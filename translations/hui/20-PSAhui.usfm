\q2 tini habane nabulene kamarunida lo manda bilo helabe.   
\ms1 MBUGA MANE  
\mr (Iba Gana 90-106)  
\c 10  
\s1 Anduane Homogohanda biamogo bilonaga bi lenego ogo  
\q1
\v 1 Anduane Homogo-o irane aginaga ina helalu í̠ kaundia kebe.  
\q2 Ko ina kamaria íbu ngagola í̠ ha do ho kego irane agibe.   
\q1
\v 2 Wali agali mini kowi karume mine halu  
\q2 wali agali yagibano karu mo ko hole talima ibaga bialu ka.  
\q1 Tigua uli tombo wuwa maru uli pelo ngaria  
\q2 habo lalu tini uli ogoniha uli pelo hame ledo.\x + \xo 10.2 \xt Iba 7.16, 9.15, Min 5.22\x*   
\b  
\q1
\v 3 Wali agali ko biagarume tinaga miniha mana ko hame lararunaga mine haga ka.  
\q1 Mbiralime mbirale bu ngaru dimagoli hai haga karume  
\q2 Anduane Homogohondo bi ko lalu erembira miaga ka.\x + \xo 10.3 \xt Iba 94.4, Lm 1.32\x*   
\q1
\v 4 Wali agali ko karume Anduane Homogo mitangi nabiaga ka.  
\q1 Tigua mine howa lalu,  
\q2 Ngode Datagaliwabe ibugua i̱ ko birugonaga pani nangulebira, laga ka.\x + \xo 10.4 \xt Iba 14.1-2, 53.1\x*   
\b  
\q1
\v 5 Mini kowi karume biraru damene bibahende mbirale dewa mo mogo biaga ka.  
\q2 Anduane Homogo-o í̠naga mini wu kego ti manda nabiore kagoni.  
\q1 Tigua tinaga waitigi karu mege biaga ka.\x + \xo 10.5 \xt Iba 12.5, Ais 26.11\x*   
\q1
\v 6 Tigua hangu hangu mitangi bialu,  
\q2 I̱ hongoheore kogoni.  
\q2 Mbirale tara tara ngarume i̱ bope naholebiraore.  
\q2 I̱ kogoha genda mbira anda naibulebira,  
\q1 lo mitangi biaga ka.\x + \xo 10.6 \xt Ais 56.12, Mo 18.7\x*   
\q1
\v 7 Bibahendengi tigua bi ko laabo halu maru karu ha haga ka.  
\q1 Ke̱ howa mendeali kago mo gi hole bi laabo haga ka.  
\q1 Mana ko bulenenaga bi ko ngaru  
\q2 tigua abale yamialu lo pebe bialu haga ka.\x + \xo 10.7 \xt Yob 20.12, Iba 12.2, Lm 3.14\x*   
\b  
\q1
\v 8 Wali agali ko ogonidagua biaga karume  
\q2 wali agali maru bayale kago bo wahole  
\q2 ohowa harigani bira do haga.  
\q1 Mbirali hongo nahe kago mo ko hole  
\q2 ohowa harigani bira do haga ka.\x + \xo 10.8 \xt Iba 17.11, Hab 3.14\x*   
\q1
\v 9 Laionome ibu nagane ale ibirago balu nole  
\q2 ohowa yu biragadagua ti biraga ka.  
\q1 Wali agali yagibano porago minule  
\q2 harigani ohowa yu biraga ka.  
\q1 Ibalu karia gono wiyagoha do ngaria  
\q2 abale hado yalu piaga ka.\x + \xo 10.9 \xt Iba 17.12, Mai 7.2\x*   
\b  
\q1
\v 10 Tigua hendore oho biruwa  
\q2 tinaga hongo timbuni daligaorehe kagome  
\q2 mbirali hongo nahe kago abale mo ko haga ka.   
\q1
\v 11 Wali agali ko urunibi karu tigua lo manda bialu,  
\q2 Mana i̱na berogo Ngode Datagaliwabe ibu mitangi nabiaga kagoni.  
\q2 Ibu de muguliho kagonigo  
\q2 i̱na berogo de nahondolebira ndobe,  
\q1 laga biaga kagoni.\x + \xo 10.11 \xt Yob 22.13, Iba 94.7, Ese 9.9\x*   
\b  
\q1
\v 12 Anduane Homogo-o í̠na ko biaga karu bole  
\q2 í̠naga gi yaraga howa nende biaho habe.  
\q1 Ngode Datagaliwabe-o í̠na hongo nahe karu biamogo bule embeda nahabe.   
\q1
\v 13 Wali agali ko biaga karume  
\q2 Ngode Datagaliwabe í̠ mege bialu erembira ngiaga kagoni.  
\q1 Tinaga miniha lo manda bialu,  
\q2 I̱na ko berogonaga pani nangulebira, laga biaga kagoni ndobe.  
\q1 Mini urunibi wiaga karuni í̠na bo wahai habe nahedane kebe.   
\b  
\q1
\v 14 Í̠na wali agali ko biaga urunime mana biaga ngago\x + \xo 10.14 \xt Iba 68.5, 2 Ti 1.12, 1 Pi 4.19\x*  
\q2 manda biaiho ke.  
\q1 Ko urunibi kagome wali agali maru bu karu genda mo miaga ngago damene  
\q2 í̠ manda biaiho kegoni.  
\q1 Í̠na wali agali genda uruni yu karu biamogo biaga kegoni.  
\q1 Wali agali hongo nahe karubi  
\q2 waneigini aba ai̱yala homene karubi  
\q2 í̠na ti biamogo biaga kego manda buwa ti í̠niha hanaho kagoni.   
\q1
\v 15 Wali agali mana ko biaga urunime ko birago mani nabilo  
\q2 tinaga hongo kago bo podai habe.   
\b  
\q1
\v 16 Anduane Homogo ibu kini haluheore kagoni.\x + \xo 10.16 \xt Iba 145.13, Yar 10.10, Dan 4.34, 1 Ti 1.17\x*  
\q1 Wali agali hameigini tara tara bibahende ibu mitangi nabiaga karu  
\q2 ibunaga dindi ngagoria howa bo taliatagi halu ereba hai helolebira.   
\b  
\q1
\v 17 Anduane Homogo-o í̠na wali agali í̠ni andaneha karume bi larago hale howa  
\q2 tinaga bu mini mo hongo harili.\x + \xo 10.17 \xt Har 22.23, Iba 9.12\x*   
\q1
\v 18 Waneigini aba ai̱yala homene karumebi  
\q1 wali agali genda yu karumebi  
\q2 dugu bialu í̠hondo bi lalu karu hale harili.  
\q1 Tinaga godi tigabi lolene ngadagua lelo  
\q2 í̠na ti biamogo bulebere.  
\q1 Í̠na ogonidagua beregola  
\q2 dindiali karume ti lone mo ko holene mbira nawulebira.\x + \xo 10.18 \xt Iba 82.3, Ais 11.4\x*   
\c 11  
\s1 Anduane Homogohondo mini mbiraore hongohe wu kago ogo  
\q1
\v 1 Anduane Homogohanda i̱ handayaho holebiragonaga\x + \xo 11.1 \xt Iba 2.12, 121.1\x*  
\q2 mini mbiraore wu ko.  
\q1 Egame agali ibirago handalu ibida piagadagua  
\q2 tígua i̱hondo, Hari bare ngaruha ha do hole ibida pu, laga kamiruni  
\q2 tí lulu mini nawi be tobaheda.   
\q1
\v 2 Tígua lalu, Agali ko biagome agali bayale kago bole\x + \xo 11.2 \xt Iba 7.12, 37.14, 64.3-4\x*  
\q2 ibu aruma kagoha howa timu edaho kagoni.   
\q1
\v 3 Wali agali bibahendeme mana tigabi ngago nabiaga heagua nde\x + \xo 11.3 \xt Iba 87.1, 119.152\x*  
\q2 mbirali tigabi kago ibugua ago bulene wiaruabe, lalu kami.   
\b  
\q1
\v 4 Anduane Homogo ibu ibunaga anda lomabia heneha kagoni.\x + \xo 11.4 \xt Mai 1.2, Md 5.34\x*  
\q1 Ibu dahuliya andaga kini howa  
\q2 ibugua wali agali bibahende bu karu de handaiore ka.  
\q1 Wali agalime bialu karuni ibu manda biaiore kagoni.   
\q1
\v 5 Anduane Homogo ibugua wali agali ko biaga bayale biagabi manda bu ka.\x + \xo 11.5 \xt Pig 22.1, Iba 34.19, Ya 1.12\x*  
\q1 Ibugua wali agali mana lo ngaru wahaga karu handabe manga haga ka.   
\b  
\q1
\v 6 Wali agali ko biaga bu kagoha\x + \xo 11.6 \xt Iba 75.8, Yar 4.11-12, Ese 38.22\x*  
\q2 ibugua ira hungubi ege to̱le̱ ambuabi mini soloba dedaore hedope holebira.  
\q1 Puyabu pobo timbuniorebi ibilalu ti pani nalu holebira.   
\q1
\v 7 Irane Anduane Homogo ibuni mini tigabi howa\x + \xo 11.7 \xt Iba 7.9-11, 16.11, 33.5\x*  
\q2 mana bayale tigabi biraru hondowa turuho haga ka.  
\q1 Wali agali mana bayale tigabi biaga karu  
\q2 tigua ibuninaga wanakui hondolebira.   
\c 12  
\s1 Anduane Homogohanda biamogo bilonaga bi lenego ogo  
\q1
\v 1 Anduane Homogo-o í̠na i̱ biamogo bibe.\x + \xo 12.1 \xt Ais 57.1, Mai 7.2\x*  
\q1 Mbirali bayale mbira naheorego.  
\q2 Tigabi biaga mbira karia nahondolebere.   
\q1
\v 2 Wali agali bibahendeme ke̱ dege haga ka.\x + \xo 12.2 \xt Iba 41.6, Yar 9.8, Lm 16.18\x*  
\q2 Tigua mendeali kago mo guya halu bi ladebodebo biaga ka.   
\b  
\q1
\v 3 Anduane Homogo-o wali agali bi ladebodebo biaga karunaga ne harigabi  
\q2 mine haga karunaga hégebi  
\q2 bibahende bo ndibu lai habe.   
\q1
\v 4 Wali agali ko biaga uruni tigua lalu,  
\q2 Inanaga hégeme wayali holeberama.  
\q2 Inanaga ne hambu anduane aibe.  
\q1 Ina handayaho haruago aibe, laga biaga ka.   
\b  
\q1
\v 5 Anduane Homogo ibugua lalu,\x + \xo 12.5 \xt Iba 10.18, 34.6, 35.10, Ais 33.10\x*  
\q1 Ko biaga bu karume yagibano karu hengedape hayadago hondowabi  
\q2 burupale karu ti dugu biaruago hale howabi  
\q2 i̱ni abale ibulebero.  
\q1 Tini bayale holenenaga maliaho karu  
\q2 i̱na ti ogoriani mo helolebero, laya.   
\b  
\q1
\v 6 Anduane Homogonaga bi lo winigo bibahende heneneore lo nga.\x + \xo 12.6 \xt Iba 119.140, Min 30.5\x*  
\q1 Ibunaga bi bayaleore laganego  
\q2 siliba irani ka halu delene ngarale ngaligobiore ngagoni.   
\b  
\q1
\v 7 Anduane Homogo-o í̠nime ina bu kamaru\x + \xo 12.7 \xt Iba 37.28, 97.10\x*  
\q2 baya hangu de handayaho habe.  
\q1 Ko biaga karume ina mo ko holigo  
\q2 í̠na ina baya hangu mamageho haabo habe.   
\q1
\v 8 Ko biaga karu tigua dindi bibahendeha mine halu ibaga biame haga ka.\x + \xo 12.8 \xt Iba 55.10-11\x*  
\q1 Wali agali bibahende karume mana ko bulenego hame lowa  
\q2 mana ogoni bayaleda mitangi biaga ka.   
\c 13  
\s1 Anduane Homogohanda biamogo bilo bi lenego ogo  
\q1
\v 1 Anduane Homogo-o í̠na i̱ angi mitangi bule kebe.\x + \xo 13.1 \xt Yob 13.24, Iba 88.14, Ais 59.2\x*  
\q1 Í̠na i̱ embeda halu yu waore haribe.  
\q1 Í̠naga dengui lone hondoliya  
\q2 i̱hondo angi mo walia holeberebe.   
\q1
\v 2 I̱ genda yu kogonigo angi mo waholeberebe.  
\q1 I̱ miniha tandaga ngelo koruni  
\q2 horombe mbiragabi agiru hondo holeberebe.  
\q1 I̱ waitigi karunaga andaneha naholiya  
\q2 í̠na i̱ angi biamogo buleberebe.   
\b  
\q1
\v 3 Anduane Homogo i̱naga Ngode Datagaliwabeore-o\x + \xo 13.3 \xt Yar 51.39\x*  
\q2 Í̠na i̱ mitangi halu i̱naga bi larogo hale habe.  
\q1 I̱ nahomoliya i̱naga de mo ngalalu lone mo hongo habe.   
\q1
\v 4 I̱ homaruyagua i̱naga waitigime lalu,\x + \xo 13.4 \xt Iba 25.2, 35.19, 38.16\x*  
\q2 Iname ibu bope harimadagoni, loligo nalelo.  
\q1 Tigua i̱ pilarogo hondowa turu holigo nahelo.   
\b  
\q1
\v 5 Ani lolebiragoyu í̠na i̱ gubalini holebeda lo manda bialu  
\q2 mini mbiraore wu kogoni.  
\q1 Í̠na i̱ pele ngiaabo holeberegonaga  
\q2 i̱ turu timbuniore ho kogoni.   
\q1
\v 6 Anduane Homogo í̠na i̱hondo bayale dege biaabo harigonaga\x + \xo 13.6 \xt Iba 116.7, 119.17\x*  
\q2 i̱na í̠naga mini yaraga halu  
\q2 iba gana laga bialu holebero.   
\c 14  
\s1 Wali agali mini kowinaga mana ogo  
\r (Iba Gana 53)  
\q1
\v 1 Wali agali mitangi yole biaga karume tini miniha mandabu donge halu\x + \xo 14.1 \xt Iba 10.4, 53.1\x*\x + \xo 14.1 \xt Lm 3.10-12\x*  
\q2 Ngode Datagaliwabe ogoni nahe laga ka.  
\q1 Wali agali mini urunibi wu karuni tini ko ngubi habane nabuleneore howa  
\q2 ko tara tara ngaru bima polenaga ani lalu ka.  
\q1 Mana tigabi hangu biaga mbirali naheore.   
\b  
\q1
\v 2 Anduane Homogohanda dahuliya andaga howa handadali halu\x + \xo 14.2 \xt Iba 33.13, 102.19\x*  
\q1 wali agali bibahende bu karu de handame howa  
\q2 mbirali miniwi galone manda biagabi  
\q2 Ngode Datagaliwabe kalo manda bu hagabi  
\q1 au haga bidabe hondole handadali ho ka.   
\q1
\v 3 Ani handalu karia mbirali bayale naheore  
\q2 ti bibahende ko biai hene ogobi dege dege hoyu pedaria hendeda.  
\q1 Hariga tigatiga polene wiadaguaore pene mbirali naheore  
\q2 bibahende putagi halu piai hene dege hearia hendene.  
\q1 Mana tigabi hangu biaga mbira naheore.  
\q1 Mbiraoreorebi mbira naheore lama agini.   
\b  
\q1
\v 4 Anduane Homogohanda lalu,\x + \xo 14.4 \xt Ais 64.7, Yar 10.25, Amo 8.4\x*  
\q1 Wali agali ko biaga uruni ti mini nawidabe.  
\q1 Ti galone mbira manda nabiagadabe.  
\q1 Wali agali ko biaga urunime  
\q2 i̱naga wali agali bameore ti tomo naradagua budu nalu kagoni.  
\q1 Ani bialu howa tigua tinaga bu minime i̱hondo bi mbira nalagaore kagoni, lalu ka.   
\b  
\q1
\v 5 Ani bialu ha kagoyu Ngode Datagaliwabe ibuni  
\q2 wali agali ibugua bi larago hale halu biaga karu baba howa  
\q2 biamogo bigi birago hondowa  
\q1 ti gi timbuniore howa duru ala lalu holebira.   
\b  
\q1
\v 6 Wali agali ko biaga karume\x + \xo 14.6 \xt Iba 9.9, 142.5\x*  
\q2 wali agali maru abogo ka nalene karunaga minime mbirale bule mandabu wigi bidaru  
\q2 mo pere laga biaga ka.  
\q1 Ani bia biyaguabi wali agali abogo ka nalene uruni  
\q2 tinaga ha do holene Anduane Homogoha ngagome ti bayale holebira.   
\b  
\q1
\v 7 I̱na Isaraele wali agali bibahende pele ngialu haru dai biai helo\x + \xo 14.7 \xt Yob 42.10, Iba 53.6, 126.1\x*  
\q2 Ngode Datagaliwabehanda mbirali Saiono howa ibi nalara.  
\q1 Anduane Homogohanda ibunaga wali agali biamogo biragola  
\q2 ti bayuwa ho dungulo halu  
\q1 tigua mbirale bigi biraru bayale hangu haga birago hondowa  
\q2 tini turuore nde au holobadabe.   
\c 15  
\s1 Ngode Datagaliwabehanda iname mana buluma̱ya hame ledago ogo  
\q1
\v 1 Anduane Homogo-o mbirali í̠naga andaha anda ibabehe ai kabe.\x + \xo 15.1 \xt Iba 23.6, 24.3, 27.4, 61.4\x*  
\q1 Mbirali Hari Saiono wali agali ge nahaga  
\q2 í̠ni dege haga ngegoria íbu howa  
\q2 í̠ mitangi bialu í̠hondo bi labehe ai kabe.   
\b  
\q1
\v 2 Mbirali Ngode Datagaliwabehanda bibe ledadaguaore hale howa biai halu\x + \xo 15.2 \xt Ais 33.15, Seg 8.16, Eb 4.25\x*  
\q1 mana tigabi bulene ngadaguaore bialu  
\q2 ibugua bi larago henene hangu lalu  
\q1 ibu bu miniha ke̱ holene mbira nawi kago ibuore anda pobehe ka.   
\q1
\v 3 Tindule mbiralinaga mini mo ko hole ndinde lowa\x + \xo 15.3 \xt Har 23.1, Iba 28.3, 50.20\x*  
\q2 agua laya laya lama ibaga nabiaga kago  
\q2 ibu anda pobehe ka.  
\q1 Mbirali ogonibi kago ibugua ibunaga damenehondo kagua nabiaga ka.  
\q2 Wali agali mendeali lo guralu diburibu lama ibaga nabiaga ka.   
\q1
\v 4 Ani bialu wali agali maru Ngode Datagaliwabehanda handabe manga halu erembira mini karu\x + \xo 15.4 \xt Yos 9.18-20, Hgn 11.35, Ab 28.10\x*  
\q2 mbirali ogoni ibuguabi handabe manga halu erembira dege mulebira.  
\q1 Anduane Homogo ibugua bibe ledadagua hale halu biaga karu hondowa  
\q2 ibu turu halu wali agali uruninaga mini mo yaraga haga ka.  
\q1 Ibugua mbirale mbira buleore lalu lo winiyagua  
\q2 o lenedagoni gendabi bibe naheoreyaguabi tanabi biaore bulebira.   
\q1
\v 5 Mbiralime ibuhondo mbirale mbira dano habiya ngibe layagua mialu\x + \xo 15.5 \xt Man 16.19, Ese 18.8\x*  
\q2 danoali biagome yadai biragola nde huniane mbira pu helowa ndo  
\q2 ibugua miyagobiore yadai bia lowa mo yulebira.  
\q1 Marume ibuhondo dange hana howa  
\q2 mendeali kagua nabini tigabi kago ndelo ngibe layagua  
\q2 ibu ani nabiaga ka.  
\b  
\q1 Mana bayale urunibi biaga karu ti ema nabi haabo holebira.   
\c 16  
\s1 Mbirali ibu Ngode Datagaliwabehondo mini mbiraore wuwa miniha dungulo howa ibuhondo bi lenego ogo  
\q1
\v 1 Ngode Datagaliwabe-o i̱ í̠ha ha doho howa bayale holebero manda buwa\x + \xo 16.1 \xt Iba 7.1, 17.8\x*  
\q2 í̠ kegoria eberogo í̠na i̱ de hondo habe.   
\q1
\v 2 I̱na Anduane Homogohondo au laro.  
\q2 Í̠ i̱naga Anduane kegoni.  
\q1 Mbirale bayale bayale o bu ngoruni  
\q2 í̠naga gini howa ibini hangu o bu ngoruni laro.   
\b  
\q1
\v 3 Anduane Homogonaga wali agali mini bilinahe karu\x + \xo 16.3 \xt Iba 101.6, 119.63\x*  
\q2 ti wali agali bayaore bu kagoni.  
\q1 I̱ ti heba mandagi howa turu timbuniore ho haga biruli.   
\b  
\q1
\v 4 Wali agali maru mbirale gime wabiniru tinaga bi pupu wiagane ogoni lowa\x + \xo 16.4 \xt Yos 23.7, Iba 32.10, 106.37-38\x*  
\q2 uruni hendehende gerai piaga karu  
\q2 tigua genda yulene dewaore bu wulebira.  
\q1 I̱na ti heba mandagi howa  
\q2 bi pupu wiagane urunihondo mbirale bo lomabu miradagua namulebero.  
\q1 Mbirale gime wabini uruni tinaga bi pupu wiagane ogoni lowa  
\q2 uruninaga mini mo yaraga haradaguabi i̱ naholebero.   
\b  
\q1
\v 5 I̱ mbirale galone yu haradagua bu kogo\x + \xo 16.5 \xt Iba 23.5, 119.57, 125.3, Dug 3.24\x*  
\q2 Anduane Homogo í̠bi í̠naga bi manabi ogoni dege galone yido lowa yu kogoni.  
\q1 I̱ mbirale buru pado alego í̠na ngiaiore hariligoni.  
\q1 I̱ mani hama polobodagoni í̠na haru holebere lowa  
\q2 í̠ha hanaho kogoni.   
\q1
\v 6 Í̠na i̱hondo mbirale bayale bayaleru turu halu ngigi birigoni.\x + \xo 16.6 \xt Yar 3.19\x*  
\q1 Í̠na o ngigi biriyaruni nde baya taraore ngigi biriyago hondowa i̱ turuore ho kogoni.   
\b  
\q1
\v 7 Anduane Homogo ibugua i̱ mo tiga bialu haru haganegonaga\x + \xo 16.7 \xt Iba 73.24, 77.6\x*  
\q2 i̱na ibunaga mini mo yaraga haro.  
\q1 I̱ mbiraga padoria i̱naga bu miniha howa bi langiaga.   
\q1
\v 8 Anduane Homogo ibuni kawareore i̱ heba o kagonida lo manda buore haabo haruli.\x + \xo 16.8 \xt Iba 27.8, 73.23\x*\x + \xo 16.8 \xt Ab 2.25-28\x*  
\q1 Ibuni kaware i̱ heba howa i̱ mo hongo haga kago manda buwa  
\q2 i̱ gi halu mogo nale holebero.   
\b  
\q1
\v 9 Anigo i̱ turu howa i̱naga bu miniha dunguore lowa\x + \xo 16.9 \xt Iba 13.5, 30.12, 108.1\x*  
\q2 mbirale mbira hondowa gi naholeore kogoni.   
\q1
\v 10 I̱ homolene winigoria howa\x + \xo 16.10 \xt Iba 49.15, 86.13, Ab 13.35\x*  
\q2 homanaga hongome yani nahelonaga í̠na i̱ gi miriligoni.  
\q1 I̱na í̠naga biabe bialu mini bilina ho harugonaga  
\q2 í̠na i̱ humbirini andaga homa dinini bu karu baba holiya wahalu  
\q2 yupe naholebere lo manda bido.   
\b  
\q1
\v 11 Í̠nime i̱hondo haabo holene hariga ogodagua lalu\x + \xo 16.11 \xt Iba 36.7-8, 43.4\x*  
\q2 walia holebere lo manda bido.  
\q1 Í̠ni i̱ heba kegome i̱ miniha turu bialu dunguore laragola  
\q2 turuho haabo haruli.   
\c 17  
\s1 Debidi ibu mini tigabi howa Anduane Homogohondo bi lenego ogo  
\q1
\v 1 Anduane Homogo-o í̠na i̱naga bi larogo hale habe.  
\q1 I̱ tigabi ibaga bu henego  
\q2 ai i̱naga genda ngaru í̠ keria mo yalu eberogoni.  
\q1 I̱na í̠hondo bi ke̱ howa ndo larogo hale habe.   
\q1
\v 2 Í̠na i̱ biamogo beregome  
\q2 i̱na godi lalu wayali holebero.  
\q1 Í̠na mana bayale ogo nga de handabelo hame ledogoni.   
\b  
\q1
\v 3 I̱naga miniha ngogo í̠ manda biaiho ke.\x + \xo 17.3 \xt Iba 16.7, Seg 13.9, Mal 3.2-3, 1 Pi 1.7\x*  
\q1 Í̠na mbiraga ibuwa i̱ ba handariyagua  
\q2 mini ko i̱ha mbira ngaria handa nabulebere ndobe.  
\q1 I̱na i̱ninaga ne harigaha howa bi ko nalolebero lo wirugoni.   
\q1
\v 4 Agali maru karume bi ko lagadagua i̱ nalaga kogoni.  
\q1 I̱na í̠naga bi lowini ngago hongo howa yu halu  
\q2 keba holenebi wai bulene ngarubi bibahende erembira miai harugoni.   
\q1
\v 5 I̱na í̠naga hariga ngagoria pialu kogome\x + \xo 17.5 \xt Iba 119.133\x*  
\q2 i̱naga geme hariga mendeha pubagi nahene kogoni.   
\b  
\q1
\v 6 Ngode Datagaliwabe-o i̱na í̠hondo bi larogola í̠ hale harili.  
\q1 Ani kego manda bialu  
\q2 i̱na í̠hondo bi áyu larogo haleore habe.   
\q1
\v 7 Í̠naga gubalini holene timbuniore ngego\x + \xo 17.7 \xt Iba 31.21\x*  
\q2 ina kamagohondo mo walia habe.  
\q1 Í̠na í̠naga gi tigame ina yania haga kegonigo  
\q2 ina waitigi hondoligo í̠ni andaneha ha do kama.   
\b  
\q1
\v 8 Í̠ninaga deore baya hangu handayaho harilidagua\x + \xo 17.8 \xt Man 32.10, Iba 91.1, 91.4, Seg 2.8, Md 23.37\x*  
\q2 i̱ handayaho habe.  
\q1 Ega angibunime ibu igini babaganeme dambi hagadagua  
\q2 i̱ mo do howa handayaho habe.   
\q1
\v 9 Agali ko karume i̱ mo ko nahelobi  
\q2 i̱naga waitigi ho mabu bupe karume i̱ bo wa nahelobi  
\q2 ani handayaho habe.   
\b  
\q1
\v 10 Tigua agali mende kago dara nahagaore ka.\x + \xo 17.10 \xt 1 Sml 2.3, Yob 15.27, Iba 73.7\x*  
\q1 Tigua bi hongo howa laabo halu  
\q2 tininaga mini hangu yaraga halu bi laga kagoni.   
\q1
\v 11 Tigua i̱ ge porogoha talima ibaga bialu  
\q2 i̱ ho mabu bupe haiho kagoni.  
\q1 Tigua i̱ gi dolaho yu ibaga bialu  
\q2 i̱ bope hole manda mandabu ka.   
\q1
\v 12 Ti laiono gabua ale howa  
\q2 mbirale ema bialu porago minu bo nole lowa ha do haga ka.  
\q1 Laiono daluame mbira bo nole yu bira do ho hagadagua  
\q2 i̱ bo wahole manda manda bu hai ka.   
\b  
\q1
\v 13 Anduane Homogo-o í̠ ibalu  
\q2 waitigi bu karu baba wai bialu ti bope hai habe.  
\q1 Í̠naga ayu tibu ne gadele biago yu ibalu  
\q2 waitigi karu bo wahai habe.  
\q1 Agali ko uruninaga giha howa  
\q2 i̱ mo wialu haru dai bibe.   
\q1
\v 14 Anduane Homogo-o  
\q2 agali ko uruni ti dindini wini ngaru hangu mo tene haga bu karu  
\q2 tinaga giha koria í̠naga hongome i̱ mo wialu biamogo bibe.  
\q1 Wali agali í̠ hame nalaga ho karu  
\q2 ti pani karulape nelo mibe.  
\q1 Tinaga waneigini aguanene maha holebiraruhondobi  
\q2 pani mia dege bibelo hameledo.   
\b  
\q1
\v 15 Ai i̱ni agali tigabiore kogodago\x + \xo 17.15 \xt Iba 4.6-7, 16.11, 1 Yo 3.2\x*  
\q2 mani í̠ninaga denguiore hondolebero.  
\q1 De ngalalu heyu howa í̠ kegobi hondowa  
\q2 i̱ turu timbuniore holebero.   
\c 18  
\s1 Anduane Homogohanda biamogo biragola ina wayali holeberema lenego ogo  
\r (2 Samuele 22.1-51)  
\q1
\v 1 Anduane Homogo-o í̠na i̱ mo hongo haga kegoni.  
\q2 I̱na í̠hondo gubaliniore ho kogoni.   
\b  
\q1
\v 2 Anduane Homogo ibuni i̱naga wai pabe hongoheore kagoni.\x + \xo 18.2 \xt Hi 2.13\x*  
\q1 Ibu ege to̱le̱ ale howa i̱ ho gehalu  
\q2 waitigirunaga giha howa i̱ mo wiaga.  
\q1 Ibu i̱naga humbi ale howa ibugua i̱ hapai haga ka.  
\q2 Ibugua i̱ mo wialu handayaho holene hongo karulapeore kagoni.   
\q1
\v 3 Anduane Homogonaga mini yaraga hami̱ya.  
\q1 I̱na ibu olalu haruli.  
\q1 Ibugua hale halu i̱ biamogo bialu  
\q2 i̱naga waitigirunaga giha howa i̱ mo wiaga kagonaga  
\q1 iname ibunaga mini yaraga holene nga.   
\b  
\q1
\v 4 I̱ homolene kawareni harugoni.\x + \xo 18.4 \xt Iba 116.3\x*\x + \xo 18.4 \xt Yna 2.5-7\x*  
\q2 Homolene pume dariba haradagua i̱ dariba hayagoni.  
\q1 Iba li hongoheme ibalu dambi haradagua  
\q2 agali ko bu karume i̱ bo wahole ani biyagoni.   
\q1
\v 5 Homolene dameneme i̱ mabu bupe howa pume dariba haradagua biyagoni.  
\q2 Homalime i̱ minule mandabu hayagoni.   
\q1
\v 6 I̱naga miniha genda ho howa Anduane Homogo olalu harugoni.  
\q2 I̱naga Ngode Datagaliwabehondo i̱ biamogo bia lalu harugoni.  
\q1 Ibuni andaga howa i̱naga bi hale haya.  
\q2 Ibuhondo i̱ biamogo bia larugo hale hayagoni.   
\b  
\q1
\v 7 Ngode Datagaliwabe ibugua keba timbuniore howa  
\q2 dindi mo dumbirumbi bilaya.  
\q2 Dindi hari timbuni wearu mo emabia hayagola ema bia gimbu biya.   
\q1
\v 8 Ibunaga ngui harigaha howa ira hagua tagira ibalu  
\q2 ibunaga ne harigaha howa ira hungu datagitagi biyagome  
\q1 mbirale wiaru bibahende do mundu laya.   
\q1
\v 9 Ibugua hari daliga buda edene bialu daliape haya.  
\q2 Daliape hayagola hari beraliba mindibi ibu geha hai haya.   
\q1
\v 10 Ibunaga dahuliyali mbiranaga erekunini biralu yagalalu daliape haya.\x + \xo 18.10 \xt Iba 104.3\x*  
\q2 Puyabu ega babagane aleheme ibu yalu abaleore daliape haya.   
\q1
\v 11 Aruma holeneme ibu dambi hai haya.  
\q2 Hari beraliba mindibigome ibuni ho ge hayagoni.   
\q1
\v 12 Hari daba timbuni ibu heagoha bialu  
\q2 kulu megelalu wá timbuni hama ibu mo bamba halu piya.  
\q1 Iramebi dalu dindi kunimebi beraliba mindibi biago bo haealabaga bialu ibira helaya.   
\b  
\q1
\v 13 Anduane Homogo ibuni hari daligaha howa bi hongo howa hari kilikulu laradagua biayua.  
\q2 Anduane Homogo Daligaorene Daliga kagonaga bi layuago hale hene.   
\q1
\v 14 Ibugua ibunaga timu edalu ba amunana biyagome waitigi purogo laya.  
\q2 Hari dabame waitigi bu hearu bayagola ti ibida bilibulu lalu piai haya.   
\q1
\v 15 Anduane Homogo í̠na waitigi hearuhondo keba harigome  
\q2 í̠naga ngui harigaha buhe̱ tagira ibiyagome puyabu hongohe pulo yu purogo laradagua biya.  
\q1 Iba solowara timbuni bereago hundiai hayagola  
\q2 dindi andaneha gene wiyago bame ha pana ho haya.   
\b  
\q1
\v 16 Anduane Homogo ibu daligaha howa gi yupe halu i̱ minu yania haya.  
\q2 Iba solowara timbuni bereagome i̱ dambi hewaria ibugua i̱ gini miya.   
\q1
\v 17 I̱naga waitigi hongoheore hearunaga giha hewaria ibugua ibuninaga gime i̱ mo wiya.  
\q1 Agali marume i̱ handabe manga ho hearu i̱na ti bo podabe nahe hewariabi  
\q2 ibugua i̱ mo wialu haru dai biya.   
\q1
\v 18 Bamba i̱ha genda ngelo hewangi tigua i̱la wai bule ibiya.  
