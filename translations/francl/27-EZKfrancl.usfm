\v 9 \w Je|strong="H03588"\w* \w te|strong="H03068"\w* \w réduirai|strong="H05414"\w* \w en|strong="H05414"\w* \w solitudes|strong="H08077"\w* \w éternelles|strong="H05769"\w*, \w et|strong="H03068"\w* \w tes|strong="H05414"\w* \w villes|strong="H05892"\w* \w ne|strong="H03068"\w* \w seront|strong="H05892"\w* \w plus|strong="H03808"\w* \w habitées|strong="H03427"\w*\f + \fr 35:9 \ft 9. \ft \+it Ne seront plus habitées\+it* ; d’après les LXX. Hébr. \+it ne reviendront pas\+it*, ne seront pas rétablies.\f* ; \w et|strong="H03068"\w* \w vous|strong="H03068"\w* \w saurez|strong="H03045"\w* \w que|strong="H03588"\w* \w je|strong="H03588"\w* \w suis|strong="H01961"\w* \nd \+w Yahweh|strong="H03068"\+w*\nd*.   
\p
\v 10 \w Parce|strong="H03282"\w* \w que|strong="H03282"\w* \w tu|strong="H00834"\w* \w as|strong="H03426"\w* \w dit|strong="H00559"\w* : « \w Les|strong="H03068"\w* \w deux|strong="H08147"\w* \w nations|strong="H01471"\w*\f + \fr 35:10 \ft 10. Les deux royaumes de Juda et d’Israël.\f* \w et|strong="H03068"\w* \w les|strong="H03068"\w* \w deux|strong="H08147"\w* \w pays|strong="H00776"\w* \w seront|strong="H01471"\w* \w à|strong="H03068"\w* \w moi|strong="H06440"\w*, \w et|strong="H03068"\w* \w nous|strong="H03068"\w* \w en|strong="H03068"\w* \w prendrons|strong="H03947"\w* \w possession|strong="H03423"\w* ! » — \w et|strong="H03068"\w* \nd \+w Yahweh|strong="H03068"\+w*\nd* \w était|strong="H03068"\w* \w là|strong="H03068"\w* ! —  
