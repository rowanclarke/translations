\id OBA - Biblica® Open Ndebele Contemporary Bible
\h U-Obhadaya
\toc1 U-Obhadaya
\toc2 U-Obhadaya
\toc3 Ob
\mt1 U-Obhadaya
\c 1
\p 
\v 1 Umbono Ka-Obhadaya.
\b
\b
\p Nanku okutshiwo \nd nguThixo\nd* Wobukhosi nge-Edomi:
\q1 Sesizwe ilizwi elivela \nd kuThixo\nd*:
\q2 Kuthunywe isithunywa ezizweni ukuba sithi,
\q1 “Phakamani, asihambeni silwe laye impi”:
\b
\q1 
\v 2 “Khangela, ngizakwenza ube mncinyane phakathi kwezizwe;
\q2 uzakweyiswa kakhulu.
\q1 
\v 3 Ukuzigqaja kwenhliziyo yakho sekukukhohlisile,
\q2 wena ohlala ezingoxweni zamadwala wakhe
\q2 umuzi wakho eziqongweni,
\q1 wena ozitshela uthi,
\q2 ‘Ngubani ongangiwisela phansi enhlabathini na?’
\q1 
\v 4 Lanxa uqonga njengengqungqulu
\q2 wakhe isidleke sakho phakathi kwezinkanyezi,
\q2 ngizakwethula khonale,”
\q2 kutsho \nd uThixo\nd*.
\q1 
\v 5 “Nxa amasela efike kuwe,
\q2 nxa abaphangi ebusuku,
\q1 Awu, yeka ubukhulu bomonakalo okulindeleyo,
\q2 kabayikuntshontsha kuphela lokho okwanele abakufunayo na?
\q1 Nxa abavuni bamavini befike kuwe,
\q2 kabangeke batshiye amalutshwana na?
\q1 
\v 6 Kodwa yeka ukuphangwa okuzakwenziwa u-Esawu,
\q2 inotho yakhe efihliweyo izathunjwa!
\q1 
\v 7 Bonke abamanyane lawe bazakuxotshela emngceleni;
\q2 abangane bakho bazakukhohlisa bakunqobe;
\q1 labo abadla ukudla kwakho bazakuthiya ngomjibila,
\q2 kodwa wena kawuyikuwubona.
\b
\q1 
\v 8 Ngalolosuku,” kutsho \nd uThixo\nd*,
\q2 “kangiyikuwabhubhisa yini amadoda ahlakaniphileyo ase-Edomi,
\q2 amadoda aqedisisayo ezintabeni zako-Esawu na?
\q1 
\v 9 Amabutho akho, wena Themani, azathuthumela,
\q2 njalo bonke abasezintabeni zako-Esawu
\q2 bazacakazelwa phansi ekubulaweni kwabanengi.
\q1 
\v 10 Ngenxa yodlakela kumfowenu uJakhobe,
\q2 uzakwembeswa lihlazo;
\q2 uzachithwa nini lanini.
\q1 
\v 11 Ngosuku owema ngalo khatshana
\q2 mhla izihambi zithumba inotho yakhe
\q1 labezizweni bengena emasangweni akhe
\q2 bephosa inkatho ngeJerusalema,
\q2 wawunjengomunye wabo.
\q1 
\v 12 Akumelanga weyise umfowenu
\q2 ngosuku lokuhlupheka kwakhe,
\q1 loba uthokoze ngabantu bakoJuda
\q2 ngosuku lokubhujiswa kwabo,
\q1 loba uklamase kangaka
\q2 ngosuku lokuhlupheka kwabo.
\q1 
\v 13 Akumelanga ungene ngamasango abantu bami
\q2 ngosuku lomonakalo wabo,
\q1 loba ubeyise osizini lwabo
\q2 ngosuku lomonakalo wabo,
\q1 loba uthumbe inotho yabo
\q2 ngosuku lomonakalo wabo.
\q1 
\v 14 Akumelanga ume emahlukanandlela
\q2 ukuba ubulale ababalekayo babo,
\q1 loba unikele abaphephileyo babo
\q2 ngosuku lokuhlupheka kwabo.
\b
\q1 
\v 15 Usuku \nd lukaThixo\nd* selusondele
\q2 ezizweni zonke.
\q1 Njengalokho okwenzileyo,
\q2 yikho okuzakwenziwa kuwe;
\q2 izenzo zakho zizaphendukela
\q2 phezu kwekhanda lakho.
\q1 
\v 16 Njengokunatha elakwenzayo entabeni yami,
\q2 ngokunjalo izizwe zonke zizanatha njalonjalo;
\q1 zizanatha, zinathe kuze kube
\q2 angathi kazizange zivele zibe khona.
\q1 
\v 17 Kodwa phezu kweNtaba iZiyoni kuzakuba lokusindiswa;
\q2 kuzakuba ngcwele,
\q2 lendlu kaJakhobe izazuza ilifa layo.
\q1 
\v 18 Indlu kaJakhobe izakuba ngumlilo
\q2 lendlu kaJosefa ibe lilangabi;
\q1 indlu ka-Esawu izakuba libibi,
\q2 njalo bazayithungela ngomlilo ozayiqothula.
\q1 Akuyikuba khona abasilayo
\q2 endlini ka-Esawu.”
\q1 \nd UThixo\nd* usekhulumile.
\b
\q1 
\v 19 Abantu abavela eNegebi
\q2 bazathumba izintaba zako-Esawu,
\q1 labantu abavela emawatheni ezintaba
\q2 bazathumba ilizwe lamaFilistiya.
\q1 Bazathumba amasimu ako-Efrayimi lawaseSamariya,
\q2 loBhenjamini uzathumba iGiliyadi.
\q1 
\v 20 Lelibutho labako-Israyeli abathunjwayo abaseKhenani
\q2 lizalithatha ilizwe kusiyafika eZarefathi;
\q1 abathunjwa eJerusalema abaseSefaradi
\q2 bazathatha amadolobho aseNegebi.
\q1 
\v 21 Abakhululi bazakhwela iNtaba iZiyoni
\q2 ukuba babuse izintaba zako-Esawu.
\q2 Njalo umbuso uzakuba \nd ngokaThixo\nd*.
