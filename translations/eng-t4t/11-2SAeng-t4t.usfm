\v 2 \w So|strong="H6485"\w* \w the|strong="H3605"\w* \w king|strong="H4428"\w* said \w to|strong="H5704"\w* \w Joab|strong="H3097"\w*, \w the|strong="H3605"\w* \w commander|strong="H8269"\w* \w of|strong="H4428"\w* \w his|strong="H3605"\w* \w army|strong="H2428"\w*, “\w Go|strong="H5971"\w* \add with your officers\add* \w through|strong="H3605"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w tribes|strong="H7626"\w* \w of|strong="H4428"\w* \w Israel|strong="H3478"\w*, \w from|strong="H3478"\w* \w Dan|strong="H1835"\w* \add city in the far north\add* \w to|strong="H5704"\w* Beersheba \add town in the far south\add*, \w and|strong="H3478"\w* \w count|strong="H4557"\w* \w the|strong="H3605"\w* \w people|strong="H5971"\w*, \w in|strong="H3478"\w* order \w that|strong="H3045"\w* \w I|strong="H5704"\w* \w may|strong="H4994"\w* \w know|strong="H3045"\w* \w how|strong="H3045"\w* \w many|strong="H5704"\w* \w people|strong="H5971"\w* \add there are who are able to be soldiers in the army\add*.”
\p 
