\p
\v 13 \w Entonces|strong="G5119"\w* \w los|strong="G3588"\w* \w discípulos|strong="G3101"\w* comprendieron \w que|strong="G3754"\w* les \w hablaba|strong="G3004"\w* \w de|strong="G4012"\w* \w Juan|strong="G2491"\w* \w el|strong="G3588"\w* Bautista.   
\s1 Liberación de un lunático  
\p
\v 14 Cuando \w llegó|strong="G2064"\w* \w al|strong="G3588"\w* \w gentío|strong="G3793"\w*, \w un|strong="G3588"\w* hombre \w se|strong="G4314"\w* \add le\add* acercó, \w se|strong="G4314"\w* arrodilló ante \w Él|strong="G3588"\w*  
\v 15 \w y|strong="G2532"\w* \w le|strong="G1519"\w* \w dijo|strong="G3004"\w*: \w Señor|strong="G2962"\w*, ten compasión \w de|strong="G1519"\w* \w mi|strong="G3588"\w* \w hijo|strong="G5207"\w*, \w pues|strong="G1063"\w* es lunático \w y|strong="G2532"\w* \w padece|strong="G3958"\w* severamente. \w Porque|strong="G1063"\w* \w muchas|strong="G4178"\w* veces \w cae|strong="G4098"\w* \w en|strong="G1519"\w* \w el|strong="G3588"\w* \w fuego|strong="G4442"\w* \w y|strong="G2532"\w* \w en|strong="G1519"\w* \w el|strong="G3588"\w* \w agua|strong="G5204"\w*.  
\v 16 \w Lo|strong="G3588"\w* traje a \w tus|strong="G3588"\w* \w discípulos|strong="G3101"\w*, \w pero|strong="G2532"\w* \w no|strong="G3756"\w* fueron capaces \w de|strong="G3588"\w* sanarlo.   
\p
\v 17 \w Jesús|strong="G2424"\w* respondió: \wj ¡\+w Oh|strong="G5599"\+w* \+w generación|strong="G1074"\+w* incrédula \+w y|strong="G2532"\+w* \+w perversa|strong="G1294"\+w*! ¿\+w Hasta|strong="G2193"\+w* \+w cuándo|strong="G4219"\+w* \+w estaré|strong="G1510"\+w* \+w con|strong="G3326"\+w* ustedes? ¿\+w Hasta|strong="G2193"\+w* \+w cuándo|strong="G4219"\+w* \+w los|strong="G3588"\+w* soportaré? ¡Tráiganlo \+w acá|strong="G5602"\+w*!\wj*  
\v 18 \w Jesús|strong="G2424"\w* \w lo|strong="G3588"\w* \w reprendió|strong="G2008"\w* \w y|strong="G2532"\w* \w el|strong="G3588"\w* \w demonio|strong="G1140"\w* \w salió|strong="G1831"\w* \w de|strong="G3588"\w* \w él|strong="G3588"\w*. \w El|strong="G3588"\w* muchacho fue sanado desde \w aquel|strong="G3588"\w* momento.   
\p
\v 19 \w Entonces|strong="G5119"\w*, \w los|strong="G3588"\w* \w discípulos|strong="G3101"\w* se acercaron \w a|strong="G2596"\w* \w Jesús|strong="G2424"\w* \w en|strong="G2596"\w* privado \w y|strong="G5119"\w* \w le|strong="G2596"\w* preguntaron: ¿\w Por|strong="G1223"\w* \w qué|strong="G3588"\w* \w nosotros|strong="G2249"\w* \w no|strong="G3756"\w* \w pudimos|strong="G1410"\w* echarlo?   
\p
\v 20 Les respondió: \wj \+w Por|strong="G1223"\+w* \+w su|strong="G3588"\+w* poca \+w fe|strong="G4102"\+w*, \+w porque|strong="G1063"\+w* \+w en|strong="G1223"\+w* \+w verdad|strong="G4102"\+w* les \+w digo|strong="G3004"\+w* \+w que|strong="G3588"\+w* \+w si|strong="G1437"\+w* tuvieran \+w fe|strong="G4102"\+w* \+w como|strong="G5613"\+w* \+w un|strong="G3588"\+w* \+w grano|strong="G2848"\+w* \+w de|strong="G1223"\+w* mostaza, dirían \+w a|strong="G1161"\+w* \+w esta|strong="G3778"\+w* montaña: ¡\+w Pásate|strong="G3327"\+w* \+w de|strong="G1223"\+w* \+w aquí|strong="G1759"\+w* \+w allá|strong="G1563"\+w*! \+w Y|strong="G2532"\+w* \+w se|strong="G2532"\+w* pasaría, \+w y|strong="G2532"\+w* \+w nada|strong="G3762"\+w* les sería imposible.\wj* [[ 
\v 21 ]]   
\s1 Segunda predicción de su muerte y resurrección  
\p
\v 22 \w Cuando|strong="G1722"\w* \w estaban|strong="G3195"\w* \w en|strong="G1722"\w* \w Galilea|strong="G1056"\w* \w Jesús|strong="G2424"\w* \w les|strong="G1519"\w* \w dijo|strong="G3004"\w*: \wj \+w El|strong="G3588"\+w* \+w Hijo|strong="G5207"\+w* \+w del|strong="G3588"\+w* Hombre va \+w a|strong="G1519"\+w* ser \+w entregado|strong="G3860"\+w* \+w en|strong="G1722"\+w* \+w manos|strong="G5495"\+w* \+w de|strong="G1722"\+w* \+w unos|strong="G3588"\+w* hombres\wj*  
\v 23 \wj \+w y|strong="G2532"\+w* \+w lo|strong="G3588"\+w* matarán, \+w pero|strong="G2532"\+w* \+w al|strong="G3588"\+w* \+w tercer|strong="G5154"\+w* \+w día|strong="G2250"\+w* será \+w resucitado|strong="G1453"\+w*.\wj* \w Y|strong="G2532"\w* \w ellos|strong="G3588"\w* \w se|strong="G2532"\w* entristecieron muchísimo.   
\s1 El impuesto del Templo  
\p
\v 24 \w Al|strong="G3588"\w* llegar \w ellos|strong="G3588"\w* \w a|strong="G1519"\w* Cafarnaúm, \w los|strong="G3588"\w* \w que|strong="G3588"\w* cobraban \w las|strong="G3588"\w* \w dos|strong="G1323"\w* dracmas \w se|strong="G2532"\w* acercaron \w a|strong="G1519"\w* \w Pedro|strong="G4074"\w* \w y|strong="G2532"\w* \w dijeron|strong="G3004"\w*: ¿\w Su|strong="G3588"\w* \w Maestro|strong="G1320"\w* \w no|strong="G3756"\w* \w paga|strong="G5055"\w* didracma?\f + \fr 17:24 \ft Dracma: salario de un día, moneda de plata equivalente a un denario. Didracma: dos dracmas.\f*   
\p
\v 25 Contestó: \w Sí|strong="G3483"\w*.  
\p \w Y|strong="G2532"\w* \w al|strong="G3588"\w* llegar \w a|strong="G1519"\w* \w la|strong="G3588"\w* \w casa|strong="G3614"\w*, \w Jesús|strong="G2424"\w* \w se|strong="G2532"\w* \w le|strong="G1519"\w* adelantó \w y|strong="G2532"\w* preguntó: \wj ¿\+w Qué|strong="G3588"\+w* opinas, \+w Simón|strong="G4613"\+w*? ¿\+w De|strong="G1519"\+w* \+w quiénes|strong="G5101"\+w* \+w cobran|strong="G2983"\+w* impuestos \+w o|strong="G2228"\+w* \+w tributo|strong="G2778"\+w* \+w los|strong="G3588"\+w* reyes \+w de|strong="G1519"\+w* \+w la|strong="G3588"\+w* \+w tierra|strong="G1093"\+w*? ¿\+w De|strong="G1519"\+w* \+w sus|strong="G3588"\+w* \+w hijos|strong="G5207"\+w* \+w o|strong="G2228"\+w* \+w de|strong="G1519"\+w* \+w los|strong="G3588"\+w* extraños?\wj*   
\p
\v 26 \w Y|strong="G1161"\w* respondió: \w De|strong="G3588"\w* \w los|strong="G3588"\w* extraños.  
\p \w Jesús|strong="G2424"\w* le \w dijo|strong="G3004"\w*: \wj \+w Entonces|strong="G1161"\+w* \+w los|strong="G3588"\+w* \+w hijos|strong="G5207"\+w* están exentos.\wj*  
\v 27 \wj \+w Sin|strong="G3361"\+w* embargo, \+w para|strong="G1519"\+w* \+w que|strong="G3588"\+w* \+w no|strong="G3361"\+w* \+w los|strong="G3588"\+w* ofendamos, \+w vé|strong="G4198"\+w* \+w al|strong="G3588"\+w* \+w mar|strong="G2281"\+w*, lanza \+w un|strong="G3588"\+w* anzuelo \+w y|strong="G2532"\+w* \+w toma|strong="G2983"\+w* \+w el|strong="G3588"\+w* \+w primer|strong="G4413"\+w* \+w pez|strong="G2486"\+w* \+w que|strong="G3588"\+w* salga. \+w Al|strong="G3588"\+w* abrir \+w su|strong="G3588"\+w* \+w boca|strong="G4750"\+w*, \+w hallarás|strong="G2147"\+w* \+w un|strong="G3588"\+w* didracma. \+w Tómalo|strong="G2983"\+w*, \+w vé|strong="G4198"\+w*, \+w dáselo|strong="G1325"\+w* \+w por|strong="G1519"\+w* \+w Mí|strong="G3588"\+w* \+w y|strong="G2532"\+w* \+w por|strong="G1519"\+w* \+w ti|strong="G1438"\+w*.\wj*   
\c 18  
\s1 ¿Quién es mayor?  
\p
\v 1 \w En|strong="G1722"\w* \w aquel|strong="G3588"\w* \w tiempo|strong="G5610"\w* \w los|strong="G3588"\w* \w discípulos|strong="G3101"\w* se acercaron \w a|strong="G1722"\w* \w Jesús|strong="G2424"\w* \w y|strong="G1510"\w* \w le|strong="G1722"\w* preguntaron: ¿\w Quién|strong="G5101"\w* es \add el\add* \w mayor|strong="G3173"\w* \w en|strong="G1722"\w* \w el|strong="G3588"\w* reino celestial?   
\p
\v 2 \w Entonces|strong="G2532"\w* \w llamó|strong="G4341"\w* \w a|strong="G1722"\w* \w un|strong="G1722"\w* \w niño|strong="G3813"\w*, lo puso \w en|strong="G1722"\w* \w medio|strong="G3319"\w* \w de|strong="G1722"\w* ellos  
\v 3 \w y|strong="G2532"\w* \w dijo|strong="G3004"\w*: \wj \+w En|strong="G1519"\+w* verdad \+w les|strong="G1519"\+w* \+w digo|strong="G3004"\+w*: \+w Si|strong="G1437"\+w* ustedes \+w no|strong="G3756"\+w* \+w son|strong="G1096"\+w* transformados \+w y|strong="G2532"\+w* \+w son|strong="G1096"\+w* \+w como|strong="G5613"\+w* \+w niños|strong="G3813"\+w*, \+w de|strong="G1519"\+w* \+w ningún|strong="G3756"\+w* modo \+w entrarán|strong="G1525"\+w* \+w en|strong="G1519"\+w* \+w el|strong="G3588"\+w* reino celestial.\wj*  
\v 4 \wj \+w Por|strong="G1722"\+w* tanto \+w cualquiera|strong="G3748"\+w* \+w que|strong="G3588"\+w* \+w se|strong="G1438"\+w* \+w humille|strong="G5013"\+w* \+w como|strong="G5613"\+w* \+w este|strong="G3778"\+w* niñito \+w es|strong="G3778"\+w* \+w el|strong="G3588"\+w* \+w mayor|strong="G3173"\+w* \+w en|strong="G1722"\+w* \+w el|strong="G3588"\+w* reino celestial.\wj*   
