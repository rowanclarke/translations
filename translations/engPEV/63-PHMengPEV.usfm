\p \w You|strong="G1510"\w* know \w me|strong="G1223"\w*, \w Paul|strong="G3972"\w*, \w and|strong="G2532"\w* \w you|strong="G1510"\w* know \w that|strong="G3588"\w* \w I|strong="G2532"\w*’m \w an|strong="G2532"\w* \w old|strong="G2532"\w* \w man|strong="G5108"\w*. \w I|strong="G2532"\w* work \w for|strong="G1223"\w* \w Jesus|strong="G2424"\w* \w Christ|strong="G5547"\w*, \w so|strong="G2532"\w* \w the|strong="G2532"\w* bosses \w here|strong="G1510"\w* \w put|strong="G2532"\w* \w me|strong="G1223"\w* \w in|strong="G2532"\w* jail.  
