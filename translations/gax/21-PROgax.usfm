\v 14 Nami hamaan gatii hammeenna ifii hin fudhata; 
\q2 nami dansaalle gatii hujii dansaa ifii hin fudhata. 
\q1  
\v 15 Gowwaan waan mara dhugeeffata; 
\q2 qalbeeffataan ammoo ijjata ifii hin ilaallata. 
\q1  
\v 16 Nami qaroon waan hantuu sodaatee irraa hin deebi'a; 
\q2 nami gowwaan ammoo ifi hin eegatu; 
\q2 hin ariifatalle'e. 
\q1  
\v 17 Nami dafee aaru waan gadhee huja; 
\q2 nami mala namatti dhowu hin jibbatama. 
\q1  
\v 18 Nami hin bilchaatin gowwummaa dhaala; 
\q2 nami qalbeeffataan beekkumsa 
\q2 akka kallachaa keyata. 
\q1  
\v 19 Worri hamaan worra dansaa duratti, 
\q2 worri cubbaaleyyiin 
\q2 karra worra balcha'aa duratti gad hin jedhan. 
\q1  
\v 20 Hiyyeessi ollaa ifiitiinuu hin jibbatama; 
\q2 dureessi ammoo jaalota hedduu qaba. 
\q1  
\v 21 Nami nama tuffatu cubbaalessa; 
\q2 nami hiyyeessaaf nayu ka gammade. 
\q1  
\v 22 Worri mala hamaa dhowu 
\q2 karaa irraa goranii motii ree? 
\q2 Worri mala dansaa dhowu ammoo hin jaalataman; 
\q2 hin addatamanille'e. 
\q1  
\v 23 Jabaatanee hujiis bu'aa qaba; 
\q2 oduu callaa odeessiis ammoo 
\q2 gara hiyyumma'aa qofa nama geessiti. 
\q1  
\v 24 Qananummaan kallacha qaroole'ee ti; 
\q2 gowwummaan ammoo seesa gowwoole'ee ti. 
\q1  
\v 25 Dhugaa bayaan dhugaammessi jiruu fayyisa; 
\q2 dhugaa bayaan dharaamessi ammoo hin soba. 
\q1  
\v 26 Nami Mootii Waan Maraa sodaatu 
\q2 kushee jadduu qaba; 
\q2 ijoollee isaatiifille addee itti baqattu hin teeti. 
\q1  
\v 27 Mootii Waan Maraa sodaatiis madda jiru'uu ti; 
\q2 tiyyoo du'aa irraa nama deebisa. 
\q1  
\v 28 Ulfinni mooti'ii bacinna kolba'aa ti; 
\q2 kolbaan yoo hin jiraatin ammoo inni hin bada. 
\q1  
\v 29 Nami ossatu hubantii guddoo qaba; 
\q2 nami dafee aaru ammoo gowwummaa mudhisa. 
\q1  
\v 30 Yaadi nageyaa jiruu nafaaf kenna; 
