\v 21  \w Elisha|strong="H7725"\w* \w went|strong="H3212"\w* \w back|strong="H7725"\w* \w and|strong="H6965"\w* \w took|strong="H3947"\w* \w his|strong="H5414"\w* \w pair|strong="H6776"\w* \w of|strong="H3627"\w* \w oxen|strong="H1241"\w* \w and|strong="H6965"\w* \w slaughtered|strong="H2076"\w* \w them|strong="H5414"\w*. \w He|strong="H5414"\w* cooked \w the|strong="H5414"\w* \w meat|strong="H1320"\w* \w over|strong="H5414"\w* \w a|strong="H3068"\w* fire \w that|strong="H5971"\w* \w he|strong="H5414"\w* \w made|strong="H5414"\w* \w by|strong="H6965"\w* burning \w the|strong="H5414"\w* harness \w and|strong="H6965"\w* \w yoke|strong="H6776"\w*. \w He|strong="H5414"\w* \w gave|strong="H5414"\w* \w the|strong="H5414"\w* \w people|strong="H5971"\w* \w meat|strong="H1320"\w* \w and|strong="H6965"\w* \w they|strong="H5971"\w* ate. \w Then|strong="H6965"\w* \w he|strong="H5414"\w* \w got|strong="H6965"\w* \w up|strong="H6965"\w* \w and|strong="H6965"\w* \w followed|strong="H3212"\w* Elijah \w and|strong="H6965"\w* \w became|strong="H7725"\w* \w his|strong="H5414"\w* \w assistant|strong="H8334"\w*.   
\c 20  
\p
\v 1  \w Now|strong="H4428"\w* \w King|strong="H4428"\w* Ben Hadad \w of|strong="H4428"\w* Syria \w assembled|strong="H6908"\w* \w all|strong="H3605"\w* \w his|strong="H3605"\w* \w army|strong="H2426"\w*, \w along|strong="H5921"\w* \w with|strong="H5921"\w* \w thirty-two|strong="H7970"\w* \w other|strong="H8147"\w* \w kings|strong="H4428"\w* \w with|strong="H5921"\w* \w their|strong="H3605"\w* \w horses|strong="H5483"\w* \w and|strong="H4428"\w* \w chariots|strong="H7393"\w*. \w He|strong="H3605"\w* \w marched|strong="H5927"\w* \w against|strong="H5921"\w* \w Samaria|strong="H8111"\w* \w and|strong="H4428"\w* \w besieged|strong="H6696"\w* \w and|strong="H4428"\w* \w attacked|strong="H5927"\w* \w it|strong="H5921"\w*.  
