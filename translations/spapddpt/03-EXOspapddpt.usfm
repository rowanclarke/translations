\p
\v 32 \w Así|strong="H3651"\w* fue acabada \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w obra|strong="H6213"\w* del \w Tabernáculo|strong="H4908"\w* \w de|strong="H1121"\w* Reunión y \w de|strong="H1121"\w* \w la|strong="H3605"\w* tienda \w que|strong="H1121"\w* \w lo|strong="H6213"\w* cubría. \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w hicieron|strong="H6213"\w* según \w todo|strong="H3605"\w* \w lo|strong="H6213"\w* \w que|strong="H1121"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w ordenó|strong="H6680"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*. \w Así|strong="H3651"\w* \w lo|strong="H6213"\w* \w hicieron|strong="H6213"\w*.   
\p
\v 33 Llevaron \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w* \w el|strong="H3605"\w* \w Tabernáculo|strong="H4908"\w*, \w la|strong="H3605"\w* tienda y \w todos|strong="H3605"\w* sus utensilios: sus broches, sus tablones, sus travesaños, sus \w columnas|strong="H5982"\w* y sus basas,  
