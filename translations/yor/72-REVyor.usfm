\id REV - Biblica® Open Yoruba Contemporary Bible 2017
\h Ìfihàn
\toc1 Ìwé Ìfihàn ti Johanu
\toc2 Ìfihàn
\toc3 If
\mt1 Ìwé Ìfihàn ti Johanu
\c 1
\s1 Ọ̀rọ̀ ìṣáájú
\p 
\v 1 Ìfihàn ti Jesu Kristi, tí Ọlọ́run fi fún un, láti fihàn fún àwọn ìránṣẹ́ rẹ̀, ohun tí kò le ṣàìṣẹ ní lọ́ọ́lọ́ọ́; ó sì ránṣẹ́, ó sì fi í hàn láti ọwọ́ angẹli rẹ̀ wá fún Johanu, ìránṣẹ́ rẹ̀,
\v 2 ẹni tí ó jẹ́rìí ohun gbogbo tí ó rí, èyí ì ni ọ̀rọ̀ Ọlọ́run, àti ẹ̀rí ti Jesu Kristi.
\v 3 Ẹni ìbùkún ni ẹni tí ń kà, àti àwọn tí ó ń gbọ́ ọ̀rọ̀ ìsọtẹ́lẹ̀ yìí, tí ó sì ń pa nǹkan wọ̀n-ọn-nì tí a kọ sínú rẹ̀ mọ́, nítorí ìgbà kù sí dẹ̀dẹ̀.
\b
\s1 Ọ̀rọ̀ ìkíni àti ìyìn
\p 
\v 4 Johanu,
\b
\p Sí àwọn ìjọ méje tí ń bẹ ní Asia:
\b
\p Oore-ọ̀fẹ́ fún yín, àti àlàáfíà, láti ọ̀dọ̀ ẹni tí ó ń bẹ, tí ó sì ti wà, tí ó sì ń bọ̀ wá; àti láti ọ̀dọ̀ àwọn ẹ̀mí méje tí ń bẹ níwájú ìtẹ́ rẹ̀;
\v 5 àti láti ọ̀dọ̀ Jesu Kristi, ẹlẹ́rìí olóòtítọ́, àkọ́bí nínú àwọn òkú, àti aláṣẹ àwọn ọba ayé.
\b
\b
\p Ẹni tí ó fẹ́ wa, ẹni tí ó gbà wá kúrò lọ́wọ́ ẹ̀ṣẹ̀ wa nípa ẹ̀jẹ̀ rẹ̀,
\v 6 tí ó sì ti fi wá jẹ ọba àti àlùfáà láti sin Ọlọ́run àti Baba rẹ; tirẹ̀ ni ògo àti ìjọba láé àti láéláé. Àmín.
\q1 
\v 7 “Kíyèsi i, o ń bọ̀ nínú àwọsánmọ̀,
\q2 gbogbo ojú ni yóò sì rí i,
\q1 àti àwọn tí ó gún un ní ọ̀kọ̀ pẹ̀lú”;
\q2 àti gbogbo orílẹ̀-èdè ayé ni
\q2 “yóò sì máa pohùnréré ẹkún nítorí rẹ̀.”
\qc Bẹ́ẹ̀ náà ni! Àmín.
\p 
\v 8 “Èmi ni Alfa àti Omega,” ni Olúwa Ọlọ́run wí, “ẹni tí ó ń bẹ, tí ó ti wà, tí ó sì ń bọ̀ wá, alágbára.”
\b
\s1 Ọ̀kan gẹ́gẹ́ bí Ọmọ Ènìyàn
\p 
\v 9 Èmi, Johanu, arákùnrin yín àti alábápín pẹ̀lú yín nínú wàhálà àti ìjọba àti sùúrù tí ń bẹ nínú Jesu, wà ní erékúṣù tí a ń pè ní Patmo, nítorí ọ̀rọ̀ Ọlọ́run, àti nítorí ẹ̀rí Jesu Kristi.
\v 10 Mo wà nínú Ẹ̀mí ní ọjọ́ Olúwa, mo sì gbọ́ ohùn ńlá kan lẹ́yìn mi, bí ìró ìpè,
\v 11 Ó ń wí pé, \wj “Kọ́ ìwé rẹ̀, ohun tí ìwọ rí, kí ó sí fi ránṣẹ́ sí àwọn ìjọ méje; sí Efesu, àti sí Smirna, àti sí Pargamu, àti sí Tiatira, àti sí Sardi, àti sí Filadelfia, àti sí Laodikea.”\wj*
\p 
\v 12 Mo sì yí padà láti wo ohùn tí ń bá mi sọ̀rọ̀. Nígbà tí mo yípadà, mo rí ọ̀pá fìtílà wúrà méje,
\v 13 àti láàrín àwọn ọ̀pá fìtílà náà, ẹnìkan tí ó dàbí “ọmọ ènìyàn,” tí a wọ̀ ní aṣọ tí ó kanlẹ̀ dé ẹsẹ̀, tí a sì fi àmùrè wúrà dì ní ẹ̀gbẹ́.
\v 14 Orí rẹ̀ àti irun rẹ̀ funfun bí ẹ̀gbọ̀n òwú, ó funfun bí yìnyín; ojú rẹ̀ sì dàbí, ọwọ́ iná.
\v 15 Ẹsẹ̀ rẹ̀ sì dàbí idẹ dáradára, bí ẹni pé a dà á nínú ìléru; ohùn rẹ̀ sì dàbí ìró omi púpọ̀.
\v 16 Ó sì ní ìràwọ̀ méje ní ọwọ́ ọ̀tún rẹ̀; àti láti ẹnu rẹ̀ wá ni idà olójú méjì mímú ti jáde. Ojú rẹ̀ sì dàbí oòrùn tí ó ń fi agbára rẹ̀ hàn.
\p 
\v 17 Nígbà tí mo rí i, mo wólẹ̀ ní ẹsẹ̀ rẹ̀ bí ẹni tí ó kú. Ó sì fi ọwọ́ ọ̀tún rẹ̀ lé mi, ó ń wí fún mi pé, \wj “Má ṣe bẹ̀rù. Èmi ni ẹni ìṣáájú àti ẹni ìkẹyìn.\wj*
\v 18 \wj Èmi ni ẹni tí ó ń bẹ láààyè, tí ó sì ti kú; sì kíyèsi i, èmi sì ń bẹ láààyè sí i títí láé! Mo sì ní kọ́kọ́rọ́ ikú àti ti ipò òkú lọ́wọ́.\wj*
\p 
\v 19 \wj “Kọ̀wé nítorí náà ohun tí ìwọ ti rí, àti ti ohun tí ń bẹ, àti ti ohun tí yóò hù lẹ́yìn èyí;\wj*
\v 20 \wj ohun ìjìnlẹ̀ tí ìràwọ̀ méje náà tí ìwọ rí ní ọwọ́ ọ̀tún mi, àti ọ̀pá wúrà fìtílà méje náà. Ìràwọ̀ méje ni àwọn angẹli ìjọ méje náà: àti ọ̀pá fìtílà méje náà ní àwọn ìjọ méje.\wj*
\c 2
\s1 Sí ìjọ Efesu
\p 
\v 1 \wj “Sí angẹli ìjọ ní Efesu kọ̀wé:\wj*
\pm \wj Nǹkan wọ̀nyí ní ẹni tí ó mú ìràwọ̀ méje náà ni ọwọ́ ọ̀tún rẹ̀ wí, ẹni tí ń rìn ní àárín ọ̀pá wúrà fìtílà méje.\wj*
\b
\pm 
\v 2 \wj Èmi mọ iṣẹ́ rẹ, àti làálàá rẹ, àti ìfaradà rẹ, àti bí ara rẹ kò ti gba àwọn ẹni búburú, àti bí ìwọ sì ti dán àwọn tí ń pe ara wọn ní aposteli, tí wọ́n kì í sì í ṣe bẹ́ẹ̀ wo, tí ìwọ sì rí pé èké ni wọ́n,\wj*
\v 3 \wj tí ìwọ sì faradà ìyà, àti nítorí orúkọ mi tí ó sì rọ́jú, tí àárẹ̀ kò sì mú ọ.\wj*
\pm 
\v 4 \wj Síbẹ̀ èyí ni mo rí wí sí ọ, pé, ìwọ ti fi ìfẹ́ ìṣáájú rẹ sílẹ̀.\wj*
\v 5 \wj Rántí ibi tí ìwọ ti gbé ṣubú! Ronúpìwàdà, kí ó sì ṣe iṣẹ́ ìṣáájú; bí kò sì ṣe bẹ́ẹ̀, èmi ó sì tọ̀ ọ́ wá, èmi ó sì ṣí ọ̀pá fìtílà rẹ̀ kúrò ní ipò rẹ̀, bí kò ṣe bí ìwọ bá ronúpìwàdà.\wj*
\v 6 \wj Ṣùgbọ́n èyí ni ìwọ ní, pé ìwọ kórìíra ìṣe àwọn Nikolatani, èyí tí èmi pẹ̀lú sì kórìíra.\wj*
\pm 
\v 7 \wj Ẹni tí ó bá ní etí kí ó gbọ́ ohun tí Ẹ̀mí ń sọ fún àwọn ìjọ. Ẹni tí ó bá ṣẹ́gun ni èmi yóò fi èso igi ìyè nì fún jẹ, tí ń bẹ láàrín Paradise Ọlọ́run.\wj*
\s1 Sí Ìjọ ní Smirna
\p 
\v 8 \wj “Àti sí angẹli ìjọ ní Smirna kọ̀wé.\wj*
\pm \wj Nǹkan wọ̀nyí ni ẹni tí í ṣe ẹni ìṣáájú àti ẹni ìkẹyìn wí, ẹni tí ó ti kú, tí ó sì tún yè.\wj*
\b
\pm 
\v 9 \wj Èmi mọ iṣẹ́ rẹ, àti ìpọ́njú, àti àìní rẹ—ṣùgbọ́n ọlọ́rọ̀ ni ọ́, èmi sì mọ ọ̀rọ̀-òdì tí àwọn tí ń wí pé, Júù ni àwọn tìkára wọn, tí wọn kì sì í ṣe bẹ́ẹ̀, ṣùgbọ́n tí wọ́n jẹ́ Sinagọgu ti Satani.\wj*
\v 10 \wj Má ṣe bẹ̀rù ohunkóhun tí ìwọ ń bọ wá jìyà rẹ̀. Kíyèsi i, èṣù yóò gbé nínú yín jù sínú túbú, kí a lè dán yin wò; ẹ̀yin ó sì ní ìpọ́njú ní ọjọ́ mẹ́wàá, ìwọ ṣa ṣe olóòtítọ́ dé ojú ikú, èmi ó sì fi adé ìyè fún ọ.\wj*
\pm 
\v 11 \wj Ẹni tí ó bá ní etí kí ó gbọ́ ohun tí Ẹ̀mí ń sọ fún àwọn ìjọ. Ẹni tí ó bá ṣẹ́gun kì yóò fi ara pa nínú ikú kejì.\wj*
\s1 Sí ìjọ ní Pargamu
\p 
\v 12 \wj “Àti sì angẹli ìjọ ni Pargamu kọ̀wé.\wj*
\pm \wj Ọ̀rọ̀ wọ̀nyí ni ẹni tí ó ní idà mímú olójú méjì.\wj*
\b
\pm 
\v 13 \wj Èmí mọ̀ ibi tí ìwọ ń gbé, àní ibi tí ìtẹ́ Satani wà. Síbẹ̀ ìwọ di orúkọ mi mú ṣinṣin. Ìwọ kò sì sẹ́ ìgbàgbọ́ nínú mi, pàápàá jùlọ ni ọjọ́ Antipa ẹlẹ́rìí mi, olóòtítọ́ ènìyàn, ẹni tí wọn pa láàrín yín, níbi tí Satani ń gbé.\wj*
\pm 
\v 14 \wj Ṣùgbọ́n mo ni nǹkan díẹ̀ wí sí ọ; nítorí tí ìwọ ní àwọn kan tí ó di ẹ̀kọ́ Balaamu mú síbẹ̀, ẹni tí ó kọ́ Balaki láti mú ohun ìkọ̀sẹ̀ wá síwájú àwọn ọmọ Israẹli, láti máa jẹ ohun tí a pa rú ẹbọ sí òrìṣà, àti láti máa ṣe àgbèrè.\wj*
\v 15 \wj Bẹ́ẹ̀ ni ìwọ sì ní àwọn tí ó gbá ẹ̀kọ́ àwọn Nikolatani pẹ̀lú, ohun tí mo kórìíra.\wj*
\v 16 \wj Nítorí náà, ronúpìwàdà; bí kò ṣe bẹ́ẹ̀, èmi ó tọ̀ ọ́ wá nísinsin yìí, èmí o sì fi idà ẹnu mi bá wọn jà.\wj*
\pm 
\v 17 \wj Ẹni tí ó bá létí, kí ó gbọ́ ohun tí Ẹ̀mí ń sọ fún àwọn ìjọ. Ẹni tí o bá ṣẹ́gun ni èmi o fi manna tí ó pamọ́ fún, èmi ó sì fún un ni òkúta funfun kan, àti sára òkúta náà ni a kọ orúkọ tuntun kan, tí ẹnìkan kò mọ̀ bí kò ṣe ẹni tí ó gbà á.\wj*
\s1 Sí ìjọ ni Tiatira
\p 
\v 18 \wj “Àti sí angẹli ìjọ ní Tiatira kọ̀wé.\wj*
\pm \wj Nǹkan wọ̀nyí ni Ọmọ Ọlọ́run wí, ẹni tí ojú rẹ̀ dàbí ọ̀wọ́-iná, tí ẹsẹ̀ rẹ̀ sì dàbí idẹ dáradára.\wj*
\b
\pm 
\v 19 \wj Èmi mọ̀ iṣẹ́, ìfẹ́, àti ìgbàgbọ́ àti ìsìn àti sùúrù rẹ̀; àti pé iṣẹ́ rẹ̀ ìkẹyìn ju tí ìṣáájú lọ.\wj*
\pm 
\v 20 \wj Ṣùgbọ́n èyí ni mo rí wí sí ọ, nítorí tí ìwọ fi ààyè sílẹ̀ fún obìnrin Jesebeli tí ó ń pe ara rẹ̀ ní wòlíì. Nípasẹ̀ ẹ̀kọ́ rẹ̀, ó sì ń kọ́ àwọn ìránṣẹ́ mi, ó sì ń tàn wọ́n láti máa ṣe àgbèrè, àti láti máa jẹ ohun tí a pa rú ẹbọ sì òrìṣà.\wj*
\v 21 \wj Èmi fi àkókò fún un, láti ronúpìwàdà; ṣùgbọ́n òun kò fẹ́ ronúpìwàdà àgbèrè rẹ̀.\wj*
\v 22 \wj Nítorí náà, èmi ó gbé e sọ sí orí àkéte ìpọ́njú, àti àwọn tí ń bá a ṣe panṣágà ni èmi ó fi sínú ìpọ́njú ńlá, bí kò ṣe bí wọ́n bá ronúpìwàdà iṣẹ́ wọn.\wj*
\v 23 \wj Èmi o pa àwọn ọmọ rẹ̀ run; gbogbo ìjọ ni yóò sì mọ̀ pé, èmi ni ẹni tí ń wádìí inú àti ọkàn, èmi ó sì fi fún olúkúlùkù yín gẹ́gẹ́ bí iṣẹ́ rẹ̀.\wj*
\pm 
\v 24 \wj Ṣùgbọ́n ẹ̀yin ni mò ń sọ fún, ẹ̀yin ìyókù tí ń bẹ ní Tiatira, gbogbo ẹ̀yin tí kò ni ẹ̀kọ́ yìí, ti kò ì tí ì mọ̀ ohun tí wọn pè ni ohun ìjìnlẹ̀ Satani, èmi kò di ẹrù mìíràn rù yín,\wj*
\v 25 \wj ṣùgbọ́n èyí tí ẹ̀yin ní, ẹ di mú ṣinṣin títí èmi ó fi dé.\wj*
\pm 
\v 26 \wj Ẹni tí ó bá sì ṣẹ́gun, àti tí ó sì ṣe ìfẹ́ mi títí dé òpin, èmi ó fún un láṣẹ lórí àwọn orílẹ̀-èdè:\wj*
\v 27 \wj ‘Òun ó sì máa fi ọ̀pá irin ṣe àkóso wọn; gẹ́gẹ́ bí a ti ń fọ́ ohun èlò amọ̀kòkò ni a ó fọ́ wọn túútúú,’ gẹ́gẹ́ bí èmi pẹ̀lú tí gbà àṣẹ láti ọ̀dọ̀ Baba mi.\wj*
\v 28 \wj Èmi yóò sì fi ìràwọ̀ òwúrọ̀ fún un.\wj*
\v 29 \wj Ẹni tí ó bá létí, kí ó gbọ́ ohun tí Ẹ̀mí ń sọ fún àwọn ìjọ.\wj*
\c 3
\s1 Sí ìjọ ní Sardi
\p 
\v 1 \wj “Àti sí angẹli ìjọ ni Sardi kọ̀wé:\wj*
\pm \wj Ọ̀rọ̀ wọ̀nyí ni ẹni tí ó ni Ẹ̀mí méje Ọlọ́run, àti ìràwọ̀ méje wí pé.\wj*
\b
\pm \wj Èmi mọ iṣẹ́ rẹ̀, àti pé ìwọ ní orúkọ pé ìwọ ń bẹ láààyè, ṣùgbọ́n ìwọ ti kú.\wj*
\v 2 \wj Jí, kí o sì fi ẹsẹ̀ ohun tí ó kù múlẹ̀, tàbí tí ó ṣetán láti kú, nítorí èmi kò rí iṣẹ́ rẹ ni pípé níwájú Ọlọ́run.\wj*
\v 3 \wj Nítorí náà rántí bí ìwọ ti gbà, àti bí ìwọ ti gbọ́, kí o sì pa á mọ́, kí o sì ronúpìwàdà. Ǹjẹ́, bí ìwọ kò ba ṣọ́ra, èmi yóò dé sí ọ bí olè, ìwọ kì yóò sì mọ́ wákàtí tí èmi yóò dé sí ọ.\wj*
\pm 
\v 4 \wj Ìwọ ní orúkọ díẹ̀ ní Sardi, tí kò fi aṣọ wọn yí èérí; wọn yóò sì máa ba mi rìn ní aṣọ funfun: nítorí wọ́n yẹ.\wj*
\v 5 \wj Ẹni tí ó bá ṣẹ́gun, òun náà ni a ó fi aṣọ funfun wọ̀; èmi kì yóò pa orúkọ rẹ̀ kúrò nínú ìwé ìyè, ṣùgbọ́n èmi yóò jẹ́wọ́ orúkọ rẹ̀ níwájú Baba mi, àti níwájú àwọn angẹli rẹ̀.\wj*
\v 6 \wj Ẹni tí ó ba létí, kí ó gbọ́ ohun tí Ẹ̀mí ń sọ fún àwọn ìjọ.\wj*
\s1 Sí ìjọ Filadelfia
\p 
\v 7 \wj “Àti sí angẹli Ìjọ ni Filadelfia kọ̀wé.\wj*
\pm \wj Ọ̀rọ̀ wọ̀nyí ni ẹni tí ó jẹ́ mímọ́ náà wí, ẹni tí ó ṣe olóòtítọ́, ẹni tí ó ní kọ́kọ́rọ́ Dafidi, ẹni tí ó ṣí, tí kò sí ẹni tí yóò tì; ẹni tí o sì tì, tí kò sì ẹni tí yóò ṣí i.\wj*
\b
\pm 
\v 8 \wj Èmi mọ iṣẹ́ rẹ̀, kíyèsi i, mo gbe ìlẹ̀kùn tí ó ṣí kálẹ̀ níwájú rẹ̀, tí kò sí ẹni tí o lè tì í; pé ìwọ ni agbára díẹ̀, ìwọ sì pa ọ̀rọ̀ mi mọ́, ìwọ kò sì sẹ́ orúkọ mi.\wj*
\v 9 \wj Kíyèsi i, èmi ó mú àwọn ti Sinagọgu Satani, àwọn tí wọ́n ń wí pé Júù ni àwọn, tí wọn kì í sì ṣe bẹ́ẹ̀, ṣùgbọ́n tí wọn ń ṣèké; kíyèsi i, èmi ó mú kí wọn wá wólẹ̀ níwájú ẹsẹ̀ rẹ̀, kí wọn sì mọ̀ pé èmi tí fẹ́ ọ.\wj*
\v 10 \wj Nítorí tí ìwọ tí pa ọ̀rọ̀ sùúrù mi mọ́, èmi pẹ̀lú yóò pa ọ́ mọ́ kúrò nínú wákàtí ìdánwò, tí ń bọ̀ wá dé bá gbogbo ayé, láti dán àwọn tí ń gbé orí ilẹ̀ ayé wò.\wj*
\pm 
\v 11 \wj Kíyèsi i, èmi ń bọ̀ kánkán, di èyí ti ìwọ ní mú ṣinṣin, kí ẹnikẹ́ni má ṣe gba adé rẹ.\wj*
\v 12 \wj Ẹni tí ó ba ṣẹ́gun, òun ni èmi ó fi ṣe ọ̀wọ́n nínú tẹmpili Ọlọ́run mi, òun kì yóò sì jáde kúrò níbẹ̀ mọ́, èmi ó sì kọ orúkọ Ọlọ́run mi sí i lára, àti orúkọ ìlú Ọlọ́run mi, tí i ṣe Jerusalẹmu tuntun, tí ó ń ti ọ̀run sọ̀kalẹ̀ láti ọ̀dọ̀ Ọlọ́run mi wá: àti orúkọ tuntun ti èmi tìkára mi.\wj*
\v 13 \wj Ẹni tí ó bá ní etí, kí ó gbọ́ ohun ti Ẹ̀mí ń sọ fún àwọn ìjọ.\wj*
\s1 Sí ìjọ Laodikea
\p 
\v 14 \wj “Àti sí angẹli ìjọ ní Laodikea kọ̀wé.\wj*
\pm \wj Ọ̀rọ̀ wọ̀nyí ni ẹni tí ń jẹ́ Àmín wí, ẹlẹ́rìí olódodo àti olóòtítọ́, olórí ìṣẹ̀dá Ọlọ́run.\wj*
\b
\pm 
\v 15 \wj Èmi mọ̀ iṣẹ́ rẹ, pé ìwọ kò gbóná bẹ́ẹ̀ ni ìwọ kò tútù: èmi ìbá fẹ́ pé kí ìwọ kúkú tutù, tàbí kí ìwọ kúkú gbóná.\wj*
\v 16 \wj Ǹjẹ́ nítorí tí ìwọ lọ wọ́ọ́rọ́, tí o kò si gbóná, bẹ́ẹ̀ ni tí o kò tutù, èmi yóò pọ̀ ọ́ jáde kúrò ni ẹnu mi.\wj*
\v 17 \wj Nítorí tí ìwọ wí pé, èmi ní ọrọ̀, èmi sì ń pọ̀ sí i ni ọrọ̀, èmi kò sì ṣe aláìní ohunkóhun; tí ìwọ kò sì mọ̀ pé, òsì ni ìwọ, ẹni-ìkáàánú, tálákà, afọ́jú, àti ẹni ìhòhò:\wj*
\v 18 \wj Èmi fún ọ ni ìmọ̀ràn pé kí o ra wúrà lọ́wọ́ mi tí a ti dà nínú iná, kí ìwọ lè di ọlọ́rọ̀; àti aṣọ funfun, kí ìwọ lè fi wọ ara rẹ̀, àti kí ìtìjú ìhòhò rẹ̀ má ba hàn kí ìwọ sì fi ohun ìkunra kun ojú rẹ̀, kí ìwọ lè ríran.\wj*
\pm 
\v 19 \wj Gbogbo àwọn ti èmi bá fẹ́ ni èmi ń bá wí, tí mo sì ń nà: nítorí náà, ní ìtara, kì ìwọ sì ronúpìwàdà.\wj*
\v 20 \wj Kíyèsi i, èmi dúró ni ẹnu ìlẹ̀kùn, èmi sì ń kànkùn, bí ẹnikẹ́ni bá gbọ́ ohun mi, tí ó sì ṣí ìlẹ̀kùn, èmi yóò sì wọlé tọ̀ ọ́ wá, èmi yóò sì máa bá a jẹun, àti òun pẹ̀lú mi.\wj*
\pm 
\v 21 \wj Ẹni tí ó bá ṣẹ́gun ni èmi yóò fi fún láti jókòó pẹ̀lú mi lórí ìtẹ́ mi, bí èmi pẹ̀lú ti ṣẹ́gun, tí mo sì jókòó pẹ̀lú Baba mi lórí ìtẹ́ rẹ̀.\wj*
\v 22 \wj Ẹni tí ó bá létí, kí ó gbọ́ ohun tí Ẹ̀mí ń sọ fún àwọn ìjọ.”\wj*
\c 4
\s1 Ìtẹ́ Ọ̀run
\p 
\v 1 Lẹ́yìn nǹkan wọ̀nyí èmi wò, sì kíyèsi i, ìlẹ̀kùn kan ṣí sílẹ̀ ní ọ̀run, ohùn kìn-ín-ní tí mo gbọ́ bí ohùn ìpè tí ń bá mi sọ̀rọ̀, tí ó wí pé, \wj “Gòkè wá níhìn-ín, èmi ó sì fi ohun tí yóò ṣẹlẹ̀ lẹ́yìn èyí hàn ọ́.”\wj*
\v 2 Lójúkan náà, mo sì wà nínú Ẹ̀mí, sì kíyèsi i, a tẹ́ ìtẹ́ kan ní ọ̀run, ẹnìkan sì jókòó lórí ìtẹ́ náà.
\v 3 Ẹni tí ó sì jókòó náà dàbí òkúta jasperi àti kaneliani lójú. Ni àyíká ìtẹ́ náà ni òṣùmàrè kan wà tí ó dàbí òkúta emeradi lójú.
\v 4 Yí ìtẹ́ náà ká sì ni ìtẹ́ mẹ́rìnlélógún mìíràn; àti lórí àwọn ìtẹ́ náà mo rí àwọn àgbà mẹ́rìnlélógún jókòó, tí a wọ̀ ni aṣọ àlà; adé wúrà sì wà ni orí wọn.
\v 5 Àti láti ibi ìtẹ́ náà ni ìró mọ̀nàmọ́ná àti ohùn àti àrá ti jáde wá: níwájú ìtẹ́ náà ni fìtílà iná méje sì ń tàn, èyí tí ń ṣe Ẹ̀mí méje ti Ọlọ́run.
\v 6 Àti láti ibi ìtẹ́ náà ni òkun bi dígí wà tí o dàbí kristali.
\p Àti yí ìtẹ́ náà ká ní ẹ̀gbẹ́ kọ̀ọ̀kan ni ẹ̀dá alààyè mẹ́rin tí ó kún fún ojú níwájú àti lẹ́yìn wọn.
\v 7 Ẹ̀dá kìn-ín-ní sì dàbí kìnnìún, ẹ̀dá kejì si dàbí ọmọ màlúù, ẹ̀dá kẹta sì ni ojú bi ti ènìyàn, ẹ̀dá kẹrin sì dàbí idì tí ń fò.
\v 8 Àwọn ẹ̀dá alààyè mẹ́rin náà, tí olúkúlùkù wọn ni ìyẹ́ mẹ́fà, kún fún ojú yíká ara àti nínú; wọn kò sì sinmi lọ́sàn àti lóru, láti wí pé:
\qc “ ‘Mímọ́, mímọ́, mímọ́,
\qc Olúwa Ọlọ́run Olódùmarè,’
\qc tí ó ti wà, tí ó sì ń bẹ, tí ó sì ń bọ̀ wá!”
\m 
\v 9 Nígbà tí àwọn ẹ̀dá alààyè náà bá sì fi ògo àti ọlá, àti ọpẹ́ fún ẹni tí o jókòó lórí ìtẹ́, tí o ń bẹ láààyè láé àti láéláé.
\v 10 Àwọn àgbà mẹ́rìnlélógún náà yóò sì wólẹ̀ níwájú ẹni tí o jókòó lórí ìtẹ́, wọn yóò sì tẹríba fún ẹni tí ń bẹ láààyè láé àti láéláé, wọn yóò sì fi adé wọn lélẹ̀ níwájú ìtẹ́ náà, wí pé:
\q1 
\v 11 “Olúwa àti Ọlọ́run, ìwọ ni o yẹ,
\q1 láti gba ògo àti ọlá àti agbára,
\q1 nítorí pé ìwọ ni o dá ohun gbogbo,
\q2 àti nítorí ìfẹ́ inú rẹ̀ ni
\q2 wọn fi wà tí a sì dá wọn.”
\c 5
\s1 Ìwé àti Ọ̀dọ́-àgùntàn
\p 
\v 1 Mo sì rí i ni ọwọ́ ọ̀tún ẹni tí ó jókòó lórí ìtẹ́ náà, ìwé kan ti a kọ nínú àti lẹ́yìn, ti a sì fi èdìdì méje dí.
\v 2 Mó sì rí angẹli alágbára kan, ó ń fi ohùn rara kéde pé, “Ta ni ó yẹ láti ṣí ìwé náà, àti láti tu èdìdì rẹ̀?”
\v 3 Kò sì ṣí ẹni kan ní ọ̀run, tàbí lórí ilẹ̀ ayé, tàbí nísàlẹ̀ ilẹ̀, tí ó le ṣí ìwé náà, tàbí ti o lè wo inú rẹ̀.
\v 4 Èmi sì sọkún gidigidi, nítorí tí a kò ri ẹnìkan tí o yẹ láti sí i àti láti ka ìwé náà, tàbí láti wo inú rẹ̀.
\v 5 Ọ̀kan nínú àwọn àgbà náà sì wí fún mi pé, “Má ṣe sọkún: kíyèsi i, kìnnìún ẹ̀yà Juda, Gbòǹgbò Dafidi, tí borí láti ṣí ìwé náà, àti láti tú èdìdì rẹ̀ méjèèje.”
\p 
\v 6 Mo sì rí Ọ̀dọ́-Àgùntàn ni àárín ìtẹ́ náà, àti àwọn ẹ̀dá alààyè mẹ́rin náà, àti ni àárín àwọn àgbà náà, Ọ̀dọ́-àgùntàn kan dúró bí èyí tí a ti pa, ó ní ìwo méje àti ojú méje, tí o jẹ́ Ẹ̀mí méje tí Ọlọ́run, tí a rán jáde lọ sì orí ilẹ̀ ayé gbogbo.
\v 7 Ó sì wá, o sì gbà á ìwé náà ni ọwọ́ ọ̀tún ẹni tí ó jókòó lórí ìtẹ́ náà.
\v 8 Nígbà tí ó sì gba ìwé náà, àwọn ẹ̀dá alààyè mẹ́rin náà, àti àwọn àgbà mẹ́rìnlélógún náà wólẹ̀ níwájú Ọ̀dọ́-àgùntàn náà, olúkúlùkù wọn mú ohun èlò orin olókùn kan lọ́wọ́, àti ago wúrà tí ó kún fún tùràrí tí i ṣe àdúrà àwọn ènìyàn mímọ́.
\v 9 Wọn sì ń kọ orin tuntun kan, wí pé:
\q1 “Ìwọ ní o yẹ láti gba ìwé náà,
\q2 àti láti ṣí èdìdì rẹ̀:
\q1 nítorí tí a tí pa ọ,
\q2 ìwọ sì tí fi ẹ̀jẹ̀ rẹ̀ ṣe ìràpadà ènìyàn sí Ọlọ́run láti inú ẹ̀yà gbogbo,
\q2 àti èdè gbogbo, àti inú ènìyàn gbogbo, àti orílẹ̀-èdè gbogbo wá.
\q1 
\v 10 Ìwọ sì tí ṣe wọ́n ni ọba àti àlùfáà sì Ọlọ́run wá:
\q2 wọ́n sì ń jẹ ọba lórí ilẹ̀ ayé.”
\p 
\v 11 Èmi sì wò, mo sì gbọ́ ohùn àwọn angẹli púpọ̀ yí ìtẹ́ náà ká, àti yí àwọn ẹ̀dá alààyè náà àti àwọn àgbà náà ká. Iye wọn sì jẹ́ ẹgbàárùn-ún ọ̀nà ẹgbàárùn-ún àti ẹgbẹẹgbẹ̀rún ọ̀nà ẹgbẹẹgbẹ̀rún.
\v 12 Wọn ń wí lóhùn rara pé:
\q1 “Yíyẹ ni Ọ̀dọ́-àgùntàn náà tí a tí pa,
\q1 láti gba agbára,
\q1 àti ọ̀rọ̀ àti ọgbọ́n, àti ipá, àti ọlá,
\q1 àti ògo, àti ìbùkún.”
\p 
\v 13 Gbogbo ẹ̀dá tí o sì ń bẹ ni ọ̀run, àti lórí ilẹ̀ ayé, àti nísàlẹ̀ ilẹ̀ àti irú àwọn tí ń bẹ nínú Òkun, àti gbogbo àwọn tí ń bẹ nínú wọn, ni mo gbọ́ tí ń wí pé,
\q1 “Kí a fi ìbùkún àti ọlá, àti ògo, àti agbára,
\q1 fún Ẹni tí ó jókòó lórí ìtẹ́ àti fún Ọ̀dọ́-àgùntàn
\qc náà láé àti láéláé.”
\m 
\v 14 Àwọn ẹ̀dá alààyè mẹ́rin náà wí pé, “Àmín!” Àwọn àgbà mẹ́rìnlélógún náà wólẹ̀, wọn sì foríbalẹ̀ fún ẹni tí ń bẹ láààyè láé àti láéláé.
\c 6
\s1 Ṣí àwọn èdìdì ìwé náà
\p 
\v 1 Èmi sì rí i nígbà tí Ọ̀dọ́-àgùntàn náà ṣí ọkàn nínú èdìdì wọ̀nyí, mo sì gbọ́ ọ̀kan nínú àwọn ẹ̀dá alààyè mẹ́rin náà ń wí bí sísán àrá pé, “Wá, wò ó!”
\v 2 Mo sì wò ó, kíyèsi i, ẹṣin funfun kan: ẹni tí ó sì jókòó lórí i rẹ̀ ní ọfà kan; a sì fi adé kan fún un: ó sì jáde lọ láti ìṣẹ́gun dé ìṣẹ́gun.
\p 
\v 3 Nígbà tí ó sì ṣí èdìdì kejì, mo gbọ́ ohùn ẹ̀dá alààyè wí pé, “Wá, wò ó!”
\v 4 Ẹṣin mìíràn tí ó pupa sì jáde, a sì fi agbára fún ẹni tí ó jókòó lórí rẹ̀, láti gba àlàáfíà kúrò lórí ilẹ̀ ayé, àti pé kí wọn kí ó máa pa ara wọn, a sì fi idà ńlá kan lé e lọ́wọ́.
\p 
\v 5 Nígbà tí ó sì di èdìdì kẹta, mo gbọ́ ohùn ẹ̀dá alààyè kẹta wí pé, “Wá wò ó”. Mo sì wò ó, sì kíyèsi i, ẹṣin dúdú kan; ẹni tí ó jókòó lórí rẹ̀ ní ìwọ̀n aláwẹ́ méjì ní ọwọ́ rẹ̀.
\v 6 Mo sì gbọ́ bí ẹni pé ohùn kan ní àárín àwọn ẹ̀dá alààyè mẹ́rẹ̀ẹ̀rin nì ti ń wí pé, òsùwọ̀n alikama kan fún owó idẹ kan, àti òsùwọ̀n ọkà barle mẹ́ta fún owó idẹ kan, sì kíyèsi i, kí ó má sì ṣe pa òróró àti ọtí wáìnì lára.
\p 
\v 7 Nígbà tí ó sì ṣí èdìdì kẹrin, mo gbọ́ ohùn ẹ̀dá alààyè kan wí pé, “Wá wò ó!”
\v 8 Mo sì wò ó, kíyèsi, ẹṣin ràndànràndàn kan, orúkọ ẹni tí ó jókòó lórí rẹ̀ ni ikú, àti ipò òkú sì tọ̀ ọ́ lẹ́yìn. A sì fi agbára fún wọn lórí ìdámẹ́rin ayé, láti fi idà, àti ebi, àti ikú, àti ẹranko lu orí ilẹ̀ ayé pa.
\p 
\v 9 Nígbà tí ó sì ṣí èdìdì karùn-ún, mo rí lábẹ́ pẹpẹ, ọkàn àwọn tí a ti pa nítorí ọ̀rọ̀ Ọlọ́run, àti nítorí ẹ̀rí tí wọ́n dìímú,
\v 10 Wọ́n kígbe ní ohùn rara, wí pé, “Yóò ti pẹ́ tó, Olúwa Olódùmarè, ẹni mímọ́ àti olóòtítọ́ ìwọ kì yóò ṣe ìdájọ́ kí o sì gbẹ̀san ẹ̀jẹ̀ wa mọ́ lára àwọn tí ń gbé orí ilẹ̀ ayé?”
\v 11 A sì fi aṣọ funfun fún gbogbo wọn; a sì wí fún wọn pé, kí wọn kí ó sinmi fún ìgbà díẹ̀ ná, títí iye àwọn ìránṣẹ́ ẹlẹgbẹ́ wọn àti arákùnrin wọn tí a o pa bí wọn, yóò fi dé.
\p 
\v 12 Nígbà tí ó sì ṣí èdìdì kẹfà mo sì rí i, sì kíyèsi i, ìṣẹ̀lẹ̀ ńlá kan ṣẹ̀; oòrùn sì dúdú bí aṣọ ọ̀fọ̀ onírun, òṣùpá sì dàbí ẹ̀jẹ̀;
\v 13 àwọn ìràwọ̀ ojú ọ̀run sì ṣubú sílẹ̀ gẹ́gẹ́ bí igi ọ̀pọ̀tọ́ tí ń rẹ̀ àìgbó èso rẹ̀ dànù, nígbà tí ẹ̀fúùfù ńlá bá mì í.
\v 14 A sì ká ọ̀run kúrò bí ìwé tí a ká, àti olúkúlùkù òkè àti erékùṣù ní a sì ṣí kúrò ní ipò wọn.
\p 
\v 15 Àwọn ọba ayé àti àwọn ọlọ́lá àti àwọn olórí ogun, àti àwọn ọlọ́rọ̀ àti àwọn alágbára, àti olúkúlùkù ẹrú, àti olúkúlùkù òmìnira, sì fi ara wọn pamọ́ nínú ihò ilẹ̀, àti nínú àpáta orí òkè;
\v 16 wọ́n sì ń wí fún àwọn òkè àti àwọn àpáta náà pé, “Ẹ wó lù wá, kí ẹ sì fi wá pamọ́ kúrò lójú ẹni tí ó jókòó lórí ìtẹ́, àti kúrò nínú ìbínú Ọ̀dọ́-Àgùntàn náà.
\v 17 Nítorí ọjọ́ ńlá ìbínú wọn dé; ta ni ó sì le dúró?”
\c 7
\s1 Ọ̀kẹ́ méje ó lé ẹgbàajì èdìdì ìwé
\p 
\v 1 Lẹ́yìn èyí ni mo rí angẹli mẹ́rin dúró ní igun mẹ́rẹ̀ẹ̀rin ayé, wọ́n di afẹ́fẹ́ mẹ́rẹ̀ẹ̀rin ayé mú, kí ó má ṣe fẹ́ sórí ilẹ̀, tàbí sórí Òkun, tàbí sára igikígi.
\v 2 Mo sì rí angẹli mìíràn tí ó ń ti ìhà ìlà-oòrùn gòkè wá, ti òun ti èdìdì Ọlọ́run alààyè lọ́wọ́ rẹ. Ó sì kígbe ní ohùn rara sí àwọn angẹli mẹ́rin náà tí a fi fún un láti pa ayé, àti Òkun, lára,
\v 3 wí pé, “Ẹ má ṣe pa ayé, tàbí Òkun, tàbí igi lára, títí àwa ó fi fi èdìdì sàmì sí àwọn ìránṣẹ́ Ọlọ́run wa ní iwájú wọn.”
\v 4 Mo sì gbọ́ iye àwọn tí a fi èdìdì sàmì si, àwọn tí a sàmì sí jẹ́ ọ̀kẹ́ méje ó lé ẹgbàajì (144,000) láti inú gbogbo ẹ̀yà àwọn ọmọ Israẹli wá.
\b
\li1 
\v 5 Láti inú ẹ̀yà Juda a fi èdìdì sàmì sí ẹgbàá mẹ́fà (12,000).
\li1 Láti inú ẹ̀yà Reubeni a fi èdìdì sàmì sí ẹgbàá mẹ́fà (12,000).
\li1 Láti inú ẹ̀yà Gadi a fi èdìdì sàmì sí ẹgbàá mẹ́fà (12,000).
\li1 
\v 6 Láti inú ẹ̀yà Aṣeri a fi èdìdì sàmì sí ẹgbàá mẹ́fà (12,000).
\li1 Láti inú ẹ̀yà Naftali a fi èdìdì sàmì sí ẹgbàá mẹ́fà (12,000).
\li1 Láti inú ẹ̀yà Manase a fi èdìdì sàmì sí ẹgbàá mẹ́fà (12,000).
\li1 
\v 7 Láti inú ẹ̀yà Simeoni a fi èdìdì sàmì sí ẹgbàá mẹ́fà (12,000).
\li1 Láti inú ẹ̀yà Lefi a fi èdìdì sàmì sí ẹgbàá mẹ́fà (12,000).
\li1 Láti inú ẹ̀yà Isakari a fi èdìdì sàmì sí ẹgbàá mẹ́fà (12,000).
\li1 
\v 8 Láti inú ẹ̀yà Sebuluni, a fi èdìdì sàmì sí ẹgbàá mẹ́fà (12,000).
\li1 Láti inú ẹ̀yà Josẹfu a fi èdìdì sàmì sí ẹgbàá mẹ́fà (12,000).
\li1 Láti inú ẹ̀yà Benjamini a fi èdìdì sàmì sí ẹgbàá mẹ́fà (12,000).
\s1 Ọ̀pọ̀lọpọ̀ àwọn ènìyàn nínú ẹ̀wù funfun
\p 
\v 9 Lẹ́yìn náà, mo ri, sì kíyèsi i, ọ̀pọ̀lọpọ̀ ènìyàn tí ẹnikẹ́ni kò lè kà, láti inú orílẹ̀-èdè gbogbo, àti ẹ̀yà, àti ènìyàn, àti láti inú èdè gbogbo wá, wọn dúró níwájú ìtẹ́, àti níwájú Ọ̀dọ́-Àgùntàn náà, a wọ̀ wọ́n ni aṣọ funfun, imọ̀ ọ̀pẹ si ń bẹ ni ọwọ́ wọn.
\v 10 Wọ́n sì kígbe ní ohùn rara, wí pé:
\q1 “Ìgbàlà ni ti Ọlọ́run wá
\q1 tí o jókòó lórí ìtẹ́,
\q1 àti ti Ọ̀dọ́-àgùntàn!”
\m 
\v 11 Gbogbo àwọn angẹli sì dúró yí ìtẹ́ náà ká, àti yí àwọn àgbà àti àwọn ẹ̀dá alààyè mẹ́rin náà ká, wọn wólẹ̀ wọn si dojúbolẹ̀ níwájú ìtẹ́ náà wọ́n sì sin Ọlọ́run.
\v 12 Wí pe:
\q1 “Àmín!
\q1 Ìbùkún, àti ògo,
\q1 àti ọgbọ́n, àti ọpẹ́, àti ọlá,
\q1 àti agbára àti ipá fún Ọlọ́run wa láé àti láéláé!
\q1 Àmín!”
\p 
\v 13 Ọ̀kan nínú àwọn àgbà náà si dáhùn, ó bi mí pé, “Ta ni àwọn wọ̀nyí tí a wọ ni aṣọ funfun? Níbo ni wọn sì ti wá?”
\p 
\v 14 Mo sì wí fún un pé, “Olúwa mi, ìwọ ni o lè mọ̀.”
\p Ó sì wí fún mí pé, “Àwọn wọ̀nyí ni o jáde láti inú ìpọ́njú ńlá, wọ́n sì fọ aṣọ wọ́n, wọ́n sì sọ wọ́n di funfun nínú ẹ̀jẹ̀ Ọ̀dọ́-àgùntàn náà.
\v 15 Nítorí náà ni,
\q1 “wọn ṣe ń bẹ níwájú ìtẹ́ Ọlọ́run,
\q2 tí wọn sì ń sìn ín, lọ́sàn àti lóru nínú tẹmpili rẹ̀;
\q1 ẹni tí o jókòó lórí ìtẹ́ náà yóò si síji bò wọn.
\q1 
\v 16 Ebi kì yóò pa wọn mọ́,
\q2 bẹ́ẹ̀ ni òùngbẹ kì yóò gbẹ́ wọ́n mọ́;
\q1 bẹ́ẹ̀ ni oòrùn kì yóò pa wọn
\q2 tàbí oorukóoru kan.
\q1 
\v 17 Nítorí ọ̀dọ́-àgùntàn tí ń bẹ ni àárín ìtẹ́ náà ni yóò máa ṣe olùṣọ́-àgùntàn wọn,
\q2 ‘tí yóò sì máa ṣe amọ̀nà wọn sí ibi orísun omi ìyè.’
\q1 ‘Ọlọ́run yóò sì nu omijé gbogbo nù kúrò ni ojú wọn.’ ”
\c 8
\s1 Èdìdì keje àti àwo tùràrí
\p 
\v 1 Nígbà tí ó sì ṣí èdìdì keje, ìdákẹ́rọ́rọ́ sì wà ní ọ̀run níwọ̀n ààbọ̀ wákàtí kan.
\p 
\v 2 Mo sì rí àwọn angẹli méje tí wọn dúró níwájú Ọlọ́run; a sì fi ìpè méje fún wọn.
\p 
\v 3 Angẹli mìíràn sì wá, ó sì dúró ti pẹpẹ, ó ní àwo tùràrí wúrà kan a sì fi tùràrí púpọ̀ fún un, láti máa fi kún àdúrà gbogbo àwọn ènìyàn mímọ́ lórí pẹpẹ, pẹpẹ wúrà tí ń bẹ níwájú ìtẹ́.
\v 4 Àti èéfín tùràrí náà pẹ̀lú àdúrà àwọn ènìyàn mímọ́ sì gòkè lọ síwájú Ọlọ́run láti ọwọ́ angẹli náà wá.
\v 5 Angẹli náà sì mú àwo tùràrí náà, ó sì fi iná orí pẹpẹ kùn ún, ó sì dà á sórí ilẹ̀ ayé, a sì gbọ́ ohùn, àrá sì sán, mọ̀nàmọ́ná sì kọ, àti ilẹ̀-rírì.
\s1 Àwọn ìpè
\p 
\v 6 Àwọn angẹli méje náà tí wọn ni ìpè méje sì múra láti fún wọn.
\p 
\v 7 Èkínní sì fọn ìpè tirẹ̀, Yìnyín àti iná, tí o dàpọ̀ pẹ̀lú ẹ̀jẹ̀, sì jáde, a sì dà wọ́n sórí ilẹ̀ ayé: ìdámẹ́ta ilẹ̀ ayé si jóná, ìdámẹ́ta àwọn igi sì jóná, àti gbogbo koríko tútù sì jóná.
\p 
\v 8 Angẹli kejì si fún ìpè tirẹ̀, a sì sọ ohun kan, bí òkè ńlá tí ń jóná, sínú Òkun: ìdámẹ́ta Òkun si di ẹ̀jẹ̀;
\v 9 àti ìdámẹ́ta àwọn ẹ̀dá tí ń bẹ nínú Òkun tí ó ni ẹ̀mí sì kú; àti ìdámẹ́ta àwọn ọkọ̀ si bàjẹ́.
\p 
\v 10 Angẹli kẹta sì fún ìpè tirẹ̀, ìràwọ̀ ńlá kan tí ń jó bí fìtílà sì bọ́ láti ọ̀run wá, ó sì bọ́ sórí ìdámẹ́ta àwọn odò ṣíṣàn, àti sórí àwọn orísun omi.
\v 11 A sì ń pe orúkọ ìràwọ̀ náà ní Iwọ, ìdámẹ́ta àwọn omi sì di iwọ, ọ̀pọ̀lọpọ̀ ènìyàn sì tí ipa àwọn omi náà kú, nítorí tí a sọ wọn di kíkorò.
\p 
\v 12 Angẹli kẹrin sì fún ìpè tirẹ̀, a sì kọlu ìdámẹ́ta oòrùn, àti ìdámẹ́ta òṣùpá, àti ìdámẹ́ta àwọn ìràwọ̀, ki ìdámẹ́ta wọn lè ṣókùnkùn, kí ọjọ́ má ṣe mọ́lẹ̀ fún ìdámẹ́ta rẹ̀, àti òru bákan náà.
\p 
\v 13 Mo sì wò, mo sì gbọ́ idì kan tí ń fò ni àárín ọ̀run, ó ń wí lóhùn rara pé, “Ègbé, ègbé, fún àwọn tí ń gbé orí ilẹ̀ ayé nítorí ohun ìpè ìyókù tí àwọn angẹli mẹ́ta tí ń bọ̀ wá yóò fún!”
\c 9
\p 
\v 1 Angẹli karùn-ún sì fún ìpè tirẹ̀, mo sì rí, ìràwọ̀ kan bọ́ sílẹ̀ láti ọ̀run wá, a sì fi kọ́kọ́rọ́ ihò ọ̀gbun fún un.
\v 2 Ó sì ṣí ihò ọ̀gbun náà, èéfín sì rú jáde láti inú ihò náà wá, bí èéfín ìléru ńlá, oòrùn àti ojú sánmọ̀ sì ṣókùnkùn nítorí èéfín ihò náà.
\v 3 Àwọn eṣú sì jáde ti inú èéfín náà wá sórí ilẹ̀, a sì fi agbára fún wọn gẹ́gẹ́ bí agbára àkéekèe ilẹ̀.
\v 4 A sì fún wọn pé ki wọn má ṣe pa koríko ilẹ̀ lára tàbí ohun tútù kan, tàbí igikígi kan; bí kò ṣe àwọn ènìyàn tí kò ni èdìdì Ọlọ́run ní iwájú wọn.
\v 5 A sì pàṣẹ fún wọn pé, kí wọn má ṣe pa wọ́n, ṣùgbọ́n kí a dá wọn ni oró ni oṣù márùn-ún, oró wọn sì dàbí oró àkéekèe, nígbà tí o bá ta ènìyàn.
\v 6 Ní ọjọ́ wọ̀nyí ni àwọn ènìyàn yóò sì máa wá ikú, wọn kì yóò sì rí i; wọn yóò sì fẹ́ láti kú, ikú yóò sì sá kúrò lọ́dọ̀ wọn.
\p 
\v 7 Ìrísí àwọn eṣú náà sì dàbí àwọn ẹṣin tí a múra sílẹ̀ fún ogun; àti ní orí wọn ni ohun tí o dàbí àwọn adé wúrà wà, ojú wọn sì dàbí ojú ènìyàn;
\v 8 wọ́n sì ní irun bí obìnrin, eyín wọn sì dàbí ti kìnnìún.
\v 9 Wọ́n sì ní ìgbàyà tí ó dàbí ìgbàyà irin; ìró ìyẹ́ wọn sì dàbí ìró kẹ̀kẹ́-ẹṣin púpọ̀ tí ń súré lọ sí ogun.
\v 10 Wọ́n sì ni ìrù àti oró bí tí àkéekèe, àti ní ìrù wọn ni agbára wọn wà láti pa ènìyàn lára fún oṣù márùn-ún.
\v 11 Wọ́n ní angẹli ọ̀gbun náà bí ọba lórí wọn, orúkọ rẹ̀ ní èdè Heberu ní Abaddoni, àti ni èdè Giriki orúkọ rẹ̀ a máa jẹ́ Apollioni (èyí ni Apanirun).
\p 
\v 12 Ègbé kan tí kọjá, kíyèsi i, ègbé méjì ń bọ̀ síbẹ̀ lẹ́yìn èyí.
\p 
\v 13 Angẹli kẹfà si fọn ìpè rẹ̀, mo sì gbọ́ ohùn kan láti ibi ìwo mẹ́rin pẹpẹ wúrà wá, tí ń bẹ níwájú Ọlọ́run.
\v 14 Òun wí fún angẹli kẹfà náà tí o ni ìpè náà pé, “Tú àwọn angẹli mẹ́rin náà sílẹ̀ tí a dè lẹ́bàá odò ńlá Eufurate!”
\v 15 A sì tú àwọn angẹli mẹ́rin náà sílẹ̀, tí a ti pèsè tẹ́lẹ̀ fún wákàtí náà, àti ọjọ́ náà, àti oṣù náà, àti ọdún náà, láti pa ìdámẹ́ta ènìyàn.
\v 16 Iye ogún àwọn ẹlẹ́ṣin sì jẹ́ àádọ́ta ọ̀kẹ́ lọ́nà igba, mo sì gbọ́ iye wọn.
\p 
\v 17 Báyìí ni mo sì rí àwọn ẹṣin náà ní ojúran, àti àwọn tí o gùn wọ́n, wọ́n ni ìgbàyà aláwọ̀ iná, àti ti jakinti, àti ti sulfuru, orí àwọn ẹṣin náà sì dàbí orí àwọn kìnnìún; àti láti ẹnu wọn ni iná, àti èéfín, àti sulfuru tí ń jáde.
\v 18 Nípa ìyọnu mẹ́ta wọ̀nyí ni a tí pa ìdámẹ́ta ènìyàn, nípa iná, àti nípa èéfín, àti nípa sulfuru tí o ń tí ẹnu wọn jáde.
\v 19 Nítorí pé agbára àwọn ẹṣin náà ń bẹ ní ẹnu wọn àti ní ìrù wọn: nítorí pé ìrù wọn dàbí ejò, wọn sì ní orí, àwọn wọ̀nyí ni wọn sì fi ń pa ni lára.
\p 
\v 20 Ṣùgbọ́n àwọn ènìyàn ìyókù tí a kò sì ti ipa ìyọnu wọ̀nyí pa, kò sì ronúpìwàdà iṣẹ́ ọwọ́ wọn, kí wọn má ṣe sin àwọn ẹ̀mí èṣù àti ère wúrà, àti ti fàdákà, àti ti idẹ, àti òkúta, àti ti igi mọ́: àwọn tí kò lè ríran, tàbí kí wọn gbọ́rọ̀, tàbí kí wọn rìn.
\v 21 Bẹ́ẹ̀ ni wọn kò ronúpìwàdà ìwà ìpànìyàn wọn, tàbí oṣó wọn tàbí àgbèrè wọn, tàbí olè wọn.
\c 10
\s1 Àwọn angẹli àti ìwé kékeré
\p 
\v 1 Mó sì rí angẹli mìíràn alágbára ò ń ti ọ̀run sọ̀kalẹ̀ wá, a fi àwọsánmọ̀ wọ̀ ọ́ ni aṣọ; òṣùmàrè sì ń bẹ ní orí rẹ̀, ojú rẹ̀ sì dàbí oòrùn, àti ẹsẹ̀ rẹ̀ bí ọ̀wọ́n iná.
\v 2 Ó sì ní ìwé kékeré kan tí a ṣí ní ọwọ́ rẹ̀; ó sì fi ẹsẹ̀ rẹ̀ ọ̀tún lé Òkun, àti ẹsẹ̀ rẹ̀ òsì lé ilẹ̀.
\v 3 Ó sì ké lóhùn rara, bí ìgbà tí kìnnìún bá bú ramúramù. Nígbà tí ó sì ké, àwọn àrá méje náà fọhùn.
\v 4 Nígbà tí àwọn àrá méje fọhùn, mo múra àti kọ̀wé, mo sì gbọ́ ohùn láti ọ̀run wá ń wí fún pé, “Fi èdìdì di ohun tí àwọn àrá méje náà sọ, má sì ṣe kọ wọ́n sílẹ̀.”
\p 
\v 5 Angẹli náà tí mo rí tí ó dúró lórí Òkun àti lórí ilẹ̀, sì gbé ọwọ́ rẹ̀ sí òkè ọ̀run.
\v 6 Ó sì fi ẹni tí ń bẹ láààyè láé àti láé búra, ẹni tí o dá ọ̀run, àti ohun tí ń bẹ nínú rẹ̀, ayé ohun tí ń bẹ nínú rẹ̀ pé, “Kí yóò si ìjáfara mọ́.
\v 7 Ṣùgbọ́n ní ọjọ́ ohùn angẹli keje, nígbà tí yóò ba fún ìpè, nígbà náà ni ohun ìjìnlẹ̀ Ọlọ́run, gẹ́gẹ́ bí o tí sọ fún àwọn ìránṣẹ́ rẹ̀, àwọn wòlíì ni a ó mú ṣẹ.”
\p 
\v 8 Ohùn náà tí mo gbọ́ láti ọ̀run tún ń ba mi sọ̀rọ̀, ó sì wí pé, “Lọ, gba ìwé tí o ṣí lọ́wọ́ angẹli tí o dúró lórí Òkun àti lórí ilẹ̀.”
\p 
\v 9 Mo sì tọ angẹli náà lọ, mo sì wí fún pé, “Fún mi ní ìwé kékeré náà.” Ó sì wí fún mi pé, “Gbà kí o sì jẹ ẹ́ tan: yóò dàbí oyin.”
\v 10 Mo sì gba ìwé kékeré náà ni ọwọ́ angẹli náà mo sì jẹ ẹ́ tan; ó sì dùn lẹ́nu mi bí oyin; bí mo sì tí jẹ ẹ́ tan, inú mi korò.
\v 11 A sì wí fún mi pé, “Ìwọ ó sì tún sọ àsọtẹ́lẹ̀ nípa ọ̀pọ̀lọpọ̀ ènìyàn, àti orílẹ̀ àti èdè, àti àwọn ọba.”
\c 11
\s1 Àwọn ẹlẹ́rìí méjì
\p 
\v 1 A sì fi ìfèéfèé kan fún mi tí o dàbí ọ̀pá-ìwọ̀n: ẹnìkan sì wí pé, “Dìde, wọn tẹmpili Ọlọ́run, àti pẹpẹ, àti àwọn tí ń sìn nínú rẹ̀.
\v 2 Sì fi àgbàlá tí ń bẹ lóde tẹmpili sílẹ̀, má sì ṣe wọ́n ọ́n; nítorí tí a fi fún àwọn aláìkọlà: ìlú mímọ́ náà ni wọn ó sì tẹ̀ mọ́lẹ̀ ní oṣù méjìlélógójì (42).
\v 3 Èmi ó sì yọ̀ǹda fún àwọn ẹlẹ́rìí mi méjèèje, wọn ó sì sọtẹ́lẹ̀ fún ẹgbẹ̀fà ọjọ́ ó lé ọgọ́ta (1,260) nínú aṣọ ọ̀fọ̀.”
\v 4 Wọ̀nyí ni igi olifi méjì náà, àti ọ̀pá fìtílà méjì náà tí ń dúró níwájú Olúwa ayé.
\v 5 Bí ẹnikẹ́ni bá sì fẹ́ pa wọn lára, iná ó ti ẹnu wọn jáde, a sì pa àwọn ọ̀tá wọn run, báyìí ni a ó sì pa ẹnikẹ́ni tí ó ba ń fẹ́ pa wọn lára run.
\v 6 Àwọn wọ̀nyí ni ó ni agbára láti sé ọ̀run, tí òjò kò fi lè rọ̀ ni ọjọ́ àsọtẹ́lẹ̀ wọn. Wọ́n sì ní agbára lórí omi láti sọ wọn di ẹ̀jẹ̀, àti láti fi onírúurú àjàkálẹ̀-ààrùn kọlu ayé, nígbàkígbà tí wọ́n bá fẹ́.
\p 
\v 7 Nígbà tí wọn bá sì ti parí ẹ̀rí wọn, ẹranko tí o ń tí inú ọ̀gbun gòkè wá yóò bá wọn jagun, yóò sì ṣẹ́gun wọn, yóò sì pa wọ́n.
\v 8 Òkú wọn yóò sì wà ni ìgboro ìlú ńlá náà tí a ń pè ní Sodomu àti Ejibiti nípa ti ẹ̀mí, níbi tí a gbé kan Olúwa wọ́n mọ́ àgbélébùú.
\v 9 Fún ọjọ́ mẹ́ta àti ààbọ̀ ni àwọn ènìyàn nínú ènìyàn gbogbo àti ẹ̀yà, àti èdè, àti orílẹ̀, wo òkú wọn, wọn kò si jẹ kì a gbé òkú wọn sínú ibojì.
\v 10 Àti àwọn tí o ń gbé orí ilẹ̀ ayé yóò sì yọ̀ lé wọn lórí, wọn yóò sì ṣe àríyá, wọn ó sì ta ara wọn lọ́rẹ; nítorí tí àwọn wòlíì méjèèjì yìí dá àwọn tí o ń bẹ lórí ilẹ̀ ayé lóró.
\p 
\v 11 Àti lẹ́yìn ọjọ́ mẹ́ta àti ààbọ̀ náà, ẹ̀mí ìyè láti ọ̀dọ̀ Ọlọ́run wá wọ inú wọn, wọn sì dìde dúró ni ẹsẹ̀ wọn; ẹ̀rù ńlá sì ba àwọn tí o rí wọn.
\v 12 Wọn sì gbọ́ ohùn ńlá kan láti ọ̀run wá ń wí fún wọn pé, “Ẹ gòkè wá ìhín!” Wọn sì gòkè lọ sí ọ̀run nínú ìkùùkuu àwọsánmọ̀; lójú àwọn ọ̀tá wọn.
\p 
\v 13 Ní wákàtí náà omìmì-ilẹ̀ ńlá kan sì mì, ìdámẹ́wàá ìlú náà sì wó, àti nínú omìmì-ilẹ̀ náà ẹ̀ẹ́dẹ́gbàárin (7,000) ènìyàn ní a pa; ẹ̀rù sì ba àwọn ìyókù, wọn sì fi ògo fún Ọlọ́run ọ̀run.
\p 
\v 14 Ègbé kejì kọjá; sì kíyèsi i, ègbé kẹta sì ń bọ̀ wá kánkán.
\s1 Ìpè méje
\p 
\v 15 Angẹli keje sì fọn ìpè; a sì gbọ́ ohùn ńlá láti ọ̀run, wí pé,
\q1 “Ìjọba ayé di ti Olúwa wá, àti tí Kristi rẹ̀;
\q2 òun yóò sì jẹ ọba láé àti láéláé!”
\m 
\v 16 Àwọn àgbà mẹ́rìnlélógún náà tí wọn jókòó níwájú Ọlọ́run lórí ìtẹ́ wọn, dojúbolẹ̀, wọn sì sin Ọlọ́run,
\v 17 wí pé:
\q1 “Àwa fi ọpẹ́ fún ọ, Olúwa Ọlọ́run, Olódùmarè,
\q2 tí ń bẹ, tí ó sì ti wà,
\q1 nítorí pé ìwọ ti gba agbára ńlá rẹ̀,
\q2 ìwọ sì ti jẹ ọba.
\q1 
\v 18 Inú bí àwọn orílẹ̀-èdè, bẹ́ẹ̀ ni ìbínú rẹ̀ ti dé,
\q1 àti àkókò láti dá àwọn òkú lẹ́jọ́,
\q2 àti láti fi èrè fún àwọn ìránṣẹ́ rẹ̀ wòlíì,
\q1 àti àwọn ènìyàn mímọ́, àti àwọn tí o bẹ̀rù orúkọ rẹ̀,
\q2 àti ẹni kékeré àti ẹni ńlá;
\q1 àti láti run àwọn tí ń pa ayé run.”
\p 
\v 19 A sì ṣí tẹmpili Ọlọ́run sílẹ̀ ní ọ̀run, a sì ri àpótí májẹ̀mú nínú tẹmpili rẹ̀. Mọ̀nàmọ́ná sì kọ, a sì gbọ́ ohùn, àrá sì sán, ilẹ̀ sì mi, yìnyín ńlá sì bọ́.
\c 12
\s1 Obìnrin kan àti dragoni
\p 
\v 1 Àmì ńlá kan sì hàn ni ọ̀run; obìnrin kan tí a fi oòrùn wọ̀ ní aṣọ, òṣùpá sì ń bẹ lábẹ́ ẹsẹ̀ rẹ̀, adé oníràwọ̀ méjìlá sì ń bẹ lórí rẹ̀.
\v 2 Ó sì lóyún, ó sì kígbe ni ìrọbí, ó sì wà ni ìrora àti bímọ.
\v 3 Àmì mìíràn sì hàn ní ọ̀run; sì kíyèsi i, dragoni pupa ńlá kan, tí ó ní orí méje àti ìwo mẹ́wàá, àti adé méje ní orí rẹ̀.
\v 4 Ìrù rẹ̀ sì wọ́ ìdámẹ́ta àwọn ìràwọ̀ ní ojú ọ̀run, ó sì jù wọ́n sí ilẹ̀ ayé, dragoni náà sì dúró níwájú obìnrin náà tí ó fẹ́ bímọ, pé nígbà tí o bá bí i, kí òun lè pa ọmọ rẹ̀ jẹ.
\v 5 Ó sì bi ọmọkùnrin kan tí yóò fi ọ̀pá irin ṣe àkóso gbogbo àwọn orílẹ̀-èdè, a sì gba ọmọ rẹ̀ lọ sókè sí ọ̀dọ̀ Ọlọ́run, àti sí orí ìtẹ́ rẹ̀.
\v 6 Obìnrin náà sì sálọ sí aginjù, níbi tí a gbé ti pèsè ààyè sílẹ̀ dè é láti ọwọ́ Ọlọ́run wá, pé kí wọ́n máa bọ́ ọ níbẹ̀ ní ẹgbẹ̀fà ọjọ́ ó lé ọgọ́ta (1,260).
\p 
\v 7 Ogun sì ń bẹ ní ọ̀run: Mikaeli àti àwọn angẹli rẹ̀ bá dragoni náà jagun; dragoni sì jagun àti àwọn angẹli rẹ̀.
\v 8 Wọ́n kò sì lè ṣẹ́gun; bẹ́ẹ̀ ni a kò sì rí ipò wọn mọ́ ni ọ̀run.
\v 9 A sì lé dragoni ńlá náà jáde, ejò láéláé nì, tí a ń pè ni Èṣù, àti Satani, tí ń tan gbogbo ayé jẹ: a sì lé e jù sí ilẹ̀ ayé, a sì lé àwọn angẹli rẹ̀ jáde pẹ̀lú rẹ̀.
\p 
\v 10 Mo sì gbọ́ ohùn ńlá ní ọ̀run, wí pè:
\q1 “Nígbà yìí ni ìgbàlà dé, àti agbára, àti ìjọba Ọlọ́run wá,
\q2 àti ọlá àti Kristi rẹ̀.
\q1 Nítorí a tí le olùfisùn àwọn arákùnrin wa jáde,
\q2 tí o ń fi wọ́n sùn níwájú Ọlọ́run wa lọ́sàn án àti lóru.
\q1 
\v 11 Wọ́n sì ti ṣẹ́gun rẹ̀
\q2 nítorí ẹ̀jẹ̀ ọ̀dọ́-àgùntàn náà,
\q2 àti nítorí ọ̀rọ̀ ẹ̀rí wọn,
\q1 wọn kò sì fẹ́ràn ẹ̀mí wọn
\q2 àní títí dé ikú.
\q1 
\v 12 Nítorí náà ẹ máa yọ̀, ẹ̀yin ọ̀run,
\q2 àti ẹ̀yin tí ń gbé inú wọn.
\q1 Ègbé ni fún ayé àti Òkun;
\q2 nítorí èṣù sọ̀kalẹ̀ tọ̀ yín wá ní ìbínú ńlá,
\q1 nítorí ó mọ̀ pé ìgbà kúkúrú sá ni òun ní.”
\p 
\v 13 Nígbà tí dragoni náà rí pé a lé òun lọ sí ilẹ̀ ayé, ó ṣe inúnibíni sì obìnrin tí ó bí ọmọkùnrin náà.
\v 14 A sì fi apá ìyẹ́ méjì tí idì ńlá náà fún obìnrin náà, pé kí ó fò lọ sí aginjù, sí ipò rẹ̀, níbi tí a ó gbe bọ ọ fún àkókò kan àti fún àwọn àkókò, àti fún ìdajì àkókò kúrò lọ́dọ̀ ejò náà.
\v 15 Ejò náà sì tu omi jáde láti ẹnu rẹ̀ wá bí odò ńlá sẹ́yìn obìnrin náà, kí ó lè fi ìṣàn omi náà gbà á lọ.
\v 16 Ilẹ̀ sì ran obìnrin náà lọ́wọ́, ilẹ̀ sì ya ẹnu rẹ̀, ó sì fi ìṣàn omi náà mú, tí dragoni náà tu jáde láti ẹnu rẹ̀ wá.
\v 17 Dragoni náà sì bínú gidigidi sí obìnrin náà, ó sì lọ bá àwọn irú-ọmọ rẹ̀ ìyókù jagun, tí wọ́n ń pa òfin Ọlọ́run mọ̀, tí wọn sì di ẹ̀rí Jesu mú, Ó sì dúró lórí iyanrìn Òkun.
\c 13
\s1 Ẹranko kan tí n ti inú okun jáde wá
\p 
\v 1 Mo sì rí ẹranko kan ń ti inú Òkun jáde wá, ó ní ìwo mẹ́wàá àti orí méje, lórí àwọn ìwo náà ni adé méje wà, ni orí kọ̀ọ̀kan ni orúkọ ọ̀rọ̀-òdì wà.
\v 2 Ẹranko tí mo rí náà sì dàbí ẹkùn, ẹsẹ̀ rẹ̀ sì dàbí tí beari ẹnu rẹ̀ sì dàbí tí kìnnìún: dragoni náà sì fún un ni agbára rẹ̀, àti ìtẹ́ rẹ̀, àti àṣẹ ńlá.
\v 3 Mo sì rí ọ̀kan nínú àwọn orí rẹ̀ bí ẹni pé a sá a pa, a sì tí wo ọgbẹ́ àṣápa rẹ̀ náà sàn, gbogbo ayé sì fi ìyanu tẹ̀lé ẹranko náà.
\v 4 Wọ́n sì foríbalẹ̀ fún dragoni náà, nítorí tí o fún ẹranko náà ní àṣẹ, wọn sì foríbalẹ̀ fún ẹranko náà, wí pé, “Ta ni o dàbí ẹranko yìí? Ta ni ó sì lè bá a jagun?”
\p 
\v 5 A sì fún un ni ẹnu láti má sọ ohun ńlá àti ọ̀rọ̀-òdì, a sì fi agbára fún un láti ṣe bẹ́ẹ̀ ni oṣù méjìlélógójì.
\v 6 Ó sì ya ẹnu rẹ̀ ni ọ̀rọ̀-òdì sí Ọlọ́run, láti sọ ọ̀rọ̀-òdì sí orúkọ rẹ̀, àti sí àgọ́ rẹ̀, àti sí àwọn tí ń gbé ọ̀run.
\v 7 A sì fún un láti máa bá àwọn ènìyàn mímọ́ jagun, àti láti ṣẹ́gun wọn, a sì fi agbára fún un lórí gbogbo ẹ̀yà, àti ènìyàn, àti èdè, àti orílẹ̀.
\v 8 Gbogbo àwọn tí ń gbé orí ilẹ̀ ayé yóò sì máa sìn ín, olúkúlùkù ẹni tí a kò kọ orúkọ rẹ̀, sínú ìwé ìyè Ọ̀dọ́-Àgùntàn tí a tí pa láti ìpilẹ̀ṣẹ̀ ayé.
\p 
\v 9 Bí ẹnikẹ́ni bá létí kí o gbọ́.
\q1 
\v 10 Ẹni tí a ti pinnu rẹ̀ fún ìgbèkùn,
\q2 ìgbèkùn ni yóò lọ;
\q1 ẹni tí a sì ti pinnu rẹ̀ fún idà,
\q2 ni a ó sì fi idà pa.
\m Níhìn-ín ni sùúrù àti ìgbàgbọ́ àwọn ènìyàn mímọ́ wà.
\s1 Ẹranko jáde nínú ilẹ̀
\p 
\v 11 Mo sì rí ẹranko mìíràn gòkè láti inú ilẹ̀ wá; ó sì ní ìwo méjì bí ọ̀dọ́-àgùntàn, ó sì ń sọ̀rọ̀ bí dragoni.
\v 12 Ó sì ń lo gbogbo agbára ẹranko èkínní níwájú rẹ̀, ó sì mú ilẹ̀ ayé àti àwọn tí ń gbé inú rẹ̀ foríbalẹ̀ fún ẹranko èkínní tí a ti wo ọgbẹ́ àṣápa rẹ̀ sàn.
\v 13 Ó sì ń ṣe ohun ìyanu ńlá, àní tí ó fi ń mú iná sọ̀kalẹ̀ láti ọ̀run wá sì ilẹ̀ ayé níwájú àwọn ènìyàn.
\v 14 Ó sì ń tán àwọn tí ń gbé orí ilẹ̀ ayé jẹ nípa àwọn ohun ìyanu tí a fi fún un láti ṣe níwájú ẹranko náà; ó wí fún àwọn tí ń gbé orí ilẹ̀ ayé láti ya àwòrán fún ẹranko náà tí o tí gbá ọgbẹ́ idà, tí ó sì yè.
\v 15 A sì fi fún un, láti fi ẹ̀mí fún àwòrán ẹranko náà kí ó máa sọ̀rọ̀ kí ó sì mu kí a pa gbogbo àwọn tí kò foríbalẹ̀ fún àwòrán ẹranko náà.
\v 16 Ó sì mu gbogbo wọn, àti kékeré àti ńlá, ọlọ́rọ̀ àti tálákà, olómìnira àti ẹrú, láti gba àmì kan sí ọwọ́ ọ̀tún wọn, tàbí ní iwájú orí wọn;
\v 17 àti kí ẹnikẹ́ni má lè rà tàbí tà, bí kò ṣe ẹni tí o bá ní àmì náà, èyí ni orúkọ ẹranko náà, tàbí àmì orúkọ rẹ̀.
\p 
\v 18 Níhìn-ín ni ọgbọ́n gbé wà. Ẹni tí o bá ní òye, kí o ka òǹkà tí ń bẹ̀ lára ẹranko náà, nítorí pé òǹkà ènìyàn ni, òǹkà rẹ̀ náà sì jẹ́ ọ̀tàlélẹ́gbẹ̀ta ó lé mẹ́fà (666).
\c 14
\s1 Ọ̀dọ́-àgùntàn àti ọ̀kẹ́ méje ó lé ẹgbàajì (144,000)
\p 
\v 1 Mo sì wo, si kíyèsi i, Ọ̀dọ́-Àgùntàn náà dúró lórí òkè Sioni, àti pẹ̀lú rẹ̀ ọ̀kẹ́ méje ó lé ẹgbàajì (144,000) ènìyàn; wọ́n ní orúkọ rẹ̀, àti orúkọ baba rẹ̀ tí a kọ sí iwájú orí wọn.
\v 2 Mo sì gbọ́ ohùn kan láti ọ̀run wá, bí ariwo omi púpọ̀, àti bí sísán àrá ńlá, mo sì gbọ́ àwọn aludùùrù tí wọn ń lu dùùrù.
\v 3 Wọ́n sì ń kọ bí ẹni pé orin tuntun níwájú ìtẹ́ náà, àti níwájú àwọn ẹ̀dá alààyè mẹ́rin n nì àti àwọn àgbà náà, kò sì ṣí ẹni tí o lè kọ orin náà, bí kò ṣe àwọn ọ̀kẹ́ méje ó lé ẹgbàajì (144,000) ènìyàn, tí a tí rà padà láti inú ayé wá.
\v 4 Àwọn wọ̀nyí ni a kò fi obìnrin sọ di èérí, nítorí tí wọ́n jẹ́ wúńdíá. Àwọn wọ̀nyí ni o ń tọ Ọ̀dọ́-àgùntàn náà lẹ́yìn níbikíbi tí o bá ń lọ. Àwọn wọ̀nyí ni a rà padà láti inú àwọn ènìyàn wá, wọ́n jẹ́ àkọ́so fún Ọlọ́run àti fún Ọ̀dọ́-Àgùntàn náà.
\v 5 A kò sì rí èké lẹ́nu wọn, wọn jẹ́ aláìlábùkù.
\s1 Àwọn angẹli mẹ́ta
\p 
\v 6 Mo sì rí angẹli mìíràn ń fò ní àárín méjì ọ̀run, pẹ̀lú ìyìnrere àìnípẹ̀kun láti wàásù fún àwọn tí ń gbé orí ilẹ̀ ayé, àti fún gbogbo orílẹ̀, àti ẹ̀yà, àti èdè, àti ènìyàn.
\v 7 Ó ń wí ni ohùn rara pé, “Ẹ bẹ̀rù Ọlọ́run, kí ẹ sì fi ògo fún un, nítorí tí wákàtí ìdájọ́ rẹ̀ dé: ẹ sì foríbalẹ̀ fún ẹni tí o dá ọ̀run, àti ayé, àti Òkun, àti àwọn orísun omi!”
\p 
\v 8 Angẹli mìíràn sì tẹ̀lé e, ó ń wí pé, “o ṣubú, Babeli ńlá ṣubú, èyí ti o tí ń mú gbogbo orílẹ̀-èdè mu nínú ọtí wáìnì àìmọ́ àgbèrè rẹ̀!”
\p 
\v 9 Angẹli mìíràn, ẹ̀kẹta, sì tẹ̀lé wọn, ó ń wí ni ohùn rara pé, “Bí ẹnikẹ́ni bá ń foríbalẹ̀ fún ẹranko náà àti àwòrán rẹ̀, tí ó sì gba àmì sí iwájú orí rẹ̀ tàbí sí ọwọ́ rẹ̀.
\v 10 Òun pẹ̀lú yóò mú nínú ọtí wáìnì ìbínú Ọlọ́run, tí a dà ní ẹ̀kúnrẹ́rẹ́ sínú ago ìrunú rẹ̀; a ó sì fi iná sulfuru dá a lóró níwájú àwọn angẹli mímọ́, àti níwájú Ọ̀dọ́-àgùntàn.
\v 11 Èéfín ìdálóró wọn ń lọ sókè títí láéláé wọn kò sì ní ìsinmi ni ọ̀sán àti ní òru, àwọn tí ń foríbalẹ̀ fún ẹranko náà àti fún àwòrán rẹ̀, àti ẹnikẹ́ni tí o ba sì gba àmì orúkọ rẹ̀.”
\v 12 Níhìn-ín ni sùúrù àwọn ènìyàn mímọ́ gbé wà: àwọn tí ń pa òfin Ọlọ́run àti ìgbàgbọ́ Jesu mọ́.
\p 
\v 13 Mo sì gbọ́ ohùn kan láti ọ̀run wá ń wí fún mi pé, “Kọ̀wé rẹ̀, Alábùkún fún ni àwọn òkú tí o kú nínú Olúwa láti ìhín lọ.”
\p Alábùkún ni wọ́n nítòótọ́, bẹ́ẹ̀ ni, Ẹ̀mí wí, “Nítorí tí wọn yóò sinmi kúrò nínú làálàá wọn, nítorí iṣẹ́ wọn ń tọ̀ wọn lẹ́yìn.”
\s1 Ìkórè ayé
\p 
\v 14 Mo sì wo, sì kíyèsi i, ìkùùkuu àwọsánmọ̀ funfun kan, àti lórí ìkùùkuu àwọsánmọ̀ náà ẹnìkan jókòó tí o dàbí “ọmọ ènìyàn,” tí òun ti adé wúrà ní orí rẹ̀, àti dòjé mímú ni ọwọ́ rẹ̀.
\v 15 Angẹli mìíràn sì tí inú tẹmpili jáde wa tí ń ké lóhùn rara sí ẹni tí ó jókòó lórí ìkùùkuu àwọsánmọ̀ náà pé, “Tẹ dòjé rẹ bọ̀ ọ́, kí ó sì máa kórè; nítorí àkókò àti kórè dé, nítorí ìkórè ayé ti gbó tán.”
\v 16 Ẹni tí ó jókòó lórí ìkùùkuu àwọsánmọ̀ náà sì tẹ dòjé rẹ̀ bọ orí ilẹ̀ ayé; a sì ṣe ìkórè ilẹ̀ ayé.
\p 
\v 17 Angẹli mìíràn sì tí inú tẹmpili tí ń bẹ ni ọ̀run jáde wá, òun pẹ̀lú sì ní dòjé mímú, kan.
\v 18 Angẹli mìíràn sì tí ibi pẹpẹ jáde wá, tí ó ní agbára lórí iná; ó sì ké ni ohùn rara sí ẹni tí o ni dòjé mímú náà, wí pé, “Tẹ dòjé rẹ mímú bọ̀ ọ́, ki ó sì rẹ́ àwọn ìdì àjàrà ayé, nítorí àwọn èso rẹ̀ tí pọ́n.”
\v 19 Angẹli náà sì tẹ dòjé rẹ̀ bọ ilẹ̀ ayé, ó sì gé àjàrà ilẹ̀ ayé, ó sì kó o lọ sínú ìfúntí, ìfúntí ńlá ìbínú Ọlọ́run.
\v 20 A sì tẹ ìfúntí náà lẹ́yìn òde ìlú náà, ẹ̀jẹ̀ sì ti inú ìfúntí náà jáde, ó sì ga sókè dé okùn ìjánu ẹṣin, èyí tí ìnàsílẹ̀ rẹ to ẹ̀gbẹjọ̀ (1,600) ibùsọ̀.
\c 15
\s1 Angẹli méje pẹ̀lú ìyọnu méje
\p 
\v 1 Mo sì rí àmì mìíràn ní ọ̀run tí ó tóbi tí ó sì ya ni lẹ́nu, àwọn angẹli méje tí ó ni àwọn ìyọnu méje ìkẹyìn, nítorí nínú wọn ni ìbínú Ọlọ́run dé òpin.
\v 2 Mo sì rí bí ẹni pé, Òkun dígí tí o dàpọ̀ pẹ̀lú iná: àwọn tí ó sì dúró lórí Òkun dígí yìí jẹ́ àwọn ti wọ́n ṣẹ́gun ẹranko náà, àti àwòrán rẹ̀, àti àmì rẹ̀ àti nọ́mbà orúkọ rẹ̀, wọn ní ohun èlò orin Ọlọ́run.
\v 3 Wọ́n sì ń kọ orin ti Mose, ìránṣẹ́ Ọlọ́run, àti orin ti Ọ̀dọ́-Àgùntàn, wí pé:
\q1 “Títóbi àti ìyanu ni àwọn iṣẹ́ rẹ,
\q2 Olúwa Ọlọ́run Olódùmarè;
\q1 òdodo àti òtítọ́ ni ọ̀nà rẹ̀,
\q2 ìwọ ọba àwọn orílẹ̀-èdè.
\q1 
\v 4 Ta ni kì yóò bẹ̀rù, Olúwa,
\q2 tí kì yóò sì fi ògo fún orúkọ rẹ̀?
\q1 Nítorí ìwọ nìkan ṣoṣo ni mímọ́.
\q1 Gbogbo àwọn orílẹ̀-èdè ni yóò sì wá,
\q2 ti yóò sì foríbalẹ̀ níwájú rẹ,
\q1 nítorí a ti fi ìdájọ́ rẹ hàn.”
\p 
\v 5 Lẹ́yìn náà mo sì wo, sì kíyèsi i, a ṣí tẹmpili àgọ́ ẹ̀rí ní ọ̀run sílẹ̀;
\v 6 àwọn angẹli méje náà sì ti inú tẹmpili jáde wá, wọ́n ni ìyọnu méje náà, a wọ̀ wọ́n ní aṣọ ọ̀gbọ̀ funfun ti ń dán, a sì fi àmùrè wúrà dìwọ́n ni oókan àyà.
\v 7 Àti ọ̀kan nínú àwọn ẹ̀dá alààyè mẹ́rin náà fi ìgò wúrà méje fún àwọn angẹli méje náà, tí ó kún fún ìbínú Ọlọ́run, ẹni tí ń bẹ láààyè láé àti láéláé.
\v 8 Tẹmpili náà sì kún fún èéfín láti inú ògo Ọlọ́run àti agbára rẹ̀ wá; ẹnikẹ́ni kò sì lè wọ inú tẹmpili náà lọ títí a fi mú ìyọnu méjèèje àwọn angẹli méje náà ṣẹ.
\c 16
\s1 Àwọn ago ìbínú Ọlọ́run
\p 
\v 1 Mo sì gbọ́ ohùn ńlá kan láti inú tẹmpili wá, ń wí fún àwọn angẹli, méje nì pé, “Ẹ lọ, ẹ sì tú ago ìbínú Ọlọ́run wọ̀n-ọn-nì sí orí ayé.”
\p 
\v 2 Èkínní sì lọ, ó sì tú ago tirẹ̀ sí orílẹ̀ ayé: egbò kíkẹ̀ tí ó sì díbàjẹ́ sì dá àwọn ènìyàn tí ó ní àmì ẹranko náà, àti àwọn tí ń foríbalẹ̀ fún àwòrán rẹ̀.
\p 
\v 3 Èkejì sì tú ago sínú Òkun; ó sì dàbí ẹ̀jẹ̀ òkú ènìyàn, gbogbo ọkàn alààyè sì kú nínú Òkun.
\p 
\v 4 Ẹ̀kẹta sì tú ago tirẹ̀ sínú odò, àti sí orísun àwọn omi; wọ́n sì di ẹ̀jẹ̀.
\v 5 Mo sì gbọ́ angẹli tí ó n wí pé:
\q1 “Olódodo ni ìwọ ninu gbogbo ìdájọ́ wọ̀nyí,
\q2 ìwọ ẹni tí ó n bẹ àti tí ó tí wa, Ẹni Mímọ́
\q2 nítorí tí ìwọ ṣe ìdájọ́ bẹ́ẹ̀.
\q1 
\v 6 Nítorí tí wọ́n ti ta ẹ̀jẹ̀ àwọn ènìyàn mímọ́ àti ti àwọn wòlíì sílẹ̀,
\q2 ìwọ sì fi ẹ̀jẹ̀ fún wọn mu; èyí yìí ní ó yẹ wọ́n.”
\m 
\v 7 Mo sì gbọ́ ti pẹpẹ ń ké wí pé:
\q1 “Bẹ́ẹ̀ ni, Olúwa Ọlọ́run Olódùmarè,
\q2 òtítọ́ àti òdodo ní ìdájọ́ rẹ.”
\p 
\v 8 Ẹ̀kẹrin sì tú ago tirẹ̀ sórí oòrùn; a sì yọ̀ǹda fún un láti fi iná jó ènìyàn lára.
\v 9 A sì fi ooru ńlá jó àwọn ènìyàn lára, wọ́n sì sọ̀rọ̀-òdì sí orúkọ Ọlọ́run, ẹni tí ó ní agbára lórí ìyọnu wọ̀nyí: wọn kò sì ronúpìwàdà láti fi ògo fún un.
\p 
\v 10 Ẹ̀karùnún sì tú ago tirẹ̀ sórí ìtẹ́ ẹranko náà; ilẹ̀ ọba rẹ̀ sì ṣókùnkùn; wọ́n sì ń gé ahọ́n wọn jẹ́ nítorí ìrora.
\v 11 Wọ́n sì sọ̀rọ̀-òdì sí Ọlọ́run ọ̀run nítorí ìrora wọn àti nítorí egbò wọn, wọ́n kò sì ronúpìwàdà iṣẹ́ wọn.
\p 
\v 12 Ẹ̀kẹfà sì tu ìgò tirẹ̀ sórí odò ńlá Eufurate; omi rẹ̀ sì gbẹ, kí a lè pèsè ọ̀nà fún àwọn ọba láti ìlà-oòrùn wá.
\v 13 Mo sì rí àwọn ẹ̀mí àìmọ́ mẹ́ta bí ọ̀pọ̀lọ́, wọ́n ti ẹnu dragoni náà àti ẹnu ẹranko náà àti ẹnu wòlíì èké náà jáde wá.
\v 14 Nítorí ẹ̀mí èṣù ni wọ́n, tí ń ṣe iṣẹ́ ìyanu, àwọn tí ń jáde lọ sọ́dọ̀ àwọn ọba gbogbo ilẹ̀ ayé, láti gbá wọn jọ sí ogun ọjọ́ ńlá Ọlọ́run Olódùmarè.
\b
\mi1 
\v 15 \wj “Kíyèsi i; ń bọ̀ bi olè, ìbùkún ni fún ẹni tí ń ṣọ́nà, tí ó sì ń pa aṣọ rẹ̀ mọ́, kí ó má bá a rìn ni ìhòhò, wọn a sì rí ìtìjú rẹ̀.”\wj*
\b
\m 
\v 16 Ó sì gbá wọn jọ́ sí ibìkan tí a ń pè ní Amagedoni ní èdè Heberu.
\p 
\v 17 Èkeje si tú ago tirẹ̀ sí ojú ọ̀run; ohùn ńlá kan sì ti inú tẹmpili jáde láti ibi ìtẹ́, wí pé, “Ó parí!”
\v 18 Mọ̀nàmọ́ná sì kọ, a sì gbọ́ ohùn, àrá sì sán, ìṣẹ̀lẹ̀ ńlá sì ṣẹ̀, irú èyí tí kò ṣẹ̀ ri láti ìgbà tí ènìyàn ti wà lórí ilẹ̀, irú ìṣẹ̀lẹ̀ ńlá bẹ́ẹ̀, tí ó sì lágbára tó bẹ́ẹ̀.
\v 19 Ìlú ńlá náà sì pín sí ipa mẹ́ta, àwọn orílẹ̀-èdè sì ṣubú: Babeli ńlá sì wá sí ìrántí níwájú Ọlọ́run, láti fi ago ọtí wáìnì ti ìrunú ìbínú rẹ̀ fún un.
\v 20 Olúkúlùkù erékùṣù sì sálọ, a kò sì ri àwọn òkè ńlá mọ́.
\v 21 Yìnyín ńlá, tí ọ̀kọ̀ọ̀kan rẹ̀ tó tálẹ́ǹtì ní ìwọ̀n, sì bọ́ lù àwọn ènìyàn láti ọ̀run wà, àwọn ènìyàn sì sọ̀rọ̀-òdì sí Ọlọ́run nítorí ìyọnu yìnyín náà; nítorí tí ìyọnu rẹ̀ náà pọ̀ gidigidi.
\c 17
\s1 Obìnrin àti ẹranko
\p 
\v 1 Ọ̀kan nínú àwọn angẹli méje náà tí ó ní ìgò méje wọ̀n-ọn-nì sì wá, ó sì ba mi sọ̀rọ̀ wí pé, “Wá níhìn-ín; èmi ó sì fi ìdájọ́ àgbèrè ńlá ní tí ó jókòó lórí omi púpọ̀ han ọ,
\v 2 ẹni tí àwọn ọba ayé bá ṣe àgbèrè, tí a sì fi ọtí wáìnì àgbèrè rẹ̀ pa àwọn tí ń gbé inú ayé.”
\p 
\v 3 Ó sì gbé mi nínú ẹ̀mí lọ sí aginjù: mo sì rí obìnrin kan ó jókòó lórí ẹranko aláwọ̀ òdòdó kan tí ó kún fún orúkọ ọ̀rọ̀-òdì, ó ní orí méje àti ìwo mẹ́wàá.
\v 4 A sì fi aṣọ elése àlùkò àti aṣọ òdòdó wọ obìnrin náà, a sì fi wúrà àti òkúta iyebíye àti perli ṣe é ní ọ̀ṣọ́, ó ní ago wúrà kan ní ọwọ́ rẹ̀, tí ó kún fún ìríra àti fún ẹ̀gbin àgbèrè rẹ̀;
\v 5 àti níwájú rẹ̀ ni orúkọ kan tí a kọ:
\pc Ohun ìjìnlẹ̀ Babeli ńlá
\pc ìyá àwọn panṣágà
\pc àti àwọn ohun ìríra ayé.
\m 
\v 6 Mo sì rí obìnrin náà mu ẹ̀jẹ̀ àwọn ènìyàn mímọ́, àti ẹ̀jẹ̀ àwọn ajẹ́rìí ikú Jesu ní àmuyó.
\p Nígbà tí mo sì rí i, ẹnu yà mi gidigidi.
\v 7 Angẹli sì wí fún mi pé, “Nítorí kí ni ẹnu ṣe yà ọ́? Èmi ó sọ ti ìjìnlẹ̀ obìnrin náà fún ọ, àti ti ẹranko tí ó gùn, ti ó ní orí méje àti ìwo mẹ́wàá.
\v 8 Ẹranko tí ìwọ ri nì, o ti wà, kò sì ṣí mọ́, yóò sì ti inú ọ̀gbun gòkè wá, yóò sì lọ sínú ìparun rẹ. Àwọn olùgbé ayé ti a kọ orúkọ wọn sínú ìwé iye láti ìpilẹ̀ṣẹ̀ ayé, nígbà tí wọn ń wò ẹranko tí o ti wà, tí kò sì ṣí mọ́, tí ó sì ń bọ̀ wá, ẹnu si ya wọn.
\p 
\v 9 “Níhìn-ín ni ìtumọ̀ tí o ní ọgbọ́n wà. Orí méje ni òkè ńlá méje ni, lórí èyí tí obìnrin náà jókòó.
\v 10 Ọba méje sì ní wọn: àwọn márùn-ún ṣubú, ọ̀kan ń bẹ, ọ̀kan ìyókù kò sì tí ì dé; nígbà tí ó bá sì dé, yóò dúró fún ìgbà kúkúrú.
\v 11 Ẹranko tí ó sì ti wà, tí kò sì ṣí, òun náà sì ni ẹ̀kẹjọ, ó sì ti inú àwọn méje náà wá, ó sì lọ sí ìparun.
\p 
\v 12 “Ìwo mẹ́wàá tí ìwọ sì rí ni ọba mẹ́wàá ni wọn, tí wọn kò ì ti gba ìjọba; ṣùgbọ́n wọn gba àṣẹ bí ọba pẹ̀lú ẹranko náà fún wákàtí kan.
\v 13 Àwọn wọ̀nyí ní inú kan, wọ́n yóò sì fi agbára àti ọlá wọn fún ẹranko náà.
\v 14 Àwọn wọ̀nyí ni yóò si máa bá Ọ̀dọ́-Àgùntàn jagun, Ọ̀dọ́-Àgùntàn náà yóò sì ṣẹ́gun wọn: nítorí òun ni Olúwa àwọn Olúwa, àti ọba àwọn ọba: àwọn tí ó sì wà pẹ̀lú rẹ̀, tí a pè, tí a yàn, tí wọ́n sì jẹ́ olóòtítọ́ yóò sì ṣẹ́gun pẹ̀lú.”
\p 
\v 15 Ó sì wí fún mi pé, “Àwọn omi tí ìwọ ti rí ni, níbi tí àgbèrè náà jókòó, àwọn ènìyàn àti ẹ̀yà àti orílẹ̀ àti onírúurú èdè ni wọ́n.
\v 16 Àti ìwo mẹ́wàá tí ìwọ rí, àti ẹranko náà, àwọn wọ̀nyí ni yóò kórìíra àgbèrè náà, wọn ó sì sọ ọ́ di ahoro àti ẹni ìhòhò, wọn ó sì jẹ ẹran-ara rẹ̀, wọn ó sì fi iná sun ún pátápátá.
\v 17 Nítorí Ọlọ́run ti fi sínú ọkàn wọn láti mú ìfẹ́ rẹ̀ ṣẹ, láti ní inú kan, àti láti fi ìjọba wọn fún ẹranko náà, títí ọ̀rọ̀ Ọlọ́run yóò fi ṣẹ.
\v 18 Obìnrin tí ìwọ rí ní ìlú ńlá ni, tí ń jẹ ọba lórí àwọn ọba ilẹ̀ ayé.”
\c 18
\s1 Ìṣubú Babeli
\p 
\v 1 Lẹ́yìn nǹkan wọ̀nyí mo sì rí angẹli mìíràn, ó ń ti ọ̀run sọ̀kalẹ̀ wá ti òun ti agbára ńlá; ilẹ̀ ayé sì ti ipa ògo rẹ̀ mọ́lẹ̀.
\v 2 Ó sì kígbe ní ohùn rara, wí pé:
\q1 “Babeli ńlá ṣubú! Ó ṣubú!
\q2 Ó sì di ibùjókòó àwọn ẹ̀mí èṣù,
\q1 àti ihò fún ẹ̀mí àìmọ́ gbogbo,
\q2 àti ilé fún ẹyẹ àìmọ́ gbogbo,
\q2 ilé fún ẹranko ìríra àti àìmọ́ gbogbo.
\q1 
\v 3 Nítorí nípa ọtí wáìnì ìrunú àgbèrè rẹ̀ ni
\q2 gbogbo àwọn orílẹ̀-èdè ṣubú.
\q1 Àwọn ọba ayé sì ti bá a ṣe àgbèrè,
\q2 àti àwọn oníṣòwò ayé sì di ọlọ́rọ̀ nípa ọ̀pọ̀lọpọ̀ wọ̀bìà rẹ̀.”
\p 
\v 4 Mo sì gbọ́ ohùn mìíràn láti ọ̀run wá, wí pé:
\q1 “ ‘Ẹ ti inú rẹ̀ jáde, ẹ̀yin ènìyàn mi,’
\q2 kí ẹ ma bá a ṣe alábápín nínú ẹ̀ṣẹ̀ rẹ̀,
\q2 kí ẹ ma bà á sì ṣe gbà nínú ìyọnu rẹ̀.
\q1 
\v 5 Nítorí àwọn ẹ̀ṣẹ̀ rẹ̀ ga títí dé ọ̀run,
\q2 Ọlọ́run sì ti rántí àìṣedéédéé rẹ̀.
\q1 
\v 6 San an fún un, àní bí òun tí san án fún ní,
\q2 kí ó sì ṣe e ni ìlọ́po méjì fún un gẹ́gẹ́ bí iṣẹ́ rẹ̀,
\q2 nínú ago náà tí o ti kún, òun ni kí ẹ sì kún fún un ni méjì.
\q1 
\v 7 Níwọ́n bí o ti yin ara rẹ̀ lógo tó,
\q2 tí ó sì hùwà wọ̀bìà,
\q1 níwọ̀n bẹ́ẹ̀ ni kí ẹ dá a lóró kí ẹ sì fún un ní ìbànújẹ́;
\q2 nítorí tí ó wí ní ọkàn rẹ̀ pé,
\q2 ‘Mo jókòó bí ọbabìnrin,
\q2 èmi kì sì í ṣe opó, èmí kì yóò sì rí ìbànújẹ́ láé.’
\q1 
\v 8 Nítorí náà, ní ọjọ́ kan ni ìyọnu rẹ̀ yóò dé,
\q2 ikú, àti ìbìnújẹ́, àti ìyàn;
\q1 a ó sì fi iná sun ún pátápátá:
\q2 nítorí pé alágbára ni Olúwa Ọlọ́run tí ń ṣe ìdájọ́ rẹ̀.
\p 
\v 9 “Àti àwọn ọba ayé, tí ó ti ń bá a ṣe àgbèrè, tiwọn sì ń hùwà wọ̀bìà, yóò sì pohùnréré ẹkún lé e lórí, nígbà tí wọn bá wo èéfín ìjóná rẹ̀.
\v 10 Wọ́n ó dúró ní òkèrè réré nítorí ìbẹ̀rù iṣẹ́ oró rẹ̀, wọn ó máa wí pé:
\q1 “ ‘Ègbé! Ègbé, ni fún ìlú ńlá náà,
\q2 Babeli ìlú alágbára nì!
\q1 Nítorí ní wákàtí kan ni ìdájọ́ rẹ dé!’
\p 
\v 11 “Àwọn oníṣòwò ayé sì ń sọkún, wọn sì ń ṣọ̀fọ̀ lórí rẹ̀, nítorí pé ẹnikẹ́ni kò rà ọjà wọn mọ́.
\v 12 Ọjà wúrà, àti ti fàdákà, àti ti òkúta iyebíye, àti ti perli, àti ti aṣọ ọ̀gbọ̀ wíwẹ́, àti tí elése àlùkò, àti ti ṣẹ́dà, àti ti òdòdó, àti ti gbogbo igi olóòórùn dídùn, àti ti olúkúlùkù ohun èlò tí a fi igi iyebíye ṣe, àti ti idẹ, àti ti irin, àti ti òkúta mabu.
\v 13 Àti ti Kinamoni, àti ti onírúurú ohun olóòórùn dídùn, àti ti ohun ìkunra, àti tí tùràrí, àti ti ọtí wáìnì, àti ti òróró, àti ti ìyẹ̀fun dáradára, àti ti alikama, àti ti ẹran ńlá, àti ti àgùntàn, àti ti ẹṣin, àti ti kẹ̀kẹ́, àti ti ẹrú, àti ti ọkàn ènìyàn.
\p 
\v 14 “Àti àwọn èso tí ọkàn rẹ̀ ń ṣe. Ìfẹ́kúfẹ̀ẹ́ sí, si lọ kúrò lọ́dọ̀ rẹ, àti ohun gbogbo tí ó dùn tí ó sì dára ṣègbé mọ́ ọ lójú, kì yóò sì tún rí wọn mọ́ láé.
\v 15 Àwọn oníṣòwò nǹkan wọ̀nyí, tí a ti ipa rẹ̀ sọ di ọlọ́rọ̀, yóò dúró ní òkèrè réré nítorí ìbẹ̀rù iṣẹ́ oró rẹ̀, wọn o máa sọkún, wọ́n ó sì máa ṣọ̀fọ̀,
\v 16 wí pé:
\q1 “ ‘Ègbé! Ègbé, ni fún ìlú ńlá nì,
\q2 tí a wọ̀ ní aṣọ ọ̀gbọ̀ wíwẹ́,
\q2 àti ti elése àlùkò, àti ti òdòdó, àti ti a sì fi wúrà ṣe ní ọ̀ṣọ́, pẹ̀lú òkúta iyebíye àti peali!
\q1 
\v 17 Nítorí pé ní wákàtí kan ni ọrọ̀ ti o pọ̀ tó bẹ́ẹ̀ di asán!’
\p “Àti olúkúlùkù ẹni tí ń rin ojú omi lọ sí ibikíbi, àti àwọn ti ń ṣiṣẹ́ nínú ọkọ àwọn ti ń ṣòwò ojú Òkun dúró ní òkèrè réré,
\v 18 wọ́n sì kígbe nígbà tí wọ́n rí èéfín jíjóná rẹ́, wí pé, ‘Ìlú wo ni o dàbí ìlú yìí?’
\v 19 Wọ́n sì kú ekuru sí orí wọn, wọ́n kígbe, wọ́n sọkún, wọn sì ń ṣọ̀fọ̀, wí pé:
\q1 “ ‘Ègbé! Ègbé, ni fún ìlú ńlá náà,
\q2 nínú èyí tí a sọ gbogbo àwọn tí ó ni ọkọ̀
\q2 ní Òkun di ọlọ́rọ̀ nípa ohun iyebíye rẹ̀!
\q1 Nítorí pé ni wákàtí kan, a sọ ọ́ di ahoro.’
\b
\q1 
\v 20 “Yọ̀ lórí rẹ̀, ìwọ ọ̀run!
\q2 Ẹ yọ̀, ẹ̀yin ènìyàn Ọlọ́run!
\q2 Ẹ yọ̀, ẹ̀yin aposteli mímọ́ àti wòlíì!
\q1 Nítorí Ọlọ́run ti gbẹ̀san yín lára rẹ̀
\q2 nítorí ìdájọ́ tí ó gbé ka orí rẹ.”
\p 
\v 21 Angẹli alágbára kan sì gbé òkúta kan sókè, ó dàbí ọlọ ńlá, ó sì jù ú sínú Òkun, wí pé:
\q1 “Báyìí ní a ó fi agbára ńlá
\q2 bí i Babeli ìlú ńlá ni wó,
\q2 a kì yóò sì rí i mọ́ láé.
\q1 
\v 22 Àti ohùn àwọn aludùùrù, àti ti àwọn olórin,
\q2 àti ti àwọn afunfèrè, àti ti àwọn afùnpè,
\q1 ni a kì yóò sì gbọ́ nínú rẹ mọ́ rara;
\q2 àti olúkúlùkù oníṣọ̀nà ohunkóhun ni a kì yóò sì rí nínú rẹ mọ́ láé.
\q1 Àti ìró ọlọ ní a kì yóò
\q2 sì gbọ́ mọ̀ nínú rẹ láé;
\q1 
\v 23 Àti ìmọ́lẹ̀ fìtílà ni kì yóò sì tàn nínú rẹ̀ mọ́ láé;
\q2 a kì yóò sì gbọ́ ohùn ọkọ ìyàwó àti ti ìyàwó nínú rẹ mọ́ láé:
\q1 nítorí pé àwọn oníṣòwò rẹ̀ ni àwọn ẹni ńlá ayé;
\q2 nítorí pé nípa ọ̀ṣọ́ rẹ̀ ní a fi tàn orílẹ̀-èdè gbogbo jẹ.
\q1 
\v 24 Àti nínú rẹ̀ ní a gbé ri ẹ̀jẹ̀ àwọn wòlíì,
\q2 àti ti àwọn ènìyàn mímọ́, àti ti gbogbo àwọn tí a pa lórí ilẹ̀ ayé.”
\c 19
\s1 Haleluya
\p 
\v 1 Lẹ́yìn nǹkan wọ̀nyí mo gbọ́ ohùn ńlá ní ọ̀run bí ẹni pé tí ọ̀pọ̀lọpọ̀ ènìyàn, ń wí pé:
\q1 “Haleluya!
\q1 Ti Olúwa Ọlọ́run wa ni ìgbàlà, àti ọlá àti agbára,
\q2 
\v 2 nítorí òtítọ́ àti òdodo ni ìdájọ́ rẹ̀.
\q1 Nítorí o ti ṣe ìdájọ́ àgbèrè ńlá a nì,
\q2 tí o fi àgbèrè rẹ̀ ba ilẹ̀ ayé jẹ́, ó sì ti gbẹ̀san ẹ̀jẹ̀ àwọn ìránṣẹ́ rẹ̀ lọ́wọ́ rẹ̀ náà.”
\m 
\v 3 Àti lẹ́ẹ̀kejì wọ́n wí pé:
\q1 “Haleluya!
\q1 Èéfín rẹ̀ sì gòkè lọ láé àti láéláé.”
\p 
\v 4 Àwọn àgbà mẹ́rìnlélógún nì, àti àwọn ẹ̀dá alààyè mẹ́rin nì sì wólẹ̀, wọ́n sì foríbalẹ̀ fún Ọlọ́run tí ó jókòó lórí ìtẹ́, wí pé:
\q1 “Àmín, Haleluya!”
\p 
\v 5 Ohùn kan sì ti ibi ìtẹ́ náà jáde wá, wí pé:
\q1 “Ẹ máa yin Ọlọ́run wa,
\q2 ẹ̀yin ìránṣẹ́ rẹ̀ gbogbo,
\q1 ẹ̀yin tí ó bẹ̀rù rẹ̀,
\q2 àti èwe àti àgbà!”
\p 
\v 6 Mo sì gbọ́ bí ẹni pé ohùn ọ̀pọ̀lọpọ̀ ènìyàn, àti bí ìró omi púpọ̀, àti bí ìró àrá ńlá ńlá, ń wí pé:
\q1 “Haleluya!
\q1 Nítorí Olúwa Ọlọ́run wa, Olódùmarè ń jẹ ọba.
\q1 
\v 7 Ẹ jẹ́ kí a yọ̀, kí inú wa kí ó sì dùn gidigidi,
\q2 kí a sì fi ògo fún un.
\q1 Nítorí pé ìgbéyàwó Ọ̀dọ́-Àgùntàn dé,
\q2 aya rẹ̀ sì ti múra tán.
\q1 
\v 8 Òun ni a sì fi fún pé kí ó wọ aṣọ ọ̀gbọ̀
\q2 wíwẹ́ tí ó funfun gbòò.”
\m (Nítorí pé aṣọ ọ̀gbọ̀ nì dúró fún iṣẹ́ òdodo àwọn ènìyàn mímọ́.)
\b
\p 
\v 9 Ó sì wí fún mi pé, “Kọ̀wé rẹ̀, ‘Ìbùkún ni fún àwọn tí a pè sí àsè alẹ́ ìgbéyàwó ọ̀dọ́-àgùntàn.’ ” Ó sì wí fún mi pé, “Ìwọ̀nyí ni ọ̀rọ̀ òtítọ́ Ọlọ́run.”
\p 
\v 10 Mo sì wólẹ̀ ní ẹsẹ̀ rẹ̀ láti foríbalẹ̀ fún un. Ó sì wí fún mi pé, “Wò ó, má ṣe bẹ́ẹ̀: ìránṣẹ́ ẹlẹgbẹ́ rẹ̀ ni èmi, àti ti àwọn arákùnrin rẹ̀ tí wọ́n di ẹ̀rí Jesu mú. Foríbalẹ̀ fún Ọlọ́run: nítorí pé ẹ̀rí Jesu ni ìsọtẹ́lẹ̀.”
\s1 Ẹni tó gun ẹṣin funfun
\p 
\v 11 Mo sì rí ọ̀run ṣí sílẹ̀, sì wò ó, ẹṣin funfun kan; ẹni tí ó jókòó lórí rẹ̀ ni à ń pè ní Olódodo àti Olóòtítọ́, nínú òdodo ni ó sì ń ṣe ìdájọ́, tí ó ń jagun.
\v 12 Ojú rẹ̀ dàbí ọ̀wọ́-iná, àti ní orí rẹ̀ ni adé púpọ̀ wà; ó sì ní orúkọ kan tí a kọ, tí ẹnikẹ́ni kò mọ́, bí kò ṣe òun tìkára rẹ̀.
\v 13 A sì wọ̀ ọ́ ní aṣọ tí a tẹ̀ bọ inú ẹ̀jẹ̀, a sì ń pe orúkọ rẹ̀ ní Ọ̀rọ̀ Ọlọ́run.
\v 14 Àwọn ogun tí ń bẹ ní ọ̀run tí a wọ̀ ní aṣọ ọ̀gbọ̀ wíwẹ́, funfun àti mímọ́, sì ń tọ̀ ọ́ lẹ́yìn lórí ẹṣin funfun.
\v 15 Àti láti ẹnu rẹ̀ ni idà mímú ti ń jáde lọ, kí ó lè máa fi sá àwọn orílẹ̀-èdè: “Òun ó sì máa fi ọ̀pá irin ṣe àkóso wọn.” Ó sì ń tẹ ìfúntí àti ìbínú Ọlọ́run Olódùmarè.
\v 16 Ó sì ní lára aṣọ rẹ̀ àti ni ìtàn rẹ̀ orúkọ kan tí a kọ:
\pc Ọba àwọn ọba àti Olúwa àwọn olúwa.
\p 
\v 17 Mo sì rí angẹli kan dúró nínú oòrùn; ó sì fi ohùn rara kígbe, ó ń wí fún gbogbo àwọn ẹyẹ tí ń fò ní agbede-méjì ọ̀run pé, “Ẹ wá ẹ sì kó ara yín jọ pọ̀ sí àsè ńlá Ọlọ́run;
\v 18 kí ẹ̀yin kí ó lè jẹ ẹran-ara àwọn ọba, àti ẹran-ara àwọn olórí ogun àti ẹran-ara àwọn ènìyàn alágbára, àti ẹran àwọn ẹṣin, àti ti àwọn tí ó jókòó lórí wọn, àti ẹran-ara ènìyàn gbogbo, àti ti òmìnira, àti ti ẹrú, àti ti èwe àti ti àgbà.”
\p 
\v 19 Mo sì rí ẹranko náà àti àwọn ọba ayé, àti àwọn ogun wọn tí a gbá jọ láti bá ẹni tí ó jókòó lórí ẹṣin náà àti ogun rẹ̀ jagun.
\v 20 A sì mú ẹranko náà, àti wòlíì èké nì pẹ̀lú rẹ̀, tí ó ti ń ṣe iṣẹ́ ìyanu níwájú rẹ̀, èyí tí ó fi ń tan àwọn tí ó gba àmì ẹranko náà àti àwọn tí ń foríbalẹ̀ fún àwòrán rẹ̀ jẹ. Àwọn méjèèjì yìí ni a sọ láààyè sínú adágún iná tí ń fi sulfuru jó.
\v 21 Àwọn ìyókù ni a sì fi idà ẹni tí ó jókòó lórí ẹṣin náà pa, àní idà tí ó ti ẹnu rẹ̀ jáde, gbogbo àwọn ẹyẹ sì ti ipa ẹran-ara wọn yó.
\c 20
\s1 Ìjọba ẹgbẹ̀rún ọdún
\p 
\v 1 Mo sì rí angẹli kan ń ti ọ̀run sọ̀kalẹ̀ wá, ti òun ti kọ́kọ́rọ́ ọ̀gbun, àti ẹ̀wọ̀n ńlá kan ní ọwọ́ rẹ̀.
\v 2 O sì di dragoni náà mú, ejò àtijọ́ nì, tí í ṣe èṣù, àti Satani, ó sì dè é ní ẹgbẹ̀rún (1,000) ọdún.
\v 3 Ó sì gbé e sọ sínú ọ̀gbun náà, ó sì tì í, ó sì fi èdìdì dì í lórí rẹ̀, kí ó má ba à tan àwọn orílẹ̀-èdè jẹ mọ́ títí ẹgbẹ̀rún (1,000) ọdún náà yóò fi pé. Lẹ́yìn èyí, a kò le ṣàì tú u sílẹ̀ fún ìgbà díẹ̀.
\p 
\v 4 Mo sì rí àwọn ìtẹ́, wọ́n sì jókòó lórí wọn, a sì fi ìdájọ́ fún wọ́n, mo sì rí ọkàn àwọn tí a ti bẹ́ lórí nítorí ẹ̀rí Jesu, àti nítorí ọ̀rọ̀ Ọlọ́run, àti àwọn tí kò sì foríbalẹ̀ fún ẹranko náà, àti fún àwòrán rẹ̀, tàbí tí kò sì gbà àmì rẹ̀ ní iwájú wọn àti ní ọwọ́ wọn; wọ́n sì wà láààyè, wọ́n sì jẹ ọba pẹ̀lú Kristi ní ẹgbẹ̀rún (1,000) ọdún.
\v 5 (Àwọn òkú ìyókù kò wà láààyè mọ́ títí ẹgbẹ̀rún (1,000) ọdún náà yóò fi pé). Èyí ni àjíǹde èkínní.
\v 6 Ẹni ìbùkún àti mímọ́ ni ẹni tí ó ní ipa nínú àjíǹde èkínní náà. Lórí àwọn wọ̀nyí ikú ẹ̀ẹ̀kejì kò ní agbára, ṣùgbọ́n wọn ó jẹ́ àlùfáà Ọlọ́run àti ti Kristi, wọn ó sì máa jẹ ọba pẹ̀lú rẹ̀ ní ẹgbẹ̀rún (1,000) ọdún.
\s1 Ìparun Satani
\p 
\v 7 Nígbà tí ẹgbẹ̀rún (1,000) ọdún náà bá sì pé, a ó tú Satani sílẹ̀ kúrò nínú túbú rẹ̀.
\v 8 Yóò sì jáde lọ láti máa tan àwọn orílẹ̀-èdè tí ń bẹ ní igun mẹ́rẹ̀ẹ̀rin ayé jẹ, Gogu àti Magogu, láti gbá wọn jọ sí ogun: àwọn tí iyè wọn dàbí iyanrìn Òkun.
\v 9 Wọ́n sì gòkè lọ la ibú ayé já, wọ́n sì yí ibùdó àwọn ènìyàn mímọ́ ká àti ìlú àyànfẹ́ náà: iná sì ti ọ̀run sọ̀kalẹ̀ wá, ó sì jó wọn run.
\v 10 A sì wọ́ Èṣù tí ó tàn wọ́n jẹ lọ sínú adágún iná àti sulfuru, níbi tí ẹranko àti wòlíì èké nì gbé wà, a ó sì máa dá wọn lóró tọ̀sán tòru láé àti láéláé.
\s1 Àwọn òkú gba ìdájọ́
\p 
\v 11 Mo sì rí ìtẹ́ funfun ńlá kan, àti ẹni tí ó jókòó lórí rẹ̀, níwájú ẹni tí ayé àti ọ̀run fò lọ; a kò sì rí ààyè fún wọn mọ́.
\v 12 Mo sì rí àwọn òkú, àti èwe àti àgbà, wọn dúró níwájú ìtẹ́; a sì ṣí àwọn ìwé sílẹ̀; a sì ṣí àwọn ìwé mìíràn kan sílẹ̀ tí í ṣe ìwé ìyè: a sì ṣe ìdájọ́ fún àwọn òkú láti inú ohun tí a ti kọ sínú àwọn ìwé náà, gẹ́gẹ́ bí iṣẹ́ wọn.
\v 13 Òkun sì jọ̀wọ́ àwọn òkú tí ń bẹ nínú rẹ̀ lọ́wọ́; àti òkú àti ipò òkú sì jọ̀wọ́ òkú tí ó wà nínú wọn pẹ̀lú: a sì ṣe ìdájọ́ wọn, olúkúlùkù gẹ́gẹ́ bí iṣẹ́ wọn.
\v 14 Àti ikú àti ipò òkú ni a sì sọ sínú adágún iná. Èyí ni ikú kejì.
\v 15 Bí a bá sì rí ẹnikẹ́ni tí a kò kọ orúkọ rẹ̀ sínú ìwé ìyè, a ó sọ ọ́ sínú adágún iná.
\c 21
\s1 Jerusalẹmu tuntun
\p 
\v 1 Mo sì rí ọ̀run tuntun kan àti ayé tuntun kan, nítorí pé ọ̀run ti ìṣáájú àti ayé ìṣáájú ti kọjá lọ; Òkun kò sì ṣí mọ́.
\v 2 Mo sì rí ìlú mímọ́, Jerusalẹmu tuntun ń ti ọ̀run sọ̀kalẹ̀ wá láti ọ̀dọ̀ Ọlọ́run, tí a ti múra sílẹ̀ bí ìyàwó tí a ṣe lọ́ṣọ̀ọ́ fún ọkọ rẹ̀.
\v 3 Mo sì gbọ́ ohùn ńlá kan láti orí ìtẹ́ náà wá, ń wí pé, “Kíyèsi i, àgọ́ Ọlọ́run wà pẹ̀lú àwọn ènìyàn, òun ó sì máa bá wọn gbé, wọn ó sì máa jẹ́ ènìyàn rẹ̀, àti Ọlọ́run tìkára rẹ̀ yóò wà pẹ̀lú wọn, yóò sì máa jẹ́ Ọlọ́run wọn.
\v 4 Ọlọ́run yóò sì nu omijé gbogbo nù kúrò ni ojú wọn; kì yóò sì ṣí ikú mọ́, tàbí ọ̀fọ̀, tàbí ẹkún, bẹ́ẹ̀ ni kí yóò sí ìrora mọ́, nítorí pé ohun àtijọ́ tí kọjá lọ.”
\p 
\v 5 Ẹni tí ó jókòó lórí ìtẹ́ náà, sì wí pé, “Kíyèsi i, mo sọ ohun gbogbo di ọ̀tun!” Ó sì wí fún mi pé, “Kọ̀wé rẹ̀, nítorí ọ̀rọ̀ wọ̀nyí òdodo àti òtítọ́ ni wọ́n.”
\p 
\v 6 Ó sì wí fún mi pé, “Ó parí. Èmi ni Alfa àti Omega, ìpilẹ̀ṣẹ̀ àti òpin. Èmi ó sì fi omi fún ẹni tí òùngbẹ ń gbẹ láti inú orísun omi ìyè lọ́fẹ̀ẹ́.
\v 7 Ẹni tí ó ba ṣẹ́gun ni yóò jogún nǹkan wọ̀nyí; èmi ó sì máa jẹ́ Ọlọ́run rẹ̀, òun ó sì máa jẹ ọmọ mi.
\v 8 Ṣùgbọ́n àwọn ojo, àti aláìgbàgbọ́, àti ẹni ìríra, àti apànìyàn, àti àgbèrè, àti oṣó, àti abọ̀rìṣà, àti àwọn èké gbogbo, ni yóò ni ipa tiwọn nínú adágún tí ń fi iná àti sulfuru jó: èyí tí i ṣe ikú kejì.”
\p 
\v 9 Ọ̀kan nínú àwọn angẹli méje, tí wọ́n ni ago méje, tí ó kún fún ìyọnu méje ìkẹyìn sì wá, ó sì ba mi sọ̀rọ̀ wí pé, “Wá níhìn-ín, èmi ó fi ìyàwó, aya Ọ̀dọ́-àgùntàn hàn ọ́.”
\v 10 Ó sì mu mi lọ nínú Ẹ̀mí si òkè ńlá kan tí o sì ga, ó sì fi ìlú náà hàn mi, Jerusalẹmu mímọ́, tí ń ti ọ̀run sọ̀kalẹ̀ wá láti ọ̀dọ̀ Ọlọ́run,
\v 11 tí ó ní ògo Ọlọ́run, ìmọ́lẹ̀ rẹ̀ sì dàbí òkúta iyebíye gidigidi, àní bí òkúta jasperi, ó mọ́ bí kirisitali;
\v 12 Ó sì ní odi ńlá àti gíga, ó sì ni ẹnu ibodè méjìlá, àti ní àwọn ẹnu ibodè náà angẹli méjìlá àti orúkọ tí a kọ sára wọn tí i ṣe orúkọ àwọn ẹ̀yà méjìlá tí àwọn ọmọ Israẹli.
\v 13 Ní ìhà ìlà-oòrùn ẹnu ibodè mẹ́ta; ní ìhà àríwá ẹnu ibodè mẹ́ta; ní ìhà gúúsù ẹnu ibodè mẹ́ta; àti ní ìhà ìwọ̀-oòrùn ẹnu ibodè mẹ́ta.
\v 14 Odi ìlú náà sì ni ìpìlẹ̀ méjìlá, àti lórí wọn orúkọ àwọn Aposteli méjìlá tí Ọ̀dọ́-Àgùntàn.
\p 
\v 15 Ẹni tí o sì ń bá mi sọ̀rọ̀ ní ọ̀pá-ìwọ̀n wúrà kan láti fi wọn ìlú náà àti àwọn ẹnu ibodè rẹ̀, àti odi rẹ̀.
\v 16 Ìlú náà sì wà ní ibú mẹ́rin lọ́gbọọgba, gígùn rẹ̀ àti ìbú rẹ̀ sì dọ́gba: ó sì fi ọ̀pá-ìwọ̀n náà wọn ìlú náà wò, ó jẹ ẹgbàá mẹ́fà (12,000) ibùsọ̀ gígùn rẹ̀ àti ìbú rẹ̀, àti gíga rẹ̀ sì dọ́gba.
\v 17 Ó sì wọn odi rẹ̀ ó jẹ́ ogóje ìgbọ̀nwọ́ lé mẹ́rin (144), gẹ́gẹ́ bí òsùwọ̀n ènìyàn, bẹ́ẹ̀ ni tí angẹli náà.
\v 18 A sì fi jasperi mọ odi ìlú náà. Ìlú náà sì jẹ́ kìkì wúrà, ó dàbí dígí tí o mọ́ kedere.
\v 19 A fi onírúurú òkúta iyebíye ṣe ìpìlẹ̀ ògiri ìlú náà lọ́ṣọ̀ọ́. Ìpìlẹ̀ èkínní jẹ́ jasperi; èkejì, safiru; ẹ̀kẹta, kalkedoni; ẹ̀kẹrin, emeradi;
\v 20 ẹ̀karùnún, sardoniki; ẹ̀kẹfà, kaneliani; èkeje, krisoliti; ẹ̀kẹjọ, berili; ẹ̀kẹsànán, topasi; ẹ̀kẹwàá, krisoprasu; ẹ̀kọkànlá, jakiniti; èkejìlá, ametisiti.
\v 21 Ẹnu ibodè méjèèjìlá jẹ́ perli méjìlá: olúkúlùkù ẹnu ibodè jẹ́ peali kan; ọ̀nà ìgboro ìlú náà sì jẹ́ kìkì wúrà, ó dàbí dígí dídán.
\p 
\v 22 Èmi kò sì ri tẹmpili nínú rẹ̀, nítorí pé Olúwa Ọlọ́run Olódùmarè ni tẹmpili rẹ̀, àti Ọ̀dọ́-àgùntàn.
\v 23 Ìlú náà kò sì ní oòrùn, tàbí òṣùpá, láti máa tan ìmọ́lẹ̀ sí i, nítorí pé ògo Ọlọ́run ni ó ń tàn ìmọ́lẹ̀ sí i, Ọ̀dọ́-àgùntàn sì ni fìtílà rẹ̀.
\v 24 Àwọn orílẹ̀-èdè yóò sì máa rìn nípa ìmọ́lẹ̀ rẹ̀, àwọn ọba ayé sì ń mú ògo wọn wá sínú rẹ̀.
\v 25 A kì yóò sì ṣé àwọn ẹnu ibodè rẹ̀ rárá ní ọ̀sán: nítorí ki yóò si òru níbẹ̀.
\v 26 Wọ́n ó sì máa mú ògo àti ọlá àwọn orílẹ̀-èdè wá sínú rẹ̀.
\v 27 Ohun aláìmọ́ kan ki yóò sì wọ inú rẹ̀ rárá, tàbí ohun tí ń ṣiṣẹ́ ìríra àti èké; bí kò ṣe àwọn tí a kọ sínú ìwé ìyè Ọ̀dọ́-àgùntàn.
\c 22
\s1 Omi iyè
\p 
\v 1 Ó sì fi odò omi ìyè kan hàn mi, tí ó mọ́ bí kirisitali, tí ń tí ibi ìtẹ́ Ọlọ́run àti tí Ọ̀dọ́-Àgùntàn jáde wá,
\v 2 ní àárín ìgboro rẹ̀, àti níhà èkínní kejì odò náà, ni igi ìyè gbé wà, tí o máa ń so onírúurú èso méjìlá, a sì máa so èso rẹ̀ ni oṣooṣù ewé igi náà sí wà fún mímú àwọn orílẹ̀-èdè láradà.
\v 3 Ègún kì yóò sì ṣí mọ: ìtẹ́ Ọlọ́run àti tí Ọ̀dọ́-àgùntàn ni yóò sì máa wà níbẹ̀; àwọn ìránṣẹ́ rẹ̀ yóò sì máa sìn ín.
\v 4 Wọ́n ó si máa rí ojú rẹ̀; orúkọ rẹ̀ yóò si máa wà ni iwájú orí wọn.
\v 5 Òru kì yóò sí mọ́; wọn kò sì ní wa ìmọ́lẹ̀ fìtílà, tàbí ìmọ́lẹ̀ oòrùn; nítorí pé Olúwa Ọlọ́run ni yóò tan ìmọ́lẹ̀ fún wọn: wọn ó sì máa jẹ ọba láé àti láéláé.
\p 
\v 6 Ó sì wí fún mi pé, “Òdodo àti òtítọ́ ni ọ̀rọ̀ wọ̀nyí: Olúwa Ọlọ́run ẹ̀mí àwọn wòlíì ni ó sì ran angẹli rẹ̀ láti fi ohun tí ó ní láti ṣẹlẹ̀ láìpẹ́ yìí hàn àwọn ìránṣẹ́ rẹ̀.”
\b
\p 
\v 7 \wj “Kíyèsi i, èmi ń bọ̀ kánkán! Ìbùkún ni fún ẹni tí ń pa ọ̀rọ̀ ìsọtẹ́lẹ̀ inú ìwé yìí mọ́!”\wj*
\b
\p 
\v 8 Èmi, Johanu, ni ẹni tí ó gbọ́ tí ó sì ri nǹkan wọ̀nyí. Nígbà tí mo sì gbọ́ tí mo sì rí, mo wólẹ̀ láti foríbalẹ̀ níwájú ẹsẹ̀ angẹli náà, tí o fi nǹkan wọ̀nyí hàn mi.
\v 9 Nígbà náà ni ó wí fún mi pé, “Wó ò, má ṣe bẹ́ẹ̀, ìránṣẹ́ ẹlẹgbẹ́ rẹ ni èmi, àti ti àwọn arákùnrin rẹ̀ wòlíì, àti ti àwọn tí ń pa ọ̀rọ̀ inú ìwé yìí mọ́. Foríbalẹ̀ fún Ọlọ́run!”
\p 
\v 10 Ó sì wí fún mi pé, “Má ṣe fi èdìdì di ọ̀rọ̀ ìsọtẹ́lẹ̀ tí inú ìwé yìí, nítorí ìgbà kù sí dẹ̀dẹ̀.
\v 11 Ẹni tí ń ṣe aláìṣòótọ́, kí ó máa ṣe aláìṣòótọ́ nì só; àti ẹni tí ń ṣe ẹlẹ́gbin, kí ó máa ṣe ẹ̀gbin nì só; àti ẹni tí ń ṣe olódodo, kí ó máa ṣe òdodo nì só; àti ẹni tí ń ṣe mímọ́, kí ó máa ṣe mímọ́ nì só.”
\b
\s1 Ìkádìí: Ìpeni àti ìkìlọ̀
\p 
\v 12 \wj “Kíyèsi i, èmi ń bọ̀ kánkán; èrè mí sì ń bẹ pẹ̀lú mi, láti sán fún olúkúlùkù gẹ́gẹ́ bí iṣẹ́ rẹ̀ yóò tí rí.\wj*
\v 13 \wj Èmi ni Alfa àti Omega, ẹni ìṣáájú àti ẹni ìkẹyìn, ìpilẹ̀ṣẹ̀ àti òpin.\wj*
\b
\p 
\v 14 \wj “Ìbùkún ni fún àwọn ti ń fọ aṣọ wọn, kí wọ́n lè ni ẹ̀tọ́ láti wá sí ibi igi ìyè náà, àti kí wọ́n lè gbà àwọn ẹnu ibodè wọ inú ìlú náà.\wj*
\v 15 \wj Nítorí ni òde ni àwọn ajá gbé wà, àti àwọn oṣó, àti àwọn àgbèrè, àti àwọn apànìyàn, àti àwọn abọ̀rìṣà, àti olúkúlùkù ẹni tí ó fẹ́ràn èké tí ó sì ń hùwà èké.\wj*
\b
\p 
\v 16 \wj “Èmi, Jesu, ni ó rán angẹli mi láti jẹ́rìí nǹkan wọ̀nyí fún yin ní tí àwọn ìjọ. Èmi ni gbòǹgbò àti irú-ọmọ Dafidi, àti ìràwọ̀ òwúrọ̀ tí ń tàn.”\wj*
\b
\p 
\v 17 Ẹ̀mí àti ìyàwó wí pé, “Máa bọ!” Àti ẹni tí ó ń gbọ́ kí ó wí pé, “Máa bọ̀!” Àti ẹni tí òǹgbẹ ń gbẹ kí ó wá, àti ẹni tí o bá sì fẹ́, kí ó gba omi ìyè náà lọ́fẹ̀ẹ́.
\b
\p 
\v 18 Èmi kìlọ̀ fún olúkúlùkù ẹni tó ń gbọ́ ọ̀rọ̀ ìsọtẹ́lẹ̀ inú ìwé yìí pé, bí ẹnikẹ́ni ba fi kún wọn, Ọlọ́run yóò fi kún àwọn ìyọnu tí a kọ sínú ìwé yìí fún un.
\v 19 Bí ẹnikẹ́ni bá sì mú kúrò nínú ọ̀rọ̀ ìwé ìsọtẹ́lẹ̀ yìí, Ọlọ́run yóò sì mú ipa tirẹ̀ kúrò nínú ìwé ìyè, àti kúrò nínú ìlú mímọ́ náà, àti kúrò nínú àwọn ohun tí a kọ sínú ìwé yìí.
\b
\p 
\v 20 Ẹni tí ó jẹ́rìí nǹkan wọ̀nyí wí pé, \wj “Nítòótọ́ èmi ń bọ̀ kánkán.”\wj*
\p Àmín. Máa bọ̀, Jesu Olúwa!
\b
\p 
\v 21 Oore-ọ̀fẹ́ Jesu Olúwa kí ó wà pẹ̀lú gbogbo àwọn ènìyàn mímọ́. Àmín.
