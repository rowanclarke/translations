\v 19 \w I|strong="G2532"\w* \w continue|strong="G2532"\w* \w to|strong="G1519"\w* \w speak|strong="G3004"\w* \w on|strong="G1519"\w* \w a|strong="G2532"\w* \w human|strong="G4561"\w* level \w because|strong="G1223"\w* \w of|strong="G1223"\w* \w the|strong="G2532"\w* weakness \w of|strong="G1223"\w* \w your|strong="G1223"\w* \w flesh|strong="G4561"\w*. \w Now|strong="G3568"\w* \w just|strong="G5618"\w* \w as|strong="G5618"\w* \w you|strong="G5210"\w* used \w to|strong="G1519"\w* \w present|strong="G3936"\w* \w your|strong="G1223"\w* \w body|strong="G4561"\w* \w parts|strong="G3196"\w* \w as|strong="G5618"\w* \w slaves|strong="G1401"\w* \w to|strong="G1519"\w* uncleanness, \w and|strong="G2532"\w* \w to|strong="G1519"\w* \w ever|strong="G1519"\w* increasing lawlessness,\f + \fr 6:19 \ft Sin, and mere gratification of physical desire, obey the law of diminishing returns. To maintain the same ‘kick’ from any drug, you have to keep increasing the dose—this is a slavery that keeps on dragging you down to ever lower levels.\f* \w so|strong="G3779"\w* \w now|strong="G3568"\w* \w present|strong="G3936"\w* \w your|strong="G1223"\w* \w body|strong="G4561"\w* \w parts|strong="G3196"\w* \w as|strong="G5618"\w* \w slaves|strong="G1401"\w* \w to|strong="G1519"\w* \w righteousness|strong="G1343"\w* \w with|strong="G1223"\w* \w a|strong="G2532"\w* \w view|strong="G1519"\w* \w to|strong="G1519"\w* sanctification.  
\v 20 \w For|strong="G1063"\w* \w when|strong="G3753"\w* \w you|strong="G1510"\w* \w were|strong="G1510"\w* \w slaves|strong="G1401"\w* \w to|strong="G1401"\w* \w the|strong="G3588"\w* sin, \w you|strong="G1510"\w* \w were|strong="G1510"\w* ‘\w free|strong="G1658"\w*’ \w from|strong="G3588"\w* \w the|strong="G3588"\w* \w righteousness|strong="G1343"\w*.  
\v 21 \w So|strong="G3767"\w* \w what|strong="G5101"\w* ‘\w fruit|strong="G2590"\w*’ \w did|strong="G5101"\w* \w you|strong="G3739"\w* \w have|strong="G2192"\w* \w at|strong="G1909"\w* \w that|strong="G3739"\w* \w time|strong="G5119"\w* \w from|strong="G3588"\w* \w the|strong="G1909"\w* \w things|strong="G3588"\w* \w you|strong="G3739"\w* \w are|strong="G3588"\w* \w now|strong="G3568"\w* \w ashamed|strong="G1870"\w* \w of|strong="G1909"\w*? \w The|strong="G1909"\w* \w end|strong="G5056"\w* \w of|strong="G1909"\w* \w those|strong="G3588"\w* \w things|strong="G3588"\w* \w is|strong="G3588"\w* \w death|strong="G2288"\w*!\f + \fr 6:21 \ft Yea, verily!\f*  
\v 22 \w But|strong="G1161"\w* \nd \+w now|strong="G1161"\+w*\nd*, \w having|strong="G2192"\w* \w been|strong="G2192"\w* emancipated \w from|strong="G3588"\w* \w the|strong="G1519"\w* sin, \w and|strong="G1161"\w* \w having|strong="G2192"\w* \w become|strong="G1161"\w* \w enslaved|strong="G1402"\w* \w to|strong="G1519"\w* \w God|strong="G2316"\w*, \w you|strong="G5210"\w* \w have|strong="G2192"\w* \w your|strong="G2192"\w* ‘\w fruit|strong="G2590"\w*’ \w into|strong="G1519"\w* sanctification—\w and|strong="G1161"\w* \w the|strong="G1519"\w* \w end|strong="G5056"\w* \w is|strong="G3588"\w* eternal \w life|strong="G2222"\w*!  
\v 23 \w Because|strong="G1063"\w* \w the|strong="G1722"\w* \w wages|strong="G3800"\w* \w of|strong="G2316"\w* sin \w is|strong="G3588"\w* \w death|strong="G2288"\w*,\f + \fr 6:23 \ft Sin results in two deaths, physical and spiritual. The spiritual one is by far the more important since it lasts for eternity. Belonging to Jesus does not exempt us from physical death, but it does from the spiritual one—He gives us eternal life instead of eternal death. Eternal death means eternal separation from the Creator, presumably a conscious state.\f* \w but|strong="G1161"\w* \w the|strong="G1722"\w* gracious \w gift|strong="G5486"\w* \w of|strong="G2316"\w* \w God|strong="G2316"\w* \w is|strong="G3588"\w* eternal \w life|strong="G2222"\w* \w in|strong="G1722"\w* \w Christ|strong="G5547"\w* \w Jesus|strong="G2424"\w* \w our|strong="G2316"\w* \w Lord|strong="G2962"\w*.   
\c 7  
\s1 More about law  
\m
\v 1 \w Do|strong="G2228"\w* \w you|strong="G3754"\w* \w not|strong="G2198"\w* \w know|strong="G1097"\w*, brothers (\w for|strong="G1063"\w* \w I|strong="G1063"\w* \w am|strong="G3551"\w* \w speaking|strong="G2980"\w* \w to|strong="G1909"\w* \w those|strong="G3588"\w* \w who|strong="G3588"\w* \w know|strong="G1097"\w* \w law|strong="G3551"\w*), \w that|strong="G3754"\w* \w the|strong="G1909"\w* \w law|strong="G3551"\w* \w has|strong="G3748"\w* authority \w over|strong="G1909"\w* someone only \w as|strong="G3745"\w* \w long|strong="G5550"\w* \w as|strong="G3745"\w* \w he|strong="G3754"\w* \w lives|strong="G2198"\w*?  
