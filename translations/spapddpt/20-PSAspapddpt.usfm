\q1 \w Ya|strong="H3068"\w* \w no|strong="H3808"\w* \w hay|strong="H5750"\w* \w profeta|strong="H5030"\w*,
\q1 \w Ni|strong="H3808"\w* \w hay|strong="H5750"\w* \w entre|strong="H3808"\w* nosotros \w quien|strong="H4100"\w* \w sepa|strong="H3045"\w* \w hasta|strong="H5704"\w* \w cuándo|strong="H4100"\w*.
