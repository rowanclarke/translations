\c 16
\m 
\v 1 \w Y|strong="H3068"\w* DIJO \w el|strong="H5921"\w* \w SEÑOR|strong="H3068"\w* \w a|strong="H3068"\w* \w Samuel|strong="H8050"\w*: ¿\w Hasta|strong="H5704"\w* \w cuándo|strong="H3588"\w* \w has|strong="H4427"\w* tú \w de|strong="H5921"\w* llorar \w a|strong="H3068"\w* \w Saúl|strong="H7586"\w*, habiéndolo \w yo|strong="H3588"\w* \w desechado|strong="H3988"\w* \w para|strong="H5704"\w* \w que|strong="H3588"\w* \w no|strong="H3588"\w* \w reine|strong="H4427"\w* \w sobre|strong="H5921"\w* \w Israel|strong="H3478"\w*? \w Hinche|strong="H4390"\w* tu \w cuerno|strong="H7161"\w* \w de|strong="H5921"\w* \w aceite|strong="H8081"\w*, \w y|strong="H3588"\w* \w ven|strong="H3212"\w*, \w te|strong="H5921"\w* \w enviaré|strong="H7971"\w* \w a|strong="H3068"\w* \w Isaí|strong="H3448"\w* \w de|strong="H5921"\w* Belem: \w porque|strong="H3588"\w* \w de|strong="H5921"\w* sus \w hijos|strong="H1121"\w* \w me|strong="H5921"\w* he provisto \w de|strong="H5921"\w* \w rey|strong="H4428"\w*.
\m 
\v 2 \w Y|strong="H3068"\w* dijo \w Samuel|strong="H8050"\w*: ¿Cómo \w iré|strong="H3212"\w*? Si \w Saúl|strong="H7586"\w* lo entendiere, me \w matará|strong="H2026"\w*. El \w SEÑOR|strong="H3068"\w* respondió: \w Toma|strong="H3947"\w* conti­go una \w becerra|strong="H5697"\w* de la vacada, \w y|strong="H1241"\w* di: \w A|strong="H3068"\w* sacrificar al \w SEÑOR|strong="H3068"\w* he veni­do.
\m 
\v 3 \w Y|strong="H3068"\w* \w llama|strong="H7121"\w* \w a|strong="H3068"\w* \w Isaí|strong="H3448"\w* al \w sacrificio|strong="H2077"\w*, y \w yo|strong="H6213"\w* te enseñaré \w lo|strong="H6213"\w* \w que|strong="H3045"\w* has de \w hacer|strong="H6213"\w*; y ungirme has al \w que|strong="H3045"\w* \w yo|strong="H6213"\w* te dijere.
