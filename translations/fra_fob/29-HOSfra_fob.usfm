\v 11 \w Et|strong="H3068"\w* \w du|strong="H1004"\w* \w pays|strong="H3427"\w* d'\w Assyrie|strong="H3427"\w*, \w comme|strong="H3068"\w* \w une|strong="H3068"\w* \w colombe|strong="H3123"\w*, \w et|strong="H3068"\w* \w je|strong="H3068"\w* \w les|strong="H3068"\w* \w ferai|strong="H3068"\w* \w habiter|strong="H3427"\w* \w dans|strong="H5921"\w* \w leurs|strong="H1004"\w* \w maisons|strong="H1004"\w*, \w dit|strong="H5002"\w* l'\w Éternel|strong="H3068"\w*.  
\v 12 Éphraïm m'\w a|strong="H3068"\w* environné de mensonge, et la maison d'Israël de tromperie; et Juda est encore inconstant avec Dieu, avec le Saint, le Fidèle.   
\c 12
\p
\v 1 \w Éphraïm|strong="H1004"\w* \w se|strong="H3478"\w* repaît \w de|strong="H1004"\w* vent, \w et|strong="H3478"\w* poursuit \w le|strong="H3478"\w* vent d'orient. \w Chaque|strong="H1004"\w* jour \w il|strong="H3478"\w* multiplie \w le|strong="H3478"\w* \w mensonge|strong="H3585"\w* \w et|strong="H3478"\w* \w la|strong="H3478"\w* violence; \w il|strong="H3478"\w* traite alliance \w avec|strong="H5973"\w* Assur, \w et|strong="H3478"\w* \w on|strong="H1004"\w* porte l'huile \w en|strong="H3478"\w* Égypte.  
\v 2 \w L|strong="H3068"\w*'Éternel \w est|strong="H3117"\w* \w aussi|strong="H3117"\w* \w en|strong="H3117"\w* procès \w avec|strong="H5973"\w* Juda, \w et|strong="H3117"\w* \w il|strong="H3117"\w* punira Jacob \w à|strong="H3117"\w* \w cause|strong="H3117"\w* \w de|strong="H3117"\w* \w ses|strong="H3117"\w* \w voies|strong="H3117"\w*; \w il|strong="H3117"\w* \w lui|strong="H7307"\w* rendra \w selon|strong="H3117"\w* \w ses|strong="H3117"\w* œuvres.  
\v 3 \w Dès|strong="H3068"\w* \w le|strong="H3068"\w* \w sein|strong="H7725"\w* maternel \w il|strong="H3068"\w* supplanta \w son|strong="H3068"\w* \w frère|strong="H7725"\w*, \w et|strong="H3068"\w* \w dans|strong="H5921"\w* \w sa|strong="H3068"\w* \w force|strong="H5973"\w* \w il|strong="H3068"\w* lutta \w avec|strong="H5973"\w* \w Dieu|strong="H3068"\w*.  
\v 4 Il \w lutta|strong="H8280"\w* \w avec|strong="H8280"\w* l'ange, et il fut le plus fort; il pleura, et lui demanda grâce. \w A|strong="H3068"\w* Béthel il le trouva, et c'est là que Dieu nous \w a|strong="H3068"\w* parlé.  
\v 5 \w L|strong="H3068"\w*'Éternel \w est|strong="H1696"\w* \w le|strong="H4672"\w* \w Dieu|strong="H1696"\w* \w des|strong="H1696"\w* armées; \w son|strong="H1696"\w* nom \w est|strong="H1696"\w* l'Éternel.  
\v 6 \w Toi|strong="H3068"\w* \w donc|strong="H3068"\w*, reviens \w à|strong="H3068"\w* \w ton|strong="H3068"\w* \w Dieu|strong="H3068"\w*; garde \w la|strong="H3068"\w* \w miséricorde|strong="H3068"\w* \w et|strong="H3068"\w* \w la|strong="H3068"\w* justice; \w et|strong="H3068"\w* espère continuellement \w en|strong="H3068"\w* \w ton|strong="H3068"\w* \w Dieu|strong="H3068"\w*.  
\v 7 Éphraïm \w est|strong="H4941"\w* \w un|strong="H7725"\w* marchand, \w qui|strong="H8104"\w* \w a|strong="H3068"\w* \w dans|strong="H7725"\w* \w sa|strong="H7725"\w* main \w des|strong="H7725"\w* balances fausses; \w il|strong="H7725"\w* \w aime|strong="H8104"\w* \w à|strong="H7725"\w* frauder.  
\v 8 \w Et|strong="H3027"\w* Éphraïm \w dit|strong="H3027"\w*: “Oui, \w je|strong="H3027"\w* \w suis|strong="H3027"\w* devenu riche; \w je|strong="H3027"\w* \w me|strong="H3027"\w* \w suis|strong="H3027"\w* acquis \w des|strong="H3027"\w* richesses. \w Dans|strong="H3027"\w* tout \w mon|strong="H3027"\w* \w travail|strong="H3027"\w* \w on|strong="H3027"\w* \w ne|strong="H3027"\w* trouvera aucune injustice, \w rien|strong="H3027"\w* \w qui|strong="H3027"\w* soit \w un|strong="H3027"\w* péché. “  
