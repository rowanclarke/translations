\v 20  \w The|strong="G2532"\w* \w mystery|strong="G3466"\w* \w of|strong="G2532"\w* \w the|strong="G2532"\w* \w seven|strong="G2033"\w* stars \w that|strong="G3739"\w* \w you|strong="G3739"\w* \w saw|strong="G3708"\w* \w in|strong="G1909"\w* \w my|strong="G3708"\w* \w right|strong="G1188"\w* \w hand|strong="G1188"\w* \w and|strong="G2532"\w* \w the|strong="G2532"\w* \w seven|strong="G2033"\w* \w golden|strong="G5552"\w* \w lampstands|strong="G3087"\w* \w is|strong="G1510"\w* \w this|strong="G3588"\w*: \w The|strong="G2532"\w* \w seven|strong="G2033"\w* stars \w are|strong="G1510"\w* \w the|strong="G2532"\w* angels \w of|strong="G2532"\w* \w the|strong="G2532"\w* \w seven|strong="G2033"\w* \w churches|strong="G1577"\w* \w and|strong="G2532"\w* \w the|strong="G2532"\w* \w seven|strong="G2033"\w* \w lampstands|strong="G3087"\w* \w are|strong="G1510"\w* \w the|strong="G2532"\w* \w seven|strong="G2033"\w* \w churches|strong="G1577"\w*.   
