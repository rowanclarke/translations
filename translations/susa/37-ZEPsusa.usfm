\id ZEP
\h عَننَبِ سٌقٌنِ
\toc1 عَلَ شَ مَسٍنيِ عَننَبِ سٌقٌنِ بّ
\toc2 عَننَبِ سٌقٌنِ
\toc3 سٌق
\mt1 عَننَبِ سٌقٌنِ شَ كِتَابُي
\imt1 مَسٍنيِ ندٍ يِ كِتَابُي شَ قٍ رَ
\ip عَننَبِ سٌقٌنِ نَشَ كَوَندِ تِ مَنفّ يٌسِيَ شَ وَشَتِ يُدَيَ بْشِ مَ. عِسِرَيِلَكَيٍ نُ بَرَ سٌ قٍ حَاشِ كُي نَ وَشَتِ، هَن عَلَتَلَ نُ وَ مَ عٍ حَشَنكَتَقٍ. بٍينُ عَ شَ نَ رَبَ، عَ نَشَ عَننَبِ سٌقٌنِ شّي عَلَكٌ عَ شَ نَ تَفِ رَبَ عٍ بّ، عَ شَ كَتَ عِسِرَيِلَكَيٍ رَفبِلٍندٍ عٍ وَشْنقٍ حَاشِ قْشْ رَ.
\ip نَ مَسٍنيِ مَنِيَشِ عِسِرَيِلَ نَمِحْنمّ فبٍفبٍ شَ مَسٍنيِ نَن نَ. نَ كُي عٍ مِشِيٍ شَ يُنُبِيٍ مَسٍنمَ عٍ بّ عَ قِيشّ رَ، عَلَكٌ عٍ شَ عَ كٌلٌن عٍ نَ قٍ نَن كُي نَ كِ نَشَن مُ رَقَنشِ عَلَ مَ. عِسِرَيِلَكَيٍ نُ بِرَ مَ كُيٍيٍ نَن قْشْ رَ، عٍ نَشٍيٍ لِشِ كَنَان بْشِ مَ عٍ مِنِ مِسِرَ بْشِ رَ تّمُي نَشّ. نَ قٍ نَشَ عَلَ رَشْنْ، بَرِ مَ عَ مُ وَ مَ عَ قِرِن ندٍ شْن مَ. عِسِرَيِلَكَيٍ مَن نُ قٍ حَاشِ رَبَ رَ عٍ بٌورٍيٍ رَ. مِشِ نَشَن نُ بَرَ سّنبّ سْتْ مَنفّيَ كُي، شَ نَ مُ عَ رَ نَاقُلِ قٍ كُي، عَ نُ سٍتَرٍيٍ تْورْ مَ. نَ قٍ مْولِ مُ رَقَن عَلَ مَ، بَرِ مَ عَ عَ حّنفِ سَشِ عَدَ مَدِ شَ قٍ شْن مَ، عَ مُ تِنمَ عَ شَ تْورْ.
\ip عَننَبِ سٌقٌنِ تٌ فّ نَ يُنُبِ مَسٍندٍ عِسِرَيِلَكَيٍ بّ، عَ نَشَ عَ قَلَ عَ عَلَتَلَ قَمَ نّ عٍ حَشَنكَتَدٍ نَ شَ قٍ رَ. نَ كِيتِ مَفَاشُ. عَلَ شَ شْنّ سّنبّ فبٌ. عَلَ شَ حَشَنكَتّ مُ نْمَ مِشِ ندٍ رَقِسَدٍ عَ بٌورٍ بّ. نَ كُي عِسِرَيِلَكَيٍ نُن سِ فبّتّ بِرِن نَ نَ كِيتِ بُن مَ. عَدَ مَ بِرِن نَشَن عَلَتَلَ مَتَندِ مَ، عٍ قَمَ نّ عَ شَ شْنّ كٌلٌندٍ كِيتِ وَشَتِ.
\ip كْنْ مَسٍنيِ فبّتّ قَن نُ سَشِ نَ وْيّنيِ شْرْشْي قَرِ. عَننَبِ سٌقٌنِ نَشَ عَ قَلَ عَ عَلَتَلَ وَ مَ مِشِ رَكِسِقٍ. عَ وَ مَ عٍ مَلِقٍ عَلَكٌ عٍ شَ فبِلٍن قٍ حَاشِ قْشْ رَ، عٍ شَ لُ عَلَ شَ كِرَ شْن مَ نَشَن نْمَ قِندِدٍ بْحّسَ رَ عٍ بّ. عَلَ شْنْمَ نّ مِشِ حَاشِيٍ مَ بَرِ مَ عٍ شَ يُنُبِيٍ مُ رَقَنشِ عَ مَ، كْنْ عَ مَن عٍ شَنُمَ نّ عَ بْحّ بِرِن نَ. نَ نَن عَ تٌشِ عَننَبِ سٌقٌنِ بَرَ كِسِ مَسٍنيِ سَ حَشَنكَتّ مَسٍنيِ قَرِ. وٌن شَ عَ كٌلٌن عَلَ يُنُبِيٍ شْنشِ، كْنْ عَ يُنُبِتْييٍ شَنُمَ نّ، عَ وَ مَ عٍ رَفبِلٍنقٍ عٍ شَ قٍ حَاشِيٍ قْشْ رَ. عَلَ شَ نَ لْننِ رَ سٌ وٌن سٌندٌنيِ كُي. عَمِنَ.
\mt1 عَننَبِ سٌقٌنِ شَ كِتَابُي
\c 1
\s1 عَلَتَلَ شَ شْنّ يُدَيَ بّ
\p 
\v 1 عَلَتَلَ شَ مَسٍنيِ نَن يَ، عَ نَشَن تِشِ عَننَبِ سٌقٌنِ بّ. سٌقٌنِ قِندِ كُو سِ شَ دِ نَن نَ، فّدَلَيَ شَ مَمَدِ، عَمَرَيَ تٌلٌبِتّ، شٍسٍكِيَ بْنسْي. عَ مَسٍنيِ تِ نّ يُدَيَ مَنفّ يٌسِيَ شَ وَشَتِ، نَشَن قِندِشِ عَمٌن شَ دِ رَ.
\q1 
\v 2 «عَلَتَلَ شَ مَسٍنيِ نَن يَ؛
\q1 ﭑ بِرِن حْنمَ نّ دُنِحَ بّندّ قُحِ قَرِ.
\q1 
\v 3 ﭑ عَدَ مَ نُن سُبٍ حْنمَ نّ،
\q1 ﭑ شْنِ بَ كٌورٍ مَ،
\q1 ﭑ يّشّ بَ بَا مَ.
\q1 ﭑ مَرَتَنتَنيِ نُن مِشِ حَاشِ حْنمَ نّ،
\q1 ﭑ عَدَ مَدِيٍ بَ دُنِحَ بّندّ قُحِ قَرِ.
\q1 عَلَتَلَ شَ مَسٍنيِ نَن نَ كِ.»
\b
\q1 
\v 4 «ﭑ نَن ﭑ بّلّشّ عِتَلَمَ نّ يُدَيَ نُن دَرِ سَلَمُكَيٍ شِلِ مَ.
\q1 ﭑ بَلِ كُيٍ بَمَ نّ، نَشٍيٍ لُشِ بْشِ مَ.
\q1 ﭑ عٍ شَ بَتُي يَرٍرَتِيٍ نُن سّرّشّدُبّيٍ سْنتْمَ نّ.
\q1 
\v 5 ﭑ مِشِيٍ هَلَكِمَ نّ،
\q1 نَشٍيٍ تُنبُييٍ بَتُمَ عٍ شَ بَنشِ قَرِ.
\q1 ﭑ قِلَنكَقُييٍ حَشَنكَتَمَ نّ،
\q1 نَشٍيٍ عٍ كَلِ عَلَتَلَ شِلِ رَ،
\q1 عٍ مَن عٍ كَلِ مْلْكْ كُيٍ شِلِ رَ.
\q1 
\v 6 ﭑ مِشِيٍ رَبّحِنمَ نّ نَشٍيٍ بَرَ فبِلٍن عَلَتَلَ قْشْ رَ،
\q1 نَشٍيٍ مُ عَلَتَلَ قٍنمَ،
\q1 نَشٍيٍ مُ بِرَ مَ عَ شَ مَرَ سِ قْشْ رَ.»
\b
\q1 
\v 7 «وٌ سَبَرِ مَرِفِ عَلَتَلَ بّ،
\q1 بَرِ مَ عَ شَ لْشْي شُنفبٍ نَ قَقٍ.
\q1 عَلَتَلَ تَن سّرّشّ نَن بَمَ.
\q1 عَ مِشِ ندٍيٍ سُفَندِشِ نَ نَن مَ.
\q1 
\v 8 عَلَتَلَ شَ سّرّشّ لْشْي،
\q1 ﭑ مَنفّ شَ دِيٍ نُن كُنتِفِيٍ هَلَكِمَ نّ،
\q1 عَ نُن مِشِ نَشٍيٍ سِ فبّتّ شَ دُفِيٍ رَفٌرٌ مَ عٍ مَ.
\q1 
\v 9 ﭑ مِشِيٍ هَلَكِمَ نّ نَشٍيٍ تُفَنمَ سٌدٍ دّ رَ،
\q1 نَشٍيٍ عٍ مَرِفِ شَ بَنشِ رَقٍمَ فٍرٍ نُن يَنقَنتٍيَ رَ.»
\b
\q1 
\v 10 «عَلَتَلَ شَ مَسٍنيِ نَن يَ؛
\q1 نَ لْشْي مِشِ فبٍلٍفبٍلٍمَ نّ،
\q1 كٍلِقٍ تَا نَادّ مَ نَشَن شِلِ يّشّ نَادّ،
\q1 هَن تَا نّينّ،
\q1 كٍلِقٍ تَا قَرِ فٍيَيٍ مَ،
\q1 
\v 11 هَن مَكِتِ يِرٍ،
\q1 بَرِ مَ يُلّيٍ شَ قٍ بَرَ كَنَ،
\q1 ﭑ بَرَ عٍ بِرِن قَشَ.
\q1 
\v 12 نَ وَشَتِ ﭑ دَرِ سَلَمُ يِرٍ بِرِن مَتٌمَ نّ عَ قَنيِ رَ،
\q1 عَلَكٌ ﭑ شَ مِشِ سْنتْ،
\q1 نَشٍيٍ دْشْشِ عٍ شَ نَاقُلِ مَكَنتَقٍ رَ،
\q1 عٍ عَ قَلَقٍ عٍ بْحّ كُي،
\q1 ‹قٍ قَنيِ يٌ، قٍ حَاشِ يٌ،
\q1 عَلَ مُ قَمَ قٍقٍ رَبَدٍ ﭑ نَ.›
\q1 
\v 13 عٍ شَ نَاقُلِ لْيمَ نّ،
\q1 عٍ شَ بَنشِيٍ كَنَ.
\q1 عٍ بَرَ بَنشِ تِ، كْنْ عٍ مُ سَبَتِمَ نَ كُي.
\q1 عٍ بَرَ وّنِ بٌفِ سِ، كْنْ عٍ مُ نَ وّنِ مِنمَ سْنْن.»
\b
\q1 
\v 14 عَلَتَلَ شَ لْشْي شُنفبٍ بَرَ مَكْرّ،
\q1 عَ فبٍ مُ لُشِ عَ شَ قَ.
\q1 سّنبّمَيٍ قَمَ نّ فبٍلٍفبٍلٍدٍ
\q1 عَلَتَلَ شَ لْشْي مَفَاشُشِ مَ.
\q1 
\v 15 شْنّ لْشْي نَ عَ رَ، تْورّ لْشْي نَ عَ رَ،
\q1 فبَلٌي لْشْي نَ عَ رَ، دِ مِ لْشْي نَ عَ رَ،
\q1 نُشُي عِقْورْشِ لْشْي نَ عَ رَ.
\q1 
\v 16 فٍرٍ شُي مِنِمَ نّ نَ لْشْي تَا سّنبّمَيٍ شِلِ مَ،
\q1 عٍ شَ يِرٍ مَكَنتَشِيٍ شِلِ مَ.
\b
\q1 
\v 17 عَلَتَلَ نَشّ، «ﭑ عَدَ مَدِيٍ تْورْ مَ نّ نَ لْشْي،
\q1 عٍ قَ حّرّ عَلْ دْنشُييٍ،
\q1 بَرِ مَ عٍ بَرَ يُنُبِ رَبَ عَلَتَلَ رَ.
\q1 نَ كُي عٍ سْنتْمَ نّ عَ حَاشِ رَ،
\q1 عٍ وُلِ رَ مِنِ بْشِ مَ عَ فبٍفبٍ رَ،
\q1 عٍ بِنبِيٍ وْلّ حٌوفٍ شْورَ.
\q1 
\v 18 عٍ شَ شّيمَ نُن فبٍتِ مُ نْمَ عٍ رَتَنفَدٍ
\q1 عَلَتَلَ شَ شْنّ لْشْي مَ.
\q1 دُنِحَ بِرِن فَنمَ نّ نَ لْشْي عَ حَاشِ رَ
\q1 عَلَتَلَ شَ شْنّ شَ قٍ رَ،
\q1 بَرِ مَ عَ شَ حَمَ بَرَ بِرَ عَلَ فبّتّيٍ قْشْ رَ.
\q1 نَ كُي دُنِحَ مِشِ بِرِن سْنتْمَ نّ.»
\c 2
\s1 عَلَتَلَ شَ شْنّ يُدَيَ نُن سِ فبّتّيٍ مَ
\q1 
\v 1 «سِ يَافِتَرٍ، وٌ شَ وٌ يّتّ مَتٌ،
\q1 
\v 2 بٍينُ وَشَتِ شَ كَمَلِ،
\q1 بٍينُ عَلَتَلَ شَ شْنّ شَ وٌ لِ،
\q1 بٍينُ عَلَتَلَ شَ لْشْي شْرْشْي شَ قَ وٌ مَ.
\q1 نَ لْشْي دَنفِمَ نّ عَلْ مَالٍ لَفِ قٌيٍ نَشَن تُتُنمَ.
\q1 
\v 3 وٌ تَن مِشِ مَفٌرٌشِ نَشٍيٍ نَ عِسِرَيِلَ،
\q1 وٌ شَ عَلَتَلَ قٍن، وٌ شَ عَ شَ سّرِيّ رَبَتُ،
\q1 وٌ شَ تِنشِنيِ، نُن يّتّ مَفٌرٍ قٍن.
\q1 تّمُندٍ نَ كُي وٌ نْمَ نّ رَتَنفَدٍ عَلَتَلَ شَ شْنّ لْشْي مَ.»
\b
\q1 
\v 4 «فَسَ رَبّحِنمَ نّ، عَسِكَلْن كَنَ،
\q1 عَسِدٌدِ كٍرِ حَمَ يَ شْرِ، عٍكِرٌن تَلَ.
\q1 
\v 5 حَشَنكَتّ نَ وٌ بّ،
\q1 وٌ تَن نَشٍيٍ سَبَتِشِ بَا دّ رَ،
\q1 وٌ تَن نَشٍيٍ كٍلِشِ كِرّتِ.
\q1 عَلَتَلَ بَرَ نَتّ تٌنفٌ وٌ شَ قٍ رَ،
\q1 كَنَانكَ نَشٍيٍ نَ قِلِسِتَ بْشِ مَ،
\q1 ﭑ وٌ شُن نَكَنَمَ نّ هَن مِشِ بِرِن حْن وٌ يِ.
\q1 
\v 6 شُرُ سٍيٍ قَمَ نّ لُدٍ وٌ شَ بْشِ مَ،
\q1 وٌ شْنيِ قِندِ فْورّ رَ شُرُ سٍ دّ مَدٌنيِيٍ بّ.
\q1 
\v 7 نَ بْشِ قِندِ مَ يُدَيَكَ مِشِ دْنشْييٍ نَن فبٍ رَ،
\q1 عٍ قَ عٍ شَ شُرُ سٍيٍ دّ مَدٌندٍ نَا.
\q1 نُنمَرٍ تّمُي عٍ عٍ مَلَبُمَ نّ عَسِكَلْن شَ بَنشِيٍ كُي،
\q1 بَرِ مَ عٍ مَرِفِ عَلَتَلَ قَمَ نّ عٍ مَلِدٍ،
\q1 عَ عٍ شَ مِشِ سُشُشِيٍ رَفبِلٍن عٍ شْنيِ.»
\b
\q1 
\v 8 «ﭑ بَرَ مٌوَبَكَيٍ شَ كٌنبِيٍ مّ،
\q1 عَمٌنِكَيٍ شَ وْيّن بّشُشِيٍ بَرَ ﭑ لِ.
\q1 عٍ بَرَ ﭑ مَ حَمَ رَيَافِ،
\q1 عٍ بَرَ دَنفِ نَانِنيِ رَ.»
\b
\q1 
\v 9 «ﭑ تَن عِسِرَيِلَ مَرِفِ عَلَتَلَ، شِلِ شُنفبٍ كَنيِ،
\q1 ﭑ بَرَ ﭑ كَلِ مٌوَبَ لُمَ نّ عَلْ سٌدٌ مَ،
\q1 عَمٌنِكَيٍ لُ عَلْ فٌمٌرَكَيٍ،
\q1 عٍ شَ بْشِ كَنَ، حٌوفٍ حَاشِ نُن قْشّ لُ نَا.
\q1 
\v 10 عٍ نَ سْتْمَ عٍ شَ يّتّ عِفبٌحَ نَن مَ.
\q1 عٍ بَرَ عَلَتَلَ شِلِ شُنفبٍ كَنيِ شَ حَمَ رَيَافِ،
\q1 عٍ بَرَ تٍ عَ شَ حَمَ شِلِ مَ.
\q1 
\v 11 عَلَتَلَ مَفَاشُ، عَ عٍ حَشَنكَتَمَ نّ عَ حَاشِ رَ.
\q1 عَ كُيٍ بِرِن كَنَمَ نّ دُنِحَ مَ،
\q1 سِ بِرِن قَ عَلَتَلَ بَتُ عٍ شْنيِ.»
\b
\q1 
\v 12 «وٌ تَن كُسِكَيٍ،
\q1 وٌ قَن سْشْمَ نّ ﭑ مَ سَنتِدّفّمَ رَ.»
\b
\q1 
\v 13 «عَلَ عَ سّنبّ رَ مِنِمَ نّ كْولَ مَ، عَ قَ عَسِرِيَ سْنتْ.
\q1 عَ نِنٍوٍ شُن نَكَنَمَ نّ، عَ نَ قِندِ فبٍنفبٍرٍن يِرٍ رَ.
\q1 
\v 14 شُرُ سٍيٍ لُمَ نّ عٍ دّ مَدٌن نَ نَ تَا كُي،
\q1 عَ نُن وُلَءِ سُبٍ مْولِ بِرِن.
\q1 يُبّ نُن شُندِ كْي رَدَنفِمَ نّ نَ بَنشِ كَنَشِيٍ قَرِ.
\q1 نَادّ نُن وُندّرِ بِرِن كَنَشِ، عٍ شَ وُرِ بَرَ بْرْ.
\q1 
\v 15 يِ تَا شُنفبٍ نَشَن نُ لُمَ حّلّشِن نَ،
\q1 نَشَن بْحّ نُ سَشِ،
\q1 نَشَن نُ بَرَ عَ قَلَ عَ يّتّ بّ،
\q1 ‹ﭑ كٍرٍن نَن تِدٍ فبٌ،›
\q1 عَ شُن بَرَ رَكَنَ هَن عَ بَرَ قِندِ وُلَءِ سُبٍيٍ شْنيِ رَ.
\q1 دَنفِ مِشِ بِرِن يٌمَ نّ عَ مَ سْنْن،
\q1 عَ قِندِ دّءِ سِفِ رَ عٍ بّ.»
\c 3
\s1 عَلَتَلَ شَ شَنُنتٍيَ
\q1 
\v 1 «حَشَنكَتّ نَ عِ بّ، تَا مَتَندِلَ سّنِيّنتَرٍ،
\q1 نَشَن لُمَ مِشِ تْورْ رَ.
\q1 
\v 2 عَ مُ ﭑ شُي سُشُمَ، عَ مُ ﭑ مَ مَرَ سِ رَبَتُمَ،
\q1 عَ مُ عَ شَشِلِ تِمَ عَلَتَلَ رَ، عَ مُ مَكْرّشِ عَ مَرِفِ عَلَ رَ.
\q1 
\v 3 عَ شَ كُنتِفِيٍ لُمَ نّ عَلْ يّتّ
\q1 نَشٍيٍ عٍ شُي رَ مِنِمَ حَمَ تَفِ،
\q1 عَ شَ كِيتِسَمَيٍ لُشِ عَلْ وُلَءِ بَرٍ
\q1 نَشٍيٍ سُبٍ دٌنمَ كٍرٍن نَ.
\q1 
\v 4 عَ شَ نَمِحْنمّيٍ قِندِشِ يّتّ عِفبٌييٍ نُن يَنقَنتٍيٍ نَن نَ،
\q1 عَ شَ سّرّشّدُبّيٍ بَرَ قٍ سّنِيّنشِيٍ نْشْ،
\q1 عَ بَرَ عَلَ شَ سّرِيّ مَتَندِ.
\q1 
\v 5 كْنْ عَلَ نَن تِنشِن نَ مِشِيٍ يَ مَ.
\q1 عَ مُ مِشِ مَدَشُمَ،
\q1 لْشْ يٌ لْشْ عَ شَ نْندِ يَنبَمَ.
\q1 عَ تَن مُ لَنلَنتٍيَ كَنَمَ،
\q1 كْنْ تِنشِنتَرٍ مُ يَافِ كٌلٌن.»
\b
\q1 
\v 6 «ﭑ بَرَ سِيٍ حَشَنكَتَ،
\q1 ﭑ بَرَ عٍ شَ يِرٍ مَكَنتَشِيٍ رَبِرَ،
\q1 ﭑ بَرَ عٍ شَ كِرَيٍ كَنَ.
\q1 مِشِ يٌ مُ نَ عٍ شَ تَايٍ كُي سْنْن،
\q1 عٍ بِرِن شُن نَكَنَشِ.
\q1 
\v 7 ﭑ نُ بَرَ عَ قَلَ عٍ بّ،
\q1 ‹شَ وٌ فَاشُ ﭑ يَ رَ،
\q1 شَ وٌ ﭑ مَ مَرَ سِ سُشُ،
\q1 وٌ شُن مُ رَكَنَمَ.›
\q1 كْنْ عٍ فبَتَ قٍ حَاشِ رَبَدٍ.
\q1 نَ نَن عَ تٌشِ ﭑ بَرَ عٍ حَشَنكَتَ.
\q1 
\v 8 عَلَتَلَ شَ مَسٍنيِ نَن يَ؛
\q1 وٌ شَ مَمّ تِ، لْشْي قَمَ عَ لِدٍ
\q1 ﭑ مَ نَتّ كَمَلِمَ تّمُي نَشّ.
\q1 ﭑ بَرَ عَ قَلَ وٌ بّ،
\q1 نَ لْشْي ﭑ سِيٍ حَشَنكَتَمَ نّ ﭑ مَ شْنّ حَاشِ رَ،
\q1 دُنِحَ بِرِن شَ كَنَ.»
\b
\q1 
\v 9 «ﭑ قَمَ سِيٍ رَ سّنِيّندٍ،
\q1 عَلَكٌ عٍ شَ عَلَتَلَ شِلِ قَلَ،
\q1 عٍ بِرِن شَ عَ رَبَتُ لَنيِ كُي.
\q1 
\v 10 كٍلِقٍ يِرٍ مَكُيٍ دَنفِقٍ كُسِ شُرٍيٍ رَ،
\q1 ﭑ بَتُلَيٍ قَمَ نّ سّرّشّيٍ رَ ﭑ بّ.
\q1 
\v 11 نَ لْشْي وٌ مُ يَافِمَ سْنْن وٌ شَ قٍ رَبَشِيٍ رَ،
\q1 وٌ قٍ حَاشِ نَشٍيٍ رَبَشِ ﭑ نَ،
\q1 بَرِ مَ ﭑ يّتّ عِفبٌييٍ بَمَ نّ وٌ يَ مَ،
\q1 عَلَكٌ يّتّ عِفبٌحَ شَ حْن ﭑ مَ فٍيَ سّنِيّنشِ يِرٍ.
\q1 
\v 12 ﭑ تْورْ مِشِيٍ نُن مِشِ مَفٌرٌشِيٍ لُمَ نّ وٌ يَ مَ،
\q1 نَشٍيٍ شَشِلِ تِمَ عَلَتَلَ رَ.
\q1 
\v 13 عِسِرَيِلَ دْنشْي مُ قٍ حَاشِ رَبَمَ سْنْن،
\q1 عٍ مُ وُلٍ قَلَمَ، عٍ مُ مِشِ مَدَشُمَ.
\q1 عٍ لُمَ نّ عٍ مَلَبُ رَ بْحّسَ كُي،
\q1 مِشِ يٌ مُ عٍ تْورْ مَ سْنْن.»
\b
\q1 
\v 14 سِيٌن مِشِيٍ، وٌ شَ عَلَ مَتْشْ.
\q1 عِسِرَيِلَ، وٌ شَ سّيوَ.
\q1 دَرِ سَلَمُ، وٌ شَ حّلّشِن وٌ بْحّ بِرِن نَ.
\q1 
\v 15 عَلَتَلَ شَ شْنّ بَرَ فبِلٍن وٌ قْشْ رَ،
\q1 عَ بَرَ وٌ يَشُييٍ رَفبِلٍن عٍ شْنيِ.
\q1 عِسِرَيِلَ مَنفّ عَلَتَلَ بَرَ لُ وٌ تَفِ.
\q1 وٌ نَشَ فَاشُ، وٌ مُ تْورْ مَ سْنْن.
\q1 
\v 16 نَ لْشْي عَ عَ قَلَمَ نّ دَرِ سَلَمُ بّ،
\q1 «سِيٌن مِشِيٍ، وٌ نَشَ فَاشُ،
\q1 لِمَنِيَ نَشَ بَ وٌ يِ رَ.»
\q1 
\v 17 وٌ مَرِفِ عَلَتَلَ وٌ رَكِسِمَ نَ وٌ يَ مَ.
\q1 عَ سّيوَ مَ نّ وٌ شَ قٍ رَ،
\q1 عَ وٌ مَدُندُ عَ شَ شَنُنتٍيَ رَ،
\q1 عَ حّلّشِن وٌ رَ عَ شُي عِتٍشِ رَ.
\b
\q1 
\v 18 عَلَتَلَ نَشّ، «ﭑ سُننُنيِ بَمَ نّ وٌ شَ سَلِيٍ كُي،
\q1 ﭑ وٌ بَ وٌ شَ يَافِ شْرْشْي كُي.
\q1 
\v 19 نَ لْشْي ﭑ وٌ يَشُييٍ حَشَنكَتَمَ نّ،
\q1 ﭑ تْورْ مِشِيٍ رَكِسِ،
\q1 ﭑ مِشِ كٍرِشِيٍ رَفبِلٍن عٍ شْنيِ.
\q1 ﭑ عٍ شَ يَافِ حْشْمَ نّ مَتْشْي نُن بِنيّ رَ يِرٍ بِرِن.
\q1 
\v 20 نَ لْشْي ﭑ وٌ رَفبِلٍنمَ نّ وٌ شْنيِ.
\q1 ﭑ وٌ مَلَنمَ نّ عَلَكٌ وٌ شَ مَتْشْي نُن بِنيّ سْتْ،
\q1 دُنِحَ حَمَنّ بِرِن كُي.
\q1 ﭑ وٌ رَفبِلٍنمَ نّ، وٌ قَ نَ تٌدٍ.
\q1 عَلَتَلَ شَ مَسٍنيِ نَن نَ كِ.»
