\id HEB - Yagua NT -Peru 2008 (web -2013) 
\h Ebrévuveda 
\toc1 Ebrevuvedamuju̱ra Catera 
\toc2 Ebrévuveda 
\toc3 Ebr 
\mt1 Ebrevuvedamuju̱ra Catera 
\c 1  
\s1 Saniquejada Ju̱denu jidyenumusiy vu̱jyu̱ 
\p  
\v 1 Ta̱riy saniquenu̱yada Ju̱denu jaryedora jiñiquejada, saniquenu̱yada japichiy jijyu̱ tu̱chuvamyusiy ruuva vu̱myunatyavay.  
\v 2 Pariche diye rundamu ji̱ta saniquema̱ jidyenu jtosiy vuryiva, jiryatiy sabayada já̱mu nutyityu̱ju̱ ti̱ta̱ju̱nchani̱, simusiy jiryi̱nu̱y su̱ndejada ti̱ta̱ju̱ra tara.  
\v 3 Sadenu ji̱ta vichasara jidyáta, si̱tenu sa̱ntyasi̱ jarye variñi̱. Ni̱ni̱ suru̱chusara jiñiquejada vanu̱tya̱data ti̱ta̱ju̱ra tara, jiryatiy su̱ndesara darya. Ni̱day pu̱yada jibetyedata nijya̱nvavyasintyirya jijyuuchuvedantiy, rivasiy ji̱ta sama̱sa̱da variy santyityudamyuju̱ Ju̱denu, jiryatiy jarichu vandamu vichi̱ni̱. 
\s1 Savichasara Crístu jaryiñu̱va̱ju̱ Ju̱denu jpa̱vamyusiy 
\p  
\v 4 Jiryatiy su̱mutya̱jada jijye̱myusirya yitya nu̱tyu Ju̱denu denu, ramutiy savichasara jaryiñu̱va̱ju̱ Ju̱denu jpa̱vamyusiy.  
\v 5 Tama̱ su̱teda Ju̱denu tara siva yipa̱nu daryatiy su̱teda jidyenuva: 
\q1 “Jiñi rañi̱cha radyenucu̱, radyetuyasiy diye ji,” varimyata: 
\q1 “Ni̱ni̱ dyetya rañi̱cha radyenu, rañi̱ dyetya rañi̱cha saja̱y varidye.” 
\m  
\v 6 Su̱pa̱jadanumatiy Ju̱denu ni̱ jidyenu munatyi̱ jirya mucadimu, su̱teda variy: 
\q1 “Rirya̱ma̱ jadasiñu ri̱pa̱vay sanijyu̱yu.” 
\m  
\v 7 Su̱pa̱vaynchiy yiteda: 
\q1 “Ri̱tedamu rivyichasara ri̱pa̱vay nu̱tyu riicho; raynsu̱byimiy ji̱ta vichasara nu̱tyu jiidatyi quivaya̱sara daryá.” 
\m  
\v 8-9 Sadenunchiy ji̱ta yitatyadeda: 
\q1 “Ju̱denu, yinsu̱jyo ra̱chajaya̱sara ju̱na̱reju̱, yinsu̱yada ji̱ta rañi̱cha vase. Jivya̱tasara ji̱tara vase vichasa̱da, yavittyuy varirya va̱cha vichasa̱da. Ramuni̱ sivasara Ju̱denura vu̱rudija̱ yiva, rirya̱tidye jchana̱tya nijya̱nvay jaryivya̱ju̱ jityevamyusiy ji.” 
\m  
\v 10-12 Jadchintyi su̱tatyadeda jidyenunchintyi: 
\q1 “Nutyityu̱, yindejada rajo̱ta̱damusirya mucadi, jarichu jarye jiryatiy jijyomututa jvaachara darya. Rani̱ ra̱parutachara jarichu, mucadi risa̱ju̱, ji ji̱ta ra̱ma̱cho̱sara. Rani̱ ra̱rimyityuuchara nu̱tyu sujapyo. Ya̱day richera, nu̱tyu sujajyuu mi̱jajyuu jiryatiy vu̱jetyara, vurya̱tidye jachura samije ru̱bivaju̱. Ji ji̱ta ra̱suru̱jeya̱sara, ne ra̱baryi̱sara vaata jiijyu̱, tii mitya.” 
\m  
\v 13 Tama̱ su̱teda Ju̱denu ti̱ yipa̱nuva daryatiy su̱teda jidyenuva: 
\q1 “Ya̱ma̱sa rayntyityudamyuju̱ jasicha̱ra̱ju̱tiy ra̱bay jiñumutujariryi jimyityasimyi.” 
\m  
\v 14 Neviy jiryi̱nu̱y riñi rivyichasara Ju̱denu tuunu vichavay, simusiy pi̱ru̱vye, rirya̱tidye jmu̱tyajaya̱sara riy rityi ra̱jmutya̱ru̱rya jantyutya̱da Ju̱denumusiy. 
\c 2  
\s1 Ne vurya̱rrachura Ju̱denu jantyutya̱da 
\p  
\v 1 Ramuni̱tiy vu̱ryi tuva̱chu dyetya jaryivya̱ju̱ ramu jiryatiy vu̱tyuva̱chuma̱, vu̱ñuma caray ramusiy.  
\v 2 Ju̱denu niquejada ji̱ta jiryatiy satu̱chutadeda yipa̱varya, ravichasara si̱tenu niquejada daryá. Rityimyu̱ ne siityeru̱yada raju̱, ru̱mutya̱jada varirya tanuvu̱doda ramurichirya.  
\v 3 ¿Nu̱tyuramusiy vurya̱ramitya varirya Ju̱denu nique̱yada, nu̱tyuramusiy? vu̱tyi rrachura sa̱ntyutya̱da jiryatiy jaryi samirya rani̱cha, jiryatiy satu̱choda Ju̱denu munatya Vu̱yntyityu̱ Jesucrístu jtosirya, rivasiy ji̱ta su̱dutya̱da vu̱jyu̱ra, simu tuva̱chuvay jtedamusintyi.  
\v 4 Ju̱denu ji̱ta dityadoda ru̱teda jsa̱ju̱ra mityamusiy datyadoda, ti̱ttasara, mityamusiy jvaayada jarye, jiryatiy si̱tenu tu̱choda rani̱cha day. Sava̱ta̱damusiy jiche̱yadantirya Yintu datya̱daterantiy. 
\s1 Su̱deda Jesús nu̱tyu nijya̱mi̱ vurye̱ntyutyasa̱daju̱ 
\p  
\v 5 Ne sabayada Ju̱denu vadi mucadi nutyityu̱mijyu̱ riy yipa̱vay, ranchityi nu̱ñique.  
\v 6-8 Satu̱choda ti̱ vijyo̱mujache daryaju̱ jiñiquejadamu: 
\q1 “¿Chi̱ra sani̱cha nijya̱mi̱ jiryatiy jijechipityani̱? ¿Va̱ nijya̱mi̱ denu cay, chi̱ra sani̱cha ya̱tidye jachipityaja̱sarani̱, chi̱? Jibeyada yipa̱vay jarijyu̱ni̱ nijya̱mi̱ taraquideju̱. Jibechara su̱no̱vara nu̱tyu parenu vanda, rirya̱tidye jnu̱chara nijya̱nvay suvu̱yadamu sana̱cho̱, jibeyadani̱ nusu̱ñu yinderanchaju̱ntiy. Jichabodeda ti̱ta̱ju̱ sansu̱yadamuju̱ra.” 
\m Jiryatiy sasabodeda ti̱ta̱ju̱ nijya̱mi̱ju̱ra, ne rama̱cho̱ tara jiryatimyu̱ ne sabonichara darya. Diye ji̱ta, ne vu̱dyi riva ti̱ta̱ju̱ sabonichara nijya̱mi̱ju̱ didye.  
\v 9 Vu̱dyi ji̱ta siva Jesús jiryatiy sani̱cha bachi̱ Ju̱denu jpa̱vay jarijyu̱ taraquideju̱, jiryatiy sabatyeda paru̱cha̱rimyusiy, sa̱tidye bay Ju̱denu varirya já̱mu nutyityu̱ nuvii su̱no̱va, jiryatiy vandara, samiy jvadichara jarye risa̱ju̱ra. Daryani̱ sabatyeda Jesús ti̱ta̱ju̱ nijya̱nvay jiyadaju̱ Ju̱denu va̱ta̱damusiy. 
\p  
\v 10 Jiryatiy su̱ndejada Ju̱denu ti̱ta̱ju̱ jijecharaju̱ra tara, samirya rani̱cha sa̱tidye ca̱siy paru̱cha̱rimyusirya yivaayada simu, vuryeyada rá̱ñu Jesucrístumu, ni̱tiy ju̱dejadara vuryentyutya̱da, sa̱tidye jiryiryi rajuuvay nijya̱nvay jidyedyeñuju̱, vandamu vicha̱daju̱ yisa̱ju̱.  
\v 11 Tapi vu̱jiintyabi, daryantiy sajiintyavay vu̱ñi̱cha vatajuu Ju̱denu dadyeñu ti̱ta̱ju̱. Ramuni̱mu̱y ne sa̱da Jesús ju̱teda jityeryi̱veda riy.  
\v 12 Su̱tedantiy: 
\q1 “Ra̱tu̱chusarara yitya ratyeryi̱veda cabyiva. Nijya̱nvajyuu parudamu ra̱murra̱y ri̱chana̱yadamu jiñijyu̱ Ri̱ndenu.” 
\m  
\v 13 Su̱tedantiy: 
\q1 “Rantya ra̱jachipiya̱sara sanijyu̱,” 
\m jadchintyi: 
\q1 “Jiyu darye, deramidyeri̱ risa̱, jiryatiy sasa̱yada Ju̱denu ray.” 
\p  
\v 14 Ramuni̱tiy jiryatiy rivyichasara jivye deramidyeri̱ savityavay, nudatavay jarye, ni̱ jarye vichasara mityiji rusa̱, sa̱tidye paruta jibetyedamusiñi̱ ni̱tiy datya ju̱veda riy nijya̱nvay, jiryatiy bayantu nutyityu̱ dañi̱.  
\v 15 Ramusiy ji̱ta sa̱ntyuchara ruuva rityi vichasara bayantu cumudemiy jichuvu̱yadamusiy.  
\v 16 Si̱tenuni̱ ne su̱mu̱tyaru̱yada rata riy Ju̱denu jpa̱vay; su̱mu̱tyaru̱yada ji̱ta riy nijya̱nvadye jiryatiy Avurá̱bay dadyeñujuu daryi, rityuva̱chodamu.  
\v 17 Ramuni̱tiy daryani̱ saryi vichasara Jesús nu̱tyu jityeryi̱veda nta ti̱ta̱ju̱, sa̱tidye vicha caserdótevyeda nutyityu̱, jantyutyara, yivaayada jto̱tanirya jarye, jiryatiy sivaachara Ju̱denu diya nijya̱nvajyu̱ra, jiryatiy sara̱y rijyuuchuveda jiyadaju̱ntiy.  
\v 18 Ni̱ jarye datya̱dara paru̱tya̱da jijye̱ jantya̱damusiy, ramuni̱tiy sadatya jmu̱tya̱da rivasivyu̱y, jiryatiy vu̱vyichasara saja̱y jantya̱damu. 
\c 3  
\s1 Savichasara Jesús jaryiñu̱ Muyisésibemyusiy 
\p  
\v 1 Ramuni̱tiy, ratyeryi̱veda, jiryatiy jiintyasavañuma Ju̱denumuju̱ vu̱y, jiryatiy sanatuyada yisa̱ju̱ vu̱y, vurye̱ntya jnu̱y samiy sana̱cho̱ Jesús ni̱tiy vichasara Ju̱denu nusu̱byi vuryimuju̱, Ju̱denu mo̱mu jarye savichasara vuryeyada rá̱ñu, jiryatiy vu̱tyuva̱chu vatajuu simu.  
\v 2 Daryatiy savicha̱da Muyisésibe siityera Ju̱denuju̱ ti̱ta̱ju̱ sansu̱yadamu, sanijya̱nvay cabyiva, daryani̱day savichasara Jesús siityera saju̱ ni̱tiy jpa̱jadani̱.  
\v 3 Jesús ji̱ta raryi jmutya̱ jaryivya̱ju̱ra vanda Muyisésibemyusiy, daryani̱ vu̱ryi jnu̱y jaryi jvadichi̱ni̱ jiryoriy jvaañu jiryorimyusiy.  
\v 4 Nu̱ñi taroriqui ti̱qui jvaañu tara, Ju̱denu ji̱ta ju̱dejada ti̱ta̱ju̱ra.  
\v 5 Savicha̱da Muyisésibe siityera Ju̱denuju̱, nu̱tyu samiy muchechiy savicha̱da daryaju̱ Ju̱denu siityari̱vajyuu cabyimu, sa̱tidye tu̱chu vijyo̱mujachera jiryatiy sani jteda yaniquera.  
\v 6 Jesucrístu ji̱ta vichasara siityera Ju̱denuju̱ nu̱tyu sadenu jichiityari̱vajyuu nusu̱yadaju̱, jiryatiy vu̱ñi̱ vu̱ñi̱cha, vu̱ryityi jiriryi̱ surravay rabaryi̱jadasa̱ra̱ju̱ra vu̱yntuyada Crístujiju̱, jiryatiy vu̱jechipiya̱ ranijyu̱ vuryi̱chana̱tya̱damu. 
\s1 Jiituyada jiryatiy Ju̱denu siityari̱vajyuuju̱ra 
\p  
\v 7-8 Ramuni̱tiy su̱tachara Ju̱denu Jnutu darya vuryiva: 
\q1 “Jiryeñumatiy tuva̱chu diyera Ju̱denu niquejada, ne jirya̱suru̱chura jijechiy rayaro̱ju̱ nu̱tyu sanijya̱nvatyi suru̱choda jivyara jachipiya̱jadamusirya jijechiy, rirya̱ntya̱danumatiy mityatomuni̱ Ju̱denu.” 
\m  
\v 9-11 Su̱teda daryaju̱: 
\q1 “Jiryemyunatyavay jantyajaya̱jada tuva̱chu̱sa̱miy daryaju̱yu vu̱yaju̱y nijya̱ca̱ ray, ridyiñu̱yada riva rivaayada jiyadaju̱. Ramuni̱tiy rañique̱yada ji̱ta riñijyu̱, ri̱teda variy: Ricyarayanumucha jijechimyu; ne riryupiryu̱y rañú̱va. Jadchiy ri̱tedara si̱tenu niquejada rañique̱yadamu: ¡Tama̱ rirya̱jay rajyiituyadamu, tama̱, mitya!” 
\p  
\v 12 Jiryi̱nu̱tyata̱ta ra̱jisiyu, ratyeryi̱veda, jiryeñuma vichasara tuva̱chu̱sa̱miy, jamirya jachityavay, jasicha̱ra̱ju̱tiy jirya̱jiintya sa̱jisiy Ju̱denu jnu̱ñuyu.  
\v 13 Jirya̱ma̱ vanu̱tya̱yu jasicha̱ra̱ju̱tiy sasa̱y Ju̱denu jnu̱yadaju̱ vu̱y, jiryeñuma suru̱chura jijechiy juuchuveda quivu̱yadata.  
\v 14 Vu̱ryityi jiriryi̱ surravay rabaryi̱jadasa̱ra̱ju̱ra simu tuva̱choda daryatiy vu̱jyo̱ta̱da tuva̱choda ta̱riy simu, vurya̱jmutya̱ vatajuu Crístusa̱ varirya vuryeyaru̱rya.  
\v 15 Jiryatiy ti̱ jteda: 
\q1 “Jirya̱tiy tuva̱chu diyera saniquejada, ne jirya̱suru̱chura jijechiy nu̱tyu ta̱rijye̱myityi suru̱choda jivyara jachipiya̱jadamusirya jijechiy Ju̱denu jiyaro̱ju̱.” 
\m  
\v 16 ¿Muvyerya nique̱ñu̱yada Ju̱denu jiyaro̱ju̱, muvye? ¿Ne viy jivye nijya̱nvadye jiryatiy richipyateda Ejíptumusiy Muyisésibejsa̱?  
\v 17 Jadchintyi, ¿Muvye jsa̱ sanique̱ñu̱yada Ju̱denu daryaju̱yu vu̱yaju̱y vaatasa̱ra̱ju̱, muvye? ¿Ne viy rusa̱ day jiryatiy riño̱teda diibyimiy mityatomu, jiryatiy rijyuuchuveda sanijyu̱ daryaju̱?  
\v 18 Jadchintyi, ¿Muvyevyara su̱teda Ju̱denu si̱tenu niquejadata, muvyevya: 
\q1 “Tama̱ jirya̱jay rajyiituyadamu, tama̱?” 
\m ¿Ne viy ruuva jiryatiy tuva̱chu̱sa̱midyeryi?  
\v 19 Vuryi̱nu̱y variy ramusiy: ne vana̱y rijeyada sajiituyadamu jiryatimyu̱ ne rityuva̱churu̱yada daryaju̱ simu. 
\c 4  
\p  
\v 1 Ramuni̱ vurya̱suvu̱y variy, vu̱ñuma su̱tye ra̱jisiy Ju̱denu jiituyadamu jayada, sani siityari̱tidye natuyada vu̱jeyadaju̱ vu̱y.  
\v 2 Riti̱ma̱ vuryimu daryaju̱ samitu̱chodantiy daryani̱ rito̱jada ta̱riy ruumuntiy, dañumamu̱y ne ru̱mutya̱jadara jiituyada, jiryatimyu̱ ne rityuva̱choda jijechitya saniquejadamu daryaju̱, jiryatiy sani tu̱choda ruuvara.  
\v 3 Vu̱y ji̱ta ra̱jay sajiituyadamu jiryatiy simu tuva̱chuvay daryaju̱ davyu̱y, dañuma su̱teda tavay nchiy: 
\q1 “Ri̱teda rañique̱yadamu: Ne rirya̱jay rajyiituyadamuju̱.” 
\m Ju̱denu ji̱ta jvaamyu̱rya yivaayada jiryatiy su̱ndejada rajo̱ta̱damusiy ti̱ta̱ju̱ra tara, sajiituyada variy rivasiy.  
\v 4 Su̱teda daryaju̱ jiñiquejadamu jiituyada rundanchiy: 
\q1 “Sajiituyada ji̱ta Ju̱denu darundaju̱ñijyate jasacha̱damu yivaayadamusiy ti̱ta̱ju̱.” 
\m  
\v 5 Su̱teda ji̱ta tara niquejadamu jadchintyi: 
\q1 “Riryi javya̱ jivye rajyiituyadamu.” 
\m  
\v 6 Ramuni̱day rama̱cho̱sara tavay jayadaju̱, dañumamu̱y ne rijeyada ta̱rijye̱myi tuva̱chu̱sa̱miy jiryatimyu̱ ne rityuva̱churu̱yada ramu samitu̱choda daryaju̱.  
\v 7 Sabayada Ju̱denu ju̱na̱ntyirya rarundantiy varityi vurya̱jay, daryatiy su̱teda rivasiy Davyíbe murra̱yadamu: 
\q1 “Diye ji̱ta jirya̱ma̱ tuva̱chu ramu saniquejada; ne jirya̱suru̱chura jijechiy sayaro̱ju̱.” 
\m  
\v 8 Saryityi sa̱yada Josuvébay jiituyadariy judíyuveda, tama̱ saryi niquejada Ju̱denu rivasiy ratarya jiituyada runda, tama̱.  
\v 9 Daryani̱day rama̱cho̱ jiituyada Ju̱denu siityari̱vajyuuju̱.  
\v 10 Tapi ni̱tiy jay sajiitujyomu, sajiitumya̱ yivaayadivasiy daryatiy sajiituyada Ju̱denu yivaayadivasintyi.  
\v 11 Vurya̱ma̱ jantya siityari̱jada jayada sajiituyadamu, vu̱ñuma rupa̱ vu̱ño̱tedamusirya, daryamusiñi̱day ripyaruteda ta̱rijye̱myi tuva̱chu̱sa̱miy.  
\v 12 Jnú̱rya daryaju̱ra Ju̱denu niquejada, vanu̱yadatara, mityamusiy datya̱datara jarye risa̱ju̱ra, jiryatiy jaryi jimyurava̱ju̱ ramusiy jchityitya̱ra, jiryatiy daraju̱y jimyura mo̱tárara. Rajachara Ju̱denu niquejada vu̱ñube ti̱ta̱ju̱, vuryi̱ntusa̱ra̱ju̱, nu̱tyu nta vuryi̱vichiy sa̱ra̱ju̱, vu̱dyuricha sa̱ra̱ju̱ ti̱ta̱ju̱; rajay jasicha̱ra̱ju̱tiy radityanuntirya vu̱jechiy jachipiya̱jadantiy, vu̱ñi̱ru̱yada jarye risa̱ju̱.  
\v 13 Ne vana̱y sadutya Ju̱denu ju̱debi yajisiyu, nu̱tyu sidyavu̱de ti̱ta̱ju̱ tara sani̱simyuju̱, jiryatiy vurya̱jmutya̱nuvesarani̱ daryatiy sa̱jtaja̱nu vu̱y. 
\s1 Jesús vichasara caserdótevyeda ja̱mu nutyityu̱va̱ju̱ 
\p  
\v 14 Ramuni̱day jiryatiy vu̱vyichasara vuryeyada rá̱ñutávay, ni̱tiy jay jarichuvimuju̱ vuryeyadaju̱ ti̱ta̱ju̱, jiryatiy ja̱mu nutyityu̱ Jesús ni̱, Ju̱denu denu, vurya̱ma̱ jiriryi̱ra tu̱choda vu̱jechipiya̱jadata sanchiy.  
\v 15 Savichasara daryaju̱ vuryeyada rá̱ñu mityamusiy datyara, jiryatiy sadatya samiy jachipiya̱jadatara vuryi̱diva̱jada ti̱ta̱ju̱. Sa̱ntya̱da Ju̱denu daryaju̱ ti̱ta̱ju̱muni̱, daryaday sa̱ntyasarantidyevyu̱y, ne sajuuchuveda Jesucrístu variy ru̱co̱siy, mitya.  
\v 16 Ramuni̱day vurya̱tuudiye̱ vu̱chuvu̱yasa̱damura vuryeyada rá̱ñu vichajo, jasityi vurya̱jmutya̱ra sa̱ntyutya̱da, sa̱tidye jmu̱tyasara vurye̱ntyuyadiva varivyu̱y. 
\c 5  
\p  
\v 1 Judíyuveda jaryetanu̱yada jiquebyimusiñi̱ ti̱qui vanu caserdótevyeda nutyityu̱ju̱, ribeyada variñi̱ sa̱tidye raniy Ju̱denu mo̱mu jityevay jiyadaju̱, jiryatiy su̱ntatya̱dara riche̱rya sanijyu̱, ru̱veda riy jasi̱veda sanijyu̱ntiy, nijya̱nvay juuchuveda murichirya.  
\v 2 Ni̱ni̱ datya̱da vichadeda samiryi datyi̱sa̱miy, caravye jarye rusa̱ju̱, jiryatiy ni̱ jarye vichasara jdiva̱jni̱ jijyuuchuvedivantiy.  
\v 3 Ramuni̱ sava̱ta̱da jnutatya̱da riy jasi̱veda jvachavay jijyuuchuveda jiyadaju̱, daryaday su̱ntatya̱da tavay juuchuveda jiyadaju̱ntiy.  
\v 4 Dantyamu̱y ne ti̱ jiryeda jidyiryamusirya jirya jvaayada, vinu jiryatiy sanatuchara Ju̱denu raju̱ni̱, nu̱tyu Arú̱batyi sanatuyada darya.  
\v 5 Daryaday Crístuntiy, ne sani va̱ta̱da caserdótevyeda nutyityu̱ju̱yu, savicha̱da ji̱ta Jesús raju̱ bachi̱ jijye̱myusiy ni̱tiy jteda siva: 
\q1 “Jiñi rañi̱cha radyenu, radyetuyasiy diye ji.” 
\m  
\v 6 Daryantiy ratarya niquejadamu su̱teda: 
\q1 “Jiñi jiñi̱cha caserdóte ju̱na̱reju̱ nu̱tyu savicha̱da Meruquisedécu jtyati̱ daryá.” 
\m  
\v 7 Savicha̱danumatiy Jesús nijya̱mi̱ vu̱ti̱ jiyu, satu̱choda sisa̱ Ju̱denu jijechiñu̱yadamu, jiryatiy sayasanta̱da jiche̱ñe̱ya̱jadatani̱, su̱na̱ya̱ja̱ta jarye risa̱ju̱, jiryatiy sadatya̱da Ju̱denura siva jantyuyada diiyadajisiy. Satuva̱choda ji̱ta Ju̱denu simu, jiryatiy sajachiñu̱yada siityejada jachityi̱ sivara.  
\v 8 Dañuma sani̱cha Ju̱denu denu, sadatya̱da paru̱cha̱rimyusirya siityera vichasa̱da.  
\v 9 Sadatyamu̱yadanumatiy ti̱ta̱ju̱ tara yimuju̱, savicha̱da variy ramusiy rirye̱ntyutya̱da ju̱desaramu ti̱ta̱ju̱ jiryatiy rityuva̱chusara simu diyesa̱ra̱ju̱.  
\v 10 Sadiryejada Ju̱denu daryaju̱ni̱: 
\q1 “Jiñi jiñi̱cha caserdótevyeda nutyityu̱ nu̱tyu Meruquisedécu vicha̱da daryá.” 
\s1 Jatyi vu̱rrachura Ju̱denu siityari̱sa̱da 
\p  
\v 11 Jasidyerya rajuura tu̱choda ranchiy jiryatiy surramusiy datyasarara, jiryatiy jiryeñi̱cha tu̱yupuryimyi nta jiryejechimyu.  
\v 12 Dañuma jiryeñi vicharu̱y nta datyanuvay, jiryevya̱ta diye sa̱ra̱ju̱ sa̱tidye datyanu ti̱ ju̱na̱y jiryentyirya Ju̱denu niquejada jo̱tarantiy. Jiryevya̱ta ji̱tara ji̱tya̱ja̱ jiryi̱ntu poyadaju̱, ne ja̱myi jmyi̱sara day.  
\v 13 Tapi ni̱tiy pochusara vinu ji̱tya̱ja̱tayu, ne vana̱y sa̱jmutya̱sarara vase datyadoda niquejada, jiryatiy sani̱cha nu̱tyu deradera yintumu day.  
\v 14 Jmyichara jiryatiy surrara, rani̱ ji̱ta ja̱myi jmyi̱sara day, jiryatiy datyavañuma yivaayadamusiryi, mirya jvaayada samirya day, miryara nicyara̱y. 
\c 6  
\p  
\v 1 Ramuni̱ vurya̱tochirya rajo̱ttya̱musiy datyadoda Crístunchiy vurya̱tidye jiriryi̱ra jiryatiy ja̱myi vichasa̱da darya. Ne vurya̱siityari̱ datyadodara ru̱ndesaranu̱day, jiryatiy vu̱ryipyaru̱y riva ti̱ta̱ju̱ jvaayada jiryatimyu̱ ne samirya jvadichara Ju̱denu diya darya, vurya̱tidye jachipiya̱ variy sanijyu̱.  
\v 2 Dantyamu̱y ne vurya̱datyanusara ji̱tyadodanchintyi, dantyamu̱y ne ranchiy jiryatiy vu̱berya vu̱jyomutu nijya̱nvayncha sa̱tidye jmu̱tya Ju̱denu variryi, dantyamu̱y ne diibyimusiy mi̱sadedanchiy, ne vinu Ju̱denu murichenutadedanchiy. Ne vurya̱datyanusara vinu ranchiy.  
\v 3 Vurya̱day jiriryi̱ rayadaju̱ sa̱tiy va̱ta Ju̱denura daryá.  
\v 4 Ne vana̱y sa̱numitye nijya̱mi̱ ju̱na̱y Ju̱denunijyu̱ nu̱day, ni̱tiy caray sanú̱vasiy. Ni̱tiy sano̱no̱nu̱y Ju̱denu jiñú̱va, jiryatiy sadatyama̱ Ju̱denu sa̱yada jarichumusiyu, su̱mutya̱ma̱ variñi̱ Su̱ntu yimuju̱.  
\v 5 Sadatyama̱ntiy ta̱ jaryi samiryani̱te rani̱cha Ju̱denu niquejada, sadatyantirya Ju̱denu vanu̱yadantiy, jiryatiy sasa̱y diye jvaayadaju̱ra.  
\v 6 Sanumatiy caray variy Ju̱denu nú̱vasiy, saryi jvay nta ju̱na̱y crusitya̱sa nta ni̱ Ju̱denu denuntiy, saryi javityiye̱ variy vijyo̱mujache ramusiñi̱.  
\v 7 Daryani̱day si̱chana̱tyasara Ju̱denura mucadi, jiryatiy ru̱mutya̱numatirya ru̱mura yimuju̱, raja̱vyechu varirya nutasara rijyu̱ nijya̱nvay jiryatiy rijya̱sicharára.  
\v 8 Ranumatiy ja̱vyechu mucadira cariitu, vachuy jarye, saryi rrachuru̱y Ju̱denu variy rivara, saryintay variy rupedaju̱ra, sa̱tiy javatya Ju̱denu variy riva vu̱jyuuchuveda vu̱y. 
\s1 Vu̱ryi vichasara samivye vu̱yntuyadamu 
\p  
\v 9 Ravya̱tavay, dañuma rañiquera darya niquejada, rajechipiya̱ samiryava̱ju̱ jiryenchiy, jiryatiy jirya̱jiriryi̱ra yentyutyasa̱da.  
\v 10 Ne savichasara Ju̱denu taji jachipiya̱ra, sa̱jachipujerya jiryivaayada, jiryevya̱ta̱da jarye ne sa̱jachipuchara jiryatiy jiryedyityadoda sayadaju̱ sasiityari̱vajyuu nijyu̱ra, jiryatiy jiryi̱mu̱tyajaya̱sara riy.  
\v 11 Nu̱ñi̱ru̱y nu̱ñi ti̱qui jiyadaju̱, jirya̱ma̱ jiriryi̱ dityadodara darya jvaaryu̱yada, jasicha̱ra̱ju̱tiy ra̱jto̱taniy ti̱ta̱ju̱ra jiryatiy jiryentuyada ra̱jiju̱ Ju̱denumusiy.  
\v 12 Ne jirye̱cha pituvye variy, jirye̱cha ji̱ta rirye̱ntyávay rityi jmutya̱sarara Ju̱denu niquejada tapi, jityuva̱chodamusiy. 
\p  
\v 13-14 Su̱tedanumatiy Ju̱denu darya siva Avurá̱bay: 
\q1 “Ra̱vichanichara samiy ji, ra̱jasa̱chusara jaryi variryi jidyedyeñu.” 
\m Su̱teda variy yityamusiy jiryatimyu̱ ne ti̱ vichasara jaryiñu̱ simusiy.  
\v 15 Jadchiy, jiryatiy savichanu̱yada Avurá̱bay tapimusiy tuva̱chura, su̱mutya̱jada varirya jiryatiy su̱teda ya̱jvaay Ju̱denu saju̱ra.  
\v 16 Nijya̱nvay ji̱ta ru̱taryu̱ñumatiy si̱tenura tara, ru̱tay jaryiñu̱ jtyamura, rirya̱tidye tuva̱chu tavay variy ramu riñiquejada. Ru̱mutya̱sara tavay variy nu̱tyu si̱tenura riñiquejada.  
\v 17 Sadityanuru̱ñumatiy Ju̱denu variy jichiityari̱vajyuura si̱tenu yiteda, jiryatimyu̱ ne vana̱y ti̱tunusara darya, su̱teda variy yityamusiy.  
\v 18 Jiryatimyu̱ ne vana̱y saquivu̱choda Ju̱denu yitedamu, dantyamu̱y ne si̱tyamusiy, vu̱vyanu̱tya vurye̱ntyuyadamu vu̱y jiryatiy vu̱tyuva̱chusara vu̱ryamityanicha̱daju̱ simu.  
\v 19-20 Vu̱yntuyada ji̱ta rani̱cha rupanitya̱ nta vu̱beyanuju̱ jiryatiy vu̱dyetya saya̱da Jesús jiyanti̱ vurya̱jiju̱ Ju̱denumuju̱ vuryeyadaju̱, jiryatiy savichajaya̱sara caserdóte ju̱na̱reju̱ nu̱tyu Meruquisedécu vichanu̱yada daryá. 
\c 7  
\s1 Jesús vichasara caserdóte nu̱tyu Meruquisedécu vichanu̱yada daryantiy 
\p  
\v 1 Jiñu Meruquisedécu jiryatiy savicha̱da nutyityu̱ Saré̱mu, na̱vay vichi̱ Ju̱denunijyu̱ caserdóte jarye risa̱ju̱ni̱, sasaryedanumatiñi̱ Avurá̱bay, jiryatiy satarya̱jada munu̱ñu nutyityu̱veda ju̱vedamusiy, su̱teda samiy Ju̱denu jtyamu sayadaju̱.  
\v 2 Ni̱ni̱ ji̱ta sasa̱yada Avurá̱bay taraqui vu̱yaju̱tye jicho̱varyatera jiryatiy saso̱veda jimyityasimyimyusirya. Rú̱tachara daryaju̱ si̱tya Meruquisedécu, “vase jvaayada nutyityu̱,” jadchintyi savicha̱da nutyityu̱ Saré̱mu, jiryatiy vuryi̱tachara “samirya vichasa̱da nutyityu̱.”  
\v 3 Savichanu̱yada ne ja̱tyi̱, dantyamu̱y ne jno̱dati̱, dantyamu̱y ne munatyi̱ti̱. Dantyamu̱y ne nu̱dyetya sapi̱ru̱yadanchiy, ne vinu sadiiyadanchintyi, mitya ti̱ta̱ju̱. Savicha̱da ji̱ta nu̱tyu Ju̱denu denu, jiryatiy sa̱vichajaya̱sara caserdóte ju̱na̱reju̱. 
\p  
\v 4 Jirya̱jachipiya̱ samiy: Ta̱ jaryi ja̱mu nutyityu̱ savicha̱da jiñu Meruquisedécu jiryatiy sasa̱yada vu̱myunatyi̱ Avurá̱bay vu̱yaju̱tye jicho̱varyateni̱, jiryatiy Ju̱denu jiyaru̱ryara.  
\v 5 Sabayada Ju̱denu rivasiryi Devyíbe dadyeñu caserdótevyedaju̱, rirya̱tidye jmutya̱sara jityevamyusirya Ju̱denu jiyaru̱rya riberyatera, dañuma riñi̱chanu̱yada Avurá̱bay jasi̱vedantiy.  
\v 6 Jiñu Meruquisedécu, dañumamu̱y ne sani̱cha̱da Devyíbe denu, su̱mutya̱jadara Ju̱denu jiyaru̱rya Avurá̱bay baryatera, su̱teda variy samiy Ju̱denu jtyamu sayadaju̱ Avurá̱bay, ni̱tiy jmutya̱jadantirya Ju̱denu jteda samiy jiñijyu̱ntiy.  
\v 7 Vu̱dyetya ji̱ta ti̱ta̱ju̱, ni̱tiy vichasara jaryiñu̱ jityenumusiy, ni̱ni̱ jtachara samiy jtedamu variy siva jityenu.  
\v 8 Jadchintyi, Devyíbe dadyeñu jiryatiy ru̱mutya̱jadara Ju̱denu jiyaru̱rya, riñi̱ ji̱ta vicha̱da diiyasavadye. Meruquisedécu ji̱ta ru̱tachara jnu̱ñu diyesa̱ra̱ju̱.  
\v 9-10 Vuryi̱tay dyetya Devyíbe nchiy: “Ni̱ni̱ jiryatiy saryi jmutya̱sarara Ju̱denu jiyaru̱rya, nu̱tyuni̱ nta murichenu Avurá̱bavyimusirya Ju̱denu jiyaru̱rya, jiryatimyu̱ ne pi̱ru̱ñu variy didyeñi̱, sasaryejadanumatiy Meruquisedécu ni̱ samunatyi̱ Avurá̱bay.” 
\p  
\v 11 Rasa̱ra̱tiy raricha̱da rirye̱yada Devyíbe dadyeñu nijya̱nvay jiyadaju̱, jiryatiy ru̱mutya̱jadara Ju̱denu jteda Muyisésibemyusiy, ¿ta̱raju̱na̱ vurya̱va̱ta ju̱na̱y sa̱mu̱ti̱ ti̱ vuryeyada rá̱ñuju̱ntiy, ta̱raju̱? nu̱tyu Meruquisedécu daryá, Devyíbe dadyeñu ju̱bivaju̱.  
\v 12 Tapi rirya̱numatiy ja̱tay vuryeyada rá̱vye tavayjisiy, vu̱vya̱ta ji̱tara Ju̱denu jteda vadi niquejada ramuju̱ntiy.  
\v 13 Ni̱ni̱ ji̱ta sanchiy jtacha̱datiy darya niquejada, ni̱ni̱ vichasara tavay ju̱riiñumusi̱, samunatyavatyimyu̱ ne jvaañu̱yada Ju̱denu mo̱mu nijya̱nvay jiyadaju̱.  
\v 14 Jvadatyasara daryaju̱ra jiryatiy Vu̱yntyityu̱ Jesús munatyi̱ vicha̱da Judábay, sanchityimyu̱y ne su̱teda Muyisésibe rirye̱cha caserdótevyeda Ju̱denu mo̱mu jvaayadaju̱.  
\v 15-16 Jvadatyasarava̱ju̱ vu̱jyu̱ darya, sa̱numatiy mu̱ti̱ ti̱ vuryeyada rá̱ñuju̱ nu̱tyu Meruquisedécu vicha̱da daryá, ni̱ni̱ ji̱ta vichasara vuryeyada rá̱ñuju̱ bachi̱, ne jiryatiy savichasara Devyíbe denu. Savichasara ji̱ta vuryeyada rá̱ñuju̱ bachi̱ jiryatimyu̱ ne parutachara darya su̱nu̱yada vanu̱yada day.  
\v 17 Jtachara daryaju̱ sanchiy: 
\q1 “Jiñi jiñi̱cha caserdóte ju̱na̱reju̱ nu̱tyu Meruquisedécu vichanu̱yada daryantiy.” 
\p  
\v 18 Baryi̱ranuma ji̱ta munatya Ju̱denu jteda Devyíbe dadyeñu jvaayadanchiy, jiryatiy jdiva̱sara daryaju̱ra, dantyamu̱y ne samirya taraju̱ra.  
\v 19 Ne vana̱y rito̱tadedara tara daryaju̱, mitya. Sabayada Ju̱denu ru̱bivaju̱ra nutuyada jiryatiy samiryava̱ju̱ra, ramusityi vu̱tyuudiya̱ru̱ñi̱ Ju̱denu. 
\p  
\v 20 Su̱teda Ju̱denu yityamura jirya vadi jteda Jesús nchiy. Ne sabayada ji̱ta Devyíbe dadyeñu caserdótevyedaju̱ yityamu day, mitya.  
\v 21 Jesúsva ji̱ta su̱teda Ju̱denu: 
\q1 “Ri̱tyamu ji̱ta ri̱tay, ne ra̱paru̱tyasara riva ray: Jiñi jiñi̱cha caserdóte ju̱na̱reju̱.” 
\m  
\v 22 Ramuni̱tiy savichasara Jesús vuryeyada rá̱ñu samiy jtedamuju̱.  
\v 23 Riñi̱cha̱da Devyíbe dadyeñu rajuuvay, jiryatimyu̱ ne vana̱y ririryi̱jadara yivaayada, jiryatiy ridyiiye̱ñu̱yada daryaju̱.  
\v 24 Jesús ji̱ta, jiryatiy sasiityari̱jaya̱sara jvaayada ju̱na̱reju̱, ne sava̱ta ti̱ ra̱jay yibivaju̱ vuryeyada rá̱ñuju̱, mitya.  
\v 25 Sa̱ntyutyaru̱y ti̱ta̱ju̱ daryaju̱riy, jiryatiy rityuudiye̱charani̱ Ju̱denu simusiy, jiryatiy savichajaya̱sara riyada rá̱ñuju̱ Ju̱denu tuunu. 
\p  
\v 26 Vu̱vya̱tasara daryaju̱ni̱ caserdótevyeda nutyityu̱ nu̱tyu ni̱tiy daryá, jiryatiy Ju̱denuju̱ jiintyasi̱ni̱, juuchajsa̱ jarye risa̱ju̱ni̱, ne va̱cha jvaayadati̱, mitya. Ni̱ni̱ sani̱cha jiintyasi̱ juuchatavaynchiy, jiryatiy nubesumityanichi̱ jaryivya̱ju̱ jarichu jiyadaju̱ni̱.  
\v 27 Ne sava̱tasara Jesús jnutatya̱dani̱ jasi̱ jvachi̱ jijyuuchuveda murichiryaju̱ munatya, rivasiy ji̱ta nijya̱nvay juuchuveda murichiryaju̱, daryatiy ruvaachara tavay caserdótevyeda nutyityu̱miy. Su̱ntatya̱danumatiy Ju̱denumuju̱yu, sivaamyu̱mya̱ ji̱ta ratara caserdótevyeda nutyityu̱ jvaayada.  
\v 28 Ju̱denu niquejada, jiryatiy Muyisésibemyusirya, rañi bachara caserdótejyu̱ riy vaduy, jiryatiy jdiva̱jnuvay yintumu daryi. Ju̱denu niquejada ji̱ta jtay jiryatiy su̱teda rivasiy yityamu: “Rañi bay caserdótevyeda nutyityu̱ju̱ni̱ radyenu ni̱tiy vichasara sami̱ ti̱ta̱ju̱ rundamu, ne juuchati̱, mitya.” 
\c 8  
\s1 Jesús vichasara vuryi̱mu̱tyi̱si̱ Ju̱denu mo̱mu vurye̱ntyutyasa̱daju̱ 
\p  
\v 1-2 Vuryi̱tay jirya datyadodata jiryatiy savichasara Jesús vuryeyada rá̱ñu, ni̱tiy ma̱sasara santyityudamyu Vu̱jye̱ jaryiñu̱, jarichumu, jasityi sivaachara Ju̱denumu vuryeyadaju̱, si̱tenu Ju̱denu vichajomu jiryatiy saroriiyada yajiju̱ra, ne nijya̱mi̱ jomututa jvaachara dárya.  
\v 3 Darya sabayada Ju̱denu rirya̱jnutatya caserdótevyedara sa̱chara Ju̱denunijyu̱, rirya̱jvaryi jasi̱veda sanijyu̱ntiy, daryadantyi sa̱ma̱ jnutatya vu̱cyaserdóte nutyityu̱ra tara Ju̱denunijyu̱, vuryeyadaju̱.  
\v 4 Saryityi vichasara jirya mucadincha, ne saryi vicha caserdóte, mitya, jiryatiy jasiñuma riy caserdótevyeda bachavay raju̱, rirya̱tidye jnutatyasarara sa̱chara Ju̱denunijyu̱ su̱tedamusiy.  
\v 5 Riñi̱ ji̱ta jvaachara Ju̱denunijyu̱ nu̱tyu mitya jantyasara, nu̱tyu Jesús jvaarya jnutu nta, jiryatiy jarichumura. Daryani̱ su̱teda Ju̱denu ta̱riy siva Muyisésibe saroriiryu̱yadanumatiy donajatyara roriy Ju̱denujiju̱: 
\q1 “Jatyi yivaachara darya ti̱ta̱ju̱ nu̱tyu ra̱ntyasara jiryatiy radyityadosiy musiquincha jíírya.” 
\p  
\v 6 Vu̱dyi ji̱ta siva Jesús jiryatiy sasaryera samiy jvaayadava̱ju̱ ruumusiy caserdótevyeda, daryasa̱ra̱ju̱ ravichasara samivya̱ju̱ Ju̱denu niquejadantiy, ramusityi sivaachara Jesús vuryeyadaju̱, ramusintyi saniquejada jiryatiy su̱teda Muyisésibemyusirya. Jirya saniquejada samivya̱ju̱ dárya, jiryatiy su̱teda yityamuju̱ra.  
\v 7 Netimyu̱ ne rani su̱tyeda tara munatya saniquejada, jiryatiy Muyisésibemyusirya, ne saryi va̱ta̱da tara niquejadana̱cho̱ ru̱bivaju̱.  
\v 8-12 Sadityadoda Ju̱denura rasu̱tyeryá jiryatiy su̱teda: 
\q1 “Ri̱tay si̱tenu jiryiva: Ra̱jti̱ rarunda jasityi ra̱jto̱tanirya vadi niquejada rusa̱ju̱ Irayénuveda, ti̱ta̱ju̱ jiryatiy judíyuveda daryi. Ne ra̱cha variy nu̱tyu rañiquejada jiryatiy ri̱teda rusa̱ju̱ rarundamu varityi ramyuteda Ejíptu mucadimusiryi. Jiryatimyu̱ ne rityuva̱churu̱yada daryaju̱ rañiquejadamu variy, rañi jiintye rirya̱jisiy variy, ri̱tay ji̱ta ray variy. Jiryatirya rañiquejada jiryatiy ra̱jtay rusa̱ju̱ Irayénuveda rarundavasirya: Ra̱numa barya rañiquejada rijechipiya̱jadamu, ra̱nu̱y variy rijechivyara. Ratyidye ra̱cha variy ru̱ndenuju̱, rityidye ra̱cha rañijya̱nvajyu̱ varintyidye. Ne rirya̱va̱ta datyadoda rityevay nu̱ñi ti̱quimusiy variy raynchiñu̱dayu, jiryatiy rirya̱datyasara ti̱ta̱ju̱ ray, deramimyusiy, ja̱myicha̱ra̱ju̱ ti̱ta̱ju̱. Ra̱jantyutya daryaju̱ va̱cha ruvaayadamusiyu, ne ra̱jachipityasarara rijyuuchuveda nu̱day, mitya.” 
\m Darya su̱teda Vu̱jye̱ Ju̱denu ta̱riy, jiñijya̱nvay nchiy.  
\v 13 Ta̱riy niquejadata sadityadodara munatya jiñiquejada, jiryatiy su̱teda: Ra̱jto̱tanirya vadi niquejada ru̱bivaju̱. Ratiy ra̱rimyityuutyityi, ra̱caratyityi variy ru̱sijyu̱. 
\c 9  
\s1 Ju̱denunijyu̱ jachipiya̱jo jiryatiy mucadinchara, rataryajo jiryatiy jarichunchantirya 
\p  
\v 1-2 Ravichanu̱yada ji̱ta su̱teda munatya jiñiquejadamu nu̱tyuramusiy riryi jachipiya̱sara nijya̱nvay sanijyu̱ Ju̱denu. Ravichanu̱yada sanijyu̱ jachipiya̱jo jiyu mucadinchantiy, jiryatiy riryoriiyada ra̱jiju̱ donajatyara. Munatya cuartu jiryatiy bimu na̱cho̱sirya, ru̱tachara Ju̱denuju̱ jiintyasarára jasityi ravichanu̱yada no̱no̱siichuma, mi̱sa jarye, ranchatiy ribeñu̱yadara pa̱ Ju̱denu diya.  
\v 3 Munatya cuartu jiyadaju̱ ravichanu̱yada ratarya cuartuntiy, mutanujay jiyada, jiryatiy ru̱tachara jaryi samiryava̱ju̱ Ju̱denu jtedamuju̱ra.  
\v 4 Jasiñi̱ ravichanu̱yada vu̱rudi juru rupajyo, órutera, jadchintyi rasasi jiryatiy Ju̱denu niquejadajiju̱ra, jiryatiy órujatya mutanusarára. Ravimu ji̱ta ravichanu̱yada jiimo̱, órutera, jiryatiy Ju̱denu paji vichanu̱yada ravimu, jadchintyi Arú̱bay ruvese jiryatiy radipuvesubeda rajii, jadchintyi ravichu̱ padyejyu̱y jarye, jasityi nu̱charara Ju̱denu niquejada siva.  
\v 5 Rasasi mutaduyncha nanuvicha̱da danu̱ju̱y jantyasanu̱jyu̱y, Ju̱denu tuunu vichanu̱y jantyasanu̱jyu̱y. Nanunipya̱ canuvu̱nura ramutaduy jiryatiy ru̱tachara Ju̱denu jantyutyajora. Ne vana̱y vuryeriryi̱ tu̱chodara tara diye ranchintyi. 
\p  
\v 6 Jiryatiy ravichanu̱yada darya Ju̱denu roriy, caserdótevyeda jaya̱nu̱yada japichiy munatya cuartuvimu, rirya̱tidye jvaacharara yivaayada Ju̱denunijyu̱.  
\v 7 Vinu caserdóte nutyityu̱ ji̱ta jayada ratarya cuartuvimu taraquiju̱ nu̱ñi tanijya̱quimusiy. Ne saryijeyada netimyu̱ ne saryi jtoda yisa̱ra jasi̱ nudaja̱, jiryatiy su̱ntatya̱da jijyuuchuveda murichiryara, nijya̱nvay juuchuveda murichirya jarye ti̱ta̱ju̱, jiryatiy rijyuuchuveda jidyetyi̱sa̱damu.  
\v 8 Sadityadoda ji̱ta Ju̱denu Jnutu ramusirya jiryatimyu̱ ne jayadaju̱ jasiy didye Ju̱denuju̱ jiintyajovimuju̱, varimyuju̱timyu̱ ne raso̱vacha̱da munatya cuartu jadchiy didyeyu.  
\v 9 Rani̱ ji̱ta vichasara dityanuta̱ diye rundaju̱ day, vurya̱tidye datya nijya̱nvanchiy: Rityi jnutatyasarára sa̱chara Ju̱denunijyu̱, ru̱vacharani̱ jasi̱ sanijyu̱ntiy, ne vana̱y nta ruti̱sara samiy jvadichavay ramusiy Ju̱denu tuunuju̱.  
\v 10 Ruvaayada ji̱tara jiryatiy ru̱ntatya̱da sanijyu̱ra jmyichara varimyata jatusara, varimyata jiryatiy richuuta̱da sa̱jiju̱yu, ruvaayada Ju̱denu jtedamu vinu saratyadoda runda sa̱ra̱ju̱. 
\p  
\v 11 Samu̱ti̱jadanumatiy Crístu nu̱tyu caserdóte nutyityu̱ vuryeyadaju̱, samiryava̱ju̱ vichasa̱dajiju̱ ti̱ta̱ju̱, samu̱ti̱jada Jijye̱ rorimyu jiryatiy jaryi samiryava̱ju̱ ti̱ta̱ju̱ taramusirya, jiryatimyu̱ ne jomututa jvaachara darya, dantyamu̱y ne jirya mucadimu ju̱desarara.  
\v 12 Sajamya̱ ju̱na̱reju̱ Ju̱denuju̱ jiintyajomuju̱. Ne su̱toda yisa̱ra jasi̱ nudaja̱, nu̱tyu voca nudaja̱, ne vinu carni̱ru nudaja̱. Su̱toda ji̱ta darya vinu yindaja̱ day, ratatiy sasaryeda ju̱na̱reju̱ra vurye̱ntyutya̱da.  
\v 13 Ta̱riy ripyu̱yada nijya̱nvay juuchatavay jimyi̱dodivasiyu, jiryatiy ru̱rejada caserdótevyedara carni̱ru nudaja̱ ruuva, ¡ra̱, ra̱, ra̱! ne vinu voca vanu nudaja̱ta, sadetu rupachi̱ pupujuruja̱ta jarye risa̱ju̱.  
\v 14 Ta̱ jaryivya̱ju̱ ra̱pu̱chara Crístu nudaja̱ vu̱jyuuchuvedivasivyu̱y, jiryatiy su̱ntatya̱da Ju̱denu ju̱na̱reju̱ vichi̱ jnutumusiyu. Su̱ntatya̱da Crístu ne juuchati̱ Ju̱denumuju̱yu, sa̱tidye pu̱rya vu̱jechipiya̱jada Ju̱denunijyu̱, va̱cha jvaayada jachipityaja̱jadajisiy, vurya̱tidye vichasara sanijyu̱ Vu̱jye̱ ju̱na̱reju̱ vichi̱. 
\p  
\v 15 Ramuni̱ savichasara Crístu vuryeyada rá̱ñu Ju̱denu tuunu, vadira Ju̱denu niquejada jto̱tadedaju̱. Jiryatiy sabatyeda vurye̱ntyutyasa̱daju̱, sapu̱chara variy vuryivasirya vu̱jyuuchuveda ti̱ta̱ju̱, jiryatiy vu̱jyuuchuvay munatya Ju̱denu niquejada jiyaro̱ju̱, jiryatiy Muyisésibemyusirya, vurya̱tidye jmutya̱sarara vuryeyaru̱rya ti̱ta̱ju̱, jiryatiy su̱teda Ju̱denu ya̱sa̱y jiñatuvyerya.  
\v 16 Vurya̱tidye jmutya̱ra vuryeyaru̱rya jiryatiy vu̱jye̱be barya ma̱cho̱rara, vurya̱datya samiy munatya si̱tenuni̱viy sadiimya̱.  
\v 17 Jiryatiy sabayada ti̱ra darya vicha̱da, vu̱ryi jmutya̱ dyetya su̱bivara jiberya, ne vana̱y vuryi̱mutya̱ra netimyu̱ ne sadiiy raja̱mi̱ didye.  
\v 18-19 Ramuni̱timyu̱ ne sabayada Ju̱denu munatyara jiñiquejada nudaja̱jsá̱, sireda ji̱ta Muyisésibe daryaju̱ra múrejii, sapuchodara carni̱ru jasicho variy rí̱dcha, jiryatiy ruuna̱tya muchanusarára. Jadchiy ji̱tantiy saparodeda ja̱a̱múra, jiryatiy vocadenu nudaja̱ta jaryenusara darya, carni̱ru nudaja̱ jarye risa̱ju̱, sa̱tidye ju̱re varirya nudaja̱ raniy, Ju̱denu niquejada padye, nijya̱nvañe̱cho̱ju̱ jarye.  
\v 20 Su̱teda Muyisésibe variy yivaayadamu: 
\q1 “Jiryatirya nudaja̱ jiryatiy su̱teda Ju̱denu vurya̱rumirya, ratatiy vuryito̱tanirya saniquejada vurye̱ntyutyasa̱daju̱.” 
\m  
\v 21 Daryaday su̱rera nudaja̱ riva Ju̱denu rorintyi, ti̱ta̱ju̱ ruvaatya̱va jarye, jiryatiy ruvaatyasara caserdótevyeda Ju̱denunijyu̱ra.  
\v 22 Ju̱denu jtedamusiy ji̱ta riryi pu̱chara ti̱ta̱ju̱nubesiy nudaja̱tara. Nuda rubedajisiy ji̱ta ne vana̱y saramityaniy Ju̱denu vuryivara vu̱jyuuchuveda. 
\s1 Crístu batyeda vu̱jyuuchuveda pu̱cha̱da jiyadaju̱ 
\p  
\v 23 Riryityi pu̱ryu̱chara nudaja̱tara jirya Ju̱denu vichajo jantyasara, jirya ji̱ta jiryatiy jarichuvimu bachara vichajoju̱ darya, rava̱tasara jaryivya̱ju̱ra pu̱tya̱ jiryamusiy.  
\v 24 Tapitya sajayada Crístu ravimu Ju̱denuju̱ jiintyasajo, jiryatiy jomututa jvaachara darya, jiryatiy vinu mitya jantyasara darya. Sajayada ji̱ta si̱tenu Ju̱denu vichajovimu, jiryatiy jarichuvimu darya, jasityi samu̱ti̱sara Ju̱denu tuunu vuryeyadaju̱.  
\v 25 Dantyamu̱y ne sajajeya̱sara Crístu japichiy nu̱tyu jnutatyasi̱ Jijye̱myuyu, nu̱tyu caserdótevyeda nutyityu̱mityi jaachara nu̱ñi tanijya̱quimusiy Ju̱denuju̱ jiintyajovimuju̱ day, rirya̱tidye jnutatyara nudaja̱ jiryatimyu̱ ne rindaja̱ darya.  
\v 26 Raryityi vicha̱da daryá, saryiñi diijeya̱ japichiy mucadi ju̱desa̱damusiy. Nu̱ye ji̱ta, mucadi baryi̱ru̱yada rundamu, samu̱ti̱ma̱ taraquiju̱, sa̱tidye parutara juuchuveda jibetyedamusiy.  
\v 27-28 Daryatiy sabayada Ju̱denu nijya̱nvajyu̱ntirya taraquiju̱ diiyadantiy, sa̱murichenutanichara rivasiy vuryivaayada murichirya vu̱y, daryaday savichasara Crístu jnutatyasi̱ jidyiiyadivasintyi, sa̱tidye pu̱chicharara rajuuvay juuchuveda. Sa̱day mu̱ti̱ daraju̱jyu̱ juuchajsa̱ntiy, jivyejyu̱ jiryatiy rintuyanumucha sa̱jiju̱ jirye̱ntyutyasa̱daju̱. 
\c 10  
\p  
\v 1 Ju̱denu jteda ji̱ta jiryatiy Muyisésibemyusirya, vinu samiy vichasa̱da jnutu day jiryatiy jativyenumara. Ne ravichanu̱yada si̱tenu vichasa̱da jiryatiy sabachara vurya̱jiju̱ra. Dañuma riñi jnutatyajaya̱ caserdótevyeda nijya̱nvajyuu jiyadaju̱ni̱ jasi̱ jvachi̱, Ju̱denunijyu̱, tama̱ vana̱y jto̱tanivye rivyichasara samivye, tama̱, rityi rañi tuudiya̱sara ratani̱ Ju̱denu.  
\v 2 Raryityi jto̱tadeda ru̱ntatya̱dara rivyichasa̱da samivyejyu̱, riryi paru̱yada riva jasi̱ jvachi̱ jnutatya̱da variy, jiryatiy riryi ma̱cho̱ variy pu̱chavay, ne riryi jachipiya̱ jiyasachavay variñu̱dayu.  
\v 3-4 Jivye jasi̱ ji̱ta jiryatiy Ju̱denunijyu̱ jvachavaryi, rañi jachipityataniy nu̱ñi tanijya̱quimusiryi nijya̱nvay rijyuuchuvedanchiy, jiryatimyu̱ ne vana̱y rapu̱y voca nudaja̱ra vu̱jyuuchuveda vuryivasiy, dantyamu̱y ne carni̱ru nudaja̱. 
\p  
\v 5-7 Ramuni̱tiy siti̱jadanumatiy Crístu jirya mucadimu, su̱teda siva jijye̱ variy: 
\q1 “Jivya̱tasaratyara jasi̱ jvachi̱ jnutatyasa̱da yiva. Yindejadara nijya̱mi̱vu̱ ra̱jiju̱ ramusityi ra̱siityee jiijyu̱. Samiy jvadicharavitya jidyiya daryaju̱ra jiryatiy ru̱ntatyasara nijya̱nvay jiñijyu̱ni̱ jasi̱ jvachi̱, jiryatiy riryupeda yichana̱tya̱damu jiñijyu̱ni̱, varimyata rijyuuchuveda murichiryaju̱. Ri̱tachara variy yiva: Ya̱jnu̱y Ye̱ye̱, riti̱ma̱ ra̱tidye jvaarya jivya̱tara, darya nu̱charatiy catera padyevya raynchirya.” 
\m  
\v 8 Su̱teda Crístu munatya: 
\q1 “Jivya̱tasaratyara jasi̱ jvachi̱ jnutatyasa̱da yiva, daryantyamu̱y ne jiryatiy ru̱ntatyasara nijya̱nvay jiñijyu̱ni̱ jasi̱ jvachi̱, jiryatiy riryupeda yichana̱tya̱damu jiñijyu̱ni̱, varimyata rijyuuchuveda murichiryaju̱,” 
\m dañuma riñi jnutatyasara Ju̱denu jtedamuju̱ra.  
\v 9 Rivasiy ji̱ta su̱teda Crístuntiy: 
\q1 “Ya̱jnu̱y Ye̱ye̱, riti̱ma̱ ra̱tidye jvaarya jivya̱tara.” 
\m Jirya saniquejadata jipyaruta̱dara munatya Ju̱denu jteda jasi̱ jvachi̱nchiy, sa̱tidye jnutatya ru̱bivaju̱yu.  
\v 10 Variñi̱ ji̱ta Ju̱denu va̱ta̱damu vu̱vyichasara jiintyasavay saju̱, Jesucrístu batyedata, jiryatiy su̱ntatyama̱ Ju̱denunijyu̱ra jivyu̱. 
\p  
\v 11 Ju̱denu jtedamusiy riryaniñu̱yada caserdótevyeda sanijyu̱ jvaavye, jiryatiy ru̱ntatyajaya̱sara japichiy Ju̱denunijyu̱ riy jasi̱veda jvachavay jiryatimyu̱ ne vana̱y raso̱vacheda ruuvasirya jijyuuchuveda.  
\v 12 Jesús ji̱ta, su̱ntatya̱danumatiy Ju̱denunijyu̱ra jivyu̱, ti̱ta̱ju̱ vu̱jyuuchuveda murichirya, sama̱sa̱da variy Ju̱denu nutyityudamyuju̱.  
\v 13 Jadchiy ji̱ta santuy ra̱jiju̱ jiryatiy sa̱bay Ju̱denu sanumutujare riy jimyityasimyi.  
\v 14 Taraqui su̱ntatya̱data daryaju̱ yito̱tanimyu̱rya vu̱jiintyasa̱da Ju̱denuju̱. 
\p  
\v 15 Satu̱chusara vijyo̱mujache Ju̱denu Jnutu vuryivantiy jiryatiy su̱teda: 
\q1  
\v 16 “Jiryatirya rañiquejada jiryatiy ra̱jtay rivasiy rusa̱ju̱ra. Ra̱numa barya rañiquejada rijechimyu, ra̱nu̱y variy rijechipiya̱jadamura.” 
\m  
\v 17 Su̱teda jadchintyi: 
\q1 “Ne ra̱jachipityasarara rijyuuchuveda nu̱day, mitya, dantyamu̱y ne ruvaayada jiryatiy rañiquejada jiyaro̱ju̱ra.” 
\m  
\v 18 Jiryatiy saramityanimya̱ Ju̱denu vuryivara vu̱jyuuchuveda, vuryivaayada jarye, jiryatiy saniquejada jiyaro̱ju̱ra, ne vu̱vya̱ta Ju̱denunijyu̱ nu̱ndyerya vu̱jyuuchuveda murichirya jnutatya̱da nu̱day, mitya. 
\s1 Vu̱ryi tuudiye̱ñi̱ Ju̱denu 
\p  
\v 19 Ramuni̱tiy, ratyeryi̱veda, vurya̱numa jay vu̱chuvu̱yasa̱damu Ju̱denu jiintyasájomuju̱, jiryatiy sarubeda Jesúsra yindaja̱ vuryeyadaju̱.  
\v 20 Samuttasara daryaju̱ vu̱jyu̱ra vadi jajyo jiryatiy jnu̱rya darya, tapi ni̱ni̱ sani̱cha vu̱jejyo, jiryatiy setasara daryaju̱ra savu̱ nu̱tyu mutanujay, jiryatiy Ju̱denu mo̱ jiyada vicharára, vurya̱tidye ju̱ti̱ simuju̱.  
\v 21-22 Jiryatiy ni̱ni̱ sani̱cha nijya̱nvay jiyada rá̱ñu, jiryatiy sansu̱chara jaryiñu̱ nta Ju̱denu rorimyu, vurya̱numa tuudiye̱ samirya jachityavañi̱ Ju̱denu. Vurya̱numa jachipiya̱ vu̱chuvu̱yasa̱damu sanijyu̱, jiryatiy pu̱charanuma jiyasayadajisiy ti̱ta̱ju̱ra vu̱jechipiya̱jada, nu̱tyu vu̱vyu̱ jarye suutasara nta vandaja̱ta, vuryi̱tyu̱yadata.  
\v 23 Vurya̱numa ju̱riy surravarya vu̱tyu̱choda Ju̱denu jiyadaju̱, jiryatiy vu̱yntuchara sa̱jiju̱, ne siquityaja̱ra vu̱jechipiya̱jada sanchiy, ni̱ni̱ ji̱ta ra̱jto̱tanichara daryaju̱ra yiteda vuryeyadaju̱ day.  
\v 24 Vurya̱numa jachipiya̱ vu̱ñijyu̱: nu̱tyuramusiy vu̱ryi jo̱ta va̱ta̱da vu̱y, nu̱tyuramusiy, samiy jvaayada jarye risa̱ju̱.  
\v 25 Ne vu̱ryi paru̱y riva vu̱yntye̱ryadeda vu̱y, nu̱tyu tavatyi paru̱chara riva. Vurya̱numa vanu̱tya jaryivya̱ju̱ nu̱ñi ti̱quimusivyu̱y, jiryatiy vu̱dyi riva tamitya runda tuudiye̱yada. 
\p  
\v 26 Vuryi̱mutya̱jadanumatirya datya̱da si̱tenu Ju̱denu niquejadanchiy, vu̱ryityi jiriryi̱ra juuchuveda vu̱dyetya̱damu variy, ne tara ju̱na̱y tara jadchiñu̱day ta̱ramusitya sa̱ramityaniy Ju̱denura vu̱jyuuchuveda ju̱na̱y jadchiñu̱dantyi.  
\v 27 Vurya̱day nutuy ji̱ta vu̱chuvu̱yadanube variy ra̱jiju̱ Ju̱denu murichenutadeda, jiryatiy sa̱ca̱siryu̱y jijiidatya riy jimyityasimyi.  
\v 28 Nijya̱mi̱ ji̱ta, ni̱tiy raryi rrachodara Ju̱denu niquejada jiryatiy Muyisésibemyusirya, ni̱ni̱ diiyada jantyutyasi̱sá̱ ru̱co̱siy nanutu̱chuta̱danumatiy danu̱ju̱y nijya̱mi̱ju̱ñi̱, varimyata mu̱nvamyusiy.  
\v 29 Ta̱ jaryivya̱ju̱ murichenutadeda saryi jmutya̱ dyetya nijya̱mi̱ ni̱tiy raniye̱ nta mucadinubeju̱ni̱ Ju̱denu denu, sa̱viryu̱tya varirya Crístu nudaja̱ ratatiy sani̱cha̱da jiintyasi̱ Ju̱denuju̱. Sa̱vityiye̱ daryamusiñi̱ Ju̱denu Jnutu jiryatiy sani jmu̱tyaru̱ñi̱.  
\v 30 Vu̱dyetya ji̱ta daryaju̱ni̱ Ju̱denu jiryatiy su̱teda: 
\q1 “Rajyu̱numa ra̱cha murichenutadeda jto̱tadeda day, rañuma ra̱murichenutanicharara.” 
\m Jadchintyi su̱tedantiy: 
\q1 “Sa̱saranusara Vu̱yntyityu̱ra jiñijya̱nvay murichenutanicha̱da.” 
\m  
\v 31 Suvu̱chara ji̱ta ju̱u̱yada ju̱na̱reju̱ vichi̱ Ju̱denu jomu. 
\p  
\v 32 Jirya̱ma̱ jachipityara jivyicha̱da rano̱no̱nu̱ñumatiy Ju̱denu datyadoda jirye, jiryatiy jiryejechi̱nitya̱da jantyuramusirya totiyadasumarya.  
\v 33-34 Jiryevyichanu̱yada vijyo̱mujache javittyuchavay, jiyasantasavay jarye risa̱ju̱, jadchintyi jiryepyaru̱tyajaya̱ rusa̱ darya vichanichavayu, jiryatiy jirye̱ntyutya̱da riy tanuvu̱nusavay, jiryedyiryejada yichana̱yadamura jiryeberya paranusa̱da, jiryedyetya̱da daryaju̱ jivyichasara taratavay, jiryatiy samiryava̱ju̱ darya, suru̱yada jachara jarye risa̱ju̱ra.  
\v 35 Ramuni̱tiy ne jirya̱jatya yajisirya jichuvu̱yasa̱da, jiryatiy ja̱mura murichevarya daryaju̱ darya.  
\v 36 Jiryevya̱ta daryaju̱ra tapimusiy jachi̱deda, jirya̱numatiy jvaarya Ju̱denu va̱ta̱da, jirya̱jmutya̱ varirya jiryatiy su̱teda ya̱sa̱y jiryerya.  
\v 37 Tapi vani̱ra jaryuve sa̱day jniy ni̱tiy ra̱jniy, ne sa̱riche.  
\v 38 Jiryatiy rimu tuva̱chu̱ni̱, ri̱tachara variy sami̱ ni̱, sa̱jnu̱jeya̱sara ju̱na̱re variy. Saryityi dutyaru̱y jichuvu̱yadamuyu, ne samiy jvadichi̱ saryicha variy rajyu̱.  
\v 39 Vu̱y ji̱tamu̱y ne siityejada vu̱ryudivaju̱ vu̱pyarutasa̱damuju̱, vu̱tyuva̱choda ji̱ta vu̱beyanu ramityadedaju̱. 
\c 11  
\s1 Ju̱denumu tuva̱choda 
\p  
\v 1 Simu tuva̱chodamusiy ji̱ta vu̱dyetya sa̱jto̱taniy Ju̱denura jiryatiy vu̱yntuy ra̱jiju̱, vu̱dyetya ji̱ta ravichasara, jiryatimyu̱ ne vu̱dyiryu̱y nta riva didye.  
\v 2 Simu tuva̱chodamusiy ji̱ta rivyichanu̱yada vu̱myunatyavabe samiy jvadichavay Ju̱denu diya. 
\p  
\v 3 Ju̱denumu tuva̱chodamusiy vu̱dyetya ru̱ndayada ju̱desara ti̱ta̱ju̱ su̱tedamuju̱. Ti̱ta̱ju̱ jiryatiy vu̱dyi diye sa̱ra̱ju̱ riva, ne ru̱ndayada ramusiy jiryatiy vu̱dyichara riva. 
\p  
\v 4 Ju̱denumu tuva̱chodamusiy ji̱ta, su̱ntatya̱da Abénubañi̱ jasi̱ jvachi̱ Ju̱denunijyu̱, jiryatiy samiryava̱ju̱ Cayí̱bay jnutatyasaramusirya. Satuva̱chodiva su̱teda Ju̱denu sami̱yu, sasa̱ryá jiyadaju̱. Ju̱denumu tuva̱chodamusiy, dañuma sani̱cha diiñu Abénu, saniquesara diye sa̱ra̱ju̱ vuryiva. 
\p  
\v 5 Simu tuva̱chodamusiy jijya̱ta̱da Ju̱denu na̱vajyu̱ni̱ Enócu, jiryatimyu̱ ne diiñu saya̱da day. Ne richeryeda ju̱na̱ñu̱nñi̱, jiryatiy saja̱ta̱dama̱ Ju̱denu daryaju̱ yimuju̱ dañi̱. Saja̱tasa̱dajisiy ji̱ta rityu̱choda Enócunchiy: “Ni̱ni̱ sani̱cha samiy jvadichi̱ Ju̱denuju̱.”  
\v 6 Netimyu̱ ne vu̱tyuva̱chusara simu Ju̱denu, ne vana̱y nta vuryi̱chana̱chu variñi̱, tapi ni̱tiy tuudiye̱ryu̱ñi̱ Ju̱denu, saryi tuva̱chu munatya sanchiy: “Si̱tenu savichasara Vuryi̱ndenu, ni̱ni̱ ji̱ta datya murichedoda riy jiryatiy rivya̱tasara sana̱cho̱.” 
\p  
\v 7 Ju̱denumu tuva̱chodamusiy savicha̱da Novébay siityera. Su̱vatanutadedanumatiy Ju̱denu ni̱ Novébay ranchiy, jiryatimyu̱ ne ridyetya̱da nijya̱nvay didyerya, sivaayadara cartyequiisuma rirya̱jiju̱ yisa̱ vichavay, riryamityajoju̱. Ju̱denumu tuva̱chodamusiy sadityadoda Novébarya rivyicha̱da mucadiva vichavay tuva̱chu̱sa̱miy, savicha̱da Novébay variy Ju̱denu jteda jmutya̱nu, jiryatiy su̱teda sami̱ satuva̱chodivayu. 
\p  
\v 8 Jadchintyi Avurá̱bay tuva̱choda simu Ju̱denu sanatuyadanumatiñi̱ sa̱tidye sipyatay tamucadimuju̱, jiryatiy saryi jmutya̱ jivyichajoju̱ra. Sasipyateda ji̱ta ne sadatya̱da tera rayácu̱. 
\p  
\v 9 Ju̱denumu tuva̱chodamusiy sasu̱ta̱ñumaya̱jada tara mucadiva jiryatiy Ju̱denu jtedamuju̱ra, nu̱tyu ma̱myi mucadimu nta savicha̱da jasiy. Savichanu̱yada su̱ta̱myu sisa̱ jidyenu Isácubay, sa̱si̱ Jacóbubay jarye, jiryatiy su̱teda Ju̱denu sivantiy: “Rache̱y jiirya mucadi jivyichajoju̱, jidyedyeñu vichajoju̱ jarye.”  
\v 10 Avurá̱bay ji̱ta daryaju̱ nutuyada ra̱jiju̱ ja̱mu vicha̱da suru̱yasara, jiryatiy Ju̱denu ju̱derára, sivaayada jarye risa̱ju̱ra. 
\p  
\v 11 Ju̱denumu tuva̱chodamusiy sadetuchoda Avurá̱bañi̱ jivyatura suru̱tyu, Sára jtyati̱bay, dañuma sani ramimya̱ra jiñijya̱ detuyadaju̱, tapi jidyetya̱da jto̱tanirya sani̱cha Ju̱denu jiryatiy su̱teda: “Sa̱day detuy jivyatura Sára jidyenuju̱.”  
\v 12 Ramuni̱ ti̱qui vanumusiy, jiryatiy savichanu̱yada nu̱tyu diiñu nta, ripyi̱ru̱yada rajuuvay simusiy, nu̱tyu jdarichijyuutiy jarichumu, ti̱cha̱juru jarye, jiryatimyu̱ ne vana̱y saranumu̱yadasa̱rá̱ra. 
\p  
\v 13 Ridyiimyu̱yada ji̱ta jivyejyuu ti̱ta̱ju̱, netimyu̱ ne ru̱mutya̱jadara Ju̱denu jteda jiyadaju̱ didye. Mitya ridyiyadá ripyasiy riva, ridyiryejada varirya, ru̱teda vijyo̱mujache variy yiva: “Nu̱tyu ma̱myi vu̱vyicha mitya vu̱taya̱vay jirya mucadincha.”  
\v 14 Jiryatiy ru̱tedara darya niquejada, ridyetyatadeda ramusivyu̱y, jiryatiy riñi va̱tanu̱yada rana̱cho̱ mucadi, jasityi riñi jtachara ye̱chasara.  
\v 15 Riryityi jachipitya̱dara jimyucadi jadchityi richipyateda, riryi ta̱ryaru̱yada dyetya variy yibivaju̱ntiy.  
\v 16 Nu̱ye ji̱ta, rivya̱ta̱numucha rana̱cho̱ samiy mucadi jiryatiy jarichumura. Ramuni̱timyu̱ ne sa̱dasara Ju̱denu jiryatiy ru̱tachara: “Ni̱ni̱ sani̱cha Vuryi̱ndenu.” Su̱dutya̱da daryaju̱ra ja̱mu vicha̱da rirya̱jiju̱. 
\p  
\v 17 Ju̱denumu tuva̱chodamusiy Avurá̱bay jnutatya̱dani̱ jidyenu Isácubay sanijyu̱, sa̱ntya̱danumatiy Ju̱denuni̱. Su̱ntatyanu̱yadani̱ jidyenu vinu ti̱qui, sanchityi su̱teda Ju̱denu siva: 
\q1  
\v 18 “Isácumusivye ji̱ta rirya̱jtachara jidyedyeñu.” 
\m  
\v 19 Sajachipiya̱jada Avurá̱bay daryaju̱: “Sani mi̱saniryu̱y Ju̱denuni̱ diibyi,” daryantani̱ ji̱ta su̱mutya̱jada ntani̱ jidyenu diiyadamusiy. 
\p  
\v 20 Ju̱denumu tuva̱chodamusiy ji̱ta Isácubay jteda samiy Ju̱denu jtyamu nadayadaju̱ jidyenuju̱y Jacóbubay, Esavúbatya, nu̱tyura nana̱cha. 
\p  
\v 21 Ju̱denumu tuva̱chodamusintyi Jacóbubay jteda jidyiitya̱ju̱ samiy Ju̱denu jtyamu nadayadaju̱ Jusíbe denuju̱be. Sajachipiya̱jada Ju̱denunijyu̱ variy jiryatiy sabutyajayada Ju̱denumuyu, sabutyajayada jiryuvese jchayu.  
\v 22 Ju̱denumu tuva̱chodamusiy Jusíbe jachipitya̱da jidyiiryu̱yadamura jidyedyeñu sipyateda Ejíptumusiy, su̱teda variy ruuva: “Jirya̱ma̱ pu̱chichara yisa̱ra radyuumiy.” 
\p  
\v 23 Ju̱denumu tuva̱chodamusiy sadutya̱da saja̱be vu̱ryupi̱de Muyisésibeyu, mumutumiy jarimyuni̱ sa̱ra̱ju̱ sadutya̱dani̱. Jiryatiy nanudiyada daryaju̱ jaryi sami̱de siva jidyenu, ne nanusuvu̱yadara ja̱mu nutyityu̱bay jteda jiryatiy su̱teda judíyuvedava: “Jirya̱ma̱ jatya ja̱a̱mu riy vadirupavye jiryatiy vadudyeryi.” 
\p  
\v 24 Ju̱denumu tuva̱chodamusiy, ja̱ñumatiy savicha̱da Muyisésibe, sarrachodara jiryatiy ru̱teda nijya̱nvay ja̱mu nutyityu̱bay jasi̱ sani̱cha.  
\v 25 Sajaryeta̱dara paru̱cha̱riy vichanicha̱da rusa̱ju̱ Ju̱denu nijya̱nvay, ramusiy jiryatiy taraquiju̱ sa̱jcanurya samiy vichasa̱da juuchuvedanube.  
\v 26 Sajachipiya̱jada ji̱ta: “Ra̱day vichasara jaryi tarati̱va̱ju̱ jiryatiy ravyichasara javiryu̱tyasi̱ nu̱tyu Ju̱denu jaryeti̱ nta, ramusiy raryityi jmutya̱ra Ejíptu ja̱mu nutyityu̱ barya ratyi rañi̱cha sa̱si̱ víchi̱.” Su̱nu̱ñu̱yada Muyisésibe daryaju̱ rana̱cho̱ Ju̱denu murichedoda yivaayada murichirya. 
\p  
\v 27 Ju̱denumu tuva̱chodamusiy sasipyateda Muyisésibe suvu̱yasa̱ Ejíptumusiy dañuma sani nique̱yada ja̱mu nutyityu̱bay ranchiy. Sajachi̱deda variyu, nu̱tyi sadiyada nta siva Ju̱denu jiryatimyu̱ ne vana̱y jvadichi̱ ntani̱. 
\p  
\v 28 Ju̱denumu tuva̱chodamusiy ji̱ta sabayadara Pasco vichtya, jasityi sadatyadoda riy nijya̱nvay: “Jirya̱ma̱ ju̱rera carni̱ru nudaja̱ rorijyu̱davya, sañuma jvay nijya̱nvay parutarani̱ jityevay denu jiryatiy munatya rupi̱ni̱.” 
\p  
\v 29 Ju̱denumu tuva̱chodamusiy ji̱ta rityiryo̱ri̱jada Irayénuvedabay ja̱mu na̱vata̱savumú, nu̱tyu siinu nta ravicha̱da rirya̱jiju̱. Ejíptu ja̱nvabe ji̱ta jantya̱da tiryo̱ri̱jada ru̱sijyu̱ daryantidye, ti̱ta̱ju̱ni̱ rijemyu̱yada ja̱a̱mu day, pattaryi. 
\p  
\v 30 Ju̱denumu tuva̱chodamusiy raju̱u̱ya̱jada Jericó vicha̱da puryesiy, jiryatiy riryabeja̱jada Irayénuvedabay darundaju̱ñijyate sa̱ra̱ju̱ ru̱ro̱. 
\p  
\v 31 Ju̱denumu tuva̱chodamusiy ne nanuparuteda cadnatoda Raábijyu̱y jtyatanu̱be rusa̱ju̱ tuva̱chu̱sa̱mibe, jiryatiy sadiryejada daryaju̱ samiryi dichevye. 
\p  
\v 32 ¿Ta̱ra ra̱tu̱chu jadchintyi, ta̱ra? Runda ji̱ta raryi su̱tye daryaju̱ ra̱tidye tu̱chu sanchiy Jedeyó̱bay, varimyata Barácubay, Sansú̱bay, Jetébay, Davyíbe, Samí̱rubay, ti̱ta̱ju̱ jiryatiy Ju̱denuju̱ tu̱chuvaberyi. 
\p  
\v 33 Ju̱denumu tuva̱chodamusiy rivyuudoda nijya̱nvaberya nusu̱chajo, ruvaayada vasera, ri̱mutya̱jadara Ju̱denu jteda riyadaju̱, ratamumyu̱yada nibyijú̱yu, sañuma su̱y. 
\p  
\v 34 Ju̱denumu tuva̱chodamusiy riryícha̱dára jiiday quívaya̱ra, riryamitya̱dara jchityitya̱ta jveda, rivyanu̱tyadeda yidiva̱jadamusiyu, rivyichanu̱yada ja̱surya vanu̱vyebe jiryatiy ribecha̱da riy jimyityasimyijyuu. 
\p  
\v 35 Ju̱denumu tuva̱chodamusiy ru̱mutya̱jada vatuberyi jityevay diiyadamusiy mi̱sa̱sumivye, tavay ji̱ta rañi batyeda javatyasavay, jiryatiy rirrachodara ramityadeda, rirya̱tidye saryerya mi̱sa̱da jidyiiyadamusiy jiryatiy samiryava̱ju̱ darya.  
\v 36 Tavay jarye datyanu̱yadara javityiye̱yadamusiy jantyasara, musiye̱yada jarye, ridyetya̱dantirya tanuvu̱dodantiy, cadyidyaju̱u̱ta puchusa̱da jarye risa̱ju̱.  
\v 37 Ridyetya̱dantirya ravichu̱ta jachedantiy, rivyicha̱da ra̱chasavay siiryata, rivyicha̱da jantyasavay, jadchintyi jchityitya̱ta jvachavay, riryupiñumaya̱jada carni̱rujatyera sujatyavay, rivyichanu̱yada jantyuyadavay, paru̱chari̱myu vichavay jarye, jarupanusavay jarye risa̱ju̱riy.  
\v 38 Rivyichanu̱yada nijya̱nvabe samivya̱ju̱ ruumusiy jityevay mucadincha vichavabe. Rivyu̱taya̱jada mitya tova, musiquivantiy, rivyichajo ji̱ta mucadijaridye. 
\p  
\v 39-40 Jivye ti̱ta̱ju̱, dañuma rivyicha̱da samiy jvadichavay jityuva̱chodiva, ne riryichedara jiryatiy sani jteda Ju̱denu ya̱sa̱ryi, sajachipiya̱jada Ju̱denu daryaju̱ samivya̱ju̱ vu̱jyu̱ra, jiryatimyu̱ ne rirya̱jmutya̱mu̱y su̱tedamuju̱ra tara jiryatimyu̱ ne vurya̱jmutya̱ rusa̱ntidyerya. 
\c 12  
\s1 Vurya̱ntya jnu̱chara sana̱cho̱ Jesús 
\p  
\v 1 Jiryatiy vuryi̱ro̱ riy jivye rajuuvay tu̱chuvay Ju̱denumu tuva̱chodanchiy, ramuni̱tiy vurya̱ jiriryi̱ siicheda Ju̱denu nú̱va. Vu̱chiichedamu vurya̱ma̱ jatyachiy vuryimusirya ti̱ta̱ju̱ jiryatiy jiinra vuryimura, vu̱jyuuchuveda jarye jiryatiy raruparyu̱y vu̱ñiy, vurya̱tidye siichiy tapimusiy Ju̱denu nú̱va, jiryatiy sabay vu̱chiiyadaju̱ra.  
\v 2 Vurya̱ma̱ jnu̱y sana̱cho̱ju̱ Jesús ni̱tiy ju̱dejadara vu̱tyuva̱choda, sito̱tadeda varintyirya. Ni̱ni̱ ji̱ta jachi̱nitya̱dara crusitya̱sa batyeda, sa̱viryu̱tya̱da varirya riva jádasa̱da, jiryatiy sadatya̱da yajiju̱ra yichana̱yada, sama̱sa̱da variy Ju̱denu nutyityudamyuju̱.  
\v 3 Jirya̱ma̱ jachipiya̱ sanijyu̱ Jesús jiryatiy sajachi̱nitya̱da tapimusirya juuchatavay jiyaro̱doda, jiryeñuma jdiva̱, jiryeñuma paru̱ryu̱y riva jichiityari̱jada. 
\p  
\v 4 Ne jiryetyotiyada juuchuveda jcho̱ju̱ yindarubeda sa̱ra̱ju̱ didye.  
\v 5-6 Jiryejechipumya̱ vidyerya Ju̱denu niquejada day, jiryatiy su̱teda nu̱tyu jidyedyeñumiy jiryiva: 
\q1 “Pi̱pi̱veda, ne jirya̱rrachúra Vu̱yntyityu̱ vasedoda, dantyamu̱y ne jirya̱paru̱tya sanique̱tya̱damusiyu. Savasenusara Vu̱yntyityu̱ daryaju̱ riy ti̱ta̱ju̱ jivya̱tasavay, samusiye̱charani̱ ni̱tiy su̱mutya̱sara nu̱tyu jidyenuju̱.” 
\m  
\v 7 Jirya̱ma̱ jachi̱niy jivyasenusa̱damuyu, jiryatiy savichenichara Ju̱denu nu̱tyu jidyedyeñu jirye. ¿Mi̱ deramu̱y ne vasenusi̱ jijye̱myusiy, mi̱?  
\v 8 Netimyu̱ ne sa̱vasenusara Ju̱denu jirye nu̱tyu savasenusaratiryi jidyedyeñu vasevajyu̱ nu̱tyu ridyetyasaratiy ti̱ta̱ju̱ Ju̱denu dadyeñu, ne jirye̱cha variy si̱tenu sadadyeñu, jirye̱cha ji̱ta variy riicho dadyeñu day.  
\v 9 Vu̱ryityi tuva̱choda simu vu̱jye̱ jirya mucadimu vichi̱, ni̱tiy vasedoda vu̱y, vurya̱ma̱ saboniy jaryivya̱ju̱ saju̱ Vu̱jye̱ jarichumu vichi̱ vu̱y, vurya̱tidye jnu̱jeya̱sara variy ta̱rijyu̱.  
\v 10 Vu̱jye̱vyeda jiyu vichavay rañi vasedoda taraquideju̱ vu̱y, daryatiy samiy jvadichara ridyiyara. Vu̱jye̱ jarichumu vichi̱ ji̱ta rañi vasenu samiy vu̱vyicha̱daju̱ vu̱y, vurya̱tidye vichasara vu̱ñi̱ru̱yadamu juuchajsa̱ vatajuu sisa̱.  
\v 11 Diyedera vu̱dyi riva vasedoda nu̱tyu yivatya̱, rivasiy ji̱ta rajontachara samiy vichasa̱da vu̱jyu̱ jiryatiy vu̱dyetyatityi ramusiy. 
\s1 Vuryi̱nu̱tyata̱ta vu̱y vu̱ñuma rrachura Ju̱denu jantyutya̱da 
\p  
\v 12 Vu̱ryityi paru̱ryu̱y riva Ju̱denu nú̱va rupiyada, vurya̱ma̱ vanu̱tyaniy ju̱na̱ntyirya vu̱jyomutu so̱taryi̱rantiy, vu̱dyuse jdiva̱jnura jarye risa̱ju̱.  
\v 13 Vurya̱ma̱ ma̱ntya vase nú̱ vurya̱jiju̱ vu̱ñuma tadityaniy riva vu̱y, vu̱tye̱ryo̱ ji̱ta vuryi̱bivaju̱ varintyi vu̱tyuva̱chodamu. 
\p  
\v 14 Vurya̱ma̱ jiryiri̱ra samiy vichasa̱da rusa̱ nijya̱nvay ti̱ta̱ju̱, vurya̱ma̱ jantyasara jiintya̱da Ju̱denuju̱ vu̱y, jiryatimyu̱ ne vana̱y ti̱ dichara siva, jiryatimyu̱ ne savichasara jiintyi̱ saju̱.  
\v 15 Vu̱ryi jnu̱tya dyetya vu̱y, vu̱ñuma su̱tye Ju̱denu jantyutya̱damusiy. Vu̱ryi jnu̱tya dyetya vu̱y, rañuma dipuvay, nu̱tyu cariitu jnutijyu̱u̱ nta, jivyara jachipiya̱jada vu̱quebyimu, jiryatiy ra̱jarupanu varirya vu̱vyicha̱da, rirya̱mi̱vachara variy rajuuvay ru̱co̱siy.  
\v 16 Vu̱ryi jnu̱tya dyetya vu̱y sañuma vicha vanu cadnavu̱ vu̱quebyimu, varimyata datyi̱sa̱ nu̱tyu Esavúbatyi vichanu̱yada darya, ni̱tiy ta̱ryu̱tya̱da taraqui jibyeda murichiryara jiyaru̱yasara jijye̱ barya.  
\v 17 Vu̱dyetya daryaju̱ jiryatiy sani va̱ta̱danumatiy rana̱cho̱ jiyaru̱ryantiy, sarrachoda saja̱y ra̱jisiyu dañuma sani yasanta̱da yina̱ya̱danube sivara. Ne vana̱y sasaryedara sa̱tidye paru̱y saja̱y riva jirrachoda, tii mitya. 
\p  
\v 18 Ne vuryiti̱ nu̱tyu vu̱myunatyavatyi jti̱jada ja̱mu musiquimu vurya̱tidye tuva̱chura Ju̱denu niquejada, jiryatiy Muyisésibemyusirya. Riñi jti̱jada musiquimu jiryatiy radacutyadeda rajiruju̱ryanube jasiy, jiiday quivaya̱ra jarye risa̱ju̱, jiryatiy ja̱mu riicho jaryedora.  
\v 19 Rityuva̱choda varirya natutya̱ suuyada, niquejada jarye jiryatiy rara̱yada nupocudinubesiy. Rityi tuva̱chodara niquejada, riñi jiyasanta̱da variñi̱ Muyisésibe: “Sa̱numa paru̱y Ju̱denu riva niquejada nu̱ñe̱cho̱.”  
\v 20 Ne rijechi̱nityaru̱yada daryaju̱ra su̱teda: 
\q1 “Saryityi ja̱tyo̱ vinu rirya̱si̱ raniy musiqui, riryi jvesiy ravichu̱ta variy riva ni̱.” 
\m  
\v 21 Jiryatiy ravichanu̱yada jaryi suvu̱chara daryaju̱, jiryatiy ridyiñu̱yada riva, su̱teda Muyisésibe variy: 
\q1 “Ramyichutyeñuma rachuvu̱yadamu.” 
\p  
\v 22-23 Ne vuryiti̱ nu̱tyu vu̱myunatyavatyi jti̱jada musiquimuju̱ jiryatiy jirya mucadimura. 
\p Vuryiti̱ma̱ ji̱ta vinu Siyó̱ musiquimuju̱ day, na̱vay vichi̱ Ju̱denu vicha̱damuju̱, jiryatiy jarichumu vicha̱da darya, Jerusarí̱ jtyatara. Vuryiti̱ma̱ ji̱ta ruumu rajuuvay Ju̱denu tuunu vichavay jiryatiy rintye̱ryaniy jchana̱tyavayu; ruumu jarye jiryatiy sanatuchara Ju̱denu jidyedyeñu munatyavajyu̱ riy, jiryatiy nu̱chavay jarichumu vicha̱daju̱ riy. Vuryiti̱ma̱ ja̱mu cadnadumuntiy, ni̱tiy vichasara Vuryi̱ndenu ti̱ta̱ju̱, ruumu jarye jiryatiy diiñu bayanumiryi, jiryatiy saja̱vyechoda Ju̱denu munatya ta̱riy samivyeryi.  
\v 24 Vuryiti̱ma̱ simu vuryeyada rá̱ñu Jesúsntiy, jiryatiy Ju̱denu vadi niquejada jmu̱tyi̱ni̱, sandaja̱muntiy jiryatiy ju̱resara vu̱pyu̱cha̱daju̱ra. Sandaja̱ ji̱ta tu̱chusara vuryiva samivya̱ju̱ ramusiy jiryatiy jachiñu̱ryara Abénubay nudaja̱ yivacha̱da murichirya.  
\v 25 Vu̱ryi jnu̱tya dyetya vu̱y, vu̱ñuma rrachuni̱ Ju̱denu jiryatiy saniquesara vu̱y. Netimyu̱ ne riryamitya̱da vu̱myunatyavarya Ju̱denu murichenutadeda, jiryatiy rirrachodara saniquejada jirya mucadimu niquesara, ne vinu vu̱y ra̱ramityára, vu̱ryityi janumitye sa̱jisiy ni̱tiy niquesara vu̱jyuuchuveda murichenusa̱danchiy jarichumusivyu̱y.  
\v 26 Saniquejadanumatiy musiquimu ta̱riy, samuchutyetyadedara mucadi jiñiquejadata. Diye ji̱ta su̱tay: 
\q1 “Daraju̱jyu̱ tamitya ra̱day muchutyetyanirya mucadi, jarichu jarye risa̱ju̱.” 
\m  
\v 27 Jiryatiy su̱tedara “Daraju̱jyu̱ tamitya” jidyityadoda yitedamusiy jiryatiy sa̱parutamu̱rya ti̱ta̱ju̱ jiryatiy su̱ndejada ja̱ta̱daju̱ra, ra̱tidye ma̱cho̱jaya̱sara ti̱ta̱ju̱ jiryatimyu̱ ne vana̱y muchutyetyaniya̱sarára.  
\v 28 Ramuni̱tiy, jiryatiy vuryi̱mutya̱sara Ju̱denumusirya yinsu̱jyo jiryatimyu̱ ne vana̱y muchutyetyaniya̱sarára, vurya̱ma̱ jchana̱tyani̱, vurya̱tidye vichasara siityeevay vu̱chuvu̱yadanube saju̱, jiryatiy vu̱tyuva̱chusara simu.  
\v 29 Tapi Vuryi̱ndenu ji̱ta jiiday nu̱ya̱ra day. 
\c 13  
\s1 Nu̱tyuramusiy vu̱ryi jvaarya Ju̱denu va̱tasara 
\p  
\v 1 Vurya̱ma̱ va̱tasara riy vu̱tyeryi̱veda Jesucrístumu.  
\v 2 Ne vurya̱jachipurya samiy jmutya̱jada vu̱ryorimyu riy jañu̱vye, tapi daryamusiy ridyiryejada tavay jiñiya̱resiryi Ju̱denu tuunu vichavay.  
\v 3 Vurya̱ma̱ jachipityasara riy tanuvu̱nusavay daryatiy vu̱vyicha nta tanuvu̱nusavay rusa̱ju̱, rijeryentiy jiryatiy jarupantasavadyeryi, vu̱jerye vichasara daryaju̱ vu̱tavantyi, vu̱dyetya varirya rivyichasa̱dantiy.  
\v 4 Samirya jvadichara ra̱cha̱siy ja̱mu̱yada, nanuji̱yada jarye jiryatiy nanurupi danu̱ju̱myusiy yisa̱. Sa̱murichenutaniy Ju̱denu daryaju̱ riy rityi cadnavachara.  
\v 5 Ne vurya̱va̱ta jaryirya criquiy, vurya̱ma̱ ma̱cho̱ samiy jachityavay rata jiryatiy vuryimura. Ju̱denu ji̱ta jteda daryaju̱: 
\q1 “Ne ra̱jiintye jiryimusiy, dantyamu̱y ne ra̱tochiy jirye, mitya.” 
\m  
\v 6 Daryamusiy ji̱ta vuryi̱tachara vu̱chuvu̱yasa̱damu: 
\q1 “Vu̱yntyityu̱ ji̱ta vuryi̱mu̱tyi̱ day, ne vurya̱suvu̱y. ¿Ta̱ra sa̱jvaay vanu vuryeyaro̱ju̱ variy, ta̱ra?” 
\p  
\v 7 Jirya̱ma̱ jachipityasara riy jiryeyantavay, jiryatiy riñiquejadara Ju̱denu niquejada jiryiva. Jirya̱jachipitya samirya rivyicha̱da, nu̱tyuramusiy ruto̱tadedara, jirya̱tidye jantyara rityuva̱choda Ju̱denumu.  
\v 8 Daryatiy savicha̱da Jesucrístu ta̱riy, daryaday savichasara diyentiy, daryani̱ sa̱chajaya̱sara ju̱na̱reju̱ ti̱ta̱ju̱.  
\v 9 Ne jirya̱caratyaniy Ju̱denu nú̱vasiyu, jiryatiy jiryetyuva̱chu ramu datyadoda jaryedo, jiryatiy tajijyu̱ darya. Samirya dyetya vurya̱vanu̱tya Ju̱denu jmu̱tya̱data vu̱jechimyu vu̱y, ne jmyichara jibyedata, tapi ne ru̱mu̱tyasara riy rityi rani jibyeda Ju̱denunijyu̱ra tara.  
\v 10 Ju̱denunijyu̱ jnutatyajo, jasityi su̱ntatya Jesucrístu vuryeyadaju̱yu, rani̱ vichasara jnutatyajo jasityimyu̱y ne vana̱y riimyi Ju̱denu mo̱mu jvaavyerya jnutatyasi̱tera.  
\v 11 Tapi riryupamyu̱chara vicha̱da tuva̱ryara savu̱ voca jnutatyasi̱, simusityi sapu̱chiñu̱yada caserdótevyeda nutyityu̱ra sandaja̱ Ju̱denu rorivyimuju̱, nijya̱nvay juuchuveda pu̱yadaju̱. Ne riñi jmyichara rate sasaviy, mitya.  
\v 12 Daryaday sabatyeda Jesús vicha̱da tuva̱ryantiy, sa̱tidye jiintya yindaja̱ta Ju̱denuju̱ riy nijya̱nvay.  
\v 13 Ramuni̱tiy vurya̱ntya sipyatay Jesús tuunuju̱, jiryatiy vu̱jechi̱nityasarára javityiye̱yada vatajuu sisa̱.  
\v 14 Tapi ne tara vicha̱da jiyu jiryatiy ra̱suru̱jeya̱sara ju̱na̱reju̱. Vu̱vya̱tasara ji̱ta vicha̱dana̱cho̱ jiryatiy ra̱cha̱siy rivasiy.  
\v 15 Ramuni̱tiy vurya̱ma̱ jnutatyajaya̱sara Jesúsmusirya vuryi̱chana̱tya̱da Ju̱denunijyu̱, jiryatiy rajontay nta vuryi̱tó, Ju̱denu jtya baya̱jada nijyu̱.  
\v 16 Ne vurya̱jachipurya samirya jvaayada, jiryatiy vu̱che̱chara vu̱beryatera riy tavay, tapi su̱canuchara Ju̱denu daryaju̱ra darya jnutatyasara.  
\v 17 Jirya̱ma̱ tuva̱chu jiyantavamyu, jirya̱ma̱ saboniy variy ruumuyu, tapi rivyitya jnu̱tyasara daryaju̱ jiryi̱ntu jiyadaju̱, jiryatiy rirya̱tu̱chu yinu̱tya̱danchiy siva yinsu̱ñu. Jirya̱ma̱ saboniy ruumuyu, rirya̱tidye mutay jchana̱vye Ju̱denu nú̱va jirye, ne yívavye, jiryatimyu̱ ne raryicha samirya jiryejyu̱. 
\p  
\v 18 Jirya̱ma̱ tu̱chusara Ju̱denujsa̱ nu̱dyeyadaju̱, jiryatiy nu̱dyetya jijechimyu nu̱vyicharu̱chara samivye Ju̱denu diya ti̱ta̱ju̱.  
\v 19 Rayasanta jaryivya̱ju̱ jirye, jirya̱tidye tu̱chu Ju̱denujsa̱ rayadaju̱, ra̱tidye ta̱rya vani̱rava̱ju̱ jiryimuju̱. 
\s1 Samu̱chuveda samirya niquejadata tamitya riy 
\p  
\v 20 Ju̱denu ji̱ta vichasara samiy vichasa̱da ja̱mi̱, ni̱ni̱ ta̱ryatadeda diivye cabyimusiñi̱ Vu̱yntyityu̱ Jesús, jiryatiy savichasara jasi̱ jnu̱tyavay nutyityu̱, jichiityari̱vajyu̱. Savichasara vuryi̱nu̱tyi̱ jiryatiy sarubedara yindaja̱ vuryeyadaju̱, Ju̱denu jteda jto̱tadedaju̱ ju̱na̱reju̱.  
\v 21 Rajechiñu̱y siva jiñu Ju̱denu, sa̱tidye jdutyamu̱y samirya jiryivaatya̱ju̱sara, jirya̱tidye jvaarya sava̱tara, jiryatiy sivaachara Jesucrístumusiy vuryimuju̱ra, jiryatiy samiy jvadichara sadiyara. ¡Jesucrístunijyu̱ ra̱chajaya̱sara vanda ju̱na̱reju̱tecu̱! Daryanuma ra̱cha̱siy. 
\p  
\v 22 Rayasanta jirye, ratyeryi̱veda, jirya̱ntya jachi̱nityara ravyanu̱tya̱da, tapi rañu̱yasiy ne jaryi rajuura niquejadatara catera.  
\v 23 Jirya̱datya jmu̱ryasi̱numani̱ vu̱tyeryi̱ Timutévu. Saryityi ju̱ti̱ varenu, ra̱diy vatajuu sisa̱ jiryiva. 
\p  
\v 24 Jirya̱ma̱ mu̱chuvaryi jintyityu̱veda ti̱ta̱ju̱, Ju̱denuju̱ jiintyasavay jarye ti̱ta̱ju̱ rusa̱ju̱. Rimyu̱chuvay Itáriyamusivye jiryentyidye.  
\v 25 Sa̱numa jmu̱tyasara Ju̱denu jirye. ¡Daryanuma ra̱cha̱sitye!