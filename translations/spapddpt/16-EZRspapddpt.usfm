\v 8 \w A|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H1931"\w* \w que|strong="H1931"\w* \w no|strong="H3808"\w* llegara en \w tres|strong="H7969"\w* \w días|strong="H3117"\w*, según \w el|strong="H1931"\w* acuerdo \w de|strong="H8269"\w* \w los|strong="H3605"\w* \w jefes|strong="H8269"\w* y \w de|strong="H8269"\w* \w los|strong="H3605"\w* \w ancianos|strong="H2205"\w*, \w toda|strong="H3605"\w* \w su|strong="H1931"\w* \w hacienda|strong="H7399"\w* sería maldita y \w él|strong="H1931"\w* \w mismo|strong="H1931"\w* sería proscrito \w de|strong="H8269"\w* \w la|strong="H1931"\w* \w congregación|strong="H6951"\w* del \w cautiverio|strong="H1473"\w*.   
\p
\v 9 \w Todos|strong="H3605"\w* \w los|strong="H3427"\w* hombres \w de|strong="H5921"\w* \w Judá|strong="H3063"\w* \w y|strong="H5921"\w* \w Benjamín|strong="H1144"\w* \w se|strong="H1931"\w* reunieron \w en|strong="H5921"\w* Jerusalén \w dentro|strong="H5921"\w* \w de|strong="H5921"\w* \w los|strong="H3427"\w* \w tres|strong="H7969"\w* \w días|strong="H3117"\w*. \w Era|strong="H1931"\w* \w el|strong="H1931"\w* 20 \w del|strong="H5921"\w* \w mes|strong="H2320"\w* \w noveno|strong="H8671"\w*. \w Todo|strong="H3605"\w* \w el|strong="H1931"\w* \w pueblo|strong="H5971"\w* \w se|strong="H1931"\w* sentó \w en|strong="H5921"\w* \w la|strong="H1931"\w* plaza \w del|strong="H5921"\w* \w Templo|strong="H1004"\w* \w de|strong="H5921"\w* \nd ʼElohim\nd*. Temblaban \w a|strong="H3068"\w* \w causa|strong="H1697"\w* \w de|strong="H5921"\w* \w aquel|strong="H1931"\w* \w asunto|strong="H1697"\w* \w y|strong="H5921"\w* \w por|strong="H5921"\w* \w la|strong="H1931"\w* gran \w lluvia|strong="H1653"\w*.   
\p
\v 10 \w El|strong="H5921"\w* \w sacerdote|strong="H3548"\w* \w Esdras|strong="H5830"\w* \w se|strong="H5921"\w* \w levantó|strong="H6965"\w* \w y|strong="H5921"\w* \w les|strong="H5921"\w* dijo: Ustedes fueron infieles \w al|strong="H5921"\w* convivir \w con|strong="H5921"\w* mujeres \w extranjeras|strong="H5237"\w*, \w con|strong="H5921"\w* \w lo|strong="H5921"\w* cual \w aumentaron|strong="H4603"\w* \w la|strong="H5921"\w* culpabilidad \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.  
\v 11 \w Ahora|strong="H6258"\w* \w pues|strong="H6258"\w*, confiesen ante \nd \+w Yavé|strong="H3068"\+w*\nd*, \w el|strong="H6213"\w* \nd ʼElohim\nd* \w de|strong="H4480"\w* sus antepasados. \w Hagan|strong="H6213"\w* \w lo|strong="H6213"\w* \w que|strong="H4480"\w* \w a|strong="H3068"\w* \w Él|strong="H6213"\w* le agrada y apártense \w de|strong="H4480"\w* los \w pueblos|strong="H5971"\w* \w de|strong="H4480"\w* \w esta|strong="H7522"\w* tierra y \w de|strong="H4480"\w* las mujeres \w extranjeras|strong="H5237"\w*.   
