\p 
\v 14 \w Amasa|strong="H6021"\w* convinced \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w people|strong="H1320"\w* \w of|strong="H3117"\w* Judah \w to|strong="H1961"\w* unitedly support \w David|strong="H3117"\w*,\f + \fr 19:14 \ft “David”: name supplied for clarity.\f* \w so|strong="H6213"\w* \w they|strong="H3117"\w* sent \w a|strong="H3068"\w* message \w to|strong="H1961"\w* \w the|strong="H3605"\w* \w king|strong="H6440"\w*: “Please \w come|strong="H1961"\w* back, \w you|strong="H6440"\w* \w and|strong="H3117"\w* \w everyone|strong="H3605"\w* \w with|strong="H6213"\w* \w you|strong="H6440"\w*.”
