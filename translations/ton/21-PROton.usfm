\q1 
\v 18 Ko ia К»oku К»eveК»eva К»i he angatonu К»e fakamoК»ui ia:
\q2 ka К»e hinga leva ia К»aia К»oku pikopiko hono ngaahi hala.
\q1 
\v 19 Ko ia К»oku faК»a ngДҒue ki heК»ene ngoue К»e maК»u К»e ia К»ae meК»akai lahi:
\q2 ka К»e lahi moК»oni К»ae masiva kiate ia К»oku muimui ki he kakai taК»epoto.
\q1 
\v 20 вҖҢК»E lahi К»aupito К»ae tДҒpuaki ki he tangata К»oku angatonu:
\q2 ka ko ia К»oku fai fakatoК»otoК»o ke ne koloaК»ia К»e К»ikai tonuhia ia.
\q1 
\v 21 вҖҢК»Oku К»ikai lelei ke filifilimДҒnako:
\q2 he ko e tangata К»oku pehД“, К»e fai hala ia ke ne maК»u ai ha konga mДҒ.
\q1 
\v 22 вҖҢК»Oku К»iate ia К»oku fai fakatoК»otoК»o ke ne koloaК»ia К»ae mata К»oku kovi,
\q2 pea К»oku К»ikai te ne tokangaК»i К»e hoko mai К»ae masiva kiate ia.
\q1 
\v 23 Ko ia К»oku lea valoki ki ha tangata К»e maК»u К»e ia К»ae К»ofa lahi hake,
\q2 К»amui К»iate ia К»oku lea lapu К»aki К»ae К»elelo.
\q1 
\v 24 Ko ia К»oku kaihaК»a mei heК»ene tamai pe ko К»ene faК»Д“,
\q2 К»o ne pehД“, вҖңК»Oku К»ikai ko e fai hala ia;вҖқ
\q1 К»oku kaumeК»a ia mo e tangata fakaК»auha.
\q1 
\v 25 Ko ia К»oku loto fielahi К»oku fakatupu К»e ia К»ae fekeК»ikeК»i:
\q2 ka К»e fakamonЕ«К»ia ia К»aia К»oku falala kia Sihova.
\q1 
\v 26 Ko ia К»oku falala ki hono loto К»oК»ona ko e vale ia:
\q2 ka ko ia К»oku К»alu fakapotopoto, К»e fakahaofi ia.
\q1 
\v 27 Ko ia К»oku faК»a foaki ki he masiva К»e К»ikai masiva ia:
\q2 ka ko ia К»oku fufЕ« hono mata К»e lahi К»ae fakamalaК»ia К»e hoko ki ai.
\q1 
\v 28 вҖҢК»Oka hakeakiК»i К»ae angahala, К»oku toitoi К»ae kakai: ka К»oka К»auha К»akinautolu, К»oku tupu К»o tokolahi К»ae mДҒК»oniК»oni.
\c 29
\cd \it 1 Ko e lea К»oku kau ki he pule fakamaama, 15 Mo e pule ki he fДҒnau. 22 Ko e lea ki he К»ita, mo e fielahi, mo e kaihaК»a, mo e foК»i, mo e fai kДҒkДҒ.\it*
\q1 
\v 1 Ko ia kuo liunga lahi hono valokiК»i kae fakakekeva К»e ia hono kia,
\q2 К»e fakaК»auha fakafokifДҒ ia, pea К»e К»ikai ha fakamoК»ui ki ai.
\q1 
\v 2 вҖҢК»Oka pule К»ae mДҒК»oniК»oni К»oku fiefia ai К»ae kakai:
\q2 ka К»oka maК»u К»ae pule К»e he angahala К»oku mamahi ai К»ae kakai.
\q1 
\v 3 Ko ia К»oku manako ki he poto К»oku ne fakafiefiaК»i К»a К»ene tamai:
\q2 ka К»oku maumauК»i К»ene koloa К»e ia К»oku kaumeК»a mo e kau faК»a feК»auaki.
\q1 
\v 4 Ko e meК»a К»i he fakamaau totonu К»ae tuК»i К»oku fokotuК»umaК»u ai К»ae fonua:
\q2 ka ko ia К»oku ne faК»a maК»u К»ae ngaahi foaki К»oku ne fakamalaК»ia ia.
\q1 
\v 5 Ko e tangata ko ia К»oku lea lapu ki hono kaungДҒК»api,
\q2 К»oku К»aК»au К»e ia К»ae kupenga ki hono vaК»e.
\q1 
\v 6 Ko e fai angahala К»ae tangata angakovi ko e tauhele ia:
\q2 ka К»oku hiva mo fiefia К»ae mДҒК»oniК»oni.
\q1 
\v 7 вҖҢК»Oku tokanga К»ae mДҒК»oniК»oni ki he masiva:
\q2 ka К»oku К»ikai tokanga К»ae angakovi ke К»iloК»i ia.
\q1 
\v 8 вҖҢК»Oku tutu К»ae kolo К»e he kau tangata manuki;
\q2 ka К»oku taК»ofi atu К»ae houhau К»e he kakai poto.
\q1 
\v 9 Kapau К»oku fakakikihi К»ae tangata poto mo ha tangata vale,
\q2 neongo К»ene lili pe kata, К»e К»ikai ha fiemДҒlie К»e tupu ai.
\q1 
\v 10 вҖҢК»Oku fehiК»a ki he angatonu К»aia К»oku fieinu ki he toto:
\q2 ka К»oku kumi hono laumДҒlie К»e he mДҒК»oniК»oni.
\q1 
\v 11 вҖҢК»Oku fakahДҒ К»e he vale К»a hono loto kotoa pД“:
\q2 ka К»oku fakalaulauloto К»e he poto ki he К»amui:
\q1 
\v 12 Kapau К»oku faК»a tokanga К»aia К»oku pule ki he ngaahi loi,
\q2 К»e hoko К»o kovi К»a К»ene kau tamaioК»eiki kotoa pД“.
\q1 
\v 13 вҖҢК»Oku faК»a fakataha pe К»ae masiva pea mo e kДҒkДҒ:
\q2 pea К»oku fakatou mДҒmangia hona mata meia Sihova.
\q1 
\v 14 вҖҢК»E fokotuК»umaК»u ke taК»engata К»ae nofoК»a fakaК»eiК»eiki К»oe tuК»i,
\q2 ko ia К»oku fai totonu К»ae fakamaau ki he masiva.
\q1 
\v 15 вҖҢК»Oku tupu К»ae poto mei he meК»a tДҒ mo e valoki:
\q1 ka ko e tamasiК»i К»oku tuku pe ki heК»ene faК»iteliha К»oku ne fakamaaК»i К»a К»ene faК»Д“.
\q1 
\v 16 вҖҢК»Oka tupu К»o tokolahi К»ae kakai angahala,
\q2 К»oku tupu mo e fai kovi: ka К»e mamata К»ae mДҒК»oniК»oni ki heК»enau hinga.
\q1 
\v 17 Ke ke tauteК»i ho foha, pea te ke fiemДҒlie К»iate ia:
\q2 К»io, te ne fakafiefiaК»i ho laumДҒlie.
\q1 
\v 18 вҖҢК»Oka К»ikai К»i ai ha kikite К»oku malaК»ia К»ae kakai;
\q2 ka К»oku monЕ«К»ia ia К»aia К»oku fai ki he fono.
\q1 
\v 19 вҖҢК»E К»ikai poto К»ae tamaioК»eiki К»i ha lea valoki:
\q2 he naК»a mo К»ene К»iloК»i К»e К»ikai te ne talangofua.
\q1 
\v 20 вҖҢК»Oku ke mamata ki ha tangata К»oku faК»a lea vave?
\q2 К»Oku tau К»amanaki lelei hake ki he vale К»iate ia.
\q1 
\v 21 Ko ia К»oku fakahikihiki К»a К»ene tamaioК»eiki talu К»ene kei tamasiК»i,
\q2 К»e faifai pea hoko ia К»amui ko hono foha.
\q1 
\v 22 вҖҢК»Oku fakatupu К»ae fekeК»ikeК»i К»e he tangata faК»a К»ita,
\q2 pea К»oku lahi К»ae fai hala К»ae tangata loto fili.
\q1 
\v 23 Ko e fielahi К»ae tangata, К»e fakahifo ai ia ki lalo;
\q2 ka К»e poupou hake К»ae laumДҒlie К»oe angavaivai К»aki К»ae ongoongolelei.
\q1 
\v 24 Ko ia К»oku kaumeК»a mo e kaihaК»a К»oku fehiК»a ia ki hono laumДҒlie К»oК»ona:
\q2 pea К»oku fanongo К»e ia ki he kape, ka К»e К»ikai te ne fakahДҒ ia.
\q1 
\v 25 Ko e manavahД“ ki ha tangata, К»oku hoko ia ko e tauhele:
\q2 ka К»e moК»ui pe ia К»aia К»oku falala kia Sihova.
\q1 
\v 26 вҖҢК»Oku kumi К»e he tokolahi ki he loto lelei К»o ia К»oku pule;
\q2 ka К»oku meia Sihova К»ae fakamaau ki he tangata taki taha.
\q1 
\v 27 Ko e tangata taК»efaitotonu К»oku fakalielia ia ki he angatonu.
\q2 Pea ko ia К»oku fai totonu К»i hono hala К»oku fakalielia ia ki he angahala.
\c 30
\cd \it 1 Ko e fakamatala К»e К»Akuli К»a К»ene tui. 7 Ko e meК»a К»e ua К»i heК»ene lotu. 10 Ke К»oua naК»a fakamДҒlohiК»i К»ae kakai mДҒК»ulalo. 11 Ko e toК»utangata К»e fДҒ К»oku angakovi. 15 Ko e meК»a К»e fДҒ К»oku К»ikai ke fiu. 17 Ko e К»oua naК»a manukiК»i К»ae mДҒtuК»a. 18 Ko e meК»a К»e fДҒ К»oku К»ilongataК»a. 21 Ko e meК»a К»e fДҒ К»oku К»ikai ke kДҒtakiК»i. 24 Ko e meК»a К»e fДҒ К»oku poto lahi. 29 Ko e meК»a К»e fДҒ К»oku toulekeleka. 32 Ko e К»ita ko e meК»a ia ke taК»ofi.\it*
\p 
\v 1 Ko e ngaahi lea К»a К»Akuli ko e foha К»o Sake, К»aia ko e kikite:
\q1 naК»e lea К»ae tangata kia К»Itieli,
\q2 К»io, kia К»Itieli mo К»Ukali.
\q1 
\v 2 вҖңKo e moК»oni К»oku lahi hake К»a К»eku vale К»i he tangata kotoa pД“,
\q2 pea К»oku К»ikai te u maК»u К»ae poto К»o ha tangata.
\q1 
\v 3 Kuo К»ikai akonekina au ki he poto,
\q2 pea К»oku К»ikai te u maК»u К»ae К»ilo К»oe mДҒК»oniК»oni.
\q1 
\v 4 Ko hai kuo К»alu hake ki he langi, pe К»alu hifo?
\q2 Ko hai К»oku ne tДҒnaki К»ae matangi К»i hono nima?
\q2 Ko hai kuo ne fakamaК»opoК»opo К»ae ngaahi vai К»i ha kofu?
\q2 Ko hai kuo ne fokotuК»umaК»u К»ae ngaahi ngataК»anga К»o mДҒmani?
\q2 Ko hai hono huafa, pea ko hai К»ae huafa К»o hono К»Alo, К»o kapau К»oku ke faК»a fakahДҒ?
\q1 
\v 5 вҖңК»Oku maК»a К»ae folofola kotoa pД“ К»ae К»Otua:
\q2 pea ko e ungaК»anga ia kiate kinautolu kotoa pД“ К»oku falala kiate ia.
\q1 
\v 6 вҖҢК»Oua naК»a ke fakalahi ki heК»ene folofola telia naК»a ne valokiК»i koe,
\q2 pea К»e К»ilo ai koe ko e loi.вҖқ
\q1 
\v 7 Ko e meК»a К»e ua kuo u kole kiate koe;
\q2 pea К»oua naК»a ke taК»ofi ia К»iate au К»o aК»u ki heК»eku mate.
\q1 
\v 8 Hiki ke mamaК»o К»iate au К»ae vaК»inga mo e loi:
\q2 pea К»oua naК»aku masiva pe koloaК»ia:
\q2 fafanga К»aki au К»ae meК»akai К»oku taau pe mo au:
\q1 
\v 9 Telia naК»aku mДҒkona, pea u fakafisiК»i koe, pea u pehД“, Ko hai К»a Sihova?
\q2 Telia foki naК»aku masiva, pea u kaihaК»a,
\q2 mo takuanoa К»ae huafa К»o hoku К»Otua.
\q1 
\v 10 вҖҢК»Oua naК»a ke fakakoviК»i К»ae tamaioК»eiki ki heК»ene К»eiki,
\q2 telia naК»a ne kapeК»i koe, pea К»ilo ko koe К»oku halaia.
\q1 
\v 11 вҖҢК»Oku ai К»ae fДҒnau К»oku kape ki heК»enau tamai,
\q2 pea К»oku К»ikai ke tДҒpuakiК»i К»enau faК»Д“.
\q1 
\v 12 вҖҢК»Oku ai К»ae toК»utangata К»e taha К»oku nau mДҒК»oniК»oni К»i honau mata К»onautolu,
\q2 ka К»oku teК»eki ke fufulu К»enau anga fakalielia.
\q1 
\v 13 вҖҢК»Oku ai К»ae toК»utangata К»e taha, К»Oi seuke! Hono К»ikai mДҒК»olunga К»a honau mata!
\q2 Pea kuo nau hiki hake honau laumata.
\q1 
\v 14 вҖҢК»Oku ai К»ae toК»utangata К»e taha, К»oku tatau honau nifo mo e heletДҒ,
\q2 mo honau ngao К»oku hangД“ ko e hele,
\q2 ke kai К»o К»osi К»ae masiva mei he funga К»o mДҒmani, pea К»osi mo e paea mei he kakai.
\b
\q1 
\v 15 вҖңК»Oku maК»u К»e he aluka К»ae К»ofefine К»e toko ua К»oku tangi,
\q2 вҖҳFoaki mai, foaki mai.вҖҷ
\b
\q1 вҖңК»Oku ai К»ae meК»a К»e tolu К»oku К»ikai siК»i ke fiemДҒlie,
\q2 К»io, К»oku fДҒ К»ae meК»a К»oku К»ikai ke nau pehД“, вҖҳMaК»uДҒ, kuo lahi:вҖҷ
\q1 
\v 16 Ko e faК»itoka;
\q2 mo e manДҒva К»oku paК»a;
\q2 ko e kelekele К»oku К»ikai pito К»i he vai;
\q2 pea mo e afi К»oku К»ikai ke pehД“, вҖҳMaК»uДҒ, kuo lahi.вҖҷ
\q1 
\v 17 вҖңKo e mata К»oku manuki ki heК»ene tamai,
\q2 pea К»ikai tokanga ke fai talangofua ki heК»ene faК»Д“,
\q2 К»e kapeК»i ia К»e he fanga leveni К»oe teleК»a,
\q2 pea К»e kai ia К»e he fanga К»ikale iiki.
\q1 
\v 18 вҖҢК»Oku ai К»ae meК»a К»e tolu К»oku fakaofo lahi kiate au,
\q2 К»io, ko e meК»a К»e fДҒ К»oku К»ikai te u К»iloК»i.
\q1 
\v 19 Ko e punaК»anga К»oe К»ikale К»i he К»atДҒ;
\q2 mo e hala К»oe ngata К»i he funga maka;
\q2 mo e К»aluК»anga К»oe vaka К»i he loto vaha;
\q2 mo e anga К»ae tangata ki he tДҒupoК»ou.
\q1 
\v 20 вҖҢК»Oku pehД“ К»ae anga К»ae fefine tonotangata;
\q2 К»oku ne kai, К»o ne holoholo hono ngutu,
\q2 К»o ne pehД“, вҖңNaК»e К»ikai te u fai ha kovi.вҖқ
\q1 
\v 21 Ko e meК»a К»e tolu К»oku maveuveu ai К»a mДҒmani,
\q2 ko e meК»a К»e fДҒ К»oku К»ikai ke ne faК»a kДҒtakiК»i:
\q1 
\v 22 Ko e tamaioК»eiki kuo fakanofo ke pule;
\q2 mo e tangata vale kuo mДҒkona К»i he meК»akai;
\q1 
\v 23 Mo e fefine anga fakalielia kuo mali;
\q2 mo e kaunanga К»oku hoko ki he koloa К»a К»ene К»eiki fefine.
\q1 
\v 24 вҖҢК»Oku ai К»ae meК»a К»e fДҒ К»oku iiki К»i he funga К»o mДҒmani,
\q2 ka К»oku lahi К»aupito К»enau poto:
\q1 
\v 25 Ko e lЕҚ, ko e faК»ahinga ia К»oku К»ikai ke mДҒlohi,
\q2 ka К»oku nau tokonaki К»enau meК»akai К»i he faК»ahitaК»u mafana.
\q1 
\v 26 Ko e fanga safana, ko e faК»ahinga ia К»oku vaivai pe,
\q2 ka К»oku nau ngaohi honau fale К»i he ngaahi maka;
\q1 
\v 27 вҖҢК»Oku К»ikai maК»u ha tuК»i К»e he fanga heК»e,
\q2 ka К»oku nau puna fakataha atu;
\q1 
\v 28 вҖҢК»Oku puke К»aki К»e he hina К»a hono nima,
\q2 К»o ne nofo К»i he ngaahi fale К»oe ngaahi tuК»i.
\q1 
\v 29 вҖҢК»Oku ai К»ae meК»a К»e tolu К»oku lelei К»enau К»alu,
\q2 К»io, К»oku fДҒ, К»ae meК»a К»oku matalelei К»enau К»alu:
\q1 
\v 30 Ko e laione К»aia К»oku mДҒlohi К»i he fanga manu,
\q2 pea К»e К»ikai te ne tafoki atu К»i ha taha;
\q1 
\v 31 Ko e hoosi; mo e kosi tangata foki;
\q2 pea mo e tuК»i, К»oku К»ikai faК»a fai ki ai ha angatuК»u.
\q1 
\v 32 вҖңKapau kuo ke fai vale К»i hoК»o hiki hake koe К»e koe,
\q2 pea kapau kuo ke mahalo kovi, ke ke К»ai ho nima ki ho ngutu.
\q1 
\v 33 Ko e moК»oni К»oku tupu К»ae pota К»i he tuki К»ae huК»ahuhu К»oe manu,
\q2 pea tupu К»ae toto К»i he mioК»i К»oe ihu:
\q1 К»oku pehД“, К»oku tupu К»ae fekeК»ikeК»i К»i he К»ita fakamДҒlohi.вҖқ
\c 31
\cd \it 1 Ko e enginaki К»a Limueli ki he fai mДҒК»oniК»oni mo e taК»ofi ki he faК»a inu ke konДҒ. 6 Ke maluК»i mo fakafiemДҒlie К»ae kakai mamahiК»ia. 11 Ko e ongoongolelei mo e К»aonga К»ae fefine alafia angalelei.\it*
\p 
\v 1 Ko e ngaahi lea К»ae tuК»i ko Limueli, ko e tala naК»e akonaki К»aki ia К»e heК»ene faК»Д“.
\q1 
\v 2 вҖңKo e hДҒ, К»eku tama?
\q2 Pea ko e hДҒ, К»ae tama К»o hoku manДҒva?
\q2 Pea ko e hДҒ, К»ae tama К»a К»eku ngaahi fuakava?
\q1 
\v 3 вҖҢК»Oua naК»a tuku ho mДҒlohi ki he kakai fefine,
\q2 pe ko ho ngaahi hala ki he meК»a К»oku К»auha ai К»ae ngaahi tuК»i.
\q1 
\v 4 вҖҢК»Oku К»ikai taau mo e ngaahi tuК»i, К»E Limueli,
\q2 К»oku К»ikai taau mo e ngaahi tuК»i ke faК»a inu kava pe ke inu К»e he houК»eiki К»ae kava kona.
\q1 
\v 5 Telia naК»a nau inu, pea ngalo ai К»ae fono,
\q2 pea taК»etotonu ai К»ae fakamaau, ki he kakai К»oku mamahi.
\q1 
\v 6 вҖҢК»Atu К»ae kava mДҒlohi kiate ia К»oku meimei mate,
\q2 mo e uaine kiate kinautolu К»oku mДҒfasia honau loto.
\q1 
\v 7 Tuku ke ne inu ke ngalo ai К»ene masiva,
\q2 pea К»oua naК»a toe manatu ki heК»ene mamahi.
\q1 
\v 8 Ke matoК»o ho ngutu koeК»uhi ko e noa,
\q2 К»i he meК»a К»anautolu kotoa pД“ kuo fakamaau ki he mate.
\q1 
\v 9 MatoК»o ho ngutu, pea ke fakamaau mДҒК»oniК»oni,
\q2 pea ke langomakiК»i К»ae masiva, pea mo e paea К»i heК»ene meК»a.вҖқ
\b
\q1 
\v 10 Ko hai К»oku faК»a maК»u К»ae fefine fai lelei?
\q2 He К»oku maК»ongoК»onga ia К»i he ngaahi maka koloa.
\q1 
\v 11 вҖҢК»Oku falala fakamoК»omoК»oni kiate ia К»ae loto К»o hono husepДҒniti,
\q2 pea К»e К»ikai К»aonga kiate ia ha meК»a К»oku maК»u К»i he fakamДҒlohi.
\q1 
\v 12 вҖҢК»E fai lelei ia kiate ia,
\q2 ka К»e К»ikai ha kovi К»i he К»aho kotoa pД“ К»o К»ene moК»ui:
\q1 
\v 13 вҖҢК»Oku ne kumi К»ae fulufuluК»i sipi, mo e louК»akau,
\q2 К»o ne ngДҒue fiefia К»aki К»a hono nima.
\q1 
\v 14 вҖҢК»Oku ne hangД“ ko e ngaahi vaka К»oe kau fakatau,
\q2 he К»oku ne К»omi К»ene meК»akai mei he mamaК»o.
\q1 
\v 15 вҖҢК»Oku ne tuК»u hake foki К»i he kei poК»uli, К»o ne tufaki К»ae meК»akai ki heК»ene kau nofoК»anga,
\q2 mo e К»inasi К»o К»ene kau kaunanga.
\q1 
\v 16 вҖҢК»Oku ne manako ki ha ngoue, pea ne fakatau ia:
\q2 pea К»oku ne tЕҚ К»ae ngoue vaine mei he fua К»o hono nima.
\q1 
\v 17 вҖҢК»Oku nonoК»o К»aki К»ae mДҒlohi К»a hono kongaloto,
\q2 К»oku ne fakamДҒlohi hono nima.
\q1 
\v 18 вҖҢК»Oku ne К»ilo К»oku lelei К»ae meК»a К»oku ne fakatauК»aki:
\q2 К»oku К»ikai ke mate К»ene maama К»i he pЕҚ.
\q1 
\v 19 вҖҢК»Oku ne ai hono nima ki he meК»a К»oku fД«К»aki К»ae filo,
\q2 pea К»oku puke К»i hono nima К»ae К»aiК»anga filo.
\q1 
\v 20 вҖҢК»Oku mafao atu hono nima ki he masiva,
\q2 К»io, К»oku mafao atu hono nima kiate kinautolu К»oku paea.
\q1 
\v 21 вҖҢК»Oku К»ikai manavahД“ ia ki he tЕҚ mai К»ae К»uha hinehina ki heК»ene kau nofoК»anga:
\q2 he К»oku lЕҚua К»ae kofu К»o К»ene kau nofoК»anga kotoa pД“.
\q1 
\v 22 вҖҢК»Oku ne ngaohi kiate ia К»ae ngaahi kofuК»aki К»ae tupenu kuo tuitui fakasanisani:
\q2 ko hono ngaahi kofu ko e silika mo e meК»a kulaК»ahoК»aho.
\q1 
\v 23 вҖҢК»Oku ongoongoa hono husepДҒniti К»i he ngaahi matapДҒ,
\q2 К»oka nofo hifo ia mo e kau mДҒtuК»a К»oe fonua.
\q1 
\v 24 вҖҢК»Oku ngaohi К»e ia К»ae tupenu tuК»ovalevale lelei, К»o ne fakatauК»aki:
\q2 pea К»oku К»atu К»a hono ngaahi noК»o ki he kau fakatau.
\q1 
\v 25 Ko hono kofu ko e mДҒlohi mo e ongoongolelei;
\q2 pea К»e fiefia ia К»i he ngaahi К»aho kimui.
\q1 
\v 26 вҖҢК»Oku matoК»o hono ngutu К»i he poto;
\q2 pea К»oku К»i hono К»elelo К»ae fono К»oe К»ofa.
\q1 
\v 27 вҖҢК»Oku ne tokanga lahi ki he anga К»o hono fale,
\q2 pea К»oku К»ikai ke kai К»e ia К»ae mДҒ К»ae fakapikopiko.
\q1 
\v 28 вҖҢК»Oku tupu hake К»ene fДҒnau, К»onau ui ia ko e monЕ«К»ia;
\q1 pea К»oku fakaongoongoleleiК»i ia К»e hono husepДҒniti foki.
\q2 
\v 29 вҖңKuo fai lelei К»e he kau К»ofefine tokolahi,
\q2 ka К»oku ke lelei hake koe К»iate kinautolu kotoa pД“.вҖқ
\q1 
\v 30 Ko e meК»a kДҒkДҒ К»ae matamatalelei, pea ko e vaК»inga К»ae hoihoifua:
\q2 ka ko e fefine К»oku manavahД“ kia Sihova К»e fakaongoongoleleiК»i ia.
\q1 
\v 31 Foaki kiate ia mei he fua К»o hono nima:
\q2 pea tuku pe ke fakaongoongoleleiК»i ia К»i he ngaahi matapДҒ К»e heК»ene ngaahi ngДҒue К»aК»ana. 
