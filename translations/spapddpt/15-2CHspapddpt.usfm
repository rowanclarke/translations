\v 3 \w Cuando|strong="H1961"\w* \w el|strong="H5921"\w* \w reino|strong="H4467"\w* \w fue|strong="H1961"\w* firmemente establecido, \w mató|strong="H2026"\w* \w a|strong="H3068"\w* sus esclavos \w que|strong="H5921"\w* \w mataron|strong="H2026"\w* \w a|strong="H3068"\w* su padre \w el|strong="H5921"\w* \w rey|strong="H4428"\w*.  
\v 4 \w Pero|strong="H3588"\w* \w no|strong="H3808"\w* \w mató|strong="H4191"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w ellos|strong="H5921"\w*, \w según|strong="H5921"\w* \w lo|strong="H3808"\w* \w escrito|strong="H3789"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w Ley|strong="H8451"\w*, \w en|strong="H5921"\w* \w el|strong="H5921"\w* rollo \w de|strong="H5921"\w* \w Moisés|strong="H4872"\w*, \w donde|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w ordenó|strong="H6680"\w*: \w No|strong="H3808"\w* \w morirán|strong="H4191"\w* \w los|strong="H1121"\w* padres \w por|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w*, \w ni|strong="H3808"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w por|strong="H5921"\w* \w los|strong="H1121"\w* padres, \w sino|strong="H3588"\w* cada uno \w morirá|strong="H4191"\w* \w por|strong="H5921"\w* \w su|strong="H3588"\w* \w pecado|strong="H2399"\w*.   
\p
\v 5 Después Amasías reunió \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w* y \w los|strong="H1121"\w* organizó según sus \w casas|strong="H1004"\w* paternas por \w todo|strong="H3605"\w* \w Judá|strong="H3063"\w* y \w Benjamín|strong="H1144"\w* como \w jefes|strong="H8269"\w* \w de|strong="H1121"\w* millares y \w jefes|strong="H8269"\w* \w de|strong="H1121"\w* centenas. \w E|strong="H3068"\w* hizo un censo \w de|strong="H1121"\w* \w ellos|strong="H3605"\w*, \w de|strong="H1121"\w* 20 \w años|strong="H8141"\w* \w arriba|strong="H4605"\w*, \w de|strong="H1121"\w* \w los|strong="H1121"\w* cuales \w había|strong="H5975"\w* 300.000 escogidos \w que|strong="H1121"\w* tenían \w lanza|strong="H7420"\w* y \w escudo|strong="H6793"\w* para \w salir|strong="H3318"\w* \w a|strong="H3068"\w* \w la|strong="H3605"\w* \w guerra|strong="H6635"\w*.  
\v 6 Además tomó \w a|strong="H3068"\w* sueldo \w a|strong="H3068"\w* 100.000 \w hombres|strong="H1368"\w* \w valientes|strong="H1368"\w* de \w Israel|strong="H3478"\w* por 3,3 toneladas de \w plata|strong="H3701"\w*.   
\p
\v 7 \w Pero|strong="H3588"\w* un varón \w de|strong="H3588"\w* \nd ʼElohim\nd* \w fue|strong="H6635"\w* \w a|strong="H3068"\w* \w él|strong="H5973"\w* \w y|strong="H3588"\w* \w le|strong="H5973"\w* dijo: \w Oh|strong="H1121"\w* \w rey|strong="H4428"\w*, \w no|strong="H3588"\w* vaya \w el|strong="H5973"\w* \w ejército|strong="H6635"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* \w contigo|strong="H5973"\w*, \w porque|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w no|strong="H3588"\w* está \w con|strong="H5973"\w* \w Israel|strong="H3478"\w* \w ni|strong="H5973"\w* \w con|strong="H5973"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* Efraín.  
\v 8 \w Pero|strong="H3588"\w* \w si|strong="H3588"\w* vas, \w vé|strong="H3068"\w*. Sé fuerte \w en|strong="H3588"\w* \w la|strong="H3588"\w* \w batalla|strong="H4421"\w*. Sin embargo, \nd ʼElohim\nd* \w te|strong="H3588"\w* derribará \w delante|strong="H6440"\w* del enemigo, \w porque|strong="H3588"\w* \nd ʼElohim\nd* \w tiene|strong="H3426"\w* \w el|strong="H3588"\w* \w poder|strong="H3581"\w* \w para|strong="H3588"\w* ayudar \w y|strong="H3588"\w* \w para|strong="H3588"\w* derribar.   
\p
\v 9 Amasías preguntó al varón \w de|strong="H5414"\w* \nd ʼElohim\nd*: ¿\w Qué|strong="H4100"\w* \w haremos|strong="H6213"\w* en \w cuanto|strong="H4100"\w* \w a|strong="H3068"\w* las 3,3 toneladas \w de|strong="H5414"\w* plata \w que|strong="H4100"\w* pagué al \w ejército|strong="H1416"\w* \w de|strong="H5414"\w* \w Israel|strong="H3478"\w*? \w Y|strong="H3068"\w* \w el|strong="H6213"\w* varón \w de|strong="H5414"\w* \nd ʼElohim\nd* le respondió: \nd \+w Yavé|strong="H3068"\+w*\nd* puede darte \w mucho|strong="H7235"\w* \w más|strong="H7235"\w* \w que|strong="H4100"\w* eso.   
\p
\v 10 \w Entonces|strong="H7725"\w* Amasías apartó las tropas de Efraín \w que|strong="H1416"\w* le llegaron, para \w que|strong="H1416"\w* fueran \w a|strong="H3068"\w* sus casas. Por \w tanto|strong="H3966"\w*, ellos se enojaron muchísimo contra \w Judá|strong="H3063"\w* y regresaron \w a|strong="H3068"\w* sus casas enfurecidos.   
\p
\v 11 Pero Amasías \w se|strong="H5971"\w* esforzó y \w guió|strong="H3212"\w* \w a|strong="H3068"\w* su \w pueblo|strong="H5971"\w*. \w Fue|strong="H3212"\w* al \w valle|strong="H1516"\w* \w de|strong="H1121"\w* la \w Sal|strong="H4417"\w* y \w mató|strong="H5221"\w* \w a|strong="H3068"\w* 10.000 \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Seír|strong="H8165"\w*.  
\v 12 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w* capturaron \w vivos|strong="H2416"\w* \w a|strong="H3068"\w* otros 10.000, y \w los|strong="H1121"\w* llevaron \w a|strong="H3068"\w* \w la|strong="H3605"\w* \w cumbre|strong="H7218"\w* \w de|strong="H1121"\w* un \w peñasco|strong="H5553"\w*. Allí \w los|strong="H1121"\w* despeñaron, y \w todos|strong="H3605"\w* se volvieron pedazos.   
\p
\v 13 Pero \w las|strong="H1992"\w* tropas \w que|strong="H5704"\w* Amasías despidió \w para|strong="H5704"\w* \w que|strong="H5704"\w* no fueran \w con|strong="H5973"\w* \w él|strong="H5973"\w* \w a|strong="H3068"\w* la \w batalla|strong="H4421"\w*, saquearon \w las|strong="H1992"\w* \w ciudades|strong="H5892"\w* \w de|strong="H5973"\w* \w Judá|strong="H3063"\w*, \w desde|strong="H5704"\w* \w Samaria|strong="H8111"\w* \w hasta|strong="H5704"\w* Bet-horón. \w Mataron|strong="H5221"\w* \w a|strong="H3068"\w* 3.000 \w de|strong="H5973"\w* \w ellos|strong="H1992"\w* \w y|strong="H5704"\w* tomaron un \w gran|strong="H7227"\w* despojo.   
\p
\v 14 \w Aconteció|strong="H1961"\w* \w que|strong="H1121"\w*, \w cuando|strong="H1961"\w* Amasías regresó \w de|strong="H6440"\w* la matanza \w de|strong="H6440"\w* \w los|strong="H1121"\w* edomitas, \w se|strong="H1961"\w* llevó consigo \w los|strong="H1121"\w* \tl ʼelohim\tl* \w de|strong="H6440"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w Seír|strong="H8165"\w*. \w Los|strong="H1121"\w* \w puso|strong="H5975"\w* \w para|strong="H1961"\w* \w que|strong="H1121"\w* fueran sus \tl ʼelohim\tl*, \w se|strong="H1961"\w* postró \w ante|strong="H6440"\w* ellos y les quemó incienso.   
\p
\v 15 Entonces la ira \w de|strong="H5971"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w se|strong="H3808"\w* encendió contra Amasías, y le \w envió|strong="H7971"\w* \w a|strong="H3068"\w* un \w profeta|strong="H5030"\w* \w quien|strong="H4100"\w* le dijo: ¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* fuiste tras los \tl ʼelohim\tl* \w de|strong="H5971"\w* un \w pueblo|strong="H5971"\w* \w que|strong="H4100"\w* \w no|strong="H3808"\w* pudo ser \w librado|strong="H5337"\w* \w de|strong="H5971"\w* tu \w mano|strong="H3027"\w*?   
\p
\v 16 \w Cuando|strong="H3588"\w* \add el profeta\add* le \w hablaba|strong="H1696"\w* \w estas|strong="H2063"\w* \w cosas|strong="H3045"\w*, \w él|strong="H3588"\w* respondió: ¿\w Te|strong="H3588"\w* designamos \w a|strong="H3068"\w* ti \w como|strong="H4100"\w* \w consejero|strong="H3289"\w* del \w rey|strong="H4428"\w*? \w Déjate|strong="H2308"\w* \w de|strong="H3588"\w* \w eso|strong="H2063"\w*. ¿\w Por|strong="H3588"\w* \w qué|strong="H3588"\w* quieres \w que|strong="H3588"\w* \w te|strong="H3588"\w* maten?  
\p \w Entonces|strong="H3588"\w* \w el|strong="H3588"\w* \w profeta|strong="H5030"\w* desistió, \w pero|strong="H3588"\w* agregó: \w Yo|strong="H3588"\w* \w sé|strong="H3045"\w* \w que|strong="H3588"\w* \nd ʼElohim\nd* determinó \w destruirte|strong="H7843"\w*, \w porque|strong="H3588"\w* \w hiciste|strong="H6213"\w* \w esto|strong="H2063"\w* \w y|strong="H3588"\w* \w no|strong="H3808"\w* atendiste \w mi|strong="H1961"\w* \w consejo|strong="H6098"\w*.   
\p
\v 17 Después \w de|strong="H6440"\w* tomar \w consejo|strong="H3289"\w* Amasías, \w rey|strong="H4428"\w* \w de|strong="H6440"\w* \w Judá|strong="H3063"\w*, \w envió|strong="H7971"\w* \w a|strong="H3068"\w* decir \w a|strong="H3068"\w* \w Joás|strong="H3101"\w*, \w hijo|strong="H1121"\w* \w de|strong="H6440"\w* Joacaz, \w hijo|strong="H1121"\w* \w de|strong="H6440"\w* \w Jehú|strong="H3058"\w*, \w rey|strong="H4428"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*: ¡\w Ven|strong="H7200"\w*, enfrentémonos \w el|strong="H1121"\w* uno \w al|strong="H4428"\w* otro!   
\p
\v 18 \w Joás|strong="H3101"\w*, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, \w envió|strong="H7971"\w* \w a|strong="H3068"\w* decir \w a|strong="H3068"\w* Amasías, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*: \w El|strong="H1121"\w* cardo del \w Líbano|strong="H3844"\w* \w envió|strong="H7971"\w* \w a|strong="H3068"\w* decir \w al|strong="H4428"\w* cedro del \w Líbano|strong="H3844"\w*: \w Da|strong="H5414"\w* tu \w hija|strong="H1323"\w* como esposa \w a|strong="H3068"\w* mi \w hijo|strong="H1121"\w*. \w Y|strong="H3068"\w* \w pasó|strong="H5674"\w* una fiera del \w Líbano|strong="H3844"\w* y pisoteó \w el|strong="H1121"\w* cardo.  
\v 19 Tú dices: \w Ciertamente|strong="H2009"\w* derroté \w a|strong="H3068"\w* Edom, y \w con|strong="H5973"\w* eso tu \w corazón|strong="H3820"\w* \w se|strong="H4100"\w* enaltece \w para|strong="H5973"\w* ufanarte. \w Quédate|strong="H3427"\w* \w ahora|strong="H6258"\w* \w en|strong="H5973"\w* tu \w casa|strong="H1004"\w*. ¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* provocas un \w mal|strong="H7451"\w* \w en|strong="H5973"\w* \w el|strong="H5973"\w* \w cual|strong="H4100"\w* puedes \w caer|strong="H5307"\w* tú y \w Judá|strong="H3063"\w* \w contigo|strong="H5973"\w*?   
\p
\v 20 \w Pero|strong="H3588"\w* Amasías \w no|strong="H3808"\w* \w escuchó|strong="H8085"\w*, \w porque|strong="H3588"\w* \w esto|strong="H1931"\w* estaba determinado \w por|strong="H3588"\w* \nd ʼElohim\nd*, \w Quien|strong="H1931"\w* \w los|strong="H1931"\w* quería entregar \w en|strong="H3588"\w* \w su|strong="H1931"\w* \w mano|strong="H3027"\w* \w por|strong="H3588"\w* \w haber|strong="H3808"\w* ido tras \w los|strong="H1931"\w* \tl ʼelohim\tl* \w de|strong="H3588"\w* Edom.   
\p
\v 21 \w Joás|strong="H3101"\w*, \w rey|strong="H4428"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*, \w subió|strong="H5927"\w* y \w se|strong="H1931"\w* enfrentó \w a|strong="H3068"\w* Amasías, \w rey|strong="H4428"\w* \w de|strong="H6440"\w* \w Judá|strong="H3063"\w*, en Bet-semes, \w que|strong="H1931"\w* pertenece \w a|strong="H3068"\w* \w Judá|strong="H3063"\w*.  
\v 22 \w Judá|strong="H3063"\w* \w fue|strong="H3063"\w* derrotado \w por|strong="H6440"\w* \w Israel|strong="H3478"\w*, y \w huyeron|strong="H5127"\w* cada uno \w a|strong="H3068"\w* sus tiendas.  
\v 23 \w Joás|strong="H3101"\w*, \w rey|strong="H4428"\w* \w de|strong="H5704"\w* \w Israel|strong="H3478"\w*, capturó \w a|strong="H3068"\w* Amasías, \w rey|strong="H4428"\w* \w de|strong="H5704"\w* \w Judá|strong="H3063"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5704"\w* \w Joás|strong="H3101"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5704"\w* Joacaz, \w en|strong="H5704"\w* Bet-semes, \w y|strong="H5704"\w* \w lo|strong="H5704"\w* llevó \w a|strong="H3068"\w* Jerusalén. Abrió una brecha \w de|strong="H5704"\w* 180 metros \w en|strong="H5704"\w* \w el|strong="H1121"\w* \w muro|strong="H2346"\w* \w de|strong="H5704"\w* Jerusalén, \w desde|strong="H5704"\w* la \w puerta|strong="H8179"\w* \w de|strong="H5704"\w* Efraín \w hasta|strong="H5704"\w* la \w puerta|strong="H8179"\w* \w de|strong="H5704"\w* la Esquina.  
\v 24 Tomó \w todo|strong="H3605"\w* \w el|strong="H5973"\w* \w oro|strong="H2091"\w*, \w la|strong="H3605"\w* \w plata|strong="H3701"\w* y \w todos|strong="H3605"\w* \w los|strong="H1121"\w* utensilios \w que|strong="H1121"\w* fueron hallados \w en|strong="H5973"\w* \w la|strong="H3605"\w* \w Casa|strong="H1004"\w* \w de|strong="H5973"\w* \nd ʼElohim\nd* \w a|strong="H3068"\w* cargo \w de|strong="H5973"\w* \w Obed-edom|strong="H5654"\w*, y también \w los|strong="H1121"\w* tesoros \w del|strong="H5973"\w* palacio \w real|strong="H4428"\w*. Tomó rehenes y \w volvió|strong="H7725"\w* \w a|strong="H3068"\w* \w Samaria|strong="H8111"\w*.   
\p
\v 25 Amasías, \w hijo|strong="H1121"\w* \w de|strong="H2568"\w* \w Joás|strong="H3101"\w*, \w rey|strong="H4428"\w* \w de|strong="H2568"\w* \w Judá|strong="H3063"\w*, \w vivió|strong="H2421"\w* 15 \w años|strong="H8141"\w* después \w de|strong="H2568"\w* la \w muerte|strong="H4191"\w* \w de|strong="H2568"\w* \w Joás|strong="H3101"\w*, \w hijo|strong="H1121"\w* \w de|strong="H2568"\w* Joacaz, \w rey|strong="H4428"\w* \w de|strong="H2568"\w* \w Israel|strong="H3478"\w*.  
\v 26 \w Los|strong="H5921"\w* demás \w hechos|strong="H1697"\w* \w de|strong="H5921"\w* Amasías, \w primeros|strong="H7223"\w* \w y|strong="H5921"\w* últimos, \w ciertamente|strong="H2005"\w* ¿\w no|strong="H3808"\w* están \w escritos|strong="H3789"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* rollo \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w Reyes|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w* \w y|strong="H5921"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*?   
\p
\v 27 \w Desde|strong="H5921"\w* \w el|strong="H5921"\w* \w tiempo|strong="H6256"\w* \w cuando|strong="H6256"\w* Amasías \w se|strong="H5921"\w* apartó \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, tramaron una conjura \w contra|strong="H5921"\w* \w él|strong="H5921"\w* \w en|strong="H5921"\w* Jerusalén. \w Él|strong="H5921"\w* \w huyó|strong="H5127"\w* \w a|strong="H3068"\w* Laquis, pero \w enviaron|strong="H7971"\w* tras \w él|strong="H5921"\w* \w a|strong="H3068"\w* Laquis, \w y|strong="H5921"\w* \w allá|strong="H8033"\w* \w lo|strong="H5921"\w* \w mataron|strong="H4191"\w*.  
\v 28 \w Lo|strong="H5921"\w* \w llevaron|strong="H5375"\w* \w sobre|strong="H5921"\w* \w caballos|strong="H5483"\w* \w y|strong="H5921"\w* \w lo|strong="H5921"\w* \w sepultaron|strong="H6912"\w* \w con|strong="H5973"\w* sus antepasados \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*.   
\c 26  
\s1 Reinado de Uzías en Judá  
\p
\v 1 Entonces \w todo|strong="H3605"\w* \w el|strong="H1931"\w* \w pueblo|strong="H5971"\w* \w de|strong="H8478"\w* \w Judá|strong="H3063"\w* \w tomó|strong="H3947"\w* \w a|strong="H3068"\w* Uzías, \w que|strong="H1931"\w* \w tenía|strong="H1931"\w* 16 \w años|strong="H8141"\w*, y \w lo|strong="H1931"\w* proclamaron \w rey|strong="H4427"\w* \w en|strong="H8478"\w* \w lugar|strong="H8478"\w* \w de|strong="H8478"\w* \w su|strong="H1931"\w* padre Amasías.  
\v 2 \w Él|strong="H1931"\w* reconstruyó Eilat y \w la|strong="H1931"\w* \w restituyó|strong="H7725"\w* \w a|strong="H3068"\w* \w Judá|strong="H3063"\w*, después \w que|strong="H1931"\w* \w el|strong="H1931"\w* \w rey|strong="H4428"\w* reposó \w con|strong="H5973"\w* \w sus|strong="H1931"\w* antepasados.   
\p
\v 3 Uzías tenía 16 \w años|strong="H8141"\w* cuando comenzó \w a|strong="H3068"\w* reinar, y \w reinó|strong="H4427"\w* 52 \w años|strong="H8141"\w* \w en|strong="H4480"\w* Jerusalén. \w El|strong="H1121"\w* \w nombre|strong="H8034"\w* \w de|strong="H4480"\w* su madre fue Jecolías \w de|strong="H4480"\w* Jerusalén.  
\v 4 \w Hizo|strong="H6213"\w* \w lo|strong="H6213"\w* \w recto|strong="H3477"\w* ante \nd \+w Yavé|strong="H3068"\+w*\nd*, según \w todo|strong="H3605"\w* \w lo|strong="H6213"\w* \w que|strong="H3605"\w* \w hizo|strong="H6213"\w* su padre Amasías.  
\v 5 Persistió en buscar \w a|strong="H3068"\w* \nd ʼElohim\nd* en el \w tiempo|strong="H3117"\w* de \w Zacarías|strong="H2148"\w*, entendido en visiones de \nd ʼElohim\nd*. \w Y|strong="H3068"\w* en el \w tiempo|strong="H3117"\w* \w cuando|strong="H3117"\w* \w buscó|strong="H1875"\w* \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*, ʼElohim\nd* lo prosperó.   
\p
\v 6 \w Salió|strong="H3318"\w* \w a|strong="H3068"\w* combatir contra los \w filisteos|strong="H6430"\w* y derribó el \w muro|strong="H2346"\w* \w de|strong="H3898"\w* Gat, el \w de|strong="H3898"\w* Jabnia y el \w de|strong="H3898"\w* Asdod. \w Edificó|strong="H1129"\w* \w ciudades|strong="H5892"\w* \w en|strong="H3318"\w* la región \w de|strong="H3898"\w* Asdod, entre los \w filisteos|strong="H6430"\w*.  
\v 7 \nd ʼElohim\nd* \w lo|strong="H5921"\w* \w ayudó|strong="H5826"\w* \w contra|strong="H5921"\w* \w los|strong="H3427"\w* \w filisteos|strong="H6430"\w*, \w contra|strong="H5921"\w* \w los|strong="H3427"\w* árabes \w que|strong="H5921"\w* \w vivían|strong="H3427"\w* \w en|strong="H5921"\w* Gur-baal, \w y|strong="H5921"\w* \w contra|strong="H5921"\w* \w los|strong="H3427"\w* meunitas.  
\v 8 \w Los|strong="H3588"\w* amonitas pagaron \w tributo|strong="H4503"\w* \w a|strong="H3068"\w* Uzías. \w Su|strong="H3588"\w* \w fama|strong="H8034"\w* se extendió \w hasta|strong="H5704"\w* \w la|strong="H3588"\w* entrada \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w*, \w pues|strong="H3588"\w* \w fue|strong="H3212"\w* \w muy|strong="H4605"\w* \w poderoso|strong="H2388"\w*.   
\p
\v 9 Uzías también \w edificó|strong="H1129"\w* \w torres|strong="H4026"\w* \w en|strong="H5921"\w* Jerusalén \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w puerta|strong="H8179"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* Esquina, \w en|strong="H5921"\w* \w la|strong="H5921"\w* entrada \w del|strong="H5921"\w* \w Valle|strong="H1516"\w* \w y|strong="H5921"\w* \w junto|strong="H5921"\w* \w al|strong="H5921"\w* ángulo. \w Las|strong="H5921"\w* \w fortificó|strong="H2388"\w*.  
\v 10 También \w edificó|strong="H1129"\w* \w torres|strong="H4026"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* región despoblada. Excavó \w muchas|strong="H7227"\w* cisternas, \w pues|strong="H3588"\w* \w tenía|strong="H1961"\w* \w mucho|strong="H7227"\w* \w ganado|strong="H4735"\w*, tanto \w en|strong="H3588"\w* \w la|strong="H3588"\w* Sefela \w como|strong="H3588"\w* \w en|strong="H3588"\w* las vegas. \w Tenía|strong="H1961"\w* \w además|strong="H3588"\w* agricultores \w y|strong="H3588"\w* viñadores \w en|strong="H3588"\w* las montañas \w y|strong="H3588"\w* \w en|strong="H3588"\w* \w los|strong="H1961"\w* campos fértiles, \w pues|strong="H3588"\w* amaba \w la|strong="H3588"\w* agricultura.   
\p
\v 11 Uzías \w tuvo|strong="H1961"\w* un \w ejército|strong="H2428"\w* \w de|strong="H5921"\w* \w guerreros|strong="H6213"\w* \w que|strong="H5921"\w* \w salían|strong="H3318"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w guerra|strong="H4421"\w* \w por|strong="H5921"\w* divisiones, \w según|strong="H5921"\w* \w la|strong="H5921"\w* lista elaborada \w por|strong="H5921"\w* \w el|strong="H5921"\w* \w escriba|strong="H5608"\w* \w Jeiel|strong="H3273"\w*, \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w magistrado|strong="H6486"\w* \w Maasías|strong="H4641"\w*, dirigidos \w por|strong="H5921"\w* \w Hananías|strong="H2608"\w*, uno \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w jefes|strong="H8269"\w* \w del|strong="H5921"\w* \w rey|strong="H4428"\w*.  
\v 12 \w El|strong="H3605"\w* \w número|strong="H4557"\w* total de \w jefes|strong="H7218"\w* de casas paternas, \w hombres|strong="H1368"\w* \w valientes|strong="H1368"\w*, era 2.600,  
