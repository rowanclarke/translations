\p 
\v 19 \w Y|strong="H3068"\w* Micaías respondió: \w Por|strong="H5921"\w* \w eso|strong="H3651"\w* \w escuchen|strong="H8085"\w* \w la|strong="H5921"\w* \w Palabra|strong="H1697"\w* \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd*: \wj \w Vi|strong="H7200"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w sentado|strong="H3427"\w* \w en|strong="H5921"\w* su \w trono|strong="H3678"\w*. \w Todo|strong="H3605"\w* \w el|strong="H5921"\w* \w ejército|strong="H6635"\w* \w de|strong="H5921"\w* \w los|strong="H3427"\w* \w cielos|strong="H8064"\w* \w estaba|strong="H5975"\w* \w en|strong="H5921"\w* \w pie|strong="H5975"\w* \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w Él|strong="H5921"\w*, \w a|strong="H3068"\w* su \w derecha|strong="H3225"\w* \w y|strong="H5921"\w* \w a|strong="H3068"\w* su \w izquierda|strong="H8040"\w*.\wj*
\v 20 \w Y|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* decía: \wj ¿\w Quién|strong="H4310"\w* \w inducirá|strong="H6601"\w* \w a|strong="H3068"\w* Acab para \w que|strong="H4310"\w* \w suba|strong="H5927"\w* \w y|strong="H3541"\w* \w caiga|strong="H5307"\w* en Ramot de \w Galaad|strong="H1568"\w*?\wj*
\p \w Y|strong="H3068"\w* uno respondía de una manera \w y|strong="H3541"\w* \w otro|strong="H2088"\w* de otra.
\v 21 \w Salió|strong="H3318"\w* un \w espíritu|strong="H7307"\w* y se colocó \w ante|strong="H6440"\w* \nd \w Yavé|strong="H3068"\w*\nd*, y dijo: Yo lo induciré.
\p \w Y|strong="H3068"\w* le preguntó \nd \w Yavé|strong="H3068"\w*\nd*: \wj ¿\w De|strong="H6440"\w* cuál modo?\wj*
\p 
\v 22 \w Y|strong="H3068"\w* respondió: \w Saldré|strong="H3318"\w* \w y|strong="H1571"\w* \w seré|strong="H1961"\w* \w espíritu|strong="H7307"\w* de \w mentira|strong="H8267"\w* \w en|strong="H3318"\w* \w la|strong="H1571"\w* \w boca|strong="H6310"\w* de \w todos|strong="H3605"\w* sus \w profetas|strong="H5030"\w*.
\p \w Y|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* dijo: \wj \w Tú|strong="H6213"\w* \w lo|strong="H6213"\w* inducirás \w y|strong="H1571"\w* prevalecerás. ¡Vé \w y|strong="H1571"\w* \w hazlo|strong="H6213"\w* \w así|strong="H3651"\w*!\wj*
\p 
\v 23 \w Ahora|strong="H6258"\w*, \w ciertamente|strong="H2009"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w puso|strong="H5414"\w* un \w espíritu|strong="H7307"\w* \w de|strong="H5921"\w* \w mentira|strong="H8267"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w boca|strong="H6310"\w* \w de|strong="H5921"\w* \w todos|strong="H3605"\w* \w estos|strong="H3605"\w* \w profetas|strong="H5030"\w* tuyos, \w pues|strong="H6258"\w* \nd \w Yavé|strong="H3068"\w*\nd* decretó \w el|strong="H5921"\w* \w mal|strong="H7451"\w* \w contra|strong="H5921"\w* \w ti|strong="H5921"\w*.
\p 
\v 24 Entonces Sedequías, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Quenaana, \w se|strong="H5921"\w* \w acercó|strong="H5066"\w*, golpeó \w a|strong="H3068"\w* Micaías \w en|strong="H5921"\w* \w la|strong="H5921"\w* mejilla \w y|strong="H5921"\w* \w dijo|strong="H1696"\w*: ¿\w Por|strong="H5921"\w* cuál camino \w pasó|strong="H5674"\w* \w de|strong="H5921"\w* \w mí|strong="H5921"\w* \w el|strong="H5921"\w* \w Espíritu|strong="H7307"\w* \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w para|strong="H5921"\w* \w hablarte|strong="H1696"\w* \w a|strong="H3068"\w* \w ti|strong="H5921"\w*?
\p 
\v 25 \w Y|strong="H3068"\w* Micaías respondió: ¡\w Mira|strong="H7200"\w*, \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* tú \w lo|strong="H1931"\w* \w verás|strong="H7200"\w*, \w cuando|strong="H3117"\w* vayas de aposento en aposento para esconderte!
\p 
\v 26 \w Entonces|strong="H7725"\w* \w el|strong="H1121"\w* \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* dijo: \w Toma|strong="H3947"\w* \w a|strong="H3068"\w* Micaías, hazlo \w volver|strong="H7725"\w* \w a|strong="H3068"\w* Amón, \w gobernador|strong="H8269"\w* \w de|strong="H1121"\w* la \w ciudad|strong="H5892"\w*, y \w a|strong="H3068"\w* \w Joás|strong="H3101"\w*, \w hijo|strong="H1121"\w* del \w rey|strong="H4428"\w*,
\v 27 \w y|strong="H5704"\w* di: \w Así|strong="H3541"\w* dijo el \w rey|strong="H4428"\w*: Metan \w a|strong="H3068"\w* \w éste|strong="H2088"\w* \w en|strong="H5704"\w* la cárcel, \w y|strong="H5704"\w* denle \w pan|strong="H3899"\w* \w y|strong="H5704"\w* \w agua|strong="H4325"\w* \w de|strong="H5704"\w* aflicción \w hasta|strong="H5704"\w* \w que|strong="H5704"\w* yo vuelva \w en|strong="H5704"\w* \w paz|strong="H7965"\w*.
\p 
\v 28 Micaías \w respondió|strong="H7725"\w*: ¡\w Si|strong="H3808"\w* \w vuelves|strong="H7725"\w* en \w paz|strong="H7965"\w*, \nd \w Yavé|strong="H3068"\w*\nd* \w no|strong="H3808"\w* \w habló|strong="H1696"\w* por medio \w de|strong="H5971"\w* mí! \w Y|strong="H3068"\w* agregó: ¡Escúchenlo, \w pueblos|strong="H5971"\w* \w todos|strong="H3605"\w*!
\p 
\v 29 Enseguida el \w rey|strong="H4428"\w* de \w Israel|strong="H3478"\w* \w subió|strong="H5927"\w* con Josafat, \w rey|strong="H4428"\w* de \w Judá|strong="H3063"\w*, \w contra|strong="H3478"\w* Ramot de \w Galaad|strong="H1568"\w*.
\v 30 \w Y|strong="H3068"\w* el \w rey|strong="H4428"\w* \w de|strong="H3847"\w* \w Israel|strong="H3478"\w* dijo \w a|strong="H3068"\w* Josafat: Yo me disfrazaré para entrar en la \w batalla|strong="H4421"\w*, pero tú cúbrete con tus ropas \w reales|strong="H4428"\w*. \w Y|strong="H3068"\w* el \w rey|strong="H4428"\w* \w de|strong="H3847"\w* \w Israel|strong="H3478"\w* se disfrazó y entró en la \w batalla|strong="H4421"\w*.
\p 
\v 31 \w Pero|strong="H3588"\w* \w el|strong="H3588"\w* \w rey|strong="H4428"\w* \w de|strong="H3588"\w* Siria \w ordenó|strong="H6680"\w* \w a|strong="H3068"\w* \w los|strong="H3588"\w* 32 \w capitanes|strong="H8269"\w* \w de|strong="H3588"\w* \w los|strong="H3588"\w* carruajes \w que|strong="H3588"\w* tenía: \w No|strong="H3808"\w* luchen \w contra|strong="H3478"\w* \w pequeño|strong="H6996"\w* \w ni|strong="H3808"\w* \w contra|strong="H3478"\w* \w grande|strong="H1419"\w*, \w sino|strong="H3588"\w* solo \w contra|strong="H3478"\w* \w el|strong="H3588"\w* \w rey|strong="H4428"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*.
\v 32 \w Sucedió|strong="H1961"\w* \w que|strong="H1931"\w* \w cuando|strong="H1961"\w* \w los|strong="H1992"\w* \w capitanes|strong="H8269"\w* \w de|strong="H5921"\w* \w los|strong="H1992"\w* carruajes \w vieron|strong="H7200"\w* \w a|strong="H3068"\w* Josafat, dijeron: ¡\w De|strong="H5921"\w* seguro \w ése|strong="H1931"\w* \w es|strong="H1931"\w* \w el|strong="H1931"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*! \w Y|strong="H3068"\w* \w se|strong="H1961"\w* dirigieron \w a|strong="H3068"\w* \w él|strong="H1931"\w* \w para|strong="H5921"\w* atacarlo, pero Josafat \w clamó|strong="H2199"\w*.
\v 33 \w Al|strong="H4428"\w* \w ver|strong="H7200"\w* \w los|strong="H1931"\w* \w capitanes|strong="H8269"\w* \w de|strong="H3588"\w* \w los|strong="H1931"\w* carruajes \w que|strong="H3588"\w* \w no|strong="H3808"\w* \w era|strong="H1961"\w* \w el|strong="H1931"\w* \w rey|strong="H4428"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*, \w se|strong="H1961"\w* apartaron \w de|strong="H3588"\w* \w él|strong="H1931"\w*.
\p 
\v 34 Un hombre tiró \w con|strong="H4480"\w* \w su|strong="H3588"\w* \w arco|strong="H7198"\w* \add una flecha\add* \w a|strong="H3068"\w* \w la|strong="H3588"\w* ventura \w e|strong="H3068"\w* \w hirió|strong="H5221"\w* \w al|strong="H4480"\w* \w rey|strong="H4428"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w* \w entre|strong="H3588"\w* las junturas \w de|strong="H4480"\w* \w la|strong="H3588"\w* armadura. \w Y|strong="H3068"\w* \w el|strong="H3588"\w* \w rey|strong="H4428"\w* dijo \w al|strong="H4480"\w* \w que|strong="H3588"\w* manejaba \w el|strong="H3588"\w* caballo \w de|strong="H4480"\w* \w su|strong="H3588"\w* carruaje: ¡Da \w vuelta|strong="H2015"\w* \w y|strong="H3588"\w* \w sácame|strong="H3318"\w* \w del|strong="H4480"\w* \w campamento|strong="H4264"\w*, \w porque|strong="H3588"\w* estoy herido!
\v 35 Pero \w la|strong="H1931"\w* \w batalla|strong="H4421"\w* arreció \w aquel|strong="H1931"\w* \w día|strong="H3117"\w*. \w Por|strong="H4428"\w* tanto, \w el|strong="H1931"\w* \w rey|strong="H4428"\w* \w fue|strong="H1961"\w* sostenido \w en|strong="H5975"\w* \w su|strong="H1931"\w* carruaje frente \w a|strong="H3068"\w* \w los|strong="H1931"\w* sirios. \w Al|strong="H4428"\w* llegar \w la|strong="H1931"\w* noche \w murió|strong="H4191"\w*. \w La|strong="H1931"\w* \w sangre|strong="H1818"\w* \w de|strong="H1818"\w* \w la|strong="H1931"\w* herida corrió \w hasta|strong="H3117"\w* \w el|strong="H1931"\w* fondo del carruaje.
\v 36 Al ocultarse \w el|strong="H5674"\w* \w sol|strong="H8121"\w*, \w salió|strong="H5674"\w* un pregón por \w el|strong="H5674"\w* \w campamento|strong="H4264"\w*: ¡Cada uno \w a|strong="H3068"\w* su \w ciudad|strong="H5892"\w*! ¡Cada uno \w a|strong="H3068"\w* su tierra!
\p 
\v 37 Así \w murió|strong="H4191"\w* el \w rey|strong="H4428"\w*. Fue llevado \w a|strong="H3068"\w* \w Samaria|strong="H8111"\w*, y allí lo \w sepultaron|strong="H6912"\w*.
\v 38 Mientras uno lavaba \w el|strong="H5921"\w* carruaje \w junto|strong="H5921"\w* \w al|strong="H5921"\w* \w estanque|strong="H1295"\w* \w de|strong="H5921"\w* \w Samaria|strong="H8111"\w* \w donde|strong="H5921"\w* \w las|strong="H5921"\w* prostitutas \w se|strong="H5921"\w* \w lavaban|strong="H7364"\w*, \w los|strong="H5921"\w* \w perros|strong="H3611"\w* \w lamieron|strong="H3952"\w* su \w sangre|strong="H1818"\w*, \w conforme|strong="H5921"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w Palabra|strong="H1697"\w* \w que|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w habló|strong="H1696"\w*.
\p 
\v 39 \w Los|strong="H1992"\w* demás \w hechos|strong="H1697"\w* \w y|strong="H5921"\w* \w cosas|strong="H1697"\w* \w de|strong="H5921"\w* Acab, \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w marfil|strong="H8127"\w* \w y|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H1992"\w* \w ciudades|strong="H5892"\w* \w que|strong="H3808"\w* \w edificó|strong="H1129"\w*, ¿\w no|strong="H3808"\w* están \w escritos|strong="H3789"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* rollo \w de|strong="H5921"\w* \w las|strong="H1992"\w* Crónicas \w de|strong="H5921"\w* \w los|strong="H1992"\w* \w reyes|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*?
\v 40 Acab descansó \w con|strong="H5973"\w* sus antepasados, y su \w hijo|strong="H1121"\w* Ocozías \w reinó|strong="H4427"\w* \w en|strong="H5973"\w* su \w lugar|strong="H8478"\w*.
\s1 Reinado de Josafat en Judá
\p 
\v 41 Josafat, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Asa, comenzó \w a|strong="H3068"\w* reinar \w en|strong="H5921"\w* \w Judá|strong="H3063"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* cuarto \w año|strong="H8141"\w* \w de|strong="H5921"\w* Acab, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.
\v 42 Josafat tenía 35 \w años|strong="H8141"\w* cuando comenzó \w a|strong="H3068"\w* reinar, y \w reinó|strong="H4427"\w* 25 \w años|strong="H8141"\w* en Jerusalén. \w El|strong="H1121"\w* \w nombre|strong="H8034"\w* \w de|strong="H2568"\w* su madre fue \w Azuba|strong="H5806"\w*, \w hija|strong="H1323"\w* \w de|strong="H2568"\w* \w Silhi|strong="H7977"\w*.
\v 43 \w Él|strong="H3605"\w* \w anduvo|strong="H3212"\w* \w en|strong="H4480"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w camino|strong="H1870"\w* \w de|strong="H4480"\w* su padre Asa, \w sin|strong="H3808"\w* \w apartarse|strong="H5493"\w* \w de|strong="H4480"\w* \w él|strong="H3605"\w*, \w e|strong="H3068"\w* \w hizo|strong="H6213"\w* \w lo|strong="H3808"\w* \w recto|strong="H3477"\w* ante \nd \w Yavé|strong="H3068"\w*\nd*. Pero \w los|strong="H3605"\w* lugares altos \w no|strong="H3808"\w* \w fueron|strong="H3212"\w* quitados, \w porque|strong="H3808"\w* \w aún|strong="H3808"\w* \w el|strong="H3605"\w* pueblo ofrecía sacrificios y quemaba incienso \w de|strong="H4480"\w* continuo allí.
\v 44 Josafat estableció la paz con el rey \w de|strong="H5750"\w* Israel.
\p 
\v 45 \w Los|strong="H5973"\w* demás hechos \w de|strong="H5973"\w* Josafat, \w el|strong="H5973"\w* poderío que logró y las guerras que peleó, ¿no están escritos \w en|strong="H5973"\w* \w el|strong="H5973"\w* rollo \w de|strong="H5973"\w* las Crónicas \w de|strong="H5973"\w* \w los|strong="H5973"\w* \w reyes|strong="H4428"\w* \w de|strong="H5973"\w* Judá?
\v 46 \w Él|strong="H5921"\w* eliminó \w el|strong="H5921"\w* \w resto|strong="H3499"\w* \w de|strong="H5921"\w* \w los|strong="H1992"\w* varones sodomitas \w del|strong="H5921"\w* país \w que|strong="H3808"\w* quedaron \w del|strong="H5921"\w* \w tiempo|strong="H3117"\w* \w de|strong="H5921"\w* \w su|strong="H1992"\w* padre Asa.
\v 47 \w En|strong="H4480"\w* ese \w tiempo|strong="H3117"\w* no había rey \w en|strong="H4480"\w* Edom, sino un gobernador \w de|strong="H4480"\w* parte \w del|strong="H4480"\w* rey.
\p 
\v 48 Josafat hizo naves como las de Tarsis, para ir \w a|strong="H3068"\w* Ofir \w a|strong="H3068"\w* buscar oro, pero nunca fueron, pues las naves se destrozaron en Ezión-geber.
\v 49 Ocozías, hijo \w de|strong="H3588"\w* Acab, dijo \w a|strong="H3068"\w* Josafat: \w Que|strong="H3588"\w* \w vayan|strong="H3212"\w* mis esclavos \w con|strong="H3588"\w* \w los|strong="H3588"\w* tuyos \w en|strong="H3588"\w* las naves, \w pero|strong="H3588"\w* Josafat \w no|strong="H3808"\w* quiso.
\p 
\v 50 Josafat descansó \w con|strong="H5973"\w* sus antepasados, y \w fue|strong="H3212"\w* sepultado \w con|strong="H5973"\w* ellos \w en|strong="H5973"\w* la ciudad \w de|strong="H5973"\w* David, su antepasado. Su \w hijo|strong="H1121"\w* Joram reinó \w en|strong="H5973"\w* su lugar.
\s1 Reinado de Ocozías en Israel
\p 
\v 51 \w El|strong="H5973"\w* año 17 \w de|strong="H8478"\w* Josafat, \w rey|strong="H4427"\w* \w de|strong="H8478"\w* Judá, Ocozías, \w hijo|strong="H1121"\w* \w de|strong="H8478"\w* Acab, comenzó \w a|strong="H3068"\w* reinar sobre Israel \w en|strong="H5973"\w* Samaria, y \w reinó|strong="H4427"\w* dos años.
\v 52 Hizo \w lo|strong="H5921"\w* malo ante \nd \w Yavé|strong="H3068"\w*\nd*. Anduvo \w en|strong="H5921"\w* \w el|strong="H5921"\w* camino \w de|strong="H5921"\w* su padre, su madre, \w y|strong="H5921"\w* \w de|strong="H5921"\w* Jeroboam, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Nabat, quien estimuló \w a|strong="H3068"\w* \w Israel|strong="H3478"\w* \w a|strong="H3068"\w* pecar.
\v 53 Sirvió \w a|strong="H3068"\w* baal y se postró ante \w él|strong="H1121"\w*. Provocó la \w ira|strong="H3212"\w* \w de|strong="H1121"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w el|strong="H1121"\w* \nd ʼElohim\nd* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, conforme \w a|strong="H3068"\w* todas las \w cosas|strong="H7451"\w* \w que|strong="H1121"\w* \w hizo|strong="H6213"\w* su padre. 
