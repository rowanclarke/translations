\v 4  Eleazar \w the|strong="H6440"\w* \w priest|strong="H3548"\w* \w is|strong="H6440"\w* \w to|strong="H6440"\w* \w take|strong="H3947"\w* some \w of|strong="H6440"\w* \w its|strong="H3947"\w* \w blood|strong="H1818"\w* \w with|strong="H6440"\w* \w his|strong="H3947"\w* finger, \w and|strong="H3548"\w* \w sprinkle|strong="H5137"\w* some \w of|strong="H6440"\w* \w the|strong="H6440"\w* \w blood|strong="H1818"\w* \w seven|strong="H7651"\w* \w times|strong="H6471"\w* \w directly|strong="H5227"\w* \w in|strong="H6440"\w* \w front|strong="H6440"\w* \w of|strong="H6440"\w* \w the|strong="H6440"\w* tent \w of|strong="H6440"\w* \w meeting|strong="H4150"\w*.  
\v 5  Then \w the|strong="H5921"\w* \w heifer|strong="H6510"\w* \w must|strong="H1818"\w* \w be|strong="H5869"\w* \w burned|strong="H8313"\w* \w in|strong="H5921"\w* \w his|strong="H5921"\w* \w sight|strong="H5869"\w* – \w its|strong="H5921"\w* \w skin|strong="H5785"\w*, \w its|strong="H5921"\w* \w flesh|strong="H1320"\w*, \w its|strong="H5921"\w* \w blood|strong="H1818"\w*, \w and|strong="H5869"\w* \w its|strong="H5921"\w* \w offal|strong="H6569"\w* \w is|strong="H1320"\w* \w to|strong="H5921"\w* \w be|strong="H5869"\w* \w burned|strong="H8313"\w*.  
\v 6  \w And|strong="H6086"\w* \w the|strong="H3947"\w* \w priest|strong="H3548"\w* \w must|strong="H3947"\w* \w take|strong="H3947"\w* cedar \w wood|strong="H6086"\w*, hyssop, \w and|strong="H6086"\w* \w scarlet|strong="H8144"\w* wool \w and|strong="H6086"\w* \w throw|strong="H7993"\w* \w them|strong="H3947"\w* \w into|strong="H8432"\w* \w the|strong="H3947"\w* \w midst|strong="H8432"\w* \w of|strong="H8432"\w* \w the|strong="H3947"\w* \w fire|strong="H8316"\w* where \w the|strong="H3947"\w* \w heifer|strong="H6510"\w* \w is|strong="H3548"\w* \w burning|strong="H8316"\w*.  
