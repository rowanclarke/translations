\v 26 \w Todas|strong="H3605"\w* las \w personas|strong="H5315"\w* \w que|strong="H1121"\w* fueron con \w Jacob|strong="H3290"\w* \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w*, sus descendientes directos, sin contar las esposas \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Jacob|strong="H3290"\w* fueron 66.   
\p
\v 27 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w José|strong="H3130"\w* \w que|strong="H1121"\w* le \w nacieron|strong="H3205"\w* en \w Egipto|strong="H4714"\w*, \w dos|strong="H8147"\w* \w personas|strong="H5315"\w*. \w Todas|strong="H3605"\w* las \w personas|strong="H5315"\w* \w de|strong="H1121"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w de|strong="H1121"\w* \w Jacob|strong="H3290"\w* \w que|strong="H1121"\w* entraron en \w Egipto|strong="H4714"\w* fueron 70.   
\p
\v 28 Jacob \w envió|strong="H7971"\w* \w a|strong="H3068"\w* \w Judá|strong="H3063"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* él \w a|strong="H3068"\w* la casa \w de|strong="H6440"\w* \w José|strong="H3130"\w* para que preparara el camino \w a|strong="H3068"\w* Gosén. Cuando entraron en la tierra \w de|strong="H6440"\w* Gosén,  
