\q1 \w the|strong="H4390"\w* voices \w of|strong="H4390"\w* \w your|strong="H4390"\w* \w messengers|strong="H4390"\w* will no longer be heard.”   
\c 3  
\p  
\q1
\v 1  \w Woe|strong="H1945"\w* \w to|strong="H5892"\w* \w the|strong="H3605"\w* \w city|strong="H5892"\w* guilty \w of|strong="H5892"\w* \w bloodshed|strong="H1818"\w*!  
