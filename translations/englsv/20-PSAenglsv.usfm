\c 2
\p 
\v 1 \w Why|strong="H4100"\w* \w have|strong="H1471"\w* \w nations|strong="H1471"\w* assembled tumultuously? \w And|strong="H1471"\w* \w peoples|strong="H3816"\w* \w meditate|strong="H1897"\w* \w vanity|strong="H7385"\w*?
\v 2 \w Kings|strong="H4428"\w* \w of|strong="H4428"\w* \w the|strong="H5921"\w* earth \w station|strong="H3320"\w* \w themselves|strong="H3320"\w*, \w and|strong="H3068"\w* \w princes|strong="H7336"\w* \w have|strong="H3068"\w* \w been|strong="H3068"\w* \w united|strong="H3162"\w* \w together|strong="H3162"\w*, \w against|strong="H5921"\w* \w YHWH|strong="H3068"\w*, \w and|strong="H3068"\w* \w against|strong="H5921"\w* \w His|strong="H3068"\w* \w Messiah|strong="H4899"\w*:
\v 3 “Let \w us|strong="H4480"\w* \w draw|strong="H5423"\w* \w off|strong="H5423"\w* \w Their|strong="H7993"\w* \w cords|strong="H5688"\w*, || \w And|strong="H4480"\w* \w cast|strong="H7993"\w* \w Their|strong="H7993"\w* thick \w bands|strong="H4147"\w* \w from|strong="H4480"\w* \w us|strong="H4480"\w*.”
