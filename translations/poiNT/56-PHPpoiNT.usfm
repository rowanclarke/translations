\id PHP
\h FILIPENSES
\toc1 Jém carta jém ijáyayñewɨɨp Pablo jém it́yajwɨɨp jém attebet Filipos
\toc2 FILIPENSES
\toc3 Fil.
\mt1 Jém carta jém ijáyayñewɨɨp Pablo jém it́yajwɨɨp jém attebet Filipos
\c 1
\s1 Jém Pablo ijáyáypa jém Dios ipɨxiñt́am jém it́yajwɨɨp Filipos
\p 
\v 1 Ɨch aPablo con jém aŋcompañero Timoteo aŋcuyo̱xatámpa jém Jesucristo. Sɨɨp manjáyáypa mimicht́am jém Dios mipɨxiñt́am jém iŋcupɨcnetaŋwɨɨp Jesucristo jém attebet Filipos. Anjáyáypat́im it́u̱mpɨy jém impastoryaj con it́u̱mpɨy jém diáconos jém icuyo̱xayajpaap jém Dios ipɨxiñt́am.
\v 2 Jém tanJa̱tuŋ Dios y jém tánO̱mi Jesucristo miwɨ̱wadáyiñ, michiit́ámiñ jém paz iga odoy iniid́iñ co̱bacpi̱ji íña̱namaŋjo̱m.
\s1 Jém Pablo iwatpa oración para jém iamigoyaj
\p 
\v 3 Cuando manjɨ̱spa, siempre anchiiba gracia jém tanJa̱tuŋ Dios para mimicht́am.
\v 4 Cuando anaŋwejpátpa Dios para mimicht́am iñt́u̱mpɨyt́am, tsa̱m amaymay porque
\v 5 dende wiñɨgam hasta sɨɨp, tawagayo̱xa̱p iga tanaŋmatpa jém wɨbɨc aŋma̱t́i.
\v 6 Ɨch aŋwɨ̱jo̱doŋ iga tanJa̱tuŋ Dios jém mojnewɨɨp iwat jém wɨbɨc yo̱xacuy íña̱namaŋjo̱m, seguido iwatpa hasta cupacpa cuando núcpa jém ja̱ma iga miñgacpa jém Jesucristo yɨ́p naxyucmɨ.
\v 7 Wɨ̱ iga manjɨ̱spa porque tsa̱m mantoypa. Agui anyo̱xpát cuando ait́ preso y cuando aŋcupuj jém wɨbɨc aŋma̱t́i jém aŋjagooyi iwiñjo̱m y anaŋmadáy iga nu̱ma jém aŋma̱t́i d́a je mɨgooyi. Mimicht́am miwɨ̱wadáyt́im Dios juuts ɨch awɨ̱wadayñe.
\v 8 Dios ijo̱doŋ iga tsa̱m pɨ̱mi mantoypa iñt́u̱mpɨyt́am con jém wɨbɨc tóyooyi jém iniit́wɨɨp Jesucristo.
\v 9 Anaŋwejpátpa Dios iga más iniit́t́ámiñ jém wɨbɨc tóyooyi íña̱namaŋjo̱m y iga michiiñ jáyaŋ jém wɨ̱tampɨc jɨ̱xi. Jesɨc más iŋcutɨɨyɨ́ypa t́i ixunpa Dios.
\v 10 Jesɨc wɨa̱p iŋcupiŋ jém wɨbɨc cosa. Jesɨc cuáyñe íña̱nama, d́a i̱ wɨa̱p miñɨ́máy iga mit́áŋcaɨ́y hasta jém ja̱ma cuando miñgacpa jém Cristo.
\v 11 Mimicht́am wattaamɨ jáyaŋ wɨ̱tampɨc cosa juuts tu̱m wɨbɨc cosecha por medio de Jesucristo. Jesɨc ixt́a̱p iga agui wɨ̱ jém tanJa̱tuŋ Dios, tsa̱m cujípta̱p.
\s1 Jém Pablo icuyo̱xa̱p Cristo yɨ́p naxyucmɨ
\p 
\v 12 Sɨɨp mantɨ̱wɨtam, ansunpa iga iñjo̱dóŋa̱iñ t́i annascane yɨɨm y iga más jáyaŋa̱p jém wɨbɨc aŋma̱t́i cuando annasca je̱mpɨc.
\v 13 It́u̱mpɨy jém it́yajwɨɨp jém palacio, con los de más, ijo̱dóŋa̱yaj iga anaŋnúc jém Cristo iŋquímayooyi.
\v 14 Casi it́u̱mpɨy jém tantɨ̱wɨtam, jém it́yajwɨɨp yɨɨm, d́a cɨ̱ŋyajpa porque iyo̱xpátpa jém tánO̱mi. Icamamwatyaj ia̱nama cuando iixyaj iga apajneta̱. Jeeyucmɨ sɨɨp d́a cɨ̱ŋyajpa iga iŋmatpa jém Dios iŋma̱t́i.
\p 
\v 15 Algunos iŋmatyajpa jém Cristo iŋquímayooyi porque agui acujóyɨ́ypa, tsa̱m ajóyixpa. Pero jém tuŋgac iŋmatyajpa jém Cristo iŋquímayooyi porque iwɨ̱aŋja̱m iga iwɨ̱watpa.
\v 16 Jém wɨbɨc pɨxiñt́am iŋmatyajpa jém Cristo iŋquímayooyi porque tsa̱m tóyóypa. Ijo̱dóŋa̱yaj iga ait́ yɨɨm iga aŋcupujpa jém wɨbɨc aŋma̱t́i jém aŋjagooyi iwiñjo̱m.
\v 17 Pero jém malopɨc aŋmat́cɨɨwiñ iŋmatyajpa jém Cristo iŋquímayooyi porque ipɨctsoŋtooba alguna cosa para je iyaac, d́a porque iwɨ̱wattooba. Iwatyajpa así iga más ayaachwatta̱iñ iganam sɨɨp ait́ preso.
\v 18 Ɨch d́a ant́icutɨgɨ̱yi i̱ iŋmatpa jém Cristo iŋquímayooyi. Ɨch amaymay cuando jém pɨxiñt́am iñuumaŋmatpa. Amaymayt́im siiga algunos iŋmatpa no más iga ipɨctsoŋpa algun t́i para je.
\p Ɨch tsa̱m amaymayt́im
\v 19 porque anjo̱doŋ iga núcpa ja̱ma iga atopta̱p porque micht́am iniŋwejpáttámpa Dios para ɨch y ayo̱xpátpat́im jém Dios iA̱nama jém tachiiñewɨɨp jém tánO̱mi Cristo.
\v 20 Ɨch aŋwɨ̱aŋja̱m y anaŋjócpa t́it́am achiiba. D́a atsaa̱p ni uxaŋ. Ansunpa iga ɨch aŋwɨ̱watpa con ammɨjta̱y iga cujípta̱iñ jém Cristo. D́a ant́icutɨgɨ̱yi siiga atsɨ́ypa vivo o acaaneum.
\v 21 Porque iganam ait́, aŋcuyo̱xa̱p Cristo. Siiga acaaba, tu̱m coñwɨyooyi para ɨch.
\v 22 Siiga d́anam acaane, aŋwatpa jém tánO̱mi iyo̱xacuy, pero sɨɨp d́a anjo̱doŋ juppɨc aŋcupiŋpa.
\v 23 Tsa̱m táŋca iga aŋcupiŋpa jup más wɨ̱. Tsa̱m nɨctooba ai̱t́i con Cristo porque más pɨ̱mi wɨ̱ para ɨch.
\v 24 Pero para mimicht́am más wɨ̱ iga atsɨ́ypa vivo yɨ́p naxyucmɨ.
\v 25 Aŋwɨ̱jo̱doŋ iga apoychɨ́ypa yɨ́p naxyucmɨ con mimicht́am. Manyo̱xpátpa iga más miwɨa̱támiñ y más mimaymáya̱támpa porque iŋcupɨcneta.
\v 26 Cuando ait́gacpa con mimicht́am, jesɨc agui mimaymáya̱támpa, tsa̱m iŋcujíptámpa tánO̱mi Cristo.
\p 
\v 27 Wadayt́aamɨ caso iga iŋwɨ̱wattámpa yɨ́p naxyucmɨ juuts nɨmpa jém Cristo iŋquímayooyi. Jesɨc siiga nɨcpa mánám o d́anam anɨcpa, ammatoŋpa iga iŋwɨ̱wattámpa y d́a i̱ wɨa̱p mictsac jém Dios iŋma̱t́i porque tu̱mt́i íña̱nama y tu̱mt́i iñjɨ̱xi iniit́t́a. Ammatoŋpat́im iga miwagayo̱xatámpa con it́u̱mpɨy impɨ̱mi iga jém pɨxiñt́am wɨa̱p icupɨcyaj jém wɨbɨc aŋma̱t́i.
\v 28 Odoy jɨɨcɨ iga michɨgaŋcɨ̱ŋpa jém íñenemigo. Cuando iixyajpa iga d́a micɨ̱ŋpa, jesɨc tsa̱m wɨ̱quejpa iga togoyyajpa jeeyaj, ipɨctsoŋyajpa jém mɨjpɨc castigo. Pero mimicht́am cuando iñja̱mpa iga d́a micɨ̱ŋpa, jesɨc iñjo̱doŋ iga micɨacputtámpa Dios.
\v 29 Jém Cristo icuyucmɨ mimicht́am d́a no más michiit́a̱ jém derecho iga iŋcupɨcpa je, pero iga miyaachwatta̱pt́im.
\v 30 Sɨɨp míŋa̱támpa contra jeet́im enemigo juuts ɨch jáy áŋa̱ji juuts íñixñe iga ɨch aŋwat. Iñjo̱doŋtam iga ɨch seguido áŋa̱pa contra jém malopɨc jɨ̱xi.
\c 2
\s1 Jém Cristo ijɨ́c iga tsɨ́y juuts tu̱m pɨ̱xiñ d́a t́i wɨa̱p
\p 
\v 1 Siiga Cristo micamamwadáypa íña̱nama, siiga Cristo it́óyooyi miyo̱xpátpa, siiga iniit́ Dios iA̱nama íña̱namaŋjo̱m, siiga wɨ̱ íña̱nama y tsa̱m mit́óyóypa,
\v 2 jesɨc acapsaayɨ jém ammaymáya̱ji. Nait́t́aamɨ tu̱mt́i tóyooyi, tu̱mt́i jɨ̱xi y tu̱mt́i íña̱nama. It́t́aamɨ de acuerdo.
\v 3 Pero odoy na̱jacujóyɨ́yooyɨ, odoy nacujípta̱jɨ iñyaac. Más wɨ̱ iga d́a malo íña̱nama y iga más iñt́oypa jém iñt́ɨ̱wɨtam que minitoyt́a̱p iñyaac.
\v 4 Odoy métstaamɨ iga miniwɨ̱wadayt́a̱p iñyaac. Pero métstaamɨ jutsa̱p iŋwɨ̱wadáyt́a jém iñt́ɨ̱wɨtam.
\p 
\v 5 Iniit́t́ámiñ jeet́im jɨ̱xi juuts jém tánO̱mi Jesucristo.
\v 6 Jém tánO̱mi Cristo jext́im ijɨ̱xi y jext́im ipɨ̱mi juuts tanJa̱tuŋ Dios. Iwɨ̱jo̱doŋ iga d́a je nuumi iga tsɨ́y juuts Dios.
\v 7 Pero iyaac ichac it́u̱mpɨy ipɨ̱mi juuts Dios. Oy i̱t́i yɨ́p naxyucmɨ juuts tu̱m mozo. Jém imɨjta̱y juuts pɨ̱xiñ.
\v 8 Cuando oy yɨ́p naxyucmɨ juuts tu̱m pɨ̱xiñ, ijɨ́c iga tsɨ́yiñ juuts tu̱m pɨ̱xiñ d́a t́i wɨa̱p. Iyaac nachiit́a̱ iga accaata̱ porque asíam ixunpa iJa̱tuŋ. Accaata̱ cunusyucmɨ juuts tu̱m malopɨc pɨ̱xiñ.
\v 9 Jeeyucmɨ Dios iccám iga más mɨjpɨc aŋjagooyi. Ichi más wɨbɨc nɨ̱yi de it́u̱mpɨy,
\v 10 iga jém Jesús iñɨyi̱mɨ it́u̱mpɨy jém pɨxiñt́am ico̱steeñayyaj. Ico̱steeñayyajpa it́u̱mpɨy jém sɨŋyucmɨpɨc pɨxiñt́am y jém it́yajwɨɨp yɨ́p naxyucmɨ con it́u̱mpɨy jém it́yajwɨɨp nascucɨɨm.
\v 11 Cada pɨ̱xiñ it́ots iŋmad́iñ iga jém Jesucristo je jém tánO̱mi iga cujípta̱iñ jém tanJa̱tuŋ Dios.
\s1 Jém Dios ipɨxiñt́am juuts tu̱m wɨbɨc juctɨ
\p 
\v 12 Mantɨ̱wɨtam, mantoyt́ampáppɨc, tsa̱m aŋcupɨcta cuando jáy tawagai̱t́it́am, sɨɨp más acupɨctaamɨ iga ait́ juumɨ. Jɨ̱staamɨ jutsa̱p iŋcɨɨputta. Cɨ̱ŋtaamɨ Dios.
\v 13 Porque Dios iwatpa mimicht́ámaŋjo̱m juuts je iwɨ̱aŋja̱m. Michiiba jém wɨbɨc jɨ̱xi iga iŋwatpa juuts je ixunpa, miyo̱xpátpa iga wɨa̱iñ iŋwɨ̱watta.
\p 
\v 14 Iganam iŋwattámpa juuts ixunpa Dios odoy áŋa̱taamɨ con jém iñt́ɨ̱wɨtam. Odoy nacujɨyt́amta̱jɨ,
\v 15 iga d́a i̱ wɨa̱p mipádáy iñt́áŋca. Jesɨc Dios mima̱nɨctam, d́a mit́áŋcaɨ́y iganam mixɨɨba jém malopɨc pɨxiñt́ámaŋjo̱m, jém icupɨcneyajwɨɨp jém mɨgooyi. Tsa̱m michoctámpa yɨ́p naxyucmɨ juuts tu̱m wɨbɨc ma̱tsa aŋtɨwaŋyucmɨ iganam
\v 16 ininɨctámpa jém Dios iŋma̱t́i jém tachiipáppɨc vida. Jeeyucmɨ tsa̱m amaymáya̱p jém ja̱ma cuando miñgacpa Cristo yɨ́p naxyucmɨ iga d́a manxajaaŋquejáy jém Dios iŋma̱t́i ni d́a axajayo̱xa̱.
\v 17 Ɨch agui amaymay iga wɨa̱p manyo̱xpát iga iŋcupɨctámiñ Cristo. Siiga accaata̱p porque manaŋmadáy jém Dios iŋma̱t́i, d́a aŋyácpa. Amaymay y ansunpa iga mimaymáya̱támiñt́im porque sɨɨp Dios miwɨ̱pɨctsoŋpa juuts tu̱m wɨbɨc ofrenda porque iŋcupɨcne Cristo.
\v 18 Maymáya̱taamɨ mimicht́am y wagamaymáya̱taamɨt́im con aɨch.
\s1 Jém Timoteo y jém Epafrodito
\p 
\v 19 Siiga jém tánO̱mi Jesús iwɨ̱aŋja̱m, anjɨ̱spa iga d́a jáyñe maŋcutsadáypa jém Timoteo. Jesɨc cuando miñgacpa yɨɨm, más amaymáya̱p cuando anjo̱dóŋa̱ jutsa̱ne íñi̱t́i.
\v 20 D́a anai̱ yɨɨm ni tu̱m pɨ̱xiñ jexpɨct́im ijɨ̱xi juuts aɨch, jém tsa̱mpɨc mijɨ̱spa iga wɨ̱pud́iñ jém imvida.
\v 21 Porque it́u̱mpɨy imétsyajpa jutsa̱p iniwɨ̱wadayyajta̱ iyaac. D́a imétsyajpa jutsa̱p icuyo̱xa̱ jém Jesucristo.
\v 22 Pero micht́am iñjo̱doŋtam iga wɨbɨc pɨ̱xiñ jém Timoteo, tsa̱m ayo̱xpát aɨch iga anaŋmatta jém wɨbɨc aŋma̱t́i, aŋwaganayo̱xa̱ juuts tu̱m amma̱nɨc.
\v 23 Anjɨ̱spa iga maŋcutsadáypa jém Timoteo cuando anjo̱dóŋa̱ t́i annascaaba.
\v 24 Ɨch aŋcupɨcpa iga tánO̱mi ayo̱xpátpa iga ɨch d́a jáyñe nɨcpa mánám anyaac.
\p 
\v 25 Wɨ̱ iga maŋcutsadáypa e̱ybɨc jém tantɨ̱wɨ Epafrodito, jém michpɨc aŋcutsadáy iga achi t́it́am atogóyáy. Aŋwaganayo̱xa̱, tsa̱m áŋa̱ta contra jém malopɨc jɨ̱xi.
\v 26 Jém Epafrodito tsa̱m mijɨ̱spa. Tsa̱m miixt́ooba iñt́u̱mpɨyt́am. Tsa̱m aŋyácne porque ijo̱doŋ iga immatoŋneta iga mɨmne.
\v 27 Nu̱ma, tsa̱m pɨ̱mi mɨmne hasta caatooba. Pero Dios iyaachaŋja̱m. D́a no más je, pero ayaachaŋja̱mt́im aɨch iga odoy más pɨ̱mi aŋyáguiñ.
\v 28 Jeeyucmɨ aŋcutsatpa jicscɨy jém Epafrodito iga mimaymáya̱támiñ cuando e̱ybɨc íñixpa. Jesɨc ɨch d́a pɨ̱mi aŋyácpa.
\v 29 Jesɨc wɨ̱pɨctsoŋtaamɨ juuts iñt́ɨ̱wɨ porque Cristot́im imɨɨchi. Maymáya̱taamɨ, siempre toyt́aamɨ jexpɨc pɨ̱xiñ juuts iñt́oypa jém tánO̱mi.
\v 30 Por uxaŋ caaba jém Epafrodito porque icuyo̱xa̱ jém Cristo. Je d́a cɨ̱ŋpa, núc ju̱t́ it́ jém peligro iga cupacpa iwat jém yo̱xacuy porque mich d́a wɨa̱ anyo̱xpátta iñyaac.
\c 3
\s1 Dios tawɨ̱tsagáypa tantáŋca cuando taŋcupɨcpa Cristo
\p 
\v 1 Sɨɨp mantɨ̱wɨtam, maymáya̱taamɨ porque Cristo mimɨɨchit́am. Para ɨch d́a je molestia iga e̱ybɨc manaŋmadáypa jeet́im jɨ̱xi juuts manjáyayñe. Wɨ̱ para mimicht́am iga e̱ybɨc immatoŋpa.
\v 2 Nawattamta̱jɨ cuenta de jém chimpa, jém malopɨc obrero, jém iŋmatpáppɨc jém mɨgooyi. Inimiñpa jém aŋquímayooyi iga Dios ipɨxiñt́am tienes que iwatpa jém marca de circuncisión jém imɨjta̱yyucmɨ.
\v 3 Pero taɨcht́am tanait́ jém nu̱mapɨc marca iga Dios tamɨɨchi. Tanait́ Dios iA̱nama tána̱namaŋjo̱m jeeyucmɨ wɨa̱p tanjɨ̱s Dios. Tsa̱m tamaymay iga Jesucristo tamɨɨchi. Taɨchtam tanjo̱doŋ iga tanyaac d́a t́i wɨa̱p taŋwat iga tapɨctsóŋiñ Dios.
\v 4 Siiga jém wiñɨcpɨc aŋquímayooyi wɨa̱p tacɨacput, jesɨc ɨch pecam acɨɨputne, porque ɨch ampɨ̱mi̱mɨ seguido aŋwatpa juuts nɨmpa jém wiñɨcpɨc aŋquímayooyi.
\v 5 Awadayt́a̱ jém marca de circuncisión cuando ocho día anayñe. Ɨch Israelpɨc apɨ̱xiñ de jém tribu de Benjamín. Anaŋmatpat́im jém aŋma̱t́i hebreo juuts iŋmatpa jém anja̱tuŋ. Aŋcuyujcane jém wiñɨcpɨc aŋquímayooyi con jém fariseopɨc pɨxiñt́am.
\v 6 Ɨch tsa̱m pɨ̱mi antoypa id́ɨc jém wiñɨcpɨc aŋquímayooyi. Jeeyucmɨ tsa̱m pɨ̱mi ammalwadáy jém icupɨcneyajwɨɨp Jesús. Anjɨ̱spa iga d́a atáŋcaɨ́y porque aŋwatne it́u̱mpɨy cosa juuts nɨmpa jém wiñɨcpɨc aŋquímayooyi.
\v 7 Pero it́u̱mpɨy jexpɨc cosa, jém anjɨ̱spáppɨc id́ɨc iga tsa̱m wɨ̱, sɨɨp d́a t́i cuwatcuy para ɨch porque aŋcupɨcneum Cristo.
\v 8 It́u̱mpɨy cosa jém anait́wɨɨp id́ɨc sɨɨp anjɨ̱spa iga it́ wɨ̱ siiga togoypa porque ánixpɨc jém tánO̱mi Jesucristo. Jém Cristo icuyucmɨ togoy it́u̱mpɨy jém anait́wɨɨp id́ɨc, sɨɨp it́u̱mpɨy jexpɨc cosa ánixpa juuts pu̱chi porque más wɨ̱ iga ampɨctsoŋ Cristo,
\v 9 atsɨ́ypa juuts jém Cristo imɨɨchi. Dios d́a apɨctsoŋpa iga wɨbɨc apɨ̱xiñ o porque agui aŋwɨ̱watne juuts nɨmpa jém Moisés iŋquímayooyi, pero apɨctsoŋpa iga aŋcupɨcne Cristo. Dios apɨctsoŋ iga wɨbɨc apɨ̱xiñ porque Dios awɨ̱wadáy por medio de jém fe.
\v 10 Ɨch ansunpa iga más y más ánixpɨguiñ Cristo y más anaid́iñ jém Dios ipɨ̱mi jém icpɨsnewɨɨp Cristo. Anyaachɨ́ypa cuando ayaachwatta̱p jém Cristo icuyucmɨ. Hasta núcpa iga anait́pa jexpɨc jɨ̱xi ána̱namaŋjo̱m juuts iniit́ jém tánO̱mi Cristo cuando ijɨ́cpa iga accaata̱.
\v 11 Anaŋjócpa iga acpɨsta̱p de ju̱t́ it́ jém caaneyajwɨɨp.
\s1 Wɨ̱ iga taŋwatpa juuts ixunpa Dios con it́u̱mpɨy tampɨ̱mi
\p 
\v 12 D́a mannɨ́máypa iga anactsɨ́yum it́u̱mpɨy. D́at́im wɨa̱p aŋwat it́u̱mpɨy cosa juuts ixunpa Dios, pero seguido antúŋɨ́ypa hasta anactsɨ́ypa it́u̱mpɨy juuts ixunpa Dios. Jeeyucmɨ amɨɨcha̱neum jém tánO̱mi Jesucristo.
\v 13 Mantɨ̱wɨtam, ɨch d́a mannɨ́máypa iga anactsɨ́yñeum it́u̱mpɨy. Sɨɨp no más tu̱m cosa aŋwatpa. Anja̱mnotpa jém wiñɨcpɨc cosa, tsɨ́ypa antuuñiaŋcɨɨm, pero con it́u̱mpɨy ampɨ̱mi aŋwatpa jém cosa jém miñpáppɨc.
\v 14 Juuts tu̱m apuesto, poyi̱mɨ anɨcpa iga aŋcoñwɨ́yiñ jém premio, jém taŋwejayñewɨɨp Dios sɨŋyucmɨ iga tachiiba porque Cristo Jesús tamɨɨchi.
\p 
\v 15 Tantu̱mpɨy, jém taŋwɨ̱cupɨcnewɨɨp, wɨ̱ iga tanjɨ̱stámpa je̱mpɨc. Pero siiga algunos de mimicht́am tuŋgac cosa iñjɨ̱spa, jesɨc Dios micjo̱dóŋa̱pt́im.
\v 16 Wɨ̱ iga cada tu̱mtu̱m seguido taŋwattámiñ de acuerdo con jém jɨ̱xi jém tampɨctsoŋnewɨɨp.
\p 
\v 17 Mantɨ̱wɨtam, acuixt́aamɨ juuts ɨch aŋwatpa. Ámtaamɨ i̱ iwɨ̱watpa juuts ɨch manaŋquejayñe.
\v 18 Mannɨ́mayñeum wa̱t́cɨy, sɨɨp e̱ybɨct́im mannɨ́máypa hasta awejpa, iga tsa̱m jáyaŋ pɨxiñt́am ijóyixpa jém aŋquímayooyi iga accaata̱ Cristo cunusyucmɨ.
\v 19 Núcpa ja̱ma iga ipɨctsoŋyajpa jém castigo jém d́apɨc cuyajpa. Ipuu jém idios. Tsa̱m nacujípta̱p iyaac iga iwatpa jém malopɨc cosa jém aguipɨc tatsaa̱p. Tsa̱m ijɨ̱spa yɨ́p naxyucmɨpɨc jɨ̱xi.
\v 20 Pero taɨcht́am sɨŋyucmɨpɨc tapɨxiñt́am. Sɨ́p tanaŋjócta iga miñpa sɨŋyucmɨ jém tacɨacputpáppɨc, jém tánO̱mi Jesucristo.
\v 21 Tacucagáyáypa jém tammɨjta̱y jém sɨɨppɨc tanait́ jém d́apɨc wɨa̱p. Tachiiba tu̱m jo̱mipɨc mɨjta̱y juuts jém Cristo imɨjta̱y tsa̱mpɨc wɨa̱p. Tawadáypa así con ipɨ̱mi jém wɨa̱paap iŋjac it́u̱mpɨy cosa.
\c 4
\s1 Tamaymáya̱támiñ porque Cristo tánO̱mi
\p 
\v 1 Jeeyucmɨ mantɨ̱wɨtam, mantoyt́ampáppɨc, tsa̱m mánixt́ooba. Tsa̱m amaymay con mimicht́am. Mijext́am juuts tu̱m wɨbɨc coñwɨyooyi. Quejpa iga d́a axajayo̱xa̱ mimicht́ámaŋjo̱m. Mantoyt́ampáppɨc, odoy tsa̱cɨ jém tánO̱mi iŋquímayooyi.
\p 
\v 2 Sɨɨp aŋcunucsáypa jém yo̱mtam jém Evodia y jém Síntique iga odom más áŋa̱yajiñ, iga iniit́yajiñ tu̱mt́i jɨ̱xi porque icupɨcyajpa tánO̱mi.
\v 3 Maŋcunucsáypat́im mimich, jém wɨbɨc maŋcompañero. Maŋwágáypa iga iñyo̱xpád́iñ yɨ́p yo̱mtam. Icuɨstɨc aŋwaganayo̱xa̱ cuando anaŋmat jém wɨbɨc aŋma̱t́i. Aŋwaganayo̱xat́im jém Clemente y jém tuŋgac tantɨ̱wɨtam jém jaycámayñeta̱wɨɨp iñɨ̱yi jém librojo̱m iga ipɨctsoŋpa jém vida d́apɨc cuyajpa.
\p 
\v 4 Maymáya̱taamɨ it́u̱mpɨy tiempo porque Cristo mimɨɨchi. E̱ybɨc mannɨ́máypa iga maymáya̱taamɨ.
\v 5 Siempre wɨ̱wa̱tɨ iga miixyajiñ it́u̱mpɨy pɨxiñt́am iga d́a mimalo. Jɨ̱staamɨ iga d́a jáyñe miñpa jém tánO̱mi.
\p 
\v 6 Odoy jɨ̱sɨ t́i iññascaaba. Aŋwejpaatɨ Dios, wágaayɨ t́it́am iñxunpa. Siempre cuando iŋwatpa oración chiit́aamɨ gracia Dios.
\v 7 Dios michi jém wɨbɨc jɨ̱xi íña̱namaŋjo̱m iga odoy t́i iŋcɨɨŋiñ. D́a i̱ wɨa̱p icutɨɨyɨ́y yɨ́p jɨ̱xi jutsa̱p tayo̱xpát Dios. Yɨ́p wɨbɨc jɨ̱xi miwadáypa cuenta íña̱nama y iñjɨ̱xi por medio de Jesucristo.
\s1 Jɨ̱staamɨ jém wɨbɨc cosa
\p 
\v 8 Jesɨc, mantɨ̱wɨtam, siempre jɨ̱staamɨ jém nu̱mapɨc cosa. Jɨ̱staamɨ jém wɨbɨc jɨ̱xi, jém d́apɨc malo, jém wɨ̱tampɨc cosa, jém iwɨ̱aŋja̱myajpáppɨc jém wɨbɨc pɨxiñt́am, jém cosa aguipɨc wɨ̱ tánix y it́u̱mpɨy jém iwɨ̱ixyajpáppɨc jém pɨxiñt́am. Jɨ̱staamɨ it́u̱mpɨy jém wɨbɨc cosa jém icujíppáppɨc Dios.
\p 
\v 9 Wattaamɨ juuts manaŋquejayñe juuts nɨmpa jém aŋquímayooyi jém impɨctsoŋnewɨɨp. Wattaamɨ juuts immatoŋne y juuts íñix iga ɨch aŋwatpa. Sɨɨp miwaganait́ tanJa̱tuŋ Dios iga odoy micɨɨŋiñ.
\s1 Jém ofrenda jém chiiñeta̱wɨɨp jém Pablo
\p 
\v 10 Agui amaymay jém tánO̱mi iñɨyi̱mɨ porque mimicht́am e̱ybɨc anjɨ̱stámpa. Agui aŋwɨ̱wadayt́ooba id́ɨc, pero d́a impát jutsa̱p aŋwɨ̱wadáy.
\v 11 D́a manaŋmadáypa iga atogóyáy algun t́i. Porque ɨch anaŋyujne iga ayaacha̱p. Ɨch amaymay con t́it́am anait́.
\v 12 Anaŋyujne iga ayaacha̱p y anaŋyujne iga anait́ jáyaŋ. Aŋcuyujcane iga awɨ̱it́pa o d́a t́i anait́pa. Anaŋyujne iga cuspa awiiqui o iga tsa̱m ayua̱p. Anaŋyujne iga d́a t́i atogóyáy o d́a t́i anait́.
\v 13 Ɨch wɨa̱p aŋwat it́u̱mpɨy cosa porque jém Cristo achi ipɨ̱mi.
\v 14 Pero mimicht́am tsa̱m iŋwɨ̱watta porque tsa̱m anyo̱xpát cuando ayaachwatta̱.
\p 
\v 15 Mimicht́am, miit́wɨɨp Filipos, iñjo̱doŋtam iga cuando moj anaŋmat jém wɨbɨc aŋma̱t́i, cuando aput jém naxyucmɨ de Macedonia, jém Dios ipɨxiñt́am jém tuŋgac attebet d́a ayo̱xpát solamente mimicht́am.
\v 16 Cuando todavía d́a juumɨ anɨcne, cuando ait́ jém attebet Tesalónica, mimicht́am wat́cɨy aŋcutsadayt́a jém ofrenda iga anyo̱xpátpa.
\v 17 D́a ammétspa jém xaja, pero ansunpa iga iŋwɨ̱wad́iñ iga Dios miccáyáypa sɨŋyucmɨ jém iñriqueza.
\v 18 Ɨch ampɨctsoŋne it́u̱mpɨy cosa t́it́am atogóyáy. Sɨɨp anait́ jáyaŋ hasta cutsɨ́yñe. Agui ayo̱xpát jém xaja jém aŋcutsadayñewɨɨp con jém tantɨ̱wɨ Epafrodito. Jém xaja jex juuts tu̱m ofrenda aguipɨc cɨ̱npa Dios iwiñjo̱m juuts tu̱m sacrificio, jém tsa̱mpɨc iwɨ̱aŋja̱m Dios.
\v 19 Jém tanJa̱tuŋ Dios michiiba it́u̱mpɨy cosa t́it́am mit́ogóyáy porque je iniit́ jém sɨŋyucmɨpɨc riqueza. Michiiba porque Jesucristo mimɨɨchit́am.
\v 20 Wɨ̱ iga taŋcujíptámiñ jém tanJa̱tuŋ Dios para siempre. Amén.
\s1 Aŋquímyajta̱p jém amigoyaj
\p 
\v 21 Dioschi̱ɨ it́u̱mpɨy jém icupɨcneyajwɨɨp Jesucristo. Jém tantɨ̱wɨtam, jém aŋwaganait́wɨɨp yɨɨm, micutsadáypa wa̱t́idios.
\v 22 It́u̱mpɨy jém Dios ipɨxiñt́am jém it́yajwɨɨp yɨ́p attebet micutsadáypa wa̱t́idios. Micutsadáypat́im wa̱t́idios jém icupɨcneyajwɨɨp Cristo jém it́yajwɨɨp jém Romapɨc aŋjagooyi it́ɨccɨɨm.
\p 
\v 23 Jém tánO̱mi Jesucristo miwɨ̱wadáyiñ iñt́u̱mpɨyt́am. Jemum cuyaj.
