\toc3 Flm
\mt1 FILEMON
\c 1
\s1 Pablo Filemodi AcaatÉØnÉØuhaame.
\p 
\v 1 Uujoho Pablo, jino Cristo Jesu momohallÉØtÉØ cÉØvojafaĆ±o iicaabo jihaameque caatÉØnÉØhi sano monahabo Timoteoma ÉØÉØdi, agaijÉØÉØbo Filemon mududÉØcamaaje nahabonÉØmÉØnaafidi,
\v 2 bu Moocaani iijamÉØnaa oono diijafaĆ±o igaivehicamedi, tollÉØro bu monago Apiadi, bu Arquipo mÉØÉØhaico mududÉØcamaajeque aamusuhicaabedi icano.
\v 3 Jaamo amÉØÉØhai magaayÉØcÉØ Moocaani, bu AivojÉØÉØbo Jesucristo icamÉØsi imino omoonÉØnoco, bu sajeebÉØÉØ icaco aacÉØnoco icano.
\s1 Filemon GaijÉØ, Miyaavogo Icano.
\p 
\v 4 FahiijÉØvaro uujoho Moocaanico dihallÉØvÉØ imehicahi. Jaabo diiboma ihiimaasumi ÉØÉØtÉØ esafetehicahi,
\v 5 AivojÉØÉØbo Jesuco ÉØÉØjoho agaijÉØnoco, imiyaavogonoco icano, bu paryÉØ Moocaanita iicamoco agaijÉØnoco icano uguubuuboro.
\v 6 TollÉØro bu Moocaanico dilluhicahi oono dimiyaavogoco aatyÉØmemere imiyaavogomohallÉØvÉØ, jaamo Cristo JesufaĆ±odÉØ paryÉØ iiminoco magaayÉØcÉØnoco imino igaajaqui.
\v 7 Jaabo tajeebÉØÉØ jacusucafetehi, bu uujoho sihidÉØ imo imo icahi ÉØÉØjoho sihidÉØ gaijÉØma idiicanotÉØ. MÉØÉØro ÉØÉØjoho taĆ±ahabo, difaĆ±odÉØ miyaavogomÉØnaa jeebÉØÉØ jacusucafetehi.
\s1 Pablo Filemon JÉØjovonohallÉØvÉØ Filemoco Idilluno.
\p 
\v 8 Jaanegui uujoho Cristo minÉØsumÉØnaafi iicaruubo ÉØco tajÉØÉØbajitÉØhi ÉØÉØjoho omoonÉØjinoco.
\v 9 Ę—vÉØ jillÉØro gaijÉØfeenedÉØ ÉØco dilluhi. Uujoho Pablo amiyaabo iicacuubo, bu jino Cristo JesuhallÉØtÉØ cÉØvojafaĆ±o iicaabo,
\v 10 ÉØco dilluhi jaanÉØ Onesimo onoobohallÉØvÉØ. Jaabo jino cÉØvojafaĆ±o miyaavogofeenedÉØ taseemenetÉØ minifutucuuhi.
\p 
\v 11 ItÉØconÉØ naha Onesimo jillÉØ mÉØhÉØÉØfoobo dijÉØjovono icauhi. Jaaruubo jisumi miyaabotÉØro mÉØsidi icacuuhi, ÉØÉØdi bu uudi icano.
\v 12 Jaaboco dijaago uujoho siino galluhi. Jaaboco imino gaayÉØcÉØ tafiico idiicajirubadÉØ.
\v 13 Imogorahi jinoovÉØ uuma iicanoco dibuunavÉØ uco ijeecÉØvequi jino Cristo jÉØÉØbogohallÉØtÉØ cÉØvojafaĆ±o iicaaboco.
\v 14 Jaaruubo uujoho imogotÉØhi ÉØÉØjoho idiimogotÉØnoco omoonÉØnoco. Jaabo uudi ÉØÉØjoho omoonÉØno uujoho atajÉØÉØbaneri icatÉØno iicaqui, jillÉØ ÉØÉØro idiimogooboro omoonÉØno iicaqui.
\v 15 FÉØne Onesimo ÉØÉØtÉØ dugaavuuhi gueenene sihÉØ iicatÉØqui. Jaaruubo jisumi ÉØÉØma fahiijÉØvaro icacuujiibo.
\v 16 Jaaruubo jÉØjovonobadÉØ icacujitÉØhi. JillÉØ jÉØjovono janaanÉØcÉØvÉØ imino icacujiibo. Jaabo agaijÉØÉØbo dinahaborucuuji. Jaaboco uujoho sihidÉØ gaijÉØhi. Imi jaano janaanÉØcÉØvÉØ ÉØÉØjoho diiboco gaijÉØ dijÉØjovono iicamaĆ±o, bu MohaivojÉØÉØbofaĆ±odÉØ dinahabo iicamaĆ±o icano.
\p 
\v 17 Jaaneguiiha digataavomÉØnaafi uujoho iicahachiijÉØ diiboco gaayÉØcÉØ uco idiicajirubadÉØ.
\v 18 JaanotÉØ ÉØco diibo imitÉØno omoonÉØuhachiijÉØ, bu ÉØco edebehachiijÉØ icano ucoro toonoco daadusu.
\v 19 Jaabo uujoho Pablo, jinoocoro tahuseri caatÉØnÉØhi: Uujoho ÉØco jaaduji. MÉØÉØro bu uujoho ÉØco neejirahi: Ę—ÉØjoho tahallÉØvÉØ guijevejirahi uco edebeneque daaduqui, neejirahi. Jaarunoco ÉØco uujoho nootÉØhi.
\v 20 Jaaneguiiha taĆ±ahabo, uudi jino iminoco deetavo AivojÉØÉØbo Jesuco imiyaavogomo iicanÉØcÉØbadÉØ. Jaaneguiiha tajeebÉØÉØco daacusu CristofaĆ±odÉØ taĆ±ahabo idiicamaĆ±o.
\p 
\v 21 JillÉØ ÉØÉØdi caatÉØnÉØhi ÉØÉØjoho omoonÉØjinoco agaajaaboro, bu jino ÉØco onoonoco janaanÉØcÉØvÉØ omoonÉØjinoco agaajaaboro icano.
\v 22 Bu tollÉØro uudi uujoho ÉØÉØfetejimaĆ±oco tahÉØmega dimibachu. MÉØÉØro jino teemehi amÉØÉØhai Moocaanico midilluhicanoco amÉØÉØhaico ihacÉØqui uujoho amÉØÉØhaico emeecÉØtejinoco.
\s1 Niino Fitacu.
\p 
\v 23 JaanÉØ Epafra onoobo dijaago iijÉØco galluhi, jino Cristo JesuhallÉØtÉØ uuma cÉØvojafaĆ±o iicaabo.
\v 24 TollÉØro bu Marco onoobo, bu Aristaco onoobo, bu Demas onoobo, bu Lucas icamo jino uco tadyudÉØcamaajetÉØ aamusuhicamo dijaago iijÉØco gallumo.
\p 
\v 25 Jaafa MohaivojÉØÉØbo Jesucristo amÉØÉØhaico imino moonÉØhi.
