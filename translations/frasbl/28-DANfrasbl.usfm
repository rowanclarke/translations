\v 21 \w Il|strong="H5922"\w* \w fut|strong="H1655"\w* \w chassé|strong="H2957"\w* \w du|strong="H4481"\w* \w milieu|strong="H4481"\w* \w des|strong="H4481"\w* \w fils|strong="H1123"\w* \w des|strong="H4481"\w* \w hommes|strong="H4481"\w*, \w son|strong="H5922"\w* \w cœur|strong="H3825"\w* \w devint|strong="H7739"\w* \w semblable|strong="H5974"\w* \w à|strong="H5922"\w* \w celui|strong="H1768"\w* \w des|strong="H4481"\w* \w bêtes|strong="H2423"\w*, \w et|strong="H4481"\w* \w sa|strong="H5922"\w* \w demeure|strong="H4070"\w* \w fut|strong="H1655"\w* \w avec|strong="H5974"\w* \w les|strong="H5922"\w* \w ânes|strong="H5922"\w* \w sauvages|strong="H6167"\w*. \w On|strong="H4481"\w* \w le|strong="H5922"\w* nourrit \w d|strong="H4481"\w*'\w herbe|strong="H6211"\w* \w comme|strong="H4481"\w* \w les|strong="H5922"\w* \w bœufs|strong="H8450"\w*, \w et|strong="H4481"\w* \w son|strong="H5922"\w* \w corps|strong="H1655"\w* \w fut|strong="H1655"\w* \w trempé|strong="H6647"\w* \w par|strong="H4481"\w* \w la|strong="H4481"\w* \w rosée|strong="H2920"\w* \w du|strong="H4481"\w* \w ciel|strong="H8065"\w*, jusqu'\w à|strong="H5922"\w* \w ce|strong="H4481"\w* \w qu|strong="H1768"\w*'\w il|strong="H5922"\w* reconnaisse \w que|strong="H1768"\w* \w le|strong="H5922"\w* \w Dieu|strong="H4481"\w* \w Très-Haut|strong="H4437"\w* \w domine|strong="H7990"\w* \w sur|strong="H5922"\w* \w la|strong="H4481"\w* royauté \w des|strong="H4481"\w* \w hommes|strong="H4481"\w* \w et|strong="H4481"\w* \w qu|strong="H1768"\w*'\w il|strong="H5922"\w* \w y|strong="H5922"\w* \w établit|strong="H6966"\w* \w qui|strong="H4437"\w* \w il|strong="H5922"\w* veut.   
