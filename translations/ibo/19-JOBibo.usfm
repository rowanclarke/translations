\id JOB - Biblica® Open Igbo Contemporary Bible 2020 
\h Job 
\toc1 Job 
\toc2 Job 
\toc3 Job 
\mt1 Job 
\c 1  
\s1 Okwu mmalite 
\p  
\v 1 Otu nwoke aha ya bụ Job bi nʼobodo Uz.\f + \fr 1:1 \ft Job abụghị onye Izrel, kama ọ bụ onye Uz, obodo dị nʼakụkụ ọwụwa anyanwụ osimiri Jọdan. \xt Jer 25:20\f* Nwoke a bụ Job bụ onye na-enweghị ịta ụta ọbụla, bụrụkwa onye ezi omume nke na-atụ egwu Chineke ma na-agbara mmehie ọsọ.  
\v 2 Ọ mụrụ ụmụ ndị ikom asaa na ụmụ agbọghọ atọ.  
\v 3 O nwere puku atụrụ asaa, na puku ịnyịnya kamel atọ, na ehi ọnụọgụgụ ha dị otu puku e jikọrọ abụọ abụọ, na narị ịnyịnya ibu ise, na ọtụtụ ndị na-ejere ya ozi. Ọ bụ nwoke dị ukwuu karịa ndị niile bi nʼọwụwa anyanwụ. 
\p  
\v 4 Ụmụ ya ndị ikom na-eme mmemme oriri na ọṅụṅụ nʼụbọchị ọmụmụ ha nʼụlọ ha, nke ọbụla nʼime ya nʼusoro. Mgbe ha na-eme nke a, ha na-akpọkwa ụmụnne ha ndị nwanyị atọ ka ha bịa soro ha rie ma ṅụkwaa.  
\v 5 Mgbe oge mmemme ndị ahụ gwụsịrị, Job na-akpọkọta ụmụ ya doo ha nsọ. Nʼisi ụtụtụ ya, ọ na-achụ aja\f + \fr 1:5 \ft Onyeisi ezinaụlọ ọbụla na-arụ ọrụ dị ka onye nchụaja nye ezinaụlọ ya, tupu Onyenwe anyị e nye Mosis iwu banyere ihe ndị a.\f* nsure ọkụ nʼihi onye ọbụla nʼetiti ụmụ ya. Echiche ya bụ, “Ma eleghị anya, ụmụ ya emehiela kọchaa Chineke nʼime obi ha.” Nke a bụ ihe Job na-eme mgbe niile. 
\s1 Ọnwụnwa mbụ bịakwasịrị Job 
\p  
\v 6 Otu ụbọchị ụmụ Chineke bịara igosi onwe ha nʼihu \nd Onyenwe anyị\nd* ma ekwensu sonyekwara ha bịa.  
\v 7 \nd Onyenwe anyị\nd* sịrị Ekwensu, “Ebee ka i si abịa?” 
\p Ekwensu zara \nd Onyenwe anyị\nd*, “Site nʼịwagharị nʼụwa na site nʼịgagharị ihu na azụ nʼime ya.” 
\p  
\v 8 Mgbe ahụ, \nd Onyenwe anyị\nd* sịrị Ekwensu, “I leziela ohu m nwoke Job anya? Ọ dịghị onye ọzọ nọ nʼụwa nke dịka ya. Ọ bụ nwoke zuruoke, onye na-emekwa ihe ziri ezi. Ọ bụ onye na-atụ egwu Chineke, na-adịghị etinye aka ya nʼihe ọjọọ ọbụla.” 
\p  
\v 9 Ekwensu zara \nd Onyenwe anyị\nd* sị, “Job ọ na-atụ Chineke egwu nʼefu?  
\v 10 Ọ bụ na ị gbaghị Job na ezinaụlọ ya na ihe niile o nwere ogige gburugburu nʼakụkụ niile? I gọziela ọrụ aka ya, nke mere na igwe ewu na atụrụ ya na igwe ehi ya jupụtara ebe niile.  
\v 11 Ngwa, setịpụ aka gị metụ ihe niile o nwere aka, ka ị hụ ma ọ gaghị abụ gị ọnụ.” 
\p  
\v 12 Mgbe ahụ, \nd Onyenwe anyị\nd* zara ekwensu sị ya, “Lee Job, jiri niile o nwere mee ihe ọbụla ị chọrọ, kama emetụkwala ndụ ya aka.” 
\p Emesịa, ekwensu sitere nʼihu \nd Onyenwe anyị\nd* pụọ. 
\p  
\v 13 Otu ụbọchị, mgbe ụmụ Job ndị nwoke na ụmụnne ya ndị nwanyị zukọrọ iri ihe oriri na ịṅụ ihe ọṅụṅụ nʼụlọ nwanne ha nwoke nke okenye.  
\v 14 Otu onye nʼime ndị na-eje ozi bịakwutere Job sị, “Mgbe ehi anyị na-akọ ọrụ na mgbe ịnyịnya ibu anyị na-ata nri nʼebe dị nso,  
\v 15 ndị Sheba\f + \fr 1:15 \ft Ha bụ ndị na-agagharị site nʼotu ebe gaa ebe ọzọ na-azụ ụmụ anụmanụ. Ebe obibi ha bụ na ndịda Arebịa.\f* bịara lụsoo anyị ọgụ ma chịkọrọ ha laa. Ha ji mma agha gbuo ndị ọhụ gị, maọbụ naanị m bụ onye gbapụtara ịgwa gị.” 
\p  
\v 16 Mgbe ọ ka kpụ okwu nʼọnụ, onyeozi ọzọ gbabatara kwuo sị, “Ọkụ Chineke zitere sitere na mbara eluigwe daa rechapụ igwe atụrụ na ndị ohu niile. Ọ bụ naanị m bụ onye gbapụtara ịgwa gị ihe mere.” 
\p  
\v 17 Mgbe onye nke ahụ nọ na-ekwu okwu, onyeozi ọzọ batara kwuokwa sị, “Ndị agha ndị Kaldịa\f + \fr 1:17 \ft Ha bụ ndị na-ebi nʼọzara Mesopotamịa, na-agagharị ịzụ ụmụ anụmanụ, ma mesie bụrụ ndị biiri nʼala Babilọn mee ka ọ ghọọ alaeze.\f* kere onwe ha ụzọ atọ bịakwasị ịnyịnya kamel gị niile, dọta ha nʼagha, kpụrụ ha laa. Ha ji mma agha gbuo ndị ohu gị niile gbalaa. Ọ bụ naanị m bụ onye gbapụtara ịgwa gị ihe mere.” 
\p  
\v 18 Mgbe ọ kpụ okwu ya nʼọnụ, onyeozi ọzọ batakwara kwuo sị, “Ụmụ gị ndị ikom na ndị inyom nọ nʼụlọ nwanne ha nke okenye na-eri na-aṅụ,  
\v 19 na mberede, oke ifufe dị ukwuu nke si nʼọzara feere tie akụkụ anọ nke ụlọ ahụ, mee ka ọ dakwasị ha. Ha niile nwụrụ, ma ọ bụkwa naanị m gbapụtara ịgwa gị ihe mere.” 
\p  
\v 20 Mgbe Job nụrụ ihe ndị a, o sitere nʼebe ọ nọ bilie ọtọ, dọwaa uwe ya, kpụchaa agịrị isi ya, ọ dara nʼala ma kpọọ isiala,  
\v 21 kwuo sị: 
\q1 “Ọtọ ka m gba mgbe m si nʼafọ nne m pụta 
\q2 nʼọnọdụ ịgba ọtọ ka m ga-eji laghachikwa. 
\q1 \nd Onyenwe anyị\nd* nyere ihe niile, \nd Onyenwe anyị\nd* ewerekwala ihe niile, 
\q2 ka aha \nd Onyenwe anyị\nd* bụrụ ihe a gọziri agọzi.” 
\p  
\v 22 Nʼime ihe ndị a niile, Job emehieghị site nʼibo Chineke ebubo ime ihe ọjọọ. 
\c 2  
\s1 Ọnwụnwa nke abụọ 
\p  
\v 1 Ụbọchị ọzọkwa, ụmụ Chineke bịakwara igosi onwe ha nʼihu \nd Onyenwe anyị\nd*. Ekwensu sonyekwaara ha ọzọ bịakwa igosi onwe ya nʼihu ya.  
\v 2 Mgbe ahụ, \nd Onyenwe anyị\nd* jụkwara ekwensu ajụjụ sị, “Ebee ka i si abịa?” 
\p Ekwensu zara \nd onyenwe anyị\nd*, “Site nʼịwagharị nʼụwa na site nʼịgagharị ihu na azụ nʼime ya.” 
\p  
\v 3 Mgbe ahụ, \nd Onyenwe anyị\nd* sịrị ekwensu, “I leziela ohu m nwoke Job anya? Ọ dịghị onye ọzọ dị nʼụwa nke dịka ya. Ọ bụ nwoke zuruoke, onye na-emekwa ihe ziri ezi. Ọ bụ onye na-atụ egwu Chineke, na-adịghị etinye aka ya nʼihe ọjọọ ọbụla. Ọ ka jidekwara izuoke ya, nʼagbanyeghị na ị kpaliri m imegide ya ka m laa ya nʼiyi mgbe ọ na-adịghị ihe o mere.” 
\p  
\v 4 Ekwensu zaghachiri \nd Onyenwe anyị\nd*, “Akpụkpọ anụ ahụ lara akpụkpọ anụ ahụ; mmadụ ga-enye ihe niile o nwere nʼọnọdụ ndụ ya.  
\v 5 Setịpụ aka gị metụ akpụkpọ anụ ahụ ya na ọkpụkpụ ya, ọ ghakwaghị ị bụ gị ọnụ nʼihu gị.” 
\p  
\v 6 \nd Onyenwe anyị\nd* sịrị ekwensu, “Lee, ọ nọ nʼaka gị. Kama ị ghaghị idebe ndụ ya.” 
\p  
\v 7 Mgbe ahụ, ekwensu sitere nʼihu \nd Onyenwe anyị\nd* pụọ. O were ọnya ọjọọ na-egbu mgbu tie Job, site nʼọbọ ụkwụ ya ruo nʼopi isi ya.  
\v 8 Job tụtụụrụ mpekele ite wara awa, jiri ya na-akọ onwe ya ọkọ nʼahụ, ma dinara nʼebe e kpokọtara ntụ. 
\p  
\v 9 Nwunye ya sịrị ya, “Ị ka na-eguzo nʼizuoke gị? Bụọ Chineke ọnụ, nwụọ.” 
\p  
\v 10 Ma ọ zara, “Ị na-ekwu okwu dịka otu nʼime ndị inyom nzuzu. Anyị ga-anata ihe ọma site nʼaka Chineke, hapụ ịnata ihe ọjọọ?” 
\p Ma nʼime nsogbu a niile, Job emehieghị site nʼikwu okwu ọjọọ ọbụla. 
\b  
\s1 Ndị enyi Job atọ 
\p  
\v 11 Mgbe ndị enyi Job atọ, Elifaz\f + \fr 2:11 \ft Ọ bụ onye si nʼagbụrụ Edọm, nʼobodo Teman.\f* onye Teman, Bildad onye Shua na Zofa onye Neama, nụrụ banyere nsogbu niile dakwasịrị ya, ha biliri ije site nʼụlọ ha, ha zukọtara site na nkwekọrịta ịga nọnyere ya na ịkasị ya obi.  
\v 12 Mgbe ha hụrụ ya site nʼebe dị anya, ha amataghị ya, ha weliri olu bido iti mkpu akwa, dọkaa uwe ha yi nʼahụ ha, kporo aja kpokwasị onwe ha nʼisi.  
\v 13 Ha sooro Job nọdụ nʼala ụbọchị asaa, ehihie na abalị. Ọ dịghị onye gwara ya okwu nʼihi na ha hụrụ otu ihe mgbu ya si dị ukwuu. 
\c 3  
\s1 Okwu Job 
\p  
\v 1 Nʼikpeazụ, onye kwuru okwu bụ Job nʼonwe ya. O kwuru okwu bụọ ụbọchị a mụrụ ya ọnụ.  
\v 2 Job sịrị: 
\q1  
\v 3 “Ka ụbọchị ahụ amụrụ m bụrụ ụbọchị lara nʼiyi; 
\q2 ya na abalị ahụ e kwuru sị, ‘Atụrụ ime nwa nwoke.’ 
\q1  
\v 4 Ụbọchị ahụ, ka ọ ghọọ ọchịchịrị: 
\q2 ka Chineke site nʼelu ghara ịjụ ase ya; 
\q2 ka ìhè gharakwa ịmụkwasị ya. 
\q1  
\v 5 Ka ọchịchịrị na onyinyo ọnwụ gbara ụbọchị ahụ dịka ụbọchị nke aka ya, 
\q2 ka igwe ojii kpuchigidekwa ya, 
\q2 ka ọchịchịrị kpuchie ya nʼebe ọ dị ukwuu. 
\q1  
\v 6 Abalị ahụ, ka oke ọchịchịrị kpuchie ya, 
\q2 ka a kachapụ ya, ka ọ hapụ ịbụkwa ụbọchị a ga-agụkọ ya na ụbọchị ndị ọzọ nʼafọ, 
\q2 ka ọ ghara dịka otu ụbọchị nke na-adị nʼọnwa. 
\q1  
\v 7 Ka abalị ụbọchị ahụ bụrụ ụbọchị tọgbọrọ nʼefu, 
\q2 ka a ghara ịnụ mkpu ọṅụ ọbụla nʼime ya. 
\q1  
\v 8 Ka ndị ahụ na-abụ ụbọchị ọnụ bụọ ụbọchị ahụ ọnụ, 
\q2 bụ ndị ahụ jikeere ịkpọte Leviatan.\f + \fr 3:8 \ft Anụ ọjọọ dị ukwuu bi nʼosimiri\f* 
\q1  
\v 9 Ka kpakpando ụtụtụ ya gbaa ọchịchịrị, 
\q2 ka o lee anya ìhè na-efu, 
\q2 ka ọ ghara ihu mgbubere anya nke chi ọbụbọ, 
\q1  
\v 10 nʼihi na o mechighị akpanwa nne m, 
\q2 i zonarịkwa anya m nsogbu. 
\b  
\q1  
\v 11 “Gịnị mere m ji hapụ ịnwụ mgbe ahụ nne m mụpụtara m, 
\q2 kubie ume mgbe m si nʼime akpanwa pụta? 
\q1  
\v 12 Gịnị mere ikpere ji dịrị ịnabata m? 
\q2 Gịnị mere ara ji dịrị i ji zụọ m? 
\q1  
\v 13 Nʼihi na ugbu a, agara m idina nʼudo; 
\q2 agaara m anọ nʼụra na izuike, 
\q1  
\v 14 mụ na ndị eze na ndị ọchịchị nke ụwa, 
\q2 ndị rụkwaara onwe ha ebe obibi dị iche iche nke tọgbọọrọ nʼefu ugbu a, 
\q1  
\v 15 mụ na ụmụ ndị ikom eze, ndị nwere ọlaedo, 
\q2 ndị jikwa ọlaọcha kpojuo ụlọ ha. 
\q1  
\v 16 Ọ bụ gịnị mere e zofughị m nʼala dịka nwantakịrị a mụkworo amụkwo, 
\q2 dịka nwa ọhụrụ nke na-ahụghị ìhè nke ụbọchị anya? 
\q1  
\v 17 Nʼebe ahụ ka ndị na-emebi iwu na-akwụsị iweta ọgbaaghara, 
\q2 nʼebe ahụ ka ndị ike gwụrụ na-ezu ike. 
\q1  
\v 18 Ebe ahụ ka ndị nọ nʼagbụ na-enwere onwe ha, 
\q2 ha adịghị anụkwa ịba mba nke ndị na-eji aka ike achị ha. 
\q1  
\v 19 Ebe ahụ ka ndị ukwu na ndị nta nọ; 
\q2 ebe ahụ kwa ka ohu na-enwere onwe ya kpamkpam site nʼaka onye nwe ya. 
\b  
\q1  
\v 20 “Nʼihi gịnị ka e ji enye ndị nọ nʼọnọdụ nhụju anya ìhè? 
\q2 Gịnị bụ uru ndụ nye onye mkpụrụobi ya jupụtara nʼihe ilu? 
\q1  
\v 21 Gịnị bụ uru ya nye ndị na-echere ọnwụ ma ọ dịghị abịa, 
\q2 ee, ndị na-achọsi ọnwụ ike karịa akụ e zoro ezo, 
\q1  
\v 22 ndị jupụtara nʼọṅụ, 
\q2 na-aṅụrị ọṅụ mgbe ha rịdaruru nʼili? 
\q1  
\v 23 Gịnị mere e ji enye mmadụ ndụ; 
\q2 bụ onye ahụ ụzọ ya zoro ezo, 
\q2 onye Chineke mechibidoro ụzọ? 
\q1  
\v 24 Nʼihi na ịma ọsụ aghọọla ihe oriri m kwa ụbọchị; 
\q2 ịsụ ude m na-awụpụtakwa dịka mmiri. 
\q1  
\v 25 Ihe m tụrụ egwu ya abịakwasịla m, 
\q2 ihe m tụrụ ụjọ ya bụ ihe bịakwasịrị m. 
\q1  
\v 26 Enweghị m udo, anọkwaghị m jụụ, 
\q2 enweghị m izuike, naanị ọgbaaghara.” 
\c 4  
\s1 Okwu Elifaz 
\p  
\v 1 Mgbe ahụ, Elifaz onye obodo Teman zara Job sị: 
\q1  
\v 2 “Iwe ọ ga-ewe gị ma ọ bụrụ na mmadụ agwa gị okwu? 
\q2 Onye kwanụ nwere ike ịnọ nʼebe a hapụ ikwu okwu? 
\q1  
\v 3 Lee ka i siri nye ọtụtụ mmadụ ndụmọdụ, 
\q2 na ka i si mee ka ndị na-ada mba nwee ume. 
\q1  
\v 4 Okwu ọnụ gị abụrụla ihe ịgbaume nye ọtụtụ mmadụ, 
\q2 ị bụrụla ịgbaume nye ndị ikpere ha na-ama jijiji. 
\q1  
\v 5 Ma leenụ ugbu a, nsogbu abịakwasịla gị, ị bụrụla onye na-ada mba; 
\q2 nsogbu etiela gị aka, i na-ama jijiji. 
\q1  
\v 6 Egwu ị na-atụ Chineke ọ gaghị abụ ihe ịgbaume nye gị, 
\q2 izi ezi nke ndụ gị abụrụkwa olileanya gị? 
\b  
\q1  
\v 7 “Chee echiche ugbu a! Onye, bụ onye aka ya dị ọcha, nke a larala nʼiyi? 
\q2 Ebee ka i hụrụ ka e bibiri ndị na-eme ihe ziri ezi? 
\q1  
\v 8 Dịka m si hụ ya, ndị na-agha ajọ ihe dịka mkpụrụ na ndị na-akụ okwu na ụka 
\q2 na-aghọta ya dịka ihe ubi. 
\q1  
\v 9 Chineke na-ala ha nʼiyi site nʼume ọ na-ekupụta. 
\q2 Ọ na-esitekwa nʼoke iwe ya repịa ha. 
\q1  
\v 10 Ọdụm nwere ike gbọọ ụja, maọbụ bigbọọ, 
\q2 ma eze ọdụm dị ike ka a gbajisiri. 
\q1  
\v 11 Oke ọdụm na-ala nʼiyi site na-enweghị ihe ọ dọgbutara, 
\q2 ụmụ nne ọdụm niile ka a na-achụsa. 
\b  
\q1  
\v 12 “E mere ka okwu rute m nʼụzọ nzuzo, 
\q2 ntị m nụrụ ya nʼịgba izu. 
\q1  
\v 13 Nʼime nkụja nke oke nrọ nke abalị, 
\q2 mgbe oke ụra na-adakwasị ụmụ mmadụ, 
\q1  
\v 14 oke ụjọ na ahụ ịma jijiji dakwasịrị m, 
\q2 meekwa ka ọkpụkpụ niile dị nʼahụ m maa jijiji. 
\q1  
\v 15 Otu mmụọ sitere nʼihu m gafee. 
\q2 Ọ bụladị ajị dị m nʼahụ guzochara ọtọ nʼihi ụjọ. 
\q1  
\v 16 Ọ kwụsịrị; 
\q2 ma apụghị m ịkọ ihe ọ bụ. 
\q1 Onyinyo guzooro nʼanya m, 
\q2 anụrụ m olu dị nro, nke kwuru sị: 
\q1  
\v 17 ‘Mmadụ efu ọ nwere ike bụrụ onye ezi omume karịa Chineke? 
\q2 Ọ bụladị nwoke dị ike, ọ pụrụ ịdị ọcha nʼobi karịa Onye kere ya? 
\q1  
\v 18 Ọ bụrụ na Chineke adịghị atụkwasị ndị ozi ya obi, 
\q2 ọ bụrụ na ọ na-ebo ndị mmụọ ozi ya ebubo imejọ ihe, 
\q1  
\v 19 ọ ga-esi aṅaa ghara ibo ndị bi nʼụlọ ụrọ ebubo karịa, 
\q2 bụ ndị ntọala ha dị nʼaja, 
\q2 ndị nke a na-azọpịa ngwangwa dịka nla. 
\q1  
\v 20 Site nʼụtụtụ ruo nʼanyasị, a na-etipịasị ha: 
\q2 ha na-ala nʼiyi ruo mgbe ebighị ebi, ihe niile a na-agakwa dịka o si aga. 
\q1  
\v 21 Ọ bụ na-eholiteghị eriri ụlọ ikwu ha elu, 
\q2 mee ka ha nwụọ na-enweghị amamihe?’ 
\b  
\c 5  
\q1  
\v 1 “Kpọọ oku ma ị chọọ, ma onyekwanụ ga-aza gị? 
\q2 Ole ndị dị nsọ ị ga-agbakwuru? 
\q1  
\v 2 Oke iwe na-egbu onye nzuzu, 
\q2 ekworo na-egbu onye na-enweghị uche. 
\q1  
\v 3 Mụ onwe m ahụla onye nzuzu ka ọ na-agba mgbọrọgwụ, 
\q2 mana mberede, abụrụ ụlọ ya ọnụ. 
\q1  
\v 4 Ụmụ ya na-anọpụ anya site nʼebe nchebe dị, 
\q2 a na-azọpịa ha nʼọnụ ụzọ ama, ọ dịkwaghị onye na-anapụta ha. 
\q1  
\v 5 Onye agụụ na-agụ na-eripịa ihe o wetara nʼubi; 
\q2 ọ na-ewere ihe ubi ndị a ọ bụladị site nʼetiti ogwu; 
\q2 akụnụba ya ka onye akpịrị na-akpọ nkụ ga-achụso. 
\q1  
\v 6 Nʼihi na ọnọdụ ọjọọ adịghị esite nʼala pupụta, 
\q2 ma ọ bụkwanụ nsogbu adịghịkwa esite nʼala walite. 
\q1  
\v 7 Kama, a mụrụ mmadụ nye nsogbu,\f + \fr 5:7 \ft \xt 14:1\f* 
\q2 dịka ire ọkụ si esite nʼọkụ a kwanyere na-amali elu. 
\b  
\q1  
\v 8 “Ma ọ bụrụ na m bụ gị, m ga-ekpesara Chineke; 
\q2 ya ka m ga-akọsara ihe niile. 
\q1  
\v 9 Nʼihi na Chineke na-arụ ọrụ ịtụnanya karịrị nghọta, 
\q2 ọrụ ebube nke a na-apụghị ịgụta ọnụ. 
\q1  
\v 10 Ọ bụ ya na-enye elu ụwa mmiri ozuzo, 
\q2 ma na-ezigakwa mmiri nʼubi niile. 
\q1  
\v 11 Ọ na-ebuli ndị dị ala elu, 
\q2 na-emekwa ka ndị na-eru ụjụ nọ nʼebe a na-echebe ha. 
\q1  
\v 12 Ọ na-emebi nzube niile nke ndị aghụghọ, 
\q2 ka aka ha ghara imezu ihe ha zubere. 
\q1  
\v 13 Ọ na-ejide ndị oke amamihe nʼaghụghọ ha niile, 
\q2 mee ka atụmatụ ndị aghụghọ bụrụ ihe e kpochapụrụ. 
\q1  
\v 14 Ọchịchịrị na-abịakwasị ha nʼoge ehihie, 
\q2 nʼetiti ehihie ha na-asọ ìsì dịka ndị nọ nʼọchịchịrị nke abalị; 
\q1  
\v 15 Ọ na-azọpụta ndị mkpa na-akpa, site na mma agha dị ha nʼọnụ, 
\q2 ọ na-anapụtakwa ha site nʼaka ndị dị ike. 
\q1  
\v 16 Ya mere, ndị ogbenye na-enwe olileanya, 
\q2 ikpe ezighị ezi na-emechikwa ọnụ ya. 
\b  
\q1  
\v 17 “Ngọzị na-adịrị mmadụ ahụ Chineke na-adọ aka na ntị; 
\q2 ya mere, ajụla ịdọ aka na ntị nke Onye pụrụ ime ihe niile. 
\q1  
\v 18 Nʼihi na ọ na-etihịa mmadụ ahụ ma na-ekechikwa ọnya ha; 
\q2 Ọ na-eti mmadụ ihe, ma aka ya na-agwọkwa. 
\q1  
\v 19 Ọ ga-anapụta gị site nʼụzọ nsogbu isii, 
\q2 mee ka ihe ọjọọ hapụ irute gị na nsogbu nke asaa. 
\q1  
\v 20 Ọ ga-echebe gị ka ị hapụ ịnwụ nʼoge ụnwụ; 
\q2 chebekwa gị ka mma agha hapụ ịmetụ gị nʼoge agha. 
\q1  
\v 21 Ị ga-abụ onye a na-echebe site na nkwutọ nke ire ndị ga-ekwutọ gị. 
\q2 Ị gaghị atụkwa egwu mgbe mbibi bịara. 
\q1  
\v 22 Ị ga-achị ọchị nʼoge ụnwụ na nʼoge mbibi, 
\q2 ị gaghị atụkwa egwu ajọ anụ ọhịa dị iche iche. 
\q1  
\v 23 Nʼihi na gị na nkume niile dị nʼọhịa ga-agba ndụ, 
\q2 gị na anụ ọhịa ga-anọkwa nʼudo. 
\q1  
\v 24 Ị ga-amata na ụlọ ikwu gị dị nʼudo; 
\q2 ị ga-agụkọ ihe niile i nwere chọpụta na o nweghị nke na-efu efu. 
\q1  
\v 25 Ị ga-amata na ụmụ gị ga-adị ọtụtụ, 
\q2 matakwa na ụmụ ụmụ gị dị ukwuu nʼọnụọgụgụ dịka ahịhịa dị nʼala. 
\q1  
\v 26 Ị ga-aba nʼili gị mgbe i mere nnọọ ezigbo agadi, 
\q2 dịka ọka a ghọrọ mgbe oge ya ruru. 
\b  
\q1  
\v 27 “Anyị enyochaala ihe a, hụ na ọ bụ eziokwu. 
\q2 Ya mere nụrụ ya, ma jiri ya rụọ ọrụ na ndụ gị.” 
\c 6  
\s1 Okwu Job 
\p  
\v 1 Mgbe ahụ, Job zara sị: 
\q1  
\v 2 “A sịkwarị na a pụrụ ịtụ ihe mgbu m 
\q2 ya na nhụju anya m niile nʼelu nʼihe ọtụtụ! 
\q1  
\v 3 Ọ ghaghị ịdị arọ karịa aja dị nʼọnụ mmiri ọtụtụ osimiri, 
\q2 nke mere okwu m ji ada ike ike. 
\q1  
\v 4 Àkụ Onye pụrụ ime ihe niile gbara dị nʼime m; 
\q2 mmụọ m na-aṅụkwa nsi dị na ha; 
\q2 ihe egwu Chineke edoola onwe ha nʼusoro imegide m. 
\q1  
\v 5 Ịnyịnya ibu ọhịa ọ na-akwa akwa mgbe o nwere ahịhịa ọ na-ata, 
\q2 ka oke ehi ọ na-akwa akwa mgbe ihe oriri ya dị? 
\q1  
\v 6 A na-eri nri na-adịghị ụtọ ma e etinyeghị ya nnu, 
\q2 ka o nwere ụtọ dị na eso ọkwụrụ? 
\q1  
\v 7 A jụrụ m ịmetụ ya aka, 
\q2 nʼihi na nri dị otu a na-eme ka m daa ọrịa. 
\b  
\q1  
\v 8 “O, asị nnọọ na a ga-emere m ihe m na-arịọ, 
\q2 na Chineke ga-enye m ihe m na-atụ anya ya. 
\q1  
\v 9 Ọbụladị ka Chineke kwe igwepịa m 
\q2 ka ọ tọpụ aka ya, bipụ ndụ m. 
\q1  
\v 10 Mgbe ahụ, aga m enwe nkasiobi a, 
\q2 wụlikwaa elu\f + \fr 6:10 \ft Maọbụ, \fqa nwekwa ọṅụ\f* nʼime ihe mgbu na-adịgide, 
\q2 na o nwebeghị oge ọbụla m gọnarịrị okwu nke Onye ahụ dị nsọ. 
\b  
\q1  
\v 11 “Ike gịnị ka m nwere, na m ga-anọgide na-enwe olileanya ndụ? 
\q2 Ọganihu gịnị dị, na m na-anọgide na-enwe ndidi? 
\q1  
\v 12 Ọ ga-abụ na m nwere ike nkume? 
\q2 Ka anụ ahụ m ọ bụ bronz? 
\q1  
\v 13 Ọ ga-abụ na m nwere ike inyere onwe m aka, 
\q2 ugbu a, e siterela nʼebe m nọ wezuga nzube? 
\b  
\q1  
\v 14 “Onye ọbụla nʼejichi ebere site nʼebe enyi ya nọ 
\q2 na-agbakụta egwu Onye pụrụ ime ihe niile azụ. 
\q1  
\v 15 Ma ụmụnna m bụ ndị a na-ekwesighị ịdabere na ha, 
\q2 dịka iyi mmiri na-akọ, dịka iyi nke na-etofe ọnụ ya, 
\q1  
\v 16 nke na-eji ojii nʼihi mkpụrụ mmiri oyi, 
\q2 nke unyi jupụtara nʼihi mgbaze nke mkpụrụ mmiri oyi. 
\q1  
\v 17 Nke na-akwụsị ịsọpụta nʼoge ọkọchị, 
\q2 nke na-ata ata nʼihi okpomọkụ. 
\q1  
\v 18 Ndị ije na-atụgharị site nʼokporoụzọ ije ha. 
\q2 Ha na-arịgo nʼala akọrọ si otu a laa nʼiyi. 
\q1  
\v 19 Ndị ije si Tema na-ele anya mmiri, 
\q2 otu a kwa ndị ahịa Sheba na-ele anya nʼolileanya. 
\q1  
\v 20 Obi mgbu na-ejide ha nʼihi na ha nwere ntụkwasị obi, 
\q2 ha bịarutere ebe ahụ, bụrụ ndị emenyere ihere. 
\q1  
\v 21 Ma ugbu a, unu egosila na unu abaghị uru, 
\q2 unu ahụla ihe na-eyi egwu ma ụjọ ejidela unu. 
\q1  
\v 22 O nweela mgbe m sịrị unu, ‘Nyenụ ihe ọbụla nʼọnọdụ m, 
\q2 sitenụ nʼakụnụba unu kwụọ ụgwọ ịgbapụta m, 
\q1  
\v 23 gbapụtanụ m nʼaka ndị iro, 
\q2 maọbụ napụtanụ m nʼaka ndị na-enweghị obi ebere’? 
\b  
\q1  
\v 24 “Zienụ m ihe ga-eme ka m mechie ọnụ, 
\q2 gosi m ebe m si mejọọ. 
\q1  
\v 25 Eziokwu na-egbu mgbu nʼobi! 
\q2 Ma gịnị ka ịrụ ụka unu na-ewepụta? 
\q1  
\v 26 Ị chọrọ idozi okwu ọnụ m? 
\q2 Si otu a mee ka okwu onye ike gwụrụ ghọọ ikuku efu? 
\q1  
\v 27 Unu nwere ike ife nza nʼisi onye na-enweghị nna, 
\q2 ma refukwaa enyi unu. 
\b  
\q1  
\v 28 “Lezie m anya nke ọma, 
\q2 ọ dị unu ka m nwere ike ilegide unu anya gwa unu okwu ụgha? 
\q1  
\v 29 Kwụsịnụ ihe unu na-eme. Unu abụla ndị na-eme ihe na-ezighị ezi, 
\q2 tuleenụ ihe unu na-eme, nʼihi na ezi omume m ka guzosiri ike. 
\q1  
\v 30 Ọ dị ihe ọjọọ si nʼegbugbere ọnụ m abụọ pụta? 
\q2 Ọ bụ na ọnụ m apụghị ịchọpụta nzube iro? 
\b  
\c 7  
\q1  
\v 1 “Ndụ mmadụ nʼụwa ọ bụghị ọgụ na mgba? 
\q2 Ụbọchị ya ọ dịghị ka ụbọchị onye e goro ọrụ? 
\q1  
\v 2 Dịka ọhụ na-eche mgbe anyanwụ ga-ada, 
\q2 maọbụ dịka onye e goro ọrụ si ele anya ụgwọ ọrụ ya, 
\q1  
\v 3 otu a ka e si kenye m ọtụtụ ọnwa nke obi ụtọ na-adịghị nʼime ya, 
\q2 nakwa abalị nhụju anya dị nʼime ya. 
\q1  
\v 4 Mgbe m na-edina ala, ana m asị, ‘Olee mgbe m ga-ebili?’ 
\q2 Abalị na-eseti onwe ya, nʼihi ya, m na-anọ na-atụgharị onwe m tutu chi abọọ. 
\q1  
\v 5 Lee na anụ ahụ m jupụtara nʼikpuru, na akpụkpọ; 
\q2 anụ ahụ m etiwasịala jupụta nʼọnya. 
\b  
\q1  
\v 6 “Ụbọchị nke ndụ m na-agabiga ngwangwa karịa ihe eji akpa akwa nke ọkpa akwa, 
\q2 ha na-agwụcha na-enweghị olileanya ọbụla. 
\q1  
\v 7 O Chineke cheta na ndụ m bụ naanị otu nkuume; 
\q2 anya m abụọ agaghị ahụkwa ọṅụ ọzọ. 
\q1  
\v 8 Anya na-ahụ m ugbu a agaghị ahụkwa m ọzọ; 
\q2 unu ga-achọ m ma unu agaghị a hụ m ọzọ. 
\q1  
\v 9 Dịka igwe ojii si efefusi ma na-agbasa, 
\q2 otu a ka ọ dịrị onye na-arịda nʼime ili ọ naghị arịpụtakwa. 
\q1  
\v 10 E, ọ naghị alọghachikwa nʼụlọ ya ọzọ; 
\q2 ebe ya agaghị amakwa ya ọzọ. 
\b  
\q1  
\v 11 “Ya mere agaghị m emechi ọnụ; 
\q2 aga m ekwupụta nʼihi ihe mgbu dị m nʼime mmụọ. 
\q2 Aga m eme mkpesa nʼihi ihe ilu dị m nʼobi. 
\q1  
\v 12 A bụ m oke osimiri, maọbụ anụ ukwu dị nʼogbu osimiri, 
\q2 nke mere i ji eche m nche? 
\q1  
\v 13 Mgbe m chere na ihe ndina m ga-akasị m obi, 
\q2 maọbụ na oche izuike m ga-ewepụ ntamu m, 
\q1  
\v 14 nʼagbanyeghị na ị na-eji nrọ menye m egwu 
\q2 werekwa ịhụ ọhụ mee ka m maa jijiji, 
\q1  
\v 15 ya mere, ahọrọ m ị bụ onye a tọgburu atọgbu na ọnwụ, 
\q2 karịa inwe ụdị ahụ m nke a. 
\q1  
\v 16 Ana m asọ ndụ m oyi; agaghị m adị ndụ ruo ebighị ebi. 
\q2 Nʼihi ya, hapụ m ka m nọọrọ onwe m, nʼihi na ụbọchị ndụ m enweghị isi. 
\b  
\q1  
\v 17 “Gịnị ka mmadụ bụ i ji na-agụ ya dịka ihe, 
\q2 i ji na-elenye anya nʼihe gbasara ya, 
\q1  
\v 18 i ji na-enyocha ya ụtụtụ niile, 
\q2 ma na-anwale ya mgbe mgbe? 
\q1  
\v 19 Ị gaghị elepụ anya gị site nʼebe m nọ, 
\q2 maọbụ hapụ m ka m nọọrọ onwe m loda asụ mmiri? 
\q1  
\v 20 Ọ bụrụ na m emehiela, gịnị ka m mere megide gị, 
\q2 gị onye na-ahụ ihe niile anyị na-eme? 
\q1 Gịnị mere i ji elekwasị m anya? 
\q2 Abụrụla m ibu arọ nye gị? 
\q1  
\v 21 Ọ bụ na i nweghị ike ịgbaghara m njehie m, 
\q2 ma bupụ mmehie m? 
\q1 Nʼihi na oge ọnwụ m eruola nso, e, oge a ga-eliba m nʼaja, ma m nwụọ. 
\q2 Mgbe ahụ ị ga-achọ m, ma ị gaghị ahụkwa m anya ọzọ, nʼihi na agaghị m adịkwa.” 
\c 8  
\s1 Okwu Bildad 
\p  
\v 1 Mgbe ahụ, Bildad onye Shua zaghachiri sị: 
\q1  
\v 2 “Ruo ole mgbe ka i ga na-ekwu okwu dị otu a? 
\q2 Okwu ọnụ gị bụ naanị ifufe dị ike. 
\q1  
\v 3 Chineke ọ na-ekpe ikpe na-ezighị ezi? 
\q2 Onye pụrụ ime ihe niile ọ na-eme ka ihe ziri ezi gbagọọ agbagọ? 
\q1  
\v 4 Mgbe ụmụ gị mehiere megide ya, 
\q2 o weere ha nyefee nʼikpe ọmụma kwesiri mmehie ha. 
\q1  
\v 5 Ma ọ bụrụ na i ga-achọsi Chineke ike, 
\q2 rịọ Onye pụrụ ime ihe niile, 
\q1  
\v 6 ọ bụrụ na ị bụ onye dị ọcha nʼobi na onye ụzọ ya ziri ezi, 
\q2 ọ bụladị ugbu a, ọ ga-agbachitere gị 
\q2 weghachi gị nʼọnọdụ ịbụ ọgaranya gị. 
\q1  
\v 7 Ọ bụ ezie, na mmalite gị nwere ike ịdị ala, 
\q2 ma ụbọchị ikpeazụ gị ga-adị elu. 
\b  
\q1  
\v 8 “Jụọ ọgbọ ndị gara aga 
\q2 ma chọpụta ihe ndị bụ nna ha chọpụtara. 
\q1  
\v 9 Nʼihi na anyị onwe anyị bụ ndị a mụrụ naanị ụnyaahụ, ndị ọ dịghị ihe ha maara. 
\q2 Ụbọchị ndụ anyị nʼụwa dịka onyinyo. 
\q1  
\v 10 Ọ bụ na ha agaghị agwa gị ma kuziekwara gị ihe? 
\q2 Ọ bụ na ha agaghị esite na nghọta kwuo okwu? 
\q1  
\v 11 Ahịhịa papịrọs o nwere ike ito nʼebe apịtị na-adịghị? 
\q2 Ahịhịa riidi ọ ga-eto nʼebe mmiri na-adịghị? 
\q1  
\v 12 Nʼihi na mgbe ha ka na-etopụta etopụta, mgbe a na-egbubibeghị ha, 
\q2 ha na-ebu ahịhịa ndị ọzọ ụzọ kpọnwụọ. 
\q1  
\v 13 Nke a bụ oke ndị na-echefu Chineke, 
\q2 otu a kwa ka olileanya nke onye na-amaghị Chineke si ala nʼiyi. 
\q1  
\v 14 Ihe ọ tụkwasịrị obi bụ ihe na-awa awa; 
\q2 ihe mgbakwasị ụkwụ ya bụ akwụ udide. 
\q1  
\v 15 Ọ bụrụ na ọ dabere na ya, ọ ga-etibi; 
\q2 ọ bụrụ na o jide ya aka, ọ ga-adọbikwa. 
\q1  
\v 16 Ọ dị ka ahịhịa ubi a na-agba mmiri nke ọma nʼubi a gbara ogige, nke anwụ na-amụkwasị, 
\q2 nke ome ya na-awasa ruo akụkụ niile nke ogige ahụ. 
\q1  
\v 17 Mgbọrọgwụ ya tụhịrị gburugburu nkume ndị dị nʼubi ahụ, 
\q2 ma na-achọkwa ọnọdụ nʼetiti nkume ndị a. 
\q1  
\v 18 Ma mgbe e si nʼọnọdụ ya hopu ya, 
\q2 ebe ahụ na-agọnarịkwa ya, na-asị, ‘Ahụtụbeghị m gị.’ 
\q1  
\v 19 Nʼezie, ndụ ya na-akpọnwụ, 
\q2 site nʼala ahụ ahịhịa ndị ọzọ na-etopụtakwa. 
\b  
\q1  
\v 20 “Nʼezie Chineke anaghị agbakụta onye ụzọ ya ziri ezi azụ, 
\q2 maọbụ gbaa aka onye ajọ omume ume. 
\q1  
\v 21 Ọ ga-eme ka ọnụ gị jupụta nʼọchị. 
\q2 Ọ ga-eme ka mkpu ọṅụ si nʼegbugbere ọnụ gị pụta. 
\q1  
\v 22 Ndị iro gị ka a ga-eyikwasị ihere dị ka uwe, 
\q2 ebe obibi nke ndị na-emebi iwu agaghị adịkwa.” 
\c 9  
\s1 Okwu Job 
\p  
\v 1 Job zara sị: 
\q1  
\v 2 “Nʼezie, amaara m na ihe ndị a bụ eziokwu. 
\q2 Ma mmadụ dị ndụ ọ ga-esi aṅaa gosi na ya bụ onye aka ya dị ọcha nʼihu Chineke? 
\q1  
\v 3 Ọ bụrụ na Chineke ekpebie ịjụ mmadụ ajụjụ, 
\q2 ebee ka mmadụ ahụ nọ nke nwere ike ịza ọ bụladị otu nʼime ajụjụ dị iche iche Chineke ga-ajụ ya? 
\q1  
\v 4 Amamihe ya dị ukwuu, ike ya sara mbara, 
\q2 onye guzogidere ya ma hapụ imerụ ahụ? 
\q1  
\v 5 Ọ na-enugharị ugwu ukwu ma ha adịghị ama nke a, 
\q2 na-akwatụ ha nʼiwe ya. 
\q1  
\v 6 Ọ na-enugharịkwa ụwa site na ntọala ya, 
\q2 mee ka ogidi ya maa jijiji. 
\q1  
\v 7 Ọ na-agwa anyanwụ okwu mee ka ọ kwụsị ịcha; 
\q2 ọ na-emenyụ ìhè kpakpando na-enye. 
\q1  
\v 8 Naanị ya gbasara mbara eluigwe, 
\q2 ọ na-agakwa ije nʼelu ebili mmiri nke oke osimiri. 
\q1  
\v 9 Ọ bụ ya mere kpakpando Bịaa, na Orion 
\q2 na Pleiades, na kpakpando niile nke ndịda eluigwe. 
\q1  
\v 10 Ọ na-arụ ọtụtụ ọrụ ebube nke mmadụ na-enweghị ike ịghọta, 
\q2 ihe ịrịbama nke ọnụ na-enweghị ike ịgụta. 
\q1  
\v 11 Mgbe ọ na-esi nʼakụkụ m agafe, enweghị m ike ịhụ ya, 
\q2 mgbe ọ na-agabiga, adịghị m amata na ọ bụ ya. 
\q1  
\v 12 Ọ bụrụ na ọ pụnara ihe, onye na-akwụsị ya? 
\q2 Onye kwa pụrụ ịjụ ya si, ‘Gịnị ka ị na-eme?’ 
\q1  
\v 13 Chineke adịghị eme ka iwe ya laghachi, 
\q2 ọbụladị ndị inyeaka Rehab, ruru ala nʼụkwụ ya. 
\b  
\q1  
\v 14 “Onye kwanụ ka m bụ, m ga-eji nwee ike iguzo nʼihu ya ịjụ ya ajụjụ, 
\q2 maọbụ mụ na ya ịrụrịta ụka? 
\q1  
\v 15 Nʼagbanyeghị na aka m dị ọcha, apụghị m ịsa ya okwu; 
\q2 kama m ga-arịọ onye ikpe m ka o mere m ebere. 
\q1  
\v 16 A sịkwarị na m kpọọ ya oku, ọ za m, 
\q2 ekwenyeghị m na ọ ga-ege m ntị. 
\q1  
\v 17 Ọ ga-eji oke ifufe tirie m, 
\q2 meekwa ka ihe mgbu m baa ụba na-enweghị ihe butere ya. 
\q1  
\v 18 Ọ gaghị ekwe ka iku ume m lọghachi 
\q2 kama ọ ga-eji iru ụjụ kpuchie m. 
\q1  
\v 19 Ọ bụrụ ihe e ji ike eme, lee na ọ dị ike nke ukwuu! 
\q2 Ọzọ ọ bụrụ nʼikpe ziri ezi, onye pụrụ iguzogide ya. 
\q1  
\v 20 A sịkwarị na aka m dị ọcha, ọnụ m ga-ama m ikpe; 
\q2 ọ bụrụ na abụ m onye na-enweghị ịta ụta, ọ ga-agụ m nʼonye ikpe mara. 
\b  
\q1  
\v 21 “Ọ bụ ezie na abụ m onye ikpe na-amaghị 
\q2 ejighị m onwe m kpọrọ ihe; 
\q2 nʼezie ana m eleda ndụ m anya. 
\q1  
\v 22 Otu ihe ahụ ka ọ bụ; nʼihi ya ka m ji asị, 
\q2 ‘Ọ na-ala ndị ezi omume na ndị ajọ omume nʼiyi.’ 
\q1  
\v 23 Mgbe ịpịa ụtarị wetara ọnwụ mberede, 
\q2 ọ na-achị enweghị olileanya nke ndị na-enweghị ihe ha mere ọchị. 
\q1  
\v 24 Mgbe ala dabara nʼaka ndị na-emebi iwu, 
\q2 ọ na-ekpuchi ndị ọkaikpe anya. 
\q2 Ọ bụrụ na ọ bụghị ya na-eme ya, onye kwanụ bụ onye ahụ na-eme ya? 
\b  
\q1  
\v 25 “Ụbọchị ndụ m dị gara gara karịa onye ọgba ọsọ; 
\q2 ha na-agafekwa na-ahụtụghị ọṅụ anya. 
\q1  
\v 26 Ha na-agafe dịka ụgbọ mmiri papịrọs,\f + \fr 9:26 \ft Ọ bụ nʼIjipt ka a na-eji ahịhịa papịrọs arụ ụgbọ epeepe. \xt Ọpụ 2:3\f* 
\q2 dịka mgbe ugo na-efeda ngwangwa ijide anụ ọ ga-eri. 
\q1  
\v 27 Ọ bụrụ na m sị, ‘Aga m echefu mkpesa m, 
\q2 aga m agbanwe ihu m, nwee ihu ọchị.’ 
\q1  
\v 28 Nsogbu m niile ka na-atụ m egwu 
\q2 nʼihi na amara m na ị gaghị ewere m dịka onye aka ya dị ọcha. 
\q1  
\v 29 Ebe m bụrịị onye ikpe mara, 
\q2 nʼihi gịnị ka m ji na-adọgbu onwe m nʼefu? 
\q1  
\v 30 A sịkwarị na m jiri ncha saa ahụ m 
\q2 werekwa soda saa aka m abụọ, 
\q1  
\v 31 ị ga-enuba m nʼolulu apịtị 
\q2 nke pụrụ ime ka uwe m yi nʼahụ m kpọọ m asị. 
\b  
\q1  
\v 32 “Ọ bụghị mmadụ efu dịka m nke m ga-aza ya, 
\q2 ka anyị abụọ kpọrịtaa onwe anyị ikpe nʼụlọikpe. 
\q1  
\v 33 A sịkwarị na e nwere onye odozi okwu nʼetiti mụ na gị, 
\q2 onye ga-ebikwasị anyị abụọ aka ya, 
\q1  
\v 34 onye ga-ewepụ mkpara Chineke site nʼebe m nọ, 
\q2 ka oke egwu ya gharakwa ịtụ m ọzọ. 
\q1  
\v 35 Mgbe ahụ ka m ga-ekwu okwu na-atụghị ya egwu; 
\q2 ma ka ọ dị ugbu a ọ dịghị ihe m nwere ike ime. 
\b  
\c 10  
\q1  
\v 1 “Ike ịdị ndụ agwụla m. 
\q2 Hapụnụ m ka m kwuo ihe dị m nʼobi, 
\q2 kwupụta ya dịka obi ilu nke mkpụrụobi m si dị. 
\q1  
\v 2 Ihe m ga-agwa Chineke bụ nke a: Apụtala maa m ikpe, 
\q2 kama gwa m ihe mere i ji ama m ikpe. 
\q1  
\v 3 Ọ dị gị mma nʼobi imegbu m, 
\q2 si otu a leda ọrụ aka gị anya, 
\q2 mgbe ị na-anabata atụmatụ nke ndị na-emebi iwu? 
\q1  
\v 4 Ị nwere anya nke anụ ahụ? 
\q2 Ị na-ahụ ụzọ dịka mmadụ si ahụ? 
\q1  
\v 5 Ụbọchị nke gị, ha dịka nke ndị nwere anụ ahụ, 
\q2 ka afọ nke gị, ha dịka nke mmadụ dị ike? 
\q1  
\v 6 Nke ga-eme na i na-achọpụta ikpe ọmụma m 
\q2 ma nyochaa mmehie m? 
\q1  
\v 7 Ọ bụ ezie na ị maara na ikpe amaghị m, 
\q2 na ọ dịghị onye pụrụ ịnapụta m site nʼaka gị. 
\b  
\q1  
\v 8 “Ọ bụ aka gị kpụrụ m kee m.\f + \fr 10:8 \ft \xt Abụ 119:73; 139:13\f* 
\q2 Ọ ga-atụgharịa ugbu a bibie m? 
\q1  
\v 9 Cheta na ị kpụrụ m dịka ụrọ. 
\q2 Ị ga-eme ka m laghachi nʼaja ọzọ? 
\q1  
\v 10 Ọ bụ na ị wụpụghị m dịka mmiri ara ehi 
\q2 mee ka m kpụkọta dịka mmiri ara rahụrụ arahụ? 
\q1  
\v 11 Yikwasị m akpụkpọ ahụ na anụ ahụ, 
\q2 werekwa ọkpụkpụ na akwara kpaa m dịka uwe? 
\q1  
\v 12 I nyere m ndụ gosikwa m obiọma gị, 
\q2 nʼịdị mma gị chebekwara mmụọ m. 
\b  
\q1  
\v 13 “Ma nke a bụ ihe i zoro nʼime obi gị, 
\q2 amakwa m na ọ bụ ihe dị gị nʼuche. 
\q1  
\v 14 Ọ bụrụ na m mehiere, ị ga na-ele m anya, 
\q2 ị gaghị ekwe ka m ghara ịta ahụhụ nʼihi mmehie m. 
\q1  
\v 15 Ọ bụrụ na ikpe mara m, ahụhụ na-adịrị m! 
\q2 A sịkwarị na aka m dị ọcha, apụghị m iweli isi m elu 
\q1 nʼihi na ejupụtara m nʼihere, 
\q2 bụrụkwa onye e mibara nʼime nsogbu m. 
\q1  
\v 16 Ọ bụrụ na m welie m isi elu, dịka ọdụm ị ga-eji nwayọọ na-eso m nʼazụ 
\q2 ma werekwa ike gị dị egwu megide m. 
\q1  
\v 17 I na-eweta ndị ama ọhụrụ megide m, 
\q2 mee ka iwe gị baa ụba nʼebe m nọ; 
\q2 ị na-eme ka ndị agha gị na-abịakwute m, otu nʼelu ibe ya dịka ebili mmiri. 
\b  
\q1  
\v 18 “Gịnị mere i ji wepụta m site nʼafọ nne m? 
\q2 Ọ gaara aka m mma ịnwụ tupu anya ọbụla ahụ m. 
\q1  
\v 19 A sịkwarị na amụpụtaghị m 
\q2 maọbụ na e sitere nʼafọ nne m buba m nʼime ili! 
\q1  
\v 20 Ụbọchị ndụ m ọ dịghị ole na ole? 
\q2 Si nʼebe m nọ wezuga onwe gị ka m nwetu ọṅụ nwa mgbe nta, 
\q1  
\v 21 tupu m hapụ laa nʼala ọchịchịrị na onyinyo nke ọnwụ 
\q2 ebe m na-agaghị esi pụtakwa. 
\q1  
\v 22 Nʼala nke oke ọchịchịrị, 
\q2 ala nke onyinyo ọnwụ, nke usoro na-adịghị, 
\q2 ebe ọbụladị ìhè dịkwa ka ọchịchịrị.” 
\c 11  
\s1 Okwu Zofa 
\p  
\v 1 Mgbe ahụ, Zofa onye Neama zara sị: 
\q1  
\v 2 “Ọ dịghị nzaghachi dịịrị ọtụtụ okwu niile ndị a? 
\q2 A ga-agụ onye ekwurekwu a dịka onye ikpe na-amaghị? 
\q1  
\v 3 Okwu efu gị ndị a ha ga-eme ka mmadụ gba nkịtị? 
\q2 Ọ bụ na ọ dịghị onye ga-abara gị mba mgbe ị na-akwa emo? 
\q1  
\v 4 Ị na-asị Chineke, ‘Okwukwe m enweghị ntụpọ, 
\q2 adịkwa m ọcha nʼanya gị.’ 
\q1  
\v 5 Ọ ga-adị m nnọọ mma ma a si na Chineke ga-ekwu okwu, 
\q2 na ọ ga-asaghe egbugbere ọnụ ya imegide gị. 
\q1  
\v 6 Kpugheere gị ihe nzuzo niile nke amamihe, 
\q2 nʼihi na ezi amamihe nwere akụkụ abụọ. 
\q2 Mara nke a: Chineke echefuola ụfọdụ mmehie gị. 
\b  
\q1  
\v 7 “I nwere ike ịchọpụta ihe omimi Chineke? 
\q2 I nwere ike ịnwapụta nsọtụ nke Onye pụrụ ime ihe niile? 
\q1  
\v 8 Ha dị elu karịa eluigwe, gịnị ka ị pụrụ ime? 
\q2 Ha dị ogbu karịa ala ili, gịnị ka ị pụrụ ịma? 
\q1  
\v 9 Ọtụtụ ha dị ogologo karịa ụwa, 
\q2 dị obosara karịa oke osimiri. 
\b  
\q1  
\v 10 “Ọ bụrụ na ọ bịa tụba gị nʼime ụlọ mkpọrọ, 
\q2 kpọkọta ndị ikpe, onye ga-egbochi ya? 
\q1  
\v 11 Nʼezie, ya onwe ya na-amata ndị nduhie, 
\q2 mgbe ọ hụrụ ajọ ihe, ọ bụ na ọ dịghị amatakwa ya? 
\q1  
\v 12 Onye nzuzu ga-aghọ onye maara ihe 
\q2 naanị mgbe nwa ịnyịnya ibu ọhịa mụrụ ghọrọ mmadụ. 
\b  
\q1  
\v 13 “Ma ọ bụrụ na i were obi gị nye ya, 
\q2 setịpụ aka gị abụọ nye ya, 
\q1  
\v 14 ọ bụrụ na i wezuga mmehie nke dị gị nʼaka, 
\q2 ghara ikwe ka ihe ọjọọ dịrị nʼụlọ ikwu gị 
\q1  
\v 15 mgbe ahụ, ihere agaghị eme gị iwelite ihu gị, 
\q2 ị ga-eguzokwa chịm na-atụghị egwu. 
\q1  
\v 16 Nʼezie ị ga-echefukwa nsogbu gị, 
\q2 na-echeta ya dịka mmiri gabigara agabiga. 
\q1  
\v 17 Ndụ gị ga-amụke karịa etiti ehihie, 
\q2 ọchịchịrị ya ga-adịkwa ka ụtụtụ. 
\q1  
\v 18 Ị ga-anọkwa nʼudo nʼihi na olileanya dị; 
\q2 ị ga-elegharịkwa anya gburugburu gị zuo ike na-atụghị ụjọ. 
\q1  
\v 19 Ị ga-edina ala na-atụghị egwu onye ọbụla, 
\q2 ọtụtụ ndị mmadụ ga-achọ ịnata amara nʼihu gị. 
\q1  
\v 20 Ma anya ndị na-emebi iwu ga-ada, 
\q2 ha agaghị achọta ụzọ mgbapụ; 
\q2 olileanya ha ga-abụ nkubi ume nke ọnwụ.” 
\c 12  
\s1 Okwu Job 
\p  
\v 1 Mgbe ahụ, Job zara: 
\q1  
\v 2 “Nʼezie, naanị unu bụ ndị maara ihe, 
\q2 unu na amamihe ga-anwụkọ nʼotu. 
\q1  
\v 3 Ma enwere m mmụọ iche uche dịka unu; 
\q2 abụghị m onye na-erughị eru nʼebe unu nọ. 
\q2 Onye bụ onye na-amaghị ihe ndị a unu na-ekwu? 
\b  
\q1  
\v 4 “Abụzi m ihe ọchị nʼebe ndị enyi m nọ, 
\q2 nʼagbanyeghị na m kpọkuru Chineke, ọ za, 
\q2 onye ezi omume, onye na-enweghị ịta ụta bụzikwa ihe eji akpa ọchị! 
\q1  
\v 5 Ndị na-enweghị nsogbu na-eleda ndị ọdachi dakwasịrị anya 
\q2 dịka nsogbu si eche ndị ụkwụ ha na-amịchapụ amịchapụ. 
\q1  
\v 6 Ụlọ ikwu nke ndị na-apụnara mmadụ ihe na-adị jụụ; 
\q2 ndị na-akpasu Chineke iwe na-adị nʼudo, 
\q2 bụ ndị na-ebugharị chi ha nʼaka ha. 
\b  
\q1  
\v 7 “Ma jụọ ụmụ anụmanụ, ha ga-akụziri gị, 
\q2 maọbụ ụmụ nnụnụ, ha ga-agwa gị. 
\q1  
\v 8 Ma ọ bụkwanụ gwa ala okwu, ọ ga-akụziri gị, 
\q2 maọbụ kwere ka azụ nọ na mmiri kọọrọ gị. 
\q1  
\v 9 Olee otu nʼime ihe ndị a nke na-amaghị 
\q2 na ọ bụ aka \nd Onyenwe anyị\nd* mere nke a? 
\q1  
\v 10 Nʼaka ya ka ndụ ihe niile e kere eke dị, 
\q2 ya na ndụ ụmụ mmadụ 
\q1  
\v 11 Ọ bụ na ntị adịghị anwale okwu, 
\q2 otu ire si anwale ihe oriri? 
\q1  
\v 12 Ọ bụ na-adịghị ahụ amamihe nʼetiti ndị okenye? 
\q2 Ogologo ndụ, ọ dịghị eweta nghọta? 
\b  
\q1  
\v 13 “Ọ bụ Chineke nwe amamihe na ike, 
\q2 ndụmọdụ na nghọta bụkwa nke ya. 
\q1  
\v 14 Ihe o tidara enweghị mwugharị ọzọ; 
\q2 mgbapụta adịghị nye onye o tụbara nʼụlọ mkpọrọ. 
\q1  
\v 15 Ọ bụrụ na o gbochie mmiri, ebe niile atakọrọchaa. 
\q2 Ọ bụrụ na o zipụ ha, ha erikpuo ala niile. 
\q1  
\v 16 Nʼaka ya ka ike na nzube ihe dị; 
\q2 ndị a ghọgburu na ndị na-aghọgbu bụkwa nke ya. 
\q1  
\v 17 Ọ na-anapụ ndị ndụmọdụ ọkwa ha chụpụ ha, 
\q2 ma ndị ikpe ka ọ na-eme ka ha ghọọ ndị nzuzu. 
\q1  
\v 18 Ọ na-atọpụ mkpọrọ igwe ndị eze kere, 
\q2 ma were akwa mgbochi kee ha nʼukwu.\f + \fr 12:18 \ft Ndị ohu a dọtara nʼagha bụ naanị akwa mgbochi a na-eke nʼukwu ka ha na-eyi.\f* 
\q1  
\v 19 Ọ na-agbawa ndị nchụaja ọtọ chụpụ ha, 
\q2 kwatuokwa ndị ọnọdụ ha sirila ike ogologo oge gara aga. 
\q1  
\v 20 Ọ na-emechi ọnụ ndị ndụmọdụ a tụkwasịrị obi, 
\q2 wepụkwa nghọta nke ndị okenye. 
\q1  
\v 21 Ọ na-eji ndị ọgaranya eme ihe ọchị, 
\q2 napụkwa ngwa agha nke ndị dị ike. 
\q1  
\v 22 Ọ na-ekpughe ihe omimi nke ọchịchịrị 
\q2 meekwa ka oke ọchịchịrị pụta ìhè. 
\q1  
\v 23 Ọ na-eme ka mba dị ukwuu, ọ na-emekwa ka ha laa nʼiyi; 
\q2 Ọ na-eme ka mba baa ụba, ma chụsakwaa ha. 
\q1  
\v 24 Ọ na-anapụ ndị ndu nke ụwa amamihe ha, 
\q2 zipụkwa ha ka ha na-awagharị nʼọzara ebe ụzọ na-adịghị. 
\q1  
\v 25 Ha na-asọgharị ìsì nʼọchịchịrị na-enweghị ìhè. 
\q2 Ọ na-eme ha ka ha na-adagharị dịka ndị mmanya na-egbu. 
\b  
\c 13  
\q1  
\v 1 “Anya m abụọ ahụla ihe ndị a niile, 
\q2 ntị m anụla ma ghọtakwa ha. 
\q1  
\v 2 Mụ onwe m makwa ihe unu maara; 
\q2 abụghị m onye dị ala nʼebe unu nọ. 
\q1  
\v 3 Ma ọ bụ Onye pụrụ ime ihe niile ka m chọrọ ịgwa okwu, 
\q2 ka mụ na Chineke rụọkwa ụka banyere okwu m. 
\q1  
\v 4 Ma otu ọ dị, unu ji okwu ụgha etechi m dịka ọ bụ mgba ụlọ; 
\q2 unu niile bụ ndị dibịa na-abaghị uru. 
\q1  
\v 5 Ọ bụrụ nnọọ na unu ga-agba nkịtị, 
\q2 nke a gaara egosi na unu bụ ndị nwere amamihe. 
\q1  
\v 6 Ugbu a, nụrụnụ ịrụ ụka m; 
\q2 geekwanụ ntị nụrụ okwu si m nʼọnụ na-apụta. 
\q1  
\v 7 Unu ga-ekpelara Chineke ikpe mmegide? 
\q2 Unu ga-esite nʼokwu aghụghọ kwuchitere Chineke ọnụ ya? 
\q1  
\v 8 Unu ga-egosi ya na unu na-ekpelara ya ikpe? 
\q2 Unu ga-ekwuchite ọnụ Chineke? 
\q1  
\v 9 Ọ ga-adịrị unu mma ma ọ bụrụ na o nyochaa unu? 
\q2 Unu pụrụ ịghọgbu ya dịka unu si aghọgbu ndị mmadụ? 
\q1  
\v 10 Ọ ghaghị ịbara unu mba 
\q2 ma ọ bụrụ na unu ejiri okwu ụgha chọọ inyere ya aka. 
\q1  
\v 11 Ọ ga-abụ na ebube na ịdị ukwuu ya adịghị eme ka unu maa jijiji? 
\q2 Egwu ya ọ dịghị atụ unu? 
\q1  
\v 12 Okwu amamihe unu niile dịka ilu nke ntụ; 
\q2 okwu ngọpụ unu dịka ihe ngọpụ ụrọ. 
\b  
\q1  
\v 13 “Nọọnụ jụụ ka m kwuo okwu; 
\q2 ihe ọ pụtara ya pụta. 
\q1  
\v 14 Nʼihi gịnị ka m ga-eji tinye onwe m na nsogbu, 
\q2 werekwa ndụ m tinye nʼọbụaka m? 
\q1  
\v 15 A sịkwarị na ọ ga-etigbu m aghaghị m ịtụkwasị ya obi m. 
\q2 Aga m ekwuchite ọnụ m gwa ya na ụzọ m dị ọcha. 
\q1  
\v 16 Nʼezie, nke a ga-aghọrọ m nzọpụta 
\q2 maka na ọ dịghị onye ajọ omume ọbụla pụrụ ịbịa nʼihu ya. 
\q1  
\v 17 Geenụ ntị nke ọma nʼokwu m. 
\q2 Kwerenụ ka ihe m na-ekwu baa unu ntị. 
\q1  
\v 18 Ugbu a, edoziela m ikpe m nʼusoro, 
\q2 amatala m na ikpe agaghị ama m. 
\q1  
\v 19 Ọ dị onye pụrụ ibo m ebubo\f + \fr 13:19 \ft \xt Aịz 50:8\f*? 
\q2 Ọ bụrụ na o nwere, aga m emechi ọnụ m ma nwụọ. 
\b  
\q1  
\v 20 “Meere m naanị ihe abụọ ndị a, O Chineke, 
\q2 mgbe ahụ agaghị m ezo onwe m nʼihu gị. 
\q1  
\v 21 Wepụ aka gị i ji emegide m, meekwa ka ha dị anya nʼebe m nọ. 
\q2 Kwụsị ime ka oke egwu gị mee ka m maa jijiji. 
\q1  
\v 22 Mgbe ahụ, kpọọ m oku, aga m azakwa gị. 
\q2 Maọbụ, kwerekwa ka m kwuo okwu, ka ị zaa m. 
\q1  
\v 23 Ole ka ha dị bụ mmejọ na mmehie m mere? 
\q2 Gosi m ajọ omume m na mmehie m. 
\q1  
\v 24 Gịnị mere i ji gbakụta m azụ?\f + \fr 13:24 \ft \xt Abụ 13:1\f* 
\q2 Gịnị mere i ji gụọ m dịka onye iro gị? 
\q1  
\v 25 Ị ga-enye ahịhịa ikuku na-ebugharị ntaramahụhụ? 
\q2 Ị ga-achụ ahịhịa kpọrọ nkụ ọsọ? 
\q1  
\v 26 Nʼihi na ị na-edetu ihe ndị dị ilu megide m, 
\q2 na-emekwa ka m ghọrọ mkpụrụ mmehie m mere nʼoge okorobịa m. 
\q1  
\v 27 Ị na-eji mkpọrọ igwe kegide ụkwụ m abụọ; 
\q2 na-enyochakwa nzọ ụkwụ m niile 
\q2 site nʼitinye akara nʼebe ọbụla ọbụ ụkwụ m zọrọ. 
\b  
\q1  
\v 28 “Ya mere, mmadụ nʼala nʼiyi dịka ihe rere ere, 
\q2 na dịka akwa nke nla riri. 
\b  
\c 14  
\q1  
\v 1 “Mmadụ nke nwanyị mụrụ 
\q2 nwere ụbọchị ole na ole nke jupụtara na nsogbu. 
\q1  
\v 2 Ọ na-awalite dịka okoko osisi, ma kpọnwụọkwa mgbe na-adịghị anya, 
\q2 dịka onyinyo, ọ na-agabiga agabiga. 
\q1  
\v 3 Ị na-elegide onye dị otu a anya? 
\q2 Ị ga-akpọ ya ikpe nʼihu gị? 
\q1  
\v 4 Onye pụrụ iwepụta ihe dị ọcha site nʼihe na-adịghị ọcha? 
\q2 Ọ dịghị onye ọ bụ. 
\q1  
\v 5 Ị kpebiela ụbọchị ndụ nke mmadụ; 
\q2 ị kabiela ọnụọgụgụ nke ọnwa ya niile, 
\q2 kpaakwa oke ebe ọ na-agaghị agabiga. 
\q1  
\v 6 Nʼihi nke a, wepụ anya gị nʼebe ọ nọ, hapụ ya ka ọ nọọrọ onwe ya 
\q2 ruo mgbe ụbọchị ya ga-ezu dịka onye e goro ọrụ. 
\b  
\q1  
\v 7 “Ma olileanya dịịrị osisi; 
\q2 nʼihi na ọ bụrụ na e gbutuo ya, ọ ga-epuchikwa, 
\q2 alaka ọhụrụ ya aghaghị ịwapụtakwa. 
\q1  
\v 8 A sịkwarị na mgbọrọgwụ ya emeela ochie nʼala, 
\q2 maọbụ na ogwe ya anwụọ nʼaja, 
\q1  
\v 9 mgbe ọbụla mmiri zokwasịrị ya, 
\q2 ọ na-epupụta dịka ihe a kụrụ akụ. 
\q1  
\v 10 Ma mmadụ na-anwụ, e lie ya; 
\q2 ọ na-ekubikwa ume si otu a gabiga. 
\q1  
\v 11 Dịka mmiri dị nʼoke osimiri si ata, 
\q2 maọbụ ka mmiri dị nʼiyi si ata nʼoge ọkọchị, 
\q1  
\v 12 otu a ka mmadụ si e dinaa ma ọ dịghị etetakwa ọzọ; 
\q2 tutu ruo mgbe eluigwe na-agaghị adịkwa; mmadụ ọbụla apụghị i si nʼụra kpọtee ya, 
\q2 agaghị akpọtekwa ha site nʼụra ha. 
\b  
\q1  
\v 13 “A sị na ị ga-ezo m nʼala mmụọ, 
\q2 na ị ga-ezobe m tutu ruo mgbe iwe gị gabigara. 
\q1 A sị na ị ga-akanyere m oge 
\q2 ma mesịa cheta m. 
\q1  
\v 14 Ọ bụrụ na mmadụ anwụọ, ọ ga-adị ndụ ọzọ? 
\q2 Ụbọchị niile nke ọrụ ahụhụ m, 
\q2 aga m echere mgbe nnapụta m ga-abịa. 
\q1  
\v 15 Ị ga-akpọ, aga m azakwa gị, 
\q2 agụụ ọrụ aka gị ga-agụ gị. 
\q1  
\v 16 Nʼihi mgbe ahụ ị ga-agụ nzọ ụkwụ m niile ọnụ, 
\q2 ma ị gaghị agụkọ mmehie m. 
\q1  
\v 17 A ga-ekechi njehie m nʼakpa, 
\q2 ị ga-ekpuchi mmehie m. 
\b  
\q1  
\v 18 “Ma dịka ugwu si erichasi daa, 
\q2 na dịka a na-enupu oke nkume nʼọnọdụ ya, 
\q1  
\v 19 dịka mmiri si akwọchasị nkume, 
\q2 na dịka oke mmiri ozuzo si akwazekwa aja ala, 
\q2 otu a ka i si eme ka olileanya mmadụ laa nʼiyi. 
\q1  
\v 20 Ị na-egosi ya na ị karịrị ya ike, ma ha na-agabiga; 
\q2 ị na-eme ka ihu ya gbanwee, ma zilaga ya. 
\q1  
\v 21 Ọ bụrụ na a na-asọpụrụ ụmụ ha, ha adịghị amata nke a; 
\q2 ọ bụrụkwa na a na-eweda ha nʼala, ha ọ dịghị ahụ ya. 
\q1  
\v 22 Ihe mgbu nke anụ ahụ ya ka ọ na-ama 
\q2 ma na-erukwara naanị onwe ya ụjụ.” 
\c 15  
\s1 Okwu Elifaz 
\p  
\v 1 Mgbe ahụ, Elifaz onye Teman zara sị: 
\q1  
\v 2 “Onye maara ihe ọ ga-eji okwu na-abaghị uru zaghachi? 
\q2 Ọ ga-emeju afọ ya nʼifufe na-ekpo ọkụ nke si nʼọwụwa anyanwụ? 
\q1  
\v 3 Ọ ga-eji okwu na-abaghị uru rụọ ụka, 
\q2 maọbụ kwuo okwu na-enweghị isi? 
\q1  
\v 4 Ma ị na-eleda ezi omume anya 
\q2 na-egbochikwa ịsọpụrụ Chineke. 
\q1  
\v 5 Mmehie gị na-eme ka ọnụ gị kwuo okwu ngwangwa; 
\q2 ọ bụkwa ire ndị aghụghọ ka i nwere. 
\q1  
\v 6 Ọnụ gị na-ama gị ikpe, ọ bụghị mụ onwe m, 
\q2 egbugbere ọnụ gị na-ekwu okwu megide gị. 
\b  
\q1  
\v 7 “Ị bụ mmadụ mbụ a mụrụ? 
\q2 A mụọla gị tupu e kee ugwu niile? 
\q1  
\v 8 Ọ getụla ntị nʼizu nzuzo nke Chineke? 
\q2 Amamihe niile ọ bụ nʼime gị ka ha juru? 
\q1  
\v 9 Gịnị ka ị maara nke anyị na-amaghị? 
\q2 Ụdị nghọta dị aṅaa ka i nwere nke anyị na-enweghị? 
\q1  
\v 10 Ndịisi awọ na ndị kara nka nọ nʼetiti anyị, 
\q2 ndị ikom mere agadi karịa nna mụrụ gị. 
\q1  
\v 11 Ọ ga-abụ na nkasiobi Chineke bụrụ gị ihe nta, 
\q2 ka ọ bụ okwu dị nro nke ọ gwara gị? 
\q1  
\v 12 Gịnị mere obi gị ji duhie gị, 
\q2 gịnị mekwara anya gị abụọ ji chagharịa, 
\q1  
\v 13 nke mere iwe gị jiri dị ọkụ megide Chineke, 
\q2 meekwa ka okwu ọjọọ ndị a niile si nʼọnụ gị pụta? 
\b  
\q1  
\v 14 “Gịnị ka mmadụ efu bụ, ọ ga-eji dị ọcha nʼobi, 
\q2 gịnị ka mmadụ nwanyị mụrụ bụ, na ha nwere ike ị bụ ndị ezi omume? 
\q1  
\v 15 Ọ bụrụ na Chineke atụkwasịghị ndị nsọ ya obi, 
\q2 ọ bụrụkwa na eluigwe adịghị ọcha nʼanya ya, 
\q1  
\v 16 ọ ga-esi aṅaa tụkwasị mmadụ efu onye rụrụ arụ obi, 
\q2 bụ onye na-aṅụ ajọ omume dịka mmiri. 
\b  
\q1  
\v 17 “Gee m ntị ka m kọwaara gị; 
\q2 kwerekwa ka m gwa gị ihe m hụrụ, 
\q1  
\v 18 bụ ihe ndị amamihe kwuru, 
\q2 ndị na-ezobeghị ihe ha natara nʼaka nna nna ha, 
\q1  
\v 19 bụ ndị e nyefere ala ndị a nʼaka ha 
\q2 mgbe ọ dịghị onye ọbịa gabigara nʼetiti ha. 
\q1  
\v 20 Ụbọchị ndụ ya niile, onye ajọ omume na-ata ahụhụ mmekpa ahụ, 
\q2 bụ nke e debere ogologo afọ nye nwoke ahụ na-eme ihe ike. 
\q1  
\v 21 Ụzụ na-eweta oke egwu na-eju ya ntị, 
\q2 mgbe ọ dị ka ihe niile na-aga nke ọma, ndị na-apụnara mmadụ ihe na-abịakwasị ya. 
\q1  
\v 22 O nweghị olileanya ịgbanarị ọchịchịrị; 
\q2 mma agha nọ na-echere ya. 
\q1  
\v 23 Ọ na-akpagharị na-achọ ebe nri dịka udele; 
\q2 ọ makwara na ụbọchị ọchịchịrị nọ nso. 
\q1  
\v 24 Ahụhụ na mkpagbu na-eme ka ọ tụọ oke egwu, 
\q2 nsogbu na-abịakwasị ya dịka eze nke nọ na njikere ibuso ndị iro ya agha. 
\q1  
\v 25 Nʼihi na ọ na-atụ Chineke aka nʼihu, 
\q2 dokwaa onwe ya imegide Onye pụrụ ime ihe niile. 
\q1  
\v 26 O ji ikwesi olu ike, 
\q2 dịka ọta siri ike, na-emegide Chineke. 
\b  
\q1  
\v 27 “Ọ bụ ezie na abụba kpuchiri ihu ya, 
\q2 abụba nke dị nʼukwu ya na-eme ka anụ ahụ nupụtakwa, 
\q1  
\v 28 ọ ga-ebi nʼobodo e bibiri ebibi, 
\q2 nʼụlọ nke mmadụ na-ekwesighị ibi nʼime ha, 
\q2 ụlọ nke na-adakasị adakasị. 
\q1  
\v 29 Ma ọ gaghị aga nʼihu ị bụ ọgaranya, akụ ya agaghị adịgidekwa. 
\q2 Ihe o nwere agakwaghị agbasapụ nʼala niile ahụ. 
\q1  
\v 30 Ọ gaghị agbanarị ọchịchịrị, 
\q2 ire ọkụ ga-eme ka ome ya kpọnwụọ, 
\q2 iku ume nke ọnụ Chineke ga-ebufu ya. 
\q1  
\v 31 Ka onye dị otu a hapụ ịghọgbu onwe ya site nʼịtụkwasị uche nʼihe efu, 
\q2 nʼihi na ọ dịghị ụgwọ ọrụ ọbụla ọ ga-enweta. 
\q1  
\v 32 Tụpụ oge ya eruo, ọ ga-anata ụgwọ ọrụ ya nʼuju, 
\q2 ọzọ, alaka ya ga-akpọnwụ 
\q1  
\v 33 Ọ ga-adị ka osisi vaịnị nke mkpụrụ ya dapụsịrị na-achaghị acha, 
\q2 dịka osisi oliv nke akwụkwọ ya kpọnwụrụ akpọnwụ. 
\q1  
\v 34 Nʼihi na ndị na-amaghị Chineke ga-adị ka nwanyị aga, 
\q2 ọkụ ga-erepịa ụlọ ikwu niile nke ndị hụrụ iri ngarị nʼanya. 
\q1  
\v 35 Ha na-atụrụ ihe ọjọọ dịka ime, ma mụọkwa ajọọ omume; 
\q2 naanị aghụghọ ka akpanwa ha na-arụpụta.” 
\c 16  
\s1 Okwu Job 
\p  
\v 1 Mgbe ahụ, Job zara sị: 
\q1  
\v 2 “Anụla m ọtụtụ ihe dịka ndị a; 
\q2 ndị nkasiobi na-eweta ọnọdụ ọjọọ ka unu niile bụ. 
\q1  
\v 3 Ogologo okwu efu ndị a niile unu na-ekwu, ọ naghị akwụsị? 
\q2 Gịnị bụ nsogbu unu nke mere unu ji aga nʼihu na-arụ ụka niile ndị a? 
\q1  
\v 4 Mụ onwe m nwekwara ike ikwu okwu dịka unu, 
\q2 ma ọ bụrụ na unu nọ nʼọnọdụ m; 
\q1 enwere m ike kwuo okwu dị ụtọ na ntị megide unu, 
\q2 ma fufekwaa isi\f + \fr 16:4 \ft Ifufe isi nʼihu mmadụ, bụ omume nlelị anya. Ọ pụtara na e nweghị nsọpụrụ nʼebe onye dị otu a nọ. \xt Abụ 22:7; Akw 2:15; Mat 27:39\f* m megide unu. 
\q1  
\v 5 Ma ọnụ m ga-agba unu ume; 
\q2 nkasiobi si nʼegbugbere ọnụ m ga-emekwa ka ihe mgbu unu dajụọ. 
\b  
\q1  
\v 6 “Ma ọ bụrụ na m ekwuo, adịghị egbochi ihe mgbu m, 
\q2 ọ bụrụ na m ahapụ ikwu okwu, ọdịghị esi nʼahụ m pụọ? 
\q1  
\v 7 Nʼezie o Chineke, i meela ka ike gwụ m, 
\q2 i tidakwala ezinaụlọ m. 
\q1  
\v 8 I keela m agbụ; agbụ m abụrụla ihe akaebe megide m; 
\q2 ịta ahụ m ebiliela ịgba akaebe megide m. 
\q1  
\v 9 Chineke na-eweso m iwe, jiri iwe ya na-adọwasị m, 
\q2 ọ na-atakwa ikikere eze ya megide m; 
\q2 onye iro m na-achịchapụrụ m anya ya. 
\q1  
\v 10 Ụmụ mmadụ na-asaghe ọnụ ka ha chịa m ọchị, 
\q2 ha ji iti m aka nʼọnụ na-akwa m emo, 
\q2 jikọtakwa onwe ha megide m. 
\q1  
\v 11 Chineke ewerela m nyefee nʼaka ndị ajọ omume, 
\q2 tụbakwa m nʼaka ndị na-emebi iwu. 
\q1  
\v 12 Ihe na-agara m nke ọma, ma Chineke tipịara m. 
\q2 O jidere m nʼolu ma tiwasịa m. 
\q1 O meela m ihe ịgba ụta ya; 
\q2  
\v 13 ndị ọgba ụta ya agbaala m gburugburu. 
\q1 Ọ na-agbawa akụrụ m na-enweghị ọmịiko 
\q2 mee ka oluilu m wụsịa nʼala. 
\q1  
\v 14 Mgbe niile, ọ na-emegide m; 
\q2 ọ na-achụso m dịka dike nʼagha. 
\b  
\q1  
\v 15 “Adụkọtala m akwa mkpe were ya kpuchie anụ ahụ m, 
\q2 liekwa ikuanya\f + \fr 16:15 \ft Maọbụ, \fqa mpi\f* m nʼime ntụ. 
\q1  
\v 16 Ihu m na-acha ọbara ọbara site nʼakwa nke m na-akwa, 
\q2 onyinyo nke ọnwụ dịkwa gburugburu egbugbere anya m abụọ; 
\q1  
\v 17 ma aka m emeghị ihe ike ọbụla, 
\q2 ọzọ ekpere m dịkwa ọcha. 
\b  
\q1  
\v 18 “Ala, biko, ezokwala ọbara m; 
\q2 mee ka akwa m ghara ịbụ ihe lara nʼiyi! 
\q1  
\v 19 Ọ bụladị ugbu a, onye akaebe m nọ nʼeluigwe, 
\q2 onye nkwuchite ọnụ m nọ nʼebe dị elu. 
\q1  
\v 20 Onye na-arịọrọ m arịrịọ bụ enyi m, 
\q2 dịka m na-awụsara Chineke anya mmiri m. 
\q1  
\v 21 Nʼọnọdụ mmadụ ka ọ na-arịọ Chineke 
\q2 dịka mmadụ na-arịọ nʼihi enyi ya. 
\b  
\q1  
\v 22 “Naanị afọ ole na ole ga-agabiga 
\q2 tupu m ga nʼụzọ nke nlọghachi m na-adịghị. 
\c 17  
\q1  
\v 1 Mmụọ m tiwara etiwa, 
\q2 ụbọchị m niile dị mkpụmkpụ, 
\q2 ili na-echere ịnabata m. 
\q1  
\v 2 Nʼezie ndị na-akwa emo gbara m gburugburu; 
\q2 anya m na-elekwasịkwa mkpasu iwe ha. 
\b  
\q1  
\v 3 “Debere m ihe ebe nʼebe gị Chineke nọ. 
\q2 Olee onye ọzọ pụrụ ịnara m nʼakaebe? 
\q1  
\v 4 I mechiela uche ha ka ha ghara inwe nghọta; 
\q2 ya mere, i gaghị ekwe ka ha nwee mmeri. 
\q1  
\v 5 Ọ bụrụ na mmadụ ekwujọọ enyi ya ka o were nweta uru dị nʼime ya, 
\q2 anya ụmụ ya ga-ada mba. 
\b  
\q1  
\v 6 “Chineke emeela ka m bụrụ okwu ilu nye onye ọbụla, 
\q2 meekwa ka m bụrụ onye ha na-agbụsa asọ mmiri nʼihu. 
\q1  
\v 7 Anya m na-ahụ inyogho inyogho nʼihi iru ụjụ; 
\q2 ahụ m aghọọla onyinyo nke ihe m bụ na mbụ. 
\q1  
\v 8 Ndị na-eme ihe ziri ezi na-akụja mgbe ha hụrụ nke a; 
\q2 ndị aka ha dị ọcha na-enwe mkpali megide ndị ajọ omume. 
\q1  
\v 9 Ma otu ọbụla ọ dị, ndị ezi omume ga-aga nʼihu nʼiso ụzọ ha, 
\q2 ndị aka ha dị ọcha ga-aga nʼihu nʼịdị ike. 
\b  
\q1  
\v 10 “Ma bịanụ, unu niile, bidonụ okwu unu ọzọ! 
\q2 Agaghị m achọta onye maara ihe nʼetiti unu. 
\q1  
\v 11 Ụbọchị m niile agafeela, atụmatụ m abụrụla ihe lara nʼiyi. 
\q2 Ma ọchịchọ nke obi m 
\q1  
\v 12 na-edo abalị nʼọnọdụ ehihie; 
\q2 nʼihu ọchịchịrị ka ìhè dị nso. 
\q1  
\v 13 Ọ bụrụ na ebe obibi m na-ele anya ya bụ ili, 
\q2 ọ bụrụ na m agbasaa\f + \fr 17:13 \ft Maọbụ, \fqa atụsaa\f* ihe ndina m nʼelu ọchịchịrị, 
\q1  
\v 14 a sikwa na m asị ire ure, ‘Nna m ka ị bụ,’ 
\q2 maọbụ sị ikpuru ‘Nne m’ maọbụ ‘Nwanne m nwanyị,’ 
\q1  
\v 15 ebeekwa ka olileanya m dị? 
\q2 Onye pụrụ ịhụ ma m nwere olileanya? 
\q1  
\v 16 Olileanya m ọ ga-arịda ruo nʼọnụ ụzọ ama nke ọnwụ? 
\q2 Anyị ga-esokọta rịdaruo nʼuzuzu?” 
\c 18  
\s1 Okwu Bildad 
\p  
\v 1 Mgbe ahụ Bildad onye Shua zara sị: 
\q1  
\v 2 “Ruo ole mgbe ka ị ga-ekwubi okwu ndị a ị na-ekwu? 
\q2 Nwee ezi uche ka anyị kparịtaa ụka. 
\q1  
\v 3 Gịnị mere i ji were anyị dịka anụ ọhịa, 
\q2 gụọ anyị dịka ndị na-enweghị uche nʼanya gị? 
\q1  
\v 4 Gị onye na-eji iwe adọkasị onwe gị, 
\q2 a ga-ahapụ ụwa nʼihi gị? 
\q2 Ka a ga-enupu oke nkume nʼọnọdụ ha? 
\b  
\q1  
\v 5 “A na-afụnyụ oriọna nke onye na-emebi iwu; 
\q2 ire ọkụ ya ga-akwụsịkwa inwu enwu, 
\q1  
\v 6 ìhè nke dị nʼime ụlọ ikwu ya na-abụ ọchịchịrị, 
\q2 oriọna nke dị nʼakụkụ ya na-anyụkwa. 
\q1  
\v 7 Ike agakwaghị adị na nzọ ukwu ya; 
\q2 atụmatụ ya onwe ya ga-atụda ya nʼala. 
\q1  
\v 8 Ụkwụ ya na-eduba ya nʼọnya; 
\q2 ọ na-akpagharị na-adaba nʼime oghere. 
\q1  
\v 9 Ọnya na-ejide ikiri ụkwụ ya, 
\q2 ọnya ahụ na-ejidesi ya ike. 
\q1  
\v 10 E zobere ya ụdọ ọnya igbudu nʼala, 
\q2 ihe e ji ejide ya na-echere ya nʼụzọ ya. 
\q1  
\v 11 Ihe egwu na-emenye ya ụjọ nʼakụkụ niile, 
\q2 na-agbasokwa nzọ ụkwụ ya niile. 
\q1  
\v 12 Ịla nʼiyi na-achọsi ya ike; 
\q2 mbibi nọkwa na njikere na-eche mgbe ọ ga-ada. 
\q1  
\v 13 Mbibi na-eripịa akụkụ anụ ahụ ya; 
\q2 ọkpara ọnwụ na-eripịa ahụ ya niile. 
\q1  
\v 14 Esi na nchekwa nke ụlọ ikwu ya dọpụta ya 
\q2 duru ya jekwuru eze nke ihe egwu niile. 
\q1  
\v 15 Ọkụ na-ebi nʼime ụlọ ikwu ya; 
\q2 a ga-efesasị nkume na-enwu ọkụ nʼebe obibi ya. 
\q1  
\v 16 Mgbọrọgwụ ya na-akpọ nkụ nʼime ala, 
\q2 alaka ya ga-akpọnwụ nʼelu. 
\q1  
\v 17 A gaghị echeta echiche ya nʼụwa ọzọ, 
\q2 o nweghị onye ọbụla na-echetakwa aha ya. 
\q1  
\v 18 A na-esite nʼìhè chụba ya nʼọchịchịrị, 
\q2 otu a kwa, a na-achụpụkwa ya site nʼụwa. 
\q1  
\v 19 O nweghị ụmụ, o nwekwaghị ụmụ ụmụ nʼetiti ndị ya, 
\q2 ọ dịghị onye fọdụrụ nʼebe o bi na mbụ. 
\q1  
\v 20 Ọnọdụ ya na-eju ndị si nʼọdịda anyanwụ anya; 
\q2 oke egwu na-ejidekwa ndị si nʼọwụwa anyanwụ nʼihi ya. 
\q1  
\v 21 Nʼezie, otu a ka ebe obibi nke onye ajọ omume dị, 
\q2 ee, bụ onye ahụ nke na-amaghị Chineke.” 
\c 19  
\s1 Okwu Job 
\p  
\v 1 Job zara sị: 
\q1  
\v 2 “Ruo ole mgbe ka unu ga-anọgide na-ata m ahụhụ? 
\q2 Ruo ole mgbe ka unu ga-ewere okwu ọnụ unu zọpịa m? 
\q1  
\v 3 Ugboro iri ndị a ka unu kọcharala m, 
\q2 ihere adịghị eme unu na unu na-ebuso m agha? 
\q1  
\v 4 A sịkwarị na m bụ onye mmehie, 
\q2 ọ bụ naanị mụ onwe m ka ọ gbasara. 
\q1  
\v 5 Ọ bụrụ na unu na-ebuli onwe unu elu karịa m, 
\q2 ma were ọnọdụ ịdị ala m megide m, 
\q1  
\v 6 mgbe ahụ, maranụ na Chineke emejọọla m, 
\q2 were ụgbụ ya tụọ m gburugburu. 
\b  
\q1  
\v 7 “Ọ bụ ezie na m na-eti mkpu akwa sị: ‘A na-emejọ m.’ Ma ọ dịghị ọsịsa m na-anata; 
\q2 ọ bụ ezie na m na-eti mkpu ka e nyere m aka ma ikpe ziri ezi adịghị. 
\q1  
\v 8 Ọ nọchiela ụzọ m ka m ghara ịgafe; 
\q2 o jirila ọchịchịrị kpuchie ụzọ m. 
\q1  
\v 9 O yipụla m ugwu m, 
\q2 wepụkwa okpueze m kpu nʼisi. 
\q1  
\v 10 Ọ na-eti m ihe otiti nʼakụkụ niile, ruo mgbe m gabigara; 
\q2 ọ na-ehopu olileanya m dịka osisi. 
\q1  
\v 11 Iwe ya dị ọkụ megide m; 
\q2 ọ na-agụnyekwa m dịka onye iro ya. 
\q1  
\v 12 Ndị agha ya ji ike na-abịa; 
\q2 ha ewuola mgbidi were nnọchibido m 
\q2 ha agbaala ụlọ ikwu m gburugburu imegide m. 
\b  
\q1  
\v 13 “O meela ka ụmụnne m 
\q2 na ndị enyi m si nʼebe m nọ pụọ. 
\q1  
\v 14 Ndị ikwu m anaghị etinyekwa uche nʼihe banyere m; 
\q2 ndị ezi enyi m niile echefuola m. 
\q1  
\v 15 Ndị ọbịa nọ nʼụlọ m na ndị odibo m nwanyị na-agụ m dịka onye ala ọzọ; 
\q2 adị m ka onye mba ọzọ nʼebe ha nọ. 
\q1  
\v 16 Ana m akpọ odibo m oku ma ọ dịghị aza m, 
\q2 ọ bụladị mgbe m jiri ọnụ m rịọ ya. 
\q1  
\v 17 Iku ume m abụrụla ihe nwunye m apụghị ịnagide; 
\q2 abụrụla m ihe arụ nye ụmụnne m. 
\q1  
\v 18 Ọ bụladị ụmụntakịrị nwoke na-akwa m emo; 
\q2 ha na-ejikwa m eme ihe ọchị mgbe ọbụla m pụtara. 
\q1  
\v 19 Ndị ahụ m kpọrọ ndị enyi ọma m na-ele m anya dịka m bụ ihe arụ; 
\q2 ndị ahụ niile m hụrụ nʼanya echigharịakwala megide m 
\q1  
\v 20 Abụ m naanị ọkpụkpụ ọkpụkpụ; 
\q2 ihe m ji gbanarị ọnwụ adịghị ukwuu. 
\b  
\q1  
\v 21 “Meerenụ m ebere, ndị enyi m, meerenụ m ebere, 
\q2 nʼihi na aka Chineke na-emegide m. 
\q1  
\v 22 Gịnị mere unu ji achụ m dịka Chineke si achụ m? 
\q2 Ọ ga-abụ na ahụhụ m ejubeghị unu afọ? 
\b  
\q1  
\v 23 “Ọ gaara atọ m ụtọ 
\q2 ma a sị na e dekọrọ okwu m nʼakwụkwọ, 
\q1  
\v 24 na e ji mkpisi igwe dee ha, 
\q2 maọbụ kakwasị ha nʼelu mbadamba nkume ruo mgbe ebighị ebi. 
\q1  
\v 25 Amara m na onye mgbapụta m na-adị ndụ, 
\q2 amakwaara m na ọ ga-eguzo nʼelu ụwa nʼoge ikpeazụ. 
\q1  
\v 26 Mgbe e mebisikwara akpụkpọ ahụ m, 
\q2 ma nʼanụ ahụ m aga m ahụ Chineke. 
\q1  
\v 27 Mụ onwe m ga-eji anya m abụọ hụ ya, 
\q2 mụ onwe m, ọ bụghị onye ọzọ. 
\q2 Lee ka obi m si anụ ọkụ nʼime m maka nke a! 
\b  
\q1  
\v 28 “Ọ bụrụ na unu asị, ‘Anyị ga-emegide ya 
\q2 nʼihi na nsogbu a si nʼaka ya,’ 
\q1  
\v 29 unu onwe unu kwesiri ịtụ egwu mma agha; 
\q2 nʼihi na iwe ga-ebute ịta ahụhụ nke mma agha, 
\q2 mgbe ahụ, unu ga-ama na ikpe dị.” 
\c 20  
\s1 Okwu Zofa 
\p  
\v 1 Mgbe ahụ, Zofa onye Neama zara sị: 
\q1  
\v 2 “Enweghị udo nke echiche m na-akpali m izaghachi 
\q2 nʼihi na anọ m na mwute dị ukwuu. 
\q1  
\v 3 Anụla m okwu mkparị nke ileda anya nye m, 
\q2 ma nghọta m na-akpalịte m ịzaghachi gị. 
\b  
\q1  
\v 4 “Nʼezie, ị maara otu ọ dị site na mgbe ochie, 
\q2 ya bụ kemgbe e debere mmadụ nʼụwa. 
\q1  
\v 5 Obi ụtọ nke onye na-emebi iwu na-adị nwa mgbe nta, 
\q2 ọṅụ nke ndị na-amaghị Chineke na-anọ naanị nwa oge. 
\q1  
\v 6 Nʼagbanyeghị na ịnya isi ya ga-eru eluigwe, 
\q2 na isi ya ga-emetụkwa igwe ojii; 
\q1  
\v 7 ọ ga-ala nʼiyi ebighị ebi, dịka nsị ya onwe ya nyụrụ; 
\q2 ndị maara ya ga-ajụ, ‘Olee ebe ọ nọ?’ 
\q1  
\v 8 Ọ ga-efelaga dịka nrọ, agaghị achọtakwa ya mgbe ọbụla, 
\q2 dịka ọhụ abalị nke e chefuru echefu. 
\q1  
\v 9 Anya hụrụ ya na mbụ agaghị ahụkwa ya ọzọ, 
\q2 ebe obibi ya agaghị elegidekwa ya anya ọzọ. 
\q1  
\v 10 Ụmụ ya ga-achọ ihuọma site nʼaka ndị ogbenye; 
\q2 aka ya abụọ kwa ga-enyeghachi akụ ya. 
\q1  
\v 11 Ọkpụkpụ ya nke jupụtara nʼike okorobịa 
\q2 ga-eso ya bụrụ ihe a ghanyere na ntụ. 
\b  
\q1  
\v 12 “Ọ bụ ezie na ihe ọjọọ na-atọ ya ụtọ nʼọnụ, 
\q2 na ọ na-ezokwa ya nʼokpuru ire ya; 
\q1  
\v 13 ọ bụ ezie na ọ pụghị nʼịhapụ ya, 
\q2 ọ na-edebe ya nʼọnụ ya, 
\q1  
\v 14 ma nri ọ na-eri ga-aghọ ihe gbara ụka nʼafọ ya, 
\q2 ọ ga-aghọkwa elo agwọ nʼime afọ ya. 
\q1  
\v 15 Ọ ga-agbọpụta akụnụba niile o lodara; 
\q2 Chineke ga-eme ka o si nʼafọ ya gbọpụtachaa ha. 
\q1  
\v 16 Ọ ga-amịcha elo agwọ, 
\q2 eze agwọ ajụala ga-egbu ya. 
\q1  
\v 17 Ọ gaghị anụ ụtọ mmiri si nʼiyi, 
\q2 bụ iyi nke na-asọ asọ nke jupụtara na mmanụ aṅụ na mmiri ara ehi rahụrụ arahụ. 
\q1  
\v 18 Ihe ọ rụpụtara ka ọ ga-eji kwụghachi ụgwọ o ji na-erighị ma otu. 
\q2 Uru ọ zụtara nʼahịa agaghị abụrụ ya ihe ọṅụ. 
\q1  
\v 19 Nʼihi na ọ kpagburu ndị ogbenye, hapụ ha na-enweghị olileanya ọbụla, 
\q2 ọ nakọtakwara ụlọ nke ọ na-ewughị. 
\b  
\q1  
\v 20 “Nʼezie, ọ gaghị enwe izuike site nʼoke ọchịchọ ya; 
\q2 ọ gaghị azọpụtakwa onwe ya site nʼụlọakụ ya. 
\q1  
\v 21 Ọ dịghị ihe fọdụụrụ ya iripịa, 
\q2 ọganihu ya agaghị adịgide. 
\q1  
\v 22 Nʼetiti ihe niile o nwere ka mkpagbu ga-abịakwasị ya, 
\q2 oke ịta ahụhụ ga-adakwasị ya. 
\q1  
\v 23 Mgbe o rijuru afọ 
\q2 ka Chineke ga-eme ka iwe ya dị ọkụ megide ya, 
\q2 iti aka Chineke ga-adakwasị ya dịka mmiri ozuzo. 
\q1  
\v 24 Ọ bụrụ na o si na ngwa agha e ji igwe kpụọ gbalaga, 
\q2 àkụ nke e ji ọla bronz kpụọ ọnụ ya ga-amapu ya ahụ. 
\q1  
\v 25 Nʼazụ ya ka ọ na-esi mịpụta ya, 
\q2 site nʼumeju ya ka a ga-esi mịpụta ọnụ ya na-egbu amụma. 
\q1 Oke egwu dị iche iche ga-abịakwasị ya. 
\q2  
\v 26 Oke ọchịchịrị nọ na-echere akụnụba ya, 
\q1 ọkụ nke a na-afụnwughị afụnwu ga-erepịa ya 
\q2 ọ ga-erechapụkwa ihe niile fọdụrụ nʼụlọ ikwu ya. 
\q1  
\v 27 Eluigwe ga-ekpughe ikpe ọmụma ya 
\q2 ụwa niile ga-ebili megide ya. 
\q1  
\v 28 Idee mmiri ga-ebupu ụlọ ya; 
\q2 oke mmiri okwukwo nʼụbọchị iwe Chineke. 
\q1  
\v 29 Nke a bụ oke nke Chineke debeere ndị na-emebi iwu, 
\q2 ya bụkwa ihe nketa nke Chineke kwadooro ha.” 
\c 21  
\s1 Okwu Job 
\p  
\v 1 Mgbe ahụ, Job zara sị: 
\q1  
\v 2 “Gee ntị nke ọma nʼokwu m; 
\q2 ka nke a bụrụ nkasiobi ị ga-enye m. 
\q1  
\v 3 Nwee ndidi ka m kwuchaa okwu m, 
\q2 mgbe m kwuchara, gaa nʼihu ịkwa m emo. 
\b  
\q1  
\v 4 “Ọ bụ mmadụ ka m na-ekpesara? 
\q2 Gịnị ka m ga-eji ghara ịbụ onye na-enweghị ndidi? 
\q1  
\v 5 Lee m anya ka ahụ maa gị jijiji; 
\q2 were aka gị kpuchie ọnụ gị. 
\q1  
\v 6 Mgbe m chere echiche maka nke a, egwu tụrụ m 
\q2 meekwa ka ahụ m maa jijiji. 
\q1  
\v 7 Gịnị mere ndị ajọ omume ji enwe ndụ ogologo, 
\q2 ghọọ okenye, baakwa ụba nʼịdị ike? 
\q1  
\v 8 Ha na-ahụ ụmụ ka ha na-akwụsike ike gburugburu ha, 
\q2 ụmụ ha ka ha ji anya ha ahụ. 
\q1  
\v 9 Ha na-ebi ndụ udo nʼezinaụlọ ha na-atụghị egwu na ihe ọjọọ ọbụla ga-adakwasị ha; 
\q2 mkpara Chineke adịghịkwa adakwasị ha. 
\q1  
\v 10 Oke ehi ha na-agba nne ehi ha na-esepụghị aka; 
\q2 nne ehi ha na-amụ ụmụ, ha adịghị ekwo ime. 
\q1  
\v 11 Ha na-ezipụ ụmụ ha dịka igwe atụrụ; 
\q2 ụmụntakịrị ha na-etegharị egwu. 
\q1  
\v 12 Ha na-abụ abụ nʼụda egwu otiti na ụbọ akwara; 
\q2 ha na-aṅụrịkwa ọṅụ nʼụda nke ọja. 
\q1  
\v 13 Ha na-anọ ụbọchị ndụ ha niile nʼọganihu, 
\q2 ha na-arịdakwa nʼili ha nʼudo. 
\q1  
\v 14 Ma ndị a na-asị Chineke, ‘Hapụ anyị aka, 
\q2 ọ dịghị anyị mkpa ịmata ụzọ gị. 
\q1  
\v 15 Onye ka Onye pụrụ ime ihe niile bụ, anyị ga-eji jeere ya ozi? 
\q2 Uru gịnị ka ịrịọ ya arịrịọ ga-abara anyị?’ 
\q1  
\v 16 Ma ọganihu ha adịghị nʼaka ha 
\q2 ya mere ana m ewezuga onwe m site na ndụmọdụ ndị na-emebi iwu. 
\b  
\q1  
\v 17 “Ma ugboro ole ka a na-emenyụ ọkụ oriọna nke ndị na-emebi iwu? 
\q2 Ugboro ole ka nhụju anya na-adakwasị ha, 
\q2 bụ nke Chineke kenyere ha nʼiwe ya? 
\q1  
\v 18 Ugboro ole ka ha dịka ahịhịa kpọrọ nkụ nʼihu ikuku, 
\q2 maọbụ dịka igbugbo ọka nke ikuku siri ike na-efesasị? 
\q1  
\v 19 A na-asị, ‘Chineke na-akpakọtara ụmụ ha ntaramahụhụ nke njehie ha.’ 
\q2 Ka a kwụghachi ha ya, ka ha nwee ike mata ya. 
\q1  
\v 20 Ka anya ha hụ mbibi nke onwe ya, 
\q2 ka ha ṅụọ ọnụma nke Onye pụrụ ime ihe niile dịka mmiri. 
\q1  
\v 21 Gịnị gbasara ha banyere ezinaụlọ ha hapụrụ 
\q2 mgbe ọnwa ndị e kenyere ya bịara na ngwụcha? 
\b  
\q1  
\v 22 “Ọ dị onye pụrụ izi Chineke ihe ọmụma, 
\q2 ebe ọ bụ ya na-ekpe ndị kachasị elu ikpe? 
\q1  
\v 23 Otu onye na-anwụ mgbe o jupụtara nʼike na ume, 
\q2 mgbe ọ nọ na nchekwa na udo, 
\q1  
\v 24 mgbe ahụ ya bụ nke eji ezi nri zụọ nke ọma, 
\q2 ọkpụkpụ ya jupụtakwara nʼụmị. 
\q1  
\v 25 Onye ọzọ na-anwụ nʼihe ilu nke mkpụrụobi, 
\q2 nʼihi na o nweghị mgbe o riri ezi ihe ọbụla. 
\q1  
\v 26 Nke ọbụla nʼime ha dina nʼakụkụ ibe ya nʼime aja, 
\q2 ikpuru kpuchikwara ha abụọ. 
\b  
\q1  
\v 27 “Amaara m nke ọma ihe bụ echiche unu 
\q2 na nzube unu ji emegide m. 
\q1  
\v 28 Unu ga-ajụ m ajụjụ sị, ‘Ugbu a, ole ụlọ oke mmadụ ahụ. 
\q2 Ụlọ ikwu ndị ahụ ebe ndị na-emebi iwu biiri?’ 
\q1  
\v 29 Ọ bụ na unu ajụbeghị ndị njem ajụjụ? 
\q2 Ọ bụ na unu ejighị ihe ha kọrọ mere ihe, 
\q1  
\v 30 na a na-echebe ndị ọjọọ pụọ nʼụbọchị nhụju anya, 
\q2 na a na-anapụta ha site nʼụbọchị oke iwe? 
\q1  
\v 31 Onye na-atụ ha mmehie ha nʼihu? 
\q2 Onye kwa na-akwụghachi ha ụgwọ ihe ha mere? 
\q1  
\v 32 A na-eburu ha gaa nʼili, 
\q2 a na-echekwa ili ha nche. 
\q1  
\v 33 Aja dị na ndagwurugwu na-atọ ha ụtọ; 
\q2 Mmadụ niile na-eso ha nʼazụ, 
\q2 na ọtụtụ a na-apụghị ịgụta ọnụ na-ebu ha ụzọ nʼaga. 
\b  
\q1  
\v 34 “Ya mere, olee otu unu ga-esi were okwu na-enweghị isi kasịe m obi? 
\q2 Ọ dịghị ihe fọdụrụ nʼọsịịsa unu ma ọ bụghị naanị okwu ụgha.” 
\c 22  
\s1 Okwu Elifaz 
\p  
\v 1 Mgbe ahụ, Elifaz onye Teman zara sị: 
\q1  
\v 2 “Mmadụ ọ pụrụ ịbara Chineke uru? 
\q2 Ọ bụladị onye nwere uche ọ pụrụ ịbara Chineke uru? 
\q1  
\v 3 O nwere ọṅụ ọ ga-enye Onye pụrụ ime ihe niile ma a sị na ị bụ onye ezi omume? 
\q2 Uru gịnị ka ọ ga-enweta ma ọ bụrụ na ụzọ gị niile enweghị ịta ụta? 
\b  
\q1  
\v 4 “Chineke ọ na-abara gị mba na-ebo gị ebubo 
\q2 nʼihi na ị na-atụ egwu ya? 
\q1  
\v 5 Ọ bụ na mmebi iwu gị adịghị ukwuu? 
\q2 Mmehie gị o nwere ọgwụgwụ? 
\q1  
\v 6 Ị naara ụmụnne gị ihe ebe nʼefu; 
\q2 ị yipụrụ ndị mmadụ uwe ha gbawa ha ọtọ. 
\q1  
\v 7 I nyeghị ndị ike gwuru mmiri, 
\q2 i nyeghịkwa ndị agụụ na-agụ ihe oriri. 
\q1  
\v 8 Ọ bụ eziokwu na ị bụ nwoke dị ike na onye nwere ala, 
\q2 bụrụkwa onye a na-asọpụrụ bi nʼala ya, 
\q1  
\v 9 Ị na-agbaba ụmụ nwanyị di ha nwụrụ aka, zipụ ha, 
\q2 Ị na-anyaji ogwe aka nke ụmụ na-enweghị nna. 
\q1  
\v 10 Ọ bụ ya mere ọnya jiri gbaa gị gburugburu, 
\q2 bụrụkwa ihe mbibi ji eyi gị egwu. 
\q1  
\v 11 Ọ bụkwa ya mere ọchịchịrị ji gbaa gị gburugburu ka ị ghara ịhụ ụzọ, 
\q2 meekwa ka idee mmiri kpuchie gị. 
\b  
\q1  
\v 12 “Ọ bụ na Chineke anọghị nʼebe dị elu nke eluigwe? 
\q2 Lee ka ịdị elu nke kpakpando dị elu si dị. 
\q1  
\v 13 Kama ị na-asị, ‘Gịnị ka Chineke maara? 
\q2 Ọ na-esite nʼoke ọchịchịrị dị otu a ekpe ikpe? 
\q1  
\v 14 Oke ọchịchịrị kpuchiri ya, nke mere na ọ naghị ahụ anyị 
\q2 mgbe ọ na-agagharị nʼebe dị elu nke eluigwe.’ 
\q1  
\v 15 Ị ga-agbaso ụzọ ochie 
\q2 nke ndị na-eme ihe ọjọọ zoro ije na ya? 
\q1  
\v 16 E bupụrụ ha tupu oge ha eruo. 
\q2 Ntọala ndụ ha ka idee mmiri sachapụrụ 
\q1  
\v 17 Ha sịrị Chineke, ‘Hapụ anyị aka! 
\q2 Gịnị ka Onye pụrụ ime ihe niile ga-eme anyị?’ 
\q1  
\v 18 Ma ọ bụ ya ji ihe dị mma dị iche iche mejupụta ụlọ ha, 
\q2 ya mere ana m ewezuga onwe m site na ndụmọdụ ndị na-emebi iwu. 
\q1  
\v 19 Ndị ezi omume na-ahụ mbibi ndị dị otu a ma ṅụrịa; 
\q2 ndị aka ha dị ọcha na-akwa ha emo sị: 
\q1  
\v 20 ‘Nʼezie, e bibiela ndị iro anyị, 
\q2 ọkụ erepịala akụnụba ha.’ 
\b  
\q1  
\v 21 “Doo onwe gị nʼokpuru Chineke ka gị na ya nọọ nʼudo, 
\q2 nʼụzọ dị otu a, ọganihu ga-abịara gị. 
\q1  
\v 22 Gee ntị, nabata ndụmọdụ si ya nʼọnụ, 
\q2 doo okwu ya niile nʼobi gị. 
\q1  
\v 23 Ọ bụrụ na ịlaghachikwute Onye pụrụ ime ihe niile, ọ ga-eweghachi gị nʼọnọdụ gị; 
\q2 ọ bụrụ na iwezuga ihe mmebi iwu mee ka ọ dị anya site nʼebe ụlọ ikwu gị dị, 
\q1  
\v 24 tọgbọ ọkpụrụkpụ ọlaedo gị nʼaja, 
\q2 tụpụkwa ọlaedo nke Ọfịa gị nʼelu nkume dị nʼime ọdọ mmiri nta. 
\q1  
\v 25 Mgbe ahụ, Onye pụrụ ime ihe niile ga-abụrụ gị ọlaedo, 
\q2 bụkwara gị ọlaọcha kachasị mma. 
\q1  
\v 26 Nʼezie, mgbe ahụ kwa, ihe nke Onye pụrụ ime ihe niile ga-atọ mkpụrụobi gị ụtọ, 
\q2 ị ga-ewelikwa ihu gị nye Chineke. 
\q1  
\v 27 Ị ga-ekpe ekpere, ọ ga-azakwa gị ekpere gị, 
\q2 ị ga-emezukwa nkwa i kwere. 
\q1  
\v 28 Ihe i kpebiri ga-emezukwa, 
\q2 ìhè ga-amụkwasị nʼụzọ gị niile. 
\q1  
\v 29 Mgbe a na-eweda ndị mmadụ ala, ọ bụrụkwa na ị sị, ‘Bulienụ ha elu,’ 
\q2 mgbe ahụ ọ ga-azọpụta ndị e wedara nʼala. 
\q1  
\v 30 Ọ ga-azọpụta ọ bụladị onye ahụ nke aka ya na-adịghị ọcha, 
\q2 bụ onye nke a ga-azọpụta site nʼịdị ọcha nke aka gị.” 
\c 23  
\s1 Okwu Job 
\p  
\v 1 Mgbe ahụ, Job zara sị: 
\q1  
\v 2 “Ọ bụladị taa, mkpesa m dị ilu; 
\q2 aka ya dị arọ megide m nʼagbanyeghị ịsụ ude m. 
\q1  
\v 3 A sịkwa na m maara ebe m ga-achọta ya; 
\q2 a sịkwa na m nwere ike ijeru ebe obibi ya! 
\q1  
\v 4 Aga m edozi mkpesa m nʼusoro nʼihu ya 
\q2 were ịrụ ụka mejuo ọnụ m. 
\q1  
\v 5 Aga m achọpụta ihe o ga-aza m 
\q2 ma tuleekwa ihe ọ ga-agwa m. 
\q1  
\v 6 Ọ ga-eji ike dị egwu megide m? 
\q2 Mba, ọ gaghị ebo m ebubo. 
\q1  
\v 7 Nʼebe ahụ, onye ziri ezi ga-eme mkpesa nʼihu ya. 
\q2 Nʼebe ahụ, a ga-anapụtakwa m site nʼaka onye ikpe m rụọ mgbe ebighị ebi. 
\b  
\q1  
\v 8 “Ma ọ bụrụ na m agaa nʼọwụwa anyanwụ ọ nọghị nʼebe ahụ; 
\q2 ọ bụrụ na m gaa nʼọdịda anyanwụ, agaghị m achọta ya. 
\q1  
\v 9 Mgbe ọ nọ nʼọrụ nʼugwu anaghị m ahụ ya, 
\q2 mgbe ọ lọghachiri na ndịda anaghị m ahụkwa ya. 
\q1  
\v 10 Ma ọ maara ụzọ m na-aga, 
\q2 mgbe ọ nwapụtasịrị m, aga m apụta dịka ọlaedo, 
\q1  
\v 11 ụkwụ m abụọ na-agbaso nzọ ụkwụ ya; 
\q2 ana m eso ụzọ ya na-atụgharịghị nʼaka nri maọbụ aka ekpe. 
\q1  
\v 12 Esibeghị m nʼiwu nke si nʼọnụ ya pụta wezuga onwe m; 
\q2 a na m echekwa okwu ọnụ ya karịa nri nke m na-eri kwa ụbọchị. 
\b  
\q1  
\v 13 “Ma o guzo naanị ya, onye pụrụ iguzogide ya? 
\q2 Ọ na-eme ihe ọbụla masịrị ya. 
\q1  
\v 14 Ọ na-emezu ụkpụrụ ya niile o zubere megide m, 
\q2 ọ ka nwekwara nzube ndị ọzọ yiri nke a o dobere imegide m. 
\q1  
\v 15 Nʼihi ya ka obi ji ama m jijiji nʼihu ya; 
\q2 mgbe m chetara banyere ihe ndị a niile, ana m atụ egwu ya. 
\q1  
\v 16 Chineke emeela ka obi m daa mba; 
\q2 Onye pụrụ ime ihe niile emeela ka m maa jijiji. 
\q1  
\v 17 Ma ọchịchịrị emeghị ka m mechie ọnụ m, 
\q2 bụ oke ọchịchịrị nke kpuchiri ihu m. 
\b  
\c 24  
\q1  
\v 1 “Gịnị mere Onye pụrụ ime ihe niile adịghị ahọpụta oge maka ikpe ikpe? 
\q2 Gịnị mere ndị maara ya ga-eji na-ele anya nʼefu maka oge ndị a? 
\q1  
\v 2 Ụfọdụ ụmụ mmadụ na-ewezuga nkume oke ala, 
\q2 na-elekọta igwe atụrụ ha zutere nʼohi. 
\q1  
\v 3 Ha na-apụnara ịnyịnya ibu nke nwa mgbei, 
\q2 ha na-anarakwa ehi nke nwanyị di ya nwụrụ nʼihe ebe. 
\q1  
\v 4 Site nʼokporoụzọ ka ha na-akwapụ ndị nọ na mkpa. 
\q2 Ha na-ejikwa aka ike mee ka ndị ogbenye dị nʼala ahụ zoo onwe ha. 
\q1  
\v 5 Dịka ịnyịnya ibu ọhịa nọ nʼọzara, 
\q2 otu a ka ndị ogbenye si agagharị na-achọgharị ihe oriri, 
\q2 ala na-adịghị epupụta ihe na-enye ụmụ ha nri. 
\q1  
\v 6 Ha na-ekpokọta ahịhịa anụ ụlọ na-ata nʼubi, 
\q2 na-atụtụkọtakwa mkpụrụ vaịnị nke fọdụrụ nʼubi ndị ajọ omume. 
\q1  
\v 7 Nʼihi enweghị uwe, ha na-agba ọtọ nʼabalị, 
\q2 ha enwekwaghị akwa iji kpuchie onwe ha oyi. 
\q1  
\v 8 Oke mmiri ozuzo nke ugwu na-ede ha ahụ, 
\q2 ha na-amaku nkume nʼihi enweghị ebe mgbaba. 
\q1  
\v 9 Nwa na-enweghị nna ka a na-eji ike napụ ara. 
\q2 Nwa ọhụrụ nke onye ogbenye ka a na-anara nʼihe ebe. 
\q1  
\v 10 Nʼihi enweghị akwa ha na-agba ọtọ na-agagharị, 
\q2 ha na-ebu ukwu ọka ma nọrọ nʼagụụ. 
\q1  
\v 11 Ha na-asụpụta mmanụ oliv nʼelu ebe e mebere maka ya, 
\q2 ha na-azọchapụta mmanya vaịnị ma akpịrị na-akpọ ha nkụ. 
\q1  
\v 12 Ụzụ ịsụ ude ndị na-anwụ si nʼobodo na-ebili, 
\q2 mkpụrụobi nke ndị e merụrụ ahụ na-eti mkpu enyemaka. 
\q2 Ma ọ dịghị onye Chineke na-ahụta ka onye ikpe mara nʼihi ihe ndị a. 
\b  
\q1  
\v 13 “Ọ dị ndị na-enupu isi megide ìhè, 
\q2 ndị na-amaghị ụzọ ya 
\q2 maọbụ na-anọgide nʼụzọ ya. 
\q1  
\v 14 Mgbe ìhè nke ụbọchị gafere, ogbu mmadụ na-ebili, 
\q2 gbuo onye ogbenye na onye nọ na mkpa; 
\q2 nʼabalị kwa, ọ na-ezoba dịka onye ohi. 
\q1  
\v 15 Anya onye na-akwa iko na-ele anya chi ojiji; 
\q2 ọ na-eche nʼobi ya sị, ‘Ọ dịghị onye ọbụla ga-ahụ m,’ 
\q2 ọ na-ekpuchikwa ihu ya. 
\q1  
\v 16 Nʼọchịchịrị, ndị ohi na-egbuka ụlọ ndị mmadụ baa, 
\q2 ma nʼehihie ha na-emechibido onwe ha ụzọ nʼime ụlọ; 
\q2 o nweghị ihe ha na ìhè jikọrọ. 
\q1  
\v 17 Nʼebe ha niile nọ, etiti abalị bụ ụtụtụ ha, 
\q2 ha na ihe egwu nke ọchịchịrị bụ enyi. 
\b  
\q1  
\v 18 “Ma ha bụ ụfụfụ dị nʼelu mmiri; 
\q2 ala ha ketara bụ ihe a bụrụ ọnụ, 
\q2 nke mere na ọ dịghị onye na-agakwa nʼubi vaịnị ha. 
\q1  
\v 19 Dịka okpomọkụ na ọkọchị si eme ka mkpụrụ mmiri oyi gbazee, 
\q2 otu a ka ala ili si ewere ndị mehiere nʼike. 
\q1  
\v 20 Akpanwa na-echefu ha, 
\q2 ikpuru na-eji ha mere ihe oriri; 
\q1 anaghị echetakwa ndị ajọọ omume 
\q2 kama a na-etiji ha dịka osisi. 
\q1  
\v 21 Ha na-akpagbu nwanyị aga na nwanyị na-enweghị nwa, 
\q2 ha adịghị elekọta nwanyị di ya nwụrụ. 
\q1  
\v 22 Ma Chineke na-eji ike ya dọkpụrụ ndị dị ike nke ukwuu pụọ, 
\q2 ọ bụ ezie na ha bụ ndị ihe na-agara nke ọma, ma ha enweghị nkwa nke ndụ. 
\q1  
\v 23 Ọ nwere ike ime ka ha dabere na ntụkwasị obi na o nweghị ihe pụrụ ịmetụ ha, 
\q2 ma anya ya dịkwasịrị ụzọ ha niile. 
\q1  
\v 24 A na-ebuli ha elu nwa mgbe nta, ma e mesịa, ha anọkwaghị, 
\q2 a na-eweda ha nʼala chikọtakwa ha dịka ndị ọzọ, 
\q2 a na-ebipụ ha dịka ukwu ọka. 
\b  
\q1  
\v 25 “Ọ bụrụ na ọ bụghị otu a, onye pụrụ ị sị na ihe m kwuru bụ okwu ụgha 
\q2 si otu a mee ka okwu m bụrụ ihe efu?” 
\c 25  
\s1 Okwu Bildad 
\p  
\v 1 Mgbe ahụ, Bildad onye Shua zara sị: 
\q1  
\v 2 “Ike ọchịchị na oke egwu bụ nke Chineke; 
\q2 Ọ bụ ya na-eme ka udo dịrị nʼeluigwe. 
\q1  
\v 3 Onye pụrụ ịgụta usuu ndị agha ya ọnụ? 
\q2 Onye kwa ka ìhè ya na-adịghị enwukwasị? 
\q1  
\v 4 Mmadụ ọ ga-esi aṅaa bụrụ onye ezi omume nʼihu Chineke? 
\q2 Mmadụ nwanyị mụrụ ọ ga-esi aṅaa dị ọcha? 
\q1  
\v 5 Lee, ọ bụladị ọnwa adịghị achawapụta, 
\q2 ọzọ kpakpando adịghị ọcha nʼanya ya, 
\q1  
\v 6 ka ọfọdụzie nwa mmadụ efu mụrụ, nke bụ naanị ikpuru, 
\q2 mmadụ, nke bụ naanị idide.” 
\c 26  
\s1 Okwu Job 
\p  
\v 1 Mgbe ahụ, Job zaghachiri: 
\q1  
\v 2 “Lee ka i si nyere onye na-adịghị ike aka! 
\q2 Leekwa ka i si zọpụta ogwe aka nke onye ume na-adịghị! 
\q1  
\v 3 Lee ụdị ndụmọdụ i nyerela onye na-enweghị amamihe! 
\q2 Leekwa ụdị oke nghọta nke ị gosipụtara. 
\q1  
\v 4 Ọ bụ onye nyeere gị aka ikwu okwu ndị a? 
\q2 Mmụọ onye si nʼọnụ gị kwuo okwu? 
\b  
\q1  
\v 5 “Ndị nwụrụ anwụ nọ nʼoke ihe mgbu, 
\q2 ha na ndị nọ nʼokpuru mmiri na ndị bi nʼime ya. 
\q1  
\v 6 Ala mmụọ gba ọtọ nʼihu Chineke; 
\q2 mbibi\f + \fr 26:6 \ft Maọbụ, \fqa Abadọn nʼasụsụ Hibru\f* tọgbọkwara na-enweghị ihe kpuchiri ya. 
\q1  
\v 7 Ọ na-agbasapụ elu elu nke mbara eluigwe nʼelu ebe tọgbọrọ nʼefu. 
\q2 O nweghị ihe o kokwasịrị ụwa nʼelu ya. 
\q1  
\v 8 Ọ na-ekechi mmiri nʼime igwe ojii, 
\q2 ma ịdị arọ ya adịghị eme ka igwe ojii gbawaa. 
\q1  
\v 9 Ọ na-ekpuchi ihu ọnwa nke dị nʼuju ya,\f + \fr 26:9 \ft Ọ na-ekpuchi ihu ocheeze nke ọnwa\f* 
\q2 na-agbasakwa igwe ojii ya nʼelu ya, 
\q1  
\v 10 O kewapụtara oke nʼelu ogbu mmiri, 
\q2 ka ọ bụrụ oke dị nʼetiti ìhè na ọchịchịrị. 
\q1  
\v 11 Ogidi niile nke eluigwe na-ama jijiji, 
\q2 tụọkwa oke egwu nʼihi ịba mba ya. 
\q1  
\v 12 Nʼike ya ka o ji kpalie oke osimiri; 
\q2 ọ bụ amamihe ya ka o ji tigbuo Rehab. 
\q1  
\v 13 Ọ bụ site na nkuume ya ka mbara eluigwe ji maa mma; 
\q2 aka ya dupuru agwọ na-agba ọsọ. 
\q1  
\v 14 Ihe ndị a bụ ọnụ ọnụ ọrụ aka ya;\f + \fr 26:14 \ft Ihe ndị a bụ ụfọdụ nʼime ihe ọ na-eme\f* 
\q2 lee ka o si dị nta bụ okwu ntakwu anyị na-anụ gbasara ya! 
\q2 Onye pụrụ ịghọtacha ịda ụda\f + \fr 26:14 \ft Egbe eluigwe nke ike\f* nke ike ya?” 
\c 27  
\s1 Okwu ikpeazụ Job nye ndị enyi ya 
\p  
\v 1 Ma Job gakwara nʼihu nʼokwu ya sị: 
\q1  
\v 2 “Nʼezie, dịka Chineke na-adị ndụ, onye jụrụ ikpere m ikpe ziri ezi, 
\q2 Onye pụrụ ime ihe niile, onye mere ka m hụ ihe ilu nke mkpụrụobi. 
\q1  
\v 3 Ogologo mgbe m nwere ndụ nʼime m, 
\q2 mgbe iku ume Chineke dịkwa nʼimi m, 
\q1  
\v 4 egbugbere ọnụ m agaghị ekwu ihe ọjọọ, 
\q2 ire m agakwaghị ekwu okwu aghụghọ. 
\q1  
\v 5 Agaghị m ekwenye na ihe unu kwuru ziri ezi; 
\q2 ruo mgbe m ga-anwụ, agaghị m agọnarị izuoke m. 
\q1  
\v 6 Aga m ejigidesi ezi omume m aka ike, agaghị m ahapụ ya; 
\q2 o nwekwaghị mgbe obi m ga-ata m ụta ogologo ụbọchị niile nke ndụ m. 
\b  
\q1  
\v 7 “Ka ndị iro m dịrị ka ndị ajọ omume, 
\q2 ka ndị na-ebili imegide m dịrị ka ndị na-emebi iwu. 
\q1  
\v 8 Nʼihi nke a, gịnị bụ olileanya onye na-amaghị Chineke nwere mgbe e bipụrụ ya, 
\q2 mgbe Chineke wepụrụ ndụ ya? 
\q1  
\v 9 Chineke ọ na-anụ ịkwa akwa ya 
\q2 mgbe nsogbu dakwasịrị ya? 
\q1  
\v 10 Ọ ga-achọta ihe ụtọ nʼime Onye pụrụ ime ihe niile? 
\q2 Ọ ga-akpọku Chineke mgbe niile? 
\b  
\q1  
\v 11 “Aga m akụziri unu maka ike nke Chineke; 
\q2 agaghị m ezo ihe banyere ụzọ Onye pụrụ ime ihe niile. 
\q1  
\v 12 Unu onwe unu ahụla ihe ndị a, 
\q2 gịnị mere unu ji ekwu okwu ndị a na-enweghị isi? 
\b  
\q1  
\v 13 “Nke a bụ oke Chineke na-ekenye ndị ajọ omume, 
\q2 nke a bụkwa ihe nketa nke onye ahụ na-adịghị eme ebere na-anata site nʼaka Onye pụrụ ime ihe niile. 
\q1  
\v 14 Nʼagbanyeghị ọnụọgụgụ ụmụ ya, oke ha bụ mma agha; 
\q2 ụmụ ya agaghị enwe ihe oriri ga-ezuru ha. 
\q1  
\v 15 Ọrịa na-efe efe ga-egbu ndị ya fọrọ ndụ; 
\q2 ọzọ, ụmụ nwanyị ha hapụrụ nwụọ agaghị akwa akwa nʼihi ha. 
\q1  
\v 16 Ọ bụrụ na ọ kpakọta ọlaọcha dịka uzuzu, 
\q2 ma tụkọtakwa uwe dịka aja ụrọ, 
\q1  
\v 17 ihe ndị ọ kpakọtara bụ onye ezi omume ga-eyi ha, 
\q2 ndị aka ha dị ọcha ga-ekekwa ọlaọcha ya. 
\q1  
\v 18 Ụlọ o wuru dị ka ụlọ nla, 
\q2 dịkwa ka ụlọ ntu nke onye nche wuru. 
\q1  
\v 19 Ọ na-edina ala dịka ọgaranya ma ọ gaghị edinakwa dịka ọgaranya ọzọ; 
\q2 mgbe ọ saghere anya ya abụọ, ihe niile efuola. 
\q1  
\v 20 Oke egwu na-adakwasị ya dịka idee mmiri; 
\q2 oke ebili mmiri na-ebufu ya nʼabalị. 
\q1  
\v 21 Ifufe si nʼọwụwa anyanwụ na-ebufu ya, agaghị ahụkwa ya anya ọzọ; 
\q2 ọ na-azachapụ ya site nʼọnọdụ ya. 
\q1  
\v 22 Ọ na-atụfu ya na-enweghị ebere 
\q2 mgbe ọ na-eme ngwangwa ịgbapụ site nʼike ya. 
\q1  
\v 23 Ọ na-akụkọta aka ya nʼịkwa emo, 
\q2 were ịma ọsụ wezuga ya nʼọnọdụ ya.” 
\c 28  
\s1 Nwa mgbe nta: Ebe a na-achọta amamihe 
\q1  
\v 1 Olulu e si egwupụta ọlaọcha dị; 
\q2 ebe a na-anụcha ọlaedo dịkwa. 
\q1  
\v 2 E si nʼime ala ewepụta igwe, 
\q2 ọlanchara na-agbazepụta site nkume na-aghọ ọla. 
\q1  
\v 3 Mmadụ na-eme ka ọchịchịrị nwee ọgwụgwụ; 
\q2 ọ na-enyochapụta ihe dị ebe dị anya, 
\q2 na-achọ igwe nʼime oke ọchịchịrị. 
\q1  
\v 4 Ọ na-egwu olulu nʼebe dị anya site nʼebe mmadụ bi, 
\q2 nʼebe ụkwụ mmadụ na-adịghị eru, 
\q2 nʼebe ahụ dị anya site nʼebe mmadụ bi ka ha na-akwụfegharị.\f + \fr 28:4 \ft Nʼoge ochie, ọ bụ nʼoche e ji eriri kegide ka ndị na-egwupụta ihe dị iche iche site nʼime ala na-anọdụ ala. Mgbe a na-adọtu ha, ụkwụ ha adịghị eru ala, ha na-akwụfegharịkwa nʼihi ọnọdụ ha.\f* 
\q1  
\v 5 Ala ahụ e si na ya enweta nri, 
\q2 abụrụla ihe e ji ọkụ gbanwee nʼokpuru ya. 
\q1  
\v 6 Safaia bụ nkume dị oke ọnụahịa dị na nkume ya; 
\q2 aja ya nwekwara mkpụrụ ọlaedo. 
\q1  
\v 7 Ọ dịghị anụ ufe nke na-eri anụ maara ụzọ ahụ zoro ezo; 
\q2 anya agụ nkwọ ọbụla ahụtụbeghị ya. 
\q1  
\v 8 Anụ ọhịa dị nganga anaghị azọnye ụkwụ nʼelu ya, 
\q2 ọdụm ọbụla adịghị awagharị nʼebe ahụ. 
\q1  
\v 9 Ndị mmadụ na-eji aka na-etiwasị nkume ahụ na-enwu ọkụ 
\q2 mee ka mgbọrọgwụ ugwu ahụ pụta ìhè. 
\q1  
\v 10 Ha na-awapụta ọwa ụzọ nʼetiti nkume ahụ, 
\q2 anya ha na-ahụkwa akụnụba ya niile. 
\q1  
\v 11 Ha na-achọpụta isi mmiri niile 
\q2 ma meekwa ka ihe nzuzo pụta ìhè. 
\b  
\q1  
\v 12 Ma olee ebe ka a ga-achọta amamihe? 
\q2 Olee kwa ebe nghọta bi? 
\q1  
\v 13 Mmadụ apụghị ịghọta ọnụahịa ya, 
\q2 agaghị achọtakwa ya nʼala ndị dị ndụ. 
\q1  
\v 14 Ogbu mmiri na-asị, “Ọ dịghị nʼime m,” 
\q2 osimiri na-asị, “Ọ dịghị nʼaka m.” 
\q1  
\v 15 A gaghị eji ọlaedo a nụchara nke ọma zụta ya, 
\q2 apụghị ịtụ ihe bụ ọnụahịa ya nʼọlaọcha. 
\q1  
\v 16 A gaghị eji ọlaedo nke Ọfịa zụta ya, 
\q2 a gaghị ejikwa nkume dara oke ọnụahịa nke ọniks maọbụ safaia zụta ya, 
\q1  
\v 17 A gaghị eji ọlaedo maọbụ kristal tụnyere ya, 
\q2 maọbụ iji ejiji ọlaedo nweta ya. 
\q1  
\v 18 Koral na jaspa erughị ihe a na-akpọtụ aha nʼebe ọ dị; 
\q2 ọnụahịa nke amamihe karịrị ọtụtụ rubi. 
\q1  
\v 19 A gaghị eji ọla topaazi nke Kush tụnyere ya; 
\q2 a pụghị iji ọlaedo a nụchara anụcha zụta ya. 
\b  
\q1  
\v 20 Olee ebe amamihe si abịa? 
\q2 Olee ebe nghọta bi? 
\q1  
\v 21 E zoro ya ezo site nʼanya ihe niile dị ndụ, 
\q2 e kpuchikwara ya nye ọ bụladị anụ ufe nke eluigwe. 
\q1  
\v 22 Mbibi na ọnwụ na-asị; 
\q2 “Naanị akụkọ ya ruru anyị ntị.” 
\q1  
\v 23 Chineke ghọtara ụzọ ya, 
\q2 naanị ya makwara ebe obibi ya dị. 
\q1  
\v 24 Nʼihi na ọ na-ahụ nsọtụ nke ụwa, 
\q2 na-ahụkwa ihe niile dị nʼokpuru eluigwe. 
\q1  
\v 25 Mgbe o hiwere ike nke ikuku, 
\q2 tụọkwa mmiri nʼihe ọtụtụ, 
\q1  
\v 26 mgbe o nyere mmiri ozuzo iwu 
\q2 meekwa ụzọ nye egbe eluigwe na oke ikuku, 
\q1  
\v 27 mgbe ahụ, o lere amamihe anya, nyochasịa ya, 
\q2 meekwa ka o guzosie ike, ma nwapụtakwa ya. 
\q1  
\v 28 Ọ sịrị mmadụ, 
\q2 “Ịtụ egwu Onyenwe anyị, nke ahụ bụ amamihe; 
\q2 ọzọ, ị sị nʼihe ọjọọ wezuga onwe bụ nghọta.” 
\c 29  
\s1 Ngọpụ ikpeazụ Job 
\p  
\v 1 Job gakwara nʼihu nʼokwu ya sị: 
\q1  
\v 2 “Ọ gaara adị m nọọ mma ma a sị na m ga-adị dịka m dị nʼọnwa ole na ole gara aga, 
\q2 dịka ụbọchị ndị ahụ mgbe Chineke na-elekọta m, 
\q1  
\v 3 mgbe oriọna ya na-achakwasị m nʼisi 
\q2 ìhè ya ka m ji jee ije nʼọchịchịrị. 
\q1  
\v 4 Ewoo, otu ihe dịịrị nʼụbọchị ihe na-agara m nke ọma, 
\q2 mgbe mmekọrịta mụ na Chineke mere ka ụlọ m bụrụ ebe a gọziri agọzi, 
\q1  
\v 5 mgbe Onye pụrụ ime ihe niile nọnyeere m 
\q2 na mgbe ụmụ m nọkwa m gburugburu, 
\q1  
\v 6 mgbe ụzọ m jupụtara na mmiri ara ehi rahụrụ arahụ, 
\q2 mgbe nkume na-awụpụtara m mmanụ oliv dịka mmiri na-asọ asọ. 
\b  
\q1  
\v 7 “Mgbe m na-apụ nʼọnụ ụzọ ama obodo 
\q2 were ọnọdụ m nʼama. 
\q1  
\v 8 Ụmụ okorobịa na-ahụ m wezuga onwe ha, 
\q2 ndị okenye na-ahụkwa m ma guzo nʼụkwụ ha; 
\q1  
\v 9 ndịisi ọchịchị obodo na-akwụsị ikwu okwu 
\q2 ma were aka ha kpuchie ọnụ ha; 
\q1  
\v 10 olu ndị a na-asọpụrụ na-adakwa jụụ, 
\q2 ire ha na-araparakwa ha nʼakpo ọnụ. 
\q1  
\v 11 Nʼoge ahụ, onye ọbụla nụrụ olu m na-ekwu ihe dị mma banyere m, 
\q2 ndị hụkwara m na-agba ama ọma maka m. 
\q1  
\v 12 Nʼihi na anapụtara m ndị ogbenye na-eti mkpu enyemaka, 
\q2 napụtakwa ndị mgbei na-enweghị ndị enyemaka. 
\q1  
\v 13 Onye nọ nʼọnụ ọnwụ gọziri m; 
\q2 emekwara m ka obi nwanyị di ya nwụrụ bụọ abụ. 
\q1  
\v 14 Ana m eyikwasị ezi omume dịka uwe, 
\q2 ikpe ziri ezi bụ uwe mwụda m na akwa okike nke isi m. 
\q1  
\v 15 Abụ m anya nye onye ìsì, 
\q2 bụrụkwa ụkwụ nye onye ngwụrọ. 
\q1  
\v 16 Abụ m nna nke onye nọ na mkpa; 
\q2 bụrụkwa onye gbalịrị ịhụ na ndị ọbịa natara ikpe ziri ezi. 
\q1  
\v 17 Etijiri m ikiri eze nke ndị ajọ omume, 
\q2 si otu a napụta ndị ha na-achọ ịdọgbu. 
\b  
\q1  
\v 18 “Echere m sị, ‘Aga m anwụ nʼụlọ nke aka m, 
\q2 na ụbọchị m ga-abakwa ụba dịka aja dị nʼala. 
\q1  
\v 19 Mgbọrọgwụ m ga-eto rịda na mmiri, 
\q2 na igirigi ga-adakwasịkwa nʼalaka m abalị niile. 
\q1  
\v 20 Nsọpụrụ m ga-adịgide ọhụrụ nʼime m, 
\q2 ụta m ga-adịgidekwa ọhụrụ nʼaka m.’ 
\b  
\q1  
\v 21 “Ụmụ mmadụ na-eji oke olileanya na-ege m ntị, 
\q2 ha na-ederekwa duu ịnụrụ ndụmọdụ m. 
\q1  
\v 22 Mgbe m kwụsịrị okwu, ha anaghị ekwukwa ọzọ. 
\q2 Okwu m na-ada juu na ntị ha. 
\q1  
\v 23 Ha na-echerekwa m dịka e si echere mmiri ozuzo, 
\q2 na-aṅụkwa okwu m dịka ala si aṅụ mmiri ozuzo nʼọkọchị. 
\q1  
\v 24 Mgbe m miiri ha ọnụ ọchị, ha adịghị ekwenye ya; 
\q2 ìhè nke ihu m dị oke mkpa nye ha. 
\q1  
\v 25 Ọ bụ m na-ahọpụtara ha ụzọ, na-anọdụ dịka onyeisi ha; 
\q2 ebiri m dịka a ga-asị na m bụ onye eze nʼetiti ndị agha ya; 
\q2 na dịka onye na-akasị ndị na-eru ụjụ obi. 
\b  
\c 30  
\q1  
\v 1 “Ma ugbu a, ha na-akwa m emo 
\q2 bụ ndị bụ ụmụntakịrị nʼebe m nọ, 
\q1 bụ ndị nna ha na-etorughị ndị m na-ezipụ 
\q2 ka ha na nkịta na-eso atụrụ m nọkọta. 
\q1  
\v 2 Uru gịnị ka ike aka ha ga-abara m, 
\q2 ebe ọ bụ na ha adịghịkwa ike? 
\q1  
\v 3 Ha bụ ndị ike gwụrụ site nʼụkọ na agụụ, 
\q2 ha na-agagharị nʼala kpọrọ nkụ 
\q2 na-awagharịkwa nʼime ọzara nʼabalị. 
\q1  
\v 4 Nʼala ọhịa ka ha na-atụrị ahịhịa nnu, 
\q2 mgbọrọgwụ osisi brum bụkwa nri ha. 
\q1  
\v 5 A chụpụrụ ha site nʼetiti ndị mmadụ ibe ha, 
\q2 a na-etiso ha mkpu dịka ha bụ ndị ohi. 
\q1  
\v 6 A chụpụrụ ha ka ha gaa biri nʼala iyi mmiri na-adịghị. 
\q2 Ha bi nʼetiti ọgba nkume na ọnụ a tụrụ nʼime ala. 
\q1  
\v 7 Ha na-eme ụzụ nʼọhịa dịka ụmụ anụmanụ, 
\q2 na-ejikọta onwe ha nʼahịhịa toro nʼokpuru osisi. 
\q1  
\v 8 Ha bụ ndị e ledara anya, ndị na-enweghị aha, 
\q2 e sitere nʼala ahụ chụpụ ha. 
\b  
\q1  
\v 9 “Ma ugbu a, abụrụla m ihe ụmụ okorobịa ji abụ abụ ịkwa emo; 
\q2 abụrụkwala m okwu ha ji anọpụrụ ụbọchị. 
\q1  
\v 10 Abụ m ihe ịsọ oyi nye ha, ha adịghị abịakwa m nso; 
\q2 ha anaghị egbu oge igbu m asọ mmiri nʼihu. 
\q1  
\v 11 Ma ugbu a, ebe ọ bụ na Chineke atọpụla eriri ụta m ma kpagbuo m, 
\q2 o nwekwaghị ihe ha na-adịghị eme nʼihu m. 
\q1  
\v 12 Nʼaka nri m mba ndị a na-ebuso m agha. 
\q2 Ha na-esiri ụkwụ m ọnya, 
\q2 ha na-ewuli mgbidi ha nọchibido m. 
\q1  
\v 13 Ha na-etiwasị ụzọ m, 
\q2 ha kwadoro mmekpa ahụ m. 
\q2 ‘O nweghị onye ga-enyere ya aka,’ ka ha na-ekwu. 
\q1  
\v 14 Ha na-abịakwasị m dịka ndị sitere ebe e tipuru mgbidi; 
\q2 nʼetiti mbibi ya ha na-enu onwe ha enute nʼebe m nọ. 
\q1  
\v 15 Oke egwu abịakwasịla m; 
\q2 ugwu m adịla ka ihe ifufe buuru, 
\q2 nchekwa m agabigala dịka igwe ojii. 
\b  
\q1  
\v 16 “Ugbu a, ndụ m ji nwayọọ nwayọọ na-agabiga; 
\q2 ụbọchị ahụhụ ejidela m. 
\q1  
\v 17 Abalị na-esewasị ọkpụkpụ m, 
\q2 ihe mgbu m nke na-ata ata enweghị ezumike. 
\q1  
\v 18 Nʼoke ike ya, Chineke na-adịrị m ka uwe; 
\q2 ọ na-ekechi m dịka olu uwe m. 
\q1  
\v 19 Ọ na-atụba m nʼime apịtị, 
\q2 mee ka m ghọọ ntụ na aja. 
\b  
\q1  
\v 20 “Chineke m, anam etiku gị ma ị dịghị aza m; 
\q2 anam eguzo ọtọ, ma naanị anya ka i lere m. 
\q1  
\v 21 Ị na-emegide m na-enweghị obi ebere; 
\q2 i ji aka gị dị ike megide m. 
\q1  
\v 22 Ị na-ejide m nʼike welie m elu chụba m nʼoke ifufe, 
\q2 ị na-eme ka m bụrụ onye na-akwụfegharị nʼoke ifufe nke mmiri. 
\q1  
\v 23 Amara m na ị ga-eweda m ruo ọnwụ; 
\q2 ruo nʼebe e debeere mmadụ niile dị ndụ. 
\b  
\q1  
\v 24 “Nʼezie, ọ dịghị onye na-emegide onye e tidara nʼala; 
\q2 mgbe ọ na-eti mkpu nʼọnọdụ nhụju anya ya na-achọ enyemaka. 
\q1  
\v 25 Ọ bụ na m akwaghị akwa nʼihi ndị nọ na nsogbu; 
\q2 ọ bụ na mmụọ m erughị ụjụ nʼihi ndị ogbenye? 
\q1  
\v 26 Ma mgbe m lere anya ihe ọma, ihe ọjọọ bịara; 
\q2 mgbe m lere anya ìhè, mgbe ahụ ka ọchịchịrị bịara. 
\q1  
\v 27 Obi m anaghị ezu ike nʼime m; 
\q2 ụbọchị ahụhụ na-ezute m. 
\q1  
\v 28 Ana m agagharị na-eji nji ma ọ bụghị nʼihi oke anwụ. 
\q2 Eguzola m ọtọ nʼọgbakọ ndị mmadụ tikuo ha ka ha nyere m aka. 
\q1  
\v 29 Abụrụla m nwanne nkịta ọhịa; 
\q2 onye ya na ikwighịkwighị na-esogharị. 
\q1  
\v 30 Akpụkpọ ahụ m na-eji nji na-ekpe iwere; 
\q2 anụ ahụ m na-anụ ọkụ dịka ihe a kwanyere ọkụ. 
\q1  
\v 31 Ụda ụbọ akwara m bụ ụda iru ụjụ; 
\q2 ụda ọja m bụkwa ụda iti mkpu akwa. 
\b  
\c 31  
\q1  
\v 1 “Mụ na anya m gbara ndụ kpebie 
\q2 na o nweghị mgbe m ga-ele nwaagbọghọ ọbụla anya nʼihi agụụ ịkwa iko.\f + \fr 31:1 \ft Maọbụ, \fqa anya ọjọọ \xt Mat 5:28\f* 
\q1  
\v 2 Nʼihi na, gịnị bụ oke mmadụ ketara nʼaka Chineke onye bi nʼelu; 
\q2 gịnị bụkwa ihe nketa ya site nʼaka Onye pụrụ ime ihe niile nọ nʼelu? 
\q1  
\v 3 Ọ bụghị mbibi nye ndị ajọ omume, 
\q2 nhụju anya nye ndị na-eme ihe ọjọọ? 
\q1  
\v 4 Ọ bụ na ọ naghị ahụ ụzọ m niile, 
\q2 gụọkwa nzọ ukwu m niile ọnụ? 
\b  
\q1  
\v 5 “Ọ bụrụ na m gara ije nʼụzọ ụgha 
\q2 maọbụ na ụkwụ m mere ngwangwa gbasoro ụzọ aghụghọ, 
\q1  
\v 6 ka Chineke were ihe ọtụtụ ziri ezi tụọ m, 
\q2 ọ ga-amata na m bụ onye na-enweghị ịta ụta. 
\q1  
\v 7 Ọ bụrụ na nzọ ụkwụ m si nʼụzọ wezuga onwe ya, 
\q2 ọ bụrụ anya m na-edu obi m, 
\q2 ma ọ bụkwanụ na aka m abụọ bụ ihe e merụrụ emerụ, 
\q1  
\v 8 ọ bụrụ otu a, ka onye ọzọ rie ihe m kụrụ nʼubi, 
\q2 ka e hopuchakwa ihe niile m kụrụ nʼubi. 
\b  
\q1  
\v 9 “Ọ bụrụ na ọ gụọla obi m agụụ ijekwuru nwanyị ọzọ, 
\q2 maọbụ na m ezoola nʼọnụ ụzọ onye agbataobi m, 
\q1  
\v 10 mgbe ahụ, ka nwunye m kwọọrọ nwoke ọzọ nri, 
\q2 ka ndị ikom ọzọ dinaa ya. 
\q1  
\v 11 Nʼihi na nke ahụ ga-abụ ihe ihere, 
\q2 bụrụkwa mmehie kwesiri ka e kpee ya ikpe. 
\q1  
\v 12 Ọ bụ ọkụ na-ere ruo nʼebe ịla nʼiyi;\f + \fr 31:12 \ft Maọbụ, \fqa Mbibi\f* 
\q2 nke pụrụ ihopu ihe owuwe ubi m niile. 
\b  
\q1  
\v 13 “Ọ bụrụ na m jụrụ ikpe ikpe ziri ezi 
\q2 nye nwoke maọbụ nwanyị ọbụla na-ejere m ozi 
\q2 mgbe ha nwere mkpesa megide m, 
\q1  
\v 14 gịnị ka m ga-eme mgbe Chineke bịakwutere m? 
\q2 Gịnị ka m ga-aza ya mgbe ọ jụrụ m ajụjụ? 
\q1  
\v 15 Ọ bụ na ọ bụghị onye kpụrụ m nʼafọ nne m mekwara ha? 
\q2 Ọ bụghị ya kpụrụ anyị abụọ nʼafọ nne anyị? 
\b  
\q1  
\v 16 “Ọ bụrụ na m ajụ inye ndị ogbenye ihe dị ha mkpa, 
\q2 ma ọ bụrụkwa na m eme ka anya nwanyị di ya nwụrụ dalaa ya nʼisi, 
\q1  
\v 17 ọ bụrụ na m dobere ihe oriri m maka naanị m, 
\q2 ma jụ inye ya ụmụ mgbei; 
\q1  
\v 18 ma site nʼokorobịa m, azụlitere m ha dịka nna kwesiri, 
\q2 ọ bụkwa site na nwantakịrị ka m bụ onyendu nye nwanyị di ya nwụrụ. 
\q1  
\v 19 Ọ bụrụ na ọ dị mgbe m hụrụ onye na-ala nʼiyi nʼihi enweghị akwa, 
\q2 maọbụ onye nọ nʼụkọ nke na-enweghị uwe, 
\q1  
\v 20 ma obi ha agọzighị m 
\q2 nʼihi iji ajị sitere nʼụmụ atụrụ m mee ka o nwee okpomọkụ nʼahụ ya. 
\q1  
\v 21 Ọ bụrụ na m eweliela aka m megide onye nna ya nwụrụ, 
\q2 nʼihi na m mara na m nwere nkwuwa okwu nʼụlọikpe, 
\q1  
\v 22 mgbe ahụ, ka aka m si nʼubu m dapụ, 
\q2 ka e tijiekwa ogwe aka m site na nkwonkwo ya. 
\q1  
\v 23 Nʼihi na atụrụ m egwu mbibi na-esite nʼaka Chineke, 
\q2 nʼihi egwu ebube ya, enweghị m ike ime ihe ndị a. 
\b  
\q1  
\v 24 “Ọ bụrụ na ntụkwasị obi m dị nʼọlaedo, 
\q2 maọbụ na m sị ọlaedo a nụchara anụcha, ‘Ị bụ ebe ndabere m.’ 
\q1  
\v 25 Ọ bụrụ na m ṅụrịrị ọṅụ nʼihi oke akụ m, 
\q2 ihe nnweta nke aka m ritere nʼuru, 
\q1  
\v 26 ọ bụrụ na m legidere anyanwụ anya nʼebube ya, 
\q2 maọbụ ọnwa nʼike nchawa ya, 
\q1  
\v 27 nke ga-eme ka obi m bụrụ ihe a rafuru na nzuzo, 
\q2 maọbụ aka m abụrụ ihe e weliri ife ha ofufe, 
\q1  
\v 28 mgbe ahụ, ihe ndị a ga-abụ mmehie nke a ga-ekpe ikpe, 
\q2 nʼihi na m gaara abụ onye na-ekwesighị ntụkwasị obi nye Chineke, Onye bi nʼelu. 
\b  
\q1  
\v 29 “Ọ bụrụ na m ṅụrịrị ọṅụ nʼihi ọdachi nke dakwasịrị onye iro m 
\q2 maọbụ chịa ọchị nʼihi nsogbu nke dakwasịrị ya, 
\q1  
\v 30 ekwebeghị m ka ọnụ m mehie 
\q2 megide ha site nʼịbụ ndụ ha ọnụ. 
\q1  
\v 31 Ọ bụrụ na o nwebeghị oge ndị nọ nʼezinaụlọ m kwuru okwu sị. 
\q2 ‘Onye ka ọ bụ nke na-erijubeghị afọ site nʼihe oriri Job na-enye?’ 
\q1  
\v 32 Ma ọ dịghị onye ọbịa na-anọ ọnọdụ abalị nʼama, 
\q2 nʼihi ụzọ m na-eghe oghe mgbe ọbụla nye ndị ije. 
\q1  
\v 33 Ọ bụrụ na m na-ezo mmehie m dịka ndị ọzọ,\f + \fr 31:33 \ft Maọbụ, \fqa dịka Adam mere\f* 
\q2 site nʼizobe mmehie m nʼime obi m, 
\q1  
\v 34 nʼihi na m tụrụ egwu igwe mmadụ, 
\q2 si otu a, tụọ oke egwu nʼihi nleda anya nke ndị agbụrụ dị iche iche, 
\q2 nke mere ka m gbaa nkịtị ghara ịpụ nʼezi. 
\b  
\q1  
\v 35 (“O, a sị na o nwere onye ga-ege m ntị! 
\q2 Ana m ebinye aka m nʼokwu ngọpụ m, ka Onye pụrụ ime ihe niile za m, 
\q2 ka onye na-ebo m ebubo depụta ihe o nwere megide m nʼakwụkwọ. 
\q1  
\v 36 Nʼezie, aga m eyiri ya nʼubu m, 
\q2 aga m eyinyekwa ya dịka okpueze. 
\q1  
\v 37 Aga m agụkọrọ ya nzọ ụkwụ m niile, 
\q2 aga m ejekwuru ya dịka ọkpara eze.) 
\b  
\q1  
\v 38 “Ọ bụrụ na ala m etie mkpu megide m, 
\q2 ọ bụrụ na olulu dị na ya ejupụta nʼanya mmiri, 
\q1  
\v 39 ọ bụrụ na m eripịa ihe o mepụtara na-akwụghị ụgwọ, 
\q2 maọbụ mee ka mmụọ ndị bi nʼime ya daa mba, 
\q1  
\v 40 ka ogwu pupụta nʼọnọdụ ọka wiiti, 
\q2 ka ahịhịa na-esi isi ọjọọ pupụtakwa nʼọnọdụ ọka balị.” 
\p Okwu Job agwụla. 
\b  
\c 32  
\s1 Okwu Elihu 
\p  
\v 1 Mgbe ahụ, ndị ikom atọ ndị a kwusịrị ịsa Job okwu ọbụla ọzọ nʼihi na ọ hụrụ onwe ya dịka onye ezi omume.  
\v 2 Ma oke iwe were Elihu nwa Barakel onye obodo Buz, si nʼikwu Ram megide Job nʼihi na ọ gụrụ onwe ya dịka onye ezi omume karịa Chineke.  
\v 3 Iwe wekwara ya nʼebe mmadụ atọ ndị enyi Job nọ, nʼihi na ọ dịghị ebe ha hụtara Job dịka onye ụzọ ya na-ezighị ezi, ma ha gara nʼihu ịma ya ikpe.  
\v 4 Ma ruo ugbu a, Elihu agwaghị Job okwu ọbụla nʼihi na ndị ọzọ bụ okenye nʼebe ọ nọ.  
\v 5 Ma mgbe ọ hụrụ na ndị ikom atọ ndị a enweghị okwu ọzọ ha ga-ekwu, nke a kpasuru ya iwe. 
\p  
\v 6 Ma Elihu nwa Barakel onye obodo Buz zara sị: 
\q1 “Abụ m nwantakịrị nʼọnụọgụgụ afọ m gbara, 
\q2 ma unu bụ ndị okenye; 
\q1 ọ bụ nke a mere m ji gbaa nkịtị nʼụjọ, 
\q2 hapụ ịgwa unu ihe m maara. 
\q1  
\v 7 Echere m nʼobi m sị, ‘Ọnụọgụgụ afọ ga-ekwu okwu; 
\q2 ọtụtụ afọ ka ọ dịkwara ikuzi amamihe.’ 
\q1  
\v 8 Ma ọ bụ mmụọ dị nʼime mmadụ, 
\q2 nkuume nke Onye pụrụ ime ihe niile na-enye nghọta. 
\q1  
\v 9 Ọ bụghị naanị ndị okenye bụ ndị mara ihe, 
\q2 ọ bụkwaghị naanị ndị gbara ọtụtụ afọ bụ ndị na-aghọta ihe ziri ezi. 
\b  
\q1  
\v 10 “Ya mere m na-asị, Geenụ m ntị; 
\q2 mụ onwe m ga-agwa unu ihe m ma. 
\q1  
\v 11 Echeere m oge niile unu na-ekwu okwu, 
\q2 egere m ntị na ntụgharị uche unu, 
\q1 oge niile unu na-achọpụta okwu unu ga-ekwu. 
\q2  
\v 12 Egere m nnọọ unu ntị, 
\q1 ma ọ dịghị onye nʼime unu nwerela ike gosi Job ụzọ o si jehie; 
\q2 ọ dịghị onye nʼime unu zaghachiri ịrụ ụka ya. 
\q1  
\v 13 Unu ekwula sị, ‘Anyị achọtala amamihe; 
\q2 ka Chineke na-abụghị mmadụ gosi ya mmehie ya.’ 
\q1  
\v 14 Ma Job edozighị okwu ya nʼusoro megide m, 
\q2 ya mere agaghị m eji ịrụ ụka unu zaghachi ya. 
\b  
\q1  
\v 15 “Ha adaala mba na-enweghị ihe ọzọ ha ga-ekwu; 
\q2 ike okwu agwụla ha. 
\q1  
\v 16 M ga-echere, ugbu a ha deere duu, 
\q2 ugbu a ha guzo ebe ahụ na-enweghị ọsịsa? 
\q1  
\v 17 Mụ onwe m ga-ekwu uche m; 
\q2 ihe m maara ka mụ onwe m ga-ekwu, 
\q1  
\v 18 nʼihi na okwu juru m ọnụ, 
\q2 ọ bụkwa mmụọ dị nʼime m na-akwagide m. 
\q1  
\v 19 Nʼime m, adị m ka mmanya na-agbọ ụfụfụ a kwuchiri na karama, 
\q2 dịka karama akpụkpọ ọhụrụ dị njikere ịgbawa. 
\q1  
\v 20 Aga m ekwurịrị okwu ka m sị nʼụzọ dị otu a chọta izuike; 
\q2 aga m emeghe egbugbere ọnụ m ma zaghachi. 
\q1  
\v 21 Agaghị m ekpe mmadụ ọbụla ikpe mmegide 
\q2 maọbụ jaa mmadụ ọbụla mma nʼụzọ na-ezighị ezi. 
\q1  
\v 22 Nʼihi na ọ bụrụ na m bụ ọka nwere ire ụtọ nʼịja ihe na-ezighị ezi mma, 
\q2 Onye kere m ga-ewepụ m nʼoge na-adịghị anya. 
\b  
\c 33  
\q1  
\v 1 “Ma ugbu a, Job, gee ntị nʼokwu m; 
\q2 ṅaakwa ntị nke ọma nʼihe niile m ga-ekwu. 
\q1  
\v 2 Ejikerela m imeghe ọnụ m ikwu okwu; 
\q2 okwu m dịkwa nʼọnụ ire m. 
\q1  
\v 3 Okwu m sitere nʼizi ezi nke obi m; 
\q2 egbugbere ọnụ m na-ekwu naanị eziokwu nke m ma. 
\q1  
\v 4 Ọ bụ Mmụọ nke Chineke mere m, 
\q2 nkuume nke Onye pụrụ ime ihe niile na-enye m ndụ. 
\q1  
\v 5 Zaghachi m ma ọ bụrụ na i nwere ike; 
\q2 jikere onwe gị ka anyị rụrịtaa ụka. 
\q1  
\v 6 Mụ onwe m dị ka i si dị nʼihu Chineke; 
\q2 mụ onwe m bụkwa ihe esitere nʼụrọ kpuo. 
\q1  
\v 7 Egwu m ekwesighị ime ka ị tụọ oke ụjọ, 
\q2 ma ọ bụkwanụ ogwe aka m ịdị arọ nʼahụ gị. 
\b  
\q1  
\v 8 “Ma ị kwuola ya na ntị m, 
\q2 anụrụ m okwu ndị ahụ niile, 
\q1  
\v 9 ‘Mụ onwe m dị ọcha nʼobi m, o nweghị ihe na-ezighị ezi m mere; 
\q2 adị m ọcha na-enweghị mmehie ọbụla. 
\q1  
\v 10 Ma Chineke chọtara ezughị oke nʼebe m nọ; 
\q2 ọ na-ahụta m dịka onye iro ya. 
\q1  
\v 11 Ọ na-eji mkpọrọ kechie ụkwụ m abụọ; 
\q2 ọ na-enyochakwa ụzọ m niile.’ 
\b  
\q1  
\v 12 “Ma ana m agwa gị, na nke a i meghị nke ọma, 
\q2 nʼihi na Chineke dị elu karịa mmadụ. 
\q1  
\v 13 Gịnị mere i ji na-ekpesara ya 
\q2 na ọ dịghị azaghachi mmadụ ọbụla okwu? 
\q1  
\v 14 Ma Chineke na-ekwu okwu, ugbu a nʼotu ụzọ, ugbu a kwa nʼụzọ ọzọ, 
\q2 ọ bụ ezie na mmadụ nwere ike ghara ịghọta ya. 
\q1  
\v 15 Na nrọ maọbụ nʼọhụ nke abalị, 
\q2 mgbe ụmụ mmadụ na-ada nʼoke ụra, 
\q2 mgbe ha na-atụgharị nʼelu ihe ndina ha. 
\q1  
\v 16 O nwere ike kwunye ha okwu na ntị 
\q2 ma mee ka egwu tụọ ha site nʼọtụtụ ịdọ aka na ntị; 
\q1  
\v 17 ka mmadụ si nʼajọ omume ya chegharịa, 
\q2 ka o si na nganga ya wezuga onwe ya, 
\q1  
\v 18 ka o chebe mkpụrụobi ya site nʼolulu, 
\q2 chebekwa ndụ ya site nʼịla nʼiyi nke mma agha. 
\b  
\q1  
\v 19 “Ọzọkwa, a na-abara mmadụ mba site nʼihe mgbu nke na-eme ka o dinara nʼelu ihe ndina, 
\q2 ebe ọkpụkpọ niile dị ya nʼahụ na-anọgide na-egbu ya mgbu. 
\q1  
\v 20 Nke na-eme ka ndụ ya na-asọ ihe oriri oyi, 
\q2 ọzọ, mkpụrụobi ya na-ajụkwa nri dịkarịsịrị ụtọ. 
\q1  
\v 21 Anụ ahụ ya na-abụ ihe na-ala nʼiyi, 
\q2 ma ọkpụkpụ ya; nke bụ ihe zoro ezo na mbụ, na-apụta ihe ugbu a. 
\q1  
\v 22 Mkpụrụobi ya na-abịaru ili nso, 
\q2 ndụ ha na-anọkwa nso nʼaka ndị na-ejere ọnwụ ozi. 
\q1  
\v 23 Ma a sị na e nwere mmụọ ozi nọ ya nʼakụkụ, 
\q2 dịka onye nkwuchite ọnụ, otu onye nʼetiti puku mmadụ, 
\q2 onye ga-agwa mmadụ ihe ziri ezi nye ya, 
\q1  
\v 24 ọ na-emere onye ahụ amara, na-asịkwa Chineke, 
\q2 ‘Napụta ya, ekwela ka ọ gbadaa nʼime olulu ili; 
\q2 achọtala ihe mgbapụta nʼihi ya. 
\q1  
\v 25 Ka ahụ ya nwogharịa dịka nke nwantakịrị, 
\q2 ka a eweghachi ike ya dịka ọ dị nʼụbọchị okorobịa ya.’ 
\q1  
\v 26 Mgbe ahụ, onye ahụ ga-arịọ Chineke arịrịọ ma chọtakwa ihuọma ya, 
\q2 ha ga-ahụ ihu Chineke ma tiekwa mkpu ọṅụ, 
\q2 ọ na-enyeghachi ha ezi ihe nʼihi ezi omume ya. 
\q1  
\v 27 Mgbe ahụ, ọ na-abịakwute ụmụ mmadụ sị ha: 
\q2 ‘Emehiere m, mee ihe ziri ezi ka ọ bụrụ ajọ omume, 
\q2 ma anataghị m ihe kwesiri ịbụ ụgwọ ọrụ m; 
\q1  
\v 28 ọ gbapụtara mkpụrụobi m ka m ghara ịrịda nʼolulu ili, 
\q2 ya mere aga m adị ndụ hụkwa ìhè nke ndụ.’ 
\b  
\q1  
\v 29 “Ihe ndị a niile ka Chineke na-emere mmadụ 
\q2 ugboro abụọ, ọbụladị ugboro atọ. 
\q1  
\v 30 Ka ọ dọghachite mkpụrụobi ya site nʼolulu ili, 
\q2 ka ìhè nke ndụ si otu a mụkwasị ya. 
\b  
\q1  
\v 31 “Gee ntị, Job, ma nụrụ okwu m; 
\q2 dere jii ka m kwuo okwu. 
\q1  
\v 32 Ọ bụrụ na i nwere ihe ị chọrọ ikwu, zaghachi m; 
\q2 kwupụ okwu, nʼihi na achọrọ m ịgụ gị nʼonye ezi omume. 
\q1  
\v 33 Ma ọ bụghị otu a, gee m ntị; 
\q2 dere jii, ka m zi gị amamihe.” 
\c 34  
\p  
\v 1 Mgbe ahụ Elihu sịrị: 
\q1  
\v 2 “Nụrụ okwu m, unu ndị amamihe; 
\q2 gee m ntị unu ndị ikom nwere mmụta. 
\q1  
\v 3 Ntị na-anwale okwu dịka 
\q2 ire si anụ ụtọ ihe oriri. 
\q1  
\v 4 Ka anyị chọpụtara onwe anyị ihe ziri ezi; 
\q2 ka anyị nọkọta mụta ihe dị mma. 
\b  
\q1  
\v 5 “Job na-asị, ‘Abụ m onye ezi omume, 
\q2 ma Chineke na-anapụ m ikpe ziri ezi. 
\q1  
\v 6 Ọ bụ eziokwu na aka m dị ọcha 
\q2 ma a na-ahụta m dịka onye ụgha; 
\q1 ọ bụ eziokwu na ikpe amaghị m 
\q2 ma ọnya na-enweghị ngwọta ka àkụ ya na-enye m.’ 
\q1  
\v 7 Olee nwoke dịka Job, 
\q2 nke na-aṅụ ịkwa emo dịka mmiri? 
\q1  
\v 8 Ya na ndị na-eme ajọ ihe bụ enyi, 
\q2 ya na ndị ajọ omume na-emekọkwa ihe. 
\q1  
\v 9 Nʼihi na ọ na-asị, ‘Ọ dịghị uru dị ya 
\q2 na mmadụ na-achọ ime ihe na-atọ Chineke ụtọ.’\f + \fr 34:9 \ft \xt Mal 3:14\f* 
\b  
\q1  
\v 10 “Ya mere, geenụ m ntị, unu ndị ikom nwere nghọta. 
\q2 Ya bụrụ ihe dị anya nʼebe Chineke nọ, bụ ime ajọ omume, 
\q2 bụrụkwa ihe dị anya nʼebe Onye pụrụ ime ihe niile nọ, bụ ime ihe na-ezighị ezi. 
\q1  
\v 11 Ọ na-akwụghachi onye ọbụla dịka ihe o mere si dị, 
\q2 ọ na-ewetara mmadụ dịka omume ya kwesiri. 
\q1  
\v 12 Ọ bụ ihe a na-ekwesighị iche nʼuche na Chineke pụrụ ime ihe na-ezighị ezi, 
\q2 na Onye pụrụ ime ihe niile ga-ekpe ikpe nʼezighị ezi. 
\q1  
\v 13 Onye họpụtara ya ịchị ụwa? 
\q2 Onye mere ya onye nlekọta ụwa niile? 
\q1  
\v 14 Ọ bụrụ na ọ bụ ebumnuche ya 
\q2 iweghachi mmụọ ya na nkuume ya, 
\q1  
\v 15 mmadụ niile ga-alakọta nʼiyi, 
\q2 mmadụ niile ga-alaghachikwa nʼaja. 
\b  
\q1  
\v 16 “Ọ bụrụ na i nwere nghọta, nụrụ nke a; 
\q2 gee ntị nʼokwu m. 
\q1  
\v 17 Ọ pụrụ ịchị bụ onye ahụ kpọrọ ikpe ziri ezi asị? 
\q2 Ị ga-ama Onye ezi omume na onye dị ike ikpe? 
\q1  
\v 18 Ọ bụghị ya na-agwa ndị eze okwu sị, ‘Unu abaghị uru,’ 
\q2 ma na-agwakwa ndị a mara aha ha sị, ‘Unu bụ ndị ajọ omume.’ 
\q1  
\v 19 Onye na-adịghị ekpe ikpe mmegide\f + \fr 34:19 \ft \xt Dit 10:17; Rom 2:11\f* nye ụmụ ndị ikom eze, 
\q2 onye na-adịghị emenyere ndị ọgaranya, ma megbuo ndị ogbenye, 
\q2 nʼihi na ha niile bụ ọrụ aka ya. 
\q1  
\v 20 Nʼotu ntabi anya, ha na-anwụ nʼime etiti abalị; 
\q2 ndị ahụ na-ama jijiji ma gabiga; 
\q2 a na-ewezugakwa ndị dị ike ma ọ bụghị site nʼaka mmadụ. 
\b  
\q1  
\v 21 “Anya ya na-elekwasị ụzọ niile nke ụmụ mmadụ; 
\q2 ọ na-ahụkwa nzọ ụkwụ ha niile. 
\q1  
\v 22 Ọ dịghị ọchịchịrị dị, ọ dịghịkwa oke ọchịchịrị dị, 
\q2 ebe ndị na-eme ajọ ihe pụrụ izo. 
\q1  
\v 23 Ọ dịghị mkpa ọ dịịrị Chineke ịga nʼihu inyocha ụmụ mmadụ, 
\q2 nke mere na ha ga-abịa nʼihu ya maka ikpe ikpe. 
\q1  
\v 24 Na-ajụghị ajụjụ Chineke na-akụtu ndị a maara aha ha 
\q2 ma were ndị ọzọ dochie nʼọnọdụ ha. 
\q1  
\v 25 Nʼihi na ọ na-agụkọ ọrụ ha niile, 
\q2 ọ na-achụpụ ha nʼabalị mee ka ha ghọọ ndị e gwepịara egwepịa. 
\q1  
\v 26 Nʼebe mmadụ niile ga-ahụ ha ka ọ na-ata ha ahụhụ 
\q2 nʼihi ajọ omume ha, 
\q1  
\v 27 nʼihi na ha sitere nʼiso ya wezuga onwe ha, 
\q2 ha enweghịkwa uche ilebanye anya nʼụzọ ya ọbụla. 
\q1  
\v 28 Ha mere ka iti mkpu akwa nke ndị ogbenye ruo ya ntị, 
\q2 nke mere na ọ nụrụ akwa ndị nọ na mkpa. 
\q1  
\v 29 Ma ọ bụrụ na ọ gba nkịtị, onye ga-ama ya ikpe? 
\q2 Ọ bụrụ na o zoo ihu ya, onye pụrụ ịhụ ya? 
\q1 Ma ya onwe ya na-achị isi nʼebe mmadụ na mba nọ, 
\q2  
\v 30 igbochi nwoke na-adịghị atụ egwu Chineke ịchị obodo, 
\q2 ka ọ gharakwa ịbụ ihe ọnya nye ndị mmadụ. 
\b  
\q1  
\v 31 “Ọ bụrụ na mmadụ a sị Chineke, 
\q2 ‘Abụ m onye ikpe mara ma agaghị m emehie kwa ọzọ. 
\q1  
\v 32 Biko, zi m ihe ndị ahụ m na-apụghị\f + \fr 34:32 \ft Maọbụ, \fqa amaghị\f* ịhụ; 
\q2 ọ bụrụ na m emehiela, agaghị m emekwa ya ọzọ.’ 
\q1  
\v 33 Chineke ọ ga-akwụghachi gị ụgwọ ọrụ site na mkpebi\f + \fr 34:33 \ft Ya bụ, nrọpụta\f* gị 
\q2 mgbe ị jụrụ ichegharị? 
\q1 Gị onwe gị ga-ekpebi, ọ bụghị mụ; 
\q2 ya mere gwa m ihe ị mara. 
\b  
\q1  
\v 34 “Ndị ikom ndị nwere nghọta na-ekwu si, 
\q2 ndị amamihe nụrụ okwu m na-asị m, 
\q1  
\v 35 ‘Job na-ekwu okwu dịka onye na-amaghị ihe; 
\q2 okwu ya dị ka nke onye na-enweghị uche.’ 
\q1  
\v 36 Ọ ga-adị nnọọ mma ma a sị na a nwaa Job ruo nsọtụ 
\q2 maka ọsịsa ya dịka nke ajọ mmadụ! 
\q1  
\v 37 Ọ na-atụkwasị nnupu isi nʼelu mmehie ya; 
\q2 na-akụ aka nʼetiti anyị nʼụzọ ịkwa emo, 
\q2 ma werekwa okwu nkwulu bara ụba megide Chineke.” 
\c 35  
\p  
\v 1 Mgbe ahụ, Elihu sịrị: 
\q1  
\v 2 “Ị na-eche na nke a ziri ezi? 
\q2 Ị sịrị, ‘Na m ziri ezi ọ bụghị Chineke.’ 
\q1  
\v 3 Nʼagbanyeghị ihe ndị a, ị na-ajụ ya si, ‘Uru gịnị ka ọ baara m, 
\q2 gịnị bụ uru m ma ọ bụrụ na emehieghị m?’ 
\b  
\q1  
\v 4 “Ọ ga-amasị m ịzaghachi gị, 
\q2 zaghachikwa ndị enyi gị na ha nọ. 
\q1  
\v 5 Lelie anya na eluigwe ma hụkwa. 
\q2 Legide mbara igwe na igwe oji niile, nke dị anya karịa gị. 
\q1  
\v 6 Ọ bụrụ na i mehie, olee ụzọ nke a si metụta ya? 
\q2 Ọ bụrụ na mmehie gị bara ụba, gịnị ka nke a pụrụ ime ya? 
\q1  
\v 7 Ọ bụrụ na ị bụ onye ezi omume, gịnị ka ị na-enye ya, 
\q2 maọbụ gịnị ka ọ na-anata site nʼaka gị? 
\q1  
\v 8 Ajọ omume gị na-emetụta naanị mmadụ dịka gị, 
\q2 ma ezi omume gị na-emetụta naanị ụmụ ndị mmadụ. 
\b  
\q1  
\v 9 “Ụmụ mmadụ na-eti mkpu akwa nʼihi ịba ụba nke mmegbu, 
\q2 ha na-arịọ arịrịọ enyemaka site nʼaka ndị dị ike. 
\q1  
\v 10 Ma ọ dịghị onye na-asị, ‘Olee ebe Chineke onye kere m nọ, 
\q2 onye na-enye abụ nʼime abalị, 
\q1  
\v 11 onye na-akụziri anyị ihe karịa ka ọ na-akụziri ụmụ anụ ọhịa nke ụwa, 
\q2 onye na-eme ka anyị bụrụ ndị maara ihe karịa ụmụ nnụnụ\f + \fr 35:11 \ft Maọbụ, \fqa anụ ufe\f* nke igwe?’ 
\q1  
\v 12 Ọ dịghị azaghachi mgbe ụmụ mmadụ na-eti mkpu akwa, 
\q2 nʼihi ịnya isi nke ndị ajọ omume. 
\q1  
\v 13 Nʼezie, Chineke adịghị aṅa ntị nʼarịrịọ efu ha; 
\q2 Onye pụrụ ime ihe niile a dịghị elebara ya anya. 
\q1  
\v 14 Ma ya bụrụzie nke a ị na-ekwu, ọ ga-esi aṅaa gee ntị 
\q2 mgbe ị na-ekwu na ị dịghị ahụ ya anya, 
\q1 na i burula ikpe gị bịa nʼihu ya 
\q2 na ị ga-anọkwa na-eche ya! 
\q1  
\v 15 Ọzọ, nʼihi na iwe ya adịghị eweta ntaramahụhụ, 
\q2 nʼihi na ọ dịghị arịba ama ajọ omume ọ bụladị nke dịkarịsịrị nta. 
\q1  
\v 16 Ya mere, Job saghere ọnụ ya kwuo okwu dịka onye na-amaghị ihe; 
\q2 ka onye na-enweghị uche ọ na-ekwu okwu nkwukwasị efu.” 
\c 36  
\p  
\v 1 Elihu gara nʼihu sị: 
\q1  
\v 2 “Nyetụ m nwa oge nta, ka m gosi gị 
\q2 na ọ ka dị ọtụtụ ihe e nwere ikwu nyere Chineke. 
\q1  
\v 3 Ana m enweta amamihe m site nʼebe dị anya; 
\q2 aga m enye Onye kere m ezi omume. 
\q1  
\v 4 Ya doo gị anya na okwu m abụghị okwu ụgha; 
\q2 onye zuruoke nʼihe ọmụma nọnyeere gị. 
\b  
\q1  
\v 5 “Chineke dị ike ma ọ dịghị eleda mmadụ ọbụla anya; 
\q2 ọ dị ike, bụrụkwa onye na-eme ihe ọbụla o zubere ime. 
\q1  
\v 6 Ọ naghị edebe ndị ajọ omume ndụ, 
\q2 kama ọ na-enye ndị a na-akpagbu akpagbu ihe ruuru ha. 
\q1  
\v 7 Ọ dịghị ewepụ anya ya\f + \fr 36:7 \ft Maọbụ, \fqa ịgbakụta azụ\f* nʼebe ndị ezi omume nọ, 
\q2 kama ọ na-eme ka ha na ndị eze nọkwasị nʼocheeze, 
\q2 bụrụ ndị e buliri elu ruo mgbe ebighị ebi. 
\q1  
\v 8 Ma ọ bụrụ na e kechie ụmụ mmadụ nʼagbụ igwe, 
\q2 jirikwa agbụ nke mkpagbu jidesie ha ike, 
\q1  
\v 9 ọ na-agwa ha ihe ha mere, 
\q2 na ha sitere na nganga ha mehie. 
\q1  
\v 10 Ọ na-eme ka ha ṅaa ntị nye ntụziaka, 
\q2 na-enyekwa ha iwu ka ha chegharịa site nʼajọ ihe ha na-eme. 
\q1  
\v 11 Ọ bụrụ na ha erube isi, jekwaara ya ozi, 
\q2 ha ga-abụ ndị ga-ebi oge ndụ ha fọdụrụ nʼakụnụba, 
\q2 biekwa ogologo ndụ ha niile nʼafọ ojuju. 
\q1  
\v 12 Ma ọ bụrụ na ha egeghị ntị, 
\q2 ha ga-ala nʼiyi site na mma agha, 
\q2 ha ga-anwụ na-enweghị ọmụma ihe. 
\b  
\q1  
\v 13 “Ndị ajọ omume na-ebu iro nʼobi ha. 
\q2 Ha adịghị echegharị kpọkuo ya ọ bụladị mgbe o kere ha agbụ.\f + \fr 36:13 \ft Ọ tara ha ahụhụ\f* 
\q1  
\v 14 Ha na-anwụ nʼoge okorobịa ha, 
\q2 nʼetiti ndị ikom na-agba akwụna nʼụlọ arụsị dị iche iche. 
\q1  
\v 15 Ma ndị na-ahụsị anya ka ọ na-azọpụta site nʼahụhụ ha; 
\q2 na-agwa ha okwu site na mkpagbu ha. 
\b  
\q1  
\v 16 “Ọ na-achọsi ike ịnapụta gị site nʼọnụ mkpagbu, 
\q2 baa nʼebe sara mbara, ebe mkpagbu na-adịghị, 
\q2 baa na tebul nke jupụtara na nri dị ezi ụtọ. 
\q1  
\v 17 Ma ugbu a, ikpe ọmụma dịịrị ndị ajọ omume na-anyịgbu gị; 
\q2 ikpe ọmụma na ikpe ziri ezi abịakwasịla gị. 
\q1  
\v 18 Lezie anya ka mmadụ ọbụla ghara iji akụnụba rafuo gị; 
\q2 ekwekwala ka ihe ngarị bara ụba wezuga gị nʼọnọdụ gị. 
\q1  
\v 19 Akụnụba gị maọbụ ịdị ike gị ha pụrụ ịnapụta gị 
\q2 ka ị ghara ịnọ na mkpagbu? 
\q1  
\v 20 Anọla na-echere ka abalị bịa, 
\q2 mgbe a na-adọkpụrụ ndị ụmụ mmadụ site nʼụlọ ha pụọ. 
\q1  
\v 21 Lezie anya, ka i ghara iche ihu nye ajọ ihe, 
\q2 bụ nke ọ dị ka ị na-ahọrọ karịa mkpagbu. 
\b  
\q1  
\v 22 “E buliela Chineke elu nʼike ya, 
\q2 onye bụ onye ozizi dịka ya? 
\q1  
\v 23 Onye họpụtaara ya ụzọ ọ ga-agbaso, 
\q2 maọbụ sị ya ‘I meela ajọ ihe’? 
\q1  
\v 24 Cheta ka i bulie ọrụ aka ya elu, 
\q2 bụ nke ụmụ mmadụ torola site nʼabụ. 
\q1  
\v 25 Mmadụ niile ahụzuola ya; 
\q2 ụmụ mmadụ nọ nʼebe dị anya na-ele ya anya. 
\q1  
\v 26 Lee, Chineke dị ukwuu, karịa nghọta anyị. 
\q2 Ọnụọgụgụ afọ ya karịrị mmadụ ịchọpụta. 
\b  
\q1  
\v 27 “Ọ bụ ya na-eme ka ukuru mmiri rigoro nʼelu mgbe anwụ na-acha, 
\q2 nke a na-aghọ mmiri ozuzo nye iyi niile. 
\q1  
\v 28 Igwe ojii na-awụdata mmiri dị nʼime ya 
\q2 mee ka mmiri ozuzo dị ukwuu zokwasị ụmụ mmadụ. 
\q1  
\v 29 Onye pụrụ ịghọta ka o si gbasaa igwe ojii, 
\q2 ka o si ebigbọ site nʼebe obibi ya? 
\q1  
\v 30 Lee, ọ gbasaala amụma ya gburugburu ya 
\q2 na-ekpuchi ebe niile dịkarịsịrị omimi nke oke osimiri. 
\q1  
\v 31 Nke a bụ ụzọ o si achị mba niile 
\q2 na-enyejukwa ha nri afọ. 
\q1  
\v 32 O ji amụma nke egbe eluigwe kpojuo aka ya, 
\q2 ma na-enye ya iwu itida ihe ọbụla ọ chọrọ. 
\q1  
\v 33 Ịda ụda nke egbe eluigwe na-akọwa ọbịbịa nke oke ifufe mmiri; 
\q2 ọ bụladị ehi na-eme ka a mara na ọ nọ nso. 
\b  
\c 37  
\q1  
\v 1 “Nʼihi nke a, obi m na-ama jijiji, 
\q2 na-amali elu site nʼọnọdụ ya. 
\q1  
\v 2 Gee ntị! Gee ntị nụrụ ụda olu ya, 
\q2 na ụzụ nke si nʼọnụ ya apụta. 
\q1  
\v 3 Ọ na-atọpụ amụma ya ka ọ na-ejeru nʼokpuru eluigwe niile, 
\q2 ọ na-ezisakwa ya ebe niile ụwa sọtụrụ. 
\q1  
\v 4 Nke a gasịa, ihe ọzọ na-eso ya bụ mbigbọ nke olu ike ya; 
\q2 ụda olu ya na ada ụda dịka egbe eluigwe, 
\q1 mgbe olu ahụ dara dakwasị, 
\q2 ọ naghị egbochi amụma igbu egbu. 
\q1  
\v 5 Nʼụzọ dị ebube ka olu Chineke si ada dịka egbe eluigwe; 
\q2 ọ na-eme ọtụtụ ihe ukwuu nke anyị na-apụghị ịghọta. 
\q1  
\v 6 Nʼihi na ọ bụ ya na-agwa snoo okwu sị: ‘Daa nʼelu ala,’ 
\q2 na-agwakwa mmiri ozuzo okwu sị, ‘Zoo nnukwu mmiri ozuzo.’\f + \fr 37:6 \ft Ghọọ oke mmiri ozuzo\f* 
\q1  
\v 7 Ka mmadụ o kere mata akaọrụ ya; 
\q2 ọ na-emekwa ka mmadụ ọbụla kwụsị ịdọgbu onwe ya nʼọrụ. 
\q1  
\v 8 Ụmụ anụmanụ bi nʼọhịa na-agbaba zoo onwe; 
\q2 ha na-anọgide nʼebe obibi ha. 
\q1  
\v 9 Oke ifufe na-esite nʼụlọ ya na-abịa, 
\q2 oyi na-esitekwa nʼikuku na-agbasa agbasa. 
\q1  
\v 10 Iku ume Chineke na-emepụta mkpụrụ mmiri, 
\q2 ogbu mmiri na-akpụkọtakwa. 
\q1  
\v 11 Ọ na-eme ka igwe ojii jupụta na mmiri; 
\q2 na-eme ka amụma gbuo nʼime igwe ojii. 
\q1  
\v 12 Site na ntụziaka ya ka ha na-echigharị onwe ha gburugburu 
\q2 imezu ihe ọbụla ọ chọrọ ka ha mee 
\q2 nʼelu ụwa niile. 
\q1  
\v 13 Ọ na-ewebata igwe ojii maka ịta ndị mmadụ ahụhụ, 
\q2 na-eweta ya maka ime ka mmiri zokwasị elu ala igosi ịhụnanya ya. 
\b  
\q1  
\v 14 “Job, gee ntị. 
\q2 Tulee ọrụ ebube niile Chineke na-arụ. 
\q1  
\v 15 Ị maara otu Chineke si achịkọta igwe ojii 
\q2 na-eme ka amụma gbuo? 
\q1  
\v 16 Ị maara otu Chineke si kwụba igwe ojii na mbara eluigwe, 
\q2 nke bụ ọrụ ebube onye ihe ọmụma ya zuruoke? 
\q1  
\v 17 Gị onye uwe i yi nʼahụ na-ekpo gị ọkụ 
\q2 mgbe ụwa dere jii nʼihi ifufe na-esite na ndịda na-abịa, 
\q1  
\v 18 ị pụrụ iso ya tụsaa mbara eluigwe 
\q2 nke dị ike dịka enyo bronz a wụrụ awụ? 
\b  
\q1  
\v 19 “Gwa anyị ihe anyị ga-azaghachi ya; 
\q2 ebe ọ bụ na anyị apụghị ido okwu anyị nʼusoro nʼihi ọchịchịrị nke anyị nọ nʼime ya. 
\q1  
\v 20 A ga-agwa ya na m nwere okwu? 
\q2 Ọ dị mmadụ ọbụla ga-achọ ka e loda ya? 
\q1  
\v 21 Ugbu a, ọ dịghị mmadụ ọbụla pụrụ ilekwasị anyanwụ anya 
\q2 ka ọ na-achake na mbara igwe, 
\q2 mgbe ifufe ji ngwangwa gabiga mee ka o nwuo ọcha. 
\q1  
\v 22 Nʼugwu ka ebube na-enwu dịka ọlaedo si apụta;\f + \fr 37:22 \ft Maọbụ, \fqa nʼugwu ka ọ si na-abịa ka ebube ọlaedo\f* 
\q2 Chineke na-eji ebube dị egwu na-abịa. 
\q1  
\v 23 Onye pụrụ ime ihe niile bụ onye anyị na-enweghị ike chọta. Ike ya dị ukwuu, 
\q2 nʼikpe ikpe ya ziri ezi na ezi omume ya bara ụba, ọ naghị emegbu mmadụ. 
\q1  
\v 24 Ya mere, ụmụ mmadụ na-atụ egwu ya, 
\q2 ọ bụ na o nweghị nsọpụrụ nye ndị niile obi ha maara ihe?”\f + \fr 37:24 \ft Ma ọ dịghị agụnye ndị niile na-eche na ha maara ihe.\f* 
\c 38  
\s1 \nd Onyenwe anyị\nd* ekwuo okwu 
\p  
\v 1 Mgbe ahụ, \nd Onyenwe anyị\nd* sitere nʼoke ifufe gwa Job okwu sị: 
\q1  
\v 2 “Onye bụ onye a nke ji okwu ihe ọmụma na-adịghị na ya 
\q2 na-eme ka atụmatụ m ghara ịpụta ìhè? 
\q1  
\v 3 Ugbu a, jikere onwe gị dịka dimkpa 
\q2 nʼihi na enwere m ajụjụ m ga-ajụ gị 
\q2 nke m chọrọ ka i nye m ọsịsa ha. 
\b  
\q1  
\v 4 “Ebee ka ị nọ mgbe m tọrọ ntọala ụwa? 
\q2 Gwa m ma ọ bụrụ na ị ghọtara. 
\q1  
\v 5 Onye kpebiri ihe ụwa ga-aha ka ya? Nʼezie ị maara, 
\q2 onye setịrị ihe ọtụtụ e ji tụọ ya nʼelu ya? 
\q1  
\v 6 Nʼelu gịnị ka a tọrọ ntọala ya, 
\q2 onye doro nkume mbụ e ji tọọ ntọala ya? 
\q1  
\v 7 Mgbe kpakpando nke isi ụtụtụ zukọrọ bụọ abụ, 
\q2 ụmụ Chineke niile tisikwara mkpu ọṅụ ike? 
\b  
\q1  
\v 8 “Onye kara akara nye osimiri iwu ebe ọ ga-ejedebe\f + \fr 38:8 \ft \xt Abụ 33:7; Abụ 104:9; Ilu 8:29; Jer 5:22\f* 
\q2 mgbe o nupụtara dịka a ga-asị na o si nʼakpanwa pụta, 
\q1  
\v 9 mgbe m yikwasịrị ha igwe ojii dịka uwe, 
\q2 werekwa ọchịchịrị meere ya akwa okike, 
\q1  
\v 10 mgbe m kpaara ya oke ebe ọ ga-akwụsị, 
\q2 tinye ibo ọnụ ụzọ na mkpọrọ e ji akpọchi ya, 
\q1  
\v 11 mgbe m sịrị, ‘Ruo ebe a ka ị ga-asọrute, ị gaghị agabiga ya, 
\q2 nʼebe a ka a ga-akwụsị ebili mmiri mpako gị’? 
\b  
\q1  
\v 12 “O nweela oge i nyere ụtụtụ iwu, 
\q2 maọbụ mee ka chi ọbụbọ maara ọnọdụ ya, 
\q1  
\v 13 ka o jide akụkụ niile nke ụwa aka 
\q2 ma site nʼụwa yọpụ ndị mmebi iwu? 
\q1  
\v 14 Ụwa na-ewere ụdịdị ya dịka ụrọ a kakwasịrị akara; 
\q2 ụdịdị ya na-egosipụta dịka uwe. 
\q1  
\v 15 A na-eme ka ndị na-emebi iwu ghara inwe ìhè, 
\q2 meekwa ka aka e weliri elu bụrụ nke a nyajiri. 
\b  
\q1  
\v 16 “I jeruola nʼisi iyi mmiri dị nʼosimiri, 
\q2 ka i jegharịala nʼebe miri emi nke ogbu mmiri? 
\q1  
\v 17 O nweela onye gosiri gị ọnụ ụzọ ọnwụ? 
\q2 Ka i jirila anya gị hụ ọnụ ụzọ nke onyinyo ọnwụ? 
\q1  
\v 18 Ị ghọtara ịdị ukwu nke ụwa na otu o si gbasapụ? 
\q2 Gwa m, ma ọ bụrụ na ị maara ihe ndị a niile. 
\b  
\q1  
\v 19 “Olee ụzọ e si aga ebe ìhè bi? 
\q2 Olee ebe ọchịchịrị bi? 
\q1  
\v 20 Ị nwere ike iduru ha jee nʼebe ha bi? 
\q2 Ị maara ụzọ e si eje ebe obibi ha? 
\q1  
\v 21 Nʼezie ị maara, nʼihi na a mụọla gị tupu e kee ihe ndị a! 
\q2 Ị bikwaala ọtụtụ afọ. 
\b  
\q1  
\v 22 “Ị banyela nʼụlọ niile ebe a na-achịkọba snoo, 
\q2 ka ị hụla ụlọ niile ebe a na-achịkọba mkpụrụ mmiri igwe, 
\q1  
\v 23 nke m chekwara nye oge nsogbu, 
\q2 nʼoge ọgụ na nʼoge agha? 
\q1  
\v 24 Kedụ ụzọ e si ejeru ebe a na-anọ ekesasị amụma egbe eluigwe, 
\q2 ebee ka e si ekesasị ifufe ọwụwa anyanwụ nʼelu ụwa? 
\q1  
\v 25 Onye wara ụzọ maka oke mmiri ozuzo, 
\q2 onye kwa waara amụma na egbe eluigwe ụzọ? 
\q1  
\v 26 Si otu a mee ka mmiri zokwasị ebe mmadụ na-ebighị, 
\q2 ala ọzara ebe ọ dịghị onye nọ nʼime ya, 
\q1  
\v 27 ka mmiri ozuzo mee ka ala kpọrọ nkụ nweta mmiri 
\q2 iji mee ka ahịhịa pupụta nʼime ya. 
\q1  
\v 28 Mmiri ozuzo o nwere nna? 
\q2 Onye mụrụ igirigi? 
\q1  
\v 29 Site nʼakpanwa onye ka mkpụrụ mmiri si apụta? 
\q2 Onye kwa bụ nne oke oyi nke eluigwe, 
\q1  
\v 30 nke na-eme ka mmiri kpụkọtaa dịrị ike dịka nkume, 
\q2 meekwa ka ihu ogbu mmiri kpụkọta? 
\b  
\q1  
\v 31 “Ị pụrụ ikechi agbụ niile nke Pleiades? 
\q2 Ị pụrụ ịtọpụ ihe nkechikọta Orion? 
\q1  
\v 32 Ị pụrụ ime ka igwe kpakpando pụta nʼoge ha 
\q2 maọbụ dupụta anụ ndọgbu Bịa na ụmụ ya ndị ọzọ? 
\q1  
\v 33 Ị maara iwu na-achị ihe niile dị na mbara eluigwe? 
\q2 Ị pụrụ inye ha ike ịchị ụwa? 
\b  
\q1  
\v 34 “Ị pụrụ iti mkpu ruo igwe ojii 
\q2 si otu a mee ka idee mmiri kpuchie gị? 
\q1  
\v 35 Ị pụrụ izipụ amụma egbe eluigwe nʼụzọ ha? 
\q2 Ha na-asị gị, ‘Ebe a ka anyị nọ’? 
\q1  
\v 36 Onye na-etinye amamihe nʼobi mmadụ, 
\q2 maọbụ na-enye oke ọkpa nghọta? 
\q1  
\v 37 Onye nwere amamihe ịgụ igwe ojii niile dị na mbara eluigwe ọnụ? 
\q2 Onye kwa pụrụ ịhulata karama mmiri niile nke eluigwe niile, 
\q1  
\v 38 mgbe aja dị nʼala siri ike, 
\q2 mgbe ọkpụrụkpụ aja dị nʼala na-akpụkọta nʼahụ ibe ha? 
\b  
\q1  
\v 39 “Ọ bụ gị na-achụtara nne ọdụm ihe oriri, 
\q2 mee ka afọ ju ụmụ ọdụm 
\q1  
\v 40 mgbe ha makpuuru nʼime ọgba ha, 
\q2 maọbụ mgbe ha zoro onwe ha na-eche anụ nʼọhịa? 
\q1  
\v 41 Onye na-edoziri ugolọma ihe oriri ya, 
\q2 mgbe ụmụ ya na-etiku Chineke mkpu agụ, 
\q2 mgbe ha na-akpagharị na-achọ ihe oriri? 
\b  
\c 39  
\q1  
\v 1 “Ị maara mgbe ewu ọhịa bi nʼelu ugwu ji amụ nwa? 
\q2 O nweela mgbe ị ji hụ nne ele ka ọ na-amụpụta nwa ya? 
\q1  
\v 2 Ị na-agụkọ ọnwa ole afọ ime ha na-adị tupu ha amụọ nwa ha. 
\q2 Ị maara oge ha na-amụ ụmụ ha? 
\q1  
\v 3 Ha na-amakpuru ala mụpụta nwa ha. 
\q2 Ihe mgbu nke ọmụmụ nwa ha ebiekwa. 
\q1  
\v 4 Ụmụ ha na-eto nʼọhịa gbasiekwa ike. 
\q2 Ha na-apụ, ha adịghị alaghachikwute ha ọzọ. 
\b  
\q1  
\v 5 “Onye na-eme ka ịnyịnya ibu ọhịa nwere onwe ya? 
\q2 Onye na-atọpụ agbụ e kere ya? 
\q1  
\v 6 Nke m nyere ala ihe na-adịghị ka ọ bụrụ ebe obibi ha, 
\q2 ala nnu ahụ ka ọ bụrụ ụlọ ha. 
\q1  
\v 7 Ụzụ dị nʼobodo adịghị emetụta ya, 
\q2 ọ naghị anụkwa mbigbọ nke onye na-achị ya. 
\q1  
\v 8 Elu ugwu niile bụ ebe ịkpa nri ya, 
\q2 ebe ahụ ka ọ na-achọpụta ahịhịa ndụ ọbụla. 
\b  
\q1  
\v 9 “Ị nwere ike ime ka atụ jeere gị ozi? 
\q2 Ị nwere ike ime ka ọ nọdụ nʼabalị nʼụlọ ebe ị na-azụ anụ ụlọ gị nri? 
\q1  
\v 10 Ị nwere ike ime ka atụ rụọra gị ọrụ nʼubi gị? 
\q2 Ọ ga-akpụgharịrị gị ọgụ ị ji akọ ala? 
\q1  
\v 11 Ị ga-atụkwasị ya obi nʼihi na ike ya hiri nne? 
\q2 Ị ga-ahapụrụ ya ọrụ ndị ahụ siri ike ka ọ rụọ? 
\q1  
\v 12 I nwere ike ịtụkwasị ya obi ka o gaa bulatara gị ọka 
\q2 site nʼebe ịzọcha ọka gị? 
\b  
\q1  
\v 13 “Enyi nnụnụ na-eji ọṅụ gbasapụ nku ya, 
\q2 ma a pụghị iji nku ya tụnyere 
\q2 nku na abụba nke ụgbala. 
\q1  
\v 14 Ọ na-eyi akwa ya nʼala 
\q2 ma hapụ ha ka uzuzu kpoo ha ọkụ. 
\q1  
\v 15 Ọ naghị emetụ ya nʼobi na ụkwụ nwere ike ịzọpịa ha 
\q2 maọbụ na anụ ọhịa nwere ike zọrie ha. 
\q1  
\v 16 Ọ na-emeso ụmụ ya ihe ike dịka a ga-asị na ha abụghị nke ya, 
\q2 ọ dịghị emetụta ya na ndọgbu nʼọrụ ya nwere ike i bụ nʼefu, ma ọ dịghị atụ egwu. 
\q1  
\v 17 Nʼihi na Chineke ekenyeghị ya amamihe 
\q2 maọbụ kenye ya oke na inwe uche. 
\q1  
\v 18 Ma ọ na-agbalite ọsọ. Mgbe ọbụla ọ gbasara nku ya ịgba ọsọ, 
\q2 ọ na-achị ịnyịnya na onye na-agba ịnyịnya ọchị. 
\b  
\q1  
\v 19 “Ọ bụ gị na-enye ịnyịnya ike ya, 
\q2 ka ọ bụ gị mere ka ajị ogologo ahụ o nwere dịrị nʼolu ya? 
\q1  
\v 20 Ị na-eme ya ka ọ wụgharịa dịka igurube, 
\q2 were ebube\f + \fr 39:20 \ft Maọbụ, \fqa nganga\f* nke ịmapụ imi ya na-eyinye ihe oke egwu? 
\q1  
\v 21 Ọ na-azọ ụkwụ gam gam nʼala, ọ na-aṅụrị ọṅụ nʼihi ike ya, 
\q2 ọ na-apụ izute agha na-atụghị egwu. 
\q1  
\v 22 Ọ na-achị ihe egwu ọchị, ụjọ ọbụla anaghị atụ ya; 
\q2 ọ naghị esi na mma agha wezuga onwe ya. 
\q1  
\v 23 Akpa àkụ na-ayọgharị nʼakụkụ ya, 
\q2 ya na ùbe na arụa na-egbu maramara. 
\q1  
\v 24 Mgbe ụzụ agha bara ya nʼisi, ọ na-eripịa ala. 
\q2 Mgbe ọ nụrụ ụda opi ike, ọ naghị eguzo otu ebe. 
\q1  
\v 25 Mgbe ụzụ agha bara ya nʼisi, ọ na-eti mkpu sị, ‘Ahaa!’ 
\q2 Site nʼebe dị anya ka ọ na-anụ isisi agha. 
\q2 Ọ na-aṅụrịkwa ọṅụ maka iti mkpu nke ndị ọchịagha nʼoge agha. 
\b  
\q1  
\v 26 “Ọ bụ site nʼamamihe gị ka egbe ji efego nʼelu, 
\q2 gbasaakwa nku ya gaa nʼebe ndịda? 
\q1  
\v 27 Ọ bụ gị nyere ugo iwu ifeli elu 
\q2 ma wuo akwụ ya nʼebe dị elu? 
\q1  
\v 28 Nʼelu nkume dị elu ka ọ na-ebi nọọkwa ọnọdụ abalị; 
\q2 ọwara nkume dị elu bụ ebe e wusiri ike ya. 
\q1  
\v 29 O bụ site nʼebe ahụ 
\q2 ka ọ na-esi enyochapụta ihe ọ ga-eburu. 
\q1  
\v 30 Ụmụ ya na-amịchakwa ọbara, 
\q2 nʼihi na ebe ọ na-aga bụ ebe ọbụla ọ ga-ahụ ihe e gburu egbu.” 
\c 40  
\p  
\v 1 \nd Onyenwe anyị\nd* zara Job sị: 
\q1  
\v 2 “Onye ahụ na-arụso Onye pụrụ ime ihe niile ụka ọ pụrụ ịdọ ya aka na ntị? 
\q2 Ka onye ahụ na-ebo Chineke ebubo zaghachi ya.” 
\p  
\v 3 Mgbe ahụ, Job zaghachiri \nd Onyenwe anyị\nd* sị: 
\q1  
\v 4 “Abụ m onye na-erughị eru. Oleekwanụ ka m ga-esi zaghachi gị? 
\q2 Eji m aka m kpuchie ọnụ m. 
\q1  
\v 5 Ekwuola m mbụ, ma enweghị m ọsịsa ọzọ 
\q2 kwuokwa ugboro abụọ, ma agaghị m ekwukwa ọzọ.” 
\p  
\v 6 Mgbe ahụ, \nd Onyenwe anyị\nd* sitere nʼoke ifufe gwa Job okwu sị: 
\q1  
\v 7 “Kwadoo onwe gị dịka dimkpa; 
\q2 enwere m ajụjụ m ga-ajụ gị, 
\q2 achọkwara m ka i nye m ọsịsa. 
\b  
\q1  
\v 8 “Ị ga-aga nʼihu ikwujọ ikpe ziri ezi m? 
\q2 Ị ga-aga nʼihu maa m ikpe ka ị si otu a bụrụ onye ikpe gaara? 
\q1  
\v 9 Ogwe aka gị ọ dị ike dịka nke Chineke? 
\q2 Olu gị ọ pụrụ ịda ụda dịka nke ya? 
\q1  
\v 10 Were ebube na ịdị ukwuu chọọ onwe gị mma, 
\q2 yikwasịkwa onwe gị nsọpụrụ na ugwu dịka uwe. 
\q1  
\v 11 Wụsa iwe gị dị ọkụ nʼebe ndị mpako niile nọ, 
\q2 weda ha nʼala, 
\q1  
\v 12 lekwasịkwa ndị mpako niile anya mee ha ihe ihere, 
\q2 ma tiriekwa ndị na-emebi iwu ebe ha guzo. 
\q1  
\v 13 Likọta ha niile nʼotu nʼaja, 
\q2 kpuchie ihu ha niile nʼala ili. 
\q1  
\v 14 Mgbe ahụ, mụ onwe m ga-ekwenyere gị, 
\q2 na aka nri nwere ike ịzọpụta gị. 
\b  
\q1  
\v 15 “Lee enyi mmiri anya, 
\q2 bụ nke m kere dịka m si kee gị, 
\q2 ma ihe ọ na-eri bụ ahịhịa dịka ehi. 
\q1  
\v 16 Lee ike dị nʼukwu ya, 
\q2 leekwa ike dị nʼime afọ ya. 
\q1  
\v 17 Ọdụdụ ya ka ọ na-efegharị dịka osisi sida; 
\q2 akwara dị ya nʼahụ ka e jikọtara nke ọma. 
\q1  
\v 18 Ọkpụkpụ ya niile dịka ogidi bronz nwere ụmị, 
\q2 ọkpụkpụ ụkwụ na aka ya dịka okporo igwe. 
\q1  
\v 19 Ya onwe ya bụ otu nʼime ọrụ aka mbụ nke Chineke, 
\q2 ma naanị onye kere ya nwere ike iji mma agha bịa ya nso. 
\q1  
\v 20 Ugwu na-enye ya ihe ọ na-eri. 
\q2 Nʼebe ahụ kwa ka ụmụ anụ ọhịa ndị ọzọ na-anọ egwuri egwu. 
\q1  
\v 21 Ọ na-edina nʼokpuru ahịhịa na-eto nʼakụkụ mmiri, 
\q2 zookwa onwe ya nʼetiti ahịhịa riidi nʼapịtị. 
\q1  
\v 22 Ahịhịa lotus na-eji ndo ya kpuchie ya, 
\q2 osisi pọpla nke dị nʼakụkụ mmiri gbara ya gburugburu. 
\q1  
\v 23 Ọ bụladị mgbe ebili mmiri na-ama, ọ dịghị atụ egwu; 
\q2 ọ na-anọ nwayọọ, nʼagbanyeghị na mmiri Jọdan na-asọpụta na-asọju ya nʼọnụ. 
\q1  
\v 24 Onye pụrụ ijide ya mgbe ọ na-ele anya, 
\q2 maọbụ were ọnya jide ya mapuo ya imi? 
\b  
\c 41  
\q1  
\v 1 “Ị pụrụ iji nko azụ jide Leviatan 
\q2 maọbụ jiri ụdọ kegide ire ya bịada ya? 
\q1  
\v 2 Ị pụrụ ikenye eriri nʼimi ya 
\q2 maọbụ were ngu igwe mapuo agba ya? 
\q1  
\v 3 Ọ ga-arịọ gị arịrịọ ka i meere ya ebere? 
\q2 Ọ ga-eji olu dị nro gwa gị okwu? 
\q1  
\v 4 Ọ ga-ekwe ka gị na ya baa nʼọgbụgba ndụ 
\q2 ka i were ya dịka ohu gị ogologo ndụ ya niile? 
\q1  
\v 5 Ị ga-eji ya gwurie egwu dịka nnụnụ? 
\q2 Maọbụ kee ya eriri nye ya ụmụ agbọghọ nọ nʼụlọ gị? 
\q1  
\v 6 Ndị ahịa ha ga-eji ya zụọ ahịa? 
\q2 Ha ga-eke ya nʼetiti ndị mgbereahịa? 
\q1  
\v 7 Ị pụrụ iji igwe nko mejuo akpụkpọ ahụ ya 
\q2 maọbụ iji ùbe ndị ọkụ azụ dupuo isi ya? 
\q1  
\v 8 Ọ bụrụ na ị tụkwasị ya aka, 
\q2 ị gaghị echefu ọgụ ọ ga-alụso gị. Ị gakwaghị anwa ya ọzọ. 
\q1  
\v 9 Ọ bụ ime ihe nzuzu bụ mmadụ ịgbalị ijide ya. 
\q2 Naanị ilekwasị ya anya na-eyi egwu. 
\q1  
\v 10 Nʼihi nke a, o nweghị onye nwere obi ike ịkpasu ya iwe. 
\q2 Ọ bụ onye pụrụ iguzogide m? 
\q1  
\v 11 Olee onye m ji ụgwọ nke m na-aghaghị ịkwụ? 
\q2 Ihe niile dị nʼokpuru eluigwe bụ nke m. 
\b  
\q1  
\v 12 “Agaghị m akwụsị ikwu ihe banyere ụkwụ na aka Leviatan, 
\q2 na ike ya, na ụdịdị ya mara mma. 
\q1  
\v 13 Onye nwere ike ikpughepụ ihe e ji kpuchie ya ahụ? 
\q2 Onye nwekwara ike ịbanye nʼagba ya apịajiri okpukpu abụọ? 
\q1  
\v 14 Onye pụrụ imeghe ụzọ nke ọnụ ya, 
\q2 nke eze dị oke egwu gbara gburugburu? 
\q1  
\v 15 Azụ ya nwere ọta\f + \fr 41:15 \ft Mpako ya bụ ọta azụ ya\f* ndị e doro nʼusoro 
\q2 nke e mechisịrị ike ka ha rapara nʼahụ ibe ha, 
\q1  
\v 16 nke ọbụla dị ibe ya nso, 
\q2 na ikuku enweghị ike gafee nʼetiti ha. 
\q1  
\v 17 E jikọtara ha ọnụ nke ọma, 
\q2 ha na-ejisi onwe ha ike, enweghị ike ikewa ha. 
\q1  
\v 18 Ìhè na-enwupụta mgbe ọbụla o zere uzere; 
\q2 anya ya abụọ na-achakwa dịka anwụ ụtụtụ. 
\q1  
\v 19 Ire ọkụ na-asọpụta site nʼọnụ ya, 
\q2 icheku ọkụ na-ekepụtakwa nʼọnụ ya. 
\q1  
\v 20 Anwụrụ ọkụ na-esi nʼimi ya na-apụta, 
\q2 dịka ukuru ọkụ nke na-esi nʼime mmiri na-agbọ nʼelu osisi achara.\f + \fr 41:20 \ft Lit. \fqa Riidi\f* 
\q1  
\v 21 Ume ọ na-ekupụta na-afụnwu ọkụ icheku. 
\q2 Ire ọkụ na-esitekwa nʼọnụ ya na-amapụ dịka àkụ. 
\q1  
\v 22 Ike nwere ọnọdụ nʼolu ya, 
\q2 obi ịlọ mmiri na-aga ya nʼihu. 
\q1  
\v 23 Akpụkpọ anụ ahụ ya bụ ihe jikọtara ọnụ nke ọma, 
\q2 ha siri ike na-apụghị inugharị ha. 
\q1  
\v 24 Obi ya dị ike dịka nkume, 
\q2 dịka nkume e ji akwọ ihe. 
\q1  
\v 25 Mgbe o bilitere ọtọ, ndị dike na-atụ oke ụjọ; 
\q2 ha na-alaghachi azụ nʼihi mmagharị ya. 
\q1  
\v 26 O nweghị mma agha ọbụla pụrụ igbochi ya, 
\q2 o nwekwaghị ùbe igwe, maọbụ àkụ maọbụ ihe ọbụla a pịrị ọnụ ya apị nke pụrụ igbochi ya. 
\q1  
\v 27 Nʼebe ọ nọ, igwe dị ka ahịhịa; 
\q2 bronz dịkwa ka osisi rere ure nʼebe ọ nọ. 
\q1  
\v 28 Àkụ adịghị eme ka ọ gbalaga, 
\q2 ịtụ ya nkume dị ka ịtụ ya igbugbo ọka. 
\q1  
\v 29 Mkpọrọ osisi na-adị ya ka ahịhịa ọka, 
\q2 ọ na-achị ọchị na mkpọtụ arụa na-eme. 
\q1  
\v 30 Okpuru afọ ya dị ka ejuju dị nkọ, 
\q2 nke na-ahapụ ụzọ nʼapịtị dịka igwe eji azọcha mkpụrụ ọka site nʼogbe ya. 
\q1  
\v 31 Ọ na-eme mmiri dị ogbu ka ọ gbọọ dịka ite; 
\q2 ọ na-akpagharị oke osimiri ka ọ dị ka mmanụ otite dị nʼite. 
\q1  
\v 32 Ọ na-ahapụ ụfụfụ nʼazụ mgbe ọ na-aga; 
\q2 mmadụ ga-eche na ọ osimiri nwere isi awọ. 
\q1  
\v 33 O nweghị ihe ọzọ dị nʼụwa yiri ya, 
\q2 o nweghị ihe na-emenye ya ụjọ. 
\q1  
\v 34 Ọ na-eleda ndị mpako niile anya. 
\q2 Ọ bụkwa eze nʼebe ndị na-anya isi nọ.” 
\c 42  
\s1 Okwu Job 
\p  
\v 1 Mgbe ahụ, Job zara \nd Onyenwe anyị\nd* sị: 
\q1  
\v 2 “Amara m na ị pụrụ ime ihe niile; 
\q2 ọ dịghị atụmatụ gị nke a pụrụ ikposa. 
\q1  
\v 3 Ị jụrụ sị, ‘Onye bụ onye nke a ji okwu ihe ọmụma na-adịghị na ya na-eme ka atụmatụ m ghara ịpụta ihe?’ 
\q2 Nʼezie, ekwuru m banyere ihe ndị m na-aghọtaghị, 
\q2 ihe ndị dị oke ebube karịa m ịmata. 
\b  
\q1  
\v 4 “Ị sịrị, ‘Gee ntị ugbu a, aga m ekwu okwu; 
\q2 m ga-ajụ gị ajụjụ, 
\q2 gị onwe gị ga-azakwa m.’ 
\q1  
\v 5 Ntị m nụrụ ihe banyere gị 
\q2 ma ugbu a, ejirila m anya abụọ hụ gị. 
\q1  
\v 6 Ya mere, ana m akpọ onwe m asị, 
\q2 na echegharịkwa nʼime ntụ na uzuzu.” 
\s1 Okwu mmechi 
\p  
\v 7 Mgbe \nd Onyenwe anyị\nd* gwasịrị Job okwu, ọ tụgharịrị gwa Elifaz onye Teman okwu sị ya, “Ana m ewesa gị na ndị enyi gị abụọ iwe, nʼihi na ihe unu kwuru banyere m ezighị ezi dịka nke ohu m Job kwuru.  
\v 8 Ugbu a, werenụ oke ehi asaa na ebule asaa, jekwuru ohu m bụ Job ka o jiri ha chụọrọ unu aja nsure ọkụ, ohu m bụ Job ga-ekpekwara unu ekpere. Aga m anabatakwa ekpere ọ ga-ekpe nʼihi unu. Agaghị m alakwa unu nʼiyi nʼihi okwu nzuzu unu. Unu ekwughị ihe ziri ezi banyere m dịka ohu m Job si kwuo.”  
\v 9 Ya mere, Elifaz onye Teman, na Bildad, onye Shu, na Zofa, onye Naaman mere dịka \nd Onyenwe anyị\nd* si nye ha nʼiwu. \nd Onyenwe anyị\nd* nabatakwara ekpere nke Job kpere nʼihi ndị enyi ya. 
\p  
\v 10 Mgbe Job kpesịrị ekpere maka ndị enyi ya, \nd Onyenwe anyị\nd* mekwara ka ọ baa ụba ọzọ. O nyekwara ya okpukpo abụọ nke ihe niile o nwere na mbụ.  
\v 11 Mgbe ahụ, ụmụnne ya ndị ikom na ụmụnne ya ndị inyom, na ndị enyi ya niile bịara soro ya rie oriri nʼụlọ ya, na-akasị ya obi nʼihi iru ụjụ ya niile. Ha kasịkwara ya obi nʼihi ọnwụnwa niile \nd Onyenwe anyị\nd* mere ka ọ bịakwasị ya. Ha niile nʼotu nʼotu nyere ya onyinye ọlaọcha na mgbaaka ọlaedo. 
\p  
\v 12 Mgbe ahụ, \nd Onyenwe anyị\nd* gọziri Job nʼoge ikpeazụ nke ndụ ya karịa ka o si gọzie ya na mbụ. Job nwere puku atụrụ iri na anọ na puku ịnyịnya kamel isii na puku ehi abụọ na otu puku ịnyịnya ibu.  
\v 13 Chineke mekwara ka ọ mụta ụmụ ndị ikom asaa, na ụmụ ndị inyom atọ ọzọ.  
\v 14 Ndị a bụ aha ụmụ ya ndị inyom: nke mbụ bụ Jimaịma, nke abụọ bụ Kezaya, ebe nke atọ bụ Kerin-Hapuk.  
\v 15 Nʼala ahụ niile, o nweghị ụmụ agbọghọ mara mma dịka ụmụ ndị inyom Job ndị a. Job mekwara ka ha bụrụ ndị ga-eso ụmụ ya ndị ikom keta oke nʼihe niile o nwere. 
\p  
\v 16 Job nọgidekwara ndụ narị afọ na iri afọ anọ ọzọ. Ọ hụrụ ụmụ ya, na ụmụ ha ruo ọgbọ nke anọ.  
\v 17 Job nwụrụ mgbe o mere ezigbo agadi, ụbọchị ndụ ya jukwara ya afọ.