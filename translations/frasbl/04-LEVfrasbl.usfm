\v 9 « Ordonne \w à|strong="H1121"\w* \w Aaron|strong="H1121"\w* \w et|strong="H1121"\w* \w à|strong="H1121"\w* \w ses|strong="H1121"\w* \w fils|strong="H1121"\w*, \w en|strong="H1121"\w* disant : \w Voici|strong="H1121"\w* \w la|strong="H1121"\w* loi \w de|strong="H1121"\w* l'holocauste : l'holocauste \w restera|strong="H3498"\w* \w sur|strong="H1121"\w* \w le|strong="H1121"\w* foyer \w de|strong="H1121"\w* l'autel toute \w la|strong="H1121"\w* \w nuit|strong="H1121"\w* jusqu'\w au|strong="H1121"\w* matin, \w et|strong="H1121"\w* \w le|strong="H1121"\w* \w feu|strong="H1121"\w* \w de|strong="H1121"\w* l'autel \w y|strong="H4725"\w* \w sera|strong="H1121"\w* maintenu allumé.
\v 10 \w Le|strong="H5414"\w* prêtre revêtira \w sa|strong="H5414"\w* tunique \w de|strong="H5414"\w* lin, \w et|strong="H3808"\w* \w mettra|strong="H5414"\w* \w des|strong="H5414"\w* caleçons \w de|strong="H5414"\w* lin \w sur|strong="H5414"\w* \w son|strong="H5414"\w* \w corps|strong="H5414"\w* ; \w il|strong="H1931"\w* enlèvera \w les|strong="H5414"\w* cendres \w que|strong="H3808"\w* \w le|strong="H5414"\w* \w feu|strong="H5414"\w* \w a|strong="H3068"\w* consumées \w avec|strong="H3808"\w* l'holocauste \w sur|strong="H5414"\w* l'autel, \w et|strong="H3808"\w* \w les|strong="H5414"\w* déposera près \w de|strong="H5414"\w* l'autel.
\v 11 \w Il|strong="H3068"\w* quittera \w ses|strong="H1121"\w* \w vêtements|strong="H3068"\w* \w et|strong="H1121"\w* \w en|strong="H3068"\w* \w mettra|strong="H3068"\w* d'\w autres|strong="H3068"\w*, \w et|strong="H1121"\w* \w il|strong="H3068"\w* emportera \w les|strong="H3068"\w* cendres hors \w du|strong="H1121"\w* camp \w dans|strong="H3068"\w* \w un|strong="H1121"\w* \w lieu|strong="H3068"\w* pur.
\v 12 \w Le|strong="H3068"\w* \w feu|strong="H3068"\w* \w sur|strong="H3068"\w* l'autel \w sera|strong="H3068"\w* maintenu allumé, \w il|strong="H3068"\w* \w ne|strong="H3068"\w* s'éteindra \w pas|strong="H1696"\w* ; \w et|strong="H3068"\w* \w le|strong="H3068"\w* prêtre \w y|strong="H3068"\w* brûlera \w du|strong="H3068"\w* \w bois|strong="H3068"\w* \w chaque|strong="H3068"\w* matin. \w Il|strong="H3068"\w* \w y|strong="H3068"\w* arrangera l'holocauste, \w et|strong="H3068"\w* \w y|strong="H3068"\w* brûlera \w la|strong="H3068"\w* graisse \w des|strong="H3068"\w* \w sacrifices|strong="H3068"\w* \w de|strong="H1696"\w* paix.
\v 13 \w Le|strong="H3068"\w* \w feu|strong="H3068"\w* \w sera|strong="H3068"\w* \w continuellement|strong="H8548"\w* maintenu allumé \w sur|strong="H3068"\w* \w l|strong="H4503"\w*'autel ; \w il|strong="H3068"\w* \w ne|strong="H3068"\w* s'éteindra \w pas|strong="H3068"\w*.
\p 
\v 14 \w Voici|strong="H3068"\w* \w la|strong="H6213"\w* loi \w de|strong="H6213"\w* \w l|strong="H4503"\w*'\w offrande|strong="H4503"\w* \w de|strong="H6213"\w* gâteau : \w les|strong="H3068"\w* \w fils|strong="H6213"\w* d'\w Aaron|strong="H3068"\w* \w l|strong="H4503"\w*'\w offriront|strong="H7126"\w* \w devant|strong="H7126"\w* \w le|strong="H3068"\w* \w SEIGNEUR|strong="H3068"\w*, \w devant|strong="H7126"\w* \w l|strong="H4503"\w*'autel.
\v 15 \w Il|strong="H3068"\w* \w y|strong="H3068"\w* \w prendra|strong="H3068"\w* \w une|strong="H6213"\w* poignée \w de|strong="H1121"\w* \w la|strong="H6213"\w* fleur \w de|strong="H1121"\w* farine \w de|strong="H1121"\w* l'\w offrande|strong="H6213"\w* \w de|strong="H1121"\w* gâteau, \w et|strong="H1121"\w* \w de|strong="H1121"\w* \w son|strong="H6213"\w* huile, \w et|strong="H1121"\w* \w tout|strong="H3632"\w* l'\w encens|strong="H6999"\w* \w qui|strong="H3068"\w* \w est|strong="H3068"\w* \w sur|strong="H3068"\w* l'\w offrande|strong="H6213"\w* \w de|strong="H1121"\w* gâteau, \w et|strong="H1121"\w* \w il|strong="H3068"\w* \w la|strong="H6213"\w* \w brûlera|strong="H6999"\w* \w sur|strong="H3068"\w* l'autel \w pour|strong="H6213"\w* \w une|strong="H6213"\w* agréable odeur, \w comme|strong="H3068"\w* \w sa|strong="H6213"\w* \w portion|strong="H3068"\w* mémoriale, \w au|strong="H6213"\w* \w SEIGNEUR|strong="H3068"\w*.
\v 16 \w Ce|strong="H3605"\w* \w qui|strong="H3548"\w* \w en|strong="H3548"\w* \w restera|strong="H3808"\w*, \w Aaron|strong="H3548"\w* \w et|strong="H3548"\w* \w ses|strong="H3605"\w* \w fils|strong="H3548"\w* \w le|strong="H1961"\w* \w mangeront|strong="H3548"\w*. \w Il|strong="H3548"\w* \w sera|strong="H1961"\w* \w mangé|strong="H3808"\w* \w sans|strong="H3808"\w* levain \w dans|strong="H3808"\w* \w un|strong="H4503"\w* \w lieu|strong="H1961"\w* saint. \w Ils|strong="H1961"\w* \w le|strong="H1961"\w* \w mangeront|strong="H3548"\w* \w dans|strong="H3808"\w* \w le|strong="H1961"\w* parvis \w de|strong="H1961"\w* \w la|strong="H1961"\w* \w tente|strong="H1961"\w* \w de|strong="H1961"\w* \w la|strong="H1961"\w* Rencontre.
\v 17 \w Il|strong="H3068"\w* \w ne|strong="H3068"\w* \w sera|strong="H3068"\w* \w pas|strong="H1696"\w* cuit \w avec|strong="H1696"\w* \w du|strong="H3068"\w* levain. \w Je|strong="H3068"\w* l'\w ai|strong="H3068"\w* \w donné|strong="H3068"\w* \w comme|strong="H3068"\w* \w leur|strong="H3068"\w* \w part|strong="H3068"\w* \w de|strong="H1696"\w* \w mes|strong="H1696"\w* offrandes \w faites|strong="H1696"\w* \w par|strong="H3068"\w* \w le|strong="H3068"\w* \w feu|strong="H3068"\w*. C'\w est|strong="H3068"\w* \w une|strong="H3068"\w* \w chose|strong="H3068"\w* \w très|strong="H3068"\w* sainte, \w tout|strong="H1696"\w* \w comme|strong="H3068"\w* \w le|strong="H3068"\w* \w sacrifice|strong="H3068"\w* \w pour|strong="H3068"\w* \w le|strong="H3068"\w* \w péché|strong="H3068"\w* \w et|strong="H3068"\w* \w le|strong="H3068"\w* \w sacrifice|strong="H3068"\w* \w de|strong="H1696"\w* culpabilité.
\v 18 \w Tout|strong="H6440"\w* mâle \w parmi|strong="H6440"\w* \w les|strong="H3068"\w* \w enfants|strong="H1121"\w* \w d|strong="H6440"\w*'\w Aaron|strong="H3068"\w* \w en|strong="H3068"\w* \w mangera|strong="H3068"\w*. \w C|strong="H1931"\w*'\w est|strong="H3068"\w* \w leur|strong="H3068"\w* \w part|strong="H6440"\w* perpétuelle \w pour|strong="H6440"\w* \w vos|strong="H6440"\w* \w générations|strong="H3068"\w*, \w sur|strong="H6440"\w* \w les|strong="H3068"\w* offrandes \w du|strong="H1121"\w* \w SEIGNEUR|strong="H6440"\w* \w faites|strong="H1696"\w* \w par|strong="H3068"\w* \w le|strong="H6440"\w* \w feu|strong="H3068"\w*. Quiconque \w les|strong="H3068"\w* touchera \w sera|strong="H3068"\w* \w saint|strong="H6944"\w*. »
\p 
\v 19 \w Le|strong="H4725"\w* SEIGNEUR parla \w à|strong="H2398"\w* Moïse, \w en|strong="H3548"\w* disant :
\v 20 « Voici l'offrande d'\w Aaron|strong="H6942"\w* \w et|strong="H5921"\w* \w de|strong="H5921"\w* \w ses|strong="H5921"\w* fils, qu'\w ils|strong="H5921"\w* offriront \w au|strong="H1818"\w* SEIGNEUR \w le|strong="H4725"\w* \w jour|strong="H5921"\w* \w où|strong="H4725"\w* \w il|strong="H5921"\w* \w sera|strong="H5060"\w* oint : \w un|strong="H5060"\w* dixième d'épha\f + \fr 6.20 \ft 1 épha représente environ 22 litres.\f* \w de|strong="H5921"\w* fleur \w de|strong="H5921"\w* farine \w comme|strong="H6942"\w* offrande \w de|strong="H5921"\w* gâteau perpétuelle, \w la|strong="H5921"\w* moitié \w le|strong="H4725"\w* matin, \w et|strong="H5921"\w* \w la|strong="H5921"\w* moitié \w le|strong="H4725"\w* soir.
\v 21 \w Elle|strong="H4325"\w* \w sera|strong="H1310"\w* préparée \w à|strong="H4325"\w* \w la|strong="H1310"\w* poêle \w avec|strong="H4325"\w* \w de|strong="H3627"\w* l'huile. \w Tu|strong="H3627"\w* l'apporteras bien imbibée. \w Tu|strong="H3627"\w* offriras l'offrande \w de|strong="H3627"\w* gâteau \w en|strong="H4325"\w* \w morceaux|strong="H2789"\w* cuits, \w pour|strong="H4325"\w* une agréable odeur \w au|strong="H7665"\w* SEIGNEUR.
\v 22 \w Le|strong="H3605"\w* \w prêtre|strong="H3548"\w* oint \w qui|strong="H3548"\w* \w lui|strong="H1931"\w* \w succédera|strong="H3548"\w* \w parmi|strong="H2145"\w* \w ses|strong="H3605"\w* \w fils|strong="H2145"\w* l'\w offrira|strong="H3548"\w*. \w Par|strong="H6944"\w* \w une|strong="H3548"\w* loi perpétuelle, \w elle|strong="H1931"\w* \w sera|strong="H1931"\w* \w entièrement|strong="H1931"\w* brûlée \w pour|strong="H6944"\w* \w le|strong="H3605"\w* SEIGNEUR.
\v 23 \w Toute|strong="H3605"\w* offrande \w de|strong="H2403"\w* gâteau d'\w un|strong="H2403"\w* prêtre \w sera|strong="H1818"\w* entièrement \w brûlée|strong="H8313"\w*. \w Elle|strong="H3808"\w* \w ne|strong="H3808"\w* \w sera|strong="H1818"\w* \w pas|strong="H3808"\w* mangée. »
\p 
\v 24 Le SEIGNEUR parla à Moïse, en disant :
\v 25 « Parle à Aaron et à ses fils, en disant : Voici la loi du sacrifice pour le péché : dans le lieu où l'on égorge l'holocauste, le sacrifice pour le péché sera égorgé devant le SEIGNEUR. C'est une chose très sainte.
\v 26 Le prêtre qui l'offre pour le péché le mangera. Il sera mangé dans un lieu saint, dans le parvis de la tente de la Rencontre.
\v 27 Quiconque touchera sa chair sera saint. S'il en rejaillit du sang sur un vêtement, tu laveras ce qui en \w a|strong="H3068"\w* été aspergé dans un lieu saint.
\v 28 Mais le vase de terre dans lequel il aura été bouilli sera brisé ; et s'il \w a|strong="H3068"\w* été bouilli dans un vase de bronze, celui-ci sera récuré et rincé dans l'eau.
\v 29 Tout mâle parmi les prêtres en mangera. C'est une chose très sainte.
\v 30 Aucun sacrifice pour le péché, dont une partie du sang est apportée dans la tente de la Rencontre pour faire l'expiation dans le lieu saint, ne sera mangé. Il sera brûlé au feu.
\c 7
\p 
