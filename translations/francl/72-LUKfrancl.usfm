\q1  
\q1
\v 49 \w Parce|strong="G2532"\w* \w qu|strong="G3754"\w*’\w il|strong="G2532"\w* \w a|strong="G2532"\w* \w fait|strong="G4160"\w* \w en|strong="G2532"\w* \w moi|strong="G1473"\w* \w de|strong="G2532"\w* \w grandes|strong="G3173"\w* \w choses|strong="G3588"\w*, \w Celui|strong="G3588"\w* \w qui|strong="G3588"\w* \w est|strong="G3588"\w* \w puissant|strong="G1415"\w*,  
\q1 \w Et|strong="G2532"\w* \w dont|strong="G3588"\w* \qt le nom est saint\qt*,   
\q1
\v 50 \qt Et dont la miséricorde s’étend d’âge en âge,\qt*  
\q1 \qt Sur ceux qui le craignent.\qt*   
\q1  
\q1
\v 51 \w Il|strong="G1722"\w* \w a|strong="G1722"\w* \w déployé|strong="G4160"\w* \w la|strong="G1722"\w* \w force|strong="G2904"\w* \w de|strong="G1722"\w* \w son|strong="G1722"\w* \w bras|strong="G1023"\w* ;  
