\p 
\v 7 \w Jacob|strong="H3290"\w* \w was|strong="H3290"\w* \w very|strong="H1980"\w* afraid \w and|strong="H3967"\w* worried. \w So|strong="H1980"\w* \w he|strong="H1980"\w* divided \w the|strong="H7725"\w* \w people|strong="H1571"\w* \w who|strong="H4397"\w* \w were|strong="H3290"\w* \w with|strong="H5973"\w* \w him|strong="H7725"\w* \w into|strong="H1980"\w* \w two|strong="H1980"\w* groups. \w He|strong="H1980"\w* \w also|strong="H1571"\w* divided \w the|strong="H7725"\w* sheep \w and|strong="H3967"\w* goats, \w the|strong="H7725"\w* cattle, \w and|strong="H3967"\w* \w the|strong="H7725"\w* camels, \w into|strong="H1980"\w* \w two|strong="H1980"\w* groups.
