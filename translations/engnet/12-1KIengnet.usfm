\v 5  \w Then|strong="H4428"\w* \w Jehoshaphat|strong="H3092"\w* \w added|strong="H3117"\w*, “\w First|strong="H3117"\w* \w seek|strong="H1875"\w* \w an|strong="H3068"\w* \w oracle|strong="H4994"\w* \w from|strong="H3478"\w* \w the|strong="H3068"\w* \nd \+w Lord|strong="H3068"\+w*\nd*.”  
