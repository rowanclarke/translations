\p
\v 25 \w Salomón|strong="H8010"\w* poseía caballerizas \w para|strong="H1961"\w* 4.000 \w caballos|strong="H5483"\w* y carruajes, y 12.000 \w jinetes|strong="H6571"\w*, \w los|strong="H5973"\w* cuales instaló \w en|strong="H5973"\w* las \w ciudades|strong="H5892"\w* \w que|strong="H1961"\w* \w tenía|strong="H1961"\w* \w para|strong="H1961"\w* sus carruajes y \w en|strong="H5973"\w* Jerusalén \w cerca|strong="H5973"\w* \w del|strong="H5973"\w* \w rey|strong="H4428"\w*.  
\v 26 Dominaba \w sobre|strong="H4480"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w reyes|strong="H4428"\w* \w desde|strong="H4480"\w* \w el|strong="H3605"\w* \w río|strong="H5104"\w* Éufrates \w hasta|strong="H5704"\w* \w la|strong="H3605"\w* tierra \w de|strong="H4480"\w* \w los|strong="H3605"\w* \w filisteos|strong="H6430"\w* \w y|strong="H5704"\w* \w hasta|strong="H5704"\w* \w la|strong="H3605"\w* frontera \w de|strong="H4480"\w* \w Egipto|strong="H4714"\w*.   
\p
\v 27 El \w rey|strong="H4428"\w* acumuló \w plata|strong="H3701"\w* en Jerusalén en \w abundancia|strong="H7230"\w* como las piedras, y madera \w de|strong="H5414"\w* cedro como los sicómoros \w de|strong="H5414"\w* la Sefela.  
\v 28 De \w Egipto|strong="H4714"\w* y de \w todas|strong="H3605"\w* las tierras se importaban \w caballos|strong="H5483"\w* para \w Salomón|strong="H8010"\w*.   
\p
\v 29 \w El|strong="H5921"\w* resto \w de|strong="H5921"\w* \w los|strong="H1992"\w* \w hechos|strong="H1697"\w* \w de|strong="H5921"\w* \w Salomón|strong="H8010"\w*, \w los|strong="H1992"\w* \w primeros|strong="H7223"\w* \w y|strong="H5921"\w* \w los|strong="H1992"\w* últimos, ¿\w no|strong="H3808"\w* están \w escritos|strong="H3789"\w* \w en|strong="H5921"\w* \w las|strong="H1992"\w* crónicas \w del|strong="H5921"\w* \w profeta|strong="H5030"\w* Natán, \w en|strong="H5921"\w* \w la|strong="H5921"\w* profecía \w de|strong="H5921"\w* \w Ahías|strong="H3379"\w* \w silonita|strong="H7888"\w*, \w y|strong="H5921"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* visión \w del|strong="H5921"\w* \w vidente|strong="H2374"\w* Iddo \w contra|strong="H5921"\w* \w Jeroboam|strong="H3379"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Nabat|strong="H5028"\w*?  
\v 30 \w Salomón|strong="H8010"\w* \w reinó|strong="H4427"\w* 40 \w años|strong="H8141"\w* \w en|strong="H5921"\w* Jerusalén \w sobre|strong="H5921"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w*.  
\v 31 \w Salomón|strong="H8010"\w* descansó \w con|strong="H5973"\w* sus antepasados, y lo \w sepultaron|strong="H6912"\w* \w en|strong="H5973"\w* la \w Ciudad|strong="H5892"\w* \w de|strong="H8478"\w* su padre \w David|strong="H1732"\w*. \w Reinó|strong="H4427"\w* \w en|strong="H5973"\w* su \w lugar|strong="H8478"\w* su \w hijo|strong="H1121"\w* \w Roboam|strong="H7346"\w*.   
\c 10  
\s1 División del reino  
\p
\v 1 \w Entonces|strong="H3588"\w* \w Roboam|strong="H7346"\w* \w fue|strong="H3212"\w* \w a|strong="H3068"\w* Siquem, \w porque|strong="H3588"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* \w había|strong="H3588"\w* \w ido|strong="H3212"\w* \w a|strong="H3068"\w* Siquem \w para|strong="H3588"\w* proclamarlo \w rey|strong="H4427"\w*.   
\p
\v 2 \w Sucedió|strong="H1961"\w* \w que|strong="H1931"\w* \w cuando|strong="H1961"\w* \w lo|strong="H1931"\w* \w oyó|strong="H8085"\w* \w Jeroboam|strong="H3379"\w*, \w hijo|strong="H1121"\w* \w de|strong="H6440"\w* \w Nabat|strong="H5028"\w*, \w quien|strong="H1931"\w* \w aún|strong="H7725"\w* \w estaba|strong="H1961"\w* en \w Egipto|strong="H4714"\w*, adonde \w huyó|strong="H1272"\w* \w de|strong="H6440"\w* \w la|strong="H1931"\w* \w presencia|strong="H6440"\w* del \w rey|strong="H4428"\w* \w Salomón|strong="H8010"\w*, \w Jeroboam|strong="H3379"\w* regresó \w de|strong="H6440"\w* \w Egipto|strong="H4714"\w*.   
\p
\v 3 Mandaron \w a|strong="H3068"\w* llamarlo. \w Jeroboam|strong="H3379"\w* llegó con \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* para \w hablar|strong="H1696"\w* \w a|strong="H3068"\w* \w Roboam|strong="H7346"\w* y \w dijo|strong="H1696"\w*:  
\v 4 Tu padre \w agravó|strong="H7186"\w* nuestro \w yugo|strong="H5923"\w*. \w Ahora|strong="H6258"\w* \w pues|strong="H6258"\w*, busca \w que|strong="H6258"\w* \w la|strong="H5921"\w* \w dura|strong="H7186"\w* \w servidumbre|strong="H5656"\w* \w de|strong="H5921"\w* tu padre \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w pesado|strong="H3515"\w* \w yugo|strong="H5923"\w* \w que|strong="H6258"\w* \w nos|strong="H5921"\w* \w impuso|strong="H5414"\w* sea \w más|strong="H5921"\w* llevadero, \w y|strong="H5921"\w* \w te|strong="H5921"\w* \w serviremos|strong="H5647"\w*.   
\p
\v 5 \w Y|strong="H3068"\w* les \w respondió|strong="H7725"\w*: ¡\w Vuelvan|strong="H7725"\w* \w a|strong="H3068"\w* mí \w dentro|strong="H5750"\w* \w de|strong="H5750"\w* \w tres|strong="H7969"\w* \w días|strong="H3117"\w*! \w Y|strong="H3068"\w* el \w pueblo|strong="H5971"\w* \w se|strong="H5971"\w* retiró.   
\p
\v 6 El \w rey|strong="H4428"\w* \w Roboam|strong="H7346"\w* consultó \w a|strong="H3068"\w* \w los|strong="H1961"\w* \w ancianos|strong="H2205"\w* \w que|strong="H5971"\w* \w estuvieron|strong="H1961"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* su padre \w Salomón|strong="H8010"\w* \w cuando|strong="H1961"\w* \w estaba|strong="H1961"\w* \w vivo|strong="H2416"\w*: ¿\w Cómo|strong="H1961"\w* aconsejan \w que|strong="H5971"\w* \w responda|strong="H7725"\w* \w a|strong="H3068"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w*?   
\p
\v 7 \w Y|strong="H3068"\w* le \w respondieron|strong="H1696"\w*: \w Si|strong="H1961"\w* muestras \w buena|strong="H2896"\w* voluntad \w a|strong="H3068"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w*, \w los|strong="H3605"\w* complaces y les hablas \w buenas|strong="H2896"\w* \w palabras|strong="H1697"\w*, \w serán|strong="H1961"\w* tus esclavos \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w días|strong="H3117"\w*.   
\p
\v 8 Pero \add Roboam\add* despreció el \w consejo|strong="H6098"\w* que los \w ancianos|strong="H2205"\w* le dieron, y consultó \w a|strong="H3068"\w* los jóvenes que crecieron con él y \w estaban|strong="H5975"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* él.  
\v 9 \w Y|strong="H3068"\w* \w les|strong="H5921"\w* preguntó: ¿\w Qué|strong="H4100"\w* aconsejan ustedes \w que|strong="H4100"\w* \w respondamos|strong="H7725"\w* \w a|strong="H3068"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w* \w que|strong="H4100"\w* \w me|strong="H4480"\w* \w habló|strong="H1696"\w*: \w Alivia|strong="H7043"\w* \w el|strong="H5921"\w* \w yugo|strong="H5923"\w* \w que|strong="H4100"\w* tu padre \w impuso|strong="H5414"\w* \w sobre|strong="H5921"\w* \w nosotros|strong="H5921"\w*?   
\p
\v 10 \w Los|strong="H5921"\w* jóvenes \w que|strong="H5921"\w* crecieron \w con|strong="H5921"\w* \w él|strong="H5921"\w* \w le|strong="H5921"\w* \w respondieron|strong="H1696"\w*: \w Dirás|strong="H1696"\w* \w al|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w que|strong="H5921"\w* \w te|strong="H5921"\w* \w habló|strong="H1696"\w*: Tu padre hizo pesado nuestro \w yugo|strong="H5923"\w*. Tú, \w pues|strong="H3513"\w*, \w alivia|strong="H7043"\w* nuestro \w yugo|strong="H5923"\w*. \w Les|strong="H5921"\w* \w dirás|strong="H1696"\w*: \w Mi|strong="H5921"\w* meñique \w es|strong="H3541"\w* \w más|strong="H5921"\w* grueso \w que|strong="H5921"\w* \w la|strong="H5921"\w* cintura \w de|strong="H5921"\w* \w mi|strong="H5921"\w* padre.  
\v 11 \w De|strong="H5921"\w* modo \w que|strong="H6258"\w*, \w si|strong="H5921"\w* \w mi|strong="H5921"\w* padre \w les|strong="H5921"\w* impuso un \w yugo|strong="H5923"\w* \w pesado|strong="H3515"\w*, yo \w añadiré|strong="H3254"\w* \w a|strong="H3068"\w* su \w yugo|strong="H5923"\w*. \w Mi|strong="H5921"\w* padre \w los|strong="H5921"\w* castigó \w con|strong="H5921"\w* azotes, pero yo, \w con|strong="H5921"\w* escorpiones.   
\p
\v 12 \w Al|strong="H4428"\w* tercer \w día|strong="H3117"\w* \w Jeroboam|strong="H3379"\w* y \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* fueron \w a|strong="H3068"\w* \w Roboam|strong="H7346"\w*, tal como \w el|strong="H3605"\w* \w rey|strong="H4428"\w* les \w habló|strong="H1696"\w*: \w Vuelvan|strong="H7725"\w* \w a|strong="H3068"\w* mí \w al|strong="H4428"\w* tercer \w día|strong="H3117"\w*.   
\p
\v 13 El \w rey|strong="H4428"\w* les \w respondió|strong="H6030"\w* \w duramente|strong="H7186"\w*, pues el \w rey|strong="H4428"\w* \w Roboam|strong="H7346"\w* menospreció el \w consejo|strong="H6098"\w* de los \w ancianos|strong="H2205"\w*.  
\v 14 \w Les|strong="H5921"\w* \w habló|strong="H1696"\w* \w de|strong="H5921"\w* acuerdo \w con|strong="H5921"\w* \w el|strong="H5921"\w* \w consejo|strong="H6098"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* jóvenes: \w Mi|strong="H5921"\w* padre hizo pesado su \w yugo|strong="H5923"\w*, pero yo \w añadiré|strong="H3254"\w* \w a|strong="H3068"\w* \w él|strong="H5921"\w*. \w Mi|strong="H5921"\w* padre \w los|strong="H5921"\w* castigó \w con|strong="H5921"\w* azotes, pero yo, \w con|strong="H5921"\w* escorpiones.   
\p
\v 15 \w Así|strong="H3588"\w* \w que|strong="H3588"\w* \w el|strong="H5973"\w* \w rey|strong="H4428"\w* \w no|strong="H3808"\w* \w escuchó|strong="H8085"\w* \w al|strong="H4428"\w* \w pueblo|strong="H5971"\w*, \w porque|strong="H3588"\w* \w era|strong="H1961"\w* \w designio|strong="H1697"\w* \w de|strong="H3588"\w* \nd ʼElohim\nd*, \w para|strong="H4616"\w* \w que|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* cumpliera \w su|strong="H3588"\w* \w Palabra|strong="H1697"\w* \w dicha|strong="H1696"\w* \w por|strong="H3588"\w* \w medio|strong="H3027"\w* \w de|strong="H3588"\w* \w Ahías|strong="H3379"\w* \w silonita|strong="H7888"\w* \w a|strong="H3068"\w* \w Jeroboam|strong="H3379"\w*, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* \w Nabat|strong="H5028"\w*.   
\p
\v 16 \w Cuando|strong="H3588"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* \w vio|strong="H7200"\w* \w que|strong="H3588"\w* \w el|strong="H3588"\w* \w rey|strong="H4428"\w* \w no|strong="H3808"\w* \w los|strong="H1992"\w* escucharía \w ni|strong="H3808"\w* \w les|strong="H1992"\w* pondría atención, \w respondió|strong="H7725"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w*: ¿\w Qué|strong="H3588"\w* \w parte|strong="H2506"\w* tenemos \w en|strong="H3588"\w* \w David|strong="H1732"\w*? ¡\w No|strong="H3808"\w* tenemos \w herencia|strong="H5159"\w* \w con|strong="H3588"\w* \w el|strong="H3588"\w* \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* \w Isaí|strong="H3448"\w*! ¡\w Israel|strong="H3478"\w*, \w cada|strong="H3605"\w* uno \w a|strong="H3068"\w* \w sus|strong="H1992"\w* tiendas! ¡\w David|strong="H1732"\w*, cuida \w ahora|strong="H6258"\w* tu propia \w casa|strong="H1004"\w*!  
\p \w Y|strong="H3068"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* \w se|strong="H3808"\w* retiró \w a|strong="H3068"\w* \w sus|strong="H1992"\w* tiendas.  
\v 17 Pero \w Roboam|strong="H7346"\w* \w reinó|strong="H4427"\w* \w sobre|strong="H5921"\w* \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w que|strong="H5921"\w* \w vivían|strong="H3427"\w* \w en|strong="H5921"\w* \w las|strong="H5921"\w* \w ciudades|strong="H5892"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*.   
\p
\v 18 \w Después|strong="H5921"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w Roboam|strong="H7346"\w* \w envió|strong="H7971"\w* \w a|strong="H3068"\w* Adoram, quien estaba \w a|strong="H3068"\w* cargo \w del|strong="H5921"\w* \w tributo|strong="H4522"\w* laboral. Pero \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w lo|strong="H5921"\w* apedrearon, \w y|strong="H5921"\w* \w murió|strong="H4191"\w*. Entonces \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w Roboam|strong="H7346"\w* \w se|strong="H5921"\w* apresuró, \w subió|strong="H5927"\w* \w en|strong="H5921"\w* su carroza \w y|strong="H5921"\w* \w huyó|strong="H5127"\w* \w a|strong="H3068"\w* Jerusalén.  
\v 19 \w De|strong="H5704"\w* \w esta|strong="H2088"\w* manera \w Israel|strong="H3478"\w* se rebeló \w contra|strong="H3478"\w* la \w casa|strong="H1004"\w* \w de|strong="H5704"\w* \w David|strong="H1732"\w* \w hasta|strong="H5704"\w* \w hoy|strong="H3117"\w*.   
\c 11  
\s1 Reinado de Roboam en Judá  
\p
\v 1 Cuando \w Roboam|strong="H7346"\w* llegó \w a|strong="H3068"\w* Jerusalén congregó \w a|strong="H3068"\w* 180.000 \w guerreros|strong="H6213"\w* escogidos \w de|strong="H5973"\w* las \w casas|strong="H1004"\w* \w de|strong="H5973"\w* \w Judá|strong="H3063"\w* y \w de|strong="H5973"\w* \w Benjamín|strong="H1144"\w* \w para|strong="H5973"\w* luchar \w contra|strong="H5973"\w* \w Israel|strong="H3478"\w* y restituir su \w reino|strong="H4467"\w*.   
\p
\v 2 Pero la \w Palabra|strong="H1697"\w* \w de|strong="H1697"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* llegó \w a|strong="H3068"\w* \w Semaías|strong="H8098"\w*, varón \w de|strong="H1697"\w* \nd ʼElohim\nd*:  
\v 3 \wj Habla \+w a|strong="H3068"\+w* \+w Roboam|strong="H7346"\+w*, \+w hijo|strong="H1121"\+w* \+w de|strong="H1121"\+w* \+w Salomón|strong="H8010"\+w*, \+w rey|strong="H4428"\+w* \+w de|strong="H1121"\+w* \+w Judá|strong="H3063"\+w*, y \+w a|strong="H3068"\+w* \+w todos|strong="H3605"\+w* \+w los|strong="H1121"\+w* israelitas \+w que|strong="H1121"\+w* estén en \+w Judá|strong="H3063"\+w* y \+w Benjamín|strong="H1144"\+w*: \wj*  
\v 4 \wj \+nd \+w Yavé|strong="H3068"\+w*\+nd* dijo: \+w No|strong="H3808"\+w* suban \+w ni|strong="H3808"\+w* luchen \+w contra|strong="H5973"\+w* sus hermanos. Regrese \+w cada|strong="H1697"\+w* uno \+w a|strong="H3068"\+w* \+w su|strong="H3588"\+w* \+w casa|strong="H1004"\+w*, \+w porque|strong="H3588"\+w* \+w Yo|strong="H3588"\+w* hice \+w esto|strong="H2088"\+w*.\wj*  
\p \w Y|strong="H3068"\w* ellos \w escucharon|strong="H8085"\w* \w la|strong="H3588"\w* \w Palabra|strong="H1697"\w* \w de|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*. Regresaron \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w salieron|strong="H5927"\w* \w contra|strong="H5973"\w* \w Jeroboam|strong="H3379"\w*.   
\p
\v 5 \w Roboam|strong="H7346"\w* vivió en Jerusalén y \w edificó|strong="H1129"\w* \w ciudades|strong="H5892"\w* para la defensa en \w Judá|strong="H3063"\w*.  
\v 6 \w Edificó|strong="H1129"\w* Belén, Etam, Tecoa,  
\v 7 Bet-sur, Soco, Adulam,  
\v 8 Gat, \w Maresa|strong="H4762"\w*, Zif,  
\v 9 Adoraim, Laquis, \w Azeca|strong="H5825"\w*,  
\v 10 Zora, Ajalón y \w Hebrón|strong="H2275"\w*, \w ciudades|strong="H5892"\w* fortificadas que están en \w Judá|strong="H3063"\w* y \w Benjamín|strong="H1144"\w*.  
\v 11 También reforzó las fortalezas. Colocó en ellas comandantes, almacenes \w de|strong="H5057"\w* alimentos, \w aceite|strong="H8081"\w* y \w vino|strong="H3196"\w*.  
\v 12 En \w cada|strong="H3605"\w* \w ciudad|strong="H5892"\w* puso \w escudos|strong="H6793"\w* y \w lanzas|strong="H7420"\w*. Las reforzó muchísimo. \w Así|strong="H2388"\w* \w retuvo|strong="H2388"\w* \w a|strong="H3068"\w* \w Judá|strong="H3063"\w* y \w Benjamín|strong="H1144"\w*.   
\p
\v 13 \w Los|strong="H3605"\w* \w sacerdotes|strong="H3548"\w* \w y|strong="H5921"\w* \w levitas|strong="H3881"\w* \w que|strong="H5921"\w* estaban \w en|strong="H5921"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* \w se|strong="H5921"\w* presentaron \w a|strong="H3068"\w* \add Roboam\add*,  
\v 14 \w porque|strong="H3588"\w* \w los|strong="H1121"\w* \w levitas|strong="H3881"\w* abandonaron sus campos \w y|strong="H3588"\w* posesiones, \w y|strong="H3588"\w* \w fueron|strong="H3212"\w* \w a|strong="H3068"\w* \w Judá|strong="H3063"\w* \w y|strong="H3588"\w* \w a|strong="H3068"\w* Jerusalén. (\w Pues|strong="H3588"\w* \w Jeroboam|strong="H3379"\w* \w y|strong="H3588"\w* sus \w hijos|strong="H1121"\w* \w los|strong="H1121"\w* destituyeron del ministerio \w como|strong="H3588"\w* sacerdotes \w de|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*,  
\v 15 por cuanto \w él|strong="H6213"\w* nombró sus propios \w sacerdotes|strong="H3548"\w* para los lugares \w altos|strong="H1116"\w*, los que actuaban como demonios y los \w becerros|strong="H5695"\w* que \w hizo|strong="H6213"\w*.)   
\p
\v 16 \w Aquellos|strong="H3605"\w* \w de|strong="H5414"\w* \w todas|strong="H3605"\w* las \w tribus|strong="H7626"\w* \w de|strong="H5414"\w* \w Israel|strong="H3478"\w* \w que|strong="H3605"\w* dedicaron su \w corazón|strong="H3824"\w* \w a|strong="H3068"\w* buscar \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w* ʼElohim\nd* \w de|strong="H5414"\w* \w Israel|strong="H3478"\w*, siguieron \w a|strong="H3068"\w* \add los sacerdotes y levitas\add* hasta Jerusalén \w para|strong="H5414"\w* ofrecer \w sacrificios|strong="H2076"\w* \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \w el|strong="H3605"\w* \nd ʼElohim\nd* \w de|strong="H5414"\w* sus antepasados.  
