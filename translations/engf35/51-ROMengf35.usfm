\p
\v 23 \w Now|strong="G1161"\w* \w it|strong="G3754"\w* \w was|strong="G3748"\w* \w not|strong="G3756"\w* \w only|strong="G3440"\w* \w for|strong="G3754"\w* \w his|strong="G1223"\w* \w sake|strong="G1223"\w* \w that|strong="G3754"\w* \w it|strong="G3754"\w* \w was|strong="G3748"\w* \w written|strong="G1125"\w* \w that|strong="G3754"\w* \w it|strong="G3754"\w* \w was|strong="G3748"\w* \w credited|strong="G3049"\w* \w to|strong="G3756"\w* \w him|strong="G1125"\w*,  
