\v 13 \w Ellos|strong="H3027"\w* le respondieron: \w No|strong="H3808"\w*, solo \w te|strong="H4480"\w* ataremos \w y|strong="H3588"\w* \w te|strong="H4480"\w* entregaremos \w en|strong="H4480"\w* las \w manos|strong="H3027"\w* \w de|strong="H4480"\w* \w ellos|strong="H3027"\w*, \w pero|strong="H3588"\w* \w de|strong="H4480"\w* seguro \w no|strong="H3808"\w* \w te|strong="H4480"\w* \w mataremos|strong="H4191"\w*. \w Entonces|strong="H3588"\w* \w lo|strong="H3808"\w* ataron \w con|strong="H4480"\w* \w dos|strong="H8147"\w* \w cuerdas|strong="H5688"\w* \w nuevas|strong="H2319"\w* \w y|strong="H3588"\w* le ordenaron salir \w de|strong="H4480"\w* \w la|strong="H3588"\w* \w peña|strong="H5553"\w*.
\v 14 \w Cuando|strong="H5704"\w* \w llegó|strong="H5704"\w* \w a|strong="H3068"\w* \w Lehi|strong="H3896"\w*, \w al|strong="H5921"\w* verlo \w los|strong="H5921"\w* \w filisteos|strong="H6430"\w* gritaron. Entonces \w el|strong="H1931"\w* \w Espíritu|strong="H7307"\w* \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w vino|strong="H1961"\w* poderosamente \w sobre|strong="H5921"\w* \w él|strong="H1931"\w*, \w de|strong="H5921"\w* tal modo \w que|strong="H1931"\w* \w las|strong="H5921"\w* \w cuerdas|strong="H5688"\w* \w que|strong="H1931"\w* \w estaban|strong="H1961"\w* \w en|strong="H5921"\w* \w sus|strong="H1931"\w* \w brazos|strong="H2220"\w* \w fueron|strong="H1961"\w* \w como|strong="H1961"\w* \w lino|strong="H6593"\w* \w quemado|strong="H1197"\w* \w al|strong="H5921"\w* fuego, \w y|strong="H5921"\w* \w sus|strong="H1931"\w* ataduras cayeron \w de|strong="H5921"\w* \w sus|strong="H1931"\w* \w manos|strong="H3027"\w*.
\v 15 Al \w hallar|strong="H4672"\w* \w una|strong="H4672"\w* quijada de \w asno|strong="H2543"\w* aún fresca, \w extendió|strong="H7971"\w* su \w mano|strong="H3027"\w*, la \w tomó|strong="H3947"\w*, y con ella \w mató|strong="H5221"\w* \w a|strong="H3068"\w* 1.000 hombres.
\p 
