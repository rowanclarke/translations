\id COL  
\ide UTF8
\h Kolossalani 
\toc1 Pauluni Dakani jaura Kolossalani 
\toc2 Kolossalani 
\toc3 Kol 
\mt1 Pauluni Dakani jaura Kolossalani.  
\c 1  
\p
\v 1 Paululu, Jesuni Christuni Apostel Godaia jertapaterinandru, ja Timotheulu, ngatata,   
\p
\v 2 Kana kulikirini Kolossangu, ja ngatatani Christungu, tanali morlalu ngundrai; manjula jurangu nganaiatimai, ja murla Goda ngaianani Ngaperandru, ja Kapara Jesu Christungundru.   
\p
\v 3 Ngaiani Goda ngaiananaia Kaparaia Jesuni Christuni Ngaperi milingeru jurakokai, ngaiani jurangundru ngatjinani,   
\p
\v 4 Ngaiani matja ngarana jurani morlalu ngundrana Christungu Jesungu, ja jurani ngantjana kana kulikiri pratjanani,   
\p
\v 5 Wolkareli kalkanandru, nauja jurangu parai pariwilpani, ninaia jura ngopera ngarana warai ngantjani jauraia morlalulani,   
\p
\v 6 Nauja jurangu wokaranala, worderu bakana mita maruni, ja nauja tandrariai ja punkai, worderu bakana jurangu nunkangupini ditjindru, jura ninaia ngarana wonti ja Godaia manjulaia morlalula ngujamana wonti,   
\p
\v 7 Worderu jura ninaia kiririna wonti Epaphrasungundru, ngaianani jelalingankanietja ngantjalundru, nauja Christuni mili talku nganai jurangu,   
\p
\v 8 Nulia bakana ngaianingu jurani ngantjana Jaolani kaukaubana wonti.   
\lit (Dakani jaura G. D. 24. Trinitatis.)  
\p
\v 9 Jendrangundruja bakana ngaiani, nunkangupini ditjindru, ngaiani jenia ngaranala, wata mudai jurangundru Godani ngatjila, jura manamiri pantjinanto nunkanaia jertapaterinaia ngujamanali ja kirila pratjanali ja Jaolaia ngundranali,   
\p
\v 10 Jura talku wirarinanto Kaparaia ngantjana pratjanani, ja tandrarinanto ngankana ngumu pratjanani,   
\p
\v 11 Ja punkananto Godaia ngujamanani ngurula pratjanali ngurunguru, nunkanaia pirnalaia ngurulandru, manjula ja malti pratjanaia,   
\p
\v 12 Ja mankinali jurakokananto Ngaperi, Nulia ngaianana talku ngankana wonti kulikirilaia maratunkaia praitjani,   
\p
\v 13 Nulia ngaianana kulkana wonti npalpuraia ngurulandru, ja kurana wonti nunkanaia ngantjanaia Ngatamuraia mililani,   
\p
\v 14 Nunkangundru ngaiana kulkani ngamalkai, madlentji kalingani;  
\b  
\p
\v 15 Nauja watanajini Godaia jeribakamudla nganai, Panturu pantjimani poto warupotuni.   
\p
\v 16 Ngangau nunkangundru warupoto pantjina wonti mina pariwilpani ja mitani nganai, mina najini ja wata najini, angela kapara worana kara, jirijiribani worana kara, mitaia kapara worana kara, ngurula worana kara; warupoto nunkangundru ja nunkangu pantjina wonti,   
\p
\v 17 Ja Nauja warupotuni ngopera nganai, ja warupoto nunkangu parai.   
\p
\v 18 Ja Nauja palkuja mangatandra nganai, jenia wondrai mili wolaraia; Naupini wonini ja Panturu nganai narindru, ngangau Nauja warupotuni ngoperala nganananto.   
\p
\v 19 Ngangau Nulia ngantjana wonti nunkangu manamirila warupoto ngamananto,   
\p
\v 20 Ja nunkangundru warupoto kulnukulnuni pantjinanto nunkangu, ja Nulia murla ngankana wonti nunkanaia kunarkuja kumarali, nunkangundru, mina mitani ja mina pariwilpani kara.   
\p
\v 21 Bakana jurana, jura warula tula ja talpala ngankana madlentjaia ngundranali nganana wonti;   
\p
\v 22 Ja Nulia karari jurana kulnukulnuni ngankana warai nunkani palkuja narieli, jurana kulikiri ja madlentji pani ja ngulku panini nunkangu munta wondralkananto;   
\p
\v 23 Jura wonki ja ngurunguru morlalu ngundranani ngamanani ja tataura terkanani ngantjani jauraia kalkanandru, ninaia jura ngarana warai, ja jenia matja kaukaubana pantjimani poto warupotuni tana pariwilpa ngalpani nganai, nunkani mili ngani Paulus pantjina wonti.   
\p
\v 24 Karari ngato mankila wapaia ngakani ketjaketjanani jurangundru, ja ngato manamiri ngankai mina Christuni ketjaketjanani ngadaia parai nunkani palkuja, nauja mili wolara nganai,   
\p
\v 25 Tananapini mili ngani pantjina wonti Godaia ngamalkijiribanandru, ninapini Nulia ngakangu jinkina wonti jurangu, ngato Godaia jaura manamiri ngankananto,   
\p
\v 26 Ninapini kurukurula, nauja kurukuru nganana wonti mita pantjimanandru ja miljarandru, ja karari tinkari pantjina wonti nunkani kana kulikirini,   
\p
\v 27 Tanangu Godali ngantjana wonti tinkari ngankala ninapini kurukurulaia pirnalaia poto pirna kana koni, Naupini Christus nganai jurangu, pirnalaia kalkani,   
\p
\v 28 Ninaia ngaiani kaukaubai, ja kana pratjana kurukurubai, ja pratjanani ngujangujara jinkiai kirila pratjanali, ngaiani kana warupoto manamiri wondralkananto Christungu Jesungu,   
\p
\v 29 Nunkangundru ngato bakana jiglerali ngankai, ta tirimaliai nunkani ngankanani jeribaka, Nulia ngurulali ngakangu ngankai.   
\c 2  
\p
\v 1 Ngato ngantjai, jura milkila nganananto, mina tirimalini pirna ngato jurangundru ngamalkai, ja tanangu Laodicäandru ja pratjanandru, tanali ngana mudla palkuni wata najinala;   
\p
\v 2 Tanani ngara ngankalkani ngamalkananto ja ngokananto ngantjanali ngundrani morlaluja poto pirna warupotuja, ja Godaia Ngaperaia kurukurulaia ngujamanaia Christungu,   
\p
\v 3 Nunkangu kirilaia ja ngujamanaia poto pratjana kurukuru parai.   
\p
\v 4 Ngani jenia jatai, ngangau wata kulnujeli jurana tjautjau ngankananto jaura kirieli.   
\p
\v 5 Ngani palku bakana jurangu worita ngananani, jeruja ngani jaola jurangu jela ngamai; ja ngani mankila wapaia ja najila wapaia, worderu jura talku ngamai ja ngurungurujeli morlalu ngundrai Christungu.   
\p
\v 6 Worderu jura Christus Jesus Kapara patana wonti, jeruja nunkangu wirarianau,   
\p
\v 7 Jura kapararinanto ja wotiterina tarananto nunkangu, ja ngurunguru pantjinanto morlalu ngundranali, worderu jura kiririna wonti, ja manamiri pantjinanto nunkangu jurakokanali.   
\p
\v 8 Ngamalkaterianau, wata kulnujeli jurana watawatali maninanto mitaia kirieli ja kana jirijiribani jauraia jedibanali ja mitaia ngujangujarali ja wata Christujeli.   
\p
\v 9 Ngangau nunkangu Godaia manamirila warupoto kantji ngamala wapaia,   
\p
\v 10 Ja jura nunkangu manamiri nganai, Nauja kaparaia ja ngurula pratjanaia mangatandra nganai,   
\p
\v 11 Nunkangu jura bakana karuwalila pantjina wonti karuwali ngankani mara panieli, ngangau jura kana womala dukarana wonti Christuni karuwalila ngankanali,   
\p
\v 12 Nunkangu jela jura bakana todina wonti multibanilali, nunkangundru jura bakana jela jiritjibana wonti morlalu ngundranali Godaia ngurulani, Nulia ninaia jiritjibana wonti narindru,   
\p
\v 13 Bakana jurana, jura dankaranani ja jurani palkuja karuwalila panini matja nari, jurana Nulia tepi ngankana wonti nunkangu jela, ngangau Nulia dankarana ngaianani baku ngundrana wonti,   
\p
\v 14 Ja Nauja ngaianani wilpantuja dakani jaura, nauja kanaia jirijiribani jaurali ngaianani tula nganana wonti, kalingana wonti, ja Nulia ninaia tertindru manina wonti ja kunarkuni katibana wonti;   
\p
\v 15 Ja Nulia kapara worana ja ngurula worana dukarana wonti, ja tanana wondrani malka kurana wonti tinkari, ja tanana kalala ngankana wonti nunkangu.   
\p
\v 16 Jeruja wata kulnujeli jurana kalala ngundrananto tajinandru kara, tapanandru kara, ditji pirnandru kara, pira marrandru kara, Sabbath ditjindru kara;   
\p
\v 17 Tana pungala nganai nunkangu nau wokarananto, ja palku munta Christus nganai.   
\p
\v 18 Wata kulnujeli jurani tirimalinaia kalala mamananto, ngangau nau ngantjateriai waka ngundraterinani ja angelani wodatarana ngamanani, ngangau nulu poto ngundrai, tanana nulu wata najina warai, baku nau wombatjerai nunkani palkuja ngundranandru;   
\p
\v 19 Ja nulu mangatandra worarai, nunkangundru palku warupotujeli diltjali ja pantjali ngurungurula maniai ja ngokamaliai, ja jeruja punkai Godaia pirnalaia.   
\p
\v 20 Jura Christungunto mitaia jirijiribani jaurani matja palina, minandru tanali jurangu jirijiribani jaura jinkiai, jura mitani ngamanani jeribaka?   
\p
\v 21 „Jenia wata patamai, jenia wata wontjamai, jenia wata karakaramai,“   
\p
\v 22 Jenia pratjana tintaterinaia parai ngankanali kanaia jirijiribani jaurandru ja ngujangujarandru.   
\p
\v 23 Jenipara kirilaia malka ngamalkai, ngangau tana Godani wodatarana ngamai, ninaia tanali muntali kalkalkana warai, ja waka ngundrateriai, ja palku wata kulkai, ja nunkangu wata pirnala jinkiai ninaia ngumu ngamalkala.   
\c 3  
\p
\v 1 Nulia jurana Christungu jela matja jiritjibana, jeruja wontianau mina miri nganai, woderi Christus nganai, Nauja Godaia ngunarani ngamala wapaia.   
\p
\v 2 Nunkangu jigleri ngananau, mina miri nganai, ja wata nunkangu, mina mitani nganai.   
\p
\v 3 Ngangau jura matja palina, ja tepi jurani kurukuru nganai Christungunto Godani.   
\p
\v 4 Christus, tepi juranina, matja wondraterina warai, ngadani bakana jura nunkangu jela wondraterila nganai pirnalani.   
\p
\v 5 Jurani buru, tana mitani nganai, nari nandranau: Palakantji, murumuru, jertapaterina madlentji, milkirina madlentji, ngukingukipaterina nauja nganai muramurani wodatarana ngamana,   
\p
\v 6 Tanangundru Godaia tirila delkinietjaia ngatamurani wokarai,   
\p
\v 7 Tanangupini bakana jura warula wirarina wonti, jura tanangu matja ngamana.   
\p
\v 8 Karari bakana jura jenia pratjana woranau: Tiri, tirijiritjini, kuterini, ngirkibani, jaura madlentji jurani manandru.   
\p
\v 9 Wata jedibijiribamalianau, ja kana womala dukaranimai nunkani ngankananto,   
\p
\v 10 Ja kana marra widmaterianau, ninaia Nulia marraribai ngujamanaia, nunkani pantjimanipirnaia mudlani jeribaka;   
\p
\v 11 Jeruja wata morla nganai Grieka kana ja Juda kana, ja karuwalila, ja karuwalila pani, ja tula, ja Skytha, ja mili, ja kurakanila, a‐ai, warupoto warupotuni Christus.   
\lit (Dakani jaura G. D. 5 Epiphanias.)  
\p
\v 12 Jeruja widmaterianau Godaia kalkalkani ja kulikiri ja ngantjalu jeribaka: Ngarali kalumiltjamiltjarina, ngumu, waka ngundraterina, malti, manju;   
\p
\v 13 Kulnukulnuni ngankijiribamalianimai ja worijiribamalianimai, kulnujeli kulnuni ngulku ngamalkanani; worderu Christulu madlentji jurani worana wonti, jeruja bakana jura.   
\p
\v 14 Nunkangu pratjanani widmaterianimai ngantjana, ngangau nauja manamiria kuma nganai.   
\p
\v 15 Ja Godaia murla jurangu ngarani kapara nganaiatimai, nunkangupini jura matja karkana palku kulnuni; ja jurakokanali manamiri pantjianau.   
\p
\v 16 Christuni jaura poto pirna jurangu nganaiatimai, ja munta ngujangujara jinkimalianimai ja kurukurubijiribamalianimai kiri pratjanani, Psalma wimali ja jurakokani wimali, ja Jaolaia wimali murlali Kaparani wonkanau jurani ngarani.   
\p
\v 17 Ja pratjana, mina jura ngankai, jaurali kara ngankanali kara, jenia pratjana ngankanau Kaparaia Jesuni talani, ja jurakokanau Goda ja Ngaperi nunkangundru.  
\b  
\p
\v 18 Jura widla worajai, materani juranani wodatarana ngamanau, worderu talku nganai Kaparani.   
\p
\v 19 Jura materi worajai, widla jurani ngantjanau, ja wata kaldri tanangu pantjianau.   
\p
\v 20 Jura kupa worajai, ngaperani ja ngandrini pankianau warupotuni, ngangau jenia Kaparali ngantjai.   
\p
\v 21 Jura ngaperi worajai, jurani kupa wata tirijiritjibanau, tana wata wurpuru pantjinanto.   
\p
\v 22 Jura mili worajai, jurani palkuja Kaparani pankianau warupotuni, wata milki kantjini kana windri murlali ngankala jeribaka, a‐ai, ngara kulnukulnuni ngundranali, Godandru japali.   
\p
\v 23 Ja pratjana, mina jura ngankai, jenia ngarali ngankanau Kaparani ja wata kanani,   
\p
\v 24 Ngangau jura milkila, jura Kaparandru maratunkaia kalala manila nganai; Kapara Christungu ngamanau!   
\p
\v 25 Warle tjikatjika ngankai, nulu manila nganai, mina tjikatjika nulu ngankana warai, ja kana mudla Nulia wata ngundrai.   
\c 4  
\p
\v 1 Jura kapara worajai, mina talku ja jeribaka nganai jurani milini ngankanau, ngangau jura milkila, bakana jura Kapara ngamalkai pariwilpani.   
\p
\v 2 Milingeru ngatjianimai, ja nunkangu tepi ngamanau jurakokanali.   
\p
\v 3 Bakana ngaianingu ngatjianau, Godali ngaianingu jauraia mana piri ngankananto Christuni kurukurula kaukaubala, nunkangundru ngani dupudupu ngamai.   
\p
\v 4 Ngangau ngato ninaia tinkari ngankananto worderu ngani jatananto.   
\p
\v 5 Kirini wirarianau tanangundru, tana palarani nganai, ja ditjini juranani jigleri ngananau.   
\p
\v 6 Jurani jaura milingeru manju nganaiatimai kaldrieli matja ngankingana, ngangau jura ngujamananto, worderu jura pratjanani kalabananto.   
\p
\v 7 Worderu ngani ngamai, jenia pratjana jurangu Tychikulu kaukaubala nganai, nauja ngatata ngantjalu ja mili talku ja jelangankanietja Kaparani.   
\p
\v 8 Ninaia ngato jendrania jurangu jinpana warai, jura ngujamananto, worderu ngaiani ngamai, ja nulia ngara jurani ngankalkananto,   
\p
\v 9 Onesimusungu jela, nauja ngatata talku ja ngantjalu nganai, ja jurangundru nganai. Pudlalia pratjana jurangu kaukaubala nganai, mina ninkida.   
\p
\v 10 Jurangu mandurini jaura jinkiai Aristarchulu, ngakani jeladupudupula, ja Markusulu, Barnabani ngadada, nunkangundru jura jirijiribani jaura manina warai; nauja jurangu wokaranani, ninaia patanau,   
\p
\v 11 Ja Jesujeli, ninaia tanali dikai Justus; tanaia karuwalilandru nganai, ja windri tanapini jelangankanietja ngakani nganai Godaia mililani, tanaia ngakangu ngankalkani pantjina warai.   
\p
\v 12 Mandurini jaura jurangu jinkiai Epaphrasali, nauja jurangundru nganai, ja Christuni Jesuni mili, nauja milingeru tirimaliai jurangundru ngatjinali, jura talku ja ngurunguru Godaia jertapaterinani terkananto;   
\p
\v 13 Ngato morlalu kurai nunkangu, nulia jigleri ngankai jurangundru, ja tanangundru Laodicäangu, ja tanangundru Hierapolingu.   
\p
\v 14 Jurangu mandurini jaura jinkiai Lukasali, nauja kunki ngantjalu, ja Demasali.   
\p
\v 15 Mandurini jaura jinkianau ngatata worangu Laodiceangu ja Nymphasangu ja mili wolarani pungani nunkanani.   
\p
\v 16 Ja jura ninapini dakani jaura matja warapana, ngankanau, ninaia bakana Laodiceala mili wolarali warapananto, ja jura bakana ninaia Laodiceandru warapanau.   
\p
\v 17 Ja Archippusungu jatanau: Ngamalkijiribani jinkani ngundramai, ninaia jundru Kaparandru maninala, jundru ninaia manamiri ngankananto.   
\p
\v 18 Mandurini jaura ngakani Paululu marali. Ngakani dupudupu ngundranau. Manjula jurangunto nganaiatimai!   