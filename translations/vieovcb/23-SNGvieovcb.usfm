\id SNG - Biblica® Open Vietnamese Contemporary Bible 2015 (Biblica® Thiên Ban Kinh Thánh Hiện Đại) 
\h Nhã Ca 
\toc1 Nhã Ca 
\toc2 Nhã Ca 
\toc3 Nhã 
\mt1 Nhã Ca 
\c 1  
\p  
\v 1 Đây là bài ca trong các bài ca của Sa-lô-môn, tuyệt vời hơn bất cứ bài ca nào khác. 
\sp Thiếu Nữ 
\q1  
\v 2 Hãy hôn em và hôn em lần nữa, 
\q2 vì tình chàng ngọt hơn rượu. 
\q1  
\v 3 Mùi thơm chàng ngào ngạt quyến rũ; 
\q2 tên chàng tỏa ngát như hương. 
\q2 Chẳng trách các thiếu nữ mê say! 
\q1  
\v 4 Xin cho em theo chàng; nào, chúng ta cùng chạy! 
\q2 Vua đã đưa em vào phòng người. 
\sp Các Thiếu Nữ Giê-ru-sa-lem 
\q1 Ôi vua, chúng em hân hoan vì chàng biết bao. 
\q2 Chúng em thấy tình chàng nồng nàn hơn rượu. 
\sp Thiếu Nữ 
\q1 Họ say mê chàng lắm! 
\q1  
\v 5 Da em đen nhưng rất đẹp xinh, 
\q2 các thiếu nữ Giê-ru-sa-lem hỡi— 
\q1 đen như các lều trại Kê-đa, 
\q2 đen như màn lều trại Sa-lô-môn. 
\q1  
\v 6 Đừng cứ nhìn em vì làn da đen— 
\q2 mặt trời đã khiến da em đen sạm. 
\q1 Các anh trai em đã giận em; 
\q2 họ giao em chăm sóc vườn nho họ, 
\q2 Vậy nên em không thể chăm sóc mình—vườn nho của riêng em. 
\q1  
\v 7 Xin hãy nói với em, người em yêu mến, hôm nay chàng chăn bầy nơi đâu? 
\q2 Chàng sẽ cho chiên nghỉ trưa nơi nào? 
\q1 Sao em phải đi thẫn thờ như gái điếm 
\q2 giữa bạn bè chàng và bầy của họ? 
\sp Chàng Trai 
\q1  
\v 8 Hỡi người đẹp nhất trong các thiếu nữ, nếu em không biết, 
\q2 hãy theo dấu chân của bầy anh, 
\q2 và để bầy dê con gần lều bọn chăn chiên. 
\q1  
\v 9 Em thật lý thú, em yêu dấu của anh, 
\q2 em như con tuấn mã đóng vào xe của Pha-ra-ôn. 
\q1  
\v 10 Đôi má em đáng yêu làm sao; 
\q2 đôi hoa tai làm đôi má em thêm hồng thắm! 
\q1 Cổ em thật duyên dáng, 
\q2 được nổi bật bởi vòng hạt trân châu. 
\q1  
\v 11 Chúng tôi sẽ làm cho em hoa tai bằng vàng 
\q2 và chuỗi hạt nạm bạc. 
\sp Thiếu Nữ 
\q1  
\v 12 Khi vua đang nằm dài trên ghế, 
\q2 say mê mùi hương thơm ngát của em. 
\q1  
\v 13 Người yêu em như bó hoa một dược 
\q2 nằm nghỉ êm ấm giữa ngực em. 
\q1  
\v 14 Chàng như chùm hoa phụng tiên, 
\q2 trong vườn nho của Ên-ghê-đi. 
\sp Chàng Trai 
\q1  
\v 15 Em quá đẹp, em yêu dấu của anh, 
\q2 ôi xinh đẹp làm sao! 
\q2 Mắt của em như đôi mắt bồ câu. 
\sp Thiếu Nữ 
\q1  
\v 16 Chàng đẹp biết bao, hỡi người em yêu, 
\q2 quyến rũ biết bao! 
\q2 Thảm cỏ xanh là giường của chúng ta; 
\q1  
\v 17 gỗ bá hương là xà nhà của chúng ta, 
\q2 và gỗ linh sam thơm lừng là nóc nhà. 
\c 2  
\sp Thiếu Nữ 
\q1  
\v 1 Em là hoa thủy tiên nở rộ trên Cánh Đồng Sa-rôn, 
\q2 và là hoa huệ ngoài thung lũng. 
\sp Chàng Trai 
\q1  
\v 2 Em yêu dấu của anh giữa vòng các thiếu nữ 
\q2 như hoa huệ giữa những bụi gai. 
\sp Thiếu Nữ 
\q1  
\v 3 Người yêu của em giữa các chàng trai khác 
\q2 như cây táo ngon nhất trong vườn cây. 
\q1 Em thích ngồi dưới bóng của chàng, 
\q2 và thưởng thức những trái ngon quả ngọt. 
\q1  
\v 4 Chàng đưa em vào phòng yến tiệc; 
\q2 rõ ràng là chàng yêu em nhiều lắm. 
\q1  
\v 5 Hãy thêm sức cho em bằng những bánh nho, 
\q2 làm em tươi mới bằng những trái táo. 
\q2 Vì yêu mà em dần cạn kiệt. 
\q1  
\v 6 Tay trái chàng kê dưới đầu em, 
\q2 tay phải chàng ôm thân em thật chặt. 
\q1  
\v 7 Hãy hứa với tôi, hỡi người nữ Giê-ru-sa-lem, 
\q2 nhân danh đàn linh dương và đàn nai đồng nội, 
\q2 đừng đánh thức ái tình cho đến khi đúng hạn. 
\q1  
\v 8 Này, em nghe tiếng chân người yêu đang đến! 
\q2 Chàng đang nhảy qua từng khe núi, 
\q2 và phóng nhanh qua các đỉnh đồi. 
\q1  
\v 9 Người yêu em như linh dương thoăn thoắt 
\q2 hay như nai tơ đực lẹ làng. 
\q1 Kìa, chàng đã đến đứng sau bức vách, 
\q2 đang nhìn qua cửa sổ, 
\q2 đang ngó chăm vào phòng. 
\q1  
\v 10 Người yêu em nói với em rằng: 
\q2 “Hãy chỗi dậy, em yêu dấu! 
\q2 Hãy đến cùng anh, người đẹp của anh ơi! 
\q1  
\v 11 Ô kìa, mùa đông đã trôi qua, 
\q2 mưa đã tạnh rồi. 
\q1  
\v 12 Những cánh hoa đang nở rộ khắp đất, 
\q2 mùa chim hót vang đã đến gần, 
\q2 và tiếng gù của bồ câu khắp không gian. 
\q1  
\v 13 Những cây vả đã bắt đầu ra trái, 
\q2 mùi nho thơm cũng ngào ngạt tỏa hương! 
\q1 Hãy chỗi dậy, em yêu dấu! 
\q2 Hãy đến với anh, người đẹp của anh ơi!” 
\sp Chàng Trai 
\q1  
\v 14 Bồ câu của anh đang ẩn mình trong đá, 
\q2 tận trong nơi sâu kín của núi đồi. 
\q1 Hãy để anh ngắm nhìn gương mặt em; 
\q2 hãy để anh nghe tiếng của em. 
\q1 Vì giọng nói của em dịu dàng, 
\q2 và gương mặt của em kiều diễm. 
\sp Các Thiếu Nữ Giê-ru-sa-lem 
\q1  
\v 15 Hãy bắt tất cả chồn, những con chồn nhỏ kia, 
\q2 trước khi chúng phá hoại vườn nho tình yêu, 
\q2 vì vườn nho đang trong mùa nở rộ! 
\b  
\sp Thiếu Nữ 
\q1  
\v 16 Người yêu của em thuộc riêng em, và em là của chàng. 
\q2 Chàng vui thỏa giữa rừng hoa huệ. 
\q1  
\v 17 Trước khi gió mai hiu hiu thổi 
\q2 và bóng tối biến tan đi, 
\q1 hãy về với em, người yêu hỡi, như linh dương 
\q2 hay nai tơ trên đồi núi gập ghềnh. 
\c 3  
\sp Thiếu Nữ 
\q1  
\v 1 Đêm khuya trên giường, em khao khát vì người yêu. 
\q2 Em mong mỏi nhưng chàng không đến. 
\q1  
\v 2 Em tự nhủ: “Ta phải dậy và đi quanh thành phố, 
\q2 đến các ngã đường và từng khu dân cư. 
\q1 Ta phải tìm được người ta yêu dấu.” 
\q2 Nhưng chàng vẫn biệt tăm dù đã kiếm khắp nơi. 
\q1  
\v 3 Lính tuần thành gặp em trên đường phố, 
\q2 em hỏi: “Ông có thấy người tôi yêu?” 
\q1  
\v 4 Chẳng bao lâu khi rời khởi họ, 
\q2 em tìm được người em dấu yêu! 
\q1 Em đã giữ và ôm chàng thật chặt, 
\q2 rồi đưa chàng về nhà của mẹ em, 
\q2 vào giường của mẹ, nơi em được sinh ra. 
\b  
\q1  
\v 5 Hãy hứa với tôi, hỡi người nữ Giê-ru-sa-lem, 
\q2 nhân danh đàn linh dương và đàn nai đồng nội, 
\q2 đừng đánh thức ái tình cho đến khi đúng hạn. 
\sp Các Thiếu Nữ Giê-ru-sa-lem 
\q1  
\v 6 Bóng ai từ hoang mạc đi lên như cột khói? 
\q2 Ngào ngạt mùi nhũ hương và một dược, 
\q2 cùng mọi thứ hương liệu ấy là ai? 
\q1  
\v 7 Xem kìa, đó là kiệu của Sa-lô-môn, 
\q2 chung quanh có sáu mươi người quả cảm, 
\q2 là dũng sĩ giỏi nhất của Ít-ra-ên. 
\q1  
\v 8 Tất cả họ đều thạo sử dụng gươm, 
\q2 là những tay kinh nghiệm chiến đấu. 
\q1 Mỗi người mang bên mình gươm sắc, 
\q2 bảo vệ vua lúc đêm tối hiểm nguy. 
\q1  
\v 9 Kiệu Vua Sa-lô-môn được làm bằng 
\q2 gỗ quý hiếm từ rừng Li-ban. 
\q1  
\v 10 Những cột trụ được làm bằng bạc, 
\q2 vòm che kiệu được tạo bằng vàng; 
\q2 đệm được bao bọc bằng vải tím. 
\q1 Nó được trang trí bằng tình yêu 
\q2 của các thiếu nữ Giê-ru-sa-lem. 
\sp Thiếu Nữ 
\q1  
\v 11 Hãy đến ngắm nhìn Vua Sa-lô-môn, 
\q2 hỡi các thiếu nữ Giê-ru-sa-lem. 
\q1 Vua mang vương miện mẹ tặng trong ngày cưới, 
\q2 đó là ngày hạnh phúc nhất của vua. 
\c 4  
\sp Chàng Trai 
\q1  
\v 1 Em đẹp quá, em yêu dấu, 
\q2 ôi em đẹp quá. 
\q1 Đôi mắt em như mắt bồ câu 
\q2 ẩn hiện sau màn the che mặt. 
\q1 Mái tóc em bồng bềnh buông xõa 
\q2 như bầy dê chạy quanh co trên triền Ga-la-át. 
\q1  
\v 2 Răng em trắng tựa đàn chiên 
\q2 vừa được hớt lông và tắm mát 
\q1 Nụ cười em vẹn toàn hoàn mỹ, 
\q2 với hai hàm răng khít khao đều đặn. 
\q1  
\v 3 Đôi môi em đỏ tựa chỉ điều; 
\q2 miệng em hấp dẫn thật đáng yêu. 
\q1 Đôi má hồng hào như thạch lựu 
\q2 thấp thoáng ẩn hiện sau màn che. 
\q1  
\v 4 Cổ em đẹp như tháp Đa-vít, 
\q2 được phủ đầy khiên của hàng nghìn dũng sĩ. 
\q1  
\v 5 Ngực em như cặp nai con, 
\q2 cặp nai song sinh của con linh dương 
\q2 đang gặm cỏ giữa vùng hoa huệ. 
\q1  
\v 6 Trước khi hừng đông ló dạng 
\q2 và bóng tối tan đi, 
\q1 anh sẽ nhanh chân đến núi một dược 
\q2 và đến đồi nhũ hương. 
\q1  
\v 7 Em đẹp quá, ôi người yêu dấu, 
\q2 đẹp tuyệt trần trên thân không tì vít. 
\b  
\q1  
\v 8 Hãy cùng anh rời khỏi Li-ban, cô dâu của anh ơi. 
\q2 Hãy cùng anh rời khỏi Li-ban. 
\q1 Ngắm nhìn phong cảnh từ Núi A-ma-na, 
\q2 từ Sê-nia và từ đỉnh Hẹt-môn, 
\q1 nơi những hang sư tử, 
\q2 và đồi núi của beo. 
\b  
\q1  
\v 9 Em đã bắt lấy hồn anh, 
\q2 em gái ơi, cô dâu của anh ơi. 
\q1 Em đã giữ chặt tim anh 
\q2 bằng một cái liếc mắt, 
\q2 với một vòng trân châu trên cổ. 
\q1  
\v 10 Tình yêu của em thắm thiết nồng nàn, 
\q2 em gái ơi, cô dâu của anh ơi. 
\q1 Tình yêu em hơn cả rượu nho, 
\q2 mùi thơm em tỏa hơn hương liệu. 
\q1  
\v 11 Cô dâu của anh ơi, môi em ngọt như mật hoa, 
\q2 mật ong và sữa nằm dưới lưỡi em. 
\q2 Áo em thơm như hương nam của Li-ban. 
\b  
\q1  
\v 12 Em là vườn kín của riêng anh, em gái anh, cô dâu của anh ơi, 
\q2 như suối niêm phong, như mạch nước ẩn mình. 
\q1  
\v 13 Tay chân em tựa vườn thạch lựu ngọt ngon 
\q2 với những hương quý hiếm và cây cam tùng, 
\q1  
\v 14 cam tùng và nghệ, 
\q2 xương bồ và nhục quế, 
\q1 cùng tất cả cây nhũ hương, một dược, và lô hội 
\q2 với mọi loại hương liệu quý giá. 
\q1  
\v 15 Em là mạch nước trong vườn, 
\q2 là dòng nước tươi mát 
\q2 chảy từ những ngọn núi của Li-ban. 
\sp Thiếu Nữ 
\q1  
\v 16 Hỡi gió bắc, hãy chỗi dậy! 
\q2 Hỡi gió nam, hãy thổi đến! 
\q1 Hãy thổi vào vườn em 
\q2 cho hương thơm tỏa khắp. 
\q1 Hãy vào vườn của chàng, người yêu em hỡi; 
\q2 em mời chàng nếm trái ngọt ngon. 
\c 5  
\sp Chàng Trai 
\q1  
\v 1 Anh đã vào khu vườn của anh rồi, 
\q2 em gái của anh, cô dâu của anh ơi. 
\q1 Anh đã hòa một dược với các hương liệu 
\q2 và ăn cả tàng ong với mật của anh. 
\q2 Anh uống rượu nho với sữa của anh. 
\sp Các Thiếu Nữ Giê-ru-sa-lem 
\q1 Ôi, hỡi người yêu và người được yêu, hãy ăn và uống! 
\q2 Vâng, hãy say men tình yêu của bạn! 
\sp Thiếu Nữ 
\q1  
\v 2 Em đã ngủ, nhưng tim em vẫn thức, 
\q2 khi nghe tiếng người yêu em gõ cửa gọi mời: 
\q1 “Hãy mở cho anh, em gái anh, người yêu dấu của anh! 
\q2 Bồ câu của anh, người tuyệt hảo của anh ơi. 
\q1 Đầu anh ướt đẫm sương móc, 
\q2 mái tóc anh thấm giọt sương đêm.” 
\b  
\q1  
\v 3 Nhưng em cất tiếng đáp lời: 
\q2 “Em đã cởi áo dài của em. 
\q2 Chẳng lẽ lại mặc vào lần nữa? 
\q2 Chân em cũng đã rửa sạch rồi. 
\q2 Lẽ nào lại chịu lấm chân sao?” 
\b  
\q1  
\v 4 Người yêu em cố đẩy then cài, 
\q2 và tim em rung lên rạo rực. 
\q1  
\v 5 Em chỗi dậy để mở cửa cho người yêu, 
\q2 hương thơm ướt đẫm trên bàn tay em. 
\q1 Ngón tay em đầm đìa một dược 
\q2 khi em kéo then gài qua bên. 
\q1  
\v 6 Vội mở cửa cho người em yêu, 
\q2 nhưng chàng đã không còn nơi đó! 
\q1 Lòng dạ em se thắt. 
\q2 Em tìm kiếm mọi nơi nhưng chẳng thấy chàng đâu. 
\q1 Em cất tiếng gọi chàng, 
\q2 nhưng không một lời đáp lại, 
\q1  
\v 7 Lính tuần thành ban đêm bắt gặp em. 
\q2 Họ đánh đập và gây thương tích cho em, 
\q1 những lính tuần thành đó 
\q2 còn lấy cả khăn che mặt của em! 
\q1  
\v 8 Xin hãy hứa, hỡi các thiếu nữ Giê-ru-sa-lem, 
\q2 nếu các chị tìm thấy người yêu của em, 
\q2 xin nhắn với chàng rằng em đang bệnh tương tư. 
\sp Các Thiếu Nữ Giê-ru-sa-lem 
\q1  
\v 9 Người yêu chị có gì hơn người khác, 
\q2 hỡi người đẹp trong những người đẹp? 
\q1 Người yêu chị có gì đặc biệt 
\q2 đến nỗi chúng tôi phải hứa điều này? 
\sp Thiếu Nữ 
\q1  
\v 10 Người yêu em ngăm đen và rạng rỡ, 
\q2 đẹp nhất trong muôn người! 
\q1  
\v 11 Đầu chàng bằng vàng ròng tinh chất. 
\q2 Tóc chàng gợn sóng và đen như quạ. 
\q1  
\v 12 Mắt chàng lấp lánh như bồ câu 
\q2 bên cạnh dòng suối nước; 
\q1 hình thể như cặp trân châu 
\q2 được tắm trong sữa. 
\q1  
\v 13 Má chàng như vườn hoa hương liệu 
\q2 ngào ngạt mùi thơm. 
\q1 Môi chàng như chùm hoa huệ, 
\q2 với mùi một dược tỏa ngát. 
\q1  
\v 14 Đôi tay chàng như những ống vàng 
\q2 khảm đầy lam ngọc. 
\q1 Thân hình chàng như ngà voi chói sáng, 
\q2 rực rỡ màu ngọc xanh. 
\q1  
\v 15 Đôi chân chàng như hai trụ đá 
\q2 đặt trên hai đế vàng ròng. 
\q1 Dáng dấp chàng oai nghiêm, 
\q2 như cây bá hương trên rừng Li-ban. 
\q1  
\v 16 Môi miệng chàng ngọt dịu; 
\q2 toàn thân chàng hết mực đáng yêu. 
\q1 Hỡi những thiếu nữ Giê-ru-sa-lem, 
\q2 người yêu em là vậy, bạn tình em là thế đó! 
\c 6  
\sp Các Thiếu Nữ Giê-ru-sa-lem 
\q1  
\v 1 Người yêu của chị đã đi đâu, 
\q2 hỡi người đẹp trong những người đẹp? 
\q1 Con đường nào mà chàng hướng đến 
\q2 để chúng tôi giúp chị tìm chàng? 
\sp Thiếu Nữ 
\q1  
\v 2 Người yêu em đã xuống vườn chàng, 
\q2 đến các luống hoa hương liệu, 
\q1 để ăn trái trong vườn 
\q2 và hái những hoa huệ. 
\q1  
\v 3 Em thuộc về người em yêu, và người yêu em thuộc về em. 
\q2 Chàng vui thỏa ăn giữa đám hoa huệ. 
\sp Chàng Trai 
\q1  
\v 4 Em thật đẹp, người anh yêu dấu, 
\q2 xinh đẹp như thành Tia-xa. 
\q1 Phải, xinh đẹp như Giê-ru-sa-lem, 
\q2 oai phong như đội quân nhấp nhô cờ hiệu. 
\q1  
\v 5 Xin em đưa mắt nhìn nơi khác, 
\q2 vì chúng làm ngơ ngẩn lòng anh. 
\q1 Mái tóc em bồng bềnh buông xõa 
\q2 như bầy dê chạy quanh co trên triền Ga-la-át. 
\q1  
\v 6 Răng em trắng tựa đàn chiên 
\q2 vừa được tắm mát. 
\q1 Nụ cười em vẹn toàn hoàn mỹ, 
\q2 với hai hàm răng khít khao đều đặn. 
\q1  
\v 7 Đôi má em hồng hào như thạch lựu 
\q2 thấp thoáng ẩn hiện sau màn che. 
\q1  
\v 8 Dù ở giữa sáu mươi hoàng hậu, 
\q2 tám mươi cung phi, 
\q2 và vô số cung nữ, 
\q1  
\v 9 anh vẫn chọn bồ câu của anh, người tuyệt hảo của anh— 
\q2 là con quý nhất của mẹ, 
\q2 là con yêu dấu của người sinh ra em. 
\q1 Các thiếu nữ thấy em và ngợi khen em; 
\q2 ngay cả các hoàng hậu và cung phi cũng phải khen ngợi em: 
\q1  
\v 10 “Người này là ai mà xuất hiện như rạng đông, 
\q2 xinh đẹp như mặt trăng 
\q2 rực rỡ như mặt trời, 
\q2 oai phong như đội quân nhấp nhô cờ hiệu?” 
\sp Thiếu Nữ 
\q1  
\v 11 Em vừa xuống thăm khóm hạnh nhân 
\q2 và ngắm nhìn chồi xanh trong thung lũng, 
\q2 xem nho có nẩy lộc hay thạch lựu có trổ hoa chưa. 
\q1  
\v 12 Trước khi em nhận ra sự việc 
\q2 thì nỗi khao khát đã đưa em lên xe của người quyền quý. 
\sp Các Thiếu Nữ Giê-ru-sa-lem 
\q1  
\v 13 Hãy quay lại, quay lại với chúng tôi, ôi người đẹp Su-la-mít. 
\q2 Hãy trở về, trở về đây, để chúng tôi nhìn ngắm nàng lần nữa. 
\sp Chàng Trai 
\q1 Sao các cô cứ ngắm nhìn thiếu nữ Su-la-mít 
\q2 như thể nhìn nàng bước đi duyên dáng giữa hai hàng vũ nữ? 
\c 7  
\q1  
\v 1 Bàn chân em mang hài đẹp biết bao, 
\q2 công nương hỡi. 
\q1 Vòng đùi em khác nào châu ngọc 
\q2 do công trình của thợ khéo tài năng. 
\q1  
\v 2 Rốn em tròn trịa như chung rượu 
\q2 đầy rượu pha. 
\q1 Bụng em như một ôm lúa mạch, 
\q2 chung quanh có hoa huệ thơm ngát. 
\q1  
\v 3 Ngực em như cặp nai con, 
\q2 cặp nai song sinh của con linh dương. 
\q1  
\v 4 Cổ em như ngọn tháp ngà. 
\q2 Mắt em như ao hồ lấp lánh tại Hết-bôn 
\q2 bên cổng Bát Ra-bim. 
\q1 Mũi em cao đẹp như tháp Li-ban 
\q2 trông ngóng hướng về thành Đa-mách. 
\q1  
\v 5 Đầu em oai nghiêm như ngọn Núi Cát-mên, 
\q2 và tóc em lộng lẫy như thảm hoàng cung. 
\q2 Vua bị làn tóc này vương vấn. 
\q1  
\v 6 Ôi, em xinh đẹp biết bao! 
\q2 Thật khoái lạc, em yêu dấu, em khiến anh vui thích thể nào! 
\q1  
\v 7 Thân em thon như cây chà là, 
\q2 và bầu ngực em như chùm quả chín. 
\q1  
\v 8 Anh đã nói: “Ta sẽ trèo lên cây chà là, 
\q2 và ôm lấy những chùm quả chín.” 
\q1 Ước gì bầu ngực em như chùm nho, 
\q2 và hơi thở em thơm như táo ngọt. 
\q1  
\v 9 Nụ hôn em kích thích như rượu ngon, 
\q2 chảy dịu dàng qua môi và răng! 
\sp Thiếu Nữ 
\q1  
\v 10 Em thuộc về người em yêu, 
\q2 và ước vọng chàng hướng về em. 
\q1  
\v 11 Hãy đến, người yêu dấu, chúng ta cùng đến những cánh đồng, 
\q2 và trải qua đêm ở giữa đồng hoa dại. 
\q1  
\v 12 Chúng ta cùng dậy sớm và đến vườn nho 
\q2 để xem những dây nho nứt đọt, 
\q1 xem các loài hoa đang nở, 
\q2 và thạch lựu trổ hoa. 
\q2 Tại nơi đó em trao cả tình yêu cho chàng. 
\q1  
\v 13 Quả phong già tỏa mùi thơm ngát, 
\q2 và hoa quả ngon ngọt, 
\q1 cùng với niềm vui thích cũ và mới, 
\q2 em đặt trước cửa để dành cho anh, người em yêu dấu. 
\c 8  
\sp Thiếu Nữ 
\q1  
\v 1 Ôi, ước gì chàng là anh trai của em, 
\q2 người được nuôi từ bầu sữa của mẹ em. 
\q1 Để em có thể hôn chàng dù có người đang nhìn, 
\q2 không bị ai chỉ trích. 
\q1  
\v 2 Em có thể đưa chàng về nhà mẹ em, 
\q2 và nơi đó chàng dạy dỗ em. 
\q1 Em sẽ mời chàng uống rượu thơm, 
\q2 nước rượu ngọt của thạch lựu. 
\q1  
\v 3 Tay trái chàng kê dưới đầu em, 
\q2 Tay phải chàng ôm thân em thật chặt. 
\b  
\q1  
\v 4 Hãy hứa với em, hỡi các thiếu nữ Giê-ru-sa-lem, 
\q2 đừng đánh thức ái tình cho đến khi đúng hạn. 
\sp Các Thiếu Nữ Giê-ru-sa-lem 
\q1  
\v 5 Ai từ hoang mạc đến 
\q2 tựa mình vào người yêu của nàng? 
\sp Thiếu Nữ 
\q1 Em đánh thức chàng dưới cây táo, 
\q2 nơi mẹ chàng đã hạ sinh chàng, 
\q2 nơi ấy người sinh chàng trong cơn đau quặn thắt. 
\q1  
\v 6 Xin đặt em như chiếc ấn trong lòng chàng, 
\q2 như chiếc ấn nơi cánh tay chàng. 
\q1 Vì ái tình mạnh như sự chết, 
\q2 lòng ghen tuông bốc cháy như âm phủ. 
\q1 Tình yêu chiếu tia như lửa, 
\q2 như ngọn lửa phừng phừng bốc cháy. 
\q1  
\v 7 Bao nhiêu nước cũng không thể làm nguội lạnh tình yêu, 
\q2 hay nhiều sông cũng không nhấn chìm được nó. 
\q1 Nếu có người đem hết tài sản mình để mua tình yêu, 
\q2 thì cũng chỉ chuốc lấy tiếng đời cười chê. 
\sp Các Anh của Thiếu Nữ 
\q1  
\v 8 Chúng tôi có người em gái nhỏ 
\q2 chưa đến tuổi cập kê. 
\q1 Chúng tôi sẽ làm gì cho em gái mình 
\q2 khi có người ngõ ý cầu hôn? 
\q1  
\v 9 Nếu em là trinh nữ, như bức tường, 
\q2 chúng tôi sẽ xây tháp bạc bảo vệ em. 
\q1 Nhưng nếu em là người lả lơi, như cánh cửa đu đưa, 
\q2 chúng tôi sẽ đóng cửa của em bằng gỗ bá hương. 
\sp Thiếu Nữ 
\q1  
\v 10 Em là trinh nữ, như bức tường; 
\q2 bây giờ ngực em như hai ngọn tháp. 
\q1 Khi người yêu em nhìn em, 
\q2 chàng vui thỏa với những gì chàng thấy. 
\q1  
\v 11 Sa-lô-môn có vườn nho tại Ba-anh Ha-môn, 
\q2 người đã để các đầy tớ thuê mướn. 
\q2 Mỗi người phải trả một nghìn miếng bạc về hoa lợi. 
\q1  
\v 12 Nhưng vườn nho của em không phải để bán, 
\q2 Sa-lô-môn chẳng cần phải trả một nghìn miếng bạc để được mảnh vườn ấy. 
\q1 Còn em sẽ trả hai trăm miếng bạc 
\q2 cho người trông coi vườn. 
\sp Chàng Trai 
\q1  
\v 13 Ôi em yêu dấu, cứ ở trong vườn, 
\q2 các bạn anh may mắn được nghe tiếng của em. 
\q2 Hãy cho anh nghe tiếng của em với! 
\sp Thiếu Nữ 
\q1  
\v 14 Nhanh lên anh, người yêu của em ơi! Như linh dương 
\q2 hay nai con trên đồi núi ngào ngạt hương thơm.