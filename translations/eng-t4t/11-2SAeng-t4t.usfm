\v 7 \w Hushai|strong="H2365"\w* replied, “\w This|strong="H2063"\w* \w time|strong="H6471"\w* \w what|strong="H2896"\w* Ahithophel \w has|strong="H3289"\w* suggested \w is|strong="H2896"\w* \w not|strong="H3808"\w* \w good|strong="H2896"\w* \w advice|strong="H6098"\w*.
\v 8 \w You|strong="H3588"\w* \w know|strong="H3045"\w* \w that|strong="H3588"\w* \w your|strong="H3045"\w* father \w and|strong="H5971"\w* \w the|strong="H3588"\w* \w men|strong="H1368"\w* \w who|strong="H5971"\w* \w are|strong="H1992"\w* \w with|strong="H3045"\w* \w him|strong="H5315"\w* \w are|strong="H1992"\w* \w strong|strong="H1368"\w* \w soldiers|strong="H4421"\w*, \w and|strong="H5971"\w* \w that|strong="H3588"\w* \w now|strong="H3588"\w* \w they|strong="H1992"\w* \w are|strong="H1992"\w* \w very|strong="H3045"\w* \w angry|strong="H4751"\w*, \w like|strong="H3808"\w* [SIM] \w a|strong="H3068"\w* mother \w bear|strong="H1677"\w* \w whose|strong="H3045"\w* \w cubs|strong="H7909"\w* \w have|strong="H5971"\w* \w been|strong="H5971"\w* stolen \w from|strong="H5315"\w* \w her|strong="H3045"\w*. Furthermore, \w your|strong="H3045"\w* father \w knows|strong="H3045"\w* \w how|strong="H3588"\w* \w to|strong="H5971"\w* \w fight|strong="H4421"\w* \w because|strong="H3588"\w* \w he|strong="H3588"\w* \w has|strong="H3588"\w* fought \w in|strong="H5315"\w* \w many|strong="H3808"\w* \w battles|strong="H4421"\w*. \w He|strong="H3588"\w* \w will|strong="H5971"\w* \w not|strong="H3808"\w* \w stay|strong="H3885"\w* \w with|strong="H3045"\w* \w his|strong="H3045"\w* \w troops|strong="H5971"\w* during \w the|strong="H3588"\w* \w night|strong="H3885"\w*.
