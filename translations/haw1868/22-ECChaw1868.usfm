\id ECC  
\h Kekahuna 
\toc1 Kekahuna 
\toc2 Kekahuna 
\toc3 Kekahuna 
\mt1 Kekahuna  
\c 1  
\s1 KEKAHUNA.  
\q1
\v 1 O NA olelo a ke kahuna, a ke keiki a Davida, oia ke alii ma Ierusalema.   
\q1
\v 2 Lapuwale o na lapuwale, wahi a ke kahuna; lapuwale o na lapuwale, pau loa na mea i ka lapuwale.   
\b  
\q1
\v 3 Heaha ka uku i ke kanaka i ka hana a pau ana i hana'i malalo iho o ka la?   
\q1
\v 4 Hele aku la kekahi hanauna, a hele mai la kekahi hanauna; aka, ua mau no ka honua.   
\q1
\v 5 Puka mai ka la, a napoo ka la, a wikiwiki aku la ia ma kona wahi i puka mai ai.   
\q1
\v 6 Puhi aku la ka makani i ke kukulu hema, a huli mai la ia i ke kukulu akau; huli ae la ia io, a io; a hoi hou ka makani i kona wahi i puhi ai.   
\q1
\v 7 Kahe aku la na muliwai a pau i ke kai, aole nae i piha ke kai; i kahi a lakou i kahe mai ai, malaila lakou e hoi hou aku ai.   
\q1
\v 8 He mea luhi na olelo a pau, aole hiki i ke kanaka ke hai aku; aole i ana ka maka i ka ike ana, aole hoi i piha ka pepeiao i ka lohe ana.   
\q1
\v 9 O na mea mamua, oia na mea e hiki mai ana; a o na mea i hanaia, oia na mea e hanaia mahope aku nei: aohe mea hou malalo iho o ka la.   
\q1
\v 10 No kekahi mea e hiki anei ke olelo mai, Eia! he mea hou keia? he mea no ia i ka wa kahiko mamua loa o kakou.   
\q1
\v 11 Aole i hoomanaoia mai na mea kahiko; a o na mea e hiki mai ana, aole e hoomanaoia ia mau mea e ka poe mahope aku.   
\b  
\q1
\v 12 Owau o ke kahuna, ua noho au i alii maluna o ka Iseraela ma Ierusalema.   
\q1
\v 13 Ua haawi au i ko'u naau e imi, a e huli me ka noeau i na mea a pau i hanaia malalo iho o ka lani. He mea kaumaba loa keia a ke Akua i haawi mai ai i na keiki a kanaka e hana'i.   
\q1
\v 14 Ua ike au i na mea a pau i hanaia malalo iho o ka lani, aia hoi, he mau mea lapuwale ia a pau a me ka luhi hewa.   
\q1
\v 15 O na mea kekee, aole ia e hoopololeiia; a o ka mea nele, aole hiki ke helu aku.   
\q1
\v 16 Ua kukakuka au me ko'u naau iho, a i iho la, Ka! ua hookiekieia'ku au, a ua hoonui au i ka naauao mamua o na mea a pau ma Ierusalema; a ua hoomaopopo aku ko'u naau i ka noeau, a me ka ike.   
\q1
\v 17 A haawi au i ko'u naau e ike i ka naauao, a e ike no hoi i ka uhauha, a me ka lapuwale; a ike iho la au, he mea luhi hewa ia.   
\q1
\v 18 No ka mea, ma ka naauao nui, malaila ke kaumaha; a o ka mea i hoonui i ka ike, hoonui no ia i ka eha.   
\c 2  
\b  
\q1
\v 1 I IHO la au i ko'u naau iho, Ina kaua, e hoao iho au ia oe ma ka lealea, a e ike i ka olioli malaila; aia ka, he mea lapuwale keia.   
\q1
\v 2 I iho la au no ka akaaka, He hehena ia; a no ka lealea, Heaha ka mea ana i hana'i?   
\q1
\v 3 Ua imi au iloko o ko'u naau e hooikaika i ko'u kino i ka waina, e pili ana no nae ko'u naau i ke akamai; a e lalau hoi au i ka mea lapuwale, a ike au i ka maikai no na keiki a kanaka e hana'i malalo iho o ka lani, i na la a pau loa o ko lakou ola ana.   
\q1
\v 4 Hoonui au i ka'u mau mea i hana'i; kukulu iho la au i na hale no'u, a kanu iho la au no'u i na mala waina;   
\q1
\v 5 Ua hana aku la au no'u i na kihapai a me na wahi ululaau, a ua kanu iho la au iloko o ia mau wahi i na laau hua a pau;   
\q1
\v 6 Ua eli iho la au no'u i na punawai e hoopulu i kahi e ulu ai na laau;   
\q1
\v 7 Ua imi a loaa ia'u na kauwakane a me na kauwawahine, a ua hanau hoi iloko o ko'u hale na kauwa; a ia'u no hoi na holoholona nui a me na holoholona liilii he lehulehu, a oi aku i ka poe mamua ma Ierusalema.   
\q1
\v 8 Ua hooiliili no hoi au no'u i ke kala, a me ke gula a me ka waiwai o na'lii a o na aina hoi; ua imi ia'u a loaa kekahi poe kane mele, a me kekahi poe wahine mele, a me na mea e olioli ai na keiki a kanaka, he wahine a me na haiawahine.   
\q1
\v 9 Pela, ua lilo au i mea nui a oi aku i na mea a pau i noho mamua ma Ierusalema; a o ko'u naauao, ua mau ia mea ia'u.   
\q1
\v 10 O na mea a pau a ko'u mau maka i makemake ai, aole au i hoole ia lakou; aole aua au i ko'u naau i ka olioli a pau, no ka mea, olioli ko'u naau i ka'u hana a pau; a oia ka uku no'u i ka'u hana a pau.   
\q1
\v 11 Ua nana au i na mea a pau a ko'u mau lima i hana'i, a me ka hana a'u i hooluhi ai ia'u iho; aia hoi, he mea lapuwale a pau a me ka luhi hewa, aohe mea e pono ai malalo iho o ka la.   
\b  
\q1
\v 12 A haliu au e ike i ka naauao, a me ka uhauha, a me ka lapuwale; no ka mea, heaha ka mea a ke kanaka [e hana'i] i kiki mai mahope o ke alii? O ka mea wale no i hanaia mamua.   
\q1
\v 13 Alaila, ike iho la au, ua oi aku ka naauao mamua o ka naaupo, me he malamalama la mamua o ka pouli.   
\q1
\v 14 O ka mea naauao, aia kona mau maka i kona poo, aka, e hele ana ka mea naaupo ma ka pouli; a ike no hoi au e loaa ia lakou a pau ka hopena hookahi.   
\q1
\v 15 I iho la au iloko o ko'u naau, E like me ka mea i loaa i ka mea naaupo, pela no ka mea i loaa mai ia'u. A no ke aha la i oi kuu naauao? I iho la au iloko o ko'u naau, He mea lapuwale hoi keia.   
\q1
\v 16 A ma neia hope aku, aole i hoomanaoia ke kanaka naauao mamua o ka mea naaupo, no ka mea, o na mea e noho nei, i na la e hiki mai ana, e pau ia i ka hoopoinaia. A pehea ka make ana o ka mea naauao? Ua like no me ko ka mea naaupo.   
\q1
\v 17 No ia mea, ua hoopailua au i ko'u ola ana, no ka mea, ua kaumaha au i ka hana i hanaia malalo iho o ka la; no ka mea, ua pau na mea i ka lapuwale a me ka luhi hewa.   
\b  
\q1
\v 18 Ua hoopailua hoi au i ka hana a pau a'u i hana'i malalo iho o ka la; no ka mea, e waiho auanei au ia mea no ke kanaka e hiki mai ana mahope o'u.   
\q1
\v 19 A owai la ka mea i ike, he mea naauao paha oia, he mea naaupo paha? aka, oia no ia maluna o na mea a pau a'u i hana naauao ai malalo iho o ka lani. He mea lapuwale keia.   
\q1
\v 20 Alaila imi iho la au e hoopauaho i kuu naau i ka hana a pau a'u i hana'i malalo iho o ka la.   
\q1
\v 21 No ka mea, aia no ke kanaka nana e hana ma ka naauao, a me ke akamai, a me ka pomaikai, aka, e waiho no oia i kana i ke kanaka nana i hana ole i keia mau mea, i hooilina nona. He mea lapuwale keia, a me ka luhi hewa.   
\q1
\v 22 No ka mea, heaha ka mea i loaa i ke kanaka i kana hana a pau, a me ka makemake o kona naau, ka mea ana i hana'i malalo iho o ka la?   
\q1
\v 23 No ka mea, ua kaumaha kona mau la a pau loa, a ua luhi kana hana ana, aole nae i maha kona naau i ka po. He mea lapuwale keia.   
\b  
\q1
\v 24 Aohe mea maikai i ke kanaka e like me keia, e ai ai oia, a e inu ai hoi, a e hoohauoli ai i kona naau iho i ka maikai ma kana hana ana. Ua ike au, no ko ke Akua lima mai no ia.   
\q1
\v 25 No ka mea, owai ka mea e ai ai, a owai ka mea e lealea ai malaila, i ole au?   
\q1
\v 26 No ka mea, ua haawi mai ke Akua i ke kanaka maikai imua ona, i naauao, a me ke akamai, a me ka olioli; aka, i ke kanaka hewa haawi mai ia i ka hana kaumaha, nana e hooiliili a e hoahu hoi, e haawi aku i ke kanaka maikai imua o ke Akua. He mea lapuwale keia, a me ka luhi hewa.   
\c 3  
\b  
\q1
\v 1 A IA he manawa no na mea a pau, a he wa hoi no na hana a pau, malalo iho o ka lani.   
\q1
\v 2 He wa e hanau ai, A he wa hoi e make ai; He wa e kanu ai, A he wa hoi e uhuki ai i ka mea i kanuia;   
\q1
\v 3 He wa e pepehi ai, A he wa hoi e hoola ai; He wa e wawahi ai, A he wa hoi e kukulu iho ai;   
\q1
\v 4 He wa e uwe ai, A he wa hoi e akaaka ai; He wa e kanikau ai, A he wa hoi e haa ai;   
\q1
\v 5 He wa e hoolei aku ai i na pohaku, A he wa hoi e hoiliili ai i na pohaku; He wa e apo ai, A he wa e apo ole ai.   
\q1
\v 6 He wa e imi ai, A he wa hoi e lilo aku ai; He wa e malama'i, A he wa hoi e hoolei wale aku ai.   
\q1
\v 7 He wa e haehae aku ai, A he wa hoi e humuhumu iho ai; He wa e hamau ai, A he wa hoi e olelo ai.   
\q1
\v 8 He wa e aloha aku ai, A he wa hoi e inaina aku ai; He wa kaua, A he wa maluhia.   
\b  
\q1
\v 9 Heaha ka uku a ka mea hana i ka mea ana i hana'i?   
\q1
\v 10 Ua ike au i ka hana a ke Akua i haawi mai ai i na keiki a kanaka e hana'i.   
\q1
\v 11 Ua hana mai la oia i na mea a pau he maikai i kona manawa; a hookomo no hoi oia i ko ke ao nei iloko o ko lakou mau naau, i ike ole ke kanaka i ka hana a ke Akua i hana'i, mai ka mua a hiki i ka hope.   
\b  
\q1
\v 12 Ua ike au, aohe mea maikai iloko o ia mau mea, ke ole e hauoli [ke kanaka,] a e hana maikai i kona ola ana.   
\q1
\v 13 A o kela kanaka keia kanaka e ai, a e inu hoi, a e ike i ka maikai o kana hana a pau, oia ka haawina a ke Akua.   
\q1
\v 14 Ua ike au, o na mea a pau a ke Akua i hana'i, e mau loa no ia, aole e hiki i kekahi ke hoonui, aole e hiki i kekahi he hooemi; a na ke Akua no i hana mai i makau lakou imua ona.   
\q1
\v 15 O ka mea mamua, oia ka mea e noho nei, a o ka mea e hiki mai ana, oia na mea mamua aku; a imi mai ke Akua i ke ano o na mea i hala aku nei.   
\b  
\q1
\v 16 A ike aku la au malalo iho o ka la i kahi e ahaolelo ai, a malaila no ka hewa; a i kahi o ka pono, a malaila hoi ka hana ino.   
\q1
\v 17 I iho la au iloko o ko'u naau, e hookolokolo ana ke Akua i ka poe pono, a me ka poe hewa; no ka mea, oia ka wa no na mea a pau a me na hana a pau.   
\q1
\v 18 I iho la au iloko o ko'u naau no na keiki a kanaka, i hoao ke Akua ia lakou i ike lakou ia lakou iho, he poe holoholona.   
\q1
\v 19 No ka mea, o ka mea e hiki mai i na keiki a kanaka, e hiki mai no ia i na holoholona, hookahi mea ia lakou; e like me ka make ana o kela, pela no ka make ana o keia, hookahi hanu ia lakou a pau; aohe mea o ke kanaka i oi aku mamua o ka holoholona; no ka mea, ua pau na mea i ka lapuwale.   
\q1
\v 20 Ua hele lakou a pau i kahi hookahi; no ka lepo mai lakou a pau, a e hoi hou aku ana lakou i ka lepo.   
\q1
\v 21 Owai ka mea ike i ke ea o na keiki a kanaka, ka mea i pii iluna, a me ke ea o na holoholona ka mea i iho ilalo i ka honua?   
\q1
\v 22 No ia mea, ike iho la au, aohe mea maikai e ae i ke kanaka, o ka hauoli wale no i kana hana ana; no ka mea, oia kona haawina. A owai ka mea e hoike ia ia i ka mea e hiki mai ana mahope ona?   
\c 4  
\b  
\q1
\v 1 A LAILA, haliu au a ike aku la i na mea luhi i hanaia malalo iho o ka la, aia hoi, na waimaka o ka poe i hooluhiia, aohe mea nana lakou e kokua mai; a ma ka aoao o ka poe nana lakou i hooluhi, he ikaika; aka, aohe mea nana lakou e kokua mai.   
\q1
\v 2 No ia mea, hoomaikai aku la au i ka poe make, ka poe i make i ka wa i hala aku nei, mamua o ka poe ola, ka poe ola i keia wa e noho nei kakou.   
\q1
\v 3 Oia hoi, ua oi aku mamua o laua a elua ka maikai o ka mea i hanau ole ia, ka mea i ike ole i ka hana ino i hanaia malalo iho o ka la.   
\b  
\q1
\v 4 Ua ike au i na mea luhi a pau, a me na hana pololei a pau, aia hoi, no ia mau mea, ua huahuaia mai ke kanaka e kona hoalauna. He mea lapuwale keia a me ka luhi hewa.   
\q1
\v 5 Ua hookui mai la ka mea naaupo i kona mau lima, a ai iho la i kona io iho.   
\q1
\v 6 Ua oi aku ka piha ana o ka lima hookahi me ka noho oluolu mamua o ko na lima elua me ka hana kaumaha, a me ka luhi hewa.   
\b  
\q1
\v 7 Alaila, haliu hou ae la au, a ike i ka mea lapuwale malalo iho o ka la.   
\q1
\v 8 Aia, he mea hookahi, aole ona lua, aole ana keiki, aole ona hoahanau; aka, o kana hana ana, aole e pau, aole pili iki kona mau maka i ka nana i ka waiwai, aole ia i ninau iho, No wai ko'u e hana nei, a i hoonele i ko'u uhane i ka maikai? He mea lapuwale keia, a he mea luhi loa no hoi.   
\b  
\q1
\v 9 Ua oi aku ka maikai o na mea elua mamua o ka mea hoohahi; no ka mea, ia laua ka uku maikai no ka laua hana ana.   
\q1
\v 10 No ka mea, ina e haule kekahi, e hoala kekahi i kona hoa; aka, auwe hoi ka mea hookahi i kona haule ana, no ka mea, aohe mea nana ia e hooala mai.   
\q1
\v 11 Ina i moe pu na mea elua e pumehana no laua; aka hoi, pehea a mehana ai ka mea hookahi?   
\q1
\v 12 Ina e hana eha ia mai kekahi, e hiki no i na mea elua ke lanakila maluna o ia mea, a o ke kaula kaakolu, aole ia e moku koke.   
\b  
\q1
\v 13 Oi aku ka maikai o ke keiki ilihune me ka naauao, mamua o ke alii elemakule me ka naaupo, ka mea hiki ole ke aoia mai.   
\q1
\v 14 No ka mea, puka mai ia mai ka hale hooluhi o alii ai; aka, o ka mea i hanau alii ia ua lilo ia i mea ilihune.   
\q1
\v 15 Ike iho la au i ka poe ola a pau e hele ana malalo iho o ka la, me ka lua o ke keiki, i ku i kona hakahaka.   
\q1
\v 16 Aole pau i ka heluia na kanaka, ka poe mamua o lakou; a o ka poe mahope, aole lakou olioli ia ia. He mea lapu wale keia, a me ka luhi hewa.   
\c 5  
\b  
\q1
\v 1 E MALAMA oe i kou wawae i kou hele ana i ka hale o ke Akua, e hoolohe koke, aole hoi oe e haawi i ka mohai a ka poe naaupo, no ka mea, aole lakou i manao pono, ua hana hewa lakou.   
\q1
\v 2 Mai olelo wawe kou waha, aole hoi e wikiwiki kou naau e hoopuka aku i kekahi mea imua o ke Akua; no ka mea, aia ke Akua ma ka lani, aka, eia no oe ma ka honua nei, no ia mea, e hoouuku i kau mau olelo.   
\q1
\v 3 No ka mea, no ka nui o ka hana, e hiki mai ai ka moeuhane; a o ka leo o ka naaupo, ua ikeia no ka lehulehu o kana olelo ana.   
\q1
\v 4 Ina e olelo oe e hoohiki i ke Akua, mai hoohakalia oe i ka hooko aku, no ka mea, aole oluolu ke Akua, i ka poe naaupo; e hooko aku oe i kau mea e hoohiki ai.   
\q1
\v 5 Ua oi aku kou maikai ke hoohiki ole, mamua o kou maikai ke hoohiki oe, aole hoi e hooko aku.   
\q1
\v 6 E malama oe i kou waha i ole e hoohihia'i kou kino; mai olelo oe imua o ke kahuna, He kuhi hewa ia. No ke aha la e huhu mai ai ke Akua i kou leo, a e hoohiolo i ka hana a kou mau lima?   
\q1
\v 7 No ka mea, ma ka lehulehu o na moenhane, a me na olelo he nui wale, aia na mea lapuwale. Aka hoi, e makau aku oe i ke Akua.   
\b  
\q1
\v 8 I kou ike ana i ka hooluhiia o ka poe ilihune, a me ka hookahuli ana i ka oiaio, a me ka pono ma ka aina, mai kahaha kou naau i keia, no ka mea, o ka mea kiekie o na mea kiekie a pau, oia ka mea i ike mai, a aia hoi na mea kiekie maluna o lakou.   
\b  
\q1
\v 9 O ka hua o ka honua, na na mea ia a pau; a o ke alii pu kekahi i hanaiia e ka aina.   
\b  
\q1
\v 10 O ka mea makemake i ke kala, aole pau kona ono i ke kala; a o ka mea makemake i na mea nui, aole ia e ana i ka nui o ka waiwai. He mea lapuwale keia.   
\q1
\v 11 I ka mahuahua ana o na mea maikai, mahuahua no hoi ka poe e hoopau ana ia mau mea; a heaha ka pono i loaa mai i ka poe nana ia mau mea? O ka ike wale ana o ko lakou mau maka.   
\q1
\v 12 Ua lea ka hiamoe o ka poe hana, ke ai unku lakou a ke ai nui hoi; aka, o ka maona nui o ka mea waiwai, he mea ia e lea ole ai kona hiamoe ana.   
\b  
\q1
\v 13 Eia kekahi mea pono ole a'u i ike ai malalo iho o ka la, o ka waiwai i malamaia i mea e poino ai ka poe nona ia.   
\q1
\v 14 Aka, e pau auanei keia waiwai i ka hana pono ole; a ua hanau aku kana keiki, aka, aohe mea ma kona lima.   
\q1
\v 15 E like me kona puka ana mai, mai ka opu mai o kona makuwahine, pela no ia e hoi hou aku ai me ke kapa ole, e like me kona puka ana mai; aole hiki ia ia ke lawe aku ma kona lima i kekahi mea ana i hana'i.   
\q1
\v 16 Eia ka mea pono ole; e like loa me kona puka ana mai, pela no kona hele ana aku. Heaha kona pono i kana hana ana no ka makani?   
\q1
\v 17 A o kona mau la a pau, ua ai oia iloko o ka pouli, a i kona wa mai, ua kaumaha oia no ka huhu.   
\b  
\q1
\v 18 Aia hoi, ka mea a'u i ike ai, he mea maikai keia, a he nani hoi, e ai kekahi, a e inu hoi, a e olioli i ka hana a pau ana i hana'i malalo iho o ka la, i na la a pau loa o kona ola ana a ke Akua i haawi mai ai nana; no ka mea, oia kona haawina.   
\q1
\v 19 A o kela kanaka, keia kanaka, ka mea a ke Akua i haawi mai ai i ka waiwai a me ka lako, a ua ae mai hoi oia i kana ai ana, a me kona lawe ana i kona haawina, a i kona olioli ana i ka hana ana i hana'i. Oia ka mea a ke Akua i haawi mai ai.   
\q1
\v 20 Aole ia e hoomanao nui i na la o kona ola ana; no ka mea, ua ae mai ke Akua i ka olioli o kona naau.   
\c 6  
\b  
\q1
\v 1 A IA no ka mea pono ole a'u i ike ai malalo iho o ka la, a he mea nui la maluna o na kanaka.   
\q1
\v 2 O ke kanaka ka mea a ke Akua i haawi mai ai i ka waiwai nona, a me ka lako me ka hanohano; aole nele iki kona uhane i na mea ana e makemake ai, aka hoi, aole i ae mai ke Akua e ai ia i keia mau mea, aka, ua aiia kana e ka malihini. He mea lapuwale keia, a he mea ino hoi.   
\b  
\q1
\v 3 Ina i loaa i ke kanaka na keiki hookahi haneri, a ola ia i na makahiki he nui loa, aole okana mai na la o kona mau makahiki, aole nae i maona kona uhane i ka maikai, aole hoi ona wahi e kanuia'i; ke hai aku nei au, ua oi aku ka maikai o ke keiki oiliwale i kona.   
\q1
\v 4 No ka mea, ua puka mai oia ma ka lapuwale, a hele aku la ia ma ka pouli, a ua uhiia kona inoa i ka pouli.   
\q1
\v 5 Aole hoi ia i nana i ka la, aole oia i ike iki, ua oi aku ko ia nei oluolu i ko ia la.   
\b  
\q1
\v 6 Oia, ina e ola ia i na makahiki hookahi tausani ke paluaia, aole hoi oia i ike i ka maikai. Aole anei e hele na mea a pau i kahi hookahi?   
\b  
\q1
\v 7 O na hana a pau a ke kanaka, na kona waha iho no ia, aole nae i maona kona opu.   
\q1
\v 8 Ma na mea hea i oi aku ai ka mea naauao mamua o ka mea naaupo? Heaha ka mea i loaa i ka ilihune, ka mea i ike i ka hele ana imua o ka poe ola?   
\b  
\q1
\v 9 Ua oi aku ka maikai o ka ike maka ana mamua o ka hele ana'ku o ka manao. He mea lapuwale keia, a me ka luhi hewa.   
\b  
\q1
\v 10 O ka mea i hala aku nei, ua kapaia kona inoa, a o ke kanaka hoi ua ikeia oia, aole hiki ia ia ke ku e i ka mea mana mamua ona.   
\b  
\q1
\v 11 Nolaila, ua mahuahua ka lapuwale ma na mea he nui loa; a pehea la e pono ai ke kanaka?   
\q1
\v 12 No ka mea, owai ka mea i ike i ka mea e pono ai ke kanaka i kona ola ana, i na la a pau o kona ola lapuwale ana i hoopau ai me he aka la; a owai hoi ka mea nana e hai aku i ke kanaka i na mea e hiki mai ana mahope ona malalo iho o ka la?   
\c 7  
\b  
\q1
\v 1 U A oi aku ka inoa maikai mamua o ka mea poni maikai, a o ka la make mamua o ka la i hanau ai.   
\b  
\q1
\v 2 Ua oi aku ka maikai o ka hele ana i ka hale kanikau mamua o ka hele ana i ka hale ahaaina; no ka mea, malaila ka hopena o na kanaka a pau, a e hoopili ke kanaka ola ia mea i kona naau iho.   
\q1
\v 3 Ua oi aku ka maikai o ka uwe ana mamua o ka akaaka; no ka mea, ma ka inoino o ka maka, e maikai ai ka naau.   
\q1
\v 4 O ka naau o ka mea naauao, aia no ia ma ka hale kanikau; aka hoi, o ka naau o ka mea naaupo, aia no ia ma ka hale paani.   
\q1
\v 5 Ua oi aku ka maikai o ka lohe ana i ka oleloao a ka poe naauao, mamua o ko ke kanaka lohe ana i ka mele lea a ka poe naaupo.   
\q1
\v 6 No ka mea, e like me ka paapaaina o na kakalaioa malalo iho o ka ipu hao, pela no ka akaaka ana o ka mea naaupo. He mea lapuwale hoi keia.   
\b  
\q1
\v 7 No ka mea, o ka hooluhi, oia ka mea e pupule ai ka mea naauao; a o ke kipe he mea ia e lolelua ai ka naau.   
\q1
\v 8 Ua oi aku ka maikai o ka hope o kekahi mea mamua o ka hoomaka ana; a o ka mea naau hoomanawanui mamua o ka mea hookiekie.   
\q1
\v 9 Mai wikiwiki kou naau, e huhu aku; no ka mea, o ka huhu, aia no ia ma ka naau o ka poe naaupo.   
\q1
\v 10 Mai olelo ae oe, No ke aha la i oi aku ai ka maikai o na la kahiko mamua o keia mau la? No ka mea, aole i naauao kau ninau ana mai pela.   
\b  
\q1
\v 11 Ua maikai ka naauao me ka waiwai hooili, oia hoi ka mea e pono ai na mea i ike i ka la.   
\q1
\v 12 No ka mea, o ka naauao, oia ka mea e malu ai, a o ke kala oia hoi kekahi mea e malu ai; aka, eia ka maikai o ka ike, o ka naauao, oia ka mea e ola'i ka poe nona ia.   
\q1
\v 13 E noonoo oe i ka hana a ke Akua i hana'i; no ka mea, owai ka mea e hiki ai ke hoopololei i ka mea ana i hana ai a kekee?   
\q1
\v 14 I ka la pomaikai e olioli ai oe, a i ka la popilikia e noonoo ai. Ua hoonoho ke Akua i kekahi e kupono i kekahi, i loaa ole ai i ke kanaka kekahi mea e hiki mai ana mahope ona.   
\b  
\q1
\v 15 Ua ike au i keia mau mea a pau i na la o kou noho lapuwale ana; aia no ke kanaka hoopono e make ana i kona pono iho; a eia no ka mea hewa e hooloihi ana i kona mau la iloko o kona hewa.   
\q1
\v 16 Mai hoonui i koa pono, aole hoi oe e hoomahuahua i kou naauao; no ke aha la oe e hoomake ia oe iho?   
\q1
\v 17 Mai hoonui oe i kou hewa, aole hoi e noho naaupo; no ke aha la oe e make ai mamua o kou manawa?   
\q1
\v 18 He mea maikai nou e lalau i kela, aole hoi e hookuu i keia mai kou lima aku; no ka mea o ka mea i makau i ke Akua, oia ka mea e puka, mai ia mau mea a pau.   
\b  
\q1
\v 19 O ka naauao ka mea e ikaika ai ka mea naauao mamua o na kanaka koikoi he umi iloko o ke kulanakauhale.   
\q1
\v 20 No ka mea, aohe kanaka pono ma ka honua, nana e hana maikai, me ka hana hewa ole.   
\q1
\v 21 Mai manao hoi oe i na olelo a pau loa i oleloia, o lohe auanei oe i kau kauwa e hoino ana ia oe.   
\q1
\v 22 No ka mea, ua ike pinepine kou naau iho, ua hoino oe ia hai.   
\b  
\q1
\v 23 Ua hoao iho la au i keia mau mea a pau me ka naauao. I iho la au, e lilo auanei au i kanaka naauao, aka hoi, na mamao loa ia mea mai o'u aku.   
\q1
\v 24 O ka mea ma kahi loihi aku, a hohonu loa hoi, owai ka mea e loaa'i?   
\q1
\v 25 Ua haawi au i ko'u naau e ike, a e huli, a e imi hoi i ka naauao, a me ke ano [o na mea,] a e ike hoi i ka hewa o ka naaupo, a o ka noho lapuwale, a me ka uhauha.   
\q1
\v 26 A na loaa mai ia'u keia, o ka wahine nona ka naau e hoohihia ai, a e hoohei ai, nona hoi na lima e paa ai me he kaula la, ua oi aku kona awaawa mamua o ka make; o ka mea maikai imua o ke Akua e pakele no ia mai ona aku la, aka, o ka mea hewa, e hihia auanei oia ia ia.   
\b  
\q1
\v 27 Aia hoi! ua loaa ia'u keia, wahi a ke kahuna, ma ka helu pakahi ana no e loaa mai ai ka huina.   
\q1
\v 28 Ka mea a ko'u uhane i imi ai, aole nae i loaa; hookahi kanaka mawaena o kekahi tausani ua loaa mai ia'u; aka, o ka wahine mawaena o keia poe a pau loa, aole i loaa.   
\q1
\v 29 Aia hoi, eia ka mea i loaa mai ia'u: Hana iho la ke Akua i ke kanaka i mea pololei, aka hoi, ua imi oia i na mea kekee he nui wale.   
\c 8  
\b  
\q1
\v 1 O WAI ka mea i like me ka mea naauao? Owai ka mea i ike i ka hoakaka ana i ka olelo? Ka naanao o ke kanaka, oia ka mea e oluolu ai kona maka, a ua hala kona maka haaheo.   
\b  
\q1
\v 2 Ke ao aku nei au ia oe, e malama i ke kanawai o ke alii, no ka hoohiki ana i ke Akua.   
\q1
\v 3 Mai wikiwiki oe i kou hele ana mai kona alo aku: mai kupaa oe ma ka mea ino; no ka mea, ke hana la ia i na mea a pau loa ana i makemake ai.   
\q1
\v 4 Ma ka olelo a ke alii, aia no ka mana; a owai la ka mea e hiki ke olelo aku ia ia, Heaha kau i hana'i?   
\b  
\q1
\v 5 O ka mea malama i ke kanawai, aole ia e ike i ka mea ino; a o ka naau o ka mea akamai, ua ike ia i ka manawa a me ka hoopono.   
\b  
\q1
\v 6 No ka mea, aia no i na mea a pau he wa no, a me ka hoopono; a ua nui ke kaumaha maluna o ke kanaka.   
\q1
\v 7 No ka mea. aole ia i ike i ka mea e hiki mai ana; a o ka wa e hiki mai ai, owai la ka mea e hiki ke hai aku ia ia?   
\q1
\v 8 Aohe kanaka e hiki ke malama i ka hanu a paa ia, aohe mea ikaika i ka la e make ai; aole hoi i hookuuia kekahi mai keia kaua aku; aole nae e hoopakele ka hewa i ka poe hewa.   
\q1
\v 9 Ua ike au i keia mau mea a pau, a halalo kuu naau i na hana a pau i hanaia malalo iho o ka la, aia i kekahi wa no e alii ai kekahi kanaka maluna o kekahi i mea e poino ai oia iho.   
\b  
\q1
\v 10 A pela no, ua ike au i ke kanuia o ka poe hewa, ua hele lakou iloko o kahi hemolele, a hoi mai, a ua poina lakou ma ke kulanakauhale, kahi a lakou i hana'i pela. He mea lapuwale keia.   
\q1
\v 11 No ka hooko koke ole ia mai o ka olelo hoahewa i ka hana ino; no ia mea, ua paa loa ka naau o na keiki a kanaka e hana hewa.   
\b  
\q1
\v 12 Ina e hana ino ka mea hewa, pahaneri ka hana ana, a ua hooloihiia kona mau la, ua ike no au, ua pomaikai ka poe makau i ke Akua, ka poe makau imua ona.   
\q1
\v 13 Aole e pomaikai ka mea hewa, aole nae ia e hooloihi i kona mau la, no ka mea, me he aka la ka mea i makau ole imua i ke alo o ke Akua.   
\q1
\v 14 Eia kekahi mea lapuwale i hanaia ma ka honua; aia no kekahi poe pono, a ua ili wale ia lakou e like me ka hana a ka poe hewa, a aia hoi ka poe hewa, ua ili wale ia lakou e like me ka hana a ka poe pono. I iho la au, he mea lapuwale keia.   
\q1
\v 15 Alaila, mahalo iho la au i ka olioli, no ka mea, aohe mea maikai i ke kanaka malalo iho o ka la i oi aku i ka ai ana, i ka inu, a me ka olioli; he mea mau keia ia ia no kana haua, i na la o kona ola ana a ke Akua i haawi mai ai ia ia malalo iho o ka la.   
\b  
\q1
\v 16 Alaila, haawi ae la au i ko'u naau e ike i ka naauao, a e ike hoi i ka mea i hanaia ma ka honua; no ka mea, aia no kekahi mea i pili ole ai kona mau maka i ka hiamoe i ka po a me ke ao:   
\q1
\v 17 A ike iho la au i na hana a pau a ke Akua, no ka mea, aole hiki i ke kanaka ke hoomaopopo i na hana i hanaia malalo iho o ka la; oiaio hoi, ina e hooikaika ke kanaka e imi, aole nae i maopopo, ina e olelo ka mea naauao e ike ia, aole nae e hiki ia ia ke hoomaopopo aku.   
\c 9  
\b  
\q1
\v 1 NO keia mau mea a pau, ua haawi au i ko'u naau e noonoo i keia. Aia no iloko o ka lima o ke Akua ka poe pono, a me ka poe naauao, a me ka lakou hana ana; aole ike kekahi kanaka i ke aloha, aole i ka inaina; aia na mea a pau imua o lakou.   
\b  
\q1
\v 2 Ua loaa i na kanaka a pau na mea like. Hookahi no hope i ka mea pono, a me ka mea hewa; i ka mea maikai, i ka mea maemae, a me ka mea maemae ole; i ka mea i mohai aku, a me ka mea i mohai ole aku. E like me ka mea maikai, pela no ka mea hewa; me ka mea hoohiki, pela no ka mea makau i ka hoohiki ana.   
\q1
\v 3 He mea pono ole keia ma na mea i hanaia malalo iho o ka la; aia hookahi hope i loaa mai i na kanaka a pau. Oiaio, o ka naau o na keiki a kanaka, ua piha i ka ino, aia no ka ulala iloko o ko lakou naau i ko lakou ola ana, alaila, [hele lakou] i ka make.   
\b  
\q1
\v 4 No ka mea, ua laua ka manao, no ka mea i huipuia me na mea ola a pau; no ka mea, ua oi aku ka ilio ola mamua o ka liona make.   
\q1
\v 5 No ka mea, ua ike ka poe ola e make auanei lakou; aka, o ka poe make, aole lakou i ike i kekahi mea, aole he uku i koe ia lakou; no ka mea, ua nalowale ko lakou mea i hoomanaoia'i.   
\q1
\v 6 O ko lakou aloha, a me ko lakou inaina, a me ko lakou huahua, ua pau ia mau mea; ua nele mau loa lakou i ka haawina ole, ma na mea a pau i hanaia malalo iho o ka la.   
\b  
\q1
\v 7 E hele oe, e ai i kau berena, me ka oluolu, a e inu hoi i kou waina me ka naau olioli; no ka mea, ano, ua maliu mai ke Akua i kau hana ana.   
\q1
\v 8 I na manawa a pau e keokeo wale no kou kapa komo, aole hoi e hoonele i kou poo i ka aila ala.   
\q1
\v 9 E noho oluolu pu oe me ka wahine au i aloha'i i na la a pau o kou ola lapuwale ana, i haawiia mai ai ia oe malalo iho o ka la, i kou mau la lapuwale a pau loa; no ka mea, oia kou haawina i kou ola ana, a me ka hana ana hoi au i hana'i malalo iho o ka la.   
\b  
\q1
\v 10 O na mea a pau i loaa mai i kou lima e hana'i, e hana oe me kou ikaika; no ka mea, ma ka lua kupapau kahi au e hele aku nei, aole hana, aole noonoo, aole ike, aole naauao.   
\b  
\q1
\v 11 Alaila, haliu ae la au a ike malalo iho o ka la, aole no ka poe mama ke kukini ana, aole hoi no ka poe ikaika ke kaua, aole no ka poe naauao ka berena, aole no ka poe akamai ka waiwai, aole hoi no ka poe maiau ke aloha; aka, o ka manawa, a me na mea hiki wale ke loaa i na kanaka a pau.   
\q1
\v 12 No ka mea, aole ike ke kanaka i kona manawa; e like me na ia i hooheiia i ka upena ino, a e like me na manu i paheleia iloko o ke kipuka, pela no i paheleia'i na keiki a kanaka i ka wa ino, i haule koke ia maluna o lakou.   
\b  
\q1
\v 13 Eia ka mea naauao a'u i ike ai malalo iho o ka la, a he mea nui ia ia'u;   
\q1
\v 14 Aia ke kulanakauhale uuku, aole nui na kanaka maloko; a hiki mai kekahi alii nui, a hoopopilikia ia wahi, a kukulu iho i pa kaua nui e ku e aku i ua kulanakauhale la.   
\q1
\v 15 A ua loaa malaila he kanaka ilihune naauao, a ua hoopakele ia i ke kulanakauhale ma kona naauao, aka hoi, aole kekahi kanaka i hoomanao i ua kanaka ilihune la.   
\q1
\v 16 Alaila, i iho la au, Ua oi aku ka naauao mamua o ka ikaika; aka hoi, ua hoowahawahaia ka naauao o ka mea ilihune, aole hoi i hooloheia kana olelo.   
\q1
\v 17 Ua loheia no na olelo a ka poe naauao ma kahi noho malu ai, mamua o ke kala ana o ka luna o ka poe naaupo.   
\q1
\v 18 Ua oi aku ka naauao mamua o na mea kaua; aka hoi, ua hoohiolo ke kanaka hewa hookahi i ka maikai he nui wale.   
\c 10  
\b  
\q1
\v 1 O NA nalo make, he mea ia e pilau ai ka laau hamo a ka mea hana laau, pela no ka hana uhauha iki ana, ka mea i manaoia he naauao, a he hanohano hoi.   
\q1
\v 2 O ka naau o ka mea naauao, aia no ia ma kona lima akau; aka hoi, o ka naau o ka mea naaupo, aia no ia ma kona lima hema.   
\q1
\v 3 Aia hoi i ka hele ana o ka mea naaupo ma ke alanui, ua nalowale kona ike, a ua i iho la ia no na mea a pau, he naaupo ia.   
\q1
\v 4 Ina e ku o ia oe ka manao o ke alii, mai haalele i kou wahi; no ka mea, o ka noho malie, oia ka mea e hooluolu aku ai ka huhu nui.   
\b  
\q1
\v 5 Aia ka hewa au i ike iho ai malalo iho o ka la, e like me ka hewa i puka mai ai mai ke alii mai.   
\q1
\v 6 Ua hoonohoia ka naaupo ma na wahi kiokie, a o ka mea waiwai, ua noho oia ma kahi haahaa.   
\q1
\v 7 Ua ike au i na kauwa maluna o na lio, a i na'lii e hele wawae ana ma ka honua, me he poe kauwa la.   
\b  
\q1
\v 8 O ka mea i eli i ka lua, e haule auanei oia iloko; a o ka mea i wawahi i ka pa, e nahu mai ka nahesa ia ia.   
\q1
\v 9 O ka mea e uneune i na pohaku, e eha auanei oia ia lakou; a o ka mea i kaka iho i ka wahie, e moku auanei ia ilaila.   
\q1
\v 10 Ina kumumu ka hao, aole hoi ia e hookala i kona maka, alaila pono ke hoonui i ka ikaika; aka, he pono ka naauao i mea e hoopomaikai ai.   
\q1
\v 11 Oiaio, e nahu mai ka nahesa ke hoowalewale ole ia mai; aole hoi i oi aku ka maikai o ka mea holoholo olelo.   
\q1
\v 12 O na olelo a ka waha o ka mea naauao, ua lokomaikai no, aka, o na lehelehe o ka mea naaupo, e ale auanei ia ia iho.   
\q1
\v 13 O ka mua o na olelo a kona waha, he mea lapuwale ia; a o ka hope o kona waha, he huhu kolohe no ia.   
\q1
\v 14 Ua hoomahuahua ka mea naaupo i kana mau olelo; aole nae i ike ke kanaka i na mea e hiki mai ana; a o na mea e hiki mai ana mahope ona, nawai e hai aku ia ia?   
\q1
\v 15 O ka hana a ka poe naaupo, he mea ia e hoomaluhiluhi ai ia lakou, no ka mea, aole ia i ike i ka hele i ke kulanakauhale.   
\b  
\q1
\v 16 Auwe oe, e ka aina, i ka wa i noho ai he keiki i alii nou, a e ai ai hoi kou poe kaukaualii i ke kakahiaka!   
\q1
\v 17 Pomaikai oe, e ka aina, i ka wa i noho ai ke keiki a na'lii i alii nou, a e ai ai kau poe kaukaualii i ka wa pono, no ka ikaika, aole no ka uhauha.   
\b  
\q1
\v 18 No ka palaualelo, ua popopo na kaola; a no ka molowa o na lima, ua kulu ka hale.   
\b  
\q1
\v 19 O ka ahaaina he mea ia e akaaka ai, a o ka waina, he mea ia e olioli ai; aka, o ke kala, he mea ia e hiki ai na mea a pau.   
\b  
\q1
\v 20 Mai hoino aku oe i ke alii, aole hoi ma kou manao; mai hoino aku hoi i ka poe waiwai iloko o kou keena moe, no ka mea, o na manu o ka lewa, e lawe aku lakou i ka leo, a o na mea eheu, na lakou hoi e hai aku ia mea.   
\c 11  
\b  
\q1
\v 1 E HOOLEI i kau bereua maluna iho o ka wai; no ka mea, a hala na la he nui loa, e loaa hou mai no ia ia oe.   
\q1
\v 2 E puunaue aku na na mea ehiku, a me na mea ewalu paha; no ka mea, aole oe i ike i ka hewa e hiki mai ana maluna o ka honua.   
\q1
\v 3 Ina i piha na ao i ka ua, alaila ua haule mai maluna o ka honua; a ina e hina ka laau i ke kukulu hema, a i ke kukulu akau paha, ma kahi a ka laau e hina ai, malaila auanei no ia.   
\q1
\v 4 O ka mea i manao nui i ka makani. aole ia e kanu, a o ka mea i manao nui i na ao, aole ia e ohi.   
\q1
\v 5 Me kou ike ole ana i ka aoao o ka uhane, a me na iwi iloko o ka opu o ka wahine hapai; pela no, aole oe i ike i ka hana a ke Akua, ka mea nana i hana na mea a pau.   
\q1
\v 6 I ke kakahiaka, e lulu oe i kau hua, a i ke ahiahi, aole hoi e hoomaha kou mau lima, no ka mea, aole oe i ike i ka mea maikai o laua, o kela paha, o keia paha, ua maikai pu paha laua.   
\b  
\q1
\v 7 Oia hoi, ua oluolu ka malamalama, a he mea maikai no hoi i na maka ke ike i ka la.   
\q1
\v 8 Aka, ina e ola kekahi kanaka i na makahiki he nui wale, a olioli no hoi ia lakou a pau, e pono ia ia ke hoomanao i na la o ka pouli, no ka mea, ua nui no lakou. O na mea a pau e hiki mai ana, he lapuwale ia.   
\b  
\q1
\v 9 E ke kanaka ui, e olioli oe i kou wa ui, a e hoohauoli kou naau ia oe iho i kou mau la opiopio, a e hele ma na aoao o kou naau iho, a ma ka ike ana o kou mau maka; aka hoi, e ike pono oe, e hookomo ana ke Akua ia oe iloko o ka hookolokoloia, no keia mau mea a pau.   
\q1
\v 10 No ia mea, e hookaawale aku oe i ke kaumaha mai kou naau aku, a me ka ino mai kou kino aku; no ka mea, o ka wa opiopio, a me ka wa ui, he mea lapuwale ia.   
\c 12  
\b  
\q1
\v 1 E HOOMANAO oe i kou Mea nana i hana, I na la o kou noho opiopio ana; Oi hiki ole mai na la ino, A hookokoke ole ia mai na makahiki, Au e olelo ai, Aole o'u oluolu i keia mau mea:   
\q1
\v 2 I ka wa i pouli ole ai ka la, a me ka malamalama, O ka mahina hoi a me na hoku; A hoi ole mai na ao mahope o ka ua:   
\q1
\v 3 I ka la i haalulu ai na kiai hale, A kulou ilalo na kanaka ikaika; A oki ka poe wili no ka hapa, A i pouli ai na mea nana ma na puka makani;   
\q1
\v 4 A paniia na puka ma ke alanui, I ka wa i uuku mai ai ka leo o ka wili ana; A e ala ae oia i ka leo o ka manu, A e hoohaahaaia na kaikamahine lea i ke oli a pau.   
\q1
\v 5 A makau lakou i na mea kiekie; Aia hoi ma ke alanui na mea e weliweli ai, Ua hoopailua hoi ka laau alemona, A o ka uhini, he mea ia e kaumaha ai, A lilo no hoi ka hua kepa i mea mikomiko ole; No ka mea, hele ke kanaka i kona hale mau, A hele ka poe kanikau ma na alanui:   
\q1
\v 6 Oi moku ole ia ke kaula kala, Aole hoi i naha ke kiaha gula; Aole naha ka bakeke ma ka punawai, Aole hoi i naha ke kaa ma ka luawai.   
\q1
\v 7 Alaila, e hoi ka lepo i ka honua e like me ia mamua, A o ka uhane, e hoi ia i ke Akua nana ia i haawi mai.   
\b  
\q1
\v 8 Lapuwale o na lapuwale, wahi a ke kahuna, pau na mea i ka lapuwale.   
\b  
\q1
\v 9 Eia hoi kekahi: I ko ke kahuna naauao ana, ua ao mau aku oia i na kanaka; ua noonoo oia, a imi, a hooponopono hoi i na olelo akamai he nui hoa.   
\q1
\v 10 Ua imi iho la ke kahuna e loaa mai na olelo oluolu, a o na mea i kakauia, he olelo pololei ia a me ka oiaio hoi.   
\b  
\q1
\v 11 O na olelo a ka poe naauao, ua like ia me na mea oi, a me na kui i makiaia a paa e ka poe luna o ka ahakanaka, na mea i haawiia'ku ai e ke kahu hookahi.   
\q1
\v 12 Eia hoi kekahi: E aoia mai oe, e ka'u keiki, e keia mau mea; o ka hana ana i na buke he nui loa, he mea hope ole ia, a o ka imi nui i ka palapala, he mea ia e luhi ai ke kino.   
\b  
\q1
\v 13 E hoolohe oe i ka hope o keia mau mea a pau. E makau i ke Akua, a e malama i kona mau kanawai, no ka mea. oia ka ke kanaka [pono] a pau.   
\q1
\v 14 No ka mea, e hookomo ana ke Akua i na hana a pau, a me na mea a pau i hunaia iloko o ka hookolokoloia, ina paha he pono, ina paha he hewa.   