\id 1PE - IKWERRE
\h 1 Pita
\toc1 Ọkwukwo izi ke Mbọm Pita gbarụ
\toc2 1 Pita
\toc3 1 Pita
\mt2 Ọkwukwo izi
\mt2 ke Mbọm
\mt1 Pita
\mt2 gbarụ
\imt1 Nhne gbasịri ọkwukwo izi ka
\im \bk Ọkwukwo izi ke Mbọm Pita gbarụ\bk* bụ ke Pita gbaznennu ele Karaịsi naata awhnụwhnu kwnornu be neekpenu Nyenwe aị. Pita kannụ be nụ agịda ele ke Karaịsi nọowhnusni anya n'aka ele Rom ele kwége nụ Jizọsi Karaịsi. Be jaazị kọriri naata awhnụwhnu ke kakwo. Kọvu, Pita naakanụ be nụ be nwe ndidi kwnornu nụ kpakara ele sno Nyenwe aị jaata awhnụwhnu kwnornu ọkwnata ovu be. Ọ kaa nụ ka jeeme ọkwnata ovu be si rikne, ke jeenye Nyenwe aị igwugwu n'ọbochi Jizọsi jaava.
\ip Kọvu kwnornu nhne Chiokike mernu hite n'ome Karaịsi hi n'ẹnwu lizọ, kpakara ele Karaịsi nwernu olile anya. Lele kpa Karaịsi beru ọsno ta awhnụwhnu, omekwo, be nyee a igwugwu, ọ bụ masị kpa nye Karaịsi ọbula jeenwe igwugwu nga Jizọsi jaava.
\iot Nhne zị n'ọkwukwo izi ka
\io1 Obekwu ikwu nụ okpukpe \ior (1:1,2) \ior*
\io1 Risi olile anya aị \ior (1:3-12) \ior*
\io1 Owu bụdnu zị nsọ lele ele ke Chiokike \ior (1:13---2:17) \ior*
\io1 Nhne atụ awhnụwhnu Karaịsi \ior (2:18-25) \ior*
\io1 Awhnụwhnu nye Karaịsi \ior (3:1---4:19) \ior*
\io1 Ezni ele risi ọgbako Chiokike \ior (5:1-11) \ior*
\io1 Obekwu ikwu ipne-aznụ \ior (5:12-14) \ior*
\c 1
\p 
\v 1 Mawa, Pita, nye izi Jizọsi Karaịsi, naagbaznenu ele Chiokike họhiaru ke gbasarụ kpakara ẹli Pọntosi, Galasia, Kapadosia, Esia nụ Bitinia ọkwukwo izi ka.
\v 2 Chiokike Nda mahịaru anụ, gweru aka a họru anụ, bịta anụ nsọ hite n'Enine Nsọ, ma anụ noobnonu Jizọsi Karaịsi nsnị, ma ọvnarna a snụsnama anụ.
\p Oru nụ udno banụ anụ aba.
\s1 Olile anya ke zị bụdnu
\p 
\v 3 Ọznarni zịnu Chiokike nụ Nda Nyenwe aị Jizọsi Karaịsi, nye hiri nụ obirizi a mụhia aị nụ bụdnu ikne. O mernu Jizọsi Karaịsi hi n'ẹnwu lizọ, ke nyernu aị ọkwnata ovu zị bụdnu.
\v 4 A bna n'okehịa mkpe ke zá noolulu olulu, nụ ke be mérula emeru, nụ ke zá nọobo ọbo, ke Chiokike bịtannu anụ n'oligwe.
\v 5 Chiokike jeeji iknernema a bịta anụ tem anụ nahịa ọznohia, kwnornu nụ anụ tụkwasiri a ovu. O jeeme ka whụya iwhne n'ige ipne-aznụ.
\v 6 Anụ nọonwudna ọnwudna kịtna kwnornu ka, ọ bụ n'ezi nụ anụ naata awhnụwhnu zị ọdo n'ọdo n'ige matị ka.
\v 7 Kpakara ọrnurna ka varụ ma be tule ọkwnata ovu anụ ma anụ zị snam lele kpa be neeji bẹkwnu naagba golu ke noolu olulu. Ọ bụ kpa be neeji bẹkwnu nọotule ọkwnata ovu anụ, ma anụ nwehịa ọznarni nụ igwugwu n'ọbochi be jookpume Jizọsi Karaịsi.
\v 8 Nye anụ whnụrnu n'anya, ọ bụ n'ezi nụ anụ jíle anya anụ lawụru whnụ a, anụ kweru nụ ya, ọ bụ n'ezi nụ anụ jíle anya anụ lawụru whnụ a kịtna. Kam kpayarụ anụ nwernu snarnịma k'agịda ke ọnu jọ́okowali.
\v 9 Anụ nahịaru nhne anụ kwnatarụ ovu ke bụ ọznohia ke mkpụru ovu anụ.
\p 
\v 10 Ka bụ ọznohia wam ele ọwhnurninya piosiri rikne, nyosna nhne gbasịri a, be whnụrnu ọwhnurninya gbasịri nkesi wam Chiokike jeenye anụ.
\v 11 Be pioru ọ mahịa ige wam nụ kpa ọ jọoburu bụ nhne Enine Karaịsi ke zị nụ rime be kwuru, nhne gbasịri awhnụwhnu Karaịsi jaata nụ igwugwu ke joosno a.
\v 12 Chiokike kpumennu ele ọwhnurninya ka nụ ẹrnu be bụ́o ke be, kọvu ke jaabnanụ anụ iru, bụ ke be kwuru hite n'ọnu ele znirni anụ izi ọma, hite nụ rikne ke Enine Nsọ ke hiri n'oligwe va. Ka bụ nhne ke ele enine izi pioru o lebna anya nụ rime a.
\s1 Anụ zịri nsọ
\p 
\v 13 Kam kpayarụ, anụ suru ajnị n'ovu anụ, anya dụ anụ ẹli, anụ neele oru ke Jizọsi Karaịsi jeenye anụ anya nga be kpumernu a.
\v 14 Lele rụmu ke noobnonu Chiokike nsnị, anụ láhna nụ rime nhne ọjo ke nọogwnu anụ nụ mbọm nga anụ zị lele ele máa nhne.
\v 15 Tnụnuma, lele kpa nye wam sukwuru anụ zị nsọ, anụ zịri nsọ nụ kpakara nhne anụ neeme.
\v 16 Kwnornu nụ be gbarụ a n'ọkwukwo nsọ, kaa, “Anụ zịri nsọ, lele kpa me zị nsọ.”
\p 
\v 17 Ọ bụru nụ anụ noosukwu Nda ke zá neele badnụ anya n'ikpe, bụ nye neekpe badnụ ọbula lele kpa ẹrnu be jiri zị, anụ zịri bụdnu lele ele izne nọotu ogwnu n'ọwa ka.
\v 18 Anụ magwụ nụ ọ bụ́o golu mọbu siliva ke noolulu olulu bụ nhne be jiri gbahịa anụ hite n'aka nhne ọjo ke anụ nahịaru n'aka ele nda anụ ọknani,
\v 19 kọvu ọ bụ ọvnarna Karaịsi ke zị okne ọnu ahịa, lele nnwọ atnụrnu ke nwée ọru mọbu ntụpo.
\v 20 Chiokike họhiaru a tụtu sụ ọ tụru ntụ-ẹli ọwa. Kọvu o mernu a ọ whụya iwhne n'ọbochi ipne-aznụ ka kwnornu anụ.
\v 21 Anụ kweru nụ Chiokike hite nụ ya, nye o mernu ma o hi n'ẹnwu lizọ, nyee a igwugwu, ma olile anya anụ nụ ọkwnata ovu zịri nụ Chiokike.
\p 
\v 22 Hne anụ bịtaru ẹhni anụ snam hite n'obno nsnị n'ezi ọka, nọowhnu ele kweru ekwe n'anya, anụ gweru ọwhnun'anya ke hi n'ovu anụ whụya whnụ ibne anụ n'anya.
\v 23 Be mụrnu anụ berere, ọ bụ́o hite nụ mkpụru ke nooro oro, kọvu hite nụ mkpụru ke zá nooro oro, ke bụ ikwu-ọnu Chiokike ke zị ọkwnukokwnu.
\v 24 Ọkwukwo nsọ kwuru,
\q1 “Kpakara badnụ nụ lele achara,
\q2 igwugwu badnụ nụ lele okoko achara,
\q1 achara chanwụ, okoko a dnahala,
\q2 
\v 25 kọvu ikwu-ọnu ke Nyenwe aị jaazị ọkwnukokwnu.”
\m Ka bụ ikwu-ọnu ke izi ọma wam be znirni anụ.
\c 2
\p 
\v 1 Kam kpayarụ, anụ gweme kpakara nhne ọjo n'ẹhni anụ, irno, nụ kpakara aghịgho, nụ ruwhnu lawụru, nụ okwno-awụwa nụ ọkaja.
\v 2 Lele rụmu be mụrnu ikne, akpịri ke mini-rẹma ke zị snam ke enine, ke bụ ikwu-ọnu Chiokike nọokpo anụ bẹkwnu, ma anụ nwọ a, sopiya nụ badnụ dụ ọznohia.
\v 3 Kịtna, anụ ratụru a riro whnụ nụ Nyenwe aị bụru ọma.
\s1 Akaworugwu zị bụdnu
\p 
\v 4 Anụ vakwnusi Nyenwe aị lele rugwu ke zị bụdnu ke ele badnụ jụru, kọvu ke Chiokike họhiaru, zị okne ọnu ahịa n'anya a.
\v 5 Anụwa masị, lele akaworugwu ke zị bụdnu, be jiri anụ wu Ọro Nsọ ke enine, ma anụ bụru ele ọkwa arịohna zị nsọ, ele jaakwa arịohna enine ke Chiokike jaanarnụ hite nụ Jizọsi Karaịsi.
\v 6 Be gbarụ a n'ọkwukwo nsọ, kaa,
\q1 “Le, m bịtaru m nụ rime Zayọni,
\q2 akaworugwu nsụkala ọro me họhiaru ke zị okne ọnu ahịa,
\q1 nye ọbula ke tụkwasiri a ovu,
\q2 iwhnerne jọ́otu a.”
\p 
\v 7 Nụ hne anụ ele kweru ekwe zị, akaworugwu ka zị okne ọnu, kọvu hne ele kwé ekwe zị, be gbarụ a n'ọkwukwo nsọ, kaa,
\q1 “Akaworugwu ke ele noowu ọro jụru,
\q2 kịyam ghọlam risi nsụkala ọro.”
\m 
\v 8 Be gba kwno,
\q1 “Akaworugwu ke jeeme badnụ kpọbi ọchi,
\q2 nụ rugwu ke jeeme be dna.”
\m Be dnarnụ kwnornu nụ be kwége ikwu-ọnu Chiokike, lele kpa echiche Chiokike zịnu be.
\p 
\v 9 Kọvu anụ bụ ele Chiokike jiri aka a họhia, ele arịohna ke eze, mbam ke zị nsọ, ele ke Chiokike, ma anụ gesi ọznarni nye wam sukwuru anụ hite nụ rime ọchichiri bna nụ rime iwhne a zị igwugwu.
\v 10 Nụ mbọm anụ bụ́o ele ke Chiokike, kọvu kịtna, anụ bụ ele ke a, ele nwée obirizi nụ mbọm, kọvu kịtna, Chiokike dọnnu anụ obirizi.
\p 
\v 11 Ele me whnụrnu n'anya, m naarịasno anụ, lele ele izne nụ ele neewhe ewhe n'ọwa ka, anụ nyée nhne ọjo ke nọogwnu anụ, ke nọolu masị ọgwnu megidne mkpụru ovu anụ oghere.
\v 12 Anụ wu bụdnu ke bụru ọma n'esilawụru ele máa Chiokike, ọ bụ n'ezi nụ be noobno anụ nhne ọjo, kọvu be whnụ ẹrnu ọma anụ, ma be znarnị Chiokike n'ọbochi o jeelekasi aị.
\s1 Bịta ẹhni anụ nụ mkpururu // ele ọchichi
\p 
\v 13 Kwnornu nụ Nyenwe aị, anụ bịta ẹhni anụ nụ mkpururu ọchichi ke badnụ, mọbu eze, lele nye risi,
\v 14 mọbu ele ọchi ẹli ele o ziyaru ọ ta ele ọjo awhnụwhnu, nụ ọ znarnị nye neeme nhne ọma.
\v 15 Ka bụ nhne Chiokike noopio, ma anụ hite n'ẹrnu ọma anụ kpusni ọnu ele iwhnirniwhno.
\v 16 Anụ wu bụdnu lele ele nwernu ẹhni be. Anụ jí ọnodi wam kpusni nhne ọjo, kọvu anụ zịri bụdnu lele ele izi Chiokike.
\v 17 Anụ sọ kpakara badnụ anya, anụ whnụ rụmu Nda n'anya, anụ tụ ogwnu Chiokike, anụ sọbisinu eze.
\s1 Awhnụwhnu Karaịsi
\p 
\v 18 Ele ọhi, anụ gweru ọso anya bịta ẹhni anụ nụ mkpururu ele nwe anụ. Anụ ménu nye ovu ọma nụ nye udno kpọi, ma nye aka rikne masị.
\v 19 Kwnornu nụ Chiokike jọogozi anụ ọ bụru nụ anụ tarụ awhnụwhnu hne ọ zá nhne ọjo anụ mernu, kọvu kwnornu nụ anụ tụru ogwnu Chiokike.
\v 20 Ndaa igwugwu ke anụ jeenwe, ọ bụru nụ anụ tarụ awhnụwhnu kwnornu nụ nhne ọjo anụ mernu? Kọvu anụ gwuzogidne n'awhnụwhnu hne anụ mernu nhne ọma, Chiokike jọogozi anụ.
\p 
\v 21 Ọ bụ nhne be sukwuru anụ, Karaịsi tarụ awhnụwhnu nụ risi anụ, ghasanụ anụ nhne atụ, ma anụ snornu rẹnu ọchi a.
\p 
\v 22 “Ọ zá mmehie o mernu,
\q2 ọ zá aghịgho be piohịaru n'ọnu a.”
\p 
\v 23 Nga be mernu a nhne iwhnerne, o mégwnarnuge, nga ọ tarụ awhnụwhnu, ọ kpála rikne, kọvu o gweru ẹhni a yisi n'aka nye wam neekpe ikpe bụru ọma.
\v 24 Ya n'iwhuru a jiri ẹhni a vuru kpakara mmehie aị n'olu ọgba, ma a bụru ele nwụrnu ọnwu ghasa mmehie, zịri bụdnu ele mee mma. O jiri ẹnya a gwọ kpakara ẹhni igbugbu aị.
\v 25 Anụ nụ lele atnụrnu ke whuru apna, kọvu ke hiehnarnu hne Nye Ọznuznu nụ Nye Risi mkpụru ovu anụ zị.
\c 3
\s1 Ele nzi nụ nnwerne
\p 
\v 1 Kpam masị, anụ ele bụ nnwerne, anụ bịta ẹhni anụ nụ mkpururu nzi anụ. Ọ bụrubedi nụ be bụ ele kwéle ikwu-ọnu Chiokike, be jeenwe rikne hiri nụ agwa ọma anụ kweru hne anụ kwúle ọka,
\v 2 kpa be jọowhnu anụ noowu bụdnu bụru ọma ke zị masị snam n'ọso n'anya.
\v 3 Anụ kwé mma anụ bụru nhne ke anya nọowhnu kpọi, ọ bụ́o kpa anụ kparụ risi anụ, mọbu golu anụ tụ n'ẹhni, mọbu iwo marnụ mma anụ wogwu.
\v 4 Kọvu mma anụ bụru agwa ọma wam tugwaru otugwa ke zị nụ rime ovu, ke bụ nhne ẹyi ke zá nooro oro, ke bụ ọzi wọhnernerne nụ enine ke udno, ke zị okne ọnu ahịa n'anya Chiokike.
\v 5 Ọ bụ kpa ele rinya gbaka zị nsọ ele tụkwasiri Chiokike ovu mernu ẹhni be mma, be bịtaru ẹhni be nụ mkpururu nzi be.
\v 6 Sera nụ kpam, o bnonnu Ebereham nsnị, noosukwu a, “Nyenwe m.” Anụ bụ rụmu a rinya, ọ bụru nụ anụ jeeme nhne ọma gharụ ọ tụ ogwnu nhne ọbula.
\p 
\v 7 Kpam masị, anụ ele bụ nzi, anụ jiri ọso anya nụ akọ, anụ nụ nnwerne anụ wuru, hne anụ magwụ nụ be bụ ele nwée rikne. Anụ nụ be jeekehịa nkesi bụdnu kwó okwo Chiokike neekesi anụ n'etekne. Anụ mee kpam, ọ zị nhne ọbula bnosni okpukpe anụ.
\s1 Awhnụwhnu kwnornu // ome nhne bụru ọma
\p 
\v 8 N'ipne-aznụ, kpakara anụ nwe otu ovu, anụ dọnu ibne anụ obirizi, anụ whnụ ibne anụ n'anya lele rụmu nda, anụ nwe obirizi n'ẹhni ibne anụ, anụ bụru ele be gwednarnụ ẹli.
\v 9 Anụ jí nhne ọjo kwụhnata nhne ọjo, anụ gọ́gwna ngụgo, kọvu anụ nọogozi ọgozi, kpa Chiokike sukwuru anụ ma anụ kehịa ngọzi masị.
\v 10 Kwnornu nụ ọkwukwo nsọ kwuru,
\q1 “Nye ọbula ke whnụrnu bụdnu n'anya,
\q2 ke noopio ọbochi ọma,
\q1 ọ bịta ọnu a ma ọ gharụ o kwu ọka ọjo,
\q2 bịta masị mgbele-ọnu a n'aghalaghala.
\q1 
\v 11 Ọ gharụ nhne ọjo, mee nhne bụru ọma,
\q2 pio udno, gbasno a.
\q1 
\v 12 Kwnornu nụ anya lawụru Nyenwe aị zị n'ẹhni ele mee mma,
\q2 nsnị a nọonu okpukpe be,
\q1 kọvu ruwhnu Nyenwe aị neemegidne ele neeme nhne ọjo.”
\p 
\v 13 Nyele jeemejọ anụ, ọ bụru nụ anụ gwuzosi rikne nụ nhne ọma?
\v 14 Ọ bụru nụ anụ ta awhnụwhnu kwnornu nụ anụ mernu nhne ọma, ovu sọ anụ n'ọnu, ogwnu tụ́ anụ kwnornu be, ovu lákwadia anụ mini.
\p 
\v 15 Anụ sọbisinu Karaịsi lele Nyenwe aị nụ rime ovu anụ. Anụ jiknernu ọ sa ajịji nye ọbula jaasịkwa anụ nhne gbasịri olile anya wam zị n'ovu anụ hite n'ọso anya nụ ovu zị wọhnernerne.
\v 16 Anụ bịta ovu anụ snam, ma ele nookwu nhne ọjo kwnornu agwa ọma anụ kweru nụ Karaịsi, iwhnerne jọotu be nụ nhne ọjo be nookwu.
\v 17 Ọ ka mma, ọ bụru nụ ọ bụ echiche Chiokike nụ anụ tarụ awhnụwhnu kwnornu nụ anụ mernu nhne ọma karụ kwnornu nụ anụ mernu nhne ọjo.
\v 18 Karaịsi nwụrnu otu mgba kwnornu mmehie aị, nye ikpe mána nwụrnu kwnornu ele ikpe marnụ. Karaịsi mernu ka ma o duru anụ dụ hne Chiokike zị. Ọ nwụrnu ẹnwu n'anọ-ẹhni, kọvu ọ zị bụdnu n'Enine,
\v 19 nụ rime enine zị bụdnu,\f + \fr 3:19 \ft hite nụ Enine Nsọ\f* o znernu zni ele enine ke zị n'ọro ikelu izi ọma.
\v 20 Ka bụ ele zá noobno nsnị, kpa Chiokike ji nkasi ovu neese nga Noa nọotu ọgbo ke be jiri znọhia badnụ ele nụ ele, badnụ ẹsato kpọi hite nụ mini.
\v 21 Ka neegesi nụ ọwu mini znọhiaru anụ, ke bụ nọorio Chiokike ovu zị snam hite n'olizọ n'ẹnwu ke Jizọsi Karaịsi. Ọ bụ́o ọsnuma rune ke ẹhni.
\v 22 Karaịsi bụ nye larụ oligwe dazịri ẹli n'akarikwnunga Chiokike, hne kpakara ele enine izi nụ ọchi risi nụ rikne zị nụ mkpururu a.
\c 4
\s1 Owunu Chiokike bụdnu
\p 
\v 1 Kpam masị, Karaịsi tarụ awhnụwhnu n'anọ-ẹhni a, anụ jiknernu o mee kpam masị, kwnornu nye tarụ awhnụwhnu n'anọ-ẹhni a zị́ma neeme mmehie.
\v 2 Kam kpayarụ, ọ zá noowu bụdnu a n'ọwa ka lele kpa agwnụrnu nhne ọjo ke badnụ, kọvu lele echiche Chiokike.
\v 3 Kwnornu nụ ige anụ tuwhuru n'ige wheru ewhe noowu bụdnu lele ele máa Chiokike zulem. Ige wam anụ noowu bụdnu ke zị́la rịchna, agwnụrnu nhne ọjo, ọnwo manya, okne otne eri, nụ ọkwa rẹnwu.
\v 4 Kịtna, o jiri be anya nụ anụ zá noosno be neeme nhne ọjo berere, ke kpayarụ be nọovu anụ ọnu.
\v 5 Kọvu be jaasa ajịji gbasịri ẹhni be nụ ruwhnu nye wam jeekpe ele zị bụdnu nụ ele nwụrnu ọnwu ikpe.
\v 6 Kam kpayarụ, be jiri zni ele nwụrnu ọnwu izi ọma nga be zị, ma be kpe ikpe be hite nụ nhne be mernu nga be zị bụdnu lele badnụ, ma be zịri bụdnu n'enine lele Chiokike.
\p 
\v 7 Mbimambi kpakara nhne zị ndụndu. Anụ nwe anya udno, anya dụ anụ ẹli, anụ neekpe okpukpe.
\v 8 Ke kakwo, anụ nwe ọwhnun'anya zị omimi n'esilawụru anụ, kwnornu nụ ọwhnun'anya nookpusni agịda mmehie.
\v 9 Anụ jí ntamu nabnanya ibne anụ.
\v 10 Nye ọbula gweru nkesi ọ nahịaru n'aka Chiokike znenu ibne a izi, gweru okwesi ọkwnata ovu neekesi oru Chiokike zị ọdo n'ọdo.
\v 11 Nye neezni izi ọma, ọ zni a lele nụ ọ bụ ikwu-ọnu ke hi n'ọnu Chiokike whụya. Nye neezne izi, o mee a lele Chiokike nyernu a iknernema, ma be znarnị Chiokike nụ rime kpakara nhne hite nụ Jizọsi Karaịsi, nye nwe igwugwu nụ rikne tim tọm. Amịm.
\s1 Awhnụwhnu lele // nye Karaịsi
\p 
\v 12 Ele me whnụrnu n'anya, ọ gbagwoji anụ anya kwnornu ọrnurna zị igbugbu ke naarna anụ lele nụ ọ bụ nhne ikne neeme anụ.
\v 13 Kọvu anụ nwụdna, kwnornu nụ anụ sno Karaịsi takọ awhnụwhnu, ma anụ nwe ovu ọso n'ọnu zị agịda nga be jookpume igwugwu a.
\v 14 Ọ bụru nụ be mernu anụ nhne iwhnerne kwnornu nụ rẹwhna Karaịsi, ovu sọ anụ n'ọnu, ka neegesi nụ Enine igwugwu, ke bụ Enine Chiokike wu nụ rime anụ.
\v 15 Ọ zá nye ta awhnụwhnu n'esilawụru anụ lele nye gburu badnụ, mọbu nye buznu, mọbu nye mernu nhne ọjo berere, mọbu nye neelebna anya nụ nhne gbásịla a.
\v 16 Kọvu, ọ bụru nụ nye ọbula ta awhnụwhnu lele nye Karaịsi, iwhnerne tụ́ko nye wam, kọvu o nyee Chiokike ọznarni kwnornu nụ be nookwu a nye Karaịsi.
\v 17 Ige valẹm nga be jaapanịzo ikpe n'ezi-nụ-ọro Chiokike. Ọ bụru be panịzo ikpe nụ hne a zị, ndaa kpa ọ jaazịnu ele kwéle izi ọma Chiokike?
\q1 
\v 18 Ọ bụru nụ ọ jaara ẹhni ọ znọhia ele mee mma,
\q2 ndaa hne ele máa Chiokike nụ ele mmehie jaazị?
\p 
\v 19 Kam kpayarụ, nye ọbula ke naata awhnụwhnu lele kpa echiche Chiokike jiri zị, gweru ovu ọma yisi ẹhni a kpam kpam n'aka Nye Okike nye kwesiri ọkwnata ovu. Nye wam zne nụ ruwhnu neeme nhne ọma.
\c 5
\s1 Ele okno badnụ nụ // ele ikoro
\p 
\v 1 M naarịasno ele okno badnụ zị n'esilawụru anụ hne me bụ masị nye okno badnụ, m whnụrnu m awhnụwhnu Karaịsi tarụ, m jeekehịa masị igwugwu a nga be jookpume a.
\v 2 Anụ znụ atnụrnu Chiokike ke zị nụ mkpururu anụ, neelegidne be anya nụ kpakara ovu anụ kpa Chiokike pioru a, ọ bụ́o nụ mkpa kpagwụ anụ, kọvu kwnornu nụ ọ bụ nhne kwesiri omume. Anụ rnụ ẹrnu anụ, ọ bụ́o kwnornu iru anụ jeenwehịa, kọvu nụ ọ nhne zị n'ovu anụ n'omume.
\v 3 Anụ mée be lele nụ be bụ nhne ke aka anụ, kọvu anụ bụru nhne atụ be joosno.
\v 4 Nga Nye Risi Ọznuznu Atnụrnu varụ, anụ jaanahịa okpu-eze zị igwugwu ke jaazị noonwu va-a-a tem.
\p 
\v 5 Kpam masị, rụmu ikoro, anụ bịta ẹhni anụ nụ mkpururu ele okno badnụ. Kpakara anụ woru ọzi wọhnernerne n'ovu lele iwo, neeznenu ibne anụ izi. Kwnornu nụ ọkwukwo nsọ kwuru,
\q1 “Chiokike noogwuzogidne ele oknomokno,
\q2 kọvu o neenye ele zị wọhnernerne n'ovu oru.”
\m 
\v 6 Kam kpayarụ, anụ gwedna ẹhni anụ nụ mkpururu aka dikne ke Chiokike, o joovulizọ anụ olu n'ige ke a.
\v 7 Anụ vukwnusi a kpakara mkpa anụ, kwnornu nụ nhne gbasịri anụ neemetụ a n'ovu.
\p 
\v 8 Anya dụ anụ ẹli, anụ neese nse, nye irno anụ bụ Ekwensu, naagbagharị lele odum nọogbo ọgbugbo noopio nye o jeeri.
\v 9 Anụ zịri kwem nụ ọkwnata ovu anụ, anụ gwuzogidne a, kwnornu nụ rụmu Nda anụ nụ kpakara ọwa naagawhe otu awhnụwhnu wam.
\p 
\v 10 Nga anụ tarụ awhnụwhnu ige matị, Chiokike ke oru nye sukwuru anụ bna n'igwugwu a kwó okwo nụ Karaịsi, joogwuzote anụ, nyee anụ rikne, gba anụ inwe.
\v 11 Kpakara rikne ọchichi bụ ke a ọkwnukokwnu. Amịm.
\s1 Obekwu ipne-aznụ
\p 
\v 12 Saịlasi nwene aị rukna ke kwesiri ọkwnata ovu yinnu m aka gba ọkwukwo izi matị ka, m naarịasno anụ naagba akebne nụ ka bụ ezi oru Chiokike n'olu hne anụ gwuzo.
\v 13 Ọgbako Chiokike ke zị nụ Babịloni,\f + \fr 5:13 \ft Ka bụ \fq Rom\f* ke be họhiakoru anụ nụ ya neebekwu anụ, ma Makị nnwọ m.
\v 14 Anụ gweru ọwhnun'anya Karaịsi neebekwu ibne anụ.
\p Udno dazịnu kpakara anụ ele zị nụ rime Karaịsi.
