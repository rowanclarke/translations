\v 13 \w And|strong="G2532"\w* \w if|strong="G1437"\w* \w he|strong="G2532"\w* \w happens|strong="G1096"\w* \w to|strong="G2532"\w* \w find|strong="G2147"\w* \w it|strong="G2532"\w*, assuredly \w I|strong="G2532"\w* \w say|strong="G3004"\w* \w to|strong="G2532"\w* \w you|strong="G5210"\w*, \w he|strong="G2532"\w* \w rejoices|strong="G5463"\w* \w more|strong="G3123"\w* \w over|strong="G1909"\w* \w it|strong="G2532"\w* \w than|strong="G2228"\w* \w over|strong="G1909"\w* \w the|strong="G2532"\w* \w ninety-nine|strong="G1768"\w* \w that|strong="G3754"\w* \w did|strong="G2532"\w* \w not|strong="G3361"\w* \w go|strong="G2532"\w* \w astray|strong="G4105"\w*.  
