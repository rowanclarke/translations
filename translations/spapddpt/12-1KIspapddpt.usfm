\v 22 Pero \w el|strong="H1121"\w* \w pueblo|strong="H5971"\w* \w que|strong="H5971"\w* seguía \w a|strong="H3068"\w* \w Omri|strong="H6018"\w* \w pudo|strong="H2388"\w* \w más|strong="H4191"\w* \w que|strong="H5971"\w* \w el|strong="H1121"\w* \w que|strong="H5971"\w* seguía \w a|strong="H3068"\w* Tibni, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Ginat. Tibni \w murió|strong="H4191"\w* y \w Omri|strong="H6018"\w* fue \w rey|strong="H4427"\w*.
\s1 Reinado de Omri en Israel
\p 
\v 23 \w El|strong="H5921"\w* \w año|strong="H8141"\w* 31 \w de|strong="H5921"\w* Asa, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*, \w Omri|strong="H6018"\w* comenzó \w a|strong="H3068"\w* reinar \w sobre|strong="H5921"\w* \w Israel|strong="H3478"\w* \w y|strong="H5921"\w* \w reinó|strong="H4427"\w* 12 \w años|strong="H8141"\w*. \w Seis|strong="H8337"\w* \w años|strong="H8141"\w* \w reinó|strong="H4427"\w* \w en|strong="H5921"\w* Tirsa.
\v 24 \w Compró|strong="H7069"\w* \w la|strong="H5921"\w* montaña \w de|strong="H5921"\w* \w Samaria|strong="H8111"\w* \w a|strong="H3068"\w* Semer \w por|strong="H5921"\w* 66 kilogramos \w de|strong="H5921"\w* \w plata|strong="H3701"\w*. \w Edificó|strong="H1129"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* montaña. \w Llamó|strong="H7121"\w* \w Samaria|strong="H8111"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w* \w que|strong="H5921"\w* \w edificó|strong="H1129"\w*, \w según|strong="H5921"\w* \w el|strong="H5921"\w* \w nombre|strong="H8034"\w* \w de|strong="H5921"\w* Semer, dueño \w de|strong="H5921"\w* \w la|strong="H5921"\w* montaña.
\p 
\v 25 \w Omri|strong="H6018"\w* \w hizo|strong="H6213"\w* \w lo|strong="H6213"\w* \w malo|strong="H7451"\w* \w ante|strong="H6440"\w* \nd \w Yavé|strong="H3068"\w*\nd*. Actuó \w peor|strong="H7489"\w* \w que|strong="H3605"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w que|strong="H3605"\w* reinaron \w antes|strong="H6440"\w* \w de|strong="H6440"\w* \w él|strong="H3605"\w*,
\v 26 pues \w anduvo|strong="H3212"\w* \w en|strong="H3212"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w camino|strong="H1870"\w* \w de|strong="H1121"\w* \w Jeroboam|strong="H3379"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Nabat|strong="H5028"\w*, y \w en|strong="H3212"\w* \w los|strong="H1121"\w* \w pecados|strong="H2403"\w* con \w los|strong="H1121"\w* cuales estimuló \w a|strong="H3068"\w* \w pecar|strong="H2398"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w*. Provocó \w la|strong="H3605"\w* \w ira|strong="H3212"\w* \w de|strong="H1121"\w* \nd \w Yavé|strong="H3068"\w*, ʼElohim\nd* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, con \w los|strong="H1121"\w* ídolos \w de|strong="H1121"\w* \w ellos|strong="H3605"\w*.
\p 
\v 27 \w Los|strong="H1992"\w* demás \w hechos|strong="H1697"\w* \w y|strong="H5921"\w* \w cosas|strong="H1697"\w* \w de|strong="H5921"\w* \w Omri|strong="H6018"\w* \w y|strong="H5921"\w* \w el|strong="H5921"\w* poderío \w que|strong="H3808"\w* logró, ¿\w no|strong="H3808"\w* están \w escritos|strong="H3789"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* rollo \w de|strong="H5921"\w* \w las|strong="H1992"\w* Crónicas \w de|strong="H5921"\w* \w los|strong="H1992"\w* \w reyes|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*?
\v 28 \w Omri|strong="H6018"\w* descansó \w con|strong="H5973"\w* sus antepasados y fue \w sepultado|strong="H6912"\w* \w en|strong="H5973"\w* \w Samaria|strong="H8111"\w*. \w En|strong="H5973"\w* \w lugar|strong="H8478"\w* suyo \w reinó|strong="H4427"\w* su \w hijo|strong="H1121"\w* Acab.
\s1 Reinado de Acab en Israel
\p 
\v 29 Acab, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Omri|strong="H6018"\w*, comenzó \w a|strong="H3068"\w* reinar \w sobre|strong="H5921"\w* \w Israel|strong="H3478"\w* \w el|strong="H5921"\w* \w año|strong="H8141"\w* 38 \w de|strong="H5921"\w* Asa, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*. \w Reinó|strong="H4427"\w* \w sobre|strong="H5921"\w* \w Israel|strong="H3478"\w* \w en|strong="H5921"\w* \w Samaria|strong="H8111"\w* 22 \w años|strong="H8141"\w*.
\v 30 Acab, \w hijo|strong="H1121"\w* \w de|strong="H6440"\w* \w Omri|strong="H6018"\w*, \w hizo|strong="H6213"\w* \w lo|strong="H6213"\w* \w malo|strong="H7451"\w* \w ante|strong="H6440"\w* \nd \w Yavé|strong="H3068"\w*\nd*, más \w que|strong="H1121"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w que|strong="H1121"\w* reinaron \w antes|strong="H6440"\w* \w de|strong="H6440"\w* \w él|strong="H3605"\w*,
\v 31 \w porque|strong="H4428"\w* le \w fue|strong="H1961"\w* cosa ligera \w andar|strong="H3212"\w* \w en|strong="H3212"\w* \w los|strong="H1121"\w* \w pecados|strong="H2403"\w* \w de|strong="H1121"\w* \w Jeroboam|strong="H3379"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Nabat|strong="H5028"\w*. \w Tomó|strong="H3947"\w* \w como|strong="H1961"\w* esposa \w a|strong="H3068"\w* Jezabel, \w hija|strong="H1323"\w* \w de|strong="H1121"\w* Et-baal, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w sidonios|strong="H6722"\w*. \w Fue|strong="H1961"\w* y \w sirvió|strong="H5647"\w* \w a|strong="H3068"\w* \w baal|strong="H1168"\w*, y \w se|strong="H1961"\w* postró ante \w él|strong="H1121"\w*.
\v 32 En el \w templo|strong="H1004"\w* de \w baal|strong="H1168"\w* que \w edificó|strong="H1129"\w* en \w Samaria|strong="H8111"\w* le \w erigió|strong="H6965"\w* un \w altar|strong="H4196"\w*.
\v 33 Acab \w hizo|strong="H6213"\w* también una imagen \w de|strong="H6440"\w* Asera, con \w lo|strong="H6213"\w* cual provocó \w a|strong="H3068"\w* ira \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*, ʼElohim\nd* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*, \w más|strong="H3254"\w* \w que|strong="H1961"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w reyes|strong="H4428"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w* \w que|strong="H1961"\w* \w lo|strong="H6213"\w* antecedieron.
\p 
\v 34 En ese \w tiempo|strong="H3117"\w* \w Hiel|strong="H2419"\w* \w de|strong="H1121"\w* Bet-ʼEl \w reedificó|strong="H1129"\w* \w Jericó|strong="H3405"\w*. Puso \w los|strong="H1121"\w* \w cimientos|strong="H3245"\w* con \w el|strong="H1121"\w* sacrificio \w de|strong="H1121"\w* Abiram, \w su|strong="H7687"\w* \w primogénito|strong="H1060"\w*, y con \w el|strong="H1121"\w* sacrificio \w de|strong="H1121"\w* Segub, \w su|strong="H7687"\w* \w hijo|strong="H1121"\w* \w menor|strong="H6810"\w*, levantó sus \w puertas|strong="H1817"\w*, según la \w Palabra|strong="H1697"\w* \w que|strong="H1697"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w dijo|strong="H1696"\w* \w por|strong="H1697"\w* \w medio|strong="H3027"\w* \w de|strong="H1121"\w* \w Josué|strong="H3091"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Nun|strong="H5126"\w*.\f + \fr 16:34 \ft Ver Josué 6.26.\f*
\c 17
\s1 El profeta Elías
\p 
\v 1 \w Entonces|strong="H3588"\w* Elías tisbita, \w que|strong="H3588"\w* \w era|strong="H1961"\w* \w de|strong="H3588"\w* \w los|strong="H1961"\w* moradores \w de|strong="H3588"\w* \w Galaad|strong="H1568"\w*, dijo \w a|strong="H3068"\w* Acab: ¡\w Vive|strong="H2416"\w* \nd \w Yavé|strong="H3068"\w*, ʼElohim\nd* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*, \w en|strong="H3588"\w* cuya \w presencia|strong="H6440"\w* \w estoy|strong="H1961"\w*! ¡\w No|strong="H3588"\w* \w habrá|strong="H1961"\w* \w rocío|strong="H2919"\w* ni \w lluvia|strong="H4306"\w* \w en|strong="H3588"\w* estos \w años|strong="H8141"\w*, \w sino|strong="H3588"\w* \w por|strong="H3588"\w* \w mi|strong="H1961"\w* \w palabra|strong="H1697"\w*!
\p 
\v 2 La \w Palabra|strong="H1697"\w* \w de|strong="H1697"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* él:
\v 3 \wj \w Apártate|strong="H3212"\w* \w de|strong="H5921"\w* \w aquí|strong="H2088"\w*, dirígete \w al|strong="H5921"\w* \w oriente|strong="H6924"\w* \w y|strong="H5921"\w* escóndete \w junto|strong="H5921"\w* \w al|strong="H5921"\w* \w arroyo|strong="H5158"\w* \w de|strong="H5921"\w* Querit \w que|strong="H5921"\w* \w está|strong="H2088"\w* frente \w al|strong="H5921"\w* \w Jordán|strong="H3383"\w*.\wj*
\v 4 \wj \w Sucederá|strong="H1961"\w* \w que|strong="H1961"\w* \w beberás|strong="H8354"\w* \w del|strong="H8354"\w* \w arroyo|strong="H5158"\w*, y \w Yo|strong="H6680"\w* \w mandé|strong="H6680"\w* \w a|strong="H3068"\w* \w los|strong="H1961"\w* cuervos \w que|strong="H1961"\w* te sustenten \w allí|strong="H8033"\w*.\wj*
\p 
\v 5 \w Fue|strong="H3212"\w* \w e|strong="H3068"\w* \w hizo|strong="H6213"\w* \w según|strong="H5921"\w* \w la|strong="H5921"\w* \w Palabra|strong="H1697"\w* \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd*, pues \w salió|strong="H3212"\w* \w y|strong="H5921"\w* vivió \w junto|strong="H5921"\w* \w al|strong="H5921"\w* \w arroyo|strong="H5158"\w* \w de|strong="H5921"\w* Querit, \w que|strong="H5921"\w* \w está|strong="H3427"\w* frente \w al|strong="H5921"\w* \w Jordán|strong="H3383"\w*.
\v 6 Los cuervos \w le|strong="H1242"\w* llevaban \w pan|strong="H3899"\w* y \w carne|strong="H1320"\w* \w por|strong="H4480"\w* la \w mañana|strong="H1242"\w* y \w al|strong="H4480"\w* llegar la noche, y bebía \w del|strong="H4480"\w* \w arroyo|strong="H5158"\w*.
\p 
\v 7 \w Sucedió|strong="H1961"\w* \w que|strong="H3588"\w* al pasar \w los|strong="H1961"\w* \w días|strong="H3117"\w* \w se|strong="H1961"\w* \w secó|strong="H3001"\w* \w el|strong="H3588"\w* \w arroyo|strong="H5158"\w*, \w porque|strong="H3588"\w* \w no|strong="H3808"\w* llovía \w en|strong="H3588"\w* \w la|strong="H3588"\w* tierra.
\v 8 \w Y|strong="H3068"\w* la \w Palabra|strong="H1697"\w* \w de|strong="H1697"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* Elías:
\v 9 \wj \w Levántate|strong="H6965"\w*, \w vé|strong="H3068"\w* \w a|strong="H3068"\w* \w Sarepta|strong="H6886"\w* de \w Sidón|strong="H6721"\w* y vive \w allí|strong="H8033"\w*. \w Mira|strong="H2009"\w*, \w Yo|strong="H2009"\w* \w ordené|strong="H6680"\w* \w a|strong="H3068"\w* una viuda de \w allá|strong="H8033"\w* que te sustente.\wj*
\v 10 Él se \w levantó|strong="H6965"\w* y \w fue|strong="H3212"\w* \w a|strong="H3068"\w* \w Sarepta|strong="H6886"\w*. Cuando \w llegó|strong="H3212"\w* \w a|strong="H3068"\w* la \w puerta|strong="H6607"\w* \w de|strong="H4325"\w* la \w ciudad|strong="H5892"\w*, \w ciertamente|strong="H2009"\w* una viuda \w estaba|strong="H2009"\w* \w allí|strong="H8033"\w* y recogía \w leña|strong="H6086"\w*. Él la \w llamó|strong="H7121"\w* y le dijo: Te \w ruego|strong="H4994"\w* \w que|strong="H4994"\w* me traigas un \w poco|strong="H4592"\w* \w de|strong="H4325"\w* \w agua|strong="H4325"\w* \w en|strong="H3212"\w* un \w vaso|strong="H3627"\w* para \w beber|strong="H8354"\w*.
\v 11 Cuando \w iba|strong="H3212"\w* \w a|strong="H3068"\w* llevársela, él la volvió \w a|strong="H3068"\w* \w llamar|strong="H7121"\w* y le dijo: Te \w ruego|strong="H4994"\w* \w que|strong="H4994"\w* me traigas un bocado de \w pan|strong="H3899"\w* \w en|strong="H3212"\w* tu \w mano|strong="H3027"\w*.
\p 
\v 12 \w Pero|strong="H3588"\w* ella respondió: ¡\w Vive|strong="H2416"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w tu|strong="H6213"\w* \nd ʼElohim\nd*, \w que|strong="H3588"\w* \w no|strong="H6213"\w* \w tengo|strong="H3426"\w* pan cocido! \w Solamente|strong="H3588"\w* \w tengo|strong="H3426"\w* un puñado \w de|strong="H3588"\w* \w harina|strong="H7058"\w* \w en|strong="H3588"\w* una tinaja \w y|strong="H3588"\w* un \w poco|strong="H4592"\w* \w de|strong="H3588"\w* \w aceite|strong="H8081"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* vasija. \w Y|strong="H3068"\w* \w mira|strong="H2005"\w*, recogía un par \w de|strong="H3588"\w* leños \w para|strong="H3588"\w* entrar \w y|strong="H3588"\w* prepararlo \w para|strong="H3588"\w* mí \w y|strong="H3588"\w* mi \w hijo|strong="H1121"\w* \w a|strong="H3068"\w* fin \w de|strong="H3588"\w* \w que|strong="H3588"\w* comamos \w y|strong="H3588"\w* \w muramos|strong="H4191"\w*.
\p 
\v 13 Elías le dijo: \w No|strong="H6213"\w* \w temas|strong="H3372"\w*. Vé, \w haz|strong="H6213"\w* como dijiste, solo \w que|strong="H1697"\w* \w de|strong="H1121"\w* ello me \w hagas|strong="H6213"\w* \w primero|strong="H7223"\w* una \w torta|strong="H5692"\w* \w pequeña|strong="H6996"\w* y tráemela. Después \w harás|strong="H6213"\w* para ti y para \w tu|strong="H6213"\w* \w hijo|strong="H1121"\w*,
\v 14 \w porque|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*, ʼElohim\nd* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, dice: \wj \w La|strong="H5921"\w* \w harina|strong="H7058"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tinaja \w no|strong="H3808"\w* \w se|strong="H5921"\w* acabará, \w ni|strong="H3808"\w* \w el|strong="H5921"\w* \w aceite|strong="H8081"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* vasija disminuirá \w hasta|strong="H5704"\w* \w el|strong="H5921"\w* \w día|strong="H3117"\w* \w cuando|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* mande \w lluvia|strong="H1653"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* superficie \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra.\wj*
\p 
\v 15 \w Ella|strong="H1931"\w* \w fue|strong="H3212"\w* \w e|strong="H3068"\w* \w hizo|strong="H6213"\w* según \w la|strong="H1931"\w* \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* Elías, y comieron \w él|strong="H1931"\w*, \w ella|strong="H1931"\w*, y \w su|strong="H1931"\w* \w casa|strong="H1004"\w* muchos \w días|strong="H3117"\w*.
\v 16 La \w harina|strong="H7058"\w* \w de|strong="H1697"\w* la tinaja \w no|strong="H3808"\w* \w se|strong="H3808"\w* \w acabó|strong="H3615"\w*, \w ni|strong="H3808"\w* el \w aceite|strong="H8081"\w* \w de|strong="H1697"\w* la vasija disminuyó, conforme \w a|strong="H3068"\w* la \w Palabra|strong="H1697"\w* \w que|strong="H3808"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w habló|strong="H1696"\w* \w por|strong="H1697"\w* \w medio|strong="H3027"\w* \w de|strong="H1697"\w* Elías.
\p 
\v 17 \w Después|strong="H1961"\w* \w de|strong="H5704"\w* estas \w cosas|strong="H1697"\w*, \w aconteció|strong="H1961"\w* \w que|strong="H3808"\w* \w el|strong="H1121"\w* \w hijo|strong="H1121"\w* \w de|strong="H5704"\w* la mujer dueña \w de|strong="H5704"\w* \w casa|strong="H1004"\w* cayó \w enfermo|strong="H2470"\w*. Su \w enfermedad|strong="H2483"\w* \w fue|strong="H1961"\w* \w tan|strong="H3966"\w* \w grave|strong="H2389"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w quedó|strong="H3498"\w* aliento \w en|strong="H5704"\w* \w él|strong="H1121"\w*.
\v 18 Ella preguntó \w a|strong="H3068"\w* Elías: ¿\w Qué|strong="H4100"\w* tengo yo contigo, varón \w de|strong="H1121"\w* \nd ʼElohim\nd*? ¿Viniste aquí \w a|strong="H3068"\w* recordarme mis \w iniquidades|strong="H5771"\w* y para \w que|strong="H4100"\w* \w muera|strong="H4191"\w* mi \w hijo|strong="H1121"\w*?
\p 
\v 19 \w Y|strong="H3068"\w* \w él|strong="H1931"\w* \w le|strong="H1931"\w* respondió: ¡\w Dame|strong="H5414"\w* tu \w hijo|strong="H1121"\w*! \w Lo|strong="H1931"\w* \w tomó|strong="H3947"\w* \w del|strong="H5921"\w* \w seno|strong="H2436"\w* \w de|strong="H5921"\w* \w ella|strong="H1931"\w*, \w lo|strong="H1931"\w* \w llevó|strong="H3947"\w* \w al|strong="H5921"\w* altillo \w donde|strong="H8033"\w* \w él|strong="H1931"\w* \w vivía|strong="H3427"\w* \w y|strong="H5921"\w* \w lo|strong="H1931"\w* acostó \w en|strong="H5921"\w* \w su|strong="H1931"\w* propia \w cama|strong="H4296"\w*.
\v 20 \w Clamó|strong="H7121"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*: ¡\w Oh|strong="H1121"\w* \nd \w Yavé|strong="H3068"\w*, ʼElohim\nd* \w mío|strong="H5921"\w*! ¿\w Aun|strong="H1571"\w* \w afliges|strong="H7489"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* viuda \w en|strong="H5921"\w* cuya casa estoy hospedado, \w al|strong="H5921"\w* matar \w a|strong="H3068"\w* su \w hijo|strong="H1121"\w*?
