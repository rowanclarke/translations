\id GEN - Biblica® Open Igbo Contemporary Bible 2020 
\h Jenesis 
\toc1 Jenesis 
\toc2 Jenesis 
\toc3 Jen 
\mt1 Jenesis 
\c 1  
\s1 Mmalite ihe niile 
\p  
\v 1 Na mmalite Chineke kere eluigwe na ụwa.  
\v 2 Ụwa bụ ihe na-enweghị ụdịdị ọbụla, bụrụkwa ihe tọgbọrọ nʼefu. Ọchịchịrị gbara nʼelu ogbu mmiri dị omimi. Mmụọ nke Chineke na-erugharị nʼelu ogbu mmiri ahụ. 
\b  
\p  
\v 3 Mgbe ahụ Chineke kwuru sị, “Ka ìhè dị,” ìhè dịkwara.  
\v 4 Chineke hụrụ na ìhè ahụ mara mma. Ọ kpara oke nʼetiti ìhè na ọchịchịrị.  
\v 5 Chineke kpọrọ ìhè ahụ Ehihie, kpọọ ọchịchịrị ahụ Abalị. Uhuruchi dị, ụtụtụ dịkwa. Ọ bụrụ ụbọchị nke mbụ. 
\b  
\p  
\v 6 Chineke kwukwara sị, “Ka mbara pụta nke ga-ekewapụ mmiri dị nʼelu mbara ahụ site na mmiri nke dị nʼokpuru mbara ahụ”  
\v 7 Ya mere, Chineke mere mbara, kewapụ mmiri dị nʼokpuru mbara ahụ site na mmiri nke dị nʼelu mbara ahụ. O sikwa otu a dịrị.  
\v 8 Mbara ahụ ka Chineke kpọrọ mbara eluigwe. Uhuruchi dị, ụtụtụ dịkwa. Ọ bụrụ ụbọchị nke abụọ. 
\b  
\p  
\v 9 Chineke kwuru sị, “Ka mmiri dị nʼokpuru mbara eluigwe chịkọta onwe ha ọnụ nʼotu ebe, ka ala akọrọ pụta.” O sikwa otu a dịrị.  
\v 10 Chineke kpọrọ ala akọrọ ahụ “ala,” kpọọ mmiri ahụ chịkọtara onwe ha ọnụ “osimiri.” Chineke lere anya hụ na ha dị mma. 
\p  
\v 11 Chineke kwuru sị, “Ka ala pupụta ahịhịa ndụ dị iche iche: ahịhịa na-amịpụta mkpụrụ, na osisi dị nʼelu ala nke na-amịpụta mkpụrụ, nke mkpụrụ ọkụkụ ya dị nʼime ya, dịka ụdịdị ha dị iche iche si dị.” O sikwa otu a dịrị.  
\v 12 Ala puputara ahịhịa ndụ dị iche iche: ahịhịa na-amịpụta mkpụrụ dịka ụdịdị ha si dị, na osisi na-amịpụta mkpụrụ, nke mkpụrụ ọkụkụ ya dị nʼime ya, dịka ụdịdị ha si dị. Chineke lere anya hụ na ọ dị mma.  
\v 13 Uhuruchi dị, ụtụtụ dịkwa. Ọ bụrụ ụbọchị nke atọ. 
\b  
\p  
\v 14 Chineke kwuru sị, “Ka ìhè nke na-enye ìhè dịrị na mbara eluigwe, ikewapụ ehihie site nʼabalị. Ka ha bụrụ ihe ama igosi oge dị iche iche, ụbọchị dị iche iche, na afọ dị iche iche.  
\v 15 Ka ha bụrụ ìhè na mbara eluigwe inye ìhè nʼelu ụwa.” O si otu a dịrị.  
\v 16 Chineke mere ìhè ukwu abụọ, nke kacha ịdị ukwu ka ọ bụrụ nke ga-achị ehihie, ma nke dị nta ka ọ bụrụ nke ga-achị abalị. O mekwara kpakpando dị iche iche.  
\v 17 Chineke debere ha na mbara eluigwe inye ìhè nʼụwa,  
\v 18 ịchị ehihie na abalị na ịkpa oke nʼetiti ìhè na ọchịchịrị. Chineke lere anya hụ na ọ dị mma.  
\v 19 Uhuruchi dị, ụtụtụ dịkwa. Ọ bụrụ ụbọchị nke anọ. 
\b  
\p  
\v 20 Chineke kwuru sị, “Ka mmiri jupụta nʼihe ndị na-eku ume, ka ụmụ anụ ufe fegharịkwa nʼelu ụwa, ma nʼelu mbara igwe.”  
\v 21 Ya mere Chineke kere anụ ukwu niile bi na mmiri, na anụ niile nwere ndụ bi na mmiri, na ụdị ihe ọbụla nwere ndụ na-akpụgharị akpụgharị ndị jupụtara na mmiri, dịka ụdịdị ha si dị, na anụ ufe niile dịka ụdịdị ha si dị. Chineke lere anya hụ na ọ dị mma.  
\v 22 Chineke gọziri ha, sị ha, “Mụbaanụ, dịkwanụ ukwuu nʼọnụọgụgụ, jupụtanụ osimiri niile. Ka anụ ufe dịkwa ukwuu nʼọnụọgụgụ nʼelu ụwa.”  
\v 23 Uhuruchi dị, ụtụtụ dịkwa. Ọ bụrụ ụbọchị nke ise. 
\b  
\p  
\v 24 Chineke kwuru sị, “Ka ala wepụta ụmụ anụ dị iche iche nwere ndụ dịka ụdịdị ha si dị: anụ ụlọ, anụ na-akpụgharị nʼala, na anụ ọhịa, nke ọbụla dịka ụdịdị ya si dị.” O si otu a dịrị.  
\v 25 Chineke mere ụmụ anụ ọhịa, dịka ụdịdị ha si dị, mee anụ ụlọ, dịka ụdịdị ha si dị, na anụ niile nwere ndụ nke na-akpụgharị nʼala dịka ụdịdị ha si dị. Chineke lere anya hụ na ọ dị mma. 
\p  
\v 26 Mgbe ahụ, Chineke kwuru sị, “Ka anyị mee mmadụ nʼoyiyi anyị, dịka ụdịdị anyị si dị, ka ha chịa azụ niile nke osimiri, na anụ ufe niile nke eluigwe, na anụ ụlọ niile, na anụ ọhịa niile, na ihe niile e kere eke nwere ndụ nke na-akpụ akpụ nʼala.” 
\q1  
\v 27 Ya mere, Chineke kere mmadụ nʼoyiyi nke ya, 
\q2 nʼoyiyi Chineke ka o kere ha, 
\q2 nwoke na nwanyị ka o kere ha. 
\p  
\v 28 Chineke gọziri ha sị ha, “Mịanụ mkpụrụ, mụbaanụ, jupụtanụ nʼụwa, meenụ ka ihe niile dịrị nʼokpuru unu. Chịanụ azụ niile nke osimiri na anụ ufe niile nke eluigwe na ihe niile e kere dị ndụ nke na-akpụgharị akpụgharị nʼala.” 
\p  
\v 29 Mgbe ahụ, Chineke sịrị “Enyela m unu ahịhịa ubi niile na-amị mkpụrụ dị nʼelu ụwa, na osisi ọbụla mịrị mkpụrụ, nke mkpụrụ ọkụkụ ya dị nʼime ha, ka ha bụrụ ihe oriri gị.  
\v 30 Ma ụmụ anụmanụ niile na anụ ufe niile, na anụ niile e kere eke na-akpụgharị akpụgharị nʼala, anụ ọbụla nwere ndụ nʼime ha ka m na-enye ahịhịa ndụ niile ka ọ bụrụ ihe oriri ha.” 
\p  
\v 31 Chineke legharịrị anya nʼihe o kere, hụ na ọ dị ezi mma. Uhuruchi dị, ụtụtụ dịkwa. Ọ bụrụ ụbọchị nke isii. 
\b  
\c 2  
\p  
\v 1 Otu a ka e si rụzuo ọrụ ike eluigwe na ụwa na ihe niile dị nʼime ha. 
\b  
\p  
\v 2 Nʼụbọchị nke asaa, Chineke kwụsịrị ọrụ ya nke ọ na-arụ, o zukwara ike site nʼọrụ ya niile.  
\v 3 Chineke gọziri ụbọchị nke asaa ahụ mee ya ka ọ bụrụ ụbọchị dị nsọ, nʼihi na ọ bụ nʼụbọchị ahụ ka ọ zuru ike site nʼọrụ nke ike ihe niile. 
\s1 Adam na Iiv 
\p  
\v 4 Nke a bụ akụkọ banyere usoro okike eluigwe na ụwa mgbe e kere ha, nʼụbọchị ahụ mgbe \nd Onyenwe anyị\nd* Chineke kere eluigwe na ụwa. 
\b  
\p  
\v 5 Ahịhịa ọbụla epupụtabeghị nʼọhịa, o nwekwaghị ihe ubi ọbụla sitere nʼala pupụta, nʼihi na \nd Onyenwe anyị\nd* Chineke ezitebeghị mmiri ozuzo nʼelu ụwa, o nwekwaghị mmadụ ọbụla nọ na-arụ ọrụ ubi,  
\v 6 ma mmiri si nʼala na-asọpụta na-asọ nʼelu ala niile.  
\v 7 \nd Onyenwe anyị\nd* Chineke kpụrụ mmadụ site nʼaja nke ala, kunye ya ume ndụ nʼimi ya, nke mere ka mmadụ ghọọ ihe dị ndụ. 
\p  
\v 8 \nd Onyenwe anyị\nd* Chineke kụrụ ubi a gbara ogige nʼakụkụ ọwụwa anyanwụ, nʼIden. O tinyere mmadụ ahụ ọ kpụrụ nʼime ubi a.  
\v 9 \nd Onyenwe anyị\nd* Chineke mere ka osisi dị iche iche si nʼala pupụta, osisi ndị dị mma ile anya na nke dịkwa mma iri eri. Nʼetiti ogige a, e nwere osisi na-enye ndụ, na osisi nke ịmata ihe ọma na ihe ọjọọ. 
\p  
\v 10 E nwere iyi si nʼIden na-asọpụta na-asọbanye nʼime ogige ahụ ime ka ala ahụ nwee mmiri. Site nʼebe ahụ, iyi a kewara nwee ngalaba anọ.  
\v 11 Aha ngalaba nke mbụ bụ Paịshọn. Ọ sọọrọ ogologo gafee ala niile nke Havila, ebe a na-enweta ọlaedo.  
\v 12 (Ọlaedo dị nʼala ahụ mara mma. Eso osisi na-esi isi ụtọ na nkume dị oke ọnụahịa a na-akpọ ọniks dịkwa nʼebe ahụ.)  
\v 13 Aha ngalaba nke abụọ bụ Gaihọn. O sitere nʼala Kush\f + \fr 2:13 \ft Kush bụ aha e ji maara ala ndị Sụdan \ft maọbụ \fqa Itiopia nʼasụsụ ndị Hibru. \ft Mgbe ọbụla e kwuru banyere Kush nʼakwụkwọ ọgbụgba ndụ ochie, ọ bụ ala ahụ ka a na-ekwu ihe banyere ya.\f* gafee.  
\v 14 Aha osimiri nke atọ bụ Taịgris. Ọ na-asọla nʼakụkụ ọwụwa anyanwụ nke ala Ashọ.\f + \fr 2:14 \ft Ashọ na Asịrịa bụ otu ihe\f* Aha osimiri nke anọ bụ Yufretis. 
\p  
\v 15 \nd Onyenwe anyị\nd* Chineke weere mmadụ ahụ tinye ya nʼogige Iden, ka ọ na-akọ ya ma bụrụkwa onye na-elekọta ya.  
\v 16 \nd Onyenwe anyị\nd* Chineke nyere mmadụ ahụ iwu sị ya “I nwere ike iri mkpụrụ osisi niile dị nʼubi a,  
\v 17 ma ị gaghị eri mkpụrụ si nʼosisi ịmata ihe ọma na ihe ọjọọ. Nʼihi na ụbọchị i riri ya ị ga-anwụrịrị.” 
\p  
\v 18 \nd Onyenwe anyị\nd* Chineke kwuru sị, “Ọ dịghị mma ka nwoke nọrọ naanị ya. Aga m emere ya onye inyeaka nke kwesiri ya.” 
\p  
\v 19 \nd Onyenwe anyị\nd* Chineke sitere nʼala kpụọ ụmụ anụmanụ niile nke ọhịa na ụmụ anụ ufe niile nke eluigwe. O dutere ha ka ọ mara ihe mmadụ ahụ ga-akpọ ha. Ihe ọbụla mmadụ ahụ kpọrọ ihe ọbụla ndị a nwere ndụ, nke ahụ bụkwa aha ya.  
\v 20 Ya mere, mmadụ ahụ nyere anụ ụlọ niile na anụ ufe niile na anụ ọhịa niile aha. 
\p Ma nʼebe Adam nọ, o nweghị onye inyeaka kwesiri ya.  
\v 21 Ya mere, \nd Onyenwe anyị\nd* Chineke mere ka nwoke ahụ daa nʼụra. Mgbe ọ nọ na-arahụ ụra, o wepụtara otu ọgịrịga site na ngụ dị ya nʼahụ, mechikwaa ebe o si wepụta ya.  
\v 22 Mgbe ahụ, \nd Onyenwe anyị\nd* Chineke ji otu ọgịrịga o si nʼahụ nwoke ahụ wepụta, mee nwanyị, dutere ya nwoke ahụ. 
\p  
\v 23 Nwoke ahụ kwuru sị, 
\q1 “Nke a bụ ọkpụkpụ si nʼọkpụkpụ m, 
\q2 na anụ ahụ si nʼahụ m, 
\q1 a ga-akpọ ya ‘nwanyị,’ 
\q2 nʼihi na e si nʼime nwoke wepụta ya.” 
\m  
\v 24 Ọ bụ nke a mere nwoke ga-eji hapụ nne na nna ya, e jikọta ya na nwunye ya, ha ga-abụ otu anụ ahụ. 
\p  
\v 25 Nwoke ahụ na nwunye ya gba ọtọ, ma ihere emeghị ha. 
\c 3  
\s1 Mmehie na Ọdịda 
\p  
\v 1 Agwọ dị aghụghọ karịa ụmụ anụ ọhịa niile \nd Onyenwe anyị\nd* Chineke kere. Ọ bịakwutere nwanyị ahụ sị ya, “Ọ bụ ezie na Chineke sị unu erila mkpụrụ si nʼosisi niile dị nʼogige a?” 
\p  
\v 2 Nwanyị ahụ zara sị ya, “Anyị nwere ike rie mkpụrụ si nʼosisi niile dị nʼogige a  
\v 3 ma Chineke kwuru sị, ‘Unu erila mkpụrụ si nʼosisi dị nʼetiti ogige a, unu emetụkwala ya aka, ka unu ghara ịnwụ.’ ” 
\p  
\v 4 Agwọ gwara nwanyị ahụ sị, “Unu agaghị anwụ.  
\v 5 Nʼihi na Chineke maara na ọ bụrụ na unu erie ya, anya unu ga-emeghe, unu ga-amata ezi ihe na ajọ ihe.” 
\p  
\v 6 Nwanyị ahụ hụrụ na mkpụrụ si nʼosisi ahụ dị mma iri eri, na ọ dị mma nʼanya, na ọ bụ osisi mara mma e si enweta amamihe. Ọ ghọọrọ mkpụrụ ahụ rie, nyekwa di ya, onye nke na ya nọ, o rie.  
\v 7 Mgbe ahụ, anya ha abụọ meghere, ha chọpụtara na ha gba ọtọ. Ya mere, ha dụkọtara ahịhịa fiig, jiri ya mere onwe ha akwa. 
\p  
\v 8 Mgbe nwoke ahụ na nwunye ya nụrụ ụda njegharị \nd Onyenwe anyị\nd* Chineke nʼogige ahụ nʼoge uhuruchi, ha zoro onwe ha site nʼebe \nd Onyenwe anyị\nd* Chineke nọ nʼetiti osisi ndị dị nʼogige ahụ.  
\v 9 Ma \nd Onyenwe anyị\nd* Chineke kpọrọ nwoke ahụ oku sị ya, “Ebee ka ị nọ?” 
\p  
\v 10 Ọ zara si, “Anụrụ m ụda ụkwụ gị nʼogige, nʼihi ya, atụrụ m ụjọ, ebe ọ bụ na m gba ọtọ. Ezokwara m onwe m.” 
\p  
\v 11 \nd Onyenwe anyị\nd* Chineke jụrụ ya sị, “Onye gwara gị na ị gba ọtọ? I riela mkpụrụ si nʼosisi ahụ m nyere gị iwu sị gị erila?” 
\p  
\v 12 Nwoke ahụ sịrị, “Nwanyị ahụ i mere ka mụ na ya nọdụ, ọ bụ ya nyere m mkpụrụ sitere nʼosisi ahụ, m rie.” 
\p  
\v 13 Mgbe ahụ, \nd Onyenwe anyị\nd* Chineke sịrị nwanyị ahụ, “Gịnị bụ ihe a i mere?” 
\p Nwanyị ahụ zara sị, “Ọ bụ agwọ ghọgburu m, mee m ka m rie ya.” 
\s1 Ikpe Ọmụma 
\p  
\v 14 Ya mere, \nd Onyenwe anyị\nd* Chineke gwara agwọ ahụ sị, “Nʼihi ihe a i mere, 
\q1 “Ihe a bụrụ ọnụ ka ị bụ nʼetiti anụ ụlọ niile 
\q2 na nʼetiti anụ ọhịa niile. 
\q1 Afọ gị ka ị ga-eji na-aga ije, 
\q2 aja ka ị ga na-eri 
\q2 ogologo ụbọchị ndụ gị niile. 
\q1  
\v 15 Aga m eme ka iro 
\q2 dịrị nʼetiti gị na nwanyị ahụ, 
\q2 nʼetiti mkpụrụ gị na mkpụrụ ya, 
\q1 mkpụrụ ya ga-etipịa gị isi, 
\q2 gị onwe gị ga-ata ya arụ nʼikiri ụkwụ.” 
\p  
\v 16 Ọ gwara nwanyị ahụ sị ya, 
\q1 “Aga m eme ka ihe mgbu nke ịmụ nwa gị baa ụba nke ukwuu, 
\q2 ọ bụ site nʼihe mgbu ka ị ga-eji mụpụta ụmụ gị. 
\q1 Ọchịchọ nke obi gị ga-adị nʼaka di gị, 
\q2 ọ bụ ya ga-achịkwa gị.” 
\p  
\v 17 Ọ gwara Adam sị, “Nʼihi na ị ṅara nwunye gị ntị, rie mkpụrụ site nʼosisi ahụ m nyere gị iwu sị, ‘Gị erila mkpụrụ sitere na ya,’ 
\q1 “Ala bụ ihe a bụrụ ọnụ nʼihi gị, 
\q2 site nʼoke ndọgbu nʼọrụ ka ị ga-eri ihe si na ya pụta 
\q2 ogologo ụbọchị ndụ gị niile. 
\q1  
\v 18 Ọ ga-erupụtara gị ogwu na uke, 
\q2 ị ga-erikwa ahịhịa nke ubi. 
\q1  
\v 19 Site nʼọsụsọ nke ga-agbapụta gị nʼihu 
\q2 ka ị ga-eri nri gị 
\q1 tutu ruo mgbe ị lọghachiri nʼala 
\q2 ebe ọ bụ site nʼala ka e si mepụta gị 
\q1 nʼihi na aja ka ị bụ, 
\q2 nʼaja ka ị ga-alaghachikwa.” 
\p  
\v 20 Adam\f + \fr 3:20 \ft Maọbụ, \fqa Nwoke ahụ\f* gụrụ nwunye ya Iiv,\f + \fr 3:20 \ft Eleghị anya Iiv pụtara Ịdị ndụ\f* nʼihi na ọ bụ nne mmadụ niile dị ndụ. 
\p  
\v 21 Emesịa, \nd Onyenwe anyị\nd* Chineke weere akpụkpọ anụ meere Adam na nwunye ya uwe oyiyi.  
\v 22 \nd Onyenwe anyị\nd* Chineke sịrị, “Lee, mmadụ adịla ka onye ọbụla nʼime anyị site nʼịmata ihe ọma na ihe ọjọọ. Ugbu a, ka ọ gharakwa ị setịpụ aka ya ghọrọ mkpụrụ osisi ahụ na-enye ndụ rie, si otu a dịrị ndụ ruo mgbe ebighị ebi.”  
\v 23 Nʼihi nke a, \nd Onyenwe anyị\nd* Chineke chụpụrụ ya site nʼogige Iden ka ọ gaa na-arụ ọrụ nʼala e si wepụta ya.  
\v 24 Mgbe ọ chụpụrụ mmadụ, o dochiri nʼọwụwa anyanwụ nke ogige Iden ndị mmụọ ozi dị ike a na-akpọ Cherubim, na mma agha na-acha ọkụ, ka ha na-eche ọnụ ụzọ e si aba nʼebe osisi ahụ na-enye ndụ dị nche. 
\c 4  
\s1 Ken na Ebel 
\p  
\v 1 Emesịa, Adam na nwunye ya Iiv dinakọrọ dịka di na nwunye. Iiv tụụrụ ime mụọ nwa nwoke, onye ha gụrụ Ken. Iiv sịrị, “Site nʼinyeaka \nd Onyenwe anyị\nd*, amụtala m nwa nwoke!”  
\v 2 Emesịa Iiv mụtara nwanne ya nwoke Ebel. 
\p Ebel ghọrọ onye na-azụ igwe atụrụ. Ma Ken ghọrọ onye ọrụ ubi.  
\v 3 Mgbe ụfọdụ oge gasịrị, Ken wetaara \nd Onyenwe anyị\nd* ụfọdụ ihe ubi ya dịka onyinye.  
\v 4 Ma Ebel, ya onwe ya nyekwara onyinye site nʼigwe ewu na atụrụ ya e bụ ụzọ mụọ, nke mara abụba. \nd Onyenwe anyị\nd* nabatara Ebel na onyinye ya,  
\v 5 ma ọ nabataghị Ken na onyinye ya. Nke a wutere Ken, mee ka o wee iwe dị ukwuu. Ihu ya agbarụọ. 
\p  
\v 6 Ma \nd Onyenwe anyị\nd* jụrụ ya sị, “Gịnị mere i ji ewe iwe? Gịnị mere ihu gị ji gbarụọ?  
\v 7 Ọ bụrụ na i mee ihe ziri ezi, agaghị anabata gị? Ọ bụrụkwanụ na ị jụ ime ihe ziri ezi, mmehie nọ nʼọnụ ụzọ na-eche gị ịla gị nʼiyi. Lezie anya hụ na i meriri ya.” 
\p  
\v 8 Ken gwara nwanne ya Ebel sị, “Bịa soro m ka anyị banye ọhịa.” Mgbe ha nọ nʼebe ahụ, Ken jidere nwanne ya gbuo ya. 
\p  
\v 9 Emesịa, \nd Onyenwe anyị\nd* jụrụ Ken ajụjụ sị, “Ebee ka Ebel nwanne gị nwoke nọ?” 
\p Ọ zaghachiri, “Amaghị m. Abụ m onye nche nwanne m?” 
\p  
\v 10 Ma \nd Onyenwe anyị\nd* zara sị ya, “Gịnị ka i mere? Gee ntị, ọbara nwanne gị na-akpọku m site nʼala.  
\v 11 Site ugbu a gaa nʼihu ị bụrụla onye a bụrụ ọnụ, na onye e si nʼala chụpụ, ala ahụ meghepụrụ ọnụ ya nabata ọbara nwanne gị, site nʼaka gị.  
\v 12 Mgbe ị kụrụ ihe ọbụla nʼime ya, ala agaghị enye gị mkpụrụ ya nʼuju. Site ugbu a gaa nʼihu, ị ga-abụ onye na-awagharị awagharị na onye na-abaghị nʼihe nʼụwa.” 
\p  
\v 13 Ken zara \nd Onyenwe anyị\nd*, “Ntaramahụhụ i nyere m dị ukwuu karịa nke m nwere ike ibu.  
\v 14 Ugbu a, abụ m onye i si nʼala ubi ya chụpụ. Abụkwa m onye i si nʼihu gị chụpụ. Bido taa aga m abụ onye na-awagharị awagharị nʼime ụwa. Onye ọbụla hụkwara m ga-egbu m.” 
\p  
\v 15 \nd Onyenwe anyị\nd* zara sị ya, “O nweghị onye ga-egbu gị, nʼihi na aga m atụkwasịrị onye ọbụla metụrụ gị aka ntaramahụhụ okpukpu asaa karịa nke m nyere gị.” Ya mere, \nd Onyenwe anyị\nd* kara Ken akara iji gbochie onye ọbụla hụrụ ya igbu ya.  
\v 16 Ken sitere nʼihu \nd Onyenwe anyị\nd* pụọ gaa biri nʼala Nọd,\f + \fr 4:16 \fq Nọd \ft pụtara \fqa Awagharị \ft Nke a dị nʼamaokwu \xt 4:12,16\f* obodo dị nʼakụkụ ọwụwa anyanwụ Iden. 
\p  
\v 17 Ken na nwunye ya dinakọrọ, nwunye ya tụụrụ ime mụta nwa nwoke aha ya bụ Enọk. Nʼoge a, Ken nọ na-ewu otu obodo ọ gụrụ Enọk, nke bụ aha nwa ya nwoke.  
\v 18 Enọk bụ nna Irad, Irad bụ nna Mehujael, Mehujael bụ nna Metusael, Metusael abụrụ nna Lamek. 
\p  
\v 19 Lamek lụrụ ụmụ nwanyị abụọ. Aha nwunye ya nke mbụ bụ Ada. Aha nke ọzọ bụ Zila.  
\v 20 Ada mụtara Jabal, onye bụ nna ndị na-azụ anụ ụlọ, na ndị na-ebi nʼụlọ ikwu.  
\v 21 Aha nwanne ya nwoke bụ Jubal, onye mbụ bụ nna ndị na-akpọ ụbọ akwara, na ndị na-afụ opi.  
\v 22 Zila, mụtara otu nwa nwoke aha ya bụ Tubal Ken, onye bụ nna ndị niile na-akpụ ihe dị iche iche e ji bronz maọbụ igwe kpụọ. Aha nwanne nwanyị Tubal Ken bụ Naama. 
\p  
\v 23 Lamek kpọrọ ndị nwunye ya sị ha, 
\q1 “Geenụ m ntị, Ada na Zila, 
\q2 unu ndị nwunye Lamek, nụrụ okwu sị m nʼọnụ. 
\q1 Egbuola m otu nwoke nʼihi na ọ merụrụ m ahụ, 
\q2 otu nwokorobịa nʼihi na ọ mehịara m ahụ. 
\q1  
\v 24 Ọ bụrụ na a ga-abọtara Ken ọbọ ugboro asaa, 
\q2 mgbe ahụ, a ga-abọtara Lamek ọbọ iri ugboro asaa na asaa.” 
\p  
\v 25 Adam na Iiv dinakọrọ ọzọ, Iiv tụụrụ ime mụta nwa nwoke ọ gụrụ Set. Nʼihi na Iiv kwuru sị, “Chineke enyela m nwa nwoke ọzọ nʼọnọdụ Ebel onye Ken gburu.”  
\v 26 Set mụtara nwa nwoke gụọ ya Enọsh. 
\p Nʼoge ahụ ka ụmụ mmadụ bidoro ịkpọku aha \nd Onyenwe anyị\nd*. 
\c 5  
\s1 Site nʼAdam ruo Noa 
\p  
\v 1 Nke a bụ usoro ihe ndepụta banyere agbụrụ Adam. 
\b  
\p Mgbe Chineke kere mmadụ, o kere ya nʼoyiyi Chineke.  
\v 2 O kere ha nwoke na nwanyị, gọziekwa ha. Mgbe e kere ha, ọ kpọrọ ha mmadụ. 
\b  
\li1  
\v 3 Mgbe Adam gbara narị afọ na iri afọ atọ, ọ mụrụ nwa ya nwoke nʼoyiyi nke ya, na nʼụdịdị nke ya. Ọ gụrụ ya Set.  
\v 4 Site nʼoge a mụrụ Set, Adam dịrị ndụ narị afọ asatọ ọzọ, ọ mụrụ ụmụ ndị ikom na ụmụ ndị inyom.  
\v 5 Adam nwụrụ mgbe ọ gbara narị afọ itoolu na iri afọ atọ. 
\li1  
\v 6 Set gbara narị afọ na ise mgbe ọ ghọrọ nna Enọsh,  
\v 7 Mgbe ọ ghọchara nna Enọsh, Set dịrị ndụ ruo narị afọ asatọ na asaa ọzọ, mụta ụmụ ndị ikom na ụmụ ndị inyom.  
\v 8 Set nwụrụ mgbe ọ gbara narị afọ itoolu na iri afọ na abụọ. 
\li1  
\v 9 Mgbe Enọsh gbara iri afọ itoolu, ọ ghọrọ nna Kenan.  
\v 10 Mgbe ọ ghọchara nna Kenan, Enọsh dịrị ndụ narị afọ asatọ na iri afọ na ise, mụta ụmụ ndị ikom na ụmụ ndị inyom.  
\v 11 Enọsh nwụkwara mgbe ọ nọzuru narị afọ itoolu na afọ ise. 
\li1  
\v 12 Mgbe Kenan gbara iri afọ asaa ka ọ ghọrọ nna Mahalalel.  
\v 13 Mgbe ọ ghọchara nna Mahalalel, Kenan dịrị ndụ narị afọ asatọ na iri afọ anọ mụta ụmụ ndị ikom na ụmụ ndị inyom.  
\v 14 Kenan nwụrụ mgbe ọ gbara narị afọ itoolu na afọ iri. 
\li1  
\v 15 Mgbe Mahalalel gbara iri afọ isii na afọ ise ka ọ ghọrọ nna Jared.  
\v 16 Mgbe ọ ghọchara nna Jared, Mahalalel dịrị ndụ narị afọ asatọ na iri afọ atọ, mụta ụmụ ndị ikom na ụmụ ndị inyom.  
\v 17 Mahalalel nwụrụ mgbe ọ gbara narị afọ asatọ na iri afọ itoolu na ise. 
\li1  
\v 18 Mgbe Jared dị narị afọ na iri afọ isii na abụọ ka ọ ghọrọ nna Enọk.  
\v 19 Mgbe ọ ghọchara nna Enọk, Jared dịrị ndụ narị afọ asatọ ọzọ mụta ụmụ ndị ikom na ụmụ ndị inyom.  
\v 20 Jared nwụrụ mgbe ọ gbara narị afọ itoolu na iri afọ isii na abụọ. 
\li1  
\v 21 Mgbe Enọk gbara iri afọ isii na afọ ise ka ọ ghọrọ nna Metusela.  
\v 22 Mgbe ọ ghọchara nna Metusela, Enọk soro ụzọ Chineke narị afọ atọ. Nʼoge a, ọ mụtara ụmụ ndị ikom na ụmụ ndị inyom.  
\v 23 Ọnụọgụgụ nke afọ niile Enọk biri ndụ, bụ narị afọ atọ na iri afọ isii na ise.  
\v 24 Enọk soro ụzọ Chineke ruo na a hụkwaghị ya nʼihi na Chineke kpọọrọ ya. 
\li1  
\v 25 Mgbe Metusela gbara narị afọ na iri afọ asatọ na asaa ka ọ ghọrọ nna Lamek.  
\v 26 Mgbe ọ ghọchara nna Lamek, Metusela dịrị ndụ narị afọ asaa na iri afọ asatọ na abụọ ọzọ mụta ụmụ ndị ikom na ụmụ ndị inyom.  
\v 27 Metusela nwụrụ mgbe ọ gbara narị afọ itoolu na iri afọ isii na itoolu. 
\li1  
\v 28 Mgbe Lamek gbara narị afọ na iri afọ asatọ na abụọ ka ọ mụtara nwa nwoke.  
\v 29 Lamek gụrụ ya Noa, nʼihi na ọ sịrị: “Ọ ga-akasị anyị obi nʼime oke ọrụ na ndọgbu anyị na-adọgbu onwe anyị nʼọrụ nʼala a \nd Onyenwe anyị\nd* bụrụ ọnụ.”  
\v 30 Mgbe a mụsịrị Noa, Lamek dịrị ndụ narị afọ ise na iri afọ itoolu na ise ọzọ mụta ụmụ ndị ikom na ụmụ ndị inyom.  
\v 31 Lamek nwụrụ mgbe ọ gbara narị afọ asaa na iri afọ asaa na asaa. 
\li1  
\v 32 Mgbe Noa gbara narị afọ ise ọ ghọrọ nna Shem, Ham na Jafet. 
\c 6  
\s1 Ajọ omume dị nʼime Ụwa 
\p  
\v 1 Mgbe ndị mmadụ bidoro mụbaa nʼụwa, mgbe a mụtakwaara ha ọtụtụ ụmụ ndị inyom,  
\v 2 ka ụmụ ndị ikom Chineke bidoro ilekwasị ụmụ ndị inyom ndị mmadụ anya, hụ na ha mara mma. Ha duuru ndị inyom ọbụla masịrị ha ka ha bụrụ nwunye ha.  
\v 3 Mgbe ahụ, \nd Onyenwe anyị\nd* sịrị, “Mmụọ m na mmadụ agaghị anọgide nʼịgba mgba nʼime mmadụ ruo ebighị ebi, nʼihi na mmadụ efu ka ọ bụ.\f + \fr 6:3 \ft Maọbụ, \fqa Mmụọ m agaghị adịgide nʼime mmadụ ruo ebighị ebi nʼihi na ha bụ ihe rụrụ arụ.\f* Ọnụọgụgụ ndụ ya ga-abụ narị afọ na iri afọ abụọ.” 
\p  
\v 4 Ndị Nefilim nọ nʼụwa nʼoge ahụ, ma nʼoge sotere ya mgbe ahụ, ụmụ ndị ikom Chineke na-abakwuru ndị inyom ụmụ mmadụ, site na mmekọrịta dị otu a mụọ ụmụ. Ndị a bụ ndị dike mgbe ochie ahụ, ndị a ma ama. 
\p  
\v 5 \nd Onyenwe anyị\nd* hụrụ otu ịba ụba nke ajọ omume mmadụ si dị ukwuu, hụkwa na echiche uche nke obi ya niile dị naanị nʼime ihe ọjọọ, mgbe niile.  
\v 6 O wutere \nd Onyenwe anyị\nd* nke ukwuu na o kere mmadụ, mkpụrụobi ya jupụtakwara nʼihe mgbu.  
\v 7 Nʼihi ya, \nd Onyenwe anyị\nd* sịrị, “Aga m esi nʼụwa kpochapụ mmadụ niile m kere eke. E e, mmadụ na anụmanụ niile, na ihe e kere eke na-akpụgharị nʼelu ala, na anụ ufe niile. Nʼihi na o wutere m na m kere ha.”  
\v 8 Ma Noa nwetara ihuọma nʼanya \nd Onyenwe anyị\nd*. 
\s1 Noa na uju mmiri 
\p  
\v 9 Nke a bụ akụkọ banyere usoro ndụ Noa na ezinaụlọ ya. 
\b  
\p Noa bụ onye ezi omume. Onye na-enweghị ịta ụta ọbụla nʼetiti ndị bi nʼoge ya. O mere ihe nʼụzọ Chineke chọrọ ya.  
\v 10 Noa mụtara ụmụ ndị ikom atọ aha ha bụ, Shem, Ham, na Jafet. 
\p  
\v 11 Ma nʼanya Chineke, ụwa bụ ihe rụrụ arụ, jupụtakwa nʼihe ike.  
\v 12 Chineke hụrụ otu ụwa si jọgbuo onwe ya na njọ, hụkwa na ụmụ mmadụ bụ ndị ihe ọjọọ riri ahụ.  
\v 13 Chineke sịrị Noa, “Aga m ebibi ihe niile bụ mmadụ, nʼihi na ụwa jupụtara nʼihe ike nʼihi omume mmadụ. E e, aga m ebibi ụwa na ndị niile nọ nʼime ya.  
\v 14 Ya mere, jiri osisi gofa wuore onwe gị ụgbọ mmiri. Rụnye ọtụtụ ọnụụlọ nʼime ya. Jiri korota techie elu ya na ime ya.  
\v 15 Otu a ka i ga-esi wuo ya: mee ka ogologo ụgbọ mmiri ahụ dịrị narị mita na iri mita anọ, obosara ya dịrị iri mita abụọ na atọ, ịdị elu ya dịrị mita iri na atọ na ọkara.  
\v 16 Meere ụgbọ mmiri ahụ ihe e ji ekpuchi elu ya. Mekwa oghere ga-adị ọkara mita site nʼebe ihe mkpuchi elu ụgbọ mmiri ahụ gbadata. Tinye ọnụ ụzọ nʼakụkụ ụgbọ mmiri ahụ, ma rụọkwa okpukpu nkwasa atọ, nke ala ala, nke etiti na nke elu elu.  
\v 17 Nʼihi na aga m eweta uju mmiri nʼụwa, ibibi ihe niile nwere ndụ dị nʼokpuru eluigwe. Ihe niile e kere eke na-eku ume ndụ ga-anwụ. Ihe niile nọ nʼụwa ga-ala nʼiyi.  
\v 18 Ma aga m eme ka ọgbụgba ndụ m dịrị gị. Ị ga-abanye nʼụgbọ mmiri ahụ, gị na ụmụ gị ndị ikom, na nwunye gị, na ndị nwunye ụmụ gị ndị ikom.  
\v 19 Ị ga-ewebata ihe niile e kere eke dị ndụ, abụọ abụọ, oke na nwunye, ichebe ha ndụ.  
\v 20 Ụdị nnụnụ dị iche iche, abụọ abụọ, na ụdị anụmanụ ọbụla dị iche iche, na ụdị anụ na-akpụ akpụ dị iche iche, ga-abịakwute gị ka i debe ha ndụ.  
\v 21 Ị ga-ewebata ụdị nri dị iche iche a na-eri eri, chịkọtaa ha ka ọ bụrụ nri nke gị na nke ha.” 
\p  
\v 22 Noa mere ihe niile dịka Chineke nyere ya iwu ime. 
\c 7  
\p  
\v 1 Mgbe ụbọchị ahụ zuru, \nd Onyenwe anyị\nd* kpọrọ Noa sị ya, “Baa nʼime ụgbọ mmiri, gị na ezinaụlọ gị niile, nʼihi na nʼime ndị niile bi nʼọgbọ a, ọ bụ naanị gị bụ onye ezi omume m hụrụ.  
\v 2 Kpọrọ ụmụ anụmanụ ndị a a gụrụ dịka ndị dị ọcha, dịka ụdị ha si dị asaa asaa, oke na nwunye. Otu a kwa, kpọrọkwa ụmụ anụmanụ ndị a gụrụ dịka ndị na-adịghị ọcha, dịka ụdị ha si dị, abụọ abụọ, oke na nwunye,  
\v 3 na ụmụ anụ ufe asaa asaa, dịka ụdị ha si dị, oke na nwunye, maka idebe ụdị ndị a niile ndụ nʼụwa.  
\v 4 Nʼihi na ụbọchị asaa site taa, aga m ezidata mmiri ozuzo nʼụwa. Mmiri a ga-ezo iri ụbọchị anọ, ehihie na abalị. Aga m ekpochapụ site nʼelu ụwa ihe niile nwere ndụ nke m kere.” 
\p  
\v 5 Ya mere, Noa mere ihe niile \nd Onyenwe anyị\nd* nyere ya nʼiwu. 
\p  
\v 6 Noa gbara narị afọ isii mgbe mmiri ukwu a bidoro izo nʼelu ụwa.  
\v 7 Noa banyere nʼụgbọ mmiri ahụ, ya na ụmụ ya ndị ikom na nwunye ya, na ndị nwunye ụmụ ya ndị ikom ịgbanarị uju mmiri ahụ.  
\v 8 Ụmụ anụmanụ ndị dị ọcha, na ndị na-adịghị ọcha, abụọ abụọ, tinyere anụ ufe na ihe niile e kere eke na-akpụgharị nʼala, abụọ abụọ kwa,  
\v 9 oke na nwunye, bịakwutere Noa soro ya banye nʼụgbọ mmiri ahụ, dịka Chineke nyere Noa nʼiwu.  
\v 10 Mgbe abalị asaa gafere, uju mmiri ahụ bịakwasịrị ụwa. 
\p  
\v 11 Nʼafọ narị isii nke ndụ Noa, nʼọnwa nke abụọ, nʼụbọchị nke iri na asaa, bụ ụbọchị isi iyi niile dị nʼime ime ala nupụtara nʼelu ala, mmiri niile dị na mbara eluigwe ka a hapụrụ ka ha wụdata nʼụwa.  
\v 12 Mmiri zogịdere na-esepụghị aka iri ụbọchị anọ, ehihie na abalị. 
\p  
\v 13 Nʼụbọchị ahụ kpomkwem, Noa banyere nʼụgbọ mmiri ahụ, ya na Shem, Ham na Jafet, bụ ụmụ Noa, na nwunye Noa, na ndị nwunye atọ nke ụmụ ya.  
\v 14 Ha onwe ha, na anụ ọhịa ọbụla, nʼụdị ya, na anụ ụlọ ọbụla, nʼụdị ya na ihe ọbụla e kere eke na-akpụgharị nʼala, nʼụdị ya, na anụ ufe ọbụla nʼụdị ya, na aha nnụnụ ọbụla na ihe ọbụla nwere nku.  
\v 15 Ha bịakwutere Noa nʼime ụgbọ mmiri ahụ, abụọ abụọ site nʼihe niile ọbụla e kere eke, nke nwere ume ndụ nʼime ha.  
\v 16 Ma ndị banyerenụ bụ oke na nwunye, site na ihe niile nwere ndụ dịka Chineke nyere ya nʼiwu. Mgbe ahụ, \nd Onyenwe anyị\nd* mechiri ọnụ ụzọ dị nʼụgbọ mmiri ahụ. 
\p  
\v 17 Uju mmiri nọgidere nʼụwa iri ụbọchị anọ. Mgbe mmiri ndị a na-aba ụba, ha buliri ụgbọ mmiri ahụ elu site nʼelu ala.  
\v 18 Mmiri ndị a toro na-ala elu na-abawanyekwa ụba nʼelu ụwa. Ụgbọ mmiri ahụ segooro nʼelu mmiri.  
\v 19 Mmiri ndị ahụ toro laa elu kpuchie ugwu ukwu niile dị nʼokpuru mbara eluigwe.  
\v 20 Mmiri ndị a toro kpuchiri ugwu niile, ruo na ịla elu mmiri ndị a site nʼelu ugwu ukwu niile ruru mita asaa.  
\v 21 Ihe niile nwere ndụ nke na-ejegharị nʼelu ụwa kubiri ume. Anụ ufe, na anụ ụlọ, na anụ ọhịa, na ihe niile e kere eke jupụtara nʼụwa, na ụmụ mmadụ niile.  
\v 22 Ee, ihe niile na-eku ume nke bi nʼelu ala nwụrụ.  
\v 23 Ihe niile nwere ume ndụ nʼelu ụwa ka e kpochapụrụ. Mmadụ na anụmanụ, na anụ na-akpụgharị nʼala na nnụnụ niile. A lara ha niile nʼiyi. Ma ọ bụ naanị Noa na ndị niile so ya nọdụ nʼụgbọ mmiri ahụ ka a hapụrụ ndụ. 
\p  
\v 24 Narị ụbọchị na iri ụbọchị ise ka mmiri dọọrọ nʼelu ụwa dum. 
\c 8  
\p  
\v 1 Ma Chineke chetara Noa na ụmụ anụ ọhịa niile, na ụmụ anụ ụlọ niile so ya nọdụ nʼụgbọ mmiri ahụ. O zitere ifufe, mee ka o fee nʼelu mmiri ahụ ime ka mmiri ahụ bido ịta.  
\v 2 A kpọchiri isi iyi mmiri niile dị nʼime ime ala, kpọchiekwa ọnụ ụzọ mmiri ozuzo nke mbara eluigwe. Mmiri kwụsịrị isi na mbara eluigwe na-ezokwasị ụwa.  
\v 3 Mmiri ahụ dị nʼụwa ji nwayọọ na-ata. Mgbe narị ụbọchị na iri ụbọchị ise gafesịrị, mmiri ahụ atalatala.  
\v 4 Nʼụbọchị iri na asaa nke ọnwa asaa, ụgbọ mmiri ahụ gara nọkwasị nʼelu ugwu Ararat.  
\v 5 Mmiri a gara nʼihu na-ata ruo ọnwa nke iri. Nʼụbọchị nke mbụ nke ọnwa iri, e bidoro ịhụ elu ugwu ndị ọzọ anya. 
\p  
\v 6 Mgbe iri ụbọchị anọ gafere, Noa meghere oghereikuku ọ rụnyere nʼakụkụ ụgbọ mmiri ahụ,  
\v 7 site nʼebe ahụ zipụ otu ugolọma nke na-efepụ na-efebatakwa, tutu ruo mgbe mmiri kọrọ nʼelu ala.  
\v 8 Emesịa, o zipụrụ otu nduru iji mata ma mmiri ọ kọọla nʼala,  
\v 9 ma nduru ahụ achọtaghị ebe o nwere ike ibe, nʼihi na mmiri ka tojuru elu ụwa niile. Nʼihi ya, nduru ahụ lọghachikwutere Noa nʼime ụgbọ ahụ. Noa setịpụrụ aka ya nwụbata nduru ahụ nʼụgbọ.  
\v 10 Mgbe abalị asaa gafere, Noa zipụrụ nduru ahụ ọzọ  
\v 11 Nʼoge anyasị, nduru a lọghachiri. Ọ kpụ akwụkwọ oliv ọhụrụ ọ kụbitere nʼọnụ ya. Nke a gosiri Noa na mmiri ahụ ataala nʼelu ala.  
\v 12 Mgbe abalị asaa gafere, Noa zipụkwara nduru ahụ ọzọ. Ma nʼoge a, ọ lọtakwaghị ọzọ. 
\p  
\v 13 Nʼụbọchị mbụ nke ọnwa mbụ nʼafọ narị isii na otu nke ndụ Noa, mmiri ahụ atachaala nʼelu ala. Mgbe ahụ, Noa kpughepụrụ ihe mkpuchi nke ụgbọ mmiri ahụ, hụ na mmiri atachaala nʼelu ala.  
\v 14 Ma ọ bụ nʼụbọchị iri abụọ na asaa nke ọnwa abụọ ka mmiri ji takọrọchaa nʼelu ala. 
\p  
\v 15 Mgbe ahụ, Chineke gwara Noa okwu sị ya,  
\v 16 “Site nʼụgbọ mmiri pụta, gị na nwunye gị, na ụmụ gị ndị ikom, na ndị nwunye ụmụ gị ndị ikom.  
\v 17 Kpọpụta anụ niile dị ndụ nke gị na ha nọ, anụ ufe, na ụmụ anụmanụ, na ihe e kere eke niile na-akpụgharị nʼala, ka ha gaa nʼụwa mụọ ọmụmụ, baa ụba, jupụta nʼelu ya.” 
\p  
\v 18 Ya mere, Noa si nʼụgbọ mmiri ahụ pụta, ya na ụmụ ya, na nwunye ya, na ndị nwunye ụmụ ya.  
\v 19 Ma anụmanụ niile ọbụla nke dị ndụ, na ihe niile na-akpụgharị nʼala, na anụ ufe niile, ihe niile na-ejegharị nʼụwa, ka ụdị ha si dị, sitere nʼụgbọ mmiri ahụ pụta. 
\p  
\v 20 Mgbe ahụ, Noa wuru ebe ịchụ aja\f + \fr 8:20 \ft Aja mbụ a chụrụ nʼAkwụkwọ Nsọ nye Onyenwe anyị bụ aja nsure ọkụ Noa chụrụ, mgbe o ji anụmanụ a na-ewepụghị ihe ọbụla nʼahụ ya chụọ aja.\f* nye \nd Onyenwe anyị\nd*. Ọ họọrọ site nʼanụ ụlọ ndị dị ọcha na anụ ufe ndị dị ọcha chụọ aja nsure ọkụ.  
\v 21 \nd Onyenwe anyị\nd* nụrụ isisi ụtọ nke aja nsure ọkụ ahụ kwuo nʼobi ya sị, “Agaghị m abụ ala ọnụ ọzọ nʼihi mmadụ, ebe ọ bụ na izuzu obi mmadụ bụ ime ihe ọjọọ site na mgbe ọ bụ nwata, agakwaghị m ala ihe niile e kere eke na-eku ume ndụ iyi ọzọ, dịka m mere. 
\q1  
\v 22 “Ogologo oge niile ụwa ga-anọgide, 
\q1 oge ịkụ mkpụrụ na oge iwe ihe ubi, 
\q1 oge oyi na oge okpomọkụ, 
\q1 ọkọchị na udu mmiri, 
\q1 ehihie na abalị, 
\q1 agaghị ebi.” 
\c 9  
\s1 Ọgbụgba Ndụ Chineke na Noa gbara 
\p  
\v 1 Mgbe ihe ndị a gasịrị, Chineke gọziri Noa na ụmụ ya sị ha: “Mụọnụ, baanụ, jupụtanụ nʼụwa.  
\v 2 Egwu unu na ụjọ unu ga-adakwasị anụmanụ niile nke ụwa nke dị ndụ, na anụ ufe niile nke eluigwe, na ihe e kere eke niile na-akpụgharị nʼala, na azụ niile dị nʼosimiri. Ewerela m ha niile nyefee unu nʼaka.  
\v 3 Ihe ọbụla dị ndụ nke na-ejegharị ejegharị ga-abụ nri unu. Enyela m unu ihe niile ugbu a dịka m si nye unu ahịhịa ndụ niile. 
\p  
\v 4 “Ma unu agaghị eri anụ ọbụla nke ọbara ndụ ya dị ya nʼahụ.  
\v 5 Ma gbasara ọbara ndụ unu, unu ga-asara ọnụ unu nʼihu m. Anụmanụ ọbụla ga-asara ọnụ ya nʼihu m. Mmadụ ọbụla kwa ga-asara ọnụ ya nʼihu m banyere ndụ mmadụ ibe ya. 
\q1  
\v 6 “Onye ọbụla wufuru ọbara mmadụ, 
\q2 nʼaka mmadụ ka a ga-awụfu ọbara nke ya, 
\q1 nʼihi nʼoyiyi Chineke 
\q2 ka Chineke mere mmadụ. 
\m  
\v 7 Ma unu onwe unu, mịanụ mkpụrụ, mụbaanụ, jupụtanụ ụwa, baakwanụ ụba nʼime ya.” 
\p  
\v 8 Chineke gwara Noa na ụmụ ya sị,  
\v 9 “Ugbu a, ana m ehiwe ọgbụgba ndụ nʼetiti mụ na unu, na nʼetiti agbụrụ unu ndị ga-anọchi unu,  
\v 10 na nʼetiti ihe niile nwere ndụ nke unu na ha so, ụmụ anụ ufe, na ụmụ anụ ụlọ, na ụmụ anụ ọhịa niile, ndị ahụ niile so unu si nʼụgbọ mmiri pụta, bụ ihe niile nwere ndụ nʼụwa.  
\v 11 Ebe ọ bụ na m ehiwela ọgbụgba ndụ m nʼetiti mụ na unu, ọ gaghị emekwa ọzọ na a ga-eji uju mmiri kpochapụ ihe niile e kere eke, ọ gaghị emekwa ọzọ na a ga-eji uju mmiri bibie ụwa.” 
\p  
\v 12 Chineke kwuru sị, “Nke a bụ ihe ama nke ọgbụgba ndụ nke m na-etinye nʼetiti mụ na unu, na nʼetiti ihe niile nwere ndụ so unu, ọgbụgba ndụ nke ga-adị nye ọgbọ niile na-abịa nʼihu.  
\v 13 Etinyela m eke na egwurugwu m na mbara eluigwe, ka ọ bụrụ ihe ama nke ọgbụgba ndụ dị nʼetiti mụ na ụwa.  
\v 14 Mgbe ọbụla m zitere igwe ojii nʼụwa, ọ bụrụ na eke na egwurugwu apụta ìhè na mbara eluigwe,  
\v 15 aga m echeta ọgbụgba ndụ m mere ka ọ dịrị nʼetiti mụ na unu, na nʼetiti mụ na ihe niile nwere ndụ site nʼihe niile e kere eke. Ọ gaghị emekwa ọzọ na mmiri ga-aghọ uju mmiri ibibi ihe niile nwere ndụ.  
\v 16 Mgbe ọbụla eke na egwurugwu pụtara nʼigwe ojii, aga m ahụ ya cheta ọgbụgba ndụ ebighị ebi nke dị nʼetiti Chineke na ihe niile nwere ndụ site nʼihe niile e kere eke nọ nʼelu ụwa.” 
\p  
\v 17 Chineke gwara Noa sị, “Nke a bụ ihe ama ọgbụgba ndụ ahụ m hiwere nʼetiti mụ na ihe niile nwere ndụ nʼụwa.” 
\s1 Ụmụ ndị ikom Noa 
\p  
\v 18 Ụmụ ndị ikom Noa ndị si nʼụgbọ mmiri pụta bụ Shem, Ham na Jafet. (Ham bụ nna Kenan.)  
\v 19 Ndị a bụ ụmụ ndị ikom atọ Noa mụrụ. Ọ bụ site na ha ka ndị mmadụ niile gbasara nʼụwa niile si pụta. 
\p  
\v 20 Noa, onye ọrụ ubi, bidoro ịkụ ubi vaịnị a gbara ogige.  
\v 21 Mgbe ọ ṅụrụ mmanya si nʼubi a, ṅụbiga ya oke, ọ gbaara ọtọ dinaa ala nʼime ụlọ ikwu ya.  
\v 22 Ham, nna Kenan, hụrụ ọtọ nna ya, gaa kọọrọ ụmụnne ya abụọ nọ nʼezi ihe ọ hụrụ.  
\v 23 Ma Shem na Jafet weere akwa tụkwasị nʼubu ha, were azụ jere ije ruo nʼebe nna ha nọ, hapụ akwa ahụ ka ọ dakwasị nna ha kpuchikwaa ọtọ ya. Ma ha chepuru ihu nʼebe ọzọ mgbe ha na-eme nke a, nʼihi ya, ha elekwasịghị ọtọ nna ha anya. 
\p  
\v 24 Mgbe Noa si nʼụra mmanya ya bilie, chọpụta ihe nwa ya nwoke nke nta mere,  
\v 25 o kwuru sị, 
\q1 “Onye a bụrụ ọnụ ka Kenan bụ! 
\q2 Ohu ndị ohu, 
\q2 ka ọ ga-abụrụ ụmụnne ya.” 
\p  
\v 26 Ọ sịkwara, 
\q1 “Ngọzị dịrị \nd Onyenwe anyị\nd* Chineke Shem. 
\q2 Ka Kenan bụrụ ohu Shem. 
\q1  
\v 27 Ka Chineke mee ka ebe obibi Jafet saa mbara, 
\q2 ka Jafet biri nʼụlọ ikwu Shem, 
\q2 meekwa ka Kenan bụrụ ohu ya.” 
\p  
\v 28 Mgbe uju mmiri ahụ gabigachara, Noa biri ndụ narị afọ atọ na iri afọ ise ọzọ.  
\v 29 Ọnụọgụgụ afọ Noa niile mgbe ọ nwụrụ, bụ narị afọ itoolu na iri afọ ise. 
\c 10  
\s1 Usoro ọmụmụ ụmụ Noa 
\li4  
\v 1 Ndị a bụ akụkọ banyere Shem, Ham na Jafet, ụmụ ndị ikom atọ Noa mụrụ. Ha onwe ha mụtara ụmụ nke aka ha, mgbe uju mmiri gafesịrị. 
\s2 Ụmụ Jafet 
\li1  
\v 2 Ụmụ ndị ikom Jafet bụ: 
\li2 Goma, Magog, Madai, Javan, Tubal, Meshek na Tiras. 
\li1  
\v 3 Ụmụ ndị ikom Goma bụ: 
\li2 Ashkenaz, Rifat na Togama. 
\li1  
\v 4 Ụmụ ndị ikom Javan bụ: 
\li2 Elisha, Tashish, Kitim na Rodanim.  
\v 5 (Site nʼagbụrụ ndị a bi nʼakụkụ mmiri ka e nwetara mba dị iche iche, nʼagbụrụ ha nʼime obodo ha dị iche iche, ndị ọbụla nʼime ha nwekwara asụsụ nke ha.) 
\s2 Ụmụ Ham 
\li1  
\v 6 Ụmụ ndị ikom Ham bụ: 
\li2 Kush,\f + \fr 10:6 \ft Kush na-ekwu banyere ala dị nʼugwu ugwu Naịl, nʼala Itiopia, nakwa ala Sụdan. Mizraim bụ maka ndị Ijipt, ebe Put na-ekwu banyere ndị Libiya, maọbụ ndị bi gburugburu ala Sọmalia.\f* Ijipt, Put na Kenan. 
\li1  
\v 7 Ụmụ ndị ikom Kush\f + \fr 10:7 \ft Ọ bụ nʼime ala Arab ka mba asaa ndị Kush dị.\f* bụ: 
\li2 Seba, Havila, Sabta, Raama na Sabteka. 
\li1 Ụmụ ndị ikom Raama bụ: 
\li2 Sheba na Dedan. 
\li4  
\v 8 Kush bụ nna Nimrọd, onye mesịrị bụrụ dike nʼagha nʼụwa.  
\v 9 Ọ bụ dike nʼịchụ nta, nʼihu \nd Onyenwe anyị\nd*. Ọ bụ nke a mere e ji na-ekwu okwu na-asị, “Ị dị ka Nimrọd, dike nʼịchụ nta, nʼihu \nd Onyenwe anyị\nd*.”  
\v 10 Obodo ndị bụ mmalite alaeze ya bụ, Babel,\f + \fr 10:10 \ft Maọbụ, \fqa Babilọn\f* Erek, Akad na Kalne, ndị dị nʼala Shaịna.\f + \fr 10:10 \ft Shaịna bụ ala Babilọn ochie.\f* 
\v 11 Site nʼala ahụ ọ gara Asịrịa, ebe o wuru obodo Ninive na Rehobọt Ia, na Kala,  
\v 12 na Resin, nke dị nʼetiti Ninive na Kala, ya bụ obodo ukwu ahụ. 
\li1  
\v 13 Ijipt bụ nna ndị 
\li2 Lud, ndị Anam, ndị Lehab, ndị Naftuh,  
\v 14 ndị Patrus, ndị Kasluh (onye ndị Filistia\f + \fr 10:14 \ft Ndị Filistia bụ mba si nʼagbụrụ (agwara ụgwa) abụọ, otu agbụrụ sitere nʼEshịa, ebe nke ọzọ bụ agbụrụ ndị Ọcha. Njem mbụ ha duuru ha gaa ala Kriit, ebe ha gara biri. \xt Jer 47:4; Ems 9:7\ft  Emesịa, ha busoro ndị Ijipt agha na senchuri nke iri na atọ, ma bichie ala ha. Mgbe e sitere nʼala Ijipt chụpụ ha, ha gara biri nʼakụkụ ọnụ mmiri ala Kenan.\f* sitere na ya) na ndị Kafto. 
\li1  
\v 15 Kenan bụ nna 
\li2 Saịdọn, ọkpara ya, na ndị Het,  
\v 16 ndị Jebus, ndị Amọrait, ndị Gigash,  
\v 17 ndị Hiv, ndị Aka, ndị Sini,  
\v 18 ndị Avad, ndị Zema na ndị Hamat. 
\li2 Emesịa, ndị ikwu Kenan gbasara,  
\v 19 oke ala ndị Kenan sitere na Saịdọn ruo Gera, gbatịa ruo Gaza, ruokwa Sọdọm, Gọmọra, Adma na Zeboiim, nke dị nso Lasha. 
\li4  
\v 20 Ndị a bụ ụmụ ndị ikom Ham, dịka ikwu ha na asụsụ ha si dị, nʼoke ala ebe ha bi, na obodo ha dị iche iche. 
\s2 Ụmụ Shem 
\li4  
\v 21 A mụụrụ Shem ụmụ ndị ikom, onye nwanne nwoke nke tọrọ ya bụ Jafet. Ọ bụkwa nna nna ochie ụmụ ndị ikom niile Eba mụtara. 
\li1  
\v 22 Ụmụ ndị ikom Shem bụ 
\li2 Elam,\f + \fr 10:22 \ft Aha ochie e ji mara Asịrịa.\f* Ashua, Apakshad, Lud na Aram. 
\li1  
\v 23 Ụmụ ndị ikom Aram bụ, 
\li2 Uz, Hul, Geta na Meshek. 
\li1  
\v 24 Apakshad bụ nna Shela, 
\li2 Shela bụrụ nna Eba. 
\li1  
\v 25 Eba mụtara ụmụ ndị ikom abụọ: 
\li2 Aha otu nʼime ha bụ Peleg, nʼihi na ọ bụ nʼoge ndụ ya ka e kewara ụwa. Aha nwanne ya nwoke bụ Joktan. 
\li1  
\v 26 Joktan bụ nna 
\li2 Almodad, Shelef, Hazamavet, Jera,  
\v 27 Hadoram, Ụzal, Dikla,  
\v 28 Obal, Abimael, Sheba,  
\v 29 Ọfịa, Havila na Jobab. Ndị a niile bụ ụmụ ndị ikom Joktan. 
\li2  
\v 30 Akụkụ ala ha bi gbasapụrụ site na Mesha ruo Sefa nʼala ugwu ugwu nke ọwụwa anyanwụ. 
\li4  
\v 31 Ndị a niile bụ ụmụ ndị ikom Shem, dịka ikwu ha na asụsụ ha si dị, nʼoke ala ebe ha dị, na obodo ha dị iche iche. 
\b  
\li4  
\v 32 Ndị a bụ ndị ikwu ụmụ Noa ndị ikom dịka usoro ọmụmụ ha si dị, dịka ha si biri na mba dị iche iche. Ọ bụ site na ndị a ka mba niile si gbasasịa ruo akụkụ niile nke ụwa mgbe uju mmiri ahụ gafechara. 
\c 11  
\s1 Ụlọ elu Babel 
\p  
\v 1 Nʼoge ahụ, ụwa niile nwere naanị otu asụsụ, okwu niile bụkwa otu.  
\v 2 Mgbe ndị mmadụ gbasara nʼakụkụ ọwụwa anyanwụ ha chọtara ala dị larịị na Shaịna biri nʼebe ahụ. 
\p  
\v 3 Ha gwarịtara onwe ha okwu sị, “Bịanụ ka anyị kpụọ brik,\f + \fr 11:3 \ft Maọbụ, \fqa Aja ụrọ\f* kpọọ ha ọkụ nke ọma.” Ya mere, ha kpụrụ brik kama nkume, jirikwa bitumen kama ụrọ.  
\v 4 Mgbe ahụ, ha kwuru sị, “Bịanụ ka anyị wuore onwe anyị obodo na ụlọ elu, nke elu ya ga-eru nʼeluigwe, ka anyị si otu a meere onwe anyị aha, ka anyị ghara ịbụ ndị a ga-agbasa nʼụwa niile.” 
\p  
\v 5 \nd Onyenwe anyị\nd* rịdatara hụ obodo ahụ na ụlọ elu ahụ ndị mmadụ na-ewu.  
\v 6 \nd Onyenwe anyị\nd* sịrị, “Lee! Ọ bụrụ na ha malitere ime ihe dị otu a, ugbu a ha bụ otu ndị, nweekwa otu asụsụ, o nweghị ihe ha zubere ime nke ha na-apụghị ime.  
\v 7 Ngwa, ka anyị rịda gaa gbarụọ asụsụ ha, ka onye o bụla ghara ịghọta asụsụ ibe ya.” 
\p  
\v 8 \nd Onyenwe anyị\nd* mere ka ha gbasaa nʼelu ụwa niile. Ha kwụsịkwara iwu obodo ahụ.  
\v 9 Ọ bụkwa nke a mere e ji kpọọ obodo ahụ Babel\f + \fr 11:9 \fqa Babel ya bụ Babilọn \ft pụtara \fqa ọgbaaghara nʼasụsụ Hibru.\f* nʼihi na ọ bụ nʼebe ahụ ka \nd Onyenwe anyị\nd* wetara ọgbaaghara nʼasụsụ ndị niile bi nʼụwa. Ọ bụkwa nʼebe ahụ ka \nd Onyenwe anyị\nd* si gbasasịa ha nʼelu ụwa dum. 
\s1 Site na Shem ruo Ebram 
\p  
\v 10 Nke a bụ akụkọ banyere usoro ezinaụlọ Shem. 
\b  
\li1 Mgbe afọ abụọ gafechara site nʼoge uju mmiri ahụ, nʼoge Shem gbara narị afọ, ọ mụtara Apakshad.  
\v 11 Shem dịrị ndụ, mgbe ọ mụsịrị Apakshad, narị afọ ise ọzọ, mụtakwa ụmụ ndị ikom na ụmụ ndị inyom. 
\li1  
\v 12 Mgbe Apakshad gbara iri afọ atọ na ise, ọ mụtara Shela.  
\v 13 Mgbe ọ mụchara Shela, ọ dịrị ndụ narị afọ anọ na atọ ọzọ, mụta ụmụ ndị ikom na ụmụ ndị inyom. 
\li1  
\v 14 Shela gbara iri afọ atọ mgbe ọ mụrụ nwa ya nwoke Eba.  
\v 15 Mgbe ọ ghọrọ nna Eba, ọ dịrị ndụ narị afọ anọ na atọ, mụta ụmụ ndị ikom na ụmụ ndị inyom. 
\li1  
\v 16 Eba gbara iri afọ atọ na anọ mgbe ọ mụrụ Peleg.  
\v 17 Mgbe ọ ghọrọ nna Peleg, ọ dịrị ndụ narị afọ anọ na iri atọ ọzọ mụta ụmụ ndị ikom na ụmụ ndị inyom. 
\li1  
\v 18 Peleg gbara iri afọ atọ mgbe ọ mụrụ Reu.  
\v 19 Emesịa, mgbe ọ ghọrọ nna Reu, ọ dịrị ndụ narị afọ abụọ na itoolu ọzọ mụta ụmụ ndị ikom na ụmụ ndị inyom. 
\li1  
\v 20 Reu gbara iri afọ atọ na abụọ mgbe ọ mụrụ Serug.  
\v 21 Emesịa, ọ dịrị ndụ narị afọ abụọ na asaa ọzọ, mgbe ọ mụsịrị Serug, ọ mụtakwara ụmụ ndị ikom na ụmụ ndị inyom. 
\li1  
\v 22 Serug gbara iri afọ atọ mgbe ọ mụrụ Nahọ.  
\v 23 Emesịa, mgbe ọ ghọrọ nna Nahọ, ọ dịrị ndụ narị afọ abụọ ọzọ mụta ụmụ ndị ikom na ụmụ ndị inyom. 
\li1  
\v 24 Nahọ gbara iri afọ abụọ na itoolu mgbe ọ mụrụ Tera.  
\v 25 Emesịa, mgbe ọ ghọrọ nna Tera, ọ dịrị ndụ narị afọ na afọ iri na itoolu ọzọ, mụta ụmụ ndị ikom na ụmụ ndị inyom. 
\li1  
\v 26 Mgbe Tera gbara iri afọ asaa, ọ ghọrọ nna Ebram, Nahọ na Haran. 
\s1 Ezinaụlọ Ebram 
\p  
\v 27 Nke a bụ akụkọ gbasara usoro ezinaụlọ Tera. 
\b  
\p Tera ghọrọ nna Ebram, Nahọ na Haran. Haran ghọrọ nna Lọt.  
\v 28 Haran nwụrụ nʼihu nna ya Tera nʼala ebe a nọ mụọ ya, nke bụ na Ụọ, obodo ndị Kaldịa.  
\v 29 Ebram na Nahọ lụrụ nwunye. Aha nwunye Ebram bụ Serai ma aha nwunye Nahọ bụ Milka. Milka bụ nwa Haran, onye bụ nna Milka na Iska.  
\v 30 Ma Serai bụ nwanyị aga, ọ mụtaghị nwa ọbụla. 
\p  
\v 31 Tera kpọrọ nwa ya Ebram, na nwa nwa ya Lọt, onye bụ nwa Haran,\f + \fr 11:31 \ft Haran bụ aha mmadụ, bụrụkwa aha obodo dị nʼala Mesopotamịa. Obodo e ji ife ọnwa mara, dị ka a makwaara obodo Ụọ.\f* na nwunye nwa ya Serai, bụ nwunye Ebram, duru ha hapụ Ụọ, obodo ndị Kaldịa, pụọ gawa nʼala Kenan. Ma mgbe ha bịarutere nʼobodo Haran, ha kwụsịrị biri nʼebe ahụ. 
\p  
\v 32 Ọ bụ nʼobodo Haran ka Tera nọ nwụọ, mgbe ọ gbara narị afọ abụọ na ise. 
\c 12  
\s1 Ọkpụkpọ Ebram 
\p  
\v 1 \nd Onyenwe anyị\nd* gwara Ebram okwu sị, “Site nʼobodo gị, sikwa na ụmụnna gị na ezinaụlọ nna gị, gaa nʼala m ga-egosi gị. 
\q1  
\v 2 “Aga m eme gị mba ukwu, 
\q2 aga m agọzi gị, 
\q1 aga m eme ka aha gị dị ukwuu, 
\q2 ị ga-abụ ngọzị. 
\q1  
\v 3 Aga m agọzi ndị na-agọzi gị, 
\q2 ma onye ọbụla kọchara gị ka m ga-akọcha; 
\q1 a ga-agọzikwa agbụrụ niile nọ nʼụwa 
\q2 site na gị.” 
\p  
\v 4 Ya mere, Ebram hapụrụ gaa dịka \nd Onyenwe anyị\nd* gwara ya. Lọt sokwa ya. Ebram agbaala iri afọ asaa na ise mgbe o si na Haran bulie ije.  
\v 5 O duru nwunye ya Serai na Lọt nwa nwanne ya, chịkọtakwa akụ niile ha kpakọbara, na ndị ohu niile ha nwetara nʼala Haran, chee ihu ịga nʼala Kenan. Emesịa ha rutere nʼebe ahụ. 
\p  
\v 6 Ebram jere ije nʼime ala Kenan jeruo nʼebe osisi ukwu More, nke dị nʼobodo Shekem. Ndị Kenan bi nʼala ahụ nʼoge ahụ.  
\v 7 \nd Onyenwe anyị\nd* mere ka Ebram hụ ya anya, ọ sịrị, “Aga m enye mkpụrụ gị ala a.” Ya mere, Ebram wuru ebe ịchụ aja nʼebe ahụ nye \nd Onyenwe anyị\nd* onye gosiri ya onwe ya. 
\p  
\v 8 Emesịa, Ebram hapụrụ ebe ahụ chee ihu nʼala ugwu dị nʼọwụwa anyanwụ Betel, maa ụlọ ikwu ya. Obodo Betel dị nʼakụkụ ọdịda anyanwụ, ma obodo Ai dị nʼakụkụ ọwụwa anyanwụ ebe ọ mara ụlọ ikwu ya. Nʼebe nsọ ahụ Ebram wuru ebe ịchụ aja, nọrọ nʼebe ahụ kpọkuo aha \nd Onyenwe anyị\nd*. 
\p  
\v 9 Ọzọ, Ebram si nʼebe ahụ pụọ gaa ije rute Negev.\f + \fr 12:9 \ft Ihe aha a pụtara bụ “ala kpọrọ nkụ.” Nke a bụ nʼihi ala ahụ tọgbọrọ nʼefu, gbatịa gbadaa ndịda Jerusalem, nʼụzọ ọzara.\f* 
\s1 Ebram ejee Ijipt 
\p  
\v 10 Nʼoge ahụ, oke ụnwụ dara nʼala ahụ.\f + \fr 12:10 \ft \xt Jen 26:1; 41:56\f* Nʼihi ya, Ebram hapụrụ ala ahụ gaa nʼala\f + \fr 12:10 \ft Nʼoge a, ụkọ mmiri ozuzo e metụtabeghị ihe ubi nʼala Ijipt, nʼihi na ha na-esite na iyi ha rụrụ na-agba ubi ha mmiri.\f* Ijipt, ebe o biri nwa oge.  
\v 11 Ma mgbe ha na-akwado ịbanye ala Ijipt, ọ gwara Serai nwunye ya sị, “Amaara m na ị bụ nwanyị mara mma.  
\v 12 Mgbe ndị Ijipt ga-ahụ gị, ha ga-asị, ‘Onye a bụ nwunye ya.’ Mgbe ahụ, ha ga-egbu m ma hapụ gị ndụ.  
\v 13 Gwa ha na ị bụ nwanne m nwanyị, ka ha meso m mmeso ọma nʼihi gị. Ha ga-echebekwa m ndụ nʼihi gị.” 
\p  
\v 14 Mgbe Ebram rutere Ijipt, ndị Ijipt hụrụ na nwunye ya bụ nwanyị mara mma.  
\v 15 Mgbe ndị ozi Fero hụrụ ya, ha toro ya nʼihu Fero. Nʼihi nke a, ha kpọbatara Serai nʼụlọeze Fero.  
\v 16 Fero mesoro Ebram mmeso ọma nʼihi nwunye ya. Ebram nwetara igwe atụrụ, na ehi, na nne ịnyịnya ibu, oke na nwunye, na ndị ohu ndị nwoke na ndị nwanyị, na ịnyịnya kamel. 
\p  
\v 17 Ma \nd Onyenwe anyị\nd* jiri ajọọ ọrịa tie Fero na ndị ezinaụlọ ya ihe otiti nʼihi Serai nwunye Ebram.  
\v 18 Mgbe ahụ, Fero kpọrọ Ebram sị ya, “Gịnị bụ ihe a i mere? Gịnị mere ị gwaghị m na ọ bụ nwunye gị?  
\v 19 Gịnị mere i ji sị na ọ bụ nwanne gị nwanyị, si otu a mee m ka m kpọrọ ya ka ọ bụrụ nwunye m? Ugbu a, lee nwunye gị, kpọrọ ya laa.”  
\v 20 Fero nyere iwu banyere Ebram na ndị ikom so ya. Ha zilagara ya, ya na nwunye ya, na ihe niile o nwere. 
\c 13  
\s1 Nkewa Ebram na Lọt 
\p  
\v 1 Ebram na nwunye, na ihe niile ha nwere hapụrụ ala Ijipt, gaa ije bịaruo Negev. Lọt sokwa ha.  
\v 2 Nʼoge a, Ebram aghọọla ọgaranya dị ukwuu, onye nwere akụnụba nke ọtụtụ anụ ụlọ, na ọlaọcha, na ọlaedo. 
\p  
\v 3 Ha sitere na Negev pụọ ije site nʼotu ebe ruo nʼebe ọzọ tutu ha erute Betel, nʼebe dị nʼetiti Betel na Ai, ebe ọ mara ụlọ ikwu ya na mbụ.  
\v 4 Nʼebe nsọ o wukwara ebe ịchụ aja na mbụ, nʼebe ahụ Ebram kpọkuru aha \nd Onyenwe anyị\nd*. 
\p  
\v 5 Ugbu a Lọt, onye ya na Ebram so na njem ya, bụkwa onye nwere akụnụba nke igwe ewu na atụrụ, na igwe ehi, na ọtụtụ ụlọ ikwu.  
\v 6 Ma ala ebe ha nọ ezurughị ha mgbe ha nọkọrọ ọnụ nʼihi na ihe onwunwe ha dị ukwuu ruo na ha enweghị ike ịnọkọ ọnụ.  
\v 7 Nke a mere esemokwu ji dapụta nʼetiti ndị ọzụzụ anụ ụlọ Ebram na ndị ọzụzụ anụ ụlọ Lọt. Ndị Kenan na ndị Periz bikwa nʼala ahụ nʼoge ahụ. 
\p  
\v 8 Ya mere Ebram gwara Lọt sị, “Biko, ka esemokwu ghara ịdị nʼetiti mụ na gị, maọbụ nʼetiti ndị ọzụzụ anụ ụlọ m na ndị ọzụzụ anụ ụlọ gị, nʼihi na anyị bụ ụmụnne.  
\v 9 Lee, ọ bụ na ala a niile adịghị nʼihu gị? Ka anyị kewaa. Ọ bụrụ na ị gaa nʼakụkụ aka ekpe, aga m aga nʼakụkụ aka nri. Ma ọ bụrụ na i gaa nʼakụkụ aka nri gị, aga m aga nʼakụkụ aka ekpe.” 
\p  
\v 10 Lọt lelitere anya hụ na mbara ala Jọdan bụ ala mmiri na-ezokwasị nke ọma, ala dịka ubi a gbara ogige \nd Onyenwe anyị\nd*, dịka ala ndị Ijipt nke dị na nso nso Zoa. (Ihe a mere tupu \nd Onyenwe anyị\nd* ebibie obodo Sọdọm na Gọmọra.)  
\v 11 Ya mere, Lọt họọrọ nye onwe ya mbara ala Jọdan niile, chee ihu ịga nʼakụkụ ọwụwa anyanwụ. Ya na Ebram kewara.  
\v 12 Ebram nọdụrụ nʼala Kenan, ma Lọt gara biri nʼetiti obodo ndị ahụ dị na mbara ala. Ọ mara ụlọ ikwu ya nso nso obodo Sọdọm.  
\v 13 Ma ndị Sọdọm bụ ndị obi tara mmiri, ndị na-emehie nke ukwuu megide \nd Onyenwe anyị\nd*. 
\p  
\v 14 Mgbe Lọt siri nʼebe ahụ pụọ, \nd Onyenwe anyị\nd* gwara Ebram okwu sị ya, “Site nʼebe ahụ ị nọ lelie anya gị, lee anya nʼugwu na ndịda, nʼọwụwa anyanwụ na ọdịda anyanwụ.  
\v 15 Ala ahụ niile ị hụrụ ka m ga-enye gị na mkpụrụ gị ruo mgbe ebighị ebi.  
\v 16 Aga m eme ka mkpụrụ gị baa ụba dịka aja dị nʼala. Ọ bụrụ na mmadụ enwe ike ịgụta ọnụọgụgụ aja dị nʼala, ha ga-enwe ike gụta ọnụọgụgụ mkpụrụ gị.  
\v 17 Bilie jegharịa nʼala ahụ niile nʼakụkụ ya ọbụla, nʼihi na ana m enye gị ha niile.” 
\p  
\v 18 Ya mere, Ebram bugharịrị ụlọ ikwu ya, gaa biri nʼakụkụ osisi ukwu Mamre nke dị na Hebrọn. O wuru ebe ịchụ aja nye \nd Onyenwe anyị\nd* nʼebe ahụ. 
\c 14  
\s1 Ebram anapụta Lọt 
\p  
\v 1 Nʼoge ahụ kwa, Amrafel, eze Shaịna, na Ariok, eze ndị Elasa, na Kedoloma eze Elam, na Tidal eze Goiim,  
\v 2 buru agha megide Bera eze Sọdọm, na Biasha eze Gọmọra, na Shịnab, eze Adma, na Shemeba eze Zeboiim, na eze obodo Bela (ya bụ Zoa).  
\v 3 Ndị eze obodo ndị a: Sọdọm, Gọmọra, Adma, Zeboiim na Bela, jikọtara ndị agha ha ọnụ na Ndagwurugwu Sidim (ya bụ, ndagwurugwu osimiri nnu ahụ).  
\v 4 Ha fere ofufe nʼokpuru ọchịchị eze Kedoloma afọ iri na abụọ, ma nʼafọ nke iri na atọ, ha nupuru isi. 
\p  
\v 5 Nʼafọ nke iri na anọ, eze Kedoloma na ndị eze ya na ha jikọrọ ọnụ buru agha megide ma merie ndị Refaim\f + \fr 14:5 \fq Refaim \ft Aha a Refaim pụtara \fqa ndị ọ gbaa dimkpa \xt Jen 15:20\f* bi nʼAshterọt Kenaim na ndị Zuzim bi na Ham na ndị Emim bi Kiriatem na Shave,  
\v 6 na ndị Hor nʼobodo ugwu Sia, ruo obodo El Paran, nke dị nʼakụkụ ọzara.  
\v 7 Mgbe ahụ, ha chigharịrị azụ gaa En Mishpat (ya bụ Kadesh). Ha meriri ala niile nke ndị Amalek nakwa ndị Amọrait bi na Hazezọn Tama. 
\p  
\v 8 Mgbe ahụ kwa, ndị agha ndị eze obodo Sọdọm na eze Gọmọra, na eze Adma, na eze Zeboiim, na eze Bela (ya bụ Zoa) pụrụ doo onwe ha nʼusoro ibu agha na Ndagwurugwu Sidim,  
\v 9 imegide Kedoloma eze Elam, Tidal eze Goiim, Amrafel eze Shaịna na Ariok eze Elasa. Ya bụ eze ise buru agha megide eze anọ.  
\v 10 Ma Ndagwurugwu Sidim jupụtara nʼolulu apịtị. Mgbe ndị agha eze Sọdọm na Gọmọra bidoro ịgba ọsọ. Ụfọdụ nʼime ha dabanyere nʼime olulu ndị a, ma ndị fọdụrụ gbapụrụ ọsọ gbaga nʼugwu.  
\v 11 Ma eze anọ ndị a banyere nʼime obodo Sọdọm na Gọmọra bukọrọ akụ ha, na ihe oriri ha niile laa.  
\v 12 Ha buuru Lọt, nwa nwanne Ebram, onye bi na Sọdọm na ihe niile o nwere, buru ha na-ala ebe ha si bịa. 
\p  
\v 13 Ma otu onye gbara ọsọ ndụ site nʼebe ahụ gara kọọrọ Ebram onye Hibru ihe mere. Nʼoge a, Ebram bi nʼebe dị nso nʼosisi ukwu nke Mamre, onye Amọrị, nwanne Eshkọl na Anea, ndị ha na Ebram gbara ndụ.  
\v 14 Mgbe Ebram nụrụ na adọrọla Lọt nwa nwanne ya nʼagha, ọ kpọkọtara ndị ikom a zụrụ azụ na-ejere ya ozi, ndị a mụrụ nʼụlọ ya. Ọnụọgụgụ ha dị narị ndị ikom atọ na iri na asatọ, ha chụrụ ndị agha ahụ ọsọ tutu ha erute Dan.  
\v 15 Nʼabalị, Ebram kere ndị agha ya ibuso ndị ahụ agha. O meriri ha, chụọ ha ọsọ, chụruo ha Hoba, nke dị nʼakụkụ ugwu Damaskọs.  
\v 16 Ebram nwetaghachiri ihe niile ahụ ha dọtara nʼagha, dulata nwanne ya Lọt, na ihe onwunwe ya niile, tinyere ndị inyom, na ndị ọzọ niile a dọtara nʼagha. 
\s1 Melkizedek agọzie Ebram 
\p  
\v 17 Mgbe Ebram si na mmeri ahụ o meriri Kedoloma na eze ndị ọzọ ahụ na-alọta, eze Sọdọm bịara zute ya na Ndagwurugwu Shave (nke a na-akpọ Ndagwurugwu Eze). 
\p  
\v 18 Melkizedek, eze\f + \fr 14:18 \fq Salem \ft Eleghị anya, nke bụ aha ochie e ji mara obodo Jerusalem.\f* Salem, onye nchụaja Chineke nke kachasị ihe niile elu, wepụtara achịcha na mmanya,  
\v 19 ọ gọziri Ebram sị ya, 
\q1 “Ngọzị dịrị Ebram site nʼaka Chineke nke kachasị ihe niile elu, 
\q2 Onye kere eluigwe na ụwa. 
\q1  
\v 20 Ngọzị dịkwara Chineke nke kachasị ihe niile elu, 
\q2 onye weere ndị iro gị nyefee gị nʼaka.” 
\m Mgbe ahụ, Ebram nyere ya otu ụzọ nʼime ụzọ iri nke ihe niile. 
\p  
\v 21 Eze Sọdọm gwara Ebram sị, “Nyeghachi m naanị ndị mmadụ, ma debere onwe gị ihe ndị ọzọ.” 
\p  
\v 22 Ma Ebram zara eze Sọdọm sị, “Eweliri m aka m elu ṅụọ iyi nye \nd Onyenwe anyị\nd* Chineke nke kachasị ihe niile elu, Onye kere eluigwe na ụwa, sị  
\v 23 na agaghị m esi nʼaka gị were ihe ọbụla bụ nke gị, ọ bụladị eriri maọbụ eriri akpụkpọụkwụ. Ka ị ghara ị sị, ‘Ọ bụ m mere ka Ebram baa ọgaranya.’  
\v 24 Naanị ihe m ga-anara bụ ihe ụmụ okorobịa m ndị a riri, ya na oke ruuru Anea, na Eshkọl, na Mamre so m gaa. Nye ha oke ruuru ha.” 
\c 15  
\s1 Ọgbụgba Ndụ Chineke na Ebram 
\p  
\v 1 Mgbe nke a gasịrị, okwu \nd Onyenwe anyị\nd* ruru Ebram site nʼọhụ, sị ya, 
\q1 “Atụla egwu, Ebram 
\q2 Abụ m ọta gị, 
\q2 ụgwọ ọrụ dị ukwu nke i nwere.” 
\p  
\v 2 Ma Ebram zara sị ya, “Gị, Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd*, gịnị bụ ihe ị ga-enye m ebe ọ bụ na m amụtaghị nwa? Lee, ọ bụ Elieza, onye Damaskọs, ga-eketa akụ m niile.”  
\v 3 Ebram gara nʼihu kwuo sị, “Ebe ọ bụ na m amụtaghị ụmụ, ọ bụ ohu nọ nʼụlọ m ga-eketa akụ m.” 
\p  
\v 4 Ma okwu \nd Onyenwe anyị\nd* rutere ya, “Nwoke a agaghị eketa ihe i nwere, kama nwa nwoke nke ga-esi nʼahụ gị pụta ga-eketa ihe i nwere.”  
\v 5 Mgbe ahụ, \nd Onyenwe anyị\nd* kpọpụtara Ebram nʼezi sị ya, “Lelie anya gị elu na mbara eluigwe, gụọ kpakpando niile ị hụrụ ọnụ, ma ị ga-enwe ike ịgụta ha.” Ọ gwara ya sị, “Otu a ka mkpụrụ gị ga-adị. A gaghị agụta ha ọnụ.” 
\p  
\v 6 Ebram kweere nʼihe \nd Onyenwe anyị\nd* kwuru. Nʼihi nke a, a gụnyere ya okwukwe a dịka ezi omume. 
\p  
\v 7 \nd Onyenwe anyị\nd* gwakwara ya sị, “Mụ onwe m bụ \nd Onyenwe anyị\nd*, onye si nʼala Ụọ nke ndị Kaldịa kpọpụta gị, inye gị ala a ka ọ bụrụ ihe nweta gị.” 
\p  
\v 8 Ma Ebram zara sị, “Biko, Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* olee otu m ga-esi mara na m ga-enweta ya?” 
\p  
\v 9 \nd Onyenwe anyị\nd* zara sị ya, “Wetara m nwa nne ehi gbara afọ atọ, na nne ewu gbara afọ atọ, na ebule gbara afọ atọ, na nduru, na nwa kpalakwukwu.” 
\p  
\v 10 Ebram wetaara ya ihe ndị a niile bọwaa ha ụzọ abụọ, doo ha nʼusoro ka otu akụkụ chee akụkụ nke ọzọ ihu. Ma ọ bọwaghị ụmụ nnụnụ ndị ahụ.\f + \fr 15:10 \ft Nʼọgbụgba ndụ niile a na-eji anụmanụ a chụọ aja. Ndị ahụ gbara ndụ na-esi nʼetiti anụ ndị ahụ a kpọwara ọkara abụọ gafee, maka imesi ọgbụgba ndụ dị otu a ike. \xt Jen 15:17; Jer 34:18\f* 
\v 11 Mgbe anụ ufe fekwasịrị ozu anụ ndị ahụ, Ebram chụpụrụ ha. 
\p  
\v 12 Mgbe anwụ bidoro ịda, Ebram dara nʼoke ụra, oke ụjọ na oke ọchịchịrị dakwasịrị ya.  
\v 13 Mgbe ahụ, \nd Onyenwe anyị\nd* gwara ya sị, “Mata nke ọma na ụmụ ụmụ gị ga-anọ dịka ndị ọbịa nʼala na-abụghị nke ha. A ga-edo ha ọnọdụ dịka ndị ohu, mejọọ ha narị afọ anọ.  
\v 14 Ma aga m ata mba ahụ ha na-efe dịka ohu ahụhụ. Nʼikpeazụ, ha ga-eji ọtụtụ akụ si nʼebe ahụ pụta.  
\v 15 Ma ị ga-anwụ nʼudo. A ga-eli gị mgbe ị kara ezi nka.  
\v 16 Mgbe ọgbọ anọ gasịrị, ụmụ ụmụ gị ga-alọtakwa nʼala a. Nʼihi na mmehie ndị Amọrait erubeghị nʼuju ya.” 
\p  
\v 17 Mgbe anwụ dara, mgbe ọchịchịrị gbachiri ebe niile, ite ọkụ na-akwụ anwụrụ ọkụ nke nwere ọwa na-enwu ọkụ si nʼetiti ibe anụ ndị ahụ gafee.  
\v 18 Nʼụbọchị ahụ ka \nd Onyenwe anyị\nd* na Ebram gbara ndụ. Ọ sị, “Ndị agbụrụ gị ka m ga-enye ala ndị a, malite nʼiyi ndị Ijipt ruo nʼiyi ukwu Yufretis.  
\v 19 Ala ndị Ken, na nke ndị Keniz, na nke ndị Kadmọn,  
\v 20 na ala ndị Het, na nke ndị Periz na nke ndị Refaim,  
\v 21 na ala ndị Amọrait na nke ndị Kenan na nke ndị Gigash na nke ndị Jebus.” 
\c 16  
\s1 Hega na Ishmel 
\p  
\v 1 Ma Serai nwunye Ebram, amụtaghị nwa. Serai nwere odibo nwanyị onye Ijipt, aha ya bụ Hega.  
\v 2 Ya mere ọ gwara Ebram sị, “Lee, ugbu a, \nd Onyenwe anyị\nd* egbochiela m ịmụta ụmụ.\f + \fr 16:2 \ft Amụtaghị nwa bụ ihe ndị mmadụ na-ahụta dị ka ntaramahụhụ si nʼaka Chineke. Ọ bụrụ na nwanyị amụtaghị nwa, nʼebe ụfọdụ, omenaala na-akwado ya ị họtara di ya nwanyị ọzọ, onye ga-amụrụ ya ụmụ. Ụmụ niile nwanyị ahụ ga-amụta na-abụ nke nwanyị ahụ na-amụtaghị nwa. \xt Jen 20:18; 30:3\f* Ugbu a, bakwuru nwanyị na-ejere m ozi. Ma eleghị anya, aga m esi na ya wulite ezinaụlọ m.” 
\p Ebram kweere ihe Serai kwuru.  
\v 3 Ya mere Serai nwunye Ebram, duuru Hega, odibo nwanyị ya, onye Ijipt, dunye Ebram ka ọ bụrụ nwunye ya. Ihe a mere na ngwụcha afọ iri site na mgbe Ebram bịara biri nʼala Kenan.  
\v 4 Ebram na Hega dinara. Hega tụụrụ ime. 
\p Ma mgbe Hega matara na ọ dịrịla ime, ọ malitere ileda nne ya ukwu bụ Serai anya.  
\v 5 Mgbe ahụ, Serai gwara Ebram sị, “Ọ bụ gị butere ahụhụ a m nọ nʼime ya. Ọ bụ m were nwaodibo nwanyị m kunye gị nʼaka, ma ugbu a ọ hụrụ na ọ dị ime, abụrụla m onye ọ na-eleda anya. Ka \nd Onyenwe anyị\nd* kpee ikpe a nʼetiti mụ na gị.” 
\p  
\v 6 Ebram zara Serai sị, “Lee, ohu gị nwanyị dị gị nʼaka. Jiri ya mee ihe ọbụla dị gị mma nʼanya.” Nʼihi nke a, Serai mesiri ya ihe ike, nke mere ka o si nʼebe Serai nọ gbapụ. 
\p  
\v 7 Ma mmụọ ozi \nd Onyenwe anyị\nd* hụrụ ya nʼakụkụ isi iyi mmiri dị nʼọzara, nʼakụkụ ụzọ Shua,  
\v 8 jụọ ya sị, “Hega, ohu nwanyị Serai, olee ebe i si bịa, olee ebe ka ị na-ejekwa?” 
\p Hega zara sị, “Ọ bụ site nʼihu nne m ukwu Serai ka m na-agba ọsọ.” 
\p  
\v 9 Mmụọ ozi \nd Onyenwe anyị\nd* gwara ya sị, “Laghachikwuru nne gị ukwu. Doo onwe gị nʼokpuru ya.”  
\v 10 Mmụọ ozi \nd Onyenwe anyị\nd* sịkwa ya, “Aga m amụba ụmụ gị, ka a hapụ inwe ike ịgụta ole ha dị.” 
\p  
\v 11 Mmụọ ozi \nd Onyenwe anyị\nd* gwakwara ya sị, 
\q1 “Ị dị ime ugbu a, 
\q2 ị ga-amụ nwa nwoke. 
\q1 Aha ị ga-agụ ya bụ Ishmel 
\q2 nʼihi na \nd Onyenwe anyị\nd* anụla maka nhụju anya gị. 
\q1  
\v 12 Nwoke dịka ịnyịnya ibu a na-azụghị azụ ka ọ ga-abụ. 
\q2 Ọ ga-emegide onye ọbụla, 
\q2 onye ọbụla ga-emegidekwa ya. 
\q1 Ọ ga-ebi nʼime ibu iro, 
\q2 megide ụmụnna ya niile.” 
\p  
\v 13 Hega kpọkuru aha \nd Onyenwe anyị\nd*, onye gwara ya okwu sị, “Ị bụ Chineke m na-ahụ m.” Nʼihi na Hega kwuru sị, “Ahụla m, ugbu a, onye ahụ na-ahụ m.”  
\v 14 Ọ bụ ya mere e ji na-akpọ olulu mmiri ahụ, Bịa-Lahai-Rọị.\f + \fr 16:14 \ft Ma o bụ, \fqa Olulu Mmiri nke Onye ahụ dị ndụ na-ahụ m.\f* Ọ ka dị ebe ahụ, nʼetiti Kadesh na Bered. 
\p  
\v 15 Emesịa, Hega mụtaara Ebram nwa nwoke. Ebram kpọrọ nwa nwoke ahụ Hega mụtaara ya Ishmel.  
\v 16 Ebram gbara iri afọ asatọ na isii mgbe Hega mụtaara ya Ishmel. 
\c 17  
\s1 Ọgbụgba ndụ nke obibi ugwu 
\p  
\v 1 Mgbe Ebram gbara iri afọ itoolu na itoolu, \nd Onyenwe anyị\nd* gosiri ya onwe ya sị ya, “Abụ m Chineke Onye pụrụ ime ihe niile. Jegharịa ije nʼihu m, bụrụ onye na-enweghị ịta ụta ọbụla.  
\v 2 Aga m eme ka ọgbụgba ndụ m dịrị nʼetiti mụ na gị, mekwa ka ị mụbaa nke ukwuu nʼọnụọgụgụ.” 
\p  
\v 3 Ebram dara nʼala, kpudo ihu ya nʼala. Chineke gwara ya sị,  
\v 4 “Lee, nke a bụ ọgbụgba ndụ dị nʼetiti mụ na gị. Ị ga-abụ nna ọtụtụ mba.  
\v 5 Aha gị agaghị abụkwa Ebram, kama ọ ga-abụ Ebraham, nʼihi na emeela m gị nna nke ọtụtụ mba.  
\v 6 Aga m eme gị ka ị mụbaa nke ukwuu. Aga m eme ka ị ghọọ ọtụtụ mba dị iche iche, ndị eze ga-esitekwa na gị pụta.  
\v 7 Aga m eme ka ọgbụgba ndụ mụ na gị gbara guzosie ike, ka ọ dịkwara ụmụ ụmụ ndị ga-esote gị nʼọgbọ niile na-abịa. Ọ bụ ọgbụgba ndụ na-egosi na m bụ Chineke gị, na Chineke ụmụ ụmụ gị niile ga-eso gị.  
\v 8 Ala Kenan niile, ebe ị nọ ugbu a dịka ọbịa ka m ga-enye gị na ụmụ ụmụ gị ga-esote gị dịka ihe nketa ebighị ebi. Aga m abụ Chineke ha.” 
\p  
\v 9 Chineke gwara Ebraham okwu sị ya, “Ma nʼebe ị nọ, ị ghaghị irube isi imezu ihe ọgbụgba ndụ m kwuru, gị onwe gị na ụmụ ụmụ gị ndị ga-esote gị, ruo ọgbọ niile.  
\v 10 Nke a bụ ọgbụgba ndụ dị nʼetiti mụ na gị na ụmụ ụmụ gị ndị ga-esote gị, ọgbụgba ndụ nke unu na-aghaghị idebe. A ga-ebi nwoke ọbụla nʼetiti unu ugwu.  
\v 11 A ga-ebi unu ugwu, bipụ elu ahụ nke anụ ahụ unu. Nke a ga-abụ ihe ama nke ọgbụgba ndụ dị nʼetiti mụ na unu.  
\v 12 Nʼoge ọ gbara mkpụrụ ụbọchị asatọ, unu ga-ebi nwoke ọbụla nʼagbụrụ unu ugwu: ndị a mụrụ nʼụlọ, maọbụ ndị eji ego zụta site nʼaka ndị mba ọzọ, ndị na-esighị na mkpụrụ nke afọ gị.  
\v 13 A ga-ebi ha niile ugwu. Ma a mụrụ ha nʼezinaụlọ gị ma i ji ego zụta ha site nʼaka onye mba ọzọ. Ọgbụgba ndụ m nke ga-apụta ihe nʼanụ ahụ gị bụ ọgbụgba ndụ ebighị ebi.  
\v 14 Nwoke ọbụla a na-ebighị ugwu nke anụ ahụ ka a ga-ebipụ site nʼetiti ụmụnna ya. Nʼihi na o mehiela megide ọgbụgba ndụ m.” 
\p  
\v 15 Chineke gwakwara Ebraham sị, “Ma nʼebe Serai nwunye gị nọ, ị gaghị akpọkwa ya Serai ọzọ, kama aha ya ga-abụ Sera.  
\v 16 Aga m agọzi ya, sitekwa na ya nye gị nwa nwoke. Aga m agọzi ya ruo na ọ ga-abụ nne nke ọtụtụ mba. Ndị eze ga-achị ọtụtụ mmadụ ga-esite na ya pụta.” 
\p  
\v 17 Ebraham dara kpuo ihu nʼala, chịakwa ọchị nʼobi ya sị, “Ọ bụ onye gbara narị afọ ka a ga-amụrụ nwa? Sera, onye gbara iri afọ itoolu ọ ga-amụ nwa?”  
\v 18 Ebraham gwara Chineke sị, “A sịkwa na ị ga-ekwe mee ka Ishmel bụrụ onye dị ndụ nʼihu gị.” 
\p  
\v 19 Ma Chineke zara sị ya, “Ee, kama Sera nwunye gị ga-amụtara gị nwa nwoke. Ị ga-agụ ya Aịzik. Ọgbụgba ndụ m ga-adịkwara ya na agbụrụ ya ruo mgbe ebighị ebi.  
\v 20 Ma banyere Ishmel, anụla m ihe i kwuru. Aga m agọzi ya mee ya ka ọ baa ụba ma dịkwa ukwuu nʼọnụọgụgụ. Ọ ga-aghọ nna ndị eze iri na abụọ. Aga m eme ya ka ọ ghọọ mba dị ukwuu.  
\v 21 Ma ọgbụgba ndụ m ka m ga-eme ka o guzosie ike nʼebe Aịzik nọ, onye Sera ga-amụtara gị nʼoge dịka ugbu a nʼafọ ọzọ.”  
\v 22 Mgbe ọ gwasịrị Ebraham okwu, Chineke si nʼebe ọ nọ pụọ. 
\p  
\v 23 Nʼụbọchị ahụ, Ebraham duuru Ishmel nwa ya nwoke, na ndị ikom niile a mụrụ nʼezinaụlọ ya, tinyere ndị e ji ego zụta, ndị ikom niile nọ nʼezinaụlọ ya, bie ha ugwu dịka Chineke gwara ya ka ọ mee.  
\v 24 Ebraham gbara iri afọ itoolu na itoolu mgbe e biri ya ugwu,  
\v 25 Ishmel nwa ya gbara afọ iri na atọ.  
\v 26 E biri Ebraham na nwa ya bụ Ishmel ugwu nʼotu ụbọchị ahụ.  
\v 27 Ndị ikom niile nọ nʼezinaụlọ Ebraham, ndị a mụrụ nʼụlọ ya na ndị e si nʼaka ndị mba ọzọ zụta ka e biri ugwu nʼoge Ebraham biri ugwu. 
\c 18  
\s1 Ndị ọbịa atọ 
\p  
\v 1 \nd Onyenwe anyị\nd* gosiri Ebraham onwe ya nʼakụkụ osisi ukwu dị na Mamre, mgbe Ebraham nọdụrụ ala nʼihu ụlọ ikwu ya, nʼetiti ehihie.  
\v 2 O lelitere anya ya hụ ndị ikom atọ ka ha guzo ebe ọ nọ nso. Mgbe ọ hụrụ ha, o sitere nʼihu ụlọ ikwu ya gbakwuru ha izute ha, kpọọ isiala. 
\p  
\v 3 Ọ sịrị, “Onyenwe m, ọ bụrụ na m natara amara nʼihu gị, agabigala ohu gị.  
\v 4 Biko, ka ekutere unu mmiri ntakịrị, ka unu sachaa ụkwụ unu, zurukwa ike nʼokpuru osisi a.  
\v 5 Ka m wetara unu nri ntakịrị unu ga-eri nke ga-agba unu ume tupu unu agawa nʼihu nʼije unu ugbu a unu bịara na nke ohu unu.” 
\p Ha zara sị ya, “Ọ dị mma. Mee dịka i kwuru.” 
\p  
\v 6 Ya mere, Ebraham mere ngwangwa banyekwuru Sera nʼụlọ ikwu ya sị ya, “Mee ngwa, mapụta ihe ọtụtụ sịa atọ\f + \fr 18:6 \ft Ya bụ ihe ruru kilogram iri na isii\f* site na ọka a kwọrọ nke ọma jiri meta achịcha.” 
\p  
\v 7 Mgbe ahụ, Ebraham gbagara nʼigwe ehi ya, họpụta otu nwa ehi na-akaghị aka nke ahụ ya dị mma, nye ya otu ohu ya onye mere ngwangwa gbuo ya, dozie ya maka oriri.  
\v 8 Emesịa, Ebraham buuru mmiri ara ehi nke rahụrụ arahụ, na mmiri ara ehi, na anụ ahụ a kwadoro dozie ha nʼihu ndị ọbịa ahụ. O guzokwara nso nso ebe ha nọ nʼokpuru osisi ahụ mgbe ha na-eri nri. 
\p  
\v 9 Ha jụrụ ya sị, “Ebee ka Sera nwunye gị nọ?” 
\p Ọ zara sị, “Ọ nọ nʼime ụlọ ikwu.” 
\p  
\v 10 Ọ sịrị ya, “Nʼezie, mụ onwe m ga-alọghachikwute gị nʼoge a nʼafọ ọzọ, Sera nwunye gị ga-amụta nwa nwoke.” 
\p Sera guzo nʼime ụlọ ikwu ahụ nke dị nʼazụ Ebraham na-ege ntị nʼihe ha na-ekwu.  
\v 11 Nʼoge a, Ebraham na Sera emeela nnọọ agadi, gbaakwa isi awọ. Sera agafeela oge ịmụta nwa.  
\v 12 Ya mere, mgbe Sera nụrụ ihe Onyenwe anyị kwuru, ọ chịrị ọchị sị, “Agadi nwanyị dịka m o si aṅaa amụta nwa, ugbu a onyenwe m karala nka?” 
\p  
\v 13 \nd Onyenwe anyị\nd* jụrụ Ebraham ajụjụ sị, “Gịnị mere Sera ji achị ọchị? Gịnị mere o ji kwuo sị, ‘Olee otu agadi nwanyị dịka m ga-esi mụọ nwa?’  
\v 14 Ọ dị ihe nyịrị \nd Onyenwe anyị\nd* ime? Mụ onwe m ga-alọghachikwute gị nʼoge a kara aka, Sera nwunye gị ga-amụta nwa nwoke.” 
\p  
\v 15 Ma ụjọ tụrụ Sera. Nʼihi ya, ọ gọrọ agọ sị, “Achịghị m ọchị.” 
\p Ma Ọ zara sị, “Ọ bụ ezie, Sera, ị chịrị ọchị.” 
\s1 Ebraham arịọ arịrịọ banyere Sọdọm 
\p  
\v 16 Mgbe ndị ikom atọ ahụ biliri ibidokwa ije ha, ha chere ihu ịga obodo Sọdọm,\f + \fr 18:16 \ft Ọnọdụ obodo Sọdọm agbanwebeghị, ọ bụladị ugbu a, ọ ka dị na ndịda akụkụ osimiri Nwụrụ anwụ nke bụkwa osimiri Nnu.\f* Ebraham dupụkwara ha.  
\v 17 Mgbe ha na-aga nʼụzọ, \nd Onyenwe anyị\nd* tulere sị, “O kwesiri ka m zochiere Ebraham ihe m chọrọ ime?  
\v 18 Ebraham aghaghị ịbụ mba dị ukwuu dịkwa ike. A ga-agọzikwa agbụrụ niile nọ nʼụwa site na ya.  
\v 19 Nʼihi na ahọpụtala m ya, ka ọ tụziere ụmụ ya na ụlọ ya ndị ga-esote ya ịgbaso ụzọ \nd Onyenwe anyị\nd* site nʼime ihe dị mma na ihe ziri ezi, ka \nd Onyenwe anyị\nd* mezuoro Ebraham ihe niile o kwere ya na nkwa.” 
\p  
\v 20 Mgbe ahụ, \nd Onyenwe anyị\nd* kwuru sị, “Mkpu akwa m na-anụ site na Sọdọm na Gọmọra dị ukwuu, otu a kwa, mmehie ha jọbigara njọ oke.  
\v 21 Ugbu a, ana m aga ka m jiri anya m hụ ma ihe ha mere ọ dị njọ dịka mkpu akwa m na-anụ si dị. Ma o sighị otu ahụ dịrị, aga m amata.” 
\p  
\v 22 Mgbe ahụ, ndị ikom abụọ nʼime ha gawara Sọdọm. Ma Ebraham nọ na-eguzo nʼihu \nd Onyenwe anyị\nd*.  
\v 23 Ebraham jeruru Onyenwe anyị nso jụọ ya sị, “Uche gị ọ bụ ikpochapụ ndị ezi omume na ndị ajọ omume?  
\v 24 Ọ bụrụ na ị chọta iri ndị ezi omume ise nʼime obodo ahụ, ị ga-ekpochapụ obodo ahụ? Ị gaghị agbaghara\f + \fr 18:24 \ft Maọbụ, \fqa Ị gaghị echebe ya\f* ya nʼihi iri ndị ezi omume ise nọ nʼime ya?  
\v 25 Ọ bụghị ezi ihe na ị ga-ala ndị ezi omume na ndị ajọ omume nʼiyi. Nʼihi na ị gaghị emeso ndị ezi omume dịka i si mesoo ndị na-eme ajọ ihe. O kwesighị ka onye ga-ekpe ụwa niile ikpe, kpee ikpe ziri ezi?” 
\p  
\v 26 Mgbe ahụ, \nd Onyenwe anyị\nd* zara sị ya, “Ọ bụrụ na m achọta iri ndị ezi omume ise nʼobodo Sọdọm, aga m agbaghara obodo ahụ niile nʼihi ha.” 
\p  
\v 27 Ebraham kwukwara ọzọ sị, “Ugbu a m nwere ike kwuwapụta okwu nʼihu Onyenwe anyị, mụ onye bụ naanị aja na ntụ.  
\v 28 Eleghị anya ọ bụrụ na e nweta naanị iri ndị ezi omume anọ na ise, ị ga-emebi obodo ahụ?” 
\p \nd Onyenwe anyị\nd* zara sị, “Agaghị m ebibi ya ma ọ bụrụ na m achọta iri mmadụ anọ na ise nʼime ya.” 
\p  
\v 29 Ọzọkwa, ọ sịrị ya, “Ọ bụrụkwanụ na a ga-achọta naanị iri mmadụ anọ?” 
\p \nd Onyenwe anyị\nd* zara sị ya, “Nʼihi iri mmadụ anọ, agaghị m ebibi ya.” 
\p  
\v 30 Mgbe ahụ ọ sịrị, “Biko, ka iwe hapụ iwe Onyenwe anyị ma m kwuo okwu. Eleghị anya, achọta naanị iri mmadụ atọ nʼebe ahụ?” 
\p \nd Onyenwe anyị\nd* zaghachiri sị ya, “Agaghị m emebi ya, ma ọ bụrụ na m achọta iri mmadụ atọ nʼime ya.” 
\p  
\v 31 O kwuru sị, “Ebe ọ bụ na m amalitela ịgwa gị, Onyenwe anyị okwu, biko kwere ka m gaa nʼihu. Ọ bụrụ na a ga-achọta naanị iri mmadụ abụọ?” 
\p \nd Onyenwe anyị\nd* zara sị, “Nʼihi iri mmadụ abụọ ahụ agaghị m emebi ya.” 
\p  
\v 32 Nʼikpeazụ, Ebraham kwuru sị, “Ka iwe hapụ iwe Onyenwe anyị. Ka m kwuo naanị otu ugboro a. Ọ bụrụkwanụ na a chọta naanị mmadụ iri nʼebe ahụ?” 
\p \nd Onyenwe anyị\nd* zara sị, “Nʼihi mmadụ iri ahụ, agaghị m ebibi ya.” 
\p  
\v 33 Mgbe \nd Onyenwe anyị\nd* gwachara Ebraham okwu, ọ hapụrụ ya gawa ebe ọ na-aga. Ebraham laghachiri azụ nʼụlọ ya. 
\c 19  
\s1 Mbibi Sọdọm na Gọmọra 
\p  
\v 1 Nʼoge anyasị, ndị mmụọ ozi abụọ ahụ bịarutere Sọdọm. Lọt nọ ala nʼọnụ ụzọ ama obodo ahụ. Mgbe ọ hụrụ ha, o biliri jekwuru ha, hulata ihu ya nʼala.  
\v 2 Ọ sịrị, “Ndị nwe m, batanụ nʼụlọ ohu unu. Unu nwere ike saa ụkwụ unu, nọọkwa ọnọdụ abalị. Chi bọọ, unu nwere ike ibilikwa bido ịga nʼihu nʼije unu.” 
\p Ha zara sị, “Ee, anyị ga-edina nʼama.” 
\p  
\v 3 Ma Lọt rịọsiri ha ike. Nʼikpeazụ ha sooro ya laa nʼụlọ ya. Ọ kwadooro ha ihe oriri, ya bụ achịcha na-ekoghị eko ka o ghere. Ha rikwara ya.  
\v 4 Tupu ha abanye ịrahụ ụra, ndị ikom obodo ahụ, ndị ikom Sọdọm, bịara gbaa ụlọ ahụ gburugburu, ma ụmụ okorobịa ma ndị agadi, ndị niile si nʼakụkụ obodo ahụ.  
\v 5 Ha kpọrọ Lọt oku sị ya, “Olee ebe ha nọ, bụ ndị ikom ahụ bịara nʼụlọ gị nʼabalị a? Kpọpụtara anyị ha ka anyị na ha dinakọọ.” 
\p  
\v 6 Lọt pụkwuru ha nʼezi, mechie ụzọ ụlọ ya,  
\v 7 sị ha, “Bikonu, ndị enyi m, unu emela ihe ọjọọ dị otu a.  
\v 8 Leenụ, enwere m ụmụ nke aka m, ụmụ agbọghọ abụọ na-amaghị nwoke. Ka m kpọpụtara unu ha, ka unu mee ha ihe masịrị unu. Ma hapụnụ ndị ikom ndị a, nʼihi na ha bụ ndị batara izere ndụ nʼụlọ m.” 
\p  
\v 9 Ha zara sị ya, “Pụọra anyị nʼụzọ. Mbịarambịa ka ị bụ! Leenụ mbịarambịa a! Ọ chọrọ ịbụ onye ikpe. Anyị mee gị ihe, ọ ga-ajọrọ gị njọ karịa ihe anyị ga-eme ha.” Ha nuru Lọt aka nughachi ya azụ, malite itiwa ọnụ ụzọ ụlọ ya. 
\p  
\v 10 Ma ndị ikom ahụ nọ nʼụlọ Lọt, setịpụrụ aka ha dọbata ya nʼụlọ, ma mechie ụzọ ahụ.  
\v 11 Ha tiri ndị ikom ndị ahụ nọ nʼọnụ ụzọ ihe otiti nke mere ka ha kpụọ ìsì, onye ukwu ha na onye nta ha. Nʼihi ya, ha enweghị ike ịchọta ọnụ ụzọ ụlọ ahụ. 
\p  
\v 12 Ndị ikom abụọ ahụ gwara Lọt sị, “O nwere onye ọbụla ọzọ i nwere nʼebe a? Ndị ọgọ nwoke, maọbụ ụmụ gị ndị ikom, maọbụ ụmụ gị ndị inyom, na ọ bụ onye ọbụla bụ nke gị nʼobodo a. Site nʼebe a kpọpụ ha!  
\v 13 Nʼihi na anyị na-aga imebi obodo a, mkpu akwa ruru \nd Onyenwe anyị\nd* ntị megide ndị bi nʼobodo a adịla ukwuu, nke mere o ji zite anyị ibibi ya.” 
\p  
\v 14 Ya mere, Lọt pụrụ gaa gwa ndị ọgọ ya nwoke, ndị na-akwado ịlụ ụmụ ya ndị inyom, sị ha, “Ọsọ, sinụ nʼobodo a pụọ. Nʼihi na \nd Onyenwe anyị\nd* na-akwado ibibi ya.” Ma ndị ọgọ ya nwoke ndị a chere na ọ na-egwu egwu. 
\p  
\v 15 Nʼụtụtụ, mgbe chi na-abọta, ndị mmụọ ozi a kwagidere Lọt sị ya, “Ọsọ, kpọrọ nwunye gị na ụmụ gị ndị inyom abụọ ndị a site nʼebe a gbapụ, ma ọ bụghị ya, a ga-ekpochapụ unu nʼihi ajọ omume ndị obodo a.” 
\p  
\v 16 Mgbe Lọt ka nọ na-eche ihe ọ ga-eme, ndị ikom ahụ jidere ya nʼaka, jidekwa nwunye ya, na ụmụ ya ndị inyom abụọ duru ha pụọ nʼobodo ahụ, nʼihi na \nd Onyenwe anyị\nd* nwere obi ebere nʼebe ha nọ.  
\v 17 Mgbe ha si nʼime obodo kpọpụta ha, otu onye nʼime ha gwara ha sị, “Gbalaganụ nʼihi ndụ unu. Unu elekwala anya nʼazụ. Unu akwụsịkwala ebe ọbụla na mbara ala. Gbaganụ nʼugwu, nʼihi na ọ bụrụ na unu emeghị otu a, a ga-ekpochapụ unu.” 
\p  
\v 18 Ma Lọt sịrị ha, “Mba, ndị nwe m, bikonu,  
\v 19 ohu unu achọtala amara nʼihu unu, unu egosila m obi ebere dị ukwuu site nʼichebe ndụ m. Ma agaghị m enwe ike gbalaga nʼugwu ka mbibi a ghara ịdakwasị m, m nwụọ.  
\v 20 Lee obodo dị nso nke m nwere ike ịgbaga. Ọ bụ obodo dị nta. Kwere ka m gbaga nʼebe ahụ. Obodo nta ka ọ bụ, ọ bụghị ya? Aga m echebekwa ndụ m na ya.” 
\p  
\v 21 Ọ zara sị ya, “Ọ dị mma, aga m emere gị dịka arịrịọ gị si dị. Agaghị m emebi obodo nta ahụ.  
\v 22 Ma mee ngwangwa, nʼihi na o nweghị ihe ọbụla m ga-eme tutu ruo mgbe i ruru nʼebe ahụ.” (Ọ bụ nke a mere e ji akpọ aha obodo ahụ Zoa.) 
\p  
\v 23 Mgbe Lọt rutere obodo Zoa, anwụ awalitela nʼala ahụ.  
\v 24 Mgbe ahụ \nd Onyenwe anyị\nd* sitere nʼeluigwe zokwasị obodo Sọdọm na Gọmọra nkume ọkụ nke \nd Onyenwe anyị\nd* mere ka o si nʼeluigwe zoo.  
\v 25 Otu a ka o si kwatuo obodo ndị ahụ niile dị na mbara ala ahụ niile, na ndị niile bi nʼobodo ndị ahụ. O kwatukwara ihe niile na-epu nʼala.  
\v 26 Ma mgbe nwunye Lọt lere anya nʼazụ, otu mgbe ahụ, ọ ghọrọ ogidi nnu. 
\p  
\v 27 Nʼụtụtụ echi ya, Ebraham biliri jeruo ebe ahụ o guzoro nʼihu \nd Onyenwe anyị\nd* nʼụbọchị gara aga.  
\v 28 Ọ lepụrụ anya nʼebe obodo Sọdọm na Gọmọra dị, na nʼebe mbara ala ndị ahụ niile dị. Ọ hụrụ anwụrụ ọkụ dị ukwuu nke si nʼala ahụ na-alali elu. Anwụrụ ọkụ a dị ka anwụrụ ọkụ si nʼebe a kwanyere ọkụ na-enwusi ike. 
\p  
\v 29 Ya mere, mgbe Chineke bibiri obodo ndị ahụ dị na mbara ala, o chetara Ebraham, kpọpụta Lọt site nʼoke mbibi ahụ e bibiri obodo ndị ahụ Lọt bi nʼime ha. 
\s1 Lọt na ụmụ ya ndị inyom 
\p  
\v 30 Emesịa, Lọt na ụmụ ya ndị inyom abụọ hapụrụ obodo Zoa, nʼihi na ọ tụrụ egwu ibi nʼime Zoa. Ọ gara biri nʼime ọgba nkume ya na ụmụ ya ndị inyom abụọ.  
\v 31 Otu ụbọchị, ada ya sịrị nke nta, “Nna anyị emeela agadi, ọ nwekwaghị nwoke ọbụla nọ nʼụwa a, onye ga-enye anyị ụmụ, dịka omenaala si dị nʼụwa niile.  
\v 32 Ka anyị mee ka nna anyị ṅụọ mmanya, ka anyị na ya dinakọọ, ka anyị chebe agbụrụ anyị site na nna anyị.” 
\p  
\v 33 Nʼabalị ahụ, ha mere ka nna ha ṅụọ mmanya, nke ada banyere soro nna ya dina. Ha abụọ nwere mmekọ. Ma ọ amaghị mgbe ada ya dinara maọbụ mgbe o bilikwara. 
\p  
\v 34 Nʼechi ya, ada gwara nwanne ya nke nta, “Mụ na nna anyị dinara nʼabalị gara aga. Ka anyị mee ka ọ ṅụọkwa mmanya nʼabalị taa, ka ị gaakwa ka gị na ya dina. Ka anyị mee ka agbụrụ anyị dịgide site na nna anyị.”  
\v 35 Ha mere ka nna ha ṅụọ mmanya nʼabalị ahụ, ada ya nke nta banyere ya na nna ya dinaa. Dịka ọ dịkwa na mbụ, nna ha amataghị mgbe o dinara ala maọbụ mgbe o bilitere. 
\p  
\v 36 Ya mere, ụmụ ndị inyom Lọt abụọ ndị a tụrụ ime site nʼaka nna ha.  
\v 37 Nke ada mụtara nwa nwoke onye ọ gụrụ Moab. Ọ bụ ya bụ nna nna ndị Moab ruo taa.  
\v 38 Nwa ya nke nta mụtakwara nwa nwoke onye ọ gụrụ Ben-Ammi. Ọ bụ ya bụ nna nna ndị Amọn ruo taa. 
\c 20  
\s1 Ebraham na Abimelek 
\p  
\v 1 Ugbu a, Ebraham sitere nʼebe ahụ bilie gaa na mpaghara Negev biri nʼebe dị nʼagbata Kadesh na Shua. Ọ nọrọ nʼobodo Gera nwa oge nta.  
\v 2 Nʼebe ahụ, Ebraham kwuru maka Sera, nwunye ya, sị “Ọ bụ nwanne m nwanyị.” Abimelek, eze Gera, ziri ozi kpọrọ Sera. 
\p  
\v 3 Ma Chineke bịakwutere Abimelek na nrọ nʼanyasị, sị ya, “Onye nwụrụ anwụ ka ị bụ, nʼihi nwanyị nke ị kpọọrọ, nwanyị a bụ onye nwere di.” 
\p  
\v 4 Ma Abimelek abịabeghị Sera nso, ya mere o ji sị, “Onyenwe m, ị ga-ebibi mba aka ya dị ọcha?  
\v 5 Ọ bụ na ya onwe ya agwaghị m sị, ‘ọ bụ nwanne m nwanyị,’ nke nwanyị nʼonwe ya, ekwuokwa sị, ‘Nwanne m nwoke ka ọ bụ?’ E ji m uche dị ọcha na aka dị ọcha mee ihe niile m mere.” 
\p  
\v 6 Chineke zara ya sị, “Amaara m na i ji uche dị ọcha mee ihe i mere. Ọ bụ ya mere m ji gbochie gị imehie megide m. Ọ bụkwa ya mere m ji gbochie gị ịmetụ ya aka.  
\v 7 Ugbu a, nyeghachi nwoke a nwunye ya. Nʼihi na ọ bụ onye amụma. Ọ ga-ekpere gị ekpere, ka ị ghara ịnwụ. Ma ọ bụrụ na i dughachịghị nwanyị a nye di ya, unu ga-anwụ, gị na ndị gị niile.” 
\p  
\v 8 Ya mere, Abimelek biliri nʼisi ụtụtụ echi ya, kpọọ nzukọ nke ndịisi ozi ya niile, kọọrọ ha ihe mere. Ha tụrụ ụjọ nke ukwuu.  
\v 9 Emesịa, Abimelek kpọbatara Ebraham sị ya, “Gịnị bụ ihe a i mere anyị? Gịnị bụ ihe ọjọọ m mere i ji butere mụ na alaeze m ihe oke ikpe ọmụma dị otu a? Ihe a i mere m bụ ihe na-ekwesighị ekwesi.”  
\v 10 Abimelek jụrụ Ebraham sị, “Ọ bụ gịnị ka ị hụrụ i jiri mee omume dị otu a?” 
\p  
\v 11 Ebraham zara ya, “Nʼihi na asịrị m nʼobi m, ‘Nʼezie, ịtụ egwu Chineke adịghị nʼebe a. Ha ga-egbu m nʼihi nwunye m.’  
\v 12 Ewezugakwa nke a, ọ bụ nwanna m nwanyị, nʼihi na otu nna mụrụ anyị, ma ọ bụghị otu nne, tupu ọ bụrụ nwunye m.  
\v 13 Mgbe Chineke sitere nʼezinaụlọ nna m zipụ m ije ebe dị anya, agwara m ya sị, ‘Otu a ka ị ga-esi gosi na ị hụrụ m nʼanya, ebe ọbụla anyị gara, kwuo gbasara m, “Onye a bụ nwanne m.” ’ ” 
\p  
\v 14 Mgbe ahụ, Abimelek dupụtara atụrụ, na ehi, na ndị ohu ndị ikom, na ndị ohu ndị inyom, nye Ebraham. Ọ kpọnyekwara ya Sera nwunye ya.  
\v 15 Abimelek sịrị, “Lee nʼala m niile, birikwa nʼebe ọbụla masịrị gị.” 
\p  
\v 16 Mgbe ahụ, ọ sịrị Sera, “Ana m enye nwanne gị puku shekel ọlaọcha, ka ọ bụrụ ihe m ji kwụọ ụgwọ mmeso ọjọọ m mesoro gị. Ejikwa m ya na-egosi na ị bụ onye aka ya dị ọcha.” 
\p  
\v 17 Mgbe ahụ, Ebraham kpọkuru Chineke nʼekpere. Chineke gwọrọ Abimelek na nwunye ya, na ndị inyom ndị ohu ya niile, ka ha nwee ike ịmụta ụmụ ọzọ.  
\v 18 Nʼihi na \nd Onyenwe anyị\nd* mechiri akpanwa ndị inyom niile nọ nʼezinaụlọ Abimelek nʼihi Sera nwunye Ebraham. 
\c 21  
\s1 Ọmụmụ Aịzik 
\p  
\v 1 \nd Onyenwe anyị\nd* jiri amara leta Sera dịka o kwuru na ọ ga-eme. \nd Onyenwe anyị\nd* meere Sera ihe o kwere na nkwa.  
\v 2 Sera tụụrụ ime, mụọra Ebraham nwa nwoke nʼoge o merela agadi. Ọ mụrụ ya nʼoge ahụ a kara aka Chineke kwere ya na nkwa.  
\v 3 Ebraham gụrụ nwantakịrị ahụ Sera mụụrụ ya aha, kpọọ ya Aịzik.  
\v 4 Mgbe Aịzik nọrọ ụbọchị asatọ site nʼụbọchị a mụrụ ya, Ebraham biri ya ugwu dịka Chineke si nye ya nʼiwu.  
\v 5 Ebraham agbaala narị afọ mgbe a mụrụ Aịzik nwa ya nwoke. 
\p  
\v 6 Nʼoge ahụ, Sera kwuru sị, “Chineke ewetarala m ọchị. Ndị niile nụrụ akụkọ a ga-esoro m chịa ọchị.”  
\v 7 O kwukwara sị, “Onye gaara agwa Ebraham sị ya na Sera ga-azụlite ụmụntakịrị. Ma otu ọ dị, amụtarala m ya nwa nwoke ugbu a o merela agadi.” 
\s1 Ebraham achụpụ Hega na nwa ya 
\p  
\v 8 Nwata ahụ tokwara, ruo mgbe a kwụsịrị ya ara.\f + \fr 21:8 \ft Nʼusoro omenaala, ọ bụ mgbe nwantakịrị gbara afọ abụọ, maọbụ atọ ka a na-akwụsị ya ara. Nʼoge ochie, ị kwụsị nwantakịrị ara na-abụ oge mmemme na oke oriri.\f* Nʼụbọchị ahụ a kwụsịrị ya ara, Ebraham kpọrọ oriri.  
\v 9 Ma mgbe Sera hụrụ na nwa nwoke ahụ Hega onye Ijipt mụtaara Ebraham nọ na-akwa emo,  
\v 10 ọ gwara Ebraham okwu sị ya, “Chụpụ ohu nwanyị a na nwa ya. Nʼihi na nwa nwoke ohu nwanyị agaghị eso nwa m nwoke Aịzik keta oke nʼihe nketa.” 
\p  
\v 11 Okwu a wutere Ebraham nke ukwuu nʼihi na ihe banyere nwa ya nwoke Ishmel na-emetụ ya nʼobi.  
\v 12 Ma Chineke gwara Ebraham sị, “Ekwela ka obi jọọ gị njọ nʼihi nwantakịrị a na ohu gị nwanyị. Gee ntị nʼihe ọbụla Sera gwara gị. Nʼihi na ọ bụ site nʼAịzik ka a ga-akpọ mkpụrụ gị aha.  
\v 13 Aga m eme ka nwa gị nwoke nke ohu gị mụtara ghọọ mba dị ukwuu, nʼihi na mkpụrụ afọ gị ka ọ bụ.” 
\p  
\v 14 Ebraham biliri nʼisi ụtụtụ echi ya, kwadoo ihe oriri na mmiri ọṅụṅụ nke dị nʼime karama akpụkpọ, bunye ha Hega. O bukwasịrị ha nʼubu Hega, zipụ ya na nwa ya nwoke. Hega si nʼebe ahụ pụọ wagharịa nʼime ọzara Bịasheba. 
\p  
\v 15 Mgbe mmiri dị na karama akpụkpọ ahụ gwụsịrị, o nibere nwantakịrị ahụ nʼokpuru otu osisi ọhịa.  
\v 16 Hapụ ya gaa nọdụ ala nʼebe dịtụ anya, ihe dịka narị nzọ ụkwụ, nʼihi na o kwuru nʼobi ya sị, “Achọghị m ịhụ nwantakịrị nwoke a anya mgbe ọ na-anwụ.” Mgbe ọ nọdụrụ ebe ahụ, o bidoro ịkwa akwa. 
\p  
\v 17 Ma Chineke nụrụ ịkwa akwa nwantakịrị nwoke ahụ. Mmụọ ozi Chineke sikwa na mbara eluigwe kpọọ Hega oku sị ya, “Hega, gịnị na-eme gị? Atụla egwu, nʼihi na Chineke anụla\f + \fr 21:17 \fq Chineke anụla \ft Maọbụ, \fqa Chineke na-anụ, bụ ihe Ishmel pụtara.\f* olu akwa nwantakịrị ahụ nʼebe ahụ o dina.  
\v 18 Gaa kulite nwantakịrị ahụ kasịe ya obi, nʼihi na aga m eme ya ka ọ ghọọ mba dị ukwuu.” 
\p  
\v 19 Mgbe ahụ, Chineke meghere anya ya, mee ka ọ hụ olulu mmiri dị nʼebe ahụ. Ọ gara kujuo karama akpụkpọ ahụ mmiri, ma nye nwantakịrị ahụ mmiri ka ọ ṅụọ. 
\p  
\v 20 Chineke nọnyeere nwantakịrị ahụ mgbe ọ na-eto. O biri nʼọzara ahụ ghọọ onye na-agba àkụ nke ọma.  
\v 21 Mgbe o bi nʼọzara Paran, nne ya chọtaara ya nwunye site nʼIjipt. 
\s1 Nkwekọrịta e nwere na Bịasheba 
\p  
\v 22 Nʼoge a, Abimelek na Fikọl onyeisi ndị agha ya, bịakwutere Ebraham sị ya, “Chineke nọnyeere gị nʼihe niile ị na-eme.  
\v 23 Ugbu a, ṅụọra m iyi nʼaha Chineke na ị gaghị aghọgbu m maọbụ ghọgbuo ụmụ m, maọbụ ụmụ ụmụ m. Gosi m nʼobodo a i bi nʼime ya dịka onye ọbịa ụdị obiọma m gosiri gị.” 
\p  
\v 24 Ebraham zara sị ya, “Ọ dị mma, aga m aṅụrụ gị iyi.” 
\p  
\v 25 Mgbe ahụ, Ebraham kọsaara Abimelek ihe banyere olulu mmiri nke ndị na-ejere ya ozi ji anya ike nara ndị na-ejere Ebraham ozi.  
\v 26 Abimelek zara sị, “Amaghị m onye mere ihe dị otu a. Ị gwaghị m na ihe dị otu a mere, anụghị m ya ma ọ bụghị naanị taa.” 
\p  
\v 27 Mgbe ahụ, Ebraham kpụpụtara atụrụ, na ehi, nye Abimelek. Ha abụọ gbara ndụ nkwekọrịta.  
\v 28 Mgbe Ebraham sitere nʼigwe atụrụ ya wepụta nne atụrụ asaa nupu ha ka ha nọpụ iche,  
\v 29 Abimelek jụrụ Ebraham sị ya, “Gịnị ka i ji nne atụrụ asaa ndị a ị họpụtara iche eme?” 
\p  
\v 30 Ebraham zara sị, “Nabata ụmụ atụrụ asaa ndị a dịka ihe akaebe na-egosi na ọ bụ m gwuru olulu mmiri a.” 
\p  
\v 31 Ya mere, e bidoro ịkpọ ebe ahụ Bịasheba, nʼihi na nʼebe ahụ ka mmadụ abụọ a nọ ṅụrịtaara onwe ha iyi. 
\p  
\v 32 Mgbe ha gbachara ndụ nkwekọrịta na Bịasheba, Abimelek na Fikọl onyeisi agha ya laghachiri azụ nʼala ndị Filistia.  
\v 33 Ebraham kụrụ osisi tamarisk na Bịasheba. Ebe ahụ ka ọ nọ kpọkuo aha \nd Onyenwe anyị\nd*, Chineke ebighị ebi.  
\v 34 Ebraham bigidere nʼala ndị Filistia ogologo oge. 
\c 22  
\s1 Ọnwụnwa a nwara Ebraham 
\p  
\v 1 Mgbe ihe ndị a gasịrị, Chineke nwara Ebraham. Ọ sịrị ya, “Ebraham.” 
\p Ebraham zara sị, “Lekwa m.” 
\p  
\v 2 Chineke sịrị, “Duru nwa gị nwoke, naanị otu nwa gị nwoke, Aịzik onye ị hụrụ nʼanya, gaa nʼala Mọrịa. Jiri ya chụọrọ m aja nsure ọkụ nʼelu otu nʼime ugwu dị nʼebe m ga-egosi gị.” 
\p  
\v 3 Nʼisi ụtụtụ echi ya, Ebraham biliri kwadoo ịnyịnya ibu ya. O duuru ndị ikom abụọ na-ejere ya ozi, na nwa ya nwoke Aịzik. O gbutere nkụ ga-ezuru ya ịchụ aja nsure ọkụ, bilie gawa ebe ahụ Chineke gwara ya maka ya.  
\v 4 Nʼụbọchị nke atọ, Ebraham lepụrụ anya hụ ebe ahụ nʼebe dị anya.  
\v 5 Ọ gwara ndị na-ejere ya ozi sị, “Nọdụnụ nʼebe a, unu na ịnyịnya ibu anyị, ka mụ na nwokorobịa a gaa nʼebe ahụ. Anyị feecha ofufe, anyị ga-alọghachikwute unu ọzọ.” 
\p  
\v 6 Ebraham boro nwa ya nwoke Aịzik ukwu nkụ ahụ e ji achụ aja nsure ọkụ nʼisi, ma ya onwe ya jidere ọkụ na mma.  
\v 7 Aịzik gwara nna ya Ebraham sị, “Nna m.” 
\p Ebraham zara, “Ehee, nwa m.” 
\p Aịzik sịrị, “Ọkụ na nkụ dị nʼebe a, olee nwa atụrụ e ji achụ aja nsure ọkụ?” 
\p  
\v 8 Ebraham zara, “Nwa m, Chineke nʼonwe ya ga-eweta nwa atụrụ e ji achụ aja nsure ọkụ.” Ha abụọ gakwara nʼihu nʼije ha. 
\p  
\v 9 Mgbe ha ruru ebe ahụ Chineke gwara ya maka ya, Ebraham wuru ebe ịchụ aja nʼebe ahụ, doo nkụ ndị ahụ niile nʼusoro nʼelu ya. O kere nwa ya Aịzik agbụ, tụkwasị ya nʼelu ebe ịchụ aja ahụ, na nʼelu nkụ ndị ahụ.  
\v 10 Mgbe ahụ Ebraham setịpụrụ aka ya, welite mma ka o gbuo nwa ya nwoke.  
\v 11 Ma mmụọ ozi \nd Onyenwe anyị\nd* si nʼeluigwe kpọọ ya oku sị ya, “Ebraham! Ebraham!” 
\p Ebraham zara, “Lekwa m nʼebe a.” 
\p  
\v 12 Ọ sịrị ya, “Emetụkwala nwokorobịa ahụ aka. Emekwala ya ihe ọbụla. Nʼihi na amatala m ugbu a na ị na-atụ egwu Chineke, ebe ọ bụ na i kwenyere iji nwa gị nwoke, naanị otu nwa nwoke i nwere chụọrọ m aja.” 
\p  
\v 13 Ebraham leliri anya hụ otu ebule nke eriri ọhịa jidere na mpi ya. Ebraham gara jide ebule ahụ, were ya chụọ aja nsure ọkụ nʼọnọdụ nwa ya nwoke.  
\v 14 Ya mere, Ebraham kpọrọ ebe ahụ, “\nd Onyenwe anyị\nd* ga-arọpụta.\f + \fr 22:14 \ft Maọbụ, \fqa Onyenwe anyị Jaire\f*” Ya mere ruo taa a na-asị, “Nʼugwu \nd Onyenwe anyị\nd*, a ga-arọpụta.” 
\p  
\v 15 Mmụọ ozi \nd Onyenwe anyị\nd* sitere nʼeluigwe kpọọ Ebraham oku nke ugboro abụọ,  
\v 16 sị, “Mụ onwe m, bụ \nd Onyenwe anyị\nd*, ji onwe m na-aṅụ iyi na-ekwupụta sị, ebe ọ bụ na i mere ihe dị otu a, na i kwenyere iji nwa gị nwoke, naanị otu nwoke i nwere chụọrọ m aja,  
\v 17 aga m agọzi gị nʼezie, mekwa ka ụmụ ụmụ gị mụbaa nʼọnụọgụgụ dịka kpakpando nke mbara eluigwe na dịka aja dị nʼọnụ mmiri osimiri. Ụmụ ụmụ gị ga-enwetara onwe ha ọnụ ụzọ ama ndị iro ha.  
\v 18 Sitekwa na mkpụrụ gị ka a ga-agọzikwa agbụrụ niile nọ nʼụwa, nʼihi na i rubeere m isi.” 
\p  
\v 19 Emesịa, Ebraham laghachikwuru ndị na-ejere ya ozi. Ha niile laghachikwara Bịasheba. Ebraham birikwara na Bịasheba. 
\s1 Ụmụ ụmụ Nahọ 
\li1  
\v 20 Mgbe ihe ndị a gasịrị, e ziri Ebraham ozi si ya, “Lee, Milka ya onwe ya amụkwaarala nwanne gị nwoke bụ Nahọ, ụmụ ndị ikom. 
\li2  
\v 21 Aha ha bụ Uz, onye bụ ọkpara, na Buz nwanne ya, 
\li2 Kemuel bụ (nna Aram), 
\li2  
\v 22 Kesed, Hazọ, Pildash, Jidlaf na Betuel.” 
\li3  
\v 23 Betuel mụrụ Ribeka. 
\li1 Milka mụtaara Nahọ, nwanne Ebraham ụmụ ndị ikom asatọ ndị a. 
\b  
\li1  
\v 24 Iko ya nwanyị, onye aha ya bụ Reuma, mụkwaara ya ụmụ ndị ikom. 
\li2 Ha bụ Teba, Gaham, Tahash na Maaka. 
\c 23  
\s1 Ọnwụ Sera 
\p  
\v 1 Sera dị ndụ ruo narị afọ na iri afọ abụọ na asaa.  
\v 2 Ọ nwụrụ na Kiriat Arba (nke bụ Hebrọn), nʼala Kenan. Ebraham ruru ụjụ nʼihi Sera, kwaa akwa nke ukwuu nʼihi ọnwụ ya. 
\p  
\v 3 Ebraham sitere nʼebe ozu nwunye ya dị pụọ, jekwuru ụmụ Het gwa ha sị,  
\v 4 “Abụ m ọbịa na onye obodo ọzọ nʼetiti unu. Resinụ m ala m ji eme ebe olili nʼebe a, ka m nwee ike lie onye m nwụrụ anwụ.” 
\p  
\v 5 Ụmụ Het zara Ebraham sị,  
\v 6 “Nna anyị ukwu, gee anyị ntị. Nwa eze dị ukwu ka ị bụ nʼetiti anyị, lie onye gị nwụrụ anwụ nʼili ahụ nke kachasị mma nʼime ili anyị nwere. O nweghị onye ọbụla nʼime anyị ga-ajụ inye gị ala olili ya maka ili onye gị nwụrụ anwụ.” 
\p  
\v 7 Mgbe ahụ, Ebraham biliri kpọọ isiala nʼihu ndị nwe ala, bụ ndị Het,  
\v 8 sị ha, “Ọ bụrụ ọchịchọ unu ka m lie onye m nwụrụ anwụ, geenụ m ntị ma rịọrọ m Efrọn nwa Zoha,  
\v 9 ka o resi m ọgba Makipela, nke bụ nke ya, nke dị na ngwụsị ọhịa ya. Gwa ya ka o resi m ya nʼọnụ ahịa o ruru ka ọ bụrụ ebe olili m nwere nʼetiti unu.” 
\p  
\v 10 Efrọn onye Het nʼonwe ya so nọdụ nʼebe ahụ nʼetiti ndị ya. Ọ zara Ebraham nʼihu ndị Het niile bịara nʼọnụ ụzọ ama obodo  
\v 11 sị ya, “Mba! Nna m ukwu, gee m ntị. Ana m enye gị ala ahụ na ọgba dị nʼime ya nʼihu ndị a niile bụ ndị m. Gaa lie onye gị nwụrụ anwụ nʼime ya.” 
\p  
\v 12 Ọzọ Ebraham kpọrọ isiala nye ndị nwe ala,  
\v 13 ọ sịrị Efrọn, nʼihu ha niile, “Biko gee m ntị, aga m akwụ gị ọnụahịa iji zụọ ala ahụ. Nara m ya ka m nwee ike lie onye m nwụrụ anwụ nʼime ya.” 
\p  
\v 14 Efrọn zara Ebraham,  
\v 15 “Gee m ntị, nna m ukwu, ọ bụ ezie na ala ahụ ruru narị shekel ọlaọcha anọ, ma gịnị ka nke a bụ nʼetiti mụ na gị? Gaa lie onye gị nwụrụ anwụ nʼime ya.” 
\p  
\v 16 Ebraham kwenyere nʼego ole Efrọn chọrọ ka ọ kwụọ. O ji ihe ọtụtụ tụpụtara Efrọn ego ruru ọnụahịa ọ kpọrọ aha nʼihu ndị Het niile, narị shekel ọlaọcha anọ, dịka ihe ọtụtụ nke dị nʼoge ahụ nʼetiti ndị na-azụ ahịa. 
\p  
\v 17 Site nʼoge ahụ, ala ahụ Efrọn nwere na Makipela, nke dị nso na Mamre, ala ahụ na ọgba dị nʼime ya, na osisi niile dị nʼime ala ahụ niile gburugburu,  
\v 18 ghọrọ nke Ebraham dịka ihe nzụta ya nʼihu ụmụ Het, nʼihu ndị niile ndị bịara nʼọnụ ụzọ e si abata obodo ahụ.  
\v 19 Emesịa, Ebraham liri Sera nwunye ya nʼime ọgba ahụ dị nʼala dị na Makipela na nso Mamre (nke dị na Hebrọn) nʼala ndị Kenan.  
\v 20 Ya mere, ala ahụ na ọgba dị nʼime ya ka ndị Het resiri Ebraham ka ọ bụrụ nke ya, ebe a na-eli ozu. 
\c 24  
\s1 Aịzik na Ribeka 
\p  
\v 1 Ugbu a, Ebraham aghọọla agadi nʼahụ ya ma nʼọnụọgụgụ afọ ya. \nd Onyenwe anyị\nd* agọziela ya nʼụzọ niile  
\v 2 Ọ gwara onyeisi ndị ozi nʼụlọ ya, onye nke na-elekọta ihe niile o nwere sị ya, “Tinye aka gị nʼokpuru apata m.\f + \fr 24:2 \ft Nʼusoro ịṅụ iyi a, ọ pụtara na ọgbụgba ndụ a maọbụ nkwa ahụ, ga-adịgide nʼagbụrụ Ebraham niile. Jenesis 47:29.\f* 
\v 3 Achọrọ m ka i jiri aha \nd Onyenwe anyị\nd* Chineke nke eluigwe na ụwa, ṅụọra m iyi, na ị gaghị achọtara nwa m nwoke nwunye site nʼetiti ndị Kenan, ndị m bi nʼetiti ha.  
\v 4 Kama na ị ga-aga nʼala nke m na ụmụnna m lụtara nwa m, bụ Aịzik, nwunye nʼetiti ụmụnna m.” 
\p  
\v 5 Ohu ahụ jụrụ ya, “Ọ bụrụkwanụ na nwaagbọghọ ahụ achọghị isoro m lọghachi nʼebe a, m ga-akpọrọ nwa gị nwoke laghachi nʼobodo i si bịa?” 
\p  
\v 6 Ebraham sịrị ya, “Lezie anya hụ na ị kpọghachighị nwa m nwoke nʼebe ahụ.  
\v 7 \nd Onyenwe anyị\nd*, Chineke nke eluigwe, bụ onye kpọpụtara m site nʼụlọ nna m nakwa obodo nke aka m, onye ahụ gwara m okwu ma kwem nkwa site nʼịṅụ iyi nye sị, ‘Aga m enye ụmụ ụmụ gị ala a.’ Ọ ga-ezipụ mmụọ ozi ya ka ọ gaa nʼihu gị ka i nwee ike inwetara nwa m nwoke nwunye site nʼebe ahụ.  
\v 8 Ma ọ bụrụ na nwanyị ahụ achọghị isoro gị lọghachi, mgbe ahụ, ị ga-abụ onye nwere onwe ya pụọ nʼiyi a ị ṅụrụ. Naanị na ị gaghị eme ka nwa m nwoke laghachi nʼebe ahụ.”  
\v 9 Ya mere, ohu ahụ tinyere aka ya nʼokpuru apata nna ya ukwu Ebraham, ṅụọ iyi banyere okwu ndị a. 
\p  
\v 10 Emesịa, ohu a duuru ịnyịnya kamel iri nʼime ndị nna ya ukwu nwere pụọ. O sitekwara nʼaka nna ya ukwu were ihe ọma dị iche iche maka njem a, gawa Aram Naharaim, rute nʼobodo Nahọ.  
\v 11 O mere ka ịnyịnya kamel ndị ahụ makpuru ala nʼakụkụ olulu mmiri dị nʼazụ obodo ahụ. Ọ bụ nʼoge anyasị, oge ụmụ nwanyị ji apụta iseta mmiri nʼebe ahụ. 
\p  
\v 12 Mgbe ahụ, o kpere ekpere sị, “\nd Onyenwe anyị\nd*, Chineke nke nna m ukwu Ebraham, mee ka ihe gaara m nke ọma taa. Gosi nna m ukwu Ebraham obi ebere gị.  
\v 13 Lee, ana m eguzo nʼakụkụ isi iyi mmiri a, ụmụ nwanyị ndị obodo a na-abịa iseta mmiri.  
\v 14 Kwere ka o si otu a dịrị na nwaagbọghọ nke m ga-asị, ‘Biko, zie ite gị ka m ṅụrụ mmiri.’ Ọ bụrụ na onye ahụ asị m, ‘Ṅụọ, aga m ekutekwa mmiri nke ịnyịnya kamel gị ga-aṅụ,’ ka onye ahụ bụrụ onye ị họpụtara ohu gị Aịzik. Nʼụzọ dị otu a ka m ga-esi mata na i gosila nna m ukwu obi ebere.” 
\p  
\v 15 Tupu o kpechaa ekpere a, lekwa Ribeka ada Betuel, nwa nwoke Milka, onye bụ nwunye Nahọ, nwanne Ebraham. Ọ na-apụta bukwasị ite nʼubu ya.  
\v 16 Ọ bụ nwaagbọghọ mara mma nke ukwuu, onye na-amatabeghị nwoke, nke nwoke ọbụla na-edinabeghị. Ọ gara nʼolulu mmiri kujuo ite ya si nʼebe ahụ na-arịgopụta. 
\p  
\v 17 Ohu ahụ mere ngwangwa jekwuru ya sị ya, “Biko nyetụ m mmiri si nʼite mmiri gị.” 
\p  
\v 18 Ọ mere ngwangwa budata ite ahụ nʼaka ya, hulata ya si ya, “Ṅụọ, onyenwe m.” 
\p  
\v 19 Mgbe o nyechara ya mmiri, ọ sịrị, “Aga m ekutekwa mmiri nye ịnyịnya kamel gị ndị a ruo mgbe ha ṅụjuru afọ.”  
\v 20 Ngwangwa, ọ wụpụrụ mmiri dị nʼite ya nʼime ihe anụ ụlọ ji aṅụ mmiri, gbara ọsọ gaa kute mmiri ọzọ na-agbanye nʼime ihe ahụ. O kugidere mmiri tutu ruo mgbe ịnyịnya kamel ndị ahụ ṅụjuchara afọ.  
\v 21 Mgbe ihe ndị a na-eme, ohu ahụ gbara nkịtị na-ele ya anya ịchọpụta ma \nd Onyenwe anyị\nd* emeela ka ije ya bụrụ ihe gara nke ọma. 
\p  
\v 22 Mgbe ịnyịnya kamel ndị ahụ ṅụsịrị mmiri, nwoke ahụ wepụtara mgbanimi ọlaedo nke ọtụtụ ya bụ otu beka,\f + \fr 24:22 \ft Maọbụ, \fqa ọkara shekel\f* na mgbaaka ọlaedo abụọ nke ọtụtụ ha bụ shekel iri.  
\v 23 Ọ jụrụ ya sị, “Nwa onye ka ị bụ? Ohere ọ dị nʼụlọ nna gị ebe mụ na ịnyịnya kamel ndị a ga-anọ nʼabalị a?” 
\p  
\v 24 Ọ zara sị ya, “Abụ m nwa Betuel, nwa Milka nwunye Nahọ.”  
\v 25 Ọ sịkwara, “Anyị nwere nri anụ ụlọ, nweekwa ebe ị ga-edina nʼabalị a.” 
\p  
\v 26 Nwoke ahụ hulatara ala kpọọ isiala nye \nd Onyenwe anyị\nd*.  
\v 27 Kwuo sị, “Ngọzị dịrị \nd Onyenwe anyị\nd*, bụ Chineke nna m ukwu Ebraham, onye na-esitebeghị nʼebe nna m ukwu nọ wezuga ebere ya na ikwesi ntụkwasị obi ya. Ma banyere mụ onwe m, \nd Onyenwe anyị\nd* e duola m nʼije a, kpọrọ m rute nʼụlọ ndị ikwu nna m ukwu.” 
\p  
\v 28 Nwaagbọghọ ahụ gbalara gaa kọọrọ ndị ezinaụlọ nne ya ihe ndị a.  
\v 29 Ribeka nwere otu nwanne nwoke aha ya bụ Leban. Leban gbara ọsọ gbakwuje nwoke ahụ nʼisi iyi mmiri ahụ.  
\v 30 Mgbe ọ hụrụ mgbanimi, na mgbaaka ndị ahụ nwanne ya nwanyị yi nʼaka ya, ma nụkwa ihe Ribeka kwuru banyere ihe nwoke ahụ gwara ya, o jekwuru nwoke ahụ, hụ ya ka ya na ịnyịnya kamel ya guzo nʼakụkụ olulu mmiri.  
\v 31 Ọ sịrị ya, “Bịa, gị onye \nd Onyenwe anyị\nd* gọziri. Gịnị mere i ji guzo nʼebe a. Edozielara m gị ụlọ ebe ị ga-edina na ebe ịnyịnya kamel ndị a ga-anọ.” 
\p  
\v 32 Ya mere, nwoke ahụ gara nʼụlọ, ebe Leban nyere aka butukwaara ya ibu nke ịnyịnya kamel ndị ahụ bu. E wetara nri nye ịnyịnya kamel ndị ahụ, wetara ya mmiri nke ya na ndị ikom so ya ji saa ụkwụ ha.  
\v 33 E doziri ya ihe oriri, ma ọ zara sị, “Agaghị m eri ihe ọbụla tutu ruo mgbe m kwuru ihe m ji bịa.” 
\p Leban sịrị, “Ngwa, kwuonụ.” 
\p  
\v 34 Ya mere, ọ sịrị, “Abụ m ohu Ebraham.  
\v 35 \nd Onyenwe anyị\nd* agọziela nna m ukwu, mee ya ka ọ bụrụ ọgaranya. O nyela ya igwe atụrụ, na igwe ehi, na ọlaọcha na ọlaedo, na ọtụtụ ndị ohu nwoke na nwanyị, na ịnyịnya kamel, na ịnyịnya ibu.  
\v 36 Sera nwunye nna m ukwu mụtaara ya otu nwa nwoke mgbe o merela agadi. Ihe niile nna m ukwu nwere ka o nyefere nwa ahụ nʼaka.  
\v 37 Nna m ukwu mere ka m ṅụọra ya iyi sị, ‘Ị gaghị esite nʼetiti ụmụ ndị inyom Kenan ndị anyị bi nʼala ha lụtara nwa m nwoke nwunye.  
\v 38 Kama ị ga-aga nʼezinaụlọ nna m, na nke ndị ikwu m chọtara nwa m nwoke nwunye.’ 
\p  
\v 39 “Mgbe ahụ, ajụrụ m nna m ukwu, ‘Ọ bụrụkwanụ na nwanyị ahụ ekweghị iso m lọghachi?’ 
\p  
\v 40 “Ọ sịrị, ‘\nd Onyenwe anyị\nd*, onye m na-ejegharị nʼihu ya, ga-eziga mmụọ ozi ya ka o soro gị gaa ime ka ije gị nwee isi, ka i nwee ike chọtara nwa m nwoke nwanyị site nʼetiti ndị ikwu m na ezinaụlọ nna m.  
\v 41 Ị ga-abụ onye nwere onwe gị site nʼiyi ị ṅụrụ ma ọ bụrụ na mgbe i gakwuru ndị ikwu m, ha jụrụ ịkpọnye gị nwanyị ahụ. Ị ga-abụ onye nwere onwe gị site nʼiyi ị ṅụrụ m.’ 
\p  
\v 42 “Mgbe m rutere nʼisi iyi mmiri taa, ekwuru m sị, ‘\nd Onyenwe anyị\nd* Chineke nna m ukwu Ebraham, ọ bụrụ na ọ masị gị, biko mee ka ije a m bịara bụrụ nke ga-aga nke ọma.  
\v 43 Lee, ka m na-eguzo nʼakụkụ isi iyi mmiri a, ka nwaagbọghọ ahụ bịara ikuru mmiri nke m ga-asị, “Biko kwere ka m si nʼite gị ṅụrụtụ ntakịrị mmiri,”  
\v 44 ma ọ bụrụ na ọ sị m, “Ṅụọ, aga m ekutekwa mmiri nye ịnyịnya kamel gị ndị a,” ka onye dị otu a bụrụ nwanyị ahụ \nd Onyenwe anyị\nd* chọtaara Aịzik nwa nna m ukwu.’ 
\p  
\v 45 “Tupu m kpesịa ekpere a nʼobi m, lekwa Ribeka ka o bụ ite mmiri ya nʼubu ya na-abịa. Ọ gbadara nʼisi iyi mmiri ahụ kute mmiri. Asịrị m ya, ‘Biko nye m mmiri ka m ṅụọ.’ 
\p  
\v 46 “Ngwangwa, o sitere nʼubu ya budata ite, sị m, ‘Ṅụọ, aga m ekutekwa mmiri nke ịnyịnya kamel ndị a ga-aṅụ.’ Ya mere, aṅụrụ m, o nyekwara ịnyịnya kamel m ndị ahụ mmiri ha ṅụrụ. 
\p  
\v 47 “Mgbe ahụ, ajụrụ m ya, ‘Nwa onye ka ị bụ?’ 
\p “Ọ sịrị m, ‘Abụ m nwa Betuel onye bụ nwa Nahọ nke Milka mụtaara ya.’ 
\p “Mgbe ahụ etinyere m ya mgbanimi ahụ nʼimi ya, tinyekwa ọlaaka ahụ nʼaka ya abụọ.  
\v 48 Ehulatara m ala kpọọ isiala nye \nd Onyenwe anyị\nd*. Etoro m \nd Onyenwe anyị\nd*, Chineke nke nna m ukwu Ebraham, onye duru m nʼezi ụzọ inweta nwa nwanne nna m ukwu dịka nwunye nwa ya nwoke.  
\v 49 Ugbu a, ọ bụrụ na unu ga-egosi nna m ukwu obiọma na ikwesi ntụkwasị obi gwanụ m. Ọ bụrụkwanụ na ọ gaghị esi otu a dịrị, gwanụ m ka m mata ụzọ m ga-agbaso.” 
\p  
\v 50 Leban na Betuel zara sị ya, “Ihe niile si nʼaka \nd Onyenwe anyị\nd*. Anyị enweghị ike ịgwa gị okwu ọjọọ maọbụ nke ọma.  
\v 51 Lee Ribeka, kpọrọ ya laa, ka ọ bụrụ nwunye nwa nna gị ukwu, dịka \nd Onyenwe anyị\nd* kwuru.” 
\p  
\v 52 Mgbe ohu Ebraham nụrụ ihe ha kwuru, ọ dara nʼala kpọọ isiala nye \nd Onyenwe anyị\nd*.  
\v 53 Mgbe ahụ kwa, ohu ahụ wepụtara ihe ịchọ mma ọlaedo, na ọlaọcha dị iche iche na uwe nye ha Ribeka. Ọ wepụtakwara onyinye ndị ọzọ dị oke ọnụahịa nye nwanne ya nwoke na nne ya.  
\v 54 Emesịa, mgbe ihe ndị a gasịrị, ya na ndị ikom so ya riri, ṅụọ, dinaakwa nʼabalị ahụ. 
\p Mgbe ha si nʼụra teta, o kwuru sị, “Zilaga m ka m lakwuru nna m ukwu.” 
\p  
\v 55 Ma Leban na nne ya zara sị ya, “Ka nwantakịrị nwanyị a nọnyere anyị ihe dịka ụbọchị iri tupu o soro gị laa.” 
\p  
\v 56 Ma ọ zara ha sị, “Unu egbochila anyị. Ebe ọ bụ na \nd Onyenwe anyị\nd* emeela ka ije m bụrụ ihe gara nke ọma, zilaga m ka m laghachikwuru nna m ukwu.” 
\p  
\v 57 Ha zara sị ya, “Ka anyị kpọọ nwantakịrị nwanyị ahụ jụọ ya ihe bụ uche ya.”  
\v 58 Ya mere ha kpọrọ Ribeka jụọ ya sị, “Ị ga-eso nwoke a gaa?” 
\p Ọ zara sị, “E, aga m aga.” 
\p  
\v 59 Ya mere, ha zipụrụ nwanne ha nwanyị Ribeka, tinyere nwanyị lekọtara ya anya mgbe ọ dị na nwantakịrị, na ohu Ebraham na ndị ikom so ya.  
\v 60 Ha gọziri Ribeka sị ya, 
\q1 “Nwanne anyị nwanyị mụọ ọmụmụ, 
\q2 mụruo puku kwụrụ puku, 
\q1 ka mkpụrụ afọ gị nwetara onwe ha, 
\q2 ọnụ ụzọ ama ndị iro ha.” 
\p  
\v 61 Ribeka biliri, ya na ndị inyom na-ejere ya ozi, ha rigoro nʼelu ịnyịnya kamel ndị ahụ, soro nwoke ahụ. Ya mere, ohu ahụ duuru Ribeka laa. 
\p  
\v 62 Nʼoge a, Aịzik bịara nʼebe mbata obodo Bịa-Lahai-Rọị nʼihi na o bi na Negev.  
\v 63 Aịzik pụtara ịtụgharị uche nʼọhịa nʼoge uhuruchi. Ọ lepụrụ anya hụ ọtụtụ ịnyịnya kamel na-abịanụ.  
\v 64 Ribeka nʼonwe ya lepụkwara anya hụ Aịzik. O sitere nʼelu ịnyịnya kamel rịdata,  
\v 65 jụọ ohu ahụ sị, “Onye bụ nwoke a si nʼọhịa na-abịa izute anyị?” 
\p Ohu ahụ zara sị ya, “Ọ bụ nna m ukwu” Nʼihi nke a, Ribeka weere akwa mkpudo ya kpuchie ihu ya. 
\p  
\v 66 Ohu ahụ kọọrọ Aịzik akụkọ otu ije ya niile si gaa.  
\v 67 Aịzik kpọbatara Ribeka nʼụlọ ikwu Sera,\f + \fr 24:67 \ft Cheta nʼoge a, Sera a nwụọlarị afọ atọ gara aga. \xt Jen 17:17; 23:1; 25:20\f* nne ya. Ọ lụrụ Ribeka, onye ghọrọ nwunye ya. Aịzik hụrụ ya nʼanya, ma nweta nkasiobi nʼihi ọnwụ nne ya. 
\c 25  
\s1 Ọnwụ Ebraham 
\p  
\v 1 Ebraham lụrụ nwunye ọzọ, onye aha ya bụ Ketura.  
\v 2 Ọ mụụrụ ya Zimran, Jokshan, Medan, Midian, Ishbak na Shua.  
\v 3 Jokshan bụ nna Sheba na Dedan. Ụmụ ndị ikom Dedan bụ Ashurim, Letushim, na Leumim.  
\v 4 Ụmụ ndị ikom Midian bụ Efaa, Efe, Hanok, Abida, na Eldaa. Ndị a niile bụ ụmụ Ketura. 
\p  
\v 5 Ebraham nyere Aịzik ihe niile o nwere.  
\v 6 Ebraham nyere ụmụ ndị ikom ndị iko ya nwanyị mụtara onyinye dị iche iche, zipụ ha nʼala dị nʼebe ọwụwa anyanwụ, mgbe ọ ka nọ ndụ, ka ha ghara ịnọ nwa ya nwoke Aịzik nso. 
\p  
\v 7 Ebraham dị ndụ ruo narị afọ na iri afọ asaa na ise.  
\v 8 Ebraham kubiri ume ndụ nwụọ mgbe o mere nnọọ ezigbo agadi, agadi nwoke nke ndụ juru afọ, e mere ka ọ lakwuru ndị ya.  
\v 9 Ụmụ ya, Aịzik na Ishmel, liri ya nʼọgba Makipela nʼakụkụ Mamre, nʼala ubi Efrọn nwa Zoha onye Het,  
\v 10 ala ahụ Ebraham zụrụ site nʼaka ndị Het. Ebe ahụ ka e liri Ebraham ya na Sera nwunye ya.  
\v 11 Mgbe Ebraham nwụrụ, Chineke gọziri nwa ya nwoke Aịzik onye bi nʼoge ahụ na nso nso Bịa-Lahai-Rọị. 
\s1 Ụmụ ụmụ Ishmel 
\p  
\v 12 Nke a bụ akụkọ banyere usoro ezinaụlọ Ishmel nwa Ebraham onye Hega, nwanyị Ijipt ahụ na-ejere Sera ozi mụụrụ ya. 
\b  
\li4  
\v 13 Ndị a bụ aha ụmụ ndị ikom Ishmel nʼusoro ọmụmụ ha. 
\b  
\li1 Nebaiot bụ nwa mbụ ya. 
\li1 Ndị ọzọ bụ Keda, Adbel, Mibsam, 
\li1  
\v 14 Mishma, Duma, Masa, 
\li1  
\v 15 Hadad, Tema, Jetua, 
\li1 Nafish na Kedema. 
\b  
\li4  
\v 16 Ndị a bụ ụmụ Ishmel, ndị a bụkwa aha ndịisi ikwu iri na abụọ ha, dịka ebe obibi ha si dị, na dịka ọmụma ụlọ ikwu ha si dị. 
\b  
\p  
\v 17 Ishmel biri ndụ ruo narị afọ na iri afọ na asaa. Ọ nwụrụ, e mere ka ọ lakwuru ndị ya.  
\v 18 Ụmụ ụmụ ya bi nʼala dị site na Havila ruo Shua nso nso oke ala ndị Ijipt, nʼụzọ e si aga Ashọ. Ha na ụmụnna ha ndị ọzọ ebighị nʼudo. 
\s1 Jekọb na Ịsọ 
\p  
\v 19 Nke a bụ akụkọ banyere usoro agbụrụ Aịzik nwa Ebraham. 
\b  
\p Ebraham bụ nna Aịzik.  
\v 20 Aịzik gbara iri afọ anọ mgbe ọ lụrụ Ribeka, nwa Betuel, onye Aram si nʼobodo Padan Aram, nwanne Leban, onye Aram. 
\p  
\v 21 Aịzik kpere ekpere rịọọ \nd Onyenwe anyị\nd* ka o nye nwunye ya nwa nʼihi na ọ bụ nwanyị aga. \nd Onyenwe anyị\nd* zara ekpere ya. Nwunye ya, Ribeka dịịrị ime.  
\v 22 Ụmụ o bu nʼafọ bidoro na-alụ ọgụ nʼime afọ ya. Nʼihi nke a, o kwuru sị, “Gịnị mere ihe dị otu a ji eme m?” Ya mere, ọ gara jụta ase nʼaka \nd Onyenwe anyị\nd*. 
\p  
\v 23 \nd Onyenwe anyị\nd* gwara ya sị, 
\q1 “Mba abụọ dị gị nʼafọ, 
\q2 ụzọ mba abụọ dị nʼime gị ka a ga-ekewa. 
\q1 Otu ụzọ ga-adị ike karịa nke ọzọ, 
\q2 nke okenye ga-ejere nke nta ozi.” 
\p  
\v 24 Mgbe oge ime ya zuru, ụmụ abụọ dị nʼakpanwa ya.  
\v 25 Ahụ nwa nke mbụ buru ụzọ pụta na-acha uhie uhie, ahụ ya niile dịka uwe ajị. Nʼihi ya, ha kpọrọ aha ya Ịsọ.  
\v 26 Emesịa, nwanne ya pụtara, ma aka ya jidere ikiri ụkwụ Ịsọ. Nʼihi ya, a kpọrọ aha ya Jekọb. Aịzik gbara iri afọ isii mgbe Ribeka mụrụ ha. 
\p  
\v 27 Ha abụọ toro, Ịsọ ghọrọ onye ọka nʼịchụ nta, onye na-epiogharị nʼọhịa, ebe Jekọb bụ nwoke dị nwayọọ, onye na-anọ nʼetiti ụlọ ikwu.  
\v 28 Aịzik hụrụ Ịsọ nʼanya nʼihi na ụtọ anụ Ịsọ na-egbute nʼọhịa na-adị ya mma, ma Ribeka hụrụ Jekọb nʼanya. 
\s1 Ịsọ eree ọnọdụ ọkpara ya 
\p  
\v 29 Otu ụbọchị, Jekọb nọ na-esi ofe mgbe Ịsọ si nʼọhịa bata. Agụụ na-agụkwa ya nke ukwuu.  
\v 30 Ịsọ rịọrọ Jekọb sị, “Nyetụ m ụfọdụ nʼime nri a na-acha uhie uhie ị na-esi ka m rie, nʼihi na agụụ na-agụ m hie nne.” (Ọ bụ ihe a mere e ji na-akpọ ya Edọm.\f + \fr 25:30 \ft Edọm pụtara uhie.\f*) 
\p  
\v 31 Ma Jekọb zara ya, “Buru ụzọ resi m ọnọdụ ịbụ ọkpara gị.” 
\p  
\v 32 Ịsọ sịrị, “Gịnị bụ uru ọnọdụ ịbụ ọkpara bara mgbe m na-anwụ nʼagụụ?” 
\p  
\v 33 Jekọb sịrị ya, “Buru ụzọ ṅụọrọ m iyi.” Ya mere, ọ ṅụụrụ ya iyi, sị otu a resi Jekọb ọnọdụ ọkpara ya. 
\p  
\v 34 Mgbe ahụ, Jekọb nyere Ịsọ achịcha na ofe lentil o siri. O riri, ṅụọkwa, bilie ọtọ pụọ. 
\p Ya mere Ịsọ ledara ọnọdụ ịbụ ọkpara nna ya anya. 
\c 26  
\s1 Abimelek na Aịzik 
\p  
\v 1 Nʼoge a, ụnwụ dara nʼala ahụ. Ụnwụ a dị iche nʼụnwụ mbụ nke dara nʼoge Ebraham dị ndụ. Aịzik jekwuru Abimelek\f + \fr 26:1 \ft Abimelek, bụ aha ndịisi na-achị obodo a na-aza. Abimelek nke anyị nụrụ ihe banyere ya nʼakwụkwọ Jenesis isi 20, a nwụọlarị. Ọ nwụrụ ihe dịka iri afọ asatọ gara aga. Onye nke a bụ eze ọzọ.\f* eze ndị Filistia nʼobodo Gera.  
\v 2 \nd Onyenwe anyị\nd* gosiri Aịzik onwe ya, sị, “Agakwala Ijipt; biri nʼala ahụ m sị gị biri nʼime ya.  
\v 3 Nọrọ nʼala a nwa oge nta, aga m anọnyere gị ma gọziekwa gị, nʼihi na gị na ụmụ ụmụ gị ka m ga-enye ala ndị a niile. Aga m emezukwa iyi ahụ m ṅụrụ nye Ebraham nna gị.  
\v 4 Aga m eme ka ụmụ ụmụ gị mụbaa, mee ka ha hie nne nʼọnụọgụgụ dịka kpakpando dị na mbara eluigwe. Ha ka m ga-enye ala ndị a niile. Aga m esite na mkpụrụ gị gọzie mba niile nke ụwa.  
\v 5 Ihe ndị a niile ka m ga-eme nʼihi na Ebraham rubere isi ime ihe m gwara ya, na idebe iwu m na ụkpụrụ m, na ịdọ aka na ntị m.”  
\v 6 Ya mere, Aịzik nọgidere nʼobodo Gera. 
\p  
\v 7 Mgbe ndị obodo ahụ jụrụ ya banyere nwunye ya, ọ gwara ha sị, “Ọ bụ nwanne m nwanyị.” Ọ tụrụ ụjọ ị sị ha, “Nwunye m ka ọ bụ,” O chere nʼobi ya sị, “Ndị ikom obodo a nwere ike gbuo m nʼihi Ribeka. Nʼihi na Ribeka nʼonwe ya mara mma ile anya.” 
\p  
\v 8 Mgbe Aịzik nọrọ ebe ahụ ogologo oge, Abimelek eze ndị Filistia, sitere na oghereikuku ya lepụ anya hụ Aịzik ka ọ nọ na-egwusa Ribeka nwunye ya egwu.  
\v 9 Ya mere, Abimelek kpọrọ Aịzik sị, “Nwunye gị ka ọ bụ nʼezie. Gịnị mere i ji gwa anyị na ọ bụ nwanne gị nwanyị?” 
\p Aịzik zara ya, “Ọ bụ nʼihi na m chere na-enwere ike igbu m nʼihi ya.” 
\p  
\v 10 Abimelek sịrị, “Gịnị bụ ihe a i mere anyị? Otu nwoke nʼetiti anyị gaara akpọrọ nwunye gị dinaa ya. Ị gaara esi otu a wetara anyị ikpe ọmụma.” 
\p  
\v 11 Ya mere, Abimelek nyere ndị niile ya iwu, sị ha, “Onye ọbụla metụrụ nwoke a maọbụ nwunye ya aka, aghaghị ime ka ọ nwụọ.” 
\p  
\v 12 Aịzik kụrụ mkpụrụ ubi nʼala ahụ. Nʼotu afọ ahụ kwa, o si nʼala ahụ webata ihe ubi narị okpukpu karịa nke ọ kụrụ, nʼihi na \nd Onyenwe anyị\nd* gọziri ya.  
\v 13 Nwoke a bara ụba, ghọọ ọgaranya. Akụnụba ya gara nʼihu na-amụba, tutu ruo mgbe ọ ghọrọ nnọọ onye ọgaranya a ma ama.  
\v 14 O nwere ọtụtụ igwe anụ ụlọ, na igwe ehi, na ndị ikom na-ejere ya ozi. Nʼihi ihe ndị a, ndị Filistia bidoro inwe anya ukwu megide ya.  
\v 15 Ndị Filistia wụjuru aja nʼolulu mmiri ndị ahụ niile ndị na-ejere nna ya ozi gwuru nʼoge nna ya Ebraham dị ndụ. 
\p  
\v 16 Abimelek kpọrọ Aịzik sị ya, “Si nʼala a kwapụ gaa nʼebe ọzọ, nʼihi na ịba ụba gị na ịdị ike gị adịla ukwuu karịa nke anyị.” 
\p  
\v 17 Ya mere Aịzik si nʼebe ahụ kwapụ, gaa maa ụlọ ikwu ya na Ndagwurugwu Gera, biri nʼebe ahụ.  
\v 18 O gwugharịkwara olulu mmiri ndị ahụ e gwuru nʼoge nna ya Ebraham, nke ndị Filistia kpojuru aja mgbe Ebraham nwụrụ, kpọọ olulu mmiri ndị a otu aha ahụ nna ya kpọrọ ha na mbụ. 
\p  
\v 19 Ọzọ, ndị na-ejere Aịzik ozi gwuru olulu mmiri ọhụrụ na ndagwurugwu Gera ahụ, gwute mmiri nke si nʼala na-asọpụta.  
\v 20 Ma ndị ọzụzụ anụ ụlọ obodo Gera sesịrị ndị ọzụzụ anụ ụlọ Aịzik okwu. Ha kwuru sị, “Mmiri a bụ nke anyị!” Nke a mere Aịzik ji kpọọ olulu mmiri ahụ Esek, nʼihi ise okwu nke ha sesịrị ya.  
\v 21 Ha gwuru olulu mmiri ọzọ, ma ndị ahụ bịakwara ọzọ bido ịzọ ya. Nʼihi ya Aịzik kpọrọ olulu mmiri ahụ Sitna.  
\v 22 O si nʼebe ahụ pụọ gaa nʼebe ọzọ gwuo olulu mmiri ọzọ. Ma o nweghị ndị bịara zọọ ya. Nʼihi ya ọ kpọrọ olulu mmiri ahụ Rehobọt. O kwuru sị, “Ugbu a, \nd Onyenwe anyị\nd* enyela anyị ebe sara mbara, ebe ihe ga-anọ gaara anyị nke ọma.” 
\p  
\v 23 O sitere nʼebe ahụ kwapụ gaa Bịasheba.  
\v 24 Nʼabalị ahụ, \nd Onyenwe anyị\nd* mere ka ọ hụ ya anya, sị ya, “Abụ m Chineke nna gị Ebraham. Atụla egwu, nʼihi na anọnyere m gị, aga m agọzi gị, mụbaa ọnụọgụgụ ụmụ ụmụ gị nʼihi ohu m Ebraham.” 
\p  
\v 25 Ya mere, o wuru ebe ịchụ aja nʼebe ahụ kpọkuo aha \nd Onyenwe anyị\nd*. Ọ makwara ụlọ ikwu ya nʼebe ahụ. Ndị na-ejere ya ozi gwukwara olulu mmiri. 
\s1 Ọgbụgba ndụ Aịzik na Abimelek 
\p  
\v 26 Abimelek na Ahuzat, onye ndụmọdụ ya, na Fikọl onyeisi ndị agha ya sitere Gera jekwuru Aịzik.  
\v 27 Aịzik jụrụ ha sị, “Gịnị mere unu ji bịakwute m, ebe ọ bụ na unu kpọrọ m asị, chụpụkwa m site nʼetiti unu?” 
\p  
\v 28 Ha sị, “Anyị hụrụ nke ọma na \nd Onyenwe anyị\nd* nọnyeere gị, ya mere anyị ji sị, ‘O kwesiri ka ịṅụ iyi dị nʼetiti anyị na gị,’ ka anyị na gị gbaakwa ndụ  
\v 29 na ị gaghị eme anyị ihe ọjọọ dịka anyị na-esighị mee gị ihe ọjọọ. I lezie anya nke ọma, ị ga-ahụ na anyị meere gị ihe ọma mgbe anyị hapụrụ gị ka ị laa nʼudo. Ugbu a, anyị maara na ị bụ onye \nd Onyenwe anyị\nd* gọziri agọzi.” 
\p  
\v 30 Aịzik meere ha mmemme nri dị ukwuu; ha riri, ṅụọkwa.  
\v 31 Nʼisi ụtụtụ echi ya, ndị ikom ahụ niile ṅụrịtaara onwe ha iyi ịgba ndụ. Aịzik zilagara ha, ha hapụrụ ya laa nʼudo. 
\p  
\v 32 Nʼotu ụbọchị ahụ kwa, ndị ohu Aịzik bịakwutere ya gwa ya banyere olulu mmiri ha na-egwu, sị ya, “Anyị achọtala mmiri nʼolulu ahụ anyị na-egwu.”  
\v 33 Ọ kpọrọ ya Shiba. Ọ bụkwa nke a mere e ji akpọ obodo ahụ Bịasheba\f + \fr 26:33 \ft Nke a pụtara \fqa Olulu mmiri ịṅụ iyi\f* ruo taa. 
\s1 Ndị inyom Ịsọ lụrụ 
\p  
\v 34 Mgbe Ịsọ gbara iri afọ anọ, ọ lụrụ Judit nwa Beiri, onye Het. Ọ lụkwara Basemat nwa Elọn, onye Het.  
\v 35 Ha ghọrọ Aịzik na Ribeka ihe ọnọdụ obi ilu. 
\c 27  
\p  
\v 1 Mgbe Aịzik ghọrọ agadi, nʼoge anya ya na-adịghị ahụzi ụzọ nke ọma, ọ kpọrọ Ịsọ ọkpara ya, sị ya, “Nwa m nwoke.” 
\p Ọ zara sị, “Lee m nʼebe a.” 
\p  
\v 2 Aịzik gwara ya sị, “Ugbu a, emeela m agadi, amakwaghị m ụbọchị ọnwụ m.  
\v 3 Ya mere, were ihe ịchụ nta gị, ụta gị na àkụ gị, gaa nʼọhịa, gbutere m anụ.  
\v 4 Siere m nri ụtọ otu ahụ o si amasị m, butere m ya ka m rie, ka mụ onwe m gọzie gị tupu m nwụọ.” 
\p  
\v 5 Ma Ribeka nọ na-ege ntị mgbe Aịzik na-agwa nwa ya Ịsọ okwu. Nke mere na mgbe Ịsọ gawara nʼọhịa ịchụ nta,  
\v 6 Ribeka gwara Jekọb nwa ya okwu sị ya, “Lee, anụrụ m ka nna gị na-agwa nwanne gị Ịsọ okwu sị ya,  
\v 7 ‘Gaa nʼọhịa gbute anụ, siere m nri ụtọ, ka m nọdụ nʼihu \nd Onyenwe anyị\nd* nye gị ngọzị ikpeazụ tupu m nwụọ.’  
\v 8 Ugbu a, nwa m nwoke, gee ntị nke ọma, mee ihe niile m gwara gị.  
\v 9 Gaa ugbu a nʼigwe anụ ụlọ wetara m ụmụ nwa ewu abụọ dị mma ka m jiri ha siere nna gị nri dị ụtọ, ụdị ahụ na-amasị ya.  
\v 10 Ị ga-eburu ya bujere nna gị ka o rie, ka ya onwe ya gọzie gị tupu ọ nwụọ.” 
\p  
\v 11 Ma Jekọb gwara Ribeka nne ya okwu sị ya, “Nwanne m nwoke Ịsọ bụ onye gbara ajị. Ahụ nke m na-akwọ mụrụmụrụ.  
\v 12 Gịnị ga-eme ma nna m metụ m aka nʼahụ? Nʼihi ya, aga m abụ onye na-aghọ ya aghụghọ, aga m esi otu a wetara onwe m ịbụ ọnụ kama ngọzị.” 
\p  
\v 13 Nne ya gwara ya sị, “Nwa m nwoke ka ọbụbụ ọnụ gị dakwasị m. Naanị mee ihe m kwuru. Gaa wetara m ha.” 
\p  
\v 14 Ya mere, ọ gara weta ha nye nne ya. O ji ha sie nri dị ụtọ, ụdị nke na-amasị nna ya.  
\v 15 Emesịa, Ribeka chịpụtara uwe Ịsọ ọkpara ya, ndị dị mma, ndị ọ debere nʼụlọ ya, nye ya nwa ya nta bụ Jekọb.  
\v 16 O jikwa akpụkpọ anụ ụmụ ewu nwere ajị ajị kee Jekọb nʼaka na nʼakụkụ olu ya na-akwọ mụrụmụrụ.\f + \fr 27:16 \ft Ya bụ ebe ajị nʼadịghị\f* 
\v 17 O bunyere nwa ya nwoke Jekọb nri ahụ na-atọ ụtọ, na achịcha o mere. 
\p  
\v 18 O jekwuuru nna ya sị ya, “Nna m.” 
\p Ọ zara sị, “Ahaa, nwa m, onye ka ị bụ?” 
\p  
\v 19 Jekọb zara nna ya sị ya, “Abụ m Ịsọ, ọkpara gị. Emeela m ihe ị sị m mee. Biko bilie ka i rie anụ m gbutere nʼọhịa, ka gị onwe gị gọzie m.” 
\p  
\v 20 Ma Aịzik jụrụ nwa ya nwoke sị, “Olee otu i si chọta ya ngwangwa, nwa m?” 
\p Jekọb zara ya sị, “Ọ bụ \nd Onyenwe anyị\nd* Chineke gị mere ka ihe gaara m nke ọma.” 
\p  
\v 21 Mgbe ahụ Aịzik gwara Jekọb sị, “Bịa nso ka m metụ gị aka nwa m nwoke, ka m mata ma ị bụ Ịsọ nʼeziokwu.” 
\p  
\v 22 Jekọb jere nna ya Aịzik nso, onye metụrụ ya aka kwuo sị, “Olu bụ olu Jekọb ma aka gị bụ aka Ịsọ.”  
\v 23 Ọ chọpụtaghị na ọ bụ Jekọb, nʼihi na aka ya dị ajị ajị dịka nke Ịsọ. Ya mere, ọ gọziri ya.  
\v 24 Ma ọ jụkwara ya ajụjụ ọzọ sị ya, “Ị bụ nwa m nwoke Ịsọ nʼeziokwu?” 
\p Jekọb zara sị ya, “E, abụ m ya.” 
\p  
\v 25 Mgbe ahụ, Aịzik zara sị ya, “Butere m ụfọdụ nʼime anụ ahụ i gbutere ka m rie, nye gị ngọzị m.” 
\p Jekọb butere ya bunye ya. O riri ya.  
\v 26 Mgbe ahụ, nna ya Aịzik sịrị ya, “Bịa nʼebe a nwa m nwoke, sutu m ọnụ.” 
\p  
\v 27 Ya mere, o jekwuuru ya sutu ya ọnụ. Mgbe Aịzik nụrụ isisi uwe ya, ọ gọziri ya, sị, 
\q1 “Nʼezie, isisi nwa m nwoke 
\q2 dịka isisi ala ubi 
\q2 nke \nd Onyenwe anyị\nd* gọziri. 
\q1  
\v 28 Ka Chineke nye gị site nʼigirigi nke eluigwe, 
\q2 na mmanụ nke ala, 
\q2 ụba nke mkpụrụ ubi na mmanya ọhụrụ 
\q1  
\v 29 Ka ọtụtụ mba jeere gị ozi, 
\q2 ka ndị mmadụ kpọọ isiala nye gị. 
\q1 Bụrụ onye ọchịchị nʼebe ụmụnna gị nọ, 
\q2 ka ụmụ nne gị mụrụ kpọọ isiala nye gị. 
\q1 Ka ndị niile na-abụ gị ọnụ bụrụ ndị a bụrụ ọnụ, 
\q2 ka ndị na-agọzi gị bụrụ ndị a gọziri agọzi.” 
\s1 Ịsọ arịọọ ka a gọzie ya 
\p  
\v 30 Mgbe Aịzik gọzichara Jekọb, ka Jekọb si nʼihu ya na-apụ, lee Ịsọ ka o si ịchụ nta na-alọbata.  
\v 31 Ya onwe ya sikwara nri na-atọ ụtọ butere nna ya. Mgbe ahụ, ọ gwara ya sị, “Ka nna m, bilie, rie anụ nwa ya si nʼọhịa gbute, ka gị onwe gị nye m ngọzị gị.” 
\p  
\v 32 Aịzik zara sị ya, “Ị bụ onye?” 
\p Ọ zara sị, “Abụ m nwa gị nwoke Ịsọ, ọkpara gị Ịsọ.” 
\p  
\v 33 Oke ahụ ọma jijiji mara Aịzik, ọ sị, “Onye kwanụ bụ onye ahụ gara gbute anụ butere m ya? Eriri m ya tupu ị bata. Agọziri m ya. Nʼezie, onye a gọziri agọzi ka ọ ga-abụ.” 
\p  
\v 34 Mgbe Ịsọ nụrụ okwu ndị a si nʼọnụ nna ya, o jiri oke olu kwaa akwa nke obi ilu gwa nna ya sị ya, “Gọzie m, mụ onwe m, nna m.” 
\p  
\v 35 Ma ọ zara sị ya, “Nwanne gị ejirila ụzọ aghụghọ bịa nara ngọzị gị.” 
\p  
\v 36 Ịsọ kwuru sị, “E meziri kpọọ ya Jekọb,\f + \fr 27:36 \fq Jekọb \ft pụtara \fqa onye aghụghọ maọbụ onye na-ewere ọnọdụ onye ọzọ nʼike.\f* onye aghụghọ. Lee, ọ ghọgbuola m ugboro abụọ. Nke mbụ, ọ naara m ọnọdụ ịbụ ọkpara m, ugbu a ọ narakwala m ngọzị m.” Ọ jụrụ ajụjụ sị, “Ọ bụ na i nweghị ngọzị ọ bụla fọdụrụ nke ị ga-agọzi m?” 
\p  
\v 37 Aịzik zara sị ya, “Emeela m ya ka ọ bụrụ onyeisi nʼebe ị nọ, mee ụmụnna ya niile ndị na-ejere ya ozi. Enyela m ya mkpụrụ ubi niile na mmanya ọhụrụ. Gịnị ọzọ ka m nwere ike imere gị, nwa m nwoke?” 
\p  
\v 38 Ịsọ jụrụ nna ya sị, “Nna m, ọ bụ naanị otu ngọzị ka i nwere? Gọziekwa m nna m!” Ịsọ kwara akwa nʼoke olu. 
\p  
\v 39 Nna ya Aịzik zara sị ya, 
\q1 “Ebe obibi\f + \fr 27:39 \ft Ala Edọm ebe ndị agbụrụ Ịsọ biri, bụ ala akọrọ, ala nkume nkume, nke na-adịghị emepụta nri nke ọma dị ka ala Kenan. \xt Jen 36:8; 2Ez 8:20\f* gị ga-adịpụ adịpụ, 
\q2 site nʼebe akụnụba nke ala dị, 
\q2 site nʼebe igirigi nke eluigwe dị. 
\q1  
\v 40 Nriju afọ gị ga-abụ site na mma agha, 
\q2 ị ga-ejekwara nwanne gị ozi. 
\q1 Ma mgbe i mesịrị nwere onwe gị, 
\q2 ị ga-atọpụ agbụ ya, 
\q2 site nʼolu gị.” 
\s1 Jekọb agbakwuru Leban 
\p  
\v 41 Ịsọ buru iro nʼobi megide Jekọb nʼihi ngọzị ahụ nna ya nyere ya. O kwuru nʼime onwe ya sị, “Oge a ga-eru ụjụ nʼihi nna m na-abịa nso, nʼoge ahụ aga m egbu nwanne m Jekọb.” 
\p  
\v 42 Mgbe a gwara Ribeka ihe nwa ya nwoke nke okenye bụ Ịsọ kwuru, o ziri kpọọ nwa ya nwoke nke nta bụ Jekọb sị ya, “Lee, Ịsọ nwanne gị na-akasị onwe ya obi site nʼechiche ọ na-eche igbu gị.  
\v 43 Nʼihi nke a, nwa m nwoke, mee ihe m gwara gị, gbapụ ọsọ ngwangwa, gbakwuru nwanne m Leban na Haran,  
\v 44 Nọdụ nʼebe ahụ ruo mgbe iwe nwanne gị ga-adajụ.  
\v 45 Mgbe nwanne gị kwụsịrị iwe iwe megide gị, mgbe o chefuru ihe i mere ya, aga m ezitere gị ozi ka ị lọta. Nʼihi gịnị ka m ga-eji gbara aka unu abụọ nʼotu ụbọchị.” 
\p  
\v 46 Mgbe ahụ Ribeka gara gwa Aịzik sị, “Ike ịdị ndụ agwụla m nʼihi ndị inyom Het ndị a. Ọ bụrụ na Jekọb esite nʼetiti ndị inyom ala a, site nʼetiti ndị inyom Het ndị a lụọ nwunye, mara na ọnwụ ga-akara m ịdị ndụ mma.” 
\c 28  
\p  
\v 1 Aịzik kpọrọ Jekọb gọzie ya, nye ya iwu sị ya, “Alụla nwunye site nʼala Kenan.  
\v 2 Kama bilie gaa Padan Aram nʼụlọ nna nne gị, Betuel, lụrụ nwunye site nʼụmụ ndị inyom Leban.  
\v 3 Ka Chineke Onye pụrụ ime ihe niile, gọzie gị, mee ka ị mịa mkpụrụ, mụbaa, ghọọ ọtụtụ mba.  
\v 4 Ka Chineke nye gị na ụmụ ụmụ gị ngọzị ahụ o kwere nkwa inye Ebraham. Ka i nweta ala a, nke i bi nʼime ya ugbu a dịka ọbịa, bụ ala ahụ Chineke kwere Ebraham na nkwa inye ya.”  
\v 5 Mgbe ahụ Aịzik zipụrụ Jekọb nʼije ya, ọ gara Padan Aram, nʼụlọ Leban nwa Betuel onye Aram, nwanne Ribeka onye bụ nne Jekọb na Ịsọ. 
\p  
\v 6 Ịsọ hụrụ ka Aịzik siri gọzie Jekọb, ziga ya Padan Aram ka ọ gaa lụọ nwunye nʼebe ahụ, nyekwa ya iwu mgbe ọ na-agọzi ya sị, “Alụla nwanyị na Kenan,”  
\v 7 Jekọb rubekwara nna ya na nne ya isi gawa Padan Aram.  
\v 8 O dokwara Ịsọ anya na ndị inyom Kenan dị njọ nʼanya nna ya Aịzik.  
\v 9 Nʼihi ya, Ịsọ gakwuru Ishmel lụrụ Mahalat, ada Ishmel, nwa Ebraham, onye bụ nwanyị Nebaiot, tinyekwara ndị nwunye ọ lụrụ na mbụ. 
\s1 Nrọ Jekọb rọrọ na Betel 
\p  
\v 10 Jekọb hapụrụ Bịasheba gawa Haran.  
\v 11 Mgbe chi na-eji, ọ kwụsịrị ebe ọ ga-anọ zuo ike abalị. Mgbe ọ chọrọ idina ala, o weere otu nʼime nkume ndị dị nʼebe ahụ hinye nʼisi ya, dinara ala ịrahụ ụra.  
\v 12 Nʼabalị ahụ, ọ rọrọ nrọ, hụ mbube e ji arị elu. E mere ka o guzo site nʼụwa ruo nʼeluigwe. Ọ hụkwara ndị mmụọ ozi Chineke ka ha si na ya na-arịgo na-arịdakwa.  
\v 13 Nʼelu ya, ọ hụrụ \nd Onyenwe anyị\nd* ka o guzo, nụkwa ka ọ na-agwa ya okwu sị, “Mụ onwe m bụ \nd Onyenwe anyị\nd*, Chineke nna gị Ebraham, na Chineke Aịzik. Aga m enye gị na ụmụ ụmụ gị ala ahụ nke i dina nʼelu ya.  
\v 14 Ụmụ gị ga-adị ukwuu, dị ka aja dị nʼala. Ha ga-ejupụta ala a, site nʼọwụwa anyanwụ ruo nʼọdịda anyanwụ, sitekwa nʼugwu ruo na ndịda. A ga-esitekwa na gị na mkpụrụ gị, gọzie mba niile nke ụwa a.  
\v 15 Anọnyeere m gị. Aga m echebe gị ebe ọbụla ị na-aga. Aga m akpọghachite gị nʼala a. Agaghị m ahapụ gị tutu ruo mgbe m mezuoro gị ihe niile m kwere gị na nkwa.” 
\p  
\v 16 Jekọb tetara nʼụra sị, “Nʼezie \nd Onyenwe anyị\nd* nọ nʼebe a. Ma amaghị m ya.”  
\v 17 Ọ tụrụ egwu sị, “Lee ka ebe a si dị oke egwu, o nweghị ihe ebe a bụ karịa ụlọ Chineke, nʼezie ọ bụ ọnụ ụzọ ama eluigwe.” 
\p  
\v 18 Nʼisi ụtụtụ echi ya, Jekọb weere nkume ahụ o hinyere nʼisi ya guzo ya dịka ogidi, wụsa mmanụ nʼelu ya.  
\v 19 Ọ kpọrọ ebe ahụ Betel, ọ bụ ezie na Luz bụ aha obodo ahụ na mbụ. 
\p  
\v 20 Mgbe ahụ, Jekọb kwere nkwa sị, “Ọ bụrụ na Chineke ga-anọnyere m, chebe m nʼije m na-eje, ọ bụrụ na ọ ga-enye m ihe oriri m ga-eri na uwe m ga-eyi,  
\v 21 m lọghachi nʼụlọ nna m nʼudo, mgbe ahụ, \nd Onyenwe anyị\nd* ga-abụ Chineke m.  
\v 22 Nkume a m doziri elu dịka ogidi ga-abụ ụlọ Chineke. Aga m eke ihe niile i nyere m ụzọ iri, nyeghachi gị otu ụzọ.” 
\c 29  
\s1 Jekọb erute nʼụlọ Leban 
\p  
\v 1 Jekọb gara nʼihu nʼije ya rute nʼala dị nʼọwụwa anyanwụ.  
\v 2 NʼEbe Nsọ a, ọ hụrụ otu olulu mmiri, hụkwa ụzọ igwe atụrụ atọ ndị nọ nʼakụkụ olulu mmiri nʼihi na ndị na-elekọta ha na-enye ha mmiri site nʼolulu mmiri ahụ. Nkume e ji mechie ọnụ olulu mmiri ahụ buru ibu.  
\v 3 Nʼihi na mgbe igwe atụrụ niile bịazukọtara nʼolulu mmiri ahụ, ndị ọzụzụ atụrụ na-emeghepụ nkume ahụ nye ha mmiri. Emesịa, ha na-ejikwa nkume ahụ mechie ọnụ olulu mmiri ahụ. 
\p  
\v 4 Jekọb jekwuru ndị na-elekọta atụrụ ahụ jụọ ha sị, “Ụmụnna m, ebee ka unu si?” 
\p Ha zara sị ya, “Anyị si Haran.” 
\p  
\v 5 Ọ jụrụ ha sị, “Unu maara Leban, nwa Nahọ?” 
\p Ha zara sị, “Anyị ma ya.” 
\p  
\v 6 Ọzọ Jekọb jụrụ ha sị, “Ahụ ọ dịkwa ya mma?” 
\p Ha zara sị ya, “E, ahụ dị ya. Lee nwa ya nwanyị Rechel ka ọ chị atụrụ ya na-abịa.” 
\p  
\v 7 Jekọb kwuru sị, “Lee, anyanwụ ka na-acha. O rubeghị oge e ji achịbata igwe ụmụ anụ ụlọ. Nyenụ ha mmiri ka ha ṅụọ, ka ha laghachi gaa taa ahịhịa.” 
\p  
\v 8 Ha zara sị ya, “Anyị agaghị enye ha mmiri tutu ruo mgbe igwe atụrụ niile bịakọtara, mgbe e wepụrụ nkume e ji mechie ọnụ olulu mmiri, mgbe ahụ ka anyị ga-enye ha mmiri.” 
\p  
\v 9 Mgbe Jekọb na ndị ọzụzụ atụrụ ndị a kpụ okwu nʼọnụ, Rechel chịịrị atụrụ nna ya bịakwute ha, nʼihi na onye ọzụzụ atụrụ nwanyị ka ọ bụ.  
\v 10 Mgbe Jekọb hụrụ Rechel nwa Leban nwanne nne ya, hụkwa igwe atụrụ Leban, ọ meghepụrụ nkume ahụ e ji mechie ọnụ olulu mmiri ahụ nye igwe atụrụ Leban, nwanne nne ya mmiri ka ha ṅụọ.  
\v 11 Emesịa, Jekọb suturu Rechel ọnụ, kwaa akwa nʼoke olu.  
\v 12 Jekọb kọwaara Rechel na ọ bụ onye ikwu nna ya, bụrụkwa nwa Ribeka. Nʼihi ya Rechel ji ọsọ gbalaa nʼụlọ ha kọọrọ nna ya. 
\p  
\v 13 Mgbe Leban nụrụ maka Jekọb nwa nwanne ya nwanyị, o mere ngwangwa pụọ izute ya. Ọ makụrụ ya, sutu ya ọnụ, kpọrọ ya laa nʼụlọ. Nʼebe ahụ, Jekọb kọọrọ ya ihe ndị a niile.  
\v 14 Leban sịrị ya, “Nʼezie, ị bụ ọkpụkpụ m na anụ ahụ m.” 
\s1 Ije ozi Jekọb nʼihi Rechel na Lịa 
\p Ọ nọnyeere ya otu ọnwa.  
\v 15 Leban sịrị Jekọb, “Ọ bụ nʼihi na ị bụ onye ikwu m ka ị na-agbara m odibo nʼefu? Gwa m ego ole m ga-akwụ gị nʼihi ọrụ ị na-arụrụ m?” 
\p  
\v 16 Leban mụrụ ụmụ ndị inyom abụọ. Aha nke okenye bụ Lịa. Aha nke nta bụ Rechel.  
\v 17 Ịma mma Lịa dị ya nʼanya, ma Rechel mara mma nʼahụ, maakwa mma ile anya.  
\v 18 Ọ bụ Rechel ka Jekọb hụrụ nʼanya. Nʼihi ya Jekọb gwara Leban sị, “Aga m arụrụ gị ọrụ\f + \fr 29:18 \ft Onye ọbụla chọrọ ịlụ nwanyị na-akwụ nna nwaagbọghọ ahụ ego akụ, nʼisi ya. \xt Jen 34:12\ft  Ma ọ bụrụ na o nweghị ego ịkwụ ego akụ, ọ ga-arụrụ nna nwanyị ahụ ọrụ rụzuo ego ole, maọbụ afọ ole rụrụ ihe o kwesiri ịkwụ dịka ego akụ, nʼisi onye ahụ.\f* afọ asaa ma ọ bụrụ na ị ga-ekwe ka m lụọ Rechel.” 
\p  
\v 19 Leban zara Jekọb sị ya, “Ọ dị mma na ị lụrụ Rechel karịa na onye ọzọ ga-alụ ya. Soro m nọdụ nʼebe a.”  
\v 20 Ya mere Jekọb gbara odibo afọ asaa maka Rechel. Ma afọ asaa ndị a dịka abalị ole na ole nʼanya Jekọb nʼihi ịhụnanya o nwere nʼebe Rechel nọ. 
\p  
\v 21 Jekọb gwara Leban, okwu sị ya, “Kpọnye m nwunye m nʼihi nʼụbọchị m ezuola. Achọrọ m ịbakwuru ya.” 
\p  
\v 22 Leban kpọkọtara ndị niile bi nʼebe ahụ mere ha nʼoke oriri.  
\v 23 \f + \fr 29:23 \ft Ụmụ nwanyị a lụrụ alụ na-eji akwa mkpudo kpuchie ihu ha. \xt Jen 24:65\f*Nʼanyasị ụbọchị ahụ, Leban kpọọrọ nwa ya nwanyị bụ Lịa kpọbara Jekọb, ọ bakwuuru ya.  
\v 24 Leban nyekwara Lịa odibo ya, Zilpa, ka ọ bụrụ odibo nwanyị ya. 
\p  
\v 25 Mgbe chi bọrọ, Jekọb hụrụ na ọ bụ Lịa ka Leban kpọnyere ya. Jekọb sịrị Leban, “Gịnị bụ ihe a i mere m? Ọ bụghị nʼihi Rechel ka m ji gbaara gị odibo? Gịnị mere i ji ghọgbuo m?” 
\p  
\v 26 Leban zara sị ya, “Ọ bụghị omenaala anyị ibu ụzọ kee nwantakịrị nwanyị nke nta di tupu nke ada.  
\v 27 Otu ọ dị, chere ka mmemme izu ụka nke onye nke a gafee. Mgbe ahụ, aga m akpọnyekwa gị onye nke ọzọ a maka odibo ị ga-agbara m afọ asaa ọzọ.” 
\p  
\v 28 Jekọb mere ka o si kwuo. O debezuru mmemme otu izu ụka onye nke a, Leban kpọnyere ya nwa ya Rechel ka ọ bụrụ nwunye ya.  
\v 29 Leban nyere nwa ya nwanyị, Rechel, odibo ya nwanyị bụ Bilha, ka ọ bụrụ odibo ya.  
\v 30 Jekọb bakwukwara Rechel. Ọ hụrụ Rechel nʼanya nke ukwuu karịa Lịa. Ọ gbakwaara Leban odibo afọ asaa ọzọ. 
\s1 Ụmụ Jekọb 
\p  
\v 31 Mgbe \nd Onyenwe anyị\nd* hụrụ na Lịa bụ nwanyị a kpọrọ asị, o meghere akpanwa ya, ma Rechel bụ nwanyị aga.  
\v 32 Lịa tụrụ ime mụọ nwa nwoke, kpọọ ya Ruben. Nʼihi na o kwuru sị, “Ọ bụ nʼihi na \nd Onyenwe anyị\nd* ahụla nsogbu m, ugbu a di m ga-ahụ m nʼanya.” 
\p  
\v 33 Ọ tụụrụ ime ọzọ mụọkwa nwa nwoke. O kwuru sị, “\nd Onyenwe anyị\nd* anụla na m bụ nwanyị a kpọrọ asị, ọ bụ ya mere o ji nye m nwa nwoke ọzọ.” Ya mere ọ kpọrọ aha ya Simiọn. 
\p  
\v 34 Lịa tụrụ ime ọzọ, mgbe ọ mụrụ nwa nwoke, o kwuru sị, “Nʼezie, ugbu a ka di m ga-arapara m nʼahụ, nʼihi na amụọrala m ya ụmụ ndị ikom atọ.” Ya mere ọ kpọrọ aha ya Livayị. 
\p  
\v 35 Ọ tụụrụ ime ọzọ mụọ nwa nwoke. O kwuru sị, “Ugbu a aga m eto \nd Onyenwe anyị\nd*.” Ya mere, ọ kpọrọ aha ya Juda. Lịa mụsịrị nwa a kwụsị ịmụ ụmụ. 
\c 30  
\p  
\v 1 Rechel hụrụ na ya amụghị nwa ọbụla nye Jekọb, o kworo ekworo megide nwanne ya nwanyị. Ya mere, ọ sịrị Jekọb, “Nye m ụmụ. Ọ bụrụ na i meghị otu a, aga m anwụ.” 
\p  
\v 2 Jekọb were iwe megide Rechel, sị ya, “Abụ m Chineke onye gbochiri gị mkpụrụ nke afọ?” 
\p  
\v 3 \f + \fr 30:3 \ft Anyị hụrụ na omenaala a bụ nke sitere nʼala ndị si nʼakụkụ ọwụwa anyanwụ, nʼụlọ Ebraham. \xt Jen 16:2\ft  Ugbu a, Jekọb na-eme otu ihe ahụ.\f*Mgbe ahụ Rechel gwara Jekọb sị ya, “Lee odibo m nwanyị Bilha, bakwuru ya ka ọ mụọ nwa nʼikpere m abụọ, ka mụ onwe m site na ya bụrụkwa onye mụtara ụmụ.” 
\p  
\v 4 Rechel nyere Jekọb Bilha, odibo nwanyị ya, Jekọb bakwuuru ya.  
\v 5 Bilha tụụrụ ime mụọra Jekọb nwa nwoke.  
\v 6 Nke a mere ka Rechel kwuo sị, “Chineke ekpepụtala m. Ọ nụla arịrịọ m nye m nwa nwoke.” Nʼihi nke a, Rechel gụrụ nwa ahụ Dan. 
\p  
\v 7 Bilha, odibo nwanyị Rechel, tụụrụ ime ọzọ mụtara Jekọb nwa nwoke nke abụọ.  
\v 8 Rechel kwuru sị, “Mgba dị ukwuu ka mụ na nwanne m nwanyị gbara, m merie.” Ọ kpọọ ya Naftalị. 
\p  
\v 9 Lịa hụrụ na ya akwụsịla ịmụ nwa, ọ kpọọrọ Zilpa, odibo ya nwanyị kpọnye Jekọb ka ọ bụrụ nwunye ya.  
\v 10 Zilpa, odibo nwanyị Lịa, mụtara Jekọb nwa nwoke.  
\v 11 Mgbe nke a mere, Lịa kwuru sị, “Nke a bụ ihuọma.” Ọ kpọrọ nwa ahụ Gad. 
\p  
\v 12 Zilpa, odibo nwanyị Lịa mụtaara Jekọb nwa nwoke nke abụọ.  
\v 13 Mgbe ahụ Lịa kwuru sị, “Ọṅụ ejula m obi, nʼihi na ụmụ nwanyị ibe m ga-akpọ m onye ihe na-agara nke ọma.” Lịa kpọrọ nwantakịrị nwoke ahụ Asha. 
\p  
\v 14 Otu ụbọchị, nʼoge a na-aghọ ọka wiiti, Ruben nwa Lịa, gara nʼọhịa hụ ahịhịa a na-akpọ mandreki.\f + \fr 30:14 \ft Mandreki, bụ ahịhịa nke ụmụ mmadụ na-asị, na o nwere ọgwụ na-eweta mkpali ọchịchọ mmekọrịta nʼahụ mmadụ, na-emekwa ka nwanyị ọbụla tara ya tụrụ ime. \xt Abk 7:13\f* Ọ kụtaara nne ya ụfọdụ nʼime ahịhịa a. Mgbe Rechel hụrụ ahịhịa a, ọ rịọrọ Lịa sị ya, “Biko nyetụ m ụfọdụ nʼime mandreki ndị a nwa gị nwoke kụtara.” 
\p  
\v 15 Ma Lịa zara sị ya, “O zubeere gị na ị napụrụ m di m? Ị chọkwara ịnapụ m mandreki ndị a nwa m nwoke wetaara m?” 
\p Rechel zara Lịa sị, “Ọ dị mma, ka gị na ya dinaa nʼabalị a ka ọ bụrụ ihe mgbanwo maka mandreki nwa gị nwoke.” 
\p  
\v 16 Ya mere, mgbe Jekọb si nʼọhịa na-alọbata nʼuhuruchi ụbọchị ahụ, Lịa pụrụ izute ya, sị ya, “Ị ga-abakwute m nʼihi na m ejirila m ahịhịa mandreki nwa m nwoke m zụta gị.” Ha dinara nʼabalị ahụ. 
\p  
\v 17 Chineke nụrụ olu Lịa, ọ tụụrụ ime mụtara Jekọb nwa nwoke nke ise.  
\v 18 Lịa sịrị, “Chineke akwụọla m ụgwọ maka odibo m nwanyị m nyere di m.” Ya mere ọ kpọrọ aha ya Isaka. 
\p  
\v 19 Lịa tụkwaara ime ọzọ mụtara Jekọb nwa nwoke nke isii.  
\v 20 Ugbu a Lịa kwuru sị, “Chineke enyela m ezi onyinye dị oke ọnụ. Ugbu a, di m ga-eji nkwanye ugwu leta m nʼihi na amụọrala m ya ụmụ ndị ikom isii.” Ọ kpọrọ aha ya Zebụlọn. 
\p  
\v 21 Emesịa, Lịa mụrụ nwa nwanyị, kpọọ ya Daịna. 
\p  
\v 22 Chineke chetara Rechel. Ọ nụrụ olu ya, meghee akpanwa ya.  
\v 23 Nʼihi ya, Rechel tụụrụ ime mụta nwa nwoke. Ọ sịrị, “Chineke ewepụla nkọcha dịịrị m.”  
\v 24 Rechel kpọrọ aha ya Josef, dị ka ọ sịrị, “Ka \nd Onyenwe anyị\nd* nyekwa m nwa nwoke ọzọ.” 
\s1 Nkwekọrịta Jekọb na Leban 
\p  
\v 25 Mgbe Rechel mụsịrị Josef, Jekọb jekwuru Leban sị ya, “Zilaga m ka m laghachi nʼebe m na ala nke m.  
\v 26 Kpọnye m ndị nwunye m, ndị m ji nʼihi ha gbara gị odibo, ha na ụmụ m, ka m lakwaa. Ị maara otu m siri gbaara gị odibo. Kpọnye m ha ka m duru ha laghachi ebe m si bịa.” 
\p  
\v 27 Leban sịrị Jekọb, “Ọ bụrụ na m achọtala amara nʼihu gị biko nọdụ, nʼihi na esi m nʼịgba afa chọpụta na \nd Onyenwe anyị\nd* agọziela m nʼihi gị.”  
\v 28 Leban sịrị, “Kwuo ego ole ị chọrọ ka m kwụọ gị, aga m akwụ ya.” 
\p  
\v 29 Jekọb zara sị Leban, “Gị onwe gị maara otu m si gbara gị odibo na ihe mere igwe anụ ụlọ gị ndị m lekọtara.  
\v 30 Nʼihi na ole na ole ka i nwere mgbe m bịara, ma ugbu a, ha abaala ụba nke ukwuu. \nd Onyenwe anyị\nd* esitela nʼụkwụ m gọzie gị. Ugbu a, kedụ mgbe m ga-arụkwanụ ọrụ nke mụ onwe m maka ezinaụlọ m?” 
\p  
\v 31 Leban jụrụ Jekọb sị, “Kedụ ihe m ga-enye gị?” 
\p Jekọb gwara ya sị, “Enyela m ihe ọbụla, kama o nwere otu ihe m chọrọ ka i mee. Ọ bụrụ na i mee ya, aga m alaghachi ilekọta igwe anụ ụlọ gị.  
\v 32 Kwere ka m jegharịa nʼetiti igwe anụ ụlọ gị, ka m họpụta site nʼetiti igwe atụrụ gị ndị niile tụrụ agwa agwa, na ụmụ atụrụ niile dị oji, na ewu niile tụrụ agwa agwa. Atụrụ na ewu ndị a niile m ga-ahọpụta ga-abụ ụgwọ ọrụ m.  
\v 33 Ezi omume m ga-azara nʼọdịnihu, mgbe ọbụla ị bịara nyochaa ụgwọ ọrụ ị kwụrụ m. Ewu ọbụla na-atụghị agwa agwa, maọbụ atụrụ ọbụla na-ejighị oji ị chọpụtara nʼetiti igwe ewu na atụrụ nke m ka a ga-agụ dị ka ihe e zuru nʼohi.” 
\p  
\v 34 Leban zara sị ya, “Ọ dị mma. Ya dịrị dịka i kwuru.”  
\v 35 Nʼotu ụbọchị ahụ, ọ họpụtachara mkpi niile tụrụ agwa maọbụ ntụpọ na nne ewu niile ndị nwere tụrụ agwa maọbụ ntụpọ na nke ọbụla nwere ajị ọcha nʼahụ ya. Ọ họpụtakwara atụrụ ojii niile, nyefee ha nʼaka ụmụ ya ka ha lekọtaa ha.  
\v 36 Leban jere ije abalị atọ nke kewapụrụ ha site nʼebe Jekọb nọ. Ma Jekọb nọgidere na-elekọta igwe anụ ụlọ Leban ndị ọzọ. 
\p  
\v 37 Mgbe ahụ Jekọb gara gbute ngalaba osisi pọpla, na osisi alụmọnd, na osisi plenụ, kpechapụ ahụ agbụgbọ osisi ndị a, si otu a mee ka ime ime ngalaba osisi ndị a dị ọcha pụta ìhè.  
\v 38 Ọ tọgbọrọ osisi ndị a o kpechapụtara nʼebe ewu na atụrụ ndị a na-aṅụ mmiri, ka ha cherịta ịhụ ebe igwe anụ ụlọ ndị a nọ mgbe ọbụla ha na-aṅụ mmiri. Nke a mere mgbe igwe anụ ụlọ ndị a na-enwe ekpomọkụ nke ịgba ibe ha, nʼoge ha bịara ịṅụ mmiri,  
\v 39 ọ bụ nʼihu ngalaba osisi ndị a ka ha na-anọ na-agba onwe ha. Mgbe anụ ụlọ ndị a mụrụ ụmụ, ahụ ụmụ ha na-atụ agwa agwa maọbụ nwe ntụpọ.  
\v 40 Jekọb na-edo ụmụ igwe ewu na atụrụ ndị a nʼotu akụkụ, ma ọ na-eme ka anụ ụlọ ndị ọzọ chee ihu ha nʼanụ ụlọ Leban ndị tụrụ agwa agwa, maọbụ na-eji oji. Nʼụzọ dị otu a, ọ kewapụtaara onwe ya anụ ụlọ nke ya. O tinyekọtaghị ha nʼanụ ụlọ Leban.  
\v 41 Mgbe ọbụla nne anụ ụlọ ndị ahụ siri ike nọ nʼọnọdụ ịtụrụ ime, Jekọb na-edobe ngalaba osisi ndị ahụ nʼakụkụ ebe ha na-aṅụ mmiri nʼihu ha, ka ha nọrọ nʼebe ahụ gbaa onwe ha.  
\v 42 Ma ọ bụrụ na anụ ụlọ ndị ahụ adịghị ike, Jekọb anaghị edebe osisi ndị a nʼihu ha. Ya mere, igwe ewu na atụrụ ndị na-esighị ike gaara Leban. Ma ndị siri ike gaara Jekọb.  
\v 43 Site nʼụzọ dị otu a, Jekọb ghọrọ onye nwere akụ hie nne. O nwekwara ọtụtụ igwe anụ ụlọ na ọtụtụ ndị na-ejere ya ozi nwoke na nwanyị, na ọtụtụ ịnyịnya kamel, na ọtụtụ ịnyịnya ibu ndị ọzọ. 
\c 31  
\s1 Jekọb ahapụ Padan Aram 
\p  
\v 1 Jekọb nụrụ na ụmụ ndị ikom Leban na-asị, “Jekọb ewerechaala ihe niile nna anyị nwere. O sitere nʼihe nna anyị nwere kpata akụnụba ya niile.”  
\v 2 Jekọb hụkwara na omume Leban nʼebe ọ nọ adịghịkwa otu ọ dị na mbụ. 
\p  
\v 3 Mgbe ahụ, \nd Onyenwe anyị\nd* sịrị Jekọb, “Laghachi nʼala nna gị ha, lakwuru ụmụnna gị, aga m anọnyere gị.” 
\p  
\v 4 Ya mere, Jekọb ziri Rechel na Lịa ozi ka ha bịakwute ya nʼọhịa ebe ọ nọ na-elekọta igwe anụ ụlọ ya.  
\v 5 Ọ sịrị ha, “Ahụla m na omume nna unu nʼebe m nọ adịghịkwa otu ọ dị na mbụ. Ma Chineke nna m ha nọnyeere m.  
\v 6 Unu maara na eji m ike m niile rụọra nna unu ọrụ.  
\v 7 Ma nna unu ghọgburu m, gbanwee ụgwọ ọrụ m ugboro iri. Otu ọ dị, Chineke ekweghị ka nna unu merụọ m ahụ.  
\v 8 Ọ bụrụ na ọ sị, ‘Ndị tụrụ agwa agwa ga-abụ ụgwọ ọrụ gị,’ mgbe ahụ, igwe anụ ụlọ niile na-amụ ụmụ na-abụ ndị tụrụ agwa. Ma ọ bụrụ na ọ sị, ‘Ndị niile nwere ntụpọ ga-abụ ụgwọ ọrụ gị,’ mgbe ahụ, igwe anụ ụlọ niile na-amụ ụmụ na-enwe ntụpọ ọcha nʼahụ ha.  
\v 9 Chineke napụrụ nna unu anụ ụlọ ya ma nye m ha. 
\p  
\v 10 “Nʼoge ụmụ anụ ụlọ ji atụ ime, eweliri m anya hụ na nrọ na ụmụ mkpi niile na-agba igwe nne ewu bụ ụmụ mkpi ndị tụrụ agwa agwa, ndị nwere akara maọbụ ndị nwere ntụpọ ọcha nʼahụ ha.  
\v 11 Mgbe ahụ, mmụọ ozi Chineke sịrị m na nrọ, ‘Jekọb.’ Azara m sị, ‘Lee m nʼebe a.’  
\v 12 Ọ sịrị m, ‘Lelie anya gị elu, lee ka ị hụ na mkpi niile na-agba igwe nne ewu ndị a bụ mkpi ndị ahụ tụrụ agwa agwa, ndị nwere akara maọbụ ndị nwere ntụpọ ọcha. Nʼihi na ahụla m ihe niile Leban na-eme gị.  
\v 13 Mụ onwe m bụ Chineke nke Betel, ebe ị wụkwasịrị mmanụ nʼogidi nkume ahụ, ebe ị kwekwara m nkwa. Ugbu a, kulie, hapụ obodo a, laghachi nʼala a nọ mụọ gị.’ ” 
\p  
\v 14 Rechel na Lịa zara sị ya, “Anyị ka nwere oke nʼihe nketa nʼụlọ nna anyị?  
\v 15 Ọ bụghị dịka ndị ọbịa ka ọ gụnyeziri anyị? Nʼihi na o reela anyị, ripịakwa ụgwọ isi anyị.  
\v 16 Nʼezie, akụ ndị ahụ Chineke napụrụ nna anyị bụ nke anyị na nke ụmụ anyị. Ya mere, mee ihe ọbụla Chineke sị gị mee.” 
\p  
\v 17 Jekọb biliri, kukwasị ụmụ ya na ndị nwunye ya nʼelu ịnyịnya kamel,  
\v 18 duru igwe anụ ụlọ ya niile, na ihe ọ kpatara na Padan Aram, lakwuru nna ya Aịzik nʼala Kenan. 
\p  
\v 19 Ka Leban gara ịkpachapụ ajị ụmụ atụrụ ya, Rechel zuuru arụsị ezinaụlọ nna ya.  
\v 20 Jekọb ghọkwara Leban onye Aram aghụghọ nʼihi na ọ gwaghị ya na ọ na-agbapụ ọsọ.  
\v 21 Ya mere, o buru ihe niile o nwere gbapụ ọsọ, gbafee iyi ukwu Yufretis, chee ihu nʼala ugwu ugwu Gilead. 
\s1 Leban achụso Jekọb ọsọ 
\p  
\v 22 Abalị atọ agafeelarị tupu a gwa Leban na Jekọb agbalaala.  
\v 23 O duuru ndị ikwu ya chụọ Jekọb ọsọ abalị asaa tupu ọ chụkwute ya nʼala ugwu ugwu Gilead.  
\v 24 Ma Chineke bịakwutere Leban onye Aram na nrọ nʼabalị sị ya, “Kpachapụ anya gị, hụ na o nweghị ihe ị gwara Jekọb, maọbụ okwu dị mma, maọbụ nke dị njọ.” 
\p  
\v 25 Jekọb amaala ụlọ ikwu ya nʼala ugwu Gilead mgbe Leban chụkwutere ya. Leban na ndị ikwu ya makwara ụlọ ikwu nke ha nʼebe ahụ.  
\v 26 Leban sịrị Jekọb, “Gịnị bụ ihe a i mere? Ị ghọgbuola m. I burula ụmụ m ndị inyom dịka ndị a dọtara nʼagha?  
\v 27 Gịnị mere i ji ghọgbuo m, zoro ezo gbapụ? Gịnị mere ị gwaghị m ka m jiri ọṅụ na ịbụ abụ nke ya na ịkpọ ụbọ akwara na iti ịgba so, zilaga gị?  
\v 28 Gịnị mere i nyeghị m ohere ka m sutu ụmụ ụmụ m na ụmụ m ndị inyom ọnụ sị ha laa nke ọma? Omume a i mere bụ omume nzuzu.  
\v 29 Enwere m ike merụọ gị ahụ ugbu a, ma Chineke nke nna gị mere ka m hụ ya anya na nrọ nʼabalị gara aga. Ọ dọrọ m aka na ntị sị m, ‘Kpachapụ anya gị hụ na o nweghị ihe ị gwara Jekọb, maọbụ okwu dị mma, maọbụ nke dị njọ.’  
\v 30 Ugbu a, ị na-ala nʼihi na ọ gụrụ gị agụụ ịlaghachi nʼụlọ nna gị, ma gịnị mere i ji zuru chi m?” 
\p  
\v 31 Jekọb zara sị Leban, “Nʼihi na m tụrụ egwu, nʼihi na m chere sị na ị ga-eji ike napụ m ụmụ gị ndị inyom a.  
\v 32 Ma ọ bụrụ na ị chọta onye ọbụla ji chi gị ndị a, onye ahụ ga-anwụ. Nʼihu ndị ikwu gị ndị a, chọgharịa nʼonwe gị, lee ma ị ga-achọta ihe ọbụla bụ nke gị dị m nʼaka. Ọ bụrụ na ị chọta ya, were ya.” Ma Jekọb amaghị na Rechel zuuru chi ndị ahụ. 
\p  
\v 33 Ya mere, Leban bara nʼụlọ ikwu Jekọb, na nʼime ụlọ ikwu Lịa, na nʼime ụlọ ikwu ndị odibo nwanyị abụọ ya, ma o nweghị ihe ọ chọtara. O sitere nʼụlọ ikwu Lịa pụta baa nʼụlọ ikwu Rechel.  
\v 34 Nʼoge a, Rechel ewerela arụsị ezinaụlọ ndị ahụ tinye ha nʼime akwa e ji anọkwasị nʼelu ịnyịnya kamel nọdụ ọdụ nʼelu ya. Leban chọgharịrị ebe niile nʼime ụlọ ikwu ahụ ma ọ chọtaghị arụsị ezinaụlọ ndị ahụ. 
\p  
\v 35 Mgbe ahụ, Rechel gwara nna ya Leban sị, “Biko, ewela iwe nna m ukwu, nʼihi na enweghị m ike ibili ọtọ nʼihu gị. Anọ m nʼọnọdụ ndị inyom na-anọ kwa ọnwa.” Leban chọgharịrị ebe niile, ma ọ hụghị arụsị ezinaụlọ ndị ahụ. 
\p  
\v 36 Iwe were Jekọb megide Leban. O ji iwe jụọ Leban sị, “Gịnị bụ njehie m? Gịnị bụ mmehie m mere i ji si otu a na-achụsi m ike?  
\v 37 Ugbu a, ị chọgharịala nʼibu m niile, gịnị ka ị chọtara bụ nke gị? Wepụta ya nʼihu ndị ikwu gị na nʼihu ndị nke m, ka ha kpeere mụ na gị ikpe. 
\p  
\v 38 “Iri afọ abụọ ka mụ na gị nọrọ. O nweghị mgbe ime pụrụ ụmụ ewu na atụrụ gị; o nwekwaghị mgbe m riri ebule si nʼigwe anụ ụlọ gị.  
\v 39 \f + \fr 31:39 \ft Ọ bụrụ na anụ ọhịa adọgbuo atụrụ e nyere onye ọzụzụ atụrụ ka o lekọta, onye ọzụzụ atụrụ ahụ ga-eweta ụfọdụ nʼime anụ ahụ a dọgburu adọgbu, iji gosi ihe mere. Mgbe ahụ, o nweghị onye ọbụla ga-asị ya kwụọ ụgwọ ọbụla, nʼihi anụ ụlọ ahụ nwụrụ anwụ. \xt Ọpụ 22:13\f*O nweghị mgbe m welataara gị anụ ụlọ nke anụ ọhịa dọgburu, kama akwụrụ m ụgwọ ha. I mekwara ka m kwụghachi gị anụ ụlọ ọbụla e zuru nʼohi, maọbụ nʼehihie, maọbụ nʼabalị.  
\v 40 Nʼime oke anwụ nke ehihie ka m rụụrụ gị ọrụ. Rụọkwara gị ọrụ nʼoge oyi na-atụ, nʼabalị ụra sikwa nʼanya m pụọ.  
\v 41 Otu a ka ọ dịrị m iri afọ abụọ m jeere gị ozi. Arụrụ m gị ọrụ afọ iri na anọ maka ụmụ gị ndị inyom abụọ ndị a, afọ isii ka m lekọtara igwe ewu na atụrụ gị. Ị nọkwa nʼime ihe ndị a gbanwee ụgwọ ọrụ m ugboro iri.  
\v 42 A sị na Chineke m, Chineke Ebraham, onye ahụ a na-atụ egwu nke Aịzik, anọnyereghị m, ị gaara ezilaga m nʼaka efu, agaara m agbara aka laa. Ma Chineke ahụla ịrụsị ọrụ ike m, na nhụju anya m niile, ọ bụ ya mere o ji baara gị mba nʼabalị gara aga.” 
\p  
\v 43 Mgbe ahụ Leban zaghachiri sị Jekọb, “Ndị inyom ndị a bụ ụmụ m. Ụmụaka ndị a bụ ụmụ m. Igwe anụ ụlọ ndị a bụ nke m. Ihe ndị a niile ị na-ahụ anya bụ nke m. Olee otu m ga-esi merụọ ụmụ m, na ụmụ ụmụ m ahụ?  
\v 44 Ugbu a, bịa ka anyị gbaa ndụ mụ na gị, ka ọ bụrụ ihe ama nʼetiti anyị.” 
\p  
\v 45 Ya mere, Jekọb weere otu nkume guzo ya ọtọ dịka ogidi.  
\v 46 Jekọb gwakwara ndị so ya sị ha, “Tụtụkọta nkume.” Ha tụtụkọtara nkume wụsa ha nʼotu ebe mee ka ọ laa elu. Emesịa, ha nọdụrụ nʼakụkụ nkume ndị ahụ rie nri.\f + \fr 31:46 \ft Oge ọbụla mmadụ na ibe ya gbara ndụ, ha na-eri nri a na-akpọ, nri ọgbụgba ndụ iji mesie ọgbụgba ndụ ahụ ike.\f* 
\v 47 Leban kpọrọ nkume ndị ahụ Jega-Sahaduta, nʼasụsụ nke ya. Jekọb kpọrọ ya Galeed, nʼasụsụ nke ya. 
\p  
\v 48 Emesịa, Leban sịrị, “Ka nkume ndị a bụrụ ihe ama nʼetiti mụ na gị taa.” Nke a mere e ji kpọọ ya Galeed.  
\v 49 A kpọkwara ya Mizpa, nʼihi na Leban sịrị, “Ka \nd Onyenwe anyị\nd* bụrụ onye ga-eche mụ na gị nche ịhụ na onye ọbụla nʼime anyị debere ọgbụgba ndụ a, mgbe anyị na-anọghị ibe anyị nso.  
\v 50 Ọ bụrụ na i mee ụmụ m ndị inyom ihe ọjọọ, maọbụ lụọ ndị inyom ndị ọzọ tinyere ha, o nweghị onye nʼime anyị ga-amata, ma cheta na Chineke ga-abụ onyeama nʼetiti mụ na gị.” 
\p  
\v 51 Leban gwakwara Jekọb sị, “Lee nkume ndị a a wụsara nʼebe a na ogidi m mere ka o guzo nʼetiti mụ na gị.  
\v 52 Nkume ndị a a wụsara bụ akaebe, ogidi a bụkwa ihe ama. Agaghị m agabiga nkume ndị a a wụsara gafeeta nʼakụkụ nke gị ime gị ihe ọjọọ. Gị onwe gị agaghị agabiga nkume ndị a a wụsara na ogidi a gafeeta nʼakụkụ nke m ime m ihe ọjọọ.  
\v 53 Ka Chineke Ebraham na Chineke Nahọ,\f + \fr 31:53 \ft Nahọ bụ nwanne Ebraham, \xt Jen 11:26; 22:20\ft  bụrụkwa nna nna Leban. \xt Jen 24:24,29\ft  Leban bụ nwoke na-efe ọtụtụ chi. \xt Jen 31:19\f* Chineke nna ha, bụrụ onye ikpe nʼetiti mụ na gị.” 
\p Ya mere Jekọb ji onye ahụ a na-atụ egwu nke nna ya Aịzik ṅụọ iyi.  
\v 54 Ọ chụrụ aja nʼala ugwu ugwu ahụ, kpọọ ndị ikwu ya niile oriri. Mgbe ha richara nri, ha rahụrụ ụra nʼebe ahụ. 
\p  
\v 55 Nʼisi ụtụtụ echi ya, Leban biliri sutu ụmụ ya ndị inyom na ụmụ ụmụ ya ọnụ. Ọ gọziri ha, hapụ ha laghachi ụlọ ha. 
\c 32  
\s1 Jekọb akwadobe maka izute Ịsọ 
\p  
\v 1 Jekọb nʼonwe ya hapụrụ gawa nʼihu nʼije ya. Ndị mmụọ ozi Chineke zutere ya nʼụzọ.  
\v 2 Mgbe Jekọb hụrụ ha, o kwuru sị, “Ebe a bụ ụlọ ikwu Chineke!” Ọ kpọrọ ebe ahụ, Mahanaim. 
\p  
\v 3 Mgbe ahụ, Jekọb zipụrụ ndị ozi ka ha jee hụ Ịsọ nwanne ya nwoke nʼala Sia,\f + \fr 32:3 \ft Ala Sịa nke dị nso iyi Jabọk, ga-emesịa bụrụ ala dị mkpa nʼoge ọchịchị eze Devid na Solomọn. \xt Jen 14:6; 33:14,16\f* nʼobodo Edọm.  
\v 4 O ziri ha ozi sị, “Ihe a bụ ihe unu ga-agwa nna m ukwu Ịsọ, ‘Odibo gị Jekọb kwuru sị, Ọ bụ na nke Leban ka m jere kemgbe, ọ bụkwa ebe ahụ ka m nọ ruo ugbu a.  
\v 5 Enwere m ọtụtụ ehi, na ịnyịnya ibu, na igwe atụrụ na ewu, na ndị odibo ndị nwoke na ndị nwanyị. Ana m ezigara onyenwe m ozi a ka m nata ihuọma nʼebe ọ nọ.’ ” 
\p  
\v 6 Mgbe ndị ozi ahụ lọghachikwutere Jekọb, ha gwara ya sị ya, “Anyị jekwuru nwanne gị nwoke Ịsọ dị ka i ziri anyị. Ugbu a, ọ na-abịa. Ọ chị narị ndị ikom anọ na-abịa izute gị.” 
\p  
\v 7 Ụjọ tụrụ Jekọb nke ukwuu, obi ya jupụtakwara na nsogbu. Nʼihi nke a, o kewara ndị niile so ya ụzọ abụọ, tinyere anụ ụlọ ya, na igwe ehi ya na ịnyịnya kamel ya.  
\v 8 O chere nʼobi ya sị, “Ọ bụrụ na Ịsọ alụso otu nʼime ụzọ abụọ a ọgụ, otu ụzọ fọdụrụ ga-enwe ike gbalaga.” 
\p  
\v 9 Mgbe ahụ, Jekọb kpere ekpere sị, “Chineke nke nna m Ebraham, Chineke nke nna m Aịzik, \nd Onyenwe anyị\nd*, gị onye gwara m sị, ‘Laghachi nʼala gị na nʼebe ụmụnna gị nọ, aga m eme ka ihe gaara gị nke ọma.’  
\v 10 Ekwesighị m obi ebere na ikwesi ntụkwasị obi nke i gosiri ohu gị. Mgbe m gabigara Jọdan a, enweghị m ihe ọbụla karịa mkpanaka m, ma ugbu a, abụ m ọmụma ụlọ ikwu abụọ.  
\v 11 Zọpụta m, arịọ m gị, site nʼaka nwanne m Ịsọ, nʼihi na egwu na-atụ m na ọ ga-abịa lụso m agha, lụsokwa ndị nne a na ụmụntakịrị ha agha.  
\v 12 Ọ bụ gị kwuru sị, ‘Aga m eme ka ihe gaara gị nke ọma, meekwa ka ụmụ ụmụ gị dịrị ka aja nke dị nʼọnụ osimiri, nke mmadụ na-apụghị ịgụta ọnụ.’ ” 
\p  
\v 13 Jekọb rahụrụ nʼebe ahụ nʼabalị ahụ. Site nʼihe niile o nwere, ọ họpụtara onyinye ọ ga-enye nwanne ya Ịsọ.  
\v 14 Ọ kwadoro inye ya: narị nne ewu abụọ (200), iri mkpi abụọ (20), narị nne atụrụ abụọ (200), iri ebule abụọ (20)  
\v 15 Iri nne ịnyịnya kamel atọ (30) na ụmụ ha, na iri nne ehi anọ (40), oke ehi iri (10), iri nne ịnyịnya ibu abụọ (20), oke ịnyịnya ibu iri (10).  
\v 16 O weere onyinye ndị a niile nyefee nʼaka ndị ozi ya nʼusoro dịka ụdị ha si dị. Ọ gwara ndị na-ejere ya ozi sị ha, “Burunu ụzọ na-aga, meenụ ka ohere dị nʼetiti igwe anụ na igwe ibe ya.” 
\p  
\v 17 O nyere onye mbụ iwu sị ha, “Mgbe Ịsọ nwanne m zutere unu jụọ unu ajụjụ sị, ‘Onye bụ nna unu ukwu? Ebee ka unu na-aga? Onye nwe anụ ụlọ ndị a niile unu chị na-aga?’  
\v 18 Unu ga-aza sị ya, ‘Anụ ụlọ ndị a bụ nke ohu gị Jekọb. Ha bụ onyinye e zitere onyenwe m Ịsọ, lee ka ọ na-abịa nʼazụ anyị.’ ” 
\p  
\v 19 Otu ozi ahụ ka Jekọb ziri onye nke abụọ na onye nke atọ, na ndị ọzọ niile chị igwe anụ ụlọ, sị ha, “Unu ga-agwa Ịsọ otu ihe ahụ mgbe unu zutere ya.  
\v 20 Hụkwanụ na unu gwara ya sị, ‘Ohu gị Jekọb nọ nʼazụ anyị.’ ” Echiche ya bụ, “Aga m eji onyinye ndị a niile m na-ezipụrụ ya mee ka obi ya dajụọ, nke ọ ga-abụ mgbe mụ na ya zutere, ma eleghị anya, ọ ga-anabata m.”  
\v 21 Mgbe o zipụchasịrị onyinye ndị ahụ niile, Jekọb rahụrụ ụra nʼụlọ ikwu ya nʼabalị ahụ. 
\s1 Mgba Jekọb na Chineke gbara 
\p  
\v 22 Nʼabalị ahụ, Jekọb biliri duru ndị nwunye ya abụọ na ndị odibo nwanyị ya abụọ, na ụmụ ya iri na otu, site nʼebe na-adịghị omimi nke iyi Jabọk kpọfee ha.  
\v 23 Mgbe ọ kpọfechara ha, o bufekwara ihe niile o nwere.  
\v 24 Emesịa, Jekọb lọghachiri nọdụ naanị ya. Mgbe ahụ, otu nwoke bịara gbaso ya mgba. Ha abụọ gbagidere mgba a tutu chi ebido ịbọ.  
\v 25 Mgbe nwoke ahụ hụrụ na ọ pụghị imeri Jekọb na mgba ahụ, o tiri Jekọb aka nʼọkpụ, mee ka ọkpụ ya hịkwapụ site nʼọnọdụ ya.  
\v 26 Mgbe nke a mesịrị, nwoke ahụ gwara Jekọb sị ya: “Hapụ m aka ka m laa, nʼihi na chi ebidola ịbọ.” 
\p Ma Jekọb zara sị ya, “Ọ bụ naanị mgbe ị gọziri m ka m ga-ahapụ gị ka ị laa.” 
\p  
\v 27 Mgbe ahụ nwoke ahụ jụrụ Jekọb ajụjụ sị ya, “Gịnị bụ aha gị?” 
\p Ọ zara sị, “Aha m bụ Jekọb.” 
\p  
\v 28 Nwoke ahụ zara sị ya, “Aha gị agaghị abụkwa Jekọb, kama ọ ga-abụ Izrel, nʼihi na gị na Chineke na ndị mmadụ gbara mgba, ị mmeri.” 
\p  
\v 29 Jekọb sịrị, “Biko gwa m aha gị.” 
\p Ma ọ zaghachiri, “Gịnị mere ị ji ajụ aha m?” Mgbe ahụ, ọ gọziri ya nʼebe ahụ. 
\p  
\v 30 Jekọb kpọrọ aha ebe ahụ Peniel, nʼihi na ọ sịrị, “Ahụla m Chineke ihu na ihu, ma e chebere ndụ m.” 
\p  
\v 31 Anyanwụ awaala mgbe Jekọb si Peniel gafee. Ma nʼihi ihe mere ya nʼọkpụ, ọ naghị agazikwa ije.  
\v 32 Ọ bụ ihe a mere ụmụ Izrel adịghị eri akwara anụ jikọtara ukwu anụ na ọkpụ ya ruo taa. Nʼihi na ihe ahụ mere Jekọb metụtara akwara ukwu ya. 
\c 33  
\s1 Jekọb ezute Ịsọ 
\p  
\v 1 Jekọb lepụrụ anya nʼihu, hụ Ịsọ ka ọ na-abịa, ya na narị ndị ikom anọ ndị so ya. Nʼihi ya, o kesara ụmụntakịrị ndị ahụ, nʼetiti Lịa, na Rechel na ndị odibo nwanyị ya abụọ.  
\v 2 O mere ka ndị odibo nwanyị ya abụọ ahụ na ụmụ ha buru ụzọ, Lịa na ụmụ ya esoro nʼazụ, ebe Rechel na Josef nọ nʼazụ azụ.  
\v 3 Ma ya onwe ya buru ụzọ na-aga nʼihu ha niile, na-akpọ isiala nye Ịsọ ugboro asaa, tutu ruo mgbe ọ bịarutere nwanne ya nwoke nso. 
\p  
\v 4 Ma Ịsọ gbaara ọsọ bịakwute ya, makụọ ya, jikụọ ya aka nʼolu, sutu ya ọnụ. Ha abụọ kwara akwa.  
\v 5 Mgbe Ịsọ lelitere anya hụ ndị inyom ndị a na ụmụntakịrị ndị ahụ. Ọ sịrị, “Ndị ole bụ ndị a gị na ha so?” 
\p Jekọb sịrị, “Ha bụ ụmụ Chineke sitere nʼamara ya nye ohu gị.” 
\p  
\v 6 Mgbe ahụ, ndị odibo nwanyị abụọ na ụmụ ha rutere nso, kpọọ isiala.  
\v 7 Lịa na ụmụ ya bịarutekwara kpọọ isiala, nʼikpeazụ Rechel na Josef bịara kpọọkwa isiala. 
\p  
\v 8 Ịsọ sịrị, “Igwe ewu na atụrụ ndị a niile m zutere nʼụzọ, gịnị ka ọ pụtara?” 
\p Jekọb zara, “Ha bụ maka ịnata ihuọma nʼaka gị, onyenwe m.” 
\p  
\v 9 Ma Ịsọ sịrị, “Nwanne m nwoke, debere onwe gị ihe i nwere, nʼihi na enwere m akụ hie nne.” 
\p  
\v 10 Jekọb sịrị, “E, biko, ọ bụrụ na m achọtala ihuọma nʼanya gị, nara m onyinye ndị a. Nʼihi na ịhụ gị anya dịka ilekwasị Chineke anya nʼihu, nke ka nke, otu a i ji ihu ọcha nabata m.  
\v 11 Biko nara onyinye ndị ahụ e wetaara gị, nʼihi na Chineke emelara m amara. Enwekwara m ihe ga-ezuru m.” Jekọb kwagidere ya, ọ naara onyinye ndị ahụ. 
\p  
\v 12 Mgbe ahụ, Ịsọ sịrị, “Bilienụ ka anyị malite ije ịlaghachi. Aga m esonyere unu.” 
\p  
\v 13 Ma Jekọb sịrị ya, “Onyenwe m, ị maara na ụmụntakịrị ndị a adịghị ike, aga m ejikwa nwayọọ chịa ụmụ atụrụ ndị a na ehi ndị na-enye ụmụ ha ara. Ọ bụrụ na a chịa ha nʼike nʼime otu ụbọchị, ụmụ anụmanụ ndị a niile ga-anwụ.  
\v 14 Ya mere, ka onyenwe m buru ohu ya ụzọ na-aga, ma ka m jiri nwayọọ nwayọọ na-abịa, dịka ike igwe anụ ndị a na ụmụaka ndị a si dị. Tutu ruo mgbe m ga-ezute onyenwe m na Sia.” 
\p  
\v 15 Ịsọ sịrị, “Ọ bụrụ otu a, ka m hapụrụ gị ụfọdụ ndị a mụ na ha so.” 
\p Ma Jekọb sịrị, “Nʼihi gịnị kwanụ? Ka m hụta naanị ihuọma nʼanya onyenwe m.” 
\p  
\v 16 Ịsọ laghachikwara azụ na Sia nʼotu ụbọchị ahụ.  
\v 17 Ma Jekọb na ezinaụlọ ya jere Sukọt, ebe o wuuru onwe ya ụlọ obibi, wuokwara anụ ụlọ ya ụlọ obibi ha. Ọ bụ nke a mere e ji kpọọ ebe ahụ Sukọt. 
\p  
\v 18 Mgbe Jekọb si Padan Aram lọghachi, o rutere obodo Shekem nke dị nʼala Kenan nʼudo. O mara ụlọ ikwu ya nʼihu obodo ahụ.  
\v 19 Ọ zụrụ ala ebe o mara ụlọ ikwu ya nʼaka ụmụ Hamọ, nna Shekem, ọ kwụrụ narị mkpụrụ ọlaọcha maka ala ahụ.  
\v 20 Nʼebe ahụ, o wuru ebe ịchụ aja, kpọọ aha ya El Elohe Izrel.\f + \fr 33:20 \ft Nke a pụtara Chineke Izrel dị ike nke ukwuu.\f* 
\c 34  
\s1 Daịna na nwa eze Shekem 
\p  
\v 1 Ugbu a, Daịna nwa nwanyị Lịa mụụrụ Jekọb pụrụ ileta ndị inyom ala ahụ.  
\v 2 Mgbe Shekem, nwa Hamọ onye Hiv, onye na-achị mpaghara ahụ, hụrụ ya, ọ kpọọrọ ya jiri ike ya na ya dinaa.  
\v 3 Mkpụrụobi ya gara nʼebe Daịna nwa Jekọb, ọ hụrụ nwantakịrị nwanyị ahụ nʼanya, gwakwa ya okwu dị nro.  
\v 4 Shekem sịrị nna ya bụ Hamọ “Lụtara m nwaagbọghọ a, ka ọ bụrụ nwunye m.” 
\p  
\v 5 Mgbe Jekọb nụrụ na e merụrụ Daịna nwa ya nwanyị, nʼihi na ụmụ ya ndị ikom nọ nʼọhịa ebe ha na-azụ anụ ụlọ, ọ gbara nkịtị na-emeghị ihe ọbụla ruo mgbe ha lọtara. 
\p  
\v 6 Hamọ bụ nna Shekem, pụkwuuru Jekọb ka ha kparịta ụka.  
\v 7 Ụmụ ndị ikom Jekọb si nʼọhịa na-alọta mgbe ha nụrụ ihe merenụ, iwe na ọnụma juputara ha obi nke ukwuu nʼihi na Shekem mere ihe na-eweta ihere nʼIzrel site nʼidinakwuru ada Jekọb, ihe a na-ekwesighị ime eme. 
\p  
\v 8 Ma Hamọ sịrị ha, “Nwa m nwoke Shekem hụrụ nwa unu nwanyị nʼanya. Biko, kwerenụ ka ọ lụọ ya.  
\v 9 Kwerenụ ka anyị na unu na-alụrịta. Ka anyị na-alụ ụmụ ndị inyom unu, ka unu na-alụkwa ụmụ ndị inyom anyị.  
\v 10 Unu nwere ike biri nʼetiti anyị. Ala a ghere oghe nye unu. Birinụ nʼime ya, na-azụkwanụ ahịa nʼime ya, nwekwanụ akụ nʼime ya nye onwe unu.” 
\p  
\v 11 Shekem gwara nna na ụmụnne Daịna ndị ikom sị, “Kwerenụ ka m chọta ihuọma nʼebe unu nọ, aga m enyekwa unu ihe ọbụla unu chọrọ ka m nye unu.  
\v 12 Ihe ọbụla unu sị m kwụọ dịka ego akụ ọlụlụ nwunye, ya na onyinye ọbụla unu si m nye aga m enye unu. Naanị kwerenụ ka nwaagbọghọ a bụrụ nwunye m.” 
\p  
\v 13 Ma ụmụ Jekọb jiri aghụghọ zaa Shekem na Hamọ nna ya mgbe ha na-agwa ha okwu, nʼihi na e merụrụ Daịna nwanne ha nwanyị.  
\v 14 Ha sịrị ha, “Anyị enweghị ike ime ihe a, ị kpọrọ nwanne anyị nwanyị kpọnye nwoke a na-ebighị ugwu. Nke a ga-abụrụ anyị ihe ihere.  
\v 15 Anyị nwere ike ikwenye ka ọ lụọ ya ma ọ bụrụ na unu ga-adị ka anyị, ka e bie ndị nwoke unu niile ugwu.  
\v 16 Mgbe ahụ anyị ga-edunye unu ụmụ ndị inyom anyị, ma kpọrọkwa ụmụ ndị inyom unu dịka ndị nwunye anyị. Anyị ga-ebi nʼetiti unu, soro unu bụrụ otu ndị.  
\v 17 Ọ bụrụ na unu agaghị ekwe ka e bie unu ugwu, anyị ga-akpọrọ nwanne anyị nwanyị laa.” 
\p  
\v 18 Obi tọrọ Hamọ na Shekem nwa ya nwoke ụtọ nʼihi ihe ụmụ ndị ikom Jekọb kwuru.  
\v 19 Nwokorobịa ahụ bụ onye a na-asọpụrụ karịa onye ọbụla nʼụlọ nna ya egbughị oge ime ihe ha kwuru, nʼihi na ihe banyere nwa nwanyị Jekọb dị ya mma nke ukwuu.  
\v 20 Emesịa, Hamọ na Shekem nwa ya nwoke gara nʼọnụ\f + \fr 34:20 \ft Ọ bụ nʼọnụ ụzọ ama nke obodo ka ndị okenye na-ezukọ, akparịta ụka. \xt Jen 19:2; 23:10; Rut 4:1,11; 2Sa 15:2\f* ụzọ ama nke obodo ha gwa ndị ikom obodo ha okwu, sị.  
\v 21 “Ndị ikom ndị a nwere mmasị nʼebe anyị nọ. Kwerenụ ka ha biri nʼala anyị, ka ha na-agagharị kwa nʼime ya. Anyị nwere ala buru ibu nke ga-ezuru anyị na ha. Ha ga-alụ ụmụ nwanyị anyị, anyị ga-alụkwa ndị nke ha.  
\v 22 Ma ọ dị otu ihe ha chọrọ ka anyị mee tupu ha ekwere ibi nʼetiti anyị ka anyị na ha bụrụ otu ndị. Ọ bụ ibi ndị ikom anyị niile ugwu dịka e si bie ha ugwu.  
\v 23 Ọ bụrụ na unu chọrọ ka anụ ụlọ ha niile na akụ ha niile bụrụ nke anyị, ọ dị mma ka anyị kwenyere ha, ka ha binyere anyị.” 
\p  
\v 24 Ndị ikom niile bịara nʼọnụ ụzọ ama obodo ahụ kwenyere nʼokwu Hamọ na nwa ya nwoke Shekem. E bikwara nwoke ọbụla nọ nʼobodo ahụ ugwu. 
\p  
\v 25 O ruo nʼụbọchị nke atọ, mgbe ọnya ugwu ha na-egbu ha mgbu, ụmụ ndị ikom Jekọb abụọ, Simiọn na Livayị, ụmụnne Daịna, jiri mma agha ha pụkwuru ndị bi nʼobodo ahụ na-atụghị anya na ihe dị otu a ga-eme, gbuo ndị ikom niile nọ nʼobodo ahụ.  
\v 26 Ha gbukwara Hamọ na Shekem nwa ya nwoke, kpọpụta Daịna site nʼụlọ Shekem, laghachi nʼụlọ ha.  
\v 27 Mgbe ahụ ụmụ ndị ikom Jekọb niile bịakwasịrị ndị a e gburu egbu, kwakọọ ihe niile dị nʼobodo ahụ niile, nʼihi mmerụ e merụrụ nwanne ha nwanyị.  
\v 28 Ha kwakọọrọ ngwongwo niile dị nʼobodo ahụ, kpụrụkwa anụ ụlọ niile, igwe ewu na atụrụ, igwe ehi na igwe ịnyịnya ibu niile, na ihe niile dị nʼime obodo ahụ, na ihe niile dị nʼubi ndị ahụ obodo nwere.  
\v 29 Akụ ha niile, na ndị inyom ha niile na ụmụntakịrị ha, na ihe niile dị nʼime ụlọ ha, ka ha weere dịka ihe a dọtara nʼagha. 
\p  
\v 30 Mgbe Jekọb hụrụ ihe ụmụ ya mere, ọ kpọrọ Simiọn na Livayị sị ha, “Unu ebuterela m nsogbu mee ka m bụrụ ihe na-esi isi ọjọọ nʼetiti ndị Kenan na ndị Periz nwe ala a. Ebe anyị dị ole na ole, ọ bụrụ na ha ejikọta onwe ha ọnụ lụso m agha, ha ga-ekpochapụ mụ na ezinaụlọ m.” 
\p  
\v 31 Ma ha zara sị ya, “O kwesiri ka o meso nwanne anyị nwanyị mmeso dịka ọ bụ akwụna?” 
\c 35  
\s1 Jekọb alọghachi Betel 
\p  
\v 1 Chineke sịrị Jekọb, “Bilie, gaa Betel, birikwa nʼebe ahụ. Wuo ebe ịchụ aja nye Chineke, onye mere ka ị hụ ya mgbe ị na-agbanarị Ịsọ nwanne gị nwoke.” 
\p  
\v 2 Ya mere, Jekọb gwara ndị ezinaụlọ ya na ndị niile so ya sị, “Wezuganụ chi ndị ala ọzọ dị nʼetiti unu. Doonụ onwe unu ọcha, gbanweekwanụ uwe unu.  
\v 3 Bilienụ, ka anyị gaa Betel, ebe m ga-ewu ebe ịchụ aja nye Chineke, onye zara m oku nʼụbọchị nsogbu m, ma nọnyekwara m na njem nke m gara.”  
\v 4 Ya mere, ha nyere Jekọb chi ndị ala ọzọ niile ha ji nʼaka, na ọla\f + \fr 35:4 \ft Nʼoge ahụ, ndị mmadụ kwenyere na ọlantị ha na-eyi bụ ihe na-echekwa ha.\f* niile dị ha na ntị. Jekọb chịịrị ha niile lie ha nʼokpuru osisi ook dị na Shekem.  
\v 5 Ha biliri ije. Egwu Chineke dakwasịrị obodo niile gbara ha gburugburu. Ọ dịghị ndị chụsoro ha. 
\p  
\v 6 Jekọb na ndị niile so ya rutere Luz, nke a na-akpọkwa Betel nke dị na Kenan.  
\v 7 Jekọb wuru ebe ịchụ aja nʼebe a, kpọọ aha ebe ahụ El Betel, nʼihi na ọ bụ nʼebe ahụ ka Chineke gosiri ya onwe ya mgbe ọ na-agbanarị Ịsọ nwanne ya nwoke. 
\p  
\v 8 Mgbe nke a gasịrị, Debọra, nwanyị lekọtara Ribeka mgbe ọ bụ nwantakịrị, nwụrụ. E liri ya nʼokpuru osisi ook dị na Betel. A kpọkwara ebe ahụ, “Osisi ook ebe ịkwa akwa.” 
\p  
\v 9 Chineke gosiri Jekọb onwe ya ọzọ, mgbe o sitere na Padan Aram pụta, gọziekwa ya.  
\v 10 Chineke sịrị ya, “Aha gị bụ Jekọb ma a gaghị akpọkwa gị Jekọb ọzọ, kama aha gị ga-abụ Izrel.” Ya mere ọ kpọrọ ya Izrel. 
\p  
\v 11 Chineke sịrị ya, “Abụ m Chineke onye pụrụ ime ihe niile. Mụọ ọmụmụ, baakwa ụba nʼọnụọgụgụ. Otu mba na igwe mba ga-esi na gị pụta. Ndị eze ga-esitekwa gị nʼahụ pụta.  
\v 12 Ala ahụ m nyere Ebraham na Aịzik ka m na-enyekwa gị. Aga m enyekwa ya ụmụ ụmụ gị ndị ga-esote gị.”  
\v 13 Emesịa, Chineke si nʼebe ahụ ha nọ kparịtaa ụka pụọ. 
\p  
\v 14 Jekọb wuru ogidi nkume nʼebe ahụ Chineke nọ gwa ya okwu. Ọ wụsara onyinye ihe ọṅụṅụ wụkwasịkwa mmanụ nʼelu ogidi nkume ahụ.  
\v 15 Jekọb kpọrọ ebe ahụ ya na Chineke nọ kparịtaa ụka Betel. 
\s1 Ọnwụ Rechel na Aịzik 
\p  
\v 16 Ha biliri ije, site na Betel. Ma mgbe ha ka nọ ebe dị anya site nʼobodo Efrat, Rechel mụrụ nwa, ma o nwere ihe mgbu ka ọ na-amụ nwa.  
\v 17 Mgbe o sitere nʼoke ihe mgbu na-amụpụta nwa ahụ, nwanyị na-aghọ nwa gwara ya, “Atụla egwu, nʼihi na ọ bụ nwa nwoke ọzọ ka ị mụtara.”  
\v 18 Ma tupu Rechel ekuo ume ikpeazụ, nʼihi na ọ na-anwụ, ọ kpọrọ aha nwa ọhụrụ ahụ Ben-Oni, ma nna ya kpọrọ ya Benjamin. 
\p  
\v 19 Rechel nwụrụ, e lie ya nʼakụkụ ụzọ gara Efrat, nke a na-akpọkwa Betlehem.  
\v 20 Jekọb wuru ogidi nʼelu ili ya, nke na-eguzokwa ruo taa, igosi ebe e liri Rechel. 
\p  
\v 21 Izrel malitere ije ya, tutu ruo ebe o wuru ebe izuike ya nʼala dị nʼofe ọzọ nke Migdal Eda.  
\v 22 Mgbe Izrel bi nʼala ahụ, Ruben gara dinakwuru Bilha, iko nwanyị nna ya. E mekwara ka Izrel nụ ihe a Ruben mere. 
\b  
\li4 Ụmụ ndị ikom Jekọb dị iri na abụọ. 
\b  
\li1  
\v 23 Ụmụ Lịa bụ, 
\li2 Ruben, ọkpara Jekọb. 
\li2 Simiọn, Livayị, Juda, Isaka na Zebụlọn. 
\li1  
\v 24 Ụmụ Rechel bụ, 
\li2 Josef na Benjamin. 
\li1  
\v 25 Ụmụ Bilha, odibo nwanyị Rechel bụ, 
\li2 Dan na Naftalị. 
\li1  
\v 26 Ụmụ Zilpa, odibo nwanyị Lịa bụ, 
\li2 Gad na Asha. 
\b  
\li4 Ụmụ ndị ikom ndị a ka a mụụrụ Jekọb na Padan Aram. 
\b  
\p  
\v 27 Nʼikpeazụ, Jekọb bịakwutere nna ya Aịzik na Mamre nke dị nso na Kiriat Arba (ebe a na-akpọ Hebrọn). Ebe ahụ ka Ebraham na Aịzik biri na mbụ.  
\v 28 Nʼoge ahụ Aịzik gbara narị afọ na iri afọ asatọ.  
\v 29 Ọ dịkwaghị anya site nʼoge a, Aịzik nwụrụ, mgbe o mere nnọọ agadi. Ụmụ ya ndị ikom abụọ, Ịsọ na Jekọb, liri ya. 
\c 36  
\s1 Ụmụ ụmụ Ịsọ 
\p  
\v 1 Nke a bụ akụkọ banyere usoro agbụrụ Ịsọ, onye a na-akpọ Edọm. 
\b  
\p  
\v 2 Ịsọ lụrụ ndị inyom a site nʼala Kenan. Onye nke mbụ bụ Ada nwa Elọn, onye Het. Nke abụọ bụ Oholibama, nwa Ana, nwa nwa Zibiọn, onye Hiv.  
\v 3 Onye nke atọ bụ Basemat, nwa Ishmel, onye nwanne ya nwanyị bụ Nebaiot. 
\p  
\v 4 Ada mụụrụ Ịsọ Elifaz, ebe Basemat mụrụ Reuel.  
\v 5 Oholibama mụtaara Jeush na Jalam na Kora. Ndị a bụ ụmụ Ịsọ ndị a mụtara ya nʼala Kenan. 
\p  
\v 6 Emesịa, Ịsọ duuru ndị nwunye ya na ụmụ ya ndị ikom na ndị inyom, na ndị niile nọ nʼezinaụlọ ya. Ọ chịkọọrọ anụ ụlọ ya niile, na akụ niile ọ kpatara nʼala Kenan kwapụ gaa biri nʼala dị anya site nʼebe nwanne ya Jekọb nọ.  
\v 7 Ebe ọ bụ na akụnụba ha nwere dịkarịrị ukwuu ha ibikọta ọnụ, tinyekwara na ala ebe ha bi enwezighị ike ibuli ha nʼihi anụ ụlọ niile ha nwere.  
\v 8 Ya mere, Ịsọ gara biri nʼala ugwu ugwu Sia, Ịsọ bụkwa Edọm. 
\b  
\li4  
\v 9 Nke a bụ akụkọ banyere usoro agbụrụ Ịsọ, nna obodo Edọm, nʼala ugwu ugwu Sia. 
\b  
\li1  
\v 10 Ndị a bụ aha ụmụ ndị ikom Ịsọ mụtara. 
\li2 Elifaz bụ ọkpara Ada, nwunye Ịsọ. Nwanne ya bụ Reuel, nwa Basemat, nwunye Ịsọ. 
\li1  
\v 11 Ụmụ Elifaz ndị ikom bụ, 
\li2 Teman, Ọmaa, Zefo, Gatam na Kenaz.  
\v 12 Elifaz nwa Ịsọ nwere iko nwanyị aha ya bụ Timna, onye mụtaara ya Amalek. Ndị a niile bụ ụmụ ndị ikom Ada, nwunye Ịsọ. 
\li1  
\v 13 Ụmụ ndị ikom Reuel bụ, 
\li2 Nahat, Zera, Shama na Miza. Ndị a niile bụ ụmụ ụmụ Basemat, nwunye Ịsọ. 
\li1  
\v 14 Ndị a bụ ụmụ Oholibama, nwunye Ịsọ. Oholibama bụ nwa Ana na nwa nwa Zibiọn. Ọ mụtaara Ịsọ 
\li2 Jeush, Jalam na Kora. 
\b  
\li4  
\v 15 Ndị a bụ ọnụmara si nʼetiti ụmụ ụmụ Ịsọ. 
\li1 Site nʼetiti ụmụ Elifaz, ọkpara Ịsọ, 
\li2 e nwere Ọnụmara Teman, ọnụmara Ọmaa, ọnụmara Zefo, ọnụmara Kenaz.  
\v 16 Ọnụmara Kora, ọnụmara Gatam na ọnụmara Amalek. Ndị eze ndị a bụ ụmụ Elifaz nʼala Edọm. Ha bụ ụmụ ụmụ Ada. 
\li1  
\v 17 Ndị bụ ụmụ Reuel, nwa Ịsọ, 
\li2 e nwere ọnụmara Nahat, ọnụmara Zera, ọnụmara Shama, ọnụmara Miza. Ọnụmara ndị a bụ ụmụ Reuel nʼala Edọm. Ha bụ ụmụ Basemat, nwunye Ịsọ. 
\li1  
\v 18 Ndị a bụ ụmụ Oholibama, nwunye Ịsọ, 
\li2 ọnụmara Jeush, ọnụmara Jalam, na ọnụmara Kora. Ndị a bụ ọnụmara ụmụ Oholibama nwa Ana, nwunye Ịsọ. 
\li4  
\v 19 Ndị a niile bụ ụmụ ndị ikom Ịsọ (ya bụ, Edọm). Ndị a bụkwa ọnụmara ha. 
\b  
\li1  
\v 20 Ndị a bụ ụmụ ndị ikom Sia onye Hor, ndị bi nʼakụkụ ala ahụ: 
\li2 Lotan, Shobal, Zibiọn, Ana,  
\v 21 Dishọn, Eza na Dishan. Ụmụ ndị ikom Sia nʼala Edọm, ha bụ ndị ọnụmara Hor. 
\li1  
\v 22 Ụmụ ndị ikom Lotan bụ, 
\li2 Hori na Homam. Timna bụkwa nwanne nwanyị Lotan. 
\li1  
\v 23 Ụmụ ndị ikom Shobal bụ, 
\li2 Alvan, Manahat, Ebal, Shefo na Onam. 
\li1  
\v 24 Ụmụ ndị ikom Zibiọn mụrụ bụ 
\li2 Aịa na Ana. Ana bụ nwoke ahụ chọpụtara isi iyi mmiri ime ala ahụ nke mmiri dị ọkụ si nʼime ya na-asọpụta nʼọzara, mgbe ọ na-elekọta ịnyịnya ibu nna ya Zibiọn. 
\li1  
\v 25 Ụmụ Ana bụ, 
\li2 Dishọn na Oholibama nwa nwanyị Ana. 
\li1  
\v 26 Ụmụ ndị ikom Dishọn bụ, 
\li2 Hemdan na Eshban na Itran na Keran. 
\li1  
\v 27 Ụmụ ndị ikom Eza bụ, 
\li2 Bilhan na Zaavan na Akan. 
\li1  
\v 28 Ụmụ ndị ikom Dishan bụ, 
\li2 Uz na Aran. 
\li1  
\v 29 Ndị a bụ ndị ọnụmara Hor, 
\li2 ọnụmara Lotan, ọnụmara Shobal, ọnụmara Zibiọn, ọnụmara Ana,  
\v 30 ọnụmara Dishọn, ọnụmara Eza na ọnụmara Dishan. 
\li4 Ndị a niile bụ ndị ọnụmara Hor dịka nkewa ha si dị nʼala Sia. 
\s1 Ndị eze Edọm 
\li4  
\v 31 Ndị a bụ ndị eze chịrị nʼEdọm tupu ndị Izrel enwee eze mbụ ha. 
\li1  
\v 32 Bela, nwa Beoa chịrị dịka eze nʼEdọm. Isi obodo ya bụ Dinhaba. 
\li1  
\v 33 Mgbe Bela nwụrụ, Jobab nwa Zera onye Bozra nọchiri ya dịka eze. 
\li1  
\v 34 Mgbe Jobab nwụrụ, Husham onye si nʼala Teman nọchiri ya dịka eze. 
\li1  
\v 35 Mgbe Husham nwụrụ, Hadad nwa Bedad, onye meriri ndị Midia nʼagha nʼala Moab nọchiri dịka eze. Isi obodo ya bụ Avit. 
\li1  
\v 36 Mgbe Hadad nwụrụ, Samla onye Masrika nọchiri ya dịka eze. 
\li1  
\v 37 Mgbe Samla nwụrụ, Shaul onye sitere na Rehobọt dị nʼakụkụ osimiri nọchiri ya dịka eze. 
\li1  
\v 38 Mgbe Shaul nwụrụ, Baal-Hanan nwa Akboa nọchiri ya dịka eze. 
\li1  
\v 39 Mgbe Baal-Hanan nwa Akboa nwụrụ, Heda nọchiri ya dịka eze. Aha obodo ya bụ Pau. Aha nwunye ya bụ Mehetabel, nwa Matred nwa nwa Mezahab. 
\b  
\li4  
\v 40 Ndị a bụ ndịisi ọnụmara Ịsọ, dịka aha ha si dị, dịka ikwu ha na akụkụ ebe ha bi si dị: 
\li1 Timna, Alva, Jetet, 
\li1  
\v 41 Oholibama, Elaa, Pinon, 
\li1  
\v 42 Kenaz, Teman, Mibza, 
\li1  
\v 43 Magdiel na Iram. 
\li4 Ndị a bụ ndịisi ọnụmara nʼEdọm, dịka ebe obibi ha na ala obi ha si dị. 
\b  
\li4 Nke a bụ ezinaụlọ Ịsọ bụkwa nna ndị Edọm. 
\c 37  
\s1 Nrọ Josef 
\p  
\v 1 Jekọb bigidere nʼala Kenan, ala ahụ nna ya buru ụzọ biri nʼime ya. 
\b  
\p  
\v 2 Nke a bụ usoro akụkọ banyere ezinaụlọ Jekọb. 
\b  
\p Josef, onye gbarala afọ iri na asaa, na-esonyere ụmụnne ya ndị ikom na-azụ igwe anụ ụlọ, ya onwe ya bụ naanị nwantakịrị na-enyere ụmụ Bilha na ụmụ Zilpa ndị nwunye nna ya aka. Ma Josef na-ewetara nna ha akụkọ maka ihe ọjọọ ha na-eme. 
\p  
\v 3 Ma Izrel hụrụ Josef nʼanya karịa ụmụ ya ndị ikom ndị ọzọ niile nʼihi na Josef bụ nwa a mụụrụ ya nʼoge agadi ya. Ọ kwaara ya uwe mwụda nwere ọtụtụ agwa.  
\v 4 Mgbe ụmụnne ya chọpụtara na nna ha hụrụ ya nʼanya karịa onye ọbụla nʼime ha, ha kpọrọ ya asị, ha adịghị agwakwa ya okwu ọma. 
\p  
\v 5 Otu oge, Josef rọrọ nrọ, mgbe ọ kọọrọ ụmụnne ya nrọ a ọ rọrọ, ha kpọrọ ya asị karịa.  
\v 6 Ọ gwara ha, “Geenụ ntị na nrọ a m rọrọ.  
\v 7 Anyị niile nọ nʼubi na-achịkọta ọka, ngwangwa ukwu ọka nke m biliri guzoro ọtọ, ebe ukwu ọka nke unu niile gbara ukwu ọka nke m gburugburu, na-akpọ isiala nye ya.” 
\p  
\v 8 Ụmụnne ya jụrụ ya, “Ị na-akọwa na ọ bụ gị ga-abụ eze anyị? Na ọ bụ gị nʼezie ga-achị anyị?” Ha kpọrọ ya asị karịa nʼihi nrọ ya na okwu ya niile. 
\p  
\v 9 Josef rọkwara nrọ ọzọ, kọkwara ụmụnne ya. Ọ sịrị, “Geenụ ntị, arọrọ m nrọ ọzọ. Ma na nrọ nke ugbu a, anyanwụ na ọnwa na kpakpando iri na otu na-akpọ isiala nye m.” 
\p  
\v 10 Ma mgbe ọ kọọrọ nna ya na ụmụnne ya nrọ a. Nna ya baara ya mba, sị, “Nrọ nke a ị rọrọ bụ nrọ gịnị? Ọ bụ ezie na anyị niile, mụ onwe m na nne gị na ụmụnne gị, ga-abịa na-akpọrọ gị isiala?”  
\v 11 Ụmụnne ya kwosiri ya ekworo nʼihi ya, ma nna ya debere ihe ndị a niile nʼobi ya. 
\s1 Orire e rere Josef 
\p  
\v 12 Ka ọ dị, ụmụnne ya gara ilekọta igwe anụ ụlọ nna ha na Shekem.  
\v 13 Izrel sịrị Josef, “Dịka ị maara, ụmụnne gị nọ na-eche anụ ụlọ na Shekem. Bịa, aga m eziga gị nʼebe ahụ.” 
\p Josef zara sị, “Ọ dị mma.” 
\p  
\v 14 Ya mere, ọ gwara ya, “Gaa ka ị chọpụta ma ihe ọ na-agazikwara ụmụnne gị na igwe anụ ụlọ ndị ahụ nke ọma, ma weghachiri m ozi.” O sitere na Ndagwurugwu Hebrọn zipụ ya. 
\p Ọ bịaruru Shekem,  
\v 15 ma otu nwoke hụrụ ya ka ọ na-awagharị gburugburu nʼọhịa dị nʼebe ahụ, ọ jụrụ ya, “Gịnị ka ị na-achọ?” 
\p  
\v 16 Ọ sịrị, “Ana m achọ ụmụnne m. Biko, ị nwere ike ịgwa m ebe ha nọ na-azụ igwe anụ ụlọ ha?” 
\p  
\v 17 Nwoke ahụ zara sị, “Ha esitela nʼebe a pụọ. Anụrụ m ka ha na-asị, ‘Ka anyị gaa Dọtan.’ ” 
\p Ya mere, Josef gawara Dọtan ịchọ ụmụnne ya. Ọ hụkwara ha nʼebe dị nso na Dọtan.  
\v 18 Ma ha lepụrụ anya hụ ya ka ọ na-abịa, gbaa izu otu ha ga-esi gbuo ya. 
\p  
\v 19 Ha sịrịtara onwe ha, “Lee eze nrọ ahụ ka ọ na-abịa!  
\v 20 Ugbu a, bịanụ, ka anyị gbuo ya, tụba ya nʼime otu olulu ndị a.\f + \fr 37:20 \ft Ebe ala ala olulu mmiri ndị a na-agbasa agbasa karịa ọnụ ha. \xt Jer 38:6,13\f* Anyị ga-asịkwa na anụ ọhịa eriela ya. Mgbe ahụ, anyị ga-ahụkwa ihe nrọ ya niile ga-abụ.” 
\p  
\v 21 Ruben nụrụ ihe a, ma napụtakwa ya site nʼaka ha. Ọ sịrị, “Ka anyị hapụ igbu ya.”  
\v 22 Ruben sịrị ha, “Ka unu hapụ ịkwafu ọbara. Kama tụnyenụ ya nʼime olulu a dị nʼọzara. Ma unu akpatụkwala ya aka.” Ma nzube ya bụ ịnapụta ya site nʼaka ha, dulaara ya nna ya. 
\p  
\v 23 Ya mere, mgbe Josef bịakwutere ụmụnne ya, ha yipụrụ ya uwe mwụda ya, uwe mwụda nwere ọtụtụ agwa o yi nʼahụ.  
\v 24 Ha duru ya tụnye ya nʼime olulu. Ọ bụ olulu tọgbọrọ nʼefu, nke mmiri na-adịghị nʼime ya. 
\p  
\v 25 Mgbe ha nọdụrụ ala bido iri nri, ha leliri anya ha hụ igwe ndị ahịa Ishmel si Gilead. Ịnyịnya kamel ha bu ụda na mgbaa na máá. Ọ bụkwa Ijipt ka ha bu ihe ndị a na-aga. 
\p  
\v 26 Mgbe ahụ, Juda jụrụ ụmụnne ya, “Uru gịnị ka ọ ga-abara anyị igbu nwanne anyị, ma kpuchie ọbara ya?  
\v 27 Bịanụ, ka anyị resi ya ndị Ishmel ndị a, ka aka anyị ghara nʼimetụ ya, nʼihi na nwanne anyị na otu anụ ahụ anyị ka ọ bụ.” Ụmụnne ya gere ya ntị. 
\p  
\v 28 Mgbe ndị ahịa Midia ahụ rutere, ha sitere nʼolulu dọpụta Josef resi ya ndị Ishmel ahụ, ndị kwụrụ ụmụnne Josef iri mkpụrụ shekel ọlaọcha abụọ. Ha duuru Josef gaa Ijipt. 
\p  
\v 29 Ruben mechara lọghachi gaa nʼolulu ahụ, ma ka ọ na-ahụghị Josef nʼime olulu a, ọ dọwara uwe ya.  
\v 30 O jekwuru ụmụnne ya sị ha, “Nwata ahụ anọkwaghị ebe ahụ! Mụ onwe m, olee ebe m ga-ala?” 
\p  
\v 31 Ụmụnne ya gburu otu ewu were uwe Josef bịanye nʼime ọbara ya.  
\v 32 Ha chịịrị uwe mwụda ahụ nwere ọtụtụ agwa jekwuru nna ha sị ya, “Anyị hụrụ uwe a nʼime ọhịa. Leruo ya anya ka ị mara maọbụ uwe mwụda nwa gị.” 
\p  
\v 33 Ọ matara na ọ bụ ya, sị, “E, nke a bụ uwe nwa m nwoke. Ajọ anụ eriela ya. Anụ ọhịa adọkasịala Josef nʼezie.” 
\p  
\v 34 Mgbe ahụ, Jekọb dọwara uwe ya, yiri akwa mkpe, ruo ụjụ ọtụtụ ụbọchị nʼihi nwa ya.  
\v 35 Ụmụ ya ndị ikom na ụmụ ya ndị inyom niile bịara ịkasị ya obi, ma ọ jụrụ ịnabata nkasiobi ọbụla. Ọ sịrị, “Aga m alakwuru nwa m nʼala mmụọ site nʼiru ụjụ.” Nna ya kwagidere akwa nʼihi ya. 
\p  
\v 36 Ugbu a, ndị Midia ahụ rere\f + \fr 37:36 \ft Ire maọbụ ịzụta mmadụ dịka ohu bụ otu nʼime ahịa ndị bi nʼọzara na-azụ. \xt Jen 17:12; 37:26\f* Josef nʼIjipt, resi ya Pọtifa, otu nʼime ndịisi na-ejere Fero ozi, onye bụ onyeisi ndị nche Fero, bụ eze Ijipt. 
\c 38  
\s1 Juda na Tama 
\p  
\v 1 Nʼoge ahụ, Juda hapụrụ ụmụnne ya gaa binyere otu nwoke onye Adulam a na-akpọ Hira.  
\v 2 Nʼebe ahụ, Juda hụrụ otu nwaagbọghọ, nwa otu nwoke onye Kenan, aha ya bụ Shua. Ọ lụrụ ya ma bakwuru ya.  
\v 3 Ọ tụụrụ ime mụọ nwa nwoke, onye Juda gụrụ aha Ịa  
\v 4 Nwunye ya dịkwara ime ọzọ mụta nwa nwoke nke ya bụ nwunye ya gụrụ Onan.  
\v 5 Ọ mụkwara nwa nwoke ọzọ, onye ọ kpọrọ Shela. Ọ bụ na Kezib ka ọ mụrụ ya. 
\p  
\v 6 Juda lụtaara Ịa, ọkpara ya, nwunye onye aha ya bụ Tama.  
\v 7 Ma nʼihi na Ịa, ọkpara Juda, dị njọ nʼanya \nd Onyenwe anyị\nd*. \nd Onyenwe anyị\nd* gburu ya. 
\p  
\v 8 Mgbe ahụ, Juda sịrị Onan, “Bakwuru nwunye nwanne gị ka ịkuchie ya, ka i si otu a wulite mkpụrụ maka nwanne gị.”  
\v 9 Onan ma na mkpụrụ a agaghị abụ nke ya. Nʼihi ya, mgbe ọbụla ọ bakwuru nwunye nwanne ya, ọ na-anyụsa mkpụrụ nwa ya nʼala, ime ka ọ ghara inye nwanne ya nwoke nwa.  
\v 10 Ma ihe a o mere jọrọ njọ nʼanya \nd Onyenwe anyị\nd*. Nʼihi ya \nd Onyenwe anyị\nd* gbukwara ya. 
\p  
\v 11 Juda sịrị nwunye nwa ya, bụ Tama, “Laa nʼụlọ nna gị nọrọ dịka nwanyị di ya nwụrụ tutu Shela nwa m nwoke etoo.” Ma echiche ya bụ, “ka ọ ghara ịnwụ dịka ụmụnne ya.” Tama lara gaa biri nʼụlọ nna ya. 
\p  
\v 12 Mgbe ọtụtụ oge gasịrị, nwunye Juda nwa Shua nwụrụ. Mgbe oge nkasiobi ya gasịrị, Juda jere Timna, ya na enyi ya Hira, onye Adulam, ilekọta ndị na-akpụchapụ igwe ewu na atụrụ ya ajị. 
\p  
\v 13 A gwara Tama sị ya, “Nna di gị na-aga Timna ịkpacha atụrụ ya ajị.”  
\v 14 O yipụrụ uwe mkpe ya, were akwa mkpuchi kpuchie onwe ya gaa nọdụ ala nʼọnụ ụzọ ama Enayim, nke dị nʼụzọ e si aga Timna. O mere otu a nʼihi na ọ matara na Shela etoola, ma enyeghị ya ka ọ bụrụ nwunye ya. 
\p  
\v 15 Mgbe Juda hụrụ ya, o chere na ọ bụ otu nwanyị akwụna, ebe ọ bụ na o kpuchiri ihu ya.  
\v 16 Ma ebe ọ mataghị na ọ bụ nwunye nwa ya, o jekwuru ya ebe ọ nọdụrụ ala nʼakụkụ ụzọ sị ya, “Bịa, kwere ka mụ na gị dinaa.” 
\p Tama jụrụ, “Gịnị ka ị ga-enye m ma ọ bụrụ na m kwere ka mụ na gị dinaa?” 
\p  
\v 17 Ọ zara, “Aga m ezitere gị otu nwa ewu site nʼigwe ewu na atụrụ m.” 
\p Ọ jụrụ, “Ị ga-enye m ihe akaebe ruo mgbe ị ga-ezite ya?” 
\p  
\v 18 Ọ sịrị, “Kedụ ihe akaebe m ga-enye gị?” 
\p Ọ zara, “Mgbaaka akara gị na eriri ya, na mkpanaka dị gị nʼaka.” O nyere ya ihe ndị a. Ọ bakwuru ya nke mere na ọ tụụrụ ime.  
\v 19 Mgbe o si nʼebe ahụ pụọ, o yipụrụ akwa ahụ o ji kpuchie ihu ya, yirikwa uwe mkpe ya. 
\p  
\v 20 Mgbe Juda zigara enyi ya onye Adulam ka ọ gaa wegara ya nwa ewu ahụ, ma nataghachi ihe ibe ahụ, ọ hụghị ya.  
\v 21 Ọ jụrụ ndị ikom bi nʼebe ahụ sị, “Olee nwanyị akwụna ụlọ arụsị ahụ na-anọdụ nʼọnụ ụzọ ama Enayim?” 
\p Ha sịrị, “O nweghị nwanyị akwụna ụlọ arụsị nọrọla nʼebe a.” 
\p  
\v 22 Ya mere, ọ laghachiri gaa gwa Juda, “Ahụghị m ya. Ọzọkwa, ndị ikom ndị bi nʼebe ahụ sịrị, ‘O nweghị nwanyị akwụna\f + \fr 38:22 \ft Nʼoge ochie, ụmụ nwanyị akwụna bụ ndị na-efe chi ndị ha na-ewe ka chi ọmụmụ. \xt Jen 38:21\f* ụlọ arụsị nọrọla nʼebe a.’ ” 
\p  
\v 23 Juda zara, “Ka o jide ihe niile o ji, ma ọ bụghị otu a anyị ga-aghọ ihe ọchị. Lee, ezigarala m ya nwa ewu a, ma gị onwe gị achọtaghị ya.” 
\p  
\v 24 Mgbe ọnwa atọ gasịrị, ozi ruru Juda ntị sị, “Tama nwunye nwa gị gbara akwụna, bịa site nʼịgba akwụna dịrị ime.” 
\p Juda sịrị, “Kpọpụtanụ ya ka akpọọ ya ọkụ.” 
\p  
\v 25 Ma mgbe ha kpọ ya na-apụta, o zigara nna di ya ozi, sị, “Ọ bụ nwoke nwee ihe ndị a tụwara m ime. Ọ sịkwara, Leruo anya ma ị ga-amata onye nwe ihe ndị a: mgbaaka akara a na eriri ya, na mkpanaka a.” 
\p  
\v 26 Juda ghọtara ha, sị, “Ọ bụ onye ezi omume karịa m, ebe ọ bụ na m jụrụ ịkpọrọ ya kpọnye nwa m nwoke Shela ka ọ bụrụ nwunye ya.” O dinakwaghị ya ọzọ. 
\p  
\v 27 Mgbe oge ọmụmụ nwa ya ruru, ejima ka ahụrụ nʼakpanwa ya.  
\v 28 Mgbe ọ na-amụ ha, otu nʼime ha sepụtara aka ya. Nwanyị na-aghọ nwa weere eriri na-acha uhie uhie kee ya na nkwoji aka kwuo sị, “Ọ bụ nke a bụ ụzọ pụta.”  
\v 29 Ma nwa ahụ mesịrị sekpuo aka ya, nwanne ya nke ọzọ eburu ya ụzọ pụta. Nwanyị ahụ sịrị, “Ọ bụ otu a ka ị si tikapụta?” A kpọrọ ya Perez.\f + \fr 38:29 \ft Perez bụ nna ochie Devid. \xt Rut 4:18-22; Mat 1:3-6; Luk 3:32-33\f* 
\v 30 Emesịa, nwanne ya, nke bu eriri uhie uhie ahụ na nkwoji aka pụtakwara. A kpọrọ ya Zera. 
\c 39  
\s1 Josef na nwunye Pọtifa 
\p  
\v 1 A kpọọrọ Josef gaa nʼala Ijipt. Pọtifa, bụ nwoke Ijipt, otu nʼime ndịisi na-ejere Fero ozi, na onyeisi ndị agha na-eche nche zụụrụ ya site nʼaka ndị Ishmel, bụ ndị duuru ya gaa nʼebe ahụ. 
\p  
\v 2 \nd Onyenwe anyị\nd* nọnyeere Josef, nke mere na ihe gaara ya nke ọma nʼụlọ nna ya ukwu onye Ijipt.  
\v 3 Nna ya ukwu hụrụ na \nd Onyenwe anyị\nd* nọnyeere Josef, hụkwa na \nd Onyenwe anyị\nd* na-eme ka ihe niile o mere gaara ya nke ọma.  
\v 4 Josef hụtara amara nʼihu ya, ghọọ onyeozi nke aka ya. Pọtifa mere ya onye na-elekọta ezinaụlọ ya. Nyefee ya ihe niile o nwere ka ọ bụrụ onye na-elekọta ha.  
\v 5 Site nʼoge a, o mere ka ọ bụrụ onye na-elekọta ezinaụlọ ya na ihe niile o nwere, \nd Onyenwe anyị\nd* gọziri ezinaụlọ onye Ijipt ahụ nʼihi Josef. Ngọzị \nd Onyenwe anyị\nd* dịkwasịrị nʼihe niile Pọtifa nwere, ma ihe o nwere nʼụlọ ma ndị o nwere nʼubi ya.  
\v 6 Ya mere, ọ hapụrụ ihe niile o nwere nʼaka Josef. Nke a mere na ọ mazighị ihe ọzọ na-eme, ma ọ bụghị nri nke ọ na-eri.\f + \fr 39:6 \ft Usoro iri nri ndị Ijipt dị iche site na nke ndị Juu, nʼihi ụzọ esi akwado ha tupu e rie ha. \xt Jen 43:32\f* 
\p Josef nʼonwe ya mara mma ahụ dịkwa mma ile anya.  
\v 7 Mgbe oge nta gasịrị, nwunye Pọtifa lere Josef anya sị ya, “Bịa ka anyị abụọ dinaa.” 
\p  
\v 8 Ma Josef jụrụ. Ọ gwara nwunye nna ya ukwu sị, “Lee, nna m ukwu anaghị echegbu onwe ya banyere ihe ọbụla nʼụlọ a. O werela ihe niile o nwere nyefee m nʼaka ka m lekọta ha anya.  
\v 9 O nweghị onye ọnọdụ ya dị elu karịa nke m nʼụlọ a. O gbochighị m ihe ọbụla ma ọ bụghị gị, nʼihi na ị bụ nwunye ya. Olee otu m ga-esi mee oke ihe ọjọọ dị otu a, mee mmehie megide Chineke.”  
\v 10 Ọ bụ ezie na nwanyị a nọgidere na-enye Josef nsogbu site nʼụbọchị ruo ụbọchị ma Josef jụrụ iso ya dinaa, jụkwa ịnọnyere ya. 
\p  
\v 11 Otu ụbọchị, Josef batara nʼime ụlọ ịrụ ọrụ ya. O nweghị ndị ọzọ na-eje ozi nọ nʼime ụlọ nʼụbọchị ahụ.  
\v 12 Nwunye Pọtifa jidere Josef nʼuwe mwụda ya, rịọọ ya sị ya, “Bịa ka anyị dinaa.” Ma Josef si nʼime ụlọ ahụ gbapụ, hapụ uwe mwụda ya nʼaka nwunye Pọtifa. 
\p  
\v 13 Mgbe nwanyị a hụrụ na Josef agbapụla, hapụ uwe ya,  
\v 14 ọ kpọrọ ndị na-eje ozi nʼezinaụlọ ya sị ha, “Lee, onye Hibru a di m kpọbatara nʼụlọ a chọrọ iji anyị gwurie egwu. Ọ bịakwutere m nʼime ụlọ chọọ ka mụ na ya dinaa. E tiri m mkpu nʼolu ike.  
\v 15 Mgbe ọ nụrụ ka m welitere olu m tie mkpu enyemaka m tiri, o sitere nʼime ụlọ a gbapụ, ma hapụrụ m uwe ya.” 
\p  
\v 16 Nwanyị a debere uwe ahụ nʼakụkụ ya ruo mgbe nna ya ukwu lọtara nʼụlọ.  
\v 17 Mgbe ahụ, ọ gwara di ya okwu ndị a sị, “Onye ohu Hibru a ị kpọbataara anyị bakwutere m iji m gwurie egwu.  
\v 18 Ma mgbe m welitere olu tie mkpu enyemaka o sitere nʼụlọ gbapụ hapụrụ m uwe ya.” 
\p  
\v 19 Mgbe nna ya ukwu nụrụ ihe nwunye ya gwara ya sị, “Otu a ka ohu gị si meso m mmeso,” o were iwe dị ọkụ.  
\v 20 Nna ukwu Josef weere ya tụnye nʼụlọ mkpọrọ, nʼebe a na-etinye ndị mkpọrọ eze Ijipt. 
\p Ma ebe ahụ Josef nọ nʼụlọ mkpọrọ,  
\v 21 \nd Onyenwe anyị\nd* nọnyeere ya. O meere ya ebere, mekwa ka o nweta ihuọma nʼebe onyeisi ndị nche ụlọ mkpọrọ ahụ nọ.  
\v 22 Onyeisi ndị na-eche ụlọ mkpọrọ mere Josef onyeisi ndị mkpọrọ niile nọ nʼime ụlọ mkpọrọ ahụ. Josef ghọrọ onye a na-ajụ otu ihe si aga nʼime ụlọ mkpọrọ ahụ.  
\v 23 Onyeisi ndị nche ụlọ mkpọrọ ahụ enyeghịkwa onwe ya nsogbu maka ihe ọbụla. Nʼihi na \nd Onyenwe anyị\nd* nọnyeere Josef, mee ka ihe ọbụla ọ na-eme gaa nke ọma. 
\c 40  
\s1 Josef akọwaa nrọ 
\p  
\v 1 Mgbe ụfọdụ oge gasịrị, onye na-ebu iko ihe ọṅụṅụ eze Ijipt na onye na-esiri ya nri mehiere megide nna ha ukwu, eze Ijipt.  
\v 2 Nʼihi ya, Fero were iwe megide ndị ozi ya abụọ ndị a, onyeisi ndị na-ebu iko ya na onye na-esiri ya nri.  
\v 3 O tinyere ha na nga, nʼụlọ mkpọrọ dị nʼụlọ onyeisi ndị nche, ebe ahụ a tụbara Josef.  
\v 4 Onyeisi ndị nche mere Josef onye na-elekọta ha. 
\p Ha nọrọ nʼụlọ mkpọrọ ọtụtụ ụbọchị.  
\v 5 Ha abụọ, onye ahụ na-esiri eze nri, na onye na-ebu iko eze Ijipt, rọrọ nrọ nʼotu abalị. Nrọ nke onye ọ bụla nwere nkọwa nke ya. 
\p  
\v 6 Mgbe chi bọrọ, Josef bịakwutere ha hụ na ihu ha gbarụrụ agbarụ.  
\v 7 Nʼihi ya, ọ jụrụ ndị ozi Fero ndị a ha na ya nọ nʼụlọ mkpọrọ dị nʼụlọ nna ya ukwu sị ha, “Gịnị mere ihu unu ji gbarụọ taa?” 
\p  
\v 8 Ha zara sị ya, “Anyị rọrọ nrọ ọjọọ, ma onye nkọwa ya adịghị.” 
\p Josef sịrị ha, “Ọ bụghị Chineke nwee ike ịkọwa nrọ? Kọọrọnụ\f + \fr 40:8 \ft Maọbụ, \fqa Unu zere m nrọ unu\f* m ha.” 
\p  
\v 9 Onyeisi ndị na-ebu iko kọọrọ Josef nrọ ya. Ọ sịrị ya, “Arọrọ m nrọ hụ osisi vaịnị nʼihu m.  
\v 10 Osisi vaịnị a nwere alaka atọ. Mgbe m nọ na-ele anya, osisi vaịnị ahụ mara ifuru, mịpụta mkpụrụ nʼụyọkọ nʼụyọkọ, ha chakwaa.  
\v 11 Ebe ọ bụ nʼiko Fero dị m nʼaka, a ghọọrọ m mkpụrụ vaịnị ndị a, pịpụta mmiri ha pịnye nʼime iko mmanya Fero, bunye ya ka ọ ṅụọ.” 
\p  
\v 12 Josef sịrị ya, “Nke a bụ ihe nrọ gị pụtara. Alaka atọ ahụ bụ abalị atọ.  
\v 13 Nʼime abalị atọ Fero ga-akpọpụta gị, mee ka i nwere onwe gị. Fero ga-enyeghachikwa gị ọrụ gị. Ị ga-etinyekwa Fero iko ya nʼaka dịka i si eme na mbụ mgbe ị bụ onye na-ebu iko ya.  
\v 14 Mgbe ihe gaara gị nke ọma, chetakwa m, ma gosi m obiọma, gwara m Fero ka o si nʼụlọ mkpọrọ a wepụta m.  
\v 15 Ọ bụ ntọrọ ka atọọrọ m site nʼala ndị Hibru. Nʼotu aka ahụ, nʼebe a ọ dịkwaghị ihe ọjọọ ọ bụla m mere nke kwesiri ka atụnye m nʼụlọ mkpọrọ a.” 
\p  
\v 16 Mgbe onyeisi ndị na-esiri Fero nri hụrụ na nkọwa nrọ ahụ dị mma, ọ sịrị Josef, “Mụ onwe m, na nrọ m nke m, ebu m nkata achịcha atọ nʼisi.  
\v 17 Nkata nke dị nʼelu jupụtara na achịcha dị iche iche e gheere eze, bụ Fero. Ma ụmụ nnụnụ bịara na-eri achịcha ndị ahụ dị na nkata m bụ nʼisi.” 
\p  
\v 18 Josef zara sị ya, “Lee ihe nrọ gị pụtara. Nkata atọ ahụ bụ abalị atọ.  
\v 19 Nʼime abalị atọ ka Fero ga-esi nʼụlọ mkpọrọ kpọpụta gị, nye iwu ka e bepụ gị isi, kwụba gị nʼelu osisi. Ụmụ nnụnụ ga-erichapụ anụ ahụ gị.” 
\p  
\v 20 Nʼabalị nke atọ, site nʼụbọchị ndị a rọrọ nrọ ha, Fero mere mmemme ncheta ọmụmụ ya. Ọ kpọrọ ndị niile na-ejere ya ozi oriri. O ziri ozi ka a gaa nʼụlọ mkpọrọ kpọpụta onyeisi ndị na-ebunye ya iko ihe ọṅụṅụ na onyeisi ndị na-esiri ya nri.  
\v 21 O nyeghachiri onyeisi ndị na-ebu iko ya ọrụ ya, weghachi ya nʼọnọdụ ya. Nwoke a bunyekwara Fero iko ya dịka o si eme na mbụ.  
\v 22 Ma ọ kwụgburu onyeisi ndị na-esiri ya nri, dịka Josef si kọwaa nrọ ha. 
\p  
\v 23 Ma onyeisi ndị ahụ na-ebu iko eze echetaghị Josef. O chefuru ya. 
\c 41  
\s1 Nrọ Fero na nkọwa ya 
\p  
\v 1 O ruo mgbe afọ abụọ gasịrị, Fero rọrọ nrọ hụ onwe ya ka o guzo nʼakụkụ mmiri Naịl.  
\v 2 Nʼebe ahụ, ọ hụrụ ehi asaa ndị si nʼosimiri Naịl na-apụta. Ehi ndị a buru ibu, maa mma. Ahụ ha na-akwọ mụrụmụrụ. Ha pụtara, bido ịta nri nʼetiti ahịhịa riidi.  
\v 3 Nʼatụfughị oge, ehi asaa ọzọ soro ha nʼazụ sikwa nʼosimiri Naịl na-apụta. Ma ehi ndị a tara ahụ nke ukwuu. Ha bụ nnọọ ọkpụkpụ ọkpụkpụ, jọọ njọ ile anya. Ha bịara guzo nʼakụkụ ehi ndị ahụ buru ibu.  
\v 4 Mgbe ahụ, ehi ndị a bụ naanị ọkpụkpụ ọkpụkpụ bịara richapụ ehi ndị ahụ buru ibu. Mgbe nke a mere Fero kwolitere. 
\p  
\v 5 Emesịa, Fero rahụkwara ụra ọzọ, rọọ nrọ nke ugboro abụọ, hụ ogbe ọka asaa ndị mịrị nʼotu ukwu ọka. Ogbe ọka ndị a buru ibu maa ezi mma.  
\v 6 Emesịa, ọ hụkwara ogbe ọka asaa ọzọ ka ha mịkwara nʼotu ukwu ọka ahụ. Ma ndị a ọ hụrụ kpọnwụsịrị akpọnwụ, fịkpọkwa afịkpọ. Ọ bụ ikuku si nʼọwụwa anyanwụ mere ka ha kpọnwụọ.  
\v 7 Ogbe ọka ndị a fịkpọrọ afịkpọ loro ogbe ọka asaa ndị ahụ buru ibu. Fero kwolitere hụ na ihe ndị a bụ nrọ. 
\p  
\v 8 Mgbe chi bọrọ, o nweghị udo na mmụọ ya. O ziri ozi kpọkọta ndị majiki niile, na ndị ọkachamara niile nke Ijipt. Fero kọọrọ ha ihe ọ rọrọ na nrọ. Ma ọ dịghị onye nwere ike ịkọwara ya ihe nrọ ya pụtara. 
\p  
\v 9 Ma nʼoge ahụ, onyeisi ndị na-ebu iko jekwuuru Fero gwa ya sị, “Taa ka m chetara mmehie m.  
\v 10 Oge ahụ Fero were iwe megide ndị na-ejere ya ozi, o tinyere mụ na onyeisi ndị na-esi nri nʼụlọ mkpọrọ nke dị nʼebe onyeisi ndị nche eze bi.  
\v 11 Onye ọbụla nʼime anyị abụọ rọrọ nrọ nʼotu abalị, nrọ ọbụla nwekwara nkọwa nke ya.  
\v 12 O nwere nwokorobịa onye Hibru anyị na ya nọ nʼụlọ mkpọrọ nʼoge ahụ. Ọ bụ ohu onyeisi ndị nche eze. Anyị kọọrọ ya nrọ anyị rọrọ. Ọ kọwakwaara anyị ihe nrọ anyị pụtara nye onye ọbụla nkọwa nke nrọ ya.  
\v 13 Ihe niile mere dịka o si kọwara anyị. E nyeghachiri m ọnọdụ m, ma kwụba onye nke ọzọ nʼosisi.” 
\p  
\v 14 Ya mere Fero ziri ozi ka a kpọọ Josef. E mere ngwangwa wepụta ya site nʼụlọ mkpọrọ ahụ. Mgbe ọ kpụchara afụọnụ\f + \fr 41:14 \ft Otu ihe e ji maara ndị Ijipt bụ ịkpụcha agịrị isi na afụọnụ ha, ma nke a bụghị omenaala ndị Juu.\f* ya, gbanwee uwe ya, ọ bịakwara nʼihu Fero. 
\p  
\v 15 Fero gwara Josef sị, “Arọrọ m nrọ ma o nweghị onye ọbụla nwere ike ịkọwara m ihe nrọ m rọrọ pụtara. Ma anụla m na a kọọrọ gị nrọ a rọrọ, i nwere ike ịkọwa ihe nrọ ahụ pụtara.” 
\p  
\v 16 Josef zara sị ya, “Enweghị m ike ịkọwa nrọ nʼike aka m. Ma Chineke ga-enye Fero ọsịsa udo dịka ọ chọrọ.” 
\p  
\v 17 Mgbe ahụ, Fero malitere ịkọwara Josef nrọ ya. O kwuru sị, “Eguzoro m nʼakụkụ osimiri Naịl na nrọ m.  
\v 18 Mgbe ahụ, ahụrụ m ehi asaa si na mmiri ahụ pụta. Ehi ndị a mara abụba, ma gbaa agba. Ha bidokwara ịta nri nʼetiti ahịhịa riidi.\f + \fr 41:18 \fq Ahịhịa riidi \ft bụ ahịhịa na-epu nʼakụkụ osimiri Naịl\f* 
\v 19 Emesịa, a hụrụ m ehi asaa ọzọ ka ha sikwa nʼosimiri ahụ pụta. Ehi ndị a ejighị ahụ. Ha bụ ọkpụkpụ ọkpụkpụ, jọọ njọ ile anya. Nʼezie, ahụtụbeghị m ụdị ehi dị otu a nʼala Ijipt niile.  
\v 20 Ehi asaa ndị a jọrọ njọ riri ehi ndị ahụ buru ibu, bụ ndị bu ha ụzọ si nʼosimiri ahụ pụta.  
\v 21 Ma mgbe ha risiri ehi ndị a, nri ahụ emeghị ka ụdịdị ha gbanwee. Ha dịkwa otu ha dị. Mgbe m hụsịrị ihe a, etetara m nʼụra. 
\p  
\v 22 “Mgbe m rọrọ nrọ ọzọ, a hụrụ m ogbe ọka asaa nke mịrị nʼotu ukwu ọka. Ọka asaa ndị a buru ibu, dị mma ile anya.  
\v 23 Ogbe ọka asaa ọzọ mịkwara nʼelu ukwu ọka ahụ, ma ndị a kpọnwụrụ akpọnwụ, fịkpọkwa afịkpọ nʼihi nʼikuku si nʼọwụwa anyanwụ chakpọrọ ha.  
\v 24 Ma ọka ndị a fịkpọrọ afịkpọ lodara ọka asaa ndị ahụ mara mma. Akọọlara m ndị majiki ihe ndị a, ma ọ dịghị onye nʼime ha nwere ike ịkọwara m ihe nrọ ndị a pụtara.” 
\p  
\v 25 Mgbe ahụ, Josef sịrị Fero, “Nrọ abụọ Fero rọrọ pụtara otu ihe. Chineke esitela na nrọ ndị a gwa Fero ihe ọ na-aga ime.  
\v 26 Ehi asaa ndị ahụ buru ibu bụ afọ asaa. Ogbe ọka asaa ndị ahụ buru ibu bụkwa afọ asaa. Ọ bụ otu nrọ ahụ, ọ bụ ezie na ị rọrọ ya ugboro abụọ.  
\v 27 Ehi asaa ndị ọzọ ahụ dị ọkpụkpụ ọkpụkpụ ndị pụtara mgbe ndị nke mbụ pụtachara bụ afọ asaa. Otu a kwa ogbe ọka ndị ọzọ fịkpọrọ afịkpọ nke ikuku si nʼọwụwa anyanwụ mere ka ha fịkpọọ bụ afọ asaa. Ha na-egosi afọ asaa mgbe oke ụnwụ ga-adị. 
\p  
\v 28 “Dịka m gwara Fero na mbụ, Chineke egosila gị ihe ọ chọrọ ime.  
\v 29 Afọ asaa na-abịa ga-abụ afọ asaa mgbe nri ga-adị ukwuu nʼala Ijipt niile.  
\v 30 Emesịa afọ asaa oke ụnwụ ga-eso ha. Mgbe ahụ, a ga-echefu ụba niile nke ala Ijipt. Ụnwụ a ga-ala obodo nʼiyi.  
\v 31 Agaghị echetakwa na e nwere oge ịba ụba ihe oriri nʼala a, nʼihi oke ụnwụ ahụ nke ga-eso ya ga-adị oke ukwuu.  
\v 32 Ihe mere Fero ji rọọ nrọ a ugboro abụọ bụ nʼihi na Chineke ekpebiela na ihe ndị a ga-emezuriri. Chineke ga-emekwa ya nʼoge na-adịghị anya. 
\p  
\v 33 “Ma ugbu a, ka Fero chọọ onye nwere ezi nghọta na amamihe. Ya mee ya onyeisi ọchịchị nʼala Ijipt niile.  
\v 34 Ka Fero mee nhọpụta ndị nlekọta ala Ijipt. Ka e debe otu ụzọ nʼime ụzọ ise nke nri niile a ga-enweta nʼoge ahụ nri ga-adị ukwuu nʼala Ijipt.  
\v 35 Ka ha kpokọtaa nri niile ga-adị nʼoge ịba ụba nke ihe oriri, nke ga-adị nʼafọ ndị a na-abịa. Ka ha kpokọta ha nʼụlọ ichebe nri nke ga-adị nʼokpuru ọchịchị Fero. Ka ọ bụrụ nri e debere nʼobodo dị iche iche.  
\v 36 A ga-echebe nri ndị a nke ọma maka ndị bi nʼala a, ka ọ bụrụ nri a ga-eri nʼime afọ asaa ndị ahụ nke ụnwụ ga-adị nʼala Ijipt, ka ụnwụ ghara ibibi ala a.” 
\p  
\v 37 Ntụpụta ahụ dị mma nʼanya Fero na ndịisi ọchịchị ya.  
\v 38 Fero jụrụ ndịisi ọchịchị ya, “Anyị ga-achọtali onye ọzọ dịka nwoke a, onye mmụọ nke Chineke dị nʼime ya?” 
\p  
\v 39 Ya mere Fero tụgharịrị sị Josef, “Ebe Chineke kpugheere gị ihe ndị a, o nweghị onye ọzọ nwere ezi nghọta na amamihe dịka gị.  
\v 40 Gị onwe gị ga-abụ onye na-elekọta ụlọeze m. Ndị m niile ga-erube isi nʼiwu ọbụla i nyere. Ọ bụ naanị nʼocheeze ka m ga-eji dị ukwuu karịa gị.” 
\s1 Josef aghọọ onye na-achị Ijipt 
\p  
\v 41 Fero gwara Josef, “Lee, emeela m gị onye nlekọta ala Ijipt niile.”  
\v 42 Mgbe ahụ, Fero gbapụtara mgbaaka\f + \fr 41:42 \ft Mgbaaka a na-agbanye na mkpịsịaka bụ ihe e ji emesi okwu ike. \xt Est 3:10\f* eze ya gbanye ya Josef nʼaka. O yikwasịkwara Josef uwe e ji ezi akwa ọcha duo, nyanye ya ihe ịnya nʼolu nke e ji ọlaedo kpụọ.  
\v 43 O mere ka ọ nyaa ịnyịnya ụgbọ ya nke abụọ. Ndị oti mkpu na-etikwa nʼihu ya, “Gbuonụ ikpere nʼala.” Otu a ka Fero si mee Josef onye na-achị ala Ijipt niile. 
\p  
\v 44 Fero gwakwara Josef sị, “Ọ bụ mụ onwe m bụ Fero! O nweghị onye ọbụla ga-ewelita aka maọbụ ụkwụ ya nʼala Ijipt niile ma ọ bụghị site nʼike i nyere ya.”  
\v 45 Fero gụrụ Josef aha Zafenat-Pania.\f + \fr 41:45 \ft Aha a pụtara, Onye nwere ike dị ka chi nke nwere ike ndụ na ọnwụ.\f* Ọ kpọnyekwara ya, Asenat, nwa Pọtifera, onye nchụaja obodo a na-akpọ On,\f + \fr 41:45 \ft Pọtifera bụ onye nchụaja nke obodo On.\f* ka ọ bụrụ nwunye ya. Josef bịara gazuo ala Ijipt. 
\p  
\v 46 Josef gbara iri afọ atọ mgbe o bidoro iguzo nʼihu Fero eze Ijipt. O si nʼihu Fero pụọ, malite ijegharị ebe niile nʼala Ijipt.  
\v 47 Nʼafọ asaa ahụ nke a na-eriju afọ, ala mepụtara nri nʼebe ọ dị ukwuu.  
\v 48 Nʼime afọ asaa ndị a nke nri juru ebe niile nʼIjipt, Josef chịkọtara nri niile nke si nʼubi, ma chekwaa ha nʼụlọ e wuru maka iche nri nʼobodo niile ahụ. Nʼobodo ọbụla, ka ọ na-etinye ihe oriri nke si nʼubi gbara ya gburugburu.  
\v 49 Josef chekwara ọka dị ukwuu nʼọnụọgụgụ, dịka aja dị nʼakụkụ osimiri. A kwụsịrị ịgụ ha ọnụ nʼihi na ha hiri nne nke ukwuu nke na ha enweghị ọnụọgụgụ. 
\p  
\v 50 Tupu oge ụnwụ ahụ ebido, Asenat nwa nwanyị Pọtifera, onye nchụaja nke On, mụtara Josef ụmụ ndị ikom abụọ.  
\v 51 Josef gụrụ ọkpara ya Manase,\f + \fr 41:51 \ft Aha a bụ Manase pụtara Nchefu.\f* nʼihi na ọ sịrị, “Chineke emeela ka m chefuo ahụhụ m niile, mekwa ka m chefuo ndị ezinaụlọ nna m.”  
\v 52 Josef gụrụ nwa ya nke abụọ Ifrem.\f + \fr 41:52 \ft Ifrem pụtara Ụba.\f* Ọ sịrị, “Nʼihi na Chineke emeela ka m mịa mkpụrụ nʼala nke ahụhụ m.” 
\p  
\v 53 Afọ asaa nke ụba nri nke dịrị nʼala Ijipt mechara gabiga.  
\v 54 Afọ asaa nke ụnwụ bidoro bịawa dịka Josef kwuru. Ụnwụ nọ nʼobodo niile, ma nʼala Ijipt niile nri dị.  
\v 55 Ka agụ jidere ala Ijipt niile, ndị mmadụ tikuru Fero ka o nye ha nri. Ma Fero gwara ndị Ijipt niile, “Jekwurunụ Josef. Ihe ọbụla ọ gwara unu meenụ ya.” 
\p  
\v 56 Mgbe ụnwụ ahụ gbasara ruo nʼakụkụ niile nke ala ahụ, Josef meghepụrụ ụlọ ichebe nri niile bido iresi ndị Ijipt nri, nʼihi na ụnwụ ahụ dị njọ nʼala Ijipt niile.  
\v 57 Mba niile bịara Ijipt ịzụ nri site nʼaka Josef nʼihi na ụnwụ ahụ dị njọ nʼụwa niile. 
\c 42  
\s1 Ụmụnne Josef abịaruo Ijipt 
\p  
\v 1 Ugbu a, Jekọb nụrụ na ọka dị nʼIjipt. Ọ sịrị ụmụ ya, “Kedụ ihe anyị jiri nọrọ na-elerịta onwe anyị anya”  
\v 2 Ọ sịrị, “Lee anụrụ m na ọka dị nʼIjipt. Gbadatanụ nʼebe ahụ zụtara anyị ọka ka anyị dị ndụ ghara ịnwụ.” 
\p  
\v 3 Ụmụnne Josef iri ndị ahụ gbadara Ijipt ịzụta ọka.  
\v 4 Ma Jekọb ekweghị ka Benjamin nwanne nta Josef soro ha gaa, nʼihi na ọ tụrụ egwu na ihe ndaba ọjọọ nwere ike ịbịakwasị ya.  
\v 5 Otu a, ụmụ Izrel so nʼọtụtụ ndị ọzọ ndị jekwara ịzụrụ nri nʼIjipt, nʼihi na ụnwụ ahụ dị njọ nʼala Kenan. 
\p  
\v 6 Nʼoge a, Josef na-achị ala Ijipt, bụrụkwa onye iresi ndị obodo ọka dị nʼaka. Ya mere, mgbe ụmụnne Josef rutere, ha bịara hulata kpọọ isiala nye Josef.  
\v 7 Mgbe Josef hụrụ ụmụnne ya, ọ matara ndị ha bụ. Ma ọ kpara agwa dịka onye na-amaghị ha, gwa ha okwu nʼolu ike, sị ha, “Ebee ka unu si bịa?” 
\p Ha zara, “Anyị si ala Kenan bịa. Anyị bịara ịzụrụ nri.” 
\p  
\v 8 Josef matara ụmụnne ya, ma ha onwe ha amataghị onye ọ bụ.  
\v 9 Josef chetakwara nrọ ndị ahụ ọ rọrọ banyere ha. Ọ gwara ha okwu sị ha, “Unu bụ ndị nnyocha. Ịchọpụta adịghị ike ala anyị mere unu ji bịa.” 
\p  
\v 10 Ha zara sị, “Nna anyị ukwu, anyị bụ ndị ohu gị bịara ịzụrụ nri.  
\v 11 Anyị niile bụ ụmụ otu nna. Ndị ohu gị bụ ndị kwesiri ntụkwasị obi. Anyị abụghị ndị nnyopụta.” 
\p  
\v 12 Ma Josef gwara ha sị, “Mba! Unu bịara ịchọpụta akụkụ obodo anyị nke a na-echezighị nke ọma.” 
\p  
\v 13 Ha zara sị ya, “Ndị ohu gị dị ụmụnne iri na abụọ. Ọ bụkwa otu nna mụrụ anyị niile. Nna anyị na nwanne anyị nta, onye ikpeazụ ọ mụrụ nọ na Kenan ugbu a. Ma otu onye nʼime anyị anwụọla.” 
\p  
\v 14 Josef sịrị, “Ihe unu na-akọ na-egosi na unu bụ ndị nnyopụta, dịka m gwara unu.  
\v 15 Nke a ka a ga-eji anwale unu. Nʼaha Fero dị ndụ, unu agaghị esi nʼebe a laa tutu nwanne unu nke nta ahụ abịa nʼebe a.  
\v 16 Zipụnụ otu onye nʼime unu ka ọ gaa kpọta nwanne unu nwoke. Ma aga m etinye ndị fọdụrụ nʼụlọ mkpọrọ, tutu m chọpụta ma ihe unu kwuru ọ bụ eziokwu maọbụ ụgha. Ọ bụrụ ụgha nʼezie, dịka Fero na-adị ndụ, unu bụ ndị nnyopụta.”  
\v 17 O tinyere ha niile nʼụlọ mkpọrọ, hapụ ha nʼebe ahụ abalị atọ. 
\p  
\v 18 Josef gwara ha, nʼụbọchị nke atọ, “Nke a bụ ihe unu ga-eme ma dị ndụ, nʼihi na abụ m onye na-atụ egwu Chineke.  
\v 19 Ọ bụrụ na unu bụ ndị ezi mmadụ, ka otu onye nʼime unu nọdụ nʼebe a, nʼụlọ mkpọrọ, ka ndị fọdụrụ buru ọka bulaara ndị ezinaụlọ unu nọ nʼagụụ.  
\v 20 Ma kpọtaranụ m nwanne unu nke nta nʼebe a, nke a ga-egosi na okwu unu bụ eziokwu, na unu agaghịkwa anwụ.” Ha mere otu a. 
\p  
\v 21 Ha gwarịtara onwe ha okwu sị, “Nʼezie, ọ bụ nʼihi nwanne anyị nwoke ka ahụhụ ndị a ji abịakwasị anyị. Anyị hụrụ obi mgbawa ya, mgbe ọ na-arịọ ka anyị chebe ndụ ya, ma anyị egeghị ya ntị. Ọ bụ nke a mere mmekpa ahụ ndị a ji bịakwasị anyị ugbu a.” 
\p  
\v 22 Ruben zara sị ha, “Ọ bụ na mụ agwaghị unu sị unu hapụ imejọ nwantakịrị ahụ, ma unu egeghị ntị? Ugbu a, anyị na-asa ajụjụ banyere ọbara ya.”  
\v 23 Ha amataghị na Josef na-anụ ihe ha na-ekwu, nʼihi na onye nsụgharị okwu nọ nʼetiti ha. 
\p  
\v 24 O sitere nʼebe ha nọ tụgharịa gaa kwaa akwa. Ọ lọghachikwutere ha ọzọ gwakwa ha okwu. O si nʼetiti ha kpọpụta Simiọn kee ya agbụ ka ha na-ele ya anya. 
\p  
\v 25 Josef nyere iwu ka e kpojuo ọka nʼakpa ha, tinyekwara onye ọbụla ego ọ kwụrụ nʼakpa ya. Ọ nyere iwu ka e nye ha ihe ha ga-eri nʼụzọ. Mgbe e mesịrị ihe ndị a,  
\v 26 ha bokwasịrị ịnyịnya ibu akpa ọka ha nʼotu nʼotu. Ha hapụrụ Ijipt lawa. 
\p  
\v 27 Mgbe ha ruru ebe ha nọrọ ọnọdụ abalị, otu nʼime ha meghere akpa ya ka o nye ịnyịnya ibu ya ọka, ọ hụrụ ego ya nʼọnụ akpa ya.  
\v 28 Ọ gwara ụmụnne ya sị, “Lee, e tighachiri ego m kwụrụ. Lee ya nʼakpa ọka m.” 
\p Ike gwụrụ onye ọbụla nʼime ha. Site nʼahụ ịma jijiji ha lerịtara onwe ha anya sị, “Gịnị bụ ihe a Chineke mere anyị?” 
\p  
\v 29 Mgbe ha lakwutere nna ha Jekọb nʼala Kenan, ha kọọrọ ya ihe niile dakwasịrị ha. Ha gwara ya sị,  
\v 30 “Nwoke na-achị ala ahụ gwara anyị okwu nʼolu ike. O mesoro anyị mmeso dịka anyị bụ ndị bịara inyochapụta obodo ha.  
\v 31 Ma anyị gwara ya sị, ‘Anyị bụ ndị kwesiri ntụkwasị obi, ndị na-abụghị ndị nnyopụta obodo.  
\v 32 Anyị dị ụmụnne iri na abụọ ndị nwere otu nna. Otu nʼime anyị anọkwaghị, ma nke ntakịrị na nna anyị nọ na nʼala Kenan taa.’ 
\p  
\v 33 “Mgbe ahụ, nwoke a, onye na-achị ala ahụ, sịrị anyị, ‘Nke a ka m ga-eji mata ma unu bụ ndị ezi mmadụ. Hapụrụnụ m otu nwanne unu. Burunu ọka, bulaara ndị ezinaụlọ unu agụụ na-agụgbu.  
\v 34 Ma kpọtara m nwanne unu nke nta. Mgbe ahụ ka m ga-ama ihe unu bụ. Ma unu bụ ndị nnyopụta maọbụ ndị ezi mmadụ. Mgbe ahụ, aga m ahapụrụ unu nwanne unu. Unu ga na-azụkwa ahịa nʼala a.’ ” 
\p  
\v 35 Mgbe ha bidoro ịwụpụtasị ọka dị nʼakpa ha, lee, nʼime akpa ọka onye ọbụla, a chọtara ego ọ kwụrụ nʼakpa ya. Mgbe ha na nna ha hụrụ ego ndị a, ha tụrụ egwu.  
\v 36 Ya mere, nna ha Jekọb gwara ha sị, “Unu agbawala m aka ụmụ. Josef anọghị, Simiọn anọkwaghị. Ma unu na-achọ iwezuga Benjamin. Naanị m ka ihe niile ndị a na-emegide!” 
\p  
\v 37 Mgbe ahụ, Ruben gwara nna ya sị, “I nwere ike gbuo ụmụ m ndị ikom abụọ ma ọ bụrụ na m akpọghachighị Benjamin. Tifee ya nʼaka m, aga m akpọghachikwara gị ya.” 
\p  
\v 38 Ma Jekọb sịrị, “Nwa m agaghị eso unu gaa. Nʼihi na nwanne ya anwụọla, ọ bụkwa naanị ya ka ọ fọdụrụ. Ọ bụrụ na nsogbu ezute ya nʼụzọ nʼije a, unu ga-eme ka m jiri isi awọ m laa nʼili nʼọnọdụ mwute.” 
\c 43  
\s1 Njeru Ijipt nke ugboro abụọ 
\p  
\v 1 Ma ụnwụ a siri oke ike nʼala ahụ nʼoge a.  
\v 2 O ruo, mgbe ha richara nri ha zụtara nʼIjipt, nna ha gwara ha sị, “Jeghachinụ, zụtara anyị ntakịrị nri.” 
\p  
\v 3 Juda gwara nna ya bụ Jekọb sị, “Nwoke ahụ dọsiri anyị aka na ntị ike sị, ‘Unu agaghị ahụ ihu m ma ọ bụrụ na nwanne unu esoghị unu bịa.’  
\v 4 Ọ bụrụ na ị ga-edunyere anyị nwanne anyị, anyị ga-agbada gaa zụtara gị nri.  
\v 5 Ma ọ bụrụ na ị gaghị edunyere anyị ya, anyị agaghị agbada, nʼihi na nwoke a sịrị anyị, ‘Unu agaghị ahụ ihu m ma ọ bụrụ na nwanna unu esoghị unu.’ ” 
\p  
\v 6 Mgbe ahụ Izrel sịrị, “Gịnị mere unu ji wetara m nsogbu dị otu a, site nʼịgwa nwoke ahụ na unu nwere nwanne ọzọ.” 
\p  
\v 7 Ha zara sị, “Nwoke a jụrụ anyị ajụjụ dị iche iche banyere onwe anyị, na ndị ezinaụlọ anyị. Ọ sị, ‘Nna unu, ọ dị ndụ ugbu a? Unu nwere nwanne ọzọ?’ Ya mere, anyị zara ajụjụ niile. O nweghị otu anyị siri mara na ọ ga-asị anyị kpọta nwanne anyị.” 
\p  
\v 8 Mgbe ahụ, Juda sịrị nna ya Izrel, “Dunye m nwantakịrị a ka anyị bilie gawa, ka anyị dị ndụ ghara ịnwụ, ma anyị onwe anyị, ma gị, ma ụmụntakịrị anyị.  
\v 9 Aga m eji onwe m gbaa ebe nʼihi ya. I nwere ike itife ya nʼaka m. Ọ bụrụ na m akpọtaghachighị ya, kpọbata ya nʼihu gị, mgbe ahụ, ịta ụta bụrụ nke m nʼihu gị, nʼụbọchị ndụ m niile.  
\v 10 A sị nnọọ na anyị egbughị oge niile a, anyị gaara aga ma lọtakwarị ugboro abụọ.” 
\p  
\v 11 Mgbe ahụ nna ha Izrel gwara ha sị, “Ọ bụrụ na ọ ga-adịrịrị otu a, gịnị ọzọ ka anyị ga-eme. Kama mgbe unu na-aga, werenụ nʼakpa unu onyinye ịnata ihuọma nke bụ ihe niile kachasị mma nke si nʼala a welaara nwoke a. Werenụ nwantịntị mmanụ otite, na nwantịntị mmanụ aṅụ, ha na ụda dị iche iche, na eso osisi máá, na akụ, na alụmọnd.  
\v 12 Werekwanụ ego okpukpu abụọ nʼaka unu. Weghachirinụ ya ego ahụ e tinyere nʼọnụ akpa unu, eleghị anya ọ bụ nʼohihie anya ka ha ji tinye ya.  
\v 13 Ngwa, kpọrọnụ nwanne unu nwoke bilienụ laghachikwurunụ nwoke ahụ.  
\v 14 Ka Chineke Onye pụrụ ime ihe niile, mee ka nwoke ahụ nwee obi ebere nʼebe unu nọ. Ya meekwa ka o nwee ike ịhapụrụ unu nwanne unu Simiọn na Benjamin ka ha soro unu lọta. Ọ bụrụkwanụ uche Chineke na m ga-agbara aka ụmụ, ya mee dịka o si chọọ.” 
\p  
\v 15 Ya mere, ndị ikom ahụ weere onyinye ndị a, na okpukpu ego abụọ nʼaka, ma kpọrọkwa Benjamin. Ha biliri ije. Garuo Ijipt, ma guzo nʼihu Josef.  
\v 16 Mgbe Josef lepụrụ anya hụ Benjamin nʼetiti ha, ọ gwara onye na-elekọta ụlọ ya sị, “Duru ndị ikom ndị a gaa nʼụlọ. Gbuo anụ, kwadoo nri, nʼihi na ndị a ga-eso m rie nri ehihie.” 
\p  
\v 17 Odibo a mere dịka Josef ziri ya. O duuru ndị ikom ndị ahụ gaa nʼụlọ Josef.  
\v 18 Nʼoge a, mgbe a kpọbatara ha nʼụlọ, ndị ikom ndị ahụ tụrụ ụjọ, nʼihi na a kpọbatara ha nʼime ụlọ Josef. Ha sịrị, “Ọ bụ nʼihi ego ahụ e tighachiri nʼakpa anyị nʼoge mbụ ka e ji kpọbata anyị, ka o nwee ike ịchọta ụzọ ọ ga-esi megide anyị, mesie anyị ike, si otu a were anyị na ịnyịnya ibu anyị dịka ndị ohu ya.” 
\p  
\v 19 Ha bịaruru odibo Josef ahụ nso gwa ya okwu nʼọnụ ụzọ ụlọ ahụ.  
\v 20 Ha sịrị ya, “Nna anyị ukwu, anyị bịara ebe a nʼoge mbụ ịzụ ihe oriri.  
\v 21 Ma, mgbe anyị rutere ebe anyị nọrọ ọnọdụ abalị, anyị meghere akpa anyị, chọpụta ego anyị kwụrụ nʼihi nri ahụ anyị zụrụ ka ọ dị nʼọnụ akpa anyị nʼotu na otu. E sepụkwaghị ya ihe ọ bụla. Ya mere, anyị weghachiri ya nʼoge a.  
\v 22 Anyị jikwa ego ọzọ anyị ga-eji zụọ ihe oriri. Ma anyị amaghị onye tinyere ego ahụ nʼime akpa anyị.” 
\p  
\v 23 Odibo ahụ zara sị ha, “Udo dịrị unu, unu atụla egwu, nʼihi na Chineke unu, na Chineke nna unu enyela unu akụ zoro ezo nʼime akpa unu. Ego unu kwụrụ ruru m aka.” Mgbe ahụ, ọ hapụrụ ha gaa kpọpụta Simiọn. 
\p  
\v 24 Nʼoge ahụ, odibo ahụ duuru ndị ikom ndị ahụ bata nʼụlọ Josef, nye ha mmiri ha ji saa ụkwụ ha. O nyekwara ịnyịnya ibu ha nri.  
\v 25 Mgbe ahụ, ụmụ Jekọb kwadoro onyinye ịnata ihuọma ha ji bịa, nke ha ga-enye Josef ma ọ bata nʼetiti ehihie, nʼihi na ha anụla na ha ga-eri nri nʼebe ahụ. 
\p  
\v 26 Mgbe Josef lọtara ụlọ, ha wetaara ya onyinye dị nʼaka ha, daa nʼala, kpọọ isiala nye ya.  
\v 27 Josef jụrụ ha ajụjụ banyere ọdịmma ha, jụọkwa ha sị, “Agadi nna unu, nke unu gwara m ihe banyere ya, ahụ ọ dịkwa ya? Ọ ka dịkwa ndụ.” 
\p  
\v 28 Ha zaghachiri sị ya, “Ahụ dị ohu gị bụ nna anyị. Ọ ka nọ ndụ.” Ha hulatara isi ha, kpọọ isiala nye ya. 
\p  
\v 29 Mgbe Josef welitere anya ya elu hụ nwanne ya Benjamin, onye bụ nwanne afọ ya, ọ jụrụ ha ajụjụ sị, “Onye a ọ bụ nwanne unu nke nta ahụ unu gwara m ihe banyere ya?” Tupu ha asaa ya ihe ọbụla, o lere Benjamin anya sị ya, “Ka amara Chineke dịrị gị, nwa m nwoke.”  
\v 30 Mgbe ahụ kwa Josef mere ọsịịsọ pụọ nʼezi ịchọ ebe ọ ga-akwa akwa nʼihi na ọhụhụ ọ hụrụ nwanne ya anya ọzọ metụrụ ya nnọọ nʼobi. Ọ pụrụ banye nʼime ụlọ ya kwaa akwa. 
\p  
\v 31 Emesịa, ọ sara ihu ya, pụta, jisie onwe ya ike nye odibo ya iwu ka o bute nri ahụ. 
\p  
\v 32 Ha doziiri ya nri nke ya iche, doziekwara ụmụnne ya nri nke ha iche. Otu a kwa, ha dozikwaara ndị Ijipt ya na ha na-erikọ nri, nri nke ha iche. Nʼihi na ọ bụ ihe arụ nʼanya ndị Ijipt na ha na ndị Hibru ga-erikọta nri ọnụ.  
\v 33 Ma mgbe e nyere ha ọnọdụ nʼihu Josef, e mere ka ha nọdụ dịka ha si tọọ ibe ha. Nke ọkpara buru ụzọ nọdụ, onye na-eso ya anọdụkwa. Otu a ka ha niile siri nọdụ ruo nʼonye ikpeazụ nʼime ha. Ha lerịtara onwe ha anya nʼihi na o juru ha anya.  
\v 34 O sitekwara na nri e doziri ya nyebinye ha nri. Nri e nyere Benjamin dị ukwuu okpukpu ise karịa nri nke e nyere ha niile. Ha na ya riri, ṅụọkwa nʼuju. 
\c 44  
\s1 Iko ọlaọcha a chọtara nʼakpa 
\p  
\v 1 Mgbe ahụ Josef nyere odibo nọ nʼụlọ ya iwu sị, “Gbajuo akpa ndị ikom ndị a nri. Tinyere ha nri nke onye ọbụla nʼime ha nwere ike ibu, tinyekwa ego nke onye ọbụla nʼime ha kwụrụ nʼọnụ akpa ya.  
\v 2 Ma tinye iko ọlaọcha m nʼime ọnụ akpa onye nke nta nʼime ha. Tinyekwa ego ọ kwụrụ nʼihi nri ọ zụrụ nʼime akpa ya.” Odibo a mere dịka Josef gwara ya. 
\p  
\v 3 Mgbe chi bọrọ, ha zipụrụ ndị ikom ndị a, ha na ịnyịnya ibu ha.  
\v 4 Mgbe ha ji naanị ihe nta gafee obodo ahụ, Josef gwara odibo ya sị, “Bilie, chụso ndị ikom ndị ahụ ọsọ. I zute ha, sị ha, ‘Gịnị mere unu ji were ihe ọjọọ kwụghachi ihe ọma?  
\v 5 Gịnị mere unu ji zuru iko ọlaọcha nna m ukwu, iko o ji aṅụ ihe ọṅụṅụ na nke o ji ajụ ase? Unu emeela ihe ọjọọ nʼihi ihe a unu mere.’ ” 
\p  
\v 6 Mgbe odibo ahụ zutere ha, ọ gwara ha ihe ndị a.  
\v 7 Ma ha zara sị ya, “Nna anyị ukwu, gịnị mere i ji ekwu ụdị okwu ndị a? Ihe arụ ka ọ bụ anyị ime ihe dị otu a.  
\v 8 Lee, ego anyị chọtara nʼọnụ akpa anyị ka anyị sitere nʼala Kenan weghachi. Olee otu anyị ga-esi zuru ọlaedo maọbụ ọlaọcha site nʼụlọ nna gị ukwu?  
\v 9 Onye ọbụla nʼime anyị a chọtara iko a nʼaka ya ga-anwụ. Anyị onwe anyị ga-aghọrọ nna anyị ukwu ndị ohu.” 
\p  
\v 10 Odibo ahụ zara sị ha, “Ka ọ dịrị dịka unu kwuru. Onye ọbụla a chọtara ya nʼaka ga-abụ ohu m. Ma ndị a na-achọtaghị ya nʼaka ha enweghị ịta ụta ọbụla.” 
\p  
\v 11 Ha mere ngwangwa, onye ọbụla tọdatara akpa ya. Onye ọbụla kwa meghere akpa ya.  
\v 12 Odibo ahụ malitere nʼonye ukwu nʼetiti ha chọọ rute nʼonye nta. Ọ bụ nʼakpa Benjamin ka a chọtara iko ahụ.  
\v 13 Mgbe ahụ, ha dọwara uwe ha nʼihi mwute. Onye ọbụla nʼime ha tighachiri ibu ya nʼelu ịnyịnya ibu ya. Ha niile bidokwara ịlaghachi azụ nʼobodo ha si pụta. 
\p  
\v 14 Mgbe Juda na ụmụnne ya lọghachiri nʼụlọ Josef, ha hụrụ Josef ka ọ nọ nʼebe ahụ. Ha dara nʼala nʼihu ya.  
\v 15 Ma Josef jụrụ ha sị, “Gịnị bụ ihe a unu mere? Ọ bụ na unu amataghị na onye dịka m nwere ike ịmata onye zuru iko m?” 
\p  
\v 16 Ya mere Juda sị ya, “Gịnị ka anyị ga-ekwu? Olee otu anyị ga-esi gosi nʼaka anyị dị ọcha? Chineke ekpugheela ikpe ọmụma ndị ohu gị. Lee, anyị bụkwa ndị ohu onyenwe m. Anyị onwe anyị, tinyekwara onye a chọtara iko ahụ nʼaka ya.” 
\p  
\v 17 Ma Josef sịrị, “Ọ ga-abụrụ m ajọ omume ime ihe dị otu ahụ. Naanị nwoke ahụ a chọpụtara iko ahụ nʼakpa ya bụ onye ga-abụ ohu m. Ma unu onwe unu nwere ike laa nʼudo jekwuru nna unu nʼudo.” 
\s1 Arịrịọ nʼihi Benjamin 
\p  
\v 18 Juda jekwuuru ya, sị, “Biko, onyenwe m, kwere ka ohu gị gwa gị okwu. Ewesola mụ bụ ohu gị iwe nʼihi na ị nọ ọnọdụ dị ka Fero.  
\v 19 Onyenwe m, ọ bụ gị jụrụ ndị ohu gị ajụjụ sị, ‘Unu nwere nna maọbụ nwanne?’  
\v 20 Anyị zara sị, ‘Anyị nwere nna onye bụ agadi, na otu nwa nwoke ọ mụtara nʼagadi ya. Nwanne nwantakịrị nwoke a anwụọla, ya mere naanị otu a fọdụrụ nʼime ụmụ nke nne ha mụtara. Nna ya hụkwara ya nʼanya.’ 
\p  
\v 21 “Mgbe ahụ, ị sị ndị ohu gị, ‘Kpọta nwantakịrị a ka m hụ ya anya.’  
\v 22 Ma anyị gwara onyenwe m sị na ‘Nwata a apụghị ịhapụ nna ya, nʼihi na nna ya ga-anwụ ma ọ bụrụ na ọ hapụ ya.’  
\v 23 Ma ị gwara ndị ohu gị sị, ‘Unu agaghị ahụ ihu m anya ọzọ, ma ọ bụrụ na nwanne unu a esoghị unu gbadata.’  
\v 24 Mgbe anyị lakwuuru ohu gị bụ nna anyị, anyị gwara ya okwu onyenwe m kwuru. 
\p  
\v 25 “Mgbe nna anyị gwara anyị sị, ‘Laghachi gaa zụta nri,’  
\v 26 anyị gwara ya na, ‘Anyị agaghị agbada ma ọ bụrụ na nwanne anyị nta agaghị eso anyị. Nʼihi na anyị enweghị ike ịhụ nwoke ahụ anya, ma ọ bụrụ na nwanne anyị nta esoghị anyị.’ 
\p  
\v 27 “Oge ahụ, ohu gị bụ nna anyị sịrị anyị, ‘Unu maara na nwunye m mụụrụ m ụmụ nwoke abụọ.  
\v 28 Otu nʼime ha funarịrị m, mgbe anụ ọhịa dọkasịrị ya iperipe na iperipe. Ruo ugbu a, ahụbeghị m ya anya.  
\v 29 Ọ bụrụ na unu anapụkwa m onye nke a, si otu a mee ka ihe ọjọọ zute ya, ọ pụtara na unu ga-eme ka m jiri isi awọ m laa nʼili nʼọnọdụ obi ọjọọ?’ 
\p  
\v 30 “Ya mere, ọ bụrụ na m alaghachikwute ohu gị, bụ nna anyị, ma nwantakịrị a esoghị anyị, ebe ọ bụ na e kekọtara ndụ nna anyị na ndụ nwantakịrị a,  
\v 31 mgbe ọ ga-ahụ na nwantakịrị a esoghị anyị, ọ ga-anwụ. Mgbe ahụ, anyị bụ ndị ohu gị, ga-eme ka nna anyị jiri isi awọ laa nʼili nʼọnọdụ obi ọjọọ.  
\v 32 Biko, onyenwe m, eji m ndụ m zọọrọ nna m ebe na m ga-elezi nwantakịrị a anya. Asị m ya, ‘Ọ bụrụ na m akpọghachighị nwantakịrị a nye gị, ka ịta ụta bụrụ nke m nʼihu gị bụ nna m nʼụbọchị niile nke ndu m.’ 
\p  
\v 33 “Ya mere ugbu a, biko, ka ohu gị nọdụ dịka ohu onyenwe m nʼọnọdụ nwantakịrị a, ka nwantakịrị a soro ụmụnne ya laghachikwuru nna anyị.  
\v 34 Aga m esi aṅaa laghachikwuru nna m ma ọ bụrụ na mụ na nwantakịrị a esoghị? Enweghị m ike ilekwasị ihe ọjọọ ga-adakwasị nna m anya.” 
\c 45  
\s1 Ụmụnne Josef amara onye ọ bụ 
\p  
\v 1 Nʼoge a, Josef enwekwaghị ike ijite onwe ya aka nʼihu ndị na-ejere ya ozi. O welitara olu sị, “Zipụnụ onye ọbụla site nʼebe m nọ.” Ya mere, o nweghị onye ya na Josef nọ mgbe ọ kọọrọ ụmụnne ya onye ọ bụ.  
\v 2 O tiri mkpu akwa nke ndị Ijipt nụrụ, na nke ndị ụlọ Fero nụkwara. 
\p  
\v 3 Josef gwara ụmụnne ya sị, “Mụ onwe m bụ Josef. Nna m ọ ka nọ ndụ ugbu a?” Ma ụmụnne ya enweghị ọnụ ha ji asa ya, nʼihi na oke egwu jidere ha nʼihu ya. 
\p  
\v 4 Mgbe ahụ, Josef sịrị ụmụnne ya, “Biko, bịanụ m nso.” Mgbe ha bịara ya nso, ọ sịrị ha, “Abụ m nwanne unu, Josef, onye unu rere ree gaa Ijipt.  
\v 5 Ma otu ọ dị, ka ọ ghara iwute unu, unu atakwala onwe unu ụta nʼihi orure unu rere m. Nʼihi na ọ bụ nʼihi ichebe ndụ unu ka Chineke ji buru ụzọ zite m nʼebe a.  
\v 6 Oge ụnwụ agwụchabeghị. Ọ bụ ezie na afọ abụọ nke oke ụnwụ agafeela, ma ọ fọdụrụ afọ ise ọzọ nʼihu, oge a na-agaghị akọ ihe ọbụla nʼala, maọbụ iwere ihe ọbụla nʼubi.  
\v 7 Chineke zitere m ka m buru ụzọ bịa nʼebe a nʼihi ime ka ndụ fọdụrụ unu nʼụwa, na ịzọpụta ndụ unu site nʼụzọ nnapụta dị oke egwu. 
\p  
\v 8 “Ya mere, ọ bụghị unu zitere m nʼebe a, kama ọ bụ Chineke. Ya onwe ya emeela ka m ghọọrọ Fero nna, na onyeisi ezinaụlọ ya niile, na onye na-achị ala Ijipt niile.  
\v 9 Ugbu a, meenụ ngwa lakwuru nna m, sị ya, ‘Ihe ndị a ka Josef nwa gị nwoke kwuru, Chineke emeela m onye na-achị Ijipt niile. Egbula oge ịbịakwute m.  
\v 10 Ị ga-ebi nʼala Goshen,\f + \fr 45:10 \ft Ala Goshen bụ ala na-emepụta nri nʼebe ọ dị ukwuu. Ọ dị na mpaghara akụkụ ọnụ mmiri osimiri Naịl.\f* ka i nwee ike ịnọ m nso, gị na ụmụ gị, na ụmụ ụmụ gị, na igwe ewu na atụrụ gị, na igwe ehi gị, na ihe niile i nwere.  
\v 11 Nʼebe ahụ ka m ga-enyekwa gị ihe ị chọrọ, nʼihi na ụnwụ afọ ise ka dị nʼihu na-abịa. Ọ bụrụ na i meghị otu a, gị na ezinaụlọ gị na ihe niile bụ nke gị ga-ada ụkpa.’ 
\p  
\v 12 “Nʼezie, anya unu na nʼanya nwanne m Benjamin, ahụla na mụ onwe m ji ọnụ m na-agwa unu okwu ndị a.  
\v 13 Unu ga-akọrọ nna m maka nsọpụrụ niile a na-enye m nʼala Ijipt na ihe niile unu hụrụ. Kpọtakwanụ nna m ọsịịsọ ebe a.” 
\p  
\v 14 Ugbu a, ọ dakwasịrị nʼolu Benjamin, nwanne ya, kwaa akwa. Benjamin jidekwara ya nʼolu kwaa akwa.  
\v 15 Emesịa, o suturu ụmụnne ya niile ọnụ, bekwasịkwa ha akwa. Nʼikpeazụ, ụmụnne ya kpanyeere ya ụka. 
\p  
\v 16 Mgbe akụkọ a ruru ụlọ Fero na ụmụnne Josef bịara, ọ tọrọ Fero na ndịisi ozi niile ya ụtọ.  
\v 17 Fero gwara Josef sị ya, “Gwa ụmụnne gị, ka ha mee ihe otu a, ha bokwasị ịnyịnya ibu unu ibu laghachikwa nʼala Kenan.  
\v 18 Ha ruo, ha kpọta nna gị, na ezinaụlọ ha, ka ha lọghachikwute m nʼala Ijipt. Nʼihi na aga m enye ha ala kachasị mma nʼIjipt. Ha onwe ha ga-erikwa uru ala ahụ. 
\p  
\v 19 “Gwakwa ụmụnne gị okwu sị ha, ‘Sitenụ nʼala Ijipt were ụgbọala, nke unu ga-eji budata ndị nwunye unu na ụmụntakịrị unu. Dutekwanụ nna unu.  
\v 20 Unu esogbula onwe unu banyere ngwa ụlọ unu, nʼihi na ihe niile dị mma nʼala Ijipt bụ nke unu.’ ” 
\p  
\v 21 Ya mere ụmụ Izrel mere ihe ndị a. Josef nyere ha ụgbọala dịka Fero nyere nʼiwu. O nyekwara ha nri ha ga-eri nʼụzọ.  
\v 22 O nyere onye ọ bụla nʼime ha uwe mgbanwe ọhụrụ, ma o nyere Benjamin narị shekel ọlaọcha atọ, na uwe mgbanwe ise.  
\v 23 O zipụụrụ nna ya ihe ndị a: ịnyịnya ibu iri ndị e bokwasịrị ihe mara mma niile si nʼala Ijipt, na nne ịnyịnya ibu iri ndị e bokwasịrị ọka na achịcha, na ihe ndị ọzọ dị iche iche, nʼihi ije ya.  
\v 24 O zipụrụ ụmụnne ya. Ma oge ha na-achọ ịhapụ ya, ọ gwara ha sị, “Unu esekwala okwu nʼụzọ.” 
\p  
\v 25 Mgbe ahụ, ha hapụrụ ala Ijipt mechaa rute ala Kenan, bịakwute Jekọb nna ha.  
\v 26 Ha gwara ya sị, “Josef ka nọ ndụ. Nʼezie, ọ bụ ya na-achị ala Ijipt niile.” Ma o siiri Jekọb ike ịnabata akụkọ a. O kwenyeghị na ọ bụ eziokwu.  
\v 27 Ma mgbe ha gwasịrị ya ihe niile Josef gwara ha, mgbe ọ hụkwara ụgbọala niile Josef zitere ka e jiri bute ya, mmụọ nna ha Jekọb lọghachiri.  
\v 28 Mgbe ahụ Izrel kwuru sị, “Ekwetala m! Josef nwa m ka dị ndụ. Aga m aga hụ ya anya tupu m nwụọ.” 
\c 46  
\s1 Jekọb abịaruo Ijipt 
\p  
\v 1 Izrel biliri ije, ya na ihe niile o nwere rute Bịasheba. Ebe a, ọ chụrụ aja nye Chineke nke nna ya Aịzik. 
\p  
\v 2 Chineke gwara Izrel okwu nʼọhụ nke abalị. Ọ sịrị, “Jekọb! Jekọb!” 
\p Ọ zara sị, “Lee m nʼebe a.” 
\p  
\v 3 Chineke gwara ya sị, “Abụ m Chineke, Chineke nke nna gị. Atụla egwu ịgbada Ijipt nʼihi na aga m eme gị ka ị ghọọ mba dị ukwuu nʼebe ahụ.  
\v 4 Mụ onwe m ga-eso gị agbada nʼala Ijipt. Mụ onwe m ga-akpọlatakwa gị ọzọ. Josef nʼonwe ya ga-eji aka ya ekpuchikwa gị anya.” 
\p  
\v 5 Jekọb mechara si na Bịasheba pụta. Ụmụ Izrel kuuru Jekọb nna ha, na ụmụaka ha na ndị nwunye ha, kubanye nʼụgbọala ahụ Fero zitere ka ha ji bute ya.  
\v 6 Ha buuru anụ ụlọ ha niile, na ihe onwunwe ha niile, nke ha kpatara nʼala Kenan, gaa Ijipt. Jekọb na agbụrụ ya niile so.  
\v 7 Ụmụ ya ndị ikom niile, na ụmụ ụmụ ya ndị ikom niile, na ụmụ ya ndị inyom niile, na ụmụ ụmụ ya ndị inyom niile, na ndị niile bụ mkpụrụ afọ ya, ka ọ kpọrọ gaa Ijipt. 
\b  
\li4  
\v 8 Ndị a bụ aha ụmụ ndị ikom Izrel, ya bụ Jekọb na ụmụ ụmụ ya, ndị sooro ya gaa Ijipt. 
\b  
\li1 Ruben, ọkpara Jekọb 
\li1  
\v 9 Ụmụ ndị ikom Ruben bụ, 
\li2 Hanok, na Palu, na Hezrọn na Kami. 
\li1  
\v 10 Ụmụ ndị ikom Simiọn bụ, 
\li2 Jemuel, na Jamin, na Ohad, na Jakin, na Zoha, na Shaul. Nne Shaul bụ nwanyị Kenan. 
\li1  
\v 11 Ụmụ ndị ikom Livayị bụ, 
\li2 Geshọn, na Kohat, na Merari. 
\li1  
\v 12 Ụmụ ndị ikom Juda bụ, 
\li2 Ịa, na Onan, na Shela, na Perez, na Zera. Ma Ịa na Onan nwụrụ nʼala Kenan. 
\li2 Ụmụ ndị ikom Perez bụ, 
\li3 Hezrọn na Hamul. 
\li1  
\v 13 Ma ụmụ ndị ikom Isaka bụ, 
\li2 Tola, na Puva, na Jashub, na Shịmrọn. 
\li1  
\v 14 Ụmụ ndị ikom Zebụlọn bụ, 
\li2 Sered, na Elọn, na Jaliil. 
\li4  
\v 15 Ndị a bụ ụmụ ndị ikom Lịa mụụrụ Jekọb nʼala Padan Aram. Ọ mụtakwara otu nwanyị aha ya bụ Daịna. Ụmụ ndị ikom na ndị inyom ndị a dị iri atọ na atọ. 
\b  
\li1  
\v 16 Ụmụ ndị ikom Gad bụ, 
\li2 Zefọn, na Hagi, na Shuni, na Ezbon, na Eri, na Arodi na Areli. 
\li1  
\v 17 Ụmụ ndị ikom Asha bụ, 
\li2 Imna, Ishva, Ishvi na Beriya. Nwanne ha nwanyị bụ Sera. 
\li2 Ụmụ Beriya bụ, 
\li3 Heba na Malkiel. 
\li4  
\v 18 Ndị a bụ ụmụ a mụụrụ Jekọb site na Zilpa, odibo nwanyị ahụ Leban kpọnyere Lịa nwa ya nwanyị. Ha dị iri na isii nʼọnụọgụgụ. 
\b  
\li1  
\v 19 Ụmụ ndị ikom Jekọb site na Rechel nwunye ya bụ, 
\li2 Josef na Benjamin. 
\li3  
\v 20 Nʼala Ijipt, a mụụrụ Josef Manase na Ifrem, site na nwunye ya Asenat nwa nwanyị Pọtifera, onye nchụaja nke On. 
\li1  
\v 21 Ụmụ ndị ikom Benjamin bụ, 
\li2 Bela, Beka, Ashbel, Gera, Neeman, Ehi, Rosh, Mupim, Hupim na Aad. 
\li4  
\v 22 Ndị a bụ ndị ikom nke Rechel mụụrụ Jekọb. Ha dị iri na anọ. 
\b  
\li1  
\v 23 Nwa nwoke nke Dan mụrụ bụ, 
\li2 Hushim. 
\li1  
\v 24 Ụmụ ndị ikom Naftalị bụ, 
\li2 Jaziil, na Guni, na Jeza, na Shilem. 
\li4  
\v 25 Ndị a bụ ụmụ ndị ikom a mụụrụ Jekọb site na Bilha, odibo nwanyị ahụ Leban kpọnyere nwa ya nwanyị Rechel. Ha niile dị asaa. 
\b  
\li4  
\v 26 Ya mere, ndị niile so Jekọb gaa Ijipt, ndị bụ ụmụ ụmụ ya, na-agụghị ndị nwunye ụmụ Jekọb niile, dị iri mmadụ isii na isii.  
\v 27 Tinyere ụmụ ndị ikom abụọ amụtara nye Josef nʼIjipt, ndị si nʼezinaụlọ Jekọb gara Ijipt dị iri asaa. 
\b  
\p  
\v 28 Jekọb zipụrụ Juda ka jekwuru Josef ịjụta ya ụzọ Goshen. Mgbe ha rutere nʼala Goshen,  
\v 29 Josef kwadoro ịnyịnya ụgbọ ya gawa Goshen izute nna ya Izrel. Mgbe Josef bịara nʼihu nna ya, ọ makụrụ ya, bee akwa ogologo oge. 
\p  
\v 30 Izrel gwara Josef sị, “Ugbu a ejikerela m ịnwụ, ebe m hụrụ ihu gị anya ọzọ, mata na ị ka dị ndụ.” 
\p  
\v 31 Mgbe ahụ, Josef gwara ụmụnne ya na ndị ezinaụlọ nna ya niile sị, “Ka m gaa kọọrọ Fero. Ka m gaa sị ya, ‘Ụmụnne m na ezinaụlọ nna m, ndị bi nʼala Kenan abịakwutela m.  
\v 32 Ha bụ ndị ọzụzụ atụrụ, ndị na-elekọta anụ ụlọ. Ha chị igwe ewu na atụrụ ha, na igwe ehi ha, na ihe niile ha ji biri.’  
\v 33 Ya mere, ọ bụrụ na Fero akpọ unu jụọ unu ajụjụ sị, ‘Gịnị bụ ọrụ aka unu?’  
\v 34 Unu ga-asị ya, ‘Ndị ohu gị bụ ndị ọzụzụ anụ ụlọ site na mgbe anyị bụ ụmụnta, dịka nna nna anyị ha bụ.’ Mgbe ahụ, ọ ga-ekwe ka unu biri nʼala Goshen. Nʼihi na ndị niile na-azụ ewu na atụrụ bụ ndị akpọrọ asị nʼala Ijipt.” 
\c 47  
\p  
\v 1 Josef gara gwa Fero sị, “Nna m na ụmụnne m ejirila igwe ewu na atụrụ ha, igwe ehi ha na ihe niile ha nwere site nʼala Kenan bịa nʼebe a. Ha nọ nʼala Goshen.”  
\v 2 Mgbe ọ gara ịgwa Fero okwu, o duuru mmadụ ise nʼetiti ụmụnne ya ndị ikom gosi ha Fero. 
\p  
\v 3 Fero jụrụ ụmụnne ya ajụjụ sị ha, “Gịnị bụ ọrụ aka unu?” 
\p Ha zara sị ya, “Ndị ohu gị bụ ndị ọzụzụ atụrụ dịka nna nna anyị ha.”  
\v 4 Ha kwukwara sị, “Anyị bịara ịnọ dịka ọbịa nʼala a nʼihi na ụnwụ a siri oke ike nʼala Kenan. O nweghị nri igwe ewu na atụrụ anyị nwere iri nʼala ahụ. Ya mere, anyị na-arịọ ka i nye ndị ohu gị ike ka ha biri nʼala Goshen.” 
\p  
\v 5 Fero gwara Josef sị, “Nna gị na ụmụnne gị abịakwutela gị. Ha biri nʼala Goshen.  
\v 6 Ala Ijipt dịkwa gị nʼihu. Họrọ ebe ọbụla masịrị gị nke dịkwa ezi mma nye nna gị na ụmụnne gị ka ha biri. Ka ha biri na Goshen. Ọ bụrụkwa na ị maara ndị ikom nʼetiti ha ndị nwere ike, mee ha ndị na-elekọta igwe anụ ụlọ m.” 
\p  
\v 7 Josef kpọtara nna ya Jekọb, mee ka o guzo nʼihu Fero. Jekọb nọ nʼebe ahụ gọzie Fero.  
\v 8 Fero jụrụ Jekọb sị, “Ị gbaala afọ ole ugbu a?” 
\p  
\v 9 Jekọb zara Fero sị ya: “Ebiela m dịka onye ọbịa narị afọ na iri afọ atọ. Ọnụọgụgụ afọ ndị a ehighị nne, ma ha jupụtara nʼahụhụ na nsogbu. Ma a nọrubeghị m ọnụọgụgụ afọ nna m ha gbara mgbe ha biri nʼụwa dịka ọbịa.”  
\v 10 Jekọb gọziri Fero, site nʼihu ya pụọ. 
\p  
\v 11 Ya mere, Josef mere ka nna ya na ụmụnne ya biri nʼala Ijipt. O nyere ha ala kachasị mma nʼala ahụ na mpaghara Ramesis, dịka Fero nyere nʼiwu.  
\v 12 Josef nyere nna ya na ụmụnne ya na ezinaụlọ nna ya nri dịka ọnụọgụgụ nke ụmụ ha si dị. 
\s1 Ụnwụ na ụkọ nri 
\p  
\v 13 Ma nri adịghị nʼala ahụ niile nʼihi na ụnwụ ahụ dị nnọọ njọ. Ihe siri ike nʼala Ijipt ma nʼala Kenan nʼihi ụnwụ a.  
\v 14 Josef chịkọtara ego niile dị nʼala Ijipt, na nʼala Kenan, nke ndị mmadụ ji kwụọ ụgwọ nri ha zụrụ webata ha nʼụlọeze Fero.  
\v 15 Mgbe ego niile dị ndị mmadụ nʼaka gwụchara nʼala Ijipt ma nʼala Kenan, ndị Ijipt niile bịakwutere Josef sị ya, “Nye anyị nri, gịnị mere anyị ga-eji nwụọ nʼihu gị? Ego anyị agwụla.” 
\p  
\v 16 Mgbe ahụ Josef zara sị ha: “Jirinụ anụ ụlọ unu kwụọ ụgwọ nri m ga-enye unu, ebe ọ bụ na ego unu agwụla.”  
\v 17 Ya mere, ha kpụtaara Josef anụ ụlọ ha. Josef nyere ha nri nʼọnọdụ ịnyịnya ha, na atụrụ ha, na ewu ha, na ehi, na ịnyịnya ibu ha. O were nri zụọ ha nʼafọ ahụ nʼọnọdụ anụ ụlọ ha niile. 
\p  
\v 18 Mgbe afọ ahụ gafesịrị, ha bịakwutekwara ya nʼafọ nke ọzọ sị ya, “Anyị agaghị ezoro onyenwe anyị na ego anyị agwụla, na igwe anụ ụlọ anyị bụkwa nke gị. O nweghị ihe ọzọ fọdụrụ anyị karịa ahụ anyị na ala anyị.  
\v 19 Gịnị mere anyị ga-eji nọọ nʼagụụ nʼihu gị? Zụrụ anyị na ala anyị nʼọnọdụ ụgwọ anyị ga-akwụ maka nri ị ga-enye anyị. Ka anyị na ala anyị bụrụ ndị ohu Fero. Nye anyị mkpụrụ ubi ka anyị dịrị ndụ ghara ịnwụ, ka ala a ghara ịbụ ihe tọgbọrọ nʼefu.” 
\p  
\v 20 Ya mere, Josef zụtaara Fero ala Ijipt niile. Ndị Ijipt niile nʼotu nʼotu rere ala ha nʼihi oke ụnwụ ahụ dakwasịrị ha. Mgbe ahụ, ala ha niile ghọrọ nke Fero.  
\v 21 Ya mere, Josef si otu a mee ka ndị Ijipt niile ghọọ ndị ohu Fero, site nʼotu obodo nʼala ahụ ruo na nke ọzọ ya.  
\v 22 Ala nke Josef na-azụtaghị nʼoge a bụ naanị ala ndị nchụaja. Nʼihi na ndị nchụaja si nʼaka Fero na-enweta nri ha site nʼoge ruo nʼoge. Ha nwekwara nri na-ezuru ha site na oke ahụ Fero na-enye ha. Ya mere ha ereghị ala ha. 
\p  
\v 23 Mgbe ahụ, Josef gwara ndị mmadụ ahụ niile okwu sị, “Lee, azụọla unu taa, zụkwaa a ala unu nye Fero.  
\v 24 Nʼoge owuwe ihe ubi, otu ụzọ nʼime ụzọ ise nke ihe unu nwetara nʼubi unu bụ nke Fero. Deberenụ onwe unu ụzọ anọ fọdụrụ ka ọ bụrụ ihe unu ga-akụ nʼubi na ihe unu ga-eri na ihe ndị ezinaụlọ unu, na nke ụmụntakịrị unu ga-eri.” 
\p  
\v 25 Ha zara sị ya, “Ị zọpụtala ndụ anyị. Ka anyị hụta amara nʼihu nna anyị ukwu. Anyị ga-abụ ndị ohu Fero.” 
\p  
\v 26 Josef mere ka nke a bụrụ iwu nʼala Ijipt niile ruo taa, na Fero ga-ewe otu ụzọ nʼime ụzọ ise nke ihe ọbụla si nʼala. Naanị ihe si nʼala ndị nchụaja bụ nke na-esoghị nʼiwu a. 
\p  
\v 27 Izrel biri na Goshen nke dị nʼala Ijipt. Ha kpatara akụ hie nne, mụbaa nʼọmụmụ, ma nʼọnụọgụgụ. 
\p  
\v 28 Jekọb biri nʼala Ijipt afọ iri na asaa. Ya mere, afọ niile Jekọb gbara bụ narị afọ na iri afọ anọ na asaa.  
\v 29 Mgbe ụbọchị ọnwụ Izrel na-abịaru nso, ọ kpọrọ Josef nwa ya sị ya, “Ọ bụrụ na m ahụtala amara nʼihu gị, tinye aka gị nʼokpuru apata m, kwee m nkwa na ị ga-egosi m obi ebere na ezi ntụkwasị obi. Elila m nʼala nʼIjipt.  
\v 30 Kama, mgbe m nwụrụ, site nʼala Ijipt bupụ m. Buru ozu m gaa lie ya ebe e liri nna m ha.” 
\p Ọ zara, “Aga m eme dịka i kwuru.” 
\p  
\v 31 Ọ sịrị ya, “Ṅụọrọ m iyi na ị ga-eme ya.” Josef ṅụọrọ ya iyi. Izrel nʼonwe ya, kpọrọ isiala dịka ọ dabere nʼelu mkpanaka ya. 
\c 48  
\s1 Jekọb agọzie ụmụ Josef 
\p  
\v 1 Mgbe ihe ndị a gasịrị, a gwara Josef sị, “Lee nna gị na-arịa ọrịa.” Josef biliri duru ụmụ ya ndị ikom abụọ bụ Manase na Ifrem gawa ileta ya.  
\v 2 Mgbe a gwara Jekọb okwu sị ya, “Nwa gị nwoke Josef abịala ileta gị.” Izrel chịkọtara ume ya, jisie ike, nọdụ ala nʼelu akwa ya. 
\p  
\v 3 Mgbe ahụ, Jekọb sịrị Josef, “Chineke, Onye pụrụ ime ihe niile gosiri m onwe ya na Luz, nʼala Kenan, ma gọziekwa m.  
\v 4 Ọ sịrị m, ‘Lee, aga m eme ka ị mịa mkpụrụ, baakwa ụba nʼọnụọgụgụ. Aga m eme ka ị ghọọ ọgbakọ ọtụtụ mba. Aga m enye gị ala a ka ọ bụrụ ihe nketa ebighị ebi maka agbụrụ gị ndị ga-esote gị.’ 
\p  
\v 5 “Ugbu a, ana m eme ụmụ gị ndị ikom abụọ ndị a, ndị a mụtaara gị nʼala Ijipt, ụmụ nke m. Ha abụọ, Ifrem na Manase, ga-abụ ụmụ m, dịka Ruben na Simiọn si bụrụ ụmụ m.  
\v 6 Ma ụmụ ọzọ a ga-amụtara gị ga-abụ nke gị. Ọ bụ aha ụmụnne ha ndị a ka a ga-eji mara ha nʼala nketa nke ha.  
\v 7 Ana m eme nke a nʼihi na mgbe m si Padan Aram pụta, nne unu Rechel, nwụrụ nʼala Kenan mgbe anyị ka nọ nʼụzọ ije anyị nʼebe dịtụ anya site na Efrat. Nʼakụkụ ụzọ e si aga Efrat, ya bụ Betlehem, ka m likwara ya.” 
\p  
\v 8 Mgbe Izrel hụrụ ụmụ ndị ikom abụọ Josef kpọ bịa, ọ jụrụ Josef ajụjụ sị, “Ndị a, bụ ndị ole?” 
\p  
\v 9 Josef zara nna ya sị, “Ha bụ ụmụ ndị ikom ndị Chineke nyere m nʼebe a.” 
\p Ya mere, Jekọb gwara ya sị, “Kpọtara m ha, ka m gọzie ha.” 
\p  
\v 10 Nʼoge a, Izrel adịghị ahụzikwa ụzọ nke ọma nʼihi ime agadi ya. Ya mere, Josef duuru ụmụ ya ndị ikom ndị ahụ bịa nso ebe nna ya nọ. Mgbe ahụ, Jekọb suturu ha ọnụ, makụọ ha. 
\p  
\v 11 Izrel sịrị Josef, “O nweghị mgbe m lere anya na m ga-ahụ ihu gị ọzọ. Ma Chineke emeela ka m hụkwa ụmụ gị.” 
\p  
\v 12 Josef sitere nʼikpere\f + \fr 48:12 \ft Ị kuu mmadụ nʼikpere, bụ mmemme iji gosipụta na onye ahụ eku nʼikpere, a bụrụla nwa onye ahụ kuu ya.\f* Jekọb kupu ụmụ ya, bịa hulata isi ala. O kpuru ihu ya nʼala mgbe o mere nke a.  
\v 13 Josef kpọọrọ ha abụọ, Ifrem nʼaka nri ya nke bụ aka ekpe Izrel, na Manase nʼaka ekpe ya nke bụ aka nri Izrel, kpọta ha bịa nna ya nso.  
\v 14 Ma Izrel setịrị aka nri bikwasị ya nʼisi Ifrem, nwa nke nta. Ma aka ekpe ya ka o setịpụrụ bikwasị nʼisi Manase bụ ọkpara. 
\p  
\v 15 Mgbe ahụ, ọ gọziri Josef sị ya. 
\q1 “Ka Chineke, onye nna m ha 
\q2 Ebraham na Aịzik jere ije nʼihu ya 
\q1 Chineke onye bụrịị Onye zụrụ m dịka atụrụ 
\q2 ogologo ndụ m niile ruo taa, 
\q1  
\v 16 Mmụọ ozi ahụ napụtara m site nʼihe egwu niile, 
\q2 ya gọzie ụmụ ndị ikom ndị a. 
\q1 Ka ha bụrụ ndị a kpọkwasịrị aha m 
\q2 na aha nna m ha Ebraham na Aịzik, 
\q1 ka ha mụbaa 
\q2 hie nne nʼelu ụwa.” 
\p  
\v 17 O wutere Josef mgbe ọ hụrụ na nna ya bikwasịrị aka nri ya nʼisi Ifrem. O jidere aka nna ya iwepụ ya nʼisi Ifrem, ka ọ tụkwasị ya nʼisi Manase.  
\v 18 Mgbe ahụ, Josef sịrị nna ya, “I bikwasịjọrọ aka gị. Onye a bụ ọkpara, bikwasị aka nri gị nʼisi ya.” 
\p  
\v 19 Ma nna ya jụrụ, sị ya, “Amaara m ihe m na-eme nwa m, Manase ga-aghọ oke obodo, ma nwanne ya nke nta ga-akarị ya ịdị ukwuu, nʼihi na ụmụ ụmụ ya ga-aghọ ọtụtụ mba dị iche iche.”  
\v 20 Ọ gọziri ha nʼụbọchị ahụ sị, 
\q1 “Nʼaha gị ka Izrel ga-ekwupụta ngọzị a, 
\q2 ‘Ka Chineke mee gị dịka Ifrem na Manase.’ ” 
\m Ya mere o buru ụzọ kpọọ Ifrem tupu Manase. 
\p  
\v 21 Mgbe ahụ, Izrel gwara Josef okwu sị ya, “Lee, mụ onwe m na-aga ịnwụ. Ma Chineke ga-anọnyere unu, kpọghachikwa unu azụ nʼala nna unu ha.  
\v 22 Mụ onwe m na-enye gị otu akụkụ ugwu karịa nke ụmụnne gị, bụ ala ugwu ahụ m sitere na mma agha m na ụta m napụta ndị Amọrait ka ọ bụrụ nke gị.” 
\c 49  
\s1 Jekọb agọzie ụmụ ya 
\p  
\v 1 Mgbe ahụ, Jekọb kpọkọtara ụmụ ya ndị ikom niile nʼotu sị ha, “Zukọọnụ ka m gwa unu ihe ga-adakwasị unu nʼụbọchị dị nʼihu. 
\q1  
\v 2 “Zukọọnụ nụrụ, ụmụ ndị ikom Jekọb 
\q2 nụrụ okwu nna unu Izrel. 
\b  
\q1  
\v 3 “Ruben, ọkpara m ka ị bụ, 
\q2 ume m, ihe ngosi mbụ nke ike m, 
\q2 onye nsọpụrụ kwesiri, onye mbụ nʼịdị ike. 
\q1  
\v 4 Onye na-agbanwe agbanwe dịka mmiri dị nʼiyi, ị gaghị abụkwa onye mbụ, 
\q2 nʼihi na ị banyere nʼihe ndina nna gị, 
\q2 i dinara nʼihe ndina m, merụọ ya. 
\b  
\q1  
\v 5 “Simiọn na Livayị bụ ụmụnne. 
\q2 Mma agha ha bụ ngwa ihe ike. 
\q1  
\v 6 Ka obi m ghara isonye nʼizuzu ha, 
\q2 ka m ghara isonye nʼọgbakọ ha, 
\q1 nʼihi na ha gburu mmadụ nʼoge iwe ha, 
\q2 bipụkwa nkwonkwo ụkwụ ụmụ ehi na-echeghị echiche. 
\q1  
\v 7 Ihe a bụrụ ọnụ ka iwe ha bụ, nʼihi na ọ dị njọ. 
\q2 Ọnụma ha, ọ jọbigara njọ oke. 
\q1 Aga m ekesa ha nʼetiti ụmụ Jekọb 
\q2 Kpasaa ha nʼetiti ndị Izrel. 
\b  
\q1  
\v 8 “Gị, Juda, ụmụnne gị ga-eto gị. 
\q2 Aka gị ga-adị nʼolu ndị iro gị. 
\q2 Ụmụ ndị ikom nna gị ga-akpọ isiala nye gị. 
\q1  
\v 9 Ị bụ nwa ọdụm, gị, Juda, 
\q2 i si nʼịchụ nta lọta, nwa m. 
\q1 Dịka ọdụm, ọ na-amakpu, na-edina ala, 
\q2 dịka nne ọdụm, onye ga-anwa anwa kpọtee ya? 
\q1  
\v 10 Mkpanaka eze agaghị esite nʼebe Juda nọ wezuga onwe ya, 
\q2 maọbụ mkpanaka onyendu esi nʼagbata ụkwụ ya pụọ, 
\q1 tutuu ruo mgbe eze ahụ nwe ya ga-abịa, 
\q2 irube isi nke mba niile ga-abụ nke ya. 
\q1  
\v 11 Ọ ga-ekenye ịnyịnya ibu ya nʼosisi vaịnị, 
\q2 nʼalaka kachasị mma ka ọ ga-ekenye nwa ịnyịnya ibu ya.\f + \fr 49:11 \ft Nke a na-egosipụta ịba ụba nʼebe ọ dị ukwuu, maọbụ mmadụ ịbụ ọgaranya.\f* 
\q1 Ọ ga-asakwa uwe ya na mmanya. 
\q2 Uwe mwụda ya ka ọ ga-asụkwa nʼọbara mkpụrụ vaịnị. 
\q1  
\v 12 Anya ya ga-acha uhie uhie karịa mmanya vaịnị. 
\q2 Eze ya ga-enwupụkwa ọcha karịa mmiri ara ehi. 
\b  
\q1  
\v 13 “Zebụlọn ga-ebi nʼakụkụ osimiri. 
\q2 Ọ ga-abụ ebe izuike nye ụgbọ mmiri. 
\q2 Oke ala ya ga-agbatịpụ ruo Saịdọn. 
\b  
\q1  
\v 14 “Isaka dị ike dịka ịnyịnya ibu 
\q2 na-amakpu nʼetiti ọgba atụrụ. 
\q1  
\v 15 Mgbe ọ hụrụ otu ebe izuike ya si dị mma, 
\q2 hụ otu ala ya si maa mma, 
\q1 ọ ga-ehudata isi ya ibu ibu arụ; 
\q2 were onwe ya nye ịrụ ọrụ ike. 
\b  
\q1  
\v 16 “Dan ga-eme ka ikpe ziri ezi rute ndị ya aka 
\q2 dịka otu nʼime ebo Izrel. 
\q1  
\v 17 Dan ga-adị ka agwọ dị nʼakụkụ okporoụzọ, 
\q2 dịka ajụala dị nʼụzọ ọhịa, 
\q1 nke na-ata ịnyịnya nʼikiri ụkwụ, 
\q2 si otu a mee ka onye na-agba ịnyịnya dalaa azụ. 
\b  
\q1  
\v 18 “O \nd Onyenwe anyị\nd*, ana m ele anya nnapụta gị. 
\b  
\q1  
\v 19 “Gad bụ onye usuu ndị o-ji-egbe-aga ga-abịakwasị, 
\q2 ma ọ ga-alụso ha ọgụ, chụọkwa ha ọsọ. 
\b  
\q1  
\v 20 “Asha ga-esi nʼubi ya wepụta nri gbara abụba, 
\q2 nke na-adị ndị eze mma. 
\b  
\q1  
\v 21 “Naftalị dịka nne ele a hapụrụ ahapụ, 
\q2 nke na-amụpụta ụmụ ele mara mma. 
\b  
\q1  
\v 22 “Dịka osisi vaịnị a kụrụ nʼakụkụ iyi, 
\q2 nke alaka ya na-awasa rigoro nʼelu mgbidi, 
\q2 na nke na-amị ezi mkpụrụ, otu a ka Josef dị. 
\q1  
\v 23 Ndị na-agbata ụta sitere nʼobi ilu lụso ya agha, 
\q2 ha gbara ya àkụ site nʼịkpọ asị. 
\q1  
\v 24 Ma aka o ji jide ụta nke ya adaghị mba, 
\q2 ike agwụghị ogwe aka ya, 
\q1 nʼihi aka Onye dị ike nke Jekọb, 
\q2 nʼihi Onye ọzụzụ atụrụ, Oke Nkume Izrel, 
\q1  
\v 25 nʼihi Chineke nna gị, onye na-enyere gị aka, 
\q2 nʼihi Onye pụrụ ime ihe niile, ka ọ gọzie gị, 
\q1 site na ngọzị nke eluigwe site nʼelu, 
\q2 ngọzị nke osimiri dị nʼokpuru ala, 
\q2 ngọzị nke ara na akpanwa. 
\q1  
\v 26 Ngọzị niile nke nna gị, dị ukwu karịa, 
\q2 ngọzị niile nke ugwu ukwu mgbe ochie, 
\q2 karịakwa ngọzị nke ugwu nta mgbe ochie, 
\q1 Ka ngọzị ndị a dị iche dịkwasị nʼisi Josef, 
\q2 dịkwasị nʼegedege ihu Josef, onye bụ onyendu nʼetiti ụmụnne ya. 
\b  
\q1  
\v 27 “Benjamin dịka nkịta ọhịa nke na-adọgbu anụ. 
\q2 Nʼụtụtụ, ọ na-eri anụ ọ dọgburu. 
\q2 Nʼanyasị ọ na-ekesakwa ihe o gbutere.” 
\p  
\v 28 Ndị a bụ ebo iri na abụọ dị nʼIzrel. Ihe ndị a bụkwa ihe nna ha gwara ha mgbe ọ gọziri ha, nye onye ọbụla nʼime ha ngọzị nke ruuru ya. 
\s1 Ọnwụ Jekọb 
\p  
\v 29 Emesịa, o nyere ha ndụmọdụ sị ha, “Nʼoge na-adịghị anya site ugbu a, aga m anwụ. Unu aghaghị ili m nʼebe e liri nna m ha, nʼala Kenan, nʼime ọgba ahụ dị nʼọhịa Efrọn, onye Het.  
\v 30 Nʼime ọgba dị nʼọhịa Makipela, nke dị nso na Mamre, nʼala Kenan, ọhịa Ebraham zụtara site nʼaka Efrọn onye Het, maka ili ozu.  
\v 31 Nʼebe ahụ ka e liri Ebraham na Sera nwunye ya. Nʼebe ahụ kwa ka e liri Aịzik na Ribeka nwunye ya. Nʼebe ahụ ka m liri Lịa.  
\v 32 Ebraham nna nna m zụrụ ala ahụ na ọgba dị nʼime ya site nʼaka ụmụ Het.” 
\p  
\v 33 Mgbe Jekọb kwuchara okwu ndụmọdụ ikpeazụ ndị a nye ụmụ ya ndị ikom, ọ chịkọtara ụkwụ ya nʼelu akwa, kuo ume ikpeazụ. A chịkọtara ya na ndị ya. 
\c 50  
\s1 Olili Jekọb 
\p  
\v 1 Josef dakwasịrị nʼihu nna ya, kwaa akwa, sutukwa ya ọnụ.  
\v 2 Josef nyere iwu, ka ndị dibịa na-ejere ya ozi gbasie ozu nna ya. Ya mere, ndị dibịa ahụ gbasikwara Izrel.  
\v 3 O were ha iri ụbọchị anọ ịgbasi ozu, nʼihi na nke a bụ oge o kwesiri iwe ha ime ya. Mgbe nke a gasịrị, a kwara ya nʼala Ijipt iri ụbọchị asaa. 
\p  
\v 4 Mgbe oge iru ụjụ gafesịrị, Josef gwara ndị ụlọ Fero sị ha, “Ọ bụrụ na m ahụtala amara nʼihu unu, biko, gwaranụ m Fero otu a, sị ya,  
\v 5 ‘Nna m mere ka m ṅụọra ya iyi mgbe ọ na-anwụ, sị, “Lee, agala m ịnwụ, ị ga-eli m nʼili m, nke m gwuuru onwe m nʼala Kenan.” Ugbu a, biko ka m gaa lie nna m, ma lọghachikwa.’ ” 
\p  
\v 6 Fero zara sị ya, “Gaa lie nna gị dịka o mere ka ị ṅụọ iyi na ị ga-eme.” 
\p  
\v 7 Ya mere, Josef gara ili nna ya. Ọtụtụ ndị mmadụ sokwa ya. Ndịisi ọchịchị Fero, na ndị okenye ụlọ ya, na ndị okenye a ma ama nʼala Ijipt.  
\v 8 Ndị ọzọ bụkwa ndị ụlọ Josef niile, ụmụnne ya, na ndị ụlọ nna ya. Naanị ụmụntakịrị, na igwe ewu na atụrụ ha, na igwe ehi ha, ka ha hapụrụ nʼala Goshen.  
\v 9 Ma ịnyịnya ụgbọ na ndị na-agba ịnyịnya, so ya gaa. Igwe mmadụ gara ije a buru ibu nke ukwuu. 
\p  
\v 10 Mgbe ha ruru ebe ịzọcha ọka nke Atad, nʼofe ọzọ nke Jọdan, ha weere iti aka nʼobi dị ukwuu tie aka nʼobi ha nʼebe ahụ. Josef ruru ụjụ ụbọchị asaa maka nna ya nʼebe ahụ.  
\v 11 Mgbe ndị bi nʼala Kenan hụrụ oke iru ụjụ nke ebe ịzọcha ọka nke Atad ahụ, ha sịrị, “Nke a bụụrụ ndị Ijipt iru ụjụ dị ukwuu.” Nʼihi nke a, ha kpọrọ ebe ahụ dị nso na Jọdan Ebel-Mizraim. 
\p  
\v 12 Ụmụ Jekọb mere dịka nna ha gwara ha.  
\v 13 Nʼihi na ha buuru ozu ya laa nʼala Kenan, lie ya nʼọgba ahụ dị nʼọhịa Makipela, nke bụ ala ubi Ebraham zụrụ dịka ala olili ozu, site nʼaka Efrọn, onye Het; nʼakụkụ Mamre.  
\v 14 Emesịa, Josef laghachiri Ijipt ya na ụmụnne ya, na ndị niile sooro ya gaa olili ozu nna ya, ngwangwa elichara nna ya. 
\s1 Josef agbaghara ụmụnne ya 
\p  
\v 15 Mgbe ụmụnne Josef hụrụ na nna ha anwụọla, ha sịrị, “Eleghị anya Josef ga-akpọ anyị asị, kwụghachi anyị ụgwọ ihe ọjọọ niile anyị mere ya?”  
\v 16 Nʼihi nke a, ha zipụrụ Josef ozi sị, “Nna gị nyere iwu a tupu ọ nwụọ.  
\v 17 ‘Gwa Josef sị ya, Arịọọ m gị, gbaghara ihe ọjọọ niile ụmụnne gị mere, na mmehie ha mere megide gị.’ Ugbu a, gbaghara mmehie anyị bụ ndị ohu Chineke nna gị.” Mgbe Josef nụrụ ihe ha kwuru, ọ kwara akwa. 
\p  
\v 18 Ụmụnne ya bịakwara daa nʼihu ya, sị, “Anyị bụ ndị ohu gị.” 
\p  
\v 19 Ma Josef sịrị ha, “Unu atụla egwu. Abụ m Chineke onye na-ekpe ikpe nke m ga-eji taa unu ahụhụ?  
\v 20 Ọ bụ ezie na unu chere ime m ihe ọjọọ, ma Chineke chere ya ka ọ bụrụ ezi ihe, iji debe ọtụtụ ndụ dịka ọ na-eme taa.  
\v 21 Ya mere, ụjọ atụla unu. Mụ onwe m ga-azụ unu na ụmụntakịrị unu.” Ọ kasịrị ha obi, gwa ha okwu bara ha nʼobi. 
\s1 Ọnwụ Josef 
\p  
\v 22 Josef biri nʼIjipt, ya na ụmụnne ya, na ndị ụlọ ha. Josef gbara narị afọ na iri.  
\v 23 Josef hụrụ ụmụ Ifrem, na ụmụ ụmụ ya. Ọ nọkwa ndụ hụ ụmụ Makia nwa Manase, ndị e kukwasịrị nʼikpere ya. 
\p  
\v 24 Mgbe ahụ, Josef sịrị ụmụnne ya, “Agala m ịnwụ, ma Chineke ga-abịa ileta unu. Ọ ga-esi nʼala a kpọpụta unu kpọgakwa unu nʼala ahụ ọ ṅụụrụ Ebraham na Aịzik na Jekọb iyi, na ọ ga-enye ha.”  
\v 25 Mgbe ahụ, Josef mere ka ụmụ Izrel ṅụọrọ ya iyi sị, “Mgbe Chineke bịara ileta unu, unu aghaghị ị site nʼebe a chịkọrọ ọkpụkpụ m.” 
\p  
\v 26 Josef nwụrụ mgbe ọ gbara narị afọ na iri. Ha gbasiri ozu ya, tinye ya nʼime igbe ozu, nʼala Ijipt.