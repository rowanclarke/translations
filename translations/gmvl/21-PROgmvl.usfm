\v 5 Asa wozina halchchoy 
\q2 ciimma ollan de7iza 
\q2 haaththa mala; 
\q2 gido attiin wozinama asi 
\q2 heeppe duuqqi kessees. 
\q1  
\v 6 Daro asati bantta 
\q2 kiyateththa yooteettes; 
\q2 gido attiin ammanettiza as 
\q2 ooni demmanaas dandayzee? 
\q1  
\v 7 Xillo asi borey baynda de7o dees; 
\q2 izappe kaallidi 
\q2 iza naytikka anjjettidayta. 
\q1  
\v 8 Kawoy pirdanaas ba kawoteththa 
\q2 algan uttiza wode 
\q2 iita ubbaa ba ayfetan 
\q2 harqidi kessees. 
\q1  
\v 9 «Ta wozinaa geeshshadis; 
\q2 ta geeshsha; 
\q2 tanan nagaray baawa» 
\q2 gaanay oonee? 
\q1  
\v 10 GODAY wordo meezaanenne 
\q2 nam7u qommo geeddara 
\q2 miish ixxees. 
\q1  
\v 11 Nay geeshshinne suure gidizayssi 
\q2 izi ooththiza ooson erettees. 
\q1  
\v 12 Siyiza hayththinne xeelliza ayfe, 
\q2 isttaka GODAY medhdhides. 
\q1  
\v 13 Dhisko siiqoppa! 
\q2 Ne histtontta aggiko ne manqana. 
\q2 Minnada ooththa; 
\q2 histtiko neni kath kallana. 
\q1  
\v 14 Shammiza asi, 
\q2 «Hayssi al7o! Qohees!» gees; 
\q2 gido attiin shammi 
\q2 simmidaappe guyen, 
\q2 «Hiraysson shammadis» 
\q2 giidi ceeqettees. 
\q1  
\v 15 Eray kumida qaala haasayza 
\q2 metershati worqqafenne 
\q2 zo7o inqqufekka 
\q2 aadho geexe. 
\q1  
\v 16 Erontta asas 
\q2 waase geliza asa may7o 
\q2 qaari ekkite; 
\q2 hawusha maccassas 
\q2 waase geliza as oykkite.\f + \fr 20:16 \ft Hawusha maccas gizayssas birsheththay kawushsha guussa.\f* 
\q1  
\v 17 Wordon demmida kaththi mal7ees; 
\q2 gido attiin aqi pe7idi 
\q2 doonan ace gidees. 
\q1  
\v 18 Zore ekkada halchcho halchcha; 
\q2 zore ekkontta de7ashe 
\q2 olas booppa. 
\q1  
\v 19 Zigiranchchay xuura laallees; 
\q2 hessa gishshas lom7ulom7a 
\q2 asappe haakka. 
\q1  
\v 20 Ba aawa woykko 
\q2 ba aayo cayizaades, 
\q2 xomppey sakkanna 
\q2 dhuman to7ana. 
\q1  
\v 21 Koyrora eeson beettida aqotas 
\q2 wurseththan anjjoy deenna. 
\q1  
\v 22 Neessi iita ooththida asas, 
\q2 «tani izas halo kessana» gooppa; 
\q2 GODAAN ammanettada naaga; 
\q2 izi nena ashshana. 
\q1  
\v 23 GODAY wordo meezaanen 
\q2 ufayettenna 
\q2 nam7u qommo geeddara 
\q2 miish ixxees. 
\q1  
\v 24 Asay baanaas bessiza oge 
\q2 GODAY kaaleththees; 
\q2 histtiin asi barkka 
\q2 ba baana oge 
\q2 wostti akeekanaas dandayzee? 
\q1  
\v 25 Issi miish Eesotidi, 
\q2 «Hayssa tani Xoossas immana» 
\q2 giidi adinettidaappe guye 
\q2 zil7eteththi as oykkiza yarde. 
\q1  
\v 26 Aadho erateththi diza kawoy 
\q2 makkallanchchata shaakki erees; 
\q2 izi istta qadhettontta qaxxayees. 
\q1  
\v 27 Asa ayanay GODAA xomppe; 
\q2 hessa gishshas 
\q2 giddo asateth ubbaa 
\q2 izi pilggi xeellees. 
\q1  
\v 28 Kiyateththinne tumateththi 
\q2 kawo naagettees; 
\q2 iza kawoteththa araataykka 
\q2 siiqon minnees. 
\q1  
\v 29 Yelagata wolqqay isttas bonchcho; 
\q2 cimata pulunththi 
\q2 isttas bonchcho. 
\q1  
\v 30 Mino qixaatey iitateth diggees; 
\q2 wadhay iita wozina laammees. 
\c 21  
\q1  
\v 1 Kawo wozinay 
\q2 GODAA kushen dees; 
\q2 izi iza wozinaa 
\q2 goggiza haaththa mala 
\q2 ba dosidaso zaarees. 
\q1  
\v 2 Asi biza ogey izaades 
\q2 suure misatees; 
\q2 GODAY gidikko 
\q2 wozinaa pilggi xeellees. 
\q1  
\v 3 Yarshofe bollara xillonne 
\q2 suure pirda GODAY dosees. 
\q1  
\v 4 Otoroynne hallacay 
\q2 iita asata bessiza malata; 
\q2 hessika nagara. 
\q1  
\v 5 Mino oosanchcha 
\q2 halchchoy duresees; 
\q2 gido attiin bichcharisi manqisees. 
\q1  
\v 6 Wordotidi dagasida aqotay 
\q2 dhayza pentta mala; 
\q2 qasseka wodhiza woximade mala. 
\q1  
\v 7 Iitati suure ooso dosontta gishshas 
\q2 iitata istta makkallateththi 
\q2 dhayssana. 
\q1  
\v 8 Mooranchchati 
\q2 geella ogera hemetteettes; 
\q2 gido attiin geeshshati 
\q2 suure haneettes. 
\q1  
\v 9 Duunama machchira daanaappe 
\q2 keeththa daaranchchan 
\q2 aqoy lo7o. 
\q1  
\v 10 Iitati iita miish ooththanaas 
\q2 keehi amotteettes. 
\q2 Iza laggey izappe 
\q2 qadheta demmenna. 
\q1  
\v 11 Qilccizaadey qaxxayettida wode 
\q2 wozinay paccida asi 
\q2 aadho erateth tamaarees; 
\q2 wozinama asikka tamaardi 
\q2 erateth demmees. 
\q1  
\v 12 Xillo Xoossay iitatason 
\q2 oosettiza ubbaa caddi xeellees; 
\q2 istta mulera dhayssees. 
\q1  
\v 13 Manqo waaso siyanaappe giidi 
\q2 ba hayth tucciko 
\q2 izikka waassiza wode 
\q2 alliza asi dhayana. 
\q1  
\v 14 Geeman immiza imotay 
\q2 hanqo doshisees; 
\q2 afala giddora immida matta7ey 
\q2 suule hanqo irxxisees. 
\q1  
\v 15 Suure pirday xillota ufayssees; 
\q2 iita ooththizayta gidikko 
\q2 shirosees. 
\q1  
\v 16 Akeeka ogeppe kare keziza asi 
\q2 moytille duulatan shemppees. 
\q1  
\v 17 Hallaca duus daana 
\q2 koyza asi manqees; 
\q2 ushshinne muus 
\q2 gooddiza asi durettenna. 
\q1  
\v 18 Xillota bolla yida metoy 
\q2 iitata bolla simmana; 
\q2 suure asata bolla yida metoy 
\q2 ammanettonttayta bolla gakkana. 
\q1  
\v 19 Wocamizanne doonatiza 
\q2 machchira daanaappe 
\q2 bazzon duussi kiya. 
\q1  
\v 20 Wozinama asa soon 
\q2 mal7o qumaynne 
\q2 zaytey dagatti dees; 
\q2 gido attiin eeya asi 
\q2 baas dizayssa, bayndaa 
\q2 ubbaa dippi histti mees. 
\q1  
\v 21 Xilloteththinne siiqo 
\q2 kaallizaadey de7o, 
\q2 dureteththinne 
\q2 bonchcho demmees. 
\q1  
\v 22 Wozinama asi 
\q2 wolqqama olanchchati diza 
\q2 katama menththi gelees; 
\q2 istti ammanettida miixatakka 
\q2 laalli yeggees. 
\q1  
\v 23 Ba doonanne ba inxars naagiza asi 
\q2 bana boshappe naagees. 
\q1  
\v 24 Otoranchchaynne hallaca asi 
\q2 qidhanchcha geetettees; 
\q2 izi otoro hano hanees. 
\q1  
\v 25 Azalla amoy wodhees; 
\q2 ays giikko 
\q2 izi ooththanaas koyenna. 
\q1  
\v 26 Azallay gallas kumeth 
\q2 amottishe pe7ees; 
\q2 xilloy gidikko uuzettontta immees. 
\q1  
\v 27 Iita asa yarshoy harassees; 
\q2 iita qofan shiishshizaa gidikko 
\q2 ay mala iita gidanee? 
\q1  
\v 28 Wordo markkay dhayana; 
\q2 gido attiin tumu markkattizay 
\q2 minnidi de7ana. 
\q1  
\v 29 Iita asi bessonttaz xala xalees; 
\q2 gido attiin suure asi 
\q2 yuushshi qoppees. 
\q1  
\v 30 Asi ba eran, akeekaninne 
\q2 halchchon GODAARA 
\q2 eqettanaas dandayenna. 
\q1  
\v 31 Ola gallassas para giigssees; 
\q2 gido attiin xoonoy GODAAPPE yees. 
\c 22  
\q1  
\v 1 Lo7o sunththi 
\q2 daro dureteththafe aadhdhees; 
\q2 asa matan bonchcheteththika 
\q2 birappenne worqqafe aadhdhees. 
\q1  
\v 2 Durenne manqo ubbaa 
\q2 GODAY medhdhides; 
\q2 hessan istta naykka issi gina. 
\q1  
\v 3 Akeekanchcha asi iita be7idi 
\q2 attanaas baqatees; 
\q2 gido attiin akeekay paccida asi 
\q2 meton gelidi qohettees. 
\q1  
\v 4 Ashketeththinne GODAAS yashshi, 
\q2 dureteth, bonchchonne 
\q2 de7o immees. 
\q1  
\v 5 Iita asa ogen agunththinne 
\q2 yardey dees; 
\q2 gido attiin bana naagiza asi 
\q2 hessafe haakkees. 
\q1  
\v 6 Nayi waanidi de7ana bessizaakko 
\q2 tamaarsa; 
\q2 histtiko izi cimmidikka 
\q2 hessafe haakkenna. 
\q1  
\v 7 Durey manqo haarees; 
\q2 tal7e ekkidaadey tal7e 
\q2 immidaades aylle gides. 
\q1  
\v 8 Iitateth zeriza asi waaye cakkees; 
\q2 iza hanqo guufey dhayana. 
\q1  
\v 9 Kiya asi anjjettees; 
\q2 ba qumappeka hiyeesas immees. 
\q1  
\v 10 Qilcciza as digga; 
\q2 histtiko palamay attana; 
\q2 ooshshinne cashshika dhayana. 
\q1  
\v 11 Wozina geeshshateth dosiza asinne 
\q2 doonappe lo7o haasayza asara 
\q2 kawoy laggetees. 
\q1  
\v 12 GODAA ayfeti erateth naagettees; 
\q2 gido attiin wordanchchata qaala 
\q2 hada kessees. 
\q1  
\v 13 Azalla asi, 
\q2 «Gaammoy karen dees; 
\q2 tana ogen wodhana» gees. 
\q1  
\v 14 Layma maccassa doonay 
\q2 ciimma olla mala; 
\q2 GODAY hanqettida asi 
\q2 izin wullees. 
\q1  
\v 15 Naa wozina eeyateththi 
\q2 baqqi oykkees; 
\q2 gido attiin seera shoch 
\q2 izappe haassees. 
\q1  
\v 16 Baas aqota gujjana giidi 
\q2 hiyeesa naaqqizaynne 
\q2 duresi imota immizay 
\q2 naykka manqana. 
\b  
\s1 Aadho Eranchcha Zore Heedzdzu Tammata 
\q1  
\v 17 Aadho eranchcha zore 
\q2 wozinappe siya; 
\q2 ne wozinaykka 
\q2 ta timirtekko simmo! 
\q1  
\v 18 Ays giikko 
\q2 istta ne wozinan woththiko, 
\q2 ne doonanka 
\q2 istta ubbaa haasaykko 
\q2 ne ufayettana. 
\q1  
\v 19 Ne ammanoy 
\q2 GODAAN gidana mala 
\q2 tani nena hach tamaarsays. 
\q1  
\v 20 Tani neessi zorenne 
\q2 erateth immiza 
\q2 lo7o timirteta xaafabeekkinaa? 
\q1  
\v 21 Nena kiittidayssas bessiza 
\q2 zaaro zaarana mala, 
\q2 tani nena tumanne 
\q2 ammanettida qaalata 
\q2 tamaarsana mala gidennee? 
\q1  
\v 22 Hiyeesatasi aykkoyka baynda 
\q2 gishshas istta bonqofa; 
\q2 shilotankka metotanchchata 
\q2 waayisoppa. 
\q1  
\v 23 Ays giikko GODAY 
\q2 istta gishshas mootettana; 
\q2 istta bonqqidaytakka 
\q2 izi bonqqana. 
\q1  
\v 24 Hanqettiza asara laggetoppa; 
\q2 hanqettanaas eesotiza 
\q2 asarakka zuppetoppa. 
\q1  
\v 25 Neni iza hanoza meezetikko, 
\q2 guyeppe agganawu dandayakka. 
\q1  
\v 26 Waase gelanaas caaqqofa; 
\q2 asa aco qanxxanaas 
\q2 waase geloppa. 
\q1  
\v 27 Neessi qanxxizaazi dhaykko, 
\q2 ne ichchiza algayka 
\q2 attontta ekettana. 
\q1  
\v 28 Ne aawati essida 
\q2 beniisofe diza zawaa shoddofa. 
\q1  
\v 29 Ba ooson loohida as beyadii? 
\q2 Izi kawotas ooththeesippe attiin 
\q2 bessontta asatas ooththenna. 
\c 23  
\q1  
\v 1 Neni dere haarizayssara 
\q2 kath maanaas uttida wode, 
\q2 ne sinththan de7izayssa 
\q2 lo7eththada akeeka. 
\q1  
\v 2 Neni daro yora as gidikko, 
\q2 keehippe naagetta. 
\q1  
\v 3 Izi nena paaccanaas 
\q2 dandayza gishshas, 
\q2 shiiqida mal7o qumas yiiqetoppa. 
\q1  
\v 4 Duretana gaada daaburoppa; 
\q2 hayssa mala qofa agganaas 
\q2 akeekanchcha gida. 
\q1  
\v 5 Hessa mala dureteththa bolla 
\q2 neni ne ayfe woththiko 
\q2 heera dhayana; 
\q2 qefe kessida golle kafo mala 
\q2 salora paallana. 
\b  
\q1  
\v 6 Uuze asa kath mooppa; 
\q2 mal7iza iza kath 
\q2 maanaas amottofa. 
\q1  
\v 7 Qoodheppe qommon izi nena, 
\q2 «Ma; uya» geesippe attiin 
\q2 iza wozinay nenara de7enna. 
\q1  
\v 8 Neni mida guuththa kaththayka 
\q2 nena cooshshana; 
\q2 ne galataykka hada gidana. 
\b  
\q1  
\v 9 Eeyara haasayoppa; 
\q2 ays giikko 
\q2 ne aadho era haasaya 
\q2 izi kadhana. 
\q1  
\v 10 Beniisofe diza dhassaa shoddofa. 
\q2 Qasse yi7o nayta gade sugoppa; 
\q2  
\v 11 ays giikko istta 
\q2 ashshiza GODAY mino; 
\q2 izi istta gishshas nenara mootettana. 
\q1  
\v 12 Ne wozina zores, 
\q2 ne hayththaka erateththa 
\q2 qaalaakko zaara. 
\b  
\q1  
\v 13 Ne naa seeranaappe guye gooppa; 
\q2 neni qircunchchan shocikko 
\q2 izi hayqqenna. 
\q1  
\v 14 Neni qircunchchan shoca; 
\q2 iza shemppo hayqoppe ashsha. 
\q1  
\v 15 Ta naazoo! 
\q2 Ne wozinay aadho 
\q2 eranchcha gidikko 
\q2 ta wozinaykka ufayettees. 
\q1  
\v 16 Ne inxarsay suure haasayza wode 
\q2 ta wozinay ufayettees. 
\b  
\q1  
\v 17 Nagaranchchata bolla qanaatoppa; 
\q2 gido attiin ubbato GODAAS 
\q2 yashshateth aggofa. 
\q1  
\v 18 Histtiko nees sinththafe kiyana; 
\q2 ne hidotay hada gidenna. 
\b  
\q1  
\v 19 Ta naazoo! Siya; wozinama gida; 
\q2 ne wozinay suure ogeppe 
\q2 kare kezoppo. 
\q1  
\v 20 Daro woyne ushshu uyizaytaranne 
\q2 asho muussas 
\q2 yaaretizaytara zuppetoppa. 
\q1  
\v 21 Ays giikko maththottizaytinne 
\q2 yorati manqana; 
\q2 dhisko daroy carqqa mayzees. 
\b  
\q1  
\v 22 Nena yelida aaway yootizayssa siya; 
\q2 ne aayiyakka 
\q2 ceeggida wode kadhoppa. 
\q1  
\v 23 Tumaa shammafe attiin 
\q2 mulekka bayzoppa; 
\q2 aadho erateth, seeranne 
\q2 akeeka nees miishshe ooththa. 
\q1  
\v 24 Xillo naa aaway 
\q2 keehippe ufayettees; 
\q2 wozinama naa yelida asikka 
\q2 izan ufayettees. 
\q1  
\v 25 Ne aawaynne ne aaya ufayettetto; 
\q2 nena yelidaarakka ufayettu. 
\b  
\q1  
\v 26 Ta naazoo! 
\q2 Ne wozina ha taakko zaara; 
\q2 ne ayfeti ta ogeppe 
\q2 kare kezoppetto. 
\q1  
\v 27 Ays giikko layma maccassaya 
\q2 ciimma olla mala; 
\q2 laggeththo machcha 
\q2 xunththa olla mala. 
\q1  
\v 28 Iza panga mala zamada naagawus; 
\q2 ammanettontta addeta 
\q2 dere giddon darsawus. 
\b  
\q1  
\v 29 «Woo!» giza waasoy oossee? 
\q2 Ceecey oossee? Ooshshi oossee? 
\q2 Zuuzunththi oossee? 
\q2 Gaasoykka baynda 
\q2 madunththi oossee? 
\q2 Ayfey zo7izay oossee? 
\q1  
\v 30 Woyne ushshu uyishe 
\q2 gam7izaytas gidennee? 
\q2 Walakettida woyne ushshu 
\q2 yuuyi yuuyi 
\q2 ganxizaytas gidennee? 
\q1  
\v 31 Woyne ushshi zo7ida wode, 
\q2 iza medhay birille giddon 
\q2 phoolliza wode, 
\q2 duuqqishin cororu gi geliza wode 
\q2 iza tishshi histta xeellofa. 
\q1  
\v 32 Wurseththan izi 
\q2 shooshsha mala dukkees; 
\q2 goppe shooshsha malakka 
\q2 ba yiishsha puukkees. 
\q1  
\v 33 Ne ayfey beyi eronttaaz beyana; 
\q2 ne wozinaykka elumettana. 
\q1  
\v 34 Neni abbaa giddon diza 
\q2 markabe xeeran 
\q2 ichchida asa mala gidana. 
\q1  
\v 35 Neni, «Istti tana dechchida; 
\q2 gido attiin tani qohettabeekke; 
\q2 istti tana wadhdhida; 
\q2 gido attiin taas erettibeenna. 
\q2 Hara ushsha uyanaas 
\q2 tani awude 
\q2 dendandinaashaa?» gaana. 
\c 24  
\q1  
\v 1 Ta naazoo! Iita asata mala 
\q2 gidarkina gooppa; 
\q2 Isttara laggeteththika 
\q2 nena lo7oppo. 
\q1  
\v 2 Istti ubbato makkalla 
\q2 miish maqetteettes; 
\q2 bantta inxarsankka 
\q2 gene haasayeettes. 
\q1  
\v 3 Keeththi aadho erateththan 
\q2 keexettees; 
\q2 akeekankka minnees. 
\q1  
\v 4 Eray de7ikko, 
\q2 keeththi al7oninne 
\q2 lo7o miishshan kumees. 
\b  
\q1  
\v 5 Wozinama asas gita wolqqay dees; 
\q2 eranchcha asikka 
\q2 minoteth gujjees. 
\q1  
\v 6 Ola olettanaas nees lo7o zore 
\q2 xoono demmanaaskka 
\q2 daro zoranchchata koshshees. 
\b  
\q1  
\v 7 Eeya asi aadho erateththafe 
\q2 keehi haahon dees; 
\q2 duulata sinththan eqqidi 
\q2 haasayana dandayenna. 
\b  
\q1  
\v 8 Iita ooththanaas halchchiza asi 
\q2 «Genanchcha» geetettees. 
\q1  
\v 9 Eeyateththa qofay nagara; 
\q2 qilccizaade asi ixxees. 
\b  
\q1  
\v 10 Neni meto gallas laafikko, 
\q2 ne wolqqay ay mala guuththee? 
\b  
\q1  
\v 11 Hayqos laagetti bizayta ashsha; 
\q2 shukettanaas gooshetti 
\q2 bizayta ashsha. 
\q1  
\v 12 Neni, «Ta hayssa erikke» giikko, 
\q2 wozina pilggi erizayssi 
\q2 izi akeekennee? 
\q2 Ne shemppo naagizayssi erennee? 
\q2 As ubbaas iza 
\q2 ooso ooso mala immennee? 
\b  
\q1  
\v 13 Ta naazoo! 
\q2 Lo7o gidida gishshas eessa ma; 
\q2 ililo eessi doonan mal7ees. 
\q1  
\v 14 Aadho erateththika hessa mala; 
\q2 izi ne shemppos 
\q2 mal7o gididayssa era. 
\q2 Neni izo demmizaa gidikko 
\q2 wonto nees zemppo gidana; 
\q2 ne hidotaykka hada gidenna. 
\b  
\q1  
\v 15 Xillo asa keeth bonqqanaas 
\q2 panga mala zamadoppa; 
\q2 iza keeththa bolla meto gaththofa. 
\q1  
\v 16 Xillo asi 
\q2 laappunto kundikokka dendees; 
\q2 gido attiin iitati 
\q2 meton dhayeettes. 
\q1  
\v 17 Ne morkkey 
\q2 kundiza wode ufayettofa; 
\q2 izi dhuphettiza wodekka 
\q2 ne wozinan, «Hashshu!» gooppa. 
\q1  
\v 18 Ne histtontta aggiko 
\q2 GODAY hessa be7idi ufayettenna; 
\q2 izi ba hanqoza 
\q2 ne morkkeza bollafe zaarana. 
\b  
\q1  
\v 19 Iita asata ooson ceecoppa; 
\q2 istta mala gidarkina gooppa. 
\q1  
\v 20 Iita asas hidotay baawa; 
\q2 iitata xomppey tippi giidi to7ana. 
\b  
\q1  
\v 21 Ta naazoo! GODAASSINNE 
\q2 kawaas yayya; 
\q2 makkallizaytarakka zuppetoppa. 
\q1  
\v 22 Ays giikko hessa mala asata 
\q2 qoppontta metoy gakkees; 
\q2 kawoppenne GODAAPPE yaana 
\q2 meto oonee erizay? 
\s1 Aadho Eranchchay Gujji Yootida Hara Leemisota 
\p  
\v 23 Aadho eranchchati 
\q2 gujjidikka hayssaththo gida; 
\q1 Pirdishe maado pirday 
\q2 lo7o gidenna. 
\q1  
\v 24 Mooranchcha, «Neni xillo» gizaade 
\q2 derey qanggees; 
\q2 kawoteththatikka iza hileettes. 
\q1  
\v 25 Gido attiin Mooranchcha, 
\q2 «Neni mooradasa» gizayta 
\q2 isttara lo7o miishshi gayttana; 
\q2 isttas keehi daro anjjoy yaana. 
\b  
\q1  
\v 26 Suure zaaro imoy 
\q2 doona yeereteththa mala. 
\b  
\q1  
\v 27 Kasetada ne karen diza 
\q2 ooso ooththa; 
\q2 ne goshsha giigsa; 
\q2 hessafe guye ne keeth keexxa. 
\b  
\q1  
\v 28 Ne shooroza bolla 
\q2 gaasoy baynda markkattofa; 
\q2 ne doonanka cimmofa. 
\q1  
\v 29 Izi taas ooththida mala 
\q2 tani izas ooththana; 
\q2 «Tani izas iza ooso 
\q2 kushe zaarana» gooppa. 
\b  
\q1  
\v 30 Tani azalla asa gadera aadhdhadis; 
\q2 akeekay paccida asa 
\q2 woyne tura giddora kanththadis. 
\q1  
\v 31 Ubbason agunththi mokkides; 
\q2 gadaa sharafay goozides; 
\q2 gimbeyka laalettides. 
\q1  
\v 32 Tani be7idayssa yuushsha qoppadis; 
\q2 tani beyooysafe 
\q2 timirte demmadis. 
\q1  
\v 33 Neni, «Guuththara liphiphi gays; 
\q2 guuththara dhiska ekkays; 
\q2 ne kushezakka shiishshada 
\q2 guuththara shempa 
\q2 ekkays» giikko, 
\q2  
\v 34 manqoteththi ne bolla 
\q2 panga mala yaana; 
\q2 paceykka ola miishsha 
\q2 oykkida asa mala puttu gaana.\x - \xo 24:33-34 \xt Leemi 6:10-11\x* 
\c 25  
\s1 Solomooney Xaafida Hara Leemisota 
\p  
\v 1 Yuhuda Kawo Hizqiyaasa asati duuqqidi xaafida Solomoone leemisoti hayssafe kaallizayta. 
\q1  
\v 2 Xuura genththoy Xoossas bonchcho; 
\q2 xuura pilggidi kesoy 
\q2 kawotas bonchcho. 
\b  
\q1  
\v 3 Salota dhoqqateththanne 
\q2 sa7a ciimmateththa 
\q2 asi gakkonttayssa mala, 
\q2 kawota qofaakka asi pilggi 
\q2 eranaas dandayenna. 
\q1  
\v 4 Birappe qita diggaycha; 
\q2 wogaceykka qoxxidi 
\q2 lo7o miish kessana. 
\q1  
\v 5 Kawo sinththafe iitata diggaycha; 
\q2 histtiko iza kawoteththa araatay 
\q2 xilloteththan minni eqqana. 
\b  
\q1  
\v 6 Kawo sinththan nena 
\q2 dhoqqu dhoqqu histtofa; 
\q2 gita asata giddon 
\q2 beettanaas amottofa. 
\q1  
\v 7 Gita asa sinththan 
\q2 nena kawushshanaappe 
\q2 izi barkka nena, 
\q2 «Haysso dhoqqu ga» 
\q2 giikko nees lo7o.\x - \xo 25:6-7 \xt Luqa 14:8-10\x* 
\b  
\q1  
\v 8 Ne ayfezan be7ida ubbaa 
\q2 markkattanaas dubbusha 
\q2 baanaas eesotoppa; 
\q2 ays giikko 
\q2 neni markkatta simmiin, 
\q2 hara asi ne markkateththay 
\q2 bala gididayssa qonccisikko 
\q2 neni yeellatana. 
\b  
\q1  
\v 9 Neessinne ne laggezas giddon 
\q2 palamay medhettiko, 
\q2 he palama garsan 
\q2 hara asa xuura qonccisoppa. 
\q1  
\v 10 Histtontta aggiko 
\q2 neni yootizayssa siyida asi 
\q2 nena kawushshana; 
\q2 hessan ne sunththay 
\q2 nam7anththo simmidi 
\q2 lo7ontta mala moorettana. 
\b  
\q1  
\v 11 Koshshiza wodezan 
\q2 haasayettida likke 
\q2 qaalay bira bolla tigettida 
\q2 worqqa alleqo mala. 
\b  
\q1  
\v 12 Aadho erateththi diza asi 
\q2 zoriza zorey ezgiza asas 
\q2 hayththan aaththiza worqqa mala; 
\q2 woykko muuruta worqqafe 
\q2 oosettida alleqo mala. 
\b  
\q1  
\v 13 Kath shiishshiza wode irxxa haaththi 
\q2 uyiin aliza mala; 
\q2 ammanettiza kiitanchchay 
\q2 bana kiittizayta ufayssees. 
\b  
\q1  
\v 14 Immonttayssa, «Immana» giidi 
\q2 coo paapottiza asi 
\q2 iray baynda shaaranne carko mala. 
\b  
\q1  
\v 15 Dandayanchcha asi 
\q2 dere haarizaade 
\q2 yooti mayzees; 
\q2 liiqo qaalay 
\q2 meqeth kanththi gelees. 
\b  
\q1  
\v 16 Ees demmiko ginara ma; 
\q2 gido attiin darssiko 
\q2 nena xuuggana. 
\q1  
\v 17 Nena uufidi ixxontta mala 
\q2 ne lagge soo ubbato booppa. 
\b  
\q1  
\v 18 Ba laggeza bolla wordora 
\q2 markkattiza asi koxey, 
\q2 giththa mashshaynne wondafey 
\q2 as qohiza mala qohees. 
\b  
\q1  
\v 19 Metto wode ammanettontta 
\q2 asan zemppoy, 
\q2 qaaxxiza achchan 
\q2 coommiza malanne 
\q2 silida tohon hemettiza mala. 
\b  
\q1  
\v 20 Ceeci uttida asas mazamure yexeththi 
\q2 meego gallas 
\q2 may7o qaariza malanne 
\q2 madunththa bolla xuuggiza miish 
\q2 tigiza mala. 
\b  
\q1  
\v 21 Ne morkkey gafikko miza; 
\q2 saamettiko ushsha. 
\q1  
\v 22 Neni hessaththo ooththiko 
\q2 iza hu7en tama bonqo kaashidi 
\q2 qolizaade mala. 
\q2 GODAYKKA ne oosos 
\q2 waaga immana.\x - \xo 25:21-22 \xt Oro 12:20\x* 
\b  
\q1  
\v 23 Arshey mokkiza bagga carkoy 
\q2 ira ehiza mala, 
\q2 zigirsi hanqo ehees. 
\q1  
\v 24 Duunama machchira 
\q2 issi keeththan de7anaappe 
\q2 keeththa daaranchchan 
\q2 deeththi lo7o. 
\b  
\q1  
\v 25 Daaburda asi irxxa haath 
\q2 uyidi aliza mala 
\q2 haakko biittafe yiza 
\q2 lo7o qaalay ufayssees. 
\q1  
\v 26 Iita asa sinththan 
\q2 kundiza xillo asi 
\q2 bulqottida pulttonne 
\q2 moorettida olla haaththa mala. 
\q1  
\v 27 Daro eessa muusi lo7o gidenna; 
\q2 hessaththoka baas bonchcho 
\q2 koshshi bonchchisenna. 
\b  
\q1  
\v 28 Bana haarontta asi 
\q2 gimbey laalettida katama mala. 
\c 26  
\q1  
\v 1 Bonen shach, kath shiishshiza wodenkka 
\q2 iray koshshonttayssa mala, 
\q2 eeyas bonchchoy koshshenna. 
\q1  
\v 2 Kafoti yaanne haa paallishe 
\q2 as qohonttayssa mala, 
\q2 gaasoykka baynda 
\q2 qanggiza qanggeththi 
\q2 as gakkenna. 
\q1  
\v 3 Parasi lisso, 
\q2 hares ancafa koshshizayssa mala, 
\q2 eeya zokkozas durqqa koshshees. 
\q1  
\v 4 Eeya asas 
\q2 iza eeyateththa mala zaaroppa; 
\q2 zaarikko nenikka 
\q2 iza mala gidana. 
\q1  
\v 5 Gidikkoka eeyas 
\q2 iza eeyateththaa bessa; 
\q2 histtontta aggiko izi bana 
\q2 eranchcha mala qoodana. 
\q1  
\v 6 Eeya asa bolla kiita yedoy 
\q2 barkka ba tohota 
\q2 qanxxizayssa mala; 
\q2 woykko wodhiza 
\q2 marze ushsha mala. 
\q1  
\v 7 Eeya asa leemisoy 
\q2 silida toho mala. 
\q1  
\v 8 Eeya asas bonchcho imoy 
\q2 yanbarsha bolla 
\q2 qachchi woththidi 
\q2 yuushshiza shuchcha mala. 
\q1  
\v 9 Eeya asa leemisoy 
\q2 maththottida asa kushen eqqida 
\q2 agunththa mala. 
\q1  
\v 10 Eeya as woykko 
\q2 baas ogera kanththi biza as 
\q2 oosos qaxariza asi 
\q2 ba wondafen coo demmida as 
\q2 dukki madunththiza asa mala. 
\q1  
\v 11 Kanay ba cooshshi 
\q2 simmi laacciza mala, 
\q2 eeyay ba eeyateththa ooso 
\q2 zaari zaari yeggees. 
\b  
\q1  
\v 12 Barkka bana, 
\q2 «Tani aadho eranchcha» 
\q2 giza as beyadii? 
\q2 Izappe eeya asas 
\q2 lo7o qaaday dees. 
\b  
\q1  
\v 13 Azallay, «Ogen gaammoy dees; 
\q2 yashshiza gaammoy 
\q2 wogga ogen yuuyees» gees. 
\b  
\q1  
\v 14 Pengey ba maaxafa bollan 
\q2 yaanne haa qaaxxiza mala 
\q2 azallaykka ba hiixan yaanne haa 
\q2 shiretti shiretti wodhdhees. 
\b  
\q1  
\v 15 Azallay ba kushe maaddan yeddees; 
\q2 gido attiin pude ba doonan 
\q2 zaaranaas waayettees. 
\b  
\q1  
\v 16 Azalla asi akeekan yootiza 
\q2 laappun eranchchatappe 
\q2 bana aadho eranchcha 
\q2 giidi qoppees. 
\q1  
\v 17 Bana gaththontta asa yo7on 
\q2 guppi geliza asi 
\q2 kana hayth oykkiza asa mala. 
\q1  
\v 18 Gooyiza asi tamaa xiifa oliza mala 
\q2 woykko wondafe dukkiza mala; 
\q1  
\v 19 «Tani kaassas ooththadis» gishe 
\q2 ba laggeza cimmiza asikka 
\q2 hessa mala. 
\q1  
\v 20 Miththi wurikko tamay to7ees; 
\q2 zigirssi dhaykko ooshshi attees. 
\q1  
\v 21 Xiixinththi bonqo 
\q2 darssizayssa malanne 
\q2 miththi tamaa darssizayssa mala, 
\q2 doonama asi oosh darssees. 
\q1  
\v 22 Zigirsanchcha qaalay 
\q2 mal7o qumaa mala 
\q2 asas duge marace gakkees. 
\q1  
\v 23 Wozinan iita miishshi dishin, 
\q2 ba inxarsan liiqo qaala 
\q2 haasayza asi 
\q2 biran meeshettida 
\q2 mana miishsha mala. 
\q1  
\v 24 Gene asi ba doonan cimees; 
\q2 gido attiin ba wozinan 
\q2 iitateth xunttees. 
\q1  
\v 25 Iza wozinan laappun tunateththi 
\q2 kumi uttides; 
\q2 hessa gishshas izi 
\q2 lo7o qaala haasaykkoka 
\q2 ammanoppa. 
\q1  
\v 26 Izi ba gene baleththon 
\q2 genththanaas dandayees; 
\q2 gido attiin izi ooththida 
\q2 iitateththi duulatan qonccana. 
\q1  
\v 27 Haratas olla bookkiza asi 
\q2 he ollan baas kundana; 
\q2 harata bolla shuch 
\q2 bululiza asa bolla 
\q2 he shuchchay simmi 
\q2 iza bolla kundana. 
\q1  
\v 28 Wordotiza inxarsi 
\q2 ba qohida asata ixxawus; 
\q2 cimmiza metershika bash ehawus. 
\c 27  
\q1  
\v 1 Wontoyssan ceeqettofa; 
\q2 wonto aazi hananaakko 
\q2 ne erakka.\x - \xo 27:1 \xt Yaaqo 4:13-16\x* 
\q1  
\v 2 Nena hara asi galatoppe attiin 
\q2 nerkka nena galatoppa; 
\q2 hara asi nena sabbofe attiin 
\q2 neni nerkka nena sabbofa. 
\q1  
\v 3 Shuchchi deexo; 
\q2 anccoy tooko; 
\q2 gido attiin eeya asi 
\q2 denththiza ooshshi 
\q2 nam7atappeka deexxees. 
\q1  
\v 4 Sheney menxe iita; 
\q2 hanqoy menxe iita; 
\q2 qanaate sinththan eqqi 
\q2 dandayanay oonee? 
\q1  
\v 5 Geemmida siiqoppe 
\q2 qonccen seeriza seeray lo7o. 
\q1  
\v 6 Morkkey nena daroto yeeranaappe 
\q2 siiqoy nena dechchizayssi kiya. 
\q1  
\v 7 Kallida as eessa ililoy iitees; 
\q2 gido attiin gafida as 
\q2 gara mala cammiza 
\q2 miishshika mal7ees. 
\q1  
\v 8 Ba soo aggidi yuuyiza asi, 
\q2 ba keeththafe haakka paalliza 
\q2 kafo mala. 
\q1  
\v 9 Shittoynne exaaney 
\q2 as ufayssizayssa mala, 
\q2 siiqo lagge zoreykka ufayssees. 
\q1  
\v 10 Ne laggenne ne aawa lagge aggofa; 
\q2 nena metoy gakkiza wode 
\q2 ne ishaakko booppa. 
\q2 Haahon diza ishappe 
\q2 nees matan diza 
\q2 shooroy kiya. 
\q1  
\v 11 Ta naazoo! 
\q2 Neni aadho eranchcha gida; 
\q2 ta wozina ufayssa; 
\q2 histtiko tana kadhizayta 
\q2 oyshakka zaarana. 
\q1  
\v 12 Cincca asi metoy yiza wode 
\q2 be7idi qotettees; 
\q2 gido attiin akeekay paccida asi 
\q2 meto gars bi gelees; 
\q2 histtidi guyeppe qohettees. 
\q1  
\v 13 Erontta asas hurbuta geliza 
\q2 asa may7o qaara ekka; 
\q2 hawusha maccassas waase geliza 
\q2 asa may7o oykka. 
\q1  
\v 14 Maalado wonttara 
\q2 ba qaala dhoqqu histtidi 
\q2 ba shooro anjjoy 
\q2 qanggeththa mala qoodettees. 
\q1  
\v 15 Ubbaa wode oosh ooyettiza machcha 
\q2 ira gallas pacey baynda 
\q2 aaththiza keeththa mala. 
\q1  
\v 16 Carko teqqanaas woykko 
\q2 zayte cucumidi oykkanaas 
\q2 dandayettonttayssa mala 
\q2 izo co7u ooththanaas 
\q2 dandayettenna. 
\q1  
\v 17 Biratay birata qarasiza mala 
\q2 asikka issoy issaa qarasees. 
\q1  
\v 18 Balase miththayo 
\q2 ishalsidi naagida asi 
\q2 izi ayfe maana; 
\q2 ba godaas ooththiza 
\q2 asi bonchchettana. 
\q1  
\v 19 Haaththay heregaththo 
\q2 sinth bessiza mala 
\q2 asa wozinay 
\q2 izaade kando bessees. 
\q1  
\v 20 Hayqoynne Bashshi kalli erettenna; 
\q2 hessaththoka asa ayfey kallenna. 
\q1  
\v 21 Biraynne worqqay taman paacettidi 
\q2 geeyza mala 
\q2 asikka ba ekkiza 
\q2 galatan paacettees. 
\q1  
\v 22 Eeya as kaththa mala 
\q2 udulan yeggada, 
\q2 udula miththan caddizaakkoka 
\q2 izappe eeyateththi kichchenna. 
\q1  
\v 23 Ne dorsati de7iza hanota 
\q2 lo7eththada era; 
\q2 ne wudekka wozinappe heemma. 
\q1  
\v 24 Ays giikko 
\q2 dureteththi mernaas de7enna; 
\q2 kallachchayka yeletappe 
\q2 yeleta gakkanaas 
\q2 minni de7enna. 
\q1  
\v 25 Mela maatay buucettidaappe, 
\q2 aaca maatay ke7idaappe, 
\q2 zumbullata bollan de7iza maatay 
\q2 shiiqidaappe guyen, 
\q2  
\v 26 dorsata iskefe 
\q2 neni nees 
\q2 may7o kessana; 
\q2 deyshatan nees 
\q2 goshsha gade shammana. 
\q1  
\v 27 Attida deyshata maaththi 
\q2 neessinne ne soo asas, 
\q2 ne macca aylletaskka 
\q2 quma gidanaas 
\q2 kumi palahana. 
\c 28  
\q1  
\v 1 Iita asi oonikka 
\q2 yedeththontta baqatees; 
\q2 gido attiin xilloy 
\q2 gaammo mala wozina kumeththa. 
\q1  
\v 2 Derey makkalliko 
\q2 haarizay corattees; 
\q2 Gido attiin era asinne 
\q2 akeekiza asi woga essees. 
\q1  
\v 3 Hiyeesata un7eththiza daannay 
\q2 kath dhayssiza 
\q2 wolqqama ira mala. 
\q1  
\v 4 Woga bonchchontta asi 
\q2 mooranchchata sabbees; 
\q2 gido attiin wogaa bonchchizay 
\q2 istta qofa palqqees. 
\q1  
\v 5 Iita asatas suure pirday gelenna; 
\q2 gido attiin GODAAS goynnizayti 
\q2 ubbaaka ereettes. 
\q1  
\v 6 Geella as gidi uttidi 
\q2 dure gidanaappe 
\q2 borey baynda hiyeesa 
\q2 gideththi lo7o. 
\q1  
\v 7 Wogaa naagiza nay akeekanchcha; 
\q2 gido attiin 
\q2 ganjamatara zuppetizay 
\q2 ba aawa yeellasees. 
\q1  
\v 8 Bessontta dishon 
\q2 ba aqota dagasiza asi 
\q2 he aqota hiyeesas 
\q2 kiyiza asas shiishshees. 
\q1  
\v 9 Wogaa siyanaappe ba hayth 
\q2 wora zaariza asa woosay 
\q2 Xoossa harassees. 
\q1  
\v 10 Suureta iita oge kaaleththiza asi 
\q2 ba bookkida ollan kundana; 
\q2 gido attiin geeshsha asi 
\q2 lo7o miish laattana. 
\q1  
\v 11 Dure asi bana 
\q2 aadho eranchcha giidi qoppees; 
\q2 gido attiin akeekay de7iza 
\q2 hiyeesay iza paaccees. 
\q1  
\v 12 Xilloti xoonida wode asay 
\q2 ubbay ufayettees; 
\q2 gido attiin iitati maata 
\q2 oykkida wode asay baqatees. 
\q1  
\v 13 Ba nagara genththiza asi aacenna; 
\q2 gido attiin paaxizaynne 
\q2 nagara aggizay maarettana. 
\q1  
\v 14 GODAAS ubbato 
\q2 yayyiza asi anjjettidaade; 
\q2 gido attiin ba wozina dammasiza 
\q2 asi meton gelana. 
\q1  
\v 15 Hiyeesa haariza iita daannay 
\q2 xaaggiza gaammonne 
\q2 guppi oykkiza zardo mala. 
\q1  
\v 16 Wozinay paccida daannay 
\q2 menxe iitees; 
\q2 gido attiin bessontta 
\q2 go7a ixxizaadey 
\q2 daro layth de7ees. 
\q1  
\v 17 As wodhida asi hayqqana 
\q2 gakkanaas toylattishe dees; 
\q2 iza oonikka shiishshi ekkenna. 
\q1  
\v 18 Borey baynda hemettiza asi 
\q2 qohettontta attana; 
\q2 gido attiin geella asi 
\q2 issi gallas kundana. 
\q1  
\v 19 Ba gade goyiza mino asi 
\q2 kath kallees; 
\q2 gido attiin hada yo7o kaalliza asi 
\q2 manqoteththaafe ke7enna. 
\q1  
\v 20 Ammanettida asi keehi anjjettana; 
\q2 gido attiin durettanaas jaamizay 
\q2 qaxxayettontta attenna. 
\q1  
\v 21 Shaakkidi maadoy lo7enna; 
\q2 gido attiin asi guuththa kaththas 
\q2 giidi mooro ooththees. 
\q1  
\v 22 Uuzettiza asi durettanaas jaamees; 
\q2 bana hiyeesateththi 
\q2 oykkanayssaka erenna. 
\q1  
\v 23 As coo sabbiza asappe 
\q2 seeriza asi guyeppe dosettees. 
\q1  
\v 24 Ba aawappenne ba aayppe kaysidi, 
\q2 «Tani aykkoka nagara 
\q2 ooththabeekke» giza asi 
\q2 bashshiza asara issi mala. 
\q1  
\v 25 Yiiqey asi oosh denththees; 
\q2 gido attiin GODAAN 
\q2 ammanettizay anjjettees. 
\q1  
\v 26 Banan ammanettiza asi eeya; 
\q2 gido attiin aadho erateththan 
\q2 hemettizay saron de7ees. 
\q1  
\v 27 Hiyeesas immiza asas paccenna; 
\q2 gido attiin istti 
\q2 be7ishe be7onttaththo 
\q2 hanizaade qanggeththi gakkana. 
\q1  
\v 28 Iita asati maata demmiza wode 
\q2 derey baqatees; 
\q2 gido attiin istti dhayza wode 
\q2 xilloti coratteettes. 
\c 29  
\q1  
\v 1 Daro wode seeriin ixxidi 
\q2 ba morge zoodisida asi 
\q2 hassa7ontta meqqana; 
\q2 hessaades paxeteththika deenna. 
\q1  
\v 2 Xillo asati maata oykkiza wode 
\q2 asay ufayettees; 
\q2 gido attiin iita asati 
\q2 biitta haariza wode asay oolees. 
\q1  
\v 3 Aadho erateth dosiza asi 
\q2 ba aawa ufayssees; 
\q2 gido attiin laymatara laggetizay 
\q2 ba aqota dhayssees. 
\q1  
\v 4 Tumaa pirdiza kawoy 
\q2 ba dere woppu histtees; 
\q2 gido attiin matta7e 
\q2 maanaas yiiqetizay 
\q2 ba deraa laallees. 
\q1  
\v 5 Ba laggezas cimo haasayza asi 
\q2 iza tohos woximade waaxees. 
\q1  
\v 6 Iita asi barkka 
\q2 ba nagaran oykettees; 
\q2 gido attiin xillo asi 
\q2 ufayetteessinne yexxees. 
\q1  
\v 7 Xillo asi hiyeesatas 
\q2 suure pirday 
\q2 pirdettana mala qoppees; 
\q2 gido attiin iita asi 
\q2 hessa mala wudukka geenna. 
\q1  
\v 8 Miirizayti kataman 
\q2 shiro denththeettes; 
\q2 gido attiin aadho erateththi diza 
\q2 asati hanqo irixiseettes. 
\q1  
\v 9 Aadho erateththi diza asi 
\q2 eeya asara pirdaso biikko 
\q2 eeyay hanqetteessinne qidhees; 
\q2 izas saroykka deenna. 
\q1  
\v 10 Suuth gussanaas jaamiza asati 
\q2 suure as ixxeettes; 
\q2 qasse xillo asaakka 
\q2 wodhanaas koyeettes. 
\q1  
\v 11 Eeya asi zaway baynda hanqeettes; 
\q2 gido attiin aadho eranchchay 
\q2 ba hanqo mittees. 
\q1  
\v 12 Dere haarizaadey 
\q2 wordo yo7o ekkiko 
\q2 iza shuumeti ubbay 
\q2 iita gideettes. 
\q1  
\v 13 Hiyeesaynne as naaqqizaades 
\q2 koththa miishshi dees; 
\q2 GODAY nam7ataska 
\q2 xeelliza ayfe immides. 
\q1  
\v 14 Issi kawoy hiyeesas suure pirdiko 
\q2 iza kawoteththa araatay 
\q2 mernaas minni daana. 
\q1  
\v 15 Xunduqi dishoy naytas 
\q2 aadho erateth immees; 
\q2 gido attiin yeda diccida nay 
\q2 ba aayo kawushshees. 
\q1  
\v 16 Iita asati maata oykkiza wode 
\q2 nagaray darees; 
\q2 gido attiin xilloti 
\q2 istta kundeththaa be7ana. 
\q1  
\v 17 Ne naa seera; 
\q2 histtiko neni saro demmana; 
\q2 izi nena ufayssana. 
\q1  
\v 18 Ajjuutay bayndason 
\q2 derey yeda daana; 
\q2 gido attiin wogaa naagiza 
\q2 asi anjjettidaade. 
\q1  
\v 19 Ashkaray coo doonan yootiin 
\q2 xalla erenna; 
\q2 yo7oy izas gelizaakkoka 
\q2 izi azazettenna. 
\q1  
\v 20 Eeson haasayza as beyay? 
\q2 Izappe eeya asas hidotay dees. 
\q1  
\v 21 Asi ba aylle 
\q2 naateteththafe doommidi 
\q2 al7ison dichchiko 
\q2 wurseththan izaade bolla 
\q2 ceecey gakkana. 
\q1  
\v 22 Hanqettiza asi 
\q2 oosh denththeththees; 
\q2 elle yiillotiza asi 
\q2 daro nagara ooththees. 
\q1  
\v 23 Otoroy as kawushshees; 
\q2 gido attiin 
\q2 ashketeththi bonchchisees. 
\q1  
\v 24 Kaysora zuppetiza asi 
\q2 bana ixxiza asa; 
\q2 qanggi caaqisishin siyishekka 
\q2 izi co7u gees. 
\q1  
\v 25 Asas yayyizayssi 
\q2 izaades woximade gidees; 
\q2 gido attiin 
\q2 GODAAN ammanettiza asi 
\q2 saron de7ees. 
\q1  
\v 26 Daroti dere haarizayta sinththan 
\q2 erettana koyeettes; 
\q2 gido attiin asas suure pirday 
\q2 GODAA achchafe beettees. 
\q1  
\v 27 Xilloti as baleththizayta 
\q2 shaatetteettes; 
\q2 Iitati suure asata ixxeettes. 
\c 30  
\s1 Agurey Haasayda Leemisota 
\p  
\v 1 Hayssafe kaallidi xaafettidayssi Yaaqe naa Agurey haasayda leemisota. 
\q2 Agurey Itti7eelessinne 
\q2 Ukaalas hayssa haasaydes. 
\b  
\q1  
\v 2 «Tani asa ubbaafekka eeya darays; 
\q2 asas de7iza akeekay taas baawa. 
\q1  
\v 3 Tani aadho erateth tamaarabeekke; 
\q2 Geeshshaza gishshassika 
\q2 tani eriza miishshi deenna. 
\q1  
\v 4 Salo pude ke7idi 
\q2 duge wodhdhiday oonee? 
\q2 Carko ba kushen oykkiday, 
\q2 haath ba afalan yiiciday 
\q2 sa7a gaxa iza soon soon 
\q2 woththiday oonee? 
\q2 Ane erikko iza sunth taas yoota; 
\q2 Iza naaza sunththi 
\q2 oona geetettizee? 
\b  
\q1  
\v 5 «Xoossay yootiza qaalay 
\q2 ubbay tuma; 
\q2 Izan ammanettiza ubbaas 
\q2 izi gondalle. 
\q1  
\v 6 Iza qaala bolla aykkoka gujjofa; 
\q2 gujjiko izi nena seerana; 
\q2 neni wordanchcha gididayssaka 
\q2 izi qonccisana. 
\b  
\q1  
\v 7 «GODAWU! Tani nena 
\q2 nam7u miish oychchays; 
\q2 tani hayqqana gakkanaas 
\q2 istta tana diggofa. 
\q1  
\v 8 Tani as cimmontta malanne 
\q2 wordo haasayontta mala 
\q2 tana naaga; 
\q2 tana dure woykko 
\q2 manqo histtofa; 
\q2 gido attiin hachchis hachchis 
\q2 gidiza kath taas imma. 
\q1  
\v 9 Histtontta aggiko 
\q2 tani keeha kallada nena kaddana; 
\q2 ‹GODAY izi oonee?› gaana; 
\q2 woykko manqada kaysana; 
\q2 histtada tani Xoossa 
\q2 sunththaa caysana. 
\b  
\q1  
\v 10 «Nena qanggontta malanne 
\q2 izi qanggiin nees 
\q2 gometontta mala, 
\q2 aylle iza goda sinththan 
\q2 iitan denththofa. 
\q1  
\v 11 Ba aawa qanggizanne 
\q2 ba aayokka anjjontta 
\q2 yeletay dees. 
\q1  
\v 12 Tuna gidi uttidi 
\q2 banttana geeshsha mala 
\q2 qoodiza asati deettes. 
\q1  
\v 13 Otoron kumida asatinne 
\q2 as kadhidi xeelliza asati deettes. 
\q1  
\v 14 Hiyeesatanne metotanchchata 
\q2 dere giddofe dhayssanaas 
\q2 istta achchay mashsha mala gidida 
\q2 istta gaaginay biillama mala 
\q2 gidida asati deettes. 
\b  
\q1  
\v 15 «Ulos nam7u macca nayti deettes. 
\q2 Istti, ‹Nuus imma! Nuus imma!› 
\q2 giidi waasseettes. 
\q2 Mulekka kalli erontta 
\q2 heedzdzati deettes; 
\q2 oydanththozi qasse mulera, 
\q2 ‹Gidana› gi erenna. 
\q1  
\v 16 Hessanttika duufo, maynida ulo, 
\q2 haaththi kalli erontta 
\q2 mela biittanne, 
\q2 ‹Taas gidana!› gi erontta tama. 
\b  
\q1  
\v 17 «Ba aawa qidhiza naa ayfenne, 
\q2 ba aayo kadhiza naa ayfe 
\q2 kelkan de7iza quuroti woocana; 
\q2 iza ashoza ankkoti maana. 
\q1  
\v 18 Tana keehi malalisiza 
\q2 heedzdzu miishshati deettes; 
\q2 oydanththozi 
\q2 ubbaarakka taas gelenna. 
\q1  
\v 19 Hessanttika golleti 
\q2 salora paalliza paalo, 
\q2 shooshshi shuchcha bollara 
\q2 sololu gi buus, 
\q2 markabey abbaa bollara biza 
\q2 buus addey macca naa siiqo 
\q2 demmanaas haniza hanota. 
\b  
\q1  
\v 20 «Layma maccassaya 
\q2 haniza hanoykka 
\q2 hessa mala. 
\q2 Iza muussa mawus; 
\q2 gido attiin midaappe guyen, 
\q2 ba doona quccada, 
\q2 ‹Tani aykkoka 
\q2 moorabeekke› gawus. 
\b  
\q1  
\v 21 «Heedzdzu yo7otan 
\q2 biittay qaaxxees; 
\q2 oydanththoza ubbaaka 
\q2 tookkanaas dandayenna. 
\q1  
\v 22 Hessanttika aylley kawotida wode, 
\q2 eeyay kath kallida wode, 
\q1  
\v 23 asi ixxida maccassaya 
\q2 adde gelida wodenne 
\q2 macca ashkariya ba godatteyo 
\q2 laattida wode haniza hanota. 
\b  
\q1  
\v 24 «Sa7a bolla oyddu 
\q2 guuththa medhetati deettes; 
\q2 gido attiin istti 
\q2 keehi aadho eranchchata. 
\q1  
\v 25 Hessanttika cunccalleti 
\q2 wolqqay baynda medheta; 
\q2 gido attiin banttas miza miish 
\q2 bone shiishshi dagaseettes. 
\q1  
\v 26 Guppaleti guuththa 
\q2 wolqqay de7izayta; 
\q2 gido attiin bantta keeth 
\q2 zaalla giddon keexxeettes. 
\q1  
\v 27 Booletas kawoy deenna; 
\q2 gido attiin istti ubbayka 
\q2 maaran maaran zatteettes. 
\q1  
\v 28 Zareti kushen 
\q2 oykkiinkka oyketteettes; 
\q2 gido attiin istti 
\q2 kawo keeththankka de7eettes. 
\b  
\q1  
\v 29 «Bantta maata bessishe hemettiza, 
\q2 heedzdzu medhetati deettes; 
\q2 oydanththozikka 
\q2 puulattidi hemettees. 
\q1  
\v 30 Hessanttika do7a ubbaafe 
\q2 wolqqamanne 
\q2 aykkoska yayyidi 
\q2 baqati erontta gaammo. 
\q1  
\v 31 Maccassata giddon kososi 
\q2 hemettiza adde kutto, 
\q2 deysha orgenne 
\q2 ba olanchchatan 
\q2 ajjabettida kawo. 
\b  
\q1  
\v 32 «Neni eeyada 
\q2 otorettidaa gidikkonne 
\q2 iita miish ooththanaas 
\q2 halchchidaa gidikko 
\q2 ane takki gaada qoppa. 
\q1  
\v 33 Maaththi bukkiin oysi ke7iza mala, 
\q2 siidhe iccinkka 
\q2 suuththi yiza mala 
\q2 hanqo denththeththiko 
\q2 oosh medhdhees.» 
\c 31  
\s1 Kawo Limu7eele Aaya Ba Naazas Immida Timirte 
\p  
\v 1 Kawo Limu7eele aaya kawo Limu7eele tamaarsida timirtey hayssafe kaallidayssa. 
\q1  
\v 2 «Ta naazoo! 
\q2 Ta uloppe wodhdhida ta naazoo! 
\q2 Tani adinetta yelida ta naazoo! 
\q1  
\v 3 Maccassan ne wolqqa wursofa; 
\q2 kawota bashshiza miishshan 
\q2 ne akata dhayssofa. 
\b  
\q1  
\v 4 «Limu7eele hayssi kawotas 
\q2 bessenna; 
\q2 kawoti woyne ushshu 
\q2 uyanaas bessenna; 
\q2 dere ayssizayti 
\q2 maththosiza ushshu 
\q2 yaaretanaas bessenna. 
\q1  
\v 5 Istti uyiza wode wogaa baletteettes; 
\q2 qohettidayta maata sugeettes. 
\q1  
\v 6 Hayqqana hanizaytas 
\q2 maththosiza ushshu 
\q2 meto bolla dizaytas 
\q2 woyne ushshu immite. 
\q1  
\v 7 Istti uyidi 
\q2 bantta manqoteththa dogetto; 
\q2 bantta tuggaka zaari qoppofetto. 
\b  
\q1  
\v 8 «Bantta gishshas haasayanaas 
\q2 dandayonttaytas 
\q2 neni haasaya; 
\q2 metotanchchata maata gishshas 
\q2 neni mootetta. 
\q1  
\v 9 Haasayada isttas suure pirda pirda; 
\q2 hiyeesatanne 
\q2 metotanchchata maata 
\q2 bonchchisa» gaada tamaarsadus. 
\b  
\s1 Wozinama Machcho 
\q1  
\v 10 Wozinama machcho 
\q2 ooni demmanawu dandayzee? 
\q2 Iza zo7o inqqufekka 
\q2 keeha aadhdhawus. 
\q1  
\v 11 Izi keeththa aaway 
\q2 izo ubbaa miishshankka 
\q2 ammanees; 
\q2 izas aykkoyka paccenna. 
\q1  
\v 12 Iza ba de7o layth ubbaan 
\q2 izas lo7o attiin 
\q2 iita miish ooththuku. 
\q1  
\v 13 Dorsa iskefenne 
\q2 talbba buuxa ekkada, 
\q2 ooso dosiza ba kushen suqawus. 
\q1  
\v 14 Iza zal7anchchata markabe mala; 
\q2 ba kath haakko biittafe ehawus. 
\q1  
\v 15 Iza ba soo asas 
\q2 quma kaththanaassinne 
\q2 ba macca aylletas 
\q2 ooso shaakka immanaas, 
\q2 sa7ay buro wonttana gishin 
\q2 dendawus. 
\q1  
\v 16 Iza barkka qoppada 
\q2 goshsha gade shammawus; 
\q2 ba demmida miishshan 
\q2 woyne tokkawus. 
\q1  
\v 17 Iza minnada ba ooso polawus; 
\q2 izi qesetikka oosos mino. 
\q1  
\v 18 Iza ba oosos 
\q2 wodhey dizayssa akeekawus; 
\q2 omarsika izi xomppey to7enna. 
\q1  
\v 19 Iza ba liqaqan suqawus, 
\q2 ba afala daddawus. 
\q1  
\v 20 Iza hiyeesatas ba kushe miccawus; 
\q2 metotanchchatas 
\q2 kiyateth immawus. 
\q1  
\v 21 Izi soo asay ubbay 
\q2 ho7iza may7o may7ida; 
\q2 hessa gishshas iza 
\q2 shachchi bukkikokka hirguku. 
\q1  
\v 22 Hiiththan ongiza 
\q2 may7o ooththawus; 
\q2 laynonne ochcha teera misatiza 
\q2 may7o may7awus. 
\q1  
\v 23 Dere cimati dubbusha shiiqizason 
\q2 izi keeththa aaway 
\q2 bonchchettida asa. 
\q1  
\v 24 Laynoppe seelo may7ota 
\q2 ooththada bayzawus; 
\q2 zal7anchchataskka dancco 
\q2 dadda shiishshawus. 
\q1  
\v 25 Iza minonne puulara diza maccassa; 
\q2 iza yiza layththata 
\q2 ufayssan mokkawus. 
\q1  
\v 26 Aadho eran iza haasayawus; 
\q2 izi inxarsafe 
\q2 suure zorey ke7ees. 
\q1  
\v 27 Iza ba soo asaa hano 
\q2 lo7eththa kaallawus; 
\q2 azalla hanoy izi bollan 
\q2 beetti erenna. 
\q1  
\v 28 Izi nayti izo, 
\q2 «Anjjettidaree» geettes; 
\q2 izi keeththa aawaykka 
\q2 izo galatishe, 
\q1  
\v 29 «Lo7o miish ooththida 
\q2 daro maccassati deettes; 
\q2 gido attiin neni istta 
\q2 ubbaafe aadhdhaasa» gees. 
\q1  
\v 30 Mala lo7oy baleththees; 
\q2 puulaykka qokkees; 
\q2 gido attiin GODAAS yayyiza 
\q2 maccassi iza anjjettidaaro. 
\q1  
\v 31 Izis bessiza imota immite; 
\q2 iza ooththida oosoy ubbay 
\q2 dubbushan izo galatisso.