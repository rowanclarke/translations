\v 23 \w The|strong="H3606"\w* \w king|strong="H4430"\w* \w was|strong="H4430"\w* overjoyed \w and|strong="H4430"\w* gave orders \w to|strong="H6925"\w* lift Daniel \w out|strong="H5648"\w* \w of|strong="H4430"\w* \w the|strong="H3606"\w* den, \w and|strong="H4430"\w* \w when|strong="H1768"\w* Daniel \w was|strong="H4430"\w* lifted \w out|strong="H5648"\w* \w of|strong="H4430"\w* \w the|strong="H3606"\w* den, \w no|strong="H3809"\w* wounds \w whatsoever|strong="H3606"\w* \w were|strong="H1768"\w* \w found|strong="H7912"\w* on \w him|strong="H6925"\w*, \w because|strong="H6903"\w* \w he|strong="H1768"\w* \w had|strong="H4430"\w* trusted \w in|strong="H7912"\w* \w his|strong="H7972"\w* God.
\b
\m 
\v 24 \w At|strong="H7912"\w* \w the|strong="H3606"\w* command \w of|strong="H4481"\w* \w the|strong="H3606"\w* \w king|strong="H4430"\w*, \w the|strong="H3606"\w* men \w who|strong="H1768"\w* \w had|strong="H4430"\w* falsely accused \w Daniel|strong="H1841"\w* \w were|strong="H1768"\w* \w brought|strong="H1841"\w* \w and|strong="H4430"\w* thrown into \w the|strong="H3606"\w* \w den|strong="H1358"\w* \w of|strong="H4481"\w* lions—\w they|strong="H3606"\w* \w and|strong="H4430"\w* \w their|strong="H3606"\w* children \w and|strong="H4430"\w* wives. \w And|strong="H4430"\w* \w before|strong="H4481"\w* \w they|strong="H3606"\w* \w had|strong="H4430"\w* reached \w the|strong="H3606"\w* bottom \w of|strong="H4481"\w* \w the|strong="H3606"\w* \w den|strong="H1358"\w*, \w the|strong="H3606"\w* lions overpowered \w them|strong="H5922"\w* \w and|strong="H4430"\w* crushed \w all|strong="H3606"\w* \w their|strong="H3606"\w* bones.
\s1 Darius Honors God
\b
\m 
\v 25 \w Then|strong="H1768"\w* \w King|strong="H4430"\w* Darius wrote \w to|strong="H5705"\w* \w the|strong="H3606"\w* \w people|strong="H1400"\w* \w of|strong="H4430"\w* \w every|strong="H3606"\w* nation \w and|strong="H4430"\w* language throughout \w the|strong="H3606"\w* land: “May \w your|strong="H1768"\w* prosperity abound.
\v 26 \w I|strong="H1768"\w* hereby decree \w that|strong="H1768"\w* \w in|strong="H1753"\w* \w every|strong="H3606"\w* part \w of|strong="H4430"\w* \w my|strong="H1768"\w* kingdom, men \w are|strong="H1768"\w* \w to|strong="H4430"\w* tremble \w in|strong="H1753"\w* fear before \w the|strong="H3606"\w* God \w of|strong="H4430"\w* Daniel:
\b
\q1 \w For|strong="H1768"\w* \w He|strong="H1768"\w* \w is|strong="H1768"\w* \w the|strong="H3606"\w* \w living|strong="H1753"\w* God,
\q2 \w and|strong="H4430"\w* \w He|strong="H1768"\w* endures forever;
