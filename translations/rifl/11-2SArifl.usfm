\id 2SA
\h 2 Ṣamwil 
\toc1 2 Ṣamwil 
\toc2 2 Ṣamwil 
\toc3 2 Ṣm. 
\mt1 2 Ṣamwil  
\c 1
\s1 Řmewt n Cawul d Yunatan  
\m
\v 1 Imsar awarni i řmewt n Cawul, \add umi\add* dd-iɛqeb Dawud zi řeɣřeb x ayt n Ɛamaliq, iqqim Dawud tnayen n wussan di Ṣiqlaɣ. \x ◘ \xo 1:1 \xt 1 Ṣm. 30:17\x*  
\v 2 \add Xenni\add* imsar deg wass wiss třata, aqa da, yusa-dd ijj n weryaz zi řmargeḥ n řɛeskar n Cawul s warruḍ icarreg u s ucař x uzeǧif nnes. \add Umi\add* dd-yiweḍ netta ɣar Dawud, iwḍa ɣar temmurt, yuḍar \add as\add*.  
\v 3 Dawud inna as: “Manis i dd-tusid cek?” Netta yarra-dd xas: “Necc ssnejmeɣ-dd ixef inu zi řmargeḥ n řɛeskar n Israil.”  
\v 4 Dawud inna as: “Min \add din\add* d řexbar? Ini ayi t!” Netta yarra-dd xas: “Řgens yarweř zeg umenɣi u aṭṭas n řgens i wḍan, mmuten. Uřa d Cawul d mmis Yunatan mmuten.”  
\v 5 Dawud inna i uḥudri nni d as dd-yiwyen řexbar: “Mammec teggid tessned, belli Cawul d mmis Yunatan mmuten?”  
\v 6 \add Xenni\add* inna uḥudri i d as dd-yiwyen řexbar: “Necc usiɣ-dd amenni waha ɣar idurar n Jilbuɛa uca ẓriɣ mammec isenned Cawul x lansa nnes u ikarruten \add n umenɣi\add* d imnayen inni xasen inyin ḍeffaren t břa qeṭṭu. \f ◼ \fr 1:6 \ft \+fk amnay - imnayen\ft  - niɣ ‘bu-iysan’ - ‘ayt n bu-iysan’. D wenni inyin x yijj n uyis d netta d amnay.\f*  
\v 7 Netta, am dd-inneqřeb, iẓra ayi, iřaɣa ayi-dd u necc nniɣ as: ‘Aqa-yi da!’  
\v 8 Netta inna ayi: ‘Min teɛnid cek?’ Necc arriɣ-dd xas: ‘Necc zeg ayt n Ɛamaliq.’  
\v 9 \add Xenni\add* inna ayi netta: ‘As-dd ɣari, neɣ ayi, maɣar necc teřqef ayi tuccent, maca \add waxxa amenni\add* tudart aqa-tt dayi.’ \f ◼ \fr 1:9 \ft \+fk tudart\ft  - s Tɛibranit ‘řeɛmar’.\f*  
\v 10 \add Řexdenni\add* necc uyureɣ u nɣiɣ t, maɣar necc ssneɣ, aqa war ittɣimi iddar awarni i uweṭṭu nnes. \add Xenni\add* ksiɣ ttaj \add n weɛzař\add* nni x uzeǧif nnes d tmeqyast i tuɣa ɣares deg uɣiř, iwyeɣ ten-dd \add řexxu\add* da ɣar sidi inu.”   
\m
\v 11 \add Řexdenni\add* iṭṭef Dawud arruḍ nnes, icarreg i-t. \add Ammu i tt ggin\add* uřa d marra iryazen i tuɣa ɣares iǧan. \x ◘ \xo 1:11 \xt 2 Ṣm. 3:31; 13:31\x*  
\v 12 Nitni wtin agejdur, run u ẓummen ař tameddit x Cawul, x mmis Yunatan, x řgens n SIDI u x taddart n Israil, minzi wḍan s ssif.   
\m
\v 13 \add Xenni\add* inna Dawud i uḥudri nni tuɣa i d as-dd-yiwyen řexbar: “Zi manis \add dd-tusid\add* cek?” Netta inna as: “Necc d mmis n ijj n ubarrani, n ijj n weryaz zeg ayt n Ɛamaliq.”  
\v 14 Dawud inna as: “Mammec teggid, cek war teggʷided ca ad tesswiẓẓḍed s ufus ḥima ad tareddǧed amedhun n SIDI?”  
\v 15 \add Xas\add* uca iřaɣa-dd Dawud x ijjen zeg imsexxaren inna: “Qarreb-dd, ḥeyyeḥ xas!” U netta iḥeyyeḥ xas ařami t inɣa.  
\v 16 Dawud inna as: “Idammen nnec \add ad iřin\add* x uzeǧif nnec, maɣar aqemmum nnec iched xak umi tennid: ‘Necc nɣiɣ amedhun n SIDI.’”   
\b  
\m  
\s1 Izři s igejduren x Cawul d Yunatan  
\m
\v 17 Iɣennej Dawud izři-ya n wecḍan x Cawul u x mmis Yunatan.  
\v 18 Netta inna: “Ad řemden ayt n Yahuda \add Izři n\add* Řqews.” Xzar, yura deg Wedlis n Umsegged. \x ◘ \xo 1:18 \xt Yac. 10:13\x*   
\b  
\m
\v 19 \qt “Talwizt n Israil ittwaneɣ\qt*  
\m \qt x řegɛudi nnec.\qt*  
\m \qt Mammec wḍan ayt n bu-teɣruḍt!\qt*   
\m
\v 20 \qt War \+tl tt\+tl* ttḥajam di Jat,\qt*  
\m \qt war ttsiwḍem řexbar\qt*  
\m \qt deg ibriden n Acqalun,\qt*  
\m \qt maḥend yessis n Ifilisṭiniyyen\qt*  
\m \qt war farrḥent,\qt*  
\m \qt maḥend yessis n yinni war ittwaxetnen\qt*  
\m \qt war ssřiwřiwent.\qt* \x ◘ \xo 1:20 \xt Mixa 1:10\x*   
\m
\v 21 \qt \+tl A\+tl* idurar n Jilbuɛa,\qt*  
\m \qt war xawem ittiři nnda niɣ anẓar,\qt*  
\m \qt war xawem ttiřin iyyaren\qt*  
\m \tl maḥend ad zzaysen ttwakksent\tl*  
\m \qt tiwhibin n usgeɛɛed,\qt*  
\m \qt maɣar din ittwabeqqeḍ\qt*  
\m \qt tseddart n ayt n bu-teɣruḍt s řɛar,\qt*  
\m \qt taseddart n Cawul,\qt*  
\m \qt \+tl axmi netta\+tl* war iǧi d amedhun s zzect.\qt*   
\m
\v 22 \qt Zeg idammen n yinni ittwanɣen,\qt*  
\m \qt zi tadunt n ayt n bu-teɣruḍt\qt*  
\m \qt war d imniɛ řqews n Yunatan,\qt*  
\m \qt u ssif n Cawul war dd-iɛqib baṭeř.\qt*   
\m
\v 23 \qt Cawul d Yunatan ttwaɛizzen\qt*  
\m \qt d iɣřan \+tl ɣar iwdan\+tl* di tudart nsen,\qt*  
\m \qt u di řmewt nsen war mmsebḍin.\qt*  
\m \qt \+tl Nitni tuɣa aten\+tl* fsusen x igidaren\qt*  
\m \qt d jehden x wayraden.\qt*   
\m
\v 24 \qt \+tl A\+tl* yessis n Israil, runt x Cawul,\qt*  
\m \qt wenni kennint issyarḍen s uzeggʷaɣ,\qt*  
\m \qt s řeqcuɛ iɣřan,\qt*  
\m \qt d wenni iggin talwizt n wureɣ\qt*  
\m \qt x warruḍ nkent.\qt*   
\m
\v 25 \qt Mammec i wḍan ayt n bu-teɣruḍt\qt*  
\m \qt di řwesṭ n umenɣi!\qt*  
\m \qt \+tl A,\+tl* Yunatan, tettwanɣed x řegɛudi nnec.\qt*   
\m
\v 26 \qt Di ssibbet nnec ttwaḥṣareɣ,\qt*  
\m \qt \+tl a\+tl* uma Yunatan!\qt*  
\m \qt Cek tuɣa tᵉttwaɛizzed ɣari aṭṭas.\qt*  
\m \qt Tuɣa tayri nnec ɣari d ssar ktar\qt*  
\m \qt x tayri n temɣarin.\qt*   
\m
\v 27 \qt Mammec wḍan ayt n bu-teɣruḍt,\qt*  
\m \qt \+tl mammec\+tl* weddaren řesnaḥ n umenɣi!”\qt*   
\b  
\b  
\m  
\c 2
\s1 Dawud ittwadhen am ujeǧid x Yahuda  
\m
\v 1 Awarni uya imsar, aqa Dawud isseqsa SIDI, inna: “Ma ad geɛɛdeɣ ɣar icten zi tneddam n Yahuda?” SIDI inna as: “Geɛɛed!” Uca Dawud inna: “Mani ɣa geɛɛdeɣ?” Netta inna: “Ɣar Ḥabrun.”  
\v 2 \add Xenni\add* igeɛɛed Dawud ɣar Ḥabrun ak-d tnayen n temɣarin nnes, Axinuɛam zi Yazraɛil, u Abijayil, tamɣart n Nabal zi Karmil.  
\v 3 Dawud yarra ad geɛɛden ɛawed iryazen nni tuɣa akides \add iǧan\add*, \add kuř\add* aryaz ak-d twacunt nnes, uca nitni uyuren ad zedɣen di tneddam n Ḥabrun.  
\v 4 \add Awarni uya\add* usin-dd yeryazen n Yahuda \add ɣar Ḥabrun\add* uca dehnen Dawud dinni d ajeǧid x taddart n Yahuda. \add Xenni\add* usin-dd ḥima ad xebbaren Dawud, nnan: “Iryazen n Yabic di Jilɛad aqa neḍřen Cawul.”   
\m
\v 5 \add Xenni\add* issekk Dawud ireqqasen ɣar yeryazen n Yabic di Jilɛad, inna asen: “Ad kenniw ibarek SIDI, minzi kenniw teggim i Cawul, sidi nwem, s tmexsiwt icewwaren uca tneḍřem t.  
\v 6 Ad awem isscen SIDI řexxu tamexsiwt \add nnes\add* icewwaren d řaman nnes. Uřa d necc ad awem ggeɣ s tcuni, minzi aqa kenniw teggim aya.  
\v 7 Xenni řexxu, jjem ad ttwassjehden ifassen nwem u iřim tmeḥḥdem, maɣar Cawul, sidi nwem, immut. Uřa d taddart n Yahuda tedhen ayi d ajeǧid xasen.”   
\b  
\m  
\s1 Dawud d Ic-Bucat, mmis n Cawul  
\m
\v 8 Abnir, mmis n Nir, akumandar n řɛeskar n Cawul, tuɣa yiwi akides Ic-Bucat, mmis n Cawul, ɣar Maḥanayim.  
\v 9 Netta igga i-t d ajeǧid x Jilɛad, x Icuriyyen, x Yazraɛil, x Ifrayim, x Binyamin u x marra Israil.  
\v 10 Ic-Bucat, mmis n Cawul, tuɣa ɣares arebɛin n iseggʷusa umi idweř netta d ajeǧid x Israil, u netta iḥkem tnayen n iseggʷusa. Mɣir inni n taddart n Yahuda bedden ak-d Dawud.  
\v 11 Řqedd n wussan i tuɣa Dawud iḥkem di Ḥabrun am ujeǧid x taddart n Yahuda, tuɣa sebɛa n iseggʷusa d setta n iyuren. \x ◘ \xo 2:11 \xt 2 Ṣm. 5:5; 1 Ij. 2:11\x*   
\m
\v 12 Abnir, mmis n Nir, iffeɣ ak-d imsexxaren n Ic-Bucat, mmis n Cawul, zi Maḥanayim ɣar Jibɛun.  
\v 13 Uřa d Yuwab, mmis n Ṣaruya, d imsexxaren n Dawud ffɣen uca nitni mmeřqan ak-d wayawya ɣar uyeřmam n Jibɛun. \add Dinni\add* qqimen nitni bedden, ijj ɣar uɣezdis-a n uyeřmam u wenneɣni x ujemmaḍ n uyeřmam.  
\v 14 Inna Abnir i Yuwab: “Ejj iḥudriyyen ad kkaren ad mmuɣzřen zzatneɣ.” Yuwab inna: “Nitni ad kkaren!”  
\v 15 Nitni kkaren, \add xenni\add* ɛeddun. Aqa ḥesben tenɛac zi Binyamin i Ic-Bucat, mmis n Cawul, u tenɛac zeg imsexxaren n Dawud.  
\v 16 Ijj iṭṭef wenneɣni zeg uzeǧif u ijju as s ssif nnes deg uɣezdis n wenneɣni u nitni wḍan s tnayen idsen. S uyenni qqaren as i wemcan nni Ḥalqat-Haṣurim wenni \add iǧan\add* ɣar Jibɛun.  
\v 17 Deg wass nni idweř umenɣi iqseḥ aṭṭas. Abnir d yeryazen n Israil ttwaɣellben zzat i wudem n imsexxaren n Dawud.   
\m
\v 18 Tuɣa din třata n iḥenjiren n Ṣaruya, nitni d Yuwab d Abicay d Ɛasa’il. Ɛasa’il tuɣa ifsus x iḍaren am yijj zeg iɣayḍen n wezɣar deg iyyar.  
\v 19 Ɛasa’il iḍfar Abnir. Umi tuɣa iggur, war iḥeyyed ɣar ḍeffar n Abnir, \add řa ɣar\add* yefus uřa \add ɣar\add* uzeřmaḍ.  
\v 20 Uca inneqřeb Abnir, inna: “Ma d cek, Ɛasa’il?” U netta inna: “D necc!”  
\v 21 Abnir inna as: “Farɣ \add ɣar\add* yefus niɣ \add ɣar\add* uzeřmaḍ u cebbar deg ijj zeg iḥudriyyen u ksi i yixef nnec arruḍ nnes n řɛeskar!” Ɛasa’il \add maca\add* war ixs ad xas iḥeyyed zi ḍeffar nnes.  
\v 22 \add Xenni\add* inna Abnir ɛawed i Ɛasa’il: “Ḥeyyed zi ḍeffar inu. Mayemmi cek i ɣa wteɣ ɣar temmurt? Mammec i ɣa ggeɣ xenni ɛad ad xzareɣ i umac Yuwab di tiṭṭawin?”  
\v 23 Netta \add maca\add* yugi ad as iḥeyyed. \add Xenni\add* ijju as Abnir deg uɛeddis s yixef aneggaru n lansa nnes, ařami dd-issuffeɣ fřitca zi ḍeffar. Netta iwḍa din uca immut deg wemcan nni. Imsar belli marra inni dd-yusin ɣar wemcan mani iwḍa u mani immut Ɛasa’il, qqimen bedden.  
\v 24 Yuwab d Abicay ḍfaren Abnir. Řami dd-iwḍen nitni ař tawrirt n Amma, tenni zzat i Jiyaḥ, ɣar webrid n řexřa n Jibɛun, teɣři tfuct.  
\v 25 Ayt n Binyamin munen awarni Abnir, dewřen d ict n terbiɛt \add akides\add*, uca \add ammu i qqimen\add* nitni bedden x tqiccet n ict n tewrirt.  
\v 26 Abnir iřaɣa-dd x Yuwab, inna: “Ma ad icc ssif i řebda? Ma war tessined cek, aqa aya ad indeh ɣar ijj n uqeṭṭu d amerzag? Ař meřmi \add ɛad\add* war teqqared i řgens \add nnec,\add* ḥima ad iɛqeb zeg weḍfar n aytmatsen?”  
\v 27 Yuwab inna: “\add S tidett am\add* iddar AREBBI, mařa cek war tessiwřed \add x ijj n umuɣzeř\add*, xenni ad yiři řgens issbedd \add zi man aya\add* ɣar ṣṣbeḥ, iři \add kuř\add* aryaz \add ad issbedd\add* zeg weḍfar n umas!”  
\v 28 \add Xenni\add* isuḍ Yuwab deg uyicc n icarri u marra řgens issbedd. Nitni war ḍfaren ɛad Israil uca war mmenɣen ɛad ktar.   
\m
\v 29 Abnir d yeryazen nnes cuqen ǧiřet nni marra di Řewḍa, ẓwan L’Urdun, kkin x marra taɣzurt uca iwḍen ɣar Maḥanayim.  
\v 30 Uřa d Yuwab iɛqeb-dd zeg weḍfar n Abnir u netta issmun marra řgens. Weddaren tseɛṭac n iryazen n Dawud uřa d Ɛasa’il.  
\v 31 Imsexxaren n Dawud \add maca\add* tuɣa wtin \add aṭṭas n yeryazen\add* zeg \add ayt n\add* Binyamin u zeg yeryazen n Abnir. Mmuten teřt-mya u-settin n yeryazen.  
\v 32 Nitni ssgeɛɛden Ɛasa’il u neḍřen t deg wenḍeř n babas di Bayt-Laḥm. Yuwab d yeryazen nnes uyuren ǧiřet nni marra u řami iwḍen ɣar Ḥabrun, tenqar-dd xasen tfawt.   
\b  
\b  
\m  
\c 3
\s1 Amenɣi jar aytbab n taddart n Cawul d Dawud  
\m
\v 1 Idweř ij n umenɣi jar taddart n Cawul d taddart n Dawud i ikkin aṭṭas. Dawud idweř yarenni di jjhed u inni n taddart n Cawul gguren arexxun.   
\b  
\m
\v 2 \bd Di Ḥabrun ttwarwen-dd i Dawud iḥenjiren.\bd* Amenzu nnes Amnun, n Axinuɛam Tayazraɛilit. \f ◼ \fr 3:2 \ft \+fk Tayazraɛilit\ft  - ict n temɣart zi jjihet n Yazraɛil di ccamal n Israil.\f*  \x ◘ \xo 3:2 \xt 1 Im. 3:1-9\x*  
\v 3 Wiss tnayen nnes Kil’ab, n Abijayil, tamɣart n Nabal, Akarmali, wiss třata Abcalum, mmis n Maɛka, yeǧis n Talmay, ajeǧid n Jacur, \f ◼ \fr 3:3 \ft \+fk Akarmali\ft  - ijj n weryaz zi jjihet n Karmil.\f*  
\v 4 wiss arebɛa Aduniya, mmis n Hajjit, wiss xemsa Cafaṭya, mmis n Abiṭal,  
\v 5 u wiss setta Yitraɛam, n Ɛajla, tamɣart n Dawud. Ina ttwarwen-dd ɣar Dawud di Ḥabrun.   
\b  
\m
\v 6 Min ikka umenɣi jar taddart n Cawul d taddart n Dawud, imsar, aqa Abnir issemɣar tizemmar nnes di taddart n Cawul.  
\v 7 Cawul tuɣa ɣares ict n tayya, ttřaɣan as Riṣfa. Nettat tuɣa-tt d yeǧis n Ayya. Uca inna \add Ic-Bucat\add* i Abnir: “Mayemmi tudfed ɣar tayya n baba?” \x ◘ \xo 3:7 \xt 2 Ṣm. 21:8, 10, 11\x*  
\v 8 Abnir iffugem x wawařen n Ic-Bucat, inna: “Ma necc d ijj n uzeǧif n weqzin i iqqnen ɣar Yahuda? Ma war iǧi d necc d wenni isscanen \add ɛad ař\add* ass-a tamexsiwt \add inu\add* icewwaren i taddart n Cawul, babac, u i yaytmas u i imeddukkař nnes, ma war iǧi d necc d wenni war cek ijjin ad tewḍid deg ifassen n Dawud? Ma texsed \add xenni\add* ad xafi tɛeyyared ass-a x řmuɛṣiyyet ak-d ict n temɣart?  
\v 9 Ejj AREBBI ad igg ta d ta ak-d Abnir u ad dayes yarni ɛad! Am mammec ijjuǧ SIDI i Dawud ammu i zzayes ɣa ggeɣ,  
\v 10 umi ɣa sseɛduɣ tageldit n taddart n Cawul uca ad ssmetneɣ řɛarc n Dawud x Israil u x Yahuda, zi Dan ař Bi’r-Sebɛa.”  
\v 11 Uca netta war izemmar x temwarrit i Abnir, maɣar netta tuɣa iggʷed zzayes.   
\m
\v 12 \add Xenni\add* issekk Abnir ireqqasen di ṭṭweɛ n yixef nnes ɣar Dawud, inna: “Wi \add yiřan\add* tammurt?” Inna \add ɛawed\add*: “Egg akidi řɛahd nnec, xzar, ad ac wceɣ afus ḥima marra Israil ad ɣarek dd-inneqřeb.”  
\v 13 U netta inna: “Mliḥ, necc ad ggeɣ ijj n řɛahd akidek, maca mɣir ict n tmesřact ad ac tt ttareɣ. Ad ac iniɣ: ‘Cek war tẓarred udem inu, mɣir mařa cek ad tawyed \add da\add* d amezwaru Mixal, yeǧis n Cawul, xmi dd ɣa tased ḥima ad tẓared udem inu.’”   
\m
\v 14 Xenni issekk Dawud ireqqasen ɣar Ic-Bucat, mmis n Cawul, inna: “Ewc ayi-dd tamɣart inu Mixal, tenni i dd-iwyeɣ s mya n řeɛdařeyyat n Ifilisṭiniyyen s wexḍab n tesřit!” \x ◘ \xo 3:14 \xt 1 Ṣm. 18:25, 27\x*  
\v 15 Ic-Bucat issekk \add ireqqasen\add* uca ikkes i-tt x weryaz nnes, x Falṭiyil, mmis n Layic. \x ◘ \xo 3:15 \xt 1 Ṣm. 25:44\x*  
\v 16 Aryaz nnes yuyur akides ař Baxurim, yuyur ittru awarni as. \add Xenni\add* inna as Abnir: “Uyur, ɛqeb!” Uca iɛqeb netta.   
\m
\v 17 Tuɣa issiweř Abnir x imɣaren n Israil, inna: “Aṭṭas zeg wami kenniw texsem Dawud \add ad yiři\add* d ajeǧid xawem.  
\v 18 Řexxu ggem t, maɣar SIDI issiweř ak-d Dawud, inna: ‘S ufus n Dawud, amsexxar inu, ad fekkeɣ řgens inu Israil zeg ufus n Ifilisṭiniyyen u zeg ufus n marra řɛedyan nsen.’”  
\v 19 Issiweř Abnir uřa deg imezzuɣen n \add ayt n\add* Binyamin. \add Xenni\add* yuyur Abnir ɣar Ḥabrun, ḥima ad issiweř deg imezzuɣen n Dawud x marra min iǧan d lemliḥ di tiṭṭawin n Israil u di tiṭṭawin n taddart n Binyamin.   
\m
\v 20 Uca yusa-dd Abnir ɣar Dawud di Ḥabrun. Tuɣa ɛicrin n yeryazen akides. Dawud igga ict n zzardet i Abnir d yeryazen i kides \add iǧan\add*.  
\v 21 \add Xenni\add* inna Abnir i Dawud: “Necc ad kkareɣ ad ṭṭfeɣ abrid maḥend ad yarweɣ marra Israil ɣar sidi inu, ajeǧid, ḥima nitni ad ggen akidek ijj n řɛahd u cek ad tiřid d ajeǧid x marra min immeẓri řeɛmar nnec.” S uya ijja Dawud Abnir ad yuyur di řehna.   
\b  
\m  
\s1 Abnir ittwaneɣ zi Yu’ab  
\m
\v 22 Uca xzar, imsexxaren n Dawud d Yuwab ɛeqben-dd zeg ijj n usafar n ukecceḍ. Nitni iwyen akidsen ict n tkeccaḍt d tameqqrant. Abnir tuɣa war iǧi ɛad ɣar Dawud di Ḥabrun, maɣar \add Dawud\add* tuɣa ijja i-t ad yuyur di řehna.  
\v 23 \add Řami\add* dd-yiweḍ Yuwab d marra řɛeskar nni ɣares, ɛawden i Yuwab, nnan: “Abnir, mmis n Nir, yusa-dd ɣar ujeǧid u netta ijja i-t ad yuyur uca \add xenni\add* yuyur \add Abnir\add* di řehna.”  
\v 24 \add Xenni\add* yuyur Yuwab ɣar ujeǧid, inna as: “Min teggid? Aqa Abnir yusa-dd ɣarek. Mayemmi i t tessekked uca \add xenni\add* yuyur netta amenni waha?  
\v 25 Cek tessned Abnir, mmis n Nir. Netta yusa-dd waha ḥima ad cek icmet u ḥima ad issen x wuffuɣ nnec \add ɣar umenɣi\add* u x weɛqab nnec u x marra min texsed ad tegged.”  
\v 26 Yuwab iffeɣ zi ɣar Dawud uca issekk ireqqasen awarni i Abnir inni t-i-dd-yarrin ad idweř zeg wanu n Sira. \add Maca\add* Dawud war issin walu x man aya.  
\v 27 \add Umi\add* dd-iɛqeb Abnir ɣar Ḥabrun, indeh i-t Yuwab ɣar uɣezdis di řwesṭ n tewwart \add n tendint\add* maḥend ad kides issiweř s řhudnet uca \add xenni\add* ijju t din deg uɛeddis, ařami immut, di ssibbet \add n wexřaf\add* n idammen n umas Ɛasa’il. \f ◼ \fr 3:27 \ft \+fk maḥend akides issiweř\ft  - ixs ad yini aqa Yu’ab igga axmi ixs akides issiweř břa axewwej, maca s tidett netta ixs ad t ineɣ.\f*  \x ◘ \xo 3:27 \xt  2 Ṣm. 2:23; 1 Ij. 2:5\x*  
\v 28 \add Umi\add* isřa Dawud manawenni awarni as, inna: “Necc d tgeldit inu d afurri zzat i SIDI i řebda x idammen n Abnir, mmis n Nir.  
\v 29 Ejj i-ten ad iřin x uzeǧif n Yuwab u x marra taddart n babas. Ejj taddart n Yuwab war d as ineqqeṣ ɛemmarṣ ca n ijj ad dayes yiři useyyeř, niɣ wenni di iǧa řbarṣ, niɣ wenni iṭṭfen deg umekkuk n uxeyyaḍ, niɣ wenni iwḍan s ssif, niɣ wenni ittxeṣṣan aɣrum!”   
\m
\v 30 Yuwab d umas Abicay nɣin Abnir, minzi netta tuɣa inɣa umatsen Ɛasa’il deg umenɣi ɣar Jibɛun.  
\v 31 \add Maca\add* Dawud inna i Yuwab u i marra řgens nni tuɣa ɣares iǧan: “Carrgem arruḍ nwem, yarḍem arruḍ n wecḍan uca \add uyurem\add* zzat i \add řmeḥmeř n\add* Abnir \add am\add* teccatem agejdur!” Ajeǧid Dawud \add simant nnes\add* yuyur ɣar ḍeffar n řmeḥmeř.  
\v 32 \add Řami\add* neḍřen Abnir di Ḥabrun, issgeɛɛed ujeǧid tmijja nnes, iru ɣar wenḍeř n Abnir uřa d řgens iru marra.  
\v 33 Ajeǧid issgeɛɛed ict n ucetci n imettan i Abnir, inna: “Ma immut Abnir am immut ijj n ubuhaři?  
\v 34 Ifassen nnec tuɣa war carfen u iḍaren nnec tuɣa war qeyyden s ssnaseř n nnḥas, maca cek tewḍid am mammec iwḍa \add bnadem\add* sadu ufus n ayt n řmuɛṣiyyet.” \add Řexdenni\add* yarni řgens marra ɛad deg imeṭṭawen.   
\m
\v 35 Marra řgens yusa-dd ɣar Dawud ḥima ad xas ziyyaren ad icc aɣrum am tuɣa ɛad d aziř. \add Maca\add* Dawud ijjuǧ, inna: “Ejj AREBBI ad ayi igg ta d ta uca ad dayes yarni ɛad, mařa necc cciɣ ca n weɣrum niɣ ca nneɣni qbeř ma ad teɣři tfuct!”  
\v 36 man aya idweř ittwassen ɣar marra řgens uca tuɣa d man aya d lemliḥ di tiṭṭawin nsen, am mammec tuɣa marra min igga ujeǧid d lemliḥ di tiṭṭawin n marra řgens.  
\v 37 Marra řgens d marra Israil ssnen deg wass nni, aqa war dd-yekki zeg ujeǧid maḥend ad nɣen Abnir, mmis n Nir.  
\v 38 Inna ujeǧid i imsexxaren nnes: “Ma war tessinem kenniw, aqa ass-a iwḍa ijj n řḥakem, \add wah,\add* ijj n weryaz d ameqqran di Israil?  
\v 39 Ass-a ḍeɛfeɣ, \add waxxa\add* necc ttwadehneɣ d ajeǧid. Iryazen-a, arraw n Ṣaruya, qesḥen xafi. SIDI ad ixeǧeṣ aɛeffan tuɛeffna nnes nni igga.”   
\b  
\b  
\m  
\c 4
\s1 Aneqqi n Ic-Bucat  
\m
\v 1 \add Umi\add* isřa mmis n Cawul, aqa Abnir immut di Ḥabrun, dewřen ifassen nnes ḍeɛfen u marra Israil innexřeɛ.  
\v 2 Mmis n Cawul tuɣa ɣares tnayen n yeryazen \add jar imsexxaren nnes\add*, inni \add iǧan d\add* řqebṭanat n bandiyyat. Ijjen qqaren as Baɛna u wenneɣni Rakab, tuɣa aten d iḥenjiren n Rimmun, Abi’ruti, zeg ayt n Binyamin, maɣar uřa d Biɛrut ittwaḥseb-dd ɣar Binyamin. \x ◘ \xo 4:2 \xt Yac. 9:17, 18:25 \x*  
\v 3 Ibiɛrutiyyen arewřen ɣar Jattayim uca qqimen zeddɣen dinni ař ass-a am ibarraniyyen.   
\b  
\m
\v 4 Yunatan, mmis n Cawul, tuɣa ɣares ijj n mmis nni tuɣa iqarrmen zi tnayen n iḍaren. Netta tuɣa ɣares xemsa n iseggʷusa umi dd-yusa řexbar x Cawul d Yunatan zi Yazraɛil. Tenni t isseymen tuɣa tᵉṭṭef i-t uca tarweř. Aqa deg uqeǧeq n tarewřa, imsar, netta iwḍa, idweř iqarrem. Qqaren as Mafibucat. \x ◘ \xo 4:4 \xt 2 Ṣm. 9:3-13\x*   
\b  
\m
\v 5 Rakab d Baɛna, iḥenjiren n Rimmun, Abiɛruti, ṭṭfen abrid uca usin-dd di ṭṭḥa n uziř ɣar taddart n Ic-Bucat. Netta tuɣa izzeř di qama di tmeddit. \f ◼ \fr 4:5 \ft \+fk Abiɛruti\ft  - ijj n weryaz zi tendint n Birut di temmurt n ayt n Binyamin.\f*  
\v 6 Xzar, nitni udfen ɣar daxeř di taddart axmi tuɣa nwan ad ksin irden, uca ssnuqqben t deg uɛeddis. Rakab d umas Baɛna xtuttřen.  
\v 7 Nitni udfen ɣar taddart umi t tuɣa izzeř di qama nnes deg wexxam n yiḍeṣ nnes, uca ssnuqben t, nɣin t uca qessen as azeǧif. \add Xenni\add* ksin azeǧif nnes \add akidsen\add* uca uyuren ǧiřet tmun, kkin abrid n Řewḍa.  
\v 8 Nitni iwyen azeǧif n Ic-Bucat ɣar Dawud ɣar Ḥabrun, nnan i ujeǧid: “Xzar, azeǧif n Ic-Bucat, mmis n Cawul, řeɛdu nnec, wenni tuɣa yarezzun buḥbeř nnec. Aqa ass-a SIDI ixřef i sidi inu ajeǧid zi Cawul d zzariɛet nnes.” \f ◼ \fr 4:8 \ft \+fk buḥbeř nnec\ft  - s Tɛibranit ‘tudart nnec’.\f*  
\v 9 \add Maca\add* Dawud yarra-dd x Rakab d umas Baɛna, iḥenjiren n Rimmun, Abiɛruti, inna asen: “\add S tidett am\add* iddar SIDI, wenni ifekken řeɛmar inu zi marra řeḥṣaret!  
\v 10 Aqa wenni d ayi dd-yiwyen řexbar uca inna: ‘Xẓar, Cawul immut!’, tuɣa ittɣiř as di tiṭṭawin nnes aqa netta am yijjen i dd-yiwyen řexbar aṣebḥan, \add maca\add* necc ṭṭfeɣ t uca nɣiɣ t di Ṣiqlaɣ, waxxa netta \add tuɣa iraja\add* ad as wceɣ řmunet i řexbar aṣebḥan. \x ◘ \xo 4:10 \xt 2 Ṣm. 1:15\x*  
\v 11 Mecḥař ɛad \add řexxu\add* iryazen iɛeffanen inni inɣin ijj n weryaz d amsegged di taddart nnes x qama nnes! Xenni řexxu, ma necc war xeǧfeɣ xenni zzaywem idammen nnes u ad kenniw mḥiɣ zi temmurt?”  
\v 12 \add Xenni\add* yumur Dawud imsexxaren \add nnes\add* u nitni nɣin ten. Qessen asen ifassen d iḍaren uca uyřen ten ɣar uyeřmam n Ḥabrun. Azeǧif n Ic-Bucat, \add maca\add* ksin t nitni, neḍřen t deg wenḍeř n Abnir di Ḥabrun. \x ◘ \xo 4:12 \xt 2 Ṣm. 3:32\x*   
\b  
\b  
\m  
\c 5
\s1 Dawud ittwadhen am ujeǧid di Hibrun  
\m
\v 1 Marra tiqebbař n Israil usint-i-dd ɣar Dawud ɣar Ḥabrun, ssiwřent, nnant: “Xzar, neccin d iɣussan d weysum nnec. \x ◘ \xo 5:1 \xt [1 Im. 11:1-9; 14:1-17]\x*  
\v 2 Iḍennaḍ uřa d fariḍennaḍ umi tuɣa Cawul d ajeǧid xaneɣ, tuɣa d cek i dd-issuffɣen Israil \add ɣar umenɣi\add* u tejjid i-t-i-dd ad idweř. Ɛawed inna ac SIDI: ‘Cek ad tarewsed řgens inu Israil u cek ad tiřid d řḥakem x Israil.’” \x ◘ \xo 5:2 \xt 2 Ṣm. 7:7; Izhd. 78:71\x*  
\v 3 \add Xenni\add* usin-dd marra imɣaren n Israil ɣar ujeǧid di Ḥabrun u ajeǧid Dawud igga ijj n řɛahd akidsen di Ḥabrun zzat i wudem n SIDI. Nitni dehnen Dawud d ajeǧid x Israil.   
\m
\v 4 Tuɣa ɣar Dawud třatin n iseggʷusa umi idweř netta d ajeǧid. Netta iḥkem arebɛin n iseggʷusa.  
\v 5 Di Ḥabrun iḥkem x Yahuda sebɛa n iseggʷusa d setta n iyuren u di Urcalim iḥkem třata u-třatin n iseggʷusa x marra Israil d Yahuda. \x ◘ \xo 5:5 \xt 2 Ṣm. 2:11; 1 Ij. 2:11; 1 Im. 3:4\x*   
\b  
\m  
\s1 Aṭṭefu n Urcalim  
\m
\v 6 Ajeǧid iffeɣ ak-d yeryazen nnes ɣar Urcalim, \add ḥima ad immneɣ\add* ak-d ayt n Iyabusiyyen, imezdaɣ n temmurt. Ssiwřen ak-d Dawud, nnan: “Cek war tᵉttidfed ca da, maɣar idarɣařen d iqiḍaren ad cek ḥṣaren, ad inin: ‘Dawud war da ittidef ca.’”  
\v 7 Dawud iḥewwes lburj n Ṣihyun, d wenni d tandint n Dawud.  
\v 8 Deg wass nni inna Dawud: “Kur ijj i ɣa iwten ijj n Uyabusi, ejj-i-t ad t immenḍar deg waman \add issizzřen aṭṭas\add*. Iqidaren d idarɣařen icarreh i-ten řeɛmar n Dawud.” X uya qqaren: “Ijj n udarɣař d ijj n uqidar war dd-ttidfen ɣar taddart.” \x ◘ \xo 5:8 \xt 1 Im. 11:6 \x*   
\m
\v 9 Dawud iqqim izdeɣ di lqelɛa uca igga as: ‘Tandint n Dawud’. Ibna Dawud deg wenneḍ n lburj uřa ɣar daxeř nnes.  
\v 10 Dawud idweř yarenni di řemɣaret, maɣar SIDI, AREBBI n řɛeskarat, \add tuɣa-t\add* akides.   
\m
\v 11 Ḥiram, ajeǧid n Ṣur, issekk ireqqasen ɣar Dawud ak-d akeccuḍ n \add tcejjart n\add* tengelt d ineqqacen n ukeccuḍ d ineqqacen n weẓru n řḥiḍ. Nitni ssbedden ict n taddart i Dawud. \f ◼ \fr 5:11 \ft \+fk tacejjart\ft  - niɣ ‘addag’ (‘iddagen’).\f*  
\v 12 Dawud issen, aqa SIDI tuɣa igga i-t d ajeǧid x Israil u tuɣa issgeɛɛed tageldit nnes di ṭṭweɛ n řgens nnes Israil.   
\b  
\m
\v 13 Awarni twasit nnes zi Ḥabrun tuɣa Dawud yarenni tiyya d temɣarin i yixef nnes zi Urcalim u \bd ttwarwen as-dd i Dawud \+bdit ɛad\+bdit* iḥenjiren d tḥenjirin.\bd* \x ◘ \xo 5:13 \xt 1 Im. 3:9; 14:3-7\x*  
\v 14 Ina d ismawen n iḥenjiren i d as dd-ittwarwen di Urcalim: Cammuɛ, Cubab, Natan, Suliman,  
\v 15 Yibḥar, Ilicuɛ, Nafaj, Yafiɛ,  
\v 16 Alicamaɛ, Alyadaɛ d Ilifalaṭ.   
\b  
\m  
\s1 Aɣelleb x Ifilisṭiniyyen  
\m
\v 17 \add Umi\add* sřin Ifilisṭiniyyen, aqa dehnen Dawud d ajeǧid x Israil, geɛɛden marra Ifilisṭiniyyen ḥima ad arzun x Dawud. Dawud isřa \add x man aya\add* u netta ihwa ɣar lqelɛa.  
\v 18 Ifilisṭiniyyen usin-dd uca bezzɛen ixef nsen di teɣzurt n Irafawiyyen.  
\v 19 \add Xenni\add* isseqsa Dawud SIDI, inna: “Ma ad geɛɛdeɣ ḍidd i Ifilisṭiniyyen? Ma ad ten tegged deg ufus inu?” SIDI inna i Dawud: “Geɛɛed, maɣar Necc nican ad ggeɣ Ifilisṭiniyyen deg ufus nnec!”  
\v 20 U yiweḍ Dawud ɣar Baɛl-Faraṣim. Dinni iwta Dawud Ifilisṭiniyyen, inna: “SIDI icuq zzat i wudem inu di řɛedyan inu am yict n tareẓẓit n waman.” X uya igga as i wemcan nni Baɛl-Faraṣim. \x ◘ \xo 5:20 \xt Ica. 28:21\x*  
\v 21 Ifilisṭiniyyen jjin dinni řexyařat n l’aṣnam nsen u Dawud d yeryazen nnes ksin ten akidsen.   
\m
\v 22 Geɛɛden Ifilisṭiniyyen ict n twařa nneɣnit u bezzɛen ixef nsen di teɣzurt n Irafawiyyen.  
\v 23 Dawud isseqsa SIDI u Netta inna: “War ttgeɛɛid ca ḍidd nsen, maca ekk asen-dd ɣar ḍeffar, ad ɣarsen dd-tased zi jjihet n tcejjura n umetti.  
\v 24 Xmi ɣa tesřed i tecři n iṣuraf di tqiccat n tcejjura n umetti, \add xenni\add* ffeɣ, thejmed, maɣar SIDI ad ac izwar zzat i wudem nnec, ḥima ad iwwet řɛeskar n Ifilisṭiniyyen.”  
\v 25 Dawud igga am mammec d as yumur SIDI u netta iwta Ifilisṭiniyyen zi Jibɛa ař mani ɣa tawḍed ɣar Jazar.   
\b  
\b  
\m  
\c 6
\s1 Asmuṭṭi n Ttabut ɣar tendint n Dawud  
\m
\v 1 Dawud issmun twařa nneɣnit marra \add iɛeskariyyen\add* ittwafarzen di Israil, třatin-ařef \add n yeryazen\add*. \x ◘ \xo 6:1 \xt [1 Im. 13:1-14; 15:25-29; 16:1-3]\x*  
\v 2 Uca ikkar Dawud, iffeɣ ak-d marra řgens i ɣares \add iǧan\add* zi Baɛli-Yahuda ḥima ad ssenni issgeɛɛed Ttabut n SIDI, \add Ttabut\add* i x ittwabarreḥ s Yisem, s Isem n SIDI n řɛeskarat, wenni ittɣiman \add x\add* ikiruben. \f ◼ \fr 6:2 \ft \+fk ikiruben\ft  - ict n marka n lmalakat.\f*  
\v 3 Nitni nedhen Ttabut n SIDI x ijj n ukarru n jdid. Nitni iwyen tt-i-dd zi taddart n Abinadab tenni ibedden x ict n teɛrurt. Ɛuzza d Axiyu, iḥenjiren n Abinadab, nedhen akarru n jdid. \x ◘ \xo 6:3 \xt 1 Ṣm. 6:7, 8; 7:1\x*  
\v 4 Nitni iwyen t-i-dd zi taddart n Abinadab i tuɣa ibedden x ict n teɛrurt, uca \add uyuren\add* ak-d Ttabut n SIDI. Axiyu yuyur ɣar zzat i Ttabut.  
\v 5 Dawud d marra taddart n Israil uraren zzat i wudem n SIDI s ɛřam kuř dduzan n ǧɣa zeg ukeccuḍ n \add tcejjart n\add* umerzi, s řgambriyat d lharpat d ibendiren d nnaqusat d teǧunin n wuzzař. \f ◼ \fr 6:5 \ft \+fk amerzi\ft  - niɣ ‘ameḍzi’. \fk taǧunin n wuzzař\ft  - niɣ ‘asimbal’ d ‘isimbalen’.\f*   
\m
\v 6 \add Umi\add* iwḍen ɣar unedrar n Naxun, isswiẓẓeḍ Ɛuzza \add afus nnes\add* ɣar Ttabut n AREBBI uca iṭṭef i-tt, minzi nderfen ifunasen.  
\v 7 \add Xenni\add* yarɣa weɣḍab n SIDI x Ɛuzza uca iwta i-t AREBBI din x uxeṭṭu-ya. Netta immut din ɣar Ttabut n SIDI.  
\v 8 Yiweḍ ssem ɣar wuř n Dawud, aqa SIDI tuɣa isɛar ammu x Ɛuzza, uca iřaɣa as i wemcan nni Fariṣ-Ɛuzza ař ass-a.  
\v 9 Deg wass nni teřqef Dawud tiggʷudi zi SIDI, inna: “Mammec i ɣa yegg ad ɣari dd-tas Ttabut n SIDI?”  
\v 10 \add S uyenni\add* Dawud war ixs ad yejj ad ɣares dd-awyen Ttabut n SIDI di tendint n Dawud. Dawud ijja i-tt ad taggʷej ɣar taddart n Ɛubid-Idum, Ajitti. \f ◼ \fr 6:10 \ft \+fk Ajitti\ft  - ijj n weryaz zi tendint n Jat.\f*   
\m
\v 11 Tekka Ttabut n SIDI třata n iyuren di taddart n Ɛubid-Idum, Ajitti, uca SIDI ibarek Ɛubid-Idum d marra taddart nnes.  
\v 12 \add Xenni\add* xebbaren i ujeǧid Dawud, nnan: “SIDI aqa ibarek taddart n Ɛubid-Idum d marra min iǧan nnes, di ṭṭweɛ n Ttabut n AREBBI.” \add Xenni\add* yuyur Dawud \add din\add*, issgeɛɛed Ttabut n AREBBI s řefraḥet zi taddart n Ɛubid-Idum ɣar tendint n Dawud.  
\v 13 Řami uyuren inni yarebbun Ttabut n SIDI setta n iṣuraf, imsar, aqa iqeddem \add Dawud\add* ijj n ufunas d \add ijj n uɛejmi imesřen\add* \add d tɣarṣt\add*.  
\v 14 Dawud icḍeḥ s marra tizemmar \add nnes\add* zzat i wudem n SIDI. Tuɣa Dawud yarḍ ijj n upalṭu \add n ukehhan\add* n řeqṭen.   
\m
\v 15 Dawud d marra taddart n Israil iwyen Ttabut n SIDI s usřiwřew u s řḥess n usuḍi deg uyicc n icarri ɣar sennej.  
\v 16 Řami dd-tiweḍ Ttabut n SIDI ɣar tendint n Dawud, imsar, aqa Mixal, yeǧis n Cawul, texzar-dd zi řkazi. \add Umi\add* teẓra nettat mammec ineggez d iceṭṭeḥ ujeǧid Dawud zzat i wudem n SIDI, tesseḥqar i-t deg wuř nnes.   
\m
\v 17 Arbun Ttabut n SIDI ɣar daxeř uca ssarsen tt deg wemcan nnes di řwesṭ n uqiḍun nni tuɣa i d as icedd Dawud uca Dawud issgeɛɛed tiɣarṣa n wecmaḍ zzat i wudem n SIDI, uřa d tiɣarṣa n řehna.  
\v 18 \add Umi\add* ikemmeř Dawud zeg usgeɛɛed n tɣarṣa n wecmaḍ d tɣarṣa n řehna, ibarek řgens deg Yisem n SIDI n řɛeskarat.  
\v 19 Netta ibḍa x marra řgens, x marra řɣaci n Israil, x yeryazen d temɣarin, i kuř ijj iwca as ict n txebbazt n weɣrum, ijj n uřeqquz \add n weysum\add* n ufunas d ijj n weɣrum n zzbib. \add Xenni\add* yuyur řgens marra, \add kuř\add* aryaz ɣar taddart nnes.   
\m
\v 20 Yareggʷeḥ Dawud, ḥima ad ibarek taddart nnes. Teffeɣ-dd ɣares Mixal, yeǧis n Cawul, tenna as: “Mammec igga ujeǧid n Israil ass-a ccan d ameqqran i ixef nnes, umi iɛarra netta ixef nnes zzat i tiṭṭawin n tiyya n imsexxaren nnes am mammec iɛarra ca n yijjen zeg inni war isekkwin?”  
\v 21 Dawud yarra-dd x Mixal: “\add Necc ggiɣ t\add* zzat i wudem n SIDI wenni d ayi ifarzen x babam d marra taddart nnes, ḥima ad ayi igg d řḥakem x řgens n SIDI, x Israil, aqa zzat i wudem n SIDI i ceṭṭḥeɣ s řefraḥet.  
\v 22 D ameẓyan ɛad i ɣa dewřeɣ. Necc ad iřiɣ d amuqřiř di tiṭṭawin inu. Ɣar tiyya i x tessiwřed cem, ɣarsent i ɣa ṭṭfeɣ ccan.”  
\v 23 Mixal, yeǧis n Cawul, teqqim břa aḥenjir ař ass n řmewt nnes.   
\b  
\b  
\m  
\c 7
\s1 Řwaɛd zi jjihet n Zzawect Tameqqrant i ɣa tᵉttwabna zi Suliman  
\m
\v 1 Umi iqqim ujeǧid di taddart nnes u SIDI tuɣa igga as řehna zi marra řɛedyan nnes i d as dd-innḍen, imsar, \x ◘ \xo 7:1 \xt [1 Im. 17:1-6]\x*  
\v 2 aqa inna ujeǧid i unabi Natan: “Xzar, necc zeddɣeɣ deg ict n taddart n ukeccuḍ n \add tcejjart n\add* tengelt, \add maca\add* Ttabut n AREBBI třeḥḥef sadu tajartiřt \add n uqiḍun\add*.”  
\v 3 Natan inna i ujeǧid: “Uyur waha, egg marra min ɣarek deg wuř nnec, maɣar SIDI akidek.”   
\m
\v 4 Di ǧiřet nni imsar aqa iffeɣ wawař n SIDI ɣar Natan, inna:  
\v 5 “Uyur, ini i umsexxar inu, i Dawud: ‘Ammu i iqqar SIDI: Ma texsed ad ayi tebnid ict n taddart, maḥend ad dayes zedɣeɣ?  
\v 6 Ɛemmarṣ war zdiɣeɣ deg ict n taddart zeg wass umi dd-ssgeɛɛdeɣ ayt n Israil zi Miṣra ař ass-a, \add maca\add* durryeɣ deg ijj n Uqiḍun, deg ict n Tzeddiɣt.  
\v 7 Mani ma uyureɣ ak-d ayt n Israil, ma Necc ssiwřeɣ ɛemmarṣ uřa s yijj n wawař i yict zi tqebbař n Israil tinni i umureɣ ad arwesen řgens inu Israil, u nniɣ: Mayemmi war d ayi tebnim ict n Taddart n ukeccuḍ n \add tcejjart n\add* tengelt?  
\v 8 Xenni řexxu, ammu i ittxeṣṣa ad tinid i umsexxar inu, i Dawud: Ammu i iqqar SIDI n řɛeskarat: Necc iwyeɣ-dd cek zi řkuri, zi ḍeffar n wuǧi, maḥend ad tiřid d řḥakem x řgens inu, x Israil. \x ◘ \xo 7:8 \xt 1 Ij. 8:16; 2 Im. 6:5\x*  
\v 9 Mani ma tuyured, ǧiɣ Necc akidek u qḍiɣ x marra řɛedyan nnec zzat i wudem nnec. Necc ggiɣ ac ijj n isem d ameqqran am yismawen n imeqqranen nni \add iǧan\add* x temmurt. \x ◘ \xo 7:9 \xt 2 Ṣm. 8:6, 14\x*  
\v 10 Necc neyyceɣ ijj n wemcan i řgens inu, i Israil, uca ẓẓuɣ t \add din\add*, maḥend ad izdeɣ deg wemcan \add nnes\add*, war ittwanhezzi ɛad u war t ḥeṣṣaren ɛad ayt n řmuɛṣiyyet am deg umezwaru,  
\v 11 zeg wass nni ggiɣ Necc řquḍat x řgens inu Israil. Necc wciɣ ac řehna zi marra řɛedyan nnec uca \add řexxu\add* ad ac isscen SIDI, aqa SIDI ad ac igg ict n taddart.  
\v 12 Řami ttwakemmřen wussan nnec uca ad tegged ad tareyyḥed jar řejdud nnec, ad dd-ssekkareɣ zzariɛet nnec i dd-itteffɣen zi daxeř nnec u Necc ad ssmetneɣ tagelda nnes. \x ◘ \xo 7:12 \xt 1 Ij. 8:20\x*  
\v 13 Netta ad ibna ict n taddart i Yisem inu u Necc ad ssmetneɣ řɛarc n tagelda nnes i řebda. \x ◘ \xo 7:13 \xt 1 Ij. 5:19; 6:12; 1 Im. 22:10\x*  
\v 14 Necc ad iřiɣ d Babas i netta u netta ad yiři i Necc d mmi. Mařa netta iffaryeḍ, ad t arebbiɣ s weɛmud d teyyita n tarwa n bnadem. \x ◘ \xo 7:14 \xt Izhd. 89:27, 31; Ɛbr. 1:5\x*  
\v 15 Tamexsiwt inu icewwaren war zzayes tᵉttxennes am mammec ttessxenseɣ tt x Cawul i x tt kkseɣ zzat i tiṭṭawin nnec.  
\v 16 Taddart nnec d tgelda nnec ad ttwassmetnent zzat i wudem nnec i řebda, řɛarc nnec ad iqqim ibedd i řebda.’” \f ◼ \fr 7:16 \ft \+fk řɛarc\ft  - niɣ ‘řkursi igellden’.\f*  
\v 17 Natan issiweř ɣar Dawud \add nican\add* ɛlaḥsab awařen-a u ɛlaḥsab marra řewḥiy-a.   
\b  
\m
\v 18 \add Xenni\add* yudef ujeǧid Dawud uca iqqim zzat i wudem n SIDI, inna: “Min ɛniɣ necc, Sidi inu, SIDI, u min teɛna taddart inu aqa Cek tnedhed ayi-dd ař danita?  
\v 19 Di tiṭṭawin nnec d man aya \add marra\add* ɛad drus, \add a\add* Sidi inu SIDI, \add maca řexxu\add* tessiwřed ɛad x taddart n umsexxar nnec \add deg wussan\add* iggʷejen \add i dd ittasen\add*. D man aya d taɣuri \add d tidett\add* i bnadem, \add a\add* Sidi inu, SIDI!   
\m
\v 20 Min d ac i ɣa yini Dawud ɛad ktar? Cek tessned amsexxar nnec, \add a\add* Sidi inu, SIDI!  
\v 21 Di ṭṭweɛ n wawař nnec u ɛlaḥsab uř nnec aqa teggid marra \add planu\add* imɣaren wanita, ḥima ad tessargbed amsexxar nnec.  
\v 22 X uya Cek d ameqqran, \add a\add* Sidi inu SIDI, maɣar war \add din\add* iǧi uřa d ijj am Cek u war \add din\add* iǧi uřa d ijj n AREBBI mɣir Cek ɛlaḥsab marra min nesřa s imezzuɣen nneɣ. \x ◘ \xo 7:22 \xt Aɛwd. 3:24; 4:35; 32:39; 1 Ṣm. 2:2; Izhd. 86:8; Ica. 45:5, 18, 22; Mk. 12:29, 32\x*  
\v 23 Man wen \add i iǧan\add* am řgens nnec, am Israil, ayenni n řgens x temmurt i ɣar iraḥ AREBBI ḥima ad t ifdi i Yixef nnes d řgens, u ḥima ad igg i Yixef nnes ijj n Yisem, u ḥima ad awem igg \add ict n řxedmet d\add* tameqqrant uřa d tmegga d timeqqranin i temmurt nnec zzat i wudem n řgens nnec nni tefdid i Yixef nnec zi Miṣra, \add zi\add* řegnus u \add zeg\add* irebbiten nsen. \f ◼ \fr 7:23 \ft \+fk ifdi\ft  - xzar Izhd. 78:35.\f*  \x ◘ \xo 7:23 \xt Aɛwd. 4:7; 34; 10:21; 33:29; Izhd. 147:20\x*  
\v 24 Cek teggid řgens nnec Israil d ijj n řgens i Yixef nnec i řebda. Cek, \add a\add* SIDI, aqa Cek tdewřed d AREBBI i nitni.   
\m
\v 25 Xenni řexxu, SIDI AREBBI, ejj awař nni tessiwřed x umsexxar nnec u x taddart nnes ad ibedd i řebda u egg am mammec tessiwřed.  
\v 26 Ejj Isem nnec ad ittwassemɣar i řebda, ad inin: ‘SIDI n řɛeskarat ijehden aqa-t d AREBBI x Israil!’, uca iři ad tᵉttwassemten taddart n umsexxar nnec Dawud zzat i wudem nnec.  
\v 27 Maɣar Cek, \add a\add* SIDI n řɛeskarat, AREBBI n Israil, aqa tessargbed deg imezzuɣen n umsexxar nnec, tennid: ‘Necc ad ac ssbeddeɣ ict n taddart!’ X uya tusa-dd deg wuř n umsexxar nnec maḥend ad iẓẓaǧ taẓaǧit-a ɣarek.  
\v 28 \add Xenni\add* řexxu, \add a\add* Sidi inu, SIDI, Cek d AREBBi nni uca awařen nnec d tidett u Cek tessiwřed s \add marra\add* tcuni-ya ɣar umsexxar nnec. \x ◘ \xo 7:28 \xt Yḥ. 17:17\x*  
\v 29 \add Xenni\add* řexxu, mařa tusa ac-dd x řxaḍar, barek taddart n umsexxar nnec, ḥima ad tiři zzat i wudem nnec i řebda, minzi Cek, \add a\add* Sidi inu, SIDI, tessiwřed \add aya\add* u s lbaraka nnec ad tᵉttwabarek taddart n umsexxar nnec i řebda.’”   
\b  
\b  
\m  
\c 8
\s1 Iɣellaben n Dawud  
\m
\v 1 Awarni aya imsar aqa Dawud iɣřeb x Ifilisṭiniyyen uca yarra i-ten sadu afus nnes u Dawud ikkes řeḥkamet zeg ufus n Ifilisṭiniyyen. \x ◘ \xo 8:1 \xt [1 Im. 18:1-14]\x*  
\v 2 \add Ɛawed\add* iɣřeb netta x Mu’ab uca iɛbar i-ten s yijj n ufiřu \add n řeɛbar\add* am zzřen di temmurt. Netta iɛbar tnayen n ifiřan \add n řeɛbar\add*, ḥima ad ten ineɣ, uřa d ijj n ufiřu imun, ḥima ad ten yejj ddaren. \add Ammu\add* i dewřen ayt n Mu’ab d imsexxaren i Dawud nni ittxeṣṣan ad \add as\add* wcen ljizya.   
\m
\v 3 Dawud iɣřeb ɛawed x Hadad-Ɛazar, mmis n Raḥub, ajeǧid n Ṣuba, umi tuɣa dd-iffeɣ wanita ḥima ad ɣares dd-yarr řeḥkamet nnes ɣar yeɣzar \add n Lfuraṭ\add*. \f ◼ \fr 8:3 \ft \+fk řeḥkamet\ft  - s Tɛibranit ‘afus nnes’.\f*  
\v 4 Dawud ikkes zzayes ařef u sebɛa-mya n imnayen d ɛicrin-ařef n yeryazen x iḍaren, uca iqess Dawud iẓewran n iḍaren n marra \add iysan n\add* ikarruten, \add maca\add* ijja zzayes mya n \add iysan n\add* ikarruten. \x ◘ \xo 8:4 \xt 1 Im. 18:4\x*  
\v 5 Yusa-dd Aram zi Dimacq, ḥima ad iwc afus i Hadad-Ɛazar, ajeǧid n Ṣuba, u Dawud iɣřeb x tnayen u-ɛicrin-ařaf n yeryazen n Aram.  
\v 6 Dawud igga řɛeskarat \add n uḥewwes\add* jar Iramiyyen n Dimacq u Iramiyyen dewřen d imsexxaren n Dawud inni ittxeṣṣan ad \add as\add* wcen tarzifin. SIDI igga ttasiɛ i Dawud mani ma iruḥ.  
\v 7 Dawud iksi tiseddariyin iqesḥen n uɛeskari nni ttwaggent s wureɣ, tinni tuɣa \add iǧan\add* n imsexxaren n Hadad-Ɛazar u yiwyi tent ɣar Urcalim.  
\v 8 Iksi Dawud aṭṭas n nnḥas zi Bataḥ u zi Biratay, tineddam n Hadad-Ɛazar.   
\m
\v 9 \add Umi\add* Tuɛi, ajeǧid n Ḥamat, isřa aqa Dawud iɣřeb x marra řɛeskar n Hadad-Ɛazar,  
\v 10 issekk Tuɛi mmis Yuram ɣar ujeǧid Dawud, ḥima ad isseqsa x umeddur nnes u ḥima ad as ibarek, minzi netta immneɣ akides u iɣřeb xas, maɣar Hadad-Ɛazar tuɣa yarezzu ad immneɣ ak-d Tuɛi řebda. \add Netta yiwi akides\add* deg ufus nnes řeqcuɛ n nnuqart d řeqcuɛ n wureɣ d řeqcuɛ n nnḥas, \f ◼ \fr 8:10 \ft \+fk Hadad-Ɛazar tuɣa yarezzu ad immneɣ ak-d Tuɛi řebda\ft  - awařen-a xsen ad inin aqa Hadad-Ɛazar iffeɣ aṭṭas n twařawin ɣar umenɣi ak-d ujeǧid Tuy.\f*  
\v 11 inni issqeddes ujeǧid Dawud ɛawed i SIDI, \add imun\add* ak-d nnuqart d wureɣ nni tuɣa issqeddes zi marra řegnus nni tuɣa yarra sadu nnes:  
\v 12 zi Aram, zi Mu’ab, zeg ayt n Ɛammun, zeg Ifilisṭiniyyen, zi Ɛamaliq uřa zi tkeccaḍt n Hadad-Ɛazar, mmis n Raxub, ajeǧid n Ṣuba.   
\m
\v 13 Igga Dawud ɛawed ijj n yisem, umi dd-iɛqeb netta zeg řeɣřeb x Aram di Teɣzurt n Tmeǧaḥt, tmenṭac-ařef \add n yeryazen\add*. \x ◘ \xo 8:13 \xt Izhd. 60:2\x*  
\v 14 Netta igga řɛeskarat \add n uḥewwes\add* di Idum. Di marra Idum igga řɛeskarat \add n uḥewwes\add* u marra Idumiyyen dewřen d imsexxaren i Dawud. SIDI igga ttasiɛ i Dawud mani ma iffeɣ netta.   
\b  
\m  
\s1 Imdebbaren imeqqranen n Dawud  
\m
\v 15 Dawud iḥkem x marra Israil u Dawud igga s řḥeqq d tsegda i marra řgens nnes. \x ◘ \xo 8:15 \xt [2 Ṣm. 20:23-26; 1 Im. 18:15-17]\x*   
\m
\v 16 Yuwab, mmis n Ṣaruya, \add tuɣa-t\add* x řɛeskar u Yahucafaṭ, mmis n Axilud, tuɣa-t d amarir n umezruy.  
\v 17 Ṣaduq, mmis n Axiṭub, d Aximalik, mmis n Abyatar, tuɣa aten d ikehhanen u Saraya tuɣa-t d amarir.  
\v 18 Banaya, mmis n Yahuyadaɛ, \add tuɣa-t x\add* iɛessasen n arrimet \add n ujeǧid\add* u \add x\add* ireqqasen n tazřa. Iḥenjiren n Dawud \add tuɣa aten d\add* ikehhanen nnes.   
\b  
\b  
\m  
\c 9
\s1 Dawud d Mafibucat  
\m
\v 1 Dawud inna: “Ma iqqim ɛad ca n yijjen zi taddart n Cawul, ḥima necc ad as ssecneɣ tamexsiwt \add inu\add* icewwaren di ṭṭweɛ n Yunatan?”  
\v 2 Tuɣa \add din\add* ijj n umsexxar \add ɣar\add* taddart n Cawul, ttřaɣan as Ṣiba. Řaɣan as-dd ɣar Dawud. Inna as ujeǧid: “Ma cek d Ṣiba?” Netta inna: “D amsexxar nnec.” \x ◘ \xo 9:2 \xt 2 Ṣm. 16:1-4; 19:17\x*  
\v 3 Ajeǧid inna: “Ma iqqim ɛad ca n ijj zi taddart n Cawul \add iddar\add*, ḥima ad as ssecneɣ tamexsiwt icewwaren n AREBBI?” \add Xenni\add* inna Ṣiba i ujeǧid: “Aqa din ɛad ijj n mmis n Yunatan wenni d aneɛḍab zi tnayen n iḍaren.” \x ◘ \xo 9:3 \xt 2 Ṣm. 4:4\x*  
\v 4 Inna as ujeǧid: “Mani iǧa netta?” Ṣiba inna as i ujeǧid: “Xzar, netta aqa-t di taddart n Maxir, mmis n Ɛammiyil, di Lu-Dabar.”   
\m
\v 5 \add Xenni\add* issekk ujeǧid Dawud din u yiwyi t-i-dd zi taddart n Maxir, mmis n Ɛammiyil di Lu-Dabar.  
\v 6 \add Umi\add* Mafibucat, mmis n Yunatan, mmis n Cawul, yudef ɣar Dawud, iwḍa s uɣembub nnes \add ɣar temmurt\add*, yuḍar \add as\add*. Dawud inna: “Mafibucat!” Netta inna: “Xzar, aqa da amsexxar nnec.”  
\v 7 Dawud inna as: “War tteggʷed, maɣar necc ad ac ssecneɣ tamexsiwt \add inu\add* icewwaren di ṭṭweɛ n babac Yunatan. Necc ad ac arreɣ marra iyyaren n jedd nnec Cawul u cek ad tecced řebda macca ɣar ṭṭabřa inu.” \f ◼ \fr 9:7 \ft \+fk jedd nnec\ft  - s Tɛibranit ‘babac’.\f*  
\v 8 \add Xenni\add* yuḍar \add as\add*, inna: “Min iɛna umsexxar nnec ařami cek texzared ɣar ijj n weqzin immuten am mammec ǧiɣ necc?”  
\v 9 \add Xenni\add* iřaɣa ujeǧid x Ṣiba, amsexxar n Cawul, inna as: “Marra min iǧan n Cawul d marra taddart nnes, wciɣ t i mmis n sidi nnec.  
\v 10 Cek ad as tcarzed tammurt, cek d iḥenjiren nnec d imsexxaren nnec, uca ad as tawyed ṣṣabet nnes, ḥima mmis n sidi nnec ad ɣares yiři weɣrum maḥend ad yecc. Mafibucat, mmis n sidi nnec, ad yecc řebda aɣrum ɣar ṭṭabřa inu.” Ṣiba tuɣa ɣares xemmesṭac n iḥenjiren d ɛicrin n imsexxaren.   
\m
\v 11 Ṣiba inna i ujeǧid: “Amsexxar nnec ad igg ɛlaḥsab marra min yumur sidi inu ajeǧid i umsexxar nnes!” \add Dawud inna ɛad\add*: “Mafibucat ad icc ɣar ṭṭabřa inu am yijjen zeg iḥenjiren n ujeǧid.”  
\v 12 Mafibucat tuɣa ɣares ijj n mmis ttřaɣan as Mixa. Marra inni tuɣa izeddɣen di taddart n Ṣiba tuɣa aten d imsexxaren n Mafibucat.  
\v 13 U Mafibucat tuɣa izeddeɣ di Urcalim, maɣar netta ittett řebda ɣar ṭṭabřa n ujeǧid. Netta tuɣa-t d aneɛḍab zi tnayen n iḍaren.   
\b  
\b  
\m  
\c 10
\s1 Amenɣi ak-d ayt n Ɛammun d Iramiyyen  
\m
\v 1 Awarni aya imsar, aqa ajeǧid n ayt n Ɛammun immut. Mmis Ḥanun idweř d ajeǧid deg wemcan nnes. \f ◼ \fr 10:1 \ft \+fk deg wemcan nnes\ft  - man aya ixs ad yini, aqa ixřef i-t.\f*  \x ◘ \xo 10:1 \xt [1 Im. 19:1-19]\x*  
\v 2 \add Xenni\add* inna Dawud: “Necc xseɣ ad ssecneɣ tamexsiwt icewwaren i Ḥanun, mmis n Naḥac, am mammec i d ayi isscen babas tamexsiwt \add nnes\add* icewwaren.” Dawud issekk \add ireqqasen\add* ḥima ad t iɛezza x \add řmewt n\add* babas s ufus n imsexxaren nnes u imsexxaren n Dawud iwḍen ɣar temmurt n ayt n Ɛammun.  
\v 3 \add Xenni\add* nnan řḥukkam n ayt n Ɛammun i sidi nsen Ḥanun: “Ma \add ixs\add* Dawud \add s tidett\add* ad iweqqar babac di tiṭṭawin nnec, umi dd-issekk netta imsexxaren maḥend ad cek ɛezzan? Ma war dd-issekk Dawud imsexxaren nnes ɣarek, ḥima ad arzun di tendint, ad ssmunen řexbar uca \add xenni\add* ad tt arren war teǧi d nettat?”   
\m
\v 4 \add Xas uca\add* iṭṭef Ḥanun imsexxaren n Dawud, iḥeff asen azyen zi tmart u iqess asen azyen n warruḍ ař ḍeffar, uca issekk i-ten.  
\v 5 \add Umi\add* xebbaren aya i Dawud, issekk asen \add ireqqasen\add*, minzi nitni tuɣa ttseḍḥan ixef nsen aṭṭas. Inna ujeǧid: “Qqimem di Ariḥa ař dd ɣa temɣar tmart nwem, xenni ad dd-tdewřem.”   
\m
\v 6 \add Umi\add* ẓrin ayt n Ɛammun belli nitni tuɣa ssarzgen ixef nsen ɣar Dawud, ssekken ayt n Ɛammun \add ireqqasen\add* u cran zeg ayt n Aram zi Bayt-Raxub u zeg ayt n Aram zi Ṣuba ɛicrin-ařaf n yeryazen x iḍaren, u zeg ujeǧid n Maɛka ařef n yeryazen u zeg yeryazen n Ṭub tenɛac-ařaf n yeryazen.  
\v 7 \add Umi\add* isřa Dawud aya, issekk netta Yuwab s marra řɛeskar nnes, ayt n bu-teɣruḍt.  
\v 8 Ayt n Ɛammun ffɣen-dd u sedden ixef nsen i umenɣi ɣar wadaf n tewwart \add n tendint\add*, maca ayt n Aram n Ṣuba d Raxub d yeryazen n Ṭub d Maɛka \add tuɣa aten\add* s yixef nsen deg iyyar.  
\v 9 \add Umi\add* iẓra Yuwab, aqa amenɣi ixeẓẓar i-ten deg uɣembub ɣar zzat u ɣar ḍeffar, ixḍar netta zi marra inni ittwafarzen \add di řɛeskar\add* n Israil uca issbedd i-ten \add i umenɣi\add* ajemmaḍ n ayt n Aram.  
\v 10 Min iqqimen n řgens igga i-ten sadu ufus n umas Abicay, wenni ten issbedden ajemmaḍ n ayt n Ɛammun.  
\v 11 Inna netta: “Mařa Aram ijhed xafi, xenni as-dd, fekk ayi! Mařa ayt n Ɛammun jehden xak, \add xenni\add* ad dd-aseɣ ad cek fekkeɣ.  
\v 12 Iři d aryaz u ad niři d iryazen di ṭṭweɛ n řgens nneɣ u di ṭṭweɛ n tneddam n AREBBI. Ejj SIDI ad igg min iǧan d lemliḥ di tiṭṭawin nnes.”  
\v 13 \add Xenni\add* iqarreb-dd Yuwab d řgens i ɣares iǧan i umenɣi ak-d Aram uca ina ṭṭfen di tarewřa zzat i wudem nnes.  
\v 14 \add Umi\add* ẓrin ayt n Ɛammun, aqa ayt n Aram arewřen, ṭṭfen uřa d nitni di tarewřa zzat i wudem n Abicay uca iwḍen ɣar tendint. Yuwab iɛqeb awarni i umenɣi ak-d ayt n Ɛammun uca yiweḍ ɣar Urcalim.   
\m
\v 15 \add Umi\add* ẓrin ayt n Aram aqa nitni ttwaɣeřben zzat i wudem n Israil, nnyarwen twařa nneɣnit.  
\v 16 Uca Hadad-Ɛazar issekk \add ireqqasen\add*, ijja ad dd-asen ayt n Aram inni \add izeddɣen\add* x ujemmaḍ n iɣzar \add n Lfuraṭ\add* uca nitni usin-dd ɣar Ḥilam. Cubak, akumandar n řɛeskar n Hadad-Ɛazar, iffeɣ zzat i wudem nsen.  
\v 17 \add Umi\add* ittwanna aya i Dawud, issmun netta marra Israil, iẓwa L’Urdun, yusa-dd ɣar Ḥilam. Ayt n Aram sedden ixef nsen i umenɣi qibač i Dawud u mmenɣen akides.  
\v 18 Ayt n Aram arewřen zzat i wudem n Israil u Dawud iqḍa x sebɛa-mya n ikarruten \add n umenɣi\add* d arebɛin-ařef n imnayen n ayt n Aram. \add Ɛawed\add* iwta netta Cubak, akumandar n řɛeskar nsen, ařami immut din.  
\v 19 \add Umi\add* ẓrin marra ijeǧiden nni tuɣa ittraḥen ak-d Hadad-Ɛazar, belli aqa nitni twaɣellben zzat i wudem n ayt n Israil, ggin nitni řehna ak-d Israil u sexxaren as. Ayt n Aram ggʷeden ad fekken ayt n Ɛammun twařa nneɣnit. \f ◼ \fr 10:19 \ft \+fk sexxaren as\ft  - s Tɛibranit ‘asen’.\f*   
\b  
\b  
\m  
\c 11
\s1 Dawud d Batcabaɛ  
\m
\v 1 Ɣar ubeddu n useggʷas n jdid, di řweqt i di itteffɣen ijeǧiden \add ɣar umenɣi\add*, imsar aqa Dawud issekk Yuwab ak-d yeryazen nnes nni akides \add iǧan\add* d marra Israil. Nitni řebzen ayt n Ɛammun uca nnḍen i Rabba. Maca Dawud simant nnes iqqim di Urcalim. \x ◘ \xo 11:1 \xt 1 Im. 20:1-3\x*   
\m
\v 2 Umi dd-ikkar Dawud ict n twařa di tmeddit zi qama nnes, imsar aqa netta yuyur x tzeqqa \add iwaṭan\add* n tzeddiɣt n ujeǧid. Iẓra ssenni ict n temɣart tessirid ixef nnes. Tamɣart nni dayes aẓri aṭṭas.  
\v 3 Dawud issekk \add ijj\add* din maḥend ad isseqsa x temɣart nni. Ittwanna \add as\add*: “Ma war teǧi d Bat-Cabaɛ, yeǧis n Iliɛam, tamɣart n Aḥitti Uriya?”  
\v 4 \add Xas uca\add* issekk Dawud ireqqasen, ijja ad tt-i-dd-awyen. Nettat tudef-dd ɣares uca iṭṭeṣ akides. \add Awarni řami\add* tuɣa tᵉttwazidged zi řexmej nnes, teɛqeb ɣar taddart nnes. \x ◘ \xo 11:4 \xt Lawi 15:19-24; 18:19\x*  
\v 5 Tamɣart tuɣa teksi s ddeyset uca tessekk \add ijj\add*, tessargeb Dawud, tenna: “Necc ksiɣ s ddeyset.”   
\m
\v 6 \add Xas uca\add* issekk Dawud \add ict n tebrat\add* ɣar Yuwab: “Sekk-dd Aḥitti Uriya ɣari!” U Yuwab issekk Uriya ɣar Dawud.  
\v 7 \add Umi\add* ɣares-dd yusa Uriya, isseqsa Dawud x mammec iǧa Yuwab u x mammec iǧa řgens u x mammec iggur umenɣi.  
\v 8 \add Xenni\add* inna Dawud i Uriya:“ Hwa ɣar taddart nnec uca ssird iḍaren nnec!” Uriya ismeḥ di taddart n ujeǧid u sseḍfaren as \add ɛad\add* ict n tarzeft n ujeǧid.  
\v 9 \add Maca\add* Uriya izzeř iṭṭeṣ ɣar tewwart n taddart n ujeǧid ak-d marra imsexxaren n sidi nnes. Netta war ihwi ca ɣar taddart nnes.  
\v 10 Xebbaren i Dawud, nnan: “Uriya war ihwi ca ɣar taddart nnes.” \add Xas uca\add* inna Dawud i Uriya: “Ma war dd-tedwiřed zeg usafar? Mayemmi cek war tehwid ɣar taddart nnec?” \f ◼ \fr 11:10 \ft \+fk asafar\ft  - niɣ ‘amuddu’.\f*  
\v 11 Uriya yarra-dd x Dawud: “Ttabut d Israil d Yahuda ttɣiman deg iqiḍan u sidi inu Yuwab d imsexxaren n sidi inu wtin iqiḍan nsen deg iyyar yarezmen. Ma \add xenni\add* ad uyureɣ necc ɣar taddart inu, ḥima ad cceɣ, ad sweɣ u ad wḍiɣ ak-d temɣart inu? \add S tidett am\add* teddared cek u iddar řeɛmar nnec, war tteggeɣ aya!”  
\v 12 \add Xas\add* uca inna Dawud i Uriya: “Qqim uřa d ass-a ɛad danita. Tiwecca ad cek ssekkeɣ \add ɛawed\add*.” Uca \add ammu i\add* iqqim Uriya ass nni d wass i t-i-dd-iḍfaren di Urcalim.   
\m
\v 13 Iɛarḍ i-t Dawud uca netta icca, iswa zzat i wudem nnes uca \add Dawud\add* isscar i-t. Ɣar tmeddit \add maca\add* iffeɣ Uriya, ḥima ad izzeř \add ɛawed\add* ɣar imsexxaren n sidi nnes, \add maca\add* netta war ihwi ca ɣar taddart nnes.  
\v 14 Ɣar tuffut imsar, aqa Dawud yura ict n tebrat i Yuwab uca issekk i-tt s ufus n Uriya.  
\v 15 Netta yura di tebrat nni: “Sbeddet Uriya ɣar zzat mani iǧa umenɣi iqesḥen, xenni ḥeyydet xas, ḥima ad t řeqfen, ad immet.”   
\m
\v 16 \add Am\add* iḥṣar Yuwab tandint, imsar netta issbedd Uriya ɣar mani netta issen aqa dinni bedden yeryazen imeḥḍen aṭṭas.  
\v 17 \add Xenni\add* i dd-ffɣen yeryazen zi tendint, mmenɣen ak-d Yuwab. Wḍan \add yeryazen\add* zi řgens, zeg imsexxaren n Dawud, uřa d Aḥitti Uriya immut.  
\v 18 Yuwab issekk \add ijj n umsexxar\add* uca iḥaja i Dawud x mammec iggur umenɣi.  
\v 19 Netta yumur i umsexxar, inna: “Mařa cek tkemmřed řexbar nnec x mammec iggur marra umenɣi,  
\v 20 uca imsar ad ikkar wesɛar n ujeǧid, ad ac yini: “Mayemmi tudsem tandint deg umenɣi? Ma war tessinem kenniw, aqa nitni ad wtin kenniw zi řḥiḍ?  
\v 21 Man wen inɣin Abimalik, mmis n Yarubbucat? Ma war iǧi d ict n temɣart tenḍared xas tasirt yuɛřan n tsirt zi řḥiḍ, ařami netta immut di Tabaṣ? Mayemmi tuyurem tudsem ammu řḥiḍ?’, xenni cek ad tinid: ‘Uřa d amsexxar nnec, Aḥitti Uriya, ittwaneɣ.’” \x ◘ \xo 11:21 \xt Řqḍ. 9:52, 53\x*   
\m
\v 22 Areqqas yuyur, yusa-dd ɣar Dawud uca iḥaja as marra x min xef t issekk Yuwab.  
\v 23 Areqqas inna i Dawud: “Iryazen tuɣa jehden xaneɣ u nitni tuɣa ffɣen-dd ɣarneɣ ař iyyar, maca neccin neḥṣar i-ten ař tawwart \add n tendint\add*.  
\v 24 \add Xenni\add* wtin inni ittḥakan \add s řqews\add* zi řḥiḍ x imsexxaren nnec, \add ařami\add* mmuten imsexxaren n ujeǧid. Uřa d amsexxar nnec, Aḥitti Uriya, immut.”  
\v 25 \add Xenni\add* inna Dawud i ureqqas: “Ammu i ɣa tinid i Yuwab: ‘War ttejji ad tiři tmesřact-a d taɛeffant di tiṭṭawin nnec, maɣar ssif ad icc wanita, daweḥda wenneɣni. Iři d aryaz deg umenɣi ak-d tendint u hdem i-tt!’ Egg dayes taryast \add s wawař-a\add*.”  
\v 26 Tamɣart n Uriya tesřa belli aqa aryaz nnes Uriya immut u nettat tegga x sidi nnes acḍan.  
\v 27 \add Umi\add* teɛdu \add řweqt n\add* wecḍan issekk Dawud ad tt-i-dd-awyen di taddart nnes. Nettat tedweř d tamɣart nnes uca turuw as-dd ijj n uḥenjir. \add Maca\add* min tuɣa igga Dawud, tuɣa d aɛeffan di tiṭṭawin n SIDI.   
\b  
\b  
\m  
\c 12
\s1 Awař n unabi Natan  
\m
\v 1 Issekk SIDI Natan ɣar Dawud. \add Řami\add* ɣares yudef netta, inna as:  
\m “Deg ict n tendint tuɣa din tnayen n yeryazen, ijjen \add tuɣa\add* ɣares agřa, wenneɣni d amezřuḍ.  
\v 2 Bu-wagřa ɣares abarru n wuǧi d ifunasen d tfunasin.  
\v 3 Amezřuḍ maca war ɣares walu mɣir ict n tḥuřit d tameẓyant i tuɣa dd-isɣa. Netta tuɣa issecca i-tt u tedweř tmeqqar ɣares u ɣar iḥenjiren nnes. Tecca zeg uřeqquz n weɣrum nnes u teswa zeg ufenjař nnes u tᵉṭṭeṣ x ifadden nnes. Tuɣa-tt i netta am yict n yeǧis.  
\v 4 \add Umi\add* dd-yusa ijj n umsebrid ɣar weryaz bu-wagřa, yewɛar xas ḥima ad issewjed \add macca\add* i umsebrid i ɣares dd-yusin zeg \add ijj n\add* wuǧi nnes niɣ zeg \add ijj n\add* ifunasen d tfunasin nnes. S uyenni iksi netta taḥuřit tameẓyant n weryaz amezřuḍ uca issewjed i-tt i weryaz nni tuɣa ɣares dd-yusin.”   
\m
\v 5 Yarɣa uxeyyeq n Dawud aṭṭas x weryaz nni, inna i Natan: “\add S tidett am\add* iddar SIDI, aryaz i iggin aya, tekkar as-dd řmewt,  
\v 6 uca taḥuřit tameẓyant ad tt ixřef arebɛa n tseqqar, minzi netta igga aya, war \add dayes\add* yarḥim.” \x ◘ \xo 12:6 \xt Uf. 22:1\x*   
\m
\v 7 \add Xenni\add* inna Natan i Dawud: “Cek \add simant nnec\add* d aryaz \add nni\add*. Ammu i iqqar SIDI, AREBBI n Israil: Necc dehneɣ cek d ajeǧid x Israil u Necc ssnejmeɣ cek zeg ufus n Cawul. \x ◘ \xo 12:7 \xt 1 Ṣm. 16:13\x*  
\v 8 Necc wciɣ ac taddart n sidi nnec d temɣarin n sidi nnec x ifadden nnec u Necc wciɣ ac taddart n Israil d Yahuda. Mařa aya drus, iři ad arniɣ wa niɣ ta i cek.  
\v 9 Mayemmi tesseḥqared awař n SIDI u teggid min iǧan d aɛeffan di tiṭṭawin nnes? Cek tenɣid Aḥitti Uriya s ssif u teksid tamɣart nnes, teggid tt d tamɣart i yixef nnec uca tenɣid aryaz nnes s ssif n ayt n Ɛammun.  
\v 10 \add Xenni\add* řexxu, ssif war ittḥeyyid i řebda x taddart nnec, maɣar cek tesseḥqared ayi u teksid tamɣart n Uḥitti Uriya, ḥima ad tedweř d tamɣart nnec.  
\v 11 Ammu i iqqar SIDI: Xẓar, Necc ad xak ssekkareɣ tuɛeffna zi taddart nnec u Necc ad ac kkseɣ timɣarin nnec zzat i tiṭṭawin nnec, ad tent wceɣ i jjar nnec u netta ad iṭṭeṣ ak-d temɣarin nnec ɣar tfuct deg ujenna. \x ◘ \xo 12:11 \xt Aɛwd. 28:30; 2 Ṣm. 16:22\x*  
\v 12 Maɣar cek teggid tt s tnuffra, maca Necc ad ggeɣ aya zzat i tiṭṭawin n marra Israil u ɣar \add tifawt\add* n tfuct.”  
\v 13 \add Xas\add* uca inna Dawud i Natan: “Necc xḍiɣ ak-d SIDI!” Inna Natan i Dawud: “SIDI iɣfar ddenb nnec, war tmettid ca.  
\v 14 Maca, umi cek tarrid řɛedyan n SIDI ad ceqqfen aṭṭas, s tidett ittxeṣṣa ad immet mmic i d ac dd-ittwarwen.”  
\v 15 Xenni yuyur Natan ɣar taddart nnes. SIDI iřqef aḥenjir i tuɣa dd-turuw temɣart n Uriya i Dawud uca idweř iḥřec aṭṭas.   
\b  
\m  
\s1 Taẓaǧit n Dawud i mmis  
\m
\v 16 Dawud yarzu AREBBI di ṭṭweɛ n uḥenjir. Iẓumm Dawud břa qeṭṭu u netta yudef, izzeř x temmurt di ǧiřet.  
\v 17 Imɣaren n taddart nnes usin-dd, bedden ɣares ḥima ad t arren ad dd-ikkar zi temmurt. Netta maca war ixs u war icci aɣrum akidsen.   
\m
\v 18 Deg wass wiss sebɛa imsar aqa aḥenjir immut. Imsexxaren n Dawud ggʷeden ad as inin, aqa aḥenjir immut, maɣar nitni nnan: “Xzar, umi aḥenjir tuɣa iddar ɛad, nessiweř akides, maca war ɣarneɣ isři ca. Mammec i nzemmar \add řexxu\add* ad as nini: ‘Aḥenjir immut’? Netta ad igg tuɛeffna \add deg ixef nnes\add*.”  
\v 19 Dawud iẓra aqa imsexxaren nnes ssawařen s tḥessect jar asen u Dawud yuca illa aḥenjir tuɣa immut. Netta inna i imsexxaren nnes: “Ma immut uḥenjir?” Nitni nnan as: “Aqa immut!”  
\v 20 \add Xenni\add* ikkar Dawud zi temmurt, issird, idhen ixef nnes, ibeddeř arruḍ nnes. Netta yudef ɣar Taddart n SIDI, isjed. \add Umi xenni\add* yareggʷeḥ ɣar taddart, ittar aɣrum u nitni ssarsen aɣrum zzates uca icca.  
\v 21 Nnan as imsexxaren nnes: “Min teggid cek řexxu? Umi aḥenjir ɛad iddar, tẓummed di ṭṭweɛ nnes u trud. \add Maca\add* awarni řami immut uḥenjir, tekkared uca teccid aɣrum.”  
\v 22 Netta yarra-dd xasen: “Umi aḥenjir ɛad iddar, ẓummeɣ u ruɣ, maɣar necc nniɣ: ‘Wi issnen, SIDI ad xafi iḥinn u aḥenjir ad iddar.’  
\v 23 Řexxu maca immut. Mayemmi ɣa ẓummeɣ ɛad? Ma zemmareɣ ad t-i-dd-arreɣ? Necc ad ɣares raḥeɣ ict n twařa, maca netta war dd ɣari ittɛiqqib.”   
\m
\v 24 Dawud issfewwej tamɣart nnes Bat-Cabaɛ u netta yudef xas, iṭṭeṣ akides. Nettat turuw-dd ijj n uḥenjir, igga as Suliman. SIDI tuɣa ittexs i-t \x ◘ \xo 12:24 \xt 1 Im. 22:9; Mt. 1:6\x*  
\v 25 uca igga as Yadid-Yah s ufus n unabi Natan, am mammec tuɣa ixs SIDI.   
\b  
\m  
\s1 Aɣelleb x tendint n Rabba di Ɛammun  
\m
\v 26 Yuwab immneɣ ak-d Rabba n ayt n Ɛammun u netta iḥewwes tandint n ujeǧid. \x ◘ \xo 12:26 \xt [1 Im. 20:1-3]\x*  
\v 27 \add Xas uca\add* issekk Yuwab ireqqasen ɣar Dawud, inna: “Necc mmenɣeɣ ak-d Rabba ṭṭfeɣ uřa d tandint n waman.  
\v 28 Smun min iqqimen n řɛeskar uca nneḍ i tendint, ṭṭef i-tt, niɣ ad ṭṭfeɣ necc tandint uca ad xas řaɣan s yisem inu.”   
\m
\v 29 \add Xenni\add* issmun Dawud marra řɛeskar, iffeɣ ɣar Rabba, immneɣ akides uca iṭṭef i-tt.  
\v 30 Ikkes ttaj x uzeǧif n ujeǧid, wenni s yijj n řewzen n ict n talint n wureɣ u xas tayaqutin iɣřan, uca tusa-dd \add ttaj\add* x uzeǧif n Dawud. Netta yiwi \add ɛawed\add* ict n tkeccaḍt d tameqqrant aṭṭas zi tendint. \x ◘ \xo 12:30 \xt 1 Im. 20:2\x*  
\v 31 Řgens nni dayes \add iǧan\add* issuffeɣ i-t u iḥjem xasen s řmencarat d iyařzimen n wuzzař d ccwaqar n wuzzař uca netta ijja i-ten ad ɛdun s řkuccat n llajur. Ammu i igga netta ak-d marra tineddam n ayt n Ɛammun. \add Xenni\add* iɛqeb Dawud d marra řgens ɣar Urcalim. \x ◘ \xo 12:31 \xt 1 Im. 20:3\x*   
\b  
\b  
\m  
\c 13
\s1 Amnun d Tamar  
\m
\v 1 Imsar awarni aya, aqa Abcalum, mmis n Dawud, tuɣa ɣares ict n učmas dayes aẓri, qqaren as Tamar, uca Amnun, mmis n Dawud, iɛceq i-tt.  
\v 2 Amnun tuɣa icḍen aṭṭas ařami ihřec x ssibbet n učmas Tamar, maɣar nettat tuɣa d taɛzarect, uca tuɣa war izemmar di tiṭṭawin n Amnun ad as igg ca.  
\v 3 Amnun tuɣa ɣares ijj n umeddukkeř qqaren ass Yunadab, ijj n mmis n Cimɛa, umas n Dawud. Yunadab tuɣa d ijj n weryaz d aḥraymi aṭṭas.  
\v 4 Netta inna as: “Mayemmi tceḍned ammu zi tuffut ař tuffut, cek, mmis n ujeǧid? Ma war texsed cek ad ayi t tɛawded?” Amnun yarra-dd xas: “Necc ɛecqeɣ Tamar, učmas n uma Abcalum.”   
\m
\v 5 Inna as Yunadab: “Zzeř di qama u egg ixef nnec theřced. Mařa \add xenni\add* yusa-dd babac, ḥima ad xak issijj, ini as: ‘Ejj učma Tamar ad ɣari dd-tas maḥend ad ayi tewc macca u ad tessewjed macca zzat i tiṭṭawin inu, ḥima ad ẓarɣ, ad cceɣ zeg ufus nnes.’”  
\v 6 Amnun izzeř din, issniɛmiř ihřec. Umi dd-yusa ujeǧid, ḥima ad xas issijj, inna Amnun i ujeǧid: “Ejj ad dd-tas učma Tamar maḥend nettat ad ayi tessewjed tnayen n tɣaryiṭatin u necc ad tent cceɣ zeg ufus nnes.”  
\v 7 Dawud issekk \add ijj\add* ɣar Tamar, di taddart \add nnes\add*, ḥima ad as inna: “Ruḥ ɣar taddart n umam Amnun u sewjed as macca.”  
\v 8 Tamar tuyur ɣar taddart n umas Amnun wenni din izzřen di qama. Nettat teksi arecti, teggʷa t u tessewjed tiɣaryiṭatin zzat i tiṭṭawin nnes uca teggʷa tiɣaryiṭatin.  
\v 9 Nettat teksi marmita teggid-i-tt zzates, maca netta yugi ad icc. \add Xenni\add* inna Amnun: “Ejj ad xafi ffɣen marra!” U marra ffɣen xas.   
\m
\v 10 \add Xenni\add* inna Amnun i Tamar: “Awi-dd macca deg wexxam, ḥima ad cceɣ zeg ufus nnem.” U Tamar teksi tiɣaryiṭatin i tuɣa tegga u tiwyi tent i umas Amnun deg wexxam.  
\v 11 Nettat tessiẓẓwiḍ \add i-tent\add* \add s ufus nnes\add* ɣares maḥend ad icc. Netta iṭṭef i-tt, inna as: “As-dd, ṭṭeṣ ɣari, učma!”  
\v 12 \add Maca\add* nettat tenna as: “Lla, a uma, war d ayi ssexsari ca, maɣar ammu war ittwagg di Israil. War ttegg ca řefḍiḥet-a!  
\v 13 Mani ɣa uyureɣ di řefḍiḥet inu? U cek, cek ad tiřid d ijjen zeg ibuhařiyyen di Israil. Siweř maca ak-d ujeǧid, minzi netta war d ayi itteṭṭef xak.”  
\v 14 \add Maca\add* Amnun war ixs ca ad ɣares iseř, maca ijhed xas uca issbehdeř i-tt, iṭṭeṣ akides.   
\m
\v 15 \add Daweḥda nnes\add* iɛiff i-tt s yijj n uɛiffi d ameqqran aṭṭas, minzi aɛiffi i zi tt iɛiff, tuɣa-t d tameqqrant x tayri i zi tuɣa tt iɛceq. Amnun inna as: “Kkar, aggʷej!”  
\v 16 \add Xenni\add* inna as: “War din řesbab maḥend ad ayi tessekked. Tuɛeffna-ya ad tiři ɛad \add d řɛib\add* d ameqqran x min d ayi teggid.” Netta maca war ixs ad ɣares iseř.  
\v 17 Iřaɣa x umsexxar nnes wenni i xas ittsexxaren, inna as: “Sekk ta xafi ɣar barra u belleɛ tawwart awarni as!”   
\m
\v 18 Nettat tuɣa xas arruḍ \add s ifassen d iziraren\add*, maɣar ammu i yarḍent yessis n ujeǧid min ɣa kkent d tiɛzariyyin. Amsexxar nnes yiwyi tt ɣar barra, ibelleɛ tawwart awarni as.  
\v 19 Tamar tzuzzar iɣɣeḍ x uzeǧif nnes u tcarreg arruḍ \add s ifassen d iziraren\add* i tyarḍ, tessars ifassen nnes x uzeǧif nnes, \add am\add* tuyur tesɣuyyu.   
\m
\v 20 Umas Abcalum isseqsa tt: “Ma tuɣa umam Amnun akidem? Řexxu \add xenni\add*, učma, susem, netta d umam. War d am itteqqes bu řḥař!” U Tamar teqqim weḥḥdes di taddart n umas Abcalum.  
\v 21 \add Řami\add* isřa ujeǧid Dawud x marra timesřayin-a, idweř ixeyyeq aṭṭas.  
\v 22 Abcalum war issiweř ɛad ak-d Amnun, war iǧi di tcuni uřa di tuɛeffna, maɣar Abcalum iɛiff Amnun minzi wanita tuɣa issbehdeř učmas Tamar.   
\b  
\m  
\s1 Ittwaneɣ Amnun zi Abcalum  
\m
\v 23 Awarni řami \add ɛdun\add* tnayen n iseggʷusa munen, imsar, aqa Abcalum \add tuɣa ɣares\add* irewwan di Baɛl-Ḥaṣur nni \add iǧan\add* ɣar Ifrayim u Abcalum iɛarḍ marra arraw n ujeǧid.  
\v 24 Yuyur Abcalum ɣar ujeǧid, inna: “Xzar, amsexxar nnec ɣares irewwan! Ejj ujeǧid s marra imsexxaren nnes ad uyuren ak-d umsexxar nnec.”  
\v 25 \add Maca\add* ajeǧid yarra-dd x Abcalum: “LLa, \add a\add* mmi, ejj aneɣ war dd-nettis marra, ḥima war xak nᵉttegg ddqeř!” Netta izeyyar xas, \add maca\add* netta war ixs akides yuyur, \add maca waxxa amenni\add* ibarek i-t.  
\v 26 \add Xenni\add* inna Abcalum: “Mařa lla, ejj uma Amnun ad kidneɣ yuyur!” Ajeǧid inna as: “Mayemmi akidek i ɣa yuyur?”  
\v 27 \add Umi\add* xas izeyyar Abcalum, ijja netta ad uyuren Amnun d marra arraw n ujeǧid akides.   
\m
\v 28 Abcalum yumur imsexxaren nnes, inna: “Ḥḍam, xmi ɣa yarecceq uř n Amnun zi binu u necc ad awem iniɣ: ‘Wtem Amnun!’, xenni ittxeṣṣa kenniw ad t nɣem. War tteggʷedem ca! Ma necc simant inu war t umureɣ i kenniw? Iřim d iryazen u iřim d ayt n bu-teryast.”  
\v 29 Imsexxaren n Abcalum ggin ak-d Amnun am mammec i tuɣa xasen igga Abcalum. \add Xenni\add* kkaren marra iḥenjiren n ujeǧid, nyin, kuř aryaz x usardun nnes, uca arewřen.   
\m
\v 30 Umi nitni tuɣa aten ɛad deg webrid, imsar, aqa řexbar yiweḍ ɣar Dawud, nnan: “Abcalum inɣa marra iḥenjiren n Dawud, war iqqim uřa d ijjen zzaysen.”  
\v 31 Uca ikkar Dawud, icarreg arruḍ nnes, izzeř x temmurt. Marra imsexxaren nnes bedden \add din ɣares\add* s warruḍ nsen icarrgen. \x ◘ \xo 13:31 \xt 2 Ṣm. 1:11\x*  
\v 32 \add Maca\add* Yunadab, mmis n Cimɛa, umas n Dawud, issiweř, inna: “Ittxeṣṣa i sidi inu war ittɣiř \add deg ixef nnes\add*, aqa nɣin marra iḥudriyyen, iḥenjiren n ujeǧid. Amnun waha i ittwanɣen, maɣar Abcalum igga aya di řbař nnes zeg wass i di issxarreg wanita učmas Tamar.  
\v 33 Ejj sidi inu, ajeǧid, war d as ittɣimi řḥař řexxu, ad yini: ‘Marra arraw n ujeǧid ttwanɣen!’, maɣar Amnun waha immut.”   
\m
\v 34 Abcalum tuɣa yarweř. Uca amsexxar wenni ittɛessan, issgeɛɛed tamuɣři nnes, u xzar, aqa iwdan aṭṭas usin-dd zeg webrid \add i iǧan\add* awarni as, zeg uɣezdis n wedrar.  
\v 35 \add Xenni\add* inna Yunadab i ujeǧid: “Xzar, arraw n ujeǧid i dd-ttasen. Aqa imsar am mammec inna umsexxar nnec.”  
\v 36 Uca imsar umi ikemmeř awař nnes, aqa xeḍren-dd arraw n ujeǧid. Nitni ssgeɛɛden tmijja nsen, run. Uřa d ajeǧid d marra imsexxaren nnes ksin deg imeṭṭawen.   
\m
\v 37 Abcalum tuɣa yarweř, yuyur ɣar Talmay, mmis n Ɛammixur, ajeǧid n Jacur. Dawud icḍen x mmis marra ussan.  
\v 38 Abcalum tuɣa yarweř, yuyur ɣar Jacur. Netta iqqim dinni třata n iseggʷusa.  
\v 39 Aya issbedd ajeǧid Dawud maḥend ad iffeɣ \add i umenɣi\add* ak-d Abcalum, maɣar netta issɛezza ixef nnes zi jjihet n řmewt n Amnun, maɣar wanita aqa immut.   
\b  
\b  
\m  
\c 14
\s1 Aɛqeb n Abcalum ɣar Urcalim  
\m
\v 1 Umi Yuwab, mmis n Ṣaruya, iḥekkar aqa uř n ujeǧid tuɣa ḍidd i Abcalum,  
\v 2 issekk Yuwab \add ijj n ureqqas\add* ɣar Taquɛa uca ijja ad ssenni dd-awyen ict n temɣart d tamiɣist, inna as: “Ttzawgeɣ, egg axmi cem tceḍned, yarḍ arruḍ n wecḍan, war dehhen ixef nnem s zzect! Sneɛmiř am yict n temɣart nni iceḍnen x ijj n umettin aṭṭas n wussan. \f ◼ \fr 14:2 \ft \+fk Taquɛa\ft  - isem-a wanita ixs ad yini ‘amcan mani izemmar ad ttwatwen iqiḍan’. Tuɣa Taquɛa d ict n tendint ɣar ṭṭarf n ljanub n Bayt-Laḥm, ɛřayen 8 km.\f*  
\v 3 Adef ɣar ujeǧid u siweř akides awařen-a.” Uca Yuwab inna as min ɣa tini.   
\m
\v 4 Tamɣart zi Taqquɛa tenna i ujeǧid, am tewḍa s uɣembub nnes ɣar temmurt, tuḍar \add as\add*: “Senjem \add ayi\add*, \add a\add* ajeǧid!”  
\v 5 Inna as ujeǧid: “Min cem yuɣin?” Nettat tenna as: “S tidett necc d tajjač, aryaz inu immut.  
\v 6 Tayya nnec tuɣa ɣares tnayen n iḥenjiren u nitni s tnayen idsen mmenɣen deg iyyar. Tuɣa war din uřa d ijj ad ten ibḍa. \add Xenni\add* iwta ijjen wenneɣni uca inɣa i-t.  
\v 7 U xzar, marra řaǧ iɣewweɣ x tayya nnec, nnan: ‘Awi-dd wenni inɣin umas da, maḥend ad t nenneɣ di ssibbet n řeɛmar n umas wenni t inɣin u \add ammu i\add* ɣa neqḍa uřa x wewrit.’ Ammu i xsen nitni ad ssxesyen \add ayenni n\add* řefḥem itteḥduduqen i d ayi iqqimen ařami war ittɣimi i weryaz inu isem di temmurt qaɛ.”   
\m
\v 8 \add Xenni\add* inna ujeǧid i temɣart: “Uyur ɣar taddart! Necc ad ssuffɣeɣ řumurat xam.”  
\v 9 Tamɣart zi Taqquɛa tenna i ujeǧid: “Sidi inu ajeǧid, ejj ad tiři řmuɛṣiyyet xafi u x taddart n baba. Ajeǧid d řɛarc nnes d imezdagen.”  
\v 10 Inna ujeǧid: “Awi ayi-dd ɣari wenni ɣar iǧa ca xam, ařami netta war ittɣimi ɛad ad cem iṣeddeɛ.”  
\v 11 Nettat tenna: “Ejj ajeǧid ad ixarreṣ di SIDI, AREBBI nnec, ḥima wenni ixsen ad ixřef idammen war yarenni ɛad di arẓiyyet u war issuffuɣ mmi ɣar ṭṭarf.” \add Xenni\add* inna netta: “\add S tidett am\add* iddar SIDI, mařa uřa d ijj n uzeṭṭu n ucuwwaf \add n uzeǧif\add* n mmim ad iwḍa di temmurt!”  
\v 12 \add Xenni\add* tenna temɣart: “Ttzawgeɣ, ejj tayya nnec ad tini \add ɛad\add* ijj n wawař i sidi inu ajeǧid.” Uca netta inna: “Siweř.”  
\v 13 Tamɣart tenna: “Mayemmi xenni tenwid cek s yixef nnek ad tegged ammu ak-d řgens n AREBBI? Umi inna ujeǧid \add řexxu\add* awař-a, aqa netta simant nnes am wenni di iǧa řɛib, minzi ajeǧid war dd-ittarri \add ɣares\add* wenni t inḍar.  
\v 14 Maɣar neccin \add marra\add* ad nemmet, aqa neccin am waman ittwafarrɣen x temmurt, war nnyarwen. SIDI war ittekkes řeɛmar, \add maca\add* ad ixarreṣ ḥima wenni zzayes ittwammenḍar, war ittɣimi immenḍar.  
\v 15 \add Xenni\add* řexxu, necc usiɣ-dd \add da\add* ḥima ad ssiwřeɣ awař-a ak-d sidi inu ajeǧid, minzi řgens issiggʷed ayi. \add Xenni\add* tenna tayya nnec: Ejj ayi ad ssiwřeɣ ak-d ujeǧid, ad taɣ ad igg ujeǧid min ɣa tini tayya nnes,  
\v 16 maɣar ajeǧid ad iseř ɣar tayya nnes, maḥend ad tt ifekk zeg ufus n weryaz nni ixsen ad iteḥḥa necc d mmi zi tesɣart i \add ṭṭfeɣ\add* zi AREBBI.  
\v 17 Tayya nnec tenna \add ɛawed\add*: Ejj ad issareyyeḥ wawař n sidi inu ajeǧid, maɣar sidi inu ajeǧid, igga am yijj n lmalak n AREBBI ařami ittesřa min iṣebḥen d min war iḥřin. Ad kidek yiři SIDI AREBBI nnec.”   
\m
\v 18 Ajeǧid yarra-dd xas, inna i temɣart: “War xafi teffar walu zi tmesřact i x cem i ɣa sseqsiɣ.” Tamɣart tenna: “Ejj sidi inu, ajeǧid, ad issiweř.”  
\v 19 Inna ujeǧid: “Ma Yuwab ɣares afus di marra man aya?” Tamɣart tarra-dd xas: “\add S tidett am\add* iddar řeɛmar inu, \add a\add* sidi inu, ajeǧid, \add ma izemmar\add* uřa d ijjen \add ad ibeɛɛed\add* ɣar yefus niɣ ɣar uzeřmaḍ x marra min issiweř sidi inu, ajeǧid! Wah, amsexxar nnec Yuwab d wenni d ayi yumuren. Netta igga marra awařen-a deg uqemmum n tayya nnec.  
\v 20 Aya igga i-t umsexxar nnec Yuwab, ḥima ad iwc i tmesřact ijj n uɣembub nneɣni. \add Maca\add* sidi inu d amiɣis am yijj n lmalak n AREBBI, ařami issen marra min ittemsaran di temmurt.”   
\m
\v 21 \add Xas\add* uca inna ujeǧid i Yuwab: “Xzar ɛafak, necc ggiɣ man aya. Uyur, awi-dd aḥudri Abcalum!”  
\v 22 Yuwab iwḍa s uɣembub nnes ɣar temmurt, yuḍar \add as\add*, iqada i ujeǧid. Uca inna Yuwab: “Ass-a issen umsexxar nnec, aqa ufiɣ arḍa di tiṭṭawin nnec, sidi inu, ajeǧid, minzi ajeǧid igga ɛlahsab awař n umsexxar nnes.”  
\v 23 Ikkar Yuwab, yuyur ɣar Jacur u yiwiḍ ɣar Urcalim ak-d Abcalum.  
\v 24 Inna ujeǧid: “Ejj i-t ad iɛqeb ɣar taddart nnes. Udem inu \add maca\add* war t iẓẓar.” \add Xenni\add* iɛqeb Abcalum ɣar taddart nnes, \add maca\add* war iẓri udem n ujeǧid.   
\m
\v 25 Di marra Israil war iǧi uřa d ijj n weryaz icewwar am Abcalum ařami ittwassuɛřa aṭṭas. Zi tařeqqa n iḍaren ař tqiccit n uzeǧif nnes war dayes uřa d ijj n řɛib.  
\v 26 Mařa iḥeff acuwwaf nnes, \add tuɣa innum\add* ad t iḥeff ɣar uneggar n wussan ɛlaḥsab ussan \add n kuř aseggʷas\add*, minzi tuɣa iddekkwař idqeř xas. Iḥeff u iwzen acuwwaf n uzeǧif nnes. \add Tuɣa řewzen n ucuwwaf\add* mitayen ciqlu ɛlaḥsab aẓru s řewzen imten n ujeǧid.  
\v 27 Ttwarwen-dd třata n iḥenjiren i Abcalum d ict n yeǧis qqaren as Tamar. Nettat tedweř d ict n temɣart dayes aẓri.   
\m
\v 28 Abcalum izdeɣ tnayen n iseggʷusa di Urcalim. Netta war iẓri udem n ujeǧid.  
\v 29 \add Xenni\add* issekk Abcalum \add ijj n ureqqas\add* ɣar Yuwab, ḥima ad t issekk ɣar ujeǧid \add di ṭṭweɛ n yixef nnes\add*, \add maca\add* Yuwab war ixs ad ɣares dd-yas. Uca issekk \add areqqas\add* twařa nneɣnit, maca netta war ixs ad dd-yas.  
\v 30 \add Xenni\add* inna i imsexxaren nnes: “Xzarem, iyyar n Yuwab i iǧan x uɣezdis n wenni inu u netta \add iẓẓu\add* dayes imendi. Uyurem din, qqedem as timessi!” Uca imsexxaren n Abcalum qqden timessi i iyyar \add nni\add*.   
\m
\v 31 \add Xas\add* uca ikkar Yuwab uca issijj x Abcalum di taddart \add nnes\add*, inna as: “Mayemmi qqden imsexxaren nnec timessi i ureqqiɛ n iyyar i iǧan inu?”  
\v 32 Abcalum inna i Yuwab: “Xzar, necc ssekkeɣ-dd ɣarek \add ḥima\add* ad ac iniɣ: ‘As-dd da, ḥima ad cek ssekkeɣ ɣar ujeǧid ad tinid: Min ɣar dd-usiɣ \add da\add* zi Jacur? Mliḥ i necc mři dinni qqimeɣ.’ Xenni řexxu ittxeṣṣa ad ẓareɣ udem n ujeǧid. Mařa dayi \add ɛad\add* řmuɛṣiyyet, ejj i-t ad ayi ineɣ.”  
\v 33 \add Xenni\add* yuyur Yuwab ɣar ujeǧid, inna as aya. U wanita iřaɣa-dd x Abcalum uca yudef netta ɣar ujeǧid, ibendeq as s uɣembub nnes ɣar temmurt, zzat i ujeǧid, uca ajeǧid issudem Abcalum.   
\b  
\b  
\m  
\c 15
\s1 Tameɛmuč i igga Abcalum x Dawud  
\m
\v 1 Awarni uya imsar, aqa Abcalum ijja ad as iḍebbaran ijj n ukarru d iysan d xemsin n yeryazen inni ittazzřen ɣar zzat nnes.  
\v 2 Tuɣa ittekkar Abcalum zic ɣar tuffut \add n řḥař\add* uca ibedd ɣar uɣezdis n webrid ɣar tewwart \add n tendint\add*. Uca imsar, meřmi ma ixs ijj n weryaz ad iraḥ s ict n ddeɛwet ɣar ujeǧid i ccreɛ, iřaɣa-dd xas ɣares, inna: “Zi man tandint cek?” Mařa wanita yarra-dd: “Amsexxar nnec zeg ict zi tqebbař n Israil”,  
\v 3 inna as Abcalum: “Xzar, ddeɛwa nnec mliḥ u nican, \add maca\add* ɣar ujeǧid war iǧi uřa d ijj wenni ɣarek ɣa isřen.”  
\v 4 Abcalum yarni inna: Mři d ayi ggin d řqaḍi di temmurt, \add maḥend\add* \add kuř\add* aryaz wenni ɣar iǧa umcubbec niɣ ddeɛwet, ad ɣari dd-yas, necc ad as aɣeɣ tasɣart?” \f ◼ \fr 15:4 \ft \+fk Man wen d ayi i ɣa iggin d řqaḍi di temmurt\ft  - řmeɛna n wawařen n Abcalum d wanita: ‘Mři d ayi maca ɣa ggen d řqaḍi di temmurt’.\f*  
\v 5 Mařa iqarreb-dd ɣares ijj n weryaz ḥima ad as ibendeq, isswiẓẓeḍ afus nnes, iṭṭef i-t uca issudem i-t.  
\v 6 Ammu igga Abcalum ɣar marra \add inni iǧan zi\add* Israil, inni dd-yusin i ccreɛ ɣar ujeǧid. Ammu yucar Abcalum uř n yeryazen n Israil.   
\m
\v 7 Awarni arebɛa n iseggʷusa imsar aqa Abcalum inna i ujeǧid: “Ejj ayi ad uyureɣ, ad ssqefřeɣ di Ḥabrun lwaɛd inu i waɛdeɣ i SIDI.  
\v 8 Maɣar amsexxar nnec igga ijj n lwaɛd umi tuɣa zeddɣeɣ \add ɛad\add* di Jacur di Aram, nniɣ: ‘Mařa SIDI ijja ayi s tidett ad dd-dewřeɣ ɣar Urcalim, \add xenni\add* ad xedmeɣ i SIDI.’”  
\v 9 \add Xenni\add* inna as ujeǧid: “Uyur di řehna!” Ikkar netta uca yuyur ɣar Ḥabrun.   
\m
\v 10 Abcalum \add maca\add* issekk iryazen x iḍaren ɣar marra tiqebbař n Israil ḥima ad inin: “Mařa kenniw tesřam i usuḍi deg uyicc n icarri, xenni ittxeṣṣa ad tinim: ‘Abcalum d ajeǧid di Ḥabrun.’”  
\v 11 Zi Urcalim uyuren ak-d Abcalum mitayen n yeryazen inni ittwaɛarḍen. Nitni uyuren akides di řehna nsen, war ssinen x walu.  
\v 12 Řami \add din\add* iqeddem tiɣarṣa, issekk Abcalum \add ɛawed\add* ɣar Axitufil, zi Jilu, wenni d amcawar n Dawud, zi tendint nnes, zi Jilu. \add Ammu\add* i tedweř tmeɛmuč tmeqqar uca immarni řgens \add i iǧan\add* ɣar Abcalum.   
\b  
\m  
\s1 Arweř n Dawud zi Abcalum  
\m
\v 13 \add Xenni\add* dd-yusa ijj n ureqqas ɣar Dawud, inna: “Uř n \add kuř\add* aryaz \add idweř\add* ak-d Abcalum!”  
\v 14 \add Xenni\add* inna Dawud i marra imsexxaren nnes, inni tuɣa ɣares iǧan di Urcalim: “Kkarem, ad narweř, maɣar war ittɣimi ɣarneɣ uřa d ijjen nni i ɣa injem zzat i wudem n Abcalum. Deɣyam deg wuffuɣ niɣ netta ad iqeǧeb ad xaneɣ iḥart, ad dayneɣ igg tuɛeffna uca ad iwwet tandint-a s řeqḍeɛ n ssif.”  
\v 15 \add Xenni\add* nnan imsexxaren n ujeǧid i ujeǧid: “Xzar, imsexxaren nnec \add ad ggen\add* ɛlaḥsab marra min ɣa yixḍar sidi inu ajeǧid.”  
\v 16 Ammu i iffeɣ ujeǧid \add zi tendint\add*, ak-d marra taddart nnes deg iṣuraf nnes. Ajeǧid ijja ɛecra n tiyya maḥend ad ḥḍant taddart.  
\v 17 \add Umi\add* dd-iffeɣ ujeǧid \add zi tendint\add* ak-d marra řgens nnes deg iṣuraf nnes, qqimen nitni bedden ɣar řaggʷaj.  
\v 18 Marra imsexxaren ɛdun xas uřa d iɛessasen n arrimet nnes marra, u marra ireqqasen nnes n tazřa. Uřa d marra ayt n Jat, setta-mya n yeryazen nni dd-yusin deg iṣuraf nnes zi Jat, aqa kkin zzat i wudem n ujeǧid. \x ◘ \xo 15:18 \xt 2 Ṣm. 8:18; 1 Ij. 1:38; 1 Im. 18:17\x*   
\m
\v 19 \add Xenni\add* inna ujeǧid i Ittay, wenni zeg ayt n Jat: “Mayemmi texsed uřa d cek ad tuyured akidneɣ? Ɛqeb u qqim ɣar ujeǧid, maɣar cek d ijj n ubarrani, aqa cek beɛda tᵉttwassuffɣed zi temmurt nnec.  
\v 20 Iḍennaḍ i dd-tusid cek. Ma necc ad cek awyeɣ akidneɣ ass-a ḥima ad dd-teffɣed, \add umi\add* i ɣa uyureɣ necc mani ma i ttwariɣ izemmar ad řaḥeɣ. Ɛqeb, awi-dd akidek aytmac. Ad kidek tiři tmexsiwt icewwaren d řaman.”  
\v 21 \add Maca\add* Ittay yarra-dd x ujeǧid, inna: “\add S tidett am\add* iddar SIDI u iddar sidi inu ajeǧid, deg wemcan mani ɣa yiři sidi inu ajeǧid, ma immut niɣ iddar, dinni i ɣa yiři uřa d amsexxar nnec!”  
\v 22 \add Xenni\add* inna Dawud i Ittay: “Uyur \add xenni\add*, ekk-dd!” Ikka xas Ittay, wenni iǧan zeg ayt n Jat, ak-d marra iryazen nnes d iḥenjiren i ɣares \add iǧan\add*.  
\v 23 Marra temmurt tru umi ikka řgens. Ajeǧid iẓwa tiɣzart n Qidrun uřa d marra řgens iẓwa, \add ṭṭfen\add* abrid ɣar řexřa. \x ◘ \xo 15:23 \xt Yḥ. 18:1\x*   
\m
\v 24 Aqa din uřa d Ṣaduq d marra Ilawiyyen inni yarbun Ttabut n Řɛahd akides. Nitni ssarsen Ttabut n AREBBI u Abyatar igeɛɛed \add din\add* ařami iqfeř uɛeddu n marra řgens zi tendint.  
\v 25 \add Xenni\add* inna ujeǧid i Ṣaduq: “Arr Ttabut n AREBBI ɣar tendint. Mařa necc ufiɣ arḍa zzat i tiṭṭawin n SIDI, xenni Netta ad ayi yarr \add ɣar da\add*, ad ayi yarr ad ẓarɣ \add Ttabut\add* ɛawed uřa d Tazeddiɣt.  
\v 26 \add Maca\add* mařa Netta ad yini: ‘Cek war d ayi dd-tusid x řxaḍar!’, aqa ayi da, ejj i-t ad kidi igg min iǧan d lemliḥ di tiṭṭawin nnes.”   
\m
\v 27 Yarenni inna ujeǧid i ukehhan Ṣaduq: “Ma war teǧid cek d amwařaw? Ɛqeb di řehna ɣar temmurt nnec d tnayen n iḥenjiren nwem akidwem: mmic Aximaɛaṣ, d Yunatan, mmis n Abyatar. \f ◼ \fr 15:27 \ft \+fk amwařaw\ft  - d wenni ittwařan min innufaren s tirja niɣ s tmeẓra.\f*  
\v 28 Xzar, necc ad rajiɣ di řexřa ɣar manis ẓekkwan x \add L’Urdun\add*, ař dd ɣa tas tebrat zzaywem ɣari.”  
\v 29 \add Xas uca\add* yiwyi Ṣaduq ak-d Abyatar Ttabut n AREBBI ɣar Urcalim uca qqimen dinni.   
\m
\v 30 Dawud igeɛɛed tasawent n \add wedrar n\add* Zzitun. Iru am dd-igeɛɛed. Tuɣa azeǧif nnes ireḥḥef, yuyur x iḍaren s řeḥfa. Uřa d marra řgens i ɣares, \add kuř\add* aryaz \add zzayes\add* ireḥḥef azeǧif nnes, uca geɛɛden nitni, run am geɛɛden.  
\v 31 \add Xenni\add* ḥajan as i Dawud, nnan: “Axitufil tuɣa-t jar inni iggin tameɛmuč x uɣezdis n Abcalum.” Uca inna Dawud: “\add A\add* SIDI, sbeṭṭeř ccwar n Axitufil.”   
\m
\v 32 \add Řami\add* Dawud yiweḍ ɣar tqiccet n wedrar, mani ttnuman ad sejden zzat i AREBBI, xzar, \add yusa-dd\add* Ḥucay, Ayarki, i umsagar akides s warruḍ icarrgen u s ucař x uzeǧif nnes. \x ◘ \xo 15:32 \xt Yac. 16:2\x*  
\v 33 Dawud inna as: “Mařa cek teẓwid akidi, ad xafi tiřid d ddqeř.  
\v 34 Mařa maca cek tɛeqbed ɣar tendint, ad tinid i Abcalum: ‘Necc ad iřiɣ d amsexxar nnec, \add a\add* ajeǧid! Tuɣa ayi zic d amsexxar n babac, řexxu maca ad iřiɣ d amsexxar nnec!’, \add xenni\add* tzemmared ad tbeḍřed ccwar n Axitufil.  
\v 35 Ma war dinni ɣarek ikehhanen Ṣaduq d Abyatar? Ad imsar ad tɛawded marra min ɣa tesřed zi taddart n ujeǧid i ikehhanen Ṣaduq d Abyatar.  
\v 36 Aqa nitni ɣarsen dinni tnayen n iḥenjiren nsen, Aximaɛaṣ, mmis n Ṣaduq, d Yunatan, mmis n Abyatar. Ad ayi dd-tessiwḍem marra awař i tesřim \add zzaysen\add*.”   
\m
\v 37 Uca Ḥucay, ameddukkeř n Dawud, yudef ɣar tendint uca uřa d Abcalum yudef ɣar Urcalim.   
\b  
\b  
\m  
\c 16
\s1 Amsagar n Dawud ak-d Ṣiba  
\m
\v 1 \add Umi\add* iɛdu Dawud cwayt x tqiccet n wedrar, iffeɣ Ṣiba, amsexxar n Mafibucat, i umsagar akides s ict n tyuya n yeɣyař bardɛen, \add issars\add* xasen mitayen n iɣrumen, mya n iɣrumen n zzbib u mya n tini n unebdu d ict n tecyart \add dayes\add* binu. \f ◼ \fr 16:1 \ft \+fk tini n unebdu\ft  - niɣ ‘fruta n unebdu’.\f*  
\v 2 Inna ujeǧid i Ṣiba: “Min texsed ad tegged s uya?” Inna Ṣiba: “Iɣyař i taddart n ujeǧid ḥima ad xasen nyen, u aɣrum d tini n unebdu i imsexxaren, ḥima ad ccen, u binu i yinni yuḥřen di řexřa, ḥima ad swen.”  
\v 3 \add Xenni\add* inna ujeǧid: “Mani iǧa mmis n sidi nnec?” Inna Ṣiba i ujeǧid: “Xzar, netta iqqim di Urcalim, maɣar netta inna: ‘Ass-a taddart n Israil ad ayi dd-tarr tageldit n baba.’” \x ◘ \xo 16:3 \xt 2 Ṣm. 19:27\x*  
\v 4 \add Xenni\add* inna ujeǧid i Ṣiba: “Xzar, marra min \add iǧan\add* n Mafibucat, ad yiři nnec!” Ṣiba inna: “Necc bendqeɣ, mři ufiɣ arḍa di tiṭṭawin nnec, \add a\add* sidi inu ajeǧid!”   
\b  
\m  
\s1 Dawud ittwanɛeř zi Cimɛi  
\m
\v 5 \add Umi\add* dd-yusa ujeǧid Dawud ɣar Baxurim, iẓra ijj n weryaz iffeɣ-dd ssenni zi řaǧ n taddart n Cawul. Qqaren as Cimɛi, mmis n Jira. Netta iggur am ineɛɛeř. \x ◘ \xo 16:5 \xt 1 Ij. 2:8\x*  
\v 6 Netta iḥejjar Dawud d marra imsexxaren n ujeǧid Dawud s yeẓra, \add am\add* ibedd řgens marra d marra ayt n bu-teɣruḍt zzates ɣar yefus d uzeřmaḍ.  
\v 7 Ammu i iqqar Cimɛi am t ineɛɛeř: “Aggʷej, aggʷej, cek, aryaz n \add usizzeř n\add* idammen d weryaz i war isekkwin!  
\v 8 SIDI issiweḍ xak marra idammen n taddart n Cawul wenni deg wemcan nnes i tḥekmed. SIDI iwca tageldit deg ifassen n mmic Abcalum. Xzar \add man aya iffeɣ-dd\add* zi tuɛeffna nnec umi cek d ijj n weryaz n \add usizzeř n\add* idammen.”  
\v 9 \add Xenni\add* inna Abicay, mmis n Ṣaruya, i ujeǧid: “Mayemmi ɣa inɛeř weqzin-a immuten, sidi inu ajeǧid? Ejj ayi ad din ẓwiɣ, ad as qesseɣ azeǧif.” \x ◘ \xo 16:9 \xt 1 Ṣm. 24:15; 2 Ṣm. 9:8\x*  
\v 10 \add Maca\add* ajeǧid inna: “Min din jar ayi d kenniw, arraw n Ṣaruya? Aqa netta inɛeř, umi d as inna SIDI: ‘Nɛeř Dawud!’ Man wen izemmaren \add xenni\add* ad yini: ‘Mayemmi i teggid aya?’”  
\v 11 Dawud yarni inna i Abicay d marra imsexxaren nnes: “Xzarem, mmi i dd-iffɣen zi ddat inu, yarezzu ad ayi ineɣ. Mahu xenni řexxu aryaz-a zeg ayt n Binyamin? Jjem t ad inɛeř, minzi SIDI i d as t innan.  
\v 12 Ad taɣ SIDI ad ittwařa tamara inu uca ad ayi dd-yarr SIDI taṣebḥant deg wemcan n nneɛřet nnes n wass-a.”  
\v 13 Dawud ak-d yeryazen nnes ṭṭfen abrid u Cimɛi yuyur arendad nnes ɣar uɣezdis nneɣni n tewrirt, am ineɛɛeř u ittḥejjar \add Dawud\add* s yeẓra uca igga taɛejjajt ad tḍuw.  
\v 14 Yiweḍ-dd ujeǧid ak-d marra řgens i ɣares ɣar Ayafim. Dinni izemmar ad yarr nnefs \add ɛawed\add*.   
\b  
\m  
\s1 Ḥucay d Axitufil ak-d Abcalum  
\m
\v 15 Abcalum ak-d marra řgens, iryazen n Israil, usin-dd ɣar Urcalim u Axitufil tuɣa-t ɣares.  
\v 16 Umi i dd-yusa Ḥucay, Ayarki, ameddukkeř n Dawud, ɣar Abcalum, imsar belli Ḥucay inna i Abcalum: “Tudart i ujeǧid, tudart i ujeǧid!”  
\v 17 Abcalum inna i Ḥucay: “Ma d man aya \add xenni\add* d \add ijj n wescan n\add* tmexsiwt icewwaren i umeddukkeř nnec? Mayemmi war triḥed ak-d umeddukkeř nnec?”  
\v 18 Ḥucay inna i Abcalum: “Lla, necc ad iřiɣ ɣar wenni ittwafarzen zi SIDI u \add zi\add* marra řgens-a u \add zi\add* marra iryazen n Israil, u necc ad ɣares qqimeɣ.  
\v 19 I umi ɣa sexxareɣ xenni? Ma war ittiři zzat i wudem n mmis? Am mammec necc xedmeɣ zzat i wudem n babac, ammu i ɣa iřiɣ zzat i wudem nnec.”   
\m
\v 20 Abcalum inna i Axitufil: “Wcem \add aneɣ\add* ccwar, min ɣa negg?”  
\v 21 Axitufil inna i Abcalum: “Adef ɣar tiyya n babac tinni ijja awarni as ḥima ad ḥḍant taddart. \add Ammu\add* i ɣa iseř marra Israil, aqa cek tessarzged ixef nnec ɣar babac uca ad ttwassjehden ifassen n marra inni akidek \add iǧan\add*.”  
\v 22 Wtin i Abcalum ict n tqiḍunt x tzeqqa u Abcalum yudef ɣar tiyya n babas zzat i tiṭṭawin n marra Israil.  
\v 23 Deg wussan nni ittwaḥseb ccwar n Axitufil axmi \add ijjen\add* yarezzu awař n AREBBI. Ammu \add i yeǧa\add* s marra ccwar n Axitufil, am ɣar Dawud am ɣar Abcalum.   
\b  
\b  
\m  
\c 17
\s1 Abeṭṭeř n cwar n Axitufil  
\m
\v 1 Axitufil inna i Abcalum: “Ejj ayi ad farzeɣ tenɛac-ařef n yeryazen, ad sswejdeɣ ixef inu ḥima ad ḍfareɣ Dawud ǧiřet-a.  
\v 2 \add Xenni\add* necc ad xas hejmeɣ, \add mintra\add* ifassen nnes \add ɛad\add* uḥřen u ḍeɛfen. Ad t ssiggʷideɣ u marra řgens i ɣares \add iǧan\add* ad yarweř. \add Xenni\add* necc ad nɣeɣ ajeǧid, netta waha.  
\v 3 Ad ɣarek dd-arreɣ marra řgens. \add Řmewt n\add* weryaz i x tarezzud \add aqa-t\add* am wedwař n yewdan marra, řgens \add ad t iqbeř,\add* ad tiři řehna.”  
\v 4 Tuɣa aya d ijj n wawař nican di tiṭṭawin n Abcalum u di tiṭṭawin n marra imɣaren n Israil.   
\m
\v 5 \add Maca\add* inna Abcalum: “Řaɣat uřa i Ḥucay, Ayarki. Ejj aneɣ ad ɣares nseř ɛawed min ɣa yini.”  
\v 6 Umi dd-yudef Ḥucay, issiweř Abcalum akides, inna: “Ammu i issiweř Axitufil. Ma ad negg ɛlaḥsab awař nnes? Mařa war iǧi ammu, \add xenni\add* siweř cek!”  
\v 7 \add Xenni\add* inna Ḥucay i Abcalum: “Twařat-a ccwar nni iwcin Axitufil war iǧi mliḥ.”  
\v 8 \add Yarni\add* Ḥucay inna: “Cek tessned aqa babac d yeryazen nnes, nitni d ayt n bu-teɣruḍt, u aqa řeɛmar nsen yarzeg am yijj n ddub di řexřa, wenni umi ittwacar wenjuɣ. Babac d ijj n weryaz aɛeskari u netta war ittnusi ak-d řgens.  
\v 9 Aqa řexxu innuffar deg ijj zeg ifran niɣ deg ijj zeg imucan n tnuffra. Mařa ɣar umezwaru wḍan ca zzaysen, \add xenni\add* marra wi t ɣa isřen, ad yini: ‘Aqa din ict n tecti di řgens nni iḍfaren Abcalum.’  
\v 10 \add Xenni\add* ɛad wenni dd-ixeřqen i umenɣi, wenni uř nnes am wuř n ijj n weyrad, ad ifceř deɣya, maɣar marra Israil issen aqa babac d ijj n bu-teɣřuḍt u ɣares ayt n umenɣi.  
\v 11 S uyenni ad ac ssecneɣ ad tessmuned deɣya marra Israil zi Dan ař Bi’r-Sebɛa, ijj n ubarru aṭṭas am yijdi ɣar tma n řebḥar, u cek ad kidsen teffɣed ɣar umenɣi.  
\v 12 \add Xenni\add* neccin ad xas nehjem deg ijj zeg imucan n tnuffra mani ɣa ittwaf. Ad xas nehjem am iweṭṭa nnda x temmurt. War ittɣimi uřa d ijjen zzayes u zi marra iryazen i ɣares iǧan.  
\v 13 Mařa netta ad issmun ixef nnes di ca n tendint, marra Israil ad kkaren ad awyen iseɣwan ɣar tendint nni, ad tt njarr di teɣzurt ařami war zzayes ittwaf uřa d ijj n weẓru ɛad.”   
\m
\v 14 \add Xenni\add* inna Abcalum uřa d marra iryazen n Israil: “Ccwar n Ayarki Ḥucay iḥřa x ccwar n Axitufil.” Aqa SIDI tuɣa yumur ad beḍřen ccwar lemliḥ n Axitufil, ḥima SIDI ad yawi tuɛeffna x Abcalum.   
\b  
\m  
\s1 Dawud iruḥ ɣar Maḥanayim  
\m
\v 15 Inna Ḥucay i ikehhanen Ṣaduq d Abyatar: “Ta d ta icawar Axitufil i Abcalum d imɣaren n Israil, maca d ta d ta ixef weṣṣiɣ necc.  
\v 16 \add Xenni\add* řexxu, sekk deɣya \add ijj n ureqqas\add* maḥend ad ixebbar i Dawud, ad yini: “War sens ǧiřet-a deg imucan n uẓekkwu n řexřa. Ẓwa deɣya, niɣ ad ittwaṣarḍ ujeǧid d marra řgens i ɣares \add iǧan\add*.”  
\v 17 Maca Yunatan d Aximaɛaṣ qqimen bedden ɣar tařa n Rujal. Ict n tayya tuyur dinni, tḥaja asen tt. Nitni uyuren u ḥajan tt i ujeǧid Dawud. Tuɣa-ten war zemmaren ad adfen ɣar tendint, umi ittxeṣṣa war ten ẓarren \add iwdan\add*.  
\v 18 \add Waxxa amenni\add* ijj n umsexxar iẓra i-ten uca iḥaja t i Abcalum. \add Maca\add* ina s tnayen idsen uzzřen, usin-dd ɣar taddart n ijj n weryaz di Baxurim wenni tuɣa ɣar iǧa ijj n wanu di řemraḥ. Nitni ḍrin dayes.  
\v 19 Tamɣart teksi tazarbeč uca tessars i-tt x uqemmum n wanu uca tareyyec xas iwzan i ittwaqeccaren n imendi. \add Ammu\add* i war dd-tbin tmesřact.  
\v 20 \add Řami\add* imsexxaren n Abcalum usin-dd ɣar temɣart di taddart, sseqsan tt: “Mani iǧa Aximaɛaṣ d Yunatan?” Tamɣart tarra-dd xasen: “Nitni ẓwan tiɣzart nni.” \add Xenni\add* ffɣen imsexxaren nni, arzun, war \add ten\add* ufin. \add Xenni\add* ɛeqben ɣar Urcalim.   
\m
\v 21 Awarni umi tuɣa nitni uyuren, imsar, nitni geɛɛden zeg wanu, uyuren, xebbaren aya i ujeǧid Dawud. Nitni nnan i Dawud: “Kkarem, ẓwam aman deɣya, maɣar ta d ta d ccwar i xawem igga Axitufil.”   
\m
\v 22 Ikkar Dawud ak-d marra řgens i ɣares iǧan u nitni ẓwan L’Urdun. Ɣar tfawt n tuffut n wass, tuɣa war din ɛad uřa d ijjen war iẓwi L’Urdun.  
\v 23 \add Umi\add* Axitufil iẓra, aqa ccwar nnes ittwabeṭṭeř, ibardeɛ netta i weɣyuř nnes, ikkar, yuyur ɣar taddart nnes di tendint nnes. Netta yumur i taddart nnes, \add xenni\add* yuyeř ixef nnes. \add Ammu\add* i immut u ittwanḍeř deg wenḍeř n babas.   
\m
\v 24 Dawud yiweḍ ɣar Maḥanayim, u Abcalum iẓwa L’Urdun, netta d marra iryazen n Israil akides.  
\v 25 Abcalum tuɣa igga Ɛamasa x řɛeskar deg wemcan n Yuwab. Ɛamasa tuɣa d mmis n ijj n weryaz qqaren as Yitra, ijj n weryaz zi Israil, wenni tuɣa yudfen x Abijayil, yeǧis n Naḥac, učmas n Ṣaruya, yemmas n Yuwab.  
\v 26 Israil d Abcalum wtin iqiḍan nsen di temmurt n Jilɛad.   
\m
\v 27 Umi dd-yusa Dawud ɣar Maḥanayim, imsar, aqa Cubi, mmis n Naḥac, zi Rabba, zeg ayt n Ɛammun, d Maxir, mmis n Ɛammiyil zi Lu-Dabar, d Barzilay, Ajilɛadi zi Rujalim \add iwyen as-dd marra man aya\add*: \x ◘ \xo 17:27 \xt 2 Ṣm. 19:31, 32; 1 Ij. 2:7\x*  
\v 28 ifarracen d ṭṭbaṣi d iqdiḥen n třaxt d irden d imendi d waren, \add aqa\add* řeḥbub qřan, uca uřa d ibawen d řeɛdes, \add aqa\add* \add uřa d nitni\add* qřan,  
\v 29 d tamment d ddhen d wuǧi d trussi n tfunasin. Nitni iwyen marra man aya ɣar Dawud d řgens i ɣares iǧan maḥend ad ccen. Maɣar nnan: “Řgens iǧuẓ, iheyyef, iffud \add din\add* di řexřa.”   
\b  
\b  
\m  
\c 18
\s1 Aɣelleb x Abcalum d řmewt nnes  
\m
\v 1 Isedd Dawud řgens nni tuɣa ɣares iǧan u igga xasen imeqqranen x wařef d imeqqranen x mya.  
\v 2 Dawud issekk řgens. Ict n tuřut zzaysen sadu ufus n Yuwab, ict n ttuřut sadu ufus n Abicay, mmis n Ṣaruya, umas n Yuwab, d ict n tuřut sadu afus n Ittay, zi Jat. Inna ujeǧid i řgens: “Uřa d necc ad akidwem ffɣeɣ \add ɣar umenɣi\add*.”  
\v 3 \add Maca\add* řgens inna: “Cek war kidneɣ teffɣeḍ ca \add ɣar umenɣi\add*, maɣar mařa neccin narweř s tidett, war kidneɣ řehhin. Mařa azyen zzayneɣ immut, war kidneɣ řehhin. Maɣar cek \add řexxu\add* tsekkwʷid am ɛecra n řuřuf zzayneɣ. S uyenni řexxu mlih, mařa cek ad aneɣ tewced afus zi tendint.”  
\v 4 \add Xenni\add* inna asen ujeǧid: “Necc ad ggeɣ min tᵉttwařam mliḥ di tiṭṭawin nwem!” Ajeǧid ibedd ɣar tewwart \add n tendint\add* u marra řgens iffeɣ s řmyawat d řuřuf.  
\v 5 Yumur ujeǧid i Yuwab, Abicay d Ittay: “Egg s uḥaweř ak-d uḥudri, ak-d Abcalum, di ṭṭweɛ inu.” Marra řgens isřa i ujeǧid am yumur marra imeqqranen x Abcalum.   
\m
\v 6 Řgens iffeɣ ɣar iyyar, ɣar umsagar ak-d Israil. Amenɣi ikkar deg wezɣar n Ifrayim. \f ◼ \fr 18:6 \ft \+fk azɣar\ft  - niɣ ‘řɣabet’ niɣ ‘tazgant’.\f*  
\v 7 Ttwaɣellben din \add iryazen n\add* řgens n Israil zzat i wudem n imsexxaren n Dawud. Deg wass nni temsar din ict n tecti tameqqrant \add ařami wḍan\add* ɛicrin-ařef \add n yeryazen\add*.  
\v 8 Amenɣi iffeɣ ssenni di marra jjwayeh. Deg wass nni isarḍ wezɣar \add iryazen\add* zi řgens ktar zeg inni isarḍ ssif.   
\m
\v 9 Imsar Abcalum ibedd tiṭṭ di tiṭṭ ak-d imsexxaren n Dawud. Abcalum inya x ijj n userdun. Umi aserdun yuyur sadu řefruɛ imcubbcen n yict n tcejjart n yigg ameqqran, innuɣ netta s uzeǧif nnes di tcejjart n yigg ařami iqqim ittennuyeř jar ujenna d temmurt d userdun yuyur swadday nnes.  
\v 10 Ijj n weryaz iẓra i-t, iḥaja t i Yuwab, inna: “Xzar, necc ẓriɣ Abcalum yuyeř ɣar ict n tcejjart n yigg.”  
\v 11 Inna Yuwab i weryaz i d as iḥajan aya: “Xzar, cek teẓrid \add t\add*, mayemmi war t teẓwiḍed ca dinni ɣar temmurt? \add Xenni iři\add* necc ad ac wceɣ ɛecra n \add uqiyyat n\add* nnuqart d ijj n webyas!”  
\v 12 Inna weryaz i Yuwab: “War wezzneɣ uřa d ařef n \add uqiyyat n\add* nnuqart deg ifassen inu, war sswiẓẓiḍeɣ afus inu x mmis n ujeǧid, maɣar ajeǧid yumur i cek d Abicay d Ittay deg imezzuɣen n řgens, inna: ‘Ejj kuř ijj ad iḥḍa x uḥuḍri Abcalum!’  
\v 13 Mařa necc ad ggeɣ s řɣecc ak-d řeɛmar nnes - aqa i ujeǧid war teqqim uřa d ict n řḥajjet txemmeř - xenni cek ad xafi tekkared.”  
\v 14 \add Xenni\add* inna Yuwab: “Necc war xak ttrajiɣ.” U netta iksi třata n lansat, ijju as tent deg wuř n Abcalum, am netta ɛad yuyeř iddar di řwesṭ n tcejjart n yigg.  
\v 15 Ɛecra n imsexxaren inni d as yarebbun řesnaḥ i Yuwab, nnḍen as uca wtin Abcalum, nɣin t.  
\v 16 \add Xenni\add* isuḍ Yuwab deg uyicc n icarri uca iɛqeb-dd řgens marra zeg weḍfar n Israil, minzi Yuwab ixs ad iḥaweř x řgens.  
\v 17 Nitni ksin Abcalum, nḍaren t deg wezɣar di tesraft tuǧeɣ u ssarbun xas ijj n uɛurric n yeẓra imɣar aṭṭas. Marra Israil iṭṭef di tarewřa, \add kuř\add* aryaz ɣar uqiḍun nnes.  
\v 18 Umi tuɣa iddar, iksi Abcalum i yixef nnes ijj n umayḍu \add iqeddsen\add*, issbedd i-t di Teɣzurt n Ujeǧid, minzi inna: “Necc war ɣari bu mmi i ɣa isseɛqeř isem inu.” Netta iřaɣa as i umayḍu nni s yisem nnes. Ař ass-a qqaren as \add i umayḍu nni\add* ‘afus n Abcalum’.   
\m
\v 19 \add Xenni\add* inna Aximaɛaṣ, mmis n Ṣaduq: “Ejj ayi ad azzřeɣ ɣar ujeǧid ad as ssiwḍeɣ řexbar aṣebḥan, aqa SIDI iḥḍa t zeg ifassen n řɛedyan nnes.”  
\v 20 \add Maca\add* Yuwab inna as: “Ass-a war tessiwḍed ca řexbar aṣebḥan, \add maca\add* deg ijj n wass nneɣni \add tzemmared\add* ad tessiwḍed řexbar aṣebḥan. Ass-a war tessiwḍed areqqas d aṣebḥan maɣar mmis n ujeǧid immut.”  
\v 21 Inna Yuwab i Ukuci: “Uyur, ini i ujeǧid, min teẓrid cek!” Akuci ibendeq zzat i Yuwab uca \add xenni\add* yuzzeř.  
\v 22 \add Xenni\add* Aximaɛaṣ, mmis n Ṣaduq, inna ict n twařa nneɣnit i Yuwab: “Ad dd-yas wi ixsen, ejj ayi uřa d necc ad azzřeɣ awarni i Ukuci!” Inna Yuwab: “Mayemmi texsed \add ɛad\add* ad tazzřed, a mmi? War ittwaf \add ɛad\add* areqqas d aṣebḥan i cek, \add maḥend ad t tessiwḍed\add*!”  
\v 23 \add Inna\add*: “Ad dd-yas wi ixsen, necc xseɣ ad \add din\add* azzřeɣ.” \add Xenni\add* inna as Yuwab: “Azzeř!” Uca Aximaɛaṣ yuzzeř x webrid n udewwar \add n L’Urdun\add* uca izzar netta Akuci.   
\m
\v 24 Dawud iqqim jar tnayen n tewwura \add n tendint\add*. Aɛessas igeɛɛed tazeqqa n tewwart \add i iǧan\add* ɣar řḥiḍ, issgeɛɛed tamuɣři nnes, iceyyeɛ, iẓra ijj n weryaz ittazzeř, netta weḥḥdes.  
\v 25 Aɛessas iřaɣa, inna i-tt i ujeǧid. Ajeǧid inna: “Mařa netta weḥḥdes, xenni ad yaweḍ ijj n řexbar d aṣebḥan!” Yarni iqarreb-dd weryaz.  
\v 26 \add Xenni\add* iẓra uɛessas \add ɛad\add* ijj n weryaz nneɣni ittazzeř uca iřaɣa ɣar uɛessas n tewwart, inna: “Xzar, \add ittazzeř din\add* ɛad ijj n weryaz nneɣni, uřa d netta weḥḥdes.” Ajeǧid inna: “Uřa d netta ad yaweḍ ijj n řexbar d aṣebḥan.”  
\v 27 Aɛessas inna \add ɛawed\add*: “Necc ttwařiɣ amezwaru iggur am Aximaɛaṣ, mmis n Ṣaduq.” Inna ujeǧid: “Wa d ijj n weryaz iṣbeḥ, netta ad dd-yas s yijj n ureqqas d aṣebḥan.”  
\v 28 Aximaɛaṣ iřaɣa, inna i ujeǧid: “Řehna!” U netta ibendeq zzat i ujeǧid s uɣembub nnes ɣar temmurt, inna: “Ad ittwabarek SIDI, AREBBI nnec, wenni d ac isellmen iryazen nni igeɛɛden afus nsen x sidi inu ajeǧid.”  
\v 29 Inna ujeǧid: “Ma aḥudri, Abcalum, aqa-t mliḥ?” Inna Aximaɛaṣ: “Necc ẓriɣ ijj n ubarru d ameqqran umi Yuwab, amsexxar n ujeǧid, issekk amsexxar nnec, \add maca\add* necc war ssineɣ min \add imsaren\add*.”  
\v 30 Inna ujeǧid: “Ḥeyyed ɣar uɣezdis, bedd da!” U netta iḥeyyed ɣar uɣezdis, iqqim ibedd \add dinni\add*.  
\v 31 Uca xzar, yusa-dd uřa d Akuci. Akuci inna: “Xzar, ijj n řexbar d aṣebḥan i sidi inu, ajeǧid. SIDI iḥḍa cek zeg ufus n marra inni xak iɣewwɣen.”  
\v 32 \add Xenni\add* inna ujeǧid i Ukuci: “Ma aḥudri, Abcalum, aqa-t mliḥ?” Inna Ukuci: “Iři ad dewřen marra řɛedyan n sidi inu ajeǧid d marra inni xak iɣewwɣen maḥend ad cek ggen tuɛeffna am uḥuḍri.”   
\b  
\b  
\m  
\c 19
\s1 Dawud icḍen x Abcalum  
\m
\v 1 \add Xenni\add* innexřeɛ ujeǧid aṭṭas, igeɛɛed ɣar wexxam i iǧan sennej i tewwart, iru. Uca am ikka ssa d ssa, inna \add ammu\add*: “\add A\add* mmi Abcalum, \add a\add* mmi, \add a\add* mmi Abcalum! Iři necc mmuteɣ deg wemcan nnec, \add a\add* Abcalum, \add a\add* mmi, \add a\add* mmi!”  
\v 2 Nnan i Yuwab: “Xzar, ajeǧid ittru, ittecḍin x Abcalum.”  
\v 3 Deg wass nni idweř usenjem n marra řgens ɣar wecḍan, maɣar řgens isřa deg wass nni: “Ajeǧid icḍen x mmis.”  
\v 4 Deg wass nni yudef-dd řgens ɣar tendint am mammec ittḥama řgens i ittseḍḥa ixef nnes, xmi ttarekkʷařen zeg umenɣi.   
\m
\v 5 Ajeǧid tuɣa iřeḥḥef i uɣembub nnes, ittřaɣa ujeǧid s tmijja ijehden: “\add A\add* Mmi Abcalum, Abcalum, \add a\add* mmi, \add a\add* mmi!”  
\v 6 \add Xenni\add* yudef Yuwab ɣar ujeǧid di taddart, inna: “Cek ass-a tessḥecmed udem n marra imsexxaren nnec inni dd-ifekken ass-a řeɛmar nnec d řeɛmar n iḥenjiren nnec d tḥenjirin nnec uřa d řeɛmar n temɣarin nnec d řeɛmar n tiyya nnec,  
\v 7 umi texsed inni cek ittɛiffen u umi tɛiffed inni cek ittexsen. Maɣar cek tewcid aneɣ ass-a ad nessen, aqa ɣarek imeqqranen d imsexxaren war sekkwin walu. Iwa ass-a ssneɣ, mařa Abcalum iddar u neccin marra tuɣa nemmut, man aya ad yiři nican di tiṭṭawin nnec.  
\v 8 Xenni řexxu, kkar, ffeɣ ɣar barra, uca siweř ɣar wuř n imsexxaren nnec, maɣar necc ad ac jjaǧeɣ ɣar SIDI, mařa cek war teffiɣed ɣar barra, xenni ǧiřet-a war ittɣimi ad ɣarek issens uřa d ijj n weryaz. D man aya ad yiři mahu i cek x marra tuɛeffna i cek iřeqfen zi temẓi nnec ař iḍa.”  
\v 9 \add Xenni\add* ikkar ujeǧid, iqqim di tewwart n tendint. U nitni xebbaren marra řgens, nnan: “Xzar, ajeǧid iqqim di tewwart.” Uca yusa-dd marra řgens zzat i wudem n ujeǧid. \add Maca\add* Israil yarweř, \add kuř\add* aryaz ɣar iqiḍan nnes.   
\b  
\m  
\s1 Aɛqab n Dawud ɣar Urcalim  
\m
\v 10 Uca marra řgens, di marra tiqebbař n Israil, tuɣa ittemcubbec, nitni nnan: “Ajeǧid issenjem aneɣ zeg ufus n řɛedyan nneɣ u netta ifekk aneɣ zeg ufus n Ifilisṭiniyyen u řexxu yarweř zi temmurt zi ssibbet n Abcalum,  
\v 11 \add umi\add* Abcalum, wenni nedhen neccin \add d ajeǧid\add* xaneɣ, immut deg umenɣi. \add Xenni\add* řexxu, mayemmi tessusmem \add ammu\add* ḥima ad dd-tarrem ajeǧid ɛawed \add ɣar da\add*?”  
\v 12 \add Xenni\add* issekk ajeǧid Dawud \add ijj n ureqqas\add* ɣar ikehhanen Ṣaduq d Abyatar, inna: “Siweř ak-d imɣaren n Yahuda, ini: ‘Mayemmi texsem ad tiřim d ineggura ḥima ad tarrem ajeǧid ɣar taddart nnes?’ - \add minzi\add* awařen n marra Israil iwḍen ɣar ujeǧid di taddart nnes -  
\v 13 ‘Kenniw d aytma inu, kenniw d iɣsan inu d weysum inu. Mayemmi texsem xenni ad tiřim d ineggura i d ɣa yarren ajeǧid?’  
\v 14 Uca i Ɛamasa ad as tinim: ‘Ma war iǧi cek d iɣsan inu d aysum inu? Ejj AREBBI ad ayi igg ta d ta, mařa war tᵉttiřid d akumandar n řɛeskar deg wemcan n Yuwab zzat i wudem inu marra ussan.’” \x ◘ \xo 19:14 \xt 2 Ṣm. 17:25\x*  
\v 15 Ammu \add izemmar\add* Dawud ad ɣares dd-ijbedd uř n marra iryazen n Yahuda am \add uř\add* n ijj n weryaz u nitni ssekken ɣar ujeǧid nnan: “Ɛqeb, cek d marra imsexxaren nnec.”   
\m
\v 16 \add Xenni\add* iɛqeb-dd ujeǧid uca yiweḍ-dd ɣar L’Urdun, \add uca\add* \add ayt n\add* Yahuda usin-dd ɣar Jiljal i umsagar ak-d ujeǧid maḥend ad raḥen ad ɛawnen aẓekkʷi n ujeǧid x L’Urdun.  
\v 17 Uca Cimɛi, mmis n Jira, ijj zeg ayt n Binyamin zi Baxurim iksi deg uḍar nnes, ihwa ak-d yeryazen n Yahuda i umsagar ak-d ujeǧid Dawud. \x ◘ \xo 19:17 \xt 2 Ṣm. 16:5; 1 Ij. 2:8\x*  
\v 18 Tuɣa akides \add ɛawed\add* ařef n yeryazen zi Binyamin, uřa d Ṣiba, amsexxar n taddart n Cawul ak-d xemmesṭac n iḥenjiren nnes d ɛicrin n imsexxaren nnes akides. Nitni iwḍen ad ɛdun L’Urdun qbeř i dd ɣa yas \add dinni\add* ujeǧid.  
\v 19 Teẓwa tɣarrabut i useẓwi n taddart n ujeǧid u ḥima ad tegg min iǧan d lemliḥ di tiṭṭawin nnes. U Cimɛi, mmis n Jira, iwḍa \add s uɣembub nnes ɣar temmurt\add* zzat i wudem n ujeǧid, umi dd-iẓwa wanita L’Urdun,  
\v 20 u netta inna i ujeǧid: “Ejj sidi inu war d ayi iḥesseb řmuɛṣiyyet inu, ejj i-t war ittidar \add ɛad\add* deg ufaryeḍ i igga umsexxar nnec deg wass umi iffeɣ sidi inu ajeǧid zi Urcalim, ḥima ajeǧid war tt ikessi ammu ɣar wuř \add ḥima ad zzayi intaqem\add*.  
\v 21 Maɣar amsexxar nnec issen: Necc, \add wah,\add* necc xḍiɣ, \add maca\add* xzar, necc ass-a d amezwaru zi marra taddart n Yusuf i dd-ihwan, ḥima ad msagareɣ sidi inu ajeǧid.”   
\m
\v 22 \add Xenni\add* yarra-dd Abicay, mmis n Ṣaruya, inna: “Zeɛma war ittxeṣṣi Cimɛi ad immet x man aya? Aqa netta inɛeř amedhun n SIDI.”  
\v 23 \add Maca\add* Dawud inna: “Min jar ayi-dd akidwem, arraw n Ṣaruya, umi tdewřem ayi ass-a \add am\add* ijj n weɣrim? Ma ittxeṣṣa ad ittwaneɣ ass-a ca n ijj di Israil? Axmi necc war ssineɣ, aqa necc ass-a dewřeɣ d ajeǧid x Israil?”  
\v 24 Ajeǧid inna i Cimɛi: “Cek war tᵉttmettid ca!” Uca ajeǧid ijjuǧ as \add t\add*.   
\m
\v 25 Uřa d Mafibucat, mmis n Cawul, yusa-dd i umsagar ak-d ujeǧid. Netta tuɣa war issird iḍaren nnes, u war iḥeff acřaɣem nnes u war iṣebben arruḍ nnes zeg wass i di iffeɣ ujeǧid ař ass i di dd-iɛqeb netta di řehna.  
\v 26 Umi dd-yusa di Urcalim i umsagar ak-d ujeǧid, imsar, aqa inna as ujeǧid: “Mayemmi war kidi truḥed, Mafibucat?”  
\v 27 Netta inna as: “Sidi inu ajeǧid, amsexxar inu iɣdar ayi, maɣar amsexxar nnec inna: ‘Necc xseɣ ad bardɛeɣ i weɣyuř, ad xas nyeɣ, ad raḥeɣ ak-d ujeǧid!’, maɣar amsexxar nnec d aqejdaḥ.  
\v 28 Netta iceqqef deg umsexxar nnec ɣar sidi inu ajeǧid. \add Maca\add* sidi inu ajeǧid, am yijj n lmalak n AREBBI. Egg min iǧan d lemliḥ di tiṭṭawin nnec. \x ◘ \xo 19:28 \xt 2 Ṣm. 16:3\x*  
\v 29 Minzi marra taddart n baba tuɣa war teǧi mɣir iryazen imettinen i sidi inu ajeǧid. \add Waxxa amenni\add* cek tessɣimed amsexxar nnec ɣar yinni ittetten ɣar ṭṭabřa nnec! Min ɣari ɛad d tasɣart u i umi ɣa ttareɣ ɛad ktar ɣar ujeǧid?”  
\v 30 Ajeǧid inna as: “Mayemmi tessawařed ɛad ammu x tmesřayin nnec? Necc qqareɣ ac: Cek d Ṣiba, kenniw ad tebḍam tammurt.”  
\v 31 Inna Mafibucat i ujeǧid: “Netta izemmar ad tt iksi marra, maɣar sidi inu ajeǧid, aqa iɛqeb ɣar taddart nnes di řehna.”   
\m
\v 32 Barzillay, Ajilɛadi, ihwa zi Rujalim maḥend ad t iwc afus i ujeǧid ɣar uẓekkwu n L’Urdun, ḥima ad t issqebbeḍ \add ammu\add* x L’Urdun.  
\v 33 Barzillay tuɣa iwsar aṭṭas, ijj n weryaz n tmenyin n iseggʷusa. Netta tuɣa iksi ɣares ajeǧid umi t tuɣa di Maḥanayim, minzi netta tuɣa-t d ijj n weryaz ɣares agřa aṭṭas. \x ◘ \xo 19:33 \xt  2 Ṣm. 17:27-29; 1 Ij. 2:7\x*  
\v 34 Ajeǧid inna i Barzillay: “Ẓwa akidi. Necc ad cek ɣari ksiɣ di Urcalim.”  
\v 35 \add Maca\add* Barzillay inna i ujeǧid: “Mecḥař n wussan n iseggʷusa n tudart inu \add ɛad din\add* ařami ɣa ffɣeɣ ak-d ujeǧid ɣar Urcalim?  
\v 36 Ass-a necc ɣari tmenyin n iseggʷusa. Ma zemmareɣ ad farzeɣ \add ɛad\add* min iṣebḥen zi min war iḥřin? Ma izemmar umsexxar nnec ad iqqas min ɣa cceɣ d min ɣa sweɣ? Ma zemmareɣ ad sřeɣ ɛad i tmijja n imedyazen d tmedyazin? Mayemmi ɣa issedqeř umsexxar nnec ɛad x sidi inu ajeǧid?  
\v 37 Amsexxar nnec ad iẓwa L’Urdun ak-d ujeǧid mɣir cwayt. Mayemmi d ayi ɣa iwc ujeǧid tarebbaḥt-a?  
\v 38 Ejj amsexxar nnec ad iɛqeb ḥima ad mmteɣ di tendint inu, ɣar wenḍeř n baba d yemma. Xzar, aqa da amsexxar nnec Kimham! Ejj i-t ad iẓwa ak-d sidi inu ajeǧid. Egg as min tᵉttwařid mliḥ di tiṭṭawin nnec.”  
\v 39 \add Xenni\add* inna ujeǧid: “Kimham ad kidi iẓwa u min tᵉttwařid mliḥ di tiṭṭawin nnec, ad as t ggeɣ. Marra min zzayi tessutared, ad ac t ggeɣ.”   
\m
\v 40 \add Umi\add* iẓwa marra řgens L’Urdun, iẓwa uřa d ajeǧid. Ajeǧid issudem Barzillay, ibarek i-t. \add Xas uca\add* idweř netta ɣar temmurt nnes.   
\m
\v 41 Ajeǧid maca yarni iɛdu ɣar Jiljal u Kimham iɛdu akides. Marra řgens n Yahuda tuɣa isseɛdu ajeǧid, uřa d azyen n řgens n Israil.  
\v 42 U xzar, marra iryazen n Israil usin-dd ɣar ujeǧid, nnan i ujeǧid: “Mayemmi aytmatneɣ, iryazen n Yahuda, ucaren cek \add i neccin\add* u nedhen ajeǧid d taddart nnes řami tuɣa iẓwa L’Urdun d marra iryazen n Dawud akides?”  
\v 43 \add Xenni\add* arrin-dd marra iryazen n Yahuda x yeryazen n Israil: “Minzi ajeǧid itteɛna aneɣ-dd. Mayemmi txeyyqem x uya? Ma necca neccin zi \add macca n\add* ujeǧid niɣ yiwi-dd netta ict n tarzeft i neccin?”  
\v 44 Iryaz\add en\add* n Israil arrin-dd x yeryazen n Yahuda, nnan: “Neccin ɣarneɣ ɛecra n ifassen ɣar ujeǧid, uřa ak-d Dawud \add ɣarneɣ xenni\add* ktar xawem. Mayemmi d aneɣ tesseḥqarem? Ma war iǧi wawař nneɣ d amezwaru, maḥend ad narr ajeǧid nneɣ?” \add Uca\add* tuɣa awař n yeryazen n Yahuda ijhed x wawař n yeryazen n Israil.   
\b  
\b  
\m  
\c 20
\s1 Aɣewweɣ n Cabɛa  
\m
\v 1 Tuɣa din ijj n weryaz i war isekkwin, qqaren as Cabaɛ, mmis n Bikri, ijj n Ubinyamini. Netta isuḍ deg uyicc n icarri, inna: “Neccin war ɣarneɣ tasɣart di Dawud u neccin war ɣarneɣ řwart ak-d mmis n Yassa. \add Ejj\add* \add kuř\add* aryaz ad yuyur ɣar iqiḍan nnes, \add a\add* Israil!”  
\v 2 \add Xenni\add* iffeɣ kuř aryaz zi ḍeffar n Dawud, \add iruḥ\add* awarni i Cabaɛ, mmis n Bikri. \add Maca\add* iryazen n Yahuda qqimen řesqen ak-d ujeǧid nsen, zi L’Urdun ař Urcalim.   
\m
\v 3 \add Umi\add* yudef Dawud ɣar taddart nnes di Urcalim, iksi ujeǧid ɛecra n temɣarin, tiyya nnes tinni tuɣa ijja awarni as ḥima ad ḥḍant taddart. Netta igga i-tent deg ict n taddart tᵉttwaḥḍa u netta itthilla daysent, maca war ɣarsent yudif. Nitenti qqiment bellɛent ař ass n řmewt nsent, ddarent d tijjař.   
\m
\v 4 Inna ujeǧid \add ɛawed\add* i Ɛamasa: “Řaɣa-dd x yeryazen n Yahuda ad munen ɣari di třata n wussan, uca \add xenni\add* bedd cek da!”  
\v 5 Ɛamasa iffeɣ ḥima ad iřaɣa x Yahuda ad ssmunen, \add maca\add* netta iɛeṭṭeř x řweqt i tuɣa akides igga ujeǧid.  
\v 6 \add Xenni\add* inna Dawud i Abicay: “Řexxu ad aneɣ igg Cabaɛ, mmis n Bikri, tuɛeffna mahu x Abcalum. Ksi akidek imsexxaren n sidi u ḍfar i-t, ḥima netta war izemmar ad yaf i yixef nnes tineddam ifaryen uca ad iweddar zi tiṭṭawin nneɣ.”  
\v 7 Ffɣen yeryazen n Yuwab, \add uyuren\add* awarni as ak-d iɛessasen n arrimet d ireqqasen n tazřa d marra ayt n bu-teɣruḍt. Nitni ffɣen-dd zi Urcalim, ḥima ad ḍfaren Cabaɛ, mmis n Bikri.   
\m
\v 8 \add Umi\add* ten tuɣa ɣar weẓru ameqqran n Jibɛun, tuɣa Ɛamasa zzat i wudem nsen. Yuwab tuɣa ittḥezzam arruḍ nnes n umenɣi i yarḍ. Tuɣa xas ijj n uḥezzam ak-d ssif deg ufurru n weɣřaf i xas ittwaggen ɣar tejɛinna nnes. \add Umi\add* yuyur netta ɣar zzat, iwḍa as ssif \add zzayes\add*.  
\v 9 Inna Yuwab i Ɛamasa: “Aqa cek mliḥ, uma?” Icebbar Yuwab s ufus afusi di tmart n Ɛamasa ḥima ad t issudem.  
\v 10 Ɛamasa war iḥekkar i ssif i tuɣa deg ufus n Yuwab uca netta iřqef i-t zzayes deg uɛeddis uca ffɣen as-dd wadan ɣar temmurt. Netta immut břa ma iřqef i-t ict n twařa nneɣnit. U Yuwab ak-d umas Abicay iḍfar Cabaɛ, mmis n Bikri. \x ◘ \xo 20:10 \xt 1 Ij. 2:5\x*  
\v 11 Ijj n weryaz ibedd ɣares \add ɣar Ɛamasa\add*. \add Tuɣa netta\add* zeg imsexxaren n Yuwab, inna: “Ejj wenni ixḍaren Yuwab uřa d wenni iǧan ak-d Dawud, ad iḍfar Yuwab!” \f ◼ \fr 20:11 \ft \+fk ibedd ɣares\ft  - ixs ad yini ibedd ɣar arrimet n Amasa.\f*   
\m
\v 12 Ɛamasa maca tuɣa izzeř ittwanneḍ deg idammen nnes deg webrid ameqqran. \add Umi\add* iẓra aryaz nni, aqa marra řgens iqqim ibedd, ijarr netta Ɛamasa zeg webrid ɣar yeyyar u inḍar ijj n warruḍ tiwa nnes, minzi iẓra qaɛ wi ɣares dd-iwḍen, iqqim ittbedda.  
\v 13 Ařami tuɣa netta ittwaggʷej x webrid, ɛdun marra iryazen awarni i Yuwab, ḥima ad ḍfaren Cabaɛ, mmis n Bikri,  
\v 14 wenni tuɣa ikka x marra tiqebbař n Israil ɣar Abal u ɣar Bayt-Maɛka, ak-d marra Ibiriyyen nni ittwassmunen u ruḥen \add ɛawed\add* awarni as.  
\v 15 \add Ammu\add* dd-iwḍen nitni \add ɣar din\add* uca nnḍen-dd i \add Cabaɛ\add* di Abal-Bayt-Maɛka. Nitni ssefyen ijj n lbaraj x tendint u \add lbaraj\add* nni ibedd ɣar řḥiḍ n zzat \add i dd-innḍen i tendint\add*. Marra řgens i tuɣa ak-d Yuwab, ggin ad areddǧen řḥiḍ ḥima ad as ssɣeḍřen.   
\m
\v 16 \add Xenni\add* třaɣa ict n temɣart d tmiɣist zi tendin:t “Sřem, sřem, inim i Yuwab: ‘As-dd da, ades-dd, ařami zemmareɣ akidek ssiwřeɣ.’”  
\v 17 \add Umi\add* dd-yusa netta, yudes-dd ɣares, tenna temɣart: “Ma cek d Yuwab?” Netta inna: “D necc.” Tenna as nettat: “Seř ɣar wawařen n tayya nnec.” Netta inna: “Necc ttesřiɣ.”  
\v 18 \add Xenni\add* tenna: “Zic tuɣa ssiwřen di kuř amcan, nnan: ‘Ittxeṣṣa asen ad tt sseqsan nican di Abal!’, uca ammu i kemmřen nitni \add tamesřact nni\add* mliḥ.  
\v 19 Necc zeg inni n ayt n řehna u zeg imtiqqan di Israil, \add maca\add* cek texsed ad tenɣed ict n tendint, tenni d yemmas di Israil. Mayemmi ɣa tṣarḍed řwart n SIDI?”  
\v 20 Yuwab yarra-dd xas, inna: “Aya iggʷej xafi aqa necc ad ṣarḍeɣ u ad hedmeɣ!  
\v 21 Tamesřact war teǧi amenni. Maca ijj n weryaz zeg idurar n Ifrayim, qqaren as Cabɛa, mmis n Bikri, iksi afus nnes x ujeǧid, x Dawud. Netta waha ittxeṣṣa ad t tewcem, \add xenni\add* ad ḥeyydeɣ zi tendint.” Tenna temɣart i Yuwab: “Xzar, azeǧif nnes ad ac t-i-dd-immenḍar tiwa i řḥiḍ.”  
\v 22 Tusa-dd temɣart s tiɣit nnes ɣar marra řgens u nitni qessen azeǧif i Cabɛa, mmis n Bikri, nḍaren t i Yuwab. \add Xenni\add* isuḍ Yuwab deg uyicc n icarri u nitni bezzɛen ixef nsen, aggʷejen x tendint u \add kuř\add* aryaz \add yuyur\add* ɣar iqiḍan nnes u Yuwab iɛqeb ɣar Urcalim, ɣar ujeǧid.   
\b  
\m  
\s1 Imdebbaran imeqqranen n Dawud  
\m
\v 23 Yuwab \add ittwagg\add* d azeǧif x marra řɛeskar n Israil, u Banaya, mmis n Yahuyadaɛ, tuɣa x iɛessasen n arrimet u x ireqqasen n tazřa. \x ◘ \xo 20:23 \xt [2 Ṣm. 8:16-18; 1 Im. 18:15-17]\x*  
\v 24 Aduram \add ibedd\add* x ljizya u Yahucafaṭ, mmis n Axilud, \add tuɣa-t\add* d amarir n umezruy.  
\v 25 Ciwa tuɣa d amarir, u Ṣaduq d Abyatar tuɣa aten d ikehhanen.  
\v 26 Uřa d Ɛira zi Ya’ir tuɣa d akehhan n Dawud.   
\b  
\b  
\m  
\c 21
\s1 Ddeɛwet n ayt n Jibɛun ḍidd i Cawul  
\m
\v 1 Deg wussan n Dawud tuɣa din ijj n řaẓ, třata n iseggʷusa, aseggʷas awarni useggʷas. U Dawud yarzu udem n SIDI u SIDI inna: “\add D man aya\add* x Cawul u x idammen \add i iřeṣqen di\add* taddart \add nnes\add*, minzi netta inɣa ayt n Jibɛun.”  
\v 2 \add Xenni\add* iřaɣa-dd ujeǧid x ayt n Jibɛun, issiweř akidsen. Ayt n Jibɛun war \add dd-qqarṣen\add* ca zeg ayt n Israil, maca zi min \add ɛad\add* iqqimen zeg Imuriyyen. Ayt n Israil tuɣa jjuǧen asen, \add maca\add* Cawul tuɣa yarezzu ad ten iwwet deg wecḍar nnes i ayt n Israil d Yahuda. \x ◘ \xo 21:2 \xt Yac. 9:19\x*  
\v 3 Dawud inna i ayt n Jibɛun: “Min d awem i ɣa ggeɣ u s min zi ɣa ggeɣ aṣřaḥ, \add maḥend\add* ad tbarkem řwart n SIDI?”  
\v 4 Ayt n Jibɛun nnan as: “War d aneɣ icqi nnuqart niɣ d wureɣ zi Cawul niɣ zi taddart nnes. Ɛawed war d aneɣ dd-ikkar ad neneɣ ca n ijj di Israil.” U netta inna: “Min ɣa tinim, ad awem t ggeɣ.”  
\v 5 Nitni nnan i ujeǧid: “\add Icqa aneɣ\add* weryaz nni ixsen ad xaneɣ iqḍa u tuɣa inwa ad imḥa aɣimi nneɣ di marra tammurt n Israil.  
\v 6 Ad aneɣ mmewcen sebɛa n yeryazen zeg iḥenjiren nnes, ḥima ad ten ayřen zzat i SIDI di Jibɛa n Cawul, wenni ittwafarzen zi SIDI!” Uca ajeǧid inna: “Necc ad \add ten\add* wceɣ.”  
\v 7 \add Maca\add* ajeǧid issɛizz x Mafibucat, mmis n Yunatan, mmis n Cawul, di ṭṭweɛ n tjaǧit i SIDI, tenni \add tᵉttwagg\add* jar asen, jar Dawud d Yunatan, mmis n Cawul. \x ◘ \xo 21:7 \xt 1 Ṣm. 18:3; 20:15, 42; 23:18\x*   
\m
\v 8 Ajeǧid iksi tnayen n iḥenjiren n Riṣfa, yeǧis n Aya, i dd-turuw i Cawul, Armuni d Mafibucat, d xemsa n iḥenjiren n Mirab, yeǧis n Cawul, i dd-turuw i Ɛadriyil, mmis n Barzillay zi Maḥulay.  
\v 9 Netta iwca i-ten deg ifassen n ayt n Jibɛun inni ten ayřen x wedrar zzat i wudem n SIDI. Sebɛa nni wḍan deg ict n twařa u s ijj n webrid. Nitni ttwanɣen deg wussan n tmeyra, deg wussan imezwura, ɣar beddu n tmeyra n imendi.   
\m
\v 10 \add Xenni\add* teksi Riṣfa, yeǧis n Aya, ict n txancet tessu tt zzat i yixef nnes x ijj n jjarf. Zi beddu n tmeyra ař xasen dd-zeǧɛen waman zeg ujenna. Nettat war tejji ijḍaḍ n ujenna ad ɣarsen dd-asen s uziř uřa d řewḥuc n řexřa s ǧiřet.   
\m
\v 11 Ḥajan as i Dawud min tuɣa tegga Riṣfa, yeǧis n Aya, tayya n Cawul.  
\v 12 Iṭṭef Dawud abrid maḥend ad iksi zeg imezdaɣ n Yabic di Jilɛad iɣussan n Cawul d iɣussan n mmis Yunatan nni dd-kksen nitni zeg wazzaɣ n Bayt-San, mani ten yuyřen Ifilisṭiniyyen deg wass i di ɣeřben Ifilisṭiniyyen Cawul x \add idurar n\add* Jilbuɛa. \x ◘ \xo 21:12 \xt 1 Ṣm. 31:10-13\x*  
\v 13 Netta issgeɛɛed ssenni iɣsan n Cawul d iɣsan n mmis Yunatan. Nitni ssmunen ɛawed iɣsan n yinni ittwayřen.  
\v 14 Neḍřen iɣsan n Cawul d mmis Yunatan di temmurt n Binyamin di Ṣaylaɛ deg wenḍeř n babas Qis u nitni ggin marra min d asen yumur ujeǧid. Awarni man aya ijja AREBBI ad ittwasseṣřeḥ ixef nnes di ṭṭweɛ n temmurt s tẓaǧit \add nsen\add* yuǧɣen.   
\b  
\m  
\s1 Amenɣi ak-d ayt n Rafa  
\m
\v 15 Ifilisṭiniyyen mmenɣen ɛawed ak-d Israil. Dawud ihwa d imsexxaren nnes akides. Nitni mmenɣen ak-d Ifilisṭiniyyen uca idweř Dawud yuḥeř aṭṭas. \x ◘ \xo 21:15 \xt [1 Im. 20:4-8]\x*  
\v 16 Yicbi-Banub, ijj zeg iḥenjiren n Rafa, wenni lansa nnes tewzen teřt-mya ciqlu n nnḥas u \add wenni\add* tuɣa ibyes s yijj n \add ssif\add* n jdid, iṭṭɣiř as ad iwwet Dawud.  
\v 17 \add Maca\add* Abicay, mmis n Ṣaruya, iwca afus \add i Dawud\add*, iwta Afilisṭini, inɣa i-t. Xenni jjuǧen as yeryazen n Dawud, nnan: “Cek war akidneɣ teffɣed ɛad ɣar umenɣi, war iɛeddeř ad txesyid řefnar n Israil.”   
\m
\v 18 Awarni as imsar, aqa ikkar ɛawed umenɣi ak-d Ifilisṭiniyyen di Jub. Řexdenni Sabkay, Aḥucayi, iwta Saf, wenni d ijj zeg iḥenjiren n Rafa. \x ◘ \xo 21:18 \xt 1 Im. 20:4\x*   
\m
\v 19 Ɛawed tuɣa din umenɣi ak-d Ifilisṭiniyyen di Jub. Ilḥanan, mmis n Yaɛri-Arjim, zi Bayt-Laḥm, iɣřeb x \add učmas n\add* Julyat zi Jat. Akeccuḍ n lansa nnes igga am yijj n weɛmud n ukeccuḍ n uxeyyeḍ.   
\m
\v 20 Uca ikkar ɛawed umenɣi di Jat. Tuɣa din ijj n weryaz d azirar, s setta n iḍewḍan ɣar ifassen nnes u setta n tfednin ɣar iḍaren nnes, \add marra\add* řqedd nsen arebɛa u ɛicrin. Uřa d netta ittwaxřeq-dd i Rafa.  
\v 21 Netta istehza zi Israil, maca Yunatan, mmis n Cimɛa, umas n Dawud, iɣřeb xas.   
\m
\v 22 Arebɛa-ya ttwaxeřqen-dd di Rafa di Jat u nitni wḍan s ufus n Dawud u s ufus n imsexxaren nnes.   
\b  
\b  
\m  
\c 22
\s1 Izři n Dawud  
\m
\v 1 Dawud issiweř awařen n izři-ya i SIDI deg wass umi t ifekk SIDI zeg ufus n marra řɛedyan nnes u zeg ufus n Cawul. \x ◘ \xo 22:1 \xt [Izhd. 18]\x*  
\v 2 Netta inna:  
\b  
\m \qt “SIDI d Taṣḍart inu\qt*  
\m \qt d lburj inu d amfekki inu.\qt*   
\m
\v 3 \qt SIDI n Teṣḍart inu, ɣares arekkwařeɣ.\qt*  
\m \qt \+tl Cek\+tl* d aseřqi inu\qt*  
\m \qt d yicc n usenjem inu,\qt*  
\m \qt lburj inu yuɛřan,\qt*  
\m \qt amcan inu n tarewřa d Amsenjam inu.\qt*  
\m \qt Cek tfekked ayi zi lɛunf.\qt* \x ◘ \xo 22:3 \xt Ɛbr. 2:13\x*   
\m
\v 4 \qt Řaɣiɣ: Asemɣar i SIDI!,\qt*  
\m \qt uca ttwassnejmeɣ zi řɛedyan inu.\qt*   
\m
\v 5 \qt Maɣar nnḍen ayi-dd\qt*  
\m \qt řemwaj n řmewt,\qt*  
\m \qt ssiggʷedent ayi\qt*  
\m \qt řḥemřat n waman ihajen.\qt*   
\m
\v 6 \qt Iseɣwan n řaxart carfen ayi,\qt*  
\m \qt tixecfin n řmewt ḥṣarent ayi.\qt*   
\m
\v 7 \qt Di řeḥṣaret inu řaɣiɣ-dd x SIDI\qt*  
\m \qt u x AREBBI inu i x dd-řaɣiɣ.\qt*  
\m \qt Zi Zzawect Tameqqrant nnes\qt*  
\m \qt isřa Netta i tmijja inu\qt*  
\m \qt uca iɣuyyan inu \+tl udfen\+tl*\qt*  
\m \qt ɣar imezzuɣen nnes.\qt*   
\m
\v 8 \qt \+tl Xenni\+tl* tenhezz u tarjiji temmurt,\qt*  
\m \qt dsusa n ujenna\qt*  
\m \qt ttraḥen-dd ttasen-dd, nhezzen,\qt*  
\m \qt maɣar aɣḍab nnes tuɣa ittwassarɣ.\qt*   
\m
\v 9 \qt Ddexxan igeɛɛed-dd zeg wenzaren nnes,\qt*  
\m \qt timessi zeg uqemmum nnes tṣarḍ,\qt*  
\m \qt řefḥem itteḥduduqen ittwassarɣ zzayes.\qt*   
\m
\v 10 \qt Netta igga ajenna ad yaḍar,\qt*  
\m \qt Netta ihwa-dd.\qt*  
\m \qt \+tl Aqa din\+tl* ijj n useynu ibbumbes\qt*  
\m \qt sadu iḍaren nnes.\qt*   
\m
\v 11 \qt Netta indeh x ijj n ukirub, iḍwa,\qt*  
\m \qt Netta ittwaẓar x wafriwen n usemmiḍ.\qt* \f ◼ \fr 22:11 \ft \+fk akirub\ft  - ict n marka n lmalakat.\f*   
\m
\v 12 \qt Netta igga taǧest ad as tenneḍ\qt*  
\m \qt \+tl am\+tl* iɛuccuten,\qt*  
\m \qt ijj n wegraw n waman,\qt*  
\m \qt iseynuten iqelljen ibbarecnen.\qt*   
\m
\v 13 \qt Zi tissiqt qibač nnes\qt*  
\m \qt ttwassarɣen řefḥem itteḥduduqen.\qt*   
\m
\v 14 \qt Ijja SIDi ajjaj ad idduqqez zeg ujenna,\qt*  
\m \qt uca Amɛuǧi x kuřci\qt*  
\m \qt igga tmijja nnes ttnefrara.\qt*   
\m
\v 15 \qt Netta issekk fřitcat \+tl n řqews nnes\+tl*\qt*  
\m \qt uca ibezzeɛ i-ten,\qt*  
\m \qt \+tl izzaryeḍ\+tl* assamen uca issiggʷed i-ten.\qt*   
\m
\v 16 \qt Tisiwin n řebḥar dewřent ttbanent,\qt*  
\m \qt dsusa n ddunect dewřen ɛarran\qt*  
\m \qt zeg uweddeb n SIDI,\qt*  
\m \qt zeg usuḍi n řeɛwin zeg wenzaren nnes.\qt*   
\m
\v 17 \qt Isswiẓẓeḍ-dd \+tl afus nnes\+tl* zi řuɛřa,\qt*  
\m \qt yiwi ayi, ijbed ayi-dd zeg waman mɣaren.\qt*   
\m
\v 18 \qt Netta ifekk ayi-dd\qt*  
\m \qt zi řeɛdu inu ijehden,\qt*  
\m \qt zeg inni d ayi icarrhen,\qt*  
\m \qt minzi nitni tuɣa jehden xafi.\qt*   
\m
\v 19 \qt Ḥṣaren ayi deg wass n arẓiyyet inu,\qt*  
\m \qt \+tl maca\+tl* SIDI tuɣa d amɛemmed inu.\qt*   
\m
\v 20 \qt Netta indeh ayi ɣar ttasiɛ, issenjem ayi,\qt*  
\m \qt maɣar Netta tuɣa ittɛizza dayi.\qt*   
\m
\v 21 \qt SIDI ixřef ayi ɛlaḥsab tasegda inu,\qt*  
\m \qt ɛlaḥsab tazdugi n ifassen inu ixeǧeṣ ayi.\qt*   
\m
\v 22 \qt Maɣar necc ḥḍiɣ ibriden n SIDI,\qt*  
\m \qt war ḥeyydeɣ ca x AREBBI inu s uxeyyeb.\qt*   
\m
\v 23 \qt Maɣar marra lfarayiḍ nnes\qt*  
\m \qt \+tl tuɣa\+tl* jar \+tl tiṭṭawin\+tl* inu,\qt*  
\m \qt war ḥeyyideɣ ca x tweṣṣa nnes.\qt*   
\m
\v 24 \qt Dewřeɣ kemřeɣ i Netta,\qt*  
\m \qt ḥḍiɣ ixef inu zi řmuɛṣiyyet inu.\qt*   
\m
\v 25 \qt SIDI ixřef ayi anect n tasegda inu,\qt*  
\m \qt anect n tazdugi inu zzat i tiṭṭawin nnes.\qt*   
\m
\v 26 \qt I umeddukkeř amtiqqi\qt*  
\m \qt i teǧid d ameddukkeř d amtiqqi,\qt*  
\m \qt i bu-teɣruḍt ikemmřen\qt*  
\m \qt i teǧid Cek tkemmřed.\qt*   
\m
\v 27 \qt I wenni ittwassizedgen\qt*  
\m \qt aqa Cek d amezdag,\qt*  
\m \qt ak-d wenni ifarɣen, aqa tfarɣed.\qt*   
\m
\v 28 \qt Cek tessnejmed řgens ittwaḥṣar,\qt*  
\m \qt \+tl maca\+tl* tiṭṭawin nnec ḍidd i imɛeffaren,\qt*  
\m \qt Cek ad \+tl ten\+tl* tessehwid.\qt* \f ◼ \fr 22:28 \ft \+fk imɛeffaren\ft  - ‘ayt bu-nnfaxet’.\f*   
\m
\v 29 \qt Minzi Cek d řefnar inu, \+tl a\+tl* SIDI!\qt*  
\m \qt SIDI ittegg tafawt di taǧest inu.\qt*   
\m
\v 30 \qt Minzi akidek ad azzřeɣ\qt*  
\m \qt x ict n bandiyya,\qt*  
\m \qt ak-d AREBBI inu ad neggzeɣ\qt*  
\m \qt x ijj n řḥiḍ.\qt*   
\b  
\m
\v 31 \qt Abrid n Arebbi ikmeř, min iqqar SIDI\qt*  
\m \qt aqa ittwaṣeffa \+tl di tmessi\+tl*.\qt*  
\m \qt Netta d aseřqi i marra\qt*  
\m \qt inni ɣares yarekkwařen.\qt* \x ◘ \xo 22:31 \xt Aɛwd. 32:4; Dan. 4:34; Izhd. 12:7; 119:140; Awřn. 30:5; Asa. 15:3\x*   
\m
\v 32 \qt Maɣar man wen i iǧan d Arebbi,\qt*  
\m \qt mɣir SIDI,\qt*  
\m \qt u man wen i iǧan d taṣḍart,\qt*  
\m \qt mɣir AREBBI nneɣ?\qt* \x ◘ \xo 22:32 \xt Aɛwd. 32:39; 1 Ṣm. 2:2; Izhd. 86:8; Ica. 45:5\x*   
\m
\v 33 \qt Arebbi nni d lqelɛa inu ijhed,\qt*  
\m \qt Netta issarxu abrid inu nican.\qt*   
\m
\v 34 \qt Netta igga iḍaren inu\qt*  
\m \qt am yinni n tudadin,\qt*  
\m \qt Netta yarra ayi\qt*  
\m \qt ad beddeɣ x řegɛudi inu.\qt*   
\m
\v 35 \qt Netta isseřmed ifassen inu i umenɣi,\qt*  
\m \qt iɣaǧen inu maḥend ad meḥḍen\qt*  
\m \qt ijj n řqews n nnḥas.\qt*   
\m
\v 36 \qt Tewcid ayi aseřqi n usenjem nnec,\qt*  
\m \qt s uwaḍeɛ nnec tessemɣared ayi.\qt*   
\m
\v 37 \qt Aqa tegged ttasiɛ i uṣurif inu sadu inu,\qt*  
\m \qt uca ticeɛbin inu war meyyřent.\qt*   
\m
\v 38 \qt Necc ḍfareɣ řɛedyan inu\qt*  
\m \qt uca teḥḥiɣ ten,\qt*  
\m \qt war dd-ttɛiqqibeɣ ař ten qḍiɣ.\qt*   
\m
\v 39 \qt Necc qḍiɣ ten u řebzeɣ ten,\qt*  
\m \qt ařami war kkaren ɛawed.\qt*  
\m \qt Nitni wḍan-dd sadu iḍaren inu.\qt*   
\m
\v 40 \qt Cek tbeysed ayi s jjehd i umenɣi,\qt*  
\m \qt tarrid inni ɣari dd-ikkaren\qt*  
\m \qt ad aḍaren sadu inu.\qt*   
\m
\v 41 \qt Cek tewcid ayi timejjart n řɛedyan inu,\qt*  
\m \qt n yinni d ayi icarrhen,\qt*  
\m \qt u necc areddǧeɣ ten.\qt*   
\m
\v 42 \qt Nitni řaɣan, \+tl maca\+tl* war din tuɣi amsenjem,\qt*  
\m \qt \+tl řaɣan,\+tl* x SIDI,\qt*  
\m \qt maca Netta war xasen dd-yarri.\qt*   
\m
\v 43 \qt Necc ssweddareɣ ten\qt*  
\m \qt am tɛejjajt n temmurt,\qt*  
\m \qt am ubeǧaɛ x ibriden\qt*  
\m \qt ɛejneɣ xasen u řebzeɣ ten.\qt*   
\b  
\m
\v 44 \qt Cek tfekked ayi\qt*  
\m \qt zeg imcubbecen n řgens inu,\qt*  
\m \qt teḥḍid ayi d azeǧif n řegnus,\qt*  
\m \qt ijj n řgens war t ssineɣ, ad ayi isexxar.\qt* \x ◘ \xo 22:44 \xt Izhd. 18:44\x*   
\m
\v 45 \qt Tarwa n ijj n ubarrani\qt*  
\m \qt ssniɛmiřen sswaḍɛen ayi.\qt*  
\m \qt Mɣir řami d ayi isřa umezzuɣ \+tl nsen\+tl* waha,\qt*  
\m \qt sřin-dd ɣari.\qt*   
\m
\v 46 \qt Arrawen n ijj n ubarrani fecřen,\qt*  
\m \qt \+tl waxxa\+tl* nnḍen asen-dd lbarajat nsen.\qt*   
\m
\v 47 \qt Tudart i SIDI. Ad tᵉttwabarek Teṣḍart inu.\qt*  
\m \qt Ejj AREBBI n teṣḍart n usenjem inu\qt*  
\m \qt ad ittwassgeɛɛed \+tl ɣar ujenna\+tl*!\qt*.   
\m
\v 48 \qt Arebbi wenni xafi ittentaqamen\qt*  
\m \qt \+tl d wenni\+tl* d ayi itteggen řegnus\qt*  
\m \qt sadu ufus inu,\qt*   
\m
\v 49 \qt wenni d ayi ittfekkan\qt*  
\m \qt zeg \+tl ufus n\+tl* řɛedyan inu,\qt*  
\m \qt \+tl wah\+tl*, Cek tessgeɛɛaded ayi\qt*  
\m \qt tiwa n yinni d ayi ittḍaddan,\qt*  
\m \qt Cek tessenjamed ayi\qt*  
\m \qt zeg weryaz n řexcunet.\qt*   
\m
\v 50 \qt X uya, SIDI, xseɣ ad Cek qadiɣ,\qt*  
\m \qt xseɣ ad zehhdeɣ Isem nnec.\qt* \x ◘ \xo 22:50 \xt Rum. 15:9\x*   
\m
\v 51 \qt Netta igga isenjimen\qt*  
\m \qt n ujeǧid nnes mɣaren,\qt*  
\m \qt uca isscen tamexsiwt nnes icewwaren\qt*  
\m \qt i umedhun nnes,\qt*  
\m \qt i Dawud u i zzariɛet nnes i řebda.”\qt*   
\b  
\b  
\m  
\c 23
\s1 Awařen ineggura n Dawud  
\m
\v 1 Ina d awařen ineggura n Dawud.  
\b  
\m Dawud, mmis n Yassa issawař, bu-teɣruḍt i ittwassɛuǧan issawař, amedhun n AREBBI n Yaɛqub, amedyaz iɛizzen n Israil.   
\b  
\m
\v 2 Arruḥ n SIDI issiweř zzayi u awař nnes x iřes inu.   
\m
\v 3 AREBBI n Israil inna, aqa Taṣḍart n Israil tessiweř akidi:  
\b  
\m \qt “Ijj n řḥakem jar iwdan, ijj n umsegged,\qt*  
\m \qt ijj n řḥakem nni itteggʷeden AREBBI,\qt*   
\m
\v 4 \qt \+tl wenni iggin\+tl* am tfawt ɣar tuffut\qt*  
\m \qt xmi dd-tneqqar tfuct,\qt*  
\m \qt ɣar ict n tuffut\qt*  
\m \qt břa iseynuten iɛbubbzen,\qt*  
\m \qt \+tl xmi\+tl*, s tissiqt n tfawt\qt*  
\m \qt awarni i wenẓar,\qt*  
\m \qt aqa issfuffuy aɣemmuy aziza\qt*  
\m \qt zi temmurt.”\qt*   
\b  
\m
\v 5 \qt “Ma war teǧi taddart inu\qt*  
\m \qt ɣar Arebbi amenni?\qt*  
\m \qt Aqa igga ayi ijj n Řɛahd i řebda,\qt*  
\m \qt msettef di marra u ittwaḥḍa.\qt*  
\m \qt Qaɛ asenjem inu\qt*  
\m \qt d marra min issnekkaran řefraḥet,\qt*  
\m \qt ma Netta war issɣemmi aya?\qt*   
\m
\v 6 \qt \+tl Maca\+tl* inni war isekkwin\qt*  
\m \qt ad ttwammenḍaren\qt*  
\m \qt am ict n tseṭṭa ak-d isennanen,\qt*  
\m \qt marra nitni,\qt*  
\m \qt maɣar war izemmar\qt*  
\m \qt ad ttwaṭṭfen s ufus.\qt*   
\m
\v 7 \qt Aryaz i ixsen ad tent iḥada,\qt*  
\m \qt ad iḥezzem ixef nnes s wuzzař\qt*  
\m \qt d ukeccuḍ n lansa\qt*  
\m \qt u nitni ad ttwasscemḍen s tmessi\qt*  
\m \qt deg wemcan \+tl nsen\+tl*.”\qt*   
\b  
\m  
\s1 Ayt n bu-teɣruḍt n Dawud  
\m
\v 8 Ina d ismawen n ayt n bu-teɣruḍt i \add iǧan\add* ɣar Dawud: \bd Yucayb Bacabbat\bd*, mmis n Atahkamuni, azeǧif n ineɣrafen. Lansa nnes tuɣa d řehzuṭ nnes, issnuqqeb temn-mya n yeryazen deg ijj n umenɣi. \f ◼ \fr 23:8 \ft \+fk deg ijj n umenɣi\ft  - s Tɛibranit ‘deg icten ticti’.\f*  \x ◘ \xo 23:8 \xt [1 Im. 11:10-47]\x*  
\v 9 Awarni as \add yusa-dd\add* \bd Aliɛazar\bd*, mmis n Dudu, mmis n Axuxi. Netta tuɣa \add d ijjen\add* zi třata n ayt n bu-teɣruḍt \add nni iǧan\add* ak-d Dawud, řami nitni stehzan zeg Ifilisṭiniyyen nni tuɣa din munen i umenɣi, \add am\add* geɛɛden iryazen n Israil ɣarsen \add i umenɣi\add*.  
\v 10 Netta ikkar, iwta deg Ifilisṭiniyyen ař yuḥeř ufus nnes. Iřṣeq ufus nnes di ssif. SIDI yiwiḍ ijj n usenjem d ameqqran deg wass nni uca \add iryazen n\add* řgens ɛeqben awarni as, \add maca\add* mɣir ḥima ad keccḍen.  
\v 11 Awarni as \add yusa-dd\add* \bd Camma\bd*, mmis n Aji, Aharari. \add Řami\add* nnjarwen Ifilisṭiniyyen ɣar Laxi, tuɣa dinni ijj n iyyar iccuren s řeɛdes. Řgens tuɣa yarweř zzat i wudem n Ifilisṭiniyyen.  
\v 12 Netta ibedd di řwest n ureqqiɛ \add n iyyar\add* \add nni\add*, ifekk i-t-i-dd uca iɣřeb x Ifilisṭiniyyen. \add Ammu\add* yarra as SIDI ijj n weɣřab d ameqqran.   
\m
\v 13 Třata zi třatin n izeǧifen hwan, usin-dd ɣar Dawud di \add řweqt n\add* tmeyra, deg ifri n Abdullam. Tuɣa \add din\add* ict n terbiɛt n Ifilisṭiniyyen tewta iqiḍan nsen di teɣzurt n Irafawiyyen.  
\v 14 Dawud \add tuɣa-t\add* di lqelɛa u \add tuɣa\add* din ict n teřbiḥt n řɛeskar n Ifilisṭiniyyen \add di\add* Bayt-Laḥm.  
\v 15 Uca Dawud iřqef i-t ufadi, inna: “Wi d ayi i dd ɣa yawyen aman zi tařa n Bayt-Laḥm i \add iǧan\add* ɣar tewwart \add n tendint\add*?”  
\v 16 \add Xenni\add* cuqen třata n ayt n bu-teɣruḍt nni řmargeḥ n řɛeskar n Ifilisṭiniyyen, uymen-dd aman zi tařa n Bayt-Laḥm, i \add iǧan\add* ɣar tewwart \add n tendint\add*. Ksin ten akidsen u iwḍen ɣar Dawud, \add maca\add* netta yugi ad ten isu uca izeǧeɛ i-ten zzat i SIDI.  
\v 17 Netta inna: “Aya iggʷej xafi, \add a\add* SIDI, aqa necc ad ggeɣ man aya. Ma ad sweɣ idammen n yeryazen, inni \add din\add* iruḥen \add am sebbřen\add* tudart nsen?” U netta war ixs ad ten isu. D man aya i t iggin třata n ayt n bu-teɣruḍt nni.   
\m
\v 18 \bd Abicay\bd*, mmis n Yuwab, mmis n Ṣaruya, tuɣa d azeǧif n třata \add nni\add*. Netta iḥenneḍ lansa nnes x teřt-mya, issnuqqeb i-ten. Netta ɣares ijj n isem \add ittwacenneɛ\add* jar třata \add nni\add*.  
\v 19 Ma war iǧi netta d wenni ittwacennɛen aṭṭas zi třata-ya? S uya tuɣa netta d řqebṭan nsen. Maca netta war yiwiḍ uřa ɣar třata n \add imezwura\add*.   
\m
\v 20 \add Xenni\add* \bd Banaya\bd*, mmis n Yahuyadaɛ, mmis n ijj weryaz imeḥḍen, timegga nnes mɣarent, netta zi Qabḍiyil. Netta iɣřeb x tnayen n iyraden ijehden. Ɛawed tuɣa netta ihwa \add ict n twařa\add*, iɣřeb x ijj n weyrad di řwesṭ n ijj n wanu deg ijj n wass umi iwta wedfeř.  
\v 21 Netta iɣřeb uřa x yijj n weryaz d Amiṣri, ijj n \add weryaz\add* isseggʷaden. Amiṣri tuɣa ɣares ict n lansa deg ufus \add nnes\add*. Ihwa ɣares s yijj n weɛmud, ikkes lansa zeg ufus n Umiṣri u inɣa i-t s lansa nnes.  
\v 22 D man aya i igga Banaya, mmis n Yahuyadaɛ. S uya ɣares isem \add icneɛ\add* jar třata n ayt n bu-teɣruḍt.  
\v 23 Netta tuɣa d wenni ittwacennɛen aṭṭas zi třatin, maca war yiweḍ ař třata imezwura. Dawud igga i-t jar imtiqqan nnes.   
\b  
\m
\v 24 \add Tuɣa\add* \bd Ɛasa’il\bd*, umas n Yuwab, jar třatin;  
\m Ilḥanan, mmis n Dudu, zi Bayt-Laḥm;   
\m
\v 25 Camɛa, Aḥarudi;  
\m Iliqa, Aḥarudi;   
\m
\v 26 Halaṣ, Afalṭi;  
\m Ɛira, mmis n Ɛiqqic, Atiqquɛi;   
\m
\v 27 Abiɛazar, Aɛanatuti;  
\m Mabunnay, Aḥucayi;   
\m
\v 28 Ṣalmun, Axuxi;  
\m Mahray, Anaṭufati;   
\m
\v 29 Xalab, mmis n Baɛna, Anaṭufati;  
\m Ittay, mmis n Ribay,  
\m zi Jibɛa zeg ayt n Binyamin;   
\m
\v 30 Banaya, zi Firɛatun;  
\m Hidday, zi teɣzurin n Jaɛac;   
\m
\v 31 Abu-Ɛalbun, Aɛarabati;  
\m Ɛazmawet, Abarḥumi;   
\m
\v 32 Ilyaḥba, Acaɛlubuni;  
\m zeg iḥenjiren n Yacan, \add mɣir\add* Yunatan;   
\m
\v 33 Camma, Aharari;  
\m Axiyam, mmis Carar, Arari;   
\m
\v 34 Ilifalaṭ, mmis n Aḥasbay,  
\m mmis n Umaɛki;  
\m Iɛam, mmis n Axiṭufil, Ajiluni;   
\m
\v 35 Ḥaṣray, Akarmali;  
\m Faɛray, Alarbi;   
\m
\v 36 Yijɛal, mmis n Natan, zi Ṣuba;  
\m Bani, Ajadi;   
\m
\v 37 Ṣalaq, Aɛammuni;  
\m Naḥray, Abiɛruti,  
\m aḥemmař n řesnaḥ n Yuwab, mmis n Ṣaruya;   
\m
\v 38 Ɛira, Ayitri;  
\m Jarib, Ayitri;   
\m
\v 39 Uriya, Aḥitti.  
\m Marra \add jmiɛ\add* sebɛa u-třatin \add n yeryazen\add*.   
\b  
\b  
\m  
\c 24
\s1 Aḥsab n řgens d lɛiqab  
\m
\v 1 Tuɣa yarɣa weɣḍab n SIDI ɛawed x Israil. Netta issekkar Dawud xasen, inna: “Uyur ad tḥesbed Israil d Yahuda!” \x ◘ \xo 24:1 \xt [1 Im. 21]\x*  
\v 2 Inna ujeǧid i Yuwab, akumandar n řɛeskar, wenni tuɣa ɣares \add iǧan\add*: “Ekk marra tiqebbař n Israil, zi Dan ař Bi’r-Sebɛa, sedd řgens maḥend necc ad ssneɣ řqedd \add n iryazen\add* n řgens.”  
\v 3 \add Xenni\add* inna Yuwab i ujeǧid: “Ad yarni SIDI, AREBBI nnec, aṭṭas i řgens-a am mammec \add ǧan\add* nitni \add řexxu\add*, \add ɛad\add* mya n tseqqar am mammec \add ǧan\add* nitni \add řexxu\add*, u ejj ad ẓarent tiṭṭawin n sidi inu ujeǧid \add aya\add*. \add Maca\add* i umi iwca sidi inu ajeǧid taynit i tmesřact-a?”  
\v 4 \add Maca\add* awař n ujeǧid ijhed x Yuwab u x ikumandaren n řɛeskar, uca iffeɣ Yuwab ak-d ikumandaren n řɛeskar, yaggʷej x wudem n ujeǧid ḥima ad isedd řɛeskar n Israil.  
\v 5 Nitni ẓwan L’Urdun u wtin iqiḍan nsen ɣar uɣezdis afusi n tendint n Ɛaruɛir tenni ɣar řwesṭ n teɣzart n \add yeɣzar n\add* Jad, uca \add uyuren xenni\add* ɣar Yaɛzir. \x ◘ \xo 24:5 \xt Řxř. 21:15; Aɛwd. 2:36; Yac. 13:9, 16\x*  
\v 6 Usin-dd di Jilɛad u di Taḥtim-Ḥudci. \add Xas uca\add* usin-dd ɣar Dan-Yaɛan u ɣar jjwayeh n Ṣidun.  
\v 7 Uca usin-dd ɣar tendint n Ṣur i ifaryen \add s iɣebřawen\add* u ɣar marra tneddam n Iḥiwiyyen d Ikenɛaniyyen, \add Ɣar uneggar\add* iwḍen \add nitni\add* ɣar ljanub n Yahuda di Bi’r-Sebɛa.  
\v 8 Ammu kkin nitni marra tammurt u awarni ɛdun tesɛa n iyuren d ɛicrin n wussan usin-dd ɣar Urcalim.  
\v 9 U Yuwab iwca i ujeǧid řqedd n řeḥsab n řgens. Di Israil tuɣa dayes temn-myat-ařef n yeryazen imeḥḍen inni izemmaren x ssif u xemsa-myat-ařef n yeryazen \add tuɣa aten\add* zi Yahuda.   
\m
\v 10 \add Maca\add* uř n Dawud ibda ad ireddu as awarni iḥseb řgens u Dawud inna i SIDI: “Necc xḍiɣ \add xak\add* aṭṭas s min ggiɣ. \add A\add* SIDI, kkes řexxu řmuɛṣiyyet x umsexxar nnec, maɣar necc ggiɣ tubbuheřya tameqqrant.”  
\v 11 \add Umi\add* Dawud ikkar ɣar tuffut, imsar, aqa yusa-dd awař n SIDI i unabi Jad, amwařaw n Dawud, inna:  
\v 12 “Uyur, siweř i Dawud: ‘Ammu i iqqar SIDI: Ad ac dd-ssarseɣ třata n tmesřayin. Ixḍar ict zzaysent uca ad ac tt ggeɣ.’”  
\v 13 Yusa-dd Jad ɣar Dawud, ixebbar i-t, inna as: “Ma ad iwḍa sebɛa n iseggʷusa n řaẓ x temmurt nnec? Niɣ texsed ad tarewřed třata n iyuren zzat i wudem n řɛedyan nnec u netta ad cek iḍfar? Niɣ \add texsed\add* ad yiři ṭṭaɛun di temmurt nnec? Xenni řexxu, ssen \add min i ɣa tixḍared\add* u xzar, min dd ɣa arreɣ ɣar wenni d ayi dd-issekken.”   
\m
\v 14 \add Xenni\add* inna Dawud i Jad: “Necc ttwaḥṣareɣ aṭṭas. Ejj aneɣ ad newḍa deg ifassen n SIDI, maɣar arreḥmet nnes temɣar, maca war xseɣ ca ad wḍiɣ deg ifassen n iwdan.”  
\v 15 \add Xenni\add* issiweḍ SIDI ijj n ṭṭaɛun x Israil, zi tuffut ař ijj n řmijař ittwaggen. Mmuten sebɛin-ařef n yeryazen n řgens zi Dan ař Bi’r-Sebɛa.  
\v 16 \add Umi\add* isswiẓẓeḍ lmalak afus nnes x Urcalim, ḥima ad iɣḍeř \add tandint\add* deg uḍeyyeɛ, indem SIDI x tuɛeffna, inna i lmalak i iggur ad iɣḍeř řgens deg uḍeyyeɛ: “Cfa, sehwa afus nnec řexxu!” Tuɣa lmalak n SIDI ittaweḍ ɣar unedrar n Uyabusi Arawna.  
\v 17 \add Umi\add* Dawud iẓra lmalak wenni iwtin řgens, issiweř Dawud ak-d SIDI, inna: “Xzar, necc xḍiɣ u necc, \add wah\add* necc ggiɣ řmuɛṣiyyet, maca uǧi-ya, min ggin? Ejj ad yiři ufus nnec i tecti ɣari d ɣar taddart n baba.”   
\b  
\m  
\s1 Aɛalṭar x wendrar n Arawna  
\m
\v 18 Deg wass nni beɛda yusa-dd Jad ɣar Dawud, inna as: “Geɛɛed, sbedd ijj n uɛalṭar i SIDI x unedrar n Uyabusi Arawna.”  
\v 19 Dawud igeɛɛed ɛlaḥsab awař n Jad, am mammec \add t\add* yumur SIDI.  
\v 20 Arawna iceyyeɛ u iẓra ajeǧid ak-d imsexxaren nnes usin-dd ɣares. \add Xenni\add* yuyur Arawna ɣar barra, ibendeq zzat i ujeǧid s uɣembub nnes ɣar temmurt.  
\v 21 Arawna inna: “Mayemmi i dd-yusa sidi inu ajeǧid, ɣar umsexxar nnes?” Dawud inna: “Ḥima ad xak sɣeɣ andrar ḥima ad bniɣ din ijj n uɛalṭar i SIDI, maḥend ad tbedd tecti di řgens.”  
\v 22 \add Xenni\add* inna Arawna i Dawud: “Ejj sidi inu ajeǧid ad iksi u ad iwehheb min d as ittɣiř d lemliḥ di tiṭṭawin nnes. Xzar aqa din ifunasen d tfunasin i tɣarṣt n wecmaḍ u \add ksi\add* tiřwiḥin itteḥřuǧuḍen i usarwet d řeḥwayej n ifunasen d tfunasin d akeccuḍ \add i tmessi\add*.  
\v 23 Aya marra, \add a\add* ajeǧid, ad ac iwc Arawna i ujeǧid.” \add Ɛawed\add* inna Arawna i ujeǧid: “Iři ad dd-tased cek x řxaḍar ɣar SIDI, AREBBI nnec!”  
\v 24 \add Maca\add* ajeǧid inna i Arawna: “Lla, maɣar necc xseɣ ad xak t sɣeɣ s ttaman \add nnes ikmeř\add*, maɣar necc war ttwehhbeɣ i SIDI, AREBBI inu, tiɣarṣa n wecmaḍ i war isekkwin walu.” U Dawud isɣa andrar d ifunasen d tfunasin i xemsin ciqlu n nnuqart.  
\v 25 Dawud ibna din ijj n uɛalṭar i SIDI uca issgeɛɛed din tiɣarṣa n wecmaḍ d tewhibin \add n řɣiǧet\add*. Ammu ittwasseṣřeḥ SIDI x temmurt s tẓaǧit yuǧɣen u tᵉttwassbedd tecti di Israil.   