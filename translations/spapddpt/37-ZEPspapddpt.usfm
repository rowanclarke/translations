\mt1 Sofonías  
\c 1  
\p
\v 1 La \w Palabra|strong="H1697"\w* \w de|strong="H1121"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w que|strong="H1697"\w* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w Sofonías|strong="H6846"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Cusi|strong="H3569"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Gedalías|strong="H1436"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Amarías, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Ezequías, en \w días|strong="H3117"\w* \w de|strong="H1121"\w* \w Josías|strong="H2977"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Amón, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*.   
\s1 Destrucción  
\p
\v 2 \wj Destruiré completamente \+w todas|strong="H3605"\+w* \+w las|strong="H5921"\+w* cosas \+w de|strong="H5921"\+w* \+w sobre|strong="H5921"\+w* \+w la|strong="H5921"\+w* superficie \+w de|strong="H5921"\+w* \+w la|strong="H5921"\+w* tierra, \wj*\w dice|strong="H5002"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.  
\v 3 \wj \+w Destruiré|strong="H3772"\+w* \+w los|strong="H5921"\+w* hombres \+w y|strong="H5921"\+w* \+w las|strong="H5921"\+w* bestias. \+w Destruiré|strong="H3772"\+w* \+w las|strong="H5921"\+w* \+w aves|strong="H5775"\+w* \+w del|strong="H5921"\+w* \+w cielo|strong="H8064"\+w* \+w y|strong="H5921"\+w* \+w los|strong="H5921"\+w* peces \+w del|strong="H5921"\+w* \+w mar|strong="H3220"\+w*. \+w Haré|strong="H3772"\+w* tropezar \+w a|strong="H3068"\+w* \+w los|strong="H5921"\+w* perversos \+w y|strong="H5921"\+w* \+w cortaré|strong="H3772"\+w* \+w al|strong="H5921"\+w* hombre \+w de|strong="H5921"\+w* \+w la|strong="H5921"\+w* superficie \+w de|strong="H5921"\+w* \+w la|strong="H5921"\+w* tierra, \wj*\w dice|strong="H5002"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.  
\v 4 \wj \+w Extenderé|strong="H5186"\+w* \+w mi|strong="H5921"\+w* \+w mano|strong="H3027"\+w* \+w contra|strong="H5921"\+w* \+w Judá|strong="H3063"\+w*, \+w contra|strong="H5921"\+w* \+w todos|strong="H3605"\+w* \+w los|strong="H3427"\+w* \+w habitantes|strong="H3427"\+w* \+w de|strong="H4480"\+w* Jerusalén. Exterminaré \+w de|strong="H4480"\+w* \+w este|strong="H2088"\+w* \+w lugar|strong="H4725"\+w* \+w lo|strong="H2088"\+w* \+w que|strong="H4480"\+w* queda \+w de|strong="H4480"\+w* \+w baal|strong="H1168"\+w*, \+w y|strong="H5921"\+w* \+w el|strong="H5921"\+w* \+w nombre|strong="H8034"\+w* \+w de|strong="H4480"\+w* \+w los|strong="H3427"\+w* ministros \+w y|strong="H5921"\+w* \+w sacerdotes|strong="H3548"\+w* idólatras,\wj*  
\v 5 \wj \+w a|strong="H3068"\+w* \+w los|strong="H5921"\+w* \+w que|strong="H5921"\+w* \+w se|strong="H5921"\+w* postran \+w sobre|strong="H5921"\+w* \+w las|strong="H5921"\+w* azoteas ante \+w el|strong="H5921"\+w* \+w ejército|strong="H6635"\+w* \+w del|strong="H5921"\+w* \+w cielo|strong="H8064"\+w*, \+w a|strong="H3068"\+w* \+w los|strong="H5921"\+w* \+w que|strong="H5921"\+w* \+w se|strong="H5921"\+w* postran \+w y|strong="H5921"\+w* juran \+w por|strong="H5921"\+w* \+nd \+w Yavé|strong="H3068"\+w*\+nd* \+w y|strong="H5921"\+w* \+w al|strong="H5921"\+w* mismo tiempo juran \+w por|strong="H5921"\+w* Moloc,\wj*  
\v 6 \wj \+w a|strong="H3068"\+w* los \+w que|strong="H3808"\+w* \+w se|strong="H3808"\+w* apartan de seguir \+w a|strong="H3068"\+w* \+nd \+w Yavé|strong="H3068"\+w*\+nd*, y \+w a|strong="H3068"\+w* los \+w que|strong="H3808"\+w* \+w no|strong="H3808"\+w* \+w buscan|strong="H1245"\+w* \+w a|strong="H3068"\+w* \+nd \+w Yavé|strong="H3068"\+w*\+nd* \+w ni|strong="H3808"\+w* le consultan.\wj*   
\s1 El banquete de \nd Yavé\nd*  
\p
\v 7 ¡Silencio \w ante|strong="H6440"\w* \nd ʼAdonay \+w Yavé|strong="H3068"\+w*\nd*! \w Porque|strong="H3588"\w* \w el|strong="H3588"\w* \w día|strong="H3117"\w* \w de|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* está \w cercano|strong="H7138"\w*. \nd \+w Yavé|strong="H3068"\+w*\nd* \w preparó|strong="H3559"\w* un \w sacrificio|strong="H2077"\w* \w y|strong="H3588"\w* escogió \w a|strong="H3068"\w* sus invitados.  
\v 8 \wj \+w El|strong="H5921"\+w* \+w día|strong="H3117"\+w* \+w del|strong="H5921"\+w* \+w sacrificio|strong="H2077"\+w* \+w de|strong="H5921"\+w* \+nd \+w Yavé|strong="H3068"\+w*\+nd* castigaré \+w a|strong="H3068"\+w* \+w los|strong="H1121"\+w* \+w principales|strong="H8269"\+w*, \+w a|strong="H3068"\+w* \+w los|strong="H1121"\+w* \+w hijos|strong="H1121"\+w* \+w del|strong="H5921"\+w* \+w rey|strong="H4428"\+w* \+w y|strong="H5921"\+w* \+w a|strong="H3068"\+w* \+w todos|strong="H3605"\+w* \+w los|strong="H1121"\+w* \+w que|strong="H5921"\+w* llevan ropa extranjera. \wj*  
\v 9 \wj \+w Aquel|strong="H1931"\+w* \+w día|strong="H3117"\+w* también castigaré \+w a|strong="H3068"\+w* \+w todos|strong="H3605"\+w* \+w los|strong="H5921"\+w* \+w que|strong="H1931"\+w* asaltan \+w la|strong="H1931"\+w* entrada, \+w que|strong="H1931"\+w* llenan \+w de|strong="H5921"\+w* \+w violencia|strong="H2555"\+w* \+w y|strong="H5921"\+w* \+w engaño|strong="H4820"\+w* \+w la|strong="H1931"\+w* \+w casa|strong="H1004"\+w* \+w de|strong="H5921"\+w* \+w su|strong="H1931"\+w* \+tl ʼadon\+tl*. \wj*  
\v 10 \wj \+w Aquel|strong="H1931"\+w* \+w día|strong="H3117"\+w*, \wj*\w dice|strong="H5002"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \wj \+w habrá|strong="H1961"\+w* \+w voz|strong="H6963"\+w* \+w de|strong="H4480"\+w* \+w clamor|strong="H6818"\+w* \+w desde|strong="H4480"\+w* \+w la|strong="H1931"\+w* \+w puerta|strong="H8179"\+w* \+w del|strong="H4480"\+w* \+w Pescado|strong="H1709"\+w*, un gemido \+w desde|strong="H4480"\+w* \+w la|strong="H1931"\+w* ciudad Nueva, y un \+w estruendo|strong="H6963"\+w* enorme \+w desde|strong="H4480"\+w* las colinas.\wj*  
\v 11 \wj ¡Giman, \+w habitantes|strong="H3427"\+w* \+w de|strong="H3588"\+w* Mactes, \+w porque|strong="H3588"\+w* \+w todo|strong="H3605"\+w* \+w el|strong="H3588"\+w* \+w pueblo|strong="H5971"\+w* \+w de|strong="H3588"\+w* mercaderes \+w está|strong="H3427"\+w* arruinado! \+w Todos|strong="H3605"\+w* \+w los|strong="H3427"\+w* \+w que|strong="H3588"\+w* iban cargados \+w de|strong="H3588"\+w* \+w plata|strong="H3701"\+w* \+w son|strong="H3588"\+w* exterminados.\wj*  
\v 12 \wj \+w En|strong="H5921"\+w* \+w aquel|strong="H1931"\+w* \+w tiempo|strong="H6256"\+w* escudriñaré \+w a|strong="H3068"\+w* Jerusalén \+w con|strong="H5921"\+w* linterna, \+w y|strong="H5921"\+w* castigaré \+w a|strong="H3068"\+w* \+w los|strong="H5921"\+w* aletargados \+w sobre|strong="H5921"\+w* \+w los|strong="H5921"\+w* restos \+w de|strong="H5921"\+w* \+w su|strong="H1931"\+w* \+w vino|strong="H1961"\+w*, \+w a|strong="H3068"\+w* quienes dicen \+w en|strong="H5921"\+w* \+w su|strong="H1931"\+w* \+w corazón|strong="H3824"\+w*: \+nd \+w Yavé|strong="H3068"\+w*\+nd* \+w no|strong="H3808"\+w* \+w hará|strong="H1961"\+w* \+w bien|strong="H3190"\+w* \+w ni|strong="H3808"\+w* \+w mal|strong="H7489"\+w*.\wj*  
\v 13 \wj Además sus \+w riquezas|strong="H2428"\+w* \+w serán|strong="H1961"\+w* saqueadas y sus \+w casas|strong="H1004"\+w* desoladas. \+w Edificarán|strong="H1129"\+w* \+w casas|strong="H1004"\+w*, pero \+w no|strong="H3808"\+w* las \+w habitarán|strong="H3427"\+w*, \+w plantarán|strong="H5193"\+w* \+w viñas|strong="H3754"\+w*, pero \+w no|strong="H3808"\+w* \+w beberán|strong="H8354"\+w* su \+w vino|strong="H3196"\+w*.\wj*   
\s1 Terror ante \nd Yavé\nd*  
\p
\v 14 ¡\w Cercano|strong="H7138"\w* \w está|strong="H8033"\w* el \w día|strong="H3117"\w* \w grande|strong="H1419"\w* de \nd \+w Yavé|strong="H3068"\+w*\nd*! \w Cercano|strong="H7138"\w* y se apresura rápidamente. Escuchen el \w día|strong="H3117"\w* de \nd \+w Yavé|strong="H3068"\+w*\nd*. \w Hasta|strong="H3117"\w* el guerrero clama \w amargamente|strong="H4751"\w*.  
\v 15 \w Día|strong="H3117"\w* de ira \w es|strong="H1931"\w* \w aquel|strong="H1931"\w* \w día|strong="H3117"\w*, \w día|strong="H3117"\w* de \w tribulación|strong="H6869"\w* y \w angustia|strong="H6869"\w*, \w día|strong="H3117"\w* de destrucción y desolación, \w día|strong="H3117"\w* de \w oscuridad|strong="H6205"\w* y tenebrosidad, \w día|strong="H3117"\w* de \w nubes|strong="H6051"\w* y densa niebla,  
\v 16 \w día|strong="H3117"\w* \w de|strong="H5921"\w* \w trompeta|strong="H7782"\w* \w y|strong="H5921"\w* \w de|strong="H5921"\w* griterío \w sobre|strong="H5921"\w* \w las|strong="H5921"\w* \w ciudades|strong="H5892"\w* \w fortificadas|strong="H1219"\w* \w y|strong="H5921"\w* \w las|strong="H5921"\w* altas \w torres|strong="H6438"\w*.   
\p
\v 17 \wj Atribularé \+w a|strong="H3068"\+w* \+w los|strong="H3588"\+w* hombres \+w y|strong="H3588"\+w* deambularán \+w como|strong="H3588"\+w* \+w ciegos|strong="H5787"\+w*, \+w porque|strong="H3588"\+w* \+w pecaron|strong="H2398"\+w* contra \+nd \+w Yavé|strong="H3068"\+w*\+nd*. \+w Su|strong="H3588"\+w* \+w sangre|strong="H1818"\+w* será derramada \+w como|strong="H3588"\+w* \+w polvo|strong="H6083"\+w* \+w y|strong="H3588"\+w* \+w su|strong="H3588"\+w* carne \+w como|strong="H3588"\+w* estiércol.\wj*  
\v 18 \w Ni|strong="H3808"\w* \w su|strong="H3588"\w* \w plata|strong="H3701"\w* \w ni|strong="H3808"\w* \w su|strong="H3588"\w* \w oro|strong="H2091"\w* \w podrán|strong="H3201"\w* librarlos \w el|strong="H3588"\w* \w día|strong="H3117"\w* \w de|strong="H3588"\w* \w la|strong="H1571"\w* ira \w de|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \w cuando|strong="H3588"\w* \w el|strong="H3588"\w* fuego \w de|strong="H3588"\w* \w su|strong="H3588"\w* \w celo|strong="H7068"\w* consuma \w toda|strong="H3605"\w* \w la|strong="H1571"\w* tierra, \w porque|strong="H3588"\w* \w ciertamente|strong="H3588"\w* \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w que|strong="H3588"\w* viven \w en|strong="H3588"\w* \w la|strong="H1571"\w* tierra serán destruidos apresuradamente.   
\c 2  
\s1 Exhortación urgente  
\p
\v 1 ¡Reúnanse en asamblea, oh \w nación|strong="H1471"\w* desvergonzada!  
\v 2 \w Antes|strong="H2962"\w* \w que|strong="H3808"\w* \w entre|strong="H5921"\w* \w en|strong="H5921"\w* vigencia \w el|strong="H5921"\w* decreto \w del|strong="H5921"\w* \w día|strong="H3117"\w* \w que|strong="H3808"\w* arrebatará \w la|strong="H5921"\w* concha \w del|strong="H5921"\w* grano trillado, \w antes|strong="H2962"\w* \w que|strong="H3808"\w* venga \w sobre|strong="H5921"\w* ustedes \w el|strong="H5921"\w* \w día|strong="H3117"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w ira|strong="H2740"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*,  
\v 3 ¡\w busquen|strong="H1245"\w* \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \w todos|strong="H3605"\w* \w los|strong="H3605"\w* humildes de \w la|strong="H3605"\w* tierra! \w Los|strong="H3605"\w* \w que|strong="H3117"\w* cumplen sus Preceptos \w busquen|strong="H1245"\w* \w la|strong="H3605"\w* \w justicia|strong="H6664"\w* y \w busquen|strong="H1245"\w* \w la|strong="H3605"\w* humildad. Tal vez sean escondidos \w el|strong="H3605"\w* \w día|strong="H3117"\w* de \w la|strong="H3605"\w* ira de \nd \+w Yavé|strong="H3068"\+w*\nd*.   
\s1 Contra las provincias vecinas  
\p
\v 4 \w Gaza|strong="H5804"\w* \w será|strong="H1961"\w* \w desamparada|strong="H5800"\w*, Ascalón \w asolada|strong="H8077"\w*. Asdod \w será|strong="H1961"\w* desterrada al mediodía, \w y|strong="H3588"\w* \w Ecrón|strong="H6138"\w* \w será|strong="H1961"\w* \w desarraigada|strong="H6131"\w*.  
\v 5 ¡\w Ay|strong="H1945"\w* \w de|strong="H5921"\w* \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* costa, \w del|strong="H5921"\w* pueblo \w de|strong="H5921"\w* \w los|strong="H3427"\w* cereteos! \w La|strong="H5921"\w* \w Palabra|strong="H1697"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w está|strong="H3427"\w* \w contra|strong="H5921"\w* ustedes, \w oh|strong="H1945"\w* \w Canaán|strong="H3667"\w*, tierra \w de|strong="H5921"\w* \w filisteos|strong="H6430"\w*. \wj Haré \+w que|strong="H5921"\+w* seas arrasada \+w hasta|strong="H5921"\+w* \+w que|strong="H5921"\+w* \+w no|strong="H5921"\+w* \+w quede|strong="H3427"\+w* algún habitante.\wj*  
\v 6 Entonces la costa marítima \w se|strong="H1961"\w* convertirá en pastizales con \w cabañas|strong="H5116"\w* de \w pastores|strong="H7462"\w* y apriscos \w para|strong="H1961"\w* \w ovejas|strong="H6629"\w*.  
\v 7 \w La|strong="H5921"\w* costa \w será|strong="H1961"\w* \w para|strong="H5921"\w* \w el|strong="H5921"\w* remanente \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w Casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*. Allí apacentarán, \w y|strong="H3588"\w* \w al|strong="H5921"\w* llegar \w la|strong="H5921"\w* noche \w se|strong="H1961"\w* recogerán \w en|strong="H5921"\w* \w las|strong="H5921"\w* \w casas|strong="H1004"\w* \w de|strong="H5921"\w* Ascalón, \w pues|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w su|strong="H3588"\w* \nd ʼElohim\nd* \w los|strong="H5921"\w* \w visitará|strong="H6485"\w* \w y|strong="H3588"\w* \w los|strong="H5921"\w* \w hará|strong="H1961"\w* \w volver|strong="H7725"\w* \w de|strong="H5921"\w* \w su|strong="H3588"\w* cautiverio.   
\s1 Contra moabitas y amonitas  
\p
\v 8 \wj \+w Oí|strong="H8085"\+w* \+w los|strong="H1121"\+w* insultos \+w de|strong="H5921"\+w* \+w Moab|strong="H4124"\+w* \+w y|strong="H5921"\+w* \+w las|strong="H5921"\+w* ofensas \+w con|strong="H5921"\+w* \+w las|strong="H5921"\+w* cuales \+w los|strong="H1121"\+w* \+w hijos|strong="H1121"\+w* \+w de|strong="H5921"\+w* Amón \+w afrentaron|strong="H2778"\+w* \+w a|strong="H3068"\+w* \+w mi|strong="H5921"\+w* \+w pueblo|strong="H5971"\+w*, \+w y|strong="H5921"\+w* \+w cómo|strong="H5921"\+w* \+w se|strong="H5921"\+w* expandieron \+w al|strong="H5921"\+w* invadir \+w los|strong="H1121"\+w* territorios \+w de|strong="H5921"\+w* Israel. \wj*  
\v 9 \wj \+w Por|strong="H3588"\+w* \+w tanto|strong="H3651"\+w*, \+w vivo|strong="H2416"\+w* \+w Yo|strong="H3588"\+w*, \+nd \+w Yavé|strong="H3068"\+w*\+nd* \+w de|strong="H3588"\+w* las huestes, \+w el|strong="H3588"\+w* \+nd ʼElohim\+nd* \+w de|strong="H3588"\+w* \+w Israel|strong="H3478"\+w*, \+w dice|strong="H5002"\+w*: \+w Ciertamente|strong="H3588"\+w* \+w Moab|strong="H4124"\+w* \+w será|strong="H1961"\+w* \+w como|strong="H3588"\+w* \+w Sodoma|strong="H5467"\+w*, \+w y|strong="H3588"\+w* \+w los|strong="H1121"\+w* \+w hijos|strong="H1121"\+w* \+w de|strong="H3588"\+w* Amón \+w como|strong="H3588"\+w* \+w Gomorra|strong="H6017"\+w*: \+w campo|strong="H4476"\+w* \+w de|strong="H3588"\+w* \+w ortigas|strong="H2738"\+w*, salina \+w y|strong="H3588"\+w* desolación \+w perpetua|strong="H5769"\+w*. \+w El|strong="H3588"\+w* remanente \+w de|strong="H3588"\+w* \+w mi|strong="H1961"\+w* \+w pueblo|strong="H5971"\+w* \+w los|strong="H1121"\+w* saqueará \+w y|strong="H3588"\+w* \+w el|strong="H3588"\+w* \+w resto|strong="H3499"\+w* \+w de|strong="H3588"\+w* \+w mi|strong="H1961"\+w* \+w nación|strong="H1471"\+w* \+w los|strong="H1121"\+w* \+w heredará|strong="H5157"\+w*.\wj*   
\p
\v 10 \w Esto|strong="H2063"\w* tendrán \w por|strong="H5921"\w* \w su|strong="H1992"\w* orgullo, \w porque|strong="H3588"\w* \w se|strong="H5921"\w* mofaron \w y|strong="H3588"\w* \w se|strong="H5921"\w* jactaron \w contra|strong="H5921"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w de|strong="H5921"\w* \w las|strong="H1992"\w* huestes.  
\v 11 \w Terrible|strong="H3372"\w* será \nd \+w Yavé|strong="H3068"\+w*\nd* \w contra|strong="H5921"\w* \w ellos|strong="H5921"\w*, \w porque|strong="H3588"\w* dejará pasar hambre \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \tl ʼelohim\tl* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra. \w Y|strong="H3068"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* costas \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w*, \w cada|strong="H3605"\w* una \w desde|strong="H5921"\w* \w su|strong="H3588"\w* \w lugar|strong="H4725"\w*, \w se|strong="H5921"\w* inclinarán ante \w Él|strong="H5921"\w*.   
\p
\v 12 \wj \+w También|strong="H1571"\+w* ustedes, \+w los|strong="H1992"\+w* etíopes, \+w serán|strong="H1992"\+w* \+w muertos|strong="H2491"\+w* \+w con|strong="H1571"\+w* mi \+w espada|strong="H2719"\+w*. \wj*   
\p
\v 13 \w Extenderá|strong="H5186"\w* su \w mano|strong="H3027"\w* \w contra|strong="H5921"\w* \w el|strong="H5921"\w* \w norte|strong="H6828"\w* \w y|strong="H5921"\w* destruirá \w a|strong="H3068"\w* Asiria, \w y|strong="H5921"\w* \w hará|strong="H7760"\w* \w de|strong="H5921"\w* \w Nínive|strong="H5210"\w* una desolación, árida \w como|strong="H5921"\w* \w el|strong="H5921"\w* \w desierto|strong="H4057"\w*.  
\v 14 Se echarán \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H3588"\w* \w ella|strong="H3605"\w* las manadas \w y|strong="H1571"\w* \w toda|strong="H3605"\w* \w bestia|strong="H2416"\w* del campo. Se alojarán \w la|strong="H1571"\w* lechuza \w y|strong="H1571"\w* \w el|strong="H3588"\w* erizo \w en|strong="H8432"\w* sus capiteles, \w y|strong="H1571"\w* \w su|strong="H3588"\w* \w voz|strong="H6963"\w* resonará \w en|strong="H8432"\w* las \w ventanas|strong="H2474"\w*. Habrá desolación \w en|strong="H8432"\w* las puertas, \w pues|strong="H3588"\w* \w su|strong="H3588"\w* enmaderado \w de|strong="H3588"\w* cedro quedará descubierto.  
\v 15 \w Esta|strong="H2063"\w* \w es|strong="H1961"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w* \w alegre|strong="H5947"\w* \w que|strong="H5921"\w* \w vivía|strong="H3427"\w* confiadamente, \w que|strong="H5921"\w* decía \w en|strong="H5921"\w* su \w corazón|strong="H3824"\w*: Yo, \w y|strong="H5921"\w* \w ningún|strong="H3605"\w* \w otro|strong="H5750"\w*. ¡\w Cómo|strong="H1961"\w* \w fue|strong="H1961"\w* convertida \w en|strong="H5921"\w* horror, \w en|strong="H5921"\w* madriguera \w de|strong="H5921"\w* fieras! \w Cualquiera|strong="H3605"\w* \w que|strong="H5921"\w* \w pase|strong="H5674"\w* \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w ella|strong="H5921"\w* \w se|strong="H1961"\w* burlará \w y|strong="H5921"\w* agitará su \w mano|strong="H3027"\w*.   
\c 3  
\s1 Juicio contra Jerusalén  
\p
\v 1 ¡\w Ay|strong="H1945"\w* de la \w ciudad|strong="H5892"\w* rebelde, contaminada y \w opresora|strong="H3238"\w*!  
\v 2 \w No|strong="H3808"\w* \w escucha|strong="H8085"\w* la \w voz|strong="H6963"\w* \w ni|strong="H3808"\w* \w recibe|strong="H3947"\w* la \w corrección|strong="H4148"\w*, \w no|strong="H3808"\w* confía en \nd \+w Yavé|strong="H3068"\+w*\nd* \w ni|strong="H3808"\w* \w se|strong="H3808"\w* acerca \w a|strong="H3068"\w* su \nd ʼElohim\nd*.  
\v 3 Sus magistrados \w son|strong="H3808"\w* leones rugientes en \w medio|strong="H7130"\w* \w de|strong="H8269"\w* ella, sus \w jueces|strong="H8199"\w*, \w lobos|strong="H2061"\w* nocturnos, \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w dejan|strong="H1633"\w* hueso para la \w mañana|strong="H1242"\w*.  
\v 4 Sus \w profetas|strong="H5030"\w* son insolentes, hombres desleales. Sus \w sacerdotes|strong="H3548"\w* \w profanaron|strong="H2490"\w* \w el|strong="H5030"\w* \w Santuario|strong="H6944"\w* y violaron la \w Ley|strong="H8451"\w*.  
\v 5 \nd \+w Yavé|strong="H3068"\+w*\nd* es \w justo|strong="H6662"\w* en \w medio|strong="H7130"\w* \w de|strong="H5414"\w* ella, \w no|strong="H3808"\w* \w hará|strong="H6213"\w* injusticia. Cada \w mañana|strong="H1242"\w* saca \w a|strong="H3068"\w* luz su \w justicia|strong="H4941"\w*, \w nunca|strong="H3808"\w* falla. Pero \w el|strong="H6213"\w* injusto \w no|strong="H3808"\w* \w conoce|strong="H3045"\w* la vergüenza.   
\p
\v 6 \wj Yo destruí \+w naciones|strong="H1471"\+w*, sus torreones \+w están|strong="H3427"\+w* en ruinas. Dejé \+w desiertas|strong="H2717"\+w* sus \+w calles|strong="H2351"\+w* \+w hasta|strong="H1097"\+w* \+w no|strong="H1097"\+w* quedar quien \+w pase|strong="H5674"\+w*. Sus \+w ciudades|strong="H5892"\+w* \+w están|strong="H3427"\+w* devastadas, \+w sin|strong="H1097"\+w* hombre, \+w sin|strong="H1097"\+w* habitante.\wj*  
\v 7 \wj Dije: \+w Ciertamente|strong="H6485"\+w* \+w me|strong="H5921"\+w* \+w temerá|strong="H3372"\+w*, aceptará \+w corrección|strong="H4148"\+w* \+w y|strong="H5921"\+w* \+w no|strong="H3808"\+w* \+w será|strong="H3808"\+w* destruida su vivienda, \+w a|strong="H3068"\+w* pesar \+w de|strong="H5921"\+w* \+w todo|strong="H3605"\+w* \+w lo|strong="H3808"\+w* \+w que|strong="H3808"\+w* determiné \+w con|strong="H5921"\+w* respecto \+w a|strong="H3068"\+w* \+w ella|strong="H5921"\+w*. Pero \+w ellos|strong="H5921"\+w* anhelaban pervertir \+w todas|strong="H3605"\+w* sus \+w obras|strong="H5949"\+w*.\wj*   
\p
\v 8 \wj \+w Por|strong="H5921"\+w* \+w tanto|strong="H3651"\+w*, \wj*\w dice|strong="H5002"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \wj espérenme \+w hasta|strong="H5921"\+w* \+w el|strong="H5921"\+w* \+w día|strong="H3117"\+w* \+w cuando|strong="H3588"\+w* \+w Yo|strong="H3588"\+w* \+w me|strong="H5921"\+w* levante \+w para|strong="H5921"\+w* juzgarlos, \+w pues|strong="H3588"\+w* \+w mi|strong="H5921"\+w* decisión \+w es|strong="H3588"\+w* reunir \+w las|strong="H5921"\+w* \+w naciones|strong="H1471"\+w* \+w y|strong="H3588"\+w* congregar \+w los|strong="H5921"\+w* \+w reinos|strong="H4467"\+w*, \+w para|strong="H5921"\+w* derramar \+w sobre|strong="H5921"\+w* \+w ellos|strong="H5921"\+w* \+w mi|strong="H5921"\+w* \+w furor|strong="H2740"\+w*, \+w todo|strong="H3605"\+w* \+w el|strong="H5921"\+w* ardor \+w de|strong="H5921"\+w* \+w mi|strong="H5921"\+w* \+w ira|strong="H2740"\+w*, \+w porque|strong="H3588"\+w* \+w toda|strong="H3605"\+w* \+w la|strong="H5921"\+w* tierra será devorada \+w con|strong="H5921"\+w* \+w el|strong="H5921"\+w* fuego \+w de|strong="H5921"\+w* \+w mi|strong="H5921"\+w* \+w celo|strong="H7068"\+w*.\wj*   
\s1 Restauración  
\p
\v 9 \wj \+w En|strong="H3588"\+w* \+w aquel|strong="H3605"\+w* tiempo devolveré pureza \+w de|strong="H3588"\+w* \+w labios|strong="H8193"\+w* \+w a|strong="H3068"\+w* \+w los|strong="H3605"\+w* \+w pueblos|strong="H5971"\+w*, \+w para|strong="H3588"\+w* \+w que|strong="H3588"\+w* \+w todos|strong="H3605"\+w* \+w invoquen|strong="H7121"\+w* \+w el|strong="H3588"\+w* \+w Nombre|strong="H8034"\+w* \+w de|strong="H3588"\+w* \+nd \+w Yavé|strong="H3068"\+w*\+nd*, \+w y|strong="H3588"\+w* le sirvan \+w de|strong="H3588"\+w* común acuerdo. \wj*  
\v 10 \wj Desde más allá de los ríos de \+w Etiopía|strong="H3568"\+w*, los \+w que|strong="H1323"\+w* me invocan en medio de la dispersión, me traerán \+w ofrenda|strong="H4503"\+w*. \wj*  
\v 11 \wj \+w En|strong="H3588"\+w* \+w aquel|strong="H1931"\+w* \+w día|strong="H3117"\+w* \+w no|strong="H3808"\+w* serás avergonzada \+w por|strong="H3588"\+w* \+w ninguna|strong="H3605"\+w* \+w de|strong="H3588"\+w* tus \+w obras|strong="H5949"\+w* \+w con|strong="H3588"\+w* las cuales \+w te|strong="H3588"\+w* rebelaste contra Mí, \+w porque|strong="H3588"\+w* \+w entonces|strong="H3117"\+w* \+w quitaré|strong="H5493"\+w* \+w de|strong="H3588"\+w* \+w en|strong="H3588"\+w* \+w medio|strong="H7130"\+w* \+w de|strong="H3588"\+w* ti \+w a|strong="H3068"\+w* \+w los|strong="H3605"\+w* \+w que|strong="H3588"\+w* \+w se|strong="H1931"\+w* alegran \+w en|strong="H3588"\+w* tu altivez. \+w No|strong="H3808"\+w* volverás \+w a|strong="H3068"\+w* ser altiva \+w en|strong="H3588"\+w* mi \+w Santa|strong="H6944"\+w* Montaña.\wj*  
\v 12 \wj Entonces dejaré en \+w medio|strong="H7130"\+w* \+w de|strong="H5971"\+w* ti un \+w pueblo|strong="H5971"\+w* \+w humilde|strong="H6041"\+w* y \+w pobre|strong="H1800"\+w*, el cual \+w se|strong="H5971"\+w* refugiará en el \+w Nombre|strong="H8034"\+w* \+w de|strong="H5971"\+w* \+nd \+w Yavé|strong="H3068"\+w*\+nd*.\wj*  
\v 13 \wj \+w El|strong="H3588"\+w* remanente \+w de|strong="H3588"\+w* \+w Israel|strong="H3478"\+w* \+w no|strong="H3808"\+w* \+w hará|strong="H6213"\+w* injusticia, \+w ni|strong="H3808"\+w* dirá \+w mentiras|strong="H3577"\+w*, \+w ni|strong="H3808"\+w* \+w se|strong="H3808"\+w* \+w hallará|strong="H4672"\+w* \+w en|strong="H3588"\+w* \+w su|strong="H1992"\+w* \+w boca|strong="H6310"\+w* \+w lengua|strong="H3956"\+w* \+w engañosa|strong="H8649"\+w*, \+w pues|strong="H3588"\+w* \+w ellos|strong="H1992"\+w* \+w se|strong="H3808"\+w* apacentarán \+w y|strong="H3588"\+w* reposarán, \+w sin|strong="H3808"\+w* \+w que|strong="H3588"\+w* alguien \+w los|strong="H1992"\+w* \+w haga|strong="H6213"\+w* temblar.\wj*   
\s1 Regocijo  
\p
\v 14 ¡\w Canta|strong="H7442"\w*, oh \w hija|strong="H1323"\w* de \w Sion|strong="H6726"\w*! ¡Da voces de júbilo, oh \w Israel|strong="H3478"\w*! ¡\w Alégrate|strong="H8055"\w* y regocíjate de \w todo|strong="H3605"\w* \w corazón|strong="H3820"\w*, Oh \w hija|strong="H1323"\w* de Jerusalén!  
\v 15 \nd \+w Yavé|strong="H3068"\+w*\nd* apartó tus \w juicios|strong="H4941"\w*. \w Echó|strong="H5493"\w* fuera tus enemigos. \nd \+w Yavé|strong="H3068"\+w*\nd*, el \w Rey|strong="H4428"\w* \w de|strong="H5750"\w* \w Israel|strong="H3478"\w*, está \w en|strong="H5493"\w* \w medio|strong="H7130"\w* \w de|strong="H5750"\w* ti. ¡\w Ya|strong="H3068"\w* \w no|strong="H3808"\w* \w temerás|strong="H3372"\w* \w al|strong="H4428"\w* desastre!  
\v 16 En \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w se|strong="H1931"\w* dirá \w a|strong="H3068"\w* Jerusalén: ¡No \w temas|strong="H3372"\w*, oh \w Sion|strong="H6726"\w*, ni \w se|strong="H1931"\w* debiliten tus \w manos|strong="H3027"\w*!  
\v 17 ¡\nd \+w Yavé|strong="H3068"\+w*\nd* tu \nd ʼElohim\nd* \w está|strong="H5921"\w* \w en|strong="H5921"\w* \w medio|strong="H7130"\w* \w de|strong="H5921"\w* \w ti|strong="H5921"\w*! \w El|strong="H5921"\w* \w Poderoso|strong="H1368"\w* \w salvará|strong="H3467"\w*. \w Se|strong="H5921"\w* gozará \w contigo|strong="H5921"\w* alegremente \w y|strong="H5921"\w* \w te|strong="H5921"\w* tranquilizará \w con|strong="H5921"\w* su amor. \w Se|strong="H5921"\w* regocijará \w por|strong="H5921"\w* \w ti|strong="H5921"\w* \w con|strong="H5921"\w* cánticos.   
\p
\v 18 \wj Reuniré \+w a|strong="H3068"\+w* \+w los|strong="H5921"\+w* \+w que|strong="H4480"\+w* lloran apartados \+w de|strong="H4480"\+w* \+w ti|strong="H5921"\+w*. \+w Como|strong="H1961"\+w* \+w en|strong="H5921"\+w* \+w los|strong="H5921"\+w* días \+w de|strong="H4480"\+w* fiesta solemne \+w te|strong="H5921"\+w* libraré \+w del|strong="H4480"\+w* \+w oprobio|strong="H2781"\+w* \+w que|strong="H4480"\+w* pesa \+w sobre|strong="H5921"\+w* \+w ti|strong="H5921"\+w*.\wj*  
\v 19 \wj \+w Ciertamente|strong="H2005"\+w* en \+w aquel|strong="H1931"\+w* \+w tiempo|strong="H6256"\+w* convertiré \+w a|strong="H3068"\+w* \+w todos|strong="H3605"\+w* tus \+w opresores|strong="H6031"\+w* en oprobio. Pero \+w salvaré|strong="H3467"\+w* \+w a|strong="H3068"\+w* \+w la|strong="H1931"\+w* \+w que|strong="H1931"\+w* cojea y \+w recogeré|strong="H6908"\+w* \+w a|strong="H3068"\+w* \+w la|strong="H1931"\+w* descarriada. Las \+w pondré|strong="H7760"\+w* \+w como|strong="H1931"\+w* objeto \+w de|strong="H6256"\+w* \+w alabanza|strong="H8416"\+w* y renombre en \+w todas|strong="H3605"\+w* las naciones \+w donde|strong="H8034"\+w* fueron avergonzadas.\wj*  
\v 20 \wj \+w En|strong="H3588"\+w* \+w ese|strong="H1931"\+w* \+w tiempo|strong="H6256"\+w* \+w los|strong="H3605"\+w* traeré \+w y|strong="H3588"\+w* \+w en|strong="H3588"\+w* \+w esa|strong="H1931"\+w* ocasión \+w los|strong="H3605"\+w* \+w recogeré|strong="H6908"\+w*. \+w Los|strong="H3605"\+w* \+w haré|strong="H5414"\+w* motivo \+w de|strong="H3588"\+w* \+w alabanza|strong="H8416"\+w* \+w y|strong="H3588"\+w* renombre \+w entre|strong="H3588"\+w* \+w todos|strong="H3605"\+w* \+w los|strong="H3605"\+w* \+w pueblos|strong="H5971"\+w* \+w de|strong="H3588"\+w* \+w la|strong="H1931"\+w* tierra \+w cuando|strong="H3588"\+w* \+w Yo|strong="H3588"\+w* \+w los|strong="H3605"\+w* restaure \+w de|strong="H3588"\+w* \+w su|strong="H1931"\+w* cautiverio ante \+w sus|strong="H1931"\+w* mismos \+w ojos|strong="H5869"\+w*, \wj*dice \nd \+w Yavé|strong="H3068"\+w*\nd*.   