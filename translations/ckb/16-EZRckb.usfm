\id EZR - Biblica® Open Kurdi Sorani Standard Version 
\h عەزرا 
\toc1 عەزرا 
\toc2 عەزرا 
\toc3 عەزرا 
\mt1 عەزرا 
\c 1  
\s1 پشتگیری کۆرش بۆ گەڕانەوەی ڕاپێچکراوەکان 
\p  
\v 1 لە ساڵی یەکەمی کۆرشی پاشای فارس، بۆ بەدیهێنانی پەیامی یەزدان کە لەسەر زاری یەرمیاوە فەرمووبووی، یەزدان ڕۆحی کۆرشی پاشای فارسی هەژاند. ئینجا بانگەوازێکی بەناو هەموو شانشینەکەیدا ڕاگەیاند، هەروەها بە نووسراویش فەرمانی دا: 
\pmo  
\v 2 «کۆرشی پاشای فارس ئاوا دەڵێت: 
\pm «”یەزدان، خودای ئاسمان هەموو شانشینەکانی زەوی داوەتە دەستم، ڕایسپاردووم پەرستگایەکی لە ئۆرشەلیمی یەهودا بۆ بنیاد بنێم.  
\v 3 هەرکەسێک لە ئێوە کە سەر بە گەلەکەی ئەوە، با خودای خۆی لەگەڵ بێت و بەرەو ئۆرشەلیمی یەهودا بڕوات، پەرستگاکەی یەزدانی پەروەردگاری ئیسرائیل بنیاد بنێتەوە، ئەو یەزدانەی کە لە ئۆرشەلیمە.  
\v 4 هەرکەسێکیش لە هەر شوێنێک کە تێیدا ئاوارەیە و ماوەتەوە، با دانیشتووانی شوێنەکەی بە زێڕ و زیو و کەلوپەل و ئاژەڵی ماڵی یارمەتی بدەن، لەگەڵ ئەو بەخشینە ئازادانەی\f + \fr 1:4 \ft بەخشینە ئازاد: بڕوانە \xt دەرچوون 35‏:29 و 36‏:3.‏\ft ‏\f* کە دەیبەخشن بۆ پەرستگای خودا لە ئۆرشەلیم.“» 
\p  
\v 5 ئینجا گەورەی بنەماڵەکانی یەهودا و بنیامین لەگەڵ کاهین و لێڤییەکان، هەموو ئەوانەی خودا ڕۆحی هەژاندن، هەستان بۆ ئەوەی بچنە ئۆرشەلیم تاکو لەوێ ماڵەکەی یەزدان بنیاد بنێنەوە.  
\v 6 هەموو دراوسێکانیان بە قاپوقاچاغی زێڕ و زیو، بە کەلوپەل و ئاژەڵی ماڵی و بە دیاری نایاب یارمەتییان دان، سەرباری هەموو بەخشینە ئازادەکان. 
\p  
\v 7 کۆرشی پاشاش قاپوقاچاغەکانی پەرستگای یەزدانی دەرهێنا، ئەوانەی نەبوخودنەسر لە ئۆرشەلیمەوە دەریهێنابوون و لە پەرستگای خوداوەندەکەی خۆی داینابوو.  
\v 8 کۆرشی پاشای فارس لەسەر دەستی میترەداتی خەزنەدار دەریهێنا، ئەویش بۆ شێشبەچەری میری یەهودای ژماردن. 
\b  
\li4  
\v 9 ئەمەش ژمارەکەیانە: 
\b  
\li1 سی لەگەنی زێڕین و هەزار لەگەنی زیوین؛ 
\li1 بیست و نۆ تاوەی زیوین؛ 
\li1  
\v 10 سی جامی زێڕین لەگەڵ چوار سەد و دە جامی زیوین؛ 
\li1 هەزار پارچە قاپوقاچاغی دیکە. 
\b  
\li4  
\v 11 هەموو ئەو قاپوقاچاغەنەی لە زێڕ و زیو بوون، پێنج هەزار و چوار سەد پارچە بوون. 
\b  
\p لەگەڵ سەرکەوتنی ڕاپێچکراوەکان لە بابلەوە بۆ ئۆرشەلیم شێشبەچەر هەموو ئەمانەی لەگەڵ خۆی هێنا. 
\c 2  
\s1 ئەوانەی لە ڕاپێچکراوی گەڕانەوە 
\li4  
\v 1 ئەمانەش خەڵکی هەرێمەکەن، ئەوانەی لە ڕاپێچکراوی گەڕانەوە، ئەوانەی نەبوخودنەسری پاشای بابل بۆ بابل ڕاپێچی کردبوون (ئەوان گەڕانەوە ئۆرشەلیم و یەهودا، هەریەکە بۆ شارۆچکەکەی خۆی،  
\v 2 لەگەڵ زروبابل، یەشوع، نەحەمیا، سەرایا، ڕەعێلایا، مۆردەخای، بیلشان، میسپار، بیگڤەی، ڕەحوم و بەعەنا): 
\b  
\li4 ژمارەی پیاوانی گەلی ئیسرائیل: 
\li1  
\v 3 نەوەی پەرعۆش، دوو هەزار و سەد و حەفتا و دوو؛ 
\li1  
\v 4 نەوەی شەفەتیا، سێ سەد و حەفتا و دوو؛ 
\li1  
\v 5 نەوەی ئارەح، حەوت سەد و حەفتا و پێنج؛ 
\li1  
\v 6 نەوەی پەحەت‌مۆئاب لە نەوەی یێشوع و یۆئاب، دوو هەزار و هەشت سەد و دوازدە؛ 
\li1  
\v 7 نەوەی ئیلام، هەزار و دوو سەد و پەنجا و چوار؛ 
\li1  
\v 8 نەوەی زەتو، نۆ سەد و چل و پێنج؛ 
\li1  
\v 9 نەوەی زەکای، حەوت سەد و شەست؛ 
\li1  
\v 10 نەوەی بانی، شەش سەد و چل و دوو؛ 
\li1  
\v 11 نەوەی بێڤەی، شەش سەد و بیست و سێ؛ 
\li1  
\v 12 نەوەی عەزگاد، هەزار و دوو سەد و بیست و دوو؛ 
\li1  
\v 13 نەوەی ئەدۆنیقام، شەش سەد و شەست و شەش؛ 
\li1  
\v 14 نەوەی بیگڤەی، دوو هەزار و پەنجا و شەش؛ 
\li1  
\v 15 نەوەی عادین، چوار سەد و پەنجا و چوار؛ 
\li1  
\v 16 نەوەی ئاتێر لە حەزقیا، نەوەد و هەشت؛ 
\li1  
\v 17 نەوەی بێسای، سێ سەد و بیست و سێ؛ 
\li1  
\v 18 نەوەی یۆرا، سەد و دوازدە؛ 
\li1  
\v 19 نەوەی حاشوم، دوو سەد و بیست و سێ؛ 
\li1  
\v 20 نەوەی گیبار، نەوەد و پێنج. 
\b  
\li1  
\v 21 پیاوانی بێت‌لەحم، سەد و بیست و سێ؛ 
\li1  
\v 22 پیاوانی نەتۆفا، پەنجا و شەش؛ 
\li1  
\v 23 پیاوانی عەناتۆت، سەد و بیست و هەشت؛ 
\li1  
\v 24 پیاوانی عەزماڤێت، چل و دوو؛ 
\li1  
\v 25 پیاوانی قیریەت یەعاریم، کەفیرا و بئێرۆت، حەوت سەد و چل و سێ؛ 
\li1  
\v 26 پیاوانی ڕامە و گەڤەع، شەش سەد و بیست و یەک؛ 
\li1  
\v 27 پیاوانی میخماس، سەد و بیست و دوو؛ 
\li1  
\v 28 پیاوانی بێت‌ئێل و عای، دوو سەد و بیست و سێ؛ 
\li1  
\v 29 پیاوانی نەبۆ، پەنجا و دوو؛ 
\li1  
\v 30 پیاوانی مەگبیش، سەد و پەنجا و شەش؛ 
\li1  
\v 31 پیاوانی ئیلامەکەی دیکە، هەزار و دوو سەد و پەنجا و چوار؛ 
\li1  
\v 32 پیاوانی حاریم، سێ سەد و بیست؛ 
\li1  
\v 33 پیاوانی لۆد، حادید و ئۆنۆ، حەوت سەد و بیست و پێنج؛ 
\li1  
\v 34 پیاوانی ئەریحا، سێ سەد و چل و پێنج؛ 
\li1  
\v 35 پیاوانی سەنائا، سێ هەزار و شەش سەد و سی. 
\b  
\li4  
\v 36 کاهینەکان: 
\li1 نەوەی یەدایا لە بنەماڵەی یێشوع، نۆ سەد و حەفتا و سێ. 
\li1  
\v 37 نەوەی ئیمێر، هەزار و پەنجا و دوو. 
\li1  
\v 38 نەوەی پەشحور، هەزار و دوو سەد و چل و حەوت. 
\li1  
\v 39 نەوەی حاریم، هەزار و حەڤدە. 
\b  
\li4  
\v 40 لێڤییەکان: 
\li1 نەوەی یێشوع و قەدمیێل لە نەوەی هۆدەڤیا، حەفتا و چوار. 
\b  
\li4  
\v 41 گۆرانیبێژەکان: 
\li1 نەوەی ئاساف، سەد و بیست و هەشت. 
\b  
\li4  
\v 42 نەوەی دەرگاوانەکانی پەرستگا: 
\li1 نەوەکانی 
\li2 شەلوم، ئاتێر، تەلمۆن، عەقوڤ، حەتیتا و شۆڤای، هەموویان سەد و سی و نۆ. 
\b  
\li4  
\v 43 خزمەتکارانی پەرستگا: 
\li1 نەوەکانی 
\li2 چیحا، حەسوفا، تەباعۆت، 
\li2  
\v 44 قێرۆس، سیعەها، پادۆن، 
\li2  
\v 45 لەڤانا، حەگاڤا، عەقوڤ، 
\li2  
\v 46 حاگاڤ، شەلمای، حانان، 
\li2  
\v 47 گیدێل، گەحەر، ڕەئایا، 
\li2  
\v 48 ڕەچین، نەقۆدا، گەزام، 
\li2  
\v 49 عوزە، پاسێیەح، بێسەی، 
\li2  
\v 50 ئەسنا، مەعونیم، نەفوسیم، 
\li2  
\v 51 بەقبوق، حەقوفا، حەرحور، 
\li2  
\v 52 بەچلوت، مەحیدا، حەرشا، 
\li2  
\v 53 بەرقۆس، سیسرا، تەمەح، 
\li2  
\v 54 نەچیەح و حەتیفا. 
\li4  
\v 55 نەوەی خزمەتکارەکانی سلێمان: 
\li1 نەوەکانی 
\li2 سۆتەی، هەسۆفەرەت، پەرودا، 
\li2  
\v 56 یەعلا، دەرکۆن، گیدێل، 
\li2  
\v 57 شەفەتیا، حەتیل، 
\li2 پۆخەرەت‌هەچەڤایم و ئامی. 
\li4  
\v 58 سەرجەم خزمەتکارانی پەرستگا و نەوەکانی خزمەتکارانی سلێمان، سێ سەد و نەوەد و دوو بوون. 
\b  
\li4  
\v 59 ئەمانەش ئەوانەن کە لە شارۆچکەکانی تێل‌مەلەح، تێل‌حەرشا، کەروڤ، ئەدۆن و ئیمێرەوە سەرکەوتن، بەڵام نەیانتوانی پێناسەی بنەماڵە و ڕەچەڵەکیان دیاری بکەن کە لە نەوەی ئیسرائیلن: 
\li1  
\v 60 نەوەکانی 
\li2 دەلایا، تۆڤییا و نەقۆدا، شەش سەد و پەنجا و دوو. 
\b  
\li4  
\v 61 لە نەوەی کاهینەکانیش: 
\li1 نەوەکانی 
\li2 حۆڤەیا، هەقۆچ و بەرزیلەی، کە کچێکی بەرزیلەیی گلعادی هێنا و ناوی ئەوی لێنرا. 
\li4  
\v 62 ئەمانە بەدوای ڕەچەڵەکنامەکانیاندا گەڕان، بەڵام نەدۆزرانەوە، لەبەر ئەوە لە کاهینیێتی قەدەغە کران.  
\v 63 پارێزگارەکە پێی گوتن کە نابێت لە خواردنە هەرەپیرۆزەکان بخۆن هەتا ئەو کاتەی کاهینێک بۆ ئوریم و تومیم\f + \fr 2:63 \ft دوو بەردی گرانبەها بوون، لە کاتی بڕیاردان بۆ زانینی خواستی خودا بەکارهێنراون، بڕوانە \xt دەرچوون 28‏:30 و یەکەم ساموئێل 23‏:9‏-12.‏\ft ‏\f* دادەنرێت. 
\b  
\li4  
\v 64 هەموو کۆمەڵەکە پێکەوە چل و دوو هەزار و سێ سەد و شەست کەس بوون،  
\v 65 جگە لە خزمەتکار و کارەکەرەکانیان کە حەوت هەزار و سێ سەد و سی و حەوت کەس بوون، هەروەها دوو سەد گۆرانیبێژی پیاو و ژنیان هەبوو.  
\v 66 حەوت سەد و سی و شەش ئەسپ، دوو سەد و چل و پێنج هێستر،  
\v 67 چوار سەد و سی و پێنج وشتر و شەش هەزار و حەوت سەد و بیست گوێدرێژیشیان لەگەڵدا بوو. 
\b  
\p  
\v 68 هەندێک لە گەورەی بنەماڵەکان لە کاتی گەیشتنیان بۆ ماڵی یەزدان لە ئۆرشەلیم، بە خواستی دڵی خۆیان بەخشینی ئازادیان پێشکەش کرد بۆ ماڵی یەزدان، بۆ بنیادنانەوەی ماڵی یەزدان لە شوێنەکەی خۆی.  
\v 69 بەپێی توانای خۆیان بە گەنجینەی بەڕێوەبردنی کارەکەیان بەخشی، شەست و یەک هەزار درهەمی زێڕ و پێنج هەزار مەنای\f + \fr 2:69 \ft پێنج هەزار مەنا: نزیکەی 2900 کیلۆگرام.‏\f* زیو، لەگەڵ سەد کراس بۆ کاهینەکان. 
\p  
\v 70 کاهین، لێڤی، گۆرانیبێژ، دەرگاوان و خزمەتکارانی پەرستگا، لەگەڵ هەندێک کەسانی دیکە، لە شارۆچکەکانی خۆیاندا نیشتەجێ بوون، پاشماوەی ئیسرائیلییەکانیش لە شارۆچکەکانی خۆیان نیشتەجێ بوون. 
\c 3  
\s1 بنیادنانەوەی قوربانگاکە 
\p  
\v 1 کاتێک مانگی حەوت\f + \fr 3:1 \fq مانگی حەوت \ft ئەو مانگەی ساڵنامەی عیبرانی دەکەوێتە کۆتایی مانگی ئەیلول و زۆربەی تشرینی یەکەم.\f* هات، نەوەی ئیسرائیل لە شارۆچکەکانی خۆیان جێگیر بوون، ئینجا گەل وەک یەک کەس لە ئۆرشەلیم کۆبوونەوە.  
\v 2 یەشوعی کوڕی یۆچاداق و برا کاهینەکانی، لەگەڵ زروبابلی کوڕی شەئەلتیێل و هاوکارەکانی، دەستیان بە بنیادنانەوەی قوربانگاکەی خودای ئیسرائیل کرد بۆ ئەوەی قوربانی سووتاندنی لەسەر پێشکەش بکەن، هەروەک لە تەوراتی موسای پیاوی خودا نووسراوە.  
\v 3 لەگەڵ ئەوەی ترسی گەلانی دەوروبەری لە دڵدا بوو، قوربانگاکەیان لە شوێنەکەی خۆیدا بنیاد نایەوە و قوربانی سووتاندنیان لەسەری بۆ یەزدان پێشکەش کرد، قوربانی سووتاندنی بەیانییان و ئێواران.  
\v 4 بەپێی ئەوەی کە نووسرابوو جەژنی کەپرەشینەیان\f + \fr 3:4 \ft جەژنێکی جولەکەیە، بڕوانە (دواوتار 16‏:13).‏\f* گێڕا، بەگوێرەی ئەو ژمارەیەی کە دیاری کرابوو قوربانی سووتاندنی ڕۆژانەیان پێشکەش دەکرد، کاری هەر ڕۆژێک لە ڕۆژی خۆیدا.  
\v 5 پاشان قوربانی سووتاندنی بەردەوام و قوربانی سەرەمانگ و قوربانی هەموو جەژنە پیرۆزەکانی یەزدانیشیان پێشکەش کرد، بێجگە لە بەخشینە ئازادەکان کە هەر یەکێک بە خواستی دڵی خۆی پێشکەشی یەزدانی دەکرد.  
\v 6 لە ڕۆژی یەکەمی مانگی حەوتەوە دەستیان کرد بە پێشکەشکردنی قوربانی سووتاندن بە یەزدان، هەرچەندە بناغەی پەرستگای یەزدانیش هێشتا دانەمەزرابوو. 
\s1 بنیادنانەوەی پەرستگا 
\p  
\v 7 زیویان دایە نەقاڕ و دارتاشەکان، هەروەها خواردن و خواردنەوە و زەیتیان دایە سەیدائی و سورییەکان بۆ ئەوەی داری ئورز بە ڕێی دەریادا لە لوبنانەوە بهێننە یافا، بەپێی ئەو موڵەتەی کۆرشی پاشای فارس پێیدابوون. 
\p  
\v 8 لە ساڵی دووەمی هاتنیان بۆ ماڵی خودا لە ئۆرشەلیم، لە مانگی دوو، زروبابلی کوڕی شەئەلتیێل، لەگەڵ یەشوعی کوڕی یۆچاداق و پاشماوەی برا کاهین و لێڤییەکانیان و هەموو ئەوانەی لە ڕاپێچکراوی گەڕابوونەوە ئۆرشەلیم، دەستیان بە کار کرد. ئەو لێڤییانەی کە بیست ساڵ و بەرەو سەرەوە بوون، دایاننان بۆ چاودێریکردنی کارەکەی ماڵی یەزدان.  
\v 9 هەروەها یەشوع و کوڕ و براکانی، قەدمیێل و کوڕەکانی لە نەوەی هۆدەڤیا، هەروەها نەوەی حێناداد و کوڕ و براکانی کە هەموویان لێڤی بوون، پێکەوە ڕاوەستان بۆ چاودێریکردنی ئەو کرێکارانەی کارەکەی ماڵی خودایان دەکرد. 
\p  
\v 10 کە بیناسازەکان بناغەی پەرستگاکەی یەزدانیان دامەزراند، بەپێی ڕێکخستنەکەی داودی پاشای ئیسرائیل کاهینەکان بە جلوبەرگ و کەڕەناوە چوونە شوێنی خۆیان، هەروەها لێڤییەکانی نەوەی ئاسافیش بە سەنجەوە چوونە شوێنی خۆیان تاکو ستایشی یەزدان بکەن.  
\v 11 بە ستایش و سوپاسەوە گۆرانییان بۆ یەزدان گوت: 
\q1 «بێگومان خودا چاکە، 
\q2 بۆ هەتاهەتایە خۆشەویستییە نەگۆڕەکەی بۆ ئیسرائیل بەردەوام دەبێت.» 
\m هەموو گەلیش بە دەنگی بەرز بە ستایشەوە هاواریان بۆ یەزدان دەکرد، لەبەر دامەزراندنی بناغەی ماڵی یەزدان.  
\v 12 بەڵام زۆربەی کاهین و لێڤی و گەورەی بنەماڵەکان کە پیر بوون، ئەوانەی پەرستگاکەی یەکەمیان بینیبوو، لە کاتی دامەزراندنی بناغەی ئەم پەرستگایە لەپێش چاویاندا بە دەنگێکی بەرز گریان، زۆریش هەبوو بە دەنگی بەرز هاواری خۆشییان دەکرد.  
\v 13 کەس نەیدەتوانی هاواری خۆشی لە دەنگی گریان جیا بکاتەوە، چونکە گەل بە دەنگی بەرز هاواریان دەکرد، تەنانەت لە دووریشەوە دەنگەکە دەبیسترا. 
\c 4  
\s1 دژایەتییەکانی بنیادنانەوە 
\p  
\v 1 کاتێک دوژمنەکانی یەهودا و بنیامین بیستیانەوە ئەوانەی لە ڕاپێچکراوی گەڕابوونەوە پەرستگایەکیان بۆ یەزدانی پەروەردگاری ئیسرائیل بنیاد دەنایەوە،  
\v 2 هاتن بۆ لای زروبابل و گەورەی بنەماڵەکان و پێیان گوتن: «با لەگەڵتان بنیاد بنێین، چونکە ئێمەش وەک ئێوەین و داوا لە خوداکەتان دەکەین، لە ماوەی پاشایەتی ئێسەرحەدۆنی پاشای ئاشورەوە ئێمەی بۆ ئێرە هێناوە، قوربانیمان سەربڕیوە.» 
\p  
\v 3 بەڵام زروبابل و یەشوع و پاشماوەی گەورەی بنەماڵەکانی ئیسرائیل وەڵامیان دانەوە: «بۆتان نییە لەگەڵ ئێمە پەرستگای خودامان بنیاد بنێنەوە، بەڵکو ئێمە بە تەنها بۆ یەزدانی پەروەردگاری ئیسرائیلی بنیادی دەنێین، بەو شێوەیەی کۆرشی پاشا، پاشای فارس فەرمانی پێ کردووین.» 
\p  
\v 4 جا گەلانی خاکەکە دەستی گەلی یەهودایان شل دەکردەوە و لە بیناکردنەکە دەیانترساندن،  
\v 5 چەند ڕاوێژکارێکیان بۆ پووچەڵکردنەوەی پلانەکەیان بە کرێ گرت، بە درێژایی سەردەمی کۆرشی پاشای فارس هەتا پاشایەتی داریوشی پاشای فارس.\f + \fr 4:5 \ft مێژووی بنیادنانەوەی پەرستگاکە لە 4‏:24 دەستپێدەکات.‏\f* 
\s1 بەربەرەکانێ لە دژی بنیادنانەوەی شار 
\p  
\v 6 لە سەرەتای پاشایەتی ئەحەشوێرۆش، سکاڵانامەیەکیان لە دژی دانیشتووانی یەهودا و ئۆرشەلیم نووسی. 
\p  
\v 7 هەروەها لە سەردەمی پاشایەتی ئەرتەحشەستەی پاشای فارس، بیشلام و میترەدات و تاڤئێل و سەرجەم یاوەرەکانیان نامەیەکیان بۆ ئەرتەحشەستەی نووسی، نامەکەش بە پیت و زمانی ئارامی نووسرا.\f + \fr 4:7 \ft دەقی 4‏:8 هەتا 6‏:18 بە زمانی ئارامی نووسراوە.‏\f* 
\p  
\v 8 ڕەحومی فەرماندە و شیمشەیی خامەی نهێنی\f + \fr 4:8 \ft ڕازپۆش.‏\f* نامەیەکیان لە دژی ئۆرشەلیم بۆ ئەرتەحشەستەی پاشا بەم شێوە نووسی: 
\pmo  
\v 9 ڕەحومی فەرماندە و شیمشەیی خامەی نهێنی و سەرجەم یاوەرەکانیان، کە لە دادوەر و کاربەدەست و بەرپرسانی گەلی فارس و ئەرەک و بابل و ئیلامییەکانی شوش  
\v 10 و سەرجەم ئەو نەتەوانە پێکهاتبوون کە ئەشوربەنیپەلی گەورە و بەڕێز ڕاپێچی کردن، لە شاری سامیرە و چەند شوێنێکی دیکە لە هەرێمی ئەوبەری فورات نیشتەجێی کردن. 
\p  
\v 11 ئەمەش وێنەی ئەو نامەیەیە کە بۆیان نارد. 
\pmo بۆ ئەرتەحشەستەی پاشا، 
\pmo خزمەتکارانت، پیاوانی هەرێمی ئەوبەری فورات: 
\pm  
\v 12 با پاشا بزانێت کە ئەو جولەکانەی لەلای تۆوە سەرکەوتن بۆ لامان، هاتوون بۆ ئۆرشەلیم و ئەو شارە یاخی و خراپە بنیاد دەنێنەوە، شووراکانیش تەواو دەکەن و بناغەکان چاک دەکەنەوە. 
\pm  
\v 13 با ئێستا لەلای پاشا زانراو بێت کە ئەگەر ئەم شارە بنیاد بنرێتەوە و شووراکانی تەواو بکرێن، چیتر سەرانە و گومرگ و باج نادرێت، لە کۆتاییشدا زیان لە پاشاکان دەکەوێت.  
\v 14 ئێستاش لەبەر ئەوەی ئێمە نمەکی کۆشکی پاشا دەکەین و شیاویش نییە زیانی پاشا ببینین، لەبەر ئەوە بۆ ئاگادارکردنەوەی پاشا ئەم نامەیە دەنێرین،  
\v 15 بۆ ئەوەی لێکۆڵینەوەیەک لە ئەرشیفی شاهانەی باوباپیرانتدا بکرێت. ئینجا لە ئەرشیفی شاهانە دەبینیتەوە و دەزانیت کە ئەم شارە شارێکی یاخییە و زیانبەخشە بە پاشاکان و هەرێمەکان، لە دێرزەمانەوە یاخیبوونیان لەناویدا بەرپا کردووە، لەبەر ئەوە ئەم شارە کاول کرا.  
\v 16 ئێمەش پاشا ئاگادار دەکەینەوە کە ئەگەر ئەم شارە بنیاد بنرێت و شووراکانی تەواو بکرێن، ئیتر لە هەرێمی ئەوبەری فوراتەوە بەشت نابێت. 
\p  
\v 17 پاشا ئەم وەڵامەی نارد: 
\pmo بۆ ڕەحومی فەرماندە و شیمشەیی خامەی نهێنی و سەرجەم یاوەرەکانیان کە لە سامیرە و شوێنەکانی دیکەی هەرێمی ئەوبەری فورات نیشتەجێن: 
\pmo پاش سڵاو. 
\pm  
\v 18 ئەو نامەیەی بۆتان ناردین بە ڕوونی لەبەردەممدا خوێنرایەوە و وەرگێڕدرا.  
\v 19 فەرمانێکم دەرکرد و لێکۆڵینەوەیەک کرا، دەرکەوت کە ئەم شارە لە دێرزەمانەوە لە دژی پاشایان وەستاوەتەوە و یاخیبوون و سەرپێچیکردنی تێدا بەرپا کراوە.  
\v 20 ئۆرشەلیم پاشای بە توانای هەبووە و دەسەڵاتیان بەسەر هەموو هەرێمی ئەوبەری فوراتدا ڕۆیشتووە، سەرانە و گومرگ و باجیان پێدراوە.  
\v 21 ئێستاش فەرمانێک بۆ دەست لە کار هەڵگرتنی ئەم پیاوانە دەربکەن، ئیتر هەتا فەرمان لە منەوە دەرنەچێت ئەو شارە بنیاد نانرێتەوە.  
\v 22 وریابن لەم کارە کەمتەرخەمی نەکەن، نەوەک زیان بە بەرژەوەندی پاشاکان بگات. 
\p  
\v 23 کاتێک نامەکەی ئەرتەحشەستەی پاشا لەبەردەم ڕەحوم و شیمشەیی خامەی نهێنی و یاوەرەکانیاندا خوێنرایەوە، بە پەلە چوون بۆ ئۆرشەلیم بۆ لای جولەکەکان و بە زەبری هێز لە کارەکە ڕایانگرتن. 
\b  
\p  
\v 24 کارەکەی ماڵی خودا لە ئۆرشەلیم ڕاگیرابوو، هەتا دووەم ساڵی پاشایەتی داریوشی پاشای فارس.\f + \fr 4:24 \ft ڕووداوەکانی 4‏:6‏-24 پاش ڕووداوەکانی 4‏:24‏–10‏:22 بوون.‏\f* 
\c 5  
\s1 نامەی تەتەنەی بۆ داریوش 
\p  
\v 1 حەگەی پێغەمبەر و زەکەریای پێغەمبەر لە نەوەی عیدۆ، بە ناوی خودای ئیسرائیل کە دەسەڵاتی بەسەریانەوە هەبوو پەیامی خودایان بۆ ئەو جولەکانە ڕاگەیاند کە لە یەهودا و ئۆرشەلیم بوون.  
\v 2 ئیتر زروبابلی کوڕی شەئەلتیێل و یەشوعی کوڕی یۆچاداق هەستان و دەستیان بە بنیادنانەوەی ماڵەکەی خودا کرد لە ئۆرشەلیم، پێغەمبەرەکانی خوداش لەگەڵیان بوون و یارمەتییان دەدان. 
\p  
\v 3 لەو کاتەدا تەتەنەیی پارێزگاری هەرێمی ئەوبەری فورات و شەتاربوزەنەی و یاوەرەکانیان چوونە لایان و لێیان پرسین: «کێ ڕێگای پێدان ئەم پەرستگایە بنیاد بنێنەوە و ئەم تەلارە تەواو بکەن؟»  
\v 4 هەروەها لێیان پرسین: «ئەو پیاوانە ناویان چییە کە ئەم تەلارە بنیاد دەنێنەوە؟»  
\v 5 بەڵام پیرانی جولەکەش خودای خۆیان چاودێری دەکردن، ئیتر لە کارەکە ڕایاننەگرتن هەتا هەواڵەکە بە داریوش گەیشتەوە، ئینجا بە نامەیەک دەربارەی ئەمە وەڵامیان دایەوە. 
\p  
\v 6 ئەمەش وێنەیەکی ئەو نامەیەی تەتەنەی پارێزگاری هەرێمی ئەوبەری فورات و شەتاربوزەنەی و یاوەرەکانیان، ئەوانەی کە کاربەدەستەکانی هەرێمی ئەوبەری فورات بوون، بۆ داریوشیان نارد.  
\v 7 ئەو هەواڵەی کە بۆیان نارد بەم شێوەیە نووسرابوو: 
\pmo بۆ داریوشی پاشا: 
\pmo سڵاوێکی گەرم. 
\pm  
\v 8 با لەلای پاشا زانراو بێت کە ئێمە چووینە ناوچەی یەهودا، بۆ پەرستگای خودای گەورە، بینیمان بە بەردی گەورە بنیاد دەنرێتەوە و کاریتە لەناو دیوارەکانی دادەنرێت، ئەم کارەش بە وردی دەکرێت و لەژێر سەرپەرشتییان سەرکەوتووانەیە. 
\pm  
\v 9 پرسیارمان لەو پیرانە کرد و لێمان پرسین: «کێ ڕێگای پێداون ئەم پەرستگایە بنیاد بنێنەوە و ئەم تەلارە تەواو بکەن؟»  
\v 10 هەروەها پرسیاری ناوەکانیانمان لێکردن تاوەکو بتوانین ناوی ڕابەرەکانیان بۆ زانیاریت بنووسین. 
\pm  
\v 11 بەم شێوەیە وەڵامیان داینەوە و گوتیان: 
\b  
\pm «ئێمە خزمەتکارانی خودای ئاسمان و زەوین، ئەم پەرستگایە بنیاد دەنێینەوە کە پێش ساڵانێکی زۆر بنیاد نرابوو، پاشایەکی گەورەی ئیسرائیل بنیادی نا و تەواوی کرد.  
\v 12 بەڵام دوای ئەوەی باوباپیرانمان خودای ئاسمانیان تووڕە کرد، ئەوانی دا بەدەست نەبوخودنەسری پاشای بابلی کلدانییەوە، ئەوەی کە ئەم پەرستگایەی وێران کرد و گەلەکەی بۆ بابل ڕاپێچ کرد. 
\pm  
\v 13 «بەڵام لە یەکەم ساڵی کۆرشی پاشای بابل، کۆرشی پاشا فەرمانی دەرکرد بۆ بنیادنانەوەی ئەم ماڵەی خودا.  
\v 14 کۆرشی پاشا تەنانەت قاپوقاچاغەکانی ئەم پەرستگایەی خودای لە پەرستگای بابلەوە دەرهێنا، کە لە زێڕ و زیوە، ئەوەی نەبوخودنەسر لەم پەرستگایەی ئۆرشەلیمی دەرهێنابوو و بۆ ئەو پەرستگایەی بردبوو کە لە بابلە. ئینجا کۆرشی پاشا قاپوقاچاغەکانی دایە یەکێک کە ناوی شێشبەچەر بوو، ئەوەی کردییە پارێزگار.  
\v 15 پێی گوت: ”ئەم قاپوقاچاغە ببە، بڕۆ و لە پەرستگاکەی ئۆرشەلیمی دابنێ، با پەرستگای خودا لە شوێنەکەی خۆیدا بنیاد بنرێتەوە.“ 
\pm  
\v 16 «لەبەر ئەوە ئەم شێشبەچەرە هات و بناغەکەی ماڵی خودای دانا ئەوەی لە ئۆرشەلیمە، لەو کاتەوە بنیاد دەنرێتەوە، بەڵام هەتا ئێستا تەواو نەکراوە.» 
\b  
\pm  
\v 17 ئێستاش ئەگەر پاشا پێی باشە، با لەنێو ئەرشیفی شاهانەدا بگەڕێن کە لە بابلە، بۆ ئەوەی بزانین بەڕاستی لە کۆرشی پاشاوە فەرمان دەرچووە بۆ بنیادنانەوەی ئەم ماڵەی خودا کە لە ئۆرشەلیمە؟ با پاشا لەم کارەدا خواستی خۆیمان بۆ بنێرێت. 
\c 6  
\s1 فەرمانی داریوش 
\p  
\v 1 ئینجا داریوشی پاشا فەرمانی دا و لەناو ئەرشیفی شاهانەدا گەڕان کە لەنێو گەنجینەی بابل دانرا بوو،  
\v 2 ئەوە بوو لەناو کۆشکی هەمەدان لە هەرێمی میدیا، نووسراوێک دۆزرایەوە کە ئەمەی تێدابوو: 
\pmo یاداشت: 
\pm  
\v 3 کۆرشی پاشا لە یەکەم ساڵی پاشایەتییەکەیدا، سەبارەت بە پەرستگای خودا کە لە ئۆرشەلیمە ئەم فەرمانەی دەرکرد: 
\b  
\pm با پەرستگاکە بنیاد بنرێتەوە، ئەو شوێنەی قوربانی تێدا سەردەبڕن، با بناغەکانی دابمەزرێنن، بەرزییەکەی شەست باڵ\f + \fr 6:3 \ft شەست باڵ: نزیکەی 27 مەتر.‏\f* و پانییەکەی شەست باڵ بێت.  
\v 4 بە سێ ڕیز لە بەردی گەورە و ڕیزێک لە تەختەدار، با خەرجییەکەشی لە گەنجینەی پاشاوە بدرێت.  
\v 5 هەروەها قاپوقاچاغەکانی ماڵی خودا، ئەوەی لە زێڕ و زیوە، ئەوەی نەبوخودنەسر لەو پەرستگایەی لە ئۆرشەلیمە دەریهێنا و هێنایە بابل، با ببردرێتەوە و بگەڕێنرێتەوە بۆ ئەو پەرستگایەی کە لە ئۆرشەلیمە، بۆ شوێنەکەی خۆی و لە ماڵی خودا دابنرێت. 
\b  
\pm  
\v 6 ئێستاش ئەی تەتەنەی پارێزگاری هەرێمی ئەوبەری فورات و ئەی شەتاربوزەنەی و یاوەرە کاربەدەستەکانی هەرێمەکە، لەوێ دوور بکەونەوە.  
\v 7 دەست مەخەنە ناو کاری بنیادنانی پەرستگای خوداوە. با فەرمانڕەوا و پیرانی جولەکەکان ئەم ماڵەی خودا لە شوێنەکەی خۆیدا بنیاد بنێنەوە. 
\pm  
\v 8 من فەرمان دەردەکەم کە دەبێت لە بنیادنانەوەی ئەم ماڵەی خودا لەگەڵ پیرانی جولەکەدا چی بکەن: 
\pm لە پارەی پاشاوە، لە سەرانەی هەرێمی ئەوبەری فورات، بەبێ دواکەوتن خەرجی بەو پیاوانە دەدرێت تاوەکو دەست لە کارەکە هەڵنەگرن.  
\v 9 هەرچیشیان پێویستە، لە جوانەگا\f + \fr 6:9 \ft لەو کاتەوەی کە گوێرەکەی نێر لە شیر دەبڕدرێتەوە پێی دەگوترێت (نۆبەن) یان (جوانەگا).‏\f*، بەران، بەرخ وەک قوربانی سووتاندن بۆ خودای ئاسمان، لەگەڵ گەنم، خوێ، شەراب و زەیت، با ڕۆژانە بەپێی داواکاری ئەو کاهینانەی لە ئۆرشەلیمن بەبێ دواکەوتن پێیان بدرێت، تاکو خاو نەبنەوە  
\v 10 لە پێشکەشکردنی بۆنی ڕەزامەندی بۆ خودای ئاسمان و لە نزاکردن لە پێناوی ژیانی پاشا و کوڕەکانی. 
\pm  
\v 11 هەروەها فەرمان لەلای منەوە دەرچووە کە هەر کەسێک ئەم فەرمانە بشکێنێت، کاریتەیەک لە ماڵەکەی ڕادەکێشرێت و دەکرێتە ستوونێک و دوای کوشتنی، پێوەی دەکرێت. لەبەر ئەم تاوانە ماڵەکەی دەبێتە کەلاوە.  
\v 12 خوداش کە ناوی خۆی لەوێ نیشتەجێ کرد، هەر پاشا و گەلێک لەناودەبات ئەگەر دەستدرێژی بکات بۆ گۆڕینی ئەم فەرمانە یان ڕووخاندنی ئەم پەرستگایەی خودا کە لە ئۆرشەلیمە. 
\pm من داریوشم فەرمانم دا و با بە وردی جێبەجێ بکرێت. 
\s1 تەواوکردن و تەرخانکردنی پەرستگاکە 
\p  
\v 13 ئینجا تەتەنەی پارێزگاری هەرێمی ئەوبەری فورات و شەتاربوزەنەی لەگەڵ یاوەرەکانیان بە وردی جێبەجێیان کرد، بەگوێرەی ئەوەی داریوشی پاشا ناردبووی.  
\v 14 پیرانی جولەکەش بەهۆی ڕاگەیاندنی پەیامی خودا لە لایەن حەگەی پێغەمبەر و زەکەریای نەوەی عیدۆوە، بەردەوام بوون لە بنیادنان و سەرکەوتوو دەبوون. جا بەگوێرەی فەرمانی خودای ئیسرائیل و فەرمانی کۆرش و داریوش و ئەرتەحشەستەی پاشایانی فارس پەرستگاکەیان بنیاد ناوە و تەواویان کرد.  
\v 15 ئیتر لە سیی مانگی ئادار، لە ساڵی شەشەمی پاشایەتی داریوش پاشا ئەم پەرستگایە تەواو بوو. 
\p  
\v 16 نەوەی ئیسرائیلیش لە کاهین و لێڤییەکان و پاشماوەی نەوەی ڕاپێچکراوەکان بە دڵخۆشییەوە ئەم ماڵەی خودایان تەرخان کرد.  
\v 17 قوربانیشیان پێشکەش کرد بۆ تەرخانکردنی ئەم ماڵەی خودا، سەد گا و دوو سەد بەران و چوار سەد بەرخ و دوازدە گیسکی نێر، بۆ قوربانی گوناه لە جیاتی هەموو ئیسرائیل، بەگوێرەی هۆزەکانی ئیسرائیل.  
\v 18 ئینجا کاهینەکانیان لە بەشەکانی خۆیان دانا و لێڤییەکانیش لە بەشەکانیان لەسەر خزمەتەکەی خودا لە ئۆرشەلیم، هەروەک ئەوەی لە پەڕتووکی موسا نووسراوە. 
\s1 جەژنی پەسخە 
\p  
\v 19 ئەوانەی لە ڕاپێچکراوی گەڕانەوە لە چواردەی مانگی یەکدا جەژنی پەسخەیان گێڕا،  
\v 20 چونکە کاهین و لێڤییەکان هەموو خۆیان پاک کردبووەوە، هەموویان بەپێی ڕێوڕەسم پاک بوون و بەرخی پەسخەیان بۆ هەموو نەوەی ڕاپێچکراوەکان و بۆ برا کاهینەکانیان و بۆ خۆیان سەربڕی.  
\v 21 نەوەی ئیسرائیلیش ئەوانەی کە لە ڕاپێچکراوییەکە گەڕابوونەوە لێیان خوارد، لەگەڵ هەموو ئەوانەی خۆیان لە نەریتە گڵاوەکانی نەتەوەکانی خاکەکە جیا کردبووەوە و هاتبوونە پاڵیان، بۆ ئەوەی ڕوویان لە یەزدانی پەروەردگاری ئیسرائیل بکەن.  
\v 22 هەروەها حەوت ڕۆژ بە خۆشییەوە جەژنی فەتیرەیان گێڕا، چونکە یەزدان دڵی پڕکردن لە خۆشی و دڵی پاشای ئاشوری بەلایاندا ڕاکێشا بۆ بەهێزکردنی دەستیان لە کارەکەی پەرستگای خودا، خودای ئیسرائیل. 
\c 7  
\s1 هاتنی عەزرا بۆ ئۆرشەلیم 
\p  
\v 1 پاش ئەم شتانە و لە سەردەمی پاشایەتی ئەرتەحشەستەی پاشای فارس، عەزرا کە کوڕی سەرایا کوڕی عەزەریا کوڕی حیلقیا  
\v 2 کوڕی شەلوم کوڕی سادۆق کوڕی ئەحیتوڤ  
\v 3 کوڕی ئەمەریا کوڕی عەزەریا کوڕی مەرایۆت  
\v 4 کوڕی زەرەحیا کوڕی عوزی کوڕی بوقی  
\v 5 کوڕی ئەبیشوەع کوڕی فینەحاس کوڕی ئەلعازاری کوڕی هارونی سەرۆک کاهین بوو،  
\v 6 ئەم عەزرایە لە بابلەوە سەرکەوت. مامۆستایەکی بە توانا بوو لە تەوراتی موسا، یەزدانی پەروەردگاری ئیسرائیل پێیدابوو. پاشاش هەموو ئەوەی داوای کردبوو پێیدابوو، چونکە یەزدانی پەروەردگاری خۆی لەگەڵی بوو.  
\v 7 هەندێک لە نەوەی ئیسرائیل و لە کاهین و لێڤی و گۆرانیبێژ و دەرگاوان و خزمەتکارانی پەرستگا لەگەڵی بەرەو ئۆرشەلیم سەرکەوتن، لە ساڵی حەوتەمی ئەرتەحشەستەی پاشا. 
\p  
\v 8 عەزرا لە مانگی پێنج لە ساڵی حەوتەمی پاشادا گەیشتە ئۆرشەلیم.  
\v 9 لە یەکی مانگی یەکەوە دەستی پێکردبوو لە بابلەوە سەربکەوێت و لە یەکی مانگی پێنجدا گەیشتە ئۆرشەلیم، بەپێی ئەوەی دەستی چاکەی خوداکەی لەسەری بوو،  
\v 10 چونکە عەزرا بۆ خوێندنی تەوراتی یەزدان و کارکردن پێی تەرخان کردبوو، هەروەها بۆ فێرکردنی فەرز و یاسای تەورات لەناو ئیسرائیلدا. 
\s1 نامەی ئەرتەحشەستەی پاشا بۆ عەزرا 
\p  
\v 11 ئەمەش وێنەی ئەو نامەیەیە کە ئەرتەحشەستەی پاشا دایە عەزرای کاهین و مامۆستای شەریعەت، کە شارەزای فەرمان و فەرزەکانی یەزدان بوو بۆ ئیسرائیل: 
\pmo  
\v 12 لە ئەرتەحشەستەی پاشای پاشایانەوە، 
\pmo بۆ عەزرای کاهین و مامۆستای تەوراتی خودای ئاسمان. 
\pmo پاش سڵاو.\f + \fr 7:12 \ft دەقی ئایەتی 12 بە زمانی ئارامی نووسراوە.‏\f* 
\pm  
\v 13 لەلایەن منەوە فەرمانێک دەرچووە کە هەرکەسێک لەناو پاشایەتییەکەی من لە گەلی ئیسرائیل و کاهین و لێڤییەکان بیەوێت لەگەڵ تۆ خۆبەخشانە بگەڕێتەوە ئۆرشەلیم، با بگەڕێتەوە.  
\v 14 تۆ لەلایەن پاشا و حەوت ڕاوێژکارەکەیەوە نێردراویت بۆ ئەوەی لە یەهودا و ئۆرشەلیم بکۆڵیتەوە، بەگوێرەی تەوراتی خوداکەت کە بە دەستتەوەیە.  
\v 15 هەروەها نێردراویت بۆ بردنی ئەو زێڕ و زیوەش کە پاشا و ڕاوێژکارەکانی بە ئازادی بەخشیویانە بە خودای ئیسرائیل، ئەوەی نشینگەکەی لە ئۆرشەلیمە،  
\v 16 لەگەڵ هەموو ئەو زێڕ و زیوەش کە لە هەرێمی بابل بە دەستت دەکەوێت، هەروەها بەخشینە ئازادەکانی گەل و کاهینەکان کە دەیبەخشن بە پەرستگای خودای خۆیان لە ئۆرشەلیم.  
\v 17 دڵنیابە لەوەی بەم زیوە گا و بەران و بەرخی نێر لەگەڵ پێشکەشکراوی دانەوێڵە و شەراب بکڕیت و لەسەر قوربانگاکەی پەرستگای خوداتان کە لە ئۆرشەلیمە پێشکەشیان بکەیت. 
\pm  
\v 18 هەرچی خۆت و برا جولەکەکانت پێتان باش بوو بە پاشماوەی زێڕ و زیوەکە بیکەن، بەپێی خواستی خودای خۆتان بکەن.  
\v 19 ئەو قاپوقاچاغەش کە بۆ خزمەتی پەرستگای خوداکەت پێت دەدرێت، لەبەردەم خودای ئۆرشەلیم دایبنێ.  
\v 20 پاشماوەی پێویستییەکانی پەرستگای خوداکەت کە بۆت ڕێک دەکەوێت بیدەیت، ئەوا لە گەنجینەکانی پاشاوە بیدە. 
\pm  
\v 21 لە من، لە ئەرتەحشەستەی پاشاوە، فەرمان دەرچووە بۆ هەموو گەنجینەکانی هەرێمی ئەوبەری فورات کە هەرچی عەزرای کاهین و مامۆستای تەوراتی خودای ئاسمان داواتان لێ دەکات، با بە وردی جێبەجێ بکرێت،  
\v 22 هەتا سەد تالنت زیو\f + \fr 7:22 \ft کەمێک زیاتر لە 3,4 تەنی زیو دەبوو.‏\f* و سەد کۆر\f + \fr 7:22 \ft سەد کۆر: نزیکەی 16 تەنی گەنم.‏\f* گەنم و سەد بەت\f + \fr 7:22 \ft سەد بەت: نزیکەی 2200 لیتر.‏\f* شەراب و سەد بەت\f + \fr 7:22 \ft سەد بەت: نزیکەی 2200 لیتر.‏\f* زەیت و خوێش بەبێ سنوور.  
\v 23 هەرچی خودای ئاسمان فەرمانی پێداوە بە وردی بۆ پەرستگای خودای ئاسمان جێبەجێ بکرێت، چونکە بۆچی تووڕەیی لەسەر شانشینی پاشا و کوڕەکانی بێت؟  
\v 24 هەروەها پێتان ڕادەگەیەنین کە هەموو کاهین و لێڤی و گۆرانیبێژ و دەرگاوان و خزمەتکارانی پەرستگا و خزمەتکارانی ئەم ماڵەی خودا، ڕێ نادرێت سەرانە و باج و گومرگیان لەسەر بێت. 
\pm  
\v 25 تۆش ئەی عەزرا، بەپێی دانایی خوداکەت کە هەتە، قازی و دادوەر دابنێ بۆ ئەوەی دادپەروەری بکەن بۆ هەموو ئەو گەلەی هەرێمی ئەوبەری فورات، لە هەموو ئەوانەی فێرکردنەکانی خودات دەزانن، ئەوانەش کە نایزانن، فێریان بکەن.  
\v 26 هەرکەسێکیش کار بە فێرکردنەکانی خوداکەت و فێرکردنەکانی پاشا نەکات، با بە دڵنیاییەوە حوکمی بەسەردا بدرێت، بە سزای مردن یان دوورخستنەوە یان سزای دارایی یان زیندانی. 
\p  
\v 27 ستایش بۆ یەزدانی پەروەردگاری باوباپیرانمان کە ئەم شتەی خستە دڵی پاشاوە بۆ شکۆدارکردنی ماڵی یەزدان، ئەوەی لە ئۆرشەلیمە.  
\v 28 لەبەردەم پاشا و ڕاوێژکارەکانی و لەبەردەم هەموو کاربەدەستە توانادارەکانی پاشا بە خۆشەویستییە نەگۆڕەکەی دایپۆشیم، منیش بەهۆی ئەو پشتگیرییەی یەزدانی پەروەردگارم بەهێز بووم، جا لە ئیسرائیل ڕابەرەکانم کۆکردەوە تاوەکو لەگەڵم سەربکەون. 
\c 8  
\s1 لیستی گەورەی بنەماڵەکان 
\li4  
\v 1 ئەمانەش گەورەی بنەماڵەکان و ئەوانەن کە لەگەڵیاندا تۆمارکراون، ئەوانەی لە سەردەمی ئەرتەحشەستەی پاشادا لەگەڵ من لە بابلەوە گەڕانەوە: 
\b  
\li1  
\v 2 لە نەوەی فینەحاس، 
\li2 گێرشۆم؛ 
\li1 لە نەوەی ئیتامار، 
\li2 دانیال؛ 
\li1 لە نەوەی داود، 
\li2 حەتوش  
\v 3 لە نەوەی شەخەنەیا؛ 
\li1 لە نەوەی پەرعۆش، 
\li2 زەکەریا و سەد و پەنجا نێرینەش لەگەڵیدا تۆمار کران؛ 
\li1  
\v 4 لە نەوەی پەحەت‌مۆئاب، 
\li2 ئەلیهۆعێینەی کوڕی زەرەحیا، دوو سەد نێرینەش لەگەڵی؛ 
\li1  
\v 5 لە نەوەی زەتو، 
\li2 شەخەنەیا کوڕی یەحەزیێل و سێ سەد نێرێنەش لەگەڵی؛ 
\li1  
\v 6 لە نەوەی عادین، 
\li2 عەبەدی کوڕی یۆناتان، پەنجا نێرینەش لەگەڵی؛ 
\li1  
\v 7 لە نەوەی ئیلام، 
\li2 یەشەعیای کوڕی عەتەلیا، حەفتا نێرینەش لەگەڵی؛ 
\li1  
\v 8 لە نەوەی شەفەتیا، 
\li2 زەڤەدیای کوڕی میکائیل، هەشتا نێرینەش لەگەڵی؛ 
\li1  
\v 9 لە نەوەی یۆئاب 
\li2 عۆبەدیای کوڕی یەحیێل، دوو سەد و هەژدە نێرینەش لەگەڵی؛ 
\li1  
\v 10 لە نەوەی بانی، 
\li2 شەلۆمیت کوڕی یۆسیفیا، سەد و شەست نێرینەش لەگەڵی؛ 
\li1  
\v 11 لە نەوەی بێڤەی، 
\li2 زەکەریای کوڕی بێڤەی، بیست و هەشت نێرینەش لەگەڵی؛ 
\li1  
\v 12 لە نەوەی عەزگاد، 
\li2 یۆحانانی کوڕی هەقاتان سەد و دە نێرینەش لەگەڵی؛ 
\li1  
\v 13 لە نەوەی ئەدۆنیقام، 
\li2 کە لە کۆتاییدا هاتن، ئەمە ناوەکانیانە، ئەلیفەلەت و یەعوئێل و شەمەعیا، شەست نێرینەش لەگەڵیان؛ 
\li1  
\v 14 لە نەوەی بیگڤەی، 
\li2 عوتەی و زەکور، حەفتا نێرینەش لەگەڵیان. 
\s1 گەڕانەوە بۆ ئۆرشەلیم 
\p  
\v 15 جا بۆ لای ئەو نۆکەندەی بەرەو ئەهەڤا دەڕوات کۆمکردنەوە و سێ ڕۆژ لەوێ ماینەوە، لە گەل و کاهینەکان ورد بوومەوە، بەڵام کەسم لە لێڤییەکان لەوێ بەدی نەکرد.  
\v 16 لەبەر ئەوە بانگی هەر یەک لە ئەلیعەزەر، ئەریێل، شەمەعیا، ئەلناتان، یاریڤ، ئەلناتان، ناتان، زەکەریا و مەشولام کرد، کە لە ڕابەرەکان بوون، هەروەها یۆیاریڤ و ئەلناتان کە تێگەیشتوو بوون.  
\v 17 هەموویانم نارد بۆ لای ئیدۆی ڕابەر لەو شوێنەی ناوی کاسیفیا بوو، پێم گوتن لە کاسیفیا چی بە ئیدۆ و برا خزمەتکارەکانی پەرستگا بڵێن، تاوەکو خزمەتکارانمان بۆ بهێنن بۆ ماڵی خودامان.  
\v 18 ئینجا بەپێی ئەوەی دەستی چاکی خودا لەسەرمان بوو، پیاوێکی وریایان بۆمان هێنا کە ناوی شێرێڤیا بوو، لە نەوەی مەحلی کوڕی لێڤی کوڕی ئیسرائیل، لەگەڵ کوڕەکانی شێرێڤیا و براکانی کە هەموویان هەژدە پیاو بوون؛  
\v 19 هەروەها حەشەڤیا لەگەڵ یەشەعیا لە نەوەی مەراری و براکانی و کوڕەکانیان بیست کەس بوون.  
\v 20 لە خزمەتکارانی پەرستگاش، لەو کۆمەڵەی کە داود و کاربەدەستەکان بۆ یارمەتیدانی لێڤییەکان دایانمەزراندبوون، دوو سەد و بیست پیاویان هێنا. هەموویان بە ناوی خۆیانەوە دیاری کران. 
\p  
\v 21 لەوێدا لەسەر نۆکەندی ئەهەڤا بانگەوازی ڕۆژووگرتنم ڕاگەیاند، بۆ ئەوەی لەبەردەم خوداکەماندا ملکەچ بین و داوای ڕێگایەکی ڕاستی لێ بکەین بۆ خۆمان و منداڵەکانمان و هەموو ئەوەی هەمانە.  
\v 22 پێم شەرم بوو داوای سەرباز و سوار لە پاشا بکەم، بۆ ئەوەی لە ڕێگاکەدا لە دوژمن بمانپارێزن، چونکە ئێمە بە پاشامان گوتبوو کە خودای ئێمە چاکە لەگەڵ ئەوانە دەکات کە پشتی پێ دەبەستن، زۆریش لەوە تووڕە دەبێت کە وازی لێ بهێنێت.  
\v 23 جا بە ڕۆژوو بووین و ئەوەمان لە خودامان داوا کرد، ئەویش وەڵامی داینەوە. 
\p  
\v 24 پاشان لە کاهینانی باڵا دوازدە کەسم جیا کردەوە: شێرێڤیا و حەشەڤیا، لەگەڵ ئەوانیش دە لە براکانیان،  
\v 25 زێڕ و زیو و قاپوقاچاغەکەشم بۆیان پێوا، کە بەخشینەکەی ماڵی خودامان ئەوەی پاشا و ڕاوێژکارەکانی و کاربەدەستەکانی و هەموو ئەو ئیسرائیلییانەی کە لەوێ بوون بەخشییان.  
\v 26 شەش سەد و پەنجا تالنت\f + \fr 8:26 \ft شەش سەد و پەنجا تالنت: نزیکەی 22 تەنی زیو.‏\f* زیوم کێشا و خستمە ناو دەستیان، سەد تالنتیش\f + \fr 8:26 \ft نزیکەی ٣.٥ تەن زیو.‏\f* لە قاپوقاچاغی زیو لەگەڵ سەد تالنت زێڕ و  
\v 27 بیست پەرداخی زێڕ بە هەزار درهەم\f + \fr 8:27 \ft زێڕ بە هەزار درهەم: نزیکەی 8,5 کیلۆگرامی زێڕ.‏\f*، دوو قاپی بڕۆنزیش زۆر باش مشتوماڵکراو، کە وەک زێڕ بە نرخ بوون. 
\p  
\v 28 بەوانم گوت: «ئێوە تەرخانکراون بۆ یەزدان و قاپوقاچاغەکانیش تەرخانکراون و زێڕ و زیوەکەش بەخشینێکی ئازادن بۆ یەزدانی پەروەردگاری باوباپیرانتان.  
\v 29 ئیتر پاسەوانیی بکەن و بیپارێزن هەتا لەبەردەم کاهینانی باڵا و لێڤییەکان و گەورەی بنەماڵەکانی ئیسرائیل لە ئۆرشەلیم بیکێشن، لە ژوورەکانی ماڵی یەزدان.»  
\v 30 ئینجا کاهین و لێڤییەکان کێشی زێڕ و زیو و قاپوقاچاغەکەیان وەرگرت تاوەکو بۆ ئۆرشەلیمی بهێنن، بۆ ماڵی خوداکەمان. 
\p  
\v 31 لە دوازدەی مانگی یەک لە نۆکەندی ئەهەڤاوە بەڕێکەوتین تاکو بچینە ئۆرشەلیم، خوداشمان پشتگیری دەکردین، جا لە دەستی دوژمن و چەتەکانی سەر ڕێگا فریامان کەوت.  
\v 32 ئینجا گەیشتینە ئۆرشەلیم و سێ ڕۆژ لەوێ ماینەوە. 
\p  
\v 33 لە ڕۆژی چوارەمدا زێڕ و زیو و قاپوقاچاغەکەی ناو ماڵی خودامان لەسەر دەستی مەرێمۆتی کوڕی ئوریای کاهین کێشرا. ئەلعازاری کوڕی فینەحاسیش لەگەڵی بوو، لەگەڵ یۆزاڤادی کوڕی یێشوع و نۆعەدیای کوڕی بەنوی کە هەردووکیان لێڤی بوون.  
\v 34 بە ژمارە و کێش بۆ هەموویان، هەموو کێشەکەش لەو کاتەدا نووسران. 
\p  
\v 35 نەوەی ڕاپێچکراوەکانیش ئەوانەی لە ڕاپێچکراوی گەڕابوونەوە، قوربانی سووتاندنیان پێشکەشی خودای ئیسرائیل کرد، دوازدە گا لەبری هەموو ئیسرائیل، لەگەڵ نەوەد و شەش بەران، حەفتا و حەوت بەرخی نێر، هەروەها دوازدە گیسکی نێری بۆ قوربانی گوناه، هەموو کرانە قوربانی سووتاندن بۆ یەزدان.  
\v 36 هەروەها یاساکانی پاشایان دایە دەست میر و پارێزگارەکانی هەرێمی ئەوبەری فورات، ئەوانیش یارمەتی گەل و ماڵی خودایان دا. 
\c 9  
\s1 نزای عەزرا لەبارەی ژنهێنان و شووکردن 
\p  
\v 1 پاش تەواوبوونی ئەمە، ڕابەرەکان هاتن بۆ لام و گوتیان: «گەلی ئیسرائیل و کاهین و لێڤییەکان خۆیان جیا نەکردووەتەوە لە گەلانی دراوسێ و نەریتە قێزەونەکانیان، لە کەنعانی، حیتی، پریزی، یەبوسی، عەمۆنی، مۆئابی، میسری و ئەمۆرییەکان،  
\v 2 چونکە لە کچەکانی ئەوانیان بۆ خۆیان و کوڕەکانیان هێناوە و نەژادی پیرۆز تێکەڵ بە گەلانی خاکەکان بووە. دەستی ڕابەر و کاربەدەستەکانیش لەم ناپاکییە یەکەم بووە.» 
\p  
\v 3 کە گوێم لەم شتە بوو، کراسەکەم و کەواکەم دادڕی و مووی سەر و ڕیشی خۆمم ڕنییەوە و بە سەرسوڕمانەوە دانیشتم.  
\v 4 جا هەموو ئەوانەی لە ترسی وشەکانی خودای ئیسرائیل لەرزین لێم کۆبوونەوە، لەبەر ناپاکی ئەوانەی لە ڕاپێچکراوی گەڕابوونەوە. منیش هەتا کاتی قوربانی ئێوارە بە سەرسوڕمانەوە دانیشتم. 
\p  
\v 5 لە کاتی قوربانی ئێوارەدا لە زەلیلکردنی خۆم هەستام و بە کراس و کەوا دڕاوەکەمەوە کەوتمە سەر چۆک و دەستم بۆ یەزدانی پەروەردگارم پانکردەوە و  
\v 6 گوتم: 
\pm «خودایە، من شەرمەزار و سەرشۆڕم لەوەی ڕووم ڕووەو تۆ هەڵبڕم، چونکە تاوانەکانمان لەسەر سەرمان بەرزبوونەوە و خراپەکانمان بۆ ئاسمان بەرزبوونەتەوە.  
\v 7 لە سەردەمی باوباپیرانمانەوە هەتا ئەمڕۆ ئێمە لە خراپەیەکی گەورەداین، لەبەر تاوانەکانمان ئێمە و پاشا و کاهینەکانمان دراینە دەست پاشایانی خاکەکان و کەوتینە بەر شمشێر و دیلیێتی و تاڵان و سەرشۆڕی، وەک ئەمڕۆ. 
\pm  
\v 8 «بەڵام ئێستا بۆ ساتێک یەزدانی پەروەردگارمان میهرەبان بوو بەرامبەرمان کە دەربازمان دەکات و سنگێکمان لە پیرۆزگای خۆی دەداتێ، تاکو خودامان چاومان ڕووناک بکاتەوە و لە کاتی کۆیلەییدا هەندێک بمانبووژێنێتەوە.  
\v 9 هەرچەندە ئێمە کۆیلەین، بەڵام خودامان لە کۆیلایەتییمان بەجێی نەهێشتین، بەڵکو لەبەردەم پاشاکانی فارس بە خۆشەویستییە نەگۆڕەکەی دایپۆشین: ژیانی نوێی پێمان داوە بۆ ئەوەی ماڵی خوداکەمان بنیاد بنێینەوە و کەلاوەکانی نۆژەن بکەینەوە، هەروەها لە یەهودا و ئۆرشەلیم دیوارێکی پێمان داوە. 
\pm  
\v 10 «ئێستاش ئەی خودای ئێمە، پاش ئەوە چی بڵێین؟ وازمان لە فەرمانەکانت هێنا،  
\v 11 ئەوەی لە ڕێگەی بەندە پێغەمبەرەکانت فەرمانت پێدا و فەرمووت: ”ئەو خاکەی دەچنە ناوی تاکو دەستی بەسەردا بگرن، خاکێکی گڵاوە بەهۆی گڵاوی خەڵکەکەیەوە، کە بەهۆی نەریتە قێزەونەکانیان لەمپەڕ بۆ ئەوپەڕی خاکەکەیان پڕ کردووە لە گڵاوی.  
\v 12 ئێستاش کچتان مەدەنە کوڕیان و کچیشیان بۆ کوڕەکانتان مەهێنن. هەرگیز پەیمانی ئاشتی و چاکەیان لەگەڵ مەبەستن، تاوەکو ئێوە بەهێز بن و خێری خاکەکە بخۆن و بۆ هەتاهەتایە بە میرات بۆ کوڕەکانتانی بەجێبهێڵن.“ 
\pm  
\v 13 «هەموو ئەوە بەهۆی کارە خراپەکانمان و بەدکارییە گەورەکانمان بەسەرمان هات. ئەی خودای ئێمە، لەگەڵ ئەوەشدا تۆ لە تاوانەکانمان کەمتر سزات داین و دەربازبوونێکی بەم شێوەیەت بە ئێمە بەخشی.  
\v 14 ئایا بگەڕێینەوە و سەرپێچی فەرمانەکانت بکەین و خزمایەتی لەگەڵ ئەو گەلانە بکەین کە ئەم جۆرە نەریتە قێزەونە دەکەن؟ ئایا لێمان تووڕە نابیت و لەناومان نابەیت هەتا ئەوەی هیچ پاشماوە و دەربازبووێکمان نەبێت؟  
\v 15 ئەی یەزدانی پەروەردگاری ئیسرائیل، تۆ ڕاستودروستیت، چونکە هەتا ئەمڕۆ بە دەربازبوویی ماوینەتەوە. ئەوەتا ئێمە بە تاوانەکانمانەوە لەبەردەمتداین، چونکە لەبەر ئەمە بۆ ئێمە نییە لەبەردەمت ڕابوەستین.» 
\c 10  
\s1 دانپێدانانی گەل بە گوناهەکانیان 
\p  
\v 1 کە عەزرا نوێژی دەکرد و دانی پێدا دەنا و بە گریانەوە لەبەردەم ماڵی خودا کەوتبوو، کۆمەڵێکی ئێجگار زۆر لە ئیسرائیل، لە پیاو و ئافرەت و منداڵ لێی کۆبوونەوە، چونکە گەل گریانێکی بەکوڵ دەگریان.  
\v 2 ئینجا شەخەنەیای کوڕی یەحیێل لە نەوەی ئیلام وەڵامی دایەوە و بە عەزرای گوت: «ئێمە ناپاکیمان لەگەڵ خودامان کرد، ژنی بێگانەمان لە گەلانی خاکەکەوە هێنا. بەڵام سەرەڕای ئەمەش، ئیسرائیل هیوای بەمە هەیە:  
\v 3 با ئێستا پەیمانێک لەگەڵ خوداماندا ببەستین، کە هەموو ژنەکان و ئەوانەی لەوان لەدایک بوونە دەریانبکەین، بەپێی ڕاوێژی گەورەم و ئەوانەی لە فەرمانەکانی خودامان دەترسن، با بەپێی تەورات کار بکرێت.  
\v 4 هەستە! ئەم کارە لەسەر تۆیە و ئێمەش لەگەڵتداین. ئازابە و دەستبەکاربە!» 
\p  
\v 5 ئیتر عەزرا هەستا و کاهینە باڵاکان و لێڤی و هەموو ئیسرائیلی سوێند دا کە کار بەم پێشنیارە بکەن، ئەوانیش سوێندیان خوارد.  
\v 6 پاشان عەزرا لەبەردەم ماڵی خودا هەستا و چووە ژوورەکەی یەهۆحانانی کوڕی ئەلیاشیڤ. بەرەو ئەوێ چوو، بێ ئەوەی نان بخوات و ئاو بخواتەوە، چونکە بەهۆی ناپاکی ڕاپێچکراوەکانەوە شینی دەگێڕا. 
\p  
\v 7 ئینجا لە یەهودا و ئۆرشەلیم بانگەوازیان کرد بۆ هەموو ئەوانەی لە ڕاپێچکراوی گەڕابوونەوە تاوەکو لە ئۆرشەلیم کۆببنەوە،  
\v 8 بەپێی ڕاوێژی کاربەدەستەکان و پیران، هەرکەسێک لە ماوەی سێ ڕۆژدا ئامادە نەبێت، دەست بەسەر ماڵەکەیدا دەگیرێت و خۆشی لە کۆمەڵی ڕاپێچکراوەکان جیا دەکرێتەوە. 
\b  
\p  
\v 9 لە ماوەی سێ ڕۆژەکە هەموو پیاوانی یەهودا و بنیامین لە ئۆرشەلیم کۆبوونەوە، واتا لە بیستی مانگی نۆ، لە ئۆرشەلیم کۆبوونەوە و هەموو گەل بە ترسەوە لەناو گۆڕەپانەکەی ماڵی خودا دانیشتن، لەبەر بابەتەکە و لەبەر بارانەکە.  
\v 10 ئینجا عەزرای کاهین هەستا و پێی گوتن: «ئێوە ناپاکیتان کرد، ژنی بێگانەتان هێنا بۆ ئەوەی تاوانی زیاتر بخەنە سەر خراپەی ئیسرائیل.  
\v 11 ئێستا لەبەردەم یەزدانی پەروەردگاری باوباپیرانتان دانی پێدا بنێن و ئەوە بکەن کە پێی خۆشە، خۆتان لە گەلانی خاکەکە و لە ژنە بێگانەکان داببڕن.» 
\p  
\v 12 هەموو کۆمەڵەکە بە دەنگێکی بەرز وەڵامیان دایەوە: «چۆنت پێ گوتین، ئاوا دەکەین.  
\v 13 بەڵام گەلەکە زۆرن و کاتەکەش کاتی بارانە و توانای ئەوەمان نییە لە دەرەوە ڕابوەستین، کارەکەش کاری یەک دوو ڕۆژ نییە، چونکە لەم بارەیەوە یاخیبوونی زۆرمان کردووە.  
\v 14 تکایە با کاربەدەستەکانمان لە جێی هەموو کۆمەڵەکە ڕاوەستن و هەموو ئەوانەی لە شارۆچکەکانمان ژنی بێگانەیان هێناوە، با لە کاتی دیاریکراودا لەگەڵ پیران و دادوەرانی شارەکەی خۆیان بێن، هەر شارە و بە تەنها، هەتا گڕی تووڕەیی خودامان کە بەهۆی ئەم کارەوەیە لێمان دامرکێتەوە.»  
\v 15 تەنها یۆناتانی کوڕی عەساهێل و یەحزەیای کوڕی تیقڤا لە دژی ئەمە ڕاوەستان، مەشولام و شەبەتەی کە هەردووکیان لێڤی بوون پشتگیرییان کردن. 
\p  
\v 16 ئینجا ئەوانەی لە ڕاپێچکراوی گەڕانەوە ئاوایان کرد، عەزرای کاهین و ئەو پیاوانەی گەورەی بنەماڵەکان بوون جیا بوونەوە، بەپێی بنەماڵەکانیان و هەموویان بە ناوی خۆیان، لە یەکەم ڕۆژی مانگی دە بۆ لێکۆڵینەوە لە بابەتەکە دانیشتن.  
\v 17 لە یەکەم ڕۆژی مانگی یەک لە بابەتی هەموو ئەو پیاوانە بوونەوە کە ژنی بێگانەیان هێنابوو. 
\s1 ئەوانەی ژنی بێگانەیان هێنابوو 
\li4  
\v 18 لەنێو کاهینەکان چەند کەسێکیان بینییەوە کە ژنی بێگانەیان هێنابوو: 
\li1 لە نەوەی یەشوعی کوڕی یۆچاداق و براکانی: 
\li2 مەعسێیاهو، ئەلیعەزەر، یاریڤ و گەدەلیاهو.  
\v 19 بەڵێنیان دا کە ژنە بێگانەکانیان دەربکەن و لەبەر تاوانەکەیان بەرانێکی مێگەلیان پێشکەش کرد. 
\li1  
\v 20 لە نەوەی ئیمێر: 
\li2 حەنانی و زەڤەدیا. 
\li1  
\v 21 لە نەوەی حاریم: 
\li2 مەعسێیاهو، ئەلیاس، شەمەعیا، یەحیێل و عوزیا. 
\li1  
\v 22 لە نەوەی پەشحور: 
\li2 ئەلیۆعێنەی، مەعسێیاهو، ئیسماعیل، نەتەنێل، یۆزاڤاد و ئەلعاسا. 
\b  
\li4  
\v 23 لە لێڤییەکان: 
\li2 یۆزاڤاد، شیمعی، قێلایا کە قەلیتایە، پەتەحیا، یەهودا و ئەلیعەزەر. 
\li1  
\v 24 لە گۆرانیبێژەکان: 
\li2 ئەلیاشیڤ. 
\li1 لە دەرگاوانەکان: 
\li2 شەلوم، تەلەم و ئوری. 
\b  
\li4  
\v 25 لەنێو ئیسرائیلییەکانی دیکەش: 
\li1 لە نەوەی پەرعۆش: 
\li2 ڕەمیا، یەزییا، مەلکیا، میامین، ئەلعازار، مەلکیا و بەنایا. 
\li1  
\v 26 لە نەوەی ئیلام: 
\li2 مەتەنیا، زەکەریا، یەحیێل، عەبدی، یەرێمۆت و ئەلیاس. 
\li1  
\v 27 لە نەوەی زەتو: 
\li2 ئەلیۆعێنەی، ئەلیاشیڤ، مەتەنیا، یەرێمۆت، زاڤاد و عەزیزا. 
\li1  
\v 28 لە نەوەی بێڤەی: 
\li2 یەهۆحانان، حەنەنیا، زەبەی و عەتلای. 
\li1  
\v 29 لە نەوەی بانی: 
\li2 مەشولام، مەلوخ، عەدایا، یاشوڤ، شەئال و یەرێمۆت. 
\li1  
\v 30 لە نەوەی پەحەت‌مۆئاب: 
\li2 عەدنا، کەلال، بەنایا، مەعسێیاهو، مەتەنیا، بەسەلئێل، بەنوی و مەنەشە. 
\li1  
\v 31 لە نەوەی حاریم: 
\li2 ئەلیعەزەر، یەشییا، مەلکیا، شەمەعیا، شیمەعۆن،  
\v 32 بنیامین، مەلوخ و شەمەریاهو. 
\li1  
\v 33 لە نەوەی حاشوم: 
\li2 مەتەنەی، مەتەتا، زاڤاد، ئەلیفەلەت، یەرێمەی، مەنەشە و شیمعی. 
\li1  
\v 34 لە نەوەی بانی: 
\li2 مەعەدەی، عەمرام، ئوئێل،  
\v 35 بەنایا، بێدەیا، کەلووهی،  
\v 36 ڤەنیا، مەرێمۆت، ئەلیاشیڤ،  
\v 37 مەتەنیا، مەتەنەی و یەعەسۆ. 
\li1  
\v 38 لە نەوەی بەنوی: 
\li2 شیمعی،  
\v 39 شەلەمیاهو، ناتان، عەدایا،  
\v 40 مەخنەدەڤەی، شاشەی، شارای،  
\v 41 عەزەرئێل، شەلەمیاهو، شەمەریاهو،  
\v 42 شەلوم، ئەمەریا و یوسف. 
\li1  
\v 43 لە نەوەی نەبۆ: 
\li2 یەعیێل، مەتیسیا، زاڤاد، زەڤینا، یەدەی، یۆئێل و بەنایا. 
\b  
\li4  
\v 44 هەموو ئەوانە ژنی بێگانەیان هێنابوو، هەروەها هەندێک لە ژنەکان منداڵیان ببوو.