\v 19 “\w Your|strong="H6440"\w* Majesty, \w please|strong="H2896"\w* forgive \w me|strong="H6440"\w* \w and|strong="H1121"\w* disregard \w the|strong="H6440"\w* wrong \w that|strong="H4428"\w* \w I|strong="H6440"\w*, \w your|strong="H6440"\w* servant, \w did|strong="H6213"\w* \w when|strong="H6213"\w* \w Your|strong="H6440"\w* Majesty \w left|strong="H5674"\w* Jerusalem. \w Please|strong="H2896"\w* forget \w all|strong="H6213"\w* \w about|strong="H6213"\w* \w it|strong="H6213"\w*.
