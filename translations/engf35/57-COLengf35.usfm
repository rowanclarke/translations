\v 9 \w Do|strong="G3361"\w* \w not|strong="G3361"\w* \w lie|strong="G5574"\w* \w to|strong="G1519"\w* \w one|strong="G3588"\w* \w another|strong="G3588"\w*, since \w you|strong="G3361"\w* \w have|strong="G3361"\w* taken off \w the|strong="G1519"\w* \w old|strong="G3820"\w* \w man|strong="G3361"\w* \w with|strong="G4862"\w* \w his|strong="G1519"\w* \w practices|strong="G4234"\w*
\v 10 \w and|strong="G2532"\w* \w have|strong="G2532"\w* \w put|strong="G1746"\w* \w on|strong="G1519"\w* \w the|strong="G2532"\w* \w new|strong="G3501"\w* \w one|strong="G3588"\w*, \w who|strong="G3588"\w* \w is|strong="G3588"\w* \w being|strong="G2532"\w* renewed \w into|strong="G1519"\w* \w real|strong="G1922"\w* \w knowledge|strong="G1922"\w* \w according|strong="G2596"\w* \w to|strong="G1519"\w* \w the|strong="G2532"\w* \w image|strong="G1504"\w* \w of|strong="G2532"\w* \w his|strong="G1519"\w* \w Creator|strong="G2936"\w*,
\v 11 \w where|strong="G3699"\w* \w there|strong="G2532"\w* \w is|strong="G3588"\w* \w neither|strong="G3756"\w* \w Greek|strong="G1672"\w* \w nor|strong="G2532"\w* \w Jew|strong="G2453"\w*, \w circumcision|strong="G4061"\w* \w nor|strong="G2532"\w* uncircumcision, barbarian, \w Scythian|strong="G4658"\w*, \w slave|strong="G1401"\w*, \w free|strong="G1658"\w*; \w but|strong="G2532"\w* \w Christ|strong="G5547"\w* \w is|strong="G3588"\w* \w all|strong="G3956"\w* \w and|strong="G2532"\w* \w in|strong="G1722"\w* \w all|strong="G3956"\w*.\f + \fr 3:11 \ft ‘Nationalism’ has no legitimate place in the Church. There will be no ‘Americans’, ‘Brazilians’, ‘Russians’, ‘Chinese’, etc. in Heaven—there will only be true disciples of Sovereign Jesus.\f*
\s1 Relationships among believers
\p 
\v 12 \w Therefore|strong="G3767"\w*, \w as|strong="G5613"\w* \w God|strong="G2316"\w*'s \w chosen|strong="G1588"\w* ones, holy \w and|strong="G2532"\w* beloved, \w put|strong="G1746"\w* \w on|strong="G1746"\w* \w hearts|strong="G4698"\w* \w of|strong="G2532"\w* \w compassion|strong="G3628"\w*, \w kindness|strong="G5544"\w*, \w humility|strong="G5012"\w*, \w gentleness|strong="G4240"\w*, \w patience|strong="G3115"\w*;
\v 13 \w bearing|strong="G2192"\w* \w with|strong="G4314"\w* \w one|strong="G5100"\w* \w another|strong="G1438"\w* \w and|strong="G2532"\w* \w forgiving|strong="G5483"\w* \w each|strong="G1438"\w* \w other|strong="G5100"\w*, \w if|strong="G1437"\w* \w anyone|strong="G5100"\w* \w should|strong="G5100"\w* \w have|strong="G2192"\w* \w a|strong="G2192"\w* \w complaint|strong="G3437"\w* \w against|strong="G4314"\w* \w another|strong="G1438"\w*—\w just|strong="G2531"\w* \w as|strong="G2531"\w* \w the|strong="G2532"\w* \w Christ|strong="G5547"\w*\f + \fr 3:13 \ft Instead of “Christ”, perhaps 2% of the Greek manuscripts have ‘Lord’ (as in NIV, NASB, LB, TEV, etc.).\f* \w forgave|strong="G5483"\w* \w you|strong="G5210"\w*, \w so|strong="G3779"\w* \w you|strong="G5210"\w* \w also|strong="G2532"\w* \w must|strong="G5100"\w* \w do|strong="G2532"\w*.
\v 14 \w And|strong="G1161"\w* \w above|strong="G1909"\w* \w all|strong="G3956"\w* \w these|strong="G3778"\w* \w things|strong="G3956"\w* \w put|strong="G3956"\w* \w on|strong="G1909"\w* love, \w which|strong="G3739"\w* \w is|strong="G1510"\w* \w the|strong="G3956"\w* \w bond|strong="G4886"\w* \w of|strong="G1909"\w* \w perfection|strong="G5047"\w*.\f + \fr 3:14 \ft \it Agape\it* love is unselfish, genuinely concerned for the other's well-being.\f*
\p 
\v 15 \w Let|strong="G1096"\w* \w the|strong="G1722"\w* \w peace|strong="G1515"\w* \w of|strong="G2532"\w* \w God|strong="G2532"\w*\f + \fr 3:15 \ft Instead of “God”, some 5% of the Greek manuscripts have ‘Christ’ (as in NIV, NASB, LB, TEV, etc.).\f* \w rule|strong="G1018"\w* \w in|strong="G1722"\w* \w your|strong="G2532"\w* \w hearts|strong="G2588"\w*, \w into|strong="G1519"\w* \w which|strong="G3739"\w* \w also|strong="G2532"\w* \w you|strong="G5210"\w* \w were|strong="G3588"\w* \w called|strong="G2564"\w* \w in|strong="G1722"\w* \w one|strong="G1520"\w* \w body|strong="G4983"\w*; \w and|strong="G2532"\w* \w be|strong="G1096"\w* \w thankful|strong="G2170"\w*.
\p 
\v 16 \w Let|strong="G1774"\w* \w the|strong="G1722"\w* \w Word|strong="G3056"\w* \w of|strong="G3056"\w* \w Christ|strong="G5547"\w* \w dwell|strong="G1774"\w* \w in|strong="G1722"\w* \w you|strong="G5210"\w* \w richly|strong="G4146"\w* \w as|strong="G1722"\w* \w you|strong="G5210"\w* \w teach|strong="G1321"\w* \w and|strong="G2532"\w* \w admonish|strong="G3560"\w* \w one|strong="G3956"\w* \w another|strong="G1438"\w* \w with|strong="G1722"\w* \w all|strong="G3956"\w* \w wisdom|strong="G4678"\w*, \w and|strong="G2532"\w* \w as|strong="G1722"\w* \w you|strong="G5210"\w* sing \w with|strong="G1722"\w* \w grace|strong="G5485"\w* \w in|strong="G1722"\w* \w your|strong="G2532"\w* \w heart|strong="G2588"\w* \w to|strong="G2532"\w* \w the|strong="G1722"\w* \w Lord|strong="G3588"\w*,\f + \fr 3:16 \ft Instead of “the Lord”, perhaps 4% of the Greek manuscripts have ‘God’ (as in NIV, NASB, LB, TEV, etc.).\f* \w with|strong="G1722"\w* \w psalms|strong="G5568"\w* \w and|strong="G2532"\w* \w hymns|strong="G5215"\w* \w and|strong="G2532"\w* \w spiritual|strong="G4152"\w* \w songs|strong="G5603"\w*.\f + \fr 3:16 \ft Our singing is supposed to reflect “the Word of Christ”. Indeed, all of our teaching and admonishing should be based on that Word.\f*
\p 
\v 17 \w Whatever|strong="G3739"\w* \w you|strong="G3739"\w* \w may|strong="G2532"\w* \w do|strong="G4160"\w* \w in|strong="G1722"\w* \w word|strong="G3056"\w* \w or|strong="G2228"\w* \w deed|strong="G2041"\w*, \w do|strong="G4160"\w* \w all|strong="G3956"\w* \w in|strong="G1722"\w* \w the|strong="G1722"\w* \w name|strong="G3686"\w* \w of|strong="G3056"\w* \w the|strong="G1722"\w* \w Lord|strong="G2962"\w* \w Jesus|strong="G2424"\w*, \w giving|strong="G2168"\w* \w thanks|strong="G2168"\w* \w to|strong="G2532"\w* \w God|strong="G2316"\w* \w the|strong="G1722"\w* \w Father|strong="G3962"\w* \w through|strong="G1223"\w* \w Him|strong="G3588"\w*.\f + \fr 3:17 \ft We thank God for the privilege.\f*
\s1 Household relationships
\p 
\v 18 \w Wives|strong="G1135"\w*, subordinate \w yourselves|strong="G5293"\w* \w to|strong="G1722"\w* \w your|strong="G2962"\w* own husbands,\f + \fr 3:18 \ft In these verses we have a series of verbs in the imperative mood; they are commands. A woman who subordinates herself to her husband will be doing herself a favor (it makes it easier for him to love her).\f* \w as|strong="G5613"\w* \w is|strong="G3588"\w* fitting \w in|strong="G1722"\w* \w the|strong="G1722"\w* \w Lord|strong="G2962"\w*.
\p 
\v 19 Husbands, love \w your|strong="G2532"\w* \w wives|strong="G1135"\w* \w and|strong="G2532"\w* \w do|strong="G2532"\w* \w not|strong="G3361"\w* \w be|strong="G2532"\w* \w embittered|strong="G4087"\w* \w against|strong="G4314"\w* \w them|strong="G3588"\w*.\f + \fr 3:19 \ft Right on! That is just how men tend to react, being frustrated by women's wiles and quite different way of thinking. But a man who has the good sense to give value to that different way of thinking will come out ahead.\f*
\p 
\v 20 \w Children|strong="G5043"\w*, \w obey|strong="G5219"\w* \w your|strong="G2962"\w* \w parents|strong="G1118"\w* \w in|strong="G1722"\w* \w everything|strong="G3956"\w*, \w because|strong="G1063"\w* \w this|strong="G3778"\w* \w is|strong="G1510"\w* \w well|strong="G1063"\w* \w pleasing|strong="G2101"\w* \w in|strong="G1722"\w* \w the|strong="G1722"\w* \w Lord|strong="G2962"\w*.\f + \fr 3:20 \ft So of course such commands must not be contrary to God's moral code.\f*
\p 
\v 21 \w Fathers|strong="G3962"\w*, \w do|strong="G3361"\w* \w not|strong="G3361"\w* \w provoke|strong="G2042"\w* \w your|strong="G3588"\w* \w children|strong="G5043"\w* \w so|strong="G2443"\w* \w that|strong="G2443"\w* \w they|strong="G3588"\w* lose heart.\f + \fr 3:21 \ft Unreasonable demands, harsh treatment, lack of clear guidelines—there are various ways to frustrate children and cause them to lose heart, and even give up. In today's world they will probably cop out by going to drugs, or the Internet (both of which leave them wide open to demonic influence).\f*
\p 
\v 22 \w Slaves|strong="G1401"\w*, \w obey|strong="G5219"\w* \w your|strong="G2962"\w* \w masters|strong="G2962"\w* (\w according|strong="G2596"\w* \w to|strong="G2596"\w* \w the|strong="G1722"\w* \w flesh|strong="G4561"\w*) \w in|strong="G1722"\w* \w all|strong="G3956"\w* \w things|strong="G3956"\w*, \w not|strong="G3361"\w* \w just|strong="G5613"\w* \w when|strong="G5613"\w* \w they|strong="G3588"\w* \w are|strong="G3588"\w* looking, \w as|strong="G5613"\w* men-pleasers, \w but|strong="G3361"\w* \w in|strong="G1722"\w* sincerity \w of|strong="G2962"\w* \w heart|strong="G2588"\w*, \w fearing|strong="G5399"\w* \w God|strong="G3361"\w*.\f + \fr 3:22 \ft Notice that slavery is not condemned; a slave who converted to Christ could not expect to go free; rather he was expected to be a better slave! Instead of “God”, perhaps 10% of the Greek manuscripts have ‘the Lord’ (as in NIV, NASB, LB, TEV, etc.).\f*
\v 23 \w And|strong="G2532"\w* \w whatever|strong="G3739"\w* \w you|strong="G3739"\w* \w do|strong="G4160"\w*, \w give|strong="G4160"\w* \w it|strong="G2532"\w* \w all|strong="G2532"\w* \w you|strong="G3739"\w*'ve got,\f + \fr 3:23 \ft If a human owner is to be served in this way, how much more a divine Owner!\f* \w as|strong="G5613"\w* \w to|strong="G2532"\w* \w the|strong="G2532"\w* \w Lord|strong="G2962"\w* \w and|strong="G2532"\w* \w not|strong="G3756"\w* \w to|strong="G2532"\w* \w men|strong="G3588"\w*,
\v 24 \w knowing|strong="G1492"\w* \w that|strong="G3754"\w* \w it|strong="G3754"\w* \w is|strong="G3588"\w* \w from|strong="G3588"\w* \w the|strong="G3588"\w* \w Lord|strong="G2962"\w* \w that|strong="G3754"\w* \w you|strong="G3754"\w* \w will|strong="G2962"\w* receive \w the|strong="G3588"\w* \w inheritance|strong="G2817"\w* \w as|strong="G3754"\w* \w a|strong="G1492"\w* reward; \w because|strong="G3754"\w* \w you|strong="G3754"\w* \w serve|strong="G1398"\w* \w the|strong="G3588"\w* \w Lord|strong="G2962"\w* \w Christ|strong="G5547"\w*.
\v 25 (\w But|strong="G2532"\w* \w he|strong="G2532"\w* \w who|strong="G3739"\w* \w does|strong="G1510"\w* \w wrong|strong="G2865"\w* \w will|strong="G1510"\w* \w be|strong="G1510"\w* repaid \w for|strong="G1063"\w* \w this|strong="G3588"\w* \w wrong|strong="G2865"\w*, \w and|strong="G2532"\w* \w there|strong="G2532"\w* \w is|strong="G1510"\w* \w no|strong="G3756"\w* \w favoritism|strong="G4382"\w*.)\f + \fr 3:25 \ft Being saved does not mean we get a free ride.\f*
\c 4
\m 
\v 1 \w Masters|strong="G2962"\w*, provide \w your|strong="G2962"\w* \w slaves|strong="G1401"\w* \w with|strong="G1722"\w* \w what|strong="G3588"\w* \w is|strong="G3588"\w* \w just|strong="G1342"\w* \w and|strong="G2532"\w* \w fair|strong="G2532"\w*, \w knowing|strong="G1492"\w* \w that|strong="G3754"\w* \w you|strong="G5210"\w* \w also|strong="G2532"\w* \w have|strong="G2192"\w* \w a|strong="G2192"\w* \w Master|strong="G2962"\w* \w in|strong="G1722"\w* \w the|strong="G1722"\w* \w heavens|strong="G3772"\w*.\f + \fr 4:1 \ft This is a good thing for all of us to remember.\f*
\s1 Redeem the time
\p 
\v 2 \w Continue|strong="G4342"\w* \w earnestly|strong="G4335"\w* \w in|strong="G1722"\w* \w prayer|strong="G4335"\w*, \w being|strong="G1722"\w* \w vigilant|strong="G1127"\w* \w in|strong="G1722"\w* \w it|strong="G3588"\w* \w with|strong="G1722"\w* \w thanksgiving|strong="G2169"\w*,
