\p 
\v 11 \w Our|strong="H6213"\w* adversaries \w also|strong="H6213"\w* boasted, “Before \w they|strong="H6213"\w* \w are|strong="H3027"\w* aware \w or|strong="H3027"\w* anticipate \w anything|strong="H4399"\w*, \w we|strong="H3068"\w* \w will|strong="H3027"\w* \w come|strong="H2346"\w* \w in|strong="H6213"\w* among \w them|strong="H3027"\w* \w and|strong="H3027"\w* kill \w them|strong="H3027"\w*, \w and|strong="H3027"\w* \w we|strong="H3068"\w* \w will|strong="H3027"\w* \w bring|strong="H5375"\w* \w this|strong="H6213"\w* \w work|strong="H4399"\w* \w to|strong="H6213"\w* \w a|strong="H3068"\w* halt!”
\p 
\v 12 \w So|strong="H5921"\w* \w it|strong="H5921"\w* happened \w that|strong="H2719"\w* \w the|strong="H5921"\w* Jews \w who|strong="H1129"\w* \w were|strong="H2719"\w* living \w near|strong="H5921"\w* \w them|strong="H5921"\w* came \w and|strong="H2719"\w* warned \w us|strong="H5921"\w* repeatedly \w about|strong="H5921"\w* \w all|strong="H5921"\w* \w the|strong="H5921"\w* schemes \w they|strong="H5921"\w* \w were|strong="H2719"\w* plotting \w against|strong="H5921"\w* \w us|strong="H5921"\w*.
