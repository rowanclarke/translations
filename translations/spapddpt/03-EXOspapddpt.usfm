\s1 El Éxodo  
\p
\v 17 \w Sucedió|strong="H1961"\w* \w que|strong="H3588"\w* \w cuando|strong="H3588"\w* \w Faraón|strong="H6547"\w* \w dejó|strong="H7971"\w* salir al \w pueblo|strong="H5971"\w*, \nd ʼElohim\nd* \w no|strong="H3808"\w* \w los|strong="H1931"\w* condujo \w por|strong="H3588"\w* \w el|strong="H1931"\w* \w camino|strong="H1870"\w* \w de|strong="H3588"\w* \w la|strong="H1931"\w* tierra \w de|strong="H3588"\w* \w los|strong="H1931"\w* \w filisteos|strong="H6430"\w*, \w aunque|strong="H3588"\w* \w estaba|strong="H1961"\w* \w cerca|strong="H7138"\w*, \w porque|strong="H3588"\w* \nd ʼElohim\nd* dijo: \wj \+w No|strong="H3808"\+w* \+w sea|strong="H1961"\+w* \+w que|strong="H3588"\+w* \+w el|strong="H1931"\+w* \+w pueblo|strong="H5971"\+w* cambie \+w de|strong="H3588"\+w* mente \+w cuando|strong="H3588"\+w* \+w vea|strong="H7200"\+w* \+w guerra|strong="H4421"\+w* \+w y|strong="H3588"\+w* regrese \+w a|strong="H3068"\+w* \+w Egipto|strong="H4714"\+w*.\wj*   
\p
\v 18 \w Por|strong="H1870"\w* tanto, \nd ʼElohim\nd* condujo al \w pueblo|strong="H5971"\w* \w por|strong="H1870"\w* \w el|strong="H1121"\w* \w camino|strong="H1870"\w* del \w desierto|strong="H4057"\w* \w hacia|strong="H1870"\w* \w el|strong="H1121"\w* \w mar|strong="H3220"\w* Rojo, y \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w subieron|strong="H5927"\w* \w armados|strong="H2571"\w* \w de|strong="H1121"\w* la tierra \w de|strong="H1121"\w* \w Egipto|strong="H4714"\w*.   
\p
\v 19 \w Moisés|strong="H4872"\w* \w tomó|strong="H3947"\w* \w consigo|strong="H5973"\w* \w los|strong="H1121"\w* \w huesos|strong="H6106"\w* \w de|strong="H3588"\w* \w José|strong="H3130"\w*, \w pues|strong="H3588"\w* \w éste|strong="H2088"\w* ordenó jurar solemnemente \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*: \w De|strong="H3588"\w* \w cierto|strong="H3588"\w* \nd ʼElohim\nd* \w los|strong="H1121"\w* \w visitará|strong="H6485"\w* \w y|strong="H3588"\w* llevarán mis \w huesos|strong="H6106"\w* \w de|strong="H3588"\w* \w aquí|strong="H2088"\w* \w con|strong="H5973"\w* ustedes.   
\p
\v 20 Luego \w salieron|strong="H5265"\w* de Sucot y acamparon en Etam, al borde del \w desierto|strong="H4057"\w*.   
\p
\v 21 \nd \+w Yavé|strong="H3068"\+w*\nd* \w iba|strong="H1980"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ellos, \w de|strong="H6440"\w* \w día|strong="H3119"\w* \w en|strong="H3212"\w* una \w columna|strong="H5982"\w* \w de|strong="H6440"\w* \w nube|strong="H6051"\w* para guiarlos \w por|strong="H1870"\w* el \w camino|strong="H1870"\w*, y \w de|strong="H6440"\w* \w noche|strong="H3915"\w* \w en|strong="H3212"\w* una \w columna|strong="H5982"\w* \w de|strong="H6440"\w* fuego para alumbrarles, \w a|strong="H3068"\w* fin \w de|strong="H6440"\w* que \w caminaran|strong="H3212"\w* \w de|strong="H6440"\w* \w día|strong="H3119"\w* y \w de|strong="H6440"\w* \w noche|strong="H3915"\w*.  
\v 22 \w Nunca|strong="H3808"\w* \w se|strong="H3808"\w* apartó \w de|strong="H6440"\w* \w delante|strong="H6440"\w* del \w pueblo|strong="H5971"\w* la \w columna|strong="H5982"\w* \w de|strong="H6440"\w* \w nube|strong="H6051"\w* durante el \w día|strong="H3119"\w*, \w ni|strong="H3808"\w* la \w columna|strong="H5982"\w* \w de|strong="H6440"\w* fuego durante la \w noche|strong="H3915"\w*.   
\c 14  
\s1 El mar Rojo  
\p
\v 1 \nd \+w Yavé|strong="H3068"\+w*\nd* \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*:  
\v 2 \wj \+w Dí|strong="H1696"\+w* \+w a|strong="H3068"\+w* \+w los|strong="H1121"\+w* \+w hijos|strong="H1121"\+w* \+w de|strong="H5921"\+w* \+w Israel|strong="H3478"\+w* \+w que|strong="H5921"\+w* regresen \+w y|strong="H5921"\+w* acampen \+w delante|strong="H6440"\+w* \+w de|strong="H5921"\+w* Pi-hahirot, \+w entre|strong="H5921"\+w* \+w Migdol|strong="H4024"\+w* \+w y|strong="H5921"\+w* \+w el|strong="H5921"\+w* \+w mar|strong="H3220"\+w*, \+w delante|strong="H6440"\+w* \+w de|strong="H5921"\+w* Baal-zefón. Frente \+w a|strong="H3068"\+w* \+w él|strong="H5921"\+w* \+w acamparán|strong="H2583"\+w* \+w junto|strong="H5921"\+w* \+w al|strong="H5921"\+w* \+w mar|strong="H3220"\+w*,\wj*  
\v 3 \wj \+w porque|strong="H5921"\+w* \+w Faraón|strong="H6547"\+w* dirá \+w de|strong="H5921"\+w* \+w los|strong="H1992"\+w* \+w hijos|strong="H1121"\+w* \+w de|strong="H5921"\+w* \+w Israel|strong="H3478"\+w*: \+w Ellos|strong="H1992"\+w* están vagando sin rumbo cierto \+w en|strong="H5921"\+w* \+w el|strong="H5921"\+w* país. \+w El|strong="H5921"\+w* \+w desierto|strong="H4057"\+w* \+w los|strong="H1992"\+w* encerró.\wj*  
\v 4 \wj \+w Yo|strong="H3588"\+w* \+w endureceré|strong="H2388"\+w* \+w el|strong="H3588"\+w* \+w corazón|strong="H3820"\+w* \+w de|strong="H3588"\+w* \+w Faraón|strong="H6547"\+w* \+w y|strong="H3588"\+w* \+w los|strong="H3605"\+w* \+w perseguirá|strong="H7291"\+w*. \+w Yo|strong="H3588"\+w* seré glorificado \+w por|strong="H3588"\+w* medio \+w de|strong="H3588"\+w* \+w Faraón|strong="H6547"\+w* \+w y|strong="H3588"\+w* \+w de|strong="H3588"\+w* \+w todo|strong="H3605"\+w* \+w su|strong="H3588"\+w* \+w ejército|strong="H2428"\+w*, \+w y|strong="H3588"\+w* \+w los|strong="H3605"\+w* \+w egipcios|strong="H4713"\+w* entenderán \+w que|strong="H3588"\+w* \+w Yo|strong="H3588"\+w* soy \+nd \+w Yavé|strong="H3068"\+w*\+nd*.\wj*  
\p \w Y|strong="H3068"\w* \w ellos|strong="H3605"\w* \w hicieron|strong="H6213"\w* \w así|strong="H3651"\w*.   
\p
\v 5 \w Cuando|strong="H3588"\w* \w se|strong="H5971"\w* le informó \w al|strong="H4428"\w* \w rey|strong="H4428"\w* \w de|strong="H3588"\w* \w Egipto|strong="H4714"\w* \w que|strong="H3588"\w* \w el|strong="H3588"\w* \w pueblo|strong="H5971"\w* \w huyó|strong="H1272"\w*, \w el|strong="H3588"\w* \w corazón|strong="H3824"\w* \w de|strong="H3588"\w* \w Faraón|strong="H6547"\w* \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w de|strong="H3588"\w* sus esclavos \w se|strong="H5971"\w* mudó \w contra|strong="H3478"\w* \w el|strong="H3588"\w* \w pueblo|strong="H5971"\w*, \w y|strong="H3588"\w* dijeron: ¿\w Qué|strong="H3588"\w* \w es|strong="H3588"\w* \w esto|strong="H2063"\w* \w que|strong="H3588"\w* \w hicimos|strong="H6213"\w*? ¿\w Por|strong="H3588"\w* \w qué|strong="H3588"\w* dejamos salir \w a|strong="H3068"\w* \w Israel|strong="H3478"\w* \w de|strong="H3588"\w* nuestra esclavitud?  
\v 6 Entonces aparejó su carroza, \w tomó|strong="H3947"\w* \w consigo|strong="H5973"\w* \w a|strong="H3068"\w* su \w pueblo|strong="H5971"\w*  
\v 7 \w y|strong="H5921"\w* \w tomó|strong="H3947"\w* 600 carruajes escogidos \w y|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* carruajes \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w* \w con|strong="H5921"\w* capitanes \w sobre|strong="H5921"\w* \w todos|strong="H3605"\w* \w ellos|strong="H5921"\w*.   
\p
\v 8 \nd \+w Yavé|strong="H3068"\+w*\nd* \w endureció|strong="H2388"\w* \w el|strong="H1121"\w* \w corazón|strong="H3820"\w* \w de|strong="H1121"\w* \w Faraón|strong="H6547"\w*, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w Egipto|strong="H4714"\w*, quien \w persiguió|strong="H7291"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*. Pero \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w salieron|strong="H3318"\w* con atrevimiento.  
\v 9 \w Los|strong="H5921"\w* \w egipcios|strong="H4713"\w* \w los|strong="H5921"\w* \w persiguieron|strong="H7291"\w* \w con|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w caballos|strong="H5483"\w* \w y|strong="H5921"\w* carruajes \w de|strong="H5921"\w* \w Faraón|strong="H6547"\w*, \w con|strong="H5921"\w* sus \w jinetes|strong="H6571"\w* \w y|strong="H5921"\w* su \w ejército|strong="H2428"\w*. \w Los|strong="H5921"\w* \w alcanzaron|strong="H5381"\w* \w mientras|strong="H3605"\w* acampaban \w junto|strong="H5921"\w* \w al|strong="H5921"\w* \w mar|strong="H3220"\w*, \w al|strong="H5921"\w* lado \w de|strong="H5921"\w* Pi-hahirot, frente \w a|strong="H3068"\w* Baal-zefón.   
\p
\v 10 Cuando \w Faraón|strong="H6547"\w* se acercó, \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* levantaron sus \w ojos|strong="H5869"\w*, y \w ciertamente|strong="H2009"\w* \w los|strong="H1121"\w* \w egipcios|strong="H4713"\w* marchaban tras ellos. \w Y|strong="H3068"\w* ellos \w temieron|strong="H3372"\w* muchísimo, así \w que|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w clamaron|strong="H6817"\w* \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.  
\v 11 \w Y|strong="H3068"\w* dijeron \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: ¿\w Nos|strong="H4100"\w* \w sacaste|strong="H3318"\w* para \w que|strong="H4100"\w* \w muriéramos|strong="H4191"\w* \w en|strong="H3318"\w* \w el|strong="H6213"\w* \w desierto|strong="H4057"\w* \w porque|strong="H4100"\w* \w no|strong="H1097"\w* \w había|strong="H6213"\w* \w sepulcros|strong="H6913"\w* \w en|strong="H3318"\w* \w Egipto|strong="H4714"\w*? ¿\w Qué|strong="H4100"\w* \w es|strong="H2063"\w* \w esto|strong="H2063"\w* \w que|strong="H4100"\w* \w nos|strong="H4100"\w* \w hiciste|strong="H6213"\w* al sacarnos de \w Egipto|strong="H4714"\w*?  
\v 12 ¿\w No|strong="H3808"\w* \w es|strong="H2088"\w* \w esta|strong="H2088"\w* \w la|strong="H3588"\w* \w palabra|strong="H1697"\w* \w que|strong="H3588"\w* \w te|strong="H4480"\w* \w hablamos|strong="H1696"\w* \w en|strong="H4480"\w* \w Egipto|strong="H4714"\w*: \w Déjanos|strong="H2308"\w* \w que|strong="H3588"\w* \w sirvamos|strong="H5647"\w* \w como|strong="H3588"\w* esclavos \w a|strong="H3068"\w* \w los|strong="H3588"\w* \w egipcios|strong="H4713"\w*? \w Porque|strong="H3588"\w* sería \w mejor|strong="H2896"\w* \w para|strong="H3588"\w* nosotros \w servir|strong="H5647"\w* \w como|strong="H3588"\w* esclavos \w de|strong="H4480"\w* \w los|strong="H3588"\w* \w egipcios|strong="H4713"\w* \w que|strong="H3588"\w* \w morir|strong="H4191"\w* \w en|strong="H4480"\w* \w el|strong="H3588"\w* \w desierto|strong="H4057"\w*.   
\p
\v 13 \w Pero|strong="H3588"\w* \w Moisés|strong="H4872"\w* respondió \w al|strong="H5704"\w* \w pueblo|strong="H5971"\w*: ¡\w No|strong="H3808"\w* \w teman|strong="H3372"\w*! ¡Estén firmes \w y|strong="H3588"\w* \w vean|strong="H7200"\w* \w la|strong="H3588"\w* salvación \w que|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w hará|strong="H6213"\w* \w hoy|strong="H3117"\w* \w por|strong="H3588"\w* ustedes, \w porque|strong="H3588"\w* \w los|strong="H3588"\w* \w egipcios|strong="H4713"\w* \w que|strong="H3588"\w* ustedes \w vieron|strong="H7200"\w* \w hoy|strong="H3117"\w*, \w no|strong="H3808"\w* \w los|strong="H3588"\w* \w volverán|strong="H3254"\w* \w a|strong="H3068"\w* \w ver|strong="H7200"\w* \w jamás|strong="H5769"\w*!  
\v 14 \nd \+w Yavé|strong="H3068"\+w*\nd* luchará por ustedes, y ustedes estén quietos.   
\p
\v 15 Entonces \nd \+w Yavé|strong="H3068"\+w*\nd* \w dijo|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: \wj ¿\+w Por|strong="H4100"\+w* \+w qué|strong="H4100"\+w* \+w clamas|strong="H6817"\+w* \+w a|strong="H3068"\+w* Mí? ¡\+w Di|strong="H1696"\+w* \+w a|strong="H3068"\+w* \+w los|strong="H1121"\+w* \+w hijos|strong="H1121"\+w* \+w de|strong="H1121"\+w* \+w Israel|strong="H3478"\+w* \+w que|strong="H4100"\+w* sigan adelante!\wj*  
\v 16 \wj \+w Y|strong="H3068"\+w* tú, ¡\+w levanta|strong="H7311"\+w* tu \+w vara|strong="H4294"\+w*, \+w extiende|strong="H5186"\+w* tu \+w mano|strong="H3027"\+w* \+w sobre|strong="H5921"\+w* \+w el|strong="H5921"\+w* \+w mar|strong="H3220"\+w* \+w y|strong="H5921"\+w* divídelo, \+w y|strong="H5921"\+w* \+w los|strong="H1121"\+w* \+w hijos|strong="H1121"\+w* \+w de|strong="H5921"\+w* \+w Israel|strong="H3478"\+w* pasarán \+w por|strong="H5921"\+w* \+w en|strong="H5921"\+w* \+w medio|strong="H8432"\+w* \+w del|strong="H5921"\+w* \+w mar|strong="H3220"\+w* \+w en|strong="H5921"\+w* \+w lo|strong="H5921"\+w* seco!\wj*  
\v 17 \wj Yo \+w ciertamente|strong="H2005"\+w* \+w endureceré|strong="H2388"\+w* \+w el|strong="H3605"\+w* \+w corazón|strong="H3820"\+w* de \+w los|strong="H3605"\+w* \+w egipcios|strong="H4713"\+w* para \+w que|strong="H3605"\+w* entren tras \+w ellos|strong="H3605"\+w*, y seré glorificado en \+w Faraón|strong="H6547"\+w*, en \+w todo|strong="H3605"\+w* su \+w ejército|strong="H2428"\+w*, sus carruajes y sus \+w jinetes|strong="H6571"\+w*.\wj*  
\v 18 \wj \+w Cuando|strong="H3588"\+w* sea glorificado \+w en|strong="H3588"\+w* \+w Faraón|strong="H6547"\+w*, sus carruajes \+w y|strong="H3588"\+w* sus \+w jinetes|strong="H6571"\+w*, \+w los|strong="H3588"\+w* \+w egipcios|strong="H4713"\+w* entenderán \+w que|strong="H3588"\+w* \+w Yo|strong="H3588"\+w* soy \+nd \+w Yavé|strong="H3068"\+w*\+nd*.\wj*   
\p
\v 19 Entonces \w el|strong="H4264"\w* \w Ángel|strong="H4397"\w* \w de|strong="H6440"\w* \nd ʼElohim\nd*, Quien \w iba|strong="H1980"\w* adelante del \w campamento|strong="H4264"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*, se colocó detrás \w de|strong="H6440"\w* ellos. La \w columna|strong="H5982"\w* \w de|strong="H6440"\w* \w nube|strong="H6051"\w* se \w movió|strong="H5265"\w* \w de|strong="H6440"\w* adelante \w de|strong="H6440"\w* ellos y se \w puso|strong="H5975"\w* detrás \w de|strong="H6440"\w* ellos,  
\v 20 \w e|strong="H3068"\w* iba \w entre|strong="H3808"\w* \w el|strong="H3605"\w* \w campamento|strong="H4264"\w* de \w Egipto|strong="H4714"\w* y \w el|strong="H3605"\w* de \w Israel|strong="H3478"\w*. \w Era|strong="H1961"\w* \w nube|strong="H6051"\w* y \w oscuridad|strong="H2822"\w* \add para Egipto\add*, pero iluminaba \w la|strong="H3605"\w* \w noche|strong="H3915"\w* \add para Israel\add*. \w No|strong="H3808"\w* \w se|strong="H1961"\w* acercó \w el|strong="H3605"\w* uno al \w otro|strong="H2088"\w* en \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w noche|strong="H3915"\w*.   
\p
\v 21 Entonces \w Moisés|strong="H4872"\w* \w extendió|strong="H5186"\w* su \w mano|strong="H3027"\w* \w hacia|strong="H5921"\w* \w el|strong="H5921"\w* \w mar|strong="H3220"\w*, \w y|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* hizo \w que|strong="H5921"\w* \w el|strong="H5921"\w* \w mar|strong="H3220"\w* \w se|strong="H5921"\w* retirara \w por|strong="H5921"\w* \w medio|strong="H3027"\w* \w de|strong="H5921"\w* un recio \w viento|strong="H7307"\w* \w del|strong="H5921"\w* este \w toda|strong="H3605"\w* \w la|strong="H5921"\w* \w noche|strong="H3915"\w*. \w Las|strong="H5921"\w* \w aguas|strong="H4325"\w* \w fueron|strong="H3212"\w* divididas, \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w mar|strong="H3220"\w* \w se|strong="H5921"\w* volvió tierra seca.  
\v 22 Así \w que|strong="H4325"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* pasaron \w en|strong="H8432"\w* \w medio|strong="H8432"\w* del \w mar|strong="H3220"\w* sobre \w tierra|strong="H3004"\w* seca. Las \w aguas|strong="H4325"\w* eran un \w muro|strong="H2346"\w* para ellos \w a|strong="H3068"\w* su mano \w derecha|strong="H3225"\w* y \w a|strong="H3068"\w* su \w izquierda|strong="H8040"\w*.   
\p
\v 23 \w Los|strong="H3605"\w* \w egipcios|strong="H4713"\w* continuaron \w la|strong="H3605"\w* persecución. \w Toda|strong="H3605"\w* \w la|strong="H3605"\w* caballería de \w Faraón|strong="H6547"\w*, sus carruajes y sus \w jinetes|strong="H6571"\w* entraron tras \w ellos|strong="H3605"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* del \w mar|strong="H3220"\w*.   
\p
\v 24 Pero en la vigilia del alba, \w aconteció|strong="H1961"\w* \w que|strong="H1961"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w miró|strong="H8259"\w* desde la \w columna|strong="H5982"\w* de fuego y \w nube|strong="H6051"\w* al \w campamento|strong="H4264"\w* de \w los|strong="H1961"\w* \w egipcios|strong="H4713"\w*, y lo trastornó.  
\v 25 \w Quitó|strong="H5493"\w* las ruedas \w de|strong="H3588"\w* sus carruajes, \w de|strong="H3588"\w* modo \w que|strong="H3588"\w* \w los|strong="H3588"\w* conducían \w con|strong="H3588"\w* dificultad. \w Por|strong="H3588"\w* tanto \w los|strong="H3588"\w* \w egipcios|strong="H4714"\w* dijeron: ¡Huyamos \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*, \w porque|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w pelea|strong="H3898"\w* \w por|strong="H3588"\w* ellos \w contra|strong="H6440"\w* \w los|strong="H3588"\w* \w egipcios|strong="H4714"\w*!   
