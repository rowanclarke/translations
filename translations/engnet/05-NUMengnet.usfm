\v 4  \w and|strong="H3318"\w* \w then|strong="H1961"\w* \w the|strong="H5674"\w* \w border|strong="H1366"\w* \w will|strong="H1961"\w* \w turn|strong="H5437"\w* \w from|strong="H3318"\w* \w the|strong="H5674"\w* \w south|strong="H5045"\w* \w to|strong="H3318"\w* \w the|strong="H5674"\w* Scorpion \w Ascent|strong="H4610"\w*, \w continue|strong="H1961"\w* \w to|strong="H3318"\w* \w Zin|strong="H6790"\w*, \w and|strong="H3318"\w* \w then|strong="H1961"\w* \w its|strong="H1961"\w* \w direction|strong="H3318"\w* \w will|strong="H1961"\w* \w be|strong="H1961"\w* \w from|strong="H3318"\w* \w the|strong="H5674"\w* \w south|strong="H5045"\w* \w to|strong="H3318"\w* Kadesh Barnea. \w Then|strong="H1961"\w* \w it|strong="H5437"\w* \w will|strong="H1961"\w* \w go|strong="H3318"\w* \w to|strong="H3318"\w* Hazar Addar \w and|strong="H3318"\w* \w pass|strong="H5674"\w* \w over|strong="H5674"\w* \w to|strong="H3318"\w* \w Azmon|strong="H6111"\w*.  
