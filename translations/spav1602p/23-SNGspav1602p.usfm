\v 10 Yo \w soy|strong="H1961"\w* \w muro|strong="H2346"\w*, y mis \w pechos|strong="H7699"\w* \w como|strong="H1961"\w* \w torres|strong="H4026"\w*, desde \w que|strong="H1961"\w* \w fui|strong="H1961"\w* en sus \w ojos|strong="H5869"\w* \w como|strong="H1961"\w* la \w que|strong="H1961"\w* \w halla|strong="H4672"\w* \w paz|strong="H7965"\w*.   
