\id DAN
\h ذَانِييَالْ 
\toc1 ذَانِييَالْ 
\toc2 ذَانِييَالْ 
\toc3 دَان. 
\mt1 ذَانِييَالْ  
\c 1
\s1 ذَانِييَالْ جَارْ إِمْسخَّارنْ ن ؤُجدْجِيذْ ن بَابِيلْ  
\m
\v 1 ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثْڒَاثَا ن ثْڭلْذَا ن ؤُجدْجِيذْ يَاهُويَاقِيمْ، أَجدْجِيذْ ن يَاهُوذَا، يُوسَا-د نابُوخَاذْنَاصَّارْ، أَجدْجِيذْ ن بَابِيلْ، غَارْ ؤُرْشَالِيمْ ؤُشَا إِنّضْ أَسْ-د. \x ◘ \xo 1:‏1 \xt 2 إِج. 24‏:‏2، 3؛ 2 إِم. 36‏:‏6\x*  
\v 2 سِيذِي إِڭَّا يَاهُويَاقِيمْ، أَجدْجِيذْ ن يَاهُوذَا، ذڭْ ؤُفُوسْ نّسْ، ؤُڒَا ذ إِشْثْ ن ثسْغَارْثْ ن ڒقْشُوعْ ن ثَادَّارْثْ ن أَربِّي. نتَّا يِيوْيِي ثنْ غَارْ ثمُّورْثْ ن شِينْعَارْ، ذِي ثَادَّارْثْ ن أَربِّي نّسْ ؤُشَا يِيوْيِي ثنْ غَارْ وخَّامْ ن ثْخُوبَايْ ن أَربِّي نّسْ.   
\m
\v 3 إِنَّا ؤُجدْجِيذْ إِ أَشْفَانَازْ، أَزدْجِيفْ ن إِمْسخَّارنْ نّسْ إِشنّْعنْ، أَقَا وَانِيثَا أَذْ يَاوِي إِحُوذْرِييّنْ زڭْ أَيْثْ ن إِسْرَائِيل، زِي زَّارِيعثْ ن ؤُجدْجِيذْ ؤُ زِي ثَارْوَا ن ثَاصِيڒثْ،  
\v 4 \add إِحُوذْرِييّنْ\add* إِنِّي وَارْ ذِي إِدْجِي ؤُڒَا ذ إِجّْ ن ڒْعِيبْ، \add إِنِّي\add* ذ إِصبْحَاننْ، إِتّْوَاسّْڒمْذنْ ذِي مَارَّا ثِيغِيثْ، سّْننْ ثُوسّْنَا، غَارْسنْ ڒعْقڒْ س ڒفْهَامثْ ؤُ غَارْسنْ ثِيزمَّارْ إِ ثْسخَّارْثْ ذِي ڒقْصَارْ ن ؤُجدْجِيذْ، حِيمَا أَذْ أَسنْ سّْڒمْذنْ إِذْلِيسنْ ذ يِيڒسْ ن إِكَالْذَانِييّنْ. \f ◼ \fr 1:‏4 \ft \+bd ’إِ ثْسخَّارْثْ‘\+bd* - س ثْعِيبْرَانِيثْ ’إِ ؤُبذِّي‘، إِخْسْ أَذْ يِينِي ’حِيمَا أَذْ بدّنْ أَذْ سخَّارنْ إِ ؤُجدْجِيذْ‘.\f*  
\v 5 أَجدْجِيذْ إِڭَّا أَسنْ إِجّْ ن لْمَاعِيشَا ذِي كُوڒْ أَسّْ زِي مَاشَّا ن ؤُجدْجِيذْ ؤُ زِي بِينُو ن طَّابْڒَا ن ثْسسِّيثْ نّسْ، ؤُ حِيمَا أَذْ ثنْ سّْڒمْذنْ ثْڒَاثَا ن إِسڭّْوُوسَا. غَارْ ؤُنڭَّارْ ن إِسڭّْوُوسَا نِّي أَذْ سخَّارنْ زَّاثْ إِ وُوذمْ ن ؤُجدْجِيذْ.   
\m
\v 6 زڭْ أَيْثْ ن يَاهُوذَا ثُوغَا ذِينْ جَارْ أَسنْ ذَانِييَالْ، حَانَانْيَا، مِيشَايِيلْ ذ عَازَارْيَا.  
\v 7 أَمقّْرَانْ ن إِمْسخَّارنْ إِشنّْعنْ إِوْشَا أَسنْ إِسْمَاونْ نّغْنِي. ذَانِييَالْ إِڭَّا أَسْ بَالْطَاشَاصَّارْ، حَانَانْيَا شَاذْرَاخْ، مِيشَايِيلْ مِيشَاخْ ؤُ عَازَارْيَا \add إِڭَّا أَسْ\add* عَابْذْ-نَاغُو.   
\m
\v 8 ذَانِييَالْ ثُوغَا إِڭَّا ؤُڒْ نّسْ مَاحنْذْ وَارْ إِسّْخمِّيجْ إِخفْ نّسْ س مَاشَّا ذ بِينُو ن طَّابْڒَا ن ؤُجدْجِيذْ ؤُ إِتَّارْ إِ ؤُمقّْرَانْ ن إِمْسخَّارنْ إِشنّْعنْ، حِيمَا وَارْ إِسّْخمِّيجْ إِخفْ نّسْ \add زَّايْسنْ\add*.  
\v 9 أَربِّي إِسّْشنْ إِ ذَانِييَالْ ثَامخْسِيوْثْ \add نّسْ\add* إِشوَّارنْ ذ أَرّحْمثْ \add نّسْ\add* زَّاثْ إِ وُوذمْ ن أَمقّْرَانْ ن إِمْسخَّارنْ إِشنّْعنْ.  
\v 10 أَمقّْرَانْ ن إِمْسخَّارنْ إِشنّْعنْ إِنَّا إِ ذَانِييَالْ: ”نشّْ تّڭّْوذغْ زِي بَابْ إِنُو، أَجدْجِيذْ، ونِّي إِ كنِّيوْ إِوصَّانْ خْ مَاشَّا ذ ثْسسِّيثْ، مَاغَارْ مَايمِّي أَذْ إِژَارْ إِغمْبَابْ نْومْ زرّْينْ خْ إِحُوذْرِييّنْ \add نّغْنِي\add*، إِقْرِيننْ نْومْ؟ كنِّيوْ أَذْ ثوْشمْ أَزدْجِيفْ إِنُو إِ ؤُجدْجِيذْ!“   
\m
\v 11 \add خنِّي\add* إِنَّا ذَانِييَالْ إِ ؤُوقَّافْ نِّي ثُوغَا إِڭَّا ؤُمقّْرَانْ ن إِمْسخَّارنْ إِشنّْعنْ خْ ذَانِييَالْ، حَانَانْيَا، مِيشَايِيلْ ذ عَازَارْيَا:  
\v 12 ”قدْجبْ إِمْسخَّارنْ نّشْعشْرَا ن وُوسَّانْ. أجّْ أَذْ أَنغْ وْشنْ زِي مِينْ إِتّْوَازَارْعنْ إِ مَاشَّا ؤُڒَا ذ وَامَانْ حِيمَا أَذْ نْسُو.  
\v 13 \add خنِّي\add* أجّْ أَذْ أَنغْ قدّْمنْ زَّاثْ إِ وُوذمْ نّشْ مَامّشْ إِدْجَا وَادُّوذْ نّغْ ؤُڒَا ذ إِحُوذْرِييّنْ نِّي إِتّتّنْ زِي مَاشَّا ن ؤُجدْجِيذْ مَامّشْ إِدْجَا وَادُّوذْ نْسنْ ؤُ أڭّْ أَمْ مَامّشْ ثتّْوَاڒِيذْ شكْ!“  
\v 14 نتَّا إِسْڒَا أَسنْ ؤُشَا إِقدْجبْ إِ-ثنْعشْرَا ن وُوسَّانْ.  
\v 15 غَارْ ؤُنڭَّارْ نعشْرَا ن وُوسَّانْ ذوْڒنْ نِيثْنِي تّْبَاننْ شْنَانْ ؤُ صبْحنْ خْ مَارَّا إِحُوذْرِييّنْ إِ إِشّنْ زِي مَاشَّا ن ؤُجدْجِيذْ.  
\v 16 \add خنِّي\add* إِمْسَارْ أَقَا أَوقَّافْ إِكّسْ أَسنْ مَاشَّا نْسنْ \add إِڭلّْذنْ\add* ذ بِينُو إِ إِتّْخصَّا أَسنْ أَذْ سْونْ ؤُشَا إِوْشَا أَسنْ زِي مِينْ إِتّْوَازَارْعنْ.  
\v 17 إِ أَربْعَا ن إِحُوذْرِييّنْ-أَ إِوْشَا أَسنْ أَربِّي ثُوسّْنَا ذ ڒعْقڒْ زِي مَارَّا إِذْلِيسنْ ذ ثِيغِيثْ. ؤُشَا إِ ذَانِييَالْ إِوْشَا أَسْ ؤُڒَا ذ أَحكَّارْ ذِي مَارَّا ڒوْحِييْ ذ ثِيرْجَا.   
\m
\v 18 غَارْ ؤُنڭَّارْ ن وُوسَّانْ إِ خْ ثُوغَا إِنَّا ؤُجدْجِيذْ أَقَا أَوَارْنِي أَسنْ إِتّْخصَّا أَذْ ثنْ قدّْمنْ \add زَّاثسْ\add*، يِيوْيِي إِ-ثنْ ؤُمقّْرَانْ ن إِمْسخَّارنْ إِشنّْعنْ، إِنِّي ؤُمِي تّْوَادّْزنْ إِمدْجَاڒنْ، زَّاثْ إِ وُوذمْ ن نابُوخَاذْنَاصَّارْ.  
\v 19 إِسِّيوڒْ ؤُجدْجِيذْ أَكِيذْسنْ ؤُ وَارْ إِتّْوِيفْ ؤُڒَا ذ إِجّنْ جَارْ أَسنْ أَمْ ذَانِييَالْ، حَانَانْيَا، مِيشَايِيلْ ذ عَازَارْيَا ؤُ نِيثْنِي ذوْڒنْ تّْسخَّارنْ إِ ؤُجدْجِيذْ.  
\v 20 ذِي كُوڒْ ثَامسْڒَاشْثْ إِ ذِي ثُوغَا إِتّْخصَّا ثِيغِيثْ ذ ڒفْهَامثْ إِ خْ ثُوغَا ثنْ إِتّْسقْسَا ؤُجدْجِيذْ، يُوفَا أَقَا عْذُونْ مَارَّا ثَارْوَا ن ثْسحَّارْثْ ذ إِمسْنَاونْ ن إِثْرَانْ ذِي ثْڭلْذِيثْ نّسْ سعشْرَا ن ثْسقَّارْ.  
\v 21 ذَانِييَالْ إِقِّيمْ ذِينِّي أَڒْ أَسڭّْوَاسْ أَمزْوَارُو ن ؤُجدْجِيذْ كُورَاشْ.   
\b  
\b  
\m  
\c 2
\s1 ثَارْجِيثْ ن ؤُجدْجِيذْ نَاپُوخَاذْنَاصَّارْ  
\m
\v 1 ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثْنَاينْ ن ثْڭلْذَا ن نابُوخَاذْنَاصَّارْ يُورْجَا نابُوخَاذْنَاصَّارْ ثِيرْجَا. بُوحْبڒْ نّسْ إِنّحْوڒْ ؤُشَا إِرُوحْ أَسْ يِيضصْ.  
\v 2 \add خنِّي\add* إِنَّا ؤُجدْجِيذْ أَذْ ڒَاغَانْ إِ ثَارْوَا ن ثْسحَّارْثْ ذ إِمسْنَاونْ ن إِثْرَانْ ذ إِسحَّارنْ ذ إِكَالْذَانِييّنْ حِيمَا نِيثْنِي أَذْ أَسْ فسَّارنْ ثِيرْجَا نّسْ. نِيثْنِي ؤُسِينْ-د ؤُشَا بدّنْ زَّاثْ إِ وُوذمْ ن ؤُجدْجِيذْ.   
\m
\v 3 إِنَّا أَسنْ ؤُجدْجِيذْ: ”نشّْ غَارِي إِشْثْ ن ثَارْجِيثْ ؤُ بُوحْبڒْ إِنُو إِنّحْوڒْ، مَاحنْذْ أَذْ سّْنغْ مِينْ ثخْسْ أَذْ ثِينِي ثَارْجِيثْ.“  
\v 4 \add خنِّي\add* نَّانْ إِكَالْذَانِييّنْ إِ ؤُجدْجِيذْ:  
\b  
\m \bd \+bdit مِينْ يُورَانْ سْوَادَّايْ أَقَا-ث س يِيڒسْ ن\+bdit* ثْرَامِيثْ.\bd*  
\b  
\m \add أَ\add* أَجدْجِيذْ، دَّارْ إِ ڒبْذَا! إِنِي أَسنْ إِ إِمْسخَّارنْ نّشْ ثَارْجِيثْ، \add خنِّي\add* أَذْ أَكْ ت نْفسَّارْ!“  
\v 5 يَارَّا-د ؤُجدْجِيذْ، إِنَّا إِ إِكَالْذَانِييّنْ: ”أَقَا إِفّغْ-د ڒُومُورْ. مَاڒَا كنِّيوْ وَارْ ذ أَيِي ثسَّارْڭْبمْ خْ ثَارْجِيثْ، أَذْ ثتّْوَاقسّمْ ذ إِوثْوِيثنْ ؤُ ثُوذْرِينْ نْومْ أَذْ ثنْثْ أَرّنْ ذ ثِيزُوبَايِّينْ. \x ◘ \xo 2:‏5 \xt دَان. 3‏:‏29\x*  
\v 6 مَاشَا مَاڒَا ثْفسَّارمْ أَيِي كنِّيوْ ثَارْجِيثْ ذ مِينْ ثخْسْ أَذْ ثِينِي، أَذْ ثطّْفمْ زَّايِي ثَارْزفِينْ ذ أَرِّيغَالُوثنْ ذ شَّانْ أَمقّْرَانْ. س ؤُينِّي، سشّْنمْ أَيِي ثَارْجِيثْ إِنُو ذ ڒْمعْنَا نّسْ.“  
\v 7 أَرِّينْ-د نِيثْنِي خَاسْ ثْوَاڒَا وِيسّْ ثْنَاينْ، نَّانْ: ”أجّْ أَجدْجِيذْ أَذْ إِحَاجَا ثَارْجِيثْ إِ إِمْسخَّارنْ نّسْ، \add خنِّي\add* أَذْ أَسْ نوْشْ أَفسَّارْ.“  
\v 8 يَارَّا-د ؤُجدْجِيذْ، إِنَّا: ”ڒخُّو سّْنغْ نِيشَانْ، أَقَا كنِّيوْ ثخْسمْ أَذْ ثَاربْحمْ ڒْوقْثْ، ؤُمِي ثتّْوَاڒَامْ أَقَا إِفّغْ-د ڒُومُورْ زَّايِي.  
\v 9 مَاڒَا وَارْ ذ أَيِي ثسَّارْڭْبمْ خْ ثَارْجِيثْ، أَذْ كنِّيوْ إِڒْقفْ ڒْحُوكْمْ ذ إِجّْ. كنِّيوْ ثكّْسمْ أَوَاڒْ مَاحنْذْ أَذْ خَافِي ثسّْخَارّْقمْ ؤُ أَذْ أَيِي ثْغشّمْ أَڒْ غَا ثْبدّڒْ ڒْوقْثْ. س ؤُينِّي، إِنِي أَيِي ثَارْجِيثْ، خنِّي أَذْ سّْنغْ أَقَا ثْزمَّارمْ أَذْ أَيِي ثوْشمْ ؤُڒَا ذ ڒْمعْنَا نّسْ.“  
\v 10 أَرِّينْ-د إِكَالْذَانِييّنْ قِيبَاتْشْ إِ ؤُجدْجِيذْ، نَّانْ: ”وَارْ ذِينْ ؤُڒَا ذ إِجّْ ن بْنَاذمْ ذِي ثمُّورْثْ ونِّي إِزمَّارنْ أَذْ إِفسَّارْ ثَامسْڒَاشْثْ-أَ إِ ؤُجدْجِيذْ. س ؤُينِّي وَارْ ذِينْ ؤُڒَا ذ إِجّْ ن ؤُجدْجِيذْ، مَامّشْ إِدْجَا ذ أَمقّْرَانْ نِيغْ مشْحَاڒْ مَا غَارسْ ذ ثِيزمَّارْ، ونِّي إِتَّارنْ ثَامسْڒَاشْثْ أَمْ ثَانِيثَا زِي شَا ن ؤُسحَّارْ نِيغْ أَمسْنَاوْ ن إِثْرَانْ نِيغْ أَكَالْذَانِييْ.  
\v 11 مِينْزِي ثَامسْڒَاشْثْ إِ إِتَّارْ ؤُجدْجِيذْ ثوْعَارْ أَطَّاسْ ؤُ وَارْ ذِينْ ؤُڒَا ذ إِجّْ إِزمَّارْ أَذْ ث إِسَّارْڭبْ، مْغِيرْ إِربِّيثنْ نِّي وَارْ إِزدّْغنْ جَارْ إِوْذَانْ.“   
\m
\v 12 س ؤُينِّي إِذْوڒْ ؤُجدْجِيذْ إِتّْحَاجَا ؤُ إِتّْخيَّاقْ كْثَارْ، يُومُورْ أَذْ نْغنْ مَارَّا إِمِيغِيسنْ ذِي بَابِيلْ.  
\v 13 إِفّغْ-د ڒُومُورْ مَاحنْذْ أَذْ نْغنْ إِمِيغِيسنْ. أَرْزُونْ ؤُڒَا خْ ذَانِييَالْ ذ إِمدُّوكَّاڒْ نّسْ حِيمَا أَذْ \add ثنْ\add* نْغنْ.   
\m
\v 14 \add خنِّي\add* يَارَّا-د ذَانِييَالْ س ثِيغِيثْ ذ ڒعْقڒْ غَارْ أَرِييُوخْ، ڒْقبْطَانْ ن إِعسَّاسنْ ن أَرِّيمثْ ن ؤُجدْجِيذْ، ونِّي ثُوغَا إِفّْغنْ حِيمَا أَذْ إِنغْ إِمِيغِيسنْ ن بَابِيلْ.  
\v 15 ذَانِي ألْ إِطّفْ ذڭْ وَاوَاڒْ، إِنَّا إِ أَرِييُوخْ، أَكُومَانْذَارْ ن ؤُجدْجِيذْ: ”مَايمِّي إِڭَّا ؤُجدْجِيذْ ڒُومُوڒْ أَمُّو س ثَازْڒَا؟“ ڒخْذنِّي إِسَّارْڭبْ أَرِييُوخْ خْ ثَامسْڒَاشْثْ إِ ذَانِييَالْ.   
\m
\v 16 \add خَاسْ ؤُشَا\add* يُوذفْ ذَانِييَالْ ؤُشَا إِتَّارْ زڭْ ؤُجدْجِيذْ، مَاحنْذْ نتَّا أَذْ أَسْ إِوْشْ إِجّْ ن ڒْمِيجَاڒْ ن ڒْوقْثْ، مَاحنْذْ أَذْ أَسْ إِوْشْ أَفسَّارْ.  
\v 17 خنِّي يُويُورْ ذَانِييَالْ غَارْ ثَادَّارْثْ نّسْ، إِحَاجَا ثَامسْڒَاشْثْ إِ إِعْشِيرنْ نّسْ حَانَانْيَا، مِيشَايِيلْ ذ عَازَارْيَا،  
\v 18 حِيمَا أَذْ تَّارنْ أَرّحْمثْ زِي أَربِّي ن إِجنْوَانْ خْ سِّيرّْ-أَ حِيمَا ذَانِييَالْ ذ إِعْشِيرنْ نّسْ وَارْ ثتّْوَاهلِّيكنْ شَا أَكْ-ذ إِمِيغِيسنْ نّغْنِي ن بَابِيلْ.   
\m
\v 19 خَاسْ ؤُشَا إِتّْوَاسَّارْڭبْ-د إِ ذَانِييَالْ مِينْ ثُوغَا إِنُّوفَّارنْ ذڭْ إِجّْ ن ڒوْحِييْ سْ دْجِيڒثْ. خنِّي إِبَاركْ ذَانِييَالْ أَربِّي ن إِجنْوَانْ.  
\v 20 يَارَّا-د ذَانِييَالْ، إِنَّا:  
\b  
\m ”أَذْ إِتّْوَابَاركْ إِسمْ ن أَربِّي  
\m زِي ڒبْذَا أَڒْ ڒبْذَا قَاعْ،  
\m مَاغَارْ ثِيغِيثْ ذ جّهْذْ أَقَا أَثنْ نّسْ.   
\m
\v 21 مَاغَارْ نتَّا إِتّْبدَّاڒْ زَّامَانَاثْ ذ ثْسَاعّثِينْ.  
\m نتَّا إِكّسْ إِجدْجِيذنْ ؤُ يَاڒقّمْ إِجدْجِيذنْ،  
\m نتَّا إِوْشَا ثِيغِيثْ إِ إِمِيغِيسنْ  
\m ؤُ ثُوسّْنَا إِ يِينِّي غَارْ إِدْجَا ڒعْقڒْ.   
\m
\v 22 نتَّا إِسَّارْڭبْ ثِيمسْڒَايِينْ يُودْجْغنْ إِنُّوفَارنْ،  
\m نتَّا إِسّنْ مِينْ إِدْجَانْ ذِي ثَادْجسْثْ،  
\m مَاغَارْ ثَافَاوْثْ ثْزدّغْ غَارسْ. \x ◘ \xo 2:‏22 \xt أَيُوبْ 32‏:‏8\x*   
\m
\v 23 شكْ، \add أَ\add* أَربِّي ن ڒجْذُوذْ إِنُو،  
\m أَقَا تّْقَاذِيغْ ؤُ تّْصبّْحغْ،  
\m مِينْزِي ثوْشِيذْ أَيِي ثِيغِيثْ ذ جّهْذْ،  
\m ؤُ ؤُمِي ثسَّارْڭْبذْ أَيِي ڒخُّو  
\m مِينْ زَّايكْ نتَّارْ،  
\m مَاغَارْ شكْ ثسَّارْڭْبذْ أَنغْ  
\m خْ ثَامسْڒَاشْثْ ن ؤُجدْجِيذْ.“   
\b  
\m
\v 24 س ؤُينِّي يُويُورْ ذَانِييَالْ غَارْ أَرِييُوخْ، ونِّي إِڭَّا ؤُجدْجِيذْ مَاحنْذْ أَذْ إِسّْهلّكْ إِمِيغِيسنْ ن بَابِيلْ. يُويُورْ غَارسْ، إِسِّيوڒْ أَكِيذسْ أَمُّو: ”وَارْ نقّْ إِمِيغِيسنْ ن بَابِيلْ، مَاشَا نْذهْ أَيِي غَارْ وُوذمْ ن ؤُجدْجِيذْ. نشّْ أَذْ أَسْ سّشْنغْ أَفسَّارْ إِ ؤُجدْجِيذْ.“   
\m
\v 25 ڒخْذنِّي إِنْذهْ أَرِييُوخْ ذَانِييَالْ س ثَازْڒَا غَارْ ؤُجدْجِيذْ ؤُشَا إِسِّيوڒْ أَكِيذسْ أَمُّو: ”نشّْ ؤُفِيغْ إِجّْ ن ورْيَازْ جَارْ إِمنْفِييّنْ ن يَاهُوذَا ونِّي ذ إِ غَا إِسّشْننْ أَفسَّارْ إِ شكْ، \add أَ\add* أَجدْجِيذْ!“   
\m
\v 26 \add خنِّي\add* إِطّفْ ؤُجدْجِيذْ ذڭْ وَاوَاڒْ، إِنَّا إِ ذَانِييَالْ، ونِّي ؤُمِي قَّارنْ بَالْطَاشَاصَّارْ: ”مَا ثْزمَّارذْ أَذْ أَيِي ثسَّارْڭْبذْ خْ ثَارْجِيثْ نِّي ژْرِيغْ ذ ڒْمعْنَا نّسْ؟“   
\m
\v 27 يَارَّا-د ذَانِييَالْ زَّاثْ إِ ؤُجدْجِيذْ، إِنَّا: ”مِينْ إِنُّوفَّارنْ إِ إِتَّارْ ؤُجدْجِيذْ وَارْ زمَّارمْ إِمِيغِيسنْ ذ إِمسْنَاونْ ن إِثْرَانْ ذ ثَارْوَا ن ثْسحَّارْثْ ذ إِڭزَّاننْ أَذْ ث سَّارڭْبنْ إِ ؤُجدْجِيذْ.  
\v 28 مَاشَا أَقَا ذِينْ إِجّْ ن أَربِّي ذڭْ ؤُجنَّا ونِّي إِسَّارْڭَابنْ مِينْ إِنُّوفَارنْ. نتَّا إِسَّارْڭبْ إِ ؤُجدْجِيذْ نابُوخَاذْنَاصَّارْ مِينْ غَا إِمْسَارنْ ذڭْ ؤُنڭَّارْ ن وُوسَّانْ. أَقَا ثَا ذ ثَارْجِيثْ نّشْ ذ إِوحَّانْ نِّي د-يُوسِينْ ذڭْ ؤُزدْجِيفْ نّشْ ذِي ثَاسُّوثْ.   
\b  
\m
\v 29 شكْ، \add أَ\add* أَجدْجِيذْ، ؤُمِي شكْ ثُوغَا ذِي ثَاسُّوثْ ؤُسِينْ أَشْ-د إِخَارِّيصنْ \add خْ مِينْ\add* إِ غَا إِمْسَارنْ أَوَارْنِي أَيَا ؤُ ونِّي إِسَّارْڭْبنْ مِينْ إِنُوفَّارنْ، أَقَا إِسّْشنْ أَشْ مِينْ غَا إِمْسَارنْ.  
\v 30 أَقَا إِتّْوَاسّْشنْ أَيِي-د مِينْ ثُوغَا إِنُّوفَّارنْ، وَارْ إِدْجِي زِي ثِيغِيثْ نِّي ذَايِي سنّجْ إِ مَارَّا مِينْ إِدَّارنْ، مَاشَا حِيمَا أَذْ إِتّْوَاسَّارْڭبْ ؤُفسَّارْ إِ ؤُجدْجِيذْ ؤُ حِيمَا أَذْ ثسّْنذْ إِخَارِّيصنْ ن وُوڒْ نّشْ.“   
\b  
\m
\v 31 ”شكْ، \add أَ\add* أَجدْجِيذْ، ثُوغَا ثْخزَّارذْ ؤُ ثژْرِيذْ إِجّْ ن ڒخْيَاڒْ ذ أَمقّْرَانْ. ڒخْيَاڒْ-أَ ثُوغَا إِسِّيڭّْوذْ ؤُ ثِيسِّيقْثْ نّسْ ثدْجَا أَڒْ طَّارْفْ. أَقَا إِبدّْ زَّاثكْ ؤُ إِسِّيڭّْوذْ أَمْ ث ثژْرِيذْ.  
\v 32 أَزدْجِيفْ ن ڒخْيَاڒْ-أَ ثُوغَا ذ ؤُرغْ إِصْفَانْ، إِذْمَارنْ نّسْ ذ إِغَادْجنْ نّسْ ذ نُّوقَارْثْ، أَعذِّيسْ نّسْ ذ ثِيجْعِينَّا نّسْ ذ نّْحَاسْ،  
\v 33 ثِيمسَّاضِينْ نّسْ ذ ؤُزَّاڒْ، إِضَارنْ نّسْ شْوَايْثْ ذ ؤُزَّاڒْ ؤُ شْوَايْثْ \add زَّايْسنْ\add* ذ ثَارِّيسْثْ.  
\v 34 أَيَا إِ ثژْرِيذْ، أَڒَامِي إِتّْوَاشدْجقْ إِجّْ ن وژْرُو بْڒَا إِفَاسّنْ. وَانِيثَا إِڒْقفْ ڒخْيَاڒْ نِّي غَارْ إِضَارنْ نّسْ ن وُوزَّاڒْ أَكْ-ذ ثَارِّيسْثْ، ؤُشَا إِڒْبزْ إِ-ثنْ.  
\v 35 خنِّي إِتّْوَاڒْبزْ وُوزَّاڒْ ذ ثَارِّيسْثْ ذ نّْحَاسْ ذ نُّوقَارْثْ ذ وُورغْ ذڭْ إِشْثْ ن ثشْثِي ؤُشَا ذوْڒنْ أَمْ ؤُڒُومْ ن إِنذْرَارنْ ذڭْ ؤُنبْذُو، ؤُشَا إِسُوضْ ذَايْسنْ ؤُسمِّيضْ، وَارْ زَّايْسنْ ثقِّيمْ ؤُڒَا ذ إِشْثْ ن جُّورثْ. مَاشَا أَژْرُو نِّي إِڒقْفنْ ڒخْيَاڒْ، إِذْوڒْ ذ إِجّْ ن وذْرَارْ أَمقّْرَانْ، إِعمَّارْ مَارَّا ثَامُّورْثْ.   
\b  
\m
\v 36 ذ ثَا ذ ثَارْجِيثْ. أَذْ نْعَاوذْ مِينْ ثخْسْ أَذْ ثِينِي \add ڒخُّو\add* زَّاثْ إِ ؤُجدْجِيذْ. *   
\b  
\m
\v 37 شكْ، \add أَ\add* أَجدْجِيذْ، \add ثدْجِيذْ\add* ذ أَجدْجِيذْ ن إِجدْجِيذنْ، مَاغَارْ أَربِّي ن إِجنْوَانْ إِوْشَا أَشْ ثَاڭلْذَا ذ ثْزمَّارْ ذ جّهْذْ ذ شَّانْ.  
\v 38 مَانِي مَا زدّْغنْ ثَارْوَا ن بْنَاذمْ، إِڭَّا إِمُودَّارنْ ن ڒخْڒَا ذ إِجْضَاضْ ن ؤُجنَّا ذڭْ ؤُفُوسْ نّشْ ؤُ نتَّا إِڭَّا شكْ ذ ڒْحَاكمْ خْ مَارَّا مَانْ أَيَا. أَقَا شكْ ذ أَزدْجِيفْ نِّي ن وُورغْ. *   
\b  
\m
\v 39 أَوَارْنِي أَشْ أَذْ د-ثَاسْ إِشْثْ ن ثْڭلْذِيثْ نّغْنِيثْ، ثُوذْرُوسْ خْ ثنِّي نّشْ. أَوَارْنِي أَسْ أَذْ ثِيڒِي إِشْثْ ن نّغْنِيثْ، ثَاڭلْذِيثْ وِيسّْ ثْڒَاثَا ن نّْحَاسْ، ثنِّي أَذْ ثحْكمْ خْ مَارَّا ثَامُّورْثْ. *   
\b  
\m
\v 40 ؤُشَا ثَاڭلْذِيثْ وِيسّْ أَربْعَا أَذْ ثِيڒِي ثجْهذْ أَمْ وُوزَّاڒْ، مَاغَارْ ؤُزَّاڒْ إِڒبّزْ ؤُ إِبَارِّي مَارَّا، ؤُ أَمْ مَامّشْ إِتَّارژَّا وُوزَّاڒْ مَارَّا، أَمُّو إِ غَا ثڒْبزْ ؤُ ثْبَارِّي مَارَّا. *   
\b  
\m
\v 41 ؤُمِي ثژْرِيذْ بلِّي إِضَارنْ ذ ثْفذْنِينْ أَقَا شْوَايْثْ زَّايْسنْ س ثَارِّيسْثْ ن بُو-ثْڒَاخْثْ ؤُ شْوَايْثْ زَّايْسنْ س وُوزَّاڒْ، \add إِخْسْ أَذْ يِينِي\add* أَقَا أَذْ ثِيڒِي ذ إِشْثْ ن ثْڭلْذِيثْ ثمْسبْضَا. شْوَايْثْ زَّايسْ \add وَاهَا\add* أَذْ ذَايسْ ثِيڒِي ڒقْسَاحثْ أَمْ وُوزَّاڒْ، مَاغَارْ ثژْرِيذْ ؤُزَّاڒْ إِصُّورْ س ثَارِّيسْثْ ن ثْڒَاخْثْ. \f ◼ \fr 2:‏41 \ft \+bd ’أَقدَّارْ‘\+bd* - نِيغْ ’بُو-ثْڒَاخْثْ‘.\f*  
\v 42 ؤُ \add ؤُمِي ثژْرِيذْ\add* ثِيفذْنِينْ ن إِضَارنْ، أَقَا شْوَايْثْ زَّايْسنْثْ س وُوزَّاڒْ ؤُ شْوَايْثْ زَّايْسنْثْ س ثَارِّيسْثْ، \add إِخْسْ أَذْ يِينِي\add* أَقَا ثَاڭلْذِيثْ نِّي شْوَايْثْ زَّايسْ أَذْ ذَايسْ ثِيڒِي ڒقْسَاحثْ ؤُ شْوَايْثْ أَذْ ثِيڒِي ثَارْخفْ.  
\v 43 ؤُ ؤُمِي ثژْرِيضْ أَقَا ؤُزَّاڒْ إِصُّورْ س ثَارِّيسْثْ ن ثْڒَاخْثْ، \add إِخْسْ أَذْ يِينِي\add* نِيثْنِي أَذْ صُّورنْ س زَّارِيعثْ ن ورْيَازْ، مَاشَا وَارْ ڒسّْقنْ شَا إِجّْ غَارْ ونّغْنِي، وَا وَارْ إِڒسّقْ أَكْ-ذ وَا، أَمْ وُوزَّاڒْ وَارْ إِڒسّْقنْ أَكْ-ذ ثْڒَاخْثْ.  
\v 44 مَاشَا ذڭْ وُوسَّانْ ن إِجدْجِيذنْ نِّي أَذْ إِسّْبدّْ أَربِّي ن إِجنْوَانْ إِشْثْ ن ثْڭلْذِيثْ نِّي وَارْ ثتّْوَاضيِّيعْ إِ ڒبْذَا ؤُ ثَاڭلْذَا نّسْ وَارْ ثتّْرِيحْعمَّارْصْ غَارْ إِجّْ ن ڒْڭنْسْ نّغْنِي. أَذْ ثڒْبزْ ؤُ أَذْ ثبْضڒْ مَارَّا ثِيڭلْذِيوِينْ نِّي، مَاشَا نتَّاثْ س يِيخفْ نّسْ أَثْ ثِيڒِي إِ ڒبْذَا قَاعْ. \x ◘ \xo 2:‏44 \xt دَان. 3‏:‏33؛ 4‏:‏31؛ 6‏:‏27؛ 7‏:‏14، 27؛ مِيخَا 4‏:‏7؛ لك. 1‏:‏33\x*  
\v 45 س ؤُينِّي ثژْرِيذْ، إِتّْوَاشدْجقْ-د إِجّْ ن وژْرُو زڭْ وذْرَارْ بْڒَا إِفَاسّنْ، ونِّي إِڒبْزنْ ؤُزَّاڒْ ذ ثَارِّيسْثْ ذ نُّوقَارْثْ ذ نّْحَاسْ. أَربِّي أَمقّْرَانْ أَقَا إِسّْشنْ إِ ؤُجدْجِيذْ مِينْ غَا إِمْسَارنْ أَوَارْنِي أَيَا. ثَارْجِيثْ أَقَا ثْبدّْ ؤُ ڒْمعْنَا نّسْ ذ ثِيذتّْ.“   
\b  
\m
\v 46 خنِّي إِوْضَا ؤُجدْجِيذْ نابُوخَاذْنَاصَّارْ خْ ؤُغمْبُوبْ نّسْ \add غَارْ ثمُّورْثْ\add* ؤُشَا إِسْجذْ إِ ذَانِييَالْ، إِوصَّا أَذْ أَوْينْ إِشْثْ ن ثوْهِيبْثْ ذ ڒبْخُورْ إِتّْفُوحنْ أَمْ يِيشْثْ ن ثوْهِيبْثْ ن ؤُسيّبْ.  
\v 47 يَارَّا-د ؤُجدْجِيذْ خْ ذَانِييَالْ، إِنَّا: ”ذ ثِيذتّْ، أَقَا أَربِّي نْومْ ذ أَربِّي خْ \add مَارَّا\add* إِربِّيثنْ ؤُ نتَّا ذ سِيذِي خْ \add مَارَّا\add* إِجدْجِيذنْ ؤُڒَا ذ ونِّي إِسَّارْڭَابنْ مِينْ إِنُّوفَارنْ، مَاغَارْ ثِيوْضذْ أَذْ ثْكشْفذْ أَيَا إِ ثُوغَا إِنُّوفَّارنْ.“   
\m
\v 48 خَاسْ ؤُشَا إِوْشَا ؤُجدْجِيذْ إِ ذَانِييَالْ أَسمْغَارْ أَمقّْرَانْ ؤُ إِوْشَا أَسْ ثِيرْزِيفِينْ ثِيمقّْرَانِينْ. إِڭَّا إِ-ث خْ مَارَّا لْعَامَالَا ن بَابِيلْ ؤُ إِڭَّا إِ-ث ذ أَرَّايْسْ خْ إِمحْضَاينْ نِّي ثُوغَا خْ مَارَّا إِمِيغِيسنْ ن بَابِيلْ.  
\v 49 ؤُ ذَانِييَالْ إِقدّمْ إِشْثْ ن ثُوثْرَا إِ ؤُجدْجِيذْ ؤُ وَانِيثَا إِڭَّا سَاذْرَاخْ، مِيشَاخْ ذ عَابْذْ-نَاغُو ذ إِمْضبَّارنْ خْ لْعَامَالَا ن بَابِيلْ، \add مَاشَا\add* ذَانِييَالْ \add إِقِّيمْ\add* غَارْ ڒقْصَارْ ن ؤُجدْجِيذْ.   
\b  
\b  
\m  
\c 3
\s1 إِمدُّوكّْوَاڒْ ن ذَانِييَالْ ذِي ثفْقُونْثْ إِشمْضنْ  
\m
\v 1 أَجدْجِيذْ نابُوخَاذْنَاصَّارْ إِڭَّا إِجّْ ن ڒخْيَاڒْ ن وُورغْ س يِيجّْ ن ڒُوعْڒَا ن ستِّينْ إِغَادْجنْ ذ يِيجّْ ن ثِيرُو ن ستَّا ن إِغَادْجنْ. إِسّْبدّْ إِ-ث ذِي ڒْوَاطَا ن ذُورَا ذِي لْعَامَالَا ن بَابِيلْ.  
\v 2 \add خنِّي\add* إِسّكّْ ؤُجدْجِيذْ نابُوخَاذْنَاصَّارْ \add إِرقَّاسنْ\add* حِيمَا أَذْ سّْمُوننْ إِجدْجِيذنْ إِ إِدْجَانْ سَاذُو ؤُجدْجِيذْ ذ إِمْضبَّارنْ إِمقّْرَاننْ ذ لْوُولَاثْ، ڒْقُوضَاثْ إِمزْوُورَا \add ن ثْڭلْذِيثْ\add* ذ يِينِّي خْ ثْخُوبَايْ ذ إِمسْنَاونْ ن إِزرْفَانْ ذ إِمْوضْضْفنْ ن ثُوذْرِينْ ن شّْرعْ ذ مَارَّا إِنِّي غَارْ ثدْجَا صُّولْطَا ذِي لْعَامَالَاثْ مَاحنْذْ أَذْ د-أَسنْ غَارْ ؤُذشّنْ ن ڒخْيَاڒْ نِّي إِسّْبدّْ ؤُجدْجِيذْ.  
\v 3 خنِّي مُوننْ إِجدْجِيذنْ نِّي إِدْجَانْ سَاذُو إِ ؤُجدْجِيذْ ذ إِمْضبَّارنْ إِمقّْرَاننْ ذ لْوُولَاثْ ذ ڒْقُوضَاثْ إِمزْوُورَا \add ن ثْڭلْذِيثْ\add* ذ يِينِّي خْ ثْخُوبَايْ ذ إِمسْنَاونْ ن إِزرْفَانْ ذ إِمْوضْضْفنْ ن ثُوذْرِينْ ن شّْرعْ ذ مَارَّا إِنِّي غَارْ ثدْجَا صُّولْطَا ذِي لْعَامَالَاثْ إِ ؤُذشّنْ ن ڒخْيَاڒْ نِّي إِسّْبدّْ ؤُجدْجِيذْ نابُوخَاذْنَاصَّارْ، ؤُ نِيثْنِي بدّنْ زَّاثْ إِ ڒخْيَاڒْ نِّي إِسّْبدّْ نابُوخَاذْنَاصَّارْ.  
\v 4 إِڒَاغَا إِجّْ ن ؤُمْبَارّحْ س جّهْذْ ...  
\b  
\m ”\add أَ\add* ڒڭْنُوسْ ذ شُّوعُوبْ ذ إِڒْسَاونْ، إِ كنِّيوْ إِ غَا إِڒِينْ أَوَاڒنْ-أَ إِ غَا إِنِيغْ.   
\m
\v 5 ذِي ثْسَاعّثْ إِ ذِي إِ غَا ثسْڒمْ ڒْحسّْ ن ڒْبُوقْ ذ ثْزَامَّارْثْ ذ لْعُوذْ ذ لْڭَامْبْرِي ذ لهَارْپَا ذ ثمْجَا ذ مَارَّا مَارْكَاثْ ن دْجْغَا، إِتّْخصَّا أَذْ ثوْضَامْ أَذْ ثْسجْذمْ إِ ڒخْيَاڒْ ن وُورغْ إِ إِسّْبدّْ ؤُجدْجِيذْ نابُوخَاذْنَاصَّارْ.  
\v 6 ونِّي وَارْ إِوْضِينْ ؤُ وَارْ إِسْجذْ أَذْ إِتّْوَامّنْضَارْ ذِي ڒْوسْطْ ن ثفْقُونْثْ ن ثْمسِّي إِتّحْذُوذُوقنْ ذِي ثْسَاعّثْ نِّي.“   
\b  
\m
\v 7 س ؤُينِّي، ذِي ثْسَاعّثْ إِ ذِي سْڒنْ مَارَّا ڒڭْنُوسْ إِ ڒْحسّْ ن ڒْبُوقْ ذ ثْزَامَارْثْ ذ لْعُوذْ ذ لْڭَامْبْرِي ذ لهَارْپَا ذ مَارَّا مَارْكَاثْ ن دُّوزَانْ ن دْجْغَا، وْضَانْ مَارَّا ڒڭْنُوسْ ذ شُّوعُوبْ ذ إِڒْسَاونْ \add غَارْ ثمُّورْثْ\add* ؤُ سجْذنْ إِ ڒخْيَاڒْ ن وُورغْ نِّي إِسّْبدّْ ؤُجدْجِيذْ نابُوخَاذْنَاصَّارْ.   
\b  
\m
\v 8 ذِي ڒْوقْثْ نِّي ذ إِشْثنْ قَارّْبنْ-د \add شَا ن\add* إِكَالْذَانِييّنْ ذِي سِّيبّثْ-أَ، شثْشَانْ زڭْ وُوذَاينْ س بْطَايْطَايْ.  
\v 9 نِيثْنِي طّْفنْ ذڭْ وَاوَاڒْ، نَّانْ إِ ؤُجدْجِيذْ نابُوخَاذْنَاصَّارْ: ”\add أَ\add* أَجدْجِيذْ، دَّارْ إِ ڒبْذَا!  
\v 10 شكْ، \add أَ\add* أَجدْجِيذْ، ثُومُورذْ بلِّي مَارَّا إِوْذَانْ نِّي إِسْڒِينْ إِ ڒْحسّْ ن ڒْبُوقْ ذ ثْزَامَارْثْ ذ لْعُوذْ ذ لْڭَامْبْرِي ذ لهَارْپَا ذ ثمْجَا ذ مَارَّا مَارْكَاثْ ن دُّوزَانْ ن دْجْغَا، أَذْ وْضَانْ أَذْ سجْذنْ إِ ڒخْيَاڒْ ن وُورغْ.  
\v 11 ونِّي وَارْ إِوْضِينْ ؤُ إِسْجذْ، أَذْ إِمّنْضَارْ ذِي ڒْوسْطْ ن ثفْقُونْثْ ن ثْمسِّي إِتّحْذُوذُوقنْ.  
\v 12 أَقَا ذِينْ إِرْيَازنْ ؤُذَاينْ، إِنِّي ثڭِّيذْ خْ ؤُضبَّارْ ن لْعَامَالَا ن بَابِيلْ، أَقَا أَثنْ ذ شَاذْرَاخْ، مِيشَاخْ ذ عَابْذْ-نَاغُو. إِرْيَازنْ-أَ وَارْ وْشِينْ ثَايْنِيثْ إِ \add ڒُْومُورْ\add* نّشْ، \add أَ\add* أَجدْجِيذْ. أَربِّيثنْ نّشْ وَارْ ثنْ تّْوقَّارنْ ؤُ ڒخْيَاڒْ نّشْ وَارْ ذ أَسْ سجْذنْ.“   
\m
\v 13 خنِّي إِنَّا نابُوخَاذْنَاصَّارْ ذڭْ ؤُخيّقْ ذ ثفْقحْثْ \add نّسْ\add* أَقَا أَذْ نذْهنْ شَاذْرَاخْ، مِيشَاخْ ذ عَابْذْ-نَاغُو زَّاثسْ. خنِّي نذْهنْ إِرْيَازنْ نِّي زَّاثْ إِ ؤُجدْجِيذْ.  
\v 14 نابُوخَاذْنَاصَّارْ إِطّفْ ذڭْ وَاوَاڒْ، إِنَّا أَسنْ: ”شَاذْرَاخْ، مِيشَاخْ ذ عَابْذْ-نَاغُو مَا س نعْمَاذَا زعْمَا وَارْ ثتّْوقَّارمْ إِربِّيثنْ إِنُو ؤُ وَارْ ثْسجَّاذمْ إِ ڒخْيَاڒْ إِ سّْبدّغْ؟  
\v 15 خنِّي ڒخُّو، مَاڒَا كنِّيوْ، ذِي ثْسَاعّثْ إِ ذِي إِ غَا ثسْڒمْ إِ ڒْحسّْ ن ڒْبُوقْ ذ ثْزَامَارْثْ ذ لْعُوذْ ذ لْڭَامْبْرِي ذ لهَارْپَا ذ ثمْجَا ذ مَارَّا مَارْكَاثْ ن دُّوزَانْ ن دْجْغَا، ثْوجْذمْ مَاحنْذْ أَذْ ثوْضَامْ ؤُ أَذْ ثْسجْذمْ إِ ڒخْيَاڒْ إِ سّْبدّغْ نشّْ، أَقَا مْلِيحْ. مَاشَا مَاڒَا وَارْ ثْسجْذمْ، أَذْ ثتّْوَامّنْضَارمْ ذِي ثفْقُونْثْ ن ثْمسِّي إِتّحْذُوذُوقنْ ذِي ثْسَاعّثْ نِّي. ؤُ مَانْ أَربِّي إِ كنِّيوْ إِ غَا إِفكّنْ زڭْ إِفَاسّنْ إِنُو؟  
\v 16 أَرِّينْ-د شَاذْرَاخْ ذ مِيشَاخْ ذ عَابْذْ-نَاغُو، نَّانْ إِ ؤُجدْجِيذْ نابُوخَاذْنَاصَّارْ: ”وَارْ نحْذَاجْ أَذْ خَاكْ د-نَارّْ ذِي ثْمسْڒَاشْثْ-أَ.  
\v 17 مَاڒَا خنِّي أَربِّي نّغْ نِّي نْسخَّارْ، غَارسْ ثِيزمَّارْ حِيمَا أَذْ أَنغْ إِفكّْ زِي ثفْقُونْثْ ن ثْمسِّي إِتّحْذُوذُوقنْ، \add خنِّي\add* أَذْ أَنغْ إِفكّْ زڭْ ؤُفُوسْ نّشْ، \add أَ\add* أَجدْجِيذْ!  
\v 18 مَاڒَا لَّا، أَذْ ثسّْنذْ، \add أَ\add* أَجدْجِيذْ، أَقَا نشِّينْ وَارْ نتّْوقَّارْ إِربِّيثنْ نّشْ ذ ڒخْيَاڒْ إِ ثسّْبدّذْ شكْ، وَارْ ذ أَسْ نْسجّذْ شَا.“   
\m
\v 19 خنِّي إِسْعَارْ ؤُجدْجِيضْ ؤُ ثْبدّڒْ صِّيفثْ ن وُوذمْ نّسْ زَّاثْ إِ شَاذْرَاخْ، مِيشَاخْ ذ عَابْذْ-نَاغُو. نتَّا إِطّفْ ذڭْ وَاوَاڒْ، إِنَّا أَذْ أَرْنِينْ ذِي ثفْقُونْثْ سبْعَا ن ثْسقَّارْ أَمْ مَامّشْ نُومنْ ت سَّارقّنْ،  
\v 20 ؤُ نتَّا يُومُورْ إِرْيَازنْ إِنِّي ذ إِرْيَازنْ إِجهْذنْ قَاعْ زِي ڒْعسْكَارْ نّسْ، أَذْ شَارْفنْ شَاذْرَاخْ ذ مِيشَاخْ ذ عَابْذْ-نَاغُو حِيمَا أَذْ \add ثنْ\add* نْضَارنْ \add أَمُّو\add* ذِي ثفْقُونْثْ ن ثْمسِّي إِتّحْذُوذُوقنْ.  
\v 21 خنِّي تّْوَاشَارْفنْ إِرْيَازنْ نِّي أَكْ-ذ إِسڒْهَامنْ نْسنْ ذ سّْرَاوڒْ نْسنْ ذ ثْشُوشَّايْ نْسنْ ذ وَارُّوضْ نْسنْ نّغْنِي ؤُشَا نْضَارنْ ثنْ ذِي ڒْوسْطْ ن ثفْقُونْثْ ن ثْمسِّي إِتّحْذُوذُوقنْ.  
\v 22 مِينْزِي ڒُومُورْ ن ؤُجدْجِيذْ ثُوغَا إِقْسحْ أَطَّاسْ ؤُ ثَافْقُونْثْ ثحْمَا أَڒْ طَّارْفْ، نْغِينْ إِحُوذَاقْ ن ثْمسِّي إِرْيَازنْ نِّي سّْڭعّْذنْ شَاذْرَاخْ ذ مِيشَاخْ ذ عَابْذْ-نَاغُو،  
\v 23 ؤُشَا ثْڒَاثَا ن يرْيَازنْ نِّي، شَاذْرَاخْ، مِيشَاخْ ذ عَابْذْ-نَاغُو، وْضَانْ تّْوَاشَارْفنْ ذِي ڒْوسْطْ ن ثفْقُونْثْ ن ثْمسِّي إِتّحْذُوذُوقنْ.   
\m
\v 24 خنِّي إِنّخْڒعْ ؤُجدْجِيذْ نابُوخَاذْنَاصَّارْ، إِكَّارْ ذغْيَا، إِطّفْ ذڭْ وَاوَاڒْ، إِنَّا إِ إِمْشَاوَارنْ نّسْ: ”مَا وَارْ ننْضَارْ ثْڒَاثَا ن يرْيَازنْ إِتّْوَاشَارْفنْ ذِي ڒْوسْطْ ن ثْمسِّي؟“ نِيثْنِي أَرِّينْ-د، نَّانْ إِ ؤُجدْجِيذْ: ”نِيشَانْ، \add أَ\add* أَجدْجِيذْ“  
\v 25 نتَّا يَارَّا-د، إِنَّا: ”خْزَارْ، تّْوَاڒِيغْ أَربْعَا ن يرْيَازنْ ڭُّورنْ ذِي ڒْوسْثْ ن ثْمسِّي ؤُ ثِيمسِّي وَارْ ذ أَسنْ ثڭِّي شَا ؤُ ونِّي ذ وِيسّْ أَربْعَا يَارْوسْ ذڭْ إِجّْ ن مِّيسْ ن إِربِّيثنْ!“   
\m
\v 26 خنِّي إِقَارّبْ-د نابُوخَاذْنَاصَّارْ غَارْ ثوَّارْثْ ن ثفْقُونْثْ ن ثْمسِّي إِتّحْذُوذُوقنْ، إِطّفْ ذڭْ وَاوَاڒْ، إِنَّا: ”كنِّيوْ، شَاذْرَاخْ، مِيشَاخْ، عَابْذْ-نَاغُو، كنِّيوْ إِمْسخَّارنْ ن أَربِّي أَمْعُودْجِي خْ كُوڒْشِي، فّْغمْ-د ؤُ أَسمْ-د ذَا!“ خنِّي فّْغنْ-د، شَاذْرَاخْ ذ مِيشَاخْ ذ عَابْذْ-نَاغُو زِي ڒْوسْطْ ن ثْمسِّي إِتّحْذُوذُوقنْ.  
\v 27 خنِّي سّْمُوننْ إِجدْجِيذنْ نِّي إِدْجَانْ سَاذُو إِ ؤُجدْجِيذْ ذ إِمْضبَّارنْ ذ إِمْشَاوَارنْ ن ؤُجدْجِيذْ ؤُشَا ژْرِينْ أَقَا إِرْيَازنْ نِّي وَارْ ذ أَسنْ إِمْسَارْ شَا س ثْمسِّي ؤُ أَشُوَّافْ ن ؤُزدْجِيفْ نْسنْ وَارْ إِشْمِيضْ شَا ؤُ إِسڒْهَامنْ نْسنْ وَارْ تّْوَاڒقْفنْ ؤُ وَارْ ذَايْسنْ ؤُڒَا ذ إِشْثْ \add جُّورّثْ ن\add* أَرِّيحثْ ن ثْمسِّي.   
\m
\v 28 خنِّي إِطّفْ نَابُوخَاذْنَاصَّارْ ذڭْ وَاوَاڒْ، إِنَّا: ”أَذْ إِتّْوَابَاركْ أَربِّي ن شَاذْرَاخْ، مِيشَاخْ ذ عَابْذْ-نَاغُو، ونِّي د-إِسّكّنْ لْمَالَاكْ نّسْ ؤُ إِفكّْ إِنِّي ثُوغَا خَاسْ إِتّشْڒنْ. نِيثْنِي بضْڒنْ ڒُومُورْ ن ؤُجدْجِيذْ ؤُ سلّْمنْ أَرِّيمَاثْ نْسنْ، مَاغَارْ وَارْ خْسنْ أَذْ وقَّارنْ نِيغْ أَذْ سجْذنْ ؤُڒَا إِ يِيجّْ ن أَربِّي مْغِيرْ إِ أَربِّي نْسنْ.  
\v 29 \add خْ ؤُينِّي\add* إِفّغْ-د زَّايِي ڒُومُورْ مَاحنْذْ كُوڒْ ڒْڭنْسْ ذ شّعْبْ ذ يِيڒسْ نِّي إِ غَا إِشقّْفنْ ذڭْ أَربِّي ن شَاذْرَاخْ، مِيشَاخْ ذ عَابْذْ-نَاغُو، أَذْ إِتّْوَاقسّْ ذ إِوثْوِيثنْ ؤُ ثَادَّارْثْ نّسْ أَذْ ثذْوڒْ ذ إِجّْ ن ؤُزُوبَايْ، مَاغَارْ وَارْ ذِينْ ؤُڒَا ذ إِجّْ ن أَربِّي ونِّي إِزمَّارنْ أَذْ إِفكّْ أَمُّو.“ \x ◘ \xo 3:‏29 \xt دَان. 2‏:‏5\x*   
\m
\v 30 خنِّي يَارْنِي أَسنْ ؤُجدْجِيذْ ذِي شَّانْ إِ شَاذْرَاخْ، مِيشَاخْ ذ عَابْذْ-نَاغُو ذِي لْعَامَالَا ن بَابِيلْ.   
\b  
\m
\v 31 ”\bd أَجدْجِيذْ نَابُوخَاذْنَاصّرْ، إِ مَارَّا ڒڭْنُوسْ ذ شُّوعُوبْ ذ إِڒْسَاونْ نِّي إِزدّْغنْ ذِي مَارَّا ثَامُّورْثْ\bd*: أَذْ يِيڒِي ڒهْنَا نْومْ ذ أَمقّْرَانْ!  
\v 32 إِعْجبْ أَيِي ڒْحَاڒْ حِيمَا أَذْ أَومْ سّشْنغْ ڒعْڒَامَاثْ ذ لْمُوعْجِيزَاثْ نِّي ذ أَيِي إِڭَّا أَربِّي أَمْعُودْجِي خْ كُوڒْشِي.  
\v 33 مَامّشْ مْغَارنْثْ ڒعْڒَامَاثْ نّسْ ذ مَامّشْ جهْذنْثْ لْمُوعْجِيزَاثْ نّسْ! ثَاڭلْذِيثْ نّسْ ذ إِشْثْ ن ثْڭلْذِيثْ إِ ڒبْذَا ذ لْمُولْكْ نّسْ زِي جِّيڒْ أَڒْ جِّيڒْ.“ \x ◘ \xo 3:‏33 \xt إِزهد. 93‏:‏1، 2؛ دَان. 6‏:‏27\x*   
\b  
\b  
\m  
\c 4
\s1 ثَارْجِيثْ ن نَاپُوخَاذْنَاصَّارْ  
\m
\v 1 ”نشّْ، نَابُوخَاذْنَاصَّارْ، ثُوغَا أَيِي ذِي ڒَامَانْ ذِي ثَادَّارْثْ إِنُو ؤُ س تِّيسِيرْ ذِي ڒقْصَارْ إِنُو.  
\v 2 \add خنِّي\add* ژْرِيغْ إِشْثْ ن ثرْجِيثْ، ثسِّيڭّْوذْ أَيِي. سّْحيَّارنْ أَيِي إِخَارِّيصنْ نِّي غَارِي ذِي ثَاسُّوثْ، ؤُڒَا ذ إِوحَّانْ ذڭْ ؤُزدْجِيفْ إِنُو.  
\v 3 س ؤُينِّي د-إِفّغْ زَّايِي ڒُومُورْ حِيمَا أَذْ أَوْينْ زَّاثِي مَارَّا إِمِيغِيسنْ ن بَابِيلْ، مَاحنْذْ نِيثْنِي أَذْ أَيِي سَّارْڭْبنْ أَفسَّارْ ن ثرْجِيثْ.   
\m
\v 4 ڒخْذنِّي ؤُسِينْ-د ثَارْوَا ن ثْسحَّارْثْ ذ إِمسْنَاونْ ن إِثْرَانْ ذ إِكَالْذَانِييّنْ ذ إِڭزَّاننْ ؤُ نشّْ عَاوْذغْ أَسنْ ثَارْجِيثْ، مَاشَا نِيثْنِي وَارْ زمَّارنْ أَذْ أَيِي سَّارْڭْبنْ خْ ؤُفسَّارْ نّسْ.  
\v 5 غَارْ ؤُنڭَّارْ يُوسَا-د غَارِي ذَانِييَالْ ونِّي ؤُمِي قَّارنْ بَالْطَاشَاصَّارْ غَارْ يِيسمْ ن أَربِّي إِنُو، ذِي مِينْ ذِي إِزدّغْ بُوحْبڒْ ن إِربِّيثنْ إِمْقدَّاسنْ ؤُ إِ نتَّا ؤُمِي حَاجِيغْ ثَارْجِيثْ ؤُشَا نِّيغْ:   
\m
\v 6 ’بَالْطَاشَاصَّارْ، \add شكْ، أَ\add* أَرَّايْسْ ن ثَارْوَا ن ثْسحَّارْثْ، أَقَا سّْنغْ بلِّي بُوحْبڒْ ن إِربِّيثنْ إِمْقدَّاسنْ إِ ذَايكْ إِزدّْغنْ، ؤُ وَارْ خَاكْ إِوْعَارْ ؤُڒَا ذ إِجّْ ن سِّيرْ. إِنِي أَيِي إِوحَّانْ نِّي ژْرِيغْ ذ ؤُفسَّارْ نّسْ.   
\m
\v 7 إِوحَّانْ نِّي غَارِي ذڭْ ؤُزدْجِيفْ إِنُو ڒَامِي ذ أَيِي ثُوغَا ذِي ثَاسُّوثْ، أَقَا ذ ثِينَا: نشّْ ژْرِيغْ، ؤُ خْزَارْ، أَقَا ذِينْ إِشْثْ ن ثْشجَّارْثْ ذِي ڒْوسْثْ ن ثمُّورْثْ، ثُوغَا ثُوعْڒَا أَطَّاسْ. \f ◼ \fr 4:‏7 \ft \+bd ’ثَاشجَّارْثْ‘\+bd* - نِيغْ ’أَدَّاڭْ‘ (’إِدَّاڭنْ‘).\f*  
\v 8 ثَاشجَّارْثْ ثمْغَارْ ثذْوڒْ ثجْهذْ ؤُ ثَاقِيشَّاثْ نّسْ ثِيوضْ غَارْ ؤُجنَّا ؤُ ثتّْوَاژَارّْ \add ثْشجَّارْثْ\add* ذڭْ ؤُنڭَّارُو ن ثمُّورْثْ مَارَّا.  
\v 9 ثِيفْرَايْ نّسْ صبْحنْثْ ؤُ ڒْغِيدْجثْ نّسْ ثُوغَا-ت ذ أَطَّاسْ ؤُ ثُوغَا ذَايسْ مَاشَّا إِ مَارَّا. إِمُودَّارنْ ن ڒخْڒَا ؤُفِينْ ثِيڒِي سَاذُو نّسْ ؤُ إِجْضَاضْ ن ؤُجنَّا زذْغنْ جَارْ ڒفْرُوعْ نّسْ ؤُ إِتّْوَاسّشّْ زَّايسْ مَارَّا إِنِّي غَارْسنْ \add إِشْثْ ن أَرِّيمثْ ن\add* ويْسُومْ.“ “   
\m
\v 10 ”نشّْ ژْرِيغْ إِوحَّانْ ذڭْ ؤُزدْجِيفْ إِنُو ڒَامِي ذ أَيِي ثُوغَا ذِي ثَاسُّوثْ، ؤُ خْزَارْ، إِجّْ ن ؤُعسَّاسْ، إِجّْ ن ؤُمْقدَّاسْ إِهْوَا-د زڭْ ؤُجنَّا.  
\v 11 إِڒَاغَا-د س جّهْذْ، إِنَّا أَمُّو: ’زْذمْ ثَاشجَّارْثْ ؤُشَا قسّمْ ڒفْرُوعْ نّسْ. كّْسمْ زَّايسْ ثِيفْرَايْ نّسْ ؤُ زدْجْعمْ ڒْغِيدْجثْ نّسْ \add مَاحنْذْ\add* إِمُودَّارنْ أَذْ أَروْڒنْ زِي سَاذُو نّسْ ؤُڒَا ذ إِجْضَاضْ زِي جَارْ ڒفْرُوعْ نّسْ،  
\v 12 مَاشَا أجّْ جّْذعْ \add ن ثْشجَّارْثْ\add* س إِژوْرَانْ نّسْ أَذْ إِقِّيمْ ذِي ثمُّورْثْ ؤُ \add أجّْ إِ-ث أَذْ إِقِّيمْ\add* س إِشْثْ ن ثْسَارِّيفْثْ ن وُوزَّاڒْ ذ نّْحَاسْ جَارْ أَرْبِيعْ أَزِيزَا ذِي ڒخْڒَا، ؤُ أجّْ إِ-ث أَذْ إِسُّوفّْ س نّْذَا ن ؤُجنَّا ؤُ أَذْ ثِيڒِي ثسْغَارْثْ نّسْ أَكْ-ذ ڒوْحُوشْ جَارْ شْبَارْقْ ن ثمُّورْثْ.  
\v 13 أجّْ ؤُڒْ نّسْ أَذْ إِبدّڒْ مَاحنْذْ وَارْ إِتِّيڒِي عَاذْ ذ ؤُڒْ نْ بْنَاذمْ ؤُ أوْشْ أَسْ ؤُڒْ ن إِجّْ ن لْحَايَاوَانْ. \add أَمُّو\add* خَاسْ إِ غَا عْذُونْثْ سبْعَا ن ڒْمِيجَاڒَاثْ ن ڒْوقْثْ. \f ◼ \fr 4:‏13 \ft \+bd ’ؤُڒْ ن إِمُودَّارنْ‘\+bd* - إِخْسْ أَذْ يِينِي ’ؤُڒْ ن لْحَايَاوَانَاثْ‘.\f*  
\v 14 ثَامسْڒَاشْثْ-أَ \add ثْبدّْ\add* خْ ڒْخَاضَارْ ن إِعسَّاسنْ ؤُ ثُوثْرَا-يَا أَقَا ثُوسَا-د زڭْ إِمْقدَّاسنْ، حِيمَا إِنِّي إِدَّارنْ أَذْ نعْمنْ أَقَا أَمْعُودْجِي خْ كُوڒْشِي غَارسْ ثِيزمَّارْ خْ ثْڭلْذَا ن يوْذَانْ ؤُ أَذْ ت إِوْشْ إِ وِي إِخْسْ نتَّا، أَقَا إِڭَّا خَاسْ ؤُڒَا ذ ونِّي ذ أَمُوقْڒِيڒْ قَاعْ جَارْ إِوْذَانْ.‘  
\v 15 ثَارْجِيثْ-أَ ژْرِيغْ ت نشّْ، أَجدْجِيذْ نَابُوخَاذْنَاصَّارْ. شكْ، بَالْطَاشَاصَّارْ، إِنِي أَيِي أَفسَّارْ نّسْ، مَاغَارْ مَارَّا إِمِيغِيسنْ ذِي ثْڭلْذِيثْ إِنُو وَارْ زمَّارنْ أَذْ أَيِي وْشنْ أَفسَّارْ نّسْ، مَاشَا شكْ وَاهْ \add ثْزمَّارذْ\add*، مِينْزِي بُوحْبڒْ ن إِربِّيثنْ إِمْقدَّاسنْ إِزدّغْ ذَايكْ.“   
\b  
\m
\v 16 خنِّي ثُوغَا ذَانِييَالْ، ونِّي ؤُمِي قَّارنْ بَالْطَاشَاصَّارْ، يَارْجفْ إِشْثْ ن ڒْوقْثْ ؤُشَا إِخَارِيصّنْ نّسْ سّْحيَّارنْ ث. إِطّفْ ؤُجدْجِيذْ ذڭْ وَاوَاڒْ ؤُشَا إِنَّا: ”بَالْطَاشَاصَّارْ، أجّْ ثَارْجِيثْ ذ ؤُفسَّارْ نّسْ وَارْ شكْ سّْحيَّارنْ!“ يَارَّا-د بَالْطَاشَاصَّارْ، إِنَّا: ”سِيذِي إِنُو، أجّْ ثَارْجِيثْ أَذْ ثِيڒِي خْ يِينِّي شكْ إِشَارّْهنْ ؤُ أَفسَّارْ نّسْ خْ يِينِّي إِدْجَانْ ضِيدّْ نّشْ!  
\v 17 ثَاشجَّارْثْ نِّي ثژْرِيذْ، ثنِّي إِذوْڒنْ ثمْغَارْ ؤُ ثجْهذْ، ثنِّي ؤُمِي ثِيوضْ ثَاقِيشَّاثْ نّسْ أَڒْ أَجنَّا ؤُ ثنِّي د-إِتّْبَاننْ زِي مَارَّا دُّونشْثْ،  
\v 18 - س ثفْرَايْ نّسْ إِصبْحنْ ذ ڒْغِيدْجثْ نّسْ إِ ثُوغَا ذڭْ وَاطَّاسْ، إِ ذَايسْ إِتّْوَافنْ مَاشَّا إِ مَارَّا، ؤُ سْوَادَّايْ نّسْ زدّْغنْ مَارَّا إِمُودَّارنْ نْ ڒخْڒَا، ؤُڒَا ذ إِجْضَاضْ ن ؤُجنَّا زدّْغنْ جَارْ ڒفْرُوعْ نّسْ -  
\v 19 أَقَا ذ شكْ، \add أَ\add* أَجدْجِيذْ، شكْ ونِّي إِذوْڒنْ ذ أَمقّْرَانْ ؤُ ثْجهْذذْ، مَاغَارْ ڒمْغَارثْ نّشْ ثمَّارْنِي أَڒَامِي ثِيوضْ أَڒْ أَجنَّا ؤُ لْمُولْكْ نّشْ أَڒْ طَّارْفْ ن دُّونشْثْ.  
\v 20 ؤُ ڒَامِي إِژْرَا ؤُجدْجِيذْ، أَقَا إِجّْ ن ؤُعسَّاسْ، إِجّْ ن ؤُمْقدَّاسْ، إِهْوَا-د زڭْ ؤُجنَّا، إِ إِنَّانْ: ’زْذمْ ثَاشجَّارْثْ ؤُغضْڒمْ إِ-ت، مَاشَا أجّْ جّْذعْ س إِژوْرَانْ نّسْ ذڭْ ؤُشَاڒْ أَكْ-ذ إِشْثْ ن ثْسَارِّيفْثْ ن وُوزَّاڒْ ذ نّْحَاسْ جَارْ أَرْبِيعْ ن ڒخْڒَا ؤُ أجّْ إِ-ث أَذْ إِسُّوفّْ س نّْذَا ن ؤُجنَّا ؤُ أَذْ ثِيڒِي ثسْغَارْثْ نّسْ جَارْ ڒوْحُوشْ نْ ڒخْڒَا أَڒَامِي خَاسْ عْذُونْثْ سبْعَا ن ڒْمِيجَاڒَاثْ ن ڒْوقْثْ!‘،  
\v 21 أَقَا أَمُّو إِ يدْجَا ڒْمعْنَا ن \add مَارَّا\add* مَانْ أَيَا، \add أَ\add* أَجدْجِيذْ، ؤُ مَانْ أَيَا ذ لْقَارَارْ \add إِ د-إِفّْغنْ\add* زڭْ ؤُمْعُودْجِي خْ كُوڒْشِي، \add إِجّْ ن لْقَارَارْ\add* نِّي د غَا يَاسْ خْ سِيذِي إِنُو، أَجدْجِيذْ.   
\m
\v 22 أَذْ خَاكْ أَژّْڒنْ زِي ڒْوسْثْ ن إِوْذَانْ ؤُ ثَازذِّيغْثْ نّشْ أَذْ ثِيڒِي أَكْ-ذ ڒْمَاڒْ نْ ڒخْڒَا. أَمْ ڒبْهَايمْ أَذْ أَكْ سّشّنْ أَرْبِيعْ ؤُ نّْذَا ن ؤُجنَّا أَذْ شكْ إِسُّوفّْ. \add أَمُّو\add* إِ خَاكْ غَا عْذُونْثْ سبْعَا ن ڒْمِيجَاڒَاثْ ن ڒْوقْثْ أَڒْ غَا ثْنعْمذْ أَقَا أَمْعُودْجِي خْ كُوڒْشِي إِحكّمْ خْ ثْڭلْذَا ن إِوْذَانْ ؤُ إِتِّيشْ إِ-ت إِ وِي إِخْسْ نتَّا. \x ◘ \xo 4:‏22 \xt دَان. 5‏:‏20، 21\x*  
\v 23 أَقَا نَّانْ أَقَا إِتّْخصَّا أَذْ إِتّْوَاجّْ جّْذعْ \add ن ثْشجَّارْثْ\add* أَكْ-ذ إِژوْرَانْ نّسْ، \add إِخْسْ أَذْ يِينِي\add*، أَقَا ثَاڭلْذَا نّشْ أَذْ ثقِّيمْ خْمِي غَا ثْنعْمذْ أَقَا صُّولْثَا غَارْ ؤُجنَّا إِ ثدْجَا.  
\v 24 س ؤُينِّي، \add أَ\add* أَجدْجِيذْ، إِڒِي أَذْ يِيڒِي شّْوَارْ إِنُو إِ ڒْخَاضَارْ نّشْ. أَرْژْ دّْنُوبْ نّشْ س ثْسڭْذَا ؤُ ڒْمُوعْصِييّثْ نّشْ ؤُمِي ثڭِّيذْ سْ  ؤُحِينِّي إِ ڒْمُوسَاكِينْ. أَذْ ثَاغْ أَذْ ثتّْوَازُّوڭَّارْ تِّيسِيرْ نّشْ.“   
\m
\v 25 قَاعْ مَانْ أَيَا إِوْضَا-د خنِّي خْ ؤُجدْجِيذْ نَابُوخَاذْنَاصَّارْ.   
\b  
\m
\v 26 أَوَارْنِي ڒَامِي عْذُونْ ثنْعَاشْ ن إِيُورنْ، ڒَامِي ثُوغَا إِڭُّورْ خْ \add ثْزقَّا\add* ن ڒقْصَارْ ن بَابِيلْ،  
\v 27 إِسِّيوڒْ ؤُجدْجِيذْ، إِنَّا: ”مَا مَانْ أَيَا وَارْ إِدْجِي ذ بَابِيلْ أَمقّْرَانْ نِّي بْنِيغْ س جّهْذْ ن ثْزمَّارْ إِنُو ذ ثَادَّارْثْ إِ ثْڭلْذَا ؤُ إِ ؤُعُودْجِي ن لْعَاضَامَا إِنُو!“   
\m
\v 28 عَاذْ ثُوغَا وَاوَاڒْ-أَ ذڭْ ؤُقمُّومْ ن ؤُجدْجِيذْ ؤُشَا ثفّغْ-د إِشْثْ ن ثْمِيجَّا زڭْ ؤُجنَّا ثنَّا: ”\add أَمُّو\add* إِ ذ أَشْ قَّارنْ، \add أَ\add* أَجدْجِيذْ نَابُوخَاذْنَاصَّارْ: ثَاڭلْذَا ثتّْوَاكّسْ زَّايكْ!  
\v 29 أَذْ خَاكْ أَژّْڒنْ زِي ڒْوسْطْ ن إِوْذَانْ ؤُ ثَازذِّيغْثْ نّشْ أَذْ ثِيڒِي أَكْ-ذ ڒْمَاڒْ ن ڒخْڒَا. أَمْ ڒبْهَايمْ أَذْ شكْ سّشّنْ أَرْبِيعْ ؤُ أَذْ خَاكْ عْذُونْثْ سبْعَا ن ڒْمِيجَاڒَاثْ ن ڒْوقْثْ أَڒْ غَا ثْنعْمذْ أَقَا صُّولْطَا خْ ثْڭلْذَا ن إِوْذَانْ غَارْ ؤُمْعُودْجِي خْ كُوڒْشِي ؤُ نتَّا إِوْشَا إِ-ت إِ وِي إِخْسْ نتَّا.“   
\m
\v 30 ذِي ثْسَاعّثْ نِّي إِقْفڒْ وَاوَاڒْ-أَ خْ نَابُوخَاذْنَاصَّارْ، مِينْزِي ؤُژّْڒنْ خَاسْ زِي ڒْوسْثْ ن إِوْذَانْ. ثُوغَا إِتّتّْ أَرْبِيعْ أَمْ ڒبْهَايمْ ؤُ أَرِّيمثْ نّسْ إِسُّوفّْ إِ-ت نّْذَا ن ؤُجنَّا، أَڒَامِي إِذْوڒْ ؤُشُوَّافْ نّسْ ذ أَزِيرَارْ أَمْ وَافْرِيونْ ن إِڭِيذَارنْ ؤُ أَشَّارنْ نّسْ أَمْ يِينِّي ن إِجْضَاضْ.   
\m
\v 31 أَوَارْنِي عْذُونْ وُوسَّانْ-أَ، سّْڭعّْذغْ نّشْ، نَابُوخَاذْنَاصَّارْ ثِيطَّاوِينْ إِنُو غَارْ ؤُجنَّا ؤُشَا إِذْوڒْ-د غَارِي ڒعْقڒْ إِنُو. نشّْ صبْحغْ أَمْعُودْجِي خْ كُوڒْشِي ؤُ سّمْغَارغْ ؤُ سّْعُودْجغْ ونِّي إِدَّارنْ إِ ڒبْذَا، مَاغَارْ صُّولْطَا نّسْ ذ إِشْثْ ن صُّولْطَا ن ڒبْذَا ؤُ ثَاڭلْذِيثْ نّسْ \add ثقِّيمْ\add* زِي جِّيڒْ أَڒْ جِّيڒْ.  
\v 32 مَارَّا إِمزْذَاغْ ن ثمُّورْثْ تّْوَاحسْبنْ ذ وَالُو ؤُ نتَّا إِڭَّا أَمْ مَامّشْ إِخْسْ س ڒْعسْكَارْ ن ؤُجنَّا ؤُ س إِمزْذَاغْ ن دُّونشْثْ. وَارْ ذِينْ إِدْجِي ؤُڒَا ذ إِجّْ نِّي إِزمَّارنْ أَذْ إِمْنعْ أَفُوسْ نّسْ نِيغْ أَذْ أَسْ يِينِي: مِينْ ثتّڭّذْ؟!   
\m
\v 33 ذِي ثْسَاعّثْ نِّي إِذْوڒْ أَيِي-د ڒعْقڒْ. ؤُڒَا ذ أَعُودْجِي ن ثْڭلْذَا إِنُو ذ لْعَاضَامَا إِنُو ذ ؤُشوَّارْ إِنُو ذوْڒنْ-د خَافِي. إِمْشَاوَارنْ إِنُو ذ أَيْثْ ن جّهْذْ إِنُو أَرْزُونْ عَاوذْ خَافِي ؤُ تّْوَاسّْمثْنغْ ذِي ثْڭلْذَا إِنُو ؤُ عَاذْ إِمَّارْنِي أَيِي ذڭْ ؤُعُودْجِي إِنُو.   
\m
\v 34 ڒخُّو نشّْ، نَابُوخَاذْنَاصَّارْ، سّْعُودْجغْ ؤُ سّمْغَارغْ أَجدْجِيذْ ن ؤُجنَّا، مِينْزِي مَارَّا ڒفْعَايڒْ نّسْ ذ ثِيذتّْ ؤُ إِمسْرَاقْ نّسْ ذ ثَاسڭْذَا. نتَّا غَارسْ صُّولْطَا مَاحنْذْ أَذْ إِسّْوَاضعْ إِنِّي إِدَّارنْ ذِي نّْفَاخثْ.“   
\b  
\b  
\m  
\c 5
\s1 أَجدْجِيذْ بَالْشَاصَّارْ ذ ثِيرَّا خْ ڒْحِيضْ  
\m
\v 1 أَجدْجِيذْ بَالْشَاصَّارْ إِڭَّا إِجّْ ن ؤُمنْسِي ذ أَمقّْرَانْ إِ وَاڒفْ ن أَيْثْ ن جّهْذْ نّسْ ؤُ نتَّا إِسْوَا بِينُو زَّاثْ إِ وَاڒفْ نِّي.  
\v 2 \add ڒَْامِي\add* إِقَّاسْ بَالْشَاصَّارْ بِينُو، يُومَارْ أَذْ د-أَوْينْ ڒقْشُوعْ ن وُورغْ ذ نُّوقَارْثْ نِّي إِكْسِي بَابَاسْ نَابُوخَاذْنَاصَّارْ زِي زَّاوشْثْ ثَامقّْرَانْثْ ذِي ؤُرْشَالِيمْ حِيمَا أَذْ زَّايْسنْ إِسُو ؤُجدْجِيذْ ذ أَيْثْ ن جّهْذْ نّسْ ذ ثمْغَارِينْ نّسْ ذ ثِييَّا نّسْ.  
\v 3 خنِّي إِوْينْ-د ڒقْشُوعْ ن وُورغْ نِّي د-كّْسنْ زِي زَّاوشْثْ ثَامقّْرَانْثْ ذِي ؤُرْشَالِيمْ، \add زِي\add* ثَادَّارْثْ ن أَربِّي إِ ثُوغَا \add قْبڒْ\add* ذِي ؤُرْشَالِيمْ، ؤُشَا إِسْوَا زَّايْسنْ ؤُجدْجِيذْ ذ أَيْثْ ن جّهْذْ نّسْ ذ ثمْغَارِينْ نّسْ ذ ثِييَّا نّسْ.  
\v 4 نِيثْنِي سْوِينْ بِينُو ؤُ صبّْحنْ إِ إِربِّيثنْ ن وُورغْ ذ نُّوقَارْثْ ذ نّْحَاسْ ذ وُوزَّاڒْ ذ وژْرُو.  
\v 5 ذِي ڒْوقْثْ ذ إِشْثْ ضْهَارنْ-د إِضوْضَانْ ن إِجّْ ن ؤُفُوسْ ن بْنَاذمْ نِّي ثُوغَا إِتَّارِينْ أَرنْذَاذْ إِ ڒْقنْذِيڒْ خْ جَّارْ ن ڒْحِيضْ ن ڒقْصَارْ إِڭلّْذنْ، ؤُشَا إِژْرَا ؤُجدْجِيذْ ثَاسْغَارْثْ ن ؤُفُوسْ نِّي ثُوغَا إِتَّارِينْ.  
\v 6 خنِّي ثْبدّڒْ ثِينْثَا \add ن وُوذمْ\add* ن ؤُجدْجِيذْ ؤُشَا إِخَارِّيصنْ نّسْ سِّيڭّْوْذنْ ث ؤُ ثِيسْغُونِينْ ن ثْمصَّاضِينْ نّسْ ذوْڒنْثْ فسْينْثْ ؤُ إِفَادّنْ نّسْ دُّوقْزنْ إِجّْ \add أَرنْذَاذْ\add* إِ ونّغْنِي.  
\v 7 أَجدْجِيذْ إِڒَاغَا س جّهْذْ مَاحنْذْ أَذْ أَوْينْ زَّاثسْ إِمسْنَاونْ ن إِثْرَانْ ذ إِكَالْذَانِييّنْ ذ إِڭزَّاننْ ؤُ أَجدْجِيذْ إِطّفْ ذڭْ وَاوَاڒْ، إِنَّا إِ إِمِيغِيسنْ ن بَابِيلْ: ”كُوڒْ أَرْيَازْ إِ إِزمَّارنْ أَذْ إِغَارْ ثِيرَا-يَا ؤُ أَذْ أَيِي إِوْشْ ڒْمعْنَا نّسْ، أَذْ أَسْ سّْيَارْضنْ \add إِجّْ ن وَارُّوضْ\add* ذ أَذهْمَانِي، أَكْ-ذ إِشْثْ ن ثْسدّشْثْ ن وُورغْ خْ يِيرِي نّسْ، ؤُ نتَّا أَذْ يِيڒِي ذ ڒْحَاكمْ وِيسّْ ثْڒَاثَا ذِي ثْڭلْذِيثْ.“   
\m
\v 8 خنِّي ؤُذْفنْ مَارَّا إِمِيغِيسنْ ن ؤُجدْجِيذْ، مَاشَا نِيثْنِي وَارْ زمَّارنْ أَذْ غَارنْ ثِيرَا نِّي ؤُ ڒْمعْنَا نّسْ وَارْ زمَّارنْ أَذْ ث سَّارْڭْبنْ.  
\v 9 ڒخْذنِّي إِنّخْڒعْ ؤُجدْجِيذْ بَالْشَاصَّارْ ؤُ ثِيسِّيقْثْ ن وُوذمْ نّسْ ثْبدّڒْ ؤُ أَيْثْ ن جّهْذْ نّسْ قِّيمنْ حيَّارنْ.   
\m
\v 10 ذِي سِّيبّثْ ن ڒْهَارْذْ ن ؤُجدْجِيذْ ذ أَيْثْ ن جّهْذْ نّسْ، ثُوذفْ ثْجدْجِيذْثْ غَارْ ثَادَّارْثْ ن ؤُمنْسِي. ثسِّيوڒْ ثْجدْجِيذْثْ، ثنَّا: ”\add أَ\add* أَجدْجِيذْ، دَّارْ إِ ڒبْذَا! أجّْ إِخَارِّيصنْ نّشْ وَارْ شكْ سّْنخْڒِيعنْ ؤُ أجّْ ثِيسِّيقْثْ \add ن وُوذمْ نّشْ\add* وَارْ ثْبذِّيڒْ.  
\v 11 أَقَا ذِينْ إِجّْ ن ورْيَازْ ذِي ثْڭلْذِيثْ نّشْ إِ ذِي إِدْجَا بُوحْبڒْ ن إِربِّيثنْ إِمْقدَّاسنْ. مِينْزِي ذڭْ وُوسَّانْ ن بَابَاشْ ؤُفِينْ ذَايسْ ثَافَاوْثْ، ڒفْهَامثْ ذ ثِيغِيثْ أَمْ ثِيغِيثْ ن إِربِّيثنْ. س ؤُينِّي إِڭَّا إِ-ث ؤُجدْجِيذْ نابُوخَاذْنَاصَّارْ، بَابَاشْ، ذ أَرَّايْسْ خْ ثَارْوَا ن ثْسحَّارْثْ ذ إِمسْنَاونْ ن إِثْرَانْ ذ إِكَالْذَانِييّنْ ذ إِڭزَّاننْ، \add وَاهْ،\add* بَابَاشْ، \add أَ\add* أَجدْجِيذْ، \x ◘ \xo 5:‏11 \xt دَان. 2‏:‏47، 48\x*  
\v 12 مِينْزِي ذِي ذَانِييَالْ، إِ ؤُمِي إِڭَّا ؤُجدْجِيذْ إِسمْ ن بَالْطَاشَاصَّارْ، أَقَا إِتّْوَافْ ذَايسْ إِجّْ ن بُوحْبڒْ إِشْنَا أَطَّاسْ ذ ثُوسّْنَا ذ ڒفْهَامثْ \add مَاحنْذْ\add* أَذْ إِفسَّارْ ثِيرْجَا ؤُ أَذْ إِسّنْ مِينْ إِنُّوفَّارنْ ؤُ أَذْ إِفكّْ إِفقُّوسنْ إِوْعَارنْ. أجّْ أَذْ ڒَاغَانْ خْ ذَانِييَالْ ؤُ نتَّا أَذْ إِسَّارْڭبْ ڒْمعْنَا نّسْ.“   
\b  
\m
\v 13 خنِّي إِوْينْ-د ذَانِييَالْ زَّاثْ إِ ؤُجدْجِيذْ. أَجدْجِيذْ إِطّفْ ذڭْ وَاوَاڒْ، إِنَّا إِ ذَانِييَالْ: ”مَا شكْ ذ ذَانِييَالْ، إِجّْ زڭْ أَيْثْ ن إِمنْفِييّنْ زِي يَاهُوذَا نِّي يِيوِي ؤُجدْجِيذْ، بَابَا، \add أَكِيذسْ\add* زِي يَاهُوذَا؟  
\v 14 نشّْ سْڒِيغْ خَاكْ، أَقَا بُوحْبڒْ ن إِربِّيثنْ إِزدّغْ ذَايكْ، ؤُ ثتّْوَافْ ذَايكْ ثَافَاوْثْ ذ ڒفْهَامثْ ذ ثِيغِيثْ أَڒْ طَّارْفْ.  
\v 15 أَقَا نذْهنْ زَّاثِي إِمِيغِيسنْ ذ إِمسْنَاونْ ن إِثْرَانْ حِيمَا أَذْ غَارنْ ثِيرَا-يَا ؤُ أَذْ سَّارْڭْبنْ ڒْمعْنَا نّسْ، مَاشَا نِيثْنِي وَارْ زمَّارنْ أَذْ أَيِي سَّارْڭْبنْ خْ ڒْمعْنَا ن وَاوَاڒْ-أَ.  
\v 16 نشّْ \add مَاشَا\add* سْڒِيغْ خَاكْ أَقَا شكْ ثْزمَّارذْ أَذْ ثْفسَّارذْ \add أَطَّاسْ ن ثْمسْڒَايِينْ\add* ؤُ أَذْ ثْفكّذْ ڒمْعَانِي إِوْعَارنْ. خنِّي ڒخُّو، مَاڒَا ثْزمَّارذْ أَذْ ثْغَارذْ ثِيرَا-يَا ؤُ أَذْ أَيِي ثسَّارڭْبذْ خْ ڒْمعْنَا نّسْ، أَذْ شكْ سّْيَارْضنْ أَرُّوضْ أَذهْمَانِي، أَكْ-ذ إِشْثْ ن ثْسدّشْثْ ن وُورغْ خْ يِيرِي نّشْ، ؤُ أَذْ ثِيڒِيذْ ذ ڒْحَاكمْ وِيسّْ ثْڒَاثَا ذِي ثْڭلْذِيثْ إِنُو.“   
\m
\v 17 ڒخْذنِّي يَارَّا-د ذَانِييَالْ، إِنَّا زَّاثْ إِ ؤُجدْجِيذْ: ”ثِيرْزِيفِينْ نّشْ أَذْ غَاركْ قِّيمنْثْ ؤُ شَّانْ نّشْ أوْشْ إِ-ث إِ ونّغْنِي. مَاشَا ثِيرَا إِ ؤُجدْجِيذْ أَذْ ثنْثْ غَارغْ ؤُ أَذْ ث سَّارْڭْبغْ خْ ڒْمعْنَا.  
\v 18 خَاكْ، \add أَ\add* أَجدْجِيذْ، أَقَا أَربِّي، أَمْعُودْجِي خْ كُوڒْشِي، إِوْشَا إِ بَابَاشْ نابُوخَاذْنَاصَّارْ ثَاڭلْذَا ؤُڒَا ذ ڒمْغَارثْ ذ شَّانْ ذ لْعَاضَامَا.  
\v 19 زِي سِّيبّثْ ن ڒمْغَارثْ إِ ذ أَسْ إِوْشَا، ذوْڒنْ مَارَّا ڒڭْنُوسْ ذ شُّوعُوبْ ذ إِڒْسَاونْ تَّارْجِيجنْ تّْقفْقِيفنْ زَّاثسْ. نتَّا ثُوغَا إِنقّْ ونِّي يخْسْ، إِتّجَّا إِدَّارْ ونِّي يخْسْ، إِسّْڭعّذْ ونِّي يخْسْ ؤُ إِسّْفطَّاحْ ونِّي يخْسْ نتَّا.  
\v 20 مَاشَا ؤُمِي إِبْذَا ؤُڒْ نّسْ إِتّْنُورْفُوعْ ؤُ بُوحْبڒْ نّسْ إِتّقْسَاحْ أَڒَامِي ثذْوڒْ \add ذَايسْ\add* نّْفَاخثْ، إِتّْوَاغْضڒْ زِي ڒْعَارْشْ نّسْ ؤُ إِتّْوَاكّسْ زَّايسْ شَّانْ نّسْ.  
\v 21 سُّوفّْغنْ ث-إِ-د زِي ثَارْوَا ن بْنَاذمْ ؤُ ؤُڒْ نّسْ إِذْوڒْ أَمْ \add وُوڒْ\add* ن إِمُودَّارنْ ؤُ نتَّا ثُوغَا إِزدّغْ أَكْ-ذ يغْيَاڒْ ن ڒخْڒَا. وْشِينْ أَسْ أَرْبِيعْ ذ مَاشَّا أَمْ ڒبْهَايمْ ؤُ نّْذَا ن ؤُجنَّا إِسُّوفَّا زَّايسْ أَرِّيمثْ نّسْ أَڒَامِي إِنْعمْ أَقَا أَربِّي، أَمْعُودْجِي خْ كُوڒْشِي، ذ ڒْحَاكمْ خْ ثْڭلْذَا ن إِوْذَانْ ؤُ إِوْشَا إِ-ت إِ ونِّي يخْسْ نتَّا. \x ◘ \xo 5:‏21 \xt دَان. 4‏:‏22\x*   
\m
\v 22 ؤُ شكْ، مِّيسْ، بَالْشَاصَّارْ، وَاخَّا ثسّْنذْ مَارَّا مَانْ أَيَا، شكْ وَارْ ثسّْوَاضْعذْ ؤُڒْ نّشْ.  
\v 23 شكْ ثسّْڭعّْذذْ إِخفْ نّشْ ضِيدّْ إِ سِيذِي ن ؤُجنَّا ؤُ ڒقْشُوعْ زِي ثَادَّارْثْ نّسْ إِوْينْ ثنْ زَّاثكْ. ؤُ شكْ ذ أَيْثْ ن صُّولْثَا نّشْ ذ ثمْغَارِينْ نّشْ ذ ثِييَّا نّشْ سْوِينْ زَّايْسنْ، شكْ ثُوغَا ثتّْصبَّاحذْ إِ إِربِّيثنْ ن نُّوقَارْثْ ذ وُورغْ ذ وُوزَّاڒْ ذ ؤُكشُّوضْ ذ وژْرُو، إِنِّي وَارْ إِتّْوِيڒِينْ، وَارْ إِتّسْڒِينْ، وَارْ سِّيننْ وَالُو، \add مَاشَا\add* أَربِّي إِ غَارْ إِدْجَا ثْوَارِّيثْ ن نّفْسْ نّشْ ذڭْ ؤُفُوسْ نّسْ ؤُ ونِّي غَارْ إِدْجَا مَارَّا إِبْرِيذنْ نّشْ، وَارْ ث ثسّْعُودْجِيذْ شَا.  
\v 24 خنِّي إِسّكّْ نتَّا إِضوْضَانْ ن ؤُفُوسْ نِّي يُورِينْ ثِيرَا-يَا \add خْ ڒْحِيضْ\add*.  
\v 25 مَانْ أَيَا ذ ثِيرَا إِ يُورِينْ: \bd ’مِينِي، مِينِي، ثِيكِيلْ، ؤُفَارْسِينْ‘\bd*.  
\v 26 وَا ذ ڒْمعْنَا ن وَاوَاڒْ-أَ. ’مِينِي‘، \add إِخْسْ أَذْ يِينِي\add*، أَربِّي أَقَا إِحْسبْ ثَاڭلْذَا نّشْ ؤُ إِقْضَا إِ-ت.  
\v 27 ’ثِيكِيلْ‘، أَقَا شكْ ثتّْوَاوزْنذْ خْ ڒْمِيزَانْ ؤُ ؤُفِينْ شكْ ثفْسُوسذْ.   
\m
\v 28 ’فَارِيسْ‘، ثَاڭلْذِيثْ نّشْ ثمّْسبْضَا ؤُ ثمّوْشْ إِ أَيْثْ ن مَاذَايْ ذ أَيْثْ ن لْفُورْسْ.“ \f ◼ \fr 5:‏28 \ft \+bd ’فَارِيسْ‘\+bd* - أَقَا-ث ذ إِجّْ ن وَاوَاڒْ ذ أَقُوضَاضْ ذڭْ ومْشَانْ ن ’ؤُفَارْسِينْ‘، مَاشَا غَارْسنْ ڒْمعْنَا ذ إِجّنْ.\f*   
\b  
\m
\v 29 ڒخْذنِّي يُومَارْ بَالْشَاصَّارْ حِيمَا أَذْ سّْيَارْضنْ ذَانِييَالْ أَرُّوضْ أَذهْمَانِي، أَكْ-ذ إِشْثْ ن ثْسنْذشْثْ ن وُورغْ خْ يِيرِي نّسْ، ؤُ أَذْ خَاسْ بَارّْحنْ بلِّي نتَّا أَذْ يِيڒِي ذ ڒْحَاكمْ وِيسّْ ثْڒَاثَا ذِي ثْڭلْذِيثْ.   
\m
\v 30 ذِي دْجِيڒثْ نِّي إِتّْوَانغْ بَالْشَاصَّارْ، أَجدْجِيذْ ن إِكَالْذَانِييّنْ.   
\b  
\b  
\m  
\c 6
\s1 ذَانِييَالْ ذڭْ وحْفُورْ ن إِيْرَاذنْ  
\m
\v 1 ذَارِييُوسْ، أَمَاذَايْ، إِكْسِي ثَاڭلْذَا ؤُمِي ثُوغَا غَارسْ عْڒَاحَاڒْ ثْنَاينْ ؤُ-ستِّينْ ن إِسڭّْوُوسَا.  
\v 2 يَارْضَا ذَارِييُوسْ حِيمَا أَذْ يَاڒقّمْ مْيَا ؤُ-عِيشْرِينْ ن إِجدْجِيذنْ سَاذُو \add ؤُفُوسْ\add* نّسْ إِنِّي إِ غَا إِحكّْمنْ مَانِي مَا ذِي كُوڒْ ثْڭلْذِيثْ.  
\v 3 \add نتَّا إِڭَّا\add* خَاسنْ ثْڒَاثَا ن ڒْحُوكَّامْ إِمقّْرَاننْ. ثُوغَا ذَانِييَالْ إِجّنْ زَّايْسنْ. ثُوغَا إِتّْخصَّا إِ إِجدْجِيذنْ نِّي إِدْجَانْ سَاذُو \add ؤُفُوسْ\add* ن ؤُجدْجِيذْ، أَذْ أَسنْ ڭّنْ ڒحْسَابْ، حِيمَا أَجدْجِيذْ وَارْ ث ثْڒقّفْ ثْخسَّارْثْ.  
\v 4 خنِّي ثُوغَا ذَانِييَالْ إِعدُّو ڒْحُوكَّامْ إِمقّْرَاننْ نِّي ذ إِجدْجِيذنْ نِّي إِدْجَانْ سَاذُو \add ؤُفُوسْ\add* ن ؤُجدْجِيذْ، مِينْزِي ثُوغَا ذَايسْ إِجّْ ن بُوحْبڒْ إِشْنَا أَطَّاسْ، ؤُ أَجدْجِيذْ ثُوغَا إِتّْخَارّصْ، حِيمَا أَذْ ث يڭّْ خْ مَارَّا ثَاڭلْذِيثْ.  
\v 5 خنِّي أَرْزُونْ ڒْحُوكَّامْ إِمقّْرَاننْ ذ إِجدْجِيذنْ نِّي إِشْثْ ن سِّيبّثْ مَاحنْذْ أَذْ تَّاهْمنْ ذَانِييَالْ ذِي ثْمسْڒَاشْثْ ن ثْڭلْذِيثْ، مَاشَا نِيثْنِي وَارْ ؤُفِينْ ؤُڒَا ذ إِشْثْ ن سِّيبّثْ نِيغْ ڒْغشّْ، مَاغَارْ نتَّا ثُوغَا ذ أَمْثِيقِّي ؤُ وَارْ ذَايسْ إِتّْوِيفْ ڒعْڭزْ نِيغْ \add ؤُڒَا ذ إِشْثْ ن جُّورثْ\add* ن ثْمسْڒَايِينْ ثِيعفَّانِينْ.  
\v 6 خنِّي نَّانْ إِرْيَازنْ نِّي: ”وَارْ نتِّيفْ ؤُڒَا ذ إِشْثْ ن سِّيبّثْ إِ تُّوهْمثْ خْ ذَانِييَالْ-أَ، مْغِيرْ مَاڒَا نُوفَا إِ-ت ذِي ثْمسْڒَاشْثْ ن شَّارِيعَا ن أَربِّي نّسْ.“   
\m
\v 7 ڒخْذنِّي مُوننْ ڒْحُوكَّامْ إِمقّْرَاننْ ذ إِجدْجِيذنْ نِّي إِدْجَانْ سَاذُو \add ؤُفُوسْ\add* ن ؤُجدْجِيذْ، ؤُسِينْ-د هَاجَانْ إِ ؤُجدْجِيذْ، نَّانْ أَسْ: ”\add أَ\add* أَجدْجِيذْ ذَارِييُوسْ، دَّارْ إِ ڒبْذَا!  
\v 8 مْشَاوَارنْ مَارَّا ڒْحُوكَّامْ إِمقّْرَاننْ ن ثْڭلْذِيثْ: إِمْضبَّارنْ ذ إِجدْجِيذنْ \add نِّي إِدْجَانْ\add* سَاذُو إِ ؤُجدْجِيذْ ذ إِمْشَاوَارنْ ذ لْوُولَاثْ، حِيمَا أَجدْجِيذْ أَذْ د-إِسُّوفّغْ إِجّْ ن ڒُومُورْ ذ إِجّْ ن ڒحْكَامْ إِنهَّانْ مَارَّا ونِّي إِ غَا إِقدّْمنْ إِشْثْ ن ثُوثْرَا إِ يِيجّْ ن أَربِّي نِيغْ إِ يِيجّْ ن بْنَاذمْ مْغِيرْ إِ شكْ، \add أَ\add* أَجدْجِيذْ، ذِي ڒْمِيجَاڒْ ن ثْڒَاثِينْ ن وُوسَّانْ، أَذْ إِتّْوَامّنْضَارْ ذِي ثسْرَافْثْ ن وَايْرَاذنْ.  
\v 9 خنِّي ڒخُّو، \add أَ\add* أَجدْجِيذْ، سكَّارْ ڒُومُورْ ؤُ وقّعْ ثِيرَا، حِيمَا وَارْ إِتّْوَابطّڒْ \add ڒُومُورْ\add* ؤُ وَارْ إِفنِّي أَمْ مَامّشْ كُوڒْ ڒْقَانُونْ ن أَيْثْ ن مَاذَايْ ذ أَيْثْ ن لْفُورْسْ.“ \x ◘ \xo 6:‏9 \xt إِسْت. 1‏:‏9؛ 8‏:‏8\x*   
\m
\v 10 س ؤُينِّي يُورَا ؤُجدْجِيذْ ذَارِييُوسْ ثِيرَا ذ ڒُومُورْ نِّي \add س يِيسمْ نّسْ\add*.   
\m
\v 11 ؤُمِي إِسّنْ ذَانِييَالْ أَقَا ثِيرَا-يَا ثتّْوَاوقّعْ، يُوذفْ نتَّا غَارْ ثَادَّارْثْ نّسْ. ثُوغَا ثِيبُورْجَاثِينْ ن ثْغُورْفثْ نّسْ أَرزْمنْثْ غَارْ ؤُرْشَالِيمْ. نتَّا إِسْجذْ \add ذِينْ\add* خْ إِفَادّنْ ثْڒَاثَا ن ثْوَاڒَاوِينْ ذڭْ وَاسّْ، إِژُّودْجْ ؤُ إِقَاذَا أَربِّي نّسْ أَمْ مَامّشْ ثُوغَا إِتّڭّْ قْبڒْ. \x ◘ \xo 6:‏11 \xt 1 إِج. 8‏:‏44؛ إِزهد. 55‏:‏18\x*   
\m
\v 12 ڒخْذنِّي مُوننْ يرْيَازنْ نِّي س ؤُهَاجِي ؤُشَا ؤُفِينْ ذَانِييَالْ إِتّْژَادْجْ ؤُ إِتّْزَاوَاڭْ إِ أَربِّي نّسْ.  
\v 13 خنِّي ؤُذْفنْ-د \add غَارسْ\add* ؤُ سِّيوْڒنْ زَّاثْ \add إِ وُوذمْ\add* ن ؤُجدْجِيذْ خْ ڒُومُورْ ن ؤُجدْجِيذْ: ”مَا وَارْ ثْوقّْعذْ شَا إِجّْ ن ڒُومُورْ بلِّي كُوڒْ إِجّنْ ونِّي، ذِي ڒْمِيجَاڒْ ن ثْڒَاثِينْ ن وُوسَّانْ، غَا إِقدّْمنْ إِشْثْ ن ثُوثْرَا إِ يِيجّْ ن أَربِّي نِيغْ إِ يِيجّْ ن بْنَاذمْ مْغِيرْ إِ شكْ، \add أَ\add* أَجدْجِيذْ، أَذْ إِتّْوَامّنْضَارْ ذِي ثسْرَافْثْ ن وَايْرَاذنْ؟“ يَارَّا-د ؤُجدْجِيذْ، إِنَّا: ”ثَامسْڒَاشْثْ ثْبدّْ أَمْ يِيجّْ ن ڒْقَانُونْ ن أَيْثْ ن مَاذَايْ ذ أَيْثْ ن لْفُورْسْ نِّي وَارْ إِفنِّينْ.“  
\v 14 خنِّي أَرِّينْ-د، نَّانْ زَّاثْ \add إِ وُوذمْ ن\add* ؤُجدْجِيذْ: ”ذَانِييَالْ، إِجّنْ زڭْ إِمنْفِييّنْ زِي يَاهُوذَا، أَقَا وَارْ شكْ إِتّْوقَّارْ، \add أَ\add* أَجدْجِيذْ، ؤُڒَا ذ ڒُومُورْ نِّي ثْوقّْعذْ. نتَّا إِتّْژَادْجْ ثْڒَاثَا ن ثْوَاڒَاوِينْ ذڭْ وَاسّْ.“  
\v 15 ؤُمِي إِسْڒَا ؤُجدْجِيذْ أَوَاڒْ-أَ، إِخيّقْ أَطَّاسْ خْ يِيخفْ نّسْ ؤُشَا إِڭَّا خْ وُوڒْ نّسْ مَاحنْذْ أَذْ إِفكّْ ذَانِييَالْ. أَڒْ أَغدْجَايْ ن ثْفُوشْثْ إِڭَّا ثِيزمَّارْ نّسْ مَاحنْذْ أَذْ ث إِسّنْجمْ.  
\v 16 خنِّي مُوننْ-د يرْيَازنْ نِّي س ؤُهَاجِي غَارْ ؤُجدْجِيذْ، نَّانْ إِ ؤُجدْجِيذْ: ”\add أَ\add* أَجدْجِيذْ، ثسّْنذْ أَقَا-ث ذ إِجّْ ن ڒْقَانُونْ ن أَيْثْ ن مَاذَايْ ذ أَيْثْ ن لْفُورْسْ \add ؤُ\add* وَارْ إِزمَّارْ أَذْ إِتّْوَابدّڒْ ؤُڒَا ذ إِجّْ ڒُومُورْ نِيغْ ذ ڒحْكَامْ نِّي د-إِفّْغنْ زڭْ ؤُجدْجِيذْ.“  
\v 17 خنِّي يُومُورْ ؤُجدْجِيذْ أَذْ نذْهنْ ذَانِييَالْ زَّاثسْ ؤُ نْضَارنْ ث ذِي ثسْرَافْثْ ن وَايْرَاذنْ. أَجدْجِيذْ إِطّفْ ذڭْ وَاوَاڒْ، إِنَّا إِ ذَانِييَالْ: ”أَربِّي نّشْ، ونِّي إِ ثْوقَّارذْ ڒبْذَا، أَذْ شكْ إِفكّْ!“  
\v 18 إِوْينْ-د إِجّْ ن وژْرُو ؤُشَا سَّارْسنْ ث خْ ؤُقمُّومْ ن ثسْرَافْثْ ؤُشَا إِشمّعْ إِ-ث ؤُجدْجِيذْ س ثْخَاذنْثْ نّسْ ؤُڒَا س ثْخَاذنْثْ ن أَيْثْ ن جّهْذْ نّسْ، حِيمَا وَارْ إِتّْبذِّيڒْ أَرَّايْ خْ ذَانِييَالْ.   
\m
\v 19 خنِّي يُويُورْ ؤُجدْجِيذْ غَارْ ڒقْصَارْ نّسْ. إِسّعْذُو دْجِيڒثْ نِّي ذڭْ ؤُژُومِّي ؤُ وَارْ يجِّي أَذْ أَسْ د-أَوْينْ أَفَارّجْ ؤُشَا إِضْوَا زَّايسْ يِيضصْ.  
\v 20 زِيشْ غَارْ صّْبحْ غَارْ \add ونْقَارْ\add* ن ثْفَاوْثْ، إِكَّارْ-د ؤُجدْجِيذْ، إِتَّاژّڒْ غَارْ ثسْرَافْثْ ن وَايْرَاذنْ.  
\v 21 ؤُمِي د-إِقَارّبْ غَارْ ثسْرَافْثْ، إِڒَاغَا س ثْمِيجَّا ثشْضنْ خْ ذَانِييَالْ. أَجدْجِيذْ إِسِّيوڒْ، إِنَّا إِ ذَانِييَالْ: ”\add أَ\add* ذَانِييَالْ، شكْ ذ أَمْسخَّارْ ن أَربِّي إِدَّارنْ! مَا أَربِّي نّشْ، ونِّي إِ ثْوقَّارذْ ڒبْذَا، مَا ثُوغَا إِزمَّارْ أَذْ شكْ إِفكّْ زڭْ إِيْرَاذنْ؟“  
\v 22 خنِّي إِسِّيوڒْ ذَانِييَالْ أَكْ-ذ ؤُجدْجِيذْ ”\add أَ\add* أَجدْجِيذْ، دَّارْ إِ ڒبْذَا!  
\v 23 أَربِّي إِنُو إِسّكّْ لْمَالَاكْ نّسْ ؤُ إِبلّعْ أَقمُّومْ ن وَايْرَاذنْ. ثُوغَا وَارْ زمَّارنْ أَذْ أَيِي إِيْزْمنْ مَاغَارْ يُوفَا أَيِي ذ أَمزْذَاڭْ زَّاثسْ. ؤُڒَا أَكِيذكْ، \add أَ\add* أَجدْجِيذْ، وَارْ ڭِّيغْ ؤُڒَا ذ إِشْثْ ن لْجَارِيمَا!“   
\m
\v 24 خنِّي إِفَارْحْ ؤُجدْجِيذْ أَطَّاسْ، يُومُورْ أَذْ د-أَوْينْ ذَانِييَالْ زِي ثسْرَافْثْ. أَوَارْنِي ڒَامِي ث إِوْينْ زِي ثسْرَافْثْ وَارْ ذَايسْ ؤُفِينْ ؤُڒَا ذ إِشْثْ ن جّْرِيحشْثْ، مَاغَارْ نتَّا ثُوغَا إِتّْشڒْ خْ أَربِّي نّسْ.  
\v 25 ڒخْذنِّي يُومُورْ ؤُجدْجِيذْ أَذْ أَوْينْ إِرْيَازنْ نِّي ثُوغَا إِتَّاهْمنْ ذَانِييَالْ. نْضَارنْ ثنْ ذِي ثسْرَافْثْ ن وَايْرَاذنْ، نِيثْنِي ذ إِحنْجِيرنْ نْسنْ ذ ثمْغَارِينْ نْسنْ. نِيثْنِي ثُوغَا عَاذْ وَارْ إِوِيضنْ شَا غَارْ ثِيسِي ن ثسْرَافْثْ ؤُمِي ثنْ طّْفنْ وَايْرَاذنْ ؤُشَا مزّْقنْ مَارَّا إِغْسَانْ نْسنْ.   
\m
\v 26 خنِّي يُورَا ؤُجدْجِيذْ ذَارِييُوسْ إِ مَارَّا ڒڭْنُوسْ ذ شُّوعُوبْ ذ إِڒْسَاونْ: ”أَذْ يِيڒِي ڒهْنَا نْومْ ذ أَمقّْرَانْ أَطَّاسْ.  
\v 27 أَقَا سُّوفّْغغْ-د إِجّْ ن ڒُومُورْ حِيمَا \add إِمزْذَاغْ\add* ذِي مَارَّا ثَاڭلْذِيثْ إِنُو، ثنِّي خْ صلّْطغْ، أَذْ أَرْجِيجنْ ؤُ أَذْ قفْقْفنْ زَّاثْ إِ وُوذمْ ن أَربِّي ن ذَانِييَالْ مَاغَارْ نتَّا ذ أَربِّي إِدَّارنْ ؤُ نتَّا أَذْ إِقِّيمْ إِ ڒبْذَا قَاعْ ؤُ ثَاڭلْذَا نّسْ وَارْ زمَّارنْ أَذْ ت ضَارّنْ ؤُ صُّولْطَا نّسْ أَذْ ثقِّيمْ أَڒْ أَنڭَّارُو. \x ◘ \xo 6:‏27 \xt دَان. 2‏:‏44؛ 4‏:‏3؛ 7‏:‏14، 27؛ لك. 1‏:‏33\x*  
\v 28 نتَّا إِفكّْ ؤُ إِسّنْجمْ ؤُ إِتّڭّْ ڒعْڒَامَاثْ ذ لْمُوعْجِيزَاثْ ذڭْ ؤُجنَّا ؤُ خْ ثمُّورْثْ. ذ نتَّا إِ إِفكّنْ ؤُ إِسّنْجْمنْ ذَانِييَالْ زڭْ وَاشَّارنْ ن وَايْرَاذنْ.“  
\v 29 ذَانِييَالْ وَانِيثَا ثُوغَا إِفْڒحْ ؤُمِي ثُوغَا ثَاڭلْذَا ذڭْ ؤُفُوسْ ن ذَارِييُوسْ ؤُ ذڭْ ؤُفُوسْ ن كُورَاشْ، أَفَارْسِي.   
\b  
\b  
\m  
\c 7
\s1 ثَارْجِيثْ ن أَربْعَا ن إِمُودَّارنْ  
\m
\v 1 ذڭْ ؤُسڭّْوَاسْ أَمزْوَارُو ن بَالْشَاصَّارْ، أَجدْجِيذْ ن بَابِيلْ، إِژْرَا ذَانِييَالْ إِشْثْ ن ثَارْجِيثْ ذ إِوحَّانْ ذڭْ ؤُزدْجِيفْ نّسْ ؤُمِي ث ثُوغَا ذِي ثَاسُّوثْ. خنِّي يُورَا ثَارْجِيثْ نِّي ؤُشَا إِحَاجَا زَّايسْ ثِيمسْڒَايِينْ ثِيمزْوُورَا.   
\m
\v 2 إِسِّيوڒْ ذَانِييَالْ، إِنَّا: ”ثْوَاڒِيغْ س دْجِيڒثْ إِجّْ ن ڒوْحِييْ، ؤُ خْزَارْ، أَقَا ذِينْ أَربْعَا ن إِسمِّيضنْ ن ؤُجنَّا سّْهوْڒنْ ڒبْحَارْ أَمقّْرَانْ،  
\v 3 ؤُشَا أَربْعَا ن إِمُودَّارنْ إِمقّْرَاننْ، إِنِّي وَارْ يَاروْسنْ شَا ذڭْ وَايَاوْيَا، ڭعّْذنْ-د زِي ڒبْحَارْ.   
\m
\v 4 \add ثُوغَا\add* أَمزْوَارُو أَمْ ويْرَاذْ، غَارسْ أَفْرِيونْ أَمْ ؤُڭِيذرْ. نشّْ قِّيمغْ خزَّارغْ أَڒَامِي تّْوَاقڒْعنْ وَافْرِيونْ نّسْ. إِتّْوَاسّْڭعّذْ-د زِي ثمُّورْثْ ؤُشَا إِتّْوَاسَّارْسْ خْ إِضَارنْ نّسْ أَمْ يِيجّْ ن بْنَاذمْ ؤُشَا إِمّوْشْ أَسْ إِجّْ ن وُوڒْ ن بْنَاذمْ.   
\m
\v 5 ؤُ خْزَارْ، إِجّنْ نّغْنِي، وِيسّْ ثْنَاينْ، يَارْوسْ ذِي دُّوبْ ؤُ إِسّْڭعّذْ إِخفْ نّسْ غَارْ إِجّْ ن ؤُغزْذِيسْ ؤُ ذڭْ ؤُقمُّومْ نّسْ جَارْ ثغْمَاسْ نّسْ أَقَا ذِينْ ثْڒَاثَا ن يغْسَانْ ن ثْغزْذِيسْثْ \add زڭْ إِذْمَارنْ\add*، ؤُشَا نَّانْ أَسْ: ’كَّارْ، أشّْ أَطَّاسْ ن ويْسُومْ!‘   
\m
\v 6 أَوَارْنِي أَسْ ثْوَاڒِيغْ \add عَاوذْ\add*، ؤُ خْزَارْ، إِجّْ نّغْنِي أَمْ ؤُغِيڒَاسْ. غَارسْ خْ وعْرُورْ نّسْ أَربْعَا ن وَافْرِيونْ ن إِجّْ ن وجْضِيضْ. أَمُودَّارْ \add نِّي\add* ثُوغَا غَارسْ أَربْعَا ن إِزدْجِيفنْ ؤُشَا ثمّوْشْ أَسْ صُّولْطَا.   
\m
\v 7 أَوَارْنِي أَسْ ثْوَاڒِيغْ \add عَاوذْ\add* ذڭْ إِوحَّانْ ذِي دْجِيڒثْ، ؤُ خْزَارْ، أَمُودَّارْ وِيسّْ أَربْعَا إِسَّاڭّْوَاذْ ؤُ إِسّْنخْڒَاعْ ؤُ غَارسْ أَطَّاسْ ن جّهْذْ. غَارسْ ثِيغْمَاسْ ن وُوزَّاڒْ، إِشَّا، إِڒْبزْ ؤُ مِينْ إِقِّيمنْ إِعْفسْ خَاسْ س إِضَارنْ نّسْ. ثُوغَا إِمّْسبْضَا خْ إِمُودَّارنْ نّغْنِي نِّي ثُوغَا قْبڒْ نّسْ ؤُ غَارسْعشْرَا ن وَاشَّاونْ.  
\v 8 نشّْ حْضِيغْ خْ وَاشَّاونْ، ؤُ خْزَارْ، إِجّْ ن وَاشَّاوْ ذ أَمژْيَانْ إِڭعّذْ جَارْ أَسنْ ؤُ تّْوَاقڒْعنْ-د ثْڒَاثَا ن وَاشَّاونْ إِمزْوُورَا ؤُشَا تّْوَاكّْسنْ-د زڭْ ومْشَانْ نْسنْ. ؤُ خْزَارْ، ذڭْ وَاشَّاوْ نِّي ثُوغَا أَخْمِي ذَايسْ ثِيطَّاوِينْ ن بْنَاذمْ ذ يِيجّْ ن ؤُقمُّومْ إِشُّورْ س ڒفْضَايحْ ثِيمقّْرَانِينْ.   
\m
\v 9 نشّْ قِّيمغْ تّْوَاڒِيغْ أَڒَامِي مَّارْسنْ ڒكْرَاسِي إِڭلّْذنْ ؤُشَا إِقِّيمْ ؤُوسَّارْ ن وُوسَّانْ. أَرُّوضْ نّسْ ذ أَشمْڒَاڒْ أَمْ وذْفڒْ ؤُ أَشُوَّافْ نّسْ أَمْ ثَاضُوفْثْ ثصْفَا. ڒْكُورْسِي إِڭلّْذنْ نّسْ ذ إِحُوذَاقْ ن ثْمسِّي ذ ثْجَارَّارِينْ نّسْ أَمْ ثْمسِّي إِتّحْذُوذُوقنْ.  
\v 10 إِفّغْ-د زَّايسْ إِجّْ ن إِغْزَارْ ن ثْمسِّي. أَڒفْ \add خْ\add* ڒُوڒُوفْ ثُوغَا تّْسخَّارَانْ أَسْ ؤُعشْرَا ن ڒُوڒُوفْ \add خْ\add*عشْرَا ن ڒُوڒُوفْ بدّنْ زَّاثسْ. أَڭْرَاوْ ن شّْرعْ إِطّفْ ذڭْ ؤُغِيمِي ؤُشَا نُّورْزْمنْ إِذْلِيسنْ. \x ◘ \xo 7:‏10 \xt أَسَا. 5‏:‏11؛ 20‏:‏12\x*   
\m
\v 11 نشّْ قِّيمغْ خزَّارغْ زِي سِّيبّثْ ن ڒْحسّْ ن وَاوَاڒنْ إِمقّْرَاننْ نِّي إِسِّيوڒْ يِيشّْ \add نِّي\add*. نشّْ قِّيمغْ خزَّارغْ أَڒَامِي إِتّْوَانغْ ؤُمُودَّارْ ؤُ ثتّْوَاهلّكْ أَرِّيمثْ نّسْ ؤُ إِتّْوَاسلّمْ إِ ثْمسِّي إِتّحْذُوذُوقنْ.  
\v 12 ؤُڒَا ذ إِمُودَّارنْ إِنّغْنِي ثتّْوَاكّسْ أَسنْ صُّولْطَا نْسنْ ؤُ إِمّوْشْ أَسنْ ثَازُّوڭَّارْثْ ن ثُوذَارْثْ \add نْسنْ\add* أَڒْ إِشْثْ ن ثْسَاعّثْ ؤُ أَڒْ إِجّْ ن ڒْمِيجَاڒْ \add إِتّْوَاڭّنْ\add*.   
\m
\v 13 نشّْ قِّيمغْ تّْوَاڒِيغْ ذِي إِوحَّانْ ن دْجِيڒثْ، ؤُ خْزَارْ، يُوسَا-د أَكْ-ذ إِسيْنُوثنْ ونِّي إِڭِّينْ أَمْ يِيجّْ ن مِّيسْ ن بْنَاذمْ، ؤُ نتَّا يُويُورْ غَارْ ؤُوسَّارْ ن وُوسَّانْ ؤُشَا سّْقَارّْبنْ ث زَّاثسْ.  
\v 14 ثمّوْشْ أَسْ صُّولْطَا ذ شَّانْ ذ ثْڭلْذَا، ؤُ مَارَّا ڒڭْنُوسْ ذ شُّوعُوبْ ذ إِڒْسَاونْ ثُوغَا تّْسخَّارنْ أَسْ. صُّولْطَا نّسْ ذ إِشْثْ ن صُّولْطَا إِ ڒبْذَا إِ وَارْ إِفنِّينْ ؤُ ثَاڭلْذَا نّسْ وَارْ إِزمَّارْ أَذْ ت ضَارّنْ. \x ◘ \xo 7:‏14 \xt دَان. 2‏:‏44؛ لك. 1‏:‏33\x*   
\b  
\m
\v 15 نشّْ، ذَانِييَالْ، أَقَا إِتّْوَاسّْحِيسّفْ بُوحْبڒْ إِنُو ذَاخڒْ ذِي أَرِّيمثْ إِنُو ؤُ إِوحَّانْ ذڭْ ؤُزدْجِيفْ إِنُو سّنْخڒْعنْثْ أَيِي.  
\v 16 نشّْ ؤُيُورغْ غَارْ يِيجّنْ زڭْ يِينِّي ذِينْ إِبدّنْ ؤُ سّقْسِيغْ ث خْ مِينْ إِخْسْ أَذْ يِينِي مَانْ أَيَا مَارَّا ؤُ نتَّا إِسِّيوڒْ-د أَكِيذِي، إِشَارّحْ أَيِي ثِيمسْڒَايِينْ-أَ.   
\m
\v 17 ”إِمُودَّارنْ-أَ إِمقّْرَاننْ، أَربْعَا نِّي، \add أَقَا أَثنْ\add* أَربْعَا ن إِجدْجِيذنْ نِّي د غَا إِڭعّْذنْ زِي ثمُّورْثْ.  
\v 18 \add أَوَارْنِي أَيَا\add* إِمْقدَّاسنْ ن ؤُمْعُودْجِي خْ كُوڒْشِي أَذْ طّْفنْ ثَاڭلْذَا ؤُ ثَاڭلْذَا أَذْ غَارْسنْ ثِيڒِي إِ ڒبْذَا، \add وَاهْ،\add* إِ ڒبْذَا ن ڒبْذَايَاثْ.“   
\m
\v 19 خنِّي خْسغْ أَذْ سّْنغْ ڒْمعْنَا ن ؤُمُودَّارْ وِيسّْ أَربْعَا، ونِّي ثُوغَا إِمّْسبْضَا أَطَّاسْ خْ مَارَّا إِنّغْنِي، إِسَّاڭّْوَاذْ بْڒَا ڒْحذْ. أَقَا غَارسْ ثِيغْمَاسْ ن وُوزَّاڒْ ذ وَاشَّارنْ ن نّْحَاسْ، إِشَّا، إِڒْبزْ ؤُ مِينْ إِقِّيمنْ إِعْفسْ خَاسْ س إِضَارنْ نّسْ.  
\v 20 \add ثُوغَا خْسغْ أَذْ سّْنغْ عَاوذْ ڒْمعْنَا ن\add* وَاشَّاونْ خْ ؤُزدْجِيفْ نّسْ ؤُ خْ ونّغْنِي إِ د-إِڭعّْذنْ إِ ؤُمِي د-وْضَانْ ثْڒَاثَا زَّاثسْ، \add إِخْسْ أَذْ يِينْ\add* خْ يِيشّْ نِّي غَارسْ ثِيطَّاوِينْ ذ إِجّْ ن ؤُقمُّومْ \add إِشُّورْ س\add* وَاوَاڒنْ إِمْغَارنْ، ذ ونِّي إِبَانْ-د ذ أَمقّْرَانْ خْ \add وَاشَّاونْ\add* نّغْنِي،  
\v 21 نشّْ ژْرِيغْ أَقَا إِشّْ نِّي إِتّْمنْغَا أَكْ-ذ إِمْقدَّاسنْ ؤُ إِغلّبْ خَاسنْ،  
\v 22 أَڒَامِي د-يُوسَا ؤُمْغَارْ ن وُوسَّانْ ؤُ يُوغَا ثَاسْغَارْثْ إِ إِمْقدَّاسنْ ن ؤُمْعُودْجِي خْ كُوڒْشِي ؤُشَا ثُوسَا-د ثْسَاعّثْ إِتّْوَاڭّنْ ؤُشَا طّْفنْ إِمْقدَّاسنْ ثَاڭلْذَا.   
\m
\v 23 نتَّا إِنَّا أَمُّو: ”أَمُودَّارْ وِيسّْ أَربْعَا أَذْ يِيڒِي ذ ثَاڭلْذِيثْ وِيسّْ أَربْعَا خْ ثمُّورْثْ نِّي إِ غَا ثِيڒِي ثمْسبْضَا خْ مَارَّا ثِيڭلْذِيوِينْ \add نّغْنِي\add*. أَذْ يشّْ ثَامُّورْثْ مَارَّا، أَذْ خَاسْ إِعْفسْ ؤُ أَذْ ت إِڒْبزْ.  
\v 24 ؤُ خْعشْرَا ن وَاشَّاونْ، أَقَا زِي ثْڭلْذِيثْ نِّي أَذْ كَّارنْعشْرَا ن إِجدْجِيذنْ ؤُ أَوَارْنِي أَسنْ أَذْ إِكَّارْ ونّغْنِي ؤُ وَانِيثَا أَذْ يِيڒِي إِمّْسبْضَا خْ إِمزْوُورَا ؤُ نتَّا أَذْ إِذدْجْ ثْڒَاثَا ن إِجدْجِيذنْ.  
\v 25 نتَّا أَذْ إِتّْعفَّارْ س وَاوَاڒنْ نّسْ خْ ؤُمْعُودْجِي ن كُوڒْشِي ؤُ أَذْ يَاردّدْجْ إِمْقدَّاسنْ ن ؤُمْعُودْجِي خْ كُوڒْشِي ؤُ أَذْ يَارْزُو مَاحنْذْ أَذْ إِبدّڒْ زّْمَانَاثْ ذ شَّارِيعَا، ؤُ نِيثْنِي أَذْ مّوْشنْ ذڭْ ؤُفُوسْ نّسْ إِ يِيجّْ ن ڒْمِيجَاڒْ ن ڒْوقْثْ ذ ڒوْقَاثْ ذ إِجّْ وزْينْ ن ڒْمِيجَاڒْ ن ڒْوقْثْ. \x ◘ \xo 7:‏25 \xt دَان. 11‏:‏36\x*  
\v 26 خنِّي أَذْ إِطّفْ وڭْرَاوْ ن شّْرعْ ذڭْ ؤُغِيمِي، ؤُشَا أَذْ زَّايسْ تّْوَاكّْسنْ صُّولْطَا نّسْ مَاحنْذْ أَذْ إِتّْوَاردّدْجْ ؤُ أَذْ إِتّْوَاثحَّا أَمْ إِكْمڒْ.  
\v 27 مَاشَا ثَاڭلْذَا ذ صُّولْطَا ذ ڒمْغَارثْ ن مَارَّا ثِيڭلْذِيوِينْ سَاذُو ؤُجنَّا أَذْ مّوْشنْثْ إِ ڒْڭنْسْ ن إِمْقدَّاسنْ ن ؤُمْعُودْجِي خْ كُوڒْشِي. ثَاڭلْذِيثْ نّسْ ذ إِشْثْ ن ثْڭلْذِيثْ إِ ڒبْذَا ؤُ مَارَّا ثِيڭلْذِيوِينْ أَذْ ث وقَّارنْ ؤُ أَذْ أَسْ طَاعنْ إِ نتَّا.“   
\m
\v 28 وَانِيثَا ذ أَوَاڒْ أَنڭَّارُو. \add خَافِي\add* نشّْ، نشّْ ذَانِييَالْ، أَقَا إِخَارِّيصنْ إِنُو سّنْخڒْعنْ أَيِي ؤُ ثِيسِّيقْثْ ثْرُوحْ زڭْ وُوذمْ إِنُو، مَاشَا نشّْ حْضِيغْ أَوَاڒْ نِّي ذڭْ وُوڒْ إِنُو.  
\b  
\m \bdit أَڒْ ذَانِيثَا إِ ثِيوضْ ثِيرَا س يِيڒسْ ن ثْرَامِيثْ.\bdit*   
\b  
\b  
\m  
\c 8
\s1 ثَامژْرِيوْثْ ن إِشَارِّي ذ ؤُمْيَانْ  
\m
\v 1 ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثْڒَاثَا ن ثْڭلْذَا ن ؤُجدْجِيذْ بَالْشَاصَّارْ، إِبَانْ-أَيِي-د إِجّْ ن ڒوْحِييْ، إِ نشّْ ذَانِييَالْ، أَوَارْنِي إِ \add ڒوْحِييْ\add* أَمزْوَارُو نِّي ثُوغَا إِ ذ أَيِي د-إِبَاننْ.  
\v 2 نشّْ ثُوغَا تّْوَاڒِيغْ ذڭْ إِجّْ ن ڒوْحِييْ ؤُ ژْرِيغْ ثُوغَا أَيِي ذِي لْبُورْجْ ن شُوشَانْ \add نِّي إِدْجَانْ\add* ذِي لْعَامَالَا ن عِيلَامْ. نشّْ تّْوَاڒِيغْ ذِي ڒوْحِييْ ثُوغَا أَيِي غَارْ يغْزَارْ ن ؤُلَايْ.   
\m
\v 3 نشّْ سّْڭعّْذغْ ثِيطَّاوِينْ إِنُو، ؤُ خْزَارْ، إِجّْ ن إِشَارِّي إِبدّْ زَّاثْ إِ إِغْزَارْ. ثُوغَا غَارسْ ثْنَاينْ ن وَاشَّاونْ ؤُ ثْنَاينْ نِّي ن وَاشَّاونْ ثُوغَا أَثنْ ذ إِزِيرَارنْ. ثُوغَا إِجّْ ن يِيشّْ \add زَّايْسنْ\add* يُوعْڒَا خْ ونّغْنِي ؤُ ونِّي يُوعْڒَانْ إِڭعّذْ ذ أَنڭَّارْ.  
\v 4 نشّْ ژْرِيغْ أَقَا إِشَارِّي إِشَّاثْ س وَاشَّاونْ نّسْ غَارْ ڒْغَارْبْ ؤُ غَارْ شَّامَالْ ذ لْجَانُوبْ. ؤُڒَا ذ إِجّْ ن ؤُمُودَّارْ إِزمَّارْ أَذْ إِبدّْ زَّاثسْ ؤُ وَارْ إِدْجِي وِي غَا إِنجْمنْ زڭْ ؤُفُوسْ نّسْ. نتَّا إِڭَّا مِينْ إِخْسْ ؤُ إِسّمْغَارْ إِخفْ نّسْ.   
\m
\v 5 نشّْ قِّيمغْ حكَّارغْ، ؤُ خْزَارْ، يُوسَا-د إِجّْ ن ومْيَانْ زِي لْغَارْبْ خْ مَارَّا ؤُذمْ ن ثمُّورْثْ، وَارْ إِحِيذِي ثَامُّورْثْ. أَمْيَانْ-أَ غَارسْ إِجّْ ن دّڭْ ن يِيشّْ جَارْ ثِيطَّاوِينْ نّسْ غَارسْ ڒْقِيمثْ.  
\v 6 نتَّا يِيوضْ-د غَارْ إِشَارِّي نِّي إِ غَارْ إِدْجَا ثْنَاينْ ن وَاشَّاونْ، ونِّي ژْرِيغْ إِبدّْ زَّاثْ إِ إِغْزَارْ. إِقَارّبْ-د غَارسْ س ثزْڒَا أَكْ-ذ ڒقْسَاحثْ ن جّهْذْ نّسْ،  
\v 7 ؤُ ژْرِيغْ أَقَا يِيوضْ غَارْ ؤُغزْذِيسْ ن إِشَارِّي ؤُ إِشَّاثْ ذَايسْ س ثيِّيثَا قسْحنْثْ. نتَّا إِمْقَارْقبْ أَكْ-ذ إِشَارِّي ؤُ يَارْژَا أَسْ ثْنَاينْ ن وَاشَّاونْ نّسْ ؤُشَا إِشَارِّي ثُوغَا وَارْ غَارسْ جّحْذْ عَاذْ مَاحنْذْ أَذْ إِقِّيمْ إِبدّْ. إِنْضَارْ إِ-ث غَارْ ثمُّورْثْ ؤُ يَارْفسْ إِ-ث ؤُ ثُوغَا وَارْ ذِينْ وِي ث غَا إِفكّنْ زڭْ ؤُفُوسْ نّسْ.   
\m
\v 8 أَمْيَانْ إِسّمْغَارْ إِخفْ نّسْ أَڒْ طَّارْفْ، \add مَاشَا\add* أَڒَامِي إِذْوڒْ إِجْهذْ، يَارْژَا يِيشّْ نِّي أَمقّْرَانْ ؤُشَا خڒْفنْ-د ذڭْ ومْشَانْ نّسْ أَربْعَا ن وَاشَّاونْ إِتّْبَاننْ غَارْ جّْوَايهْ ن أَربْعَا ن إِغزْذِيسنْ ن ؤُسمِّيضْ ن ؤُجنَّا.   
\m
\v 9 زڭْ يِيجّْ زَّايْسنْ إِفّغْ-د إِجّْ ن يِيشّْ ذ أَمعْنَانْ ؤُشَا إِذْوڒْ ذ أَمقّْرَانْ أَڒْ طَّارْفْ، غَارْ لْجَانُوبْ ؤُ غَارْ شَّارْقْ ؤُ غَارْ \add ثمُّورْثْ ن\add* ثلْوِيزْثْ.  
\v 10 إِذْوڒْ إِمْغَارْ \add إِڭعّذْ\add* أَڒْ ڒْعسْكَارْ ن ؤُجنَّا ؤُشَا إِنْضَارْ-د \add شَا\add* زِي ڒْعسْكَارْ ؤُ زِي يثْرَانْ غَارْ ثمُّورْثْ ؤُشَا يَارْفسْ إِ-ثنْ.  
\v 11 \add وَاهْ\add*، إِسّمْغَارْ إِخفْ نّسْ أَڒَامِي د-يِيوضْ غَارْ ڒْحَاكمْ ن ڒْعسْكَارْ. وَانِيثَا ثتّْوَاكّسْ زَّايسْ \add ثوْهِيبْثْ\add* ن ڒبْذَا ؤُ إِمّنْضَارْ ومْشَانْ ن زَّاوشْثْ نّسْ إِقدّْسنْ.  
\v 12 أَذْ إِتّْوَاڭّْ إِجّْ ن ڒْعسْكَارْ خْ ثوْهِيبْثْ ن ڒبْذَا زِي سِّيبّثْ ن إِجّْ ن ؤُعذِّي ؤُشَا ثمّنْضَارْ-د ثِيذتّْ خْ ثمُّورْثْ ؤُ \add مَارَّا مِينْ\add* إِڭَّا، إِفّغْ \add أَسْ-د\add*.   
\m
\v 13 \add أَوَارْنِي ؤُيَا\add* سْڒِيغْ إِ يِيجّْ ن ؤُمْقدَّاسْ إِسَّاوَاڒْ ؤُ إِنَّا إِجّْ ن ؤُمْقدَّاسْ \add نّغْنِي\add* إِ ونِّي ثُوغَا إِسَّاوَاڒنْ: ”أَڒْ مڒْمِي غَا يِيڒِي ڒوْحِييْ ن ثوْهِيبْثْ ن ڒبْذَا ذ نّْعِي ن ڒْمُوعْصِييّثْ، أَقَا أَذْ ثتّْوَاسلّمْ زَّاوشْثْ إِقدّْسنْ ذ ڒْعسْكَارْ مَاحنْذْ أَذْ تّْوَارفْسنْ؟“   
\m
\v 14 ؤُ نتَّا إِنَّا أَيِي: ”أَڒْ أَڒْفَاينْ ذ ثڒْثْ-مْيَا ن ثْمذِّيثِينْ ذ ثُوفُّوثِينْ، \add خنِّي\add* زَّاوشْثْ إِقدّْسنْ أَذْ ثتّْوَاسّڭّذْ.“   
\b  
\m
\v 15 ؤُشَا إِمْسَارْ، ڒَامِي نشّْ، ذَانِييَالْ، ژْرِيغْ ڒوْحِييْ نِّي ؤُ أَرْزُوغْ أَذْ سّْنغْ ڒْمعْنَا نّسْ، خْزَارْ، أَقَا ذَا إِبدّْ زَّاثِي أَمْ وَادُّوذْ ن إِجّْ ن ورْيَازْ.  
\v 16 ؤُشَا سْڒِيغْ ثْمِيجَّا ن إِجّْ ن بْنَاذمْ جَارْ \add ثمَّاوِينْ ن إِغْزَارْ ن\add* ؤُلَايْ، إِڒَاغَا، إِنَّا: ”\bd جِيبْرِيلْ\bd*، فسَّارْ أَسْ ڒوْحِييْ!“ \x ◘ \xo 8:‏16 \xt دَان. 9‏:‏21؛ لك. 1‏:‏26\x*  
\v 17 ؤُشَا يُوسَا-د غَارْ ؤُغزْذِيسْ إِنُو مَانِي ثُوغَا تّْبذِّيغْ ؤُ ڒَامِي د-يُوسَا، نّْخڒْعغْ ؤُ وْضِيغْ خْ ؤُغمْبُوبْ إِنُو. \add خنِّي\add* إِنَّا أَيِي: ”\add أَ\add* مِّيسْ ن بْنَاذمْ، سّنْ أَقَا ڒوْحِييْ \add إِڒقّفْ\add* ڒْوقْثْ ن ؤُنڭَّارْ.“  
\v 18 ڒَامِي ثُوغَا أَكِيذِي إِسَّاوَاڒْ، هْوِيغْ س ؤُغمْبُوبْ إِنُو غَارْ ثمُّورْثْ ذڭْ يِيجّْ ن يِيضصْ يُودْجغْ. \add خنِّي\add* إِحَاذَا أَيِي، إِسّْبدّْ أَيِي \add خْ إِضَارنْ\add*،  
\v 19 إِنَّا: ”خْزَارْ، أَذْ أَشْ سّشْنغْ مِينْ غَا إِمْسَارنْ غَارْ ؤُنڭَّارْ ن \add ڒْوقْثْ-أَ\add* ن وسْخضْ، مَاغَارْ أَنڭَّارْ أَذْ يِيڒِي ذِي ڒْوقْثْ إِتّْوَاڭّنْ.   
\m
\v 20 إِشَارِّي نِّي ثژْرِيذْ، أَقَا غَارسْ ثْنَاينْ ن وَاشَّاونْ. إِنَا ذ إِجدْجِيذنْ ن أَيْثْ ن مَاذَايْ ذ أَيْثْ ن لْفُورْسْ.  
\v 21 أَمْيَانْ نِّي س ؤُشُوَّافْ، نتَّا ذ أَجدْجِيذْ ن يَاوَانْ، \add إِخْسْ أَذْ يِينِي ن لْيُونَانْ\add* ؤُ إِشّْ أَمقّْرَانْ \add إِ إِدْجَانْ\add* جَارْ ثِيطَّاوِينْ نّسْ ذ أَجدْجِيذْ أَمزْوَارُو.  
\v 22 إِشّْ نِّي إِتّْوَارْژْ، خڒْفنْ ث أَربْعَا \add نّغْنِي\add* ذڭْ ومْشَانْ نّسْ، \add مَانْ أَيَا إِخْسْ أَذْ يِينِي\add* زِي ڒْڭنْسْ نّسْ أَذْ كَّارنْثْ أَربْعَا ن ثْڭلْذِيوِينْ، \add مَاشَا\add* وَارْ إِدْجِي س جّْهذْ نّسْ.  
\v 23 ذڭْ ؤُنڭَّارْ ن ثْڭلْذَا نْسنْ، ؤُمِي كمّْڒنْ إِنِّي إِتّْعدَّانْ أَڒْ \add ڒْْقدّْ\add* نْسنْ، أَذْ د-إِكَّارْ إِجّْ ن ؤُجدْجِيذْ س وُوذمْ إِقْسحْ ؤُ س ڒعْقڒْ ن ثحْرَايْمشْثْ.  
\v 24 جّهْذْ نّسْ أَذْ إِمْغَارْ، مَاشَا وَارْ إِدْجِي زِي جّهْذْ \add ن يِيخفْ\add* نّسْ. نتَّا أَذْ يَاردّدْجْ س ؤُثبْهثْ ؤُ مَارَّا مِينْ غَا يڭّْ أَذْ ذَايسْ إِفْڒحْ. نتَّا أَذْ يَاردّدْجْ إِنِّي غَارْ ثدْجَا صُّولْطَا، ؤُڒَا ذ ڒْڭنْسْ ن إِمْقدَّاسنْ.  
\v 25 س ثحْرَايْمشْثْ نّسْ أَذْ أَسْ إِنْجحْ ڒْغشّْ نِّي ذڭْ ؤُفُوسْ نّسْ ؤُ نتَّا أَذْ إِسّمْغَارْ إِخفْ نّسْ ذڭْ وُوڒْ نّسْ ؤُ ذڭْ إِشْثْ ن ثشْثِي أَذْ يَاردّدْجْ أَطَّاسْ ؤُ أَذْ إِغوّغْ خْ ڒْحَاكمْ ن ڒْحُوكَّامْ، \add مَاشَا\add* بْڒَا مَا إِكَّا خَاسْ ؤُفُوسْ ڭُّورْ أَذْ إِتّْوَارْژْ.   
\m
\v 26 ڒوْحِييْ ن ثْمذِّيثِينْ ذ ثفُّوثِينْ إِ خفْ سَّاوَاڒنْ، أَقَا-ت ذ ثِيذتّْ. ؤُ شكْ، شمّعْ ڒوْحِييْ-أَ، مَاغَارْ أَقَا نتَّا أَذْ د-يَاسْ \add أَوَارْنِي إِ\add* وَاطَّاسْ ن وُوسَّانْ.“   
\m
\v 27 نشّْ، ذَانِييَالْ، ثُوغَا ضعْفغْ أَطَّاسْ ؤُ هڒْشغْ شَا ن وُوسَّانْ. \add خنِّي\add* كَّارغْ-د ؤُ ڭِّيغْ \add عَاوذْ\add* ڒْخذْمثْ ن ؤُجدْجِيذْ. نّْخڒْعغْ زِي ڒوْحِييْ-أَ، مَاشَا ؤُڒَا ذ إِجّْ وَارْ يُوشِي.   
\b  
\b  
\m  
\c 9
\s1 سبْعِينْ ن سِيمَانَاثْ  
\m
\v 1 ذڭْ ؤُسڭّْوَاسْ أَمزْوَارُو ن ذَارِييُوسْ، مِّيسْ ن أَحَاشْوِيرُوسْ، ونِّي زڭْ أَيْثْ ن مَاذَايْ، ونِّي إِذوْڒنْ ذ أَجدْجِيذْ خْ ثْڭلْذِيثْ ن إِكَالْذَانِييّنْ، \f ◼ \fr 9:‏1 \ft \+bd ’سِيمَانَاثْ‘\+bd* - نِيغْ ’إِمَالَاسنْ‘.\f*  
\v 2 ذڭْ ؤُسڭّْوَاسْ أَمزْوَارُو ن ثْڭلْذَا نّسْ إِبَانْ-أَيِي-د، إِ نشّْ ذَانِييَالْ، زڭْ إِذْلِيسنْ، بلِّي ڒْقدّْ ن إِسڭّْوُوسَا إِ خْ ثُوغَا إِسِّيوڒْ وَاوَاڒْ ن سِيذِي إِ ؤُنَابِي إِرْمِييَا إِ ؤُكمّڒْ ن \add ڒْوقْثْ ن\add* ڒْخِيرْبَاثْ ن ؤُرْشَالِيمْ، ثُوغَا-ث سبْعِينْ ن إِسڭّْوُوسَا.  
\v 3 نشّْ أَرِّيغْ أَغمْبُوبْ إِنُو غَارْ سِيذِي أَربِّي، حِيمَا أَذْ خَاسْ أَرْزُوغْ س ثْژَادْجِيثْ ذ ؤُزَاوڭْ، س ؤُژُومِّي ذڭْ ثْخَانْشثْ ن وشْضَانْ ذ يِيغّضْ.  
\v 4 نشّْ ژُّودْجغْ إِ سِيذِي، أَربِّي إِنُو، ؤُ نعْمغْ \add خْ دّْنُوبْ نّغْ\add*، نِّيغْ  
\b  
\m ”أَ سِيذِي إِنُو، شكْ ذ أَربِّي أَمقّْرَانْ ذ إِسِّيڭّْوِيذنْ، ونِّي إِحطَّانْ ڒْعَاهْذْ نّسْ ذ ثْمخْسِيوْثْ نّسْ إِشوَّارنْ إِ يِينِّي ث إِتّخْسنْ ؤُ إِ يِينِّي إِحطَّانْ ثِيوصَّا نّسْ. \x ◘ \xo 9:‏4 \xt أَعَوذ. 7‏:‏9\x*  
\v 5 نشِّينْ نخْضَا ؤُ نڭَّا ڒْمُوعْصِييّثْ ذ ڒْغَارْ ؤُ نْغوّغْ أَمْ نفّغْ زِي ثِيوصَّا ذ لْفَارَايِيضْ نّشْ. \x ◘ \xo 9:‏5 \xt إِزهد. 106‏:‏6؛ إِشا. 64‏:‏4‏-‏6\x*  
\v 6 وَارْ نسْڒِي إِ إِمْسخَّارنْ نّشْ، إِنَابِييّنْ، إِنِّي ثُوغَا إِسَّاوَاڒنْ ذڭْ يِيسمْ نّشْ إِ إِجدْجِيذنْ نّغْ ذ ڒْحُوكَّامْ نّغْ ذ ڒجْذُوذْ نّغْ ؤُڒَا إِ مَارَّا  ڒْڭنْسْ ن ثمُّورْثْ.   
\m
\v 7 شكْ، \add أَ\add* سِيذِي إِنُو، غَاركْ ثَاسڭْذَا، مَاشَا نشِّينْ غَارْنغْ ڒحْيَا ذڭْ ؤُغمْبُوبْ، أَمْ \add مَامّشْ ثدْجَا\add* أَسّْ-أَ، غَارْ إِرْيَازنْ ن يَاهُوذَا ذ إِمزْذَاغْ ن ؤُرْشَالِيمْ ذ مَارَّا إِسْرَائِيل، \add غَارْ\add* يِينِّي يُوذْسنْ ذ يِينِّي إِڭّْوجنْ ذِي مَارَّا ثِيمُّورَا مَانِي خَاسنْ ثُوژّْڒذْ شكْ ذِي سِّيبّثْ ن ڒغْذَارْ نْسنْ إِ زِي شكْ غْضَارنْ.  
\v 8 \add أَ\add* سِيذِي، ذَايْنغْ ڒحْيَا \add ذڭْ\add* ؤُغمْبُوبْ \add نّغْ\add*، أَقَا-ث ذڭْ إِجدْجِيذنْ نّغْ ذِي ڒْحُوكَّامْ نّغْ ذڭْ إِبَابَاثنْ نّغْ مَاغَارْ نشِّينْ نخْضَا أَكِيذكْ.   
\m
\v 9 غَارْ سِيذِي إِنُو، أَربِّي نّغْ، أَرّحْمثْ ذ وغْفَارْ، وَاخَّا نشِّينْ نْغوّغْ خَاسْ. \x ◘ \xo 9:‏9 \xt إِزهد. 130‏:‏3، 7؛ إِڭجذ. 3‏:‏22\x*  
\v 10 وَارْ نسْڒِي إِ ثْمِيجَّا ن سِيذِي، أَربِّي نّغْ، مَاحنْذْ أَذْ نُويُورْ ذِي لْقَاوَانِينْ نّسْ نِّي إِ ذ أَنغْ إِوْشَا س ؤُفُوسْ ن إِمْسخَّارنْ نّسْ، إِنَابِييّنْ.  
\v 11 مَارَّا إِسْرَائِيل ثُوغَا إِتّْعدَّا خْ شَّارِيعَا نّشْ ؤُ إِتّفّغْ \add زڭْ وبْرِيذْ\add* مَاحنْذْ وَارْ إِتّسْڒِي إِ ثْمِيجَّا نّشْ. ؤُ \add أَمُّو إِ\add* خَانغْ ثتّْوَازدْجعْ نّعْڒثْ إِ إِتّْوَاضمْننْ س ثْجَادْجِيثْ إِ إِتّْوَارِينْ ذِي شَّارِيعَا ن مُوسَا، أَمْسخَّارْ ن أَربِّي، مِينْزِي نشِّينْ نخْضَا أَكِيذسْ. \x ◘ \xo 9:‏11 \xt لَاوِي 26‏:‏14‏-‏45؛ أَعَوذ. 27‏:‏15‏-‏26؛ 28‏:‏15‏-‏68؛ 29‏:‏20؛ 30‏:‏17‏-‏20؛ 31‏:‏17، 18؛ 32‏:‏19‏-‏25؛ إِڭجذ. 2‏:‏17\x*  
\v 12 نتَّا إِڭَّا أَوَاڒنْ نّسْ تّْبدَّانْ، \add أَوَاڒنْ\add* نِّي إِسِّيوڒْ أَكِيذْنغْ ؤُ أَكْ-ذ ڒْقُوضَاثْ نّغْ نِّي ثُوغَا إِ خَانغْ إِحكّْمنْ، أَمْ ذَايْنغْ إِڭَّا إِجّْ ن ڒْغَارْ ذ أَمقّْرَانْ إِ وَارْ إِمْسَارنْعمَّارْصْ سَاذُو ؤُجنَّا، أَمْ مَامّشْ إِ إِتّْوَاڭّْ إِ ؤُرْشَالِيمْ.  
\v 13 أَمْ مَامّشْ ثُورَا ذِي شَّارِيعَا ن مُوسَا، أَمُّو يُوسَا-د خَانغْ مَارَّا ڒْغَارْ نِّي. ؤُ نشِّينْ \add خنِّي\add* وَارْ نْزَاوڭْ شَا زَّاثْ إِ وُوذمْ ن سِيذِي، أَربِّي نّغْ، مَاحنْذْ أَذْ نْحيّذْ خْ ڒْمُوعْصِييّثْ نّغْ ؤُ مَاحنْذْ أَذْ نَارْزُو أَذْ نفْهمْ ثِيذتّْ نّشْ.  
\v 14 سِيذِي إِحْضَا ڒْغَارْ ؤُشَا إِسَّارْسْ إِ-ث-إِ-د خَانغْ، مَاغَارْ سِيذِي، أَربِّي نّغْ ذ أَمْسڭّذْ ذِي مَارَّا ڒفْعَايڒْ نّسْ نِّي إِڭَّا ؤُمِي وَارْ نسْڒِي غَارْ ثْمِيجَّا نّسْ.   
\m
\v 15 ؤُ ڒخُّو، \add أَ\add* سِيذِي، أَربِّي نّغْ، ونِّي إِسُّوفّْغنْ ڒْڭنْسْ نّشْ زِي ثمُّورْثْ ن مِيصْرَا س يِيجّْ ن ؤُفُوسْ إِجهْذنْ ؤُ ونِّي إِڭِّينْ إِ يِيخفْ نّسْ إِجّْ ن يِيسمْ، أَمْ مَامّشْ إِدْجَا أَڒْ أَسّْ-أَ. نشِّينْ نخْضَا ؤُ نڭَّا ڒْغَارْ. \x ◘ \xo 9:‏15 \xt ؤُف. 32‏:‏11؛ إِزهد. 105‏:‏7؛ 106‏:‏47\x*  
\v 16 \add أَ\add* سِيذِي إِنُو، زِي سِّيبّثْ ن ثْسڭْذَا نّشْ، سْحيّذْ أَغْضَابْ نّشْ ذ وسْعَارْ نّشْ خْ ثنْذِينْثْ نّشْ ؤُرْشَالِيمْ، \add خْ\add* وذْرَارْ نّشْ إِقدّْسنْ. مَاغَارْ زِي سِّيبّثْ ن دّْنُوبْ نّغْ ذ ڒْمُوعْصِييّثْ ن ڒجْذُوذْ نّغْ ثذْوڒْ  ؤُرْشَالِيمْ ذ ڒْڭنْسْ نّشْ ذ ڒْعَارْ إِ مَارَّا إِنِّي ذ أَنغْ د-إِنّْضنْ.  
\v 17 ؤُ ڒخُّو، \add أَ\add* أَربِّي نّغْ، سڒْ غَارْ ثْژَادْجِيثْ ن ؤُمْسخَّارْ نّشْ ؤُ غَارْ ؤُزَاوڭْ نّسْ، أجّْ ؤُذمْ نّشْ أَذْ يڭّْ ثَافَاوْثْ ذِي طّْوعْ نّشْ، \add أَ\add* سِيذِي إِنُو، خْ زَّاوشْثْ نّشْ إِقدّْسنْ، ثنِّي إِذوْڒنْ ذ ڒْخَارْبثْ. \x ◘ \xo 9:‏17 \xt ڒخْڒ. 6‏:‏23‏-‏27\x*  
\v 18 أوْشْ أَمزُّوغْ نّشْ، \add أَ\add* أَربِّي، سڒْ. أَرْزمْ ثِيطَّاوِينْ نّشْ ؤُ خْزَارْ ڒْخِيرْبَاثْ ذ ثنْذِينْثْ نِّي إِتّْوَاڒَاغَانْ س يِيسمْ نّشْ، مِينْزِي نشِّينْ وَارْ نوْضِي زَّاثْ إِ وُوذمْ نّشْ مَاحنْذْ أَذْ نْزَاوڭْ خْ ؤُسْذَاهدْجِي ن ثْسڭْذَا نّغْ، مَاشَا خْ ؤُسْذَاهدْجِي ن أَرَّاحْمثْ نّشْ ثَامقّْرَانْثْ.  
\v 19 \add أَ\add* سِيذِي إِنُو، سڒْ! \add أَ\add* سِيذِي إِنُو، غْفَارْ! \add أَ\add* سِيذِي إِنُو، حْضَا ؤُشَا أڭّْ، وَارْ ثْعطَّاڒْ شَا، ذِي طّْوعْ ن يِيخفْ نّشْ، \add أَ\add* أَربِّي إِنُو، مَاغَارْ ثَانْذِينْثْ نّشْ ذ ڒْڭنْسْ نّشْ تّْوَاڒَاغَانْ س يِيسمْ نّشْ.“   
\b  
\m
\v 20 أَمْ ثُوغَا سَّاوَاڒغْ عَاذْ ؤُ تّْژَادْجِيغْ ؤُ نعّْمغْ س دّْنُوبْ إِنُو ذ دّْنُوبْ ن ڒْڭنْسْ إِنُو إِسْرَائِيل ؤُ تّْزدْجْعغْ أَزَاوڭْ إِنُو زَّاثْ إِ وُوذمْ ن سِيذِي، أَربِّي إِنُو، ذِي طّْوعْ ن وذْرَارْ إِقدّْسنْ ن أَربِّي إِنُو،  
\v 21 أَمْ ثُوغَا سَّاوَاڒغْ عَاذْ \add أَمُّو\add*، تّْژَادْجِيغْ، يُوسَا-د \bd ورْيَازْ جِيبْرِيلْ\bd* نِّي ژْرِيغْ ذڭْ ؤُمزْوَارُو ذِي ڒوْحِييْ، إِضْوَا-د زڭْ ؤُجنَّا غَارِي. إِحَاذَا أَيِي غَارْ ڒْوقْثْ ن ثوْهِيبْثْ ن ثْمذِّيثْ. \f ◼ \fr 9:‏21 \ft \+bd ’جِيبْرَايِيلْ‘\+bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’أَرْيَازْ إِجْهذْ ن أَربِّي‘.\f*  \x ◘ \xo 9:‏21 \xt ڒخْڒ. 28‏:‏1‏-‏8. \x*  
\v 22 نتَّا إِسّفْهمْ ؤُ إِسِّيوڒْ أَكِيذِي، إِنَّا:  
\m ”ذَانِييَالْ، نشّْ فّْغغْ-د غَارْ ڒْوقْثْ-أَ مَاحنْذْ أَذْ شكْ سَّارْڭْبغْ خْ ڒْمعْنَا.  
\v 23 غَارْ ؤُمزْوَارُو ن ؤُزَاوڭْ نّشْ إِفّغْ-د يِيجّْ ن وَاوَاڒْ ؤُ نشّْ ؤُسِيغْ-د حِيمَا أَذْ أَشْ ث نِّيغْ، مَاغَارْ شكْ ذ إِجّْ \add ن ورْيَازْ\add* إِعِيزّنْ أَطَّاسْ. فْهمْ أَوَاڒْ-أَ ؤُ أَرْزُو ڒفْهَامثْ ذِي ڒوْحِييْ-أَ.  
\v 24 تّْوَاڭّنْثْ سبْعِينْ ن سِّيمَانَاثْ خْ ڒْڭنْسْ نّشْ ؤُ خْ ثنْذِينْثْ نّشْ إِقدّْسنْ، حِيمَا أَذْ إِتّْوَاسّْبدّْ ؤُعدُّو ؤُ أَذْ إِتّْوَاشمّعْ دّنْبْ ؤُ أَذْ ثتّْوَاصْڒحْ إِ ڒْمُوعْصِييّثْ ؤُ حِيمَا أَذْ ثتّْوَاوِي ثْسڭْذَا ؤُ حِيمَا أَذْ إِتّْوَاكمّڒْ ڒوْحِييْ ذ ؤُنَابِيمْ ؤُ حِيمَا أَذْ إِتّْوَاذْهنْ مِينْ إِدْجَانْ إِقدّْسنْ قَاعْ. \x ◘ \xo 9:‏24 \xt أَمز. 47‏:‏28\x*  
\v 25 سّنْ ؤُ فْهمْ، أَقَا زڭْ وَامِي د-إِفّغْ وَاوَاڒْ حِيمَا أَذْعذْڒنْ ؤُ أَذْ بْنَانْ ؤُرْشَالِيمْ أَڒْ أَمذْهُونْ، \add مِينْ إِخْسْ أَذْ يِينِي لْمَاسِيحْ\add*، ڒْحَاكمْ، أَقَا سبْعَا ن سِّيمَانَاثْ، ؤُ ثْنَاينْ ؤُ-ستِّينْ ن سِيمَانَاثْ أَذْ ثقِّيمْ \add ثنْذِينْثْ\add* ثثْوَاعذڒْ ؤُ أَذْ ثتّْوَابْنَا \add ؤُرْشَالِيمْ\add* عَاوذْ أَكْ-ذ وَازَّايْ ذ وُورغْ إِقُّورنْ، \add عَاذْ ذِي\add* ڒحْصَارثْ ن ڒوْقَاثْ \add يوْعَارنْ\add*.   
\m
\v 26 أَوَارْنِي ثْنَاينْ ؤُ-ستِّينْ ن سِّيمَانَاثْ نِّي أَذْ إِتّْوَاكّسْ ؤُمذْهُونْ ؤُ وَارْ غَارسْ إِتِّيڒِي وَالُو. ؤُ ثَانْذِينْثْ ذ زَّاوشْثْ إِقدّْسنْ أَذْ تّْوَاردّْدْجنْثْ س يِيجّْ نْ ڒْڭنْسْ ن إِجّْ نْ ڒْحَاكمْ ونِّي إِ د غَا يَاسنْ ؤُ ثَانڭَّارُوثْ نّسْ أَذْ ثِيڒِي ذِي سّحْڒثْ ؤُشَا أَذْ ذِينْ يِيڒِي ؤُمنْغِي أَڒْ أَنڭَّارْ، أَردّدْجْ نِّي أَقَا يُورَا أَذْ يِيڒِي.  
\v 27 نتَّا أَذْ إِسّذْقڒْ ڒْعَاهْذْ إِ وَاطَّاسْ إِ يِيجّْ ن ڒْمِيجَاڒْ نْ إِشْثْ ن سِّيمَانَا ؤُ ذڭْ وزْينْ ن سِّيمَانَا أَذْ إِسّْبدّْ ثَاغَارْصْثْ ذ ثوْهِيبْثْ ن ڒْغِيدْجثْ ؤُ خْ وَافْرِيوْ ن نّْعَاوَاثْ أَذْ د-يَاسْ إِجّْ ن ؤُمْثحَّايْ أَڒْ غَا إِتّْوَافَارّغْ ڒحْكَامْ إِ يُورِينْ خْ ونِّي إِتّْوَاثحَّانْ. \f ◼ \fr 9:‏27 \ft \+bd ’سِّيمَانَا‘\+bd* - نِيغْ ’إِمَالَاسّْ‘.\f*  \x ◘ \xo 9:‏27 \xt مت. 24‏:‏15؛ مك. 13‏:‏14؛ لك. 21‏:‏20\x*   
\b  
\b  
\m  
\c 10
\s1 ڒْقِيمڒْ ن ڒْڭنْسْ ن ذَانِييَالْ  
\m
\v 1 ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثْڒَاثَا ن كُورَاشْ، أَجدْجِيذْ ن لْفُورْسْ، إِتّْوَاسَّارْڭبْ إِجّْ ن وَاوَاڒْ إِ ذَانِييَالْ، ونِّي ؤُمِي قَّارنْ بَالْطَاشَاصَّارْ، ؤُ أَوَاڒْ نِّي ثُوغَا ذ ثِيذتّْ، \add إِسِّيوڒْ\add* خْ يِيجّْ ن ؤُمنْغِي أَمقّْرَانْ. نتَّا إِفْهمْ أَوَاڒْ نِّي ؤُ ثُوغَا ذَايسْ ڒفْهَامثْ ن ڒوْحِييْ.   
\m
\v 2 ذڭْ وُوسَّانْ نِّي ثُوغَا أَيِي، ذَانِييَالْ، شضْنغْ ثْڒَاثَا ن سِّيمَانَاثْ أَسّْ أَوَارْنِي ؤُمَاسْ. \f ◼ \fr 10:‏2 \ft \+bd ’سِّيمَانَاثْ‘\+bd* - نِيغْ ’إِمَالَاسّنْ‘.\f*  
\v 3 مَاشَّا إِ ذ أَيِي إِتّْڒِيقَانْ، وَارْ ث شِّيغْ، أَيْسُومْ ذ بِينُو وَارْ د-ؤُسِينْ ذڭْ ؤُقمُّومْ إِنُو. وَارْ ذْهِينغْ إِخفْ إِنُو أَڒَامِي عْذُونْثْ ثْڒَاثَا ن سِّيمَانَاثْ كمّْڒنْثْ.  
\v 4 ذڭْ وَاسّْ وِيسّْ أَربْعَا ؤُ-عِيشْرِينْ ن ؤُيُورْ أَمزْوَارُو، ثُوغَا بدّغْ غَارْ ثْمَا ن إِغْزَارْ أَمقّْرَانْ ونِّي \add ؤُمِي قَّارنْ\add* ذَاجْلَا. \x ◘ \xo 10:‏4 \xt أَمز. 2‏:‏14\x*  
\v 5 نشّْ سّْڭَّاعْذغْ ثَامُوغْڒِي إِنُو ؤُشَا ژْرِيغْ، ؤُ خْزَارْ، ثُوغَا ذِينْ إِجّْ ن ورْيَازْ يَارْضْ ڒقْطنْ أَزْذَاذْ ؤُ غَارْ ثجْعِينَّا نّسْ إِبْيسْ نتَّا س وُورغْ إِغْڒَانْ قَاعْ زِي ؤُفَازْ. \x ◘ \xo 10:‏5 \xt أَسَا. 1‏:‏13، 14، 15\x*  
\v 6 أَرِّيمثْ نّسْ \add ثُوغَا\add* أَمْ \add وژْرُو ن\add* ثخْرِيسُولِيثْ ؤُ ؤُذمْ نّسْ \add يَارقّْ\add* أَمْ وَاسَّامنْ ؤُ ثِيطَّاوِينْ نّسْ \add ثُوغَا\add* أَمْ يِيصفْضَاونْ يَارقّنْ ؤُ إِغَادْجنْ ذ إِضَارنْ نّسْ تّْوسّْڭنْ أَمْ نّْحَاسْ إِتّْوَاسُّويْذَانْ ؤُ ثْمِيجَّا ن وَاوَاڒنْ نّسْ ثُوغَا-ت أَمْ زّْهِيرْ ن إِجّْ ن ؤُهِيمُورْ \add أَمقّْرَانْ\add*.\x ◘ \xo 10:‏6 \xt أَسَا. 1‏:‏\x*   
\m
\v 7 مْغِيرْ نشّْ، ذَانِييَالْ، ژْرِيغْ ڒوْحِييْ، مَاشَا إِرْيَازنْ نِّي غَارِي إِدْجَانْ، وَارْ ژْرِينْ شَا ڒوْحِييْ، مَاشَا ثوْضَا-د خَاسنْ إِشْثْ ن أَرّهْبثْ ذ ثَامقّْرَانْثْ ؤُشَا أَروْڒنْ نِيثْنِي مَاحنْذْ أَذْ نُّوفَّارنْ. \x ◘ \xo 10:‏7 \xt ڒخ. \x*  
\v 8 نشّْ قِّيمغْ وحّْذِي ؤُ ژْرِيغْ ڒوْحِييْ-أَ أَمقّْرَانْ وَانِيثَا، ؤُ وَارْ ذَايِي إِقِّيمْ جّهْذْ \add عَاذْ\add*. ثِيسِّيقْثْ ن وُوذمْ إِنُو ثذْوڒْ ذ ڒْغشّْ ؤُ وَارْ مْنِيعْغْ جّهْذْ \add عَاذْ\add*. \x ◘ \xo 10:‏8 \xt دَان. 7‏:‏28\x*  
\v 9 نشّْ سْڒِيغْ زّْهِيرْ ن وَاوَاڒنْ نّسْ ؤُ ڒَامِي سْڒِيغْ زّْهِيرْ ن وَاوَاڒنْ نّسْ، وْضِيغْ خْ ؤُغمْبُوبْ إِنُو س يِيجّْ ن يِيضصْ يُودْجغْ ؤُ أَغمْبُوبْ إِنُو ثُوغَا يَارَّا غَارْ ثمُّورْثْ.   
\m
\v 10 ؤُ خْزَارْ، إِجّْ ن ؤُفُوسْ إِحَاذَا أَيِي ؤُ يَارَّا أَيِي تّنْهزّغْ خْ إِفَادّنْ ذ ثْڒقَّا ن إِفَاسّنْ إِنُو.  
\v 11 نتَّا إِنَّا أَيِي: ”ذَانِييَالْ، شكْ ذ أَرْيَازْ إِعِيزّنْ أَطَّاسْ، حْضَا أَوَاڒنْ نِّي إِ ذ أَشْ غَا إِنِيغْ ؤُ كَّارْ، بدّْ ذِينْ، مِينْزِي ڒخُّو تّْوَاسّكّغْ-د نشّْ غَاركْ.“ ڒَامِي أَكِيذِي إِسِّيوڒْ س وَاوَاڒنْ-أَ، كَّارغْ-د نشّْ أَمْ تَّارْجِيجغْ.  
\v 12 \add خنِّي\add* إِنَّا أَيِي: ”وَارْ تّڭّْوذْ شَا، \add أَ\add* ذَانِييَالْ، مِينْزِي زڭْ وَاسّْ أَمزْوَارُو إِ ذِي ثَارِّيذْ ؤُڒْ نّشْ غَارْ ثِيغِيثْ ؤُ مَاحنْذْ أَذْ ثسّْوَاضْعذْ إِخفْ نّشْ زَّاثْ إِ وُوذمْ ن أَربِّي، أَقَا تّْوَاسْڒنْ وَاوَاڒنْ نّشْ ؤُشَا ؤُسِيغْ-د ذِي طّْوعْ ن وَاوَاڒنْ نّشْ.  
\v 13 مَاشَا ڒْحَاكمْ ن ثْڭلْذِيثْ ن لْفُورْسْ ثُوغَا إِكَّارْ ضِيدّْ إِنُو وَاحْذْ ؤُ-عِيشْرِينْ ن وُوسَّانْ. ؤُ خْزَارْ، مِيخَايِيلْ، إِجّنْ زڭْ إِمزْوُورَا نْ ڒْحُوكَّامْ، يُوسَا-د حِيمَا أَذْ أَيِي إِوْشْ أَفُوسْ ؤُ نشّْ قِّيمغْ تّطّْفغْ صُّولْطَا ذِينِّي خْ إِجدْجِيذنْ ن لْفُورْسْ.  
\v 14 ڒخُّو ؤُسِيغْ-د نشّْ، حِيمَا أَذْ شكْ سّْفهْمغْ مِينْ غَا إِمْسَارنْ إِ ڒْڭنْسْ نّشْ ذڭْ ؤُنڭَّارْ ن وُوسَّانْ، مِينْزِي ڒوْحِييْ \add أَقَا-ث\add* إِ وُوسَّانْ \add نِّي\add*.“   
\m
\v 15 ڒَامِي ثُوغَا أَكِيذِي إِسَّاوَاڒْ س وَاوَاڒنْ-أَ، ؤُضَارغْ س ؤُغمْبُوبْ إِنُو غَارْ ثمُّورْثْ، سّغْذغْ.  
\v 16 ؤُ خْزَارْ، إِجّنْ ذِي صِّيفثْ ن ثَارْوَا ن بْنَاذمْ إِحَاذَا إِينْشِيشنْ إِنُو. \add خنِّي\add* أَرْزْمغْ أَقمُّومْ ؤُشَا سِّيوْڒغْ، نِّيغْ إِ ونِّي إِبدّنْ زَّاثِي: ”\add أَ\add* سِيذِي إِنُو، ؤُمِي ژْرِيغْ ڒوْحِييْ، إِطّفْ أَيِي أَمْ ڒوْجعْ ن ثَارُوثْ، أَمْ وَارْ مْنِيعغْ جّهْذْ \add عَاذْ\add*. \x ◘ \xo 10:‏16 \xt إِشا.6‏:‏5‏-‏7؛ إِرْم. 1‏:‏6‏-‏10\x*  
\v 17 مَامّشْ إِ غَا إِزمَّارْ ؤُمْسخَّارْ ن سِيذِي إِنُو أَذْ أَكِيذكْ إِسِّيوڒْ، \add أَ\add* سِيذِي؟ أَقَا نشّْ، وَارْ ذَايِي إِقِّيمْ جّهْذْ نِيغْ ثْوَارِّيثْ ن نّفْسْ \add عَاذْ\add*.   
\m
\v 18 \add خنِّي\add* إِحَاذَا أَيِي عَاوذْ. نتَّا يَارْوسْ ذڭْ يِيجّْ ن بْنَاذمْ ؤُ إِڭَّا ذَايِي جّهْذْ.  
\v 19 نتَّا إِنَّا: ”وَارْ تّڭّْوذْ شَا، شكْ، \add أَ\add* أَرْيَازْ إِعِيزّنْ! أَذْ غَاركْ يِيڒِي ڒهْنَا، أڭّْ ثَارْيَاسْثْ، \add وَاهْ،\add* أڭّْ ثَارْيَاسْثْ!“ ؤُمِي نتَّا أَكِيذِي إِسِّيوڒْ \add أَمُّو\add*، إِذْوڒْ-د غَارِي جّهْذْ عَاوذْ ؤُ نِّيغْ: ”سِيوڒْ، \add أَ\add* سِيذِي إِنُو، شكْ ثڭِّيذْ ذَايِي جّهْذْ.“   
\m
\v 20 \add خنِّي\add* إِنَّا: ”ثسّْنذْ شكْ، مَايمِّي إِ غَاركْ د-ؤُسِيغْ؟ ڒخُّو أَذْعقْبغْ حِيمَا أَذْ منْغغْ أَكْ-ذ ڒْحَاكمْ ن لْفُورْسْ ؤُ خْمِي غَا فّْغغْ \add إِ ؤُمنْغِي\add*، خنِّي أَذْ د-يَاسْ ڒْحَاكمْ ن لْيُونَانْ.  
\v 21 مَاشَا أَذْ شكْ سّشْنغْ مِينْ يُورِينْ ذڭْ وذْلِيسْ ن ثِيذتّْ، وَاخَّا وَارْ ذِينْ ؤُڒَا ذ إِجّنْ إِ خَاسنْ ذ إِبدّنْ أَكِيذِي، مْغِيرْ ڒْحَاكمْ نْومْ، مِيخَايِيلْ.“   
\b  
\b  
\m  
\c 11
\m
\v 1 ”ذڭْ ؤُسڭّْوَاسْ أَمزْوَارُو ن ذَارِييُوسْ، أَمَاذَايْ، بدّغْ نشّْ أَكِيذسْ مَاحنْذْ أَذْ ث سّجهْذغْ ؤُ أَذْ أَسْ سّنْذغْ.   
\m
\v 2 ڒخُّو أَذْ أَشْ إِنِيغْ إِجّْ ن وَاوَاڒْ ذ ثِيذتّْ! خْزَارْ، أَذْ كَّارنْ عَاذْ ثْڒَاثَا ن إِجدْجِيذنْ ذِي لْفُورْسْ ؤُشَا ونِّي وِيسّْ أَربْعَا أَذْ إِڭّْ أَڭْڒَا أَمقّْرَانْ إِ يِيخفْ نّسْ، كْثَارْ خْ مَارَّا \add إِنّغْنِي\add*. ؤُ أَوَارْنِي خْمِي غَا إِطّفْ ثِيزمَّارْ س وَاڭْڒَا نّسْ، أَذْ إِسّْنكَّارْ مَارَّا \add مِيدّنْ نّسْ\add* ضِيدّْ إِ ثْڭلْذِيثْ ن يَاوَانْ. \f ◼ \fr 11:‏2 \ft \+bd ’ضِيدّْ‘\+bd* - نِيغْ ’مْڭَالْ‘.\f*   
\m
\v 3 \add خنِّي\add* أَذْ إِكَّارْ إِجّْ ن ؤُجدْجِيذْ إِجْهذْ ونِّي إِ غَا إِصلّْطنْ س صُّولْطَا ثَامقّْرَانْثْ ؤُ نتَّا أَذْ إِڭّْ مِينْ إِخْسْ نتَّا.  
\v 4 خْمِي غَا إِكَّارْ، ڒخْذنِّي أَذْ ثَارژْ ثْڭلْذِيثْ نّسْ، أَذْ ثتّْوَامْصبْضَا خْ أَربْعَا ن ثْغمُّورَا ن ؤُسمِّيضْ ن ؤُجنَّا، مَاشَا وَارْ ثتِّيڒِي \add ثْڭلْذِيثْ\add* إِ ثَارْوَا نّسْ ؤُ وَارْ \add غَارسْ\add* ثتِّيڒِي صُّولْطَا أَمْ ثنِّي إِ زِي ثُوغَا إِتّْصلّضْ نتَّا، مَاغَارْ ثَاڭلْذِيثْ أَذْ ثتّْوَاقْڒعْ ؤُ \add أَذْ ثِيڒِي\add* إِ إِنّغْنِي وَارْ إِدْجِي إِ يِينَا.   
\m
\v 5 \add خنِّي\add* أَجدْجِيذْ ن لْجَانُوبْ أَذْ إِذْوڒْ إِجْهذْ، \add مَاشَا\add* إِجّْ زِي ڒْحُوكَّامْ نّسْ أَذْ إِذْوڒْ إِجْهذْ خَاسْ ؤُ وَانِيثَا أَذْ إِصلّطْ س صُّولْطَا ثَامقّْرَانْثْ خْ صُّولْطَا نّسْ.  
\v 6 أَوَارْنِي ڒَامِي عْذُونْ شَا ن إِسڭّْوُوسَا، نِيثْنِي أَذْ ڭّنْ إِجّْ ن ڒْعَاهْذْ ؤُ يدْجِيسْ ن ؤُجدْجِيذْ ن لْجَانُوبْ أَذْ د-ثَاسْ غَارْ ؤُجدْجِيذْ ن شَّامَالْ مَاحنْذْ أَذْ ت ثْسڭّمْ، \add مَاشَا\add* نتَّاثْ وَارْ ثْزمَّارْ أَذْ ثحْضَا جّهْذْ ن ؤُغِيڒْ نّسْ ؤُ نتَّا وَارْ إِزمَّارْ أَذْ إِقِّيمْ إِبدّْ، ؤُ أَغِيڒْ نّسْ أَمْ نّغْنِي. نتَّاثْ أَذْ ثتّْوَاسلّمْ ؤُڒَا ذ يِينِّي ت إِوْينْ ذ ونِّي إِ-ت-إِ-د يُورْونْ ذ ونِّي ت إِسّْجهْذنْ ذڭْ وُوسَّانْ نِّي.   
\m
\v 7 مَاشَا زڭْ إِشْثْ ن ثْغدُّوثْ ن إِژوْرَانْ نّسْ أَذْ إِكَّارْ \add إِجّنْ\add* ذڭْ ومْشَانْ نّسْ. نتَّا أَذْ إِفّغْ ضِيدّْ إِ ڒْعسْكَارْ ؤُشَا أَذْ يَاذفْ لْبُورْجْ إِجهْذنْ ن ؤُجدْجِيذْ ن شَّامَالْ ؤُ أَذْ ذَايْسنْ إِڭّْ \add مِينْ إِخْسْ\add* ؤُ أَذْ د-إِبَانْ إِجْهذْ قَاعْ.  
\v 8 أَربِّيثنْ نْسنْ أَكْ-ذ ڒخْيَاڒَاثْ نْسنْ إِفسْينْ ذ ڒقْشُوعْ نْسنْ إِغْڒَانْ إِ إِتّْوَاڭّنْ س نُّوقَارْثْ ذ وُورغْ أَذْ ثنْ يَاوِي ذ ثْكشَّاضْثْ غَارْ مِيصْرَا ؤُ \add خنِّي\add* أَذْ إِبعّذْ شَا ن إِسڭّْوُوسَا خْ ؤُجدْجِيذْ ن شَّامَالْ.  
\v 9 ؤُ نتَّا أَذْ يَاذفْ ثَاڭلْذِيثْ ن لْجَانُوبْ ؤُ أَذْ إِعْقبْ غَارْ ثمُّورْثْ نّسْ.   
\m
\v 10 إِحنْجِيرنْ نّسْ أَذْ حزّْمنْ إِ ؤُمنْغِي ؤُ أَذْ سّْمُوننْ إِجّْ ن ؤُبَارُّو ن ڒْعسْكَارْ أَمقّْرَانْ ؤُ نتَّا أَذْ د-يَاسْ ؤُ أَذْ إِعمَّارْ \add ثَامُّورْثْ\add* ؤُ أَذْ خَاسْ إِعْذُو. ؤُ \add أَوَارْنِي ڒَامِي\add* د-إِعْقبْ، أَذْ حزّْمنْ عَاوذْ إِ ؤُمنْغِي \add أَذْ يَاذفْ\add* أَڒْ لْبُورْجْ نّسْ إِجهْذنْ.  
\v 11 ؤُشَا أَذْ إِمُّوزَّارْ ؤُجدْجِيذْ ن لْجَانُوبْ ؤُشَا إِڭُّورْ أَذْ إِفّغْ أَكِيذسْ إِمّْنغْ أَكْ-ذ ؤُجدْجِيذْ ن شَّامَالْ، ونِّي إِ غَا إِسّْمُوننْ إِجّْ ن ؤُبَارُّو أَمقّْرَانْ \add ن ڒْعسْكَارْ\add*، \add مَاشَا\add* أَبَارُّو نِّي أَذْ إِتّْوَاسلّمْ ذڭْ ؤُفُوسْ نّسْ.   
\m
\v 12 مَاڒَا إِمّكْسِي ؤُبَارُّو نِّي، \add خنِّي\add* ؤُڒْ نّسْ أَذْ إِسّْڭعّذْ إِخفْ نّسْ ؤُ نتَّا أَذْ إِسّغْذڒْعشْرَا ن ڒُوڒُوفْ، \add مَاشَا\add* نتَّا وَارْ إِتّْمَارْنِي ذِي جّهْذْ.  
\v 13 أَجدْجِيذْ ن شَّامَالْ أَذْ د-إِذْوڒْ ؤُ أَذْ إِسّْمُونْ إِجّْ ن ؤُبَارُّو أَمقّْرَانْ كْثَارْ زڭْ ؤُمزْوَارُو. أَوَارْنِي ڒْمِيجَاڒَاثْ ن ڒْوقْثْ ذ إِسڭّْوُوسَا أَذْ د-يَاسْ س يِيجّْ ن ڒْعسْكَارْ أَمقّْرَانْ ؤُ س وَاطَّاسْ ن ڒسْنَاحْ.  
\v 14 ذڭْ وُوسَّانْ نِّي أَذْغوّْغنْ أَطَّاسْ خْ ؤُجدْجِيذْ ن لْجَانُوبْ ؤُ أَيْثْ ن بُو-ڒخْشُونثْ ن ڒْڭنْسْ نّشْ أَذْ سّْڭعّْذنْ إِخفْ نْسنْ حِيمَا أَذْ سّْقفْڒنْ إِجّْ ن ڒوْحِييْ، مَاشَا نِيثْنِي أَذْ وْضَانْ.  
\v 15 \add خنِّي\add* أَذْ د-يَاسْ ؤُجدْجِيذْ ن شَّامَالْ، أَذْ إِسّْبدّْ إِجّْ نْ ڒْحِيضْ إِ ڒحْصَارثْ ؤُ أَذْ إِطّفْ إِشْثْ ن ثنْذِينْثْ إِفَارْينْ. إِغَادْجنْ ن لْجَانُوبْ \add إِجهْذنْ\add* وَارْ زمَّارنْ أَذْ قِّيمنْ تّْقَاوَامنْ ؤُڒَا ذ ڒْڭنْسْ ن يِينِّي زَّايسْ إِتّْوَافَارْزنْ لَّا. وَارْ ذِينْ إِتِّيڒِي جّهْذْ حِيمَا أَذْ قِّيمنْ تّْبدَّانْ.  
\v 16 ونِّي د-يُوسِينْ ضِيدّْ نّسْ، أَذْ إِڭّْ مِينْ إِخْسْ. ؤُڒَا ذ إِجّْ وَارْ إِزمَّارْ أَذْ إِبدّْ زَّاثْ إِ وُوذمْ نّسْ ؤُ نتَّا أَذْ إِبدّْ ذِي ثمُّورْثْ ن ثلْوِيزْثْ ؤُ أَردّدْجْ أَذْ يِيڒِي س ؤُفُوسْ نّسْ.  
\v 17 نتَّا أَذْ يَارْزُو أَذْ إِسّمْثنْ ثِيزمَّارْ نّسْ ذِي مَارَّا ثَاڭلْذِيثْ نّسْ ؤُ غَارسْ إِمْثَاوِييّنْ إِسڭّْذنْ ؤُ أَذْ \add زَّايْسنْ\add* إِڭّْ. نتَّا أَذْ أَسْ إِوْشْ يدْجِيسْ ن ثمْغَارِينْ حِيمَا أَذْ يَاردّدْجْ \add ثَاڭلْذِيثْ نِّي\add*، مَاشَا نتَّاثْ وَارْ ثتّْبدَّا ؤُ وَارْ ذ أَسْ ثفِّيغْ.   
\m
\v 18 \add خنِّي\add* أَذْ يَارّْ أَغمْبُوبْ نّسْ غَارْ ثڭْزِيرِينْ ؤُشَا أَذْ إِطّفْ أَطَّاسْ \add زَّايْسنْثْ\add*. \add مَاشَا\add* إِجّْ ن ؤُكُومَانْذَارْ ن ڒْعسْكَارْ أَذْ إِسّْبدّْ ڒْحڭْرَا نّسْ خَاسْ، بْڒَا مَا إِزمَّارْ نتَّا أَذْ أَسْ إِخدْجصْ ڒْحڭْرَا نّسْ.  
\v 19 نتَّا أَذْ يَارّْ أَغمْبُوبْ نّسْ غَارْ لْبُورْجَاثْ ن ثمُّورْثْ نّسْ ؤُ \add خنِّي\add* أَذْ إِنْقَارْضْ، أَذْ إِوْضَا ؤُ وَارْ إِتّْوِيفِّي \add عَاذْ\add*.  
\v 20 أَذْ إِكَّارْ \add إِجّنْ\add* ذڭْ ومْشَانْ نّسْ ونِّي إِ غَا إِسّعْذُونْ إِجّنْ خْ ثمُّورْثْ نِّي إِ غَا إِسّهْوَانْ أَعُودْجِي ن ثْڭلْذِيثْ، \add مَاشَا\add* وَانِيثَا أَذْ إِتّْوَارْژْ ذِي شَا ن وُوسَّانْ، وَارْ إِدْجِي س إِمْشُوبّشنْ ؤُڒَا س ؤُمنْغِي.   
\m
\v 21 \add خنِّي\add* أَذْ د-إِكَّارْ إِجّْ ن \add بْنَاذمْ\add* أَحڭَّارْ ذڭْ ومْشَانْ نّسْ ونِّي وَارْ ذ أَسْ تِّيشنْ لْعَاضَامَا إِڭلّْذنْ. نتَّا أَذْ د-يَاسْ س ڒْغفْڒثْ ؤُ أَذْ إِطّفْ ثَاڭلْذِيثْ س ثحْرَايْمشْثْ \add نّسْ\add*.  
\v 22 إِغَادْجنْ \add إِجهْذنْ\add* نِّي إِفيّْضنْ \add ثَامُّورْثْ\add*، أَذْ تّْوَامْحَانْ زَّاثْ إِ وُوذمْ إِنُو ؤُ أَذْ تّْوَارّْژنْ ؤُڒَا ذ ڒْحَاكمْ ن ڒْعَاهْذْ.  
\v 23 ؤُ زڭْ وَامِي إِ غَا ڭّنْ إِجّْ ن ڒْعقْذْ أَكِيذسْ، أَذْ إِڭّْ س ڒْغشّْ. أَذْ إِسّْڭعّذْ ؤُ أَذْ إِذْوڒْ إِزمَّارْ \add خَاسنْ\add* س ذْرُوسْ ن ڒْڭنْسْ \add وَاهَا\add*.  
\v 24 أَذْ يَاذفْ س ڒْغفْڒثْ ذِي جّْوَايهْ إِسّْغمَّاينْ ن لْعَامَالَا ؤُشَا أَذْ إِڭّْ مِينْ وَارْ ڭِّينْ ڒجْذُوذْ نّسْ نِيغْ ڒجْذُوذْ ن ڒجْذُوذْ نّسْ: أَذْ يَاشَارْ ؤُ أَذْ إِكشّضْ ؤُ \add مَارَّا\add* أَڭْڒَاونْ أَذْ ثنْ إِزدْجعْ جَارْ أَسنْ. نتَّا ڭُّورْ أَذْ إِخَارّصْ ذڭْ إِنْوَاينْ ضِيدّْ إِ لْقلْعَاثْ، أَڒْ إِشْثْ نْ ڒْوقْثْ \add إِتّْوَاڭّنْ\add*.   
\m
\v 25 س يِيجّْ ن ڒْعسْكَارْ أَمقّْرَانْ أَذْ يَارّْ جّهْذْ نّسْ ذ وُوڒْ نّسْ ضِيدّْ إِ يِيجّْ ن ؤُجدْجِيذْ ن لْجَانُوبْ ؤُشَا أَجدْجِيذْ ن لْجَانُوبْ أَذْ إِفّغْ غَارْ ؤُمنْغِي س يِيجّْ ن ڒْعسْكَارْ أَمقّْرَانْ إِجْهذْ، مَاشَا وَارْ إِزمَّارْ أَذْ إِبدّْ، مِينْزِي أَذْ خَاسْ ڭّنْ ثِيمعْمَاتْشْ،  
\v 26 ذ يِينِّي إِتّتّنْ زِي مَاشَّا ن ؤُجدْجِيذْ، أَذْ ث أَرْژنْ ؤُ ڒْعسْكَارْ نّسْ أَذْ إِتّْوَامْحَا ؤُ أَطَّاسْ أَذْ تّْوَانْغنْ.  
\v 27 ؤُڒْ ن ثْنَاينْ ن إِجدْجِيذنْ-أَ أَذْ يِيڒِي إِسّڭُّورْ غَارْ ڒْغَارْ ؤُ خْ طَّابْڒَا ذ إِشْثْ أَذْ إِنِينْ إِخَارِّيقنْ، \add مَاشَا\add* مَانْ أَيَا وَارْ إِنفّعْ، مَاغَارْ أَنڭَّارْ \add إِتّْرَاجَا\add* عَاذْ أَڒْ ڒْوقْثْ إِتّْوَاڭّنْ.  
\v 28 س ؤُبَارُّو ن وَاڭْڒَا أَذْ يَارڭّْوحْ غَارْ ثمُّورْثْ نّسْ ؤُ ؤُڒْ نّسْ أَذْ يِيڒِي ضِيدّْ إِ ڒْعَاهْذْ إِقدّْسنْ ؤُ نتَّا أَذْ إِڭّْ \add أَمنِّي\add* ؤُ \add خنِّي\add* أَذْ إِعْقبْ غَارْ ثمُّورْثْ نّسْ.   
\m
\v 29 ذڭْ إِشْثْ ن ڒْوقْثْ إِتّْوَاڭّنْ أَذْ د-إِعْقبْ، أَذْ إِرَاحْ غَارْ لْجَانُوبْ، مَاشَا ثْوَاڒَا-يَا ثَانڭَّارُوثْ وَارْ ثتِّيڒِي أَمْ ثْوَاڒَا ثَامزْوَارُوثْ.  
\v 30 مَاغَارْ إِغَارُّوبَا ن كِيتِّيمْ أَذْ غَارسْ د-أَسنْ ؤُ نتَّا أَذْ إِتّْوَاسِّيڭّْوذْ، أَذْ إِعْقبْ ؤُ \add خنِّي\add* أَذْ إِسْخضْ خْ ڒْعَاهْذْ إِقدّْسنْ ؤُ أَذْ إِڭّْ \add أَمنِّي\add*. خْمِي د غَا إِعْقبْ أَذْ إِمّْسفْهمْ أَكْ-ذ يِينِّي د-إِفّْغنْ زِي ڒْعَاهْذْ إِقدّْسنْ. \f ◼ \fr 11:‏30 \ft \+bd ’كِيتِّيمْ‘\+bd* - إِخْسْ أَذْ يِينِي ’قُوبْرُوسْ‘.\f*  
\v 31 أَذْ \add قِّيمنْ\add* بدّنْ إِغَادْجنْ \add ن ڒْعسْكَارْ\add* إِ زَّايسْ، إِنِّي إِ غَا إِغصْبنْ زَّاوشْثْ إِقدّْسنْ، لْبُورْجْ، ؤُشَا أَذْ كّْسنْ ثَاغَارْصْثْ ن ڒبْذَا ؤُ أَذْ \add ذِينْ\add* سّْبدّنْ نّْعِي ن ؤُخَارّبْ.  
\v 32 إِنِّي ذَايْسنْ نّيّثْ ثَاعفَّانْثْ خْ ڒْعَاهْذْ، أَذْ ثنْ إِسُّوفّغْ \add زڭْ وبْرِيذْ\add* س ثحْرَايْمشْثْ، \add مَاشَا\add* ڒْڭنْسْ، أَقَا إِنِّي إِسّْننْ أَربِّي نْسنْ، ڭُّورْ أَذْ إِڒِينْ جهْذنْ ؤُ أَذْ ڭّنْ.  
\v 33 إِفهَّامنْ ن ڒْڭنْسْ أَذْ سّْفثْننْ أَطَّاسْ، ؤُشَا أَطَّاسْ أَذْ نّْقَارْضنْ س سِّيفْ ذ إِحُوذَاقْ \add ن ثْمسِّي\add* ذ ثْمحْبَاسْثْ ذ ؤُكشّضْ، \add أَطَّاسْ ن\add* وُوسَّانْ.  
\v 34 خْمِي غَا نْقَارْضنْ، أَذْ أَفنْ إِشْثْ ن ثْوِيزَا ثَامژْيَانْثْ ؤُ أَطَّاسْ أَذْ غَارْسنْ د-مُوننْ س ثحْرَايْمشْثْ.  
\v 35 شَا زڭْ إِفهَّامنْ أَذْ نْقَارْضنْ مَاحنْذْ أَذْ تّْوَاصفَّانْ ؤُ أَذْ تّْوَاسِّيزذْڭنْ ؤُ أَذْ تّْوَاصفَّانْ أَڒْ ڒْوقْثْ ن ؤُنڭَّارْ، مَاغَارْ \add أَذْ يِيڒِي\add* أَڒْ ڒْوقْثْ إِتّْوَاڭّنْ.   
\m
\v 36 أَجدْجِيذْ أَذْ إِڭّْ مِينْ إِخْسْ نتَّا ؤُ أَذْ إِسّْڭعّذْ إِخفْ نّسْ ؤُ أَذْ إِسّمْغَارْ إِخفْ نّسْ سنّجْ خْ كُوڒْ أَربِّي ؤُ نتَّا أَذْ يِينِي ڒعْجبْ ن ثْمسْڒَايِينْ ضِيدّْ إِ أَربِّي خْ \add مَارَّا\add* إِربِّيثنْ. نتَّا أَذْ إِفْڒحْ أَڒْ غَا إِتّْوَاكمّڒْ وسْخضْ مَارَّا، مَاغَارْ أَقَا يُورَا ؤُشَا أَذْ يِيڒِي. \x ◘ \xo 11:‏36 \xt دَان. 7‏:‏25\x*  
\v 37 نتَّا وَارْ ڭُّورْ أَذْ ث شْقَانْ إِربِّيثنْ ن ڒجْذُوذْ نّسْ ؤُڒَا ذ ڒغْرِيزثْ ن ثمْغَارِينْ. نتَّا وَارْ ذ أَسْ إِشْقِي ؤُڒَا ذ إِجّْ ن أَربِّي، مَاشَا أَذْ إِسّمْغَارْ إِخفْ نّسْ سنّجْ خْ مَارَّا.  
\v 38 ذڭْ ومْشَانْ نّسْ أَذْ إِوقَّارْ أَربِّي ن لْبُورْجَاثْ. أَذْ إِوقَّارْ أَربِّي نِّي وَارْ سِّيننْ شَا ڒجْذُوذْ نّسْ، س وُورغْ ذ نُّوقَارْثْ ذ يژْرَا إِغْڒَانْ ذ ڒقْشُوعْ إِغْڒَانْ.  
\v 39 نتَّا أَذْ إِڭّْ ضِيدّْ إِ لْقلْعَاثْ س أَربِّي أَغْرِيبْ. ونِّي \add ث\add* غَا إِقبْڒنْ، أَذْ إِكْسِي أَطَّاسْ ن شَّانْ ؤُ أَذْ إِصلّطْ خْ وَاطَّاسْ ؤُ نتَّا أَذْ خَاسنْ إِبْضَا ثَامُّورْثْ ذ ڒْمُونثْ.   
\m
\v 40 ذِي ڒْوقْثْ ن ؤُنڭَّارُو أَذْ أَسْ إِزْذمْ ؤُجدْجِيذْ ن لْجَانُوبْ \add س وَاشَّاونْ نّسْ\add* ؤُ أَجدْجِيذْ ن شَّامَالْ أَذْ خَاسْ إِدُّوقّزْ س إِكَارُّوثنْ ذ إِمْنَاينْ ذ وَاطَّاسْ ن إِغَارُّوبَا ؤُ نتَّا أَذْ يَاذفْ ثِيمُّورَا أَمْ ڒْحمْڒثْ ؤُشَا \add خنِّي\add* أَذْ \add خَاسنْ\add* إِعْذُو.  
\v 41 نتَّا أَذْ يَاذفْ ثَامُّورْثْ ن ثلْوِيزْثْ ؤُ أَطَّاسْ أَذْ نّْقَارْضنْ، مَاشَا إِنَا أَذْ أَروْڒنْ زڭْ ؤُفُوسْ نّسْ: إِذُومْ ذ مُوآبَ ذ ؤُمزْوَارْ ن أَيْثْ ن عَامُّونْ.  
\v 42 نتَّا أَذْ إِسّْوِيژّضْ س ؤُفُوسْ نّسْ غَارْ ثمُّورَا. ؤُڒَا ذ ثَامُّورْثْ ن مِيصْرَا وَارْ ثْنجّمْ.  
\v 43 نتَّا أَذْ إِصلّطْ خْ ثْخُوبَايْ ن وُورغْ ذ نُّوقَارْثْ ذ مَارَّا ڒقْشُوعْ إِغْڒَانْ ن مِيصْرَا. أَيْثْ ن لِيبْيَا ذ أَيْثْ ن كُوشْ أَذْ ثْ ضْفَارنْ ذڭْ إِصُورَافْ نّسْ.   
\m
\v 44 \add مَاشَا\add* ڒخْبُورَاثْ زِي شَّارْقْ ؤُ زِي شَّامَالْ أَذْ ث سّْنخْڒعنْ. \add خنِّي\add* أَذْ إِفّغْ س وسْعَارْ أَمقّْرَانْ حِيمَا أَذْ يَاردّدْجْ أَطَّاسْ ؤُ حِيمَا أَذْ \add ثنْ\add* إِثحَّا.  
\v 45 أَذْ إِوّثْ ثِيخُوزَانْ نّسْ إِڭلّْذنْ جَارْ ڒبْحُورْ ذ وذْرَارْ ن ثلْوِيزْثْ إِقدّْسنْ ؤُ نتَّا أَذْ يَاوضْ غَارْ ؤُنڭَّارْ نّسْ ؤُ وَارْ ذِينْ إِتِّيفْ حذْ أَذْ ث إِعَاونْ.“ \x ◘ \xo 11:‏45 \xt دَان. 8‏:‏25\x*   
\b  
\b  
\m  
\c 12
\m
\v 1 ”ذِي ڒْوقْثْ نِّي أَذْ إِكَّارْ مِيخَايِيلْ، ڒْحَاكمْ أَمقّْرَانْ. ونِّي إِبدّنْ أَكْ-ذ ڒْڭنْسْ نّشْ. أَذْ ثِيڒِي ذ إِشْثْ نْ ڒْوقْثْ ن ڒحْصَارثْ أَمْ وَارْ ثدْجِي زڭْ وَامِي إِدْجَا إِجّْ ن ڒْڭنْسْ أَڒْ ڒْوقْثْ نِّي. ؤُ ذِي ڒْوقْثْ نِّي أَذْ إِتّْوَاسّنْجمْ ڒْڭنْسْ نّشْ، كُوڒْ إِجّنْ إِ غَا إِتّْوَافنْ أَقَا ؤُرِينْ ث ذڭْ وذْلِيسْ. \x ◘ \xo 12:‏1 \xt إِشا. 4‏:‏3\x*  
\v 2 أَطَّاسْ زڭْ يِينِّي إِطّْصنْ ذِي ثْعجَّاجْثْ ن ثمُّورْثْ أَذْ فَاقنْ، إِنَا إِ ثُوذَارْثْ إِتّْذُومَانْ ؤُ إِنّغْنِي \add أَذْ فَاقنْ\add* إِ ؤُبهْذڒْ ؤُ إِ يِيجّْ ن ؤُعِيفِّي إِ ڒبْذَا. \x ◘ \xo 12:‏2 \xt يُوح. 5‏:‏28، 29\x*  
\v 3 إِنِّي غَارْ ثدْجَا ڒفْهَامثْ أَذْ أَرْغنْ أَمْ مَامّشْ يَارقّْ ؤُجنَّا ؤُ إِنِّي ثُوغَا إِندّْهنْ أَطَّاسْ غَارْ ثْسڭْذَا، أَمْ يِيثْرَانْ، إِ ڒبْذَا قَاعْ.\x ◘ \xo 12:‏3 \xt مت. 13‏:‏43\x*  
\v 4 ؤُ شكْ، ذَانِييَالْ، سْنُوفَّارْ أَوَاڒنْ-أَ ؤُ ثْشمّْعذْ أَذْلِيسْ أَڒْ ڒْوقْثْ ن ؤُنڭَّارْ. أَطَّاسْ أَذْ أَرْزُونْ ؤُ ثُوسّْنَا أَذْ ثمْغَارْ.“   
\m
\v 5 ؤُ نشّْ، ذَانِييَالْ، ژْرِيغْ، ؤُ خْزَارْ، أَقَا ذِينْ بدّنْ ثْنَاينْ نّغْنِي، إِجّْ غَارْ ثْمَا-يَا ن إِغْزَارْ ؤُ ونّغْنِي غَارْ ثْمَا نّغْنِي ن إِغْزَارْ.  
\v 6 ؤُ نتَّا إِنَّا إِ ورْيَازْ إِ ثُوغَا يَارْضنْ ڒقْطنْ أَزْذَاذْ، ونِّي \add إِبدّنْ\add* سنّجْ إِ وَامَانْ ن إِغْزَارْ: ”مشْحَاڒْ عَاذْ إِقِّيمنْ أَڒْ أَنڭَّارُو ن ڒعْجَايبْ-أَ؟“ \x ◘ \xo 12:‏6 \xt دَان. 10‏:‏5\x*   
\m
\v 7 ؤُ سْڒِيغْ أَرْيَازْ نِّي ثُوغَا يَارْضنْ ڒقْطنْ أَزْذَاذْ، ونِّي \add إِبدّنْ\add* سنّجْ إِ وَامَانْ ن إِغْزَارْ، ؤُ نتَّا إِسّْڭعّذْ أَفُوسْ نّسْ أَفُوسِي ذ ؤُفُوسْ نّسْ أَزڒْمَاضْ ؤُ إِجُّودْجْ غَارْ ونِّي إِدَّارنْ إِ ڒبْذَا، بلِّي خْمِي إِ غَا إِتّْوَاقْضَا ؤُفَارْثكْ ن ؤُفُوسْ ن ڒْڭنْسْ إِقدّْسنْ أَوَارْنِي يِيجّْ ن ڒْمِيجَاڒْ ن ڒْوقْثْ ذ ڒوْقَاثْ ذ وزْينْ ن يِيجّْ ن ڒْمِيجَاڒْ ن ڒْوقْثْ، أَذْ يِيڒِي ؤُقطُّو ن مَارَّا ثِيمسْڒَايِينْ-أَ. \x ◘ \xo 12:‏7 \xt أَسَا. 10‏:‏5، 6\x*   
\m
\v 8 نشّْ سْڒِيغْ \add ث\add*، مَاشَا وَارْ \add ذ أَسْ\add* فْهِيمغْ ؤُ نِّيغْ: ”\add أَ\add* سِيذِي إِنُو، مِينْ غَا يِيڒِينْ ذ أَنڭَّارُو ن أَيَا؟“   
\m
\v 9 نتَّا إِنَّا: ”ؤُيُورْ، ذَانِييَالْ، مَاغَارْ أَوَاڒنْ-أَ أَذْ قِّيمنْ بلّْعنْ، شمّْعنْ أَڒْ ڒْوقْثْ ن ؤُنڭَّارْ.  
\v 10 أَطَّاسْ إِ غَا إِتّْوَاسِّيزذْڭنْ، أَذْ ذوْڒنْ ذ إِشمْڒَاڒنْ ؤُ أَذْ تّْوَاصفَّانْ، مَاشَا إِعفَّاننْ أَذْ ڭّنْ ثُوعفّْنَا ؤُ مَارَّا إِعفَّاننْ وَارْ \add ذ أَسْ\add* فهّْمنْ، مَاشَا إِمِيغِيسنْ أَذْ فهْمنْ.  
\v 11 زِي ڒْوقْثْ إِ ذِي ثتّْوَاكّسْ ثْغَارْصْثْ ن ڒبْذَا ؤُ إِمَّارْسْ نّْعِي ن ؤُخَارّبْ \add ذڭْ ومْشَانْ نّسْ\add*، \add أَقَا-ث\add* أَڒفْ ؤُ-مِيثَايْنْ ؤُ-ثسْعِينْ ن وُوسَّانْ.  
\v 12 سّعْذْ ن ونِّي إِتّْرَاجَانْ ؤُ أَذْ يَاوضْ أَڒفْ ؤُ-ثڒْثْ-مْيَا ؤُ-خمْسَا ؤُ-ثْڒَاثِينْ ن وُوسَّانْ.   
\m
\v 13 ؤُ شكْ، ؤُيُورْ أَڒْ أَنڭَّارْ. أَذْ ثَاريّْحذْ ؤُ أَذْ ثكَّارذْ مَاحنْذْ \add أَذْ ثكْسِيذْ\add* ثَاقدُّوحْثْ إِ ذ أَشْ \add د-إِكَّارنْ\add* ذڭْ ؤُنڭَّارْ ن وُوسَّانْ.“   