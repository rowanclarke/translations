\p 
\v 1 \w Then|strong="H6965"\w* Ahithophel said \w to|strong="H1732"\w* Absalom, “\w Allow|strong="H4994"\w* \w me|strong="H4994"\w* \w to|strong="H1732"\w* choose 12,000 \w men|strong="H8147"\w*, \w and|strong="H6965"\w* \w I|strong="H6965"\w* \w will|strong="H7291"\w* leave \add with them\add* \w tonight|strong="H3915"\w* \w to|strong="H1732"\w* \w pursue|strong="H7291"\w* \w David|strong="H1732"\w*.
