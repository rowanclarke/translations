\id PSA
\h Psalms
\toc1 Psalms
\toc2 Psalms
\mt1 Psalms
\ip Unknown if consultant checked.
\c 1
\s1 Psalm 1
\q1 
\v 1 Pikaly yiji nyarrarrangu marrngurrangu yakal manakata kurlujartiny jinakatarrangumilaku muwarrku,
\q1 munu manal-manal jarrinyayijanaku kurlujartinyarrangumilingi jinangapa
\q1 munu kulurnayijaninyi palarrangu nyurni manakata Ngarrkaku.
\b
\q1 
\v 2 Pikaly yiji waninyayi kurlkarri manajalu Ngarrkamilaku muwarrku, pinakarrinyayalu ngarrakunyju.
\b
\q1 
\v 3 Miranu nyurra nyarra mungka yintamartaji waninyi,
\q1 ngalypa kakuputu,
\q1 mayi karrinyili ngalypakatapa
\q1 parrka munu tikirl jarrinyakayi.
\q1 Ngalypakata marrngurrangu palajunngarra mungkakapali.
\q1 Jurtulu jinayi nganiwarralpirti, ngalypa jarrulinyjanaku.
\b
\q1 
\v 4 Munu yiji yakujun kurlujartiny jinakatarrangu marrngurrangu;
\q1 jana nyarra ngapikapali, yapinajakapali mayikurnukapali, wangalju kanganyi.
\q1 
\v 5 Ngarrkalu marrjalu wirlalkulinyjaninyi.
\q1 Palinyju jinta pilkulinyjaninyi,
\q1 jana munu wantulupiyijanaku palinymilirrangungu.
\b
\q1 
\v 6 Ngarrkalu tukulu kalkunajaninyi palinymilirrangu jurtungu ruwurtungu.
\q1 Wariny yiji kurlujartiny jinakatarranguku,
\q1 jana yananyayi yijakarti yiji kurluny-kurlunykarti.
\c 9
\p 
\v 17 Kurlujartiny jinakatarrangu marrngurrangu wiyirr marlkarri jarrulupiyi, jana wiyirr yakal manakata Ngarrkaku.
\c 23
\p 
\v 1 Ngarrkalungarra tuku jinanyi; ngajulu kalkunarni nganiwarralpirti wankanyu waninyaku.
\c 32
\s1 Psalm 32
\q1 
\v 1 Jinta marrngu kurlu jiniyi.
\q1 Palaja wurrarnayalu Ngarrkanga, “Kurntany jarrinyarnangu”.
\q1 Puru yakarnajaninyi.
\q1 Palaja pikaly waninyayi ngarramarnti.
\b
\q1 
\v 2 Jinta marrngu kurlu jiniyi.
\q1 Palaja wurrarnayalu Ngarrkanga, “Kurntanyja jarrinyayirni.”
\q1 Munu mitu marnamayi,
\q1 munu warnta marnamajaninyi.
\q1 Kuwarri pikaly waninyiyi kakuputu.
\b
\q1 
\v 3 Purlpi kurlu jinirni,
\q1 munu wurrarnamarnalu Ngarrkanga.
\q1 Palajalu ngangkurl jinikinyirni kara wurrpu.
\q1 Ngangkurlaja manyurla jarrinyirni.
\b
\q1 
\v 4 Karrpurrangu karrpungu, warrukartirrangu warrukarti,
\q1 nyuntulu kararr jinijin, nyampali!
\q1 Manyurla yija-yiji jarrinyirni.
\q1 Yurranga karrpulu yarntalkuliny janpa, punarra jilkuliny.
\q1 Palakapali warnta marninyin, Nyampali,
\q1 palangulu tirtirti pinirni, murrjin jarrinyirni,
\q1 marlkarri jarrimarna.
\b
\q1 
\v 5 Palangulu wurrarnarnangu yija,
\q1 palakapali jinirni, kurlu jinirni.
\q1 Munu kuku jarrrimarnangu nyuntunga,
\q1 kurlka jarrinyirni wurralamarnangu kurlurrangu jinirni. Wurrarnarnangu,
\q1 “Milya kaniny jarrinyarnangu kurntanyjartiny.”
\q1 Palajalu puru ngakarninyin ngalypalu kakuputu.
\b
\q1 
\v 6 Palajalu nyuntumili marrngurrangu,
\q1 palarrangu marrngu miranu nyuntuku,
\q1 wurranaku nyuntungu nganijartiny muwarrjartiny.
\q1 Janalu japirr manaku nyuntu,
\q1 “Ngarrka, ngani jilamarnajanaku nyungurrangu?”
\b
\q1 Palaja jilipiyi, ngalypa yankulupiyi.
\q1 Nganipa kurlu milpulinyjanaku,
\q1 ngapikapali mangkurtu mirti jarrulkuliny marrja pijunga,
\q1 nyuntulu kalkulumanjaninyi tukulu.
\q1 Pala mangkurtu munu kanka jarrulinyjanaku,
\q1 munu kangkulinyjaninyi warnan-warnan.
\b
\q1 
\v 7 Tuku waninyarni nyuntunga.
\q1 Nganingamarrapa tuku kalkuluminyin.
\q1 Purntu marnanyin.
\q1 Palajalu kurntarnarni marrjalu,
\q1 “Ngarrkalu tukulu kalkurninyi!”
\b
\q1 
\v 8-9 Nyampalilu wurrarnaji, “Pinakarraji ngajuku!
\q1 Munu ngakumpa jarrinyaku yawartakapalipa tangkikapali.
\q1 Wirriliman purayitul yirranga.
\q1 Munujalu yankulupiyi warinykurnu.
\q1 Munu ngakumpa jarruluman janakapali.
\q1 Wirrilimarnanga purayitul nyuntunga? Munu yiji!
\q1 Ngajumili muwarrjartinyju miranu jilamarnanta,
\q1 ngani jilaman.
\q1 Nyuntulu yirrkulu pinakarrlupijin ngajuku.
\b
\q1 
\v 10 Kurlujartinyju marrngulu yirrkulu kurlu jinayarninyi.
\q1 Ngarrka yirrkulu karrinyijanaku yajarnayipa punjalu,
\q1 palinyju tukulu kalkulinyjaninyi.
\b
\q1 
\v 11 Nyurra marrngu ngalypa jininyurru,
\q1 parrjalayi Ngarrka ngani jini!
\q1 Pikaly jarrayi, raka jarrayi!
\q1 Nyurra marrngurrangu, nyurralu yajarnakinyinyurra Ngarrka,
\q1 kamalayi pikalyjartinyju. 
