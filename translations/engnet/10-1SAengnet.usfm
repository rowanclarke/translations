\v 11  \w Then|strong="H2009"\w* \w Samuel|strong="H8050"\w* said \w to|strong="H5704"\w* \w Jesse|strong="H3448"\w*, “\w Is|strong="H2009"\w* \w that|strong="H3588"\w* \w all|strong="H5704"\w* \w of|strong="H6629"\w* \w the|strong="H3588"\w* \w young|strong="H5288"\w* \w men|strong="H5288"\w*?” \w Jesse|strong="H3448"\w* replied, “\w There|strong="H2009"\w* \w is|strong="H2009"\w* \w still|strong="H5750"\w* \w the|strong="H3588"\w* \w youngest|strong="H6996"\w* \w one|strong="H3808"\w*, \w but|strong="H3588"\w* \w he|strong="H3588"\w*’s \w taking|strong="H3947"\w* care \w of|strong="H6629"\w* \w the|strong="H3588"\w* \w flock|strong="H6629"\w*.” \w Samuel|strong="H8050"\w* said \w to|strong="H5704"\w* \w Jesse|strong="H3448"\w*, “\w Send|strong="H7971"\w* \w and|strong="H7971"\w* \w get|strong="H3947"\w* \w him|strong="H7971"\w*, \w for|strong="H3588"\w* \w we|strong="H3068"\w* \w cannot|strong="H3808"\w* \w turn|strong="H5437"\w* \w our|strong="H3947"\w* attention \w to|strong="H5704"\w* \w other|strong="H5750"\w* \w things|strong="H6996"\w* \w until|strong="H5704"\w* \w he|strong="H3588"\w* comes \w here|strong="H6311"\w*.”   
