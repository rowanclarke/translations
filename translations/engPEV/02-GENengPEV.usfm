\v 11 \w Then|strong="H1571"\w* \w Judah|strong="H3063"\w* thought, “\w My|strong="H3588"\w* \w sons|strong="H1121"\w* Er \w and|strong="H1121"\w* Onan, \w they|strong="H3588"\w* \w are|strong="H1121"\w* \w both|strong="H1571"\w* \w dead|strong="H4191"\w*, \w and|strong="H1121"\w* \w they|strong="H3588"\w* didn’t \w have|strong="H1121"\w* \w any|strong="H1571"\w* \w kids|strong="H1121"\w* \w with|strong="H1004"\w* \w that|strong="H3588"\w* \w woman|strong="H1004"\w*. \w So|strong="H6435"\w* \w now|strong="H3588"\w*, \w my|strong="H3588"\w* other \w son|strong="H1121"\w* \w Shelah|strong="H7956"\w* \w has|strong="H3063"\w* \w to|strong="H5704"\w* marry \w that|strong="H3588"\w* \w woman|strong="H1004"\w* \w and|strong="H1121"\w* \w have|strong="H1121"\w* \w kids|strong="H1121"\w* \w with|strong="H1004"\w* \w her|strong="H1931"\w*. \w That|strong="H3588"\w*’s \w the|strong="H3588"\w* \w rule|strong="H3427"\w* \w in|strong="H3427"\w* \w our|strong="H3588"\w* culture. \w But|strong="H3588"\w* \w if|strong="H3588"\w* \w Shelah|strong="H7956"\w* marries \w that|strong="H3588"\w* \w woman|strong="H1004"\w*, \w he|strong="H1931"\w* \w might|strong="H6435"\w* \w die|strong="H4191"\w* \w too|strong="H1571"\w*, \w just|strong="H1571"\w* \w like|strong="H1004"\w* Er \w and|strong="H1121"\w* Onan.” \w So|strong="H6435"\w* \w Judah|strong="H3063"\w* got worried, \w and|strong="H1121"\w* \w he|strong="H1931"\w* didn’t want \w his|strong="H3588"\w* \w son|strong="H1121"\w* \w Shelah|strong="H7956"\w* \w to|strong="H5704"\w* marry \w that|strong="H3588"\w* \w woman|strong="H1004"\w* \w Tamar|strong="H8559"\w*.  
\p \w So|strong="H6435"\w* \w Judah|strong="H3063"\w* talked \w to|strong="H5704"\w* \w Tamar|strong="H8559"\w*, \w and|strong="H1121"\w* \w he|strong="H1931"\w* tried \w to|strong="H5704"\w* trick \w her|strong="H1931"\w*. \w He|strong="H1931"\w* said \w to|strong="H5704"\w* \w her|strong="H1931"\w*, “\w My|strong="H3588"\w* \w son|strong="H1121"\w* \w Shelah|strong="H7956"\w* \w is|strong="H1931"\w* \w too|strong="H1571"\w* \w young|strong="H1121"\w* \w to|strong="H5704"\w* marry \w you|strong="H3588"\w* \w now|strong="H3588"\w*. \w So|strong="H6435"\w* \w go|strong="H3212"\w* \w back|strong="H3212"\w* \w to|strong="H5704"\w* \w your|strong="H3588"\w* \w father|strong="H1121"\w*’s \w house|strong="H1004"\w*, \w and|strong="H1121"\w* \w live|strong="H3427"\w* \w there|strong="H3427"\w*. Don’t \w get|strong="H3212"\w* \w married|strong="H3427"\w* \w to|strong="H5704"\w* \w anyone|strong="H3588"\w* \w else|strong="H6435"\w*. Later \w on|strong="H3427"\w*, \w Shelah|strong="H7956"\w* \w will|strong="H1571"\w* \w grow|strong="H1431"\w* \w up|strong="H1431"\w*, \w and|strong="H1121"\w* \w then|strong="H1571"\w* \w you|strong="H3588"\w* \w can|strong="H1004"\w* marry \w him|strong="H4191"\w*.” \w So|strong="H6435"\w* \w Tamar|strong="H8559"\w* \w went|strong="H3212"\w* \w back|strong="H3212"\w* \w to|strong="H5704"\w* \w her|strong="H1931"\w* \w father|strong="H1121"\w*’s \w house|strong="H1004"\w*, \w and|strong="H1121"\w* \w she|strong="H1931"\w* \w lived|strong="H3427"\w* \w there|strong="H3427"\w*.  
\p \w Judah|strong="H3063"\w*’s \w son|strong="H1121"\w* \w Shelah|strong="H7956"\w* \w grew|strong="H1431"\w* \w up|strong="H1431"\w* \w and|strong="H1121"\w* \w became|strong="H1431"\w* \w a|strong="H3068"\w* \w man|strong="H1121"\w*. \w But|strong="H3588"\w* \w Judah|strong="H3063"\w* didn’t \w keep|strong="H3427"\w* \w that|strong="H3588"\w* promise \w he|strong="H1931"\w* \w made|strong="H1571"\w* \w to|strong="H5704"\w* \w Tamar|strong="H8559"\w*. \w He|strong="H1931"\w* didn’t \w let|strong="H3212"\w* \w her|strong="H1931"\w* marry \w his|strong="H3588"\w* \w son|strong="H1121"\w* \w Shelah|strong="H7956"\w*.   
\s1 Tamar tricked Judah  
\p
\v 12 \w Some|strong="H3117"\w* \w time|strong="H3117"\w* later, \w Judah|strong="H3063"\w*’s wife \w died|strong="H4191"\w*. \w Her|strong="H5921"\w* father’s name \w was|strong="H1931"\w* \w Shua|strong="H7770"\w*. \w Judah|strong="H3063"\w* missed \w his|strong="H5921"\w* wife, \w so|strong="H5927"\w* \w he|strong="H1931"\w* felt \w very|strong="H7235"\w* sad \w for|strong="H5921"\w* \w a|strong="H3068"\w* \w while|strong="H3117"\w*. \w But|strong="H1931"\w* later \w on|strong="H5921"\w*, \w he|strong="H1931"\w* felt \w all|strong="H5921"\w* right again.  
\p \w Judah|strong="H3063"\w*’s work-men \w were|strong="H3117"\w* \w in|strong="H5921"\w* \w the|strong="H5921"\w* place called \w Timnah|strong="H8553"\w*. \w They|strong="H3117"\w* \w were|strong="H3117"\w* cutting \w the|strong="H5921"\w* wool \w off|strong="H5921"\w* \w Judah|strong="H3063"\w*’s \w sheep|strong="H6629"\w*. \w Judah|strong="H3063"\w* wanted \w to|strong="H4191"\w* visit \w his|strong="H5921"\w* work-men, \w so|strong="H5927"\w* \w he|strong="H1931"\w* started \w to|strong="H4191"\w* \w go|strong="H5927"\w* towards \w Timnah|strong="H8553"\w*, \w and|strong="H3063"\w* \w his|strong="H5921"\w* \w friend|strong="H7453"\w* \w Hirah|strong="H2437"\w* \w went|strong="H5927"\w* \w with|strong="H5921"\w* \w him|strong="H5921"\w*. \w That|strong="H3117"\w* \w man|strong="H4191"\w* \w Hirah|strong="H2437"\w*, \w he|strong="H1931"\w* \w was|strong="H1931"\w* \w from|strong="H5921"\w* \w the|strong="H5921"\w* town called Adullam.   
\p
