\q1  
\v 37 Lamec Matusalén hiewaa; 
\q1 Matusalén Enoc hiewaa; 
\q1 Enoc Jared hiewaa; 
\q1 Jared Mahalaleel hiewaa; 
\q1 Mahalaleel Cainán hiewaa; 
