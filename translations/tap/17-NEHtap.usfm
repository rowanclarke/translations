\p  
\v 43 Balawi, bena Yeshua i kulanda nangue Kadimieli, pamo ni bena Hodavia baali 74. 
\li1  
\v 44 Bakemba, bena Asafu baali 148. 
\li1  
\v 45 Bakalinda ba pa mulyango, ni bena Salumu, ni bena Ateri, ni bena Talmoni, ni bena Akubu, ni bena Hatita, pamo ni bena Sobai, baali 138. 
\p  
\v 46 Babombi ba mu Nghanda yakua Leza, 
\li1 bena Siha, ni bena Hasufa, ni bena Tobaoti, 
\li1  
