\id HOS
\h Oseas
\toc3 Os
\toc2 Oseas
\toc1 Oseas
\mt1 Oseas
\c 1
\s1 Castigo y restauración de Israel
\p 
\v 1 La \w Palabra|strong="H1697"\w* \w de|strong="H1121"\w* \w Yavé|strong="H3068"\w* \w que|strong="H1697"\w* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w Oseas|strong="H1954"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Beeri, en \w los|strong="H1121"\w* \w días|strong="H3117"\w* \w de|strong="H1121"\w* Uzías, Jotam, Acaz y Ezequías, \w reyes|strong="H4428"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*, y en \w los|strong="H1121"\w* \w días|strong="H3117"\w* \w de|strong="H1121"\w* \w Jeroboam|strong="H3379"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Joás|strong="H3101"\w*, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*.
\p 
\v 2 \w Cuando|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* comenzó \w a|strong="H3068"\w* \w hablar|strong="H1696"\w* \w por|strong="H3588"\w* medio \w de|strong="H3588"\w* \w Oseas|strong="H1954"\w* le \w dijo|strong="H1696"\w*: \wj \w Vé|strong="H3212"\w*, \w toma|strong="H3947"\w* \w para|strong="H3588"\w* ti una mujer prostituta \w y|strong="H3588"\w* engendra \w hijos|strong="H3206"\w* \w de|strong="H3588"\w* prostitución, \w porque|strong="H3588"\w* \w la|strong="H3588"\w* tierra se prostituye totalmente \w y|strong="H3588"\w* se aparta \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd*.\wj*
\p 
\v 3 \w Fue|strong="H3212"\w*, pues, y \w tomó|strong="H3947"\w* \w a|strong="H3068"\w* \w Gomer|strong="H1586"\w*, \w hija|strong="H1323"\w* \w de|strong="H1121"\w* Diblaim, la cual \w concibió|strong="H2029"\w* y le dio \w a|strong="H3068"\w* luz un \w hijo|strong="H1121"\w*.
\p 
\v 4 \nd \w Yavé|strong="H3068"\w*\nd* \w le|strong="H5921"\w* dijo: \wj Llámalo \w Jezreel|strong="H3157"\w*, \w porque|strong="H3588"\w* muy pronto castigaré \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Jehú|strong="H3058"\w* \w por|strong="H5921"\w* \w la|strong="H5921"\w* \w sangre|strong="H1818"\w* derramada \w en|strong="H5921"\w* \w Jezreel|strong="H3157"\w*, \w y|strong="H3588"\w* eliminaré \w el|strong="H5921"\w* reino \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w Casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.\wj*
\v 5 \wj \w Sucederá|strong="H1961"\w* \w que|strong="H1931"\w* \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w quebraré|strong="H7665"\w* \w el|strong="H1931"\w* \w arco|strong="H7198"\w* de \w Israel|strong="H3478"\w* en \w el|strong="H1931"\w* \w valle|strong="H6010"\w* de \w Jezreel|strong="H3157"\w*.\wj*
\p 
\v 6 \w Otra|strong="H5750"\w* vez \w concibió|strong="H2029"\w* \w y|strong="H3588"\w* dio \w a|strong="H3068"\w* luz una \w hija|strong="H1323"\w*.
\p \w Y|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w le|strong="H3254"\w* dijo: \wj \w Llámala|strong="H7121"\w* \w Lo-ruhama|strong="H3808"\w*,\wj*\f + \fr 1:6 \ft Lo-ruhama: no amada.\f* \wj \w porque|strong="H3588"\w* \w ya|strong="H3254"\w* \w no|strong="H3808"\w* \w me|strong="H3588"\w* compadeceré \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w Casa|strong="H1004"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* \w para|strong="H3588"\w* perdonarlos.\wj*
\v 7 \wj Pero tendré compasión de la \w Casa|strong="H1004"\w* de \w Judá|strong="H3063"\w* y los \w salvaré|strong="H3467"\w* por \nd \w Yavé|strong="H3068"\w*\nd*, su ʼElohim. \w No|strong="H3808"\w* los \w libraré|strong="H3467"\w* con \w arco|strong="H7198"\w*, \w ni|strong="H3808"\w* con \w espada|strong="H2719"\w*, \w ni|strong="H3808"\w* con \w batalla|strong="H4421"\w*, \w ni|strong="H3808"\w* con \w caballos|strong="H5483"\w*, \w ni|strong="H3808"\w* con \w jinetes|strong="H6571"\w*.\wj*
\p 
\v 8 Después \w de|strong="H1121"\w* destetar \w a|strong="H3068"\w* Lo-ruhama, \w concibió|strong="H2029"\w* y dio \w a|strong="H3068"\w* luz un \w hijo|strong="H1121"\w*.
\p 
\v 9 \nd \w Yavé|strong="H3068"\w*\nd* dijo: \wj Llámalo \w Lo-ammi|strong="H3808"\w*,\wj*\f + \fr 1:9 \ft Lo-ammi: no pueblo mío.\f* \wj \w porque|strong="H3588"\w* ustedes \w no|strong="H3808"\w* \w son|strong="H1961"\w* \w mi|strong="H1961"\w* \w pueblo|strong="H5971"\w* \w ni|strong="H3808"\w* \w Yo|strong="H3588"\w* \w seré|strong="H1961"\w* \w para|strong="H3588"\w* ustedes \w su|strong="H3588"\w* \add \nd ʼElohim\nd*\add*.\wj*
\v 10 \wj Sin embargo, el número de los hijos de Israel será como la arena del mar, que no se puede medir ni contar. \w Y|strong="H3068"\w* en el lugar donde les fue dicho: Ustedes no son mi pueblo, se les dirá: Son hijos del \nd ʼEL\nd* que vive.\wj*
\v 11 \wj Los hijos de Judá y de Israel se unirán y designarán un solo caudillo. Subirán de la tierra, porque grande es el día de Jezreel.\wj*
\c 2
\s1 Adulterio espiritual
\p 
\v 1 \wj Llamen \w a|strong="H3068"\w* \w sus|strong="H1992"\w* hermanos \w Ammi|strong="H5971"\w*, y \w a|strong="H3068"\w* \w sus|strong="H1992"\w* hermanas Ruhama.\wj*\f + \fr 2:1 \ft Ammi: pueblo mío; Ruhama: amada.\f*
\v 2 \wj Contiendan \w con|strong="H4480"\w* \w su|strong="H3588"\w* madre, contiendan, \w porque|strong="H3588"\w* \w ella|strong="H4480"\w* \w no|strong="H3588"\w* \w es|strong="H3588"\w* mi esposa ni \w Yo|strong="H4480"\w* soy \w su|strong="H3588"\w* esposo, \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w se|strong="H4480"\w* quite \w de|strong="H4480"\w* \w su|strong="H3588"\w* cara sus fornicaciones, \w y|strong="H3588"\w* sus adulterios \w de|strong="H4480"\w* \w entre|strong="H3588"\w* sus pechos.\wj*
\v 3 \wj No sea \w que|strong="H5971"\w* la despoje, la deje totalmente desnuda, la coloque como el día cuando nació, la deje como el desierto, la reduzca \w a|strong="H3068"\w* tierra árida, la mate \w de|strong="H5971"\w* sed,\wj*
\v 4 \wj \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w me|strong="H3588"\w* compadezca \w de|strong="H3588"\w* \w sus|strong="H1931"\w* hijos \w porque|strong="H3588"\w* \w son|strong="H3588"\w* hijos bastardos.\wj*
\v 5 \wj \w Sí|strong="H6435"\w*, su madre \w se|strong="H6435"\w* prostituyó, la \w que|strong="H6435"\w* los \w dio|strong="H7760"\w* \w a|strong="H3068"\w* luz \w se|strong="H6435"\w* deshonró, pues \w se|strong="H6435"\w* dijo: Iré tras mis amantes, los cuales me dan mi pan y mi agua, mi lana y mi lino, mi aceite y mi vino.\wj*
\v 6 \wj \w Por|strong="H3588"\w* tanto mira, \w Yo|strong="H3588"\w* obstruyo tu camino \w con|strong="H3588"\w* espinos. Construiré un muro contra ella \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* encuentren \w sus|strong="H1992"\w* senderos.\wj*
\v 7 \wj Perseguirá \w a|strong="H3068"\w* sus amantes \w y|strong="H3588"\w* \w no|strong="H3588"\w* \w los|strong="H3588"\w* alcanzará, \w los|strong="H3588"\w* buscará \w y|strong="H3588"\w* \w no|strong="H3588"\w* \w los|strong="H3588"\w* hallará, \w y|strong="H3588"\w* dirá: Volveré \w a|strong="H3068"\w* mi primer esposo, \w porque|strong="H3588"\w* \w entonces|strong="H3588"\w* estaba mejor \w que|strong="H3588"\w* ahora.\wj*
\p 
\v 8 \wj Ella \w no|strong="H3808"\w* entendía \w que|strong="H3808"\w* era Yo el \w que|strong="H3808"\w* le daba el grano, el mosto y el aceite, el \w que|strong="H3808"\w* le multiplicaba la plata y el oro \w que|strong="H3808"\w* usan para baal.\wj*
\v 9 \wj \w Por|strong="H3588"\w* eso le retendré \w mi|strong="H1245"\w* grano \w en|strong="H3588"\w* \w la|strong="H3588"\w* cosecha \w y|strong="H3588"\w* \w mi|strong="H1245"\w* mosto \w en|strong="H3588"\w* \w su|strong="H3588"\w* época. Recuperaré \w mi|strong="H1245"\w* lana \w y|strong="H3588"\w* \w mi|strong="H1245"\w* lino \w con|strong="H3588"\w* \w los|strong="H7291"\w* cuales cubría \w su|strong="H3588"\w* desnudez.\wj*
\v 10 \wj Descubriré ante \w sus|strong="H1931"\w* amantes \w su|strong="H1931"\w* infamia, \w y|strong="H3588"\w* \w no|strong="H3808"\w* habrá \w quien|strong="H1931"\w* \w la|strong="H1931"\w* libre \w de|strong="H3588"\w* mi \w mano|strong="H1931"\w*.\wj*
\v 11 \wj Haré cesar todo su alborozo: sus fiestas, sus nuevas lunas y sus sábados, y todas sus \w solemnidades|strong="H4150"\w*. \wj*
\v 12 \wj Arrasaré su vid y su higuera, \w de|strong="H5869"\w* las cuales decía: \w son|strong="H3808"\w* mi paga, me las dieron mis amantes. Las convertiré en matorrales, y los comerán las bestias del campo.\wj*
\v 13 \wj \w La|strong="H3605"\w* castigaré por \w los|strong="H3605"\w* días dedicados \w a|strong="H3068"\w* \w los|strong="H3605"\w* baales, \w a|strong="H3068"\w* \w los|strong="H3605"\w* cuales les quemaba incienso, y adornada con aretes y collares iba detrás de sus amantes, y se olvidaba de mí, \wj*dice \nd \w Yavé|strong="H3068"\w*\nd*.
\p 
\v 14 \wj \w Por|strong="H5414"\w* tanto, Yo la atraeré y la llevaré al desierto, y le hablaré \w a|strong="H3068"\w* \w su|strong="H1992"\w* corazón.\wj*
\v 15 \wj Allí \w le|strong="H5921"\w* daré \w sus|strong="H1992"\w* viñas \w y|strong="H5921"\w* \w el|strong="H5921"\w* valle \w de|strong="H5921"\w* Acor, \w como|strong="H5921"\w* puerta \w de|strong="H5921"\w* esperanza. Allí \w me|strong="H5921"\w* responderá \w como|strong="H5921"\w* \w en|strong="H5921"\w* \w su|strong="H1992"\w* juventud, \w como|strong="H5921"\w* \w cuando|strong="H3117"\w* \w salió|strong="H3212"\w* \w de|strong="H5921"\w* Egipto.\wj*
\v 16 \wj Sucederá \w en|strong="H5921"\w* aquel día,\wj* \w dice|strong="H1696"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \wj \w que|strong="H5921"\w* tú \w me|strong="H5921"\w* llamarás: Esposo \w mío|strong="H5921"\w*, \w y|strong="H5921"\w* ya \w no|strong="H5921"\w* \w me|strong="H5921"\w* llamarás: \nd ʼAdón\nd* \w mío|strong="H5921"\w*.\wj*
\v 17 \wj Pues quitaré \w de|strong="H5414"\w* su boca los nombres \w de|strong="H5414"\w* los baales, y sus nombres ya no serán invocados.\wj*
\v 18 \wj Haré un pacto \w a|strong="H3068"\w* favor \w de|strong="H5750"\w* \w ellos|strong="H1931"\w* con las bestias salvajes, las aves \w de|strong="H5750"\w* \w los|strong="H1931"\w* cielos y \w los|strong="H1931"\w* reptiles \w de|strong="H5750"\w* \w la|strong="H1931"\w* tierra. Romperé \w el|strong="H1931"\w* arco, \w la|strong="H1931"\w* espada y las batallas \w de|strong="H5750"\w* \w la|strong="H1931"\w* tierra, y haré \w que|strong="H1931"\w* reposen seguros.\wj*
\v 19 \wj Te comprometeré conmigo \w para|strong="H5493"\w* siempre. Te desposaré conmigo \w en|strong="H5493"\w* justicia y justo juicio, con benignidad y gran misericordia.\wj*
\v 20 \wj \w Te|strong="H4480"\w* desposaré \w conmigo|strong="H5973"\w* \w en|strong="H4480"\w* fidelidad, y tú conocerás \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*.\wj*
\p 
\v 21 \wj Aquel día responderé, \wj*dice \nd \w Yavé|strong="H3068"\w*\nd*. \wj Yo responderé \w a|strong="H3068"\w* los cielos, y ellos responderán \w a|strong="H3068"\w* la tierra.\wj*
\v 22 \wj \w Y|strong="H3068"\w* la tierra responderá al trigo, al vino y al aceite, y ellos responderán \w a|strong="H3068"\w* Jezreel. \wj*
\v 23 \wj \w Y|strong="H3068"\w* \w la|strong="H1931"\w* sembraré en \w la|strong="H1931"\w* tierra \w para|strong="H1961"\w* \w Mí|strong="H1961"\w* \w mismo|strong="H1931"\w*, y me compadeceré de Lo-ruhama, y diré \w a|strong="H3068"\w* Lo-ammi: \w Pueblo|strong="H1992"\w* mío. \wj*
\p \wj \w Y|strong="H3068"\w* \w él|strong="H1931"\w* \w responderá|strong="H6030"\w*: Tú \w eres|strong="H1961"\w* \w mi|strong="H1961"\w* \nd ʼElohim\nd*.\wj*
\c 3
\s1 El amor imperecedero
\p 
\v 1 \nd \w Yavé|strong="H3068"\w*\nd* me dijo: \wj \w Vé|strong="H3212"\w* \w otra|strong="H5750"\w* vez, ama \w a|strong="H3068"\w* una mujer amada \w por|strong="H5750"\w* \w su|strong="H1992"\w* esposo, aunque \w adúltera|strong="H5003"\w*, tal \w como|strong="H5750"\w* \nd \w Yavé|strong="H3068"\w*\nd* ama \w a|strong="H3068"\w* \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H5750"\w* \w Israel|strong="H3478"\w*, aunque siguen \w a|strong="H3068"\w* \tl ʼelohim\tl* extraños y aman \w las|strong="H1992"\w* tortas \w de|strong="H5750"\w* \w uvas|strong="H6025"\w* pasas.\wj*
\p 
\v 2 La compré para mí por 165 piezas \w de|strong="H2568"\w* \w plata|strong="H3701"\w* y 230 litros \w de|strong="H2568"\w* \w cebada|strong="H8184"\w*.
\v 3 \w Y|strong="H3068"\w* le dije: \w Muchos|strong="H7227"\w* \w días|strong="H3117"\w* \w estarás|strong="H1961"\w* conmigo. \w No|strong="H3808"\w* te prostituirás \w ni|strong="H3808"\w* aceptarás \w a|strong="H3068"\w* otro hombre. \w Lo|strong="H3808"\w* \w mismo|strong="H1571"\w* haré yo contigo.
\p 
\v 4 \w Porque|strong="H3588"\w* \w muchos|strong="H7227"\w* \w días|strong="H3117"\w* \w estarán|strong="H3427"\w* \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*, sin \w rey|strong="H4428"\w* \w y|strong="H3588"\w* sin caudillo, sin \w sacrificio|strong="H2077"\w* \w y|strong="H3588"\w* sin columna, sin \tl efod\tl* \w y|strong="H3588"\w* las pequeñas imágenes \w que|strong="H3588"\w* usan \w como|strong="H3588"\w* ídolos domésticos.
\v 5 Después \w volverán|strong="H7725"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* y \w buscarán|strong="H1245"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* su \nd ʼElohim\nd* y \w a|strong="H3068"\w* \w David|strong="H1732"\w* su \w rey|strong="H4428"\w*. Acudirán temblorosos \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* y \w a|strong="H3068"\w* su \w bondad|strong="H2898"\w* en \w los|strong="H1121"\w* últimos \w días|strong="H3117"\w*.
\c 4
\s1 Contra los sacerdotes
\p 
\v 1 \w Oigan|strong="H8085"\w* \w la|strong="H3588"\w* \w Palabra|strong="H1697"\w* \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w oh|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*. \wj \w Porque|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* contiende \w con|strong="H5973"\w* \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* tierra, \w porque|strong="H3588"\w* \w no|strong="H3588"\w* hay verdad \w ni|strong="H5973"\w* compasión \w ni|strong="H5973"\w* \w conocimiento|strong="H1847"\w* \w de|strong="H3588"\w* \nd ʼElohim\nd* \w en|strong="H5973"\w* \w la|strong="H3588"\w* tierra,\wj*
\v 2 \wj Sino propagan el juramento falso y la \w mentira|strong="H3584"\w*, el asesinato, el robo y el adulterio prevalecen. Uno tras otro suceden los homicidios. \wj*
\v 3 \wj \w Por|strong="H5921"\w* \w eso|strong="H3651"\w* \w la|strong="H5921"\w* tierra tendrá luto, \w y|strong="H1571"\w* \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w que|strong="H5921"\w* \w la|strong="H5921"\w* \w habitan|strong="H3427"\w* desfallecerán \w juntamente|strong="H1571"\w* \w con|strong="H5921"\w* \w las|strong="H5921"\w* \w bestias|strong="H2416"\w* \w del|strong="H5921"\w* \w campo|strong="H7704"\w* \w y|strong="H1571"\w* \w las|strong="H5921"\w* \w aves|strong="H5775"\w* \w del|strong="H5921"\w* \w cielo|strong="H8064"\w*. \w También|strong="H1571"\w* \w los|strong="H3427"\w* peces \w del|strong="H5921"\w* \w mar|strong="H3220"\w* perecerán.\wj*
\p 
\v 4 \wj Pero nadie acuse ni \w reprenda|strong="H3198"\w* \w a|strong="H3068"\w* otro, \w porque|strong="H3198"\w*, oh \w sacerdote|strong="H3548"\w*, mi \w contienda|strong="H7378"\w* es \w contigo|strong="H5971"\w*.\wj*
\v 5 \wj Por tanto, \w tropezarás|strong="H3782"\w* \w de|strong="H5973"\w* \w día|strong="H3117"\w* \w y|strong="H1571"\w* \w el|strong="H5973"\w* \w profeta|strong="H5030"\w* \w tropezará|strong="H3782"\w* \w contigo|strong="H5973"\w* \w de|strong="H5973"\w* \w noche|strong="H3915"\w*.\wj*
\v 6 \wj \w Porque|strong="H3588"\w* mi \w pueblo|strong="H5971"\w* perece \w por|strong="H3588"\w* falta \w de|strong="H3588"\w* \w conocimiento|strong="H1847"\w*. \w Porque|strong="H3588"\w* \w desechaste|strong="H3988"\w* \w el|strong="H3588"\w* \w conocimiento|strong="H1847"\w*, \w Yo|strong="H3588"\w* \w te|strong="H3588"\w* \w echaré|strong="H3988"\w* del \w sacerdocio|strong="H3547"\w*. \w Porque|strong="H3588"\w* \w olvidaste|strong="H7911"\w* \w la|strong="H1571"\w* \w Ley|strong="H8451"\w* \w de|strong="H3588"\w* tu \nd ʼElohim\nd*, \w también|strong="H1571"\w* \w Yo|strong="H3588"\w* \w me|strong="H3588"\w* \w olvidaré|strong="H7911"\w* \w de|strong="H3588"\w* tus \w hijos|strong="H1121"\w*,\wj*
\p 
\v 7 \wj Que \w cuanto|strong="H3651"\w* \w más|strong="H7235"\w* \w se|strong="H3651"\w* \w multiplican|strong="H7235"\w*, \w más|strong="H7235"\w* pecan contra Mí. Cambiaré su resplandor en vergüenza.\wj*
\v 8 \wj \w Se|strong="H5971"\w* alimentan con las ofrendas por el \w pecado|strong="H2403"\w* \w de|strong="H5971"\w* \w mi|strong="H5375"\w* \w pueblo|strong="H5971"\w*, y \w a|strong="H3068"\w* su \w iniquidad|strong="H5771"\w* elevan su anhelo.\wj*
\v 9 \wj \w Como|strong="H1961"\w* \w es|strong="H1961"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w* así \w es|strong="H1961"\w* \w el|strong="H5921"\w* \w sacerdote|strong="H3548"\w*. \w Los|strong="H5921"\w* castigaré \w por|strong="H5921"\w* sus \w caminos|strong="H1870"\w* \w y|strong="H5921"\w* \w les|strong="H5921"\w* \w pagaré|strong="H7725"\w* \w según|strong="H5921"\w* sus \w obras|strong="H4611"\w*.\wj*
\v 10 \wj Comerán \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* \w saciarán|strong="H7646"\w*, \w fornicarán|strong="H2181"\w* \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* multiplicarán, \w porque|strong="H3588"\w* abandonaron \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*.\wj*
\p 
\v 11 \wj \w Fornicación|strong="H2184"\w*, \w vino|strong="H3196"\w* y \w mosto|strong="H8492"\w* \w quitan|strong="H3947"\w* el \w entendimiento|strong="H3820"\w*.\wj*
\v 12 \wj Mi \w pueblo|strong="H5971"\w* consulta \w al|strong="H8478"\w* \w leño|strong="H6086"\w*, \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w palo|strong="H6086"\w* le responde. \w Porque|strong="H3588"\w* un \w espíritu|strong="H7307"\w* \w de|strong="H3588"\w* prostitución lo extravió, \w y|strong="H3588"\w* \w se|strong="H5971"\w* prostituyeron contra \w su|strong="H3588"\w* \nd ʼElohim\nd*.\wj*
\v 13 \wj \w Sobre|strong="H5921"\w* \w las|strong="H5921"\w* cumbres \w de|strong="H5921"\w* \w las|strong="H5921"\w* montañas ofrecen \w sacrificios|strong="H2076"\w* \w y|strong="H3588"\w* queman incienso \w sobre|strong="H5921"\w* \w las|strong="H5921"\w* colinas \w debajo|strong="H8478"\w* \w del|strong="H5921"\w* roble, \w del|strong="H5921"\w* álamo \w y|strong="H3588"\w* \w del|strong="H5921"\w* olmo, \w porque|strong="H3588"\w* \w su|strong="H3588"\w* \w sombra|strong="H6738"\w* \w es|strong="H3588"\w* agradable. \w Por|strong="H5921"\w* \w eso|strong="H3651"\w* sus \w hijas|strong="H1323"\w* fornican \w y|strong="H3588"\w* sus \w nueras|strong="H3618"\w* cometen adulterio.\wj*
\v 14 \wj \w Yo|strong="H3588"\w* \w no|strong="H3808"\w* castigaré \w a|strong="H3068"\w* \w sus|strong="H1992"\w* \w hijas|strong="H1323"\w* \w cuando|strong="H3588"\w* \w se|strong="H5921"\w* prostituyan, \w ni|strong="H3808"\w* \w a|strong="H3068"\w* \w sus|strong="H1992"\w* \w nueras|strong="H3618"\w* \w cuando|strong="H3588"\w* adulteren, \w porque|strong="H3588"\w* \w los|strong="H1992"\w* hombres \w se|strong="H5921"\w* van \w con|strong="H5973"\w* \w las|strong="H1992"\w* prostitutas \w y|strong="H3588"\w* \w con|strong="H5973"\w* \w las|strong="H1992"\w* prostitutas sagradas ofrecen \w sacrificios|strong="H2076"\w*. \w El|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w sin|strong="H3808"\w* entendimiento \w se|strong="H5921"\w* arruina.\wj*
\p 
\v 15 \wj Aunque tú, \w Israel|strong="H3478"\w* te prostituyas, que \w Judá|strong="H3063"\w* no sea culpable. Tampoco \w vaya|strong="H5927"\w* \w a|strong="H3068"\w* \w Gilgal|strong="H1537"\w*, ni \w suba|strong="H5927"\w* \w a|strong="H3068"\w* Bet-avén, ni \w jure|strong="H7650"\w* al decir: ¡\w Vive|strong="H2416"\w* \nd \w Yavé|strong="H3068"\w*\nd*!\wj*
\v 16 \wj \w Puesto|strong="H3588"\w* \w que|strong="H3588"\w* \w Israel|strong="H3478"\w* \w es|strong="H3588"\w* terco \w como|strong="H3588"\w* novilla indómita, ¿\nd \w Yavé|strong="H3068"\w*\nd* lo pastoreará \w como|strong="H3588"\w* \w cordero|strong="H3532"\w* \w en|strong="H3588"\w* \w el|strong="H3588"\w* campo?\wj*
\p 
\v 17 \wj Efraín se apegó \w a|strong="H3068"\w* los \w ídolos|strong="H6091"\w*. ¡Déjalo!\wj*
\v 18 \wj Su embriaguez es rebelión. Ciertamente cometen prostitución, y sus gobernantes aman mucho el deshonor.\wj*
\v 19 \wj El \w viento|strong="H7307"\w* los \w ató|strong="H6887"\w* en sus \w alas|strong="H3671"\w*, y serán avergonzados \w a|strong="H3068"\w* causa de sus \w sacrificios|strong="H2077"\w*.\wj*
\c 5
\s1 La sentencia
\p 
\v 1 \wj ¡\w Oigan|strong="H8085"\w* \w esto|strong="H2063"\w*, \w sacerdotes|strong="H3548"\w*! ¡Atiendan, oh \w Casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*! Presten atención, oh \w casa|strong="H1004"\w* \w real|strong="H4428"\w*. \w A|strong="H3068"\w* ustedes afecta \w esta|strong="H2063"\w* \w sentencia|strong="H4941"\w*, \w porque|strong="H3588"\w* \w fueron|strong="H1961"\w* trampa \w en|strong="H5921"\w* \w Mizpa|strong="H4709"\w*, \w red|strong="H7568"\w* tendida \w en|strong="H5921"\w* \w la|strong="H5921"\w* montaña \w Tabor|strong="H8396"\w*,\wj*
\v 2 \wj y fosa cavada en Sitim. Yo \w los|strong="H3605"\w* castigaré \w a|strong="H3068"\w* \w todos|strong="H3605"\w*.\wj*
\p 
\v 3 \wj \w Conozco|strong="H3045"\w* \w a|strong="H3068"\w* Efraín, \w e|strong="H3068"\w* \w Israel|strong="H3478"\w* \w no|strong="H3808"\w* \w se|strong="H3045"\w* \w me|strong="H4480"\w* oculta. Tú, Efraín, incitaste \w a|strong="H3068"\w* \w la|strong="H3588"\w* prostitución, \w e|strong="H3068"\w* \w Israel|strong="H3478"\w* \w se|strong="H3045"\w* \w contaminó|strong="H2930"\w*.\wj*
\v 4 \wj Sus \w obras|strong="H4611"\w* \w no|strong="H3808"\w* \w los|strong="H3588"\w* dejan \w volver|strong="H7725"\w* \w a|strong="H3068"\w* \w su|strong="H3588"\w* \nd ʼElohim\nd*, \w porque|strong="H3588"\w* un \w espíritu|strong="H7307"\w* \w de|strong="H3588"\w* prostitución está \w dentro|strong="H7130"\w* \w de|strong="H3588"\w* ellos, \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w conocen|strong="H3045"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*.\wj*
\p 
\v 5 \wj \w La|strong="H1571"\w* \w soberbia|strong="H1347"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w* testifica \w contra|strong="H5973"\w* \w él|strong="H5973"\w* \w mismo|strong="H1571"\w*. \w Israel|strong="H3478"\w* \w y|strong="H1571"\w* Efraín \w tropezaron|strong="H3782"\w* \w en|strong="H5973"\w* su \w pecado|strong="H5771"\w*, \w y|strong="H1571"\w* \w Judá|strong="H3063"\w* \w tropezará|strong="H3782"\w* \w con|strong="H5973"\w* \w ellos|strong="H1571"\w*.\wj*
\v 6 \wj Con \w sus|strong="H1992"\w* rebaños \w y|strong="H1241"\w* manadas de \w ganado|strong="H6629"\w* \w vacuno|strong="H1241"\w* \w Irán|strong="H3212"\w* \w a|strong="H3068"\w* buscar \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*, pero \w no|strong="H3808"\w* \w lo|strong="H3808"\w* hallarán. \w Él|strong="H1992"\w* \w se|strong="H3808"\w* apartó de \w ellos|strong="H1992"\w*.\wj*
\v 7 \wj Ellos traicionaron \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w porque|strong="H3588"\w* \w engendraron|strong="H3205"\w* \w hijos|strong="H1121"\w* ilegítimos. \w Ahora|strong="H6258"\w* \w los|strong="H1121"\w* devorará \w la|strong="H3588"\w* luna nueva junto \w con|strong="H3588"\w* \w su|strong="H3588"\w* tierra.\wj*
\p 
\v 8 \wj ¡Toquen la \w trompeta|strong="H7782"\w* en \w Gabaa|strong="H1390"\w* y la \w trompeta|strong="H7782"\w* en \w Ramá|strong="H7414"\w*! ¡Toquen la alarma en Bet-avén! ¡Detrás de ti, oh \w Benjamín|strong="H1144"\w*!\wj*
\v 9 \wj Efraín \w será|strong="H1961"\w* \w asolado|strong="H8047"\w* el \w día|strong="H3117"\w* del castigo. Entre las \w tribus|strong="H7626"\w* de \w Israel|strong="H3478"\w* declaro lo \w que|strong="H3045"\w* \w es|strong="H1961"\w* seguro.\wj*
\v 10 \wj \w Los|strong="H5921"\w* gobernantes \w de|strong="H5921"\w* \w Judá|strong="H3063"\w* \w son|strong="H1961"\w* \w como|strong="H1961"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* desplazan linderos. \w Derramaré|strong="H8210"\w* \w mi|strong="H5921"\w* ira \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w* \w como|strong="H1961"\w* \w el|strong="H5921"\w* \w agua|strong="H4325"\w*.\wj*
\v 11 \wj Efraín está \w oprimido|strong="H6231"\w*, sus \w derechos|strong="H4941"\w* violados, \w porque|strong="H3588"\w* \w quiso|strong="H2974"\w* seguir mandatos.\wj*
\v 12 \wj Yo seré, pues, como \w polilla|strong="H6211"\w* \w a|strong="H3068"\w* Efraín, y como carcoma \w a|strong="H3068"\w* la \w Casa|strong="H1004"\w* de \w Judá|strong="H3063"\w*.\wj*
\p 
\v 13 \wj Cuando Efraín \w vio|strong="H7200"\w* \w su|strong="H1931"\w* \w enfermedad|strong="H2483"\w*, y \w Judá|strong="H3063"\w* \w miró|strong="H7200"\w* \w su|strong="H1931"\w* \w llaga|strong="H4205"\w*, entonces Efraín \w fue|strong="H3212"\w* \w a|strong="H3068"\w* Asiria y acudió \w al|strong="H4480"\w* \w rey|strong="H4428"\w* \w Jareb|strong="H3377"\w*. Pero \w él|strong="H1931"\w* \w no|strong="H3808"\w* \w puede|strong="H3201"\w* sanarlos, \w ni|strong="H3808"\w* curar \w su|strong="H1931"\w* \w llaga|strong="H4205"\w*.\wj*
\v 14 \wj \w Porque|strong="H3588"\w* \w Yo|strong="H3588"\w* seré \w como|strong="H3588"\w* un \w león|strong="H7826"\w* \w para|strong="H3588"\w* Efraín, \w y|strong="H3588"\w* \w como|strong="H3588"\w* un \w leoncillo|strong="H3715"\w* \w para|strong="H3588"\w* \w la|strong="H3588"\w* \w Casa|strong="H1004"\w* \w de|strong="H3588"\w* \w Judá|strong="H3063"\w*. \w Yo|strong="H3588"\w*, \w Yo|strong="H3588"\w* mismo haré presa \w y|strong="H3588"\w* \w me|strong="H3588"\w* \w iré|strong="H3212"\w*. \w La|strong="H3588"\w* \w llevo|strong="H5375"\w*, \w y|strong="H3588"\w* \w no|strong="H3588"\w* hay quien \w me|strong="H3588"\w* \w la|strong="H3588"\w* quite.\wj*
\v 15 \wj Me \w iré|strong="H3212"\w* \w y|strong="H5704"\w* regresaré \w a|strong="H3068"\w* \w mi|strong="H1245"\w* \w lugar|strong="H4725"\w* \w hasta|strong="H5704"\w* \w que|strong="H5704"\w* reconozcan \w su|strong="H1992"\w* pecado \w y|strong="H5704"\w* \w busquen|strong="H1245"\w* \w mi|strong="H1245"\w* \w rostro|strong="H6440"\w*. \w En|strong="H5704"\w* \w su|strong="H1992"\w* \w aflicción|strong="H6862"\w* me \w buscarán|strong="H1245"\w* sinceramente.\wj*
\c 6
\s1 Una conversión auténtica
\p 
\v 1 ¡Vengan, \w volvamos|strong="H7725"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*! \w Porque|strong="H3588"\w* \w Él|strong="H1931"\w* desgarró, \w pero|strong="H3588"\w* nos sanará. \w Él|strong="H1931"\w* \w hirió|strong="H5221"\w*, \w pero|strong="H3588"\w* nos \w vendará|strong="H2280"\w*.
\v 2 Nos dará \w vida|strong="H2421"\w* después \w de|strong="H6440"\w* \w dos|strong="H3117"\w* \w días|strong="H3117"\w*. Al tercer \w día|strong="H3117"\w* nos \w levantará|strong="H6965"\w* para \w que|strong="H3117"\w* vivamos \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Él.
\v 3 ¡Conozcámoslo, pues! ¡Sigamos adelante para conocer \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*! Su \w salida|strong="H4161"\w* es tan \w cierta|strong="H3559"\w* como la aurora. Él vendrá \w a|strong="H3068"\w* nosotros como la \w lluvia|strong="H1653"\w*, como la \w lluvia|strong="H1653"\w* \w tardía|strong="H4456"\w* \w que|strong="H3045"\w* riega la tierra.
\p 
\v 4 \wj ¿\w Qué|strong="H4100"\w* \w haré|strong="H6213"\w* contigo, Efraín? ¿\w Qué|strong="H4100"\w* \w haré|strong="H6213"\w* contigo, \w Judá|strong="H3063"\w*? Su fidelidad es \w como|strong="H4100"\w* \w nube|strong="H6051"\w* mañanera, \w como|strong="H4100"\w* \w el|strong="H6213"\w* \w rocío|strong="H2919"\w* temprano \w que|strong="H4100"\w* desaparece.\wj*
\v 5 \wj \w Por|strong="H5921"\w* \w eso|strong="H3651"\w* \w los|strong="H5921"\w* \w maté|strong="H2026"\w* \w con|strong="H5921"\w* \w las|strong="H5921"\w* \w palabras|strong="H6310"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w boca|strong="H6310"\w*. \w Los|strong="H5921"\w* trocé \w por|strong="H5921"\w* medio \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w profetas|strong="H5030"\w*, \w y|strong="H5921"\w* \w mi|strong="H5921"\w* \w sentencia|strong="H4941"\w* \w saldrá|strong="H3318"\w* \w como|strong="H5921"\w* \w la|strong="H5921"\w* luz.\wj*
\v 6 \wj \w Porque|strong="H3588"\w* fidelidad \w quiero|strong="H2654"\w*, \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w sacrificios|strong="H2077"\w*, \w conocimiento|strong="H1847"\w* \w de|strong="H3588"\w* \nd ʼElohim\nd*, \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w holocaustos|strong="H5930"\w*.\wj*
\p 
\v 7 \wj \w Ellos|strong="H1992"\w*, como Adán, quebrantaron mi \w Pacto|strong="H1285"\w*. \w Allí|strong="H8033"\w* me fueron infieles.\wj*
\v 8 \wj \w Galaad|strong="H1568"\w* es una villa \w de|strong="H1818"\w* malhechores, llena \w de|strong="H1818"\w* huellas \w de|strong="H1818"\w* \w sangre|strong="H1818"\w*.\wj*
\v 9 \wj \w Como|strong="H3588"\w* salteadores al acecho \w de|strong="H3588"\w* un hombre, \w así|strong="H3588"\w* bandas \w de|strong="H3588"\w* \w sacerdotes|strong="H3548"\w* asesinan \w por|strong="H3588"\w* \w el|strong="H3588"\w* \w camino|strong="H1870"\w* \w a|strong="H3068"\w* Siquem, \w cometieron|strong="H6213"\w* execrable \w maldad|strong="H2154"\w*.\wj*
\v 10 \wj En la \w Casa|strong="H1004"\w* de \w Israel|strong="H3478"\w* \w vi|strong="H7200"\w* cosas horrendas. \w Allí|strong="H8033"\w* se prostituye Efraín. \w Allí|strong="H8033"\w* se contamina \w Israel|strong="H3478"\w*.\wj*
\p 
\v 11 \wj \w Y|strong="H3068"\w* \w también|strong="H1571"\w* tú, \w Judá|strong="H3063"\w*, tienes preparada \w la|strong="H1571"\w* cosecha \w cuando|strong="H1571"\w* Yo restaure \w de|strong="H5971"\w* \w la|strong="H1571"\w* \w cautividad|strong="H7622"\w* \w a|strong="H3068"\w* mi \w pueblo|strong="H5971"\w*.\wj*
\c 7
\s1 La respuesta divina
\p 
\v 1 \wj \w Cuando|strong="H3588"\w* \w Yo|strong="H3588"\w* curaba \w a|strong="H3068"\w* \w Israel|strong="H3478"\w* se \w descubrió|strong="H1540"\w* \w la|strong="H3588"\w* \w iniquidad|strong="H5771"\w* \w de|strong="H3588"\w* Efraín \w y|strong="H3588"\w* salieron \w a|strong="H3068"\w* \w la|strong="H3588"\w* luz las \w maldades|strong="H5771"\w* \w de|strong="H3588"\w* \w Samaria|strong="H8111"\w*. \w Porque|strong="H3588"\w* obran \w con|strong="H3588"\w* \w engaño|strong="H8267"\w*. \w El|strong="H3588"\w* \w ladrón|strong="H1590"\w* se mete \w por|strong="H3588"\w* dentro, \w y|strong="H3588"\w* \w la|strong="H3588"\w* pandilla \w despoja|strong="H6584"\w* \w por|strong="H3588"\w* \w fuera|strong="H2351"\w*.\wj*
\v 2 \wj \w No|strong="H1077"\w* reflexionan en su \w corazón|strong="H3824"\w* \w que|strong="H6258"\w* Yo tengo presentes \w todas|strong="H3605"\w* sus perversidades. Sus propias acciones \w los|strong="H3605"\w* cercaron y \w están|strong="H1961"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w Mí|strong="H1961"\w*.\wj*
\v 3 \wj \w Alegran|strong="H8055"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w* con sus \w maldades|strong="H7451"\w*, y \w a|strong="H3068"\w* los \w príncipes|strong="H8269"\w* con sus mentiras.\wj*
\v 4 \wj \w Todos|strong="H3605"\w* \w ellos|strong="H3605"\w* son adúlteros. Son \w como|strong="H3644"\w* \w horno|strong="H8574"\w* \w encendido|strong="H1197"\w* \w que|strong="H5704"\w* \w el|strong="H3605"\w* panadero solo deja \w de|strong="H5704"\w* atizar \w desde|strong="H5704"\w* \w el|strong="H3605"\w* amasado \w hasta|strong="H5704"\w* \w la|strong="H3605"\w* fermentación.\wj*
\v 5 \wj El \w día|strong="H3117"\w* \w de|strong="H8269"\w* nuestro \w rey|strong="H4428"\w*, \w al|strong="H4428"\w* calor del \w vino|strong="H3196"\w*, los \w príncipes|strong="H8269"\w* lo contaminaron. Él \w extendió|strong="H4900"\w* su \w mano|strong="H3027"\w* \w a|strong="H3068"\w* los escarnecedores,\wj*
\v 6 \wj \w Porque|strong="H3588"\w* \w como|strong="H3588"\w* \w a|strong="H3068"\w* un \w horno|strong="H8574"\w* acercaron \w su|strong="H1931"\w* \w corazón|strong="H3820"\w* \w a|strong="H3068"\w* \w la|strong="H1931"\w* intriga. \w Toda|strong="H3605"\w* \w la|strong="H1931"\w* \w noche|strong="H3915"\w* dormita \w su|strong="H1931"\w* ira. \w Por|strong="H3588"\w* \w la|strong="H1931"\w* \w mañana|strong="H1242"\w* arde \w como|strong="H3588"\w* \w llama|strong="H3852"\w* \w de|strong="H3588"\w* fuego.\wj*
\v 7 \wj \w Todos|strong="H3605"\w* arden como un \w horno|strong="H8574"\w*, devoran \w a|strong="H3068"\w* sus gobernantes. \w Todos|strong="H3605"\w* sus \w reyes|strong="H4428"\w* van \w a|strong="H3068"\w* \w la|strong="H3605"\w* caída. Pero entre \w ellos|strong="H3605"\w* no hay \w quien|strong="H3605"\w* \w clame|strong="H7121"\w* \w a|strong="H3068"\w* Mí.\wj*
\p 
\v 8 \wj Efraín \w se|strong="H1961"\w* mezcló con \w los|strong="H1931"\w* \w pueblos|strong="H5971"\w*. Efraín \w es|strong="H1931"\w* una \w torta|strong="H5692"\w* \w no|strong="H1097"\w* volteada.\wj*
\v 9 \wj \w Le|strong="H1931"\w* socavan \w su|strong="H1931"\w* \w fuerza|strong="H3581"\w* \w los|strong="H1931"\w* extraños, pero \w él|strong="H1931"\w* \w no|strong="H3808"\w* \w se|strong="H3045"\w* da cuenta. \w El|strong="H1931"\w* cabello \w cano|strong="H7872"\w* \w se|strong="H3045"\w* esparce en \w él|strong="H1931"\w*, pero \w él|strong="H1931"\w* \w no|strong="H3808"\w* \w se|strong="H3045"\w* da cuenta.\wj*
\v 10 \wj \w La|strong="H3605"\w* propia \w soberbia|strong="H1347"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w* testifica en \w contra|strong="H6440"\w* suya, pero \w ellos|strong="H3605"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* \w vuelven|strong="H7725"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* su \nd ʼElohim\nd*. \w A|strong="H3068"\w* pesar \w de|strong="H6440"\w* \w todo|strong="H3605"\w*, \w no|strong="H3808"\w* \w lo|strong="H3808"\w* \w buscan|strong="H1245"\w*.\wj*
\p 
\v 11 \wj Efraín \w es|strong="H1961"\w* una \w paloma|strong="H3123"\w* ingenua y atolondrada. \w Claman|strong="H7121"\w* \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w*, acuden \w a|strong="H3068"\w* Asiria.\wj*
\v 12 \wj Tan pronto \w como|strong="H5921"\w* Yo eche \w mi|strong="H5921"\w* \w red|strong="H7568"\w* \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w*, \w y|strong="H5921"\w* \w como|strong="H5921"\w* \w a|strong="H3068"\w* pájaros \w los|strong="H5921"\w* haré caer. \w Los|strong="H5921"\w* atraparé tan pronto \w como|strong="H5921"\w* escuche \w la|strong="H5921"\w* bandada.\wj*
\v 13 \wj ¡Ay \w de|strong="H4480"\w* \w ellos|strong="H1992"\w*, \w porque|strong="H3588"\w* \w se|strong="H5921"\w* apartaron \w de|strong="H4480"\w* \w Mí|strong="H5921"\w*! ¡\w Destrucción|strong="H7701"\w* \w sobre|strong="H5921"\w* \w ellos|strong="H1992"\w*, \w porque|strong="H3588"\w* \w se|strong="H5921"\w* rebelaron \w contra|strong="H5921"\w* \w Mí|strong="H5921"\w*! ¿\w Los|strong="H1992"\w* redimiré \w cuando|strong="H3588"\w* \w ellos|strong="H1992"\w* \w me|strong="H4480"\w* calumnian?\wj*
\p 
\v 14 \wj \w Aun|strong="H3808"\w* \w cuando|strong="H3588"\w* gimen \w en|strong="H5921"\w* sus \w camas|strong="H4904"\w* \w no|strong="H3808"\w* claman \w a|strong="H3068"\w* \w Mí|strong="H5921"\w* \w de|strong="H5921"\w* \w corazón|strong="H3820"\w*. \w Se|strong="H5921"\w* apartan \w de|strong="H5921"\w* \w Mí|strong="H5921"\w* \w y|strong="H3588"\w* \w se|strong="H5921"\w* reúnen \w para|strong="H5921"\w* \w el|strong="H5921"\w* \w trigo|strong="H1715"\w* \w y|strong="H3588"\w* \w para|strong="H5921"\w* \w el|strong="H5921"\w* \w vino|strong="H8492"\w*.\wj*
\v 15 \wj Aunque Yo adiestré y fortalecí sus \w brazos|strong="H2220"\w*, ellos \w piensan|strong="H2803"\w* \w mal|strong="H7451"\w* contra Mí.\wj*
\v 16 \wj \w Se|strong="H1961"\w* \w vuelven|strong="H7725"\w*, pero \w no|strong="H3808"\w* \w a|strong="H3068"\w* \nd ʼElyón\nd*. \w Son|strong="H1961"\w* \w como|strong="H1961"\w* \w arco|strong="H7198"\w* \w que|strong="H3808"\w* yerra. Sus \w príncipes|strong="H8269"\w* \w pues|strong="H1961"\w* \w caerán|strong="H5307"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w* por la ira \w de|strong="H8269"\w* su propia \w lengua|strong="H3956"\w*. Esto \w será|strong="H1961"\w* su escarnio en la tierra \w de|strong="H8269"\w* \w Egipto|strong="H4714"\w*.\wj*
\c 8
\s1 Razones para el castigo
\p 
\v 1 \wj ¡Pon \w la|strong="H5921"\w* \w trompeta|strong="H7782"\w* \w en|strong="H5921"\w* tus labios! ¡\w Como|strong="H5921"\w* águila viene \w contra|strong="H5921"\w* \w la|strong="H5921"\w* \w Casa|strong="H1004"\w* \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w porque|strong="H5921"\w* violaron \w mi|strong="H5921"\w* \w Pacto|strong="H1285"\w* \w y|strong="H5921"\w* \w se|strong="H5921"\w* rebelaron \w contra|strong="H5921"\w* \w mi|strong="H5921"\w* \w Ley|strong="H8451"\w*!\wj*
\v 2 \wj \w A|strong="H3068"\w* Mí \w clamarán|strong="H2199"\w*: ¡\nd ʼElohim\nd* mío, nosotros te conocemos!\wj*
\v 3 \wj Pero \w Israel|strong="H3478"\w* rechazó lo \w bueno|strong="H2896"\w*, el enemigo lo \w perseguirá|strong="H7291"\w*.\wj*
\p 
\v 4 \wj Designaron reyes \w sin|strong="H3808"\w* intervención mía. Constituyeron gobernantes \w sin|strong="H3808"\w* mi aprobación. \w Con|strong="H4480"\w* \w su|strong="H1992"\w* \w plata|strong="H3701"\w* y \w con|strong="H4480"\w* \w su|strong="H1992"\w* \w oro|strong="H2091"\w* \w hicieron|strong="H6213"\w* \w ídolos|strong="H6091"\w* \w para|strong="H4616"\w* \w su|strong="H1992"\w* destrucción. \wj*
\v 5 \wj Él rechaza tu \w becerro|strong="H5695"\w*, oh \w Samaria|strong="H8111"\w*. Mi ira \w se|strong="H3808"\w* encendió contra ellos. ¿\w Hasta|strong="H5704"\w* \w cuándo|strong="H4970"\w* \w son|strong="H3808"\w* incapaces \w de|strong="H5704"\w* lograr purificación?\wj*
\v 6 \wj \w Porque|strong="H3588"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* \w es|strong="H1931"\w* \w aun|strong="H3808"\w* \w esto|strong="H1931"\w*. \w El|strong="H1931"\w* \w artífice|strong="H2796"\w* \w lo|strong="H1931"\w* \w hizo|strong="H6213"\w*, \w no|strong="H3808"\w* \w es|strong="H1931"\w* \nd ʼElohim\nd*. ¡\w Será|strong="H1961"\w* destrozado \w el|strong="H1931"\w* \w becerro|strong="H5695"\w* \w de|strong="H3588"\w* \w Samaria|strong="H8111"\w*!\wj*
\p 
\v 7 \wj \w Sembraron|strong="H2232"\w* \w viento|strong="H7307"\w* \w y|strong="H3588"\w* cosecharán tempestad. \w No|strong="H1097"\w* tendrán cosecha, \w ni|strong="H1097"\w* \w la|strong="H3588"\w* espiga producirá \w harina|strong="H7058"\w*. \w Y|strong="H3068"\w* \w si|strong="H3588"\w* \w la|strong="H3588"\w* produce, extraños \w la|strong="H3588"\w* comerán.\wj*
\v 8 \wj \w Israel|strong="H3478"\w* \w será|strong="H1961"\w* devorado. \w Será|strong="H1961"\w* una \w vasija|strong="H3627"\w* inútil entre las \w naciones|strong="H1471"\w*.\wj*
\v 9 \wj \w Porque|strong="H3588"\w* \w fueron|strong="H5927"\w* \w a|strong="H3068"\w* Asiria \w y|strong="H3588"\w* Efraín \w como|strong="H3588"\w* asno solitario. j Alquiló amantes.\wj*
\v 10 \wj \w Pero|strong="H3588"\w* \w aunque|strong="H3588"\w* \w alquilen|strong="H8566"\w* \w entre|strong="H3588"\w* las \w naciones|strong="H1471"\w*, \w ahora|strong="H6258"\w* \w los|strong="H3588"\w* reuniré \w y|strong="H1571"\w* serán \w afligidos|strong="H2490"\w* un \w poco|strong="H4592"\w* \w por|strong="H3588"\w* \w la|strong="H1571"\w* \w carga|strong="H4853"\w* del \w rey|strong="H4428"\w* \w de|strong="H3588"\w* \w los|strong="H3588"\w* \w príncipes|strong="H8269"\w*.\wj*
\p 
\v 11 \wj Efraín \w multiplicó|strong="H7235"\w* \w los|strong="H3588"\w* \w altares|strong="H4196"\w* \w para|strong="H3588"\w* \w pecar|strong="H2398"\w*. \w Para|strong="H3588"\w* \w él|strong="H3588"\w* \w son|strong="H1961"\w* \w altares|strong="H4196"\w* \w para|strong="H3588"\w* \w pecar|strong="H2398"\w*.\wj*
\v 12 \wj Le escribí las grandezas de mi \w Ley|strong="H8451"\w*. Fueron recibidas \w como|strong="H3644"\w* cosa extraña.\wj*
\v 13 \wj \w Aunque|strong="H3808"\w* en \w los|strong="H1992"\w* \w sacrificios|strong="H2077"\w* de mis ofrendas \w sacrifican|strong="H2077"\w* y coman \w carne|strong="H1320"\w*, \nd \w Yavé|strong="H3068"\w*\nd* \w no|strong="H3808"\w* \w las|strong="H1992"\w* aceptará. \w Se|strong="H3808"\w* acuerda de \w su|strong="H1992"\w* \w iniquidad|strong="H5771"\w* y castigará \w sus|strong="H1992"\w* \w pecados|strong="H2403"\w*. \w Volverán|strong="H7725"\w* \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w*.\wj*
\v 14 \wj Porque \w Israel|strong="H3478"\w* \w olvidó|strong="H7911"\w* \w a|strong="H3068"\w* su \w Hacedor|strong="H6213"\w* y \w edificó|strong="H1129"\w* palacios. \w Judá|strong="H3063"\w* \w multiplicó|strong="H7235"\w* \w ciudades|strong="H5892"\w* \w fortificadas|strong="H1219"\w*. Pero \w Yo|strong="H6213"\w* encenderé un fuego en sus \w ciudades|strong="H5892"\w* que consumirá sus palacios.\wj*
\c 9
\s1 El castigo inminente
\p 
\v 1 Oh \w Israel|strong="H3478"\w*, \w no|strong="H3588"\w* \w te|strong="H5921"\w* alegres ni \w te|strong="H5921"\w* regocijes \w como|strong="H3588"\w* otros \w pueblos|strong="H5971"\w*, \w porque|strong="H3588"\w* \w te|strong="H5921"\w* prostituiste \w al|strong="H5921"\w* abandonar \w a|strong="H3068"\w* tu \nd ʼElohim\nd*, \w y|strong="H3588"\w* amaste salario \w de|strong="H5921"\w* prostituta \w en|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* eras \w del|strong="H5921"\w* \w trigo|strong="H1715"\w*.
\v 2 La era y el \w lagar|strong="H3342"\w* \w no|strong="H3808"\w* los alimentarán, y el \w mosto|strong="H8492"\w* les fallará.
\v 3 \w No|strong="H3808"\w* vivirán en la tierra de \nd \w Yavé|strong="H3068"\w*\nd*. Efraín \w se|strong="H3808"\w* \w volverá|strong="H7725"\w* \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w*, y en Asiria comerán manjar impuro.
\p 
\v 4 \w No|strong="H3808"\w* ofrecerán \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w libaciones|strong="H5258"\w* \w de|strong="H3588"\w* \w vino|strong="H3196"\w*, \w ni|strong="H3808"\w* sus holocaustos le serán aceptos. Serán \w para|strong="H3588"\w* \w ellos|strong="H3605"\w* \w como|strong="H3588"\w* \w pan|strong="H3899"\w* \w de|strong="H3588"\w* duelo. \w Todos|strong="H3605"\w* \w los|strong="H3605"\w* \w que|strong="H3588"\w* \w lo|strong="H3808"\w* coman quedarán impuros. \w Su|strong="H3588"\w* \w pan|strong="H3899"\w* \w será|strong="H2930"\w* \w para|strong="H3588"\w* \w ellos|strong="H3605"\w* mismos, \w pero|strong="H3588"\w* \w no|strong="H3808"\w* entrará \w en|strong="H3588"\w* \w la|strong="H3588"\w* \w Casa|strong="H1004"\w* \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\p 
\v 5 ¿\w Qué|strong="H4100"\w* \w harán|strong="H6213"\w* \w el|strong="H6213"\w* \w día|strong="H3117"\w* de la \w solemnidad|strong="H2282"\w*, \w el|strong="H6213"\w* \w día|strong="H3117"\w* de la \w fiesta|strong="H2282"\w* de \nd \w Yavé|strong="H3068"\w*\nd*?
\v 6 \w Si|strong="H3588"\w* escapan \w a|strong="H3068"\w* causa \w de|strong="H3588"\w* \w la|strong="H3588"\w* calamidad, \w Egipto|strong="H4714"\w* \w los|strong="H3588"\w* recogerá, \w y|strong="H3588"\w* Menfis \w los|strong="H3588"\w* sepultará. \w La|strong="H3588"\w* codicia \w de|strong="H3588"\w* \w su|strong="H3588"\w* \w plata|strong="H3701"\w* \w la|strong="H3588"\w* \w heredará|strong="H3423"\w* \w la|strong="H3588"\w* \w ortiga|strong="H7057"\w*, \w y|strong="H3588"\w* \w en|strong="H3588"\w* sus tiendas crecerán espinos.
\p 
\v 7 Llegan \w los|strong="H5921"\w* \w días|strong="H3117"\w* \w del|strong="H5921"\w* castigo, Llegan \w los|strong="H5921"\w* \w días|strong="H3117"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* retribución. \w Que|strong="H5921"\w* \w lo|strong="H5921"\w* \w sepa|strong="H3045"\w* \w Israel|strong="H3478"\w*: \w A|strong="H3068"\w* causa \w de|strong="H5921"\w* \w la|strong="H5921"\w* magnitud \w de|strong="H5921"\w* tu \w pecado|strong="H5771"\w*, \w A|strong="H3068"\w* causa \w de|strong="H5921"\w* tu \w gran|strong="H7227"\w* \w maldad|strong="H5771"\w* \w y|strong="H5921"\w* \w de|strong="H5921"\w* tu \w gran|strong="H7227"\w* \w odio|strong="H4895"\w*, \w El|strong="H5921"\w* \w profeta|strong="H5030"\w* enloqueció. \w El|strong="H5921"\w* hombre inspirado es \w insensato|strong="H7696"\w*.
\v 8 \w El|strong="H5921"\w* vidente \w de|strong="H5921"\w* Efraín profetiza sin contar \w con|strong="H5973"\w* su \nd ʼElohim\nd*. Es trampa \w de|strong="H5921"\w* cazador \w en|strong="H5921"\w* \w todos|strong="H3605"\w* sus \w caminos|strong="H1870"\w*, \w odio|strong="H4895"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w Casa|strong="H1004"\w* \w de|strong="H5921"\w* su \nd ʼElohim\nd*.
\v 9 Se corrompieron grandemente, \w como|strong="H5771"\w* en los \w días|strong="H3117"\w* de \w Gabaa|strong="H1390"\w*. Pero Él se acuerda de su culpa y castigará su \w pecado|strong="H2403"\w*.
\p 
\v 10 \wj \w Como|strong="H1961"\w* \w uvas|strong="H6025"\w* en \w el|strong="H1992"\w* \w desierto|strong="H4057"\w* \w hallé|strong="H4672"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w*. \w Como|strong="H1961"\w* la fruta temprana de la higuera encontré \w a|strong="H3068"\w* \w sus|strong="H1992"\w* antepasados. Pero \w ellos|strong="H1992"\w* \w fueron|strong="H1961"\w* \w a|strong="H3068"\w* Baal-peor y \w se|strong="H1961"\w* apartaron \w para|strong="H1961"\w* vergüenza. \w Fueron|strong="H1961"\w* tan repugnantes \w como|strong="H1961"\w* aquello \w que|strong="H1961"\w* amaron.\wj*
\v 11 \wj Como \w ave|strong="H5775"\w* \w volará|strong="H5774"\w* la \w gloria|strong="H3519"\w* de Efraín. No habrá parto, ni embarazo, ni concepción.\wj*
\v 12 \wj \w Y|strong="H3068"\w* \w aunque|strong="H3588"\w* críen \w a|strong="H3068"\w* \w sus|strong="H1992"\w* \w hijos|strong="H1121"\w*, \w los|strong="H1992"\w* \w quitaré|strong="H5493"\w* \w de|strong="H3588"\w* \w en|strong="H3588"\w* medio \w de|strong="H3588"\w* \w los|strong="H1992"\w* \w hombres|strong="H1121"\w*. ¡Ay \w de|strong="H3588"\w* \w ellos|strong="H1992"\w* \w en|strong="H3588"\w* verdad, \w cuando|strong="H3588"\w* \w Yo|strong="H3588"\w* \w me|strong="H3588"\w* \w aparte|strong="H5493"\w* \w de|strong="H3588"\w* \w ellos|strong="H1992"\w*!\wj*
\v 13 \wj Según observé, Efraín es otra \w Tiro|strong="H6865"\w* \w plantada|strong="H8362"\w* \w en|strong="H3318"\w* la pradera, pero Efraín entregará sus \w hijos|strong="H1121"\w* al verdugo.\wj*
\p 
\v 14 \w Dales|strong="H5414"\w*, \w oh|strong="H4100"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w lo|strong="H4100"\w* \w que|strong="H4100"\w* les vas \w a|strong="H3068"\w* \w dar|strong="H5414"\w*. \w Dales|strong="H5414"\w* una \w matriz|strong="H7358"\w* \w que|strong="H4100"\w* aborte y \w pechos|strong="H7699"\w* resecos.
\p 
\v 15 \wj \w Toda|strong="H3605"\w* \w su|strong="H3588"\w* \w maldad|strong="H7451"\w* ocurrió \w en|strong="H5921"\w* \w Gilgal|strong="H1537"\w*. \w Allí|strong="H8033"\w*, \w pues|strong="H3588"\w*, \w les|strong="H5921"\w* tomé aversión \w por|strong="H5921"\w* \w la|strong="H5921"\w* perversidad \w de|strong="H5921"\w* sus \w hechos|strong="H4611"\w* \w los|strong="H5921"\w* eché \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w Casa|strong="H1004"\w*. \w Ya|strong="H3068"\w* \w no|strong="H3808"\w* \w los|strong="H5921"\w* amaré \w más|strong="H3588"\w*. \w Todos|strong="H3605"\w* sus gobernantes \w son|strong="H3588"\w* desleales.\wj*
\p 
\v 16 \wj Herido está Efraín. \w Su|strong="H3588"\w* raíz está \w seca|strong="H3001"\w* \w y|strong="H1571"\w* \w no|strong="H1097"\w* da \w fruto|strong="H6529"\w*. \w Aunque|strong="H3588"\w* \w engendre|strong="H3205"\w*, \w mataré|strong="H4191"\w* \w lo|strong="H6213"\w* deseable \w de|strong="H3588"\w* sus órganos internos.\wj*
\p 
\v 17 \w Mi|strong="H1961"\w* \nd ʼElohim\nd* \w los|strong="H3588"\w* desechará, \w porque|strong="H3588"\w* ellos \w no|strong="H3808"\w* \w lo|strong="H3808"\w* \w escucharon|strong="H8085"\w*, yandarán errantes \w entre|strong="H3808"\w* las \w naciones|strong="H1471"\w*.
\c 10
\s1 Acusaciones y anuncios de juicios
\p 
\v 1 \w Vid|strong="H1612"\w* frondosa \w es|strong="H7235"\w* \w Israel|strong="H3478"\w*. \w Produce|strong="H3190"\w* \w fruto|strong="H6529"\w* para sí mismo según la \w abundancia|strong="H7230"\w* de su \w fruto|strong="H6529"\w*. Él \w aumentó|strong="H7235"\w* los \w altares|strong="H4196"\w* según la \w abundancia|strong="H7230"\w* de su tierra. Ellos embellecen sus estelas.
\v 2 \w El|strong="H1931"\w* \w corazón|strong="H3820"\w* de \w ellos|strong="H1931"\w* \w es|strong="H1931"\w* engañoso. \w Ahora|strong="H6258"\w* son hallados culpables. \w Él|strong="H1931"\w* derribará \w sus|strong="H1931"\w* \w altares|strong="H4196"\w*. \w Él|strong="H1931"\w* arruinará \w sus|strong="H1931"\w* estelas.
\p 
\v 3 \w Porque|strong="H3588"\w* \w ahora|strong="H6258"\w* dicen: \w No|strong="H3808"\w* tenemos \w rey|strong="H4428"\w*. \w No|strong="H3808"\w* respetamos \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*. \w En|strong="H3588"\w* \w cuanto|strong="H3588"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w*, ¿\w qué|strong="H3588"\w* puede \w hacer|strong="H6213"\w* \w por|strong="H3588"\w* nosotros?
\v 4 \w Hablan|strong="H1696"\w* solo \w palabras|strong="H1697"\w*. \w Con|strong="H5921"\w* juramentos falsos hacen contratos \w y|strong="H5921"\w* juran \w en|strong="H5921"\w* vano. \w El|strong="H5921"\w* \w juicio|strong="H4941"\w* crece \w como|strong="H5921"\w* hierba venenosa \w en|strong="H5921"\w* \w los|strong="H5921"\w* surcos \w del|strong="H5921"\w* \w campo|strong="H7704"\w*.
\v 5 \w Los|strong="H5921"\w* habitantes \w de|strong="H4480"\w* \w Samaria|strong="H8111"\w* temen \w a|strong="H3068"\w* causa \w del|strong="H4480"\w* becerro \w de|strong="H4480"\w* Bet-avén, \w en|strong="H5921"\w* verdad \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w* hará lamento \w por|strong="H5921"\w* \w él|strong="H5921"\w*, \w y|strong="H3588"\w* sus sacerdotes idólatras llorarán \w por|strong="H5921"\w* \w él|strong="H5921"\w*, \w porque|strong="H3588"\w* salió \w de|strong="H4480"\w* \w él|strong="H5921"\w* \w su|strong="H3588"\w* \w gloria|strong="H3519"\w*.
\v 6 Será \w llevado|strong="H2986"\w* \w a|strong="H3068"\w* Asiria \w como|strong="H1571"\w* \w presente|strong="H4503"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w* \w Jareb|strong="H3377"\w*. \w La|strong="H1571"\w* vergüenza se adueña de Efraín. \w Israel|strong="H3478"\w* se avergüenza de su propia decisión.
\p 
\v 7 \w El|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Samaria|strong="H8111"\w* es destruido, \w como|strong="H5921"\w* una astilla \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w agua|strong="H4325"\w*.
\v 8 \w Los|strong="H5921"\w* lugares \w altos|strong="H1116"\w* \w de|strong="H5921"\w* Avén, \w pecado|strong="H2403"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, serán \w destruidos|strong="H8045"\w*, \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* sus \w altares|strong="H4196"\w* \w crecerán|strong="H5927"\w* \w espinos|strong="H6975"\w* \w y|strong="H5921"\w* cardos. Entonces dirán \w a|strong="H3068"\w* \w las|strong="H5921"\w* montañas: ¡Cúbrannos! \w Y|strong="H3068"\w* \w a|strong="H3068"\w* \w las|strong="H5921"\w* colinas: ¡\w Caigan|strong="H5307"\w* \w sobre|strong="H5921"\w* \w nosotros|strong="H5921"\w*!
\p 
\v 9 \wj \w Desde|strong="H5921"\w* \w los|strong="H1121"\w* \w días|strong="H3117"\w* \w de|strong="H5921"\w* \w Gabaa|strong="H1390"\w* pecaste, \w oh|strong="H1121"\w* \w Israel|strong="H3478"\w*. \w Allí|strong="H8033"\w* están firmes. ¿\w La|strong="H5921"\w* \w batalla|strong="H4421"\w* \w de|strong="H5921"\w* \w Gabaa|strong="H1390"\w* \w contra|strong="H5921"\w* \w los|strong="H1121"\w* inicuos \w no|strong="H3808"\w* \w los|strong="H1121"\w* \w alcanzó|strong="H5381"\w*? \wj*
\v 10 \wj Cuando \w lo|strong="H5921"\w* desee, \w los|strong="H5921"\w* \w castigaré|strong="H3256"\w*. \w Los|strong="H5921"\w* \w pueblos|strong="H5971"\w* \w se|strong="H5921"\w* reunirán \w contra|strong="H5921"\w* \w ellos|strong="H5921"\w* cuando sean atados \w por|strong="H5921"\w* sus \w dos|strong="H8147"\w* transgresiones.\wj*
\v 11 \wj Efraín es una \w novilla|strong="H5697"\w* domesticada \w a|strong="H3068"\w* \w la|strong="H5921"\w* cual \w le|strong="H5921"\w* gusta trillar. Yo puse \w el|strong="H5921"\w* \w yugo|strong="H5921"\w* \w de|strong="H5921"\w* \w bondad|strong="H2898"\w* \w sobre|strong="H5921"\w* su hermoso \w cuello|strong="H6676"\w*. \w A|strong="H3068"\w* Efraín \w le|strong="H5921"\w* pondré \w el|strong="H5921"\w* \w yugo|strong="H5921"\w*. \w Judá|strong="H3063"\w* tirará \w el|strong="H5921"\w* arado. \w Jacob|strong="H3290"\w* desmenuzará \w los|strong="H5921"\w* terrones.\wj*
\p 
\v 12 Siembren \w para|strong="H5704"\w* ustedes \w justicia|strong="H6664"\w*. Cosechen \w para|strong="H5704"\w* ustedes \w misericordia|strong="H2617"\w*. Aren \w para|strong="H5704"\w* ustedes \w barbecho|strong="H5214"\w*,\f + \fr 10:12 \ft Barbecho: tierra labrantía que no se siembra durante uno o más años.\f* pues es \w tiempo|strong="H6256"\w* \w de|strong="H5704"\w* buscar \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w hasta|strong="H5704"\w* \w que|strong="H5704"\w* Él venga \w y|strong="H5704"\w* haga llover \w justicia|strong="H6664"\w* sobre ustedes.
\p 
\v 13 \w Araron|strong="H2790"\w* perversidad, cosecharon \w iniquidad|strong="H5766"\w*, comieron \w el|strong="H3588"\w* \w fruto|strong="H6529"\w* \w de|strong="H3588"\w* mentiras. \w Porque|strong="H3588"\w* ustedes confiaron \w en|strong="H3588"\w* \w su|strong="H3588"\w* propio \w camino|strong="H1870"\w* \w y|strong="H3588"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* \w multitud|strong="H7230"\w* \w de|strong="H3588"\w* sus \w valientes|strong="H1368"\w*.
\v 14 \w Por|strong="H5921"\w* \w tanto|strong="H5921"\w*, un tumulto surgirá \w entre|strong="H5921"\w* tu \w pueblo|strong="H5971"\w*, \w y|strong="H5921"\w* \w todas|strong="H3605"\w* tus fortalezas serán destruidas. \w Y|strong="H3068"\w* \w Como|strong="H5921"\w* \w Salmán|strong="H8020"\w* destruyó \w a|strong="H3068"\w* Bet-arbel \w el|strong="H5921"\w* \w día|strong="H3117"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w batalla|strong="H4421"\w*, \w la|strong="H5921"\w* madre fue destrozada \w con|strong="H5921"\w* sus \w hijos|strong="H1121"\w*.
\v 15 \w Así|strong="H3602"\w* se \w hará|strong="H6213"\w* con ustedes, Bet-ʼEl, \w por|strong="H6440"\w* \w causa|strong="H6440"\w* \w de|strong="H6440"\w* su gran \w maldad|strong="H7451"\w*. \w Al|strong="H4428"\w* rayar \w el|strong="H1008"\w* alba \w será|strong="H6213"\w* \w cortado|strong="H1820"\w* completamente \w el|strong="H1008"\w* \w rey|strong="H4428"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*.
\c 11
\s1 El amor de \nd ʼElohim\nd* hacia Israel
\p 
\v 1 \wj \w Cuando|strong="H3588"\w* \w Israel|strong="H3478"\w* \w era|strong="H1121"\w* un \w muchacho|strong="H5288"\w*, \w Yo|strong="H3588"\w* lo amé, \w y|strong="H3588"\w* \w de|strong="H3588"\w* \w Egipto|strong="H4714"\w* \w llamé|strong="H7121"\w* \w a|strong="H3068"\w* mi \w hijo|strong="H1121"\w*.\wj*
\v 2 \wj \w Cuanto|strong="H3651"\w* más los \w llamaba|strong="H7121"\w*, \w tanto|strong="H3651"\w* más \w se|strong="H3651"\w* alejaban \w de|strong="H6440"\w* mi \w Presencia|strong="H6440"\w*. Continuaban los \w sacrificios|strong="H2076"\w* \w a|strong="H3068"\w* los baales y quemaban incienso \w a|strong="H3068"\w* los \w ídolos|strong="H6456"\w*.\wj*
\p 
\v 3 \wj \w Pero|strong="H3588"\w* \w fui|strong="H3808"\w* \w Yo|strong="H3588"\w* Quien enseñó \w a|strong="H3068"\w* andar \w a|strong="H3068"\w* Efraín. \w Los|strong="H5921"\w* \w tomé|strong="H3947"\w* \w por|strong="H5921"\w* sus \w brazos|strong="H2220"\w*. \w Sin|strong="H3808"\w* embargo, \w no|strong="H3808"\w* reconocieron \w que|strong="H3588"\w* \w Yo|strong="H3588"\w* \w los|strong="H5921"\w* sanaba.\wj*
\v 4 \wj \w Los|strong="H5921"\w* atraje \w con|strong="H5921"\w* \w cuerdas|strong="H5688"\w* humanas, \w con|strong="H5921"\w* correas \w de|strong="H5921"\w* amor. \w Fui|strong="H1961"\w* \w para|strong="H5921"\w* \w ellos|strong="H5921"\w* \w como|strong="H1961"\w* \w el|strong="H5921"\w* \w que|strong="H5921"\w* \w quita|strong="H7311"\w* \w el|strong="H5921"\w* \w yugo|strong="H5923"\w* \w de|strong="H5921"\w* su nuca. \w Me|strong="H5921"\w* \w incliné|strong="H5186"\w* \w y|strong="H5921"\w* \w los|strong="H5921"\w* alimenté.\wj*
\p 
\v 5 \wj \w No|strong="H3808"\w* regresará \w a|strong="H3068"\w* \w la|strong="H1931"\w* tierra \w de|strong="H3588"\w* \w Egipto|strong="H4714"\w*, \w pero|strong="H3588"\w* \w el|strong="H1931"\w* asirio \w será|strong="H1931"\w* \w su|strong="H1931"\w* \w rey|strong="H4428"\w*, \w porque|strong="H3588"\w* rehusaron convertirse.\wj*
\v 6 \wj La \w espada|strong="H2719"\w* blandirá contra sus \w ciudades|strong="H5892"\w*, y demolerá los cerrojos de sus puertas, porque siguieron sus propios planes.\wj*
\v 7 \wj Mi \w pueblo|strong="H5971"\w* está inclinado \w a|strong="H3068"\w* \w apartarse|strong="H3808"\w* \w de|strong="H5971"\w* Mí. \w Aunque|strong="H3808"\w* me \w llaman|strong="H7121"\w* el Altísimo, \w ninguno|strong="H3808"\w* en absoluto me exalta.\wj*
\p 
\v 8 \wj ¿\w Cómo|strong="H5921"\w* puedo abandonarte, oh Efraín? ¿\w Cómo|strong="H5921"\w* puedo entregarte, oh \w Israel|strong="H3478"\w*? ¿\w Cómo|strong="H5921"\w* puedo hacerte \w como|strong="H5921"\w* Adma? ¿\w Cómo|strong="H5921"\w* puedo tratarte \w como|strong="H5921"\w* \w a|strong="H3068"\w* Zeboim? \w Se|strong="H5921"\w* \w me|strong="H5921"\w* conmueve \w el|strong="H5921"\w* \w corazón|strong="H3820"\w* \w dentro|strong="H5921"\w* \w de|strong="H5921"\w* \w Mí|strong="H5921"\w*, \w se|strong="H5921"\w* enternece \w toda|strong="H5921"\w* \w mi|strong="H5921"\w* compasión.\wj*
\v 9 \wj \w No|strong="H3808"\w* \w me|strong="H3588"\w* \w volveré|strong="H7725"\w* \w para|strong="H3588"\w* \w destruir|strong="H7843"\w* \w a|strong="H3068"\w* Efraín, \w por|strong="H3588"\w* \w cuanto|strong="H3588"\w* \w Yo|strong="H3588"\w* soy \nd \w ʼEL|strong="H3588"\w*\nd*, \w y|strong="H3588"\w* \w no|strong="H3808"\w* hombre, \w el|strong="H3588"\w* \w Santo|strong="H6918"\w* \w en|strong="H3588"\w* \w medio|strong="H7130"\w* \w de|strong="H3588"\w* ti, \w y|strong="H3588"\w* \w no|strong="H3808"\w* vendré \w con|strong="H3588"\w* \w furor|strong="H2740"\w*.\wj*
\p 
\v 10 \wj \w Caminarán|strong="H3212"\w* tras \nd \w Yavé|strong="H3068"\w*\nd*. \w Él|strong="H1931"\w* \w rugirá|strong="H7580"\w* \w como|strong="H3588"\w* un león. \w Cuando|strong="H3588"\w* ruja, \w sus|strong="H1931"\w* \w hijos|strong="H1121"\w* vendrán temblorosos desde occidente.\wj*
\v 11 \wj \w Desde|strong="H5921"\w* \w Egipto|strong="H4714"\w* vendrán temblorosos \w como|strong="H5921"\w* pájaros, \w desde|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* Asiria, \w como|strong="H5921"\w* palomas, \w y|strong="H5921"\w* vivirán \w en|strong="H5921"\w* sus \w casas|strong="H1004"\w*, \wj*\w dice|strong="H5002"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\p 
\v 12 \wj Efraín me rodeó de mentiras, la Casa de Israel, de falsedad. Judá aún divaga contra \nd ʼEL\nd*, contra el Santo, Quien es Fiel.\wj*
\c 12
\s1 Promesa
\p 
\v 1 Efraín se apacienta \w de|strong="H5973"\w* viento, y persigue al viento \w del|strong="H5973"\w* este. Mentiras y destrucción aumentan continuamente. \w Además|strong="H5750"\w* hizo un pacto \w con|strong="H5973"\w* Asiria, y lleva \w el|strong="H5973"\w* aceite \w de|strong="H5973"\w* Egipto.
\p 
\v 2 \nd \w Yavé|strong="H3068"\w*\nd* tiene pleito \w con|strong="H5973"\w* Judá. Castigará \w a|strong="H3068"\w* Jacob conforme \w a|strong="H3068"\w* sus caminos. \w Le|strong="H5973"\w* pagará según sus obras.
\v 3 \w En|strong="H5921"\w* \w el|strong="H5921"\w* vientre tomó \w por|strong="H5921"\w* \w el|strong="H5921"\w* talón \w a|strong="H3068"\w* su hermano, \w y|strong="H5921"\w* \w en|strong="H5921"\w* su madurez luchó \w con|strong="H5973"\w* \nd ʼElohim\nd*.
\v 4 Luchó con el Ángel y prevaleció. Lloró, y le imploró gracia. En Bet-ʼEl lo encontró, y allí habló con nosotros.
\v 5 ¡Sí, \nd \w Yavé|strong="H3068"\w*\nd* es \w el|strong="H5973"\w* \nd ʼElohim\nd* \w de|strong="H5973"\w* las huestes! ¡\nd \w Yavé|strong="H3068"\w*\nd* es su \w nombre|strong="H8033"\w*!
\v 6 Tú, pues, devuélvete hacia tu \nd ʼElohim\nd*. Practica la bondad y la justicia, y espera siempre en tu \nd ʼElohim\nd*.
\p 
\v 7 Mercader que tiene en su mano balanza falsa es amigo de oprimir.
\v 8 Dijo Efraín: Me enriquecí ciertamente. Hallé riqueza para mí. En todas mis labores no hallarán en mí alguna iniquidad \w que|strong="H3027"\w* sea pecado.
\p 
\v 9 \wj \w Sin|strong="H3808"\w* embargo, desde \w la|strong="H3605"\w* tierra de Egipto Yo soy \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd*. \w Aún|strong="H3808"\w* te haré vivir en tiendas, \w como|strong="H5771"\w* en \w los|strong="H3605"\w* días de \w la|strong="H3605"\w* solemnidad.\wj*
\v 10 \wj Porque \w también|strong="H5750"\w* hablé \w a|strong="H3068"\w* \w los|strong="H3427"\w* profetas. Multipliqué visiones y \w por|strong="H5750"\w* medio \w de|strong="H5750"\w* \w los|strong="H3427"\w* profetas expuse parábolas.\wj*
\p 
\v 11 ¿Hay iniquidad \w en|strong="H5921"\w* Galaad? Solo son vanidad. \w En|strong="H5921"\w* Gilgal \w sacrificaban|strong="H5921"\w* becerros, pero sus altares son \w como|strong="H5921"\w* pilas \w de|strong="H5921"\w* piedras \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* surcos \w del|strong="H5921"\w* campo.
\v 12 Huyó Jacob \w a|strong="H3068"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* Aram. Israel sirvió \w para|strong="H5921"\w* adquirir esposa, \w y|strong="H1571"\w* \w por|strong="H5921"\w* una esposa cuidó ovejas.
\v 13 Por medio de un profeta \nd \w Yavé|strong="H3068"\w*\nd* sacó \w a|strong="H3068"\w* \w Israel|strong="H3478"\w* de Egipto, y por medio de un profeta fue preservado.
\v 14 Efraín lo provocó \w a|strong="H3068"\w* amarga \w ira|strong="H5927"\w*. Por tanto, \nd ʼAdonay\nd* dejará sobre \w él|strong="H5030"\w* \w la|strong="H8104"\w* culpa de sangre y \w hará|strong="H8104"\w* volver sobre \w él|strong="H5030"\w* su oprobio.
\c 13
\s1 Acusación y juicio
\p 
\v 1 Cuando Efraín \w hablaba|strong="H1696"\w*, había temor. \w Era|strong="H1931"\w* exaltado en \w Israel|strong="H3478"\w*, pero pecó por causa de \w baal|strong="H1168"\w* y \w murió|strong="H4191"\w*.
\v 2 \w Y|strong="H3068"\w* \w ahora|strong="H6258"\w* \w añadieron|strong="H3254"\w* \w a|strong="H3068"\w* \w su|strong="H1992"\w* \w pecado|strong="H2398"\w*. \w Se|strong="H1992"\w* \w hacen|strong="H6213"\w* \w imágenes|strong="H4541"\w* fundidas. Con \w su|strong="H1992"\w* \w plata|strong="H3701"\w* \w hacen|strong="H6213"\w* \w imágenes|strong="H4541"\w* fundidas, \w ídolos|strong="H6091"\w*, según \w su|strong="H1992"\w* \w entendimiento|strong="H8394"\w*, \w todos|strong="H3605"\w* \w ellos|strong="H1992"\w*, \w obra|strong="H4639"\w* de artesano. \w Les|strong="H1992"\w* dicen \w a|strong="H3068"\w* \w los|strong="H1992"\w* hombres \w que|strong="H6258"\w* \w sacrifican|strong="H2076"\w* \w que|strong="H6258"\w* besen \w los|strong="H1992"\w* \w becerros|strong="H5695"\w*.
\v 3 \w Por|strong="H3651"\w* \w tanto|strong="H3651"\w*, \w serán|strong="H1961"\w* \w como|strong="H1961"\w* la niebla de la \w mañana|strong="H1242"\w*, \w como|strong="H1961"\w* el \w rocío|strong="H2919"\w* del amanecer \w que|strong="H1961"\w* pronto desaparece, \w como|strong="H1961"\w* la concha del trigo soplada de la \w era|strong="H1961"\w* \w por|strong="H3651"\w* el viento, \w como|strong="H1961"\w* el \w humo|strong="H6227"\w* de la chimenea.
\p 
\v 4 \wj Pero desde la tierra \w de|strong="H2108"\w* \w Egipto|strong="H4714"\w* Yo soy \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd*, y tú \w no|strong="H3808"\w* tendrás \tl ʼelohim\tl*, aparte \w de|strong="H2108"\w* \w Mí|strong="H1115"\w*, \w porque|strong="H3808"\w* \w no|strong="H3808"\w* hay \w Salvador|strong="H3467"\w* \w sino|strong="H2108"\w* Yo.\wj*
\v 5 \wj Yo te \w conocí|strong="H3045"\w* en el \w desierto|strong="H4057"\w*, en tierra de sequedad.\wj*
\v 6 \wj Cuando comieron su \w pasto|strong="H4830"\w* quedaron satisfechos. \w Se|strong="H5921"\w* llenaron \w y|strong="H5921"\w* \w se|strong="H5921"\w* exaltó su \w corazón|strong="H3820"\w*. \w Por|strong="H5921"\w* \w esta|strong="H3651"\w* causa \w se|strong="H5921"\w* \w olvidaron|strong="H7911"\w* \w de|strong="H5921"\w* \w Mí|strong="H5921"\w*.\wj*
\v 7 \wj \w Por|strong="H5921"\w* \w tanto|strong="H3644"\w*, \w seré|strong="H1961"\w* \w para|strong="H5921"\w* \w ellos|strong="H5921"\w* \w como|strong="H3644"\w* un \w león|strong="H7826"\w*. j \w Los|strong="H5921"\w* acecharé \w como|strong="H3644"\w* leopardo \w junto|strong="H5921"\w* \w al|strong="H5921"\w* \w camino|strong="H1870"\w*.\wj*
\v 8 \wj Los asaltaré como osa \w a|strong="H3068"\w* la cual le robaron las crías, y desgarraré la cobertura de sus corazones. Los devoraré como una leona y las fieras del \w campo|strong="H7704"\w* los despedazarán.\wj*
\p 
\v 9 \wj Tu rebelión \w contra|strong="H3478"\w* Mí, tu Ayudador, oh \w Israel|strong="H3478"\w*, \w es|strong="H3588"\w* tu destrucción.\wj*
\v 10 \wj ¿Dónde está \w tu|strong="H8199"\w* \w rey|strong="H4428"\w* \w para|strong="H5414"\w* \w que|strong="H3605"\w* te \w salve|strong="H3467"\w* en \w todas|strong="H3605"\w* tus \w ciudades|strong="H5892"\w*? ¿\w Y|strong="H3068"\w* tus \w jueces|strong="H8199"\w*, \w a|strong="H3068"\w* \w los|strong="H3605"\w* cuales dijiste: Denme un \w rey|strong="H4428"\w* y \w capitán|strong="H8269"\w*?\wj*
\v 11 \wj En mi furor te \w di|strong="H5414"\w* un \w rey|strong="H4428"\w*, y en mi ira te lo quité.\wj*
\p 
\v 12 \wj \w Atada|strong="H6887"\w* está la \w maldad|strong="H5771"\w* \w a|strong="H3068"\w* Efraín. Su \w pecado|strong="H2403"\w* está bien guardado.\wj*
\v 13 \wj \w Le|strong="H1931"\w* vendrán \w dolores|strong="H2256"\w* \w de|strong="H3588"\w* mujer \w que|strong="H3588"\w* \w está|strong="H1931"\w* \w de|strong="H3588"\w* parto. \w Él|strong="H1931"\w* \w es|strong="H1931"\w* un \w hijo|strong="H1121"\w* necio \w que|strong="H3588"\w* \w no|strong="H3808"\w* llegó \w a|strong="H3068"\w* \w tiempo|strong="H6256"\w* \w a|strong="H3068"\w* \w la|strong="H1931"\w* apertura del vientre.\wj*
\p 
\v 14 \wj ¿Los libraré del \w poder|strong="H3027"\w* del \tl Seol\tl*? ¿Los \w redimiré|strong="H1350"\w* \w de|strong="H5869"\w* la \w muerte|strong="H4194"\w*? ¿Dónde está, oh \w muerte|strong="H4194"\w*, tu \w pestilencia|strong="H1698"\w*? ¿Dónde, oh \w sepulcro|strong="H7585"\w*, tu destrucción? \wj*
\p \wj La compasión estará escondida \w de|strong="H5869"\w* mis \w ojos|strong="H5869"\w*.\wj*
\v 15 \wj \w Aunque|strong="H3588"\w* \w él|strong="H1931"\w* fructifique \w entre|strong="H3588"\w* \w sus|strong="H1931"\w* hermanos, \w vendrá|strong="H5927"\w* un \w viento|strong="H7307"\w* del \w este|strong="H1931"\w*. \w El|strong="H1931"\w* \w viento|strong="H7307"\w* \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w subirá|strong="H5927"\w* del \w desierto|strong="H4057"\w*. \w Entonces|strong="H3588"\w* \w su|strong="H1931"\w* \w manantial|strong="H4726"\w* \w se|strong="H1931"\w* secará. \w Se|strong="H1931"\w* agotará \w su|strong="H1931"\w* \w fuente|strong="H4599"\w*. \w Él|strong="H1931"\w* despojará \w el|strong="H1931"\w* tesoro \w de|strong="H3588"\w* \w todos|strong="H3605"\w* \w sus|strong="H1931"\w* objetos preciosos\wj*
\v 16 \wj Porque se rebeló contra su \nd ʼElohim\nd*. Culpable de castigo es Samaria. Ellos caerán por la espada. Sus bebés serán estrellados, y sus esposas embarazadas desgarradas.\wj*
\c 14
\s1 Restauración
\p 
\v 1 ¡Oh Israel, regresa \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd*, \w pues|strong="H3588"\w* \w caíste|strong="H5307"\w* \w a|strong="H3068"\w* causa \w de|strong="H3588"\w* tu iniquidad!
\v 2 Tomen palabras \w y|strong="H3588"\w* regresen \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*. Díganle: \w Quita|strong="H7725"\w* toda \w iniquidad|strong="H5771"\w*, acéptanos \w con|strong="H3588"\w* benevolencia. \w Te|strong="H3588"\w* ofreceremos \w el|strong="H3588"\w* fruto \w de|strong="H3588"\w* nuestros labios.
\v 3 Asiria no nos salvará. No montaremos \w en|strong="H5973"\w* caballos, \w ni|strong="H5973"\w* diremos nunca más \w a|strong="H3068"\w* \w la|strong="H3605"\w* obra \w de|strong="H5973"\w* nuestras manos: ustedes son nuestro \nd ʼElohim\nd*. Porque \w en|strong="H5973"\w* \w ti|strong="H5973"\w* \w el|strong="H5973"\w* huérfano halla misericordia.
\p 
\v 4 \wj Sanaré su apostasía. \w Los|strong="H5921"\w* amaré \w por|strong="H5921"\w* gracia, \w porque|strong="H5921"\w* \w mi|strong="H5921"\w* ira \w se|strong="H5921"\w* apartó \w de|strong="H5921"\w* \w ellos|strong="H3027"\w*.\wj*
\v 5 \wj Seré \w para|strong="H3588"\w* Israel \w como|strong="H3588"\w* \w el|strong="H3588"\w* rocío. Florecerá \w como|strong="H3588"\w* \w el|strong="H3588"\w* lirio \w y|strong="H3588"\w* extenderá sus raíces \w como|strong="H3588"\w* \w el|strong="H3588"\w* Líbano.\wj*
\v 6 \wj \w Se|strong="H1961"\w* extenderán sus ramas. Su esplendor \w será|strong="H1961"\w* \w como|strong="H1961"\w* el del olivo, y exhalará su fragancia \w como|strong="H1961"\w* el \w Líbano|strong="H3844"\w*.\wj*
\v 7 \wj Regresarán y \w se|strong="H1961"\w* sentarán bajo su sombra. \w Serán|strong="H1961"\w* revividos \w como|strong="H1961"\w* el grano y crecerán \w como|strong="H1961"\w* una vid. Su aroma \w será|strong="H1961"\w* \w como|strong="H1961"\w* la del \w vino|strong="H3212"\w* del \w Líbano|strong="H3844"\w*.\wj*
\v 8 \wj Efraín dirá: ¿Qué \w más|strong="H2421"\w* tengo yo que hacer con ídolos? Yo responderé y velaré por ti. Soy como un exuberante ciprés. De mí viene tu fruto.\wj*
\p 
\v 9 El \w que|strong="H4100"\w* es sabio, \w que|strong="H4100"\w* entienda estas cosas. El \w que|strong="H4100"\w* sea prudente \w que|strong="H4100"\w* las sepa. \w Porque|strong="H4100"\w* los caminos \w de|strong="H4480"\w* \nd \w Yavé|strong="H3068"\w*\nd* son rectos, el justo andará \w en|strong="H4480"\w* \w ellos|strong="H4480"\w*, pero los transgresores tropezarán \w en|strong="H4480"\w* \w ellos|strong="H4480"\w*. 
