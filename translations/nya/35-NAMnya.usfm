\id NAM - Biblica® Open God’s Word in Contemporary Chichewa 2016
\h NAHUMU
\toc1 Nahumu
\toc2 Nahumu
\toc3 Nah
\mt1 Nahumu
\c 1
\p 
\v 1 Uthenga wonena za Ninive. Buku la masomphenya a Nahumu wa ku Elikosi.
\s1 Mkwiyo wa Yehova pa Ninive
\q1 
\v 2 Yehova ndi Mulungu wansanje
\q1 ndiponso wobwezera;
\q2 Yehova amabwezera ndipo ndi waukali.
\q1 Yehova amabwezera adani ake
\q2 ndipo ukali wake umakhala nthawi zonse pa adani akewo.
\q1 
\v 3 Yehova sakwiya msanga koma ndi wa mphamvu yayikulu;
\q2 ndipo sadzalola kuti munthu
\q2 wolakwa asalangidwe.
\q1 Iye amayenda mʼkamvuluvulu ndi mʼnamondwe,
\q2 ndipo mitambo ndi fumbi la ku mapazi ake.
\q1 
\v 4 Amalamulira nyanja ndipo imawuma;
\q1 amawumitsa mitsinje yonse.
\q1 Zomera za ku Basani ndi Karimeli zimawuma
\q2 ndipo maluwa a ku Lebanoni amafota.
\q1 
\v 5 Mapiri amagwedera pamaso pake
\q1 ndipo zitunda zimasungunuka.
\q1 Dziko lapansi limanjenjemera pamaso pake,
\q2 dziko lonse ndi zonse zokhala mʼmenemo.
\q1 
\v 6 Ndani angathe kuyima pamaso pake Iye akalusa?
\q2 Ndani angapirire mkwiyo wake woopsa?
\q1 Ukali wake ukuyaka ngati moto;
\q2 matanthwe akunyeka pamaso pake.
\b
\q1 
\v 7 Yehova ndi wabwino,
\q2 ndiye kothawirako nthawi ya masautso.
\q1 Amasamalira amene amamudalira,
\q1 
\v 8 koma ndi madzi achigumula choopsa
\q1 Iye adzawononga adani ake (Ninive);
\q2 adzapirikitsira adani ake ku malo a mdima.
\b
\q1 
\v 9 Chiwembu chilichonse chimene akukonzekera kumuchitira Yehova
\q2 adzachiwononga kotheratu;
\q2 msautso sudzabweranso kachiwiri.
\q1 
\v 10 Iwo adzakodwa mu ziyangoyango za minga
\q2 ndipo adzaledzera ndi vinyo wawo;
\q2 adzatenthedwa ngati ziputu zowuma.
\q1 
\v 11 Kwa iwe, Ninive, kunachokera munthu wa cholinga choyipa,
\q2 wofuna kuchitira Yehova chiwembu,
\q2 amene amapereka uphungu woyipa.
\q1 
\v 12 Yehova akuti,
\q1 “Ngakhale Asiriyawo ali ndi abwenzi,
\q2 kaya iwowo ndi ambiri,
\q2 koma adzawonongedwa ndi kutheratu.
\q1 Ngakhale ndinakuzunza iwe Yuda,
\q2 sindidzakuzunzanso.
\q1 
\v 13 Tsopano ndidzathyola goli lake pa khosi lako
\q2 ndipo ndidzadula maunyolo ako.”
\b
\q1 
\v 14 Yehova walamulira za iwe, Ninive kuti,
\q2 “Sudzakhala ndi zidzukulu
\q2 zimene zidzadziwike ndi dzina lako.
\q1 Ndidzawononga zifanizo zosema ndi mafano owumba
\q2 amene ali mʼnyumba ya milungu yako.
\q1 Ine ndidzakukumbira manda
\q2 chifukwa ndiwe woyipitsitsa.”
\q1 
\v 15 Taonani, pa phiripo,
\q2 mapazi a munthu amene akubweretsa nkhani yabwino,
\q2 amene akulengeza za mtendere!
\q1 Inu anthu a ku Yuda, chitani madyerero anu
\q2 ndipo kwaniritsani malumbiro anu.
\q1 Anthu oyipa sadzakuthiraninso nkhondo;
\q2 iwo adzawonongedwa kotheratu.
\c 2
\s1 Kugwa kwa Ninive
\q1 
\v 1 Wodzathira nkhondo akubwera
\q2 kudzalimbana nawe, Ninive.
\q2 Tetezani malinga anu,
\q2 dziyangʼanani ku msewu,
\q2 konzekerani nkhondo,
\q2 valani dzilimbe.
\q1 
\v 2 Yehova adzabwezeretsa ulemerero wa Yakobo
\q2 ngati ulemerero wa Israeli,
\q1 ngakhale anthu owononga anawawononga kotheratu
\q2 ndipo anawononganso mpesa wawo.
\b
\q1 
\v 3 Zishango za ankhondo ake ndi zofiira;
\q2 asilikali ake avala zovala zofiirira.
\q1 Zitsulo za pa magaleta zikunyezimira
\q2 tsiku la kukonzekera kwake.
\q2 Akuonetsa mikondo ya mkungudza yonoledwa.
\q1 
\v 4 Magaleta akuthamanga mʼmisewu
\q2 akungothamangathamanga pa mabwalo.
\q1 Akuoneka ngati miyuni yoyaka;
\q2 akuthamanga ngati chingʼaningʼani.
\b
\q1 
\v 5 Iye akuyitanitsa asilikali ake wolemekezeka,
\q2 koma iwo akubwera napunthwa.
\q1 Akuthamangira ku linga la mzinda;
\q2 akuyimika chodzitchinjirizira pamalo pake.
\q1 
\v 6 Atsekula zipata zotchinga madzi a mu mtsinje
\q2 ndipo nyumba yaufumu yagwa.
\q1 
\v 7 Zatsimikizika kuti mzinda
\q2 utengedwa ndi kupita ku ukapolo.
\q1 Akapolo aakazi akulira ngati nkhunda
\q2 ndipo akudziguguda pachifuwa.
\q1 
\v 8 Ninive ali ngati dziwe,
\q2 ndipo madzi ake akutayika.
\q1 Iwo akufuwula kuti, “Imani! Imani!”
\q2 Koma palibe amene akubwerera.
\q1 
\v 9 Funkhani siliva!
\q2 Funkhani golide!
\q1 Katundu wake ndi wochuluka kwambiri,
\q2 chuma chochokera pa zinthu zake zamtengowapatali!
\q1 
\v 10 Iye wawonongedwa, wafunkhidwa ndipo wavulidwa!
\q2 Mitima yasweka, mawondo akuwombana,
\q2 anthu akunjenjemera ndipo
\q2 nkhope zasandulika ndi mantha.
\b
\q1 
\v 11 Kodi tsopano dzenje la mikango lili kuti,
\q2 malo amene mikango inkadyetserako ana ake,
\q1 kumene mkango waumuna ndi waukazi unkapitako,
\q2 ndipo ana a mkango sankaopa kanthu kalikonse?
\q1 
\v 12 Mkango waumuna unkapha nyama yokwanira ana ake
\q2 ndiponso kuphera nyama mkango waukazi,
\q1 kudzaza phanga lake ndi zimene wapha
\q2 ndiponso dzenje lake ndi nyama imene waphayo.
\b
\q1 
\v 13 Yehova Wamphamvuzonse akuti,
\q2 “Ine ndikutsutsana nawe.
\q1 Ndidzatentha magaleta ako mpaka utsi tolotolo,
\q2 ndipo lupanga lidzapha mikango yako yayingʼono;
\q1 sindidzakusiyira chilichonse choti udye pa dziko lapansi.
\q1 Mawu a amithenga anu sadzamvekanso.”
\c 3
\s1 Tsoka la Ninive
\q1 
\v 1 Tsoka kwa mzinda wopha anthu,
\q2 mzinda wodzaza ndi mabodza,
\q1 mzinda wodzaza ndi anthu olanda zinthu anzawo,
\q2 mu mzinda mʼmene simusowa anthu osautsidwa nthawi zonse!
\q1 
\v 2 Kulira kwa zikwapu,
\q2 mkokomo wa mikombero,
\q1 kufuwula kwa akavalo
\q2 ndiponso phokoso la magaleta!
\q1 
\v 3 Kuthamanga kwa anthu okwera pa akavalo,
\q2 kungʼanima kwa malupanga
\q2 ndi kunyezimira kwa mikondo!
\q1 Anthu ambiri ophedwa,
\q2 milumilu ya anthu akufa,
\q1 mitembo yosawerengeka,
\q2 anthu akupunthwa pa mitemboyo.
\q1 
\v 4 Zonsezi ndi chifukwa cha zilakolako za mkazi wachiwerewere,
\q2 wokopa anthu uja, mkazi wochita zamatsenga,
\q1 amene anakopa mitundu ya anthu ndi zachiwerewere zake,
\q2 ndiponso anthu a mitundu ina ndi zaufiti zake.
\b
\q1 
\v 5 Yehova Wamphamvuzonse akuti,
\q1 “Ine ndikutsutsana nawe.
\q2 Ndidzakuvula chovala chako.
\q1 Anthu a mitundu ina ndidzawaonetsa umaliseche wako
\q2 ndipo udzachita manyazi pamaso pa maufumu onse.
\q1 
\v 6 Ndidzakuthira zonyansa,
\q2 ndidzakuchititsa manyazi
\q2 ndiponso kukusandutsa chinthu choseketsa.
\q1 
\v 7 Onse amene adzakuona adzakuthawa ndipo adzati,
\q2 ‘Ninive wasanduka bwinja,
\q2 adzamulira ndani?’
\q1 Kodi ndingamupeze kuti munthu woti nʼkukutonthoza?”
\b
\q1 
\v 8 Kodi ndiwe wopambana Tebesi,
\q2 mzinda wokhala mʼmbali mwa Nailo,
\q2 wozunguliridwa ndi madzi?
\q1 Mtsinjewo unali chitetezo chake,
\q2 madziwo anali linga lake.
\q1 
\v 9 Mphamvu zake zinali Kusi ndi Igupto,
\q2 Puti ndi Libiya anali ena mwa abwenzi ake.
\q1 
\v 10 Komabe anthu a ku Tebesi anagwidwa
\q2 ndipo anapita ku ukapolo.
\q1 Ana ake anawaphwanyitsa pansi
\q2 mʼmisewu yonse ya mu mzindamo.
\q1 Anachita maere ogawana anthu ake otchuka,
\q2 ndipo anthu ake onse amphamvu
\q2 anamangidwa ndi maunyolo.
\q1 
\v 11 Iwenso Ninive udzaledzera;
\q2 udzabisala
\q2 ndipo udzafunafuna malo othawirako kuopa mdani.
\b
\q1 
\v 12 Malo ako onse otetezedwa ali ngati mitengo ya mkuyu
\q2 yokhala ndi zipatso zoyambirira kucha;
\q2 pamene agwedeza mitengoyo,
\q2 nkhuyuzo zimagwera mʼkamwa mwa wofuna kuzidya.
\q1 
\v 13 Tayangʼana ankhondo ako,
\q2 onse ali ngati akazi!
\q1 Zipata za dziko lako zatsekukira adani ako;
\q2 moto wapsereza mipiringidzo yake.
\b
\q1 
\v 14 Tungani madzi woti mudzamwe nthawi ya kuzunguliridwa kwanu,
\q2 limbitsani chitetezo chanu!
\q1 Pondani dothi,
\q2 ikani mʼchikombole,
\q2 konzani khoma la njerwa!
\q1 
\v 15 Kumeneko moto udzakupserezani;
\q2 lupanga lidzakukanthani
\q2 ndipo lidzakuwonongani ngati likuwononga ziwala.
\q1 Chulukanani ngati ziwala,
\q2 chulukanani ngati dzombe!
\q1 
\v 16 Mwachulukitsa chiwerengero cha anthu a malonda anu
\q2 mpaka kupambana nyenyezi za mlengalenga,
\q1 koma iwo ngati dzombe akuwononga dziko
\q2 ndipo kenaka akuwuluka nʼkuchoka.
\q1 
\v 17 Akalonga ako ali ngati dzombe,
\q2 akuluakulu ako ali ngati gulu la dzombe
\q2 limene lamatirira pa khoma nthawi yozizira,
\q1 koma pamene dzuwa latuluka limawuluka,
\q2 ndipo palibe amene amadziwa komwe lapita.
\b
\q1 
\v 18 Iwe mfumu ya ku Asiriya,
\q2 abusa ako agona tulo;
\q2 anthu ako olemekezeka amwalira.
\q1 Anthu ako amwazikira ku mapiri
\q2 popanda ndi mmodzi yemwe wowasonkhanitsa.
\q1 
\v 19 Palibe chimene chingachize bala lako;
\q2 chilonda chako sichingapole.
\q1 Aliyense amene amamva za iwe
\q2 amawomba mʼmanja chifukwa cha kugwa kwako,
\q1 kodi alipo amene sanazilawepo
\q2 nkhanza zako zosatha?
