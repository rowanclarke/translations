\v 6 \w Y|strong="H3068"\w* \w circuncidará|strong="H4135"\w* \w el|strong="H3605"\w* \w SEÑOR|strong="H3068"\w* tu \w Dios|strong="H3068"\w* tu \w corazón|strong="H3824"\w*, y \w el|strong="H3605"\w* \w corazón|strong="H3824"\w* de tu \w simiente|strong="H2233"\w*, \w para|strong="H4616"\w* \w que|strong="H4616"\w* ames al \w SEÑOR|strong="H3068"\w* tu \w Dios|strong="H3068"\w* con \w todo|strong="H3605"\w* tu \w corazón|strong="H3824"\w* y con \w toda|strong="H3605"\w* tu \w alma|strong="H5315"\w*, \w a|strong="H3068"\w* fin de \w que|strong="H4616"\w* tú \w vivas|strong="H2416"\w*.
