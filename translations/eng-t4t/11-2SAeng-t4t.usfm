\v 13 If \w I|strong="H1697"\w* \w had|strong="H4428"\w* disobeyed \w the|strong="H3605"\w* \w king|strong="H4428"\w* \w and|strong="H4428"\w* killed Absalom, \w the|strong="H3605"\w* \w king|strong="H4428"\w* \w would|strong="H5315"\w* \w have|strong="H1697"\w* heard \w about|strong="H1697"\w* \w it|strong="H6213"\w*, \w because|strong="H4480"\w* \w the|strong="H3605"\w* \w king|strong="H4428"\w* hears \w about|strong="H1697"\w* \w everything|strong="H3605"\w*, \w and|strong="H4428"\w* \w even|strong="H6213"\w* \w you|strong="H3605"\w* \w would|strong="H5315"\w* \w not|strong="H3808"\w* \w have|strong="H1697"\w* defended \w me|strong="H5315"\w*!”
\p 
\v 14 \w Joab|strong="H3097"\w* \w said|strong="H3651"\w*, “\w I|strong="H3651"\w* am \w not|strong="H3808"\w* going \w to|strong="H3820"\w* \w waste|strong="H3176"\w* \w time|strong="H3820"\w* talking \w to|strong="H3820"\w* \w you|strong="H6440"\w*!” \w Then|strong="H3947"\w* \w he|strong="H3651"\w* \w took|strong="H3947"\w* \w three|strong="H7969"\w* \w spears|strong="H7626"\w* \add and went to where Absalom was\add*, \w and|strong="H6440"\w* \w thrust|strong="H8628"\w* \w them|strong="H6440"\w* \w into|strong="H3947"\w* Absalom’s chest/\w heart|strong="H3820"\w* \w while|strong="H5750"\w* \w he|strong="H3651"\w* \w was|strong="H3820"\w* \w still|strong="H5750"\w* \w alive|strong="H2416"\w*, dangling \w from|strong="H6440"\w* \w the|strong="H6440"\w* oak tree.
\v 15 \w Then|strong="H5375"\w* \w ten|strong="H6235"\w* \w young|strong="H5288"\w* \w men|strong="H5288"\w* \w who|strong="H5288"\w* \w carried|strong="H5375"\w* \w weapons|strong="H3627"\w* \w for|strong="H4191"\w* \w Joab|strong="H3097"\w* \w surrounded|strong="H5437"\w* Absalom \w and|strong="H5288"\w* \add finished\add* \w killing|strong="H5221"\w* \w him|strong="H5221"\w*.
\p 
\v 16 \w Then|strong="H7725"\w* \w Joab|strong="H3097"\w* \w blew|strong="H8628"\w* \w his|strong="H7725"\w* \w trumpet|strong="H7782"\w* \add to signal that they should not fight any more\add*, \w and|strong="H3478"\w* \w his|strong="H7725"\w* \w soldiers|strong="H5971"\w* \w returned|strong="H7725"\w* \w from|strong="H7725"\w* \w pursuing|strong="H7291"\w* \w those|strong="H7291"\w* Israeli \w soldiers|strong="H5971"\w*.
\v 17 \w They|strong="H5921"\w* \w took|strong="H3947"\w* Absalom’s body \w and|strong="H3478"\w* \w threw|strong="H7993"\w* \w it|strong="H5921"\w* \w into|strong="H5921"\w* \w a|strong="H3068"\w* huge \w pit|strong="H6354"\w* \w in|strong="H5921"\w* \w the|strong="H3605"\w* \w forest|strong="H3293"\w*, \w and|strong="H3478"\w* covered \w it|strong="H5921"\w* \w with|strong="H5921"\w* \w a|strong="H3068"\w* huge \w pile|strong="H1530"\w* \w of|strong="H5921"\w* stones. \w Then|strong="H3947"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* remaining Israeli soldiers \add who had been with Absalom\add* \w fled|strong="H5127"\w* \w to|strong="H3478"\w* \w their|strong="H3605"\w* own towns.
\p 
\v 18 Absalom \w had|strong="H4428"\w* \w no|strong="H3947"\w* \w sons|strong="H1121"\w* \w to|strong="H5704"\w* \w preserve|strong="H2142"\w* \w his|strong="H7121"\w* \add family\add* \w name|strong="H8034"\w*. \w So|strong="H3947"\w*, \w while|strong="H5704"\w* Absalom \w was|strong="H8034"\w* \w alive|strong="H2416"\w*, \w he|strong="H3588"\w* built \w a|strong="H3068"\w* \w monument|strong="H3027"\w* \w to|strong="H5704"\w* \w himself|strong="H3027"\w* \w in|strong="H5921"\w* \w the|strong="H5921"\w* \w King|strong="H4428"\w*’s \w Valley|strong="H6010"\w* \add near Jerusalem, in order that people would remember him\add*. \w He|strong="H3588"\w* \w put|strong="H3947"\w* \w his|strong="H7121"\w* \w name|strong="H8034"\w* \w on|strong="H5921"\w* \w the|strong="H5921"\w* \w monument|strong="H3027"\w*, \w and|strong="H1121"\w* \w people|strong="H1121"\w* \w still|strong="H2142"\w* \w call|strong="H7121"\w* \w it|strong="H7121"\w* Absalom’s \w monument|strong="H3027"\w*.
\s1 The report of Absalom’s death reached David
\p 
\v 19 \add After Absalom had been killed,\add* \w Zadok|strong="H6659"\w*’s \w son|strong="H1121"\w* Ahimaaz said \w to|strong="H3068"\w* Joab, “\w Allow|strong="H4994"\w* \w me|strong="H4994"\w* \w to|strong="H3068"\w* \w run|strong="H7323"\w* \w to|strong="H3068"\w* \w the|strong="H3588"\w* \w king|strong="H4428"\w* \w to|strong="H3068"\w* \w tell|strong="H4994"\w* \w him|strong="H3027"\w* \w the|strong="H3588"\w* \w good|strong="H1319"\w* \w news|strong="H1319"\w* \w that|strong="H3588"\w* \w Yahweh|strong="H3068"\w* \w has|strong="H3068"\w* rescued \w him|strong="H3027"\w* \w from|strong="H3027"\w* \w the|strong="H3588"\w* \w power|strong="H3027"\w* \w of|strong="H1121"\w* \w his|strong="H3068"\w* \w enemies|strong="H3027"\w*!”
\p 
\v 20 \w But|strong="H3588"\w* \w Joab|strong="H3097"\w* said \w to|strong="H4191"\w* \w him|strong="H5921"\w*, “\w No|strong="H3808"\w*, \w I|strong="H3588"\w* \w will|strong="H4428"\w* \w not|strong="H3808"\w* allow \w you|strong="H3588"\w* \w to|strong="H4191"\w* \w take|strong="H1121"\w* \w news|strong="H1319"\w* \w to|strong="H4191"\w* \w the|strong="H5921"\w* \w king|strong="H4428"\w* \w today|strong="H3117"\w*. \w Some|strong="H3117"\w* \w other|strong="H2088"\w* \w day|strong="H3117"\w* \w I|strong="H3588"\w* \w will|strong="H4428"\w* allow \w you|strong="H3588"\w* \w to|strong="H4191"\w* \w take|strong="H1121"\w* \w some|strong="H3117"\w* \w news|strong="H1319"\w*, \w but|strong="H3588"\w* \w not|strong="H3808"\w* \w today|strong="H3117"\w*. \add If you took news today it would not be good news for the king,\add* \w because|strong="H3588"\w* \w his|strong="H5921"\w* \w son|strong="H1121"\w* \w is|strong="H2088"\w* \w dead|strong="H4191"\w*.”
\p 
\v 21 \w Then|strong="H4428"\w* \w Joab|strong="H3097"\w* said \w to|strong="H3212"\w* David’s servant \w who|strong="H4428"\w* \w was|strong="H4428"\w* \w from|strong="H3212"\w* \w Ethiopia|strong="H3569"\w*, “\w You|strong="H5046"\w* \w go|strong="H3212"\w* \w and|strong="H4428"\w* \w tell|strong="H5046"\w* \w the|strong="H7200"\w* \w king|strong="H4428"\w* \w what|strong="H7200"\w* \w you|strong="H5046"\w* \w have|strong="H7200"\w* \w seen|strong="H7200"\w*.” \w So|strong="H7200"\w* \w the|strong="H7200"\w* \w man|strong="H7200"\w* \w from|strong="H3212"\w* \w Ethiopia|strong="H3569"\w* \w bowed|strong="H7812"\w* \w in|strong="H4428"\w* front \w of|strong="H4428"\w* \w Joab|strong="H3097"\w*, \w and|strong="H4428"\w* started \w to|strong="H3212"\w* \w run|strong="H7323"\w*.
\p 
\v 22 \w Then|strong="H1961"\w* Ahimaaz said \w again|strong="H5750"\w* \w to|strong="H1961"\w* \w Joab|strong="H3097"\w*, “\w Even|strong="H1571"\w* \w though|strong="H1571"\w* \add that man from Ethiopia is running\add*, \w allow|strong="H4994"\w* \w me|strong="H4994"\w* \w to|strong="H1961"\w* \w run|strong="H7323"\w* behind \w him|strong="H4672"\w*.” \w Joab|strong="H3097"\w* replied, “\w My|strong="H1961"\w* boy/\w son|strong="H1121"\w*, \w why|strong="H4100"\w* \w do|strong="H3254"\w* \w you|strong="H4100"\w* \w want|strong="H7323"\w* \w to|strong="H1961"\w* \w do|strong="H3254"\w* \w that|strong="H2088"\w*? \w You|strong="H4100"\w* \w will|strong="H1961"\w* \w not|strong="H2088"\w* \w receive|strong="H1961"\w* \w any|strong="H5750"\w* \w reward|strong="H1309"\w* \w for|strong="H1121"\w* \w your|strong="H1961"\w* \w news|strong="H1309"\w*!”
\p 
\v 23 \w But|strong="H1961"\w* Ahimaaz replied, “\w That|strong="H1961"\w* \w does|strong="H4100"\w* \w not|strong="H1961"\w* matter, \w I|strong="H4100"\w* \w want|strong="H7323"\w* \w to|strong="H1961"\w* \w go|strong="H5674"\w*.” \w So|strong="H1961"\w* Joab said, “Okay, \w go|strong="H5674"\w*.” \w So|strong="H1961"\w* Ahimaaz \w ran|strong="H7323"\w* \w along|strong="H5674"\w* \add another\add* \w road|strong="H1870"\w* \w through|strong="H5674"\w* \w the|strong="H5674"\w* Jordan \w Valley|strong="H3603"\w* \w and|strong="H1870"\w* arrived \add where David was\add* \w before|strong="H5674"\w* \w the|strong="H5674"\w* \w man|strong="H5674"\w* \w from|strong="H1961"\w* \w Ethiopia|strong="H3569"\w* arrived.
\p 
\v 24 \w David|strong="H1732"\w* \w was|strong="H1732"\w* \w sitting|strong="H3427"\w* \w between|strong="H3427"\w* \w the|strong="H7200"\w* outer \w gate|strong="H8179"\w* \w and|strong="H3212"\w* \w the|strong="H7200"\w* inner \w gate|strong="H8179"\w* \add of the city\add*. \w The|strong="H7200"\w* \w watchman|strong="H6822"\w*/\w lookout|strong="H6822"\w* \w went|strong="H3212"\w* \w up|strong="H5375"\w* \w on|strong="H7200"\w* \w top|strong="H1406"\w* \w of|strong="H3427"\w* \w the|strong="H7200"\w* \w city|strong="H8179"\w* \w wall|strong="H2346"\w* \w and|strong="H3212"\w* stood \w on|strong="H7200"\w* \w the|strong="H7200"\w* \w roof|strong="H1406"\w* \w over|strong="H3427"\w* \w the|strong="H7200"\w* \w gates|strong="H8179"\w*. \w He|strong="H1732"\w* \w looked|strong="H7200"\w* \w out|strong="H7200"\w* \w and|strong="H3212"\w* \w saw|strong="H7200"\w* \w one|strong="H7200"\w* \w man|strong="H8179"\w* \w running|strong="H7323"\w* alone.
