\id GLO - Achi’, Rabinal (new orthography) 2009 (DBL 2013) 
\h Vocabulario Bíblico 
\toc2 Vocabulario Bíblico 
\toc1 Vocabulario Bíblico 
\mt1 Vocabulario Bíblico  
\ili1 \k Abba:\k* Tat  
\ili2 E jun chꞌaꞌtem arameo. (\xt Mr. 14:36; Ro. 8:15; Gl. 4:6\xt*)  
\ili1 \k Abismo:\k* Siwan na jinta utaqexik ruchoyil upa  
\ili2 Pa ri Nuevo Testamento, waꞌ na e ta juna siwan kilitaj che ruwachulew; e ri luwar pa kakꞌaq wubꞌi ri Satanás kukꞌ konoje ritzel uxlabꞌixel chaꞌ na kebꞌel ta chuloq. (\xt Lc. 8:31; Ap. 9:1; 20:1\xt*)  
\ili1 \k Abominación:\k* Ri lik chꞌul y lik kꞌixbꞌal uwach, ri lik tzel kilitaj ruma ri Dios  
\ili2 Waꞌ e ri lik na usukꞌ taj kakiꞌan ri tikawex. (\xt Mr. 13:14; Lc. 16:15; Ap. 17:4\xt*)  
\ili1 \k Adoración a Dios:\k* Uloqꞌnimaxik uqꞌij ri Dios (\xt Mt. 4:10; 1 Co. 14:25; Ap. 4:10\xt*)  
\ili1 \k Adulterio:\k* Makunik chirij ri kꞌulanikil  
\ili2 1) Ri kuꞌan junoq kꞌulanik echiriꞌ kuyoj ribꞌ rukꞌ jun chik na ukꞌulel taj (\xt Mt. 5:27-28; Mr. 10:11-12; Ro. 7:3\xt*)  
\ili2 2) Ri kuꞌan junoq uyaꞌom ribꞌ puqꞌabꞌ ri Dios echiriꞌ kꞌo ri más keꞌek ukꞌuꞌx chirij y más kꞌax kunaꞌ waꞌ chwa ri Dios. E ri kaꞌanaw waꞌ, na jusukꞌ ta ri ranimaꞌ chwach ri Dios. (\xt Mt. 12:39; Mr. 8:38\xt*)  
\ili1 \k Águila:\k* (Junam rubꞌiꞌxik pa qachꞌaꞌtem)  
\ili2 Waꞌ e jun awaj kaxikꞌikꞌ lik chikaj jelaꞌ pachaꞌ juna xik. (\xt Ap. 4:7; 8:13; 12:14\xt*)  
\ili1 \k Alfa y Omega:\k* Ri jeqebꞌal re y ri kꞌisbꞌal re  
\ili2 “Alfa” e ri nabꞌe letra re ri alfabeto griego y “omega” e ri kꞌisbꞌal re. Ri Cristo xubꞌiꞌij: «Riꞌin in ri jeqebꞌal re yey in ri kꞌisbꞌal re, jelaꞌ pachaꞌ ri kaꞌibꞌ letra A y Z.» (\xt Ap. 1:8; 21:6; 22:13\xt*)  
\ili1 \k Alma:\k* Rukꞌaslemal juna tikawex, rukꞌuꞌx, ri ranimaꞌ  
\ili2 E ru “espíritu” juna tikawex, ri na kakam taj tobꞌ kakam rucuerpo. (\xt Mt. 11:29; Mr. 8:36; 1 Ts. 5:23\xt*)  
\ili1 \k Altar:\k* (Junam rubꞌiꞌxik pa qachꞌaꞌtem)  
\ili2 E ri luwar pa kakiya wi ri tikawex ri kiqasaꞌn chwach ri Dios o chwach juna tiox. (\xt Mt. 5:23-24; Hch. 17:23; Heb. 13:10\xt*)  
\ili1 \k Amar:\k* Kꞌax kunaꞌ junoq (\xt Jn. 3:16; Jn. 13:35\xt*)  
\ili1 \k Amén:\k* (Junam rubꞌiꞌxik pa qachꞌaꞌtem)  
\ili2 Chꞌaꞌtem hebreo, keꞌelawi “lik qatzij” o “lik areꞌ” o “e chuꞌana riꞌ”. (\xt Mt. 6:13; Ro. 1:25; 1 Co. 14:16\xt*)  
\ili1 \k Amor:\k* Rutzil kꞌuꞌxaj  
\ili2 E ri kaqakꞌutu echiriꞌ kꞌax kaqanaꞌ ri Dios y kꞌax kaqanaꞌ qibꞌ chiqawach riꞌoj. (\xt 1 Co. 13:4-7\xt*)  
\ili1 \k Animar:\k* Unimarisaxik ukꞌuꞌx junoq  
\ili2 E ri kaqaꞌano echiriꞌ kaqetaꞌmaj kꞌo junoq pa bꞌis o pa kꞌax. (\xt Mt. 9:22; 14:27; Hch. 27:22\xt*)  
\ili1 \k Anticristo:\k* Ri kayakataj chirij ri Cristo (\xt 1 Jn. 2:18, 22; 2 Jn. 7\xt*)  
\ili1 \k Aposento alto:\k* Ri kaleꞌ ja, ruroxleꞌ ja (\xt Mr. 14:14-15; Hch. 20:8\xt*)  
\ili1 \k Apóstol:\k* Taqoꞌn  
\ili2 Ri kabꞌlajuj utijoꞌn ri Jesús xebꞌuꞌan e “utaqoꞌn”, ma xetaq bꞌi ruma Rire chaꞌ keꞌkitzijoj ri Utzilaj Tzij. Yey ri Pablo e jun chike rutaqoꞌn. (\xt Lc. 6:13; Hch. 5:12\xt*)  
\ili1 \k Atrio:\k* Uwa ja (\xt Mr. 15:16\xt*)  
\ili1 \k ¡Ay de ellos!:\k* ¡Toqꞌoꞌ kiwach!  
\ili2 Pa Ruchꞌaꞌtem ri Dios, e kabꞌiꞌx waꞌ chike ri tikawex kꞌo chi ri qꞌatbꞌal tzij re ri Dios pakiwiꞌ. (\xt Mr. 14:21; Lc. 11:42-47; Ap. 8:13\xt*)  
\ili1 \k Bautismo:\k* (Junam rubꞌiꞌxik pa qachꞌaꞌtem)  
\ili2 E ri kuꞌan junoq echiriꞌ kuqꞌalajisaj ri Qanimajawal Jesucristo e Ukolobꞌenel. Kamuq pa yaꞌ o kaqꞌej yaꞌ chwi ujolom.  
\li2 1) \k Bautizar:\k* Kuya ri bautismo (\xt Mt. 3:6, 13; Lc. 20:4\xt*)  
\li2 2) \k Bautizarse:\k* Kukꞌul ri bautismo (\xt Mr. 16:16; Hch. 16:15; Heb. 10:22\xt*)  
\ili1 \k Beelzebú:\k* Kajawal ritzel uxlabꞌixel o aj wach ke ritzel uxlabꞌixel (\xt Mt. 10:25; Mr. 3:22; 2 Co. 6:15\xt*)  
\ili1 \k Bendito:\k* Lik nim uqꞌij (\xt Lc. 13:35; 2 Co. 1:3\xt*)  
\ili1 \k Bienaventurado:\k* Lik nim uqꞌij ralaxik  
\ili2 E kabꞌiꞌx waꞌ che ri tikawex kukꞌul ri bendición re ri Dios. (\xt Mt. 5:3-11; 25:34; Lc. 1:42\xt*)  
\ili1 \k Blasfemar:\k* Ri tzel chꞌaꞌtibꞌenik chirij ri Dios (\xt Mt. 12:31; Jn. 10:33; Ap. 13:6\xt*)  
\ili1 \k Bondad:\k* Relej kꞌuꞌxaj  
\ili2 Jun kukꞌut ri relej ukꞌuꞌx echiriꞌ kuꞌan ri utz che jun chik. (\xt Gl. 5:22; Ef. 2:7; Tit. 3:4\xt*)  
\ili1 \k Carne:\k*  
\li2 1) Taq ri rayibꞌal re ri tiꞌjil  
\li4 E taq ri na utz taj kalax lo pa qanimaꞌ. (\xt Gl. 5:16-17\xt*)  
\li2 2) Tikawex  
\li4 Pa jujun versículos e kachꞌaꞌt pakiwi ri tikawex. (\xt Hch. 2:17\xt*)  
\li2 3) Tiꞌoꞌn o tiꞌij  
\li4 E ri tiꞌoꞌn re katijik. (\xt 1 Co. 8:13\xt*)  
\ili1 \k César, emperador:\k* Nimalaj taqanel re Roma  
\ili2 Ri nimalaj taqanel re Roma xtaqan pakiwi konoje ri jujun chik taqanelabꞌ. “César” na bꞌiꞌaj taj; ma e ubꞌiꞌ ruwach ri nimalaj taqanel, yey chikijujunal rike kꞌo kibꞌiꞌ, pachaꞌ Julio, Augusto, Nerón. (\xt Mt. 22:17; Lc. 20:22; Hch. 25:25\xt*)  
\ili1 \k Cielo:\k*  
\li2 1) Ruwa kaj  
\li4 E pa e kꞌo wi ri chꞌumil, ri qꞌij y ri ikꞌ. (\xt Mt. 16:3; Heb. 1:10\xt*)  
\li2 2) Chilaꞌ chikaj  
\li4 E ri luwar lik chom pa jeqel wi ri Dios, tobꞌ Rire pa ronoje luwar kꞌo wi. (\xt Mt. 3:2; 2 Co. 12:4; Ap. 4:2\xt*)  
\ili1 \k Cilicio:\k* Kꞌul kꞌax rij y tzakꞌan upa  
\ili2 E kꞌul kakikoj ri tikawex ojertan kꞌutubꞌal re ri unimal kibꞌis ruma ri kimak o ruma kakam juna katz-kichaqꞌ. (\xt Mt. 11:21; Ap. 6:12; 11:3\xt*)  
\ili1 \k Circuncisión:\k* Ri retalil re circuncisión  
\ili2 1) Ri kakiꞌan raj judiꞌabꞌ echiriꞌ juna ralko ala kukꞌis wajxaqibꞌ qꞌij ralaxik, e kaqꞌat rutzꞌuꞌmalil ruwi ri rulewal, kꞌutubꞌal re e jun chike rutinamit ri Dios. (\xt Gn. 17:9-14; Lc. 2:21; Hch. 7:8\xt*)  
\ili2 2) “Los de la circuncisión” keꞌelawi ri e aj judiꞌabꞌ. “Los que no son de la circuncisión” keꞌelawi ri na e ta aj judiꞌabꞌ. (\xt Ro. 3:30\xt*)  
\ili2 3) E kꞌo jujun aj judiꞌabꞌ kikojom chi rubꞌiꞌ ri Cristo yey kakibꞌiꞌij ri na e ta aj judiꞌabꞌ chirajawaxik chike kakikoj ri retalil re circuncisión chaꞌ kekolobꞌetajik. (\xt Gl. 2:12\xt*)  
\ili1 \k Cobrador de impuestos:\k* Aj tzꞌonol puaq re tojonik  
\ili2 Raj tzꞌonol puaq lik tzel kebꞌil kuma ri kach aj Israel ma kechakun rukꞌ ri gobierno romano, ri kataqan pakiwi raj Israel. Kabꞌiꞌx chike e rayinel y eleqꞌomabꞌ ma kakitzꞌonoj uwi ri tojonik kaꞌanik y rukꞌ waꞌ kakiꞌan kꞌax che ri tinamit. (\xt Mt. 9:11; Lc. 3:12-13; 19:2\xt*)  
\ili1 \k Compasión:\k* Kꞌaxnaꞌbꞌal kꞌuꞌxaj  
\li2 1) \k Mostrar compasión:\k* Kukꞌut ri kꞌaxnaꞌbꞌal ukꞌuꞌx (\xt Ro. 9:15; Heb. 4:15; 1 P. 3:8\xt*)  
\li2 2) \k Sentir compasión:\k* Kajuchꞌ kaꞌn pa ranimaꞌ, kajuchꞌ kaꞌn ukꞌuꞌx che junoq (\xt Mt. 9:36; Mr. 8:2; 1 Jn. 3:17\xt*)  
\ili1 \k Comunión, compañerismo, unánime:\k* Junam qakꞌuꞌx, kojuꞌan xa oj jun  
\ili2 E ri kaqariqo echiriꞌ kaqamol qibꞌ chaꞌ rukꞌ rutzil kꞌuꞌxaj junam kojwaꞌik, junam kaqaloqꞌnimaj uqꞌij ri Dios o kaqanimarisaj qakꞌuꞌx chiqawach. (\xt Hch. 2:1, 42; 1 Co. 1:9\xt*)  
\ili1 \k Conciencia:\k* Kunaꞌ chukꞌuꞌx we utz uꞌanom chwach ri Dios o na utz ta uꞌanom  
\li2 1) \k Conciencia buena:\k* Kunaꞌ chukꞌuꞌx jusukꞌ rubꞌinik usilabꞌik chwach ri Dios, kumaj usukꞌ saꞌ ri utz yey e kuꞌano (\xt Hch. 23:1; Ro. 9:1\xt*)  
\ili1 \k Concilio:\k* Konoje ri uchapom wi ribꞌ ri qꞌatbꞌal tzij  
\ili2 Waꞌ e 70 achijabꞌ e aj judiꞌabꞌ; chikixoꞌl kꞌo ri kajawal raj chakunel pa Rocho Dios, e kꞌo ri nimaq e aj chakunel pa Rocho Dios yey jujun nimaq winaq re ri tinamit. Pakiqꞌabꞌ kꞌu rike kꞌo wi ri qꞌatbꞌal tzij kaꞌan pakiwi ri tinamit Israel. (\xt Mt. 26:59; Mr. 15:43; Hch. 22:30\xt*)  
\ili1 \k Concupiscencia:\k* Rayibꞌal na chom ta uwach (\xt Ro. 1:24; Stg. 1:14; 2 P. 3:3\xt*)  
\ili1 \k Consolador:\k* Toꞌbꞌel re kubꞌochiꞌij qakꞌuꞌx, Toꞌbꞌel re kunimarisaj qakꞌuꞌx  
\ili2 Waꞌ e ri Ruxlabꞌixel ri Dios. (\xt Jn. 14:16, 26; 15:26; 16:7\xt*)  
\ili1 \k Contaminar:\k*  
\li2 1) Ri kuyojo o kuchꞌulaj rubꞌinik usilabꞌik ri tikawex (\xt Mt. 15:20; Stg. 3:6\xt*)  
\li2 2) Ri waꞌim kuchꞌulaj ri tikawex  
\li4 Chikiwach raj judiꞌabꞌ ojertan, kꞌo ri kutij junoq o kuchapo, yey waꞌ kuꞌan che junoq na utz taj kok pa ri Rocho Dios chilaꞌ Jerusalem we na xujosqꞌij ta ribꞌ nabꞌe. (\xt Hch. 15:20\xt*)  
\ili1 \k Copa:\k* (Junam rubꞌiꞌxik pa qachꞌaꞌtem)  
\li2 1) Kꞌolibꞌal re tijbꞌal vino (\xt Mt. 26:27; Mr. 14:23; Lc. 22:17; 1 Co. 11:25\xt*)  
\li2 2) Kꞌaxkꞌobꞌik  
\li4 E kꞌambꞌal naꞌoj puwi taq ri kꞌaxkꞌolil. (\xt Mt. 26:39; Mr. 14:36; Ap. 16:1\xt*)  
\ili1 \k Cordero:\k* Qꞌapoj bꞌexex  
\ili2 Chupa ri Nuevo Testamento kakꞌambꞌex uwach ri Jesús rukꞌ jun qꞌapoj bꞌexex kayaꞌiꞌ re qasaꞌn chwach ri Dios. (\xt Jn. 1:29; 1 P. 1:19; Ap. 5:6\xt*)  
\ili1 \k Cordón:\k* (Junam rubꞌiꞌxik pa qachꞌaꞌtem)  
\ili2 Che ruchiꞌ ri kiqꞌuꞌ rachijabꞌ e aj judiꞌabꞌ, karabꞌabꞌ jujun cordón saq pachꞌum, waꞌ kꞌo jujik chij azul chupa. Ri Dios xtaqan che kakiꞌan waꞌ, kuxtabꞌal re chike kakikoj utzij Rire.  
\ili2 Nm. 15:38-39; Mt. 23:5 \fig Cordón|alt="Pharasee with phylacteries" src="LB00276b.tif" size="col" ref="voc" \fig*  
\ili1 \k Cristo:\k* (Junam rubꞌiꞌxik pa qachꞌaꞌtem)  
\ili2 Ri chꞌaꞌtem “Cristo” pa griego junam keꞌelawi rukꞌ ri chꞌaꞌtem “Mesías” pa hebreo. Ukabꞌichal wa chꞌaꞌtem keꞌelawi “Ruchaꞌoꞌn ri Dios ubꞌiꞌtisim loq”, waꞌ e ri Kolobꞌenel bꞌiꞌisitim lo ruma ri Dios. (\xt Mt. 16:16; Jn. 20:31; Hch. 17:3\xt*)  
\ili1 \k Cuerdo:\k* Ri kuchꞌobꞌ chi utz saꞌ ri kuꞌano (\xt 2 Co. 5:13\xt*)  
\ili1 \k Demonio:\k* Itzel uxlabꞌixel (\xt Mt. 7:22; Mr. 1:34; Lc. 8:2\xt*)  
\ili1 \k Denario:\k* (Junam rubꞌiꞌxik pa qachꞌaꞌtem)  
\ili2 E jun meyo re Roma, rajil jun qꞌij chak. Oxibꞌ ciento e kuchꞌak jun aj chak pa jun junabꞌ. (\xt Mt. 20:9; Lc. 10:35\xt*)  
\ili1 \k Descendiente:\k* Ralkꞌoꞌal kanoq  
\ili2 Raj judiꞌabꞌ lik kakibꞌiꞌij waꞌ echiriꞌ kechꞌaꞌt puwi ri familia kipetebꞌem lo wi, pachaꞌ “ri e ralkꞌoꞌal kan ri Abraham” ma rike kipetebꞌem lo che ri Abraham. (\xt Jn. 8:37; Ro. 9:7-8; 2 Co. 11:22\xt*)  
\ili1 \k Deseo de la carne:\k* Ri rayibꞌal na utz ta uwach re ri qatiꞌjil (\xt Ro. 13:14; Gl. 5:16; 1 Jn. 2:16\xt*)  
\ili1 \k Día del Señor:\k*  
\li2 1) Ruqꞌijol rukꞌunibꞌal ri Qanimajawal (\xt 1 Co. 5:5; 2 Ts. 2:2; 2 P. 3:10\xt*)  
\li2 2) Ri domingo  
\li4 Ri qꞌij echiriꞌ xkꞌastaj ri Qanimajawal Jesucristo chikixoꞌl ri ekaminaq. (\xt Ap. 1:10\xt*)  
\ili1 \k Día de reposo:\k* Qꞌij re uxlanibꞌal  
\ili2 Echiriꞌ kubꞌiꞌij “qꞌij re uxlanibꞌal” chupa Ruchꞌaꞌtem ri Dios, waꞌ e keꞌelawi ri qꞌij echiriꞌ raj judiꞌabꞌ na kechakun taj. Waꞌ e ruwuq qꞌij re ri semana, kajeqer viernes pa rokibꞌal aqꞌabꞌ y kakꞌis sábado pa tzaqibꞌal qꞌij. (\xt Mt. 12:1; 28:1; Mr. 2:27; Jn. 9:14\xt*)  
\ili1 \k Diablo:\k* Ritzel winaq  
\ili2 Rubꞌiꞌ ritzel winaq e “Satanás”. (\xt Lc. 4:2; Hch. 13:10; 1 P. 5:8\xt*)  
\ili1 \k Diaconisas:\k* Aj chakibꞌ e toꞌbꞌel piglesia  
\ili2 E kabꞌiꞌx chike rixoqibꞌ ketoꞌbꞌ piglesia. (\xt Ro. 16:1\xt*)  
\ili1 \k Diáconos:\k* Aj chakibꞌ e toꞌbꞌel piglesia  
\ili2 E kabꞌiꞌx chike rachijabꞌ ketoꞌbꞌ piglesia. (\xt Flp. 1:1; 1 Ti. 3:8, 12\xt*)  
\ili1 \k Diezmo:\k* (Junam rubꞌiꞌxik pa qachꞌaꞌtem)  
\ili2 We junoq kuchꞌak lajuj quetzales yey karesaj jun re kuya che ri Dios, ri kuyaꞌo e “rudiezmo”. (\xt Lc. 18:12; Heb. 7:2\xt*)  
\ili1 \k Discípulo:\k* Tijoꞌn  
\ili2 E jun lik kutaqej ri kꞌutunik re rutijonel. (\xt Mt. 10:1; Lc. 6:13; Hch. 24:5\xt*)  
\ili1 \k Doctrina:\k* Kꞌutunik (\xt Mt. 7:28; Jn. 7:16; Tit. 2:1\xt*)  
\ili1 \k Don del Espíritu Santo:\k* Ri sipanik re ri Santowilaj Ruxlabꞌixel ri Dios  
\ili2 Ri Dios kuya ri Santowilaj Ruxlabꞌixel chike ri e re ri Cristo. (\xt Hch. 2:38; 10:45\xt*)  
\ili1 \k Dones espirituales:\k* Taq ri sipanik uyaꞌom ri Ruxlabꞌixel ri Dios  
\ili2 Chike konoje ri e re ri Cristo, ri Ruxlabꞌixel ri Dios kuya kichuqꞌabꞌ y kinaꞌoj che uꞌanikil taq ruchak. Jun che taq waꞌ e ri kayaꞌtaj chike jujun kakiqꞌalajisaj runaꞌoj ri Dios. (\xt 1 Co. 12:1; 14:1, 12\xt*)  
\ili1 \k Dracma:\k* Saqil puaq  
\ili2 E jun meyo, rajil jun qꞌij chak. (\xt Lc. 15:8; 19:13\xt*)  
\ili1 \k Dragón:\k* (Junam rubꞌiꞌxik pa qachꞌaꞌtem)  
\ili2 1) E jun nimalaj itzel chikop (\xt Ap. 12:3; 13:2\xt*)  
\ili2 2) Ruchꞌaꞌtem ri Dios echiriꞌ kachꞌaꞌt puwi ri Satanás, kꞌo jutaq laj kubꞌiꞌij “dragón” o “kumatz” che. (\xt Ap. 12:9; 20:2\xt*)  
\ili1 \k Esclavo:\k*  
\li2 1) Jun aj chak loqꞌotal ruma ri rajaw  
\li4 E junoq kakꞌojiꞌ puqꞌabꞌ ri rajaw chaꞌ kachakun ronoje qꞌij rukꞌ y na jinta uqꞌijol rukꞌolem rukꞌ. Ri “esclavo” xew katzuq ruma ri rajaw pero na kachꞌakan taj. (\xt 1 Co. 12:13; Flm. 10; Ap. 6:15\xt*)  
\li2 2) Junoq kꞌo puqꞌabꞌ ri mak  
\li4 Ruchꞌaꞌtem ri Dios kubꞌiꞌij we junoq kꞌo puqꞌabꞌ ri mak, e ri mak ri kataqan puwiꞌ. Yey xew ri Jesús kꞌo uchuqꞌabꞌ re karesaj junoq puqꞌabꞌ ri mak. (\xt Jn. 8:34; Ro. 6:16, 20\xt*)  
\ili1 \k Escriba:\k* Raj kꞌutunel re ri tzijpixabꞌ  
\ili2 Raj kꞌutunel re ri tzijpixabꞌ e lik kitaqem ri Tzij Pixabꞌ re ri Moisés y kekꞌutun puwi waꞌ chikiwach ri winaq. Pero lik ekꞌi chike waꞌ e más kitaqem taq naꞌoj xa ke achijabꞌ y kꞌutunik ke kan kichu-kiqaw re ojertan, chwa ri kakitaqej Rutzij Upixabꞌ ri Dios. Pa kaxtila kabꞌiꞌx chike “escribas”, “intérpretes de la ley” y “doctores de la ley”. (\xt Mt. 2:4; Mr. 11:18; Jn. 8:3\xt*)  
\ili1 \k Escritura:\k* Ruchꞌaꞌtem ri Dios tzꞌibꞌital kanoq, Rutzij Upixabꞌ ri Dios (\xt Mr. 15:28; Lc. 4:21; Jn. 19:36; Ro. 10:11; 2 Ti. 3:16; 2 P. 1:21\xt*)  
\ili1 \k Espiritual:\k* E kꞌamom uwach ruma ri Ruxlabꞌixel ri Dios  
\ili2 Uyaꞌom ribꞌ puqꞌabꞌ ri Dios (\xt 1 Co. 2:14-15; Gl. 5:25-26; 6:1\xt*)  
\ili1 \k Espíritu de Dios:\k* Ruxlabꞌixel ri Dios (\xt Lc. 4:18; Jn. 3:8; Ro. 8:1\xt*)  
\ili1 \k Espíritu Santo:\k* Santowilaj Ruxlabꞌixel ri Dios (\xt Mt. 1:18; Lc. 1:15; 3:22; Hch. 2:4\xt*)  
\ili1 \k Espíritus:\k*  
\li2 1) \k Espíritus malos:\k* Itzel uxlabꞌixel (\xt Lc. 7:21; Hch. 19:12, 15\xt*)  
\li2 2) \k Espíritus inmundos:\k* Itzelilaj uxlabꞌixel (\xt Mt. 12:43; Mr. 1:26; Lc. 6:18\xt*)  
\ili1 \k Eunuco:\k* (Junam rubꞌiꞌxik pa qachꞌaꞌtem)  
\ili2 Ojertan keꞌan “castrar” jujun achijabꞌ chaꞌ kechakun pa palacio o pa rocho juna bꞌeyom. Jujun kaꞌan chike e chajinel ke ixoqibꞌ y alito o kaꞌan chike e kꞌutunel. Yey e kꞌo jujun lik kꞌo kiwach. (\xt Mt. 19:12; Hch. 8:27\xt*)  
\ili1 \k Evangelio:\k* Utzilaj Tzij  
\ili2 Rukꞌuꞌxibꞌal ri Utzilaj Tzij e waꞌ: Kꞌo kuybꞌal mak y kolobꞌetajik ruma ri xuꞌan ri Qanimajawal Jesucristo.  
\ili2 Mr. 1:1; Lc. 9:6; Hch. 8:4.  
\ili1 \k Evangelista:\k* Aj tzijol re ri Utzilaj Tzij (\xt Hch. 21:8; Ef. 4:11; 2 Ti. 4:5\xt*)  
\ili1 \k Expiación:\k* Resaxik umak junoq ruma rukamik juna awaj o juna tikawex  
\ili2 Ri Dios karesaj ri qꞌatbꞌal tzij kꞌo puwi junoq ruma rukamik ri Jesús. (\xt Heb. 2:17; 10:6\xt*)  
\ili1 \k Faraón:\k* (Junam rubꞌiꞌxik pa qachꞌaꞌtem)  
\ili2 Waꞌ keꞌelawi “rey”; na e ta bꞌiꞌaj. Konoje ri reyes re Egipto, kabꞌiꞌx “faraón” chike. (\xt Hch. 7:10, 13; Ro. 9:17\xt*)  
\ili1 \k Fariseos:\k* (Junam rubꞌiꞌxik pa qachꞌaꞌtem)  
\ili2 Waꞌ e jun grupo achijabꞌ e aj judiꞌabꞌ. Rike kakibꞌiꞌij lik kakiloqꞌnimaj ri Dios ma kakiꞌan ronoje ri taqanik tzꞌibꞌital kan ruma ri Moisés; y na xew ta waꞌ ma kikojom ne más uwiꞌ. E uwariꞌche lik kiꞌanom nim che kibꞌ y kakichꞌobꞌ raqan xew rike lik e jusukꞌ chwach ri Dios. (\xt Mt. 3:7; Lc. 18:11; Hch. 26:5\xt*)  
\ili1 \k Fe:\k*  
\li2 1) Kubꞌulibꞌal kꞌuꞌxaj  
\li4 Riꞌoj kubꞌul qakꞌuꞌx rukꞌ ri Dios ma Rire kꞌax kojunaꞌo, kojuchajij y kuꞌan ronoje ri ubꞌiꞌtisim loq. (\xt Mt. 8:10; Mr. 5:34; Heb. 11\xt*)  
\li2 2) Ri saqil kꞌutunik puwi ri Qanimajawal Jesucristo (\xt 1 Ti. 3:9\xt*)  
\ili1 \k Filacteria:\k* (Junam rubꞌiꞌxik pa qachꞌaꞌtem)  
\ili2 Ri “filacteria” e jurabꞌaj tzꞌuꞌum rukꞌ jutaq bꞌiqꞌ Uchꞌaꞌtem ri Dios tzꞌibꞌital chwach. Kꞌo achijabꞌ e aj judiꞌabꞌ kakixim waꞌ chukurusil ri kipalaj y che ri kiqꞌabꞌ. Ri Dios xtaqan che kakiꞌan waꞌ, kuxtabꞌal re chike kakikoj utzij Rire.  
\ili2 Dt. 6:8; Mt. 23:5 \fig Jun achi kꞌo jun “filacteria” ximital chukurusil rupalaj (Mateo 23:5)|alt="Phylacteries" src="HK00274b.tif" size="col" ref="Mt. 23:5" \fig*  
\ili1 \k Fornicación:\k* Ri karetzꞌabꞌej uwa uqꞌij rukꞌ jun chik na ukꞌulel taj; ri kuya ribꞌ chupa taq rayibꞌal na chom ta uwach (\xt Mr. 7:21; 1 Co. 5:9; 6:13\xt*)  
\ili1 \k Gentiles:\k*  
\li2 1) Ri na e ta aj judiꞌabꞌ  
\li4 E ri tikawex na e ta ralkꞌoꞌal kan ri Jacob. (\xt Hch. 9:15; 1 Co. 1:23; Ef. 3:8\xt*)  
\ili1 \k Gloria:\k* Unimal uchomalil  
\ili2 Kaqayak uqꞌij ri Dios ruma taq ri kꞌutubꞌal re runimal uchomalil. (\xt Mt. 24:30; Hch. 7:55; 1 Ti. 1:17\xt*)  
\ili1 \k Gracia:\k* Unimal rutzil kꞌuꞌxaj  
\li2 1) \k La gracia de Dios:\k* Unimal rutzil ukꞌuꞌx ri Dios (\xt Jn. 1:17; Hch. 15:11; Ef. 2:8\xt*)  
\li2 2) \k Encontrar gracia ante los ojos de otro:\k*  
\li4 Waꞌ e echiriꞌ ri uꞌanom junoq lik utz kilitaj ruma jun chik. (\xt Lc. 2:52\xt*)  
\ili1 \k Griego:\k* Ri chꞌaꞌtem griego  
\ili2 Waꞌ e kichꞌaꞌtem ri e aj Grecia. Yey lik e kꞌi ketaꞌam waꞌ wa chꞌaꞌtem ojertan, na xew ta ri e aj Grecia. Lik e kꞌi e tijotal pa wa chꞌaꞌtem yey e kꞌi ri xkitzꞌibꞌaj libros pa ri chꞌaꞌtem griego. (\xt Lc. 23:38; Hch. 6:1; Ro. 1:14\xt*)  
\ili1 \k Griegos:\k*  
\li2 1) Ri e aj Grecia  
\li4 Waꞌ e ri xebꞌalax Grecia. (\xt Hch. 18:17; 1 Co. 1:22\xt*)  
\li2 2) Ri e aj griego na e ta aj judiꞌabꞌ  
\li4 Waꞌ e ri na e ta aj judiꞌabꞌ pero ri kichꞌaꞌtem e griego y kitaqem ri kojobꞌal ke raj Grecia tobꞌ na e jeqel ta Grecia. Ukꞌiyal laj echiriꞌ kubꞌiꞌij “judíos y griegos” pa kaxtila, waꞌ e keꞌelawi ri e aj judiꞌabꞌ y ri na e ta aj judiꞌabꞌ. Kil “gentiles” pa vocabulario. (\xt Hch. 16:1, 3\xt*)  
\li2 3) Ri e aj judiꞌabꞌ kechꞌaꞌt pa ri chꞌaꞌtem griego  
\li4 Waꞌ e tikawex e aj judiꞌabꞌ ma ri katiꞌ-kimam e aj judiꞌabꞌ. Rike kakitaqej jujun che taq ri kojobꞌal ke ri katiꞌ-kimam, pero kitaqem jujun che taq ri kojobꞌal ke ri e aj griego yey ri kichꞌaꞌtem e griego. Jujun chike taq waꞌ e kukꞌil ri kikojom rubꞌiꞌ ri Cristo. (\xt Hch. 6:1\xt*)  
\ili1 \k Hades:\k* Xibꞌalbꞌaꞌ re tijbꞌal kꞌax; luwar pa kekꞌojiꞌ wi ri e kaminaq (\xt Mt. 11:23; Lc. 10:15\xt*)  
\ili1 \k Hijo del Hombre:\k* Ralaxel Chikixoꞌl Tikawex  
\ili2 E kakibꞌiꞌij waꞌ ri David kukꞌ taq ri qꞌalajisanelabꞌ ojertan echiriꞌ kechꞌaꞌt puwi Ruchaꞌoꞌn lo ri Dios kakꞌunik. Waꞌ e ri Qanimajawal Jesucristo. Yey ri Jesucristo xubꞌiꞌij Rire e Uchaꞌoꞌn lo ri Dios y e Alaxel Chikixoꞌl Tikawex. (\xt Mt. 8:20; Mr. 2:28; Hch. 7:56\xt*)  
\ili1 \k Hipócrita:\k* Tikawex xa kebꞌ upalaj  
\ili2 E ri tikawex lik chakojo ri kubꞌiꞌij yey na e ta uꞌanom. (\xt Mt. 6:2; Lc. 11:44; 12:56\xt*)  
\ili1 \k Hora:\k* Ora  
\ili2 Chupa ri Biblia, ri rajlibꞌal ri ora re jun qꞌij kujeqo echiriꞌ kel lo ri qꞌij; noꞌj chiqawach riꞌoj kujeq tikꞌil aqꞌabꞌ. E uwariꞌche, echiriꞌ pa ri chꞌaꞌtem griego kubꞌiꞌij “la hora tercera del día”, waꞌ pa qachꞌaꞌtem e “ri ubꞌelej ora anim”. Kil ri cuadro chuxeꞌ.  
\tr
\th1 Griego —
\th2 Pa qachꞌaꞌtem 
\tr
\tc1 la hora tercera —
\tc2 ri ubꞌelej ora 
\tr
\tc1 la hora sexta —
\tc2 tikꞌil qꞌij 
\tr
\tc1 la hora séptima —
\tc2 ri nabꞌe ora 
\tr
\tc1 la hora novena —
\tc2 ri urox ora 
\tr
\tc1 la hora décima —
\tc2 ri ukaj ora 
\tr
\tc1 la hora undécima —
\tc2 ri uroꞌ ora 
\ili1 \k Idolatría:\k* Uloqꞌnimaxik tiox  
\ili2 Echiriꞌ junoq kꞌo ri uyaꞌom pukꞌaxel ri Dios (pachaꞌ tiox, puaq, yakbꞌal uqꞌij o juna tikawex) yey más kꞌax kunaꞌ waꞌ chwa ri Dios, e kuꞌan pachaꞌ “dios” che waꞌ. (\xt Hch. 17:16; 1 Co. 10:14; Col. 3:5\xt*)  
\ili1 \k Idolo:\k*  
\li2 1) Tiox  
\li4 E taq ri kidios ri tikawex, waꞌ na e ta ri Dios Qajawxel. (\xt Hch. 7:41; 1 Co. 12:2\xt*)  
\li2 2) Rajaw juna luwar  
\li4 Waꞌ na winaq taj, ma e jun uxlabꞌixel kꞌo pa tew. (\xt 1 Co. 8:5\xt*)  
\ili1 \k Iglesia:\k* Riglesia, ri tinamit re ri Cristo, ri kikojom rubꞌiꞌ ri Cristo  
\ili2 Ri kimolom kibꞌ pa rubꞌiꞌ ri Cristo pa juna luwar. (\xt Hch. 2:47; 9:31; Gl. 1:13\xt*)  
\ili1 \k Incienso:\k* (Junam rubꞌiꞌxik pa qachꞌaꞌtem)  
\ili2 E qꞌol esam che jujun cheꞌ. Ri qꞌol kaporoxik chaꞌ kabꞌuqix sibꞌ lik kꞌo ruxlabꞌ. Ri incienso lik kꞌi uwach; jun che waꞌ e ri pom. Rojertan chupa ri Rocho Dios kaporox incienso chwa ri altar re ri Dios. Wa incienso yijbꞌital rukꞌ qꞌol na xa ta jun uwach y lik kiꞌ ruxlabꞌ. Pa Éxodo 30:34-35 kubꞌiꞌij suꞌanik kayijibꞌaxik. Yey waꞌ xew chwach ri Dios kayaꞌiꞌ wi; ruma kꞌu laꞌ e jun incienso kaporoxik lik santo chwach ri Dios. Pa Jeremías 44:21-23 kubꞌiꞌij ri Dios xusach kiwach jujun tinamit ruma xkiporoj incienso chikiwach ri tiox. (\xt Mt. 2:11; Lc. 1:9; Ap. 8:3\xt*)  
\ili1 \k Infierno:\k* Xibꞌalbꞌaꞌ re tijbꞌal kꞌax (\xt Mt. 5:29; Mr. 9:43-47; Lc. 12:5; 2 P. 2:4\xt*)  
\ili1 \k Inmundicia:\k* Ri chꞌulilaj mak  
\ili2 E ri kuꞌan junoq echiriꞌ kuya ribꞌ che uꞌanik taq ri rayibꞌal re rutiꞌjil, pachaꞌ ri karetzꞌabꞌej uwa uqꞌij xa tobꞌ na rukꞌ. (\xt Ro. 1:24; 2 Co. 12:21; 1 Ts. 4:7\xt*)  
\ili1 \k Insensato:\k* Tikawex na jinta unaꞌoj, ri na kuchꞌobꞌ ta chi utz ri kuꞌano (\xt Mt. 7:26; 25:2-3, 8; Ef. 5:17\xt*)  
\ili1 \k Intercesor:\k* Ri jun kachꞌaw puwi junoq chwach jun chik (\xt Ro. 8:26; Flp. 1:9; Heb. 7:25\xt*)  
\ili1 \k Invierno:\k* Pa qꞌalaj  
\ili2 Chupa ri Biblia pa kaxtila kabꞌiꞌx “invierno” che ruqꞌijol echiriꞌ lik kꞌax tew y kꞌo jabꞌ. Chilaꞌ Israel waꞌ kajeqer octubre y kakꞌis abril. (\xt Mt. 24:20\xt*)  
\ili1 \k Juan el Bautista:\k* Ri Juan aj yaꞌl bautismo (\xt Mt. 3:1; Mr. 6:14; Hch. 1:5\xt*)  
\ili1 \k Juicio:\k* Qꞌatbꞌal tzij (\xt Lc. 10:14; Jn. 16:8; Ap. 15:4\xt*)  
\ili1 \k Juramento:\k* Chꞌaꞌtem kajikibꞌax uwach (\xt Mt. 5:33-37; Hch. 2:30; Heb. 6:16\xt*)  
\ili1 \k Justicia:\k* Ri lik usukꞌ chwach ri Dios, ri jusukꞌ bꞌinik silabꞌik (\xt Mt. 3:15; 5:10; Hch. 10:35; Ro. 10:5-6\xt*)  
\ili1 \k Justificar:\k* Ri Dios kuꞌan jusukꞌ che junoq (\xt Ro. 4:25; 5:18; 1 Co. 1:30; 2 Co. 3:9\xt*)  
\ili1 \k Lascivia:\k* Ri kuya ribꞌ chupa ri rayibꞌal re ri tiꞌjil (\xt Mr. 7:22; Ro. 1:27; Ef. 4:19\xt*)  
\ili1 \k Lepra:\k* (Junam rubꞌiꞌxik pa qachꞌaꞌtem)  
\ili2 E jun yabꞌil kuqꞌayisaj rutiꞌjil junoq yey waꞌ lik kaqꞌaxik. Ruma kꞌu riꞌ e janipa ri kakꞌojiꞌ lepra chike, na utz ta chik kekꞌojiꞌ kukꞌ ri utz kiwach. E uwariꞌche kebꞌeꞌkꞌola lo naj che ri tinamit. (\xt Mt. 8:1-3; Mr. 1:40; Lc. 5:12-13\xt*)  
\ili1 \k Levitas:\k* (Junam rubꞌiꞌxik pa qachꞌaꞌtem)  
\ili2 Waꞌ e ralkꞌoꞌal kan ri Leví. Xyaꞌ chike rike kebꞌuꞌan e aj chak chupa ri Rocho Dios. (\xt Nm. 4; Lc. 10:32; Jn. 1:19; Hch. 4:36\xt*)  
\ili1 \k Ley:\k* Tzijpixabꞌ, taqanik (\xt Mt. 19:18; 22:38; Lc. 2:27; Heb. 10:16\xt*)  
\ili1 \k Ley de Moisés:\k* Tzij Pixabꞌ re ri Dios tzꞌibꞌital kan ruma ri Moisés (\xt Jn. 1:17; Ro. 2:23; 2 Co. 3:15\xt*)  
\ili1 \k Los cuatro puntos cardinales:\k* Rukajchal rajlibꞌal ruwachulew  
\ili2 Waꞌ keꞌelawi pa norte, pa sur, pa relebꞌal qꞌij y putzaqibꞌal qꞌij. (\xt Mt. 24:31; Mr. 13:27; Ap. 7:1\xt*)  
\ili1 \k Lugar Santísimo:\k* Luwar lik Santo  
\ili2 E rukaꞌm upa ja re ri Rocho Dios. Chiriꞌ kꞌo ri kaxa re ri tzij uꞌanom ri Dios kukꞌ rutinamit, yey wa kaxa chꞌuqum rij rukꞌ oro. Xew taqal che ri kajawal raj chakunel pa Rocho Dios kok chupa xa julaj che ri junabꞌ re kutzꞌonoj che ri Dios kukuy kimak ri tinamit Israel. (\xt Mt. 27:51; Heb. 9:3, 8; 13:11\xt*)  
\ili1 \k Lugar santo:\k* Luwar Santo  
\ili2 E ri nabꞌe upa ja re ri Rocho Dios pa kꞌo wi taq ri chapabꞌal re yakbꞌal uqꞌij ri Dios. Chiriꞌ kꞌo wi ri tzukꞌulibꞌal aqꞌ kꞌo wuqubꞌ uqꞌabꞌ, ri mexa pa kayaꞌ wi ri pam yaꞌtal chwach ri Dios y ri altar re oro pa kaporox wi incienso. Xew taq raj chakunel re ri Rocho Dios taqal chike kebꞌok chupa wa luwar. (\xt Mt. 24:15; Mr. 15:38; Lc. 1:9\xt*)  
\ili1 \k Maná:\k* (Junam rubꞌiꞌxik pa qachꞌaꞌtem)  
\ili2 E ri xuya ri Dios chike ri tinamit Israel re kakitij chupa ri luwar katzꞌintzꞌotik. (\xt Jn. 6:31; Heb. 9:4; Ap. 2:17\xt*)  
\ili1 \k Mandamiento:\k* Tzijpixabꞌ, taqanik (\xt Mt. 19:18; 22:38; Lc. 2:27; Heb. 10:16\xt*)  
\ili1 \k Mansedumbre:\k* Chꞌuꞌchꞌuj kꞌuꞌxaj  
\ili2 Juna tikawex chꞌuꞌchꞌuj ukꞌuꞌx na kuꞌan ta nim che ribꞌ. (\xt 1 Co. 4:21; 1 Ti. 6:11; Tit. 3:2\xt*)  
\ili1 \k (El) Mediador entre Dios y los hombres:\k* Ri Jun kꞌo puqꞌabꞌ kachꞌaw paqawiꞌ chwach ri Dios, ri Jun kakꞌamaw qawach chwach ri Dios (\xt 1 Ti. 2:5; Heb. 9:15\xt*)  
\ili1 \k Mente:\k* Unaꞌoj junoq  
\ili2 También keꞌelawi “idea”, “inteligencia” y “pensamiento”. (\xt Mt. 22:37; 1 Co. 2:16; Ap. 2:23\xt*)  
\ili1 \k Mesías:\k* (Junam rubꞌiꞌxik pa qachꞌaꞌtem)  
\ili2 E keꞌelawi ri Cristo, Ruchaꞌoꞌn lo ri Dios. “Mesías” e chꞌaꞌtem pa Hebreo y “Cristo” e chꞌaꞌtem pa griego. (\xt Jn. 1:41\xt*)  
\ili1 \k Mirra:\k* (Junam rubꞌiꞌxik pa qachꞌaꞌtem)  
\ili2 Kunabꞌal kiꞌ ruxlabꞌ y lik kꞌi rajil.  
\ili2 Mt. 2:11; Jn. 19:39; Ap. 18:13 \fig Mirra|alt="Myrrh" src="BK00119b.tif" size="col" ref="voc" \fig*  
\ili1 \k Misericordia\k* Kꞌutubꞌal re ri rutzil kꞌuꞌxaj, kꞌutubꞌal re ri kꞌaxnaꞌbꞌal kꞌuꞌxaj  
\ili2 Ri Dios kukꞌut ri rutzil ukꞌuꞌx chiqe echiriꞌ kukuy ri qamak. (\xt Mt. 5:7; Ro. 11:30; 2 Jn. 3\xt*)  
\ili1 \k Nacer de nuevo:\k* Kalax tanchik  
\ili2 E ri kꞌakꞌ kꞌaslemal kuya ri Dios che junoq echiriꞌ kuya ribꞌ puqꞌabꞌ ri Cristo. (\xt Jn. 3:7; 1 P. 1:3\xt*)  
\ili1 \k Naciones:\k* Rukꞌiyal kiwach taq ri tikawex e kꞌo che ruwachulew  
\ili2 Pa kaxtila también kakibꞌiꞌij “étnias” che waꞌ. (\xt Mt. 24:14; Hch. 3:25; Ap. 1:7\xt*)  
\ili1 \k Nardo:\k* (Junam rubꞌiꞌxik pa qachꞌaꞌtem)  
\ili2 E jun kotzꞌiꞌj kaꞌan perfume che.  
\ili2 Mr. 14:3; Jn. 12:3 \fig Nardo|alt="Spikenard" src="HK00117b.tif" size="col" ref="voc" \fig*  
\ili1 \k Obispo:\k* Aj kꞌamal kiwach rutinamit ri Dios (\xt Hch. 20:28; Flp. 1:1; 1 Ti. 3:2; 1 P. 2:25\xt*)  
\ili1 \k Odre:\k* Surun  
\ili2 E jun ukꞌolibꞌal vino ꞌanom rukꞌ tzꞌuꞌum re kaprux o re bꞌexex.  
\ili2 Mt. 9:17; Mr. 2:22; Lc. 5:37 \fig Odre: Surun|alt="Wineskin" src="LB00145b.tif" size="col" ref="voc" \fig*  
\ili1 \k Ósculo Santo:\k* Jun saqil tzꞌubꞌuj chiꞌaj kakiya ri hermanos chikiwach chwach ri Dios (\xt Ro. 16:16; 1 Co. 16:20; 2 Co. 13:12\xt*)  
\ili1 \k Pacto:\k* Ri tzij kuꞌan junoq rukꞌ jun chik (\xt Lc. 1:72; Hch. 3:25; Ro. 11:27\xt*)  
\ili1 \k Paganos:\k* Ri na ketaꞌam ta uwach ri Dios (\xt Mt. 6:7; 1 Co. 5:1; Ef. 4:17\xt*)  
\ili1 \k Parábola:\k* Kꞌambꞌal naꞌoj (\xt Mt. 13:3; Mr. 4:2; Lc. 18:1\xt*)  
\ili1 \k Paraíso:\k* Chomilaj luwar, werta re ri Dios (\xt Lc. 23:43; 2 Co. 12:4; Ap. 2:7\xt*)  
\ili1 \k Pascua:\k* (Junam rubꞌiꞌxik pa qachꞌaꞌtem)  
\ili2 Ronoje junabꞌ ri aj judiꞌabꞌ kakiꞌan jun nimalaj nimaqꞌij Pascua rubꞌiꞌ. E jun nimaqꞌij kuxtabꞌal re ri xuꞌan ri Dios che rutinamit Israel echiriꞌ xebꞌeresaj lo Egipto, pa lik xꞌan wi kꞌax chike. Kil Éxodo 12:1-28; 23:14-19; 34:18-26; Deuteronomio 16:1-17. Chupa ri nabꞌe Pascua ri ángel re ri Dios xikꞌow chikixoꞌl raj Egipto y xebꞌukamisaj ri atzixelabꞌ chike ri e alabꞌo. Noꞌj raj Israel xekolobꞌetaj che waꞌ ma rike xkisoqꞌ kikꞌ re bꞌexex che ruchiꞌ ri puerta re ri kocho jelaꞌ pachaꞌ ri xtaqan ri Dios che. Waqꞌij ora riꞌoj kaqakuxtaj ri nimaqꞌij Pascua pa taq loqꞌlaj qꞌij, kuxtabꞌal re ri qakolobꞌetajik ruma rukikꞌel ri Cristo. Ri nimaqꞌij Pascua na e ta uqꞌijol ri ralaxibꞌal ri Jesús. (\xt Mt. 26:2; Lc. 2:41; Hch. 12:3\xt*)  
\ili1 \k Pastor:\k*  
\li2 1) Aj chajal bꞌexex  
\li4 Ruchak juna aj chajal bꞌexex e kebꞌutzuqu y kebꞌukunaj rawaj yey kebꞌuchajij chikiwach ritzel chikop. (\xt Lc. 2:8; Jud. 12\xt*)  
\li2 2) Aj chajal rutinamit ri Dios  
\li4 Ruchak juna aj chajal rutinamit ri Dios e kebꞌuchajij ri kikojom rubꞌiꞌ ri Cristo chaꞌ kꞌo kikꞌiyibꞌal chwach ri Dios. Kukꞌut Ruchꞌaꞌtem ri Dios chike, kebꞌupixabꞌaj y kunimarisaj kikꞌuꞌx. (\xt Ef. 4:11; 1 P. 5:4\xt*)  
\ili1 \k Patriarcas:\k* Ri kimam ri tinamit Israel  
\ili2 Waꞌ e ri kabꞌlajuj ukꞌajol Jacob. (\xt Hch. 7:8\xt*)  
\ili1 \k Paz:\k* Utzil chomal (\xt Mr. 5:34; Lc. 2:14; 12:51; Gl. 5:22\xt*)  
\ili1 \k Pentecostés:\k* Nimaqꞌij re Pentecostés  
\ili2 E jun nimaqꞌij katzaq cincuenta qꞌij rikꞌowik ri nimaqꞌij re Pascua. Chupa kꞌu wa nimaqꞌij xqaj lo ri Ruxlabꞌixel ri Dios pakiwi rutijoꞌn ri Jesús jelaꞌ pachaꞌ rubꞌiꞌtisim Rire chike. (\xt Hch. 2:1; 20:16; 1 Co. 16:8\xt*)  
\ili1 \k Perla:\k* (Junam rubꞌiꞌxik pa qachꞌaꞌtem)  
\ili2 E jun chomilaj abꞌaj lik kꞌo rajil. Waꞌ kesax che jun awaj re mar ostra rubꞌiꞌ.  
\ili2 Mt. 7:6; 13:44-46; 1 Ti. 2:9; Ap. 17:4 \fig Perlas|alt="Pearls" src="LB00171b.tif" size="col" ref="voc" \fig*  
\ili1 \k Persecución:\k* Uternabꞌexik junoq rukꞌ kꞌaxkꞌobꞌik  
\ili2 Ri e nabꞌe xkikoj rubꞌiꞌ ri Cristo xeyaꞌ pa kꞌax ruma ri kubꞌulibꞌal kikꞌuꞌx rukꞌ Rire. (\xt Mt. 5:10; Hch. 8:1; Ro. 8:35\xt*)  
\ili1 \k Perseverar:\k* Kuchuqꞌubꞌej ribꞌ che uꞌanik taq ri kuꞌano kꞌa pa kꞌisbꞌal re  
\ili2 Jewaꞌ kuꞌano tobꞌ waꞌ kꞌayew o karikꞌowibꞌej kꞌax ruma. (\xt Mt. 24:13; Ro. 2:7; Col. 4:2\xt*)  
\ili1 \k Piedad:\k* Jun saqil bꞌinik silabꞌik chwach ri Dios  
\ili2 Junoq “piadoso” e ri uyaꞌom ribꞌ che jun saqil bꞌinik silabꞌik chwach ri Dios (\xt 1 Ti. 4:7-8; Tit. 2:12; 2 P. 3:11\xt*)  
\ili1 \k Principales Sacerdotes:\k* Ri nimaq e aj chakunel pa Rocho Dios  
\ili2 E kꞌo 24 grupos e aj chakunel pa ri Rocho Dios y chikijujunal waꞌ kꞌo jun aj wach, yey wa e aj wach kabꞌiꞌx “nimaq e aj chakunel pa Rocho Dios” chike. (\xt Mt. 2:4; Lc. 23:4; Hch. 25:2\xt*)  
\ili1 \k Profecía:\k* Uqꞌalajisaxik runaꞌoj ri Dios, ri qꞌalajisanik puwi ri katajin loq (\xt 1 Co. 13:2; 1 Ts. 5:20; 2 P. 1:21\xt*)  
\ili1 \k Profeta:\k* Qꞌalajisanel re ri Dios  
\ili2 E ri kuqꞌalajisaj runaꞌoj ri Dios y Rutzij ri Dios. (\xt Mt. 2:17; Mr. 11:32; Jn. 7:40\xt*)  
\ili1 \k Prosélito al judaismo:\k* E junoq xkoj pujolom kuꞌan kukꞌil raj judiꞌabꞌ  
\ili2 E ri lik kuloqꞌnimaj uqꞌij ri Dios y utaqem ri kꞌutunik ke raj judiꞌabꞌ, tobꞌ ruchu-uqaw na e ta kukꞌil raj judiꞌabꞌ. (\xt Hch. 2:10; 6:5; 13:43\xt*)  
\ili1 \k Prueba:\k* Kꞌambꞌal upa junoq (\xt Lc. 8:13; Ro. 5:4; Stg. 1:3\xt*)  
\ili1 \k Publicano o cobrador de impuestos:\k* Aj tzꞌonol puaq re tojonik  
\ili2 Raj tzꞌonol puaq lik tzel kebꞌil kuma ri kach aj Israel ma kechakun rukꞌ ri gobierno romano, ri kataqan pakiwi raj Israel. Kabꞌiꞌx chike e rayinel y eleqꞌomabꞌ ma kakitzꞌonoj uwi ri tojonik kaꞌanik y rukꞌ waꞌ kakiꞌan kꞌax che ri tinamit. (\xt Mr. 2:14-15; Lc. 3:12-13; 19:2\xt*)  
\ili1 \k Púrpura:\k* Morato  
\ili2 Ojertan xew ri lik kꞌo kiwach pachaꞌ ri reyes o ri bꞌeyomabꞌ kakikoj kꞌul morato, ma waꞌ lik kꞌi rajil. (\xt Mr. 15:17; Lc. 16:19; Hch. 16:14; Ap. 18:12\xt*)  
\ili1 \k Querubines:\k* (Junam rubꞌiꞌxik pa qachꞌaꞌtem)  
\ili2 E pachaꞌ e ángeles. Ri Dios xebꞌukoj jujun querubines re kakichajij ri werta re Edén echiriꞌ xebꞌeresaj bꞌi ri Adán y ri Eva. Kil Génesis 3:24. También ri Dios xtaqan che kakoj kikꞌaxwach kebꞌ querubines puwi ri kaxa re ri tzij uꞌanom ri Dios kukꞌ rutinamit. Kil Éxodo 25:18-20. (\xt Ez. 10; Is. 37:16; Heb. 9:5\xt*)  
\ili1 \k Rabí:\k* Lal tijonel  
\ili2 E jun tijonel lik uyaꞌom ribꞌ che umajik Ruchꞌaꞌtem ri Dios y kuqꞌalajisaj taq ri umajom chikiwach ri winaq. Taq rutijoꞌn kakibꞌiꞌij “lal tijonel” che. (\xt Mt. 23:8; Jn. 1:49; 4:31\xt*)  
\ili1 \k Reconciliación:\k* Ri kakiꞌan utzil chomal chikiwach  
\ili2 Echiriꞌ ri Adán y ri Eva xemakunik, e xkijam ri utzil chomal rukꞌ ri Dios. Pero ruma ri Qanimajawal Jesucristo, taq ri tikawex utz kakiriq tanchi utzil chomal rukꞌ ri Dios. (\xt Ro. 5:11; 2 Co. 5:18\xt*)  
\ili1 \k Redención:\k* Loqꞌobꞌal re ri xujamo, kolobꞌetajik  
\ili2 1) E echiriꞌ junoq kꞌo tojbꞌal kuya pukꞌaxel ri ujamom, waꞌ kuꞌan tanchi re.  
\ili2 2) Taq ri tikawex xekꞌojiꞌ puqꞌabꞌ ritzel winaq echiriꞌ ri Adán y Eva xemakunik, pero ri Qanimajawal Jesucristo xuya ribꞌ pa kamik chaꞌ ruma rukikꞌel kojuloqꞌo y jelaꞌ kojresaj puqꞌabꞌ ritzel winaq y kojuꞌan oj re Rire. (\xt Lc. 2:38; Ro. 3:24; Heb. 9:12\xt*)  
\ili1 \k Reino de Dios:\k* Rutaqanik ri Dios  
\ili2 E pa kataqan wi Rire. Chilaꞌ chikaj ronoje puqꞌabꞌ ri Dios kꞌo wi. Yey wara che ruwachulew rutaqanik e ri kuꞌan pa kanimaꞌ janipa ri kiyaꞌom kibꞌ puqꞌabꞌ. (\xt Mt. 6:33; Mr. 4:26; Hch. 8:12\xt*)  
\ili1 \k Reino de los cielos:\k* Rutaqanik ri Dios petinaq chilaꞌ chikaj (\xt Mt. 3:2; 13:24; 19:23\xt*)  
\ili1 \k Regeneración:\k* Ri kuꞌan tanchi kꞌakꞌ  
\ili2 1) E ri kaꞌan kꞌakꞌ che taq ri kꞌolik (\xt Mt. 19:28; Tit. 3:5\xt*)  
\ili2 2) E ri kalax tanchi ri tikawex che jun kꞌakꞌ kꞌaslemal (\xt Ef. 4:22-24; Col. 3:8-10, 12\xt*)  
\ili1 \k Resurrección:\k* Kꞌastajibꞌal ke ri ekaminaq, kꞌastajibꞌal chikixoꞌl ri ekaminaq (\xt Mt. 22:31; Hch. 17:32; 1 Co. 15:13\xt*)  
\ili1 \k Rollo, libro:\k* Jubꞌotaj wuj  
\ili2 Ojertan junwi ri libro; e jubꞌotaj wuj ꞌanom rukꞌ tzꞌuꞌum o rukꞌ jun tikoꞌn “papiro” rubꞌiꞌ.  
\ili2 Lc. 4:20; Heb. 10:7; Ap. 6:14 \fig Ri “libros” re ojertan e jubꞌotaj wuj (Lucas 4:20; Hebreos 10:7; Apocalipsis 6:14)|alt="Scrolls" src="HK00153b.tif" size="col" ref="voc" \fig*  
\ili1 \k Sacerdote:\k* Ri aj chakunel pa Rocho Dios  
\ili2 Ri chak kakiꞌan raj chakunel pa Rocho Dios e waꞌ: Kechꞌaw pakiwi ri tinamit chwach ri Dios rukꞌ oración, kebꞌixonik, kakikꞌul ri qasaꞌn y kakiqꞌatisaj ri sacrificios ke ri tinamit chwach ri Dios. Konoje raj chakunel pa Rocho Dios kipetebꞌem chike ri e ralkꞌoꞌal ri Aarón, ri nabꞌe aj chakunel xuchaꞌ ri Dios. Kil Levítico 8:1-9,12-14. Taq rukꞌajol juna aj chakunel pa Rocho Dios kebꞌuꞌana e aj chakunel pachaꞌ ri kiqaw. (\xt Mt. 8:4; Lc. 10:31; Heb. 7:5\xt*)  
\ili1 \k Sacrificio:\k* Qasaꞌn re awaj ekamisam chwa juna altar  
\ili2 Ojertan kekamisax awaj pakikꞌaxel ri winaq ruma ri kimak. Yey woꞌora na kajawax ta chi kaꞌan waꞌ, ma ri Qanimajawal Jesucristo xkam pakikꞌaxel ri tikawex, tojbꞌal re ri kimak. (\xt Mt. 9:13; Ro. 12:1; Heb. 9:26\xt*)  
\ili1 \k Saduceos:\k* (Junam rubꞌiꞌxik pa qachꞌaꞌtem)  
\ili2 E jun grupo aj judiꞌabꞌ lik kꞌo kiwach. E kꞌi chike raj chakunel pa ri Rocho Dios e saduceos. Rike na kakitaqej ta rukꞌiyal taqanik ke ri fariseos yey na kakikoj taj we e kꞌo ángeles o we kꞌo kꞌastajibꞌal chike ri ekaminaq. (\xt Mt. 22:23; Mr. 12:18; Hch. 5:17; 23:8\xt*)  
\ili1 \k Samaria:\k* (Junam rubꞌiꞌxik pa qachꞌaꞌtem)  
\ili2 E jun tinamit kꞌo chuxoꞌlibꞌal taq ri luwar re Galilea y Judea. Ri aj Samaria e kalkꞌoꞌal kan tikawex e aj naj xekꞌojiꞌ chilaꞌ ojertan. Rike na kebꞌopon ta Jerusalem che uyakik uqꞌij ri Dios yey lik tzel kebꞌil kuma ri aj judiꞌabꞌ. Kil 1 Reyes 12; 16:24; 2 Reyes 17:24-41; Juan 4. (\xt Lc. 10:33; Jn. 4:7; Hch. 8:14\xt*)  
\ili1 \k Santo:\k*  
\ili2 Xew ri Dios lik nim uqꞌij santo, ma Rire na jinta kꞌana umak. (\xt Lc. 1:49; 1 P. 1:15-16\xt*)  
\ili1 \k Santos:\k* Konoje ri lik kiyaꞌom kibꞌ puqꞌabꞌ ri Cristo, ri hermanos kikojom rubꞌiꞌ ri Cristo (\xt 2 Co. 13:13; Heb. 3:1\xt*)  
\ili1 \k Santidad:\k* Jusukꞌ bꞌinik silabꞌik chwach ri Dios (\xt Lc. 1:75; 2 Co. 7:1; 1 P. 1:16\xt*)  
\ili1 \k Satanás:\k* (Junam rubꞌiꞌxik pa qachꞌaꞌtem)  
\ili2 E ubꞌiꞌ ritzel winaq, ri kajawal ritzel uxlabꞌixel. “Satanás” keꞌelawi “tzꞌaqal tzij”. (\xt Mt. 4:10; Lc. 10:18; 2 Co. 11:14\xt*)  
\ili1 \k Sinagoga:\k* (Junam rubꞌiꞌxik pa qachꞌaꞌtem)  
\ili2 E jun luwar pa kakimol wi kibꞌ raj judiꞌabꞌ chaꞌ kakita Rutzij Upixabꞌ ri Dios y kakiꞌan orar. Pa taq ri tinamit kꞌo sinagogas, noꞌj ri Rocho Dios xew ri jun kꞌo Jerusalem y xew chilaꞌ kekamisax awaj chwach raltar re ri Dios. (\xt Mt. 4:23; Lc. 4:33; Hch. 13:42\xt*)  
\ili1 \k Sion:\k* (Junam rubꞌiꞌxik pa qachꞌaꞌtem)  
\ili2 E jun juyubꞌ kꞌo Israel; puwi waꞌ kꞌo wi ri tinamit Jerusalem. Yey kꞌolik keꞌelawi e ri luwar pa kꞌo wi ri Dios chilaꞌ chikaj. (\xt Mt. 21:5; Heb. 12:22; 1 P. 2:6\xt*)  
\ili1 \k Sobrio:\k* Ri kuchꞌobꞌ na chi utz saꞌ taq ri kuꞌano (\xt 1 Ts. 5:6; 2 Ti. 4:5; 1 P. 5:8\xt*)  
\ili1 \k Sorteo:\k* (Junam rubꞌiꞌxik pa qachꞌaꞌtem)  
\ili2 Ri kakiꞌan ojertan e pa jun kꞌolibꞌal kayaꞌ raltaq ko abꞌaj o raltaq ko cheꞌ tzꞌibꞌital jun bꞌiꞌaj chwach. Yey e ri kachꞌopilin loq echiriꞌ kayikiyoꞌxik, e riꞌ ri uchaꞌom lo ri Dios. (\xt Lc. 1:9; Hch. 1:26\xt*)  
\ili1 \k Sumo Sacerdote:\k* Kajawal raj chakunel pa Rocho Dios (\xt Mt. 26:3; Mr. 14:60; Hch. 4:6\xt*)  
\ili1 \k Tabernáculo:\k* Rocho Dios xa kakirik  
\ili2 E nabꞌe Rocho Dios xyak kuma ri tinamit Israel. Echiriꞌ xebꞌin rike pa ri luwar katzꞌintzꞌotik, kakitor waꞌ, kakikꞌam bꞌi y kakiyak tanchi pa kekꞌojiꞌ wi.  
\ili2 Hch. 7:44; Heb. 8:5 \fig Ri tabernáculo: Ri Rocho Dios xa kakirik|alt="Tabernaculo" src="CN01921b.tif" size="span" ref="voc" \fig*  
\ili1 \k Temor:\k* Xiꞌin ibꞌ  
\li2 \k Tener miedo:\k*  
\li4 Lik kuxiꞌij ribꞌ. (\xt Mt. 2:22\xt*)  
\li2 \k Temor respetuoso a Dios:\k*  
\li4 Kꞌo xiꞌin ibꞌ rukꞌ chwach ri Dios. (\xt Hch. 10:2\xt*)  
\ili1 \k Templo:\k* Rocho Dios  
\ili2 Ri Rocho Dios xyakiꞌ ruma ri Salomón chupa ri tinamit Jerusalem, e xujal bꞌi ri “tabernáculo” xkukꞌaꞌaj ri tinamit Israel echiriꞌ xebꞌin chupa ri luwar katzꞌintzꞌotik. Ri Rocho Dios xkꞌojiꞌ Jerusalem e jun sitio sutum rij rukꞌ tapia re nimaꞌq taq abꞌaj. Chilaꞌ xebꞌopon ri tikawex re keꞌkiloqꞌoj uqꞌij ri Dios y re keꞌkiyaꞌa ri kiqasaꞌn chwach ri Dios. Xew chilaꞌ taq raj chakunel pa Rocho Dios xekikamisaj rawaj chwa raltar re ri Dios. Chunikꞌajal ri sitio kꞌo jun chomilaj ja kebꞌ upa. Ri nabꞌe e ri Luwar Santo y rukaꞌm e ri Luwar lik Santo. Chupa ri nabꞌe upa ja xew xebꞌok taq raj chakunel re ri Rocho Dios. Chupa ri Luwar lik Santo xew xok ri kajawal raj chakunel re ri Rocho Dios. Ri Rocho Dios xyak ruma ri Salomón, xwulix ruma ri rey Nabucodonosor, yey xyakiꞌ tanchik ruma ri Zorobabel chupa ruqꞌijol ri Esdras. Chwach pan ri ralaxibꞌal ri Jesús, ri Herodes xujeq uyijbꞌaxik ri Rocho Dios, yey waꞌ xwulix kuma ri soldados aj Roma chupa ri junabꞌ 70 D.C. cuarenta junabꞌ chwi rukamik ri Jesús.  
\ili2 Mt. 24:1; Mr. 12:35; Hch. 2:46 \fig Ri Rocho Dios xyak ruma ri Herodes|alt="Herods temple" src="LB00250b.tif" size="span" ref="voc" \fig*  
\ili1 \k Tentación:\k* Ri kamin uwach junoq pa mak, kꞌambꞌal upa junoq  
\ili2 E ritzel winaq o taq ri rayibꞌal re ri qatiꞌjil ri kojumin chupa ri mak. (\xt Mt. 26:41; 1 Co. 10:13; Stg. 1:12\xt*)  
\ili1 \k Títulos de Cristo:\k*  
\li2 \k El Buen Pastor:\k* Ri Utzilaj Chajinel ke bꞌexex (\xt Jn. 10:11\xt*)  
\li2 \k El Cordero de Dios:\k* Ri Qꞌapoj Bꞌexex (\xt Jn. 1:29; Ap. 5:6\xt*)  
\li2 \k El Pan de vida:\k* Ri Pam kuya kꞌaslemal (\xt Jn. 6:48\xt*)  
\li2 \k El Kamino:\k* Ri Bꞌe (\xt Jn. 14:6\xt*)  
\li2 \k La Verdad:\k* Ri Qꞌijsaq (\xt Jn. 14:6\xt*)  
\li2 \k La Vida:\k* Ri Kꞌaslemal (\xt Jn. 14:6\xt*)  
\ili1 \k Títulos de Dios:\k*  
\li2 \k El Altísimo:\k* Ri kataqan chwi ronoje (\xt Lc. 1:32; 6:35\xt*)  
\li2 \k El Dios Padre:\k* Ri Qaqaw Dios (\xt Ef. 6:23; Flp. 2:11; Tit. 1:4\xt*)  
\li2 \k El Señor Dios:\k* Ri Dios Qajawxel (\xt Lc. 1:32; Ap. 4:8\xt*)  
\li2 \k El Todopoderoso:\k* Ri kꞌo ronoje unimal chuqꞌabꞌ puqꞌabꞌ (\xt 2 Co. 6:18; Ap. 4:8; 11:17\xt*)  
\ili1 \k Tribulación:\k* Kꞌaxkꞌobꞌik (\xt Mt. 24:9; Ro. 5:3; Flp. 4:14\xt*)  
\ili1 \k Tribunal:\k* Luwar pa kaqꞌat wi tzij pakiwi ri tikawex (\xt Jn. 19:13; Hch. 18:12; 2 Co. 5:10\xt*)  
\ili1 \k Ungido de Dios:\k* Ruchaꞌoꞌn lo ri Dios (\xt Lc. 2:26; Hch. 4:27\xt*)  
\ili1 \k Ungir:\k*  
\li2 1) Kuqꞌej che o kusoqꞌ che o kukoj che  
\li4 Kaꞌan waꞌ re kunabꞌal. (\xt Stg. 5:14\xt*)  
\li2 2) Kukoj puwiꞌ  
\li4 Kaꞌan waꞌ rukꞌ aceite echiriꞌ junoq kakojik re rey o kakojik re kajawal raj chakunel pa Rocho Dios.  
\li2 3) Ri kaꞌanik echiriꞌ kayijbꞌax juna cuerpo re kamuqik (\xt Mr. 14:3-8; Jn. 12:3-7; 19:40\xt*)  
\ili1 \k Verano:\k* Pa saqꞌij  
\ili2 Chupa ri Biblia pa kaxtila kabꞌiꞌx “verano” che ruqꞌijol echiriꞌ lik kabꞌukbꞌutik y na jinta jabꞌ. Chilaꞌ Israel waꞌ kajeqer mayo y kakꞌis kꞌa septiembre. (\xt Mt. 24:32; Mr. 13:28; Lc. 21:30\xt*)  
\ili1 \k Verdad:\k* Ri Qꞌijsaq re ri Dios, ri saqil kꞌutunik, ri qatzij, ri areꞌ (\xt Mr. 12:32; Jn. 1:14; Ef. 4:25\xt*)  
\ili1 \k Vida eterna:\k* Kꞌaslemal na jinta utaqexik (\xt Mt. 19:16; Jn. 3:36; 6:68; 1 Jn. 2:25\xt*)  
\ili1 \k Virgen:\k*  
\li2 1) Junoq na kꞌuliꞌnaq taj y na uminom ta ribꞌ rukꞌ junoq (\xt 1 Co. 7:25; Ap. 14:4\xt*)  
\li2 2) Qꞌapoj ali o ala (\xt Mt. 1:23; 25:7; 2 Co. 11:2\xt*)  
\ili1 \k Voluntad de Dios:\k* Ri rajawal ukꞌuꞌx ri Dios  
\ili2 E janipa ri karaj ri Dios. (\xt Mt. 6:10; 26:42; Hch. 21:14; Ro. 12:2\xt*)  
\ili1 \k Zelote o Cananista:\k* (Junam rubꞌiꞌxik pa qachꞌaꞌtem)  
\ili2 Ri chꞌaꞌtem “zelote” pa griego junam keꞌelawi rukꞌ ri chꞌaꞌtem “cananista” pa arameo. Waꞌ e jun kukꞌil ri lik kakaj kel lo ri tinamit Israel puqꞌabꞌ ri taqanik re Roma. (\xt Mt. 10:4; Mr. 3:18; Lc. 6:15; Hch. 1:13\xt*)  