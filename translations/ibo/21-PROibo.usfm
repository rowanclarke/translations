\id PRO - Biblica® Open Igbo Contemporary Bible 2020
\h Ilu
\toc1 Ilu
\toc2 Ilu
\toc3 Ilu
\mt1 Ilu
\c 1
\ms1 Ihe mere e ji dee Ilu
\p 
\v 1 Ndị a bụ ilu Solomọn nwa Devid, eze Izrel.
\q1 
\v 2 Ọ bụ maka amamihe na ntụziaka,
\q2 maka ịghọta okwu niile kwesiri ịghọta nke ọma,
\q1 
\v 3 nʼihi inweta ntụziaka nʼinwe uche,
\q2 ime ezi omume na ikpe ziri ezi nke aghụghọ na-adịghị.
\q1 
\v 4 Nʼihi ime ka ndị na-enweghị uche nwee ezi uche,
\q2 ka ndị na-eto eto nweta ihe ọmụma na izuzu ọma.
\q1 
\v 5 Ka onye maara ihe gee ntị, tụkwasịkwa ihe nʼihe ọ maara,
\q2 ka ndị nwere nghọta nwetakwa ezi ndụmọdụ.
\q1 
\v 6 Ka ha ghọta ilu niile na okwu niile
\q2 na-esi nʼọnụ ndị maara ihe.
\b
\q1 
\v 7 Ịtụ egwu \nd Onyenwe anyị\nd* bụ mmalite ihe ọmụma.\f + \fr 1:7 \ft \xt Ilu 9:10; Ilu 15:33; Ekl 12:13\xt*\f*
\q2 Ọ bụkwa naanị ndị nzuzu bụ ndị na-adịghị anabata amamihe na ịdọ aka na ntị.
\ms1 Okwu mmalite: Nkwado maka ịnabata amamihe
\s1 Ịdọ aka na ntị banyere ndị nrafu
\q1 
\v 8 Nwa m, na-aṅa ntị na ntụziaka nke nna gị
\q2 ahapụkwala ndụmọdụ nne gị.
\q1 
\v 9 Nʼihi na okpu amara ka ha ga-abụrụ isi gị,
\q2 bụrụkwa ihe ịnya nʼolu nye gị.
\b
\q1 
\v 10 Nwa m, ọ bụrụ na ndị mmehie ara gị ụra,
\q2 ekwenyerela ha, Ekwela!\f + \fr 1:10 \ft \xt Jen 39:7-10; Dit 13:8; Efe 5:11.\xt*\f*
\q1 
\v 11 Ọ bụrụ na ha asị gị, “Bịa soro anyị; ka anyị zoo onwe anyị,
\q2 tigbuo onye ọbụla anyị hụrụ,
\q2 bụ onye na-emeghị ihe ọjọọ ọbụla.
\q1 
\v 12 Ka anyị loo ha na ndụ, dịka ala ili,
\q2 loo ha kpamkpam dịka ndị na-arịda nʼolulu.
\q1 
\v 13 Anyị ga-enwetakwa ọtụtụ ihe dị oke ọnụahịa,
\q2 nke anyị ga-akwaju nʼụlọ anyị.
\q1 
\v 14 Soro anyị fee nza gị ka anyị nwaa ike anyị,
\q2 ihe ọbụla kwa anyị nwetara, anyị na gị ga-ekekọta ya ọnụ.”
\q1 
\v 15 Nwa m, ejela ije nʼụzọ ndị dị otu a,
\q2 a zọọkwala ụkwụ nʼokporoụzọ ha;
\q1 
\v 16 nʼihi na ụkwụ ha na-agba ọsọ ime ihe ọjọọ,
\q2 na-emekwa ngwangwa iwufu ọbara.
\q1 
\v 17 Ọ bụ ihe abaghị uru ịgbasa ụgbụ,
\q2 nʼebe nnụnụ ọbụla na-ahụ ya anya.
\q1 
\v 18 Ma ndị a na-esi ọnya nke na-ama ha.
\q2 Ha onwe ha ka ọnya ahụ ga-ejide.
\q1 
\v 19 Otu a ka ọ na-adịkwara ndị ọ na-agụsị agụụ ike inweta akụnụba nʼụzọ na-ezighị ezi.
\q2 Nʼihi na ịgbaso ụzọ dị otu a na-ewetara ndị na-eso ya ọnwụ.
\s1 Jidesie amamihe aka ike
\q1 
\v 20 Amamihe na-eti mkpu nʼezi ka mmadụ nụ.
\q2 Olu ya na-ada ụda nʼama.
\q1 
\v 21 Ọ bụ nʼisi akụkụ ụzọ nke mkpọtụ dịkarịsịrị ka ọ na-akpọ oku,
\q2 nʼọnụ ụzọ ama obodo ka ọ na-anọ ekwupụta okwu ọnụ ya niile.
\b
\q1 
\v 22 “Unu ndị na-enweghị uche ruo ole mgbe ka unu ga-anọgide bụrụ ndị ga-ahụ enweghị uche nʼanya?
\q2 Ruo ole mgbe ka ndị na-akwa emo ga-anọgide na mmasị ịkwa emo?
\q2 Ruo ole mgbe ka ndị nzuzu ga-anọgide na-akpọ ihe ọmụma asị?
\q1 
\v 23 Ọ bụrụ na unu gere ntị na mba m na-abara unu,
\q2 aga m awụpụ echiche niile nke obi m nye unu,
\q2 aga m emekwa ka unu mara okwu m.
\q1 
\v 24 Ma ebe ọ bụ na unu egeghị ntị mgbe m kpọrọ oku,
\q2 setịpụkwa aka m nye unu ma ọ dịghị onye ṅara ntị,
\q1 
\v 25 ebe ọ bụ na unu akpọla ndụmọdụ m asị,
\q2 jụkwa ịnabata ịba mba m nye unu,
\q1 
\v 26 ụbọchị unu ga-adaba na mmekpa ahụ, aga m achị ọchị.
\q2 Mgbe ihe egwu bịakwasịrị unu, aga m akwa unu emo.
\q1 
\v 27 Mgbe oke ihe egwu ga-abịakwasị unu dịka ikuku dị ike,
\q2 mgbe nhụju anya ga-erubiga nʼelu unu dịka oke ifufe,
\q2 mgbe ịta ahụhụ na nsogbu ga-agbagwoju unu anya.
\b
\q1 
\v 28 “Agaghị m ege ntị nʼakwa unu, ọ bụ ezie na unu ga na-akpọ m.
\q2 Unu ga-achọkwa m ma unu agaghị achọta m.
\q1 
\v 29 Nʼihi na unu mechiri anya unu nʼebe ihe ọmụma dị,
\q2 unu atụghị egwu \nd Onyenwe anyị\nd*.
\q1 
\v 30 Unu aṅaghị ntị na ndụmọdụ m.
\q2 Unu lelịrị ịba mba m anya.
\q1 
\v 31 Ihe niile unu kụrụ ka unu ga-aghọta.
\q2 Ọ bụkwa ụzọ unu na ndụmọdụ unu ga-eju unu afọ.
\q1 
\v 32 Nʼihi na ejezighị ije nke ndị na-enweghị uche na-egbu ha,
\q2 ọ bụkwa ọnọdụ afọ ojuju ndị nzuzu ga-alakwa ha nʼiyi.
\q1 
\v 33 Ma onye na-ege ntị nʼokwu m ga-ebi obi ntụkwasị obi.
\q2 Ọ ga-anọ jụụ na-enweghị ihe ọbụla ga-atụ ya egwu.”
\c 2
\s1 Ịba uru nke amamihe
\q1 
\v 1 Nwa m, ọ bụrụ na ị nabata okwu ọnụ m niile
\q2 zobekwa iwu m niile nʼime obi gị,
\q1 
\v 2 tọọ ntị gị nʼala nye amamihe,
\q2 wepụta obi gị inwe nghọta.
\q1 
\v 3 E, ọ bụrụ na ọ bụ ihe ọmụma ka ị na-akpọku,
\q2 ọ bụrụkwa na ọ bụ nghọta ka ị na-eweliri olu gị,
\q1 
\v 4 ọ bụrụ na ị na-achọ ya dịka i si achọ ọlaọcha
\q2 maọbụ akụ nke zoro ezo,
\q1 
\v 5 mgbe ahụ, ị ga-aghọtakwa ihe bụ ịtụ egwu \nd Onyenwe anyị\nd*
\q2 chọtakwa ihe ọmụma nke Chineke.
\q1 
\v 6 Nʼihi na ọ bụ \nd Onyenwe anyị\nd* na-enye amamihe;
\q2 nʼebe ọ nọ ka nghọta na ihe ọmụma na-esi abịa.\f + \fr 2:6 \ft \xt 1Ez 3:9,12; Job 32:8; Jem 1:5.\xt*\f*
\q1 
\v 7 Ọ na-edebere ndị ụzọ ha ziri ezi nzube ọganihu,
\q2 ọ bụ ọta nye ndị na-eje ije nʼizuoke.
\q1 
\v 8 Ọ na-echebekwa ụzọ nke ndị na-eme ezi ihe na-agbaso,
\q2 na-elekọtakwa ụzọ nke ndị hụrụ ya nʼanya na-agbaso.
\b
\q1 
\v 9 Mgbe ahụ ka ị ga-aghọta ihe ziri ezi
\q2 na ihe dị mma na ezi ụzọ niile.
\q1 
\v 10 Nʼihi na amamihe ga-enwe ọnọdụ nʼime obi gị,
\q2 ihe ọmụma ga-adịkwa mkpụrụobi gị ụtọ.
\q1 
\v 11 Izuzu zuruoke ga-echebe gị,
\q2 nghọta ga na-eche gị nche.
\b
\q1 
\v 12 Amamihe ga-azọpụta gị site nʼụzọ ndị mmehie,
\q2 sitekwa na mmadụ ndị okwu ha jọrọ njọ,
\q1 
\v 13 ndị hapụrụ ụzọ niile ziri ezi nke Chineke
\q2 na-agbaso ụzọ niile nke ọchịchịrị,
\q1 
\v 14 ndị na-aṅụrị ọṅụ nʼihe ọjọọ,
\q2 nʼihi na mmehie ha na-atọ ha ụtọ.
\q1 
\v 15 Ihe ọbụla ha na-eme gbagọrọ agbagọ,
\q2 jọọkwa njọ.
\b
\q1 
\v 16 Ọ bụ naanị amamihe ga-anapụta gị nʼaka nwanyị akwụna,
\q2 na nwanyị na-abụghị nwunye gị nke na-ekwu okwu nrafu.
\q1 
\v 17 Onye na-ahapụ di ọ lụrụ nʼagbọghọ,
\q2 nke chefuru ọgbụgba ndụ ọ gbara nʼihu Chineke.
\q1 
\v 18 Ụlọ nwanyị dị otu a dị nʼokporoụzọ
\q2 nke na-eduba nʼọnwụ na nʼọkụ ala mmụọ.
\q1 
\v 19 Ndị ikom niile banyere nʼụlọ ha na-ala nʼiyi.
\q2 Ha adịghị alọtakwa nʼokporoụzọ nke na-eduba na ndụ.
\b
\q1 
\v 20 Nʼihi nke a, ị ga-aga ije nʼụzọ ndị ezi omume,
\q2 debekwa ụkwụ gị nʼokporoụzọ niile nke ndị ezi omume,
\q1 
\v 21 nʼihi na ọ bụ naanị ndị ziri ezi ga-ebi nʼala ahụ,
\q2 ndị na-enweghị ịta ụta ga-afọdụkwa nʼime ya.
\q1 
\v 22 Ma ndị na-emebi iwu ka a ga-ebipụ site nʼala ahụ,
\q2 ọ bụkwa ndị na-ekwesighị ntụkwasị obi ka a ga-ewezuga na ya.
\c 3
\s1 Amamihe na-eweta ahụ ike
\q1 
\v 1 Nwa m echezọla ihe niile m ziri gị.
\q2 Ma debe iwu m nʼobi gị.
\q1 
\v 2 Nʼihi na ha ga-eme ka ndụ gị dị ogologo ruo ọtụtụ afọ,
\q2 wetakwara gị udo na ọganihu.
\b
\q1 
\v 3 Ekwela ka ịhụnanya na ikwesi ntụkwasị obi hapụ gị,
\q2 kekwasị ha nʼolu gị,
\q2 deekwa ha nʼelu mbadamba nkume, bụ obi gị.\f + \fr 3:3 \ft Ịsụgharị ya nʼụzọ ọzọ ga-abụ, \fqa deekwa ha nʼime obi gị \xt 7:3; 2Kọ 3:3\xt*\f*
\q1 
\v 4 Mgbe ahụ, ị ga-enwe ihuọma na ezi aha
\q2 nʼanya Chineke na nʼihu mmadụ.
\b
\q1 
\v 5 Tụkwasị \nd Onyenwe anyị\nd* obi gị niile,
\q2 adaberekwala na nghọta gị.
\q1 
\v 6 Nʼihe ọbụla ị na-eme, ka Chineke bute ụzọ,
\q2 ọ ga-eduzi gị, meekwa ka okporoụzọ gị niile gazie.
\b
\q1 
\v 7 A bụla onye maara ihe nʼanya nke onwe gị.
\q2 Tụọ \nd Onyenwe anyị\nd* egwu, kpọọkwa ihe ọjọọ asị.
\q1 
\v 8 Nke a ga-eme ka i nwee ahụ ike
\q2 gbaakwa ọkpụkpụ gị ume.
\b
\q1 
\v 9 Sọpụrụ \nd Onyenwe anyị\nd* site nʼinye ya mkpụrụ mbụ nke akụnụba gị,
\q2 na mkpụrụ mbụ nke ihe ubi gị.
\q1 
\v 10 Mgbe ahụ ka ọ ga-eme ka ọba gị niile jubigakwa oke,
\q2 ebe ịnara mmanya gị ga-ejupụta na mmanya ọhụrụ.
\b
\q1 
\v 11 Nwa m nwoke ajụla ịdọ aka na ntị nke \nd Onyenwe anyị\nd*,
\q2 ike agwụla gị ịnagide ịba mba ya.
\q1 
\v 12 Nʼihi na ọ bụ ndị \nd Onyenwe anyị\nd* hụrụ nʼanya ka ọ na-abara mba,
\q2 dịka nna si abara nwa ya nke ihe ya na-atọ ya ụtọ mba.
\b
\q1 
\v 13 Onye a gọziri agọzi ka mmadụ ahụ bụ onye chọtara amamihe,
\q2 onye nwetara nghọta.
\q1 
\v 14 Nʼihi na amamihe dị mma karịa ọlaọcha,
\q2 ọ bakwara uru karịa ọlaedo.
\q1 
\v 15 Ọ dị oke ọnụahịa karịa ọla rubi,
\q2 ọ dịghị ihe na-amasị gị e ji atụnyere ya.
\q1 
\v 16 Ndụ ogologo dị nʼaka nri ya;
\q2 nʼaka ekpe ya ka akụnụba na nsọpụrụ dịkwa.
\q1 
\v 17 Ụzọ ya bụ ụzọ dị mma
\q2 bụrụkwa ụzọ udo.
\q1 
\v 18 Amamihe bụ osisi nke ndụ\f + \fr 3:18 \ft \xt Jen 2:9; Ilu 11:30; Ilu 15:4; Mkp 2:7\xt*\f* nye ndị na-ejide ya aka,
\q2 e, onye ahụ nke na-ejidesi ya aka ike ka ihe na-agara nke ọma.
\b
\q1 
\v 19 Ọ bụ site nʼamamihe ka \nd Onyenwe anyị\nd* ji tọọ ntọala ụwa;
\q2 ọ bụkwa nghọta ya mere ka eluigwe dịrị ebe ọ dị.
\q1 
\v 20 Esitere nʼihe ọmụma ya kewaa ogbu mmiri niile,
\q2 igwe ojii na-atụdakwa igirigi.
\b
\q1 
\v 21 Nwa m nwoke, ekwela ka ihe abụọ ndị a site nʼihu gị wezuga onwe ha:
\q2 amamihe na nghọta nke ime ihe dị mma nʼizuzu zuruoke,
\q1 
\v 22 nʼihi na ha na-enye gị ndụ ọhụrụ,
\q2 ha bụkwaara gị ihe ịchọ mma amara nʼolu gị.
\q1 
\v 23 Ha na-eme ka ị na-aga ije nʼụzọ gị na-enweghị ihe egwu
\q2 maọbụ ihe mkpọbi ụkwụ.
\q1 
\v 24 Mgbe ị ga-edina ala, ị gaghị atụ egwu,
\q2 ị ga-edina ala ụra gị ga-adị ụtọ.
\q1 
\v 25 Ị gaghị atụ egwu ihe mbibi mberede ọbụla
\q2 maọbụ tụọ egwu ịla nʼiyi nke na-abịakwasị ndị ajọ omume.
\q1 
\v 26 Nʼihi na \nd Onyenwe anyị\nd* bụ ebe ndabere gị,
\q2 ọ ga-echebekwa gị.
\b
\q1 
\v 27 Ejigidele ihe ọma ị pụrụ imere onye ọzọ
\q2 mgbe ọ dị gị nʼaka ime ya.\f + \fr 3:27 \ft \xt Gal 6:10.\xt*\f*
\q1 
\v 28 A sịkwala onye agbataobi gị laa,
\q2 bịaghachi azụ echi
\q2 mgbe i nwere ike ime ya taa.
\q1 
\v 29 Agbala izu ọjọọ megide onye agbataobi gị,
\q2 nʼihi na o nwere ntụkwasị obi nʼebe ị nọ.
\q1 
\v 30 Ebola mmadụ ebubo na-enweghị isi,
\q2 mgbe onye ahụ na-emeghị gị ihe ọjọọ ọbụla.
\b
\q1 
\v 31 Ekwosola onye na-eme ihe ike ekworo
\q2 maọbụ họrọ ụzọ ya ọbụla.
\b
\q1 
\v 32 Nʼihi na ndị dị otu a bụ ihe arụ nʼanya \nd Onyenwe anyị\nd*,
\q2 ma ọ na-emeso ndị na-eme ihe ziri ezi mmeso ọma.
\q1 
\v 33 Ọbụbụ ọnụ \nd Onyenwe anyị\nd* dị nʼụlọ ndị na-eme ajọ omume,
\q2 ma ọ na-agọzi ụlọ ndị ezi omume.
\q1 
\v 34 Ndị mpako na-akwa emo ka ya onwe ya na-akwakwa emo,
\q2 ma ndị dị umeala nʼobi ka ọ na-enye amara.\f + \fr 3:34 \ft \xt Jem 4:6; 1Pt 5:5\xt*\f*
\q1 
\v 35 Ndị maara ihe na-enweta nsọpụrụ,
\q2 ma ndị nzuzu na-enweta ihere.
\c 4
\s1 Amamihe Kachasị ihe niile
\q1 
\v 1 Ụmụ m ndị ikom, geenụ ntị na ndụmọdụ nke nna unu,
\q2 lezienụ anya ka unu nwee nghọta.
\q1 
\v 2 Ṅaanụ ntị, nwee uche, nʼihi na ọ bụ ezi ozizi ka m na-ezi unu;
\q2 ya mere, unu ahapụkwala iwu m.
\q1 
\v 3 Mgbe m bụ nwantakịrị nʼụlọ nna m,
\q2 mgbe m ka dị ntakịrị, bụrụkwa naanị otu nwa nne m ji,
\q1 
\v 4 ọ ziri m ihe, sịkwa m,
\q2 “Ka obi gị jidesie okwu m niile ike,
\q2 debe nʼiwu niile, ị ga-adịkwa ndụ.
\q1 
\v 5 Nweta amamihe, nwetakwa nghọta,
\q2 echezọkwala okwu m, maọbụ site na ya wezuga onwe gị.
\q1 
\v 6 Ahapụla amamihe, ọ ga-echebe gị,
\q2 hụ ya nʼanya, nʼihi na ọ ga-eduzi gị.
\q1 
\v 7 Mmalite amamihe bụ nke a, nweta amamihe,
\q2 ihe ọbụla o ga-efu gị, nweta nghọta.
\q1 
\v 8 Ọ bụrụ na i bulie amamihe elu, o ga-ebulikwa gị elu.
\q2 Jidesie ya ike, ọ ga-ewetara gị oke nsọpụrụ.
\q1 
\v 9 Ọ ga-eji okpueze okoko osisi chọọ isi gị mma
\q2 nyekwa gị okpueze mara mma nʼisi gị.”
\b
\q1 
\v 10 Nwa m, ṅaa m ntị, meekwa ihe m gwara gị;
\q2 ị ga-enwekwa ndụ ogologo.
\q1 
\v 11 M ga-edu gị nʼụzọ nke amamihe,
\q2 duokwa gị nʼụzọ ziri ezi.
\q1 
\v 12 Ọ bụrụ na i bie ụdị ndụ dị otu a, ihe agaghị akpọ gị nʼụkwụ nʼije gị,
\q2 ị gaghị asụkwa ngọngọ mgbe ị na-agba ọsọ.
\q1 
\v 13 Mee ihe niile m gwara gị, echefukwala ha,
\q2 nʼihi na ọ ga-eduba gị na ndụ zuruoke.
\q1 
\v 14 Emela dịka ndị na-emebi iwu.
\q2 Esokwala ụzọ ha.
\q1 
\v 15 Zeere ha, ejekwala nʼụzọ ha;
\q2 chepu ihu gị nʼụzọ ahụ,
\q1 
\v 16 nʼihi na ndị na-emebi iwu adịghị arahụ ụra tutu ha emee arụ nke ụbọchị ahụ.
\q2 Ha anaghị ezu ike tutu ha emee ka otu onye maa nʼọnya.
\q1 
\v 17 Ha na-eri ihe oriri nke mmebi iwu,
\q2 na-aṅụkwa ihe ọṅụṅụ nke ọgbaaghara.
\b
\q1 
\v 18 Ma ụzọ ndị ezi omume dị ka anyanwụ na-awa nʼisi ụtụtụ,
\q2 nke na-enwuwakwa dịka ìhè nʼetiti ehihie ụbọchị.
\q1 
\v 19 Ma ụzọ onye na-emebi iwu dị ka itiri nke ọchịchịrị,
\q2 ha anaghị ama ihe na-eme ka ha sụọ ngọngọ.
\b
\q1 
\v 20 Gee ntị nwa m, nʼihe m na-ekwu.
\q2 Gee ntị nke ọma.
\q1 
\v 21 Doo ihe ndị a nʼuche gị mgbe niile;
\q2 ka ha bamiekwa nʼime obi gị,
\q1 
\v 22 nʼihi na ha bụ ndụ nye ndị chọtara ha,
\q2 bụrụkwa ahụ ike nye mmadụ.
\q1 
\v 23 Nke ka nke, lezie echiche uche gị niile anya,
\q2 nʼihi na ha na-emetụta ndụ gị niile.
\q1 
\v 24 Ka ụgha ọbụla ghara isi gị nʼọnụ pụta;
\q2 kpọọ ịgha ụgha niile na okwu rụrụ arụ niile asị.
\q1 
\v 25 Legide anya nʼihu ime ihe bụ eziokwu;
\q2 atụgharịkwala isi gị ile ihe ọbụla.
\q1 
\v 26 Leruo ije ụkwụ gị anya,
\q2 doziekwa ụzọ gị niile ka ọ guzozie.
\q1 
\v 27 Ewezugala onwe gị site nʼaka nri maọbụ nʼaka ekpe;
\q2 si nʼihe ọjọọ wezuga ụkwụ gị.
\c 5
\s1 Ịdọ aka na ntị banyere ịkwa iko
\q1 
\v 1 Nwa m, ṅaa ntị nʼokwu amamihe m,
\q2 gee ntị nʼokwu nghọta m ndị a.
\q1 
\v 2 Lezie anya, ka i debe izuzu dị iche iche,
\q2 ka egbugbere ọnụ gị na-echebekwa ihe ọmụma.\f + \fr 5:2 \ft \xt Mal 2:7\xt*\f*
\q1 
\v 3 Nʼihi na egbugbere ọnụ nwanyị na-akwa iko na-atọ ka mmanụ aṅụ,
\q2 okwu ọnụ ya na-akwọ mụrụmụrụ karịa mmanụ.
\q1 
\v 4 Ma nʼikpeazụ, ọ na-elu ilu dịka oluilu
\q2 dịkwa nkọ ka mma agha ihu abụọ.
\q1 
\v 5 Ụkwụ ya abụọ na-arịdaru nʼọnwụ,
\q2 nzọ ụkwụ ya abụọ na-eje nʼụzọ ọkụ ala mmụọ.
\q1 
\v 6 Nʼihi na ọ dịghị agbaso ụzọ kwesiri ndụ;
\q2 ụzọ ya gbagọrọ agbagọ, ma ọ maghị nke a.
\b
\q1 
\v 7 Ugbu a ụmụ m, geenụ m ntị,
\q2 unu esikwala nʼokwu niile nke ọnụ m wezuga onwe unu.
\q1 
\v 8 Gbaara nwanyị dị otu a ọsọ!
\q2 Ejekwala ọnụ ụzọ ụlọ ya nso,
\q1 
\v 9 ka ị ghara ire ugwu gị nʼebe ndị ọzọ nọ,
\q2 maọbụ were ndụ gị tinye nʼaka ndị na-enweghị obi ebere.
\q1 
\v 10 Ka ndị ọbịa ghara inwe oke oriri nʼelu akụ gị,
\q2 ka ihe niile ị dọgburu onwe gị nʼọrụ ịkpata gharakwa imejupụta ụlọ onye ọzọ.
\q1 
\v 11 Ka ị gharakwa ịsụ ude nʼikpeazụ
\q2 mgbe ọrịa ga-eripịa ọkpụkpụ gị na anụ ahụ gị.
\q1 
\v 12 Mgbe ị ga-asị, Lee ka m si kpọọ ịdọ aka na ntị asị!
\q2 “Leekwa ka obi m si lelịa iba mba anya!
\q1 
\v 13 Egeghị m ntị nʼozizi nke ndị nkuzi m
\q2 maọbụ nabata ndụmọdụ nke ndị ndụmọdụ m.
\q1 
\v 14 Nʼihi na ugbu a, abịaruola m na mbibi
\q2 nʼihu ọha mmadụ niile.”
\b
\q1 
\v 15 Ṅụọ naanị mmiri nke si nʼite mmiri gị;
\q2 mmiri dị mma nke si nʼolulu mmiri gị.
\q1 
\v 16 Gịnị mere ị ga-eji kwe ka isi mmiri gị sọọ nʼokporoụzọ,
\q2 ka mmiri nke aka gị sọọ nʼama?
\q1 
\v 17 Kwee ka ha bụrụ nke naanị gị,
\q2 nke onye ọbịa na-agaghị enwe oke nʼime ya.
\q1 
\v 18 Kwere ka ịbụ nwoke gị bụrụ ngọzị nye gị;
\q2 ṅụrịakwa ọṅụ nʼihi nwunye nke ị lụtara nʼokorobịa gị.
\q1 
\v 19 Nne anụ nke na-ahụ nʼanya, dịka ele mara mma,
\q2 ka ara dị ya nʼobi zuore gị,
\q2 ka ịhụnanya ya na-enye gị obi ụtọ mgbe ọbụla.
\q1 
\v 20 Gịnị ka ị na-achọ nʼahụ nwanyị na-akwa iko?
\q2 Gịnị mere i ji na-amaku nwunye onye ọzọ obi?
\b
\q1 
\v 21 Nʼihi na \nd Onyenwe anyị\nd* na-ele gị anya,
\q2 ihe niile ị na-eme ka ọ na-ahụ.
\q1 
\v 22 Onye na-emebi iwu na-esite na mmehie ya laa onwe ya nʼiyi;
\q2 mmehie ndị a bụ ụdọ nke na-ejide ya.
\q1 
\v 23 Ọ ga-anwụ nʼihi na ọ nabataghị ịdọ aka na ntị;
\q2 ọ bụkwa nzuzu ya dufuru ya.
\c 6
\s1 Ịdọ aka na ntị banyere nzuzu
\q1 
\v 1 Nwa m, ọ bụrụ na ị nara onye agbataobi gị nʼibe,
\q2 ọ bụrụ na ị nara aka ị bụrụ onye ọbịa onye akaebe,
\q1 
\v 2 ị bụrụla onye mara nʼọnya site nʼihe ị kwuru,
\q2 onye enwudere site nʼokwu ọnụ ya.
\q1 
\v 3 Mee nke a, nwa m, si nʼime ya wepụ onwe gị;
\q2 nʼihi na ịdabala nʼaka onye agbataobi gị:
\q1 Jee ọsịịsọ weda onwe gị nʼala rịọọ ya
\q2 enyekwala ya izuike ọbụla.
\q1 
\v 4 Ekwekwala ka ụra baa gị anya abụọ,
\q2 ekwekwala ka mbụbara anya gị ruo ụra.
\q1 
\v 5 Napụta onwe gị, dịka mgbada site nʼaka dinta,
\q2 maọbụ dịka nnụnụ site nʼọnya osi ọnya.
\b
\q1 
\v 6 Gaa mụta ihe site nʼaka ndanda, gị onye umengwụ.
\q2 Mụta ihe site nʼụzọ ya niile.
\q1 
\v 7 Ọ bụ ezie na o nweghị eze na-achịkọta ha,
\q2 maọbụ onyendu, maọbụ ọchịagha,
\q1 
\v 8 ma ọ na-akpakọta nri ya nʼoge ọkọchị
\q2 ma na-ewebata nri ya nʼoge owuwe ihe ubi.
\b
\q1 
\v 9 Ọ bụ ruo ole mgbe ka ị ga-edina ala nʼebe ahụ, gị onye umengwụ?
\q2 Olee mgbe ka ị ga-esi nʼụra bilie?
\q1 
\v 10 Nwa ụra nta, nwa iru ụra nta,
\q2 nwa ịchịkọba aka nta zuo ike,
\q1 
\v 11 ụbịam ga-abịakwasị gị dịka onye ohi,
\q2 ụkọ abịakwasịkwa gị dịka onye na-apụnara mmadụ ihe.
\b
\q1 
\v 12 Onye okwu na ụka na onye omume ya jọgburu onwe ya,
\q2 onye na-ejegharị na-ekwu okwu aghụghọ,
\q2 
\v 13 onye ji iro na-egbu ikuanya ya,
\q2 jiri ụkwụ ya na-ekwu okwu
\q2 na mkpịsịaka ya na-egosi ihe.
\q2 
\v 14 Onye obi ya na-echepụta ihe ọjọọ na aghụghọ,
\q2 onye na-akpalikwa esemokwu mgbe niile.
\q1 
\v 15 Nʼihi ya, mbibi ga-abịakwasị ya na mberede;
\q2 nʼotu ntabi anya ka a ga-ebibi ya, apụghịkwa ịgwọta ya.
\b
\li1 
\v 16 Ọ dị ụzọ ihe isii \nd Onyenwe anyị\nd* kpọrọ asị,
\li2 e, ha dị asaa bụ ihe arụ nʼebe ọ nọ.
\li3 
\v 17 Anya dị nganga,
\li3 ire na-ekwu okwu ụgha,
\li3 aka na-awụfu ọbara ndị na-emeghị ihe ọjọọ.
\li3 
\v 18 Obi na-echepụta nzube ọjọọ;
\li3 ụkwụ na-eme ngwangwa ịgbaba nʼajọ ihe,
\li3 
\v 19 onyeama ụgha na-awụpụ ụgha dịka mmiri
\li3 na onye na-agbasa esemokwu nʼetiti ụmụnna.
\s1 Ịdọ aka na ntị banyere ịkwa iko
\q1 
\v 20 Nwa m, debe ihe nna gị nyere gị nʼiwu,
\q2 ahapụkwala iwu nke nne gị.\f + \fr 6:20 \ft \xt Efe 6:1\xt*\f*
\q1 
\v 21 Ka ndụmọdụ ha dịrị gị nʼobi mgbe niile,
\q2 ka ị ghara ichefu ha.
\q1 
\v 22 Mgbe ị na-ejegharị, ọ ga na-edu gị;
\q2 mgbe ị na-arahụ ụra, ọ ga na-eche gị.
\q2 Mgbe i tetakwara, ha ga-akpanyere gị ụka.
\q1 
\v 23 Nʼihi na iwu a bụ oriọna,\f + \fr 6:23 \ft \xt Abụ 119:105\xt*\f*
\q2 Ihe ozizi a bụkwa ìhè,\f + \fr 6:23 \ft \xt Abụ 19:8; 2Pt 1:19\xt*\f*
\q1 otu a kwa ịdọ aka na ntị na ịba mba
\q2 bụ ụzọ ezi ndụ,
\q1 
\v 24 idebe gị ka ị pụọ nʼebe nwunye onye agbataobi gị nọ,
\q2 sitekwa nʼire ụtọ nke nwanyị ọjọọ.
\b
\q1 
\v 25 Ekwela ka agụ nʼezighị ezi gụọ gị nʼime obi nʼihi ịma mma ya,
\q2 ma ọ bụkwanụ ka o jiri ile anya ya rata gị.
\b
\q1 
\v 26 Nʼihi na nwanyị akwụna ka enwere ike iji otu ogbe achịcha nweta,
\q2 ma nwunye nwoke ọzọ na-achụ nta ndụ gị ịla ya nʼiyi.
\q1 
\v 27 Mmadụ ọ pụrụ ịgụrụ ọkụ tụkwasị nʼahụ ya,
\q2 ma uwe ya ereghị ọkụ?
\q1 
\v 28 Mmadụ ọ pụrụ ije ije nʼelu icheku ọkụ
\q2 ma ụkwụ ya ahapụ igbuchapụ?
\q1 
\v 29 Otu a ka ọ na-adịrị nwoke na-abakwuru nwunye mmadụ ibe ya;
\q2 o nweghị onye ọbụla na-emetụ ya aka nke a na-agaghị ata ahụhụ.
\b
\q1 
\v 30 Ndị mmadụ adịghị eleda onye ohi anya ma ọ bụrụ na o zuo ohi
\q2 ka o were gboo mkpa agụụ nke na-agụsị ya ike.
\q1 
\v 31 Ma ọ bụrụ na ejide ya ọ ga-akwụghachi ụgwọ ihe niile ahụ o zuru okpukpu asaa.
\q2 Nʼagbanyeghị na nke a ga-eme ka o ree ihe niile o ji biri nʼụlọ ya.
\q1 
\v 32 Ma nwoke ahụ na-akwa iko bụ onye nzuzu, amamihe kọrọ ya,
\q2 nʼihi na ọ bụ onwe ya ka ọ na-ala nʼiyi.
\q1 
\v 33 A ga-eti ya ezi ihe otiti, a ga-elelikwa ya anya,
\q2 ihere ya agaghị ekwe ihichapụ.
\b
\q1 
\v 34 Nʼihi na di nwanyị ahụ ga-esite nʼekworo wee iwe dị ọkụ;
\q2 ọ gakwaghị enwe obi ebere nʼebe ọ nọ nʼụbọchị ọ ga-abọ ọbọ.
\q1 
\v 35 Ọ gaghị anara ihe ọbụla nʼọnọdụ ihe nkwụghachi nʼihi ihe ọjọọ o mere ya.
\q2 O nwekwaghị ihe a ga-enye ya pụrụ ime ka iwe ya dajụọ.
\c 7
\s1 Ịdọ aka na ntị banyere nwanyị na-akwa iko
\q1 
\v 1 Na-agbaso okwu m nwa m, nọgide na ya,
\q2 dokwaa iwu m niile nʼime obi gị.
\q1 
\v 2 Debe iwu m ka ị dị ndụ,\f + \fr 7:2 \ft \xt Lev 18:5; Aịz 55:3\xt*\f*
\q2 chee ozizi m nche dịka ọ bụ mkpụrụ anya gị.
\q1 
\v 3 Kee ha na mkpịsịaka gị,
\q2 deekwa ha nʼelu mbadamba nkume, bụ obi gị.
\q1 
\v 4 Hụ amamihe nʼanya dịka nwaagbọghọ ị hụrụ nʼanya;
\q2 hụkwa inwe nghọta nʼanya dịka a ga-asị na ọ bụ nwanne gị.
\q1 
\v 5 Kwee ka ha debe gị, ka ị ghara ijekwuru nwanyị na-akwa iko,
\q2 ka ị gharakwa ịṅa ntị nʼokwu ire ụtọ ya.
\b
\q1 
\v 6 Nʼihi na otu ụbọchị,
\q2 esi m na oghereikuku dị nʼụlọ m lepụ anya,
\q1 
\v 7 hụ nʼetiti ndị na-enweghị uche,
\q2 ahụtara m otu nwokorobịa nʼetiti ha,
\q2 onye amamihe kọrọ,
\q1 
\v 8 ka ọ na-aga nʼụzọ dị nso ebe nkuku ụlọ
\q2 nʼakụkụ ụlọ nwanyị ihere na-adịghị eme,
\q1 
\v 9 nʼoge anyasị, dịka chi na-eji,
\q2 mgbe ọchịchịrị na-agbachi.
\b
\q1 
\v 10 Mgbe ahụ, nwanyị ahụ pụtara zute ya.
\q2 O yi uwe dịka nwanyị akwụna, jiri aghụghọ na-abịakwute ya.
\q1 
\v 11 (Ọ na-eme ụzụ na-aṅaghị ntị ịnụ ihe ọbụla.
\q2 Ụkwụ ya anaghị anọgide nʼụlọ ya.
\q1 
\v 12 Ọ na-akwụgharị ma nʼokporoụzọ ma nʼama;
\q2 na-amịgharị nʼebe nzuzo niile.)
\q1 
\v 13 O weere aka ya abụọ jikụọ nwokorobịa ahụ nʼolu, sutu ya ọnụ,
\q2 were ihu nke ihere na-adịghị, sị:
\b
\q1 
\v 14 “Emezuru m nkwa niile m kwere taa,
\q2 enwekwara m nri nke sitere nʼihe aja udo m chụrụ nʼụlọ m,
\q1 
\v 15 Ọ bụ gị ka m na-achọkwute,
\q2 lee gị ka ị na-abịa.
\q1 
\v 16 Agbasaala m akwa mara mma nʼelu ihe ndina m,
\q2 bụ akwa ọcha mara mma tụrụ ọtụtụ agwa nke e ji ogho ndị Ijipt kpaa.
\q1 
\v 17 Efesakwala m mmanụ isi ọma nke máá, aloos na sinamọn
\q2 nʼelu nʼihe ndina m.
\q1 
\v 18 Bịa, ka anyị were ịhụnanya ṅụjụbiga afọ anyị;
\q2 ka anyị mee onwe anyị obi ụtọ site ugbu a ruo ụtụtụ echi.
\q1 
\v 19 Nʼihi na di m anọghị nʼụlọ
\q2 o jeela njem dị anya.
\q1 
\v 20 O ji akpa ego juru gaa njem,
\q2 abalị ole na ole ga-agafekwa tupu ọ lọta.”
\b
\q1 
\v 21 Otu a ka o si jiri okwu ire ụtọ ya megharịa nwokorobịa ahụ isi tutu o kwenyere ya.
\q2 O nwekwaghị ike ịnapụta onwe ya site nʼokwu nrafu nke nwanyị ahụ.
\q1 
\v 22 O sooro nwanyị ahụ dịka ehi
\q2 a na-adọkpụ na-aga ebe a ga-egbu ya,
\q1 dịka ele\f + \fr 7:22 \ft Maọbụ, \fqa onye nzuzu\f* nke na-aba nʼọnya,
\q2 
\v 23 nke na-eche ka e were àkụ gbata ya nʼobi.
\q1 Nwoke ahụ dịka nnụnụ nke na-efeba nʼọnya
\q2 na-amaghị ihe na-eche ya pụrụ iwepụ ndu ya.
\b
\q1 
\v 24 Geenụ ntị, ụmụ m, ma ọ bụghị naanị ige ntị,
\q2 kama meekwanụ ihe m na-ekwu.
\q1 
\v 25 Ekwela ka agụụ nke obi gị chịa gị;
\q2 ejela nwanyị dị otu a nso; gbaara ya ọsọ, ka ọ ghara ịnwa gị nwetakwa gị.
\q1 
\v 26 Nʼihi na o mebiela ndụ ọtụtụ mmadụ,
\q2 ọtụtụ mmadụ amaala nʼọnya ya.
\q1 
\v 27 Ụlọ ya bụ okporoụzọ nke na-eduba nʼili,
\q2 nke na-edubakwa nʼala ọnwụ.
\c 8
\s1 Ọkpụkpọ oku amamihe na-akpọ
\q1 
\v 1 Ọ bụ na amamihe adịghị eti mkpu?
\q2 Ọ bụ na nghọta anaghị eme ka olu ya daa ụda?
\q1 
\v 2 Ọ na-eguzo nʼelu ebe niile dị elu nʼokporoụzọ,
\q2 nʼagbata ụzọ niile.
\q1 
\v 3 Nʼọnụ ụzọ nke obodo niile
\q2 na nʼọnụ ụzọ ụlọ niile ka ọ nọ na-eti mkpu,
\q1 
\v 4 ọ na-asị, “Ụmụ mmadụ geenụ m ntị;
\q2 ọ bụ unu ndị dị ndụ ka m na-agwa okwu.
\q1 
\v 5 Unu ndị na-enweghị uche, nweenụ uche zuruoke;
\q2 unu ndị nzuzu, nweenụ nghọta.
\q1 
\v 6 Geenụ m ntị, nʼihi na enwere m okwu dị mkpa m ga-agwa unu;
\q2 Ihe ọbụla m kwuru bụ ihe ziri ezi,
\q1 
\v 7 Ọnụ m na-ekwu eziokwu
\q2 nʼihi na akpọrọ m okwu ụgha asị.
\q1 
\v 8 Ndụmọdụ m zuruoke, ọ dịkwa mma.
\q2 Ihe ọjọọ ọbụla adịghị nʼime ya.
\q1 
\v 9 Nʼebe onye nwetara nghọta nọ, okwu m doro anya;
\q2 nʼebe ndị chọtara ihe ọmụma nọ, okwu m ziri ezi.
\q1 
\v 10 Họrọ ịdọ aka na ntị m karịa ọlaọcha
\q2 họrọkwa ihe ọmụma karịa ọlaedo dị ezi mma.”
\q1 
\v 11 Amamihe dị mkpa karịa nkume rubi dị oke ọnụahịa.
\q2 Ọ dịkwaghị ihe a ga-eji tụnyere ya.
\b
\q1 
\v 12 “Mụ onwe m bụ amamihe na ezi nghọta na-agakọta.
\q2 Enwere m ọmụma ihe na ezi izuzu.
\q1 
\v 13 Ịtụ egwu \nd Onyenwe anyị\nd* bụ ịkpọ ihe ọjọọ asị.
\q2 Akpọrọ m nganga na mpako,
\q2 omume ọjọọ nakwa okwu gbagọrọ agbagọ asị.
\q1 
\v 14 Ndụmọdụ na ezi nghọta bụ nke m;
\q2 enwekwara m ọmụma ihe na ike.
\q1 
\v 15 Site na m ka ndị eze ji achị,
\q2 ọ bụ m na-eme ka ndị na-achị achị mee iwu ziri ezi.
\q1 
\v 16 Site na m ka ndị eze ji achị
\q2 bụ ndịisi niile na-achị nʼụwa.
\q1 
\v 17 Ndị niile hụrụ m nʼanya ka m na-ahụ nʼanya.
\q2 Ndị niile na-achọ m aghakwaghị ịchọta m.
\q1 
\v 18 Ana m ekenye ụba na nsọpụrụ,
\q2 na ikpe ziri ezi na ezi omume.
\q1 
\v 19 Onyinye m na-enye dị mma karịa ọlaọcha,
\q2 ọ karịkwara ọlaedo.
\q1 
\v 20 Ana m aga ije nʼụzọ ezi omume,
\q2 nʼokporoụzọ ikpe ziri ezi.
\q1 
\v 21 Ndị niile hụrụ m nʼanya, na-eketa akụnụba.
\q2 Ana m emejupụtakwa ụlọakụ ha.
\b
\q1 
\v 22 “\nd Onyenwe anyị\nd* kpụrụ m dịka mmalite ụzọ ya,
\q2 tupu o bido ike ihe ọbụla ọzọ.
\q1 
\v 23 Site nʼebighị ebi gara aga ka m dị;
\q2 adịkwa m adị tupu e kee ụwa.
\q1 
\v 24 Anọ m na-adị tupu e kee ogbu mmiri,
\q2 tupu isi iyi ọbụla agbapụta mmiri nʼelu ụwa,
\q1 
\v 25 tupu e kee ugwu ukwu
\q2 na ugwu nta.
\q1 
\v 26 E, amụọla m rịị tupu Chineke ekee ụwa
\q2 na osisi niile, na aja niile dị nʼime ya.
\q1 
\v 27 Anọ m ya mgbe o doziri mbara eluigwe nʼọnọdụ ya,
\q2 mgbe ọ tụsara ha nʼelu ogbu mmiri niile;
\q1 
\v 28 mgbe o hiwere mbara eluigwe,
\q2 mgbe o mere ka isi iyi niile nke ogbu mmiri dị ike,
\q1 
\v 29 mgbe ọ kpara oke nye osimiri ebe ọ ga-akwụsị,
\q2 ka mmiri ya ghara ịgafe iwu ya,
\q1 mgbe ọ kara akara ebe a tọrọ ntọala nke ụwa.
\q2 
\v 30 Oge ahụ niile ka m na-anọ nʼakụkụ ya dịka onye ǹka.
\q1 Ihe banyere m na-atọkwa ya ụtọ;
\q2 ana m egwuri egwu nʼihu ya.
\q1 
\v 31 Ihe niile o kere tọkwara m ụtọ,
\q2 ụwa niile na ụmụ mmadụ!
\b
\q1 
\v 32 “Nʼihi ya, ụmụ m ndị ikom, geenụ m ntị;
\q2 nʼihi na ndị niile na-eso ụzọ m na-enwe ọṅụ.
\q1 
\v 33 Gee ntị na ndụmọdụ m ka ị bụrụ onye maara ihe,
\q2 agbakụtakwala ndụmọdụ m azụ.
\q1 
\v 34 Ngọzị dịrị mmadụ ahụ na-aṅa ntị nʼokwu m,
\q2 onye na-anọ na nche nʼọnụ ụzọ m ụbọchị niile,
\q2 onye na-anọ na-echere m nʼọnụ ụzọ ụlọ m;
\q1 
\v 35 nʼihi na onye ọbụla chọtara m chọtara ndụ;
\q2 ọ natakwala ihuọma nʼebe \nd Onyenwe anyị\nd* nọ.
\q1 
\v 36 Ma onye na-enweghị ike chọta m na-emerụ onwe ya ahụ;
\q2 ndị niile kpọrọ m asị hụrụ ọnwụ nʼanya.”
\c 9
\s1 Ọkpụkpọ oku nke amamihe na nzuzu
\q1 
\v 1 Amamihe ewuola ụlọ ukwu ya
\q2 nʼelu ogidi asaa.
\q1 
\v 2 O doziela oriri ya nʼusoro,
\q2 o gbuola anụ ya, gwaakwa mmanya.\f + \fr 9:2 \ft A na-eji ụda máá gwakọọ na mmanya i ji mee ka ọtọ ezi ụtọ nʼọnụ.\f*
\q1 
\v 3 O zipụkwala ndị ozi ya ka ha gaa kpọọ mmadụ niile,
\q2 site nʼebe dị elu nke obodo ka ha nọ na-akpọ oku na-asị,
\q2 
\v 4 “Bịanụ nʼụlọ m, unu ndị niile na-enweghị uche”
\q1 Ma nye ndị amamihe kọrọ, ọ na-asị,
\q2 
\v 5 “Bịanụ, rie nri m,
\q2 ṅụọkwa mmanya m gwakọtara.
\q1 
\v 6 Hapụnụ ụzọ enweghị uche unu, ka unu were dị ndụ;
\q2 gbasokwanụ ụzọ mmụọ ịghọta ihe.”
\b
\q1 
\v 7 Onye ọbụla na-adọ onye na-akwa emo aka na ntị na-ewetara onwe ya nlelị;
\q2 onye na-abara mmadụ ọjọọ mba na-enweta nkọcha.
\q1 
\v 8 Abarala ndị na-akwa emo mba, ma ọ bụghị ya, ha ga-akpọ gị asị;
\q2 baara ndị maara ihe mba, ha ga-ahụ gị nʼanya.
\q1 
\v 9 Kuziere onye maara ihe ihe o kwesiri ịmụta, ọ ga-ama ihe karịa,
\q2 kuziere onye ziri ezi ihe ọ ga-atụkwasị ihe ọ mụtara nʼamamihe ya.
\b
\q1 
\v 10 Nʼihi na ịtụ egwu \nd Onyenwe anyị\nd* bụ mmalite amamihe,
\q2 inwe ihe ọmụma banyere onye Nsọ ahụ bụkwa nghọta.
\q1 
\v 11 Nʼihi na ọ bụ site na amamihe, ka ụbọchị gị ga-adị ogologo.
\q2 A ga-etinyekwara gị ọtụtụ afọ na ndụ gị.
\q1 
\v 12 Ị bụrụ onye nwere amamihe, amamihe gị ga-abara gị uru,
\q2 ma ị bụrụ onye na-akwa emo, naanị gị ga-ata ahụhụ ya.
\b
\q1 
\v 13 Nwanyị dị nzuzu na-eme mkpọtụ,
\q2 o nweghị uche; ihere adịghịkwa eme ya.
\q1 
\v 14 Ọ na-anọ ọdụ nʼọnụ ụzọ ụlọ ya,
\q2 nʼelu oche nʼebe dịkarịsịrị elu nʼobodo,
\q1 
\v 15 na-akpọ ndị na-aga nʼụzọ oku,
\q2 bụ ndị na-aga mkpa ha,
\q2 
\v 16 “Ka ndị niile amamihe kọrọ bịa nʼụlọ m.”
\q1 Ọ na-asịkwa ndị na-enweghị uche,
\q2 
\v 17 “Mmiri e zutere nʼohi na-atọ ụtọ,
\q2 nri e riri na nzuzo na-atọkarịkwa nʼụtọ.”
\q1 
\v 18 Ma ha adịghị aghọta na ndị nʼadịghị ndụ nọ nʼebe ahụ,
\q2 na ndị ọ kpọrọ oku nri aghọọlarị ndị nọ nʼala mmụọ.
\c 10
\ms1 Ndị a bụ ilu Solomọn
\p 
\v 1 Ilu dị iche iche nke Solomọn:
\q1 Nwata maara ihe na-eme ka nna ya ṅụrịa ọṅụ;
\q2 ma nwantakịrị dị nzuzu na-ewetara nne ya nʼiru ụjụ.
\b
\q1 
\v 2 Akụ a kpatara nʼụzọ na-ezighị ezi adịghị aba uru,
\q2 ma ezi omume na-azọpụta mmadụ site nʼọnwụ.
\b
\q1 
\v 3 \nd Onyenwe anyị\nd* agaghị ekwe ka onye ezi omume nwụọ nʼagụụ,
\q2 ọ gakwaghị ekwe ka ihe nọgide na-agara onye ajọ omume nke ọma.
\b
\q1 
\v 4 Aka ndị umengwụ na-eweta ogbenye,
\q2 ma aka na-arụsị ọrụ ike na-eweta ụba.
\b
\q1 
\v 5 Onye na-ekpokọta nʼoge ọkọchị bụ nwa maara ihe,
\q2 ma nwa ahụ nke na-arahụ ụra nʼoge ọrụ bụ nwa na-eweta ihere.
\b
\q1 
\v 6 Onye ezi omume na-anata ngọzị,
\q2 ma naanị nkọcha jupụtara nʼọnụ onye ajọ omume.
\b
\q1 
\v 7 Aha onye ezi omume ka eji enye ngọzị,
\q2 ma aha onye ajọ omume ga-ere ure.
\b
\q1 
\v 8 Onye obi ya maara ihe na-anabata ihe e nyere nʼiwu,
\q2 ma onye nzuzu ekwurekwu ga-ala nʼiyi.
\b
\q1 
\v 9 Onye ụzọ ya ziri ezi na-aga ije nʼatụghị egwu,
\q2 ma onye ụzọ ya ezighị ezi ka a ga-achọpụta.
\b
\q1 
\v 10 Onye ọbụla na-egbu ikuanya na-ebute ihe mwute,
\q2 onye nzuzu ekwurekwu ga-abịa nʼịla nʼiyi.
\b
\q1 
\v 11 Ọnụ onye ezi omume bụ isi iyi nke ndụ,
\q2 ma naanị nkọcha jupụtara nʼọnụ onye ajọ omume.
\b
\q1 
\v 12 Ịkpọ asị na-akpali esemokwu,
\q2 ma ịhụnanya na-ekpuchi mmehie niile.
\b
\q1 
\v 13 Ndị nwere nghọta na-ekwu okwu nwere isi,
\q2 ma ndị na-enweghị uche ka a na-eti ihe dịka ohu.
\b
\q1 
\v 14 Onye amamihe na-akpakọba ihe ọmụma,
\q2 ma onye nzuzu na-eji ọnụ ya akpọ ịla nʼiyi oku.
\b
\q1 
\v 15 Akụ ndị ọgaranya bụrụ ha obodo e wusiri ike,
\q2 ma ụbịam bụ ịla nʼiyi nke ndị ogbenye.
\b
\q1 
\v 16 Ụgwọ ọrụ onye ezi omume bụ ndụ,
\q2 ma ihe nweta nke onye ajọ omume bụ mmehie na ọnwụ.
\b
\q1 
\v 17 Onye na-ege ntị na ndụmọdụ na-egosi ụzọ nke ndụ,
\q2 ma onye na-adịghị anabata ndụmọdụ na-eme ka ndị ọzọ kpafuo.
\b
\q1 
\v 18 Onye ji egbugbere ọnụ ụgha ekpuchi ịkpọ asị
\q2 na onye na-agbasa okwu nkwutọ bụ onye nzuzu.
\b
\q1 
\v 19 Nʼọtụtụ okwu mmehie adịghị akwụsị
\q2 ma ndị nwere uche na-ejide ire ha.
\b
\q1 
\v 20 Ire nke onye ezi omume bụ ọlaọcha kachasị mma,
\q2 ma obi onye ajọ omume bụ ihe ọnụahịa nta.
\b
\q1 
\v 21 Egbugbere ọnụ onye ezi omume na-azụju ọtụtụ mmadụ afọ,
\q2 ma ndị nzuzu na-anwụ nʼihi amamihe nke kọrọ ha.
\b
\q1 
\v 22 Ngọzị \nd Onyenwe anyị\nd* na-eme mmadụ ọgaranya,
\q2 ọ naghị atụkwasị ya nsogbu.
\b
\q1 
\v 23 Ihe na-atọ onye nzuzu ụtọ bụ izube nzube ọjọọ;
\q2 ma ihe na-atọ onye maara ihe ụtọ bụ inwe nghọta.
\b
\q1 
\v 24 Ihe ahụ onye na-emebi iwu nʼatụ ụjọ ya ga-abịakwasị ya,
\q2 ihe onye ezi omume na-achọ ka a ga-enye ya.
\b
\q1 
\v 25 Mgbe oke ifufe na-emebi ihe, ndị na-emebi iwu ka ọ na-eburu;
\q2 ma ndị ezi omume na-eguzosi ike ruo ebighị ebi.
\b
\q1 
\v 26 Onye umengwụ na-abụ ihe mgbu nye onyenwe ya;
\q2 ọ dịka anwụrụ ọkụ nʼanya mmadụ maọbụ dịka mmanya gbara ụka nke na-ejiji eze.
\b
\q1 
\v 27 Ịtụ egwu \nd Onyenwe anyị\nd* na-enye ogologo ndụ,
\q2 ma ọnụọgụgụ afọ nke onye ajọ omume na-adị mkpụmkpụ.
\b
\q1 
\v 28 Olileanya ndị ezi omume ga-abụ ọṅụ;
\q2 olileanya ndị na-emebi iwu bụ naanị ihe efu.
\b
\q1 
\v 29 Ụzọ \nd Onyenwe anyị\nd* bụ ebe mgbaba nye ndị na-enweghị ịta ụta,
\q2 maọbụ ịla nʼiyi nye ndị na-eme ajọ ihe.
\b
\q1 
\v 30 A pụghị iwezuga\f + \fr 10:30 \ft Maọbụ, \fqa ihopu\f* onye ezi omume,
\q2 ma onye na-emebi iwu agaghị anọgide.
\b
\q1 
\v 31 Nʼọnụ onye ezi omume ka mkpụrụ amamihe si abịa,
\q2 ma ire na-ekwu okwu nduhie ka a ga-eme ka o dere duu.
\b
\q1 
\v 32 Egbugbere ọnụ onye ezi omume mara ihe na-eweta ihuọma,
\q2 ma ọnụ ndị ajọ omume bụ naanị okwu nduhie.
\b
\c 11
\q1 
\v 1 Ihe ọtụtụ aghụghọ\f + \fr 11:1 \ft \xt Lev 19:35-36; Dit 25:13-16; Mai 6:11\xt*\f* bụ arụ nʼihu \nd Onyenwe anyị\nd*
\q2 ma ihe ọtụtụ zuru ezu na-anata ihuọma nʼebe ọ nọ.
\b
\q1 
\v 2 Nganga bịa, nlelị a na-eso ya,
\q2 ma onye dị umeala nʼobi na-amụta ihe.
\b
\q1 
\v 3 Eziokwu nke ndị ziri ezi nʼobi na-edu ha;
\q2 ma omume gbagọrọ agbagọ nke ndị aghụghọ nʼala ha nʼiyi.
\b
\q1 
\v 4 Akụnụba gị agaghị azọpụta gị nʼụbọchị ikpe;
\q2 ọ bụ naanị ezi omume na-anapụta site nʼọnwụ.
\b
\q1 
\v 5 Ezi omume nke ndị na-enweghị ịta ụta na-eme ka ụzọ ha zie ezi,
\q2 ma ajọ omume nke ndị na-emebi iwu na-akwada ha.
\b
\q1 
\v 6 Ezi omume nke onye ziri ezi na-azọpụta ya;
\q2 ma ọchịchọ ọjọọ nke ndị na-aghọ aghụghọ ka a ga-eji jide ha.
\b
\q1 
\v 7 Mgbe onye ajọ omume nwụrụ, olileanya ya niile alala nʼiyi,
\q2 ihe niile ọ na-ele anya inweta site nʼike ya alaakwala nʼiyi.
\b
\q1 
\v 8 Chineke na-azọpụta ndị ezi omume site na nsogbu ha,
\q2 ma ndị ajọ omume ka ọ na-ahapụ ka ha daba nʼime ya.
\b
\q1 
\v 9 Okwu ọjọọ ka onye ajọ omume ji emebi onye agbataobi ya.
\q2 Ma site nʼihe ọmụma ka onye ezi omume ga-eji dọpụta ndụ ya.
\b
\q1 
\v 10 Ọganihu nke onye ezi omume na-atọ mmadụ niile ụtọ,
\q2 otu aka ahụ kwa, ọnwụ onye ajọ omume na-atọ mmadụ niile ụtọ.
\b
\q1 
\v 11 A na-esite na ngọzị nke ndị ziri ezi bulie obodo elu,
\q2 ma a nʼala ya nʼiyi site nʼokwu ọnụ ndị ajọ omume.
\b
\q1 
\v 12 Ikwu okwu nleda megide onye agbataobi gị bụ nzuzu;
\q2 ma onye ahụ nwere nghọta na-agba nkịtị.
\b
\q1 
\v 13 Onye na-agba asịrị na-ekpughe ihe nzuzo,
\q2 ma onye kwesiri ntụkwasị obi na-ekpuchi ihe nzuzo.
\b
\q1 
\v 14 Nʼihi enweghị ezi ndị ndu ka obodo ji ada,
\q2 ma ọtụtụ ndị ezi ndụmọdụ na-eweta mmeri.
\b
\q1 
\v 15 Onye ọbụla na-ana onye ọbịa nʼakaebe ga-ata ahụhụ,
\q2 ma onye jụrụ ịkwụ ụgwọ onye ọzọ ji, nọ na ntụkwasị obi.\f + \fr 11:15 \ft Maọbụ, \fqa ga-enwe udo\f*
\b
\q1 
\v 16 Nsọpụrụ na-adịrị nwanyị nwere obiọma,
\q2 ma ndị na-adịghị eme ebere bụ naanị akụnụba ka ha na-enweta.
\b
\q1 
\v 17 Onye nwere obiọma baara onwe ya uru,
\q2 ma onye nwere obi ọjọọ na-ewetara onwe ya nsogbu.
\b
\q1 
\v 18 Onye ajọ omume na-anata ụgwọ ọrụ aghụghọ,
\q2 ma onye na-agha ezi omume dịka mkpụrụ na-anata ụgwọ ọrụ kwesiri ekwesi.
\b
\q1 
\v 19 Onye na-eguzosi ike ime ihe ziri ezi ga-enwe ndụ;
\q2 ma onye na-agbaso ihe ọjọọ ga-ahụ ọnwụ.
\b
\q1 
\v 20 \nd Onyenwe anyị\nd* na-akpọ ndị obi ha gbagọrọ agbagọ asị
\q2 ma ndị ụzọ ha na-enweghị ihe ịta ụta na-amasị ya.
\b
\q1 
\v 21 Ọ bụ ihe doro anya na ndị na-emebi iwu ga-ata ahụhụ,
\q2 ma ndị ezi omume ka a ga-anapụta.
\b
\q1 
\v 22 Nwanyị mara mma, nke na-enweghị uche,
\q2 dịka ọlaedo a gbanyere ezi nʼimi.
\b
\q1 
\v 23 Olileanya onye ezi omume bụ ọṅụ,
\q2 ma onye na-emebi iwu na-ele naanị anya ihe ọjọọ.
\b
\q1 
\v 24 Otu onye na-agbasapụ aka ya na-enye enye ma na-enweta akụ karịa,
\q2 ma onye ọzọ na-egbochi egbochi ma na-ada ogbenye.
\b
\q1 
\v 25 E, onye na-agbasa aka ya ga-aba ọgaranya;
\q2 onye ọbụla na-atụte ndị ọzọ ka a ga-atụtekwa.
\b
\q1 
\v 26 Ndị mmadụ na-abụ onye na-achịkọba mkpụrụ ọka na-ereghị ya ere ọnụ,
\q2 ma ha na-ekpetara onye nke dị njikere ire nke ya ngọzị Chineke.
\b
\q1 
\v 27 Onye na-achọ ihe ọma na-enweta ihuọma,
\q2 ma ihe ọjọọ na-abịakwasị onye na-achọ ya.
\b
\q1 
\v 28 Ndị tụkwasịrị obi nʼakụnụba ha ga-ada,
\q2 ma onye ezi omume ga-epupụta dịka akwụkwọ ndụ.
\b
\q1 
\v 29 Onye na-ewetara ezinaụlọ ha nsogbu ga-eketa naanị ifufe,
\q2 onye nzuzu ga-abụ ohu nke onye maara ihe.
\b
\q1 
\v 30 Mkpụrụ nke ndị ezi omume bụ osisi na-enye ndụ,
\q2 onye na-erita mkpụrụobi nʼuru bụ onye maara ihe.
\b
\q1 
\v 31 Ọ bụrụ na a ga-akwụ ndị ezi omume ụgwọ ọrụ ha nʼụwa a;
\q2 a ga-esi aṅaa ghara ịkwụ ndị na-amaghị Chineke na ndị mmehie ụgwọ ọrụ.
\b
\c 12
\q1 
\v 1 Onye ọbụla na-ahụ ịdọ aka na ntị nʼanya na-ahụ ihe ọmụma nʼanya,
\q2 ma onye na-akpọ ịba mba asị bụ onye na-enweghị ụbụrụ isi.
\b
\q1 
\v 2 Ezi mmadụ na-anata ihuọma site nʼaka \nd Onyenwe anyị\nd*,
\q2 ma onye na-atụpụta atụmatụ ọjọọ ka ọ na-ama ikpe.
\b
\q1 
\v 3 Onye ajọ omume agaghị anọgide,
\q2 ma apụghị ihopu onye ezi omume.
\b
\q1 
\v 4 Ezi nwanyị bụ ọṅụ na okpueze di ya,
\q2 ma nwanyị na-eweta ihere dịka ire ure nʼọkpụkpụ di ya.
\b
\q1 
\v 5 Echiche obi niile nke onye ezi omume bụ ihe ziri ezi,
\q2 ma ndụmọdụ onye ajọ omume jupụtara nʼaghụghọ.
\b
\q1 
\v 6 Okwu niile nke ndị ajọ omume bụ ihe na-eweta ọnwụ,
\q2 ma okwu ndị omume ha ziri ezi na-anapụta ha.
\b
\q1 
\v 7 Ndị na-emebi iwu ga-ala nʼiyi,
\q2 ma ndị ezi omume ga-eguzosi ike.
\b
\q1 
\v 8 Onye nwere uche zuruoke ka mmadụ niile na-achọ,
\q2 ma onye uche ya gbagọrọ agbagọ ka mmadụ na-eleda anya.
\b
\q1 
\v 9 Ọ ka mma ịbụ onye a na-elelị anya ma i nwere ohu,
\q2 karịa ịbụ onye a na-asọpụrụ ma bụrụ onye nri na-adịghị nʼụlọ ya.
\b
\q1 
\v 10 Onye ezi omume na-elekọta anụ ụlọ ya,
\q2 ma obi ebere kachasị nro nke onye ajọ omume mere bụ enweghị obi ebere.
\b
\q1 
\v 11 Onye na-arụ ala ubi ya ga-enwe nri nʼebe ọ bara ụba,
\q2 ma onye na-agbaso ihe efu dị iche iche, amamihe kọrọ.
\b
\q1 
\v 12 Ndị ajọ omume na-enwekwa anya ukwu nʼihe ndị ajọ omume ibe ha nwere,
\q2 ma mgbọrọgwụ nke ndị ezi omume ga-eto eto.
\b
\q1 
\v 13 A na-ejide onye ajọ omume site nʼokwu ọnụ ya,
\q2 ma onye ezi omume na-esi na nsogbu wezuga onwe ya.
\b
\q1 
\v 14 Ikwu eziokwu na-enye mmadụ obi ụtọ,
\q2 inwe mgbalị na-ewetara ya ngọzị.
\b
\q1 
\v 15 Ụzọ ndị nzuzu nʼuche ha onwe ha ziri ezi,
\q2 ma onye maara ihe na-aṅa ntị nye ndụmọdụ.
\b
\q1 
\v 16 Ndị nzuzu na-egosipụta iwe ha ọsịịsọ,
\q2 ma onye nwere uche na-elepụrụ mkparị anya.
\b
\q1 
\v 17 Ezi onye akaebe na-ekwu eziokwu,
\q2 ma ajọ onye akaebe na-ekwu okwu ụgha.
\b
\q1 
\v 18 Okwu ọjọọ na-agbawa obi dịka mma agha,
\q2 ma ire onye maara ihe na-eweta ọgwụgwọ.
\b
\q1 
\v 19 Eziokwu na-eguzo ruo mgbe ebighị ebi,
\q2 ma okwu ụgha anaghị adịgide.
\b
\q1 
\v 20 Aghụghọ na-ejupụta nʼobi na-eche ihe ọjọọ;
\q2 ma ndị na-eme ka udo dị na-enwe ọṅụ.
\b
\q1 
\v 21 Ihe ọjọọ anaghị adakwasị onye ezi omume,
\q2 ma ndị ajọ omume enwetala nsogbu ebe ọ dị ukwuu.
\b
\q1 
\v 22 \nd Onyenwe anyị\nd* kpọrọ egbugbere ọnụ nʼagha ụgha asị,
\q2 ma ihe ndị kwesiri ntụkwasị obi na-amasị ya.
\b
\q1 
\v 23 Onye nwere uche na-edebe ihe ọmụma ha nye onwe ha,
\q2 ma onye nzuzu na-agbasa enweghị uche ya nʼanwụ.\f + \fr 12:23 \ft \xt Ilu 13:16\xt*\f*
\b
\q1 
\v 24 Aka na-arụsị ọrụ ike ga-achị achị,
\q2 ma umengwụ ga-akwụsị naanị nʼọrụ mmanye.
\b
\q1 
\v 25 Obi nke jupụtara na nchegbu na-ada mba,
\q2 ma okwu ọma na-eme ka obi ṅụrịa.
\b
\q1 
\v 26 Onye ezi omume na-eduzi onye agbataobi ya,
\q2 ma onye na-emebi iwu na-eduhie ha.
\b
\q1 
\v 27 Onye umengwụ adịghị ahụ anụ ọ chụtara na nta nʼọkụ,
\q2 ma ndị na-arụsị ọrụ ike na-eri site nʼakụ ha nwetara nʼịchụ nta.
\b
\q1 
\v 28 Ụzọ nke onye ezi omume na-eduba na ndụ,
\q2 nʼụzọ ahụ, ọnwụ adịghị ya.
\b
\c 13
\q1 
\v 1 Nwa maara ihe na-ege ntị na ndụmọdụ nna ya
\q2 ma onye na-akwa emo adịghị ege ntị nʼịba mba.
\b
\q1 
\v 2 Onye na-eme ezi ihe ga-esite nʼokwu ọnụ ya nweta ụgwọ ọrụ,
\q2 ma ndị na-aghọgbu ibe ha ga-anata ihe ike dịka ụgwọ ọrụ ha.
\b
\q1 
\v 3 Mmadụ zuruoke bụ onye na-ejide ire ya aka!\f + \fr 13:3 \ft \xt Abụ 141:3; Ilu 21:23\xt*\f*
\q2 Ma onye ekwuruekwu na-ewetara onwe ya mbibi.
\b
\q1 
\v 4 Ndị umengwụ na-achọ ọtụtụ ihe ma ọ dịghị ihe ha na-enweta;
\q2 ma onye na-arụsị ọrụ ike na-enweta ihe niile ọ chọrọ.
\b
\q1 
\v 5 Onye ezi omume kpọrọ ụgha asị,
\q2 ma okwu ọnụ onye na-emebi iwu
\q2 na-ewetara ya ihere na nkọcha.
\b
\q1 
\v 6 Ezi omume mmadụ na-abara ya uru na ndụ ya niile,
\q2 ma ajọ omume ndị mmehie na-ala ha nʼiyi.
\b
\q1 
\v 7 Ọ dị mmadụ na-eme ka ọ bụ ọgaranya maọbụ onye ụkpa.
\q2 Ma ọ dịkwa mmadụ na-eme ka ọ bụ onye ụkpa maọbụ ọgaranya.
\b
\q1 
\v 8 Ọgaranya nwere ike jiri ego ya gbapụta onwe ya,
\q2 ma ogbenye adịghị azaghachi mba banyere imerụ ya ahụ.
\b
\q1 
\v 9 Ìhè onye ezi omume na-enwupụ enwupụ,
\q2 ma oriọna onye mmebi iwu ga-anyụ.
\b
\q1 
\v 10 Nganga na-eweta esemokwu,
\q2 ma a na-ahụ amamihe nʼime ndụ ndị na-anata ndụmọdụ.
\b
\q1 
\v 11 Akụ a kpatara ngwangwa na-emebikwa ngwangwa;
\q2 ma akụ sitere nʼịrụsị ọrụ ike na-eto eto.
\b
\q1 
\v 12 Nchere a na-echere ogologo oge maka imezu olileanya e nwere na-egbu obi,
\q2 mgbe ihe a na-eche mezuru, oke ọṅụ na-adị.
\b
\q1 
\v 13 Onye na-elelị ntụziaka anya ga-akwụ ụgwọ nʼihi ya,
\q2 ma onye na-atụ egwu ihe enyere nʼiwu ga-anata ụgwọ ọrụ ya.
\b
\q1 
\v 14 Nkuzi nke onye maara ihe bụ isi iyi nke ndụ,
\q2 nke na-eme ka mmadụ ghara ịma nʼọnya ọnwụ.
\b
\q1 
\v 15 Ezi nghọta na-eweta ihuọma,
\q2 ma ụzọ nke ndị na-ekwesighị ntụkwasị obi na-eduba ha na mbibi.
\b
\q1 
\v 16 Onye nwere uche na-eji ọmụma ihe nʼarụ ọrụ,
\q2 ma ndị nzuzu na-egosipụta enweghị uche ya.
\b
\q1 
\v 17 Onyeozi ajọ omume na-adaba na nsogbu,
\q2 ma onyeozi kwesiri ntụkwasị obi na-eweta ọgwụgwọ.
\b
\q1 
\v 18 Onye na-ajụ ịdọ aka na ntị ga-anwụ nʼụkpa na nʼihere;
\q2 ma onye na-anabata ịdọ aka na ntị ka a ga-asọpụrụ.
\b
\q1 
\v 19 Mgbe ihe a na-ele anya mezuru ọ na-atọ mkpụrụobi ụtọ,
\q2 ma ndị nzuzu kpọrọ isite nʼajọ ihe wezuga onwe ha asị.
\b
\q1 
\v 20 Na-eso ndị maara ihe ka ị ghọọ onye mara ihe,
\q2 nʼihi na onye na-eso ndị nzuzu na-aba na nsogbu.
\b
\q1 
\v 21 Nsogbu bụ ihe na-esogharị ndị mmehie,
\q2 ma ngọzị na-esogharị ndị ezi omume.
\b
\q1 
\v 22 Mgbe ezi mmadụ nwụrụ, ọ na-ahapụrụ ụmụ ya na ụmụ ụmụ ya akụ,
\q2 ma mgbe onye mmehie nwụrụ, akụ ya na-abụ nke ndị ezi omume.
\b
\q1 
\v 23 Ubi onye ogbenye pụrụ inwe ọtụtụ ihe oriri,
\q2 ma ikpe na-ezighị ezi na-azachapụ ya.
\b
\q1 
\v 24 Onye ọbụla na-adọghị ụmụ ya aka na ntị, na-egosi na ọ hụghị ha nʼanya;
\q2 ma onye hụrụ ha nʼanya, ga-adọsi ha aka na ntị ike.
\b
\q1 
\v 25 Onye ezi omume na-eri nri ruo na nriju afọ onwe ya,
\q2 ma nri na-akọ nʼafọ onye ajọ omume.
\b
\c 14
\q1 
\v 1 Nwanyị maara ihe na-ewu ụlọ ya,
\q2 ma nwanyị nzuzu na-eji aka ya akwada ụlọ ya.
\b
\q1 
\v 2 Ime ihe ziri ezi bụ ịtụ egwu \nd Onyenwe anyị\nd*;
\q2 ma ndị na-ejehie nʼụzọ ha na-akpọ ya asị.
\b
\q1 
\v 3 Ọnụ onye nzuzu na-ekwupụta okwu mpako,
\q2 ma egbugbere ọnụ onye maara ihe na-echebe ha.
\b
\q1 
\v 4 Mgbe ehi na-adịghị, ụlọ ebe a na-azụ anụ na-adị ọcha,
\q2 ma site nʼike ehi ihe omume nke ubi na-ejupụta nʼụlọ.
\b
\q1 
\v 5 Onye akaebe eziokwu adịghị aghọgbu mmadụ,
\q2 ma onye akaebe ụgha na-agha ụgha mgbe ọbụla.
\b
\q1 
\v 6 Onye na-akwa emo na-achọ amamihe ma ọ dịghị achọta ya;
\q2 ma ihe ọmụma na-abịara onye nwere nghọta ọsịịsọ.
\b
\q1 
\v 7 Si nʼebe onye nzuzu wezuga onwe gị,
\q2 nʼihi na ị gaghị achọta ihe ọmụma nʼọnụ ya.
\b
\q1 
\v 8 Amamihe nke onye nwere uche bụ ihe na-eme ka ọ mata ebe ọ na-aga,
\q2 ma enweghị uche nke ndị nzuzu bụ aghụghọ.
\b
\q1 
\v 9 Ndị nzuzu na-eji okwu idozi ihe mmehie mebiri akwa emo;
\q2 ma obi ebere ka a na-achọta nʼetiti ndị omume ha ziri ezi.
\b
\q1 
\v 10 Ọ bụ naanị onye ihe na-eme maara ụfụ ya,
\q2 ọ dịghị onye ọzọ ga-eso keta ọṅụ ya.
\b
\q1 
\v 11 A ga-ala ụlọ onye ajọ omume nʼiyi,
\q2 ma ụlọ ikwu onye omume ya ziri ezi ga-awasa ka igu.
\b
\q1 
\v 12 Ọ dị ụzọ nke ziri ezi nʼanya mmadụ,
\q2 ma nʼikpeazụ ọ na-eduba nʼọnwụ.
\b
\q1 
\v 13 Ọ bụladị nʼime ọchị obi mgbu na-adị,
\q2 ma ọṅụ nwere ike kwụsị nʼiru ụjụ.
\b
\q1 
\v 14 Ndị na-ekwesighị ntụkwasị obi aghaghị inweta ụgwọ ọrụ ha,
\q2 ma ezi mmadụ ga-enwetakwa ụgwọ ọrụ ya.
\b
\q1 
\v 15 Onye na-enweghị uche na-ekwenye ihe niile a gwara ya;
\q2 ma onye nwere uche na-atule mara ebe ọ na-eje.
\b
\q1 
\v 16 Onye mara ihe na-atụ egwu \nd Onyenwe anyị\nd* na-ewezugakwa onwe ya nʼihe ọjọọ,
\q2 ma onye nzuzu na-ewebiga iwe oke ma na-eche na ọ ka bụ onye kwesiri ntụkwasị obi.
\b
\q1 
\v 17 Onye iwe ọkụ na-eme ihe nzuzu,
\q2 ma onye na-echepụta nzube ọjọọ ka a na-akpọ asị.
\b
\q1 
\v 18 Ndị na-enweghị uche na-enweta ụgwọ ọrụ nke uche gbagọrọ agbagọ,
\q2 ma onye nwere uche na-enweta ihe ọmụma.
\b
\q1 
\v 19 Ndị ọjọọ ga-akpọ isiala nʼihu ndị ezi mmadụ,
\q2 ndị ajọ omume ga-ada nʼọnụ ụzọ ama ndị ezi omume.
\b
\q1 
\v 20 Ọ bụladị ndị agbataobi onye ogbenye na-akpọ ya asị,
\q2 ma ọgaranya na-enwe ọtụtụ ndị enyi.
\b
\q1 
\v 21 Onye na-eleda onye agbataobi ya anya na-emehie,
\q2 ma onye na-emere ndị ogbenye ebere ka ihe ga-agara nke ọma.
\b
\q1 
\v 22 Ndị na-ezube ihe ọjọọ, ha ọ naghị akpafu?
\q2 Ma ndị na-ezube ihe ọma na-achọta ịhụnanya na ikwesi ntụkwasị obi.
\b
\q1 
\v 23 Ịrụsị ọrụ ike na-eweta uru;
\q2 ma oke okwu na-eweta ụkpa.
\b
\q1 
\v 24 Okpueze nke ndị maara ihe bụ akụnụba ha,
\q2 ma enweghị uche nke ndị nzuzu na-emepụta naanị ihe na-abaghị uru.
\b
\q1 
\v 25 Onye na-agba akaebe eziokwu na-anapụta ndụ mmadụ,
\q2 ma onye akaebe ụgha bụ onye aghụghọ.
\b
\q1 
\v 26 Onye ọbụla na-atụ egwu \nd Onyenwe anyị\nd* nwere ebe mgbaba;
\q2 nye ụmụ ya ọ ga-abụkwa ebe ize ndụ.
\b
\q1 
\v 27 Ịtụ egwu \nd Onyenwe anyị\nd* bụ isi iyi nke ndụ;
\q2 nke na-eme ka mmadụ ghara ịma nʼọnya ọnwụ.
\b
\q1 
\v 28 Otuto onye eze na-enwe dabeere nʼọnụọgụgụ ndị ọ na-achị,
\q2 e wezuga ndị ọ na-achị, eze enweghị ugwu ọbụla.
\b
\q1 
\v 29 Onye na-enwe ndidi nwere ọtụtụ nghọta,
\q2 ma onye obi ọkụ na-egosi enweghị uche ya.
\b
\q1 
\v 30 Ndụ dị jụụ na-eme ka ụbọchị mmadụ dị ogologo;
\q2 ekworo na-eme ka o ree ure.
\b
\q1 
\v 31 Onye ọbụla na-emegbu onye ogbenye na-elelị Chineke kere ha anya,
\q2 ma onye na-emere onye ogbenye ebere na-asọpụrụ Chineke.
\b
\q1 
\v 32 Ọ bụladị nʼọnwụ onye ezi omume nwere ebe mgbaba nʼime Chineke,
\q2 ma ndị ajọ omume na-ala nʼiyi, mgbe mbibi bịara.
\b
\q1 
\v 33 Nʼobi onye nwere nghọta ka amamihe na-anọgide,
\q2 ma ọ bụladị nʼetiti ndị nzuzu ọ na-eme ka amara ya.
\b
\q1 
\v 34 Ezi omume na-ewuli mba elu,
\q2 ma mmehie bụ ihe ihere nye ndị ọbụla.
\b
\q1 
\v 35 Eze na-aṅụrị ọṅụ nʼihi odibo maara ihe;
\q2 ma odibo na-eweta ihere na-akpali oke iwe ya.
\b
\c 15
\q1 
\v 1 Ọsịsa okwu dị nro na-eme ka iwe na ọnụma laa azụ;
\q2 ma okwu ike na-akpali iwe.
\b
\q1 
\v 2 Ire onye maara ihe na-eme ka ihe ọmụma mụbaa,
\q2 ma ọnụ onye nzuzu na-ekwupụta okwu enweghị uche.
\b
\q1 
\v 3 \nd Onyenwe anyị\nd* na-ahụzu ihe niile,
\q2 anya ya dịkwa nʼahụ ndị ọma na ndị ọjọọ.
\b
\q1 
\v 4 Okwu dị nwayọọ na-eweta ndụ na ume;
\q2 ma nkwutọ na-eweta ịda mba.
\b
\q1 
\v 5 Naanị onye nzuzu na-akpọ ndụmọdụ ndị mụrụ ya ihe efu;
\q2 ma onye ọbụla na-ege ntị nye mgbanwe na-ezipụta ezi uche.
\b
\q1 
\v 6 Ụlọ ndị ezi omume na-ejupụta nʼọtụtụ akụ,
\q2 ma akụ ndị na-emebi iwu na-ewetara ha nsogbu.
\b
\q1 
\v 7 Egbugbere ọnụ onye maara ihe na-agbasa ihe ọmụma,
\q2 ma obi ndị nzuzu ezighị ezi.
\b
\q1 
\v 8 \nd Onyenwe anyị\nd* na-akpọ aja ndị ajọ omume asị,
\q2 ma ekpere ndị ndụ ha ziri ezi na-atọ ya ụtọ.
\b
\q1 
\v 9 \nd Onyenwe anyị\nd* kpọrọ ụzọ ndị na-emebi iwu asị,
\q2 ma ndị na-achụso ezi omume ka ọ na-ahụ nʼanya.
\b
\q1 
\v 10 Oke ịdọ aka na ntị na-echere ndị na-ahapụ ụzọ.
\q2 Onye kpọrọ ịba mba asị ga-anwụ ọnwụ.
\b
\q1 
\v 11 \nd Onyenwe anyị\nd* mazuru ihe omimi niile nke ọnwụ na ọkụ ala mmụọ;
\q2 ọ ga-esikwa aṅaa ghara ịma obi ụmụ mmadụ?
\b
\q1 
\v 12 Ọ dịghị atọ onye na-akwa emo ụtọ ma a baara ya mba,
\q2 ya mere ọ dịghị ejekwuru onye maara ihe.
\b
\q1 
\v 13 Obi nke na-aṅụrị ọṅụ na-eme ka ihu dị mma.
\q2 Ihu gbarụrụ agbarụ na-egosi obi nwere ihe mwute.
\b
\q1 
\v 14 Obi nwere nghọta na-achọ ịmata ihe,
\q2 ma ọnụ onye nzuzu na-azụ onwe ya nʼokwu na-abaghị uru.
\b
\q1 
\v 15 Ndụ onye ogbenye jupụtara nnọọ na mgbalị,
\q2 ma ndị nwere udo nʼobi na-eri oriri mgbe niile.
\b
\q1 
\v 16 Ọ dị mma inwe akụnụba dị nta ma bụrụ onye na-atụ egwu \nd Onyenwe anyị\nd*,
\q2 karịa inwe akụ ma nọrọ na nsogbu.
\b
\q1 
\v 17 Ọ ka mma bụ oke nri akwụkwọ nri nta nke nwere ịhụnanya,
\q2 karịa ehi buru ibu a zụziri azụzi nke ịkpọ asị dị na ya.
\b
\q1 
\v 18 Onye iwe ọkụ na-amalite ọgụ;
\q2 ma onye na-adịghị ewe iwe ọsịịsọ na-eme ka ịlụ ọgụ kwụsị.
\b
\q1 
\v 19 Eji ogwu gbochie ụzọ onye umengwụ,
\q2 ma ụzọ onye omume ya ziri ezi bụ ụzọ dị larịị.
\b
\q1 
\v 20 Nwa nke maara ihe na-eme ka obi tọọ nna ya ụtọ,
\q2 ma onye nzuzu na-eleda nne ya anya.
\b
\q1 
\v 21 Onye na-enweghị uche na-aṅụrị ọṅụ nʼime amaghị ihe ya,
\q2 ma onye nwere nghọta na-aga ije nʼụzọ ziri ezi.
\b
\q1 
\v 22 Nzube na-enweghị ndụmọdụ na-ama afọ nʼala,
\q2 ma ndị ndụmọdụ dịrị ọtụtụ ọganihu ga-adị.
\b
\q1 
\v 23 Ọṅụ na-adị mgbe mmadụ natara ọsịsa dị mma,
\q2 okwu e kwuru nʼoge o kwesiri dị mma.
\b
\q1 
\v 24 Ụzọ ndụ na-agbago elu nye onye nwere uche,
\q2 iwezuga ha site na-ịgbada nʼala mmụọ dị nʼokpuru.
\b
\q1 
\v 25 \nd Onyenwe anyị\nd* na-adọtu ma na-adọrisi ụlọ nke onye mpako,
\q2 ma oke ala nke nwanyị di ya nwụrụ ka ọ na-elekọta.
\b
\q1 
\v 26 Echiche ọjọọ niile nke ndị na-emebi iwu ka \nd Onyenwe anyị\nd* kpọrọ asị
\q2 ma okwu ebere niile dị ọcha nʼanya ya.
\b
\q1 
\v 27 Onye anya ukwu na-ewetara ezinaụlọ ya nsogbu.
\q2 Ma onye kpọrọ iri ngarị asị ga-adị ndụ.
\b
\q1 
\v 28 Obi onye ezi omume na-atule ọsịsa ya
\q2 ma ọnụ nke onye ajọ omume na-asọpụta ihe ọjọọ dị iche iche.
\b
\q1 
\v 29 \nd Onyenwe anyị\nd* anọghị ndị na-emebi iwu nso;
\q2 ma ọ na-anụ ekpere ndị ezi omume.
\b
\q1 
\v 30 Ihu ọchị na-eweta obi ụtọ.
\q2 Akụkọ ọma na-enyekwa ọkpụkpụ ndụ.
\b
\q1 
\v 31 Onye na-ege ntị nye ịba mba nke na-enye ndụ
\q2 ga-esoro ndị amamihe nọrọ.
\b
\q1 
\v 32 Onye jụrụ ịdọ aka na ntị kpọrọ onwe ya asị
\q2 ma onye ọbụla naara ndụmọdụ nwere nghọta.
\b
\q1 
\v 33 Ịtụ egwu \nd Onyenwe anyị\nd* bụ amamihe na-abịa site nʼịdọ aka na ntị;
\q2 onye dị umeala nʼobi ga-anata ugwu na nsọpụrụ.
\b
\c 16
\q1 
\v 1 Mmadụ nwere ike pịa ihe ọ chọrọ ime,
\q2 ma okwu ikpeazụ ga-esi nʼọnụ \nd Onyenwe anyị\nd*.
\b
\q1 
\v 2 Ụzọ niile nke mmadụ dị ọcha nʼanya ya,
\q2 ma \nd Onyenwe anyị\nd* na-atule ebumnobi niile nke mmadụ.
\b
\q1 
\v 3 Were ọrụ gị niile nyefee nʼaka \nd Onyenwe anyị\nd*,
\q2 ọ ga-eme ka ha gaa nʼihu.
\b
\q1 
\v 4 \nd Onyenwe anyị\nd* na-eme ka ihe niile rụpụta ebumnuche ya,
\q2 o bụladị ndị mmebi iwu ka e debere maka ụbọchị mbibi.
\b
\q1 
\v 5 \nd Onyenwe anyị\nd* kpọrọ ndị nwere obi dị mpako asị.
\q2 Mara nke a nke ọma: Ha aghaghị ịta ahụhụ.
\b
\q1 
\v 6 Ọ bụ site nʼịhụnanya na eziokwu ka eji ekpuchi mmehie;
\q2 ọ bụkwa site nʼegwu \nd Onyenwe anyị\nd* ka mmadụ ji agbanarị mmehie.
\b
\q1 
\v 7 Mgbe ụzọ mmadụ na-agbaso na-atọ \nd Onyenwe anyị\nd* ụtọ,
\q2 ọ na-eme ka mmadụ ahụ na ndị iro ya dị nʼudo.
\b
\q1 
\v 8 Ọ dị mma inwe ihe nta nʼezi omume
\q2 karịa inwe ọtụtụ uru nʼụzọ ikpe na-ezighị ezi.
\b
\q1 
\v 9 Anyị nwere ike pịa ọpịpịa nʼobi anyị,
\q2 maọbụ \nd Onyenwe anyị\nd* na-edu ije anyị.
\b
\q1 
\v 10 Egbugbere ọnụ eze na-ekwu okwu sitere na-ezi nghọta,
\q2 ọnụ ya adịghị ekpe ikpe na-ezighị ezi.
\b
\q1 
\v 11 Ihe ọtụtụ ziri ezi na ihe niile ha nʼotu dịrị \nd Onyenwe anyị\nd*,
\q2 ihe niile e ji atụ ihe dị nʼime akpa bụ ya mere ha.
\b
\q1 
\v 12 Ndị eze kpọrọ ime ihe na-adịghị mma asị,
\q2 nʼihi na site nʼezi omume ka ocheeze ji eguzosi ike.
\b
\q1 
\v 13 Ndị eze na-enwe mmasị nʼegbugbere ọnụ na-ekwu eziokwu,
\q2 ha na-agụ onye na-ekwu eziokwu dị ka ezi mmadụ.
\b
\q1 
\v 14 Iwe eze bụ onyeozi nke ọnwụ.
\q2 Onye maara ihe ga-eme ka ọ dajụọ.
\b
\q1 
\v 15 Mgbe ọchị dị nʼihu eze ọ na-ewetara onye hụrụ ya ndụ,
\q2 ihuọma ya dị ka igwe ojii na-eweta mmiri ozuzo.\f + \fr 16:15 \ft Mmiri ozuzo nʼoge ọkọchị na-eme ka ahịhịa kpọnwụrụ akpọnwụ tutee, nke a na-eweta ọnụ, nʼihi olileanya ọ na-enye banyere ụba nke ihe a kụrụ nʼubi.\f*
\b
\q1 
\v 16 Ọ ka mma inwe amamihe na mmụọ ịghọta ihe
\q2 karịa inwe ọlaọcha na ọlaedo.
\b
\q1 
\v 17 Ụzọ dị larịị nke onye ziri ezi bụ iwezuga onwe ya pụọ nʼihe ọjọọ,
\q2 ndị na-echebe ụzọ ha niile na-echebekwa ndụ ha.
\b
\q1 
\v 18 Nganga na-eweta ịla nʼiyi,
\q2 mpako na-ewetakwa ọdịda.
\b
\q1 
\v 19 Ọ ka mma ịbụ onye ogbenye nwere obi umeala karịa ịbụ onye nganga,
\q2 na onye so ndị nganga keta oke nʼihe ha kwatara nʼagha.
\b
\q1 
\v 20 Onye ọbụla na-aṅa ntị na ndụmọdụ ka ihe na-agara nke ọma,
\q2 onye a gọziri agọzi bụ onye ahụ nke na-atụkwasị \nd Onyenwe anyị\nd* obi.
\b
\q1 
\v 21 A na-amata onye nwere uche site nʼụdị nghọta o nwere.
\q2 Okwu dị ụtọ na-eme ka mmadụ mụta ihe nke ọma.
\b
\q1 
\v 22 Inwe uche bụ isi iyi ndụ nye ndị niile nwere ya,
\q2 ma enweghị uche na-ewetara ndị nzuzu ntaramahụhụ.
\b
\q1 
\v 23 Obi onye maara ihe na-eme ka e tinye uche nʼokwu ọnụ ya,
\q2 egbugbere ọnụ ha na-emekwa ka mmụta gaa nʼihu.
\b
\q1 
\v 24 Okwu dị nro na-atọ ụtọ ka mmanụ aṅụ,
\q2 ọ na-atọ mkpụrụobi ụtọ, na-enyekwa ọkpụkpụ ahụ ike.
\b
\q1 
\v 25 Ọ dị ụzọ nke ziri ezi nʼanya mmadụ,
\q2 ma nʼikpeazụ ọ na-eduba nʼọnwụ.
\b
\q1 
\v 26 Agụụ ihe oriri nke onye ọrụ na-arụpụtara ya ọrụ;
\q2 agụụ na-akpali mmụọ ya ịga nʼihu.
\b
\q1 
\v 27 Ndị ọjọọ na-atụpụta echiche ọjọọ,
\q2 egbugbere ọnụ ha dị ka ọkụ nke na-ekpochapụ ahụ.
\b
\q1 
\v 28 Onye na-emebi iwu na-agbasa ise okwu;
\q2 ha na-akpali nsogbu, na-ekewa enyi na enyi.
\b
\q1 
\v 29 Ndị ọjọọ na-arafu ndị agbataobi ha,
\q2 na-edubakwa ha nʼụzọ ga-ewetara ha mbibi.
\b
\q1 
\v 30 Onye ji ikuanya ya ekwu okwu na-atụ atụmatụ ọjọọ,
\q2 onye na-atabi egbugbere ọnụ ya abụọ ekpebiela ime mmehie.
\b
\q1 
\v 31 Isi awọ bụ okpueze nke mara mma,
\q2 a na-enweta ya nʼụzọ ezi omume.
\b
\q1 
\v 32 Onye na-adịghị ewe iwe ọsịịsọ karịrị onye a maara aha ya.
\q2 Onye nwere ogologo ntachiobi karịrị onye na-adọta obodo nʼagha.
\b
\q1 
\v 33 A na-efe nza, nʼihi ịchọpụta uche \nd Onyenwe anyị\nd*,
\q2 maọbụ Chineke nʼonwe ya na-ekpebi ihe a ga-efeta na nza ahụ.
\b
\c 17
\q1 
\v 1 Ọ ka mma ịta iberibe achịcha kpọrọ nkụ ma ịnọ nʼudo adị ya,
\q2 karịa nʼụlọ jupụtara nʼoke oriri na ịlụ ọgụ.
\b
\q1 
\v 2 Ohu nwere uche ga-achị nwa nna ya ukwu na-eweta ihere
\q2 ma ketakwa oke nʼihe nketa dịka otu nʼime ndị ezinaụlọ ahụ.
\b
\q1 
\v 3 Ite eji anụcha ihe dịrị ọlaọcha, oke ọkụ dịkwara ọlaedo
\q2 ma \nd Onyenwe anyị\nd* na-anwale obi.
\b
\q1 
\v 4 Ajọ mmadụ na-aṅa ntị nʼegbugbere ọnụ na-eduhie,
\q2 onye ụgha na-aṅakwa ntị nye ire na-ekwu okwu ịla nʼiyi.
\b
\q1 
\v 5 Onye ọbụla na-akwa ogbenye emo ọ bụ Chineke kere ha ka ọ na-elelị anya.
\q2 Ndị niile na-aṅụrị ọṅụ nʼihi ihe ike dakwasịrị ha aghaghị ịta ahụhụ.
\b
\q1 
\v 6 Ụmụ ụmụ bụ okpueze ndị okenye.
\q2 Nne na nna bụ ịnya isi nke ụmụ ha.
\b
\q1 
\v 7 Egbugbere ọnụ na-ekwu okwu dị mma abụghị nke onye nzuzu,
\q2 otu a kwa, egbugbere ọnụ na-agha ụgha ekwesighị ịbụ nke onye na-achị achị.
\b
\q1 
\v 8 Nʼanya onye na-enye ngarị ọ na-ahụta ya dịka ọgwụ ịrata mmadụ,
\q2 ha na-eche nʼebe ọbụla ha chere ihu ihe ga-aga nke ọma.
\b
\q1 
\v 9 Onye ọbụla na-akwado ịhụnanya na-ekpuchi njehie,
\q2 ma onye na-ekwu ihe mere mgbe na mgbe na-ekewa ezi enyi.
\b
\q1 
\v 10 Ịba mba ntakịrị a baara onye nwere nghọta bara uru
\q2 karịa narị ụtarị nke a pịara onye nzuzu.
\b
\q1 
\v 11 Onye ọjọọ na-ebi naanị ndụ nnupu isi\f + \fr 17:11 \ft Ya bụ, omume megidere iwu ya\f* megide Chineke.
\q2 Ọ bụkwa onyeozi nke ọnwụ\f + \fr 17:11 \ft Ya bụ, onyeozi na-adịghị eme obi ebere.\f* ka a ga-eziga imegide ya.
\b
\q1 
\v 12 Ọ ka mma izute nne Bịa a napụrụ ụmụ ya
\q2 karịa izute onye nzuzu uche ya gbagọrọ agbagọ.
\b
\q1 
\v 13 Ọ bụrụ na i jiri ihe ọjọọ kwụọ ụgwọ ihe ọma,
\q2 ọbụbụ ọnụ dịrị ezinaụlọ gị.
\b
\q1 
\v 14 Esemokwu malite ọ na-esi ike imedo ya,
\q2 nʼihi ya ekwela ka ọ malite.
\b
\q1 
\v 15 Onye na-asị onye ikpe maara na ikpe amaghị ya na-amakwa onye aka ya dị ọcha ikpe,
\q2 \nd Onyenwe anyị\nd* na-akpọ omume abụọ a asị.
\b
\q1 
\v 16 Uru gịnị ka ego bara nʼaka onye nzuzu;
\q2 ebe ọ bụ na o nweghị ike ịchọ amamihe.
\b
\q1 
\v 17 Ezi enyi na-egosi ịhụnanya ya nʼoge ọbụla.
\q2 Otu a kwa, nwanne na-aba uru nʼoge mkpa.
\b
\q1 
\v 18 Ọ bụ uche ezughị oke ịnara ụgwọ onye ọzọ ji,
\q2 si otu a ghọọ onye ji ụgwọ.
\b
\q1 
\v 19 Onye na-ahụ esemokwu nʼanya hụrụ mmehie nʼanya.
\q2 Onye na-ewuli ọnụ ụzọ ama ya elu na-akpọ ntipịa oku.
\b
\q1 
\v 20 Ọ dịghị aga nʼihu bụ onye obi ya gbagọrọ agbagọ.
\q2 Onye nwere ire nrafu ga-adanye na nsogbu.
\b
\q1 
\v 21 Ọ bụ naanị iru ụjụ na obi ọjọọ
\q2 dịịrị nna nke nwa ya na-eme ihe nzuzu.
\b
\q1 
\v 22 Obi nke na-aṅụrị ọṅụ na-eme ka ahụ sie ike,
\q2 ma mmụọ na-eru ụjụ oge niile na-akpata ọrịa.
\b
\q1 
\v 23 Onye ajọ omume na-anara ihe ngarị\f + \fr 17:23 \ft \xt Ọpụ 23:8\xt*\f* na nzuzo
\q2 ka ọ sụgharịa ikpe ziri ezi isi.
\b
\q1 
\v 24 Onye nwere nghọta na-eche uche amamihe nʼihe ọ na-eme,
\q2 ma anya onye nzuzu na-elegharị ruo na nsọtụ nke ụwa.
\b
\q1 
\v 25 Nwa dị nzuzu na-ewetara nna ya mwute,
\q2 bụrụkwa nne mụrụ ya ihe ilu.
\b
\q1 
\v 26 Ọ bụrụ na ịra onye ezi omume nra adịghị mma,
\q2 nʼezie, ịpịa ndị ọrụ ihe nʼihi ezi ọrụ ha ezighị ezi.
\b
\q1 
\v 27 Nwoke ahụ na-adịghị ekwu ọtụtụ okwu bụ onye maara ihe,
\q2 onye mmụọ ya dịkwa jụụ bụ onye nwere nghọta.
\b
\q1 
\v 28 A ga-agụ onye nzuzu nʼonye maara ihe ma ọ bụrụ na ha gba nkịtị,
\q2 gụọkwa ha na ndị nwere nghọta ma ọ bụrụ na ha e jide ire ha.
\b
\c 18
\q1 
\v 1 Onye ihe mmadụ na-adịghị amasị na-agbaso naanị ọchịchọ nke ya onwe ya,
\q2 na-alụsokwa ezi nzube niile ọzọ ọgụ.
\b
\q1 
\v 2 Nghọta adịghị atọ onye nzuzu ụtọ.
\q2 Naanị ihe ọ maara bụ ikwu uche ya.
\b
\q1 
\v 3 Mgbe onye ajọ omume na-abata, ka nleda anya na-abata,
\q2 otu a kwa nkọcha na-eweta ihere.
\b
\q1 
\v 4 Okwu ọnụ niile bụ mmiri dị omimi,
\q2 ma amamihe dị ka mmiri iyi na-asọ asọ.
\b
\q1 
\v 5 Ọ dịghị mma ime ka ikpe gara onye mere ihe ọjọọ,
\q2 si otu a gbochie onye aka ya dị ọcha inweta ikpe ziri ezi.
\b
\q1 
\v 6 Egbugbere ọnụ ndị nzuzu na-ebutere ha esemokwu,
\q2 ọnụ ha na-ebutere ha ihe otiti.
\b
\q1 
\v 7 Ọnụ onye nzuzu na-etinye ya na nsogbu,
\q2 egbugbere ọnụ ya bụ ọnya nye mkpụrụobi ya.
\b
\q1 
\v 8 Okwu niile nke onye na-agba asịrị na-ekwu dịka iberibe nri nʼatọ ezi ụtọ,
\q2 ha na-agbadakwa nʼime ime ala afọ.
\b
\q1 
\v 9 Onye dị umengwụ nʼọrụ ya
\q2 bụ nwanne nke onye mbibi.
\b
\q1 
\v 10 Aha \nd Onyenwe anyị\nd* bụ ụlọ elu e wusiri ike,
\q2 ndị ezi omume na-agbaba nʼime ya izere ndụ.
\b
\q1 
\v 11 Akụ ndị ọgaranya bụrụ ha obodo e wusiri ike,
\q2 ọ bụkwa mgbidi dị elu nke a na-apụghị ịmafe nʼechiche ha.
\b
\q1 
\v 12 Tupu mmadụ adaa obi ya na-ejupụta na nganga,
\q2 ma inwe obi umeala na-eweta nsọpụrụ.
\b
\q1 
\v 13 Inye ọsịsa okwu tupu mmadụ ege ntị
\q2 bụ enweghị uche na ihe ihere.
\b
\q1 
\v 14 Ọ bụ mmụọ mmadụ na-akwado ya nʼoge nrịa nrịa,
\q2 ma mmụọ e tipịara etipịa, onye pụrụ ibuli ya?
\b
\q1 
\v 15 Obi onye nwere nghọta na-enweta ihe ọmụma,
\q2 nʼihi na ntị onye maara ihe na-achọpụta ya.
\b
\q1 
\v 16 Onyinye mmadụ na-akwara ya ụzọ sara mbara,
\q2 ọ na-edubakwa ya nʼihu ndị dị elu.
\b
\q1 
\v 17 Nʼikpe onye buru ụzọ kwuo ihe na-ese na-adị ka onye ikpe gaara,
\q2 tutu ruo mgbe mmadụ bịara bido ịjụ ya ajụjụ.
\b
\q1 
\v 18 Ife nza na-akwụsị esemokwu na ndọrọndọrọ
\q2 dị nʼetiti mmadụ abụọ ndị olu ha na-ala elu.
\b
\q1 
\v 19 Ọ dị mfe ịlụgbụ obodo karịa ime ka obi nwanne e mehiere tụgharịa.
\q2 Iwe ya na-adị ike dịka ọnụ ụzọ e jiri igodo tụchie.
\b
\q1 
\v 20 Site na mkpụrụ nke okwu ọnụ mmadụ mịpụtara ka afọ ga-eji ju ya.
\q2 Sitekwa nʼihe owuwe ubi nke egbugbere ọnụ ha ka ha ga-eji rijuo afọ.
\b
\q1 
\v 21 Ike ọnwụ na ndụ dị ire nʼaka.
\q2 Ndị hụrụ ya nʼanya ga-eri mkpụrụ ya.
\b
\q1 
\v 22 Nwoke ahụ chọtara nwunye chọtara ezi ihe.
\q2 Ọ na-anatakwa ihuọma site nʼaka \nd Onyenwe anyị\nd*.
\b
\q1 
\v 23 Onye ogbenye na-arịọ arịrịọ maka ebere;
\q2 ma ọgaranya na-asa okwu ike ike.
\b
\q1 
\v 24 Onye nwere ọtụtụ ndị enyi ndị na-ekwesighị ga-abịa nʼịla nʼiyi mgbe na-adịghị anya,
\q2 ma ọ dị enyi nke na-arapara nso karịa nwanne.
\b
\c 19
\q1 
\v 1 Ọ ka mma ịbụ ogbenye onye kwesiri ntụkwasị obi
\q2 karịa ịbụ onye nzuzu na-ekwu okwu ụgha mgbe niile.
\b
\q1 
\v 2 Arịrịọ nke na-enweghị ihe ọmụma adịghị mma
\q2 otu a kwa onye ụkwụ ya na-eme ngwa na-ejehie ụzọ.
\b
\q1 
\v 3 Enweghị uche nke mmadụ na-eduba ha nʼọghọm,
\q2 ma obi ha na-ewe iwe dị ukwuu megide \nd Onyenwe anyị\nd*.
\b
\q1 
\v 4 Onye nwere ego na-enwe ọtụtụ ndị enyi,
\q2 ma ọ na-ara ahụ ka ndị enyi onye ogbenye nọgide.
\b
\q1 
\v 5 Onye na-agba ama ụgha ga-ata ahụhụ,
\q2 ụzọ onye na-ekupụ ụgha dịka ume ka a ga-achọpụtakwa.
\b
\q1 
\v 6 Ọtụtụ mmadụ na-achọ ihuọma nʼebe onye na-achị achị nọ,
\q2 otu a kwa, mmadụ niile na-agbalị ịbụ enyi onye na-agbasa aka ya na-enye onyinye.
\b
\q1 
\v 7 Ebe ọ bụ na ụmụnne onye ogbenye na-akpọ ya asị,
\q2 gịnịkwa ka ndị enyi ya ga-eme?
\q1 Mgbalị ya niile ịrịọ ha arịrịọ
\q2 ezughị ime ka ha nọgide.
\b
\q1 
\v 8 Onye na-enweta amamihe hụrụ ndụ nʼanya,
\q2 onye na-edebekwa nghọta na-enweta ọganihu.
\b
\q1 
\v 9 Onyeama ụgha aghaghị ịta ahụhụ,
\q2 onye ọbụla na-ekwupụ okwu ụgha dịka mmiri ga-ala nʼiyi.
\b
\q1 
\v 10 Onye nzuzu ekwesighị ibi dịka ọgaranya;
\q2 ohu ekwesịkwaghị ịchị ụmụ eze.
\b
\q1 
\v 11 Ezi uche mmadụ nwere na-amụpụta ndidi;
\q2 ọ bụkwa nkwanye ugwu nye onye nʼadịghị agụ mkparị a na-akparị ya.
\b
\q1 
\v 12 Iwe eze dị ka mbigbọ nke ọdụm.
\q2 Ma obi ụtọ ya dị ka igirigi nʼelu ahịhịa ndụ.
\b
\q1 
\v 13 Nwa nzuzu bụ ịla nʼiyi nke nna,
\q2 nwunye na-ese okwu dị ka mmiri ọtụtụ na-atụ kpọm, kpọm,
\q2 mgbe niile nʼelu ụlọ puru epu.
\b
\q1 
\v 14 Ụlọ dị iche iche na akụ bụ ihe nketa a na-anata nʼaka ndị nne na nna,
\q2 ma nwunye nwere uche na nghọta na-esite naanị nʼaka \nd Onyenwe anyị\nd*.
\b
\q1 
\v 15 Umengwụ na-akpata oke ịrahụ ụra,
\q2 onye ọfọ ogori ka agụụ na-agụ.
\b
\q1 
\v 16 Onye na-edebe iwu Chineke na-enweta ndụ,
\q2 ma onye na-akpọ ya asị na-anwụ.
\b
\q1 
\v 17 Onye ọbụla na-egosi ndị ogbenye obi ebere na-ebinye \nd Onyenwe anyị\nd* ihe,
\q2 ọ ga-akwụghachi ha nʼihi ihe ọma ha mere.
\b
\q1 
\v 18 Dọọ nwa gị aka na ntị mgbe ọ ka dị na nwantakịrị nʼihi na oge ahụ ka olileanya dị.
\q2 Ma i meghị otu a, ọ bụ ndụ ya ka ị na-emebi.
\b
\q1 
\v 19 Onye oke iwe ga-anata nra so ya,
\q2 nʼihi na ọ bụrụ na ị napụta ya, ị ga-anapụtakwa ya ọzọ.
\b
\q1 
\v 20 Gee ntị na ndụmọdụ a na-enye gị, nabata ịdọ aka na ntị.
\q2 Nʼikpeazụ, ị ga-abụ onye maara ihe.
\b
\q1 
\v 21 Ọtụtụ atụmatụ dị nʼobi mmadụ;
\q2 maọbụ uche \nd Onyenwe anyị\nd* ga-emezu.
\b
\q1 
\v 22 Obi ebere mmadụ na-eme ka a na-achọsi ya ike.
\q2 Ọ ka mma ịbụ ogbenye karịa ịbụ mmadụ nke eziokwu ọbụla na-adịghị nʼọnụ ya.
\b
\q1 
\v 23 Ịtụ egwu \nd Onyenwe anyị\nd* na-eweta ndụ na ọṅụ,
\q2 na nchebe site nʼihe mmerụ ahụ.
\b
\q1 
\v 24 Onye umengwụ na-amanye aka nʼefere nri,
\q2 ọ gaghị eweghachi ya ọ bụladị tinye nʼọnụ ya.
\b
\q1 
\v 25 Tie onye na-akwa emo ihe, onye na-enweghị uche ga-aghọ onye nwere ezi uche,
\q2 baara onye nwere nghọta mba, ha ga-enweta ihe ọmụma.
\b
\q1 
\v 26 Ọ bụ nwa ahụ na-eweta ihere ga-ezu nne na nna ya ohi,
\q2 maọbụ chụpụ ha site nʼụlọ ya.
\b
\q1 
\v 27 Nwa m ọ bụrụ na ị hapụ ige ntị na ntụziaka m,
\q2 ị ga-esi nʼokwu ihe ọmụma kpafuo.
\b
\q1 
\v 28 Onyeama ụgha na-akwa ikpe ziri ezi emo.
\q2 Ọnụ nke onye ajọ omume na-eloda ajọ ihe.
\b
\q1 
\v 29 Ndị na-akwa emo na ndị nzuzu ga-ata ahụhụ;
\q2 a ga-etikwa ha ihe.
\b
\c 20
\q1 
\v 1 Mmanya bụ onye na-akwa emo. Onye mkpọtụ ka ihe ọṅụṅụ na-aba nʼanya bụ.
\q2 Onye ọbụla kwere ka ha duhie ya bụ onye nzuzu.
\b
\q1 
\v 2 Ọnụma eze na-emenye oke ụjọ nʼahụ dịka mbigbọ nke ọdụm;
\q2 ndị na-akpasu ya iwe ga-atụfu ndụ ha.
\b
\q1 
\v 3 Ọ bụ ihe nsọpụrụ nye onye na-ezere okwu na ụka,
\q2 ma onye nzuzu ọbụla na-eme ngwa ise okwu.
\b
\q1 
\v 4 Onye umengwụ adịghị arụ ọrụ ubi nʼoge ya.
\q2 Nʼoge owuwe ihe ubi ọ pụghị ịchọta ihe oriri.
\b
\q1 
\v 5 Nzube niile nke dị mmadụ nʼobi bụ mmiri dị omimi,
\q2 ma onye nwere nghọta na-adọpụta ha.
\b
\q1 
\v 6 Ọtụtụ mmadụ na-asị na ha nwere ịhụnanya na-adịghị agharịpụ,
\q2 ma onye kwesiri ntụkwasị obi, onye pụrụ ịchọta ya?
\b
\q1 
\v 7 Onye ezi omume nke na-ejegharị nʼizuoke,
\q2 ndị ihe na-agara nke ọma ka ụmụ ga-anọchi ya ga-abụ.
\b
\q1 
\v 8 Mgbe eze na-anọkwasị nʼocheeze ya ikpe ikpe,
\q2 ọ na-eji anya ya abụọ afụchapụ ihe ọjọọ niile.
\b
\q1 
\v 9 Onye pụrụ ị sị, “Emeela m ka obi m dị ọcha;
\q2 Abụ m onye dị ọcha, mmehie adịghịkwa nʼime m?”
\b
\q1 
\v 10 Ihe ọtụtụ aghụghọ na ihe ọtụtụ nghọgbu,
\q2 ha niile bụ ihe arụ nʼihu \nd Onyenwe anyị\nd*.
\b
\q1 
\v 11 Ọbụladị ụmụntakịrị ka a na-amata site nʼomume ha niile,
\q2 nke a ọ pụtara nʼomume ha dị ọcha nʼezie a, bụrụkwa ihe ziri ezi?
\b
\q1 
\v 12 Ntị nke na-anụ ihe na anya nke na-ahụ ụzọ,
\q2 ọ bụ \nd Onyenwe anyị\nd* mere ha abụọ.
\b
\q1 
\v 13 Ahụla ịrahụ ụra nʼanya, ka ị ghara ịghọ onye ụkpa.
\q2 Bilie, mụrụ anya, rụsie ọrụ ike, ka i nweekwa ihe oriri.
\b
\q1 
\v 14 “Lee, ihe a jọrọ njọ, ọ baghị uru,” ka onye na-azụ ahịa na-asị,
\q2 ma mgbe ọ pụrụ ọ na-anya isi nʼihi ihe ọ zụtara.
\b
\q1 
\v 15 Ọlaedo dị, na ọtụtụ rubi nʼebe ọ bara ụba,
\q2 ma egbugbere ọnụ nke na-ekwupụta ihe ọmụma bụ ọla dị oke ọnụahịa.
\b
\q1 
\v 16 Chiri uwe onye ahụ naara onye mba ọzọ nʼaka mbe.
\q2 Jichiekwa ihe mbe ahụ o nyere nʼihi onye mba ọzọ ọ nara na mbe.
\b
\q1 
\v 17 Nri e nwetara nʼụzọ aghụghọ na-atọ mmadụ ụtọ.
\q2 Ma nʼikpeazụ aja ga-eju ya ọnụ.
\b
\q1 
\v 18 Buru ụzọ nata ndụmọdụ tupu i mee ihe ọbụla ị chọrọ ime;
\q2 ebula agha ma i bubeghị ụzọ pịa ọpịpịa.
\b
\q1 
\v 19 Agwala onye na-akpa asịrị ihe nzuzo gị,
\q2 nʼihi na ọ ga-akụ ya nʼekwe nye ụwa niile.
\b
\q1 
\v 20 Oriọna onye ahụ na-akọcha nne ya na nna ya
\q2 ka Chineke na-afụnyụ.
\b
\q1 
\v 21 Ihe nketa nke anatara nʼoke ọsịịsọ,
\q2 agaghị agọzi ya nʼikpeazụ.
\b
\q1 
\v 22 A sịkwala, “Aga m akwụghachi gị nʼihi ihe ọjọọ a.”
\q2 Chere \nd Onyenwe anyị\nd*, ọ ga-abọrọ gị ọbọ.
\b
\q1 
\v 23 \nd Onyenwe anyị\nd* kpọrọ ihe ọtụtụ gbara iche iche asị,
\q2 ihe ọtụtụ aghụghọ adịghị atọ ya ụtọ.
\b
\q1 
\v 24 \nd Onyenwe anyị\nd* na-eduzi nzọ ụkwụ niile nke mmadụ.
\q2 Olee otu onye ọbụla ga-esi ghọta ụzọ ha?
\b
\q1 
\v 25 Ime ngwangwa\f + \fr 20:25 \ft Ya bụ mgbe mmadụ na-echeghị uche mee nke a.\f* doo ihe nsọ, bụ ịma nʼọnya
\q2 ma mesie tụgharịwa uche banyere imezu nkwa ahụ.
\b
\q1 
\v 26 Eze maara ihe na-afụchapụ ndị ajọ omume,
\q2 ọ na-eji wịịlu ịfụcha mkpụrụ gaa nʼelu ha.
\b
\q1 
\v 27 Akọnuche mmadụ bụ ọkụ \nd Onyenwe anyị\nd* ji enyocha mmụọ ya,
\q2 ọ na-egwupụta ala ala obi ya, igosi anyị ihe anyị bụ.
\b
\q1 
\v 28 Ịhụnanya na ikwesi ntụkwasị obi na-echebe eze,
\q2 site nʼịhụnanya ka ocheeze ya na-eguzo chịm.
\b
\q1 
\v 29 Ugwu a na-akwanyere ụmụ okorobịa bụ nʼihi ịdị ike ha,
\q2 ma isi awọ bụ nsọpụrụ ndị okenye.
\b
\q1 
\v 30 Ọkpọ na mmerụ ahụ na-ehichapụ ihe ọjọọ,
\q2 ụtarị na-asachapụ ime ime nke ahụ mmadụ.
\b
\c 21
\q1 
\v 1 Iyi dị iche iche nke jupụtara na mmiri ka obi eze bụ nʼaka \nd Onyenwe anyị\nd*,
\q2 nke ọ na-ahazi nʼụzọ ọbụla dị ya mma.
\b
\q1 
\v 2 Ọrụ niile bụ ihe ziri ezi nʼanya onye na-arụ ya,
\q2 ma \nd Onyenwe anyị\nd* bụ onye na-eleba anya nʼechiche obi anyị niile.
\b
\q1 
\v 3 Ime ezi omume na ihe ziri ezi
\q2 ka \nd Onyenwe anyị\nd* na-anabata karịa ịchụ aja.
\b
\q1 
\v 4 Nganga na mpako na agụụ ihe ọjọọ
\q2 nke bụ ọrụ ndị ajọ omume, bụ mmehie.
\b
\q1 
\v 5 Echiche niile nke onye na-arụsị ọrụ ike na-eweta uru,
\q2 dịka echiche onye ome ngwangwa na-enweta naanị ụkọ.
\b
\q1 
\v 6 Uru niile enwetara nʼụzọ na-ezighị ezi adịghị adịgide,
\q2 ha bụ nkuume ifufe na-efesa, ndị na-achọ ya na-achọ ọnwụ.
\b
\q1 
\v 7 Nʼihi na ndị na-emebi iwu anaghị eme ihe ọma,
\q2 ihe ọjọọ ha na-eme na-alaghachi laa ha nʼiyi.
\b
\q1 
\v 8 Ụzọ onye na-emebi iwu bụ ihe gbagọrọ agbagọ,
\q2 ma omume onye aka ya dị ọcha ziri ezi.
\b
\q1 
\v 9 Ọ ka mma ibi nʼotu akụkụ elu ụlọ
\q2 karịa ibinyere nwanyị na-ese okwu.
\b
\q1 
\v 10 Ihe na-atọ onye ọjọọ ụtọ bụ imerụ ndị ọzọ ahụ;
\q2 ọ maghị imere mmadụ ibe ya ebere.
\b
\q1 
\v 11 Mgbe a na-ata onye na-akwa emo ahụhụ, onye na-enweghị uche na-enweta amamihe,
\q2 ma mgbe a na-akụziri onye maara ihe ihe ọ na-enweta ihe ọmụma.
\b
\q1 
\v 12 Onye ezi omume na-amụta ihe site nʼile ụlọ onye ajọ omume anya
\q2 na-emekwa ka ndị ajọ omume laa nʼiyi.
\b
\q1 
\v 13 Onye na-adịghị ege ntị na mkpu onye ogbenye,
\q2 ya onwe ya ga-akpọkwa mkpu ma agaghị aza ya.
\b
\q1 
\v 14 Onyinye enyere na nzuzo na-eme ka iwe dajụọ,
\q2 otu a kwa, ngarị ezonyere nʼime uwe na-eme ka oke ọnụma dajụọ.
\b
\q1 
\v 15 Onye ezi omume na-aṅụrị ọṅụ mgbe e kpere ikpe ziri ezi,
\q2 ma bụrụ ihe oke egwu dịrị ndị na-eme ajọ ihe.
\b
\q1 
\v 16 Onye ọbụla si nʼụzọ nghọta wezuga onwe ya
\q2 ga-eso nʼotu ndị nwụrụ anwụ.
\b
\q1 
\v 17 Nwoke hụrụ ibi ndụ nganga nʼanya na-ada ụkpa;
\q2 ịṅụ mmanya na oke oriri abụghị ụzọ esi akpata akụ.
\b
\q1 
\v 18 Onye ajọ omume ga-abụ ihe mgbapụta maka onye ezi omume,
\q2 onye aghụghọ ga-abụkwa ihe mgbapụta maka onye ndụ ya ziri ezi.
\b
\q1 
\v 19 Ọ ka mma ibi nʼọzara
\q2 karịa ibinyere nwanyị na-atamu ntamu na-esekwa okwu.
\b
\q1 
\v 20 Onye maara ihe na-edebe ezi ihe oriri na mmanụ oliv nʼụlọ ya,
\q2 ma onye nzuzu na-eloda ihe niile nʼọnụ ya.
\b
\q1 
\v 21 Onye na-achụso ezi omume na ịhụnanya
\q2 ga-achọta ndụ, na ugwu na ọganihu.
\b
\q1 
\v 22 Onye maara ihe nwere ike megide obodo ndị dike,
\q2 kwatuokwa ebe ewusiri ike nke ha tụkwasịrị obi ha.
\b
\q1 
\v 23 Onye na-echekwa ire ya na ọnụ ya
\q2 na-egbochiri onwe ya ọdachi.
\b
\q1 
\v 24 Onye nganga na onye mpako, onye na-akwa emo bụ aha ya.
\q2 Ọ na-eji oke nganga eme ihe niile.
\b
\q1 
\v 25 Oke ọchịchọ nke onye umengwụ na-ewetara ya ọnwụ
\q2 nʼihi na ọ jụrụ ịrụ ọrụ.
\q1 
\v 26 Kwa ụbọchị ka ọ na-achọ inwe karịa,
\q2 ma onye ezi omume na-enye na-akpaghị oke.
\b
\q1 
\v 27 Chineke kpọrọ aja ndị na-emebi iwu asị,
\q2 nke ka nke, ma ọ bụrụ na ha na-enye onyinye a site na nzube ọjọọ.
\b
\q1 
\v 28 Onyeama ụgha ga-ala nʼiyi,
\q2 ma onye ọbụla na-ege ya ntị ka a ga-ebibi ruo ebighị ebi.
\b
\q1 
\v 29 Ndị ajọ omume na-ebi ndụ atụghị egwu,
\q2 ma ndị omume ha ziri ezi na-atụgharị uche nʼụzọ ha niile.
\b
\q1 
\v 30 O nweghị amamihe dị, o nweghị nghọta dị, o nwekwaghị atụmatụ ọbụla,
\q2 nke pụrụ iguzosi ike megide \nd Onyenwe anyị\nd*.
\b
\q1 
\v 31 E nwere ike jikere ịnyịnya, kwadokwaa maka agha,
\q2 maọbụ naanị \nd Onyenwe anyị\nd* na-enye mmeri.
\b
\c 22
\q1 
\v 1 Ihe nhọrọ dị ezi mma ka aha ọma bụ karịa ọtụtụ akụ,
\q2 ịnata amara\f + \fr 22:1 \ft Maọbụ, \fqa mmadụ inwe ugwu\f* ihuọma ka mma karịa ọlaọcha na ọlaedo.
\b
\q1 
\v 2 Ma ogbenye ma ọgaranya bụ otu nʼihu \nd Onyenwe anyị\nd*
\q2 onye kere ha niile.
\b
\q1 
\v 3 Onye nwere uche na-ahụ nsogbu nke na-abịa nʼihu ma zobe onwe ya,
\q2 ma onye na-enweghị uche anaghị ele anya, ọ na-adaba nʼime nsogbu ahụ taa ahụhụ so ya.
\b
\q1 
\v 4 Obi umeala bụ egwu \nd Onyenwe anyị\nd*,
\q2 ụgwọ ọ na-akwụ bụ akụnụba, na nsọpụrụ na ndụ ogologo.
\b
\q1 
\v 5 Ogwu na igbudu dị nʼụzọ onye na-emebi iwu;
\q2 ma onye kpọrọ ndụ ya ihe na-asọ ya asọ.
\b
\q1 
\v 6 Kuziere nwantakịrị ka ọ họrọ ụzọ ziri ezi,\f + \fr 22:6 \ft \xt Efe 6:4; 2Tm 3:15\xt*\f*
\q2 mgbe o tolitere ọ ga-anọgide nʼime ya.
\b
\q1 
\v 7 Dịka ọgaranya si achị ogbenye,
\q2 otu a kwa ka onye na-ebi ego si bụrụ ohu onye na-ebinye ya ego.
\b
\q1 
\v 8 Onye na-agha ikpe na-ezighị ezi dịka mkpụrụ, ga-ewe ajọ ihe dịka ihe ubi,
\q2 mkpanaka nke ikike iwe ha ga-agbajikwa.
\b
\q1 
\v 9 Onye na-agbasapụ aka enye onyinye ga-abụ onye a gọziri agọzi,
\q2 nʼihi na ha na ekenyetụ ndị ogbenye nri.
\b
\q1 
\v 10 Chụpụ onye na-akwa emo, ise okwu ga-akwụsị,
\q2 e, ịlụ ọgụ na nlelị ga-akwụsịkwa.
\b
\q1 
\v 11 Onye na-ahụ ịdị ọcha nke obi nʼanya,
\q2 onye okwu ya jupụtara nʼamara ga-abụ enyi eze.
\b
\q1 
\v 12 Anya \nd Onyenwe anyị\nd* na-echebe ihe ọmụma,
\q2 ma ọ na-emebi atụmatụ niile nke ndị aghụghọ.
\b
\q1 
\v 13 Onye umengwụ na-asị, “Ọdụm nọ nʼezi!
\q2 A ga-egbu m nʼama ọha mmadụ!”
\b
\q1 
\v 14 Ọnụ nwanyị na-akwa iko bụ oke olulu,
\q2 nwoke nọ nʼokpuru oke iwe \nd Onyenwe anyị\nd* na-adaba nʼime ya.
\b
\q1 
\v 15 Obi ụmụntakịrị jupụtara nʼenweghị uche,
\q2 ma apịpịa ịdọ aka na ntị ga-achụpụ ya nʼebe dị anya.
\b
\q1 
\v 16 Onye na-achọ uru site nʼimegbu onye na-enweghị ike,
\q2 maọbụ onye na-enye ọgaranya onyinye ga-ebi nʼoke ụkọ.
\ms1 Okwu iri atọ onye maara ihe
\s2 Okwu nke mbụ
\q1 
\v 17 Lezie anya gee ntị nʼokwu niile nke ndị maara ihe,
\q2 tinye uche gị nʼihe m na-akụzi.
\q1 
\v 18 Ọ dị ụtọ ma idebe ha nʼobi gị,
\q2 ma ha dịkwa nʼegbugbere ọnụ gị mgbe niile.
\q1 
\v 19 Ọ bụ ka ntụkwasị obi gị dị nʼime \nd Onyenwe anyị\nd*,
\q2 ya ka m na-akụziri gị taa, ọbụladị gị onwe gị.
\q1 
\v 20 Ọ bụ na m edepụtabereghị gị iri ndụmọdụ atọ ndị a,
\q2 bụ okwu ndụmọdụ na ihe ọmụma?
\q1 
\v 21 Ha na-ezi gị ihe bụ ikwesi ntụkwasị obi na ikwu eziokwu.
\q2 Mgbe ahụ ọ bụrụ na-ezie gị sị gị gaa chọta eziokwu
\q2 ị ga-eji ezi ọsịsa lọghachi.
\s2 Okwu nke abụọ
\q1 
\v 22 Emegbula ogbenye nʼihi na ọ bụ ogbenye.
\q2 Emegidekwala ya nʼụzọ ikpe.
\q1 
\v 23 Nʼihi na \nd Onyenwe anyị\nd* ga-ekwuchitere ha ọnụ ha
\q2 ma bibiekwa ndị na-emegide ha.
\s2 Okwu nke atọ
\q1 
\v 24 Gị na onye na-ewe oke iwe abụla enyi,
\q2 gị na onye na-ewe iwe ọsịịsọ emekọkwala ihe,
\q1 
\v 25 ma ọ bụghị ya, i nwere ike ịmụta ndụ ha,
\q2 si otu a tinye ndụ gị na nsogbu.
\s2 Okwu nke anọ
\q1 
\v 26 Abụla onye otu nʼime ndị na-anara ndị mmadụ akaebe
\q2 maọbụ kwee nkwa ikwu ụgwọ onye ọzọ ji.
\q1 
\v 27 Nʼihi na ọ bụrụ na i nweghị ego ị ga-eji kwụọ ụgwọ ahụ,
\q2 a ga-anapụ gị ọ bụladị ihe ndina gị.
\s2 Okwu nke ise
\q1 
\v 28 Ehigharịla oke ala e tinyere site na mgbe ochie.
\q2 Nke ndị nna ochie gị ha hiwere.
\s2 Okwu nke isii
\q1 
\v 29 Ị hụrụ mmadụ ahụ nke nwere ǹka nʼịrụ ọrụ ya nke ọma?
\q2 Ọ ga-eguzo nʼihu ndị eze,
\q2 ọ gaghị eguzo nʼihu ndị a na-amaghị aha ha.
\c 23
\s2 Okwu nke asaa
\q1 
\v 1 Mgbe gị na onye na-achị achị nọdụrụ irikọ nri,
\q2 lezie ihe\f + \fr 23:1 \ft Maọbụ, \fqa onye nọ nʼihu gị\f* dị nʼihu gị anya,
\q1 
\v 2 tụkwasị mma nʼakpịrị gị,
\q2 ma ọ bụrụ na ị bụ onye iri oke nri na-atọ ụtọ.
\q1 
\v 3 Achọsila nri ụtọ ya ike,
\q2 nʼihi na nri ahụ bụ nri aghụghọ.
\s2 Okwu nke asatọ
\q1 
\v 4 Adọgbula onwe gị nʼọrụ maka ịbụ ọgaranya,
\q2 atụkwasịla obi na nghọta gị.\f + \fr 23:4 \ft Maọbụ, \fqa ịdị nkọ gị\f*
\q1 
\v 5 Nʼihi na akụ nwere ike ifu
\q2 nʼotu ntabi anya dịka a ga-asị
\q2 na ha nwere nku dịka nnụnụ ugo.
\s2 Okwu nke itoolu
\q1 
\v 6 Erila nri onye aka ntagide na-enye gị.
\q2 Nri ụtọ ya agụkwala gị agụ.
\q1 
\v 7 Nʼihi na ọ bụ ụdị mmadụ ahụ
\q2 na-eche ọnụahịa ihe ọ na-emefuru gị.
\q1 Ọ na-asị gị, “Rie ihe, ṅụọkwa ihe ọṅụṅụ,”
\q2 ma obi ya adịghị nʼebe ị nọ.
\q1 
\v 8 Ị ga-agbọkwa nke ntakịrị ahụ i riri
\q2 mgbe ahụ, okwu ọma ahụ niile i kwuru banyere ya ga-abụ ihe efu.
\s2 Okwu nke iri
\q1 
\v 9 Atụfula ume gị ịgwa onye nzuzu okwu,
\q2 nʼihi na ọ ga-eleda okwu i sitere nʼezi uche kwuo anya.
\s2 Okwu nke iri na otu
\q1 
\v 10 Anarala nwa na-enweghị nne na nna ala ya
\q2 site nʼihigharị oke ala e gwunyere site nʼoge gara aga,
\q1 
\v 11 nʼihi na onye mgbapụta ha dị ike;
\q2 ya onwe ya ga-ekwuchitere ha ọnụ ha.
\s2 Okwu nke iri na abụọ
\q1 
\v 12 Tinye uche gị nʼịdọ aka na ntị;
\q2 gekwaa ntị nụrụ okwu ihe ọmụma niile.
\s2 Okwu nke iri na atọ
\q1 
\v 13 Ahapụla ịdọ ụmụ gị aka na ntị.
\q2 Ha agaghị anwụ nʼihi na ị tiri ha ihe.
\q1 
\v 14 Jiri mkpara tie ya ihe
\q2 ma zọpụta ndụ ya site nʼọnwụ.
\s2 Okwu nke iri na anọ
\q1 
\v 15 Nwa m, aga m aṅụrị ọṅụ nke ukwuu
\q2 ma ọ bụrụ na ị ghọọ onye maara ihe.
\q1 
\v 16 Mkpụrụobi m ga-aṅụrị ọṅụ
\q2 mgbe egbugbere ọnụ gị abụọ kwuru ihe ziri ezi.
\s2 Okwu nke iri na ise
\q1 
\v 17 Ekwela ka obi gị kwosa ndị mmehie ekworo,
\q2 kama nọgide nʼịnụ ọkụ nʼobi nʼịtụ egwu \nd Onyenwe anyị\nd* mgbe niile,
\q1 
\v 18 nʼihi na i nwere ọtụtụ ihe ọma nʼihu gị.
\q2 Olileanya dị ukwuu dịrị gị.
\s2 Okwu nke iri na isii
\q1 
\v 19 Nwa m, nwee uche,
\q2 gbasookwa ụzọ Chineke.
\q1 
\v 20 Anọla nʼetiti ndị na-aṅụbiga mmanya oke,
\q2 na ndị iri oke oriri na-atọ ụtọ,
\q1 
\v 21 nʼihi na ihe niile ga-akọ ha.
\q2 Ọ bụkwa nkịrịnka akwa ka onye oke ụra na-eyi nʼahụ.
\s2 Okwu nke iri na asaa
\q1 
\v 22 Ṅaa ntị nʼịdọ aka na ntị nna gị,
\q2 akpọkwala ịdọ aka na ntị nne gị bụ agadi nwanyị asị.
\q1 
\v 23 Zụta eziokwu, erekwala ya,
\q2 zụtakwa amamihe, ntụziaka, na nghọta.
\q1 
\v 24 Nna onye ezi omume ga-aṅụrị ọṅụ.
\q2 Ọ bụkwa ihe oke ọṅụ inweta nwa maara ihe.
\q1 
\v 25 Ka nne na nna gị nwee obi ụtọ.
\q2 Ka onye mụrụ gị ṅụrịa.
\s2 Okwu nke iri na asatọ
\q1 
\v 26 Nwa m, nye m obi gị
\q2 ka ụzọ m niile nyekwa anya gị ọṅụ.
\q1 
\v 27 Nʼihi na onye akwụna bụ olulu miri emi,
\q2 nwanyị nwe di na-akwa iko bụ olulu mmiri dị warawara.
\q1 
\v 28 Dịka onye ohi ka ọ na-echere
\q2 na-emekwa ka ndị na-ekwesighị ntụkwasị obi baa ụba nʼetiti ụmụ nwoke.
\s2 Okwu nke iri na itoolu
\q1 
\v 29 Onye ka obi ya jupụtara nʼahụhụ? Onye nọ na iru ụjụ?
\q2 Olee onye nwere esemokwu? Onye nwere ọtụtụ ihe mkpesa?
\q2 Onye nwere mmerụ ahụ nke na-abaghị uru? Onye nwere anya nke na-acha ọbara ọbara?
\q1 
\v 30 Ọ bụ ndị na-anọ ogologo oge na-aṅụ mmanya,
\q2 onye na-aga ịchọpụta mmanya agwara agwa.
\q1 
\v 31 Elekwasịla mmanya anya mgbe ọ na-acha ọbara ọbara,
\q2 mgbe ọ na-ezipụta ọdịdị ya nʼiko
\q2 mgbe ọ na-asụgharị nke ọma nʼime iko.
\q1 
\v 32 Nʼikpeazụ, ọ na-ata dịka agwọ
\q2 na-atụkwa dịka ajụala.
\q1 
\v 33 Anya gị abụọ ga-ahụ ihe ị na-amaghị isi ya na ọdụ ya,
\q2 obi gị ga-atụlekwa ihe ndị na-agbagwoju anya.
\q1 
\v 34 Ị ga-adị ka onye na-edina nʼetiti oke osimiri,
\q2 nke na-edinakwa nʼelu ụdọ nʼejide ụgbọ.
\q1 
\v 35 Ị ga-asị, “Ha tiri m ihe, ma emerụghị m ahụ.
\q2 Ha pịara m ihe, ma amaghị m.
\q1 Olee mgbe m ga-eteta,
\q2 ka m pụọ ga chọọ mmanya ọzọ?”
\c 24
\s2 Okwu nke iri abụọ
\q1 
\v 1 Ekwosola ndị ajọ omume ekworo,
\q2 ka ihe banyere ha ghara ịtọ gị ụtọ.
\q1 
\v 2 Nʼihi na-atụmatụ obi ha niile bụ otu ha ga-esi mee ihe ike,
\q2 egbugbere ọnụ ha na-ekwu naanị maka ọgbaaghara.
\s2 Okwu nke iri abụọ na otu
\q1 
\v 3 Ọ bụ amamihe ka e ji ewu ụlọ,
\q2 ọ bụkwa nghọta ka e ji eme ka o guzosie ike.
\q1 
\v 4 Sitekwa nʼihe ọmụma ka akụ niile ji ejupụta nʼime ya,
\q2 bụ akụ ndị pụrụ iche ma dịkwa oke ọnụahịa.
\s2 Okwu nke iri abụọ na abụọ
\q1 
\v 5 Onye maara ihe na-emeri site nʼịdị ike,
\q2 ndị nwere ọmụma ihe na-akpali ike ha.
\q1 
\v 6 Ejela ọgụ ma ọ bụghị na i nwetara ezi ndụmọdụ,
\q2 nʼihi na nzọpụta dị nʼige ọtụtụ ndị ndụmọdụ ntị.
\s2 Okwu nke iri abụọ na atọ
\q1 
\v 7 Amamihe dị elu nke ukwuu nye ndị nzuzu,
\q2 ha gaghị asaghe ọnụ ha nʼọgbakọ ọnụ ụzọ ama.
\s2 Okwu nke iri abụọ na anọ
\q1 
\v 8 Onye na-eche echiche ime ihe ọjọọ
\q2 ka a ga-agụ dịka onye nzube ihe ọjọọ
\q1 
\v 9 Nzube niile nke onye na-enweghị uche bụ mmehie,
\q2 ndị mmadụ na-akpọ onye na-akwa emo asị.
\s2 Okwu nke iri abụọ na ise
\q1 
\v 10 Ọ bụrụ na ị pụghị iguzosi ike nʼoge nsogbu,
\q2 ị bụ nnọọ onye ike ya dị ntakịrị.
\q1 
\v 11 Napụta ndị a na-eduba nʼọnwụ.
\q2 Napụtakwa ndị ahụ a mara ikpe ọnwụ nʼụzọ na-ezighị ezi.
\q1 
\v 12 Ọ bụrụ na ị sị, “Anyị amaghị banyere ihe ndị a,”
\q2 ọ bụ na onye na-enyocha obi aghọtaghị ya?
\q1 Ọ bụ na onye na-eche ndụ gị amaghị ya?
\q2 Ọ bụ na ọ gaghị akwụghachi onye ọbụla ụgwọ dịka akaọrụ ya siri dị?
\s2 Okwu nke iri abụọ na isii
\q1 
\v 13 Nwa m nwoke, rachaa mmanụ aṅụ nʼihi na ọ dị mma.
\q2 Mmanụ aṅụ nke si nʼugbugbo mmanụ aṅụ na-adị gị ụtọ nʼọnụ.
\q1 
\v 14 Marakwa na otu a ka amamihe kwesiri isi tọọ obi gị ụtọ.
\q2 Ọ bụrụ na i chọta ya
\q2 i nwere olileanya nke ga-adịgide.
\s2 Okwu nke iri abụọ na asaa
\q1 
\v 15 Adịla ka onye na-emebi iwu, onye echiche ya niile bụ imegide ụlọ onye ezi omume.
\q2 A gakwala ga kwakọrọ ihe dị nʼụlọ ya.
\q1 
\v 16 Nʼihi na onye ezi omume nwere ike daa ugboro asaa ma o ga-ebilikwa ọzọ.
\q2 Ma ndị na-emebi iwu na-asọ ngọngọ mgbe nsogbu bịakwasịrị ha.
\s2 Okwu nke iri abụọ na asatọ
\q1 
\v 17 Aṅụrịla ọṅụ mgbe onye iro gị dabara na nsogbu.
\q2 Ka obi gharakwa ịtọ gị ụtọ mgbe ọ dara.
\q1 
\v 18 Nʼihi na \nd Onyenwe anyị\nd* pụrụ iwe iwe nʼihi ya
\q2 megide gị ma kwụsị ịta ya ahụhụ.
\s2 Okwu nke iri abụọ na itoolu
\q1 
\v 19 Ekwosola onye na-emebi iwu ekworo,
\q2 maọbụ nwe anya ukwu nʼebe onye ajọ omume nọọ.
\q1 
\v 20 Nʼihi na onye na-emebi iwu enweghị ọdịnihu;
\q2 a ga-afụnyụkwa ọkụ onye ajọ omume.
\s2 Okwu nke iri atọ
\q1 
\v 21 Nwa m, tụọ egwu \nd Onyenwe anyị\nd* na onye bụ eze,
\q2 esonyerela ndị ozi na-enupu isi megide nna ha ukwu.
\q1 
\v 22 Nʼihi na ọ bụ na mberede ka ị ga-eso ha daba na nhụju anya.
\q2 Onye maara ihe ga-abụ ọgwụgwụ ya?
\ms1 Okwu ọzọ ndị amamihe kwuru
\p 
\v 23 Ndị a bụkwa okwu ọzọ ndị amamihe kwuru,
\q1 iji gosi na ikpe ikpe na-akwụghị ọtọ adịghị mma.
\q1 
\v 24 Onye ọbụla nke na-asị onye ikpe mara, “Onye ezi omume ka ị bụ,”\f + \fr 24:24 \ft Onye ọbụla nke na-asị onye na-emebi iwu, onye ikpe na-amaghị ka ị bụ\f*
\q2 ga-anata ọbụbụ ọnụ site nʼọnụ ọtụtụ mmadụ, mba niile ga-eweso ya iwe.
\q1 
\v 25 Ma ọ ga-adịrị ndị ahụ na-abara onye ikpe mara mba na mma,
\q2 ha ga-anatakwa ezi ngọzị.
\b
\q1 
\v 26 Ọsịsa ziri ezi
\q2 bụ ihe na-egosi ikwesi ntụkwasị obi.\f + \fr 24:26 \ft Dịka nsusu e susuru nʼegbugbere ọnụ\f*
\b
\q1 
\v 27 Rụchaa ọrụ gị dị nʼezi.
\q2 Dozie ala ubi gị.
\q2 Emesịa wuoro onwe gị ụlọ.
\b
\q1 
\v 28 Agbala ama ụgha megide onye agbataobi gị nʼefu.
\q2 Ọ bụ egbugbere ọnụ gị abụọ ka ị ga-eji ghọọ aghụghọ?\f + \fr 24:28 \fqa Maọbụ, \ft rafuo mmadụ\f*
\q1 
\v 29 Asịla, “Aga m emeso ha dịka ha siri meso m.
\q2 Aga m akwụghachi ha ụgwọ ihe ha mere.”
\b
\q1 
\v 30 Esitere m nʼubi otu onye umengwụ gafee,
\q2 bụ ubi vaịnị nke onye na-enweghị uche,
\q1 
\v 31 hụ na ogwu etochiela ya,
\q2 ahịhịa etochiekwala ya;
\q2 mgbidi dị ya gburugburu adaakwala.
\q1 
\v 32 Elegharịrị m ya anya
\q2 site na ya mụta otu ihe a:
\q1 
\v 33 Nwa ụra nta, nwa iru ụra nta,
\q2 nwa ịchịkọba aka nta zuo ike
\q1 
\v 34 ụbịam ga-abịakwasị gị dịka onye ohi,
\q2 ụkọ abịakwasịkwa gị dịka onye na-apụnara mmadụ ihe.
\c 25
\ms1 Ilu ndị ọzọ nke Solomọn
\p 
\v 1 Ndị a bụkwa ilu Solomọn, nke ndị ozi Hezekaya eze ndị Juda dekọtara nʼakwụkwọ.
\q1 
\v 2 Ọ bụ nsọpụrụ Chineke izobe okwu,
\q2 ma nsọpụrụ ndị eze bụ ịchọpụta ala okwu.
\q1 
\v 3 Dịka ịdị elu nke eluigwe, dịka ịdị omimi nke ala,
\q2 otu a ka obi ndị eze bụ ihe a na-apụghị ịchọpụta.
\b
\q1 
\v 4 Wepụ ihe ahụ niile na-ekpuchi mma ọlaọcha,
\q2 onye ọkpụ ụzụ ọla ga-arụpụta efere;
\q1 
\v 5 wezugakwa ndịisi nʼeme ajọ ihe nʼihu eze,
\q2 ocheeze ya ga-eguzosikwa ike site nʼezi omume.
\b
\q1 
\v 6 Egosipụtala onwe gị nʼihu eze,
\q2 ewerela ọnọdụ nʼetiti ndị oke mmadụ,
\q1 
\v 7 ọ ga-aka mma ma ọ bụrụ na ọ si gị, “Rigota nʼebe a,”
\q2 karịa na o wedara gị ala nʼihu ndị oke mmadụ.
\b
\q1 Ihe iji anya gị abụọ hụ
\q2 
\v 8 e mekwala ngwangwa ịga nʼụlọikpe,
\q1 nʼihi na ọ bụ gịnị ka ị ga-eme nʼikpeazụ
\q2 ma ọ bụrụ nʼonye agbataobi gị etinye gị nʼọnọdụ ihere?
\b
\q1 
\v 9 Ọ bụrụ na gị na onye ọzọ enwee esemokwu, dozienụ ya nʼonwe unu,
\q2 emekwala ka ndị ọzọ mata okwu nzuzo gị na onye ọzọ kwuru,
\q1 
\v 10 ma ọ bụghị ya, onye nụrụ ya nwere ike menye gị ihere,
\q2 agwa ọjọọ gị agaghị enwekwa ọgwụgwụ.
\b
\q1 
\v 11 Ndụmọdụ e nyere nʼoge kwesiri ekwesi
\q2 dị ka mkpụrụ osisi apụl ọlaedo e tinyere nʼefere ọlaọcha.
\q1 
\v 12 Dịka ọlantị ọlaedo maọbụ ihe ịchọ mma nke ọlaedo mara mma
\q2 ka mba onye maara ihe bụ na ntị onye na-anụ ya.
\b
\q1 
\v 13 Onyeozi kwesiri ntụkwasị obi na-eweta ntute na ndụ,
\q2 dịka mmiri oyi si eme ka ahụ dị jụụ
\q2 nʼoge okpomọkụ owuwe ihe ubi.
\q1 
\v 14 Onye ahụ na-adịghị emezu nkwa o kwere
\q2 dịka igwe ojii nke na-adịghị ezo mmiri.
\b
\q1 
\v 15 Nwee ndidi, nʼikpeazụ ị ga-enwe mmeri,
\q2 nʼihi na ire dị nro na-agbaji ọkpụkpụ.
\b
\q1 
\v 16 Mmanụ aṅụ ọ na-atọ gị ụtọ?
\q2 Arachala ya karịa, ka ọ ghara iwetara gị ọrịa.
\q1 
\v 17 Ejela ileta onye agbataobi gị mgbe mgbe,
\q2 ka ị ghara ire ugwu gị.
\b
\q1 
\v 18 Onye na-agbagịde onye agbataobi ya ama ụgha,
\q2 dịka mkpọrọ osisi maọbụ mma agha, maọbụ àkụ a pịziri apịzi.\f + \fr 25:18 \ft Ya bụ, nke dị nkọ\f*
\q1 
\v 19 Ịtụkwasị onye aghụghọ obi nʼoge nsogbu dị ka iji eze na-eme ndakapụ ata ihe,
\q2 maọbụ iji ụkwụ jiri eji agba ọsọ.
\q1 
\v 20 Dịka onye e yipụrụ uwe nʼụbọchị oyi ụgụrụ,
\q2 maọbụ iwere nnu tee nʼelu ọnya,
\q2 otu a ka onye na-abụrụ onye iwe na-ewe abụ dị.
\b
\q1 
\v 21 Ọ bụrụ na agụụ na-agụ onye iro gị, nye ya nri ka o rie,
\q2 ọ bụrụkwa na akpịrị na-akpọ ya nkụ, nye ya mmiri ka ọ ṅụọ.\f + \fr 25:21 \ft \xt Ọpụ 23:4-5; 2Ih 28:15; Mat 5:44\xt*\f*
\q1 
\v 22 Mgbe ị na-eme nke a, ị na-agụkwasị icheku ọkụ na-ere ere nʼisi ya,
\q2 \nd Onyenwe anyị\nd* ga-akwụghachikwa gị.
\b
\q1 
\v 23 Dịka ifufe si nʼugwu si eweta mmiri ozuzo,
\q2 otu a ka ikwu mmadụ okwu azụ si eweta iwe.
\b
\q1 
\v 24 Ọ ka mma ibi nʼotu akụkụ elu ụlọ
\q2 karịa ibinyere nwanyị na-ese okwu.
\b
\q1 
\v 25 Oziọma e sitere na mba dị anya nata
\q2 dị ka mmiri jụrụ oyi nye onye akpịrị na-akpọ nkụ.
\q1 
\v 26 Onye ezi omume nke kwenyere nʼihe onye na-emebi iwu kwuru
\q2 dị ka iyi a gwọrụrụ nʼisi ya.
\b
\q1 
\v 27 Dịka ịracha mmanụ aṅụ hie nne si jọọ njọ,
\q2 otu a ka o si bụrụ ihe na-enweghị nsọpụrụ, mmadụ ịchọpụta ihe ndị ezomiri ezomi.
\b
\q1 
\v 28 Nwoke ọbụla na-adịghị achị mmụọ ya
\q2 dị ka obodo na-enweghị ndị na-eche ya nche, nke e tikpọrọ mgbidi ya etikpọ.
\c 26
\q1 
\v 1 Ịhụ onye nzuzu a na-enye nsọpụrụ
\q2 dịka ịhụ mkpụrụ mmiri ka ọ na-ada nʼoge ọkọchị maọbụ mmiri na-ezo nʼoge owuwe ihe ubi.
\q1 
\v 2 Dịka nnụnụ nta na-efegharị efegharị, maọbụ dịka eleke na-awụgharị
\q2 otu a ka ọbụbụ ọnụ na-ekwesighị agaghị ere.
\q1 
\v 3 Ụtarị dịrị ịnyịnya, ịnyịnya ibu ka a na-ekenye mkpụmkpụ igwe nʼọnụ;
\q2 otu a kwa ka apịpịa dị nye azụ ndị nzuzu.
\q1 
\v 4 A zaghachila onye nzuzu dịka enweghị uche ya si dị,
\q2 ma ọ bụghị ya gị onwe gị ga-adị ka ya.
\q1 
\v 5 Zaa onye nzuzu dịka enweghị uche ya si dị,
\q2 ma ọ bụghị ya ọ ga-abụ onye maara ihe nʼanya onwe ya.
\q1 
\v 6 Iziga ozi site nʼaka onye nzuzu
\q2 dịka mmadụ ibipụ ụkwụ ya maọbụ ịṅụ ihe ike dịka mmiri.
\q1 
\v 7 Dịka onye ngwụrọ si eji ụkwụ ya eje ije,
\q2 otu a ka ilu si esite nʼọnụ onye nzuzu apụta.
\q1 
\v 8 Ọ baghị uru inye onye nzuzu nsọpụrụ, nʼihi na ọ gaghị anọgide.
\q2 Ọ dị ka ịwụ ọkụkọ mmiri nʼazụ.
\q1 
\v 9 Dịka ogwu manyere nʼaka onye na-aṅụbiga mmanya oke
\q2 otu a ka ilu dị nʼọnụ onye nzuzu.
\q1 
\v 10 Dịka ọgba ụta si agba ụta ya na-enweghị onye o bụ nʼobi,
\q2 otu a ka ọ dị bụ onye na-enye onye nzuzu maọbụ onye o bụla na-agafe nʼụzọ ọrụ ka o rụọra ya.
\q1 
\v 11 Dịka nkịta laghachiri ọzọ nʼihe ọ gbọrọ,
\q2 otu a ka ndị nzuzu dị mgbe ha na-emekwa omume enweghị uche ha.
\q1 
\v 12 Ị hụrụ onye mara ihe nʼanya nke onwe ya?
\q2 Olileanya dị nye onye nzuzu karịa ndị dị otu a.
\b
\q1 
\v 13 Onye umengwụ na-asị, “Ọdụm nọ nʼokporoụzọ,
\q2 ọdụm ji oke iwe na-awagharị nọ nʼama niile!”
\q1 
\v 14 Dịka ibo ọnụ ụzọ si emegharị nʼihe nkonye ya,
\q2 otu a ka onye umengwụ si na-atụgharị onwe ya nʼelu ihe ndina ya.
\q1 
\v 15 Onye umengwụ na-amanye aka nʼefere nri\f + \fr 26:15 \ft Maọbụ, \fqa ọkụ nri\f*
\q2 ma oke umengwụ a naghị ekwe ka o weghachi ya tinye nʼọnụ ya.
\q1 
\v 16 Nʼuche ya, onye umengwụ\f + \fr 26:16 \ft Ya bụ, onye nzuzu\f* na-eche na ọ maara ihe
\q2 karịa ndị ikom asaa na-eji ezi uche azaghachi okwu.
\b
\q1 
\v 17 Onye na-etinye onwe ya nʼesemokwu na-agbasaghị ya
\q2 dị ka mmadụ na-apụ nʼokporoụzọ dọkpụrụ nkịta ọbụla ọ hụrụ na ntị.
\b
\q1 
\v 18 Dịka onye ara na-agba àkụ
\q2 na-ere ọkụ nke na-eweta ọnwụ,
\q1 
\v 19 ka nwoke ahụ bụ nke na-aghọgbu onye agbataobi ya
\q2 ma sị, “ọ bụ naanị egwuregwu ka m na-egwu.”
\b
\q1 
\v 20 Ọkụ na-anyụ mgbe nkụ gwụrụ,
\q2 otu a kwa esemokwu na-akwụsị mgbe a kwụsịrị ikwu ndị ọzọ okwu nʼazụ.
\q1 
\v 21 Dịka icheku si eme ka nkụ nwuru ọkụ,
\q2 otu a ka onye na-ese okwu si eme ka ọgụ nwuru ọkụ.
\q1 
\v 22 Okwu niile nke onye na-agba asịrị na-ekwu dịka iberibe nri nʼatọ ezi ụtọ,
\q2 ha na-agbadakwa nʼime ime ala afọ.
\b
\q1 
\v 23 Dịka ite aja ụrọ nke e ji ọlaọcha na-abaghị uru techie,
\q2 ka egbugbere ọnụ dị nro nke obi jupụtara nʼihe ọjọọ bụ.
\q1 
\v 24 Ndị iro na-eji egbugbere ọnụ ha gbanwee onwe ha,
\q2 ma nʼime obi ha ọ bụ naanị aghụghọ dị ya.
\q1 
\v 25 Okwu ọnụ ya nwere ike tọọ ụtọ na ntị ma ekwenyerela ha,
\q2 nʼihi na ihe arụ asaa jupụtara nʼime obi ha.
\q1 
\v 26 Ọ bụ ezie na ọ ga na-eme ka ọ hụrụ gị nʼanya,
\q2 ma iro ya ga-apụta ihe, mmadụ niile ga-ahụkwa ya.
\q1 
\v 27 Onye na-egwuru ibe ya olulu ga-adaba nʼime ya.
\q2 Ọzọ, onye na-enuda nkume, ya ka nkume ahụ ga-adagbu.
\q1 
\v 28 Onye ị kpọrọ asị bụ onye ị ga-achọ iwetara ihe mgbu site nʼịgha ụgha.
\q2 Okwu ọma na-esighị nʼobi mmadụ pụta na-eweta ịla nʼiyi.
\b
\c 27
\q1 
\v 1 Anyala isi banyere echi,
\q2 nʼihi na ị maghị ihe echi ga-abụ.\f + \fr 27:1 \ft \xt Luk 12:19-21; Jem 4:13-16\xt*\f*
\b
\q1 
\v 2 Ka onye ọzọ too gị, ọ bụghị ọnụ gị.\f + \fr 27:2 \ft Etola onwe gị, chere ka ndị ọzọ too gị\f*
\q2 Ka onye ọzọ too gị, ka egbugbere ọnụ gị abụọ ghara ito gị.
\b
\q1 
\v 3 Nkume dị arọ, aja bụkwa ibu arọ,
\q2 ma mkpasu iwe nke onye nzuzu dị arọ karịa ha abụọ.
\b
\q1 
\v 4 Iwe na-emebi ihe,
\q2 ma ekworo jọrọ njọ karịa iwe.
\b
\q1 
\v 5 Mba abara nʼihe ka mma
\q2 karịa ịhụnanya ezoro ezo.
\b
\q1 
\v 6 Ihe kwesiri ntụkwasị obi ka mmerụ ahụ nke sitere nʼaka enyi bụ,
\q2 ma onye iro na-eme ka isutu ọnụ mụbaa.
\b
\q1 
\v 7 Mmanụ aṅụ adịghị atọ onye rijuru afọ ụtọ;
\q2 ma mgbe agụụ ji ya, ọ ga-eri ọ bụladị ihe dị ilu.
\b
\q1 
\v 8 Nwoke na-akpafu site nʼụlọ ya
\q2 dị ka nnụnụ na-amakwaghị akwụ ya.
\b
\q1 
\v 9 Mmanụ isi ụtọ na ihe nsure ọkụ na-esi isi ụtọ na-eme ka obi ṅụrịa,
\q2 otu a ka ụtọ enyi dị,
\q2 site na ndụmọdụ nke mkpụrụobi ha.
\b
\q1 
\v 10 Ahapụla enyi gị maọbụ ndị enyi nna gị.
\q2 Mgbe ị nọ na mkpa arịọla nwanne gị ka o nyere gị aka.
\q2 Onye agbataobi nọ gị nso nwere ike inyere gị aka karịa nwanne gị nọ ebe dị anya.
\b
\q1 
\v 11 Nwa m, obi ga-atọ m ụtọ nke ukwuu ma a sị na ị ga-amụta ihe!
\q2 Mgbe ahụ, aga m enwe ihe m ga-asa ndị na-akọcha m.
\b
\q1 
\v 12 Onye nwere uche na-ahụ nsogbu nke na-abịa nʼihu ma zobe onwe ya.
\q2 Ma onye na-enweghị uche anaghị ele anya, ọ na-adaba nʼime nsogbu ahụ taa ahụhụ so ya.
\b
\q1 
\v 13 Chịrị uwe onye ahụ nke naara onye mba ọzọ na mbe.
\q2 E, chiri ya ma ọ bụrụ nwanyị na-abụghị nwunye ya ka o nara na mbe.
\b
\q1 
\v 14 Ọ bụrụ na onye ọbụla e jiri oke olu gọzie onye agbataobi ya nʼisi ụtụtụ
\q2 a ga-agụ nke a dịka ịbụ ọnụ.
\b
\q1 
\v 15 Mmiri na-ata nʼime ụlọ mgbe mmiri na-ezo
\q2 na nwanyị na-eso okwu bụ otu.
\q1 
\v 16 Onye nwere ike ịkwụsị ya nwere ike iji aka jide ifufe,
\q2 maọbụ were aka jide mmanụ.
\b
\q1 
\v 17 Dịka e si eji igwe amụ igwe ọzọ ka ọ dị nkọ,
\q2 otu a ka mmadụ si enyere ibe ya aka ịdị nkọ.
\b
\q1 
\v 18 Onye na-eche osisi fiig nche ga-eri mkpụrụ ya,
\q2 onye na-echebekwa nna ya ukwu ka a ga-asọpụrụ.
\b
\q1 
\v 19 Dịka e si ahụ ihu mmadụ nʼime mmiri
\q2 otu a ka obi mmadụ si egosi ihe onye ahụ bụ.
\b
\q1 
\v 20 Dịka afọ adịghị eju ọnwụ na mbibi,
\q2 otu a ihe na-agụ anya mmadụ adịghị agwụ agwụ.
\b
\q1 
\v 21 Ite eji anụcha ihe dịrị ọlaọcha, oke ọkụ dịkwara ọlaedo
\q2 ma a na-anwale ndị mmadụ site nʼotuto a na-enye ha.
\b
\q1 
\v 22 Nʼagbanyeghị na ị ga-egwepịa onye nzuzu nʼime ikwe,
\q2 were aka odo gwee ha dịka mkpụrụ ọka,
\q2 ị pụghị isite nʼahụ ha wepụ enweghị uche ha.
\b
\q1 
\v 23 Lezie ọrụ gị anya nke ọma,
\q2 marakwa ọnọdụ igwe ewu na atụrụ gị na anụ ụlọ ndị ọzọ,
\q1 
\v 24 nʼihi na akụnụba adịghị adịgide.
\q2 Ọ bụladị okpueze nke onye eze na-emesịa gabiga.
\q1 
\v 25 Mgbe e gbupụchara ahịhịa ochie, nke ọhụrụ na-epupụta,
\q2 mgbe ahụ ka a na-achịkọbata ahịhịa sị nʼugwu.
\q1 
\v 26 Ụmụ atụrụ ga-enye gị uwe ị ga-eyi,
\q2 ụmụ ewu ga-enyekwa gị ego ọnụahịa ala ubi gị.
\q1 
\v 27 Ị ga-enwe mmiri ara ewu nke ga-ezuru gị na ndị ezinaụlọ gị nri,
\q2 na nke ga-edozi ahụ ndị odibo nwanyị gị.
\b
\c 28
\q1 
\v 1 Ndị ajọ omume na-agba ọsọ mgbe onye ọbụla na-adịghị achụ ha,
\q2 ma ndị ezi omume na-enwe ntụkwasị obi dịka ọdụm.
\b
\q1 
\v 2 Mgbe njehie dị nʼobodo dị ọtụtụ, o nwere ọtụtụ ndịisi,
\q2 ma onyeisi nwere ezi nghọta na ihe ọmụma ga-eme ka udo na-adịgide ogologo oge.
\b
\q1 
\v 3 Onye na-achị achị nke na-emegbu ndị ogbenye,
\q2 bụ mmiri ozuzo nke na-azachapụ ihe niile mee ka nri ghara ịdị.
\b
\q1 
\v 4 Onye na-adịghị asọpụrụ iwu na-eto ndị ajọ omume,
\q2 ma ndị na-edebe ihe iwu kwuru na-ebu agha megide ha.
\b
\q1 
\v 5 Ndị ajọ omume adịghị aghọta uru ikpe ziri ezi bara,
\q2 ma ndị na-eso \nd Onyenwe anyị\nd* na-aghọta ihe bụ uru ya.
\b
\q1 
\v 6 Ọ kaara gị mma ịbụ nwa ogbenye na onye eziokwu
\q2 karịa na ị bụ ọgaranya na eze aghụghọ.
\b
\q1 
\v 7 Ụmụ okorobịa nwere nghọta na-eme ihe iwu kwuru,
\q2 ma nwa nke ya na ndị oke oriri bụ enyi na-emenye nna ya ihere.
\b
\q1 
\v 8 Onye na-eme ka akụ ya baa ụba site na ịnara ụma maọbụ ọmụrụnwa nʼaka onye ogbenye,
\q2 na-ekpokọta ya nye onye ọzọ, onye na-emere ndị ogbenye ebere.
\b
\q1 
\v 9 Onye na-ewezuga ntị ya site nʼebe iwu m dị,
\q2 ọ bụladị ekpere ha bụ ihe arụ.
\b
\q1 
\v 10 Onye ọbụla na-eduhie ndị ziri ezi nʼụzọ ihe ọjọọ,
\q2 ga-adaba nʼọnya ahụ ha onwe ha gbara,
\q2 ma ndị na-enweghị ịta ụta ga-anata ezi ihe nketa.
\b
\q1 
\v 11 Nʼanya nke onwe ya, onye ọgaranya na-agụ onwe ya dịka onye maara ihe,
\q2 ma nʼezie, onye ogbenye nwere nghọta na-enyochapụta amaghị ihe nke onye ọgaranya.
\b
\q1 
\v 12 Mgbe ihe na-agara ndị ezi omume nke ọma, onye ọbụla na-aṅụrị ọṅụ,
\q2 ma onye ọbụla na-ezo onwe ya mgbe onye na-emebi iwu na-aga nʼihu.
\b
\q1 
\v 13 Onye na-ezo mmehie ya agaghị enwe ọganihu na ndụ ya.
\q2 Ma onye na-ekwupụta mmehie ya hapụkwa ha, ka a ga-emere ebere.
\b
\q1 
\v 14 Ngọzị na-adịrị mmadụ ahụ na-atụ egwu Chineke,
\q2 ma onye na-enupu isi na-etinye onwe ya na nsogbu.
\b
\q1 
\v 15 Dịka ọdụm na-agbọ ụja maọbụ nne bịa na-achụ mmadụ
\q2 otu a ka onye ọchịchị ọjọọ nke na-achị ndị na-enweghị ike dị.
\b
\q1 
\v 16 Ọ bụ naanị eze na-amaghị ihe ga-akpagbu ndị ya;
\q2 ma eze ga-achị ogologo oge bụ eze kpọrọ iri ngarị asị.
\b
\q1 
\v 17 Obi ogbu mmadụ ga na-ama ya ikpe
\q2 ruo ala mmụọ.
\q2 Ka onye ọbụla ghara inyere ya aka.
\b
\q1 
\v 18 Onye na-eje ije na-enweghị ịta ụta ka a na-echebe,
\q2 ma onye ụzọ ya gbagọrọ agbagọ ga-adaba nʼolulu.
\b
\q1 
\v 19 Onye na-arụ ala ubi ya ga-enwe nri nʼebe ọ bara ụba,
\q2 ma onye na-agbaso ihe efu dị iche iche, ụbịam ga-eju ya afọ.
\b
\q1 
\v 20 Onye ọbụla nke kwesiri ntụkwasị obi ga-enweta ọtụtụ ngọzị,
\q2 ma nwoke ahụ na-achọ ịbụ ọgaranya ngwangwa aghaghị inweta ntaramahụhụ.
\b
\q1 
\v 21 Ile mmadụ anya nʼihu nʼoge ikpe jọgburu onwe ya.
\q2 Ma ụfọdụ ndị ikpe na-eme ihe na-ezighị ezi, ọ bụladị, nʼihi iberibe nri.
\b
\q1 
\v 22 Onye aka ntagide ọ na-anụ ọkụ nʼobi ịghọ ọgaranya
\q2 amaghị na ụkpa nọ na-eche ya.
\b
\q1 
\v 23 Onye ọbụla na-abara mmadụ mba, nʼikpeazụ ga-enweta amara
\q2 karịa onye ahụ na-aja mmadụ ibe ya mma ire ụtọ.
\b
\q1 
\v 24 Nwoke na-ezu nne na nna ya ohi ma na-asịkwa,
\q2 “Olee ihe ọjọọ dị na ya?”
\q2 Onye dị otu a bụ nnọọ enyi ndị mbibi.
\b
\q1 
\v 25 Ndị oke ọchịchọ na-akpali ise okwu,
\q2 ma ndị na-atụkwasị \nd Onyenwe anyị\nd* obi na-enwe ọganihu.
\b
\q1 
\v 26 Nwoke ahụ na-atụkwasị onwe ya obi bụ onye nzuzu!
\q2 Ma ndị na-agbaso amamihe Chineke, aka adịghị akpa ha.
\b
\q1 
\v 27 Ọ bụrụ na i nye ogbenye, a ga-egboro gị mkpa gị.
\q2 Ma ọbụbụ ọnụ dịrị ndị ahụ na-ekpuchi anya ha nʼebe ndị ogbenye nọ.\f + \fr 28:27 \ft \xt Dit 15:7; Ilu 22:9\xt*\f*
\b
\q1 
\v 28 Mgbe ndị ajọ omume na-aga nʼihu, ndị ezi omume na-ezo onwe ha,
\q2 ma mgbe ha nʼala nʼiyi, ndị ezi omume nʼaba ụba.
\b
\c 29
\q1 
\v 1 Onye a na-abara mba mgbe niile ma ọ naghị anata ndụmọdụ,
\q2 nʼotu ntabi anya ka a ga-etipịa ya, ọ gaghị ekulikwa ọzọ.
\b
\q1 
\v 2 Mgbe ndị ezi omume nọ nʼọchịchị, ndị a na-achị na-aṅụrị ọṅụ,
\q2 ma ha na-asụ ude mgbe onye ajọ omume na-achị.
\b
\q1 
\v 3 Nwoke hụrụ amamihe nʼanya na-eme ka nna ṅụrịa,
\q2 ma onye bụ enyi ụmụ nwanyị akwụna, na-ala akụnụba ya nʼiyi.
\b
\q1 
\v 4 Eze na-achị nʼeziokwu na-ewetara obodo ya ọganihu,
\q2 ma nke na-achọ ngarị na-ala ya nʼiyi.
\b
\q1 
\v 5 Onye ahụ ji ire ụtọ na-aja onye agbataobi ya mma
\q2 bụ ọnya ka ọ na-esiri ya.
\b
\q1 
\v 6 Ọ bụ onye ajọ omume siri ọnya ka ọnya ahụ na-ama.
\q2 Ma ndị ezi omume na-anọrọ onwe ha na-agụ egwu ọṅụ.
\b
\q1 
\v 7 Onye ezi omume na-etinye anya nʼihe banyere ikpe ziri ezi nke ndị ogbenye,
\q2 ma ụdị echiche ahụ adịghị abata ndị ajọ omume nʼobi.
\b
\q1 
\v 8 Ndị nzuzu na-amalite ọgụ ebe niile,
\q2 ma ndị nwere uche na-agbalịsị ike ime ka udo dị.
\b
\q1 
\v 9 Ọ bụrụ na onye maara ihe esoro onye nzuzu gaa nʼụlọikpe,
\q2 onye nzuzu ga-ewe iwe ọkụ, mee mkpọtụ, kwaa emo ma udo agaghị adị.
\b
\q1 
\v 10 Ndị ndụ ha na-ebi bụ ime ihe ike na-akpọ onye eziokwu asị,
\q2 ha na-achọsikwa ike ụzọ ha ga-esi gbuo onye ndụ ya ziri ezi.
\b
\q1 
\v 11 Onye nzuzu na-egosi oke iwe ya,
\q2 ma onye nwere uche na-ejide onwe ya na-emekwa ka mmụọ ya dajụọ.
\b
\q1 
\v 12 Ọ bụrụ na onye na-achị achị aṅaa ntị nʼokwu ụgha,
\q2 ndị niile na-ejere ya ozi ga-aghọ ndị ajọ omume.
\b
\q1 
\v 13 Ogbenye na ọgaranya bụ otu na nke a:
\q2 ọ bụ \nd Onyenwe anyị\nd* na-eme ka ha jiri anya ha na-ahụ ụzọ.
\b
\q1 
\v 14 Ọ bụrụ na eze esite nʼizi ezi kpee ndị ogbenye ikpe,
\q2 a ga-eme ka ocheeze ya guzosie ike ruo mgbe ebighị ebi.
\b
\q1 
\v 15 Ịba mba na iti nwantakịrị ihe na-enye aka mee ka ọ bụrụ ezi nwa,
\q2 ma nwantakịrị a na-adịghị adụ ọdụ na-eme nne ya ihe ihere.
\b
\q1 
\v 16 Mgbe ndị na-emebi iwu na-aga nʼihu, njehie na-aba ụba nʼetiti ndị a na-achị achị,
\q2 ma ndị ezi omume ga-eguzo hụ ọdịda ha.
\b
\q1 
\v 17 Dọọ nwa gị aka na ntị, ndụ ya ga-enye obi gị udo na ọṅụ.
\q2 Ọ gaghị emekwa ka ihere mee gị.
\b
\q1 
\v 18 Obodo na-adịghị atụ egwu Chineke bụ obodo na-adịghị agazi nʼusoro,
\q2 ma ọṅụ na-adịrị obodo ahụ na-edebe ihe Onyenwe anyị nyere nʼiwu.
\b
\q1 
\v 19 Ọ bụghị naanị okwu ọnụ ka e ji adọ ndị na-eje ozi aka na ntị,
\q2 nʼihi na ha nwere ike ghọta ma ha ga-ajụ ime ihe ị chọrọ.
\b
\q1 
\v 20 Olileanya dịrị onye nzuzu
\q2 karịa onye ahụ na-adịghị echezi echiche tupu o kwuo okwu.
\b
\q1 
\v 21 Ị malite na mbụ na-emezi onye na-ejere gị ozi,
\q2 ọ ga-emesịa chọọ ka i meere ya dịka nwa gị.
\b
\q1 
\v 22 Onye na-ewe iwe na-akpali ọgụ,
\q2 onye na-ewe iwe ọkụ na-eme ọtụtụ mmehie.
\b
\q1 
\v 23 Nganga mmadụ na-eme ka ọ daa,
\q2 ma mmadụ ahụ dị umeala nʼobi ga-eweta nsọpụrụ.
\b
\q1 
\v 24 Ndị ọbụla na-enyere ndị ohi aka bụ ndị iro nke ndụ ha,
\q2 a na-edu ha nʼịṅụ iyi, ma ha adịghị agba akaebe.
\b
\q1 
\v 25 Ịtụ egwu mmadụ bụ ihe ịma nʼọnya,
\q2 ma onye ọbụla na-atụkwasị \nd Onyenwe anyị\nd* obi na-anọ nʼudo.
\b
\q1 
\v 26 Ị chọrọ ikpe ziri ezi?
\q2 Elela onye ikpe anya nʼihu, kama gwa \nd Onyenwe anyị\nd* maka ya.
\b
\q1 
\v 27 Onye ezi omume na-akpọ ajọ omume asị;
\q2 ndị na-emebi iwu na-akpọ onye ndụ ya ziri ezi asị.
\c 30
\ms1 Okwu amamihe nke Agọ
\p 
\v 1 Ndị a bụ okwu Agọ, nwa Jake, onye Masa,
\q1 Okwu si nʼọnụ nwoke a zigaara Itiel na Ukal:
\b
\q1 “Ike agwụla m, Chineke
\q2 ma a pụrụ imeri.
\q1 
\v 2 Nʼezie, abụ m onye nzuzu karịa mmadụ ọbụla;\f + \fr 30:2 \ft Abụ m anụ ọhịa, a bụghị mmadụ.\f*
\q2 Enweghị m ụdị nghọta ahụ mmadụ na-enwe.
\q1 
\v 3 Amụtabeghị m amamihe,
\q2 maọbụ ruo ịmata maka Onye Nsọ ahụ.
\q1 
\v 4 Olee onye na-arịgo nʼeluigwe na-arịdatakwa?
\q2 Onye ka ọ bụ, bụ onye jikọtara ifufe nʼaka ya?
\q1 Onye kwa weere akwa kechikọtaa osimiri niile nʼaka ya?
\q2 Onye hiwere oke nsọtụ ụwa niile? Onye ka ọ bụ?
\q1 Ọ bụrụ na ị ma onye ọ bụ, gịnị bụ aha ya?
\q2 Gịnịkwa bụ aha nwa ya?
\b
\b
\q1 
\v 5 “Okwu ọnụ Chineke niile bụ ihe anụchara anụcha,
\q2 Ọ bụ ọta nye ndị na-agbaba nʼime ya izere ndụ.
\q1 
\v 6 Atụkwasịla ihe ọbụla nʼokwu ya,
\q2 ka ọ ghara ịbara gị mba, ka ị gharakwa ịghọ onye ụgha.
\b
\q1 
\v 7 “O \nd Onyenwe anyị\nd*, naanị ihe abụọ ka m na-arịọ gị tupu m nwụọ;
\q2 ajụkwala imere m ha:
\q1 
\v 8 Nke mbụ, mee ka okwu efu na okwu ụgha dị anya nʼebe m nọ.
\q2 Nke abụọ, e nyela m ọnọdụ ogbenye maọbụ ọnọdụ ọgaranya,
\q2 kama nye m naanị nri ga-ezuru m kwa ụbọchị niile.
\q1 
\v 9 Nʼihi na, ọ bụrụ na m aghọọ ọgaranya, ma eleghị anya, afọ ga-eju m, jubiga m oke,
\q2 ruo na m ga-asị na m achọkwaghị gị ma kwuokwa si, ‘Onye ka \nd Onyenwe anyị\nd* bụ?’
\q1 Ọ bụrụkwa na m adaa ogbenye, ma eleghị anya, aga m ezu ohi,
\q2 site nʼụzọ dị otu a, wetara aha nsọ gị Chineke, ihe ihere.
\b
\q1 
\v 10 “Ekwujọla ohu nʼihu nna ya ukwu,
\q2 ka ọ ghara ịbụ gị ọnụ, ikpe amaa gị.
\b
\q1 
\v 11 “Ọ dị ndị\f + \fr 30:11 \ft Maọbụ, \fqa Ọgbọ\f* na-akọcha nna ha,
\q2 ha adịghị agọzikwa nne ha;
\q1 
\v 12 Ọgbọ ndị dị ọcha nʼanya nke onwe ha
\q2 ma asapụbeghị isisi nʼunyi ha ruru.
\q1 
\v 13 Ọ dị ndị anya ha dị nʼelu,
\q2 ndị ile anya ha jupụtara na nlelị.
\q1 
\v 14 Ndị eze ha niile bụ mma agha
\q2 ịkịrị eze ha bụkwa mma
\q1 maka irichapụ ndị ogbenye site nʼụwa
\q2 na ndị nọ nʼụkọ site nʼetiti mmadụ.
\b
\q1 
\v 15 “Etu nwere ụmụ nwanyị abụọ
\q2 ndị na-eti, ‘Nye, nye.’
\b
\li1 “Ọ dị ụzọ ihe atọ nke afọ na-adịghị eju.
\li2 E, anọ dị na-adịghị asị, ‘O zuola.’
\li3 
\v 16 Ala ili,
\li3 akpanwa nwanyị na-adịghị atụ ime,
\li3 ala nke mmiri na-adịghị eju afọ,
\li3 na ọkụ nke na-adịghị asị, ‘O zuola.’
\b
\q1 
\v 17 “Onye ahụ na-akwa nna ya emo,
\q2 nke na-akpọkwa irubere nne ya isi asị,
\q1 ugolọma ga-atụrụ mkpụrụ anya ya,
\q2 udele ga-erikwa anụ ahụ ya.
\b
\li1 
\v 18 “Ọ dị ihe atọ na-agbagwoju m anya, apụghị m ịghọta ha;
\li2 mbaa, ha dị anọ!
\li3 
\v 19 Otu ugo si efegharị na mbara eluigwe;
\li3 otu agwọ si akpụ nʼelu nkume,
\li3 otu ụgbọ mmiri si achọta ụzọ ya nʼoke osimiri;
\li3 na otu ịhụnanya si eto nʼetiti nwoke na nwaagbọghọ.
\b
\q1 
\v 20 “Nke bụ ụzọ nwanyị na-akwa iko,
\q2 Ọ na-eri ma hichaa ọnụ ya,
\q2 na-asị, ‘E meghị m ajọ ihe ọbụla.’
\b
\li1 
\v 21 “Ọ dị ihe atọ na-eme ka ụwa maa jijiji,
\li2 nʼokpuru ihe anọ nke ọ na-apụghị ịnagide,
\li3 
\v 22 Ohu ghọrọ eze,
\li3 onye nzuzu ihe na-agara nke ọma,
\li3 
\v 23 nwanyị obi ilu mesịrị lụta dị,
\li3 na odibo nwanyị ghọrọ nwunye nna ya ukwu.
\b
\li1 
\v 24 “Ihe anọ dị nke dị nta nʼelu ụwa,
\li2 ma ha maa ihe nke ukwuu.
\li2 
\v 25 Ndanda bụ ndị na-enweghị ume,
\li3 ma ha na-akpakọta nri ha, dozie nke ha ga-eri nʼoge oyi.
\li2 
\v 26 Ewi nkume\f + \fr 30:26 \ft Ewi nkume bụ otu ụdị oke nʼọtụtụ ụzọ oke e nwere. Ha na-ebi nʼigwe nʼugwu. \xt Lev 11:5; Abụ 104:18\xt*\f* bụ ndị na-adịghị ike,
\li3 ma ha na-echebe onwe ha site nʼibi nʼọgba nkume.
\li2 
\v 27 Igurube enweghị eze,
\li3 ma ha na-aga nʼigwe nʼahịrị nʼahịrị.
\li2 
\v 28 Ngwere dị mfe iji aka jide ya,
\li3 ma ị ga-achọta ha ọ bụladị nʼụlọ ndị eze.
\b
\li1 
\v 29 “Ha dị ihe atọ na-ejegharị nʼụwa nʼọnọdụ ịdị oke ebube,
\li2 mbaa, ha dị anọ:
\li3 
\v 30 Ọdụm, eze ụmụ anụmanụ. Ọ naghị atụ onye ọbụla egwu,
\li3 
\v 31 na oke ọkụkọ na-ejegharị ejegharị,
\li3 na mkpi,
\li3 na eze ndị agha ya gbara gburugburu.
\b
\q1 
\v 32 “Ọ bụrụ na i meela ihe nzuzu site nʼifuli onwe gị elu
\q2 maọbụ zube nzube ọjọọ,
\q2 anyala isi nʼihi ya, were aka gị kpuchie ọnụ gị nʼihere.
\q1 
\v 33 A pịaa mmiri ara ehi a na-ewepụta mmanụ ara ehi;
\q2 iti mmadụ aka nʼimi na-akpata ịgba ọbara,
\q2 otu a kwa ikpali iwe na-eweta ise okwu.”
\c 31
\ms1 Okwu eze Lemuel
\p 
\v 1 Ndị a bụ okwu si nʼọnụ Lemuel, eze Masa. Ha bụ okwu ndị ahụ nne eze Lemuel kuziri ya.
\q1 
\v 2 Gee ntị, nwa m, gee ntị, nwa nke afọ m.
\q2 Gee ntị, nwa m, nwa nke ọziza ekpere m niile.
\q1 
\v 3 Enyela ụmụ nwanyị\f + \fr 31:3 \ft Okwu a, ụmụ nwanyị, bụ banyere ọtụtụ ndị inyom bi nʼụlọeze. Onye dere akwụkwọ a, eleghị anya, na-arụtụ aka na ụmụ nwanyị ndị a, pụrụ ime ka uche eze pụọ site nʼihe o kwesiri ime. \xt Est 2:3,8\xt*\f* ike gị,
\q2 enyekwela ịdị ike gị nʼaka ndị nʼala ndị eze nʼiyi.
\b
\q1 
\v 4 Lemuel nwa m, ọ bụghị ihe kwesiri ekwesi na ndị eze ga-aṅụ mmanya.
\q2 O kwesikwaghị ka agụụ ịṅụ mmanya
\q2 bụrụ ihe ga na-agụ ndị eze.
\q1 
\v 5 Ka ha ghara ịṅụbiga mmanya oke si otu a chefuo ikpe ikpe ziri ezi dịka iwu kwuru.
\q2 Ka ha gharakwa isite nʼịṅụbiga mmanya oke napụ ndị a na-emegbu emegbu ikpe ziri ezi ha kwesiri inweta.
\q1 
\v 6 Ndị e kwesiri inye mmanya bụ ndị ahụ na-ala nʼiyi,
\q2 ndị ahụ nọ nʼọnọdụ oke ihe mgbu nke obi.
\q1 
\v 7 Ka ha ṅụọ chefuo ọnọdụ ọjọọ ha,
\q2 ka ha gharakwa icheta ọnọdụ nhụju anya ha.
\b
\q1 
\v 8 Jisie ike kwuchite ọnụ ndị ahụ na-enweghị ike ikwuru ọnụ onwe ha;
\q2 kwuchitekwa ọnụ ndị niile ọnọdụ ha dị ala.
\q1 
\v 9 Kwusie okwu ike, kpeekwa ikpe ziri ezi.
\q2 Gbooro ndị ogbenye na ndị mkpa na-akpa ọgụ site nʼaka ndị na-emegbu ha.
\ms1 Okwu mmechi: Ezi nwanyị nwere agwa ọma
\q1 
\v 10 Nwanyị nwere ugwu\f + \fr 31:10 \ft Maọbụ, \fqa Nwanyị nwere agwa ọma na-ejidekwa onwe ya nʼụzọ kwesiri.\f* onye ga-achọtali ya?
\q2 Ọ dị oke ọnụ karịa nkume rubi.
\q1 
\v 11 Di nwanyị dị otu a na-atụkwasị obi ya niile nʼime ya,
\q2 ọ dịghị ihe dị mkpa nke na-akọ ya.
\q1 
\v 12 Ihe nwanyị dị otu a na-ewetara di ya bụ naanị ihe ọma.
\q2 Ihe ọjọọ ọbụla adịghị esi nʼaka ya abịakwasị di ya ụbọchị niile nke ndụ ya.
\q1 
\v 13 Ọ na-ahọrọ ajị anụ na flakisi
\q2 jiri ya na-arụ ọrụ na-atọ aka ya ụtọ.
\q1 
\v 14 Ọ na-esite nʼebe dị anya na-ebubata ihe oriri nʼụlọ ya
\q2 dịka a ga-asị na ọ bụ ụgbọ mmiri.
\q1 
\v 15 Tupu chi abọzie,
\q2 nwanyị a esitelarị nʼihe ndina bilie kwadooro ezinaụlọ ya ihe oriri,
\q2 ma debekwara odibo ndị inyom na-ejere ya ozi oke ihe oriri nke ha.
\q1 
\v 16 Ọ na-apụ nyochapụta ịdị mma ala ubi, ma zụpụta ya.
\q2 Ọ bụ ego ọ rụpụtara nʼonwe ya ka o ji arụ ọrụ ubi vaịnị.
\q1 
\v 17 Ike ịrụ ọrụ adịghị agwụ ya.
\q2 Ọ dị nnọọ ike, bụrụkwa onye na-arụpụta ihe dị iche iche.
\q1 
\v 18 Ọ na-elezi anya hụ na ihe ahịa o mepụtara dị ezi oke ọnụahịa;
\q2 ọ bụ nke a mere o ji na-arụ ọrụ ruo nʼime ime abalị.
\q1 
\v 19 Nʼọbụaka ya ka o jidere osisi ịtụ ogho akwa;
\q2 mkpịsịaka ya na-ejidesikwa ozele e ji na-ekwe akwa ike.
\q1 
\v 20 Ọ na-agbasapụ aka
\q2 inyere ndị ogbenye na ndị mkpa na-akpa aka.
\q1 
\v 21 Udu mmiri maọbụ oge oke oyi adịghị eche ya uche
\q2 nʼihi na ndị niile nọ nʼezinaụlọ ya nwere uwe ha ga-eji chụọ oyi.
\q1 
\v 22 Ọ na-akpa akwa a na-agbasa nʼelu ihe ndina,
\q2 ma ya onwe ya na-eyikwa uwe e ji ezi akwa ọcha na akwa odo odo\f + \fr 31:22 \ft Nʼoge ochie, naanị ndị ọgaranya na-eyi uwe na-acha odo odo, nʼihi na ọ bụ akwa dị oke ọnụ.\f* dụọ.
\q1 
\v 23 Di ya bụ onye a na-asọpụrụ nʼọnụ ụzọ ama obodo\f + \fr 31:23 \ft Ọnụ ụzọ ama obodo bụ ebe ndị okenye na-ezukọta akparịta ụka. \xt Jen 19:1; Rut 4:1-3\xt*\f*
\q2 ebe ọ na-ewere ọnọdụ nʼetiti ndị okenye nke ala ahụ.
\q1 
\v 24 Ọ na-akpa ma na-adụkwa akwa dị iche iche, ya na ihe ike nʼukwu,
\q2 ndị ọ na-eresi ndị ahịa ndị ọzọ.
\q1 
\v 25 Ọ bụ nwanyị dị ike, onye a na-asọpụrụ asọpụrụ.
\q2 Ụjọ adịghị atụkwa ya maka ihe ga-eme nʼoge dị nʼihu.
\q1 
\v 26 Ọ na-eji amamihe na-ekwu okwu
\q2 ntụziaka kwesiri dịkwa nʼire ya.
\q1 
\v 27 Ọ na-etinye uche nʼihe niile banyere ezinaụlọ ya,
\q2 ọ naghị arụ ọrụ umengwụ.
\q1 
\v 28 Ụmụ ya na-ebili gọzie ya;
\q2 otu a kwa di ya ga-eto ya ezi otuto.
\q1 
\v 29 Ọ ga-asị; “E nwere ọtụtụ ndị inyom ndị bụ ezi nwunye nye di ha,
\q2 ma gị onwe gị kachasị ha niile mma.”
\q1 
\v 30 Ịma mma nke elu ahụ adịghị egosi ihe mmadụ bụ, nʼihi na ịma mma adịghị adịgide ogologo oge.
\q2 Ma nwanyị ọbụla nke na-atụ egwu \nd Onyenwe anyị\nd* bụ onye e kwesiri ito.
\q1 
\v 31 E kwesiri ito ya nʼihi ọrụ ọma niile nke aka ya rụpụtara.
\q2 Ka ọrụ ya niile wetara ya otuto nʼọnụ ụzọ ama nke obodo.
