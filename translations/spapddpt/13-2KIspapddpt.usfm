\p 
\v 13 \w El|strong="H5921"\w* \w año|strong="H8141"\w* 14 \w del|strong="H5921"\w* \w rey|strong="H4428"\w* Ezequías, Senaquerib, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Asiria, \w subió|strong="H5927"\w* \w contra|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w ciudades|strong="H5892"\w* \w fortificadas|strong="H1219"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w* \w y|strong="H5921"\w* \w las|strong="H5921"\w* \w tomó|strong="H5927"\w*.
\v 14 \w Entonces|strong="H7725"\w* Ezequías, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*, \w envió|strong="H7971"\w* \w a|strong="H3068"\w* decir \w al|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Asiria \w en|strong="H5921"\w* Laquis: \w Me|strong="H5921"\w* equivoqué. Retírate \w de|strong="H5921"\w* \w mí|strong="H5921"\w*, \w y|strong="H5921"\w* aceptaré \w lo|strong="H5921"\w* \w que|strong="H5921"\w* \w me|strong="H5921"\w* impongas. \w Y|strong="H3068"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Asiria \w impuso|strong="H7760"\w* \w a|strong="H3068"\w* Ezequías, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*, 9.9 toneladas \w de|strong="H5921"\w* \w plata|strong="H3701"\w* \w y|strong="H5921"\w* 990 kilogramos \w de|strong="H5921"\w* \w oro|strong="H2091"\w*.
\v 15 Ezequías \w entregó|strong="H5414"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w plata|strong="H3701"\w* \w que|strong="H3605"\w* \w había|strong="H4672"\w* en \w la|strong="H3605"\w* \w Casa|strong="H1004"\w* \w de|strong="H5414"\w* \nd \w Yavé|strong="H3068"\w*\nd* y en \w los|strong="H3605"\w* tesoros \w de|strong="H5414"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w real|strong="H4428"\w*.
