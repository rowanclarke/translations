\id ZEP
\h Ṣafanya
\toc1 Ṣafanya
\toc2 Ṣafanya
\toc3 Ṣaf.
\mt1 Ṣafanya
\c 1
\s1 Ass ameqqran n SIDI
\m 
\v 1 Awař n SIDI i dd-yusin i Ṣafanya, mmis n Kuci, mmis n Jadalya, mmis n Amarya, mmis n Ḥizqiya, deg wussan n Yuciya, mmis n Amun, ajeǧid n Yahuda. \f ◼ \fr 1:1 \fk Ṣafanya\ft - isem-a wanita ixs ad yini ‘wenni t issnuffaren SIDI’.\f*
\b
\m 
\v 2 Necc ad kkseɣ qaɛ marra \add min iǧan\add*
\m zeg wudem n temmurt,
\m \add ammu i\add* iqqar SIDI.
\m 
\v 3 Ad kkseɣ bnadem d řmař,
\m ad kkseɣ ijḍaḍ n ujenna
\m d iseřman n řebḥar
\m d tɛenkrifin ak-d iɛeffanen,
\m \add wah\add* Necc ad qḍiɣ bnadem
\m x wudem n temmurt,
\m \add ammu\add* i iqqar SIDI. \x ◘ \xo 1:3 \xt Amz. 6:7\x*
\m 
\v 4 Necc ad sswiẓẓḍeɣ s ufus inu
\m ḍidd i Yahuda
\m u ḍidd i marra imezdaɣ n Urcalim.
\m Necc ad teḥḥiɣ min iqqimen zi Baɛl
\m zeg wemcan-a
\m ak-d yisem n ikehhanen n l’aṣnam, \f ◼ \fr 1:4 \fk ad teḥḥiɣ\ft - s Tɛibranit ‘ad qeḍɛeɣ’.\f*
\m 
\v 5 d yinni isejden x tzeɣwin
\m zzat i řɛeskar n ijenwan,
\m u inni, am bendqen, jjuǧen ɣar SIDI,
\m u \add aqa\add* jjuǧen i Malkam,
\m 
\v 6 uřa d yinni dd-ittɛaqqaben
\m zi ḍeffar n SIDI,
\m u yinni war arezzun x SIDI
\m u war xas ttsseqsin. \x ◘ \xo 1:6 \xt Ica. 1:4; 59:13; Irm. 15:6\x*
\b
\m 
\v 7 Seɣd zzat i wudem n Sidi inu, SIDI,
\m maɣar ass n SIDI yudes.
\m SIDI aqa issewjed ict n tɣarṣt,
\m Netta issqeddes imeɛraḍen nnes.
\m 
\v 8 Ad imsar deg wass n tɣarṣt n SIDI,
\m aqa Necc ad ɛaqbeɣ řḥukkam
\m d iḥenjiren n ujeǧid
\m d marra inni yarrḍen arruḍ aɣrib.
\m 
\v 9 \bdit Deg wass nni\bdit* ad ɛaqbeɣ
\m marra inni ineggzen tanebdat,
\m inni ittɛemmaren taddart n siditsen
\m s lɛunf d řɣecc.
\b
\m 
\v 10 Deg wass nni, iqqar SIDI,
\m ad \add din\add* yiři ijj n řḥess n iɣuyyan
\m zi Tewwart n Iseřman,
\m uřa d \add řḥess n\add* yinni ittrun
\m zi tendint n jdid
\m d ict n tareẓẓit temɣar zi tewririn.
\m 
\v 11 Rum, imezdaɣ \add n jjihet\add* n Umehraz,
\m minzi marra isebbabben ttwaseɣḍen,
\m marra inni iwezznen tmenyat ttwaqeḍɛen.
\m 
\v 12 Di řweqt nni ad beqqceɣ
\m di Urcalim s řeqnadeř,
\m u Necc ad ɛaqbeɣ iryazen
\m inni ittwagdaren zi řatar
\m nni iqqimen n binu,
\m inni iqqaren deg wuř nsen:
\m ‘SIDI war ittegg řxar
\m u war ittegg řɣar!’
\m 
\v 13 Agřa nsen ad yiři i tkeccaḍt
\m d tudrin nsen ad dewřent d řxarbet.
\m Nitni ad bnan tudrin i yixef nsen,
\m \add maca\add* war daysent zeddɣen ca,
\m nitni ad ẓẓun tizayarin,
\m \add maca\add* war sessen zi binu nnes.
\b
\m 
\v 14 Ass ameqqran n SIDI yudes,
\m aqa-t yudes, deɣya yusa-dd.
\m Řḥess n wass n SIDI!
\m Ad isɣuy bu-teɣruḍt din
\m s yict n tɣuyyit tarzeg. \x ◘ \xo 1:14 \xt Yuw. 2:10, 31; 3:15; Ica. 13:6-13; 24:23; Am. 8:9; Mt. 24:29; Řex. 2:20; Asa. 6:12-13\x*
\m 
\v 15 Ass nni \add ad yiři\add*
\m d ass n uduqqez \add n ufugem\add*,
\m d ass n řeḥṣaret d ḍḍiqa,
\m d ass n uxarreb d wareddeǧ,
\m d ass n ṭṭřam d taǧest,
\m d ass n iseynuten d useynu ibbumbes,
\m 
\v 16 ijj n wass n usuḍi deg uyicc n icarri
\m u n iɣuyyan \add n umenɣi\add*
\m ḍidd i tneddam ifaryen
\m u ḍidd i ṣṣumɛat nni \add iǧan\add*
\m ɣar tɣemmura.
\b
\m 
\v 17 Necc ad ḥṣareɣ iwdan
\m u nitni ad uyuren am yidarɣařen,
\m minzi nitni ggin ddenb x SIDI.
\m Idammen nsen ad ttwazeǧɛen
\m amecnaw tɛejjajt,
\m d weysum nsen amecnaw ixxan.
\m 
\v 18 Uřa d nnuqart nsen d wureɣ nsen
\m war zemmaren ad ten ssnejmen
\m deg wass n uduqqez \add n ufugem\add* n SIDI.
\m Timessi n tusmi nnes \add iqeddsen\add*
\m ad tecc marra tammurt,
\m maɣar deɣya Netta ad iqḍa
\m marra imezdaɣ n temmurt. \x ◘ \xo 1:18 \xt Awřn. 11:4; Ḥiz. 7:19; Ṣaf.1:14-16\x*
\b
\b
\c 2
\s1 Řḥukm x řɛedyan n Yahuda
\m 
\v 1 Sdewřem-dd ixef nwem ɣar řeɛqeř,
\m dewřem-dd ɣar řeɛqeř,
\m \add a\add* řgens břa aseḍḥi,
\m 
\v 2 qbeř i ɣa iffeɣ řḥukm
\m - ass am uřum iɛeddu -
\m qbeř i xawem dd ɣa yas
\m řḥaduq n weɣḍab n SIDI,
\m qbeř i xawem dd ɣa yas
\m wass n weɣḍab n SIDI.
\m 
\v 3 Arzum x SIDI,
\m marra imwaḍɛen n temmurt,
\m inni itteggen řḥeqq nnes!
\m Arzum tasegda, arzum awaḍeɛ,
\m ad taɣ ad tennuffarem kenniw
\m deg wass n weɣḍab n SIDI. \x ◘ \xo 2:3 \xt Izhd. 27:5; 32:6, 7\x*
\b
\m 
\v 4 Maɣar Ɣazza ad tᵉttwajj,
\m Acqalun \add ad tedweř\add*
\m d ict n temmurt ittwareddǧen,
\m Acdud ad xas azzřen
\m ɣar wezyen n wass,
\m uca Ɛaqrun ad tᵉttwaqřeɛ.
\m 
\v 5 Uct x imezdaɣ n tma n řebḥar,
\m řgens n Ikaritiyyen.
\m Awař n SIDI ad xawem yiři,
\m \add a\add* Kenɛan, tammurt n Ifilisṭiniyyen!
\m Necc ad kenniw hellkeɣ,
\m war ittiři umezduɣ ɛad.
\m 
\v 6 \add Tammurt nni x\add* tma n řebḥar
\m ad tiři d ddmani n tarewsa,
\m uřa d wanuten i imeksawen
\m d řkurit \add i wuǧi\add*.
\m 
\v 7 Ad tiři temmurt i min iqqimen
\m n taddart n Yahuda,
\m ḥima ad dayes arewsen \add tiḥimriwin nsen\add*.
\m Di tudrin n Acqalun
\m ad din arsen ɣar tmeddit,
\m maɣar SIDI, AREBBI nsen,
\m ad ɣarsen yarzef,
\m u Netta issneqřeb tameḥbast nsen.
\b
\m 
\v 8 Necc sřiɣ i useḥqar n Mu’ab
\m d uceqqef n ayt n Ɛammun,
\m i zi ssḥeqaren nitni řgens inu,
\m u ssgeɛɛden ixef nsen aṭṭas
\m ḍidd i temmurt nsen.
\m 
\v 9 S uya, s tidett am ddareɣ Necc,
\m iqqar SIDI n řɛeskarat,
\m AREBBI n Israil:
\m Mu’ab ad tedweř am Sadum,
\m u ayt n Mu’ab am Ɛamurra,
\m zi ssibbet n uɣemmuy n tzeggʷart
\m u zi ssibbet n wanu\add ten\add* n tmeǧaḥt,
\m ict n temmurt ittwareddǧen i řebda.
\m Min iqqimen n řgens inu
\m ad ten ikecceḍ
\m u inni iqqimen n řgens inu
\m ad ṭṭfen tasɣart nsen d řwart.
\m 
\v 10 Aya \add ad\add* ten \add iřqef\add*
\m zi ssibbet n nnfaxet nsen,
\m maɣar nitni tuɣa sseḥqaren
\m u arzmen aqemmum nsen
\m x řgens n SIDI n řɛeskarat.
\b
\m 
\v 11 Issaggʷad ad ɣarsen iffeɣ SIDI,
\m maɣar Netta ad iqḍa
\m x marra irebbiten zi temmurt,
\m u nitni ad as bendqen,
\m kuř ijj zeg wemcan nnes,
\m marra tigzirin n řegnus.
\b
\m 
\v 12 Kenniw ɛawed, \add a\add* ayt n Kuc,
\m ttwassnuqqben nitni zi ssif inu.
\m 
\v 13 Netta ad isswiẓẓeḍ
\m s ufus nnes ɣar ccamal,
\m Netta ad yareddeǧ Accur,
\m u ad yarr Ninwa
\m d ict n temmurt ittwareddǧen,
\m tuẓeɣ am řexřa.
\m 
\v 14 Di řwesṭ nnes ad geyyrent tḥimriwin,
\m marra řmař nnes, aqa tteggen
\m am yijj \add ubarru n\add* n řgens.
\m Uřa d bu-iɛuqqan,
\m \add wah\add* uřa d twuct n ǧiřet
\m ad ssensen x izeǧifen n ipilaren nnes.
\m Tmijja \add nsen\add* ad tɣennej zi řkazi,
\m areddeǧ ad yiři x tnebdat nnes,
\m maɣar tafrewt n tengelt tᵉttwaɛarra.
\m 
\v 15 D ta d tandint isřiwřiwen,
\m tenni iqqimen di řaman,
\m tenni innan deg wuř nnes:
\m ‘Necc \add d tenni\add*, war teǧi d tenneɣni!’
\m Mammec tedweř
\m d \add ict n řqecɛet n\add* unexřiɛ,
\m ict n wemcan n arraḥet i řmař n řexřa!
\m Marra inni xas ɣa ikken,
\m ad \add xasen\add* iṣeffar \add u\add* s useḥqar
\m ad issenhezz afus nnes.
\b
\b
\c 3
\s1 Řḥukm x Urcalim d řegnus
\m 
\v 1 Uct xam, tenni iɣewwɣen
\m d yarṣuḍen,
\m tandint n ddeǧ!
\m 
\v 2 Nettat war tᵉttesři
\m ɣar \add uřa d ict n\add* tmijja,
\m War tqebbeř aweddeb,
\m nettat war tᵉttciř x SIDI,
\m nettat war tᵉttqarrab ca
\m ɣar AREBBI nnes.
\b
\m 
\v 3 Řḥukkam nnes di řwesṭ nnes
\m d ayraden ittarrujduden,
\m řquḍat nnes d uccanen n ǧiřet,
\m inni war ittejjin walu ař tuffut. \x ◘ \xo 3:3 \xt Awřn. 28:15; Ḥiz. 22:27\x*
\m 
\v 4 Inabiyyen nnes daysen řefcuc,
\m nitni d iryazen ixeddaɛen!
\m Ikehhanen nnes ssfesden
\m Zzawect Iqeddsen,
\m nitni xalfen Ccariɛa. \x ◘ \xo 3:4 \xt Irm. 23:11, 32; Ḥuc. 9:7\x*
\b
\m 
\v 5 SIDI amsegged \add aqa-t\add* di řwest nnes.
\m Netta war ittegg ca min war iseggden.
\m Kuř tuffut ittarra řḥeqq nnes ɣar tfawt,
\m ɛemmarṣ war tneqqeṣ!
\m \add Maca\add* wenni itteggen min war iseggden,
\m war issin ca aseḍḥi. \x ◘ \xo 3:5 \xt Aɛwd. 32:4\x*
\b
\m 
\v 6 Necc qḍiɣ řegnus,
\m areddǧeɣ ṣṣumɛat nsen n tɣemmura.
\m Necc xřiɣ i tbridin nnes,
\m ařami uřa d ijjen war iqqim ɛad
\m ittsara dinni.
\m Tineddam nsen ttwareddǧent,
\m war iqqim ḥed,
\m uřa d ijj n umezduɣ.
\m 
\v 7 Necc nniɣ: Ittxeṣṣa cem
\m ad ayi teggʷeded,
\m ad teksid aweddeb!,
\m ḥima war tᵉttwakkes Tzeddiɣt nnes,
\m \add s\add* marra min d as ɣa ggeɣ.
\m S tidett, nitni ɣewwɣen zic,
\m maḥend ad ssfeḍḥen
\m timegga nsen ař ṭṭarf.
\b
\m 
\v 8 S uya rajam ayi, iqqar SIDI,
\m ass i di dd ɣa kkareɣ i tkeccaḍt.
\m Minzi aya d řḥukm inu \add iseggden\add*
\m aqa ad jarweɣ řegnus,
\m ad ssmuneɣ tigeldin,
\m ḥima ad xasen ssfesyeɣ asxeḍ inu,
\m marra řḥaduq n weɣḍab inu,
\m maɣar s tmessi n tusmi inu \add iqeddsen\add*
\m ad tᵉttwacc marra tammurt.
\b
\s1 Ttubet n řegnus
\m 
\v 9 Minzi xenni Necc ad beddřeɣ
\m \add řḥard\add* n řegnus
\m iyencicen imezdagen \add ad ten wceɣ\add*,
\m ařami i ɣa řaɣan x Yisem n SIDI,
\m ḥima ad t ɛebbden \add am s\add* yict n teɣruḍt.
\m 
\v 10 Zeg ujemmaḍ n iɣezran n Kuc,
\m inni xafi ittẓaǧan,
\m yeǧis n immṭarrcen inu,
\m ad \add tt\add* awyen nitni \add amecnaw\add* tewhibt inu. \x ◘ \xo 3:10 \xt Ica. 66:20\x*
\m 
\v 11 \bdit Deg wass nni\bdit* war tseḍḥid ca \add ɛad\add*,
\m x marra timegga i zi xafi tɣewwɣed,
\m minzi ad kkseɣ zi řwesṭ nnem
\m inni ittfeyycen di nnfaxet,
\m u kenniw war tessgeɛɛadem ɛad ixef nwem
\m x wedrar inu Iqeddsen.
\m 
\v 12 Necc ad jjeɣ di řwesṭ nnem
\m ijj n řgens ittwaḥṣar, iẓeřḍ.
\m Nitni ad arewřen ɣar Yisem n SIDI.
\m 
\v 13 Min iqqimen n Israil
\m war ittegg min war iseggden,
\m nitni war ssxarriqen ca,
\m u deg uqemmum nsen
\m war ittᵉttwifi yiřes issxarriqen,
\m maca nitni ad heddan ad zzřen,
\m u uřa d ijjen ad ten issnexřiɛ.
\b
\s1 Řefraḥet n Israil d weɛdař nnes
\m 
\v 14 Ɣennej, \add a\add* yeǧis n Ṣihyun,
\m sřiwřew, \add a\add* Israil.
\m Farḥ u tfaǧid s marra uř nnem,
\m \add a,\add* yeǧis n Urcalim! \x ◘ \xo 3:14 \xt Zak. 9:9\x*
\m 
\v 15 SIDI ikkes řeḥkamat nnem,
\m Netta aqa imḥa řeɛdu nnem.
\m Ajeǧid n Israil,
\m SIDI, aqa-t di řwesṭ nnem!
\m War tẓarred ɛad řɣar.
\m 
\v 16 \bdit Deg wass nni\bdit* ad inin i Urcalim:
\m War tteggʷed ca, Ṣihyun!
\m War ttejji ifassen nnem
\m ad arxun ɛemmarṣ \add ɛad\add*!
\m 
\v 17 SIDI, AREBBI nnem, aqa-t di řwest nnem,
\m Bu-teɣruḍt nni i dd ɣa yawyen asenjem
\m Netta ad zzayem ifarḥ s waṭṭas,
\m Netta ad iseɣḍ di tayri nnes,
\m Netta ad xam isřiwřew s uɣennej.’
\b
\m 
\v 18 Necc ad ssmuneɣ inni iceṭṭnen
\m \add umi war zemmaren ad carcen\add*
\m \add di\add* tmesmunt ittwaggen \add i řɛid\add*.
\m Aqa nitni zzayem!
\m Ddqeř n řḥegra aqa-t xas.
\m 
\v 19 Xzar, Necc ad ceɣřeɣ ixef inu
\m ak-d yinni cem iḥṣaren.
\m Necc ad ssnejmeɣ iqejdaḥen
\m u yinni ittwassuffɣen ad ten ssmuneɣ.
\m Necc ad asen wceɣ řɛezz
\m d yijj n isem icennɛen,
\m di marra ddunect
\m nni ten tuɣa issfeṭṭḥen.
\m 
\v 20 Di řweqt nni ad kenniw dd-arreɣ,
\m u di řweqt nni ad kenniw ssmuneɣ,
\m Necc ad awem wceɣ
\m ijj n yisem \add icennɛen\add* d řɛezz
\m jar marra řegnus n ddunect,
\m xmi i zzaywem ɣa ssenqeřbeɣ
\m tameḥbast nwem
\m zzat i tiṭṭawin nwem,
\m inna SIDI. 
