\id HEB  
\h HepelŇę 
\toc1 Ko E Tohi  Ľa Paula Ki He Kakai HepelŇę 
\toc2 HepelŇę 
\toc3 Hep 
\mt2 KO E TOHI  ĽA PAULA KO E  ĽAPOSETOLO  
\mt3 KI HE KAKAI  
\mt1 HEPELŇ™  
\cl KO E VAHE  
\c 1  
\cd \it 1 Kuo hńĀ Ľele mai  Ľa Kalaisi mei he Tamai kiate kitautolu  Ľi he kuonga ki mui ni, 4  Ľoku mu Ľa ia  Ľi he kau  ĽńĀngelo,  Ľi he anga mo e ngńĀue.\it*  
\p
\v 1 Ko e  ĽOtua,  Ľaia na Ľe folofola  Ľi mu Ľa  Ľi he ngaahi kuonga kehekehe mo e ngaahi anga kehekehe ki he ngaahi tamai  Ľi he kau palŇćfita,  
\v 2 Kuo ne folofola  Ľi he ngaahi  Ľaho ki mui ni kiate kitautolu  Ľi \add hono \add* ĽAlo,  Ľaia kuo ne tu Ľutu Ľuni ke  Ľa Ľana  Ľae ngaahi me Ľa kotoa pńď,  Ľaia ne ne ngaohi ai foki  Ľae ngaahi maama;  
\v 3 Ko e malama ia  Ľo \add hono \add*nńĀunau, mo e tatau  Ľaupito  Ľo  Ľene  Ľafio, pea  Ľoku ne poupou hake  Ľae me Ľa kotoa pńď  Ľaki  Ľene folofola mńĀlohi, pea kuo hili  Ľene fai  Ľe ia  Ľae totongi  Ľi he Ľetau ngaahi angahala, pea nofo hifo ia  Ľi he nima to Ľomata Ľu  Ľoe Fungani MńĀ Ľolunga;  
\v 4 Pea kuo mńĀ Ľolunga lahi  Ľaupito ia  Ľi he kau  ĽńĀngelo, koe me Ľa  Ľi he Ľene ma Ľu totonu  Ľae huafa lelei lahi  Ľiate kinautolu.  
\v 5 He na Ľe pehńď  Ľe ia  Ľanefńď ki ha  ĽńĀngelo fńď,  
\q1 ‚ÄúKo hoku  ĽAlo koe,  
\q2 kuo u fakatupu koe  Ľi he  Ľaho ni?‚ÄĚ  
\p Pea toe pehńď,  
\q1 ‚ÄúTe u hoko au ko e Tamai kiate ia,  
\q2 pea  Ľe hoko ia ko e  ĽAlo kiate au?‚ÄĚ   
\p
\v 6 Pea  Ľi he  Ľomi  Ľe ia  Ľae  Ľuluaki fakatupu ki mńĀmani, na Ľe toe pehńď  Ľe ia, ‚ÄúKe hŇę kiate ia  Ľae kau  ĽńĀngelo kotoa pńď  Ľae  ĽOtua.‚ÄĚ  
\v 7 Pea ki he kau  ĽńĀngelo  Ľoku pehńď  Ľe ia,  
\q1 ‚Äú ĽOku ne ngaohi  Ľene kau  ĽńĀngelo \add ke hangńď \add*ko e matangi,  
\q2 mo  Ľene kautauhi \add ke hangńď \add*ko e ulo afi.‚ÄĚ   
\p
\v 8 Ka ki he  ĽAlo, \add  Ľoku ne pehńď\add*,  
\q1 ‚ÄúE  ĽOtua, ko ho nofo Ľanga  Ľoku lauikuonga pea ta Ľengata:  
\q2 ko e tokotoko  Ľo ho pule Ľanga ko e tokotoko mńĀ Ľoni Ľoni ia.   
\q1
\v 9 Kuo ke  Ľofa ki he mńĀ Ľoni Ľoni, pea fehi Ľa ki he angahala;  
\q2 ko ia ko e  ĽOtua, ko ho  ĽOtua, kuo ne tńĀkai  Ľaki koe  Ľae lolo  Ľoe fiefia  Ľo lahi hake  Ľi ho kńĀinga.‚ÄĚ   
\p
\v 10 Pea,  
\q1 ‚ÄúKo koe,  Ľe  ĽEiki, na Ľa ke  Ľai  Ľi he kamata Ľanga  Ľae tu Ľunga  Ľo mńĀmani;  
\q2 pea koe ngaahi langi ko e ngaue ia  Ľa ho nima:   
\q1
\v 11 E  Ľauha ia; ka  Ľe pehńď ai pe  Ľa koe;  
\q2  Ľe faka Ľa Ľau ia kotoa pńď ke motu Ľa  Ľo hangńď ko e kofu;   
\q1
\v 12 Pea hangńď ko e pulupulu te ke takatakai ia,  
\q2 pea  Ľe fakakehe ia:  
\q1 ka  Ľe pehńď ai pe  Ľa koe,  
\q2 pea  Ľe  Ľikai ngata  Ľa ho ngaahi ta Ľu.‚ÄĚ   
\p
\v 13 Ka na Ľe pehńď  Ľe ia  Ľanefńď ki ha  ĽńĀngelo fńď,  
\q1 ‚ÄúNofo koe  Ľi hoku nima to Ľomata Ľu,  
\q2 kae Ľoua ke u ngaohi ho ngaahi fili ko ho tu Ľunga va Ľe?‚ÄĚ   
\p
\v 14 ‚ÄĆ ĽIkai ko e kau laumńĀlie tauhi pe  Ľakinautolu kotoa pńď,  Ľoku fekaua ke tauhi Ľi  Ľakinautolu  Ľe ma Ľu  Ľae fakamo Ľui;   
\c 2  
\cd \it 1  ĽOku totonu  Ľetau talangofua kia Kalaisi Sisu, 5 Pea koe Ľuhi kuo ne to Ľo kiate ia  Ľetau anga, 14 He ko e me Ľa ia na Ľe tonu ke ne fai.\it*  
\p
\v 1 Ko e me Ľa ia  Ľoku totonu ke  ĽńĀsili ai  Ľetau tokanga lahi ki he ngaahi me Ľa kuo tau fanongo ki ai, telia na Ľa tau tukuange mei ai  Ľi ha  Ľaho.  
\v 2 He kapau na Ľe tu Ľuma Ľu  Ľae lea na Ľe lea Ľaki  Ľe he kau  ĽńĀngelo, pea ko e maumau Ľi mo e talangata Ľa kotoa pńď na Ľe ma Ľu hono totongi totonu;  
\v 3 E hao fńďfńď  Ľakitautolu,  Ľo kapau te tau ta Ľetokanga ki he fakamo Ľui lahi ko ia?  ĽAia na Ľe fuofua fakahńĀ  Ľe he  ĽEiki, pea na Ľe fakamo Ľoni ia kiate kitautolu  Ľekinautolu na Ľe fanongo \add kiate ia\add*;  
\v 4 Na Ľe fakamo Ľoni foki  Ľe he  ĽOtua,  Ľaki  Ľae ngaahi faka Ľilonga, mo e ngaahi me Ľa fakaofo, mo e ngaahi mana kehekehe, pea mo e ngaahi foaki  Ľoe LaumńĀlie MńĀ Ľoni Ľoni,  Ľo fakatatau ki hono finangalo  Ľo Ľona.  
\v 5 He  Ľoku  Ľikai te ne fakamo Ľulaloa ki he kau  ĽńĀngelo  Ľae maama kaha Ľu,  Ľaia  Ľoku mau lea ki ai.  
\v 6 Ka  Ľoku fakahńĀ  Ľe ha tokotaha  Ľi he potu  Ľe taha,  Ľo pehńď, ‚ÄúKo e hńĀ  Ľae tangata,  Ľoku ke tokanga Ľi ia? Pe ko e foha  Ľoe tangata,  Ľoku ke  Ľa Ľahi ai kiate ia?  
\v 7 Na Ľa ke ngaohi ia  Ľo mńĀ Ľulalo si Ľi  Ľi he kau  ĽńĀngelo; ne ke fakapale  Ľaki ia  Ľae nńĀunau mo e ongoongolelei,  Ľo fakanofo ia ke pule Ľi  Ľae ngaahi ngaue  Ľa ho nima:  
\v 8 Kuo ke fakamo Ľulaloa  Ľae me Ľa kotoa pńď ki hono lalo va Ľe.‚ÄĚ Pea  Ľi he Ľene ‚Äúfakamo Ľulaloa  Ľae me Ľa kotoa pńď kiate ia,‚ÄĚ na Ľe  Ľikai fakatoe ha me Ľa  Ľe ta Ľe Ľaikilalo  Ľiate ia. Ka  Ľoku te Ľeki ai ketau mamata kuo fakamo Ľulaloa  Ľae me Ľa kotoa pńď kiate ia.  
\v 9 Ka  Ľoku tau mamata kia Sisu, kuo fakapale  Ľaki ia  Ľae nńĀunau mo e ongoongolelei, koe Ľuhi ko e kńĀtaki  Ľae pekia,  Ľaia na Ľe ngaohi ke mńĀ Ľulalo si Ľi  Ľi he kau  ĽńĀngelo, ke ne kamata  Ľe ia  Ľae pekia koe Ľuhi ko e kakai kotoa pńď, ko e me Ľa  Ľi he  Ľalo Ľofa  Ľae  ĽOtua.  
\v 10 He na Ľe taau mo ia,  Ľaia  Ľoku ma Ľana  Ľae me Ľa kotoa pńď, pea  Ľoku mei ai  Ľae me Ľa kotoa pńď,  Ľi he  Ľomi  Ľae foha tokolahi ki he nńĀunau, ke fakahaohaoa  Ľi he ngaahi mamahi  Ľae  ĽEiki  Ľo  Ľenau mo Ľui.  
\v 11 He ko ia  Ľoku ne fakama Ľa, mo kinautolu kuo fakama Ľa,  Ľoku nau taha pe kotoa pńď: ko ia  Ľoku  Ľikai ai ke mńĀ ia ke ui  Ľakinautolu ko e kńĀinga,  
\v 12 ‚ÄĆ ĽO pehńď, ‚ÄúTe u fakahńĀ ho huafa ki hoku kńĀinga,  Ľi he lotolotonga  Ľoe siasi te u hiva fakafeta Ľi kiate koe.‚ÄĚ  
\v 13 Mo toe \add pehńď\add*, ‚ÄúTe u falala kiate ia.‚ÄĚ Pea toe \add pehńď\add*, ‚ÄúVakai ko au mo e fńĀnau kuo foaki  Ľe he  ĽOtua kiate au.‚ÄĚ  
\v 14 Pea ko e me Ľa  Ľi he ma Ľu  Ľe he fńĀnau  Ľae kakano mo e toto, na Ľe  Ľai foki  Ľe ia  Ľae anga ko ia; koe Ľuhi ke faka Ľauha  Ľe ia  Ľi he mate  Ľaia na Ľe  Ľa Ľana  Ľae mńĀlohi  Ľoe mate, ko e tńďvolo;  
\v 15 Mo fakamo Ľui  Ľakinautolu na Ľe mo Ľua pŇćpula  Ľi he manavahńď ki he mate,  Ľi henau mo Ľui kotoa pńď.  
\v 16 He ko e mo Ľoni na Ľe  Ľikai puke  Ľe ia  Ľae kau  ĽńĀngelo; ka na Ľa ne puke  Ľe ia  Ľae hako  Ľo  ĽEpalahame.  
\v 17 Ko ia na Ľe taau ai mo ia ke hoko  Ľo tatau mo hono kńĀinga  Ľi he me Ľa kotoa pńď, koe Ľuhi ke ne hoko ko e fungani taula Ľeiki  Ľalo Ľofa mo angatonu  Ľi he ngaahi me Ľa  Ľae  ĽOtua, ke fai  Ľae fakalelei koe Ľuhi ko e angahala  Ľae kakai.  
\v 18 He ko e me Ľa  Ľi he Ľene mamahi  Ľa Ľana  Ľi hono  Ľahi Ľahi Ľi,  Ľoku ne fa Ľa fai ke tokoni Ľi  Ľakinautolu  Ľoku  Ľahi Ľahi Ľi.   
\c 3  
\cd \it 1  ĽOku lelei pea lahi  Ľa Kalaisi kia MŇćsese, 7 Ko ia kapau  Ľe  Ľikai te tau tui kiate ia,  Ľe totonu ke lahi hake hotau tautea  Ľi he tautea na Ľe hoko ki  ĽIsileli loto fefeka.\it*  
\p
\v 1 Ko ia,  Ľe kńĀinga mńĀ Ľoni Ľoni,  Ľoku kau  Ľi he ui mei he langi, tokanga lahi ki he  Ľaposetolo mo e fungani taula Ľeiki  Ľo  Ľetau lotu, ko Kalaisi Sisu;  
\v 2 ‚ÄĆ ĽAia na Ľe angatonu kiate ia ne ne fakanofo ia,  Ľo hangńď foki ko MŇćsese  Ľi hono fale kotoa pńď.  
\v 3 He na Ľe totonu ke ne ma Ľu  Ľe ia  Ľae ongoongolelei lahi  Ľia MŇćsese,  Ľo hangńď  Ľoku ma Ľu  Ľe ia  Ľoku langa  Ľae fale  Ľae ongoongolelei lahi  Ľi he fale.  
\v 4 He kuo langa kotoa pńď  Ľae fale  Ľe ha taha; ka ko ia kuo ne langa  Ľae ngaahi me Ľa kotoa pńď ko e  ĽOtua.  
\v 5 Pea na Ľe angatonu mo Ľoni  Ľa MŇćsese  Ľi hono fale kotoa pńď,  Ľo hangńď ko e tamaio Ľeiki, ko e fakamo Ľoni  Ľoe ngaahi me Ľa ko ia  Ľe lea Ľaki;  
\v 6 Ka ko Kalaisi ko e  ĽAlo ia  Ľi hono fale  Ľo Ľona; pea ko hono fale  Ľakitautolu,  Ľo kapau te tau kuku ma Ľu  Ľae tui mo e fiefia  Ľoe  Ľamanaki lelei  Ľo a Ľu ki he iku Ľanga.  
\v 7 Ko ia ( Ľo hangńď ko e lea  Ľae LaumńĀlie MńĀ Ľoni Ľoni, ‚ÄúKo e  Ľaho ni,  Ľo kapau te mou fanongo ki hono le Ľo,  
\v 8 ‚ÄĆ ĽOua na Ľa mou fakafefeka homou loto,  Ľo hangńď ko ia  Ľi he fakahouhau  Ľi he  Ľaho  Ľoe  Ľahi Ľahi  Ľi he toafa:  
\v 9 ‚ÄĆ ĽAia na Ľe  Ľahi Ľahi Ľi au  Ľe ho Ľomou ngaahi tamai, pea nau  Ľahi Ľahi kiate au,  Ľonau mamata ki he Ľeku ngaahi ngaue  Ľi he ta Ľu  Ľe fńĀngofulu.  
\v 10 Ko ia ne u fehi Ľa ai ki he to Ľutangata ko ia, peau pehńď, ‚Äė ĽOku nau he ma Ľuaipńď  Ľi honau loto: pea  Ľoku  Ľikai te nau  Ľilo hoku ngaahi hala.‚Äô  
\v 11 Ko ia ne u fuakava ai  Ľi he Ľeku houhau, ‚ÄėE  Ľikai te nau hŇę ki hoku mńĀlŇćlŇć Ľanga.)‚Äô‚ÄĚ  
\v 12 Tokanga,  Ľe kńĀinga, telia na Ľa ai hamou tokotaha ha loto kovi  Ľo ta Ľetui, he mavahe mei he  ĽOtua mo Ľui.  
\v 13 Ka ke feakonaki Ľaki  Ľakimoutolu  Ľi he  Ľaho kotoa pńď,  Ľoku lolotonga hono ui, ‚ÄúKo e  Ľaho ni;‚ÄĚ telia na Ľa mataila hamou tokotaha  Ľi he fakakńĀkaa Ľi  Ľe he angahala.  
\v 14 He kuo ma Ľu  Ľekitautolu  Ľa Kalaisi,  Ľo kapau te tau kuku ma Ľu  Ľa  Ľetau fuofua tui  Ľo a Ľu ki he iku Ľanga;  
\v 15 Pea lolotonga  Ľoku pehńď, ‚ÄúKo e  Ľaho ni,  Ľo kapau te mou fanongo ki hono le Ľo,  Ľoua na Ľa fakafefeka homou loto,  Ľo hangńď ko ia  Ľi he fakahouhau.‚ÄĚ  
\v 16 He ko hai na Ľe fakahouhau  Ľi he hili  Ľenau fanongo?  ĽIkai ko kinautolu kotoa pńď na Ľe ha Ľu mei  ĽIsipite ia MŇćsese?  
\v 17 Ka ko hai ne houhau ai ia  Ľi he ta Ľu  Ľe fńĀngofulu?  ĽIkai ko kinautolu na Ľe angahala, pea tŇć honau  Ľanga Ľanga  Ľi he toafa?  
\v 18 Pea na Ľe fuakava ia kia hai ‚Äú Ľe  Ľikai te nau hŇę ki hono mńĀlŇćlŇć Ľanga,‚ÄĚ ka kiate kinautolu pe na Ľe ta Ľetui?  
\v 19 Ko ia  Ľoku tau  Ľilo, na Ľe  Ľikai fa Ľa hŇę atu  Ľakinautolu ko e me Ľa  Ľi he ta Ľetui.   
\c 4  
\cd \it 1 Ko e mńĀlŇćlŇć Ľanga  Ľoe Kalisitiane  Ľoku lava Ľi  Ľi he tui, 12 Ko e mńĀlohi  Ľoe folofola  Ľae  ĽOtua. 14 Na Ľe ongo Ľi  Ľe Sisu  Ľae ngaahi mamahi, ka na Ľe  Ľikai  Ľiate ia  Ľae angahala, 16 Ko ia pe te tau  Ľalu atu ai ki he nofo Ľanga  Ľoe  Ľalo Ľofa.\it*  
\p
\v 1 Ko ia ketau manavahńď, telia,  Ľi he tuku mai  Ľae tala Ľofa  Ľoe hŇę ki hono mńĀlŇćlŇć Ľanga,  Ľe ai hamou tokotaha  Ľe tomui ki ai.  
\v 2 He kuo fakahńĀ  Ľae ongoongolelei kiate kitautolu,  Ľo hangńď ko kinautolu: ka ko e fanongo ki he folofola na Ľe  Ľikai  Ľaonga kiate kinautolu, ko e  Ľikai ke felingi Ľaki ia  Ľae tui  Ľekinautolu na Ľe fanongo.  
\v 3 He ko kitautolu  Ľoku tui kuo tau hŇę ki he mńĀlŇćlŇć Ľanga,  Ľo hangńď ko  Ľene folofola, ‚ÄúKuo u fuakava  Ľi he Ľeku houhau, E  Ľikai te nau hŇę ki hoku mńĀlŇćlŇć Ľanga:‚ÄĚ ka kuo faka Ľosi  Ľae ngaahi ngaue talu  Ľae fakatupu  Ľo mńĀmani.  
\v 4 He na Ľe lea pehńď  Ľe ia  Ľi he potu  Ľe taha ki hono fitu  Ľoe  Ľaho, ‚ÄúPea na Ľe mńĀlŇćlŇć  Ľae  ĽOtua  Ľi hono fitu  Ľoe  Ľaho mei he Ľene ngaue kotoa pńď.‚ÄĚ  
\v 5 Pea mo eni foki, ‚ÄúE  Ľikai te nau hŇę ki hoku mńĀlŇćlŇć Ľanga.‚ÄĚ  
\v 6 Ko ia koe Ľuhi kuo pau  Ľe hŇę ki ai  Ľae ni Ľihi, pea na Ľe  Ľikai hŇę  Ľakinautolu na Ľe tomu Ľa malanga ia ki ai, ko e me Ľa  Ľi he ta Ľetui:  
\v 7 (Pea toe kotofa  Ľe ia  Ľae  Ľaho  Ľe taha,  Ľo pehńď mai  Ľia Tevita, ‚ÄúKo e  Ľaho ni,‚ÄĚ  Ľi he hili  Ľae ngaahi ta Ľu lahi;  Ľo hangńď ko hono fakahńĀ, ‚ÄúKo e  Ľaho ni,  Ľo kapau te mou fanongo ki hono le Ľo,  Ľoua na Ľa fakafefeka homou loto.‚ÄĚ  
\v 8 He ka ne foaki  Ľe Siosiua,  Ľae mńĀlŇćlŇć Ľanga kiate kinautolu, pehńď,  Ľe  Ľikai folofola ia ki mui ki ha  Ľaho kehe.  
\v 9 Ko ia  Ľoku kei toe  Ľae mńĀlŇćlŇć Ľanga fakaSńĀpate ki he kakai  Ľae  ĽOtua.  
\v 10 He ko ia kuo hŇę ki hono mńĀlŇćlŇć Ľanga, kuo mńĀlŇćlŇć foki  Ľe ia mei he Ľene ngaue  Ľa Ľana,  Ľo hangńď ko e  ĽOtua mei he Ľene \add ngaue\add*.)  
\v 11 Ko ia ke tau fai feinga ke hŇę ki he mńĀlŇćlŇć Ľanga ko ia, telia na Ľa ai ha taha  Ľe hinga  Ľi he fai  Ľo fakatatau ki he ta Ľetui ko ia.  
\v 12 He ko e folofola  Ľae  ĽOtua  Ľoku mo Ľui, mo mńĀlohi, pea mńĀsila lahi  Ľi ha heletńĀ  Ľoku fakatoumata,  Ľoku  Ľasi ki hono vahe Ľi  Ľoe loto mo e laumńĀlie, mo e ngaahi hokotanga hui mo e uho, pea  Ľoku ne fakahńĀ  Ľae ngaahi mahalo mo e filio Ľi  Ľoe loto.  
\v 13 Pea  Ľoku  Ľikai ha me Ľa  Ľe taha  Ľoku ta ĽehńĀmai  Ľi hono  Ľao: ka  Ľoku telefua pea tokaima Ľananga  Ľae me Ľa kotoa pńď ki he fofonga  Ľo ia  Ľaia te tau fakamaau ki ai.  
\v 14 Ko ia  Ľi he Ľetau ma Ľu  Ľae fungani taula Ľeiki lahi,  Ľaia kuo hŇę atu  Ľi he langi, ko Sisu ko e  ĽAlo  Ľoe  ĽOtua, ke tau puke ma Ľu  Ľa  Ľetau lotu.  
\v 15 He  Ľoku  Ľikai ke tau ma Ľu  Ľae fungani taula Ľeiki  Ľoku ta Ľemanava Ľofa ki he Ľetau ngaahi vaivai; ka na Ľe  Ľahi Ľahi Ľi tatau pe ia  Ľi he me Ľa kotoa pńď, ka na Ľe  Ľikai ha Ľane angahala.  
\v 16 Ko ia ke tau ha Ľu mńĀlohi ai ki he  Ľafio Ľanga  Ľoe  Ľalo Ľofa, koe Ľuhi ke tau ma Ľu  Ľae  Ľalo Ľofa, pea  Ľilo mo e foaki  Ľofa, ke tokoni mai  Ľi he  Ľaho  Ľe  Ľaonga ai.   
\c 5  
\cd \it 1 Ko e lahi mo e ongo lelei  Ľoe ngaue fakataula Ľeiki  Ľa hotau Fakamo Ľui. 11  ĽOku ne valoki Ľi  Ľae ta Ľe Ľilo lahi ki ai.\it*  
\p
\v 1 Ko eni, ko e taula Ľeiki lahi kotoa pńď kuo fili mei he kakai, kuo fakanofo ia ma Ľae kakai  Ľi he ngaahi me Ľa  Ľae  ĽOtua, koe Ľuhi ke ne  Ľatu  Ľae ngaahi me Ľa foaki mo e ngaahi feilaulau koe Ľuhi ko e angahala:  
\v 2 ‚ÄĆ ĽAia  Ľoku ne fa Ľa  Ľofa mamahi ki he vale, pea mo e hńďhńď; koe Ľuhi kuo takatakai foki ia  Ľe he vaivai.  
\v 3 Pea ko e me Ľa ia  Ľoku totonu ke ne fai tatau ai  Ľae feilaulau ma Ľae kakai, pea ma Ľana foki, koe Ľuhi ko e angahala.  
\v 4 Pea  Ľoku  Ľikai to Ľo  Ľe ha tangata  Ľae ngaue tapu ni kiate ia, ka ko ia kuo ui  Ľe he  ĽOtua,  Ľo hangńď ko  ĽElone.  
\v 5 Pea pehńď, na Ľe  Ľikai fakaongoongolelei  Ľe ia ia  Ľe Kalaisi, ke ne hoko ai ko e fungani taula Ľeiki; ka ko ia ne ne pehńď kiate ia, ‚ÄúKo hoku  ĽAlo koe, kuo u fakatupu koe he  Ľaho ni.‚ÄĚ  
\v 6 ‚ÄĆ ĽO hangńď ko  Ľene lea foki  Ľe taha, ‚ÄúKo e taula Ľeiki koe  Ľo ta Ľengata,  Ľi he lakanga  Ľo Melekiseteki.‚ÄĚ  
\v 7 ‚ÄĆ ĽAia  Ľi he ngaahi  Ľaho  Ľo hono sino, kuo ne  Ľohake  Ľae hŇę mo e kole tńĀuma Ľu, fakataha mo e tangi mńĀlohi mo e lo Ľimata, kiate ia na Ľe fa Ľa fai ke fakamo Ľui ia mei he mate, pea na Ľe ongo Ľi ia  Ľi he me Ľa na Ľe manavahńď ai ia;  
\v 8 Neongo ko e  ĽAlo ia, ka na Ľe akonekina ia ke talangofua  Ľe he ngaahi me Ľa na Ľa ne kńĀtaki;  
\v 9 Pea kuo fakahaohaoa ia, pea ne hoko ko e tupu Ľanga  Ľoe mo Ľui ta Ľengata kiate kinautolu kotoa pńď  Ľoku talangofua kiate ia;  
\v 10 Kuo ui  Ľe he  ĽOtua ko e fungani taula Ľeiki  Ľi he lakanga  Ľo Melekiseteki.  
\v 11 ‚ÄĆ ĽAia  Ľoku  Ľi ai  Ľae ngaahi me Ľa lahi  Ľiate kimautolu ke lea Ľaki, pea faingata Ľa hono fakamatala, ko e me Ľa  Ľi ho Ľomou ta Ľeongongofua.  
\v 12 He ko e me Ľa  Ľi he fuoloa kuo taau mo kimoutolu ke akonaki, ka  Ľoku  Ľaonga ke toe akonekina  Ľakimoutolu pe ko e hńĀ hono  Ľuluaki tefito  Ľoe ngaahi folofola  Ľae  ĽOtua; pea kuo mou toe tatau mo ia  Ľoku  Ľaonga ki ai  Ľae hu Ľahuhu, kae  Ľikai ha me Ľakai mńĀlohi.  
\v 13 He ko ia kotoa pńď  Ľoku fakahuhu  Ľi he hu Ľahuhu,  Ľoku ta Ľepoto ia  Ľi he folofola  Ľoe mńĀ Ľoni Ľoni: he ko e valevale ia.  
\v 14 Ka ko e me Ľakai mńĀlohi,  Ľoku  Ľanautolu  Ľoku matu Ľotu Ľa,  Ľakinautolu ko e me Ľa  Ľi he maheni ai,  Ľi he fa Ľa ngńĀue Ľaki  Ľae ngaahi anga  Ľo honau loto,  Ľoku nau  Ľilo ai  Ľae lelei mo e kovi.   
\c 6  
\cd \it 1  ĽOku ne enginaki ke  Ľoua na Ľa hinga mei he tui, 11 Ka nau tu Ľuma Ľu, 12 Pea fa Ľa ngaue, mo fa Ľa fai ke tatali ki he  ĽOtua, 13 koe Ľuhi  Ľoku mo Ľoni  Ľae  ĽOtua  Ľi he Ľene tala Ľofa.\it*  
\p
\v 1 Ko ia foki, ke tuku ki mui  Ľae ngaahi  Ľuluaki akonaki  Ľa Kalaisi, ka tau fai atu ki he haohaoa; ke  Ľoua na Ľa toe ai  Ľae tu Ľunga  Ľae fakatomala mei he ngaahi ngaue mate, pea mo e tui ki he  ĽOtua,  
\v 2 ‚ÄĆ ĽAe akonaki  Ľoe ngaahi papitaiso, mo e hilifaki  Ľoe nima, mo e toetu Ľu  Ľoe mate, mo e fakamaau ta Ľengata.  
\v 3 Pea te tau fai eni,  Ľo kapau  Ľe lelei ki he  ĽOtua.  
\v 4 He koe Ľuhi  Ľe  Ľikai  Ľaupito mafai kiate kinautolu na Ľe mu Ľaki mńĀmangia, mo nau kamata  Ľae foaki mei  Ľolunga, pea nau ma Ľu mo e LaumńĀlie MńĀ Ľoni Ľoni,  
\v 5 Pea kuo nau kamata  Ľae folofola lelei  Ľae  ĽOtua, mo e ngaahi mńĀlohi  Ľoe maama  Ľe ha Ľu,  
\v 6 Pea kuo nau hinga atu, \add  Ľe  Ľikai mafai \add*ke toe fakafo Ľou  Ľakinautolu ki he fakatomala; he  Ľoku nau toe tutuki ki he  Ľakau  Ľekinautolu pe  Ľae  ĽAlo  Ľoe  ĽOtua,  Ľo fai fakahńĀhńĀ pe  Ľa hono fakamaa Ľi.  
\v 7 He ko e kelekele  Ľoku ne inumia  Ľae  Ľuha  Ľoku fa Ľa tŇć ki ai, pea tupu mei ai  Ľae  Ľakau  Ľoku taau mo kinautolu  Ľoku tauhi ia,  Ľoku tńĀpuekina ia mei he  ĽOtua:  
\v 8 Ka ko ia  Ľoku tupu mei ai  Ľae  Ľakau talatala mo e talatala ĽńĀmoa, kuo si Ľaki, pea kuo ofi ki he mala Ľia; ko hono ngata Ľanga  Ľo ia ko e vela.  
\v 9 Ka ko kimoutolu,  Ľe kńĀinga, neongo  Ľoku pehńď ni  Ľemau lea, ka  Ľoku mau  Ľamanaki ki he ngaahi me Ľa lelei lahi  Ľiate kimoutolu, mo e ngaahi me Ľa  Ľoku hoa mo e fakamo Ľui.  
\v 10 He  Ľoku  Ľikai ta Ľeangatonu  Ľae  ĽOtua, ke ne fakangalo Ľi ho Ľomou ngaue mo e feinga  Ľofa,  Ľaia kuo mou fakahńĀ ki hono huafa,  Ľi ho Ľomou tauhi Ľi  Ľae kńĀinga mńĀ Ľoni Ľoni, mo ho Ľomou ngaue.  
\v 11 Pea ko homau loto, ke taki taha fakahńĀ  Ľekimoutolu  Ľae fa Ľa fakakukafi ko ia ki he  Ľilo pau  Ľoe  Ľamanaki lelei  Ľo a Ľu ki he ngata Ľanga:  
\v 12 Ke  Ľoua na Ľa mou fakapikopiko, ka  Ľe fa Ľifa Ľitaki kiate kinautolu kuo nau lava Ľi  Ľi he tui mo e fa Ľa kńĀtaki  Ľae ngaahi tala Ľofa.  
\v 13 He na Ľe tala Ľofa  Ľae  ĽOtua kia  ĽEpalahame, pea koe Ľuhi kuo  Ľikai ha taha  Ľe lahi hake ke ne fuakava ai, ne ne fuakava  Ľiate ia pe,  
\v 14 ‚ÄĆ Ľo pehńď, ‚ÄúKo e mo Ľoni  Ľi he fakamonŇę Ľia te u fakamonŇę Ľia Ľi koe, pea  Ľi he fakatokolahi te u fakatokolahi Ľi koe.‚ÄĚ  
\v 15 Pea kuo hili  Ľene kńĀtaki fuoloa, ne ma Ľu  Ľe ia  Ľae tala Ľofa.  
\v 16 He ko e mo Ľoni  Ľoku fuakava  Ľae kakai  Ľi he lahi hake: pea ko e fuakava ke fakamo Ľoni  Ľaki, ko e fakangata ia  Ľoe fakakikihi kotoa pńď kiate kinautolu.  
\v 17 Pea  Ľi he me Ľa ni, kuo finangalo  Ľae  ĽOtua ke fakahńĀ  Ľo lahi ki he kakai na Ľe tala Ľofa ki ai  Ľae ta Ľefa Ľaliliu  Ľo  Ľene folofola, pea ne fakamo Ľoni  Ľaki ia  Ľae fuakava:  
\v 18 Koe Ľuhi  Ľi he me Ľa ta Ľefa Ľaliliu  Ľe ua,  Ľaia kuo  Ľikai ai  Ľaupito fa Ľa loi  Ľae  ĽOtua, ke ma Ľu  Ľekitautolu  Ľae fiemńĀlie lahi,  Ľakitautolu kuo feholaki ki he hŇęfanga, ke puke ki he  Ľamanaki lelei kuo tuku  Ľi hotau  Ľao:  
\v 19 ‚ÄĆ ĽAia kuo tau ma Ľu  Ľo hangńď ko e taula  Ľoe laumńĀlie, pea  Ľoku ma Ľu mo ta ĽengńĀue, pea  Ľoku tau ia ki he \add potu \add* Ľi loto puipui;  
\v 20 ‚ÄĆ ĽAia kuo hŇę ki ai  Ľa Sisu ko e takimu Ľa ma Ľatautolu, ko e taula Ľeiki lahi  Ľo ta Ľengata  Ľi he lakanga  Ľo Melekiseteki.   
\c 7  
\cd \it 1 Ko e taula Ľeiki  Ľa Kalaisi Sisu  Ľi he lakanga  Ľo Melikiseteke, 11 Pea ko ia  Ľoku lahi ai ia  Ľi he kau taula Ľeiki  Ľi he lakanga  Ľo  ĽElone.\it*  
\p
\v 1 He ko e Melikiseteke ni, ko e tu Ľi  Ľo Salema, ko e taula Ľeiki  Ľae  ĽOtua fungani mńĀ Ľolunga,  Ľaia na Ľe fakafetaulaki kia  ĽEpalahame  Ľi he Ľene liu mai mei he tńĀmate Ľi  Ľoe ngaahi tu Ľi, pea ne tńĀpuaki ia;  
\v 2 ‚ÄĆ ĽAia ne  Ľatu ki ai foki  Ľe  ĽEpalahame hono hongofulu  Ľoe vahe  Ľoe me Ľa kotoa pńď; ko e  Ľuluaki  Ľuhinga \add  Ľo hono hingoa \add*‚Äúko e Tu Ľi  Ľoe mńĀ Ľoni Ľoni,‚ÄĚ pea ko e Tu Ľi  Ľo Salema,  Ľa ia, ‚Äúko e Tu Ľi  Ľoe fiemńĀlie;‚ÄĚ  
\v 3 Ta Ľeha Ľanetamai, ta Ľeha Ľanefa Ľńď, ta Ľehanohohoko, kuo  Ľikai ha kamata Ľanga  Ľo hono ngaahi  Ľaho, pe ha ngata Ľanga  Ľo  Ľene mo Ľui; ka kuo tatau mo e  ĽAlo  Ľoe  ĽOtua; pea nofo ko e taula Ľeiki  Ľo lauikuonga.  
\v 4 Ko eni, ke tokanga ki hono lahi  Ľoe tangata ni,  Ľaia na Ľe  Ľatu ki ai  Ľe he mu Ľaki tamai ko  ĽEpalahame hono hongofulu  Ľoe vahe  Ľoe koloa  Ľi he vete.  
\v 5 Pea ko e mo Ľoni ko kinautolu  Ľi he ngaahi foha  Ľo Livai,  Ľoku ma Ľu  Ľae ngaue fakataula Ľeiki,  Ľoku  Ľiate kinautolu  Ľae fekau  Ľo fakatatau ki he fono ke to Ľo hono hongofulu  Ľoe vahe  Ľoe me Ľa mei he kakai,  Ľio, mei honau kńĀinga, neongo ko e tupu foki  Ľakinautolu mei he sino  Ľo  ĽEpalahame:  
\v 6 Ka ko ia  Ľoku  Ľikai lau hono hohoko meiate kinautolu, ne ma Ľu  Ľe ia hono hongofulu  Ľoe vahe  Ľoe me Ľa mei  Ľa  ĽEpalahame, mo ne tńĀpuaki ia  Ľaia na Ľe  Ľa Ľana  Ľae ngaahi tala Ľofa.  
\v 7 Pea ko e mo Ľoni ta Ľehakikihi ki ai,  Ľoku tńĀpuaki Ľi  Ľe he lahi hake  Ľae si Ľi hifo.  
\v 8 Pea  Ľoku ma Ľu  Ľi heni  Ľe he kau tangata  Ľoku \add hokohoko \add*mate pe hono hongofulu  Ľoe vahe  Ľoe me Ľa; kae  Ľi hena  Ľe ia  Ľoku fakamo Ľoni ki ai  Ľoku mo Ľui ai pe.  
\v 9 Pea hangńď ka pehńď  Ľeku lea, ko Livai foki,  Ľaia  Ľoku ne ma Ľu hono hongofulu  Ľoe vahe  Ľoe me Ľa, na Ľe  Ľatu  Ľe ia hono hongofulu  Ľoe vahe ia  ĽEpalahame:  
\v 10 He na Ľe kei  Ľi he sino  Ľo  Ľene tamai ia,  Ľi he  Ľena fetaulaki mo Melekiseteki.  
\v 11 Ko ia ka ne ai ha haohaoa  Ľi he kau taula Ľeiki  Ľoe fa Ľahinga  Ľo Livai, (he na Ľe ma Ľu ai  Ľe he kakai  Ľae fono,) ko e hńĀ hono  Ľaonga  Ľoe fokotu Ľu mo e taula Ľeiki  Ľe taha  Ľi he lakanga  Ľo Melekiseteki, kae  Ľikai ui  Ľi he lakanga  Ľo  ĽElone?  
\v 12 He ko e me Ľa  Ľi he fetongi  Ľae kau taula Ľeiki,  Ľoku totonu ai foki ke fetongi mo e fono.  
\v 13 He ko ia  Ľoku lea Ľaki ki ai  Ľae ngaahi me Ľa ni,  Ľoku  Ľi he fa Ľahinga  Ľe taha, pea na Ľe  Ľikai ha taha mei ai  Ľe ngaue  Ľi he  Ľesifeilaulau.  
\v 14 He kuo ha mo Ľoni na Ľe tupu  Ľa hotau  ĽEiki meia Siuta;  Ľae fa Ľahinga ko ia na Ľe  Ľikai  Ľaupito ke lea ki ai  Ľa MŇćsese ki he ngaue fakataula Ľeiki.  
\v 15 Kae mu Ľa hake eni foki: koe Ľuhi kuo fokotu Ľu  Ľae taula Ľeiki  Ľe taha  Ľo fakatatau mo Melekiseteki,  
\v 16 ‚ÄĆ ĽAia  Ľoku fakanofo, kae  Ľikai hangńď ko e tu Ľutu Ľuni  Ľoe fekau fakakakano, kae fakatatau ki he mńĀlohi  Ľoe mo Ľui ta Ľengata.  
\v 17 He  Ľoku ne fakapatonu mai, ‚ÄúKo e taula Ľeiki koe  Ľo lauikuonga  Ľi he lakanga  Ľo Melekiseteki.‚ÄĚ  
\v 18 He  Ľoku ai mo Ľoni hono fakangata  Ľoe fekau na Ľe mu Ľomu Ľa, koe Ľuhi ko hono vaivai mo hono ta Ľe Ľaonga.  
\v 19 He na Ľe  Ľikai fakahaohaoa  Ľe he fono ha me Ľa e taha, ka ko e fakahoko pe  Ľoe  Ľamanaki lelei;  Ľaia  Ľoku tau  Ľunu Ľunu atu ai ki he  ĽOtua.  
\v 20 Pea koe Ľuhi na Ľe  Ľikai pehńď ia ka  Ľi he fuakava:  
\v 21 (He na Ľe ngaohi  Ľakinautolu koe kau taula Ľeiki ta Ľeha fuakava; ka ko ia  Ľi he fuakava  Ľiate ia na Ľa ne pehńď ki ai, ‚ÄúKuo fuakava  Ľe he  ĽEiki, pea  Ľe  Ľikai te ne liliu, Ko e taula Ľeiki koe  Ľo lauikuonga  Ľi he lakanga  Ľo Melekiseteki:‚ÄĚ)  
\v 22 Kuo pehńď hono lelei lahi hake  Ľoe fakapapau  Ľoe hoko  Ľa Sisu ko e fakalaloa.  
\v 23 Pea ko e mo Ľoni, na Ľa nau tokolahi  Ľae kau taula Ľeiki, he na Ľe  Ľikai ke tuku fuoloa  Ľakinautolu ko e me Ľa  Ľi he mate:  
\v 24 Ka ko e tangata ni, ko e me Ľa  Ľi he Ľene tolonga  Ľo ta Ľengata, kuo ma Ľu  Ľe ia  Ľae ngaue fakataula Ľeiki  Ľoku ta Ľeliliu.  
\v 25 Ko ia foki  Ľoku ne fa Ľa fai ai ke fakamo Ľui haohaoa  Ľakinautolu  Ľoku ha Ľu ki he  ĽOtua  Ľiate ia, ko e me Ľa  Ľi he Ľene mo Ľui ma Ľuaipńď ke hŇęfaki Ľi  Ľakinautolu.  
\v 26 He na Ľe taau mo kitautolu  Ľae fungani taula Ľeiki pehńď,  Ľoku mńĀ Ľoni Ľoni, ta Ľeha Ľanekovi, pea ta Ľe Ľuli, pea mavahe mei he kau angahala, pea fakamńĀ Ľolunga hake  Ľi he ngaahi langi;  
\v 27 ‚ÄĆ ĽAia na Ľe  Ľikai ke ne hangńď ko e kau taula Ľeiki lahi ko ia, ke ne tomu Ľa feilaulau  Ľi he  Ľaho kotoa pńď koe Ľuhi ko  Ľene angahala  Ľa Ľana, pea toki \add fai \add*koe Ľuhi ko e kakai: he na Ľe fai ia  Ľe ia  Ľo tu Ľo taha pe,  Ľi he Ľene  Ľohake  Ľe ia ia.  
\v 28 He  Ľoku ngaohi  Ľe he fono ke taula Ľeiki lahi  Ľae kau tangata  Ľoku vaivai; ka  Ľoku fakanofo  Ľae  ĽAlo,  Ľaia kuo fakahaohaoa  Ľo ta Ľengata  Ľe he lea  Ľoe fuakava na Ľe ki mui  Ľi he fono.   
\c 8  
\cd \it 1 Ko e me Ľa  Ľi he ngaue fakataula Ľeiki  Ľo ta Ľengata  Ľa Kalaisi kuo  Ľosi hono  Ľaonga, pea ngata  Ľae ngaue fakataula Ľeiki  Ľakinautolu mei he fa Ľahinga  Ľo Livai. 7 Pea ngata  Ľae  Ľuluaki fuakava na Ľe fai mo e mńĀtu Ľa  Ľi mu Ľa,  Ľi he fuakava ta Ľengata  Ľoe ongoongolelei.\it*  
\p
\v 1 Pea ko hono me Ľa lahi \add eni \add* Ľi he ngaahi lea ni:  ĽOku tau ma Ľu  Ľae fungani taula Ľeiki pehńď, pea kuo nofo ia  Ľi he nima to Ľomata Ľu  Ľoe  Ľafio Ľanga  Ľoe Fungani MńĀ Ľolunga  Ľi he ngaahi langi;  
\v 2 Ko e tauhi  Ľoe potu tapu, mo e fale fehikitaki mo Ľoni,  Ľaia na Ľe fokotu Ľu  Ľe he  ĽOtua, kae  Ľikai ko e tangata.  
\v 3 He ko e taula Ľeiki lahi kotoa pńď, kuo fakanofo ke ne  Ľohake  Ľae ngaahi me Ľa foaki mo e ngaahi feilaulau: ko ia na Ľe totonu mei ai ki he tangata ni ke  Ľohake foki  Ľe ia ha me Ľa.  
\v 4 He ka ne  Ľi mńĀmani ia,  Ľe  Ľikai taula Ľeiki ia, koe Ľuhi  Ľoku ai  Ľae kau taula Ľeiki  Ľoku nau  Ľohake  Ľae ngaahi me Ľa foaki  Ľo fakatatau mo e fono:  
\v 5 ‚ÄĆ ĽAkinautolu  Ľoku tauhi  Ľo fakatatau mo e ata  Ľoe ngaahi me Ľa  Ľoe langi,  Ľo hangńď ko e valoki Ľi  Ľe he  ĽOtua  Ľa MŇćsese  Ľi he Ľene teu ke langa  Ľae fale fehikitaki: he na Ľe pehńď mai  Ľe ia, ‚ÄúVakai ke ke ngaohi  Ľae me Ľa kotoa pńď  Ľo fakatatau ki hono fakatńĀtńĀ na Ľe fakahńĀ kiate koe  Ľi he mo Ľunga.‚ÄĚ  
\v 6 Ka ko eni, kuo ma Ľu  Ľe ia  Ľae ngaue  Ľoku lelei lahi,  Ľo hangńď ko hono lelei lahi  Ľoe fuakava  Ľoku fakalaloa ai ia,  Ľaia  Ľoku fokotu Ľu  Ľi he ngaahi tala Ľofa lelei lahi.  
\v 7 He ka ne haohaoa  Ľae  Ľuluaki \add fuakava \add*ko ia, pehńď, ne  Ľikai kumi ha potu mo hono ua.  
\v 8 Koe Ľuhi  Ľi he Ľene ta ĽefiemńĀlie, na Ľe pehńď  Ľe ia kiate kinautolu, ‚ÄúVakai,  Ľoku pehńď  Ľe Sihova,  Ľe hoko mai  Ľae ngaahi  Ľaho te u fai ai  Ľae fuakava fo Ľou mo e fale  Ľo  ĽIsileli mo e fale  Ľo Siuta:  
\v 9 ‚ÄĆ ĽO  Ľikai tatau mo e fuakava  Ľaia ne u fai mo  Ľenau ngaahi tamai,  Ľi he  Ľaho ne u puke ai honau nima ke tataki  Ľakinautolu mei he fonua ko  ĽIsipite;  Ľoku pehńď  Ľe Sihova, koe Ľuhi na Ľe  Ľikai ke nau tu Ľuma Ľu  Ľi he Ľeku fuakava, pea ne u ta Ľetokanga Ľi  Ľakinautolu.  
\v 10 He ko eni  Ľae fuakava  Ľaia te u fai mo e fale  Ľo  ĽIsileli  Ľoka hili ange  Ľae ngaahi  Ľaho ko ia,  Ľoku pehńď  Ľe Sihova; Teu  Ľai  Ľeku ngaahi fekau ki honau loto, pea tohi ia  Ľi honau laumńĀlie: pea teu hoko ko honau  ĽOtua, pea  Ľe hoko  Ľakinautolu ko hoku kakai:  
\v 11 Pea  Ľe  Ľikai te nau taki taha ako ki hono kaungńĀ Ľapi, mo taki taha ki hono kńĀinga,  Ľo pehńď, ‚ÄėKe  Ľilo  Ľa Sihova:‚Äô he koe Ľuhi  Ľe  Ľilo Ľi au kotoa pńď, mei he iiki  Ľo a Ľu ki he lalahi.  
\v 12 He te u  Ľalo Ľofa ki he Ľenau ta ĽemńĀ Ľoni Ľoni, pea ko  Ľenau ngaahi angahala mo  Ľenau hia,  Ľe  Ľikai te u kei manatu Ľi.‚ÄĚ  
\v 13 Pea  Ľi he Ľene pehńď, Ko e \add fuakava \add*fo Ľou, kuo hńĀ ai kuo motu Ľa  Ľae  Ľuluaki. Pea ko ia kuo motu Ľa mo vaivai, kuo tei mole ia.   
\c 9  
\cd \it 1 Ko e fakamatala  Ľoe ngaahi ngaue mo e ngaahi feilaulau toto  Ľoe fono, 11  ĽOku si Ľi hifo  Ľaupito hono  Ľaonga mo hono haohaoa  Ľi he toto mo e feilaulau  Ľa Kalaisi.\it*  
\p
\v 1 Ko eni, na Ľe ma Ľu mo Ľoni foki  Ľe he  Ľuluaki \add fuakava \add* Ľae ngaahi ngaue faka Ľeiki, pea mo e potu tapu kuo  Ľo mńĀmani.  
\v 2 He na Ľe langa  Ľae  Ľuluaki fale fehikitaki;  Ľaia na Ľe  Ľi ai  Ľae tu Ľunga maama, mo e  Ľai Ľanga me Ľa, mo e mńĀ  Ľoe  Ľao;  Ľaia na Ľe ui ko e potu tapu.  
\v 3 Pea na Ľe  Ľi loto  Ľi hono ua  Ľoe puipui,  Ľae fale fehikitaki  Ľaia  Ľoku ui ko e potu toputapu;  
\v 4 Na Ľe  Ľi ai  Ľae ipu koula  Ľai Ľanga afi, mo e puha  Ľoe fuakava na Ľe  Ľu Ľufi takatakai  Ľaki  Ľae koula,  Ľaia na Ľe ai  Ľae ipu koula na Ľe  Ľi ai  Ľae mana, mo e tokotoko  Ľo  ĽElone na Ľe moto, mo e ongo maka lafalafa  Ľoe fuakava;  
\v 5 Pea na Ľe  Ľi  Ľolunga  Ľi ai  Ľae ongo selupi  Ľoe nńĀunau na Ľe fakamalu  Ľae nofo Ľanga  Ľalo Ľofa;  Ľaia  Ľe  Ľikai te mau fa Ľa fakamatala kotoa pńď eni.  
\v 6 Pea kuo pehńď hono teuteu  Ľoe ngaahi me Ľa ni, pea hŇę ma Ľuaipńď  Ľae kau taula Ľeiki ki he  Ľuluaki fale fehikitaki,  Ľo fai ai  Ľenau ngaahi ngaue.  
\v 7 Ka ko hono ua, na Ľe ngata  Ľi he taula Ľeiki lahi,  Ľo liunga taha pe,  Ľi he ta Ľu kotoa pńď, ka na Ľe  Ľikai ta Ľehatoto,  Ľaia ne ne  Ľatu ma Ľana, mo e fai hala  Ľae kakai:  
\v 8 Ko e faka Ľilo eni  Ľe he LaumńĀlie MńĀ Ľoni Ľoni, na Ľe te Ľeki ai ke fakahńĀ  Ľae hala ki he potu tapu,  Ľi he kei tu Ľu  Ľae  Ľuluaki fale fehikitaki:  
\v 9 ‚ÄĆ ĽAia ko e fakatńĀtńĀ ki he kuonga ko ia, pea na Ľe  Ľatu  Ľi ai  Ľae ngaahi me Ľa foaki mo e ngaahi feilaulau, ka na Ľe  Ľikai fa Ľa fai ia ke fakahaohaoa  Ľae loto  Ľo ia na Ľe fai ki ai;  
\v 10 Ko e ngaahi me Ľakai mo inu pe, mo e ngaahi fufulu kehekehe, mo e ngaahi tu Ľutu Ľuni fakasino, na Ľe fokotu Ľu kae Ľoua ke hoko  Ľae kuonga  Ľoe fakafo Ľou.  
\v 11 Ka  Ľi he hoko mai  Ľa Kalaisi, ko e taula Ľeiki lahi  Ľoe ngaahi me Ľa lelei  Ľe hoko,  Ľi he fale fehikitaki  Ľoku lahi hake mo haohaoa  Ľaupito na Ľe  Ľikai ngaohi  Ľaki  Ľae nima, ko hono  Ľuhinga,  Ľoku  Ľikai  Ľoe mńĀmani;  
\v 12 Pea na Ľe  Ľikai  Ľi he toto  Ľoe fanga kosi mo e  Ľuhiki Ľi pulu,  Ľa  Ľene hŇę  Ľo liunga taha pe ki he potu tapu, ka  Ľi hono ta Ľata Ľa  Ľo Ľona, kuo ne lava Ľi  Ľae huhu Ľi ta Ľengata.  
\v 13 He kapau na Ľe fakamńĀ Ľoni Ľoni Ľi  Ľae ta Ľema Ľa ki he fakama Ľa  Ľoe sino,  Ľi he luluku  Ľaki  Ľae toto  Ľoe fanga pulu tangata mo e fanga kosi, mo e efu  Ľoe pulu fefine:  
\v 14 E fńďfńď hono lahi hake  Ľoe fakama Ľa homou loto mei he ngaahi ngaue mate  Ľe he ta Ľata Ľa  Ľo Kalaisi,  Ľaia na Ľa ne feilaulau  Ľaki ia ta Ľehanomele  Ľi he LaumńĀlie ta Ľengata ki he  ĽOtua, ke mou tauhi  Ľae  ĽOtua mo Ľui?  
\v 15 Pea ko e me Ľa eni kuo hoko ai ia ko e fakalaloa  Ľoe fuakava fo Ľou, kae fai  Ľi he pekia  Ľae totongi ki he ngaahi angahala na Ľe fai  Ľi he  Ľuluaki fuakava, pea ma Ľu  Ľekinautolu kuo ui  Ľae tala Ľofa  Ľoe nofo Ľanga ta Ľengata.  
\v 16 He ka  Ľi ai ha fuakava,  Ľoku totonu ke  Ľi ai foki mo e mate  Ľo ia  Ľoku ne fakamo Ľoni  Ľae fuakava.  
\v 17 He  Ľoku mńĀlohi  Ľae fuakava ko e hili  Ľae mate: ka  Ľi he kei mo Ľui  Ľae fakamo Ľoni,  Ľoku  Ľikai  Ľaupito hano mńĀlohi.  
\v 18 Ko ia na Ľe  Ľikai fakamo Ľoni  Ľae  Ľuluaki \add fuakava \add*ka  Ľi he toto pe.  
\v 19 He kuo lea Ľaki  Ľe MŇćsese  Ľae fekau kotoa pńď ki he kakai kotoa pńď  Ľo fakatatau ki he fono, pea to Ľo  Ľe ia  Ľae toto  Ľoe fanga  Ľuhiki Ľi pulu mo e fanga kosi, fakataha mo e vai, mo e fulufulu Ľi sipi kulokula, mo e  Ľisope,  Ľo ne luluku  Ľaki  Ľae tohi, pea mo e kakai kotoa pńď,  
\v 20 ‚ÄĆ Ľo ne pehńď, ‚ÄúKo e toto eni  Ľoe fuakava  Ľaia kuo fekau  Ľe he  ĽOtua kiate kimoutolu.‚ÄĚ  
\v 21 Pea na Ľa ne luluku foki  Ľaki  Ľae toto  Ľae fale fehikitaki, mo e ngaahi me Ľa kotoa pńď na Ľe fai  Ľaki  Ľae ngaue.  
\v 22 Pea kuo mei  Ľosi  Ľae me Ľa kotoa pńď  Ľi hono fakama Ľa  Ľaki  Ľae toto  Ľo fakatatau ki he fono; pea ka  Ľikai lilingi  Ľae toto  Ľoku  Ľikai ha fakamolemole.  
\v 23 Ko ia na Ľe totonu ai ke fakama Ľa  Ľaki eni  Ľae ngaahi fakatńĀtńĀ  Ľoe ngaahi me Ľa  Ľi he langi; ka ko e ngaahi me Ľa  Ľi he langi  Ľaki  Ľae ngaahi feilaulau  Ľoku lelei lahi hake.  
\v 24 He na Ľe  Ľikai hŇę  Ľa Kalaisi ki he potu tapu na Ľe ngaohi  Ľaki  Ľae nima, \add  Ľaia \add*ko e fakatńĀtńĀ \add pe \add*ki he mo Ľoni; ka ki he loto langi, ke ne fakahńĀ eni ia  Ľi he  Ľao  Ľae  ĽOtua koe Ľuhi ko kitautolu.  
\v 25 Pea na Ľe  Ľikai foki ke ne feilaulau  Ľaki ia  Ľo liunga lahi,  Ľo hangńď ko e hŇę  Ľae taula Ľeiki lahi ki he potu tapu  Ľi he ta Ľu kotoa pńď mo e toto kehe;  
\v 26 He ka ne pehńď, Ta  Ľe liunga lahi  Ľene mamahi talu hono fakatupu  Ľo mńĀmani: ka ko eni, kuo ne fakahńĀ ia  Ľo tu Ľo taha  Ľi he ngata Ľanga  Ľo mńĀmani, ke ne  Ľave  Ľae angahala  Ľi he feilaulau  Ľaki ia  Ľe ia.  
\v 27 Pea hangńď kuo pau ke mate  Ľo tu Ľo taha  Ľae kakai, kae hili ia ko e fakamaau:  
\v 28 Pea pehńď foki, kuo feilaulau  Ľaki  Ľa Kalaisi  Ľo liunga taha, ke ne fua  Ľae ngaahi hia  Ľae tokolahi; pea  Ľe fakahńĀ ia ko hono liunga ua, kiate kinautolu  Ľoku  Ľamanaki kiate ia, ki he fakamo Ľui, ka  Ľe  Ľikai \add ke  Ľave \add* Ľae angahala.   
\c 10  
\cd \it 1 Ko e vaivai  Ľoe ngaahi feilaulau  Ľi he fono. 10 Ko e feilaulau  Ľoe sino  Ľo Kalaisi kuo  Ľatu  Ľo tu Ľo taha, 14 Kuo to Ľo atu  Ľe ia  Ľae mala Ľia  Ľoe angahala  Ľo ta Ľengata. 19 Ko e enginaki ke kuku ma Ľu  Ľae tui,  Ľi he fa Ľa kńĀtaki mo e fakafeta Ľi.\it*  
\p
\v 1 He ko e me Ľa  Ľi he ma Ľu  Ľe he fono  Ľae  Ľata pe  Ľoe ngaahi me Ľa lelei  Ľe hoko, kae  Ľikai ko hono tatau mo Ľoni  Ľoe ngaahi me Ľa,  Ľoka  Ľikai fa Ľa fai ia  Ľi he ngaahi feilaulau ko ia  Ľoku nau fa Ľa  Ľatu  Ľi he ta Ľu kotoa pńď, ke fakahaohaoa Ľi  Ľakinautolu  Ľoku fai ki ai.  
\v 2 He ka ne pehńď,  Ľikai kuo tuku hono feilaulau Ľaki? He koe Ľuhi koe kau lotu kuo fakama Ľa  Ľo tu Ľo taha,  Ľe  Ľikai te nau kei ongo Ľi loto  Ľae angahala.  
\v 3 Ka  Ľi he ngaahi \add feilaulau\add* ko ia \add  Ľoku ai \add* Ľae fakamanatu ki he angahala  Ľi he ta Ľu kotoa pńď.  
\v 4 He  Ľoku  Ľikai  Ľaupito mafai ke  Ľave  Ľae angahala  Ľe he toto  Ľoe fanga pulu mo e fanga kosi.  
\v 5 Ko ia  Ľoku pehńď ai  Ľe ia,  Ľi he Ľene hńĀ Ľele mai ki mńĀmani, ‚ÄúKo e feilaulau mo e me Ľa foaki na Ľe  Ľikai te ke finangalo ki ai, ka kuo ke teuteu  Ľae sino mo Ľoku:  
\v 6 Ko e ngaahi feilaulau tutu mo e ngaahi feilaulau koe Ľuhi ko e angahala  Ľoku  Ľikai te ke fiemńĀlie ai.  
\v 7 Peau toki pehńď, ‚Äė ĽE  ĽOtua, vakai,  Ľoku ou ha Ľu ke fai ho finangalo: he kuo tohi  Ľi he tohi tńĀkai  Ľiate au.‚Äô‚ÄĚ  
\v 8 Pea  Ľi he Ľene fuofua pehńď mai, ‚ÄúKo e feilaulau mo e me Ľa foaki mo e feilaulau tutu mo e feilaulau koe Ľuhi ko e angahala, na Ľe  Ľikai te ke finangalo ki ai,‚ÄĚ pe fiemńĀlie ai  Ľaia  Ľoku  Ľatu  Ľo fakatatau ki he fono;  
\v 9 Pea toki pehńď  Ľe ia, ‚Äú ĽE  ĽOtua, vakai,  Ľoku ou ha Ľu ke fai ho finangalo.‚ÄĚ  ĽOku ne  Ľave  Ľae  Ľuluaki, ka ne fokotu Ľuma Ľu hono ua.  
\v 10 Pea ko e finangalo ko ia  Ľoku fakamńĀ Ľoni Ľoni Ľi ai  Ľakitautolu,  Ľi he feilaulau  Ľaki  Ľae sino  Ľo Sisu Kalaisi  Ľo liunga taha pe.  
\v 11 Pea  Ľoku tu Ľu  Ľae taula Ľeiki kotoa pńď  Ľi he  Ľaho fulipńď  Ľo tauhi, mo feilaulau  Ľaki  Ľo liunga lahi  Ľae ngaahi feilaulau pe ko ia,  Ľaia  Ľoku  Ľikai  Ľaupito fa Ľa fai ke  Ľave  Ľae angahala:  
\v 12 Ka ko ia, kuo hili  Ľene  Ľatu  Ľae feilaulau  Ľe taha koe Ľuhi ko e angahala, pea nofo ia  Ľo ta Ľengata  Ľi he nima to Ľomata Ľu  Ľoe  ĽOtua;  
\v 13 Pea talu mei ai, mo  Ľene  Ľamanaki, kae Ľoua ke ngaohi hono ngaahi fili ko hono tu Ľungava Ľe.  
\v 14 He ko e feilaulau pe taha kuo ne fakahaohaoa ai  Ľo ta Ľengata  Ľakinautolu kuo fakamńĀ Ľoni Ľoni Ľi.  
\v 15 ‚ÄĆ ĽAia  Ľoku fakamo Ľoni  Ľe he LaumńĀlie MńĀ Ľoni Ľoni kiate kitautolu: he kuo hili  Ľene mu Ľaki lea mai,  
\v 16 ‚ÄúKo e fuakava eni  Ľaia te u fai mo kinautolu  Ľoka hili  Ľae ngaahi  Ľaho ko ia, pea  Ľoku pehńď  Ľe Sihova, Te u  Ľai  Ľeku ngaahi fekau ki honau loto, pea te u tohi ia  Ľi honau laumńĀlie;  
\v 17 Pea ‚Äúko  Ľenau ngaahi angahala mo  Ľenau ngaahi hia,  Ľe  Ľikai te u kei manatu Ľi.‚ÄĚ  
\v 18 Pea ko ia \add  Ľoku  Ľi ai \add* Ľae fakamolemole  Ľo ia,  Ľe  Ľikai ha kei feilaulau koe Ľuhi ko e angahala.  
\v 19 Ko ia,  Ľe kńĀinga, ko e me Ľa  Ľi he Ľene  Ľapa Ľapangofua  Ľetau hŇę ki he potu tapu  Ľi he ta Ľata Ľa  Ľo Sisu,  
\v 20 ‚ÄĆ ĽI he hala fo Ľou pea mo Ľui,  Ľaia kuo ne fakatapui mo Ľotautolu,  Ľi he puipui,  Ľaia ko hono sino;  
\v 21 Pea \add  Ľi he ai \add*mo e fungani taula Ľeiki ki he fale  Ľoe  ĽOtua;  
\v 22 Ke tau  Ľunu Ľunu atu  Ľi he loto mo Ľoni mo e  Ľamanaki mńĀlohi  Ľoe tui, kuo luluku hotau loto mei he  Ľatamai kovi, pea fakama Ľa mo hotau sino  Ľaki  Ľae vai ma Ľa.  
\v 23 Ke tau puke ma Ľu  Ľae fakahńĀ  Ľoe tau tui  Ľo ta Ľengaueue; (he  Ľoku mo Ľoni ia kuo ne faka Ľilo;)  
\v 24 Pea tau fetokanga Ľaki ke fefaka Ľai Ľai Ľaki  Ľakitautolu ki he  Ľofa mo e ngaahi ngaue lelei:  
\v 25 Ke  Ľoua na Ľa si Ľaki  Ľekitautolu  Ľe tau fa Ľa fakataha  Ľo hangńď ko ia  Ľoku fai  Ľe he ni Ľihi; kae feakonaki Ľaki \add  Ľakimoutolu\add*: pea  ĽńĀsili ai, ko ho Ľomou  Ľilo  Ľoku ofi mai  Ľae  Ľaho.  
\v 26 He kapau te tau angahala ka ko hotau loto, ka kuo hili  Ľetau ma Ľu  Ľae  Ľilo  Ľoe mo Ľoni,  Ľoku  Ľikai kei toe ha feilaulau koe Ľuhi ko e angahala,  
\v 27 Ka ko e  Ľamanaki fakailifia ki he fakamaau mo e houhau vela,  Ľaia  Ľe faka Ľauha  Ľaki  Ľae ngaahi fili.  
\v 28 Ko ia na Ľa ne maumau Ľi  Ľae fono  Ľa MŇćsese, na Ľe mate ta Ľefakamolemolea  Ľi he fakamo Ľoni  Ľe toko ua pe toko tolu:  
\v 29 Pea  Ľoku mou pehńď,  Ľe fńďfńď hono lahi hake  Ľoe tautea  Ľe taau ke hoko kiate ia, kuo ne malaki hifo  Ľae  ĽAlo  Ľoe  ĽOtua, pea ne ui  Ľae ta Ľata Ľa  Ľoe fuakava,  Ľaia na Ľe fakama Ľa  Ľaki ia, ko e me Ľa ta Ľema Ľa, pea kuo ne fai fakamamahi ki he LaumńĀlie  Ľoe  Ľalo Ľofa?  
\v 30 He  Ľoku tau  Ľilo ia  Ľaia kuo ne pehńď, ‚Äú ĽOku pehńď  Ľe Sihova,  ĽOku  Ľa Ľaku  Ľae tautea, te u totongi  Ľeau.‚ÄĚ Pea toe pehńď, ‚ÄúE fakamaau  Ľe Sihova  Ľa hono kakai.‚ÄĚ  
\v 31 Ko e me Ľa fakailifia ke tŇć ki he nima  Ľoe  ĽOtua mo Ľui.  
\v 32 Ka mou fakamanatu ki he ngaahi  Ľaho  Ľi mu Ľa, ne hili homou fakamńĀmangia, pea ne mou kńĀtaki  Ľae ta Ľu lahi  Ľoe ngaahi mamahi;  
\v 33 Ko e ni Ľihi,  Ľi hono ngaohi  Ľakimoutolu ko e siofia Ľanga  Ľi he ngaahi manuki mo e ngaahi fakamamahi; pea ko e ni Ľihi,  Ľi ho Ľomou kaume Ľa mo kinautolu na Ľe pehńď  Ľa honau ngaohi.  
\v 34 He na Ľa mou manava Ľofa kiate au  Ľi hoku ngaahi ha Ľi, pea na Ľa mou tali fiefia  Ľae maumau  Ľo ho Ľomou koloa, ko ho Ľomou  Ľilo  Ľoku mou ma Ľu  Ľi he langi  Ľae koloa lelei lahi hake pea tolonga.  
\v 35 Ko ia ke  Ľoua na Ľa si Ľaki ho Ľomou tui,  Ľaia  Ľoku lahi hono totongi lelei.  
\v 36 He  Ľoku taau mo kimoutolu  Ľae fa Ľa kńĀtaki, koe Ľuhi ka hili ho Ľomou fai  Ľae finangalo  Ľoe  ĽOtua, ke mou ma Ľu  Ľae tala Ľofa.  
\v 37 ‚ÄúKoe Ľuhi  Ľe toetoe si Ľi pe, pea ko ia  Ľoku ha Ľu,  Ľe ha Ľu pe, pea  Ľe  Ľikai fakatuai.  
\v 38 Pea ko eni,  ĽE mo Ľui  Ľae tonuhia  Ľi he tui, ka,  ĽOka fakaholomui ia,  Ľe  Ľikai fiemńĀlie hoku laumńĀlie kiate ia.‚ÄĚ  
\v 39 Ka  Ľoku  Ľikai te tau  Ľonautolu  Ľoku fakaholomui ki he mala Ľia; kae  Ľonautolu  Ľoku tui ki he fakamo Ľui  Ľoe laumńĀlie.   
\c 11  
\cd \it 1 Hono  Ľuhinga  Ľoe tui. 6 Ka  Ľikai  Ľae tui, pea  Ľikai  Ľaupito te tau fa Ľa fakafiemńĀlie ki he  ĽOtua. 7 Ko e fua lelei  Ľoe tui  Ľi ho kau mńĀtu Ľa  Ľi mu Ľa.\it*  
\p
\v 1 Ko eni, ko e tui ko e tu Ľunga ia  Ľoe ngaahi me Ľa  Ľoku  Ľamanaki lelei ki ai, ko e fakamo Ľoni  Ľoe ngaahi me Ľa ta ĽehńĀmai.  
\v 2 He ko ia na Ľe ma Ľu ai  Ľe he mńĀtu Ľa  Ľae ongoongolelei.  
\v 3 Ko e tui  Ľoku tau  Ľilo ai na Ľe fakatupu  Ľae ngaahi maama  Ľe he folofola  Ľae  ĽOtua, ko ia ko e ngaahi me Ľa  Ľoku  Ľilo \add ni \add*na Ľe  Ľikai ke fakatupu  Ľaki  Ľae ngaahi me Ľa na Ľe hńĀ mai.  
\v 4 Ko e tui na Ľe  Ľatu ai  Ľe  ĽEpeli ki he  ĽOtua  Ľae feilaulau lelei hake  Ľia Keini, ko ia na Ľa ne ma Ľu ai  Ľae fakamo Ľoni kuo fakatonuhia ia, ko e fakamo Ľoni  Ľe he  ĽOtua ki he Ľene ngaahi foaki: pea  Ľoku ne kei lea Ľaki ia ka kuo mate ia.  
\v 5 Ko e tui na Ľe hiki ai  Ľa  ĽInoke, ke  Ľoua na Ľa hoko kiate ia  Ľae mate; pea na Ľe  Ľikai  Ľilo ia, koe Ľuhi kuo hiki ia  Ľe he  ĽOtua: he na Ľe te Ľeki fai hono hiki, kuo ne ma Ľu  Ľae fakamo Ľoni ki he Ľene fakafiemńĀlie Ľi  Ľae  ĽOtua.  
\v 6 Ka  Ľi he ta Ľema Ľu  Ľae tui  Ľoku  Ľikai mafai hono fakafiemńĀlie Ľi: he ko ia  Ľoku ha Ľu ki he  ĽOtua,  Ľoku totonu ke ne tui  Ľoku ai ia, pea  Ľoku ne totongi kiate kinautolu  Ľoku kumi lahi kiate ia.  
\v 7 Ko e tui  Ľa Noa, kuo hili hono valoki Ľi  Ľe he  ĽOtua ki he ngaahi me Ľa te Ľeki hńĀ mai, na Ľe manavahńď ai ia, pea ne fa Ľu  Ľae vaka ke fakamo Ľui ai hono fale; ko ia na Ľa ne fakahńĀ ai hono kovi  Ľoe maama ko ia, pea ne lava Ľi ai  Ľae fakatonuhia  Ľaia  Ľoku  Ľi he tui.  
\v 8 Ko e tui na Ľe talangofua ai  Ľa  ĽEpalahame,  Ľi hono ui ia ke  Ľalu atu ki ha potu te ne ma Ľu  Ľamui ko e nofo Ľanga; pea na Ľa ne fononga atu,  Ľo  Ľikai te ne  Ľilo pe ko  Ľene  Ľalu ki fńď.  
\v 9 Ko e tui na Ľa ne  ĽńĀunofo ai  Ľi he fonua  Ľoe tala Ľofa,  Ľo hangńď ha fonua ta Ľekau ia ki ai,  Ľonau nonofo  Ľi he ngaahi fale fehikitaki fakataha mo  ĽAisake mo Sńďkope,  Ľonau kau fakataha  Ľi he tala Ľofa pe ko ia:  
\v 10 He na Ľe  Ľamanaki  Ľe ia ki ha kolo kuo ai hono ngaahi tu Ľunga,  Ľaia na Ľe langa mo ngaohi  Ľe he  ĽOtua.  
\v 11 Ko e tui na Ľe ma Ľu ai  Ľe Sela  Ľae mńĀlohi ke tuitu Ľia ai ia, pea fanau Ľi  Ľe ia  Ľae tama ka kuo lahi  Ľene motu Ľa, he na Ľa ne pehńď,  Ľoku mo Ľoni ia  Ľaia kuo faka Ľilo.  
\v 12 Ko ia na Ľe tupu ai mei he tokotaha, pea hangńď ia ko ha mate,  Ľae tokolahi ke tatau mo e ngaahi fetu Ľu  Ľoe langi, pea hangńď ko e  Ľone Ľone  Ľi he matńĀtahi  Ľoku ta Ľefa Ľalaua.  
\v 13 Na Ľe mate  Ľakinautolu ni kotoa pńď  Ľi he tui,  Ľo  Ľikai ke nau lava Ľi  Ľae ngaahi tala Ľofa, ka na Ľa nau mamata mama Ľo atu, mo  Ľilo pau ki ai,  Ľo fńĀ Ľufua ia,  Ľonau fakahńĀ ko e kau muli mo e kau  ĽńĀunofo  Ľakinautolu  Ľi he mńĀmani.  
\v 14 He ko kinautolu  Ľoku lea pehńď,  Ľoku nau fakahńĀ totonu,  Ľoku nau kumi ha fonua.  
\v 15 Pea ko e mo Ľoni, ka ne nau tokanga ki he \add fonua \add*ko ia na Ľa nau ha Ľu mei ai, pehńď, ne faingofua pe  Ľenau toe foki atu.  
\v 16 Ka ko eni  Ľoku nau holi ki he \add fonua \add*lelei lahi,  Ľaia  Ľoku  Ľi he langi: ko ia kuo  Ľikai mńĀ  Ľae  ĽOtua  Ľi hono ui ia ko honau  ĽOtua: he kuo ne teuteu  Ľae kolo mo Ľonautolu.  
\v 17 Ko e tui na Ľe feilaulau  Ľaki ai  Ľe  ĽEpalahame  Ľa  ĽAisake,  Ľi hono  Ľahi Ľahi Ľi:  Ľio, ko ia ne ne ma Ľu  Ľae ngaahi tala Ľofa, na Ľa ne feilaulau  Ľaki hono \add foha \add*pe taha na Ľe fakatupu,  
\v 18 ‚ÄĆ ĽAia na Ľe pehńď ki ai, ‚ÄúKo  ĽAisake  Ľe mei ai ho hako:‚ÄĚ  
\v 19 ‚ÄĆ ĽO ne  Ľilo,  Ľoku fa Ľa fai  Ľe he  ĽOtua hono fokotu Ľu mei he mate; pea na Ľa ne ma Ľu ia mei ai foki  Ľi he fakatńĀtńĀ.  
\v 20 Ko e tui ne tńĀpuaki ai  Ľe  ĽAisake  Ľa Sńďkope mo  ĽIsoa  Ľi he ngaahi me Ľa  Ľe hoko mai.  
\v 21 Ko e tui  Ľa Sńďkope,  Ľi he Ľene teu ke mate, na Ľa ne hŇę mo tńĀpuaki ai  Ľae ongo foha  Ľo Siosefa,  Ľi he Ľene fa Ľaki ki hono tokotoko.  
\v 22 Ko e tui  Ľa Siosefa,  Ľi he Ľene teu ke mate, na Ľa ne lea ai ki he  Ľalu  Ľae fńĀnau  Ľa  ĽIsileli;  Ľo ne tuku  Ľae fekau koe Ľuhi ko hono ngaahi hui  Ľo Ľona.  
\v 23 Ko e tui na Ľe fufŇę ai  Ľa MŇćsese  Ľe he Ľene mńĀtu Ľa,  Ľi he mńĀhina  Ľe tolu, koe Ľuhi na Ľa nau  Ľilo ko e tamasi Ľi faka Ľofo Ľofa ia; pea na Ľe  Ľikai te na manavahńď ki he fekau  Ľae tu Ľi.  
\v 24 Ko e tui  Ľa MŇćsese na Ľa ne li Ľaki ai,  Ľi he Ľene lahi, hono ui ia ko e tama  Ľae  Ľofefine  Ľo Felo;  
\v 25 ‚ÄĆ ĽO ne fili mu Ľa ke ne kńĀtaki  Ľae mamahi fakataha mo e kakai  Ľae  ĽOtua,  Ľi he Ľene ma Ľu  Ľae fiefia  Ľoe angahala  Ľo fuoloa si Ľi;  
\v 26 ‚ÄĆ ĽO ne lau  Ľae manuki koe Ľuhi ko Kalaisi ko e koloa lahi hake ia  Ľi he koloa  Ľo  ĽIsipite: he na Ľe sio fakamama Ľu ia ki he totongi.  
\v 27 Ko e tui na Ľa ne li Ľaki ai  Ľa  ĽIsipite,  Ľo  Ľikai manavahńď ki he houhau  Ľae tu Ľi: he na Ľa ne fakakukafi,  Ľo hangńď  Ľoku ne mamata kiate ia  Ľoku ta ĽehńĀmai.  
\v 28 Ko e tui na Ľa ne fai ai  Ľa e \add feilaulau  Ľoe \add*Lakaatu, mo e luluku  Ľoe toto, telia na Ľa ala kiate kinautolu  Ľaia na Ľa ne faka Ľauha  Ľae  Ľuluaki fńĀnau.  
\v 29 Ko e tui na Ľa nau  Ľalu ai  Ľi he Tahi kulokula  Ľo hangńď  Ľi he mŇćmoa:  Ľaia na Ľe  Ľahi Ľahi ke fai  Ľe he kakai  ĽIsipite, pea lŇćmaki ai  Ľakinautolu.  
\v 30 Ko e tui na Ľe holo ai  Ľae ngaahi  Ľa  Ľo Seliko,  Ľi he hili hono takatakai  Ľi he  Ľaho  Ľe fitu.  
\v 31 Ko e tui na Ľe  Ľikai  Ľauha ai  Ľa Lehapi, ko e fefine fe Ľauaki, fakataha mo kinautolu na Ľe  Ľikai tui, ko  Ľene tali lelei pe  Ľae kau mataki.  
\v 32 Pea ko e hńĀ mo  Ľeku lea  Ľe fai? Koe Ľuhi  Ľe tuai  Ľaupito  Ľo kau ka lau kia Kitione, mo Pelaki, mo Samisoni, mo Sefita; mo Tevita foki, mo Samuela, mo e kau palŇćfita:  
\v 33 ‚ÄĆ ĽAkinautolu na Ľe fakavaivai  Ľae ngaahi pule Ľanga  Ľi he tui, mo fai mńĀ Ľoni Ľoni, mo lava Ľi  Ľae ngaahi tala Ľofa, mo tńĀpuni  Ľae ngutu  Ľoe fanga laione,  
\v 34 ‚ÄĆ ĽO fu Ľifu Ľi  Ľae kakaha  Ľoe afi, pea hao  Ľi he mata  Ľoe heletńĀ, pea fakamńĀlohi Ľi  Ľi \add he Ľenau \add*vaivai, na Ľa nau lototo Ľa  Ľi he tau, pea nau tulia  Ľae ngaahi matatau  Ľoe kakai muli.  
\v 35 Na Ľe ma Ľu  Ľe he kau fefine  Ľenau mate kuo fokotu Ľu mo Ľui: pea na Ľe fakamamahi  Ľae ni Ľihi,  Ľo  Ľikai te nau tali  Ľae fakahaofia; kaekehe kenau lava Ľi  Ľae toetu Ľu lelei hake:  
\v 36 Pea na Ľe tŇć ki he ni Ľihi  Ľae  Ľahi Ľahi  Ľoe ngaahi manuki mo e kau Ľimaea,  Ľio,  Ľoe ngaahi ha Ľi mo e nofo fale fakapŇćpula:  
\v 37 Na Ľe tolongaki  Ľaki  Ľae maka  Ľakinautolu, na Ľe kilisi  Ľo fahiua  Ľakinautolu, na Ľe  Ľahi Ľahi Ľi, na Ľe tńĀmate Ľi  Ľaki  Ľae heletńĀ: na Ľa nau  Ľalu fano  Ľi he kili Ľi sipi mo e kili Ľi kosi; kuo masiva, kuo mamahi, kuo ngaohikovi Ľi;  
\v 38 ( ĽAkinautolu na Ľe  Ľikai taau mo mńĀmani ke ma Ľu:) na Ľa nau  Ľalu fano  Ľi he ngaahi toafa, mo e ngaahi mo Ľunga, pea  Ľi he ngaahi  Ľana mo e luo  Ľoe kelekele.  
\v 39 Pea ko e tui na Ľe ma Ľu ai  Ľekinautolu ni kotoa pńď  Ľae ongoongolelei, ka na Ľe  Ľikai lava Ľi  Ľae tala Ľofa:  
\v 40 Ko e me Ľa  Ľi he teuteu  Ľe he  ĽOtua  Ľae me Ľa lelei hake mo Ľotautolu, ke  Ľoua na Ľa fakahaohaoa  Ľakinautolu ta Ľekau ai  Ľakitautolu.   
\c 12  
\cd \it 1 Ko e enginaki ke tui ma Ľuaipńď, ke fa Ľa kńĀtaki, pea angafaka Ľotua. 22 Ko e fakaongolelei  Ľae fuakava fo Ľou  Ľi he fuakava motu Ľa.\it*  
\p
\v 1 Ko ia, ko e me Ľa  Ľi he kńĀpui  Ľakitautolu  Ľe he  Ľao  Ľoe kau fakamo Ľoni tokolahi pehńď, ke tau si Ľaki foki  Ľae me Ľa mamafa kotoa pńď, mo e angahala  Ľoku \add tau \add*mo Ľuangofua ki ai, pea tau felele Ľi  Ľi he fakakukafi  Ľae fakapuepue kuo tofi  Ľi hotau  Ľao.  
\v 2 ‚ÄĆ ĽO sio pe kia Sisu ko e kamata Ľanga mo e ngata Ľanga  Ľoe tui;  Ľaia ne ne kńĀtaki  Ľae pekia  Ľi he  Ľakau, mo ne ta Ľetokanga ki he fakamńĀ, ko e me Ľa  Ľi he fiefia na Ľe tuku  Ľi hono  Ľao, pea kuo nofo eni  Ľi he nima to Ľomata Ľu  Ľoe  Ľafio Ľanga  Ľoe  ĽOtua.  
\v 3 Ke mou tokanga Ľi ia na Ľa ne kńĀtaki  Ľae angatu Ľu pehńď mei he kau angahala kiate ia, telia na Ľa mou fiu mo vaivai  Ľi homou loto.  
\v 4 ‚ÄĆ ĽOku te Ľeki ai ke mou fekuki  Ľo a Ľu ki he mate,  Ľi he fekuki mo e angahala.  
\v 5 Pea kuo ngalo  Ľiate kimoutolu  Ľae akonaki  Ľaia  Ľoku pehńď kiate kimoutolu,  Ľo hangńď ko e fńĀnau, ‚ÄúHoku foha,  Ľoua na Ľa ke ta Ľetokanga Ľi  Ľae tautea mei he  ĽEiki, pe vaivai  Ľi he Ľene valoki Ľi koe:  
\v 6 He ko ia  Ľoku  Ľofa ki ai  Ľae  ĽEiki  Ľoku ne tautea, pea  Ľoku ne te Ľia  Ľae foha kotoa pńď  Ľoku ne ma Ľu.‚ÄĚ  
\v 7 Kapau te mou kńĀtaki  Ľae tautea, pea  Ľoku fai ai  Ľe he  ĽOtua kiate kimoutolu  Ľo taau mo e ngaahi foha; he ko e foha fńď ia  Ľaia  Ľoku  Ľikai ke taute Ľi  Ľe he tamai?  
\v 8 Pea kapau  Ľoku  Ľikai tautea  Ľakimoutolu,  Ľaia  Ľoku totofu ai kotoa pńď, pea ta ko e tupu fe Ľauaki  Ľakimoutolu, pea  Ľoku  Ľikai mo Ľoni ko e ngaahi foha.  
\v 9 Kae Ľuma ĽńĀ na Ľe tautea  Ľakitautolu  Ľe he ngaahi tamai  Ľo hotau sino, pea tau faka Ľapa Ľapa ki ai:  Ľe  Ľikai lahi mu Ľa  Ľetau fakavaivai ki he Tamai  Ľoe ngaahi laumńĀlie, pea mo Ľui?  
\v 10 He ko e mo Ľoni na Ľa nau tautea  Ľo fa Ľiteliha pe  Ľakinautolu  Ľi he  Ľaho si Ľi pe; ka  Ľoku fai  Ľe ia ke  Ľaonga, ke \add tau \add*kau ai  Ľi he Ľene mńĀ Ľoni Ľoni.  
\v 11 Ko eni,  Ľoku  Ľikai ha fiefia lolotonga ha tautea, ka ko e mamahi: hili ange ia  Ľoku tupu  Ľae fua fakamelino  Ľoe mńĀ Ľoni Ľoni kiate kinautolu kuo akonekina ai.  
\v 12 Ko ia ke poupou hake  Ľae nima kuo tńĀupe, mo e fo Ľi tui  Ľoku vaivai;  
\v 13 Pea ngaohi  Ľae  Ľalu Ľanga totonu ki homou va Ľe, telia na Ľa fakahńď Ľi  Ľaia  Ľoku pipiki; kae fakamo Ľui mu Ľa ia.  
\v 14 Tuli ke mou melino mo e kakai kotoa pńď, pea ki he mńĀ Ľoni Ľoni,  Ľaia ka  Ľikai ma Ľu,  Ľe  Ľikai mamata  Ľe ha tangata  Ľe tokotaha ki he  ĽEiki:  
\v 15 ‚ÄĆ ĽO vakavakai lahi telia na Ľa tomui ha taha  Ľi he  Ľalo Ľofa  Ľae  ĽOtua; telia na Ľa ai ha aka kona  Ľe tupu pea fakamamahi Ľi ai \add  Ľakimoutolu\add*, pea  Ľuli Ľi ai  Ľae tokolahi;  
\v 16 Telia na Ľa ai ha taha fe Ľauaki pe ha manuki  Ľoe me Ľa tapu,  Ľo hangńď ko  ĽIsoa,  Ľaia na Ľa ne fakatau hono lelei  Ľoe  Ľuluaki foha  Ľaki  Ľae me Ľakai pe taha.  
\v 17 He  Ľoku mou  Ľilo  Ľi he hili ia, pea ne fiema Ľu  Ľae tńĀpuaki, na Ľe teke Ľi ia: he na Ľe  Ľikai te ne  Ľilo ke liliu  Ľaki hono loto, neongo  Ľa  Ľene kumi ia  Ľi he feinga mo e lo Ľimata.  
\v 18 He  Ľoku  Ľikai ke mou hoko ni ki he mo Ľunga  Ľe fa Ľa alasi,  Ľaia ne vela  Ľaki  Ľae afi, pea ki he  Ľuli Ľuli, mo e fakapo Ľuli, mo e afńĀ,  
\v 19 Pea mo e pńĀ mai  Ľoe me Ľa lea mo e ongo  Ľoe ngaahi lea;  Ľaia na Ľe kole ai  Ľakinautolu na Ľe fanongo ke  Ľoua na Ľa toe lea Ľaki kiate kinautolu:  
\v 20 (He na Ľe  Ľikai te nau fa Ľa tali  Ľaia na Ľe fekau mai, ‚ÄúPea na Ľa mo e manu kapau  Ľe lave ki he mo Ľunga,  Ľe tolongaki ia  Ľaki  Ľae maka, pe hoka Ľi ke  Ľasi  Ľaki  Ľae fo Ľi tao:‚ÄĚ  
\v 21 Pea ko hono fakailifia fau  Ľoe me Ľa na Ľe hńĀ mai, na Ľe pehńď ai  Ľe MŇćsese, ‚Äú ĽOku ou mńĀtu Ľaki manavahńď, mo tetetete:‚ÄĚ)  
\v 22 Ka kuo mou hoko ni ki he mo Ľunga ko Saione, ki he kolo  Ľoe  ĽOtua mo Ľui, ki he SelŇęsalema mei he langi, pea ki he fakataha  Ľoe kau  ĽńĀngelo tokolahi ta Ľefa Ľalaua.  
\v 23 Ki he fakataha Ľanga lahi, pea ko e siasi  Ľoe tangata angatonu kuo fakahaohaoa,  
\v 24 Pea kia Sisu ko e fakalaloa  Ľoe fuakava fo Ľou, pea ki he ta Ľata Ľa  Ľoku luluku,  Ľaia  Ľoku lea Ľaki  Ľae ngaahi me Ľa lelei lahi  Ľi \add he toto  Ľo \add* ĽEpeli.  
\v 25 Vakai ke  Ľoua na Ľa mou ta Ľetokanga Ľi ia  Ľoku folofola. He kapau na Ľe  Ľikai hao  Ľakinautolu na Ľe ta Ľetokanga Ľi ia na Ľe lea  Ľi mńĀmani,  Ľe fńďfee Ľi  Ľakitautolu,  Ľo kapau te tau tafoki meiate ia  Ľoku mei he langi?  
\v 26 ‚ÄĆ ĽAia na Ľe lulululu  Ľa mńĀmani  Ľe hono le Ľo  Ľi he kuonga ko ia: ka kuo tala Ľofa eni,  Ľo pehńď, ‚ÄúKo e toe taha teu lulululu kae  Ľikai ngata ki mńĀmani pe, ka ko e langi foki.‚ÄĚ  
\v 27 Pea ko e pehńď, ‚ÄúKo e toe taha,‚ÄĚ ko e fakahńĀ  Ľoe hiki  Ľoe ngaahi me Ľa ko ia kuo lulu Ľi,  Ľo taau mo e ngaahi me Ľa kuo ngaohi, koe Ľuhi ke tu Ľuma Ľu pe  Ľae ngaahi me Ľa  Ľoku  Ľikai fa Ľa lulu Ľi.  
\v 28 Ko ia  Ľi he Ľetau ma Ľu  Ľae pule Ľanga,  Ľe  Ľikai fa Ľa lulu Ľi, ke tau kuku ma Ľu mo e  Ľofa,  Ľaia ke tau tauhi  Ľaki  Ľae  ĽOtua ke  Ľaonga,  Ľi he faka Ľapa Ľapa mo e manavahńď:  
\v 29 He ko e afi faka Ľauha  Ľa hotau  ĽOtua.   
\c 13  
\cd \it 1 Ko e ngaahi akonaki ki he fe Ľofa Ľaki, 4 Ki he mo Ľui angatonu, 5 Ke  Ľoua  Ľe manumanu, 7 Ke tokanga Ľi  Ľae kau faifekau  Ľae  ĽOtua, 9 Ke vakai ki he ngaahi akonaki fo Ľou, 10 Ke fakahńĀ  Ľa Kalaisi, 16 Ke fai  Ľae foaki  Ľofa, 17 Ke talangofua ki he kau tataki, 18 Ke hŇęfia  Ľae  Ľaposetolo. 20 Ko hono faka Ľosi.\it*  
\p
\v 1 Ke tu Ľuma Ľu pe  Ľae fe Ľofo Ľofani fakakńĀinga.  
\v 2 ‚ÄĆ ĽOua na Ľa ngalo ke fakaafe  Ľae kakai muli: he kuo fakaafe ai  Ľe he ni Ľihi  Ľae kau  ĽńĀngelo  Ľi he ta Ľe Ľilo.  
\v 3 Manatu Ľi  Ľakinautolu  Ľoku mo Ľua  Ľi he ha Ľi,  Ľo hangńď kuo ha Ľisia mo kimoutolu; mo kinautolu  Ľoku ngaohikovi Ľi,  Ľo hangńď ko ho Ľomou kei  Ľi he sino foki.  
\v 4 Ko e fakama Ľu mali mo e mohenga ta Ľe Ľuli Ľi,  Ľoku lelei ia ki he kakai kotoa pńď, ka koe kau fe Ľauaki mo e kau tono fefine  Ľe fakamaau  Ľe he  ĽOtua.  
\v 5 Ke ta Ľemanumanu \add ho Ľomou \add* ĽulungńĀanga; pea mou fiemńĀlie  Ľi he ngaahi me Ľa  Ľoku mou ma Ľu: he kuo pehńď mai  Ľe ia, ‚ÄúE  Ľikai te u li Ľaki koe, pea  Ľe  Ľikai te u  Ľalu  Ľiate koe.‚ÄĚ  
\v 6 Ko ia  Ľoku tau lea mńĀlohi ai, ‚ÄúKo hoku tokoni  Ľae  ĽEiki pea  Ľe  Ľikai te u manavahńď ki ha me Ľa  Ľe fai  Ľe he tangata kiate au.‚ÄĚ  
\v 7 Manatu Ľi  Ľa homou kau fakahinohino,  Ľakinautolu na Ľe lea Ľaki  Ľae folofola  Ľae  ĽOtua kiate kimoutolu, pea fa Ľifa Ľitaki ki he Ľenau tui,  Ľo fakatokanga ki he ngata Ľanga  Ľo  Ľenau  ĽulungńĀanga.  
\v 8 Ko Sisu Kalaisi  Ľoku tatau  Ľi he  Ľaneafi, mo e  Ľaho ni, pea ta Ľengata.  
\v 9 Ke  Ľoua na Ľa fe Ľave Ľaki fano  Ľakimoutolu  Ľe he ngaahi akonaki  Ľoku kehekehe hono anga mo fo Ľou. He ko e me Ľa lelei ke tu Ľuma Ľu  Ľae loto  Ľi he  Ľofa;  Ľikai  Ľi he ngaahi me Ľakai,  Ľaia na Ľe  Ľikai  Ľaonga kiate kinautolu na Ľe mo Ľua ki ai.  
\v 10 ‚ÄĆ ĽOku ai  Ľetau  Ľesifeilaulau,  Ľaia  Ľoku  Ľikai totonu ke kai mei ai  Ľekinautolu  Ľoku tauhi  Ľi he fale fehikitaki.  
\v 11 Kae Ľuma ĽńĀ ia,  Ľoku tutu  Ľi tua ĽńĀ kolo  Ľae sino  Ľoe fanga manu ko ia,  Ľaia  Ľoku  Ľomi honau toto  Ľe he taula Ľeiki lahi ki he potu tapu, koe Ľuhi ko e angahala.  
\v 12 Ko ia na Ľe mamahi foki  Ľa Sisu,  Ľi he tua ĽńĀ kolo, koe Ľuhi ke ne fakamńĀ Ľoni Ľoni  Ľae kakai  Ľaki hono ta Ľata Ľa  Ľo Ľona.  
\v 13 Ko ia ke tau  Ľalu atu kiate ia kitua ĽńĀ kolo,  Ľo fua hono manuki.  
\v 14 He  Ľoku  Ľikai ma Ľu  Ľekitautolu  Ľi heni ha kolo  Ľe tu Ľuma Ľu, ka  Ľoku tau kumi ki ha taha  Ľe hoko.  
\v 15 Ko ia ke tau  Ľatu  Ľiate ia  Ľae feilaulau  Ľoe fakafeta Ľi ki he  ĽOtua  Ľo ma Ľuaipńď,  Ľaia ko e fua  Ľoe loungutu  Ľoka atu ai  Ľae fakafeta Ľi ki hono huafa.  
\v 16 Ka ko e fai lelei, mo e foaki, ke  Ľoua na Ľa ngalo: he ko e ngaahi feilaulau pehńď  Ľoku lelei Ľia ai  Ľae  ĽOtua.  
\v 17 Mou talangofua kiate kinautolu  Ľoku fakahinohino  Ľakimoutolu, pea mou fakavaivai: he  Ľoku nau le Ľohi homou laumńĀlie, he te nau fakamatala ki ai, pea koe Ľuhi ke nau fai ia  Ľi he fiefia, kae Ľoua na Ľa  Ľi he mamahi: he  Ľoku ta Ľe Ľaonga ia kiate kimoutolu.  
\v 18 HŇęfia  Ľakimautolu: he  Ľoku mau  Ľilo kuo  Ľiate kimautolu  Ľae  Ľatamai lelei, pea  Ľoku mau loto ke mo Ľui angatonu  Ľi he me Ľa kotoa pńď.  
\v 19 Ka  Ľoku ou kole ke mou tokanga lahi ki ai, koe Ľuhi ke tuku au ke vave kiate kimoutolu.  
\v 20 Ko eni, ko e  ĽOtua  Ľoe monŇę Ľia, na Ľa ne toe  Ľomi mei he pekia  Ľa hotau  ĽEiki ko Sisu, ko e tauhi lahi  Ľoe fanga sipi  Ľi he ta Ľata Ľa  Ľoe fuakava ta Ľengata.  
\v 21 ‚ÄĆ ĽOfa ke ne ngaohi  Ľakimoutolu ke mou haohaoa  Ľi he ngaue lelei kotoa pńď, ke fai hono finangalo,  Ľo ne fai  Ľiate kimoutolu  Ľaia  Ľoku lelei  Ľi hono  Ľao,  Ľia Sisu Kalaisi; ke  Ľiate ia  Ľae ongoongolelei  Ľo ta Ľengata pea ta Ľengata.  ĽEmeni.  
\v 22 Pea  Ľoku ou kole kiate kimoutolu,  Ľe kńĀinga, mou tali  Ľae lea  Ľoe akonaki ni: he kuo u tohi  Ľae tohi kiate kimoutolu  Ľi he ngaahi lea si Ľi pe.  
\v 23 ‚ÄĆ ĽOku mou  Ľilo kuo mama Ľo atu hotau kńĀinga ko Timote;  Ľa ia, ka vave  Ľene ha Ľu, te ma mamata mo ia kiate kimoutolu.  
\v 24 ‚ÄĆ ĽOfa atu kiate kinautolu kotoa pńď  Ľoku fakahinohino  Ľakimoutolu, mo e kńĀinga mńĀ Ľoni Ľoni kotoa pńď.  ĽOku  Ľofa atu kiate kimoutolu kotoa  Ľakinautolu  Ľi  ĽItali.  
\v 25 Ke  Ľiate kimoutolu kotoa pńď  Ľae  Ľalo Ľofa.  ĽEmeni.   