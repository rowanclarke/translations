\id 1JN  
\h ÁR NDU̱I AR XUWA 
\toc1 ÁR NDU̱I AR XUWA Ár ndu̱i ar he̱ꞌmi bi ꞌyotꞌa ar Xuwa 
\toc2 ÁR NDU̱I AR XUWA 
\toc3 1 Jn. 
\mt1 ÁR NDU̱I AR XUWA 
\mt2 Ár ndu̱i ar he̱ꞌmi bi ꞌyotꞌa ar Xuwa 
\c 1  
\s1 Ar mhö unga ar te 
\p  
\v 1 Nöꞌö togo mi ꞌbu̱i núꞌmu̱ hinte mi jawa har ximha̱i, ne hinte mi janu̱ mhetsꞌi, nunar mhönu̱ ungar te, getꞌö xta o̱he ne xta handase̱he, da kꞌöthe ne da tha̱ñhe. 
\p  
\v 2 Nunar mhö ungar te mi ꞌbu̱hwi ar Dada, ba e bi njöꞌi, ne da hanthe, gehnu̱ di da̱he majöni, ne di xiꞌahe nunar te hiñhamꞌu̱ da götsꞌi. 
\p  
\v 3 Nöꞌö xta hanthe ne xta o̱he, gehnu̱ di xiꞌahe. Njapꞌu̱ gi pöhu̱ nöꞌö di pöje nꞌehe, ne ga pe̱ꞌsu̱ nꞌadar mfeni mahye̱giwi Jö ar Dada ne ar Hesukristo ár Tꞌu̱. 
\p  
\v 4 Jange di otꞌaꞌihu̱ nuya mhöyu̱, ne njapꞌu̱ da nxo̱ge ri johyahu̱. 
\s1 Jö gehnu̱ ar hyatsꞌi 
\p  
\v 5 Nunar mhönu̱ di xiꞌahe, gese̱ꞌö bi xikagihe, enö njawa: Jö gehnu̱ ar hyatsꞌi. Habu̱ ꞌbu̱ꞌö hinte ma ꞌbe̱xui janu̱. 
\p  
\v 6 Nuꞌmu̱ di eñhu̱ di ꞌbu̱hwihu̱ ar tsi Dada ne di ꞌyohu̱ har ꞌbe̱xui, dar nemhñöhu̱, ne hindi te̱ñhu̱ nöꞌö majöni. 
\p  
\v 7 Ha nuꞌmu̱ ga ꞌyohu̱ har hyatsꞌi ngu ar tsi Dada ꞌbu̱ har hyatsꞌi, nꞌadar mfeni di ꞌbu̱hu̱ nꞌa ngu nꞌa ꞌmu̱, ne ár ji ar tsi Hmu Hesukristo ár Tꞌu̱ Jö da xu̱gagihu̱ gatho ma tsꞌokihu̱. 
\p  
\v 8 Nuꞌmu̱ ga eñhu̱ hindi o̱thu̱ ar tsꞌoki, di nkase̱hu̱ ne hindi te̱ñhu̱ nöꞌö majöni. 
\p  
\v 9 Nuꞌmu̱ ga da̱twabihu̱ ma tsꞌokihu̱ Jö, nöꞌö hingi yotꞌa ár ne, da ꞌyo̱tꞌa nöꞌö xi mö. Ne di ka̱xmbenihu̱ da pumgagihu̱, ne da xu̱ga gatho ma tsꞌokihu̱. 
\p  
\v 10 Nuꞌmu̱ di eñhu̱ hinxta o̱thu̱ nꞌar tsꞌoki, po̱ntho di xipabihu̱ ar tsi Dada ar nemhñö, ne hinxta pe̱ꞌspabihu̱ ár mhö ha ma mu̱ihu̱. 
\c 2  
\s1 Ar tsi Hmu Hesukristo go ꞌba̱ made ñöngagihu̱ 
\p  
\v 1 Ma tsi bötsiꞌihu̱, di otꞌahu̱ nunar he̱ꞌminu̱, ngetho hindi ne gi ntsꞌoju̱. Ha nuꞌmu̱ bi hya̱ꞌahu̱, di ꞌñehu̱ togo ñöngagihu̱ hár nthandi Jö. Gehnu̱ ar Hesukristo ngu ma ñöntehu̱, hinte ma tsꞌoki xi ꞌyo̱tꞌe. 
\p  
\v 2 Bi unse̱ ár te ngu nꞌar mꞌo̱ñho̱, ne bi mpumgagihu̱ gatho ma tsꞌokihu̱. Hinge ho̱nse̱ nuju̱, gatho nu maꞌra ꞌbu̱kwa har ximha̱i nꞌehe. 
\p  
\v 3 Njanu̱ da nhekitho ha di pöhu̱ Jö wa hinꞌö, nuꞌmu̱ di o̱thu̱ nöꞌö te ꞌbe̱pkagihu̱. 
\p  
\v 4 Nuꞌmu̱ nꞌa togo da ꞌñenö: Nuga di pö ar tsi Hmu, ne hingi o̱tꞌa nöꞌö xi ꞌbe̱pkagihu̱ Jö, nꞌar kate ne hingi pe̱ꞌsa nöꞌö majöni hár mu̱i. 
\p  
\v 5 Ha nöꞌö togo da ꞌyo̱tꞌa nöꞌö xi ꞌbe̱pkagihu̱, majöni xi ñuxa ár mhöte Jö hár mu̱i. Njapꞌu̱ hö, di pöhu̱ di ꞌbu̱hwihu̱ꞌö. 
\p  
\v 6 Nöꞌö togo enö hyaxꞌmu̱ ꞌbu̱hwi Jö, mahyoni da mꞌu̱i ngu bi mꞌu̱ ar tsi Hmu Hesukristo. 
\s1 Ar ꞌraꞌyo ꞌbe̱pate 
\p  
\v 7 Tsi kuhu̱, hindi otꞌa nꞌar ꞌraꞌyo ꞌbe̱pate ga pe̱ñꞌahu̱, ho̱nse̱ di bempꞌahu̱ nöꞌö xki nsiꞌahu̱ har ndu̱i. Nunar ꞌbe̱patenu̱ getꞌö ngu nuna xka ꞌyo̱hu̱. 
\p  
\v 8 Mödi hö, ma ga xiꞌahu̱ nꞌar ꞌraꞌyo ꞌbe̱pate gehnu̱ majöni, bi ñꞌuꞌö ne nupya di ꞌñuhu̱ nꞌehe. Ngetho ar ꞌbe̱xui ma da thogi, ne nunar ñotꞌi majöni fu̱di ungar hyatsꞌi. 
\p  
\v 9 Nöꞌö togo enö ꞌbu̱ har hyatsꞌi ne u̱tsa ár ku, ꞌbu̱ta har ꞌbe̱xuiꞌö. 
\p  
\v 10 Nöꞌö togo mö ár ku, hyaxꞌmu̱ ꞌbu̱ har hyatsꞌi, ne hinda ma da nthe̱wi ar mfetsꞌe. 
\p  
\v 11 Ha nöꞌö togo u̱tsa ár ku, ꞌbu̱ta har ꞌbe̱xui ne ja ꞌyonu̱tho. Ne hingi pödi habu̱ di ma, ngetho ar ꞌbe̱xui hingi he̱gi da hyandi. 
\p  
\v 12 Ma tsi bötsiꞌihu̱, di pe̱ñꞌahu̱ nunar he̱ꞌminu̱, ngetho hár thuhu ar tsi Hmu Hesu xi mpumpꞌa ri tsꞌokihu̱. 
\p  
\v 13 Di otꞌahu̱ dadahu̱, ngetho gi pöhu̱ nöꞌö togo mi ꞌbu̱i núꞌmu̱ hinte mi otho. Di otꞌahu̱ bötsithohu̱, ngetho xka töhu̱ ar tsꞌondöhi. 
\p Di otꞌahu̱ ma tsi bötsiꞌihu̱, ngetho xka pöhu̱ ar Dada. 
\p  
\v 14 Xta otꞌahu̱ dadahu̱, xka pöhu̱ nöꞌö togo mi ꞌbu̱i núꞌmu̱ hinte mi otho. Xta otꞌahu̱ gi bötsithohu̱, ngetho xka ze̱ta ri jamfihu̱, ne xka töhu̱ ar tsꞌondöhi ga te̱ñhu̱ ár mhö Jö xka kwathu̱ ha ri mu̱ihu̱. 
\p  
\v 15 Yo gi möhu̱ ar ximha̱i ne nuya te jawa. Nu togo mö ar ximha̱i, hingi pe̱ꞌspa ár mhöte Jö ar Dada. 
\p  
\v 16 Ngetho gatho nöꞌö te ja har ximha̱i, ngu ya tsꞌonhe benga ya jöꞌi ne handi, ne ar ñꞌetsꞌi, hingi pe̱hna Jöyu̱, go unga ar ximha̱i. 
\p  
\v 17 Ar ximha̱i ne yá tsꞌonhe ma da thotho, ha nuꞌu̱ togo o̱tꞌa nöꞌö ne Jö, ma da mꞌu̱ nꞌar mꞌu̱i hiñhamꞌu̱ da götsꞌi. 
\s1 Nöꞌö togo ne da bëpa ár nsu ar Hesukristo 
\p  
\v 18 Ma tsi bötsiꞌihu̱, di ꞌbu̱hu̱pya ya ngöxapa. Ngu xka ꞌyo̱hu̱ ma nda e nꞌa togo nda nto̱xkwi ar tsi Hmu Hesukritso, ne nupya ja nze̱ye̱ togo nto̱xkwi. Jange di pöhu̱ xi zo̱ ya ngöxapa. 
\p  
\v 19 Xi ꞌwege xi hye̱ju̱, ngetho hinxki jamfi xiñho ngu xta jamfihu̱. Nuꞌmu̱ xi jamfihmö xiñhoꞌu̱, hinxi ꞌwehmöꞌu̱. Ne xi ꞌwege, njapu̱ da nheki hinga gatho nguju̱ di nꞌatꞌwihu̱ ar tsi Hmu. 
\p  
\v 20 Ha nuꞌahu̱ hingi njahu̱pꞌu̱, ngetho xi tꞌaꞌahu̱ ár Hñö Jö, jange gi pöhu̱ xiñho gathoyu̱. 
\p  
\v 21 Hindi pe̱ñꞌahu̱ nunar he̱ꞌminu̱ ngu nuꞌu̱ hingi pö nöꞌö majöni. Di otꞌi ngetho gi pöhu̱, ha nor nhemhñö hindi ꞌñe habu̱ ja nöꞌö majöni. 
\p  
\v 22 Togo ar nemhñö. Ar nemhñö nöꞌö togo ko̱nga ar Hesu gehnu̱ ar Kristo. Nuyu̱ yá ñꞌu̱ni ar tsi Hmu, ngu gatho nuꞌu̱ togo ko̱nga ar Dada ne ár Tꞌu̱. 
\p  
\v 23 Gatho nuꞌu̱ togo ko̱nga ár Tꞌu̱ Jö, hingi pe̱ꞌsa ar Dada ha yá mu̱i. Nöꞌö togo da̱majöni ár Tꞌu̱ Jö, pe̱ꞌspa ár Dada nꞌehe. 
\p  
\v 24 Yo ma gi hye̱hu̱pꞌu̱ nöꞌö xka pöhu̱ ár ndu̱i. Nuꞌmu̱ hingi hye̱hu̱pꞌu̱, gi ꞌbu̱hwihu̱ ár Tꞌu̱ ne ar Dada. 
\p  
\v 25 Ne gehnu̱ ar ñhötꞌi bi ñötkagihu̱: ar te hiñhamꞌu̱ da götsꞌi. 
\p  
\v 26 Di otꞌahu̱ tengu yá ꞌbe̱fi nuꞌu̱ ne da kaꞌahu̱. 
\p  
\v 27 Ha nunár Hñö Jö xi ꞌraꞌahu̱ ar tsi Hmu, gehnu̱ ꞌbu̱ ha ri mu̱ihu̱. Ne hinga mahyoni togo da utꞌahu̱, ngetho gese̱ꞌö go xi utꞌahu̱, ne mönga majöni. ꞌBu̱hwihu̱ ar tsi Hmu ngu xi utꞌahu̱ꞌö. 
\p  
\v 28 Ha nupya ma tsi bötsiꞌihu̱, ꞌbu̱hwihu̱ nꞌar hogamꞌu̱i ar tsi Hmu, ne núꞌmu̱ xta ñꞌudi hinga ntsa̱hu̱, ne xta pengi hinga ꞌbe̱ ma tsa̱hu̱ ga ꞌwehu̱. 
\p  
\v 29 Nuꞌmu̱ gi pöhu̱ ar tsi Hmu Hesukristo pe̱ꞌsa nꞌar hogamu̱i, pöhu̱ nꞌehe, gatho nuꞌu̱ pe̱ꞌsa ar hogamu̱i go yá bötsi Jö. 
\c 3  
\s1 Yá bötsigihu̱ Jö 
\p  
\v 1 Beñhu̱ tengu xi mökagihu̱ Jö, bi ꞌñengagihu̱ yá bötsigihu̱. Jange nuꞌu̱ togo hingi jamfi, hingi pöju̱, ngu himbi böꞌö. 
\p  
\v 2 Ma tsi kuhu̱, nupya yá bötsigihu̱ Jö, mödi hindi pöthu̱ xiñho tengu nor mꞌu̱i ma ga pe̱ꞌsu̱ mꞌe̱fa. Nöꞌö di pöhu̱ hö, núꞌmu̱ xta epꞌu̱, ma ga ñhe̱hwihu̱ ngetho ma ga hanthu̱ tenguꞌö. 
\p  
\v 3 Ne gatho nuꞌu̱ togo di to̱ꞌmhu̱ da njapꞌu̱, hyaxꞌmu̱ di umba ma mu̱ihu̱ da tꞌaxkagihu̱ ngu xintꞌaxiꞌö. 
\p  
\v 4 Gatho nuꞌu̱ togo o̱tꞌa ya tsꞌoki, tsꞌokwa yá ꞌbe̱pate Jö, ngetho nꞌar tsꞌoki hinda ꞌyo̱ta ya ꞌbe̱pate. 
\p  
\v 5 Ne gi pöhu̱ xiñho, ar tsi Hmu ba ekwa bi hñögagihu̱ ma tsꞌokihu̱, ne nöꞌö hinte ma tsꞌoki bi ꞌyo̱tꞌe. 
\p  
\v 6 Gatho nuꞌu̱ togo ꞌbu̱hwi ar tsi Hmu, hingi o̱tꞌa ya tsꞌoki. Ha nuꞌu̱ o̱tꞌatho ya tsꞌoki, hinxi hyandi ne hinxi böꞌö. 
\p  
\v 7 Ma tsi bötsiꞌihu̱, yo ma gi ñhe̱hu̱ togo da hya̱ꞌahu̱. Pöhu̱ nunar tsi Hmu ar hogajöꞌi, ne nöꞌö togo ne da ñhogajöꞌi, te̱mbatho ár mꞌu̱iꞌö. 
\p  
\v 8 Nöꞌö togo o̱tꞌa ya tsꞌoki, ár me̱ti ar tsꞌondöhi, ngetho ar tsꞌondöhi hár ndu̱itho o̱tꞌa ya tsꞌoki. Jange ba e ár Tꞌu̱ Jö da jöꞌspa ár ꞌbe̱fi ar tsꞌondöhi. 
\p  
\v 9 Gatho nuꞌu̱ togo xi hñönga ar ꞌraꞌyo te unga Jö, xi ñꞌehwi ar tsꞌoki, ngetho di hñöxa Jö ar Dada. Hingi tsa̱ da gohnu̱tho har tsꞌoki, ngetho xi umba ár te ar tsi Dada. 
\p  
\v 10 Njanu̱ nheki togo yá bötsi Jö ne togo yá bötsi ar tsꞌondöhi: Gatho nuꞌu̱ togo hingi o̱tꞌa nöꞌö xiñho ne hingi mö ár ku, hingyá bötsi Jö. 
\p  
\v 11 Ngetho gehnu̱ ar mhö xka ꞌyo̱hu̱ ya mahamꞌu̱: Ga nmhöhu̱ nꞌa ngu nꞌa. 
\p  
\v 12 Hinga njahu̱ ngu ar Kain, mi te̱nga ar tsꞌondöhi ne bi hyo ár jödö. Bi hyonu̱ ngetho mar ntsꞌoda ár ꞌbe̱fise̱, ha nuyá ꞌbe̱fi ár jödö mar ñho. 
\p  
\v 13 Ma tsi kuhu̱, yo gi tu ri mu̱ihu̱ nuꞌmu̱ da u̱tsaꞌihu̱ nuꞌu̱ hingya gamfi. 
\p  
\v 14 Nuju̱ di pöhu̱ xta po̱ñhu̱ har ndöte ndi ꞌbu̱hu̱, ne xta thohu̱ har te, ngetho di möhu̱ ma kuhu̱. Nu togo hingi mö ár ku, po̱ntho xi du. 
\p  
\v 15 Gatho nuꞌu̱ togo u̱tsa ár ku, gehnu̱ ar hyote. Ne di pöhu̱ nuya hyote hingi pe̱ꞌsa ar te hiñhamꞌu̱ da götsꞌi. 
\p  
\v 16 Ar tsi Hmu Hesukristo bi utkagihu̱ ndana ar mhöte majöni núꞌmu̱ mi po̱kagihu̱ bi unse̱ ár te. Nuju̱ nꞌehe ga e̱nthu̱ ma tehu̱ ga homfu̱ yá ñho ma kuhu̱. 
\p  
\v 17 Nuꞌmu̱ nꞌa togo pe̱ꞌsa ya ñho, ne handa ár ñꞌohu̱ hinte pe̱tsꞌi, ne hinte da umbabi, hanja da nheki pe̱ꞌspa ár mhöte Jö ꞌmu̱. 
\p  
\v 18 Ma tsi bötsiꞌihu̱, hinge ma ga mhöhu̱ di oxta mañö. Ma ga ñꞌu ma mhötehu̱ di o̱thwu̱ ar ñho ma kuhu̱ di po̱nga ha ma mu̱ihu̱. 
\p  
\v 19 Njapꞌu̱ di pöhu̱ tsixkagihu̱ nöꞌö majöni, ne hinte di tuka ma mu̱ihu̱ hár nthandi Jö. 
\p  
\v 20 Ha nuꞌmu̱ tsu̱ka ma mu̱ihu̱ xikagihu̱ hindi ꞌbu̱hu̱ xiñho hár nthandiꞌö, Jö töpa ár mfödi ma mu̱ihu̱, ne pö gatho. 
\p  
\v 21 Ma tsi hmöka kuhu̱, nuꞌmu̱ hingi tsu̱ka ma mu̱ihu̱, hinga ntsuhu̱ ga ꞌbu̱hu̱ hár nthandi Jö. 
\p  
\v 22 Ne gatho nöꞌö te ga a̱fu̱, ga höñhu̱, ngetho di o̱thwu̱ yá ꞌbe̱pate, ne di pe̱hu̱ nöꞌö numañhoꞌö. 
\p  
\v 23 Ne go gehnu̱ ár ꞌbe̱pate Jö, ga jamfibihu̱ ár Tꞌu̱ Hesukristo, ne ga nmhöhu̱ nꞌa ngu nꞌa, jangu xi ꞌbe̱pkagihu̱. 
\p  
\v 24 Nöꞌö togo o̱ta ngu xi ꞌbe̱pkagihu̱ Jö, ꞌbu̱hwiꞌö. Di pöhu̱ xiñho di ꞌbu̱hwihu̱, ngetho xi ꞌrakagihu̱ ár Hñö. 
\c 4  
\s1 Nuꞌu̱ togo hömpa ár Hñö Jö ne nuꞌu̱ togo hömpa ár hñö ar tsꞌondöhi 
\p  
\v 1 Tsi hmöka kuhu̱, yo gi jamfibihu̱ gatho nuꞌu̱ togo ñö. Hyanthu̱ mꞌe̱tꞌo ha hömpa ár Hñö Jö wa hinꞌö, ngetho nze̱ye̱ ya kate mꞌe̱hni xi nxanga har ximha̱i. 
\p  
\v 2 Njanu̱ ma gi pöhu̱ ha hömpa ár Hñö Jö wa hinꞌö: Gatho nuꞌu̱ enö, ar tsi Hmu Hesukristo ba e bi njöꞌi, xi me̱hna Jö. 
\p  
\v 3 Ne gatho nuya ko̱nga ar tsi Hmu Hesukristo ba e bi njöꞌi, hingo xpa pe̱hna Jö. Nunu̱ ár me̱ti ár ñꞌu̱ni ar tsi Hmu xka ꞌyo̱hu̱ nda ehe, ne di xiꞌahu̱ ꞌbu̱kwapya har ximha̱i. 
\p  
\v 4 Ma tsi bötsiꞌihu̱, yá me̱tiꞌihu̱ Jö xka ntötehu̱, ngetho nöꞌö togo ꞌbu̱ ha ma mu̱ihu̱ töpa ár tsꞌe̱di nöꞌö togo ꞌbu̱kwa har ximha̱i. 
\p  
\v 5 Nuyu̱ ya meximha̱itho ne mönga gatho nöꞌö te jawa, ha nuyá mimeximha̱iwi o̱xa nöꞌö te möñꞌu̱. 
\p  
\v 6 Nuju̱ yá me̱tigihu̱ Jö, nuꞌu̱ togo pö Jö o̱xa nöꞌö di xifu̱. Ne nuꞌu̱ hingyá me̱ti Jö hingi o̱xa nöꞌö di xifu̱. Njapꞌu̱ di pöhu̱ togo mönga majöni ne togo mönga ar nhemhñö. 
\s1 Jö xa möte 
\p  
\v 7 Ma tsi hmöka kuhu̱, ma ga nmhöhu̱ nꞌa ngu nꞌa, ngetho ar mhöte gor me̱ti Jö, ne gatho nuꞌu̱ möte gehyu̱ yá bötsi Jö, ne pödi togoꞌö. 
\p  
\v 8 Nöꞌö togo u̱tsa ár ku, hinxi bö Jö, ngetho Jö xa möte. 
\p  
\v 9 Njanu̱ bi utkagihu̱ Jö, go ba pe̱nkwa har ximha̱i nöꞌö nꞌase̱ ár Tꞌu̱, bi du, ne njapꞌu̱ bi ꞌraju̱ ar ꞌraꞌyo te. 
\p  
\v 10 Ma ga xiꞌahu̱ ndana ar mhöte majöni: Nuju̱ hinge da möhu̱ Jö, go bi mökagihu̱. Jange ba pe̱hna ár Tꞌu̱ bi unga ár te ngu nꞌar mꞌo̱ñho̱, ne njapꞌu̱ xi mpumgagihu̱ ma tsꞌokihu̱. 
\p  
\v 11 Ma tsi hmöka kuhu̱, nuꞌmu̱ Jö bi mökagihu̱ njapꞌu̱, ma ga nmhöhu̱ nꞌa ngu nꞌa nꞌehe. 
\p  
\v 12 Hinto xi hyanda Jö, ha nuꞌmu̱ ga nmhöhu̱ nꞌa ngu nꞌa, gese̱ꞌö ꞌbu̱ ha ma mu̱ihu̱, ne ár mhöte xi nxo̱ge ha ma mu̱ihu̱. 
\p  
\v 13 Di pöhu̱ di ꞌbu̱hwihu̱, ngetho xi ꞌrakagihu̱ ár Hñö. 
\p  
\v 14 Ha nuje xta hanthe ne di da̱he majöni, Jö ar Dada xpa pe̱hna ár Tꞌu̱, gehnu̱ ár Po̱ho̱te ya meximha̱i. 
\p  
\v 15 Gatho nuꞌu̱ togo da̱majöni ar Hesu ár Tꞌu̱ Jö, nuyu̱ ꞌbu̱hwi Jö. 
\p  
\v 16 Ne nuju̱ xta pöhu̱ ne xta jamfihu̱ nunar mhöte pe̱ꞌskagihu̱ Jö. Jö xa möte, ne gatho nuꞌu̱ togo möte ꞌbu̱hwi Jö. 
\p  
\v 17 Njapꞌu̱ xi ñuxa ár mhöte ha ma mu̱ihu̱, ne nu xta göxa ar ximha̱i ga njohyahu̱ hinga ntsuhu̱, ngetho di hñöxkagihu̱ꞌö di ꞌbu̱hu̱wa har ximha̱i. 
\p  
\v 18 Nuꞌmu̱ xa majöni di pe̱ꞌsu̱ ar mhöte, hiñꞌotho ar ntsu, ngetho ar mhöte majöni höka ar ntsu. Nöꞌö togo ntsu, tsupa ár mfe̱i Jö, ne hinxi ñuxa ár mhöte hár mu̱i. 
\p  
\v 19 Nuju̱ di möhu̱ Jö, ngetho mꞌe̱tꞌo bi mökagihu̱ꞌö. 
\p  
\v 20 Nuꞌmu̱ da ꞌñenga nꞌa: Nuga di mö Jö, ha u̱tsa ár ku, nꞌar nemhñöꞌö. Ngetho nuꞌmu̱ hingi mö ár ku togo handi, hanja da mö Jö togo hinxi hyandi. 
\p  
\v 21 Di pe̱ꞌsu̱ nunar ꞌbe̱patenu̱ xi ꞌrakagihu̱ Jö: Nöꞌö togo mö Jö, mahyoni da mö ár ku nꞌehe. 
\c 5  
\s1 Nunar ñꞌemu̱i tö ar ximha̱i 
\p  
\v 1 Gatho nuꞌu̱ togo ñꞌemu̱i ar tsi Hmu Hesu ngu ar Kristo, gehnu̱ nꞌár bötsi Jö. Ne gatho nuꞌu̱ togo mö ar dada, mötwa yá bötsi nꞌehe. 
\p  
\v 2 Njanu̱ di pöhu̱ di möthwu̱ yá bötsi Jö, nuꞌmu̱ di möhu̱ꞌö ne di o̱thwu̱ nöꞌö xi ꞌbe̱pkagihu̱. 
\p  
\v 3 Nuꞌmu̱ xa majöni di möhu̱ Jö, ga o̱thwu̱ nöꞌö xikagihu̱ ꞌmu̱, ne nöꞌö ꞌbe̱pkagihu̱ hingi hembi ga o̱thu̱. 
\p  
\v 4 Ngetho gatho nuꞌu̱ togo yá bötsi Jö, ho̱maha̱i ar ximha̱i, ne ar ñꞌemu̱i gehnu̱ tö ar ximha̱i. 
\p  
\v 5 Nuꞌu̱ ñꞌemu̱i ar Hesu ár Tꞌu̱ Jö, gehyu̱ xi dö ar ximha̱i. 
\s1 Ár Hñö Jö da̱majöni 
\p  
\v 6 Ar tsi Hmu Hesukristo ba ekwa har ximha̱i, bi ñꞌudi har dehe ne har ji. Hinge ho̱nse̱ har dehe, har ji nꞌehe. Ne ár Hñö Jö da̱majöni, ngetho nunu̱ mönga majöni. 
\p  
\v 7 Ngetho hñu nuꞌu̱ togo da̱majöninu̱ mhetsꞌi: ar Dada, ar Mhö, ne ár Hñö Jö. Gatho hñuyu̱ nꞌatho. 
\p  
\v 8 Ne njapꞌu̱ hñu nuꞌu̱ togo da̱wa majöni har ximha̱i: ár Hñö Jö, ar dehe ne ar ji. Gatho hñuyu̱ nꞌatꞌwu̱ mö. 
\p  
\v 9 Nuꞌmu̱ di ñꞌemu̱ibihu̱ nöꞌö da̱majöni ya jöꞌi, Jö töte ga ñꞌemu̱ibihu̱, ne gese̱nu̱ xi da̱majöni togo ár Tꞌu̱. 
\p  
\v 10 Nöꞌö togo ñꞌemu̱ibi ár Tꞌu̱ Jö, pe̱ꞌsase̱ hár mu̱i nöꞌö xi da̱majöni Jö. Ha nöꞌö togo hinxi ñꞌemu̱i, ho̱xa Jö ar nemhñö, ngetho himbi ñꞌemu̱ibi nöꞌö xi da̱majöni togo ár Tꞌu̱. 
\p  
\v 11 Ne go gehnu̱ ar mhö xi da̱majöni: Jö xi ꞌraju̱ ar te hiñhamꞌu̱ da götsꞌi, ne nunar tenu̱ go unga ár Tꞌu̱. 
\p  
\v 12 Nöꞌö togo pe̱ꞌspa ár Tꞌu̱ Jö hár mu̱i, pe̱ꞌsa ar te hiñhamꞌu̱ da götsꞌi. Ha nöꞌö togo hingi pe̱ꞌspa ár Tꞌu̱, hingi to̱ꞌma ar te hiñhamꞌu̱ da götsꞌi. 
\s1 Ar hoga mfödi tꞌumba nuꞌu̱ togo pe̱ꞌsa ar te hiñhamꞌu̱ da götsꞌi 
\p  
\v 13 Di otꞌahu̱ nuya mhöyu̱, di xiꞌahu̱ nuꞌahu̱ gi ñꞌemu̱ibihu̱ ár Tꞌu̱ Jö, njapꞌu̱ gi pöhu̱ gi pe̱ꞌsu̱ ar te hiñhamꞌu̱ da götsꞌi. 
\p  
\v 14 Gehnu̱ ar ñꞌemu̱i di pe̱ꞌspabihu̱, nuꞌmu̱ ga a̱fu̱ ngu neꞌö, da ꞌyo̱xkagihu̱. 
\p  
\v 15 Ha nuꞌmu̱ di pöhu̱ da ꞌyo̱xkagihu̱ nöꞌö di a̱pabihu̱, nuꞌmu̱ di ñꞌemu̱ihu̱ gatho nöꞌö xta a̱fu̱, da ꞌraju̱. 
\p  
\v 16 Nöꞌö togo da hyanda ár ku da ꞌyo̱tꞌa nꞌar tsꞌoki hinge nuya da ꞌbe̱ ár te, dá ꞌya̱pa Jö, ne nunu̱ hinda hye̱gi da mꞌe̱di, ho̱nse̱ nuꞌmu̱ ar tsꞌoki hinda thökwa ár te. Ja ya tsꞌoki di ꞌñepa ar ndöte, nuyu̱ hindi enö da tꞌa̱pa Jö da ma̱tsꞌi. 
\p  
\v 17 Mödi gatho nöꞌö hingi ho, ar tsꞌoki, hinga gatho di ꞌñepa ar ndöte. 
\p  
\v 18 Di pöhu̱ gatho nuꞌu̱ togo ꞌbu̱hwi Jö ngu ár Dada, hingi ꞌbu̱ har tsꞌoki, ngetho ár Tꞌu̱ Jö su, ne ar tsꞌondöhi hinte tsa̱ te da japabi. 
\p  
\v 19 Di pöhu̱ nꞌehe, nuju̱ yá me̱tigihu̱ Jö, ha gatho nuya meximha̱i o hár ꞌye̱ ar tsꞌondöhi. 
\p  
\v 20 Ne di pöhu̱ nunár Tꞌu̱ Jö xpa e xi ꞌraju̱ ar hoga mfeni, ne njapꞌu̱ ga pöhu̱ Jö togo majöni. Gehnu̱ di ꞌbu̱hwihu̱, ár Tꞌu̱ Hesukristo, nunar Jö majöni togo unga ar te hiñhamꞌu̱ da götsꞌi. 
\p  
\v 21 Ma tsi bötsiꞌihu̱, yo gi ndöñhu̱ ya tsita empꞌö. Dá njapꞌu̱.