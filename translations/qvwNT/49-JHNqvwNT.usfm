\id JHN Wanca Quechua NT 
\h San Juan 
\toc1 Jesuspa Allin Willacuyninpi Juan Isquirbishan 
\toc2 San Juan 
\toc3 Jn 
\mt1 Jesuspa Allin Willacuyninpi Juan Isquirbishan 
\ip Jesuspa yaćhapacünincunapïta Juanmi “cuyaśha yaćhapacü” nicü cala. Paymi tuquicta licala uyalila Jesus imacunacta yaćhachishantapis, milagrucunacta lulaśhantapis. Waquincunam nipäcun juc isquirbishancunäpi achca watactalä cay libru isquirbisha caśhanta. Juccunäćhu mana cäcunätam cayćhu willaycamanchic. Cayćhümi Jesus niyan: “Ya'am cawsay tantaca; ya'am tutapäcäpa acchin; ya'am puncuca; ya'am allin rasun michïca; ya'am rasun caminuca cawsachimücäpis; ya'am rasun üba plantaca cayá” nil. 
\ip Juan munala llapa nuna Jesusta tuquicta lisiycul chalapaculcaptin wiñay allin cawsayniyu canantam. Chaymari cay librućhu nimanchic “Caycunactam ichá isquirbilá Jesusninchic Aclacuśhanca, Diospa Caćhamuśhan Chulinca caśhanta tantianayquipä. Jinal ćhasquicücunaca wiñay cawsayniyu capäcunayquipä” nil. 
\c 1  
\s1 Mana imapis cayällaptinlämi Diospa Limaynin cayälaña 
\p  
\v 1 Mana imapis cayaptinlämi Diospa Limaynin ñä cayälaña. Paymi Dioswan cala; paytacmi quiquin Dios cala.  
\v 2 Manaläpis ima ayca cayaptinlämi Tayta Dioswan cayälaña.  
\v 3 Paywanmi Tayta Dios lluy lluy imacunactapis camala. Manamá ima aycallapis paywan mana camaśhan'a canchu.  
\v 4-5 Pay quiquintacmi cawsachicüca. Chay cawsayninmi juc acchinuy sumä yanawyayä tutapäćhünuy lluy nunacunäta acchin. Ñatac tutawyayca imanaculpis acchïta manamá llallinmanchu. 
\p  
\v 6 Chaypämi juc nuna Juan śhutiyu Diospi caćhamuśhan cala.  
\v 7 Paymi llapa nuna chalapaculcänanpä acchïpi willaycul tantiaycachï śhamula.  
\v 8 Juan'a manam quiquin acchïchu, sinu'a willacüllam puntamula.  
\v 9 Rasun acchicá llapan nunacunäta acchinanpämi cay pachäman ñaćhapaycayämula. 
\p  
\v 10 Pay'a cay pachäćhu ñam cayälaña. Masqui paywan cay pachäta Dios camayaptinpis, nunacunaca manam lisïtuculcälachu.  
\v 11 Caśhta-masinman śhamuptinpis, paycuná manam ćhasquipäculachu.  
\v 12 Ñatac ćhasquiycul chalapacücunätam ichá, quiquinpa chulinpälä Diosninchic licaycun.  
\v 13 Paycuna manam nunap chulinnüllachu, nï aychap munaśhallanmannu näsïpischu, sinu'a Diospa munayninmannümi. 
\p  
\v 14 Ñatac Limayca nunaman muyulculmi ya'anchicwan cusca cay pachäćhu yaćhala. Rasunpa licapäculá, tantiapäculá Tayta Diospa japallan chulin maynu sumä caśhantam. Paymi sumä-sumä llaquipaynintawan rasuncällacta lisiycachimanchic. 
\p  
\v 15 Paypïmi Bawtisä Juanpis willacula: “Paypïtamari nipäculac: ‘Ipäta śhamücá ya'apïta mas puydïmi; manalä cayaptí pay puntapi cayälañamá’ nil” nin.  
\v 16 Chay sumä-sumä cuyacuyninpïtam yapalcul yapalcul llaquipaycamanchic. 
\p  
\v 17 Ñatac Moisespïmi camachicuycätá ćhasquiycunchic; llaquipäcuycätawan rasuncätam ichá Salbacüninchic Jesuspi ćhasquiycunchic.  
\v 18 Imaypis pipis Tayta Diosta manam licalachu; sinu'a Chulin quiquin Dioswan cusca cawsäcällam paypïta camalachimälanchic. 
\s1 Bawtisä Juantam “¿Pitan cayanqui?” nipäcun 
\r Mt 3.11-12; Mc 1.7-8; Lc 3.15-17 
\p  
\v 19 Má, caynümi pasala Juanwan: Jerusalen malcäćhu cä Israel puydïcunämi sasirdüticunätawan yanapä Levïcunäta Juanman tapuchï caćhala “¿Pitá cayanqui?” nil. 
\p Niptinmi Juan rasuncällacta nila:  
\v 20 “Diospa Caćhamuśhan Salbacücächu manam cayá” nil. 
\p  
\v 21 Niptinmi: “¿Chayurá pitan cayanqui? ¿Willacü Eliaschun?” nin. 
\p Niptinmi: “Manam” nin. 
\p Niptinmi: “Chayurá ¿Diospa willacünin caćhamunancächun?” nin. 
\p Nipäcuptinmi: “Manatacmi” nin. 
\p  
\v 22 Niptinmi: “Chayurá ¿mayanmá cayanqui? Caćhamänïtam niycälinä cayan. ¿Mayan cayá nicuyanquitan?” nin. 
\p  
\v 23 Nipäcuptinmi Diospa willacünin Isaiaspa limaśhanwan Juan nin: “Chunyäninćhu ayaycaćhäcämi ‘Taytanchic ćhämunanpä sumäta allichaculcay’ nishanca cayá”\x + \xo 1:23 \xt Is 40.3\x* nila. 
\p  
\v 24 Niptinmi chay caćhapämuśhan fariseo caśhtacunaca nin:  
\v 25 “Mana Diospa Caćhamuśhan Salbacücäpis, nï Eliaspis, nï Diospa Willacüninpis cayal'a ¿imapïtan-nila bawtisayanqui?” nil. 
\p  
\v 26-27 Nipäcuptinmi: “Ya'a yacullawan bawtisäcällam cayá. Ñatac amcunap ćhawpiquićhu cäcätam ichá mana lisipäcunquilächu. Ipäta śhayämuptinpis uywayninnu śhucuyninpa watullanta pasquiycunäpäpis manam bälïchu” nila.  
\v 28 Lluy caycunam Juan bawtisaśhan Jordan mayup chimpan Betania malcaćhu pasala. 
\s1 Jesusmi Diospa Śhuñaynin 
\p  
\v 29 Chay walantinmi Bawtisä Juan Jesusta śhayämüta licälul: “¡Licapäcuy licapäcuy! ¡Paymá Tayta Diospa Śhuñaynin cayan jinantin nunacunäpa juchanchicta apananpä!  
\v 30 Paymari: ‘Ipäta śhamüca ya'apïta mas munayniyümi; manalä näsiptïpis pay'a cayälañamari’ nipäcuśhacca.  
\v 31 Rasunpa ya'a manalä lisilpis, Israel caśhtacuna lisilpunanpämi yacuwan bawtisanä cala” nin. 
\p  
\v 32 Nishanpïtam: “Quiquïmi licalá Diospa Chuya Ispiritun janay pachäpi palumanuy ji'alpalcamul paypa jananćhu quïdacuśhanta.  
\v 33 Manam ya'apis pay caśhanta lisilächu. Yacuwan bawtisanäpä nimäcämi ichá: ‘Chuya Ispiritu uyaypa mayanmanpis ji'alpamul caśhancämi Chuya Ispirituwan bawtisäca can'a’ nimäla.  
\v 34 Chaymi canan ñawïwan lical Tayta Diospa Chulin rasunpa caśhanta yaćhayá” nila. 
\s1 Jesusmi Pedroctawan Andresta yaćhapacünincunapä aclan 
\p  
\v 35 Chay walantinpis yapa chayćhümi Juan cayalcäla ishcay yaćhapacünincunawan.  
\v 36 Chayninpa Jesus pasayaptinmi Juan licälul: “¡Licapäcuy, licapäcuy! ¡Diospa uwishninmá!” nin.  
\v 37 Chay nïta uyalïlälilmi ishcay yaćhapacünincuna, Jesusta aticuyalcan.  
\v 38 Jesusñatacmi muyulcamul atipäcuśhanta licälul “¿Imactam munapäcunqui?” nin. 
\p Niptinmi: “¿Yaćhachicü taytay, mayćhütan yaćhanqui?” nin. 
\p  
\v 39 Niptinmi: “Lishun-ari licapäcunayquipä” nilcul puśhala. Chay licapäcuśhanćhümi inti patacña cacuyaptin Jesuswan chayćhu quïdaculcäla. 
\p  
\v 40 Chay Juanta uyalil ishcaynin aticäpïmi Simon Pedrop śhullcan Andres jucnin cala.  
\v 41 Andresñatacmi mayurnin Simonman pasacun. Talilculmi: “Diospa Caćhamuśhan Salbacücätam talïlälimú” nin. (Cay griego limayćhu'a “Cristo” nipäcunmi.) 
\p  
\v 42 Nilculmi Jesusman puśhacun. Jesusñatacmi Simonta licälul: “Jonaspa chulin Simonmi am canqui. Cananpi'a Cefasñam śhutiqui can'a” nin. (Cefas'a griego limayćhu'a “Pedro” ninanmi.\f + \fr 1:42 \ft Cefaspis, Pedropis “lumi” ninallanmi.\f*) 
\s1 Jesusmi Felipictawan Natanaelta yaćhapacüninpä ayan 
\p  
\v 43 Chay walantin Galilea-läducta Jesus lishä niyaptinmi Felipiwan tincülul: “Acuchun, lishun” nin.  
\v 44 Cay Felipipis chaynütac Andreswan, Pedropis Betsaida malcayümi capäcula.  
\v 45 Cay Felipim Natanaelta talilcul: “Moisespa camachicuyninćhüpis, Diospa willacünincunapis willaculcäśhan nunätam talïlälí. Pay Josëpa chulin Nazaret-lädu Jesusmi cañä” nin. 
\p  
\v 46 Niptinmi Natanael: “¡Imaytá ampá chay Nazaret malcapïlä allin yalämunman!” nin. 
\p Felipiñatacmi: “Manpis, quiquiqui ñawiquiwan licämunayquipä lishun” nin. 
\p  
\v 47 Chaynu ji'aycuyalcaptinmi Natanaelta licalcul Jesus nin: “Cay śhamücá sumä Israel caśhtalämi; payćhu'a casquicuycunacta manam talinchicchu” nil. 
\p  
\v 48 Niptinmi Natanael: “¿Imanuypatan lisimanqui imanuy caśhätapis?” nin. 
\p Niptinmi: “Manaläpis Felipe willaycuyäśhuptiquilämi, ïgus jaćhap llantuyninćhu cayäśhayquita licalacña” nin. 
\p  
\v 49 Niptinmi: “Yaćhachicü taytáy ¡Diospa Chulinmi am canqui! ¡Israelcunap puydï mandäninchicmá rasunpa canqui!” nin. 
\p  
\v 50 Niptinmi: “ ‘¿Ïgus jaćhap llantuyninćhu cayaptiquim lisilac’ nillaptïchun chalapacayämanquiman? Cayllapïtá sumä jatun lulaycunactalämi licaycunqui” nin. 
\p  
\v 51 Nilculmi: “Rasunpam, janay pachaca quićhalayaptin Diospa caćha anjilnincuna cutiticlaylla Rasun Nunap Chulincäman śhayämüta licapämanqui” nilatac. 
\c 2  
\s1 Jesusmi Caná malcäćhu yacucta bïnuman muyuchin 
\p  
\v 1 Chay quimsa muyunpïtam Galileap Caná malcanćhu juc casaracuy cala. Chaymanmi Jesuspa maman ayachisha cala.  
\v 2 Chaynütacmi Jesuspis llapa yaćhapacünincunapis.  
\v 3 Chayćhu bïnu pishïluptinmi Jesuspa maman payta: “Bïnum lluy pishïlun” nin. 
\p  
\v 4 Niptinmi: “Mamay chay ya'anchictá ¿imam ucamanchic? Manalämi ürá ćhämunlächu” nin. 
\p  
\v 5 Nilcuptinmi bïnu muyuchïcunäta: “Pay nishanta imactapis lulaycäliy” nin. 
\p  
\v 6 Chayćhüñatacmi paycunap custumrinmannuy Diospa chuyanchaculcänanpä süta jatućhaćhä lumipïta luläśha yacu winacucuna cala. (Chaycunam pusä ćhuncapïta aśhta paćhac litru yacu yaycü-cama cala.) 
\p  
\v 7 Jesusñatacmi chay bïnu muyuchïcunäta: “Cay winacücunaman yacucta winapäcuy” nila. Niptinmi llapanman juntay-juntay-camacta winapäcula.  
\v 8 Jinäluptinmi: “Canan ćhacalcul apapäcuy dispinsïräman” niptin apapäcula. 
\p  
\v 9 Chaymi pay mallilcuptin ¡yacuca rasunpa bïnüman muyüñä! Ñatac maypi apamuśha caśhantapis mana yaćhayaptinpis chay apamücunacá yaćhapäculam. Chaymi dispinsïraca casaracücäta ayaycul:  
\v 10 “Lluy nunapis allinnin bïnuctam puntacta upäcun; umachäśhaña cayalcaptinñari juccunäta julapämun. Chaynu cayaptinpis ¡añalláw, caynu allinnintalämá ipa-ipapa am'a ćhulañanquipis!” nin. 
\p  
\v 11 Cay wamä milagructa Galileap Caná malcanćhümi Jesus lulala. Cay jatun lulayninpa sumä cayninta tantiachicuptinmi, yaćhapacünincuna chalapaculcäla. 
\p  
\v 12 Chaypïtam Jesus, mamanwan, śhullcancunawan, yaćhapacünincuna Capernaum malcaman liculcäla. Chayćhümi ishcay quimsa muyuncunanülla caycälila. 
\s1 Diospa chuya wasinpïtam Jesus alapacun 
\r Mt 21.12-13; Mc 11.15-18; Lc 19.45-46 
\p  
\v 13 Ñatac Israelcunaca Egiptopi Libraculcäśhan Fistaca ji'acaycayämuptinmi Jerusalen malcaman Jesus lila.  
\v 14 Chay Diospa chuya wasin patyunman yayculmi imaymana lanticuyäcunacta talïlun: wäcacunacta, uwishcunacta, ulpaycunacta, chaynütac taycapacaycälil illayta cambianacuyäcunactapis.  
\v 15 Chaymi watu-niläpi sumbacta shimpalcul, lluy wäcantinta, uwishnintinta alapacülun. Illay cambiäcunätapis lluy mïsancunacta ticlalcul ticlaculmi illaynincunactapis wichiy-pawälun.  
\v 16 Ulpaycuna lanticücunätapis: “¡Caycunacta wicapapäcuy! ¡Cärayqui cañächun taytäpa wasinta caynu läsamannuy muyulächinayquipä!” nin.  
\v 17 Cayta licalmi yaćhapacünincuna yalpälälila Diospa unay willacünincuna isquirbishanćhu: “Taytäpa wasinpïta sumämi imanacuśhäñapis” nishanta. 
\p  
\v 18 Israelcunañatacmi: “¿Mayanpa caćhaśhatá caynu lulacuyanqui? Rasunpa Diospa pudirnin cayal'a, má, imallactapis licaycälichipämay” nipäcun. 
\p  
\v 19 Niptinmi: “Má, cay Diospa chuya wasinta mana caśhanman muyülächiy-ari. Ya'a quimsa muyunllactamá śhalcachimuśhä” nin. 
\p  
\v 20 Niycüluptinmi: “Cay'a tawa ćhunca sütayu watactalämi ishpichisha cala. ¿Chaychun amlätac quimsa muyunllacta muśhüpi śhalcächinquiman ampá?” nicuyalcan.  
\v 21 Ñatac Diospa yaćhananman tincuchiypa Jesus'a quiquinpa aychanpïmi limala.  
\v 22 Chaypi Jesus wañucuśhanpïta śhalcämuptinñam yaćhapacünincuna yalpälälila caypi limaśhancäta. Jinalmi isquirbishancunämanpis quiquin Jesus limaśhancämanpis chalapaculcäla. 
\p  
\v 23 Chay fistaćhu Jesus milagrucunacta lulaśhanta licapäculmi chay Jerusalenćhu achca nunacuna payman chalapaculcäla.  
\v 24 Chaynu captinpis nunacuna imanuy caśhantapis tuquicta yaćhalmi paycunaman'a Jesus mana chalapaculachu.  
\v 25 Paytá imanuy nunacunaca caśhantapis manam willaycunanlächu quiquin lluy nunacunäpa śhun'unta tuquicta yaćhayaptin'a. 
\c 3  
\s1 Jesuswanmi Nicodemo liman 
\p  
\v 1 Ñatac Nicodemo śhutiyu nuna fariseocunap jucnin puydïninmi Israelcunäćhu cala.  
\v 2 Paymi tutallanpa Jesusman śhamul nin: “Yaćhachicü taytay, tantiapäcümi yaćhachipämänayquipä Dios caćhamuśhuśhayquita. Paywan mana cayal'a cay sumä jatun lulaśhayquitanu'a manaćh pipis lulaycunmanchu” nil. 
\p  
\v 3 Niptinmi Jesus: “Rasunpa mayanpis muśhüpi mana näsimücá, manam Diospa gubirnunćhu cawsanmanchu” nin. 
\p  
\v 4 Niptinmi: “¿Imanuypatan caśhan näsichwan awquishña cayal'a? ¿Icha mamanchicpa patanman yapalächun cutilcuchwan?” nin. 
\p  
\v 5 Niptinmi: “Rasu-rasunpa yacupïtawan Chuya Ispiritupïta mana näsïcá, Diospa gubirnunman manam mayanpis yaycunmanchu.  
\v 6 Imapis cäninman-camallam näsichimun: nunapis caśhanmannüllam; Ispiritupis caśhanmannüllatacmi.  
\v 7 Ama licapayllaman camaychu ‘Muśhüpïmi näsinayqui’ nishäcällawan'a.  
\v 8 Chuya Ispiritup lulaynin waywa-yupaymi: waywacá may munaśhanpapis linmi. Suynayninta uyaliptinchicpis, maypi śhamuśhanta nï mayman lishantapis manam licanchicchu. Chaynümi Chuya Ispiritupis lulan muśhü cawsayta uycuśhan nunacunäwan'a” nin. 
\p  
\v 9 Niptinmi: “¿Chay'a imanuytá?” nin. 
\p  
\v 10 Niptïmi: “Israelcunäpa puydï yaćhachicünin cayal-lächun mana tantianquimanpischu.  
\v 11 Rasunpa yaćhaśhäta licaśhäta willaptïpis, amcuná manam pasapämanquichu.  
\v 12 Ñatac cay pachäćhu cäcunällapïta niyaptïpis mana tantiayalchun, janay pachäćhu cäcunäpïta willaptïlä quirimanquiman ampá.  
\v 13 Caycunapi yaćhaycunanpä manam mayanpis janay pachäman ishpilachu, sinu'a ya'a Rasun Nunap Chulincällam.  
\v 14-15 Ñatac maynümi Moises chunyäninćhu brunsipi culibrayta śhalcachila, chaynümi Rasun Nunap Chulinca śhalcachisha caśhä, ya'aman chalapacamäcunäta wiñay simpri cawsayta uycunäpä. 
\p  
\v 16 “Tayta Diosñatacmari jinantin pachäćhu lluy nunacta sumä-sumä cuyal, japallan cuyay chulinta caćhamula payman chalapacücunaca juchanćhu manaña wañunanpä, aśhwanpa wiña-wiñaypä allin cawsaycäćhüña cawsananpämá.  
\v 17 Tayta Dios cay pachäman chulinta caćhamula manam nunacunäta cäraycunanpächu, sinu'a chay mana allincäpa maquinpi julunanpämi.  
\v 18 Chaymi payman chalapacücunaca juchanpi manaña cäraycuśhañachu can'a. Mana chalapacücunämi ichá cäraycüśhaña cayan, Diospa japallan chulinman mana chalapacuśhanpa.  
\v 19 Cay rasuncäpamá: juc acchinuypis cay pachäman pay śhamula. Jinaptinpis nunacunaca chay mana allin anla lulaynincunaćhu cayalcäśhanpam tutawyäcallacta ama-pacha nipäcula.  
\v 20 Mayanpis mana allinta luläcunacá chay acchïta ćhïnipalmi chayman mana aśhuycunchu lulaynincuna mana camalaycunanpä.  
\v 21 Ñatac rasuncämannuy cawsäcämi ichá, acchïman aśhuycamun, lluy lulaynincuna Diospa munaśhanmannuy caśhan camalaycunanpä” nin. 
\s1 Jesuspïtam Juan liman 
\p  
\v 22 Chaypïtam Jesus yaćhapacünincunawan Judeap muyülïnincunaman lil, chayćhu achcasca muyuncuna bawtisaśhtin capäcula.  
\v 23 Chaynütacmi Juanpis bawtisayäla Salin malcap achca yacu caśhan Enonćhu. Chaymanmi mana camacaycüña nunacunaca bawtisachicü śhayämula.  
\v 24 (Caycuna pasala Bawtisä Juan carsilman manalä wićhaśha cayaptinlämi.)  
\v 25 Ñatac Bawtisä Juanpa atïnincunam jucnin Israelwan tapunacuyta allacaycälila, Diospa ñawpäninćhu chuya caycunanpä pa'acuypïta. 
\p  
\v 26 Chaypïtam Juanman ćhaycälil: “Yaćhachicü taytay, chay Jordan mayup chimpanćhu limapämäśhayquipi nunämi bawtisayäñä. ¡Payman'a achca-achcamari licuyalcan!” nicuyalcan. 
\p  
\v 27 Niptinmi Juan: “Janay pachäćhu Tayta Dios unanchaycamäśhanchicmannuymi lluypis awniycunanchic.  
\v 28 Amcuna tuquictam yaćhayalcanqui ‘Diospa Caćhamuśhan Salbacücächu manam cayá’ nishäta. Aśhwanpa willacünin puntamücämi cayá.  
\v 29 Chaynümi casaracuyćhüpis. Walaśhca limay-masinwan cuscananpämi casaracun. Chaymi amigun licat-licat yanapänanpä cayal ima nishallantapis uyalil sumä cushicun. Chaynümari ya'apis sumä-sumä cushicú pay lulaśhanpïta.  
\v 30 Cananpi'a paytam masta-masta allinninpa licapäcun'a; ya'actañatacmi ichá masta-masta mana cäpäña licapämänan. 
\p  
\v 31 “Chay janay pachäpi śhamücá lluypïpis mas munayniyümi. Cay pachällapi ya'a cayalmá caycunallapïta yaćhaynïpis.  
\v 32 Pay janay pachäpi sumäninca cayalñatacmi ichá licaśhanpïta uyalishanpïta willan. Jinaptinpis manamá mayanpis uyaliculcanchu.  
\v 33 Chaynu captinpis willacuyninta mayanpis ćhasquicücämi ichá, tantiälälin Diospa nishan rasunca caśhanta.  
\v 34 Tayta Diospa caćhamuśhanca quiquin caćhamüninpa limayllanta limayan, paywan Chuya Ispiritu mana camacaycü cayaptinmá.  
\v 35 Tayta Dios chulinta cuyalmi lluy imacunactapis maquinman ćhulaycun.  
\v 36 Chaymi payman chalapacücá wiñay simpri cawsayta ćhasquiycun'a. Mana chalapacücunañatacmi ichá cawsaycäta manaña licaycälin'añachu, Tayta Diospa piñacuyninćhu cayalcal'a” nin. 
\c 4  
\s1 Jesusmi Samaria-lädu walmiwan liman 
\p  
\v 1 Chaypuncunaćhu fariseocunaca “Jesus Juanpïta mas mastash bawtisäcuyan. Atïnincunapis mas masläshi cacuyanpis” nipäcula.  
\v 2 (Manamá quiquin Jesuschu, sinu'a yaćhapacünincunam bawtisala.) Cay lulaśhancuna fariseocunäman ćhäśhanta yaćhälulñatacmi  
\v 3 Jesus “Galileacta cuticuśhä” nil chay Judeap malcancunapïta yapa pasacula. 
\p  
\v 4 Chayman lipäcunanpäñatacmi, Samariap malcancuna ćhawpinpa pasapäcunan cala.  
\v 5 Chaypa pasalmi Sicar nishan malcaćhu Jacob chulin Josëta ćhacla uśhancäman ji'aycuyalcäla.  
\v 6 Chayćhümi “Jacobpa püsun” nishanca cala. Chayman ćhawpi muyunnuy Jesus pishipäśha ćhälul patanćhu jamapayaptinmi  
\v 7-8 yaćhapacünincunañatac micuy lantï quiquin malcätalä liculcäla. Chayman Samaria-lädu walmi yacu julü ćhämuptinmi Jesus nila: “Mamay, yacullayquita mañacuśhayqui” nil. 
\p  
\v 9 Niptinmi licapayllaman camala Samaria-läducunäwan Israelcunaca mana allinpa apanaculcaptin. Chaymi: “Israel-lä cayal ¿imapïtam Samaria nunacta mañacamanquiman?” nin. 
\p  
\v 10 Niptinmi Jesus: “Sïchuśh Tayta Diospa uycunantawan, yacucta mañacuśhüniquita lisil'a, paytaćh mañacunquiman. Paymi ichá wiñay simpri cawsachï yacucta uycuśhunquiman” nin. 
\p  
\v 11 Niptinmi: “Taytay, mana imayquipis cayaptin ¿imanuypatan luli-luli püsupi ampá julalcamul chay cawsachï yacuctalä uycämanquiman?  
\v 12 Icha ¿cay püsu umäní awquillú Jacobpïta maslächun cälunquiman imatá? ¿Imanuypatá pay quiquin, lluy chulintin uywantin, upyanan püsupïta mas allinnintalä uycämanquiman?” nin. 
\p  
\v 13 Niptinmi: “Caypi upyäcunätá yacunan'a jinallam.  
\v 14 Ñatac yacu uśhäta upyäcunätá, manam imaypis yacunan'añachu. Jinaman pucyup ñawinpïnülämi wiñay simpri cawsay yalamun'a” nin. 
\p  
\v 15 Niptinmi: “Taytay, chayurá chay yacütari uycallämay manaña yacunäśha cay püsuman cutiticlaylla śhayämunäpä” nin. 
\p  
\v 16 Niptinmi: “Wayra wayapayquita puśhaculcul cutimunqui” nin. 
\p  
\v 17 Niptinmi: “Manam wayapäyüchu cayá” nin. 
\p Niptinmi: “Rasunpa chaytá allintam niyämanqui.  
\v 18 Chay picha wayapawan caśhayquipis canan juc wayapawan uywanacuśhayquipis manam rasunpa wayapayquichu. Chayurá rasuncätam niyämanqui” nin. 
\p  
\v 19 Niycüluptinmi: “Taytay, Diospa willacüninpisćha cayanqui.  
\v 20 Pay cüsacunapi yaćhayal'a, má, ¿imanimanquimá? Samaria-läducunacá awquillücunapïpis cay ulućhümi Diosta alawapäcú. Am Israelcunäñatac ‘Jerusalenćhümi alawänanchic’ niyalcanquiman” nin. 
\p  
\v 21 Niptinmi: “Uyalimay walmi, manaña cay uluman nï Jerusalenmanpis lillalña, Tayta Diosta alawanayqui timpu ñam jananchicćhüña.  
\v 22-24 Payta manam mayćhu alawaycälinantapis ucunchu, sinu'a nunacuna Ispiritullawan rasuncäćhu alawaycälinantam munan. Dios Ispiritu captinmá alawaycunanchicpä Chuya Ispiritunta munanchic. Chaynu alawaycücämá paypa śhun'unpä. Ñatac am Samaria-läducuna mayanta alawapäcuśhayquitapis manam yaćhapäcunquichu. Ya'a Israelcunañatacmi ichá tuquicta yaćhapäcú, ya'acunapi Salbacüca śhayämuptinmá” nin. 
\p  
\v 25 Niptinmi: “Aw yaćhayämi Diospa Caćhamuśhan Salbacüca śhamunanta. Pay ćhämulćha lluy lluyta willaycamäśhun” nin. 
\p  
\v 26 Niptinmi: “Limapäśhüniquimá, chay nishayquica cayá” nin. 
\p  
\v 27 Chay niyällaptinmi yaćhapacünincuna ćhälälimula. Jinalmi walmiwan limapäcuśhanta licälälil licapayllaman camälälil nï mayanninpis tapuycälilachu chay walmiwan imapi, nï imapä limaśhantapis. 
\p  
\v 28 Chay walmiñatacmi wacuynintapis caćhaycul malcäman pasacun. Ćhayculmi:  
\v 29 “¡Śhapämuy! ¡Juc wayapam llapa bïdäta niycäman! ¿Paypisćha Caćhamuśhan Salbacüca?” nil ayaycaćhacuyäla.  
\v 30 Chaymi llapa nunacunaca Jesus caśhancäman paćhcatityämula. 
\p  
\v 31 Chay śhamuśhancamam yaćhapacünincunañatac: “Yaćhachicü taytay, micucuycuy-ari” nil nipayalcäla. 
\p  
\v 32 Nipäcuptinmi: “Mana lisipäcuśhayqui micuymi micuná cayan” nin. 
\p  
\v 33 Niptinmi yaćhapacünincuna quiquin-pula: “¿Mayanćha apäpamunman micunanpä cala?” ninaculcäla. 
\p  
\v 34 Chaymi Jesus nila: “Micuná Caćhamänïcäpa munayninta camacänäcama lulaymi.  
\v 35 ¿Amcuna ‘Tawa quillalämi cayan cusichayta allaycunapä’ niyalcanquimanchun? Ya'añatacmi niycälic: Talpuśhacunäman ñawiquita má pallalcäliy-ari. Ñam nunacunaca cusichaycuypäña alwäśha cayalcan.  
\v 36 Cusichäcunaca wiñay simpri allincäman nunacunäta pilwaycuptinmi Tayta Dios sumä alli-allintalä uycun'a. ¡Cay maynu sumä cushicuymi talpücunäpapis, cusichäcunäpapis!  
\v 37-38 Chayurá ‘Juctacmi talpucun; jucñatacmi cusichan’ nishanchicnüpis rasunpam caćhapäculac mana lulaculcäśhayquiman. Juccuna ñacaculcäśhallantamá amcuna cusichaycälinqui” nil. 
\p  
\v 39 Ñatac Samaria-lädu walmica “Llapan bïdätam niycäman” nishallanpam achca malca-masincuna Jesusman lluy chalapaculcäla.  
\v 40 Chayćhu Jesusman ćhälälimulñatacmi “Taytay ya'acunaćhu quïdaycäliyari” niptin ishcay muyun paycunawan caycälila.  
\v 41 Chayćhu quiquin Jesuspa shiminta uyalilmi achca-achca chalapaculcäla. 
\p  
\v 42 Chaymi chay walmïta nipäcula: “Canan manam willacuśhallayquipñachu chalapaculcá, sinu'a quiquinpa shiminta uyaliycälilmi jinantin nunacunäpa Salbaycüninchic caśhanta yaćhaycälí” nil. 
\s1 Jesusmi yanapäcäpa chulinta sänaycachin 
\p  
\v 43 Chay ishcay muyunpïtañatacmi Samariapi pasala Galileap malcancunaman.  
\v 44 (Ñatac quiquin Jesusmi unay nila: “Diospi willacücuná manamá mayanpis quiquinpa malcanćhu'a allinpa ćhasquishachu” nil.)  
\v 45 Chaynu captinpis Jerusalenćhu Jesus jatun munayninwan chay Libraculcäśhan Fistaćhu lluy lulaśhanta licapäculmi Galileap malcanman ćhäluptin'a allinpa ćhasquipäcula. 
\p  
\v 46 Chaypïtañatacmi yacupïta, bïnuman muyuchishan Galileap Caná malcanman Jesus cutila. Ñatac Capernaum malcäćhümi sumä puydïnin mandacücäta yanapäninpa chulin ishyayäla.  
\v 47 Cay ishyapacüca Judeapi Galileaman Jesus ćhämuśha caśhanta uyalïlul-pacham tincuycü pasacun. Chayćhümi “Taytay, chulillämi wañucalpuyällanña. ¡Ama chaynu callaychu! ¡Lilläśhun sänaycachipamänayquipä!” nila. 
\p  
\v 48 Niptinmi Jesus: “Amcuna jatun tantiachicuycunacta milagrucunacta lulaśhäta mana licapäcul'a manam chalapacamanquichu” nin. 
\p  
\v 49 Niptinmi: “Taytay, manaläpis chulillá wañuśhancama lilläśhun” nin. 
\p  
\v 50 Niptinmi: “Cutiy jinalla. Chuliqui allinpacuyanñam” nin. 
\p Niptinmi Jesuspa nishanman chalapacul cuticun.  
\v 51 Ñatac manaläpis wasinta ćhaycuyaptinlämi, uyway nunancuna talipapämula: “Chuliqui allinyayanñam” niycälï. 
\p  
\v 52 Niptinmi talipäcunäta: “¿Imayüram sintïmullan?” nicuyan. 
\p Niptinmi: “Anyan ćhawpi muyunpïñam calur ishyayca caćhaycülunña” nipäcun. 
\p  
\v 53 Niptinmi yalpaćhacüla anyan muyuncäćhu chayüranuy Jesus: “Chuliqui allinyayanñam” nishancäta. Chaymi lluy wasintin Jesusman chalapaculcäla. 
\p  
\v 54 Chayurá cay Judeapi Galileaman cutiyninwan'a ishcay milagructam Jesus lulaycula. 
\c 5  
\s1 Jesusmi warda muyunćhu lata nunacta sänachin 
\p  
\v 1 Chaypïtam Jerusalenćhu Israelcunap fistaman Jesus lila.  
\v 2 Chay Jerusalenpa “Uwishcunap Puncun” nipäcuśhan sawanpa läduscanćhümi Israel limayćhu'a Betesda nipäcuśhan istanqui cala. Cay'a jatu-jatun mućhcanuy muyülïninćhu picha ramädayümi cala.  
\v 3 Chayćhümi achca aplacuna, walla maquicuna, latacuna, pasaypi ćhänacäśhacunapis yacuca cuyulinanta alcayalcäla. ˻  
\v 4 Chay yacuman anjilshi unaypi unaypi ji'alpaycamul sumä-sumä cuyuchila. Chayman puntacta paćhcalpücäshi, imawan ishyayalpis sänaśha cala.˼ 
\p  
\v 5 Chay ishyäcunäćhümi quimsa ćhunca pusäniyu wata ishyayä nuna jitalayäñä.  
\v 6 Chayta licälul, chay-chica wataña ishyayäśhanta Jesus tantialmi: “¿Sänayta munanquichun?” nin. 
\p  
\v 7 Niptinmi: “Taytay, manam pïlläpis canchu cuyuchishan üra yacuman apaycamäní. Jućhuycaćhacuśhäcamam juccuná apuraypa llallilläman” nin. 
\p  
\v 8 Niptinmi: “¡Śhalcuy-ari! Wantumuśhuśhayquita apaculcul licuy” nin. 
\p  
\v 9 Chayüralla sänälulmi wantumuśhanta apaculcul licun. Ñatac warda muyun captinñatacmi  
\v 10 waquin puydï Israelcuna sänäśha nunäta: “¡Caynu warda muyunćhu camachicuy mana pirmitiyächimaptinchicchun puliyanquimanlä ipicuśha!” nin. 
\p  
\v 11 Niptinmi “Sänachimäcämi, ‘Wantumuśhuśhayquita apaculcul licuy’ nimäla” nin. 
\p  
\v 12 Niptinmi: “¿Mayan nunatan chaynu niyäśhunayquipä?” nin.  
\v 13 Ñatac chay achca-achca nunacunäpi Jesus licuptinmi mana mayan sänachishantapis yaćhalachu. 
\p  
\v 14 Chaypïtam Diospa chuya wasinćhu sänachishan nunäta Jesus talïlun. Chayćhümi: “Canan sänaśhaña cayal'a amam juchacta lulanquiñachu mas piyurlä mana pasaśhunayquipä” nin.  
\v 15 Chaypïtam chay nuna Israelcunäman lil, sänachishanca Jesus caśhanta willaycamula. 
\s1 Jesuspa munayllanćhu cawsayca caśhantam willan 
\p  
\v 16 Chayurá caynu warda muyunćhu sänachishan-laycum puydï Israelcunaca Jesusta aticaćhala.  
\v 17 Jesusñatacmi: “Taytá canancamapis jinalla lulaycuyaptin'a ¿imapïtatá ya'apis mana lulämanchu?” nin.  
\v 18 Nïluptinmi, Israelcunaca wañuchiyta sumä-sumä munapapäcula. Manam warda muyuncäta jalutacuśhallanpïchu, sinu'a Diosta Taytanpälä ćhulaycul Diostucuśhanpam. 
\p  
\v 19 Chaymi Jesus: “Rasunpa, quiquilläpa munayllätá ya'a Chulin manam lulämanchu, sinu'a Taytäpa licaśha lluy lulaynincunallactam canan ya'apis lulaycuyá. 
\p  
\v 20 “Taytá cuyamalmi lluy lulaynincunacta yaćhaycachiman. Jinaman'a mas sumätalä yaćhaycachimäśhanta licalmi amcuna licapayllaman camapäcunqui.  
\v 21 Maynümi Taytá wañuśhacunacta śhalcalcachimul cawsayta uycun, chaynümi ya'a Chulinpis munaśhäcunäman'a cawsayta uycú.  
\v 22 Chaynütacmi Taytá pictapis mana cäraycun'achu, aśhwanpa ya'a Chulin captïmi lluy cäraycunäpäpis maquïman ćhulaycaman.  
\v 23 Caynu lulaycula Taytäta licapäcuśhannuy Chulintapis licaycälimänanpämi. Sïchuśh caćhamuśhan Chulinta mana allinpa licaycamäcá, caćhamäní Taytätapis mana allinpatacmi licayan. 
\p  
\v 24 “Sumäta uyalipämay: shimïta uyalicul caćhamänïman chalapacücá wiñay simpri cawsayniyüñam cayan. Manañaćh mućhuycäćhu can'añachu. Aśhwanpam wañuycäpi cawsayman juluycuśhaña cayan.  
\v 25 Rasunpa, Diospa caćhamuśhan ya'a Chulinpa shimïta wañüśhacuna uyalipäcunan muyunca jananchicćhüñam cayan. Chayćhümari uyalicücunaca cawsapäcun'a.  
\v 26 Maynümi taytäpa munayllanćhu cawsayca cayan, chaynümi ya'a Chulinpa munaylläćhüpis cawsayca cananpä uycamäla.  
\v 27 Chaynütac Rasun Nunap Chulinca captïmi Taytá maquïman cäraycunäpäpis ćhulaycamäla. 
\p  
\v 28 “Caycunapi ama licapayllaman camapäcuychu: llapa wañüśhacuna shimïta uyalil śhalcapämunan muyunca ćhämun'añam.  
\v 29 Chayćhümi allin luläcunacá wiñay cawsaypä śhalcamun'a; mana allincäćhu cäcunañatacmi ichá cäraycunäpä śhalcamun'a. 
\p  
\v 30 “Cay'a manam quiquilläpïtachu, sinu'a Taytá nimäśhanmannümi licaycú. Ñatac munaynïta caćhaycul Taytäpa munayllanta lulayta jicutayaptïmi cäraycuyni'a cäninmancamalla. 
\s1 Jesuspa lulaśhancunam pï caśhantapis willacun 
\p  
\v 31 “Quiquilläpi willacuyapti'a, manam chay willacuyní rasun bälinmanchu.  
\v 32 Juc ya'apïta willacü nishancämi ichá rasunpa bälin.  
\v 33 Quiquiquicuna Juanman tapuchï caćhapäcuptiqui, rasuncätam willapäcuśhulanqui.  
\v 34-35 Pay rasuncäta tantiaycälichishunayquipä acchiycamuptin sumä cushisha rätullapämi ćhasquiycälilanqui. Ñatac manam nunacunällap niycunallantá munächu. Caycunactam ichá niyalcac salbaycälisha caycälinayquipä.  
\v 36 Rasunpa Juanpïpis sumäninlämi pï caśhäta willacücá: Taytá lulalpunäpä quiquin umäśhanta lulaśhäcunämi Taytá caćhamäśhanta willacuyan.  
\v 37 Jinaman quiquin caćhamäní Taytäpis ya'api willacula. Amcunañatacmi ichá shiminta mana uyaliculcälanquichu, nï imanuy caśhantapis licapäculanquichu.  
\v 38 Ñatac uyaypa willacuynincunamanpis mana chalapaculcäśhayqui cayan caćhamüninta mana ćhasquipäcuśhayquipam.  
\v 39 Wiñay cawsayta talinayquipä isquirbishacunacta maynüñam ancuyalcanqui.  
\v 40 Ñatac chaycuna ya'apïta willacuyaptinpis manamá ya'aman śhapämunquichu wiñay cawsayta ćhasquipäcunayquipä.  
\v 41 Manam nunacunaca alawaycälimänantachu ashiyá. Chay'a manamá imapis ucamanchu.  
\v 42 Ya'a lisipäcucmá Tayta Diosta mana cuyapäcuśhayquita.  
\v 43 Chaymari canan Taytäpi camalachishtin śhamuptïpis manatac ćhasquipämanquichu. Ñatac juc quiquillanpi alawacuśhtin śhamuptinñatacmi ichá cushishalä ćhasquïlälinquimanpis.  
\v 44 Dioswan licachicuyta mana imactapis ucul, quiquillayqui-pula allinpa licachicuypi wañupacuyalcal'a, ¿imanuypatan payman chalapaculcanquiman?  
\v 45 Ñatac Taytäpa ñawpäninćhu ‘Payćha juchachaycamäśhun’ nil niyalcämaychu. Chayćhu quiquin alcaycälishayqui Moisesmá juchachaycälishunqui.  
\v 46 Sïchuśh payman rasunpa chalapaculcal'a ya'amanpis chalapacalcämanquimanćha, pay ya'apïta isquirbiyaptin'a.  
\v 47 Ñatac pay isquirbishanmanpis mana chalapacuyalcal-lächun willacuynïman chalapacälälinquiman ampá” nin. 
\c 6  
\s1 Jesusmi picha walanga wayapacunaman camachin 
\r Mt 14.13-21; Mc 6.30-44; Lc 9.10-17 
\p  
\v 1 Chaypïtam chay Galilea ućhap chimpanman barcuwan licula. (Chay ućhacta Tiberiaspa nipäculatacmi.)  
\v 2 Ñatac Jesus sumä ishyäcunacta sänachishanta licalmi achca-achca nunacuna atipäcula.  
\v 3 Jesusñatacmi yaćhapacünincunawan uluman ishpil, chayćhu taycacaycälila.  
\v 4 Ñatac Libraculcäśhan Fista ji'acaycayämulañam. 
\p  
\v 5 Chayman achca-achca nunacuna ishpilcämuśhanta Jesus licalculmi, Felipicta nin: “¿Paycunapä maypïćha micuyta lantishun?” nil.  
\v 6 Caynu nila Felipicta yaćhapänan-laycullam. Pay'a imanuypa camachinanpäpis yaćhalañam. 
\p  
\v 7 Niptinmi Felipe: “Juc nunap ishcay paćhac (200) muyun trabajunpis manaćh camanmanchu uchuyllanca uycunapäpis” nin. 
\p  
\v 8 Ñatac Simon Pedrop śhullcan Andres yaćhapacüninñatacmi:  
\v 9 “Cayćhu juc walaśhmi picha siwa tantactawan, ishcay challwacta uywayan. Ñatac chayllá ¿cay-chica nunapá imanpäpis ampá canmanchu?” nin. 
\p  
\v 10 Ñatac chay capäcuśhancäćhu tuqui pastulla cayaptinmi Jesus yaćhapacünincunacta: “Lluyta taycachipäcuy” nin. Chayćhu picha walanganuy wayapanllanlämi caculapis.  
\v 11 Jesusñatacmi chay tantätawan challwäta apticulcul Diosta sulpayta ucula. Jinalculmi yaćhapacünincunacta uycula aypupämunanpä. Chayćhu lluypis munaśhancamam aypuchiculcäla. 
\p  
\v 12 Ñä maćhacaycäliptinñam Jesus yaćhapacünincunacta: “Yan'almi puchünincuna usuycaćhacunman; lluyta juntupämuy” nin.  
\v 13 Niptinmi chay ishcay tantällapi puchüninta juntülälin, ćhunca ishcayniyu canaśhta juntactalä. 
\p  
\v 14 Chaynu Jesus lulaśhanta nunacuna licälälilmi: “¡Cayćhá Diospa Willacünin Śhamüca cacuyan!” nicuyalcan.  
\v 15 Jesusñatacmi mandacünin cananpä firsapi ćhulay munapäcuśhanta tantiaculcul uluman japallan yapa licula. 
\s1 Jesusmi ućhap jananpa pulin 
\r Mt 14.22-27; Mc 6.45-52 
\p  
\v 16 Ñä aspilpuyaptinñam Jesuspa yaćhapacünincuna ućhäman ji'alpapäcula.  
\v 17 Tutalpüśha cayaptinpis Jesus'a manalä cutimuptinmari juc barcuman ishpicalcälil Capernaum-läduman chimpapäcula.  
\v 18 Chaynu liyalcaptinñatacmi alli-alli waywa talcämul yacüta altu-altuman manchanaśhpa mächicächicuyan.  
\v 19 Ñä picha kilumitructanüña barcuwan liyalcalmi Jesus yacu jananpa pulishtin paycunaman śhayämüta licälälil sumä chucchucuyalcan.  
\v 20 Jesusñatacmi: “¡Ya'amari cayá! ¡Ama manchacalcämaychu!” nin.  
\v 21 Chaymi barcuman cushisha ishpilcayächimullaptin lipäcuśhanman juclla ćhälälin. 
\s1 Jesusmi cawsachicü tantaca 
\p  
\v 22-24 Chay walantinmi ućhap manyanćhu quïdä nunacunaca tantiälälin Jesuspis nï yaćhapacünincunapis mana chayćhu capäcuśhanta. Chaymi yalpälälin jucllay barcu caśhancällawan yaćhapacünincunalla Jesusta caćhaycul liculcäśhanta. Ñatac Tiberias malcapi barcucuna ćhälälimun Jesus tantacta camachishancascaman. Chaymi chay barcucunäman ishpicalcälil Capernaum malcaman Jesusta ashï liculcan. 
\p  
\v 25 Chay ućhap chimpanćhu Jesusta talïlälilmi: “Yaćhachicü taytay ¿imanuypam cayman ćhämulanqui?” nipäcun. 
\p  
\v 26 Niptinmi: “Rasunpa, manam ashiyalcämanqui siñalcunäta licalchu, sinu'a maćhaycälinayquicama micapäcuśhayquipam.  
\v 27 Ama-ari ashipäcuychu camacä micuycätá, aśhwanpa mana camacä wiñay simpri cawsachï micuycätari. Caytam Tayta Dios śhuñacuśhan Rasun Nunaca upäcuśhayqui” nin. 
\p  
\v 28 Israelcunañatacmi: “¿Ima lulapäcunätatan Tayta Dios munan?” nipäcun. 
\p  
\v 29 Niptinmi Jesus: “Caćhamuśhancäman chalapaculcänayquitamari” nin. 
\p  
\v 30 Niptinmi: “Nishayquica rasunpa caśhanta tantianäpä ¿ima milagructamá lulaycunquiman?  
\v 31 Unay awquillunchiccunapis chunyäninćhu cayalcal Maná nishan tantactam micapäcula, Moisespa isquirbishanmannuy: ‘Janay pachäpi tantactalämi micaycachila’ nil. Má, ¿am'a?” nicuyalcan. 
\p  
\v 32 Niptinmi Jesus: “Rasunpa manam Moiseschu janay pacha tantäta ula sinu'a quiquin Taytämi janay pacha rasun tantäta uycücá.  
\v 33 Chay Tayta Dios tanta uśhancá jinantin nunacunäta cawsayta uycunanpä janay pachäpi śhamücämi” nin. 
\p  
\v 34 Niptinmi nipäcula: “Taytay, chay tantätari mana pishiycachillal imaypis uycälimay” nil. 
\p  
\v 35 Jesusñatacmi: “Chay cawsachicü tantaca ya'am cayá. Chaymi ya'aman chalapacamäcätá mana imaypis micanan'achu, nïtac imaypis yacunan'achu.  
\v 36 Amcunam ichá, nishac-yupaypis, licayalcämalpis mana chalapacalcämanquichu.  
\v 37 Chaynu captinpis, Taytäpa umäśhancunämi ya'aman lluy śhapämun'a. Ñatac paycunacta manam imaypis alapacuśhächu.  
\v 38 Ñatac janay pachäpi quiquilläpa munaśhalläta lulanäpächu manam śhamulá, sinu'a caćhamänïpa munayninta lulämi.  
\v 39 Caćhamänïpa munaynin caymi: lluy umäśhancäta mana chincaycachillal muyuncunap camacaynincäćhu lluyta śhalcachimunämi.  
\v 40 Caypis Taytäpa munayninmi: chulinta lluypis uyalil chalapaculcaptin wiñay cawsayniyu caycälinanmi. Paycunactá unanchaycuśha muyuncäćhümi śhalcachimuśhä” nin. 
\p  
\v 41 Chaynu “Ya'am cayá janay pachäpi śhamü rasun tantaca” nïluptinmi chayćhu cä Israelcuna jamuyäcuyalcan:  
\v 42 “Cay Jesus Josëpa chulillan caśhanta ¿manachun lisinchic, imamá? Mamantapis, taytantapis lluymi lisinchic. ¿Imanuypatá canan ‘janay pachapïmi śhamulá’ niyämachwanlä canpis?” nil. 
\p  
\v 43 Ninacuyalcaptinmi Jesus: “Ama jamuyayalcaychu.  
\v 44 Ya'aman manam mayanpis śhamunmanchu caćhamäní Taytá mana puśhaycamuptin'a. Paycunactañatacmi unanchaycuśhan muyuncäćhu quiquí lluy śhalcachishä. 
\p  
\v 45 “Diospa willacünincunap isquirbishanćhüpis ‘Tayta Diosninchicmi yaćhaycachin'a lluy nunacta’ niyanmi. Sumäpa taytäta uyalil tuquicta lisïcunämi ya'aman śhamun'a.  
\v 46 Ya'allamari quiquinpi śhamuśha cayal taytäta lisiycú; manam juc mayanllapis licäca canchu.  
\v 47 Rasunpa chalapacücämi wiñay cawsayta ćhasquiycun'a. 
\p  
\v 48 “Ya'am cawsay tantaca cayá.  
\v 49 Ñatac awquillunchiccuna chay chunyäninćhu Maná nishan tantacta micuyalcalpis lluymi wañuculcäla.  
\v 50 Ya'añatacmi ichá limapayalcac janay pachäpi śhamü tantapi. Chayta micücá manam imaypis wañun'achu.  
\v 51 Chay janay pachäpi śhamü cawsachicü tantacá ya'am cayá. Cay tantacta micücunacá wiñay simpripämi cawsan'a. Chay uycuná tantaca quiquïpa aychämi. Jinantin nunacunaca cawsanan-laycumari uycuśhä” nin. 
\p  
\v 52 Niptinmi Israelcunaca quiquin-pula “¿Imanuypatá aychanta micächimachwan?” ninacücuyalcan. 
\p  
\v 53 Chaymi Jesus: “Rasunpa ya'a Nunap Chulincäpa aychäta mana micapäcul'a, yawarnïta mana upyapäcul'a, manam wiñay simpri cawsayniyüchu capäcunqui.  
\v 54 Chayurá ya'ap aychäta micücá yawarnïta upyäcá wiñay cawsayćhümi cawsan'a. Quiquïtacmi unanchaycuśhá muyuncäćhüpis śhalcachimuśhä.  
\v 55 Chaymi cay aychá rasun micuyca. Chaynütacmi yawarnïpis rasun upyayca.  
\v 56 Mayanpis aychäta micücá, yawarnïta upyäcá ya'aćhüñam cayan. Ya'apis payćhütacmi cayá.  
\v 57 Maynümi caćhamäní cawsä Taytäpa cawsayninwan ya'a cawsayá, chaynümi ya'api micücunäpis ya'api cawsan'a.  
\v 58 Ya'am janay pachäpi śhamü tantaca cayá. Chaymi cay tantapïta micücunacá wiñay simpripä cawsan'a. Manam chay awquillunchiccuna Maná tantacta micuyalcalpis wañuśhannüchu” nin. 
\p  
\v 59 Caycunactam Capernaumpa juntunaculcänan wasinćhu Jesus yaćhachila. 
\s1 Achca atïnincunam Jesusta caćhaycälälin 
\p  
\v 60 Caynu yaćhachishanta uyalïlälilmi atïcunäpi śhun'ullanćhu achca “Cay'a anchap sasam. ¿Pitá caycunacta tantianman?” nipäcula. 
\p  
\v 61 Jesusñatacmi jamuyapäcuśhanta tantial: “¿Cay nishäca jucmanyalächishunquichun?  
\v 62 ¿Imanipäcunquimantá Rasun Nunap Chulinca caśhan cutilcuyäta licapämal'a?  
\v 63 Cawsayta uycücá Tayta Diospa Ispiritunmi; ñatac aychallap munaynin'a manam imactapis ucunchu. Chaynütacmi cay limaśhäcunacá cawsä ispirituctawan wiñay simpri cawsayta uycun” nin.  
\v 64 Chayćhu Jesus mayan mana chalapaculcäśhantapis, mayan ipanchanantapis yaćhalmi: “Waquinniquicuna manalämi chalapaculcanquichu.  
\v 65 Nishac-yupaypis quiquin Taytá mana puśhapämuśhuptiqui'a manam śhapämunquimanchu” nin.  
\v 66 Chaypunpïmi achca atïnincuna caćhaycälälil manaña atipäculañachu. 
\p  
\v 67 Jinaptinmi Jesus ćhunca ishcayniyu yaćhapacünincunacta: “¿Amcunapis liculcaytachun munayalcanqui?” nin. 
\p  
\v 68 Niptinmi Simon Pedro: “¿Taytay, pimanćhá lipäcüman? Yaćhayalcäñam yaćhachicuyniqui wiñay cawsaypä caśhanta.  
\v 69 Cawsä Diospa Chuya chulinca, Caćhamuśhan Salbacüca caśhayquita rasunpa yaćhayalmari chalapaculcac” nin. 
\p  
\v 70 Jesusñatacmi: “Ćhunca ishcayniquita quiquïmi aclaculac. Jinaptïpis jucniqui'a supaymá cayanqui” nin.  
\v 71 Chaynüta nila Simonpa chulin Judas Iscariotipïmi. Paymi ćhunca ishcayniyu yaćhapacünin cayalpis Jesuspa ćhïnipänincunap maquinman ćhulaycunan cala. 
\c 7  
\s1 Nunacunaca ¿imanipäcuntan Jesuspi? 
\p  
\v 1 Chaypïtam Jesus chay Judea malcäćhu Israelcunaca wañuchiyta munapäcuptin, chayman mana ćhaycul Galileap malcancunallaćhu pulila.  
\v 2 Ñatac Israelcuna Chucllallaćhu Alawana Fista ćhayämulañam.\f + \fr 7:2 \ft Cay fistapa Jerusalenman llapa Israel caśhta wayapacuna linanmi cala.\f* 
\v 3 Chaymi Jesuspa śhullcancuna nipäcula: “Má, Judea malcäman liy-ari chayćhu yaćhapacüniquicunapis lulaśhayquicunacta licapäcuśhunayquipä.  
\v 4 Manamá pipis camalachicuyta munäcá pacallap lulaycaćhayanmanchu. Caynu lulätucuyalñá, jinantin nunacunap ñawpäninćhu-ari, má, camalachicuy” nin.  
\v 5 Chayćhu chay śhullcancunapis manam chalapaculcälachu. 
\p  
\v 6-7 Chaymi Jesus: “Amcunapá imayürapis nunacunaćhu licachicunayquipä allinmari cay pachäćhu nunacunaca mana ćhïniyalcäśhuptiqui'a; ya'apäñatacmi ichá chaypä manalä üra ćhämunlächu. Chay mana allin lulayninta licachiptïmari paycuna ya'acta ćhïnipapäman.  
\v 8 Chay fistaman liyta munal'a lipäcuy-ari. Ya'apá manalämi üra ćhämunlächu linäpä” nin.  
\v 9 Chayta nilculmi Galilea-lädućhu capaycula. 
\p  
\v 10 Chay śhullcancuna fistaman Jerusalenta licuyalcaptinmi, Jesuspis lila mana uyaypälächu, sinu'a pacallapam.  
\v 11 Chay fistaćhu Israelcunäñatacmi “¿Mayćhütan chay nunaca cayan?” nil ashipäcula.  
\v 12 Chayćhümi Jesuspïta limay cacula. Achcam: “Pay'a allin nunam” nipäcula. Waquinnincunañatacmi pacallapnu: “Chay'a llapa nunactam ingañayan” nil ninaculcäla.  
\v 13 Chaynu mayanpis mana uyaypa limalcälilachu Israelcunap puydïninta manchacuyninwanmi. 
\p  
\v 14 Chay fista ćhawpichayaptinñam Diospa chuya wasinman yaycuycul Jesus yaćhachila.  
\v 15 Chayćhümi Israelcunap llapa puydïninpis lluy nunacunäpis licapayllaman camälälila “¿Imanuypatá mana istudiuyu cayal sumä yaćhayniyu cacuyanman?” nil. 
\p  
\v 16 Niptinmi Jesus nila: “Ya'a manam quiquïpïtachu yaćhayalcächic, sinu'a caćhamänïpa yaćhachicuynintam.  
\v 17 Mayanpis Tayta Dios munaśhantanuy lulay munäcunacá tantiaycunmanmi paypi yaćhachishäta, ütac tantiaylläpi yaćhachishätapis.  
\v 18 Quiquillanpi tantialcul yaćhachïcunacá nunacunäwan alawachicuycunallactam ashipäcun. Ñatac caćhamänïpa alawaycuśha cananpä ashïcämi ichá rasuncäta liman. Chaymi pï imaniycunanpis mana canchu.  
\v 19 Amcunacta Moisesmi camachicuyta upäcuśhulanqui Diospa munayninmannuy cawsaycälinayquipä. Jinaptinpis ya'acta wañuchimayta munapäcuyniquiwanmi mana mayanllayquipis cäsuculcanquichu” nin. 
\p  
\v 20 Niptinmi nunacunaca: “¿Achatup lücuchishachun cayanqui imatá? ¿Mayantan amta wañuchiyta munayäśhunqui?” nipäcula. 
\p  
\v 21 Niptinmi: “Warda muyuncäćhu milagructa lulaycüluptïchun nicayalcämanquiman.  
\v 22 ¿Manachun amcuna warda muyunman ćhäluptinpis umri cayninćhu siñalachipäcunqui Moises nishanmannuy? (Ñatac manamá paychu nila, sinu'a unay awquilluyquicunalämari.)  
\v 23 Jinayalcanqui warda muyunman siñalachinayqui ćhäluptinpis camachicuyca mana jalutacüśha cananpämi. ¿Chaychun warda muyuncäćhu ishyä nunacta tuqui nunaman muyuyächiptí piñäśha cacuyalcanquiman?  
\v 24 Janallanta licalcullal'a ama niyalcaychu. Sinu'a rasun caśhanmannuy sumäpa licaycälil niycunayquim” nin. 
\s1 Jesusmi willan maypi śhamuśhantapis 
\p  
\v 25 Ñatac chay Jerusalenćhu waquin yaćhäcunämi ninaculcan: “¿Wañuchinanpä ashishan nunachućh cayćhu cayäñä?  
\v 26 ¡Lluy nunap ñawpäninćhu yaćhayächiptinpis, maytá pipis imactapis niyanchu! ¿Puydïninchiccuna ‘Caćhamuśhan Salbacüninchicmi’ niyalcanpisćhá?  
\v 27 Ñatac caytá lisinchicmi maypi śhamuśhantapis. Chay Salbacücätam ichá maypi śhamunantapis mana yaćhaśhunchu” nil. 
\p  
\v 28 Jinaptinmi Jesus chuya wasin yaćhachishancäćhu callpawan: “Chayurá amcuna yaćhacuyalcanquichun pï caśhätapis, maypi śhamuśhätapis. Ñatac ya'a manam quiquilläpïchu śhamulá, sinu'a sumä chalapacuna cäcäpa caćhaśham.  
\v 29 Amcuna manam lisipäcunquichu; ya'añatacmi ichá, paypi śhamul, paypa caćhaśha cayal tuquicta lisí” nin. 
\p  
\v 30 Niptin wićhachiyta munapäculpis, üran manalä ćhämuptinmi mana mayanllanpis chalayta atipapäculachu.  
\v 31 Waquinnincunañatacmi ichá chalapaculcal: “Salbacüninchic śhamulpis ¿caypïta mastá lulayanmanchun ampá?” nipäcula. 
\p  
\v 32 Chay nipäcuśhantam fariseocunaca uyalïlälin. Chaymi puydï sasirdüticunäwan limanacalcälil Diospa chuya wasinpa täpänincunacta Jesusta chalachimunanpä caćhälälin. 
\p  
\v 33 Chaymi Jesus nila: “Amcunawan ash muyuncunallam caycuśhä. Chaypïta cuticuśhä caśhan caćhamänïmanmi.  
\v 34 Chayćhu maynu ashipämalpis manam talipämanquichu. Chay caśhäcäman'a manam ćhäpämunquimanchu” nin.  
\v 35 Niptinmi llapa Israelcunaca quiquin-pula: “Mana talinanchicpä ¿maytaćh cay pinsayan liyta? ¿Icha calu-calućhu chi'isha\f + \fr 7:35 \fk chi'iy: \ft Waquincunaćhu'a “wichiy” nipäcunmi.\f* malca-masinchiccunaman lilchun mana-Israelcunäta yaćhachin'a, imatá?  
\v 36 Imacäta pinsaltan cay niyämanchic: ‘Ashilpis manam talimanquichu’ ñatac ‘Ya'a caśhäcäman'a manam ćhäpämunquimanchu’ niyanman” nil nipäcun. 
\s1 Cawsachicü yacupïtam liman 
\p  
\v 37 Chay fistap camacalpuynin mas puydï muyuncäćhümi Jesus śhalculcul lluy nunacunäta sumäpa nila: “Mayanpis yacunäśha cäcunacá, ya'aman śhapämul upyapäcuy.  
\v 38 Ya'aman chalapacamäcunäpá, isquirbishanćhu nishannüpis cawsachicü yacum śhun'unpïta sumä mayunu lin'a” nil.  
\v 39 Caynu Jesus nila Chuya Ispiritunta chalapacünincuna ćhasquipäcunanpïtam. Chaypun Jesus wañuśhanpi śhalcalcamul janay pachäman manalä cutiptinmi Chuya Ispiritun nï caćhamuśhalächu cala. 
\p  
\v 40 Waquinnin uyalïcunämi: “Cay nunäćhá Diospa śhamunan Willacüninca” nipäcula.  
\v 41 Juccunañatacmi: “Caćhamunan Salbaycamäninchiccäćha” nipäcula. Waquinnincunañatacmi “¿Galileapïta yalämunman Salbacüca ampá?  
\v 42 Diospa shiminćhu ¿manachun: ‘Salbacüca Davidpa milayninpïmi śhamun'a; paypa Belen malcanpïtacmi yalamun'a’ niyan-ari?” nipäcula.  
\v 43 Chaynu Jesuspïta limayninwanmi ishcayman lluy iwinacälälin.  
\v 44 Chaymi waquinnincuna Jesusta wićhachiyta munapäculpis mayanllanpis mana atipapäculachu. 
\s1 Puydïcunam Jesusman mana chalapaculcanchu 
\p  
\v 45 Ñatac Diospa chuya wasinpa chay täpänincunam caćhaśhan fariseocunämanwan puydï sasirdüticunaman jinanllan cutipäcula. Jinaptinmi: “¿Maymi? ¿Imanaltan mana puśhapämunquichu?” nicuyalcan. 
\p  
\v 46 Niptinmi: “Pay limaśhantanu'a manam imaypis, nï mayanpis limalachu” nipäcun. 
\p  
\v 47 Niptinmi fariseocunaca: “¿Ima? ¿Amcunactapis limayninwanchun awnïlächishunqui, imatá?  
\v 48 ¿Payman chalapacuyalcanchun jucllay puydïcällapis imamá, nïtac fariseocunäpïpis jucllanchicpis?  
\v 49 ¡Chay camachicuyta mana yaćhäcunam, nï Diospäpis mana bälï pasaypi luclucunam!” nipäcun. 
\p  
\v 50 Ñatac fariseocunäpi Nicodemo puntacta Jesusman tutallap śhamücämi:  
\v 51 “¿Manaläpis tuquicta yaćhaycul juchachayänapächun camachicuyca niyämanchic, imatá?” nin. 
\p  
\v 52 Niptinmi nipäcula: “¿Ampis Galilea-lädu-tucülunquichun, imatá? Camachicuyta sumäta licaycuy Galileapi Diospa willacüninca mana yalamuśhanta yaćhanayquipä” nil.  
\v 53 Chaypïtam wasinman-cama lluy liculcäla. 
\c 8  
\s1 Mansibacü walmictam pampachan 
\p  
\v 1 Jesusñatacmi Ulibus nishan ulüta licula.  
\v 2 Chay walantinmi wäla wälalla Diospa chuya wasinman cutimula. Chayćhümi nunacunaca juntunacälälimuptin taycucuycul Jesus yaćhachila.  
\v 3 Chaymanmi camachicuyta yaćhachicücunäwan fariseocunaca juc walmicta mansibacuyäta talilcälil puśhapämula. Chayćhu lluy nunacunap ñawpäninman śhaycacaycachilmi  
\v 4 Jesusta nipäcula: “Yaćhachicü taytay, cay walmictam mansibacuyäta talïlälí.  
\v 5 Moisespa camachicuyninćhu'a caynuy walmicunacta lumi tamshaypa wañuchinapämi cayan. ¿Am'a imaninquitan?” nil.  
\v 6 Cayta nipäcula Jesuspa limayllan cunca cuchuynin cananpämi. Jesusñatacmi ichá pampäman uyshucalpul dïdunwan allpäćhu isquirbiyäla. 
\p  
\v 7 Chayćhu jinalla tapucuyalcaptinmi Jesus śhalculcul nila: “Mayanniquipis mana juchayücá, má, allaycuchun tamshayta” nin.  
\v 8 Nilculmi caśhan uyshucalpul pampäćhu dïdunwan isquirbiyäla.  
\v 9 Chaynüta niycüluptinmi puśhamücunaca juchayu capäcuśhanta lluy tantiacalcälil awquishnincunapi allacaycälil jucllap jucllap chincaculcäla. Jinaptinmi Jesuswan chay walmïllaña quïdäläliña.  
\v 10 Chayćhümi Jesus śhalculcul tapula: “Walmi, ¿mayćhütan cayalcan? ¿manachun jucllanpis juchachaycälishunqui?” nil. 
\p  
\v 11 Niptinmi: “Taytay, manamá mayanllanpis” nin. 
\p Niptinmi: “Chayurá ya'apis manam juchachacchu. Jawcallañari licuy. Cananpi'a amañamá juchacta lulanquiñachu” nin. 
\s1 Mayan caśhantapis bälichicun 
\p  
\v 12 Chaypïta achca nunacunäta yapa yaćhachilmi nin: “Cay pachäćhu llapa nunacunäpa acchinmi cayá. Ya'acta atimäcá manañam tutapäcäćhu cawsan'achu, sinu'a sumä cawsayta uycuśha acchićhümi cacun'a” nil. 
\p  
\v 13 Niptinmi fariseocunaca: “Ä, canan caynu quiquillayquipi willacuśhayquiwan'a limayniqui manamá bälinchu” nin. 
\p  
\v 14 Niptinmi: “Maypi śhamuśhätapis yaćhayapti'a masqui ya'alla willacuyaptïpis, willacuśhäca rasuncämi. Amcunam ichá mana yaćhapäcunquichu maypi śhamuśhätapis nï mayta linätapis.  
\v 15 Nunacunallap tantiayllanmannümi cäraycälinquipis. Ya'añatacmi ichá mayantapis mana cäraycüchu.  
\v 16 Ñatac cärayculpis caćhamänïwan cayaptïmi tincüninman cäraycuyni'a. Manam japallächu licaycú, sinu'a paywanmi.  
\v 17 Amcunap camachicuyniquićhümi ‘Ishcay nuna willaycü captin'a tacyalpachishañam’ niyan.  
\v 18 Chayurá ya'a quiquïmi jucnin willaycüca cayá; juccäñatacmi caćhamäní Taytá” nin. 
\p  
\v 19 Niptinmi: “¿Mayćhütan chay taytayqui cayan?” nipäcula. 
\p Jesusñatacmi: “Mayan rasunpa caśhätapis mana lisiyämal'a ¿imanuypatan taytätalä lisïlälinquiman? Manamá mayannïtapis lisipämanquichu” nin. 
\p  
\v 20 Caycunacta nila Diospa chuya wasinćhu illay apapämunan ćhulacunpa läduscanćhu yaćhayächishanćhümi. Chayćhu manalä üran captinmi mana pipis prïsunanpä chalapäculachu. 
\p  
\v 21 Chaypïtam Jesus yapa nila: “Ya'a licuśhäñam; ashiyalcämalpis manam ćhäpämunquimanchu; aśhwanpa juchayquićhu cayalcalmá wañupäcunquipis” nil. 
\p  
\v 22 Niptinmi Israelcunaca: “ ‘Ya'a caśhäcäman'a manam ćhäpämunquimanchu’ ninanpä ¿‘supay-apäśhä’ nicuyanchun, imamá?” nipäcun. 
\p  
\v 23 Jesusñatacmi nin: “Amcuna cayllapïmi capäcunqui; ya'añatacmi ichá janaypi. Amcuna cay pachällapïmi capäcunqui, ya'añatacmi ichá mana cayllapïchu.  
\v 24 Pï caśhätapis nishacmannuy mana chalapaculcal'a juchayquićhümi wañupäcunqui” nil. 
\p  
\v 25 Niptinmi: “Am ¿pï tucunquitan?” nipäcun. 
\p Niptinmi: “Allaycuśhäpïta mayan caśhätapis nishäcämari.  
\v 26 Jinaman amcunapïtapis sumä achcam limapaycälinac cäraycälinac cayan. Caycuna cay pachächu sumä tincüllanman cayan rasuncällacta niycü caćhamänïpïta uyalishäta willaycuptïmi” nin.  
\v 27 Ñatac manam tantiapäculachu, taytanpïta limaśhanta. 
\p  
\v 28 Chaymi Jesus nila: “Altuman śhalcachisha captïlämi Nunap Chulinca rasunpa ya'a caśhäta, chaynütac quiquilläpi imactapis mana limal, caćhamäní yaćhachimäśhanmannülla limaśhäta tantiapäcunqui.  
\v 29 Chayurá caćhamäní ya'awanmi cayan. Imaypis paypa munaśhanta lulaptïmi mana japallätachu caćhaycaman” nin.  
\v 30 Caynu Jesus niptinmi achca chalapaculcäla. 
\s1 Taytan mayan caśhanpïtam limapäcun 
\p  
\v 31 Chay chalapacü Israelcunätam Jesus: “Amcuna willacuynïćhu masïsu tacyapäcul'a rasunpa yaćhapacünïcunam cayalcanqui.  
\v 32 Jinalmi Diospi rasun allincäta lisipäcunqui. Chay rasuncäñatacmi ćhänalächipäcuśhuśhayquipi julapäcuśhunqui” nin. 
\p  
\v 33 Niptinmi: “Ya'acuná Abrahampa milayninmi capäcú; imaypis manamá mayanpa uywayllanpis capäculächu. ¿Chaychun ‘Amñatac juluycuśham capäcunqui’ niyalcämanquiman?” nipäcula. 
\p  
\v 34 Niptinmi Jesus: “Rasunpa mayanpis juchaćhu cawsäcunacá juchap uywayninmi cayalcan.  
\v 35 Uywayca chay ayllućhu manam pasaypipächu caycun. Ñatac chulinmi ichá pasaypipä.  
\v 36 Chayurá Chulica julaycälishuptiqui'a pasaypipä libriñam capäcunqui.  
\v 37 Yaćhämari Abrahampa milaynin capäcuśhayquita. ¿Chaynu cayalcalchun yaćhachicuyní śhun'uyquipänuy mana captin wañuchiyta munayalcämanqui?  
\v 38 Ñatac quiquin Taytäpa lädunćhu cayal licaśhäcätam ya'a limá; amcunapis taytayqui limapapäcuśhuśhayquitam lulapäcunqui” nin. 
\p  
\v 39 Niptinmi nipäcula: “Ya'acunap taytá Abrahammari” nil. 
\p Jesusñatacmi: “Abrahampa rasun chulin capäcul'a, paynüćha lulaycälinquiman.  
\v 40 Manaćh wañuchiyta munayalcämanquimanchu quiquin Diospi uyalisha rasun allincäta willaycuyapti'a. Caynüchu Abraham'a manamá lulaycula.  
\v 41 Amcuná taytayquip lulaynintam lulaycuyalcanqui” nin. 
\p Niptinmi paycuna: “Ya'acuna manam ishu chulipacuychu capäcú. Tayta Diosllam ya'acunap taytá” nicuyalcan. 
\p  
\v 42 Jesusñatacmi: “Rasunpa Dios taytayqui captin'a paypi śhayämupti'a cuyapämanquimanćha. Paypa caćhaśham śhayämüpis, manamá munaylläpïchu.  
\v 43 Chayurá ¿imapïtan-nila yaćhachicuynïta mana tantiapäcunquimanchu? Mana ćhasquiculcänayquimari.  
\v 44 Aśhwanpa amcuná taytayqui Satanaśhpa munaśhanta lulayta jicutayä nunanmi capäcunqui. Pay'a cay pachap allaycuyninpïta nuna wañuchicümi. Manamari imaypis rasun allincäta niyculachu nï cayculapischu. Artishca cayalmi jinaman chay articunap quiquin taytan cayalmi articta limal'a tincüninman liman.  
\v 45 Chaymari ya'a rasun allincäta willaycupti'a mana chalapacalcämanquichu.  
\v 46 Má ¿mayanllayqui'a juchayu caśhäta licapämälanquitan? Chayurá rasuncäta yaćhayächiptí ¿imapïtan mana ćhasquiculcanquichu?  
\v 47 Rasunpa, Diospa cäcunacá shiminta uyaliculcanmi. Paypa mana capäculmi amcuna mana uyalïtuculcanquichu” nin. 
\s1 Abrahampïpis mas puntacta Jesus calañam 
\p  
\v 48 Niptinmi Israelcunaca: “Allintam niyalcac ¡anla Samaria-lädu nuna Satanaśhpa gänaśham canqui!” nipäcun. 
\p  
\v 49 Niptinmi Jesus: “Manam Satanaśhpa gänaśhachu cayá. Aśhwanpam Taytäta altuman juluycú; amcunañatacmi ichá pin'ayman julaycälimanqui.  
\v 50 Manamá quiquillächu alawacuyta ashiyá; aśhwanpa jucmi alawaycuśha canäpä ucupacuyan. Pay'a amcunactapis lluyta cäraycücämi cayan.  
\v 51 Chaymi rasunpa willacuynïta chalapacücá wañuyta mana lisipäcun'achu” nin. 
\p  
\v 52 Niptinmi Israelcunaca: “Cananmi ichá Satanaśh gänaśhuśhayquita rasunpa yaćhalpälí. ¡¿Imanuypatan ‘Shimïman chalapacücunacá manam wañuyta lisin'achu’ niyanman, aśhta quiquin Abrahampis Diospa willacünincunapis wañuyalcaptin?!  
\v 53 ¿Tayta Abrahampïpis mas puydïlächun cayanquiman, imatá? Paypis Diospa willacünincunapis wañuculcälam. ¿Am'a pï tucunquitan?” nipäcun. 
\p  
\v 54 Niptinmi Jesus: “Quiquilläpi alawacuptí manam uchucllapis pasanmanchu. Aśhwanpa amcuna ‘Diosnïmi’ nipäcuśhayqui quiquin Taytämi altuman julaycaman.  
\v 55 Niyalcalpis amcunañatacmi ichá mana lisipäcunquichu. Ya'ami ichá tuquicta lisiycú. ‘Manam lisïchu’ nipti'a amcunanüpis casquicüćha cäman. Ya'ami ichá lisiyal shiminmannuy cawsaycú.  
\v 56 Ñatac taytayqui Abrahampis cay śhamuná timpucta licaycuypi cushiculam. Chaymi licämal'a sumä-sumälä cushicula” nin. 
\p  
\v 57 Niptinmi: “Picha ćhunca watallayquipis mana cayaptin ¡Abrahamta licälunquiman ampá!” nipäcun. 
\p  
\v 58 Niptinmi Jesus: “Rasunpa, manaläpis Abraham captinmi ya'a cayäläña” nin.  
\v 59 Chaynu nïluptinmi lumicta apticälälin tamshälälinanpä. Jesusñatacmi chay-chica nunacunäpi pantalcachil Diospa chuya wasinpïta licula. 
\c 9  
\s1 Jesusmi apla nunacta sänachin 
\p  
\v 1 Liyäśhanćhümi nasïdunpi apla nunacta Jesus licälun.  
\v 2 Chayćhümi yaćhapacünincuna: “Yaćhachicü taytay, caynu apla näsïmula ¿quiquinpa juchanpïchun icha taytancunap juchanpïchun?” nipäcula. 
\p  
\v 3 Niptinmi: “Manam quiquinpa nï taytanpa juchanpïchu, sinu'a Diospa munaynin payćhu camalaycunanpämi.  
\v 4 Chaymi caćhamäní lulananchicpä nimäśhancäta wañuy-wañuylla lulaycunanchic muyunca caśhancama. Mayanpis lulayta mana atipänan tutaca ñam ji'acaycayämunña.  
\v 5 Ñatac cayćhu caśhäcamá, cay pachäćhu nunacunäpa acchinmi cayá” nin. 
\p  
\v 6 Nilculmi pampäman tuwaycul dïdunwan mitucta lulaycul chay apläpa ñawinta llusiycul nila:  
\v 7 “Siloé nishan istanquićhu pa'acamuy” nil. (Siloé ninan'a “Caćhaśhanca” ninanmi.) 
\p Niptinmi chay apla lilcul pa'acamul licaśhtinña cutïmun.  
\v 8 Chaymi malca-masincunapis, mañapacuyäta licäcunäpis: “¿Manachun wicćhu täcuylla täcul mañapacü aplaca?” nipäcula. 
\p  
\v 9 Waquinninmi “Paymari” nipäcula. 
\p Juccunañatacmi “Manam. Jucmi paynü-nilälla” nipäcula. 
\p Apläñatacmi: “Quiquïmari cayá” nila. 
\p  
\v 10 Niptinmi tapupäcula: “¿Imanuypatan-nila ñawiqui quićhacacülun?” nil. 
\p  
\v 11 Niptinmi: “Chay Jesus nishan nunam mitucta lulaycul ñawïman llusiycäman. Jinalculmi ‘Siloé istanquiman lil pa'acamuy’ niman. Chayćhu pa'acullal-pacham licälú” nin. 
\p  
\v 12 Niptinmi: “¿Mayćhütan chay nunaca cayan?” nipäcula. 
\p Niptinmi: “Äli, manam yaćhächu” nin. 
\s1 Fariseocunämi chay apla sänäśhäta tapupäcun 
\p  
\v 13-14 Ñatac Jesus mitucta lulaycul apläpa ñawinta quićhacachishanca warda muyunćhümi cala. Chaymi fariseocunäman chay apla sänäśhäta puśhälälin.  
\v 15 Ćhächiptinmi tapupäcula imanuypa ñawin quićhacacüśhantapis. 
\p Niptinmi: “Mituwan ñawïman llusiycamaptin pa'acullalmi licälú” nin. 
\p  
\v 16 Chayćhu waquinnin fariseocunämi: “Chay nuna Diospïchu manam canman. ¿Imanuypatá cay lulayninwan warda muyuncäta jalutacuyanman?” nipäcula. 
\p Juccunañatacmi: “Jucha-sapa nuna cayal'a, ¿imanuypatá caynücunactalä lulayanman?” nipäcun. Chaymi quiquin-pula iwinacälälin. 
\p  
\v 17 Chaymi yapa tapucuyalcan: “Am'a ¿imaninquimá, ñawiquita licachishüniqui nunapïta?” nil. 
\p Niptinmi: “Diospa willacüninmari” nin. 
\p  
\v 18 Ñatac fariseocunaca aplapi sänaśha caśhanta manam awnïtuculcälachu, aśhta chay apläpa mamanta taytanta ayachipämunancama.  
\v 19 Chaymi mamanta taytanta ayalcachimul: “¿Cay chuliquichun? ¿Rasunpachun nasïdunpi apla? Chayurá ¿canan imanuypatan licälun?” nin. 
\p  
\v 20 Taytancunañatacmi: “Aw, pay'a chulïmi; jina nasïdunpi aplam cala.  
\v 21 Ñatac imanuypa ñawin licaśhantam ichá ya'acunapis mana yaćhapäcüchu nï mayan quićhacachishantapis. Quiquintari tapupäcuy; ñam yayniyüña” nipäcun.  
\v 22 Chaynu nipäcula Israelcunap puydïnincunaca mayanpis “Jesus'a Caćhamuśhan Salbacücämi” nil limalcücäta juntunacuynincunapi alapacüśha cananpä limanacüśha captinmi.  
\v 23 Chaymi taytancuna “Quiquinta tapuy; ñam yayniyüña” nipäcula. 
\p  
\v 24 Chaymi aplapi sänäśhäta caśhan ayalcachimul: “Diospa ñawpäninćhu rasuncäta niycälimay.\f + \fr 9:24 \fk Diospa…niycälimay: \ft Griego limayćhu'a “Diosta altuman juluy” niyanmi. Chaynu niyaptinpis “Rasuncäta limay” ninanmi. Licay Jos 7.19-ta.\f* Ya'acunam tuquicta yaćhapäcú chay nunaca jucha-sapa caśhanta” nin. 
\p  
\v 25 Niptinmi: “Manamari yaćhächu jucha-sapa mana jucha-sapa caśhantapis. Śhun'ućhu yaćhacú aplapïta canan licaśhallätam” nila. 
\p  
\v 26 Niptinpis mastam tapupäcula: “¿Imactam luläśhulanqui? ¿Imanuypatan ñawiquita quićhacächishulanqui?” nil. 
\p  
\v 27 Niptinmi: “Niyalcacñamari; willayaptïpis manatacmi quiripämanquichu. ¿Icha yapa tapupayalcämanqui amcunapis atïnin cayta munapäculchun?” nin. 
\p  
\v 28 Niptinmi fariseocunaca: “¡Ima! ¡Amćhá chay-nilä nunäpa atïnin cayanqui; ya'acuná Moisespa atïninmi capäcú!  
\v 29 Yaćhanchictacmi quiquin Dios Moiseswan limaśhantapis. Ñatac chay nunäpïtá manam yaćhanchicchu maypi yalämuśha caśhantapis” nipäcula. 
\p  
\v 30 Niptinmi aplapi sänäśha nunaca: “¡¿Imanuypatá caynu ñawïtapis licachimä nunactalä maypi śhamuśhantapis yaćhapäcunquimanchu canpis?!  
\v 31 Tuquictam yaćhanchic Tayta Dios jucha-sapacunäta mana uyalil manchacuywan cäsucünincunallacta uyalishanta.  
\v 32 Manatacmi imaypis uyalilanchicchu nasïdunpi aplacta licächishantá.  
\v 33 Rasunpa Diospi mana śhamul'a manaćh caynüta lulälunmanchu” nin. 
\p  
\v 34 Chaynu niptinmi: “¡Cärayqui cañächun am juchallaćhu chapunacüśha näsïcälä ya'acunacta yaćhachïtucupämänayquipä!” nicuyalcan. Nilculmi lluy alülälila. 
\s1 Aplaca llapan śhun'unwanmi chalapacun 
\p  
\v 35 Jinaptinmi Jesus yaćhälun chay apla sänäśhanca alüśha caśhanta. Chaymi tincülul: “¿Rasun Nunap Chulinman chalapacunquichun?” nin. 
\p  
\v 36 Niptinmi: “Taytay ¿chay mayantan cayällan? Niycallämay chalapacunäpä” nin. 
\p  
\v 37 Niptinmi: “Licayanquiñamari; anwan limäcämi cayá” nin. 
\p  
\v 38 Niptinmi puntanman un'ulacuycul: “Aw, chalapacullämi” nil altuman juluycula. 
\p  
\v 39 Niptinmi Jesus: “Cay pachäman śhamulá imanuy nunacuna caśhantapis camalaycachïmi, aplacunäta licaycachï, licätucücunätañatac rasunpa mana licapäcuśhanta tantiaycachï” nin. 
\p  
\v 40 Niyta uyalïlälilmi chayćhu cä fariseocunaca: “¿Ima, ya'acunapis aplachun cayalcá imatá?” nicuyalcan. 
\p  
\v 41 Niptinmi Jesus: “Aplapa-yupay tantiayniqui cayaptin'a nishayqui pampachaycuśham canman. Ñatac licätucuśhayquipam juchallayquićhülä cayalcanqui” nila. 
\c 10  
\s1 Jesusmi nunacunäpa michïnin 
\p  
\v 1 Chaypïtam: “Sumäta uyalipämay: mayanpis uwish canćhaman puncunpa mana yaycul juc-lädunpa yaycücá cullu cära suwam.  
\v 2 Ñatac quiquin michïcá canćhap puncunpam yaycun.  
\v 3 Paytam puncu quićhäcäpis quićhaycun. Uwishnincunapis uyat-uyatllañam cayalcan. Chaymi ayayllawan canćhanpïta yalachimun.  
\v 4 Chaynu lluyta yalalcachimul puntanta ñawpaptinmi uwishcunäñatac shiminta lisipäcul atipäcun.  
\v 5 Ñatac juc nunactá manam atinchu. Aśhwanpa michïninpa shimin mana caśhanta yaćhalmi buryaylla ayiculcan” nin.  
\v 6 Caynu tincuchiywan Jesus yaćhachiptinpis imapi limaśhantapis manam tantiapäculachu. 
\p  
\v 7 Chaymi nila: “Rasunpa ya'am uwishcunäpa yaycunan puncuca cayá.  
\v 8 Ñatac puntäta śhamücunacá pasaypi suwacunam. Ñatac uwishnïcuná manam cäsupäculachu.  
\v 9 Sumäta uyalipämay: ya'allam rasun puncuca cayá. Chaymi mayanpis ya'ap yaycücá salbaśha can'a. Jinaptinmi uwish cutiticlaylla llullu pastucunalläćhu jawca puliycänuy capäcun'a.  
\v 10 Ñatac suwacá suwacüllam wañuchïllam camacällam śhamun. Ya'añatacmi ichá llapanta sumä-sumä allin jawca mana camacaycü cawsayta unäpä śhamulá. 
\p  
\v 11 “Chaynütacmi ya'a allin michïca cayá. Allin michïcá uwishnin-laycum bïdantapis uycun.  
\v 12 Ñatac michipacücunacá atü śhayämüta licälul'a quiquinpa uwishca mana captinmi lluy caćhaycul ayicun. Jinaptinmi atüca paćhcaycul lluy pintïchin.  
\v 13 Chay nunacá uwishcunäpi mana imapis ucunchu michipacülla calmi. 
\p  
\v 14-15 “Ya'am ichá quiquin allin michïca cayá. Maynümi Taytäwan lisinacú, chaynümi uwishnïcunawanpis lisinacú. Chay uwishnï-laycumari bïdätapis uycú.  
\v 16 Jinaman cay canćhäćhu mana cä uwishnïcunactapis atimunämi cayan. Paycunapis shimïta uyalipäman'am. Chayćhümi juc canćhallaña juc michïllaña can'a. 
\p  
\v 17 “Ñatac Taytá cuyaman quiquí cawsaynïta uycul caśhan cawsanäpä captïmi.  
\v 18 Manam mayanpis bïdäta apaman'achu; quiquilläpïmi uycuśhä. Maquilläćhümari unäpäpis, śhalcamunäpäpis cayan. Caynu lulayní cananpä Taytäpïmi ćhasquiyculá” nil. 
\p  
\v 19 Chayta uyalipäculmi Israelcunaca ishcayman iwinacälälin.  
\v 20 Waquinnincunam nipäcula: “Cay'a Satanaśhpa gänaśha lücuśhäta ¿imapämá uyalipäcunqui?” nil.  
\v 21 Juccunañatacmi: “Satanaśhpa gänäśha cayal'a caynu allin yaćhachicuyta manam limayanmanchu, nï nasïdunpi aplactapis licayächinmanchu” nipäcula. 
\s1 Caćhamuśhan Salbacüca Jesus caśhanta manam awnipäcunchu 
\p  
\v 22 Ñatac Jerusalenćhümi Diospa Wasinta Chuyanchaśhan Yalpanan Fista tamya timpućhu cala.  
\v 23 Chayćhümi chay wasip “Salomonpa Patyun” nishanćhu Jesus puliyäla.  
\v 24 Chaymi Israelcunäpa puydïnincuna cunćhacaycälil: “¿Imaycamatan umäta nanachipämanqui? Dios Caćhamuśhan Salbacüca rasunpa cayal'a, ¡sumätañari niycälimay!” nin. 
\p  
\v 25 Niptinmi Jesus: “Niyaptïpis amcuna manamá chalapaculcanquichu. Jinaman Taytäpa munayninwan imaymana milagru lulaśhäcunam pï caśhätapis tantialcächishunqui.  
\v 26 Jinaptinpis ya'ap uwishní mana capäculmi shimïta nï chalapacamanquichu.  
\v 27 Ñatac ya'a uwishnïcunawan lisinacümi. Chaymi shimïta uyalil atipäman.  
\v 28-29 Paycunactam mana imaypis chincapäcunanpä wiñay cawsayta uycú. Taytá uycayämaptinmari mana mayanpis maquïpïta ućhiman'achu. Pay lluypïtapis sumä munayniyu cayaptinmi maquinpïta mana mayanpis ućhipäcunmanchu.  
\v 30 Ya'a Taytäwan jucllamari capäcú” nin. 
\p  
\v 31 Chayćhümi Israelcunaca lumicta yapa apticälälin Jesusta tamshälälinanpä  
\v 32 Jinaptinmi: “Taytäpïmi imaymana milagrucunacta amcunaćhu lulalá. ¿Mayanninpïtatá tamshayta munacayalcämanqui?” nin. 
\p  
\v 33 Niptinmi: “¡Allin lulaśhayquipïchu manamá, sinu'a Tayta Diosta jalutacuśhayquipïtamari! ¡Am nunalla cayal Diostucuśhayquipïtamá!” nicuyalcan. 
\p  
\v 34 Jesusñatacmi: “Quiquin Diosninchic isquirbishancäćhümi ‘Amcuna dioscunam capäcunqui’\x + \xo 10:34 \xt Sal 82.6\x* nunacunallacta nila.  
\v 35-36 Yaćhaśhanchicnüpis camachicuy rasunca cayal'a, manam articunchu. Chayurá chaynu nunacunäman shiminta uycuśhancunällacta ‘dioscuna’ niyal'a, maynülämi cay pachäman quiquin Śhuñaycuśhan Caćhamuśhancätá ninmanpis. Chayurá ‘Paypa chulinmi cá’ nishalläpi ¿imapïtan-nila Tayta Diosta jalutacüpa licapämanqui?  
\v 37 Taytá nimäśhancunacta mana lulapti'a ama chalapacalcämaychu.  
\v 38 Nimäśhanta lulaptïñatacmi ichá, masqui ya'acta mana ćhasquipämalpis lulaśhäcäman-ari chalapaculcay Tayta Dios ya'aćhu caśhanta, chaynütac ya'apis Taytäćhu caśhäta tantiapäcunayquipä” nin.  
\v 39 Chaymi yapa wićhachinanpä chalayta munacuyalcaptin chaypi chincacula. 
\p  
\v 40 Chaypïmi Jordan mayüćhu Bawtisä Juan unay bawtisaśhancäman Jesus yapa chimpala chayćhu caycunanpä.  
\v 41 Chayman achca nunacuna licä lïcunämi: “Bawtisä Juan masqui ima milagructa mana lulayalpis, śhamü nunapi willamäśhanchiccänüllamá rasunpa canan pasacuyan” nipäcula.  
\v 42 Chayćhüñatacmi Jesusman achca chalapaculcäla. 
\c 11  
\s1 Jesusmi Lazarocta cawsachin 
\p  
\v 1 Ñatac Betania malcayu Martapwan Mariap tulin Lazarom chayćhu ishyayäña.  
\v 2 (Cay Lazarop panin Mariam pirfümiwan Jesuspa ćhaquinman jillpuycul ächanwan chaquichïca cala.)  
\v 3 Chaymi Lazarop panincuna Jesusman caćhapäcula: “Taytay, cuyaśhayqui Lazarom pasaypiña ishyayällan” nil. 
\p  
\v 4 Cayta Jesus uyalïlulmi: “Chay ishyaycá wañuycällaćhüchu manam camacan'a. Aśhwanpa caypam Tayta Dios altuman juluycuśha can'a jinaman caćhamuśhan chulin munayniyu caśhantapis camalachin'a” nin.  
\v 5-6 Ñatac chaynu ishyaśhanta uyalilpis Jesus chay Lazaroctapis, Mariactapis, Martactapis allicta cuyayalpis ishcay muyunlämi chay caśhancächu caycula. 
\p  
\v 7 Chaypïlämi Jesus yaćhapacünincunacta: “Acuchun cutishun Judea-läducta” nin. 
\p  
\v 8 Niptinmi: “Yaćhachicü taytay, anyan śhaluyllalä chay malcäćhu tamshayta ñacayalcäśhuptiquichun ¿canan cutiyta munayanquiman?” nipäcun. 
\p  
\v 9 Niptinmi yaćhapacünincunacta: “¿Manachun muyuncäćhu ćhunca ishcayniyu üra cayan? Cay pachäpa acchin acchiptinmi muyunpa pulïcá mana imamanpis mitcacacunchu.\f + \fr 11:9 \fk mitcacacun: \ft Waquincunaćhu'a “miticacun” nipäcunmi.\f* 
\v 10 Ñatac tutapäcäćhu pulïcämi ichá, acchi mana captin mitcacacülun” nin. 
\p  
\v 11 Nishanpïtam: “Amigunchic Lazarom puñüśha cayan. Chaymi licchachï lishä” nin. 
\p  
\v 12 Yaćhapacünincunañatacmi: “Taytay, puñuyalñá allinpacayämunñaćhá” nipäcula. 
\p  
\v 13 Ñatac Jesus chaynüllap niyäla: “Lazaro wañüśham cayan” ninantam. Yaćhapacünincunañatacmi puñuyllaman pinsapäcula.  
\v 14 Chaymi Jesus tantiapaśhta nin: “Lazaro wañüśham cayan.  
\v 15 Chayćhu mana caśhäca amcunap allinniquipä captinmi cushicú. Cananpi'a chalapacuyniqui masïsum tacyalpun'a. Acuchun, payman lishun” nin. 
\p  
\v 16 Niptinmi “Awacha”\f + \fr 11:16 \fk awacha: \ft Waquincunaćhu'a ‘awashcha’ nipäcunmi.\f* nipäcuśhan Tomas yaćhapacü-masincunacta: “Acuchun paywan lishun ya'anchicpis, wañulpis wañuśhun paywanćha” nin. 
\p  
\v 17 Ñatac Jesus Betania malcäta ćhänanpämi Lazaro tawa muyunña pampäśha cayäñä.  
\v 18-19 Chay Betania malca Jerusalenpïta ćhawpi üranuy puliycuylla captinmi Jerusalenpïta achca Israelcuna Mariactawan Martacta tulin wañuśhanpi watucuycü lipäcula.  
\v 20 Ñatac Jesus ñaćhapaycayämuśhanta Marta musyälulmi ćhasquïnin talipäla; ñañan Mariañatacmi wasinćhu quïdälun. 
\p  
\v 21 Chayćhu Jesuswan tincülulmi: “Taytay, cayćhu am cayaptiqui'a manaćh tulí wañunmanchu cala.  
\v 22 Chaynu captinpis yaćhayämi Tayta Diosta mañacuptiqui mañacuyniquimannuy imacta uśhunayquitapis” nin. 
\p  
\v 23 Niptinmi Jesus: “Tuliqui'a śhalcämun'am” nin. 
\p  
\v 24 Martañatacmi: “Aw, tantiayämi llapa wañücuna śhalcamunan muyuncäćhu śhalcamunanta” nin. 
\p  
\v 25 Niptinmi Jesus: “Ya'am śhalcachimüca cawsachïca cayá. Ya'aman chalapacamäcá wañulpis cawsan'am.  
\v 26 Ñatac chalapacamal cawsäcá manam wiñay simpri wañuyta lisin'achu. ¿Cay nishäman chalapacamanquichun?” nin. 
\p  
\v 27 Niptinmi Marta: “Aw taytay, chalapacümi Dios Caćhamuśhan Chulin Salbacüca, cay pachäman śhamüca caśhayquita” nin. 
\p  
\v 28 Nilculmi ñañan Mariaman cutilcul japächalcul linlillanćhu: “Cayćhüñam yaćhachicüca cacuyan. Ayayäśhunquim” nin.  
\v 29 Niycüluptin-pacham mana-mana śhalcuculcul Jesusman pasacun.  
\v 30 Ñatac Mariap, Martap malcanman Jesus manalämi ćhämulachu. Chay Marta talipäśhanćhu tincuśhancällaćhülämi cayäla.  
\v 31 Chaymi chay wañupacücäta cumpañä Israelcunaca Maria wayra-wayra pasacuśhanta licälälil “Pantiuncäćhu tulinta wa'apäćha liyan” nil ipanta atipäcula. 
\p  
\v 32 Chay Jesus caśhancäman ćhälulmi puntanman un'ulacuycul nila: “Taytay, am cayćhu cayaptiqui'a tulí manaćh wañunmanchu cala” nil. 
\p  
\v 33 Chayćhu Mariawan cusca liwshïnincunapis wa'acuptinmi, Jesuspa śhun'unpis alalaycuptin nila:  
\v 34 “¿Maymantan pampälälinqui?” nil. 
\p Niptinmi: “Taytay, acuchun licaycamulläśhun” nil puśhapäcula.  
\v 35 Chayćhümi Jesuspis wa'acula. 
\p  
\v 36 Chayta licalmi Israelcunaca: “Licay-ari, ¡maynu cuyayninmi cañä!” nipäcun. 
\p  
\v 37 Waquinnincunañatacmi: “Cay aplactapis licayächil'a Lazaro mana wañunanpä ¿manachun imallactapis lulanman cala?” nila. 
\p  
\v 38 Ñatac chay Lazaro pampaläśhancämi juc maćhaynuy ućhcüśha jatun palta lumiwan wićhäśha cala. Chayman aśhuyculmi Jesus śhun'unpis alaläśha nila:  
\v 39 “Cay lumïta aśhuchipäcuy” nil. 
\p Niptinmi wañücäpa panin Marta: “Taytay, tawa muyun wañucuśhan cayaptin'a aśhnaliyanñaćh” nin. 
\p  
\v 40 Niptinmi Jesus: “¿Manachun nilac ‘Chalapacamal'a Diospa sumä cayninta licanquim?’ nil” nin.  
\v 41 Chaynu chay lumïta aśhülächiptinñatacmi Jesus janay pachäta licalcul sulpayta ucula: “Sulpá cachun taytay, mañacuylläta uyalimäśhayquipi.  
\v 42 Rasunpa am imaypis uyalimäśhayquita yaćhayalpis, cayta niyá cay muyülïnïcunaćhu cäcunaca ampi caćhamuśha caśhäta tantiapäcunanpämi” nil. 
\p  
\v 43 Nilculmi ayaycaćhaypanuy “¡Lazaro, yalamuy!” nin.  
\v 44 Chayćhümi wañüca umanpi ćhaquincama illpüśha, cäranpis juc lataśhwan śhucupäśha yalämun. Chaymi Jesus: “Pasquipäcuy pulinanpä” nin. 
\s1 Jesusta wañuchipäcunanpämi limanaculcan 
\r Mt 26.1-5; Mc 14.1-2; Lc 22.1-2 
\p  
\v 45 Cayta licälälilmi Mariaman watucü lï Israelcunaca Jesusman achca chalapaculcäla.  
\v 46 Waquinnincunañatacmi ichá Jesus lulaśhanta fariseocunäman willaycü pasaculcäla.  
\v 47 Chaymi puydï sasirdüticunäwan fariseocunaca Cunsïjup puydïnincunaćhu juntunacalcälil: “¿Imanäśhuntá cay nunäwan? Ancha anchap milagrucunactañam lulacuyällan.  
\v 48 Jinacta licapayäśhá, paytaćh jinantin nunäpis chalapacalcälil aticulcan'a. Jinaptinćha Roma malcap cachacuncuna śhalcälimul llapa llapa ima cäninchictapis, quiquinchictapis chincächimachwan” ninacücuyalcan. 
\p  
\v 49 Chayćhümi chay watapä puydïnin sasirdüti cä Caifas limalïla: “Amcuna manamá imactapis yaćhapäcunquichu.  
\v 50 Malcantin wañunanchicpïtá aśhwanpa lluypïta jucllay nunalla wañüchun” nil. 
\p  
\v 51 Ñatac Caifas manam quiquillanpïtachu nila. Sinu'a chay wataćhu sasirdüticunap puydïnin captinmi quiquin Tayta Dios limachila “Jesusmi wañun'a jinantin Israelcunä-laycu” ninanpä.  
\v 52 Ñatac manam cay malcallapächu sinu'a jinantin pachäćhu Diospa Chulin chi'ishacunäta\f + \fr 11:52 \fk chi'iy: \ft Waquincunaćhu'a “wichiy” nipäcunmi.\f* jucllachamunanpämi. 
\p  
\v 53 Chay muyunpïtam Israelcunap puydïnincuna Jesusta wañuchinanpä limanacälälin.  
\v 54 Chaymi Israelcunäpa ñawquin'a Jesus manaña pulilañachu. Aśhwanpam Judeap malcancunapïta, chunyäninpa läduscanćhu Efrain nishan malcaman licula yaćhapacünincunawan caycälï. 
\p  
\v 55 Ñatac Libraculcäśhan Fista ñam ji'acaycayämulaña. Chaymi manaläpis allaycuptin custumrinmannuy yacuwan chuyanchaculcänanpä juc-läducunaćhu yaćhä Israelcunäpis Jerusalenman puntapäcula.  
\v 56 Chayćhümi Jesusta ashipäcul Diospa chuya wasinćhu: “¿Imanipäcunquim? ¿Cay fistaman śhamun'achućh manachućh?” ninaculcäla.  
\v 57 Ñatac puydï sasirdüticunäwan fariseocunämi camachila “Jesusta mayćhüpis licälälil'a willapämay chalachipäcunäpä” nil. 
\c 12  
\s1 Jesusmi Lazarop wasinman ćhan 
\r Mt 26.6-13; Mc 14.3-9 
\p  
\v 1 Ñatac süta muyunlä Libraculcäśhan Fistapä faltayaptinmi, Jesus ćhäla Lazarocta śhalcachimuśhan Betania malcaman.  
\v 2 Chayćhümi Jesus-laycu cumbiducta lulaycapäcula. Martañatacmi ćhacacamula. Lazaroñatacmi Jesuswan cusca micapäcunanpä täcuyalcäla.  
\v 3 Chayćhu Mariañatacmi butïllaćhu\f + \fr 12:3 \ft Griego limayćhu'a “ćhawpi kïlu-yupayllam” niyanmi.\f* sumä-sumä ćhaniyu nardo śhutiyu pirfümiwan Jesuspa ćhaquinman jillpuycul ächanwan pichaycula. Chayćhümi chay pirfümip mishqui aśhnaynin wasinman lluy juntäla.  
\v 4 Ñatac Jesusta ipanchananpä cä Simonpa chulin Judas Iscarioti yaćhapacüninmi:  
\v 5 “¡¿Imanuypatan quimsa paćhac (300) muyun trabajup ćhaniyüta pampaman muyuyächinman?! Aśhwanpaćh lanticulcul wacchacunäta yanapaycunman cal'a” nicuyan.  
\v 6 Cayta nila manam rasunpa wacchacunäta llaquipayninwanchu, sinu'a suwacunan-laycum. Paypa maquinćhu illay captinmi munalishanmannuy chalala. 
\p  
\v 7 Chaymi Jesus: “Jina lulachun. Caycunactá ćhulalächila wañuptí pampacunäpä alistaycamayninwanmi.  
\v 8 Wacchacunacá imaypis amcunawanläćha capäcun'a. Ya'am ichá pasaypipächu cayćhu mana caśhä” nin. 
\p  
\v 9 Ñatac achca-achca Israelcunam yaćhälälila Jesus chayćhu caśhanta. Chaymi payta chaynütac Lazaro wañuśhanpïta śhalcamuśhantawan licä pasaculcäla.  
\v 10-11 Chaymi puydï sasirdüticunaca Lazaroctapis wañuchipäcunanpä limanacälälila: “Cay Lazarop jananmi achca-achca Jesusman chalapacalcälil ya'anchicpïta japächacücuyalcan” nil. 
\s1 Jesusmi Jerusalenman yaycun 
\r Mt 21.1-11; Mc 11.1-11; Lc 19.28-40 
\p  
\v 12 Ñatac chay walantin muyun chay fistaman ćhämü nunacunämi yaćhälälin Jerusalenman Jesus ćhämunanta.  
\v 13 Chaymi talipapäcula palmïra jaćhap lapinta\f + \fr 12:13 \fk lapi: \ft Waquincunaćhu'a “lapla” nipäcunmi.\f* apticälälisha-cama bïbaśhtin: 
\q1 “¡Cawsachun Diosninchicpa pudirninca! ¡Cawsachun Israelcunap Mandäninca!” nil. 
\p  
\v 14 Jesusñatacmi malta aśhnucta talilcul sillacuśha Jerusalenman yaycula Diospa shiminćhu nishanmannuy. 
\q1  
\v 15 Chayćhümi: “Ama manchacuychu, Jerusalenćhu chulilläcuna.\f + \fr 12:15 \ft Griego limayćhu'a “Sionpa walmi chulin” niyanmi.\f* 
\q1 Juc malta aśhnuman sillacüśham Mandacüniqui śhayämun”\x + \xo 12:15 \xt Is 40.9; Sof 3.16\x* niyan. 
\p  
\v 16 Caycuna pasayaptinmi cay nishanca lulacäśhanta yaćhapacünincuna mana tantiapäculachu. Janay pachäta Jesus cuticuptinlämi paypi cay isquirbishancunaca lulacäśhanta tantiapäcula. 
\p  
\v 17 Lazarocta śhalcachimuśhanta licä nunacunäñatacmi chay pasaśhanta jinalla lluy willapacuyalcäla.  
\v 18 Chaymi chaynu milagructa lulaśhanta uyalil achca nunacuna Jesusta ćhasquipäcü yalatityapämula.  
\v 19 Chayta licalmi fariseocunäñatac: 
\p “¡Licay-ari! Jinantin nunacunäña aticuyalcan. Imactapis manam julucunchicchu” nipäcula. 
\s1 Jesuspa üran ji'acaycayämunñam 
\p  
\v 20 Chay fistaćhu Diosta alawaycälinanpä lïcunaćhümi mana-Israelcunäpis capäcuñä.  
\v 21 Paycunam Galileap Betsaida malcayu Felipiman aśhuycälil: “Taytay, Jesuswanmi tincuycuyta munapäcú” nipäcun.  
\v 22 Niptinmi Felipe Andresman lilcul willaycula. Chaypïtam pulanña Jesusman niycü lipäcula. 
\p  
\v 23 Chaynu mana-Israelcuna ashiyalcaptinmi Jesus nila: “Canan ürá ćhämunñam ya'a Nunap Chulinca rasunpa maynu sumä caśhätapis tantiapäcunanpä.  
\v 24 Sumäta uyalipämay: juc trïgu muju allpäman ćhal mana wañuptin'a, jina jucllay mujullam. Wañülulmi ichá achcaman milälunlä canpis.  
\v 25 Chaymi cawsayninta ama-pacha nïcá cawsayninta apacun'a. Cay pachäćhu cawsaynintapis imapis mana ucücäñatacmi ichá wiñay simpripä ćhulan'a.  
\v 26 Mayanpis sirbïmänïcunacá atimänanmi cayan; chay sirbïnïcunawanmi ya'a caśhäcäćhu cusca capäcuśhä. Jinaman'a Taytäpis altumanmi ćhulaycun'a” nil. 
\s1 Jesusmi wañunanpi liman 
\p  
\v 27 Nishanpïtam Jesus: “Canan bïdäćhüchu manañam cacuyá. ¿Chaychun ‘Taytay cay śhamücäćhu pasamänancunapïta julaycamay’ nishä? Manamá; cay lulanäpämari śhamulá.  
\v 28 Chayurá, Taytay, am altuman julucuycuy” nin. 
\p Niptinmi janay pachäpi ayalpämula: “Ñam ya'a altuman juluycuśhaña cayá; yapañatacmi altuman juluycuśha caśhä” nil. 
\p  
\v 29 Chayćhu nunacunäñatacmi chay ayalpämuśhanta uyalïlälil: “Räyuchućh paćhyälun” nipäcun. 
\p Waquinnincunañatacmi “Anjilchućh limapälun” nipäcula. 
\p  
\v 30 Chayćhümi Jesus: “Limamuśhanca manam ya'a-laycuchu, sinu'a amcuna-laycum” nin. 
\p  
\v 31 Nilculmi: “Cananmi cay pachäćhu jinantin nunacunaca cäraycuśha can'a. Chaynütacmi cay pachäta duyñuchacüśha cä Satanaśhpis alupacüśha can'a.  
\v 32 Ñatac śhalcachisha captïmi llapa nuna ya'aman śhapämun'a” nila.  
\v 33 Cay nishanwanmi tantiachila curuśhcäćhu imanuypa wañunanpäpis. 
\p  
\v 34 Chay nunacunäñatacmi: “Camachicuypam yaćhanchic Diospa Caćhamuśhan Salbacüca pasaypipä cawsananta. ¿Chaychun amñatac ‘Rasun Nunap Chulincá wañun'am’ niyanquiman? Chayurá ¿mayanpïtá limayanqui?” nicuyalcan. 
\p  
\v 35 Niptinmi Jesus: “Amcunawan uchucllactañam caycuśhä acchiycälinacpä. Chaymi acchi caśhancama puliycälinayqui. Tutapäca chaläśhuptiquim ichá mana maypa linayquitapis yaćhapäcunquiñachu.  
\v 36 Chaymi caśhäcamá acchïman chalapaculcay, acchïćhu cawsapäcunayquipä” nin. 
\p Caycunacta limayta camacalculmi Israelcunäwan mana licachicullal licula. 
\s1 Israelpa waquin puydïnincuna manam chalapaculcanchu 
\p  
\v 37 Chaynu Jesus milagru lulaśhancunacta Israelcunaca may-maytaña licayalcalpis manam chalapaculcälachu.  
\v 38 Caynüpam Diospa unay willacünin Isaias nishanca lulacacula. Chayćhümi niyan: 
\q1 “Tayta Dios ¿mayanllá willacuśhanchicta ćhasquiyculatan? 
\q1 ¿Mayanllá Tayta Diospa munayninta tantiayculatan?”\x + \xo 12:38 \xt Is 53.1\x* nil. 
\p  
\v 39 Caynu mana chalapaculcälachu Isaias isquirbishanćhu caynu niyaptintacmi: 
\q1  
\v 40 “Ñawincunacta aplälun, śhun'untapis lumiyächin. 
\q1 Chaymi mana licapäcun'achu, uyalipäcun'achu, tantiapäcun'achu, 
\q1 nïtac cutipämun'achu sänaycachinäpäpis”\x + \xo 12:40 \xt Is 6.10\x* nil. 
\p  
\v 41 Isaias lluy caycunacta willala Jesuspa sumä cayninta licalmi.  
\v 42 Masqui achca mana chalapacuyalcaptinpis Jesusman achcatacmi chalapaculcäla aśhta Israelpa puydïnincunapis. Ñatac fariseocunaca juntunacuynincunapi alülälinanpïta manchaculmi lluypa ñawquin'a chalapaculcäśhanta mana camalachipäculachu.  
\v 43 Paycuna Dioswan allinpa licachicunantá, nunacunäwan allinpa licachicuyllactam wañupaculcäla. 
\p  
\v 44 Jesusmi chayćhu callapawan nila: “Ya'aman chalapacücá manam ya'allamanchu, sinu'a caćhamänïmanpis chalapacuyanmi.  
\v 45 Ya'acta licamäcá caćhamänïtawanmi licayan.  
\v 46 Cay pachäman acchinümi śhamulá chalapacamäcunaca yanawyayä tutapäcäćhu manaña cayänanpä.  
\v 47 Ñatac willacuynïta uyaliyal mana cäsucücunätá manam ya'achu cäraycuśhä. Cay pachäman chaypächu manamari śhamulá, sinu'a salbaycunäpämi.  
\v 48 Ñatac mayanpis jamuyal willacuynïta mana cäsucücunätá cäraycul mućhuycachinanpä cayanñam. Chay quiquin willacuyllämi unanchaycuśhan muyuncäćhu mućhuycachin'a.  
\v 49 Ya'a quiquilläpïtachu manam limayá. Aśhwanpa quiquin caćhamäní Taytämi camachimäla imanuypa yaćhachinäpäpis limanäpäpis.  
\v 50 Yaćhämi paypa limaynin wiñay simpripä cawsachishanta. Chaymi Taytá nimäśhantanülla willacuyá” nila. 
\c 13  
\s1 Jesusmi yaćhapacünincunap ćhaquinta pa'an 
\p  
\v 1 Chay Libraculcäśhan Fistapä juc muyunllañam cayäla. Jesusñatacmi cay pachäpïta Taytan caśhancäman cuticunan üra ćhämuśhanta yaćhalaña. Pay cay pachäćhu nunancunactam cuyala. Chaymi maynu-maynu cuyaśhantapis camalaycachinanpä cayäla. 
\p  
\v 2-4 Ñatac supayca Simon Iscariotip chulin Judaspa śhun'unmanmi ćhuläla Jesusta ipanchananpä. Jesusñatacmi quiquin Tayta Diospi śhamuśhantapis payman cutinantapis, jinaman maquinman lluy imacta Taytan ćhulaycuśhantapis tuquicta yaćhala. Chay sinayalcäśhanćhümi Jesus śhalcuculcul janä müdananta lluśhticulcul tuallacta wi'awninman watacülun.  
\v 5 Jinalculmi labaturiuman yacucta ćhulaycul yaćhapacünincunap ćhaquinta pa'alcul wi'awninćhu tualläwanñatac pichala.  
\v 6 Ñatac Simon Pedroman pa'ananpä ćhäluptinmi: “Taytay ¿amlächun ćhaquïta pa'ayämanquiman?” nin. 
\p  
\v 7 Niptinmi: “Caycunacta manalämi canan tantianquimanlächu. Chaypïtam ichá tantiapäcunquiman” nin. 
\p  
\v 8 Niptinmi Pedro: “Manam imaypis ćhaquïtá pa'acamanquimanchu” nil mićhacula. 
\p Niptinmi: “Mana pa'apti'a, manam ya'apä canquimanchu” nin. 
\p  
\v 9 Niptinmi: “Taytay, chaynu captin'a, maquïtawan umätawan-ari pa'aycallämay” nin. 
\p  
\v 10 Niptinmi: “Mayanpis almacuśhacá lluy chuyañam cayan; ćhaquillantañam pa'acunan. Amcuna chuyañam cayalcanqui, masqui lluy mana capäculpis” nin.  
\v 11 Caynu Jesus nila “Manam lluychu chuya cayalcanqui” nil pï ipanchanantapis yaćhalmi. 
\p  
\v 12 Ñatac lluy yaćhapacünincunap ćhaquinta pa'ayta camacalpulmi, caśhan müdaculcul taycucuycul nila: “¿Tantiapäcunquichun imapi caynu lulaśhäta?  
\v 13 Amcuna ‘Yaćhachicü taytay’ nipämanquim. Rasunpa nimäśhayquinümi cayá.  
\v 14 Ya'a yaćhachicü taytayquilä uyway nunanu ćhaquiquicunacta pa'ayapti'a, amcunapis quiquiqui-pula pa'anaculcänayquim.  
\v 15-16 Rasunpa juc uyway manam patrunninpïta maslächu, nïtac juc caćhaśha nunapis caćhäninpïta maslächu. Chaymi caynu lulaynïwan yaćhaycälichic amcunapis lulaycälinayquipä.  
\v 17 Canan caycunacta uyalicul lulapäcul'a cushisham capäcunqui. 
\p  
\v 18 “Ñatac manam llapayquipïchu limayá. Mayanniquicuna aclaśha capäcuśhayquitapis yaćhämari. Rasunpa isquirbishancunaćhu ‘Cusca micuśhäcämi ipanchäní licalïlun’\x + \xo 13:18 \xt Sal 41.9\x* nishancämi canan lulacacun'a.  
\v 19 Cananpïmi cay pasanantapis willayalcac lluy lulacaptin rasunpa pï caśhäta tantiapäcunayquipä.  
\v 20 Sumäta uyalipäcuy: caćhacuśhäta ćhasquïcá quiquïtam ćhasquiyäman; ya'acta ćhasquiycamäcá caćhamäní Taytätapis ćhasquiyanmi” nin. 
\s1 Judas ipanchanantam Jesus willan 
\r Mt 26.20-25; Mc 14.17-21; Lc 22.21-23 
\p  
\v 21 Caycunacta nilculmi Jesus sumä-sumäta llaquisha cayal: “Rasunpa jucniquim ipanchapämanqui” nin. 
\p  
\v 22 Niptinmi yaćhapacünincuna licapänacuyllaman camälälila, “¿Mayannïćha cayalcá?” nicuśhtin.  
\v 23 Ñatac cuyaśhan yaćhapacüninmi Jesuspa lädunćhu cayäla. 
\p  
\v 24 Paytam Simon Pedro siñaśhchayllap “¿Mayanshi chay cayan?” nil tantiachila tapunanpä. 
\p  
\v 25 Niptinmi masta jućhutyalcul: “Taytay, ¿mayannïtan chay ipanchäniqui cayalcá?” nin. 
\p  
\v 26 Niptinmi Jesus: “Tantacta puśhtalcachil\f + \fr 13:26 \ft Waquincunaćhu'a “puśhcalcachil” nipäcunmi.\f* uśhäcämi cayan” nin. Nilculmi tantacta puśhtalcachil Simon Iscariotip chulin Judasman uycula.  
\v 27 Chayćhu ćhasquïllaptin-pacham Judas Satanaśhpa maquinćhu cananpä llallichicüla. 
\p Chaymi Jesus: “Lulanayquita apuraypa lulay” nin. 
\p  
\v 28 Niptinmi chayćhu lluy micücunaca imapi chaynüta nishantapis mana tantiapäculachu.  
\v 29 Ñatac Judas illay uywäca captinmi “ ‘Fistäpä lluy lantipacamuy’ niyanćha, ütac ‘Wacchacunaman uycamuy’ niyanćha” nil nipäcula.  
\v 30 Ñatac chay tanta uśhancäta Judas micacalpulmi tutapäśhaña pasacula. 
\s1 Jesusmi muśhü camachicuyta uycun 
\p  
\v 31 Chaynu pasacuptinmi Jesus: “Canan ürá ćhämunñam. Ya'a Rasun Nunap Chulinca maynu sumä caycuśhäta ñam camalachicuśhäña. Ñatac ya'a lulaśhäwanmi Tayta Dios altuman juluycuśha can'a.  
\v 32 Jinaycuptí ya'actapis altuman julaycamänan cayllaćhüñamá cacuyan. 
\p  
\v 33 “Cuyaśhäcuna, ash timpullañam amcunawan caycuśhä. Chayćhu ashipämalpis Israelcunäta nishänüpis manam lishäman'a lipäcunquimanlächu.  
\v 34 Cananmi muśhü camachicuyta niycälic: quiquiqui-pula cuyanaculcay. Maynümi cuyapäculac chaynu-ari cuyanaculcay.  
\v 35 Chaynu cuyanaculcaptiquim yaćhapacünïcuna caśhayquita lluypis tantiapäcun'a” nin. 
\s1 Pedro ipanchanantam Jesus willan 
\r Mt 26.31-35; Mc 14.27-31; Lc 22.31-34 
\p  
\v 36 Niptinmi Simon Pedro: “Taytay, ¿maytatan licunqui?” nin. 
\p Niptinmi: “Lishäcäman canan manam atimanquimanlächu. Chaypïtaćh ichá śhamunquiman” nin. 
\p  
\v 37 Niptinmi Pedro: “¿Taytay, imapïtan canan mana aticmanlächu? Am-laycu bïdätapis uśhämi” nicuyan. 
\p  
\v 38 Jesusñatacmi: “¿Rasunpachun bïdayquitapis uycunquiman? Rasunpa manaläpis wallpa wa'amuptinmi, quimsa cutictaña ‘Manam lisïchu’ nil nimanqui” nin. 
\c 14  
\s1 “Ya'am caminuca, rasun allinca, cawsayta uycücäpis cayá” 
\p  
\v 1 Nishanpïmi: “Amañari anchap jucmanyäśha cayalcaychu. Aśhwanpa Tayta Diosmanpis, ya'amanpis chalapacalcämay.  
\v 2-3 Taytá caśhancäćhümi yaćhanapä achca jäcuyalcan. Chaymi ćhäpämunayquipä allichamü liyá. Chaynu allichalcamulmi puśhäniqui cutimuśhä, ya'a caśhäcäćhu amcunapis capäcunayquipä. Sïchuśh chaynu mana captin'a manaćh ‘Allichä-ari lishä’ niyalcacmanchu.  
\v 4 Ñatac mayta linätapis, maycäpa caminu lishantapis yaćhapäcunquiñam” nin. 
\p  
\v 5 Niptinmi Tomas: “Taytay, manatac mayta linayquitapis yaćhapäcüchu. ¿Imanuypatá chay caminütälä lisïlälïman?” nin. 
\p  
\v 6 Niptinmi Jesus nin: “Ya'am caminuca, rasun allinca, cawsayta uycücäpis cayá. Ya'allapamari Taytäman ćhanman.  
\v 7 Amcuna ya'acta lisipämal'a Taytätapis lisipäcunquim. Cananpïtá lisïlälinquiñam. Jinaman'a licälälinquiñam canpis” nil. 
\p  
\v 8 Niptinmi yaćhapacünin Felipe: “Taytay, Tayta Diosta licaycachimänallayquipämi capäcuśhä” nin. 
\p  
\v 9 Jesusñatacmi: “Felipe, ¿cay-chica timpu cayaptinchicchun manalä lisimanquimanchu? Ya'acta licamäcá, Taytätapis licaycunñam. ¿Chaychun canan ‘licachimay’ niyämanquimanlä canpis?  
\v 10 Icha ¿manachun Taytäćhu ya'a caśhäta chaynütac Taytäpis ya'aćhu caśhanta chalapacunqui? Imanishacpis manam quiquilläpïchu, sinu'a ya'aćhu cä Taytämi lulaycuyan.  
\v 11 Chalapacamay-ari Taytäwan juclla capäcuśhäta masqui milagrucunacta lulaśhalläpapis.  
\v 12 Rasunpa, ya'aman chalapacamäcunacá ya'a lulaśhäcunactam lulapäcun'a. Taytäman cutiptïmi ichá sumä mascunactalä lulapäcun'apis.  
\v 13 Ñatac ya'ap pudirní cayal Taytäta imactapis mañaculcaptiqui'a uycuśhämi, Taytá maynu munayniyu caśhanta ya'awan camalaycachinanpä.  
\v 14 Chayurá ya'ap śhutïćhu mañacalcämuptiqui'a imactapis ćhasquiycälinquim. 
\s1 Chuya Ispiritucta caćhamunanpämi limalicun 
\p  
\v 15 “Ñatac rasunpa cuyapämal'a, yaćhachicuynïmannümi cawsaycälinqui.  
\v 16-17 Chaynütacmi Taytäta mañacuśhä juc Caminaycüniquita caćhamunanpä. Chay rasuncäta camalachï Ispiritunmari amcunawan imaycamapis caycun'a. Mana chalapacücunacá payta mana licalmi lisilmi nï ćhasquïpäcunmanchu. Amcunam ichá cusca cayalcal lisipäcunqui. Jinamanñatacmi amcunaćhu caycun'a.  
\v 18 Manatacmi caćhaycälishayquichu, sinu'a amcunaman cutimuśhämi.  
\v 19 Ñatac ishcay quimsa muyuncunapïtanuy caypi licuptïmi manaña licapäman'añachu. Amcunam ichá caśhan cawsamuptí licapämanqui. Chaymari amcunapis cawsapäcunqui.  
\v 20 Chay muyuncunaćhümi tantiapäcunqui Taytäćhu caśhäta, chaynütac amcunapis ya'aćhu capäcuśhayquita, jinaman'a ya'apis amcunaćhu caśhäta.  
\v 21 Mayanpis shimïta uyalicul lulaycücá llapan śhun'unwanmi cuyaman. Cuyamäcunätá Taytäpis cuyan'am. Ya'añatacmi sumäta camalaycachicuśhä” nin. 
\p  
\v 22 Chayćhümi juc Judas — cay'a manamá Judas Iscariotichu — nin: “Taytay, ¿imapïtan ya'acunallaćhu camalaycachicunqui, jinantin nunacunaćhu'a manatac?” nil. 
\p  
\v 23 Niptinmi: “Cuyamäcá camachicuynïmannümi cawsaycun'a ñatac Taytäpis cuyan'am. Taytäwan cutipämulmi cuyamänïcunawanpis yaćhapäcuśhä.  
\v 24 Mana cuyamäcunacá camachicuynïmannüchu manam cawsapäcun'a. Cay nishäcunaca manam quiquilläpïchu sinu'a caćhamäní Taytäpïmi.  
\v 25 Cayćhu caśhäcamam caycunacta yaćhayalcächic.  
\v 26 Śhamü muyuncunaćhüñatacmi ichá Taytá Caminaycüniquipä caćhamuśhan Chuya Ispiritu yaćhachipäcuśhunqui. Cay yaćhachishäcunätapis yalpachipäcuśhunquim. 
\p  
\v 27 “Canan'a ya'a-laycum jawca caycälinqui. Jawca caynïtam uycälicña. Cay jawca cayta uśhac'a manam cay pachäćhu nunacuna uśhancänüllachu. Chayurá ama jucmanyapäcunquichu, nï manchaliculcanquichu.  
\v 28 Uyalipäculanquiñam ‘Licuśhämi; chaypi caśhanmi amcunaman cutimuśhä’ nishäta. Rasunpa cuyapämal'a ya'apïpis mas munayniyu Taytäwan cusca canäpä liyapti'a cushiculcanquimanmi.  
\v 29 Lluy caycunacta willayalcac manaläpis pasayaptinlämi, cay nishänülla pasaptin chalapacalcämänayquipä. 
\p  
\v 30 “Canan'a cay pachäta duyñuchacüśhaca ji'acaycayämuptinñam manaña timpu cacuyanñachu limananchicpä. Manamá ya'apïta mas munayniyu captinchu,  
\v 31 sinu'a cananpïta jinantin nunacunaca yaćhapäcunanmi Taytäta cuyal nimäśhallanmannuy lulaycuśhäta. ¡Śhalcapäcuy, caypi licuśhun!” nin. 
\c 15  
\s1 Jesusmi rasun üba plantaca cayan 
\p  
\v 1 Nilculmi Jesus nilatac: “Ya'am rasun üba plantaca cayá; Taytäñatacmi lulaycüca.  
\v 2 Chaymi jucnin pallayní mana wayuyniyu captin'a lluy cuchülun. Ñatac wayuyniyu captinmi ichá püdapayan mas wayuy-sapa cananpälä.  
\v 3 Chaynümi amcunapis shimïta uyalil ćhasquimäcunacá, püdaśhanuy allin chuyaña cayalcanqui.  
\v 4 Chayurá ya'aćhu tacyaycäliy amcunaćhu ya'a caycuśhänuy. Juc pallay quiquillanpïta manamá wayunmanchu. Chay yulaćhümi caycunan. Chaynümi amcunapis ya'aćhu mana capäcul'a mana wayupäcunquimanchu. 
\p  
\v 5 “Ya'ami üba plantaca cayá; amcunañatacmi pallaynïcuna. Chaymi ya'aćhu tacyaycüca, chaynütac ya'apis paywan caycupti'a sumä wayuyniyu caycun'a. Ñatac quiquillayquicuná manam imallactapis lulayta atipapäcunquimanchu.  
\v 6 Chaynütacmi ya'aćhu mana caycücá chaquinanpä wicapäśha pallaycänuy cayan. Chaycuna chaquïluptinmi juntulcul nina walaśhancäćhu cañaśha can'a.  
\v 7 Ñatac ya'aćhu masïsu tacyaycul, shimïtapis śhun'unćhu uywaycücätá munaśhayquitam mañacuśhayquimannuy uycuśha capäcunqui.  
\v 8 Caynu sumä wayuyniquiwan maynu sumä yaćhapacünïcuna caśhayquita camalaycachipäcuśhayquipam Taytá altuman juluycuśha can'a. 
\p  
\v 9 “Taytá cuyamäśhannümi amcunactapis cuyapäcuc. Cay cuyacuynïćhu-ari tacyapäcuy.  
\v 10 Maynümi ya'a Taytäpa camachimäśhanta uyalicul, paypa cuyayninćhu tacyaycú, chaynümi lluy camachicuynïta uyalicul'a amcunapis cuyaynïćhu tacyaycunqui. 
\p  
\v 11 “Caycunacta niycälic amcunaćhu cushicuyní caycuptin maćhaycälälinayquicama cushiculcänayquipämi.  
\v 12 Caymi camachicuyní amcunapä: Ya'a cuyapäcuśhacnuy quiquiqui-pulapis cuyanaculcay.  
\v 13 Sumä-sumänin cuyaycücá quiquinpa bïdanta amigunpi uycücämi.  
\v 14 Amcuna camachicuynïta cäsuculcal'a amigüñam capäcunqui.  
\v 15 Manañam ‘uywayní’ niyalcacchu. Uywaycá patrunnin ima lulaśhancunactapis manam yaćhanchu. Amcunactam ichá Taytá lluy nimäśhanta yaćhaycälichicña.  
\v 16 Ñatac amcunachu manam ya'acta aclapämälanqui, aśhwanpa ya'ami aclapäculac mana camacaycü sumä wayupäcunayquipä. Chayurá pudirní cayalcaptiqui'a ima mañaculcäśhayquitapis Taytá uycälishunquim.  
\v 17 Yapa nishayqui cay camachicuynïta: quiquiqui-pula cuyanaculcay. 
\s1 Jesustawan yaćhapacünicunacta ćhïnipapäcun'am 
\p  
\v 18 “Cay pachäćhu nunacunaca ćhïnipäcuśhuptiqui'a ya'acta puntacta ćhïnipämäśhanta yalpapäcuy.  
\v 19 Sïchuśh cay pachäpä capäcuptiqui'a nunacunaca quiquintanümi cuyapäcuśhunquiman. Canan chay mana allin lulayniyücunäpi julapämuśhacpam, jinaman'a chay lulayninta manaña atichipäcuptiquim ćhïnipapäcuśhunqui.  
\v 20 Chaynütac yalpapäcuy ‘Juc uyway manam patrunninpïta maslächu’ nipäcuśhacta. Chayurá ya'actapis aticaćhayalcämal'a, amcunactapis aticaćhapäcuśhunquim. Willacuynïta ćhasquiyalcämal'a amcunactapis ćhasquipäcuśhunquim.  
\v 21 Lluy caynu lulapäcuśhunqui caćhamänïta mana lisil ya'a-laycum.  
\v 22 Rasunpa willaycunäpä mana śhamupti'a manam pï juchachaycunan canmanchu cala. Cananmi ichá juchanpi mana ima ninan canñachu.  
\v 23 Ya'acta ćhïnimäcá Taytätapis ćhïniyantacmi.  
\v 24 Munaynïwan milagrucunacta paycunaćhu mana lulapti'a mana juchachäśham capäcunman. Cananmi ichá masqui cay lulaśhäcunacta licayalcalpis ćhïnipapämäśhanwan Taytätapis ćhïniyalcantac.  
\v 25 Caycunawanmari lulacacun camachicuyćhu ‘Yan'alpïmi ćhïnipapäman’\x + \xo 15:25 \xt Sal 35.19; 69.4\x* nishanca. 
\p  
\v 26 “Ñatac Taytäpi caćhamuná Caminaycuśhüniqui, rasuncäta camalachï Ispiritum ya'api liman'a.  
\v 27 Chaynütacmi amcunapis limapäcunqui yaćhachiyta allaycuśhäpi ya'awan cayalcalñá. 
\c 16  
\p  
\v 1 “Lluy caycunacta nipäcuc ya'apïta mana laquiculcänayquipämi.  
\v 2 Chay juntunacuynincunapïta alupäcuśhunquim. Chay wañuchipäcuśhüniquicunam: ‘Diosta caynüpamari sirbinchic’ nipäcun'alä canpis.  
\v 3 Caynu lulapäcun'a ya'actapis caćhamäní Taytätapis mana imaypis lisipämalmá.  
\v 4 Caycunacta willayalcac chay ćhämuptin cay nishäcunäta yalpapäcunayquipämi. Ñatac puntapi caycunacta mana nipäculacchu ya'awan cayalcaptiquilämi.  
\v 5 Cananmi ichá caćhamäní caśhancäman cutiyaptïpis mana mayanllayquipis mayta linätapis tapupämanquichu.  
\v 6 Aśhwanpam cay nishäcunäwan sumä-sumä llaquicälälinqui.  
\v 7 Masqui chaynu captinpis, cutishäca amcunap allinniquipämari. Mana cutipti'a chay Caminaycuśhüniqui manam śhamunmanchu. Aśhwanpa cutilmi caćhamuśhä.  
\v 8 Pay śhamulmi jinantin nunacunäta tantiachin'a jucha-sapa capäcuśhanta, ya'apa allin caśhätapis, ñatac juchancunapi mućhuycachisha canantapis.  
\v 9 Tantiachin'a jucha-sapa capäcuśhanta ya'aman mana chalapaculcämäśhanpïtam.  
\v 10 Tantiachin'atac allin caśhäta Taytäman cutilcul amcunawan manaña caśhäpïtam.  
\v 11 Jinaman tantiachin'atac mućhuycachinäta cay pachäta duyñuchacüśhaca cäraycuśhaña cayaptinmi. 
\p  
\v 12 “May-mayćha amcunacta niná cayan. Canan'a anchapmari canman.  
\v 13 Chuya Ispiritu śhamulñam ichá rasun allincäta yaćhaycälichipäcuśhunqui. Pay'a manam quiquillanpïtachu yaćhachipäcuśhunqui, sinu'a lluy uyalishancätam. Jinaman'a śhamü muyuncunäćhu ima pasanancunactapis willaycälishunquim.  
\v 14 Caynu ya'api ćhasquishallanta amcunaman willaycuśhanwanmi altumanpis julaycaman'a.  
\v 15 Ñatac Taytäpa lluy cänincunapis ya'apam. Chaymi ‘Ya'api ćhasquishantam Chuya Ispiritu amcunaman willaycuśhunqui’ niyalcac” nin. 
\s1 Llaquicuycämi cushicuyman muyun'a 
\p  
\v 16 Nilculmi: “Ishcay quimsa muyuncunapïtanuy'a manam licapämanquiñachu. Chaypïtalämi caśhantac licapämanqui” nin. 
\p  
\v 17 Niptinmi waquin yaćhapacünincuna quiquin-pula: “¿Imaninantan ‘Ishcay quimsa muyuncunapïta manam licapämanquiñachu. Chaypïtalämi caśhan licapämanqui’ niyämanchic? ¿Imanuytacmi ‘Taytá caśhanman lishä’ nishancäpis?  
\v 18 Chay ‘Ishcay quimsa muyunpïtanu'a’ nishantapis manam imapi limaśhantapis tantianchicchu” ninaculcäla. 
\p  
\v 19 Ninacuptinmi Jesus tantiälun tapucuyta munapäcuśhanta. Chaymi: “¿Amcuna tapunacuyalcanqui ‘Cananpi ishcay quimsa muyuncunapïta manam licapämanquiñachu. Chaypïtalämi caśhan licapamanqui’ nishäcäpïchun?  
\v 20 Canan sumäta uyalipämay: cay pachäćhu nunacunaca cushicuyćhu cayalcaptin amcunañatacmi wa'acuyćhu llaquicuyćhu capäcunqui. Masqui chaynu llaquicuyniqui captinpis sumä cushicuymanmi muyun'a.  
\v 21 Maynümi juc walmip waćhay dulurnin chaläluptin dulurninta llaquisha apan. Näsichicülulmi ichá chay wawinpïta cushicul nanay apaśhantapis manaña yalpanñapischu.  
\v 22 Chaynümi amcunapis canan sumä llaquichisha capäcunqui. Caśhan cutimuptí tincuptinchicmi ichá sumä-sumäta cushiculcanqui. Chay cushicuyniquitá manamá pipis ućhishunquimanchu.  
\v 23 Chay muyuncunaćhu'a, manañam mañacalcämänayquipä can'añachu. Rasunpa pudirní cayalcal Taytäta mañaculcäśhayquitam lluy uycälishunqui.  
\v 24 Canancama manalämi imallactapis pudirnïnuy mañaculcanquilächu. Mañaculcal'a ćhasquipäcunquim sumä cushicuywan maćhaycuśha capäcunayquipä. 
\p  
\v 25 “Canancama caynu tincuchiyllapmi yaćhaycälichilac. Ñatac Taytäpïta tincuchiycunap mana yaćhaycachil cällanman camalaycachiná üra jananchicćhüñam.  
\v 26 Chay muyunpi pudirní cayalmi Taytäta mañaculcanqui. Manañam mañacapuná can'añachu.  
\v 27 Aśhwanpa quiquin Taytämi cuyapäcul uyalipäcuśhunqui. Ñatac caynu cuyapäcuśhunqui cuyapämäśhayquipam, jinaman paypi śhamuśhäta tantiapäcuśhayquipam.  
\v 28 Rasunpa Taytá caśhancäpïtam cay pachäman śhamulá. Cananñatacmi cay pachäta caćhaycul Taytá caśhanman cutishä” nin. 
\p  
\v 29 Niptinmi yaćhapacünincuna: “Canan'a mana tincuchillalñam tuqui tantiapaśhllacta willaycälimanqui.  
\v 30 Cananmi ichá tantiaycälí lluy imactapis yaćhaśhayquita aśhta ima tapucuyní cäcunactapis. Chaymi Diospi śhamuśhayquita chalapaculcá” nipäcun. 
\p  
\v 31 Nipäcuptinmi Jesus: “Chayurá chalapacayalcämanquićhá ¿aw?  
\v 32 Japalläta caćhaycälälimal wicta cayta chi'ipäcunayqui üraca jananchicćhüñam. Ñatac japallächu manam cayá; Taytämari ya'awan cusca cayan. 
\p  
\v 33 “Caycunacta niyalcac ya'aćhu jawca caycälinayquipämi. Cay pachäćhu'a ima sasachacuycunactapis pasapäcunquim. Ñatac chaycunaćhu callpanchaculcay; ya'a quiquïmari lluyta cay pachäćhu llalliytá llallïlüña” nin. 
\c 17  
\s1 Jesusmi Taytanta yaćhapacünincunapä mañacun 
\p  
\v 1 Nilculmi Jesus janay pachäta licalcul: “Taytay, ürá ćhämunñam. Mayan caśhätapis nunacunäman camalaycachiy ya'apis ampïta camalaycachinäpä.  
\v 2 Ya'amanmi munayniquita uycamälanqui lluy nunacunaca maquilläćhu cananpä, chaynütac lluy unanchaycuśhayquicunäta wiñay simpripä cawsachinäpä.  
\v 3 Paycuna am rasun Tayta Diosllätawan ya'a caćhamuśhayqui cäcäta lisiycuyllanwanmi wiñay cawsaycäta ćhasquipäcun.  
\v 4 Taytay, sumä caśhayquitapis cay pachäćhu camalaycachïmi nimäśhayquicunäta lluy camacaycuśhäwan.  
\v 5 Chayurá, canan-ari ñawpäniquićhu caśhan altuman julaycamay cay pacha allaycuptin anwan cusca julaycamäśhayquinu. 
\p  
\v 6 “Ñatac cay pachäćhu cäcunäpi unanchaycul uycamäśhayquicunällactam mayan caśhayquitapis lisiycachilá. Ampa cäcunätamari uycamälanqui. Ñatac shimiquita uyalilmi cäsuculcäla.  
\v 7 Chaymi canan yaćhapäcunña lluy umäśhayquicunaca amllapi śhamuśhanta.  
\v 8 Nimäśhayquicunäta lluy willacuptí ćhasquicalcämäla rasunpa am caćhamäśhayquipi śhamuśhäta tantialmi.  
\v 9 Chaymi mañacuc paycunapä. Manam cay pachäćhu nunacunäpächu, sinu'a ampa cäcunapïtam, umäśhayquicunapïtam.  
\v 10 Cay lluy nuna ya'apa cäcunäpis ampam. Chaynütacmi ampa cäcunapis ya'apatac. Paycunapñatacmi maynu sumä caśhätapis camalaycachilanqui. 
\p  
\v 11 “Canan'a cay pachäta caćhaycuśhäñam anwan cananchicpä. Paycunañatacmi ichá cay pachäćhu caycälin'alä. Chayurá Sumä Taytay, lluy umäśhayquicunäta ñawillayquićhu caycachiy-ari ya'anchicnuy jucllaylla paycunapis caycälinanpä.  
\v 12 Cay pachäćhu paycunawan caśhäcamá, lluy umäśhayquicunäta munayniquiwanmi ñawilläćhu uywalá. Manamá jucllanpis chincalachu sinu'a chay shimiquićhu nishannuy lulacacunanpä camacäśha cananpä unanchäśhancällamari. 
\p  
\v 13 “Canan cusca cananchicpämi cutiyämú. Cay pachäćhu caśhäcamam ichá caycunacta mañacamú cushicuynïwan sumä maćhaycälinanpä.  
\v 14 Paycunacta willacuyniquita willaptïmá cay pachäćhu nunacunaca ćhïnipapäcula. Chay uyalicücunäpis nï ya'apis manam cay pachäpächu capäcú.  
\v 15 Chaynu captinpis, manam cay pachäpi julunayquipächu mañacuc, sinu'a cay mana allincäpi licaycunayquipämi.  
\v 16 Rasunpa, manam paycunapis nï ya'apis cay pachäpächu capäcú.  
\v 17 Chayurá rasun allin shimiquiwan amllapäña chuya-camacta lulaycuy.  
\v 18 Maynütacmi cay pachäpa ćhawpinman caćhamälanqui, chaynümi ya'apis cay pachäpa ćhawpinman caćhayá.  
\v 19 Paycuna-laycumari amllapäña calá paycunapis amllapäña sumä capäcunanpä. 
\p  
\v 20 “Paycunallapïchu manamá mañacuc, sinu'a paycunap willacuyninpa śhamü chalapacamäcunäpäwanmi.  
\v 21 Taytay, lluy paycunari jucllaylla imaćhüpis capäcuchun. Maynümi ya'anchic juclla cayanchic, chaynu-ari paycunapis ya'anchicwan jucllaylla capäcuchun, caćhamäśhayquita lluy nunacunaca yaćhapäcunanpä.  
\v 22 Ñatac sumä caynïta umäśhayquitapis paycunactam uyculá ya'anchicnu jucllaylla capäcunanpä.  
\v 23 Ya'a paycunaćhu caśhänuy ñatac am ya'aćhu caśhayquinu-ari sumä jucllaylla caycuchun. Chayćha jinantin nunacunaca ya'acta cuyamäśhayquinuy paycunactapis maynu cuyaśhayquita tantiapäcun'a. 
\p  
\v 24 “Taytay, cay uycamäśhayquicunaca ya'awan capäcuchun. Chayćha cay pachäta manalä camal sumä altuman julaycamäśhayquitawan maynu cuyamäśhayquita licapäcun'a.  
\v 25 Sumä Chuya Allin Taytáy, cay pachällapa cäcunacá manam lisipäcuśhulanquichu. Ya'ami ichá lisic. Nunäcunapis caćhamäśhayquita yaćhapäcunñam.  
\v 26 Chaynütacmi ampi camalaycachilá; jinallam camalaycachishäpis cuyamäśhayqui cuyacuyniqui ñatac ya'a quiquïpis paycunaćhu caycunanpä” nil mañacula. 
\c 18  
\s1 Jesustam chalachin 
\r Mt 26.47-56; Mc 14.43-50; Lc 22.47-53 
\p  
\v 1 Lluy caycunacta Jesus niyculmi yaćhapacünincunawan Cedron śhutiyu wayup wic-lädu chimpanman lipäcula. Chayćhu juc wirta caśhancämanmi yaycapäcula.  
\v 2 Chay wirtaćhu achca cuti Jesus yaćhapacünincunawan juntunaculcaptinmi ipanchä Judaspis lisila.  
\v 3 Chaymanmi Judas ćhälun fariseocunaca puydï sasirdüticunaca caćhaśhan chuya wasip waquin täpänincunactawan achca cachacucunacta sumä armädu-cama michïrayüta lintirnayüta puśhapacüśha.  
\v 4 Ñatac Jesus caycuna pasananta yaćhalñam yalulcul “¿Mayantatan ashiyalcanqui?” nin. 
\p  
\v 5 Niptinmi: “Nazaret-lädu Jesustam” nipäcun. 
\p Niptinmi: “Ya'am cayá” nin. Paycunawanmi ipanchä Judaspis cayäla. 
\p  
\v 6 Chaynu Jesus “Ya'am cayá” nïluptinmi ipaman cutityalcälishanćhu cućhpatityälälin. 
\p  
\v 7 Jesusñatacmi yapa: “¿Mayantamari ashiyalcanqui?” nin. 
\p Niptinmi: “Nazaret-lädu Jesustam” nipäcun. 
\p  
\v 8 Niptinmi: “Ya'am cayá niyalcacñari. Ya'acta ashiyalcämaptiqui'a paycuná jina liculcächun” nin.  
\v 9 Caynüpam lulacacula quiquin Jesus: “Taytay umäśhayquicunapïta jucllantapis manam jitaycüchu” nishanca. 
\p  
\v 10 Simon Pedroñatacmi ispäda uywaśhanta jululcul sumä puydï sasirdütip uywaynin Malcup allï linlinta juclla pasächin.  
\v 11 Jinaptinmi Jesusñatac Pedrocta nin: “Chay ispädayquita ćhulalänanman cutiycachiy. ¿Manachun Taytá caćhamuśhan sumä ñacaycäta ñacäman, imatá?” nil. 
\s1 Jesustam puydï sasirdütiman ćhächin 
\r Mt 26.57-58; Mc 14.53-54; Lc 22.54 
\p  
\v 12 Niyällaptinmi Diospa chuya wasinpa täpänincuna, cachacucunaca jinaman puydïnincäpis Jesusman lluy shipucälälil ćhänälälin.  
\v 13 Jinalculmi chay watapä ćhuläśha sumä puydï sasirdüti Caifaspa suyrun Anasman puśhälälin.  
\v 14 Cay Caifasmi Israelcunäta “Malcantin wañunanchicpïtá allinmi canman juc nunalla lluypi wañuptin'a” nïca cala. 
\s1 Pedrom Sasirdüti Anaspa wasinman ćhaycun 
\r Mt 26.69-70; Mc 14.66-68; Lc 22.55-57 
\p  
\v 15 Ñatac Simon Pedrowan jucnin yaćhapacüninmi Jesusta atipäcula. Chay jucninmi sumä puydï sasirdütip lisisha cayal Jesuswan cusca luli patyuman yaycula.  
\v 16 Pedroñatacmi patyup puncullanćhu quïdälun. Jinaptin chay puydï sasirdütiwan lisinacuśhan yaćhapacücämi puncu quićhänin walmicta limapaycuptin Pedrocta pasaycachila.  
\v 17 Chayćhümi chay walmica Pedrocta: “Cay nunap yaćhapacünin-ari ampis cayanqui ¿aw?” nin. 
\p Niptinmi Pedro: “¡Manam, manam!” nicuyan. 
\p  
\v 18 Ñatac sumä alaläcayämuptinmi chay täpänincunawan uyway nunacunaca ninacta walacaycachil muyülïninćhu śhaycacaycälil unupacuyalcäla. Paycunawan cuscamari Pedropis unupacuyäla. 
\s1 Anasmi Jesusta tapun 
\r Mt 26.59-66; Mc 14.55-64; Lc 22.66-71 
\p  
\v 19 Jinaśhancamañatacmi chay puydï sasirdütica Jesusta tapula yaćhachishanpïtawan, yaćhapacünincunapïta. 
\p  
\v 20 Chaymi Jesus: “Ya'a llapa nunap ñawquinmi yaćhachilá. Juntunacuna wasicunaćhüpis, Diospa chuya wasinćhüpis, mayćhüpis mayanćhüpis manam pacallap imactapis yaćhachilächu.  
\v 21 ¿Chayurá imapälätá ya'acta tapumanqui? Chay uyalïcunätari tapumuy. Paycunam tuquicta yaćhapäcun imapi yaćhachishätapis” nin. 
\p  
\v 22 Nïluptinmi chayćhu jucnin täpäca cäraćhu lapyälun “¿Caynüpachun puydï sasirdütïtalä ninquimanpis?” nil. 
\p  
\v 23 Jinaptinmi: “Mana allinta limälupti'a, má, nimay-ari. Ñatac rasuncällacta niyapti'a ¿imapïtan lapyacamanquiman?” nin.  
\v 24 Jinaptinmi Anas ćhänacüśhacta sasirdüticunap sumä puydïnin Caifasman puśhachila. 
\s1 Pedrom yapa ipanchan 
\p  
\v 25 Ñatac Pedro chay nina walaśhancäćhu jinalla unupacuyaptinmi “Cay nunap yaćhapacüninchućh ampis canqui, ¿aw?” nipäcun. 
\p Niptinmi: “Chayta manamari ya'a lisïpischu” nin. 
\p  
\v 26 Chaypïtam puydï sasirdüticunap uywaynin chay Pedro linlinta cuchuśhan nunap ayllunpis: “¡Amta, ya'a licalac chay wirtaćhu Jesuswan cusca cayätachućh jinam!” nin. 
\p  
\v 27 Niptinmi Pedro: “¡Manam lisïchu!” niyällaptin wallpa wa'amun. 
\s1 Jesusmi Pilatop maquinćhu 
\r Mt 27.1-2,11-31; Mc 15.1-20; Lc 23.1-5,13-25 
\p  
\v 28 Chay Israelcunämi aspi-aspiy Jesusta puśhapäcula Caifaspa wasinpïta Roma nasyuncäpa cuartilninman. Chayman manam yaycapäculachu “Anlacüluchwanmi Libracuśhanchic Fistaćhu canapä” nil.  
\v 29 Chayćhümi Pilato yalalcamul: “Má, ¿imapïtam puśhayalcämunqui?” nin. 
\p  
\v 30 Niptinmi: “Cay nuna ancha anchapña mana lulaptin'a, manaćh anmanlächu puśhayalcämüman cala” nipäcun. 
\p  
\v 31 Pilatoñatacmi: “Amcunapïtañamá. Quiquiquip camachicuyniquimannuy imactapis lulapämuy” nin. 
\p Niptinmi: “Ya'acuna manam pictapis chacataywan wañuchipäcümanchu” nipäcun.  
\v 32 Caynu Jesus nila imanuypa wañuchisha cananpä nishanca lluy lulacacunanpämi. 
\p  
\v 33 Chaypïta Pilato cuartilman caśhan cutiycul Jesusta ayalculmi: “¿Chayurá amlächun Israelcunäpa sumä mandänincälä cacuyanquimanpis?” nin. 
\p  
\v 34 Niptinmi: “¿Caynu niyämanqui quiquillayquipïtachun ichá juccunapi uyalishayquitachun?” nin. 
\p  
\v 35 Pilatoñatacmi: “¿Israel caśhtachun cayá, imatá? Malca-masiquicunari, puydï sasirdütiquicunäwan maquïman ćhulaycayämuśhunqui. Am ¿imactamá lulalanqui?” nin. 
\p  
\v 36 Niptinmi Jesus: “Ya'apa gubirnú manam cay pachäćhüchu. Caypa capti'a nunäcunaćh Israelcunäpa maquinman mana ćhulaycuśha canäpä tincupäcunman cala. Gubirnu'a manam caypïchu” nin. 
\p  
\v 37 Niptinmi: “Chayurá ¿mandänincälächun cacuyanqui?” nin. 
\p Niptinmi: “Am nishayquinümá. Chaymi cay pachäman näsil śhamulá rasun allincäta yaćhaycachinäpä. Cay allincäta lisiyta munäcunäñatacmi cäsupäman” nin. 
\p  
\v 38 Niptinmi Pilato: “¿Rasuncá imatá?” nin. Nilculmi chay puśhamü Israelcunäman yapa yalulcul: “Cay nunäćhu ya'a manam imactapis juchachaycunäpä talïchu.  
\v 39 Ñatac cay Libraculcäśhayqui Fistaćhu custumriquimannuy watan-watanmi carsilćhu wićhaläcunäpi jucninta caćhaycunanchic. Chayurá ¿Israelcunap Mandäniquitachun caćhaycuśhä?” nin. 
\p  
\v 40 Niptinmi Israelcunaca ayaycaćhaypa: “¡Chaytá wañuchipäcuy! ¡Barrabasta caćhaycuy!” nicuyalcan. Cay Barrabasmi fïnunnin suwa cacula. 
\c 19  
\s1 Jesus chacatäśha cananpämi mañapäcun 
\p  
\v 1 Chaymi Pilato asutiwan Jesusta camacaycächila.  
\v 2 Cachacucunäñatacmi caśhapi curunacta lulalcälil Jesuspa umanman ćhulapäcula. Jinalcul mandacüpa jatun yana-nilä puca catacunwan ćhulälälin.  
\v 3 Jinayculmi jucnin jucnin aśhuycälil “¡Wiñaypä cawsachun Israelcunap mandacünin!” nil cäraćhü-cama tacapäcula. 
\p  
\v 4 Chaypïtam Pilato yapa yalalcamul Israelcunäta: “Cananmi ñawpäniquiman julamuśhä wañuchisha cananpä mana talishäta tantiaycälinayquipä” nin.  
\v 5 Chayćhu Jesusta caśha curunawan curunapacüśhacta, mandäpa müdananwan müdapacüśhacta julalcachimul Pilato: “Cay-ari. Amcunaćh nipäcunqui” nin. 
\p  
\v 6 Chaynüta licälulmi puydï sasirdüticunäwan täpäcunaca ayaycaćhaypa-cama: “¡Chacatäluy! ¡Chacatäluy!” nicuyalcan. 
\p Chaymi Pilato: “Payćhu manamari ima juchactapis talïchu wañuchisha cananpä. Chayurá amcunari chacatalpis wañuchicalcämuy” nin. 
\p  
\v 7 Niptinmi Israelcunaca: “¡‘Quiquin Tayta Diospa Caćhaśhan Chulinmi cayá’ ninmari! ¡Ya'acunap camachicuynïmannu wañuchisha cachun!” nicuyalcan.  
\v 8 Cayta uyalïlulmi Pilato masta manchapacüla. 
\p  
\v 9 Chaymi caśhan luliman cutiycälil Jesusta tapula: “¿Maypïmi canqui?” nil. 
\p Niptinmi Jesus imactapis mana limalilachu.  
\v 10 Chaymi Pilato: “¿Ya'apächun mana limalinquimanchu? ¿Manachun maquïćhu cayan caćhaycachinacpäpis chacatächinacpäpis?” nin. 
\p  
\v 11 Niptinmi Jesus: “Imanamänayquipäpis manam ima munayniquipis canmanchu, janay pachäćhu Tayta Dios mana uycuśhuptiqui'a. Chaymi maquiquiman ćhulaycamänïcá, ampïtapis mas juchayüña cayan” nin. 
\p  
\v 12 Chay niptin-pacham Pilato imanuypapis Jesusta caćhaycachiyta munala. Jinaptinpis Israelcunäñatacmi ayaycaćhaypa: “Caćhaycülul'a Romap Puydï Mandäcäpa śhalcünin manañam canquichu. Pipis mandätucücá puydï mandäninchicpa cuntranmi śhalcuyan” nicuyalcan. 
\p  
\v 13 Chaynüta Pilato uyalilculmi Jesusta julalcachimul Impidraśha nishan patyućhu cäraycunancäman taycucuycula. (“Impidraśha” Israel limayćhüñatacmi Gabata nipäcula.)  
\v 14 Ñä chay fistapä juc muyun cacuyaptinmi ćhawpi muyun Pilato Israelcunäta: “Cay-ari Mandäniqui” nin. 
\p  
\v 15 Paycunañatacmi jicutäcuyalcan: “¡Wañuchun! ¡Wañuchun! ¡Chacatäluy!” nil. 
\p Pilatoñatacmi: “¿Mandänïquitalächun chacatälüman?” nin. 
\p Niptinmi puydï sasirdüticuna “Sumä munayniyu Romaćhu mandä Cesarllam mandacüní. Manam juc canchu” nicuyalcan.  
\v 16 Chaymi paycunap maquinman Jesusta ćhulaycuptin chay üra pasachiculcan mañacuśhanmannuy chacatapäcunanpä. 
\s1 Jesusmi chacatäśha 
\r Mt 27.32-50; Mc 15.21-37; Lc 23.26-49 
\p  
\v 17 Jinaptinmi Jesusta curuśhnin umrucuśhacta cachacucunaca Uma Tullu nishanman puśhapäcula. (Cayta Israel limayćhüñatacmi Golgota nipäcula.)  
\v 18 Chayćhümi paytawan cuscacta wicninman cayninman ishcay nunactapis chacatälälila Jesusñatac ćhawpićhu.  
\v 19 Pilatoñatacmi curuśhcäpa umanman ćhulächila “Cay Nazaret-lädu Jesusmi Israelcunäpa Mandäninca” niyäta.  
\v 20 Chay chacatäśhanca malcap läduscallanćhu captinmi achca Israelcuna lïgipäcula. Chay curuśhcäpa umanćhu'a quimsa limayćhümi isquirbisha cala: Israelcunäpaćhu, Romacunäpaćhu, Griegocunäpaćhüpis. 
\p  
\v 21 Chaymi puydï sasirdüticuna Pilatocta: “Ama ćhulaychu ‘Israelcunap Mandäninmi’ nïtá, sinu'a caynüta ‘Israelcunap Mandänincämi cacuyá’ nïta” nin. 
\p  
\v 22 Niptinmi Pilato: “Imam lulaśhäcá jina lulaśhänüllaña cacuchun” nin. 
\p  
\v 23 Ñä chacatälälilmi cachacucunaca Jesuspa müdananta jucnincä-cama tawan aypunacälälin. Juc jatun müdanan janaypi ulaycama jucllaćhu awäśhäpis cacuyälalämi.  
\v 24 Chaymi “Caytá ama laćhyaśhunchu. Aśhwanpa chüsanacüśhun, mayanninchicpäshi, má can'a” ninaculcäla. Cay lulapäcuśhanwanmi isquirbishancunaćhu: 
\q1 “Quiquin-pulam waquinnin müdanäta aypunacülun, 
\q1 jucninpañatacmi chüsanacälälin”\x + \xo 19:24 \xt Sal 22.18\x* nishanca lulacacüla. 
\p Caynümi cachacucunaca lulälälila. 
\p  
\v 25 Ñatac Jesus chacataläśhancäpa lädunćhümi cayäla mamanpis, mamanpa ñañanpis, Cleofaspa walmin Mariapis, chaynütac Magdala malcayu Mariapis.  
\v 26 Chaymi chay mamanpa lädunćhu cuyaśhan yaćhapacünin śhäcuyäta licälul mamanta: “Mamay, payñam wawiqui” nin.  
\v 27 Chaynütac cuyaśhan yaćhapacünintapis: “Payñam mamayqui” nin. Chay-pachapïmi yaćhapacünin wasinćhu ćhasquila. 
\s1 Jesusmi wañun 
\p  
\v 28 Ñatac Jesus llapa lulayninta camacalpuśhanta yaćhaculñam “Yacunayämanmi” nila. Caywanmi Diospa limayninćhu nishanca lulacacüla.  
\v 29 Chayćhütacmi juc wacuyćhu ćhacćhä bïnu winacuśha cañä. Chaymi caśhpip puntanman millwacta aytiycul bïnuwan puśhtaycachil śhu'uchinanpä chacchalcapäcula.  
\v 30 Jinaptinmi chay bïnüta mallilcul: “Canan'a lluy cabalalpüśhañam” nil uyshucalpul pasacalpula. 
\p  
\v 31 Ñatac chay fistapä juc muyunllaña cacuyaptinmi allichacuyćhu Israelcunaca capäcula. Jinaman chay warda muyunćhüpis sumä manchacuywan caycuna captinmi mana munalachu curuśhcäćhu chacatäśha capäcunanta. Chaymi caćhpancunacta paquilcachil wañulpüluptin julüśha capäcunanpä Pilatocta mañapäcula. 
\p  
\v 32 Chaymi cachacucunaca Jesuspa lädunćhu ishcay chacataläcunäman aśhuycälil caćhpanta paquïlälin.  
\v 33 Jesusman aśhuycälilñatacmi pasäśha cayäta licälälil manaña caćhpanta paquipäculañachu.  
\v 34 Jucnin cachacuñatacmi ichá ispäda-niläwan Jesuspa wätanta tucsïlun. Jinaptinmi yawarwan yacu yalämun. 
\p  
\v 35 Lluy caycunacta ya'ami ñawïwan licälá. Cay lluy willaśhäcunaca rasuncällam. Chaymi willaycälic amcuna masïsu chalapaculcänayquipä.  
\v 36-37 Caynu pasaśhanwantacmi Diospa shiminćhu “Jucllay tullullantapis manam paquiycun'achu”\x + \xo 19:36-37 \xt Sal 34.20\x* nishancäpis jinaman'a “Tucsishancäta licapäcun'am”\x + \xo 19:36-37 \xt Zac 12.10\x* nishancäpis lulacacüla. 
\s1 Jesustam pampapäcun 
\r Mt 28.1-10; Mc 16.1-8; Lc 24.1-12 
\p  
\v 38 Chaypïtam Jesuspa cuirpunta aśhuchinanpä Arimatea-lädu José Pilatocta mañacula. (Pay Jesuspa atïnin caśhanta Israelcunäta manchacuypïmi mana camalachiculachu.)  
\v 39 Pilato awnïluptinmi Nicodemo apawshila. (Cay Nicodemom Jesusman tutallap śhamul tapüca cala.) Paymi quimsa ćhunca kïluctanuy mirrawan aloe nishan pulbucunacta apamuñä pampapäcunanpä.  
\v 40 Chay apamuśhancunäwanmi Jesuspa jinantin cuirpunta fïnunnin säbanaśhwan pitwïlälila, Israelcunap pampanaculcäśhanmannuy.  
\v 41 Ñatac Jesusta chacatapäcuśhancäpa wicniscallanćhümi juc wirta cala. Chayćhümi mana mayanllapis pampacuśhan muśhü ućhcu pampananpä cala.  
\v 42 Chay fistap muyunnin allaycunanpä cacuyaptinñatacmi chayman Jesuspa cuirpunta ćhulälälila. 
\c 20  
\s1 Jesusmi śhalcamun 
\p  
\v 1 Ñatac simänap allaycuyninćhu aspi-aspilla Magdala malcayu Maria Jesus pampaläśhancäman linanpämi jatun lumi wićhaśhanca aśhüchisha cayäñä.  
\v 2 Chaymi Jesuspa cuyaśhan yaćhapacüninwan Simon Pedro caśhancäman wayra-wayra pasacamun. 
\p Ćhayculmi: “¡Taytanchic Jesusta pampaläśhancäpïtam juläläliñä! ¡Mayman apälälishantapis manam yaćhapäcüchu!” nicuyan. 
\p  
\v 3 Niptinmi Pedrowan chay juc yaćhapacü-masin mana-mana cürrilla chutaläśhancäman pasaculcan.  
\v 4 Chaymi Pedropïta chay juc yaćhapacü-masin llallilcul puntacta ćhaycula.  
\v 5 Chayćhu ancuycul chay pitwishan säbanaśhcunällacta licayalpis manam yayculachu.  
\v 6-7 Chay ipanta Simon Pedro ćhayculñatacmi yaycuycul chay säbanaśhcunällacta paypis licälun chaynütac Jesuspa umanta wataśhan llapsha lataśhtapis tuqui pataläśha juc-lädućhu ćhulalayäta.  
\v 8 Chaynu Pedro maćhayman yaycüluptinlämi juccäpis yaycula. Chayćhu tuquicta licaycul-lämi quirila  
\v 9 masqui isquirbishancunapïta Jesus śhalcamunanta manalä tantialpulpis.  
\v 10 Chaypïtam capäcunancäman cuticalcämula. 
\s1 Jesusmi Magdala malcayu Mariaman licalin 
\r Mc 16.9-11 
\p  
\v 11 Mariañatacmi pampaläśhancäpa puncunćhu wa'ayäla. Chaynu wa'ayalmi lulicta ancuycula.  
\v 12 Licalpuśhanćhümi ishcay yulä-cama müdanayu anjilcuna aya ćhulaläśhancäpa saytanćhu umanćhu täcuyalcäta licälun.  
\v 13 Chay anjilcunämi: “Mamay, ¿imapïtan wa'ayanqui?” nin. 
\p Niptinmi Maria: “Taytäta chincalächishanpïtamari. Manam yaćhallächu mayman apälälishantapis” nin. 
\p  
\v 14 Nilpuyal muyulcuśhanćhümi Jesusta śhäcuyäta licälun. Jinalpis Jesus caśhanta manam lisilachu.  
\v 15 Chayćhu Jesusñatacmi: “Mamay, ¿imapïtan wa'ayanqui? ¿Mayantam ashiyanqui?” nin. 
\p Niptinmi Mariañatac “Wirta täpäcäćhá tapuyäman” nil “Am aśhuchil'a niycallämay, taytay, mayman aśhuchishayquitapis apacunäpä” nin. 
\p  
\v 16 Niptinmi Jesus: “Maria” nin. 
\p Śhutinta limalïluptinmi muyulcul “¡Yaćhachicü taytalláy!” nin. (Israel limayninćhu'a “Rabuni” nilam.) 
\p  
\v 17 Jesusñatacmi: “Caćhaycamaylä; Taytäman manalämi cutïchu. Aśhwanpa irmänücunaman cutilcul: ‘Cutiyäñam amcunapapis ya'apapis Taytanchicman, amcunapapis ya'apapis Diosninchicman’ nil willaycamuy” nin. 
\p  
\v 18 Nïluptinmi Magdalapi Maria pasacun Jesuspa yaćhapacünincunaman, quiquin licaśhancätawan, pay nishancunäta willaycü. 
\s1 Jesusmi yaćhapacünincunaman licalin 
\r Mt 28.16-20; Mc 16.14-18; Lc 24.36-49 
\p  
\v 19 Chay simänap allaycuynin muyuncälläćhütacmi aspilpuyña yaćhapacünincuna juntunacälälisha cayalcäla wasictapis sumä wićhacälälisha Israelcunäta manchacuypi. Chaynu cayaptinmi paycunap ćhawpinćhu Jesus licalilcul “¿Allinllachun? Jawcalla capäcuy” nin. 
\p  
\v 20 Nilculmi maquintawan wätanta licachila. Yaćhapacünincunañatacmi Jesusta licälälil sumä-sumäta cushicälälin. 
\p  
\v 21 Chayćhu Jesusñatacmi yapa: “Jawcalla capäcuy. Maynümi Taytá ya'acta caćhamäla, chaynümi amcunactapis caćhapäcuc” nin.  
\v 22 Nilculmi paycunaman jäcaycula: “Chuya Ispirituctam ćhasquipäcunqui.  
\v 23 Ñatac mayantapis pampachaycuśhayquicá pampachaycuśhañam can'a; mana pampachaycuśhayquiñatacmi ichá mana pampachaycuśhachu can'a” nil. 
\s1 Tomasmi Jesusta lican 
\p  
\v 24 Ñatac Jesus ćhämunanpä chay ćhunca ishcayniyu yaćhapacü-masincunapïta “Awachap”\f + \fr 20:24 \fk awacha: \ft Waquincunaćhu'a ‘awashcha’ nipäcunmi.\f* lisipäcuśhan Tomas'a, manam calachu.  
\v 25 Chaymi yaćhapacü-masincuna: “Jesusninchicta licälälïmi” nipäcuptin Tomas: “Maquinćhu läbu ućhcuśhancätawan, wätanćhu ućhcuśhanta ñawïwan licaycul dïdüta maquïta śhatiyculmi ichá quirïman” nin. 
\p  
\v 26 Chay pusä muyunpïtañatacmi yaćhapacünincuna yapa juntunacälälisha chay wasićhu cayalcäla. Chayćhümi ichá Tomaspis cayäla. Chaynu puncu sumä wićhalayaptinpis Jesus'a paycunap ćhawpinćhu licalilculmi: “¿Allinllachun? Jawcalla capäcuy” nin.  
\v 27 Nilculmi Tomasta: “Śhamuy cay maquïta licaycuy-ari; cay wätämanpis maquiquita śhatiycuy. ¡Amaña ishcayyaychu! ¡Chalapacuy-ari!” nin. 
\p  
\v 28 Niptinmi Tomas: “¡Aw Taytallämi Diosnillämi rasunpa callanqui!” nïlun. 
\p  
\v 29 Niptinmi Jesus: “Canan licämalmi chalapacamanqui. Ñatac maynu sumä cushicuymi mana licallalpis chalapacücunäpá” nin. 
\s1 Cay libru imapä isquirbisha caśhanpis 
\p  
\v 30 Ñatac Jesus yaćhapacünincunap ñawquin achca milagrucunactam lulala. Chaycuna cay librućhu manam isquirbishachu.  
\v 31 Caycunactam ichá isquirbilá Diospa Caćhamuśhan Salbacüca, Caćhamuśhan Chulinca Jesusninchic caśhanta tantianayquipä, jinal ćhasquicücunaca wiñay cawsayniyu capäcunayquipä. 
\c 21  
\s1 Jesusmi mana cäpïta challwachin 
\p  
\v 1 Chaypïtam Tiberias ućhap patanćhu yaćhapacünincuna cayaptin Jesus licalïla. Caynümi pasala.  
\v 2 Chayćhu cayalcäla Simon Pedro, “Awachap” lisipäcuśhan Tomas, Galileap Caná malcanpi Natanael, Zebedeop chulincuna, jinaman Jesuspa ishcay yaćhapacünincunapis. 
\p  
\v 3 Chayćhümi Simon Pedro: “Má, challwa chalä lishä” nin. 
\p Niptinmi llapanpis: “Ya'acunawanpis lishun-ari” nicuyalcan. Chaymi juc barcuman lluy ishpipäcula. Chayćhümi chay jinantin tuta mana ima challwallactapis chalapäculachu.  
\v 4 Ñä achicalpuyaptinñam ućha patanćhu Jesus licalïlun. Yaćhapacünincunañatacmi ichá pay caśhanta mana yaćhapäculachu. 
\p  
\v 5 Chayćhümi Jesus: “Walaśhcuna ¿manachun imallactapis chalapäcunqui?” nin. 
\p Niptinmi: “Manamari” nipäcun. 
\p  
\v 6 Niptinmi: “Barcup allïnin-läduman challwa chalacuyquita jitayculmi chalapäcunqui” nin. 
\p Chaynu jitalpäläliptinmi challwa chalacunman laćhyay-laćhyay juntälun chutaytapis mana atipapäcunancama.  
\v 7 Chaymi Jesuspa cuyaśhan yaćhapacünin Pedrocta nin: “¡Jesusninchicmari!” nil. Chayta uyalïlul-pachallam Pedro lluśhticüśhan\f + \fr 21:7 \fk lluśhti: \ft Waquincunaćhu'a ‘uśhti’ nipäcunmi.\f* müdananta caśhan ćhulaculcul ućhäman ji'acalpun.  
\v 8 Chay juc yaćhapacü-masincunañatacmi challwa chalacun ćhipuy-ćhipuy challwan aysacälälisha barcuwan ućhap patanman ćhälälimun. Chaypi paćhac mitru-yupaylämi patanman yalapämunanpä cala.  
\v 9 Chayman ćhaycamul ji'alpapämulmi nina walayäpa jananćhu challwa cancaywan, tanta cayäta talïlälin. 
\p  
\v 10 Jinaptinmi Jesus: “Challwa chalapämuśhayquipi juc ishcayta apapämuy” nin.  
\v 11 Niptinmi Simon Pedroñatac barcuman lilcul challwa chalaśhancäta ućhap patanman aysämun. Chayćhu paćhac picha ćhunca quimsayu (153) jatućhaćhä-camallam cacuñä. Chaynu achca-achca cayaptinpis challwa chalacun manam laćhyalachu.  
\v 12 Chayćhu Jesusñatacmi: “Śhapämuy micapäcunayquipä” nin. Chayćhu quiquin Jesus caśhanta tantiapäculmi mayanninpis mana tapućhaculcälachu “¿Pim cayanqui?” nil.  
\v 13 Chaypïtam Jesus challwätawan tantäta paycunaman aypuycula.  
\v 14 Caywanmari śhalcamuśhanpïta Jesus quimsa cutiña yaćhapacünincunaman licalïla. 
\s1 Pedroctam maynu cuyaśhantapis tapun 
\p  
\v 15 Chay micuyta camacalculmi Jesus nin: “Jonaspa chulin Simon, ¿lluypïtapis mastalächun cuyamanqui?” nil. 
\p Niptinmi: “Taytay, am yaćhanquim maynu cuyaśhacta” nin. 
\p Niptinmi: “Chayurá uwishnïcunactari michiy” nin.  
\v 16 Chaypïta yapa tapun: “Jonaspa chulin Simon, ¿rasunpachun cuyamanqui?” nil. 
\p Niptinmi Pedro: “Taytay, am yaćhanquim maynu cuyaśhacta” nin. 
\p Niptinmi: “Chayurá uwishnïcunactari licaycuy” nin. 
\p  
\v 17 Chaypi quimsa cutictaña tapun: “¿Jonaspa chulin Simon, cuyamanquichun?” nil. 
\p Chaynu quimsa cutictaña tapuptinmi Pedro llaquisha: “Am taytay, lluytamari yaćhanqui; cuyaśhätapis yaćhanquim” nin. 
\p Niptinmi Jesus: “Chayurá uwishnïtari michiy.  
\v 18-19 Rasunpa, müsu cayal'a tuquiy-tuquiymi müdapaculanqui mayta linayquipäpis. Ñatac awquishña cayal'a liclayquita chacchalcuptiquim, juccuna ćhänaśhunqui. Jinalculmi mana liyta munaśhayquicunäman puśhaśhunqui” nin. Cay nishanwan tantiachila Pedro imanuypa wañuśha cananpä, chaynütac wañuyninwan Diosta altuman juluycuśha cananpämi. 
\p Chaypïtam “Chayurá canan, má, atimay-ari” nin 
\p  
\v 20 Ñatac Pedro muyulcuśhanćhümi licälun Jesuspa cuyaśhan yaćhapacüninpis atiyämüta. (Pay'a sinaycälishanćhu Jesuspa matällanćhu cayal “¿Pitan ipanchäśhunqui?” nïcämi.) 
\p  
\v 21 Payta licälulmi Pedro: “Taytay, caytá ¿imam pasälun'a?” nin. 
\p  
\v 22 Niptinmi Jesus: “Ya'a munapti'a cutimuynïcamapis cawsanmanmi. Chaycuna ¿imam ucuśhunqui? Am atimay jinalla” nin. 
\p  
\v 23 Chaymi jinantin chalapacücunäman “Imaycamapis cawsan'am” nï limay ćhäla. Ñatac Jesus'a manam “Imaycamapis cawsan'am” nilachu, sinu'a “Cutimunäcamapis munapti'a cawsanmanmi. Chaycuna ¿imam ucuśhunqui?” nilam. 
\s1 Cay librup camacaynin 
\p  
\v 24 Cay quiquin cuyaśhan ya'a yaćhapacüninmi, ñawïwan licaśhäta, uyalishäta rasunpa caśhanta tuquicta yaćhal isquirbiycamú.  
\v 25 Ñatac Jesus'a may-chicactaćh allincäta lulaycula. Manyapi isquirbipti'a manaćh jinantin pachäćhu papilcunäpis camanmanchu. Chaynu cachun. 