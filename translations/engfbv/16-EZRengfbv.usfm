\v 17 \w So|strong="H1768"\w*, \w if|strong="H2006"\w* \w Your|strong="H1768"\w* Majesty wishes, authorize \w a|strong="H3068"\w* \w search|strong="H1240"\w* \w to|strong="H5922"\w* \w be|strong="H1005"\w* \w made|strong="H7761"\w* \w of|strong="H4481"\w* \w the|strong="H5922"\w* \w royal|strong="H4430"\w* \w archives|strong="H1005"\w* \w in|strong="H5922"\w* Babylon \w to|strong="H5922"\w* discover \w if|strong="H2006"\w* \w there|strong="H8536"\w* \w is|strong="H1768"\w* \w a|strong="H3068"\w* record \w that|strong="H1768"\w* \w King|strong="H4430"\w* \w Cyrus|strong="H3567"\w* \w issued|strong="H7761"\w* \w a|strong="H3068"\w* \w decree|strong="H2942"\w* \w to|strong="H5922"\w* \w rebuild|strong="H1124"\w* God's \w Temple|strong="H1005"\w* \w in|strong="H5922"\w* \w Jerusalem|strong="H3390"\w*. \w Then|strong="H4430"\w* please \w let|strong="H3705"\w* \w us|strong="H5922"\w* know \w Your|strong="H1768"\w* Majesty's decision \w in|strong="H5922"\w* \w this|strong="H1836"\w* \w matter|strong="H1836"\w*.”
