\v 9 \w Josué|strong="H3091"\w* \w hizo|strong="H6213"\w* con ellos como \nd \+w Yavé|strong="H3068"\+w*\nd* le ordenó: \w desjarretó|strong="H6131"\w* sus \w caballos|strong="H5483"\w* y \w quemó|strong="H8313"\w* sus carruajes con fuego.   
\p
\v 10 \w En|strong="H3588"\w* \w aquel|strong="H1931"\w* momento \w Josué|strong="H3091"\w* regresó \w y|strong="H3588"\w* conquistó Hazor. \w Mató|strong="H5221"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w* \w a|strong="H3068"\w* \w su|strong="H1931"\w* \w rey|strong="H4428"\w*, \w pues|strong="H3588"\w* Hazor \w fue|strong="H1931"\w* \w antiguamente|strong="H6440"\w* \w la|strong="H1931"\w* capital \w de|strong="H3588"\w* \w todos|strong="H3605"\w* \w aquellos|strong="H3605"\w* \w reinos|strong="H4467"\w*.  
\v 11 \w Mataron|strong="H5221"\w* \w a|strong="H3068"\w* filo \w de|strong="H5397"\w* \w espada|strong="H2719"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w lo|strong="H3808"\w* \w que|strong="H3808"\w* tenía \w vida|strong="H5315"\w* \w en|strong="H5221"\w* \w ella|strong="H3605"\w*. \w La|strong="H3605"\w* \w destruyeron|strong="H2763"\w* por completo, \w sin|strong="H3808"\w* \w que|strong="H3808"\w* \w quedara|strong="H3498"\w* uno \w que|strong="H3808"\w* respirara. Incendiaron \w a|strong="H3068"\w* Hazor.   
\p
\v 12 \w Josué|strong="H3091"\w* capturó \w todas|strong="H3605"\w* las \w ciudades|strong="H5892"\w* de esos \w reyes|strong="H4428"\w* y también \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w ellos|strong="H3605"\w*. \w Los|strong="H3605"\w* pasó \w a|strong="H3068"\w* filo de \w espada|strong="H2719"\w*. \w Los|strong="H3605"\w* destruyó \w por|strong="H4428"\w* completo, tal como \w ordenó|strong="H6680"\w* \w Moisés|strong="H4872"\w*, esclavo de \nd \+w Yavé|strong="H3068"\+w*\nd*.   
\p
\v 13 \w Sin|strong="H3808"\w* embargo, \w Israel|strong="H3478"\w* \w no|strong="H3808"\w* incendió \w ninguna|strong="H3605"\w* \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w ciudades|strong="H5892"\w* \w que|strong="H3808"\w* quedaron \w en|strong="H5921"\w* \w pie|strong="H5975"\w* \w sobre|strong="H5921"\w* \w las|strong="H5921"\w* colinas, \w con|strong="H5921"\w* \w la|strong="H5921"\w* sola excepción \w de|strong="H5921"\w* Hazor, \w la|strong="H5921"\w* cual \w Josué|strong="H3091"\w* \w quemó|strong="H8313"\w*.  
\v 14 \w Los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H5704"\w* \w Israel|strong="H3478"\w* tomaron \w para|strong="H5704"\w* \w ellos|strong="H1992"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w despojo|strong="H7998"\w* \w y|strong="H5704"\w* \w los|strong="H1992"\w* \w animales|strong="H1121"\w* \w de|strong="H5704"\w* \w aquellas|strong="H1992"\w* \w ciudades|strong="H5892"\w*, pero \w mataron|strong="H5221"\w* \w a|strong="H3068"\w* filo \w de|strong="H5704"\w* \w espada|strong="H2719"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1992"\w* \w hombres|strong="H1121"\w* \w hasta|strong="H5704"\w* \w destruirlos|strong="H8045"\w*, \w sin|strong="H3808"\w* \w dejar|strong="H7604"\w* \w alguno|strong="H3605"\w* \w con|strong="H5704"\w* vida.   
\p
\v 15 \w Como|strong="H3651"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w ordenó|strong="H6680"\w* \w a|strong="H3068"\w* su esclavo \w Moisés|strong="H4872"\w*, y \w Moisés|strong="H4872"\w* \add lo\add* \w ordenó|strong="H6680"\w* \w a|strong="H3068"\w* \w Josué|strong="H3091"\w*, \w así|strong="H3651"\w* \w Josué|strong="H3091"\w* \w lo|strong="H1697"\w* \w hizo|strong="H6213"\w* \w sin|strong="H3808"\w* omitir \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* \w todo|strong="H3605"\w* \w lo|strong="H1697"\w* \w que|strong="H3808"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w ordenó|strong="H6680"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*.   
\p
\v 16 \w Josué|strong="H3091"\w* \w tomó|strong="H3947"\w* \w toda|strong="H3605"\w* \w aquella|strong="H2063"\w* tierra: \w la|strong="H2063"\w* región montañosa, \w todo|strong="H3605"\w* \w el|strong="H3605"\w* Neguev, \w toda|strong="H3605"\w* \w la|strong="H2063"\w* tierra de Gosén, \w la|strong="H2063"\w* llanura, \w el|strong="H3605"\w* Arabá, \w la|strong="H2063"\w* región montañosa de \w Israel|strong="H3478"\w* y sus valles,  
\v 17 \w desde|strong="H4480"\w* \w la|strong="H3605"\w* montaña Halac, \w que|strong="H4480"\w* \w sube|strong="H5927"\w* \w hacia|strong="H4480"\w* \w Seír|strong="H8165"\w*, \w hasta|strong="H5704"\w* \w Baal-gad|strong="H1171"\w* \w en|strong="H4480"\w* \w el|strong="H3605"\w* valle \w del|strong="H4480"\w* \w Líbano|strong="H3844"\w*, \w al|strong="H4480"\w* \w pie|strong="H8478"\w* \w de|strong="H4480"\w* \w la|strong="H3605"\w* montaña \w Hermón|strong="H2768"\w*. Capturó \w a|strong="H3068"\w* \w todos|strong="H3605"\w* sus \w reyes|strong="H4428"\w*, \w los|strong="H3605"\w* \w hirió|strong="H5221"\w* \w y|strong="H5704"\w* \w los|strong="H3605"\w* \w mató|strong="H5221"\w*.   
\p
\v 18 \w Muchos|strong="H7227"\w* fueron \w los|strong="H3605"\w* \w días|strong="H3117"\w* en \w los|strong="H3605"\w* cuales \w Josué|strong="H3091"\w* \w hizo|strong="H6213"\w* \w guerra|strong="H4421"\w* contra \w estos|strong="H3605"\w* \w reyes|strong="H4428"\w*.  
\v 19 \w Excepto|strong="H1115"\w* \w los|strong="H3427"\w* \w heveos|strong="H2340"\w*, \w que|strong="H3808"\w* \w habitaban|strong="H3427"\w* en \w Gabaón|strong="H1391"\w*, \w no|strong="H3808"\w* \w hubo|strong="H1961"\w* \w ciudad|strong="H5892"\w* \w que|strong="H3808"\w* hiciera \w paz|strong="H7999"\w* con \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*. \w Todo|strong="H3605"\w* \w lo|strong="H3808"\w* \w tomaron|strong="H3947"\w* en \w guerra|strong="H4421"\w*,  
\v 20 \w porque|strong="H3588"\w* esto venía \w de|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*: Endurecer \w el|strong="H3588"\w* \w corazón|strong="H3820"\w* \w de|strong="H3588"\w* \w ellos|strong="H1992"\w* \w para|strong="H4616"\w* \w que|strong="H3588"\w* resistieran \w con|strong="H3588"\w* \w guerra|strong="H4421"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w*, \w a|strong="H3068"\w* fin \w de|strong="H3588"\w* \w que|strong="H3588"\w* \w Él|strong="H3588"\w* \w los|strong="H1992"\w* destruyera \w por|strong="H3588"\w* completo sin clemencia \w para|strong="H4616"\w* \w que|strong="H3588"\w* fueran desarraigados, tal \w como|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w ordenó|strong="H6680"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*.   
\p
\v 21 \w En|strong="H4480"\w* \w aquel|strong="H1931"\w* \w tiempo|strong="H6256"\w* \w Josué|strong="H3091"\w* llegó y destruyó \w a|strong="H3068"\w* \w los|strong="H3605"\w* anaceos \w de|strong="H4480"\w* \w la|strong="H1931"\w* región montañosa \w de|strong="H4480"\w* \w Hebrón|strong="H2275"\w*, \w de|strong="H4480"\w* \w Debir|strong="H1688"\w*, \w de|strong="H4480"\w* \w Anab|strong="H6024"\w*, \w de|strong="H4480"\w* \w toda|strong="H3605"\w* \w la|strong="H1931"\w* región montañosa \w de|strong="H4480"\w* \w Judá|strong="H3063"\w* y \w de|strong="H4480"\w* \w toda|strong="H3605"\w* \w la|strong="H1931"\w* región montañosa \w de|strong="H4480"\w* \w Israel|strong="H3478"\w*. \w Josué|strong="H3091"\w* \w los|strong="H3605"\w* destruyó completamente, \w junto|strong="H5973"\w* \w con|strong="H5973"\w* \w sus|strong="H1931"\w* \w ciudades|strong="H5892"\w*.  
\v 22 \w Ninguno|strong="H3808"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* anaceos \w quedó|strong="H7604"\w* en la tierra \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*. \w Solo|strong="H7535"\w* \w quedaron|strong="H7604"\w* \w algunos|strong="H3498"\w* en \w Gaza|strong="H5804"\w*, Gat y Asdod.   
\p
\v 23 \w Josué|strong="H3091"\w* conquistó \w toda|strong="H3605"\w* \w la|strong="H3605"\w* tierra, conforme \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w que|strong="H3605"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*. \w Josué|strong="H3091"\w* \w la|strong="H3605"\w* \w entregó|strong="H5414"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w* como \w herencia|strong="H5159"\w* conforme \w a|strong="H3068"\w* las divisiones \w de|strong="H5414"\w* sus \w tribus|strong="H7626"\w*. \w Y|strong="H3068"\w* \w la|strong="H3605"\w* tierra descansó \w de|strong="H5414"\w* \w la|strong="H3605"\w* \w guerra|strong="H4421"\w*.   
\c 12  
\s1 Los reyes derrotados  
\p
\v 1 \w Éstos|strong="H3605"\w* son \w los|strong="H1121"\w* \w reyes|strong="H4428"\w* \w de|strong="H5704"\w* aquella tierra \w que|strong="H5704"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5704"\w* \w Israel|strong="H3478"\w* derrotaron, cuyo territorio conquistaron \w al|strong="H5704"\w* otro \w lado|strong="H5676"\w* del \w Jordán|strong="H3383"\w*, hacia \w el|strong="H3605"\w* \w sol|strong="H8121"\w* naciente, \w desde|strong="H5704"\w* \w el|strong="H3605"\w* arrollo Arnón \w hasta|strong="H5704"\w* \w la|strong="H3605"\w* montaña \w Hermón|strong="H2768"\w*, \w y|strong="H5704"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* Arabá hacia \w el|strong="H3605"\w* \w oriente|strong="H4217"\w*:  
\v 2 \w Sehón|strong="H5511"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w los|strong="H3427"\w* amorreos, quien \w vivía|strong="H3427"\w* \w en|strong="H5921"\w* \w Hesbón|strong="H2809"\w* \w y|strong="H5921"\w* dominaba \w desde|strong="H5704"\w* \w Aroer|strong="H6177"\w*, \w que|strong="H5921"\w* \w está|strong="H3427"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* orilla \w del|strong="H5921"\w* arrollo Arnón, \w y|strong="H5921"\w* \w desde|strong="H5704"\w* \w la|strong="H5921"\w* \w mitad|strong="H8432"\w* \w del|strong="H5921"\w* arrollo \w hasta|strong="H5704"\w* \w Galaad|strong="H1568"\w*, \w y|strong="H5921"\w* \w hasta|strong="H5704"\w* \w el|strong="H5921"\w* \w arroyo|strong="H5158"\w* \w de|strong="H5921"\w* \w Jaboc|strong="H2999"\w*, \w que|strong="H5921"\w* es \w el|strong="H5921"\w* límite \w de|strong="H5921"\w* \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* Amón;  
\v 3 \w y|strong="H5704"\w* el Arabá \w hasta|strong="H5704"\w* el \w mar|strong="H3220"\w* \w de|strong="H8478"\w* Cineret \w por|strong="H8478"\w* el \w oriente|strong="H4217"\w*, \w y|strong="H5704"\w* \w hasta|strong="H5704"\w* el \w mar|strong="H3220"\w* del Arabá, \w mar|strong="H3220"\w* \w de|strong="H8478"\w* la \w Sal|strong="H4417"\w*, \w al|strong="H5704"\w* \w oriente|strong="H4217"\w* \w hacia|strong="H1870"\w* Bet-hayesimot, \w y|strong="H5704"\w* \w al|strong="H5704"\w* sur \w hasta|strong="H5704"\w* el \w pie|strong="H8478"\w* \w de|strong="H8478"\w* la montaña Pisga;  
\v 4 y \w el|strong="H3427"\w* territorio de \w Og|strong="H5747"\w*, \w rey|strong="H4428"\w* de \w Basán|strong="H1316"\w*, uno de \w los|strong="H3427"\w* que quedaba de \w los|strong="H3427"\w* refaítas que \w vivía|strong="H3427"\w* en Astarot y en Edrei,  
\v 5 \w y|strong="H5704"\w* dominaba \w en|strong="H5704"\w* \w la|strong="H3605"\w* montaña \w Hermón|strong="H2768"\w*, \w en|strong="H5704"\w* \w Salca|strong="H5548"\w* \w y|strong="H5704"\w* \w en|strong="H5704"\w* \w todo|strong="H3605"\w* \w Basán|strong="H1316"\w*, \w hasta|strong="H5704"\w* \w el|strong="H3605"\w* límite \w del|strong="H2677"\w* gesurita, \w del|strong="H2677"\w* maaquita \w y|strong="H5704"\w* \w la|strong="H3605"\w* mitad \w de|strong="H5704"\w* \w Galaad|strong="H1568"\w*, \w hasta|strong="H5704"\w* \w el|strong="H3605"\w* límite \w de|strong="H5704"\w* \w Sehón|strong="H5511"\w*, \w rey|strong="H4428"\w* \w de|strong="H5704"\w* \w Hesbón|strong="H2809"\w*.   
\p
\v 6 Éstos fueron derrotados \w por|strong="H5414"\w* \w Moisés|strong="H4872"\w*, esclavo \w de|strong="H1121"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, y \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*. \w Moisés|strong="H4872"\w*, esclavo \w de|strong="H1121"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \w entregó|strong="H5414"\w* aquella tierra \w en|strong="H5221"\w* \w posesión|strong="H3425"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* rubenitas, \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w gaditas|strong="H1425"\w* y \w a|strong="H3068"\w* la media \w tribu|strong="H7626"\w* \w de|strong="H1121"\w* \w Manasés|strong="H4519"\w*.   
\p
\v 7 Estos son \w los|strong="H1121"\w* \w reyes|strong="H4428"\w* \w de|strong="H5704"\w* la tierra \w que|strong="H5704"\w* \w Josué|strong="H3091"\w* \w y|strong="H5704"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5704"\w* \w Israel|strong="H3478"\w* derrotaron \w a|strong="H3068"\w* este \w lado|strong="H5676"\w* del \w Jordán|strong="H3383"\w*, \w al|strong="H5704"\w* occidente, \w desde|strong="H5704"\w* \w Baal-gad|strong="H1171"\w* \w en|strong="H5704"\w* \w el|strong="H1121"\w* valle del \w Líbano|strong="H3844"\w* \w hasta|strong="H5704"\w* la montaña \w de|strong="H5704"\w* Halac, \w que|strong="H5704"\w* \w sube|strong="H5927"\w* \w a|strong="H3068"\w* \w Seír|strong="H8165"\w*. \w Josué|strong="H3091"\w* la \w dio|strong="H5414"\w* \w en|strong="H5704"\w* \w posesión|strong="H3425"\w* \w a|strong="H3068"\w* las \w tribus|strong="H7626"\w* \w de|strong="H5704"\w* \w Israel|strong="H3478"\w* según sus divisiones:   
\li1
\v 8 la región montañosa, la Sefela, el Arabá, las laderas, el desierto y el Neguev; el heteo, el amorreo y el cananeo, el ferezeo, el heveo y el jebuseo;   
\li1
\v 9 primero, el rey de Jericó, otro, el rey de Hai, que está junto a Bet-ʼEl,   
\li1
\v 10 otro, el rey de Jerusalén, otro, el rey de Hebrón,   
\li1
\v 11 otro, el rey de Jarmut, otro, el rey de Laquis,   
\li1
\v 12 otro, el rey de Eglón, otro, el rey de Gezer,   
\li1
\v 13 otro, el rey de Debir, otro, el rey de Geder,   
\li1
\v 14 otro, el rey de Horma, otro, el rey de Arad,   
\li1
\v 15 otro, el rey de Libna, otro, el rey de Adullam,   
\li1
\v 16 otro, el rey de Maceda, otro, el rey de Bet-ʼEl,   
\li1
\v 17 otro, el rey de Tapúa, otro, el rey de Hefer,   
\li1
\v 18 otro, el rey de Afec, otro, el rey del Sarón,   
\li1
\v 19 otro, el rey de Madón, otro, el rey de Hazor,   
\li1
\v 20 otro, el rey de Simrón-merón, otro, el rey de Acsaf,   
\li1
\v 21 otro, el rey de Taanac, otro, el rey de Meguido,   
\li1
\v 22 otro, el rey de Kedes, otro, el rey de Yocneam (de la montaña Carmelo),   
\li1
\v 23 otro, el rey de Dor (de la región de Dor), otro, el rey de Goim (en Gilgal),   
\li1
\v 24 otro, el rey de Tirsa. 31 reyes en total.   
\c 13  
\s1 La tierra por conquistar  
\p
\v 1 \w Cuando|strong="H3117"\w* \w Josué|strong="H3091"\w* era anciano, avanzado en \w años|strong="H3117"\w*, \nd \+w Yavé|strong="H3068"\+w*\nd* le dijo: \wj Tú eres anciano, avanzado en \+w años|strong="H3117"\+w*, y todavía \+w queda|strong="H7604"\+w* muchísima tierra por conquistar.\wj*   
\p
\v 2 \wj \+w Esta|strong="H2063"\+w* \+w es|strong="H2063"\+w* \+w la|strong="H2063"\+w* tierra \+w que|strong="H3605"\+w* \+w queda|strong="H7604"\+w*: \+w Todos|strong="H3605"\+w* \+w los|strong="H3605"\+w* territorios de \+w los|strong="H3605"\+w* \+w filisteos|strong="H6430"\+w* y de \+w los|strong="H3605"\+w* gesuritas.\wj*  
\v 3 \wj \+w Desde|strong="H4480"\+w* \+w Sihor|strong="H7883"\+w*, \+w al|strong="H5921"\+w* oriente \+w de|strong="H4480"\+w* \+w Egipto|strong="H4714"\+w*, \+w hasta|strong="H5704"\+w* \+w el|strong="H5921"\+w* límite \+w de|strong="H4480"\+w* \+w Ecrón|strong="H6138"\+w* \+w al|strong="H5921"\+w* \+w norte|strong="H6828"\+w*, \+w que|strong="H4480"\+w* \+w se|strong="H5921"\+w* considera \+w como|strong="H5921"\+w* \+w cananeo|strong="H3669"\+w*; \+w cinco|strong="H2568"\+w* principados \+w de|strong="H4480"\+w* \+w los|strong="H5921"\+w* \+w filisteos|strong="H6430"\+w*: \+w el|strong="H5921"\+w* gazeíta, \+w el|strong="H5921"\+w* asdodita, \+w el|strong="H5921"\+w* asquelonita, \+w el|strong="H5921"\+w* guitita, \+w el|strong="H5921"\+w* acronita \+w y|strong="H5921"\+w* \+w los|strong="H5921"\+w* heveos;\wj*  
\v 4 \wj \+w al|strong="H5704"\+w* sur, \+w toda|strong="H3605"\+w* \+w la|strong="H3605"\+w* tierra \+w de|strong="H5704"\+w* \+w los|strong="H3605"\+w* \+w cananeos|strong="H3669"\+w*, \+w y|strong="H5704"\+w* Meara, \+w que|strong="H5704"\+w* pertenece \+w a|strong="H3068"\+w* \+w los|strong="H3605"\+w* \+w sidonios|strong="H6722"\+w*, \+w hasta|strong="H5704"\+w* Afec, \+w hasta|strong="H5704"\+w* \+w el|strong="H3605"\+w* límite del amorreo,\wj*  
