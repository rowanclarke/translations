\id 2TH - Margi Tiwi ∆Źnga T«Ěm [mfm] 
\h Tasalonika N«Ě M«Ěthl«Ěu 
\toc3 Tas M«Ěth 
\toc2 Tasalonika N«Ě M«Ěthl«Ěu 
\toc1 Ts«Ěf«Ě N«Ě Bulusu An«Ě Njir Tasalonika N«Ě M«Ěthl«Ěu 
\mt2 Cama Ts«Ěts«Ěf«Ě N«Ě Bulusu N«Ě M«Ěthl«Ěu An«Ě 
\mt1 Njir Tasalonika 
\c 1  
\s1 Usa Dzau 
\p  
\v 1 Cama ts«Ěts«Ěf«Ě k«Ě sara ara Bulusu, «Ěnga Silasu, ba «Ěnga Timathlawusu. 
\p A nda n«Ě da…ď«Ě dz«Ě njir nu k«Ěra wu m«Ělm«Ě Tasalonika, k«Ěra n«Ě Hyal D«Ěrm«Ěn «Ěnga Thlag«Ě Yesu K«Ěrsiti. 
\p  
\v 2 B«Ěg«Ě mayiwakur «Ěnga hu…ó«Ě p«Ěrt«Ěu sara ara Hyal Tada «Ěnga Thlag«Ě Yesu K«Ěrsiti nda nggya «Ěnga hyi. 
\s1 L«Ě Usaku ∆Źnga K«Ědi Hyal 
\p  
\v 3 Kakal nga nyi ňąya na usaku an«Ě Hyal cumu aga hyi, nahyi wazha ama, ara mb«Ěrsar hyi a v«Ěr cak«Ě gaga…óau, «Ěnga yiwu k«Ěra hya v«Ěr yiwu k«Ěrhyi a v«Ěr cakau.  
\v 4 Agabangau, ňąya v«Ěr …ďwasau «Ěnga hyi wu da…ď«Ě dz«Ě njir nu Hyal pam«Ěpam«Ě arya s«Ěs«Ěňąwu s«Ě «Ěnga mb«Ěrsar hyi wu pat«Ěr …óa dz«Ě pam«Ěpam«Ěu «Ěnga nggya dzadzau k«Ěra hya v«Ěr s«Ěs«Ěňąwuri. 
\p  
\v 5 Kalar s«Ěňąyar kau ca ng«Ě cabiya numa n«Ě Hyal tsaňąa nga nyi, arya kau nja nda jig«Ěwa hyi wu njira a …óari kakal nda gwu t«Ělkur Hyal k«Ěra hya v«Ěr sa …ďwa…ďwat«Ě aga nyi.  
\v 6 Hyal nd«Ě tsap«Ě ngau, ju nda kina «Ěnga …ďwa…ďwat«Ě an«Ě njira v«Ěr l«Ě …ďwa…ďwat«Ě an«Ě hyi.  
\v 7 ∆Źnga tsu, ju n«Ě hyi …ď«Ělsar, nahyi k«Ěra a v«Ěr sa …ďwa…ďwat«Ě «Ěkk«Ěňąyi naňąya tsu ma Thlag«Ě Yesu cabiya k«Ěr sara d«Ěm«Ělmau wu uňąu mb«Ěmbau «Ěnga waladi nyiňąyar.  
\v 8 Ju sa n«Ě nyi …ďwa…ďwat«Ě an«Ě njira g«Ěra s«Ěn Hyal «Ěnga njira piyari nu nd«Ěshigu n«Ě Thlag«Ěr m«Ěn Yesu.  
\v 9 Ndu nda sa …ďwa…ďwat«Ě k«Ěra g«Ěra ku…óau, «Ěnga na ndu nda lari bama Thlag«Ěu «Ěnga kadakadarkur n«Ě d«Ěnama nyi mai.  
\v 10 S«Ěňąyar k«Ě wu nda …óa, ar p«Ěcira ji shida, aga nji cicau ndu sa n«Ě nyi kadakadarkur, pat«Ě njira h«Ěngg«Ěri ndu nda g«Ěngg«Ěr nyi s«Ěli. ∆Źnggau, pat«Ě «Ěkk«Ěňąyi nahyi, ara a h«Ěngg«Ěr hyi «Ěnga sakida k«Ěra ňąyi nar hyi. 
\p  
\v 11 ∆Źnga najaka s«Ě a wu k«Ěr, ňąya v«Ěr k«Ědi Hyal an«Ě hyi cumu, aga Hyal«Ěr m«Ěn ja jig«Ěwa hyi wu ngga nyi, «Ěnga d«Ěnama nyi nga ju nda nyabiya kalar s«Ě m«Ěnah«Ě k«Ěra hyi m«Ěl «Ěnga kalar s«Ěra …ó«Ěfuwa hyi n«Ěr hyi lagur mb«Ěrsar hyi.  
\v 12 ňąYa v«Ěr k«Ědi Hyal kau, aga nja n«Ě nyi kadakadarkur an«Ě thl«Ěm«Ě Thlag«Ěr m«Ěn Yesu wu hyi, «Ěnga nahyi tsu, hyu uya kadakadarkur wu ja. S«Ě k«Ě wu …óar k«Ěr lagur mayiwakur n«Ě Hyal«Ěr m«Ěn «Ěnga Thlag«Ě Yesu K«Ěrsiti. 
\c 2  
\s1 Nd«Ěr Hyaňąa Hang«Ěkal 
\p  
\v 1 Ar k«Ěra shil«Ěr Thlag«Ěr m«Ěn Yesu K«Ěrsiti «Ěnga sa …ď«Ěr m«Ěn papat«Ěu «Ěkk«Ěňąyi ja, ňąya v«Ěr k«Ědi hyi wazha ama,  
\v 2 a sara hya g«Ěrah«Ě wu …ó«Ěfuwa hyi kusakusa mai alaga hang«Ěkala hyi a hyaňąari mai, ab«Ěr p«Ěcir shilir Thlag«Ěu a ku…óa shiliri mai. Ma vanyi, ab«Ěr vanyi nd«Ě a nar hyi ri abangau, lagur nd«Ěr haha, alaga cama ts«Ěts«Ěfau, alaga nd«Ěr papah«Ěu, alaga nja na ab«Ěr cama ngau sara ara ňąya.  
\v 3 A sara hya piyari kalar ndau a nggutana hyi alaga abari mai, ara p«Ěci ta aňąyi shili mai, k«Ěl ma g«Ěra nggand«Ěrkur k«Ě …óa kwatah«Ěu, «Ěnga ma nd«Ěr hyaňąa hang«Ěkal ta cabiya dzau, naja ng«Ě nd«Ěra nji fiya nyi aga sa.  
\v 4 Naja ng«Ě nd«Ěra wu tsam«Ě k«Ěrnyi «Ěnga kadakadarkur, ju nda pari kalar s«Ěra nju ngga «Ěnga Hyal, «Ěnga kalar s«Ěr dl«Ěvau. Ju nda fiya k«Ěrnyi ar vir nggya wu ki Hyal, «Ěnga ju fiya k«Ěrnyi ar viya Hyal. 
\p  
\v 5 Nahyi aňąyi a …ó«Ěngari wa, yu na s«Ěňąyar kau an«Ě hyi ar p«Ěcira m«Ěn ar vira z«Ěm«Ěu?  
\v 6 Kabang«Ěkau a s«Ěn hyi s«Ěra a v«Ěr kar nyi, aga k«Ěl ma p«Ěci nyi a …óari nga ja dz«Ěgwa cabiya dzau.  
\v 7 Ara nd«Ěr hyaňąa hang«Ěkal k«Ě a v«Ěr m«Ěl thl«Ěr …ó«Ě…ó«Ěwa kabang«Ěkau, a nggyar ja …ó«Ě…ó«Ěwa k«Ěl ma nd«Ěra v«Ěr kar nyi ara biyar babal k«Ě …ďana dzau.  
\v 8 Ba nd«Ěr hyaňąa hang«Ěkal ka dz«Ěgwa cabiya dzau, nd«Ěra Thlag«Ěu Yesu wu nda tsiya nyi «Ěnga s«Ě pi sara wu miya ja, «Ěnga ja dz«Ěgwa wushina nyi «Ěnga kadakadarkur n«Ě shili nyi.  
\v 9 Nd«Ěr hyaňąa hang«Ěkal kau, ju nda shili «Ěnga d«Ěnama sara ara shatan, ja dz«Ěgwa sana liya nji «Ěnga m«Ěl s«Ě d«Ěd«Ěgur «Ěnga m«Ětsam pampam«Ěu.  
\v 10 ∆Źnga ja nda nggutana njira ar lagu sasa «Ěnga kalar s«Ě …ó«Ěmwaňąyi k«Ěra wu s«Ěkwa dzau, ara nd«Ě piyari yiwu jiri k«Ěra wu nda k«Ětiya nda.  
\v 11 Arya najaka s«Ě ng«Ě Hyal a nda shabiya hang«Ěkala nda aga nda h«Ěngg«Ěr «Ěnga fatiya nyi,  
\v 12 aga abang«Ě nju nda thlana nda numa pat«Ěu, ara na nd«Ě h«Ěngg«Ěri «Ěnga jirkur mai, ama nd«Ě yiwu …ó«Ěmwaňąyikur. 
\s1 Hya Nggya ∆Źnga Jirkur 
\p  
\v 13 Kakal nga nyi ňąya l«Ě usaku an«Ě Hyal cumu arya hyi, nahyi wazha ama k«Ěra Thlag«Ě a yiwu, ara Hyal ng«Ě ca…ó«Ěbiya hyi aga hya …óa wu nji tangg«Ěrma k«Ěra uya mb«Ě…ó«Ě lagur Mamb«Ěl, ca ng«Ě m«Ěliya hyi cici «Ěnga lagur h«Ěngg«Ěri wu jiri.  
\v 14 Aga k«Ě nga ji ngga hyi, lagur nd«Ěshigu ňąya k«Ěra ňąyi n«Ě hyi, aga hya uya kadakadarkur n«Ě Thlag«Ěr m«Ěn Yesu K«Ěrsiti.  
\v 15 Agabangau, wazha ama, hya ciya dzau «Ěnga hya s«Ě…ďiya highi…ď«Ě ňąyar k«Ě ňąyi n«Ě hyi kau, alaga «Ěnga miya ba lagur cama ts«Ěts«Ěfau. 
\p  
\v 16 B«Ěg«Ě Thlag«Ěr m«Ěn Yesu K«Ěrsiti «Ěnga k«Ěrnyi ba Hyal Tada, k«Ěra cabiya m«Ěn yiwukur, ja n«Ě m«Ěn ts«Ěts«Ěku …ó«Ěfu k«Ěra g«Ěra ku…óau «Ěnga f«Ěr k«Ěr m«Ěnah«Ěu.  
\v 17 B«Ěg«Ě ja n«Ě hyi ts«Ěts«Ěku …ó«Ěfu, «Ěnga ja n«Ě hyi d«Ěnama wu pat«Ěr s«Ě m«Ěnah«Ěu k«Ěra hyu m«Ěl «Ěnga s«Ěra hyu na. 
\c 3  
\s1 Bulusu Wu Yiwu Nja K«Ědi Hyal An«Ě Nda 
\p  
\v 1 Wu jom«Ěya nyi, wazha ama, ňąya v«Ěr k«Ědi aga hya k«Ědi Hyal an«Ě ňąya. Hya k«Ědi Hyal aga nd«Ěshigu n«Ě Thlag«Ěu a t«Ět«Ělnak«Ěr kusakusa, «Ěnga aga ja …óa «Ěnga kadakadarkur, «Ěngg«Ěr k«Ěra ji shili an«Ě hyi.  
\v 2 ∆Źnga tsu hya k«Ědi Hyal, aga nja k«Ětiya ňąya ara nji …ó«Ěmwaňąyu «Ěnga nji shishi, ara aňąyi kalar nji ng«Ě «Ěnga mb«Ěrsa mai.  
\v 3 Ama Thlag«Ě nd«Ě tsaňąa miya …ó«Ěfu ngau, ju nda n«Ě hyi d«Ěnama, «Ěnga ja k«Ětiya hyi ara nji …ó«Ěmwaňąyu.  
\v 4 A mb«Ěrsar ňąya «Ěnga Thlag«Ěu ab«Ěr hya v«Ěr m«Ěl s«Ěra ňąyi na aga hya m«Ěl, «Ěnga tsu hya dumwa «Ěnga m«Ěl nda.  
\v 5 B«Ěg«Ě Thlag«Ěu ja ts«Ěkwar …ó«Ěfuwa hyi aga hya s«Ěnbiya yiwukur n«Ě Hyal, «Ěnga s«Ěs«Ěu s«Ě lagur K«Ěrsiti. 
\s1 M«Ěl Thl«Ěr S«Ě M«Ěnah«Ě Ngau 
\p  
\v 6 Wazha ama, ňąya v«Ěr na an«Ě hyi wu thl«Ěm«Ěr Thlag«Ěr m«Ěn Yesu K«Ěrsiti, ab«Ěr hya t«Ěk«Ě «Ěnga kalar zam«Ě ha…ó«Ěwa, «Ěnga naja aňąyi wu yiwu m«Ěl thl«Ěr «Ěnga s«Ěra hyi highi…ď«Ěri ara ňąya mai.  
\v 7 Nahyi «Ěnga k«Ěrhyi, a s«Ěn hyi «Ěngg«Ěr k«Ěra kikyau hya faňąabiya hiya s«Ěra ňąyi m«Ěl. Wu p«Ěcira ňąya «Ěgya hyi na ňąya aňąyi nggya dzaf«Ě mai.  
\v 8 ∆Źnga tsu naňąya aňąyi wu s«Ěm s«Ěr s«Ěm nji g«Ěra kina mai. Ama a sar ňąya …ďwa…ďwat«Ě vuňąyi «Ěnga puci a v«Ěr m«Ěl thl«Ěr, aga ňąya sara …óa s«Ě t«Ěd«Ě…ď«Ě an«Ě hyi.  
\v 9 S«Ěra …óa ňąyi m«Ěl abangau, ara aňąyi ňąya g«Ěra d«Ěnama n«Ě yiwa aga hya dl«Ěwar ňąya mai, ama aga ňąya …óa s«Ěr f«Ě li k«Ěra hyu faňąabiya hiya nyi.  
\v 10 Wu p«Ěcira m«Ěn ar vira z«Ěm«Ěu, a nar hyir ňąya ab«Ěr ma nd«Ě ngg«Ěl ara m«Ěl thl«Ěr, a sara nja l«Ě s«Ěr s«Ěm an«Ě nyi mai. 
\p  
\v 11 ňąYi na abang«Ě ara ňąyi nggari ab«Ěr alenyi nji wu hyi, nji ha…ó«Ěwa ngau, thl«Ěr m«Ěl aňąyi ara nda mai, k«Ěl nggya aga ji…ďa njir m«Ěl thl«Ěr.  
\v 12 Culi najaka nji ňąya v«Ěr t«Ě…ó«Ě himiya nda «Ěnga n«Ě nda s«Ěr …ď«Ěla wu d«Ěnama n«Ě Thlag«Ě Yesu K«Ěrsiti aga nda m«Ěliya k«Ěrnda, nda m«Ěl thl«Ěr aga nda uya …ó«Ěf«Ě k«Ěra nda s«Ěm.  
\v 13 Nahyi tsu, wazha ama, a sara hya h«Ě…óa «Ěnga m«Ěl s«Ěra tsaňąa mai. 
\p  
\v 14 Kalar nd«Ěra ngg«Ěl ara nu s«Ěra ňąyi nana a gwar cama ts«Ěts«Ěf«Ě kau, hya f«Ěr li m«Ěnah«Ěu ar ja. A sara hya da…ď«Ěr k«Ěr «Ěnga ja mai, aga ja gu s«Ěli.  
\v 15 Ama a sara hya fiya nyi ar viya dawa mai, ama hya t«Ě…ó«Ě himiya ja ar viya z«Ěr ama. 
\s1 F«Ě Barka 
\p  
\v 16 B«Ěg«Ě Thlag«Ě «Ěnga k«Ěrnyi nd«Ěr l«Ě hu…ó«Ě p«Ěrt«Ěu, ja n«Ě hyi hu…ó«Ě p«Ěrt«Ě cumu wu kalar lagu. B«Ěg«Ě Thlag«Ě ja nggya «Ěnga hyi pat«Ěu.  
\v 17 Nayi Bulusu ng«Ě ts«Ěf«Ě najaka usa dzau «Ěnga tsa yau. K«Ě ng«Ě sakida n«Ě kalar cama ts«Ěts«Ěf«Ě …óa. ∆Źngg«Ěr k«Ě nga yu ts«Ěfau.  
\v 18 B«Ěg«Ě mayiwakur n«Ě Thlag«Ěr m«Ěn Yesu K«Ěrsiti ja nggya «Ěnga hyi pat«Ěu. Amina.