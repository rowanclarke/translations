\p
\v 3 \w But|strong="H2009"\w* God appeared \w to|strong="H4191"\w* Abimelech \w in|strong="H5921"\w* \w a|strong="H3068"\w* \w dream|strong="H2472"\w* \w and|strong="H3915"\w* told \w him|strong="H5921"\w*, “\w Listen|strong="H2009"\w*! \w You|strong="H5921"\w*'re going \w to|strong="H4191"\w* \w die|strong="H4191"\w* \w because|strong="H5921"\w* \w the|strong="H5921"\w* woman \w you|strong="H5921"\w*'ve \w taken|strong="H3947"\w* \w is|strong="H1931"\w* already \w married|strong="H3947"\w*—\w she|strong="H1931"\w* \w has|strong="H2009"\w* \w a|strong="H3068"\w* \w husband|strong="H1167"\w*.”   
