\v 3 \w Y|strong="G2532"\w* \w se|strong="G1438"\w* preguntaban: ¿\w Quién|strong="G5101"\w* \w nos|strong="G1438"\w* removerá \w la|strong="G3588"\w* \w piedra|strong="G3037"\w* \w de|strong="G1537"\w* \w la|strong="G3588"\w* entrada \w del|strong="G3588"\w* \w sepulcro|strong="G3419"\w*?   
\p
\v 4 \w Pero|strong="G2532"\w*, \w al|strong="G3588"\w* levantar \w la|strong="G3588"\w* mirada, \w vieron|strong="G2334"\w* \w que|strong="G3754"\w*, \w aunque|strong="G2532"\w* \w la|strong="G3588"\w* \w piedra|strong="G3037"\w* \w era|strong="G1510"\w* \w muy|strong="G4970"\w* \w grande|strong="G3173"\w*, \w ya|strong="G2532"\w* había sido rodada.  
\v 5 \w Entraron|strong="G1525"\w* \w en|strong="G1722"\w* \w el|strong="G3588"\w* \w sepulcro|strong="G3419"\w* \w y|strong="G2532"\w* vieron \w a|strong="G1519"\w* \w un|strong="G3588"\w* joven \w sentado|strong="G2521"\w* \w a|strong="G1519"\w* \w la|strong="G3588"\w* \w derecha|strong="G1188"\w*, vestido \w de|strong="G1722"\w* \w un|strong="G3588"\w* manto largo \w y|strong="G2532"\w* \w blanco|strong="G3022"\w*, \w y|strong="G2532"\w* \w se|strong="G2532"\w* alarmaron.   
\p
\v 6 \w Pero|strong="G1161"\w* \w él|strong="G3588"\w* les \w dijo|strong="G3004"\w*: \w No|strong="G3756"\w* \w se|strong="G2212"\w* alarmen. \w Buscan|strong="G2212"\w* \w al|strong="G3588"\w* Nazareno \w que|strong="G3588"\w* fue \w crucificado|strong="G4717"\w*. \w No|strong="G3756"\w* \w está|strong="G3588"\w* \w aquí|strong="G5602"\w*. Fue \w resucitado|strong="G1453"\w*. Miren \w el|strong="G3588"\w* \w lugar|strong="G5117"\w* \w donde|strong="G3699"\w* \w lo|strong="G3588"\w* \w pusieron|strong="G5087"\w*.  
\v 7 \w Pero|strong="G2532"\w* vayan, digan \w a|strong="G1519"\w* \w sus|strong="G3588"\w* \w discípulos|strong="G3101"\w* \w y|strong="G2532"\w* \w a|strong="G1519"\w* \w Pedro|strong="G4074"\w* \w que|strong="G3754"\w* \w va|strong="G5217"\w* \w delante|strong="G1519"\w* \w de|strong="G1519"\w* ustedes \w a|strong="G1519"\w* \w Galilea|strong="G1056"\w*. \w Allí|strong="G1563"\w* \w lo|strong="G3588"\w* verán, \w como|strong="G2531"\w* \w les|strong="G1519"\w* \w dijo|strong="G3004"\w*.   
\p
\v 8 \w Salieron|strong="G1831"\w* \w del|strong="G3588"\w* \w sepulcro|strong="G3419"\w* \w y|strong="G2532"\w* \w huyeron|strong="G5343"\w*, \w porque|strong="G1063"\w* \w un|strong="G3588"\w* \w temblor|strong="G5156"\w* \w y|strong="G2532"\w* asombro \w las|strong="G3588"\w* dominaba. \w A|strong="G1161"\w* \w nadie|strong="G3762"\w* \w le|strong="G1438"\w* informaron \w porque|strong="G1063"\w* \w tenían|strong="G2192"\w* \w miedo|strong="G5399"\w*.  
\p [[ 
