\s1 Nehemiah’s Generosity  
\b  
\m
\v 14 \w Furthermore|strong="H1571"\w*, \w from|strong="H3117"\w* \w the|strong="H3117"\w* \w day|strong="H3117"\w* \w King|strong="H4428"\w* Artaxerxes \w appointed|strong="H6680"\w* \w me|strong="H6680"\w* \w to|strong="H5704"\w* \w be|strong="H1961"\w* \w their|strong="H1961"\w* \w governor|strong="H6346"\w* \w in|strong="H8141"\w* \w the|strong="H3117"\w* land \w of|strong="H4428"\w* \w Judah|strong="H3063"\w*, \w from|strong="H3117"\w* \w his|strong="H6680"\w* \w twentieth|strong="H6242"\w* \w year|strong="H8141"\w* \w until|strong="H5704"\w* \w his|strong="H6680"\w* \w thirty-second|strong="H7970"\w* \w year|strong="H8141"\w* (\w twelve|strong="H8147"\w* \w years|strong="H8141"\w* total), \w neither|strong="H3808"\w* \w I|strong="H3117"\w* \w nor|strong="H3808"\w* \w my|strong="H1961"\w* brothers ate \w the|strong="H3117"\w* \w food|strong="H3899"\w* \w allotted|strong="H1961"\w* \w to|strong="H5704"\w* \w the|strong="H3117"\w* \w governor|strong="H6346"\w*.   
