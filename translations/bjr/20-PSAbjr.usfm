\id PSA - Binumarien Psalms, Des & Jenny Oatridge, 18-Sep-2003; 13-April-2016
\h IDI UFA
\toc1 IDI UFA
\toc2 IDI UFA
\mt1 IDI UFA
\c 1
\ms1 Samma Papiqa
\r –41 Indaaruqaafa (Book 1)
\mr Idi Ufa 1–41
\s1 Kuqaa qira asasirafa.
\q1 
\v 1 Manda oosana maree mariasa iriranamau sia
\q2 fimariasa faqa Anutuna ufa rukiee mariasa faqa
\q1 sia moodaanaki kimariasa faqa andeeqara
\q2 oosanara fidiaqaa imariasa faqa sia ooqu maria
\q1 fasiqausa mi manda oosanausara rufiee
\q2 mariasa misa asasiranaki maridaqa.
\q1 
\v 2 Miqi maria andeeqara fasiqa anaaseesa Anutuna
\q2 sandufamau fuanara asasirana maraidaqa.
\q1 Misa faasaana faqa eendanaki faqa mi sandufana
\q2 asaana rumasee irimaree fidaqa.
\q1 
\v 3 Miqi maria fasiqa anaaseesa saqari nammari aaqa
\q2 ummaqirafara foora iqa mariasa maridaqa narí
\q1 qanaa mina aqama amiqimmasee iraidanoo
\q2 mina amanee sia kakasidanoo.
\q1 Miqira fasiqa anaasee nana ainainee auqaafanoo
\q2 anoonaikidanoo.
\q1 
\v 4 Manda oosana maree marisa sia miqidaqa.
\q1 Misa anaaqmaarara foora ufai uqinoo fuaqaqidanoo.
\q1 
\v 5 Yaaweena ufa rukiee marisa Anutufa narí ufannai
\q2 rumbannimaqaseenoo narí faiqí anaasee
\q1 mariaqooqari nianai naaduma mara
\q2 quqannisaannoo.
\q1 
\v 6 Yaaweefa andeeqarausa nirana mariranasaa
\q2 rakisidanoo itita nimaqaidanoo.
\q1 Manda oosana maree mariasa kuridiranaki maaniki
\q2 fifaranoo.
\c 2
\s1 Anutufa utaaqamaqoo karaambaiqafa.
\q1 
\v 1 Nanaree aiqama maqannaasa fifau suqufiqa manda
\q2 oosanara tipundaarammasee aanoo qidee.
\q1 Nanaree faiqí anaasee anoona siai ainainara
\q2 tipundaaridee.
\q1 
\v 2 Misa karaambaiqauqa faqa misa rakisi nimaqee
\q2 mariasa faqa Yaaweefa rakisi nimaqee marinakiqari quqasee kaqinni firara tipundaaridaqa.
\q1 Yaaweefa utaaqamaqai rakisirana rakisi nimaqaranakiqari faqa quqasee kaqinni firaree qimasee tipundaaridaqa.
\q1 
\v 3 Misa maaqi qidaqa anifaqa maasa misa rakisi nimaqaranakiqari qeeqa qifaaqa idukua.
\q1 Anifaqa misa qimaqimira ufa aqusaanee qidaqa.
\q1 
\v 4 Yaaweefa innaarunai marifa naanaidara qimasee misa oosana siai tipundaariranara ataasa ataasa qimannimaqaidanoo.
\q1 
\v 5 Miqimmaseenoo narí aanooqiranakiqari aauqima nimaqasee narí idara fooira aanooqirana kiqari rufiarana nimidanoo.
\q1 
\v 6 Mifa maaqi qidanoo qinee Yaaweesa inni karaambaiqa marianinnana qeeqa naaquqara aaqana Sioona aaqanasaa quqeeqa.
\q1 
\v 7 Maqasaa karaambaiqa maaqi qinau, qinee Yaaweefa qima qimu ufana kooroo ianauree qinau.
\q1 Mifa qiniara maaqi qinau.
\q1 Anee qini qimaaku mariananoo maqee faasaana ani akausaikammiqa.
\q1 
\v 8 Anee qini iramirinaqa qinee aiqama maqannaasa ani amianaura.
\q1 Aiqama maqa maaqa anindi kai mariannoo.
\q1 
\v 9 Anee qainna samu misa narusee nimudaani itairi nimaqeennaranoo.
\q1 Anee qafeera foora misa rukamusee andaana rumaseennaranoo.
\q1 
\v 10 Innee maa maqanasaa karaambaiqauqa maa aauqira ufana iriaqa.
\q1 Maa maqa maaqanakinaa rakisirausa maa irirana maaqimmasee iriaqa.
\q1 
\v 11 Innee naaquqee marinaqa Yaaweena ainaina mamaqaaqa.
\q1 
\v 12 Naindiri ree marinaqa mina oorinni niqoori saunu araaqa.
\q1 Innee sia miqifanoo mifa aanoo qinaqa innee kuqifaranoo.
\q1 Mifa itita qimaqaanifee qimasee mifinnai fimariasa asasi mariasa maridaqa.
\c 3
\s1 Kananaana dadaaqiani fee innaaru.
\q1 
\v 1 Oo Yaawee qini namuqaa moomoo maridaqa, qini qiqoondikiqa mariusa quandaki qini namuqaakidaqa.
\q1 
\v 2 Misa qiniara maaqi qidaqa.
\q1 Anutufa sia mina dadaaqiannoo fee qidaqa.
\q1 
\v 3 Miqi qimariafana oo Yaawee anee qini aiqama kari mandainainaki itita qimaqee marianafa mariananoo.
\q1 Anee rakiranaki uriqararana qimiseenana qini paasoosirafa taikanoo marina kaifaa qimiananoo.
\q1 
\v 4 Qinee Yaaweena dadaaqianifeera aaree marunanoo narí naaquqara aaqanasaaqari iriseenoo dadaaqirana qiminoo.
\q1 
\v 5 Qinee maqasaa faiqaqee unaanoo aiqama eendirana Yaaweefa qini itita qimaqaidanoo.
\q1 
\v 6 Namuqaauqa nukudara foora qini fiqu fiqu iqa marianara sia qinee rufiaidaqa.
\q1 
\v 7 Qini Anutu, qini Yaawee anireenana qini mandainainaki marunnana dadaaqia.
\q1 Anee qini namuqaa aiqama aupurarana nimiseenana misa afeeka siaisaikamma sainaqa maridaqa sia qini daruaqa.
\q1 
\v 8 Oosana oosana ummaaraki uriqararafa ani Yaawee finaindari anidanoo.
\q1 Mifa narí faiqí anaasee amiqi amiqimma nimaqaani.
\c 4
\s1 Eeneemari dadaaqiani fee innaaru.
\q1 
\v 1 Oo qini itita qimaqee marianna Anutufa qinee innaaru ufakiqari ani aaraanana qini ufa iria.
\q1 Qinee manda qumaaraki mariafannana anee dadaaqinau.
\q1 Qiniara maqee qimudaoo qimisee qini innaaru qirana iria.
\v 2 Kisaaqasaa fee innee aasaandaana ufa qima qimaqeefaree.
\q1 Kisaaqasaa fee innee anoona siai ainainnara ridaqee
\q2 unnaqira ainaina afaqaqa fifaree.
\q1 
\v 3 Innee iriaqa. Yaaweefa andeeqarausa nariara utaaqama qaifaqa maridaqa.
\q1 Qinee mina aaraunanoo qini ufa iridanoo.
\q1 
\v 4 Innee naindiri ree marinaqa rufiaidaqa aaqee maria oosannana minnisaaqa.
\q1 Anee aneenna qaarisaa ireeda faiqaqee idana firaaqoo minara oonu mafi iria.
\q1 
\v 5 Anee Yaaweefa aidimari andeeqara tatufirana kai suqa amia Anutuna suqa amiseenana mina kai saqarikia.
\q1 
\v 6 Moomoosa maaqi qimasee innaaru qidaqa.
\q1 Oo Yaawee moomoo amiqi amiqirana maasa qimia.
\q1 Maasa qiqafamasee qimudaoo qimasee qimia.
\q1 
\v 7 Misa miqi qimariafana anee qini asasirana qimi marianafa mifa misa mi ainainausa uriqararafa maridanoo.
\q1 
\v 8 Oo Yaawee anee kai amiqimmasee ititaqisaanaqa amiqimmasee faiqaidaqa.
\q1 Qinee qeeqa qaarisaa qifaaqa quqasee asooaranaki faiqaidaqa.
\c 5
\s1 Manda ainainaki rakisi amaaqaani fee innaaru.
\q1 
\v 1 Oo Yaaweefa qini ufa iria.
\q1 Qini innaaru annada annada qiranakiqari qimarunnana iria.
\q1 
\v 2 Oo qini Anutufa, qini karaambaiqa qinee dadaaqiannee innaaru qimarunnana iria.
\q1 Oo Yaawee qinee aniara innaaru qidaqa.
\q1 
\v 3 Oo Yaawee aiqama kananaana kananaana qini ufa iriananoo.
\q1 Suani afu ururaifaqa qeeqa innaaru qirana amiseeqa ani dadaaqiranara afeesidaqa.
\q1 
\v 4 Anee aaqara oosanara sia asasimarianna Anutufa mariananoo.
\q1 Aaqara oosana maree mariasa sia eedoo qinaqa ani afusaa marifaranoo.
\q1 
\v 5 Nári nimoo naamoo qimariasa misa noori niqafarara ani akooqaidanoo.
\q1 Anee aiqama manda oosana maree mariasara fidiaqaa imariananoo.
\q1 
\v 6 Unnufa qimariasa kuridiranaki anee quqannisee mariananoo.
\q1 Faiqí fidikanauqara faqa nikaru qimariasara faqa Yaaweefa fidiaqaamma nimaqaidanoo.
\q1 
\v 7 Ani firaa amuqusirafa marinara qinee kaqi ani naaquqara maaqaki keeqaanaura.
\q1 Qinee kaqi ani naaquqara amaana maqaki keeqafi qeeqa mara maree muqusee qiqoori saunarafi innaaru qianaura.
\q1 
\v 8 Oo Yaawee qini namuqaa moomoo maridaqa. Aneenna aidi mari ainainnara kai qimaqiminaqa auqaa.
\q1 Aneenna aana uqaqifiqainaqa mimau kai fua.
\q1 
\v 9 Qini namuqaauqa ufa sia anoona mari ufana qidaqa.
\q1 Misa kuridiranara kai nididanoo.
\q1 Misa nári ufannai unna qimasee fadameenara foora akusaafanoo faiqí narirafa qumbiqanoo maridanoo.
\q1 
\v 10 Oo Anutu anee misa ufa nimisee aupurarana faqa nimia.
\q1 Misa nariqa manda tipundaarirafa nári kuridirana nimiannoo.
\q1 Misa moomoo aaqarafa marinara faqa misa ani ufa afaqaranara ititammasee qaoo qimarianara misa aiqama aneenna afusaaqari futeeqeeqee nianai aqusaa.
\q1 
\v 11 Miqimmasainaqa aiqama ani saqariki mariasa asasifaranoo.
\q1 Misa aiqama kari ani amooqira idi raaqa.
\q1 Aniara rimariasa ititannimaqaa.
\q1 Anee mariannanara misa kuqaa uqanna asasidaqa.
\q1 
\v 12 Oo Yaawee ani ufamau fimariasa amiqi amiqimmannimaqaa.
\q1 Ani amuqusirafa rakira saqariara foora misa itita nimaqaidanoo.
\c 6
\s1 Ummaara aukuana dadaaqiani fee innaaru.
\q1 
\v 1 Oo Yaawee aneenna aanooqiranaki qari sia qiniara qaoo qimasee minni qisaa.
\q1 Aneenna aanooqiranannai sia qini aupurarana qimia.
\q1 
\v 2 Oo Yaawee qinee kudoosaapaidaqa anee qiniara qimudaoo qia.
\q1 Qini afeeka taikee marifaqa kudoosaapaida marunnanara anee afeeka qimia.
\q1 
\v 3 Qini marirafa mudukatia firaaqoo ummaaraki maridanoo.
\q1 Oo Yaawee kisaaqasaafee kaqi fifau maridanee sia qini dadaaqidanee.
\q1 
\v 4 Oo Yaawee anee aniree mandaki marunnana uqeereeqeena amiqiraqoo quqaqisaa.
\q1 Aneenna nifauaranakiqari qinee kuqiranaki marunnana dadaaqia.
\q1 
\v 5 Kuqirausa sia aniara iridaqa.
\q1 Sia moo fannoo amana miqoo ani amooqiannoo.
\q1 
\v 6 Qinee firaa ummaaraki maridaqa firaaqoo qimudaani rimarifaqa kudoosaapaidaqa.
\q1 Aiqama eenda qini qaari faiqee marunnanasaa daukunu kai nammariara foora aufidanoo.
\q1 Qiqa daukunu fannoo qini qunusaa aqufidanoo putaa idanoo.
\q1 
\v 7 Qini namuqaa darirari marianara qiki raqee marunanoo firaaqoo qifukaumuqa innooqaifaqa qifu maqarara anuqidaqa.
\q1 
\v 8 Innee manda oosana maree mariasa qinee marunnaqooqari nianasaa fifuaqa.
\q1 Yaaweefa qini qiki raqarana iridanoo.
\q1 
\v 9 Mifa qinee dadaaqianifeera nammeera qunnana irisee qini innaaru qirana akiiqara dadaaqiannoo.
\q1 
\v 10 Qini namuqaauqa manda nisaurirafa tautummasee rafaaqafu nimaqainaqa furufariqa quqasee daraanifara.
\c 7
\s1 Andeeqasee raina nimaqaranara innaaru qirufa.
\q1 
\v 1 Oo Yaawee qini Anutu qinee ititaqimaqaanneera anee iannannai anidaqa.
\q1 Qini qifaqaqa nimarianakinaana qumareeqee amiqirannai kaqinni quqaqisaa.
\q1 
\v 2 Anee sia qini dadaaqinaqa misa kaasau fainiara foora qini daaku mareeqa fifaranoo.
\q1 Qini dadaaqirausa sia maria maqa maaqanaki munusee miqoo misa qini qipata anaqifoora.
\q1 
\v 3 Oo Yaawee qini Anutufa qinee moona mandaikamma amaqasaananoo fee qeeqa qiqoondi oosana siainaki ueeqasaananoo fee.
\q1 
\v 4 Qeeqa namuqaa oosana siainaki aupurarana amiananoo fee qinee mi ainainausa akaqana auqamasaanaqau qini namuqaa qini qifaqasee qumarani.
\q1 
\v 5 Qini qumaraseefau kuqa darusee ateekaateeka masaifaqau kasirana siai ainainnara foora maqasaa qisaifaqau marini.
\q1 
\v 6 Oo Yaawee aneenna aanooqiranakiqari findifua.
\q1 Qini namuqaa aanoo qirana firaanara irinana findifinana ititaqisaa.
\q1 Anee andeeqaranara rimarianafa mariannanara findifinana qini dadaaqia.
\q1 
\v 7 Aiqama fasiqa anaasee aneenna aaqa moodaanaki suqu quqasee innaarunai mirindari rakisi nimaqaa.
\q1 
\v 8 Anee aiqama fasiqa anaasee ufa andeeqannisee marianafa mariananoo.
\q1 Qinee aaqarana siaisa marunnanara anee irimmariananoo.
\q1 Minara anee qini ufa irisee qiniara andeeqara fee qia.
\q1 
\v 9 Anutu anee andeeqarafa maridana maasa irirana faqa maasa qimuqusa faqa aiququmasee qafee marianafa mariananoo.
\q1 Anee manda oosana maree mariasa aaqara oosana taikasainaqa mariaqa.
\q1 Andeeqarausa amiqimasee dadaaqinaqa mapukusee mariaqa.
\q1 
\v 10 Anutufa qini ititaqimaqee marifa maridanoo.
\q1 Mifa narí ufa mau fimariasa dadaaqidanoo.
\q1 
\v 11 Anutufa andeeqara ufasaa rakisirafa maridanoo.
\q1 Aiqama faasaambaasaana narí aanoo qiranara manda oosana maree mariasa qimannimidanoo.
\q1 
\v 12 Misa sia naundura quandaifanoo Anutufa narí rakira faaqaana aaruqiannoo.
\q1 Mifa narí duru fufuseenoo deedaqiannoo.
\q1 
\v 13 Mifa narí kuqa nári maria duru saamuna deedaqammasee maridanoo.
\q1 Narí idaqeemari feefana faqa deedaqammasee maridanoo.
\q1 
\v 14 Manda oosana maree mariasa firaaqoo aaqara oosana auqarara qimiridaqa.
\q1 Misa unna qimasee ummaara oosana uqeerarara tipundaaridaqa.
\q1 
\v 15 Misa akaqausa nimaara ufaana fufusee nári minaki aridaqa.
\q1 
\v 16 Nariqa aaqara oosaa fannoo nariqa aupurarana nimidanoo.
\q1 
\v 17 Qinee Anutuna andeeqaranara irisee dufi dufi qidaqa.
\q1 Qinee firaaqoo uriqarara Anutuna amooqira idi raidaqa.
\c 8
\s1 Anutuna qareenaranara faqa faiqí faiqi mariranara faqa qirufa.
\q1 
\v 1 Oo Yaawee maasa Yaaweefa, ani uriqararana aiqama maa maqa maaqanaki mariasa qafaidaqa.
\q1 Ani amooqirafa innaaruna amana kai ooru maridanoo.
\q1 
\v 2 Miqi qimasee faiqí aanaaqiuqaindi faqa naaqoo iriasa faqa ani amooqira idi raidaqa.
\q1 Anee amiqiranaki marianaqa ani namuqaa sia ani arifaranoo.
\q1 Nariara uriqararausee qimariasa anee misa aana ititannimaqee mariananoo.
\q1 
\v 3 Qinee anee auqu quqaqoonnana quqoona faqa fasauqa faqa innaarunai qafaidaqa.
\q1 
\v 4 Qinee mi ainainausa qafaidaqa maaqi qidaqa,
\q1 Faiqí nanee mariafanee anee misara iridanee.
\q1 Fifau kaqikaa ainaina maridanoo.
\q1 Faiqí faiqí faqa nanainainee mariafanee anee misa rakisidanee.
\q1 
\v 5 Anee Yaaweefa faiqí faiqí mareeqee aiqama ainaina urinnaaqaramasee aneenna ameemaanai
\q2 quqaseenana miqoo qareenarana faqa nuqu firaana faqa qatara foora afisu nimaqaananoo.
\q1 
\v 6 Anee faiqiara aiqama anee auquqoonna ainainausasaa rakisiaqee qimasee qinau.
\q1 Anee aiqama ainaina auquqoonnana uriqararausa mariaqeera quqanau.
\q1 
\v 7 Sipsipauqasaa faqa burimmakauqasaa faqa kaasau aandausaa faqa rakisiaqeera quqanau.
\q1 
\v 8 Innaarunai qaqamaree nimaria ufinisa faqa ooruku nammariki maria noodaannausa faqa minaki
\q2 maria aandausa oosana oosana saa rakisiaqeera faiqí quqanau.
\q1 
\v 9 Oo Yaawee maasa Yaaweefa ani uriqarara afeeka aiqama maqa maaqaki mariasa qafaidaqa.
\c 9
\s1 Anutuna amana amana kai andeeqaranara dufi dufi qirufa.
\q1 
\v 1 Oo Yaawee qinee qeeqa qimuqusa aiqamannoo ani amooqianaura.
\q1 Anee aiqama naaquqara ainaina auqoonnanara qimannimianaura.
\q1 
\v 2 Qinee aniki marunnanara asasidaqa idi raanaura.
\q1 Aiqama afeeka faqaa Anutunara qinee amooqira idi raanaura.
\q1 
\v 3 Qini namuqaa ani qafamasee quandaki fuani qiana saamuriqa kuqidaqa.
\q1 
\v 4 Ani ufa iriranaki kuqaa qirana faqa amana amana kai ira oosanannoo rainee marianafa mariananoo.
\q1 Anee qini ufa irisee qiniara andeeqara fee qimariananoo.
\q1 
\v 5 Anee ani ufa rukiee marusa ufa nimiseenana kafaa manda oosana maree marusa kuridi nimaqasoonaqa naaru naaru sia kaifaa misara irifaranoo.
\q1 
\v 6 Anee maasa namuqaa aiqama taikaseenana misa maqusauqa faqa kuridi nimaqanau.
\q1 Miqimma soonaqa misara kaaqa qaunuqanna saqau.
\q1 Misara irirana faqa kaaqa qaunuqanna seefaranoo.
\q1 
\v 7 Miqiqa mariafanoo Yaaweefa kai naaru naaru karaambaiqa maridanoo.
\q1 Narí ufa irira qaari deedaqamma quqaseenoo ufa andeeqa nimaqaranara rakisidanoo.
\q1 
\v 8 Mifa narí andeeqaranannai maa maqa maaqanasaa mariasa rakisinimaqaidanoo.
\q1 Mifa aiqama maqannaasa amana amana kai ufa irinnimaqaidanoo.
\q1 
\v 9 Oorudupirausee qimannimaqee mariasa Yaaweefa misa afeeka ititara maqusara foora maridanoo.
\q1 Ummaara aukuana kukeeqee maria maqusafa Yaaweefa maridanoo.
\q1 
\v 10 Oo Yaawee ani oosanara irimariasa ani saqarikifaranoo.
\q1 Anee sia anee iannannai ani mariasa moona minnisaanafa mariananoo.
\q1 
\v 11 Sioonna maqusai marida rakisinnimaqee mari Yaaweena amooqira idirama amaqaaqa.
\q1 Mifa auqoo ainainnara aiqama maqannaasa kooroommasee qimannimiaqa.
\q1 
\v 12 Anutufa aupuraranaki mariasara sia qaunidanoo iridanoo.
\q1 Mifa sia misa nammeera qiranara qaunidanoo.
\q1 Mifa misa mandaikamma nimaqee mariasa aupurarana nimidanoo.
\q1 
\v 13 Oo Yaawee qini namuqaauqa ummaara qimimariana qafamasee qiniara qimudaoo qia.
\q1 Oo Yaawee qini kuqiranakinaana ititaqisaa.
\q1 
\v 14 Miqimmasainaqa qinee Yeerusaree maqannaa fasiqa anaasee nifusaa kikiqammafi ani amooqimarunnanara qimannimianaura.
\q1 Anee qini asumu mariranaki quqaqisaannanara asasianaura.
\q1 
\v 15 Anutunara sia iri mariasa maasa qimaara madika indufusee nári kai minaki aqufidaqa.
\q1 Misa maasa qimaara ufaana fufusee nári kai minaki aridaqa.
\q1 
\v 16 Yaaweefa andeeqasee ufa raina nimaqaranannai nariara kooroo idanoo.
\q1 Manda oosana maree mariasa nári auqee maria ainainafa quandakinoo ufaanara foora nariqa qumaraidanoo.
\q1 
\v 17 Aiqama manda oosana maraqanuasa faqa aiqama Anutuna ufa minnisee nári irirana mau nimariasa faqa kuqirafa misa maqusara foora maridanoo.
\q1 
\v 18 Kudi fasiqa aanaaseera Anutufa sia aiqama kari qaunuannoo.
\q1 Ainaina siaisa sia kisaaqasaa rafaaqafu nimaqaqaifaqa marifaranoo.
\q1 
\v 19 Oo Yaawee anee findifua sia faiqí faiqi ani afusaa aanoo qimasee ani ufa rukiaannoo.
\q1 Ani ufa sia irimariasa aneenna afusaa quqasee ufa nimia.
\q1 
\v 20 Oo Yaawee anee misa rufiarana nimia.
\q1 Aiqama maqannaasa nariara faiqí faiqi kai maridee qimasee iriaqa.
\c 10
\s1 Andeeqara oosanara innaaru qirufa.
\q1 
\v 1 Oo Yaawee anee nanaree nianai maridanee.
\q1 Maasa qummaaraki marunana anee nanaree kukeeqana maridanee.
\q1 
\v 2 Aaqee mariasa misa nári nimoo namoo qidaqa ainaina siaisa narunnindaqaa idaqa.
\q1 Misa kai indufuqaa dikaandanaki ainaia siaisa aqufidaqa.
\q1 
\v 3 Manda oosana maree mariasa nariqa manda oosana maree marianara nári nimoo naamoo qidaqa.
\q1 Ainainara kaaqa rimarifa Yaaweena aquraraseenoo mina ameesa ubeekama amaqaidanoo.
\q1 
\v 4 Manda oosana maree mariasa sia Yaaweenara qeerairidaqa.
\q1 Nári nasuriranakiqari Anutunara sia anoonee qidaqa.
\q1 
\v 5 Manda oosana auqee mariasa aiqama ainaina auqaafa anoona kambiqaidanoo.
\q1 Misa sia Anutuna iriranara iridaqa.
\q1 Misa nári namuqaa uqmairaaqmairamma nimaqaidaqa.
\q1 
\v 6 Misa náriara maaqi qidaqa.
\q1 Maasa sia aqufuanauree qidaqa.
\q1 Sia maasa moo ummaaraki marianauree qidaqa.
\q1 
\v 7 Misa ufa qirafa niqurara ufa faqa unna ufa faqa naaquqara ufa faqa kai umbiqanoo maridanoo.
\q1 Misa kai kaqi fidiaqaa ira manda ufauqa qidaqa.
\q1 
\v 8 Misa aiqama maqusakiaqa kukeeaqa maridaqa andeeqara fasiqauqa kuqa narirara nimaarusidaqa.
\q1 Misa afeeka siaisa nimaara kukeeqaidaqa.
\q1 
\v 9 Misa kaasau fainiara foora kukeeaqa maridaqa rakisidaqa.
\q1 Misa miqimandee ainaina siaisara rakisidaqa.
\q1 Misa ufaana fufuqaanaki arufuafaqa oonu rarisamammaree fidaqa.
\q1 
\v 10 Misasaaroo qirausa sia marisa narusaafaqa maqasaa
\q2 aqufuafaqa nikunnai radamuqaafaqara foora maridaqa.
\q1 
\v 11 Manda oosana maree mariasa maaqi qimasee nariqakai qidaqa.
\q1 Anutufa qini manda oosanara fifau ainainee qidanoo.
\q1 Mifa afu tautasee sia qini qiqafaannoo fee qidaqa.
\q1 
\v 12 Oo Yaawee, miqira manda oosana maree mariasa aupurarana nimia.
\q1 Kafaa aupuraranaki mariasara sia qaunua, misa faqa dadaaqia.
\q1 
\v 13 Manda oosana maree mariasa naqimmasee fee Anutunara unnaqimasee maaqi qidee.
\q1 Mifa sia maasa aupurana qimiannoo fee qidee.
\q1 
\v 14 Oo Anutu anee niqafee mariananoo, anee ummaaraki mariasa faqa aupuraranaki mariasa
\q2 faqa niqafaidana aiqama kari dadaaqirara deedaqi marianafa mariananoo.
\q1 Misasaaroo qirausa siaisa aniki nári nifaaqa quqaidaqa.
\q1 Anee ooqaindari sarau imariasa dadaaqi marianafa mariananoo.
\q1 
\v 15 Manda oosana maree mariasa faqa aaqee mariasa faqa misa afeeka qumaree raqurusaa.
\q1 Anee misa manda oosana auqaana akiiqara aupurarana niminaqa sia kaifaa miqiaqa.
\q1 
\v 16 Yaaweefa naaru naaru uriqarara Karaambaiqa maridanoo.
\q1 Aiqama unna anutusa nimooqi mariasa mina maqa maaqakiqari taikafifaranoo.
\q1 
\v 17 Oo Yaawee anee oorudupirausa innaaru irinnaranoo.
\q1 Anee misa paasoosirana niminnaranoo.
\q1 
\v 18 Anee fiaiqi faiqi faqa rafaaqafu nimmaqee mariasa faqa iki raqarana irinnaranoo.
\q1 Anee misa ufa irinnisainna kari misa dadaaqinnaranoo.
\q1 Miqinaqa maqasaa fasiqa rufiarana firaana nimimariasa sia kafaa miqifaranoo.
\c 11
\s1 Yaaweenaki afaaqa uqara ufa.
\q1 
\v 1 Qinee Yaaweena saqarikiananoo mifa qini ititaqimaqaannoo.
\q1 Anee nana furufaree inanee qiniara ufiniara foora qaqamaree aaqanai ooru fuannee qidanee.
\q1 
\v 2 Misa maaqi qimasee kaifaa unna qimasee qima qimidaqa.
\q1 Manda oosana maree mariasa nári duru rambaqa fufusee, dindaramasee andeeqarausa qumee kukeeqaindari nariraree qidaqa.
\q1 
\v 3 Maa maqanasaa aiqama maasa dadaaqi maria ainainausa mandaikinaqa andeeqara fasiqauqa naqaa fee ifaree.
\q1 
\v 4 Yaaweefa narí naaquqara amaana maqaki maridanoo, mina ufirira qaari innaarunai ufiqinoo marifanoo minasaa maridanoo.
\q1 Miqooqari mina afu fannoo aiqama fasiqa anaasee aiqamatinai nindafaidanoo.
\q1 Misa auqee marianara iridanoo.
\q1 
\v 5 Yaaweefa andeeqee mariasa faqa aaqee mariasa faqa amana amana kai niuqidanoo.
\q1 Sia mina sandufa afaqee mariasara Yaaweefa narí amuqusa aiqamannoo misara fidiaqaammidanoo.
\q1 
\v 6 Mandoosana maree mariasa Yaaweefa ida qauni
\q1 namufaqa idauru fasafasi marina namufaqa nammariara foora teeqimma nimaqaidanoo.
\q1 Mifa ididimari ufainannoo misa aupurarana nimidanoo.
\q1 
\v 7 Yaaweefa andeeqarafa maridanoo.
\q1 Mifa andeeqaranara aididanoo.
\q1 Miandeeqara oosanna maree mariasa misa Anutuna oorisaa marifaranoo.
\c 12
\s1 Dadaaqiani fee innaaru.
\q1 
\v 1 Oo Yaawee maasa dadaaqia, sia uqanna moodaa andeeqara fasiqa maridanoo.
\q1 Kuqaa kai qimari fasiqanara randeenana sia paqurinnaranoo.
\q1 
\v 2 Misa nári niqoonausara unnufa kai qiqanuasa maridaqa.
\q1 Misa fadameena akusee nikaru qidaqa.
\q1 
\v 3 Oo Yaawee anee fadameena akira ufa qimaria nifauruna ititannisaa.
\q1 Nári nimooqida nári nuqu uqeeree maria nifauruna faqa ititannisaa.
\q1 
\v 4 Misa maaqi qidaqa maasa qeeqa ufannai maasa didimari ainaina maraidaqee qidaqa.
\q1 Maasa didimari ufana kaqi qianaura, sia moo fannoo maasa doo ititaannoo fee qidaqa.
\q1 
\v 5 Yaaweefa maaqi qidanoo. Kudi fasiqauqa rafaaqafi marianara faqa aupurarana nimiafaqa
\q2 anaadannada qimarianara faqa qinee maqee aniree misa dadaaqianauree qidanoo.
\q1 Qinee anireeqa nifaaqa quqasee mariranara rakisimariana nimianaura.
\q1 
\v 6 Yaaweena qima afeekaikira ufasaa nifaaqa quqee mariafa maridanoo.
\q1 Mi ufafa amiqira siruaa qisauku dinni taikasee dinni
\q2 ani qaara marasee 7 kari tisirisiri maqaafara foora kaaqa amiqirafa maridanoo.
\q1 
\v 7 Oo Yaawee anee maqee maqee maasa ititaqisaa.
\q1 Mi manda fasiqausasaa ititasainaqa sia maasa mandaikamma qimaqaaqa.
\q1 
\v 8 Manda oosana maree mariasa aiqamatinai maridaqa.
\q1 Aiqama fasiqa anaasee mandoosanara amiqira ainainee qimasaida asasidaqa.
\c 13
\s1 Dadaaqiani fee innaaru.
\q1 
\v 1 Oo Yaawee kisaaqasaa fee anee qiniara qauninnaree.
\q1 Naaruara naaruara miqi fee imarinnaree.
\q1 Anee kisaaqasaa fee qini qifusaaqari kukeeqana marinnaree.
\q1 
\v 2 Kisaaqasaa fee qinee aupurarana uaqee maridaqee.
\q2 Daunduraki rairai qimari umaaranara oonu mafi irianauree.
\q1 Aiqama eendaki faasaana kisaaqasaa fee qini aiaaee qirafa mariannoo fee.
\q1 Kisaaqasaa fee qinee namuqaa nimeemaanai marianuree.
\q1 
\v 3 Oo Yaawee qini Anutu anee amiqimasee qini qiqafamasee qini ufa anoona qimaqimia.
\q1 Anee kafaa qini afeeka qiminaqa sia kuqua.
\q1 
\v 4 Oo Yaawee anee sia qini namuqaara qinaqa qiniara mina doo rafaaqafusee fee qiaqa.
\q1 Anee sia qini namuqaara qinaqa qinee saamuruannanara nasuriaqa.
\q1 
\v 5 Anee maqee maqee qiniara aidimariannanasaa qinee mundidaqa.
\q1 Anee qini asumu marainnanara qinee asasianaura.
\q1 
\v 6 Oo Yaawee anee qini amiqi amiqimma qimaqoonnanara ani amooqira idi raanaura.
\c 14
\s1 Faiqí faiqi mandoosanara qirufa.
\q1 
\v 1 Furufari mariasa nári nimuqusakiqari maaqi qidaqa sia Anutufa maridanoo fee qidaqa.
\q1 Miqi qimariasa furufarira oosana maraidaqa.
\q1 Misa kaaqa aaqara oosana uqanna auqee mariasa maridaqa.
\q1 Sia moo fannoo andeeqara oosana maraidanoo.
\q1 
\v 2 Yaaweefa innaarunaindari maa maqanasaa faiqí faiqi mariasa niuqidanoo.
\q1 Mifa irirana faqaasara randaifaqa sia maridaqa.
\q1 Akaqausa qini Anutusara inaaru qidafee qimasee randaidaqa.
\q1 
\v 3 Aiqamausa quandaki kaqi runna fidaqa.
\q1 Misoo maasoo amana amana kai mandaiki marunausa maridaqa.
\q1 Sia moo fannoo andeeqarausa maridaqa. Sia uqanna.
\q1 
\v 4 Anutufa maaqi qimasee iraidanoo, misa sia fee iridafee.
\q1 Aiqama maa aaqara oosanna maree mariasa irirana siaisee maridee.
\q1 Misa qini faiqí anaasee feemuara foora nama taikaidaqa.
\q1 Misa sia qiniara aiqama kari innaaru qimariasa maridaqa.
\q1 
\v 5 Miqi mariasa firaaqoo rufiee faranoo.
\q1 Anutufa narí ufamau fimariasa faqa maridanoo dadaaqidanoo.
\q1 
\v 6 Narí mara maree qumimarifa moo ainaina auqarara
\q2 oonu mafi irifaqa aaqeemariasa itita amaqaafanoo Yaaweefa mina dadaaqidanoo.
\q1 
\v 7 Qinee maaqi qimasee firaaqoo innaaru qidaqa,
\q2 Isaraee maqannaasa dadaaqirafa Sioonna maqusakiqari anianifee qidaqa.
\q1 Yaaweefa Isaraee maqannaasa nári maqa maaqa
\q2 faqa qumiasana faqa kafa rairaamma saina misa firaaqoo asasifaranoo.
\c 15
\s1 Anutuna aidi mari marirafa.
\q1 
\v 1 Oo Yaawee, yafee ani amaana maqaki keeqaannoo fee.
\q1 Yafee Sioonna ani naaquqara aaqanasaa marida innaaru qiannoo fee.
\q1 
\v 2 Aiqama ainainaki ani ufa mau fimariasa faqa
\q1 andeeqara oosana auqee mariasa faqa nári nimuqusa ookiqari anoona ufa kai qimariasa
\q2 faqa ani naaquqara aaqanasaa marida innaaru qifaranoo.
\q1 
\v 3 Sia aqoonnana manda auqu amifa faqa sia narí
\q2 aqoondi mandaikamma amaqaifa faqa sia nári
\q2 niqoonausara munuqi miniqiasa faqa mi
\q2 naaquqara aaqannasaa marida innaaru qifaranoo.
\q1 
\v 4 Anutufa ameesuqu nimaqaqaisara andeeqarausa faqa misara fidiaqaa idaqa.
\q1 Yaweena ufa mau fimariasara uriqararausee qidaqa.
\q2 Moo fannoo narí amana aiqamasee moo ainaina auqararee qimasaifanoo mi faasaanna moo
\q1 ummaara kambiqaifanoo afai riqiseenoo oonu
\q2 mi ainainna auqeenoo narí qima afeekaikira ufa taikaidanoo.
\q1 
\v 5 Faiqí moo fannoo narí ufaasu munnimma nimiseenoo
\q2 aabaa munnimma siaina naríndi amana kai maree
\q1 marifa faqa, aaqarana siai fasiqana mara ufaki
\q2 quqaanifee qimasee munnimma amiafanoo
\q1 qeerairi mari fasiqafa faqa ani naaquqara aaqanasaa marifaranoo.
\q1 Mi aiqama ainainausa auqee maria fasiqausa misa naaruara mapukusee marifaranoo.
\c 16
\s1 Afaaqa uqasee mariranara innaaru qirufa.
\q1 
\v 1 Qinee ani saqariki marunnanara ititaqimaqa.
\q1 Oo Anutu, anee qini ititaqimaqaa.
\q1 
\v 2 Qinee Yaaweena maaqi qimasee qimamiqa. Anee qini Yaaweefa mariananoo.
\q1 Aiqama ainaina anee iannannaindari kai qiniki anidanoo.
\q1 
\v 3 Faiqí anaasee Yaaweenaki mapukusee mariasa kaaqa andeeqarausa maridaqa.
\q1 Qini firaa irirafa misa faqa marirara dididanoo.
\q1 
\v 4 Unna anutusa iannai sandee mariasa oosana oosana ummaara nári nifaaqai mara quqaidaqa.
\q1 Qinee sia misa faqa aandau tatufirana suqaanaura.
\q1 Qinee sia misa faqa misa unnaqira anutuna amooqianaura.
\q1 
\v 5 Oo Yaawee, anee kai qini aiqama ainainara foora mariananoo.
\q1 Qini didimari aiqama ainainna anee qimimariananoo.
\q1 Qini marirafa ani asaukuki maridanoo.
\q1 
\v 6 Anee qimimarianna ainainausa amiqirafa kai maridanoo.
\q1 Mi ainainausa aiqama kaaqa amiqirafa kai maridanoo.
\q1 
\v 7 Yaweefa qini aana muquni marinara mina amooqidaqa.
\q1 Eendaki qini daakirafa daakapaidanoo.
\q1 
\v 8 Qinee aiqama kari Yaaweena afusaa marunnanara iridaqa.
\q1 Mifa qini faqa marinara sia moo ainaina fannoo qini kasi kasimma qimaqaannoo.
\q1 
\v 9 Minara qinee dufi dufi qidaqa asasidaqa.
\q1 Qinee kaaqa amiqiranaki marunnanara miqidaqa.
\q1 
\v 10 Anee kuqira afeeka ameemaanaindaraana ititaqimaqaannanara miqidaqa.
\q1 Anee aneenna aidimarina sia minnisainanoo mifa kuqufinoo putaaiannoo.
\q1 
\v 11 Anee kisaaqasaa maa maqanasaa marira aana qini uqafiqeennaranoo.
\q1 Ani afusaa marunafa asasirana qumbiqa qimaqaidanoo.
\q1 Mifa naaru naaru marira asasirana qimidanoo.
\c 17
\s1 Aaqarana siai fasiqana innaaru.
\q1 
\v 1 Oo Yaawee andeeqaranara innaaru qimarunnana iria.
\q1 Qinee dadaaqianneera innaaru qimarunnana faqa iria.
\q1 Qini kuqaa qira innaaru iria.
\q1 
\v 2 Anee andeeqaranara irimariannanara qini qifairi mariana dadaaqia.
\q1 
\v 3 Yaawee anee qini qimuqusara irimmariananoo.
\q1 Anee eendaki qinee unnannai anireenana qini
\q2 qimanammasee qafaananoo sia manda irirafa qiniki maridanoo.
\q1 
\v 4 Qinee sia akaqausa naannareeqa manda ufa qidaqa.
\q1 Qinee ani naakapara ufa qaindusidaqa sia faiqi narimariasa fimaria aatata fidaqa.
\q1 
\v 5 Qini qiku fannoo ani aatata kai fida sia munuree miniree unausa maridaqa.
\q1 
\v 6 Oo Anutu anee qini inaaru irimariannanara qinee aniara innaaru qidaqa.
\q1 Minara anee aneenna aaqoo rammatinimambi qini innaaru qirana iria.
\q1 
\v 7 Oo Anutu aneenna firaa amuqusirana maasa uqaqifiqaseenana anee maasa asumu maraqisaa.
\q1 Maasa ani mandaaqaqa maridaqa sia namuqaa dariratinai marianaura.
\q1 
\v 8 Anee aneenna afu rakisianandee kai masee qini faqa rakisia.
\q1 Anee aneenna aumooki quqaseenana rakisi qimaqainaqa qini namuqaa sia daruaqa.
\q1 
\v 9 Qini kuqa darirara imariasa qini fiqu fiqu iqa maridaqa.
\q1 
\v 10 Misa qimudaoo qirana siaisa, nári nimoo naamoo kai qimariasa maridaqa.
\q1 
\v 11 Misa qini itita qimaqaqaafaqa qinee firannai anirannaira idaqa.
\q1 Misa qini qumara rudammiqi qaqeeidaqa rakisidaqa.
\q1 
\v 12 Misa kaasau fainiara foora qini qimaara usidaqa.
\q1 Qini qumarasee rakeekaa irara miqiqa maridaqa.
\q1 
\v 13 Oo Yaawee anireenana qini namuqaa noorisaa oonureenana misa narusee urinnaaqaraa.
\q1 Aneenna rakira paipanannai mandoosana maree mariasa narusee misa nisaukukinaana qini maraa.
\q1 
\v 14 Oo Yaawee maa maqanasaaqaraa aiqama ainaina náriara kai maree mariasa nisaukukinaana qini mara qisaa.
\q1 Anee misa narirara nimaara usuqaanna samu misa narua.
\q1 Naridana mina atisamu kaqi marinana misa faiqi
\q2 namu faqa ninaiqimara faqa kasooqaqee kambiqaifana misa faqa narua.
\q1 
\v 15 Qinee sia aaqara ainaina auqaunnanara qinee ani qafaanaura.
\q1 Qinee faiqaqee iinaqa findi fuananoo ani afusaa marira oosana fannoo qini asasirana qumbiqa qimiannoo.
\c 18
\s1 Rakirana Uriaaqarara idi Dafidifa ranau.
\q1 
\v 1 Anee qini itita qimaqee marianafa mariannanara ani Yaaweenara firaaqoo dididanoo.
\q1 
\v 2 Yaaweefa qini itita qimaqee marifa maridanoo.
\q1 Mifa qini afeeka faandaamurara foora maridanoo.
\q1 Qini Anutufa qini itita qimaqee marifa maridanoo.
\q1 Minaki marunnanara asumu maridaqa.
\q1 Mifa qini rakira saqariara foora maridanoo.
\q1 Mifa qinisaa ititaseenoo qini asumu mara quqaqisaidanoo.
\q1 
\v 3 Qinee Yaaweenara innaaru qunanoo qini
\q2 namuqaauqa darirari mariana kinaana asumu mara quqaqiseenoo.
\q1 Minara Yaaweena amooqiaqa.
\q1 
\v 4 Manda kuqirafa qini fiqu fiqu inoo marifanoo,
\q2 darirafa ooruku nammari amakauriara foora inoo qini rafaaqafidanoo.
\q1 
\v 5 Manda kuqirafa qini fiqu fiqu inoo marifanoo, faiqí
\q2 madika fannoo ufaanara foora qini qimaara fufinoo maridanoo.
\q1 
\v 6 Qeeqa ummaarakiqari Yaaweena aareeqa.
\q1 Qinee qeeqa Anutuna dadaaqianifeera aareeqa.
\q1 Narí amaana maqakiqari qini nammeera qirana irinoo.
\q1 Qinee dadaaqianifeera nammeera qiqa.
\q1 
\v 7 Anutufa qini namuqaara aranaqainara maqa kasifanoo aaqanauqa doori doorifanoo firaa ooniuqa faqa kasi kasidanoo.
\q1 
\v 8 Ida muna fannoo Yaaweena aikaamaraindari anifanoo aiqama ainaina qama taikara ida faqa ida qauni namufaqa mina ookiqari anidanoo.
\q1 
\v 9 Yaaweefa innaaruna rakeemmafufanoo quminau.
\q1 Mina aiku ameemaanai asukuna arira oonnamu marinau.
\q1 
\v 10 Yaaweefa aqoosa faqaa ainainasaara foora ooqu marifinoo qaqamaree ufaimau quminau.
\q1 
\v 11 Mifa asukunannoo narí kukeeqasoofanoo, amatooki oonnamu aaku suqirafa mina fiqu fiqu inoo marinau.
\q1 
\v 12 Pupusamu faqa idauru fasafasirafa faqa mina
\q2 oorinni aakuasaa iranakiqari qumureenoo asukuna arira oonnamu rakeeinau.
\q1 
\v 13 Yaaweefa innaarunaindari innaarunai qiara foora qufaqa kaaqa uriqarara Anutuna ufa iriqau.
\q1 
\v 14 Yaaweefa miqi qidanoo narí feefauqa qumaree aquseenoo namuqaa narufaqa daraaniqau.
\q1 Mina aakuasaa fannoo feefara foora aqusee narufaqa quqasee sandaqau.
\q1 
\v 15 Anee aneenna namuqaauqa niqiseenana aranaqoofana rairai qimannimaqee marinau.
\q1 Miqunanoo ooruku nammari ameemaanaindaraa maqa koorooinau.
\q1 Maqa ameemaanaindaraa ooniuqa faqa koorooinau.
\q1 
\v 16 Yaaweefa innaarunaindari qini nammari farumakinaanara foora qisauku qumaree uqeera quqanau.
\q1 
\v 17 Mifa qini afeeka namuqaauqa nisaukukinaana mara kaqinni quqaqiseenoo, qiniara fidiaqaa imariasa
\q2 qini uridaaqarara afeeka faqaasa nisaukukinaana faqa mara kaqinni quqaqisanau.
\q1 
\v 18 Qinee ummaaraki mariafanaqa qini namuqaauqa qini darirariqau.
\q1 Miqufanoo Yaaweefa qini ititaqimaqanau.
\q1 
\v 19 Mifa qiniara asasi marunara qini manda ummaarakinaana dadaaqamma qisanau.
\q1 
\v 20 Qinee andeeqee marunnana akiiqara amiqi amiqimma qimaqeenoo.
\q1 Qiniki sia aaqarafa marinara miqimma qimaqaidanoo.
\q1 
\v 21 Qinee Yaaweena sandufamau fimarunausa maridaqa.
\q1 Sia qeeqa Anutuna qimeesa uqusee mandoosana maraidaqa.
\q1 
\v 22 Qinee mina aiqama sandufamau fimarunausa maridaqa.
\q1 Qinee sia mina naamuaqira ufa rukiqaunausa maridaqa.
\q1 
\v 23 Qinee aaqarana siaisa marunnanara mifa iridanoo.
\q1 Qinee kaqi runna fuanoora qeeqa mariranasaa rakisidaqa.
\q1 
\v 24 Qinee miqunnana akiiqara faqa andeeqara oosana maraunnanara faqa mifa amiqimma qimaqaidanoo.
\q1 Qinee aaqarana siaisa marunnanara miqimma qimaqaidanoo.
\q1 
\v 25 Oo Yaawee aniki mapukusee mariasa anee misa mapukunnimaqee mariananoo.
\q1 Kaaqa andeeqee mariasa anee amiqi amiqimma nimaqee mariananoo.
\q1 
\v 26 Anee kaaqa anukarausa andeeqa nimaqee mariananoo.
\q1 Mandoosana maree mariasa mandaikamma nimaqee mariananoo.
\q1 
\v 27 Nári mara maree qumi mariasa anee asumu maree mariananoo.
\q1 Nári nuqu uqeeree mariasa anee mara maree qumimariananoo.
\q1 
\v 28 Oo Yaawee anee kaaqa qarana qimiananoo asukuna rakeemma qisaidanoo.
\q1 
\v 29 Anee qini afeeka qimianaqa qeeqa namuqaauqa naru nindaqaaqa idaqa.
\q1 Miqimmaseeqa misa afeeka faandaamura aafeeqaramaki aqufiqa naru nindaqaaqa idaqa.
\q1 
\v 30 Mi Anutuna oosana fannoo andeeqanoo maridanoo.
\q1 Mina ufasaa faiqí mundimaria ufafa maridanoo.
\q1 Mifa narí mandaaqee mariasa rakira saqariara foora maridanoo, ititannimaqaidanoo.
\q1 
\v 31 Yaaweefa kai Anutufa maridanoo.
\q1 Anutufa kai maasa faandaamura maridanoo.
\q1 
\v 32 Mi Anutufa kai qini afeeka qimiseenoo, rakisiqimaqee marifaqa qifaaqa quqasee aana nidaqa.
\q1 
\v 33 Mifa qini qiku afaidama saifaqa kaasau aandaura foora sandaidaqa.
\q1 Qinee aaqanauqakiaqa nimarunanoo mifa qini rakisi qimaqaidanoo.
\q1 
\v 34 Mifa qini rakira oosana uqaqifiqasaifaqa qinee afeeka duru uqanna rakisidaqa.
\q1 
\v 35 Oo Yaawee anee qini itita qimaqaseenana asumu mara quqaqisaananoo.
\q1 Ani rakisi qimaqarafa qini duqu uqeereenoo.
\q1 Ani afeeka fannoo qini ititaqimaqaseenoo asumu marirana qiminoo.
\q1 
\v 36 Anee qini aana amiqimmasaanaqa sandaidaqa sia
\q2 qiku qamaki saamurunaqa namuqaa qini qumareea.
\q1 
\v 37 Qinee qeeqa namuqaa sia minniseeqa nifaqaqa
\q2 fifiifaqa oonu qumarasee naruseeqa kai seeqa.
\q1 
\v 38 Qinee oonu misa naru quqasaunaqa qini qikuki aqufiqa sia findifirana amanaikidaqa.
\q1 
\v 39 Oo Anutu anee rakira afeeka qini qimiseenana qeeqa namuqaa rakiranaki urinaaqarara afeeka qimianaqa misa urinnaaqareeqa.
\q1 
\v 40 Anee qini namuqaara qianaqa misa qini daaqu rufiasee sandeea.
\q1 Sandaafaqa akaqausa qiniara fidiaqaa imariasa naru taikeeqa.
\q1 
\v 41 Misa akaqausara dadaaqiaqeera faaqaruafaqa sia dadaaqirausa maridaqa sia dadaaqia.
\q1 Misa Yaaweenara faqa dadaaqianifeera aaraafanoo sia misa innaaru qirana irinoo.
\q1 
\v 42 Qinee misa radamusaunaqa misa kookoommaika mafuafanoo ufai fannoo misa fuaqa aqinoo.
\q1 Misa aatataqaraa doonara foora mariafaqa qinee misasaa qiku reeqa.
\q1 
\v 43 Anee qini aanoo qimaqimaqee mariasa nisaukukinaana
\q2 asumu mara quqaqiseenana moomoo maqannaasa rakisirausaikamma qisaananoo.
\q1 Miqimma saanaqa qinee sia irunna fasiqa aanaaseesa qini qimeemaanai maridaqa.
\q1 
\v 44 Anaamuru qini qikuki niqoori saunu araidaqa
\q1 Misa qini ufa irisee qini ufamau fidaqa.
\q1 
\v 45 Misa afeeka taikafifaqa nariqa afeeka faandaamura minniseeqa naindiri raifaqa qinee unannai anidaqa.
\q1 
\v 46 Yaaweefa kaqi marifa maridanoo.
\q1 Qini ititaqimaqee marina amooqiaqa.
\q1 Qini namuqaa nisaukukinaana asumu mara quqee mari Anutuna uriqararanara kooroo iaqa.
\q1 
\v 47 Mifa qini namuqaauqa urinnaaqarara afeeka qiminoo.
\q1 Mifa moomoo maqannaasa qini qimeemaanai mara quqeenoo.
\q1 
\v 48 Miqimmaseenoo qini namuqaa nisaukukinaana asumu mara quqaqiseenoo.
\q1 Oo Yaawee, anee qini namuqaa urinnaaqarara afeeka qimiseenana faiqí kuqa narimariasasaa ititaqisaananoo.
\q1 
\v 49 Miqiannanara qinee moomoo maqannaasa qambaanaindari ani amooqidaqa.
\q1 Qinee ani amooqira idi raidaqa.
\q1 
\v 50 Anee qini Dafidisa utaaqama qaanausa aneenna sia taikaaninna amuqusirana qinisaa faqa naaru
\q2 naaru qinisaa ani aruakinausasaa faqa quqaananoo.
\q1 Minara Anutufa rakira afeeka qini Dafidisasaa quqeenoo.
\c 19
\s1 Oosana aroonaki Anutufa auqu quqoo ainainafa mina qareenarana koorooidanoo.
\q1 
\v 1 Innaaruna fannoo Anutuna qareenaranara firaaqoo koorooidanoo.
\q1 Innaaruna fannoo kaifaa Anutufa auqoo ainainausara kooroo idanoo.
\q1 
\v 2 Maqee faasaana fannoo Anutuna areenaranara duna faasaana qimamidanoo.
\q1 Eendirafa miqikai qimasee moo eendirana qimamidanoo.
\q1 
\v 3 Iaqarafa faqa eendirafa faqa sia noo mari faqa sia ufa qidaqa.
\q1 Minara maasa misa ufa qirana sia iridaqa.
\q1 
\v 4 Miqinoo marifaqa aiqama maqa maaqaindari misa Anutunara koorooimariana qafaidaqa.
\q1 Maa maqana ati munu taikee mini taikee irannaindari misa ufa iridaqa.
\q1 Innaaruna Yaaweefa uiqaana maaqara foora usakasaifanoo suani minaki maridanoo.
\q1 
\v 5 Suani fannoo minakiqari narí fuka anaasee amundara anaasee mararara foora asasidanoo suani qaidanoo.
\q1 Mifa sandaranaki amani mariasara foora sandarara deedaqidanoo.
\q1 
\v 6 Suani fannoo innaaruna atisaaqari urureenoo fifiifanoo meeqai dinni keeqaidanoo.
\q1 Sia moo ainaina fannoo mina ididiranara rufiasee kukeeqaanoo.
\s1 Yaaweena sandufara qidanoo.
\q1 
\v 7 Yaaweena sanda ufa andeeqarafa uqanna maridanoo.
\q1 Mifa fuka afeeka nimidanoo.
\q1 Yaaweena naakaparufa minasaa mundi mariafa maridanoo.
\q1 Mifa irirana siaisa irirana nimidanoo.
\q1 
\v 8 Yaaweena sandufa andeeqarafa marifaqa mi ufamau fimariasa asasidaqa.
\q1 Yaaweena naamuaqira ufa fannoo amana amana kai
\q2 andeeqa nimaqaseenoo maasa qitikuraki irirana moo faqa moo faqa qimidanoo.
\q1 
\v 9 Yaaweena oorinni nisaurusee madoodoonnara oosana fannoo kaaqa anukarafa maridanoo, naaru naaru kaqi kai mariannoo.
\q1 Yaaweena ufa irirafa andeeqarafa marifanoo aiqama kari amana amana kai rainannimaqaidanoo.
\q1 
\v 10 Yaaweena ufa irirafa amiqira koora uqanna uriaaqararafa maridanoo.
\q1 Mina adiafaairafa ookasaasa anoona adiafaairana faqa arusee uriaaqaranoo maridanoo.
\q1 
\v 11 Mi ufausa qini Dafidisa ani ainainira faiqi irirana qimidanoo.
\q1 Qinee mi ufamau fimarunnana akiiqara anee Yaaweefa amiqi amiqimma qimaqaananoo.
\q1 
\v 12 Sia moo fannoo narí aaqara oosanara iridanoo.
\q1 Oo Yaawee, qinee kukeeqara aaqaranaki marunnana mara kaqinni quqaqisaa.
\q1 
\v 13 Qinee iridaqa faqa aaqee marunnanasaa ititaqisaa.
\q1 Sia mi aaqarafa qini rakisi qimaqaani.
\q1 Miqimma qisainaqa andeeqafuananoo mandoosana fannoo sia rumba qimaqaani.
\q1 
\v 14 Oo Yaawee, anee qini afeeka kukeeqara maqusa faqa qini asumu maree marianafa faqa mariananoo.
\q1 Amanee qini ufara faqa qini iriranara faqa amiqira fee qimasee eedoo qia.
\c 20
\s1 Rakiranaki uriqarara innaaru.
\q1 
\v 1 Anee ummaaraki maridana Yaaweenara innaaru qinanoo ani dadaaqiani.
\q1 Yakooboona Anutufa ani itita amaqaani.
\q1 
\v 2 Mifa Sioonna aaqanasaa narí naaquqara amaana maqakiqari ani dadaaqiani.
\q1 
\v 3 Mifa anee aminna ainainara eedoo qimasee ani aiqama aandau tatufiranara faqa asasiani.
\q1 
\v 4 Anutufa ani aidimari ainainna amiani.
\q1 Anee oonu mafi irinna ainainafa anoona kambiqaani.
\q1 
\v 5 Anee rakiranaki urinnaaqaraannanara asasida faaqa ruanaura.
\q1 Anee rakiranaki urinnaaqaraannanara maasa qeeqa Anutuna idi raidaqa amooqianaura.
\q1 Anee aiqama ainainara irainnana Yaaweefa iriani.
\q1 
\v 6 Doo maqee qinee iridaqa Yaaweefa rakirana
\q2 uriqarara afeeka narí utaaqamaqai karaambaiqana qini Dafidisa qiminoo.
\q1 Mifa narí amiqira maqusa innaarunaindari qini innaaru qirana irinoo.
\q1 Yaaweena afeeka fannoo firaa rakiranaki uriqarara afeeka qiminoo.
\q1 
\v 7 Rakiranaki akaqausa nári qoosa rarisee mari karana saqarikidaqa, akaqausa nári qoosa saqarikidaqa.
\q1 Miqi mariafaqa maasa Yaaweena maasa Anutuna mina afeeka saqarikidaqa.
\q1 
\v 8 Maasa namuqaa mi rakira ainainausa saqariki
\q2 mariasa niku amaki saamurifaqa maasa kaqi afeekaikammasee kikiqiqa marianaura.
\q1 
\v 9 Oo Yaawee anee rakiranaki uriqarara afeeka qini Dafidisa qimia.
\q1 Maasa ani aaraanana maasa dadaaqia.
\c 21
\s1 Rakirana urinnaaqararanara Yaaweena amooqira idi.
\q1 
\v 1 Oo Yaawee anee Dafidina afeeka amiannanara asasidanoo.
\q1 Anee mina dadaaqiananoo rakirana uriaaqarainara firaaqoo nasuridanoo.
\q1 
\v 2 Anee mina amuqusaki aidimari ainainna amiananoo.
\q1 Anee mifa irai ainainna faqa amiananoo.
\q1 
\v 3 Anee mifinnai anireenana firaaqoo amiqi amiqimma amaqaananoo.
\q1 Miqimmasee anee uriqararausa qata koorannai auqirana afisu amaqaananoo.
\q1 
\v 4 Mifa mariranara iraifana anee amiseenana mina marirana kisaaqaikamma amaqaananoo.
\q1 
\v 5 Anee Yaaweefa dadaaqiannanara mifa uriqarara auqu mareenoo.
\q1 Anee mina afeeka faqa uriqarara auqu faqa amiananoo.
\q1 
\v 6 Ani amiqi amiqirafa naaru naaru mina faqa mariannoo.
\q1 Ani afusaa marirafa mina asasirana qumbiqa amidanoo.
\q1 
\v 7 Dafidifa Yaaweena aiqama afeeka faqaana saqarikidanoo.
\q1 Yaaweena kaqi marira aidirafa marinara mifa aiqama ainainaki afeekaikammasee mariannoo.
\q1 
\v 8 Dafidifa narí aiqama namuqaa rumbannimaqaannoo.
\q1 Mifa nariara fidiaqaa imariasa faqa rumbannimaqaannoo.
\q1 
\v 9 Mifa anireenoo idaurunnoo narí namuqaa aiqama kuridi nimaqaannoo.
\q1 Yaaweena arana qarafa misa nambiqamasaannoo.
\q1 Ida fannoo misa qama taikaannoo.
\q1 
\v 10 Sia uqanna misa atikiqari moo fannoo kaqi mariannoo. Dafidifa aiqama naru taikaannoo.
\q1 
\v 11 Misa mina ariraree qimasee tipundaaramma saifanoo sia misa tipundaarirafa anoona kambiqaannoo.
\q1 
\v 12 Mifa feefa niiqamasainaqa quqasee sandeefaranoo.
\q1 
\v 13 Yaawee maasa ani firaa afeekara amooqidaqa. Maasa idi raidaqa ani afeekara amooqianaura.
\c 22
\s1 Ummaara faqaana iki raqarafa faqa Anutuna amooqira idi faqa maridanoo.
\q1 
\v 1 Oo qini Anutu, qini Anutu, naqifee ifanee anee qini minniqiseenanee.
\q1 Anee naqaa fee ifanee aadumai nianasaa maridana sia qini dadaaqidanee.
\q1 Anee naqaa fee ifanee sia qini ikiraqarana irinanee.
\q1 
\v 2 Faasaana ani qeeqa Anutuna aaraunana sia maqi qiananoo.
\q1 Eendaki faqa aaraida maridaqa sia idooeeqa.
\q1 
\v 3 Anee naaquqarafa andeeqara oosana faqaafa mariananoo.
\q1 Isaraee maqannaasa ani amooqi mariafa mariananoo.
\q1 
\v 4 Maasa qikeeku qikaaku ani saqariki mariqau.
\q1 Misa ani saqari kammasoofana anee misa asumu mariaqeera maranau.
\q1 
\v 5 Misa manda ainainakiqari ani auqu roonannai asumu mariqau.
\q1 Misa ani saqarikida sia nisaurirana mareea.
\q1 
\v 6 Qinee oorudupirausa fifau doodaaniara foora maridaqa.
\q1 Qiniara nikooqaifaqa fidiaqaa midaqa.
\q1 
\v 7 Misa qini qiqafeeqa uteeti qimasee nimaakiri rummiqi qimaqaidaqa.
\q1 Miqimmasee misa ninuka aqidaqa maaqi qidaqa.
\q1 
\v 8 Anee Yaaweenasaa mundi mariananoo nanaree mifa sia ani dadaaqidanoo fee.
\q1 Yaweefa aniara aidi marifanoo nanaree mifa ani sia itita amaqaidanoo fee.
\q1 Nanaree sia ani dadaaqidanoo fee.
\q1 
\v 9 Oo Yaawee anee kai qini qinoona aranandakinaana amiqimmasee qini mara akoonnai quqaqisaananoo.
\q1 Qinee aanaaqi maridaqa qeeqa qinoona naamma
\q2 neemariafanana anee qini amiqimmasee rakisi qimaqee marunaqa mariqiafana.
\q1 
\v 10 Qinee qeeqa qinoona aranandakiqari
\q2 kambiqaafannaqoo qari anisaa mundiqa maridaqa.
\q1 Miqiqa marunana anee qini Anutufa mariananoo.
\q1 
\v 11 Ummaara qiniki maridanoo, sia nianai maria. Sia qini dadaaqirausa maridammia.
\q1 
\v 12 Namuqaa moomoo kaasau aandaura foora qini fiqu fiqu iqa maridaqa.
\q1 Misa Basaana maqa maaqakina afeeka kaasau aandaura foora qini fiqu fiqu iqa maridaqa.
\q1 
\v 13 Misa kaasau fainiara foora nooraqasee qini qipata anaqirara rairai qidaqa.
\q1 
\v 14 Nammari maqasaa adiasaafanoo dadasindee inoo qini afeeka taikeenoo.
\q1 Qini qimudaani aiqama radukinoo maridanoo.
\q1 Qini qimuqusaki daaquqarafa maridanoo.
\q1 
\v 15 Qini qimaaqaara aadana usidanoo.
\q1 Qini qimaakiri qimaaqaarai atooqanoo maridanoo. Anee qini kookoommaki rumaqimaqa qaanaqa kuqirara midaqa.
\q1 
\v 16 Manda oosana maree mariasa aanoo qimaria fainisara foora qini fiqu fiqu iqa maridaqa.
\q1 Misa qini qiku qisauku aakumaree rakee iraridaqa.
\q1 
\v 17 Qini qimudaani akooqoo marifaqa misa qini kaaqa tataqaidaqa.
\q1 
\v 18 Misa qini qammunna marasee rainaidaqa.
\q1 Qini siuta raipaqusee kaatara foora sararammasee mareea.
\q1 
\v 19 Oo Yaawee sia anee nianai maria qini daaqa ani maria.
\q1 Kai kaqi aniree qini rukia qisaa.
\q1 
\v 20 Oo Yaawee misa nookinaana qini mareeqee asumu quqaqisaa.
\q1 Maa fainisa nookinaana qini mareeqee kaqinni asumu quqaqisaa.
\q1 
\v 21 Kaasau fainiuqa nookinaana mara kaqinni quqaqisaa.
\q1 Qinee kaasau aandauqa nifusaa ititarausa sia mariafaqa maridaqa.
\q1 
\v 22 Miqimma sainaqa anee auqaanna ainainnara qinee qeeqa maqannaasa qimannimianaura.
\q1 Qimannimisee qinee misa suqiranakiqari ani amooqianaura.
\q1 
\v 23 Innee Yaaweena ainainira faiqiuqa mina amooqiaqa.
\q1 Innee Yakooboona aiku asauku mariasa mina auqu uqeeraaqa.
\q1 Innee Isaraee maqannaasa mina kai amooqiaqa.
\q1 
\v 24 Yaaweefa sia kudi fasiqauqa sarau imarianara irisee ameesuqu nimaqaidanoo.
\q1 Sia oori rafusu kaqinni aqidanoo, mifa misa innaaru qirana iriseenoo dadaaqidanoo.
\q1 
\v 25 Qinee firaa suqiranaki anee auqaanna ainainnara ani amooqianaura.
\q1 Ani amooqirara suqiqa mariasa nifusaa ani amooqianaura.
\q1 Qinee qima afeekaikammasee suqa amianauree qiafanna tatufirana suqa amianaura.
\q1 
\v 26 Sarau iranaki mariasa narana namasaifanoo nimuaqu imarina marifaranoo.
\q1 Yaaweefinnai anirainausa mina amooqifaranoo.
\q1 Miqi mariasa naaru naaru aiqama ainaina amanaikirausa mariaqa.
\q1 
\v 27 Aiqama maqannaasa Yaaweenara irifaranoo.
\q1 Aiqama maqa maaqakinaasa mifinnai ubeekeefaranoo.
\q1 Aiqama fasiqa anaasee mina amooqifaranoo.
\q1 
\v 28 Yaaweefa karaambaiqa maridanoo aiqama maqannaasa rakisinnimaqaidanoo.
\q1 
\v 29 Aiqama ramoo ramaa imariasa mina oorinni niqoori saunu areefaranoo.
\q1 Aiqama faiqí faiqi mina oorinni niqoori saunu areefaranoo.
\q1 
\v 30 Naaru kambiqainausa mina ainainira faiqiuqa marifaranoo.
\q1 Misa kasooaqee kambiqainausa Yaaweenara qimannimifaranoo.
\q1 
\v 31 Yaaweefa narí faiqí anaasee maroonara naaru kambiqainausa qimannimifaranoo.
\c 23
\s1 Yaaweefa maasasaa sipsipasaara foora rakisirafa maridanoo.
\q1 col
\v 2 Yaaweefa qini sipsipasaara foora rakisi qimaqee marifaqa qinee sia moo ainainara sarau ianaura.
\q1 Mifa qini mareeqeenoo sipsipara foora quqeenara andandaki quqasaifaqa namasee faiqaidaqa.
\q1 Mifa qini qifiqeeqee amiqira nammari reendeenammasee ooqu fimarina afaisaa quqaqisaifaqa namasee idooaidaqa.
\q1 
\v 3 Mifa qini fuka afeeka qimidanoo.
\q1 Mifa narí qima afeekaika maqoomau finoo qini andeeqara aatata kai qifiqee fidanoo.
\q1 
\v 4 Yaawee anee qini faqa mariannanara qinee kuqira
\q1 ummaaraki asukuna titunaanu qiranakiara foora fidaqa sia moo mandainainara rufiaanaura.
\q1 Ani saunu faqa unnaana samu faqa qini itita qimaqeenoo.\fig Sipsipasaa rakisirafa saamu uqirafa kaasau faini sipsipa naruandoora rakisadanoo.|alt="Shepherd protecting sheep from wolves with a rod" src="BK00010B.TIF" size="col" loc="Psalms 23:6" ref="23:4"\fig*
\q1 
\v 5 Anee qini namuqaa nifusaa firaa oomaqa qini qimiananoo.
\q1 Qinee uriqarara fasiqara foora marunana qini daarama quqaananoo.
\q1 Anee amiqi amiqira ainaina namariara foora qini kaafaki adia afairaqaramma qimiananoo.
\q1 
\v 6 Ani amiqi amiqirafa faqa amuqusirafa faqa qini faqa mariinoo kuquananoo kai taikaannoo.
\q1 Ani amaana maqa fannoo qini maaqara foora
\q2 marinaqa qinee minaki keeqee raudee iiqa kuquananoo taikaannoo.
\c 24
\s1 Uriqarara karaambaiqa.
\q1 
\v 1 Maa maqa maaqafa faqa aiqama minakinaa ainaina faqa Yaaweenaindi kai maridanoo.
\q1 Maqa faqa minasaa maria fasiqa aanaaseesa faqa minaindi kai maridaqa.
\q1 
\v 2 Mifa maa maqana ameemaanai maru nammarina amuaaqa auqu quqanau.
\q1 Quqaseenoo mina faakanauqa maqa ameemaanaindaraa nammariki rakiqanau.
\q1 
\v 3 Yafee amana Yaaweena aaqanasaa oorufuannoo fee.
\q1 Yafee amana mina naaquqara amaana maqaki keeqaannoo fee.
\q1 
\v 4 Andeeqara oosana auqee marifa faqa amiqira amuqusa faqaafa faqa sia unna anutusa nimooqi mariasa
\q1 faqa sia unna qimasee nimana aiqee mariasa kai minaki keeqeefaranoo.
\q1 
\v 5 Yaaweefa misa asumu mara quqasee amiqi amiqimma nimaqaannoo.
\q1 Miqimmaseenoo Anutufa misara aaqarana siaisee qiannoo.
\q1 
\v 6 Miqira fasiqauqa Anutufinnai anidaqa.
\q1 Misa Yakooboona Anutuna oorinni fidaqa.
\q1 
\v 7 Innee faandaamura kooqiuqa firaaqoo atua aquaqa.
\q1 Innee ooqeennaa amaana maqa kooqiuqa faqa atuasaifanoo uriqarara karaambaiqa keeqaani.
\q1 
\v 8 Yafee mi uriqarara karaambaiqafa maridanoo fee.
\q1 Mifa Yaaweefa afeeka faqa eeraara faqa faqaafa maridanoo.
\q1 Mifa Yaaweefa aiqama rakiranaki uriqaree marifa maridanoo.
\q1 
\v 9 Innee faandaamura kooqiuqa firaaqoo atua aquaqa.
\q1 Innee ooqeennaa amaana maqa kooqiuqa faqa atuasaifanoo uriqarara karaambaiqa keeqaani.
\q1 
\v 10 Yafee mi afeeka karaambaiqafa maridanoo fee.
\q1 Yaaweefa aiqama maqannaa uriqarara afeeka faqaafa, afeeka karaambaiqa maridanoo.
\c 25
\s1 Rakisinnimaqaranara faqa itita nimaqaranara faqa innaaru qirufa.
\q1 
\v 1 Oo Yaawee qeeqa innaaru qirana ani amidaqa.
\q1 
\v 2 Oo qini Anutu, qinee ani saqarikidaqa.
\q1 Namuqaa darifaqa qisauruanoora anee mi dariranasaa ititaqisaa.
\q1 Anee dadaaqinaqa qini namuqaa sia qiniara ataasa ataasa qiaqa.
\q1 
\v 3 Ani saqariki mariasa namuqaa rafaaqafu nimaqarafa sia maridanoo.
\q1 Qusufa qimasee ani Yaaweenara kaukaata qimariasa namuqaa misa rafaaqafu nimaqaidaqa.
\q1 
\v 4 Oo Yaawee anee fimarianna aanna qini uqaqifiqaina fua.
\q1 Anee fimarianna aannara qini daamuaqinaqa iria.
\q1 
\v 5 Anee qini Anutufa qini asumu maree marianafa
\q2 mariannanara ani anoona ufa mau firana daakapa.
\q1 Qinee aiqama kari ani saqarikidaqa.
\q1 
\v 6 Oo Yaawee aneenna qimudaoo qirana faqa aneenna
\q2 naaru marira amuqusirana quqannifiqoonnanara oonu mafi iria.
\q1 
\v 7 Qinee kumaaraasaa auqaafanna aaqarana akiiqara minniqisaa.
\q1 Oo Yaawee, aneenna naaru marira amuqusiranannoo
\q2 faqa aneenna amiqi amiqirannoo faqa qiniara oonu mafi iriqisaa.
\q1 
\v 8 Yaaweefa andeeqara marirana faqaafa marinara aaqee mariasa andeeqara aanara naamua qidanoo.
\q1 
\v 9 Nári nifaaqa mara maree qumi mariasa Yaaweefa andeeqara aatata nifiqee fidanoo, narí aidiranara qimannimidanoo.
\q1 
\v 10 Mina moodaanaki kira ufa faqa mina sandufa faqa afaqee mariasa Yaaweefa narí mapukusee marira
\q2 oosanannoo faqa narí amuqusiranannoo faqa nifiqee fidanoo.
\q1 
\v 11 Oo Yaawee, aneenna qima afeekai kiranara oonumafi irisee qini moomoo aaqarana akiiqara minniqisaa.
\q1 
\v 12 Yaaweenara naaquqee marisa mifa amiqira aanara qimannimiannoo.
\q1 Qima niminaqa mi mau fifaranoo.
\q1 
\v 13 Misa aiqama ainaina amanaikiranaki amiqiranaki marifaranoo.
\q1 Misa faiqi namu maqa maaqa mareefaranoo.
\q1 
\v 14 Yaaweefa mina ufa qaindusi mariasa niqoondi maridanoo.
\q1 Mifa narí moodaanaki kira ufa qimaqoona kafaa qimannimidanoo.
\q1 
\v 15 Qinee aiqama kari dadaaqianifeera Yaaweefinnai qifu maqaidaqa.
\q1 Miqi marunanoo mifa qini manda ainainakinaana itita qisee marifa maridanoo.
\q1 
\v 16 Qinee qeeqaraa marida ummooquki marunnanara Yaawee anee qinnee unnannai quandafi qiniara qimudaoo qia.
\q1 
\v 17 Qini qimuqusakina oosana oosana ummaarauqa maraqu qisasee qini oosana oosana ummaarakinaana mara kaqinni quqaqisaa.
\q1 
\v 18 Oo Yaawee, qini aiqama aaqarana akiiqara minni qiseenana aupurarana faqa fitinnarana faqa dadaaqia.
\q1 
\v 19 Oo Yaawee anee qafaa qini namuqaa moomoo uqanna maridaqa.
\q1 Misa firaaqoo uqanna qiniara fidiaqaa idaqa.
\q1 
\v 20 Qini titaqisaidana qini marirana mara afeedamma qisaa.
\q1 Anee itita qimaqaanneera qinee anee iannannai anidaqa.
\q1 Namuqaa qini rafaaqafu qimaqee marianasaa itita qisaa.
\q1 
\v 21 Qinee ani mandaaqee marunnanara qini andeeqarafa
\q2 faqa anoona qiramau firafa faqa qini rakisiqimaqaani.
\q1 
\v 22 Oo Anutu, Isaraee maqannaa aneenna faiqí anaasee
\q2 nariqa oosana oosana ummaara kinaana mara kaqinni quqannisaa.
\c 26
\s1 Andeeqara fasiqa innaaru qirufa.
\q1 
\v 1 Oo Yaawee qinee andeeqara oosana maree marunnanara faqa firaaqoo ani saqariki
\q2 marunnanara faqa iriseenana qiniara aaqarana siai fee qinaqa iriaqa.
\q1 
\v 2 Oo Yaawee, anee qini diuqummasee qimanammasee qafaa.
\q1 Qini didirana faqa qini irirana faqa rainasee iria.
\q1 
\v 3 Ani aiqama kari mari amuqusirafa qini indaarunnikamma qimaqaidanoo.
\q1 Aniki mapukusee marira oosana fannoo qini dadaaqidanoo.
\q1 
\v 4 Qinee sia fifau aatata nimariasa saimbaqa nidaqa.
\q1 Qinee sia qaaraiki mariasa faqa moodaanaki kianaura.
\q1 
\v 5 Qinee aaqee mariasa faqa moodaanaki nirara fidiaqaammidanoo.
\q1 Manda oosana auqee mariasa finnaaqa raidaqa.
\q1 
\v 6 Qinee qeeqa qisauku nammari uqusee qeeqara aaqarana siaisee qidaqa.
\q1 Miqimmasee qinee ani aidara fiqu fiqu idaqa ani amooqidaqa.
\q1 
\v 7 Qinee aniara dufi dufi qira idi raidaqa anee firaa ainaina auqoonnanara qimannimidaqa.
\q1 
\v 8 Oo Yaawee qinee anee marianna maaqanara firaaqoo dididanoo.
\q1 Ani qareenarafa mariqoora firaaqoo dididanoo.
\q1 
\v 9 Sia aaqee mariasa namufaqa qini kuridi qimaqaa.
\q1 Faiqí nári mariasa darirana kinaana qini mara kaqinni quqaqisaa.
\q1 
\v 10 Miqi mariasa aiqama kari manda oosana faqa umeeramaisaanifee munnimma maqee maqee maree mariasa faqa nariranakinaana qini mara kaqinni quqaqisaa.
\q1 
\v 11 Qinee qeeqaraa andeeqara oosana auqaidaqa.
\q1 Anee qiniara qimudaoo qimasee qini asumu mara quqaqisaa.
\q1 
\v 12 Qinee aiqama manda ainainakiqari kaqinni maridaqa.
\q1 Qinee Yaaweena faiqí anaasee suqiranaki mina amooqidaqa.
\c 27
\s1 Anutuna amooqira innaaru.
\q1 
\v 1 Yaaweefa qini qoomara foora maridanoo qini asumu
\q2 maree marifa marinara qinee yanaree moonara rufiaanauree.
\q1 Qini marirana nirana afeeka Yaaweefa kai marinara qinee yanaree maparaa ianauree.
\q1 
\v 2 Manda oosana maree mariasa aanaamuru qini
\q2 namuqaauqa qini makuruanee qimasee anireeqa niku amaki saamurifara.
\q1 
\v 3 Qini namuqaa moomoo aniree qini maqusa uqusaifaqa sia qinee misara rufiaanaura.
\q1 Rakiranaki misa aniree darirarifaqa sia qinee maparaa ianaura qifaaqa quqasee marianaura.
\q1 
\v 4 Qinee moodaa ainaina kai Yaaweenasaa qaraana marararee qidaqa, qinee minara kai randaanaura.
\q1 Qinee maa maqanasaa marunna kamuqoo Yaaweena uiqaana maqaki marianauree qidaqa.
\q1 Minaki maridaqa Yaaweena qareenarana qafamasee asasianauree qidaqa.
\q1 Mina uiqaana maqaki mina iriranara mariranara randaanauree qidaqa.
\q1 
\v 5 Manda aukuana kambiqainanoo narí mari maqanaki kukeeqa qimaqaannoo.
\q1 Narí uiqaana maqaki qini kukeeqaqisaanoo.
\q1 Mifa qini uqeereeqee aaqanasaa oonisaa amiqiraqoo quqaqisaannoo.
\q1 
\v 6 Doo miqoo qini namuqaa qini uqusaafanoo Yaaweefa
\q2 qini mareeqee misa urinnaaqarama saifaqa marianaura.
\q1 Miqimmasainaqa qinee narí Yaaweena naaquqara
\q2 uiqaana maqaki faaqa quqasee asasammasee aandau tatufirana suqamianaura.
\q1 Qinee idi namu faqa ufireena namu faqa Yaaweenara amooqira idi raanaura.
\q1 
\v 7 Oo Yaawee qinee qeeqa ufannai aniara nameera qimasee aaraanana iria.
\q1 Anee qini qifauarana qimisee kafaa anoona ufa qimaqimia.
\q1 
\v 8 Anee qiniara aniree qini qimooqiannee qianaqa Yaawee, qinee eedoo qimasee anianaura.
\q1 
\v 9 Oo Yaawee aneenna oori afiri sia qini kukeeqa qimaqaa.
\q1 Sia qiniara arana qaani. Sia aneenna ainainira faiqi qiniara anirandee fuannee qia.
\q1 Anee qini dadaaqi marianafa mariananoo.
\q1 Oo qini Manika Anutu anee qini asumu maree marianafa mariananoo,
\q2 sia qini minniqisaa sia qini quqaqisaa.
\q1 
\v 10 Qini qinaukoo qini minniqisaifanoo Yaaweefa qinisaa rakisiannoo.
\q1 
\v 11 Oo Yaawee anee qiniara auqaannee qimarianna ainainnara daamuaqia.
\q1 Qini namuqaa moomoo marianara irisee andeeqara aatata amiqiraqoo qifiqee fua.
\q1 
\v 12 Sia anee qini mareeqee qini namuqaa marianaki quqaqisaa.
\q1 Misa naaquqara ufannai faqa unna ufannai faqa qini daridaqa.
\q1 
\v 13 Qinee maa ainainnara amiqimmasee iridaqa,
\q2 qinee kasooaqee kaqi mariasa faqa maridaqa Yaaweena amiqi amiqirana qafaanaura.
\q1 
\v 14 Yaaweena saqarikia.
\q1 Sia ani amuqusa ummaara raani, afeekaikammasee mina saqarikia.
\c 28
\s1 Dadaaqiani fee innaaru.
\q1 
\v 1 Oo Yaawee anee qini dadaaqida ititaqimaqee
\q1 marianaqa minakiqari qinee ani aaraanana qini nammeera qirana iria.
\q1 Anee sia qini anoona ufa qima qiminaqa qinee
\q2 kuqira maqa maaqaki kuqufida fimariasa qambaana marianaura.
\q1 
\v 2 Qinee qeeqa qisauku ani naaquqara amaana maqa
\q1 maritinai uqeerasee dadaaqianneera innaaru qianana iria.
\q1 
\v 3 Oo Yaawee anee sia manda oosana maree mariasa faqa aaqee mariasa faqa amiqira adiafaa ira ufa
\q2 qimaria fanoo misa nimuqusaki manda irirafa umbiqarausa namufaqa qini rafaaqafu qimaqaa.
\q1 
\v 4 Oo Yaawee misa auqee mariana akiiqara aupurarana nimia.
\q1 Nisaukunnai manda oosana auqee mariana amana kai aupurarana nimia.
\q1 Misa aiqama manda oosana maree mariana amana kai aupurarana nimia.
\q1 Misa aaqarana akiiqara amanaikamma nimia.
\q1 
\v 5 Miqi mariasa Yaaweefa auqoo ainainnara sia iridaqa.
\q1 Mifa narí asaukunnai auqu quqoo ainainara sia misa
\q2 iridaqa mina akiiqara Yaaweefa misa aupurarana nimiseenoo kuridi nimaqaannoo.
\q1 
\v 6 Yaaweefa qinee dadaaqiani feera nammeera qunnana irinara mina amooqidaqa.
\q1 
\v 7 Yaaweefa qini itita qimaqaseenoo qini dadaaqi marifa maridanoo.
\q1 Qinee mina saqarikidaqa.
\q1 Mifa qini dadaaqirana faqa asasirana faqa qimisaifaqa asasidaqa.
\q1 Minara qinee mina amooqidaqa asasira idi rama amaqaidaqa.
\q1 
\v 8 Yaaweefa narí faiqí anaasee itita nimaqaidanoo.
\q1 Mifa narí utaaqamaqai karaambaiqana itita
\q1 amaqaseenoo mina manda ainainakinaana mara kaqinni quqaisaidanoo.
\q1 
\v 9 Oo Yaawee aneenna faiqí anaasee manda
\q2 ainainakinaana mara kaqinni quqasee anindikiqa mariasa amiqi amiqimma nimaqaa.
\q1 Anee misasaa sipsipasaa rakisirafara foora maridana naaruara misasaa rakisia.
\c 29
\s1 Aakuasaa ufai uqirafa Yaaweena ufara foora maridanoo.
\q1 
\v 1 Innee innaarunai mariasa mina amooqiaqa.
\q1 Mina afeekara faqa qareenaranara faqa amooqiaqa.
\q1 
\v 2 Yaaweena qareenara auqu uqeeraaqa.
\q1 Yaaweefa naaquqarafa koorooinaqa mina oorinni niqoori saunu arafi naaquqamafi mina amooqiaqa.
\q1 
\v 3 Yaaweefa ufa qifaqa ooruku nammariki aiqamaindari mina ufa iridaqa.
\q1 Uriqarara qareenarana faqaa Anutufa innaarunaira
\q1 foora darara qifanoo ooruku nammari aiqamai daraanifaqa iridaqa.
\q1 
\v 4 Yaaweefa aiqama afeeka faqa eeraarirana faqaana ufa qirana irisee aiqamausa rufiaidaqa.
\q1 
\v 5 Yaaweena ufa fannoo firaa saqari raudee marifa maridanoo.
\q1 Yaaweena ufa fannoo Reebanoona maqa maaqaki
\q1 mari saqarisa sidaa saqariuqa raudee marifa maridanoo.
\q1 
\v 6 Yaaweefa qifaqa Reebanoona aaqanauqa kasidaqa aandau aanaaqiara foora rafusaki rafusaki idaqa.
\q1 Qeeramoonna aaqana faqa miqi kai idanoo
\q1 burimakau aanaaqi timmusara foora rafusaki rafusaki idanoo.
\q1 
\v 7 Yaaweena ufa fannoo aakuasaara foora pananana qidanoo.
\q1 
\v 8 Yaaweena ufa fannoo aadana maqa maaqa kasidanoo.
\q1 Mifa qifanoo Kadeesa aadana maqa maaqa faqa kasidanoo.
\q1 
\v 9 Yaaweena ufa fannoo aakuasaara foora pananana qinoo saqari amanee rauqu aqidanoo.
\q1 Yaaweena maaqaki mariasa firaaqoo faaqa rumasee Yaaweefa uriqarara qareenarana faqaafee qidaqa.
\q1 
\v 10 Yaaweefa naaruara uriqarara karaambaiqa maridanoo aiqama nammariuqasaa rakisidanoo.
\q1 
\v 11 Yaaweefa narí aiku asauku afeeka nimidanoo.
\q1 Amiqi amiqimma nimaqasee asooaranaki quqannisaidanoo.
\c 30
\s1 Dufi dufi qira innaaru.
\q1 
\v 1 Oo Yaawee, ani auqu qinee uqeeraidaqa.
\q1 Qini namuqaauqa qini darusee ataasa ataasa qidaqa
\q1 nasuriraree qianakinaana kaqinni mara quqa qisaannanara ani auqu uqeeraidaqa.
\q1 
\v 2 Oo Yaawee qini Anutufa qinee ani dadaaqiranara aaraunana anee qini dadaaqiananoo.
\q1 
\v 3 Oo Yaawee anee qini madikakinaana qumbaqi
\q1 qisaananoo, qinee kuqira madikaki ooqu raunana anee qumbaqisee kaqi marirana qimiananoo.
\q1 
\v 4 Oo innee Yaaweenaki mapukusee mariasa, innee mina amooqira idi raaqa.
\q1 Innee mifa auqoo ainainara oonu mafi irisee mina dufi dufi qima amaqaaqa.
\q1 
\v 5 Yaaweena aanooqirafa qusakamu marinoo taikaannoo.
\q1 Mina amiqirafa maa maqanasaa kisaaqasaa mariannoo.
\q1 Eendaki qusasaa qikiraqarafa mariannoo, iaqainanoo kananaana asasirafa mariannoo.
\q1 
\v 6 Qinee afeekaikammasee mapukiqa maridaqa qinee aaqamasee qeeqara maaqi qiqiafana.
\q1 Qinee naaruara naaruara sia kasianauree qiqiafana.
\q1 
\v 7 Oo Yaawee anee qini amiqimma qimaqaseenana
\q1 aaqana saaqaraa maaqara foora mariafanana qinisaa itita qimaqanau.
\q1 Anee aneenna oori kaqinni quandoonaqa qinee maparaa iranaki mariqiafana.
\q1 
\v 8 Oo Yaawee qinee ani aareeqa anee dadaaqirana qimianneera aareeqa
\q1 
\v 9 Qini kuqirafa sia kaqikaaqoo faqa ani amooqirafa mariannoo.
\q1 Qinee madikaki ooquraananoo qini mi kuqirafa sia amana moo ainaina auqaannoo.
\q1 Kuqirauasa amanee ani amooqifaree. Sia amana.
\q1 Amanee misa anee kisaaqasaa amiqimma nimaqee mariannanara kooroo ifaree. Sia amana.
\q1 
\v 10 Oo Yaawee, anee qini innaaru irisee qimudaoo qimasee qini dadaaqia.
\q1 
\v 11 Qinee soofaaraki marunnana anee quandasee idi rarana qimiananoo.
\q1 Anee qini ikiraqarana mara aquseenana asasirana qini fiqu fiqumma datimmma qimaqaananoo.
\q1 
\v 12 Miqimma qisaannanara qinee sia ufa siaina qireeda marianaura qinee ani amooqira idi raanaura.
\q1 Oo Yaawee anee qini Anutufa qinee naaruara naaruara ani dufi dufi qima amaqaanaura.
\c 31
\s1 Anutuna saqarikira innaaru.
\q1 
\v 1 Oo Yaawee qinee itita qimaqaanneera anee iannannai anidaqa.
\q1 Naaruara sia qini qisauriranaki quqaqisaa.
\q1 Anee andeeqara Anutufa mariananoo qini kuqiranakinaana mara kaqinni quqaqisaa.
\q1 
\v 2 Qini ufa irisee maqee uqanna qini kuqiranakinaana mara kaqinni quqaqisaa.
\q1 Anee qini faandaamura ooniara foora maridana qini itita qisaa.
\q1 Anee qinisaa ququsara foora auqu ititaseenana qini kuqiranakinaana mara kaqinni quqaqisaa.
\q1 
\v 3 Oo Yaawee anee qini faandaamura ooniara foora faqa ququsara foora faqa mariananoo.
\q1 Aneenna qima afeekaikunadee inana qini qisauku qumaree aana muquninaqa fua.
\q1 
\v 4 Anee qini dadaaqinaqa qini qimaara fufuqaa ufaannanaki sia arua.
\q1 Manda ainainasaa auqaanara foora qinisaa mandaaqa qimaqaa.
\q1 
\v 5 Ani asaukuki qeeqa qimana quqaidaqa.
\q1 Oo Yaawee anee qini kuqiranakinaana mara kaqinni quqa qiseennaranoo.
\q1 Anee mapukusee marirana faqaa Anutufa mariananoo.
\q1 
\v 6 Anee unnaqira anutusara innaaru qimariasara fidiaqaa imariananoo.
\q1 Misa miqi mariafaqa qinee ani kai saqarikidaqa.
\q1 
\v 7 Ani maasara kisaaqasaa amuqusiranara qinee asasidaqa nasurianaura.
\q1 Anee qini aupurarana faqa ummaara faqa qafaannanara miqianaura.
\q1 
\v 8 Anee sia qini mareeqee namuqaa nisaukuki quqasaanaqa qini qumareea.
\q1 Qinee qifaaqa quqasee qeeqa didimarinnai firana anee qimiananoo.
\q1 
\v 9 Oo Yaawee qinee qummaaraki maridaqa qiniara qimudaoo qia.
\q1 Qinee kaaqa moomoo kari iki raqee saunanoo qifukaumu innooqafinoo.
\q1 Qini qimudaani firaaqoo ummooqukidanoo.
\q1 
\v 10 Qini ummaara fannoo qini afeeka taikaidanoo.
\q1 Qini iki raqarafa qini marirana qusa raidanoo.
\q1 Qini ummaara fannoo qini afeeka taikasaifanoo qini qimudaani ummooqukidanoo.
\q1 
\v 11 Qini namuqaa faqa qini qiqoonausa faqa qiniara uteeti amara auqidaqa.
\q1 Minara kai qiniara irimariasa naaquqaifaqa qini daaqu rufiqaidaqa.
\q1 Aanai qini paquri masee quqasee sandaidaqa.
\q1 
\v 12 Qinee kuqiara foora iqa marunaqa qiniara qaunidaqa.
\q1 Qinee rukamufifaqa aqusaa qafeesara foora maridaqa.
\q1 
\v 13 Qini namuqaauqa maqandanai narí qimami narí qimami masaidaqa uteeti qimariafaqa iridaqa.
\q1 Rufiarafa firaafa qini fiqu fiqu inoo maridanoo.
\q1 Misa moodaanaki suqufiqa qini marirana taika qimaqaaneera tipundaaridaqa.
\q1 
\v 14 Miqi mariafaqa Oo Yaawee qini Anutu qinee ani kai saqarikidaqa.
\q1 
\v 15 Qinee aiqama kari ani rakisi qimaqaranaki maridaqa.
\q1 Qini namuqaa qini darirara qifaqaqa nuanakinaana qini mareeqee amiqiraqoo quqa qisaa.
\q1 
\v 16 Qini aneenna ainainira faiqiara qimudaoo qidana qiqafaa.
\q1 Aneenna sia takee mari amuqusiranaki qini mara quqa qisaa.
\q1 
\v 17 Oo Yaawee, qinee ani aaraunnanara anee qinaqa
\q1 qini namuqaauqa sia qini qisauriranaki quqaqisaaqa.
\q1 Manda oosana maree mariasa kai nisauriranaki mariaqa.
\q1 Misa ufa taikafinaqa madikaki kuqirausa faqa mariaqa.
\q1 
\v 18 Unna ufa qimariasa noo qummuna mannisaa.
\q1 Misa nári nifaaqa uqeerasee akaqausa mara maree
\q2 qumimariasa misa andeeqarausara manda ufa qidaqa.
\q1 
\v 19 Ani ameemaanai maridaqa ani ufa mau fimariasa
\q2 afeedamma nimaqaqaanna ainainausa kaaqa amiqirafa maridanoo.
\q1 Anee firaaqoo amiqimma nimaqee mariannanara aiqamausa iridaqa.
\q1 Ani saqariki mariasa anee firaaqoo rakisi nimaqaidana itita nimaqee mariananoo.
\q1 
\v 20 Ani saqariki mariasa narirara tipundaari mariafana
\q1 anee mareeqee aneenna afusaa amiqiranaki quqannisee marianafa mariananoo.
\q1 Misa namuqaa nifairiranakinaana mareeqee amiqira auqaanai quqannisee marianafa mariananoo.
\q1 
\v 21 Yaaweena amooqirana amiaqa.
\q1 Qini namuqaa qini fiqu fiqumma datimmafi
\q2 daruaneerufanoo qiniara firaaqoo aidufanoo itita qimaqoonara amooqiaqa.
\q1 
\v 22 Qinee rufiaidaqa maaqi qimasee iriqa, doo Yaaweefa
\q2 qini narí afusaa marunnana mareeqeenoo kaqinni quqaqee maqi qimasee irunanoo,
\q1 Yaaweefa qini innaaru qirana irisee dadaaqinoo.
\q1 
\v 23 Innee Yaaweena faiqí anaasee innee Yaaweenara firaaqoo nidiani.
\q1 Yaaweefa narí ufaki mapukusee mariasa itita
\q2 nimaqaseenoo, nári nuqu uqeeree mariasa nári manda oosana akiiqara nimimarifa maridanoo.
\q1 
\v 24 Innee Yaaweenaki mapukusee mariasa inni nimuqusa fannoo aiqama kari afeekaikinoo mariani.
\c 32
\s1 Numoo koorooirana faqa numoo akiiqara minninnisara ufa.
\q1 
\v 1 Inni numoo minninisaisa faqa inni numoo rafaaqafu nimaqasaisa faqa asasiaqa.
\q1 
\v 2 Yaaweena nifairiranaki sia mari fasiqafa asasiranaki maridanoo.
\q1 Sia unna qimasee nikaru qimari fasiqafa faqa asasiranaki maridanoo.
\q1 
\v 3 Qinee qeeqa numoo sia koorooiqa iki raqaida marunanoo suani afu keeqaidanoo.
\q1 Miqunanoo qini qimudaani ummooqukidanoo.
\q1 
\v 4 Eendaki faqa faasaana faqa Yaawee aneenna
\q2 asaukunnai fannoo qini aupurarana qimimariananoo qini afeeka taikeenoo.
\q1 Aiqaiqa aukuana suani firaafa qeenoo maqa aadana ususaifanoo taadairindee idanoo.
\q1 
\v 5 Qinee miqiqa maridaqa qeeqa aaqarana ani Yaaweena afusaa akooqoo koorooiqa.
\q1 Qeeqa manda oosana sia kukeeqeeqa kooroommasee ani qimamiqa.
\q1 Qinee maaqi qiqa, qeeqa aaqarana Yaaweena afusaa
\q2 kooroo qianauree qimasee kooroomma saunana
\q1 anee Yaaweefa qini mandoosana faqa qini aaqarana akiiqara faqa minniqisaananoo.
\q1 
\v 6 Miqiannanara aiqama ani ufamau fimariasa aiqama ainainara randeeqa aniara innaaru qidaqa.
\q1 Firaa ummaara nammari aufiara foora inoo sia misa rafaaqa fuannoo.
\q1 
\v 7 Anee qini kukeeqara maqusa mariananoo.
\q1 Anee ummaara aukuana qinisaa rakisinnaranoo.
\q1 Anee qini maree marianafa mariannanara firaaqoo idi raidaqa.
\q1 
\v 8 Yaaweefa maaqi qidanoo.
\q1 Qinee anee finna aannanara qima amianaura.
\q1 Qinee ani aakapamasee aamuaqianaura.
\q1 
\v 9 Anee sia qoosa doonkiara foora furufaria. Misa irirana siai ainainara foora maridaqa. Anee qainna
\q2 misa nooki quqasee rarisee mariandee inaqa irifaranoo.
\q1 Anee nookinaa qainna sia quqainaqa sia ani ufamau fifaranoo.
\q1 
\v 10 Manda oosana maree mariasa moomoo ummaara oosana oosana misaki maridanoo.
\q1 Yaaweena saqariki mariasa mina naaru marira amuqusirafa misa kukuqinoo maridanoo.
\q1 
\v 11 Innee andeeqarausa Yaaweefa auqoo ainainausara asasida nasuriaqa.
\q1 Innee mina ufa qaindusi mariasa faaqa ridaqa asasiaqa.
\c 33
\s1 Amooqira Idi.
\q1 
\v 1 Innee andeeqarausa Yaaweefa auqoo ainainnara faaqa ridaqa asasiaqa.
\q1 Mina ufa mau fimariasa mina amooqiaqa.
\q1 
\v 2 Innee piripuna aridaqa Yaaweena amooqiaqa.
\q1 Qisaukuqara taikasee sandafaqaa piripuna aridaqa Yaaweena amooqira idi raaqa.
\q1 
\v 3 Innee Yaaweenara fuka idi raidaqa amooqiaqa.
\q1 Innee amiqimmasee akoofasara foora piripuna aridaqa faaqa fuisee qidaqa amooqira idi raaqa.
\q1 
\v 4 Yaaweena ufa fannoo kuqaa anoona kai maridanoo.
\q1 Aiqama ainaina auqee marina mi mau kai uqee marifa maridanoo.
\q1 
\v 5 Yaaweefa andeeqara marirana faqa andeeqasee amana amana kai rainee marianara faqa aididanoo.
\q1 Maa maqa maaqanaki Yaaweena sia taikara amuqusirafa qumbiqanoo maridanoo.
\q1 
\v 6 Yaaweefa ufannai qufanoo innaaruna kambiqanau.
\q1 Narí ookinaa aidoonnai qufanoo suani faqa quqoona faqa fasau faqa kambiqanau.
\q1 
\v 7 Yaaweefa ooruku nammari susufinnaki saka quqaandee inoo moodaannai suqu quqanau.
\q1 Ooruku nammari faruma meemai uqanna quqasee afeedinau.
\q1 
\v 8 Minara maa maqa maaqanasaaqaraasa aiqama Yaaweenara innaaru qiaqa.
\q1 Maa maqa maaqanasaa mariasa minara naaquqee marina mina ameemaanai mariaqa.
\q1 
\v 9 Yaaweefa qufanoo maa maqa maaqafa kambiqanau.
\q1 Mifa afeeka ufa qufanoo aiqama ainaina kambiqanau.
\q1 
\v 10 Yaaweefa maa maqana saaqaraasa manda ufa tipundaariafanoo titannimaqaidanoo.
\q1 Maa maqana saa mariasa auqararee qia ainainna itita nimaqaidanoo.
\q1 
\v 11 Yaaweena qimirirafa miqinoo maridanoo naaruara naaruara afeekaikamminoo maridanoo.
\q1 Mina amuqusakinaa qimirirafa naaruara naaruara mariannoo.
\q1 
\v 12 Aiqama maqannaasa kiqari ya maqannaasee misa Anutufa Yaaweefa maridanoo fee asasiaqa.
\q1 Yaaweefa nariaree qimasee utaaqama qaisa asasiaqa.
\q1 
\v 13 Yaaweefa innaarunaindari maqasaa mariasa aiqama niuqidanoo.
\q1 
\v 14 Narí maridanoo rakisi nimaqee mariqooqari aiqama maqasaa mariasa niqafaidanoo.
\q1 
\v 15 Yaaweefa aiqama maqannaasa nimuqusa auqunisaidanoo.
\q1 Misa auqee maria aiqama ainainnara iridanoo.
\q1 
\v 16 Sia moo karaambiqa fannoo narí rakira fasiqa moomoonnaifau rakiranaki uriqaraidanoofau.
\q1 Afeeka sundia sia narí amudaanai qiranannai fau rakiranaki namuqaa urinnaaqaraidanoo fau.
\q1 
\v 17 Rakiranaki maraqa nua qoosausa sia sundiauqa dadaaqifaqa rakirana urinnaaqareefaranoo.
\q1 Mi qoosausa firaa nimudanai qiranannai sia amana moona kuqirana titaqamaqaannoo.
\q1 
\v 18 Yaaweena afu fannoo nariara rufiee mariasa dadaaqirara misasaa maridanoo.
\q1 Yaaweena naaru marira amuqusiranasaa
\q2 mundimariasa misasaa Yaaweena afu fannoo rusinoo maridanoo.
\q1 
\v 19 Mifa kuqiranasaa itita nimaqaidanoo.
\q1 Mifa aandaroo aukuana faqa rakisi nimaqaidanoo.
\q1 
\v 20 Maasa qimana Yaaweenaki kai quqaidanoo.
\q1 Mifa kai maasa dadaaqirafa maasa saqari maridanoo.
\q1 
\v 21 Maasa mina naaquqara andeeqara auqu saqarikunnanara firaaqoo asasidaqa.
\q1 
\v 22 Oo Yaawee ani naaru marira amuqusirafa maasa faqa mariani.
\q1 Maasa anisaa mundiqa maridaqa.
\c 34
\s1 Anutuna amiqirana amooqira idi.
\q1 
\v 1 Qinee aiqama kari Yaaweenara dufi dufi qianaura.
\q1 Qinee sia mina amooqirana munu quqaanaura.
\q1 
\v 2 Qinee mifa auqoo ainaina irisee mina amooqianaura.
\q1 Ummaaraki mariasa minara irisee asasiaqa.
\q1 
\v 3 Innee aniraifaqa maasa Yaaweena auqu qareenaranara koorooia.
\q1 Doo aniraifaqa innisaimbaqa mina auqu uqeeraa.
\q1 
\v 4 Qinee Yaaweenara innaaru qunanoo mifa qini dadaaqinoo.
\q1 Qini rufiaranakinaana iduku qiseenoo.
\q1 
\v 5 Ummaaraki mariasa Yaawee finnai ubeekamafuanara misa asasidaqa.
\q1 Minara misa saqarikirafa sia kuridiannoo.
\q1 
\v 6 Kudi fasiqauqa Yaaweenara innaaru qiafanoo dadaaqidanoo.
\q1 Mifa misa aiqama ummaarakinaana mareeqee kaqinni quqannisaidanoo.
\q1 
\v 7 Yaaweenara rufiee mariasa mina angiroouqa misa
\q2 fiqufiquiqa maridaqa mandainainakinaana maraqunnisaidaqa.
\q1 
\v 8 Aneenna kai Yaaweena firaa amiqiranara oonu mafi iria.
\q1 Yaaweena itita nimaqaranaki kukeeaqa mariasa asasiranaki maridaqa.
\q1 
\v 9 Innee Yaaweena faiqí anaasee innee Yaaweena ameemaanai mariaqa.
\q1 Mina ameemaanai mariasa sia sarauirafa misaki mariannoo.
\q1 
\v 10 Kaasau faini narana sia amanaikianara naara raifaqa kudoosaapaidaqa.
\q1 Yaaweena ufa mau fimariasa sia moo amiqira ainainara sarauifaranoo.
\q1 
\v 11 Innee qini faiqinamu mai aniree qini ufa irifaqa qinee Yaaweenara rufiara oosanara qimannimianaura.
\q1 
\v 12 Yafee moo fasiqa fannoo kaqi mariranara ridanoo fee.
\q1 Anee kisaaqasaa maridana asasiranara aididanoo fee.
\q1 
\v 13 Aidinana anee sia manda ufa qia.
\q1 Anee sia unna ufa qia.
\q1 
\v 14 Manda oosana ameesuqusee amiqira oosana maraa.
\q1 Aneenna aiqama amuqusannoo asooaranara randasee faiqí anaasee faqa moodaanaki maria.
\q1 
\v 15 Yaaweena afu fannoo andeeqarausasaa mundinoo marifanoo rakisi nimaqaidanoo.
\q1 Mina aaqoo fannoo misa nammeeraqiana iridanoo.
\q1 
\v 16 Yaaweefa manda oosana maree mariasara akooqaidanoo.
\q1 Misa kuquafaqa miqoo kai misara qaunidaqa.
\q1 
\v 17 Andeeqara oosana maree mariasa Yaaweena aaraafanoo iridanoo.
\q1 Mifa misa oosana oosana ummaarakinaana dadaaqidanoo.
\q1 
\v 18 Yaaweefa ummaaraki mariasa dadaaqirara naaqa maridanoo.
\q1 Mifa kudoosaapee mariasa dadaaqinoo mara amiqiraqoo quqannisaidanoo.
\q1 
\v 19 Andeeqara fasiqa anaasee ummaara oosana oosana fannoo aupurarana nimifanoo,
\q1 Yaaweefa minakinaana aiqama mareeqee amiqiraqoo quqannisaidanoo.
\q1 
\v 20 Yaaweefa misa aiqama nimudaanisaa rakisidanoo, sia moodaa nimudaani faqa raqanoo mariannoo.
\q1 
\v 21 Manda oosana fannoo manda oosana maree mariasa kuqa naruannoo.
\q1 Andeeqara oosana maree mariasara fidiaqaa
\q2 imariasa Yaaweena narira ufa ameemaanai marifaranoo.
\q1 
\v 22 Yaaweefa narí ainaini maria fasiqausa feefaurummasee kafaa maraidanoo.
\q1 Mifa innai itita qimaqaanifee qimasee fimariasa sia kuridifaranoo.
\c 35
\s1 Dadaaqiani fee innaaru.
\q1 
\v 1 Oo Yaawee qini rairai qimaqimaqee mariasa anee misa faqa rairai qimannimaqaa.
\q1 Qini darimariasa nariqa faqa narua.
\q1 
\v 2 Aneenna rakira saqari faqa rakira ainainauqa namufaqa maree aniree qini dadaaqia.
\q1 
\v 3 Aneenna duru feefa faqa saasuna faqa mara maree aniree qini darirara qifaqaqanuasa narua.
\q1 Anee qini dadaaqiraree qimasee qima qimia.
\q1 
\v 4 Qini darirari mariasa anee rafaaqafu nisainaqa nisauriranaki mariaqa.
\q1 Qini mandaikamma qimaqarara tipundaari mariasa mara quanda sainaqa furufariranaki mariaqa.
\q1 
\v 5 Yaaweena angiroo fannoo misa nifaqaseenoo oofaafanaumuara foora utitiqameeqee aqusaina ufai fannoo aanaaqmaara fuaqa aqindee iannoo.
\q1 
\v 6 Misa nimaria aanafa asukuna faqa farindarafa faqa mariani,
\q1 Yaaweena angiroo fannoo misa nifaqaani.
\q1 
\v 7 Qini namuqaauqa oosana siainaki qini qimaara qufaana fufuseeqa qini qimaarusidaqa.
\q1 Misa fifau qini qimaara madika indufia.
\q1 
\v 8 Oo Yaawee anee dadaaqinaqa qini namuqaauqa sia
\q2 iri marifanoo ummaara fannoo tautummaki misasaa aqufuani.
\q1 Misa nariqa fufuqaa ufaanaki arufi nariqa ummaaraki aqufifaranoo.
\q1 
\v 9 Miqimma fifaqa qinee Yaaweenara asasianauranoo.
\q1 Mifa qini asumu marainara nasurianauranoo.
\q1 
\v 10 Qinee qeeqa qimuqusa aiqamannoo Yaaweenara maaqi qianaura.
\q1 Sia moo fannoo ani fooqaafaa maridanoo.
\q1 Aniara afeeka siaisa afeekaikimariasa nisaukukinaana rafiaana fee qianaura.
\q1 Kudi fasiqauqa mandaikamma nimaqee mariasa
\q2 nisaukukinaana faqa maree marifee qianaura.
\q1 
\v 11 Manda fasiqauqa qinee sia qafaunna ainainara faqa
\q1 sia irunna ainainnara faqa fifau qini rairai qima qimaqaidaqa.
\q1 
\v 12 Qinee amiqi amiqimmannisaunnana akiiqara mandaikamma qimaqeea.
\q1 Miqiafanoo qini qimuqusa firaaqoo ummaarareenoo.
\q1 
\v 13 Qini oosana moomau fidanoo.
\q1 Qini namuqaauqa auriranaki mariafaqa qinee
\q2 misara soofaarira qamunna afisusee qeeqa mara
\q1 maree qumureeqa daararee marufaqa misara findifuaqeera innaaru qimariqiafana.
\q1 Qinee inuka tuqu daumoo amisee findifuaqeera innaaru qimariqiafana.
\q1 
\v 14 Qini namuqaauqa auriranaki marufaqa qini marirafa maaqimminoo marinau.
\q1 Qinee misara qini qiqoondifaqa qini qikaqaafasaa
\q2 faqa qini qinoofa faqa kuqiara foora iafaqa soofaarida kummaaraqa mariqiafana.
\q1 
\v 15 Qini namuqaauqa oosana misa sia qini daanna raidaqa.
\q1 Qinee ummaaraki aqufunaqa misa qiqafamaseeqa
\q2 asasammasee aiqama qini fiqu fiqummafi uteeti qidaqa.
\q1 Qinee aanaamuru misara sia irimarunausa qini dariqa kai maridaqa, sia idooaidaqa.
\q1 
\v 16 Qinee qiku qisauku mandaikirausara foora marunaqa misa qiniara uteeti qidaqa.
\q1 Misa qiniara fidiaqaa imarifaqa qini qiqafaidaqa.
\q1 
\v 17 Oo Yaawee, kisaaqasaa fee anee kaqi nindafaida marinnaree.
\q1 Misa qini kuridi qimaqarara imarianasaa itita qimaqaa.
\q1 Anee maa kaasau fainisa nookinaana qini mareeqee amiqiraqoo kaqinni quqaqisaa.
\q1 
\v 18 Miqimma sainaqa ani faiqí anaasee moomoosa
\q2 suqirana qambaanaindari findifi ani Yaaweenara dufi dufi qianaura.
\q1 Moomoo fasiqa anaasee firaa suqiranaki noorinni oonuree ani amooqianaura.
\q1 
\v 19 Fifau unna qimariasa qini namuqaa qini tataqaida asasifana Yaawee anee titaqisaa.
\q1 Qini qumaara qafamasee fidiaqaaidaqa noorinnai
\q2 nifunnai unnamaanna qimariasa anee misa faqa rafaaqafunnimaqasaa.
\q1 
\v 20 Misa nifauru fannoo sia asooara ufa aqoondikira ufa
\q2 qimarisa, misa oosana oosana unna ufauqa faqa ida qai ufana faqa kai qimariasa maridaqa, misa
\q1 unnamaanna qiranara randasee mareeqee asooaranaki mariasa nimuaaqa aqidaqa.
\q1 
\v 21 Qini namuqaauqa fifau firaaqoo noo raqasee qini
\q2 kikiqususeeqa qiniara eeoo eeoo maasa qifu
\q1 fannoo mina aaqarana qafee fee qidaqa unnaqidaqa.
\q1 
\v 22 Misa miqi qimariafana, oo Yaawee, anee misa unnaqirana qafaananoo.
\q1 Anee sia ufa siaina maria, anee sia nianai maria, daaqa ani marida dadaqia.
\q1 
\v 23 Oo Yaawee, anee faiqara see findifi qini itita qisaa.
\q1 Oo qini Anutu findifinana qini ufa afeekaikamma qimaqaa.
\q1 
\v 24 Oo Yaawee, qini Anutu, anee andeeqarafa, anee qiniara sia aaqarana siai fee qia.
\q1 Anee qini dadaaqinaqa qini namuqaa qiniara ataasa ataasa qiaqa.
\q1 
\v 25 Anee qinaqa qini namuqaauqa sia nári nimuqusakiqari maaqi qimasee qiniara qiaqa.
\q1 Eeoo maasa qunnandee kai qinoo mina mandainaina doo kambiqeenoo fee qiaqa.
\q1 
\v 26 Qini ummaara qafamasee nasuri mariasa anee misa aupuraranaki quqannisaa.
\q1 Anee misa nisauriranaki quqasee furufaramma nimaqaa.
\q1 Anee misa nisauriranannoo faqa noori runiranannoo faqa qamunnara foora dukunimma nimaqaa.
\q1 
\v 27 Qini andeeqaranara irisee qini iduku qimaqarara
\q2 irimariasa kaifaa kaifaa maaqi qimasee faaqaridaqa asasiaqa.
\q1 Yaaweefa kaaqa uriqararafa maridanoo.
\q1 Yaaweefa qini narí ainainira faiqi qinee auqaunna
\q2 ainainafa anoona kambiqainara iriseenoo asasidanoo.
\q1 
\v 28 Miqinaqa qinee ani andeeqaranara kananaana
\q2 oosana arasee ani amooqianafa eedirana kai raquru amianaura.
\c 36
\s1 Faiqí faiqi mandoosanara qirufa.
\q1 
\v 1 Numoo fannoo manda oosana maree mariasa
\q2 nimuqusaki maridanoo akaqa aaqara oosanara naakapaidanoo.
\q1 Anutuna minnisee sia minara rufiee marianara manda oosanara irirafa nimuqasaki kambiqaidanoo.
\q1 
\v 2 Miqi mariasa nári kai náriara kaaqa uriqararausee qidaqa,
\q1 Anutufa maasa aaqarana sia amana qafamasee maasa ufa qimiannoo fee qidaqa.
\q1 
\v 3 Misa nookinaa ufa fannoo manda ufa faqa unnufa faqa kai maridanoo.
\q1 Misa sia iriqaraasammasee auqara oosanara faqa andeeqara oosana faqa auqaidaqa.
\q1 
\v 4 Misa nári qaarisaa faiaqee idaqa manda oosanara oonumafi irida maridaqa.
\q1 Misa sia moo andeeqara oosana auqaidaqa, misa manda oosanara faqa sia qaoo qidaqa.
\s1 Anutuna Andeeqara Oosana.
\q1 
\v 5 Oo Yaawee, ani sia takaaninna amuqusirafa innaaruna amana kai ooru maridanoo.
\q1 Ani mapukusee marira oosana fannoo oonnamu amana kai ooru maridanoo.
\q1 
\v 6 Ani Yaaweena andeeqarafa firaa aaqananamuara foora uriqaranoo maridanoo.
\q1 Anee maasa ufa irisee andeeqasee raina qimaqara
\q2 oosana fannoo ooruku nammari farumara foora meemai uqanna maridanoo.
\q1 Faiqí faqa aandau faqa ani rakisinnimaqarana ameemaanai maridaqa.
\q1 
\v 7 Oo Yaawee ani maasara amuqusirafa firaa feefauru aqimaria ainainnafara foora maridanoo.
\q1 Maasa ani aqoosa ameemaanai keeqafi mandaaqaidaqa.
\q1 
\v 8 Oo Yaawee anee rairaamma nimianna naranna oomaqa sakasee naidaqa.
\q1 Anee qinaqa maasa ani andeeqara oosana nammariara foora naa.
\q1 
\v 9 Anee aiqama marirana oosana mariananoo.
\q1 Anee kaaqa qarafa mariannanara maasa kaaqa qarana qafaidaqa.
\q1 
\v 10 Oo Yaawee anee aneenna amuqusirana aniara irimariasa kaifaa kaifaa nimida kai maria.
\q1 Anee aneenna andeeqarana andeeqara aatata fimariasa nimidana kai maria.
\q1 
\v 11 Anee qinaqa nári nimoo naamoo imariasa sia nikunnai qini rafaaqafu qimaqaaqa.
\q1 Anee qinaqa manda oosana maree mariasa sia qini daru qifaqaaqa iaqa.
\q1 
\v 12 Niqafaa, manda oosana maree mariasa doo saamuriqa maridaqa.
\q1 Misa maqasaa aqufiqa sia amana kafaa
\q1 findififaaranoo. Miqoo kai marifaranoo.
\c 37
\s1 Andeeqara fasiqa faqa manda fasiqa faqa mariranara qidanoo.
\q1 
\v 1 Anee aaqara oosana maree mariasa nindafamasee
\q2 sia minara aiaaqee qimasee sia qinee misa dadaaqunoo sia qia.
\q1 Manda oosana maree mariasa nindafamasee sia minara qinee faqa sia maraunoo qimasee arana qaani.
\q1 
\v 2 Misa miqi marianara amukafaqaa sanda miqirausa
\q2 qusasaa ateeka saifaqa qammundeefaranoo, misa
\q1 andanda miqirausa maridaqa qusasaa aadanusifaranoo.
\q1 
\v 3 Yaaweena saqarikida andeeqara oosana kai maraida maria.
\q1 Anee miqidana maa maqa maaqanaki kisaaqasaa
\q2 kaqi marinanoo sia moo ainaina fannoo ani mandaikamma amaqaannoo.
\q1 Anee aneenna maqa maaqaki kai marida asooaranaki maria.
\q1 
\v 4 Yaaweenaki asasamasee marinanoo ani amuqusaki aidimari ainainna ani amiannoo.
\q1 
\v 5 Anee aneenna marirana nirana Yaaweena amisee
\q2 mina saqarikammasainanoo mifa maa ainainna ani amiannoo.
\q1 
\v 6 Mifa ani andeeqara oosana dadaaqinanoo suani qambaanara foora amiqimmasee kaaqa qaanoo.
\q1 
\v 7 Anee Yaaweena oorinni afaaqa quqasee ireeda maria.
\q1 Manda oosana maree mariasa aaqara oosanara
\q2 tipundaarifanoo anoona kambiqainana sia qeeqara faqa miqianee qia.
\q1 Sia moomoo qumiasana faqaasa niqafamasee sia qinee faqa miqiunoo qia.
\q1 
\v 8 Anee mina qafamasee sia moomoo irira iria.
\q1 Sia aanoo qia.
\q1 Mi oosanafa ummaaraki nifiqee fidanoo.
\q1 
\v 9 Manda oosana faqaasa Yaaweefa misa aiqama taikannimaqaannoo.
\q1 Irirana Yaaweenasaa mundimariasa maa maqanasaa amiqimmasee marifaranoo.
\q1 
\v 10 Kaqikaaqoo marikinanoo doo miqoo mandoosana maree mariasa taikeefaranoo.
\q1 Anee misara randeenana sia paqurinnaranoo.
\q1 
\v 11 Nári mara maree qumi mariasa Yaaweefa aiqama maqa nimiannoo.
\q1 Misa miqoo aiqama ainaina rairaa imarinaqa asooaranaki maridaqa asasifaranoo.
\q1 
\v 12 Manda oosana maraqanuasa andeeqarausa nariraree qimasee tipundaaridaqa.
\q1 Miqidaqa misa andeeqarausara fidiaqaaira noori nifiri maraidaqa.
\q1 
\v 13 Yaaweefa qusasaa misa mandaikamma nimaqaaninnanara iriseenoo naanaidara qidanoo.
\q1 
\v 14 Manda oosana maree mariasa kudi fasiqa anaasee
\q2 faqa sarauiranaki mariasa faqa andeeqara aatata
\q1 fimariasa faqa nariraree qimasee nári faaqaana
\q2 mai qumaree duru rakisisee nimaarusida maridaqa.
\q1 
\v 15 Misa nariqa rakira faaqaana fannoo nári nimuqusa raquru nimiannoo. Misa duru faqa raudaannoo.
\q1 
\v 16 Andeeqee mari fasiqana ainaina oodaa mariannoo,
\q1 Anutuna afusaa uriqaranoo maridanoo.
\q1 Manda oosana maree mari fasiqana ainaina moomoo
\q2 maridanoo, Anutuna afusaa ureeqanoo maridanoo.
\q1 
\v 17 Minara manda oosana maree mariasa Anutufa misa afeeka mara maraannoo.
\q1 Andeeqee mariasa Yaaweefa itita nimaqaannoo.
\q1 
\v 18 Yaaweena ufa mau fimariasa Yaaweefa misa marirana niranasaa rakisidanoo.
\q1 Maa maqa maaqafa misaindikinoo naaruara mariannoo.
\q1 
\v 19 Miqi mariasa manda aukuana anirainaqa sia aupurarana mareefaranoo.
\q1 Aandaroo aukuana misa narana moomoo mariannoo.
\q1 
\v 20 Mandoosana maree mariasa kuqifaranoo.
\q1 Yaaweena namuqaauqa taatuqeena kakasindee ifaranoo.
\q1 Misa ida muna qusasaa marinoo taikaindee ifaranoo.
\q1 
\v 21 Manda oosana maree mariasa moosa ainaina ufaasu maraseeqa sia kafaa nimidaqa.
\q1 Andeeqarausa oosana moo maridanoo, misa afaarida kaqi nimimariasa maridaqa.
\q1 
\v 22 Yaaweefa amiqi amiqimmanimaqee marisa misa nári maqa maaqaki amiqimmasee marifaranoo.
\q1 Yaaweefa niquraree marisa mina maqasaa mariana mara qaqusainaqa quqasee fifaranoo.
\q1 
\v 23 Andeeqara fasiqa niranara Yaaweefa asasidanoo dadaaqidanoo.
\q1 Yaaweefa asasi maria fasiqa anaaseesa itita nimaqaidanoo.
\q1 
\v 24 Mi andeeqara fasiqafa saamurinoo maqasaa aqufinoo sia miqinoo mariannoo findifuannoo.
\q1 Yaaweefa uqeerainara miqiannoo.
\q1 
\v 25 Qinee kumaaraa mariiafanausa doo maqee asooqa maridaqa,
\q1 Yaaweefa andeeqarausa minninnisoona sia qinee mi kamu qafaqiafana.
\q1 Mina faiqi namu naranara sarauida innaaru qirana faqa sia qafaqiafana.
\q1 
\v 26 Andeeqarausa aiqama kari afaari mariasa maridaqa.
\q1 Sarau imariasa iraafaqa eedooo qimasee kaqi ufaasu
\q2 nimidaqa, misa faiqi namu faqa amiqi amiqiranaki marifaranoo.
\q1 
\v 27 Anee manda oosanakiqari quandakinana andeeqara oosana maraa.
\q1 Miqinaqa ani faiqi namu ani maqasaa naaruara marifaranoo.
\q1 
\v 28 Yaaweefa andeeqara oosana maree mariasara
\q2 aididanoo narí ufamau mapukusee fimariasa faqa
\q2 sia minninnisaannoo, misasaa naaruara titannimaqaannoo.
\q1 Manda oosana maree mariasa faiqi namu mara aqusaannoo.
\q1 
\v 29 Andeeqarausa nári nikausa ninaakusa maqa maaqa
\q2 umiasanara foora maraseeqa, minaki naaruara marifara.
\q1 
\v 30 Andeeqarausa nifauru fannoo irirana faqaasa ufa kai qidanoo.
\q1 Mina afauru fannoo qambaana andeeqara ufa kai qidanoo.
\q1 
\v 31 Anutuna sanda ufa andeeqarausa nimuqusaki maridanoo.
\q1 Minara misa sia quqasee moosaa fifaranoo.
\q1 
\v 32 Manda oosana maree mariasa andeeqarausa nipuraida narirara nimaarusidaqa.
\q1 
\v 33 Yaaweefa sia andeeqarausa manda oosana maree mariasa nisaukuki quqasaifaqa naridaqa.
\q1 Manda oosana maree maria fasiqausa andeeqarausa
\q2 ufaki quqasaifanoo Yaaweefa misa titannimaqainaqa sia narifaranoo.
\q1 
\v 34 Anee aneenna irirana Yaaweenaki quqasee mina ufa mau kai andeeqasee fua.
\q1 Anee miqimarinanoo Yaaweefa ani firaa auqu
\q2 amiseenoo ani aanaakusa akausa maqa maaqa amiannoo.
\q1 Mifa minaki manda oosana maree mariasa mara aqusaina qafamasee kuqaa fee qinnaranoo.
\q1 
\v 35 Qinee Dafidisa, mandoosana maree mari fasiqana
\q2 qafaafananoo firaa saqari miqirafa Reebanoona
\q2 amiqira maqasaa kambiqafi ititanoo mariara foora inoo marinau.
\q1 
\v 36 Mifa qusasaa marinoo doo taikafifaqa qinee
\q2 qafaunanoo sia marifaqa randeeqa sia uqanna paquriqa.
\q1 
\v 37 Anee ufa siai fasiqana faqa andeeqara aatata fimari fasiqana faqa niuqummasee qafaa.
\q1 Asooara oosanaki reendeennammasee mariasa maa
\q2 maqanasaa misa saaqari kambiqainausa faqa kisaaqasaa marifaranoo.
\q1 
\v 38 Aaqee mariasa Yaaweefa aiqama uqanna kuridi nimaqaannoo.
\q1 Manda oosana maree mariasa niku nisauku marirana Anutufa ateekasaina sia marifaranoo.
\q1 
\v 39 Ummaara aukuana Yaaweefa andeeqarausa itita nimaqasee asumu maraidanoo.
\q1 
\v 40 Yaaweefa andeeqarausa dadaaqinoo manda mariranakinaana uqeerannisaidannoo.
\q1 Aaqee mariasa nisaukukinaana asumu mareeqee
\q2 kaqinni quqannisaidannoo. Misa Yaaweena mandaaqee marianara asumu maraidanoo.
\c 38
\s1 Ummaaraki mari fasiqana innaaru.
\q1 
\v 1 Oo Yaawee, aneenna aanooqiranakiqari sia qiniara aanooqia.
\q1 Aneenna aranaqaranakiqari sia qini ummaara qimia.
\q1 
\v 2 Anee feefara foora amiqimmasee qini tapooqaananoo.
\q1 Ani asauku fannoo firaaqoo qini radamimarifaqa ummaara maraidaqa.
\q1 
\v 3 Anee qiniara aanooqiannanara qini qifaaqa firaaqoo didafidanoo.
\q1 Qini numoo marinara qini qimudaani umooqukinoo marifaqa sia afeekaikidaqa.
\q1 
\v 4 Qini aaqara ummaara fannoo qini rafaaqafu qisaidanoo.
\q1 Mifa firaa ummaara maridanoo, sia qinee amana akuanaura.
\q1 
\v 5 Qini furufarirafa marinara qifaaqa ateekeeqaafanoo adiara usufifanoo afundida putaaidanoo.
\q1 
\v 6 Qinee ummaaraki maridaqa maqasaa aqufiqa
\q2 maridaqa, aiqama faasaana suani afu ururarana
\q2 namu faqa soofaarida kummaraqa maridaqa iki
\q2 raqaida marunanoo suani afu keeqaidanoo.
\q1 
\v 7 Qini qifaaqa idara foora qaidanoo.
\q1 Qinee kuqirana adeedi raqa maridaqa.
\q1 
\v 8 Qini qimudaani raqanoo mariara foora qumooqukiqa nidaqa.
\q1 Qini qimuqusa firaaqoo didafi marinara annadannada qida maridaqa.
\q1 
\v 9 Oo Yaawee qini didimari ainainausa ani afusaa akooqoo marifana iri mariananoo.
\q1 Qini didafi marifaqa annadannadirafa ani afusaa sia kukeeqanoo maridanoo.
\q1 
\v 10 Qini qimuqusa rundurundi marifanoo qini afeeka taikeenoo.
\q1 Qini afeeka doo quminoo, qini qifusaa mari kaaqa qarafa doo taikafifanoo asukuna kai titeenoo.
\q1 
\v 11 Qini qiqoondiuqa faqa qini faqa nimariasa faqa qini nammuana qafeeqa rufiasee niana tatutatuidaqa.
\q1 Qini qiqoonausa faqa miqikaimmidaqa rufiqa rufiqa idaqa.
\q1 
\v 12 Qini darirara randee mariasa qufaana fufidaqa.
\q1 Qini mandaikamma qimaqarara ufa qimariasa maridaqa.
\q1 Suani afu ururarana namufaqa tipundaarida mariafanoo suani afu keeqaidanoo.
\q1 
\v 13 Qinee daaqoo qaunirausara foora sia misa ufa iriqa doo qummunirausara foora sia qimannimidaqa.
\q1 
\v 14 Qinee sia ufa irimaria fasiqausara foora maridaqa,
\q2 qeeqa dookiqari qimannimirara sia amanaikidaqa.
\q1 
\v 15 Oo Yaawee qinee ani kai saqarikidaqa.
\q1 Oo Yaawee qini Anutufa anee qini ufa qima qiminnaranoo.
\q1 
\v 16 Oo Yaawee qini namuqaa sia qini mandaikamma qimaqasee nasuriaqa.
\q1 Qini qiku farindamaki aqufuanaqa sia nasurida asasiaqa.
\q1 
\v 17 Qinee saamuruaqaammidaqa.
\q1 Qini didafirafa kisaaqasaa qini faqa maridanoo.
\q1 
\v 18 Qinee qeeqa aaqarana akooqoo kooroomasaunanoo,
\q2 qini numoo fannoo qini qummaara qimidanoo.
\q1 
\v 19 Qini namuqaauqa moomoosa nimudaanai qimariasa maridaqa.
\q1 Qiniara fifau fidiaqaa imariasa moomoosa maridaqa.
\q1 
\v 20 Qini amiqira oosana akiiqara mandaikammaqimaqee
\q2 mariasa misa qinee andeeqaramau fimarunaqa
\q2 misa qini namuqaakamma qimaqaidaqa.
\q1 
\v 21 Oo Yaawee qini Anutu, sia qini minniqisaa, sia nianai maria, daaqa ania.
\q1 
\v 22 Oo Yaawee qini asumu maree marianafa kai kaqi aniree qini dadaaqia.
\c 39
\s1 Ummaaraki mari fasiqana numoo kooorooira ufa.
\q1 
\v 1 Qinee Dafidisa qeeqara maaqi qiqa, qinee qeeqa nirana mariranasaa rakisianaura.
\q1 Qini qifauru fannoo sia aaqara ufa qiannoo.
\q1 Manda oosana maree mariasa qini daaqa marifaqa sia qinee moo manda ufa qianaura.
\q1 
\v 2 Qeeqa ufa rafaaqa fusee doo qummunimmasee marunanoo mifa sia dadaaqinoo.
\q1 Doo qummunimmasee sia amiqira ufa faqa
\q2 qimarunanoo qini daundurakinaa ummaara firaanaikinoo.
\q1 
\v 3 Doo qummunimmasee marunanoo qini daundurai qimuqusaki idara foora aurinoo.
\q1 Qinee firaaqoo oonumafi irimarunanoo qini daundurai firaaqoo idaqeenoo.
\q1 Idaqee marifaqa qinee sia doo qummunimmasee marianaura.
\q1 
\v 4 Oo Yaawee qinee taikaanna aukuannara qinaqa iria.
\q1 Yairee fee qinee kuquanauree.
\q1 Qini marirafa munu taikaaninnanara faqa qima qimia.
\q1 
\v 5 Anee qini marirana qusa uqanna ramasaananoo.
\q1 Qini marirafa ani afusaa fifau ainainara foora sia maridanoora foora maridanoo.
\q1 Aiqama fasiqa fifau naidoora foora kai maridaqa.
\q1 
\v 6 Aiqama fasiqauqa nimanandara foora marida nidaqa.
\q1 Miqi mariasa aiqama ainaina fifau kai kadaapi ridaqa.
\q1 Maaqoo maridaqa qumiasana suqu quqaseeqa
\q2 kuqifanoo yafee maraannoo fee qimasaida sia iridaqa.
\q1 
\v 7 Oo Yaawee qinee nana moo ainainara afeesianauree.
\q1 Qini irirafa aniki maridanoo.
\q1 
\v 8 Qini aiqama numoo kinaana mareeqee kaqinni quqa qisaa.
\q1 Miqimma sainaqa furufarirausa sia qiniara naanaidara qiaqeera.
\q1 
\v 9 Anee kai maa aupurarana qimi marianafa
\q2 mariannanara qinee doo qummunimmasee
\q2 qireeda kai maridaqa sia ufa qianaura.
\q1 
\v 10 Sia kaifaa qini mandaikamma qimaqaa.
\q1 Anee qini daruanaqa kuqirara miqidaqa.
\q1 
\v 11 Faiqí aaqara oosana maraasara anee Anutufa
\q2 afeekaikaqmmasee aanoo qima amaqasee mina
\q2 idi mari ainainna kuridi aisee mariananoo.
\q1 Qumura mandaikindee idanoo.
\q1 Aiqama fasiqauqa ani afusaa aidoora foora qusasaa fuaqaki taikaidaqa.
\q1 
\v 12 Oo Yaawee qini innaaru qirana iria.
\q1 Qini dadaaqianneera aaraunnana aaqoo rammatinimmasee irisee qini dadaaqia.
\q1 Qinee ani dadaaqiranara qiki raqaidaqa nammeera qianana dadaaqia.
\q1 Qinee qusasaa maa maqanasaa ani faqa mariqa,
\q2 qeeqa qikeeku qikaaku naanna reeqa qusasaa kai maridaqa.
\q1 
\v 13 Oo Yaawee ani oori afiriara kaaqa daaquqaidanoo
\q2 anee kaqinni anneenna oori ubeekamasainaqa
\q2 qinee qusasaa asasiranaki mariqa kuqua.
\c 40
\s1 Anutuna amooqira idi.
\q1 
\v 1 Qinee Yaaweenara deendeena mandee afeesida
\q2 marunanoo, mifa quandafi qini nammeera qirana
\q2 amiqimmasee irisee qimudaoo qimasee dadaaqinoo.
\q1 
\v 2 Qinee qeeqa aaqaranaki doona doona imarina kiara
\q2 foora faqa faurima saara foora faqa farindamaki
\q2 kuqira madikaki faqa afundimari doonna kiara
\q2 foora faqa marunanoo minakinaana mifa qini
\q2 uqeereeqeenoo oonisaa kikiqammaqiseenoo.
\q1 
\v 3 Miqoo mifa fuka idi qini qima qiminoo mi idifa maasa Anutuna amooqira idi maridanoo.
\q1 Moomoosa mina qafamasee rufiasee Anutuna saqarikifaranoo.
\q1 
\v 4 Yaaweena saqariki mariasa asasiaqa.
\q1 Tumunnai auqira anutufinnai sia ubeekee mariasa
\q2 faqa unnaqira anutusa sia nimooqi mariasa faqa asasiaqa.
\q1 
\v 5 Oo Yaawee qini Anutufa anee moomoo afeeka naaquqara ainainannoo maasa dadaaqinau.
\q1 Sia moo fannoo ani fooqaafa maridanoo.
\q1 Anee moomoo amiqira irirausa maasara aneenna iriranaki qimirisaidana dadaaqi mariananoo.
\q1 Qinee minauqara ufa qianee qimasee sia amana aiqamara ufa qianaura.
\q1 Mifa moomoo maridanoo.
\q1 
\v 6 Andau tatufirana faqa oosana oosana ani amira ainainara faqa anee akooqananoo.
\q1 Anee aneenna aidimarianna tatufiranara ani ufamau firana qini daaqooki quqasaana iriaa.
\q1 Aandau ida tatufirana faiqí aaqarana akiiqara amiranara faqa anee sia qimiannee qiananoo.
\q1 
\v 7 Qinee minara iriseeqa maaqi qiqa.
\q1 Doo qinee anireeqa.
\q1 Anutuna akarakinaafa qinee aniannanara qifaqa anidaqa.
\q1 
\v 8 Oo qini Anutu, ani aidirana mau firara firaaqoo dididanoo.
\q1 Ani sanda ufa qini qimuqusaki maridanoo.
\q1 
\v 9 Qinee ani faiqí anaasee moomoosa suqiqa mariana
\q2 qambaanai anee maasa asumu maraannanara
\q2 andeeqara ufa kai qimannimidaqa.
\q1 Oo Yaawee qinee sia qeeqa doo qummunianaura, kaqi qimannimianaura.
\q1 Anee minara irimmariananoo.
\q1 
\v 10 Qinee sia anee qini dadaaqinana qini asumu
\q2 maraannanara qeeqa qimuqusaki rafaaqa fiqa, kooroomasee qimannimiqa.
\q1 Ani mapukusee marira oosanara faqa ani asumu nimirana faqa kooroommasee qimannimiqa.
\q1 Faiqí anaasee moomoosaki anee misara amuqusirana
\q2 faqa ani kuqaa anoona ufa qirana faqa sia rafaaqa fiqa, kaqi qimannimiqa.
\q1 
\v 11 Oo Yaawee qinee iridaqa ani qiniara qimudaoo qirafa sia taikaannoo.
\q1 Ani amuqusirafa faqa ani kuqaa anoona ufa qira oosana faqa qini itita qimaqeenoo.
\q1 
\v 12 Qini mandoosana moomoo sia asaanarirana amana qini Dafidisa fiqu fiqu inoo maridanoo.
\q1 Qini aaqarafa doo qini rafaaqafusaifaqa sia qifu maqaidaqa.
\q1 Qini qikiiqa qisausi moomoo maridanoo, qini
\q2 aaqarafa mina faqa uriaaqaranoo sia asaanarirana amana maridanoo.
\q1 Minara qini qimuqusa ummooquki fanoo qini afeeka taikaidanoo.
\q1 
\v 13 Oo Yaawee anee qini mandainainakinaana mara quqaqisaa.
\q1 Oo Yaawee kai kaqi aniree qini dadaaqia.
\q1 
\v 14 Qini marirana taika qimaqarara randeemariasa
\q2 rafaaqafu nimaqasee mareeqee furufariranaki quqannisaa.
\q1 Qini aupuraranara asasimariasa mara
\q2 quandasainaqa nisaurusee quqasee sandaaqa.
\q1 
\v 15 Qiniara uteeti qimariasa misa nariqa nisaurirana firaafa marina qafeeqa firaaqoo tautiaqa.
\q1 
\v 16 Oo Yaawee anee iannannai ani mariasa asasida nasuriaqa.
\q1 Ani asumu mariranara dufi dufi qimariasa aiqama
\q2 kari maaqi qiaqa Yaaweefa kaaqa uriqararafa maridanoo fee qiaqa.
\q1 
\v 17 Qinee Dafidisa qimudaani radukirausa saraui
\q2 marunna fasiqausa marunnanara oo Yaawee anee sia qiniara qaunuananoo.
\q1 Anee qini asumu maree marianafa faqa qini Anutufa
\q2 faqa mariannanara kai kaqi aniree qini dadaaqia.
\c 41
\s1 Aurira fasiqa innaaru.
\q1 
\v 1 Kudi fasiqa aanaaseera irisee dadaaqi mariasa asasiaqa.
\q1 Ummaara aukuanaki Yaaweefa miqimariasa uqeera kaqinni quqannisaannoo.
\q1 
\v 2 Kudi fasiqa anaasee dadaaqimariasa Yaaweefa
\q2 ititannimaqaseenoo misa maa maqanasaa
\q2 marirana afeekaika masainaqa kisaaqasaa marifaranoo.
\q1 Maa maqa maaqanasaa marirana mifa amiqi amiqimannimaqaannoo.
\q1 Sia mifa misa namuqaa nisaukuki quqaannoo.
\q1 
\v 3 Miqi maria fasiqa aanaaseesa auriranaki marifanoo Yaaweefa misa dadaaqiannoo.
\q1 Misa aurida marifanoo Yaaweefa misa aurirana taikannimaqaannoo.
\q1 
\v 4 Qinee maaqi qidaqa, oo Yaawee qinee ani mandaikamma amaqeeqa.
\q1 Anee qini qifauamasee qini auriranara foora taikaqisaa.
\q1 
\v 5 Qini namuqaa qiniara nimuqusa ummaara reemarifaqa maaqi qidaqa.
\q1 Yaireefee mi fasiqafa kuqinaqa maasa minara qaunuanauranoo.
\q1 
\v 6 Qinee aurimarunaqa akaqausa ani qiqafeeqa qisee ufoo qidaqa unnaqidaqa miqidaqa.
\q1 Misa unna ufa irisee raudamaki oonuree aiqama tinai qini qifasaasa qidaqa qimannimidaqa.
\q1 
\v 7 Aiqama qiniara fidiaqaa imariasa nupiqnupita kiqari nári qimami nári qimami qidaqa.
\q1 Qini mandainaina daruani fee qidaqa miqi qidaqa.
\q1 
\v 8 Misa qiniara manda aurirafa aukainaina aurirafa mina arifanoo amiqimandee auridanoo mifoo qidaqa.
\q1 Doo mifa rinoo maridanoo, sia findifuannoo, kuquannoo fee qidaqa qimatundaidaqa.
\q1 
\v 9 Qini qifaaqasaa qiqoondi, qinee minasaa
\q2 mundimarunna fasiqafa, qini faqa neeneeu
\q2 fasiqafa, mifa narí aiku qumbaqi uqeera qumaree aiku ataannai qini darinoo.
\q1 
\v 10 Oo Yaawee, anee qiniara amuqusinana qini
\q2 uqeeraqisee afeeka qiminaqa mina akiiqara mannimaqaa.
\q1 
\v 11 Oo Yaawee qini namuqaa sia qini uridaaqaree
\q2 mariafaqa qinee mina qafamasee oo Yaaweefa
\q2 qiniara aidimarifanoo miqidanoo fee qidaqa qimiridaqa.
\q1 
\v 12 Anee qini andeeqara mariranara irisee qini uqeera qisainaqa naaru naaru ani oorisaa maria.
\q1 
\v 13 Yaaweena Isaraee maqannaasa Anutuna amooqia.
\q1 Maqee faqa naaru naaru faqa amooqima amaqaa.
\q1 Kuqaa uqanna kafaa kuqaa fee qidaqa.
\c 42
\ms1 Mina Anaaqianaa Papiqa (Book 2)
\mr Idi Ufa 42–72
\s1 Asaqi moosaa oonu maru fasiqana innaaru.
\q1 
\v 1 Aandau nammariara aidifanoo maqee maqee aannanai aannanai qidanoo.
\q1 Qini maraquna fannoo misa naanna raida maqee
\q2 maqee oo Anutu ani aaqa mariranara didimarifaqa
\q2 daannanai daannanai idara foora maridaqa.
\q1 
\v 2 Qini nammariara foora kaqi marira Anutunara dididanoo.
\q1 Yairee fee qinee oonuree minara innaaru qianaura.
\q1 
\v 3 Qini namuqaauqa moomoo kari qiniara yaqoo fee
\q2 ani Anutufa marifanee qiafaqa qinee mina iriseeqa qikiraqaidaqa.
\q1 Faasaana faqa eendaki faqa qeeqa daiqunu daukunu naidaqa.
\q1 
\v 4 Qinee ooqai iafannanara irunanoo qimuqusa mandaikidanoo.
\q1 Ooqai qinee moomoo fasiqa anaasee
\q2 indaarunnikiafanaqa Anutuna amaana maqaki fimariqau.
\q1 Oonuree faaqa fuisee qida asasida Anutunara dufi dufi qira idiuqa reemariqau.
\q1 
\v 5 Nanaree qini daundura kaaqa ummaara raidanoo fee, nanaree qinee kaaqa ummaaraki maridee.
\q1 Qinee Yaaweenasaa kai irirana mundusee kaifaa mina amooqianaura.
\q1 Mifa qini asumu maree marifa faqa qini Anutufa faqa maridanoo.
\q1 
\v 6 Oo qini Anutu, qinee ummaaraki maridaqa Yooradanna maqa maaqaki faqa
\q1 Qeeramoona aaqanasaa faqa
\q1 Misaraa aaqanasaa faqa maridaqa aniara irianaura.
\q1 
\v 7 Qini ummaara firaafa ooruku nammariara foora mandinoo maridanoo.
\q1 Mi nammarina qamakaurirafa narisaa narisaa arinoo sandaaqai ooru fidanoo aiai qidaoo.
\q1 Mifa innaarunaindari oondaindariara foora aaku
\q2 quminoo maqasaa aqufifanoo firaaqoo aiai qidanoo.
\q1 Ani mi nammari amakaurirafa qini uridaaqaramafi rafaaqafu qimaqaidanoo.
\q1 
\v 8 Faasaana Yaaweefa narí sia taikara amuqusirana aiqainanoo qinisaa qumuani.
\q1 Miqinaqa eendaki qinee minara dufi dufi qira idi raanaura.
\q1 Qinee Anutufa qini mariranasaa rakisi marina innaaru qima amaqaanaura.
\q1 
\v 9 Anutufa qini itita qimaqee marinara qinee minara maaqi qidaqa.
\q1 Nanaree anee qini qaunuqiseenanee.
\q1 Naqifee ifaqee qini namuqaa aupurarana qimi mariafaqee oonuree aniree iqa nidee.
\q1 
\v 10 Qini namuqaa qini ataasa ataasa ufa qima qimaqee
\q2 mariafaqa kuqirafa qusaree marifaqara foora aupuraidaqa.
\q1 Faasaambaasaana qiniara ani Anutufa yaifee maridanoo fee qidaqa.
\q1 
\v 11 Nanaree qini daundura kaaqa ummaara raidanoo fee.
\q1 Nanaree qinee kaaqa ummaaraki maridee.
\q1 Qinee Yaaweenasaa kai irirana mundusee kaifaa mina amooqianaura.
\q1 Mifa qini asumu maree marifa faqa qini Anutufa faqa marinara mina amooqianaura.
\c 43
\s1 Asaqi moosaa oonu maru fasiqana innaaru.
\q1 
\v 1 Anutu ani ufa sia iri mariasa qini rafaaqa fidaqa,
\q2 anee qini dadaaqinaqa qifairi mariasa ufa
\q2 urinnaaqarama saanaqa qiniara andeeqara oosana faqaafee qiaqa.
\q1 Ueeqee mariasa faqa mandoosana faqaasa faqa nisaukukinaana qini maraquqisaa.
\q1 
\v 2 Oo Anutu anee qini titaqimaqee marianafa mariananoo.
\q1 Nanaree qini minniqiseenanee.
\q1 Nanaree qini namuqaa aupurarana qimi mariafaqee oonuree aniree iqa nidee.
\q1 
\v 3 Oo Anutu anee aneenna kaaqa qarana faqa anoona ufa qirana faqa niqiqainaqa qini aana muquniaqa.
\q1 Mi irira qanda qini mareeqee Sioona ani naaquqara
\q2 aaqanasaa, mari amaana maqanaki anee mariannaqoo quqaqisaaqa.
\q1 
\v 4 Qinee miqoo maridaqa Anutuna qaidara mariqoo mina amooqirara fuanaura.
\q1 Kaaqa asasirana faqa kaaqa nariara didirana faqa qimimari Yaaweefa miqoo maridanoo.
\q1 Oo Anutu qini Anutufa qinee piripuna aridaqa ani amooqianaura.
\q1 
\v 5 Nanaree qinee kaaqa doori runusee maridee.
\q1 Qinee Yaaweenasaa kai irirana mundusee kaifaa mina amooqianaura.
\q1 Mifa qini asumu maree marifa faqa qini Anutufa faqa marinara mina amooqianaura.
\c 44
\s1 Isaraee maqannaasa Anutufa dadaaqianifeera innaaru quu ufafa.
\q1 
\v 1 Oo Anutu, maasa qikeeku qikaaku ooqai anee auquqoonna ainainnara qimaqimiafaqa iridaqa.
\q1 Maasa qeeqa daaqoonnai misa marukamuqoo auqoonna firaa ainainnara qima qimiafaqa iriqa.
\q1 
\v 2 Anee aneenna kai aanaamuru niqiqamasoona
\q2 amaaramafufana maasa qikeeku qikaaku maa maqa maaqanaki mara quqanau.
\q1 Anee aanaamuru aupurarana nimisee Isaraee maqannaa maa maqanasaa mara quqasoonaqa
\q2 faiqí moomoo kambiqafi maa maqa maaqana amanakai maridaqa.
\q1 
\v 3 Isaraee maqannaasa sia nári rakiranannaifau maa maqa maaqana maraqau.
\q1 Sia nári afeekannaifau maraqau.
\q1 Anee aneenna afeekannai faqa eeraariranannai faqa
\q2 oori inaa inaa iranannai maa maqana mara niminau.
\q1 Anutu, anee misara ani aidi marunara miqinau.
\q1 
\v 4 Anee qini karaambaiqa qini Anutufa mariananoo.
\q1 Anee aneenna maqannaasara rakiranaki namuqaa urinnaaqaraaqee qiananoo.
\q1 
\v 5 Oo Anutu ani afeekannai maasa qeeqa namuqaa rafaaqafi marunausa maridaqa.
\q1 Akaqausa findifi darirariafana anee maasa faqa marianaqa maasa rakirana uraaqa raidaqa.
\q1 
\v 6 Qinee sia qeeqa duru saqarikidaqa qini rakira paipana faqa sia qini dadaaqidanoo.
\q1 Anee kai.
\q1 
\v 7 Anee kai maasara fidiaqaaimaria namuqaasa
\q2 nisaukukinaana doo rafiamaree nisaurirana misa nimiananoo.
\q1 
\v 8 Maasa aiqama kari Anutuna kai amooqidaqa.
\q1 Naaru naaru minara dufi dufi qianaura. Kuqaa.
\q1 
\v 9 Anee maasa rakira fasiqauqa faqa nidana dadaaqiunafa maqee sia nidana, sia dadaaqimariananoo.
\q1 Oo Anutu, anee maasa minniqiseenana maasa ooru muqufi qisaananoo.
\q1 
\v 10 Anee miqiannanara namuqaa maasa nifaqasaafaqa sandaunaqa maasa aiqama ainaina mareea.
\q1 
\v 11 Anee maasa mareeqee namuqaa nimianaqa misa maasa sipsipara foora kuqa darirara idaqa.
\q1 Anee maasa aanaamurukiaqa doo daru qifaqaa qianaqa moodaa moodaa iqa maridaqa.
\q1 
\v 12 Oo Anutu anee aneenna faiqí anaasee kaqikaa
\q2 munnimma aqusee maree maria ainainnara foora mariafana namuqaa nimiananoo.
\q1 Anee nimisee aabaa munnimma sia maree marianara foora nimiananoo.
\q1 
\v 13 Anutu anee miqi marianaqa maasa qiqoonausa maasara naanaidara qidaqa.
\q1 Maasa daaqa mariasa ataasa ataasa maqimaqaidaqa.
\q1 
\v 14 Anee sia maasa dadaaqiannanara aiqama maqannaasa maasa qisaurirana qimidaqa.
\q1 Akaqa maqannaa maasa Isaraee maqannaasa qiqafeeqa uteeti qimasaidaqa ninuka aqidaqa.
\q1 
\v 15-16 Qini namuqaa faqa qiniara fidiaqaa imariasa qini
\q2 ataasa ataasa qima qimaqaafaqa qinee aiqama
\q2 kari ummaaraki maruna qisaurirafa qini rafaaqa fidanoo.
\q1 
\v 17 Oo Anutu, anee fifau maasa dari mariananoo.
\q1 Maasa aniara sia qauniqa sia ani qima afeekaikira ufa rukieeqa sandanainai qidaqa.
\q1 Maa manda oosanafa fifau maasa rafaaqafu qimaqaidanoo.
\q1 
\v 18 Maasa nimuqusa sia qikooqaifaqa andeeqara
\q2 oosanasaaqari moosaa quandeeqa, kaqi mariaqoo kai maridaqa.
\q1 Maasa qiku faqa maasa firana faqa sia ani minnisee qiku munuree miniree idaqa.
\q1 
\v 19 Anee fifau maasa qimudaani tureeraummasee
\q2 mareeqee kaasau faini ooki quqeenanara foora masaanaqa maridaqa.
\q1 Anee firaa asukunannoo maasa rafaaqafu
\q2 qimaqaananoo oosana sia marinaki fifau miqiananoo.
\q1 
\v 20 Maasa Isaraee maqannaasa Anutuna auqu qaunusaananoo fau mifa iriqini.
\q1 Maasa unna anutunauqa uqeeraananoofau Anutufa minara faqa iriqini.
\q1 
\v 21 Anutufa maasa qimuqusaki kukeeqara ainainara
\q2 irimarifa marinara mi aiqama ainaina qafaiqini.
\q1 
\v 22 Faasaambaasaana misa ani auqusaara maasa daruqifaqaaidaqa.
\q1 Misa maasara kuqifandinna sipsipausee qimasaida maasa daruqifaqaaidaqa.
\q1 
\v 23 Oo Yaawee findifua nanaree faiqaidanee.
\q1 Findifua sia kisaaqasaa maasa minniqisaa.
\q1 
\v 24 Anee nanaree aneenna oorisaa ititasee sia maasa qiqafaidanee.
\q1 Yaawee anee nanaree maasa aupurarana faqa ummaara qimiranara faqa qaunidanee.
\q1 
\v 25 Maasa maqasaa aqufunaqa nikusamu radamu saafaqa maqasaa riqa maridaqa.
\q1 
\v 26 Oo Yaawee anee findifi maasa dadaaqia.
\q1 Aneenna maasara naaruara aidiranara irisee maasa mareeqee amiqiranaki quqaqisaa.
\c 45
\s1 Maqasaa karaambaiqa amundara idi.
\q1 
\v 1 Amiqira irirafa qini iriranaki umbiqanoo marifaqa
\q2 karaambaiqa irianifeera maa idi ufana akara ruma amidaqa.
\q1 Qini qifauru fannoo papiqa saiki marina amiqira kirifiara foora maa idina akara ridanoo.
\q1 
\v 2 Oo maasa maqasaa Karaambaiqa ani afaaqa aiqama faiqí faiqikiqari amiqirafa mariananoo.
\q1 Ani afauru deepimaseera foora amiqira ufa adiafaa ira ufa kai ani ookiqari ururaidanoo.
\q1 Minara naaruara naaruara Anutufa ani amiqi amiqimma amaqaidanoo.
\q1 
\v 3 Oo uriqararafa ani afeeka faqa ani qareenarafa faqa
\q2 ani uriqararafa faqa marinara doo aneenna duru feefa deedaqinana rakiranaki fua.
\q1 
\v 4 Anee aneenna uriqararana namu faqa doo rakiranaki finana uriqaraa.
\q1 Fimarinaqa ani anoona ufa qirana faqa andeeqarana faqa sia rafaaqa fuaqeera rakiranaki fua.
\q1 Ani rakirafa afeekaikinaqa manda oosana maree mariasa aniara firaaqoo rufieefaranoo.
\q1 
\v 5 Ani duru feefa aaruqirafa namuqaauqa nimuqusaki kai naruannoo.
\q1 Miqiannanannai moomoosa ani aikuki aqufifana radamu nimaqeennaranoo.
\q1 
\v 6 Anutufa anee naaru naaru uriqarana maridana
\q2 aneenna faiqí anaasee andeeqara oosanannoo rakisi nimaqaa.
\q1 
\v 7 Ani andeeqaranara aidinoo mandainainara fidiaqaa inoo imarifa mariananoo.
\q1 Minara kai ani Anutufa ani utaaqamaseenoo
\q2 asasirana ani akiiqa amoondunna akaqa uriqararausa adia nimaqaina faqa uraaqa ramasee adia amaqeenoo.
\q1 
\v 8 Ani qamunna makaqa mandeefana undidanoo ani
\q2 karaambaiqa amiqira maaqakina aiqama
\q1 ainainauqa eereefanta aanainnai auqira
\q2 ainainauqa kai maridanoo.
\q1 Minaki piripunna oosana oosanannai auqaafana anee asasimariananoo.
\q1 
\v 9 Akaqa karaambaiqa niraamuqmaaka uriqarara aanaaseeuqa kai ani maaqaki maridaqa.
\q1 Ani karaambaiqa asauku uqannai ani anaaqa uriqarara
\q2 anaasee amiqira qamunna afisimarufa Oofiraa
\q2 maqusaindaraa koorannoo afaaqa auqusee ani asauku uqannai kikiqinoo maridanoo.
\q1 
\v 10 Oo fuka amundara anaasee anee aneenna aaqoo ramatinimmafi qini ufa iria.
\q1 Aneenna maqannaa faqa aneenna ainainara faqa
\q2 qaunuseenana aneenna afaaqi maqa maaqaki kai maria.
\q1 
\v 11 Miqimarinanoo ani afaaqi karaambaiqa ani amiqira oori afiriara firaaqoo aidiannoo.
\q1 Mifa ani karaambaiqa maridanoo anee minara kai qeerairidana mina ufa qaindusua.
\q1 
\v 12 Tiree maqusaindaraasa moo amira ainaina
\q2 nisaukuki uqirausa aniree asasidaqa amifaranoo.
\q1 Faiqí aanaaseekiqari ainaina faqaasa aniree ani aqoondikifaranoo.
\q1 
\v 13 Moo maqannaa karaambaiqa araamuna fannoo narí afaaqauqira maqaki maridanoo narí afaaqinnai firaridanoo.
\q1 Mi manaaqana qamunna koorannai auqirafa idaaqirafa kai maridanoo.
\q1 
\v 14 Misa mina afiqamaree narí qamunna oosana oosana
\q2 akararirana namufaqa karaambaiqa munu amiafaqa qafeeqa.
\q1 Aqoonna maanaaqauqa mina dadaaqi marusa mina afiqee fia.
\q1 
\v 15 Misa asasirana namufaqa nasu nasurirana namufaqa
\q2 aana muquniqa karaambaiqa amiqira maaqaki keeqaafaqa niqafeeqa.
\q1 
\v 16 Maa anaaseena afaaqi karaambaiqa, ani faiqi namu
\q2 kambiqainausa ani amaaqa maqee findifi karaambaiqaikiqa fifaranoo.
\q1 Aneenna faiqi namu anee kaqi maridana aiqama
\q2 maqa maaqai uriqararausaika mannimaqasaina rakisi nimaqeefaranoo.
\q1 
\v 17 Qinee ani auqu uqeerasaanaqa naaru naaru aiqama kambiqeefandinausa minara irifaranoo.
\q1 Miqiannanara faiqí anaasee naaru naaru ani amooqifaranoo.
\c 46
\s1 Anutufa maasa faqa maridanoo.
\q1 
\v 1 Anutufa maasa kukeeqara maqusa faqa maasa afeeka faqa maridanoo.
\q1 Maasa aiqama kari ummaaraki aqufunanoo dadaaqi marifa maridanoo.
\q1 
\v 2 Maasa minara irisee sia rufiaanaura.
\q1 Maqa firaaqoo kasinaqa sia maasa minara rufiaanaura.
\q1 Aaqana namu mareeqee ooruku nammari qambaanai
\q2 uqasaina aqufinaqa maasa sia minara maparaa ianaura.
\q1 
\v 3 Aiqama nammari aufinoo firaaqoo narisaa narisaa
\q2 arinoo qaqaara qaqaarinanoo firaaqoo ufaqinaqa sia rufiaanaura.
\q1 Aaqana namu kasinaqa nammari fannoo aaqana ammitu ammitu inaqa sia rufiaanaura.
\q1 
\v 4 Anutuna maqusa aaqa mari nammarifa qumidanoo
\q2 raina rainidanoo Anutuna maqusaki mariasa mi nammarifa asasirana nimidanoo.
\q1 Mi maqusafa naaquqarafa marifanoo uriqarara Anutufa mi maqusanaki maridanoo.
\q1 
\v 5 Anutufa mi maqusanaki marinara sia kasinoo sia aqufuannoo.
\q1 Namuqaa aniraifanoo mi kananaanna kai Anutufa dadaaqiannoo.
\q1 
\v 6 Aamina maqannaa tautummasee aanoo qimasee
\q2 faaqa fuisee qiafaqa akaqa maqannaasa kurididaqa.
\q1 Misa miqi mariafanoo Anutufa narí ufa firaaqoo
\q2 uqeeraifanoo aiqama maqa tasirisirinoo nammarikidanoo.
\q1 
\v 7 Karaambaiqa aiqama afeeka faqaafa maasa faqa maridanoo.
\q1 Yaakooboona Anutufa maasa afeeka kukeeqara maqusa maridanoo.
\q1 
\v 8 Oo aiqamausa aniree Yaaweefa auqamasai ainaina qafaa.
\q1 Maa maqa maaqana aiqama naaquqara ainaina auqaina qafaaqa.
\q1 
\v 9 \fig Rakira duru saamu.|alt="weapons" src="HK00199B.TIF" size="col" loc="Psalm 46:9" ref="46:9"\fig*Mifa maa maqa maaqanasaa aiqama atiqara mari rakirana taikannimaqaidanoo.
\q1 Mifa duru feefa itairaatairidanoo.
\q1 Rakira saqari faqa idaki aqusaifanoo qama taikaidanoo.
\q1 
\v 10 Oo innee kasoomafinaqa qinee Anutusa marunnanara oonumafi iriaqa.
\q1 Qinee moomoo maqannaasa qambaanai uriqaraqa marianaura.
\q1 Qinee aiqama maa maqa maaqanaki uriqaramafuanaura.
\q1 
\v 11 Karaambaiqa aiqama afeeka faqaafa maasa faqa maridanoo.
\q1 Yakooboona Anutufa maasa afeeka kukeeqara maqusa maridanoo.
\c 47
\s1 Anutufa aiqama maqannaasa karaambaiqa maridanoo.
\q1 
\v 1 Oo innee aiqama maqannaasa nisauku aridaqa asasiaqa.
\q1 Innee Anutunara idi rama amaqaidaqa asasiaqa.
\q1 
\v 2 Kaaqa uriqarara Yaaweefa naaquqarafa maridanoo, minara rufiaaqa.
\q1 Mifa aiqama maqa maaqasaa uriqarara karaambaiqa maridanoo rakisi nimaqaidanoo.
\q1 
\v 3 Mifa aiqama maqannaa mareeqeenoo maasa Isaraee maqannaa niramandunnai quqanau.
\q1 Aiqama maqannaa oonu mafi maasa qiku ameemaanai quqasanau.
\q1 
\v 4 Maasa maqa maaqa qimiraree qimasee utaaqama qimaqoona narí kai qiminau.
\q1 Anutufa mi amiqira maqa maaqana maasa Isaraee
\q2 maqanaasa narí aidi marusa qimufaqa maasa mi maqa maaqanara asasidaqa.
\q1 
\v 5 Anutufa narí ufa irira qaari maruqoo ooru
\q2 fimarufaqa mina fiqu fiquiqa marusa faaqa ridaqa asasi mariqau.
\q1 Ukeena fuaqarana namufaqa Yaaweefa ooru finau.
\q1 
\v 6 Amooqira idi Anutuna ramamia. Doo ramamiaqa.
\q1 Maasa karaambaiqa amooqira idi ramamiaqa. Doo kafaa idi ramamiaqa.
\q1 
\v 7 Anutufa aiqama maa maqanasaa mariasa karaambaiqa maridanoo.
\q1 Doo innee mina amooqira idi ramamiaqa.
\q1 
\v 8 Mifa narí naaquqara qaarisaa ooqu marifi aiqama maqannaasasaa rakisi nimaqaidanoo.
\q1 
\v 9 Aiqama maqannaasa uriqararausa moodaaqoo
\q2 Abarahaammana Anutuna ufa iri mariasa namufaqa suqidaqa.
\q1 Misa aiqamausa Anutunaindi maridaqa.
\q1 Mifa firaaqoo uriqarara afeeka faqaafa maridanoo.
\c 48
\s1 Sioona Anutuna maqusa maridanoo.
\q1 
\v 1 Yaaweefa firaafa uqanna maridanoo.
\q1 Maasa Anutuna maqusaki mina naaquqara aaqanasaa mari maqusanaki maasa Anutuna amooqidaqa.
\q1 Mina firaaqoo uqanna amooqiaqa.
\q1 
\v 2 Sioona aaqana Anutunaindi kaaqa uriqararafa amiqirafa maridanoo.
\q1 Mifa uriqarara karaambaiqa maqusa maridanoo.
\q1 Mi aaqanafa maa maqa maaqanakinaa fasiqa anaasee asasirana nimidanoo.
\q1 
\v 3 Anutufa mi maqusanaki maridanoo faiqí anaasee
\q2 dadaaqidanoo, mifa rakira aukuana faiqí anaasee
\q1 mi afeeka faandaamura ququsanaki dadaaqidanoo ititannisaidanoo.
\q1 
\v 4-5 Moomoo namuqaa karaambaiqauqa suqufi mi
\q2 maqusana ooru qafoofanoo naindiri ree naaquqoofaqa quqasee doo sandamafiqau.
\q1 
\v 6 Naindiri rarafa misa naakufufaqa anaasee innaamunara auruandee miqau.
\q1 
\v 7 Namuqaa nariqa rakira kannuqaki oobiqasee urufanoo
\q2 suani oosanaindari ufai firaafa urinoo nammari
\q1 amakaurufanoo misa kannuqa Tarasisaa maqusanaasaindi teeqindee mannisanau.
\q1 
\v 8 Maasa ooqai Yaaweefa rakisi marunara iriafannana maqee maasa qeeqa qifunnoo qafeeqa.
\q1 Yaaweena aiqama afeeka faqaana maqusa marinara
\q2 narí Anutufa mi maqusanaki amiqimmasee
\q1 ititaqaifanoo naaru naaru afeekaikinoo maridanoo.
\q1 
\v 9 Oo Anutu, ani naaquqara amaana maqaki keeqafiqa
\q2 ani maasara firaaqoo aidi marinara oonumafi iridaqa.
\q1 
\v 10 Oo Anutu, aiqama maqa maaqaki mariasa ani amooqidaqa.
\q1 Ani firaa auquara aiqama maa maqa maaqanakinaa fasiqa anaasee asasidaqa.
\q1 Anee andeeqara oosanannoo rakisi nimaqee mariananoo.
\q1 
\v 11 Oo Anutu, ani rainara ufa andeeqarafa marinara,
\q2 Sioona aaqanasaa mariasa asasiaqa.
\q1 Yuda maqa maaqakinaa maqusakiaqa mariasa faqa nasuriaqa.
\q1 
\v 12 Innee Anutuna faiqi namu Sioona aaqana fiqu fiqummasee qafaaqa,
\q2 ooni faandaamura auquqoona amiqimasee qafeeqa asaanaruaqa.
\q1 
\v 13 Mina faandaamura ooru ree qumuree qiranakiaqa qafamaqaraasammasee kasooaqee inaaqianna
\q2 kambiqainausa mi faandaamuranara qimannimiaqa.
\q1 
\v 14 Maa Anutufa naaru naaru innisaimbaqa Anutufa maridanoo.
\q1 Mifa naaru naaru maasa qifiqee aana uqaqifiqanoo fuannoo.
\c 49
\s1 Munnimma qumiasana saqarikirafa furufarira oosana maridanoo.
\q1 
\v 1 Maa ufana aiqamausa iriaqa.
\q1 Aiqama maa maqa maaqanaki mariasa amiqimmasee iriaqa.
\q1 
\v 2 Aiqamausa uriqararausa faqa ureeqarausa faqa
\q2 ainaina faqaasa faqa kudi fasiqa faqa, aiqama iriaqa.
\q1 
\v 3 Eeqá dookiqari irirana faqaasa ufa kai qianaura.
\q1 Qini daunduraindaraa irirafa andeeqara irirana maree maria irirana nimiannoo.
\q1 
\v 4 Eeqá naamuaqira ufa quandasee qianaura.
\q1 Qini quandara ufa piripuna aridaqa idinnai qimannimianaura.
\q1 
\v 5 Manda aukuana aninaqa qinee sia fifau rufiaanaura.
\q1 Mandoosana maree mariasa qini fiqu fiqu iqa
\q2 maridaqa mandaikamma qisararifaqa sia qinee minara rufiaanaura.
\q1 
\v 6 Mi aaqara fasiqausa nári ainainasaa kai mundidaqa,
\q2 nári moomoo munnimma ainaina faqaasa marianara nári nimoo namoo qidaqa.
\q1 
\v 7 Maasa sia amana qeeqa maa maqanasaa kisaaqasaa marirana feefaurianaura.
\q1 Maasa sia amana Anutuna munnimma amisee qeeqa marirana feefaurianaura.
\q1 
\v 8 Faiqí marirana feefaurirafa firaafa fiqaranoo maridanoo.
\q1 Firaa feefauru tia aqinanoo faqa sia kai amanaikiannoo.
\q1 
\v 9 Sia amana feefauru Anutuna amisaifanoo maa
\q2 maqanasaa kisaaqasaa marida sia kuquanee qiannoo.
\q1 
\v 10 Aiqamausa maa ainainna qafaidaqa.
\q1 Irirana faqaasa misa faqa kaqi kuqifaranoo.
\q1 Irirana siaisa faqa furufarirausa faqa aiqama amana
\q2 amana kai kuqiqa nári ainaina mafi quqasaafaqa akaqausa maraidaqa.
\q1 
\v 11 Ooqai maqa misaindi marinau.
\q1 Maqee faiqí madika fannoo misa maqusa maridanoo.
\q1 Naaruara naaruara misa mi madikanaki kai marifaranoo.
\q1 
\v 12 Maasa uriqarara duqu fannoo sia amana kuqirana itita qimaqaannoo.
\q1 Maasa kaqi aandaura foora kuquanauranoo.
\q1 
\v 13 Faiqí náriara uriqararausee qimasee náriara kai
\q2 irimariasa, miqira fasiqa irirafa sia andeeqanoo maridanoo.
\q1 Misa fifau nariqa ainainara asasidaqa misa faqa aandaura foora kai kuqidaqa.
\q1 
\v 14 Misa sipsipauqara foora kuqifaranoo.
\q1 Misa kuqu fifanoo kuqirafa misa sipsipasaa rakisirafara foora misa rakisi nimaqaannoo.
\q1 Andeeqara oosana maree mariasa doo misa
\q2 kanaanaanara foora findifiqa manda oosana maree mariasasaa rakisifaranoo.
\q1 Manda oosana maree mariasa kaqi maridaqa amiqira
\q2 maaqaki mariinaqa kuqiqa sia minaki marifaranoo nianai madikaki maridaqa kai kaqi putaa ifaranoo.
\q1 Misa miqiqa mariafaqa qinee sia misa naanna raidaqa.
\q1 
\v 15 Anutufa qini kuqira afeeka ameemaanaindaraana feefauru masainaqa asumu marianaura.
\q1 
\v 16 Faiqí moo fannoo firaaqoo ainaina moomoo faqaafaikinnanara sia minara irinanoo amuqusiani.
\q1 Mina maaqa amiqirana firaana usakainara sia anee qinee faqa miqiaqaanee qia.
\q1 
\v 17 Mi ainainna faqaa fasiqa kuqinoo sia moo ainaina maree fuannoo.
\q1 Mina qumiasana sia mina faqa madikaki ooqu fuannoo.
\q1 
\v 18 Mi fasiqafa kaqi maru kamuqoo moomoo amiqira
\q2 ainaina faqaafa maridanoo mifa fifau nariara amiqi amiqiranaki maridee qimarinau.
\q1 Mifa moomoo amiqira ainaina faqaafa marufaqa aiqamausa mina amooqi mariqau.
\q1 
\v 19 Ainaina faqaafa kuqinoo mifa faqa narí akeeku akaaku kuqiqa oonu mariaqoo fuannoo.
\q1 Mifa miqoo oonu maridanoo sia kaifaa kaaqa qarana qafaannoo.
\q1 
\v 20 Maasa uriqarara duqu fannoo sia maasa kuqiranasaa itita qisaannoo.
\q1 Maasa aandaura foora kaqi kai kuquanaura.
\c 50
\s1 Kuqaa qira innaaru.
\q1 
\v 1 Afeeka faqaa Anutufa Yaaweefa maa maqa
\q2 maaqanakinaasara nammeera qifaqa suqufuafanoo qimannimi marifa maridanoo.
\q1 Suani oosanaindari faqa suani keeqee marinnaindari faqa nammeera qifaqa suqidaqa.
\q1 
\v 2 Sioonna maqusa kaaqa amiqirafa qareenarafa
\q2 marifanoo Anutufa mi maqusanaki maridanoo
\q1 akooqoo kaaqa qaidanoo rupannoo imarifa maridanoo.
\q1 
\v 3 Maasa Anutufa anireenoo sia ufa siaina marifa maridanoo.
\q1 Ida fannoo mina afunni fidanoo fasafasimarifanoo fidanoo.
\q1 Misaqa mina fiqu fiqu inoo mari ainainausa ufai
\q2 aakuasaa innaarunai qirafa mifauqa kai firaaqoo ufa qidanoo.
\q1 
\v 4 Anutufa aiqama maqannaa suqu quqaseenoo misa
\q2 ufa andeeqaani qimasee innaaruna faqa maqa faqa naaramasainaqa anireeqa Anutufa narí
\q2 faiqí anaasee raina nimaqaaninna ufana irifaranoo.
\q1 
\v 5 Anutufa qidanoo, qiniki mapukusee maria fasiqa anaaseesa suqumaree moodaaqoo aniaqa.
\q1 Aandau tatufiranannai qini faqa qima afeekaikirana
\q2 qimimariasa misa qinee marunnannai moodaaqoo suqumaree aniaqa.
\q1 
\v 6 Innaaruna fannoo Anutunara maaqi qimasee kooroo idanoo.
\q1 Anutufa narí kai andeeqarafa ufa raina nimaqee marifa maridanoo.
\q1 
\v 7 Anutufa kafaa maaqi qidanoo.
\q1 Oo Isaraee maqannaa qini maqannaasa irifaqa inni mandoosanara kooroommasee qimannimianaura.
\q1 Qinee Anutusa inni Anutusa maridaqa qimannimianaura.
\q1 
\v 8 Innee qimi maria ainainna faqa aandau tatufi
\q2 mariana faqa maqee maqee qimimariana sia minara aanoo qidaqa.
\q1 
\v 9 Qinee sia inni aandauqa kinaana burimmakau akoonara dididanoo.
\q1 Sia inni mimmi ququsakinaana moora dididanoo.
\q1 
\v 10 Nandaki maria kaasau aandausa aiqama qinindi kai
\q2 maridanoo, maaqeena aandau aiqama aaqanasaa
\q2 faqa maqa maaqaki mariasa qinindi kai maridanoo.
\q1 
\v 11 Aiqama ufiniuqa faqa qinindi kai maridanoo.
\q1 Aiqama maqa maaqaki maria aandausa aiqama qinindi kai maridaqa.
\q1 
\v 12 Qinee Anutusa aandaura didi marinaqau sia inni qimannimunaiqini.
\q1 Maa maqa maaqana faqa aiqama minaki mari ainainausa qinindi kai maridanoo.
\q1 
\v 13 Innee qiniara burimmakau akoona amaqi neemarifee fee qidaqee.
\q1 Innee qiniara mimmi fidika faqa neemari fee fee qidaqee.
\q1 Sia mina naidaqa.
\q1 
\v 14 Innee dufi dufi qirana kai tatufiranara foora qini Anutusa qimiaqa.
\q1 Innee qini uriqarara afeeka faqaasara qima afeekaikammaqaa mau kai fuaqa.
\q1 
\v 15 Ummaara inniki kambiqafinaqa qini daaraifaqa qinee inni dadaaqianaqa innee quandakina qini qimooqiaqa.
\q1 
\v 16 Aaqara oosana maree mariasa Anutufa maaqi qimasee qimannimidanoo.
\q1 Innee nanaree qini naamuaqira ufa nikaru qimasee naakapaidee.
\q1 Innee nanaree qini moodaanaki kira ufa unnaqimasee inni nifaurusaaqari uridanoo fee.
\q1 
\v 17 Qinee andeeqa nimaqararunaqa nikooqee mariasa.
\q1 Aiqama kari qini naamuaqira ufa rukiee mariasa mariafanoo.
\q1 
\v 18 Innee qummuari mari fasiqana qafamasee mina aqoondiki mariafanoo.
\q1 Innee faiqí anaasee qummuari mariasa niqafamasee innee faqa minaki ootupee mariasa mariafanoo.
\q1 
\v 19 Inni noo fannoo manda oosanara qiranara kai rakisidanoo.
\q1 Inni nifauru fannoo unna ufa qirara sia marammara ridanoo kaqi qimariafanoo.
\q1 
\v 20 Innee inneeqa nikaqaafasaa unnufannai misa ufa nimi mariasa mariafanoo.
\q1 Innee oosana siainaki misara manda ufa qimariasa mariafanoo.
\q1 
\v 21 Innee mi manda oosana oosanausa auqee mariafaqa
\q2 qinee Anutusa kaqi kasooiqa marunaqa innee qiniara Anutufa maasa daanna raidanoo manda
\q2 oosanara sia ufa qidanoo fee qimariafanoo.
\q1 Innee miqi qidaqa aaqee mariafanoo.
\q1 Inni nifusaa akooqoo inni aaqaranara kooroomma nimianaura.
\q1 
\v 22 Innee qini Anutusara nikooqee mariasa maana iriaqa.
\q1 Qinee inni mandaikamma nimaqaanaura.
\q1 Sia moo fannoo amana inni dadaaqiannoo.
\q1 
\v 23 Qini Anutusa dufi dufi qirana tatufiranara foora
\q2 suqa qimimariasa faqa qini ufamau fimariasa faqa
\q2 qinee Anutusa qeeqa asumu marirana nimianaura.
\c 51
\s1 Numoo akiiqara mininnisaani fee innaaru.
\q1 
\v 1 Oo Anutu aneenna sia taikaaninna amuqusirafa marinara irisee qini qifauama qisaa.
\q1 Aneenna firaa nifauarafa marinara irisee qini aaqarana akiiqara rukaqisaa.
\q1 
\v 2 Qini manda oosana findaukamaqisaa.
\q1 Qini aaqarana nammari uqu taika qisaa.
\q1 
\v 3 Qinee qeeqa aaqaranara iridaqa.
\q1 Qini manda oosana fannoo naaruara doorinni marinaqa sia qaunuanaura.
\q1 
\v 4 Oo Anutu qini aaqarafa ani kai mandaikamma amaqeeqa.
\q1 Ani afusaa kai maa manda oosanna auqeeqa.
\q1 Oo Anutu akooqoo ani qimamidaqa.
\q1 Anee qini ufa qimiannana anee kuqaa andeeqarafa mariananoo.
\q1 Anee ufa qimiannanannai qini aaqarana akiiqara iananoo.
\q1 
\v 5 Qini qinoofa qini maqa qisooqooqari numoo aanaaqi mariafanausa maridaqa.
\q1 Qeeqa qinoona amuaquki mariafananoo aaqarana asumu qiniki marinau.
\q1 
\v 6 Oo Anutu faiqí naundarai anoona ufa kai marianifee qimarianafa mariananoo.
\q1 Qini daundurai kukeeqaranaki aneenna irirana daamuaqia.
\q1 
\v 7 Anee qini anukama qisainaqa qinee anukaqa maria.
\q1 Qini nammari uqusainaqa qinee eekara arira qasuruara foora qiqa maria.
\q1 
\v 8 Oo Anutu anee qini aaqarana akiiqara qini qimudaani raqeera foora maqaanaqa maridaqa.
\q1 Anee qini aaqarana minni qisainanoo qini qimudaani kafaa ootupeera foora inaqa qinee asasianaura.
\q1 
\v 9 Aneenna afu tautasee qini aaqarana sia qafaa.
\q1 Qini manda oosana aiqama rukaqisaa.
\q1 
\v 10 Oo Anutu qini qimuqusa fuka amiqira qimuqusa auqu qisaa.
\q1 Qini daunduraki naaruara ani ufamau fira maraquna quqaqisaa.
\q1 
\v 11 Sia qini mareeqee aneenna mariannaqooqari aquqisaa.
\q1 Aneenna naaquqara andeeqara maraquna qiniki marina sia maraqua.
\q1 
\v 12 Qinee ani asasira asumu mariranaki mariufaqa
\q2 kaqinni ubeekaqa marunnana kaifaa mina qiminaqa asasia.
\q1 Miqianana anee kaifaa ani ufmau fira didira
\q2 maraquna qiminanoo qini dadaaqinaqa ani aidirana mau fua.
\q1 
\v 13 Anee miqinaqa qinee aaqee mariasa ani andeeqara aana uqannifiqaanaura.
\q1 Manda oosana maree mariasa faqa irisee anee innannai quandaki ubeekeefaranoo.
\q1 
\v 14 Oo Anutu qini asumu marirana qimianna Anutufa mariananoo.
\q1 Anee sia qini kuqa darua, anee ititaqisainaqa qinee
\q2 firaaqoo asasida ani andeeqaranara idi raanaura.
\q1 
\v 15 Oo Yaaweefa anee qini doo raqasainaqa qinee qeeqa
\q2 dookiqari ani amooqiranara kai koorooianaura.
\q1 
\v 16 Qinee ani Anutuna aandau tatufirana amianee
\q2 runana anee sia didiifoo qianaqa minniseeqa.
\q1 Qinee tatufirana ani amianee runana anee minara sia asasiananoo.
\q1 
\v 17 Anutufa narí amira ainainara akooqaidanoo.
\q1 Qini tatufirafa qeeqa mara maree qumirafa maridanoo.
\q1 Anee nariqa mara maree qumira oosana faqa faiqí
\q1 nári mandainainakiqari quandara oosanara faqa sia akooqaidanoo.
\q1 
\v 18 Oo Yaawee aneenna amiqira iriranannai Sioona
\q2 maqusanaasa amiqi amiqimmannimaqaa.
\q1 Anee Yeerusaree faandaamura kafaa auqu uqeerasaa.
\q1 
\v 19 Auqu uqeerasainaqa miqooqari ani aminna ainainafa ani aidimarifa mariannoo.
\q1 Aandau muduka tatufirana suqarafa oosana oosana ani aidirafa kai mariannoo.
\q1 Miqoo misa burimmakau akoonauqa arusee tatufirana suqasee ani amifaranoo.
\c 52
\s1 Anutuna raina nimaqaranara faqa amiqiranara faqa qidanoo.
\q1 
\v 1 Oo amudaanai qimarianna fasiqa, anee nanaree aneenna manda oosana amooqidanee.
\q1 Anee nanaree faasaambaasaana anee Anutufa aidimari fasiqa aanaaseesa mandaikamma nisaidanee.
\q1 Anutufa mapukusee marira oosana fannoo naaruara marifa maridanoo.
\q1 
\v 2 Manda fasiqa anee mandaikamma nimaqarara kai tipundaari marianafa mariananoo.
\q1 Afai keedaira foora raiqarafa unna ainaina kai inanuanafa.
\q1 
\v 3 Ani manda oosanara rirafa amiqira oosanara rimariannana uriqaranoo maridanoo.
\q1 Ani unna ufa qiranara aidirafa anoona ufa qira aidirana uriaaqaranoo maridanoo.
\q1 
\v 4 Anee unna ufa qirara kai aidi marifa mariananoo.
\q1 Anee faiqí mandaikamma nimaqara ufara kai aidi marianafa mariananoo.
\q1 
\v 5 Anutufa kuqaa uqanna anee mariannaqoo qaraana
\q2 ani rarisameeqee naaru naaru kuridiranaki quqasaannoo.
\q1 Mifa ani maaqakinaana qumara rarisameeqee ummaaraki quqaisaannoo.
\q1 Mifa maa maqa maaqakinaana ani umareeqeenoo kuqiranaki quqaisaannoo.
\q1 
\v 6 Anutufa manda fasiqauqa kuridinnimaqainaqa andeeqee mariasa qafamasee rufieefaranoo.
\q1 Misa mi manda fasiqausara naanaidara qifaranoo.
\q1 
\v 7 Misa mi manda fasiqanara maaqi qimasee uteeti qifaranoo.
\q1 Maa fasiqafa sia Anutunasaa mundidanoo. Sia mina dadaaqianifee qidaqa.
\q1 Narí moomoo ainainasaa mundinoo maridanoo,
\q2 mifa narí firaa qumiasanara qini dadaaqiannoo fee qidanoo.
\q1 Mifa narí manda oosanara qini itita qimaqaannoo fee qianoo
\q1 
\v 8 Qinee Davidisa sia miqimarunausa maridaqa.
\q1 Qinee Anutuna amaana maqaki fuka oorifa saqariara foora ammunidaqa.
\q1 Qinee naaru naaru Anutuna sia taikaaninna amuqusirana saqarikidaqa.
\q1 
\v 9 Qinee anee auquqoonna ainaina oosana qafamasee
\q2 naaru naaru ani faiqí anaasee nifusaa dufi dufi qianaura.
\q1 Qinee ani andeeqaranara kooroommasee qimannimianaura.
\c 53
\s1 Faiqí faiqi manda oosanara qidanoo.
\q1 
\v 1 Furufari mariasa nári nimuqusakiqari maaqi qidaqa sia Anutufa maridanoo fee qidaqa.
\q1 Miqi qimariasa oosana mandaika minoo maridanoo.
\q1 Misa manda ainaina kai auqee mariasa maridaqa.
\q1 Sia moo fannoo andeeqara oosana maraidanoo.
\q1 
\v 2 Yaaweefa innaarunaindari maa maqanasaa faiqí
\q2 faiqi mariasa nindafaidanoo maaqi qimasee qimannimidanoo.
\q1 Akaqausa amiqira irirana faqaasa maridee sia fee maridee.
\q1 Akaqausa qini Anutusara randaidee sia fee randaidee qidanoo.
\q1 
\v 3 Aiqamausa quandaki kaqi runna fidaqa.
\q1 Misoo maasoo amana amana kai mandaikiqa maridaqa.
\q1 Sia moo fannoo andeeqarafa maridanoo. Sia uqanna.
\q1 
\v 4 Anutufa maaqi qimasee iraidanoo.
\q1 Manda oosana maree mariasa irirana siaisee maridee.
\q1 Misa qini faiqí anaasee ainaina qumuaramasaida minasaa maridaqa.
\q1 
\v 5 Miqi mariasa firaaqoo rufiee faranoo.
\q1 Ooqai rufioona arusee maqee firaaqoo rufiqeefaranoo.
\q1 Anutufa narí faiqí anaasee namuqaauqa naruseenoo
\q2 misa nimudaani aiqama tinai modaa moodaa aqusaannoo.
\q1 Anutufa mi namuqaasa ameesuqinaqa Isaraee maqannaasa misa naru nifaqaaqifara.
\q1 
\v 6 Qinee maaqi qimasee innaaru qidaqa Isaraee
\q2 maqanaasa asumu marirafa Sioona maqusakiqari aniani.
\q1 Anutufa Isaraee maqannaasa nári maqa maaqa faqa
\q2 qumiasana faqa kafaa rairaamma niminaqa misa asasidaqa idireefaranoo.
\c 54
\s1 Namuqaasaa itita amaqaannee innaaru.
\q1 
\v 1 Oo Anutu aneenna afeekannai qini mara amiqiranaki quqaqisaa.
\q1 Aneenna firaa afeekannai qini rumbaranakinaana iduku qisaa.
\q1 
\v 2 Oo Anutu, qini innaaru qirana iria, qini dookinaa ufa iria.
\q1 
\v 3 Ramoo ramaa imariasa aniree qini dariraridaqa.
\q1 Faiqí kuqa narimariasa qini marirana taika qimaqarara midaqa.
\q2 Anutu ani ufara sia irimariasa qini dariraridammia.
\q1 
\v 4 Kuqaa Anutufa qini dadaaqi marifa maridanoo.
\q1 Qini mariranasaa rakisi marifa Yaaweefa maridanoo.
\q1 
\v 5 Anutufa qini namuqaa qini mandaikamma qimaqee
\q2 maria oosannana quandasee nariqa faqa mandaikamma nimaqaani.
\q1 Oo Yaawee aneenna mapukusee mariranara irisee misa kuridinnisaa.
\q1 
\v 6 Oo Yaawee qinee aandau tatufirana ani suqa amirara dididanoo.
\q1 Oo Yaawee ani auqu amiqirafa marinara ani amooqianaura.
\q1 
\v 7 Anee qini dadaaqiananoo aiqama ummaara fannoo sia qini rafaaqafinoo.
\q1 Miqimma saanaqa qeeqa qifunnai qeeqa namuqaa aqufuana niqafeeqa.
\c 55
\s1 Faiqí moo fannoo mina aqoondi fannoo ueeqasoofanoo Anutufa dadaaqianifeera innaaru qinau.
\q1 
\v 1 Oo Anutu qini innaaruqirana iria.
\q1 Qinee ani iramirianana sia aaqoosaa ititasee kaqinni oori rafusu aqua.
\q1 
\v 2 Anee qini ufa irisee dadaaqinnanara qima qimia.
\q1 Qini ummaara irirafa qini daruaqaa midanoo.
\q1 
\v 3 Qini namuqaa qini mandaikamma qimaqarara sandanainai qidaqa.
\q1 Mi manda oosanna maree mariasa qini rafaaqafu qimaqaidaqa.
\q1 Misa ummaara mareeqee qinisaa quqaidaqa.
\q1 Misa qiniara aanoo qimasee fidiqaamaqisaidaqa.
\q1 
\v 4 Qinee firaaqoo rufiee marunanoo mi irirafa qini kuqirafa qimaqaa idanoo.
\q1 Kuquanna daaquqarafa firaafa daakinoo maridanoo.
\q1 
\v 5 Firaaqoo rufiee marunanoo daindiri raidanoo.
\q1 Kuqira daaquqarafa qini rafaaqfinoo maridanoo.
\q1 
\v 6 Qinee nakipuruna miqirausa qiqoosa faqaasa
\q2 maridau qaqamaree moosaa oonuree idooaranaki marini.
\q1 
\v 7 Qinee qaqamaree nianai faiqí sia mariannai maaqa marunaiqini.
\q1 
\v 8 Ufainamu faqa aakuasaa namufaqara foora
\q2 namuqaa darimariafaqa ufini maridau kai kaqi mooatinai auqaanaira foora asooarannai fini.
\q1 
\v 9 Oo Yaawee anee qini namuqaa ufa qirana furufaramma nimaqa.
\q1 Narirafa faqa aanooqirafa faqa qini maqusaki
\q2 marinara miqimmannisaaneera qinee ani iraidaqa.
\q1 
\v 10 Eendaki faqa faasaana faqa maqusa faandaamura
\q2 afaimau oonuree aniree idaqa manda ainaina faqa ummaara faqa uqeeraidaqa.
\q1 
\v 11 Kuridinnimaqara oosana fannoo maasa maqusaki aiqama tinai maridanoo.
\q1 Narira ufa faqa unna qira ufa faqa maasa maqusaki aiqama tinai qumbiqanoo maridanoo.
\q1 
\v 12 Qini namuqaa qifasaasa ufa qimi naqau kaqi maraunaiqini.
\q1 Qini namuqaa darirari faqau qinee miqooqari kukeeqafini.
\q1 
\v 13 Sia qini namuqaa fau miqidau anee qini fooqaa ira
\q2 fasiqa qini qifaaqasaa qiqoondi fannoo qini qiqoonafa qiniara ueeqee mariananoo.
\q1 
\v 14 Maaqanda moomoosa faqa moodaanaki Anutuna
\q2 amaana maqaki keeqafiqa amiqira ufa narí
\q2 qimami narí qimami qimari qiafana.
\q1 
\v 15 Kuqirafa qini namuqaauqa tautumasee naruani.
\q1 Misa kaqi marifaqa misa mareeqee kuqirausa marianaki quqaaqa.
\q1 Aaqarafa misa maaqaki faqa misa nimuqusaki faqa marinara miqiaqa.
\q1 
\v 16 Qinee Anutuna aaraananoo mifa qini asumu maraannoo.
\q1 
\v 17 Eeneemarinaqa faqa kananaana faqa faasaana
\q2 qambaana faqa qinee qeeqa aupuraranakiqari aaraananoo mifa qini ufa iriannoo.
\q1 
\v 18 Rakiranaki moomoo namuqaa darirariafanoo
\q2 Yaaweefa minakinaana amiqimmasee qifiqaifaqa oonurandee qimaaqa anianaura.
\q1 
\v 19 Misauqa nári manda nirana sia minnisee andeeqarannai quandaidaqa.
\q1 Misa Anutunara rufiarafa sia maridanoo.
\q1 Anutufa naaru mariranakiqari uriqararafa marifa qini innaaru iriseenoo misa aupurarana nimiannoo.
\q1 
\v 20 Qini ooqeenaa qiqoondi fannoo narí aqoondiuqa naridanoo.
\q1 Narí aqoondikira qima afeekaikira ufa rukiasee naridanoo.
\q1 
\v 21 Mina afaurusaa ufa fannoo fadameenara foora amiqi
\q2 amiqi qimarifanoo mina amuqusaki qari rakirafa kai kambiqee marifa maridanoo.
\q1 Mina ufa fannoo fadameenara foora farindaidanoo
\q2 mi ufana anoona aseema miqirafa maridanoo.
\q1 
\v 22 Aneenna ummaara Yaaweenasaa quqasainanoo mifa aufadama amaqaannoo.
\q1 Yaaweefa andeeqarausa mandainainaki aqufifanoo
\q2 irinoo siamma mininnisaannoo dadaaqammiannoo.
\q1 
\v 23 Oo Anutu anee faiqí kuqa nárí mariasa faqa unna
\q2 ufa qiqanuasa faqa sia asooqa qeefaranoo, fukasaa kuqifaranoo.
\q1 Misa miqifaqa qinee ani kai saqarikinaura.
\c 56
\s1 Anutuna saqarikira innaaru.
\q1 
\v 1 Oo Anutu, anee qiniara qimudaoo qia.
\q1 Faiqí moomoo nimudaanai qimasee qini daru qifaqaa qidammia.
\q1 Qini namuqaa aiqama kari qini qifaqasee dariraridammia.
\q1 
\v 2 Qiniara ataasataasa qimariasa faasaambaasaana qini daru qifaqaa qidammia.
\q1 Moomoosa qini dariraridaqa.
\q1 
\v 3 Qinee rufiaunna kari Oo Yaawee, qinee ani kai saqarikidaqa.
\q1 
\v 4 Qinee Anutuna saqarikdaqa sia moo ainainara rufiaidaqa.
\q1 Mina qima afeekaikira ufara irisee mina auqu quqeeraidaqa.
\q1 Faiqí faiqi nana mandaikee maqimaqaifaqa sia qinee rufiaanaura.
\q1 
\v 5 Aiqama faasaana qini namuqaa ummaara qimidaqa.
\q1 Misa maqee maqee qini mandaikamma qimaqarara kai iridaqa maridaqa.
\q1 
\v 6 Misa qini marirana nirana qiqafamasee qini darirara kukeeaqa maridaqa.
\q1 
\v 7 Oo Anutu, anee misa manda oosana akiiqara aupurarana nimia.
\q1 Anee aneenna aanooqiranannai mimaqannaasa muqufisee rafaaqafunnisaa.
\q1 
\v 8 Oo Anutu qini qiki raqarana aneenna papiqaki akararua.
\q1 Qini daukunu quminara papiqaki padimmasee akara rua.
\q1 
\v 9 Qinee ani aaraanana anee irisee qinaqa namuqaa sandeefaranoo.
\q1 Anee miqinaqa qini Anutufa qini saaroo qidanoo fee qianaura.
\q1 
\v 10 Qinee Anutuna saqarikidaqa mina qima afeekaikira ufara amooqidaqa.
\q1 
\v 11 Qinee mi Anutunasaa kai qeeqa irirana rusidaqa.
\q1 Faiqí faiqi nana mandaikee maqimaqaifaqa sia qinee rufiaanaura.
\q1 
\v 12 Oo Anutu qinee qima afeekaikiafanna ufanara irisee
\q2 dufi dufi qirana aandau tatufiranara foora suqamianaura.
\q1 
\v 13 Oo Yaawee, qinee madika afaisaa oonuraunnana
\q2 uqeera qisaannanara dufi dufi qira tatufirana suqamianaura.
\q1 Qinee farindamaki saamurirara unana qini mara findifuma qisaananoo.
\q1 Qinee ani Anutuna afusaa kaqi marira kaaqa qaranasaa nuaneera mara findifuma qisaananoo.
\c 57
\s1 Dadaaqiani fee innaaru.
\q1 
\v 1 Qiniara qimudaoo qimisee dadaaqiannee qidaqa.
\q1 Oo Anutu qiniara qimudaoo qimasee dadaaqia.
\q1 Qinee anee iannannai dadaaqianeera
\q2 animarunnanara irisee qimudaoo qia.
\q1 Qinee ani aqoosa ameemaanai itita qisaina kuqirafa aiqaramafinaqa akoonnai anianaura.
\q1 
\v 2 Qinee Anutuna aiqama afeeka faqaana aaraidaqa.
\q1 Qini didimari aiqama ainainna qimimari Anutuna aaridaqa.
\q1 
\v 3 Mifa innaarunaindari qini innaaru qirana iriseenoo qini asumu maraannoo.
\q1 Mifa qini mandaikamma qimaqee mariasa rafaaqafidanoo.
\q1 Anutufa narí sia taikaaninna amuqusirana faqa narí
\q2 mapukusee marira oosana faqa qini uqaqifiqaidanoo.
\q1 
\v 4 Qinee kaasau aandau raioonnara foora fiqu fiqu iqa mariana qambaanai maridaqa.
\q1 Misa nifai fannoo feefara foora faqa faaqaanara foora faqa kaaqa aaruqirausa qambaanai maridaqa.
\q1 Misa nifauru fannoo aseemara foora raiqarafa faiqí ateekee marisa qambaanai maridaqa.
\q1 
\v 5 Oo Anutu, aneenna uriqararana innaarunai uqannifiqaa.
\q1 Aneenna qareenarana aiqama maqa maaqaki mariasa uqannifiqaa.
\q1 
\v 6 Qini namuqaa qini qiku ufana fufidammia.
\q1 Qini daundurai rufiarafa marinara mapamidaqa.
\q1 Misa qini qimaara madika indufuseeqa nariqa sia
\q2 irirai nári indufuqaanaki nári kai doo aqufia.
\q1 
\v 7 Oo Anutu miqiqa maridaqa aniara irunanoo qini qimuqusa mapukinoo maridanoo.
\q1 Minara qinee idi raidaqa ani amooqianaura.
\q1 
\v 8 Qinee findifiqa.
\q1 Qinee piripuna faqa ufireena faqa arimariananoo iaqainanoo suani afu uruani.
\q1 
\v 9 Oo Yaawee qinee moomoo maqannaasa qambaanai kikiqamafi amooqianaura.
\q1 Qinee moomoo fasiqa anaasee qambaanai idi raida ani amooqianaura.
\q1 
\v 10 Oo Yaawee ani maasara amuqusirafa firaatia innaaruna amana kai ooru maridanoo.
\q1 Ani mapukusee marira oosana fannoo kudimanda mariqoo ooru maridanoo.
\q1 
\v 11 Oo Anutu, aneenna uriqararana innaarunai uqannifiqaa.
\q1 Aneenna qareenarana aiqama maqa maaqaki mariasa uqannifiqaa.
\c 58
\s1 Anutufa manda oosana maree mariasa aupurarana nimiani fee innaaru.
\q1 
\v 1 Innee uriqararausa andeeqasee ufa nimidee.
\q1 Innee anoona ufannai faiqí amana amana kai fee andeeqannimaqaidee.
\q1 
\v 2 Innee sia miqi mariafanoo.
\q1 Inni nimuqusaki innee aaqaranara indeeindee imariafanoo.
\q1 Innee maa maqa maaqanaki faiqí narira oosana kai nimi mariafanoo.
\q1 
\v 3 Aaqee mariasa maqannimaqoona kiqari kaqi runnai ubeekaqa maridaqa.
\q1 Misa maqannimaqoona kiqari aaqaranaki kai fidaqa unnufa kai qidaqa.
\q1 
\v 4 Misa aaqara oosana fannoo ukadiqara foora faiqí anaasee ukaqa nimifaqa kuqidaqa.
\q1 Misa moo sakani sia ufa irimari sakani fara foora ufa sia iridaqa.
\q1 
\v 5 (Akaqa maqannaasa sakani rakisi mariasa ufireena fuaqaafaqa misa ninuka aqidaqa.
\q1 Davidifa faiqí sia ufa irimariasa mi sakanina kikiqa ususee niqinoo maaqi qinau.)
\q1 Innee faiqí sakaniara foora ufireena fuaqaifaqa sia ufa irifaranoo.
\q1 Ufireena akoofasa amiqimasee fuaqaifaqa mina faqa siamma irifaranoo.
\q1 
\v 6 Oo Anutu aaqee mariasa kaasau fainiara foora mariasa anee misa nifai rufidia.
\q1 
\v 7 Anee aaqara oosana maree mariasa nammari
\q2 akooqoo qumida muqufi dadasindee mannisaa.
\q1 Aanasaa mari ainainna nikunnai radamuandeemma nimaqaa.
\q1 
\v 8 Oo Anutu saina aaqee mariasa qoofi kuqufi putaa iandee iaqa.
\q1 Kuqira faiqi maqasaasa sia kaaqa qarana qafaandee iaqa.
\q1 
\v 9 Faiqí kaqikaa saqari ateekaindee inoo kai kaqi Anutufa misa mandaikamma nimaqaannoo.
\q1 Misa kaqi marifanoo Anutufa narí firaa arana qaranakiqari misa ufaira foora fuaqa aquannoo.
\q1 
\v 10 Misa manda oosana akiiqara Anutufa niminaqa,
\q2 andeeqee mariasa mina qafamasee asasammifaranoo.
\q1 Andeeqee mariasa misa fidikaki niku nammari uqifaranoo.
\q1 
\v 11 Faiqí mina qafamasee maaqi qifaranoo.
\q1 Andeeqara marirana maree mariasa mi andeeqarana akiiqara nimirafa kuqaa maridanoo.
\q1 Maa maqanasaa qaraasa andeeqasee rainee mari
\q2 Anutufa kuqaa maridanoo, sia sia maridanoo.
\c 59
\s1 Namuqaa sia mandaikamma amaqaaqee innaaru.
\q1 
\v 1 Oo Anutu qini namuqaauqa nisaukukinaana maraquqisaa.
\q1 Aiqama qini darirari mariasasaa ititaqisaa.
\q1 
\v 2 Manda fasiqa nisaukinaana maraquqisaa.
\q1 Faiqí kuqa nári mariasa nisaukukinaana qini soodaaqammaqisaa.
\q1 
\v 3 Oo Anutu anee qafaa.
\q1 Misa kukeeqafi qini darirara qipuraidaqa.
\q1 Misa kaaqa aanoo qimariasa qini darirara suqidaqa.
\q1 Oo Yaawee sia qini manda oosana akiaqarau
\q2 dariraridau, kaqi fifau nariqa kai dariraridaqa.
\q1 
\v 4 Qinee sia aaqara oosanau maree fau.
\q1 Misa sia minara irirai kaqi fifau qini darirara deedaqidaqa.
\q1 Oo Yaawee, misa kai kaqi qini darirara deedaqidaqa rakisidaqa.
\q1 
\v 5 Oo Yaawee, aiqama afeeka faqaa Anutufa findifinana qini dadaaqia.
\q1 Isaraee maqannaa Anutufa anee qumuree misa manda oosana aneenna afunnai qafaa.
\q1 Findifinana Anutuna ufa sia iriasa ummaara nimia.
\q1 Qini ueeqee mariasara sia qimudaoo qia, kaqi ummaara nimia.
\q1 
\v 6 Misa eendifaqa fainiara foora rairai qidaqa, manda
\q2 ainaina uqeerarara qini maqusamau fiqu faiqu fiqa nidaqa.
\q1 
\v 7 Misa nookiqari nanee fididee.
\q1 Misa nifauru nimaakiri qaseema miqirafa kai maridanoo.
\q1 Misa nári manda ufara maaqi qidaqa. Yafee iriannoo fee qimasaidaqa kaqi fifau qidaqa.
\q1 
\v 8 Oo Yaawee, anee misa ufa irisee misara naanaidara qimariananoo.
\q1 Anee aiqama mi manda maqannaasa ataasa ataasa qira ufa nimimariananoo.
\q1 
\v 9 Oo Yaawee, anee kai qini afeekaikamma qimaqasee rakisi qimaqee mariananoo.
\q1 Anee Anutufa qini kukeeqara maqusara foora mariananoo.
\q1 
\v 10 Qini Anutufa qiniara amuqusi marifa qinee unnannai anireenoo dadaaqiananoo.
\q1 Mifa qini namuqaa rafaaqafu nimaqainaqa qeeqa qifunnai niqafaanaura.
\q1 
\v 11 Oo Yaawee maasa ititaqisee marianafa qini maqannaasa mi manda maqannaasara qaunifoora minara sia aiqama naru taikaa.
\q1 Aneenna afeekannai mi manda fasiqausa
\q2 narunnifaqaaqa masainaqa auiqeera foora aiqama
\q2 maqa maaqakinai oonuree aniree iqa nuaqa.
\q1 
\v 12 Misa nookinaa ufa faqa nifaurusaaqaraa ufa faqa aaqarafa kai maridanoo.
\q1 Misa aaqara ufa faqa unna ufa faqa qimariana akiiqara mandaikiaqa.
\q1 Misa nári noori uqeeree maria oosanafa ufaanara foora misa ninuka qumaraani.
\q1 
\v 13 Oo Anutu aneenna aanooqiranaki qari misa kuridi nimaqaa.
\q1 Amiqimmasee kuridi taikasaa.
\q1 Miqinaqa maa maqa maaqana atinni atinni mariasa
\q2 minara iriseeqa oo Anutufa Isaraee maqannaasa rakisidanoo fee qifaranoo.
\q1 
\v 14 Eendifaqa namuqaa kafaa aniree fainiara foora
\q2 rairai qidaqa mandainaina uqeerarara fiqu faiqu idaqa maqusamau nidaqa.
\q1 
\v 15 Misa nári naranara randaida oonuree aniree iqanida
\q2 sia nimuaqu imarifaqa firaaqoo faaqa riqanidaqa.
\q1 
\v 16 Misa miqi mariafaqa qinee ani afeekara irisee idi raanaura.
\q1 Oo Anutu, qinee firaa ummaaraki marunnana anee
\q2 qini afeeka kukeeqara maqusa mariannanara
\q2 qinee kananaana findifi ani maasara
\q2 amuqusiranara idi raanaura.
\q1 
\v 17 Qinee qini Anutuna qini itita qimaqee mariannana amooqianaura.
\q1 Anutufa firaaqoo qiniara aidi marifa qini afeeka
\q2 kukeeqara maqusa maridanoo.
\c 60
\s1 Manda ainainakinaana mara kaqinni quqaqisaannee innaaru.
\q1 
\v 1 Oo Anutu, anee maasa minniqisaananoo. Anee maasa rafaaqafu qimaqaananoo.
\q1 Anee maasa aanoo qima qimaqaananoo.
\q1 Oo Yaawee, kafaa maasa iannai quandafi maasa dadaaqia.
\q1 
\v 2 Anee maqa kasiananoo maqa fannoo oo raqaidanoo.
\q1 Anee maqa oo raqafina kafaa mafi titaa.
\q1 
\v 3 Anee maa aukuanna maasa afeeka ummaara doo uqaqifiqaananoo.
\q1 Mi ummarana manda nammariara foora nimianaqa
\q2 namasaafanoo narifanoo nifuai nifuai inoo.
\q1 
\v 4 Oo Anutu maasa aniara daaquqee marisa namuqaa
\q2 maasa daru qifaqaa ifaqa anee firaka uqeerainnannai sandaifanoo namuqaa duru
\q2 feefa nammari araannoo, miqifaqa maasa sia kuridianaura kaqi marianaura.
\q1 
\v 5 Oo Yaawee maasa innaaru qirana irisee aneenna afeekannai maasa asumu maraqisaa.
\q1 Miqimmaseenana ani aidi maria fasiqa anaaseesa
\q2 mandainaina kinaana asumu mariaqeera maraa.
\q1 
\v 6 Anutufa narí naaquqara uiqaana maqakiqari maaqi qinau.
\q1 Qinee ufoona ridaqa Seekeemma maqa maaqa rainasee qeeqa maqannaasa nimianaura.
\q1 Qinee Sukoota noopundu faqa miqi kai iqa qeeqa maqannaasa rainasee nimianauree qinau.
\q1 
\v 7 Kireeata maqa maaqa faqa Mannaseena maqa maaqa faqa qinindi maridanoo fee qinau.
\q1 Eefaraimma maqa maaqa qeeqa qikiiqa afisi marunna afeeka qafeefara foora maridanoo.
\q1 Yuda maqa maaqa fannoo qini uriqararausara
\q2 uqannifiqee mari saunu fara foora maridanoo.
\q1 
\v 8 Qinee Anutusa Mooaba maqa maaqa mareeqee
\q2 nammari difaanirara foora masee ooru dupimma nisaanaura.
\q1 Qinee Eedooma maqa maaqa qiku aanaamu raipaqu
\q2 quqee marunna maqa maaqafa ooreeqarafa
\q2 mariannoo, miqiannanannoo qeeqaindika masaunnana kooroo ianaura.
\q1 Qinee Firistia maqannaasa urinnaaqaramasee faaqa rumasee ufoona ruanaura.
\q1 
\v 9 Oo Anutu, yafee qini aana muquninaqee Eedooma maqannaasa afeeka faandaamuraki keeqafi naruanauree.
\q1 
\v 10 Oo Anutufa kuqaa fee anee maasa ameesa uquqiseenanee.
\q1 Anee sia fee ooqai unnandee inana maasa rakira fasiqauqa faqa oonuree dadaqinnaree.
\q1 Anee sia maasa rakira fasiqa namufaqa fidana dadaaqi mariananoo.
\q1 
\v 11 Anee maasa dadaaqinaqa maasa nári namuqaa narua.
\q1 Faiqí faiqi dadaaqirafa sia amanaikiannoo.
\q1 
\v 12 Anutufa maasa dadaaqinaqa rakiranaki oonuree uriqaraanaura. Mifa maasa namuqaa rafaaqafu nimaqaannoo.
\c 61
\s1 Isaraee maqannaasa Anutufa dadaaqianifeera innaaru quu ufafa.
\q1 
\v 1 Oo Anutu, qini iki raqarana iria, qini innaaru qiranara aaqoo rammatinia.
\q1 
\v 2 Qinee moo maqa maaqai nianai oonu marunanoo
\q2 qini qimuqusa mandaikimarifaqa ani aaraidaqa.
\q1 Anee qini mareeqee afeeka kukeeqara maqusaki quqaqisaina asumu maria.
\q1 
\v 3 Nnaree anee qini faandaamurara foora qini ititaqimaqee marianafa mariananoo.
\q1 Anee qini faandaamura marianaqa namuqaa sia amana qini rafaaqafifaranoo.
\q1 
\v 4 Qinee naaru naaru ani uriqarara naaquqara uiqaana maqaki marirara dididanoo.
\q1 Ani aqoosa ameemaanaira foora mandaaqaanauree qidaqa.
\q1 
\v 5 Oo Anutu, qinee qima afeekaikira ufa ani
\q2 qimamiafannanara anee irimmariananoo.
\q1 Anee iriseenana ani auquara rufiee mariasa nimiraree
\q2 qianna ainainna qini Dafidisa faqa qimiananoo.
\q1 
\v 6 Qinee Isaraee maqannaa karaambaiqa marunausa Anutu anee qini aukuana moomoo ootupamasainaqa qeeqa qinaiqimara qisaifaqausa nindafaanaura.
\q1 
\v 7 Oo Anutu anee qiniara naaruara qini qifusaa maridana Isaraee maqannaasa rakisi nimaqaannee qia.
\q1 Anee aneenna amuqusirana faqa aneenna mapukusee marira oosanannoo faqa ititaqimaqaa.
\q1 
\v 8 Miqimarinaqa qinee naaru naaru ani auquara amooqira idi raanaura.
\q1 Qinee ooqai aiqama faasaana ani amianauree qimasee qima afeekaika maqaafannamau fuanaura.
\c 62
\s1 Anutuna rakisinnimaqaranasaa munduaqa.
\q1 
\v 1 Qinee Anutufa qini asumu maraani feera kai afeesida maridaqa.
\q1 Mifa kai qini asumu marirana qimidanoo.
\q1 
\v 2 Mifa kai qini itita qimaqaseenoo qini asumu marirana qimidanoo.
\q1 Mifa qini afeeka kukeeqara maqusara foora marinara
\q2 naaru naaru sia qini rakiranaki rafaaqa fifaranoo.
\q1 
\v 3 Oo qini namuqaauqa, naqumma kari fee qini darida marifaree.
\q1 Innee qiniara nauraa ququsa rafaurinoo fifaiqanoo marindee irafee qimariafanoo.
\q1 
\v 4 Innee qinee uriqararaqoo marunnana qifeeqa maqasaa aqirara ufa qimariafanoo.
\q1 Inni unnufara kai nididanoo.
\q1 Inni nookiqari unna qimasee Anutuna amooqira ufa qimariafanoo, inni naunduraki manda niqurara ufa kai umbiqanoo maridanoo.
\q1 
\v 5 Qinee Anutuna kai mandaaqaidaqa.
\q1 Qeeqa irirana minasaa kai munduqaqee maridaqa.
\q1 
\v 6 Mifa kai qini itita qimaqaseenoo qini asumu marirana qimidanoo.
\q1 Mifa kai qini afeeka kukeeqara maqusara foora
\q2 marinara sia qini rakiranaki rafaaqa fifaranoo.
\q1 
\v 7 Qini asumu marirafa faqa qini uriqarara duqu faqa
\q2 Anutunakiqari kai qiniki anidanoo.
\q1 Mifa kai qini itita qimaqee marifa maridanoo, mifa kai qini auqaana maridanoo.
\q1 
\v 8 Innee qini qiku qisauku aiqama kari Anutuna kai saqarikiaqa.
\q1 Inneeqa aiqama ummaarara mina qimamiaqa. Maasa mifinnai oonuree kai asumu marianaura.
\q1 
\v 9 Aiqama faiqí faiqi fifau naidoora foora maridaqa.
\q1 Nuqu faqaasa faqa ooreeqarausa faqa moodaakarirausa fifau ainainara foora maridaqa.
\q1 Anee misa uqaki rumaseenana sikeerasaa dirisee qafa, siara foorammiqa maridaqa.
\q1 Naidoo ummaara fannoo misa ummaara uraaqaranoo maridanoo.
\q1 
\v 10 Innee sia rakirana faqa moona ainaina ummuara mararana faqa saqarikiaqa.
\q1 Inni ainaina moomoo kinaqa sia irirana minasaa rusiaqa.
\q1 
\v 11 Moomoo kari Anutufa maaqi qifaqa iriqa.
\q1 Qinee Anutusa firaa afeeka faqaasa maridaqee qinoo.
\q1 
\v 12 Kafaa moo ainaina anee Yaaweefa maasara amuqusi marianafa mariananoo.
\q1 Oo Yaawee anee kuqaa aiqamausa ainainirana
\q2 akiiqara feefauru amana kai rainasee nimimarianafa mariananoo.
\c 63
\s1 Anutufa dadaaqianifeera indee indee idaqa.
\q1 
\v 1 Oo Anutu, anee qini Anutufa mariananoo.
\q1 Qinee doori kandamasee aniara randaida innaaru qidaqa.
\q1 Qinee aadana maqa maaqai marunanoo nammariara didiara foora aniara dididanoo.
\q1 Miqikaimmasee qini maa qifaaqafa faqa aniara nammariara foora aididanoo.
\q1 
\v 2 Ani naaquqara uiqaana maqaki ani qafaanaura, ani afeeka faqa ani qareenarana faqa qafaanaura.
\q1 
\v 3 Oo Anutu ani amuqusirafa maa maqee marunna
\q2 marirana uriaaqaranoo marinara qinee ani auqu uqeeraanaura.
\q1 
\v 4 Qinee maaqoo kaqi marianna kamu aniara dufi dufi qianaura.
\q1 Qinee qeeqa qisauku uqeeraseeqa ani innaaru qima amaqaanaura.
\q1 
\v 5 Qeeqa qimuqusannai amiqira naranara foora
\q2 namasaananoo qini qimuaqu inaqa qinee asasira idinnai ani amooqianaura.
\q1 
\v 6 Anee ooqaindari qini dadaaqi marianafa
\q2 mariannanara qinee qeeqa faiqara qaarisaa maridaqa aniara iridaqa.
\q1 Eendamuqusai faiqarara andee qumooridaqa aniara kai iridaqa.
\q1 
\v 7 Qinee ani aqoosa ameemaanai maridaqa aniara asasira idi raanaura.
\q1 
\v 8 Qinee anisaa atooqaidaqa.
\q1 Ani asauku uqannai asauku fannoo qini asumu maraidanoo.
\q1 
\v 9 Qini kuqa darirara imariasa aiqama kuqufi kuqirausa maria maqa maaqaki fifaranoo.
\q1 Misa maqa ameemaanai kuqirausa faqa marifaranoo.
\q1 
\v 10 Misa duru feefa ooki keeqaifanoo kaasau aandau misa nipata neefaranoo.
\q1 
\v 11 Qinee Isaraee maqannaasa karaambaiqa rakiranaki uriqararana qimimarinara. Anutunara asasianaura.
\q1 Aiqama Anutuna auqusaa kuqaa qima afeekaiki mariasa mina amooqifaranoo.
\q1 Unna ufa qimariasa noo Anutufa ititannimaqasainaqa sia ufa qifaranoo.
\c 64
\s1 Isaraee maqannaasa Anutufa dadaaqianifeera innaaru quu ufafa.
\q1 
\v 1 Oo Anutu, qinee ummaaraki maridaqa, qini innaaru qirana iria.
\q1 Qini namuqaa dariranara rufiaidaqa, anee qini marirana dadaaqia.
\q1 
\v 2 Manda oosana maree mariasa tipundaari
\q2 mariasakinaana qini mareeqee kukeeqaqisaa.
\q1 Aaqee mariasa faaqa fuisee qida qini darirari marianasaa faqa ititaqisaa.
\q1 
\v 3 Mi fasiqausa nári nifauru nimaakiri faaqaanara foora aaruqu maqaafanoo maridanoo.
\q1 Misa ufa fannoo feefa dindasaa quqasee rakisiandee qini rakisi qimaqaidaqa.
\q1 
\v 4 Miqi maria manda fasiqausa qumee ooqa andeeqara fasiqa naridaqa.
\q1 Misa rufiarana siaisa kaqi tautumaki naridaqa.
\q1 
\v 5 Misa nariqa suqufifaqa manda oosanara narí pooduqee narí pooduqee idaqa.
\q1 Misa kukeeqara ufaana fufira oosanara amiqimmasee
\q2 iriqaraasammasee maaqi qidaqa, sia moo fannoo maasa ufaana qafaannoo fee qidaqa.
\q1 
\v 6 Misa manda ainaina auqarara tipundaaridaqa.
\q1 Misa nariqa tipundaariranara andeeqanoo maridanoo fee qidaqa.
\q1 Faiqí faiqi kukeeqara irirafa farumara foora meemai uqnaurinoo maridanoo.
\q1 
\v 7 Anutufa mi manda faiqausa narí feefannai naruannoo.
\q1 Dauni misa naru quqasaannoo.
\q1 
\v 8 Misa manda ufa akiiqara kuridi nimaqaannoo.
\q1 Aiqamausa misa mi narirana niqafamasee boo firaa ainaina kambiqee maqi qifaranoo.
\q1 
\v 9 Misa aiqamausa misa narirana qafamaseeqa rufieeqa
\q2 misa Anutuna ainainiranara iridaqa kooroommasee mina ainainiranara qimannimifaranoo.
\q1 
\v 10 Andeeqarausa Yaaweefa auqoo ainainara irisee asasifaranoo.
\q1 Misa Yaaweenaki amiqimmasee marirana paqurifaranoo.
\q1 Aiqama andeeqarausa mina amooqifaranoo.
\c 65
\s1 Anutuna amooqirafa faqa dufi dufi qira innaaru maridanoo.
\q1 
\v 1 Oo Anutu, anee maasa innaaru irimariannanara
\q2 maasa Sioona maqusaki andeeqasee oonuree ani amooqidaqa ani amianauree qima afeekaika maqaafanna ainainauqa ani amianaura.
\q1 
\v 2 Faiqí anaasee aiqama maqa maaqaindari nári manda oosanara iriseeqa anee Anutufa iannannai ani faranoo.
\q1 
\v 3 Maasa mandainaina fannoo maasa dukunimma saifana anee Anutufa mina taikaqisaananoo.
\q1 
\v 4 Anutu anee rusandeesamummasee maraqaanausa ani asasiranaki maridaqa.
\q1 Anee aneenna naaquqara maaqaki mariaqeera nifiqa quqasainausa asasiaqa.
\q1 Maasa mi amaana maqanaki marunanoo ani amiqi
\q2 amiqirafa maasaki qumbiqanoo marifaqa maridaqa.
\q1 Ani naaquqara amaana maqaki marunanoo ani
\q2 amiqi amiqirafa minaki marifa maasaki qumbiqanoo maridanoo.
\q1 
\v 5 Oo Anutu, anee maasa asumu qimi marianafa mariananoo.
\q1 Anee maasa aneenna naaquqara andeeqara ainaina
\q2 auqee mariannanannai maasa qimaqimi marianafa mariananoo.
\q1 Aiqama maqannaasa nianai atinni atinni mariasa
\q2 faqa ooruku nammari dinni afainni mariasa faqa ani kai saqarikidaqa.
\q1 
\v 6 Anee aaqanauqa aneenna afeekannai auqu eeqee nári maqee mariaqoo quqanau.
\q1 Miqunnanannoo aneenna afeeka uqannifiqanau.
\q1 
\v 7 Ani afeeka fannoo ooruku nammari kasinoo amakaurirana faqa rafaaqafusaifanoo mina kasirana faqa ufaqirana faqa daimafinoo.
\q1 Faiqí anaasee tutuqirana faqa taikannimaqaananoo.
\q1 
\v 8 Aiqama maqannaasa anee auqee marianna ainainna qafaafanoo naaquqaidanoo.
\q1 Suani ururee marinnai mariasa faqa suani keeqee
\q2 marinnai mariasa faqa aiqama ainaina auqee marianna ainainna qafamasee mi aiqama
\q2 maqannaasa naaquqaifaqa faaqa rumasee aniara asasidaqa.
\q1 
\v 9 Oo Anutu anee maa maqa maaqana rakisidana
\q2 uqeena uqeenianifeera aaku firaana teeqiananoo.
\q1 Anee miqiannanannai maa maqana ainookamma saananoo.
\q1 Anutu ani nammariuqa qumbiqanoo maridanoo.
\q1 Mi nammarifa maqa maaqa amiqimma saifanoo amiqira narana faíqí anaasee nimidanoo.
\q1 Anee miqimmasee auqinau.
\q1 
\v 10 Oo Anutu, anee qiananoo aaku firaafa rinoo maqa uqeena uqeena masaifanoo afuqaki narana kambiqaidanoo.
\q1 Anee aaku dunoonnannai maqa uqeena saananoo narana kambiqaidanoo.
\q1 
\v 11 Ani amiqirafa narana rairaamma qimaqee marifa maridanoo.
\q1 Anee finnatinai miqikai inoo narana rairaa iannoo.
\q1 
\v 12 Andandaki aiqamatinai burimakau faqa sipsipa faqa umbiaqa maridaqa.
\q1 Aaqanauqa faqa kaqikaa amuaqu namuqa faqa aaku rifaqa firaaqoo asasidaqa.
\q1 
\v 13 Firaa afaasasaa burimakau sipsipa moomoo qumbiqaidanoo.
\q1 Noopunduki faqa sakumma ainaina moomoo kambiqeenoo aiqama noopundu titaidanoo.
\q1 Aaku rifanoo aiqama ainaina asasidaqa idi raidaqa.
\c 66
\s1 Anutuna amooqira idi faqa dufi dufi qira idi faqa maridanoo.
\q1 
\v 1 Aiqama maqa maaqaki mariasa asasidaqa firaaqoo Anutunara faaqarumasee amooqiaqa.
\q1 
\v 2 Idi raidaqa mina auqu qareenaranara kooroo iaqa.
\q1 Qareenara amooqirana mina amiaqa.
\q1 
\v 3 Innee Anutuna maaqi qimasee qimamiaqa.
\q1 Anee auqu quqoonna ainainafa kaaqa naaquqarafa maridanoo.
\q1 Ani namuqaauqa ani uriqarara afeeka qafamasee
\q2 aniara firaaqoo rufieeqa ani oorinni niqoori saunu araidaqa.
\q1 
\v 4 Aiqama maa maqa maaqanasaa qaraasa ani amooqidaqa.
\q1 Misa ani amooqira idi raidaqa ani auqu uqeeraidaqa.
\q1 
\v 5 Innee aiqamausa aniree Anutufa auqeeu ainaina qafaaqa.
\q1 Mifa naaquqara ainaina faiqí anaasee qambaanai auqanau.
\q1 
\v 6 Mifa ooruku nammariara qufanoo aadanusufufaqa
\q2 maasa qikeeku qikaaku maqamau aandanasaa funara Anutunara asasiqau.
\q1 
\v 7 Anutufa naaru naaru narí afeekannai aiqama maqannaasa rakisinnimaqaidanoo.
\q1 Mina afu fannoo aiqama maqannaasa auqee maria ainainna niuqidanoo.
\q1 Ufa rukiee mariasa sia Anutuna aana itita amaqaaqa.
\q1 
\v 8 Innee aiqama maqannaasa maasa Anutuna amooqiaqa.
\q1 Innee mina amooqirana firaaqoo uqeeraifaqa nianaindari faiqí anaasee iriaqa.
\q1 
\v 9 Mifa maasa marirana afeedammaqisaifaqa kaqi maridaqa.
\q1 Mifa maasa mandainainaki aqufuanoora itita qimaqaifaqa sia aqufidaqa.
\q1 
\v 10 Oo Anutu, anee maasa qimanammasee qafaananoo.
\q1 Siruaa tasirisiri masee apaapu maraquandee iananoo.
\q1 
\v 11 Oo Anutu, anee maasa mareeqee ufaanaki aruqisasee
\q2 firaa ummaara tia maasa qitaufakaaqa daaku qimaqaananoo.
\q1 
\v 12 Anee namuqaara qianaqa misa nikunnai maasa qikiiqa radamia.
\q1 Maasa ida qambaanaira foora faqa nammari aufi marinakiara foora faqa oosana oosana ummaaraki
\q2 fimariafanana anee maasa mareeqee amiqiraqoo quqaqisanau.
\q1 
\v 13-14 Qinee ummaaraki maridaqa ani Anutuna oosana
\q2 oosana qima afeekaikira ufa qimamiqiafana.
\q1 Doo maqee mi qima afeekaikira ufana qimamiafannandee ianaura.
\q1 Doo maqee qinee qima afeekaikiafanna ufanara qianaura.
\q1 Qinee aandau tatufirana mara maree ani amaana maqaki minisee suqa amianaura.
\q1 
\v 15 Qinee sipsipa tatufirana suqamianaura.
\q1 Qinee burimmakau akoona faqa mimmi faqa tatufirana suqa amianaura.
\q1 Miqiananoo muna fannoo innaarunai ani aikiambu iannoo.
\q1 
\v 16 Innee Anutunara qeerairi mariasa mai aniraifaqa qini dadaaqinara qimannimia.
\q1 
\v 17 Qeeqa dookiqari dadaaqianifeera aareeqa, idinnai mina amooqiqa.
\q1 
\v 18 Qinee mandainainara fifau ainainee qimasee kaqi
\q2 auqaunanoo Anutufa sia qini innaaru qirana iriqini.
\q1 
\v 19 Kuqaa Anutufa qini ufa irinoo, qini innaaru qirana faqa irinoo.
\q1 
\v 20 Anutufa sia qini innaaru qirana minniseenoo.
\q1 Sia narí aiqama kari amuqusiranara qao qinoo.
\q1 Minara mina auqu uqeerasee mina amooqiaqa.
\c 67
\s1 Anutuna dufi dufi qimamaqara idi.
\q1 
\v 1 Anutu anee maasara qimudaoo qimasee amiqi amiqimmaqisaa.
\q1 Aneenna oori afiri kaaqa qarana maasiannai ubeekamasee dadaaqia.
\q1 
\v 2 Miqinaqa ani oosana aiqama maqa maaqakinaasa iriaqa.
\q1 Aiqama maqannaasa ani asumu mariranara faqa iriaqa.
\q1 
\v 3 Oo Anutu aiqama faiqí anaasee ani amooqiaqa.
\q1 Aiqama faiqí anaasee ani amooqiaqa.
\q1 
\v 4 Oo Anutu, anee faiqí anaasee aiqama amana amana kai andeeqasee rakisi mariannana faqa amiqimmasee naamua qimasee nifiqee fimariannanara faqa aiqama maqannaasa asasammasee idi raidaqa.
\q1 
\v 5 Oo Anutu faiqí anaasee ani amooqiaqa.
\q1 Aiqama faiqí anaasee ani auqu uqeeraaqa.
\q1 
\v 6 Miqifanoo maqakiqari aiqama narana kambiqanoo.
\q1 Kambiqainanoo Anutufa maasa Anutufa amiqi amiqimma qimaqaannoo.
\q1 
\v 7 Anutufa maasa amiqi amiqimma qimaqanau.
\q1 Aiqama maa maqanasaaqaraa fasiqa anaasee minara uriqarara fee qimasee qeerairiaqa.
\c 68
\s1 Isaraee maqannaasa Anutufa misa dadaaqunara asasiqau.
\q1 
\v 1 Anutufa findifinoo narí namuqaauqa mara furufaramma saifaqa daraania.
\q1 Anutunara fidiaqaa imariasa mina oorisaaqari nisaurusee quqasee sandaaqa.
\q1 
\v 2 Aneenna namuqaauqa ufai idamuna fuaqa aqindeemma saina fifuaqa.
\q1 Mandainaina maree mariasa ainoo ainaina idaki
\q2 quqasaafanoora foora iqa Anutu ani afusaaqari tasirisirimma taikafuaqa.
\q1 
\v 3 Andeeqee mariasa asasidaqa ani Anutuna afusaa nasuriaqa.
\q1 Misa faaqa rumasee asasiaqa.
\q1 
\v 4 Innee Anutunara idi raida mina auqu amooqirana amiaqa.
\q1 Oonnamusaa ooqumarifi nimari Anutuna aana andeeqaa.
\q1 Mina auqu Yaaweefa maridanoo. Mina afusaa asasiaqa.
\q1 
\v 5 Anutufa narí naaquqara amaana maqaki marifa
\q2 fiaiqi faiqi rakisi nimaqaidanoo, adeedaana aanaaseeuqa faqa ummaaraki itita nimaqaidanoo.
\q1 
\v 6 Anutufa náriaraa mariasa mareeqee moo fasiqa anaasee nári faiqi kiaqeera nimidanoo.
\q1 Mifa rumbaranaki mariasa idukusee nifieeqee amiqiranaki quqannisaidanoo.
\q1 Anutuna ufa rukiee mariasa sia miqidaqa, misa manda maqa maaqaki marifaranoo.
\q1 
\v 7 Oo Anutu, anee ooqai Isaraee maqannaa aadana maqa maaqaki nifiqee finau.
\q1 
\v 8 Sinai aaqanasaa marunna Anutufa, Isaraee maqannaa
\q2 Anutufa, anee ooqai Isaraee maqannaasa nifiqee funanoo maqa kasinoo aaku nammariara foora adianau.
\q1 
\v 9 Oo Anutu anee qunanoo aaku firaafa rufanoo ani maqa Isaraee maqa maaqa mandaikinoo marufa amiqinau.
\q1 
\v 10 Ani maqannaasa mi maqa maaqanaki oonu marufaqa akaqausa kudi marufana Anutu anee afaaridana misa narana niminau.
\q1 
\v 11 Yaaweefa faiqí anaasee naamua qufaqa aanaaseeuqa
\q2 mi ufana mara maree aiqama maaqi qimasee qimannimiqau.
\q1 
\v 12 Kannaa maqannaa karaambaiqauqa faqa sundiauqa faqa anirandee sandama qaraasidammiaafoo qiqau.
\q1 Miqi qufaqa Isaraee maqannaa aanaaseeuqa oonu misa rakiranaki maraqoo ainainausa marasee rainaqau.
\q1 
\v 13 Mi anaaseesa siruaannnai faqa koorannai faqa nifaaqa auqusoofanoo amiqira ufiniara foora inoo marinau.
\q1 Misa nifaaqa fannoo siruaara foora daroo daraa ufanoo misa niqoosara foora koora fannoo kaaqa qee marinau.
\q1 Miqi marufaqa akaqausa nanaree kaqi nariqa sipsipasaa rakisi mariqau.
\q1 
\v 14 Mi rakiranaki aiqama afeeka faqaa Anutufa karaambaiqauqa Saramoona aaqanasaa naru nindaqaaqa ufaqa fifainufanoo firaa oonnamuara misaqa aiqamai itita aqufinau.
\q1 
\v 15 Basana aaqana kaaqa uriqarara aaqana maridanoo.
\q1 Miqoo moomoo kaqikaa aaqanauqa mina aaqa maridanoo.
\q1 
\v 16 Innee Basana aaqanasaa maria aaqanausa nanaree innee Sioona Anutufa mari aaqannara fifau ainainee qidee.
\q1 Yaaweefa narí kai mi aaqannana utaaqamaseenoo naaruara mi aaqannasaa mariannoo.
\q1 
\v 17 Anutufa narí sundiauqa moomoo tauseenna afeeka rakira karauqasaa ooqufaqee marusa faqa Sinai aaqanaindari qumuree Sioona aaqanasaa narí uiqaana maaqaki keeqanau.
\q1 
\v 18 Anutufa Sioona aaqanasaa ooru fidanoo rumbarausa aana muqunufaqa ooru fiqau.
\q1 Mifa miqoo ooru marufaqa faiqí anaasee akaqa ainaina Yaaweena mini amiqau.
\q1 Yaaweena ufa ooqai rukieeusa misa faqa akaqa ainaina amiqau. Mifa miqoo mariannoo.
\q1 
\v 19 Yaaweena amooqimamaqaa.
\q1 Maasa Anutufa maasa asumu maree marifa marina amooqiaqa.
\q1 Mifa aiqama kari maasa ummaara dadaaqi marifa marinara mina amooqiaqa.
\q1 
\v 20 Maasa Anutufa asumu marirana qimimari Anutufa maridanoo.
\q1 Yaaweefa maasa kuqiranakinaana asumu maree mari Karaambaiqafa maridanoo.
\q1 
\v 21 Anutufa narí namuqaauqa nikiiqa kuqaa uqanna radandamumma saannoo.
\q1 Nári aaqara oosanaki afeekaikammandee fimariasa faqa radandamumma saannoo.
\q1 
\v 22 Yaaweefa maaqi qinau, inni namuqaa Basana maqa maaqaki mariana nifiqee anianaura.
\q1 Ooruku nammari farumakiara foora mariana oonu nifiqee anianaura.
\q1 
\v 23 Innee inneeqa namuqaa narusaifaqa inni maqannaasa misa fidikaki niku reefaranoo.
\q1 Fainiuqa nári nidiranasaa misa fidika neefaranoo.
\q1 
\v 24 Oo Anutu qini karaambaiqa.
\q1 Anee moomoo fasiqa anaasee aana muqunimma maree aneenna amaana maqaki keeqararee qimarianaqa doo aiqamausa misa nindafaidaqa.
\q1 
\v 25 Idi ree mariasa indaaru fimarifaqa piripunna ari mariasa inaaqianna fuafaqa qambaana temberinna ari maria manaaqausa fidaqa.
\q1 
\v 26 Innee Isaraee maqannaa fasiqa anaasee suqiqa marianakiqari Anutuna amooqiaqa.
\q1 Innee Yakooboona saaqari kambiqarausa innee Anutuna amooqiaqa.
\q1 
\v 27 Isaraee maqannaasa Beensamina akeeku akaaku qoodaa marusa indaaru fimarufaqa Yudana akeeku akaaku marusakiqari uriqararausa moomoosa faqa Seeburuna akeeku akaaku kiqari faiqí uriqararausa faqa Napatarina akeeku akaaku kiqari faiqí uriqararausa faqa misa ninaaqianna amaana maqai suqirannai ooru fiqau.
\q1 
\v 28 Oo Anutu anee aneenna afeeka maasa uqaqifiqaa.
\q1 Oo Anutu, anee ooqai aneenna afeeka uqannifiqoonnandee kai inana maqee faqa uqannindiqaa.
\q1 
\v 29 Anee aneenna uriqarara amaana maqaki Yeerusaree maqusai mariannanara, moomoo maqanaa karaambaiqauqa kaqi nimimaria ainainnaa maree mini ani amifaranoo.
\q1 
\v 30 Firaa doona aqmauraqmauri marinaki mari kaasau aandaufa Isipa maqannaa karaambaiqa Faraoofa maasa darirarinana Anutu anee minara aanoo qimasee qaoo qia.
\q1 Faraoona dadaaqimaria uriqarara fasiqausa aanoo qimaria burimmakau akoonausara foora kaiqeesa qambaana oonuree narirara ifana anee misara faqa aanoo qimasee qaoo qia.
\q1 Anee misa mara muqufisainaqa misa siruaa mara maree mini ani amiaqa.
\q1 Aiqama rakiranara rimaria maqannaasa anee misa naru nindaqaaqa masainaqa daraaniaqa.
\q1 
\v 31 Isipa maqanaa uriqararausa Anutufinnai ubeekarara anifaranoo,
\q1 Eetoopia maqannaasa nisauku uqeerasee Anutunara innaaru qifaranoo
\q1 
\v 32 Oo innee maa maqanasaa mariasa innee Anutuna idi ramamaqaaqa.
\q1 Yaaweena amooqira idi raaqa.
\q1 
\v 33 Anutufa ooqaindari mari innaarunasaa nimari Anutunara amooqira idi ramamaqaaqa.
\q1 Mi Anutuna ufa firaafa innaarunai qiara foora qimarifa maridanoo.
\q1 
\v 34 Innee Anutuna afeekara koorooiaqa.
\q1 Mina amiqira uriqararafa Isaraee maqannaasa rafaaqafu nimaqaidanoo.
\q1 Mina afeeka innaarunai maridanoo.
\q1 
\v 35 Isaraee maqannaasa Anutufa narí amaana maaqaki
\q2 marifa kaaqa naaquqarafa marinara rufiaaqa.
\q1 Mifa uriqarara afeeka faqa eeraarirana faqa narí faiqí anaasee nimidanoo. Anutuna amooqiaqa.
\c 69
\s1 Isaraee maqannaasa Anutufa dadaaqianifeera innaaru qiqau.
\q1 
\v 1 Oo Anutu anee uqeeraqisaa.
\q1 Nammariara foora qini ummaara fannoo rafaaqafinoo
\q2 qinukaki ururaifaqa kaqi kaaqoo kuquanaura.
\q1 
\v 2 Qinee firaa doona poopoo qimarinakiara foora qiku
\q2 utusaqa maridaqa sia afeeka maqasaa qiku raidaqa.
\q1 Qinee nammari difukunaki aniraunanoo nammari aufirafa qini dukuniaqaa idanoo.
\q1 
\v 3 Qinee Anutufa dadaaqianifeera aaraida afeesida marunanoo qini daunda aadana usufifanoo qini ufa akieenoo.
\q1 Aniara rakisida marida qifuanda rakee iqa.
\q1 
\v 4 Qiniara fidiaqaa imariasa qini qikiiqa asausi faqa arusee fiqaramasee maridaqa.
\q1 Qini kuqa darirari mariasa fifau qini oosana siainaki namuqaakamma qimaqaidaqa.
\q1 Misa qiniara moo ainaina fifau unnaqimasee ummuariaanoo qimasee mina akiiqara nimiannee qimasee sandanainai qiafaqa rufiaseeqa fifau qeeqa ainaina nimiqa.
\q1 
\v 5 Oo Anutu qini furufarira oosanara anee irimmariananoo,
\q2 qini aaqarafa sia ani afusaa kukeeqanoo maridanoo, akooqoo maridanoo.
\q1 
\v 6 Oo Yaawee, anee qini dadaaqinaqa sia moo aaqaranaki aqufuanaqa ani ufamau fimariasa nisauruaqa.
\q1 Oo uriqarara Yaawee aiqama afeeka faqaafa anee qini dadaaqinaqa aniara innaaru qimariasara sia manda ufa qimannimaqaaqa.
\q1 Oo Isaraee maqanaasa Anutufa miqimma qimaqaa.
\q1 
\v 7 Oo Anutu, ani auqu raunnanara aasaandaana ufa qimi mariafaqa qini qisaurirafa qini rafaaqafuqaifaqa maridaqa.
\q1 
\v 8 Qinee ani auqu raunnanara qeeqa qikaqaafasaa nifusaa aanaamuruara foora maridaqa.
\q1 Qeeqa qinoona faiqi namu nifusaa moo aanaamuruara foora maridaqa.
\q1 
\v 9 Qinee ani Anutuna amaana maqara didirafa firaaqoo idara foora qaidanoo.
\q1 Ani Anutuna aquraree maria aqurararafa qinisaa faqa aqufinoo marifaqa maridaqa.
\q1 
\v 10 Qinee qeeqa mara maree muqusee narana auramasee marunaqa faiqí anaasee qini qiqafamasee aasaandaana ufa qimaqimaqaidaqa.
\q1 
\v 11 Qinee manda qammunna soofaara qammunnara foora afisuqaunaqa faiqí anaasee qiqafamaseeqa qiniara ataasa ataasa qimasee naanaidara qima qimaqaidaqa.
\q1 
\v 12 Aatata oonuree aniree idaqa qini qiqafee mandufa qidaqa.
\q1 Afeeka nammari namasee furufari mariasa faqa qiqafeeqa manda idi qiniara raidaqa.
\q1 
\v 13 Qinee sia misa ufa irianaura aniara kai innaaru qianaura.
\q1 Oo Yaawee, aneenna qinna kari qini innaaru akiiqara kafaa qiqa qimaqimia.
\q1 Anee qima afeekaikammasee qini asumu maraanauree qunnanara irisee miqia.
\q1 Anee sia unna qimarianafa mariananoo.
\q1 
\v 14 Doona poopoo qimarinakiara foora utusaqa maridaqa Oo Anutufa anee qini qumaree tatu qisainaqa sia minaki ooqu keeqafi minaki kuqua.
\q1 Qini namuqaa nisaukukinaana maraquqisaa.
\q1 Faruma firaanaki uqnauriranakiara foora aqufiqa marunnana umbaqi afainni quqaqisaa.
\q1 
\v 15 Oo Anutu anee qinanooo sia nammari qini dukuniani.
\q1 Faruma uqnauriranaki sia qinee aqufiqa ukuqnaanaura.
\q1 Sia qinee madikakiara foora aqufuana maqa fannoo mafi titaqisaani.
\q1 
\v 16 Oo Yaawee, anee aneenna amiqiranakiqari qini innaaru iria.
\q1 Anee aneena firaa nifauaranakiqari qinee unnannai oori ubeekaa.
\q1 
\v 17 Oo Anutu, qinee ani ainainira faiqi marunnanara sia anee oori rafusu kaqinni aqua.
\q1 Qinee firaa ummaaraki marunnanara dauni dauni qini irara ufa anoona qima qimia.
\q1 
\v 18 Oo Anutu, anee qini daaqa aniree qini namuqaa nisaukukinaana mara asumu quqaqisaa.
\q1 Qini namuqaauqa darirarifana qini mareeqee kaqinni qisaa.
\q1 
\v 19 Oo Anutu, qini namuqaauqa anee niqafee mariana qiniara aasaandaana qirana faqa mandaikamma qimaqarana faqa qisaurirana faqa qimi mariafana anee iri mariananoo.
\q1 
\v 20 Qini aasaandaana ufa qimiafa qini qimuqusa raquruqiminoo marifaqa qini qifaaqaki aiqama ummooqukinoo marifanoo qini qifaaqa dadaaqirafa sia maridanoo.
\q1 Qinee nimuqusiranara randauna sia moo fannoo qiniara amuqusirafa maridanoo. Qinee qimudao qira ufa qima qimaqarausara randauna sia uqanna maridaqa.
\q1 
\v 21 Qini daararaifaqa misa qini naranaki qumee adudu fooqaana minaki quqasee qimiafaqa nauna suka darifaqa minniseeqa.
\q1 Qini nammariara didifaqa misa sukaqee mari nammarina qimiafaqa namasee qafeeqa minniseeqa.
\q1 
\v 22 Mi manda oosanna qimimariasa nariqa narana difaani fannoo nári quandaki kuridi nimaqaani.
\q1 Misa nariqa mi firaa naaquqara oomaqafa nikuqamasaina aqufuaqa.
\q1 
\v 23 Misa nifu asukunaarusaina mikiqmakiqa nuaqa.
\q1 Misa nitaufaka faqa rambaqasaina naaruara miqiqa mariaqa.
\q1 
\v 24 Oo Anutu, aneenna aranaqarana nammariara foora misasaa adiasaa.
\q1 Ani aanooqirafa idara foora misa qama taikaani.
\q1 
\v 25 Misa maqa maaqa naakundu kai saaeemasaa.
\q1 Sia moodaafa faqa nariqa uiqaana maaqaki mariaqa, naakundu kai mariani.
\q1 
\v 26 Anee Yaaweefa ani ufa rukiee mariana akiiqara anee maasa kaakadi darusaanausa namuqaa anireeqa aaqaidaqa misa kaaqmukaidaqa.
\q1 Kaaqmukamaseeqa misa nári maqusai oonureeqa anee Yaaweefa maasa daruannanara aupuraunaqa ataasataasa qidaqa.
\q1 
\v 27 Oo Yaawee anee misa aaqarana akiiqara sia qaunua amiqimmasee iria.
\q1 Misa ani Anutuna asumu marirana sia uqanna kaqikaana faqa maraaqa.
\q1 
\v 28 Oo Yaawee ani naaru marira papiqaki misa nuqu marina rukaa.
\q1 Aaqee mariasa nuqu sia andeeqee mariasa nuqu namu faqa moodaanaki akara rua.
\q1 
\v 29 Qinee Dafidisa firaa didafirana faqa ummaara faqa maraidaqa.
\q1 Oo Anutu, anee qini uqeerasee asumu marirana qimia.
\q1 
\v 30 Qinee dufi dufi qira idinnai mina auqu qareenaranara koorooianaura.
\q1 
\v 31 Mina mi dufi dufi qirafa burimakau sipsipannoo tatufirana suqami mariana uriaaqaranoo maridanoo.
\q1 Muduka burimakau faqa sipsipa faqa aiku namufaqa
\q2 aanai namu faqa tatufirana suqarana faqa uriaaqaranoo maridanoo.
\q1 
\v 32 Kudi fasiqauqa mina qafamasee asasammifaranoo. Innee Anutunara randeemariasa inni irirana afeekaikamma nimaqaannoo.
\q1 
\v 33 Yaaweefa kudi fasiqauqa innaaru qiana iridanoo.
\q1 Isaraee maqannaasa namuqaa rumbaranaki mariafanoo Yaaweefa misara sia qaunidanoo misara faqa iridanoo.
\q1 
\v 34 Innaarunai mariasa faqa maqasaa mariasa faqa ooruku nammariki nimaria ainainausa faqa Yaaweena amooqiaqa.
\q1 
\v 35 Anutufa Sioona maqusa moo auqu Yeerusaree maqusaki mariasa misa namuqaasaa ititannimaqaannoo.
\q1 Yuda maqa maaqakinaa maqusauqa rapeepaa inoo marinauqa kaifaa itipiannoo.
\q1 Itipammasainaqa faiqí anaasee miqoo kaifaa maridaqa aiqama maqa mareefaranoo.
\q1 
\v 36 Isaraee maqannaasa Anutuna ainainira faiqiuqa,
\q2 misa faiqi namu kambiqafinaqa mi maqusausa marasaifanoo maasaindi kamminoo marinaqa minaki marifaranoo.
\q1 Mina auquara rimariasa faqa minaki marifaranoo.
\c 70
\s1 Dadaaqiani fee innaaru.
\q1 
\v 1 Oo Anutu, anee qini mandainainakinaana mara aquqisaa.
\q1 Oo Yaawee, kai kaqi aniree qini dadaaqia.
\q1 
\v 2 Qini marirana taika qimaqarara randeemariasa rafaaqafu saina nisauriranaki faqa furufariranaki faqa mariaqa.
\q1 Qini ummaarara irisee asasimariasa mara quandasainaqa nisauruaqa
\q1 
\v 3 Qiniara uteeti qimariasa nariqa nisaurirana firaafa marina qafaifanoo firaaqoo naaquqaani.
\q1 
\v 4 Oo Yaawee anee iannannai ani mariasa asasidaqa nasuriaqa.
\q1 Ani asumu mariranara nidimarisa, maaqi qiaqa.
\q1 Yaaweefa uriqararafa maridanoo fee qiaqa.
\q1 
\v 5 Qinee Dafidisa qimudaani radukirausa marunausa saraui marunna fasiqausa marunnanara oo Yaawee anee sia qiniara qaunuananoo.
\q1 Anee qini asumu maree marianafa faqa qini Anutufa faqa mariannanara kai kaqi aniree qini dadaaqia.
\c 71
\s1 Faiqí firaana innaaru.
\q1 
\v 1 Oo Yaawee, anee itita qimaqaanneera anee iannannai anidaqa.
\q1 
\v 2 Anee andeeqarafa mariannanara qini dadaaqinana mareeqee kaqinni quqaqisaa.
\q1 Aneenna aaqoo qinee iannannai rammatinimmandee irisee qini asumu maraa.
\q1 
\v 3 Oo Anutu, anee qini ooni faandaamurara foora faqa auqaanara foora faqa auquqisaina qinee minaki keeqafi asumu maria.
\q1 Anee qini ititee marianna oonifa faqa qini afeeka kukeeqara maqusa faqa mariananoo.
\q1 Anee qinaqa qinee amiqimmasee marianaura.
\q1 
\v 4 Oo qini Anutu, manda oosana maree mariasa nisauku kinaana faqa eendaandi mariasa nisauku kinaana faqa fitiqnarana qimimariasa nisauku kinaana faqa maraquqisaa.
\q1 
\v 5 Oo uriqarara Yaaweefa, qinee aniara kai aambeembeesida marunausa maridaqa.
\q1 Kumaaraasaa qari ani kai saqarikii aafanausa maridaqa.
\q1 
\v 6 Qini maqoonakiqari qinee anisaa mundiqa mariafanausa maridaqa.
\q1 Qini qinoofa maqaqisooqoooqari anee kai qinisaa rakisina aniifana maqee aniraananoo, minara qinee maqee maqee ani amooqianaura.
\q1 
\v 7 Moomoosa qini faqa qiniki kambiqoo ainainna faqa qafamasee iriqau.
\q1 Minara anee kai qini afeeka kukeeqara maqusara foora mariananoo.
\q1 
\v 8 Aiqama faasaambaasaana qinee ani amooqidaqa ani qareenaranara koorooidaqa.
\q1 
\v 9 Oo Anutu, qinee asooqa qaanana sia qini maraquqisaa.
\q1 Qini afeeka taikainana sia qini minniqisaa.
\q1 
\v 10 Qini namuqaauqa qini darirarammidaqa.
\q1 Qini dariraree qimasee ufa suqidaqa tipundaaridaqa.
\q1 
\v 11 Misa qiniara maaqi qidaqa.
\q1 Anutufa mina minnisaifanoo sia moo fannoo mina dadaaqirafa maridanoo, anifaqa mina afaqaseeqa qumaraanee qidaqa.
\q1 
\v 12 Oo Anutu, sia nianasaa maria.
\q1 Oo qini Anutu dauni aniree qini dadaaqia.
\q1 
\v 13 Qini darirari mariasa anee Yaaweefa misa rafaaqafu nimaqasee kuridi taikannisaa.
\q1 Qini aupurarana qimirari mariasa nisauriranaki faqa aupuraranaki faqa mariaqa.
\q1 
\v 14 Qini irirafa naaru naaru aniara kai aambeembeesida mariannoo.
\q1 Qinee kaifaa kaifaa ani amooqima amaqaanaura.
\q1 
\v 15 Qini doo fannoo ani Anutuna andeeqarana faqa asumu mariranara faqa faasaambaasaana kooroo ianaura.
\q1 Qinee mi andeeqarafa faqa asumu marirafa faqa fiqaranoo marifaqa ati kai iridaqa mina oosanara faqa ammuquara faqa sia iridaqa.
\q1 
\v 16 Oo uriqarara Yaaweefa qinee anee amudaanai qimasee auqunna ainainausara kooroo ianaura.
\q1 Qinee ani andeeqaranara kooroo ianaura. Anindiara kai kooroo ianaura
\q1 
\v 17 Oo Anutu, anee qini kumaaraasaaqari oosana arasee aneenna oosana uqaqifiqana ani mariananoo.
\q1 Qinee miqooqari anee firaa ainaina auqoonnanara faiqí anaasee kaqi kai qimannimiqa fidaqa.
\q1 
\v 18 Oo Anutu maqee qinee nauraiqi aandau aanaaqi maridaqa sia qini minniqisaa.
\q1 Anee qini faqa marinaqa qinee naaru kambiqainausa faqa qimanimia.
\q1 
\v 19 Oo Anutu, ani andeeqarafa maqasaaqari innaaruna auqanoo maridanoo.
\q1 Anee firaa ainaina auqunafa mariananoo.
\q1 Oo Anutu yafee ani fooqaafa maridanoo fee.
\q1 
\v 20 Oo Yaawee, anee oosana oosana ummaara faqa aupurarana faqa qimimariananoo.
\q1 Kasooqaqee anee kaifaa qini marirana ooqai mariundeemma qiseennaranoo.
\q1 Anee qini kuqa dariranasaa itita qimaqeennaranoo.
\q1 
\v 21 Anee qini firaaqoo uqeera murufi qiseennaranoo.
\q1 Anae kaifaa qini amiqi amiqimma qima qeennaranoo.
\q1 
\v 22 Oo qini Anutu, ani mapukusee marira oosanara piripunna aridaqa ani amooqianaura.
\q1 Oo Isaraee maqannaasa naaquqara Anutufa, qinee piripunna aridaqa ani amooqira idi raanaura.
\q1 
\v 23 Qinee piripunna arida ani amooqira idi raidaqa firaaqoo asasianaura.
\q1 Anee qini mandainainakinaana kaqinni mara quqaqisaannanara asasidaqa.
\q1 
\v 24 Qinee faasaambaasana ani andeeqaranara qimannimianaura.
\q1 Qini didafirana qimirari mariasa anee rafaaqafu nimaqasee mandaikamma nimaqaannanara irisee ani andeeqaranara qimannimianaura.
\c 72
\s1 Maqasaa karaambaiqa fannoo dadaaqianifeera innaaru qinau.
\q1 
\v 1 Oo Anutu anee Isaraee maqannaa karaambaiqa aneenna amiqimmasee ufa irira oosana amia, aneenna andeeqara oosana faqa mina amia.
\q1 
\v 2 Mifa andeeqaranannai ani Anutuna faiqí anaasee ufa andeeqannisaani.
\q1 Narí maqannaa nuqu siai fasiqa anaaseesa faqa amana amana kai andeeqasee ufa raina nimaqaani.
\q1 
\v 3 Miqi marinaqa misa maqa maaqa ainoo kinoo aiqama ainaina rairaaiani.
\q1 Mi maqanasaa mariasa andeeqara oosana mareefaranoo.
\q1 
\v 4 Mi karaambaiqafa kudi fasiqa anaasee amana amana kai raina nimaqaani.
\q1 Ainaina siaisa faqa ummaaraki marianasaa ititannimaqaani.
\q1 Mifa nariara uriqararausee qimasee akaqausa rafaaqafi mariasa radamusaani.
\q1 
\v 5 Ani faiqí anaasee suani afu kaqi qeemarinaqa ani amooqiaqa.
\q1 Quqoona faqa kaqi qeemarinaqa ani amooqiaqa.
\q1 
\v 6 Mi karaambaiqafa aakuara foora fuka afuqaki rifanoo aiqama andanda afu amifanoo raambandaariara foora iani.
\q1 Mifa aakuara foora rinoo maqa uqeenuqeeniani.
\q1 
\v 7 Mi karaambaiqafa marianinna aukuana faiqí anaasee andeeqara oosana kai maraaqa.
\q1 Quqoona kaqi qeemarinanoo reemindeemirirafa kai mariannoo.
\q1 
\v 8 Mina rakisinnimaqarafa dinni ooruku nammarinni oosanarasee dinni ooruku nammarinni amanasaa rakisinnimaqaani.
\q1 Dinni ati fannoo Eeufarateesa nammarindari maqa maaqa atinni amanasaa rakisinnimaqaani.
\q1 
\v 9 Aadana maqa maaqaki mariasa karaambaiqa aninaqa mina oorinni kummarama fifaranoo.
\q1 Mina namuqaa faqa mina qafamasee maqasaa aqufifaranoo.
\q1 
\v 10 Sipeena maqannaa karaambaiqauqa faqa kaqikaa afuma kiaqa maria karaambaiqausa faqa amiqira ainaina mara maree Isaraee maqannaasa karaambaiqa mini amifaranoo.
\q1 Seebaa faqa Sibaa maqannaa karaambaiqauqa faqa amifaranoo.
\q1 
\v 11 Aiqama maqannaa karaambaiqauqa maasa uriqarara fee qimasee mina oorinni niqoori saunu areefaranoo.
\q1 Aiqama maqannaasa mina ainainira faiqikamma fifaranoo.
\q1 
\v 12 Mifa kudi fasiqauqa nammeera qiafanoo iriseenoo dadaaqidanoo.
\q1 Kudiki mariasa faqa dadaaqirana siaisa faqa misauqa aiqama dadaaqiannoo.
\q1 
\v 13 Mifa kudiuqa faqa ainainirana sia amanaiki marifaqa ummooquki mariasara faqa qimudaoo qimasee dadaaqi marifa mariannoo, sarau imariasa nimana faqa kuqiranakinaana maree marifa mariannoo.
\q1 
\v 14 Mi karaambaiqafa mi kudi fasiqausa faqa ummooquki maria fasiqausa faqa kuqa narirari maria fasiqausa nisaukukinaana mara kaqinni quqannisaannoo.
\q1 Mifa misara uriqarara ainainee qimasee miqidanoo.
\q1 
\v 15 Mi karaambaiqafa kisaaqasaa mariani.
\q1 Seebaa maqannaasa nariqa koora mi karaambaiqana amiaqanani.
\q1 Aiqamausa maqee maqee Anutufa mi karaambaiqana dadaaqiani feera innaaru qimamaqaaqanani.
\q1 Aiqama faasaana Anutufa mina amiqimma amaqaani.
\q1 
\v 16 Mi karaambaiqafa marinna kamuqoo mi maqa maaqanaki sakuma faqa uita faqa moomoo rairaa inoo mariani, kaqikaa amuaqu namuqasaa faqa narana kai itita fuani.
\q1 Mina qaqama fannoo Reebanoonna maqa maaqakinaa saqari aanna reenoo moomoo qaqama ireenoo rairaaiani.
\q1 Mi maqusausa kiaqa faiqí qumbiaqa mariaqa.
\q1 Mi sakummana qaqama faqa uita qaqama faqa andandara foora sia kasoo mariani.
\q1 
\v 17 Mi karaambaiqana auquara naaru naaru sia aunuaqa.
\q1 Mina uriqararafa aiqama kari suani afuara foora uridaa kai mariani.
\q1 Aiqama maqannaasa mi karambaiqana amiqa amiqimma amaqoonandee inana maasa faqa amiqi amiqimma qimaqaannee qimasaidaqa qifaranoo.
\q1 
\v 18 Isaraee maqannaasa Anutufa moo auqu Yaaweefa, mina amooqimamaqaaqa.
\q1 Mifa naríara maa idaaqira ainainausa auqee marifa maridanoo.
\q1 
\v 19 Mina areenara auqu naaru naaru amooqiaqa.
\q1 Maa maqa maaqanakina aiqamai mina qareenarafa qumbiqanoo mariani.
\q1 Kuqaa uqanna.
\q1 
\v 20 Qini Dafidisa Yeeseena amaaku marunausa doo qini innaaru qirafa taikeenoo.
\c 73
\ms1 Mina Anaaqiannaa Papiqa (Book 3)
\mr Idi Ufa 73–89
\s1 Anutuna andeeqannimaqarafa.
\q1 
\v 1 Oo kuqaa Anutufa Isaraee maqannaasa amiqi amiqi marifa maridanoo.
\q1 Anukara nimuqusa faqaasa amiqi amiqimma nimaqaannoo.
\q1 
\v 2-3 Manda oosana maree mariasa aiqama ainaina amiqifaqa nári nimoo naamoo qiafaqa qinee qafaunanoo qirana qaifaqa Yaaweena minnisaaqaa unanoo Yaaweenaki mapukiqa marunafa taikaaqaammidanoo.
\q1 
\v 4 Miqi mariasa sia nidafirana maraidaqa.
\q1 Misa nifaaqa afeeka marifaqa sia dinee teeroo maraidaqa.
\q1 Amiqirausa maridaqa.
\q1 
\v 5 Misa sia akaqausa naanna raidaqa, sia ummaara oosana oosana faisa maridaqa.
\q1 
\v 6 Misa noori uqeerasee ramooramaairafa misa ninukakinaa kukukakanara foora maridanoo.
\q1 Faiqí narirana misa qamunnara foora nári nifaaqai afisuaqee maridaqa.
\q1 
\v 7 Misa nimuqusa kiqari oosana oosana manda oosana kambiqaidanoo.
\q1 Misa iriranaki oosana oosana manda ainainara oonu auqee ani auqee idanoo.
\q1 
\v 8 Misa akaqausara naanaidara qidaqa mandainainara ufa qidaqa.
\q1 Misa nári nimoo naamoo qidaqa akaqausa uriqaramafi rakisi nimaqaanauree qimasee tipundaaridaqa.
\q1 
\v 9 Misa innaarunai mari Anutuna manda ufa qimamaqaidaqa.
\q1 Misa nári ufamau fuaqeera aanoommasee maqasaa fasiqauqa qimannimidaqa.
\q1 
\v 10 Minara Anutuna faiqí anaasee misiannai quandafiqa aaqaidaqa misa ufara anoonee qidaqa.
\q1 
\v 11 Mi manda oosanna maree mariasa maaqi qimasee unnaqidaqa.
\q1 Anutufa maasa oosana sia iriannoo.
\q1 Uriqarara Anutufa sia manda oosana paquriannoo fee qidaqa.
\q1 
\v 12 Doo qafaa. Mi manda oosanna maree mariasa oosana miqimminoo maridanoo.
\q1 Misa maaqimmiqa maridaqa misa moomoo ainaina faqaasa maridaqa aiqama kari moo faqa moo faqa mara usidaqa.
\q1 
\v 13 Qinee misa nindafamaseeqa maaqi qimasee manda irirana qiqa.
\q1 Fifau qinee andeeqaidee qidaqa.
\q1 Qinee fifau aaqara oosanara qeerairi marunausee qidaqa.
\q1 
\v 14 Oo Anutu anee faasaambaasaana qini aupurarana qimimariananoo.
\q1 Aiqama kananaana kananaana ummaara kai daridanoo.
\q1 
\v 15 Qinee mi manda aaqara ufana qidaqau ani Anutuna faiqí anaasee naanna sia raunaiqini.
\q1 
\v 16 Qinee mi oosana oosana marirana oosanara irianeera oonu mafi irunanoo kadaapi daridanoo.
\q1 
\v 17 Miqiqa maridaqa ani Anutuna amaana maqaki keeqafifaqa mi manda oosanausa maree mariasa nifaaqai kambiqaaninna ainainara iriqa.
\q1 
\v 18 Oo Anutu, anee mi manda oosanna maree mariasa mareeqee farindara maqasaara foora quqeennaranoo.
\q1 Anee qinaqa misa mareeqee kuridiranaki aqifaranoo.
\q1 
\v 19 Misa tautummaki mandainainaki kuridiranaki aqufidaqa.
\q1 Miqi mariasa manda kuqiranaki ooqu fidaqa.
\q1 
\v 20 Aaqee mariasa qainammasee findifinana qaunuannandee inoo misa marirafa kai kaqi taikaanoo.
\q1 Oo Yaawee aneenna mariannaqooqari findifuanaqa misa mina qafamasee miqooqari doo sia siammafia.
\q1 
\v 21 Qinee manda oosana maree mariasa moomoo qumiasanara irunanoo qini irirafa suka qaifanoo qini qimuqusa mandaikinoo.
\q1 
\v 22 Qinee kaasau aandaura foora ani afusaa irirana siaisa furufarirausa maridaqa.
\q1 
\v 23 Miqiqa maridaqa ani aaqa aiqama kari marunana, anee qini qisauku uqannai qisauku qumaree qisaadaku imarianafa mariananoo.
\q1 
\v 24 Anee aneenna aamuaqira ufannai qini daamua qimaseenana qini itita qisamammaree munusee kasooaqee innaarunai qifiqa quqaseenana uriqarara duqu qimisainaqa ani faqa marianaura.
\q1 
\v 25 Yafee moo fannoo innaarunai qini qiqoondi maridanoo fee, sia moo fannoo maridanoo, anee kai.
\q1 Qinee ani Yaaweena maraafannaqooqari nannee moo maa maqa maaqanasaaqaraa ainainara didiannoo fee.
\q1 Aniara didirafa aiqama minauqa uriaaqaranoo maridanoo.
\q1 
\v 26 Qini irirana faqa qini qifaaqa faqa ummooquki marifanoo Anutufa qini afeeka maridanoo.
\q1 Mifa qini faqa marifaqa qinee aiqama kari amanaikidaqa.
\q1 
\v 27 Ani nimeesa uqusee kaqinni fimariasa anee mandaikamma nimaqeennaranoo.
\q1 Ani ufaki sia mapukusee kisaaqasaa mariasa anee misa aiqama kuridi nimaqeennaranoo.
\q1 
\v 28 Qinee sia miqidaqa, Anutuna aaqa mariranara qinee kaaqa amiqira fee qidaqa.
\q1 Qinee uriqarara Yaaweena mara qeeqa afeeka kukeeqara maqusaikammiqa. Anee auqoonna ainainara aiqama kooroommasee qimannimianura.
\c 74
\s1 Anutufa Isaraee maqannaasa manda ainainakinaana dadaaqiani fee innaaru.
\q1 
\v 1 Oo Anutu, anee nanaree maasa maaqi uqanna masee minniqisaidanee.
\q1 Anee kisaaqasaafee aneenna faiqí aanaaseera aanooqinnaree.
\q1 
\v 2 Oo Anutu, anee ooqai Isaraee maqannaasa rusandeesamummasee maroonausara, misara amiqi mandee oonumafi iria.
\q1 Anee maasa feefaurummasee aneenna maqannaasaika maqoona marianara oonumafi iria.
\q1 Sioona aaqanasaa anee marunafa mariananoo, minara faqa oonumafi iria.
\q1 
\v 3 Anee mai aniree Yeerusaree maqusa rapeepaa iranauqa qafaa.
\q1 Maasa namuqaauqa ani amaana maqa faqa rapeepaammaseea.
\q1 
\v 4 Namuqaauqa aniree kaasau fainiara foora faaqa ridaqa aiqama ainaina auku usidaqa.
\q1 Misa ani biraka raipaqu quqasee nariqa biraka uqeera quqasee náriara uriqararausee qirana kooroo ianifeera miqiqau.
\q1 
\v 5 Namuqaa ani Anutuna amaana maqaki anireeqa nandakinaa saqari ateekeera foora ani amaana maqa ateekaateekamma quqaseea.
\q1 
\v 6 Misa saasuna qamma firaana faqa mara mareeqa ani amaana maqaki keeqafifaqa aiqama amiqira akara mari saqarisa ateekaa teekamma aquseeqa.
\q1 
\v 7 Misa ani naaquqara amaana maqa ida arasaafanoo aiqama qama taikeenoo.
\q1 Misa ani Anutuna innaaru qimamaqee mariana faqa, rapeemmasaafanoo mandaika mafinoo.
\q1 
\v 8 Mi manda fasiqausa nariqa maaqi qimasee qimiriqa qiqau.
\q1 Doo maasa misa amiqiuqanna masee radamusaanaura.
\q1 Aiqama maqusa maqusa Anutuna amooqi maria amaana maqausa misa idarasoofanoo qama taikanau.
\q1 
\v 9 Maasa Yaaweenara daaqoo auqee mari ainainausa aiqama mandaikamma aqusaqau.
\q1 Tamummaqara fasiqauqa qima qimirausa faqa sia maridaqa aiqama taikafia.
\q1 Minara maasakiqari sia moo fannoo maa manda aukuanafa taikaaninnanara iridanoo.
\q1 
\v 10 Oo Anutu, kisaaqasaa fee namuqaa aniara naanaidara qifaree.
\q1 Naaru naaru namuqaa ani auquara manda ufa kai fee qimarifaree.
\q1 
\v 11 Oo Anutu, nanaree anee maasa dadaaqirara akooqaidanoo fee.
\q1 Nanaree aneenna asauku raqandaammasee maridanee.
\q1 
\v 12 Oo Anutu anee maasa ooqeenna karaambaiqa mariananoo.
\q1 Anee maa maqa maaqanaki maasa moomoo kari mandainainakinaana mareeqee amiqiraqoo quqaqisee marunafa mariananoo.
\q1 
\v 13 Oo Anutu, anee aneenna afeekannai ooruku nammari qambaana rakeeunafa mariananoo.
\q1 Ooruku nammariki mari firaa aandauna akiiqauqa anee rukaminau.
\q1 
\v 14 Anee ooruka nammarikinaa firaa aandau mina auqu Reefiatanee qimaruna mina aiqama akiiqauqa rukamuseenana aadana maqa maaqaki maru aandausa mina amaqi nimunaqa naqau.
\q1 
\v 15 Anee qunanoo maqakinaa nammari faqa nammariuqa faqa quminau.
\q1 Anee aneenna afeekannai firaa nammariuqa aadanusunafa mariananoo.
\q1 
\v 16 Asukuna faqa faasaana faqa auqunafa mariananoo.
\q1 Suani faqa quqoona faqa anee kai quqoonafa mariananoo.
\q1 
\v 17 Oo Anutu anee maqa maaqaki aiqama oosiranauqa quqanau.
\q1 Aiqaiqa dumudumu qira aukuna faqa suara aukuana faqa anee kai auqu quqasoonafa maridanoo.
\q1 
\v 18 Oo Yaawee namuqaa aniara uteeti naakada qimarianara iria.
\q1 Kisaaqasaa furufari mariasa aniara fifau ainaina fee qimasee ani auqu aquraraidaqa.
\q1 
\v 19 Oo Anutu, aneenna faiqí anaasee sia minninnisainaqa fitiqnarana nimimaria namuqaasa maasa daruaqa.
\q1 Aneenna faiqí anaasee namuqaa nimimaria ummaaranaki kisaaqasaa mariasara sia misara qaunua.
\q1 
\v 20 Aneenna ooqai qima afeekaikunnanara minara maqee irisee maasa dadaaqia.
\q1 Maa maqa maaqanaki narari nararirafa aiqama amannaunai faqa asukuna arirannai faqa qumbiqanoo maridanoo.
\q1 
\v 21 Oo Anutu anee ummaara ameemaanai mariasa dadaaqinaqa sia nisauriqa oofikiaqa.
\q1 Kudi fasiqa anaasee faqa sarau imariasa faqa ani auqu amooqiaqa.
\q1 
\v 22 Oo Anutu, findifinana aneenna auqusaa titaa.
\q1 Furufari maria fasiqausa faasaambaasaana ani oosanara uteeti naakada qidaqa.
\q1 
\v 23 Sia anee aneenna namuqaa ani auquara fidiaqaammasee faaqa fuisee qimarianara irisee qaunua, amiqimmasee iria.
\q1 Ani namuqaauqa aniara tutuqirafa kaqikai fida marinara sia qaunua, amiqimmasee iriaa.
\c 75
\s1 Anutuna raina nimaqarafa.
\q1 
\v 1 Oo Anutu, maasa aniara dufi dufi qidaqa ani auqu uqeeraidaqa.
\q1 Maasa anee uriqararafa mariannanara kooroommasee qimannimisee kaifaa anee naaquqara uriqarara ainaina auqoonnanara faqa aiqamausa qimannimidaqa.
\q1 
\v 2 Anutufa maaqi qidanoo.
\q1 Qinee ufa irira faasaana utaaqamaqaunanoo maridanoo, qinee andeeqasee amana amana kai raina nimaqara oosanannoo raina nimaqaanaura.
\q1 
\v 3 Maa maqa maaqanakinaa aiqama ainaina rufieeqa naindiri raifanoo maqa faqa kasinaqa qinee Anutusa kai mina oosana atukaramma qumaraananoo sia kaaqa mandaikiannoo.
\q1 
\v 4 Qinee manda oosana maree mariasa sia ramoo ramaa iaqeera qimannimidaqa.
\q1 
\v 5 Qinee maaqi qimasee qimannimidaqa. Innee sia inneeqa nuqu uqeeraseeqa qiniara sia fee qiaqa.
\q1 
\v 6 Raina nimaqara oosana fannoo sia suani oosanaindari fau sia suani keeqee marinnaindari fau sia dinni dinni ataaqeendari fau anidanoo fau.
\q1 Sia moo fannoo suani dinni dinni ataaqeendari amana faiqí raina nimaqaannoo.
\q1 
\v 7 Anutufa kai faiqí rainee marifa maridanoo.
\q1 Mifa kai moo mara maqasaa muqufi quqaidanoo, moo uqeerasaifanoo uriqaraidanoo.
\q1 
\v 8 Yaaweefa narí asaukuki narí aanooqira nammari taqu uaqee idanoo.
\q1 Mi taqufa afeeka wainna mina aanooqirafa qumbiqanoo marina uaqee idanoo.
\q1 Mifa mi nammarina adiasaifaqa aiqama manda oosana maree mariasa namaseeqa mandainainaki maridaqa.
\q1 Misa aiqama nama taikaidaqa, sia atiti taquki kaqi mariannoo.
\q1 
\v 9 Qinee Yakooboona Anutunara naaruara naaruara koorooiqa fuanaura.
\q1 Qinee Yakooboona Anutunara idi raidaqa amooqianaura.
\q1 
\v 10 Mifa manda oosana maree mariasa afeeka aiqama rauda nimaqaannoo.
\q1 Andeeqara oosana maree mariasa afeeka moo faqa moo faqa nimiannoo.
\c 76
\s1 Anutufa rakirana uriqaree marifa maridanoo.
\q1 
\v 1 Yuda maqannaasa Anutuna auquara iridaqa,
\q1 Isaraee maqa maaqakina mariasa mina auqu uqeeraidaqa.
\q1 
\v 2 Anutuna uiqaana maqa Yeerusaree maqusaki maridanoo.
\q1 Mifa Sioona aaqanasaa maridanoo.
\q1 
\v 3 Miqoo Yeerusaree maqusaki Anutufa namuqaa duru feefa saqari raudaandamma aqinau.
\q1 Mifa saqari faqa saamu faqa oosana oosana rakira ainaina faqa aiqama itairaatairamma aqinau.
\q1 
\v 4 Oo Anutu, anee firaaqoo qareenarafa mariananoo.
\q1 Anee aaqanasaa aneenna namuqaa rafaaqafuseenana aneenna uriqarara rupannoo irana namu faqa oorurandee qumuananoo.
\q1 
\v 5 Oo Anutu, anee ufa qunaqa sundiauqa nimudaanai qimarusa doo kuqufufaqa akaqausa misa aiqama ainaina raipaqu maraqau.
\q1 Misa aiqama doo saara faiqaidaqa sia kafaa findi fifara.
\q1 Misa aiqamausa rakira afeeka faqa akoofasaikirafa faqa sia nariqa dadaaqufaqa kuqiqau.
\q1 
\v 6 Oo Yakooboona Anutu, anee aanoo qianaqa rakira qoosauqa faqa qoosasaa ooqu marifi nimariasa faqa rakira afeeka taikafifaqa maqasaa aqufi kuqiqa maridaqa.
\q1 
\v 7 Oo Anutu, aiqamausa aniara rufiee mariafa mariananoo.
\q1 Anee aanooqinaqa sia amana moo fannoo ani afusaa kikiqiannoo.
\q1 
\v 8 Oo Yaawee, anee innaarunaindari andeeqa nimaqara ufa qunaqa maqasaa fasiqauqa rufiasee ufa sia qirai madoodoonnama fiqau.
\q1 
\v 9 Akaqausa uriqararanannai rafaaqafu nimaqaafaqa aiqama maa maqanasaa anee misa dadaaqiraree qimasee findifi andeeqara ufa qunaqa aiqama irisee daimmafiqau.
\q1 
\v 10 Faiqí faiqi aanoo qirafa quandaki ani Yaaweena amooqirana moo faqa moo faqa amidanoo.
\q1 Akaqausa mi rakiranaki sia kuqinausa ani ufa suqiranaki ani amooqifaranoo.
\q1 
\v 11 Innee inneeqa Anutuna Yaaweena amiraree qimasee qima afeekaika maqaa ainaina sia minnisaa, kuqaa mina amia.
\q1 Adeedi maria anaamurusa innee faqa aqoondikira ainaina mina amiaqa.
\q1 Anutufa qifaqa aiqama faiqí anaasee minara rufiaidaqa.
\q1 
\v 12 Mifa nári nuqu uqeeree maria uriqararausa mara muqufi rafaaqafidanoo.
\q1 Mifa maa maqanasaa maria uriqarara karaambaiqausa naindiri rarana nimidanoo.
\c 77
\s1 Ummaara aukuana Anutuna dadaaqiranara innaaru qirafa.
\q1 
\v 1 Qinee Anutunara dadaaqiannee qimasee faaqa riqa.
\q1 Qinee faaqa rimarunanoo mifa iridanoo.
\q1 
\v 2 Qinee ummaaraki maridaqa Yaaweenara innaaru qidaqa.
\q1 Eendaki kisaaqasaa qisauku uqeerasee innaaru qidaqa, sia daundura asooarana mareeqa.
\q1 
\v 3 Qinee Anutunara iridaqa aiaaee qidaqa.
\q1 Qinee minara oonu mafi irunanoo qini daundura ummaara reenoo.
\q1 
\v 4 Eendaki Anutufa sia qini faiqarana qimifaqa qinee oonu mafi irunanoo ummaararaifaqa sia qini ufa qirafa maridanoo.
\q1 
\v 5 Qinee ooqai mariaafannanara iridaqa, mi aukuanna amiqimmasee mariaafannanara oonu mafi iridaqa.
\q1 
\v 6 Eendaki qinee iriqaraasida maridaqa.
\q1 Qinee maaqi qimasee oonu mafi iriranakiqari qeeqa iraidaqa.
\q1 
\v 7 Anutufa naaruaree maasa minniqisaannoo fee.
\q1 Sia fee kafaa naaruara mifa maasara aidiannoo fee.
\q1 
\v 8 Kuqaa fee maasara aidirafa taikeenoo fee.
\q1 Mina maasara qima afeekaikirafa doo fee taikeenoo fee.
\q1 
\v 9 Anutufa narí nifauaranara doo fee qaunuseenoo fee.
\q1 Mina aanoo qirafee mina maasara amuqusirana amaaqa maqanoo maridanoo fee.
\q1 
\v 10 Qinee mina iriseeqa maaqi qimiriqa.
\q1 Maa ainainafa qini daundura ummaara qimidanoo,
\q2 Yaaweena afeeka doo taikanoo mariifoo qidaqa.
\q1 
\v 11 Anee firaa ainainauqa auqoonnanara qinee oonu mafi irianaura.
\q1 Qinee mifa faiqí sia amana auqaaqaa ira ainaina auqoonara irianauree qidaqa.
\q1 
\v 12 Oo Anutu, qinee anee aiqama ainaina auqoonnanara indee indee ianauranoo.
\q1 Anee amudaanai qimasee auqoonnanara qinee oonumafi irianaura.
\q1 
\v 13 Oo Anutu, ani oosana fannoo kaaqa naaquqarafa andeeqarafa maridanoo.
\q1 Unna anutusa sia maasa uriqarara Anutufara foora uriqaraqa maridaqa.
\q1 
\v 14 Oo Anutu, anee faiqí sia amana auqaaqaa ira ainaina auqunafa mariananoo.
\q1 Anee aneenna afeeka aiqama maqannaasaki uqeera akooqoo kooroommasaanaqa qafeea.
\q1 
\v 15 Aneenna afeekannai aneenna aiku asauku ummaarakinaana maraananoo.
\q1 Anee Yakooboosa Yooseefaasa nikeeku nikaaku maraananoo.
\q1 
\v 16 Oo Anutu, nammari fannoo ani qafamaseenoo rufiaseenoo, rakeeinoo.
\q1 Ooruku nammari faruma meemai ooqu marifa faqa ani qafamasee aindirireenoo.
\q1 
\v 17 Oonnamu fannoo ani Anutunara rufiasee maqasaa aaku nammariara foora adianau.
\q1 Innaarunai qirafa firaaqoo darara qufanoo aakuasaa fannoo idauruanda kai qifuki munu raqee mini raqee inoo.
\q1 
\v 18 Ufai namufaqa aaku namu faqa ifanoo ani Anutuna innaarunai qirafa minaki kambiqaifaqa iriqa.
\q1 Ani aakuasaa fannoo aiqama maqa maaqai kaaqa qamannimaqeenoo, maqa fannoo aindiri raifanoo kasinoo.
\q1 
\v 19 Anutu ani aana firaa nammari ameemaanai maridanoo.
\q1 Ani aana firaa nammari ameemaanai marifana mi aatata fuanaqa sia ani aiku amaaqa qafeeqa.
\q1 
\v 20 Mooseesa Aaroonasa rakisiraqanda maridaqa ani
\q2 Anutuna faiqí anaasee sipsipasaa rakisirausara foora iqa nifiqee fiqau.
\c 78
\s1 Anutuna faqa narí faiqí aanaaseera faqa qidanoo.
\q1 
\v 1 Oo qini maqannaasa, innee amiqimmasee qini ufa iriaqa.
\q1 Amiqimmasee naaqoo quqasee qini ufa iriaqa.
\q1 
\v 2 Qinee quandara ufannai inni qimannimianaura.
\q1 Qinee ooqeennaasa ufa oonukeeqee anikeeqee qirana qimannimianaura.
\q1 
\v 3 Maasa ooqai iriafanna ufana maasa qikausa qimaqimu ufana qimannimianaura.
\q1 
\v 4 Yaaweefa amiqira ainaina auqoonara faqa mina afeeka faqa mina naaquqara ainaina auqoona faqa maasa faiqi namu naaru kambiqainausa faqa qimannimianaura sia kukeeqaanaura.
\q1 
\v 5 Yaaweefa narí sanda ufa narí faiqí anaasee Isaraee maqannaasa nimisee,
\q1 Yakooboona aiku asauku narí aauqira ufa niminau.
\q1 Miqimmaseenoo maasa qikeeku qikaaku afeekaikammaseenoo qimanniminoo qinau.
\q1 Innee inneeqa faiqi namu sanda ufa qimannimiaqa.
\q1 
\v 6 Innee inneeqa faiqi namu qimannimifaqa misa inaaqiana kambiqainausa quandafi qimannimiaqa, kafaa misa miqi kai iqa nári ninaaqianna kambiqainausa quandafi qimannimifaqa, misa aiqamausa qini sanda ufa iriaqa.
\q1 
\v 7 Miqinnanannai nári irirana Anutunasaa kai mundifaranoo, misa Anutufa auquqoo ainainnara sia qaunuaqeera mina sanda ufa kai afaqaaqeera.
\q1 
\v 8 Miqidaqa sia nári nikausa naanna raaqeera.
\q1 Misa nikausa ufa rukiasee ramoo ramaa imarusa mariqau.
\q1 Sia misa nári irirana Anutunasaa mundiqau.
\q1 Misa sia Anutuna ufaki mapukusee mariqau.
\q1 
\v 9 Miqimarunara Eefaraimmana akeeku akaaku duru feefa mareeqa rakiranaki oonureeqa, fifau rufiasee oonurandee sandaqau.
\q1 
\v 10 Misa Anutuna moodaanaki kira ufamau sia andeeqasee fiqau.
\q1 Mina sanda ufara nikooqoofaqa minnisee kaqi runna fimariqau.
\q1 
\v 11 Anutufa auqoo ainaina qaunuseeqa, mifa naaquqara ainaina uqannifiqoonara faqa qaunusaqau.
\q1 
\v 12 Misa nikeeku nikaaku nikausa noorisaa faiqí sia amana auqaaqaa ira ainaina uqannifiqanau,
\q1 Isipa maqa maaqaki moo maqusa auqu Sooana mi maqusanaki maru afaasanasaa uqannifiqoonara faqa qaunusaqau.
\q1 
\v 13 Anutufa taatuqee ooruku nammari rakeemasee misa nifiqee aadanasaa finau.
\q1 Mifa nammari rakeemandoofanoo, dinni dinni aaqanara foora inau.
\q1 
\v 14 Faasaanasaa mifa asurukiqari misa nifiqee finau.
\q1 Eendaki ida fannoo kaaqa qamannimaqee marufaqa fiqau.
\q1 
\v 15 Misa nammari siaisaqa fimarufanoo Anutufa ooni afoommandeenoo nammari farumakinaanara foora moomoo nimufaqa naqau.
\q1 
\v 16 Anutufa oonikiqari nammariara ooqufuannee qufanoo nammari quminau, firaa nammari anoonara foora quminau.
\q1 
\v 17 Misa sia minara irirai kaqi kai aaqara oosana Anutuna afusaa maree mariqau.
\q1 Misa aadana maqa maaqaki fidaqa uriqarara Anutuna afusaa ititammasee nári iriranamau mandainainaki kaqi fimariqau.
\q1 
\v 18 Misa Anutuna amanamasee qafaanee qimasee nariqa nidimari naranara innaaru qimariqau.
\q1 
\v 19 Sia mina kai, misa Anutunara firaaqoo amanammasee qafaidee qimasee maaqi qiqau.
\q1 Amanee maa aadana maqa maaqanaki Anutufa narana qimiannoo fee.
\q1 
\v 20 Kuqaa Anutufa ooni arufanoo nammari firaafa quminau.
\q1 Mi nammarifa firaa nammariara foora quminau.
\q1 Kafaa amanee mifa narana faqa aandau faqa maasa narí maqannaasa qimiannoofee.
\q1 
\v 21 Yaaweefa misa ufa iriseenoo firaaqoo aanoo qinau.
\q1 Aanooqidanoo ida radiqisoofanoo Yakooboona faiqi namu narinau.
\q1 Mina aanooqirafa firaanaikinau.
\q1 
\v 22 Misa Anutunasaa sia nári irirana rusiqau.
\q1 Misa Anutunara sia amana mandainainakinaana maasa asumu maraannoo fee qiqau.
\q1 
\v 23 Mifa sia minara irinau kaqi qasuru qimamufanoo innaruna kooqi atuanau.
\q1 
\v 24 Atuaseenoo mannaa feemu innaarunaindaraa narana sakuma fooqaana aakuara foora teeqimasoofaqa naqau.
\q1 
\v 25 Mikari Anutufa angiroouqa neemaru naranna nimufaqa naqau.
\q1 Anutufa misa sia amana nama taikaaqaaira narana niminau.
\q1 
\v 26 Anutufa narí afeekannai qufanoo suani afu oosanaindari faqa dinni ataaqeendari faqa ufai uqinau.
\q1 
\v 27 Mifa ufiniuqa kookoommara foora misa teeqimma niminau.
\q1 Ooruku nammari afaiqaraa nukudara foora ufini misa niminau.
\q1 
\v 28 Anutufa qufanoo ufiniuqa misa uiqaana maqusa qambaana faqa naambeeqaqara faqa teeqi teequfaqa naqau.
\q1 
\v 29 Teeqi teeqimmasoofaqa marasee noofanoo moomoo uqanna kaqi marinau.
\q1 Misa faaqa rimarufanoo Anutufa moomoo uqanna nimufaqa misa namasoofanoo nimuaqu inau.
\q1 
\v 30-31 Mi ufini naranausa neemarufanoo sia nimuaqu inau, kaqi naida marufanoo Anutuna arana qoofanoo misa afeeka fasiqauqa kuqa narinau.
\q1 Mifa Isaraee maqannaa amiqira kumaaraauqa narinau.
\q1 
\v 32 Misa mi aiqama ainaina tianaki Anutuna afeeka qafamasee sia mina saqari kiqau,
\q2 kaqi aaqaranaki fimariqau. Misa Anutufa sia faiqí auqaaqaa ira naaquqara ainaina
\q2 auqoonara irisee sia misa irirana Anutunasaa rusimariqau.
\q1 
\v 33 Mina akiiqara misa maa maqanasaa marirana naidoora foora fuaqasoofaqa kai kaqi taikaqau.
\q1 Misa mandaikamma nimaqasoofaqa kuqirafa tautummasee misa qumaroofaqa kuqiqau.
\q1 
\v 34 Anutufa misa kuqa narufaqa kaqi marusa misa quandaki Anutufinnai ubeekaqau.
\q1 Mifa misa kuqa narufaqa kaqi marusa noori runusee mifunnai ubeekamafi innaaru qimariqau.
\q1 
\v 35 Anutufa misa kuqa narufaqa nári oonu mafi iriseeqa, kuqaa Anutufa maasa ititaqimaqee mari fee qiqau.
\q1 Uriqarara Anutufa maasa mandainainakinaana feefaurummasee dadaaqi marifammifoo qimariqau.
\q1 
\v 36 Misa sia nimuqusa ookiqarifau miqi qiqau.
\q1 Misa fifau nookiqari kai Anutuna amiqi amiqidaqa miqi qimariqau.
\q1 Misa nári nifaurunnai unnufa kai qimariqau.
\q1 
\v 37 Misa sia kuqaa uqanna Anutuna ufa afaqee marinau.
\q1 Misa sia Anutuna faqa moodaanaki kammaqoo ufanasaa mapukusee mariqau.
\q1 
\v 38 Anutufa misa manda oosana qafamaseenoo, mina amuqusirafa qumbiqanoo marunara misa manda oosana akiiqara minnisanau, sia narinau.
\q1 Moomoo kari narí aanooqirana rafaaqafuseenoo sia narí aanooqirana aiqama uqeeranau.
\q1 
\v 39 Mifa misara faiqí faiqi kai fee qimaseenoo irinau,
\q2 misara kaqikaa ufai fuaqaifaqa kai kaqi taikee mariasee qinau.
\q1 
\v 40 Misa aadana maqa maaqaki naqumma kari fee naakapara ufara nikooqoofaqa aanooqimariqau, moomoo kari miqimariqau.
\q1 Naqumma kari Anutuna amuqusa mandaikirana amimariqau fee. Moomoo kari miqimariqau.
\q1 
\v 41 Misa moomoo kari Anutuna amanammasee qafaqau.
\q1 Misa Isaraee maqannaa naaquqara andeeqara Anutuna amuqusa mandaikirana kaifaa kaifaa amimariqau.
\q1 
\v 42 Misa Anutuna afeekara qauniqau.
\q1 Mifa misa firaa ummaara ameemaanai mariuna kinaana maroonara faqa qauniqau.
\q1 
\v 43 Anutufa Isipa maqa maaqaki narí oosana uqannifiqoofaqa qafaqau.
\q1 Moo maqusa auqu Sooana mi maqusanaki maru afaasanasaa faqa narí oosana uqannifiqoofaqa qafaqau.
\q1 
\v 44 Anutufa qufanoo nammari uqanna fannoo quandaki fidikaikinau.
\q1 Miqimmafufaqa Isipa maqannaasa nammari naranara randoosia minnisaqau.
\q1 
\v 45 Mifa qufanoo faufaari oosana oosana kambiqafufaqa Isipa maqannaasa ukaqa nimidaqa aupurarana nimimariqau.
\q1 Mifa eeqamoosara qufaqa anireeqa misa maqa maaqa mandaikamma nimaqaqau.
\q1 
\v 46 Anutufa qufanoo pandaaqa moomoo aniree misa ainaina aiqama nama taikaqau.
\q1 Mifa qufanoo misa kadaapi rirafa aammaadi oo aamarai kaimbinau.
\q1 
\v 47 Anutufa qufanoo pupusamu aqufinoo misa waina sanda afuqakinaana ariisoofanoo aiqama aadana usu taikanau.
\q1 Firaa suara namu faqa pupusamu namu faqa aninoo misa saqari qaqama neemaruna faafisa fooqaa irana aiqama mandaikammasanau.
\q1 
\v 48 Mifa qufanoo misa burimakau aina pupusamu aqufinoo aiqama narinau.
\q1 Kafaa aakuasaa fannoo aiqama firimaru aandausa oosana oosana narinau.
\q1 
\v 49 Anutufa narí aanoo qirana faqa narí kaukaata qirana faqa narí aranaqaranara faqa faiqí nárí maru qangiroosa faqa idara foora niqiqoofaqa qumuree Isipa maqannaasa nariqau.
\q1 
\v 50 Mifa narí aanoo qirana sia rafaaqa finau.
\q1 Misa nimana kuqiranaki firarufanoo sia rafaaqa finau.
\q1 Mifa Isipa maqannaasa manda auriranaki quqasoofaqa kuqi mariqau.
\q1 
\v 51 Mi angiroofa Isipa maqannaa ooqa faiqiuqa aiqama naru raurukanau.
\q1 
\v 52 Anutufa narí maqannaa Isaraee maqanaasa sipsipara foora nifiqee finau.
\q1 Mifa sipsipara foora aadana maqa maaqaki misa andeeqasee indaarunnikamma nimaqanau.
\q1 
\v 53 Anutufa amiqimmasee rakisi nimaqee marufaqa sia narira ainainara rufiaqau.
\q1 Taatuqee nammari fannoo misa namuqaa aiqama dukuninau.
\q1 
\v 54 Anutufa misa nifiqamaree Kannaa maqa maaqai narí naaquqara maqa maaqai nifiqee oonuranau.
\q1 Narí afeekannai maroo aaqannasaa quqannisanau.
\q1 
\v 55 Mi maqa maaqanakinaa aanaamuru damunamma aquseeqa maqa maaqa oosuseeqa Isaraee maqannaa faiqí oosana faiqí oosana rainannimufaqa maqa maaqa marasee nariqa maqasaa ooqu mariqau.
\q1 
\v 56 Misa mi aiqama ainainna qafamaseeqa quandakiqa uriqarara Anutunara amanammasee qafaqau.
\q1 Misa sia mina naamuaqira ufa afaqaqau.
\q1 
\v 57 Misa quandaki nári ninaakusa naanna raida ufa rukiee mariqau.
\q1 Misa eendaandira feefaraa foora aqusoofanoo fuadakamaki kaqinni fimariqau.
\q1 
\v 58 Isaraee maqannaasa unnaqira anutusa tatufirana suqa nimidaqa minannai Anutuna uqanna arana fundakiqau.
\q1 Náriqa tumunnai auqira unna anutunannai mina arana qarana amiqau.
\q1 
\v 59 Anutufa misa oosana qafamasee misa aanoomma nimaqasee misa miniseenoo ameesa uqunnisanau.
\q1 
\v 60 Rakeemmeeqee aquseenoo Anutufa narí naaquqara uiqaana maaqa Siroo maqusaki maruna faqa minnisanau.
\q1 Narí maasa qambaana mariu maqana minnisanau.
\q1 
\v 61 Mifa narí qima afeekaikira bookisa narí afeeka maruna namuqaa nisaukuki quqasoofaqa maree fiqau.
\q1 Mifa narí bookisa narí afeeka areenarafa maruna mareeqeenoo namuqaa nisaukuki quqasoofaqa maree fiqau.
\q1 
\v 62 Mifa narí maqannasa Isaraee maqannaasa aanoomannimaqaseenoo misa namuqaara qufaqa akaqausa kuqa nariqau.
\q1 
\v 63 Misa kumaaraauqa rakiranaki kuqufufaqa maanaaqauqa marara fasiqa sia mariqau.
\q1 
\v 64 Misa amaana maqasaa aanaikirausa duru saamu ookina keeqafufaqa misa ninaaqmaaka rakirafa kaqi kai marufaqa náriara faqa rufiasee sia iki raqee mariqau.
\q1 
\v 65 Miqooqari Yaaweefa faiqaranakiara foora tautuma findifinau.
\q1 Mifa afeeka fasiqa wainna nammari namasee afeeka marasee findi fuandee inau.
\q1 
\v 66 Findifinoo narí namuqaauqa narunifaqaaqa masoofaqa fiqau.
\q1 Anutufa naru nifaqasoofaqa naaru marira nisaurirana marasee sia kafaa rakiqau.
\q1 
\v 67 Yaaweefa Yooseefaana narí amaaku Eefaraimmana faqa misa nikeeku nikaaku sia rusandeesamummasee maranau.
\q1 
\v 68 Yudana akeeku akaaku rusandeesamummasee maranau.
\q1 Anutufa misa maqa maaqaki maru aaqanna misa auqu faqaa aaqanna Sioona aaqana narí aidi maru aaqanna faqa maranau.
\q1 
\v 69 Miqoo Sioona aaqanasaa Yaaweefa narí innaarunai maru naaquqara amaana maqana fooqaairana usakanau.
\q1 Maa maqanara foora naaruara mapukusee marira maaqa usakanau.
\q1 
\v 70 Anutufa narí ainainira faiqi Dafidina rusandeesamummasee maranau.
\q1 Mifa sipsipasaa rakisi marunakinaana maranau.
\q1 
\v 71 Anutufa Dafidina sipsipasaa rakisi marunakinaana mareeqeenoo Isaraee maqannaasa karaambaiqaika masanau.
\q1 Anutu faiqí aanaaseesa sipsipara foora faqa rakisianifeera mara quqanau.
\q1 
\v 72 Miqooqari Dafidifa narí andeeqara iriranannai faqa narí akoofasaikiranannai Isaraee maqannaasa sipsipara foora indaarunnikamma nimaqanau.
\c 79
\s1 Anutufa Isaraee maqannaasa manda ainainakinaana dadaaqiani fee innaaru.
\q1 
\v 1 Oo Anutu, aamina maqannaa aniara sia iri mariasa maasa maqa maaqaki doo aniree maasa ani faiqí anaasee faqa rakidaqa.
\q1 Misa ani naaquqara amaana maqa putaammamaqeea. Yeerusaree maqusa rapeepaammaseea.
\q1 
\v 2 Misa ani aiku asauku aiqama narusee quqasoofaqa ufiniuqa aniree misa iri naqau.
\q1 Kaasau aandau faqa ani maqannaasa naru quqasoosa nipata naqau.
\q1 
\v 3 Misa fidika Yeerusaree maqusamau nammariara foora umbiqanau.
\q1 Misa nikundara fasiqa sia mariqau.
\q1 
\v 4 Maasa daaqa mariasa faqa maasa fiqu fiqumma mariasa faqa mina qafamasee maasara ataasataasa qimaseeqa naanaidara qidaqa.
\q1 
\v 5 Oo Yaawee, ani aanoo qirafa naaruaree mariannoo fee.
\q1 Ani rairai qirafa naaru naaru idara fooree qaannoo fee.
\q1 
\v 6 Oo Yaawee, aneenna aanoo qirana aamina maqannaasa, sia ani auqu amooqi mariasasaa teeqia.
\q1 Akaqa maqannaasa sia aniara innaaru qimariasa misasaa teeqiaqaana.
\q1 
\v 7 Misauqa maasa ani faiqí anaasee kuqa daridaqa.
\q1 Misa ani maqa maaqa furufaridaqa.
\q1 
\v 8 Oo Yaawee, sia maasa qikeeku qikaaku aaqarana akiiqara maasa aupurarana qimia.
\q1 Aneenna nifauara reendeeniranannoo kai kaqi maasa dadaaqia.
\q1 Maasa oonumafi irirafa oorudupinoo marinara maasa dadaaqia.
\q1 
\v 9 Oo Anutu maasa asumu maree marianafa anee aneenna auqu qareenaranara irisee maasa aaqarana akiiqara minniqisainaqa maasa ani amooqianaura.
\q1 
\v 10 Nanaree akaqa maqanaasa maasara yaifee inni Anutufa maridanoo fee qifoora.
\q1 Aneenna aiku asauku fidika akiiqara qimasee maasa qifusaa aupurarana niminaqa maasa qafaa.
\q1 Misa ani ainainira faiqiuqa naruana akiiqara miqia.
\q1 
\v 11 Oo Yaawee, maasa qiku qisauku namuqaa rumbaranaki mariasa faaqari mariana iria.
\q1 Namuqaa naruaneera ifana anee aneenna afeeka asaukunnai misa ititannimaqasee mara asumu mariranaki quqannisaa.
\q1 
\v 12 Oo Yaawee maasa daaqa mariasa ani manda ufa ami mariasa anee mina akiiqara dinni taikasee dinni ani qaaraqanda marasee kari misa nimia.
\q1 
\v 13 Anee miqimmasainaqa maasa ani faiqi namu, ani sipsipara foora aniara naaru naaru dufi dufi qianaura.
\q1 Naaru kambiqainausa faqa ani amooqirana amifaranoo.
\c 80
\s1 Isaraee maqannaasa kaifaa sooqbaandumma moodaaqoo uqara innaaru.
\q1 
\v 1 Oo Yaawee, anee Isaraee maqannaa sipsipasaa rakisirafara foora mariannanara maasa ufa iria.
\q1 Anee maasa sipsipara foora rakisi marianafa mariannanara maasa ufa iria.
\q1 Anee angiroouqa niqoosa faqaasa mariaqoo seerubimma mariaqoo miqoo anee Yaaweefa ooqu marifi marianafa mariannanara anee maasa ufa iria.
\q1 
\v 2 Eefaraimmana akeeku akaaku faqa Beensaminnana akeeku akaaku faqa Mannaseena akeeku akaaku faqa nifusaa koorooia.
\q1 Aneenna afeekannai findi finana mai aniree maasa ummaaraki marunnana uqeeraqisaa.
\q1 
\v 3 Oo Anutu, anee kafaa maasa uqeera quqaqisaa.
\q1 Anee maasara qimudaoo qinaqa maasa kaqi asumu marianaura.
\q1 
\v 4 Oo Yaawee, aiqama afeeka faqaa Anutufa, anee kisaaqasaa fee aneenna faiqí anaasee innaaru qiranara aanoo qinnaree.
\q1 
\v 5 Anee maasa naukunu kai naranara foora nimianaqa neeqa.
\q1 Anee naukunu qumbiqanoo mari difaanina qimianaqa nammariara maqi neeqa.
\q1 
\v 6 Anee qianaqa maasa daaqa mariasa faqa maasa maqasaara tinoo taanoo ridaqa.
\q1 Maasa namuqaa maasa qiqafeeqa ataasataasa qima qimaqaidanoo.
\q1 
\v 7 Oo Anutu anee kafaa maasa uqeera quqaqisaa.
\q1 Anee maasara qimudaoo qinaqa maasa kaqi asumu marianaura.
\q1 
\v 8 Oo Anutu, anee maasa Isaraee maqannaasa wainna sandara foora Isipa maqa maaqakinaana maasa asumuanara mamaree anireenana maaqoo aiqama maqannaasa futeeqa aqusee misa maqasaa ummaquqoonausa maridaqa.
\q1 
\v 9 Anee saikammasee miqoo ummaqusoona mariifanoo kambiqafinoo maa maqa maaqana amanaikinoo.
\q1 Mina atuka fannoo maqaki meemai uqanna keeqeenoo.
\q1 
\v 10 Mi sandafa firaanaikufanoo amuaqu namuqa faqa mina auqaanai mariqau.
\q1 Firaa sidaa saqariuqa faqa mi sandana auqaanai kai mariqau.
\q1 
\v 11 Mi sandana dinni asaana fannoo firaa ooruku nammari mediteereenia afainni ooqu finau.
\q1 Dinni asaana fannoo firaa nammari Eufarateesa nammari afainni amana kai finau.
\q1 
\v 12 Oo Anutu, anee nanaree mina ququsa rakeemmasaanaqee aatata fiqaree aiqaree inausa mina qaqama tiqinfaree.
\q1 
\v 13 Kaasau kuara fannoo nandakiqari aniree mi sandana nikunnai radamuseea.
\q1 Kaasau aandau faqa aniree mina naidaqa.
\q1 
\v 14 Oo aiqama afeeka faqaa Anutufa, anee maasa iannannai quandaa.
\q1 Innaarunaindari maasa qiqafaa. Ani wainna sanda marunausa qiqafamasee dadaaqia.
\q1 
\v 15 Anee qummaquqoonna afuqana qumuree qafaa.
\q1 Ani wainna sanda anooka aneennara ummaquqoonafa afeekaikinoo maridanoo, qumu qafamasee dadaaqia.
\q1 
\v 16 Maasa namuqaa maasa Isaraee maqannaasa ani wainna sanda asaanara foora mariafaqa ateekasee idara saafanoo doo qamafinoo.
\q1 Anutu anee aanoo qimasee misa kuridi nimaqaa.
\q1 
\v 17 Anee rusandeesamummasee maraqoonausa aneenna asaukunnai misa ititannimaqaa.
\s1 Isaraee maqannaasa anee afeeka nimisoonaqa namuqaa mandaikamma nimaqasoona anee kaifaa uqeerasee afeekaikamma nimaqaa.
\q1 
\v 18 Miqimmandaina sia maasa anikiqari quandaki kaqinni sandaanauranoo.
\q1 Anee marirana qiminaqa maasa kafaa findifi ani auqu ramasee ani amooqianaura.
\q1 
\v 19 Oo Yaawee aiqama afeeka faqaa Anutufa, anee kafaa maasa qifiqee aneenna iannannai ania.
\q1 Anee maasara qimudaoo qinaqa maasa sia kuqua kaqi asumu maria.
\c 81
\s1 Asasira qoomaqa sakasee nara idi.
\q1 
\v 1 Anutufa maasa dadaaqi marifa marinara faaqa rumasee asasida idi rama amaqaaqa.
\q1 Yakooboona Anutuna amooqira idi raaqa.
\q1 
\v 2 Idi oosana arasee, temberinna namu faqa piripuna namu faqa ufireena namu faqa marasee aridaqa asasira idi raaqa.
\q1 
\v 3 Fuka quqoona anirainaqa sipsipa aanainnoo ufireena fuaqaaqa.
\q1 Kafaa mi quqoonafa rufatee fatinaqa oomaqa sakasee naida ukeena fuaqaaqa.
\q1 
\v 4 Mi qoomaqa sakarafa Isaraee maqannaasa sanda ufara foora marinaqa aukuana aukuana naaru naaru miqifaranoo.
\q1 Yakooboona Anutufa maasa qimu sanda ufafa maridanoo.
\q1 
\v 5 Anutufa Isipa maqannaasa naruseenoo mi sandufana Isaraee maqannaasa niminau.
\q1 Qinee sia qafeemarunna fasiqana aunda irida.
\q1 
\v 6 Mifa maaqi qimasee qimanniminau.
\q1 Qinee inni Isaraee maqannaasa nikumaaqa firaa ummaara akunnimaqaqoona afaimeeqee quqeeqa.
\q1 Qinee inniara qunaqa inneeqa ummaara maqasaa afaimma quqaafanoo.
\q1 
\v 7 Innee manda aupuraranaki maridaqa qini Anutusa daaroofaqa qinee minakinaana inni mareeqee kaqinni quqannisa qiafana.
\q1 Qinee qeeqa kukeeqara maqusa oonnamukiqari inni dadaaiqiafana.
\q1 Innee Meeribaa nammari maruqoo marufaqa qinee inni nimanammasee qafaqiafana. (Meeribaa mi nammarina auqu oosana tinoo taanoo rira nammari fee qinau.)
\q1 
\v 8 Oo qini maqannaasa qinee inni aauqira ufa qimannimianaqa iriaqa.
\q1 Oo Isaraee maqannaasa innee qini aauqira ufa iriaqa.
\q1 
\v 9 Innee sia moo unna anutuna amooqiaqa.
\q1 Qini kai qimooqiaqa.
\q1 
\v 10 Qinee Yaaweesa inni Anutusa maridaqa.
\q1 Qinee inni Isipa maqa maaqaindaraana nifiqee aniafanausa maridaqa.
\q1 Innee minara iriseeqa qinee unnannai kai noo raqasaifaqa qinee kai inni narana nimianaura.
\q1 
\v 11 Qinee mi ufana amiqimasee qeeqa maqannaasa qimannimiafanaqa sia mi ufana iriqau.
\q1 Isaraee maqannaasa sia qini Anutusa ufamau fiqau.
\q1 
\v 12 Qinee misa mumuqira oosana qafamaseeqa misa rafuseeqee nári nidimaru mandoosanaki aqiqiafana.
\q1 Doo miqooqari misa nári nidimaru manda iriranamau fiqau.
\q1 
\v 13 Oo qini maqannaasa naqaa qini ufa iriaqaana.
\q1 Isaraee maqannaasa qini aatata fuaqaana.
\q1 
\v 14 Misa miqifaqau qinee kai kaqi misa namuqaa rafaaqafusani.
\q1 Misa qini ufa irifaqau misa namuqaauqa narini.
\q1 
\v 15 Isaraee maqannaasa qini ufa irifaqau qini Yaaweesara fidiaqaa imariasa qini doorinni firaaqoo rufiaidaqa niqoori saunu araaqini.
\q1 Miqoo misa narirafa naaruara mariqini.
\q1 
\v 16 Innee Isaraee maqannaasa qini Anutusa ufa amiqimmasee irifaqau qinee amiqira narana sakumma ainaina nimunaiqini.
\q1 Innee qini ufamau fifaqau qinee oonikinaana ookasaasa anoona adiafaa imarina nimunaiqini.
\c 82
\s1 Anutufa uriqarara rakisirafa.
\q1 
\v 1 Anutufa innaarunai suqiranaki uriqaranoo maridanoo misa ufa andeeqannimaqaidanoo.
\q1 Oosana oosana rakisirausa suqiranaki Anutufa narí irirana misa qimannimidanoo.
\q1 
\v 2 Innee Isaraee maqannaasa manda rakisirausa innee manda koota masaida sia amiqimmasee ufa rainee maria oosanna miqoo taikaaqa.
\q1 Innee sia manda oosana maree mariasa manda oosana auqaaqeera fadameena akuaqa, miqi mariana taikaaqa.
\q1 
\v 3 Innee sarau imariasa faqa fiaiqi faiqiuqa faqa ititannimaqaaqa.
\q1 Sarau imariasa faqa aupuraranaki mariasa faqa misa amiqimmasee mariaqeera dadaaqiaqa.
\q1 
\v 4 Manda oosana maree mariasa nisaukukina mariana mara kaqinni quqannisaaqa.
\q1 
\v 5 Maa maqanasaa maria siaasausa innee irirana siaisa eendaandirana oosana uqanna maraidaqa asukunakiara foora kai nimariafanoo.
\q1 Inni mi manda oosannara andeeqara oosana fannoo maa maqa maaqanaki taikanoo maridanoo.
\q1 
\v 6 Qinee Anutusa misara maaqi qidaqa.
\q1 Innee faiqí aanaaseesaa rakisira saika auqee mariasa Anutusara foora maqasaa uriaraqa maridaqa faiqí anaaseesaa rakisi mariafanoo.
\q1 Innee aiqamausa qini uriqarara Anutusa faiqi namu mariafanoo.
\q1 
\v 7 Innee faiqí faiqi naannaree kaqi kuqifaranoo.
\q1 Inni marirafa maqasaa karaambaiqauqa faiqi namu kuquafanoo misa marirafa taikaindee inoo inni marirafa taikaannoo.
\q1 
\v 8 Oo Anutu, aiqama maqannaasa ani faiqí anaasee marianara anee aniree misasaa rakisi nimaqaa.
\c 83
\s1 Anutufa Isaraee maqannaasa namuqaauqa rafaaqafu nimaqaani fee innaaru.
\q1 
\v 1 Oo Anutu, sia ufa siaina kasoo ina maria.
\q1 Sia anee kaqi muqurina maria.
\q1 
\v 2 Qafaa ani namuqaa rakirana uqeeraidaqa.
\q1 Aniara fidiaqaa imariasa ninuka uqeerasee ani ramoo ramaamma amaqaidaqa.
\q1 
\v 3 Misa umee tipundaarammasee ani faiqí anaasee nariraridaqa.
\q1 Anee itita nimaqee marianausa narirara tipundaaridammia.
\q1 
\v 4 Misa maaqi qidaqa.
\q1 Anifaqa Isaraee maqannaasa naru raurukamasaanaqa sia mariaqa.
\q1 Sia moo fannoo misara kaqikaaqoo iriaqeera doo naaruara misara qaunu saaqa.
\q1 
\v 5 Misa tipundaarammasee moodaa iriranasaa maridaqa.
\q1 Misa ani Anutuna futeeqa aqiraree qimasee moodaanaki kidaqa.
\q1 
\v 6-7 Maaqimmasee maqannaasa suqu fifaqa namuqaakidaqa.
\q1 Eedooma maqannaasa faqa Isamaeera maqannaasa faqa Mooaba maqannaasa faqa Hakari maqannaasa faqa Keebara maqannaasa faqa Amoonna maqannaasa faqa Amareeka maqannaasa faqa Firistia maqannaasa faqa Tiree maqa maaqaki mariasa faqa moodaanaki kammafifaqa misa Isaraee maqannaasa futeeqararee qidaqa.
\q1 
\v 8 Asiria maqannaasa Amoonna maqannaa faqa Moaba maqannaasa ooqeenaa niqoolndi mariusa aniree misaki ookaammafiqa Rootana aiku asauku dadaaqiqa Isaraee maqannaa namuqaa kamma nimaqaqau.
\q1 
\v 9 Oo Anutu, anee Midianna maqannaasa faqa Siseera maqannaasa faqa Yabina maqannaasa faqa Kisoona nammari afainni narunnandee maseenana misa aiqama naru taikaa.
\q1 
\v 10 Misa Eendoora maqa maaqaki fufana anee Isaraee maqannaasara qunaqa nifaqasee narusee sia nikundaqau.
\q1 Doo kaqi miqoo quqasoofaqa putaa iqa madaapee kammafiqau.
\q1 Oo Anutu, maqee maasa darirari mariasa miqi kai mandee narua.
\q1 
\v 11 Midianna maqannaasa Isaraee maqannaa narirarufanoo Gideeoonafa misa naru nifaqasee misa karaambaiqaqara Ooreebana faqa Seepana faqa miqanda narundee kai inana maqee maasa darirari mariasa Anutu anee narua.
\q1 Mi maqannaasa uriqarara karaambaiqaqara Seepana faqa Saramuna faqa narundee kai masee maasa darirari mariasa narua.
\q1 
\v 12 Misa maaqi qimasee manda ufa qiqau.
\q1 Maasa Anutuna aiku asauku Isaraee maqannaasa maqa maaqa qeeqara maraanauree qimasee oonuroofana anee misa uriqararausa narutaikanau.
\q1 
\v 13 Oo maasa Anutu, maasa darirara imariasa kookoommara foora fuaqa aqusainaqa nianai fuaqa. Ufai fannoo andanda fuaqa aqindee masaa.
\q1 
\v 14 Ida fannoo nanda qaindee inana maasa darirari mariasa nifaqasaina sandaaqa.
\q1 Usau aaqana qumbiaramasaafanoo akara qaindee inana maasa namuqaa nifaqasainaqa sandaaqa.
\q1 
\v 15 Oo Anutu, anee aakuasaa faqa innaarunai darara qirana namu faqa nifaqasaina sandaaqa.
\q1 Firaa ufai uqiranannai rufiarana niminaqa rufiasee sandamafuaqa.
\q1 
\v 16 Oo Yaawee, anee nisaurirana firaana naaku nimaqainaqa mina qafamasee quandaki ani afeekara anoonee qiaqa.
\q1 
\v 17 Maqee maasa darirari mariasa naaru naaru rafaaqafu nimaqasee rufiarana misa nimia.
\q1 Misa firaa nisauriranaki maridaqa kuquaqa.
\q1 
\v 18 Oo Yaawee anee miqinaqa maasa darirari mariasa anee kai Yaaweefa mariannanara iriaqa.
\q1 Aniara maa maqa maaqana firaa uriqarara rakisirafa maridanoomifoo qiaqa.
\c 84
\s1 Anutuna maaqara indee indee ira innaaru.
\q1 
\v 1 Oo aiqama afeeka faqaa Yaaweefa, ani amaana maqara kaaqa dididanoo.
\q1 
\v 2 Qinee ani Yaaweena amaana maqaki marirara dididanoo.
\q1 Qinee Yaaweena amaana maqaki marirara indee indee idaqa.
\q1 Qini qimuqusa faqa qifaaqa faqa ani kaqi marira Anutunara asasira idi raidaqa.
\q1 
\v 3 Oo aiqama afeeka faqaa Yaaweefa qini karaambaiqa qini Anutufa ufini moo fannoo saanoona fooqaafa ani Anutuna amaana maqaki keeqafinoo ani aandau tatufira qainda aaqa aanaamu usakaseenoo anaaqi maqaidanoo.
\q1 
\v 4 Oo Yaawee ani amaana maqaki mariasa firaaqoo asasidaqa aiqama kari ani amooqima amaqaidaqa.
\q1 
\v 5 Oo Anutu, anikinaa afeeka maree maria fasiqa anaseesa asasiranaki maridaqa.
\q1 Ani amooqirara Sioonna aaqanai ooru firara nidi marisa misa asasiranaki maridaqa.
\q1 
\v 6 Yeerusaree maqusai ooru firaree qimasee afeeka aatata aadana aatata Bakaa noopundu runna ooru fufanoo mi maqa maaqafa moomoo nammari maqakiqari ururee marufaika mafinau.
\q1 Aaku dunoonna ufanoo madikaki nammari mandi marinau.
\q1 
\v 7 Miqimmasee fimariasa afeekaika mafiqa Sioonna maqusa moo auqu Yeerusaree maqusai Anutufa aiqama unnaqira anutusa uriqararafa marina qafeefaranoo.
\q1 
\v 8 Oo Yaawee Anutufa, aiqama afeeka faqaa Anutufa, qini innaaru qirana iria.
\q1 Oo Yakooboona Anutu anee aaqoo quqasee iria.
\q1 
\v 9 Oo Anutu, anee maasa Isaraee maqannaasa karaambaiqa maasa rakiranaki saqariara foora ititaqimaqee mari fasiqana amiqi amiqimma amaqaa.
\q1 Anee mina rusandeesamummasee maraqoonafa maridanoo.
\q1 
\v 10 Moodaa faasaana ani amaana maqaki marirafa uriqararafa maridanoo.
\q1 Wan tauseena faasaana kaqinni marirafa oorudupirafa maridanoo.
\q1 Qinee qeeqa Anutuna amaana maqa kooqiki keeqarara dididanoo.
\q1 Manda oosana maree mariasa maaqaki mariranara qikooqaidanoo.
\q1 
\v 11 Yaaweefa qareenara karaambaiqa maasa itita qimaqee marifa maridanoo.
\q1 Mifa narí amiqira dadaaqirana faqa maasa duqu uqeerarana faqa mi qandannai amiqimma qimaqaidanoo.
\q1 Andeeqara aatata fimariasa moo ainainara iraifanoo sia amiqira ainaina nimiranara qaoo qiannoo.
\q1 
\v 12 Oo aiqama afeeka faqaa Yaaweefa ani saqariki mariasa firaa asasiranaki maridaqa.
\c 85
\s1 Narí maqannaasa rakisinnimaqaani fee innaaru.
\q1 
\v 1 Oo Yaawee, ani maqa maaqara ani amuda qanau.
\q1 Anee Isaraee maqannaasa kafaa reemindeemirimma nisanau.
\q1 
\v 2 Anee aneenna maqannaasa mandoosana akiiqara minninnisanau.
\q1 Misa aaqarana akiiqara aiqama rukannisanau.
\q1 
\v 3 Anee ooqai aanoo qiqiunnana faqa aneenna qarana qarana idara foora qeeqeeuna faqa maqee minnisaananoo.
\q1 
\v 4 Oo maasa asumu marirana qimi marianna Anutufa, anee kaifaa maasa sooqbaandumeeqee quqaqiseenana aneenna oori runirana maasasaa marina taikaa.
\q1 
\v 5 Anee naaru naaru maasara aanoo qinnaree.
\q1 Ani aanoo qirafa sia fee dauni taikaannoo fee.
\q1 
\v 6 Anee maasa kafaa afeekaikamma qimaqasainaqa maasa ani maqannaasa ani amooqianaura.
\q1 
\v 7 Oo Yaawee, aneenna maasara naaru naaru aidirana uqaqifiqaseenana aneenna dadaaqirana qiminaqa asumu marirana maraa.
\q1 
\v 8 Qinee Yaaweena Anutuna ufa iridaqa.
\q1 Mifa maasa narí aiku asaukuara sia inneeqa ooqeennaa furufarira aatata kafaa fifaqa qinee qeeqa asooarana inni nimianauree qidanoo.
\q1 
\v 9 Yaaweefa nariara naaquqaifaqa qeerairi mariasa kuqaa asumu mararara deedaqinoo maridanoo.
\q1 Miqinoo marifanoo mina dadaaqira marirafa maasa maqa maaqaki aiqama atinai mariannoo.
\q1 
\v 10 Miqimmafinanoo Anutufa maasara aidirafa faqa maqasaa qaraa fasiiqa mapukusee marira oosana faqa moodaanaki kifaranoo.
\q1 Yaaweena andeeqara oosana faqa maqasaaqaraasa asooarafa faqa narí difaa difaa narí difaa difaa ifaranoo.
\q1 
\v 11 Maqasaaqaraasa Anutuna ufasaa nifu mundusee firafa innaarunai ubeekaifanoo innaarunaindari Anutuna andeeqarafa qumuree misa dadaaqiannoo.
\q1 
\v 12 Miqimmafinanoo Yaaweefa maasa amiqi amiqimmanimaqaannoo.
\q1 Maasa maqa maaqaki nara ainaina rairaa inoo reemindeemiriannoo.
\q1 
\v 13 Andeeqara oosana fannoo faiqí moora foora Yaaweena afunni fidanoo mifa fuaninna aana afisidanoo.
\c 86
\s1 Dadaaqiani fee innaaru.
\q1 
\v 1 Oo Yaawee, qinee afeeka siaisa, dadaaqirana siaisa marunnanara anee qini innaaru qirana irisee dadaaqinnanara anoona ufa qimaqimia.
\q1 
\v 2 Qinee qifu mundusee ani ufamau kai fimarunausa marunnanara kuqiranakinaana mara kaqinni quqaqisaa.
\q1 Qinee ani ainainira faiqi ani saqariki marunnanara qini asumu mara quqaqisaa.
\q1 
\v 3 Anee qini Anutufa mariananoo, anee qini qifauama qimaqaa.
\q1 Qinee faasaambaasaana aniara innaaru qimamaqaidaqa.
\q1 
\v 4 Qini innaaru qirafa anee iannannai kai oorufi marinara oo Yaawee, aneenna ainainira faiqi qini asasirana qimia.
\q1 
\v 5 Oo Yaawee, anee maasa amiqimma qisaseenana maasa numoo minni qisee mariananoo.
\q1 Aniara innaaru qimariasara ani misara amuqusirafa firaafa maridanoo.
\q1 
\v 6 Oo Yaawee, qini innaaru qirana iria.
\q1 Dadaaqianeera nammeera qimarunnana irisee dadaaqia.
\q1 
\v 7 Anee qini innaaru iri mariannanara qinee ummaaraki maridaqa ani aaraidaqa.
\q1 
\v 8 Anaamuruki unna anutusa moomoosa maridaqa sia moo fannoo misa qambaanai ani fooqaafa uriqararafa maridanoo.
\q1 Sia moo unnaqira anutufa anee auqoonna ainainausa auqaannoo.
\q1 
\v 9 Oo Yaawee, aiqama maqannaasa anee auqu quqoonna maqannaasa, aiqamausa aniree ani afusaa niqoori saunu arafi ani amooqifaranoo.
\q1 Misa ani auqu qareenarana amooqifaranoo.
\q1 
\v 10 Anee kai firaa afeeka faqaafa mariananoo naaquqara ainaina auqee marianafa mariananoo.
\q1 Aneennaraa kai Anutufa mariananoo.
\q1 
\v 11 Oo Yawee, anee qiniara auqaannee qimarianna ainainna qima qimia. Miqimma sainaqa qinee ani ufamau mapukusee fua.
\q1 Qini daamua qinaqa kaaqa andeeqasee ani ainainiranaki maria.
\q1 
\v 12 Oo Yaawee, qini Anutufa, qinee qeeqa qimuqusa aiqamannai ani amooqianaura.
\q1 Qinee naaru naaru ani auqu qareenarana amianaura.
\q1 
\v 13 Anee qiniara amuqusirafa firaafa maridanoo.
\q1 Anee qini maqa ameemaanai faiqí madikakinaanara foora marunnana mareeqee kaqi mariranaki quqaqisaananoo.
\q1 
\v 14 Oo Anutu, ramooramaa imariasa qini dariraridaqa.
\q1 Kaaqa fidika ruqiee mariasa suqufifaqa qini kuqa darirara randaidaqa.
\q1 Miqi mariasa sia ani Anutunara iridaqa.
\q1 
\v 15 Oo Yaawee, anee kaaqa amuqusi marianna Anutufa faqa kaaqa afaari marianafa faqa mariananoo.
\q1 Anee sia dauni aanoo qimarianafa mariananoo. Ani maasara amuqusirafa faqa aniki mapukusee marirafa faqa fiqaranoo maridanoo.
\q1 
\v 16 Oo Anutu, qinee unannai quandafi qifauarana qimia.
\q1 Qini qinoofa iundee kai iqa qinee faqa ani ainainira faiqi marunnanara aneenna afeeka faqa asumu marirana faqa qimia.
\q1 
\v 17 Oo Yaawee, anee qini amiqi amiqimma qimaqee mariannanara moo ainaina auqainnanannai uqaqifiqainaqa qafaa.
\q1 Anee qini amiqi amiqirana faqa dadaaqirana faqa qiminaqa qiniara fidiaqaa imariasa nisaurifaranoo.
\c 87
\s1 Yeerusaree maqusa amooqiqau.
\q1 
\v 1 Sioona aaqanasaa naaquqarana saa Yaaweefa narí maqusa auqusee maridanoo.
\q1 
\v 2 Yaaweena Yeerusaree maqusara aidirafa aiqama Isaraee maqa maaqakinaa maqusauqara aidirna uriaaqaranoo maridanoo.
\q1 
\v 3 Oo Anutuna maqusa iria, mifa aniara amiqira ufa kai qidanoo.
\q1 
\v 4 Qinni ufa irimariasa nisaanariqa Firistia maqannaasa faqa Tiree maqannaasa faqa Eetioopia maqannaasa faqa mara Yeerusaree maqannaasa namufaqa moodaanaki quqasee nisaana ruanaura.
\q1 
\v 5 Sioona maqusara maaqi qifaranoo.
\q1 Aiqama maqannaasara mi maqusaanaasee qifaranoo.
\q1 Miqi qifanoo uriqarara afeeka faqaafa mi maqusana afeekaikamma saannoo.
\q1 
\v 6 Anutufa aiqama fasiqa anaasee nuqu narí papiqaki akara ruannoo.
\q1 Misakiqari akaqausara narí ufa irimariasa Sioona maqusanaasa namufaqa nisaana ruannoo.
\q1 
\v 7 Sioona maqusaki maria fasiqa anaaseesa maaqi qimasee idi reefaranoo.
\q1 Maasa aiqama amiqi amiqirana oosana Sioona maqusa maridanoo.
\c 88
\s1 Isaraee maqannaasa Anutufa dadaaqianifeera innaaru qiqau.
\q1 
\v 1 Oo Yaawee, anee qini asumu maree marianna Anutufa mariananoo.
\q1 Faasaana anee dadaaqianneera innaaru qidaqa iki raqaidaqa. Eendaki faqa aniara innaaru qidaqa.
\q1 
\v 2 Qini innaaru qirana iria.
\q1 Dadaaqianneera innaaru qimarunnana iria.
\q1 
\v 3 Qini oosana oosana ummaara darimarifaqa qusasaa kuquanaura.
\q1 
\v 4 Qinee kuqirari mariasa naanna raidaqa.
\q1 Qini afeeka aiqama taika finoo.
\q1 
\v 5 Qini kuqirausa namu faqa rarisameeqee quqaqaafaqa maridaqa.
\q1 Qinee faiqí kuqa naruqaasara foora madikaki maridaqa.
\q1 Anee faiqí kuqufuasara sia iridana sia dadaaqi mariananoo.
\q1 Qinee misara foora maridaqa.
\q1 Ani rakisi qimaqaranakiqari nianai maridaqa.
\q1 
\v 6 Oo Anutu, anee qini mareeqeenana meemaqoo maqa ameemaanai madikakiara foora aqu qisaananoo.
\q1 Asukunaki meemai uqanna aqu qisaananoo.
\q1 
\v 7 Ani aanooqirafa firaaqoo qini radandamu masaananoo, ooruku nammari amakau rinoora foora qini rafaaqafinoo.
\q1 
\v 8 Anutu anee qini daaqa qiqoondiuqara qianaqa qini minniqiseea.
\q1 Anee qini mandaika uqanna maqisa saanaqa qini qiqoondiuqa qiniara rufieea.
\q1 Qinee rumbaranakiara foora maridaqa sia amana idukuaki sandaanaura.
\q1 
\v 9 Aupuraidaqa qiki raqee marunanoo qifu mandaikidanoo.
\q1 Oo Yaawee, aiqama kari qinee qisauku anee iannannai uqeerasee dadaaqianeera innaaru qidaqa.
\q1 
\v 10 Oo Anutu, aneenna naaquqara ainaina naqimmasee kuqirausa uqannifiqeennaree.
\q1 Kuqirausa amanee findifi ani amooqifaree. Sia miqifaranoo.
\q1 
\v 11 Madikaki mariasa ani naaru marira amuqusiranara ufa qida fee. Sia ufa qidaqa.
\q1 Maaniki mariasa ani mapukusee marira oosanara ufa qidee. Sia ufa qidaqa.
\q1 
\v 12 Ani naaquqara ainaina asukunaki mariasa qafaidee. Sia qafaidaqa.
\q1 Kuqiranaki finausa ani andeeqarana qafeefaree. Sia qafeefaranoo.
\q1 Minara anee qini titaqisainaqa sia kuqua.
\q1 
\v 13 Oo Yaawee, anee qini dadaaqianneera aaraidaqa.
\q1 Aiqama kananaana qinee aniara innaaru qidaqa.
\q1 
\v 14 Oo Yaawee nanaree anee qini minni qisaidanee.
\q1 Nanaree aneenna oori afiri qini qiqafaanoo qimasee kukeeqaidanee.
\q1 
\v 15 Qinee kumaaraasaaqari manda ummaara darinoo aniifanoo maqee doo kuqirana afaisaa minisaifaqa maridaqa.
\q1 Anee moomoo aupurarana qimiananoo mifa qini qimudaani ummooquka maseenoo.
\q1 
\v 16 Ani firaa aanooqirafa doo qini rafaaqafinoo.
\q1 Ani manda darirafa qini mandaikamma qimaqeenoo.
\q1 
\v 17 Anee miqi mariana aiqama faasambaasaana manda fasiqauqa qini fiqu fiqu tookusiqa maridaqa nammari mandinoo maridanoora foora iqa maridaqa.
\q1 Mi ummaarausa firaa nammari amakauriara foora inoo firaaqoo qini rafaaqafu qimaqeenoo.
\q1 
\v 18 Qini qifaaqasaa qiqoondiuqara anee qianaqa qini minniqisaafanoo asukuna fannoo kai qini daaqa qaraa qikaqaafasaara foora maridanoo.
\c 89
\s1 Aiqama maqa maaqaki ummaara kambiqaifaqa ree maria idifa.
\q1 
\v 1 Yaaweena naaru naaru maasara firaa amuqusiranara qinee faqa naaru naaru idi raanaura.
\q1 Qinee ani mapukusee marira oosanara naaru naaru kooroommasee qimannimianaura.
\q1 
\v 2 Qinee aniara maaqi qimasee iridaqa.
\q1 Ani maasara amuqusirafa naaru naaru afeekaikinoo mariannoo.
\q1 Ani mapukusee marira oosana fannoo innaarunara foora atukaranoo marinara qimannimianauranoo.
\q1 
\v 3 Anee Anutufa maaqi qinau qinee qeeqa moodaanaki kira ufa qinee rusandeesamu masee maraafanna fasiqanasaa Dafidinasaa quqeefee qinau.
\q1 Qinee qeeqa ainainira faiqi Dafidinara qima afeekaikiqa.
\q1 
\v 4 Mifa maaqi qinau. Qinee anisaaqari rakisira saika oosana arasaanaqa naaru naaru ani aiku asauku kambiqainausa miqikai iqa fifaranoo.
\q1 Naaru naaru ani aiku asauku kai rakisirausaikamma nimaqaanaura.
\q1 
\v 5 Oo Yaawee, innaarunai maria angiroosa ani amiqira ainainiranara idi raidaqa amooqidaqa.
\q1 Innaarunai naaquqarausa mariasa faqa ani mapukusee marira oosanara idi raidaqa amooqidaqa.
\q1 
\v 6 Sia moo fannoo innaarunai marifa ani Yaaweena fooqaafa maridanoo.
\q1 Sia innaarunai mari ainainausakiqari moo ainaina fannoo ani fooqaafa maridanoo.
\q1 
\v 7 Innaarunai suqiranaki mariasa aniara firaaqoo rufiaidaqa.
\q1 Mina fiqu fiqumma mariasa firaaqoo minara naaquqaifaqa rufiaidaqa.
\q1 
\v 8 Oo Yaawee, aiqama afeeka faqaa Anutufa mariananoo.
\q1 Sia moo fannoo ani afeeka fooqaafa maridanoo.
\q1 Oo Yaawee anee aiqama ainainaki afu munduqaannaqoo kai fimarianafa mariananoo.
\q1 
\v 9 Oo Anutu, anee ooruku nammari aanooqira amakaurirana rakisi marianafa mariananoo.
\q1 Ooruku nammari firaaqoo aanoo qinoo amakaurifana anee Yaaweefa rafaaqafi marianafa mariananoo.
\q1 
\v 10 Anee ooruku nammariki mari firaa naaquqara aandauna radamunafa mariananoo.
\q1 Anee aneenna afeeka asaukunnai aneenna namuqaa furufara mandaana rakee mafiqa moodaa moodaa mafia.
\q1 
\v 11 Innaaruna anindi maridanoo.
\q1 Maa maqa maaqafa faqa anindi kai maridanoo.
\q1 Maa maqa maaqafa faqa minaki mari ainainausa faqa anee kai quqaqoonafa maridanoo.
\q1 
\v 12 Anee Yaaweefa suani afu dinni dinni ataaqeenni auqu quqaqoonafa maridanoo.
\q1 Qeeramoonna aaqana faqa Taboora aaqana faqa faiqiara foora ani Yaaweena auqu irisee asasira idi raidaqa.
\q1 
\v 13 Oo Anutu, anee firaa afeeka faqaafa marianafa mariananoo.
\q1 Anee uriqarara afeeka faqaafa mariananoo.
\q1 
\v 14 Ani rakisinnimaqarafa andeeqaranasaa faqa amana amana kai raina nimaqaranasaa faqa mundinoo maridanoo.
\q1 Faiqí aanaaseera nimuqusirafa faqa mapukusee marira oosana faqa anee Anutufa auqaanna aiqama ainainnaki maridanoo.
\q1 
\v 15 Faiqí anaasee ani Yaaweenara idi raranannai ani amooqimariasa misa firaaqoo asasiranaki maridaqa.
\q1 Oo Yaawee misa ani afusaa ani eedoo qiramau fimariasa misa asasiranaki maridaqa.
\q1 
\v 16 Misa faasaambaasaana ani auquara asasidaqa.
\q1 Misa ani andeeqaranara irisee firaaqoo nasuridaqa.
\q1 
\v 17 Anee kai maasa afeeka qimianaqa maasa firaaqoo aniara asasidaqa.
\q1 Anee aneenna aidiranannai maasa firaa afeeka nimianaqa maasa qeeqa namuqaa urinnaaqareeqa.
\q1 
\v 18 Oo Yaawee, anee maasa ititaqimaqaaninna fasiqana rusandeesamummasee mara qiminau.
\q1 Anee Isaraee maqannaasa naaquqara andeeqara Anutufa maasa maqasaa karaambaiqa qimunafa mariananoo.
\q1 
\v 19 Oo Yaawee ooqai anee qainasaa aniki mapukusee maru ainainira faiqisa maaqi qimasee qimanniminau.
\q1 Qinee moo amudaanai qimari rakira fasiqana dadaaqirana amiqa.
\q1 Qinee mi kumaaraana faiqí anaasee qambaanaindaraana rusandeesamummasee marasee Isaraee maqannaasa rakisira afeeka amiqa.
\q1 
\v 20 Qinee qeeqa ainainira faiqi Dafidina naaquqara fadameenannai akiiqa amoondunnai adiaunnanannai uriqararanaikamma amaqeeqa.
\q1 
\v 21 Qini Yaaweesa afeeka fannoo aiqama kari mina faqa mariannoo.
\q1 Qini afeeka fannoo mina afeekaikamma amaqaannoo.
\q1 
\v 22 Mina namuqaauqa sia uqanna rakiranaki mina rafaaqafu amaqeefaranoo.
\q1 Manda oosana maree mariasa faqa sia amana mina ooru muqufi seefaranoo.
\q1 
\v 23 Qinee Yaaweesa mina namuqaa radamusaanaura.
\q1 Minara fidiaqaa imariasa qinee kuqa kai narusaanaura.
\q1 
\v 24 Qinee minara didimarinaqa mina faqa naaruara marianaura.
\q1 Rakiranaki qinee mina dadaaqiananoo uriqaraanoo.
\q1 
\v 25 Mina maqa maaqa dinni oosu Mediteranea ooruku nammari mariannoo, dinni oosu Eufarateesa firaa nammari mariannoo.
\q1 
\v 26 Mifa maaqi qimasee qini Yaaweesa qimaqimiannoo.
\q1 Anee qini qikoofa mariananoo.
\q1 Qini Anutufa mariananoo, anee qini asumu qimi marianafa, qini ititee marianna ooni faandaamura fara foora mariananoo.
\q1 
\v 27 Qinee mi fasiqana Dafidina utaaqama saananoo qini ooqa faiqiara foora mariannoo.
\q1 Aiqama maa maqa maaqanakinaa karaambaiqauqa uriqarara karaambaiqa mariannoo.
\q1 
\v 28 Qinee qeeqa qima afeekaikira ufa mi fasiqana Dafidinasaa quqasaananoo naaru naaru mariannoo.
\q1 Qini moodaanaki kira ufa mina faqa naaruara mariannoo.
\q1 
\v 29 Innee Dafidinasaa aruaki oonu marinausa naaruara karaambaiqaiki faranoo.
\q1 Misa innaarunara foora naaruara maridaqa Isaraee maqannaasa rakisi nimaqeefaranoo.
\q1 
\v 30-31 Dafidina faiqi namu qini sanda ufa minnisee qini irirana mau sia fiqa misa qini naakapara ufa rukiasee, sia qumaraifaqa aupurarana nimianaura.
\q1 
\v 32 Qinee misa aaqarana akiiqara aupurarana nimianaura.
\q1 Qinee qianaqa misa nári aaqarana akiiqara nidafirana mareefaranoo.
\q1 
\v 33 Qinee misa aaqarana akiiqara ummaara nimiqa sia qini Dafidinara qimuqusirana taikaanaura, kaqi mariannoo.
\q1 Qinee qeeqa qima afeekaikirana sia minnisaanaura kaqi kai mariannoo.
\q1 
\v 34 Qinee moodaanaki kira ufa mina faqa qiafannana sia aikatamasee kaqinni fuanaura.
\q1 Qeeqa dookiqari qiafanna ufana sia moo mafi quqaanaura, miqoo kai marianaura.
\q1 
\v 35 Qinee moodaa kari qeeqa naaquqara andeeqara oosanara iriseeqa qinee minara kuqaa fee qimasee maaqi qiqa, sia unnufa Dafidina qimamianauree qiqa.
\q1 
\v 36 Miqianaqa Dafidinasaa aru akinausa naaruara marifara.
\q1 Qinee misasaa naaruara suaniara foora qaida rakisi nimaqaanaura.
\q1 
\v 37 Quqoona fannoo miqoo naaru naaru maridanoo, qinee auquafanna ainainara kooroo imarindee inoo qinee Dafidinara qima afeekaikiafanna ufafa miqinoo mariannoo.
\q1 
\v 38 Oo Yaawee, anee miqi qimasee qima afeekaikammaseenana kafaa aneenna rusandeesamummasee maraqoonna fasiqausa qini Dafidisara arana qaifana minni qisaananoo.
\q1 Anee qini firaaqoo ameesuqu qimaqaananoo.
\q1 
\v 39 Anee aneenna ainainira faiqi qini faqa moodaanaki kira ufa qimaqoonnana rukiaananoo.
\q1 Anee qini uriqarara qafee qimunnana qumareeqee kookoomaki aqusaananoo ikairi reenoo.
\q1 
\v 40 Anee qini faandaamura aiqama rakeekaa iananoo.
\q1 Anee qini afeeka maaqauqa rapeemma saananoo naakundu kammafinoo.
\q1 
\v 41 Akaqausa qinee marunnaqoo aiqaree fidaqa qini ainaina ummuaramamaree fidaqa.
\q1 Qini qiqoonausa minara uteeti qidaqa.
\q1 
\v 42 Yaawee, anee qini namuqaa dadaaqianaqa misa rakiranaki uriqareea.
\q1 Anee namuqaa dadaaqianaqa misa asasidaqa.
\q1 
\v 43 Anee qini duru saamu nammari arasaananoo.
\q1 Anee qianaqa rakiranaki misa qini rafaaqa fia.
\q1 
\v 44 Anee qini karaambaiqa duqu marina mara maraananoo.
\q1 Miqimmaseenana anee qini ufa irimarunna qaarina maqasaa aquseenana utitiqaananoo.
\q1 
\v 45 Anee qini kumaaraa marirana ateeka qusaramasaanaqa dauni asooqaikunana qisaurirana qamunnara foora dukunimma qimaqaananoo.
\q1 
\v 46 Oo Yaawee, kisaaqasaa fee kukeeqana marinnaree.
\q1 Ani aanooqirafa kisaaqasaa fee idarafoora qaida mariannoo fee.
\q1 
\v 47 Qini marirafa qusaranoo maridanoo anee minara iria.
\q1 Anee maasa aiqama kuquanausa auquqisaannanara iria.
\q1 
\v 48 Yafasiqa fee sia kuquannoo fee.
\q1 Yafasiqa fee kaqi maridanoo narí afeekannai narí madikaki firanara qeerairiannoo fee.
\q1 Sia moo fannoo miqirafa mariannoo.
\q1 
\v 49 Oo Yaawee, yaafee anee ooqai qiniara aidimariannana kooroo imari ainainafa maridanoo fee.
\q1 Anee Dafidinara qima afeekaikammaqoonafa yaifee maridanoo fee.
\q1 
\v 50 Oo Yaawee, ani ainainira faiqi ataasa ataasa qimamaqee marianara anee sia qaunua.
\q1 Aiqama maqannaasa manda aasaandaana ufa qimimariafaqa marunnanara, anee minara faqa sia qaunua.
\q1 
\v 51 Oo Yaawee anee rusandeesamummasee maraqoonna karaambaiqanara aasaandaana ufa qidaqa.
\q1 Mifa aiqama tinai nifaqa qafamasee ataasa ataasa qidaqa.
\q1 
\v 52 Naaru naaru amooqirafa Yaaweenaindi mariani. Kuqaa kafaa kuqaa.
\c 90
\ms1 Mina Anaaqiannaa (Book 4)
\mr Idi Ufa 90–106
\s1 Anutuna ufa faqa faiqí ufa faqa.
\q1 
\v 1 Oo Yaawee, ooqai uqanna maasa qikeeku qikaaku qifaqnausa faqa maasa faqa maaqara foora ina marunafa mariananoo.
\q1 
\v 2 Ooqai aaqana faqa maa maqa maaqafa faqa sia marufana anee marinau.
\q1 Anee ooqai mariunna Anutufa kafaa naaru faqa marinna Anutufa mariananoo.
\q1 
\v 3 Anee Yaaweefa faiqí mareeqee kafaa maqaiki marianafa mariananoo.
\q1 Anee qinana faiqí faiqi kafaa quandaki maqaikammiaqee qimarianafa mariananoo.
\q1 
\v 4 Anee wan tauseenna aukuanara moodaa faasaanee qimariananoo.
\q1 Anee minara eenda faasaana aiqaree maqi qimariananoo.
\q1 
\v 5 Anee Yaaweefa nammari aufinoo faiqí maree findee imariananoo, misa qainasaara foora qusasaa mariqa kai kaqi taikaidaqa.
\q1 Faiqí nimmuru kananaana amiqi amiqindee iifanoo eendifanoo ammundaidanoo.
\q1 
\v 6 Kananaana kambiqafinoo amiqi amiqidanoo.
\q1 Eendimarifanoo doo aadanusinoo rooraiqidanoo.
\q1 
\v 7 Ani Anutuna aanooqirafa maasa faiqí faiqi turaurinoo.
\q1 Ani tikoora maasa firaaqoo rufiqaidaqa.
\q1 
\v 8 Maasa aaqarana aneenna afusaa aiqama quqasee qafee marianafa mariananoo.
\q1 Maasa kukeeqafi maraunna mandoosanafa ani afusaa kaaqa qaranaki akoosaqa maridanoo.
\q1 
\v 9 Ani aanooqirafa maasa marirana qusarama qimaqaidanoo.
\q1 Maasa qeeqa maa maqanasaa marunna aukuannana moodaannai daannamma neera foora iqa taikaidaqa.
\q1 
\v 10 Maasa marianna aukuanafa qaaramoo fasiqa niku nisauku taikasee qisaukuqara taikasee 70 aukuana kai marianaura.
\q1 Afeekaikiasa ootupamasee qaara faqa qaara faqa fasiqa niku nisauku taikasee 80 aukuana maraidaqa.
\q1 Maasa miqimmasee aukuanaki maridaqa ummaaraki faqa kadaapiki faqa maridaqa. Maasa miqimmasee aukuanaki marunanoo mi aukuanafa kai kaqi taikaifanoo maasa marirafa faqa kai kaqi taikaidanoo.
\q1 
\v 11 Oo Anutu, yafee ani firaa aanoo qira afeekana oosana iriannoo fee. Sia moo fannoo iriannoo.
\q1 Yafee faiqí anaasee anee aanoo qimariana rufiee marianara irianno fee. Sia moo fannoo iriannoo.
\q1 
\v 12 Oo Yaawee, maasa qeeqa maa marirafa qusaranoo marinara qima qiminaqa iria.
\q1 Miqimmasainaqa maasa irirafa irirana faqaasa iriranara foora mariani.
\q1 
\v 13 Oo Yaawee, anee maasara aanooqirafa kisaaqasaa fee mariannoo fee.
\q1 Maasa aneenna ainainira faiqiuqara amuqusiani.
\q1 
\v 14 Oo Yaawee, aneenna naaru naaru marira amuqusirana aiqama kananaana maasa umbiqa nimia.
\q1 Miqimma niminaqa maasa kaqi marianna aukuana asasira idi raidaqa nasurianaura.
\q1 
\v 15 Oo Yaawee, anee moomoo aukuana dariunnana amana kai asasirana maqee qimia.
\q1 Mandaikamaqimaqee unna aukuana amana kai asasirana qimia.
\q1 
\v 16 Oo Yaawee anee kaaqa idaaqira ainaina auqu quqoonnana maasa aneenna ainainira fasiqauqa nifusaa kooroommasee uqannifiqaa.
\q1 Aneenna areenara afeeka faqa maasa faiqinamu qinaiqi mara uqannifiqa.
\q1 
\v 17 Yaaweefa anee maasa Anutufa, ani amiqi amiqirafa maasasaa mariani.
\q1 Maasa aiqama ainaina auqee marunnana anee anoonaika maqisaa.
\q1 Eeoo, maasa ainainirana mapukunnisaa.
\c 91
\s1 Anutufa maasa itita qimaqee marifa maridanoo.
\q1 
\v 1 Yafee Yaaweefa itita qimaqaani fee qimasee fimarifa faqa yafee aiqama afeeka faqaa Anutuna itita nimaqaranaki maridafee.
\q1 
\v 2 Misa Yaaweenara maaqi qifaranoo, mifa maasa afeeka kukeeqara maqusa maridanoo fee qidaqa.
\q1 Mifa maasa Anutufa marifaqa minakai saqarikidaqa.
\q1 
\v 3 Mifa namuqaa umee mandainainakinaana ani asumu maraannoo.
\q1 Manda kuqira auriranakinaana mareeqee kaqinni quqaannoo.
\q1 
\v 4 Mifa kookooraanara foora narí aqoosannai ani itita amaqaannoo.
\q1 Anee mina aqoosaki keeqafinana itita amaqarana paqurinnaranoo.
\q1 Mina mapukusee marira oosana fannoo ani saqari kamma amaqeenoo ani faandaamurara foora mariannoo.
\q1 
\v 5 Anee miqina maridana eendaki rufiee maria ainainausara sia rufieennaranoo.
\q1 Faasaana tautummasee ani mandaikamma amaqara ainainnara faqa sia rufieennaranoo.
\q1 
\v 6 Eendaki faiqí narimari auriranara faqa sia rufieennaranoo.
\q1 Faasaana narimari manda ainainnara faqa sia rufieennaranoo.
\q1 
\v 7 Ani aaqa wan tauseenna fasiqa kuqaki aqufifaranoo kafaa ani asauku uqannai maria fasiqausa ten tauseenna kuqiranaki fifaranoo.
\q1 Mi narirafa faqa sia uqanna ani aaqa aniannoo.
\q1 
\v 8 Aneenna afunnoo manda oosana maree mariana akiiqara narirana qafeennaranoo.
\q1 
\v 9-10 Anee uriqarara Anutunara itita qimaqee mari fee qiannanara faqa Yaaweenara qini afeeka kukeeqara maqusa fee qimasee keeqafuannanara sia moo manda ainaina anisaa aqufuannoo, sia moo ummaara ani maaqa aaqa aniannoo.
\q1 
\v 11 Anee miqinanoo Anutufa narí qangeeroouqara qinaqa misa ani marirana niranasaa rakisi amaqeefaranoo.
\q1 
\v 12 Mi qangiroosa nári nisaukunnai ani qumaraifana sia oonisaa aiku rupaurinnaranoo.
\q1 
\v 13 Anee raioona faqa manda sakani faqa nimuaaqa aiku reennaranoo.
\q1 Raioona firaana faqa ukadiqa faqa aikunnai radamusainaqa sia ani arifaranoo.
\q1 
\v 14 Anutufa maaqi qidanoo, qinee qiniara nidimarisa manda ainainakinaana qumareeqee kaqinni quqaanaura.
\q1 Qiniara karaambaiqee qimasee irimarisa qinee itita nimaanaura.
\q1 
\v 15 Misa qini daaraifaqa maqi qimasee kaifaa qimamianaura.
\q1 Misa ummaaraki marifaqa misa faqa maridaqa dadaaqammianaura.
\q1 Qinee misa mandainainakinaana uqeerasee uriqarara nuqu nimianaura.
\q1 
\v 16 Qinee misa marirana kisaaqaikamma nimaqasee manda ainainakinaana mareeqee kaqinni quqaanaura.
\c 92
\s1 Anutuna amooqira idi.
\q1 
\v 1 Oo Yaawee ani amooqirafa firaaqoo uriqararafa amiqira oosana maridanoo.
\q1 Ani uriqarara auquara irisee idinnai ani amooqirafa amiqira oosana maridanoo.
\q1 
\v 2 Aiqama kananaana ani amuqusirana kooroo irafa amiqira oosana maridanoo.
\q1 Ani mapukusee marira oosana faqa aiqama eendaki kooroo irafa amiqira oosana mariannoo.
\q1 
\v 3 Piripunnannai ani amooqira idi rarafa amiqirafa maridanoo.
\q1 Ufireena fuaqaida amiqira naundasaa idi raidaqa ani maasara amuqusirana kooroo idaqa.
\q1 
\v 4 Oo Yaawee, anee auqoonna afeeka ainainausa qini asasirana qimidanoo.
\q1 Qinee anee asaukunnai auqoonna ainaina qafamasee ani amooqira idi raidaqa.
\q1 
\v 5 Oo Yaawee, anee auqoonna ainainafa firaafa uqanna maridanoo.
\q1 Ani irirafa firaafa farumara foora meemai maridanoo.
\q1 
\v 6 Irirana siaifa maa ainainnara sia iridanoo.
\q1 Furufari marifa mifa faqa sia iridanoo.
\q1 
\v 7 Maa ainainnara faqa sia iridaqa. Aaqara oosana maree mariasa amiqira andandara foora dauni kambiqaidaqa.
\q1 Manda oosana maree mariasa reemindeemiriranaki maridaqa.
\q1 Misa miqiqa mariinaqa naaru amiqi uqanna masee kuridifaranoo.
\q1 Irirana siaisa minara sia iridaqa.
\q1 
\v 8 Oo Yaawee anee naaru naaru kaaqa uriqararafa mariannanara kuridi nimaqeennaranoo.
\q1 
\v 9 Oo Yaawee maasa iridaqa ani namuqaauqa kuqaa uqanna kuqifaranoo.
\q1 Aiqama manda oosana maree mariasa anee rafaaqafu nimaqeennaranoo.
\q1 
\v 10 Kaasau burimakau akoona afeeka amana kai qini faqa qimimariananoo.
\q1 Anee asasiranannai qini amiqi amiqimma qimaqaananoo.
\q1 
\v 11 Qini qifu fannoo qini namuqaa rafaaqafu nimaqarana qafeenoo.
\q1 Manda oosana maree maria namuqaasa qeeqa daaqoonnai misa faaqa rirana iriqa.
\q1 
\v 12 \fig Sidaa saqari.|alt="Cedar tree" src="BK00090B.TIF" size="col" loc="Psalm 92:12" ref="92:12"\fig*Andeeqee mariasa asumu saqari kambiqeenoo amanee muna munindee idaqa.
\q1 Misa innooqa fiqa. Rebanonna maqa maaqakina mari sidaa saqariara foora kisaaqa marifaranoo.
\q1 
\v 13 Mi andeeqara fasiqausa Yaaweena amaana maqa naambeeqaqaraa saqariara foora amiqimmasee kambiqaidaqa.
\q1 Misa Anutuna amaana maqa naambeeqaira foora kambiqafi moomoo kidaqa.
\q1 
\v 14 Mi andeeqara fasiqa anaaseesa asooaqeeqa saqariara foora kaqi qaqama ireefaranoo.
\q1 Misa fuka saqariara foora afeekaikiqa maridaqa amanee muna muna ifaranoo.
\q1 
\v 15 Miqianannoo Yaaweefa andeeqarafa marinara kooroo idanoo.
\q1 Yaaweefa qini afeeka itita qimaqee mari ooni fara foora maridanoo.
\q1 Sia moo aaqarafa minaki maridanoo.
\c 93
\s1 Anutufa karaambaiqa maridanoo.
\q1 
\v 1 Yaaweefa karaambaiqa maridanoo.
\q1 Mina afeeka faqa kaaqa uriqarara andeeqara oosana faqa mina qamunnara foora afisinoo maridanoo.
\q1 Maa maqa maaqafa mapukinoo maridanoo sia amana furufariannoo.
\q1 
\v 2 Oo Yaawee, ani ufa irira qaari ooqai oosana arooqooqari afeekaikinoo maridanoo.
\q1 Maa maqa maaqafa sia marunaki anee ooqai naaru naaru mariranaki marunafa mariananoo.
\q1 
\v 3 Oo Yaaweefa, ooruku nammari fannoo amakauridanoo firaaqoo ufa qidanoo.
\q1 Mi amakaurirafa firaaqoo narisaa narisaa arinoo darara qidanoo.
\q1 
\v 4 Uriqarara Yaaweefa firaa afeekannoo innaarunaindaraa ainaina rakisidanoo, ooruku nammari amakaurirana faqa arusee uriqararafa uqanna maridanoo.
\q1 Ooruku nammari firaaqoo amakauri mari afeekana Yaaweefa uraaqararafa maridanoo.
\q1 
\v 5 Oo Yaawee, ani sanda ufa naaruara marifa maridanoo.
\q1 Ani amaana maqa naaquqarafa naaru naaru marianinafa maridanoo.
\c 94
\s1 Anutufa aiqamausa raina nimaqee marifa maridanoo.
\q1 
\v 1 Oo Yaawee, anee manda oosana akiiqara imarianna Anutufa mariananoo.
\q1 Anee miqi mariannanara aneenna arana qarana kooroommasainaqa qafaaqa.
\q1 
\v 2 Oo Yaawee, maasa maa maqa maaqanasaaqaraasa ufa rainee marianafa, anee findi fua.
\q1 Doo findi finana nári noori uqeeree mariasa miqi mariana akiiqara nimia.
\q1 
\v 3 Oo Yaawee, kisaaqasaa fee manda oosana maree mariasa asasida marifaree.
\q1 Kisaaqasaa fee misa nasu nasurifaree.
\q1 
\v 4 Ummuari mariasa kisaaqasaa fee ramoo ramaa ida nári manda oosana maree mariana amoo aamoo qifaree.
\q1 
\v 5 Oo Yaawee, miqi mariasa ani faiqí anaasee radamidaqa.
\q1 Ani aiku asauku mariasa nári uriqararanannai misa rafaaqa fidaqa.
\q1 
\v 6 Mi manda oosanna faqaasa adeedaana faqa asaqiraafai faqa narimariasa maridaqa, fiaiqi faiqi maasa maqa maaqaki ani mariasa faqaa kuqa nárí mariasa maridaqa.
\q1 
\v 7 Miqi mariasa Yaaweenara quandaki maaqi qidaqa.
\q1 Yaaweefa sia maasa qiqafaidanoo.
\q1 Isaraee maqannaasa Anutufa sia minara iridanoo, mana mana kai midanoo.
\q1 
\v 8 Qini faiqí anaasee naqaa fee ifaqee maa furufarira oosana auqee fee.
\q1 Innee furufarira irirana faqaasa mariasa mariafanoo.
\q1 Yairee fee innee irirana maree faree.
\q1 
\v 9 Naaqoo auqu quqoo fasiqanara Anutunara innee minara sia ufa irimarifee fee qidafee.
\q1 Inni nifu auqu quqoo fasiqanara Anutunara innee minara sia qafee marifee fee qidafee.
\q1 
\v 10 Aiqama maqannaasa Anutufa rakisi nimaqaidanoo innee minara sia misa andeeqaannoo fee fee qidafee.
\q1 Mifa irirana uqannifiqee mari fasiqafa maridanoo Anutunara innee minara sia irirana faqaafee fee qidafee.
\q1 
\v 11 Yaaweefa aiqamausa umee irirana iridanoo.
\q1 Misa irirafa dapikira irirafa kai marinara faqa mifa iridanoo.
\q1 
\v 12 Oo Yaawee anee irirana maraanifeera qima ami marianna fasiqafa asasiani.
\q1 Anee aneenna sanda ufa uqafiqee marianna fasiqafa mifa faqa asasiani.
\q1 
\v 13 Anee misa ummaara maraafana asooarana nimimariananoo.
\q1 Miqidana anee manda oosana maree mariasara madika deedaqi mariananoo.
\q1 
\v 14 Yaaweefa narí faiqí anaasee sia ameesuqu nimaqaannoo.
\q1 Mifa sia uqanna narindikiqa mariasa ameesuqu nimaqaannoo.
\q1 
\v 15 Mikari ufa andeeqa nimaqee mariasa kaifaa andeeqa nimaqeefaranoo.
\q1 Aiqama andeeqara marirana faqaasa misa mi andeeqa nimaqara ufana qafamasee amiqirafee qimasee pooduqeefaranoo.
\q1 
\v 16 Qinee findifiqa manda oosana mareeusa qini darirarufaqa itita nimaqaaneera iafanaqa yafee moo fannoo qini dadaaqinau. Sia moo fannoo qini dadaaqinau.
\q1 Qinee findifiqa aaqee mariasa qaoo qianee riafanaqa yafee moo fannoo qini dadaaqinau. Sia moo fannoo qini dadaaqinau.
\q1 
\v 17 Yaaweefa sia qini dadaaqinaqau qini darusaifaqau qinee kai kaqi kuqirausa ufa siaisaki marunaiqini.
\q1 
\v 18 Qinee aqufuanauree qunana Yaawee aneenna naaru marira amuqusiranannai qini qumaraananoo.
\q1 
\v 19 Qini daunduraki ummaara darimarifaqa moomoo irirana irimarunana anee Yaaweefa qini daundura uqbiqasee asasirana qimi mariananoo.
\q1 
\v 20 Oo Yaawee anee eendaandira siaasauqa faqa sia amana misa faqa moodaanaki ainaini mariananoo.
\q1 Misa aaqee maria sandufausa marasee unna qimasee maasa andeeqara sanda ufee qianara aaqaidaqa.
\q1 
\v 21 Miqi maria manda siaasausa moodaanaki suqufiqa andeeqarausa mandaikamma nimaqarara tipundaaridaqa.
\q1 Mi manda siaasausa aaqarana siaisa mara kuqiranaki quqaidaqa.
\q1 
\v 22 Misa miqi marifanoo Yaaweefa qini afeeka kukeeqara maqusa maridanoo.
\q1 Qini Anutufa qini itita qimaqara ooniara foora marifaqa qinee minaki kukeeqaidaqa.
\q1 
\v 23 Yaaweefa mi manda siaasausa nariqa aaqarana akiiqara nimiannoo.
\q1 Misa aaqarana akiiqara Yaaweefa kuridi nimaqaannoo. Yaaweefa maasa Anutufa misa kuridi nimaqaannoo.
\c 95
\s1 Anutuna amooqira idi.
\q1 
\v 1 Doo aniaqa, aniraifaqa Yaaweena amooqira idi ramamaqaa.
\q1 Mifa maasasaa ititee marifa marinara firaaqoo asasira idi raaqa.
\q1 
\v 2 Doo aniaqa, aniraifaqa dufi dufi qirana namu faqa mina afusaa oonu raa.
\q1 Asasammasee amooqira idi namu faqa mina afusaa oonu raa.
\q1 
\v 3 Yaaweefa afeeka faqaa Anutufa maridanoo.
\q1 Mifa aiqama unna anutusa rafaaqafu nimaqaseenoo afeeka karaambaiqa maridanoo.
\q1 
\v 4 Mifa aiqama maa maqa maaqana rakisirafa maridanoo.
\q1 Mifa maqa ameemaanai ooni aamarauqa faqa kisaaqa aaqanauqa faqa rakisi marifa maridanoo.
\q1 
\v 5 Mifa ooruku nammari faqa maqa faqa narí auquqoona minaindi marifanoo minasaa rakisidanoo.
\q1 
\v 6 Doo aniaqa, aniraifaqa mina oorinni kummara mafi amooqia.
\q1 Yaaweefa maasa auqunara maasa mina oorinni qiqoori saunu arafi mina amooqia.
\q1 
\v 7 Mifa maasa Anutufa maridanoo.
\q1 Maasa mina sipsipara foora maridaqa.
\q1 Maasa mina sipsipara foora mina rakisi nimaqaranaki maridaqa.
\q1 Oo maqee uqanna mina ufa iriaqa.
\q1 
\v 8 Inni nikeeku nikaaku Meeribaa maqasaa undee sia iaqa.
\q1 Innee sia misa naanna ramasee inneeqa nimuqusaki qini ufara ititiaqa.
\q1 Inni nikeeku nikaaku Masaa aadana maqasaa qini Anutusa kafaa kafaa qimanammasee qafoondee sia iaqa.
\q1 
\v 9 Misa miqoo aadana maqa maaqaki marida qinee firaa ainaina auqaafannana qafamasee sia iriqau, kaqi qimanammasee qafaqau.
\q1 
\v 10 Qaara fasiqa niku nisauku taikasee 40 aukuanaki qinee Isaraee maqannaasara qikoo uqanna qoofaqa qinee Anutusa misara maaqi qiqiafana.
\q1 Maa maqannaasa kaaqa qaara irirana mau fimarisa maridaqa.
\q1 Misa qini sanda ufa minnisee moosaa fimariasa maridaqa.
\q1 
\v 11 Minara qinee Anutusa qeeqa aanoo qiranakiqari maaqi qimasee qima afeekaikiqa.
\q1 Misa qini idooara maqusaki sia uqanna keeqeefaranoo.
\c 96
\s1 Anutufa uriqarara karaambaiqa maridanoo.
\q1 
\v 1 Innee fuka idi Yaaweena rama amaqaaqa.
\q1 Aiqama maa maqanasaaqaraasa Yaaweena idi rama amaqaaqa.
\q1 
\v 2 Innee Yaaweenara idi raaqa. Mina auqu amooqiaqa.
\q1 Mifa maasa kuqiranakinaana asumu marainara aiqama faasaana mi amiqira fasaasa ufana koorooiaqa.
\q1 
\v 3 Mina areenaranara maa maqanasaa mariasa qimannimiaqa.
\q1 Mifa firaa afeeka naaquqara ainaina auqoonara aiqama faiqi anaasee qimannimiaqa.
\q1 
\v 4 Yaaweefa firaafa uriqararafa marinara mina amooqirafa faqa miqikai masee uriqararafa mariannoo.
\q1 Aiqama fasiqa anaasee unnaqira anutusara naaquqee marina minisee Anutuna uqannara firaaqoo naaquqaani.
\q1 
\v 5 Anaamuru mariasa unnaqira anutusa fifau nariqa auqusee amooqidaqa.
\q1 Miqi mariafanoo maasa Yaaweefa innaaruna faqa minakinaa ainaina faqa auqu quqoofa uriqaranoo maridanoo.
\q1 
\v 6 Kaaqa qara areenarafa faqa uriqararafa faqa mina fiqu fiqu iqa maridaqa.
\q1 Amudaanaiqirafa faqa kaaqa idaaqirafa faqa mina amaana maqaki qumbiqanoo maridanoo.
\q1 
\v 7 Innee aiqama maqannaasa Yaaweena afeeka faqa areenarana faqa amooqima amaaqa.
\q1 
\v 8 Yaaweena areenara auqu amooqiaqa.
\q1 Innee amaana maqaki keeqaani qimasee dufi dufi qima amaqee fandinna ainaina uqirafa keeqaa.
\q1 
\v 9 Naaquqara karaambaiqa kooroo inaqa aiqama maa maqanasaaqaraasa mina oorinni naindiri reemarinaqaniqoori saunu araaqa.
\q1 Aiqama maqannaasa mina afusaa rufiaida naindiri raani.
\q1 
\v 10 Innee Yaaweefa uriqararafa marinara aiqama maqannaasa qimannimiaqa.
\q1 Maa maqa maaqafa afeekaikamma mapukinoo marinara sia amana rundoorundiannoo.
\q1 Mifa aiqama maqannaasa andeeqasee amana amana kai andeeqa nimaqaannoo.
\q1 
\v 11 Innaarunai maria ainainausa Yaaweenara asasiaqa.
\q1 Maqa faqa minakinaa ainainauqa faqa asasiaqa.
\q1 Ooruku nammari anee faqa minakinaa noodaanna ainaina faqa Yaaweenara faaqa ridaqa amooqiaqa.
\q1 
\v 12 Usau maqa maaqa faqa minaki maria ainainausa faqa aiqama asasiaqa.
\q1 Nandaki saqariuqa faqa nasuridaqa asasifaranoo.
\q1 
\v 13 Yaaweefa maqasaaqaraasa rakisi nimaqarara anireenoo andeeqaranannai faqa amana amana kai ira oosanannai faqa rakisi nimaqaannoo.
\c 97
\s1 Anutufa uriqarara rakisirafa.
\q1 
\v 1 Yaaweefa karaambaiqa marinara maa maqa maaqafa asasiani.
\q1 Ooruku nammariki mari afumausa faqa asasiaqa.
\q1 
\v 2 Eekara oonnamu faqa asukuna faqa Yaaweena fiqu fiqu inoo maridanoo mina kukeeqa amaqaidanoo.
\q1 Mifa andeeqaranannai faqa amana amana kai raina nimaqararannai faqa faiqí anaasee rakisi nimaqaidanoo.
\q1 
\v 3 Ida fannoo mina oorinni fidanoo mina namuqaa mina fiqu fiqu imariasa qamataika nimaqaidanoo.
\q1 
\v 4 Mina aakuasaa fannoo aiqama maqa maaqaki kaaqa qamannimaqaifanoo, maa maqafa qafeenoo rufiaifanoo aindiri raidanoo.
\q1 
\v 5 Aiyama maqa maaqa quqoo Karaambaiqana Yaaweena afusaa aaqanauqa tasirisirimma taikaidaqa.
\q1 
\v 6 Innaaruna fannoo Yaaweena andeeqaranara kooroo ifaqa aiqama maqannaa mina areenarana qafaidaqa.
\q1 
\v 7 Nisaukunnai auqimaria unna anutusa nimoo qimariasa Anutufa uqanna misa mareeqee nisauriranaki quqaidanoo.
\q1 Unna anutusauqa aiqama quandaki Yaaweena oorinni kummarama fuaqa.
\q1 
\v 8 Yaaweena andeeqa nimaqara ufa marinara Sioona maqusanaasa faqa Yuda maqannaasa faqa asasidaqa.
\q1 
\v 9 Oo Yaawee, anee aiqama afeeka faqaafa aiqama maqa maaqaki mariasa rakisi nimaqee marianafa mariananoo.
\q1 Aiqama unnaqira anutusa faqa firaaqoo urinnaaqararafa uqanna mariananoo.
\q1 
\v 10 Yaaweefa mandoosanaa fidiaqaa imariasara aididanoo.
\q1 Mifa narí ufamau fimariasa misa mariranasaa rakisida ititannisaidanoo.
\q1 Mifa manda oosana maree mariasa nisaukukinaana mara kaqinni quqannisaidanoo.
\q1 
\v 11 Kaaqa qarafa andeeqarausasaa kaaqa qaidanoo.
\q1 Andeeqara marirana faqaasaki asasirafa maridanoo.
\q1 
\v 12 Innee andeeqaramau fimariasa, Yaaweefa auqoo ainainara irisee asasiaqa.
\q1 Naaquqara Anutufa auqoo ainainara oonumafi irisee dufi dufi qima amaqaaqa.
\c 98
\s1 Anutufa maa maqa maaqakinaa fasiqa anaasee rakisirafa.
\q1 
\v 1 Yaaweefa moo kamaakira amiqira ainaina auqoonara innee fuka idi rama amaqaaqa.
\q1 Mifa narí afeekannai faqa kaaqa naaquqara afeekannai faqa narí namuqaauqa naruseenoo urinnaaqarama finau.
\q1 
\v 2 Miqimmaseenoo Yaaweefa rakiranaki narí uriqararana koorooinau.
\q1 Aiqama maqannaasa nifusaa Yaaweefa mandainainakinaana mara kaqinni quqeemari afeekana kooroo inau.
\q1 
\v 3 Yaaweefa Isaraee maqannaasara sia taikaaninna amuqusirana faqa mapukusee marira oosanara faqa nimianauree qimasee qimaqoona sia qauninau kaqi afu mundusee fimarinau.
\q1 Aiqama maqa maaqa ati ati marusa rakiranaki maasa Anutuna afeeka doo qafaqau.
\q1 
\v 4 Maa maqa maaqanaki mariasa innee aiqama Yaaweena asasira idi ramamaqaaqa.
\q1 Innee firaaqoo asasira idi faqa amooqira idi faqa ramamaqaaqa.
\q1 
\v 5 Innee amooqira idi Yaaweena ramamaqaaqa.
\q1 Piripunna aridaqa mina amooqiaqa.
\q1 
\v 6 Ufireena faqa sipsipa aanainnai auqira ukeenannoo faqa fuaqaidaqa,
\q1 Yaaweenara maasa karaambaiqa fee qidaqa mina oorinni mi namunannai asasamma amaqaaqa.
\q1 
\v 7 Ooruku nammari faqa minakinaa aiqama ainaina faqa Yaaweenara irisee faaqaruaqa.
\q1 Maqa maaqa faqa minakina maria fasiqa aanaaseesa faqa aiqama ainainauqa faqa faaqa fuisee iqa asasiaqa.
\q1 
\v 8 Nammari uqanna faqa Yaaweena oorisaa nisauku aridaqa asasiaqa.
\q1 Amuaqu namuqa faqa moodaanaki kammafi Yaaweena oorisaa susummamaqaaqa.
\q1 
\v 9 Yaaweefa maa maqa maaqanaki mariasa ufa andeeqa nimaqarara quminara asasamma amaqaaqa.
\q1 Narí andeeqaranannai faqa amana amana kai andeeqaranannai faqa maqasaa qaraasa andeeqannisaannoo.
\c 99
\s1 Anutufa uriqarara karaambaiqa.
\q1 
\v 1 Yaaweefa karaambaiqa marifaqa aiqama fasiqa anaasee rufiaafanoo naindiri raidanoo.
\q1 Mifa angiroouqa oorinnaaqaree meeraqoo narí ufa irira qaarisaa ooqufaaqee marifanoo maqa kasidanoo.
\q1 
\v 2 Yaweefa Sioona maqusaki afeeka faqaafa maridanoo.
\q1 Aiqama maqannaa fasiqa anaasee urinnaaqaramafi maridanoo.
\q1 
\v 3 Minara aiqamausa mina firaa uriqarara auquara amoo qifaranoo.
\q1 Mifa kaaqa naaquqarafa maridanoo.
\q1 
\v 4 Afeeka faqaa karaambaiqa anee andeeqaranara kai aidimarifa mariananoo.
\q1 Anee andeeqarana kai Isaraee maqa maaqaki quqaananoo.
\q1 Anee andeeqarana faqa amana amana kai rainannimaqarana faqa maree mini quqaananoo.
\q1 
\v 5 Yaaweena maasa Anutuna amooqiaqa.
\q1 Mina ufa irira qaari aaqa oonuree minara innaaru qiaqa.
\q1 Mina andeeqarafa naaquqarafa maridanoo.
\q1 
\v 6 Mooseesa Aaroonasa mina aanaiqikira fasiqaqara mariqau.
\q1 Samueerafa faqa Anutunara innaaru qimarufa marinau.
\q1 Minamusa Yaaweena innaaru kiqari aaroofanoo iriseenoo nári qimanniminau.
\q1 
\v 7 Yaaweefa oonnamukiqari misa ufa qimanniminau.
\q1 Misa mina naamuaqira ufa faqa sanda ufa faqa iriseeqa mimau kai fimariqau.
\q1 
\v 8 Oo Yaawee maasa Anutu ani faiqí anaasee aniara innaaru qiafana anee qimannimiananoo.
\q1 Anee aaqarana akiiqara minninnisee marianafa mariannana misa uqannifiqaa. Anee misa aaqarana akiiqara aupurarana nimi mariannana faqa uqannifiqaa.
\q1 
\v 9 Minara innee Yaaweena maasa Anutuna amooqiaqa.
\q1 Mina naaquqara aaqanasaa mina amooqiaqa.
\q1 Yaaweefa maasa Anutufa andeeqarafa naaquqarafa maridanoo.
\c 100
\s1 Anutuna amooqira idi.
\q1 
\v 1 Aiqama maa maqanasaa mariasa Yaaweenara asasira idi ramamaqaaqa.
\q1 
\v 2 Asasirana namufaqa Yaaweena amooqiaqa.
\q1 Innee asasira idi ramammaree mina oorinni aniaqa.
\q1 
\v 3 Innee sia Yaaweenara aunuaqa, mifa kai Anutufa maridanoo.
\q1 Mifa kai maasa auqinau, maasa minaindi maridaqa.
\q1 Maasa mina faiqí anaasee mina sipsipara foora maridaqa.
\q1 
\v 4 Innee mina amaana maqa faandaamura kooqiki oonuree dufi dufi qimammareeqa keeqaaqa.
\q1 Oorureeqa amaana maqa kooqiki faqa dufi dufi qidaqa amooqiaqa.
\q1 
\v 5 Yaaweefa andeeqarafa maridanoo, mina faiqí aanaaseera amuqusirafa naaru naaru marifa maridanoo.
\q1 Mina mapukusee marira oosana naaru naaru marifa maridanoo.
\c 101
\s1 Karaambaiqa Dafidina qima afeekaikira ufa.
\q1 
\v 1 Ani sia taikara amuqusira oosanara faqa amana amana kai nimira oosanara faqa idi raidaqa.
\q1 Oo Yaawee, ani idi rama amaqaidaqa.
\q1 
\v 2 Qini marirafa andeeqasee ufa siaisa marianaura.
\q1 Miqiqa marianana oo Yaawee anee yairee fee qinee marunnannai qumuree dadaaqinnaree.
\q1 Qinee anukara marira qeeqa maaqaki marianaura.
\q1 
\v 3 Sia qinee naaruara moo manda aaqara oosanara eedoo qianaura.
\q1 Anutuna ufara nimeesa uqimariasa oosanara qinee fidiaqaammidaqa.
\q1 Sia misa manda oosanaki kaqikaaqoo faqa keeqaanaura.
\q1 
\v 4 Qinee unna oosana faqaasa futeeqa nianai auquanaura.
\q1 Qinee sia manda oosana maree mariana kaqikaaqoo faqa dadaaqianaura.
\q1 
\v 5 Nári niqoonausara unnufa qimasaida nupiqnupita qimaria fasiqa anaaseesa qinee misa taika nimaqaanaura.
\q1 Nári noori uqeeree mariasa faqa aanoo masee nári iriranamau fimariasa faqa sia qini daaqa marifara nianasaa futeeqa aquanaura.
\q1 
\v 6 Anutuna ufasaa nifu mundusee fimariasa qinee misara didiannoo.
\q1 Misa qini faqa qini maaqaki marifaranoo.
\q1 Aaqarana siaisa andeeqara mau kai fimariasa misa qini ainainira fasiqa anaasee marifaranoo.
\q1 
\v 7 Unna ufa qimariasa sia uqanna qinee marunnanaki marifaranoo.
\q1 Qaara iriramau fimariasa faqa sia qini qifusaa marifaranoo.
\q1 
\v 8 Qini maqa maaqaki aaqara oosana maree mariasa qinee aiqama kari randasee misa taika nimaqaanaura.
\q1 Anutuna maqusaki manda oosana maree mariasa qinee niqiqaanaura.
\c 102
\s1 Ummaaraki mari kumaaraana innaaru.
\q1 
\v 1 Oo Yaawee qini innaaru qirana iria.
\q1 Qini qikiraqarafa anee dadaaqianneera anee marianannai fimarina iria.
\q1 
\v 2 Qinee mandainainaki marianana sia aneenna oori kaqinni rafusu aqua.
\q1 Aneenna aaqoo rammatini mambi iria.
\q1 Qinee ani aaraanana dauni maqi qimasee qimaqimia.
\q1 
\v 3 Qinee auriranaki faqa namuqaa dariranaki faqa marunanoo qini marirafa munara foora dauni taikararidanoo.
\q1 Qini qifaaqa idara foora muqurinoo maridanoo.
\q1 
\v 4 Qinee aadana andanda maqamau faiqeera foora maqasaa aqufiqa, qinee naranara qikooqaifaqa daarara fidaqa.
\q1 
\v 5 Daarara marunanoo qini qifaaqa asaqufifaqa qimudaani aanaaqi maridaqa, firaaqoo annadannada qidaqa maridaqa.
\q1 
\v 6 Kaasau ufini faiqí sia maria maqa maaqanaki marindee qinee iqa maridaqa.
\q1 Qinee karoondara foora ooqeennaa naakunduki kukeeaqa maridaqa.
\q1 
\v 7 Qinee qeeqaraa ufini maaqa ataufakaaqa mariara foora iqa ummaaraki maridaqa.
\q1 Sia faiqeeqa kaqi andeequmoorida maridaqa.
\q1 
\v 8 Qini namuqaauqa faasaambaasaana manda ufa kai qimidaqa.
\q1 Qini ataasa ataasa qima qimaqee mariasa qini duqunnai akaqausa niquraraidaqa.
\q1 
\v 9-10 Anee qini aanoo qima qimaqee mariananoo qini narana fannoo dandara foora marifaqa naidaqa.
\q1 Qeeqa daiquni daukunu namu faqa nammari naidaqa.
\q1 Anee qini mareeqee nianai aqu qisaanaqa maridaqa.
\q1 
\v 11 Qini maqee marirafa nimanandara foora mariifanoo eendifanoo taikeera foora qinee iqa maridaqa.
\q1 Qinee nimmuruara foora aadanusiqa rooraiqidaqa.
\q1 
\v 12 Kafaa anee Yaaweefa, naaruara uriqarara karaambaiqa marianaqa naaru kambiqainausa kaqi aniara iriqa fifaranoo.
\q1 
\v 13 Anee findifinana Sioonna maqusanaasara qimudaoo qinnaranoo.
\q1 Mi maqusanara qimudaoo qira aukuana doo anireenoo.
\q1 Maa maqee uqanna narí aukuana maridanoo.
\q1 
\v 14 Ani ainainira fasiqauqa Isaraee maqannaasa Sioonna maqusara ridaqa.
\q1 Mandaikinoo naakundukinoo marifaqa kaqi minara qimudaoo qidaqa.
\q1 
\v 15 Aiqama maqannaasa Sioonna maqusa dadaaqirana qafamasee Yaaweena auquara rufieefaranoo.
\q1 Aiqama maa maqanasaaqaraa karaambiqauqa misa Yaaweena mi areenara afeekanara naaquqaannoo.
\q1 
\v 16 Yaaweefa Sioonna maqusa kafaa usakasee miqoo narí uriqarara afeeka kooroo iannoo.
\q1 
\v 17 Mifa qumureenoo Isaraee maqannaa fasiqa anaasee sarauirausara irinoo misa innaaru qirana faqa iriseenoo dadaaqiannoo.
\q1 
\v 18 Yaaweefa auqoo ainainara papiqasaa akara rumasainaqa naaru anisaa ani aruaki kambiqainausa qafamasee mina amooqiaqa.
\q1 
\v 19 Yaaweefa narí sandaaqai naaquqarannai marunnaindari maqasaa mara miami qafanau.
\q1 Mifa innaarunaindari maqasaaqaraasa mara miami niuqinau.
\q1 
\v 20 Kuqiranaki fuaqeera karabusaki quqaqoosa annadannada qimarufanoo mifa iriseenoo iduku nisanau.
\q1 
\v 21 Miqinaqa Sioonna maqusaki misa Yaaweena auqu kooroommasee qimannimifaranoo.
\q1 Sioonna moo auqu Yeerusaree maqusaki misa mina amooqifaranoo.
\q1 
\v 22 Moomoo maqannaasa moodaanaki Yeerusaree maqusaki suqufiqa Yaaweena amooqifaranoo.
\q1 
\v 23 Qinee kumaaraa fasiqa marunanoo Yaaweefa qini afeeka taika qiseenoo qini marirana mara qusa reenoo.
\q1 
\v 24 Miqimmasaifaqa qinee maaqi qiqa.
\q1 Oo qini Anutu qinee kumaaraa fasiqa maridaqa, sia qini mara aquqisaa.
\q1 Oo Yaawee, anee naaru naaru marianafa mariannoo.
\q1 
\v 25 Ooqai kuradoo aukuana anee maa maqa maaqana poosauqa faakanara foora atukaranau.
\q1 Aneenna asaukunnai innaaruna auqu quqoonafa mariananoo.
\q1 
\v 26 Anee aiqama ainaina auquqoonafa taikafuannoo.
\q1 Aneenna kai kaqi marinnaranoo.
\q1 Mi aiqama ainainausa nauraa qammunnara foora anaqi anaqiannoo.
\q1 Anee mi nauraa ainainausa ooqeennaa qamunnara foora aqusainaqa taikafifaranoo.
\q1 
\v 27 Anee Yaaweefa naaru naaru miqi kai ina marinanoo ani marirafa sia taikarafa mariannoo.
\q1 
\v 28 Maasa ani ainainira fasiqauqa marunaqa maasa faiqi namu ani asumu mariranaki marifaranoo.
\q1 Misasaa ani aruakinausa ani ititannimaqarafa misa fiqu fiqu inoo mariannoo.
\c 103
\s1 Anutuna aidirafa.
\q1 
\v 1 Oo qini qimana, Yaaweena amooqia.
\q1 Qini daunduraki marianna aiqama ainainafa Yaaweena amooqia.
\q1 
\v 2 Oo qini maraquna, Yaaweena amooqia.
\q1 Mifa paapaa qida qimimarinara sia qaunua.
\q1 
\v 3 Mifa aiqama qini aaqarana akiiqara minni qisee marifa maridanoo.
\q1 Mifa qini aurirana aiqama taikaqisee marifa maridanoo.
\q1 
\v 4 Yaaweefa qini madikakinaana uqeera qiseemarifa maridanoo.
\q1 Mifa amuqusiranannai faqa narí qimudaoo qiranannai faqa qini amiqi amiqimma qimaqaidanoo.
\q1 
\v 5 Yaaweefa qini mariranaki amiqira ainainannai qumbiqa qimaqaidanoo.
\q1 Miqimmasaina qini marirafa aneesara foora fuka qisausi kambiqafinaqa kumaaraara foora kafaa marianaura. (Dafidifa quqaumuara qifaqa maasa ufa sia miqinoo marifaqa aneesara kai qiqa.)
\q1 
\v 6 Uriqararausa nimeemaanai ummaaraki mariasa Yaaweefa misa ufa irisee dadaaqiannoo.
\q1 Mifa misa nári ainaina andeeqasee nariqa kai nimidanoo.
\q1 
\v 7 Yaaweefa narí qimiruna Mooseena kooroommasee uqa fiqanau.
\q1 Narí firaa afeeka ainainna auqoona Isaraee maqannaasa uqannifiqasoofaqa qafaqau.
\q1 
\v 8 Yaaweefa qimudaoo qirana faqa amuqusirana faqa faqaafa maridanoo.
\q1 Mifa sia kai kaqi aanooqidanoo.
\q1 Mina naaru marira amuqusirafa firaafa qumbiqanoo maridanoo.
\q1 
\v 9 Yaaweefa sia kisaaqasaa inni manda oosanara nifairiannoo.
\q1 Kafaa mina aanooqirafa sia naaruara mariannoo.
\q1 
\v 10 Mifa sia maasa aaqarana amana kai daridanoo, oorudupimasee daridanoo.
\q1 Sia maasa aaqarana akiiqara mina amana kai daridanoo, ureeqasee darinoo.
\q1 
\v 11 Maqasaaqari innaarunai kisaaqasaa marina amana kai Yaaweefa narí amuqsirana nariara rufiee mariasa nimidanoo.
\q1 
\v 12 Suani ururee marina faqa keeqee marina faqa nianasaa marifanoo mina amanasaa Yaaweefa maasa mandainaina mara aqu qisaidanoo.
\q1 
\v 13 Faiqi nikausa faiqiara firaaqoo nimuqusidaqa.
\q1 Miqikai inoo Yaaweefa nariara rufiee mariasara firaaqoo amuqusidanoo.
\q1 
\v 14 Yaaweefa maasa auqunara iridanoo, maasa maqannai taikaaninna ainairannai auqunara iridanoo.
\q1 
\v 15 Maasa faiqí faiqi marirafa maaqimminoo maridanoo.
\q1 Maasa fifau adandara foora maridanoo.
\q1 Maasa marirafa andandara foora urureenoo afufeenaara mafifanoo amiqi amiqinoo
\v 16 marifanoo ufai fuaqasaifanoo kai kaqi taikaidanoo.
\q1 Taikafinana sia kaifaa qafeennaranoo.
\q1 
\v 17 Yaaweenara eerairida mina ufa qaindusi mariasasaa mina amuqusirafa naaru naaru mariannoo.
\q1 Mina andeeqarafa misaki faqa misa faiqi namuki faqa misa ninaiqimaraki faqa misa nifaqnausaki faqa mariannoo.
\q1 
\v 18 Yaaweena moodaanaki kira ufamau fimariasa faqa sia mina sandaufa minnisee kaqi mi sanda ufamau fimariasa faqa, misasaa faqa mina andeeqa nimaqarafa mariannoo.
\q1 
\v 19 Yaaweefa narí rakisi nimaqara qaari innaarunai quqaqaifanoo afeekaikinoo maridanoo.
\q1 Mifa aiqama maqannaasa uriqararafa maridanoo.
\q1 
\v 20 Yaaweena afeeka qangeeroouqa mina ufara eedoo qimariasa innee Yaaweena qimannimira ufa irimariasa innee Yaaweena amooqiaqa.
\q1 
\v 21 Innee innaarunai angeeroouqa moomoo maridaqa mina ainaini mariasa mina aidiramau fimariasa innee aiqamausa Yaaweena amooqiaqa.
\q1 
\v 22 Yaaweefa auqu quqoo ainainausa, mifa aiqama atinai rakisi nimaqee marisa innee faqa mina amooqiaqa.
\q1 Qini maraquna anee faqa Yaaweena amooqia.
\c 104
\s1 Aiqama ainaina auquna amooqirafa.
\q1 
\v 1 Oo qini qimana anee Yaaweena amooqia.
\q1 Oo Yaawee, qini Anutu, anee firaafa uqanna mariananoo.
\q1 Anee qammunnara foora kaaqa qareenarana faqa uriqararana faqa afisirafa mariananoo.
\q1 
\v 2 Yaaweefa anee kaaqa qarana qumaree qamunnara foora afisi marianafa mariananoo.
\q1 Kafaa anee innaaruna qumareeseera maaqara foora usakaananoo.
\q1 
\v 3 Yaawee anee aneenna maaqa innaaruna maarinni mari nammarinasaa usakaananoo.
\q1 Asuru fannoo ani rakira karara foora marifana anee minaki nimariananoo.
\q1 Anee ufai qaqoosasaa ooqu marifi nimarianafa mariananoo.
\q1 
\v 4 Anutu anee ufai faiqiara foora niqiqaanaqa ani ufa mara maree fidanoo.
\q1 Aakuasaa faqa ani ainainira faiqiara foora maridanoo.
\q1 
\v 5 Yaawee anee maa maqa maaqana maaqa poosara foora rusisoonanoo afeekaikinoo maridanoo naaruara sia kasiannoo.
\q1 
\v 6 Oo Yaawee, ooqai anee ooruku nammari quqasoonanoo aiqama maqa maaqa qamunnara foora dukuninau.
\q1 Aiqama aaqanauqa faqa rafaaqa finau.
\q1 
\v 7 Anee aanoo qimasee qaoo qunaqa nammariuqa rufiasee sandaqau.
\q1 Ani innaarunai qirana iriseeqa doo sandamaqaraasa mafiqau.
\q1 
\v 8 Mi nammarisa anusaa qari qumuree anee mariaqee qimaqoonna noopundunaki kai maridaqa.
\q1 
\v 9 Oo Anutu, anee oosuqoonnamau nammari fannoo marida naaru naaru sia fiaaqararana amana mariannoo.
\q1 Mi oosirafa nammari ititasainanoo sia kafaa maqa maaqa rafaaqa fuannoo.
\q1 
\v 10 Yaawee anee qunaqa maqakiqari nammari uqa urureeqa noopundu runna qumidaqa.
\q1 Mi nammarisa aaqana aikundanai fiqu aiquidaqa ooqufidaqa.
\q1 
\v 11 Oosana oosana aandauqa faqa mi nammarisa naaqeera qumidaqa.
\q1 Kaasau doonkiuqa faqa mi nammarisa nimaaqaara aadanusi marina quqeenaaqeera qumidaqa.
\q1 
\v 12 Ufiniuqaindi mi nammarina afaiqara saqariki aanaamu usakasee minaki maridaqa ufa qidaqa.
\q1 
\v 13 Anutu anee aneenna oonnamukiqari aaku adiaananoo aaqanauqa saa aqufifanoo ani amiqi amiqirafa maqa maaqaki qumbiqaidanoo.
\q1 
\v 14 Anutu anee aaku adiasaananoo aandauqa neefandinna andandausa kambiqaidanoo.
\q1 Mi aakufa faiqí neemaria narannana afu amifanoo kambiqaidanoo.
\q1 Miqimasaifanoo faiqí narí nara ainaina ummaqidanoo.
\q1 
\v 15 Faiqí fannoo wainna qaqama ummaqusee tiqisee tatisee wainna anoona naifanoo mina amuqusa fannoo asasidanoo. Mifa oorifa fadameena ooriki aku usaifanoo oori amiqi amiqidanoo.
\q1 Mifa feemu uquseenoo naifanoo amuaquinoo afeekaikidanoo.
\q1 
\v 16 Yaaweefa Sidaa saqariuqa Reebanoona maqa maaqaki ummaqusoofanoo marufaqa Yaaweena saqari fee qimariqau.
\q1 Aaku moomoo mi saqarisasaa aqufifaqa amiqi amiqidaqa.
\q1 
\v 17 Mi saqarisaki ufiniuqa aniraida aanaamu usakaidaqa.
\q1 Noonaafeesoona fooqaa ira ufi faqa miqoo moo saqari tookuseena fooqaa ira saqariki aanaamu usakaidaqa.
\q1 
\v 18 Kaasau mimmiuqa uriqarara aaqanasaa misa quqaqoo qoo maridaqa.
\q1 Mi aaqannasaa mataqooma fooqaa ira aandauqa ooni afooiranauqa aundurai maridaqa.
\q1 
\v 19 Anee Yaaweefa quqoona auqu quqaqoonanoo aukuana rainaidanoo.
\q1 Suani faqa auqu quqaqoonanoo aiqama kari narí keeqaaninnanara iridanoo mimau kai fidanoo.
\q1 
\v 20 Oo Yaawee, anee eendirafa mariannee qunanoo eendirafa anifanoo nandakinaa kaasau aandau aina aana nidaqa.
\q1 
\v 21 Kaasau aandau auqu raioona Anutufa amu narannara faaqariqanidaqa randaidaqa.
\q1 
\v 22 Suani ururaifaqa mi aandausa oonu maree ani maree nári faiqee mariana kiaqa faiqaidaqa.
\q1 
\v 23 Faiqaafaqa faiqí anaasee kafaa findififaqa nári ainainirannai oonuree ainainiqa fima riafanoo eendidanoo.
\q1 
\v 24 Oo Yaawee, anee moomoo ainainatia auqu quqoonafa mariananoo.
\q1 Aneenna amiqira iriranannai kai aiqama ainaina auqu quqoonafa mariananoo.
\q1 Anee moomoo kasi mari ainainna auqu quqaqoonafa maa maqa maaqana qumbiqanoo maridanoo.
\q1 
\v 25 Ooruku nammari dinni dinni fiqu fiqu firaana quqaqoonafa maridanoo.
\q1 Minakinaa aandau ainaina kasimarina firaana faqa kaqikaana faqa moomoo uqanna usidaqa sia amana nisaana rirana amana maridanoo.
\q1 
\v 26 Miqiqa mariafaqa sipauqa mi nammarina amuaqumau oonuree aniree idaqa.
\q1 Moo firaa aandau anee auqusee ooruku nammariki sararianee qimasee auquqoonafa maridanoo.
\q1 Mina auqu Reeviatanna maridanoo.
\q1 
\v 27 Mi aiqama ainainausa ani Yaaweenara narana nári nee marianara qiafana nimimariananoo.
\q1 
\v 28 Anee Yaaweefa misa narana nimianaqa mara naidaqa.
\q1 Anee nimianaqa naafanoo nimuaqu idanoo.
\q1 
\v 29 Oo Yaawee anee misa ameesa uqunnimaqasaanaqa misa rufiaidaqa.
\q1 Anee misa naidoo taikannimaqaanaqa misa kuqiqa kafaa maqaikidaqa.
\q1 
\v 30 Anee aidoo aiqama ainaina nimianaqa misa kasirana maraidaqa.
\q1 Maa maqa maaqanasaa aiqama atinai mari ainainausa fukaikamanimaqee mariananoo.
\q1 
\v 31 Yaaweena areenarafa naaru naaru marida kai mariani.
\q1 Narí auqu quqoo ainainausara asasiani.
\q1 
\v 32 Mifa maqasaa mara miami qafainara maqa fannoo rufiasee kasidanoo.
\q1 Asaukunnai aaqana ati auqainara idamuna ururaidanoo.
\q1 
\v 33 Qinee Dafidisa kaqi marunna kamuqoo Yaaweenara idi raanaura.
\q1 Qini daanna kaqi mari kamuqoo qeeqa Anutuna amooqira idi raanaura.
\q1 
\v 34 Qini asasirafa Yaaweefa marinnaindari qumi marinara qinee idi raannanara mifa asasiani.
\q1 
\v 35 Aaqee marinausa maa maqa maaqanakiqari taikaaqanani.
\q1 Manda oosana faqaasa sia mariaqanani.
\q1 Oo qini maraquna Yaaweena amooqia.
\q1 Yaaweena amooqia.
\c 105
\s1 Anutunara faqa narí faiqí aanaaseera faqa qidanoo.
\q1 
\v 1 Oo innee, Yaaweena dufi dufi qimamaqaa.
\q1 Mina uriqararanara kooroo iaqa.
\q1 Innee mifa auqoo ainainnara aiqama maqannaasa kooroomma nimiaqa.
\q1 
\v 2 Innee Yaaweena idi ramamaqaida mina amooqiqa.
\q1 Mifa idaaqira ainaina auqoonara qima nimiaqa.
\q1 
\v 3 Maasa Yaaweenaindi marunnanara asasiaqa.
\q1 Innee minara amooqi mariasa asasiaqa.
\q1 
\v 4 Innee dadaaqiranara Yaaweena qafaifanoo nimiani.
\q1 Innee maqee maqee mina amooqiaqa.
\q1 
\v 5-6 Innee Yaaweena ainainira fasiqa Abarahaamana akeeku akaaku mariasa mariafanoo.
\q1 Anutufa rusandeesamummaqaisa Yakooboona faiqi namu mariasa, innee mifa amiqira ainaina auqoonara faqa sia faiqí auqaaqaa ira ainaina auqoonara faqa mina naamuaqira ufara faqa iriaqa.
\q1 
\v 7 Yaaweefa maasa Anutufa maridanoo.
\q1 Mina naamuaqira ufa aiqama maqa maaqaki mariasa iriaqeera maridanoo.
\q1 
\v 8 Yaaweefa narí moodaanaki qima afeekaikira ufa sia aunuannoo, kaqi mina naaru naaru irinoo fuanoo.
\q1 Wan tauseenna oosana kambiqainausara Yaaweefa narí qima afeekaikira ufa sia aunuannoo naaru naaru misasaa mariannoo.
\q1 
\v 9 Yaaweefa narí moodaanaki kira ufa Abarahaamana faqa qimasee amuna sia minnisaannoo mimau kai fuannoo.
\q1 Isakeena faqa qima afeekaikira ufa amuna faqa sia minnisaannoo kai mimau fuannoo.
\q1 
\v 10 Yaaweefa Yakooboona moo auqu Isaraeerana moodaanaki kira ufa amufa naaru naaru mariannoo.
\q1 
\v 11 Yaaweefa misa faqa moodaanaki kira ufa maaqi qinau, qinee Kannaana maqa maaqa ani amiananoo mifa ani faiqi namu anaiqimaraindi kammiannoo.
\q1 
\v 12 Ooqai Yaaweena aiku asauku Isaraee maqannaasa oodaa maridaqa Kannaa maqa maaqaki anaamuruara foora misa qambaana mariqau.
\q1 
\v 13 Isaraeerana akeeku akaaku maaqa maaqa aiqama maqusa maqusa oonuree aniree iqa nimariqau.
\q1 
\v 14 Miqi marufaqa qinee Yaaweesa qumee misa rakisi nimaqee mariafana sia moo fannoo misa ummaara niminau.
\q1 Qinee misa saara karaambaiqauqa aanoommasee qaoo qimannimaqaqiafana.
\q1 
\v 15 Qinee Yaweesa maaqi qimasee mi karaambaiqausa qimannimiqa.
\q1 Innee sia qini qisauku munduqaunausa nuqaaqa.
\q1 Sia qini tamummaqara fasiqauqa faqa mandaikamma nimaqaa.
\q1 
\v 16 Yaaweefa qufanoo aandaroo firaafa inoo misa narana aiqama taikanau.
\q1 
\v 17 Yaaweefa Isaraeena aiku asaukukinaana mina auqu Yooseefaana misa noorinni aqiqoofanoo Isipa maqa maaqai finau.
\q1 Misa Yooseefaana Midianna maqannaasa nimisee feefauru mara maroofaqa mina afiqamaree Isipa maqa maaqai quqaqoofanoo moo fasiqa ainainira faiqikinau.
\q1 
\v 18 Isipa maqannaasa karabusa maaqaki quqasee sainnandannai aikuqara rumbaqau.
\q1 Misa qainnannai faqa mina anukaki rumbaqau.
\q1 
\v 19 Yooseefaafa karabusaki kaqi maridanoo qaina oosana qimannimufa anoona kambiqoofaqa qafamasee Yooseefaana idukiqau.
\q1 Yaaweena ufa fannoo Yooseefaafa miqunara kuqaa fee qinau.
\q1 
\v 20 Isipa maqannaasa uriqararafa qufaqa Yooseefaana idukiqau. Moomoo maqannaasa uriqararafa maridanoo idukinau.
\q1 
\v 21 Faraoofa Yooseefaana qumareenoo narí uriqararausa nikiiqa fasiqaikinoo maridanoo mina maqa maaqa faqa rakisianifee qimasee karaambaiqaikinau.
\q1 
\v 22 Miqimmaseenoo Faraoofa Yooseefaanara anee qini uriqararausa nikiiqa fasiqaikina maridana qini irirana qimi mariasa anee naakapaa.
\q1 
\v 23 Miqimmasoofanoo Yakooboofa Isipa maqa maaqai oonuree miqoo marinau.
\q1 
\v 24 Miqoo marufanoo Anutufa moomoo faiqi asumu narí faiqí anaasee Isaraee maqannaasa nimiseenoo misa nári namuqaa urinaaqarara afeeka faqaasaikamannisanau.
\q1 
\v 25 Miqiqa marida mikamuqoo Anutufa qumee misa iriranaki naakapoofaqa Isipa maqannaasa Anutuna ainainira faiqiuqa Isaraee maqannaasara fidiaqaaidaqa nikaru qi mariqau.
\q1 
\v 26 Miqiqa marufanoo Anutufa narí ainainira fasiqa Mooseena misunnai aiqanau.
\q1 Anutufa rusandeesamumaqoo fasiqana Aaroona mareeqee seenoo Mooseena faqa niqiqoofaqa isipa maqusai fiqau.
\q1 
\v 27 Oonuree miqanda Isipa maqa maaqaki maridaqa Anutuna naaquqara uqannifiqara ainaina Isipa maqannaasa Anutuna moo kira ainaaina uqannifiqaqau.
\q1 
\v 28 Mikari Anutufa Isipa maqa maaqaki asukuna quqasoofanoo asukuna misa rafaaqafinau.
\q1 Sia fifau miqinau. Misa mina ufara aanoommasee rukiqoonara miqinau.
\q1 
\v 29 Mifa Isipa maqannaasa nammari fidikaikamandoofaqa misa noodaanna aiqama kuqu taikaqau.
\q1 
\v 30 Misa maqa maaqaki eeqamoosa moomoo misa uriqarausa maaqakiaqa faqa qumbiqaqiqau.
\q1 
\v 31 Anutufa qufanoo faufaari sia kasoo anireenoo maaqa maqusa ititanau.
\q1 Nunuka faqa miqikaimminoo misa maqa maaqa aiqama atinai qumbiqanau.
\q1 
\v 32 Anutufa kafaa qufanoo aaku rirara foora mandee pupusamu qumuroofanoo aakuasaa quqasoofanoo aiqama atinai daraaninau.
\q1 
\v 33 Mi ainainna qandannai Anutufa Isipa maqannaasa wainna sanda faqa saqari qaqama faqa nee maruna faqa misa fifau saqariuqa faqa aiqama raudaandammasanau.
\q1 
\v 34 Yaaweefa kafaa qufanoo aammaadi moomoo nukudara foora teeqimafufaqa sia amana nisaanarirana amana, maqa maaqa umbiqaqa mariqau.
\q1 
\v 35 Aammaadi misa andanda faqa qafuqakinaa narana faqa aiqama nama taikaqau.
\q1 
\v 36 Doo mi ainainausa taikaseenoo Anutufa quandakufanoo Isipa maqannaasa ooqa faiqi akoonaiqiuqa aiqama narinau.
\q1 
\v 37 Yaaweefa Isipa maqannaasa ooqa faiqi akoonaiqiuqa naruseenoo Isaraee maqannaasa nifiqamareenoo misa Isipa maqannaasa koora siruaannai auqira ainainauqa mara maroofanoo Isipa maqa maaqakiqari nifiqee finau.
\q1 Sia moo fannoo teeroo quqoofa mariqau aiqamausa amiqirausa kai fiqau.
\q1 
\v 38 Isipa maqannaasa Isaraee maqannaara rufiarafa firaaqoo marunara misa fufaqa Isipa maqanaasa minara asasiqau.
\q1 
\v 39 Anutufa Isaraee maqannaasa nifiqee fidanoo asurunnai faasaana auqaana aru nimaqeenoo eendaki idauru miqirafa kaaqa qamannimaqee marinau.
\q1 
\v 40 Nifiqee fimarufaqa Isaraee maqannaasa Anutunara naranara iroofanoo afida faqa innaarunaindaraa narana manna feemu faqa naaqeera niminau.
\q1 
\v 41 Mifa ooni afoomandoofanoo nammari radiqisee firaafa quminau.
\q1 Mi nammarifa aadana maqa maaqaki firaa nammariara foora ooqu finau.
\q1 
\v 42 Yaaweefa misa nifiqee fidanoo narí ooqai qima afeekaikira ufa narí ainainira faiqi Abarahaammana amu ufanara irinau.
\q1 
\v 43 Isaraee maqannaasa narí rusandeesamu mandoosa nifiqee fidanoo asasirana nimufaqa mina namufaqa fidaqa faaqa rumasee asasiqa fimariqau.
\q1 Anutuna rusadeesamu iranaki maridee qimasee idi ramasee fiqau.
\q1 
\v 44 Yaaweefa moomoo maqannaasa maqa maaqa Isaraee maqannaasa mara nimisoofaqa misa miqooqaraasa naru nifaqasee misa narana andanda aiqama ainaina neemariqau.
\q1 
\v 45 Yaaweefa sia fifau miqinau.
\q1 Isaraee maqannaasa mina aamuaqira ufa faqa sanda ufa faqa maraaqee qimasee miqinau.
\q1 Innee aiqamausa Yaaweena amooqiaqa.
\c 106
\s1 Anutufa narí faiqí anaasee amiqimma nimaqaidanoo.
\q1 
\v 1 Yaaweenara amooqiaqa.
\q1 Innee Yaaweefa amiqirafa marifanoo mina amuqusirafa naaru naaru marinara mina dufi dufi qimamaqaaqa.
\q1 
\v 2 Yafee moo fannoo mifa firaa ainaina auqoonara amana kooroommasee qiannoo fee.
\q1 Sia moo fannoo amanaikiannoo.
\q1 Yafee moo fannoo mina amana kai amooqirana amiannoo fee.
\q1 Sia moo fannoo amanaikiannoo.
\q1 
\v 3 Mina naamuaqira ufa qaindusi mariasa faqa aiqama kari andeeqara oosana maree mariasa faqa misa asasidaqa.
\q1 
\v 4 Oo Yaawee, anee aneenna maqannaasa dadaaqidana qiniara faqa iria.
\q1 Anee misa mara niseenana qini faqa mara qisaa.
\q1 
\v 5 Miqimasainaqa ani faiqí anaasee ainaina rairaa inaqa qinee kaqi maridaqa qafamaseeqa misa saimbaqa asasidaqa ani aiku asauku mariasa faqa nasu nasuriqa nua.
\q1 
\v 6 Maasa qeeqa qikeeku qikaaku naannaa reeqa aaqara oosana maree marunausa maridaqa.
\q1 Maasa aaqara oosana faqa firaa manda aaqara oosana faqa maree marunausa maridaqa.
\q1 
\v 7 Ooqai anee Anutufa Isipa maqa maaqaki naaquqara ainaina auqamasoonaqa maasa qikeeku qikaaku qafamasee sia ani oosana iriqau.
\q1 Anee misa moomoo kari amuqusamma nimaqoonnanara sia misa minara iriqau, qaunuseeqa misa Taatuqee nammari afaisaa oonuree ani aiqama afeeka faqaanara nimeesa uqusee nári nidiramau fimariqau.
\q1 
\v 8 Yaaweefa narí amudaanai qimaru afeekanara kooroo ianifeera narí qima afeekaikira ufa mau finoo misa ummaarakinaana uqeera nisanau.
\q1 
\v 9 Yaaweefa Taatuqee nammariara qufanoo aadanusinau.
\q1 Aadanusufufanoo mifa misa aana muqunufaqa aadana maqasaa taqaqau.
\q1 
\v 10 Yaaweefa Isaraee maqannaasara fidiaqaa imarusa nisaukukinaana rafiqanau.
\q1 Mifa namuqaa nisaukukinaana maranau.
\q1 
\v 11 Miqimmasoofaqa Taatuqee nammari fannoo misa namuqaa rafaaqafinau.
\q1 Sia moodaa kaqi mariqau, aiqama taikaqau.
\q1 
\v 12 Miqimmasoofaqa Isaraee maqannaasa mina qafamaseeqa Yaaweena qima afeekaikiranara kuqaa fee qimasee mina amooqira idi raqau.
\q1 
\v 13 Miqidaqa misa Yaaweefa auqoo ainainnara kai kaqi auniqau.
\q1 Misa sia mina naakapara ufara afeesiqau.
\q1 Nári iriranamau kai fiqau.
\q1 
\v 14 Oonureeqa misa aadana maqa maaqaki nidaqa nári Isipa maqa maaqai maru narana ainainausara firaaqoo nári nidi maru narannara aiaaee qimariqau.
\q1 Miqidaqa misa firaaqoo Yaaweena akooqara oosanannai amanammasee qafaqau.
\q1 
\v 15 Miqiufanoo Yaaweefa misa amanira osana iriseenoo akooqoofanoo misa qu ainaina eedoo qimasee nimiseenoo manda aurirana namu faqa nimufaqa auri mariqau.
\q1 
\v 16 Misa Isaraee maqannaasa miqoo aadana maqa maaqaki maridaqa Mooseenara rairai qimariqau.
\q1 Misa Aaroonara Yaaweena naaquqara ainainira fasiqara faqa rairai qimariqau.
\q1 
\v 17 Misa miqi qimarufanoo Yaaweefa qufanoo maqa fannoo oo raqafufanoo faiqí moo auqu Datannana nambiqanau.
\q1 Abirammana faqa mina aiku asauku namu faqa nambiqama rafaaqa finau.
\q1 
\v 18 Rafaaqafusoofanoo Yaaweefa qufanoo manda oosana auqee mrusa akaqausa kaqi marusa idauru fannoo misakiaqa fasafasufanoo mi manda fasiqa qanda ufa iri marusa idauru fannoo aiqama qama taikasanau.
\q1 
\v 19 Isaraee maqannaasa Sinai maqa maaqaki oonureeqa koorannai tasirisirimmasee burimakau akoona aanaaqi amana auqiqau.
\q1 Misa mina auqu quqaqaqee Yaaweenara foora amooqimamaqee mariqau.
\q1 
\v 20 Misa Yaaweena amiqira areenarana faqaana mafi nimeesa uquseeqa fifau andanda neemaru ainaina burimakau akoona aanaaqi amana auqirafa marunnai ubeekamafiqa amooqi mariqau.
\q1 
\v 21 Isaraee maqannaasa Isipa maqa maaqaki marufanoo Yaaweefa naaquqara ainaina firaa ainaina auqamaseenoo Isaraee maqannaasa rafioo Anutunara misa qauniqau.
\q1 
\v 22 Misa miqimmasee Isipa maqa maaqaki marufanoo Yaaweefa mookira ainaina firaatia auqamasoofaqa qafaqau.
\q1 Taatuqee nammari aaqa marufanoo Yaaweefa kaifaa naaquqara ainaina auqamasoofaqa misa minara faqa qauniqau.
\q1 
\v 23 Yaaweefa misa manda oosana nindafamaseenoo qinau.
\q1 Qinee misa aiqama kuridi taikasaanauree qinau.
\q1 Mooseefa Anutufa qutaaqamaqoofa maridanoo Yaaweefa arana qoofanoo nariraree qunasaa ititasoofanoo sia narinau.
\q1 
\v 24 Misa aadana maqa maaqaki kaqi maridaqa Isaraee maqanaasa fuka idaaqira maqa maaqara Kannaa maqa maaqaki fifandinnanara fidiaqaammasee Yaaweena qima afeekaikira ufara faqa unna fee qiqau.
\q1 
\v 25 Nári uqiqaana maqakiaqa maridaqa ninunu ridaqa Yaaweena ufa rukiee mariqau.
\q1 
\v 26 Miqufanoo Yaaweefa narí asauku uqeeraseenoo maaqi qimasee qimannimaqanau.
\q1 Qinee qianaqa innee aiqama maa aadana maqa maaqanaki kuqu taikeefaranoo.
\q1 
\v 27 Misa niku nisauku marinausa naru nindaqaaqa ianaqa aanaamurukinai furufariqa moodaa moodaa ifaranoo.
\q1 Qinee aiqama niana maqa maaqakiaqa quqannisaanaqa miqoo kuqifaranoo.
\q1 
\v 28 Isaraee maqannaasa aaqamasee Peeoora maqannaasa unna qira anutuna Baarana amooqi marunaki ootupaqau.
\q1 Peeroora maqannaasa andau tatufirana nári unnaqira anutusa suqasee nimisee naríara faqa akaqana neemarufaqa Isaraee maqannaasa aaqamasee misaki ootupaqau.
\q1 
\v 29 Misa nári manda aaqara oosanannai Yaaweena arana fundakiqau.
\q1 Misa miqi marufanoo Yaaweefa qufanoo misaki manda aurirafa kambiqafufaqa moomoosa kuqi mariqau.
\q1 
\v 30 Miqiqa nufanoo misakiqari faiqí moo andeeqara fasiqa mina auqu Fineeqasafa findifinoo Isaraee maqanaasa manda oosana akiiqara narufanoo mi manda aurirafa taikanau.
\q1 
\v 31 Doo miqooqari Fineeqasanara andeeqara fasiqa fee qiqau, maqee faqa naaru naaru faqa minara andeeqara fasiqee qifaranoo.
\q1 
\v 32 Isaraee maqannaasa Meeriba maqa maaqaki maru nammarinaki maridaqa Yaaweena amanammasee qafaidaqa arana qarana ami mariqau.
\q1 Miqiufanoo Mooseefa misa aaqaranasaa qaraana maraseenoo narí faqa moo aaqarana maranau.
\q1 
\v 33 Isaraee maqannaasa Mooseena qarana fundakufanoo Mooseena ookiqari aaqara ufa kambiqanau.
\q1 
\v 34 Yaaweefa Isaraee maqannaasa qimanniminau.
\q1 Innee Kannaa maqannaasa manda oosana maree mariasa naru taikaaqee qufaqa sia misa miqiqau.
\q1 
\v 35 Misa Yaweena ufa rukiaseeqa sia narirai misa faqa maanaaqa narí ami narí ami idaqa misa saimbaqa moodaanaki kammafi maridaqa misa manda aaqarana faqa mara nári nifaaqai quqee mariqau.
\q1 
\v 36 Anutuna faiqí anaasee unnaqira anutuna amana auquqoonauqa nimooqimannimaqee mariqau.
\q1 Misa miqiqa nidaqa nári ufaanaki ninuka nári nárí mariqau.
\q1 
\v 37 Misa moo manda oosana maraqau.
\q1 Misa nári faiqi namu akoonaiqi faqa manaaqa faqa marasaidaqa Kannaa maqannaasa unnaqira anutusa noorinni munusaida tatufirana suqa nimimariqau.
\q1 
\v 38 Isaraee maqannaasa nári faiqi aanaaqiuqa qikairi nisakadiki sia marusa nariqau.
\q1 Narusoofanoo mi fidikafa fifau teeqinoo mi fuka maqa maaqana putaa inoo maridanoo manda afundi marinau.
\q1 
\v 39 Misa mi oosanna maroo mandoosanafa nári putaa mannimaqee marinau.
\q1 Misa Anutuna uqanna minniseeqa moo unnaqira anutusasaa mundidaqa sia Anutuna uqanna saa mapukusee mariqau.
\q1 
\v 40 Miqunara Yaaweefa narí faiqí aanaaseera arana qoofanoo fidiaqaa uqannamminau.
\q1 
\v 41 Yaaweefa misauqa mareeqee moo maqannaa aaqee marusa nisaukuki quqanau.
\q1 Quqasoofaqa misa namuqaa misasaa manda rakisi rakisinnimaqee mariqau.
\q1 
\v 42 Mi namuqaasa nisaukuki marufaqa misa nariqa uriqararanannai rafaaqafuqoofaqa misa niramundunai ummaaraki mariqau.
\q1 
\v 43 Miqi marufanoo Yaaweefa moomoo kari narí faiqí anaasee ummaarakinaana mareeqee kaqinni quqanau.
\q1 Miqidaqa nariqa kai qimasee Yaaweena naakaparanara aanoo qimasee ititiqau.
\q1 Miqidaqa misa mandainainaki keeqa qaraasaa mafiqau.
\q1 
\v 44 Misa mi mandainainaki maridaqa quandaki Yaaweenara iki raqoofanoo Yaaweefa misa iki irinau.
\q1 Iriseenoo Yaaweefa misa aupuraranaki maruna amiqimmasee irisee niqafeenoo dadaaqinau.
\q1 
\v 45 Niqafamaseenoo misara qimudaoo qimaseenoo narí moodaanaki kira ufara iriseenoo narí firaa amuqusirafa marunara faqa iriseenoo narí aanooqirana minnisanau.
\q1 
\v 46 Yaaweefa misa rumbannimaqee marusa naundura quandasoofaqa qimudaoo qimasee reendeenammasee rakisinnimaqee mariqau.
\q1 
\v 47 Oo Yaawee maasa Anutufa anee maasa ummaara mariranakinaana mara kaqinni quqannisaa.
\q1 Maasa aiqama maqannasa qambaana moodaa moodaa iqa marunnana sooqbaandummeeqee kaifaa qeeqa maqasaa quqaqisaa.
\q1 Miqi mannisainaqa maasa kaifaa ani naaquqara andeeqara auquara maasa dufi dufi qimamaqaaqeera miqimma qimaqaa.
\q1 Maasa ani amooqimamaqaidaqa maasa daundura areenee marinaqa asasianaura.
\q1 
\v 48 Isaraee maqannaasa Anutuna Yaaweena amooqiaqa.
\q1 Maqee faqa naaru naaru faqa mina amooqiaqa.
\q1 Faíqi anaasee aiqama minara kuqaa fee qiaqa.
\q1 Yaaweena amooqiaqa.
\c 107
\ms1 Mina Anaaqiannaa Book 5
\mr Idi Ufa 107–150
\s1 Anutuna amiqira oosana amooqia.
\p 
\v 1 Yaaweefa andeeqarafa marinara mina dufi dufi qima amaqaaqa.
\q1 Mifa maasara amuqusirafa naaru naaru marifa maridanoo.
\q1 
\v 2 Yaaweefa inni namuqaa nisaukuki umaaraki maruna maroosa innee kafaa kafaa dufi dufi qimasee amooqiaqa.
\q1 
\v 3 Mifa inni aanaamuru maqa maaqakinaana nifiqee aninau.
\q1 Suani afu dinni dinni ataaqeendari faqa suani ururee marinnaindari faqa keeqee marinnaindari faqa nifiqee aninau.
\q1 
\v 4 Akaqausa aadana maqa maaqanaki aana sia marunakinai auiaqa nimariqau.
\q1 Misa nariqa marifandinna maqusanara randasee sia paquriqau.
\q1 
\v 5 Misa miqiqa nimarufanoo naarareenoo nammariara nidufaqa misa nári mariranara sia kaqi marianauree qiqau.
\q1 
\v 6 Misa nariqa ummaaraki maridaqa Yaaweena aaraqau.
\q1 Aaroofanoo mifa iriseenoo misa ummaarakinaana mareeqeenoo amiqira qoo uqannisanau.
\q1 
\v 7 Yaaweefa misa andeeqara aatata nifu uqu mareenoo misa mari fandinna maqusanaki quqannisanau.
\q1 
\v 8 Miqi marisa Yaaweena sia taikaaninna amuqusiranara dufi dufi qimamaqaaqa.
\q1 Mifa faiqí sia auqaqaaira ainaina dadaaqinoo auqoonara faqa dufi dufi qimamaqaaqa.
\q1 
\v 9 Mifa nammariara nidimarisa amanaikamma nimaqaseenoo naararee marisa amiqira nara ainainannai nimuaqumma nimaqainara dufi dufi qimamaqaaqa.
\q1 
\v 10 Akaqausa rumbaranaki marufaqa niku nisauku sainnandannai rumbaqoofaqa aupuraidaqa asukunaki firaa ninunuriranaki mariqau.
\q1 
\v 11 Misa aiqama afeeka faqaa Anutuna ufara aanoommasee ititunara faqa mina naamuaqira ufa minnisoonara faqa mi mandainainaki mariqau.
\q1 
\v 12 Misa minaki marufanoo Anutufa firaa kadaapi rirana nimufanoo misa afeeka taikanau.
\q1 Minaki maridaqa misa niku amaki saamu rufanoo sia moo fannoo misa uqeerarafa miqoo marinau.
\q1 
\v 13 Misa mi aupuraranaki maridaqa misa quandafiqa Yaaweena aaroofanoo misa aupurarana kinaana uqeerannisanau.
\q1 
\v 14 Yaaweefa misa niku nisauku rumbara sainnanda rakeemma aanaaqi aanaaqimmaqusee asukunaki faqa firaa ninunuriranaki faqa maruna mareeqee kaaqa qaraqoo quqannisanau.
\q1 
\v 15 Miqi marisa Yaaweena sia taikaaninna amuqusiranara dufi dufi qimamaqaaqa.
\q1 Mifa faiqí sia auqaaqaaira ainaina auqoonara faqa dufi dufi qimamaqaaqa.
\q1 
\v 16 Yaaweefa namuqaauqa karabusa kooqiuqa koopaannai auqira kooqiuqa rakeemmasee qainnannai auqira kairi kooqi ititee maruna qumaree itairi andaanandaana rumuqusanau.
\q1 
\v 17 Akaqausa nári ufa rukiqaranannai aupuraidaqa furufarirausaikiqa mariqau.
\q1 Nariqa aaqarana akiiqara mi aupuraranaki mariqau.
\q1 
\v 18 Misa mi aupuraranaki maridaqa nikoo nikaaidaqa narana faqa sia neemariqau.
\q1 Misa miqidaqa kuqirana afaisaa mariqau.
\q1 
\v 19 Misa miqiqa maridaqa nári aupuraranakiqari Yaaweena aaramasaidaqa innaaru qimariqau.
\q1 Miqi qimarufanoo Yaaweefa nariqa aupuraranakinaana uqeereeqee amiqiraqoo quqannisanau.
\q1 
\v 20 Mifa narí ufannai misa aurirana taikannimaqanau.
\q1 Mifa madika afaisaaqaraana uqeereeqee kaqini quqannisanau.
\q1 
\v 21 Miqi marisa Yaweena sia taikaaninna amuqusiranara dufi dufi qimamaqaaqa. Mifa faiqí sia auqaaqaa ira ainaina dadaaqinoo auqoonara faqa dufi dufi qimamaqaaqa.
\q1 
\v 22 Miqidaqa misa Yaaweenara dufi dufi qira aandau tatufirana suqa amiaqa.
\q1 Amiseeqa misa asasira idinnai Yaaweefa amiqira ainaina auqoonara aiqamausa qimannimiaqa.
\q1 
\v 23 Doo akaqausa sipaki ooruku nammari amuaqumau nidaqa aanaiqiara foora nidaqa ainaina munu nimi mini nimi idaqa feefauru maree mariqau.
\q1 
\v 24 Misa ooruku nammari farumaki fidaqa Yaaweefa faiqí sia auqaaqaa ira ainaina auqamaqoona qafaqau.
\q1 
\v 25 Yaaweefa qufanoo ufai firaafa aniree uqufanoo nammari amakau rinoo aaqanara foora inau.
\q1 
\v 26 Amakaura firaaqoo idanoo misa sipa uqeera innaarunai seenoo muqufi maqai rumaseenoo imarinau.
\q1 Miqi marufaqa minaki marusa misa paasoosirafa taikafufaqa naaquqeenoo naindiriranau.
\q1 
\v 27 Misa sipa teeqi taaqufaqa minakinaasa firara munari minari idaqa nammari namaqaaqee furufari mariasa naannaree mariqau.
\q1 Misa miqiqa nufanoo misa sipa akoofasaikirafa sia nimanaikufaqa furufariqau.
\q1 
\v 28 Misa miqiqa maridaqa nári aupuraranakiqari Yaaweena aaramasaidaqa innaaru qimariqau.
\q1 Miqi qimarufanoo Yaaweefa nariqa aupuraranakinaana uqeereeqeenoo amiqiraqoo quqannisanau.
\q1 
\v 29 Yaaweefa amakauriranara qaoo qufanoo daimafinau.
\q1 Firaa amakaura rirafa taikafufanoo reendeeninau.
\q1 
\v 30 Ooruku nammari fannoo kasoo inoo dai qimafufaqa sipaki mariusa nimuqusa uqbiqafufaqa asasiqau.
\q1 Miqi marufanoo Yaaweefa misa mareeqeenoo nári fuanee qunnai ubeekamasoofaqa fiqau.
\q1 
\v 31 Miqi marisa Yaaweena sia taikaaninna amuqusiranara dufi fufi qimamaqaaqa.
\q1 Mifa faiqí sia auqaaqaa ira ainaina dadaaqinoo auqoonara faqa dufi dufi qimamaqaaqa.
\q1 
\v 32 Misa faiqí suqiranaki maridaqa Yaaweena uriqararanara kooroo iaqa.
\q1 Faiqí rakisirausa suqinnanaki mina faqa amooqiaqa.
\q1 
\v 33 Yaaweefa qufanoo nammari amiqimmasee aadanusinau.
\q1 Kaqikaa nammariuqa faqa maqakiqari ururee marifauqa faqa tukaqnanau.
\q1 
\v 34 Mi maqa maaqanaki mariusa mandoosana akiiqara Yaaweefa misa maqa ainoo faqaana kafaa mara indiri maqaika masanau.
\q1 
\v 35 Kafaa Yaaweefa aadana maqa maaqa mareeqeenoo nammari namu faqa uqeena uqeenira maqaikinau.
\q1 Mifa aadana maqa maaqa mareeqeenoo nammari aanaaqi aanaaqi moomoo qumi maru maqanaikinau.
\q1 
\v 36 Miqiufanoo Yaaweefa naranara sarauimarusa nifieeqeenoo miqoo uqannisanau.
\q1 Misa miqoo maridaqa maqusa indufusee miqoo mariqau.
\q1 
\v 37 Misa miqoo maridaqa oosana oosana narainaina faqa wainna sanda faqa ummaqimariqau.
\q1 Ummaqusoofanoo aiqama narainaina fannoo kambiqeenoo, rairaa rairaa inoo didisamu rimarinau.
\q1 
\v 38 Yaaweefa mi fasiqa anaaseesa narí aiku asauku amiqi amiqimma nimaqoofaqa misa miqoo moomoo kambiqeeqa aramaree fimariqau.
\q1 Misa firinee maru aandausa mifa dadaaqufanoo sia oodaa mariqau.
\q1 Misa faqa moomoo kambiqeeqa aramaree fimariqau.
\q1 
\v 39 Misa miqi marufaqa namuqaa manda fitiqnarana nimufaqa firaaqoo aupuraqau.
\q1 Miqimmasee Yaaweena faiqí anaasee rafaaqafusee nisaurirana nimiqau.
\q1 
\v 40 Yaaweefa misa rafaaqafu nimaqee marusara fidiaqaammaseenoo misa aadana maqa maaqakinai aana sia marunnai aqusoofaqa nimariqau.
\q1 
\v 41 Mifa narí aiku asauku ainainara sarau imarusa nári noori runiranakinaana uqeereeqee amiqira qoo quqannisanau.
\q1 Kaifaa misa faiqi namu kambiqeeqa sipsipara foora moomoo kambiqafi aramaree fiqau.
\q1 
\v 42 Andeeqara oosana maree marusa mina qafamasee asasufaqa manda oosana maree marusa mina qafamaseeqa noo qumunamasee mariqau.
\q1 
\v 43 Naaqoo fainausa Yaaweena mi oosanna qafamasee amiqimasee iriaqa.
\q1 Yaaweena naaru marira amuqusiranara oonumafi iriaqa.
\c 108
\s1 Namuqaa sia dadaaqiani fee innaaru.
\q1 
\v 1 Oo Anutu qini qimuqusa aiqama anisaa mapukusee mundinoo maridanoo.
\q1 Minara qinee idi raidaqa ani amooqianaura.
\q1 Qini qimana anee findifua.
\q1 
\v 2 Qini piripunna faqa ufireena faqa findi fifaqa inniqarannai suani afu ooqu findifumaisaanaura.
\q1 
\v 3 Oo Yaawee qinee aanaamurukiaqa ani dufi dufi qimamaqaanauranoo.
\q1 Qinee faiqí anaasee qambaanai ani amooqianaura.
\q1 
\v 4 Ani aiqama kari amuqusirafa inaaruna ooraaqaranoo maridanoo.
\q1 Ani mapukusee marira oosana fannoo qasuru ooru auqanoo maridanoo.
\q1 
\v 5 Oo Anutu, aneenna uriqararana innaarunaki uqannifiqainaqa maasa qafa.
\q1 Aneenna areenarana aiqama maqa maaqaki quqasainaqa qafaaqa.
\q1 
\v 6 Oo Yaawee qini innaaru qirana irisee aneenna afeekannai maasa asumu maraqisaa.
\q1 Miqimmaseenana ani aidi maria fasiqa aanaaseesa mandainaina kinaana asumu mariaqeera maraa.
\q1 
\v 7 Anutufa narí naaquqara uiqaana maqakiqari maaqi qinau.
\q1 Qinee ufoona ridaqa Seekeemma maqa maaqa rainasee qeeqa maqannaasa nimianaura.
\q1 Qinee Sukoota noopundu faqa miqi kai iqa qeeqa maqannaasa rainasee nimianaura.
\q1 
\v 8 Gireeadana maqa maaqa faqa Mannaseena maqa maaqa faqa qiqaindi maridanoo.
\q1 Eefaraimmana maqa maaqa faqa qeeqa qikiiqa itita qimaqee mari ainaina fara foora maridanoo.
\q1 Yuda maqa maaqa fannoo qini uriqararausara uqannifiqee mari saunu fara foora maridanoo.
\q1 
\v 9 Qinee Anutusa Mooaba maqa maaqa mareeqee qeeqa qiku nammari uqi marunna difaaniara foora masee ooru dupimma nisaanaura.
\q1 Qinee Eedooma maqa maaqa qiku aanaamu raipaqu quqee marunna maqa maaqafa ooreeqarafa mariannoo.
\q1 Qinee Firistia maqannaasa urinnaaqaramasee faaqa rumasee ufoona ruanaura.
\q1 
\v 10 Oo Anutu, yafee qini aana muquninaqee Eedooma maqannaasa afeeka faandaamuraki keeqafi naruanauree.
\q1 
\v 11 Oo Anutu kuqaa fee anee maasa ameesa uquqiseenanee.
\q1 Anee sia fee ooqai unnandee inana maasa rakira fasiqauqa faqa oonuree dadaaqinnaree.
\q1 
\v 12 Anee maasa dadaaqinaqa maasa nári namuqaa narua.
\q1 Faiqí faiqi dadaaqirafa sia amanaikiannoo.
\q1 
\v 13 Oo Anutu anee maasa dadaaqinaqa rakiranaki fuanana aneenna kai maasa namuqaa rafaaqafu nimaqaa.
\c 109
\s1 Ummaaraki maru fasiqana anunurira ufa.
\q1 
\v 1 Oo Yaawee, qinee ani amooqi marunafa mariananoo anee sia kaqi muqurina maria.
\q1 
\v 2 Manda oosana maree maria fasiqausa faqa nikaru qimaria fasiqausa faqa qini namuqakamma qiaidaqa.
\q1 Misa qiniara unna ufa qimariasa maridaqa.
\q1 
\v 3 Misa qini fidiaqaamma qimaqee maria ufanannai qiniara qidaqa.
\q1 Misa sia oosana marifaqa kaqi fifau qini namuqaakamma qimaqaidaqa.
\q1 
\v 4 Qinee misara rimarunnana akiiqara misa fifau qini qifairidaqa.
\q1 Qinee misara innaaru qimarunaqa misa sia minara iridaqa kaqi qifairidaqa.
\q1 
\v 5 Qinee misa amiqi amiqimma nimaqee marunnana akiiqara misa manda oosana qini qimidammia.
\q1 Qinee misara didi marina akiiqara qini fidiaqaamma qimaqaidaqa.
\q1 
\v 6 Oo Yaawee aaqee mari siaasana utaaqamasainanoo qini namuqaa koota amiani.
\q1 Anee qinanoo mina moo namuqaa fannoo mina kikiqa usuani.
\q1 
\v 7 Mi kootanaki mi fasiqanara aaqee mari fasiqafee qiaqanani.
\q1 Mi manda fasiqana innaaru qiranara faqa aaqara oosana fee qiaqanani.
\q1 
\v 8 Mi manda fasiqana marirafa qusasaa taikainanoo moo fannoo mina amaaqa maqafinoo mina saika maraani.
\q1 
\v 9 Mi fasiqana faiqi namu fiaiqi marifanoo mina anaaqa faqa adeedaana mariani.
\q1 
\v 10 Mina faiqi namu maaqa siaisa naranara aiqama maaqakiaqa innaarumma naqanuasa mariaqanani.
\q1 Misa miqiqa nidaqa ooqeennaa naakunduki rambairira maaqaki mariana, nifaqasaifaqa fifuaqanani.
\q1 
\v 11 Mi manda fasiqafa ufaase munnimma marasee mariufa kuqufinanoo ufaasu munnimma amu fasiqafa anireenoo mina ainaina aiqama nariara maraani.
\q1 Moo maqannaasa anireeqa mifa kadaapi ririqoo ainainna náriara maraaqanani.
\q1 
\v 12 Sia moo fannoo mi manda fasiqanara amuqusiani.
\q1 Sia moo fannoo mina fiaiqi faiqiara amuqusiani.
\q1 
\v 13 Saifaqa mina faiqi namu anaiqiqmara aiqama kuquaqanani.
\q1 Akaqausa faqa sia mina auquara iriaqanani.
\q1 
\v 14 Mi manda fasiqana akeeku akaaku manda oosanara Yaaweefa oonumafi iriani.
\q1 Mi manda fasiqana maqoo aanaaseena aaqarana akiiqara naaru naaru sia minnaisaani.
\q1 
\v 15 Mi manda fasiqana akeeku akaaku aaqarana akiiqara Yaaweefa aiqama kari iriani.
\q1 Aiqamausa misara qaunuqanna saaqanani.
\q1 
\v 16 Mi manda fasiqafa faiqí anaaseera qimudaoo ira irirafa sia mina iriranaki maridanoo.
\q1 Mifa ainaina siaisa faqa sarau imariasa faqa naundura ummaara reemarisa faqa oosana oosana ummaara niminoo kuqa narinau.
\q1 
\v 17 Mi manda fasiqafa niqurara ufa qiranara kai aidimarifa marinara anee mina akiiqara aqurara ufa kai amia.
\q1 Mi manda fasiqafa amiqi amiqimma nimaqaranara fidiaqaa imarinara sia moo fannoo mina amiqi amiqimma amaqaaqanani.
\q1 
\v 18 Mi manda fasiqafa niqurara ufa afaaqa quqasee qamunnara foora afisirafa nidanoo.
\q1 Mina narí niqurara ufa fannoo narí nammari naindee inoo nariki kai keeqaani.
\q1 Mina niqurara ufa fadameenara foora nifaaqasaa akusaafanoo keeqaindee narí mi manda fasiqanaki keeqaani.
\q1 
\v 19 Mi manda fasiqana niqurara ufa fannoo oonurandeenoo qamunnara foora narikai kukuqinoo mariani.
\q1 Pikapara foora mina niqurara ufa fannoo aiqama kari narí kai rumbamaqanoo mariani.
\q1 
\v 20 Oo Yaaweefa qini namuqaa miqimmasee aupurarana nimia.
\q1 Mi namuqaasa qiniara manda ufa qimariasa aupurarana nimia.
\q1 
\v 21 Oo uriqarara Yaaweefa aneenna qima afeekaikiranara iriseenana qini dadaaqia.
\q1 Aneenna sia taikaaninna amiqira amuqusiranannai qini namuqaa nisaukukinaana mara aquqisaa.
\q1 
\v 22 Qinee Dafidisa ainaina siaisa sarau irausa maridaqa.
\q1 Qini qimuqusaki dariara foora aupuraidaqa.
\q1 
\v 23 Suani afu keeqaifanoo qini qimananda taikaindee inoo qini marirafa taikararamidanoo.
\q1 Qini marirana aammaadiara foora ufai fuaqa aqindee qusasaa taikararidaqa.
\q1 
\v 24 Narana sia naunnanara qini qikuqara indindidanoo doori ummooqukidanoo.
\q1 Qinee qifaaqa asaqinoo marifaqa qimudaani aanaaqi maridaqa.
\q1 
\v 25 Faiqí anaasee qini qiqafamasee uteeti naakada qidaqa.
\q1 Misa qini qiqafaidaqa ninuka aqidaqa ataasataasa qidaqa.
\q1 
\v 26 Oo Yaawee qini Anutufa anee qini dadaaqammaqisa.
\q1 An i sia taikaaninna amuqusirafa marinara qini mareeqee asumu mariranaki quqaqisaa.
\q1 
\v 27 Oo Yaawee anee miqinaqa qini namuqaa iriqa ani Yaaweenara qini dadaaqidanoommifoo qimasee iriaqa.
\q1 
\v 28 Qini namuqaauqa qini diqurara ufa qimifana anee amiqi amiqimma qimaqeennaranoo.
\q1 Qini aupurarana qimimariasa anee misa rafaaqafu nimaqaa.
\q1 Miqimmasainaqa qinee ani ainainira faiqi asasianauranoo.
\q1 
\v 29 Qini namuqaa nisaurirana dukunimma nimaqaa.
\q1 Misa nisaurirana qamunnara foora kukuqiaqanani.
\q1 
\v 30 Qinee Dafidisa qeeqa dookiqari Yaweenara firaaqoo dufi dufi qianaura.
\q1 Faiqí moomoosa suqi marinnanaki mina amooqimamaqaanaura.
\q1 
\v 31 Yaaweefa mifa ainaina siaina itita amaqaseenoo mina kuqa arirari mariasa nisaukukinaana marainara dufi dufi qianaura.
\c 110
\s1 Yaaweefa faqa mifa utaaqamaqoo karaambaiqafa Dafidifa faqa.
\q1 
\v 1 Yaaweefa maaqi qimasee qini karaambaiqa qimaminau.
\q1 Anee qini daaqa qisauku uqannai ooqu mari finaqa qinee ani namuqaauqa mareeqeeqa ani aramandunnai quqasaanaura.
\q1 
\v 2 Yaaweefa ani urinnaqarara rakisirana Sioona maqusasaaqari firaanaikamasainana aiqamatinai rakisi nimaqeennaranoo.
\q1 Mifa qinoo anee aneenna namuqaauqa faqa rakisi nimaqeennaranoo.
\q1 
\v 3 Anee nammeera qimasee namuqaa faqa rakuanauree qinaqa ani rakira fasiqauqa ani ufara eedoo qimasee afeekaikammasee rakifaranoo.
\q1 Kananaana suani oosana qaannaindari ani kumaaraauqa sia kasoo, qifi faramu andandasaa mandinoo marindee moomoo aaqana uqasaa suqifaranoo.
\q1 
\v 4 Yaaweefa qini karaambaiqara (Yisunara) qima afeekaikuna sia amana kaifaa moosaa fuannoo.
\q1 Mifa maaqi qimaseenoo qima afeekaikinau.
\q1 Anee naaruara naaruara aanaiqikirafa marinnaranoo.
\q1 Anee Meerakiseedeekafara foora maridana naaru naaru aanaiqikina marinnaranoo fee qinau.
\q1 
\v 5 Qini karaambaiqa Yaaweena asauku uqannai maridanoo, mifa aanoo qinanoo maqasaa karaambaiqauqa urinnaaqa raannoo.
\q1 
\v 6 Mifa maa maqanasaaqaraasa urinnaaqaramasee moomoo narueeqaida quqaannoo.
\q1 Mifa aiqama maa maqanasaa uriqararausa rafaaqafuannoo.
\q1 
\v 7 Mifa rakiranaki maridanoo kaqikaa nammari aana afainni qumi marina namasee rakiranaki afeekaikamasee urinaaqaraannoo.
\c 111
\s1 Yaaweena amooqia.
\q1 
\v 1 Yaaweena amooqiaqa.
\q1 Qinee qeeqa qimuqusannai mina faiqí anaasee suqiranaki Yaaweenara dufi dufi qianaura.
\q1 
\v 2 Yaaweefa auqoo ainainausa naaquqarafa maridanoo.
\q1 Mifa auquqoo ainainausa qafamasee asasi mariasa mi ainainausa oosanara iriraree qidaqa.
\q1 
\v 3 Aiqama ainaina Yaaweefa auqoo ainainafa areenarafa faqa uriqarara amiqi amiqirafa faqa kai maridanoo.
\q1 Mina andeeqarafa naaru naaru marifa maridanoo.
\q1 
\v 4 Yaaweefa narí naaquqara ainaina auqamasee maasara sia qaunuaqee qidanoo.
\q1 Mifa paapaa idanoo nifauee marifa maridanoo.
\q1 
\v 5 Yaaweenara qeerairida mina ufa qaindusi mariasa mifa narana nimidanoo.
\q1 Mifa narí moodaanaki kira ufa sia qauni marifa naaruara irimarifa maridanoo.
\q1 
\v 6 Mifa anaamuru maqa maaqa narí faiqí anaasee nimiranannai narí afeeka uqannifiqanau.
\q1 
\v 7 Mina aiqama ainaina auqaranaki mifa narí mapukira oosana faqa Yaaweefa narí asaukunnai auqai ainainafa mapukirafa faqa aindeeqarafa amana amana kai rainara oosana faqaafa maridanoo.
\q1 Mina aiqama naamuaqira ufa fannoo anoona ufa faiqí minasaa mundufi mariaqee ufa maridanoo.
\q1 
\v 8 Mi naamuaqira ufausa anoona ufa qiranasaa faqa andeeqara mariranasaa faqa mundinoo maridanoo, naaru naaru afeekaikinoo mariannoo.
\q1 
\v 9 Yaaweefa narí faiqí anaasee rumbararakinaana idukuseenoo naaru marira moodaanaki kira ufa misa faqa qinau.
\q1 Kaaqa naaquqara andeeqarafa faqa uriqarara afeeka faqaafa faqa marifa maridanoo.
\q1 
\v 10 Irirana faqaafa mariraree qimaseenana Yaaweenara eerairida mina ufa qaindusua.
\q1 Mina naamuaqira ufara eedoo qimasee mi mau fimariasa mifa andeeqasee rainara oosana nimidanoo.
\q1 Naaru naaru amooqirafa minaindi mariani.
\c 112
\s1 Andeeqara fasiqa anaasee asasirafa.
\q1 
\v 1 Yaaweena amooqiaqa.
\q1 Yaaweenara eerairammasee mina ufamau fimarifa faqa mina sandufara asasammasee afaqee marifa faqa asasiranaki maridanoo.
\q1 
\v 2 Andeeqara fasiqa faiqi namu nariqa maqa maaqaki nimudaanai qimarinausa marifaranoo.
\q1 Minasaa aruakinausa amiqi amiqiranaki marifaranoo.
\q1 
\v 3 Mi andeeqara fasiqana faiqi namu ainaina faqaasa arifaranoo.
\q1 Mina ainaina faqa naaruara rairaammida mariannoo.
\q1 
\v 4 Andeeqarausa faqa nifauee mariasa faqa qimudaoo qimariasa faqa asukunaki kaaqa qaranakiara foora miqi mariasa maridaqa.
\q1 
\v 5 Eedoo qimasee ufaasu munnimma nimimarifa faqa narí bisinisa kuqaa qira irirana mau kai auqee mari fasiqafa faqa asasiranaki maridanoo.
\q1 
\v 6 Andeeqee marifa sia kuridiannoo.
\q1 Faiqí anaasee minara naaruara irifaranoo.
\q1 
\v 7 Mi andeeqara fasiqafa manda ufauqaindi irinoo sia rufiannoo.
\q1 Mifa Yaaweena saqarikirafa afeekaikinoo marinara sia rufiaannoo.
\q1 
\v 8 Miqi marifa sia kaaqa amuqusifanoo rufiaidanoo.
\q1 Mifa mariinoo narí namuqaa rafaaqafu nimaqainnana qafaannoo.
\q1 
\v 9 Mi andeeqara fasiqafa afaaridanoo sarauimariasa nimidanoo.
\q1 Mina qimudaoo qirafa sia taikaannoo mi fasiqafa afeeka faqaafa marinaqa mina ufa ameemaanai keeqee faranoo.
\q1 
\v 10 Miqi marifaqa manda oosana maree mariasa mina qafaafanoo niranaqaidanoo.
\q1 Misa noori kandamasee fidiaqaamma amaqasee quqasee fidaqa.
\q1 Manda oosana maree mariasa misa mi andeeqara fasiqana andaikamma amaqarara tipundarimariafa naaruara taikafuannoo.
\c 113
\s1 Anutuna andeeqara oosanara amooqia.
\q1 
\v 1 Yaaweena amooqiaqa.
\q1 Innee Yaaweena ainainira faiqiuqa mina amooqiaqa.
\q1 Yaaweena auqu amooqiaqa.
\q1 
\v 2 Maqee faqa naaru naaru faqa Yaaweena auqu amooqirafa kai mariani.
\q1 
\v 3 Suani ururee marinnai mariasa faqa suani keeqee marinnai mariasa faqa aiqamausa Yaaweena auqu amooqimamaqaaqa.
\q1 
\v 4 Mifa Yaaweefa aiqama maa maqa maaqanaki mariasa urinnaaqaranoo maridanoo rakisi nimaqaidanoo, mina qareenarafa innaaruna uriaaqaranoo maridanoo.
\q1 
\v 5 Sia moo fannoo Yaaweena maasa Anutuna fooqaafa maridanoo.
\q1 Mifa meerai innaaruna uraaqaranoo maridanoo.
\q1 
\v 6 Miqooqari mifa mara miami innaaruna faqa maqa faqa qafaidanoo.
\q1 
\v 7 Yaaweefa ainaina siaisa nikuqara madaanai marisa uqeereeqeenoo amiqiraqoo quqannisaidanoo.
\q1 Mifa sarau imariasa nári aupuraranakinaana uqeerannisaidanoo.
\q1 
\v 8 Uqeeraseenoo misa mareeqee uriqararausa faiqi namu aqoondikamma nimaqaidanoo.
\q1 Uqeerasaifaqa Yaaweena faiqi anaasee (Isaraee maqannaasa) uriqararausa misa aqoondi kidaqa.
\q1 
\v 9 Aafaikinoo marinna anaaseena Yaaweefa amiqimma amaqaseenoo.
\q1 Faiqi aanaaqi aranandaki rumasaifanoo minara asasidanoo.
\q1 Yaaweena amooqiaqa.
\c 114
\s1 Ainnaaqarara qoomaqa suqa naidaqa ree maru idifa.
\q1 
\v 1 Isaraee maqannaasa Yakooboona akeeku akaaku aanaamuru maqa maaqa Isipa maqa maaqakiqari quqasee aniqau.
\q1 
\v 2 Miqiqa ani marufanoo Yudana akeeku akaaku Yaaweena naaquqara fasiqa anaasee kammiqa mariqau.
\q1 Isaraee maqannaasa Yaaweenaindi kammiqa mariqau.
\q1 
\v 3 Yaaweenaindi kiqa marufanoo Taatuqee Nammari misa nindafamasee quqasee sandanau.
\q1 Yooradanna nammari faqa misa nindafeenoo kasooinau.
\q1 
\v 4 Maqa kasufanoo aaqanauqa faqa mimmi aanaaqiara foora kooripoo kooripoo imariqau.
\q1 Kaqikaa amuaqu namuqaindi faqa sipsipa aanaaqiuqara maqi rafusaki rafusaki imariqau.
\q1 
\v 5 Oo maa Taatuqee nammari naqaa fee ifanee quqasee sandeenanee.
\q1 Oo Yooradanna nammari anee faqa naqaa fee ifanee kasoo inanee.
\q1 
\v 6 Oo aaqana namuqa naqaa fee ifaqee mimmi anaaqiara foora kooripoo kooripoo ifee.
\q1 Oo amuaqunamuqaindi innee faqa naqaa fee ifaqee sipsipa aanaaqiara foora rafusaki rafusaki ifee.
\q1 
\v 7 Maa maqa maaqafa mina quqoofa qumiranara aindiri raani.
\q1 Yakooboona Anutufa qumu marinara aindiri aindiri raani.
\q1 
\v 8 Mi Anutufa ooniara qufanoo quandaki nammari farumaikinau.
\q1 Mifa qufanoo afeeka ooniuqa aanaaqi nammariuqa kammafi qumi mariqau.
\c 115
\s1 Anutufa kai kuqaa qirafa.
\q1 
\v 1 Oo Yaawee sia maasa duqusaa qareenarafa mariani.
\q1 Ani auqusaa kai qareenarafa marani.
\q1 Ani sia taikaanina amuqusirafa faqa ani mapukusee marira oosana faqa marinara qareenarafa ani auqusaa mariani.
\q1 
\v 2 Aiqama maqannaasa nanaree maasara inni Anutufa yaifee maridanoo fee qimasee iraidee.
\q1 
\v 3 Maasa Anutufa innaarunai maridanoo.
\q1 Mifa narí aidiramau fidanoo narí aidi ainanna auqaidanoo.
\q1 
\v 4 Misa aiqama anaamuru mariasa unnaqira anutusa faiqí faiqi nisaukunnai koora faqa siruaannoo faqa auquqaafa maridanoo.
\q1 
\v 5 Misa noo aamara marifaqa sia ufa qidaqa.
\q1 Misa nifu faqa marifaqa sia qafaidaqa.
\q1 
\v 6 Misa naaqoo faqa marifaqa sia ufa iridaqa.
\q1 Misa naikaamara faqa marifaqa sia udi ramasee qafaidaqa.
\q1 
\v 7 Misa nisauku faqa marifaqa sia auqama qafaidaqa.
\q1 Misa niku faqa marifaqa sia nidaqa, sia kasi kasidaqa.
\q1 Misa nisananda faqa marifaqa minakiqari sia ufa qidammia.
\q1 
\v 8 Mi ainainausa auqusee mina saqariki mariasa nariqa sia kasi mari anutuna aannaraqa mariaqanani.
\q1 
\v 9 Oo Isaraee maqannaasa innee Yaaweena mandaaqaaqa.
\q1 Mifa inni dadaaqinoo itita nimaqaidanoo.
\q1 
\v 10 Oo Isaree maqannaa aanaiqikirausa nikeeku nikaaku mariasa innee Yaaweena mandaaqaaqa.
\q1 Mifa dadaaqinoo itita nimaqaidanoo.
\q1 
\v 11 Aiqama innee Yaweena amooqi mariasa mina saqarikiaqa.
\q1 Mifa inni dadaaqinoo itita nimaqaidanoo.
\q1 
\v 12 Yaaweefa maasara iridanoo amiqi amiqimma qimaqaannoo.
\q1 Mifa Isaraee maqannaasa amiqi amiqimma niseennoo.
\q1 Kafaa mifa aiqama narí aanaiqikirausa faqa amiqi amiqimma nimaqaannoo.
\q1 
\v 13 Yaaweenara naaquqaifaqa mina ufa ameemaanai keeqee mariasa mifa amiqi amiqimma nimaqaannoo.
\q1 Mifa uriqararausa faqa oorudupirausa faqa amana amana kai amiqi amiqimma nimaqaannoo.
\q1 
\v 14 Yaaweefa ani faqa ani akeeku akaaku faqa faiqi asumu nimiani.
\q1 
\v 15 Yaaweefa maa maqa maaqana faqa innaarunna faqa auqu quqaqoofa mifa inni amiqi amiqimma nimaqaani.
\q1 
\v 16 Innaaruna Yaaweenaindi kai maridanoo.
\q1 Maa maaqana Yaaweefa faiqí faiqnimufa maridanoo.
\q1 
\v 17 Kuqufuasa sia Yaaweena amooqidammia.
\q1 Ufa taikafifaqa madikaki kuqiqa mariasa sia Yaaweena amooqidaqa.
\q1 
\v 18 Maasa kaqi marunausa Yaaweena dufi dufi qimamaqaanaura.
\q1 Maqee faqa naaru naaru faqa miqianaura.
\q1 Yaaweena amooqiaqa.
\c 116
\s1 Kuqiranakinaana mara asumu quqasoofa Anutuna amooqinau.
\q1 
\v 1 Yaaweefa qini innaaru qirana iri marinara qinee minara ridaqa.
\q1 
\v 2 Mifa qini ufa aaqoo rammatinimmasee irimarinara qinee kaqi marunna kamu minara innaaru qianaura.
\q1 
\v 3 Kuqirafa qini fiqu fiqumma datinoo marinau.
\q1 Kuqiranara rufiarafa qini qumara kuqiranaki quqararinau.
\q1 Qini rufiarafa faqa qinunurirafa faqa qumbiqanoo marinau.
\q1 
\v 4 Qinee miqiqa maridaqa Yaaweena qeeqa qimuqusiranakiqari maaqi qimasee innaarukiqari qimamiqiafana.
\q1 Oo Yaawee anee qini asumu mara quqaannee qidaqa.
\q1 
\v 5 Yaaweefa mifa nifauara oosana faqaafa faqa andeeqara oosana faqaafa faqa maridanoo.
\q1 Maasa Anutufa faiqí faiqiara amuqusirafa qumbiqanoo marifa maridanoo.
\q1 
\v 6 Soodaa qirausa siaisa Yaaweefa ititannimaqaidanoo.
\q1 Qinee kuquaqaa ira ummaaraki marunanoo Yaaweefa qini mareeqee amiqiraqoo quqaqiseenoo.
\q1 
\v 7 Yaaweefa qini amiqimma qimaqainara qini qimuqusa anee kafaa paasoosida afaaqa quqasee maria.
\q1 
\v 8 Yaaweefa qini kuqiranakinaana kaqinni mara quqaqiseenoo qini daukunu aadanusu qimaqaseenoo qini rafaaqafu qimaqarariana ititaqimaqeenoo.
\q1 
\v 9 Miqimmasainara qini aiqama marirafa maa maqanasaaqaraasaki mariasa faqa maridaqa Yaaweena afusaa kai maridaqa.
\q1 
\v 10 Qinee qeeqara namuqaa kaaqa qini radamuseeaafoo qimasee kaqi kai Yaaweena saqarikidaqa.
\q1 
\v 11 Qinee qeeqa rufiaranakiqari maridaqa maaqi qiqa.
\q1 Sia faiqí faiqi moo saqariki mariafa maridanoo.
\q1 
\v 12 Yaaweefa qini amiqimma qimaqaina akiiqara nana ainainee amianauree.
\q1 
\v 13 Yaaweefa qini asumu marainara dufi dufi qimamaqara wainna nammari tatufiranara foora amianaura.
\q1 
\v 14 Mina faiqí anaasee suqirana qambaana qinee amiraree qimasee qima afeekai kammaqaafannana amianaura.
\q1 
\v 15 Yaaweena ufamau fimariasa kuquafanoo Yaaweefa firaaqoo aiaaeeqidanoo.
\q1 
\v 16 Oo Yaawee qinee ani ainainira faiqi maridaqa.
\q1 Qinee qini qinoofa undee kai iqa ani ainainira faiqi maridaqa.
\q1 Anee qini kuqiranaki quqaqoona mara qisoonafa mariananoo.
\q1 
\v 17 Qinee dufi dufi qirana faqa qeeqa innaaru qirana faqa aandau tatufiranara foora amianaura.
\q1 
\v 18-19 Ani faiqí anaasee nifusaa ani naaquqara maaqa maqusasaa Yeerusaree maqusa qambaanai Yaaweena amirara qima afeekaikiafanna ainaina amianaura.
\q1 Yaaweena amooqiaqa.
\c 117
\s1 Yaaweena amooqia.
\q1 
\v 1 Innee aiqama maqannaasa Yaaweena amooqiaqa.
\q1 Innee aiqama fasiqa anaasee mina amooqiaqa.
\q1 
\v 2 Mina maasara aidirafa afeekaikinoo maridanoo.
\q1 Mina mapukusee marira oosana naaru naaru marifa maridanoo.
\q1 Yaaweena amooqiaqa.
\c 118
\s1 Rakirana uriaaqaroonara dufi dufi qira innaaru.
\q1 
\v 1 Yaaweefa andeeqarafa marinara mina dufi dufi qimamaqaaqa.
\q1 Mina faiqí aanaaseera aidirafa naaru naaru marifa maridanoo.
\q1 
\v 2 Isaraee maqannaasa maaqi qiaqa.
\q1 Yaaweena faiqí aanaaseera aidirafa naaru naaru marifa maridanoo.
\q1 
\v 3 Anutuna aanaiqikirausa mariasa maaqi qiaqa.
\q1 Yaaweena faiqí aanaaseera aidirafa naaru naaru marifa maridanoo.
\q1 
\v 4 Aiqama mina amooqimariasa maaqi qiaqa.
\q1 Yaaweena faiqí aanaaseera aidirafa naaru naaru marifa maridanoo.
\q1 
\v 5 Qeeqa teerookiqari Yaaweena aaraafananoo mifa iriseenoo qini oosana oosana teerookinaana idukuqisanau.
\q1 
\v 6 Yaaweefa qini faqa marinara sia qinee rufiaanaura.
\q1 Moo fannoo sia amana mandaikamma qimaqaannoo.
\q1 
\v 7 Yaaweefa dadaaqi marifa marinara qinee Yaaweefa qini namuqaauqa rafaaqafu nimaqee marina qafaanaura.
\q1 
\v 8 Yaaweena saqarikirafa amiqirafa uriqarafa maridanoo.
\q1 Faiqí faiqisaa mundirafa ureeqanoo maridanoo.
\q1 
\v 9 Yaaweena saqarikirafa amiqirafa uriqararafa maridanoo.
\q1 Faiqí faiqi uriqararausasaa mundirafa ureeqanoo maridanoo.
\q1 
\v 10 Moomoo namuqaauqa qini darirara fiqu fiqumma fufaqa qinee Yaaweena afeekannai misa naru taikaqiafana.
\q1 
\v 11 Misa qini fiqu fiqumma aiqamai datimma fufaqa qinee Yaaweena afeekannai misa naru taikaqiafana.
\q1 
\v 12 Qini namuqaauqa nunukara foora qini fiqu faiqu idaqa qausana qoomara foora fasa fasi marufaqa qinee Yaaweena afeekannai misa naru taikaqiafana.
\q1 
\v 13 Qini namuqaauqa qini darusee rafaaqa firarufanoo Yaaweefa qini dadaaqi uqeeranau.
\q1 
\v 14 Yaaweefa qini afeekaikirana faqa nimudaanai qirana faqa qimidanoo.
\q1 Mifa qini mandainaina kinaana uqeera qiseenoo.
\q1 
\v 15 Yaaweena rakira fasiqauqa uiqaana maaqaki asasida qufoona rida qiana iriaqa.
\q1 Yaaweena uriqarara afeeka fannoo miqidaqinoo iriaqa.
\q1 
\v 16 Yaaweena afeeka fannoo rakiranaki uriqararana maasa qiminau.
\q1 Mina uriqarara afeeka maasa dadaaqifaqa rakirana uriqareeqa.
\q1 
\v 17 Qinee sia kuquanaura.
\q1 Qinee kaqi maridaqa Yaaweefa dadaaqu oosanara koorooianaura.
\q1 
\v 18 Yaaweefa qini firaa ummaara qimiseenoo qini kuqiranasaa ititaqiseenoo.
\q1 
\v 19 Naaquqara amaana maqa kooqiuqa atuaqisaaqa.
\q1 Qinee minaki keeqafi Yaaweenara dufi dufi qianaura.
\q1 
\v 20 Mi kooqifa Yaaweefinnai fimaria kooqifa maridanoo.
\q1 Andeeqarausa kai minaki keeqeefaranoo.
\q1 
\v 21 Anee qini innaaru qirana irisee dadaaqi mariannanara ani Yaaweena amooqidaqa.
\q1 Anee rakirana uriqararana qimiannanara ani amooqidaqa.
\q1 
\v 22 Maaqa usakee mariasa afeeka sabeena minnisoofa innaaqianna aiqama sabeenauqa uriqararafa marinau.
\q1 
\v 23 Yaaweefa kai mi ainainna auquqoofaqa qafaidaqa idaaqira ainainee qidaqa.
\q1 
\v 24 Yaaweefa maa faasaanna rakiranaki uriqaree mari faasaanafa maridanoo.
\q1 Miqunara maasa asasidaqa idi raaqanani.
\q1 
\v 25 Oo Yaawee maasa mareeqee amiqira qoo quqaqisaa.
\q1 Anee qiqama ainaina anoonaikamma qimia.
\q1 
\v 26 Yaaweena auqusaa animari fasiqana Yaaweefa amiqi amiqimmamaqaani.
\q1 Maasa Yaaweena naaquqara amaana maqakiqari inni amiqi amiqimma nimaqaidaqa.
\q1 
\v 27 Yaaweefa mifa Anutufa maridanoo.
\q1 Mifa maasa amiqimma qisee marinau.
\q1 Innee aiqamausa suqufiqa saqari amanee raudasee uqirausa asasammamaree amaana maqaki keeqafi aidara fiqu fiqu iaqa.
\q1 
\v 28 Oo Yaawee anee qini Anutufa marianaqa minara qinee ani dufi dufi qimamaqaidaqa.
\q1 Qinee ani uriqararanara kooroo ianaura.
\q1 
\v 29 Yaaweefa andeeqarafa marinara mina dufi dufi qimamaqaaqa.
\q1 Mina faiqí anaaseera aidirafa naaru naaru marifa maridanoo.
\c 119
\s1 Yaaweena sandufa.
\q1 
\v 1 Aaqara oosana sia mari marirana faqaasa asasidaqa.
\q1 Yaaweena sanda ufamau fimariasa faqa asasidaqa.
\q1 
\v 2 Yaaweefa naamuaqira ufamau fimariasa asasidaqa.
\q1 Nariqa nimuqusannai mina ufa afaqee mariasa asasidaqa.
\q1 
\v 3 Miqi marinausa sia moo aaqara oosana maraidammia.
\q1 Misa Yaaweena aatata fimariasa maridammia.
\q1 
\v 4 Oo Yaawee anee aneenna sanda ufa maasa qimiseenana mapukusee andeeqasee aiqama afaqaaqee qimasee qimanniminau.
\q1 
\v 5 Qinee ani naamuaqira ufa afaqaidaqa mapukusee marianauree qidaqa iridaqa.
\q1 
\v 6 Qinee ani sanda ufa aiqama kasoommafi iriaraasidaqa.
\q1 
\v 7 Qinee ani andeeqara rainannimaqaranara iriseeqa qeeqa anukara qimuqusannai ani amooqianauranoo.
\q1 
\v 8 Qinee ani naamuaqira ufa mau fuanaura.
\q1 Anee Yaaweefa sia qini minniqisaa.
\q1 
\v 9 Naqi masee fee kumaaraa fannoo narí marirana maqee maqee anukaida mariannoo fee.
\q1 Ani Yaaweena ufamau fimarianannai miqiannoo.
\q1 
\v 10 Qinee qeeqa qimuqusannai ani ufa qaindusiraree qidaqa amanidaqa.
\q1 Ani sanda ufa rukiaranasaa anee qini ititaqisaa.
\q1 
\v 11 Qinee ani naamuaqira ufa qumareeqa qeeqa qimuqusaki quqaseeqa sia ani mandaikamma amaqaanaura.
\q1 
\v 12 Oo Yaawee qinee ani amooqidaqa.
\q1 Aneenna oosanara qimaqimia.
\q1 
\v 13 Anee qimunna sanda ufausa kafaa kafaa firaaqoo nameera qidaqa qimannimianaura.
\q1 
\v 14 Qinee ani sanda ufamau firanara didimarifaqa asasi marunafa moomoo umiasana ainainara asasimarunnana faqa uraaqaranoo maridanoo.
\q1 
\v 15 Ani naakapara ufa qinee aiuqimarunausa maridaqa.
\q1 Ani qimannimira ufauqa amiqimmasee asooki rimarunausa maridaqa.
\q1 
\v 16 Qinee ani sanda ufara asasidaqa.
\q1 Qinee ani naamuaqira ufara sia qaunusee mana mana ianaura.
\q1 
\v 17 Qinee kaqi maridaqa ani qimannimira ufamau fuaneera aneenna ainainira faiqi qini amiqimma qisaa.
\q1 
\v 18 Oo Yaawee ani naaquara anoona ufa qirana ani sanda ufaki marina irianeera qini irirana atuqasainaqa irianaura.
\q1 
\v 19 Qinee maa maqanasaa qusasaa marianauranoo.
\q1 Sia aneenna sanda ufa qini kukeeqa qimaqaa.
\q1 
\v 20 Qinee qinunu rimarunanoo didafidanoo.
\q1 Ani rainannimaqara ufara aiqama kari iriraree qimasee aupuraidaqa.
\q1 
\v 21 Oo Yawee nári nimoo naamoo qimariasa anee aanoommasee qaoo qimarianafa mariananoo.
\q1 Ani naamuaqira ufa rukiasee kaqi runna fimariasa ani niqurara ufa ameemaanai maridaqa.
\q1 
