\q1 men \x + \xo 14:21 \xt Sòm 41:1 \x*sila ki fè gras a malere a, beni.
\q1 
\v 22 Èske sila ki \x + \xo 14:22 \xt Sòm 36:4\x*fòmante mechanste a, pa egare?
\q1 Men ladousè avèk verite se pou sa yo ki fè sa ki bon.
\q1 
\v 23 Nan tout travay gen pwofi;
\q1 men pale anpil mennen nan povrete.
\q1 
\v 24 \x + \xo 14:24 \xt Pwov 10:22\x*Kouwòn saj yo se richès yo;
\q1 men betiz moun ensanse se foli yo.
\q1 
\v 25 Yon vre temwen sove lavi a moun;
\q1 men sila ki \x + \xo 14:25 \xt Pwov 14:5\x*pale manti pase moun nan betiz.
\q1 
\v 26 Nan \x + \xo 14:26 \xt Pwov 18:10\x*lakrent SENYÈ a, gen gwo konfyans;
\q1 e pitit li yo va jwenn sekou.
\q1 
\v 27 Lakrent SENYÈ a se yon fontèn dlo lavi,
\q1 pou moun ka evite pèlen lanmò yo.
\q1 
\v 28 Nan fòs kantite a pèp yo se glwa a yon wa,
\q1 men afè prens ki manke moun gate nèt.
\q1 
\v 29 Sila ki \x + \xo 14:29 \xt Pwov 16:32\x*lan nan kòlè a, gen gwo konprann;
\q1 men sila ki fè fache vit, leve foli byen wo.
\q1 
\v 30 Yon kè trankil se lavi pou kò a;
\q1 men pasyon fè tout zo yo \x + \xo 14:30 \xt Pwov 12:4 \x*pouri.
\q1 
\v 31 Sila ki oprime malere a ap vekse Kreyatè li;
\q1 men sila ki gen bonte anvè pòv la, onore L.
\q1 
\v 32 Mechan an jete anba pa malfezans li;
\q1 men moun ladwati a gen sekou lè l mouri.
\q1 
\v 33 Sajès se nan kè a sila ki gen bon konprann nan;
\q1 menm moun ensanse yo, nan kè, yo konnen.
\q1 
\v 34 Ladwati leve yon nasyon;
\q1 men peche se yon gwo wont pou yon pèp.
\q1 
\v 35 Favè a wa a se anvè \x + \xo 14:35 \xt Mat 24:45-47\x*sèvitè ki aji ak sajès;
\q1 men kòlè li se anvè sila ki fè gwo wont.
\c 15
\q1 
\v 1 Yon repons ki dous kalme kòlè;
\q1 men yon \x + \xo 15:1 \xt I Sam 25:10-13 \x*mo sevè pwovoke gwo fache.
\q1 
\v 2 \x + \xo 15:2 \xt Pwov 15:7\x*Lang a saj la gen pou mèt, konesans;
\q1 men bouch a sila ki manke konprann nan eksprime foli.
\q1 
\v 3 Zye a SENYÈ a tout kote;
\q1 L ap veye sa ki bon ak sa ki mal.
\q1 
\v 4 Yon lang ki kalme se yon pyebwa lavi;
\q1 men si l gen desepsyon, l ap kraze lespri.
\q1 
\v 5 Yon moun ensanse refize disiplin a papa l;
\q1 men sila ki aksepte repwòch gen sajès.
\q1 
\v 6 Gran richès twouve nan kay a moun dwat yo;
\q1 men gwo twoub se salè a mechan an.
\q1 
\v 7 Lèv a moun saj yo gaye konesans;
\q1 men se pa konsa ak kè moun ensansib yo.
\q1 
\v 8 Sakrifis a mechan an abominab a SENYÈ a;
\q1 men \x + \xo 15:8 \xt Pwov 15:29\x*lapriyè moun dwat yo se gwo plezi Li.
\q1 
\v 9 Chemen mechan an abominab a SENYÈ a;
\q1 men Li renmen sila ki \x + \xo 15:9 \xt I Tim 6:11\x*chache ladwati a.
\q1 
\v 10 Pinisyon byen di ap tann sila ki abandone chemen an;
\q1 sila ki rayi korije a va mouri.
\q1 
\v 11 Sejou mò yo ak labim nan parèt devan zye SENYÈ a;
\q1 konbyen, anplis, pou \x + \xo 15:11 \xt I Sam 16:7 \x*kè a lòm!
\q1 
\v 12 \x + \xo 15:12 \xt Pwov 13:1\x*Sila ki moke a pa renmen sila ki fè l repwòch la;
\q1 li pa janm ale kote moun saj.
\q1 
\v 13 Kè ki gen lajwa fè figi moun rejwi;
\q1 men lè kè a tris, \x + \xo 15:13 \xt Pwov 17:22 \x*lespri a vin brize.
\q1 
\v 14 \x + \xo 15:14 \xt Pwov 18:15\x*Lespri a moun entèlijan an chache konesans;
\q1 men bouch a moun sòt la, manje foli.
\q1 
\v 15 Tout jou aflije yo move;
\q1 men yon kè kontan se yon fèt ki pa janm sispann.
\q1 
\v 16 Pi bon se piti ak lakrent SENYÈ a,
\q1 pase gwo richès ak gwo twoub ladann.
\q1 
\v 17 Pi bon se yon plato legim avèk lanmou,
\q1 pase yon bèf gra ak rayisman.
\q1 
\v 18 Yon nonm ki kolerik pwovoke konfli;
\q1 men sila ki lan nan kòlè a kalme yon kont.
\q1 
\v 19 Wout a parese a se tankou yon ran pikan;
\q1 men pa a moun dwat la se yon gran chemen.
\q1 
\v 20 Yon \x + \xo 15:20 \xt Pwov 10:1\x*fis ki saj fè papa l kontan;
\q1 men yon gason ensanse meprize manman l.
\q1 
\v 21 Foli se gwo plezi pou sila ki manke bon konprann nan;
\q1 men yon nonm ak bon konprann \x + \xo 15:21 \xt Pwov 14:8\x*mache dwat.
\q1 
\v 22 San konsèy, plan yo vin jennen;
\q1 men ak anpil konseyè, yo vin reyisi.
\q1 
\v 23 Yon nonm jwenn kè kontan nan yon repons ki jis,
\q1 e a la bèl yon mo livre nan pwòp lè li bèl!
\q1 
\v 24 Wout lavi a mennen moun saj la anwo,
\q1 pou l kab evite Sejou mò k ap tann li anba a.
\q1 
\v 25 SENYÈ a va demoli kay moun ògeye a;
\q1 men L ap etabli lizyè vèv la.
\q1 
\v 26 Plan mechan yo abominab a SENYÈ a;
\q1 men pawòl agreyab yo san tach.
\q1 
\v 27 Sila ki fè pwofi ak movèz fwa a, twouble pwòp lakay li;
\q1 men sila ki rayi afè anba tab la, va viv.
\q1 
\v 28 Kè a moun dwat la \x + \xo 15:28 \xt I Pi 3:15\x*reflechi anpil pou bay repons;
\q1 men bouch a mechan an fè anpil move bagay vin parèt.
\q1 
\v 29 SENYÈ a lwen mechan an;
\q1 men Li \x + \xo 15:29 \xt Sòm 145:18-19\x*tande lapriyè a moun dwat yo.
\q1 
\v 30 Zye klè fè kè kontan;
\q1 bòn nouvèl konn mete grès sou zo.
\q1 
\v 31 Zòrèy k ap koute repwòch ap viv;
\q1 zòrèy ki koute koreksyon ap alèz pami saj yo.
\q1 
\v 32 Sila ki neglije disiplin meprize pwòp tèt li;
\q1 men sila ki \x + \xo 15:32 \xt Pwov 15:5 \x*koute repwòch ranmase bon konprann.
\q1 
\v 33 Lakrent SENYÈ a se enstriksyon ki bay sajès;
\q1 avan onè, fòk imilite.
\c 16
\q1 
\v 1 \x + \xo 16:1 \xt Pwov 16:9\x*Plan kè a sòti nan lòm;
\q1 men repons a lang lan sòti nan SENYÈ a.
\q1 
\v 2 Tout chemen a yon nonm pwòp nan zye pa li;
\q1 men SENYÈ a peze sa k nan kè l.
\q1 
\v 3 \x + \xo 16:3 \xt Sòm 37:5\x*Konsakre tout zèv ou yo a SENYÈ a,
\q1 e plan ou yo va etabli.
\q1 
\v 4 SENYÈ a te fè tout bagay pou pwòp sèvis li;
\q1 menm \x + \xo 16:4 \xt Wo 9:22 \x*mechan yo pou jou jijman an.
\q1 
\v 5 Tout sila ki gen kè ògèy, abominab a SENYÈ a;
\q1 anverite, li p ap chape anba pinisyon.
\q1 
\v 6 Pa \x + \xo 16:6 \xt Dan 4:27\x*lanmou dous avèk verite, inikite lave;
\q1 e pa lakrent SENYÈ a moun chape anba mal.
\q1 
\v 7 Lè chemen a yon nonm fè SENYÈ a kontan,
\q1 \x + \xo 16:7 \xt Jen 33:4\x*l ap fè menm lènmi li yo vin anpè avè l.
\q1 
\v 8 Pi bon se piti ak ladwati
\q1 pase gwo kòb k ap antre avèk enjistis.
\q1 
\v 9 Panse a lòm fè plan pou wout li;
\q1 men \x + \xo 16:9 \xt Sòm 37:23 \x*SENYÈ a dirije pa li yo.
\q1 
\v 10 Se desizyon diven ki nan lèv a wa a;
\q1 bouch li pa dwe fè erè nan jijman.
\q1 
\v 11 Yon balans ki jis apatyen a Bondye;
\q1 li veye sou tout pwa nan sak yo.
\q1 
\v 12 Se abominab pou wa yo komèt zak mechan,
\q1 paske yon \x + \xo 16:12 \xt Pwov 25:5\x*twòn etabli sou ladwati.
\q1 
\v 13 Lèv ki dwat se plezi a wa yo;
\q1 e sila ki pale dwat, vin renmen.
\q1 
\v 14 Kòlè a yon wa se tankou mesaje lanmò;
\q1 men yon nonm saj va kalme li.
\q1 
\v 15 Nan vizaj a yon wa briye lavi;
\q1 e favè li se tankou yon nwaj avèk lapli prentan.
\q1 
\v 16 A la bon li pi bon pou resevwa sajès pase lò!
\q1 Pito nou jwenn bon konprann pase ajan.
\q1 
\v 17 \x + \xo 16:17 \xt És 35:8\x*Gran chemen a moun dwat la se pou kite mal;
\q1 sila ki veye chemen li an prezève lavi li.
\q1 
\v 18 Ògèy ale devan destriksyon
\q1 e yon lespri ògèy devan moun kap tonbe.
\q1 
\v 19 Li pi bon pou rete \x + \xo 16:19 \xt Pwov 3:34\x*enb nan lespri avèk sila ki ba yo,
\q1 pase divize piyaj ak moun ògeye yo.
\q1 
\v 20 Sila ki bay atansyon a pawòl la va jwenn sa ki bon;
\q1 beni se sila ki mete konfyans li nan SENYÈ a.
\q1 
\v 21 \x + \xo 16:21 \xt Os 14:9\x*Moun saj nan kè va rekonèt kon moun bon konprann;
\q1 e dousè nan pale va ogmante kapasite konvenk moun.
\q1 
\v 22 Bon konprann se yon fontèn dlo lavi pou sila ki genyen l;
\q1 men pou disipline moun ensanse yo se foli.
\q1 
\v 23 \x + \xo 16:23 \xt Sòm 37:30\x*Kè moun saj la enstwi bouch li;
\q1 li ogmante pouvwa l pou konvenk moun ak lèv li.
\q1 
\v 24 \x + \xo 16:24 \xt Sòm 19:10\x*Pawòl agreyab se yon nich gato siwo myèl;
\q1 dous pou nanm nan, ak gerizon pou zo.
\q1 
\v 25 \x + \xo 16:25 \xt Pwov 12:15\x*Gen wout ki parèt bon a yon nonm;
\q1 men fen li se lanmò.
\q1 
\v 26 Apeti a yon ouvriye fè byen pou li;
\q1 paske se grangou ki ankouraje l.
\q1 
\v 27 Yon \x + \xo 16:27 \xt Pwov 6:12-18\x*sanzave fòmante mechanste;
\q1 pawòl li yo brile tankou dife wouj.
\q1 
\v 28 Yon nonm pèvès gaye konfli,
\q1 e yon nonm k ap bay kout lang ap separe bon zanmi yo.
\q1 
\v 29 Yon nonm vyolan \x + \xo 16:29 \xt Pwov 1:10\x*ap tante vwazen li
\q1 pou l mennen li nan move chemen.
\q1 
\v 30 Sila kap bay zye dou, fè l pou l kab mennen bagay pèvès;
\q1 sila ki fèmen sere lèv li, fè mal la rive.
\q1 
\v 31 Yon \x + \xo 16:31 \xt Pwov 20:29\x*tèt blanch se yon kouwòn laglwa;
\q1 li jwenn nan chemen ladwati a.
\q1 
\v 32 Sila ki lan nan kòlè a pi bon pase pwisan yo;
\q1 e sila ki gouvène lespri li a pi bon pase sila k ap kaptire yon gran vil.
\q1 
\v 33 Tiraj osò fèt nan fon wòb;
\q1 men tout desizyon ki sòti, sòti nan SENYÈ a.
\c 17
\q1 
\v 1 Pi bon se yon mòso pen sèch ak lapè
\q1 pase yon kay ak gwo manje nan konfli.
\q1 
\v 2 Yon sèvitè ki aji avèk sajès
\q1 va renye sou yon fis ki aji ak wont;
\q1 li va pataje eritaj la pami frè yo.
\q1 
\v 3 Po rafine se pou ajan, e founo se pou lò;
\q1 men \x + \xo 17:3 \xt I Kwo 29:17\x*SENYÈ a ap sonde tout kè.
\q1 
\v 4 Yon malfektè koute lèv mechan yo;
\q1 yon mantè prete atansyon a yon lang k ap detwi.
\q1 
\v 5 Sila ki moke \x + \xo 17:5 \xt Pwov 14:31\x*malere a moke Kreyatè li;
\q1 sila ki rejwi nan malè a, p ap soti san pinisyon.
\q1 
\v 6 Pitit a pitit se kouwòn a granmoun,
\q1 e \x + \xo 17:6 \xt Egz 20:12 \x*glwa a fis yo se papa yo.
\q1 
\v 7 Bèl diskou pa byen koresponn ak yon moun ki ensanse,
\q1 bokou mwens \x + \xo 17:7 \xt Sòm 31:18 \x*lèv k ap manti sou yon prens.
\q1 
\v 8 Vèse kòb anba tab se tankou wanga pou mèt li;
\q1 nenpòt kote li vire, li byen reyisi.
\q1 
\v 9 Sila ki \x + \xo 17:9 \xt Pwov 10:12\x*kouvri yon transgresyon, chache lanmou;
\q1 men sila ki repete yon koze, separe bon zanmi yo.
\q1 
\v 10 Yon repwòch antre pi fon nan moun bon konprann nan
\q1 pase anpil kou sou yon moun ensanse.
\q1 
\v 11 Yon nonm rebèl se mal l ap chache;
\q1 konsa, yon mesaje byen sovaj va voye kont li.
\q1 
\v 12 Pito yon nonm rankontre yon \x + \xo 17:12 \xt II Sam 17:8 \x* lous fewòs ki separe de pitit li,
\q1 pase yon moun ensanse nan mitan foli li.
\q1 
\v 13 Pou sila ki \x + \xo 17:13 \xt Sòm 35:12 \x*remèt mal pou byen an,
\q1 mal la p ap janm kite lakay li.
\q1 
\v 14 Kòmansman a konfli se tankou pete gwo baryè dlo;
\q1 konsa, \x + \xo 17:14 \xt Pwov 20:3 \x*kite kont lan avan l kòmanse.
\q1 
\v 15 Sila ki \x + \xo 17:15 \xt Egz 23:7\x*bay rezon a mechan an, ni sila ki kondane moun dwat la;
\q1 tou de abominab a SENYÈ a.
\q1 
\v 16 Poukisa gen kòb nan men moun ensanse a
\q1 pou l \x + \xo 17:16 \xt Pwov 23:23\x*achte sajès, konsi, li pa konprann anyen?
\q1 
\v 17 Yon \x + \xo 17:17 \xt Rt 1:16\x*zanmi renmen tout tan;
\q1 yon frè fèt pou move tan.
\q1 
\v 18 Yon nonm ki manke konprann \x + \xo 17:18 \xt Pwov 6:1\x*sèvi garanti,
\q1 e devni responsab nan prezans a vwazen li.
\q1 
\v 19 Sila ki renmen vyole lalwa a renmen konfli;
\q1 sila ki \x + \xo 17:19 \xt Pwov 16:18\x*awogan an, chache gwo dega.
\q1 
\v 20 Sila ki gen panse kwochi a, \x + \xo 17:20 \xt Pwov 24:20\x*pa jwenn anyen ki bon,
\q1 e sila ki pèvès nan pawòl li yo tonbe nan mal.
\q1 
\v 21 Sila ki fè pitit ki san konprann nan, fè l nan tristès;
\q1 e papa a yon moun ensanse pa gen kè kontan.
\q1 
\v 22 Yon kè kontan se bon remèd;
\q1 men yon lespri brize \x + \xo 17:22 \xt Sòm 22:15 \x*seche tout zo.
\q1 
\v 23 Yon nonm mechan an resevwa kòb anba tab an sekrè;
\q1 pou l \x + \xo 17:23 \xt Egz 23:8\x*tòde chemen lajistis.
\q1 
\v 24 Sajès se devan fas a sila ki gen bon konprann nan;
\q1 men \x + \xo 17:24 \xt Ekl 2:14\x*zye a moun ensanse yo chache jis rive nan tout pwent latè.
\q1 
\v 25 Yon fis ki san konprann se yon tèt chaje a papa l,
\q1 ak \x + \xo 17:25 \xt Pwov 10:1 \x*gwo chagren a sila ki te pòte li a.
\q1 
\v 26 Anplis, li pa bon pou \x + \xo 17:26 \xt Pwov 17:5\x*pini moun dwat la,
\q1 ni pou frape prens yo akoz entegrite yo.
\q1 
\v 27 Sila ki kenbe pawòl li, gen konesans;
\q1 e sila ki gen \x + \xo 17:27 \xt Pwov 14:29 \x*lespri kalm nan se yon nonm ak bon konprann.
\q1 
\v 28 Menm yon moun ensanse, lè l rete an silans, konsidere kon saj;
\q1 lè l fèmen lèv li, li parèt rezonab.
\c 18
\q1 
\v 1 Sila ki izole pwòp tèt li, chache pwòp enterè l;
\q1 bon jijman an pa anyen devan l.
\q1 
\v 2 Yon moun ensanse pa pran plezi nan bon konprann;
\q1 men sèlman \x + \xo 18:2 \xt Pwov 12:23\x*nan devwale pwòp panse li.
\q1 
\v 3 Lè yon nonm mechan vin parèt, mepriz la vini ansanm avè l;
\q1 e avèk dezonè, wont vin parèt.
\q1 
\v 4 Pawòl yo ki sòti nan bouch a yon nonm se yon \x + \xo 18:4 \xt Pwov 20:5\x*dlo byen fon;
\q1 dlo sajès se yon dlo fre k ap koule tout tan.
\q1 
\v 5 Panche vè yon moun mechan an pa bon,
\q1 ni pou fè jijman ki rache jistis nan men moun dwat yo.
\q1 
\v 6 Lèv a yon moun ensanse mennen konfli;
\q1 bouch li ap mande kou.
\q1 
\v 7 Bouch a \x + \xo 18:7 \xt Sòm 64:8\x*moun san konprann nan se dega li;
\q1 e lèv li se pèlen pou nanm li.
\q1 
\v 8 Pawòl a sila ki chichote pawòl nan zòrèy moun nan
\q1 se tankou bonbon ki gen gou dous;
\q1 se jis nan fon kò a yo desann.
\q1 
\v 9 Anplis, sila ki parese nan travay li a
\q1 se \x + \xo 18:9 \xt Pwov 28:24 \x*frè a sila ki detwi a.
\q1 
\v 10 \x + \xo 18:10 \xt Egz 3:15\x*Non SENYÈ a se yon sitadèl byen fò;
\q1 moun ladwati a kouri ladann pou jwenn sekou.
\q1 
\v 11 Pou yon nonm \x + \xo 18:11 \xt Pwov 10:15\x*rich, byen li se yon vil ki fò;
\q1 kon yon miray byen wo nan panse li.
\q1 
\v 12 \x + \xo 18:12 \xt Pwov 11:2\x*Avan destriksyon, kè yon nonm plen ògèy;
\q1 men imilite ale devan onè.
\q1 
\v 13 Sila ki \x + \xo 18:13 \xt Pwov 20:25\x*bay repons avan li koute a;
\q1 plen foli ak wont.
\q1 
\v 14 Lespri a yon nonm kapab sipòte maladi;
\q1 men nan ka lespri brize a, se kilès ki kab sipòte li?
\q1 
\v 15 \x + \xo 18:15 \xt Pwov 15:4\x*Panse a sila ki gen bon konprann nan, ranmase konesans;
\q1 anplis, zòrèy a saj la chache konesans.
\q1 
\v 16 \x + \xo 18:16 \xt Jen 32:20\x*Don a yon nonm fè kont espas pou li,
\q1 e mennen li devan moun enpòtan.
\q1 
\v 17 Premye moun pou plede ka li a, sanble gen rezon;
\q1 jiskaske yon lòt moun vin egzamine l.
\q1 
\v 18 \x + \xo 18:18 \xt Pwov 16:33\x*Tiraj osò fè konfli sispann;
\q1 l ap pran desizyon antre moun pwisan yo.
\q1 
\v 19 Yon frè ki blese se pi rèd pou konvenk pase yon vil fòtifye;
\q1 konfli ak li se tankou ba fè nan yon sitadèl.
\q1 
\v 20 Se fwi a bouch moun ki satisfè vant li;
\q1 \x + \xo 18:20 \xt Pwov 14:14\x*l ap satisfè ak sa ke lèv li pwodwi.
\q1 
\v 21 \x + \xo 18:21 \xt Pwov 12:13\x*Lanmò ak lavi nan pouvwa a lang lan;
\q1 e sila ki renmen l yo, va manje fwi li.
\q1 
\v 22 Sila ki jwenn yon \x + \xo 18:22 \xt Jen 2:18\x*madanm, jwenn yon bon bagay,
\q1 e twouve favè SENYÈ a.
\q1 
\v 23 \x + \xo 18:23 \xt Pwov 19:7\x*Malere a pale: “Souple, fè m gras”;
\q1 men moun rich la reponn byen di.
\q1 
\v 24 Yon nonm ak anpil zanmi vin kraze nèt;
\q1 men gen \x + \xo 18:24 \xt Pwov 17:17\x*yon kalite zanmi ki rete pi pwòch pase yon frè.
\c 19
\q1 
\v 1 \x + \xo 19:1 \xt Pwov 28:6\x*Pi bon se yon malere ki mache ak entegrite
\q1 pase sila ak bouch konwonpi ki ensanse a.
\q1 
\v 2 Anplis, li pa bon pou gen gwo kouraj, san konesans,
\q1 ni pou prese rive \x + \xo 19:2 \xt Pwov 21:5\x* fè fo pa.
\q1 
\v 3 Foli a yon nonm fè chemen l gate;
\q1 e kè li anraje kont SENYÈ a.
\q1 
\v 4 \x + \xo 19:4 \xt Pwov 14:20\x*Richès fè zanmi ogmante anpil;
\q1 men malere pèdi zanmi li yo.
\q1 
\v 5 Yon \x + \xo 19:5 \xt Egz 23:1\x*fo temwen pa prale san pinisyon;
\q1 e sila ki fè manti a, p ap chape.
\q1 
\v 6 \x + \xo 19:6 \xt Pwov 29:26\x*Anpil moun va chache favè a yon moun jenere ak men ouvri;
\q1 tout moun se zanmi a sila ki bay kado.
\q1 
\v 7 Tout frè a malere yo a rayi li;
\q1 konbyen, anplis, pou zanmi l kouri kite l.
\q1 \x + \xo 19:7 \xt Pwov 18:23 \x*L ale jwenn yo ak pawòl plede, men yo fin ale.
\q1 
\v 8 Sila ki twouve sajès renmen pwòp nanm li.
\q1 Sila ki kenbe ak bon konprann nan va \x + \xo 19:8 \xt Pwov 16:20\x* jwenn sa ki bon.
\q1 
\v 9 Yon \x + \xo 19:9 \xt Pwov 19:5\x*fo temwen pa prale san pinisyon;
\q1 epi sila ki bay manti a, va peri.
\q1 
\v 10 Lavi alèz pa fèt pou moun ensanse;
\q1 bokou mwens pou yon \x + \xo 19:10 \xt Pwov 30:22\x*esklav ta gen otorite sou prens yo.
\q1 
\v 11 Yon nonm ak bon konprann lan nan kòlè;
\q1 se glwa li \x + \xo 19:11 \xt Mat 5:44 \x*pou bliye yon transgresyon.
\q1 
\v 12 \x + \xo 19:12 \xt Pwov 16:14\x*Kòlè a wa a se tankou yon lyon k ap rele fò;
\q1 men favè li se tankou lawouze sou zèb vèt.
\q1 
\v 13 Se yon fis plen foli k ap detwi papa l,
\q1 e yon madanm k ap \x + \xo 19:13 \xt Pwov 21:9-19 \x*diskite a
\q1 se tankou dlo kap degoute san rete.
\q1 
\v 14 Kay ak byen se \x + \xo 19:14 \xt II Kwo 12:14\x*eritaj ki sòti nan papa;
\q1 men yon fanm pridan sòti nan SENYÈ a.
\q1 
\v 15 \x + \xo 19:15 \xt Pwov 6:9-10\x*Parès va voye yon pwofon somèy sou moun,
\q1 e yon nonm ki pa travay, va soufri grangou.
\q1 
\v 16 Sila ki \x + \xo 19:16 \xt Pwov 16:16\x*kenbe kòmandman an kenbe nanm li,
\q1 men sila ki enpridan nan kondwit va mouri.
\q1 
\v 17 Yon moun ki \x + \xo 19:17 \xt Det 15:7-8\x*fè gras a yon malere prete a SENYÈ a,
\q1 e Li va bay li rekonpans pou bon zèv li a.
\q1 
\v 18 \x + \xo 19:18 \xt Pwov 13:24\x*Bay fis ou a disiplin pandan gen espwa;
\q1 pa chache lanmò li.
\q1 
\v 19 Yon nonm ak gwo kòlè va pote pinisyon li;
\q1 paske si ou pwoteje moun nan ou va oblije fè l ankò.
\q1 
\v 20 Koute konsèy e aksepte disiplin pou ou
\q1 kab vin saj pou tout rès vi ou.
\q1 
\v 21 Plan nan kè lòm yo anpil;
\q1 men se konsèy SENYÈ a ki kanpe.
\q1 
\v 22 Sa ki dezirab nan yon nonm se yon kè ki dous.
\q1 Pito yon nonm ta malere pase li ta yon mantè.
\q1 
\v 23 \x + \xo 19:23 \xt Pwov 14:27\x*Lakrent SENYÈ a dirije a lavi pou fè moun dòmi
\q1 ak kè satisfè, san kontamine ak mal.
\q1 
\v 24 Parese a fouye men l nan plato a;
\q1 men li refize rale l rive nan bouch li.
\q1 
\v 25 Frape yon mokè pou moun san konprann nan vin gen lespri;
\q1 \x + \xo 19:25 \xt Pwov 9:8\x*repwòch a yon moun bon konprann,
\q1 va fè l genyen konesans.
\q1 
\v 26 Sila \x + \xo 19:26 \xt Pwov 28:24\x*ki atake papa li e chase manman l ale,
\q1 se yon fis ki fè wont ak dega patou.
\q1 
\v 27 Sispann koute disiplin, fis mwen an
\q1 e ou va pèdi chemen konesans.
\q1 
\v 28 Yon temwen ki fè dezòd moke lajistis;
\q1 e bouch mechan an \x + \xo 19:28 \xt Job 15:16\x*gaye inikite.
\q1 
\v 29 Gen desizyon jijman pou mokè yo;
\q1 ak kou pou do a moun ensanse yo.
\c 20
\q1 
\v 1 Diven se yon mokè, e \x + \xo 20:1 \xt Pwov 3:14\x*bwason fò fè goumen rive nan tenten;
\q1 nenpòt moun ki vin sou pa li, pa saj.
\q1 
\v 2 Laperèz a wa a se tankou gwo vwa lyon k ap rele fò;
\q1 sila ki fè l fache \x + \xo 20:2 \xt Nonb 16:38\x*va pèdi lavi l.
\q1 
\v 3 \x + \xo 20:3 \xt Jen 13:7\x*Rete lwen konfli ak rayisman, e ou va gen respè;
\q1 alò, nenpòt moun ensanse ka fè yon kont.
\q1 
\v 4 \x + \xo 20:4 \xt Pwov 13:4\x*Parese a pa laboure tè nan sezon otòn;
\q1 akoz sa li mande charite pandan rekòlt la, e li p ap gen anyen.
\q1 
\v 5 Yon plan nan kè moun se tankou dlo fon;
\q1 men yon nonm ak bon konprann rale l fè l sòti.
\q1 
\v 6 Gen anpil moun ki pwomèt fidelite;
\q1 men kibò pou jwenn yon nonm onèt?
\q1 
\v 7 Yon nonm dwat ki mache nan entegrite l;
\q1 \x + \xo 20:7 \xt Sòm 37:26\x*A la beni fis ki vini apre li yo beni!
\q1 
\v 8 \x + \xo 20:8 \xt Pwov 20:26\x*Yon wa ki chita sou twòn lajistis
\q1 fè tout mal sove ale ak pwòp zye l.
\q1 
\v 9 \x + \xo 20:9 \xt I Wa 8:46\x*Se kilès ki kapab di: “Mwen te netwaye kè m;
\q1 mwen vin pirifye de tout peche m?”
\q1 
\v 10 \x + \xo 20:10 \xt Pwov 11:1\x*Balans ki pa ojis ak mezi ki pa ojis;
\q1 tou de abominab a SENYÈ a.
\q1 
\v 11 Menm yon timoun vin\x + \xo 20:11 \xt Mat 7:16\x*rekonèt pa zèv li;
\q1 si li aji byen e si kondwit li dwat.
\q1 
\v 12 \x + \xo 20:12 \xt Egz 4:11\x*Zòrèy ki tande ak zye ki wè;
\q1 se SENYÈ a ki te fè tou de.
\q1 
\v 13 \x + \xo 20:13 \xt Pwov 6:9-10\x*Pa renmen dòmi, sinon ou va vin malere;
\q1 ouvri zye ou e ou va satisfè ak manje.
\q1 
\v 14 “Pa bon, pa bon”, di sila k ap achte a;
\q1 men lè l fè wout li, li pale kè l kontan.
\q1 
\v 15 Gen lò ak tout kalite bijou;
\q1 men lèv plen konesans se pi bèl bagay.
\q1 
\v 16 Lè l sèvi garanti pou yon enkoni, pran manto li;
\q1 epi pou fanm andeyò a, fè papye pwosè vèbal pou sa li pwomèt la.
\q1 
\v 17 \x + \xo 20:17 \xt Pwov 9:17\x*Pen konn twouve nan bay manti dous;
\q1 men pita, bouch la plen gravye.
\q1 
\v 18 Fè tout plan ak konsiltasyon;
\q1 \x + \xo 20:18 \xt Pwov 24:6 \x*fè lagè ak konsèy saj.
\q1 
\v 19 Sila ki difame moun devwale sekrè;
\q1 pou sa a, pa asosye ou ak moun ki mache bouch ouvri.
\q1 
\v 20 Sila ki \x + \xo 20:20 \xt Egz 21:17\x*modi papa li oswa manman li an,
\q1 lanp li va etenn nan tan fènwa.
\q1 
\v 21 Yon eritaj ranmase vit nan kòmansman a, p ap beni nan lafen.
\q1 
\v 22 \x + \xo 20:22 \xt Sòm 27:14\x*Pa di: “M ap rekonpanse mechanste”;
\q1 tann SENYÈ a, e Li va sove ou.
\q1 
\v 23 \x + \xo 20:23 \xt Pwov 11:1\x*Pwa ki pa ojis ak mezi ki pa ojis;
\q1 tou de abominab a SENYÈ a.
\q1 
\v 24 \x + \xo 20:24 \xt Pwov 16:9\x*Pa a yon nonm regle pa SENYÈ a;
\q1 konsa, kijan yon nonm kab vin konprann chemen li?
\q1 
\v 25 Se yon pèlen pou yon nonm ta di avèk enpridans:
\q1 “Sa sen!” e \x + \xo 20:25 \xt Ekl 5:4-5\x*aprè ve yo fèt, pou fè ankèt.
\q1 
\v 26 Yon wa ki saj va vannen mechan yo
\q1 e fè \x + \xo 20:26 \xt És 28:27\x*wou moulen pase anwo yo.
\q1 
\v 27 Lespri a lòm se lanp SENYÈ a,
\q1 ki chache pati ki pi entim nan li yo.
\q1 
\v 28 Fidelite ak \x + \xo 20:28 \xt Pwov 29:14\x*verite prezève wa a,
\q1 e ladwati bay twòn li an soutyen.
\q1 
\v 29 Glwa a jèn yo se fòs yo,
\q1 e lonè a granmoun yo se cheve blan yo.
\q1 
\v 30 \x + \xo 20:30 \xt Sòm 89:32\x*Kout fwèt ki blese fè disparèt mechanste;
\q1 li frape rive nan pati pi fon yo.
\b
\c 21
\q1 
\v 1 Kè a wa a se tankou kanal dlo nan men SENYÈ a;
\q1 Li \x + \xo 21:1 \xt Esd 6:22\x*vire l kote Li vle.
\q1 
\v 2 Chemen a yon moun bon nan pwòp zye li;
\q1 men SENYÈ a \x + \xo 21:2 \xt Pwov 16:2\x*peze kè yo.
\q1 
\v 3 SENYÈ a pito \x + \xo 21:3 \xt I Sam 15:22\x*ladwati ak lajistis
\q1 plis pase sakrifis.
\q1 
\v 4 Zye ki leve wo ak kè ki plen ògèy;
\q1 \x + \xo 21:4 \xt Pwov 24:20\x*lanp a mechan yo se peche.
\q1 
\v 5 Plan a \x + \xo 21:5 \xt Pwov 10:4\x*dilijan an mennen byen si, vè avantaj;
\q1 men tout moun ki aji san reflechi va, san dout, vin pòv.
\q1 
\v 6 Ranmase anpil byen ak lang k ap bay manti
\q1 se yon vapè k ap sove ale, k ap kouri dèyè lanmò.
\q1 
\v 7 Vyolans a mechan yo va trennen yo fè yo pati,
\q1 akoz yo \x + \xo 21:7 \xt Am 5:7\x*refize aji ak jistis.
\q1 
\v 8 Chemen a yon moun koupab \x + \xo 21:8 \xt Pwov 2:15\x*kwochi;
\q1 men pou sila ki san tach la, kondwit li dwat.
\q1 
\v 9 Li pi bon pou viv nan ti kwen sou twati a
\q1 pase nan yon kay ak yon fanm k ap fè kont tout tan.
\q1 
\v 10 Nanm a mechan an vle mal;
\q1 vwazen li an pa twouve gras nan zye l.
\q1 
\v 11 Lè \x + \xo 21:11 \xt Pwov 19:25\x*mokè a vin pini, moun san konprann nan vin saj;
\q1 men lè moun saj la enstwi, li resevwa konesans.
\q1 
\v 12 Lè sila ki dwat, pran an konsiderasyon kay mechan an,
\q1 \x + \xo 21:12 \xt Pwov 14:11\x*afè mechan an vin detwi nèt.
\q1 
\v 13 Sila ki \x + \xo 21:13 \xt Mat 18:30-34\x*fèmen zòrèy li a kri aflije a,
\q1 va vin kriye pou kont li, men li p ap jwenn \x + \xo 21:13 \xt Jc 2:13 \x*repons.
\q1 
\v 14 Yon \x + \xo 21:14 \xt Pwov 18:16\x*kado vèse an sekrè kalme fachez,
\q1 e yon anba tab ki glise rive, bese gwo kòlè.
\q1 
\v 15 Aplike lajistis se yon plezi pou moun dwat;
\q1 men se yon gwo laperèz pou malfektè inikite yo.
\q1 
\v 16 Yon nonm egare ki kite chemen bon konprann nan,
\q1 va jwenn repo nan asanble mò yo.
\q1 
\v 17 Sila ki \x + \xo 21:17 \xt Pwov 23:21\x*renmen plezi, va vin pòv;
\q1 sila ki renmen diven ak lwil, p ap janm rich.
\q1 
\v 18 Mechan an se yon \x + \xo 21:18 \xt És 43:3\x*ranson pou moun dwat yo;
\q1 e sila ki fè trèt la pou sila ki kanpe dyanm.
\q1 
\v 19 \x + \xo 21:19 \xt Pwov 21:9\x*Li pi bon pou rete nan dezè
\q1 pase viv ak yon fanm k ap agase moun tout tan.
\q1 
\v 20 Gen bèl trezò ak lwil nan abitasyon a moun saj la;
\q1 men, moun san konprann nan \x + \xo 21:20 \xt Job 20:15-18 \x*vale tout.
\q1 
\v 21 Sila ki \x + \xo 21:21 \xt Pwov 15:9\x*swiv ladwati ak fidelite a
\q1 jwenn lavi, ladwati ak lonè.
\q1 
\v 22 Yon \x + \xo 21:22 \xt II Sam 5:6-9\x*nonm saj monte sou miray vil pwisan,
\q1 e fè tonbe sitadèl la ki te bay yo konfyans.
\q1 
\v 23 Sila ki \x + \xo 21:23 \xt Pwov 12:13\x*veye bouch li ak lang li
\q1 pwoteje nanm li kont gwo twoub.
\q1 
\v 24 Ògèy, Monte Tèt Wo, Mokè;
\q1 men tit a sila ki aji nan ògèy ak ensolans yo.
\q1 
\v 25 Se \x + \xo 21:25 \xt Pwov 13:4\x*volonte a parese a ki fè l mouri,
\q1 paske men li refize travay;
\q1 
\v 26 Gen moun tout lajounen k ap anvi yon bagay,
\q1 pandan moun dwat yo \x + \xo 21:26 \xt Sòm 37:26\x* ap vèse bay san rete.
\q1 
\v 27 Sakrifis mechan yo abominab;
\q1 se konbyen anplis, lè l pote ak movèz fwa.
\q1 
\v 28 Yon \x + \xo 21:28 \xt Pwov 19:5-9\x*fo temwen va peri;
\q1 men sila ki koute verite a va pale ak letènite.
\q1 
\v 29 Moun mechan an afiche yon figi brav;
\q1 men pou \x + \xo 21:29 \xt Sòm 119:5\x*moun ladwati a, chemen li an sèten.
\q1 
\v 30 \x + \xo 21:30 \xt Jr 9:23\x*Nanpwen sajès, ni bon konprann, ni konsèy kont SENYÈ a.
\q1 
\v 31 Cheval la prepare pou jou batay la;
\q1 men \x + \xo 21:31 \xt Sòm 3:8\x*viktwa a se nan men SENYÈ a.
\b
\c 22
\q1 
\v 1 Yon \x + \xo 22:1 \xt Pwov 10:7\x*bon non pi bon pase tout richès;
\q1 e favè Bondye, pase ajan ak lò.
\q1 
\v 2 Rich la ak malere a mare ansanm;
\q1 se SENYÈ a ki \x + \xo 22:2 \xt Job 31:15\x* fè yo tout.
\q1 
\v 3 Sila ki \x + \xo 22:3 \xt Pwov 14:16\x*reflechi, wè mal e kache kò li;
\q1 men ensanse yo antre ladann e jwenn pinisyon.
\q1 
\v 4 Rekonpans pou imilite avèk lakrent SENYÈ a
\q1 se richès, bon repitasyon, ak lavi.
\q1 
\v 5 \x + \xo 22:5 \xt Pwov 15:19\x*Pikan ak pèlen se nan chemen a pèvès yo;
\q1 sila ki veye nanm li, va rete lwen yo.
\q1 
\v 6 \x + \xo 22:6 \xt Ef 6:4\x*Leve yon timoun nan chemen li ta dwe ale,
\q1 e lè li vin gran, li p ap kite li;
\q1 menm lè l granmoun, li p ap kite li.
\q1 
\v 7 \x + \xo 22:7 \xt Pwov 18:23\x*Rich yo domine sou pòv yo,
\q1 e moun ki prete vin esklav a sila k ap bay prè a.
\q1 
\v 8 Sila ki \x + \xo 22:8 \xt Job 4:8\x*simen inikite a va rekòlte vanite;
\q1 e baton kòlè li a va detwi.
\q1 
\v 9 Sila ki \x + \xo 22:9 \xt Pwov 19:17\x*bay ak men louvri va beni;
\q1 paske li bay manje a malere.
\q1 
\v 10 \x + \xo 22:10 \xt Jen 21:9-10\x*Mete moun k ap moke moun yo deyò,
\q1 e diskisyon an prale tou;
\q1 wi, konfli ak dezonore moun ap sispann.
\q1 
\v 11 Sila ki renmen \x + \xo 22:11 \xt Sòm 24:4\x*kè ki san tach
\q1 e ki pale ak gras, va zanmi a wa a.
\q1 
\v 12 Zye a SENYÈ a konsève konesans;
\q1 men Li boulvèse pawòl moun malveyan yo.
\q1 
\v 13 \x + \xo 22:13 \xt Pwov 26:13\x*Parese a di: “Gen yon lyon deyò a;
\q1 m ap mouri nan lari!”
\q1 
\v 14 Bouch a \x + \xo 22:14 \xt Pwov 21:16\x*fanm adiltè a se yon fòs byen fon;
\q1 sila ke SENYÈ a modi va tonbe ladann.
\q1 
\v 15 Foli mare nan kè a yon timoun;
\q1 baton disiplin nan va retire sa mete lwen li.
\q1 
\v 16 Sila ki oprime malere a pou ogmante tèt li;
\q1 ni sila k ap fè kado a rich yo, va rive nan povrete.
\b
\q1 
\v 17 \x + \xo 22:17 \xt Pwov 5:1\x*Apiye zòrèy ou pou tande pawòl a saj yo;
\q1 epi aplike ou a konesans mwen.
\q1 
\v 18 Paske sa va \x + \xo 22:18 \xt Pwov 2:10\x*byen agreyab pou ou
\q1 si ou kenbe yo anndan ou, pou yo toujou prè sou lèv ou.
\q1 
\v 19 Pou \x + \xo 22:19 \xt Pwov 3:5\x*konfyans ou kapab nan SENYÈ a,
\q1 mwen te enstwi ou jodi a, menm ou menm nan.
\q1 
\v 20 Èske mwen pa t ekri ou trant \x + \xo 22:20 \xt Pwov 8:6\x*bèl bagay,
\q1 de konsèy ak konesans yo?
\q1 
\v 21 Pou fè ou \x + \xo 22:21 \xt Luc 1:3-4\x*konnen vre pawòl verite yo,
\q1 pou ou kab byen reponn sila ki te voye ou a?
\b
\q1 
\v 22 Pa vòlè malere a paske li pòv,
\q1 ni \x + \xo 22:22 \xt Za 7:10 \x*kraze aflije nan pòtay la;
\q1 
\v 23 paske, SENYÈ a va \x + \xo 22:23 \xt I Sam 25:39\x*plede ka yo
\q1 e pran lavi a sila ki vòlè yo.
\b
\q1 
\v 24 Pa asosye ak yon nonm ki livre a kòlè;
\q1 oswa ale ak yon \x + \xo 22:24 \xt Pwov 29:22\x*moun kolerik,
\q1 
\v 25 sinon, ou va \x + \xo 22:25 \xt I Kor 15:33\x*aprann mès li yo
\q1 e jwenn yon pèlen pou tèt ou.
\q1 
\v 26 Pa konte pami sila ki \x + \xo 22:26 \xt Pwov 17:18\x*sèvi kon garanti yo,
\q1 pami sila ki fè sekirite pou dèt yo.
\q1 
\v 27 Si ou pa gen mwayen pou ou kab peye,
\q1 poukisa ou ta kite l \x + \xo 22:27 \xt Egz 22:26\x*rale kabann nan sòti anba ou?
\b
\q1 
\v 28 \x + \xo 22:28 \xt Det 19:14\x*Pa deplase ansyen bòn
\q1 ke papa zansèt nou yo te mete a.
\q1 
\v 29 Èske ou wè yon nonm byen abil nan travay li?
\q1 Li va \x + \xo 22:29 \xt Jen 41:46\x*kanpe devan wa yo;
\q1 li p ap oblije kanpe devan nenpòt kalite vye moun.
\b
\c 23
\q1 
\v 1 Lè ou chita sou tab ak yon moun ki gouvènè,
\q1 konsidere byen sa ki devan ou.
\q1 
\v 2 Konsa, mete yon kouto sou gòj ou
\q1 si ou se yon \x + \xo 23:2 \xt Pwov 23:20\x*nonm ak gwo lanvi.
\q1 
\v 3 Pa dezire bon manje sa yo,
\q1 paske se yon repa desepsyon.
\q1 
\v 4 Pa fatige kò ou pou jwenn richès;
\q1 \x + \xo 23:4 \xt Pwov 3:5-7 \x*sispann reflechi sou sa.
\q1 
\v 5 Depi ou mete zye ou sou li, l ale.
\q1 Paske, anverite, \x + \xo 23:5 \xt Pwov 27:24\x*li gen zèl kon yon èg
\q1 k ap vole vè syèl yo.
\q1 
\v 6 Pa manje pen a yon \x + \xo 23:6 \xt Det 15:9\x*mesye ki chich,
\q1 ni anvi bèl bagay li;
\q1 
\v 7 paske jan li panse nan tèt li a, se konsa li ye.
\q1 Li di ou: “Manje e bwè!” Men \x + \xo 23:7 \xt Pwov 26:24-25\x*kè li pa avè w.
\q1 
\v 8 Ou va \x + \xo 23:8 \xt Pwov 25:16\x*vomi mòso ke ou te manje a
\q1 e gaspiye tout bèl pawòl ou yo.
\b
\q1 
\v 9 \x + \xo 23:9 \xt Mat 7:6\x*Pa pale nan zòrèy a moun sòt,
\q1 paske l ap meprize sajès a pawòl ou yo.
\b
\q1 
\v 10 Pa deplase ansyen bòn nan,
\q1 ni \x + \xo 23:10 \xt Jr 22:3\x*antre nan chan òfelen yo,
\q1 
\v 11 Paske \x + \xo 23:11 \xt Job 19:25\x*Redanmtè yo a pwisan.
\q1 Li va plede ka yo kont ou.
\b
\q1 
\v 12 Aplike kè ou a disiplin
\q1 ak zòrèy ou a pawòl ki pote konesans.
\q1 
\v 13 \x + \xo 23:13 \xt Pwov 13:24\x*Pa ralanti disiplin sou yon timoun;
\q1 malgre ou frape li ak yon baton, li p ap mouri.
\q1 
\v 14 Ou va frape li ak baton
\q1 pou \x + \xo 23:14 \xt I Kor 5:5\x*delivre nanm li de sejou mò yo.
\b
\q1 
\v 15 Fis mwen an, si kè ou \x + \xo 23:15 \xt Pwov 23:24\x*saj,
\q1 pwòp kè m va kontan tou.
\q1 
\v 16 Wi, jis anndan m va rejwi
\q1 lè lèv ou pale \x + \xo 23:16 \xt Pwov 8:6\x*sa ki dwat.
\q1 
\v 17 \x + \xo 23:17 \xt Sòm 37:1\x*Pa kite kè ou fè lanvi pechè yo,
\q1 men viv nan lakrent SENYÈ a tout tan.
\q1 
\v 18 Anverite, gen davni,
\q1 e \x + \xo 23:18 \xt Sòm 9:18\x*espwa ou p ap anile.
\q1 
\v 19 Koute, fis mwen an, vin saj
\q1 pou \x + \xo 23:19 \xt Pwov 4:23 \x*dirije kè ou nan chemen an.
\q1 
\v 20 Pa bwè twòp diven,
\q1 ni fè \x + \xo 23:20 \xt Det 21:20 \x*voras nan manje vyann;
\q1 
\v 21 paske sila ki \x + \xo 23:21 \xt Pwov 21:17\x*bwè twòp la ak moun voras la va vin pòv;
\q1 e dòmi nan zye a va fè l abiye ak vye twal chire.
\q1 
\v 22 \x + \xo 23:22 \xt Pwov 1:8\x*Koute papa ou ki te fè ou a,
\q1 e pa meprize manman ou lè l vin granmoun.
\q1 
\v 23 \x + \xo 23:23 \xt Pwov 4:7\x*Achte verite e pa vann li!
\q1 Ranmase sajès, enstriksyon ak bon konprann.
\q1 
\v 24 Papa a sila ki dwat la va rejwi anpil,
\q1 e \x + \xo 23:24 \xt Pwov 10:1\x*sila ki fè yon fis ki saj la va gen kè kontan nan li.
\q1 
\v 25 Kite \x + \xo 23:25 \xt Pwov 27:11\x*papa ou ak manman ou fè kè kontan;
\q1 kite fanm ki te fè ou a, rejwi.
\q1 
\v 26 Ban m kè ou, fis mwen an;
\q1 kite zye ou \x + \xo 23:26 \xt Sòm 1:2 \x*fè kè kontan nan chemen mwen yo.
\q1 
\v 27 Paske yon pwostitiye se yon fòs byen fon,
\q1 e yon \x + \xo 23:27 \xt Pwov 5:20 \x*fanm adiltè se yon ti pwi etwat.
\q1 
\v 28 Anverite, li \x + \xo 23:28 \xt Pwov 6:26\x*kache veye tankou vòlè,
\q1 pou l ogmante enfidelite pami lòm.
\b
\q1 
\v 29 Se kilès ki gen \x + \xo 23:29 \xt És 5:11-22\x*gwo pwoblèm?
\q1 Se kilès ki gen tristès?
\q1 Se kilès ki gen konfli?
\q1 Se kilès k ap plenyen?
\q1 Se kilès ki blese san rezon?
\q1 Se kilès ki gen zye wouj?
\q1 
\v 30 Sila ki \x + \xo 23:30 \xt I Sam 25:36\x*mize sou diven an,
\q1 sila ki ale goute diven mele an.
\q1 
\v 31 Pa gade diven an lè l wouj,
\q1 lè l fè klè nan tas la,
\q1 lè l \x + \xo 23:31 \xt Kan 7:9\x*desann byen dous.
\q1 
\v 32 Nan dènye moman an, li \x + \xo 23:32 \xt Job 20:16\x*mòde tankou sèpan;
\q1 li brile tankou bouch koulèv.
\q1 
\v 33 Zye ou va wè bagay ki dwòl,
\q1 e panse ou va \x + \xo 23:33 \xt Pwov 2:12\x*twouble anpil.
\q1 
\v 34 Ou va tankou yon moun ki kouche nan mitan lanmè,
\q1 oswa tankou yon moun ki kouche sou ma batiman.
\q1 
\v 35 “Yo te frape m, men mwen pa t santi anyen!
\q1 Yo te bat mwen, men mwen pa t konnen sa!
\q1 Lè m leve, m ap \x + \xo 23:35 \xt Pwov 26:11\x*chache pou m kab bwè ankò.”
\b
\c 24
\q1 
\v 1 Pa fè anvi a moun mechan,
\q1 ni dezire \x + \xo 24:1 \xt Sòm 1:1 \x*pou avèk yo;
\q1 
\v 2 paske panse yo fòmante \x + \xo 24:2 \xt És 30:12\x*vyolans
\q1 e lèv yo pale inikite.
\q1 
\v 3 \x + \xo 24:3 \xt Pwov 9:1\x*Avèk sajès, kay la bati
\q1 e avèk bon konprann, li vin etabli.
\q1 
\v 4 Pa konesans, chanm yon moun vin
\q1 \x + \xo 24:4 \xt Pwov 8:21\x*ranpli avèk tout bèl kalite richès.
\q1 
\v 5 Yon nonm saj byen fò,
\q1 e yon nonm ak konesans ogmante pouvwa li.
\q1 
\v 6 Paske ak konsèy saj ou va fè lagè,
\q1 e \x + \xo 24:6 \xt Pwov 11:14\x*ak konseye an abondans, gen viktwa.
\q1 
\v 7 Sajès \x + \xo 24:7 \xt Sòm 10:5\x*twò wo pou moun ensanse a;
\q1 li pa ouvri bouch li nan pòtay la.
\q1 
\v 8 Yon moun ki fè plan pou fè mal,
\q1 moun va rele li magouyè.
\q1 
\v 9 Fòmante foli se peche,
\q1 e mokè a abominab a tout moun.
\q1 
\v 10 Si ou \x + \xo 24:10 \xt Det 20:8\x*lach nan jou gran pwoblèm nan, fòs ou pa fò.
\q1 
\v 11 \x + \xo 24:11 \xt Sòm 82:4\x*Delivre sila k ap mennen vè lanmò a,
\q1 ak sila k ap mache tonbe vè labatwa a.
\q1 O, kenbe yo!
\q1 
\v 12 Si ou di: “Gade, nou pa t konnen sa”;
\q1 èske Li pa \x + \xo 24:12 \xt Ekl 5:8\x*konsidere sa, sila ki peze kè?
\q1 Epi èske Li pa konnen sa, sila kap kenbe nanm ou an?
\q1 Èske Li p ap rann a lòm selon zèv li?
\q1 
\v 13 Fis mwen, manje \x + \xo 24:13 \xt Sòm 19:10\x*siwo myèl, paske li bon;
\q1 wi, siwo sòti nan nich lan dous pou goute.
\q1 
\v 14 Konnen ke \x + \xo 24:14 \xt Pwov 2:10\x*sajès se konsa pou nanm ou;
\q1 si ou twouve li, va gen yon avni, e espwa ou p ap anile.
\q1 
\v 15 \x + \xo 24:15 \xt Sòm 10:9-10\x*Pa kouche mete pyèj, o lòm mechan,
\q1 kont kote ke moun dwat la rete a.
\q1 Pa detwi kote repo li a;
\q1 
\v 16 paske yon \x + \xo 24:16 \xt Job 5:19\x*nonm ladwati tonbe sèt fwa e leve ankò,
\q1 men se nan lè gwo malè ke mechan an tonbe.
\q1 
\v 17 \x + \xo 24:17 \xt Job 31:29\x*Pa rejwi lè lènmi ou tonbe.
\q1 Ni pa kite kè ou kontan lè l tonbe;
\q1 
\v 18 Oswa, SENYÈ a va wè l,
\q1 vin pa kontan e detounen kòlè Li de li.
\q1 
\v 19 \x + \xo 24:19 \xt Sòm 37:1\x*Pa twouble tèt ou pou malveyan yo,
\q1 ni fè lanvi pou mechan yo,
\q1 
\v 20 paske pou yon nonm mechan, \x + \xo 24:20 \xt Job 15:31\x*pa gen avni.
\q1 Lanp a mechan an va etenn nèt.
\q1 
\v 21 Fis mwen an, \x + \xo 24:21 \xt Wo 13:1-7\x*gen lakrent SENYÈ a ak wa a;
\q1 pa asosye ak sila ki pa stab yo,
\q1 
\v 22 paske, \x + \xo 24:22 \xt Pwov 24:16\x*malè yo va leve vit.
\q1 Kilès ki konnen destriksyon an k ap sòti nan yo de a.
\b
\q1 
\v 23 Sila yo, anplis, se pawòl a sajès:
\b
\q1 Fè \x + \xo 24:23 \xt Pwov 18:5\x* patipri nan jijman pa bon.
\q1 
\v 24 Sila ki di a mechan an: “Ou dwat”,
\q1 \x + \xo 24:24 \xt Pwov 11:26 \x*pèp yo va modi li e nasyon yo va rayi li;
\q1 
\v 25 men pou \x + \xo 24:25 \xt Pwov 28:23\x*sila ki repwoche mechan yo,
\q1 l ap wale byen ak yo.
\q1 Bon benediksyon va tonbe sou yo.
\q1 
\v 26 Yon repons onèt tankou yon bo sou lèv yo.
\q1 
\v 27 Prepare tout travay ou a deyò;
\q1 byen prepare chan ou.
\q1 Apre, alò, bati kay ou.
\q1 
\v 28 Pa vin yon temwen kont vwazen ou san koz,
\q1 e \x + \xo 24:28 \xt Lev 6:2-3\x*pa bay manti ak lèv ou.
\q1 
\v 29 \x + \xo 24:29 \xt Pwov 20:22\x*Pa di: “Se konsa mwen va fè l paske li te fè m konsa;
\q1 mwen va rann a nonm nan selon zèv li yo.”
\q1 
\v 30 Mwen te pase nan chan parese a;
\q1 akote chan rezen a nonm ki manke \x + \xo 24:30 \xt Pwov 6:22\x*bon konprann nan.
\q1 
\v 31 Epi gade byen, li te plen ak raje pikan,
\q1 e kouvri ak move zèb,
\q1 \x + \xo 24:31 \xt És 5:5 \x*Miray an wòch la te fin kraze nèt.
\q1 
\v 32 Lè m te wè, mwen te reflechi sou sa;
\q1 mwen te gade e m te resevwa enstriksyon.
\q1 
\v 33 \x + \xo 24:33 \xt Pwov 6:10\x*“Yon ti dòmi, yon ti somèy,
\q1 yon ti pliye men pou repoze,”
\q1 
\v 34 Konsa mizè ou va vin parèt sou ou tankou yon vòlè;
\q1 ak bezwen tankou yon bandi ak zam.
\c 25
\p 
\v 1 Sila yo se \x + \xo 25:1 \xt Pwov 1:1\x*Pwovèb a Salomon yo ke mesye Ézéchias yo, wa Juda a te dechifre.
\q1 
\v 2 Se glwa Bondye pou kache yon bagay;
\q1 men se glwa a \x + \xo 25:2 \xt Esd 6:1 \x*wa yo pou chache konprann yon bagay.
\q1 
\v 3 Tankou syèl la nan wotè a, ak tè a nan pwofondè a,
\q1 se konsa kè a wa a ensondab.
\q1 
\v 4 Retire vye kras sou ajan k ap fonn nan, e va sòti metal pi pou òfèv la.
\q1 
\v 5 Retire \x + \xo 25:5 \xt Pwov 20:8\x*mechan an devan wa a,
\q1 e twòn li an va etabli nan ladwati.
\q1 
\v 6 Pa reklame bèl repitasyon nan prezans a wa a,
\q1 e pa kanpe nan plas a moun pwisan yo;
\q1 
\v 7 paske li pi bon pou yo di ou: “Vin monte isit la”,
\q1 olye pou ou ta oblije desann piba nan prezans a prens lan,
\q1 ke zye ou te wè.
\q1 
\v 8 Pa fè vit lantre nan tribinal \x + \xo 25:8 \xt Pwov 17:14\x*pou diskite ka ou;
\q1 anfen, sa ou va fè lè vwazen ou fè ou desann nèt.
\q1 
\v 9 \x + \xo 25:9 \xt Mat 18:15\x*Diskite pwòp ka pa ou devan vwazen ou,
\q1 e pa devwale sekrè a yon lòt,
\q1 
\v 10 oswa sila ki tande ou a, va fè ou repwòch,
\q1 e move rapò sou ou menm p ap janm disparèt.
\b
\q1 
\v 11 Tankou pòm an lò ki monte sou ajan,
\q1 se konsa yon \x + \xo 25:11 \xt Pwov 15:23\x*mo byen plase nan moman li.
\q1 
\v 12 Tankou yon \x + \xo 25:12 \xt Egz 32:2\x*zanno an lò ak yon dekorasyon an lò fen
\q1 se yon repwòch saj nan zòrèy k ap koute.
\q1 
\v 13 Tankou fredi lanèj nan lè rekòlt,
\q1 se konsa yon \x + \xo 25:13 \xt Pwov 13:17\x*mesaje fidèl ye a sila ki voye l yo,
\q1 paske li rafrechi nanm a mèt li yo.
\q1 
\v 14 Tankou \x + \xo 25:14 \xt Jd 12\x*nwaj ak van san lapli,
\q1 se konsa yon nonm ki ogmante don li yo ak manti.
\q1 
\v 15 Ak \x + \xo 25:15 \xt Jen 32:4\x*pasyans, yon chèf ka vin pèswade;
\q1 se yon lang dous ki kase zo.
\q1 
\v 16 Èske ou te \x + \xo 25:16 \xt Jij 14:8\x*jwenn siwo myèl?
\q1 Manje sèlman kont ou,
\q1 pou ou pa gen twòp pou vomi li.
\q1 
\v 17 Kite pye ou raman pile lakay vwazen ou,
\q1 sinon li va fatige avè w, e vin rayi ou.
\q1 
\v 18 Tankou gwo baton, nepe, oswa flèch file,
\q1 se konsa yon nonm ki pote \x + \xo 25:18 \xt Egz 20:16\x*fo temwen kont vwazen li.
\q1 
\v 19 Tankou yon move dan ak yon pye ki pa estab,
\q1 se konsa konfyans nan yon \x + \xo 25:19 \xt Job 6:15\x*nonm enfidèl nan tan gwo twoub.
\q1 
\v 20 Tankou yon moun ki retire rad li nan jou fredi,
\q1 oswa tankou vinèg sou poud bikabonat,
\q1 se konsa sila ki chante chan ak kè twouble yo ye.
\q1 
\v 21 \x + \xo 25:21 \xt Egz 23:4-5\x*Si lènmi ou grangou, ba li manje;
\q1 epi si li swaf, ba li dlo pou l bwè;
\q1 
\v 22 paske, ou va anpile chabon tou limen sou tèt li,
\q1 e \x + \xo 25:22 \xt II Sam 16:12\x*SENYÈ a va bay ou rekonpans.
\q1 
\v 23 Van nò pote lapli
\q1 e yon \x + \xo 25:23 \xt Sòm 101:5\x*lang medizan, pote yon move vizaj.
\q1 
\v 24 Li \x + \xo 25:24 \xt Pwov 21:9\x*pi bon pou viv nan yon kwen twati
\q1 pase nan yon kay avèk yon fanm k ap fè kont tout tan.
\q1 
\v 25 Tankou dlo frèt pou yon nanm fatige,
\q1 se konsa yon \x + \xo 25:25 \xt Pwov 15:30\x*bòn nouvèl ki sòti nan yon peyi lwen.
\q1 
\v 26 Tankou yon \x + \xo 25:26 \xt Éz 32:2\x*sous ki foule anba pye ak yon pwi kontamine,
\q1 se konsa yon nonm dwat ki bay plas a mechan an.
\q1 
\v 27 Li pa bon pou bwè anpil siwo myèl,
\q1 ni li pa bon pou \x + \xo 25:27 \xt Pwov 27:2\x*chache pwòp glwa pa w.
\q1 
\v 28 Tankou yon gran vil ki kase antre san miray,
\q1 se konsa yon nonm ki \x + \xo 25:28 \xt II Kwo 32:5 \x*pa kontwole pwòp tèt li.
\c 26
\q1 
\v 1 Tankou lanèj nan sezon chalè a, tankou lapli nan sezon rekòlt,
\q1 se konsa respè \x + \xo 26:1 \xt Pwov 17:7 \x*pa merite rive sou yon moun ensanse.
\q1 
\v 2 Tankou yon ti zwazo k ap sove ale, tankou yon ti iwondèl nan vòl li,
\q1 se konsa yon \x + \xo 26:2 \xt Nonb 23:8\x*madichon san koz p ap poze.
\q1 
\v 3 Yon fwèt se pou chwal la, yon brid pou bourik la,
\q1 ak \x + \xo 26:3 \xt Pwov 10:13\x*baton pou do a moun ensanse a.
\q1 
\v 4 \x + \xo 26:4 \xt Pwov 23:9\x*Pa reponn yon moun ensanse selon foli li,
\q1 oswa ou va vin tankou li.
\q1 
\v 5 \x + \xo 26:5 \xt Mat 16:1-4\x*Reponn yon moun ensanse selon foli li merite,
\q1 pou l pa vin saj nan pwòp zye li.
\q1 
\v 6 Li koupe pwòp pye li, e bwè vyolans,
\q1 ki voye yon mesaj pa men a moun ensanse a.
\q1 
\v 7 Tankou janm ki initil pou moun bwate a,
\q1 se konsa yon pwovèb nan bouch a moun ensanse.
\q1 
\v 8 Tankou yon moun ki mare wòch anndan fistibal
\q1 se konsa sila ki bay respè a moun ensanse a.
\q1 
\v 9 Tankou yon pikan ki tonbe nan men yon moun k ap bwè gwòg,
\q1 se konsa yon pwovèb nan bouch a moun ki ensanse.
\q1 
\v 10 Tankou moun ak banza k ap blese tout moun,
\q1 se konsa sila ki anplwaye moun ensanse a,
\q1 ak sila ki anplwaye sila k ap pase pa aza a.
\q1 
\v 11 Tankou \x + \xo 26:11 \xt II Pi 2:22\x*yon chen ki retounen nan vomi li,
\q1 se konsa yon moun ensanse kap repete foli li.
\q1 
\v 12 Èske ou wè yon moun ki saj nan pwòp zye li?
\q1 \x + \xo 26:12 \xt Pwov 29:20 \x*Gen plis espwa pou moun fou pase li menm.
\q1 
\v 13 \x + \xo 26:13 \xt Pwov 22:13\x*Parese a di: “Gen yon lyon nan lari a!
\q1 Yon lyon nan plas la!”
\q1 
\v 14 Tankou pòt la vire sou gon li,
\q1 se konsa \x + \xo 26:14 \xt Pwov 6:9\x*parese a sou kabann li.
\q1 
\v 15 \x + \xo 26:15 \xt Pwov 19:24\x*Parese a fouye men l nan plato a;
\q1 men l twò fatige pou fè l ankò rive nan bouch li.
\q1 
\v 16 Parese a \x + \xo 26:16 \xt Pwov 27:11\x*pi saj nan pwòp zye li
\q1 pase sèt moun ki kab reponn ak bon konprann.
\q1 
\v 17 Tankou yon moun ki pran yon chen pa zòrèy,
\q1 se konsa sila k ap pase pa aza a,
\q1 pou l gaye nan goumen ki pa apatyen a li menm nan.
\q1 
\v 18 Tankou yon moun fou k ap jete \x + \xo 26:18 \xt És 50:11\x*bwa dife, flèch ak lanmò,
\q1 
\v 19 se konsa nonm ki tronpe vwazen li an pou di:
\q1 \x + \xo 26:19 \xt Ef 5:4 \x*“Èske se pa blag mwen t ap fè?”
\q1 
\v 20 Akoz mank bwa, dife a etenn;
\q1 lè ti koze sispann, \x + \xo 26:20 \xt Pwov 22:10 \x*rayisman vin kalme.
\q1 
\v 21 Tankou chabon tou limen anvè sann cho, ak bwa anvè dife,
\q1 se konsa yon moun tchenpwèt \x + \xo 26:21 \xt Pwov 15:18\x* chofe pwoblèm pou limen konfli.
\q1 
\v 22 \x + \xo 26:22 \xt Pwov 18:8\x*Pawòl a moun k ap chichote nan zòrèy moun nan,
\q1 vin tankou bèl ti mòso delika.
\q1 Yo desann rive jis nan pati pi fon kò a.
\q1 
\v 23 Tankou veso ki fèt ak tè ki kouvri ak yon kouch ajan,
\q1 se konsa lèv ki brile ak yon kè ki mechan.
\q1 
\v 24 Yon nonm malonèt, \x + \xo 26:24 \xt Sòm 41:6\x*kache sa pou l pa parèt sou lèv li;
\q1 men nan kè l, li fè depo desepsyon.
\q1 
\v 25 Lè l \x + \xo 26:25 \xt Sòm 28:3\x*pale byen dous, pa kwè l;
\q1 paske, gen sèt abominasyon nan kè l.
\q1 
\v 26 Malgre rayisman kouvri kò l ak riz,
\q1 mechanste li va \x + \xo 26:26 \xt Luc 8:17 \x*devwale devan asanble a.
\q1 
\v 27 Sila ki \x + \xo 26:27 \xt Est 7:10\x*fouye fòs la va tonbe ladann,
\q1 e sila ki woule wòch la, sou li menm l ap retounen.
\q1 
\v 28 Yon lang ki bay manti, rayi sila li kraze yo,
\q1 e zèv a lang flatè a se dega.
\c 27
\q1 
\v 1 Pa vin ògeye sou bagay demen,
\q1 paske ou \x + \xo 27:1 \xt Luc 12:19-20 \x*pa konnen kisa yon jou ka pote.
\q1 
\v 2 Kite \x + \xo 27:2 \xt Pwov 25:27\x*yon lòt moun ba ou lwanj,
\q1 e pa fè ak pwòp bouch ou.
\q1 Kite l fèt pa yon moun ou pa konnen,
\q1 e pa de pwòp lèv ou.
\q1 
\v 3 Yon gwo wòch lou ak sab gen pwa;
\q1 men moun ensanse k ap anmède a
\q1 pi lou pase yo tou de.
\q1 
\v 4 Fachez rèd fè move.
\q1 Kòlè se yon inondasyon.
\q1 Men se \x + \xo 27:4 \xt Pwov 6:34\x*kilès ki ka kanpe devan jalouzi.
\q1 
\v 5 Repwòch ki klè pi bon pase lanmou ki kache.
\q1 
\v 6 Fidèl se blese a yon zanmi;
\q1 men twonpri se \x + \xo 27:6 \xt Mat 26:49\x*bo a yon ènmi.
\q1 
\v 7 Moun vant plen rayi siwo myèl;
\q1 men pou sila ki grangou,
\q1 nenpòt bagay anmè vin dous.
\q1 
\v 8 Tankou yon \x + \xo 27:8 \xt Pwov 26:2\x*zwazo ki egare nich li,
\q1 se konsa yon nonm ki mache lwen kay li.
\q1 
\v 9 \x + \xo 27:9 \xt Sòm 23:5\x*Lwil ak pafen fè kè kontan;
\q1 se konsa konsèy a yon nonm dous pou zanmi li.
\q1 
\v 10 Pa abandone pwòp zanmi ou, ni \x + \xo 27:10 \xt I Wa 12:6-8\x*zanmi a papa ou.
\q1 Pa ale lakay frè ou nan jou malè ou.
\q1 Pi bon se yon vwazen toupre pase yon frè ki byen lwen.
\q1 
\v 11 \x + \xo 27:11 \xt Pwov 10:1\x*Sèvi ak sajès, fis mwen,
\q1 e fè kè m kontan pou m kab reponn sila ki repwoche mwen an.
\q1 
\v 12 Yon nonm ki saj wè mal e li kache kò l;
\q1 men sila ki fou a avanse pou peye pri a.
\q1 
\v 13 Pran vètman li lè l sèvi garanti pou yon enkoni,
\q1 e pou yon fanm adiltè, kenbe mesye a menm kon garanti a.
\q1 
\v 14 Sila ki beni zanmi li ak gwo vwa bonè maten an,
\q1 sa va rekonèt kon madichon pou li.
\q1 
\v 15 \x + \xo 27:15 \xt Pwov 19:13\x*Dlo k ap degoute san rete nan jou gwo lapli
\q1 avèk fanm k ap fè kont san rete sòti menm jan:
\q1 
\v 16 Sila ki ta anpeche fanm sa a, vle anpeche van,
\q1 oswa sezi lwil ak men dwat li.
\b
\q1 
\v 17 Se fè ki file fè;
\q1 se konsa yon nonm file zanmi l.
\q1 
\v 18 Sila ki pran swen pye fig la va manje fwi li,
\q1 e sila ki pran swen mèt li a va jwenn lonè.
\q1 
\v 19 Tankou nan dlo, figi reflete figi,
\q1 konsa kè a yon nonm reflete lentansyon l.
\q1 
\v 20 \x + \xo 27:20 \xt Job 26:6\x*Sejou Lanmò ak labim pa janm satisfè;
\q1 ni zye a lòm pa janm satisfè.
\q1 
\v 21 Po fonn nan se pou ajan, e founo se pou lò;
\q1 konsa, yon nonm rafine pa lwanj ke l resevwa.
\q1 
\v 22 Malgre ou ta \x + \xo 27:22 \xt Pwov 23:35\x*foule yon moun fou ak pilon jiskaske li fè poud,
\q1 tankou sereyal byen kraze a, foli li p ap sòti sou li.
\b
\q1 
\v 23 \x + \xo 27:23 \xt Jr 31:10\x*Konnen byen kondisyon a bann mouton ou yo,
\q1 e okipe twoupo ou yo;
\q1 
\v 24 paske richès pa la pou tout tan,
\q1 ni yon \x + \xo 27:24 \xt Job 19:9\x*kouwòn pa rete pandan tout jenerasyon.
\q1 
\v 25 Zèb yo vin disparèt, e sa ki nèf la vin pouse,
\q1 e zèb mòn yo \x + \xo 27:25 \xt És 17:5\x*fin ranmase.
\q1 
\v 26 Jenn mouton yo va sèvi kon vètman ou,
\q1 e kabrit yo va mennen pri a yon chan.
\q1 
\v 27 Lèt kabrit ap kont pou manje ou,
\q1 pou manje tout lakay ou,
\q1 ak soutyen pou tout sèvant lakay ou yo.
\c 28
\q1 
\v 1 Mechan yo \x + \xo 28:1 \xt Lev 26:17-36\x*sove ale lè pa gen k ap kouri dèyè yo;
\q1 men moun dwat yo gen kouraj kon lyon.
\q1 
\v 2 Pa transgresyon a yon pèp, \x + \xo 28:2 \xt I Wa 16:8-28\x*chèf peyi yo vin anpil;
\q1 men lòd etabli pa yon nonm bon konprann ak konesans.
\q1 
\v 3 Yon moun pòv ki peze malere
\q1 se tankou gwo lapli ki lave tè a san kite anyen.
\q1 
\v 4 Sila ki abandone lalwa a \x + \xo 28:4 \xt Sòm 49:18\x*bay lwanj a moun mechan;
\q1 men sila ki kenbe lalwa a va kanpe devan yo.
\q1 
\v 5 Moun mechan yo \x + \xo 28:5 \xt Sòm 92:6\x*pa konprann lajistis;
\q1 men sila ki chache SENYÈ yo konprann tout bagay.
\q1 
\v 6 \x + \xo 28:6 \xt Pwov 19:1\x*Pi bon se malere ki mache ak ladwati a
\q1 pase sila ki kwochi a, menm si l gen anpil richès.
\q1 
\v 7 Sila ki kenbe lalwa a se yon fis ak bon konprann;
\q1 men sila ki fè zanmi ak moun \x + \xo 28:7 \xt Pwov 23:20\x*voras fè papa l wont.
\q1 
\v 8 Sila ki agrandi richès li avèk \x + \xo 28:8 \xt Egz 22:25\x*enterè sou lajan,
\q1 ranmase li pou sila k ap fè gras a malere a.
\q1 
\v 9 Sila ki vire zòrèy li pou pa koute lalwa a,
\q1 menm \x + \xo 28:9 \xt Sòm 66:18\x*lapriyè li abominab.
\q1 
\v 10 Sila ki egare moun dwat la nan move chemen an
\q1 va li menm tonbe nan pwòp fòs li;
\q1 men \x + \xo 28:10 \xt Mat 6:33 \x*sila ki san tò a, va gen bon eritaj.
\q1 
\v 11 Mesye rich la saj nan pwòp zye l;
\q1 men malere ki gen bon konprann nan wè l jis li sonde l nèt.
\q1 
\v 12 Lè moun ladwati a gen viktwa, gen anpil glwa;
\q1 men \x + \xo 28:12 \xt Pwov 28:28\x*lè mechan yo leve tout moun kache kò yo.
\q1 
\v 13 Sila ki kache transgresyon li yo, p ap fè pwogrè;
\q1 men sila ki \x + \xo 28:13 \xt Sòm 32:5 \x*konfese yo e kite yo, va jwenn konpasyon.
\q1 
\v 14 A la beni se sila ki toujou \x + \xo 28:14 \xt Pwov 23:17\x*gen lakrent Bondye a!
\q1 Men sila ki fè kè l di, va tonbe nan malè.
\q1 
\v 15 Tankou lyon k ap rele fò ak lous k ap atake,
\q1 se konsa yon \x + \xo 28:15 \xt Egz 1:14 \x*chèf mechan ye sou yon pèp malere.
\q1 
\v 16 Yon \x + \xo 28:16 \xt Ekl 10:16\x*gouvènè ki peze pèp la manke bon konprann;
\q1 men sila ki rayi richès ki pa jis, pwolonje jou li yo.
\q1 
\v 17 Yon nonm ki \x + \xo 28:17 \xt Jen 9:6\x*twouble ak koupabilite san moun
\q1 va yon fijitif jiskaske li mouri.
\q1 Pinga pèsòn ba li soutyen.
\q1 
\v 18 Sila ki mache san tò a va delivre;
\q1 men sila ki \x + \xo 28:18 \xt Pwov 10:27\x*kwochi a va tonbe byen vit.
\q1 
\v 19 \x + \xo 28:19 \xt Pwov 12:11\x*Sila ki laboure tè a va gen anpil manje;
\q1 men sila ki swiv vanite va jwenn anpil mizè.
\q1 
\v 20 Yon nonm \x + \xo 28:20 \xt Pwov 10:6\x*fidèl va gen anpil benediksyon;
\q1 men sila ki fè vit pou jwenn richès, p ap chape anba pinisyon.
\q1 
\v 21 Montre patipri pa bon,
\q1 paske yon sèl mòso pen ka fè yon moun transgrese.
\q1 
\v 22 Yon nonm ak \x + \xo 28:22 \xt Pwov 23:6\x*move zye kouri dèyè richès
\q1 e li pa konnen kisa k ap rive li.
\q1 
\v 23 Sila ki bay yon moun repwòch
\q1 va jwenn plis favè pase sila ki \x + \xo 28:23 \xt Pwov 29:5 \x*fè flatè ak lang li an.
\q1 
\v 24 Sila ki vòlè papa li oswa manman l
\q1 epi di: “Sa pa yon transgresyon”,
\q1 se \x + \xo 28:24 \xt Pwov 18:9 \x*parèy ak yon moun ki detwi.
\q1 
\v 25 Yon nonm awogan ap \x + \xo 28:25 \xt Pwov 15:18\x*pwovoke konfli;
\q1 men sila ki mete konfyans nan SENYÈ a va pwospere.
\q1 
\v 26 Sila ki \x + \xo 28:26 \xt Pwov 3:5\x*mete konfyans nan pwòp kè li a se yon moun fou;
\q1 men sila ki mache ak sajès la va delivre.
\q1 
\v 27 Sila ki \x + \xo 28:27 \xt Pwov 11:24\x*bay a malere a p ap janm manke;
\q1 men sila ki fèmen zye l ap jwenn anpil malediksyon.
\q1 
\v 28 Lè mechan yo leve, pèp la kache kò yo;
\q1 men lè yo peri moun dwat yo vin plis.
\c 29
\q1 
\v 1 Yon nonm ki fè tèt di apre anpil repwòch
\q1 va \x + \xo 29:1 \xt Pwov 6:15\x* vin kraze sibitman san remèd.
\q1 
\v 2 Lè \x + \xo 29:2 \xt Est 8:15\x*moun dwat yo vin ogmante, pèp la rejwi;
\q1 men lè yon moun mechan gouvène, pèp la jemi.
\q1 
\v 3 Yon nonm ki \x + \xo 29:3 \xt Pwov 10:1\x*renmen sajès fè papa l kontan;
\q1 men sila ki pase tan l ak pwostitiye yo gate byen li.
\q1 
\v 4 \x + \xo 29:4 \xt II Kwo 9:8\x*Avèk jistis, wa a fè tout peyi a vin estab;
\q1 men yon nonm ki aksepte kòb anba tab boulvèse li.
\q1 
\v 5 Yon nonm ki \x + \xo 29:5 \xt Sòm 5:9\x*flate vwazen li
\q1 ap ouvri filè pou pla pye li.
\q1 
\v 6 Pa transgresyon yon nonm mechan
\q1 vin \x + \xo 29:6 \xt Pwov 22:5\x*pran nan pyèj nèt;
\q1 men moun dwat la va chante e rejwi.
\q1 
\v 7 Moun \x + \xo 29:7 \xt Job 29:16\x*ladwati a gen kè pou dwa malere;
\q1 men mechan an pa menm konprann afè sa a.
\q1 
\v 8 Mokè yo, fè gwo vil la pran dife;
\q1 men moun \x + \xo 29:8 \xt Pwov 16:14 \x*saj yo kalme kòlè.
\q1 
\v 9 Lè yon nonm saj gen yon kont ak yon moun san konprann,
\q1 moun san konprann nan anraje oswa ri, e nanpwen repo.
\q1 
\v 10 Moun k ap \x + \xo 29:10 \xt Jen 4:5-8\x*vèse san rayi inosan an;
\q1 men moun dwat yo pwoteje lavi li.
\q1 
\v 11 Moun san konprann toujou fache;
\q1 men \x + \xo 29:11 \xt Pwov 19:11\x*yon nonm saj kenbe tèt li anba kontwòl.
\q1 
\v 12 Si \x + \xo 29:12 \xt I Wa 12:14\x*gouvènè a prete atansyon a manti,
\q1 tout minis li yo va vin mechan.
\q1 
\v 13 Malere a ak opresè a gen yon bagay ki sanble;
\q1 se SENYÈ a ki \x + \xo 29:13 \xt Esd 9:8\x* mete limyè nan zye tou de.
\q1 
\v 14 Si yon \x + \xo 29:14 \xt Sòm 72:4\x*wa jije pòv yo ak verite,
\q1 twòn li va etabli jis pou tout tan.
\q1 
\v 15 \x + \xo 29:15 \xt Pwov 13:24\x*Baton ak repwòch bay sajès;
\q1 men timoun ki fè sa li pito a mennen wont sou manman l.
\q1 
\v 16 Lè mechan yo vin plis, transgresyon yo ogmante;
\q1 men \x + \xo 29:16 \xt Sòm 37:34-36\x*moun dwat yo va wè tonbe yo.
\q1 
\v 17 Korije fis ou e li va ba ou rekonfò;
\q1 anplis, li va \x + \xo 29:17 \xt Pwov 10:1 \x*bay nanm ou gwo plezi.
\q1 
\v 18 Kote nanpwen \x + \xo 29:18 \xt I Sam 3:1\x*vizyon, pèp la san fren;
\q1 men byen kontan se sila ki kenbe lalwa a.
\q1 
\v 19 Pawòl sèl p ap ka enstwi yon esklav;
\q1 paske malgre li konprann, li p ap reponn.
\q1 
\v 20 Èske ou wè yon nonm ki \x + \xo 29:20 \xt Jc 1:19\x* pale vit san reflechi?
\q1 Gen plis espwa pou moun fou a pase li menm.
\q1 
\v 21 Sila ki byen swaye esklav li depi li piti a,
\q1 nan lafen, twouve yon fis.
\q1 
\v 22 Yon \x + \xo 29:22 \xt Pwov 15:18\x*nonm an kòlè pwovoke konfli
\q1 e yon nonm ki plen fachèz fè anpil tò.
\q1 
\v 23 Ògèy a yon nonm va mennen li ba;
\q1 men yon \x + \xo 29:23 \xt Pwov 15:33 \x*lespri enb va jwenn respè.
\q1 
\v 24 Sila ki fè konplo ak yon volè rayi pwòp lavi li;
\q1 li \x + \xo 29:24 \xt Lev 5:1\x*pran sèman an men li pa pale anyen.
\q1 
\v 25 Lakrent a lòm mennen yon pèlen;
\q1 men sila ki \x + \xo 29:25 \xt Sòm 91:1-16\x*mete konfyans li nan SENYÈ a va leve wo.
\q1 
\v 26 Gen anpil moun k ap chache favè a sila ki gouvène a;
\q1 men \x + \xo 29:26 \xt És 49:4\x*lajistis pou lòm va sòti nan SENYÈ a.
\q1 
\v 27 Tankou yon nonm \x + \xo 29:27 \xt Sòm 6:8\x*enjis abominab a moun dwat,
\q1 yon nonm ladwati abominab a mechan yo.
\c 30
\p 
\v 1 Pawòl a Agur, fis a Jaké a, pwofèt la:
\q1 nonm nan pale Ithiel,
\q1 a Ithiel ak Ucal:
\q1 
\v 2 “Anverite, mwen \x + \xo 30:2 \xt Sòm 49:10\x*pi bèt pase tout moun
\q1 e mwen pa gen konprann a yon nonm.
\q1 
\v 3 Mwen pa t aprann sajès,
\q1 ni mwen pa gen \x + \xo 30:3 \xt Pwov 9:10\x*konesans a Sila Ki Sen an.
\q1 
\v 4 Kilès ki te \x + \xo 30:4 \xt Rev 19:12\x*monte nan syèl la e te desann?
\q1 Kilès ki te ranmase van nan ponyèt li?
\q1 Kilès ki te vlope dlo nan vètman li?
\q1 Kilès ki te etabli tout pwent tè yo?
\q1 Ki non li e ki non fis Li a?
\q1 Asireman, ou konnen!
\b
\q1 
\v 5 “Tout \x + \xo 30:5 \xt Sòm 12:6\x*pawòl Bondye pase a leprèv;
\q1 Li se yon boukliye pou sila ki kache nan Li yo.
\q1 
\v 6 \x + \xo 30:6 \xt Det 4:2\x*Pa ogmante sou pawòl Li yo,
\q1 oswa Li va repwoche ou
\q1 e ou va fè prèv ke se yon mantè ou ye.
\b
\q1 
\v 7 “De bagay m te mande ou yo;
\q1 pa refize m yo avan m mouri:
\q1 
\v 8 Fè desepsyon ak manti rete lwen mwen.
\q1 Pa ban m richès ni povrete.
\q1 Nouri mwen ak \x + \xo 30:8 \xt Job 23:12\x*manje ki se pòsyon pa m nan,
\q1 
\v 9 pou m pa \x + \xo 30:9 \xt Det 8:12\x*vin plen e refize rekonèt Ou
\q1 pou di: ‘Se kilès ki SENYÈ a?’
\q1 oswa, pou m ta manke, vin vòlè
\q1 e fè yon gwo wont sou non Bondye mwen an.
\b
\q1 
\v 10 “Pa pale mal yon esklav a mèt li,
\q1 sinon li va \x + \xo 30:10 \xt Ekl 7:21\x*modi ou, e ou va twouve koupab.
\q1 
\v 11 Gen yon kalite moun ki \x + \xo 30:11 \xt Egz 21:17\x*modi papa li
\q1 e refize beni manman l.
\q1 
\v 12 Gen yon kalite ki san tach nan pwòp zye li;
\q1 sepandan, yo poko lave pou sòti salte a.
\q1 
\v 13 Gen yon kalite—O, jan \x + \xo 30:13 \xt Pwov 6:17\x*zye li leve wo,
\q1 e pòpyè zye li leve ak awogans.
\q1 
\v 14 Gen yon kalite moun ak dan tankou nepe
\q1 ak machwè tankou kouto,
\q1 ki prèt pou \x + \xo 30:14 \xt Sòm 14:4\x*devore aflije sou fas tè yo,
\q1 e fè moun malere yo disparèt pami moun.
\b
\q1 
\v 15 “Sansi a gen de fi: ‘Ban mwen’ ak ‘Ban m’.
\b
\q1 “Gen twa bagay ki pa janm satisfè, menm kat ki refize di: ‘Se kont’:
\q1 
\v 16 Sejou Lanmò a, \x + \xo 30:16 \xt Jen 30:1\x*vant fanm esteril la,
\q1 latè a ki pa janm jwenn dlo ase,
\q1 ak dife ki pa janm di: ‘Se kont’.
\b
\q1 
\v 17 “Pou zye moun ki moke yon papa e ki giyonnen yon manman,
\q1 \x + \xo 30:17 \xt Det 28:26\x*kòbo nan vale a va vin rache l,
\q1 e jenn èg yo va manje li.
\b
\q1 
\v 18 “Gen twa bagay ki twò bèl pou mwen,
\q1 kat ke m pa konprann:
\q1 
\v 19 \x + \xo 30:19 \xt Det 28:49\x*Vòl a yon èg nan syèl la,
\q1 pa sèpan an sou wòch,
\q1 chemen gwo bato a nan mitan lanmè,
\q1 ak manèv a yon jennonm ak yon fi.
\b
\q1 
\v 20 “Men konsa chemen a \x + \xo 30:20 \xt Pwov 5:6\x*fanm adiltè a:
\q1 Li manje, li siye bouch li e li pale klè: ‘Mwen pa t fè mal’.
\b
\q1 
\v 21 “Anba twa bagay, latè tranble,
\q1 e anba kat, li pa ka kenbe:
\q1 
\v 22 Anba yon \x + \xo 30:22 \xt Pwov 19:10\x*esklav lè li vin wa,
\q1 ak yon moun fou lè l vin satisfè ak manje,
\q1 
\v 23 anba yon fanm neglije lè l jwenn mari,
\q1 ak yon sèvant lè l pran plas mètrès kay la.
\b
\q1 
\v 24 “Kat bagay ki tou piti sou latè, men yo plen sajès:
\q1 
\v 25 \x + \xo 30:25 \xt Pwov 6:5\x*Foumi se pa yon pèp ki fò;
\q1 men yo prepare manje yo nan gran sezon.
\q1 
\v 26 \x + \xo 30:26 \xt Lev 11:5\x*Chat mawon se pa yon pèp pwisan;
\q1 men yo fè kay yo nan wòch.
\q1 
\v 27 Krikèt volan yo pa gen wa;
\q1 men yo parèt \x + \xo 30:27 \xt Job 2:7\x*byen alinye.
\q1 
\v 28 Zandolit ke ou kab kenbe nan men ou;
\q1 sepandan, li antre nan palè a wa a.
\b
\q1 
\v 29 “Gen twa bagay ki mache parèt bèl,
\q1 menm kat ki bèl lè yo mache:
\q1 
\v 30 Lyon ki \x + \xo 30:30 \xt Jij 14:18\x*pwisan pami bèt yo,
\q1 e ki pa fè bak devan okenn bèt;
\q1 
\v 31 Jan kòk mache a,
\q1 menm ak mal kabrit,
\q1 o yon wa lè lame parèt avè l.
\b
\q1 
\v 32 “Si ou te fè foli nan leve tèt ou byen wo,
\q1 oswa si ou te fè konplo pou mal,
\q1 \x + \xo 30:32 \xt Job 21:5\x*mete men ou sou bouch ou.
\q1 
\v 33 Paske lèt k ap laboure vin fè bè,
\q1 ak peze nen pote san;
\q1 se konsa \x + \xo 30:33 \xt Pwov 10:12\x* laboure kòlè pwodwi konfli.”
\c 31
\p 
\v 1 Pawòl a wa Lemuel yo; pwofesi ke manman li te ansegne li a:
\b
\q1 
\v 2 “O fis mwen an!
\q1 O fis a vant mwen an!
\q1 O fis a ve mwen yo!
\q1 
\v 3 \x + \xo 31:3 \xt Pwov 5:9\x*Pa bay fòs ou a fanm,
\q1 ni wout ou a sila ki konn detwi wa yo.
\q1 
\v 4 Se pa pou \x + \xo 31:4 \xt Ekl 10:17\x*wa yo, O Lemuel,
\q1 se pa pou wa yo bwè diven, ni pou chèf yo ta bwè diven,
\q1 
\v 5 Paske y ap bwè epi vin bliye dekrè ki te fèt la,
\q1 e \x + \xo 31:5 \xt Egz 23:6\x*tòde dwa a sila ki aflije yo.
\q1 
\v 6 Bay bwason fò a sila k ap \x + \xo 31:6 \xt Job 29:13\x*peri a,
\q1 ak diven a sila ki gen lavi anmè a.
\q1 
\v 7 Kite li bwè pou bliye mizè li
\q1 e pa sonje pwoblèm li ankò.
\q1 
\v 8 \x + \xo 31:8 \xt Job 29:12-17\x*Ouvri bouch ou pou bèbè a;
\q1 pou dwa yo a tout sila ki san sekou.
\q1 
\v 9 Ouvri bouch ou, fè jijman ak dwati,
\q1 e defann \x + \xo 31:9 \xt És 1:17 \x*dwa a aflije yo ak endijan an.”
\b
\q1 
\v 10 Yon \x + \xo 31:10 \xt Rt 3:11\x*madanm ki ekselan, se kilès ki ka twouve li?
\q1 Paske valè li depase bijou.
\q1 
\v 11 Kè a mari li mete konfyans nan li
\q1 e li p ap manke reyisi.
\q1 
\v 12 Li fè l sa ki bon e pa sa ki mal
\q1 pandan tout jou lavi li.
\q1 
\v 13 Li chache lèn ak len e travay avèk men l ak kè kontan.
\q1 
\v 14 Li tankou bato komès;
\q1 li mennen manje li soti byen lwen.
\q1 
\v 15 Anplis, li leve pandan li toujou fènwa pou
\q1 \x + \xo 31:15 \xt Luc 12:42\x*bay manje a tout lakay li,
\q1 ak yon pòsyon pou sèvant li yo.
\q1 
\v 16 Li konsidere yon chan e achte li.
\q1 Ak benefis travay li, li plante yon chan rezen.
\q1 
\v 17 Li \x + \xo 31:17 \xt I Wa 18:46\x*mare senti l ak gwo fòs
\q1 pou fè bra li vin fò.
\q1 
\v 18 Li santi ke siksè li bon;
\q1 lanp li pa janm etenn lannwit.
\q1 
\v 19 Li lonje men l vè aparèy tise a
\q1 e men l kenbe l.
\q1 
\v 20 Li \x + \xo 31:20 \xt Det 15:11\x*lonje men l vè pòv yo
\q1 avèk sila ki gen bezwen an.
\q1 
\v 21 Lakay li pa fè krent pou lanèj,
\q1 paske tout lakay \x + \xo 31:21 \xt II Sam 1:24\x* abiye an wouj.
\q1 
\v 22 Li fè \x + \xo 31:22 \xt Pwov 7:16\x*kouvèti pou tèt li;
\q1 tout vètman li se twal fen blan ak mov.
\q1 
\v 23 Mari li byen rekonèt \x + \xo 31:23 \xt Det 16:18\x*nan pòtay lavil yo,
\q1 lè l chita pami ansyen a peyi yo.
\q1 
\v 24 Li fè \x + \xo 31:24 \xt Jij 14:12\x*vètman an len pou vann yo,
\q1 e founi sentiwon a tout komèsan yo.
\q1 
\v 25 Fòs ak \x + \xo 31:25 \xt I Tim 2:9-10\x*respè se abiman li
\q1 e li souri a lavni.
\q1 
\v 26 Li \x + \xo 31:26 \xt Pwov 10:31\x*ouvri bouch li avèk sajès
\q1 e enstriksyon ladousè sou lang li.
\q1 
\v 27 Li gade byen tout afè lakay li
\q1 e li pa manje \x + \xo 31:27 \xt Pwov 15:19\x*pen laparès.
\q1 
\v 28 Pitit li yo leve e beni li;
\q1 mari li tou ba li gwo lwanj pou di l:
\q1 
\v 29 “Anpil fi te fè byen bon;
\q1 men ou pi bon anpil pase yo tout.”
\q1 
\v 30 Cham konn twonpe e bèlte konn vanite;
\q1 men se fanm nan ki \x + \xo 31:30 \xt Sòm 112:1\x*krent SENYÈ a
\q1 k ap resevwa lwanj.
\q1 
