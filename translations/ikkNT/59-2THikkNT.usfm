\id 2TH Ika New Testament 2009
\h 2 Ndị Tẹsalonika
\toc1 Ẹhụhụọ-Ozi Nke Ẹbụọ Pọlụ Dejẹnni Ndị Tẹsalonika Ndị Tẹsalonika, Nke Ẹbụọ
\toc2 Ndị Tẹsalonika, Nke Ẹbụọ
\toc3 2Tẹ
\mt2 Ẹhụhụọ-Ozi Nke Ẹbụọ Pọlụ Dejẹnni
\mt2 Ndị Tẹsalonika
\mt1 Ndị Tẹsalonika, Nke Ẹbụọ
\c 1
\cl Isi Nke Ohu
\p 
\v 1 Pọlụ lẹ Sivanọsị lẹ Timoti de ẹhụhụọ-ozini. Ẹnyi rị e dejẹnni ụka Tẹsalonika hụn rị imẹ Osolobuẹ Nẹdi ẹnyi lẹ Di-nwọnni-ẹnyi wụ Jesu Kristi ya.
\v 2 Ẹfọma lẹ udọn hụn gha ẹka Chuku Nẹdi lẹ Nna ẹnyi wụ Jesu Kristi bịa ya rịnị ụnụ.
\s1 Osolobuẹ E Dọnmẹkẹ Ụnụ
\p 
\v 3 Umunẹ, o furu efuru nị ẹnyi gi ifiri ụnụ a kpanmịn Osolobuẹ ogẹn ile, makẹni okukwe ọnụ rị e sue ọda-ọda, ihiẹn-ọsụsụọ onyẹ-onyẹ imẹ ọnụ nwẹ ebe ibe ẹ rị rịzịkwọ a bawaye.
\v 4 Ya haịn ẹnyi lẹ enwẹn ẹnyi gi e gi ụnụ a nyan isi imẹ ụka Osolobuẹ ile rị ichẹn-ichẹn. Ẹnyi gi ụnụ a nyan isi makẹ owuzo ụnụ wuzo lẹ okukwe ụnụ tọ e nwọn imẹ ukpokpo ile wẹ rị e kpokpo ụnụ lẹ nsọngbu ile ụnụ rị e dingbu.
\s1 Okinkin-ikpe Kraịstị Wela
\p 
\v 5 Ihiẹn wẹ rị e mẹ ụnụ rị a ghọsị nị okinkin-ikpe Osolobuẹ wela furu efuru. Wẹ gizi nsọngbu ndịnị wẹ e mẹ ụnụ a wụrụ ndị ru ogo ibanye Alị-eze Osolobuẹ hụ ụnụ rị a tanị afụnfụn.
\v 6 Ezioku rọ, makẹni, o furughọ nị Osolobuẹ we afụnfụn yegwarị ndị ahụn rị e ye ụnụ afụnfụn,
\v 7 mẹ ụnụ ndị rị a ta afụnfụn zu ikẹn—mẹzikwọ ẹnyi nwẹn zu ikẹn. O jẹnkọ d'e mẹ ẹ ogẹn Di-nwọnni-ẹnyi wụ Jesu k'e gi gha enu-igwee bịa—'ya lẹ ndị mmọn-ozi ẹ hụ kin-akwanran.
\p 
\v 8 Wẹ k'e gi ọkụn rị e nwunni bịa; wẹ k'e mẹgwarị wẹ ile marịnlẹni Osolobuẹ lẹ ndị hụn humẹlẹni ni oziọma Di-nwọnni-ẹnyi wụ Jesu isi.
\v 9 Ndịnị k'a narịn afụnfụn hụn wụ ntikpọ itẹbitẹ; wẹ k'a gha ebe Di-nwọnni-ẹnyi lẹ ikẹn o gi nwẹ ọghọ rị wepụ wẹ—
\v 10 o ru Ụhụọhịn hụ—Ụhụọhịn ahụn o k'a bịa kẹni ndị nsọ a ye ẹ ọghọ, kẹni wẹ ile kwerini jazịkwọ a mma n'ọ makazị. Ụnụ lẹ enwẹn ụnụ k'a rịzị imẹ wẹ, makẹni ụnụ kweri oku ẹ hụn ẹnyi gwa ụnụ.
\p 
\v 11 Ya haịn ẹnyi gi e mẹni ụnụ ekpere ogẹn ile—a rịọ Osolobuẹ ẹnyi n'o mẹ ụnụ wụrụ ndị k'a ghọsị nị oku ọ kpọ ụnụ alanị iwi; ẹnyi a rịọzị a n'o gi ikẹn ẹ rụnzuchanrịn ihiẹn-ọma ọwụlẹ ụnụ kwademẹ obi nị ụnụ k'a rụn—lẹ ọrụn ọwụlẹ ụnụ gi okukwe a rụn—
\v 12 kẹni wẹ gi ifiri ihiẹn wẹ rị a hụn ebe ụnụ rị ye ẹfan Di-nwọnni-ẹnyi wụ Jesu ọghọ, gizi ifiri Jesu ye ọnụ ọghọ—ghahanị ẹfọma Osolobuẹ lẹ Di-nwọnni-ẹnyi wụ Jesu Kristi.
\c 2
\cl Isi Nke Ẹbụọ
\s1 Onyẹ Ahụn Hụn A Danchanrịn Iwu Ile
\p 
\v 1 Dodo ni umunẹ, o mẹ nke ọbịbịa Onyẹ-nwọnni-ẹnyi wụ Jesu Kristi lẹ owegbama wẹ jẹnkọ d'e wegbama ẹnyi ile d'e kunrun ẹ,
\v 2 anịlẹ ni obi nahịnkẹnrin ọnụ; anịlẹ ni obi gbakama ọnụ makẹ amụma mọbụ oku-ọnụ mọbụ ẹkụkwọ-ozi ọwụlẹ—wẹ sị n'ọ gha ẹka ẹnyi bịa—hụn sị nị Ụhụọhịn Di-nwọnni-ẹnyi a bịagụọ.
\p 
\v 3 Anịkwọlẹ ni onyẹ ọwụlẹ gi ụzọ ọwụlẹ dufie ụnụ: Ụhụọhịn hụ abịakọ mmanị okẹn nnupụ-isi hụ bịagụụ, e wefụhagụụ wẹ Onyẹ hụ a danchanrịn iwu ile—Onyẹ hụ a danchanrịn iwu ile hụn ntikpọ rịzịkwọ e che ya lẹ enwẹn ẹ.
\v 4 O k'a gha a lụsọn mmọn lẹ iyi ọwụlẹ lẹ ihiẹn ọwụlẹ w'e fe efe ọgụn; o k'e weshi enwẹn ẹ elu nị ịya kachanrịn wẹ ile, nke wụ nị o k'a banyedẹ imẹ Ụlọ-nsọ Osolobuẹ, weri ocho, kpọ enwẹn ẹ Osolobuẹ.
\p 
\v 5 Ụnụ anyanhanzịnị nị m gwa ụnụ ihiẹn ndịnị ogẹn mmẹ lẹ ụnụ gi rị ụzọ ohu?
\v 6 Ya wụ, ụnụ a marịnghọ ihiẹn gin'ẹ—wẹ gilẹni ke wepụha a, nị wẹ rị e che nị ogẹn ẹ rugụụ wẹ kebe wepụha a.
\p 
\v 7 Makẹni ikẹn hụ e buhẹ ịdan-iwu a rịgụọlẹ nwan ọrụn, gi nzuzue a rụn ihiẹn ọ rị a rụn; o ke pụha ifọn. Kanị, o k'e zuerihụ d'e ru ni e wepụ wẹ onyẹ hụ rị e gbọndọnn'ẹ.
\v 8 Ogẹn hụ, e wepụha wẹ Onyẹ hụ a danchanrịn iwu ile—hụn Di-nwọnni-ẹnyi wụ Jizọsị k'e gi uzun gha a ọnụ pụha tikpọpụ. Di-nwọnni-ẹnyi k'e gi ọghọ ya lẹ enwẹn ẹ wụ Di-nwọnni-ẹnyi gi bịa gbu ẹ la iwi.
\p 
\v 9 Ọbịbịa Onyẹ hụ a danchanrịn iwu ile k'a wụ ẹka-ọrụn Ekwensụ. O k'e gi ikẹn ile rị ichẹn-ichẹn lẹ ihiẹn-ahịma lẹ ọrụn-atụmẹnya ichẹn-ichẹn wẹ gi e dufie ịhịan bịa,
\v 10 ya lẹ ụdị eje-ndufie ile rị ichẹn-ichẹn o k'e gi sọn ndị hụn lakọ ntikpọ, makẹni anịnị wẹ ezioku weri ọnọdị imẹ obi wẹ, ezioku hụn nkẹ a zụọpụha wẹ;
\v 11 Osolobuẹ k'e gi ifiri n'a jụgụọ wẹ ezioku zihẹ ni wẹ okẹn ndufie ahụn wẹ jẹnkọ d'e dufie wẹ, hụn k'e mẹ wẹ kweriyeni ntụ.
\v 12 Osolobuẹ k'e mẹ ẹ kẹni wẹ gi ẹ ma wẹ ikpe, uwẹ ile gilẹni ezioku dọn, kama, eje-ihiẹn a ka wẹ a sụọ.
\s1 Wẹ Họtọ Ụnụ Kẹni Ụnụ Nwẹ Nzụọfụha
\p 
\v 13 Kanị, nke ụnụ, umunẹ ẹnyi, ọnụ ndị Di-nwọnni-ẹnyi bu obi, ẹnyi k'a gha e gi ifiri ọnụ e ye Osolobuẹ ekele ogẹn ile. Makẹni, Osolobuẹ họtọ ụnụ isi-mbidọn nọkẹ mkpụrụ-ibuzọ, kẹni ụnụ nwẹ nzụọpụha, ghahanị odidọn-nsọ Mmọn-nsọ lẹ ikwerini ezioku.
\v 14 Ọnwan haịn Osolobuẹ gi nwan kpọ ụnụ ghahanị oziọma ẹnyi zi ụnụ; kẹni ụnụ nwẹhẹn ọghọ Onyẹ-nwọnni-ẹnyi wụ Jesu Kristi.
\v 15 Umunẹ, wuzokẹnmẹ ni nwan! Ụnụ e kwọnkẹnmẹ ọdịnalị ndị hụn ẹnyi kuzi ụnụ—kẹ hụn ẹnyi gi ọnụ kuzi kẹ hụn ẹnyi gi ẹkụkwọ-ozi kuzi.
\p 
\v 16 Onyẹ-nwẹni-ẹnyi wụ Jesu Kristi lẹ enwẹn ẹ lẹ Osolobuẹ wụ Nẹdi ẹnyi hụn gi ihiẹn-ọsụsụọ o nwẹ ebe ẹnyi rị mẹni ẹnyi ọhụnma ye ẹnyi nkasị-obi itẹbitẹ lẹ olile-ẹnya rị mma,
\v 17 dodo kasị nwan onyẹ-onyẹ imẹ ụnụ obi, mẹ obi ụnụ zekẹnmẹ, ebe oku-ọnụ lẹ ọrụn ọwụlẹ rị mma rị.
\c 3
\cl Isi Nke Ẹtọ
\s1 E Mẹ Ni Ni Ẹnyi Ekpere
\p 
\v 1 Umunẹ, nke ịkpazụụn rịn'a wụ ọnwan: e mẹ ni ni ẹnyi ekpere, nị oku Di-nwọnni-ẹnyi hụn ụzọ ghagbarị ẹgwa; ni wẹ e ye ẹ ọghọ ebe ile—kẹ ụnụ dọn ye ẹ ọghọ.
\v 2 E mẹzikwọ nị nị ẹnyi ekpere ni Osolobuẹ gbapụha ẹnyi ẹka ndị eje-obi lẹ ndị eje-ịhịan, makẹni ẹlẹ ịhịan ile kwerini Osolobuẹ.
\p 
\v 3 Kanị, Di-nwọnni-ẹnyi furu onyẹ wẹ gi e dọn ẹnya; o k'e mẹ ụnụ zekẹnmẹ, chedọn ọnụ—makẹ Eje-onyẹ hụ gha e mẹ ọnụ ihiẹn ọwụlẹ.
\v 4 Makẹni ẹnyi a marịnghọzị ihiẹn Onyẹ-nwẹni-ẹnyi k'a saẹka mẹ, obi ru ẹnyi alị nị ụnụ rị e mẹ ihiẹn ndị ẹnyi sị ụnụ mẹ, ni ụnụ k'e mẹsọnmẹ wẹ.
\p 
\v 5 Di-nwọnni-ẹnyi ya dodo du obi ụnụ ile nị ụnụ ghọta ihiẹn-ọsụsụọ Osolobuẹ nwẹ lẹ okẹn-ndidi Kraịstị, e nwẹzịkwọ wẹ.
\s1 Akụtọpụkwọlẹ Ni Ẹka
\p 
\v 6 Umunẹ, ẹnyi gi nwan ẹfan Onyẹ-nwẹni-ẹnyi wụ Jizọs' Kraịstị e ye ụnụ iwuni: ụnụ lẹ onyẹ Itu-Kraịstị ọwụlẹ kụtọpụ ẹka hụn nke o gi bi kẹ ẹnyi dọn gwa ụnụ akpakwọlẹ.
\v 7 Makẹni ụnụ lẹ enwẹn ụnụ a marịnghọ nị o furu nị ụnụ kịnrịn ẹnyi. Ẹnyi akụtọpụnị ẹka ogẹn ẹnyi lẹ ụnụ gi rị ụzọ ohu;
\v 8 ẹnyi anarịnnị onyẹ ọwụlẹ ihiẹn-oriri bụ ẹnyi akụnị ụgwọ. Ẹnyi a rụn ọrụn a rụngbu enwẹn ẹnyi uhinhin lẹ efinnaị, amamgbe ẹnyi a wụrụnị onyẹ ọwụlẹ imẹ ụnụ ibu.
\v 9 Ẹlẹkwọ nị o runi ẹnyi; mba, ihiẹn runi ẹnyi rọ. Kanị, ẹnyi mẹ ẹrịra kẹni ẹnyi ghọsị ụnụ ihiẹn ụnụ e leri e bi.
\v 10 Kẹ ogẹn ẹnyi gidẹ rị imẹ igunrun ụnụ, ẹnyi ye ụnụ iwuni: “Onyẹ jụ n'ọ rụnkọ, y'e rilẹ.”
\p 
\v 11 Kanị, ẹnyi a nụgụọ nị ndị hụ imẹ ụnụ kụtọfụ ẹka, e busọnmẹ ẹka e che ọrụn rulẹni wẹ; o nwọnni ihiẹn w'a rụn.
\v 12 Ẹnyi gi ẹfan Onyẹ-nwẹni-ẹnyi wụ Jesu e ye ndị nọ ẹrịra iwu, a dụn wẹ ọdụn: wẹ nwẹ ihiẹn ẹka kụma wẹ; wẹ gi ẹka wẹ a lụrụ ihiẹn wẹ e gi bi.
\p 
\v 13 Umunẹ, ndụn imẹ ihiẹn rị mma y'a gụkwọlẹ ụnụ.
\p 
\v 14 Onyẹ ọwụlẹ gbayelẹni ihiẹnni ẹnyi rị nwan e deni ụnụ, ụnụ a kọma a ẹnya, gban'a ọsọ—kẹni ifẹnrẹn mẹ ẹ.
\v 15 Ewerikwọlẹ n'a kẹ eṅẹnrẹn, ka a gba n'a mkpịnsịn-ẹka kẹ nwẹnẹ ụnụ.
\s1 Oku Ịkpazụụn
\p 
\v 16 Di-nwọnni-ẹnyi lẹ enwẹn ẹ, onyẹ hụn udọn gha ẹka a abịa, ya ye ọnụ udọn ogẹn ile lẹ ụzọ ile. Di-nwọnni-ẹnyi ya nọyeni ọnụ ile.
\p 
\v 17 \it Mmẹ wụ Pọlụ gi ẹka m e de ekeleni. Ọnwan wụ mbiye-ẹka m, ẹnịna kẹ m'e biye ẹkụkwọ-ozi m ile ẹka.\it*
\p 
\v 18 Ẹfọma Nna ẹnyi wụ Jesu ya rịnị ọnụ ile.
