\v 13 \w Pues|strong="H3588"\w* \w que|strong="H3588"\w* \w ahora|strong="H6258"\w* yaciera \w yo|strong="H3588"\w*, \w y|strong="H3588"\w* \w reposara|strong="H5117"\w*; durmiera, \w y|strong="H3588"\w* \w entonces|strong="H3588"\w* tuviera \w reposo|strong="H5117"\w*,
