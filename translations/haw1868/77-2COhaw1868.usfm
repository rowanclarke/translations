\id 2CO
\h Korineto II.
\toc1 Korineto II.
\toc2 Korineto II.
\toc3 Korineto II.
\mt1 Korineto II.
\c 1
\s1 O KA EPISETOLE
\q1 
\v 1 O PAULO he lunaolelo na Iesu Kristo, no ka makemake o ke Akua, o Timoteo hoi ka hoahanau, na ka ekalesia o ke Akua ma Korineto, me ka poe hoano a pau e noho ana ma Akaia a puni:
\q1 
\v 2 E alohaia mai oukou, e maluhia hoi i ke Akua i ko kakou Makua, a i ka Haku ia Iesu Kristo.
\b
\q1 
\v 3 E hoomaikaiia ke Akua, ka Makua o ko kakou Haku o Iesu Kristo, o ka Makua nona ke aloha, a o ke Akua hoi nona ka oluolu a pau;
\q1 
\v 4 Nana makou e hooluolu mai i na pilikia a pau o makou, i hiki ia makou ke hooluolu aku i ka poe iloko o na pilikia a pau, ma ka oluolu o makou i hooluoluia mai ai e ke Akua.
\q1 
\v 5 No ka mea, me na hana eha ia mai o makou he nui no Kristo, pela hoi ko makou hooluoluia mai he nui ma o Kristo la.
\q1 
\v 6 No ka mea, a i hoopilikiaia mai makou, he mea ia no oukou e oluolu ai a e ola hoi; a i hooluoluia mai makou, he mea ia no oukou e oluolu ai a e ola hoi; ka mea i hooikaikaia iloko o oukou ma ka hoomanawanui ana i na eha a makou i hana eha ia mai ai.
\q1 
\v 7 Ua kupaa hoi ko makou manaolana no oukou; ua ike hoi, e like me oukou i hui pu ia me makou i na hana eha ia mai, peia no hoi i ka hooluoluia mai.
\q1 
\v 8 Nolaila, e na hoahanau, aole o makou makemake e ike ole oukou i ko makou pilikia i hiki ae io makou la i Asia; no ka mea, ua hoopilikia loa ia makou, aole ikaika iki, aole makou i manao e ola.
\q1 
\v 9 Aka, iloko o makou iho ka hoohewaia e make, i paulele ole ai makou ia makou iho, i ke Akua no nana e hoala ka poe make:
\q1 
\v 10 Oia ka i hoopakele ae ia makou i ka make ino loa; a ke hoopakele nei no ia; a ke manao nei makou ia ia, e hoopakele hou ana oia.
\q1 
\v 11 O oukou hoi e kokua pu mai ana ia makou ma ka pule, i haawiia'ku ke aloha no makou e na kanaka he nui, no ka lokomaikai i loaa mai ia makou ma na kanaka he nui.
\b
\q1 
\v 12 No ka mea, o ko makou kaena keia, o ka hoike ana no o ko makou naau; ma ka manao hookahi a me ka naau kupono i ka ke Akua, aole ma ko ke kino akamai, aka, ma ka lokomaikai o ke Akua, ko makou noho ana i keia ao; a pela io hoi iwaena o oukou.
\q1 
\v 13 No ka mea, o na mea a oukou i heluhelu ai me ka hooiaio mai, a ke manao nei au e hooiaio ana oukou a hiki i ka hope, oia wale no ka makou i palapala aku ai ia oukou.
\q1 
\v 14 No ka mea, ua hooiaio mai no oukou ia makou ma ka hapa, o makou ka oukou e kaena ai; a pela hoi auanei oukou ka makou i ka la o ka Haku o Iesu.
\b
\q1 
\v 15 Me keia manao maopopo, ua ake no au e hele aku io oukou la mamua, i loaa hoi ia oukou ka haawina hou;
\q1 
\v 16 A e hele aku ma o oukou la i Makedonia, a e hoi hou mai io oukou la mai Makedonia mai, a e alakaiia'ku e oukou i Iudea.
\q1 
\v 17 A manao iho la au i keia, he lauwili anei ka'u? a o ka'u mau mea e manao nei, ma ko ke kino anei ko'u manao ana, i ae wale aku au, ae, a hoole wale aku, aole?
\q1 
\v 18 Ma ka oiaio a ke Akua, o ka makou olelo ia oukou, aole ia he hooia a me ka hoole.
\q1 
\v 19 No ka mea o ke Keiki a ke Akua, o Iesu Kristo, ka mea a makou me Silevano a me Timoteo i hai aku ai ia oukou, aole ia he hooia a me ka hoole; aka, iloko ona, he hooia wale no.
\q1 
\v 20 No ka mea, o na olelo a ke Akua a pau, he hooia iloko ona, a he Amene iloko ona, i hoonaniia'i ke Akua e makou.
\q1 
\v 21 O ka mea nana makou i hookupaa'i me oukou iloko o Kristo, nana hoi makou i poni ai, o ke Akua ia;
\q1 
\v 22 Oia hoi ka i hoailona mai ia makou, a i haawi mai hoi i ka makana mua o ka Uhane iloko o ko makou naau.
\b
\q1 
\v 23 Ke kahea aku nei au i ke Akua i mea hoike no kuu uhane, o ka minamina ia oukou ko'u mea i hiki ole aku ai mamua i Korineto.
\q1 
\v 24 Aole no makou e hookoikoi maluna o ko oukou manaoio; aka, ke kokua nei makou i ko oukou olioli: no ka mea, ke ku nei oukou ma ka manaoio.
\c 2
\b
\q1 
\v 1 A KA, o keia ka'u i manao ai, aole e hele hou aku io oukou la me ka eha o ka naau.
\q1 
\v 2 A ina e hana eha aku au i ko oukou naau, owai la auanei e hooluolu mai ia'u; aole anei oia wale no, o ka mea i eha ia'u?
\q1 
\v 3 Nolaila, ua palapala aku au ia oukou i ua mea la, o ehaeha auanei au i ka poe e pono ke hoohauoli mai ia'u i kuu hele ana'ku; ua manao lea hoi au ia oukou a pau, o ko'u olioli ana, o ka oukou hoi ia a pau.
\q1 
\v 4 No ka mea, me ke kaumaha nui, a me ka eha o ka naau, ua palapala aku no au ia oukou me na waimaka he nui; aole no ka hoeha aku i ko oukou naau, aka, i ike oukou i ka nui o ko'u aloha ia oukou.
\b
\q1 
\v 5 A i hooeha mai kekahi, ma ka hapa wale no ka hooeha ana mai ia'u; i hooili ole aku ai au i ka hewa iluna iho o oukou a pau.
\q1 
\v 6 Ua nui keia hoopai ana no ua mea la, i hooukuia'ku e ka nui o oukou.
\q1 
\v 7 No ia mea, he pono no ke kala ae oukou ia ia, me ka hooluolu aku, malia paha o nawaliwali loa auanei ua mea la i ke kaumaha nui.
\q1 
\v 8 Noiaila, ke nonoi aku nei au ia oukou, e hoomaopopo aku i ke aloha ia ia.
\q1 
\v 9 No keia mea hoi, ua palapala aku au, i ike maopopo ai au ia oukou, ina paha oukou e hoolohe mai i na mea a pau.
\q1 
\v 10 A i kala aku oukou i ka mea o kekahi, owau hoi kekahi e kala aku; no ia hoi, ina paha au i kala aku i kekahi mea, no oukou i kala aku ai au ia mea ia ia, ma Kristo:
\q1 
\v 11 I puni ole kakou ia Satana; no ka mea, ua ike kakou i na manao ona.
\b
\q1 
\v 12 A i kuu hele ana i Teroa no ka euanelio a Kristo, a ua weheia'e la ka puka ia'u e ka Haku,
\q1 
\v 13 Aole o'u maha ma kuu naau, i ka loaa ole ia'u o Tito o ko'u hoahanau: aka, uwe aku la au ia lakou, a hele aku la i Makedonia.
\b
\q1 
\v 14 E hoomaikaiia'ku ke Akua nana makou e hoolanakila mau mai iloko o Kristo, me ka hoolaha aku i ke ala o kona naauao i na wahi a pau, ma o makou nei.
\q1 
\v 15 No ka mea, he mea ala makou no Kristo i ke Akua, no ka poe ola a me ka poe make.
\q1 
\v 16 No keia poe, he mea ala make makou e make ai; no keia poe hoi, he mea ala ola e ola'i: owai la hoi ka mea e pono ia ia keia mau mea?
\q1 
\v 17 No ka mea, aole makou e anoninoni i ka olelo a ke Akua, e like me kekahi poe nui; aka, ke olelo nei makou i ka Kristo me ka manao pono, oiaio, no ke Akua mai, imua hoi o ke Akua.
\c 3
\b
\q1 
\v 1 E HOOMAKA hou anei makou e hoomaikai aku ia makou iho? a e hemahema anei makou e like me kekahi poe i na palapala hoike ia oukou, a i na palapala hoike mai o oukou mai?
\q1 
\v 2 O oukou no ka makou palapala i kakauia maloko o ko makou naau, i ikeia a i heluheluia e na kanaka a pau.
\q1 
\v 3 No ka mea, ua hoike akaka ia, o oukou no ka Kristo palapala a makou i hana'i, i kakauia aole me ka inika, aka, me ka Uhane o ke Akua ola; aole maloko o na papa pohaku aka, maloko o na papa io o ka naau.
\q1 
\v 4 Pela ko makou manao maopopo i ke Akua ma o Kristo la:
\q1 
\v 5 Aole hoi e hiki ia makou kekahi mea ma ko makou noonoo ana, o makou wale; aka, o ke Akua no ko makou mea e hiki ai.
\q1 
\v 6 Oia ka i hoomakaukau ia makou i kahuna no ke kauoha hou, aole ma ke kanawai, aka, ma ka Uhane: no ka mea, ke pepehi mai nei ke kanawai, a ke hoola mai nei ka Uhane.
\q1 
\v 7 Ina paha ua nani ka oihana no ka make i kakauia maloko o na pohaku me na huaolelo, i hiki ole i na mamo a Iseraela ke haka pono aku i ka maka o Mose, no ke alohi o kona maka, ka mea e nalowale ana;
\q1 
\v 8 Aole anei e oi nui aku ka nani o ka oihana o ka Uhane?
\q1 
\v 9 No ka mea, ina paha he nani ko ka oihana hoohewa, he oiaio no, ua pakela aku ka nani o ka oihana hoapono.
\q1 
\v 10 No keia mea, aohe nani o kela mea i hoouaniia pela, no keia pakela nani.
\q1 
\v 11 Ina he nani ko kela mea i hoonalowaleia; oiaio, he nani ko ka mea e mau loa aku ana.
\b
\q1 
\v 12 No ia hoi, no ka loaa ana mai ia makou keia manaolana, he olelo wiwo ole ka makou:
\q1 
\v 13 Aole like me Mose i uhi iho ai i kona maka i ka pale, i hiki ole i na mamo a Iseraela ke nana pono i ka hope o ua mea la e nalowale ana:
\q1 
\v 14 Aka, ua hoopouliia ko lakou naau; no ka mea, a hiki i neia manawa, i ka heluhelu ana i ke kauoha kahiko, ua koe no ka pale, aole i weheia; ua pau no hoi ia mea ia Kristo.
\q1 
\v 15 A i neia manawa, i ka heluhelu ana i ka Mose, e kau ana no ua pale la maluna o ko lakou naau.
\q1 
\v 16 Aia huli mai ia i ka Haku, alaila e laweia aku no ua pale la.
\q1 
\v 17 A o ka Haku, oia ka Uhane: a ma kahi e noho ai ka Uhane o ka Haku, ua noa ia wahi.
\q1 
\v 18 Aka, me ka maka i uhi ole ia, ke ike aku nei makou a pau i ka nani o ka Haku, e like me ke aka ma ke aniani, a ua hoano hou ia makou ma ka like ana o ua aka la, ma ka nani e mahuahua ana, e ko ka Haku nona ka Uhane.
\c 4
\b
\q1 
\v 1 NO ia hoi, no ka loaa ana mai o keia oihana ia makou ma ka lokomaikaiia mai, aole o makou manaka.
\q1 
\v 2 Aka, ua kipaku aku makou i na mea huna e hilahila ai, aole makou i hele me ka maalea, aole hoi i nana i ka olelo a ke Akua me ka hoopunipuni; aka, ma ka hoakaka ana'ku i ka oiaio, ke hoike nei makou ia makou iho i na naau a pau o kanaka, he pono imua o ke Akua.
\q1 
\v 3 A i uhiia ka makou euanelio, ua uhiia oia no ka poe e lilo ana i ka make.
\q1 
\v 4 Ma o lakou la, ua hoomakapo mai ko keia ao akua i na naau o ka poe hoomaloka, o akaka mai auanei ia lakou ka malamalama o ka euanelio nani a Kristo; oia ko ke Akua mea like.
\q1 
\v 5 No ka mea, aole makou e hai aku ia makou iho, aka, ia Kristo Iesu i ka Haku: a ia makou iho he mau kauwa na oukou no Iesu.
\q1 
\v 6 No ka mea, o ke Akua nana i kena ka malamalama e poha mai noloko mai o ka pouli, oia ka i hoomalamalama mai iloko o ko makou naau, i malamalama i ikea ka nani o ko Akua ma ka maka o Iesu Kristo.
\b
\q1 
\v 7 Ia makou no keia waiwai iloko o na ipu lepo, i ikea ka mana nui, no ke Akua ia, aole no makou.
\q1 
\v 8 Ua hookeia mai makou a puni, aole nae i pilikia; ua lauwiliia mai makou, aole hoi i pilihua.
\q1 
\v 9 Ua hoomaauia mai makou, aole nae i haaleleia; ua kulaina mai makou, aole hoi i make.
\q1 
\v 10 E lawe mau ana makou ma ke kino i ka make ana o ka Haku o Iesu, i hoikeia hoi ke ola ana o Iesu ma ko makou kino.
\q1 
\v 11 No ka mea, o makou ka poe e ola nei, ua haawi mau ia'ku makou e make no Iesu, i hoikeia hoi ke ola ana o Iesu ma ko makou kino make.
\q1 
\v 12 Nolaila, ke hooikaika nei ka make iloko o makou, a o ke ola iloko o oukou.
\q1 
\v 13 No ka ikaika like o ko makou manaoio, me ka mea i palapalaia, Ua manaoio iho la au, nolaila au i olelo aku ai; ke manaoio nei no hoi makou, nolaila makou e olelo aku nei:
\q1 
\v 14 Ke ike nei makou, o ka mea nana i hoala mai ka Haku o Iesu, e hoala mai no hoi oia ia makou ma o Iesu la, a e hoike pu ae ia makou me oukou.
\q1 
\v 15 No ka mea, no oukou ia mau mea a pau, i hoonui ae ka lokomaikai nui i ka nani o ke Akua, ma ka hoomaikai ana'ku o na mea he nui.
\b
\q1 
\v 16 No ia mea, aole o makou manaka; aka, ina paha ua nawaliwali iho ko makou kino mawaho, ua hooikaika mau ia no nae ko loko, i kela la i keia la.
\q1 
\v 17 No ka mea, o ko makou hoino nuku pokole wale ia no, ke hana mai nei no ia i ka nani nui mau loa no makou:
\q1 
\v 18 I ko makou manao ole ana i na mea i ike maka ia, i na mea no i ike maka ole ia: no ka mea, he pokole na mea i ike maka ia; aka, he mau loa na mea i ike maka ole ia.
\c 5
\b
\q1 
\v 1 NO ka mea, ua ike makou, ina i wawahiia ko makou hale kino lepo, o ka halelewa, e loaa auanei ia makou ka hale na ke Akua, he hale hana ole ia e na lima, ua mau loa iloko o ka lani.
\q1 
\v 2 No ka mea, ke kenakena nei no makou iloko o keia, me ka makemake nui e hookomoia'ku iloko o ko makou hale i ka lani.
\q1 
\v 3 Ina paha i hookomoia makou, aole makou e ikeia mai he hune.
\q1 
\v 4 A ke kenakena nei makou me ke kaumaha e noho ana iloko o ua halelewa nei: aole na ka makemake e hele mawaho, aka, e hookomoia maloko, i aleia ka make e ke ola.
\q1 
\v 5 O ka mea nana makou e hooikaika mai i keia mea, o ke Akua ia, oia hoi ka i haawi mai ia makou i ka makana mua o ka Uhane.
\q1 
\v 6 No ia hoi, he ikaika mau ko makou, no ka ike iho, i ko makou noho ana ma ke kino, ua mamao makou i ka Haku.
\q1 
\v 7 No ka mea, ke hele nei makou ma ka manaoio, aole ma ka ike maka ana.
\q1 
\v 8 Ua ikaika no makou, a ke ake nei no hoi o noho mamao makou i ke kino, a e noho pu me ka Haku.
\q1 
\v 9 Nolaila, ke hooikaika nei makou i oluolu mai ai oia ia makou, ke noho pu makou a ke noho mamao hoi.
\q1 
\v 10 No ka mea, e hoikeia auanei kakou a pau imua o ka noho hookolokolo o Kristo; i loaa i kela mea i keia mea na mea iloko o ke kino, e like me ka mea ana i hana'i, ina paha he maikai, ina paha he hewa.
\b
\q1 
\v 11 No ia hoi, i ko makou ike ana i ka mea makau a ka Haku, ke hoohuli aku nei makou i na kanaka; a ua ike pono ia mai makou e ke Akua; a ke manao nei no hoi au, ua ike pono ia mai makou e ko oukou lunamanao.
\q1 
\v 12 Aole no makou e hoomaikai hou aku ia makou iho ia oukou; aka, ke haawi aku nei makou i ka mea e kaena ai oukou no makou iho, i loaa ia oukou ka mea e hai aku ai i ka poe kaena i ko waho, aole nae i ko ka naau.
\q1 
\v 13 Ina ua oi aku ko makou manao ikaika, no ke Akua no ia; ina ua haahaa iho ko makou manao, no oukou hoi ia.
\q1 
\v 14 Ke koi ikaika mai nei ke aloha o Kristo ia makou; no ka mea, ua akaka i ko makou manao, ina i make kekahi no na mea a pau, ina ua make na mea a pau.
\q1 
\v 15 A make no ia no na mea a pau, i ole e noho hou ai ka poe e ola ana no lakou iho, aka, no ka mea i make a i ala hou mai no lakou.
\q1 
\v 16 Nolaila, aole makou e ike hou aku i kekahi ma ke kino: ina paha na ike makou ia Kristo ma ke kino, aole makou e ike hou aku ia ia malaila.
\q1 
\v 17 No ia mea, ina iloko o Kristo kekahi kanaka, he mea hou oia; ua hala aku la na mea kahiko; aia hoi, ua ano hou ae la na mea a pau.
\q1 
\v 18 Na ke Akua mai no na mea a pau, nana makou i hoolaulea mai nona iho ma o Iesu Kristo la, a haawi mai hoi na makou i ka oihana e hoolaulea aku ai.
\q1 
\v 19 Peneia, ke hoolaulea nei ke Akua i ko ke ao nei nona iho ma o Kristo la, aole no e hoopili ana i ko lakou hewa ia lakou; a ua waiho mai la hoi ia makou i ka olelo e hoolaulea aku ai.
\b
\q1 
\v 20 No ia hoi, he mau elele makou no Kristo, ua like hoi ke Akua me ka mea nonoi aku ma o makou nei, ke noi aku nei makou no Kristo, i hoolauleaia mai oukou i ke Akua.
\q1 
\v 21 No ka mea, ua hoolilo mai la oia ia ia, ka mea hala ole, i mohaihala no kakou, i lilo ai kakou i poe pono i ke Akua ma ona la.
\c 6
\b
\q1 
\v 1 A O makou na hoahana, ke noi aku nei hoi makou, mai lawe makehewa oukou i ka lokomaikai o ke Akua.
\q1 
\v 2 (No ka mea, ke i mai la oia, Ua hoolohe aku la au ia oe i ka manawa i maliuia'i, a ua kokua aku la au ia oe i ka la e ola'i; aia hoi, ano ka manawa e maliuia mai ai; aia hoi, ano ka la e ola'i.)
\q1 
\v 3 Aole no makou e hoohihia aku i kekahi, o olelo ino ia mai ka oihana kahuna.
\q1 
\v 4 Aka, ma na mea a pau e hoike ana ia makou iho i poe kahuna no ke Akua, ma ka hoomanawanui, ma ka hoinoia mai, ma ka poino, ma ka pilikia,
\q1 
\v 5 Ma ka hahauia, ma ka paa ana i na halepaahao, ma ka haunaele, ma ka hooluhi ana, ma ke kiai ana, ma ka hoopololi ana,
\q1 
\v 6 Ma ka maemae ma ka ike, ma ke ahonui, ma ka lokomaikai, ma ka Uhane Hemolele, ma ke aloha hookamani ole,
\q1 
\v 7 Ma ka olelo oiaio, ma ka mana o ke Akua, ma ke kahiko o ka pono ma ka akau a me ka hema,
\q1 
\v 8 Ma ka mahaloia mai a me ka mahalo ole ia mai, ma ka olelo ino ia mai, a me ka olelo maikai ia mai: e like me na mea hoopunipuni, aka, he oiaio nae;
\q1 
\v 9 Like me na mea ike ole ia, a ua kaulana nae; like me ka poe e make ana, aia hoi, ke ola nei makou; like me na mea i hahauia, aole nae i make;
\q1 
\v 10 Like me na mea kaumaha, aka, e olioli mau ana; like me na mea ilihune, a ua waiwai nae na mea he nui ia makou; like me na mea nele loa, a ua loaa no nae na mea a pau.
\b
\q1 
\v 11 E ko Koriueto, ua hamama ae nei ko makou waha ia oukou, ua hooakeaia ko makou naau.
\q1 
\v 12 Aole o oukou pilikia iloko o makou; aka, ua pilikia oukou iloko o ko oukou naau iho.
\q1 
\v 13 I hooukuia mai au ma ka mea like, (ke olelo aku nei au ia oukou me he mau keiki la,) e hooakeaia hoi oukou.
\b
\q1 
\v 14 Mai hoopili ano e ia oukou me na hoomaloka: no ka mea, heaha ke kuikahi ana o ka pono me ka hewa? pehea la hoi e kohu like ai ka malamalama me ka pouli?
\q1 
\v 15 Heaha hoi ka manao hookahi ana o Kristo me Beliala? heaha hoi ke kuleana o ka mea manaoio me ka mea hoomaloka?
\q1 
\v 16 Pehea hoi e ku like ai ka luakini o ke Akua me ko na kii? no ka mea, o oukou ka luakini o ke Akua ola; e like me ka ke Akua i olelo mai ai. E noho pu auanei au me lakou, a e hele pu hoi; owau auanei ko lakou Akua, a o lakou hoi auanei ko'u poe kanaka.
\q1 
\v 17 Nolaila, ke i mai la ka Haku, E puka mai oukou mai waena mai o lakou, i kaawale oukou; mai hoopa aku hoi i ka mea haumia, a e hookipa mai au ia oukou.
\q1 
\v 18 A e lilo no au i Makua no oukou, a e lilo mai hoi oukou i poe keikikane a i poe kaikamahine na'u, wahi a ka Haku mana.
\c 7
\b
\q1 
\v 1 NO ia hoi, e ka poe i alohaia, no ka loaa ana mai ia kakou o neia mau olelo hoopomaikai, e hoomaemae kakou ia kakou iho i na mea paumaele a pau o ke kino a me ka uhane, a hoopaa ana hoi i ka maikai ma ka makau i ke Akua.
\b
\q1 
\v 2 E ike mai oukou ia makou; aole makou i hana ino aku i kekahi, aole hoi makou i hookolohe aku i kekahi, aole no hoi makou i alunu aku i ka kekahi.
\q1 
\v 3 Aole au e olelo aku ia mea no ka hoohewa aku; no ka mea, ua i aku la au mamna, eia oukou iloko o ko makou naau, e make pa a e ola pu hoi.
\q1 
\v 4 He nui ka wiwo ole o kuu olelo ana aku ia oukou, he nui hoi kuu kaena ana no oukou: na piha au i ka oluolu, na nui loa kuu olioli iloko o ko makou popilikia a pau.
\b
\q1 
\v 5 No ka mea, ia makou i hele mai ai i Makedonia, aole i loaa i ko makou kino ka maha iki, ua pilikia makou ma na aoao a pau; mawaho he hakaka, maloko he makau.
\q1 
\v 6 Aka, o ke Akua nana e hooluolu mai i ka poe haahaa, oia ka i hooluolu mai ia makou i ka hele ana mai o Tito;
\q1 
\v 7 Aole wale no i kona hele ana mai; aka, i ka oluolu ana i hooluoluia'i e oukou, i ka hai ana mai ia makou i ko oukou iini ana, i ko oukou uwe ana, a me ko oukou manao ikaika ia'u; nolaila, na nui kuu olioli.
\q1 
\v 8 Nolaila, aole au e mihi nei i kuu hana eha ana ia oukou i ka palapala; ua mihi no nae au mamua; no ka mea, ke ike nei au, he pokole wale no ko oukou eha i na palapala la.
\q1 
\v 9 Ano, ke olioli nei au, aole i ko oukou hana eha ia, aka, i hana eha ia oukou e mihi ai; no ka mea, ua hana eha ia oukou ma ka ke Akua, i loaa ole ia oukou ka hewa e makou.
\q1 
\v 10 No ka mea, o ka eha ana mai i ke Akua, nolaila mai ka mihi ola e mihi ole ia'i: aka, o ka eha ana o ko ke ao nei, oia ka mea e make ai.
\q1 
\v 11 Aia hoi, o na mea la a oukou i hana eha ia'i ma ka ke Akua, he nui ka ikaika i hanaia e ia iloko o oukou, oia, he hoakaka, oia, he huhu, oia, he makau, oia, he iini nui, oia, he manao ikaika, oia, he hoopai! ma na mea a pau, ua hoike mai oukou ia oukou iho, he hala ole i keia mea.
\q1 
\v 12 No ia hoi, aole au i palapala aku ia oukou no ka mea nana ka hana hewa ana'ku, aole hoi no ka mea i hana hewa ia'ku, aka, i akaka ia oukou ko makou malama ana ku ia oukou imua o ke Akua.
\q1 
\v 13 No ia mea, ua hooluoluia mai makou i ko oukou oluolu ana: a ua oi aku ko makou olioli no ka olioli ana o Tito, no ka mea, ua hoomahaia kona naau e oukou a pau.
\q1 
\v 14 No ia mea, ina au i kaena aku ia ia i kekahi mea no oukou, aole o'u hilahila; aka, me makou i olelo aku ai i na mea a pau ia oukou ma ka oiaio, pela hoi ko makou kaena ana imua o Tito, ua ikeia he oiaio.
\q1 
\v 15 A ua mahuahua aku konaaloha ia oukou i kona hoomanao ana i ka hoolohe o oukou a pau, i ko oukou hookipa ana ia ia me ka makau a me ka haalulu.
\q1 
\v 16 He hauoli ko'u, no ka mea, ke manao pono nei au ia oukou ma na mea a pau.
\c 8
\b
\q1 
\v 1 E NA hoahanau, ke hoike aku nei makou ia oukou i ka lokomaikai o ke Akua i haawiia mai i na ekalesia o Makedonia;
\q1 
\v 2 Ia lakou i hoao nui ia mai ai i ka hoino, mahuahua iho la ko lakou olioli, a i ko lakou ilihune loa, mahuahua iho la ko lakou manawalea ana aku.
\q1 
\v 3 No ka mea, ua ike maka au, e like me ko lakou Iako, a nui loa aku, no ko lakou makemake iho,
\q1 
\v 4 Koi ikaika mai la lakou me ke noi mai ia makou, na makou no e malama i ka haawina, a e lawe pu i manawalea na ka poe haipule.
\q1 
\v 5 Aole nae i like me ko makou manao, aka, haawi e aku la lakou mamna ia lakou iho no ka Haku, a no makou hoi, ma ka makemake o ke Akua.
\q1 
\v 6 No ia mea, ua noi aku makou ia Tito; e like me kana i hoomaka'i, pela no hoi oia e hoopau ai i keia haawina mawaena o oukou.
\q1 
\v 7 No ia hoi, no ko oukou mahuahua ana i na inea a pau, i ka manaoio, i ka olelo, i ka ike, i ka ikaika a pau, a me ko oukou aloha mai ia makou; i mahuahua hoi oukou i keia lokomaikai ana'ku.
\q1 
\v 8 Aole au e olelo aku ma ke kanoha, aka, no ka ikaika o kekahi poe, a e hoao hoi i ka oiaio o ko oukou aloha.
\q1 
\v 9 No ka mea, ua ike no oukou i ka lokomaikai o ko kakou Haku o Iesu Kristo, ua waiwai oia, a no oukou i lilo mai ai ia i mea ilihune, i waiwai ai hoi oukou ma kona ilihune.
\q1 
\v 10 Ke hai aku nei au i kun manao i keia mea; he mea pono keia no oukou ka poe i hoomaka, aole i ka hana wale no, aka, i ka makemake hoi i kela makahiki mamua.
\q1 
\v 11 Ano hoi, e hooko oukou i ka hana ana ia mea; e like me ko oukou manao makemake, pela hoi e hooko ai ma ka oukou i loaa mai.
\q1 
\v 12 No ka mea, a i loaa ka manao makemake, ua maliuia mai ia ma ka mea i loaa ia ia, aole ma ka mea i loaa ole.
\q1 
\v 13 Aole o'u makemake e mama na mea e ae, a e kaumaha oukou:
\q1 
\v 14 Aka, i like, i neia manawa e kokua aku ko oukou waiwai i ko lakou ilihune, i kokua mai hoi ko lakou waiwai i ko oukou ilihune, i like pu:
\q1 
\v 15 E like me ka mea i palapalaia, o ka mea i hoiliili nui, aohe mea i oi aku nana; a o ka mea i hoiliili liilii, aole i emi kana.
\b
\q1 
\v 16 E alohaia ke Akua nana i haawi mai keia manao ikaika iloko o ka naau o Tito no oukou.
\q1 
\v 17 No ka mea, ua hoolohe mai la ia i ka olelo hooikaika; aka, i ka oi ana aku o kona ikaika, hele aku la ia io oukou la ma kona manao iho.
\q1 
\v 18 A ua hoouna pu aku la makou me ia i ka hoahanau, nona ka hoomaikaiia mai ma na ekalesia a pau, no ka euanelio.
\q1 
\v 19 Aole keia wale no, aka, ua waeia hoi oia e na ekalesia i hoahele no makou me keia haawina i laweia e makou no ka nani o ka Haku, a me ka hoike ana'ku i ko oukou lokomaikai.
\q1 
\v 20 E makaala'na i keia, o olelo ino ia mai makou e kekahi i keia mea nui a makou e malama nei.
\q1 
\v 21 E hoomanao e ana i na mea maikai, aole imua o ke Akua wale no, imua hoi o kanaka.
\q1 
\v 22 A ua hoouna pu aku la makou i ko makou hoahanau me lakou, i ka mea a makou i ike pinepine ai, na ikaika i na mea he nui; ano, ua nui aku kona ikaika, i ka nui o kona manao maopopo ia oukou.
\q1 
\v 23 A i ninauia mai o Tito, o kuu hoapili ia a me kuu hoahana no oukou; a o na hoahanau hoi o makou, o lakou ka poe elele no na ekalesia, a me ka nani o Kristo.
\q1 
\v 24 Nolaila, e hoike mai ia lakou, a imua hoi o na ekalesia i ka oiaio o ko oukou aloha, a me ko makou kaena ana no oukou.
\c 9
\b
\q1 
\v 1 A KA hoi, no ka manawalea ana i ka poe haipule, he mea hana wale ka'u ke palapala aku ia oukou.
\q1 
\v 2 No ka mea, ke ike nei au i ka makaukau ana o ko oukou naau, oia ka'u i kaena aku ai no oukou i ko Makedonia, ua makaukau no ko Akaia i keia makahiki mamua; a o ko oukou ikaika ka mea i ikaika ai na mea he nui.
\q1 
\v 3 Aka, ua hoouna aku au i na hoahanau, o make hewa paha ko makou kaena ana i keia mea no oukou; i makaukau hoi oukou me ka'u i olelo aku ai:
\q1 
\v 4 Malia paha o hilahila auanei makou, (aole o oukou hoi ka makou e i aku nei,) i keia kaena ikaika ana, ke hele pu aku nei ko Makedonia me au, a loaa oukou aole i makaukau.
\q1 
\v 5 No ia mea, he pono i kuu manao e noi aku i ua mau hoahanau la e hele e mamua io oukou la e hoomakaukau i ko oukou haawina i olelo e ia mamua, i makaukau ai ua mea la, me he haawina la, aole me he mea ohiia la.
\b
\q1 
\v 6 O keia hoi ka'u, O ka mea lulu Iiilii, e hoiliili liilii no ia; a o ka mea lulu nui, e hoiliili nui no hoi oia;
\q1 
\v 7 E like me ka manao ana o kela mea keia mea iloko o kona naau, pela ia e haawi aku ai, aole me ka minamina, aole hoi me he mea la i auhauia; no ka mea, ke aloha mai nei no ke Akua i ka mea nana e haawi oluolu aku.
\q1 
\v 8 A e hiki no i ke Akua ke hoonui ae i na mea maikai a pau ia oukou; i lako mau oukou i na mea a pau, i mahuahua ka oukou hana maikai ana ma na mea a pau:
\q1 
\v 9 Me ka mea i palapalaia, Ua hooleilei aku la ia, ua haawi aku la ua ka poe ilihune: e mau loa ana kona pono.
\q1 
\v 10 A o ka mea nana e haawi mai i ka hua na ka mea lulu, a me ka ai e ai ai, e haawi mai no ia, a e hoonui hoi i ka oukou hua i luluia, me ka hoomahuahua i na hua o ko oukou pono:
\q1 
\v 11 I lako oukou i na mea a pau, i nui ai ko oukou lokomaikai, oia ka mea e hoomaikaiia'ku ai ke Akua ma o makou la.
\q1 
\v 12 No ka mea, o ka hana ana i keia oihana ka mea e pau ai ka nele o ka poe haipule; aole ia wale no, ka mea hoi ia e mahuahua ai ka hoomaikai nui aku i ke Akua;
\q1 
\v 13 No ka ike maopopo ana i keia lokomaikai, e hoonani aku lakou i ke Akua no ko oukou hooia ana e hoolohe i ka euanelio a Kristo, a no ka lokomaikai hoi o ka makana ia lakou, a i na mea a pau;
\q1 
\v 14 A i ka lakou pule ana no oukou, me ka makemake nui ia oukou no ka lokomaikai nui o ke Akua maluna o oukou.
\q1 
\v 15 E alohaia'ku ke Akua no kona makana nui aole e hiki ke haiia'ku.
\c 10
\b
\q1 
\v 1 O WAU iho, o Paulo, ka mea haahaa i ko'u noho ana me oukou, aka, ma kahi e ua au ko'u manao ia oukou, ke noi aku nei au ia oukou ma ke akahai a me ka oluolu o Kristo.
\q1 
\v 2 Ke noi aku nei au, i aa ole ko'u naau me oukou, e like me ko'u manao e aa aku i kekahi poe e manao mai ana ia makou, ua holo makou mamuli o ke kino.
\q1 
\v 3 No ka mea, ke noho nei makou me ke kino, aole nae makou e kaua aku mamuli o ke kino.
\q1 
\v 4 (Aole no ke ao nei na mea kaua o ko makou kaua ana; aka, he ikaika nae i ke Akua o hoohiolo iho ai i na pakaua;)
\q1 
\v 5 E hoohiolo ana hoi i na manao, a me na mea kiekie a pau e hookiekie ana ae, e ku e i ka naanao o ke Akua, a e kai pio ana i na inanao a pau i ka hoolohe aku ia Kristo:
\q1 
\v 6 Ua makaukau hoi makou e hoopai aku i ka hookuli a pau, aia ku pono mai ko oukou hoolohe.
\q1 
\v 7 Ke nana nei anei oukou i na mea ma ka helehelena? A i manao kekahi ia ia iho, ua lilo ia no Kristo, he pono no e manao hou ia ia iho, me ia i lilo ai no Kristo, pela no hoi makou i lilo ai no Kristo.
\q1 
\v 8 No ka mea, ina paha wau e kaena nui aku i ko makou mana a ke Akua i haawi mai ai ia makou no ke kukulu paa, aole no ka luku aku ia oukou, aole no au e hilahila:
\q1 
\v 9 I manao ole ia mai au e hooweliweli aku ana ia oukou ma na palapala.
\q1 
\v 10 Ke olelo ae la lakou, Ua koikoi a ua ikaika kana mau palapala; aka, ua palupalu kona kino ma ke kokoke, a o kana olelo ana, oia ke hoowahawahaia.
\q1 
\v 11 O ka mea i olelo pela, eia kana e manao pono ai; e like me ka makou olelo ana ma ka palapala ma kahi e, pela io no auanei makou e hana aku ai ma ke kokoke.
\q1 
\v 12 Aole makou e hiki ke hoopili aku, aole hoi e hoohalike aku ia makou iho me kekahi poe e hoomaikai ana ia lakou iho; no ka mea, i ke ana ana ia lakou iho ma ko lakou iho, a i ka hoohalike ana ia lakou iho me ko lakou iho, aole i naauao lakou.
\q1 
\v 13 Aole makou e kaena i na mea i ana ole ia, aka, e like me ke ana o ka mokuna a ke Akua i haawi mai ai, e hiki aku ana io oukou la.
\q1 
\v 14 Aole makou i hele ma o aku o ko makou mokuna me he hiki ole aku io oukou la; aka, ua hiki aku hoi makou io oukou la me ka euanelio a Kristo.
\q1 
\v 15 Aole no makou e kaena aku i na mea i ana ole ia maloko o na hana a hai; aka, ke manao nei makou, aia mahuahua ae ko oukou manaoio, e hoonui loa ia'e makou e oukou maloko o ko makou mokuna,
\q1 
\v 16 I hai aku ai makou i ka euanelio ma o aku o ko oukou wahi, aole no hoi e kaena aku i na mea i hoomakaukau e ia mai maloko o ko hai mokuna.
\q1 
\v 17 A o ka mea e kaena ana, he pono no ia e kaena i ka ka Haku.
\q1 
\v 18 No ka mea, aole i aponoia mai ka mea hoomaikai ia ia iho, aka, o ka mea a ka Haku i hoomaikai mai.
\c 11
\b
\q1 
\v 1 KE ake nei au, e hoomanawanui iki mai oukou ia'u, i kuu naaupo ana; oia e hoomanawanui mai hoi oukou ia'u.
\q1 
\v 2 Ke minamina nei au ia oukou ine ka minamina o ke Akua, no ka mea, ua hoopalau aku la au ia oukou na ke kane hookahi, i haawi aku ai ia oukou i wahine puupaa hala ole na Kristo.
\q1 
\v 3 Aka, ke makau nei au, o hoohuliia'e ko oukou naau mai ka pono io aku o Kristo, e like me ka nahesa i hoowalewale aku ai ia Eva i kona maalea.
\q1 
\v 4 Ina paha e hai aku ka mea i holo mai i kekahi Iesu okoa, aole ka makou i hai aku ai, a i loaa ia oukou ka uhano okoa, i loaa ole ia oukou mamua, a i ka euanelio okoa, a oukou i lohe ole ai mamua, ina ua pono no oukou ke hoomanawanui aku.
\q1 
\v 5 No ka mea, ke manao nei au, aole au i emi iki mahope o ke pookela o na lunaolelo.
\q1 
\v 6 Ina paha he hawawa ko'u i ka olelo, aole nae i ka naauao; aka, ua hoike akaka ia'ku makou iwaena o oukou ma na mea a pau.
\q1 
\v 7 Ua hana hewa anei au i ka hoohaahaa ana ia'u iho, i hookiekieia'e oukou; no ka hai wale aku ana a'u ia oukou i ka euanelio a ke Akua me ka uku ole ia mai?
\q1 
\v 8 Ua ohi aku la au i ka na ekalesia e ae i uku na'u, i hookauwa aku ai au na oukou.
\q1 
\v 9 A i kuu noho pu ana me oukou a nele, aole i kanmaha kekahi ia'u: no ka mea, o na hoahanau mai Makedonia mai ua hoolakolako mai lakou ia'u i kuu mea nele: na malama au ia'u iho i na mea a pau i kaumaha ole ai oukou ia'u, a pela aku au e malama iho ai.
\q1 
\v 10 Ma ka oiaio o Kristo iloko o'u, aole loa e okiia keia kaena ana no'u ma na aina i Akaia.
\q1 
\v 11 No ke aha? no kuu aloha ole anei ia oukou? O ke Akua ke ike.
\q1 
\v 12 Aka, o ka'u e hana nei, o ka'u ia e hana hou aku ai, i hooki ai au i ka manawa maopopo, no ka poe imi i ka manawa maopopo; i ikea lakou e like pu me makou ma ka mea e kaena aku ai lakou.
\q1 
\v 13 No ka mea, o ua poe la, he poe lunaolelo wahahee lakou, he poe lawehala hoopunipuni, e hoano hou ana ia lakou iho i poe lunaolelo na Kristo.
\q1 
\v 14 Aole ia he mea kupanaha; no ka mea, ua hoano hou ae la o Satana ia ia iho me he anela la o ka malamalama.
\q1 
\v 15 No ia hoi, aole ia he mea kupanaha ke ano hou ae na kahuna nona e like me na kahuna o ka pono; a e like auanei ko lakou hope me na hana a lakou.
\b
\q1 
\v 16 Ke olelo aku nei hoi au, Mai manao mai kekahi ia'u he naaupo; ina aole pela, e launa mai hoi oukou ia'u me he naaupo la, i kaena iki aku ai hoi au.
\q1 
\v 17 O ka'u e olelo aku nei i keia kaena ikaika ana, aole au e olelo ma ka ka Haku, aka, he like me ka ka naaupo.
\q1 
\v 18 No ia mea, no ke kaena ana o na mea he nui ma ko ke kino, owau hoi kekahi e kaena aku nei.
\q1 
\v 19 No ka mea, o oukou ka poe naauao, ke hoomanawanui nei oukou i ka poe naaupo me ka oluolu.
\q1 
\v 20 Ina paha e hookauwaia oukou e kekahi, ina paha i ai kekahi i ka oukou, ina paha e la we wale kekahi i ka oukou, ina paha e hookiekie ae kekahi, ina paha e pai aku kekahi ia oukou ma ka maka, ke hoomanawanui nei hoi oukou.
\q1 
\v 21 Ke olelo nei au no ka hoino ana, me he nawaliwali ko makou; aka, ma ka mea e maoi ku ai kekahi, (ke olelo naaupo nei au,) owau no hoi e maoi nei.
\q1 
\v 22 He poe Hebera anei lakou? pela no hoi au: no ka Iseraela anei lakou? owau no hoi: he mamo anei lakou na Aberahama? pela hoi au.
\q1 
\v 23 He poe kahuna anei lakou na Kristo? (ke olelo naaupo nei au,) owau ke oi aku: ua pakela aku au ma na hooluhi ana, he nui aku ko'u hahauia, he pinepine aku hoi kuu paa aua i na halepaahao, he nui wale hoi kuu make ana.
\q1 
\v 24 Elima o'u hahau ana e ka poe ludaio i na kaula he kanakolukumamaiwa,
\q1 
\v 25 Ekolu o'u hahau ana i na laan; akahi o'u hailuku ana i na pokahu; ekolu o'u make ana i ka moana: akahi po akahi ao o'u iloko o ka hohonu.
\q1 
\v 26 He pinepine kuu hele ana, he pilikia i na maliwai, he pilikia hoi i na powa, he pilikia i o'u hoahanauna kanaka, he pilikia i kanaka e, he pilikia iloko o ke kulanakauhale; he pilikia hoi ma ka waoakua, he pilikia i ke kai, he pilikia hoi iwaena o na hoahauau hoopunipuni;
\q1 
\v 27 I ka hana kaumauha a me ka luhi loa, i ka makaala pinepine ana, i ka pololi a me ka make wai ana, i ka hookeai pinepine ana, i ke ana a me ka olohelohe.
\q1 
\v 28 He okoa na mea mawaho, na kaumaha loa wau i kela la i keia la, i ka malama nui ana i na ekalesia a pau.
\q1 
\v 29 Owai la ka mea palupalu, aole hoi au kekahi i palupalu? owai la ka mea i hoohihiaia, aole hoi au i aa?
\q1 
\v 30 Ina paha e pono ia'u ke kaena aku, e kaena aku no au i na mea o kuu nawaliwali.
\q1 
\v 31 O ke Akua, o ka Makua o ko kakon Haku o leau Kristo, o ka mea i hoomaikai mau loa ia, ua ike no oia, aole o'u hoopunipuni.
\q1 
\v 32 Aia ma Damaseko, ke kiaaina o ke alii o Areta, i kiai ai i ke kulanakanhale o ko Damase ko me ka poe koa, e inanao ana e hopu mai ia'u:
\q1 
\v 33 A ma ka puka makani i kunia iho ai au maloko o ka hinai mawaho o ka pa a pakele aku la au i kona lima.
\c 12
\b
\q1 
\v 1 A OLE paha o'u pono ke kaena aku: aka, e hiki nuanei au ma na hihio a me na hoike ana mai a ka Haku.
\q1 
\v 2 I na makahiki mamna, he umikumamaha, ua ike no au i kekahi kanaka no Kristo, iloko o ke kino paha, aole au i ike, iwaho e ke kino paha, aole au i ike, o ke Akua ke ike; ua laweia'ku la na mea la iluna i ke kolu'o ka lani.
\q1 
\v 3 O ua kanaka la ka'u i ike, iloko o ke kino paha, iwaho e ke kine paha, aole au i ike, o ke Akua ke ike:
\q1 
\v 4 Ua laweia'ku oia iluna I paradaiso, a lohe ae ia ia i na huaolelo hiki ole ke pane ae, aole hoi e pono ke ekemuiaku e ke kanaka.
\q1 
\v 5 No ua mea la ka'u e kaena aku ai: aole no'u iho ka'u o kaena ai, aka, no ko'u mau mea palupalu.
\q1 
\v 6 Ina paha i ake au e kaena aku, aole o'u naaupo; no ka mea, e hai aku ana au i ka oiaio: aka, ke oki nei no au, o manao mai paha kekahi ia'u he kiekie maluna o kana i ike mai ai ia'u, a me kana i iohe mai ai ia'u.
\q1 
\v 7 O hookiekie paha wau no ka nui o na mea i hoikeia mai, ua haawiia mai ia'u he mea oioi ma kuu io, he elele na Satana e kui mai ai ia'u, o hookiekie auanei au.
\q1 
\v 8 No ia mea, ekolu au noi ana aku i ka Haku, i haalele mai ia mea ia'u.
\q1 
\v 9 I mai la kela ia'u, Ua lawa kuu lokomaikai nou: no ka mea, ma ka nawaliwali ka hoomaopopo ana o ko'u mana. No ia hoi, e kaena aku au me ka oluolu i kuu nawaliwali, i kau mai ai ka mana o Kristo maluna iho o'u.
\q1 
\v 10 Nolaila, he oluolu ko'u i ka nawaliwali, a me ka hoinoia, a me ka poino, a me ka hoomaauia, a me ka pilikia no Kristo: no ka mea, i kuu nawaliwali ana, alaila ua ikaika au.
\b
\q1 
\v 11 Ua lilo au i naaupo ma ke kaena ana; na oukou au i koi mai: no ka mea, he pono ko'u e hoomaikaiia mai e oukou; aole au i emi iki mahope o na lunaolelo pookela, he mea ole no nae au.
\q1 
\v 12 He oiaio, na hanaia na oihana lunaolelo iwaena o oukou me ka hoomanawanui, me na hoailona, me na mea kupanaha a me na hana mana.
\q1 
\v 13 Mahea ko oukou wnhi emi mahope o na ekalesia e ae, ke waiho ko oukou kaumaha ole ia'u? E kala mai oukou ia'u i keia mea pono ole.
\b
\q1 
\v 14 Aia hoi, eia ke kolu o kuu makankau e hele aku io oukou la; aole au e hookaumaha ia oukou; no ka mea, o oukou ka'u e imi nei, aole ka oukou: aole e pono no na keiki ke hoahu aku na na makua, aka, o na makua na na keiki.
\q1 
\v 15 A ua oluolu au ke lilo aku a e hooliloia hoi no ko oukou uhane; ina paha me ka mahuahua o ko'u aloha aka ia oukou, pela ka emi ana o ko'u alohaia mai.
\q1 
\v 16 A oia no pela, aole no oukou i kaumaha ia'u: aka, ua maalea au, nolaila ua puni oukou ia'u.
\q1 
\v 17 Ua waiwai anei au ia oukou ma kekahi o ka poe a'u i hoouna aku ai io oukou la?
\q1 
\v 18 Noi aku la au ia Tito, a hoouna pu aku la au me ia i kekahi hoahanau: ua waiwai anei o Tito ia oukou? aole anei makou i hele ma ka manao hookahi, a ma ke kapuwai hookahi?
\b
\q1 
\v 19 Eia hoi, ke manao nei anei oukou e hoakaka makou ia makou iho ia oukou? E na mea aloha, ke olelo nei makou imua o ke Akua ma o Kristo la, no ka hookupaa aku ia oukou keia mau mea a pau.
\q1 
\v 20 No ka mea, ko makau nei au, a i kuu hiki aku, e ike aku paha auanei au ia oukou aohe like me kuu makemake, a e ikea mai hoi au e oukou aohe like me ko oukou makemake: malia paha o ikea auanei ka hakaka, ka ukiuki, ka inaina, ka hoopaapaa, ke aki, ka ohumu, ka hoohaha, a me ka haunaele.
\q1 
\v 21 Anoai paha o hoohaahaa iho no hoi kuu Akua ia'u iwaena o oukou, i kuu hiki hou ana'ku; a kanikau iho au i na mea he nui i hana hewa e mamua, aole hoi i mihi i ka haumia, a me ka moekolohe, a me ke kuulala a lakou i hana'i.
\c 13
\b
\q1 
\v 1 EIA ke kolu o kuu hele ana'ku io oukou la; ma ka waha o na mea ike elua, a ekolu paha e hookupaaia'i ua mea a pau.
\q1 
\v 2 Ua hai e aku au mamua, ke hai e aku nei hoi au, e like me au e noho hou ana me oukou; aka, ma kahi e ke palapala aku nei au i ka poe i hana hewa mamua, a me na mea e ae a pau, a hiki hou aku au, aole au e minamina ia lakou.
\q1 
\v 3 No ka mea, ke imi nei oukou i ka mea e akaka ai ka Kristo olelo ana mai ma o'u nei aole ona nawaliwali ma o oukou la, aka, he ikaika kona iwaena o oukou.
\q1 
\v 4 No ka mea, ina paha i kaulia'i oia ma ke kea no ka nawaliwali, e ola ana no hoi ia ma ka mana o ke Akua: ua nawaliwali no hoi makou iloko ona, aka, e ola ana no hoi makou me ia ma ka mana o ke Akua iwaena o oukou.
\q1 
\v 5 E hoao oukou ia oukou iho, aia ma ka manaoio paha oukou; e huli oukou ia oukou iho i pono: aole anei oukou i ike ia oukou iho, aia no Iesu Kristo iloko o oukou, ke ahewa ole ia oukou?
\q1 
\v 6 Aka, ke manao nei au, e ike auanei oukou, aole makou e ahewaia.
\q1 
\v 7 A ke pule aku nei au i ke Akua i ole oukou e hana hewa iki; aole no ka ikeia o ko makou pono, aka, e hana aku oukou i ka mea maikai, ke manaoia mai makou he pono ole.
\q1 
\v 8 No ka mea, aole e pono ia makou ke hana i kekahi mea ku e i ka oiaio, aka, i ka mea ku pono i ka oiaio.
\q1 
\v 9 Ke hauoli nei makou i ko makou nawaliwali, a i ko oukou ikaika: eia hoi ka makou e pule aku nei, i hemolele oukou.
\q1 
\v 10 No ia hoi, ke palapala aku nei au ia mau mea ma kahi e, o hoowalania aku au ke hiki aku io oukou la, e like me ka mana a ka Haku i haawi mai ai no'u, no ka hookupaa, aole no ka luku aku.
\b
\q1 
\v 11 Eia ke oki, e na hoahauau, aloha oukou; i hemolele oukou, i oluolu hoi, i hookahi ko oukou manao, e noho oukou me ke kuikahi: a o ke Akua nona ke aloha a me ke kuikahi e noho pu me oukou.
\q1 
\v 12 E uwe aku kekahi i kekahi, i ka honi hoano.
\q1 
\v 13 Ke uwe aku nei na haipule a pau ia oukou.
\b
\q1 
\v 14 I mau aku ka lokomaikai o ka Haku o Iesu Kristo, me ke aloha o ke Akua, a me ka launa pu ana o ka Uhane Hemolele me oukou a pau. Amene. 
