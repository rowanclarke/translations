\v 23 Te \w phoeiah|strong="G2532"\w* \w anih|strong="G0846"\w* taengah \w rhep|strong="G4183"\w* a \w toemngam|strong="G3660"\w* tih, “\w Kai|strong="G3165"\w* taengah na \w bih|strong="G0154"\w* \w te|strong="G3739"\w* \w tah|strong="G1437"\w* \w ka|strong="G3450"\w* \w ram|strong="G0932"\w* \w rhakthuem|strong="G2255"\w* \w hil|strong="G2193"\w* khaw \w nang|strong="G4671"\w* kan \w paek|strong="G1325"\w* ni,” a ti nah.  
\v 24 \w Tedae|strong="G2532"\w* \w cet|strong="G1831"\w* tih \w a|strong="G0846"\w* \w manu|strong="G3384"\w* \w taengah|strong="G3588"\w*, “\w Balae|strong="G5101"\w* ka \w bih|strong="G0154"\w* eh?” a \w ti|strong="G2036"\w* nah \w hatah|strong="G1161"\w* a manu \w loh|strong="G3588"\w*, “\w Tuinuem|strong="G0907"\w* \w Johan|strong="G2491"\w* kah a \w lu|strong="G2776"\w* \w te|strong="G3588"\w*,” a \w ti|strong="G2036"\w* nah.   
\p
