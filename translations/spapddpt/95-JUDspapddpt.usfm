\v 2 \w Misericordia|strong="G1656"\w*, \w paz|strong="G1515"\w* \w y|strong="G2532"\w* amor les sean multiplicados.   
\s1 Contra falsas enseñanzas  
\p
\v 3 Amados, \w con|strong="G3588"\w* \w toda|strong="G3956"\w* \w diligencia|strong="G4710"\w* \w para|strong="G4012"\w* escribirles \w con|strong="G3588"\w* \w respecto|strong="G4012"\w* a \w nuestra|strong="G3588"\w* \w común|strong="G2839"\w* \w salvación|strong="G4991"\w*, \w tuve|strong="G2192"\w* necesidad \w de|strong="G4012"\w* \w escribir|strong="G1125"\w* \w para|strong="G4012"\w* exhortarlos a \w que|strong="G3588"\w* luchen ardientemente \w por|strong="G4012"\w* \w la|strong="G3588"\w* \w fe|strong="G4102"\w* \w que|strong="G3588"\w* fue dada \w una|strong="G3588"\w* vez a \w los|strong="G3588"\w* santos.  
\v 4 \w Porque|strong="G1063"\w* entraron disimuladamente \w ciertos|strong="G5100"\w* hombres impíos, \w los|strong="G3588"\w* cuales fueron destinados desde tiempo antiguo \w para|strong="G1519"\w* \w este|strong="G3778"\w* \w juicio|strong="G2917"\w*, \w que|strong="G3588"\w* convierten \w la|strong="G3588"\w* \w gracia|strong="G5485"\w* \w de|strong="G1519"\w* \w nuestro|strong="G2249"\w* \w Dios|strong="G2316"\w* \w en|strong="G1519"\w* inclinación \w a|strong="G1519"\w* deleites carnales, \w y|strong="G2532"\w* \w se|strong="G2532"\w* levantan \w contra|strong="G1519"\w* \w el|strong="G3588"\w* único Soberano \w y|strong="G2532"\w* \w contra|strong="G1519"\w* \w Jesucristo|strong="G2424"\w* \w nuestro|strong="G2249"\w* \w Señor|strong="G2962"\w*.   
\p
\v 5 Les recuerdo \w a|strong="G1537"\w* \w los|strong="G3588"\w* \w que|strong="G3754"\w* \w saben|strong="G1492"\w* \w todas|strong="G3956"\w* \w las|strong="G3588"\w* cosas, \w que|strong="G3754"\w* \add el\add* \w Señor|strong="G2962"\w*, \w luego|strong="G1208"\w* \w de|strong="G1537"\w* liberar \w una|strong="G3588"\w* vez \w al|strong="G3588"\w* \w pueblo|strong="G2992"\w* \w de|strong="G1537"\w* \add la\add* \w tierra|strong="G1093"\w* \w de|strong="G1537"\w* \w Egipto|strong="G1093"\w*, \w en|strong="G1537"\w* \w segundo|strong="G1208"\w* lugar destruyó \w a|strong="G1537"\w* \w los|strong="G3588"\w* \w que|strong="G3754"\w* \w no|strong="G3361"\w* \w creyeron|strong="G4100"\w*.  
\v 6 \w A|strong="G1519"\w* \w los|strong="G3588"\w* ángeles \w que|strong="G3588"\w* \w no|strong="G3361"\w* \w guardaron|strong="G5083"\w* \w su|strong="G3588"\w* esfera \w de|strong="G5259"\w* influencia, \w sino|strong="G3361"\w* abandonaron \w su|strong="G3588"\w* \w propia|strong="G2398"\w* morada, ha mantenido \w bajo|strong="G5259"\w* \w oscuridad|strong="G2217"\w* \w en|strong="G1519"\w* \w prisiones|strong="G1199"\w* eternas, \w para|strong="G1519"\w* \add el\add* \w juicio|strong="G2920"\w* \w del|strong="G3588"\w* \w gran|strong="G3173"\w* \w día|strong="G2250"\w*.  
\v 7 \w Como|strong="G5613"\w* \w Sodoma|strong="G4670"\w* \w y|strong="G2532"\w* \w Gomorra|strong="G1116"\w*, \w y|strong="G2532"\w* \w las|strong="G3588"\w* \w ciudades|strong="G4172"\w* \w alrededor|strong="G4012"\w* \w de|strong="G4012"\w* \w ellas|strong="G3588"\w*, \w las|strong="G3588"\w* cuales, \w de|strong="G4012"\w* \w la|strong="G3588"\w* misma \w manera|strong="G5158"\w* \w que|strong="G3588"\w* \w éstos|strong="G3778"\w*, \w por|strong="G4012"\w* practicar inmoralidad sexual \w e|strong="G2532"\w* ir \w en|strong="G4012"\w* \w pos|strong="G3694"\w* \w de|strong="G4012"\w* \w otra|strong="G2087"\w* \w carne|strong="G4561"\w*, son exhibidas \w como|strong="G5613"\w* ejemplo \w y|strong="G2532"\w* sufrieron \w un|strong="G3588"\w* castigo \w de|strong="G4012"\w* \w fuego|strong="G4442"\w* eterno.   
\p
\v 8 \w De|strong="G1161"\w* igual manera \w éstos|strong="G3778"\w* \w que|strong="G2532"\w* tienen visiones \w ciertamente|strong="G3303"\w* contaminan \add el \add*cuerpo, rechazan \add la \add*autoridad \w y|strong="G2532"\w* hablan mal \w de|strong="G1161"\w* \w los|strong="G2532"\w* gloriosos seres angelicales.  
\v 9 \w Pero|strong="G1161"\w* \w cuando|strong="G3753"\w* \w el|strong="G3588"\w* arcángel \w Miguel|strong="G3413"\w*, \w al|strong="G3588"\w* contender \w con|strong="G1161"\w* \w el|strong="G3588"\w* \w diablo|strong="G1228"\w* \w para|strong="G4012"\w* expresarse \w con|strong="G1161"\w* \w respecto|strong="G4012"\w* \w al|strong="G3588"\w* \w cuerpo|strong="G4983"\w* \w de|strong="G4012"\w* \w Moisés|strong="G3475"\w*, \w no|strong="G3756"\w* se atrevió \w a|strong="G1161"\w* pronunciar \w juicio|strong="G2920"\w* \w de|strong="G4012"\w* maldición, \w sino|strong="G1161"\w* \w dijo|strong="G3004"\w*: \add ¡El\add* \w Señor|strong="G2962"\w* \w te|strong="G4771"\w* \w reprenda|strong="G2008"\w*!  
\v 10 \w Pero|strong="G1161"\w* \w estos|strong="G3778"\w* \w ciertamente|strong="G3303"\w* hablan mal \w de|strong="G1722"\w* cuantas \w cosas|strong="G3745"\w* \w no|strong="G3756"\w* entienden, \w y|strong="G1161"\w* \w en|strong="G1722"\w* \w aquellas|strong="G3588"\w* \w que|strong="G3588"\w* \w por|strong="G1722"\w* instinto entienden son corrompidos \w como|strong="G5613"\w* \w los|strong="G3588"\w* \w animales|strong="G2226"\w* irracionales.  
\v 11 ¡\w Ay|strong="G3759"\w* \w de|strong="G3588"\w* \w ellos|strong="G3588"\w*! \w Porque|strong="G3754"\w* \w fueron|strong="G4198"\w* conducidos \w por|strong="G3754"\w* \w el|strong="G3588"\w* \w camino|strong="G3598"\w* \w de|strong="G3588"\w* \w Caín|strong="G2535"\w*, \w fueron|strong="G4198"\w* lanzados \w por|strong="G3754"\w* lucro \w al|strong="G3588"\w* engaño \w de|strong="G3588"\w* Balaam \w y|strong="G2532"\w* \w se|strong="G2532"\w* arruinaron \w en|strong="G3588"\w* \w la|strong="G3588"\w* rebelión \w de|strong="G3588"\w* Coré.   
\p
\v 12 ¡\w Éstos|strong="G3778"\w* \w son|strong="G1510"\w* \w los|strong="G3588"\w* \w que|strong="G3588"\w*, \w en|strong="G1722"\w* \w las|strong="G3588"\w* comidas fraternales \w de|strong="G1722"\w* ustedes, \w se|strong="G1438"\w* apacientan \w a|strong="G1722"\w* \w sí|strong="G1438"\w* mismos, \w son|strong="G1510"\w* agasajados \w con|strong="G1722"\w* ustedes sin respeto, \w nubes|strong="G3507"\w* sin agua llevadas \w por|strong="G1722"\w* vientos, \w árboles|strong="G1186"\w* otoñales sin fruto, \w dos|strong="G1364"\w* veces muertos, desarraigados,  
\v 13 salvajes \w olas|strong="G2949"\w* \w de|strong="G1519"\w* \w mar|strong="G2281"\w* \w que|strong="G3588"\w* espuman \w sus|strong="G3588"\w* mismas obras vergonzosas, estrellas \w erráticas|strong="G4107"\w*, \w para|strong="G1519"\w* \w quienes|strong="G3739"\w* fue \w reservada|strong="G5083"\w* \w la|strong="G3588"\w* más negra \w oscuridad|strong="G2217"\w* \w para|strong="G1519"\w* \w siempre|strong="G3588"\w*!   
\p
\v 14 \w También|strong="G2532"\w* \w con|strong="G1722"\w* respecto \w a|strong="G1722"\w* \w éstos|strong="G3778"\w* \w Enoc|strong="G1802"\w*, \w séptimo|strong="G1442"\w* \add patriarca\add* desde Adán, \w profetizó|strong="G4395"\w*: Ciertamente \add el\add* \w Señor|strong="G2962"\w* \w vino|strong="G2064"\w* \w con|strong="G1722"\w* sus santas miríadas\f + \fr 1:14 \ft Una miríada es 10.000.\f*  
\v 15 \w para|strong="G4012"\w* \w hacer|strong="G4160"\w* \w juicio|strong="G2920"\w* \w contra|strong="G2596"\w* \w todos|strong="G3956"\w* \w y|strong="G2532"\w* \w convencer|strong="G1651"\w* \w a|strong="G2596"\w* \w toda|strong="G3956"\w* persona \w con|strong="G2532"\w* \w respecto|strong="G4012"\w* \w a|strong="G2596"\w* \w todas|strong="G3956"\w* \w las|strong="G3588"\w* \w obras|strong="G2041"\w* inicuas \w de|strong="G4012"\w* \w ellos|strong="G3588"\w* \w en|strong="G2596"\w* \w las|strong="G3588"\w* \w cuales|strong="G3739"\w* actuaron impíamente, \w y|strong="G2532"\w* \w con|strong="G2532"\w* \w respecto|strong="G4012"\w* \w a|strong="G2596"\w* \w todas|strong="G3956"\w* \w las|strong="G3588"\w* \w cosas|strong="G3739"\w* insolentes \w que|strong="G3588"\w* \add los\add* pecadores impíos \w hablaron|strong="G2980"\w* \w contra|strong="G2596"\w* \w Él|strong="G3588"\w*.   
\p
