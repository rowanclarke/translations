\v 27 \w Le|strong="H5414"\w* \w roi|strong="H4428"\w* \w prit|strong="H4428"\w* \w la|strong="H5414"\w* \w parole|strong="H6030"\w* \w et|strong="H4428"\w* \w dit|strong="H5414"\w* : « \w Donnez|strong="H5414"\w* \w à|strong="H5414"\w* \w la|strong="H5414"\w* première l'\w enfant|strong="H3205"\w* \w vivant|strong="H2416"\w*, \w et|strong="H4428"\w* \w ne|strong="H3808"\w* \w le|strong="H5414"\w* \w tuez|strong="H4191"\w* surtout \w pas|strong="H3808"\w*. \w C|strong="H1931"\w*'\w est|strong="H1931"\w* \w elle|strong="H1931"\w* \w qui|strong="H4428"\w* \w est|strong="H1931"\w* \w sa|strong="H5414"\w* \w mère|strong="H5414"\w*. »
\p 
\v 28 \w Tout|strong="H3605"\w* \w Israël|strong="H3478"\w* \w apprit|strong="H8085"\w* \w le|strong="H6440"\w* \w jugement|strong="H4941"\w* \w que|strong="H3588"\w* \w le|strong="H6440"\w* \w roi|strong="H4428"\w* \w avait|strong="H4428"\w* \w prononcé|strong="H8199"\w*, \w et|strong="H3478"\w* \w l|strong="H6440"\w*'\w on|strong="H3588"\w* \w craignit|strong="H3372"\w* \w le|strong="H6440"\w* \w roi|strong="H4428"\w*, \w car|strong="H3588"\w* \w on|strong="H3588"\w* \w vit|strong="H7200"\w* \w que|strong="H3588"\w* \w la|strong="H6213"\w* \w sagesse|strong="H2451"\w* \w de|strong="H4428"\w* \w Dieu|strong="H3588"\w* \w était|strong="H4428"\w* \w en|strong="H6213"\w* \w lui|strong="H4428"\w* \w pour|strong="H6213"\w* \w rendre|strong="H3478"\w* \w la|strong="H6213"\w* \w justice|strong="H4941"\w*.
\c 4
\p 
\v 1 \w Le|strong="H3478"\w* \w roi|strong="H4428"\w* \w Salomon|strong="H8010"\w* régnait \w sur|strong="H5921"\w* \w tout|strong="H3605"\w* \w Israël|strong="H3478"\w*.
\v 2 \w Voici|strong="H1121"\w* \w les|strong="H1121"\w* \w hauts|strong="H1121"\w* dignitaires qu'\w il|strong="H3548"\w* \w avait|strong="H1121"\w* : \w Azaria|strong="H5838"\w*, \w fils|strong="H1121"\w* \w du|strong="H1121"\w* \w prêtre|strong="H3548"\w* \w Tsadok|strong="H6659"\w* ;
\v 3 Élihoreph \w et|strong="H1121"\w* Achija, \w fils|strong="H1121"\w* \w de|strong="H1121"\w* Shisha, \w étaient|strong="H1121"\w* \w secrétaires|strong="H5608"\w* ; \w Josaphat|strong="H3092"\w*, \w fils|strong="H1121"\w* d'Ahilud, \w était|strong="H1121"\w* \w archiviste|strong="H2142"\w* ;
\v 4 \w Benaja|strong="H1141"\w*, \w fils|strong="H1121"\w* \w de|strong="H1121"\w* \w Jehojada|strong="H3077"\w*, commandait l'\w armée|strong="H6635"\w* ; \w Tsadok|strong="H6659"\w* \w et|strong="H1121"\w* \w Abiathar|strong="H6659"\w* \w étaient|strong="H1121"\w* \w prêtres|strong="H3548"\w* ;
\v 5 \w Azaria|strong="H5838"\w*, \w fils|strong="H1121"\w* \w de|strong="H1121"\w* \w Nathan|strong="H5416"\w*, \w était|strong="H4428"\w* \w à|strong="H1121"\w* \w la|strong="H5921"\w* \w tête|strong="H4428"\w* \w des|strong="H1121"\w* \w intendants|strong="H5324"\w* ; \w Zabud|strong="H2071"\w*, \w fils|strong="H1121"\w* \w de|strong="H1121"\w* \w Nathan|strong="H5416"\w*, \w était|strong="H4428"\w* ministre d'\w État|strong="H3548"\w* \w et|strong="H1121"\w* \w ami|strong="H7463"\w* \w du|strong="H1121"\w* \w roi|strong="H4428"\w* ;
\v 6 Ahischar dirigeait \w le|strong="H1121"\w* \w palais|strong="H1004"\w* ; \w et|strong="H1121"\w* Adoniram, \w fils|strong="H1121"\w* d'\w Abda|strong="H5653"\w*, \w était|strong="H1121"\w* \w préposé|strong="H1121"\w* \w aux|strong="H1121"\w* \w corvées|strong="H4522"\w*.
\p 
\v 7 \w Salomon|strong="H8010"\w* \w avait|strong="H4428"\w* \w douze|strong="H8147"\w* \w intendants|strong="H5324"\w* \w sur|strong="H5921"\w* \w tout|strong="H3605"\w* \w Israël|strong="H3478"\w*, \w chargés|strong="H4428"\w* d'approvisionner \w le|strong="H3478"\w* \w roi|strong="H4428"\w* \w et|strong="H3478"\w* \w sa|strong="H4428"\w* \w maison|strong="H1004"\w*. \w Chacun|strong="H1004"\w* d'\w eux|strong="H1004"\w* \w devait|strong="H3478"\w* assurer \w l|strong="H8141"\w*'approvisionnement \w pendant|strong="H3478"\w* \w un|strong="H3478"\w* \w mois|strong="H2320"\w* \w de|strong="H4428"\w* \w l|strong="H8141"\w*'\w année|strong="H8141"\w*.
\v 8 Voici \w leurs|strong="H2022"\w* \w noms|strong="H8034"\w* : \w le|strong="H8034"\w* \w fils|strong="H8034"\w* \w de|strong="H2022"\w* \w Hur|strong="H1133"\w*, \w dans|strong="H8034"\w* \w la|strong="H2022"\w* région montagneuse d'Éphraïm ;
\v 9 le fils de \w Déker|strong="H1128"\w*, à \w Makats|strong="H4739"\w*, à Shaalbim, à Beth-Schémesch, et à Élon-Beth-Hanan ;
\v 10 \w le|strong="H3605"\w* \w fils|strong="H1136"\w* \w de|strong="H3605"\w* Hésed, à Arubboth (\w Soco|strong="H7755"\w* \w et|strong="H7755"\w* \w tout|strong="H3605"\w* \w le|strong="H3605"\w* \w pays|strong="H3605"\w* \w de|strong="H3605"\w* \w Hépher|strong="H2660"\w* lui appartenaient) ;
\v 11 \w le|strong="H1961"\w* \w fils|strong="H1323"\w* d'\w Abinadab|strong="H1125"\w*, \w sur|strong="H1961"\w* \w toute|strong="H3605"\w* \w la|strong="H1961"\w* hauteur \w de|strong="H1323"\w* \w Dor|strong="H1756"\w* (\w il|strong="H8010"\w* \w avait|strong="H1961"\w* \w pour|strong="H1323"\w* \w femme|strong="H1323"\w* Taphath, \w fille|strong="H1323"\w* \w de|strong="H1323"\w* \w Salomon|strong="H8010"\w*) ;
\v 12 \w Baana|strong="H1195"\w*, \w fils|strong="H1121"\w* d'Ahilud, \w à|strong="H1121"\w* \w Taanac|strong="H8590"\w* \w et|strong="H1121"\w* \w Meguiddo|strong="H4023"\w*, \w et|strong="H1121"\w* \w dans|strong="H5704"\w* \w tout|strong="H3605"\w* \w Beth-Schean|strong="H3605"\w* \w qui|strong="H1121"\w* \w est|strong="H1121"\w* \w près|strong="H1121"\w* \w de|strong="H1121"\w* \w Tsarthan|strong="H6891"\w*, \w au-dessous|strong="H6891"\w* \w de|strong="H1121"\w* \w Jizreel|strong="H3157"\w*, \w depuis|strong="H5704"\w* \w Beth-Schean|strong="H3605"\w* jusqu'\w à|strong="H1121"\w* Abel-Mehola, \w et|strong="H1121"\w* \w au-delà|strong="H1121"\w* \w de|strong="H1121"\w* \w Jokmeam|strong="H3361"\w* ;
\v 13 \w le|strong="H1121"\w* \w fils|strong="H1121"\w* \w de|strong="H1121"\w* \w Guéber|strong="H1127"\w*, \w à|strong="H1121"\w* \w Ramoth|strong="H7433"\w* \w en|strong="H5892"\w* \w Galaad|strong="H1568"\w* (\w il|strong="H5892"\w* \w avait|strong="H1121"\w* \w les|strong="H1121"\w* \w bourgs|strong="H2333"\w* \w de|strong="H1121"\w* \w Jaïr|strong="H2971"\w*, \w fils|strong="H1121"\w* \w de|strong="H1121"\w* \w Manassé|strong="H4519"\w*, \w qui|strong="H1121"\w* \w sont|strong="H1121"\w* \w en|strong="H5892"\w* \w Galaad|strong="H1568"\w* ; \w et|strong="H1121"\w* \w il|strong="H5892"\w* \w avait|strong="H1121"\w* \w aussi|strong="H1121"\w* \w la|strong="H1121"\w* région d'Argob, \w qui|strong="H1121"\w* \w est|strong="H1121"\w* \w en|strong="H5892"\w* \w Basan|strong="H1316"\w*, \w soixante|strong="H8346"\w* \w grandes|strong="H1419"\w* \w villes|strong="H5892"\w* fortifiées \w de|strong="H1121"\w* \w murailles|strong="H2346"\w* \w et|strong="H1121"\w* \w de|strong="H1121"\w* \w verrous|strong="H1280"\w* d'\w airain|strong="H5178"\w*) ;
\v 14 Ahinadab, \w fils|strong="H1121"\w* d'\w Iddo|strong="H5714"\w*, \w à|strong="H1121"\w* \w Mahanaïm|strong="H4266"\w* ;
\v 15 Ahimaats, \w en|strong="H3947"\w* \w Nephthali|strong="H5321"\w* (\w il|strong="H1931"\w* \w prit|strong="H3947"\w* \w aussi|strong="H1571"\w* \w pour|strong="H3947"\w* \w femme|strong="H1323"\w* \w Basmath|strong="H1315"\w*, \w fille|strong="H1323"\w* \w de|strong="H1323"\w* \w Salomon|strong="H8010"\w*) ;
\v 16 \w Baana|strong="H1195"\w*, \w fils|strong="H1121"\w* \w de|strong="H1121"\w* \w Huschaï|strong="H2365"\w*, \w en|strong="H1121"\w* \w Aser|strong="H1121"\w* \w et|strong="H1121"\w* \w à|strong="H1121"\w* \w Bealoth|strong="H1175"\w* ;
\v 17 \w Josaphat|strong="H3092"\w*, \w fils|strong="H1121"\w* \w de|strong="H1121"\w* \w Paruach|strong="H6515"\w*, \w en|strong="H1121"\w* \w Issacar|strong="H3485"\w* ;
\v 18 \w Schimeï|strong="H8096"\w*, \w fils|strong="H1121"\w* d'Éla, \w en|strong="H1121"\w* \w Benjamin|strong="H1144"\w* ;
\v 19 \w Guéber|strong="H1398"\w*, \w fils|strong="H1121"\w* d'Uri, \w dans|strong="H1121"\w* \w le|strong="H1121"\w* \w pays|strong="H1121"\w* \w de|strong="H1121"\w* \w Galaad|strong="H1568"\w*, \w la|strong="H1121"\w* \w contrée|strong="H1121"\w* \w de|strong="H1121"\w* \w Sihon|strong="H5511"\w* \w roi|strong="H4428"\w* \w des|strong="H1121"\w* \w Amoréens|strong="H4428"\w*, \w et|strong="H1121"\w* d'\w Og|strong="H5747"\w* \w roi|strong="H4428"\w* \w de|strong="H1121"\w* \w Basan|strong="H1316"\w* ; c'\w était|strong="H4428"\w* \w le|strong="H1121"\w* \w seul|strong="H1121"\w* \w intendant|strong="H5333"\w* \w dans|strong="H1121"\w* \w cette|strong="H4428"\w* région.
\p 
\v 20 \w Juda|strong="H3063"\w* \w et|strong="H3478"\w* \w Israël|strong="H3478"\w* \w étaient|strong="H3478"\w* \w aussi|strong="H3478"\w* \w nombreux|strong="H7227"\w* \w que|strong="H7227"\w* \w le|strong="H3478"\w* \w sable|strong="H2344"\w* \w au|strong="H3478"\w* \w bord|strong="H3478"\w* \w de|strong="H7227"\w* \w la|strong="H5921"\w* \w mer|strong="H3220"\w*. \w Ils|strong="H3478"\w* \w mangeaient|strong="H3478"\w*, \w buvaient|strong="H8354"\w* \w et|strong="H3478"\w* \w se|strong="H3478"\w* \w réjouissaient|strong="H8056"\w*.
\v 21 Salomon dominait sur tous les royaumes depuis le Fleuve jusqu'au pays des Philistins, et jusqu'à la frontière d'Égypte. Ils apportaient des présents et furent assujettis à Salomon tous les jours de sa vie.
\v 22 Les vivres de Salomon pour une journée comprenaient trente cors\f + \fr 4.22 \ft 1 cor équivaut à un homer, soit environ 211 litres ou 6 boisseaux.\f* de fleur de farine, soixante mesures de farine,
\v 23 dix bœufs engraissés, vingt bœufs de pâturage, et cent brebis, outre les cerfs, les gazelles, les chevreuils et les volailles engraissées.
\v 24 Car il dominait sur tout ce côté du Fleuve, de Tiphsah jusqu'à Gaza, sur tous les rois de ce côté du Fleuve ; et il avait la paix de tous les côtés, tout autour de lui.
\v 25 Juda et Israël vécurent en sécurité, chacun sous sa vigne et sous son figuier, depuis Dan jusqu'à Beer-Schéba, pendant tous les jours de Salomon.
\v 26 Salomon avait quarante mille stalles de chevaux pour ses chars, et douze mille cavaliers.
\v 27 Ces intendants pourvoyaient à l'entretien du roi Salomon et de tous ceux qui s'approchaient de la table du roi, chacun pendant son mois. Ils ne laissaient rien manquer.
\v 28 Ils apportaient aussi de l'orge et de la paille pour les chevaux et les coursiers, à l'endroit où se trouvaient les intendants, chacun selon ses instructions.
\v 29 Dieu donna à Salomon une sagesse et une intelligence très grandes, ainsi que des connaissances aussi vastes que le sable qui est sur le bord de la mer.
\v 30 La sagesse de Salomon surpassait la sagesse de tous les fils de l'Orient et toute la sagesse des Égyptiens.
\v 31 Il était plus sage qu'aucun autre homme — plus sage qu'Éthan l'Ézrachite, qu'Héman, que Calcol et que Darda, les fils de Mahol ; et sa renommée se répandit parmi toutes les nations d'alentour.
\v 32 Il prononça trois mille proverbes, et ses cantiques furent au nombre de mille et cinq.
\v 33 Il parla sur les arbres, depuis le cèdre du Liban jusqu'à l'hysope qui sort de la muraille ; il parla aussi sur les animaux, sur les oiseaux, sur les reptiles et sur les poissons.
\v 34 On venait de tous les peuples pour entendre la sagesse de Salomon, envoyés par tous les rois de la terre qui avaient entendu parler de sa sagesse.
\c 5
\p 
\v 1 Hiram, \w roi|strong="H5704"\w* \w de|strong="H3117"\w* Tyr, envoya \w ses|strong="H3117"\w* \w serviteurs|strong="H5647"\w* \w vers|strong="H4467"\w* \w Salomon|strong="H8010"\w*, car \w il|strong="H3117"\w* apprit qu'\w on|strong="H3117"\w* \w l|strong="H4503"\w*'\w avait|strong="H1961"\w* oint \w roi|strong="H5704"\w* \w à|strong="H5704"\w* \w la|strong="H3117"\w* \w place|strong="H3117"\w* \w de|strong="H3117"\w* \w son|strong="H3117"\w* \w père|strong="H3117"\w*, \w et|strong="H3117"\w* Hiram \w avait|strong="H1961"\w* \w toujours|strong="H3117"\w* aimé David.
\v 2 \w Salomon|strong="H8010"\w* \w fit|strong="H8010"\w* \w dire|strong="H8010"\w* \w à|strong="H3117"\w* Hiram :
\v 3 « Tu sais \w que|strong="H6629"\w* David \w mon|strong="H6629"\w* père n'\w a|strong="H3068"\w* pu bâtir une maison \w pour|strong="H3967"\w* \w le|strong="H6643"\w* nom \w du|strong="H6643"\w* SEIGNEUR son Dieu, \w à|strong="H6629"\w* \w cause|strong="H6629"\w* \w des|strong="H6643"\w* guerres \w qui|strong="H1241"\w* l'ont environné \w de|strong="H6629"\w* toutes parts, jusqu'\w à|strong="H6629"\w* \w ce|strong="H6629"\w* \w que|strong="H6629"\w* \w le|strong="H6643"\w* SEIGNEUR ait mis ses ennemis sous \w la|strong="H6643"\w* plante \w de|strong="H6629"\w* ses pieds.
\v 4 \w Mais|strong="H3588"\w* \w maintenant|strong="H3588"\w* \w le|strong="H4428"\w* \w SEIGNEUR|strong="H4428"\w* \w mon|strong="H4428"\w* \w Dieu|strong="H3588"\w* m'\w a|strong="H3068"\w* \w donné|strong="H1931"\w* \w du|strong="H5676"\w* \w repos|strong="H5676"\w* \w de|strong="H4428"\w* \w tous|strong="H3605"\w* \w côtés|strong="H5439"\w*. \w Il|strong="H4428"\w* n'\w y|strong="H4428"\w* \w a|strong="H3068"\w* \w ni|strong="H5704"\w* adversaire, \w ni|strong="H5704"\w* événement malheureux.
\v 5 Voici, j'\w ai|strong="H3117"\w* \w l|strong="H8010"\w*'intention \w de|strong="H3117"\w* \w bâtir|strong="H3117"\w* \w une|strong="H3117"\w* \w maison|strong="H3117"\w* \w pour|strong="H5704"\w* \w le|strong="H3117"\w* \w nom|strong="H3427"\w* \w du|strong="H3117"\w* \w SEIGNEUR|strong="H3117"\w* \w mon|strong="H3117"\w* \w Dieu|strong="H3117"\w*, \w comme|strong="H3117"\w* \w le|strong="H3117"\w* \w SEIGNEUR|strong="H3117"\w* \w en|strong="H3117"\w* \w a|strong="H3068"\w* \w parlé|strong="H3478"\w* \w à|strong="H3478"\w* David \w mon|strong="H3117"\w* \w père|strong="H3117"\w*, \w lorsqu|strong="H3117"\w*'\w il|strong="H3117"\w* \w a|strong="H3068"\w* \w dit|strong="H3478"\w* : « \w Ton|strong="H3117"\w* \w fils|strong="H3478"\w*, \w que|strong="H3117"\w* \w je|strong="H3117"\w* \w mettrai|strong="H3117"\w* \w sur|strong="H3478"\w* \w ton|strong="H3117"\w* \w trône|strong="H3427"\w* \w à|strong="H3478"\w* \w ta|strong="H3117"\w* \w place|strong="H8478"\w*, c'\w est|strong="H3117"\w* \w lui|strong="H3478"\w* \w qui|strong="H3478"\w* \w bâtira|strong="H3478"\w* \w cette|strong="H3427"\w* \w maison|strong="H3117"\w* \w pour|strong="H5704"\w* \w mon|strong="H3117"\w* \w nom|strong="H3427"\w*. »
\v 6 Ordonne donc qu'on coupe \w pour|strong="H5483"\w* \w moi|strong="H5483"\w* \w des|strong="H1961"\w* \w cèdres|strong="H8147"\w* \w du|strong="H6240"\w* Liban. \w Mes|strong="H1961"\w* serviteurs \w seront|strong="H1961"\w* \w avec|strong="H1961"\w* \w tes|strong="H1961"\w* serviteurs ; \w et|strong="H1961"\w* \w je|strong="H5483"\w* \w te|strong="H5483"\w* \w paierai|strong="H5483"\w* \w le|strong="H1961"\w* \w salaire|strong="H1961"\w* \w de|strong="H1961"\w* \w tes|strong="H1961"\w* serviteurs tel \w que|strong="H8010"\w* \w tu|strong="H5483"\w* \w l|strong="H8010"\w*'auras fixé. Car \w tu|strong="H5483"\w* sais qu'\w il|strong="H8010"\w* n'\w y|strong="H1961"\w* \w a|strong="H3068"\w* \w personne|strong="H1961"\w* \w parmi|strong="H1961"\w* nous \w qui|strong="H8147"\w* s'\w y|strong="H1961"\w* entende \w pour|strong="H5483"\w* abattre \w le|strong="H1961"\w* \w bois|strong="H8010"\w* \w comme|strong="H1961"\w* \w les|strong="H1961"\w* Sidoniens. »
\p 
\v 7 Lorsque Hiram entendit \w les|strong="H3605"\w* \w paroles|strong="H1697"\w* \w de|strong="H4428"\w* \w Salomon|strong="H8010"\w*, \w il|strong="H4428"\w* s'\w en|strong="H4428"\w* réjouit beaucoup \w et|strong="H4428"\w* déclara : « Béni \w soit|strong="H3808"\w* \w le|strong="H4428"\w* \w SEIGNEUR|strong="H4428"\w* aujourd'hui, \w lui|strong="H4428"\w* \w qui|strong="H4428"\w* \w a|strong="H3068"\w* \w donné|strong="H3808"\w* \w à|strong="H1697"\w* \w David|strong="H1697"\w* \w un|strong="H5324"\w* \w fils|strong="H1697"\w* sage \w pour|strong="H4428"\w* gouverner \w ce|strong="H1697"\w* grand peuple. »
\v 8 Hiram envoya \w ce|strong="H1961"\w* message \w à|strong="H1961"\w* Salomon : « \w J|strong="H3068"\w*'\w ai|strong="H8033"\w* \w bien|strong="H5483"\w* entendu \w ce|strong="H1961"\w* \w que|strong="H4725"\w* \w tu|strong="H5483"\w* m'\w as|strong="H5483"\w* \w fait|strong="H1961"\w* dire. \w Je|strong="H3068"\w* \w ferai|strong="H8033"\w* tout \w ce|strong="H1961"\w* \w que|strong="H4725"\w* \w tu|strong="H5483"\w* désires concernant \w les|strong="H1961"\w* \w bois|strong="H4941"\w* \w de|strong="H1961"\w* \w cèdre|strong="H4725"\w* \w et|strong="H4941"\w* \w de|strong="H1961"\w* cyprès.
