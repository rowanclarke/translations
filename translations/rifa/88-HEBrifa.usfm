\id HEB
\h  إِعِيبْرَانِييّنْ 
\toc1  إِعِيبْرَانِييّنْ 
\toc2  إِعِيبْرَانِييّنْ 
\toc3 عبر. 
\mt1 إِعِيبْرَانِييّنْ  
\c 1
\s1 مِّيسْ يُوعْڒَا أَطَّاسْ خْ لْمَالَاكَاثْ  
\m
\v 1 ذڭْ وُوسَّانْ إِعْذُونْ إِسِّيوڒْ أَربِّي ذِي كُوڒْ ڒْوقْثْ ؤُ ذڭْ وَاطَّاسْ ن إِبْرِيذنْ أَكْ-ذ ڒجْذُوذْ نّغْ س إِنَابِييّنْ.  
\v 2 ذڭْ وُوسَّانْ-أَ إِنڭُّورَا أَقَا إِسِّيوڒْ-د أَكِيذْنغْ س مِّيسْ، ونِّي إِڭَّا ذ أَوْرِيثْ ن كُوڒْشِي، س ونِّي \add عَاوذْ\add* إِڭَّا زّْمَانَاثْ. \x ◘ \xo 1:‏2 \xt أَمز. 1‏:‏3؛ إِزهد. 33‏:‏6؛ مت. 21‏:‏38؛ يُوح. 1‏:‏3؛ أَفا. 3‏:‏9؛ كُول. 1‏:‏16.\x*  
\v 3 مِينْزِي نتَّا ذ ثَاللّشْثْ ن ؤُعُودْجِي نّسْ ؤُڒَا ذ تّسْوِيرْثْ ن سِيمَانْثْ نّسْ، ؤُ \add نتَّا ذ\add* ونِّي يَاربُّونْ مَارَّا ثِيمسْڒَايِينْ س جّهْذْ ن وَاوَاڒْ نّسْ. أَقَا نتَّا إِسِّيزْذڭْ دّْنُوبْ نّغْ ذِي طّْبِيعثْ ن يِيخفْ نّسْ، ؤُشَا إِرُوحْ إِقِّيمْ غَارْ يفُوسْ ن لْعَاضِيمْ ذِي ڒُوعْڒَا. \x ◘ \xo 1:‏3 \xt 2 كُور. 4‏:‏4؛ فِيل. 2‏:‏6؛ كُول. 1‏:‏15. \x*  
\v 4 نتَّا يُوعْڒَا أَطَّاسْ خْ لْمَالَاكَاثْ أَمْ إِسمْ إِ إِطّفْ ذ ڒْوَارْثْ، أَقَا إِشْنَا خْ ونِّي نْسنْ.   
\m
\v 5 مِينْزِي إِ مَانْ ثنْ زِي لْمَالَاكَاثْ إِنَّا أَربِّي:  
\b  
\m \qt ”مِّي إِ ثدْجِيذْ شكْ،\qt*  
\m \qt أَسّْ-أَ نشّْ جِّيغْ-د شكْ!“،\qt*  
\b  
\m ؤُشَا عَاوذْ إِنَّا:  
\b  
\m \qt ”نشّْ أَذْ أَسْ إِڒِيغْ ذ بَابَاسْ\qt*  
\m \qt ؤُ نتَّا أَذْ أَيِي يِيڒِي ذ مِّي“؟\qt* \x ◘ \xo 1:‏5 \xt 2 صم. 7‏:‏14؛ 1 إِم. 17‏:‏13؛ 22‏:‏10؛ إِزهد. 2‏:‏7؛ ڒخ. 13‏:‏33؛ عبر. 5‏:‏5. \x*   
\b  
\m
\v 6 ؤُشَا خنِّي خْمِي د-إِسِّيذفْ أَمنْزُو غَارْ دُّونشْثْ، إِنَّا:  
\b  
\m \qt ”أَذْ أَسْ سجْذنْثْ مَارَّا لْمَالَاكَاثْ ن أَربِّي.“\qt* \x ◘ \xo 1:‏6 \xt إِزهد. 97‏:‏7. \x*   
\b  
\m
\v 7 \add مَاشَا\add* خْ لْمَالَاكَاثْ إِنَّا:  
\b  
\m \qt ”نتَّا إِڭَّا لْمَالَاكَاثْ نّسْ ذ إِسمِّيضنْ،\qt*  
\m \qt ؤُشَا إِمْسخَّارنْ نّسْ\qt*  
\m \qt ذ إِشْثْ ن ثْمسِّي إِتّحْذُوذُوقنْ“،\qt* \x ◘ \xo 1:‏7 \xt إِزهد. 104‏:‏4 \x*   
\b  
\m
\v 8 مَاشَا خْ مِّيسْ:  
\b  
\m \qt ”ڒْْعَارْشْ نّشْ، \+tl أَ\+tl* أَربِّي،\qt*  
\m \qt أَقَا إِدْجَا إِ ڒبْذَا قَاعْ.\qt*  
\m \qt أَزدْجَاضْ ن ثْڭلْذِيثْ نّشْ،\qt*  
\m \qt أَقَا-ت ذ أَزدْجَاضْ إِسڭّْذنْ.\qt* \x ◘ \xo 1:‏8 \xt إِزهد. 45‏:‏7. \x*   
\m
\v 9 \qt أَقَا ثخْسذْ ثَاسڭْذَا، ثْشَارْهذْ ڒْغَارْ.\qt*  
\m \qt س ؤُينِّي أَقَا إِذْهنْ إِ شْ\qt*  
\m \qt أَربِّي، أَربِّي نّشْ،\qt*  
\m \qt س زّشْثْ ن ڒفْرَاحثْ\qt*  
\m \qt سنّجْ إِ إِمْعَاشَارنْ نّشْ.“\qt* \x ◘ \xo 1:‏9 \xt إِزهد. 45‏:‏7، 8 \x*   
\b  
\m
\v 10 ؤُشَا خنِّي:  
\b  
\m \qt ”زڭْ ؤُبدُّو ثڭِّيذْ شكْ ذْسَاسْ ن ثمُّورْثْ،\qt*  
\m \qt إِجنْوَانْ دْجَانْ ذ ڒْخذْمثْ ن إِفَاسّنْ نّشْ\qt*. \x ◘ \xo 1:‏10 \xt إِزهد. 102‏:‏26. \x*   
\m
\v 11 \qt إِنَا أَذْ تّْوَاثحَّانْ، مَاشَا شكْ أَذْ ثْذُومذْ،\qt*  
\m \qt ؤُشَا إِنَا مَارَّا أَذْ أَرْشَانْ أَمْ وَارُّوضْ.\qt* \x ◘ \xo 1:‏11 \xt إِشا. 51‏:‏6؛ 2 بُط. 3‏:‏7، 10. \x*   
\m
\v 12 \qt أَمشْنَاوْ إِجّْ ن ؤُسڒْهَامْ أَذْ ثنْ تّْضفْسذْ.\qt*  
\m \qt أَذْ تّْوَابدّْڒنْ \+tl أَمْ وَارُّوضْ\+tl*،\qt*  
\m \qt مَاشَا شكْ أَذْ ثِيڒِيذْ ذ ونِّي\qt*  
\m \qt ؤُشَا إِسڭّْوُوسَا نّشْ وَارْ قطِّينْ شَا.“\qt* \x ◘ \xo 1:‏12 \xt إِزهد. 102‏:‏26‏-‏28. \x*   
\b  
\m
\v 13 \add مَاشَا\add* إِ مَانْ ثنْ زِي لْمَالَاكَاثْ إِنَّا إِجّْ ن وَاسّْ:  
\b  
\m \qt ”قِّيمْ غَارْ يفُوسْ إِنُو\qt*  
\m \qt أَڒْ ذ غَا ڭّغْ ڒْعذْيَانْ نّشْ\qt*  
\m \qt ذ ثَانبْذَاثْ سَاذُو إِضَارنْ نّشْ“؟\qt* \x ◘ \xo 1:‏13 \xt إِزهد. 110‏:‏1؛ ڒخ. 2‏:‏34؛ 1 كُور. 15‏:‏25؛ أَفا. 1‏:‏20؛ عبر. 10‏:‏12. \x*   
\b  
\m
\v 14 مَا وَارْ دْجِينْثْ نِيثنْثِي ذ أَرُّوحَاثْ إِ ثْسخَّارْثْ، تّْوَاسّكّنْثْ-إِ-د حِيمَا أَذْ سخَّارنْثْ إِ يِينِّي غَا إِوَارْثنْ ثُوذَارْثْ؟   
\b  
\b  
\m  
\c 2
\s1 يَاسُوع لْمَاسِيحْ، أَرَّايْسْ نّغْ يَارحّْمنْ ن إِكهَّاننْ  
\m
\v 1 س ؤُينِّي إِتّْخصَّا أَنغْ أَذْ نوْشْ ثَايْنِيثْ كْثَارْ إِ مِينْ نسْڒَا، حِيمَا وَارْ نتّفّغْ زڭْ وبْرِيذْ.  
\v 2 مِينْزِي، مَاڒَا أَوَاڒْ إِ إِنَّانْ لْمَالَاكَاثْ ثُوغَا ثْبدّْ ؤُ مَارَّا وِي ث إِسْڒِينْ، \add مَاشَا\add* إِعْذُو خَاسْ، أَقَا إِتّْوَاخدْجصْ س ڒْحقّْ، \x ◘ \xo 2:‏2 \xt أَمز. 19‏:‏17، 26؛ أَعَوذ. 27‏:‏26؛ ڒخ. 7‏:‏53؛ ڭال. 3‏:‏19. \x*  
\v 3 مَامّشْ إِ غَا نڭّْ أَذْ نَارْوڒْ نشِّينْ، مَاڒَا نسّحْقَارَا ثِيمسْڒَايِينْ إِ إِدْجَانْ ذ ثُوذَارْثْ إِ نشِّينْ، \add ثِيمسْڒَايِينْ\add* إِ خفْ ثُوغَا إِسَّاوَاڒْ سِيذِيثْنغْ غَارْ ؤُمزْوَارُو، ؤُشَا \add خنِّي\add* تّْوَاضمْننْثْ أَنغْ زڭْ يِينِّي جَارَانغْ إِ ثُوغَا \add ثنْثْ\add* زَّايسْ إِسْڒِينْ، \x ◘ \xo 2:‏3 \xt مت. 4‏:‏17؛ مك. 1‏:‏14؛ عبر. 12‏:‏25. \x*  
\v 4 \add ؤُمِي\add* أَربِّي إِشْهذْ أَكِيذْسنْ س ڒعْڒَامَاثْ ذ لْمُوعْجِيزَاثْ ذ ڒعْجَايبْ إِفَارْزنْ ؤُ س ثْموْشِي ن أَرُّوحْ إِقدّْسنْ، ثِينِّي إِمّوْشنْ أَمْ مَامّشْ إِخْسْ نتَّا. \x ◘ \xo 2:‏4 \xt مك. 16‏:‏20؛ ڒخ. 14‏:‏3؛ 19‏:‏11. \x*  
\v 5 مِينْزِي وَارْ إِسَّارْسْ شَا زّْمَانْ إِ د غَا يَاسنْ خْ ثنِّي نسِّيوڒْ، سَاذُو \add ڒُْومُورْ ن\add* لْمَالَاكَاثْ،  
\v 6 مَاشَا أَمْ مَامّشْ شهّْذنْثْ ؤُ قَّارنْثْ ثِيرَا \add إِقدّْسنْ\add*:  
\b  
\m \qt ”مِينْ إِعْنَا بْنَاذمْ،\qt*  
\m \qt أَقَا شكْ إِ ذَايسْ إِتّْخَارَّاصنْ،\qt*  
\m \qt \+tl ؤُ مِينْ إِعْنَا\+tl* مِّيسْ ن بْنَاذمْ،\qt*  
\m \qt أَقَا شكْ إِ ذَايسْ إِتّْهِيلَّانْ؟\qt* \x ◘ \xo 2:‏6 \xt إِزهد. 8‏:‏5. \x*   
\m
\v 7 \qt شكْ ثڭِّيذْ ث شْوَايْثْ سَاذُو لْمَالَاكَاثْ،\qt*  
\m \qt ثڭِّيذْ أَسْ أَعُودْجِي ذ شَّانْ خْ ؤُخدْجِيفْ نّسْ،\qt*  
\m \qt ثوْشِيذْ أَسْ صُّولْطَا خْ ڒخْذَايمْ ن إِفَاسّنْ نّشْ.\qt* \x ◘ \xo 2:‏7 \xt إِزهد. 8‏:‏7\x*   
\m
\v 8 \qt أَقَا مَارَّا ثِيمسْڒَايِينْ ثڭِّيذْ ثنْثْ\qt*  
\m \qt سَاذُو إِضَارنْ نّسْ.“\qt*  
\b  
\m ؤُمِي إِڭَّا مَارَّا ثِيمسْڒَايِينْ سَاذُو نتَّا، أَقَا وَارْ إِجِّي وَالُو وَارْ ث إِڭِّي سَاذُو نتَّا. مَاشَا ڒخُّو وَارْ نْژَارْ عَاذْ مَارَّا إِتّْوَاڭّْ سَاذُو نتَّا، \x ◘ \xo 2:‏8 \xt إِزهد. 8‏:‏7؛ مت. 28‏:‏18؛ 1 كُور. 15‏:‏27؛ أَفا. 1‏:‏22. \x*  
\v 9 مَاشَا نتّْوَاڒَا بلِّي نتَّا، أَقَا-ث ذ يَاسُوع، ثُوغَا إِتّْوَاڭّْ شْوَايْثْ سَاذُو لْمَالَاكَاثْ ذِي سِّيبّثْ ن ؤُودّبْ ن ڒْموْثْ نّسْ، \add نتّْوَاڒَا إِ-ث\add* س تَّاجْ ن ؤُعُودْجِي ذ شَّانْ خْ ؤُزدْجِيفْ نّسْ، مَاغَارْ أَربِّي إِقَّاسْ ڒْموْثْ إِ مَارَّا إِوْذَانْ عْلَاحْسَابْ أَرْضَا نّسْ. \x ◘ \xo 2:‏9 \xt ڒخ. 2‏:‏33؛ فِيل. 2‏:‏7، 8. \x*   
\m
\v 10 مِينْزِي ثُوغَا إِتّْڒِيقْ أَسْ إِ نتَّا س ونِّي ؤُ إِ ونِّي دْجَانْثْ مَارَّا ثْمسْڒَايِينْ - نتَّا ذ \add ونِّي\add* إِ د-إِتَّاوْينْ أَطَّاسْ ن إِحنْجِيرنْ غَارْ ؤُعُودْجِي - مَاحنْذْ أَذْ إِكمّڒْ ؤُزدْجِيفْ ن ثُوذَارْثْ نْسنْ س ؤُودّبْ نّسْ.  
\v 11 مِينْزِي ذ ونِّي إِسّْقدّْسنْ ذ يِينِّي إِتّْوَاقدّْسنْ، نِيثْنِي مَارَّا ذ إِجّنْ. س ؤُينِّي نتَّا وَارْ إِسضْحِي شَا أَذْ أَسنْ إِڒَاغَا أَوْمَاثنْ نّسْ، \x ◘ \xo 2:‏11 \xt ڒخ. 17‏:‏26. \x*  
\v 12 ؤُمِي إِنَّا:  
\b  
\m \qt ”أَذْ بَارّْحغْ إِ وَاوْمَاثنْ إِنُو س يِيسمْ نّشْ،\qt*  
\m \qt ذِي ڒْوسْطْ ن ثْمسْمُونْثْ أَذْ شكْ صبّْحغْ.“\qt* \x ◘ \xo 2:‏12 \xt إِزهد. 22‏:‏23. \x*   
\b  
\m
\v 13 ؤُشَا عَاوذْ:  
\b  
\m \qt ”نشّْ أَذْ ذَايسْ تِّيقّغْ!“\qt*  
\b  
\m ؤُشَا عَاوذْ:  
\b  
\m \qt ”أَقَا ذَا، نشّْ ذ ثَارْوَا إِ ذ أَيِي إِوْشَا أَربِّي.“\qt* \x ◘ \xo 2:‏13 \xt إِشا. 8‏:‏17، 18. \x*   
\b  
\m
\v 14 مِينْزِي ثَارْوَا شَارْشنْ ذڭْ ويْسُومْ ذ إِذَامّنْ، ؤُڒَا ذ نتَّا إِشَارْشْ أَمُّو كِيفْكِيفْ ذِي مَانْ أَيَا، حِيمَا أَذْ إِبطّڒْ س ڒْموْثْ نّسْ ونِّي غَارْ ثدْجَا صُّولْطَا خْ ڒْموْثْ، أَقَا نتَّا ذ شِّيطَانْ، \x ◘ \xo 2:‏14 \xt إِشا. 25‏:‏8؛ حُوش. 13‏:‏14؛ يُوح. 1‏:‏14؛ 1 كُور. 15‏:‏54؛ فِيل. 2‏:‏7؛ 2 تِيم. 1‏:‏10. \x*  
\v 15 ؤُشَا \add خنِّي\add* أَذْ إِفكّْ إِنِّي إِسّعْدُّونْ قَاعْ ثُوذَارْثْ نْسنْ أَمْ إِسمْغَانْ زِي ثِيڭّْوُوذِي ن ڒْموْثْ. \x ◘ \xo 2:‏15 \xt رُوم. 8‏:‏15. \x*  
\v 16 مِينْزِي ڒْموْثْ وَارْ غَارسْ ثدْجِي صُّولْطَا خْ لْمَالَاكَاثْ، مَاشَا \add ڒْموْثْ\add* غَارسْ صُّولْطَا خْ زَّارِيعثْ ن إِبْرَاهِيمْ.  
\v 17 س ؤُينِّي ثُوغَا إِتّْخصَّا أَسْ أَذْ إِذْوڒْ أَمْ وَاوْمَاثنْ نّسْ زِي مَارَّا إِغزْذِيسنْ، حِيمَا أَذْ إِذْوڒْ ذ أَرَّايْسْ ن إِكهَّاننْ أَرْحِيمْ ذ أَمْثِيقِّي ذِي مِينْ إِدْجَانْ إِ أَربِّي، ؤُشَا أَذْ يِيڒِي بْڒَا ڒْعِيبْ زِي جِّيهثْ ن دّْنُوبْ ن ڒْڭنْسْ. \x ◘ \xo 2:‏17 \xt فِيل. 2‏:‏7؛ عبر. 4‏:‏15. \x*  
\v 18 مِينْزِي مِينْ ذِي ثُوغَا نتَّا سِيمَانْثْ نّسْ إِودّبْ ؤُ إِتّْوَاجَارّبْ، أَقَا إِزمَّارْ أَذْ إِعَاونْ إِنِّي إِتّْوَاجَارّْبنْ. \x ◘ \xo 2:‏18 \xt عبر. 4‏:‏15، 16. \x*   
\b  
\b  
\m  
\c 3
\s1 يَاسُوع لْمَاسِيحْ يُوعْڒَا خْ مُوسَا  
\m
\v 1 س ؤُينِّي، \add أَ\add* أَيْثْمَا إِمْقدَّاسنْ، إِنِّي إِتّْوَاڒَاغَانْ س ثْڒَاغِيثْ ن ؤُجنَّا، خْزَارمْ غَارْ رَّاسُولْ وَانِيثَا، غَارْ أَرَّايْسْ ن إِكهَّاننْ ن شّْهَاذثْ نّغْ، يَاسُوع لْمَاسِيحْ، \f ◼ \fr 3:‏1 \ft \+bd ’رَّاسُولْ‘\+bd* - نِيغْ ’أَمَازَانْ‘.\f*  \x ◘ \xo 3:‏1 \xt عبر. 4‏:‏14؛ 6‏:‏20؛ 8‏:‏1؛ 9‏:‏11. \x*  
\v 2 ونِّي ذ أَمْثِيقِّي إِ ونِّي إِ-ث-إِ-د-إِسّْڭعّْذنْ، أَمْ مَامّشْ ثُوغَا مُوسَا \add ذ أَمْثِيقِّي\add* ذِي مَارَّا ثَادَّارْثْ نّسْ. \x ◘ \xo 3:‏2 \xt ڒخْڒ. 12‏:‏7. \x*  
\v 3 مِينْزِي أَعُودْجِي ن وَانِيثَا ذ أَمقّْرَانْ س وَاطَّاسْ خْ ونِّي ن مُوسَا، أَمْ شَّانْ ن ؤُبنَّايْ ن ثَادَّارْثْ إِمْغَارْ خْ شَّانْ ن ڒبْنِي نّسْ.  
\v 4 مِينْزِي مَارَّا ثَادَّارْثْ ثتّْوَابْنَا زڭْ إِجّنْ، مَاشَا ونِّي إِبنَّانْ مَارَّا ذ أَربِّي. \x ◘ \xo 3:‏4 \xt 2 كُور. 5‏:‏17، 18؛ أَفا. 2‏:‏10. \x*  
\v 5 ثتّْوَاوكّڒْ إِ مُوسَا مَارَّا ثَادَّارْثْ نّسْ أَمْ إِ يِيجّْ ن ؤُمْسخَّارْ، مَاحنْذْ أَذْ إِشْهذْ خْ ثْمسْڒَايِينْ مِينْ خفْ غَا إِسِّيوڒْ نتَّا. \x ◘ \xo 3:‏5 \xt أَعَوذ. 18‏:‏15، 18. \x*  
\v 6 مَاشَا لْمَاسِيحْ أَمْ مِّيسْ \add إِتّْوَاڭّْ\add* خْ ثَادَّارْثْ نّسْ، ؤُ ثَادَّارْثْ نّسْ ذ نشِّينْ، مَاڒَا نقِّيمْ نتّطّفْ ذِي ڒَامَانْ ؤُ ذڭْ ؤُعُودْجِي ن ؤُسِيثمْ نّسْ أَڒْ أَنڭَّارْ. \x ◘ \xo 3:‏6 \xt رُوم. 5‏:‏2؛ 1 كُور. 3‏:‏16؛ 6‏:‏19؛ 2 كُور. 6‏:‏16؛ 1 بُط. 2‏:‏5. \x*   
\b  
\m
\v 7 مَاشَا مِينْزِي أَرُّوحْ إِقدّْسنْ إِنَّا ...  
\b  
\m \qt ”أَقَا أَسّْ-أَ مَاڒَا ثسْڒِيمْ ثْمِيجَّا نّسْ،\qt* \x ◘ \xo 3:‏7 \xt إِزهد. 95‏:‏7؛ عبر. 4‏:‏7. \x*   
\m
\v 8 \qt وَارْ تّسّقْسِيحمْ شَا ؤُڒَاونْ نْومْ\qt*  
\m \qt مَاحنْذْ أَذْ ث ثسْعَارمْ،\qt*  
\m \qt أَمْ إِنِّي إِغوّْغنْ،\qt*  
\m \qt أَمْ ذڭْ وَاسّْ ن ؤُجَارّبْ ذِي ڒخْڒَا،\qt* \x ◘ \xo 3:‏8 \xt ؤُف. 17‏:‏2، 7؛ إِزهد. 95‏:‏8\x*   
\m
\v 9 \qt ؤُمِي ذ أَيِي جَارّْبنْ ڒجْذُوذْ نْومْ، قدْجْبنْ \+tl أَيِي\+tl*،\qt*  
\m \qt \+tl أَمْ\+tl* ژْرِينْ ثِيمڭَّا إِنُو\qt*  
\m \qt أَربْعِينْ ن إِسڭّْوُوسَا.\qt*   
\b  
\m
\v 10 ... س ؤُيَا عِيفّغْ زِي جِّيڒْ نِّي، نِّيغْ:  
\b  
\m \qt ’وَا ذ إِجّْ ن ڒْڭنْسْ إِ إِودَّارنْ ذڭْ وُوڒْ نّسْ\qt*  
\m \qt نِيثْنِي وَارْ سِّيننْ شَا إِبْرِيذنْ إِنُو!‘،\qt*   
\m
\v 11 \qt أَڒَامِي جُّودْجغْ ذڭْ وغْضَابْ إِنُو:\qt*  
\m \qt ’وَارْ د-تِّيذْفنْ شَا غَارْ أَرَّاحثْ إِنُو!‘ “\qt* \x ◘ \xo 3:‏11 \xt ڒخْڒ. 14‏:‏21‏-‏23؛ أَعَوذ. 1‏:‏34؛ إِزهد. 95‏:‏7‏-‏11. \x*   
\b  
\m
\v 12 س ؤُينِّي، \add أَ\add* أَيْثْمَا، حْضَامْ حِيمَاعمَّارْصْ وَارْ إِتِّيڒِي حذْ زَّايْومْ غَارسْ ؤُڒْ ذ أَعفَّانْ إِ وَارْ إِتِّيمْننْ ؤُمِي غَا ثَاڭّْوجمْ خْ أَربِّي إِدَّارنْ،  
\v 13 مَاشَا قدْجْبمْ إِخفْ نْومْ كُوڒْ أَسّْ، أَڒْ أَسّْ ؤُمِي قَّارنْ: ’أَسّْ-أَ!‘، حِيمَا ؤُڒَا ذ إِجّْ زَّايْومْ وَارْ إِتّقْسِيحْ شَا س ؤُغكّْوِي ن دّنْبْ.  
\v 14 مِينْزِي نتّْوَاسّْمُونْ \add أَطَّاسْ\add* أَكْ-ذ لْمَاسِيحْ مَاڒَا نقِّيمْ نْشبَّارْ زڭْ ؤُمزْوَارْ أَڒْ أَنڭَّارْ ذِي ڒْعَاهْذْ-أَ إِ ذَايسْ ڒَامَانْ.   
\b  
\m
\v 15 س ؤُيَا إِتّْوَانَّا \add أَمُّو\add*:  
\b  
\m \qt ”أَقَا أَسّْ-أَ،\qt*  
\m \qt مَاڒَا ثسْڒِيمْ ڒْحسّْ ن ثْمِيجَّا نّسْ،\qt*  
\m \qt وَارْ ثسّقْسِيحمْ شَا ؤُڒَاونْ نْومْ\qt*  
\m \qt مَاحنْذْ أَذْ ث ثسْعَارمْ.“\qt* \x ◘ \xo 3:‏15 \xt عبر. 3‏:‏7. \x*   
\b  
\m
\v 16 \add خنِّي\add* مِينْ إِعْنَانْ نِيثْنِي إِنِّي إِسْڒِينْ ث، \add خنِّي\add*غوّْغنْ؟ مَا وَارْ \add دْجِينْ\add* نِيثْنِي مَارَّا ذ إِنِّي د-إِفّْغنْ زِي مِيصْرَا س ؤُفُوسْ ن مُوسَا؟  
\v 17 زِي مَانْ ونْ إِعِيفّْ نتَّا \add خنِّي\add* أَربْعِينْ ن إِسڭّْوُوسَا؟ مَا وَارْ إِدْجِي زڭْ يِينِّي إِخْضَانْ، إِنِّي ؤُمِي إِوْضَانْ إِغْسَانْ نْسنْ ذِي ڒخْڒَا؟ \x ◘ \xo 3:‏17 \xt ڒخْڒ. 14‏:‏36؛ إِزهد. 106‏:‏26؛ 1 كُور. 10‏:‏10؛ يَاه. 5. \x*  
\v 18 إِ ؤُمِي إِجُّودْجْ نتَّا، بلِّي وَارْ د-تِّيذْفنْ شَا غَارْ أَرَّاحثْ نّسْ؟ مَا وَارْ إِدْجِي إِ يِينِّي وَارْ ذ أَسْ تِّيقّنْ؟ \x ◘ \xo 3:‏18 \xt أَعَوذ. 1‏:‏34. \x*  
\v 19 أَقَا نتّْوَاڒَا بلِّي نِيثْنِي وَارْ زمَّارنْ أَذْ أَذْفنْ خْ سِّيبّثْ ن بْڒَا لْ-إِيمَانْ نْسنْ.   
\b  
\b  
\m  
\c 4
\s1 أَريّحْ إِ ڒْڭنْسْ ن أَربِّي  
\m
\v 1 أجّْ أَنغْ أَذْ نحْضَا خنِّي، أَقَا ؤُڒَا ذ إِجّْ زَّايْومْ، \add ؤُمِي عَاذْ\add* ذِينْ إِجّْ ن لْوَاعْذْ ن وَاذَافْ ذِي أَرَّاحثْ نّسْ، أَذْ إِضْهَارْ إِتّْغِيمَا غَارْ ضفَّارْ غَارْ وَاذَافْ.  
\v 2 مِينْزِي إِتّْوَابَارّحْ ڒخْبَارْ أَصبْحَانْ عَاوذْ إِ نشِّينْ، أَمْ \add إِتّْوَابَارّحْ\add* ؤُڒَا إِ نِيثْنِي، مَاشَا أَوَاڒْ وَارْ ذ أَسنْ إِنْفِيعْ إِ يِينِّي ذ أَسْ إِسْڒِينْ، مِينْزِي ثُوغَا وَارْ د-إِتِّيسْ شَا أَكْ-ذ لْ-إِيمَانْ ذڭْ إِنِّي \add ذ أَسْ\add* إِسْڒَانْ.  
\v 3 مَاشَا نشِّينْ، إِنِّي يُومْننْ، أَذْ نَاذفْ غَارْ أَرَّاحثْ.  
\b  
\m مَاشَا أَمْ مَامّشْ إِنَّا:  
\b  
\m \qt ”أَمْ مَامّشْ جُّودْجغْ ذڭْ وغْضَابْ إِنُو:\qt*  
\m \qt ’نِيثْنِي وَارْ د-تِّيذْفنْ شَا غَارْ أَرَّاحثْ إِنُو!‘ “\qt*  
\b  
\m ؤُ خْزَارْ، ڒخْذَايمْ ن أَربِّي أَقَا تّْوَاكمّْڒنْثْ زڭْ وَامِي ثتّْوَاڭّْ دُّونشْثْ، \x ◘ \xo 4:‏3 \xt إِزهد. 95‏:‏11. \x*  
\v 4 أَمْ مَامّشْ إِنَّا خْ سّبْثْ:  
\b  
\m \qt ”يَاريّحْ أَربِّي زِي مَارَّا ڒخْذَايمْ نّسْ\qt*  
\m \qt ذڭْ وَاسّْ وِيسّْ سبْعَا.“\qt* \x ◘ \xo 4:‏4 \xt أَمز. 2‏:‏2؛ ؤُف. 20‏:‏11؛ 31‏:‏17. \x*   
\b  
\m
\v 5 \add أَمُّو\add* إِ إِنَّا عَاوذْ ذڭْ \add وَاوَاڒْ-أَ\add* وَانِيثَا:  
\b  
\m \qt ”وَارْ د-تِّيذْفنْ شَا غَارْ أَرَّاحثْ إِنُو!“\qt* \x ◘ \xo 4:‏5 \xt إِزهد. 95‏:‏11. \x*   
\b  
\m
\v 6 ؤُمِي ثقِّيمْ بلِّي مَارَّا زمَّارنْ أَذْ د-أَذْفنْ \add غَارْ أَرَّاحثْ-أَ\add*، \add مَاشَا\add* إِنِّي ؤُمِي إِتّْوَابَارّحْ س ڒخْبَارْ أَصبْحَانْ غَارْ ؤُمزْوَارُو، وَارْ ؤُذِيفنْ شَا خْ سِّيبّثْ ن ڒْمُوعْصِييّثْ نْسنْ،  
\v 7 أَقَا نتَّا إِڭَّا عَاوذْ، أَوَارْنِي أَطَّاسْ ن ڒْوقْثْ، إِجّْ ن وَاسّْ نّغْنِي، أَمْ مَامّشْ إِتّْوَارِي قْبڒْ أَقَا \bd ذَاوُوذْ\bd* إِنَّا:  
\b  
\m \qt ”أَسّْ-أَ مَاڒَا ثسْڒِيمْ إِ ثْمِيجَّا نّسْ،\qt*  
\m \qt وَارْ سقْسِيحمْ شَا ؤُڒَاونْ نْومْ!“\qt* \x ◘ \xo 4:‏7 \xt إِزهد. 95‏:‏7؛ عبر. 3‏:‏7. \x*   
\b  
\m
\v 8 مِينْزِي مَاڒَا ثُوغَا \bd يَاشُووَا، مِّيسْ ن نُونْ،\bd* إِسِّيذفْ إِ-ثنْ ذِي أَرَّاحثْ، وَارْ غَارسْ إِتِّيڒِي عَاذْ ڒْهَارْذْ \add س ؤُقمُّومْ ن ذَاوُوذْ\add* خْ إِجّْ ن وَاسّْ نّغْنِي أَوَارْنِي مَانْ أَيَا.  
\v 9 س ؤُيَا أَذْ ثقِّيمْ أَقَا ذِينْ عَاذْ أَرَّاحثْ ن سّبْثْ إِ ڒْڭنْسْ ن أَربِّي.  
\v 10 مِينْزِي وِي يُوذْفنْ غَارْ أَرَّاحثْ نّسْ، يَاريّحْ عَاوذْ زِي ڒخْذَايمْ نّسْ أَمْ مَامّشْ أَربِّي زِي ثِينِّي نّسْ.   
\m
\v 11 س ؤُيَا جّمْ أَنغْ أَذْ نمْكَابَارْ حِيمَا أَذْ نَاذفْ غَارْ أَرَّاحثْ نِّي، مَاحنْذْ وَارْ نْوطِّي أَمْ مَامّشْ وْضَانْ إِنِّي وَارْ إِطِّيعنْ.  
\v 12 مِينْزِي أَوَاڒْ ن أَربِّي إِدَّارْ، إِخدّمْ مَانِي مَا، إِقْضعْ كْثَارْ زِي كُوڒْ سِّيفْ س ثْنَاينْ ن وُوذْمَاونْ، إِتَّاكّْوَاضْ أَڒْ أَبطُّو ن ڒعْمَارْ ذ أَرُّوحْ، أَڒْ \add تَّاسِيعْ\add* جَارْ ڒمْفَاصڒْ، أَڒْ \add أَيْمِيرْ\add* جَارْ وَاضُوفْ ذ إِغْسَانْ، ؤُشَا إِحكّمْ خْ ثْنَاوِي ذ إِخَارِّيصنْ ن وُوڒْ. \x ◘ \xo 4:‏12 \xt أَمب. 12‏:‏11؛ إِشا. 49‏:‏2؛ أَفا. 6‏:‏17. \x*  
\v 13 ؤُڒَا ذ إِشْثْ ن ثْمسْڒَاشْثْ إِ زَّايسْ د-إِتّْوَاخڒْقنْ وَارْ زَّايسْ ثتّْوَاسّْنُوفَّارْ شَا، مَاشَا مَارَّا \add ثِيمسْڒَايِينْ\add* أَقَا أَثنْثْ تّْوَاعَارّْينْثْ، تّْوَارزّْمنْثْ غَارْ ثِيطَّاوِينْ ن ونِّي ؤُمِي إِ-كْ-د إِ غَا نڭّْ ڒحْسَابْ. \x ◘ \xo 4:‏13 \xt إِزهد. 33‏:‏13. \x*   
\b  
\m  
\s1 يَاسُوع ذ أَرَّايْسْ نّغْ إِمْغَارْ ن إِكهَّاننْ  
\m
\v 14 س ؤُينِّي، أَمْ غَارْنغْ أَرَّايْسْ ن إِكهَّاننْ إِمْغَارْ، يَاسُوع لْمَاسِيحْ، مِّيسْ ن أَربِّي، ونِّي إِسّْڭعّْذنْ غَارْ ؤُجنَّا، أجّْ أَنغْ أَذْ نْشبَّارْ ذِي شّْهَاذثْ نّسْ. \x ◘ \xo 4:‏14 \xt عبر. 3‏:‏1؛ 6‏:‏20؛ 8‏:‏1؛ 9‏:‏11. \x*  
\v 15 مِينْزِي وَارْ غَارْنغْ أَرَّايْسْ ن إِكهَّاننْ إِ وَارْ إِزمَّارْ أَذْ يَاشَا أَكْ-ذ ثُوضْعفْثْ نّغْ، مَاشَا إِجّنْ ونِّي إِتّْوَاجَارّْبنْ ذِي مَارَّا أَمْ نشِّينْ، مَاشَا بْڒَا دّنْبْ. \x ◘ \xo 4:‏15 \xt إِشا. 53‏:‏9؛ 2 كُور. 5‏:‏21؛ فِيل. 2‏:‏7؛ عبر. 2‏:‏18؛ 1 بُط. 2‏:‏22؛ 1 يُوح. 3‏:‏5. \x*  
\v 16 س ؤُينِّي أجّْ أَنغْ أَذْ د-نْقَارّبْ خنِّي س تِّيقّثْ غَارْ ڒْعَارْشْ ن أَرْضَا نّسْ، حِيمَا أَذْ نكْسِي أَرّحْمثْ ؤُشَا أَذْ نَافْ أَرْضَا ذِي ڒْوقْثْ ن ڒْمحْنثْ. \x ◘ \xo 4:‏16 \xt رُوم. 3‏:‏25. \x*   
\b  
\b  
\m  
\c 5
\m
\v 1 مِينْزِي كُوڒْ أَرَّايْسْ ن إِكهَّاننْ \add إِتّْوَاكّسْ-د\add* زڭْ إِوْذَانْ، إِتّْوَاسّْڭعّذْ ذِي طّْوعْ ن إِوْذَانْ خْ مِينْ إِدْجَانْ ن أَربِّي، مَاحنْذْ أَذْ إِقدّمْ ثِيوْهِيبِينْ ذ ثْغَارْصِينْ خْ دّْنُوبْ.  
\v 2 إِزمَّارْ أَذْ إِمَّارْسْ إِخفْ نّسْ، أَذْ إِحِينّْ خْ إِقُوبَّانِييّنْ ذ إِمْودَّارنْ، مِينْزِي ؤُڒَا ذ نتَّا سِيمَانْثْ نّسْ يَارْضْ ثُوضْعفْثْ.  
\v 3 مَاغَارْ س مَانْ أَيَا ذ إِشْثنْ إِتّْخصَّا أَسْ أَذْ إِسّْڭعّذْ ثِيغَارْصِينْ خْ دّْنُوبْ ن ڒْڭنْسْ ؤُشَا عَاوذْ خْ \add دّْنُوبْ ن\add* يِيخفْ نّسْ. \x ◘ \xo 5:‏3 \xt لَاوِي 9‏:‏7؛ 16‏:‏6؛ عبر. 7‏:‏26. \x*  
\v 4 ؤُڒَا ذ إِجّنْ أَذْ إِكْسِي إِ يِيخفْ نّسْ شَّانْ\add -أَ\add*، مْغِيرْ ونِّي إِتّْوَاڒَاغَانْ زِي أَربِّي أَمْ مَامّشْ \add إِتّْوَاڒَاغَا\add* هَارُونْ. \x ◘ \xo 5:‏4 \xt ؤُف. 28‏:‏1؛ 1 إِم. 23‏:‏13؛ 2 إِم. 26‏:‏16. \x*  
\v 5 أَمُّو عَاوذْ لْمَاسِيحْ وَارْ إِسّْعُودْجِي شَا إِخفْ نّسْ ؤُمِي إِذْوڒْ ذ أَرَّايْسْ ن إِكهَّاننْ، مَاشَا \add إِسّْعُودْجْ\add* ونِّي د غَارسْ إِسِّيوْڒنْ:  
\b  
\m \qt ”شكْ ذ مِّي،\qt*  
\m \qt نشّْ جِّيغْ-د شكْ أَسّْ-أَ!“\qt* \x ◘ \xo 5:‏5 \xt إِزهد. 2‏:‏7؛ ڒخ. 13‏:‏33؛ عبر. 1‏:‏5. \x*   
\b  
\m
\v 6 أَمْ مَامّشْ إِنَّا عَاوذْ ذِي مَانِي نّغْنِي:  
\b  
\m \qt ”شكْ ذ أَكهَّانْ إِ ڒبْذَا،\qt*  
\m \qt ذڭْ وَارْوَاسْ ن مَالْكِيصَاذِيقْ.“\qt* \x ◘ \xo 5:‏6 \xt إِزهد. 110‏:‏4؛ عبر. 7‏:‏17. \x*   
\b  
\m
\v 7 ڒَامِي ثُوغَا يَارّضْ \add أَرِّيمثْ ن\add* ويْسُومْ \add نّسْ\add*، إِقدّمْ ثِيژَادْجِيثِينْ ذ ثُوثْرَا س إِغُويَّانْ أَطَّاسْ ؤُ س إِمطَّاونْ إِ ونِّي ثُوغَا إِزمَّارنْ أَذْ ث-إِ-د-إِسّْنكَّارْ زِي ڒْموْثْ إِ ثُوذَارْثْ، ؤُشَا نتَّا إِسْڒَا أَسْ. \x ◘ \xo 5:‏7 \xt مت. 26‏:‏39؛ 27‏:‏46، 50؛ يُوح. 17‏:‏1. \x*  
\v 8 نتَّا، وَاخَّا ثُوغَا-ث ذ مِّيسْ، أَقَا إِڒْمذْ طَّاعثْ س ثِيڭّْوُوذِي ؤُ زڭْ ؤُودّبْ إِ إِكْسِي. \x ◘ \xo 5:‏8 \xt فِيل. 2‏:‏6. \x*  
\v 9 أَمُّو إِ إِذْوڒْ نتَّا إِكمّڒْ، إِذْوڒْ ذ سِّيبّثْ ن ثُوذَارْثْ إِتّْذُومَانْ إِ مَارَّا إِنِّي ذ أَسْ إِ غَا إِطَّاعنْ،  
\v 10 ؤُشَا إِڭَّا إِ-ث أَربِّي ذ أَرَّايْسْ ن إِكهَّاننْ ذڭْ وَارْوَاسْ ن مَالْكِيصَاذِيقْ. \x ◘ \xo 5:‏10 \xt إِزهد. 110‏:‏4\x*   
\b  
\m
\v 11 أَقَا غَارْنغْ أَطَّاسْ مِينْ غَا نِينِي خْ مَالْكِيصَاذِيقْ وَانِيثَا، مَاشَا إِوْعَارْ أَذْ ث نْفسَّارْ، مِينْزِي ثْذوْڒمْ ثوْعَارمْ أَذْ ثسْڒمْ.  
\v 12 مَاغَارْ ثُوغَا إِتّْخصَّا أَذْ ثِيڒِيمْ ذ إِمسْغَارنْ زِي جِّيهثْ ن ڒْمِيجَاڒْ ن ڒْوقْثْ إِ ثْضفَّارمْ ثْغُورِي-يَا. مَاشَا ڒخُّو إِتّْخصَّا أَومْ عَاذْ أَذْ ثْڒمْذمْ لْحُورُوفْ إِمزْوُورَا ن بدُّو ن وَاوَاڒنْ ن أَربِّي، كنِّيوْ ثحْذَاجمْ \add عَاذْ\add* أَغِي ذڭْ ومْشَانْ ن مَاشَّا إِجهْذنْ. \x ◘ \xo 5:‏12 \xt 1 كُور. 3‏:‏1، 2، 3. \x*  
\v 13 مِينْزِي كُوڒْ إِجّنْ ونِّي إِشَارْشنْ ذڭْ ؤُغِي، وَارْ إِقدّْ خْ وَاوَاڒْ ن ثْسڭْذَا، مِينْزِي نتَّا ذ أَسيْمِي \add عَاذْ\add*.  
\v 14 مَاشَا مَاشَّا إِجهْذنْ إِفّغْ-د إِ يِينِّي إِمْغَارنْ، إِنِّي أَقَا نُّومنْ أَذْ ذَارّْبنْ ثَاشِيثْ نْسنْ حِيمَا أَذْ فَارْزنْ ڒْخَارْ خْ ڒْغَارْ.   
\b  
\b  
\m  
\c 6
\s1 ذْسَاسْ إِمْثنْ ذ ڒْوَاعْذْ وَارْ إِبدّْڒنْ  
\m
\v 1 س ؤُينِّي أَذْ نجّْ ثَامزْوَارُوثْ ن وَاوَاڒْ ن لْمَاسِيحْ، أَذْ نُويُورْ زَّاثْ غَارْ ؤُكمّڒْ. مَايمِّي خنِّي ثخْسمْ أَذْ ثسَّارْسمْ عَاوذْ ذْسَاسْ نّغْنِي إِ تُّوبثْ زِي ڒخْذَايمْ إِمُّوثنْ ؤُ إِ لْ-إِيمَانْ ذِي أَربِّي،  
\v 2 ؤُ إِ ثْغُورِي ن ؤُسغْضصْ ذ ؤُسَارْسِي ن إِفَاسّنْ ؤُڒَا إِ ثْنُوكْرَا زِي ثَادَّارْثْ ن إِمتِّيننْ ذ لْحِيسَابْ إِ ڒبْذَا؟  
\v 3 مَاڒَا \add أَذْ أَنغْ\add* إِسْمحْ سِيذِي مَانْ أَيَا، أَذْ ث نڭّْ. \x ◘ \xo 6:‏3 \xt ڒخ. 18‏:‏21؛ 1 كُور. 4‏:‏19؛ يَاع. 4‏:‏15. \x*   
\m
\v 4 مَاشَا وَارْ ذ أَسنْ إِزمَّارْ إِ يِينِّي د-إِهْوَانْ إِ ؤُسغْضصْ إِشْثْ ن ثْوَاڒَا ؤُشَا قَّاسنْ ثَاوْهِيبْثْ ن ؤُجنَّا ؤُشَا طّْفنْ أَرُّوحْ إِقدّْسنْ، \x ◘ \xo 6:‏4 \xt مت. 12‏:‏31؛ عبر. 10‏:‏26؛ 1 يُوح. 5‏:‏16. \x*  
\v 5 ؤُشَا قَّاسنْ \add عَاوذْ\add* أَوَاڒْ إِشْنَانْ ن أَربِّي ذ جّهْذْ ن زّْمَانْ إِ د غَا يَاسنْ،  
\v 6 مَاحنْذْ أَذْ خْضَانْ عَاوذْ، ؤُشَا أَذْ تّْوَاسّْفَاقنْ إِ تُّوبثْ زِي جْذِيذْ، ؤُشَا أَذْ صلّْبنْ ؤُ أَذْ سّحْقَارنْ مِّيسْ ن أَربِّي إِشْثْ ن ثْوَاڒَا نّغْنِي.  
\v 7 مِينْزِي ثَامُّورْثْ، ثنِّي إِسسّنْ أَنْژَارْ ونِّي خَاسْ إِشَّاثنْ أَطَّاسْ ن ثْوَاڒَاوِينْ، ثسّْغمِّي أَغمُّويْ إِشْنَا إِ يِينِّي ؤُمِي ثتّْوَافدْجحْ، أَقَا ثكْسِي لْبَارَاكَا زِي أَربِّي.  
\v 8 مَاشَا مَاڒَا ثسّغْمِي-د \add ثمُّورْثْ\add* إِسنَّاننْ ذ ثْزڭّْوَارْثْ، أَقَا ثمّنْضَارْ ؤُ ثُوذسْ إِ نّعْڒثْ ؤُشَا أَنڭَّارْ \add ن ثمُّورْثْ\add* أَذْ يِيڒِي ذ أَشْمَاضْ.   
\b  
\m
\v 9 مَاشَا وَاخَّا نسَّاوَاڒْ أَمُّو، زِي جِّيهثْ نْومْ \add أَ\add* أَيْثْمَا، أَقَا نتّْوَاسّقْنعْ أَقَا ذِينْ ثِيمسْڒَايِينْ إِشْنَانْ إِتّْرَاحنْ نِيشَانْ أَكْ-ذ ثُوذَارْثْ.  
\v 10 مِينْزِي أَربِّي وَارْ إِدْجِي ذ ونِّي وَارْ إِسڭّْذنْ مَاحنْذْ أَذْ إِتُّو ڒْخذْمثْ نْومْ ذ ثَايْرِي نْومْ، ثِينِي ثُوغَا ثسّشْنمْ ذڭْ يِيسمْ نّسْ، إِ زَّايسْ ثُوغَا كنِّيوْ ثْسخَّارمْ إِ إِمْقدَّاسنْ ؤُشَا ثتّْسخَّارمْ \add أَسنْ عَاذْ\add*. \x ◘ \xo 6:‏10 \xt أَوڒن. 14‏:‏31؛ مت. 10‏:‏42؛ 25‏:‏40؛ مك. 9‏:‏41؛ يُوح. 13‏:‏20. \x*  
\v 11 مَاشَا ذَايْنغْ مژْرِي حِيمَا كُوڒْ إِجّنْ زَّايْومْ أَذْ إِسّْشنْ أَمْحَاضْ ذ إِجّْ إِ ؤُكمّڒْ ن ؤُسِيثمْ أَڒْ أَنڭَّارْ،  
\v 12 أَقَا وَارْ ثدّكّْوَاڒَامْ ذ إِمعْڭَازْ، مَاشَا أَذْ ثِيڒِيمْ ذ إِمضْفَارنْ ن يِينِّي س لْ-إِيمَانْ ذ تَّاسِيعْ ن ڒْخَاضَارْ ذوْڒنْ ذ إِوْرِيثنْ ن لْوَاعْذْ.   
\m
\v 13 مِينْزِي ڒَامِي إِوَاعْذْ أَربِّي إِبْرَاهِيمْ، إِجُّودْجْ س يِيخفْ نّسْ، مِينْزِي وَارْ ذِينْ إِدْجِي ونّغْنِي إِمْغَارْ خَاسْ مَاحنْذْ أَذْ أَسْ إِجَّادْجْ،  
\v 14 إِنَّا:  
\b  
\m \qt ”س ثِيذتّْ، أَذْ أَشْ بَارْكغْ\qt*  
\m \qt ؤُشَا أَذْ أَشْ أَرْنِيغْ أَطَّاسْ س وَاطَّاسْ.“\qt* \x ◘ \xo 6:‏14 \xt أَمز. 12‏:‏3؛ 17‏:‏4؛ 22‏:‏16‏-‏17؛ إِزهد. 105‏:‏9؛ لك. 1‏:‏73. \x*   
\b  
\m
\v 15 ؤُشَا أَمُّو، أَمْ إِتّْصبَّارْ \add إِبْرَاهِيمْ\add*، أَقَا إِكْسِي لْوَاعْذْ.  
\v 16 مَاغَارْ إِوْذَانْ جُّودْجنْ غَارْ مِينْ خَاسنْ إِدْجَانْ ذ أَمقّْرَانْ ؤُ مَارَّا أَمْشُوبّشْ جَارْ أَسنْ أَذْ إِقْضَا نِيشَانْ س إِشْثْ ن ثْجَادْجِيثْ. \x ◘ \xo 6:‏16 \xt ؤُف. 22‏:‏11. \x*  
\v 17 س ؤُينِّي ثُوغَا إِخْسْ أَربِّي أَذْ إِسّْشنْ س ؤُفيّضْ إِ إِوْرِيثنْ بلِّي لْوَاعْذْ نّسْ وَارْ إِتّْبذِّيڒْ شَا، ؤُشَا إِضْمنْ إِ-ث س إِشْثْ ن ثْجَادْجِيثْ.  
\v 18 حِيمَا س ثْنَاينْ ن ثْمسْڒَايِينْ وَارْ تّْبذِّيڒنْثْ شَا - أَمْ وَارْ إِزمَّارْ خنِّي أَذْ إِسّْخَارّقْ أَربِّي - أَذْ ذَايْنغْ إِتّْوَاڭّْ ؤُڒْ س وَاطَّاسْ، أَقَا ذَايْنغْ ذِي نشِّينْ إِنِّي غَارسْ أَروْڒنْ، حِيمَا أَذْ نطّفْ ذڭْ ؤُسِيثمْ إِ ذ أَنغْ إِتّْوَاوَاعْذنْ،  
\v 19 ذ ونِّي غَارْنغْ أَمْ يِيجّْ ن ؤُڒيْزِيمْ إِشبَّارنْ س ڒْمثْنثْ ذِي ڒعْمَارْ نّغْ، \add إِجّْ ن ؤُڒيْزِيمْ\add* إِ د-إِتَّاذْفنْ غَارْ ذَاخڒْ ن ؤُڒحَّافْ ن وَاذَافْ.  
\v 20 مَانِي يُوذفْ يَاسُوع ونِّي ذ أَنغْ إِزْوَارنْ خْ ثِيزِي نّغْ، أَقَا إِذْوڒْ ذ أَكهَّانْ إِ ڒبْذَا ذڭْ وَارْوَاسْ ن مَالْكِيصَاذِيقْ. \x ◘ \xo 6:‏20 \xt عبر. 3‏:‏1؛ 4‏:‏14؛ 8‏:‏1؛ 9‏:‏11. \x*   
\b  
\b  
\m  
\c 7
\s1 مَالْكِيصَاذِيقْ ذ أَجدْجِيذْ ذ أَكهَّانْ  
\m
\v 1 مَالْكِيصَاذِيقْ وَانِيثَا ثُوغَا ذ أَجدْجِيذْ ن سَالِيمْ، أَكهَّانْ ن أَربِّي ونِّي ذ أَمْعُودْجِي خْ كُوڒْشِي، ؤُ نتَّا إِفّغْ-د حِيمَا أَذْ إِڒْقَا إِبْرَاهِيمْ ڒَامِي د-إِذْوڒْ زِي ثَارژِّيثْ ن إِجدْجِيذنْ، ؤُ نتَّا إِبَاركْ \add إِبْرَاهِيمْ\add*. \x ◘ \xo 7:‏1 \xt أَمز. 14‏:‏17‏-‏20. \x*  
\v 2 إِبْرَاهِيمْ إِكْسِي إِجّْ ن ڒعْشُورْ زِي مَارَّا مِينْ غَارسْ إِ نتَّا. إِسمْ نّسْ إِخْسْ أَذْ يِينِي: ’أَجدْجِيذْ ن ثْسڭْذَا‘، ؤُ عَاوذْ: ’أَجدْجِيذْ ن سَالِيمْ‘، مِينْ إِخْسْ أَذْ يِينِي ’أَجدْجِيذْ ن ڒهْنَا‘. \x ◘ \xo 7:‏2 \xt إِزهد. 85‏:‏11\x*  
\v 3 نْحْڒَا مَا تّْوَازمّنْ بَابَاسْ ذ يمَّاسْ ذڭْ \add إِذْلِيسنْ ن\add* جَّاذِيرَا، ؤُ نْحْڒَا بدُّو ن وُوسَّانْ نّسْ نِيغْ أَنڭَّارْ ن ثُوذَارْثْ نّسْ، \add مَاشَا\add* ذڭْ وَارْوَاسْ ن مِّيسْ ن أَربِّي، أَقَا ثقِّيمْ ثُوكهَّانْثْ نّسْ إِ ڒبْذَا.   
\m
\v 4 خْزَارمْ ڒخُّو، مشْحَاڒْ ثُوغَا إِمْغَارْ وَانِيثَا خْ أَرَّايْسْ ن ڒجْذُوذْ \add نّغْ\add* إِبْرَاهِيمْ إِ ث إِوْشِينْ ڒعْشُورْ زِي مِينْ إِصبْحنْ قَاعْ!  
\v 5 مَاغَارْ إِنِّي إِكْسِينْ ثُوكهَّانْثْ زڭْ أَيْثْ ن لَاوِي، أَقَا غَارْسنْ ثَاوْصيّثْ عْلَاحْسَابْ شَّارِيعَا حِيمَا أَذْ كْسِينْ ڒعْشُورْ زِي ڒْڭنْسْ، إِعْنَا زڭْ أَيْثْمَاثْسنْ، ؤُمِي نِيثْنِي فّْغنْ-د عَاوذْ زِي ذْوَاخڒْ ن إِبْرَاهِيمْ. \x ◘ \xo 7:‏5 \xt ڒخْڒ. 18‏:‏21؛ أَعَوذ. 18‏:‏1؛ ياش. 14‏:‏4؛ 2 إِم. 31‏:‏5. \x*  
\v 6 مَاشَا \add مَالْكِيصَاذِيقْ\add* وَانِيثَا، ونِّي وَارْ إِزمّنْ ذڭْ إِذْلِيسنْ نْسنْ ن جَّاذِيرَا، إِكْسِي زِي إِبْرَاهِيمْ ڒعْشُورْ ؤُشَا إِبَاركْ إِ ونِّي إِطّْفنْ لْوَاعْذْ. \x ◘ \xo 7:‏6 \xt أَمز. 14‏:‏20. \x*  
\v 7 أَقَا بْڒَا أَوَاڒْ، ونِّي إِدْجَانْ قلّْ، أَقَا أَذْ إِتّْوَابَاركْ زڭْ ونِّي إِدْجَانْ حْسنْ زَّايسْ.  
\v 8 أَقَا ذَانِيثَا إِوْذَانْ إِفنَّانْ كسِّينْ ڒعْشُورْ، مَاشَا ذِينِّي ثنْ \add إِطّفْ\add* نتَّا، نتَّا ذ ونِّي خْ شهّْذنْثْ ثِيرَا \add إِقدّْسنْ\add*، أَقَا إِدَّارْ.  
\v 9 أَمُّو نْزمَّارْ أَذْ نِينِي بلِّي لَاوِي، ونِّي إِكْسِينْ ڒعْشُورْ، أَقَا إِعشَّارْ \add عَاوذْ\add* س ؤُفُوسْ ن إِبْرَاهِيمْ،  
\v 10 مِينْزِي ثُوغَا-ث عَاذْ ذِي ذْوَاخڒْ ن بَابَاسْ أَڒَامِي إِمْسَاڭَارْ وَانِيثَا أَكْ-ذ مَالْكِيصَاذِيقْ.   
\b  
\m  
\s1 أَرَّايْسْ ن إِكهَّاننْ يُوعْڒَانْ خْ هَارُونْ  
\m
\v 11 مَاڒَا ڒكْمَاڒثْ ثُوغَا-ت س ثُوكهَّانْثْ ن لَاوِي، مِينْزِي ثَانِيثَا ثتّْوَاضْمنْ إِ ڒْڭنْسْ س شَّارِيعَا، مَايمِّي عَاذْ إِتّْخصَّا أَذْ د-إِكَّارْ ؤُكهَّانْ نّغْنِي ذڭْ وَارْوَاسْ ن مَالْكِيصَاذِيقْ؟ \add مَاڒَا أَمُّو إِ ثدْجَا\add*، زعْمَا إِنَّا نتَّا بلِّي أَذْ يِيڒِي ذِي صِّيفثْ ن هَارُونْ! \x ◘ \xo 7:‏11 \xt إِزهد. 110‏:‏4؛ ڭال. 2‏:‏21. \x*  
\v 12 مَاشَا أَمْ مَامّشْ ثُوغَا ذِينْ إِجّْ ن ؤُبدّڒْ ن ثُوكهَّانْثْ، أَمُّو ثُوغَا ذِينْ عَاوذْ إِجّْ ن ؤُبدّڒْ ن شَّارِيعَا.  
\v 13 مِينْزِي ونِّي مِيخفْ إِتّْوَانَّا أَيَا، أَقَا إِتّْوَاخْڒقْ-د زِي ثقْبِيتْشْ نّغْنِيثْ، إِ زِي ؤُڒَا ذ إِجّْ وَارْ إِسخَّارْعمَّارْصْ غَارْ ؤُعَالْطَارْ.  
\v 14 أَقَا بَاينْ بلِّي سِيذِيثْنغْ إِفّغْ-د زِي يَاهُوذَا، زِي ثَاقْبِيتْشْ إِ وَارْ خْ إِسِّيوڒْ مُوسَا ؤُڒَا س يِيجّْ ن وَاوَاڒْ خْ ثُوكهَّانْثْ. \x ◘ \xo 7:‏14 \xt إِشا. 11‏:‏1؛ مت. 1‏:‏3. \x*  
\v 15 س مَانْ أَيَا عَاوذْ ثْبَانْ قَاعْ مْلِيحْ، أَقَا نتَّا إِنَّا بلِّي أَذْ د-إِكَّارْ ؤُكهَّانْ نّغْنِي ذڭْ وَارْوَاسْ ن مَالْكِيصَاذِيقْ،  
\v 16 ونِّي وَارْ إِتّْوَاڭّنْ عْلَاحْسَابْ شَّارِيعَا ن ثْوصَّا إِ إِتّْهِيمَانْ أَرِّيمثْ، مَاشَا عْلَاحْسَابْ جّهْذْ ن ثُوذَارْثْ وَارْ إِفنَّانْ.  
\v 17 مِينْزِي نتَّا إِشْهذْ خَاسْ:  
\b  
\m \qt ”شكْ ذ أَكهَّانْ إِ ڒبْذَا\qt*  
\m \qt ذڭْ وَارْوَاسْ ن مَالْكِيصَاذِيقْ!“\qt* \x ◘ \xo 7:‏17 \xt إِزهد. 110‏:‏4؛ عبر. 5‏:‏6. \x*   
\b  
\m
\v 18 مِينْزِي ثَاوْصيّثْ ثنِّي ثُوغَا قْبڒْ ثتّْوَاخْڒفْ زِي سِّيبّثْ ن ثُوضْعفْثْ نّسْ ذ بْڒَا نّْفَاعْ نّسْ.  
\v 19 مِينْزِي شَّارِيعَا وَارْ ثتِّيوِي قَاعْ أَكمّڒْ، مَاشَا ذڭْ ومْشَانْ نّسْ يُوسَا-د ؤُسِيثمْ ذ أَمقّْرَانْ إِ زِي نْزمَّارْ أَذْ نَاذسْ أَربِّي، \x ◘ \xo 7:‏19 \xt يُوح. 1‏:‏17؛ ڒخ. 13‏:‏39؛ رُوم. 3‏:‏21، 28؛ 8‏:‏3؛ ڭال. 2‏:‏16. \x*  
\v 20 ؤُ نتَّا إِضْمنْ مَانْ أَيَا س إِشْثْ ن ثْجَادْجِيثْ.  
\v 21 مَاغَارْ نِيثْنِي ذوْڒنْ ذ إِكهَّاننْ بْڒَا ثَاجَادْجِيثْ، مَاشَا وَانِيثَا س إِشْثْ ن ثْجَادْجِيثْ ؤُمِي نتَّا ذ أَسْ إِنَّا س \add ؤُقمُّومْ ن\add* ذَاوُوذْ:  
\b  
\m \qt ”أَقَا سِيذِي إِجِّيدْجْ،\qt*  
\m \qt وَارْ إِسّْخَارِّيقْعمَّارْصْ:\qt*  
\m \qt ’شكْ ذ أَكهَّانْ إِ ڒبْذَا\qt*  
\m \qt ذِي صِّيفثْ ن مَالْكِيصَاذِيقْ.‘ “\qt* \x ◘ \xo 7:‏21 \xt إِزهد. 110‏:‏4. \x*   
\b  
\m
\v 22 ذِي مَارَّا مَانْ أَيَا إِدْجَا ڒْعَاهْذْ-أَ، إِ زِي إِذْوڒْ يَاسُوع ذ أَضْمَانْ، قَاعْ حْسنْ.   
\m
\v 23 ثُوغَا ذِينْ \add ذِي ڒْوقْثْ نِّي عَاوذْ\add* أَطَّاسْ ن إِكهَّاننْ، مِينْزِي نِيثْنِي مُّوثنْ، تّْوَامنْعنْ أَذْ قِّيمنْ.  
\v 24 مَاشَا خْ وَانِيثَا وَارْ خَاسْ ثْعدُّو ثُوكهَّانْثْ نّسْ، مِينْزِي نتَّا أَذْ إِقِّيمْ إِبدّْ إِ ڒبْذَا.  
\v 25 س ؤُينِّي إِزمَّارْ أَذْ إِوْشْ ثُوذَارْثْ إِتّْذُومَانْ إِ يِينِّي زَّايسْ إِ د غَا قَارّْبنْ غَارْ أَربِّي، مِينْزِي نتَّا إِدَّارْ إِ ڒبْذَا ؤُشَا إِوهّبْ ثِيژَادْجِيثِينْ ذِي طّْوعْ نّغْ. \x ◘ \xo 7:‏25 \xt 1 تِيم. 2‏:‏5؛ 1 يُوح. 2‏:‏1. \x*  
\v 26 مِينْزِي ثُوغَا إِتّْڒِيقْ أَنغْ إِجّْ ن ؤُكهَّانْ أَمْ وَانِيثَا: أَمزْذَاڭْ، بْڒَا ڒْغشّْ ذ ثَاخْمُوجِي، إِتّْوَافَارْزنْ زڭْ إِمذْنَابْ، يُوعْڒَانْ خْ إِجنْوَانْ،  
\v 27 ونِّي وَارْ غَارْ إِدْجِي ڒْخصّْ أَسّْ خْ وَاسّْ أَمْ إِرُّويَاسْ ن إِكهَّاننْ، حِيمَا أَذْ إِقدّمْ أَمزْوَارْ ثِيغَارْصِينْ خْ دّْنُوبْ ن يِيخفْ نّسْ، ؤُشَا خنِّي عَاوذْ خْ دّْنُوبْ ن ڒْڭنْسْ، مِينْزِي أَيَا إِڭَّا إِ-ث إِشْثْ ن ثْوَاڒَا إِ ڒبْذَا قَاعْ، ڒَامِي إِوْشَا إِخفْ نّسْ ذ ثَاغَارْصْثْ. \x ◘ \xo 7:‏27 \xt لَاوِي 9‏:‏7؛ 16‏:‏6؛ عبر. 5‏:‏3. \x*  
\v 28 أَقَا شَّارِيعَا ثسّْڭعّذْ إِوْذَانْ إِضعْفنْ ذ إِكهَّاننْ، مَاشَا أَوَاڒْ ن ثْجَادْجِيثْ، ونِّي أَوَارْنِي شَّارِيعَا، إِسّْڭعّذْ مِّيسْ ونِّي إِتّْوَاكمّْڒنْ إِ ڒبْذَا.   
\b  
\b  
\m  
\c 8
\s1 أَرَّايْسْ ن إِكهَّاننْ ن إِجّْ ن ڒْعَاهْذْ يُوعْڒَانْ  
\m
\v 1 لْمُوفِيذْ زِي مَارَّا مَانْ أَيَا، أَقَا غَارْنغْ أَرَّايْسْ ن إِكهَّاننْ، ونِّي إِقِّيمنْ غَارْ يفُوسْ ن ڒْعَارْشْ ن لْعَاضِيمْ ذڭْ إِجنْوَانْ. \x ◘ \xo 8:‏1 \xt أَفا. 1‏:‏20؛ كُول. 3‏:‏1؛ عبر. 3‏:‏1؛ 4‏:‏14؛ 6‏:‏20؛ 9‏:‏11؛ 12‏:‏2. \x*  
\v 2 نتَّا ذ أَمْسيَّارْ ن زَّاوشْثْ إِقدّْسنْ ؤُ ن ثْزذِّيغْثْ إِقدّْسنْ ذ ثِيذتّْ نِّي إِبْنَا أَربِّي، وَارْ إِدْجِي ذ بْنَاذمْ.   
\m
\v 3 مِينْزِي كُوڒْ أَرَّايْسْ ن إِكهَّاننْ إِتّْوَاسّْڭعّذْ حِيمَا أَذْ إِوْشْ ثِيوْهِيبِينْ ذ ثْغَارْصِينْ. س ؤُينِّي ثُوغَا إِتّْخصَّا أَسْ إِ وَانِيثَا عَاوذْ أَذْ غَارسْ يِيڒِي شَا حِيمَا أَذْ ث إِوْشْ. \x ◘ \xo 8:‏3 \xt أَفا. 5‏:‏2. \x*  
\v 4 معْلِيكْ إِدْجَا ذِي ثمُّورْثْ، نتَّا وَارْ إِتِّيڒِي ذ أَكهَّانْ، مِينْزِي أَقَا ذِينْ إِكهَّاننْ \add عَاذْ\add* إِنِّي إِتّْقدَّامنْ ثِيوْهِيبِينْ عْلَاحْسَابْ شَّارِيعَا.  
\v 5 نِيثْنِي سخَّارنْ إِ ؤُمذْيَا ذ ثِيڒِي ن مِينْ إِدْجَانْ ذڭْ ؤُجنَّا، أَمْ مَامّشْ إِتّْوَانَّا إِ مُوسَا ؤُمِي ثُوغَا إِڒْهَا أَكْ-ذ ؤُقِيضُونْ إِقدّْسنْ: ”حْضَاثْ، أَذْ ثڭّذْ مَارَّا أَمْ لْمِيثَالْ ونِّي ذ أَشْ سّشْنغْ خْ وذْرَارْ.“ \x ◘ \xo 8:‏5 \xt ؤُف. 25‏:‏40؛ ڒخ. 7‏:‏44؛ كُول. 2‏:‏17؛ عبر. 10‏:‏1. \x*   
\m
\v 6 \add مَاشَا\add* ڒخُّو يَاسُوع لْمَاسِيحْ إِكْسِي ثَاسخَّارْثْ ثشْنَا خَاسْ، مِينْزِي ڒْعَاهْذْ إِ زِي إِذْوڒْ نتَّا ذ لْوَاسِيثْ، أَقَا حْسنْ قَاعْ، ؤُشَا إِمّوْشْ س لْوُوعُوذْ إِشْنَانْ خْ يِينِّي \add إِ د-إِتَّاسنْ أَكْ-ذ ڒْعَاهْذْ أَقْذِيمْ\add*. \x ◘ \xo 8:‏6 \xt 2 كُور. 3‏:‏6. \x*  
\v 7 مِينْزِي مَاڒَا ثُوغَا \add ڒْعَاهْذْ\add* أَمزْوَارُو بْڒَا ڒْعِيبْ، وَارْ إِتِّيڒِي عَاذْ ومْشَانْ إِ ونِّي ذ وِيسّْ ثْنَاينْ.  
\v 8 مَاغَارْ نتَّا يُوفَا ذَايْسنْ ڒْعِيبْ، إِنَّا:  
\b  
\m \qt ”خْزَارْ، أَذْ د-أَسنْ وُوسَّانْ، إِنَّا سِيذِي،\qt*  
\m \qt خْمِي غَا ڭّغْ إِجّْ ن ڒْعَاهْذْ ن جْذِيذْ\qt*  
\m \qt ذِي ڒكْمَارثْ،\qt*  
\m \qt إِ ڒَادْجْ ن ثَادَّارْثْ ن إِسْرَائِيل\qt*  
\m \qt ؤُ إِ ڒَادْجْ ن ثَادَّارْثْ ن يَاهُوذَا،\qt* \x ◘ \xo 8:‏8 \xt إِرْم. 31‏:‏31‏-‏34؛ مت. 26‏:‏28، مك. 14‏:‏24، لك. 22‏:‏20، 1 كُور. 11‏:‏25، 2 كُور. 3‏:‏6، عبر. 8‏:‏6، 8، 13؛ 9‏:‏15؛ 12‏:‏24\x*   
\m
\v 9 \qt وَارْ إِدْجِي أَمْ ڒْعَاهْذْ نِّي وْشِيغْ إِ ڒجْذُوذْ نْسنْ،\qt*  
\m \qt ذڭْ وَاسّْ مِينْ ذِي ثنْ طّْفغْ زڭْ ؤُفُوسْ،\qt*  
\m \qt ڭوّْذغْ ثنْ زِي ثمُّورْثْ ن مِيصْرَا.\qt*  
\m \qt مِينْزِي نِيثْنِي وَارْ قِّيمنْ شَا ذِي ڒْعَاهْذْ إِنُو،\qt*  
\m \qt نْضَارغْ ثنْ، إِقَّارْ سِيذِي.\qt*   
\m
\v 10 \qt مَاشَا ذ وَا ذ ڒْعَاهْذْ إِ غَا وْشغْ\qt*  
\m \qt إِ ڒَادْجْ ن ثَادَّارْثْ ن إِسْرَائِيل:\qt*  
\m \qt ’أَوَارْنِي وُوسَّانْ نِّي، إِنَّا سِيذِي،\qt*  
\m \qt أَذْ ڭّغْ إِزرْفَانْ إِنُو ذِي ڒعْقڒْ نْسنْ،\qt*  
\m \qt ؤُشَا أَذْ ثنْ أَرِيغْ ذڭْ وُوڒَاونْ نْسنْ،\qt*  
\m \qt ؤُشَا نشّْ أَذْ أَسنْ إِڒِيغْ ذ أَربِّي،\qt*  
\m \qt نِيثْنِي أَذْ أَيِي إِڒِينْ ذ ڒْڭنْسْ.\qt*   
\m
\v 11 \qt ؤُڒَا ذ إِجّنْ أَذْ إِسّڒْمذْ\qt*  
\m \qt مِّيسْ ن ثمُّورْثْ نِيغْ ؤُمَاسْ،\qt*  
\m \qt أَذْ يِينِي: سّنْ سِيذِي!،\qt*  
\m \qt مِينْزِي مَارَّا أَذْ أَيِي سّْننْ،\qt*  
\m \qt أَمْ ؤُمژْيَانْ نْسنْ أَمْ ؤُمقّْرَانْ نْسنْ.\qt* \x ◘ \xo 8:‏11 \xt يُوح. 6‏:‏45، 65؛ 1 يُوح. 2‏:‏27. \x*   
\m
\v 12 \qt مِينْزِي نشّْ أَذْ ثنْ سّصْفِيغْ\qt*  
\m \qt زِي ڒْمُوعْصِييّثْ نْسنْ،\qt*  
\m \qt ؤُشَا دّْنُوبْ نْسنْ وَارْ ذَايْسنْ تّْفكَّارغْ عَاذْ.‘ “\qt* \x ◘ \xo 8:‏12 \xt إِرْم. 31‏:‏31‏-‏34. \x*   
\b  
\m
\v 13 ڒَامِي إِنَّا: ’جْذِيذْ!‘، أَقَا إِڭَّا \add ڒْْعَاهْذْ\add* أَمزْوَارُو ذ أَقْذِيمْ، ؤُشَا مِينْ يَارْشَانْ ؤُ إِدُّويْسَارْ، أَقَا أَذْ إِفْنَا. \x ◘ \xo 8:‏13 \xt إِرْم. 31‏:‏31؛ مت. 26‏:‏28، مك. 14‏:‏24، لك. 22‏:‏20، 1 كُور. 11‏:‏25، 2 كُور. 3‏:‏6، عبر. 8‏:‏6، 8، 13؛ 9‏:‏15؛ 12‏:‏24\x*   
\b  
\b  
\m  
\c 9
\s1 ثَاسخَّارْثْ ن إِكهَّاننْ ذِي ثْزذِّيغْثْ إِقدّْسنْ  
\m
\v 1 مَاشَا غَارْ ؤُمزْوَارْ ثُوغَا ذِينْ ڒفْرُوضْ إِ ثْسخَّارْثْ ؤُ \add ثُوغَا ذِينْ\add* إِشْثْ ن زَّاوشْثْ إِقدّْسنْ ذِي دُّونشْثْ-أَ.  
\v 2 مِينْزِي ثَازذِّيغْثْ ثَامزْوَارُوثْ إِ ثتّْوَاڭّْ، ثُوغَا ذَايسْ ڒْقنْذِيڒْ ذ ثْزوْضَا ذ وغْرُومْ ن وسْشَانْ ؤُشَا قَّارنْ أَسْ: ’أَقدَّاسْ‘. \x ◘ \xo 9:‏2 \xt ؤُف. 26‏:‏1؛ 36‏:‏1؛ لَاوِي 24‏:‏5. \x*  
\v 3 مَاشَا ثَازذِّيغْثْ ن ذَاخڒْ، أَوَارْنِي إِ ؤُڒحَّافْ وِيسّْ ثْنَاينْ، قَّارنْ أَسْ ’أَقْذَاسْ خْ ؤُقدَّاسْ‘. \f ◼ \fr 9:‏3 \ft \+bd ’أَڒحَّافْ‘\+bd* - نِيغْ: ’أَرْوَاقْ‘.\f*  
\v 4 أَقَا ذَايسْ ڒْقشْعثْ ن وُورغْ إِ ڒبْخُورْ ؤُڒَا ذ تَّابُوثْ ن ڒْعَاهْذْ إِغدْجْفنْ س وُورغْ غَارْ مَارَّا إِغزْذِيسنْ. ثُوغَا ذَايسْ إِجّْ ن ؤُزنْبِيڒْ ن وُورغْ ذَايسْ ’مَانَّا‘، ؤُ \add ذَايسْ\add* ؤُڒَا ذ ثَاغَّارْشْثْ ن هَارُونْ ثنِّي إِتّْوَانُووّْشنْ ذ ثڒْوِيحِينْ \add ن وژْرُو\add* ن ڒْعَاهْذْ. \x ◘ \xo 9:‏4 \xt ؤُف. 25‏:‏10؛ 34‏:‏29؛ ڒخْڒ. 17‏:‏25؛ 1 إِج. 8‏:‏9؛ 2 إِم. 5‏:‏10. \x*  
\v 5 سنّجْ إِ مَانْ أَيَا أَقَا ذِينْ ’إِخِيرُوبنْ‘ ن ڒْعزّْ، إِنِّي إِدّْڒِينْ ثَاقبَّارْثْ ن وصْڒَاحْ \add إِ إِدْجَانْ خْ تَّابُوثْ\add* س ثِيڒِي ن وَافْرِيونْ نْسنْ. مَاشَا وَارْ غَارْنغْ بُو ڒْوقْثْ \add ڒخُّو\add* حِيمَا أَذْ نسِّيوڒْ خْ كُوڒْ إِشْثنْ زِي ثْمسْڒَايِينْ-أَ إِ إِتّْوَاسّْوجْذنْ أَمُّو. \x ◘ \xo 9:‏5 \xt ؤُف. 25‏:‏22. \x*  
\v 6 مَاشَا إِكهَّاننْ ثُوغَا تَّاذْفنْ ڒبْذَا غَارْ ثْزذِّيغْثْ نِّي غَارْ بَارَّا، \add ثنِّي ذ ثَامزْوَارُوثْ\add*، حِيمَا أَذْ \add ذَايسْ\add* كمّْڒنْ ثَاسخَّارْثْ نْسنْ. \x ◘ \xo 9:‏6 \xt ڒخْڒ. 28‏:‏3. \x*  
\v 7 مَاشَا أَرَّايْسْ ن إِكهَّاننْ ثُوغَا إِتَّاذفْ إِشْثْ ن ثْوَاڒَا ذڭْ ؤُسڭّْوَاسْ غَارْ ثْزذِّيغْثْ ن ذَاخڒْ أَكْ-ذ إِذَامّنْ إِ إِقدّمْ خْ يِيخفْ نّسْ ؤُڒَا خْ ؤُودَّارْ ن ڒْڭنْسْ. \x ◘ \xo 9:‏7 \xt ؤُف. 30‏:‏10؛ لَاوِي 16‏:‏2، 34؛ عبر. 9‏:‏25. \x*  
\v 8 س ثبْرِيذْثْ-أَ إِسّْشنْ أَرُّوحْ إِقدّْسنْ مْلِيحْ بلِّي أَبْرِيذْ إِقدّْسنْ عَاذْ وَارْ د-إِتّْوَامّضْهَارْ، ؤُمِي عَاذْ ثَازذِّيغْثْ ثَامزْوَارُوثْ ثْبدّْ. \x ◘ \xo 9:‏8 \xt يُوح. 14‏:‏6. \x*  
\v 9 ثَانِيثَا ثُوغَا ذ أَمذْيَا إِ ڒْوقْثْ نِّي ذِي ثُوغَا تّْقدَّامنْ صّْذَاقِي ذ ثْغَارْصِينْ نِّي وَارْ زمَّارنْثْ أَذْ أَوْينْثْ ڒكْمَارثْ غَارْ ثْنفْسشْثْ ن ونِّي إِ-ثنْثْ إِقدّْمنْ.  
\v 10 أَقَا أَثنْثْ ثُوغَا تّْهِيمَّانْثْ مْغِيرْ مَاشَّا ذ ثْسسِّي ذ إِبْرِيذنْ إِفَارْزنْ ن ؤُسغْضَاسْ \add ذڭْ وَامَانْ\add*، أَقَا أَثنْثْ ذ ڒفْرُوضْ إِ إِتّْهِيمَّانْ دَّاثْ وَاهَا، تّْوَامُورنْثْ أَڒْ ڒْوقْثْ ن وعْذَاڒْ ن ثْسڭْذَا. \x ◘ \xo 9:‏10 \xt لَاوِي 11‏:‏2؛ ڒخْڒ. 19‏:‏7‏-‏22. \x*   
\b  
\m  
\s1 أَكهَّانْ ذڭْ إِجنْوَانْ  
\m
\v 11 مَاشَا لْمَاسِيحْ إِ د-يُوسِينْ، أَقَا إِذْوڒْ ذ أَرَّايْسْ ن إِكهَّاننْ خْ ڒْخَارْ إِ إِڭَّا. نتَّا يُوذفْ غَارْ ثْزذِّيغْثْ ثَامقّْرَانْثْ إِكمّْڒنْ، ثنِّي وَارْ إِتّْوَاڭّنْ شَا س إِفَاسّنْ، وَارْ ثدْجِي زِي مِينْ د-إِتّْوَاخڒْقنْ. \x ◘ \xo 9:‏11 \xt عبر. 3‏:‏1؛ 4‏:‏14؛ 6‏:‏20؛ 8‏:‏1. \x*  
\v 12 وَارْ يُوذِيفْ شَا أَكْ-ذ إِذَامّنْ ن إِغَايْضنْ ذ إِعجْمِييّنْ ن إِجّْ ن ؤُسڭّْوَاسْ، مَاشَا أَقَا يُوذفْ إِشْثْ ن ثْوَاڒَا أَكْ-ذ إِذَامّنْ ن يِيخفْ نّسْ غَارْ زَّاوشْثْ إِقدّْسنْ ؤُ \add أَمُّو إِ\add* د-يِيوِي أَسنْجمْ إِتّْذُومَانْ. \x ◘ \xo 9:‏12 \xt ڒخ. 20‏:‏28؛ أَفا. 1‏:‏7؛ كُول. 1‏:‏14؛ عبر. 10‏:‏10؛ 1 بُط. 1‏:‏19؛ أَسَا. 1‏:‏5؛ 5‏:‏9\x*   
\m
\v 13 مِينْزِي مَاڒَا إِذَامّنْ ن إِغَايْضنْ ذ إِفُونَاسنْ إِمژْيَاننْ ذ إِغّضْ ن ؤُعجْمِي \add أَزڭّْوَاغْ\add* إِ إِتّْوَارُوشّنْ خْ يِينِّي إِتّْوَاخمْجنْ، أَقَا قدّْسنْ ؤُ سِّيزْذِيڭنْ ثنْ زِي جِّيهثْ ن ويْسُومْ نْسنْ \add ن أَرِّيمثْ\add*، \x ◘ \xo 9:‏13 \xt لَاوِي 16‏:‏14‏-‏16؛ ڒخْڒ. 19‏:‏4؛ عبر. 10‏:‏4. \x*  
\v 14 مشْحَاڒْ عَاذْ أَذْ سِّيزذْڭنْ إِذَامّنْ ن لْمَاسِيحْ ثَانفْسشْثْ نّغْ زِي ڒخْذَايمْ إِمُّوثنْ، حِيمَا أَذْ نخْذمْ أَربِّي إِدَّارنْ، أَقَا لْمَاسِيحْ ونِّي إِوْشِينْ إِخفْ نّسْ إِ أَربِّي س أَرُّوحْ ن ڒبْذَا ذ ثَاغَارْصْثْ وَارْ ذَايسْ بُو ڒْعِيبْ! \x ◘ \xo 9:‏14 \xt لك. 1‏:‏74؛ رُوم. 6‏:‏13؛ ڭال. 1‏:‏4؛ 2‏:‏20؛ أَفا. 5‏:‏2؛ ثِيث. 2‏:‏14؛ 1 بُط. 4‏:‏2؛ 1 يُوح. 1‏:‏7؛ أَسَا. 1‏:‏5. \x*  
\v 15 س ؤُينِّي أَقَا نتَّا ذ لْوَاسِيثْ ن ڒْعَاهْذْ ن جْذِيذْ، مَاغَارْ س ڒْموْثْ نّسْ إِذْوڒْ نتَّا ذ أَسنْجمْ إِ يِينِّي إِخطَّانْ ضِيدّْ ڒْعَاهْذْ أَمزْوَارْ، حِيمَا نِيثْنِي إِنِّي إِتّْوَاڒَاغَانْ إِ ڒْوَارْثْ ن ڒبْذَا، أَذْ طّْفنْ لْوَاعْذْ. \x ◘ \xo 9:‏15 \xt إِرْم. 31‏:‏31؛ مت. 26‏:‏28، مك. 14‏:‏24، لك. 22‏:‏20، 1 كُور. 11‏:‏25، 2 كُور. 3‏:‏6، عبر. 8‏:‏6، 8، 13؛ 9‏:‏15؛ 12‏:‏24؛ رُوم. 5‏:‏6؛ 1 بُط. 3‏:‏18. \x*   
\m
\v 16 مِينْزِي مَانِي إِدْجَا ڒْعَاهْذْ، إِتّْخصَّا أَذْ ثتّْوَاسَّارْڭبْ ڒْموْثْ ن ونِّي إِڭِّينْ ڒْعَاهْذْ.  
\v 17 مِينْزِي ڒْعَاهْذْ أَذْ إِذْوڒْ إِصْڒحْ وَاهَا خْمِي غَا إِمّثْ حذْ، وَارْ إِتِّيڒِي شَا نِيشَانْ مِينْ غَا يكّْ إِدَّارْ ونِّي إِڭِّينْ \add ڒْعَاهْذْ\add*. \x ◘ \xo 9:‏17 \xt ڭال. 3‏:‏15. \x*  
\v 18 س ؤُيَا ؤُڒَا ذ \add ڒْْعَاهْذْ\add* أَمزْوَارْ وَارْ إِتّْوَاضْمنْ شَا بْڒَا إِذَامّنْ.  
\v 19 مِينْزِي أَوَارْنِي ڒَامِي كُوڒْ ثَاوْصِييّثْ نِّي إِدْجَانْ ذِي شَّارِيعَا أَقَا إِوصَّا إِ ڒْڭنْسْ س ؤُفُوسْ ن مُوسَا، إِكْسِي نتَّا إِذَامّنْ ن ؤُفُونَاسْ أَمژْيَانْ أَكْ-ذ وَامَانْ ؤُڒَا ذ ثَاضُوفْثْ ثَازڭّْوَاغْثْ ذ ثْعلْدْجثْ، ؤُشَا إِرُوشّْ إِ-ثنْ خْ إِذْلِيسنْ إِتّْوَانّْضنْ ؤُ خْ مَارَّا ڒْڭنْسْ، \x ◘ \xo 9:‏19 \xt ؤُف. 24‏:‏6‏-‏8\x*  
\v 20 إِنَّا أَسنْ:  
\b  
\m \qt ”إِنَا ذ إِذَامّنْ ن ڒْعَاهْذْ،\qt*  
\m \qt إِ ذ أَومْ يُومُورْ أَربِّي.“\qt* \x ◘ \xo 9:‏20 \xt ؤُف. 24‏:‏8؛ مت. 26‏:‏28. \x*   
\b  
\m
\v 21 ثُوغَا إِرُوشّْ عَاوذْ ثَازذِّيغْثْ إِقدّْسنْ ذ مَارَّا ڒقْشُوعْ ن ثْسخَّارْثْ س إِذَامّنْ.  
\v 22 مَاغَارْ مَارَّا ثِيمسْڒَايِينْ نِّي إِدْجَانْ ذِي شَّارِيعَا تّْوَاسِّيزذْڭنْثْ س إِذَامّنْ ؤُشَا بْڒَا أَسِيزّڒْ ن إِذَامّنْ وَارْ ذِينْ إِدْجِي شَا وغْفَارْ.   
\m
\v 23 ثُوغَا قَاعْ إِتّْخصَّا أَذْ تّْوَاسِّيزْذڭنْثْ ثْمسْڒَايِينْ-أَ س ثْغَارْصَا إِ إِدْجَانْ ذ ڒمْثُوڒْ ن ثِيمسْڒَايِينْ إِ إِدْجَانْ ذڭْ إِجنْوَانْ، مَاشَا ثِيمسْڒَايِينْ نِّي إِدْجَانْ ن ؤُجنَّا سِيمَانْثْ نْسنْ س ثْغَارْصِينْ إِشْنَانْ زِي ثِينَا. \f ◼ \fr 9:‏23 \ft \+bd ’ثِيغَارْصِينْ‘\+bd* - نِيغْ ’دّْبَايحْ‘.\f*  
\v 24 مِينْزِي لْمَاسِيحْ وَارْ يُوذِيفْ شَا غَارْ زَّاوشْثْ إِقدّْسنْ إِ إِتّْوَاڭّنْ س إِفَاسّنْ، ذ ونِّي نتَّا ذ لْمِيثَالْ ن مِينْ إِدْجَانْ ذ ثِيذتّْ، مَاشَا غَارْ ؤُجنَّا سِيمَانْثْ نّسْ، حِيمَا أَذْ د-إِضْهَارْ ذِي طّْوعْ نّغْ قِيبَاتْشْ إِ أَربِّي.  
\v 25 وَارْ إِدْجِي حِيمَا أَذْ إِقدّمْ إِخفْ نّسْ أَطَّاسْ ن ثْوَاڒَاوِينْ أَمْ مَامّشْ ثُوغَا إِتَّاذفْ أَرَّايْسْ ن إِكهَّاننْ كُوڒْ أَسڭّْوَاسْ غَارْ زَّاوشْثْ إِقدّْسنْ س إِذَامّنْ وَارْ إِدْجِينْ نّسْ \x ◘ \xo 9:‏25 \xt ؤُف. 30‏:‏10؛ لَاوِي 16‏:‏2، 34؛ عبر. 9‏:‏7. \x*  
\v 26 - مِينْزِي مَاڒَا أَمُّو إِ إِدْجَا، إِڒِي إِتّْخصَّا أَذْ إِودّبْ \add يشُّو\add* أَطَّاسْ ن ثْوَاڒَاوِينْ زِي بدُّو ن دُّونشْثْ - مَاشَا ڒخُّو، غَارْ قطُّو ن دُّونشْثْ، إِوْشَا نتَّا إِخفْ نّسْ إِشْثْ ن ثْوَاڒَا حِيمَا أَذْ إِبطّڒْ دّْنُوبْ س ثْغَارْصْثْ نّسْ.   
\m
\v 27 أَمْ مَامّشْ ذ إِتّْوَاسَّارْسْ إِ إِوْذَانْ أَذْ مّْثنْ إِشْثْ ن ثْوَاڒَا، ؤُشَا خنِّي أَوَارْنِي إِ ڒْموْثْ نْسنْ \add أَذْ د-يَاسْ\add* ڒْحُوكْمْ،  
\v 28 أَمُّو عَاوذْ إِمّوْشْ لْمَاسِيحْ إِشْثْ ن ثْوَاڒَا ذ ثَاغَارْصْثْ، إِوْشَا ذڭْ يِيخفْ نّسْ ثَاغَارْصْثْ ن دّنْبْ إِ وَاطَّاسْ، مَاشَا غَارْ ثْوَاسِيثْ نّسْ إِ ثْوَاڒَا وِيسّْ ثْنَاينْ أَذْ إِتّْوَاژَارْ بْڒَا دّنْبْ إِ ثُوذَارْثْ ن يِينِّي ث إِتّْرَاجَانْ. \x ◘ \xo 9:‏28 \xt رُوم. 5‏:‏6، 8؛ 1 بُط. 3‏:‏18. \x*   
\b  
\b  
\m  
\c 10
\s1 أَصْڒَاحْ إِ ڒبْذَا  
\m
\v 1 مِينْزِي ثُوغَا شَّارِيعَا ذ ثِيڒِي ن ڒْخَارْ إِ د غَا يَاسنْ \add وَاهَا\add*، وَارْ غَارسْ طّْبِيعثْ ن ثْمسْڒَايِينْ سِيمَانْثْ نْسنْثْ. س ؤُينِّي وَارْ زمَّارنْثْ ثْغَارْصَا نِّي، وَاخَّا إِوْينْ ثنْثْ-إِ-د كُوڒْ أَسڭّْوَاسْ، أَذْ أَوْينْثْ ڒكْمَارثْ خْ يِينِّي ثنْثْ د-إِتّْقَارَّابنْ. \x ◘ \xo 10:‏1 \xt كُول. 2‏:‏17؛ عبر. 8‏:‏5. \x*  
\v 2 مِينْزِي مَاڒَا إِبَانْ-د أَقَا ثتَّاوْينْثْ غَارْ ڒكْمَارثْ، أَذْ ثِيڒِي تّْوَاسّْبدّنْ نِيثْنِي زڭْ ؤُوهّبْ ن ثْغَارْصَا نْسنْ أَطَّاسْ زڭْ وَامِي، مِينْزِي وَارْ ثتّْوَاكّْوُورْ عَاذْ ثْنفْسشْثْ نْسنْ س دّنْبْ أَوَارْنِي ڒَامِي تّْوَاسِّيزذْڭنْ إِشْثْ ن ثْوَاڒَا.  
\v 3 مَاشَا س مَانْ أَيَا تّْوَاسّْفكَّارنْ أَسنْ-د دّْنُوبْ نْسنْ كُوڒْ أَسڭّْوَاسْ،  
\v 4 مِينْزِي إِذَامّنْ ن إِفُونَاسنْ إِمژْيَاننْ ذ إِغَايْضنْ وَارْ زمَّارنْ أَذْ سِّيزْذڭنْ زِي دّْنُوبْ. \x ◘ \xo 10:‏4 \xt لَاوِي 16‏:‏14؛ ڒخْڒ. 19‏:‏4؛ عبر. 9‏:‏13. \x*  
\v 5 س ؤُينِّي ڒَامِي د-يُوذفْ غَارْ دُّونشْثْ، إِنَّا:  
\b  
\m \qt ”ثِيغَارْصَا نِيغْ ثِيوْهِيبِينْ وَارْ ثنْثْ ثخْسذْ،\qt*  
\m \qt مَاشَا أَقَا ثسّْيَارْضذْ أَيِي إِشْثْ ن أَرِّيمثْ.\qt* \x ◘ \xo 10:‏5 \xt إِزهد. 40‏:‏7؛ إِشا. 1‏:‏11؛ إِرْم. 6‏:‏20؛ عَام. 5‏:‏21. \x*   
\m
\v 6 \qt ثِيغَارْصِينْ ن وشْمَاضْ\qt*  
\m \qt أَكْ-ذ ثِيغَارْصَا ن ڒهْنَا إِ دّْنُوبْ\qt*  
\m \qt وَارْ ثنْثْ ثتَّارذْ.“\qt*   
\b  
\m
\v 7 ڒخْذنِّي نِّيغْ:  
\b  
\m \qt ”خْزَارْ، أَذْ د-أَسغْ!\qt*  
\m \qt - مِينْزِي يُورَا خَافِي ذڭْ وذْلِيسْ إِتّْوَانْضنْ -\qt*  
\m \qt حِيمَا أَذْ ڭّغْ مِينْ ثخْسذْ شكْ، \+tl أَ\+tl* أَربِّي!“\qt* \x ◘ \xo 10:‏7 \xt إِزهد. 40‏:‏8، 9\x*   
\b  
\m
\v 8 ثُوغَا إِنَّا قْبڒْ: ”ثِيغَارْصِينْ ذ ثوْهِيبِينْ ذ ثْغَارْصِينْ س ثْمسِّي ذ ثْغَارْصِينْ إِ دّْنُوبْ وَارْ ثنْثْ ثخْسذْ!“، وَاخَّا أَقَا أَثنْثْ تّْوَاقدّْمنْثْ عْلَاحْسَابْ شَّارِيعَا.  
\v 9 أَوَارْنِي مَانْ أَيَا إِنَّا: ”خْزَارْ، ؤُسِيغْ-د حِيمَا أَذْ ڭّغْ مِينْ ثخْسذْ شكْ، \add أَ\add* أَربِّي.“ س ؤُيَا إِكّسْ أَمزْوَارْ، حِيمَا أَذْ إِسّْڭعّذْ وِيسّْ ثْنَاينْ.  
\v 10 مَاغَارْ س مَانْ أَيَا، س ڒْخَاضَارْ نّسْ، أَقَا نتّْوَاقدّسْ \add ذڭْ\add* إِشْثْ ن ثْوَاڒَا س ثْغَارْصْثْ ن أَرِّيمثْ ن يَاسُوع لْمَاسِيحْ. \x ◘ \xo 10:‏10 \xt عبر. 9‏:‏12. \x*   
\m
\v 11 مَاغَارْ كُوڒْ أَكهَّانْ إِ ثُوغَا إِتّْسخَّارْ كُوڒْ أَسّْ، أَقَا إِوهّبْ أَطَّاسْ ن ثْوَاڒَاوِينْ سِيمَانْثْ ن ثْغَارْصَا، ثِينِّي وَارْ إِزمَّارنْ أَذْ سِّيزذْڭنْثْ زِي دّْنُوبْ.  
\v 12 مَاشَا وَانِيثَا إِقدّمْ إِشْثْ ن ثْغَارْصْثْ خْ دّْنُوبْ، ؤُشَا خنِّي إِقِّيمْ خْ يفُوسْ ن أَربِّي إِ ڒبْذَا. \x ◘ \xo 10:‏12 \xt إِزهد. 110‏:‏1؛ ڒخ. 2‏:‏34؛ 1 كُور. 15‏:‏25؛ أَفا. 1‏:‏20؛ كُول. 3‏:‏1؛ عبر. 1‏:‏13. \x*  
\v 13 زِي ڒخْذنِّي إِتّْرَاجَا أَڒْ ذ أَسْ تّْوَاڭّنْ ڒْعذْيَانْ نّسْ ذ ثَانبْذَاثْ سَاذُو إِضَارنْ نّسْ.  
\v 14 مِينْزِي س إِشْثْ ن ثْغَارْصْثْ أَقَا يِيوِي إِنِّي زَّايسْ إِتّْوَاقدّْسنْ غَارْ ڒكْمَارثْ إِ ڒبْذَا.   
\m
\v 15 مَاشَا أَرُّوحْ إِقدّْسنْ عَاوذْ إِشْهذْ إِ نشِّينْ، إِقَّارْ:   
\b  
\m
\v 16 \qt ”ذ وَا ذ ڒْعَاهْذْ إِ ذ أَسنْ غَا وْشغْ\qt*  
\m \qt أَوَارْنِي إِ وُوسَّانْ نِّي، إِقَّارْ سِيذِي:\qt*  
\m \qt ’أَذْ ڭّغْ شَّارِيعَا إِنُو ذِي ڒعْقڒْ نْسنْ،\qt*  
\m \qt أَذْ ت أَرِيغْ عَاوذْ ذڭْ وُوڒَاونْ نْسنْ،\qt* \x ◘ \xo 10:‏16 \xt إِرْم. 31‏:‏31‏-‏34؛ رُوم. 11‏:‏27؛ عبر. 8‏:‏8. \x*   
\m
\v 17 \qt ؤُشَا دّْنُوبْ نْسنْ ذ إِخطَّانْ نْسنْ،\qt*  
\m \qt عمَّارْصْ أَذْ ذَايْسنْ فكَّارغْ \+tl عَاذْ\+tl*.‘ “\qt* \x ◘ \xo 10:‏17 \xt إِرْم. 31‏:‏33، 34. \x*   
\b  
\m
\v 18 مَانِي إِتِّيڒِي \add خنِّي\add* وغْفَارْ إِ دّْنُوبْ، وَارْ ذِينْ إِقِّيمْ عَاذْ ثْغَارْصْثْ خْ دّْنُوبْ.  
\v 19 س ؤُينِّي، \add أَ\add* أَيْثْمَا، أَقَا غَارْنغْ تِّيقّثْ مَاحنْذْ أَذْ نَاذفْ غَارْ زَّاوشْثْ إِقدّْسنْ س إِذَامّنْ ن يَاسُوع، \x ◘ \xo 10:‏19 \xt يُوح. 10‏:‏9؛ 14‏:‏6؛ رُوم. 5‏:‏2؛ أَفا. 2‏:‏13؛ 3‏:‏12. \x*  
\v 20 خْ وبْرِيذْ ن جْذِيذْ إِدَّارنْ إِ ذ أَنغْ إِسّوْجذْ أَمْ \add وبْرِيذْ\add* ن جْذِيذْ إِ د-إِتَّاذْفنْ غَارْ ذَاخڒْ ن ؤُڒحَّافْ ن ثوَّارْثْ، ونِّي ذ ويْسُومْ نّسْ،  
\v 21 ؤُشَا أَقَا غَارْنغْ \add عَاوذْ\add* أَرَّايْسْ ن إِكهَّاننْ خْ ثَادَّارْثْ ن أَربِّي. \x ◘ \xo 10:‏21 \xt أَفا. 2‏:‏19؛ 1 تِيم. 3‏:‏1؛ 1 بُط. 4‏:‏17\x*  
\v 22 أجّْ أَنغْ خنِّي أَذْ د-نْقَارّبْ س وُوڒْ ن ثِيذتّْ، ذِي تِّيقّثْ ن لْ-إِيمَانْ، أَمْ تّْوَارُوشّنْ وُوڒَاونْ نّغْ ؤُ تّْوَاسِّيزْذڭنْ \add عَاوذْ\add* زِي ثْنفْسشْثْ ثَاعفَّانْثْ، ؤُ أَمْ ثتّْوَاسِّيرْذْ \add عَاوذْ\add* أَرِّيمثْ نّغْ س وَامَانْ إِصْفَانْ. \x ◘ \xo 10:‏22 \xt حِز. 36‏:‏25. \x*  
\v 23 أجّْ أَنغْ أَذْ نْشبَّارْ ذِي شّْهَاذثْ ن ؤُسِيثمْ نّغْ بْڒَا مَا أَذْ نَارْجِيجْ، مِينْزِي ذ ونِّي ذ أَنغْ إِوْشِينْ لْوَاعْذْ، ذَايسْ ڒَامَانْ.  
\v 24 أجّْ أَنغْ أَذْ نحْضَا إِجّْ إِ ونّغْنِي حِيمَا أَذْ نڭّْ ؤُڒْ ذڭْ وَايَاوْيَا غَارْ ثَايْرِي ؤُ غَارْ ڒخْذَايمْ ثِيصبْحَانِينْ.  
\v 25 وَارْ نتّجِّي شَا ثَامسْمُونْثْ نّغْ أَمْ مَامّشْ نُّومنْ شَا، مَاشَا أَذْ نسّمْحضْ إِجّنْ ونّغْنِي، مَاهُو عَاذْ خْمِي غَا ثْژَارمْ أَقَا أَسّْ نِّي يِيوضْ-د.   
\m
\v 26 مِينْزِي مَاڒَا إِخْضَا شَا ن إِجّْ نعْمَاذَا أَوَارْنِي مَا إِطّفْ ثُوسّْنَا ن ثِيذتّْ، خنِّي وَارْ ثقِّيمْ عَاذْ ثْغَارْصْثْ خْ دّْنُوبْ، \x ◘ \xo 10:‏26 \xt ڒخْڒ. 15‏:‏30؛ مت. 12‏:‏31؛ عبر. 6‏:‏4؛ 2 بُط. 2‏:‏20؛ 1 يُوح. 5‏:‏16. \x*  
\v 27 مَاشَا \add مْغِيرْ\add* أَرَاجِي ن لْحِيسَابْ إِسّْنخْڒْعنْ ذ ڒْعابُوقْ ن ثْمسِّي نِّي إِ غَا إِشّنْ ڒْعذْيَانْ.  
\v 28 مَاڒَا إِخْضَا حذْ أَكْ-ذ شَّارِيعَا ن مُوسَا، إِتّْخصَّا أَذْ إِمُّوثْ بْڒَا أَرّحْمثْ خْ ؤُقمُّومْ ن ثْنَاينْ نِيغْ ثْڒَاثَا ن ڒشْهُوذْ. \x ◘ \xo 10:‏28 \xt ڒخْڒ. 35‏:‏30؛ أَعَوذ. 17‏:‏6؛ 19‏:‏15؛ مت. 18‏:‏16؛ 2 كُور. 13‏:‏1. \x*  
\v 29 مشْحَاڒْ كْثَارْ إِتّْخصَّا أَذْ إِهْوَا لْعِيقَابْ خْ ؤُزدْجِيفْ ن ونِّي إِعفّْسنْ خْ مِّيسْ ن أَربِّي، ذ ونِّي إِحسّْبنْ إِذَامّنْ ن ڒْعَاهْذْ نّسْ إِ زِي ثُوغَا إِتّْوَاقدّسْ أَمشْنَاوْ إِذَامّنْ ن مَارَّا إِوْذَانْ، ذ ونِّي إِسّحْقَارنْ \add عَاوذْ\add* أَرُّوحْ ن أَرْضَا؟  
\v 30 مِينْزِي نسّنْ ذ ونِّي إِنَّانْ:  
\b  
\m \qt ”أَنْثَاقمْ إِ نشّْ ؤُمِي إِدْجَا،\qt*  
\m \qt نشّْ أَذْ ث خدْجْصغْ!“\qt*  
\b  
\m ؤُشَا عَاوذْ:  
\b  
\m \qt ”سِيذِي أَذْ إِحْكمْ ڒْڭنْسْ نّسْ.“\qt* \x ◘ \xo 10:‏30 \xt أَعَوذ. 32‏:‏35، 36؛ رُوم. 12‏:‏19. \x*   
\b  
\m
\v 31 سّعْذْ ذ أَبَارْشَانْ إِ ونِّي إِ غَا إِوْضَانْ ذڭْ إِفَاسّنْ ن أَربِّي إِدَّارنْ.  
\v 32 س ؤُيَا فكَّارمْ ذڭْ وُوسَّانْ إِمزْوُورَا ڒَامِي ثتّْوَاسّْغضْصمْ ؤُ ثُوغَا ثَاربُّومْ أَمنْغِي أَمقّْرَانْ أَمْ مَامّشْ خَاومْ ثكَّا ڒفْضِيحثْ ذ ڒْمحْنثْ.  
\v 33 ثْذوْڒمْ ذ إِجّْ ن أَفُورّجْ ؤُ ثْشَارْشمْ أَكْ-ذ إِنّغْنِي ؤُمِي ذَايْسنْ إِتّْوَاڭّْ أَمُّو كِيفْكِيفْ.  
\v 34 مِينْزِي ثكْسِيمْ أَمْنُوسْ خْ يِينِّي إِتّْوَاحبّْسنْ، ؤُشَا ثْقبْڒمْ أَكشّضْ ن وَاڭْڒَا نْومْ س ڒفْرَاحثْ، ثسّْنمْ بلِّي غَارْومْ أَڭْڒَا إِمْغَارْ إِ وَارْ إِفنِّينْ ذڭْ إِجنْوَانْ. \x ◘ \xo 10:‏34 \xt مت. 5‏:‏12؛ ڒخ. 21‏:‏33. \x*  
\v 35 وَارْ نطَّارمْ شَا ثَارْيَاسْثْ نْومْ نِّي غَارْ ثدْجَا إِشْثْ ن ڒْمُونثْ ثمْغَارْ.  
\v 36 مِينْزِي إِتّْخصَّا كنِّيوْ صّْبَارْ حِيمَا أَذْ ثڭّمْ مِينْ إِخْسْ أَربِّي ؤُ مَاحنْذْ أَذْ ثطّْفمْ لْوَاعْذْ. \x ◘ \xo 10:‏36 \xt لك. 21‏:‏19. \x*   
\b  
\m
\v 37 \qt ”مِينْزِي ذْرُوسْ ن ڒْوقْثْ إِ ذِينِّي، وَاهْ ذْرُوسْ،\qt*  
\m \qt \+tl أَڒْ\+tl* ونِّي د غَا يَاسنْ أَذْ إِخشّْ،\qt*  
\m \qt وَارْ إِتّْعطَّاڒْ شَا.\qt* \x ◘ \xo 10:‏37 \xt حَاب. 2‏:‏2‏-‏3؛ Ḥag. 2‏:‏7؛ 1 بُط. 1‏:‏6؛ 5‏:‏10. \x*   
\m
\v 38 \qt مَاشَا أَمْسڭَّاذْ س لْ-إِيمَانْ إِنُو أَذْ إِدَّارْ،\qt*  
\m \qt مَاشَا مَاڒَا إِسْمحْ،\qt*  
\m \qt وَارْ ذَايسْ يَارطِّي ڒعْمَارْ إِنُو.“\qt* \x ◘ \xo 10:‏38 \xt حَاب. 2‏:‏4؛ رُوم. 1‏:‏17؛ ڭال. 3‏:‏11. \x*   
\b  
\m
\v 39 مَاشَا نشِّينْ وَارْ غَارْنغْ مِينْ غَا نڭّْ س ثَارخُّوثْ إِ إِتَّاوْينْ غَارْ ثْخسَّارْثْ، مَاشَا غَارْنغْ لْ-إِيمَانْ إِ إِتَّاوْينْ غَارْ ؤُسنْجمْ ن ڒعْمَارْ نّغْ.   
\b  
\b  
\m  
\c 11
\s1 ڒشْهُوذْ س لْ-إِيمَانْ  
\m
\v 1 لْ-إِمَانْ ڒخُّو ذ أَضْمَانْ ن ثْمسْڒَايِينْ نِّي ذِي إِسِّيثِيمْ بْنَاذمْ، أَخْمِي ثِينَا عَاذْ خدّْمنْثْ، ؤُڒَا ذ أَسَارْڭبْ ن ثْمسْڒَايِينْ إِنُّوفَّارنْ.  
\v 2 مِينْزِي س مَانْ أَيَا ثُوسَا-د إِشْثْ ن شّْهَاذثْ خْ إِمْغَارنْ.   
\m
\v 3 س لْ-إِيمَانْ نفْهمْ بلِّي زّْمَانَاثْ تّْوَاڭّنْثْ س وَاوَاڒْ ن أَربِّي، ؤُ بلِّي ثِيمسْڒَايِينْ-أَ إِ د-إِتّْبَاننْ أَقَا تّْوَاڭّنْثْ زِي ثْمسْڒَايِينْ نِّي إِنُّوفَّارنْ. \x ◘ \xo 11:‏3 \xt أَمز. 1‏:‏1؛ إِزهد. 33‏:‏6؛ يُوح. 1‏:‏10؛ رُوم. 4‏:‏17؛ أَفا. 3‏:‏9؛ كُول. 1‏:‏16. \x*   
\m
\v 4 س لْ-إِيمَانْ ثُوغَا \bd هَابِيلْ\bd* إِقدّمْ إِشْثْ ن ثْغَارْصْثْ ثشْنَا أَطَّاسْ خْ مِينْ ثُوغَا إِقدّمْ قَايِينْ إِ أَربِّي. س ؤُيَا إِ ذِينْ ثدْجَا شّْهَاذثْ خَاسْ بلِّي ثُوغَا-ث ذ أَمْسڭَّاذْ. ؤُشَا أَربِّي إِشْهذْ إِ ثْغَارْصْثْ نّسْ ؤُ س ؤُيَا إِسَّاوَاڒْ عَاذْ، وَاخَّا نتَّا إِمُّوثْ. \x ◘ \xo 11:‏4 \xt أَمز. 4‏:‏4؛ مت. 23‏:‏35. \x*   
\m
\v 5 س لْ-إِيمَانْ إِمّكْسِي \bd إِنُوخْ\bd* بْڒَا مَا إِقَّاسْ ڒْموْثْ. وَارْ إِتّْوِيفْ عَاذْ، مِينْزِي إِكْسِي إِ-ث أَربِّي. مِينْزِي قْبڒْ مَا أَذْ ث إِكْسِي، ثُوغَا خَاسْ شّْهَاذثْ-أَ: أَقَا ثُوغَا يَارطَّا أَربِّي. \x ◘ \xo 11:‏5 \xt أَمز. 5‏:‏22، 24. \x*  
\v 6 مَاشَا بْڒَا لْ-إِيمَانْ وَارْ إِزمَّارْ بْنَاذمْ أَذْ يَارْضَا أَربِّي، مِينْزِي ونِّي إِ غَا د-إِقَارّْبنْ غَارْ أَربِّي، إِتّْخصَّا أَسْ أَذْ يَامنْ بلِّي نتَّا أَقَا-ث ذِينْ، ؤُ بلِّي نتَّا ذ أَمْخدْجَاصْ ن يِينِّي خَاسْ يَارزُّونْ.   
\m
\v 7 س لْ-إِيمَانْ ثُوغَا \bd نُوحْ\bd* إِتّڭّْوذْ، أَوَارْنِي ڒَامِي ذ أَسْ إِتّْوَانَّا مِينْ ثُوغَا وَارْ د-إِتّْبِيننْ، ؤُشَا إِڭَّا أَغَارَّابُو إِ ؤُسنْجمْ ن إِحنْجِيرنْ ن ثْوَاشُونْثْ نّسْ. س مَانْ أَيَا أَقَا إِحْكمْ خْ دُّونشْثْ ؤُشَا إِذْوڒْ نتَّا ذ أَوْرِيثْ ن ثْسڭْذَا نِّي إِدْجَانْ س لْ-إِيمَانْ. \x ◘ \xo 11:‏7 \xt أَمز. 6‏:‏13. \x*   
\m
\v 8 س لْ-إِيمَانْ ثُوغَا \bd إِبْرَاهِيمْ\bd*، ڒَامِي د-إِتّْوَاڒَاغَا، إِطَّاعْ ؤُشَا إِفّغْ غَارْ ومْشَانْ إِ غَا إِطّفْ ذ ڒْوَارْثْ، ؤُشَا إِفّغْ بْڒَا مَا أَذْ إِسّنْ مَانِي غَا يَاوضْ. \x ◘ \xo 11:‏8 \xt أَمز. 12‏:‏4. \x*  
\v 9 س لْ-إِيمَانْ ثُوغَا إِزدّغْ أَمْ ؤُمْعزّبْ ذِي ثمُّورْثْ إِ ذ أَسْ إِتّْوَاوَاعْذنْ، أَمْ ذِي ثمُّورْثْ ن إِبَارَّانِييّنْ. نتَّا إِزْذغْ ذڭْ إِقِيضَانْ أَكْ-ذ إِسْحَاقْ ذ يَاعْقُوبْ، إِنِّي ذ إِوْرِيثنْ أَكِيذسْ ن لْوَاعْذْ نِّي.  
\v 10 مِينْزِي إِتّْرَاجَا ثَانْذِينْثْ س ذْسُوسَا إِ زِي إِدْجَا أَربِّي ذ بَابْ ن ڒبْنِي ذ ونِّي ت إِڭِّينْ.   
\m
\v 11 س لْ-إِيمَانْ إِمّوْشْ أَسْ إِ \bd سَارَا\bd* جّهْذْ مَاحنْذْ أَذْ ثكْسِي دّيْسثْ - وَاخَّا نتَّاثْ وَارْ د-ثتِّيرُووْ، ؤُشَا أَمْ ت ثُوغَا عَاذْ بَارَّا إِ ڒْمِيجَاڒْ ن ثوْسَارْ نّسْ - ثُورُووْ-د مِينْزِي ثُوغَا ثسّنْ نِيشَانْ بلِّي ونِّي ذ أَسْ إِوَاعْذنْ، ذَايسْ ڒَامَانْ. \x ◘ \xo 11:‏11 \xt أَمز. 17‏:‏19؛ 21‏:‏2؛ لك. 1‏:‏36. \x*  
\v 12 س ؤُينِّي عَاوذْ زڭْ إِجّنْ، أَقَا زڭْ ونِّي ذِي إِبْضڒْ جّهْذْ نّسْ س ثوْسَارْ، تّْوَاڒْونْ أَسْ-د أَمْ يِيثْرَانْ ن ؤُجنَّا س ؤُبَارُّو نْسنْ ؤُ أَمْ يِيجْذِي خْ ثْمَا ن ڒبْحَارْ إِ وَارْ إِزمَّارْ أَذْ إِتّْوَاحْسبْ. \x ◘ \xo 11:‏12 \xt أَمز. 15‏:‏5؛ 22‏:‏17؛ رُوم. 4‏:‏18. \x*   
\m
\v 13 ذِي لْ-إِيمَانْ مُّوثنْ يِينَا مَارَّا بْڒَا مَا أَذْ طّْفنْ مِينْ ذ أَسنْ إِتّْوَاوَاعْذنْ، مَاشَا ژْرِينْ ث زِي ڒَاڭّْوَاجْ ؤُشَا فَارْحنْ زَّايسْ ؤُشَا نعْمنْ بلِّي نِيثْنِي ذ إِبَارَّانِييّنْ ذ إِمعْزَابْ خْ ثمُّورْثْ. \x ◘ \xo 11:‏13 \xt أَمز. 23‏:‏4؛ 47‏:‏9؛ يُوح. 8‏:‏53. \x*  
\v 14 \add مِينْزِي\add* إِنِّي إِقَّارنْ ثِيمسْڒَايِينْ أَمْ ثِينَا، سّشْننْ مْلِيحْ بلِّي نِيثْنِي أَرزُّونْ ثَانْذِينْثْ نْسنْ.  
\v 15 معْلِيكْ أَرْزُونْ خْ ثمُّورْثْ مَانِيسْ د-فّْغنْ، إِڒِي أَقَا ؤُفِينْ لْفُورْصَا حِيمَا أَذْعقْبنْ ذِينْ عَاوذْ.  
\v 16 مَاشَا ڒخُّو إِبَانْ-د مْلِيحْ أَقَا ذَايْسنْ مژْرِي غَارْ \add ثمُّورْثْ\add* نِّي حْسنْ، مِينْ إِخْسْ أَذْ يِينِي غَارْ ثنِّي ذڭْ ؤُجنَّا. س ؤُينِّي أَربِّي وَارْ إِسضْحِي شَا أَذْ أَسْ ڒَاغَانْ ’أَربِّي نْسنْ‘، مِينْزِي أَقَا إِسّوْجذْ أَسنْ إِشْثْ ن ثنْذِينْثْ. \x ◘ \xo 11:‏16 \xt ؤُف. 3‏:‏6؛ مت. 22‏:‏32؛ ڒخ. 7‏:‏32. \x*   
\m
\v 17 س لْ-إِيمَانْ إِوْشَا \bd إِبْرَاهِيمْ\bd*، ڒَامِي إِتّْوَاقدْجبْ، إِسْحَاقْ ذ ثَاغَارْصْثْ، ؤُشَا إِسَّارْسْ أَينِّي ن مِّيسْ نِّي إِطّفْ س لْوَاعْذْ، خْ ؤُعَالْطَارْ. \x ◘ \xo 11:‏17 \xt أَمز. 22‏:‏10. \x*  
\v 18 مَاشَا إِتّْوَانَّا أَسْ:  
\b  
\m \qt ”ذِي إِسْحَاقْ أَذْ أَشْ ڒَاغَانْ زَّارِيعثْ نّشْ.“\qt* \x ◘ \xo 11:‏18 \xt أَمز. 21‏:‏12؛ رُوم. 9‏:‏7؛ ڭال. 3‏:‏29. \x*   
\b  
\m
\v 19 ثُوغَا إِخَارّصْ أَكْ-ذ إِخفْ نّسْ، بلِّي أَربِّي إِزمَّارْ عَاوذْ أَذْ ث-إِ-د-إِسّْنكَّارْ جَارْ إِمتِّيننْ. س ؤُيَا إِذْوڒْ-د غَارسْ عَاوذْ س وبْرِيذْ ن يِيجّْ ن ؤُمذْيَا، \add أَمْ س ثْنُوكْرَا\add*.   
\m
\v 20 س لْ-إِيمَانْ زِي جِّيهثْ ن مِينْ ثُوغَا د-إِڭُّورنْ عَاذْ، إِبَاركْ \bd إِسْحَاقْ\bd* إِحنْجِيرنْ نّسْ، يَاعْقُوبْ ذ عِيسُو. \x ◘ \xo 11:‏20 \xt أَمز. 27‏:‏28، 39. \x*   
\m
\v 21 س لْ-إِيمَانْ ثُوغَا \bd يَاعْقُوبْ\bd*، ڒَامِي إِمُّوثْ، إِبَاركْ كُوڒْ إِجّنْ زڭْ إِحنْجِيرنْ ن يُوسُوفْ أَمْ ثُوغَا إِطّفْ ذڭْ إِخفْ ن ثغَّارْشْثْ نّسْ. \x ◘ \xo 11:‏21 \xt أَمز. 47‏:‏31؛ 48‏:‏15. \x*   
\m
\v 22 س لْ-إِيمَانْ ثُوغَا \bd يُوسُوفْ\bd*، ڒَامِي ثُوغَا إِمُّوثْ، إِسِّيوڒْ خْ وُوفُّوغْ ن أَيْثْ ن إِسْرَائِيل ؤُشَا إِوصَّا ثنْ خْ إِغْسَانْ نّسْ. \x ◘ \xo 11:‏22 \xt أَمز. 50‏:‏24‏-‏25. \x*   
\m
\v 23 س لْ-إِيمَانْ ثُوغَا \bd مُوسَا\bd*، ڒَامِي د-إِخْڒقْ، إِتّْوَاسّْنُوفَّارْ زِي لْوَالِيذِينْ نّسْ ثْڒَاثَا ن إِيُورنْ، ڒَامِي ژْرِينْ أَحنْجِيرْ إِصْبحْ، ؤُشَا \add س لْ-إِيمَانْ\add* وَارْ ڭّْوِيذنْ شَا زڭْ ڒُومُورْ ن ؤُجدْجِيذْ. \x ◘ \xo 11:‏23 \xt ؤُف. 2‏:‏2؛ ڒخ. 7‏:‏20. \x*   
\m
\v 24 س لْ-إِيمَانْ يُوڭِي مُوسَا، ڒَامِي إِمْغَارْ نتَّا، أَذْ أَسْ ڒَاغَانْ عَاذْ مِّيسْ ن يدْجِيسْ ن فِيرْعُونْ.  
\v 25 مْڒِي يُوفَا أَذْ يِيڒِي إِتّْوَازيَّارْ أَكْ-ذ ڒْڭنْسْ ن أَربِّي ؤُڒَا ذ ثَارِّيثْ ن مژْرِي ذِي دّْنُوبْ إِ ذْرُوسْ ن ڒْوقْثْ. \x ◘ \xo 11:‏25 \xt إِزهد. 84‏:‏11. \x*  
\v 26 ثُوغَا إِحسّبْ أَسحْقَارْ ن لْمَاسِيحْ ذ أَڭْڒَا أَمقّْرَانْ سنّجْ إِ ڒكْنُوزْ ن مِيصْرَا، مِينْزِي ثُوغَا إِخزَّارْ غَارْ زَّاثْ غَارْ ڒْمُونثْ.   
\m
\v 27 س لْ-إِيمَانْ إِجَّا مِيصْرَا، وَارْ إِڭّْوِيذْ شَا زڭْ ؤُخيّقْ ن ؤُجدْجِيذْ، مِينْزِي إِزِييَّارْ إِخفْ نّسْ أَخْمِي إِژْرَا أَربِّي إِ وَارْ إِتّْوَاژَارنْ.   
\m
\v 28 س لْ-إِيمَانْ إِڭَّا \add ثَاغَارْصْثْ ن\add* ؤُسعْذُو، ؤُشَا إِرُوشّْ إِذَامّنْ، حِيمَا أَمْكحَّاضْ ن إِمنْزَا نْسنْ وَارْ ثنْ إِتّْحِيذِي شَا. \x ◘ \xo 11:‏28 \xt ؤُف. 12‏:‏21. \x*   
\m
\v 29 س لْ-إِيمَانْ ژْوَانْ ڒبْحَارْ ن ؤُغَانِيمْ أَخْمِي كِّينْ ذِي ڒْبَارّْ، أَمْ تّْوَاصَارْضنْ إِمِيصْرِييّنْ \add زِي ڒبْحَارْ\add* ؤُمِي ثُوغَا خْسنْ أَذْ ذَايسْ شُوقنْ. \x ◘ \xo 11:‏29 \xt ؤُف. 14‏:‏22. \x*   
\m
\v 30 س لْ-إِيمَانْ وْضَانْ ڒحْيُوضْ ن أَرِيحَا ؤُمِي كِّينْ سبْعَا ن وُوسَّانْ، تّنّْضنْ أَسْ. \x ◘ \xo 11:‏30 \xt ياش. 6‏:‏20. \x*   
\m
\v 31 س لْ-إِيمَانْ وَارْ ثْهلِّيكْ شَا \bd رَاحَابْ\bd*، ثَامْغَارْثْ ن فَارْقْ-شّْغڒْ أَكْ-ذ يِينِّي وَارْ إِطِّيعنْ، أَمْ ثُوغَا ثَارحّبْ إِبرْڭَاڭنْ س ڒهْنَا. \x ◘ \xo 11:‏31 \xt ياش. 2‏:‏1؛ 6‏:‏23؛ يَاع. 2‏:‏25. \x*   
\m
\v 32 ؤُشَا مِينْ غَا إِنِيغْ عَاذْ؟ مِينْزِي ڒْوقْثْ وَارْ ثْقذِّي أَذْ سِّيوْڒغْ خْ \bd جِيذْعُونْ ذ بَارَاكْ ذ شَامْشُونْ ذ يِيفْثَا ذ ذَاوُوذْ ذ شَامْوِيلْ ؤُ خْ إِنَابِييّنْ إِنّغْنِي\bd*، \x ◘ \xo 11:‏32 \xt ڒقض. 4‏:‏6؛ 6‏:‏11؛ 11‏:‏1؛ 12‏:‏7؛ 13‏:‏24؛ 1 صم. 17‏:‏45؛ 1 صم. 12‏:‏2. \x*  
\v 33 إِنِّي ثُوغَا إِغلّْبنْ خْ ثْڭلْذِيوِينْ س لْ-إِيمَانْ، ڭِّينْ ثَاسڭْذَا، طّْفنْ لْوُوعُوذْ، قّْننْ إِخنْفُوشنْ ن وَايْرَاذنْ، \x ◘ \xo 11:‏33 \xt ڒقض. 14‏:‏6؛ 1 صم. 17‏:‏34؛ دَان. 6‏:‏23. \x*  
\v 34 سّْخسْينْ جّهْذْ ن ثْمسِّي، أَروْڒنْ زِي ڒقْضعْ ن سِّيفْ، كْسِينْ جّهْذْ ذِي ثُوضْعفْثْ، ذوْڒنْ جهْذنْ ذڭْ إِمنْغَانْ ؤُ قڒْعنْ خْ ڒمْرَاڭحْ ن ڒْعسْكَارْ ن إِبَارَّانِييّنْ. \x ◘ \xo 11:‏34 \xt 1 صم. 20‏:‏1؛ 1 إِج. 19‏:‏3؛ 2 إِج. 6‏:‏16؛ أَيُوبْ 42‏:‏10؛ إِزهد. 6‏:‏9؛ إِشا. 38‏:‏21. \x*  
\v 35 أَرِّينْ-د إِ ثمْغَارِينْ إِحنْجِيرنْ نْسنْثْ س ثْنُوكْرَا ن إِمتِّيننْ، شَا نّغْنِي مُّوثنْ س ڒعْذَابْ، ثُوغَا وَارْ تّْرِيجِينْ أَذْ تّْوَافكّنْ، مَاشَا أَذْ طّْفنْ ذِي ثْنُوكْرَا إِشْنَانْ حْسنْ زِي مَانْ أَيَا، \x ◘ \xo 11:‏35 \xt 1 إِج. 17‏:‏23؛ 2 إِج. 4‏:‏36؛ ڒخ. 22‏:‏25. \x*  
\v 36 شَا نّغْنِي كْسِينْ أَبهْذڒْ ذ ؤُركُّوضْ، ؤُ \add عَاذْ\add* إِنّغْنِي تّْوَاڭّنْ ذِي سّْنَاسڒْ ؤُ ذِي ڒحْبسْ. \x ◘ \xo 11:‏36 \xt إِرْم. 20‏:‏2. \x*  
\v 37 إِنّغْنِي تّْوَارجْمنْ، تّْوَاقسّنْ ذِي ثْنَاينْ، إِنّغْنِي مُّوثنْ س ڒقْضعْ ن سِّيفْ، ثلْعنْ أَمْ أَرْضنْ إِڒْمَاونْ ن وُودْجِي ذ إِغَايْضنْ، ذَايْسنْ ڒغْبنْ، تّْوَاحْصَارنْ، تّْوَاضڒْمنْ. \x ◘ \xo 11:‏37 \xt 1 إِج. 21‏:‏13؛ 2 إِج. 1‏:‏8؛ مت. 3‏:‏4. \x*  
\v 38 نِيثْنِي ذ إِوْذَانْ إِ وَارْ ذ أَسنْ ثسّْذَاهدْجْ دُّونِّيثْ \add حِيمَا أَذْ ذَايسْ زذْغنْ\add*. نِيثْنِي ذوْڒنْ ذ إِنِّي إِثلْعنْ ذِي ڒخْڒَاوَاثْ، خْ إِذُورَارْ ؤُ ذڭْ إِفْرَانْ ذ إِخرْذُوسنْ ن ثمُّورْثْ.   
\m
\v 39 مَارَّا إِنَا مِيخفْ ثتّْوَافْ إِشْثْ ن شّْهَاذثْ ن لْ-إِيمَانْ نْسنْ، وَارْ طِّيفنْ شَا ذِي لْوَاعْذْ،  
\v 40 مِينْزِي أَربِّي ثُوغَا إِزْوَارْ إِژْرَا ذِي طّْوعْ نّغْ، أَقَا نِيثْنِي وَارْ تِّيكّْوِيضنْ شَا غَارْ ڒكْمَارثْ بْڒَا نشِّينْ.   
\b  
\b  
\m  
\c 12
\s1 ضّْبَارْ ن يَاسُوع لْمَاسِيحْ  
\m
\v 1 س ؤُيَا نشِّينْ عَاوذْ، ؤُمِي ذ أَنغْ د-نّْضنْ مَارَّا ڒشْهُوذْ-أَ أَمْ إِسيْنُوثنْ، أَذْ ننْضَارْ مَارَّا دّْقڒْ ن دّنْبْ إِ ذ أَنغْ د-إِسّْوجْذنْ إِ ڒبْذَا. أجّْ أَنغْ أَذْ نُويُورْ س صّْبَارْ أَمْحِيزْوَارْ نِّي خَانغْ د-إِمَّارْسنْ. \x ◘ \xo 12:‏1 \xt رُوم. 6‏:‏4؛ 12‏:‏12؛ 1 كُور. 9‏:‏24؛ أَفا. 4‏:‏22؛ كُول. 3‏:‏8؛ عبر. 10‏:‏36؛ 1 بُط. 2‏:‏1، 2. \x*  
\v 2 أجّْ أَنغْ أَذْ ننْضَارْ ثِيطَّاوِينْ ذِي يَاسُوع، أَمْڭوَّاذْ ذ ؤُمْكمّڒْ ن لْ-إِيمَانْ نّغْ، ونِّي، زِي سِّيبّثْ ن ڒفْرَاحثْ إِ غَارسْ، يَارْبُو صَّالِيبْ، وَارْ ث إِشْقِي ؤُبهْذڒْ، ؤُشَا إِقِّيمْ خْ يفُوسْ ن ڒْعَارْشْ ن أَربِّي. \f ◼ \fr 12:‏2 \ft \+bd ’أَمْڭوَّاذْ‘\+bd* - نِيغْ: ’زَّاعِيمْ‘.\f*  \x ◘ \xo 12:‏2 \xt لك. 24‏:‏26؛ فِيل. 2‏:‏8‏-‏11؛ عبر. 1‏:‏3؛ 8‏:‏1؛ 1 بُط. 1‏:‏11. \x*  
\v 3 خْزَارمْ مْلِيحْ، مشْحَاڒْ إِ إِكْسِي نتَّا زڭْ إِمذْنَابْ، إِنِّي ذ إِغْرِيمنْ ن ڒعْمَارْ ن يِيخفْ نْسنْ، حِيمَا وَارْ ثتِّيحْڒمْ ؤُ وَارْ ثَارخُّومْ شَا ذِي ڒعْمَارْ نْومْ.  
\v 4 أَقَا كنِّيوْ، وَارْ ثْرُوحمْ شَا ثِيڭّْوجمْ أَكْ-ذ دّنْبْ، وَارْ ثمّْعَاڒِيمْ شَا أَڒْ \add ؤُسِيزّڒْ\add* ن إِذَامّنْ \add نْومْ\add*. \x ◘ \xo 12:‏4 \xt 1 كُور. 10‏:‏13. \x*  
\v 5 ثتُّومْ ثَاغُورِي إِ خَاومْ إِسَّاوَاڒنْ أَمْ إِحنْجِيرنْ:  
\b  
\m \qt ”مِّي إِنُو، وَارْ تّڭّْ شَا س وعْرُورْ\qt*  
\m \qt خْ تَّارْبِييّثْ ن سِيذِي،\qt*  
\m \qt وَارْ تِّيڒِي شَا ذ أَمَارْخُو ذِي ڒعْمَارْ نّشْ،\qt*  
\m \qt خْمِي غَا ثتّْوَاوبّْخذْ زَّايسْ.\qt* \x ◘ \xo 12:‏5 \xt أَيُوبْ 5‏:‏17؛ أَوڒن. 3‏:‏11‏-‏12؛ أَسَا. 3‏:‏19. \x*   
\m
\v 6 \qt مِينْزِي ونِّي إِتّخْسْ سِيذِي،\qt*  
\m \qt يَاربَّا إِ-ث س ؤُقسَّاحْ،\qt*  
\m \qt ؤُشَا إِحنْجِيرنْ نّسْ إِ خَاسْ إِعِيزّنْ،\qt*  
\m \qt إِكْسِي ثنْ كُوڒْ إِجّْ زَّايْسنْ غَارْ ؤُغزْذِيسْ.“\qt* \x ◘ \xo 12:‏6 \xt أَوڒن. 3‏:‏11، 12\x*   
\b  
\m
\v 7 خْ ؤُيَا، كْسِيمْ تَّارْبِييّثْ، مِينْزِي أَربِّي إِتّڭّْ أَومْ أَمْ إِحنْجِيرنْ نّسْ. مِينْزِي مَانْ مِّيسْ ونِّي بَابَاسْ وَارْ ث يَاربِّي شَا س ؤُقسَّاحْ؟  
\v 8 مَاڒَا أَقَا كنِّيوْ بْڒَا تَّارْبِييّثْ إِ ذِي شَارْشنْ مَارَّا، ڒخْذنِّي كنِّيوْ \add أَمْ\add* إِبَارَّانِييّنْ إِ ثدْجَامْ، وَارْ إِدْجِي ذ أَرَّاونْ.  
\v 9 مَاڒَا نكْسِي تَّارْبِييّثْ زِي بَابَاثْنغْ عْلَاحْسَابْ أَرِّيمثْ ؤُشَا نْوقَّارْ إِ-ثنْ، مشْحَاڒْ ذ أَنغْ إِتّْخصَّا أَذْ نْطَاعْ إِ بَابَاثْنغْ ن أَرُّوحَاثْ، \add حِيمَا\add* أَذْ ندَّارْ!  
\v 10 مِينْزِي نِيثْنِي وبّْخنْ أَنغْ شَا ن وُوسَّانْ أَمْ مَامّشْ ذ أَسنْ إِتّْغِيڒْ مْلِيحْ، مَاشَا أَربِّي إِڭَّا إِ-ت إِ ثِيزِي نّغْ، حِيمَا أَذْ نْشَارْشْ ذِي ثْقدَّاسْثْ نّسْ.  
\v 11 أَقَا وَارْ ذِينْ ؤُڒَا ذ إِشْثْ ن تَّارْبِييّثْ س ؤُقسَّاحْ إِ إِتّْبَاننْ ذ ڒفْرَاحثْ ذغْيَا، مَاشَا ذ ڒحْرِيقْ، مَاشَا أَوَارْنِي أَسْ ثِيوِي-د ڒْغِيدْجثْ ن ڒهْنَا ذ ثْسڭْذَا إِ يِينِّي زَّايسْ إِتّْوَاذَارّْبنْ.   
\m
\v 12 س ؤُينِّي، سْجهْذمْ إِفَاسّنْ نْومْ يَارْخُونْ ذ إِفَادّنْ نْومْ يَارهْفنْ، \x ◘ \xo 12:‏12 \xt إِشا. 35‏:‏3. \x*  
\v 13 ؤُشَا ڭّمْ نِيشَانْ إِصُورَافْ ن إِضَارنْ نْومْ، حِيمَا مِينْ إِدْجَانْ ذ أَقجْذَاحْ وَارْ إِتّفْرِيغْ شَا، مَاشَا أَذْ إِڭّنْفَا.   
\m
\v 14 ضْفَارمْ-د ڒهْنَا ذ ثُوقدّْسِي أَكْ-ذ مَارَّا، ثنِّي بْڒَا زَّايسْ وَارْ إِژَارْ حذْ سِيذِيثْنغْ. \x ◘ \xo 12:‏14 \xt رُوم. 12‏:‏18؛ 2 تِيم. 2‏:‏22. \x*  
\v 15 غَارْومْ أَقَا ؤُڒَا ذ إِجّْ جَارْ أَومْ أَذْ إِتّْوَافْ إِنْقصْ أَسْ أَرْضَا ن أَربِّي، نِيغْ أَقَا أَذْ إِغْمِي وژْوَارْ ن ثَارْزُوڭِي، أَذْ كنِّيوْ إِضَارّْ ؤُشَا خنِّي أَذْ زَّايسْ تّْوَاخمْجنْ أَطَّاسْ، \x ◘ \xo 12:‏15 \xt أَعَوذ. 29‏:‏17؛ ڒخ. 17‏:‏13؛ 2 كُور. 6‏:‏1؛ ڭال. 5‏:‏12. \x*  
\v 16 \add ؤُشَا\add* حْضَامْ، أَقَا وَارْ إِتّْوِيفِّي حذْ جَارْ أَومْ ونِّي ذ بُو-فَارْقْ-شّْغڒْ نِيغْ ذ أَمقْجُوحْ أَمْ عِيسُو نِّي إِزّنْزنْ ڒْحقّْ ن ؤُمنْزُو نّسْ خْ إِجّْ ن مَاشَّا. \x ◘ \xo 12:‏16 \xt أَمز. 25‏:‏33؛ أَفا. 5‏:‏3؛ كُول. 3‏:‏5؛ 1 تس. 4‏:‏3. \x*  
\v 17 مِينْزِي أَقَا ثسّْنمْ، بلِّي أَوَارْنِي مَانْ أَيَا ثُوغَا يَارزُّو \add عَاذْ\add* أَذْ إِوَارْثْ لْبَارَاكَا، مَاشَا يُوڭِي أَسْ، مَاغَارْ وَارْ يُوفِي شَا تَّاسِيعْ إِ وعْذَاڒْ، وَاخَّا يَارزُّو ث س إِمطَّاونْ. \x ◘ \xo 12:‏17 \xt أَمز. 27‏:‏36. \x*   
\m
\v 18 مِينْزِي كنِّيوْ وَارْ ثِيوِيضمْ شَا غَارْ ثْمسِّي يَارْغِينْ نِيغْ غَارْ وذْرَارْ إِ نْزمَّارْ أَذْ نْحَاذَا، ؤُڒَا غَارْ ثَايُّوثْ ثْبَارْشَانْثْ ذ ثْحَارْيَاضْثْ، \x ◘ \xo 12:‏18 \xt ؤُف. 19‏:‏10، 16؛ 20‏:‏21؛ أَعَوذ. 5‏:‏22. \x*  
\v 19 نِيغْ غَارْ زّْهِيرْ ن ؤُصُوذِي ذڭْ ؤُيِيشّْ \add ن إِشَارِّي\add* ؤُڒَا غَارْ ڒْحسّْ ن وَاوَاڒنْ ذِي سِّيبّثْ نْسنْ زَاوْڭنْ إِنِّي ذ أَسْ إِسْڒِينْ، مَاحنْذْ وَارْ ثنْ كِيسنْ إِسِّيوِيڒْ عَاذْ. \x ◘ \xo 12:‏19 \xt ؤُف. 20‏:‏19؛ أَعَوذ. 5‏:‏25؛ 18‏:‏16. \x*  
\v 20 س مِينْزِي وَارْ زمَّارنْ خْ دّْقڒْ ن ثْوصَّا، مِينْزِي مَاڒَا إِقَارّبْ-د مْغِيرْ إِجّْ ن ؤُمُودَّارْ أَذْرَارْ، أَذْ إِتّْوَارْجمْ نتَّا. \f ◼ \fr 12:‏20 \ft \+bd ’أَمُودَّارْ‘\+bd* - نِيغْ ’لْحَايَاوَانْ‘.\f*  \x ◘ \xo 12:‏20 \xt ؤُف. 19‏:‏13. \x*  
\v 21 مِينْ ژْرِينْ ثُوغَا إِسَّاڭّْوَاذْ أَطَّاسْ، أَڒَامِي إِنَّا مُوسَا: ”أَقَا ڭّْوذغْ ؤُ تَّارْجِيجِيغْ!“ \x ◘ \xo 12:‏21 \xt أَعَوذ. 9‏:‏19\x*   
\m
\v 22 مَاشَا كنِّيوْ ثِيوْضمْ غَارْ وذْرَارْ ن صِيهْيُونْ، غَارْ ثنْذِينْثْ ن أَربِّي إِدَّارنْ، غَارْ ؤُرْشَالِيمْ نِّي إِدْجَانْ ذڭْ إِجنْوَانْ ؤُ غَارْ ثْمسْمُونْثْ نعشْرَا ن ڒُوڒُوفَاثْ ن لْمَالَاكَاثْ، \x ◘ \xo 12:‏22 \xt ڭال. 4‏:‏26؛ أَسَا. 3‏:‏12؛ 21‏:‏10‏-‏27. \x*  
\v 23 غَارْ ثْمسْمُونْثْ ن إِمنْزَا، إِنِّي إِتّْوَازمّمنْ ذڭْ إِجنْوَانْ، ؤُ غَارْ أَربِّي، ڒْقَاضِي خْ مَارَّا ؤُ غَارْ أَرُّوحَاثْ ن إِمْسڭَّاذنْ نِّي إِوْضنْ غَارْ ڒكْمَارثْ، \x ◘ \xo 12:‏23 \xt لك. 10‏:‏20. \x*  
\v 24 ؤُ غَارْ يَاسُوع، لْوَاسِيثْ ن ڒْعَاهْذْ ن جْذِيذْ، ؤُ غَارْ ؤُرُوشِّي س إِذَامّنْ نّسْ، إِنِّي إِسَّاوَاڒنْ حْسنْ زڭْ إِنِّي ن هَابِيلْ. \x ◘ \xo 12:‏24 \xt إِرْم. 31‏:‏31؛ مت. 26‏:‏28، مك. 14‏:‏24، لك. 22‏:‏20، 1 كُور. 11‏:‏25، 2 كُور. 3‏:‏6، عبر. 8‏:‏6، 8، 13؛ 9‏:‏15؛ 12‏:‏24؛ أَمز. 4‏:‏10؛ عبر. 10‏:‏22؛ 11؛4؛ 1 بُط. 1‏:‏2. \x*   
\m
\v 25 غَارْومْ وَارْ ثَاڭِيمْ شَا خْ ونِّي أَكِيذْومْ إِسَّاوَاڒنْ، مِينْزِي مَاڒَا إِنِّي وَارْ إِتّْوَاسّْنجْمنْ ؤُڭِينْ ونِّي كِيذْسنْ إِسَّاوَاڒنْ ذِي ثمُّورْثْ، مَاهُو عَاذْ نشِّينْ، مَاڒَا نْحيّذْ خْ ونِّي أَكِيذْنغْ إِسَّاوَاڒنْ زڭْ إِجنْوَانْ، \x ◘ \xo 12:‏25 \xt عبر. 2‏:‏3. \x*  
\v 26 ونِّي ثُوغَا ثْمِيجَّا نّسْ ثسّنْهزَّا ثَامُّورْثْ، مَاشَا ونِّي ڒخُّو إِوَاعْذْ، إِنَّا:  
\b  
\m \qt ”أَذْ سّنْهزّغْ عَاوذْ إِشْثْ ن ثْوَاڒَا،\qt*  
\m \qt وَارْ إِدْجِي ثَامُّورْثْ وَاهَا، أَقَا ؤُڒَا ذ أَجنَّا.“\qt* \x ◘ \xo 12:‏26 \xt Ḥag. 2‏:‏5. \x*   
\b  
\m
\v 27 \add أَوَاڒْ-أَ\add*: ’إِشْثْ ن ثْوَاڒَا!‘، أَقَا إِمْڒَا بلِّي أَذْ إِتّْوَاكّسْ مِينْ إِتّنْهزَّانْ، مِينْزِي مَانْ أَيَا إِتّْوَاڭّْ، حِيمَا أَذْ قِّيمنْثْ ثْمسْڒَايِينْ وَارْ تّنْهزِّينْثْ.  
\v 28 س ؤُيَا، مِينْزِي أَذْ نطّفْ ثَاڭلْذِيثْ يَاركّْننْ، أجّْ أَنغْ أَذْ نقِّيمْ نتّطّفْ ذِي أَرْضَا إِ زِي نتّْسخَّارْ إِ أَربِّي ؤُ نسَّارْضَا إِ-ث س ؤُوقَّارْ ذ ثِيڭّْوُوذِي، \x ◘ \xo 12:‏28 \xt 1 بُط. 2‏:‏5. \x*  
\v 29 مِينْزِي أَربِّي نّغْ ذ إِشْثْ ن ثِيمسِّي إِتّتّنْ. \x ◘ \xo 12:‏29 \xt أَعَوذ. 4‏:‏24. \x*   
\b  
\b  
\m  
\c 13
\s1 أَوَاڒْ غَارْ ؤُنڭَّارْ أَكْ-ذ ؤُسدْجمْ  
\m
\v 1 أجّْ أَذْ ثقِّيمْ ثَايْرِي ن ثَاوْمَاثْ جَارْ أَومْ. \x ◘ \xo 13:‏1 \xt رُوم. 12‏:‏10؛ أَفا. 4‏:‏3؛ 1 بُط. 1‏:‏22؛ 2‏:‏17؛ 4‏:‏8. \x*  
\v 2 وَارْ ثتُّومْ شَا أَذْ ثِيڒِيمْ ثشْنَامْ أَكْ-ذ إِبَارَّانِييّنْ، أَقَا زعْمَا س ؤُيَا أَرحّْبنْ شَا س لْمَالَاكَاثْ أَمْ وَارْ سِّيننْ. \x ◘ \xo 13:‏2 \xt أَمز. 18‏:‏1؛ 19‏:‏1؛ رُوم. 12‏:‏13؛ 1 بُط. 4‏:‏9. \x*   
\m
\v 3 خَارّْصمْ ذڭْ إِمحْبَاسْ أَخْمِي كنِّيوْ حبّْسمْ أَكِيذْسنْ، خَارّْصمْ ذڭْ إِنِّي إِتّْوَاحْسَارنْ، أَمْ إِوْذَانْ \add أَمْ\add* كنِّيوْ، إِنِّي يَارْضنْ أَيْسُومْ \add ن أَرِّيمثْ\add*. \x ◘ \xo 13:‏3 \xt مت. 25‏:‏36. \x*   
\m
\v 4 أجّْ أَذْ يِيڒِي ڒمْڒَاشْ ذ أَوقَّارْ غَارْ مَارَّا، ذ قَامَا نْسنْ \add ن ڒمْڒَاشْ\add* ذ أَمزْذَاڭْ، مَاشَا أَربِّي أَذْ إِحْكمْ خْ أَيْثْ ن فَارْقْ-شّْغڒْ ؤُ خْ يِينِّي إِتّڭّنْ زِّينَا.   
\m
\v 5 وَارْ تّڭّمْ نّيّثْ نْومْ ذِي ثنْعَاشِينْ، مَاشَا قنْعمْ س مِينْ غَارْومْ، مِينْزِي سِيذِي إِنَّا:  
\b  
\m \qt ”نشّْ وَارْ شكْ تّجِّيغْ\qt*  
\m \qt نِيغْ أَذْ سمّْحغْ ذڭْ ؤُفُوسْ نّشْ.“\qt* \x ◘ \xo 13:‏5 \xt أَمز. 28‏:‏15؛ ؤُف. 23‏:‏8؛ أَعَوذ. 16‏:‏19؛ 31‏:‏6، 8؛ ياش. 1‏:‏5؛ 1 إِم. 28‏:‏20؛ أَوڒن. 15‏:‏16؛ فِيل. 4‏:‏11؛ 1 تِيم. 6‏:‏6، 8. \x*   
\b  
\m
\v 6 مَانْ أَيَا \add إِتّْوَانَّا\add* إِ نشِّينْ، مَاحنْذْ أَذْ نِينِي س ثرْيَاسْثْ:  
\b  
\m \qt ”سِيذِي ذ أَمْعَاونْ إِنُو، وَارْ تّڭّْوْذغْ شَا،\qt*  
\m \qt مِينْ ذ أَيِي غَا يڭّْ بْنَاذمْ؟“\qt* \x ◘ \xo 13:‏6 \xt إِزهد. 56‏:‏5؛ 118‏:‏6. \x*   
\b  
\m
\v 7 عقْڒمْ خْ إِمْڭوَّاذنْ نْومْ، إِنِّي ذ أَومْ إِسِّيوْڒنْ أَوَاڒْ ن أَربِّي. بقّْشمْ ڒْغِيدْجثْ ن ثشْرِي نْسنْ ؤُشَا ضْفَارمْ لْ-إِيمَانْ نْسنْ. \x ◘ \xo 13:‏7 \xt عبر. 13‏:‏17. \x*   
\b  
\m
\v 8 يَاسُوع لْمَاسِيحْ ذ نتَّا نتَّا إِضنَّاضْ ذ يِيضَا، ؤُ إِ ڒبْذَا.   
\b  
\m
\v 9 وَارْ ثجِّيمْ أَذْ كنِّيوْ غَارّنْ س ثْغُورِيوِينْ إِتّْبدَّاڒنْ \add ن ذغْيَا\add*، مِينْزِي ڒْحَاجّثْ ن لمْلِيحْ مَاڒَا شبَّارنْ وُوڒَاونْ نّغْ ذِي أَرْضَا، وَارْ إِدْجِي ذِي مَاشَّا، مِينْزِي إِنِّي ثُوغَا ذَايسْ يڒْهَانْ، وَارْ ذَايسْ ؤُفِينْ بُو نّْفعْ. \x ◘ \xo 13:‏9 \xt إِرْم. 29‏:‏8؛ مت. 24‏:‏4؛ يُوح. 6‏:‏27؛ رُوم. 14‏:‏17؛ 16‏:‏17؛ أَفا. 4‏:‏14؛ 5‏:‏6؛ كُول. 2‏:‏16؛ 2 تس. 2‏:‏2؛ 2 تِيم. 4‏:‏3؛ 1 يُوح. 4‏:‏1. \x*  
\v 10 غَارْنغْ إِجّْ ن ؤُعَالْطَارْ إِ ؤُمِي وَارْ إِعدّڒْ أَذْ زَّايسْ شّنْ إِنِّي إِتّْسخَّارنْ ذِي ثْزذِّيغْثْ.  
\v 11 مِينْزِي زڭْ إِمُودَّارنْ، إِنِّي إِذَامّنْ نْسنْ تّْوَاكْسِينْ غَارْ زَّاوشْثْ إِقدّْسنْ س ؤُفُوسْ ن أَرَّايْسْ ن إِكهَّاننْ، إِتّْوَاسَّارْغْ ويْسُومْ نْسنْ بَارَّا إِ ڒْمَارْڭحْ. \f ◼ \fr 13:‏11 \ft \+bd ’إِمُودَّارنْ‘\+bd* - نِيغْ ’لْحَايَاوَانَاثْ‘\f*  \x ◘ \xo 13:‏11 \xt ؤُف. 29‏:‏14؛ لَاوِي 4‏:‏21؛ 6‏:‏30؛ 16‏:‏27؛ ڒخْڒ. 19‏:‏3. \x*  
\v 12 س ؤُينِّي ثُوغَا يَاسُوع إِمَارّثْ عَاوذْ بَارَّا إِ ثنْذِينْثْ، حِيمَا أَذْ إِسّْقدّسْ ڒْڭنْسْ س إِذَامّنْ نّسْ. \x ◘ \xo 13:‏12 \xt يُوح. 19‏:‏17، 18. \x*  
\v 13 س ؤُينِّي أجّْ أَنغْ أَذْ نفّغْ غَارْ بَارَّا ن ڒْمَارْڭحْ، أَمْ نَاربُّو ڒْعَارْ نّسْ.  
\v 14 مِينْزِي وَارْ غَارْنغْ ذَا ثَانْذِينْثْ ن ڒبْذَا، مَاشَا نَارزُّو خْ ثنِّي إِ د غَا يَاسنْ. \x ◘ \xo 13:‏14 \xt فِيل. 3‏:‏20. \x*   
\m
\v 15 أجّْ أَنغْ ڒبْذَا أَذْ زَّايسْ نْقدّمْ ثِيوْهِيبِينْ ن ؤُسمْغَارْ إِ أَربِّي، ڒْغِيدْجثْ ن إِينْشِيشنْ نِّي د-إِتّْوَاينْ أَقَاذِي إِ يِيسمْ نّسْ. \x ◘ \xo 13:‏15 \xt حُوش. 14‏:‏3. \x*  
\v 16 وَارْ تّتُّومْ شَا أَرّحْمثْ ؤُڒَا ذ ثشْرِيمثْ إِ إِمژْڒَاضْ، مِينْزِي س ثوْهِيبِينْ-أَ أَذْ يَارْضَا بْنَاذمْ أَربِّي. \x ◘ \xo 13:‏16 \xt فِيل. 4‏:‏18. \x*   
\m
\v 17 إِڒِيمْ ذ إِمْثِيقَّانْ إِ يِينِّي إِ كنِّيوْ إِتّْڭوَّاذنْ، طَاعمْ أَسنْ، مِينْزِي نِيثْنِي تّْعسَّانْ خْ ڒعْمُورْ نْومْ أَمْ يِينِّي إِتّڭّنْ ڒحْسَابْ خَاومْ، حِيمَا أَذْ ت ڭّنْ س ڒفْرَاحثْ، وَارْ إِدْجِي س ؤُوحْوحْ، مِينْزِي مَانْ أَيَا وَارْ كنِّيوْ إِنفّعْ. \x ◘ \xo 13:‏17 \xt حِز. 3‏:‏18؛ 33‏:‏8؛ فِيل. 2‏:‏29؛ 1 تس. 5‏:‏12؛ 1 تِيم. 5‏:‏17. \x*   
\m
\v 18 ژَتدْجمْ خَانغْ، مِينْزِي غَارْنيْ تِّيقّثْ بلِّي غَارْنغْ ثَانفْسشْثْ ثشْنَا، أَمْ ذَايْنغْ مژْرِي، حِيمَا أَذْ نُويُورْ نِيشَانْ ذِي مَارَّا.  
\v 19 تّْزَاوْڭغْ كنِّيوْ س جّهْذْ أَذْ ثڭّمْ أَمُّو غَارْ ؤُمزْوَارُو، حِيمَا خنِّي نشّْ ذغْيَا أَذْ غَارْومْ د-ذوْڒغْ.   
\m
\v 20 أَربِّي ن ڒهْنَا ونِّي د-إِسّْنكَّارنْ أَمكْسَاوْ أَمقّْرَانْ ن وُودْجِي، يَاسُوع لْمَاسِيحْ، سِيذِيثْنغْ، زِي ثَادَّارْثْ ن إِمتِّيننْ س إِذَامّنْ ن ڒْعَاهْذْ إِ ڒبْذَا، \x ◘ \xo 13:‏20 \xt إِشا. 40‏:‏11؛ حِز. 34‏:‏23؛ يُوح. 10‏:‏11؛ 1 بُط. 5‏:‏4. \x*  
\v 21 أَذْ كنِّيوْ إِكمّڒْ ذِي كُوڒْ ڒْخذْمثْ إِشْنَانْ، حِيمَا أَذْ ثڭّمْ مِينْ إِخْسْ نتَّا. نتَّا أَذْ ذَايْنغْ إِڭّْ مِينْ إِدْجَانْ إِ أَرْضَا نّسْ س يَاسُوع لْمَاسِيحْ ونِّي غَارْ إِدْجَا ؤُعُودْجِي إِ ڒبْذَا قَاعْ. أَمِينْ. \x ◘ \xo 13:‏21 \xt 2 كُور. 3‏:‏5؛ فِيل. 2‏:‏13. \x*   
\m
\v 22 خنِّي تّْزَاوَاڭغْ زَّايْومْ، \add أَ\add* أَيْثْمَا إِنُو، قبْڒمْ أَوَاڒْ-أَ ن ؤُسجّعْ س تَّاسِيعْ ن ڒْخَاضَارْ، مِينْزِي ؤُرِيغْ أَومْ-د س ذْرُوسْ.   
\m
\v 23 سْنمْ أَقَا أَرْخُونْ إِ ؤُمَاثْنغْ ثِيمُوثِييُو. مَاڒَا يُوسَا-د ذغْيَا، أَذْ كنِّيوْ ژَترغْ \add أَكِيذسْ\add*.   
\m
\v 24 سدْجْممْ خْ مَارَّا إِنِّي إِ كنِّيوْ إِتّْڭوَّاذنْ س ڒحْنَا ؤُ خْ مَارَّا إِمْقدَّاسنْ. مَارَّا \add أَوْمَاثنْ\add* ن إِطَالْيَا تّْسدْجَامنْ-د خَاومْ س ڒهْنَا.   
\m
\v 25 أَرْضَا أَذْ كِيذْومْ يِيڒِي مَارَّا. أَمِينْ.   