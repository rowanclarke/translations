\v 12 Así el hombre \w yace|strong="H7901"\w*, \w y|strong="H5704"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* tornará \w a|strong="H3068"\w* \w levantar|strong="H6965"\w*: \w hasta|strong="H5704"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* haya \w cielos|strong="H8064"\w* \w no|strong="H3808"\w* \w despertarán|strong="H5782"\w*, \w ni|strong="H3808"\w* \w se|strong="H3808"\w* levantarán \w de|strong="H5704"\w* su \w sueño|strong="H8142"\w*.
\m 
\v 13 ¡\w Oh|strong="H4310"\w* \w quién|strong="H4310"\w* \w me|strong="H4310"\w* \w diera|strong="H5414"\w* \w que|strong="H4310"\w* \w me|strong="H4310"\w* \w escondieses|strong="H6845"\w* \w en|strong="H5704"\w* \w el|strong="H4310"\w* \w sepulcro|strong="H7585"\w*, \w que|strong="H4310"\w* \w me|strong="H4310"\w* \w encubrieras|strong="H5641"\w* \w hasta|strong="H5704"\w* apaciguar­se tu ira, \w que|strong="H4310"\w* \w me|strong="H4310"\w* \w pusieses|strong="H7896"\w* \w plazo|strong="H2706"\w*, \w y|strong="H5704"\w* \w de|strong="H5704"\w* mí te acordaras!
