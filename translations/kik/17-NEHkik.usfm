\li2 
\v 47 na Keroso, na Sia, na Padoni,
\li2 
\v 48 na Lebana, na Hagaba, na Shalimai,
\li2 
\v 49 na Hanani, na Gideli, na Gaharu,
\li2 
\v 50 na Reaia, na Rezini, na Nekoda,
