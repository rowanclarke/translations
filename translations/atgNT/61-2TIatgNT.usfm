\id 2TI - Okphela 
\h 2 iTimoti 
\toc1 2 iTimoti 
\toc2 2 iTimoti 
\toc3 2 iTimo 
\mt2 Ebe onuzi-eva ni iPọlu ọ kẹkẹ ghi 
\mt1 ITimoti 
\c 1  
\p  
\v 1 Mhẹmhẹ iPọlu ni mhi khi aghiusomhi na kẹẹ ọyi iJesu iKirisiti abi o ghọle Ẹshinẹgba shi. Mhẹmhẹ mhi kẹkẹ ebe ona. Mhẹmhẹ ni ọ ghie mhi ka ri agbọ ni o la iJesu iKirisiti ni Ẹshinẹgba ọ rọ shobọ na awa tse abọ guele. 
\p  
\v 2 ITimoti mhi kẹkẹ ebe ona ghi. Okhale ali ilẹlemhi ali opfọmhẹ eyi Ẹshinẹgba ali eyi iJesu iKirisiti Ọnọmhuẹ ọyawa e ka khi eyẹ.\f + \fr 1:2 \ft Li zẹ \fq Ika 16.1\f* 
\v 3 Mhi tsẹ Ẹshinẹgba ni mhi ri udu no pfuasẹ ẹ ga abi eni e bia mhẹ e li ga. Eri mhi a tse Ẹshinẹgba uwegbe ini mhi la iromhi isọsọ sato ẹ egbe, ẹlẹ-iyọsẹ ali ẹlẹ ọguota.  
\v 4 Mhi áá sato eviẹ oyẹ, mhi áá nono ni mhi mẹ ẹ, ẹghẹghẹ aghọ ni oghẹlẹ oyẹmhẹ o vọ.  
\v 5 Mhi áá sato egbegbi irudunga ni u mhuẹ. Irudunga onabi inyinyẹ ọ mhuẹ ikhi iLoisi ali ni inyẹ iYunisi ọ li mhuẹ. Mhi mie shi ọ khi oni irudunga o li lẹ egbe.\f + \fr 1:5 \ft Li zẹ \fq Ika 16.1\f* 
\v 6 Irari ona, mhia ye ẹ ude u guise isomhopfa ni Ẹshinẹgba ọ rọ nẹ le ke gbe akanya egbegbọ, eni u mie abi mhi rọ ri abọ ngẹ ukhomhi.  
\v 7 Irari khi Ẹshinẹgba ọa ri ayẹmhẹ ulishi na awa, ama ayẹmhẹ ekpabọ ali inono ali iguẹ ri egbe kia. 
\p  
\v 8 Itobọ ona, khi zẹ ni omama ọ muẹ ni u rọ pfi ọtsẹlẹ na Ọnọmhuẹ oyawa, wẹkhi omama mhẹ ni mhi khi oghumha itobọ iKirisiti. Ama kuma mhẹ ọ shi osoli imẹmẹ shi iri usomhi onete tsabọ, rọte ekpabọ oyi Ẹshinẹgba,  
\v 9 ni ọ tsumhi awa, ọ lu awa ni awa nu ọli la agbọ ipfuasẹ ni o khia khi ọa khi irari emhikhọghuo ni awa riẹlẹ, ama abi ọ li gba li ali irari okhale oyọli. Eri a li oni okhale ona na awa rọte obọ oyi iJesu iKirisiti neni ẹghẹghẹ o gba ekẹ le.  
\v 10 Ama mena, a she rọli khasẹ awa rọte ibhale oyi Ọmiepfuese, iJesu iKirisiti ni ọ pfuẹchẹ eghuli-a, ali ni ọ ri agbọ bhale, ni ọ rọte usomhi onete ri agbọ ni ọa ya ghu khasẹ gboo.  
\v 11 Oni usomhi onete ona Ẹshinẹgba ọ zẹ mhẹ shi mhi ke guele abi aghiusomhi na kẹẹ ọyi iJesu, ali ọni ọọ sẹsẹ.\f + \fr 1:11 \ft Li zẹ \fq 1 iTimo 2.7\f* 
\v 12 Itobọ ona o zẹ ni mhi rọ mẹ osue abi mhi li ena. Abi o tseku li, omama ọa mu mhẹ irari khi mhi lẹsẹ ọni mhi miesuọ ali khi mhi mie shi ọ khi ọ dobẹ ya ri ẹloe khu emini mhi rọnga li obọ shi ogbe ni ẹlẹghọ. 
\p  
\v 13 Emini u rọte unu oyẹmhẹ suọ, mu wẹ mhọli ni e khi ẹtẹ-awẹ ni u rọ ya ke sẹsẹ osẹsẹ ni o dala. Gbo sato ke la elemhi irudunga ali inono ni u mhuẹ elemhi iJesu iKirisiti.  
\v 14 Ri ẹloe khu osẹsẹ onete ni a rọ nga ẹ obọ, rọte ikpaghiobọ oyi Ayẹmhẹ-nọ-pfuasẹ ni ọ nu awa la ini ọgbọ khi dobẹ pfi ọli ukhomhi kpọkẹ. 
\p  
\v 15 U lẹsẹ khi ẹgbọkpa ni e la ekẹ Esha e she mẹ mhẹ na, li shi iFigẹlusi ali Ẹmogẹnẹsi. 
\p  
\v 16 Ẹshinẹgba ọ ka mhuẹ ilẹlemhi na unuẹkpẹ oyi Onesiforọsi, irari khi eri ọ ri egbe e mu mhẹ ẹghẹghẹ kpa, ọa na omama iwẹghẹ ni a sọ mhẹ.  
\v 17 Ni mhi rọ ma ọ, abi ọ rọ bhale iRomu, ọ nono mhẹ ya ramhi ni ọ rọ mẹ mhẹ.  
\v 18 Ẹshinẹgba ọ ka zẹ ni ọ mẹ ilẹlemhi oyi Ẹshinẹgba ogbẹlẹ ẹlẹghọ. U ga lẹsẹ gboo abi ọ li kpaghiẹ mhẹ obọ abi mhi rọ la Efesọsi. 
\c 2  
\s1 Abi a liẹ khi Ọkhọli-okhuẹ ọyi iJesu iKirisiti 
\p  
\v 1 ITimoti omimhẹ, zẹ ni u toto shi okhale ni o rọte obọ oyi iJesu iKirisiti bhale.  
\v 2 Emini u suọ khi mhi ngme ukpẹloe ọtsẹlẹ ebubu, rẹwẹ nga ẹgbọ ni a dobẹ ri egbe ẹ nga obọ, ni e ya dobẹ sẹsẹ ẹgbọẹse.  
\v 3 Nu mhẹ ri egbe mie osoli abi ọkhọli-okhuẹ ọnete ọyi iJesu iKirisiti.  
\v 4 Ọgbọ ni ọọ gbe akanya ọkhọli-okhuẹ, ọa ya ku abọ lo emhi agbọ, irari khi ọga ọyọli ọọ ke dua ni lọli ri egbe ke mu.  
\v 5 Ighọ o li khi, ini ọgbọ ọ kuma eni e ya na, aa ya rughu ọli arula oghie khi ọ lo owa, ini ọa li deba ushi ni o la unamhi.  
\v 6 O ti ni ọghiale ni ọ toto obọ gbe akanya, ọ kpẹ khi ọnododẹ ni ọ le emhi ẹkọmhi ni ọ gua.  
\v 7 Sa shi emini mhi ngme ena irari khi Ọnọmhuẹ ọ ya rẹ lẹsẹ udi emhi ena nya. 
\p  
\v 8 Sato iJesu egbe ni a rọte eghuli guise le, ni ọ khi unuẹkpẹ oyi iDefidi. Onana o khi usomhi onete ni mhi rọ a tse abọ,  
\v 9 ni o rẹ mhẹ a mẹ osoli ramhi ni a rọ ri igha shi mhẹ abọ abi ọgbọ usuesọ-akhuẹ. Ama, ungmemhi oyi Ẹshinẹgba ọa zẹ ẹ sọ igha.  
\v 10 Irarighọ, mhi rọ ri egbe mie emhikpa irari ẹgbọ ni Ẹshinẹgba ọ zẹ ni wẹwẹ e li mie imiepfuese ni o te obọ oyi iJesu IKirisiti bhale, li shi ufumhi na agbọagbọ. 
\p  
\v 11 Egbegbi ungmemhi ni a ri egbe a da na. 
\q1 Ini awa nu ọli ghua, 
\q2 awa gbo li ya nu ọli la agbọ. 
\q1  
\v 12 Ini awa ri egbe mie, 
\q2 awa ya nu ọli ke mhẹsẹ. 
\q1 Ini awa kie ọli, 
\q2 Ọ ya kie awa.\f + \fr 2:12 \ft Li zẹ \fq iMat 10.33; iLuk 12.9\f* 
\q1  
\v 13 Ini awa a ya gbe akanya 
\q2 te odẹ igẹsikia, 
\q2 Ọna igẹsikia ọ kiele khi. 
\q2 Irari khi ọa ya kie egbọli. 
\s1 Ọgbakanya ni ọ ghọle Ẹshinẹgba 
\p  
\v 14 Ke yele ẹgbọ eyẹ enana le. U gbo tse agua ye wẹ ukpẹloe Ẹshinẹgba, e khi wola shi ingmemhi, ni ọa mhọli eleli, eri o lẹsẹ ẹ yese eni e suọ ọli-a.  
\v 15 Rọshẹka ni u ri egbeẹ na Ẹshinẹgba abi, ọgbakanya ni ọ mie ni omama ọa ya mu, ni ọ guẹ ẹ sẹsẹ ungmemhi igẹsikia.  
\v 16 Nuata shi ingme afuẹ ni ẹa mhọli eleli, irari khi ẹgbọ ni ẹ sọ egbe ingme eghọghọ, eri ẹ ri ẹgbọ nuata shi Ẹshinẹgba ọ.  
\v 17 Osẹsẹ oyẹwẹ, o ya ke gẹ abi ugboko. Ẹgbọ eghọghọ khi Amẹneusi ali iFilẹtusi.  
\v 18 E she zobẹ odẹ igẹsikia obọ. Ẹ khi irọte eghuli guale o she bhale ya dọsẹ, e yese irudunga oyi ẹgbọ eghuo-a.  
\v 19 Abi bi o tseku li, irọgbekẹ ni Ẹshinẹgba ọ rọ gbe eri o migha gbaa, ni a kẹkẹ ena rọ shi ọli ọlẹlẹ khi: “Ọnọmhuẹ ọ lẹsẹ ẹgbọ ni e khi eyọli.” Ali, “Ọnini ọ da guele khi ọyi Ọnọmhuẹ lọli khi ne, ọ mema ya ti egbe ọkhọlọ iriẹlẹ le.”\f + \fr 2:19 \ft Li zẹ \fq iNọba 16.5\f* 
\p  
\v 20 Ukpokpomhi owa ọa lẹsẹ mhuẹ itasa igolu ali eyi ẹlomho tsẹ, ama o li mhọli eyi ẹẹra ali ẹmẹ, eghuo, e khi eni e mu ẹloe, eghuo, e khi eni ẹa mu ẹloe.  
\v 21 Ini ọgbọ khuẹsẹ egbọli-a pfuasẹ lase emhi ebe le, a ya rọli riẹlẹ egbegbi emhi. A rọli pfuasẹ, ọga ọyọli ọ rọli li emhi, ali khi ọ ya riẹlẹ ọli shi oni a rọ ke gbe ikanya enete. 
\p  
\v 22 Mẹ ọghuẹmhẹ ebe oyi ozele na, ke na khu iguẹ-ngeli ali irudunga, ali inono ali opfọmhẹ. Kuma ẹgbọ ni e ri udu ni o pfuasẹ ẹ lu eva oyi Ọnọmhuẹ ọ.  
\v 23 Khi mhọli emini u ri ekhakọ ọyẹghẹ ali umhalẹsẹ li, irari khi u lẹsẹ khi uwola ẹ pfi.  
\v 24 Ọni ọọ ga Ẹshinẹgba ọa gbudu wola. Ọ mema khi ọni ọọ riẹlẹ isomhelemhi deba ọgbọkpa, ọ khi ọsẹsẹ ọnete ni ọ ri abọ ọ mudu.  
\v 25 O ri ọfiẹ sẹsẹ eni ẹ nu ọli khakọ. Ọ mhọli ọli shi udu khi Ẹshinẹgba ọ ya khueghie odẹ-a na wẹ rọ mu pfi ni o ya rẹwẹ bhale ya lẹsẹ igẹsikia,  
\v 26 ali khi ẹgbhali oyẹwẹ o ya tiemhile, e na pfue igha ni ọkphaghiẹ ọ kpẹ khẹ wẹ. Ọni ọ she mu wẹ ighumha e ke riẹlẹ ọghuẹmhẹ oyọli. 
\c 3  
\s1 Angeli oyi ẹgbọ ikpukhokho agbọ 
\p  
\v 1 Ke bino ọli khi ẹghẹghẹ ọmunu o ya la ọ ogbẹlẹ ni e kpe ukhokho.  
\v 2 Ẹgbọ e ya ke nono ingme oyi egbe wẹwẹ-ghuo tsẹ, e mhọli ọghuẹmhẹ ebe na ukpaghọ, ẹẹ tono obọ udu, ẹẹ titiegbe, ẹẹ wẹghiẹ ẹgbọ, ẹẹ riẹlẹ umha-suesọ deba eni e bia wẹ, ẹa mhọli itsuwegbe wẹkhi itsobodẹ, e khi ẹgbọ ni ẹa mu ekpẹ na emhi Ẹshinẹgba.  
\v 3 Ẹa mhuẹ isomhelemhi, ẹa mhuẹ igbekua na ọgbọ, e ri unu ẹ pfuẹchẹ ẹgbọ-a, ẹa mhọli iguẹ-regbekia, wẹkhi ilẹlemhi, ẹa nono eminete.  
\v 4 E ri egbewẹ ẹ dẹ, ẹẹ li umumumẹ, ẹẹ ti ipfuabọ nga, e mhọli ọghuẹmhẹ na agbọ ilili, ocho ni e kha rọ mhọli inono na Ẹshinẹgba.  
\v 5 Ẹ riẹlẹ abinẹ khi eri e miesuọ, ama e kie ekpabọ ni o la imiesuọ. Khi mhọli emini u ri ẹgbọ eghọghọ li. 
\p  
\v 6 Ẹgbọ eghọghọ e bẹna lo owa deba ikpotso ni ẹa mhuẹ ẹgbhali, eni usamhi oyi olamhẹ eyẹwẹ enediọ ẹ nasẹ, ali ni ọghuẹmhẹ khi ọghuẹmhẹ ọọ gua.  
\v 7 Eri ikpotso eghọghọ ẹẹ nono ni e wẹna, ama ẹa dobẹ ẹ lẹsẹ igẹsikia.  
\v 8 Ẹzẹzẹ abi iJanẹsi ali iJabirẹsi e mu okhuẹ vule shi iMosisi ọ, ighọ eni ẹgbọ ena e li mu okhuẹ vule shi igẹsikia ọ. Ẹgbọ ni o khia khi usamhi oyẹwẹ ọa ke a gbe akanya ni e she de odẹ irudunga-a.\f + \fr 3:8 \ft Li zẹ \fq Okiali 7.11\f* 
\v 9 Ama ẹa ya kia nuata, itobọ khi ọyẹghẹ oyẹwẹ o ya ri egbe khasẹ ọgbọkpa, abi ó ke li eni emọse aava eghọ egbe. 
\s1 Omhẹsẹ ni iPọlu ọ rọ na iTimoti 
\p  
\v 10 Ama u she lẹsẹ osẹsẹ oyẹmhẹ nya ali abi mhi liẹ ngeli, U lẹsẹ emini mhi la agbọ shi, u lẹsẹ irudunga, ali irabọmudu ali inono ali iregbemie eyẹmhẹ.  
\v 11 U lẹsẹ okhọli ni a mu vule shi mhẹ ọ, ali osoli ali emini mhi mẹ egbe obini ẹoli Atiọki, ali ẹoli iKoniọmu ali ẹoli iLisitira. Okhọli oniẹmhi a mu vule shi mhẹ ọ ni mhi ri egbe mie. Ama Ọnọmhuẹ ọ rue mhẹ ọ le nya.\f + \fr 3:11 \ft Li zẹ \fq Ika 13.14-52; 14.1-7,8-20\f* 
\v 12 Egbegbọ lọ khi, ọgbọkpa ni ọ da nono ni lue la agbọ ipfuasẹ oyi iJesu IKirisiti ne, a ya mu okhọli vule shi ọli ọ.  
\v 13 Ẹgbọ ọkhọlọ ni ẹ ri egbe wẹ khi emini ẹa futẹ e ya ke riẹlẹ onobe ke khi ma ọ, ẹẹ di ẹgbọ, a lili ẹ di wẹ.  
\v 14 Ama yẹyẹ oyẹ, toto obọ emini u wẹna ni u she mie shi, irari khi u lẹsẹ obọ oyi eni u te wẹna wẹ,  
\v 15 Ali abi u te rọte ọmọfẹ lẹsẹ Ebe-no-pfuasẹ ni e dobẹ ya rẹ khili ọlẹsingme shi irudunga ni u mhọli na iJesu iKirisiti ni u khi ọni a mie pfuese.  
\v 16 Emini a kẹkẹ shi Ebe-no-pfuasẹ nya, ungmemhi oyi Ẹshinẹgba lọ. E ti ni a rọ ọ sẹsẹ emini e khi igẹsikia, ali ni a rọ ọ tse agua ye ọgbọ shi iriẹlẹ dọ-a, ali ni a rọ ọ sheshe ọgbọ shi odẹ rọte umhaguẹli, ali ni a rọ ọ sẹsẹ ọgbọ iguẹ-ngeli.  
\v 17 Ni rọ a bhale ya ẹ khi a sẹsẹ Ọmọse ọyi Ẹshinẹgba egbegbọ ni ọ guẹ ke gbe ikanya enete ọdọda. 
\c 4  
\p  
\v 1 Ukpẹloe oyi Ẹshinẹgba ali iJesu IKirisiti, ni ọ ya gue ẹgbọ ni e laọ ali eni e ghu-a ẹzọ, ali ọni ọ bhale ya mhẹsẹ abi Oghie, mhi la ri oni omhẹsẹ onana nẹ.  
\v 2 Ke tse abọ oni ungmemhi, ke mu egbe ẹghẹghẹ kpa ni u rọ ke tse ọli, o khi ẹghẹghẹ ni o ti, o ke khi ẹghẹghẹ ni ọa ti, ke sheshe ẹgbọ, wa dese wẹ ali u ri udu ẹ shi wẹ ọ. U ri iregbemie ri ọfiẹ sẹsẹ wẹ.  
\v 3 Irari khi ẹghẹghẹ ọ̀ọ́ bhale ni ẹgbọ ẹa ke rọ ya ri esọ shi egbegbi osẹsẹ. Ama ni e ba ke suọ emini ẹ ti wẹ esọ, e ya ri ochoghọ ti esẹsẹ gbili gasẹ egbe ni e ya ke ngme emini esọ ni ẹ riẹlẹ wẹ ẹ nono ni wẹwẹ e ke suọ.  
\v 4 E ya rue esọ egbegbi ungmemhi le, e ri esọ shi okhẹ nẹdẹ.  
\v 5 Ama yẹyẹ oyẹ, u mema ya ku egbe-a abibi o riẹ li. U ri egbe mie osoli, ri abọ mu udu ini u wa a mẹ osoli. Ke gbe akanya oyi ọni ọ ri usomhi onete a tsẹ abọ, u ri ẹloe shi ikanya eyẹ e gbe abi ọni ọọ ga ọyi Ẹshinẹgba. 
\p  
\v 6 Irari khi a she ku mhẹ abi onyọ ni a ku shi iluasobo, ali oni ẹghẹghẹ o she bhale ni mhi rọ ya ghua.  
\v 7 Mhi she khọli oni okhọli onete, mhi she na oni unamhi pfo, mhi mu oni irudunga mhuẹ ya to.  
\v 8 Mena, a shi ri arula iguẹ-ngeli shi na mhẹ, ni Ọnọmhuẹ ni ọ pfuasẹ ni ọ khi ọsọ-ẹzọ ọ rọ ya na mhẹ ogbe na ẹlẹghọ. Ọa khi mhẹmhẹghuo tsẹ a ya rọli na, ama li shi ẹgbọ ni e nono inyenẹ egbe bhale oyọli. 
\s1 IPọlu ọọ ghie iTimoti usomhi 
\p  
\v 9 Rọshẹka ni u kẹlẹ ramhi mhẹ egbe.  
\v 10 Irari khi iDẹmasi ọ mhọli inono na oni agbọ ona. Ọ she tsua mhẹ pfia je ẹoli iTẹsalonika. IKiresenisi ọ she je ekẹ iGalesha, iTatọsi ọ je ẹoli iDalimatia.\f + \fr 4:10 \ft Li zẹ \fq iKolo 4.14; iFilẹ 24; 2 iKọri 8.23; iGal 2.3; iTatọ 1.4\f* 
\v 11 ILuku luẹghuo kpe ọ ke lẹsẹ nu mhẹ la akana. Rue iMaki mhọli obọ bhale, irari khi ọ mhọli ikpaghiobọ na mhẹ oni akanya.\f + \fr 4:11 \ft Li zẹ \fq iKolo 4.14; iFilẹ 24; Ika 12.12,25; 13.13; 15.37-39; iKolo 4.10\f* 
\v 12 Mhi ghie iTakikọsi je ẹoli Efesọsi.\f + \fr 4:12 \ft Li zẹ \fq Ika 20.4; Ẹfi 6.21-22; iKolo 4.7-8\f* 
\v 13 Ini u wa bhale rue awulu ugbakpi ni mhi rọ shi obọ oyi iKaripusi obini ẹoli iTiroasi ali ebe eyẹmhẹ mhuẹ obọ bhale. Tete ẹkuẹ ẹlamhi ni a kẹkẹ emhi shi.\f + \fr 4:13 \ft Li zẹ \fq Ika 20.6\f* 
\p  
\v 14 Alẹzada ọni ọọ lumhi ikhuli, ọọ li mhẹ onobe gba. Ọnọmhuẹ ọ ya fali ọli ota shi emini ọ riẹlẹ.\f + \fr 4:14 \ft Li zẹ \fq 1 iTimo 1.20; Iwolo 62.12; iRom 2.6\f* 
\v 15 Yẹyẹ li mu egbe ẹ shi ọli egbe, irari khi eri ọ lolo mu okhuẹ vule shi usomhi ni awa rọ ọ tse abọ ọ. 
\p  
\v 16 Abi mhi rọ kpe todẹ pfa egbe mhẹ shi ekẹ, ọgbọkhọghuo ọa nu mhẹ migha, eri wẹwẹ nya e na tsua mhẹ pfia. Ẹshinẹgba ọ khi rọli mu ota sọ wẹ.  
\v 17 Ama eri Ẹshinẹgba ọ́ migha kpẹsẹ mhẹ, ọ́ ri ekpabọ na mhẹ ni a bhale ya ẹ khi, rọte obọ oyẹmhẹ, oni ungmemhi o lolo zẹ guele ni ẹgbọ iJẹta e suọ li. Ali ni a rọ tsumhi mhẹ obọ oyi eghuli abinẹ khi a mie ọgbọ unu oyi idumhi.  
\v 18 Ọnọmhuẹ ọ ya pfuese mhẹ okhọli obe ni o vule shi mhẹ ọ, ali khi ọ ya rue mhẹ bhale iloghie oyọli tselele. Lọli ọ mhọli ufumhi ẹlẹ na agbọagbọ ya je agbọagbọ. Atsẹ. 
\s1 Otsẹ ni o kpe ukhokho 
\p  
\v 19 Tsẹ iPisilia ali Akuila ali ọmhuẹ-apfẹ oyi Onesiforọsi na mhẹ.\f + \fr 4:19 \ft Li zẹ \fq Ika 18.2; 2 iTimo 1.16-17\f* 
\v 20 Erasitọsi ọ la ẹoli iKọriti, ali mhi zẹ iTirofimọsi obọ shi ẹoli iMilẹtusi irari khi ọọ ghua.\f + \fr 4:20 \ft Li zẹ \fq Ika 19.22; iRom 16.23; Ika 20.4; 21.29\f* 
\v 21 Rọshẹka ni u kẹlẹ ramhi ana neni oruẹ ọọ pfi. Eubulusi ọọ tsẹ ali iPudenisi ali iLanusi ali iKilaudia, ali eni e miesuọ nya e ga tsẹ.  
\v 22 Ọnọmhuẹ ọ nu ayẹmhẹ oyẹ la. Okhale oyi Ẹshinẹgba o nu ẹ la.