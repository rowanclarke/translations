\id 1TI Sanskrit Bible (NT) in Velthuis Script (satyaveda.h ।) 
\h 1 Timothy 
\toc1 1 tiimathiya.m patra.m 
\toc2 1 tiimathiya.h 
\toc3 1 tiimathiya.h 
\mt1 1 tiimathiya.m patra.m 
\c 1  
\p  
\v 1 asmaaka.m traa.nakartturii"svarasyaasmaaka.m pratyaa"saabhuume.h prabho ryii"sukhrii.s.tasya caaj naanusaarato yii"sukhrii.s.tasya prerita.h paula.h svakiiya.m satya.m dharmmaputra.m tiimathiya.m prati patra.m likhati| 
\p  
\v 2 asmaaka.m taata ii"svaro.asmaaka.m prabhu ryii"sukhrii.s.ta"sca tvayi anugraha.m dayaa.m "saanti nca kuryyaastaa.m| 
\p  
\v 3 maakidaniyaade"se mama gamanakaale tvam iphi.sanagare ti.s.than itara"sik.saa na grahiitavyaa, anante.suupaakhyaane.su va.m"saavali.su ca yu.smaabhi rmano na nive"sitavyam 
\p  
\v 4 iti kaa.m"scit lokaan yad upadi"seretat mayaadi.s.to.abhava.h, yata.h sarvvairetai rvi"svaasayukte"svariiyani.s.thaa na jaayate kintu vivaado jaayate| 
\p  
\v 5 upade"sasya tvabhipreta.m phala.m nirmmalaanta.hkara.nena satsa.mvedena ni.skapa.tavi"svaasena ca yukta.m prema| 
\p  
\v 6 kecit janaa"sca sarvvaa.nyetaani vihaaya nirarthakakathaanaam anugamanena vipathagaamino.abhavan, 
\p  
\v 7 yad bhaa.sante yacca ni"scinvanti tanna budhyamaanaa vyavasthopade.s.taaro bhavitum icchanti| 
\p  
\v 8 saa vyavasthaa yadi yogyaruupe.na g.rhyate tarhyuttamaa bhavatiiti vaya.m jaaniima.h| 
\p  
\v 9 apara.m saa vyavasthaa dhaarmmikasya viruddhaa na bhavati kintvadhaarmmiko .avaadhyo du.s.ta.h paapi.s.tho .apavitro .a"suci.h pit.rhantaa maat.rhantaa narahantaa 
\p  
\v 10 ve"syaagaamii pu.mmaithunii manu.syavikretaa mithyaavaadii mithyaa"sapathakaarii ca sarvve.saamete.saa.m viruddhaa, 
\p  
\v 11 tathaa saccidaanande"svarasya yo vibhavayukta.h susa.mvaado mayi samarpitastadanuyaayihitopade"sasya vipariita.m yat ki ncid bhavati tadviruddhaa saa vyavastheti tadgraahi.naa j naatavya.m| 
\p  
\v 12 mahya.m "saktidaataa yo.asmaaka.m prabhu.h khrii.s.tayii"sustamaha.m dhanya.m vadaami| 
\p  
\v 13 yata.h puraa nindaka upadraavii hi.msaka"sca bhuutvaapyaha.m tena vi"svaasyo .amanye paricaarakatve nyayujye ca| tad avi"svaasaacara.nam aj naanena mayaa k.rtamiti hetoraha.m tenaanukampito.abhava.m| 
\p  
\v 14 apara.m khrii.s.te yii"sau vi"svaasapremabhyaa.m sahito.asmatprabhoranugraho .atiiva pracuro.abhat| 
\p  
\v 15 paapina.h paritraatu.m khrii.s.to yii"su rjagati samavatiir.no.abhavat, e.saa kathaa vi"svaasaniiyaa sarvvai graha.niiyaa ca| 
\p  
\v 16 te.saa.m paapinaa.m madhye.aha.m prathama aasa.m kintu ye maanavaa anantajiivanapraaptyartha.m tasmin vi"svasi.syanti te.saa.m d.r.s.taante mayi prathame yii"sunaa khrii.s.tena svakiiyaa k.rtsnaa cirasahi.s.nutaa yat prakaa"syate tadarthamevaaham anukampaa.m praaptavaan| 
\p  
\v 17 anaadirak.sayo.ad.r"syo raajaa yo.advitiiya.h sarvvaj na ii"svarastasya gaurava.m mahimaa caanantakaala.m yaavad bhuuyaat| aamen| 
\p  
\v 18 he putra tiimathiya tvayi yaani bhavi.syadvaakyaani puraa kathitaani tadanusaaraad aham enamaade"sa.m tvayi samarpayaami, tasyaabhipraayo.aya.m yattva.m tai rvaakyairuttamayuddha.m karo.si 
\p  
\v 19 vi"svaasa.m satsa.mveda nca dhaarayasi ca| anayo.h parityaagaat ke.saa ncid vi"svaasatarii bhagnaabhavat| 
\p  
\v 20 huminaayasikandarau te.saa.m yau dvau janau, tau yad dharmmanindaa.m puna rna karttu.m "sik.sete tadartha.m mayaa "sayataanasya kare samarpitau| 
\c 2  
\p  
\v 1 mama prathama aade"so.aya.m, praarthanaavinayanivedanadhanyavaadaa.h karttavyaa.h, 
\p  
\v 2 sarvve.saa.m maanavaanaa.m k.rte vi"se.sato vaya.m yat "saantatvena nirvvirodhatvena ce"scarabhakti.m viniitatva ncaacaranta.h kaala.m yaapayaamastadartha.m n.rpatiinaam uccapadasthaanaa nca k.rte te karttavyaa.h| 
\p  
\v 3 yato.asmaaka.m taarakasye"svarasya saak.saat tadevottama.m graahya nca bhavati, 
\p  
\v 4 sa sarvve.saa.m maanavaanaa.m paritraa.na.m satyaj naanapraapti ncecchati| 
\p  
\v 5 yata eko.advitiiya ii"svaro vidyate ki nce"svare maanave.su caiko .advitiiyo madhyastha.h 
\p  
\v 6 sa naraavataara.h khrii.s.to yii"su rvidyate ya.h sarvve.saa.m mukte rmuulyam aatmadaana.m k.rtavaan| etena yena pramaa.nenopayukte samaye prakaa"sitavya.m, 
\p  
\v 7 tadgho.sayitaa duuto vi"svaase satyadharmme ca bhinnajaatiiyaanaam upade"saka"scaaha.m nyayuujye, etadaha.m khrii.s.tasya naamnaa yathaatathya.m vadaami naan.rta.m kathayaami| 
\p  
\v 8 ato mamaabhimatamida.m puru.sai.h krodhasandehau vinaa pavitrakaraan uttolya sarvvasmin sthaane praarthanaa kriyataa.m| 
\p  
\v 9 tadvat naaryyo.api salajjaa.h sa.myatamanasa"sca satyo yogyamaacchaadana.m paridadhatu ki nca ke"sasa.mskaarai.h ka.nakamuktaabhi rmahaarghyaparicchadai"scaatmabhuu.sa.na.m na kurvvatya.h 
\p  
\v 10 sviik.rte"svarabhaktiinaa.m yo.sitaa.m yogyai.h satyarmmabhi.h svabhuu.sa.na.m kurvvataa.m| 
\p  
\v 11 naarii sampuur.naviniitatvena nirvirodha.m "sik.sataa.m| 
\p  
\v 12 naaryyaa.h "sik.saadaana.m puru.saayaaj naadaana.m vaaha.m naanujaanaami tayaa nirvviroेdhatvam aacaritavya.m| 
\p  
\v 13 yata.h prathamam aadamastata.h para.m havaayaa.h s.r.s.ti rbabhuuva| 
\p  
\v 14 ki ncaadam bhraantiyukto naabhavat yo.sideva bhraantiyuktaa bhuutvaatyaacaari.nii babhuuva| 
\p  
\v 15 tathaapi naariiga.no yadi vi"svaase premni pavitrataayaa.m sa.myatamanasi ca ti.s.thati tarhyapatyaprasavavartmanaa paritraa.na.m praapsyati| 
\c 3  
\p  
\v 1 yadi ka"scid adhyak.sapadam aakaa"nk.sate tarhi sa uttama.m karmma lipsata iti satya.m| 
\p  
\v 2 ato.adhyak.se.naaninditenaikasyaa yo.sito bhartraa parimitabhogena sa.myatamanasaa sabhyenaatithisevakena "sik.sa.ne nipu.nena 
\p  
\v 3 na madyapena na prahaarake.na kintu m.rdubhaavena nirvvivaadena nirlobhena 
\p  
\v 4 svaparivaaraa.naam uttama"saasakena puur.naviniitatvaad va"syaanaa.m santaanaanaa.m niyantraa ca bhavitavya.m| 
\p  
\v 5 yata aatmaparivaaraan "saasitu.m yo na "saknoti tene"svarasya samitestattvaavadhaara.na.m katha.m kaari.syate? 
\p  
\v 6 apara.m sa garvvito bhuutvaa yat "sayataana iva da.n.dayogyo na bhavet tadartha.m tena nava"si.sye.na na bhavitavya.m| 
\p  
\v 7 yacca nindaayaa.m "sayataanasya jaale ca na patet tadartha.m tena bahi.hsthalokaanaamapi madhye sukhyaatiyuktena bhavitavya.m| 
\p  
\v 8 tadvat paricaarakairapi viniitai rdvividhavaakyarahitai rbahumadyapaane .anaasaktai rnirlobhai"sca bhavitavya.m, 
\p  
\v 9 nirmmalasa.mvedena ca vi"svaasasya niguu.dhavaakya.m dhaativya nca| 
\p  
\v 10 agre te.saa.m pariik.saa kriyataa.m tata.h param aninditaa bhuutvaa te paricaryyaa.m kurvvantu| 
\p  
\v 11 apara.m yo.sidbhirapi viniitaabhiranapavaadikaabhi.h satarkaabhi.h sarvvatra vi"svaasyaabhi"sca bhavitavya.m| 
\p  
\v 12 paricaarakaa ekaikayo.sito bharttaaro bhaveyu.h, nijasantaanaanaa.m parijanaanaa nca su"saasana.m kuryyu"sca| 
\p  
\v 13 yata.h saa paricaryyaa yai rbhadraruupe.na saadhyate te "sre.s.thapada.m praapnuvanti khrii.s.te yii"sau vi"svaasena mahotsukaa bhavanti ca| 
\p  
\v 14 tvaa.m pratyetatpatralekhanasamaye "siighra.m tvatsamiipagamanasya pratyaa"saa mama vidyate| 
\p  
\v 15 yadi vaa vilambeya tarhii"svarasya g.rhe .arthata.h satyadharmmasya stambhabhittimuulasvaruupaayaam amare"svarasya samitau tvayaa kiid.r"sa aacaara.h karttavyastat j naatu.m "sak.syate| 
\p  
\v 16 apara.m yasya mahattva.m sarvvasviik.rtam ii"svarabhaktestat niguu.dhavaakyamidam ii"svaro maanavadehe prakaa"sita aatmanaa sapu.nyiik.rto duutai.h sand.r.s.ta.h sarvvajaatiiyaanaa.m nika.te gho.sito jagato vi"svaasapaatriibhuutasteja.hpraaptaye svarga.m niita"sceti| 
\c 4  
\p  
\v 1 pavitra aatmaa spa.s.tam ida.m vaakya.m vadati caramakaale katipayalokaa vahninaa"nkitatvaat 
\p  
\v 2 ka.thoramanasaa.m kaapa.tyaad an.rtavaadinaa.m vivaahani.sedhakaanaa.m bhak.syavi"se.sani.sedhakaanaa nca 
\p  
\v 3 bhuutasvaruupaa.naa.m "sik.saayaa.m bhramakaatmanaa.m vaakye.su ca manaa.msi nive"sya dharmmaad bhra.m"si.syante| taani tu bhak.syaa.ni vi"svaasinaa.m sviik.rtasatyadharmmaa.naa nca dhanyavaadasahitaaya bhogaaye"svare.na sas.rjire| 
\p  
\v 4 yata ii"svare.na yadyat s.r.s.ta.m tat sarvvam uttama.m yadi ca dhanyavaadena bhujyate tarhi tasya kimapi naagraahya.m bhavati, 
\p  
\v 5 yata ii"svarasya vaakyena praarthanayaa ca tat pavitriibhavati| 
\p  
\v 6 etaani vaakyaani yadi tva.m bhraat.rn j naapayestarhi yii"sukhrii.s.tasyottam.h paricaarako bhavi.syasi yo vi"svaaso hitopade"sa"sca tvayaa g.rhiitastadiiyavaakyairaapyaayi.syase ca| 
\p  
\v 7 yaanyupaakhyaanaani durbhaavaani v.rddhayo.sitaameva yogyaani ca taani tvayaa vis.rjyantaam ii"svarabhaktaye yatna.h kriyataa nca| 
\p  
\v 8 yata.h "saariiriko yatna.h svalpaphalado bhavati kintvii"svarabhaktiraihikapaaratrikajiivanayo.h pratij naayuktaa satii sarvvatra phaladaa bhavati| 
\p  
\v 9 vaakyametad vi"svasaniiya.m sarvvai rgraha.niiya nca vaya nca tadarthameva "sraamyaamo nindaa.m bhu.mjmahe ca| 
\p  
\v 10 yato heto.h sarvvamaanavaanaa.m vi"se.sato vi"svaasinaa.m traataa yo.amara ii"svarastasmin vaya.m vi"svasaama.h| 
\p  
\v 11 tvam etaani vaakyaani pracaaraya samupadi"sa ca| 
\p  
\v 12 alpavaya.skatvaat kenaapyavaj neyo na bhava kintvaalaapenaacara.nena premnaa sadaatmatvena vi"svaasena "sucitvena ca vi"svaasinaam aadar"so bhava| 
\p  
\v 13 yaavannaaham aagami.syaami taavat tva paa.the cetayane upade"se ca mano nidhatsva| 
\p  
\v 14 praaciinaga.nahastaarpa.nasahitena bhavi.syadvaakyena yaddaana.m tubhya.m vi"sraa.nita.m tavaanta.hsthe tasmin daane "sithilamanaa maa bhava| 
\p  
\v 15 ete.su mano nive"saya, ete.su varttasva, ittha nca sarvvavi.saye tava gu.nav.rddhi.h prakaa"sataa.m| 
\p  
\v 16 svasmin upade"se ca saavadhaano bhuutvaavati.s.thasva tat k.rtvaa tvayaatmaparitraa.na.m "srot.r.naa nca paritraa.na.m saadhayi.syate| 
\c 5  
\p  
\v 1 tva.m praaciina.m na bhartsaya kintu ta.m pitaramiva yuuna"sca bhraat.rniva 
\p  
\v 2 v.rddhaa.h striya"sca maat.rniva yuvatii"sca puur.na"sucitvena bhaginiiriva vinayasva| 
\p  
\v 3 apara.m satyavidhavaa.h sammanyasva| 
\p  
\v 4 kasyaa"scid vidhavaayaa yadi putraa.h pautraa vaa vidyante tarhi te prathamata.h sviiyaparijanaan sevitu.m pitro.h pratyupakarttu nca "sik.santaa.m yatastadeve"svarasya saak.saad uttama.m graahya nca karmma| 
\p  
\v 5 apara.m yaa naarii satyavidhavaa naathahiinaa caasti saa ii"svarasyaa"sraye ti.s.thantii divaani"sa.m nivedanapraarthanaabhyaa.m kaala.m yaapayati| 
\p  
\v 6 kintu yaa vidhavaa sukhabhogaasaktaa saa jiivatyapi m.rtaa bhavati| 
\p  
\v 7 ataeva taa yad aninditaa bhaveyuustadartham etaani tvayaa nidi"syantaa.m| 
\p  
\v 8 yadi ka"scit svajaatiiyaan lokaan vi"se.sata.h sviiyaparijanaan na paalayati tarhi sa vi"svaasaad bhra.s.to .apyadhama"sca bhavati| 
\p  
\v 9 vidhavaavarge yasyaa ga.nanaa bhavati tayaa .sa.s.tivatsarebhyo nyuunavayaskayaa na bhavitavya.m; apara.m puurvvam ekasvaamikaa bhuutvaa 
\p  
\v 10 saa yat "si"supo.sa.nenaatithisevanena pavitralokaanaa.m cara.naprak.saalanena kli.s.taanaam upakaare.na sarvvavidhasatkarmmaacara.nena ca satkarmmakara.naat sukhyaatipraaptaa bhavet tadapyaava"syaka.m| 
\p  
\v 11 kintu yuvatii rvidhavaa na g.rhaa.na yata.h khrii.s.tasya vaipariityena taasaa.m darpe jaate taa vivaaham icchanti| 
\p  
\v 12 tasmaacca puurvvadharmma.m parityajya da.n.daniiyaa bhavanti| 
\p  
\v 13 anantara.m taa g.rhaad g.rha.m paryya.tantya aalasya.m "sik.sante kevalamaalasya.m nahi kintvanarthakaalaapa.m paraadhikaaracarccaa ncaapi "sik.samaa.naa anucitaani vaakyaani bhaa.sante| 
\p  
\v 14 ato mameccheya.m yuvatyo vidhavaa vivaaha.m kurvvataam apatyavatyo bhavantu g.rhakarmma kurvvataa ncettha.m vipak.saaya kimapi nindaadvaara.m na dadatu| 
\p  
\v 15 yata ita.h puurvvam api kaa"scit "sayataanasya pa"scaadgaaminyo jaataa.h| 
\p  
\v 16 apara.m vi"svaasinyaa vi"svaasino vaa kasyaapi parivaaraa.naa.m madhye yadi vidhavaa vidyante tarhi sa taa.h pratipaalayatu tasmaat samitau bhaare .anaaropite satyavidhavaanaa.m pratipaalana.m karttu.m tayaa "sakyate| 
\p  
\v 17 ye praa nca.h samiti.m samyag adhiti.s.thanti vi"se.sata ii"svaravaakyenopade"sena ca ye yatna.m vidadhate te dvigu.nasyaadarasya yogyaa maanyantaa.m| 
\p  
\v 18 yasmaat "saastre likhitamidamaaste, tva.m "sasyamarddakav.r.sasyaasya.m maa badhaaneti, aparamapi kaaryyak.rd vetanasya yogyo bhavatiiti| 
\p  
\v 19 dvau triin vaa saak.si.no vinaa kasyaacit praaciinasya viruddham abhiyogastvayaa na g.rhyataa.m| 
\p  
\v 20 apara.m ye paapamaacaranti taan sarvve.saa.m samak.sa.m bhartsayasva tenaapare.saamapi bhiiti rjani.syate| 
\p  
\v 21 aham ii"svarasya prabho ryii"sukhrii.s.tasya manoniitadivyaduutaanaa nca gocare tvaam idam aaj naapayaami tva.m kasyaapyanurodhena kimapi na kurvvana vinaapak.sapaatam etaana vidhiin paalaya| 
\p  
\v 22 kasyaapi muurddhi hastaapar.na.m tvarayaa maakaar.sii.h| parapaapaanaa ncaa.m"sii maa bhava| sva.m "suci.m rak.sa| 
\p  
\v 23 apara.m tavodarapii.daayaa.h puna.h puna durbbalataayaa"sca nimitta.m kevala.m toya.m na pivan ki ncin madya.m piva| 
\p  
\v 24 ke.saa ncit maanavaanaa.m paapaani vicaaraat puurvva.m ke.saa ncit pa"scaat prakaa"sante| 
\p  
\v 25 tathaiva satkarmmaa.nyapi prakaa"sante tadanyathaa sati pracchannaani sthaatu.m na "saknuvanti| 
\c 6  
\p  
\v 1 yaavanto lokaa yugadhaari.no daasaa.h santi te svasvasvaamina.m puur.nasamaadarayogya.m manyantaa.m no ced ii"svarasya naamna upade"sasya ca nindaa sambhavi.syati| 
\p  
\v 2 ye.saa nca svaamino vi"svaasina.h bhavanti taiste bhraat.rtvaat naavaj neyaa.h kintu te karmmaphalabhogino vi"svaasina.h priyaa"sca bhavantiiti heto.h sevaniiyaa eva, tvam etaani "sik.saya samupadi"sa ca| 
\p  
\v 3 ya.h ka"scid itara"sik.saa.m karoti, asmaaka.m prabho ryii"sukhrii.s.tasya hitavaakyaanii"svarabhakte ryogyaa.m "sik.saa nca na sviikaroti 
\p  
\v 4 sa darpadhmaata.h sarvvathaa j naanahiina"sca vivaadai rvaagyuddhai"sca rogayukta"sca bhavati| 
\p  
\v 5 taad.r"saad bhaavaad iir.syaavirodhaapavaadadu.s.taasuuyaa bhra.s.tamanasaa.m satyaj naanahiinaanaam ii"svarabhakti.m laabhopaayam iva manyamaanaanaa.m lokaanaa.m vivaadaa"sca jaayante taad.r"sebhyo lokebhyastva.m p.rthak ti.s.tha| 
\p  
\v 6 sa.myatecchayaa yuktaa ye"svarabhakti.h saa mahaalaabhopaayo bhavatiiti satya.m| 
\p  
\v 7 etajjagatprave"sanakaale.asmaabhi.h kimapi naanaayi tattayajanakaale.api kimapi netu.m na "sak.syata iti ni"scita.m| 
\p  
\v 8 ataeva khaadyaanyaacchaadanaani ca praapyaasmaabhi.h santu.s.tai rbhavitavya.m| 
\p  
\v 9 ye tu dhanino bhavitu.m ce.s.tante te pariik.saayaam unmaathe patanti ye caabhilaa.saa maanavaan vinaa"se narake ca majjayanti taad.r"se.svaj naanaahitaabhilaa.se.svapi patanti| 
\p  
\v 10 yato.arthasp.rhaa sarvve.saa.m duritaanaa.m muula.m bhavati taamavalambya kecid vi"svaasaad abhra.m"santa naanaakle"sai"sca svaan avidhyan| 
\p  
\v 11 he ii"svarasya loka tvam etebhya.h palaayya dharmma ii"svarabhakti rvi"svaasa.h prema sahi.s.nutaa k.saanti"scaitaanyaacara| 
\p  
\v 12 vi"svaasaruupam uttamayuddha.m kuru, anantajiivanam aalambasva yatastadartha.m tvam aahuuto .abhava.h, bahusaak.si.naa.m samak.sa ncottamaa.m pratij naa.m sviik.rtavaan| 
\p  
\v 13 apara.m sarvve.saa.m jiivayiturii"svarasya saak.saad ya"sca khrii.s.to yii"su.h pantiiyapiilaatasya samak.sam uttamaa.m pratij naa.m sviik.rtavaan tasya saak.saad aha.m tvaam idam aaj naapayaami| 
\p  
\v 14 ii"svare.na svasamaye prakaa"sitavyam asmaaka.m prabho ryii"sukhrii.s.tasyaagamana.m yaavat tvayaa ni.skala"nkatvena nirddo.satvena ca vidhii rak.syataa.m| 
\p  
\v 15 sa ii"svara.h saccidaananda.h, advitiiyasamraa.t, raaj naa.m raajaa, prabhuunaa.m prabhu.h, 
\p  
\v 16 amarataayaa advitiiya aakara.h, agamyatejonivaasii, marttyaanaa.m kenaapi na d.r.s.ta.h kenaapi na d.r"sya"sca| tasya gauravaparaakramau sadaatanau bhuuyaastaa.m| aamen| 
\p  
\v 17 ihaloke ye dhaninaste cittasamunnati.m capale dhane vi"svaasa nca na kurvvataa.m kintu bhogaartham asmabhya.m pracuratvena sarvvadaataa 
\p  
\v 18 yo.amara ii"svarastasmin vi"svasantu sadaacaara.m kurvvantu satkarmmadhanena dhanino sukalaa daataara"sca bhavantu, 
\p  
\v 19 yathaa ca satya.m jiivana.m paapnuyustathaa paaratrikaam uttamasampada.m sa ncinvantveti tvayaadi"syantaa.m| 
\p  
\v 20 he tiimathiya, tvam upanidhi.m gopaya kaalpanikavidyaayaa apavitra.m pralaapa.m virodhokti nca tyaja ca, 
\p  
\v 21 yata.h katipayaa lokaastaa.m vidyaamavalambya vi"svaasaad bhra.s.taa abhavana| prasaadastava sahaayo bhuuyaat| aamen|