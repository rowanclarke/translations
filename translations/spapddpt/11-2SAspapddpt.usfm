\v 34 pero \w si|strong="H1961"\w* \w vuelves|strong="H7725"\w* \w a|strong="H3068"\w* la \w ciudad|strong="H5892"\w* y dices \w a|strong="H3068"\w* Absalón: ¡Oh \w rey|strong="H4428"\w*! Yo \w seré|strong="H1961"\w* tu esclavo, \w así|strong="H6258"\w* \w como|strong="H1961"\w* \w fui|strong="H1961"\w* esclavo de tu padre, \w ahora|strong="H6258"\w* también \w soy|strong="H1961"\w* esclavo \w tuyo|strong="H6258"\w*. \w Entonces|strong="H7725"\w* frustrarás el \w consejo|strong="H6098"\w* de Ahitofel \w a|strong="H3068"\w* \w mi|strong="H1961"\w* favor.
\v 35 ¿\w Los|strong="H3605"\w* \w sacerdotes|strong="H3548"\w* \w Sadoc|strong="H6659"\w* y Abiatar \w no|strong="H3808"\w* \w estarán|strong="H1961"\w* \w allí|strong="H8033"\w* \w contigo|strong="H5973"\w*? \w Por|strong="H1697"\w* tanto, \w toda|strong="H3605"\w* \w palabra|strong="H1697"\w* \w que|strong="H3808"\w* \w oigan|strong="H8085"\w* \w en|strong="H5973"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w del|strong="H5973"\w* \w rey|strong="H4428"\w* \w la|strong="H3605"\w* declararán \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w sacerdotes|strong="H3548"\w* \w Sadoc|strong="H6659"\w* y Abiatar.
\v 36 \w Mira|strong="H2009"\w*, \w están|strong="H2009"\w* \w con|strong="H5973"\w* \w ellos|strong="H3027"\w* sus \w dos|strong="H8147"\w* \w hijos|strong="H1121"\w*: Ahimaas, \w el|strong="H5973"\w* \w de|strong="H5973"\w* \w Sadoc|strong="H6659"\w*, y Jonatán, \w el|strong="H5973"\w* \w de|strong="H5973"\w* Abiatar. \w Por|strong="H1697"\w* \w medio|strong="H3027"\w* \w de|strong="H5973"\w* \w ellos|strong="H3027"\w* \w me|strong="H5973"\w* informarán \w todo|strong="H3605"\w* \w lo|strong="H1697"\w* \w que|strong="H1697"\w* \w oigan|strong="H8085"\w*.
\p 
\v 37 Así \w Husai|strong="H2365"\w*, \w amigo|strong="H7463"\w* de \w David|strong="H1732"\w*, fue \w a|strong="H3068"\w* la \w ciudad|strong="H5892"\w*, y Absalón entró en Jerusalén.
\c 16
\s1 La fidelidad de Siba y la perversidad de Simei
\p 
\v 1 Cuando \w David|strong="H1732"\w* \w pasó|strong="H5674"\w* un \w poco|strong="H4592"\w* \w más|strong="H5921"\w* allá \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w cumbre|strong="H7218"\w*, ahí \w estaba|strong="H2009"\w* \w Siba|strong="H6717"\w*, esclavo \w de|strong="H5921"\w* Mefi-boset, \w que|strong="H5921"\w* llegaba \w a|strong="H3068"\w* encontrarlo \w con|strong="H5921"\w* un \w par|strong="H6776"\w* \w de|strong="H5921"\w* \w asnos|strong="H2543"\w* cargados \w con|strong="H5921"\w* 200 \w panes|strong="H3899"\w*, 100 racimos \w de|strong="H5921"\w* pasas, 100 tortas \w de|strong="H5921"\w* higos \w secos|strong="H7019"\w* \w y|strong="H5921"\w* un \w odre|strong="H5035"\w* \w de|strong="H5921"\w* \w vino|strong="H3196"\w*.
\p 
\v 2 El \w rey|strong="H4428"\w* preguntó \w a|strong="H3068"\w* \w Siba|strong="H6717"\w*: ¿\w Qué|strong="H4100"\w* quieres con estas cosas?
\p \w Y|strong="H3068"\w* respondió \w Siba|strong="H6717"\w*: Los \w asnos|strong="H2543"\w* son para \w que|strong="H4100"\w* monte la \w familia|strong="H1004"\w* \w del|strong="H8354"\w* \w rey|strong="H4428"\w*, el \w pan|strong="H3899"\w* y los higos \w secos|strong="H7019"\w* para \w que|strong="H4100"\w* coman los jóvenes, y el \w vino|strong="H3196"\w*, para \w que|strong="H4100"\w* \w beban|strong="H8354"\w* los \w que|strong="H4100"\w* \w se|strong="H4100"\w* cansen en la región despoblada.
\p 
\v 3 \w El|strong="H3588"\w* \w rey|strong="H4428"\w* dijo: ¿Dónde \w está|strong="H3427"\w* \w el|strong="H3588"\w* \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* tu \tl ʼadon\tl*?
\p \w Y|strong="H3068"\w* \w Siba|strong="H6717"\w* \w respondió|strong="H7725"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w*: \w Mira|strong="H2009"\w*, se \w quedó|strong="H3427"\w* \w en|strong="H3588"\w* Jerusalén \w porque|strong="H3588"\w* dijo: ¡\w Hoy|strong="H3117"\w* mismo \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* \w me|strong="H3588"\w* devolverá \w el|strong="H3588"\w* \w reino|strong="H4428"\w* \w de|strong="H3588"\w* \w mi|strong="H2009"\w* padre!
\p 
\v 4 Entonces \w el|strong="H3605"\w* \w rey|strong="H4428"\w* dijo \w a|strong="H3068"\w* \w Siba|strong="H6717"\w*: ¡\w Mira|strong="H2009"\w*, \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w que|strong="H3605"\w* pertenece \w a|strong="H3068"\w* Mefi-boset es tuyo!
\p \w Y|strong="H3068"\w* \w Siba|strong="H6717"\w* dijo: ¡Oh \w rey|strong="H4428"\w* \tl ʼadón\tl* mío, me postro y espero \w hallar|strong="H4672"\w* \w gracia|strong="H2580"\w* ante ti!
\p 
\v 5 \w Al|strong="H5704"\w* llegar \w el|strong="H1121"\w* \w rey|strong="H4428"\w* \w David|strong="H1732"\w* \w a|strong="H3068"\w* Bahurim, \w salía|strong="H3318"\w* \w de|strong="H5704"\w* \w allí|strong="H8033"\w* un \w hombre|strong="H1121"\w* \w de|strong="H5704"\w* la \w familia|strong="H1004"\w* \w de|strong="H5704"\w* la \w casa|strong="H1004"\w* \w de|strong="H5704"\w* \w Saúl|strong="H7586"\w* \w llamado|strong="H8034"\w* Simei, \w hijo|strong="H1121"\w* \w de|strong="H5704"\w* \w Gera|strong="H1617"\w*. \w Mientras|strong="H5704"\w* \w salía|strong="H3318"\w* pronunciaba maldiciones
\v 6 y lanzaba piedras contra \w David|strong="H1732"\w* y contra \w todos|strong="H3605"\w* \w los|strong="H3605"\w* esclavos del \w rey|strong="H4428"\w* \w David|strong="H1732"\w*, \w cuando|strong="H5650"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w gente|strong="H5971"\w* y \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w hombres|strong="H1368"\w* \w valientes|strong="H1368"\w* marchaban \w a|strong="H3068"\w* su \w derecha|strong="H3225"\w* y \w a|strong="H3068"\w* su \w izquierda|strong="H8040"\w*.
\p 
\v 7 Al maldecir, Simei decía: ¡\w Fuera|strong="H3318"\w*! ¡\w Fuera|strong="H3318"\w*, hombre sanguinario \w y|strong="H3541"\w* \w perverso|strong="H1100"\w*!
\p 
\v 8 \nd \w Yavé|strong="H3068"\w*\nd* \w hizo|strong="H5414"\w* \w volver|strong="H7725"\w* \w sobre|strong="H5921"\w* \w ti|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* \w sangre|strong="H1818"\w* derramada \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Saúl|strong="H7586"\w*, \w en|strong="H5921"\w* \w lugar|strong="H8478"\w* \w del|strong="H5921"\w* \w cual|strong="H3588"\w* reinaste. \nd \w Yavé|strong="H3068"\w*\nd* \w entregó|strong="H5414"\w* \w el|strong="H5921"\w* \w reino|strong="H4427"\w* \w en|strong="H5921"\w* \w mano|strong="H3027"\w* \w de|strong="H5921"\w* tu \w hijo|strong="H1121"\w* Absalón, \w y|strong="H3588"\w* \w aquí|strong="H2005"\w* estás \add atrapado\add* \w en|strong="H5921"\w* tu propia \w maldad|strong="H7451"\w*, \w porque|strong="H3588"\w* eres un \w hombre|strong="H1121"\w* sanguinario.
\p 
\v 9 \w Entonces|strong="H5493"\w* Abisai, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Sarvia, preguntó \w al|strong="H4428"\w* \w rey|strong="H4428"\w*: ¿\w Por|strong="H2088"\w* \w qué|strong="H4100"\w* \w este|strong="H2088"\w* \w perro|strong="H3611"\w* \w muerto|strong="H4191"\w* debe seguir \w maldiciendo|strong="H7043"\w* \w a|strong="H3068"\w* \w mi|strong="H4994"\w* \tl ʼadón\tl* \w el|strong="H1121"\w* \w rey|strong="H4428"\w*? ¡Permíteme ir y cortarle la \w cabeza|strong="H7218"\w*!
\p 
\v 10 \w Pero|strong="H3588"\w* \w el|strong="H3588"\w* \w rey|strong="H4428"\w* respondió: ¿\w Qué|strong="H3588"\w* tengo \w yo|strong="H3588"\w* \w con|strong="H3588"\w* ustedes, \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* Sarvia? Dejen \w que|strong="H3588"\w* sigan sus maldiciones, \w si|strong="H3588"\w* \w él|strong="H3588"\w* \w maldice|strong="H7043"\w*. \w Si|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w le|strong="H4310"\w* dijo: ¡\w Maldice|strong="H7043"\w* \w a|strong="H3068"\w* \w David|strong="H1732"\w*! ¿\w Quién|strong="H4310"\w* \w le|strong="H4310"\w* dirá: \w por|strong="H3588"\w* \w qué|strong="H3588"\w* \w haces|strong="H6213"\w* \w esto|strong="H3651"\w*?
\p 
\v 11 \w David|strong="H1732"\w* dijo \w a|strong="H3068"\w* Abisai \w y|strong="H3588"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* sus esclavos: \w Ciertamente|strong="H3588"\w* \w mi|strong="H2009"\w* propio \w hijo|strong="H1121"\w*, \w que|strong="H3588"\w* \w salió|strong="H3318"\w* \w de|strong="H3588"\w* \w mí|strong="H2009"\w*, \w acecha|strong="H1245"\w* \w mi|strong="H2009"\w* \w vida|strong="H5315"\w*. ¿\w Cuánto|strong="H3588"\w* \w más|strong="H3588"\w* \w ahora|strong="H6258"\w* este \w benjamita|strong="H1121"\w*? Déjenlo maldecir, \w porque|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* se \w lo|strong="H3605"\w* dijo.
\v 12 Quizás \nd \w Yavé|strong="H3068"\w*\nd* \w mire|strong="H7200"\w* mi aflicción y me devuelva \w bien|strong="H2896"\w* \w por|strong="H8478"\w* sus maldiciones \w de|strong="H8478"\w* \w hoy|strong="H3117"\w*.
\p 
\v 13 \w Así|strong="H7043"\w* que, mientras \w David|strong="H1732"\w* y sus hombres \w iban|strong="H1980"\w* \w por|strong="H1870"\w* el \w camino|strong="H1870"\w*, Simei seguía \w por|strong="H1870"\w* la ladera de la montaña paralela, \w andaba|strong="H1980"\w*, maldecía, tiraba piedras y esparcía \w polvo|strong="H6083"\w* \w delante|strong="H5980"\w* de él.
\v 14 \w El|strong="H3605"\w* \w rey|strong="H4428"\w* y \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* \w que|strong="H5971"\w* estaba con \w él|strong="H3605"\w* llegaron \w fatigados|strong="H5889"\w* y descansaron \w allí|strong="H8033"\w*.
\p 
\v 15 Absalón con \w toda|strong="H3605"\w* su \w gente|strong="H5971"\w*, \w los|strong="H3605"\w* hombres \w de|strong="H5971"\w* \w Israel|strong="H3478"\w*, entraron en Jerusalén, \w junto|strong="H5971"\w* con Ahitofel.
\v 16 \w Sucedió|strong="H1961"\w* \w que|strong="H1961"\w* \w cuando|strong="H1961"\w* \w Husai|strong="H2365"\w* arquita, el \w amigo|strong="H7463"\w* de \w David|strong="H1732"\w*, llegó ante Absalón, \w Husai|strong="H2365"\w* dijo \w a|strong="H3068"\w* Absalón: ¡\w Viva|strong="H2421"\w* el \w rey|strong="H4428"\w*! ¡\w Viva|strong="H2421"\w* el \w rey|strong="H4428"\w*!
\p 
\v 17 Absalón preguntó \w a|strong="H3068"\w* \w Husai|strong="H2365"\w*: ¿\w Es|strong="H2088"\w* \w ésta|strong="H2088"\w* tu lealtad para tu \w amigo|strong="H7453"\w*? ¿\w Por|strong="H2088"\w* \w qué|strong="H4100"\w* \w no|strong="H3808"\w* acompañaste \w a|strong="H3068"\w* tu \w amigo|strong="H7453"\w*?
\p 
\v 18 \w Husai|strong="H2365"\w* dijo \w entonces|strong="H3588"\w* \w a|strong="H3068"\w* Absalón: \w No|strong="H3808"\w*, \w porque|strong="H3588"\w* \add yo soy\add* \w de|strong="H3588"\w* \w quien|strong="H3605"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w y|strong="H3588"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w*, \w todos|strong="H3605"\w* \w los|strong="H3427"\w* hombres \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*, escojan. \w De|strong="H3588"\w* \w él|strong="H3588"\w* \w soy|strong="H1961"\w* \w y|strong="H3588"\w* \w con|strong="H3588"\w* \w él|strong="H3588"\w* \w me|strong="H3588"\w* \w quedo|strong="H1961"\w*.
\v 19 Además, ¿\w a|strong="H3068"\w* \w quién|strong="H4310"\w* voy \w a|strong="H3068"\w* \w servir|strong="H5647"\w*? ¿\w No|strong="H3808"\w* serviré \w a|strong="H3068"\w* su \w hijo|strong="H1121"\w*? \w Como|strong="H1961"\w* serví \w delante|strong="H6440"\w* \w de|strong="H6440"\w* tu padre, \w así|strong="H3651"\w* estaré \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ti.
\p 
\v 20 Entonces Absalón dijo \w a|strong="H3068"\w* Ahitofel: Da \w tu|strong="H6213"\w* \w consejo|strong="H6098"\w* sobre \w lo|strong="H4100"\w* \w que|strong="H4100"\w* debemos \w hacer|strong="H6213"\w*.
\p 
\v 21 Ahitofel contestó \w a|strong="H3068"\w* Absalón: Únete \w a|strong="H3068"\w* las \w concubinas|strong="H6370"\w* \w que|strong="H3588"\w* tu padre dejó \w para|strong="H3588"\w* cuidar \w la|strong="H3588"\w* \w casa|strong="H1004"\w*. \w Así|strong="H3588"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* sabrá \w que|strong="H3588"\w* eres aborrecible \w a|strong="H3068"\w* tu padre, \w con|strong="H3588"\w* \w lo|strong="H3605"\w* \w cual|strong="H3588"\w* se fortalecerán las \w manos|strong="H3027"\w* \w de|strong="H3588"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w tuyos|strong="H1004"\w*.
\v 22 Entonces instalaron una tienda \w para|strong="H5921"\w* Absalón \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* terraza, \w y|strong="H5921"\w* Absalón \w se|strong="H5921"\w* unió \w a|strong="H3068"\w* \w las|strong="H5921"\w* \w concubinas|strong="H6370"\w* \w de|strong="H5921"\w* su padre \w a|strong="H3068"\w* \w ojos|strong="H5869"\w* \w de|strong="H5921"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w*.
\p 
\v 23 En \w aquellos|strong="H1992"\w* \w días|strong="H3117"\w* \w el|strong="H3605"\w* \w consejo|strong="H6098"\w* \w que|strong="H1571"\w* Ahitofel \w daba|strong="H3289"\w* era \w como|strong="H1571"\w* \w si|strong="H1571"\w* uno consultara \w la|strong="H1571"\w* \w Palabra|strong="H1697"\w* \w de|strong="H1697"\w* \nd ʼElohim\nd*. \w Así|strong="H3651"\w* era \w todo|strong="H3605"\w* \w lo|strong="H1697"\w* \w que|strong="H1571"\w* Ahitofel \w aconsejaba|strong="H3289"\w*, \w tanto|strong="H3651"\w* para \w David|strong="H1732"\w* \w como|strong="H1571"\w* para Absalón.
\c 17
\s1 Los consejos de Ahitofel y de Husai
\p 
\v 1 Entonces Ahitofel dijo \w a|strong="H3068"\w* Absalón: Permíteme \w que|strong="H4994"\w* escoja 12.000 \w hombres|strong="H8147"\w*, y me levante para perseguir \w a|strong="H3068"\w* \w David|strong="H1732"\w* \w esta|strong="H6965"\w* misma \w noche|strong="H3915"\w*.
\p 
\v 2 Caeré \w sobre|strong="H5921"\w* \w él|strong="H1931"\w* cuando \w esté|strong="H1931"\w* cansado \w y|strong="H5921"\w* desalentado. \w Lo|strong="H1931"\w* \w atemorizaré|strong="H2729"\w* \w de|strong="H5921"\w* modo \w que|strong="H1931"\w* huya \w toda|strong="H3605"\w* \w la|strong="H1931"\w* \w gente|strong="H5971"\w* \w que|strong="H1931"\w* \w lo|strong="H1931"\w* acompaña. Mataré \w solo|strong="H1931"\w* \w al|strong="H5921"\w* \w rey|strong="H4428"\w*,
\v 3 porque \w él|strong="H3605"\w* \w es|strong="H1961"\w* \w el|strong="H3605"\w* hombre \w a|strong="H3068"\w* \w quien|strong="H3605"\w* tú \w buscas|strong="H1245"\w*.
\p Así devolveré \w a|strong="H3068"\w* ti \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w*. \w Cuando|strong="H1961"\w* \w todos|strong="H3605"\w* \w vuelvan|strong="H7725"\w*, \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* \w estará|strong="H1961"\w* en \w paz|strong="H7965"\w*.
\p 
\v 4 \w El|strong="H3605"\w* \w consejo|strong="H1697"\w* \w agradó|strong="H3474"\w* \w a|strong="H3068"\w* Absalón y \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w ancianos|strong="H2205"\w* \w de|strong="H1697"\w* \w Israel|strong="H3478"\w*.
\p 
\v 5 Pero Absalón dijo: Llamen \w también|strong="H1571"\w* \w ahora|strong="H4994"\w* \w a|strong="H3068"\w* \w Husai|strong="H2365"\w* arquita, para \w que|strong="H4100"\w* \w también|strong="H1571"\w* \w oigamos|strong="H8085"\w* \w lo|strong="H1931"\w* \w que|strong="H4100"\w* \w él|strong="H1931"\w* diga.
\v 6 Cuando \w Husai|strong="H2365"\w* fue, le \w habló|strong="H1696"\w* \w a|strong="H3068"\w* Absalón: Ahitofel \w habló|strong="H1696"\w* \w esta|strong="H2088"\w* \w palabra|strong="H1697"\w*. ¿Realizaremos su plan? Si \w no|strong="H6213"\w* \add te parece\add*, \w habla|strong="H1696"\w* \w tú|strong="H6213"\w*.
\p 
\v 7 Entonces \w Husai|strong="H2365"\w* dijo \w a|strong="H3068"\w* Absalón: \w Esta|strong="H2063"\w* \w vez|strong="H6471"\w* el \w consejo|strong="H6098"\w* \w que|strong="H3808"\w* dio Ahitofel \w no|strong="H3808"\w* \w es|strong="H2063"\w* \w bueno|strong="H2896"\w*.
\v 8 \w Y|strong="H3068"\w* \w Husai|strong="H2365"\w* agregó: Tú \w conoces|strong="H3045"\w* \w a|strong="H3068"\w* tu padre \w y|strong="H3588"\w* \w a|strong="H3068"\w* \w sus|strong="H1992"\w* \w hombres|strong="H1368"\w* \w que|strong="H3588"\w* \w son|strong="H3588"\w* \w valientes|strong="H1368"\w*. Están amargados \w como|strong="H3588"\w* una osa \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w cual|strong="H5315"\w* le roban \w sus|strong="H1992"\w* cachorros \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w campo|strong="H7704"\w*. Tu padre \w es|strong="H3588"\w* un experto \w en|strong="H3588"\w* \w guerra|strong="H4421"\w* \w y|strong="H3588"\w* \w no|strong="H3808"\w* pasará \w la|strong="H3588"\w* noche \w con|strong="H3588"\w* \w el|strong="H3588"\w* \w pueblo|strong="H5971"\w*.
\p 
