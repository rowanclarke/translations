\id 1TI
\h 1 TIMOTEO
\toc1 Tí xroon sa̱oxín ikjin chꞌín Pablo chrꞌénhen chꞌán tí chꞌín Timoteo
\toc2 1 TIMOTEO
\toc3 1 Ti.
\mt1 Tí xroon sa̱oxín ikjin chꞌín Pablo chrꞌénhen chꞌán tí chꞌín Timoteo
\c 1
\s1 Chꞌín Pablo nixje̱he̱ chꞌán tí chꞌín Timoteo
\p 
\v 1 Janhan Pablo kjueyána Jesucristo la ko Dios mé tsíkꞌe̱tua̱nna mé jehe chꞌán mé tí nkexro nchekaá chojni. La ko kja̱xin kꞌue̱tua̱nna Ìnchéni Jesucristo tí nkexro tjejóchónhenni itsi.
\v 2 Ikjian tí xroon chrꞌanhan jaha Timoteo. Tꞌíkua̱n éxí xja̱nna tí jaha kíxin jaha tinkachónkia Cristo Jesús. Kjuasáyé Itꞌéni Dios la ko Ìnchéni Jesucristo chrókjuintaya̱van chꞌán la ko chrókui̱konóa̱ha chꞌán kíxin kjuaxróxin tsjakꞌe jaha.
\s1 Chrókjuinchexráxinkaon chꞌán sín kíxin chrókuitekakuenhya sín tí nkehe chaxínhya
\p 
\v 3 Éxí xrja̱nnóa̱ha tió sákjuia estado Macedonia la mé jaha chrókuito̱ha tí chjasin Éfeso la ntaha chrókuétue̱nhén iso tí sín ntiha kíxin chrókjuakohya sín tí nkehe ntoáhya.
\v 4 La ko chrókuétue̱nhén sín kíxin chrókuahya sín kuenté tí cuento tsíchronka chojni tí ósé a. Tí tinhin sín tíha la imá tja̱cha̱xi̱n kíchó sín la ó chónkó tíha. Kaín tíha la í tsjinki̱tsahya kíxin sinchexiteyéheni Dios kíxin tinkáchónkini chꞌán.
\p 
\v 5 Tí nkehe tjinkaonni la chrótjuèheni kíchó ni kaín ni kíxin ó kótjóá a̱sénni la ko ó noheni kíxin jína tjenka̱yáxinni la ko kaín a̱sénni tinkáchónkini Cristo.
\v 6 Iso sín la kjuíchròe sín kíxin itjo tí nkehe chónkó.
\v 7 Tjinkaon sín chrókꞌóna sín maestro chrókjuako sín tí ley a̱ ntá jehe sín tienxínhya sín tí nkehe tjako sín kjánchó ntáchro sín kíxin ó ntoá tí nkehe tjako sín, ntá chaxínhya.
\p 
\v 8 A̱ ntá jeheni la ó noheni kíxin tí ley la jína tí chrokjuakoni éxí tjinkaon Dios.
\v 9 Ó noheni kíxin tí sín tjasinhya jie̱ tꞌichjánxi̱enhya sín tí ley tsíkꞌe̱to̱an Moisés. Tíhi la tꞌichjánxi̱nhin tí sín titekakonhya la ko tí sín jie̱he la ko tí sín jínahya tjasin jie̱ la ko tí sín chóntahya kjuasáyé Dios la ko tí sín tꞌóyán itꞌé la ko ìné sín la ko kaín tí sín tjàya.
\v 10 La ko tí sín tjasinko jie̱ ijnko chojni chjin ókjé la ko tí sín jnkokón ntoa sín takja kíchó sín la ko tí sín teé chojni ntá nchekji, la ko tí sín chꞌia la ko tí sín nchenohe Dios ntá chaxínhya. Mé tí ley mé chrókuinhin kaín tí sín chꞌe tí nkehe jínahya la nínkakonhen tí nkehe jína tjakoni.
\v 11 Tí nkehe tjakoni mé chaxín tí tan jína sinchekaá chojni la tí Dios tjetoan mé kꞌue̱tua̱nna kíxin tsjàkua tíha.
\s1 Chꞌín Pablo kjuanchehe chꞌán kjuasáyé Dios
\p 
\v 12 Tjáncháha̱ kjuasáyé Ìnchéni Jesucristo kíxin imá kjuínki̱tsana chꞌán la ko kꞌuíkon chꞌán kíxin jína si̱tꞌaha̱ chꞌán xra̱ ntá chjìna chꞌán tí xra̱ i.
\v 13 Mé xi̱kaha kjueyána chꞌán kjónté senó imá kꞌuékꞌántaxínha̱n tí sín tinkáchónki chꞌán la ko kꞌuéchonkíha̱ sín la ko chrókꞌoyán sín. Kjónté la Dios imá kui̱konóe̱he̱ chꞌán tí janhan kíxin ó nohe chꞌán kíxin kꞌuékinkachónkihya janhan tí jehe chꞌán la ko kꞌuénonahya nkehe tí xra̱ kꞌuékji̱tꞌa.
\v 14 Méxra̱ Ìnchéni a̱ntsí má kjuíncheyaonna kíxin ntá kjuanjon chꞌán kjuachaxin kíxin tsinkachónkia chꞌán la ko tso̱tjua̱ha̱ chꞌán. Mé xi̱kaha kaín ni chóntani tí kjuachaxin tinkáchónkini Cristo Jesús.
\p 
\v 15 Tíhi mé chaxín la kaín ni chrókuitekaonni. Ikui Jesucristo chjasintajni kíxin sinchekaá chꞌán tí sín kjuasin jie̱. Ntá janhan mé a̱ntsí má kjuásian jie̱.
\v 16 Kjónté xi̱kaha kjui̱tꞌa la Dios a̱ntsí má kui̱konóa̱na chꞌán tí janhan kíxin xi̱kaha kjua̱ko̱xi̱n Jesucristo kíxin kónínkakonhya chꞌán. Mé xi̱kaha tsjákua̱xia̱n kaín nkexro tsitekaon tí jehe chꞌán kíxin tsochónta sín kjuachón jnkochríxín.
\v 17 Ntá jnkochríxín tsochónteheni kjuasáyé tí Rey tꞌe̱to̱an. Jehe chꞌán mé ijnko nkexro xráxín tjen la mé ijnko nkexro chónhya tsꞌen la xitjahya tsꞌikonni chꞌán. Jehó chꞌán mé Dios la imá nohe chꞌán. Amén.
\p 
\v 18 Timoteo, éxí xja̱nna tꞌíkua̱n tí jaha, la kaín tí xra̱ i tja̱ha kíxin tsjanjo̱nkoa tí jínahya la tsjacha kíxin tinkachónkia jína Ìnchéni la ko tjenka̱yáxian tí nkehe jína. Mé xi̱kaha si̱nchexiteyá tí nkehe kuínhín senó kíxin tí sín kíchó ni chrónkaxín ihni̱é Dios.
\v 19 Í so sín la kjuenka̱yáxinhya sín tí jína ntá kjuíchròe sín kuíto̱he sín tí nkehe tinkáchónki sín.
\v 20 Mé xi̱kaha kónhen chꞌín Himeneo la ko chꞌín Alejandro. Janhan kjuánjuan kjuachaxin kíxin chꞌín Tsochren mé sinchekjasóte sín kíxin mé xi̱kaha tsꞌitja sín kíxin í tsꞌántaxíe̱nhya sín Dios.
\c 2
\s1 Nkexrí chrónixje̱he̱ni Dios
\p 
\v 1 A̱ ntá sa̱oxín la xrja̱nóa̱ha kíxin kaín chojni chrónixje̱he̱ sín Dios la chrókjuanchehe sín kjuasáyé chꞌán kíxin chrókjuinki̱tsa chꞌán kaín xín chojni.
\v 2 Chrókjuanchia sín kíxin Dios imá chrókjuinki̱tsa chꞌán kaín tí sín tꞌe̱to̱an la ko tí sín gobierno kíxin ntá kjuaxróxin tsꞌejóni la ko sinchexiteyéhe̱ni Dios la ko ntoá tsꞌejóni.
\v 3 Xi̱kaha mé imá jína la tóxrjínhi̱n Dios, mé tí nkexro tsaáxinni.
\v 4 Jehe chꞌán mé imá tjinkaon chꞌán kíxin tsaá kaín xín chojni la ko tjinkaon chꞌán kíxin tso̱nohe chojni tí nkehe chaxín ntoá.
\v 5 Mé itjen jnkoko̱áxón Dios la ko itjen jnkoko̱áxón nkexro nixjayákonhe̱nni kíxin tsochóxinni Dios. Tíha mé Jesucristo mé kꞌóna chojni ikui chꞌán chjasintajni.
\v 6 Jehe Jesucristo mé kꞌuenyákonhe̱nni kaín xínni, kjue̱nka̱yákonhe̱n chꞌán iji̱éni kíxin tsaáxinni chꞌán. Táha mé xiteyá tí tsíntáchro Dios ósé kíxin xi̱kaha tso̱nhen chꞌán.
\v 7 Méxra̱ tí xra̱ mé kjueyána Dios kíxin tsjíkjáko̱ha̱ tí sín jehya judío kíxin tsinkáchónki sín Jesucristo la ko tso̱nohe sín tí nkehe chaxín. Janhan mé tinkachónkia Cristo la xrja̱nka tí nkehe chaxín mé tꞌa̱yahya.
\p 
\v 8 Méxra̱ tjínka̱van kíxin kaín tí sín ntoa mé chrónixje̱he̱ sín Dios la chrókjuaya sín tja sín la chrókótjóá a̱sén sín la ko chrókónínkakonhya sín la ko chrókjuehya sín kjuanínkaon.
\v 9 A̱ ntá tí chojni chjin mé ntoá chrókꞌuitsa sín ka la chrókjuinchehnkehya sín la ko chrókjuasin chóntahya sín ka̱xi̱hi sín nkehe tjete xro̱xrjo̱ náxrjón la ko chrókꞌuitsahya sín ika imá tjete.
\v 10 Íchá jína kíxin tí chojni chjin chrókjuichꞌe sín tí xra̱ jína éxí chrókjuichꞌe kaín tí sín tsíkjinchetjóá Dios.
\v 11 Tí chojni chjin tꞌichjánxi̱n chrókuinhin sín itén Dios la chrónixjahya sín la ko chrókꞌue̱to̱anhya sín.
\v 12 A̱ ntá janhan tjánjonhya kjuachaxin kíxin chojni chjin chrókjuako tí nchónhya chojni siín la ko tjánjonhya kjuachaxin chrókꞌue̱tue̱nhen sín chojni ntoa. Jehe sín la tání sín chrókꞌuejó sín
\v 13 kíxin sa̱oxín la Dios kjuíchꞌéna chꞌán tí chꞌín Adán la ntá chrꞌéxi̱n kjuíchꞌéna chꞌán tjan Eva.
\v 14 A̱ ntá chꞌín Adán la ninkexró kjuíchꞌiyehya chꞌán. Náhí. Tí tjachjin mé tsíkitekakonhen tjan tí nkexro tsíkjichꞌiyehe tjan ntá xi̱kaha xrankíxixín kꞌuíxin jie̱.
\v 15 A̱ ntá tí chojni chjin la kjónté xi̱kaha kjuíchꞌe sín la Dios sinchekaá sín tí jína tsꞌayakonhen sín xje̱en sín la tí chaxín tinkáchónki sín Dios la ko tjuèhe sín chꞌán la ko ntoá tsꞌejó sín la ko jína tsjenka̱yáxin sín.﻿
\c 3
\s1 Jína chrókꞌuejó tí sín tꞌe̱tue̱nhen tí ni̱nko
\p 
\v 1 Ijnko nkehe chaxín tjo̱nka. Tí nkexro tjinkaon sichꞌe xra̱ kuènte ni̱nko mé imá jína xra̱ tjinkaon chꞌán.
\v 2 Tí chꞌín chrókꞌue̱to̱an mé ntoá chrókjuakꞌe chꞌán kíxin kohya nkexro chrókꞌueka chꞌán jie̱ la ko kja̱xin chróchónta chꞌán jnkoko̱á ichjién chꞌán ó la ko kja̱xin chrókjuakꞌe chꞌán jína la ko chrókjuenka̱yáxin chꞌán jína la ko chróchónta chꞌán kjuasáyé chꞌán la ko kja̱xin jína chrónixje̱he̱ chꞌán tí nkexro tjiji nto̱e la ko kja̱xin chrókónohe chꞌán tí nkehe chrókjuako chꞌán.
\v 3 La ko kja̱xin chrókókoanhya chꞌán la ko chrókjuehya chꞌán kjuanínkaon la ko kja̱xin chrókóxrjíe̱nhya chꞌán kíxin chrókjuacha chꞌán nchónhya chichaon. A̱ ntá chrókójie̱hya chꞌán la ko kjuaxróxin chrókjuakꞌe chꞌán la ko chrókóxrjíe̱nhya chꞌán chróchónta chꞌán itsjé chichaon.
\v 4 Jehe chꞌán mé kja̱xin jína chrókꞌue̱tue̱nhen chꞌán tí sín tjejó nto̱e chꞌán la ko chrókjuentuéhe chꞌán xje̱en chꞌán kíxin tsitekaon xjan la tsjikosáyehe xjan itꞌé xjan.
\v 5 Tí tsjachahya chꞌán tsꞌe̱tue̱nhen chꞌán tí sín tjejó nto̱e chꞌán la ¿ntá nkexrí chrókꞌue̱to̱an chꞌán tí ni̱nko kuènte Dios?
\v 6 Íchá jína kíxin jehya ijnko nkexro na ntá kꞌuíxenhen chrókjuako kíxin tí nkexro na ntá kꞌuíxenhen la imá chrókjuinchehnke chꞌán la ntá chrókjuasin chꞌán jie̱ éxí kjuasin chꞌín Tsochren ijie̱ senó.
\v 7 Kja̱xin tꞌichjánxi̱n kíxin kaín xín tí sín na̱xa̱ tinkáchónkihya Ìnchéni mé tsochónta sín kjuasáyé tí chꞌín tꞌe̱to̱an a. Tí náhí la tsꞌeka sín chꞌán jie̱ ntá tí xi̱kaha la chꞌín Tsochren tsjacha tsjachròe tí chꞌín a ntá tsjasin chꞌán jie̱.
\s1 Nkexrí chrókꞌuejó tí sín tsjinki̱tsa tí xra̱ kuènte ni̱nko
\p 
\v 8 Kja̱xin tí sín diácono chꞌe xra̱ kuènte ni̱nko la kja̱xin ntoá chrókꞌuejó sín kíxin chróchóntehe sín kjuasáyé chojni. Kja̱xin tꞌichjánxi̱n kíxin chrókjuinchexiteyá sín tí nkehe ntáchro sín la ko chrókókoanhya sín la ko kja̱xin chróchóntia̱xi̱nhya sín itsjé chichaon chrókjuacha sín.
\v 9 Tꞌichjánxi̱n chrókónohe sín jína tí nkehe tinkáchónki sín kíxin jehe sín chróxraxinkaon sín á ncho̱xon tí xra̱ chꞌe sín.
\v 10 Sa̱oxín chrótsjehe kaín chojni á ninkehó jie̱ chóntahya tí nkexro la ntá tí chaxín jína jehe chꞌán la ninkehó jie̱ chóntahya chꞌán ntá jína tsꞌixenhen chꞌán tí xra̱ kuènte ni̱nko.
\v 11 La ko kja̱xin tí chojni chjin mé chrókꞌuejó sín jína kíxin chróchónta sín kjuasáyé sín. Kja̱xin chrókuinkáchónkihya sín kjuachꞌia la ko jína chrókꞌuejó sín la ko chrókjuinchexiteyá sín kaín nkehe.
\v 12 Tí sín diácono la mé chróchónta sín jnkoko̱á ichjién sín la jína chrókꞌue̱tue̱nhen sín xje̱en sín la ko jína chrókꞌue̱to̱an sín nto̱e sín.
\v 13 Tꞌichjánxi̱n ijnko xra̱ jína sichꞌe sín kíxin ntá tsjacha sín tsꞌáyéhe̱ sín ijnko nkehe jína tsjanjon ìnchéni la ko kja̱xin tso̱suèhya sín tsochrónka sín nkexrí tinkáchónki sín Cristo Jesús.
\s1 Dios mé kjuínchenoheni tí nkehe kꞌuékienxínhyani
\p 
\v 14 Tjínka̱van tjoka chrókjuasántsjaha̱ tí jaha kjánchó senó tsokjian tí xroon i.
\v 15 A̱ ntá tí tso̱xrjenna isé ntá kjónté tso̱noha nkexrí chrókꞌuejó tí sín na̱xa̱ kjéhya Dios mé tí sín tꞌóna ni̱nko̱e Dios tjechón. Jeheni kaín ni mé tjejótꞌayakonhenni tí tan chaxín ntoá.
\v 16 Ninkexró chróntáchrohya kíxin chaxínhya tí nkehe tinkáchónkini mé ijnko nkehe imá jié tíha la ninkexró kꞌuénoehya tí senó a.
\q1 Dios mé ikui kꞌóna chojni;
\q1 ikui chꞌán kjua̱ko̱xi̱n chꞌán kjua̱cha̱xién Ncha̱kuen Dios chónta chꞌán kíxin jína tí jehe chꞌán.
\q1 La ntá tí sín ángel mé kꞌuíkon sín chꞌán
\q1 la kuenté chjasintajni mé ó kuínhin sín nkehe chrónka chꞌán
\q1 ntá itsjé sín kuítekaon sín chꞌán.
\q1 Ntá Dios kꞌuáyéhe̱ tí jehe chꞌán nkaya nka̱jní.
\c 4
\s1 Tí sín kuíto̱he tinkáchónkihya Cristo
\p 
\v 1 A̱ ntá ntáchro Ncha̱kuen Dios kíxin tí chjina tsjeje̱ chjasintajni mé iso sín mé tsíto̱he sín í tsinkáchónkihya sín Ìnchéni la ntá tsitekaon sín ncha̱kuen tí jínahya sichꞌiyehe sín la ko tsitekaon sín tí nkehe tjako tí sín demonio.
\v 2 Mé tsinhin sín tí nkehe tjako tí chojni tjuáhya la chꞌia sín. Kjónté imá tsjasin sín jie̱ la í tso̱suèhya sín kíxin éxí tsíchján tí tjenka̱yáxixín sín la í tjenka̱yáxinhya sín jína.
\v 3 Jehe sín mé tjinkakonhya sín kíxin chrókóte̱he chojni la ko kja̱xin tjinkakonhya sín kíxin chrókjóneni nto. A̱ ntá jeheni ó noheni kíxin Dios mé kjuíchꞌéna chꞌán kaín xín nkehe ineni la tjinkaon chꞌán kíxin tí jeheni tinkáchónkini chꞌán la ó noheni tí tan chaxín ntoá mé chrókjuancheheni chꞌán kjuasáya ntá chrókjoneni.
\v 4 Méxra̱ kaín xín tí nkehe kjuíchꞌéna Dios la jína la kohya nkehe chróntáchroni kíxin jehya jína sineni. Chrókjuancheheni Dios kjuasáya la ntá jína chrókjóneni
\v 5 kíxin tió tsoxraxinkaonni itén Dios la tsonixje̱he̱ni chꞌán la ntá sincheyaon chꞌán tí nkehe sineni.
\s1 Ijnko chojni jína chꞌehe xra̱ Jesucristo
\p 
\v 6 Jaha tjákohé tí sín kíchó ni kaín tí nkehe i la ntá xi̱kaha imá jína si̱chꞌehé xra̱ Jesucristo la ko a̱ntsí tsjinki̱tsa chꞌán tsꞌánkí kjuaxrexinkaon kuèntá tí tinkachónkia tí tan kuènté chꞌán la ko na̱xa̱ tjàkua tí nkehe jína ó xráko̱ha.
\v 7 Jaha mé tahya kuenté tí cuento chónkó la ko tí nkehe ntoáhya tinkáchónki iso sín. A̱ ntá jaha la chrókui̱to̱éhya chrókuinkachónkia Dios.
\v 8 Tí chojni tsítán la jína tíha kjánchó a̱ntsí má tjetoan chróxraxinkaonni Dios. Tíha la tsjinki̱tsa kíxin jína xritjejóni ijie la ko kja̱xin tsjinki̱tsa kíxin tsꞌáyéhe̱ni kjuachón jnkochríxín tió tsokjan Ìnchéni.
\v 9 Kaín tíhi mé chaxín la kaín chojni chrókuitekaon.
\v 10 Mé xi̱kaha kjónté tꞌántaxínhi̱nni chojni la jína chꞌeni tí xra̱ i kíxin tinkáchónkini Dios tjechón. Jehe chꞌán chaxín sinchekaá chꞌán kaín tí chojni titekaon tí jehe chꞌán.
\p 
\v 11 Kaín tíha mé tꞌichjánxi̱n tséto̱an la ko tsjàkua.
\v 12 Jaha chrókui̱to̱éhya kíxin chrokjuanoá sín kjónté na̱xa̱ ntasoyá. Chrókjuáko̱exián tí sín tinkáchónki Ìnchéni nkexrí chrónixja sín la ko nkexrí ntoá chrókꞌuejó sín la ko nkexrí chrótjuèhe sín Dios la ko nkexrí chrókuitekaon sín Ìnchéni la ko nkexrí tjóá chrókꞌuejó sín.
\v 13 Nachrohe tsjasán la jaha si̱nchekuáxian tí xroon itén Dios kíxin tsinhin kaín sín la ko si̱nchexraxinkávan kaín tí sín kíchó ni la ko tjákohé sín.
\v 14 Si̱nchekꞌitjáyanhya tí kjua̱cha̱xién Dios kꞌuayéhé tió tí sín tꞌe̱to̱an kuènte ni̱nko kjua̱cha̱xién Dios kꞌuejotja tja sín chrítaón ikjá.
\p 
\v 15 Chrókóxakonhan chrókjui̱nchexiteyá kaín tíha kíxin kaín chojni tsotsjehe sín kíxin jína noha.
\v 16 Chrókjuenka̱yáxian jína tí nkehe tjàkua kíxin jína chrókjuakꞌe jaha, chrókjui̱nchexiteyá kaín nkehe la ntá tí xi̱kaha si̱chꞌe la tsaá jaha la ko tí sín tjejótinhin tjàkua la tsaá sín kja̱xin sín.
\c 5
\s1 Jína chrókꞌuéjó tí sín tinkáchónki Cristo
\p 
\v 1 Jaha la chrókóninkákuenhya tí sín ó táda. Náhí íchá jína chrónixje̱hé sín jnkojína éxí chrónixje̱hé itꞌá. La kja̱xin tí sín ntasoá chrónixje̱hé sín éxí chrónixje̱hé kíchuá mero.
\v 2 A̱ ntá tí sín ó nána la mé chrónixje̱hé sín éxí chrónixje̱hé ìná xi̱kaha. Kja̱xin tí sín tjarisoá mé jnkojína chrónixje̱hé sín éxí chrónixje̱hé kíchuá mero la kja̱xin chróchóntehé sín kjuasáya.
\p 
\v 3 La ko kja̱xin chrókjuínki̱tsa tí síchjin tsíkókꞌán la ko ncheki̱to̱nhén sín nkehe sine sín tí chaxín kohya nkexro tsjinki̱tsa sín.
\v 4 A̱ ntá tí chojni chjin tsíkókꞌán chónta xje̱en o̱ chónta ìnté, a̱ ntá tí jehe sín mé chrókꞌuitja sín chrókjuinki̱tsa sín kíxin sine tí sín kjéhya sín. Tíha mé chrókjue̱nka̱xin sín tí itꞌé, ìné sín kíxin kjuínchekꞌánkí sín, kíxin xi̱kaha mé jína tóxrjínhi̱n Dios.
\v 5 Tí tjan chaxín tsíkókꞌán na jehó tjan tjen tjan mé jehó Dios tinkáchónki tjan la imá chrónóe̱he̱ tjan Dios tie la ko ncha̱kotjin.
\v 6 A̱ ntá tí sín tsíkókꞌán ixri sín tjasin sín jie̱ la kjónté tjejóchón sín la éxí tsíkꞌen sín xi̱kaha tjejó sín.
\v 7 Tétue̱nhén tí sín kíxin sinchexiteyá sín kaín tíha kíxin tso̱kohya nkexro tsjanchia jie̱.
\v 8 A̱ ntá tí nkexro tóxakuenhya kíxin tí sín na̱xa̱ kjéhya la ko kja̱xin tóxakuenhya kíxin tí sín tjejó nto̱e chꞌán mé xi̱kahó tja̱ko̱xi̱n kíxin ninkehó tinkáchónkihya chꞌán Dios. Mé xi̱kaha a̱ntsí chónta chꞌán jie̱ a̱ ntá tí sín tinkáchónkihya Ìnchéni la kénhyó.
\p 
\v 9 Tí tsꞌínixín ihni̱é tí sín tsíkókꞌán la chrókꞌuínixín jehó tí sín chónta sesenta nánó la ko tí sín kꞌuéchónta sín jnkoko̱á xìi.
\v 10 Kja̱xin chrókjua̱ko̱xi̱n tjan kíxin jína chꞌe tjan xra̱ la ko chrókjua̱ko̱xi̱n tjan kíxin jína kjuínchekꞌánkí xje̱en tjan la ko kja̱xin jína nixje̱he̱ tjan tí nkexro tjiji nto̱e tjan la ko kja̱xin kꞌuàyakonhen tjan tí sín tinkáchónki Cristo la nchehnkehya tjan la ko kja̱xin kjuínki̱tsa tjan tí sín níhi la ko í so xra̱ jína kjuíchꞌe tjan.
\p 
\v 11 A̱ ntá chrókꞌuénixínhya ihni̱é tí sín tsíkókꞌán na̱xa̱ tsjéhya nánó chónta kíxin tsontáchro a̱sén sín kíxin í jnko chojni ntoa tso̱te̱he sín ínaá la ntá tsíto̱he sín ixra̱ kuènte Cristo.
\v 12 Ntá xi̱kaha tsjasin sín jie̱ kíxin sinchexiteyáhya sín tí nkehe tsíntáchro sín.
\v 13 Kja̱xin sátsji sín ijnko nchia la í jnko nchia la ntá tso̱séhe sín la ntá kja̱xin xriko sín kjuachꞌia la ko chꞌéna sín kjuachꞌia la kaín nkehe nixja sín la jehya jína tí xi̱kaha chrónixja sín.
\v 14 Méxra̱ tí sín tsíkókꞌán na̱xa̱ tjarisoá sín la íchá jína chrókóte̱he sín chróchónta sín xje̱en sín la ko chrókꞌuàyakonhen sín nto̱e sín. A̱ ntá tí xi̱kaha la tí sín nínkakonhan la chrókjontahya sín tí jaha.
\v 15 A̱ ntá iso tí sín tsíkókꞌán ó kuíto̱he sín tinkáchónki sín Ìnchéni kíxin chꞌín Tsochren tsíkjachròe sín.
\p 
\v 16 A̱ ntá jnkojín chojni tinkáchónki Cristo tsꞌikon sín kíxin tsíkókꞌán tí síchjin kjéhya sín ntá tꞌichjánxi̱n tsjinki̱tsa sín kíxin sine tí sín a kíxin tsochóntiahya sín tí ni̱nko tsjinki̱tsa. Méxra̱ jehó tí sín chaxín tsíkókꞌán chóntahya ninkexró tsjinki̱tsa mé chrókjuinki̱tsa tí ni̱nko.
\p 
\v 17 Tí nkexro jína tꞌe̱to̱an xra̱ kuènte ni̱nko la jehe sín chrókjuacha sín la ko kja̱xin a̱ntsí chrókjuikosáyehe chojni tí sín chaxín xra̱ ó tjejóchronkaxín sín la ko tjako sín.
\v 18 Kíxin xroon itén Dios mé ntáchro kíxin: “Chrókꞌuéjóyáhyará kampoxa irꞌva tí koxinta tjejóchꞌe xra̱”, la ko kjaxin ntáchro kíxin: “Tí sín chꞌe xra̱ la siín kjuachaxin chrókjuacha sín.”\f + \fr 5:18 \ft Deuteronomio 25.4, Mateo 10.10; Lucas 10.7\f*
\p 
\v 19 Chrókuahya kuenté jnkojín nkexro tsji̱ka̱o kjuachꞌia tꞌeka jie̱ tí nkexro tꞌe̱to̱an xra̱ kuènte ni̱nko. Tꞌichjánxi̱n tso̱noxín yaá o̱ iyꞌá sín tsochrónka kíxin chaxín chónta jie̱ tí nkexro a.
\v 20 Chrókjuéntuéhé tí sín tjasin jie̱ nkayakon kaín sín kíxin ntá tsinhin tí í so sín kíxin tsochrakon sín, í tsjasinhya sín jie̱.
\v 21 Tétua̱nxian kjua̱cha̱xién Dios la ko Ìnchéni Jesucristo la ko tí sín ángel kjueyá chꞌán kíxin jnkokón tsjéntuéhé kaín chojni la ko jnkokón tétue̱nhén sín kaín tí nkehe xrja̱nka.
\v 22 Chrókjuéyáhya chji̱ni jnkojín sín kíxin tsꞌe̱to̱an sín xra̱ kuènté ni̱nko kíxin tí chróchónta sín jie̱ la kja̱xin jaha chrókuamá tí jie̱. A̱ ntá jaha chrókui̱to̱hé kaín nkehe jínahya.
\p 
\v 23 Jaha la jnkoya̱xón tóníha tjoté tsa̱a. Jehya ìnta̱ ó chrókꞌuia. Kja̱xin intsí xranvino chrókꞌuia ntá chrókuíto̱axián jína.
\p 
\v 24 Tí iji̱é jnkojín chojni la tꞌikonni noxín tí na̱xa̱ kuíto̱exínhya iji̱é sín. A̱ ntá í so sín nóxinhya tjasin sín jie̱ kjánchó tió tsjixixín la tso̱noxín tí jie̱ tjasin sín.
\v 25 Mé xi̱kaha kja̱xin ó tꞌikonni kíxin iso chojni imá chꞌe sín tí xra̱ jína. A̱ ntá í so sín kjónté tꞌikonhyani la xitjahya tsjakꞌemá sín tí nkehe jína chꞌe sín.
\c 6
\p 
\v 1 Tí sín chꞌexín xra̱ mé tꞌichjánxi̱n tsochóntehe sín kjuasáya tí lamo kuènte sín, kíxin ntá tí í so sín la tsꞌántaxíe̱nhya sín ihni̱é Dios la ko tsꞌántaxíe̱nhya sín tí nkehe tjakoni.
\v 2 A̱ ntá tí sín chꞌexín xra̱ la chónta sín lámo̱é sín tinkáchónki Cristo la mé chrókuíto̱ehya sín tsjikosáyehe sín tí lamo kíxin jnkoko̱á kíchó sín. La mé a̱ntsí jína chrókjuinki̱tsa sín kíxin ó nohe sín kíxin tjinki̱tsa sín ijnko nkexro tinkáchónki Cristo la chrótjuèhe sín kíchó sín. Jaha mé tjákohé sín kaín tíha.
\s1 Tí nkehe tinkáchónkini tso̱chèxinni
\p 
\v 3 Iso sín tjako tí nkehe jehó sín tjenka̱yáxin sín la tóyóe̱hya tí nkehe jína kjuako Ìnchéni Jesucristo la ko jehya tí nkehe tinkáchónkini.
\v 4 Ó jehí nchehnke sín la nínkehó noehya sín. Tí ntoáhya nixja sín la tíha mé éxí ijnko chin chónta sín la tíha mé tji̱xi̱n tí kjuachji̱no̱xínhin la ko tjanjo̱nko kíchó sín la ko tꞌántaxínhi̱n sín kíchó sín la ko chóntehya sín kíchó sín kjuasáya.
\v 5 Mé tí sín la náxrjónhya tjenka̱yáxin sín la jnkochríxín tjanjo̱nko kíchó sín la noehya sín tí nkehe chaxín. Mé tjenka̱yáxin sín kíxin tinkáchónki sín Ìnchéni kíxin xi̱kaha chrókjuacha sín nchónhya chichaon, ichro sín. Jaha la chrókui̱to̱hé tí sín xi̱kaha chꞌe.
\v 6 Tí tinkáchónkini Ìnchéni la ijnko nkehe imá tjetoan la ko tjete tíha a̱ ntá kjuaxróxin chrókꞌuejóni kjónté tí nkehe chóntani ó.
\v 7 A̱ ntá tí kokjíhini la ninkehó kuikohyani tí kuini chjasintajni la kja̱xin tió tsꞌenni la ninkehó nkehe xitjahya sátsji̱koni.
\v 8 A̱ ntá tí chóntani nkehe sineni la ko chóntani ikéni la kjónté táhó la chrókóchéhe̱ni.
\v 9 A̱ ntá tí sín tjinkaon sín imá chrókóríko sín mé tí sín a mé tsjichròe sín la lo̱nti̱ sín kíxin xi̱kaha tjenka̱yáxin sín, la mé tsꞌitjáyanxín sín tíha.
\v 10 Tí imá tjuèheni chichaon la tíha mé nuèé kaín nkehe jínahya. Jnkojín chojni imá tjinkaon sín tsochónta sín chichaon ntá tsjichròe sín tsíto̱he sín tsinkáchónki Ìnchéni la tíha mé imá sinchekjasótexín sín a̱sén sín.
\s1 Jína tí nkehe tinkáchónkini
\p 
\v 11 Jaha mé tinkachónké Dios la ti̱to̱hé kaín tí nkehe i. Chrókjuakꞌe ntoá la ko kaín a̱sán chróxráxinkávan Dios la ko chrókuinkachónkia chꞌán la ko chrótjuéhé kíchua la ko chrókónínkákonhya tjoka la ko chrókjui̱nchehnkehya a̱sán.
\v 12 Tjanjo̱nkoa kaín nkehe jehya tí jína la ko kaín a̱sán tinkachónkia Ìnchéni kíxin ntá chrókjuacha chrókꞌuayéhé tí kjuachón jnkochríxín kíxin mé xi̱kaha kꞌuíyaha Dios tí jaha. Jaha la ó tsíchro̱nka kíxin tinkachónkia Ìnchéni la ó kuínhin la ko kꞌuíkon nchónhya chojni.
\v 13 Nkayakon Dios, tí nkexro chjéhe kjuachón kaín xín tí nkehe síchón, la ko Jesucristo, tí nkexro tsíchrónka jína nkayakon chꞌín Poncio Pilato, mé tétua̱nhan
\v 14 kíxin si̱nchexiteyá kaín tí nkehe tꞌe̱to̱an Dios kíxin í chrókjuínkíhya tí nkehe chrókuinkachónkia la ntá tso̱kohya ninkexró tsꞌeka jie̱ tió tsjixrakájia tí ya̱on tsokjan Ìnchéni Jesucristo.
\v 15 Tsjixraká tí ya̱on kjueyá Dios ntá jehe chꞌán mé tsjanjon chꞌán kjuachaxin kíxin itsi Jesucristo. Dios la jehó chꞌán mé chónta chꞌán kjuachaxin tsꞌe̱to̱an chꞌán. Jehe chꞌán mé tí Rey tꞌe̱tue̱nhen kaín xín tí sín rey la ko jehe chꞌán mé Ìnché kaín chojni.
\v 16 Jehó Dios mé chónhya tsꞌen la tí tjen chꞌán la imá tꞌinkaséyan la ko kohya nínkexró tsjacha tso̱chjina tí tjen chꞌán. Nínkexró kꞌuíkonhya tí jehe chꞌán la ko ninkexró xitjahya tsꞌikon tí jehe chꞌán. Tsjikosáyeheni chꞌán kíxin jehe chꞌán chónta chꞌán kjuachaxin tsꞌe̱to̱an jnkochríxín. Amén.
\p 
\v 17 Tí sín chónta itsjé nkehe chjasintajni mé tétue̱nhén sín kíxin sinchehnkehya sín la ko tétue̱nhén sín kíxin tsochóntia̱xi̱nhya sín tí nkehe chónta sín kíxin jnkochríxínhya tsochónta sín tíha. Íchá jína chrókuinkáchónki sín Dios tjechón kíxin jehe chꞌán tjanjon chꞌán kaín xín nkehe kíxin mé xi̱kaha tjinkaon chꞌán tso̱chéhe̱ni.
\v 18 Tétue̱nhén sín kíxin chrókjuichꞌe sín tí nkehe jína kíxin tí chaxín chrókóríko sín la chrókjuinki̱tsa sín kíchó sín la chrókꞌóxika̱ye̱he sín tí nkehe chónta sín.
\v 19 Mé xi̱kaha chrókjuacha sín tí nkehe tjete kíxin chrꞌéxi̱n la jína chrókꞌuejó sín kíxin chrókjuacha chróchónta sín tí kjuachón jnkochríxín.
\s1 Kjuixixín kꞌuítuenhen chꞌín Timoteo
\p 
\v 20 Jaha Timoteo tꞌayakonhén tí xra̱ la tiénhya tí nkehe ntoáhya nixja chojni. Ntáchro sín kíxin imá nohe sín kjánchó chaxínhya tíha.
\v 21 Iso sín ó xi̱kaha ntáchro sín kíxin imá nohe sín la ntá kjuíchròe sín í tinkáchónkihya sin Ìnchéni. Dios chrókjuintayavan tí jaha. Amén. Ó tjen.
