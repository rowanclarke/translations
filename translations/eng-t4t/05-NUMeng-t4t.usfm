\v 28 \w That|strong="H3478"\w* \w was|strong="H3478"\w* \w the|strong="H1121"\w* \w order|strong="H4550"\w* \w in|strong="H3478"\w* \w which|strong="H3478"\w* \w the|strong="H1121"\w* \w groups|strong="H1121"\w* \w of|strong="H1121"\w* Israeli tribes \w traveled|strong="H5265"\w*.
