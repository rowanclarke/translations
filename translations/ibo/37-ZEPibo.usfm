\id ZEP - Biblica® Open Igbo Contemporary Bible 2020
\h Zefanaya
\toc1 Zefanaya
\toc2 Zefanaya
\toc3 Zef
\mt1 Zefanaya
\c 1
\p 
\v 1 Okwu \nd Onyenwe anyị\nd* nke rutere Zefanaya, nwa Kushi, nwa nwa Gedaliya, bụ nwa Amaraya. Amaraya bụ nwa Hezekaya. Ozi a bịara nʼoge Josaya nwa Amọn, bụ eze Juda.
\s1 Ikpe ọmụma dịrị ụwa niile nʼụbọchị nke Onyenwe anyị
\q1 
\v 2 “Aga m azachapụ ihe niile
\q2 site nʼelu ụwa,”
\q2 Otu a ka \nd Onyenwe anyị\nd* kwubiri.
\q1 
\v 3 “Aga m azachapụ mmadụ na anụmanụ.
\q2 Aga m azachapụ ụmụ anụ ufe niile nke dị nʼeluigwe,
\q2 zachapụkwa azụ niile nke dị nʼosimiri,
\q2 na arụsị niile dị iche iche nke na-eme ka ndị ajọ mmadụ sụọ ngọngọ.”
\b
\q1 “Mgbe m kpochapụrụ\f + \fr 1:3 \ft Maọbụ, \fqa lara mmadụ niile nʼiyi\f* mmadụ niile
\q2 site nʼelu ụwa,”
\q2 otu a ka \nd Onyenwe anyị\nd* kwubiri.
\s1 Ahụhụ dịrị Juda
\q1 
\v 4 “Aga m esetipụ aka m megide Juda,
\q2 megidekwa ndị niile bi na Jerusalem.
\q1 Aga m ebipụkwa ndị niile na-efe Baal fọdụrụ nʼebe a,
\q2 na aha ndị nchụaja arụsị niile, ma ndị nchụaja niile na-ekpere arụsị,
\q1 
\v 5 bụ ndị ahụ niile na-anọ nʼelu ụlọ ha
\q2 na-akpọ isiala nye ọnwa na kpakpando,
\q1 ha na ndị ahụ niile na-akpọrọ Onyenwe anyị isiala, na-eji aha ya nʼaṅụ iyi,
\q2 ma na-ejikwa Milkọm\f + \fr 1:5 \ft Maọbụ, \fqa Molek\f* na-aṅụ iyi,
\q1 
\v 6 na ndị ahụ niile na-alaghachi azụ site nʼiso \nd Onyenwe anyị\nd*,
\q2 na ndị ahụ na-adịghị achọ \nd Onyenwe anyị\nd*, maọbụ jụta ase site nʼaka ya.”
\b
\q1 
\v 7 Dere duu nʼihu Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd*
\q2 nʼihi na ụbọchị ikpe ya ahụ dị egwu na-abịa nso.
\q1 \nd Onyenwe anyị\nd* ejikerela ịchụ aja;
\q2 o doola ndị ọ kpọrọ oriri nsọ.
\b
\q1 
\v 8 “Nʼụbọchị ịchụ aja nke \nd Onyenwe anyị\nd* ahụ,
\q2 aga m ata ndịisi niile
\q2 na ụmụ eze niile,
\q1 na ndị niile na-eyi uwe
\q2 e si na mba ọzọ bubata ahụhụ.
\q1 
\v 9 Nʼụbọchị ahụ, aga m ata ha ahụhụ
\q2 bụ ndị niile na-adịghị azọ ụkwụ nʼọnụ ụzọ mbata,\f + \fr 1:9 \ft Ndị na-amafe mbata ọnụ ụzọ\f*\f + \fr 1:9 \ft Gụọ \xt 1Sa 5:5\xt*\f*
\q1 ndị ji ihe ike na aghụghọ
\q2 na-emejupụta ụlọ arụsị ha.
\b
\q1 
\v 10 “Nʼụbọchị ahụ,”
\q2 otu a ka \nd Onyenwe anyị\nd* kwubiri ya,
\q1 “olu iti mkpu akwa ga-esite nʼỌnụ Ụzọ Ama Azụ daa,
\q2 mkpu nke ịkwasi akwa ike ga-ada site nʼebe obibi ọhụrụ ahụ,
\q2 na ụzụ oke ntiwa site nʼugwu nta niile.
\q1 
\v 11 Kwasienụ akwa ike unu ndị niile bi nʼakụkụ ebe ahịa dị;
\q2 nʼihi na a ga-egbuchapụ ndị ahịa unu niile.
\q2 Ndị niile na-eji ọlaọcha azụ ahịa ka a ga-ebibi.
\q1 
\v 12 Nʼoge ahụ, aga m eji oriọna nyobanyechaa anya nʼakụkụ niile nke Jerusalem.
\q2 Aga m ata ndị ahụ niile na-anọ nʼahụ dị jụụ ahụhụ,
\q2 bụ ndị ahụ dọọrọ dịka ike mmanya a ṅụfọdụrụ aṅụfọ,
\q1 ndị na-eche nʼobi ha sị, ‘O nweghị ihe \nd Onyenwe anyị\nd* ga-eme anyị,
\q2 maọbụ ihe ọma, maọbụ ihe ọjọọ.’
\q1 
\v 13 Akụ ha ga-abụ ihe a kwakọrọ nʼike,
\q2 a ga-akwatukwa ụlọ ha niile.
\q1 Ọ bụ ezie na ha ga-ewu ụlọ,
\q2 ma ha agaghị ebi nʼime ha;
\q1 ọ bụ ezie na ha ga-akọ ubi vaịnị,
\q2 ma ha agaghị aṅụ mmanya si na ha.”
\b
\s1 Ụbọchị ukwu nke \nd Onyenwe anyị\nd*
\q1 
\v 14 Oke ụbọchị \nd Onyenwe anyị\nd* na-abịa nso,
\q2 ọ na-abịakwa ọsịịsọ.
\q1 Gee ntị! Iti mkpu akwa nke ụbọchị \nd Onyenwe anyị\nd* ga-adị ilu nke ukwuu.
\q2 A ga-anụkwa ụzụ ndị bụ dike nʼagha nʼebe ahụ.
\q1 
\v 15 Ụbọchị ahụ ga-abụ ụbọchị ọnụma,
\q2 ụbọchị ahụhụ na mkpagbu,
\q3 ụbọchị nsogbu na mbibi,
\q2 ụbọchị ọchịchịrị na oke obi ọjọọ,
\q3 ụbọchị igwe ojii, na oke ọchịchịrị,
\q2 
\v 16 ụbọchị opi ike na iti mkpu agha
\q1 imegide obodo niile e wusiri ike,
\q2 na imegide akụkụ ụlọ elu niile.
\b
\q1 
\v 17 “Aga m eme ka oke nhụju anya bịakwasị ndị mmadụ,
\q2 mee ka ha jegharịa dịka ndị kpuru ìsì,
\q2 nʼihi na ha emehiela megide \nd Onyenwe anyị\nd*.
\q1 A ga-awụsịkwa ọbara ha dịka uzuzu,
\q2 tufukwaa anụ ahụ ha dịka nsị anụ.
\q1 
\v 18 Ọlaọcha na ọlaedo ha
\q2 agaghị azọpụta ha
\q2 nʼụbọchị ọnụma nke \nd Onyenwe anyị\nd* ahụ.”
\b
\q1 A ga-erechapụ ụwa niile
\q2 site nʼọkụ ekworo ya,
\q1 nʼihi na ọ bụ na mberede
\q2 ka ọ ga-eme ka ndị niile bi nʼụwa gwụsịa.
\c 2
\s1 E kpere Juda na Jerusalem ikpe ha na mba niile
\s2 Oku akpọrọ Juda ka ọ chegharịa
\q1 
\v 1 Chịkọtaanụ onwe unu, e, chịkọtaanụ onwe unu,
\q2 unu ndị mba ihe ihere dịrị.
\q1 
\v 2 Tupu ụkpụrụ ahụ ewere ọnọdụ,
\q2 a chịpụ ụbọchị ahụ dịka igbugbo ọka nke ikuku na-ebufu,
\q1 tupu iwe ọkụ Onyenwe anyị
\q2 abịakwasị gị,
\q1 tupu ụbọchị ọnụma nke \nd Onyenwe anyị\nd*
\q2 abịakwasị gị.
\q1 
\v 3 Chọọnụ \nd Onyenwe anyị\nd*, unu ndị niile dị umeala nʼobi nọ nʼala ahụ,
\q2 unu bụ ndị na-eme ihe o nyere nʼiwu.
\q1 Gbasoonụ ezi omume, gbasoonụ ịdị umeala nʼobi,
\q2 ma eleghị anya, a ga-echebe unu
\q2 nʼụbọchị iwe \nd Onyenwe anyị\nd*.
\s2 Ahụhụ dịrị Filistia
\q1 
\v 4 Nʼihi na o nwekwaghị ndị ga-ebi nʼobodo Gaza,
\q2 obodo Ashkelọn ga-atọgbọrọ nʼefu.
\q1 Nʼetiti ehihie ka a ga-ekpochapụ ndị niile bi nʼAshdọd;
\q2 a ga-ehopukwa Ekrọn.
\q1 
\v 5 Ahụhụ dịrị unu ndị bi nʼakụkụ oke osimiri,
\q2 unu bụ ndị Keret;
\q1 okwu \nd Onyenwe anyị\nd* na-emegide unu,
\q2 Kenan, ala ndị Filistia.
\q1 Ọ sịrị, “Aga m ala gị nʼiyi,
\q2 ruo na ọ dịghị onye ga-afọdụ ndụ nʼime gị.”
\q1 
\v 6 Ala nke dị nʼakụkụ oke osimiri ahụ,
\q2 ga-aghọ ebe ahịhịa jupụtara nye ndị ọzụzụ atụrụ
\q2 na ọgba igwe ewu na atụrụ.
\q1 
\v 7 Ala nke dị nʼakụkụ oke osimiri
\q2 ga-aghọ ala nke ndị ahụ fọdụrụ na Juda,
\q2 ebe ha ga-achọtara anụ ụlọ ha ahịhịa.
\q1 Ha ga-anọkwa nʼụlọ ndị Ashkelọn nke tọgbọrọ nʼefu,
\q2 dinaa ala zuru ike nʼoge uhuruchi.
\q1 \nd Onyenwe anyị\nd* Chineke ha ga-elekọta ha,
\q2 mekwaa ka ha nwetaghachi ihe nketa ha niile.
\s2 Ahụhụ dịrị Moab na Amọn
\q1 
\v 8 “Anụla m okwu ọjọọ niile, nke ndị Moab,
\q2 na ịkwa emo niile nke ndị Amọn,
\q1 nụkwa ịbasị mba ike ha megide ndị nke m
\q2 na-anya isi na ha ga-ewere ala ha.
\q1 
\v 9 Nʼihi ya, dịka m na-adị ndụ,”
\q2 otu a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile,
\q2 bụ Chineke Izrel, kwubiri ya,
\q1 “aghaghị m ime ka Moab dịrị ka Sọdọm,
\q2 mekwaa ka Amọn dịka Gọmọra.
\q1 Ha ga-aghọ ala ebe ahịhịa na-adụ ogwu ogwu na-eru, ebe olulu nnu jupụtara,
\q2 na ebe tọgbọrọ nʼefu ruo mgbe ebighị ebi.
\q1 Ndị m, ndị fọdụrụ ga-akwakọrọ akụnụba ha,
\q2 ndị fọdụrụ ndụ na mba m ga-eketa ala ha.”
\b
\q1 
\v 10 Ihe ndị a bụ ụgwọ ọrụ ha ga-anata nʼihi ịnya isi ha,
\q2 na nʼihi nkọcha na ịkwa emo ha megide
\q2 ndị nke \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile.
\q1 
\v 11 Onye dị egwu ka \nd Onyenwe anyị\nd* ga-abụ nʼebe ha nọ,
\q2 mgbe ọ lara chi niile nke ụwa nʼiyi.
\q1 Mba niile dị nʼebe dị anya ga-akpọ isiala nye ya,
\q2 onye ọbụla nʼala nke aka ya nʼụwa niile.
\s2 Ahụhụ dịrị Kush
\q1 
\v 12 “Unu ndị Itiopia,\f + \fr 2:12 \ft Maọbụ, \fqa Kush\f*
\q2 a ghaghị iji mma agha gbuo unu.”
\s2 Ahụhụ dịrị Asịrịa
\q1 
\v 13 Ọ ga-esetipụ aka ya megide ndị bi nʼakụkụ ugwu,
\q2 laa Asịrịa nʼiyi.
\q1 Ninive ga-aghọ ebe tọgbọrọ nʼefu,
\q2 ọ ga-aghọkwa ala kpọrọ nkụ, dịka ọzara.
\q1 
\v 14 Igwe anụmanụ dị iche iche na igwe ehi ga-amakpu nʼebe ahụ,
\q2 ha na ihe e kere eke dị iche iche.
\q1 Ikwighịkwighị nke ọzara na okwolo
\q2 ga-anọ ọnọdụ abalị nʼisi ogidi ya niile ahụ.
\q1 Ụda olu ha ka a ga-anụ site na mpio-ikuku,
\q2 mkpọmkpọ aja ga-adị na mbata nke ọnụ ụzọ niile,
\q2 ibo ọnụ ụzọ niile e ji osisi sida mee ga-egherekwa oghe.
\q1 
\v 15 Nke a bụ obodo ukwu ahụ, nke na-aṅụrị ọṅụ oriri,
\q2 nke na-ebikwa na-enweghị ihe egwu ọbụla;
\q1 nke na-asị onwe ya,
\q2 “Ọ bụ mụ onwe m! Ọ dịghị onye ọzọ ma ewezuga m.”
\q1 Ma ugbu a, lee otu o si bụrụ ebe tọgbọrọ nʼefu;
\q2 lee ka o si bụrụ ebe ụmụ anụ ọhịa bi.
\q1 Onye ọbụla si nʼakụkụ ya na-agafe aghaghị ịma ọsụ,
\q2 ma fufekwaa isi ya.
\c 3
\s2 Ọdịnihu Jerusalem
\q1 
\v 1 Ahụhụ dịrị obodo ahụ ndị mmegbu,
\q2 na ndị na-enupu isi, na ndị rụrụ arụ jupụtara nʼime ya.
\q1 
\v 2 Ọ naghị ege onye ọbụla ntị,
\q2 ọ dịghị anabata ịdọ aka na ntị.
\q1 Ọ dịghị atụkwasị \nd Onyenwe anyị\nd* obi,
\q2 ọ dịkwaghị abịakwute Chineke ya nso.
\q1 
\v 3 Ndịisi nọ nʼetiti ya
\q2 dịka ọdụm na-agbọ ụja,
\q1 ndị ọkaikpe ya dịka nkịta ọhịa na-achụ nta anyasị,
\q2 nke ihe ọ chụtara na nta adịghị anọ tutu chi abọọ.
\q1 
\v 4 Ndị amụma ya bụ ndị ndu rụrụ arụ,
\q2 ha bụkwa ndị aghụghọ.
\q1 Ndị nchụaja ya na-emerụ ebe nsọ
\q2 na-ejikwa ike emebi iwu.
\q1 
\v 5 Ma \nd Onyenwe anyị\nd*, onye nọ nʼetiti ya bụ onye ezi omume.
\q2 Ọ nakwaghị eme ihe ọjọọ.\f + \fr 3:5 \ft Maọbụ, \fqa ihe na-ezighị ezi\f*
\q1 Ụtụtụ niile ka ọ na-eme ka ikpe ziri ezi ya pụta ìhè;
\q2 ụbọchị ọbụla ọ naghị ahapụ igosi ya,
\q2 ma ndị ajọ omume enweghị ihere.
\s2 Jerusalem anọgide na nnupu isi
\q1 
\v 6 “Egbuchapụla m mba niile dị iche iche,
\q2 kwatukwaa ebe ha niile e wusiri ike.
\q1 Ahapụla m okporoụzọ ha ka ọ bụrụ ihe a gbahapụrụ agbahapụ,\f + \fr 3:6 \ft Ya bụ, nʼụzọ niile dere duu\f*
\q2 ọ dịkwaghị onye na-esi na ha agabiga.
\q1 A laala obodo ha niile nʼiyi,
\q2 ọ dịkwaghị onye fọdụrụ, ọ bụladị otu onye.
\q1 
\v 7 Asịrị m, banyere Jerusalem,
\q2 ‘Nʼezie, ị ga-atụ egwu m,
\q2 ma nabatakwa ntụziaka.’\f + \fr 3:7 \ft Ọ gaghị elegharakwa ntụziaka niile m ziri ya anya\f*
\q1 Mgbe ahụ, agaghị ebibi ebe mgbaba ya,
\q2 ma ọ bụkwanụ ntaramahụhụ m niile agaghị abịakwasịkwa ya.
\q1 Ma otu ọ dị, ọ nụrụ ha ọkụ nʼobi ịga nʼihu
\q2 mee omume rụrụ arụ nʼihe niile bụ nke ha mere.
\q1 
\v 8 Nʼihi nke a, cherenụ m,” otu a ka \nd Onyenwe anyị\nd* kwubiri,
\q2 “nʼụbọchị ahụ m ga-ebili ịgba akaebe.\f + \fr 3:8 \ft Ụbọchị m ga-ebili ịkwata ihe\f*
\q1 Mkpebi m bụ ịchịkọta mba niile dị iche iche,
\q2 na ịkpọkọta alaeze niile,
\q1 ịwụkwasị ha oke iwe m,
\q2 ọ bụladị ọnụma niile nke iwe m.
\q1 Ọkụ, nke iwe si nʼekworo m,
\q2 ka a ga-eji rechapụ ụwa niile.
\s1 Nlọghachi nke ụmụ Izrel ndị fọdụrụ
\q1 
\v 9 “Mgbe ahụ, aga m anụcha egbugbere ọnụ\f + \fr 3:9 \ft Maọbụ, \fqa gbanwee okwu ha\f* ndị niile dị iche iche mee ka ọ bụrụ ihe dị ọcha,
\q2 ka ha niile nwee ike ịkpọku aha \nd Onyenwe anyị\nd*,
\q2 ma jikọta aka fekwaa ya ofufe.
\q1 
\v 10 Site nʼofe osimiri niile nke Kush,\f + \fr 3:10 \ft Maọbụ, \fqa Itiopia\f*
\q2 bụ ndị m a chụsasịrị achụsasị, ndị na-akpọ isiala nye m,
\q2 ga-ewetara m onyinye dị iche iche.
\q1 
\v 11 Nʼụbọchị ahụ, gị bụ Jerusalem, agaghị eme ka ihere mee gị,
\q2 nʼihi omume njehie niile i jere megide m,
\q1 nʼihi na aga m esite nʼetiti gị wezuga ndị gị niile
\q2 na-aṅụrị ọṅụ\f + \fr 3:11 \ft Ya bụ, ndị na-anya isi\f* na mpako ha.
\q1 A gaghị ahụkwa ndị na-afụli onwe ha elu
\q2 nʼugwu nsọ m.
\q1 
\v 12 Ma aga m eme ka ndị dị nwayọọ nʼobi,
\q2 na ndị dị umeala nʼobi
\q1 fọdụ nʼetiti ndị Izrel,
\q2 ha ga-agbabakwa\f + \fr 3:12 \ft Ya bụ, tụkwasị obi\f* nʼaha \nd Onyenwe anyị\nd*.
\q1 
\v 13 Ha agaghị emekwa ihe ọjọọ,
\q2 ha agaghị ekwu okwu ụgha.
\q1 Ire na-ekwu okwu aghụghọ
\q2 agaghị adịkwa nʼọnụ ha.
\q1 Ha ga-akpa nri ma dinakwa ala,
\q2 ọ dịkwaghị onye ga-eme ka ha tụọ egwu.”
\b
\q1 
\v 14 Bụọ abụ, gị nwaada Zayọn;
\q2 tie mkpu, gị Izrel.
\q1 Ṅụrịa ọṅụ, e, jiri obi gị niile ṅụrịa ọṅụ,
\q2 gị nwaada Jerusalem.
\q1 
\v 15 Nʼihi na \nd Onyenwe anyị\nd* ewezugala ahụhụ dịrị gị,
\q2 chụghachikwa ndị iro gị azụ.
\q1 \nd Onyenwe anyị\nd*, onye bụ Eze Izrel, nọ nʼetiti gị.
\q2 Ị gaghị atụkwa egwu ihe ọjọọ ọzọ.
\q1 
\v 16 Nʼụbọchị ahụ,
\q2 ihe a ga-agwa Jerusalem ga-abụ,
\q1 “Atụla egwu, gị Zayọn,
\q2 ekwela ka aka gị daa mba.
\q1 
\v 17 \nd Onyenwe anyị\nd* bụ Chineke gị nọ nʼetiti gị,
\q2 ọ bụ Dike nʼagha nke na-enye mmeri.
\q1 Ọ ga-eji ọṅụ nwee mmasị na ahụ gị;
\q2 nʼihi ịhụnanya ya, ọ gaghị abakwara gị mba,\f + \fr 3:17 \ft Maọbụ, \fqa ọ ga-eme ka ịdị ọhụrụ\f*
\q2 kama ọ ga-eji oke iti mkpu abụ ṅụrịa ọṅụ nʼebe ị nọ.”
\b
\q1 
\v 18 “Nʼụbọchị mmemme a kara aka,
\q2 aga m ewepụrụ gị ọdachi iru ụjụ,
\q2 nke bụ ibu arụ na ihe ịta ụta dịrị gị.
\q1 
\v 19 Nʼoge ahụ,
\q2 aga m emesi ndị ahụ niile na-emegbu gị ike.
\q1 Aga m azọpụta ndị ụkwụ rụrụ,
\q2 chịkọtakwa ndị niile e mere ka ha gaa biri nʼala ndị ọzọ.
\q1 Aga m agbanwe ihere ha ka ọ bụrụ ihe otuto
\q2 nʼihe na-ewu ewu nʼụwa ebe ha natara ihere.
\q1 
\v 20 Nʼoge ahụ, aga m akpọlata unu nʼụlọ;
\q2 mgbe m ga-akpọkọta unu ọnụ.
\q1 Aga m eme ka unu na-ewu ewu
\q2 ka unu nwekwaa otuto nʼetiti mmadụ niile bi nʼụwa,
\q1 mgbe m ga-eweghachi ihe ọma unu
\q2 nʼihu anya unu.”
\q2 Ka \nd Onyenwe anyị\nd* kwuru.
