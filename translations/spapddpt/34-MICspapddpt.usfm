\id MIC
\h Miqueas
\toc3 Miq
\toc2 Miqueas
\toc1 Miqueas
\mt1 Miqueas
\c 1
\s1 La visión
\p 
\v 1 \w La|strong="H5921"\w* \w Palabra|strong="H1697"\w* \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w que|strong="H5921"\w* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* Miqueas \w de|strong="H5921"\w* Moreset, \w en|strong="H5921"\w* \w días|strong="H3117"\w* \w de|strong="H5921"\w* Jotam, Acaz \w y|strong="H5921"\w* Ezequías, \w reyes|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*, \w lo|strong="H1697"\w* \w que|strong="H5921"\w* \w vio|strong="H2372"\w* \w sobre|strong="H5921"\w* \w Samaria|strong="H8111"\w* \w y|strong="H5921"\w* Jerusalén.
\s1 Contra la Casa de Israel
\p 
\v 2 ¡\w Escuchen|strong="H8085"\w*, \w pueblos|strong="H5971"\w* \w todos|strong="H3605"\w*! \w Atiende|strong="H7181"\w*, oh tierra, y \w lo|strong="H3605"\w* \w que|strong="H5971"\w* \w hay|strong="H1961"\w* en ti. \w Sea|strong="H1961"\w* \nd ʼAdonay \w Yavé|strong="H3068"\w*\nd* \w Testigo|strong="H5707"\w* \w contra|strong="H1961"\w* ustedes, desde su \w santo|strong="H6944"\w* \w Templo|strong="H1964"\w*.
\v 3 \w Porque|strong="H3588"\w* miren: \nd \w Yavé|strong="H3068"\w*\nd* \w sale|strong="H3318"\w* \w de|strong="H5921"\w* \w su|strong="H3588"\w* \w lugar|strong="H4725"\w*, \w descenderá|strong="H3381"\w* \w y|strong="H3588"\w* caminará \w sobre|strong="H5921"\w* \w las|strong="H5921"\w* alturas \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra.
\v 4 Las montañas se derretirán \w debajo|strong="H8478"\w* \w de|strong="H8478"\w* Él \w como|strong="H8478"\w* cera junto \w al|strong="H8478"\w* fuego. Los \w valles|strong="H6010"\w* se hendirán \w como|strong="H8478"\w* \w agua|strong="H4325"\w* derramada sobre una pendiente.
\p 
\v 5 \w Todo|strong="H3605"\w* \w esto|strong="H2063"\w* sucederá por \w la|strong="H3605"\w* transgresión de \w Jacob|strong="H3290"\w* y por \w los|strong="H3605"\w* \w pecados|strong="H2403"\w* de \w la|strong="H3605"\w* \w Casa|strong="H1004"\w* de \w Israel|strong="H3478"\w*. ¿\w Cuál|strong="H4310"\w* \w es|strong="H2063"\w* \w la|strong="H3605"\w* \w rebelión|strong="H6588"\w* de \w Jacob|strong="H3290"\w*? ¿\w No|strong="H3808"\w* \w es|strong="H2063"\w* \w Samaria|strong="H8111"\w*? ¿\w Y|strong="H3068"\w* \w cuál|strong="H4310"\w* \w es|strong="H2063"\w* \w el|strong="H3605"\w* lugar alto de \w Judá|strong="H3063"\w*? ¿\w No|strong="H3808"\w* \w es|strong="H2063"\w* Jerusalén?
\p 
\v 6 \wj Pues convertiré \w a|strong="H3068"\w* \w Samaria|strong="H8111"\w* en una pila de ruinas en el \w campo|strong="H7704"\w* abierto, tierra para plantar \w viñas|strong="H3754"\w*. Rodaré sus piedras hacia el \w valle|strong="H1516"\w* y dejaré sus cimientos al descubierto.\wj*
\v 7 \wj \w Todos|strong="H3605"\w* sus \w ídolos|strong="H6091"\w* serán destrozados, \w y|strong="H3588"\w* \w todas|strong="H3605"\w* sus ofrendas quemadas. Arrasaré \w todos|strong="H3605"\w* sus \w ídolos|strong="H6091"\w* \w porque|strong="H3588"\w* \w los|strong="H3605"\w* obtuvo \w como|strong="H3588"\w* regalos \w de|strong="H3588"\w* prostitutas, \w y|strong="H3588"\w* \w volverán|strong="H7725"\w* \w a|strong="H3068"\w* regalos \w de|strong="H3588"\w* prostitutas. \wj*
\p 
\v 8 \w Por|strong="H5921"\w* \w eso|strong="H2063"\w* \w tengo|strong="H5921"\w* \w que|strong="H5921"\w* lamentar \w y|strong="H5921"\w* gemir, \w andar|strong="H3212"\w* descalzo \w y|strong="H5921"\w* \w desnudo|strong="H6174"\w* \w y|strong="H5921"\w* \w hacer|strong="H6213"\w* un lamento \w como|strong="H5921"\w* \w los|strong="H5921"\w* chacales \w y|strong="H5921"\w* un quejido \w como|strong="H5921"\w* \w los|strong="H5921"\w* avestruces.
\v 9 \w Porque|strong="H3588"\w* \w su|strong="H3588"\w* \w llaga|strong="H4347"\w* \w es|strong="H3588"\w* incurable. \w Llegó|strong="H5060"\w* \w a|strong="H3068"\w* \w Judá|strong="H3063"\w* \w porque|strong="H3588"\w* \w llegó|strong="H5060"\w* \w hasta|strong="H5704"\w* \w la|strong="H3588"\w* \w puerta|strong="H8179"\w* \w de|strong="H3588"\w* \w mi|strong="H3389"\w* \w pueblo|strong="H5971"\w*, \w a|strong="H3068"\w* Jerusalén.
\v 10 No lo anuncien en Gat, ni se entreguen al llanto. ¡\w Revuélcate|strong="H6428"\w* en el \w polvo|strong="H6083"\w* en Bet-le-afrá!
\p 
\v 11 ¡\w Pasa|strong="H5674"\w* \w en|strong="H4480"\w* vergonzosa desnudez, oh habitante \w de|strong="H4480"\w* Safir! \w El|strong="H5674"\w* habitante \w de|strong="H4480"\w* Saanán \w no|strong="H3808"\w* \w sale|strong="H3318"\w*. Bet-esel llora y \w te|strong="H4480"\w* \w quita|strong="H5674"\w* su apoyo.
\v 12 \w El|strong="H3588"\w* habitante \w de|strong="H3588"\w* Marot anhela ansiosamente \w el|strong="H3588"\w* \w bien|strong="H2896"\w*, \w pues|strong="H3588"\w* \w de|strong="H3588"\w* parte \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* bajó \w el|strong="H3588"\w* \w mal|strong="H7451"\w* hasta \w la|strong="H3588"\w* \w puerta|strong="H8179"\w* \w de|strong="H3588"\w* Jerusalén.
\v 13 ¡Ata \w el|strong="H1931"\w* carruaje \w a|strong="H3068"\w* veloces corceles, oh habitante \w de|strong="H3588"\w* Laquis! Allí comenzó \w el|strong="H1931"\w* \w pecado|strong="H2403"\w* \w de|strong="H3588"\w* \w la|strong="H1931"\w* \w hija|strong="H1323"\w* \w de|strong="H3588"\w* \w Sion|strong="H6726"\w*. Allí \w se|strong="H1931"\w* \w hallaron|strong="H4672"\w* las transgresiones \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*.
\v 14 \w Por|strong="H5921"\w* \w tanto|strong="H3651"\w*, ustedes \w darán|strong="H5414"\w* regalos \w a|strong="H3068"\w* Moreset-gat, \w pues|strong="H3651"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* Aczib defraudó \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w reyes|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.
\v 15 \w Además|strong="H5750"\w*, oh habitante \w de|strong="H5750"\w* \w Maresa|strong="H4762"\w*, traeré sobre ti \w al|strong="H5704"\w* \w que|strong="H5704"\w* toma posesión, \w y|strong="H5704"\w* la nobleza \w de|strong="H5750"\w* \w Israel|strong="H3478"\w* se refugiará \w en|strong="H5704"\w* Adulam.
\v 16 ¡Rápate \w y|strong="H3588"\w* trasquílate \w por|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* tus delicias! \w Ensancha|strong="H7337"\w* tu calva \w como|strong="H3588"\w* \w la|strong="H5921"\w* \w del|strong="H4480"\w* buitre, \w porque|strong="H3588"\w* \w se|strong="H5921"\w* irán \w de|strong="H4480"\w* \w ti|strong="H5921"\w* \w en|strong="H5921"\w* cautiverio.
\c 2
\s1 Riquezas y opresión
\p 
\v 1 ¡\w Ay|strong="H1945"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w que|strong="H3588"\w* planean \w maldades|strong="H7451"\w* \w y|strong="H3588"\w* traman iniquidad \w en|strong="H5921"\w* sus \w camas|strong="H4904"\w*! ¡\w Cuando|strong="H3588"\w* llega \w la|strong="H5921"\w* \w mañana|strong="H1242"\w* \w las|strong="H5921"\w* ejecutan \w con|strong="H5921"\w* \w el|strong="H5921"\w* \w poder|strong="H3027"\w* \w que|strong="H3588"\w* \w tienen|strong="H3426"\w* \w en|strong="H5921"\w* \w su|strong="H3588"\w* \w mano|strong="H3027"\w*!
\v 2 Codician \w campos|strong="H7704"\w* y los \w roban|strong="H1497"\w*. Codician \w casas|strong="H1004"\w* y se las \w llevan|strong="H5375"\w*. \w Roban|strong="H1497"\w* al \w hombre|strong="H1397"\w*, su \w familia|strong="H1004"\w* y su \w heredad|strong="H5159"\w*.
\p 
\v 3 \w Por|strong="H5921"\w* \w tanto|strong="H3651"\w*, \nd \w Yavé|strong="H3068"\w*\nd* dice: \wj \w Ahora|strong="H3541"\w* \w ciertamente|strong="H3588"\w* \w Yo|strong="H3588"\w* traigo una calamidad \w contra|strong="H5921"\w* \w esta|strong="H2063"\w* \w familia|strong="H4940"\w* \w de|strong="H5921"\w* \w la|strong="H1931"\w* \w cual|strong="H1931"\w* ustedes \w no|strong="H3808"\w* podrán apartar \w sus|strong="H1931"\w* cuellos, \w ni|strong="H3808"\w* \w andar|strong="H3212"\w* \w con|strong="H5921"\w* arrogancia. \w Porque|strong="H3588"\w* \w será|strong="H1931"\w* un \w tiempo|strong="H6256"\w* \w de|strong="H5921"\w* calamidad. \wj*
\v 4 \wj \w Aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w se|strong="H1931"\w* levantará una mofa \w contra|strong="H5921"\w* ustedes, un amargo lamento \w y|strong="H5921"\w* dirán: ¡Somos completamente destruidos! \w Él|strong="H1931"\w* cambió \w la|strong="H1931"\w* \w heredad|strong="H7704"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w pueblo|strong="H5971"\w*. ¡\w Cómo|strong="H5921"\w* \w me|strong="H5921"\w* \w la|strong="H1931"\w* quitó! \w A|strong="H3068"\w* \w los|strong="H5921"\w* infieles distribuyó \w mis|strong="H5375"\w* \w campos|strong="H7704"\w*.\wj*
\p 
\v 5 \w Por|strong="H3651"\w* \w tanto|strong="H3651"\w*, ya \w no|strong="H3808"\w* \w habrá|strong="H1961"\w* en la \w congregación|strong="H6951"\w* de \nd \w Yavé|strong="H3068"\w*\nd* quien \w eche|strong="H7993"\w* la cuerda \w para|strong="H1961"\w* medir una posesión.
\v 6 Dicen \w a|strong="H3068"\w* los \w que|strong="H3808"\w* profetizan: ¡\w No|strong="H3808"\w* profeticen! Así la \w afrenta|strong="H3639"\w* \w no|strong="H3808"\w* nos alcanzará.
\p 
\v 7 \wj \w Se|strong="H3808"\w* \w dice|strong="H1697"\w*, oh \w casa|strong="H1004"\w* \w de|strong="H5973"\w* \w Jacob|strong="H3290"\w*: ¿\w El|strong="H5973"\w* \w Espíritu|strong="H7307"\w* \w de|strong="H5973"\w* \nd \w Yavé|strong="H3068"\w*\nd* está impaciente? ¿\w Son|strong="H3808"\w* éstas sus \w obras|strong="H4611"\w*? ¿Mis \w palabras|strong="H1697"\w* \w no|strong="H3808"\w* hacen \w bien|strong="H3190"\w* al \w que|strong="H3808"\w* \w anda|strong="H1980"\w* rectamente?\wj*
\v 8 \wj Recientemente mi \w pueblo|strong="H5971"\w* \w se|strong="H5971"\w* alzó \w como|strong="H8008"\w* un enemigo. Hoy despojan del manto y la ropa al \w que|strong="H5971"\w* transita confiado, \w a|strong="H3068"\w* los \w que|strong="H5971"\w* regresaron \w de|strong="H5971"\w* la \w guerra|strong="H4421"\w*.\wj*
\v 9 \wj Echan \w a|strong="H3068"\w* \w las|strong="H5921"\w* mujeres \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w pueblo|strong="H5971"\w* fuera \w del|strong="H5921"\w* calor \w de|strong="H5921"\w* sus hogares \w y|strong="H5921"\w* despojan \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w gloria|strong="H1926"\w* \w a|strong="H3068"\w* sus hijos \w para|strong="H5921"\w* \w siempre|strong="H5769"\w*.\wj*
\v 10 \wj \w Levántense|strong="H6965"\w* \w y|strong="H3588"\w* caminen, \w porque|strong="H3588"\w* \w éste|strong="H2063"\w* \w no|strong="H3808"\w* \w es|strong="H3588"\w* lugar \w de|strong="H3588"\w* \w reposo|strong="H4496"\w*, \w pues|strong="H3588"\w* \w está|strong="H2063"\w* \w contaminado|strong="H2930"\w* \w a|strong="H3068"\w* causa \w de|strong="H3588"\w* \w la|strong="H3588"\w* impureza \w que|strong="H3588"\w* trae una penosa destrucción.\wj*
\v 11 \wj \w Si|strong="H3863"\w* \w viene|strong="H1980"\w* un hombre con \w espíritu|strong="H7307"\w* \w de|strong="H5971"\w* falsedad, miente y dice: Profetizo \w que|strong="H5971"\w* \w tendrán|strong="H1961"\w* \w vino|strong="H3196"\w* y mosto fermentado \w de|strong="H5971"\w* manzana, ¡\w Ése|strong="H2088"\w* \w será|strong="H1961"\w* el \w profeta|strong="H5197"\w* \w de|strong="H5971"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w*! \wj*
\p 
\v 12 \wj ¡\w Ciertamente|strong="H6908"\w* reuniré \w a|strong="H3068"\w* \w todos|strong="H3605"\w*, oh \w Jacob|strong="H3290"\w*! \w Ciertamente|strong="H6908"\w* congregaré al remanente de \w Israel|strong="H3478"\w*. \w Los|strong="H3605"\w* reuniré como \w ovejas|strong="H6629"\w* \w en|strong="H8432"\w* \w el|strong="H3605"\w* redil, como \w un|strong="H3162"\w* \w rebaño|strong="H6629"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* del pastizal. \w Harán|strong="H7760"\w* mucho ruido \w por|strong="H1949"\w* causa de \w la|strong="H3605"\w* multitud de gente. \wj*
\v 13 \wj \w El|strong="H5674"\w* que abre caminos \w va|strong="H3068"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ellos, irrumpen, \w pasan|strong="H5674"\w* \w por|strong="H6440"\w* la \w puerta|strong="H8179"\w* y \w salen|strong="H3318"\w*. Su \w rey|strong="H4428"\w* \w va|strong="H3068"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ellos, y \w a|strong="H3068"\w* la \w cabeza|strong="H7218"\w* está \nd \w Yavé|strong="H3068"\w*\nd*. \wj*
\c 3
\s1 La ruina de Israel
\p 
\v 1 \w Y|strong="H3068"\w* dije: Les \w ruego|strong="H4994"\w* \w que|strong="H3808"\w* \w escuchen|strong="H8085"\w* \w ahora|strong="H4994"\w*, \w jefes|strong="H7218"\w* de \w Jacob|strong="H3290"\w* y gobernantes de la \w Casa|strong="H1004"\w* de \w Israel|strong="H3478"\w*: ¿\w No|strong="H3808"\w* corresponde \w a|strong="H3068"\w* ustedes conocer \w justicia|strong="H4941"\w*?
\v 2 Ustedes, \w que|strong="H5921"\w* \w aborrecen|strong="H8130"\w* \w el|strong="H5921"\w* \w bien|strong="H2896"\w* \w y|strong="H5921"\w* aman \w el|strong="H5921"\w* \w mal|strong="H7451"\w*, \w que|strong="H5921"\w* \w les|strong="H5921"\w* arrancan \w la|strong="H5921"\w* \w piel|strong="H5785"\w* \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w carne|strong="H7607"\w* \w de|strong="H5921"\w* sus \w huesos|strong="H6106"\w*,
\v 3 \w que|strong="H5921"\w* comen \w la|strong="H5921"\w* \w carne|strong="H1320"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w pueblo|strong="H5971"\w*, desollan su \w piel|strong="H5785"\w*, \w les|strong="H5921"\w* quiebran sus \w huesos|strong="H6106"\w* \w y|strong="H5921"\w* \w los|strong="H5921"\w* cortan \w como|strong="H5921"\w* \w carne|strong="H1320"\w* \w para|strong="H5921"\w* \w el|strong="H5921"\w* caldero \w y|strong="H5921"\w* \w para|strong="H5921"\w* \w la|strong="H5921"\w* \w olla|strong="H5518"\w*.
\p 
\v 4 \w Entonces|strong="H6256"\w* claman \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*, pero \w Él|strong="H1931"\w* \w no|strong="H3808"\w* \w responderá|strong="H6030"\w*. Esconderá \w su|strong="H1931"\w* \w rostro|strong="H6440"\w* en \w ese|strong="H1931"\w* \w tiempo|strong="H6256"\w*, \w porque|strong="H3808"\w* \w hicieron|strong="H7489"\w* \w obras|strong="H4611"\w* perversas.
\p 
\v 5 \nd \w Yavé|strong="H3068"\w*\nd* dice \w esto|strong="H3541"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w profetas|strong="H5030"\w* \w que|strong="H3808"\w* extravían \w a|strong="H3068"\w* \w mi|strong="H5921"\w* \w pueblo|strong="H5971"\w*, \w que|strong="H3808"\w* muerden \w con|strong="H5921"\w* sus \w dientes|strong="H8127"\w*, proclaman \w paz|strong="H7965"\w* \w y|strong="H5921"\w* \w al|strong="H5921"\w* \w que|strong="H3808"\w* \w nada|strong="H3808"\w* pone \w en|strong="H5921"\w* sus \w bocas|strong="H6310"\w* \w le|strong="H5921"\w* declaran \w guerra|strong="H4421"\w* santa.
\v 6 \wj \w Por|strong="H5921"\w* \w tanto|strong="H3651"\w*, una \w noche|strong="H3915"\w* sin brujería caerá \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* \w profetas|strong="H5030"\w*, \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w día|strong="H3117"\w* será oscuro \w para|strong="H5921"\w* \w ellos|strong="H5921"\w*. \w El|strong="H5921"\w* \w sol|strong="H8121"\w* \w se|strong="H5921"\w* ocultará \w para|strong="H5921"\w* \w el|strong="H5921"\w* \w profeta|strong="H5030"\w*, \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w día|strong="H3117"\w* será oscuro \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w*.\wj*
\v 7 \wj \w Los|strong="H5921"\w* \w videntes|strong="H2374"\w* serán avergonzados, \w los|strong="H5921"\w* \w adivinos|strong="H7080"\w* confundidos. \w Todos|strong="H3605"\w* \w ellos|strong="H5921"\w* tendrán \w su|strong="H3588"\w* boca cerrada \w porque|strong="H3588"\w* \w no|strong="H3588"\w* hay \w respuesta|strong="H4617"\w* \w de|strong="H5921"\w* \nd ʼElohim\nd*.\wj*
\p 
\v 8 Pero yo estoy \w lleno|strong="H4390"\w* de \w poder|strong="H3581"\w* del \w Espíritu|strong="H7307"\w* de \nd \w Yavé|strong="H3068"\w*\nd*, de \w justicia|strong="H4941"\w* y de valor, para declarar \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w* su \w rebelión|strong="H6588"\w* y \w a|strong="H3068"\w* \w Israel|strong="H3478"\w* su \w pecado|strong="H2403"\w*.
\v 9 Escúchenme \w esto|strong="H2063"\w*, \w jefes|strong="H7218"\w* de \w la|strong="H2063"\w* \w casa|strong="H1004"\w* de \w Jacob|strong="H3290"\w*, gobernantes de \w la|strong="H2063"\w* \w Casa|strong="H1004"\w* de \w Israel|strong="H3478"\w*, ustedes quienes aborrecen \w la|strong="H2063"\w* \w justicia|strong="H4941"\w* y pervierten \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w que|strong="H4994"\w* \w es|strong="H2063"\w* equidad,
\v 10 que \w edifican|strong="H1129"\w* \w a|strong="H3068"\w* \w Sion|strong="H6726"\w* con \w sangre|strong="H1818"\w* derramada y \w a|strong="H3068"\w* Jerusalén con \w iniquidad|strong="H5766"\w*:
\v 11 Sus magistrados \w juzgan|strong="H8199"\w* \w por|strong="H5921"\w* \w soborno|strong="H7810"\w*, sus \w sacerdotes|strong="H3548"\w* \w enseñan|strong="H3384"\w* \w por|strong="H5921"\w* \w la|strong="H5921"\w* paga, sus \w profetas|strong="H5030"\w* \w adivinan|strong="H7080"\w* \w por|strong="H5921"\w* \w dinero|strong="H3701"\w*, \w se|strong="H5921"\w* apoyan \w en|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w y|strong="H5921"\w* dicen: ¿\w No|strong="H3808"\w* \w está|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w en|strong="H5921"\w* \w medio|strong="H7130"\w* \w de|strong="H5921"\w* \w nosotros|strong="H5921"\w*? ¡\w No|strong="H3808"\w* vendrá \w mal|strong="H7451"\w* \w sobre|strong="H5921"\w* \w nosotros|strong="H5921"\w*!
\v 12 \w Por|strong="H3651"\w* \w tanto|strong="H3651"\w*, \w por|strong="H3651"\w* causa de ustedes, \w Sion|strong="H6726"\w* \w será|strong="H1961"\w* \w arada|strong="H2790"\w* \w como|strong="H1961"\w* un \w campo|strong="H7704"\w*, Jerusalén \w será|strong="H1961"\w* una pila de ruinas, y la Montaña del \w Templo|strong="H1004"\w* \w como|strong="H1961"\w* colinas de escaso \w bosque|strong="H3293"\w*.
\c 4
\s1 El reino del Mesías
\p 
\v 1 \w Acontecerá|strong="H1961"\w* \w en|strong="H5921"\w* \w los|strong="H5921"\w* últimos \w días|strong="H3117"\w* \w que|strong="H1931"\w* \w la|strong="H1931"\w* Montaña \w de|strong="H5921"\w* \w la|strong="H1931"\w* \w Casa|strong="H1004"\w* \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w será|strong="H1961"\w* establecida \w como|strong="H1961"\w* \w cabeza|strong="H7218"\w* \w de|strong="H5921"\w* \w las|strong="H5921"\w* montañas \w y|strong="H5921"\w* exaltada \w sobre|strong="H5921"\w* \w las|strong="H5921"\w* colinas. \w Los|strong="H5921"\w* \w pueblos|strong="H5971"\w* correrán \w a|strong="H3068"\w* \w ella|strong="H1931"\w*.
\v 2 \w Muchas|strong="H7227"\w* \w naciones|strong="H1471"\w* \w irán|strong="H3212"\w* allí \w y|strong="H3588"\w* dirán: \w Vengan|strong="H5927"\w*, \w subamos|strong="H5927"\w* \w a|strong="H3068"\w* \w la|strong="H3588"\w* Montaña \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w Casa|strong="H1004"\w* del \nd ʼElohim\nd* \w de|strong="H3588"\w* \w Jacob|strong="H3290"\w*. \w Él|strong="H3588"\w* nos \w enseñará|strong="H3384"\w* sus \w caminos|strong="H1870"\w*, \w y|strong="H3588"\w* nosotros \w andaremos|strong="H3212"\w* \w en|strong="H3588"\w* sus sendas. \w Porque|strong="H3588"\w* \w la|strong="H3588"\w* \w Ley|strong="H8451"\w* \w saldrá|strong="H3318"\w* \w de|strong="H3588"\w* \w Sion|strong="H6726"\w*, \w y|strong="H3588"\w* \w de|strong="H3588"\w* Jerusalén, \w la|strong="H3588"\w* \w Palabra|strong="H1697"\w* \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\v 3 Él \w juzgará|strong="H8199"\w* \w entre|strong="H3808"\w* \w muchos|strong="H7227"\w* \w pueblos|strong="H5971"\w* \w y|strong="H5704"\w* decidirá \w para|strong="H5704"\w* \w naciones|strong="H1471"\w* poderosas \w y|strong="H5704"\w* distantes. Convertirán sus \w espadas|strong="H2719"\w* \w en|strong="H5704"\w* arados \w y|strong="H5704"\w* sus lanzas \w en|strong="H5704"\w* podaderas. \w No|strong="H3808"\w* levantará \w espada|strong="H2719"\w* \w nación|strong="H1471"\w* contra \w nación|strong="H1471"\w*, \w ni|strong="H3808"\w* \w se|strong="H3808"\w* adiestrarán \w más|strong="H5750"\w* \w para|strong="H5704"\w* la \w guerra|strong="H4421"\w*.
\v 4 Cada uno se sentará \w debajo|strong="H8478"\w* \w de|strong="H3588"\w* \w su|strong="H3588"\w* \w vid|strong="H1612"\w* \w y|strong="H3588"\w* \w de|strong="H3588"\w* \w su|strong="H3588"\w* higuera. \w No|strong="H3588"\w* habrá quién \w los|strong="H3427"\w* atemorice, \w porque|strong="H3588"\w* \w habló|strong="H1696"\w* \w la|strong="H3588"\w* \w boca|strong="H6310"\w* \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w de|strong="H3588"\w* las huestes.
\p 
\v 5 \w Aunque|strong="H3588"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w pueblos|strong="H5971"\w* caminan, \w cada|strong="H3605"\w* uno \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w nombre|strong="H8034"\w* \w de|strong="H3588"\w* \w su|strong="H3588"\w* \tl ʼelohim\tl*, \w nosotros|strong="H3605"\w* caminaremos \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w nombre|strong="H8034"\w* \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd*, nuestro \add \nd ʼElohim\nd*\add* \w para|strong="H3588"\w* \w siempre|strong="H5769"\w* \w jamás|strong="H5769"\w*.
\p 
\v 6 \wj En \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* reuniré \w a|strong="H3068"\w* \w la|strong="H1931"\w* \w que|strong="H1931"\w* cojea, traeré \w a|strong="H3068"\w* \w la|strong="H1931"\w* descarriada y \w a|strong="H3068"\w* aquellas \w que|strong="H1931"\w* afligí, \wj*\w dice|strong="H5002"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\v 7 \wj \w Haré|strong="H7760"\w* un remanente \w con|strong="H5921"\w* \w las|strong="H5921"\w* \w que|strong="H6258"\w* cojean, \w y|strong="H5921"\w* una \w nación|strong="H1471"\w* poderosa \w con|strong="H5921"\w* \w las|strong="H5921"\w* descarriadas. \nd \w Yavé|strong="H3068"\w*\nd* \w reinará|strong="H4427"\w* \w sobre|strong="H5921"\w* \w ellas|strong="H5921"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* Montaña \w Sion|strong="H6726"\w* \w desde|strong="H5704"\w* entonces \w y|strong="H5921"\w* \w para|strong="H5704"\w* \w siempre|strong="H5769"\w*. \wj*
\v 8 \wj \w Y|strong="H3068"\w* tú, oh \w torre|strong="H4026"\w* del rebaño, fortaleza \w de|strong="H5704"\w* la \w hija|strong="H1323"\w* \w de|strong="H5704"\w* \w Sion|strong="H6726"\w*, \w a|strong="H3068"\w* ti llegará, sí, \w a|strong="H3068"\w* ti viene el dominio anterior, el \w reino|strong="H4467"\w* \w de|strong="H5704"\w* la ciudad \w de|strong="H5704"\w* Jerusalén. \wj*
\p 
\v 9 \w Y|strong="H3068"\w* \w ahora|strong="H6258"\w*, ¿\w por|strong="H3588"\w* \w qué|strong="H3588"\w* \w gritas|strong="H7452"\w* tanto? ¿\w No|strong="H3588"\w* hay \w rey|strong="H4428"\w* \w en|strong="H3588"\w* ti? ¿Pereció tu \w consejero|strong="H3289"\w*? ¿\w Te|strong="H3588"\w* sorprendió \w el|strong="H3588"\w* \w dolor|strong="H2427"\w* \w como|strong="H4100"\w* \w a|strong="H3068"\w* mujer \w que|strong="H3588"\w* da \w a|strong="H3068"\w* luz?
\v 10 Sufre \w dolor|strong="H2342"\w* \w y|strong="H3588"\w* gime, oh \w hija|strong="H1323"\w* \w de|strong="H3588"\w* \w Sion|strong="H6726"\w*, \w como|strong="H3588"\w* mujer \w que|strong="H3588"\w* da \w a|strong="H3068"\w* luz, \w porque|strong="H3588"\w* \w ahora|strong="H6258"\w* \w saldrás|strong="H3318"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w ciudad|strong="H7151"\w* \w y|strong="H3588"\w* vivirás \w en|strong="H5704"\w* \w el|strong="H3588"\w* \w campo|strong="H7704"\w*. Irás \w a|strong="H3068"\w* Babilonia \w y|strong="H3588"\w* \w allí|strong="H8033"\w* serás librada. \w Allí|strong="H8033"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w te|strong="H3588"\w* \w librará|strong="H5337"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w mano|strong="H3709"\w* \w de|strong="H3588"\w* tus enemigos.
\p 
\v 11 Pero \w ahora|strong="H6258"\w* \w muchas|strong="H7227"\w* \w naciones|strong="H1471"\w* \w se|strong="H5921"\w* reúnen \w contra|strong="H5921"\w* \w ti|strong="H5921"\w* \w y|strong="H5921"\w* dicen: Sea profanada, \w y|strong="H5921"\w* \w vean|strong="H2372"\w* nuestros \w ojos|strong="H5869"\w* \w a|strong="H3068"\w* \w Sion|strong="H6726"\w*.
\v 12 \w Pero|strong="H3588"\w* \w no|strong="H3808"\w* \w conocen|strong="H3045"\w* \w los|strong="H1992"\w* \w pensamientos|strong="H4284"\w* \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w ni|strong="H3808"\w* comprenden \w sus|strong="H1992"\w* \w designios|strong="H4284"\w*, \w por|strong="H3588"\w* \w los|strong="H1992"\w* cuales \w los|strong="H1992"\w* reúne \w como|strong="H3588"\w* gavillas \w en|strong="H3588"\w* \w la|strong="H3588"\w* era.
\p 
\v 13 \wj ¡\w Levántate|strong="H6965"\w* \w y|strong="H3588"\w* trilla, oh \w hija|strong="H1323"\w* \w de|strong="H3588"\w* \w Sion|strong="H6726"\w*! \w Porque|strong="H3588"\w* \w haré|strong="H7760"\w* tu \w cuerno|strong="H7161"\w* \w como|strong="H3588"\w* \w el|strong="H3588"\w* \w hierro|strong="H1270"\w* \w y|strong="H3588"\w* tus cascos \w como|strong="H3588"\w* \w el|strong="H3588"\w* bronce, \w para|strong="H3588"\w* \w que|strong="H3588"\w* destroces \w a|strong="H3068"\w* \w muchos|strong="H7227"\w* \w pueblos|strong="H5971"\w*, \w y|strong="H3588"\w* consagres sus despojos \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w y|strong="H3588"\w* sus \w riquezas|strong="H2428"\w* al \nd ʼAdonay\nd* \w de|strong="H3588"\w* \w toda|strong="H3605"\w* \w la|strong="H3588"\w* tierra. \wj*
\c 5
\s1 El Rey de paz
\p 
\v 1 ¡Reúnete \w ahora|strong="H3117"\w* \w en|strong="H4480"\w* tropas, oh hija \w de|strong="H4480"\w* guerreros! \w Fuimos|strong="H1961"\w* sitiados. \w Con|strong="H4480"\w* vara herirán \w en|strong="H4480"\w* la mejilla \w al|strong="H4480"\w* Juez \w de|strong="H4480"\w* \w Israel|strong="H3478"\w*.
\p 
\v 2 \wj Pero tú, Belén Efrata, pequeña \w para|strong="H5704"\w* estar \w entre|strong="H5921"\w* \w las|strong="H5921"\w* familias \w de|strong="H5921"\w* Judá, \w de|strong="H5921"\w* \w ti|strong="H5921"\w* \w me|strong="H5921"\w* saldrá \w el|strong="H5921"\w* \w que|strong="H5921"\w* \w será|strong="H5414"\w* Gobernante \w en|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w cuyos|strong="H5921"\w* procedimientos son \w desde|strong="H5704"\w* \w el|strong="H5921"\w* \w principio|strong="H5414"\w*, \w desde|strong="H5704"\w* \w los|strong="H1121"\w* días \w de|strong="H5921"\w* \w la|strong="H5921"\w* eternidad. \wj*
\v 3 \w Pero|strong="H3588"\w* \w los|strong="H3427"\w* abandonará \w hasta|strong="H5704"\w* \w el|strong="H3588"\w* tiempo \w cuando|strong="H3588"\w* \w dé|strong="H3588"\w* \w a|strong="H3068"\w* luz \w la|strong="H3588"\w* \w que|strong="H3588"\w* \w va|strong="H3068"\w* \w a|strong="H3068"\w* dar \w a|strong="H3068"\w* luz, \w y|strong="H3588"\w* vuelva \w el|strong="H3588"\w* resto \w de|strong="H3588"\w* sus hermanos \w a|strong="H3068"\w* reunirse \w con|strong="H3588"\w* \w los|strong="H3427"\w* hijos \w de|strong="H3588"\w* Israel.
\v 4 \w Él|strong="H5921"\w* \w se|strong="H1961"\w* \w levantará|strong="H6965"\w* \w y|strong="H3588"\w* \w apacentará|strong="H7462"\w* \w con|strong="H5921"\w* \w el|strong="H5921"\w* poder \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w con|strong="H5921"\w* \w la|strong="H5921"\w* majestad \w del|strong="H5921"\w* Nombre \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w su|strong="H3588"\w* \nd ʼElohim\nd*. \w Ellos|strong="H5921"\w* \w permanecerán|strong="H6965"\w*, \w porque|strong="H3588"\w* \w entonces|strong="H3588"\w* \w serán|strong="H1961"\w* engrandecidos \w hasta|strong="H5921"\w* \w los|strong="H5921"\w* fines \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra.
\p 
\v 5 Éste será nuestra paz. \w Si|strong="H3588"\w* Asiria se atreve \w a|strong="H3068"\w* invadir nuestra tierra, \w si|strong="H3588"\w* trata \w de|strong="H3588"\w* pisotear nuestros palacios, \w la|strong="H3588"\w* enfrentaremos siete \w pastores|strong="H7462"\w* \w y|strong="H3588"\w* ocho líderes \w de|strong="H3588"\w* hombres,
\v 6 \w los|strong="H1121"\w* cuales devastarán \w a|strong="H3068"\w* espada \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* Asiria \w y|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* Nimrod \w en|strong="H5921"\w* sus puertas. \w Él|strong="H5921"\w* \w nos|strong="H5921"\w* librará \w del|strong="H5921"\w* asirio \w cuando|strong="H1961"\w* ataque nuestra tierra, \w cuando|strong="H1961"\w* pisotee nuestro territorio.
\p 
\v 7 \w El|strong="H5674"\w* remanente \w de|strong="H5971"\w* \w Jacob|strong="H3290"\w* \w estará|strong="H1961"\w* en \w medio|strong="H7130"\w* \w de|strong="H5971"\w* \w muchos|strong="H7227"\w* \w pueblos|strong="H5971"\w* \w como|strong="H1961"\w* \w el|strong="H5674"\w* rocío \w de|strong="H5971"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w como|strong="H1961"\w* la lluvia \w que|strong="H5971"\w* \w a|strong="H3068"\w* nadie espera \w sobre|strong="H1961"\w* la hierba, ni pone su esperanza en \w los|strong="H1961"\w* hijos \w de|strong="H5971"\w* hombres.
\v 8 \w El|strong="H5921"\w* remanente \w de|strong="H5921"\w* Jacob \w estará|strong="H3605"\w* \w entre|strong="H5921"\w* \w las|strong="H5921"\w* naciones, \w en|strong="H5921"\w* \w medio|strong="H3027"\w* \w de|strong="H5921"\w* muchos pueblos, \w como|strong="H5921"\w* \w el|strong="H5921"\w* león \w entre|strong="H5921"\w* \w las|strong="H5921"\w* bestias \w del|strong="H5921"\w* campo, \w como|strong="H5921"\w* \w el|strong="H5921"\w* cachorro \w de|strong="H5921"\w* león \w en|strong="H5921"\w* \w medio|strong="H3027"\w* \w de|strong="H5921"\w* rebaños \w de|strong="H5921"\w* ovejas, \w las|strong="H5921"\w* cuales, \w si|strong="H5921"\w* pasa, arrebata \w y|strong="H5921"\w* desgarra, sin \w que|strong="H5921"\w* \w alguna|strong="H3605"\w* escape.
\v 9 ¡Levanta tu \w mano|strong="H1931"\w* \w contra|strong="H1961"\w* tus adversarios, y \w serán|strong="H1961"\w* todos destruidos!
\p 
\v 10 \wj \w Aquel|strong="H3605"\w* día, \wj*dice \nd \w Yavé|strong="H3068"\w*\nd*, \wj eliminaré tus caballos de en medio de ti, y \w destruiré|strong="H3772"\w* tus carruajes.\wj*
\v 11 \wj También \w destruiré|strong="H3772"\w* las ciudades de tu tierra y derribaré todas tus fortalezas.\wj*
\v 12 \wj \w Cortaré|strong="H3772"\w* \w de|strong="H5750"\w* tu \w mano|strong="H3027"\w* las hechicerías y \w no|strong="H3808"\w* tendrás \w más|strong="H5750"\w* adivinos.\wj*
\v 13 \wj Haré \w destruir|strong="H8045"\w* tus imágenes talladas y tus piedras rituales en \w medio|strong="H7130"\w* de ti. Nunca más te inclinarás ante la obra de tus manos.\wj*
\v 14 \wj Arrancaré tus Aseras de en medio de ti, y destruiré tus ciudades.\wj*
\v 15 \wj Ejecutaré venganza con ira y furor contra las naciones que no obedecieron.\wj*
\c 6
\s1 Recordatorio
\p 
\v 1 Les \w ruego|strong="H4994"\w* \w que|strong="H4994"\w* \w escuchen|strong="H8085"\w* lo \w que|strong="H4994"\w* dice \nd \w Yavé|strong="H3068"\w*\nd*: \wj ¡\w Levántate|strong="H6965"\w*, llama \w a|strong="H3068"\w* juicio \w a|strong="H3068"\w* las montañas, y \w que|strong="H4994"\w* las colinas \w oigan|strong="H8085"\w* tu \w voz|strong="H6963"\w*!\wj*
\v 2 Oh montañas \w y|strong="H3588"\w* fuertes cimientos \w de|strong="H3588"\w* \w la|strong="H3588"\w* tierra, \w escuchen|strong="H8085"\w* \w el|strong="H5973"\w* \w pleito|strong="H7379"\w* \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w porque|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* tiene \w pleito|strong="H7379"\w* \w con|strong="H5973"\w* \w su|strong="H3588"\w* \w pueblo|strong="H5971"\w*. Contenderá \w con|strong="H5973"\w* \w Israel|strong="H3478"\w*:
\v 3 \wj ¿\w Qué|strong="H4100"\w* te \w hice|strong="H6213"\w*, \w pueblo|strong="H5971"\w* \w mío|strong="H5971"\w*? ¿\w O|strong="H3068"\w* en \w qué|strong="H4100"\w* te agobié? ¡Testifica contra \w Mí|strong="H6030"\w*!\wj*
\v 4 \wj \w Yo|strong="H3588"\w* \w te|strong="H3588"\w* \w saqué|strong="H5927"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* \w Egipto|strong="H4714"\w*. \w Te|strong="H3588"\w* liberté \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* esclavitud. \w Envié|strong="H7971"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*, \w a|strong="H3068"\w* Aarón \w y|strong="H3588"\w* \w a|strong="H3068"\w* \w María|strong="H4813"\w* \w delante|strong="H6440"\w* \w de|strong="H3588"\w* ti.\wj*
\v 5 \wj Recuerda, \w pueblo|strong="H5971"\w* \w mío|strong="H5971"\w*, \w lo|strong="H4100"\w* \w que|strong="H4100"\w* tramaba \w Balac|strong="H1111"\w*, \w rey|strong="H4428"\w* \w de|strong="H4480"\w* \w Moab|strong="H4124"\w*, \w y|strong="H5704"\w* \w qué|strong="H4100"\w* le \w respondió|strong="H6030"\w* \w Balaam|strong="H1109"\w*, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* Beor, \w desde|strong="H4480"\w* Sitim \w hasta|strong="H5704"\w* \w Gilgal|strong="H1537"\w*. Recuerda \w para|strong="H5704"\w* \w que|strong="H4100"\w* reconozcas \w los|strong="H1121"\w* hechos justicieros \w de|strong="H4480"\w* \w Yavé|strong="H3068"\w*.\wj*
\s1 Lo que pide \nd Yavé\nd*
\p 
\v 6 ¿Con \w qué|strong="H4100"\w* me presentaré \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* y me postraré \w ante|strong="H6923"\w* \w el|strong="H1121"\w* \nd ʼElohim\nd* Altísimo? ¿Me presentaré con \w holocaustos|strong="H5930"\w*, con \w becerros|strong="H5695"\w* añales?
\v 7 ¿\nd \w Yavé|strong="H3068"\w*\nd* se deleita en millares \w de|strong="H5414"\w* carneros \w o|strong="H3068"\w* en miríadas \w de|strong="H5414"\w* \w arroyos|strong="H5158"\w* \w de|strong="H5414"\w* \w aceite|strong="H8081"\w*? ¿\w Daré|strong="H5414"\w* \w mi|strong="H5315"\w* \w primogénito|strong="H1060"\w* \w por|strong="H5414"\w* \w mis|strong="H5414"\w* actos \w rebeldes|strong="H6588"\w*, el \w fruto|strong="H6529"\w* \w de|strong="H5414"\w* \w mi|strong="H5315"\w* organismo \w por|strong="H5414"\w* el \w pecado|strong="H2403"\w* \w de|strong="H5414"\w* \w mi|strong="H5315"\w* \w alma|strong="H5315"\w*?
\v 8 \w Oh|strong="H4100"\w* hombre, \w Él|strong="H5973"\w* \w te|strong="H4480"\w* \w dijo|strong="H5046"\w* \w lo|strong="H4100"\w* \w que|strong="H3588"\w* \w es|strong="H3588"\w* \w bueno|strong="H2896"\w*, \w lo|strong="H4100"\w* \w que|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* pide \w de|strong="H4480"\w* \w ti|strong="H4480"\w*: Solo \w hacer|strong="H6213"\w* \w justicia|strong="H4941"\w*, amar \w la|strong="H3588"\w* \w misericordia|strong="H2617"\w* \w y|strong="H3588"\w* \w andar|strong="H3212"\w* humildemente \w con|strong="H5973"\w* \w tu|strong="H6213"\w* \add \nd ʼElohim\nd*\add*.
\p 
\v 9 \w Escucha|strong="H8085"\w*, \w oh|strong="H4310"\w* \w tribu|strong="H4294"\w*: La \w voz|strong="H6963"\w* \w de|strong="H3372"\w* \nd \w Yavé|strong="H3068"\w*\nd* proclama \w a|strong="H3068"\w* la \w ciudad|strong="H5892"\w*. \w Él|strong="H4310"\w* salvará \w a|strong="H3068"\w* los \w que|strong="H4310"\w* \w temen|strong="H3372"\w* su \w Nombre|strong="H8034"\w*.
\v 10 \wj ¿\w Aún|strong="H5750"\w* \w hay|strong="H5750"\w* tesoros \w de|strong="H5750"\w* perversidad \w en|strong="H5750"\w* \w casa|strong="H1004"\w* del perverso, y medida \w escasa|strong="H7332"\w* que es una repugnancia?\wj*
\v 11 \wj ¿Puedo justificar balanza inicua y una \w bolsa|strong="H3599"\w* de pesas fraudulentas\wj*
\v 12 \wj con las cuales sus ricos se \w llenaron|strong="H4390"\w* de explotación? Sus \w habitantes|strong="H3427"\w* \w hablan|strong="H1696"\w* \w mentiras|strong="H8267"\w*, y la \w lengua|strong="H3956"\w* en su \w boca|strong="H6310"\w* es \w engañosa|strong="H7423"\w*.\wj*
\p 
\v 13 \wj \w Pues|strong="H1571"\w* Yo \w también|strong="H1571"\w* \w te|strong="H5921"\w* enfermaré, \w te|strong="H5921"\w* derribaré, \w te|strong="H5921"\w* desolaré \w por|strong="H5921"\w* causa \w de|strong="H5921"\w* tus \w pecados|strong="H2403"\w*.\wj*
\v 14 \wj Comerás y \w no|strong="H3808"\w* te saciarás, y el \w abatimiento|strong="H3445"\w* estará en \w medio|strong="H7130"\w* \w de|strong="H5414"\w* ti. Recogerás, pero \w no|strong="H3808"\w* \w lo|strong="H3808"\w* conservarás, y \w lo|strong="H3808"\w* \w que|strong="H3808"\w* conserves, Yo \w lo|strong="H3808"\w* \w entregaré|strong="H5414"\w* \w a|strong="H3068"\w* \w la|strong="H7646"\w* \w espada|strong="H2719"\w*.\wj*
\v 15 \wj \w Sembrarás|strong="H2232"\w*, pero \w no|strong="H3808"\w* cosecharás. Prensarás \w olivas|strong="H2132"\w*, pero \w no|strong="H3808"\w* te ungirás con el \w aceite|strong="H8081"\w*, y uvas, pero \w no|strong="H3808"\w* \w beberás|strong="H8354"\w* el \w vino|strong="H3196"\w*.\wj*
\v 16 \wj \w Porque|strong="H4616"\w* \w guardaron|strong="H8104"\w* \w los|strong="H3427"\w* mandamientos \w de|strong="H5971"\w* \w Omri|strong="H6018"\w* y \w toda|strong="H3605"\w* práctica \w de|strong="H5971"\w* \w la|strong="H8104"\w* \w casa|strong="H1004"\w* \w de|strong="H5971"\w* Acab. \w Anduvieron|strong="H3212"\w* \w en|strong="H3212"\w* sus \w consejos|strong="H4156"\w* \w para|strong="H4616"\w* \w que|strong="H5971"\w* Yo \w pusiera|strong="H5414"\w* \w a|strong="H3068"\w* tus \w habitantes|strong="H3427"\w* como burla. \w Por|strong="H4616"\w* tanto, ustedes soportarán \w la|strong="H8104"\w* \w afrenta|strong="H2781"\w* \w de|strong="H5971"\w* \w mi|strong="H5375"\w* \w pueblo|strong="H5971"\w*.\wj*
\c 7
\s1 Días finales
\p 
\v 1 ¡Ay \w de|strong="H3588"\w* \w mí|strong="H1961"\w*! \w Porque|strong="H3588"\w* \w soy|strong="H1961"\w* \w como|strong="H3588"\w* \w el|strong="H3588"\w* último \w de|strong="H3588"\w* \w los|strong="H1961"\w* \w frutos|strong="H7019"\w* \w de|strong="H3588"\w* \w verano|strong="H7019"\w*, \w como|strong="H3588"\w* \w el|strong="H3588"\w* rebusco \w después|strong="H1961"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* cosecha, \w cuando|strong="H3588"\w* ya \w no|strong="H3588"\w* queda racimo \w que|strong="H3588"\w* \w comer|strong="H5315"\w*. \w Mi|strong="H1961"\w* \w alma|strong="H5315"\w* deseó \w el|strong="H3588"\w* fruto maduro.
\v 2 Desapareció \w el|strong="H3605"\w* piadoso \w de|strong="H4480"\w* \w la|strong="H3605"\w* tierra, y no hay \w recto|strong="H3477"\w* \w entre|strong="H4480"\w* \w los|strong="H3605"\w* hombres. \w Todos|strong="H3605"\w* acechan \w para|strong="H4480"\w* derramar \w sangre|strong="H1818"\w*. \w Cada|strong="H3605"\w* uno \w caza|strong="H6679"\w* \w al|strong="H4480"\w* otro \w con|strong="H4480"\w* una red.
\v 3 \w Con|strong="H5921"\w* respecto \w al|strong="H5921"\w* \w mal|strong="H7451"\w*, ambas \w manos|strong="H3709"\w* \w lo|strong="H1931"\w* hacen \w bien|strong="H3190"\w*. \w El|strong="H1931"\w* \w príncipe|strong="H8269"\w* \w pide|strong="H7592"\w* soborno \w y|strong="H5921"\w* también \w el|strong="H1931"\w* \w juez|strong="H8199"\w*. \w El|strong="H1931"\w* \w grande|strong="H1419"\w* \w habla|strong="H1696"\w* \w de|strong="H5921"\w* \w la|strong="H1931"\w* codicia \w de|strong="H5921"\w* \w su|strong="H1931"\w* \w alma|strong="H5315"\w*. \w Así|strong="H1931"\w* \w lo|strong="H1931"\w* entretejen juntos.
\v 4 El \w mejor|strong="H2896"\w* de ellos \w es|strong="H1961"\w* \w como|strong="H1961"\w* la espina, el \w más|strong="H6258"\w* \w recto|strong="H3477"\w* \w como|strong="H1961"\w* un \w zarzal|strong="H4534"\w*. Pero viene el \w día|strong="H3117"\w* de tu castigo, el \w que|strong="H6258"\w* anunciaron tus vigilantes. ¡\w Entonces|strong="H3117"\w* \w será|strong="H1961"\w* su turbación!
\v 5 No confíen en un vecino, ni tengan confianza en un \w amigo|strong="H7453"\w*. \w Guarda|strong="H8104"\w* tus labios de \w la|strong="H8104"\w* \w que|strong="H6310"\w* \w duerme|strong="H7901"\w* en tu \w seno|strong="H2436"\w*.
\v 6 \w Porque|strong="H3588"\w* \w el|strong="H3588"\w* \w hijo|strong="H1121"\w* \w deshonra|strong="H5034"\w* al padre, \w la|strong="H3588"\w* \w hija|strong="H1323"\w* se levanta contra \w la|strong="H3588"\w* madre \w y|strong="H3588"\w* \w la|strong="H3588"\w* \w nuera|strong="H3618"\w* contra \w la|strong="H3588"\w* \w suegra|strong="H2545"\w*. \w Los|strong="H1121"\w* enemigos del \w hombre|strong="H1121"\w* \w son|strong="H3588"\w* \w los|strong="H1121"\w* \w de|strong="H3588"\w* \w su|strong="H3588"\w* propia \w casa|strong="H1004"\w*.
\s1 Fidelidad
\p 
\v 7 Pero yo \w esperaré|strong="H3176"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*.\nd* \w Esperaré|strong="H3176"\w* al \nd ʼElohim\nd* de mi salvación. ¡Mi \nd ʼElohim\nd* me \w escuchará|strong="H8085"\w*!
\p 
\v 8 Oh enemigo mío, \w no|strong="H3588"\w* \w te|strong="H3588"\w* regocijes \w por|strong="H3588"\w* causa \w de|strong="H3588"\w* mí. \w Aunque|strong="H3588"\w* \w caiga|strong="H5307"\w*, \w me|strong="H3588"\w* \w levantaré|strong="H6965"\w*. \w Aunque|strong="H3588"\w* esté \w en|strong="H3588"\w* \w la|strong="H3588"\w* \w oscuridad|strong="H2822"\w*, \nd \w Yavé|strong="H3068"\w*\nd* será mi Luz.
\v 9 \w Soportaré|strong="H5375"\w* \w la|strong="H3588"\w* \w ira|strong="H3318"\w* \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w hasta|strong="H5704"\w* \w que|strong="H3588"\w* \w juzgue|strong="H7378"\w* \w mi|strong="H5375"\w* \w causa|strong="H7378"\w* \w y|strong="H3588"\w* \w me|strong="H3588"\w* \w haga|strong="H6213"\w* \w justicia|strong="H6666"\w*, \w porque|strong="H3588"\w* \w pequé|strong="H2398"\w* contra \w Él|strong="H3588"\w*. \w Él|strong="H3588"\w* \w me|strong="H3588"\w* \w sacará|strong="H3318"\w* \w a|strong="H3068"\w* \w la|strong="H3588"\w* luz, \w y|strong="H3588"\w* \w yo|strong="H3588"\w* \w veré|strong="H7200"\w* \w su|strong="H3588"\w* \w justicia|strong="H6666"\w*.
\v 10 \w Mi|strong="H1961"\w* enemiga lo \w verá|strong="H7200"\w* y vergüenza la \w cubrirá|strong="H3680"\w*, la \w que|strong="H6258"\w* me decía: ¿Dónde \w está|strong="H1961"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd*? Mis \w ojos|strong="H5869"\w* la \w mirarán|strong="H7200"\w* \w cuando|strong="H1961"\w* \w sea|strong="H1961"\w* pisoteada \w como|strong="H1961"\w* el lodo \w de|strong="H5869"\w* las \w calles|strong="H2351"\w*.
\p 
\v 11 \w Habrá|strong="H3117"\w* un \w día|strong="H3117"\w* para reconstruir tus muros. \w Ese|strong="H1931"\w* \w día|strong="H3117"\w* tus límites \w serán|strong="H1931"\w* extendidos
\v 12 \w y|strong="H5704"\w* vendrán \w a|strong="H3068"\w* \w ti|strong="H4480"\w* \w desde|strong="H4480"\w* Asiria \w hasta|strong="H5704"\w* Egipto, \w desde|strong="H4480"\w* \w el|strong="H1931"\w* Nilo \w hasta|strong="H5704"\w* \w el|strong="H1931"\w* Éufrates, \w de|strong="H4480"\w* \w mar|strong="H3220"\w* \w a|strong="H3068"\w* \w mar|strong="H3220"\w* \w y|strong="H5704"\w* \w de|strong="H4480"\w* montaña \w a|strong="H3068"\w* montaña.
\v 13 \w Porque|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w será|strong="H1961"\w* \w asolada|strong="H8077"\w* \w a|strong="H3068"\w* causa \w de|strong="H5921"\w* sus \w habitantes|strong="H3427"\w*, \w como|strong="H1961"\w* \w fruto|strong="H6529"\w* \w de|strong="H5921"\w* sus \w obras|strong="H4611"\w*.
\s1 Restauración
\p 
\v 14 \w Apacienta|strong="H7462"\w* \w a|strong="H3068"\w* tu \w pueblo|strong="H5971"\w* con tu cayado, el \w rebaño|strong="H6629"\w* \w de|strong="H5971"\w* tu \w posesión|strong="H5159"\w* \w que|strong="H5971"\w* vive solo \w en|strong="H8432"\w* la montaña, \w en|strong="H8432"\w* \w medio|strong="H8432"\w* del \w bosque|strong="H3293"\w* \w de|strong="H5971"\w* la montaña Carmelo. Apacentarán sus rebaños \w en|strong="H8432"\w* \w Basán|strong="H1316"\w* y \w en|strong="H8432"\w* \w Galaad|strong="H1568"\w*, \w como|strong="H7931"\w* \w en|strong="H8432"\w* los \w tiempos|strong="H3117"\w* \w antiguos|strong="H5769"\w*.
\v 15 \wj Como \w en|strong="H3318"\w* los \w días|strong="H3117"\w* \w cuando|strong="H3117"\w* \w salieron|strong="H3318"\w* de \w Egipto|strong="H4714"\w*, Yo les \w mostraré|strong="H7200"\w* \w maravillas|strong="H6381"\w*.\wj*
\p 
\v 16 \w Las|strong="H5921"\w* \w naciones|strong="H1471"\w* \w verán|strong="H7200"\w*, estarán avergonzadas \w de|strong="H5921"\w* su poderío, \w se|strong="H5921"\w* taparán \w la|strong="H5921"\w* \w boca|strong="H6310"\w* \w con|strong="H5921"\w* \w la|strong="H5921"\w* \w mano|strong="H3027"\w* \w y|strong="H5921"\w* sus oídos estarán sordos.
\v 17 \w Lamerán|strong="H3897"\w* el \w polvo|strong="H6083"\w* como la \w serpiente|strong="H5175"\w*, como los reptiles \w de|strong="H4480"\w* la \w tierra|strong="H6083"\w*. \w Temblarán|strong="H7264"\w* y saldrán \w de|strong="H4480"\w* sus fortalezas. Llegarán \w con|strong="H4480"\w* \w temor|strong="H3372"\w* y reverencia ante \w Ti|strong="H4480"\w*, oh \nd \w Yavé|strong="H3068"\w*\nd* nuestro.
\p 
\v 18 ¿\w Cuál|strong="H4310"\w* \nd \w ʼEL|strong="H1931"\w*\nd* \w hay|strong="H4310"\w* \w como|strong="H3588"\w* Tú, \w que|strong="H3588"\w* \w perdona|strong="H5375"\w* \w la|strong="H1931"\w* \w iniquidad|strong="H5771"\w* \w y|strong="H3588"\w* olvida \w el|strong="H1931"\w* \w pecado|strong="H5771"\w* \w del|strong="H5921"\w* remanente \w de|strong="H5921"\w* \w su|strong="H1931"\w* \w heredad|strong="H5159"\w*? \w Él|strong="H1931"\w* \w no|strong="H3808"\w* retiene \w su|strong="H1931"\w* ira \w para|strong="H5921"\w* \w siempre|strong="H5703"\w*, \w porque|strong="H3588"\w* \w se|strong="H1931"\w* deleita \w en|strong="H5921"\w* \w el|strong="H1931"\w* amor inmutable.
\v 19 \w Él|strong="H3605"\w* \w volverá|strong="H7725"\w* \w a|strong="H3068"\w* compadecerse de \w nosotros|strong="H3605"\w*. Sepultará nuestras \w iniquidades|strong="H5771"\w* y echará en \w lo|strong="H3605"\w* \w profundo|strong="H4688"\w* del \w mar|strong="H3220"\w* \w todos|strong="H3605"\w* nuestros \w pecados|strong="H2403"\w*.
\v 20 Concederás la verdad \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w*, y la lealtad \w a|strong="H3068"\w* Abraham \w que|strong="H3117"\w* \w juraste|strong="H7650"\w* \w a|strong="H3068"\w* nuestros antepasados desde \w tiempos|strong="H3117"\w* \w antiguos|strong="H6924"\w*. 
