\v 16 \w El|strong="H1931"\w* \w Ángel|strong="H4397"\w* \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* respondió \w a|strong="H3068"\w* \w Manoa|strong="H4495"\w*: \wj \w Aunque|strong="H3588"\w* \w me|strong="H3588"\w* detengas \w no|strong="H3808"\w* comeré \w de|strong="H3588"\w* \w tu|strong="H6213"\w* \w manjar|strong="H3899"\w*. \w Pero|strong="H3588"\w* \w si|strong="H3588"\w* preparas un \w holocausto|strong="H5930"\w*, ofrécelo \w a|strong="H3068"\w* \w Yavé|strong="H3068"\w*.\wj* \w Manoa|strong="H4495"\w* \w no|strong="H3808"\w* \w sabía|strong="H3045"\w* \w que|strong="H3588"\w* \w Él|strong="H1931"\w* \w era|strong="H1931"\w* \w el|strong="H1931"\w* \w Ángel|strong="H4397"\w* \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
