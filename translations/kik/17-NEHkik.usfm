\li2 
\v 31 na andũ a Mikimashi maarĩ 122
\li2 
\v 32 na andũ a Betheli na Ai maarĩ 123
\li2 
\v 33 na andũ a Nebo ĩrĩa ĩngĩ maarĩ 52
\li2 
\v 34 na andũ a Elamu ĩrĩa ĩngĩ maarĩ 1,254
\li2 
\v 35 na andũ a Harimu maarĩ 320
\li2 
\v 36 na andũ a Jeriko maarĩ 345
\li2 
\v 37 na andũ a Lodi, na Hadidi, na Ono maarĩ 721
