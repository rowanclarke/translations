\v 9 \w The|strong="H3605"\w* \w king|strong="H4428"\w* \w of|strong="H4428"\w* \w Israel|strong="H3478"\w* \w and|strong="H3063"\w* \w the|strong="H3605"\w* \w king|strong="H4428"\w* \w of|strong="H4428"\w* \w Judah|strong="H3063"\w* \w were|strong="H3478"\w* \w sitting|strong="H3427"\w* \w there|strong="H3427"\w* \w on|strong="H5921"\w* \w their|strong="H3605"\w* \w thrones|strong="H3678"\w*, wearing \w their|strong="H3605"\w* \w royal|strong="H4428"\w* robes. \w They|strong="H5921"\w* \w were|strong="H3478"\w* \w at|strong="H3427"\w* \w the|strong="H3605"\w* \w place|strong="H1637"\w* \w where|strong="H5921"\w* \w people|strong="H3427"\w* threshed \w grain|strong="H3605"\w*, \w near|strong="H6440"\w* \w the|strong="H3605"\w* \w gate|strong="H8179"\w* \w of|strong="H4428"\w* \w Samaria|strong="H8111"\w* \add city\add*. \w All|strong="H3605"\w* \w of|strong="H4428"\w* \add Ahab’s\add* \w prophets|strong="H5030"\w* \w were|strong="H3478"\w* standing \w in|strong="H3427"\w* \w front|strong="H6440"\w* \w of|strong="H4428"\w* \w them|strong="H5921"\w*, predicting \w what|strong="H5921"\w* \w was|strong="H3478"\w* going \w to|strong="H3478"\w* happen.   
\p
\v 10  \add One of them whose name was\add* \w Zedekiah|strong="H6667"\w*, \w the|strong="H3541"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Kenaanah|strong="H3668"\w*, \w had|strong="H3068"\w* \w made|strong="H6213"\w* \w from|strong="H1121"\w* \w iron|strong="H1270"\w* something \w that|strong="H3068"\w* resembled \w the|strong="H3541"\w* \w horns|strong="H7161"\w* \w of|strong="H1121"\w* \w a|strong="H3068"\w* \w bull|strong="H1121"\w*. \w He|strong="H5704"\w* proclaimed \w to|strong="H5704"\w* Ahab, “\w This|strong="H6213"\w* \w is|strong="H3068"\w* \w what|strong="H6213"\w* \w Yahweh|strong="H3068"\w* \w says|strong="H3541"\w*: ‘\w With|strong="H3068"\w* \w horns|strong="H7161"\w* \add like these\add*, \w your|strong="H3068"\w* \add army\add* \w will|strong="H3068"\w* \w keep|strong="H6213"\w* attacking \w the|strong="H3541"\w* army \w of|strong="H1121"\w* Syria \add like a bull attacks another animal\add*, \w until|strong="H5704"\w* \w you|strong="H5704"\w* \w completely|strong="H3615"\w* \w destroy|strong="H3615"\w* \w them|strong="H6213"\w*.’”  
