\v 5  \w Your|strong="H5921"\w* claim \w to|strong="H5921"\w* \w have|strong="H1697"\w* \w a|strong="H3068"\w* \w strategy|strong="H6098"\w* \w and|strong="H1697"\w* \w military|strong="H4421"\w* \w strength|strong="H1369"\w* \w is|strong="H4310"\w* \w just|strong="H1697"\w* \w empty|strong="H8193"\w* \w talk|strong="H1697"\w*. \w In|strong="H5921"\w* \w whom|strong="H4310"\w* \w are|strong="H1697"\w* \w you|strong="H3588"\w* trusting, \w that|strong="H3588"\w* \w you|strong="H3588"\w* \w would|strong="H4310"\w* dare \w to|strong="H5921"\w* \w rebel|strong="H4775"\w* \w against|strong="H5921"\w* \w me|strong="H5921"\w*?  
