\id PHM
\h Filemón
\toc1 Carta na̱ca̱hyí Pablo nu̱ú Filemón
\toc2 Filemón
\toc3 Flm.
\mt1 Carta na̱ca̱hyí Pablo nu̱ú Filemón
\c 1
\s1 Chíndahá Pablo Ndióxi̱ coo Filemón
\p 
\v 1 Ye̱he̱ cúú u̱ Pablo ta ndáca̱a̱n i̱ veca̱a yóho sa̱ha̱ ña̱ cúú u̱ cuéntá Jesucristo. Ye̱he̱ xi̱hi̱n Timoteo, ñani í, da̱ cúú cuéntá Jesús cáhyí nde̱ carta yóho nu̱ mún, Filemón. Quíhvi̱ ini nde̱ yo̱hó ta in cúún xi̱hín nde̱ sa̱há ña̱ cája chúún cuéntá Jesucristo.
\v 2 Ta jári cáhyí nde̱ carta yóho nu̱ú na̱ cúú cuéntá Jesús tácá vehún ja̱n xi̱hín nu̱ Apia, ñá cúú quia̱hva í sa̱há ña̱ cándeé ini ñá Jesús. Ta quia̱hva já cáhyí nde̱ carta yóho nu̱ Arquipo jáchi̱ in cúú da̱ ndóho ini da cája chúun da cuéntá Jesucristo.
\v 3 Ndióxi̱, tátá yo̱ xi̱hi̱n Jesucristo, xitoho í ná caja cua̱há ña̱ma̱ni̱ xi̱hi̱n ndo̱ ta ná caja ña̱ ná coo va̱ha ini ndó.
\s1 Cándeé cáhnu ini Filemón Jesucristo
\p 
\v 4 Tá xíca̱ ta̱hví i̱ nu̱ Ndióxi̱ sa̱hu̱n co̱ ndíndójó i̱ ndiquia̱hva i̱ ndixa̱hvi nu̱ mé á sa̱ha̱ mún.
\v 5 Jáchi̱ na̱ñe̱hé e̱ tu̱hun ña̱ cándeé inún Jesucristo, xitoho í ta quíhvi̱ inún mé á xi̱hín ndihi na̱ cúú cuéntá mé á.
\v 6 Ta xíca̱ ta̱hví i̱ nu̱ Ndióxi̱ ña̱ ná ndicanún nu̱ú java ña̱yivi ndá quia̱hva cándeé inún mé á. Ta xi̱hín ña̱ yóho cuu canda̱a̱ va̱ha ini na ndaja náhnu ña̱ma̱ni̱ cája Ndióxi̱ xi̱hi̱n tócó ndihi mí, na̱ cándeé ini Jesucristo.
\v 7 Cáji̱i̱ ini i̱ ñani mí i̱ ta sáhan tu̱hun ndeé ini i̱ jáchi̱ quíhvi̱ inún na̱ cúú cuéntá Jesús. Ta jári sáhan tu̱hun ndeé ini cua̱há na̱ cúú cuéntá Jesús jáchi̱ quíhvi̱ inún na̱.
\s1 Xíca̱ Pablo ña̱ma̱ni̱ nu̱ Filemón sa̱ha̱ Onésimo, da̱ na̱xeen Filemón caja chúun nu̱ dá
\p 
\v 8 Ye̱he̱ cúú u̱ in apóstol Jesucristo ña̱ cán quéa̱ íin sa̱há i̱ cahnda i̱ chuun nu̱u̱n cajún ña̱ ndítahan nu̱u̱n cajún.
\v 9 Joo co̱ cája i̱ ña̱. Ña̱ cája i̱ quéa̱ xíca̱ i̱ ña̱ma̱ni̱ nu̱u̱n jáchi̱ quíhvi̱ ini i̱ yo̱hó. Xíní ñúhú ndicu̱hu̱n inún ña̱ cúú u̱ Pablo, da̱ sáhnu, da̱ ndáca̱a̱n veca̱a sa̱ha̱ Jesucristo.
\v 10 Ta viti xíca̱ i̱ ña̱ma̱ni̱ nu̱u̱n sa̱ha̱ Onésimo, da̱ na̱nduu tátu̱hun ja̱hyi mí i̱ cuéntá Jesús nani ndáca̱a̱n i̱ veca̱a yóho.
\p 
\v 11 Jihna ga̱ na̱sa̱cuu Onésimo da̱ co̱ó chuun nu̱u̱n joo viti íin chuun da nu̱ ndíví yo̱.
\v 12 Ta viti chíndahá i̱ da̱ nu̱u̱n. Ndiquehe va̱hún da̱ sa̱ha̱ mí i̱ jáchi̱ quíhvi̱ ndiva̱ha ini i̱ da̱.
\v 13 Cúni̱ ña̱ ná cando̱o da yóho xi̱hín i̱ já ná cuu chindeé da̱ ye̱he̱ nu̱ mún. Jáchi̱ ndáca̱a̱n i̱ veca̱a yóho sa̱há ña̱ cáha̱n i̱ tu̱hun va̱ha sa̱há Jesucristo nu̱ú ña̱yivi.
\v 14 Joo na̱sacu ini i̱ chindahá i̱ da̱ nu̱u̱n jáchi̱ tia̱hva náá a̱ váha cúú inún xi̱hín i̱ tá ná cando̱o da yóho xi̱hín i̱. Jáchi̱ tá ná cajún ña̱ma̱ni̱ xi̱hín i̱ cúni̱ ña̱ ná caji̱i̱ inún cajún ña̱ ta co̱ cúni̱ caja ndúsa̱ i̱ xu̱hu̱n.
\v 15 Cája i̱ cuéntá na̱caxoo tóo Onésimo nu̱u̱n joo viti ndicó co̱o da ná coo da níí tiempo xu̱hu̱n.
\v 16 A̱ cája ga̱ún cuéntá ña̱ cúú dá da̱ na̱xeún. Joo va̱ha chága̱ viti jáchi̱ cúú da̱ ñani máni̱ yo̱hó cuéntá Jesucristo. Quíhvi̱ ndiva̱ha ini i̱ da̱ joo xíní ñúhú qui̱hvi̱ ini chágu̱n da̱ jáchi̱ cája chúun da nu̱u̱n ta cúú da̱ ñanún cuéntá Jesús viti.
\p 
\v 17 Ta tá mé a̱ nda̱a̱ quíhvi̱ inún ye̱he̱ já quéa̱ ndiquehe va̱hún da̱ tá quia̱hva ndiquehe va̱hún ye̱he̱ tá ná xi̱nu̱ co̱o i̱ nu̱ íún ja̱n.
\v 18 Ta tá na̱caja da in cua̱chi nu̱u̱n á tá yícá da̱ nu̱u̱n já quéa̱ nda̱cún ña̱ nu̱ú i̱ ta já cha̱hvi i̱ sa̱há.
\v 19 Ye̱he̱ cúú u̱ Pablo ta cáhyí i̱ ña̱ yóho xi̱hi̱n ndáha̱ i̱ já ná canda̱a̱ inún ña̱ sáha̱n i̱ tu̱hun i̱ nu̱u̱n ña̱ cha̱hvi i̱ ña̱. Xíní ñúhú ndicu̱hu̱n inún ña̱ yícún nu̱ú i̱ jáchi̱ na̱ndi̱hvún íchi̱ cuéntá Jesús sa̱há tu̱hun na̱ca̱ha̱n i̱ xu̱hu̱n.
\v 20 Inga tucu xíca̱ i̱ ña̱ma̱ni̱ nu̱u̱n ña̱ ná ndiquehe va̱hún Onésimo jáchi̱ cúún ñani mí i̱, da̱ cúú cuéntá Jesús. Tá ná cajún ña̱ yóho sa̱há ña̱ cándeé inún mé á já quéa̱ quia̱hvún tu̱hun ndeé ini i̱.
\p 
\v 21 Cánda̱a̱ va̱ha ini i̱ ña̱ cajún ña̱ xíca̱ i̱ nu̱u̱n cajún sa̱há ña̱ cán quéa̱ cáhyí i̱ carta yóho nu̱u̱n ta cánda̱a̱ ini i̱ ña̱ ya̱ha chága̱ cajún nu̱ú ña̱ xíca̱ i̱ nu̱u̱n.
\v 22 Inga tucu xíca̱ i̱ ña̱ma̱ni̱ nu̱u̱n ña̱ ná caja tia̱hvún in vehe loho nu̱ú coo i̱. Jáchi̱ sa̱há ña̱ xíca̱ ta̱hví ndihi ndó nu̱ Ndióxi̱ ña̱ ná sa̱a̱ i̱ coto nihni i̱ ndo̱hó sa̱há ña̱ cán quéa̱ cája i̱ cuéntá caja mé á ña̱ma̱ni̱ xi̱hín i̱ sa̱a̱ i̱ ja̱n.
\s1 Ndínda̱yí Pablo Filemón
\p 
\v 23 In da naní Epafras, da̱ ndáca̱a̱n veca̱a xi̱hín i̱ sa̱ha̱ Jesucristo chíndahá da̱ Ndióxi̱ coún.
\v 24 Chíndahá Marcos xi̱hi̱n Aristarco xi̱hi̱n Demas xi̱hi̱n Lucas Ndióxi̱ coún. Mé na̱ yóho cája chúun na xi̱hín i̱ cuéntá Jesucristo.
\p 
\v 25 Ná caja Jesucristo, xitoho í cua̱há ña̱ma̱ni̱ xi̱hín ndihi ndó, na̱ ndúu ja̱n. Já ná coo.
