\p
\v 10 \w He|strong="H6213"\w* \w made|strong="H6213"\w* \w for|strong="H6213"\w* \w the|strong="H6213"\w* \w Most|strong="H6944"\w* \w Holy|strong="H6944"\w* \w Place|strong="H6944"\w* \w two|strong="H8147"\w* wooden \w cherubim|strong="H3742"\w* \w covered|strong="H6823"\w* \w with|strong="H1004"\w* \w gold|strong="H2091"\w*.  
