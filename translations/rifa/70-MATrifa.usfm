\id MAT
\h مَاتَّا
\toc1 مَاتَّا
\toc2 مَاتَّا
\toc3 مت.
\mt1 مَاتَّا
\c 1
\s1 أَذْلِيسْ ن ؤُمزْرُويْ ن وخْڒَاقْ ن يَاسُوع لْمَاسِيحْ
\m 
\v 1 أَذْلِيسْ ن ؤُمزْرُويْ ن وخْڒَاقْ ن يَاسُوع لْمَاسِيحْ، مِّيسْ ن ذَاوُوذْ، مِّيسْ ن إِبْرَاهِيمْ. \x ◘ \xo 1:‏1 \xt [لك. 3‏:‏23‏-‏38] — لك. 1‏:‏31، 32\x*
\m 
\v 2 إِبْرَاهِيمْ إِجَّا-د إِسْحَاقْ، إِسْحَاقْ إِجَّا-د يَاعْقُوبْ، يَاعْقُوبْ إِجَّا-د يَاهُوذَا ذ أَيْثْمَاسْ. \x ◘ \xo 1:‏2 \xt أَمز. 21‏:‏2؛ 25‏:‏26، 35. \x*
\v 3 يَاهُوذَا إِجَّا-د فَارِيصْ ذ زَارَاحْ أَكْ-ذ ثَامَارْ، فَارِيصْ إِجَّا-د حَاصْرُونْ، حَاصْرُونْ إِجَّا-د أَرَامْ، \x ◘ \xo 1:‏3 \xt أَمز. 38‏:‏27، 29؛ رَاع. 4‏:‏18، 19؛ 1 إِم. 2‏:‏5، 9. \x*
\v 4 أَرَامْ إِجَّا-د عَامِّينَاذَابْ، عَامِّينَاذَابْ إِجَّا-د نَاحْشُونْ، نَاحْشُونْ إِجَّا-د سَالْمُونْ،
\v 5 سَالْمُونْ إِجَّا-د بُوعَازْ زِي رَاحَابْ، بُوعَازْ إِجَّا-د عُوبِيذْ أَكْ-ذ رَاعُوثْ، عُوبِيذْ إِجَّا-د يَاسَّا،
\v 6 يَاسَّا إِجَّا-د ذَاوُوذْ، أَجدْجِيذْ، ؤُشَا ذَاوُوذْ إِجَّا-د سُولِيمَانْ أَكْ-ذ ثمْغَارْثْ ن ؤُرِييَا. \x ◘ \xo 1:‏6 \xt رَاع. 4‏:‏22؛ 1 صم. 16‏:‏1؛ 17‏:‏12؛ 1 إِم. 2‏:‏15؛ 12‏:‏18. \x*
\m 
\v 7 سُولِيمَانْ إِجَّا-د رَاحَابْعَامْ، رَاحَابْعَامْ إِجَّا-د أَبِييَا، أَبِييَا إِجَّا-د أَسَا، \x ◘ \xo 1:‏7 \xt 1 إِج. 11‏:‏43؛ 1 إِم. 3‏:‏10. \x*
\v 8 أَسَا إِجَّا-د يَاهُوشَافَاطْ، يَاهُوشَافَاطْ إِجَّا-د يُورَامْ، يُورَامْ إِجَّا-د عُوزِّييَا،
\v 9 عُوزِّييَا إِجَّا-د يُوثَامْ، يُوثَامْ إِجَّا-د أَحَازْ، أَحَازْ إِجَّا-د حِيزْقِييَا،
\v 10 حِيزْقِييَا إِجَّا-د مَانَاسَّا، مَانَاسَّا إِجَّا-د أَمُونْ، أَمُونْ إِجَّا-د يُوشِييَا،
\v 11 يُوشِييَا إِجَّا-د يَاكُونْيَا ذ أَيْثْمَاسْ ذڭْ \add وُوسَّانْ ن\add* لْمنْفَا ن بَابِيلْ. \x ◘ \xo 1:‏11 \xt 1 إِم. 3‏:‏16. \x*
\m 
\v 12 أَوَارْنِي إِ لْمنْفَا ذِي بَابِيلْ، يَاكُونْيَا إِجَّا-د شَاعَالْثِييِيلْ، شَاعَالْثِييِيلْ إِجَّا-د زَارُوبَّابِيلْ. \x ◘ \xo 1:‏12 \xt 1 إِم. 3‏:‏17؛ عِز. 3‏:‏2. \x*
\v 13 زَارُوبَّابِيلْ إِجَّا-د أَبِيهُوذْ، أَبِيهُوذْ إِجَّا-د أَلْيَاقِيمْ، أَلْيَاقِيمْ إِجَّا-د عَازُورْ،
\v 14 عَازُورْ إِجَّا-د صَاذُوقْ، صَاذُوقْ إِجَّا-د أَخِيمْ، أَخِيمْ إِجَّا-د أَلِييُوذْ،
\v 15 أَلِييُوذْ إِجَّا-د أَلِيعَازَارْ، أَلِيعَازَارْ إِجَّا-د مَاتَّانْ، مَاتَّانْ إِجَّا-د يَاعْقُوبْ،
\v 16 يَاعْقُوبْ إِجَّا-د يُوسُوفْ، أَرْيَازْ ن مَارْيَامْ، ثنِّي إِ د-إِجِّينْ يَاسُوع ؤُمِي قَّارنْ لْمَاسِيحْ.
\m 
\v 17 س ؤُينِّي مَارَّا أَرَّاونْ زِي إِبْرَاهِيمْ أَڒْ ذَاوُوذْ إِوْضنْ أَرْبعْطَاشْ ن وَارَّاونْ. زِي ذَاوُوذْ أَڒْ لْمنْفَا ذِي بَابِيلْ أَرْبعْثَاشْ ن وَارَّاونْ ؤُشَا زِي لْمنْفَا ذِي بَابِيلْ أَڒْ لْمَاسِيحْ أَرْبعْثَاشْ ن وَارَّاونْ.
\b
\s1 أَخْڒَاقْ ن يَاسُوع لْمَاسِيحْ
\m 
\v 18 أَمُّو إِ يمْسَارْ وخْڒَاقْ ن يَاسُوع لْمَاسِيحْ. ؤُمِي يمَّاسْ مَارْيَامْ ثُوغَا-ت ذ ثَانخْضبْثْ ن يُوسُوفْ، إِضْهَارْ-د بلِّي نتَّاثْ ثكْسِي أَعذِّيسْ زِي أَرُّوحْ إِقدّْسنْ قْبڒْ إِ غَا مڒْشنْ. \x ◘ \xo 1:‏18 \xt [لك. 2‏:‏1‏-‏7] — 1‏:‏27، 34\x*
\v 19 ؤُمِي أَرْيَازْ نّسْ يُوسُوفْ ثُوغَا إِڭُّورْ نِيشَانْ، وَارْ إِخْسْ شَا أَذْ ت إِسّْبهْذڒْ، ثُوغَا يَارزُّو أَذْ أَسْ إِدْجفْ س ثْنُوفّْرَا.
\v 20 أَمْ ثُوغَا إِتّْخَارَّاصْ ذِي مَانْ أَيَا، إِضْهَارْ أَسْ-د لْمَالَاكْ ن سِيذِي ذِي ثَارْجِيثْ، إِنَّا:
\b
\m \qt ”أَ يُوسُوفْ، أَ مِّيسْ ن ذَاوُوذْ،\qt*
\m \qt وَارْ تّڭّْوذْ أَذْ د-ثَاوْيذْ\qt*
\m \qt مَارْيَامْ ذ ثَامْغَارْثْ نّشْ،\qt*
\m \qt مِينْزِي ونِّي إِ ذَايسْ د-إِخڒْقنْ،\qt*
\m \qt أَقَا نتَّا زِي أَرُّوحْ إِقدّْسنْ.“\qt*
\m 
\v 21 \qt نتَّاثْ أَذْ د-ثَارُووْ أَحنْجِيرْ،\qt*
\m \qt نتَّاثْ أَذْ ث ثْسمَّا يَاسُوع،\qt*
\m \qt مِينْزِي نتَّا أَذْ إِسّنْجمْ ڒْڭنْسْ نّسْ\qt*
\m \qt زِي دّْنُوبْ نْسنْ.“\qt* \x ◘ \xo 1:‏21 \xt لك. 1‏:‏31؛ ڒخ. 4‏:‏12. \x*
\b
\m 
\v 22 مَارَّا أَيَا إِمْسَارْ، حِيمَا أَذْ إِتّْوَاكمّڒْ مِينْ إِنَّا سِيذِي س \add ؤُقمُّومْ ن\add* ؤُنَابِي، \add ؤُمِي إِنَّا\add*:
\b
\m 
\v 23 \qt ”خْژَارْ، ثَاعْزَارشْثْ أَذْ ثكْسِي دّيْسثْ،\qt*
\m \qt ؤُشَا أَذْ د-ثَارُووْ أَحنْجِيرْ،\qt*
\m \qt أَذْ أَسْ ڭّنْ ’عِيمَّانُو-إِلْ‘\qt*
\m \qt مِينْ إِخْسْ أَذْ يِينِي: \qt*
\m \qt ’أَربِّي نّغْ أَقَا-ث أَكِيذْنغْ.‘ “\qt* \x ◘ \xo 1:‏23 \xt إِشا. 7‏:‏14؛ 8‏:‏8، 10 \x*
\b
\m 
\v 24 ڒَامِي د-إِفَاقْ يُوسُوفْ زڭْ إِضصْ، إِڭَّا أَمْ مَامّشْ ت يُومُورْ لْمَالَاكْ ن سِيذِي، ؤُشَا يِيوْيِي-د ثَامْغَارْثْ نّسْ غَارسْ.
\v 25 ؤُشَا نتَّا وَارْ غَارسْ د-إِقَارّبْ شَا أَڒَامِي د-ثُورُووْ مِّيسْ أَمنْزُو، ؤُشَا ثْسمَّا ث ’يشُّو‘. \x ◘ \xo 1:‏25 \xt لك. 2‏:‏21. \x*
\b
\b
\c 2
\s1 إِمُوسْنَاونْ ن إِثْرَانْ زِي شَّارْقْ
\m 
\v 1 ڒَامِي د-إِخْڒقْ يَاسُوع ذِي بَايْثْ-لَاحْمْ ذِي يَاهُوذِييَّا ذڭْ وُوسَّانْ ن ؤُجدْجِيذْ هِيرُوذُوسْ، ؤُسِينْ-د شَا ن إِمُوسْنَاونْ \add ن إِثْرَانْ\add* زِي مَانِيسْ ذ ثْنقَّارْ ثْفُوشْثْ غَارْ ؤُرْشَالِيمْ. \x ◘ \xo 2:‏1 \xt لك. 2‏:‏4. \x*
\v 2 نَّانْ: ”مَانِي إِدْجَا ونِّي د-إِخڒْقنْ ذ أَجدْجِيذْ ن وُوذَاينْ؟ أَقَا نژْرَا إِثْرِي نّسْ ذِي شَّارْقْ، نُوسَا-د أَذْ أَسْ نسْجذْ.“
\v 3 \add ڒَْامِي\add* إِسْڒَا ؤُجدْجِيذْ هِيرُوذُوسْ \add مَانْ أَيَا\add*، إِنّحْوڒْ نتَّا ذ قَاعْ ؤُرْشَالِيمْ أَكِيذسْ.
\v 4 إِسّْمُونْ-د زِي ڒْڭنْسْ مَارَّا إِمقّْرَاننْ ن إِكهَّاننْ ذ إِمْسڒْمَاذنْ ن إِذْلِيسنْ ؤُشَا إِسّقْسَا ثنْ خْ مَانِي غَا إِخْڒقْ لْمَاسِيحْ.
\v 5 نَّانْ: ”ذِي بَايْثْ-لَاحْمْ ذِي يَاهُوذِييَّا، مِينْزِي ذ مَانْ أَيَا إِ يُورَانْ س ؤُفُوسْ ن ؤُنَابِي:
\b
\m 
\v 6 \qt ’ؤُڒَا ذ شمْ، بَايْثْ-لَاحْمْ\qt*
\m \qt ذِي \tl ثمُّورْثْ ن\tl* يَاهُوذَا،\qt*
\m \qt شمْ وَارْ ثدْجِيذْ شَا ذ ثَامژْيَانْثْ\qt*
\m \qt جَارْ إِجدْجِيذنْ ن يَاهُوذَا،\qt*
\m \qt مِينْزِي زَّايمْ د غَا إِفّغْ ؤُجدْجِيذْ\qt*
\m \qt ونِّي إِ غَا يَاروْسنْ ڒْڭنْسْ إِنُو، إِسْرَائِيل.‘ “\qt* \x ◘ \xo 2:‏6 \xt مِيخَا 5‏:‏1، 2؛ 1 صم. 16‏:‏1؛ يُوح. 7‏:‏42. \x*
\b
\m 
\v 7 ڒخْذنِّي إِڒَاغَا هِيرُوذُوسْ خْ إِمُوسْنَاونْ \add ن إِثْرَانْ\add* س ثْنُوفّْرَا ؤُشَا يِيوضْ أَذْ زَّايْسنْ إِسّنْ ڒْوقْثْ إِ ذِي ثُوغَا ذ أَسنْ د-إِفّغْ إِثْرِي.
\v 8 \add خنِّي\add* إِسّكّْ إِ-ثنْ غَارْ بَايْثْ-لَاحْمْ، إِنَّا: ”رُوحمْ ذِينِّي، ثَارْزُومْ مْلِيحْ خْ ؤُحنْجِيرْ. مَاڒَا ثُوفِيمْ ث، أَسمْ-د، خبَّارمْ أَيِي، حِيمَا ؤُڒَا ذ نشّْ أَذْ د-أَسغْ، أَذْ أَسْ سجْذغْ.“
\v 9 أَوَارْنِي ڒَامِي سْڒِينْ \add إِ وَاوَاڒْ\add* ن ؤُجدْجِيذْ، رُوحنْ ؤُشَا خْزَارْ، إِثْرِي إِ ژْرِينْ ذِي شَّارْقْ إِڭُّورْ زَّاثْسنْ أَڒَامِي د-يِيوضْ ؤُشَا إِبدّْ سنّجْ إِ ومْشَانْ مَانِي إِدْجَا ؤُحنْجِيرْ.
\v 10 ڒَامِي ژْرِينْ إِثْرِي، فَارْحنْ س ڒفْرَاحثْ ثَامقّْرَانْثْ أَطَّاسْ.
\v 11 ؤُذْفنْ غَارْ ثَادَّارْثْ، ژْرِينْ أَحنْجِيرْ أَكْ-ذ مَارْيَامْ، يمَّاسْ، وْضَانْ غَارْ ثمُّورْثْ ؤُشَا سجْذنْ أَسْ. \add خنِّي\add* أَرزْمنْ ڒكْنُوزْ نْسنْ ؤُشَا قدّْمنْ أَسْ ثِيرْزِيفِينْ: ؤُرغْ، مِيرُّو ذ ڒفْوَاحثْ ن ڒبْخُورْ. \f ◼ \fr 2:‏11 \ft \bd ’ثِيرْزِيفِينْ‘\bd* - نِيغْ ’إِرِيغَالُوثنْ‘.\f*
\v 12 ؤُمِي ذ أَسنْ د-إِوحَّا ذِي ثَارْجِيثْ حِيمَا وَارْ تّْعِيقِّيبنْ غَارْ هِيرُوذُوسْ،عقْبنْ غَارْ ثمُّورْثْ نْسنْ زڭْ إِجّْ ن وبْرِيذْ نّغْنِي.
\b
\s1 ثَاروْڒَا غَارْ مِيصْرَا
\m 
\v 13 ؤُمِي رُوحنْ، إِضْهَارْ-د لْمَالَاكْ ن سِيذِي غَارْ يُوسُوفْ ذِي ثَارْجِيثْ، إِنَّا: ”كَّارْ، أَوِي-د أَحنْجِيرْ ذ يمَّاسْ، أَرْوڒْ غَارْ مِيصْرَا ؤُ قِّيمْ ذِينْ أَڒْ شكْ إِ غَا خبَّارغْ، مِينْزِي هِيرُوذُوسْ يَارزُّو خْ ؤُحنْجِيرْ حِيمَا أَذْ ث إِسّْهلّكْ.“
\v 14 ؤُشَا إِكَّارْ-د يُوسُوفْ، يِيوِي أَحنْجِيرْ ذ يمَّاسْ س دْجِيڒثْ ؤُشَا يَارْوڒْ غَارْ مِيصْرَا.
\v 15 إِقِّيمْ ذِينِّي أَڒَامِي إِمُّوثْ هِيرُوذُوسْ، حِيمَا أَذْ إِتّْوَاكمّڒْ مِينْ إِتّْوَانَّانْ زِي سِيذِي زڭْ ؤُنَابِي إِ إِنَّانْ: ”ڒَْاغِيغْ-د خْ مِّي \add حِيمَا أَذْ إِفّغْ\add* زِي مِيصْرَا.“ \x ◘ \xo 2:‏15 \xt ؤُف. 4‏:‏22، 23؛ حُوش. 11‏:‏1. \x*
\b
\s1 أَنْغَايْ ن إِحنْجِيرنْ ذِي بَايْثْ-لَاحْمْ
\m 
\v 16 ڒَامِي إِژْرَا هِيرُوذُوسْ بلِّي إِمُوسْنَاونْ شمْثنْ ث، إِخيّقْ أَطَّاسْ، ؤُشَا إِسّكّْ، إِنْغَا مَارَّا إِحنْجِيرنْ ن بَايْثْ-لَاحْمْ ذ قَاعْ جّْوَايهْ إِ ذ أَسْ د-يُوذْسنْ، مَارَّا إِحنْجِيرنْ زِي ثْنَاينْ ن إِسڭّْوُوسَا سْوَادَّايْ عْلَاحْسَابْ ڒْوقْثْ إِ يِيوضْ أَذْ إِسّنْ زڭْ إِمُوسْنَاونْ.
\v 17 ڒخْذنِّي إِتّْوَاكمّڒْ مِينْ إِتّْوَانَّانْ زڭْ ؤُنَابِي إِرْمِييَا، ؤُمِي إِنَّا:
\b
\m 
\v 18 \qt ”ثْمِيجَّا ثتّْوَاسڒْ ذِي رَامَا،\qt*
\m \qt إِمطَّاونْ ذ ثْغُويِّيثْ ن وشْضَانْ أَطَّاسْ.\qt*
\m \qt رَاهِيلْ ثتّْرُو خْ إِحنْجِيرنْ نّسْ،\qt*
\m \qt وَارْ ثتّخْسْ أَذْ ثتّْوَاعزَّا،\qt*
\m \qt مِينْزِي نِيثْنِي وَارْ قِّيمنْ \tl عَاذْ\tl*!“\qt* \x ◘ \xo 2:‏18 \xt إِرْم. 31‏:‏15 \x*
\b
\s1 أَذْوَاڒْ زِي مِيصْرَا
\m 
\v 19 ڒَامِي إِمُّوثْ هِيرُوذُوسْ، إِضْهَارْ-د لْمَالَاكْ ن سِيذِي ذِي ثَارْجِيثْ إِ يُوسُوفْ ذِي مِيصْرَا،
\v 20 إِنَّا: ”كَّارْ، أَوِي-د أَحنْجِيرْ ذ يمَّاسْ ؤُشَا رُوحْ غَارْ ثمُّورْثْ ن إِسْرَائِيل، مِينْزِي إِنِّي ثُوغَا يَارزُّونْ أَذْ نْغنْ أَحنْجِيرْ، أَقَا مُّوثنْ.“
\v 21 \add ڒخْذنِّي\add* إِكَّارْ، يِيوِي-د أَحنْجِيرْ ذ يمَّاسْ ؤُشَا يُوسَا-د غَارْ ثمُّورْثْ ن إِسْرَائِيل.
\v 22 مَاشَا أَڒَامِي إِسْڒَا بلِّي أَرْخِيلَاوُوسْ إِذْوڒْ ذ أَجدْجِيذْ ذِي يَاهُوذِييَّا ذڭْ ومْشَانْ ن بَابَاسْ هِيرُوذُوسْ، إِڭّْوذْ أَذْ إِرَاحْ ذِينِّي. \add خنِّي\add* إِوحَّا أَسْ-د \add أَربِّي\add* ذِي ثَارْجِيثْ مَاحنْذْ أَذْ إِرَاحْ غَارْ جّْوَايهْ ن لْجَالِيلْ.
\v 23 \add ڒَْامِي\add* د-يِيوضْ، إِزْذغْ ذِي ثنْذِينْثْ قَّارنْ أَسْ نَّاصِيرَا، حِيمَا أَذْ إِتّْوَاكمّڒْ مِينْ إِتّْوَانَّانْ زڭْ ؤُنَابِي إِ إِنَّانْ: ”أَذْ ث سمَّانْ نَّاصِيرِي!“ \x ◘ \xo 2:‏23 \xt إِشا. 11‏:‏1؛ 60‏:‏21؛ زَاك. 6‏:‏12. \x*
\b
\b
\c 3
\s1 أَبَارّحْ ن يُوحَانَّا أَمْسغْضَاصْ
\m 
\v 1 ذڭْ وُوسَّانْ نِّي يُوسَا-د يُوحَانَّا أَمْسغْضَاصْ، ثُوغَا إِتّْبَارّحْ ذِي ڒخْڒَا ن يَاهُوذِييَّا، \x ◘ \xo 3:‏1 \xt [مك. 1‏:‏1‏-‏8؛ لك. 3‏:‏1‏-‏9، 15‏-‏17؛ يُوح. 1‏:‏19‏-‏28] — مك. 1‏:‏4؛ لك. 3‏:‏3.\x*
\v 2 إِنَّا:
\b
\m \qt ”ثُوبمْ، مِينْزِي ثَاڭلْذِيثْ ن إِجنْوَانْ.\qt*
\m \qt أَقَا ثُوذسْ-د.“\qt*
\b
\m 
\v 3 مِينْزِي نتَّا ذ ونِّي خفْ إِتّْوَانَّانْ زڭْ ؤُنَابِي إِشَاعْيَا \add أَمْ إِنَّا\add*:
\b
\m \qt ”ثْمِيجَّا إِ إِتّْڒَاغَانْ ذِي ڒخْڒَا:\qt*
\m \qt ’سْوجْذمْ أَبْرِيذْ ن سِيذِي،\qt*
\m \qt سڭّمْ إِمسْرَاقْ نّسْ.‘ “\qt* \x ◘ \xo 3:‏3 \xt إِشا. 40‏:‏3؛ مك. 1‏:‏3؛ لك. 3‏:‏4؛ يُوح. 1‏:‏23. \x*
\b
\m 
\v 4 يُوحَانَّا وَانِيثَا ثُوغَا يَارّضْ \add أَرُّوضْ ن\add* ثَاضُوفْثْ ن إِڒغْمَانْ، إِبكّسْ إِجّْ ن وبْيَاسْ ن يِيڒمْ. ؤُشَا مَاشَّا نّسْ ثُوغَا ذ إِبُورخْسنْ ذ ثَامّنْثْ ثَاحُورّشْثْ. \x ◘ \xo 3:‏4 \xt مك. 1‏:‏6. \x*
\v 5 ڒخْذنِّي ثفّغْ-د غَارسْ ؤُرْشَالِيمْ ذ قَاعْ يَاهُوذِييَّا ذ مَارَّا جّْوَايهْ إِ ذ أَسْ د-إِنّْضنْ إِ لْ-ؤُرْذُونْ،
\v 6 ؤُشَا تّْوَاسّْغضْصنْ زَّايسْ ذڭْ إِغْزَارْ ن لْ-ؤُرْذُونْ، نعْمنْ س دّْنُوبْ نْسنْ. \x ◘ \xo 3:‏6 \xt مك. 1‏:‏5. \x*
\m 
\v 7 ڒَامِي إِژْرَا أَطَّاسْ ن إِفَارِيسِييّنْ ذ إِصَاذُوقِييّنْ تَّاسنْ-د مَاحنْذْ أَذْ تّْوَاسّْغضْصنْ، إِنَّا أَسنْ: ”أَ ثَارْوَا ن إِفِيغْرَانْ، وِي ذ أَومْ إِمْڒنْ، أَقَا ثْزمَّارمْ أَذْ ثَاروْڒمْ زڭْ وغْضَابْ إِ د غَا يَاسنْ؟ \x ◘ \xo 3:‏7 \xt مت. 12‏:‏34؛ 23‏:‏33؛ لك. 3‏:‏7. \x*
\v 8 ڭّمْ ڒْغِيدْجثْ إِ غَا إِڒِيقّنْ إِ تُّوبثْ. \x ◘ \xo 3:‏8 \xt لك. 3‏:‏8. \x*
\v 9 وَارْ تّْغِيڒمْ شَا أَذْ ثِينِيمْ ذڭْ إِخفْ نْومْ: ’إِبْرَاهِيمْ ذ جذِّيثْنغْ!‘، مِينْزِي نشّْ أَذْ أَومْ إِنِيغْ بلِّي أَربِّي إِزمَّارْ أَذْ إِسّْنكَّارْ زڭْ إِژْرَا-يَا ثَارْوَا إِ إِبْرَاهِيمْ. \x ◘ \xo 3:‏9 \xt يُوح. 8‏:‏39. \x*
\v 10 خْزَارْ، ثَاشَاقُورْثْ ثتّْوَاسَّارْسْ غَارْ إِژوْرَانْ ن ثْشجُّورَا. س ؤُيَا كُوڒْ ثَاشجَّارْثْ إِ وَارْ إِتِّيشنْ ڒْغِيدْجثْ ثشْنَا، أَذْ ثتّْوَاقسّْ ؤُشَا أَذْ ثوْضَا ذِي ثْمسِّي. \f ◼ \fr 3:‏10 \ft \bd ’ثَاشجَّارْثْ‘\bd* - نِيغْ ’أَدَّاڭْ‘ (’إِدَّاڭنْ‘).\f*  \x ◘ \xo 3:‏10 \xt مت. 7‏:‏19؛ يُوح. 15‏:‏6. \x*
\v 11 نشّْ أَذْ كنِّيوْ سّْغضْصغْ ذڭْ وَامَانْ إِ تُّوبثْ، مَاشَا ونِّي إِ د غَا يَاسنْ أَوَارْنِي أَيِي، نتَّا إِجْهذْ خَافِي، نشّْ وَارْ سْذِيهِيدْجغْ أَذْ كْسِيغْ سَانْذَالِييَاثْ نّسْ. أَقَا نتَّا أَذْ كنِّيوْ إِسّغْضصْ ذِي أَرُّوحْ إِقدّْسنْ ذ ثْمسِّي. \x ◘ \xo 3:‏11 \xt مك. 1‏:‏7؛ لك. 3‏:‏16؛ يُوح. 1‏:‏15، 26؛ ڒخ. 1‏:‏5؛ 11‏:‏16؛ 19‏:‏4. \x*
\v 12 ثَازَّارْثْ نّسْ ذڭْ ؤُفُوسْ نّسْ، أَذْ إِزُّوزَارْ أَنْذْرَارْ نّسْ قَاعْ، أَذْ إِيْرُو إِرْذنْ غَارْ ڒمْرَاسِي نّسْ، \add مَاشَا\add* إِشَارْفَا أَذْ ثنْ إِسّشْمضْ س ثْمسِّي إِ وَارْ إِخسّْينْ.“
\b
\s1 أَسغْضصْ ن يَاسُوع
\m 
\v 13 ڒخْذنِّي يُوسَا-د يَاسُوع زِي لْجَالِيلْ غَارْ لْ-ؤُرْذُونْ، غَارْ يُوحَانَّا، حِيمَا أَذْ إِتّْوَاسغْضصْ زَّايسْ. \f ◼ \fr 3:‏13 \ft \bd ’إِتّْوَاسغْضصْ‘\bd* - نْزمَّارْ أَذْ نسّمْقُودَّا أَسغْضسْ أَكْ-ذ ونْضڒْ ن بْنَاذمْ ذِي ڒبْحَارْ، ذڭْ وَامَانْ، خنِّي أَوَارْنِي أَسْ إِتّْوَاسّْنكَّارْ-د زَّايْسنْ. ذ مَانْ أَيَا ذ إِجّْ ن ؤُمذْيَا ن ونْضڒْ ن بْنَاذمْ أَقْذِيمْ ذ ثْنُوكّْرَا ن بْنَاذمْ ن جْذِيذْ س لْ-إِيمَانْ ذِي يَاسُوع لْمَاسِيحْ. أَسغْضصْ ذِي يَاسُوع وَارْ إِدْجِي ذ إِشْثْ ن ڒعْڒَامثْ ن طْهَارثْ وَاهَا، مَاشَا غَارْ ؤُمزْوَارْ أَقَا أَسغْضصْ ڒعْڒَامثْ ن ؤُمنْضَارْ ن بْنَاذمْ أَقْذِيمْ ذڭْ وَامَانْ ؤُ ن ثْنُوكّْرَا نّسْ زڭْ وَامَانْ أَمْ بْنَاذمْ ذ جْذِيذْ س لِيمَانْ ذِي يَاسُوع لْمَاسِيحْ. خْزَارْ رُوم. 6:1-14.\f*  \x ◘ \xo 3:‏13 \xt [مك. 1‏:‏9‏-‏11؛ لك. 3‏:‏21‏-‏22] — مك. 1‏:‏9؛ لك. 3‏:‏21.\x*
\v 14 مَاشَا يُوحَانَّا يُوڭِي أَسْ، إِنَّا: ”نشّْ حْذَاجغْ أَذْ تّْوَاسّْغضْصغْ زَّايكْ. مَا أَقَا ذ شكْ إِ غَارِي إِ د غَا يَاسنْ؟“
\m 
\v 15 مَاشَا يَاسُوع يَارَّا-د، إِنَّا أَسْ: ”أوْشْ ڒخُّو تّسْرِيحْ، مِينْزِي أَمُّو إِ ذ أَنغْ إِتّْڒِيقْ حِيمَا أَذْ نْكمّڒْ مَارَّا ثَاسڭْذَا.“ ڒخْذنِّي إِسَامْحْ أَسْ.
\v 16 \add أَوَارْنِي ڒَامِي\add* إِتّْوَاسّغْضصْ يَاسُوع، يُوڒِي-د زڭْ وَامَانْ ذغْيَا، ؤُ تّْوَارْزْمنْ أَسْ إِجنْوَانْ، ؤُشَا إِژْرَا أَرُّوحْ ن أَربِّي إِهْوَا-د أَمْ ثَاذْبِيرْثْ، ثَارْسَا خَاسْ. \x ◘ \xo 3:‏16 \xt إِشا. 11‏:‏2؛ 42‏:‏1؛ يُوح. 1‏:‏32. \x*
\v 17 خْزَارْ، ثُوسَا-د إِشْثْ ن ثْمِيجَّا زڭْ إِجنْوَانْ، ثنَّا: ”ذ وَا ذ مِّي إِعِيزّنْ، ذَايسْ ؤُفِيغْ أَرْضَا إِنُو.“ \x ◘ \xo 3:‏17 \xt إِشا. 42‏:‏1؛ مت. 12‏:‏18؛ 17‏:‏5؛ مك. 1‏:‏11؛ لك. 9‏:‏35؛ كُول. 1‏:‏13؛ 2 بُط. 1‏:‏17. \x*  *
\b
\b
\c 4
\s1 إِبْڒِيسْ إِتّْجَارّبْ يَاسُوع ذِي ڒخْڒَا
\m 
\v 1 ڒخْذنِّي إِتّْوَانْذهْ يَاسُوع غَارْ ڒخْڒَا زِي أَرُّوحْ إِقدّْسنْ، حِيمَا أَذْ إِتّْوَاجَارّبْ زڭْ إِبْڒِيسْ. \f ◼ \fr 4:‏1 \ft \bd ’إِبْڒِيسْ‘\bd* - إِسمْ-أَ وَانِيثَا إِخْسْ أَذْ يِينِي ’ونِّي إِعيّْبنْ‘. إِبْڒِيسْ نتَّا ذ شِّيطَانْ أَمقّْرَانْ.\f*  \x ◘ \xo 4:‏1 \xt [مك. 1‏:‏12‏-‏13؛ لك. 4‏:‏1‏-‏13] — مك. 1‏:‏12؛ لك. 4‏:‏1.\x*
\v 2 أَوَارْنِي ڒَامِي ثُوغَا إِژُومّْ أَربْعِينْ ن وُوسَّانْ ذ أَربْعِينْ ن دْجْيَاڒِي، يُوسَا أَسْ-د جُّوعْ غَارْ ؤُنڭَّارْ.
\v 3 يُوسَا-د غَارسْ ؤُمْجَارَّابْ، إِنَّا أَسْ: ”مَاڒَا شكْ ذ مِّيسْ ن أَربِّي، إِنِي إِ إِژْرَا-يَا أَذْ ذوْڒنْ ذ أَغْرُومْ!“
\v 4 يَارَّا-د خَاسْ إِنَّا: ”أَقَا ثُورَا:
\b
\m \qt ’بْنَاذمْ وَارْ إِدَّارْ س وغْرُومْ وَاهَا،\qt*
\m \qt مَاشَا زِي كُوڒْ أَوَاڒْ\qt*
\m \qt إِ د-إِتّكّنْ زڭْ ؤُقمُّومْ ن أَربِّي.‘ “\qt* \x ◘ \xo 4:‏4 \xt أَعَوذ. 8‏:‏3\x*
\b
\m 
\v 5 ڒخْذنِّي يِيوْيِي ث إِبْڒِيسْ غَارْ ثنْذِينْثْ إِقدّْسنْ ؤُشَا إِسّْبدّْ إِ-ث غَارْ طَّارْفْ ن ثْزقَّا ن زَّاوشْثْ ثَامقّْرَانْثْ،
\v 6 إِنَّا أَسْ: ”مَاڒَا شكْ ذ مِّيسْ ن أَربِّي، إِوَا، نْضَارْ إِخفْ نّشْ غَارْ وَادَّايْ، مِينْزِي أَقَا ثُورَا:
\b
\m \qt ’أَذْ يُومُورْ لْمَالَاكَاثْ نّسْ خَاكْ،\qt*
\m \qt أَذْ شكْ كْسِينْثْ خْ إِفَاسّنْ نْسنْثْ،\qt*
\m \qt حِيمَا أَضَارْ نّشْ وَارْ إِنڭّحْ شَا أَژْرُو.‘ “\qt* \x ◘ \xo 4:‏6 \xt إِزهد. 91‏:‏11، 12. \x*
\b
\m 
\v 7 يَاسُوع إِنَّا أَسْ: ”ثُورَا عَاوذْ:
\b
\m \qt ’وَارْ تّْجَارَّابْ سِيذِي، أَربِّي نّشْ!‘ “\qt* \x ◘ \xo 4:‏7 \xt أَعَوذ. 6‏:‏16. \x*
\b
\m 
\v 8 يِيوْيِي ث عَاوذْ إِبْڒِيسْ غَارْ وذْرَارْ يُوعْڒَانْ أَطَّاسْ، إِسّْشنْ أَسْ مَارَّا ثِيڭلْذِيوِينْ ن دُّونشْثْ ذ ؤُعُودْجِي نْسنْثْ،
\v 9 إِنَّا أَسْ: ”أَذْ أَشْ وْشغْ مَارَّا مَانْ أَيَا، مَاڒَا ثوْضِيذْ أَيِي غَارْ إِضَارنْ، أَذْ أَيِي ثْسجْذذْ!“
\v 10 إِنَّا أَسْ يَاسُوع: ”رُوحْ، \add أَ\add* شِّيطَانْ، مِينْزِي ثُورَا:
\b
\m \qt ’سِيذِي، أَربِّي نّشْ، ؤُمِي غَا ثْسجْذذْ\qt*
\m \qt ؤُ إِ نتَّا وحّْذسْ ؤُمِي غَا ثْسخَّارذْ.‘ “\qt* \f ◼ \fr 4:‏10 \ft \bd ’شِّيطَانْ‘\bd* - أَقَا-ث ذ شِّيطَانْ أَمقّْرَانْ ونِّي إِدْجَانْ خْ مَارَّا شّْوَاطنْ.\f*  \x ◘ \xo 4:‏10 \xt أَعَوذ. 6‏:‏13؛ 10‏:‏20. \x*
\b
\m 
\v 11 ڒخْذنِّي إِجَّا إِ-ث إِبْڒِيسْ، ؤُ خْزَارْ، لْمَالَاكَاثْ ؤُسِينْثْ-إِ-د، ثُوغَا سخَّارنْثْ أَسْ.
\b
\s1 أَمزْوَارُو ن ثْسخَّارْثْ ن يَاسُوع ذِي لْجَالِيلْ
\m 
\v 12 ڒَامِي إِسْڒَا يَاسُوع بلِّي يُوحَانَّا ثُوغَا إِتّْوَاسلّمْ، إِرُوحْ غَارْ لْجَالِيلْ. \x ◘ \xo 4:‏12 \xt [مك. 1‏:‏14‏-‏20؛ لك. 4‏:‏14‏-‏15؛ لك. 5‏:‏1‏-‏11؛ 6‏:‏17‏-‏19؛ 16، 31؛ يُوح. 4‏:‏43] — مك. 1‏:‏14؛ لك. 4‏:‏14؛ 16‏:‏31؛ يُوح. 4‏:‏43. \x*
\v 13 إِجَّا نَّاصِيرَا ؤُشَا يُوسَا-د غَارْ كَافَارْنَاحُومْ، ثنِّي غَارْ طَّارْفْ ن ڒبْحَارْ، ذِي ثمُّورْثْ ن زِيبُولُونْ ذ نَافْثَالِي ؤُشَا إِزْذغْ ذِينْ
\v 14 حِيمَا أَذْ إِتّْوَاكمّڒْ مِينْ إِتّْوَانَّانْ زڭْ ؤُنَابِي إِشَاعْيَا ؤُمِي إِنَّا:
\b
\m 
\v 15 \qt ”ثَامُّورْثْ ن زِيبُولُونْ ذ ثمُّورْثْ ن نَافْثَالِي\qt*
\m \qt ذڭْ وبْرِيذْ ن ڒبْحَارْ،\qt*
\m \qt غَارْ ؤُجمَّاضْ ن لْ-ؤُرْذُونْ، لْجَالِيلْ ن ڒڭْنُوسْ.\qt* \x ◘ \xo 4:‏15 \xt إِشا. 8‏:‏23؛ 9‏:‏1. \x*
\m 
\v 16 \qt ڒْڭنْسْ إِ إِقِّيمنْ ذِي ثَادْجسْثْ\qt*
\m \qt إِژْرَا ثَافَاوْثْ ثَامقّْرَانْثْ،\qt*
\m \qt ؤُ خْ يِينِّي إِزذْغنْ\qt*
\m \qt ذِي ثمُّورْثْ ذ ثِيڒِي ن ڒْموْثْ،\qt*
\m \qt أَقَا ثنْقَارْ-د خَاسنْ ثْفَاوْثْ.“\qt* \x ◘ \xo 4:‏16 \xt إِشا. 9‏:‏1\x*
\b
\m 
\v 17 زِي سِّينْ إِبْذَا يَاسُوع إِتّْبَارّحْ، إِنَّا: ”ثُوبمْ مِينْزِي ثَاڭلْذِيثْ ن إِجنْوَانْ أَقَا ثُوذسْ-د.“ \x ◘ \xo 4:‏17 \xt مك. 1‏:‏15. \x*
\b
\m 
\v 18 ڒَامِي ثُوغَا نتَّا إِڭُّورْ خْ ثْمَا ن ڒبْحَارْ ن لْجَالِيلْ، إِژْرَا ثْنَاينْ ن وَاوْمَاثنْ، شِيمْعُونْ ؤُمِي قَّارنْ بُوطْرُوسْ، \add إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’ذ أَژْرُو‘\add*، ذ أَنْذْرَاوُوسْ ؤُمَاسْ، ثُوغَا نطَّارنْ ثْرَاشَّاوِينْ ذِي ڒبْحَارْ مِينْزِي نِيثْنِي ذ إِنيْمَارنْ ن إِسڒْمَانْ. \x ◘ \xo 4:‏18 \xt [مك. 1‏:‏16‏-‏20؛ لك. 5‏:‏1‏-‏11] — مك. 1‏:‏16. \x*
\v 19 إِنَّا أَسنْ يَاسُوع: ”ضْفَارمْ أَيِي-د، أَذْ كنِّيوْ أَرّغْ ذ إِنيْمَارنْ ن إِوْذَانْ.“
\v 20 سَّارْسنْ ذغْيَا ثِيرَاشِّيوِينْ نْسنْ، ضْفَارنْ ث.
\m 
\v 21 ڒَامِي يعْذُو سّنِّي، إِژْرَا ثْنَاينْ ن وَاوْمَاثنْ نّغْنِي، يَاعْقُوبْ مِّيسْ ن زَابْذِي ذ ؤُمَاسْ يُوحَانَّا، ثُوغَا أَثنْ أَكْ-ذ بَابَاثْسنْ زَابْذِي ذڭْ ؤُغَارَّابُو،عدّْڒنْ ثِيرَاشِّيوِينْ نْسنْ ؤُشَا نتَّا إِڒَاغَا خَاسنْ.
\v 22 ذغْيَا سمْحنْ ذڭْ ؤُغَارَّابُو ؤُ ذِي بَابَاثْسنْ، ضْفَارنْ ث.
\b
\m 
\v 23 ثُوغَا يَاسُوع إِتّنّضْ ذِي ثمُّورْثْ ن لْجَالِيلْ مَارَّا، إِسّڒْمَاذْ ذِي ثمْزِيذَاوِينْ نْسنْ، إِتّْبَارّحْ س ڒخْبَارْ أَصبْحَانْ ن ثْڭلْذِيثْ ؤُشَا إِسّْڭنْفَا كُوڒْ ڒهْڒَاشْ ذ كُوڒْ ڒعْيُوبَاثْ إِ إِدْجَانْ ذِي ڒْڭنْسْ. \x ◘ \xo 4:‏23 \xt [لك. 6‏:‏17‏-‏19]\x*
\v 24 إِفّغْ ڒخْبَارْ خَاسْ ذِي سُورِييَا مَارَّا، ؤُشَا إِوْينْ-د غَارسْ مَارَّا إِمهْڒَاشْ إِنِّي غَارْ إِدْجَا عْڒَامْ كُوڒْ ڒهْڒَاشْ ڒَا ذ يِينِّي ذَايْسنْ ڒحْرِيقْ ڒَا ذ إِنِّي ذَايْسنْ شّْوَاطنْ ڒَا ذ يِينِّي إِتّْبَارْكِيكِّيضنْ ؤُڒَا ذ إِنعْضَابنْ، ؤُشَا إِسّْڭنْفَا إِ-ثنْ.
\v 25 ضْفَارنْ ث-إِ-د أَطَّاسْ ن ڒْغَاشِي زِي لْجَالِيلْ، زِي ذِيكاپُولِيسْ، زِي ؤُرْشَالِيمْ، زِي يَاهُوذِييَّا ؤُ زڭْ ؤُجمَّاضْ ن لْ-ؤُرْذُونْ.
\b
\b
\c 5
\s1 أَبَارّحْ خْ وذْرَارْ
\m 
\v 1 ڒَامِي إِژْرَا يَاسُوع ڒْغَاشِي، يُوڒِي غَارْ وذْرَارْ، ؤُشَا أَوَارْنِي ڒَامِي ذِينْ إِقِّيمْ، ؤُسِينْ-د غَارسْ إِمحْضَارنْ نّسْ. \x ◘ \xo 5:‏1 \xt [مك. 9‏:‏50؛ لك. 6‏:‏20‏-‏23؛ 14‏:‏34‏-‏35]\x*
\v 2 ؤُشَا يَارْزمْ أَقمُّومْ نّسْ، إِسّڒْمذْ إِ-ثنْ، إِنَّا:
\b
\m 
\v 3 \qt سّعْذْ ن يِينِّي أَرُّوحْ نْسنْ إِزْڒضْ،\qt*
\m \qt مِينْزِي ثَاڭلْذِيثْ ن إِجنْوَانْ أَقَا-ت إِ نِيثْنِي.\qt* \x ◘ \xo 5:‏3 \xt إِشا. 57‏:‏15؛ 66‏:‏2؛ لك. 6‏:‏20. \x*
\m 
\v 4 \qt سّعْذْ ن يِينِّي إِتّشْضِيننْ،\qt*
\m \qt مِينْزِي نِيثْنِي أَذْ تّْوَاعزَّانْ.\qt* \x ◘ \xo 5:‏4 \xt إِشا. 61‏:‏2؛ 66‏:‏10، 13؛ لك. 6‏:‏21. \x*
\m 
\v 5 \qt سّعْذْ ن إِمْوَاضْعنْ،\qt*
\m \qt مِينْزِي نِيثْنِي أَذْ وَارْثنْ ثَامُّورْثْ.\qt* \x ◘ \xo 5:‏5 \xt إِزهد. 37‏:‏11. \x*
\m 
\v 6 \qt سّعْذْ ن يِينِّي إِتّْڒَاژَانْ\qt*
\m \qt ذ يِينِّي إِتّْفَاذنْ غَارْ ثْسڭْذَا،\qt*
\m \qt مِينْزِي نِيثْنِي أَذْ جِّيوْننْ.\qt* \x ◘ \xo 5:‏6 \xt إِشا. 55‏:‏1 \x*
\m 
\v 7 \qt سّعْذْ ن يِينِّي يَارحّْمنْ،\qt*
\m \qt مِينْزِي أَذْ غَارْسنْ ثِيڒِي أَرّحْمثْ.\qt*
\m 
\v 8 \qt سّعْذْ ن يِينِّي إِ غَارْ إِدْجَا ؤُڒْ إِزْذِيڭْ،\qt*
\m \qt مِينْزِي نِيثْنِي أَذْ ژَترنْ أَربِّي.\qt* \x ◘ \xo 5:‏8 \xt إِزهد. 15‏:‏2؛ 24‏:‏4؛ عبر. 12‏:‏14. \x*
\m 
\v 9 \qt سّعْذْ ن يِينِّي إِتّڭّنْ ڒهْنَا،\qt*
\m \qt مِينْزِي نِيثْنِي أَذْ تّْوَاسمَّانْ أَرَّاونْ ن أَربِّي.\qt*
\m 
\v 10 \qt سّعْذْ ن يِينِّي إِنّحْصَارنْ\qt*
\m \qt خْ سِّيبّثْ ن ثْسڭْذَا،\qt*
\m \qt مِينْزِي ثَاڭلْذِيثْ ن إِجنْوَانْ أَذْ غَارْسنْ ثِيڒِي.\qt* \x ◘ \xo 5:‏10 \xt 2 كُور. 4‏:‏10؛ 2 تِيم. 2‏:‏12؛ 1 بُط. 3‏:‏14. \x*
\m 
\v 11 \qt سّعْذْ إِ كنِّيوْ مَاڒَا تّْعَايَارنْ\qt*
\m \qt ؤُ تّْذَارَّاشنْ خَاومْ\qt*
\m \qt ؤُشَا أَذْ خَاومْ إِنِينْ\qt*
\m \qt عْڒَامْ كُوڒْ أَوَاڒنْ إِعفَّاننْ خْ سِّيبّثْ إِنُو،\qt*
\m \qt وَاخَّا سّْخَارِّيقنْ.\qt* \x ◘ \xo 5:‏11 \xt 1 بُط. 4‏:‏14. \x*
\m 
\v 12 \qt فَارْحمْ، سْڒِيوڒْومْ،\qt*
\m \qt مِينْزِي ڒْمُونثْ نْومْ ذ ثَامقّْرَانْثْ ذڭْ إِجنْوَانْ،\qt*
\m \qt مِينْزِي أَمُّو إِ ثُوغَا تّْذَارَّاشنْ إِنَابِييّنْ،\qt*
\m \qt إِنِّي قْبڒْ نْومْ.“\qt* \x ◘ \xo 5:‏12 \xt لك. 6‏:‏23. \x*
\b
\m 
\v 13 ”كنِّيوْ ذ \bd ثَامدْجَاحْثْ ن ثمُّورْثْ\bd*. مَاشَا مَاڒَا ثَامدْجَاحْثْ إِخْسَارْ ؤُڒذِّي نّسْ، مَامّشْ غَا نڭّْ أَذْ ت نَارّْ ذ ثَامدْجَاحْثْ؟ وَارْ ثْنفّعْ عَاذْ إِ وَالُو، حَاشَا أَذْ ثمّنْضَارْ غَارْ بَارَّا، أَذْ خَاسْعفْسنْ إِوْذَانْ.“
\m 
\v 14 ”كنِّيوْ ذ \bd ثَافَاوْثْ ن دُّونشْثْ\bd*. ثَانْذِينْثْ إِ إِتّْوَابْنَانْ خْ وذْرَارْ، وَارْ ثْزمَّارْ أَذْ ثنُّوفَّارْ.
\v 15 وَارْ سّْرقِّينْ ڒفْنَارْ ؤُشَا أَذْ ث سَّارْسنْ سَاذُو ڒْمُوذْ، مَاشَا أَذْ ث سَّارْسنْ خْ ڒْمرْفعْ، \add مَاحنْذْ\add* أَذْ يَارْغْ إِ مَارَّا إِنِّي إِدْجَانْ ذِي ثَادَّارْثْ. \x ◘ \xo 5:‏15 \xt مك. 4‏:‏21؛ لك. 8‏:‏16؛ 11‏:‏33. \x*
\v 16 جّمْ ثَافَاوْثْ نْومْ أَذْ ثَارْغْ إِ إِوْذَانْ، حِيمَا أَذْ ژَترنْ ڒخْذَايمْ نْومْ إِشْنَانْ، أَذْ سُّوعْڒَانْ بَابَاثْومْ إِ إِدْجَانْ ذڭْ إِجنْوَانْ.“ \x ◘ \xo 5:‏16 \xt 1 بُط. 2‏:‏12. \x*
\m 
\v 17 ”أَقَا أَذْ أَومْ إِتّْغِيڒْ أَقَا ؤُسِيغْ-د حِيمَا أَذْ سّْبطّْڒغْ \bd شَّارِيعَا نِيغْ إِنَابِييّنْ. نشّْ وَارْ د-ؤُسِيغْ شَا حِيمَا أَذْ سّْبطّْڒغْ، مَاشَا حِيمَا أَذْ كمّْڒغْ.\bd* \f ◼ \fr 5:‏17 \ft \bd ’شَّارِيعَا ن مُوسَا‘\bd* - إِخْسْ أَذْ يِينِي تَّاوْرَاثْ أَمْ مَامّشْ ذ أَسْ قَّارنْ وُوذَاينْ.\f*
\v 18 س ثِيذتّْ، نشّْ أَذْ أَومْ إِنِيغْ: أَڒْ إِ غَا إِعْذُو ؤُجنَّا ذ ثمُّورْثْ، وَارْ إِبطّڒْ ؤُڒَا ذ إِجّنْ ڒْحَارْفْ نِيغْ ذ إِشْثنْ ثَانقِّيطْ زِي شَّارِيعَا أَڒْ غَا يِيڒِي كُوڒْشِي. \x ◘ \xo 5:‏18 \xt لك. 16‏:‏17. \x*
\v 19 س ؤُيَا ونِّي إِ غَا إِسّْبطّْڒنْ زِي ثْوصَّا-يَا إِشْثنْ، وَاخَّا ذ ثَامژْيَانْثْ، ؤُشَا إِسّڒْمَاذْ إِوْذَانْ أَمُّو، أَذْ إِتّْوَاسمَّا ذ أَمژْيَانْ ذِي ثْڭلْذِيثْ ن إِجنْوَانْ، مَاشَا ونِّي زَّايْسنْثْ إِڭِّينْ ؤُ إِسّڒْمَاذْ إِ-ثنْثْ، نتَّا أَذْ إِتّْوَاسمَّا ذ أَمقّْرَانْ ذِي ثْڭلْذِيثْ ن إِجنْوَانْ. \x ◘ \xo 5:‏19 \xt يَاع. 2‏:‏10. \x*
\v 20 مِينْزِي نشّْ أَذْ أَومْ إِنِيغْ: مَاڒَا ثَاسڭْذَا نْومْ وَارْ ثْمقَّارْ شَا خْ ثنِّي ن إِمْسڒْمَاذنْ ن إِذْلِيسنْ ذ ثنِّي ن إِفَارِيسِييّنْ، س ثِيذتّْ وَارْ ثتِّيذْفمْ شَا غَارْ ثْڭلْذِيثْ ن إِجنْوَانْ!“
\b
\m 
\v 21 ”أَقَا ثسْڒِيمْ بلِّي إِتّْوَانَّا إِ ڒجْذُوذْ: \bd ’وَارْ نقّْ!‘\bd*، ؤُ: ’ونِّي إِنقّنْ، أَذْ إِتّْوَاحَاسبْ!‘ \x ◘ \xo 5:‏21 \xt ؤُف. 20‏:‏13؛ أَعَوذ. 5‏:‏17. \x*
\v 22 مَاشَا نشّْ أَذْ أَومْ إِنِيغْ: مَارَّا ونِّي إِتّْخيَّاقنْ خْ ؤُمَاسْ بْڒَا سِّيبّثْ، نْهْڒَا مَا أَذْ خَاسْ إِتّْوَاحَاكمْ، ؤُ مَارَّا ونِّي إِقَّارنْ إِ ؤُمَاسْ: ’أَذْ خَاكْ سُّوسْفغْ!‘، أَذْ إِتّْوَاحْكمْ خَاسْ زَّاثْ إِ جْمَاعثْ \add ثَامقّْرَانْثْ\add*، ؤُ ونِّي إِقَّارنْ: ’\add أَ\add* أَبُوهَاڒِي!‘ أَذْ إِتّْوَاحَاكمْ، أَذْ يَاذفْ غَارْ ثْمسِّي ن جهنَّامَا. \f ◼ \fr 5:‏22 \fk جْمَاعثْ \bdit ثَامقّْرَانْثْ\bdit*‘ - نِيغْ: ’جْمَاعثْ ن ڒْحُوكَّامْ إِمقّْرَاننْ ن وُوذَاينْ‘.\f*
\v 23 مَاڒَا ثْقدّْمذْ ثَاوْهِيبْثْ نّشْ خْ ؤُعَالْطَارْ \add مِينْ خفْ سَّارْسنْ ثِيغَارْصَا ذ ثوْهِيبِينْ\add*، ؤُشَا ذِينِّي ثْعقْڒذْ بلِّي ؤُمَاشْ أَقَا-ث شَا خَاكْ،
\v 24 أجّْ ثَاوْهِيبْثْ نّشْ \add ذِينْ\add* زَّاثْ إِ ؤُعَالْطَارْ، رُوحْ أَمزْوَارُو، ثْصڒْحذْ أَكْ-ذ ؤُمَاشْ، خنِّي ذْوڒْ-د، ؤُشَا أوْشْ ثَاوْهِيبْثْ نّشْ.
\v 25 إِڒِي ثْوجْذذْ إِ وصْڒَاحْ أَكْ-ذ وغْرِيمْ نّشْ ؤُمِي شكْ عَاذْ أَكِيذسْ ذڭْ وبْرِيذْ، حِيمَا أَغْرِيمْ نّشْ وَارْ شكْ إِتِّيوِي غَارْ ڒْقَاضِي، \add خنِّي\add* ڒْقَاضِي أَذْ شكْ يَاوِي غَارْ ؤُمْخَازْنِي ؤُشَا أَذْ ثمّنْضَارذْ ذِي ڒحْبسْ. \x ◘ \xo 5:‏25 \xt لك. 12‏:‏58؛ أَفا. 4‏:‏26. \x*
\v 26 س ثِيذتّْ، نشّْ أَذْ أَشْ إِنِيغْ: وَارْ د-ثفّْغذْ سّنِّي، أَڒْ غَا ثْخدْجْصذْ أَصُولْذِي أَنڭَّارُو.“
\b
\m 
\v 27 أَقَا ثسْڒِيمْ بلِّي إِتّْوَانَّا: \bd ’وَارْ زنِّي شَا!‘\bd*، \x ◘ \xo 5:‏27 \xt ؤُف. 20‏:‏14؛ أَعَوذ. 5‏:‏18. \x*
\v 28 \add مَاشَا\add* نشّْ أَذْ أَومْ إِنِيغْ، مَارَّا ونِّي إِ غَا إِخْزَارنْ غَارْ ثمْغَارْثْ س نّشْوثْ، أَقَا إِزْنَا ذغْيَا أَكِيذسْ ذڭْ وُوڒْ نّسْ. \x ◘ \xo 5:‏28 \xt أَيُوبْ 31‏:‏1؛ إِزهد. 119‏:‏37. \x*
\v 29 مَاڒَا ثسّنْقَارْضْ شكْ ثِيطّْ نّشْ ثَافُوسشْثْ، قسّْ إِ-ت، نْضَارْ إِ-ت خَاكْ. إِحْڒَا أَشْ مَاڒَا إِودَّارْ إِجّْ ن طَّارْفْ \add ن أَرِّيمثْ نّشْ\add* خْ ؤُوطُّو ن أَرِّيمثْ نّشْ مَارَّا ذِي جهنَّامَا. \x ◘ \xo 5:‏29 \xt مت. 18‏:‏8؛ مك. 9‏:‏43. \x*
\v 30 مَاڒَا ثسّنْقَارْضْ شكْ أَفُوسْ نّشْ أَفُوسِي، قسّْ إِ-ث، نْضَارْ إِ-ث خَاكْ، مِينْزِي إِحْڒَا أَشْ مَاڒَا إِودَّارْ إِجّْ ن طَّارْفْ \add ن أَرِّيمثْ نّشْ وَاهَا\add* خْ ؤُوطُّو ن أَرِّيمثْ نّشْ مَارَّا ذِي جهنَّامَا.“
\b
\m 
\v 31 ”أَقَا إِتّْوَانَّا عَاوذْ: \bd ’ونِّي إِ غَا إِدْجْفنْ إِ ثمْغَارْثْ نّسْ، أَذْ أَسْ إِوْشْ ثَابْرَاثْ ن وَادْجَافْ!‘\bd* \x ◘ \xo 5:‏31 \xt [مت. 19‏:‏9؛ مك. 10‏:‏11‏-‏12؛ لك. 16‏:‏18] — ڒخْڒ. 30‏:‏2؛ أَعَوذ. 23‏:‏20‏-‏22؛ 24‏:‏1؛ \x*
\v 32 مَاشَا نشّْ أَذْ أَومْ إِنِيغْ: مَارَّا ونِّي إِ غَا إِدْجْفنْ إِ ثمْغَارْثْ نّسْ، وَارْ إِدْجِي زِي سِّيبّثْ ن فَارْقْ-شّْغڒْ، إِتَّارَّا إِ-ت أَذْ ثزْنَا، ؤُشَا ونِّي إِ غَا إِمڒْشنْ ثنِّي ؤُمِي إِدْجْفنْ، أَقَا نتَّا إِزْنَا.“ \x ◘ \xo 5:‏32 \xt مت. 19‏:‏7؛ مك. 10‏:‏4، 11؛ لك. 16‏:‏18؛ 1 كُور. 7‏:‏10. \x*
\b
\m 
\v 33 ”أَقَا ثسْڒِيمْ عَاوذْ بلِّي إِتّْوَانَّا إِ ڒجْذُوذْ: \bd ’وَارْ ثجَّادْجِيذْ ژُورْ، \bdit مَاشَا\bdit* أڭّْ مِينْ ثجُّودْجذْ إِ سِيذِي!‘\bd* \x ◘ \xo 5:‏33 \xt ؤُف. 20‏:‏7؛ لَاوِي 19‏:‏12؛ أَعَوذ. 5‏:‏11؛ 23‏:‏22 \x*
\v 34 \add مَاشَا\add* نشّْ أَذْ أَومْ إِنِيغْ: وَارْ ثجَّادْجَامْعمَّارْصْ، ؤُڒَا غَارْ ؤُجنَّا مِينْزِي نتَّا ذ ڒْعَارْشْ ن أَربِّي، \x ◘ \xo 5:‏34 \xt إِشا. 66‏:‏1؛ يَاع. 5‏:‏12. \x*
\v 35 ؤُڒَا غَارْ ثمُّورْثْ، مِينْزِي نتَّاثْ ذ ثَانبْذَاثْ سَاذُو إِضَارنْ نّسْ، ؤُڒَا غَارْ \add ثنْذِينْثْ ن\add* ؤُرْشَالِيمْ، مِينْزِي نتَّاثْ ذ ثَانْذِينْثْ ن ؤُجدْجِيذْ ذ أَمقّْرَانْ، \x ◘ \xo 5:‏35 \xt إِزهد. 48‏:‏3؛ إِشا. 66‏:‏1. \x*
\v 36 ؤُشَا وَارْ ثجَّادْجَامْ ؤُڒَا غَارْ ؤُزدْجِيفْ نّشْ، مِينْزِي وَارْ ثْزمَّارذْ أَذْ ثَارّذْ ؤُڒَا ذ إِجّْ ن ؤُژطُّو \add ن ؤُشُووَّافْ\add* ذ أَشمْڒَاڒْ نِيغْ ذ أَبَارْشَانْ.
\v 37 أَذْ إِقِّيمْ وَاوَاڒْ نْومْ ’وَاهْ!‘ ذ ’وَاهْ!‘، ’لَّ!‘ ذ ’لَّ!‘. مَانَا كْثَارْ زِي مَانْ أَيَا، أَقَا نتَّا زڭْ ؤُمْعفَّانْ.“
\b
\m 
\v 38 ”أَقَا ثسْڒِيمْ بلِّي إِتّْوَانَّا: \bd ’ثِيطّْ س ثِيطّْ ذ ثِيغْمسْثْ س ثغْمسْثْ!‘\bd*، \x ◘ \xo 5:‏38 \xt [لك. 6‏:‏29‏-‏30] — ؤُف. 21‏:‏24؛ لَاوِي 24‏:‏20؛ أَعَوذ. 19‏:‏21؛ \x*
\v 39 \add مَاشَا\add* نشّْ أَذْ أَومْ إِنِيغْ، وَارْ ثتّمْعَاڒَامْ شَا أَكْ-ذ إِجّْ ن ؤُعفَّانْ، مَاشَا ونِّي إِ غَا إِسّقّْڒنْ أَمڭِّيزْ نّشْ أَفُوسِي، سڒْقَا يَاسْ ؤُڒَا ذ \add أَمڭِّيزْ\add* نّغْنِي. \x ◘ \xo 5:‏39 \xt أَوڒن. 24‏:‏29؛ لك. 6‏:‏29؛ رُوم. 12‏:‏17؛ 1 كُور. 6‏:‏7؛ 1 تس. 5‏:‏15؛ 1 بُط. 3‏:‏9. \x*
\v 40 مَاڒَا ذِينْ حذْ إِخْسْ أَذْ كِيكْ إِڭّْ شّْرعْ ؤُشَا نتَّا أَذْ خَاكْ إِكّسْ ثْشَامِيرْ نّشْ، أجّْ إِ-ث أَذْ إِكْسِي ؤُڒَا ذ أَجدْجَابْ. \x ◘ \xo 5:‏40 \xt لك. 6‏:‏29\x*
\v 41 ونِّي خَاكْ إِڭِّينْ بزّزْ حِيمَا أَذْ كِيذسْ ثُويُورذْ إِجّْ ن كِيلُومِيثْرْ، ؤُيُورْ أَكِيذسْ ثْنَاينْ. \f ◼ \fr 5:‏41 \ft \bd ’إِجّْ ن كِيلُومِيثْرْ‘\bd* - س ثْرَامِيثْ ’إِجّْ ن مَايْلْ‘.\f*
\v 42 مَانْ ونْ ذ أَشْ إِ غَا إِتَّارنْ شَا ن ڒْحَاجّثْ، أوْشْ أَسْ ت، ؤُ ونِّي يَارزُّونْ أَذْ خَاكْ يَارْضڒْ، وَارْ ذ ث تَّارَّا أَمنِّي.“ \x ◘ \xo 5:‏42 \xt أَعَوذ. 15‏:‏8؛ لك. 6‏:‏35. \x*
\b
\m 
\v 43 ”أَقَا ثسْڒِيمْ بلِّي إِتّْوَانَّا: \bd ’أَذْ ثخْسذْ جَّارْ نّشْ، أَذْ ثْشَارْهذْ ڒعْذُو نّشْ!‘\bd* \x ◘ \xo 5:‏43 \xt [لك. 6‏:‏27‏-‏28، 32‏-‏36] — لَاوِي 19‏:‏18\x*
\v 44 مَاشَا نشّْ أَذْ أَومْ إِنِيغْ: خْسمْ ڒْعذْيَانْ نْومْ ؤُ بَارْكمْ إِنِّي كنِّيوْ إِنعّْڒنْ، ڭّمْ ثْشُونِي إِ يِينِّي كنِّيوْ إِشَارّْهنْ، ژَتدْجمْ إِ يِينِّي كنِّيوْ إِتَّاوْينْ ذ إِمحْبَاسْ ذ يِينِّي خَاومْ إِتّْذَارَّاشنْ، \x ◘ \xo 5:‏44 \xt لك. 6‏:‏27؛ 23‏:‏34؛ ڒخ. 7‏:‏60؛ رُوم. 12‏:‏20؛ 1 كُور. 4‏:‏13؛ 1 بُط. 2‏:‏23. \x*
\v 45 حِيمَا أَذْ ثِيڒِيمْ ذ ثَارْوَا ن بَابَاثْومْ إِ إِدْجَانْ ذڭْ إِجنْوَانْ، مِينْزِي نتَّا إِسّْنقَّارْ ثَافُوشْثْ نّسْ خْ إِصبْحَاننْ ذ إِعفَّاننْ، ؤُشَا نتَّا يَارخُّو-د إِ ونْژَارْ، حِيمَا أَذْ إِوّثْ خْ إِمْسڭَّاذنْ ؤُ خْ يِينِّي وَارْ إِسڭّْذنْ.
\v 46 مِينْزِي مَاڒَا ثخْسمْ إِنِّي كنِّيوْ إِتّخْسنْ، مَانْ أَرْبحْ إِ غَارْومْ؟ مَا وَارْ تّڭّنْ أَيْثْ ن ضَّارِيبَا ؤُڒَا أَمُّو؟ \f ◼ \fr 5:‏46 \ft \bd ’أَيْثْ ن ضَّارِيبَا‘\bd* - نِيغْ ’إِعشَّارنْ‘. أَيْثْ ن ضَّارِيبَا نِيثْنِي ذ ؤُذَاينْ إِ إِخدّْمنْ أَكْ-ذ ڒْمخْزنْ ن إِرُومَانِييّنْ، جمّْعنْ ضَّارِيبَا. شَا زَّايْسنْ كْسِينْ زِي ضَّارِيبَا إِ يِيخفْ نْسنْ.\f*  \x ◘ \xo 5:‏46 \xt لك. 6‏:‏32. \x*
\v 47 مَاڒَا ثْسدْجْممْ خْ وَاوْمَاثنْ نْومْ وَاهَا، مِينْ إِ ثتّڭّمْ كْثَارْ \add خْ ونّغْنِي\add*؟ مَا وَارْ تّڭّنْ أَيْثْ ن ضَّارِيبَا ؤُڒَا أَمُّو؟
\v 48 س ؤُيَا إِڒِيمْ نِيشَانْ قَاعْ أَمْ مَامّشْ ؤُڒَا ذ بَابَاثْومْ إِ إِدْجَانْ ذڭْ إِجنْوَانْ إِدْجَا نِيشَانْ قَاعْ.“ \x ◘ \xo 5:‏48 \xt أَمز. 17‏:‏1\x*
\b
\b
\c 6
\m 
\v 1 ”حْضَامْ، وَارْ ثْصدَّاقمْ زَّاثْ إِ إِوْذَانْ، حِيمَا أَذْ كنِّيوْ ژَترنْ. مَاڒَا أَمْيَا، وَارْ غَارْومْ إِتِّيڒِي بُو ڒَاجَارْ زِي بَابَاثْومْ إِ إِدْجَانْ ذڭْ إِجنْوَانْ.
\v 2 \bd مَاڒَا ثْصدّْقذْ\bd*، وَارْ ت تّڭّْ ذِي ڒْبُوقْ أَمْ مَامّشْ ث تّڭّنْ إِمْنَافْقنْ ذِي ثمْزِيذَاوِينْ ؤُ ذِي زّْنَاقِي، حِيمَا أَذْ ثنْ شنّْعنْ إِوْذَانْ. س ثِيذتّْ نشّْ أَذْ أَومْ إِنِيغْ، نِيثْنِي أَقَا ؤُفِينْ ڒَاجَارْ نْسنْ زِي بعْذَا. \x ◘ \xo 6:‏2 \xt رُوم. 12‏:‏8. \x*
\v 3 \add مَاشَا\add* شكْ، خْمِي غَا ثْصدّْقذْ، إِتّْخصَّا أَفُوسْ نّشْ أَزڒْمَاضْ وَارْ إِسِّينْ مِينْ إِتّڭّْ ؤُفُوسِي نّشْ،
\v 4 حِيمَا صّذْقثْ نّشْ أَذْ ثِيڒِي س ثْنُوفّْرَا ؤُشَا بَابَاشْ، ونِّي إِتّْوَاڒَانْ ذِي ثْنُوفّْرَا، أَذْ شكْ إِخدْجصْ س بْطَايْطَايْ.“ \x ◘ \xo 6:‏4 \xt لك. 14‏:‏14. \x*
\b
\m 
\v 5 ”\bd مَاڒَا ثژُّودْجذْ\bd*، وَارْ تِّيڒِي شَا أَمْ يِيمْنَافْقنْ إِنِّي ؤُمِي إِعْجبْ أَسنْ ڒْحَاڒْ أَذْ ژَّادْجنْ أَمْ بدّنْ ذِي ثمْزِيذَاوِينْ ذ ثْغمُّورَا ن زّْنَاقِي حِيمَا أَذْ ثنْ ژَترنْ إِوْذَانْ. س ثِيذتّْ نشّْ أَذْ أَومْ إِنِيغْ، أَقَا نِيثْنِي ؤُفِينْ ڒَاجَارْ نْسنْ زِي بعْذَا. \x ◘ \xo 6:‏5 \xt [لك. 11‏:‏2‏-‏4] \x*
\v 6 مَاشَا شكْ، مَاڒَا ثژُّودْجذْ، أَذفْ غَارْ وخَّامْ نّشْ، بلّعْ ثَاوَّارْثْ، ژَّادْجْ إِ بَابَاشْ ونِّي إِدْجَانْ ذِي ثْنُوفّْرَا، ؤُشَا بَابَاشْ إِ إِتّْوَاڒَانْ ذِي ثْنُوفّْرَا ذ نتَّا إِ شكْ إِ غَا إِخدْجْصنْ س بْطَايْطَايْ. \x ◘ \xo 6:‏6 \xt 2 إِج. 4‏:‏33؛ ڒخ. 10‏:‏4. \x*
\v 7 مَاڒَا ثژُّودْجمْ وَارْ تّْعَاوَاذمْ إِ وَاوَاڒْ أَمْ مَامّشْ تّْژَادْجَانْ لْكُوفَّارْ، مِينْزِي إِتّْغِيڒْ أَسنْ س وَاوَاڒنْ \add نْسنْ\add* أَطَّاسْ أَذْ أَسنْ إِتّْوَاسڒْ. \x ◘ \xo 6:‏7 \xt 1 إِج. 18‏:‏28؛ إِشا. 1‏:‏15. \x*
\v 8 وَارْ تِّيڒِيمْ خنِّي أَمْ نِيثْنِي، مِينْزِي بَابَاثْومْ إِسّنْ مِينْ ثحْذَاجمْ قْبڒْ ذ أَسْ إِ غَا ثتَّارمْ شَا.
\v 9 أَمُّو إِ غَا ثژَّادْجمْ كنِّيوْ:
\b
\m \qt ’أَ بَابَاثْنغْ إِ إِدْجَانْ ذڭْ إِجنْوَانْ،\qt*
\m \qt أَذْ يِيڒِي إِسمْ نّشْ إِتّْوَاقدّسْ،\qt* \x ◘ \xo 6:‏9 \xt لك. 11‏:‏2. \x*
\m 
\v 10 \qt أجّْ أَذْ د-ثَاسْ ثْڭلْذِيثْ نّشْ،\qt*
\m \qt أَذْ يِيڒِي ڒْخَاضَارْ نّشْ\qt*
\m \qt أَمْ ذڭْ ؤُجنَّا أَمُّو عَاوذْ ذِي ثمُّورْثْ.\qt*
\m 
\v 11 \qt أوْشْ أَنغْ أَسّْ-أَ أَغْرُومْ إِ نهْذَاجْ.\qt*
\m 
\v 12 \qt غْفَارْ أَنغْ إِمَارْوُوسَا نّغْ،\qt*
\m \qt أَمْ مَامّشْ نْسَامحْ عَاوذْ\qt*
\m \qt إِ يِينِّي د أَنغْ إِتُّورْسنْ،\qt*
\m 
\v 13 \qt ؤُ وَارْ ذ أَنغْ سِيذِيفْ شَا ذڭْ ؤُجَارّبْ،\qt*
\m \qt مَاشَا فكّْ أَنغْ زڭْ ؤُمْعفَّانْ.\qt*
\m \qt مِينْزِي ثَاڭلْذِيثْ ذ جّهْذْ ذ ؤُعُودْجِي\qt*
\m \qt أَذْ إِڒِينْ إِ شكْ إِ ڒبْذَا قَاعْ!‘\qt* \x ◘ \xo 6:‏13 \xt مت. 13‏:‏19. \x*
\b
\m 
\v 14 مَاغَارْ مَاڒَا كنِّيوْ ثْسَامْحمْ إِ إِوْذَانْ إِ إِعذِّيينْ نْسنْ، ؤُڒَا ذ بَابَاثْومْ إِ إِدْجَانْ ذڭْ إِجنْوَانْ أَذْ أَومْ إِغْفَارْ. \x ◘ \xo 6:‏14 \xt مك. 11‏:‏25؛ كُول. 3‏:‏13. \x*
\v 15 مَاشَا مَاڒَا كنِّيوْ وَارْ ثتّْسِيمِيحمْ إِ إِوْذَانْ، أَقَا ؤُڒَا ذ بَابَاثْومْ وَارْ إِغفَّارْ شَا إِعذِّيينْ نْومْ.“ \x ◘ \xo 6:‏15 \xt مت. 18‏:‏35؛ يَاع. 2‏:‏13. \x*
\b
\m 
\v 16 ”\bd ڒَامِي ثْژُومّمْ\bd*، وَارْ تّڭّمْ أَغمْبُوبْ أَبَارْشَانْ أَمْ يِيمْنَافْقنْ، إِنِّي إِسّْنقْڒَابنْ أَغمْبُوبْ نْسنْ حِيمَا أَذْ ثنْ ژَترنْ إِوْذَانْ بلِّي أَقَا ژُومّنْ. س ثِيذتّْ نشّْ أَذْ أَومْ إِنِيغْ، أَقَا نِيثْنِي ؤُفِينْ ڒَاجَارْ نْسنْ زِي بعْذَا. \x ◘ \xo 6:‏16 \xt إِشا. 58‏:‏3؛ مت. 9‏:‏14؛ مك. 2‏:‏18؛ لك. 5‏:‏33. \x*
\v 17 \add مَاشَا\add* شكْ، مَاڒَا ثْژُومّذْ، ذْهنْ أَزدْجِيفْ نّشْ ؤُشَا سِيرذْ أَغمْبُوبْ نّشْ،
\v 18 حِيمَا وَارْ ثْبِينِيذْ شَا إِ إِوْذَانْ بلِّي ثتّْژُومّذْ، مَاشَا إِ بَابَاشْ ونِّي إِدْجَانْ ذِي ثْنُوفّْرَا، ؤُشَا بَابَاشْ إِ إِتّْوَاڒَانْ ذِي ثْنُوفّْرَا، أَقَا نتَّا إِ شكْ إِ غَا إِخدْجْصنْ.“
\b
\m 
\v 19 ”\bd وَارْ سْمُونَامْ شَا ڒكْنُوزْ إِ يِيخفْ نْومْ ذَا ذِي دُّونشْثْ\bd* مَانِي إِ ثنْ غَا ثشّْ ثْشِينْذَا ذ دّْرَا، ؤُ مَانِي غَا سّْنُوقّْبنْ إِخوَّاننْ، أَذْ \add ثنْ\add* أَشَارنْ، \x ◘ \xo 6:‏19 \xt [لك. 12‏:‏33‏-‏34؛ 11‏:‏34‏-‏36؛ 16‏:‏13] — أَوڒن. 23‏:‏4؛ عبر. 13‏:‏5؛ يَاع. 5‏:‏1. \x*
\v 20 \add مَاشَا\add* سْمُونمْ إِ يِيخفْ نْومْ ڒكْنُوزْ ذڭْ ؤُجنَّا مَانِي وَارْ ثنْ ثتّتّْ شَا ثْشِينْذَا ذ دّْرَا، ؤُ مَانِي وَارْ سّْنُوقُّوبنْ إِخوَّاننْ، وَارْ \add ثنْ\add* تَّاشَارنْ. \x ◘ \xo 6:‏20 \xt لك. 12‏:‏33؛ 1 تِيم. 6‏:‏19. \x*
\v 21 مِينْزِي مَانِي غَا يِيڒِي ڒْكنْزْ نّشْ، أَقَا أَذْ ذِينْ يِيڒِي ؤُڒَا ذ ؤُڒْ نّشْ.“
\b
\m 
\v 22 ”\bd ڒفْنَارْ ن أَرِّيمثْ نتَّا ذ ثِيطّْ.\bd* مَاڒَا خنِّي ثِيطّْ نّشْ أَقَا ثصْفَا، أَذْ ثِيڒِي أَرِّيمثْ نّشْ مَارَّا ذ ثَافَاوْثْ. \x ◘ \xo 6:‏22 \xt لك. 11‏:‏34‏-‏36؛\x*
\v 23 مَارَا ثِيطّْ نّشْ ذ ثَاعفَّانْثْ، خنِّي أَذْ ثِيڒِي أَرِّيمثْ نّشْ مَارَّا ذ ثَادْجسْثْ. مَاڒَا ثَافَاوْثْ ثنِّي ذَايكْ ذ ثَادْجسْثْ، مشْحَاڒْ ثمْغَارْ ثَادْجسْثْ!
\b
\m 
\v 24 \bd ؤُڒَا ذ إِجّْ وَارْ إِزمَّارْ أَذْ إِخْذمْ إِ ثْنَاينْ ن إِسِيذِيثنْ،\bd* مِينْزِي \add خنِّي\add* نتَّا أَذْ إِشَارْهْ إِجّنْ، أَذْ إِخْسْ ونّغْنِي، نِيغْ أَذْ إِوقَّارْ إِجّنْ، أَذْ إِسّحْقَارْ ونّغْنِي. كنِّيوْ وَارْ ثْزمَّارمْ أَذْ ثْسخَّارمْ إِ أَربِّي ذ ثنْعَاشِينْ.“ \x ◘ \xo 6:‏24 \xt لك. 16‏:‏13. \x*
\b
\m 
\v 25 ”س ؤُيَا نشّْ أَذْ أَومْ إِنِيغْ: ’\bd وَارْ كسِّيمْ أَمْنُوسْ ذِي ثُوذَارْثْ نْومْ\bd*، مِينْ غَا ثشّمْ نِيغْ مِينْ غَا ثسْومْ، ؤُڒَا إِ أَرِّيمثْ نْومْ مَامّشْ ت إِ غَا ثسّْيَارْضمْ. خْزَارمْ، مَا وَارْ ثحْڒِي ثُوذَارْثْ خْ مَاشَّا نِيغْ أَرِّيمثْ خْ وَارُّوضْ؟ \x ◘ \xo 6:‏25 \xt [لك. 12‏:‏22‏-‏34] — إِزهد. 37‏:‏5؛ 55‏:‏23؛ فِيل. 4‏:‏6؛ 1 تِيم. 6‏:‏8؛ 1 بُط. 5‏:‏7. \x*
\v 26 خْزَارمْ غَارْ إِجْضَاضْ ن ؤُجنَّا، أَقَا نِيثْنِي وَارْ زَارّْعنْ، وَارْ مجَّارنْ ؤُشَا وَارْ تّْخمِّيڒنْ ذِي ڒمْرَاسِي. وَاخَّا أَمنِّي بَابَاثْومْ إِ إِدْجَانْ ذڭْ إِجنْوَانْ إِ ثنْ إِسّشَّانْ. خْزَارمْ، مَا كنِّيوْ وَارْ ثسّكّْوِيمْ شَا كْثَارْ أَطَّاسْ خَاسنْ؟ \x ◘ \xo 6:‏26 \xt أَيُوبْ 38‏:‏41؛ إِزهد. 147‏:‏9. \x*
\v 27 مَانْ ونْ زَّايْومْ إِزمَّارْ س ومْنُوسْ نّسْ أَذْ يَارْنِي \add مْغِيرْ\add* إِجّْ ن ؤُغِيڒْ ذِي ثُوزّڭَّارْثْ نّسْ؟
\v 28 ؤُ مَايمِّي ثْكسِّيمْ أَمْنُوسْ إِ وَارُّوضْ؟ خْزَارمْ مَامّشْغمّْينْثْ ثْلِيلِّيشِينْ ذڭْ إِيَّارْ. نِيثنْثِي وَارْ خدّْمنْثْ، وَارْ تّْقَارْضْشنْثْ، \f ◼ \fr 6:‏28 \ft \bd ’ثِيلِيلِّيشِينْ‘\bd* - إِجّْ ن مَارْكَا ن نُّووَارَاثْ ذَايْسنْ أَژْرِي أَطَّاسْ.\f*
\v 29 \add مَاشَا\add* نشّْ أَذْ أَومْ إِنِيغْ، ؤُڒَا ذ سُولِيمَانْ ذِي مَارَّا أَعُودْجِي نّسْ وَارْ يَارْضْ شَا أَمْ يِيجّنْ زَّايْسنْ.
\v 30 مَاڒَا أَربِّي إِسّْيَارْضْ أَمُّو أَرْبِيعْ ن إِيَّارْ إِ إِدْجَانْ أَسّْ-أَ ؤُشَا ثِيوشَّا أَذْ إِمّنْضَارْ ذِي ثفْقُونْثْ، مَا خنِّي وَارْ كنِّيوْ \add إِسّْيِيرّضْ\add* أَطَّاسْ حْسنْ زَّايسْ، \add أَ\add* كنِّيوْ إِ ذِي إِدْجَا ذْرُوسْ ن لْ-إِيمَانْ؟
\v 31 س ؤُيَا وَارْ كسِّيمْ شَا أَمْنُوسْ، وَارْ قَّارمْ: ’مِينْ غَا نشّْ؟‘، ؤُ: ’مِينْ غَا نْسُو؟‘، نِيغْ: ’مِينْ غَا نْيَارْضْ؟‘
\v 32 مَاغَارْ ڒڭْنُوسْ ن دُّونشْثْ أَرزُّونْ مَانْ أَيَا مَارَّا، \add مَاشَا\add* بَابَاثْومْ إِ إِدْجَانْ ذڭْ إِجنْوَانْ إِسّنْ أَقَا ثحْذَاجمْ مَانْ أَيَا مَارَّا.
\v 33 أَرْزُومْ أَمزْوَارُو خْ ثْڭلْذِيثْ ن أَربِّي ذ ثْسڭْذَا نّسْ، ؤُشَا مَانْ أَيَا مَارَّا أَذْ غَارْومْ إِمَّارْنِي عَاوذْ. \x ◘ \xo 6:‏33 \xt 1 إِج. 3‏:‏13؛ إِزهد. 37‏:‏25؛ 55‏:‏23. \x*
\v 34 س ؤُيَا وَارْ كسِّيمْ أَمْنُوسْ إِ \add مِينْ إِ غَا يِيڒِي\add* ثِيوشَّا، مِينْزِي ثِيوشَّا أَذْ ثكْسِي أَمْنُوسْ إِ يِيخفْ نّسْ. إِشْفَا إِ \add كُوڒْ\add* أَسّْ ثُوعفّْنَا نّسْ.“
\b
\b
\c 7
\m 
\v 1 ”\bd وَارْ حكّْممْ، حِيمَا وَارْ ثتّْوَاحَاكَاممْ،\bd*\x ◘ \xo 7:‏1 \xt [لك. 6‏:‏37‏-‏38؛ 41‏-‏42] — رُوم. 2‏:‏1؛ 1 كُور. 4‏:‏3، 5. \x*
\v 2 مِينْزِي عْلَاحْسَابْ ڒْحُوكْمْ إِ زِي غَا ثْحكْممْ، أَذْ ثتّْوَاحَاكْممْ، ؤُ عْلَاحْسَابْ ڒعْبَارْ إِ زِي غَا ثعْبَارمْ، أَذْ ثتّْوَاعْبَارمْ عَاوذْ. \x ◘ \xo 7:‏2 \xt مك. 4‏:‏24؛ لك. 6‏:‏38. \x*
\v 3 مَايمِّي ثْخزَّارذْ غَارْ \bd ؤُخشِّيوْ\bd* ذِي ثِيطّْ ن ؤُمَاشْ، \add مَاشَا\add* وَارْ ثْحكَّارذْ شَا إِ \bd ثحْنَاشْثْ\bd* ثنِّي ذِي ثِيطّْ نّشْ؟ \x ◘ \xo 7:‏3 \xt لك. 6‏:‏41، 42. \x*
\v 4 خنِّي مَامّشْ غَا ثڭّذْ أَذْ ثِينِيذْ إِ ؤُمَاشْ: ’أجّْ أَيِي أَذْ أَشْ د-سُّوفّْغغْ أَخشِّيوْ زِي ثِيطّْ نّشْ‘، \add ؤُشَا\add* خْزَارْ، أَقَا شكْ غَاركْ ثَاحْنَاشْثْ ذِي ثِيطّْ نّشْ؟
\v 5 شكْ، \add أَ\add* أَمْنَافقْ، سُوفّغْ-د أَمزْوَارُو ثَاحْنَاشْثْ زِي ثِيطّْ نّشْ، خنِّي ثْزمَّارذْ أَذْ ثخْزَارذْ مْلِيحْ حِيمَا أَذْ ثسُّوفّْغذْ أَخشِّيوْ زِي ثِيطّْ ن ؤُمَاشْ. \x ◘ \xo 7:‏5 \xt أَوڒن. 18‏:‏17. \x*
\m 
\v 6 \bd وَارْ تِّيشمْ مِينْ إِقدّْسنْ إِ يِيطَانْ\bd*، وَارْ نطَّارمْ شَا ثِييَاقُوثِينْ نْومْ إِ إِڒْفَانْ، حِيمَا وَارْ خَاسنْثْعفّْسنْ س إِضَارنْ نْسنْ ؤُشَا أَذْ \add غَارْومْ\add* د-نْقڒْبنْ، أَذْ كنِّيوْ مزّْقنْ.“ \x ◘ \xo 7:‏6 \xt أَوڒن. 9‏:‏8؛ 23‏:‏9. \x*
\b
\m 
\v 7 ”\bd تَّارمْ، أَذْ أَومْ إِمّوْشْ\bd*، أَرْزُومْ، أَذْ ثَافمْ، سْقَارْقْبمْ، أَذْ أَومْ إِتّْوَارْزمْ. \x ◘ \xo 7:‏7 \xt [لك. 11‏:‏9‏-‏13] — مت. 21‏:‏22؛ مك. 11‏:‏24؛ يُوح. 14‏:‏13؛ 16‏:‏24؛ يَاع. 1‏:‏5، 6؛ 1 يُوح. 3‏:‏22؛ 5‏:‏14. \x*
\v 8 مَاغَارْ مَارَّا ونِّي إِ غَا إِتَّارنْ، أَذْ إِطّفْ ؤُ ونِّي إِ غَا يَارْزُونْ أَذْ يَافْ، ؤُ ونِّي إِ غَا إِسّْقَارْقْبنْ أَذْ \add أَسْ\add* إِتّْوَارْزمْ. \x ◘ \xo 7:‏8 \xt أَوڒن. 8‏:‏17؛ إِرْم. 29‏:‏12. \x*
\v 9 نِيغْ مَانْ بْنَاذمْ جَارْ أَومْ، مَاڒَا مِّيسْ إِتَّارْ أَسْ أَغْرُومْ، أَذْ أَسْ إِوْشْ أَژْرُو؟
\v 10 نِيغْ مَاڒَا إِتَّارْ أَسْ ثَاسْڒمْثْ، أَذْ أَسْ إِوْشْ أَفِيغَارْ؟
\v 11 مَاڒَا كنِّيوْ، وَاخَّا كنِّيوْ ذ إِعفَّاننْ، أَقَا ثسّْنمْ مَامّشْ غَا ثوْشمْ مِينْ إِصبْحنْ إِ ثَارْوَا نْومْ، مشْحَاڒْ عَاذْ بَابَاثْومْ إِ إِدْجَانْ ذڭْ إِجنْوَانْ أَذْ يوْشْ مِينْ إِصبْحنْ إِ يِينِّي ذ أَسْ إِ غَا إِتَّارنْ! \x ◘ \xo 7:‏11 \xt أَمز. 6‏:‏5؛ 8‏:‏21. \x*
\v 12 قَاعْ أَمْ مَامّشْ ثخْسمْ أَذْ أَومْ ڭّنْ إِوْذَانْ، ڭّمْ أَمْيَا كنِّيوْ إِ نِيثْنِي، مِينْزِي مَانْ أَيَا ذ شَّارِيعَا ذ إِنَابِييّنْ.“ \x ◘ \xo 7:‏12 \xt لك. 6‏:‏31. \x*
\b
\m 
\v 13 ”\bd أَذْفمْ زِي ثوَّارْثْ إِحْصَارنْ\bd*، مِينْزِي ثَاوَّارْثْ ثمْغَارْ ؤُڒَا ذ أَبْرِيذْ إِ إِتَّاوْينْ غَارْ ؤُهلّكْ ذ مِيرِيوْ، ؤُشَا أَطَّاسْ إِ زَّايسْ إِتَّاذْفنْ. \x ◘ \xo 7:‏13 \xt [لك. 13‏:‏24] \x*
\v 14 مَامّشْ ثحْصَارْ ثوَّارْثْ ؤُ مَامّشْ إِمْژِي وبْرِيذْ إِ إِتَّاوْينْ غَارْ ثُوذَارْثْ! مْغِيرْ ذْرُوسْ ن يِينِّي ث إِتَّافنْ.“ \x ◘ \xo 7:‏14 \xt ڒخ. 14‏:‏22. \x*
\b
\m 
\v 15 ”\bd حْضَامْ إِخفْ نْومْ زڭْ إِنَابِييّنْ إِسّْخَارِّيقنْ\bd* إِ د-إِتَّاسنْ غَارْومْ س ثْهِيضُورْثْ ن إِزْمَارنْ، مَاشَا ذڭْ إِعذِّيسنْ نْسنْ أَقَا نِيثْنِي ذ ؤُشَّاننْ إِتّطّْفنْ. \x ◘ \xo 7:‏15 \xt [لك. 6‏:‏43‏-‏44؛ 13‏:‏25‏-‏27] — أَعَوذ. 13‏:‏4؛ إِرْم. 23‏:‏16؛ مت. 24‏:‏4؛ رُوم. 16‏:‏17؛ أَفا. 5‏:‏6؛ كُول. 2‏:‏8؛ 1 يُوح. 4‏:‏1.\x*
\v 16 زِي ڒْغِيدْجثْ نْسنْ أَذْ ثنْ ثسّْنمْ. مَا أَذْ ڒقْضنْ أَضِيڒْ زڭْ إِسنَّاننْ نِيغْ ثَازَارْثْ زِي ثْزڭّْوَارْثْ؟
\v 17 أَمُّو كُوڒْ ثَاشجَّارْثْ ثَاصبْحَانْثْ ثتَّاوِي-د ڒْغِيدْجثْ ثصْبحْ، ؤُشَا ثَاشجَّارْثْ ثَاعفَّانْثْ ثتَّاوِي-د ڒْغِيدْجثْ ثَاعفَّانْثْ. \f ◼ \fr 7:‏17 \ft \bd ’ثَاشجَّارْثْ‘\bd* - نِيغْ ’أَدَّاڭْ‘ (’إِدَّاڭنْ‘).\f*  \x ◘ \xo 7:‏17 \xt مت. 3‏:‏10؛ 12‏:‏33؛ مك. 11‏:‏13؛ لك. 8‏:‏8. \x*
\v 18 ثَاشجَّارْثْ ثَاصبْحَانْثْ وَارْ ثْزمَّارْ أَذْ ثوْشْ ڒْغِيدْجثْ ثَاعفَّانْثْ، ؤُشَا ثَاشجَّارْثْ ثَاعفَّانْثْ وَارْ ثْزمَّارْ أَذْ ثوْشْ ڒْغِيدْجثْ ثَاصبْحَانْثْ.
\v 19 كُوڒْ ثَاشجَّارْثْ ثنِّي وَارْ إِتِّيشنْ ڒْغِيدْجثْ ثصْبحْ، أَذْ ثتّْوَاقسّْ ؤُشَا أَذْ ثمّنْضَارْ ذِي ثْمسِّي.
\v 20 س ؤُينِّي أَذْ ثنْ ثسّْنمْ زِي ڒْغِيدْجثْ نْسنْ.“
\b
\m 
\v 21 ”\bd وَارْ إِدْجِي شَا كُوڒْ إِجّنْ ونِّي ذ أَيِي غَا إِنِينْ: ’أَ سِيذِي، أَ سِيذِي!‘\bd*، أَذْ يَاذفْ غَارْ ثْڭلْذِيثْ ن إِجنْوَانْ، مَاشَا ذ ونِّي إِتّڭّنْ مِينْ إِخْسْ بَابَا إِ إِدْجَانْ ذڭْ إِجنْوَانْ. \x ◘ \xo 7:‏21 \xt مت. 25‏:‏11؛ لك. 6‏:‏46؛ 13‏:‏25‏-‏27؛ ڒخ. 19‏:‏13؛ رُوم. 2‏:‏13؛ يَاع. 1‏:‏22. \x*
\v 22 أَطَّاسْ إِ ذ أَيِي غَا إِنِينْ ذڭْ وَاسّْ نِّي: ’أَ سِيذِي، أَ سِيذِي، مَا وَارْ نتّْنَابّْ شَا س يِيسمْ نّشْ، مَا وَارْ نُوژِّيڒْ خْ شّْوَاطنْ س يِيسمْ نّشْ ؤُ س يِيسمْ نّشْ مَا وَارْ نڭِّي أَطَّاسْ ن ڒعْجَايبْ؟‘ \x ◘ \xo 7:‏22 \xt إِرْم. 14‏:‏14؛ 27‏:‏15؛ لك. 13‏:‏26. \x*
\v 23 خنِّي نشّْ أَذْ أَسنْ إِنِيغْ نِيشَانْ: ’عمَّارْصْ وَارْ كنِّيوْ سِّينغْ، بعّْذمْ خَافِي، \add أَ\add* كنِّيوْ إِنِّي إِتّڭّنْ ڒْمُوعْصِييّثْ!‘ “ \x ◘ \xo 7:‏23 \xt إِزهد. 6‏:‏9؛ مت. 25‏:‏12،41؛ لك. 13‏:‏25، 27. \x*
\b
\m 
\v 24 ”\bd س ؤُيَا مَارَّا ونِّي إِتّسْڒَانْ إِ وَاوَاڒنْ إِنُو، إِتّڭّْ زَّايْسنْ\bd*، أَذْ إِتّْوَامْقُودَّا أَكْ-ذ إِجّْ ن بْنَاذمْ ذ أَمِيغِيسْ ونِّي إِبْنَانْ ثَادَّارْثْ نّسْ خْ سّدْجَاحْ. \x ◘ \xo 7:‏24 \xt إِرْم. 17‏:‏8؛ لك. 6‏:‏47؛ رُوم. 2‏:‏13؛ يَاع. 1‏:‏25. \x*
\v 25 خنِّي إِوْثَا ونْژَارْ، حمْڒنْ-د إِغزْرَانْ، سُوضنْ-د إِسمِّيضنْ ؤُشَا ڒقْفنْ ثَادَّارْثْ نِّي، \add مَاشَا\add* وَاخَّا أَمنِّي وَارْ د-ثوْضِي شَا، مِينْزِي ذْسَاسْ نّسْ إِمَّارْسْ خْ سّدْجَاحْ.
\v 26 \add مَاشَا\add* مَارَّا ونِّي إِتّسْڒَانْ إِ وَاوَاڒنْ إِنُو، وَارْ زَّايْسنْ إِتّڭّْ، أَذْ يِيڒِي أَمْ يِيجّْ ن بْنَاذمْ ذ أَفْغُوڒْ إِ إِبْنَانْ ثَادَّارْثْ نّسْ خْ إِجْذِي. \x ◘ \xo 7:‏26 \xt حِز. 13‏:‏11؛ رُوم. 2‏:‏13؛ يَاع. 1‏:‏23. \x*
\v 27 خنِّي إِوْثَا ونْژَارْ، حمْڒنْ-د إِغزْرَانْ، سُوضنْ-د إِسمِّيضنْ، ڒقْفنْ ثَادَّارْثْ نِّي ؤُشَا ثوْضَا، ثُوغَا أَوطُّو نّسْ ذ أَمقّْرَانْ.“
\b
\s1 أَنڭَّارْ ن ؤُبَارّحْ خْ وذْرَارْ
\m 
\v 28 \bd أَوَارْنِي ڒَامِي إِكمّڒْ يَاسُوع أَوَاڒنْ-أَ\bd*، أَقَا إِمْسَارْ بلِّي ڒْغَاشِي إِقِّيمْ إِتّبْهثْ س ثْغُورِي نّسْ،
\v 29 مِينْزِي ثُوغَا إِسّڒْمَاذْ إِ-ثنْ أَمشْنَاوْ ونِّي غَارْ ثدْجَا صُّولْطَا، وَارْ إِدْجِي شَا أَمْ يِيمْسڒْمَاذنْ ن إِذْلِيسنْ ذ إِفَارِيسِييّنْ. \x ◘ \xo 7:‏29 \xt مك. 1‏:‏22؛ 6‏:‏2؛ لك. 4‏:‏32. \x*
\b
\b
\c 8
\s1 أَسْڭنْفِي ن إِجّْ ن بُو-ڒْْبَارْصْ
\m 
\v 1 ڒَامِي د-إِهْوَا زڭْ وذْرَارْ، ضْفَارنْ ث-إِ-د أَطَّاسْ ن ڒْغَاشِي. \x ◘ \xo 8:‏1 \xt [مك. 1‏:‏40‏-‏45؛ لك. 5‏:‏12‏-‏16]\x*
\v 2 خْزَارْ، يُوسَا-د غَارسْ إِجّنْ إِ ذِي إِدْجَا ڒْبَارْصْ، إِسْجذْ أَسْ، إِنَّا: ”أَ سِيذِي، مَاڒَا ثخْسذْ، ثْزمَّارذْ أَذْ أَيِي ثسِّيزْذڭذْ!“ \x ◘ \xo 8:‏2 \xt مك. 1‏:‏40؛ لك. 5‏:‏12. \x*
\v 3 يَاسُوع إِسّْوِيژّضْ أَفُوسْ نّسْ ؤُشَا إِحَاذَا ث، إِنَّا: ”نشّْ خْسغْ، زْذڭْ!“ ؤُشَا إِتّْوَاسِّيزْذڭْ زِي ڒْبَارْصْ نّسْ ڒخْذنِّي.
\v 4 \add خنِّي\add* إِنَّا أَسْ يَاسُوع: ”خْزَارْ، وَارْ تّقَّارْ إِ حذْ، مَاشَا رُوحْ، سْشنْ إِخفْ نّشْ إِ ؤُكهَّانْ ؤُشَا أوْشْ ثَاغَارْصْثْ إِ أَربِّي عْلَاحْسَابْ مِينْ زَّايسْ إِوصَّا مُوسَا، أَقَا-ت ذ شّْهَاذثْ إِ نِيثْنِي.“ \x ◘ \xo 8:‏4 \xt لَاوِي 13‏:‏2؛ 14‏:‏2؛ لك. 5‏:‏14. \x*
\b
\s1 أَمْسخَّارْ نْ ڒْقبْطَانْ أَرُومَانِي
\m 
\v 5 ڒَامِي يُوذفْ يَاسُوع غَارْ كَافَارْنَاحُومْ، يُوسَا-د غَارسْ إِجّْ ن ڒْقبْطَانْ خْ مْيَا، إِتَّارْ زَّايسْ \add أَمُّو\add*، \x ◘ \xo 8:‏5 \xt [لك. 7‏:‏1‏-‏10؛ يُوح. 4‏:‏43‏-‏54] — لك. 7‏:‏1\x*
\v 6 إِنَّا: ”أَ سِيذِي، أَمْسخَّارْ أَمژْيَانْ إِنُو إِزّڒْ ذِي ثَادَّارْثْ ذ أَنعْضَابْ، أَقَا ذَايسْ ڒحْرِيقْ أَطَّاسْ!“
\v 7 إِنَّا أَسْ يَاسُوع: ”نشّْ أَذْ د-أَسغْ، أَذْ ث سّْڭنْفِيغْ!“
\v 8 ؤُشَا ڒْقبْطَانْ خْ مْيَا يَارَّا-د، إِنَّا: ”أَ سِيذِي، نشّْ وَارْ سْذِيهدْجغْ أَذْ ثَاذْفذْ سْوَادَّايْ إِ ثْزقَّا إِنُو، مَاشَا إِنِي إِجّْ ن وَاوَاڒْ وَاهَا، خنِّي أَذْ إِڭّنْفَا ؤُمْسخَّارْ أَمژْيَانْ إِنُو. \x ◘ \xo 8:‏8 \xt إِزهد. 107‏:‏20. \x*
\v 9 مِينْزِي ؤُڒَا ذ نشّْ عَاوذْ ذ بْنَاذمْ سَاذُو إِفَاسّنْ ؤُشَا غَارِي إِعسْكَارِييّنْ سَاذُو ؤُفُوسْ إِنُو، قَّارغْ إِ وَا: ’رُوحْ!‘، خنِّي أَذْ إِرَاحْ، ؤُ إِ ونّغْنِي: ’أَسْ-د!‘، خنِّي أَذْ د-يَاسْ، ؤُ إِ ؤُمْسخَّارْ إِنُو \add قَّارغْ أَسْ\add*: ’أڭّْ مَانْ أَيَا!‘، ؤُشَا أَذْ ث إِڭّْ.“
\v 10 ڒَامِي إِسْڒَا يَاسُوع مَانْ أَيَا، إِتّبْهثْ، إِنَّا إِ يِينِّي أَكِيذسْ إِدْجَانْ: ”س ثِيذتّْ نشّْ أَذْ أَومْ إِنِيغْ، وَارْ ؤُفِيغْ ؤُڒَا ذِي إِسْرَائِيل لْ-إِيمَانْ أَمْ وَانِيثَا.
\v 11 نشّْ أَذْ أَومْ إِنِيغْ، بلِّي أَطَّاسْ إِ د غَا يَاسنْ زِي شَّارْقْ ؤُ زِي ڒْغَارْبْ، أَذْ قِّيمنْ \add غَارْ طَّابْڒَا\add* أَكْ-ذ إِبْرَاهِيمْ ذ إِسْحَاقْ ذ يَاعْقُوبْ ذِي ثْڭلْذِيثْ ن إِجنْوَانْ، \x ◘ \xo 8:‏11 \xt لك. 13‏:‏29. \x*
\v 12 \add مَاشَا\add* ثَارْوَا ن ثْڭلْذِيثْ أَذْ مّنْضَارنْ بَارَّا غَارْ طَّارْفْ أَنڭَّارُو ن ثَادْجسْثْ. ذِينِّي أَذْ إِڒِينْ إِمطَّاونْ ذ ؤُغزِّي ن ثغْمَاسْ.“ \x ◘ \xo 8:‏12 \xt مت. 13‏:‏42؛ 21‏:‏43؛ 22‏:‏13؛ 24‏:‏51؛ لك. 13‏:‏28. \x*
\v 13 يَاسُوع إِنَّا إِ ڒْقبْطَانْ خْ مْيَا: ”رُوحْ، أَذْ إِمْسَارْ أَمْ مَامّشْ ثُومْنذْ.“ ؤُشَا إِڭّنْفَا ؤُحنْجِيرْ نّسْ ذِي ثْسَاعّثْ نِّي.
\b
\s1 أَسْڭنْفِي ن ثْضكّْوَاتْشْ ن بُوطْرُوسْ
\m 
\v 14 \add ڒخْذنِّي\add* يُوسَا-د يَاسُوع غَارْ ثَادَّارْثْ ن شِيمْعُونْ، إِژْرَا ثَاضكّْوَاتْشْ نّسْ ثزّڒْ، ذَايسْ ثِيمسِّي. \x ◘ \xo 8:‏14 \xt [مك. 1‏:‏29‏-‏34؛ لك. 4‏:‏38‏-‏41] — مك. 1‏:‏29؛ لك. 4‏:‏38.\x*
\v 15 إِحَاذَا أَفُوسْ نّسْ ؤُشَا ثْرُوحْ أَسْ ثْمسِّي، ڒخْذنِّي ثكَّارْ، ثْسخَّارْ خَاسْ.
\v 16 غَارْ ؤُعشِّي إِوْينْ-د غَارسْ أَطَّاسْ ن إِمَارْيَاحنْ إِ ذَايْسنْ شّْوَاطنْ. إِسُّوفّغْ شّْوَاطنْ نْسنْ س يِيجّْ ن وَاوَاڒْ \add وَاهَا\add*، ؤُشَا إِسّْڭنْفَا مَارَّا إِمهْڒَاشْ،
\v 17 حِيمَا أَذْ إِتّْوَاكمّڒْ مِينْ إِتّْوَانَّانْ زڭْ ؤُنَابِي إِشَاعْيَا: ”أَذْ إِكْسِي ڒحْرِيقْ نّغْ ؤُ أَذْ يَارْبُو ڒهْڒَاشْ نّغْ.“ \x ◘ \xo 8:‏17 \xt إِشا. 53‏:‏4؛ 1 بُط. 2‏:‏24. \x*
\b
\s1 أَضْفَارْ ن يَاسُوع
\m 
\v 18 ڒَامِي إِژْرَا يَاسُوع ڒْغَاشِي أَمقّْرَانْ إِ ذ أَسْ د-إِنّْضنْ، يُومُورْ \add إِ-ثنْ\add* أَذْ ژْوَانْ غَارْ ؤُجمَّاضْ. \x ◘ \xo 8:‏18 \xt [لك. 9‏:‏57‏-‏62] \x*
\v 19 ؤُشَا يُوسَا-د غَارسْ إِجّْ ن ؤُمْسڒْمَاذْ ن إِذْلِيسنْ، إِنَّا أَسْ: ”\add أَ\add* أَمْسڒْمَاذْ إِنُو، أَذْ شكْ ضْفَارغْ مَانِي مَا إِ غَا ثْرَاحذْ!“ \x ◘ \xo 8:‏19 \xt لك. 9‏:‏57. \x*
\v 20 إِنَّا أَسْ يَاسُوع: ”إِشعْبَانْ غَارْسنْ إِفْرَانْ ؤُ إِجْضَاضْ ن ؤُجنَّا غَارْسنْ ڒعْوَاشّْ، مَاشَا مِّيسْ ن بْنَاذمْ وَارْ يُوفِي شَا مَانِي غَا إِسنّذْ أَزدْجِيفْ نّسْ.“
\v 21 إِنَّا أَسْ إِجّنْ نّغْنِي زڭْ إِمحْضَارنْ نّسْ: ”\add أَ\add* سِيذِي، أجّْ أَيِي ذ أَمزْوَارْ أَذْ ؤُيُورغْ أَذْ نضْڒغْ بَابَا!“
\v 22 إِنَّا أَسْ يَاسُوع: ”ضْفَارْ أَيِي-د، أجّْ إِمتِّيننْ أَذْ نضْڒنْ إِمتِّيننْ نْسنْ!“ \x ◘ \xo 8:‏22 \xt 1 تِيم. 5‏:‏6. \x*
\b
\s1 يَاسُوع ذ ثْحَارْيَاضْثْ
\m 
\v 23 ڒَامِي إِنْيَا ذِي ثْغَارَّابُوثْ، نْيِينْ إِمحْضَارنْ نّسْ أَكِيذسْ. \x ◘ \xo 8:‏23 \xt [مك. 4‏:‏35‏-‏41؛ لك. 8‏:‏22‏-‏25] — مك. 4‏:‏35؛ لك. 8‏:‏22\x*
\v 24 ؤُشَا خْزَارْ، ثكَّارْ-د إِشْثْ ن ثْحَارْيَاضْثْ ذِي ڒبْحَارْ أَڒْ مَانِي ذْڒِينْثْ ڒمْوَاجْ أَغَارَّابُو، مَاشَا يَاسُوع ثُوغَا إِطّصْ.
\v 25 ؤُسِينْ-د غَارسْ إِمحْضَارنْ نّسْ ؤُشَا سّْفَاقنْ ث-إِ-ذ، نَّانْ أَسْ: ”\add أَ\add* سِيذِيثْنغْ، سنْجمْ أَنغْ، أَقَا أَذْ نتّْوَاهلّكْ!“
\v 26 إِنَّا أَسنْ: ”مَايمِّي ثتّڭّْوذمْ، \add أَ\add* كنِّيوْ إِ ذِي إِدْجَا ذْرُوسْ ن لْ-إِيمَانْ؟“ خنِّي إِكَّارْ، إِوبّخْ أَسمِّيضْ ذ ڒبْحَارْ، ؤُشَا ثُوسَا-د ڒْهُوذْنثْ ثَامقّْرَانْثْ. \x ◘ \xo 8:‏26 \xt أَيُوبْ 26‏:‏12؛ إِزهد. 107‏:‏29؛ إِشا. 51‏:‏10. \x*
\v 27 ثْبهْثنْ إِوْذَانْ، نَّانْ: ”مِينْ إِعْنَا وَا ؤُمِي إِسمِّيضنْ ذ ڒبْحَارْ تّطَّاعنْ أَسْ؟“
\b
\s1 أَسْڭنْفِي ن ثْنَاينْ ن إِمرْيَاحنْ
\m 
\v 28 ڒَامِي يِيوضْ غَارْ ؤُجمَّاضْ غَارْ ثمُّورْثْ ن ڭَاذَارِينِيسْ، ڒْقَانْ ث-إِ-د ثْنَاينْ ن إِمَارْيَاحنْ، فّْغنْ-د زڭْ إِمضْڒَانْ، ثُوغَا مُّوزَّارنْ أَطَّاسْ أَڒْ مَانِي ؤُڒَا ذ إِجّْ وَارْ إِزمَّارْ أَذْ يكّْ أَبْرِيذْ نِّي. \x ◘ \xo 8:‏28 \xt [مك. 5‏:‏1‏-‏20؛ لك. 8‏:‏26‏-‏39] — مك. 5‏:‏1؛ لك. 8‏:‏26\x*
\v 29 سْغُويّنْ، نَّانْ: ”مِينْ ذِينْ جَارْ أَنغْ ذ شكْ، أَ يَاسُوع، مِّيسْ ن أَربِّي؟ مَا ثُوسِيذْ-د ذَانِيثَا حِيمَا أَذْ أَنغْ ثْعدّْبذْ قْبڒْ ڒْوقْثْ؟“
\v 30 ثُوغَا ذِينْ إِشْثْ ن ثْحِيمَارْثْ ن إِڒْفَانْ ثَامقّْرَانْثْ ثِيڭّْوجْ خَاسنْ، ثْهدَّا ذِينْ.
\v 31 ؤُشَا شّْوَاطنْ تَّارنْ زَّايسْ، نَّانْ: ”مَاڒَا ثسُّوفّْغذْ أَنغْ، أجّْ أَنغْ أَذْ نَاذفْ غَارْ ثْحِيمَارْثْ ن يڒْفَانْ!“
\v 32 إِنَّا أَسنْ: ”رُوحمْ!“ ڒخْذنِّي فّْغنْ-د، ؤُذْفنْ ذڭْ إِڒْفَانْ. ؤُشَا خْزَارْ، ثَاحِيمَارْثْ ن إِڒْفَانْ أَمنْ ثْمُونْ ثحْذُودَّارْ زِي ثيْسَارْثْ، ؤُشَا إِڒْفَانْ وْضَانْ ذِي ڒبْحَارْ، مُّوثنْ ذڭْ وَامَانْ.
\v 33 أَروْڒنْ إِمكْسَاونْ ؤُشَا ڒَامِي إِوْضنْ غَارْ ثنْذِينْثْ، خبَّارنْ خْ كُوڒْشِي مِينْ إِمْسَارنْ، ؤُڒَا خْ إِمَارْيَاحنْ.
\v 34 ؤُشَا خْزَارْ، فّْغنْ-د أَيْثْبَابْ ن ثنْذِينْثْ مَارَّا إِ ؤُمْسَاڭَارْ أَكْ-ذ يَاسُوع. ؤُمِي ث ژْرِينْ، تَّارنْ زَّايسْ مَاحنْذْ أَذْ إِفّغْ زِي ثمُّورْثْ نْسنْ.
\b
\b
\c 9
\s1 أَسْڭنْفِي ن إِجّْ ن ؤُنعْضَابْ
\m 
\v 1 \add أَوَارْنِي ڒَامِي\add* إِنْيَا ذڭْ ؤُغَارَّابُو، إِژْوَا ڒبْحَارْ، يِيوضْ غَارْ ثنْذِينْثْ نّسْ. \x ◘ \xo 9:‏1 \xt [مك. 2‏:‏1‏-‏12؛ لك. 5‏:‏17‏-‏26] — ڒخ. 9‏:‏33. \x*
\v 2 ؤُشَا إِوْينْ أَسْ-د إِجّْ ن ؤُنعْضَابْ إِ ثُوغَا إِزّْڒنْ ذِي ثَاسُّوثْ. \add ڒَْامِي\add* إِژْرَا يَاسُوع لْ-إِيمَانْ نْسنْ، إِنَّا إِ ؤُنعْضَابْ: ”أڭّْ ؤُڒْ، \add أَ\add* مِّي، دّْنُوبْ نّشْ تّْوَاغْفَارنْ!“
\v 3 ؤُشَا خْزَارْ، شَا ن إِمْسڒْمَاذنْ ن إِذْلِيسنْ نَّانْ ذڭْ يِيخفْ نْسنْ: ”وَانِيثَا إِتّْشقَّافْ \add ذِي أَربِّي\add*.“ \x ◘ \xo 9:‏3 \xt إِزهد. 32‏:‏5؛ إِشا. 43‏:‏25. \x*
\v 4 يَاسُوع، ؤُمِي إِسّنْ مِينْ ذِي ثُوغَا تّْفكَّارنْ، إِنَّا أَسنْ: ”مَايمِّي ثتّْخمَّاممْ ذِي مِينْ وَارْ إِحْڒِينْ ذڭْ وُوڒَاونْ نْومْ؟
\v 5 مَاغَارْ مِينْ إِهوْننْ أَذْ إِنِيغْ إِ وَانِيثَا: ’دّْنُوبْ نّشْ تّْوَاغْفَارنْ!‘، نِيغْ أَذْ إِنِيغْ: ’كَّارْ، ؤُيُورْ‘؟
\v 6 مَاشَا حِيمَا أَذْ ثسّْنمْ بلِّي مِّيسْ ن بْنَاذمْ غَارسْ صُّولْطَا ذِي ثمُّورْثْ حِيمَا أَذْ إِغْفَارْ دّْنُوبْ، أَذْ إِنِيغْ إِ ؤُنعْضَابْ-أَ: ”كَّارْ، كْسِي ثَاسُّوثْ نّشْ، ثَاركّْوحذْ غَارْ ثَادَّارْثْ نّشْ!“
\v 7 خنِّي إِكَّارْ، إِرُوحْ غَارْ ثَادَّارْثْ نّسْ.
\v 8 ڒَامِي إِژْرَا ڒْغَاشِي مَانْ أَيَا، ثْبهْثنْ، سّْعُودْجنْ أَربِّي ونِّي إِوْشِينْ صُّولْطَا أَمْ ثَانِيثَا إِ إِوْذَانْ.
\b
\s1 ثَاڒَاغِيثْ ن يَاسُوع خْ مَاتَّا
\m 
\v 9 ڒَامِي سّنِّي إِكَّا يَاسُوع، إِژْرَا أَرْيَازْ ونِّي ؤُمِي قَّارنْ مَاتَّا، إِقِّيمْ غَارْ ثَادَّارْثْ ن ضَّارِيبَا. إِنَّا أَسْ: ”ضْفَارْ أَيِي-د!“ ؤُشَا إِكَّارْ، إِضْفَارْ إِ-ث. \x ◘ \xo 9:‏9 \xt [مك. 2‏:‏13‏-‏17؛ لك. 5‏:‏27‏-‏32] \x*
\v 10 ڒَامِي قِّيمنْ نِيثْنِي \add غَارْ طَّابْڒَا\add* ذِي ثَادَّارْثْ، ؤُسِينْ-د وَاطَّاسْ ن أَيْثْ ن ضَّارِيبَا ذ إِمذْنَابْ، قِّيمنْ \add غَارْ طَّابْڒَا\add* أَكْ-ذ يَاسُوع ذ إِمحْضَارنْ نّسْ.
\v 11 \add ڒَْامِي\add* ژْرِينْ إِفَارِيسِييّنْ مَانْ أَيَا، نَّانْ إِ إِمحْضَارنْ نّسْ: ”مَايمِّي إِتّتّْ ؤُمْسڒْمَاذْ نْومْ أَكْ-ذ أَيْثْ ن ضَّارِيبَا ذ إِمذْنَابْ؟“
\v 12 ؤُمِي إِسْڒَا يَاسُوع \add مَانْ أَيَا\add*، إِنَّا أَسنْ: ”إِنِّي إِصحّنْ، وَارْ حْذِيجنْ شَا أَضْبِيبْ، مَاشَا إِمهْڒَاشْ.
\v 13 رُوحمْ، أَذْ ثْڒمْذمْ مِينْ إِخْسْ أَذْ يِينِي \add وَاوَاڒْ-أَ\add*: ’خْسغْ أَرّحْمثْ، وَارْ خْسغْ شَا ثَاغَارْصْثْ!‘، مِينْزِي نشّْ وَارْ د-ؤُسِيغْ، حِيمَا أَذْ ڒَاغِيغْ خْ إِمْسڭَّاذنْ، مَاشَا خْ إِمذْنَابْ.“ \x ◘ \xo 9:‏13 \xt حُوش. 6‏:‏6؛ مِيخَا 6‏:‏8؛ مت. 12‏:‏7؛ مك. 2‏:‏17؛ لك. 5‏:‏32؛ 19‏:‏10؛ 1 تِيم. 1‏:‏15. \x*
\b
\s1 أَسقْسِي خْ ؤُژُومِّي
\m 
\v 14 خنِّي ؤُسِينْ-د غَارسْ إِمحْضَارنْ ن يُوحَانَّا، نَّانْ أَسْ: ”مَايمِّي نتّْژُومَّا نشِّينْ ذ إِفَارِيسِييّنْ أَطَّاسْ، مَاشَا إِمحْضَارنْ نّشْ وَارْ تّْژُومِّينْ شَا؟“ \x ◘ \xo 9:‏14 \xt [مك. 2‏:‏18‏-‏22؛ لك. 5‏:‏33‏-‏39] \x*
\v 15 يَاسُوع إِنَّا أَسنْ: ”مَا إِزمَّارْ أَذْ شضْننْ ڒحْبَابْ ن ؤُمُوڒَايْ ؤُمِي أَمُوڒَايْ عَاذْ أَكِيذْسنْ؟ أَذْ د-أَسنْ وُوسَّانْ أَذْ خَاسنْ إِمّكْسِي ؤُمُوڒَايْ، خنِّي أَذْ ژُومّنْ. \x ◘ \xo 9:‏15 \xt 2 كُور. 11‏:‏2. \x*
\b
\m 
\v 16 ؤُڒَا ذ إِجّْ وَارْ إِتّڭّْ ثَانقِّيتْشْ ن ثْشُوقّثْ ن جْذِيذْ خْ وَارُّوضْ أَقْذِيمْ، حِيمَا وَارْ ثْقدْجِيعْ ثْنقِّيتْشْ زڭْ وَارُّوضْ ؤُشَا أَذْ إِقَّارْصْ \add وَارُّوضْ\add* كْثَارْ.
\v 17 ؤُڒَا ذ بِينُو ن جْذِيذْ وَارْ إِتّْوَاڭّْ شَا ذِي ثْخُونْشَايْ ثِيبُوڒَايْ، حِيمَا وَارْ دُّوقُّوزنْثْ ثْخُونْشَايْ، أَذْ إِزدْجعْ بِينُو ؤُشَا ثِيخُونْشَايْ أَذْ ضيّْعنْثْ. إِتّْخصَّا أَذْ تّڭّنْ بِينُو ن جْذِيذْ ذِي ثْخُونْشَايْ ن جْذِيذْ، حِيمَا أَذْ تّْوَاخمّْڒنْ نِيثْنِي س ثْنَاينْ.“ \x ◘ \xo 9:‏17 \xt مك. 2‏:‏22. \x*
\b
\s1 أَحِينِّي ن يَاسُوع ذ إِسْڭنْفَانْ نّسْ
\m 
\v 18 أَمْ ثُوغَا إِسَّاوَاڒْ أَكِيذْسنْ خْ ثْمسْڒَايِينْ-أَ، يُوسَا-د إِجّْ ن ؤُمقّْرَانْ، إِسْجذْ أَسْ، إِنَّا: ”ڒخُّو \bd يدْجِي بْحْڒَا ثمُّوثْ\bd*، مَاشَا أَسْ-د، سَارْسْ خَاسْ أَفُوسْ نّشْ ؤُشَا أَذْ ثدَّارْ عَاوذْ.“ \x ◘ \xo 9:‏18 \xt [مك. 5‏:‏21‏-‏43؛ لك. 8‏:‏40‏-‏56] \x*
\v 19 يَاسُوع إِكَّارْ، إِضْفَارْ إِ-ث أَكْ-ذ إِمحْضَارنْ نّسْ.
\b
\m 
\v 20 ؤُشَا خْزَارْ، \bd إِشْثْ ن ثمْغَارْثْ، ثُوغَا تَّازّْڒنْ زَّايسْ إِذَامّنْ ڒْمِيجَاڒْ ن ثنْعَاشْ ن إِسڭّْوُوسَا\bd*، ثكَّا أَسْ-د غَارْ ضفَّارْ ؤُشَا ثْحَاذَا أَبحْڒُوڒْ ن ؤُجدْجَابْ نّسْ، \x ◘ \xo 9:‏20 \xt لَاوِي 15‏:‏25؛ مك. 5‏:‏25؛ لك. 8‏:‏43. \x*
\v 21 مِينْزِي نتَّاثْ ثُوغَا ثنَّا ذڭْ إِخفْ نّسْ: ”إِشْفَا مْغِيرْ أَذْ حَاذِيغْ أَجدْجَابْ نّسْ، أَذْ ڭّنْفِيغْ!“
\v 22 مَاشَا إِنّقْڒبْ-د يَاسُوع، إِژْرَا إِ-ت، إِنَّا: ”أڭّْ ؤُڒْ، أَ يدْجِي، أَقَا لْ-إِيمَانْ نّمْ إِ شمْ إِسّْنجْمنْ!“ ؤُشَا ثتّْوَاسّْڭّنْفَا ثمْغَارْثْ نِّي ذِي ثْسَاعّثْ نِّي. \x ◘ \xo 9:‏22 \xt مك. 5‏:‏38؛ لك. 8‏:‏51. \x*
\b
\m 
\v 23 \add خنِّي\add* يُوسَا-د يَاسُوع غَارْ ثَادَّارْثْ ن ؤُمقّْرَانْ، إِژْرَا إِغيَّاضنْ ذ ڒْغَاشِي سْغُويُّونْ. \x ◘ \xo 9:‏23 \xt مك. 5‏:‏38؛ لك. 8‏:‏51. \x*
\v 24 إِنَّا أَسنْ: ”فّْغمْ سَّا! ثَاحنْجِيرْثْ وَارْ ثمُّوثْ شَا، أَقَا ثطّصْ!“ نِيثْنِي ضحْشنْ ذَايسْ. \x ◘ \xo 9:‏24 \xt يُوح. 11‏:‏11. \x*
\v 25 أَڒَامِي إِسُّوفّغْ ڒْغَاشِي، يُوذفْ غَارْ ذَاخڒْ ؤُشَا إِطّفْ إِ-ت زڭْ ؤُفُوسْ نّسْ، خنِّي ثكَّارْ ثْحنْجِيرْثْ.
\v 26 ؤُشَا إِفّغْ ڒخْبَارْ غَارْ ثمُّورْثْ نِّي مَارَّا.
\b
\m 
\v 27 ڒَامِي سّنِّي إِكَّا يَاسُوع، ضْفَارنْ ث \bd ثْنَاينْ ن إِذَارْغَاڒنْ\bd*، تّْڒَاغَانْ، قَّارنْ: ”أَرْحمْ أَنغْ، أَ مِّيسْ ن ذَاوُوذْ!“
\v 28 أَڒَامِي يُوذفْ غَارْ ثَادَّارْثْ، ؤُسِينْ-د غَارسْ إِذَارْغَاڒنْ نِّي. يَاسُوع إِنَّا أَسنْ: ”مَا ثُومْنمْ بلِّي زمَّارغْ أَذْ ڭّغْ مَانْ أَيَا؟“ نَّانْ أَسْ: ”وَاهْ، \add أَ\add* سِيذِيثْنغْ!“
\v 29 ڒخْذنِّي إِحَاذَا ثِيطَّاوِينْ نْسنْ، إِنَّا: ”أَذْ غَارْومْ يِيڒِي عْلَاحْسَابْ لْ-إِيمَانْ نْومْ!“
\v 30 ڒخْذنِّي تّْوَارزْمنْثْ ثِيطَّاوِينْ نْسنْ. \add خنِّي\add* إِحَارّمْ إِ-ثنْ يَاسُوع، إِنَّا: ”غَارْومْ، وَارْ سَّارْڭَابمْ حذْ!“ \x ◘ \xo 9:‏30 \xt مت. 12‏:‏16؛ لك. 5‏:‏14. \x*
\v 31 مَاشَا نِيثْنِي، أَڒَامِي رُوحنْ، سُّوفّْغنْ خَاسْ ڒخْبَارْ ذِي مَارَّا ثَامُّورْثْ! \x ◘ \xo 9:‏31 \xt مك. 7‏:‏36. \x*
\b
\m 
\v 32 ڒَامِي د-فّْغنْ نِيثْنِي، إِوْينْ أَسْ-د \bd إِجّْ ن ورْيَازْ أَيْنَاوْ، ذَايسْ إِجّْ ن شِّيطَانْ\bd*. \x ◘ \xo 9:‏32 \xt مت. 12‏:‏22؛ لك. 11‏:‏14. \x*
\v 33 ڒَامِي \add زَّايسْ\add* إِفّغْ شِّيطَانْ نِّي، إِسِّيوڒْ ويْنَاوْ. ثُوغَا إِتّبْهثْ ڒْغَاشِي، نَّانْ: ”عمَّارْصْ وَارْ نژْرِي أَمْ وَانِيثَا ذِي إِسْرَائِيل!“
\v 34 مَاشَا إِفَارِيسِييّنْ نَّانْ: ”س ؤُمقّْرَانْ ن شّْوَاطنْ إِسُّوفُّوغْ شّْوَاطنْ!“ \x ◘ \xo 9:‏34 \xt مت. 12‏:‏24؛ مك. 3‏:‏22؛ لك. 11‏:‏15. \x*
\b
\m 
\v 35 \bd يشُّو ثُوغَا إِتّنّضْ خْ مَارَّا ثِيندَّامْ ذ ذْشُورَاثْ، إِسّڒْمَاذْ إِ-ثنْ ذِي ثمْزِيذَاوِينْ نْسنْ. ثُوغَا إِتّْبَارّحْ س ڒخْبَارْ أَصبْحَانْ ن ثْڭلْذِيثْ ؤُشَا إِسّْڭنْفَا مَارَّا ڒهْڒَاشَاثْ ذ ڒعْيُوبْ ن ڒْڭنْسْ.\bd* \x ◘ \xo 9:‏35 \xt مك. 6‏:‏6؛ لك. 13‏:‏22. \x*
\v 36 ڒَامِي إِژْرَا يَاسُوع ڒْغَاشِي، إِحِينّْ خَاسنْ، مِينْزِي ؤُحْڒنْ نّْهوْڒنْ أَمْ وُودْجِي إِ وَارْ غَارْ إِدْجِي ؤُمكْسَاوْ. \x ◘ \xo 9:‏36 \xt إِرْم. 23‏:‏1؛ حِز. 34‏:‏2؛ مك. 6‏:‏34. \x*
\v 37 خنِّي إِنَّا إِ إِمحْضَارنْ نّسْ: ”ثَاميْرَا ثمْغَارْ أَطَّاسْ، مَاشَا أَقَا ذِينْ ذْرُوسْ ن إِشوَّاڒنْ. \x ◘ \xo 9:‏37 \xt لك. 10‏:‏2؛ يُوح. 4‏:‏35. \x*
\v 38 س ؤُينِّي تَّارمْ إِ بَابْ ن ثْميْرَا، أَذْ د-إِسّكّْ إِشوَّاڒنْ إِ ثْميْرَا نّسْ.“ \x ◘ \xo 9:‏38 \xt 2 تس. 3‏:‏1. \x*
\b
\b
\c 10
\s1 ثَاڒَاغِيثْ ن يَاسُوع خْ ثنْعَاشْ ن رُّوسُولْ
\m 
\v 1 إِڒَاغَا يَاسُوع خْ ثنْعَاشْ ن إِمحْضَارنْ نّسْ، إِوْشَا أَسنْ صُّولْطَا حِيمَا أَذْ سُّوفّْغنْ ڒَارْيَاحْ إِمنْڭَاسْ ؤُ حِيمَا أَذْ سّْڭنْفَانْ مَارَّا ڒعْيُوبَاثْ ذ ڒهْڒَاشَاثْ. \x ◘ \xo 10:‏1 \xt [مك. 3‏:‏13‏-‏19؛ 6‏:‏7‏-‏13؛ لك. 6‏:‏12؛ 9‏:‏1‏-‏6] \x*
\v 2 إِسْمَاونْ ن ثنْعَاشْ ن رُّوسُولْ ذ يِينَا: أَمزْوَارُو نْسنْ شِيمْعُونْ ؤُمِي قَّارنْ بُوطْرُوسْ، \add إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’أَژْرُو‘،\add* ذ ؤُمَاسْ أَنْذْرَاوُوسْ، ذ يَاعْقُوبْ، مِّيسْ ن زَابْذِي، ذ ؤُمَاسْ يُوحَانَّا، \f ◼ \fr 10:‏2 \ft \bd ’رُّوسُولْ'\bd* - نِيغْ ’إِمَازَاننْ‘.\f*
\v 3 ذ فِيلِيبُّوسْ ذ بَارْ-ثُولُومَاوُوسْ، ثُومَا ذ مَاتَّا، ونِّي ذ بُو-ضَّارِيبَا، ذ يَاعْقُوبْ، مِّيسْ ن حَالْفَا، ذ لَابَّاوُوسْ، ؤُمِي قَّارنْ ثَادَّايْ،
\v 4 ذ شِيمْعُونْ، ونِّي ذ أَمْعسَّابْ، ذ يَاهُوذَا إِسْخَارِييُوطِي ونِّي ث إِسلّْمنْ.
\v 5 يَاسُوع إِسّكّْ ثنْعَاشْ-أَ، يُومُورْ إِ-ثنْ، إِنَّا: ”وَارْ تّْرُوحمْ شَا خْ وبْرِيذْ ن لْكُوفَّارْ، وَارْ تَّاذْفمْ شَا غَارْ ثنْذِينْثْ ن إِسَامَارِييّنْ،
\v 6 مَاشَا حْسنْ أَذْ ثْرَاحمْ غَارْ وُودْجِي إِودَّارنْ ن ثَادَّارْثْ ن إِسْرَائِيل. \x ◘ \xo 10:‏6 \xt ڒخ. 3‏:‏26؛ 13‏:‏26،46. \x*
\v 7 خْمِي غَا ثْرَاحمْ، بَارّْحمْ أَمْ ثقَّارمْ: ’ثَاڭلْذِيثْ ن إِجنْوَانْ أَقَا ثِيوضْ-د!‘ \x ◘ \xo 10:‏7 \xt لك. 9‏:‏2. \x*
\v 8 سْڭنْفَامْ إِمهْڒَاشْ، سِيزْذْڭمْ إِنِّي ذِي إِدْجَا ڒْبَارْصْ، سُوفّْغمْ شّْوَاطنْ. كنِّيوْ ثكْسِيمْ بْڒَا شَا، خنِّي وْشمْ ت بْڒَا شَا. \x ◘ \xo 10:‏8 \xt لك. 10‏:‏9؛ ڒخ. 8‏:‏18، 20. \x*
\v 9 وَارْ كسِّيمْ شَا وُورغْ ؤُڒَا ذ نُّوقَارْثْ ؤُڒَا ذ نّْحَاسْ ذڭْ إِبُويَاسْ نْومْ، \x ◘ \xo 10:‏9 \xt مك. 6‏:‏8؛ لك. 9‏:‏3؛ 22‏:‏35. \x*
\v 10 وَارْ كسِّيمْ شَا تّسْطِيمْ إِ وبْرِيذْ ڒَا ذ ثْنَاينْ ن ثْشَامِيرَاثْ ڒَا ذ سَانْذَالِييَاثْ ؤُڒَا ذ ثَاغَّارْشْثْ \add نّغْنِي\add*، مِينْزِي أَخدَّامْ إِسْذَاهدْجْ مَاشَّا نّسْ. \x ◘ \xo 10:‏10 \xt لَاوِي 19‏:‏13؛ أَعَوذ. 24‏:‏14؛ 25‏:‏4؛ لك. 10‏:‏7؛ 1 كُور. 9‏:‏4، 14؛ 1 تِيم. 5‏:‏18. \x*
\v 11 مَانْ ثَانْذِينْثْ نِيغْ ذْشَارْ إِ غَا ثَاذْفمْ، أَرْزُومْ وِي ذَايسْ إِسْذَاهدْجْ، ؤُشَا قِّيممْ ذِينْ أَڒْ ذ ثْرَاحمْ. \x ◘ \xo 10:‏11 \xt مك. 6‏:‏10؛ لك. 9‏:‏4؛ 10‏:‏8. \x*
\v 12 مَاڒَا ثُوذْفمْ غَارْ ثَادَّارْثْ، سدْجْممْ خْ أَيْثْبَابْ ن ثَادَّارْثْ س ڒهْنَا.
\v 13 مَاڒَا ثَادَّارْثْ ثسْذَاهدْجْ، جّمْ خَاسْ ڒهْنَا نْومْ، مَاڒَا وَارْ ث ثسْذِيهدْجْ، خنِّي ڒهْنَا نْومْ أَذْ غَارْومْ د-إِعْقبْ.
\v 14 مَاڒَا ثُوفِيمْ شَا ن يِيجّنْ وَارْ كنِّيوْ إِقبّڒْ ؤُ وَارْ إِتّسْڒِي إِ وَاوَاڒنْ نْومْ، فّْغمْ زِي ثَادَّارْثْ نِّي نِيغْ زِي ذْشَارْ نِّي، زّرْزمْ ثَاعجَّاجْثْ زڭْ إِضَارنْ نْومْ. \x ◘ \xo 10:‏14 \xt مك. 6‏:‏11؛ لك. 9‏:‏5؛ ڒخ. 13‏:‏51؛ 18‏:‏6. \x*
\v 15 س ثِيذتّْ، نشّْ أَذْ أَومْ إِنِيغْ: أَذْ يِيڒِي ڒْحَاڒْ إِ ثمُّورْثْ ن سَاذُومْ ذ عَامُورَّا إِهْونْ زِي ثنْذِينْثْ نِّي ذڭْ وَاسّْ ن لْحِيسَابْ.“ \x ◘ \xo 10:‏15 \xt مك. 6‏:‏11؛ لك. 10‏:‏12. \x*
\b
\s1 يَاسُوع إِسَّاوَاڒْ خْ ڒحْصَارثْ ذ ؤُذَارّشْ
\m 
\v 16 ”خْزَارمْ، ڒخُّو أَذْ كنِّيوْ سّكّغْ أَمْ ؤُدْجِي ذِي ڒْوسْطْ ن وُوشَّاننْ. إِڒِيمْ ثْفتّْنمْ أَمشْنَاوْ إِفِيغْرَانْ ؤُ غفّْڒمْ أَمشْنَاوْ إِذْبِيرنْ. \x ◘ \xo 10:‏16 \xt [مك. 9‏:‏41، 13‏:‏9–13؛ لك. 12‏:‏2‏-‏9، 12‏:‏51‏-‏53؛ 14‏:‏26، 27؛ 21‏:‏12–17] — لك. 10‏:‏3\x*
\v 17 مَاشَا حْضَامْ إِخفْ نْومْ زڭْ إِوْذَانْ، مِينْزِي نِيثْنِي أَذْ كنِّيوْ سلّْمنْ إِ ثَادَّارْثْ ن شّْرعْ، أَذْ كنِّيوْ هتّْكنْ س ؤُركُّوضْ ذِي ثمْزِيذَاوِينْ نْسنْ. \x ◘ \xo 10:‏17 \xt مت. 24‏:‏9؛ لك. 21‏:‏12؛ يُوح. 15‏:‏20؛ 16‏:‏2؛ أَسَا. 2‏:‏1. \x*
\v 18 أَذْ كنِّيوْ نذْهنْ زَّاثْ إِ ڒْحُوكَّامْ ذ زَّاثْ إِ إِجدْجِيذنْ ذِي سِّيبّثْ إِنُو، حِيمَا أَذْ ثِيڒِيمْ ذ شّْهَاذثْ إِ نِيثْنِي ؤُڒَا إِ ڒڭْنُوسْ. \x ◘ \xo 10:‏18 \xt ڒخ. 24‏:‏1؛ 25‏:‏4. \x*
\v 19 مَاڒَا سلّْمنْ كنِّيوْ، وَارْ كسِّيمْ شَا س ومْنُوسْ مَامّشْ ذ مِينْ غَا ثسِّيوْڒمْ، مِينْزِي أَذْ أَومْ إِمّوْشْ ذِي ثْسَاعّثْ نِّي مِينْ إِتّْخصَّا أَذْ ثِينِيمْ. \x ◘ \xo 10:‏19 \xt مك. 13‏:‏11؛ لك. 12‏:‏11؛ 21‏:‏14. \x*
\v 20 مَاغَارْ وَارْ إِدْجِي ذ كنِّيوْ إِنِّي إِسَّاوَاڒنْ، مَاشَا ذ أَرُّوحْ ن بَابَاثْومْ ذ نتَّا إِ ذَايْومْ إِسَّاوَاڒنْ.
\m 
\v 21 ؤُمَاسْ أَذْ إِسلّمْ ؤُمَاسْ حِيمَا أَذْ إِثْوَانغْ ؤُ بَابَاسْ مِّيسْ، ؤُشَا أَذْ كَّارنْ ثَارْوَا ذ أَغزْذِيسْ إِ لْوَالِيذِينْ نْسنْ، أَذْ ثنْ نْغنْ. \x ◘ \xo 10:‏21 \xt مِيخَا 7‏:‏2، 5؛ لك. 21‏:‏16. \x*
\v 22 أَذْ كنِّيوْ شَارْهنْ مَارَّا إِذْسنْ خْ سِّيبّثْ ن يِيسمْ إِنُو، مَاشَا ونِّي إِ غَا إِصْبَارنْ أَڒْ أَنڭَّارُو أَذْ إِتّْوَاسّنْجمْ. \x ◘ \xo 10:‏22 \xt مت. 24‏:‏13؛ مك. 13‏:‏13؛ لك. 21‏:‏19؛ أَسَا. 2‏:‏10؛ 3‏:‏10. \x*
\v 23 مَاڒَا ذَارّْشنْ خَاومْ ذِي ثنْذِينْثْ-أَ، أَروْڒمْ غَارْ ثنّغْنِيثْ. س ثِيذتّْ، نشّْ أَذْ أَومْ إِنِيغْ: كنِّيوْ وَارْ ثتّكّمْ شَا خْ مَارَّا ثِيندَّامْ ن إِسْرَائِيل أَڒْ د غَا يَاسْ مِّيسْ ن بْنَاذمْ.“ \x ◘ \xo 10:‏23 \xt مت. 2‏:‏13؛ 4‏:‏12؛ 12‏:‏15؛ ڒخ. 8‏:‏1؛ 9‏:‏25؛ 14‏:‏6. \x*
\b
\m 
\v 24 ”وَارْ إِدْجِي ؤُمحْضَارْ يُوعْڒَا خْ ؤُمْسڒْمَاذْ نّسْ، ؤُڒَا ذ أَمْسخَّارْ خْ بَابْ نّسْ. \x ◘ \xo 10:‏24 \xt لك. 6‏:‏40؛ يُوح. 13‏:‏16؛ 15‏:‏20. \x*
\v 25 إِكْفَا إِ ؤُمحْضَارْ أَذْ يِيڒِي أَمْ ؤُمْسڒْمَاذْ نّسْ ؤُ أَمْسخَّارْ أَمْ بَابْ نّسْ. مَاڒَا ڒَاغَانْ أَسْ إِ بَابْ ن ثَادَّارْثْ ’بعَالْزابُولْ‘، \add إِخْسْ أَذْ يِينِي ’إِبْڒِيسْ‘\add*، مشْحَاڒْ \add عَاذْ\add* إِ أَيْثْبَابْ ن ثَادَّارْثْ نّسْ! \x ◘ \xo 10:‏25 \xt مت. 9‏:‏34؛ 12‏:‏24؛ مك. 3‏:‏22؛ لك. 11‏:‏15؛ يُوح. 8‏:‏48. \x*
\v 26 وَارْ تّڭّْوذمْ شَا زَّايْسنْ. مِينْزِي وَارْ ذِينْ مِينْ إِذْڒِينْ أَذْ إِقِّيمْ وَارْ إِتّْوَاعَارِّي، ؤُڒَا \add وَارْ ذِينْ\add* مِينْ إِنُوفَّارنْ أَذْ إِقِّيمْ وَارْ إِتّْوِيسّنْ.“ \x ◘ \xo 10:‏26 \xt أَيُوبْ 12‏:‏22؛ إِشا. 8‏:‏12؛ إِرْم. 1‏:‏8؛ مك. 4‏:‏22؛ لك. 8‏:‏17؛ 12‏:‏2. \x*
\b
\m 
\v 27 ”مِينْ ذ أَومْ قَّارغْ ذِي ثَادْجسْثْ، إِنِيمْ ث ذِي ثْفَاوْثْ، مِينْ ثسْڒِيمْ، \add قَّارنْ ث\add* ذڭْ إِمزُّوغنْ نْومْ، بَارّْحمْ زَّايسْ خْ ثْزغْوِينْ.
\v 28 وَارْ تّڭّْوذمْ شَا زڭْ إِنِّي إِنقّنْ أَرِّيمثْ، \add مَاشَا\add* وَارْ زمَّارنْ أَذْ نْغنْ ڒعْمَارْ. ڭّْوذمْ ذ أَمزْوَارُو زڭْ ونِّي إِزمَّارنْ أَذْ إِسّْهلّكْ ڒعْمَارْ ذ أَرِّيمثْ ذِي جهنَّامَا. \x ◘ \xo 10:‏28 \xt إِرْم. 1‏:‏8؛ لك. 12‏:‏4. \x*
\v 29 مَا وَارْ تّْمنْزِينْ ثْنَاينْ ن ژَّاوشْ س يِيجّْ ن ؤُصُولْذِي ن نّْحَاسْ؟ ؤُڒَا ذ إِجّْ زَّايْسنْ وَارْ د-إِوطِّي شَا خْ ثمُّورْثْ بْڒَا بَابَاثْومْ،
\v 30 مَاشَا ؤُڒَا ذ إِژُوطَّانْ \add ن ؤُشُوَّافْ\add* ن ؤُزدْجِيفْ نْومْ تّْوَاحسّْبنْ مَارَّا. \x ◘ \xo 10:‏30 \xt 1 صم. 14‏:‏45. \x*
\v 31 س ؤُينِّي وَارْ تّڭّْوذمْ شَا، أَقَا كنِّيوْ ثعْذُومْ ژَّاوشْ أَطَّاسْ.
\v 32 س ؤُيَا كُوڒْ إِجّنْ ونِّي زَّايِي إِ غَا إِشهْذنْ زَّاثْ إِ إِوْذَانْ، ؤُڒَا ذ نشّْ أَذْ زَّايسْ شهْذغْ زَّاثْ إِ بَابَا إِ إِدْجَانْ ذڭْ إِجنْوَانْ. \x ◘ \xo 10:‏32 \xt مك. 8‏:‏38؛ لك. 9‏:‏26؛ 12‏:‏8؛ 2 تِيم. 2‏:‏12. \x*
\v 33 مَاشَا ونِّي ذ أَيِي غَا إِنْكَارنْ زَّاثْ إِ إِوْذَانْ، ؤُڒَا ذ نشّْ أَذْ ث نْكَارغْ زَّاثْ إِ بَابَا إِ إِدْجَانْ ذڭْ إِجنْوَانْ.“
\m 
\v 34 ”وَارْ تّْغِيڒمْ شَا بلِّي ؤُسِيغْ-د حِيمَا أَذْ أَوْيغْ ڒهْنَا إِ دُّونشْثْ. نشّْ وَارْ د-ؤُسِيغْ شَا حِيمَا أَذْ أَوْيغْ ڒهْنَا، مَاشَا سِّيفْ. \x ◘ \xo 10:‏34 \xt لك. 12‏:‏51. \x*
\v 35 ؤُسِيغْ-د حِيمَا أَذْ بْضِيغْ أَرْيَازْ خْ بَابَاسْ، ذ يدْجِيسْ خْ يمَّاسْ، ذ ثسْڒِيثْ خْ ڒَالَّاسْ. \x ◘ \xo 10:‏35 \xt مِيخَا 7‏:‏6. \x*
\v 36 أَيْثْبَابْ ن ثَادَّارْثْ ن بْنَاذمْ أَذْ إِڒِينْ ذ ڒْعذْيَانْ \add نّسْ\add*. \x ◘ \xo 10:‏36 \xt إِزهد. 41‏:‏10؛ 55‏:‏13؛ يُوح. 13‏:‏18. \x*
\v 37 ونِّي إِتّخْسنْ بَابَاسْ نِيغْ ذ يمَّاسْ خَافِي، وَارْ ذ أَيِي إِسْذِيهدْجْ شَا، ؤُشَا ونِّي إِتّخْسنْ مِّيسْ نِيغْ ذ يدْجِيسْ خَافِي، وَارْ ذ أَيِي إِسْذِيهدْجْ شَا. \x ◘ \xo 10:‏37 \xt لك. 14‏:‏26. \x*
\v 38 ونِّي وَارْ إِكسِّينْ صَّالِيبْ نّسْ ؤُشَا أَذْ أَيِي د-إِضْفَارْ، أَقَا نتَّا وَارْ ذ أَيِي إِسْذِيهدْجْ شَا. \f ◼ \fr 10:‏38 \ft \bd ’صَّالِيبْ‘\bd* - ذِي ڒْوقْثْ ن ڒْحُوكْمْ أَرُومَانِي، ثُوغَا إِرُومَانِييّنْ نقّنْ إِوْذَانْ إِنِّي وَارْ دْجِينْ ذ إِرُومَانِييّنْ ذِي صَّالِيبْ. ذ مَانْ أَيَا ثُوغَا ذ إِجّْ ن ڒْعِيقَابْ إِقْسحْ أَطَّاسْ.\f*  \x ◘ \xo 10:‏38 \xt مت. 16‏:‏24؛ مك. 8‏:‏34؛ لك. 9‏:‏23؛ 14‏:‏27. \x*
\v 39 ونِّي إِ غَا يَافنْ ثُوذَارْثْ نّسْ أَذْ ت إِخْسَارْ، ذ ونِّي إِ غَا إِخْسَارنْ ثُوذَارْثْ نّسْ ذِي طّْوعْ إِنُو أَذْ ت يَافْ. \x ◘ \xo 10:‏39 \xt مت. 16‏:‏25؛ مك. 8‏:‏35؛ لك. 9‏:‏24؛ 17‏:‏33؛ يُوح. 12‏:‏25. \x*
\m 
\v 40 ونِّي كنِّيوْ إِ غَا إِقبْڒنْ، إِقبّڒْ أَيِي، ؤُ ونِّي ذ أَيِي غَا إِقبْڒنْ، إِقبّڒْ ونِّي ذ أَيِي د-إِسّكّنْ. \x ◘ \xo 10:‏40 \xt لك. 10‏:‏16؛ يُوح. 13‏:‏20. \x*
\m 
\v 41 ونِّي إِ غَا إِقبْڒنْ أَنَابِي مِينْزِي نتَّا ذ أَنَابِي، أَذْ إِطّفْ ڒْمُونثْ ن ؤُنَابِي، ذ ونِّي إِ غَا إِقبْڒنْ أَمْسڭَّاذْ س مِينْزِي نتَّا ذ أَمْسڭَّاذْ، أَذْ إِطّفْ ڒْمُونثْ ن ؤُمْسڭَّاذْ. \x ◘ \xo 10:‏41 \xt 1 إِج. 17‏:‏10؛ 18‏:‏4؛ 2 إِج. 4‏:‏8. \x*
\v 42 ونِّي إِ غَا إِوْشنْ إِ يِيجّنْ زڭْ إِنَا إِمژْيَاننْ إِجّْ ن ڒْكَاسْ ن وَامَانْ ذ أَسمَّاضْ، مْغِيرْ مِينْزِي نتَّا ذ أَمحْضَارْ \add إِنُو\add*، س ثِيذتّْ، نشّْ أَذْ أَومْ إِنِيغْ، وَارْ ذ أَسْ ثتّْرِيحْ ڒْمُونثْ نّسْ \add عمَّارْصْ\add*.“ \x ◘ \xo 10:‏42 \xt مت. 25‏:‏40؛ مك. 9‏:‏41؛ عبر. 6‏:‏10. \x*
\b
\b
\c 11
\s1 يَاسُوع ذ يُوحَانَّا أَمْسغْضَاصْ
\m 
\v 1 أَوَارْنِي ڒَامِي إِكمّڒْ يَاسُوع ڒُومُورْ نّسْ إِ ثنْعَاشْ ن إِمحْضَارنْ نّسْ، يُويُورْ سّنِّي حِيمَا أَذْ إِسّڒْمذْ ؤُ أَذْ إِبَارّحْ ذِي ثْندَّامْ نْسنْ. \x ◘ \xo 11:‏1 \xt [لك. 7‏:‏18‏-‏35] \x*
\m 
\v 2 ڒَامِي ثُوغَا يُوحَانَّا إِتّسْڒَا ذِي ڒحْبسْ خْ ڒخْذَايمْ ن لْمَاسِيحْ، إِسّكّْ شَا زڭْ إِمحْضَارنْ نّسْ. \x ◘ \xo 11:‏2 \xt لك. 7‏:‏18. \x*
\v 3 إِنَّا أَسْ: ”مَا ذ شكْ ذ ونِّي د غَا يَاسنْ نِيغْ \add إِتّْخصَّا\add* أَذْ نْرَاجَا إِجّنْ نّغْنِي؟“
\v 4 يَارَّا-د يَاسُوع، إِنَّا أَسنْ: ”رُوحمْ، ثْعَاوْذمْ إِ يُوحَانَّا مِينْ ثسْڒَامْ ذ مِينْ ثژْرِيمْ!
\v 5 أَقَا إِذَارْغَاڒنْ تّْوَاڒَانْ، إِنعْضَابنْ ڭُّورنْ ذ يِينِّي ذِي إِدْجَا ڒْبَارْصْ تّْوَاسِّيزْذِيڭنْ، إِذهْشَارْ ذوْڒنْ تّسْڒَانْ، إِمتِّيننْ تّْوَاسّْنكَّارنْ-د ؤُ ڒخْبَارْ أَصبْحَانْ إِتّْوَابَارَّاحْ إِ إِمزْڒَاضْ. \x ◘ \xo 11:‏5 \xt إِشا. 29‏:‏18؛ 35‏:‏5؛ 61‏:‏1؛ لك. 4‏:‏18. \x*
\v 6 سّعْذْ ن ونِّي وَارْ ذَايِي إِتّنْذْرِيفنْ.“
\m 
\v 7 ڒَامِي ؤُيُورنْ إِنَا، إِبْذَا يَاسُوع إِسَّاوَاڒْ أَكْ-ذ ڒْغَاشِي خْ يُوحَانَّا، إِنَّا: ”مِينْ غَارْ د-ثفّْغمْ غَارْ ڒخْڒَا مَاحنْذْ أَذْ ث ثْژَارمْ؟ مَا غَارْ إِجّْ ن ؤُغَانِيمْ إِسّنْهزَّا ث ؤُسمِّيضْ؟ \x ◘ \xo 11:‏7 \xt لك. 7‏:‏24. \x*
\v 8 مَاڒَا لَّا، مِينْ غَارْ د-ثفّْغمْ أَذْ ث ثْژَارمْ؟ مَا غَارْ إِجّْ ن بْنَاذمْ س وَارُّوضْ يَارْضبْ؟ خْزَارْ، إِنِّي يَارّْضنْ أَرُّوضْ إِغْڒَانْ يَارْضبْ، أَقَا أَثنْ ذِي ثُوذْرِينْ ن ؤُجدْجِيذْ.
\v 9 مِينْ غَارْ د-ثفّْغمْ \add خنِّي\add* مَاحنْذْ أَذْ ث ثْژَارمْ؟ إِجّْ ن ؤُنَابِي؟ وَاهْ، نشّْ أَذْ أَومْ إِنِيغْ، أَقَا ذ أَمقّْرَانْ \add عَاذْ\add* خْ ؤُنَابِي.
\v 10 مَاغَارْ أَقَا ذ وَا ذ ونِّي إِ خفْ إِتّْوَارِي \add وَاوَاڒْ-أَ\add*: ’خْژَارْ، أَذْ د-سّكّغْ لْمَالَاكْ إِنُو زَّاثْ إِ وُوذمْ نّشْ، ونِّي إِ غَا إِسّْوجْذنْ أَبْرِيذْ نّشْ زَّاثكْ.‘ \x ◘ \xo 11:‏10 \xt ؤُف. 23‏:‏20؛ مـَال. 3‏:‏1؛ مك. 1‏:‏2؛ لك. 7‏:‏27. \x*
\v 11 س ثِيذتّْ، نشّْ أَذْ أَومْ إِنِيغْ، جَارْ إِنِّي د-إِتّْوَاخڒْقنْ زِي ثمْغَارِينْ، وَارْ د-إِفِّيغْ ؤُڒَا ذ إِجّْ ذ أَمقّْرَانْ خْ يُوحَانَّا أَمْسغْضَاصْ. وَاخَّا أَمنِّي أَمژْيَانْ ذِي ثْڭلْذِيثْ ن إِجنْوَانْ ذ أَمقّْرَانْ خَاسْ.
\v 12 زڭْ وُوسَّانْ ن يُوحَانَّا أَمْسغْضَاصْ أَڒْ إِضَا ثمَّارْسْ ثْڭلْذِيثْ ن إِجنْوَانْ إِ لْعُونْفْ، ؤُشَا أَيْثْ ن بُو-ڒخْشُونثْ \add أَرزُّونْ\add* تّطّْفنْ ت. \x ◘ \xo 11:‏12 \xt لك. 16‏:‏16. \x*
\v 13 مِينْزِي مَارَّا إِنَابِييّنْ ذ شَّارِيعَا ثُوغَا تّْنَابَّانْ أَڒْ د-يَاسْ يُوحَانَّا. \f ◼ \fr 11:‏13 \ft \bd ’شَّارِيعَا‘\bd* - أَقَا-ث ذ خمْسَا ن إِذْلِيسنْ إِمزْوُورَا ن وذْلِيسْ إِقدّْسنْ ذِي ڒْعَاهْذْ أَقْذِيمْ نِّي يُورَانْ س ؤُفُوسْ ن مُوسَا: أَمزْوَارُو، ؤُفُّوغْ، إِلَاوِييّنْ (نِيغْ ’أَيْثْ ن لَاوِي‘)، ذِي ڒخْڒَا (نِيغْ ’لْعَاذَاذْ‘) ذ أَعَاوذْ ن شَّارِيعَا (نِيغْ ’أَوَاڒنْ ن مُوسَا‘). ذِي ثُوثْلَايْثْ ن ثْعِيبْرَانِيثْ قَّارنْ أَسْ ’تَّاوْرَاثْ‘، إِخْسْ أَذْ يِينِي ’أَسڒْمذْ‘ نِيغْ ’ثَاغُورِي‘.\f*
\v 14 مَاڒَا ثخْسمْ، قبْڒمْ أَقَا وَانِيثَا ذ إِلِييَا ونِّي ثُوغَا إِڭَّا أَذْ د-يَاسْ. \x ◘ \xo 11:‏14 \xt مـَال. 3‏:‏23؛ لك. 1‏:‏17. \x*
\v 15 ونِّي غَارْ إِدْجَا إِمزُّوغنْ إِ ؤُسدْجِي أَذْ إِسڒْ.“
\m 
\v 16 ”وِي أَكْ-ذ إِ غَا سّمْقُودّغْ جِّيڒْ-أَ؟ أَقَا-ث أَمشْنَاوْ إِحنْجِيرنْ إِقِّيمنْ ذِي ڒسْوَاقْ تّْڒَاغَانْ خْ إِمدُّوكَّاڒْ نْسنْ، \x ◘ \xo 11:‏16 \xt لك. 7‏:‏31. \x*
\v 17 قَّارنْ: ’أَقَا نْغنّجْ إِ كنِّيوْ، كنِّيوْ وَارْ ثشْضِيحمْ. أَقَا نوْثَا أَومْ أَڭجْذُورْ، وَارْ ثشْضِينمْ.‘
\m 
\v 18 مَاغَارْ يُوسَا-د يُوحَانَّا، وَارْ إِتّتّْ، وَارْ إِسسّْ، ؤُشَا قَّارنْ نِيثْنِي: ’ذَايسْ إِجّْ ن شِّيطَانْ!‘ \x ◘ \xo 11:‏18 \xt مت. 3‏:‏4؛ مك. 1‏:‏6. \x*
\v 19 أَقَا مِّيسْ ن بْنَاذمْ يُوسَا-د، إِتّتّْ، إِسسّْ، ؤُشَا نِيثْنِي قَّارنْ: ’أَقَا ذِينْ بْنَاذمْ إِڒْهفْ خْ مَاشَّا ذ بِينُو، نتَّا ذ أَمدُّوكّڒْ ن أَيْثْ ن ضَّارِيبَا ذ إِمذْنَابْ!‘ \add مَاشَا\add* ثِيغِيثْ ثتّْوَاسڭّذْ س ڒخْذَايمْ نّسْ.“
\b
\s1 ڒْحُوكْمْ خْ ثْندَّامْ إِ وَارْ يُومِيننْ
\m 
\v 20 ڒخْذنِّي إِبْذَا إِتّْوبّخْ ثِيندَّامْ إِ ذِي إِڭَّا أَطَّاسْ ن ڒعْجَايبْ نّسْ، مِينْزِي نِيثنْثِي وَارْ ثُوبنْثْ شَا. \x ◘ \xo 11:‏20 \xt [لك. 10‏:‏13‏-‏15] \x*
\v 21 ”ؤُشْثْ خَامْ، أَ خُورَازِينْ، ؤُشْثْ خَامْ، أَ بَايْثْ-صَايْذَا! مْڒِي ثُوغَا تّْوَاڭّنْثْ ذِي صُورْ ذ صَايْذُونْ ڒعْجَايبْ إِجهْذنْ ثِينِّي إِتّْوَاڭّنْ ذَايْكنْثْ، إِڒِي أَقَا ثُوبنْثْ أَطَّاسْ زڭْ وَامِي س ثْخَانْشثْ ن وشْضَانْ ذ يِيغّضْ \add خْ إِزدْجِيفنْ نْسنْثْ\add*. \x ◘ \xo 11:‏21 \xt 2 صم. 13‏:‏19؛ 2 إِج. 6‏:‏30؛ 19‏:‏1. \x*
\v 22 مَاشَا نشّْ أَذْ أَومْ إِنِيغْ: أَذْ يِيڒِي ڒْحَاڒْ \add إِ ثنْذِينْثْ\add* ن صُورْ ذ صَايْذُونْ إِهْونْ زِي ڒْحَاڒْ نْومْ ذڭْ وَاسّْ ن لْحِيسَابْ. \x ◘ \xo 11:‏22 \xt مت. 10‏:‏15. \x*
\v 23 إِ شمْ، أَ \add ثَانْذِينْثْ ن\add* كَافَارْنَاحُومْ، ثنِّي إِتّْوَاسّْڭعّْذنْ أَڒْ أَجنَّا؟ غَارْ ڒَاخَارْثْ إِ غَارْ د غَا ثهْوِيذْ. مِينْزِي مَاڒَا تّْوَاڭّنْثْ ذِي سَاذُومْ ڒعْجَايبْ إِجهْذنْ إِ ذَايمْ إِتّْوَاڭّنْ، إِڒِي أَقَا ثقِّيمْ أَڒْ أَسّْ ن يِيضَا.
\v 24 مَاشَا نشّْ أَذْ أَمْ إِنِيغْ، أَذْ يِيڒِي ڒْحَاڒْ إِ ثمُّورْثْ ن سَاذُومْ إِهْونْ زِي \add ڒْحَاڒْ\add* نّمْ ذڭْ وَاسّْ ن لْحِيسَابْ.“ \x ◘ \xo 11:‏24 \xt مت. 10‏:‏15. \x*
\b
\s1 ثَاژَادْجِيثْ ن يَاسُوع
\m 
\v 25 ذِي ڒْوقْثْ نِّي إِبْذَا يَاسُوع أَذْ يِينِي: ”حمْذغْ شكْ أَ بَابَا، سِيذِي ن ؤُجنَّا ذ ثمُّورْثْ، مِينْزِي ثسّْنُوفَّارذْ أَيَا خْ إِمِيغِيسنْ ذ إِمُوسْنَاونْ، \add مَاشَا\add* ثسَّارڭْبذْ أَيَا إِ إِحنْجِيرنْ. \x ◘ \xo 11:‏25 \xt [لك. 10‏:‏21‏-‏22] — أَيُوبْ 5‏:‏12؛ إِشا. 29‏:‏14؛ 1 كُور. 1‏:‏19؛ 2‏:‏7، 8. \x*
\v 26 وَاهْ، \add أَ\add* بَابَا، مِينْزِي ذ وَا ذ أَرْضَا إِ شكْ.
\v 27 مَارَّا مِينْ إِدْجَانْ إِمّوْشْ أَيِي-د زِي بَابَا، ؤُشَا ؤُڒَا ذ إِجّْ وَارْ إِسِّينْ مِّيسْ مْغِيرْ بَابَاسْ، ؤُشَا ؤُڒَا ذ إِجّْ وَارْ إِسِّينْ بَابَاسْ مْغِيرْ مِّيسْ ؤُ وِي ؤُمِي إِخْسْ مِّيسْ أَذْ ث إِسَّارْڭبْ.“ \x ◘ \xo 11:‏27 \xt مت. 28‏:‏18؛ لك. 10‏:‏22؛ يُوح. 1‏:‏18؛ 3‏:‏35؛ 6‏:‏46. \x*
\m 
\v 28 ”أَسمْ-د غَارِي مَارَّا كنِّيوْ، إِنِّي يُوحْڒنْ ذ يِينِّي يَارْبُونْ دّْقڒْ، ؤُشَا نشّْ أَذْ أَومْ وْشغْ أَرَّاحثْ،
\v 29 كْسِيمْ-د أَزَايْڒُو إِنُو خَاومْ، ڒمْذمْ زَّايِي، \add مِينْزِي\add* نشّْ ذ أَمْهِينْ ذ أَمْوَاضعْ ن وُوڒْ ؤُشَا أَذْ ثَافمْ أَرَّاحثْ إِ ڒعْمُورْ نْومْ. \x ◘ \xo 11:‏29 \xt إِزهد. 45‏:‏5؛ إِرْم. 6‏:‏16. \x*
\v 30 مِينْزِي أَزَايْڒُو ذ ڒحْمڒْ إِنُو فْسُوسنْ.“ \x ◘ \xo 11:‏30 \xt 1 يُوح. 5‏:‏3. \x*
\b
\b
\c 12
\s1 يَاسُوع ذ بَابْ ن وَاسّْ ن سّبْثْ
\m 
\v 1 ذِي ڒْوقْثْ نِّي إِشُوقْ يَاسُوع ذڭْ إِيَّارنْ ن زَّارِيعثْ ن إِمنْذِي ذِي سّبْثْ. ثُوغَا إِمحْضَارنْ نّسْ دْجُوژنْ ؤُشَا بْذَانْ ڒقّْضنْ ثِيذْرِينْ، شِّينْ \add زَّايْسنْثْ\add*. \x ◘ \xo 12:‏1 \xt [مك. 2‏:‏23‏-‏28؛ 3‏:‏1‏-‏6؛ لك. 6‏:‏1‏-‏11] — أَعَوذ. 23‏:‏24 \x*
\v 2 \add أَڒَامِي\add* ثنْ ژْرِينْ إِفَارِيسِييّنْ، نَّانْ أَسْ: ”خْزَارْ إِمحْضَارنْ نّشْ تّڭّنْ مِينْ وَارْ إِعدّْڒنْ ذِي سّبْثْ!“ \x ◘ \xo 12:‏2 \xt ؤُف. 20‏:‏10. \x*
\v 3 يَارَّا-د خَاسنْ: ”مَا وَارْ ثغْڒِيمْ شَا مِينْ إِڭَّا ذَاوُوذْ ؤُمِي إِدْجُوژْ نتَّا ذ يِينِّي أَكِيذسْ؟
\v 4 مَامّشْ يُوذفْ غَارْ ثَادَّارْثْ ن أَربِّي، إِشَّا أَغْرُومْ \add ن وسْشَانْ\add* زِي ثْزوْضَا ن سِيذِي إِ وَارْ إِحدْجْڒنْ مَاشَّا نّسْ إِ نتَّا ؤُڒَا إِ يِينِّي أَكِيذسْ، مَاشَا مْغِيرْ إِ إِكهَّاننْ وَاهَا. \x ◘ \xo 12:‏4 \xt ؤُف. 29‏:‏33؛ لَاوِي 24‏:‏9؛ 1 صم. 21‏:‏6. \x*
\v 5 نِيغْ وَارْ ثغْرِيمْ شَا ذِي شَّارِيعَا بلِّي إِكهَّاننْ إِنِّي إِدْجَانْ ذِي زَّاوشْثْ ثَامقّْرَانْثْ ذِي سّبْثْ، خطَّانْ ذِي \add ثوْصِييّثْ ن\add* سّبْثْ، وَاخَّا أَمنِّي وَارْ خَاسنْ إِبِينْ ڒْعِيبْ؟ \x ◘ \xo 12:‏5 \xt ڒخْڒ. 28‏:‏9. \x*
\v 6 نشّْ أَذْ أَومْ إِنِيغْ، ونِّي إِدْجَانْ ذ أَمقّْرَانْ خْ زَّاوشْثْ ثَامقّْرَانْثْ، أَقَا-ث ذَانِيثَا! \x ◘ \xo 12:‏6 \xt 2 إِم. 6‏:‏18. \x*
\v 7 مَاشَا مَاڒَا ثُوغَا ثْفهْمنْ مِينْ إِخْسْ أَذْ يِينِي: ’نشّْ خْسغْ أَرّحْمثْ، وَارْ إِدْجِي ذ ثَاغَارْصْثْ!‘، خنِّي أَذْ ثِيڒِي وَارْ ثتّْحَاسَابمْ شَا خْ إِمزْذَاڭنْ، \x ◘ \xo 12:‏7 \xt حُوش. 6‏:‏6؛ مِيخَا 6‏:‏8؛ مت. 9‏:‏13؛ 23‏:‏23. \x*
\v 8 مِينْزِي مِّيسْ ن بْنَاذمْ ذ بَابْ ن سّبْثْ.“ \x ◘ \xo 12:‏8 \xt مك. 2‏:‏28؛ لك. 6‏:‏5. \x*
\b
\m 
\v 9 يَاسُوع يُويُورْ سّنِّي، يُوذفْ غَارْ ثمْزِيذَا نْسنْ.
\v 10 ثُوغَا ذِينْ إِجّْ ن ورْيَازْ، أَفُوسْ نّسْ إِقُوشّحْ. سّقْسَانْ ث مَاحنْذْ زمَّارنْ أَذْ زَّايسْ شتّْشَانْ، نَّانْ: \bd ”مَا إِعدّڒْ ؤُسْڭنْفِي ذِي سّبْثْ؟“\bd* \x ◘ \xo 12:‏10 \xt لك. 14‏:‏3. \x*
\v 11 إِنَّا أَسنْ: ”مَانْ بْنَاذمْ إِ ذِينِّي جَارْ أَومْ ونِّي غَارْ إِدْجَا إِزْمَارْ إِ إِوْضَانْ ذِي ثسْرَافْثْ ذِي سّبْثْ، وَارْ ث إِتّطّفْ، حِيمَا أَذْ ث-إِ-د إِسُّوفّغْ؟ \x ◘ \xo 12:‏11 \xt ؤُف. 23‏:‏4؛ أَعَوذ. 22‏:‏4. \x*
\v 12 مشْحَاڒْ إِعْذُو بْنَاذمْ خْ إِزْمَارْ! س ؤُينِّي إِعدّڒْ أَذْ إِتّْوَاڭّْ مِينْ إِصبْحنْ ذِي سّبْثْ.“ \x ◘ \xo 12:‏12 \xt أَمز. 1‏:‏27. \x*
\v 13 ڒخْذنِّي إِنَّا أَسْ إِ بْنَاذمْ نِّي: ”سْوِيژّضْ أَفُوسْ نّشْ!“ إِسّْوِيژّضْ أَفُوسْ نّسْ ؤُشَا إِذْوڒْ إِڭّنْفَا أَمْ ونّغْنِي. \x ◘ \xo 12:‏13 \xt مك. 3‏:‏5؛ لك. 6‏:‏10\x*
\m 
\v 14 إِفَارِيسِييّنْ فّْغنْ-د غَارْ بَارَّا، مْشَاوَارنْ خَاسْ، مَامّشْ غَا ڭّنْ أَذْ ث نْغنْ. \x ◘ \xo 12:‏14 \xt مك. 3‏:‏6؛ يُوح. 5‏:‏18؛ 10‏:‏39؛ 11‏:‏53. \x*
\v 15 مَاشَا يَاسُوع إِسّنْ \add أَيَا\add* ؤُشَا يُويُورْ سّنِّي. إِضْفَارْ إِ-ث-إِ-د إِجّْ ن ڒْغَاشِي ذ أَمقّْرَانْ، إِسّْڭنْفَا إِ-ثنْ مَارَّا. \x ◘ \xo 12:‏15 \xt مت. 10‏:‏23. \x*
\v 16 يُومُورْ إِ-ثنْ س جّهْذْ مَاحنْذْ وَارْ خَاسْ سُّوفُّوغنْ ڒخْبَارْ، \x ◘ \xo 12:‏16 \xt مت. 9‏:‏30؛ لك. 5‏:‏14. \x*
\v 17 حِيمَا أَذْ إِتّْوَاكمّڒْ وَاوَاڒْ إِ إِنَّانْ ؤُنَابِي إِشَاعْيَا:
\b
\m 
\v 18 \qt ”خْزَارْ، أَمْسخَّارْ إِنُو، ونِّي فَارّْزغْ،\qt*
\m \qt أَمْعِيزّْ إِنُو، ونِّي ذِي ؤُفِيغْ أَرْضَا إِنُو.\qt*
\m \qt أَذْ خَاسْ سَّارْسغْ أَرُّوحْ إِنُو\qt*
\m \qt ؤُ نتَّا أَذْ إِبَارّحْ س ڒْحُوكْمْ إِ ڒڭْنُوسْ.\qt* \x ◘ \xo 12:‏18 \xt إِشا. 42‏:‏1؛ مت. 3‏:‏17؛ 17‏:‏5؛ مك. 1‏:‏11؛ كُول. 1‏:‏13؛ 2 بُط. 1‏:‏17. \x*
\m 
\v 19 \qt وَارْ إِتّمْشُوبُّوشْ، وَارْ إِسْغُويُّو،\qt*
\m \qt ؤُڒَا ذ إِجّْ وَارْ إِتّسْڒِي ثْمِيجَّا نّسْ\qt*
\m \qt ذڭْ إِبْرِيذنْ.\qt*
\m 
\v 20 \qt أَغَانِيمْ يَارْژنْ وَارْ ث يَارژِّي،\qt*
\m \qt ؤُڒَا ذ ثَافْثِيتْشْ إِدُّوخُّوننْ،\qt*
\m \qt وَارْ ت إِسّْخسِّي\qt*
\m \qt أَڒْ د غَا إِسُّوفّغْ ڒحْكَامْ\qt*
\m \qt إِ غَا إِنذْهنْ إِ ؤُغلّبْ،\qt*
\m 
\v 21 \qt ؤُشَا أَذْ سِّيثْمنْ ڒڭْنُوسْ ذڭْ يِيسمْ نّسْ.“\qt* \x ◘ \xo 12:‏21 \xt إِشا. 42‏:‏1‏-‏4. \x*
\b
\s1 أَوَاڒْ ن يَاسُوع خْ أَرُّوحْ إِقدّْسنْ
\m 
\v 22 ڒخْذنِّي إِوْينْ أَسْ-د إِجّْ ن ؤُمرْيَاحْ، ثُوغَا-ث ذ أَذَارْغَاڒْ ذ أَيْنَاوْ، ؤُشَا نتَّا إِسّْڭنْفَا إِ-ث، أَڒَامِي ونِّي ثُوغَا إِدْجَانْ ذ أَيْنَاوْ ذ أَذَارْغَاڒْ إِذْوڒْ إِسَّاوَاڒْ ؤُ إِتّْوَاڒَا. \x ◘ \xo 12:‏22 \xt [مك. 3‏:‏20‏-‏30؛ لك. 11‏:‏14‏-‏23؛ 12‏:‏10؛ لك. 6‏:‏43‏-‏45] — مت. 9‏:‏32\x*
\v 23 إِثبْهثْ ڒْغَاشِي مَارَّا، نَّانْ: ”مَا وَانِيثَا \add خنِّي\add* وَارْ إِدْجِي ذ مِّيسْ ن ذَاوُوذْ؟“ \x ◘ \xo 12:‏23 \xt يُوح. 4‏:‏29. \x*
\v 24 مَاشَا سْڒِينْ إِفَارِيسِييّنْ مَانْ أَيَا، نَّانْ: ”وَانِيثَا إِسُّوفُّوغْ شّْوَاطنْ مْغِيرْ س وبْرِيذْ ن بعَالْزابُوبْ، أَمقّْرَانْ ن شّْوَاطنْ.“ \f ◼ \fr 12:‏24 \ft \bd ’بعَالْزَاپُوبْ‘\bd* - وَانِيثَا ذ إِسمْ ن إِبْڒِيسْ س ثُوثْلَايْثْ ن ثْرَامِيثْ.\f*  \x ◘ \xo 12:‏24 \xt مت. 9‏:‏34؛ مك. 3‏:‏22؛ لك. 11‏:‏15. \x*
\v 25 مَاشَا يَاسُوع إِسّنْ إِخَارِّيصنْ نْسنْ، إِنَّا أَسنْ: ”كُوڒْ ثَاڭلْذِيثْ إِتّمْسبْضَانْ خْ يِيخفْ نّسْ أَذْ ثتّْوَاهلّكْ، ؤُ كُوڒْ ثَادَّارْثْ نِيغْ ثَانْذِينْثْ إِتّمْسبْضَانْ خْ يِيخفْ نّسْ وَارْ ثتّْغِيمِي شَا.
\v 26 مَاڒَا أَقَا-ث ذ شِّيطَانْ إِسُّوفُّوغْ شِّيطَانْ، أَقَا نتَّا إِتّمْسبْضَا خْ يِيخفْ نّسْ، \add خنِّي\add* مَامّشْ غَا ثقِّيمْ ثْڭلْذِيثْ نّسْ؟
\v 27 مَاڒَا نشّْ سُّوفُّوغغْ شّْوَاطنْ س وبْرِيذْ ن بعَالْزابُوبْ، س مِينْ زِي ثنْ إِ غَا سُّوفّْغنْ ثَارْوَا نْومْ؟ س ؤُينِّي نِيثْنِي أَذْ إِڒِينْ ذ ڒْقُوضَاثْ خَاومْ.
\v 28 مَاشَا مَاڒَا نشّْ سُّوفُّوغغْ شّْوَاطنْ س أَرُّوحْ ن أَربِّي، أَقَا ثُوذسْ أَومْ-د ثْڭلْذِيثْ ن أَربِّي. \x ◘ \xo 12:‏28 \xt لك. 11‏:‏20\x*
\v 29 نِيغْ مَامّشْ إِزمَّارْ حذْ أَذْ يَاذفْ غَارْ ثَادَّارْثْ ن ونِّي إِجهْذنْ مَاحنْذْ أَذْ إِكشّضْ ڒقْشُوعْ نّسْ، مَاڒَا وَارْ إِشَارْفْ ونِّي إِجهْذنْ أَمزْوَارْ؟ خنِّي إِزمَّارْ أَذْ إِكشّضْ ثَادَّارْثْ نّسْ.
\v 30 ونِّي وَارْ إِدْجِينْ أَكِيذِي، أَقَا-ث ضِيدّْ إِنُو، ونِّي وَارْ كِيذِي إِسّْمُونَانْ، أَقَا إِتّْزدْجَاعْ وَاهَا. \x ◘ \xo 12:‏30 \xt مت. 12‏:‏30؛ مك. 9‏:‏39؛ لك. 9‏:‏50؛ 11‏:‏23. \x*
\v 31 س ؤُينِّي أَذْ أَومْ إِنِيغْ: مَارَّا دّْنُوبْ ذ ؤُشقّفْ أَذْ إِتّْوَاغْفَارْ إِ إِوْذَانْ، مَاشَا أَشقّفْ ذِي أَرُّوحْ وَارْ إِتّْوَاغْفَارْ شَا إِ إِوْذَانْ. \x ◘ \xo 12:‏31 \xt مك. 3‏:‏28؛ لك. 12‏:‏10؛ 1 يُوح. 5‏:‏16. \x*
\v 32 ونِّي إِ غَا إِنِينْ أَوَاڒْ ذ أَعفَّانْ خْ مِّيسْ ن بْنَاذمْ أَذْ أَسْ إِتّْوَاغْفَارْ، مَاشَا ونِّي إِ غَا إِنِينْ أَوَاڒْ ذ أَعفَّانْ خْ أَرُّوحْ إِقدّْسنْ وَارْ ذ أَسْ إِتّْوَاغْفَارْ شَا، ؤُڒَا ذِي ڒْوقْثْ-أَ ؤُڒَا ذِي ڒْوقْثْ إِ د غَا يَاسنْ. \x ◘ \xo 12:‏32 \xt ڒخْڒ. 15‏:‏30؛ 1 صم. 2‏:‏25؛ 1 يُوح. 5‏:‏16. \x*
\b
\m 
\v 33 حسْبمْ ثَاشجَّارْثْ ذ ثَاصبْحَانْثْ ؤُڒَا ذ ڒْغِيدْجثْ نّسْ ذ ثَاصبْحَانْثْ، نِيغْ حسْبمْ ثَاشجَّارْثْ ثخْسَارْ ؤُڒَا ذ ڒْغِيدْجثْ نّسْ ثخْسَارْ، مِينْزِي ثَاشجَّارْثْ ثتّْوَاسّنْ زِي ڒْغِيدْجثْ \add نّسْ\add*.“ \f ◼ \fr 12:‏33 \ft \bd ’ثَاشجَّارْثْ‘\bd* - نِيغْ ’أَدَّاڭْ‘ (’إِدَّاڭنْ‘).\f*  \x ◘ \xo 12:‏33 \xt مت. 7‏:‏18. \x*
\b
\s1 ؤُڒْ ذ ؤُقمُّومْ
\m 
\v 34 ”أَ ثَارْوَا ن إِفِيغْرَانْ، مَامّشْ غَا ثڭّمْ أَذْ ثسِّيوْڒمْ خْ مِينْ إِصبْحنْ، وَاخَّا كنِّيوْ ذ إِعفَّاننْ، مِينْزِي \bd زڭْ ؤُعمَّارْ ن وُوڒْ أَذْ إِسِّيوڒْ ؤُقمُّومْ\bd*. \x ◘ \xo 12:‏34 \xt إِزهد. 40‏:‏11؛ مت. 3‏:‏7؛ لك. 6‏:‏45. \x*
\v 35 بْنَاذمْ أَصبْحَانْ إِسُّوفُّوغْ-د مِينْ إِصبْحنْ زِي ڒْكنْزْ أَصبْحَانْ \add ن وُوڒْ نّسْ\add* ؤُشَا بْنَاذمْ أَعفَّانْ \add إِسُّوفُّوغْ-د\add* زِي ڒْكنْزْ أَعفَّانْ نّسْ مِينْ إِعفّْننْ.
\v 36 مَاشَا نشّْ أَذْ أَومْ إِنِيغْ، بلِّي كُوڒْ أَوَاڒْ إِخْوَانْ أَذْ زَّايسْ سِّيوْڒنْ إِوْذَانْ، أَذْ زَّايسْ تّْوَاحَاسْبنْ ذڭْ وَاسّْ ن لْحِيسَابْ. \x ◘ \xo 12:‏36 \xt أَمب. 12‏:‏14؛ أَفا. 5‏:‏4. \x*
\v 37 مِينْزِي س وَاوَاڒنْ نّشْ أَذْ ثتّْوَاسڭّْذذْ ؤُشَا س وَاوَاڒنْ نّشْ أَذْ ثتّْوَاحَاسْبذْ.“ \x ◘ \xo 12:‏37 \xt 2 صم. 1‏:‏16؛ لك. 19‏:‏22. \x*
\b
\s1 ڒعْڒَامثْ ن يُونُوسْ
\m 
\v 38 شَا ن إِمْسڒْمَاذنْ ن إِذْلِيسنْ ذ إِفَارِيسِييّنْ، أَرِّينْ-د خَاسْ: ”\add أَ\add* أَمْسغَّارْ، نشِّينْ نخْسْ أَذْ نْژَارْ إِشْثْ ن ڒعْڒَامثْ زَّايكْ.“ \x ◘ \xo 12:‏38 \xt [مك. 8‏:‏11‏-‏12؛ لك. 11‏:‏29‏-‏32] — مت. 16‏:‏1؛ 1 كُور. 1‏:‏22. \x*
\v 39 مَاشَا نتَّا يَارَّا-د خَاسنْ: ”جِّيڒْ أَعفَّانْ إِزنَّانْ إِتّتَّارْ إِشْثْ ن ڒعْڒَامثْ، وَارْ ذ أَسْ إِتّْموْشِي ؤُڒَا ذ إِشْثْ ن ڒعْڒَامثْ \add مْغِيرْ\add* \bd ڒعْڒَامثْ ن يُونُوسْ\bd*.
\v 40 مِينْزِي أَمْ مَامّشْ ثُوغَا يُونُوسْ ثْڒَاثَا ن وُوسَّانْ جَارْ دْجْيَاڒِي ذ وُوسَّانْ ذڭْ ؤُعذِّيسْ ن وسْڒمْ، أَمُّو إِ غَا يِيڒِي ؤُڒَا ذ مِّيسْ ن بْنَاذمْ ذڭْ وُوڒْ ن ثمُّورْثْ ثْڒَاثَا ن وُوسَّانْ جَارْ دْجْيَاڒِي ذ وُوسَّانْ. \x ◘ \xo 12:‏40 \xt يُون. 2‏:‏1، 11 \x*
\v 41 إِرْيَازنْ ن نِينْوَا أَذْ د-كَّارنْ ذڭْ \add وَاسّْ ن\add* لْحِيسَابْ أَكْ-ذ جِّيڒْ-أَ، أَذْ ث حَاسْبنْ، مِينْزِي نِيثْنِي ثُوبنْ س ثْبَارّحْثْ ن يُونُوسْ، ؤُشَا خْزَارمْ، أَقَا ذَا ونِّي إِدْجَانْ ذ أَمقّْرَانْ خْ يُونُوسْ! \x ◘ \xo 12:‏41 \xt يُون. 3‏:‏5؛ لك. 11‏:‏32. \x*
\v 42 ثَاجدْجِيذْثْ ن لْجَانُوبْ أَذْ ثكَّارْ ذڭْ \add وَاسّْ ن\add* لْحِيسَابْ أَكْ-ذ جِّيڒْ-أَ، أَذْ خَاسْ ثحْكمْ مِينْزِي نتَّاثْ ثُوسَا-د زڭْ ؤُنڭَّارُو ن دُّونشْثْ، حِيمَا أَذْ ثْسڒْ إِ ثِيغِيثْ ن سُولِيمَانْ، ؤُشَا خْزَارمْ، أَقَا ذَا ونِّي إِدْجَانْ ذ أَمقّْرَانْ خْ سُولِيمَانْ!“ \x ◘ \xo 12:‏42 \xt 1 إِج. 10‏:‏1؛ 2 إِم. 9‏:‏1؛ لك. 11‏:‏31. \x*
\b
\s1 أَوَاڒْ ن يَاسُوع خْ ڒْخذْمثْ ن ڒَارْيَاحْ أَمنْڭُوسْ
\m 
\v 43 ”أَڒَامِي إِفّغْ ڒَارْيَاحْ أَمنْڭُوسْ زِي بْنَاذمْ، إِبْذَا إِتّْسَارَا ذڭْ إِمُوشَانْ وَارْ ذَايْسنْ بُو وَامَانْ، يَارزُّو أَرَّاحثْ، وَارْ ت إِتِّيفْ. \x ◘ \xo 12:‏43 \xt [لك. 11‏:‏24‏-‏26] \x*
\v 44 ڒخْذنِّي أَذْ يِينِي: ’أَذْ ذوْڒغْ غَارْ ثَادَّارْثْ إِنُو مَانِيسْ د-فّْغغْ!‘ ؤُشَا إِرُوحْ، يُوفَا إِ-ت ثخْوَا، ثْفَارْضْ، ثْستّفْ.
\v 45 ڒخْذنِّي يُويُورْ ؤُشَا يِيوِي أَكِيذسْ سبْعَا ن ڒَارْيَاحْ نّغْنِي، ذ إِعفَّاننْ كْثَارْ زَّايسْ، أَذْ د-أَذْفنْ، أَذْ رَاحنْ أَذْ زذْغنْ ذَايسْ، ؤُشَا أَنڭَّارُو ن بْنَاذمْ نِّي أَذْ إِذْوڒْ مَاهُو خْ ؤُمزْوَارُو. أَمُّو إِ غَا يِيڒِي \add عَاوذْ\add* أَكْ-ذ جِّيڒْ-أَ أَعفَّانْ.“ \x ◘ \xo 12:‏45 \xt عبر. 6‏:‏4، 5؛ 10‏:‏26؛ 2 بُط. 2‏:‏20. \x*
\b
\s1 يمَّاسْ ذ أَيْثْمَاسْ ن يَاسُوع
\m 
\v 46 ڒَامِي ثُوغَا عَاذْ إِسَّاوَاڒْ أَكْ-ذ ڒْغَاشِي، خْزَارْ، يمَّاسْ ذ أَيْثْمَاسْ بدّنْ بَارَّا، أَرزُّونْ أَذْ كِيذسْ سِّيوْڒنْ. \x ◘ \xo 12:‏46 \xt [مك. 3‏:‏31‏-‏35؛ لك. 8‏:‏19‏-‏21] \x*
\v 47 إِنَّا أَسْ إِجّنْ: ”خْزَارْ، يمَّاشْ ذ أَيْثْمَاشْ بدّنْ ذِي بَارَّا، أَرزُّونْ أَذْ كِيذكْ سِّيوْڒنْ.“
\v 48 \add مَاشَا\add* نتَّا يَارَّا-د خْ ونِّي ثُوغَا ذ أَسْ ث إِنَّانْ، إِنَّا: ”مِينْ ثعْنَا يمَّا ذ مِينْ عْنَانْ أَيْثْمَا؟“
\v 49 \add خَاسْ ؤُشَا\add* إِسّْوِيژّضْ س ؤُفُوسْ نّسْ غَارْ إِمحْضَارنْ نّسْ، إِنَّا: ”خْزَارْ، يمَّا، خْزَارْ، أَيْثْمَا!
\v 50 مِينْزِي مَانْ ونْ إِتّڭّنْ مِينْ إِخْسْ بَابَا إِ إِدْجَانْ ذڭْ إِجنْوَانْ، أَقَا نتَّا ذ ؤُمَا ذ ؤُتْشْمَا ذ يمَّا.“ \x ◘ \xo 12:‏50 \xt يُوح. 15‏:‏14؛ 2 كُور. 5‏:‏16؛ ڭال. 5‏:‏6؛ 6‏:‏15؛ كُول. 3‏:‏11. \x*
\b
\b
\c 13
\s1 أَمذْيَا ن ؤُفدْجَاحْ إِزَارّْعنْ
\m 
\v 1 ذڭْ وَاسّْ نِّي إِفّغْ يَاسُوع زِي ثَادَّارْثْ، إِرُوحْ إِقِّيمْ خْ ثْمَا ن ڒبْحَارْ. \x ◘ \xo 13:‏1 \xt [مك. 4‏:‏1‏-‏20؛ لك. 8‏:‏4‏-‏15] \x*
\v 2 إِمُونْ-د خَاسْ إِجّْ ن ؤُهِيمُورْ ن ڒْغَاشِي، أَڒَامِي ينْيَا ذِي ؤُغَارَّابُو، إِقِّيمْ ذَايسْ ؤُشَا ڒْغَاشِي مَارَّا بدّنْ خْ ثْمَا ن ڒبْحَارْ. \x ◘ \xo 13:‏2 \xt لك. 5‏:‏3. \x*
\v 3 إِسِّيوڒْ أَكِيذْسنْ خْ وَاطَّاسْ ن ثْمسْڒَايِينْ س إِمذْيَا، إِنَّا: ”خْزَارْ، أَفدْجَاحْ إِفّغْ، حِيمَا أَذْ إِزَارْعْ. \x ◘ \xo 13:‏3 \xt مك. 4‏:‏1‏-‏9؛ لك. 8‏:‏4‏-‏8\x*
\v 4 أَمْ ثُوغَا إِزَارّعْ، ثوْضَا شَا ن زَّارِيعثْ خْ ثْمَا ن وبْرِيذْ، خشّنْ-د إِجْضَاضْ، نقْبنْ ت.
\v 5 ثوْضَا شَا نّغْنِي خْ وژْرُو مَانِي ثُوغَا وَارْ إِدْجِي ؤُشَاڒْ أَطَّاسْ. ذغْيَا ثغْمِي-د س مِينْزِي ثَامُّورْثْ وَارْ ثُودْجِيغْ.
\v 6 ؤُمِي د-ثنْقَارْ ثْفُوشْثْ، إِشْمضْ \add ؤُغمُّويْ\add*، ؤُشَا إِسْڒَاوْ مِينْزِي وَارْ غَارسْ ثُوغِي بُو وژْوَارْ.
\v 7 شَا نّغْنِي ثوْضَا خْ إِسنَّاننْ. مْغَارنْ إِسنَّاننْ، جِييّْفنْ ت.
\v 8 شَا نّغْنِي ثوْضَا خْ ثمُّورْثْ ثَاصبْحَانْثْ، ثِيوِي-د ڒْغِيدْجثْ، شَا مْيَا، شَا نّغْنِي ستِّينْ، شَا نّغْنِي ثْڒَاثِينْ ن ثْسقَّارْ.
\v 9 ونِّي غَارْ إِدْجَا إِمزُّوغنْ إِ ؤُسدْجِي، أجّْ إِ-ث أَذْ إِسڒْ.“
\b
\m 
\v 10 \add خَاسْ ؤُشَا\add* ؤُسِينْ-د غَارسْ إِمحْضَارنْ نّسْ، نَّانْ أَسْ: ”مَايمِّي أَكِيذْسنْ ثسَّاوَاڒذْ س إِمذْيَا؟“ \x ◘ \xo 13:‏10 \xt [مك. 4‏:‏10‏-‏12؛ لك. 8‏:‏9‏-‏10] مك. 4‏:‏10‏-‏12؛ لك. 8‏:‏9‏-‏10\x*
\v 11 نتَّا يَارَّا-د، إِنَّا أَسنْ: ”مِينْزِي إِمّوْشْ أَومْ أَذْ ثسّْنمْ سِّيرّْ ن ثْڭلْذِيثْ ن إِجنْوَانْ، نِيثْنِي مَاشَا وَارْ ذ أَسنْ ث إِمّوْشْ شَا. \x ◘ \xo 13:‏11 \xt مت. 11‏:‏25؛ 2 كُور. 3‏:‏14. \x*
\v 12 مِينْزِي ونِّي غَارْ إِدْجَا أَذْ أَسْ إِمّوْشْ ؤُشَا أَذْ غَارسْ يِيڒِي س وَاطَّاسْ، مَاشَا ونِّي وَارْ غَارْ إِدْجِي شَا أَذْ زَّايسْ إِتّْوَاكّسْ ؤُڒَا ذ مِينْ غَارسْ. \x ◘ \xo 13:‏12 \xt مت. 25‏:‏29؛ مك. 4‏:‏24، 25؛ لك. 8‏:‏18؛ 19‏:‏26. \x*
\v 13 س ؤُينِّي سَّاوَاڒغْ أَكِيذْسنْ س إِمذْيَا، أَڒَامِي نِيثْنِي تّْوَاڒَانْ أَمْ وَارْ تّْوِيڒِينْ ؤُ تّسْڒَانْ أَمْ وَارْ تّسْڒِينْ، وَارْ فهّْمنْ.
\v 14 ذَايْسنْ إِ غَا إِكمّڒْ وَاوَاڒْ إِ إِنبَّا إِشَاعْيَا، إِنَّا: ’س ؤُسدْجِي أَذْ ثسْڒمْ، \add مَاشَا\add* وَارْ ثْفهّْمنْ، س ثْمُوغْڒِي أَذْ ثْژَارمْ، \add مَاشَا\add* وَارْ ثْفتّْنمْ، \x ◘ \xo 13:‏14 \xt إِشا. 6‏:‏9‏-‏10؛ مك. 4‏:‏12؛ لك. 8‏:‏10؛ يُوح. 12‏:‏40؛ ڒخ. 28‏:‏26؛ رُوم. 11‏:‏8. \x*
\v 15 مَاغَارْ ؤُڒْ ن ڒْڭنْسْ-أَ أَقَا إِقْبُوبّزْ، إِمزُّوغنْ نْسنْ ضقْڒنْ ذڭْ ؤُسدْجِي ؤُ نِيثْنِي أَقَا قّْننْ ثِيطَّاوِينْ نْسنْ، \add مَاحنْذْ\add* وَارْ تّْوِيڒِينْ س ثِيطَّاوِينْ نْسنْ، أَذْ سْڒنْ س إِمزُّوغنْ نْسنْ، أَذْ فهْمنْ س وُوڒْ نْسنْ، حِيمَا أَذْ ثُوبنْ ؤُشَا نشّْ أَذْ ثنْ سّْڭنْفِيغْ.‘ \x ◘ \xo 13:‏15 \xt إِشا. 6‏:‏9‏-‏10\x*
\v 16 مَاشَا سّعْذْ ن ثِيطَّاوِينْ نْومْ ؤُمِي تّْوَاڒَانْثْ، سّعْذْ ن إِمزُّوغنْ نْومْ ؤُمِي تّسْڒَانْ! \x ◘ \xo 13:‏16 \xt لك. 10‏:‏23؛ يُوح. 20‏:‏29؛ 1 بُط. 1‏:‏8. \x*
\v 17 س ثِيذتّْ نشّْ أَذْ أَومْ إِنِيغْ، أَطَّاسْ ن إِنَابِييّنْ ذ إِمْسڭَّاذنْ ثُوغَا خْسنْ أَذْ ژَترنْ مِينْ ثژْرِيمْ، \add مَاشَا\add* وَارْ ث ژْرِينْ، خْسنْ أَذْ سْڒنْ مِينْ ثسْڒِيمْ، وَارْ ث سْڒِينْ.“ \x ◘ \xo 13:‏17 \xt 1 بُط. 1‏:‏10. \x*
\b
\m 
\v 18 ”\add خنِّي\add* كنِّيوْ، سْڒمْ إِ ؤُمذْيَا ن ونِّي إِزَارّْعنْ.
\v 19 كُوڒْ إِجّنْ ونِّي إِتّسْڒَانْ إِ وَاوَاڒْ ن ثْڭلْذِيثْ ؤُشَا وَارْ ث إِفْهِيمْ، أَذْ غَارسْ د-يَاسْ ؤُمْعفَّانْ، أَذْ إِخْضفْ مِينْ إِتّْوَازَارْعنْ ذڭْ وُوڒْ نّسْ. أَقَا ذ مَانْ أَيَا مِينْ إِتّْوَازَارْعنْ خْ ثْمَا ن وبْرِيذْ. \x ◘ \xo 13:‏19 \xt مت. 4‏:‏23. \x*
\v 20 مِينْ إِتّْوَازَارْعنْ خْ وژْرُو، أَقَا وَا ذ ونِّي إِ غَا إِسدْجنْ أَوَاڒْ، أَذْ ث إِقْبڒْ ذغْيَا س ڒفْرَاحثْ،
\v 21 مَاشَا وَارْ ذ أَسْ إِوْثِي شَا وژْوَارْ ذڭْ إِخفْ نّسْ، أَذْ إِقِّيمْ ذْرُوسْ وَاهَا. خْمِي د غَا ثَاسْ ڒْمحْنثْ نِيغْ أَمَارّثْ ذِي طّْوعْ ن وَاوَاڒْ أَذْ إِنّذْرفْ ذغْيَا.
\v 22 مِينْ إِتّْوَازَارْعنْ جَارْ إِسنَّاننْ أَقَا وَا ذ ونِّي إِتّسْڒَانْ أَوَاڒْ، \add مَاشَا\add* أَمْنُوسْ ن ڒْوقْثْ-أَ ذ ؤُغكّْوِي ن وَاڭْڒَا أَذْ جِييّْفنْ أَوَاڒْ ؤُشَا نتَّا وَارْ د-إِتِّيوِي شَا ڒْغِيدْجثْ. \x ◘ \xo 13:‏22 \xt مت. 19‏:‏23؛ مك. 10‏:‏23؛ لك. 18‏:‏24؛ 1 تِيم. 6‏:‏9. \x*
\v 23 مِينْ إِتّْوَازَارْعنْ ذِي ثمُّورْثْ ثَاصبْحَانْثْ أَقَا وَا ذ ونِّي إِتّسْڒَانْ أَوَاڒْ ؤُشَا أَذْ ث إِفْهمْ، أَذْ يَارْبُو ؤُ أَذْ د-يَاوِي خنِّي ڒْغِيدْجثْ: إِجّنْ أَذْ يَاڒُو مْيَا ن ثْسقَّارْ، ونّغْنِي ستِّينْ ؤُشَا ونّغْنِي ثْڒَاثِينْ.“
\b
\s1 أَمذْيَا ن ڒْحَايَّارْ ذِي ڒْوسْثْ ن يِيرْذنْ
\m 
\v 24 إِوْشَا أَسنْ إِجّْ ن ؤُمذْيَا نّغْنِي، إِنَّا: ”ثَاڭلْذِيثْ ن إِجنْوَانْ أَمْ يِيجّْ ن بْنَاذمْ ثُوغَا إِزَارّعْ زَّارِيعثْ ثَاصبْحَانْثْ ذڭْ إِيَّارْ نّسْ.
\v 25 أَڒَامِي ثُوغَا إِوْذَانْ طّْصنْ، يُوسَا-د ڒعْذُو نّسْ، إِزَارْعْ ڒْحَايَّارْ ذِي ڒْوسْطْ ن يِيرْذنْ ؤُشَا يُويُورْ.
\v 26 أَڒَامِي د-إِمْغَارْ ؤُغمُّويْ ؤُشَا يِيوِي-د ڒْغِيدْجثْ، ڒخْذنِّي إِضْهَارْ-د ڒْحَايَّارْ عَاوذْ.
\v 27 خنِّي ؤُسِينْ-د إِمْسخَّارنْ ن بَابْ ن ثَادَّارْثْ، نَّانْ أَسْ: ’أَ سِيذِيثْنغْ، مَا وَارْ ثْزَارْعذْ شَا زَّارِيعثْ ثَاصبْحَانْثْ ذڭْ إِيَّارْ نّشْ؟ مَانِيسْ إِ د-يُوسَا \add خنِّي\add* ڒْحَايَّارْ-أَ إِ ذَايسْ إِدْجَانْ؟‘
\v 28 إِنَّا أَسنْ: ’أَقَا ڒعْذُو إِڭَّا مَانْ أَيَا‘. نَّانْ أَسْ إِمْسخَّارنْ: ’مَا ثخْسذْ أَذْ نْرَاحْ، أَذْ ث نيْرُو؟‘
\v 29 مَاشَا نتَّا إِنَّا: ’لَّ، حِيمَا خْمِي غَا ثْيَارّْومْ ڒْحَايَّارْ وَارْ كِيسْ ثْقدْجْعمْ ؤُڒَا ذ إِرْذنْ.
\v 30 أجّْ إِ-ثنْ أَذْ مْغَارنْ س ثْنَاينْ أَڒْ ثَاميْرَا. ذِي ڒْوقْثْ ن ثْميْرَا أَذْ إِنِيغْ إِ يِينِّي إِمجَّارنْ: ’يَارْومْ أَمزْوَارْ ڒْحَايَّارْ، شدّمْ ث ذِي ثْقبِّيطِينْ حِيمَا أَذْ إِتّْوَاسّشْمضْ، مَاشَا إِرْذنْ، يَارْومْ ث ذِي ڒْمَارْسِي إِنُو.‘ “ \x ◘ \xo 13:‏30 \xt مت. 3‏:‏12. \x*
\b
\s1 أَمذْيَا ن ثْحبُّوشْثْ ن زَّارِيعثْ ن ؤُخرْذلْ ذ ؤُمذْيَا ن ونْثُونْ
\m 
\v 31 إِوْشَا أَسنْ \add عَاوذْ\add* إِجّْ ن ؤُمذْيَا نّغْنِي، إِنَّا: ”ثَاڭلْذِيثْ ن إِجنْوَانْ أَمْ يِيشْثْ ن ثْحبُّوشْثْ ن زَّارِيعثْ ن ؤُخرْذلْ، يِيوْيِي ت-إِ-د إِجّْ ن ورْيَازْ، إِزَارْعْ إِ-ت ذڭْ إِيَّارْ نّسْ. \x ◘ \xo 13:‏31 \xt [مك. 4‏:‏30‏-‏34؛ لك. 13‏:‏18‏-‏21] \x*
\v 32 وَاخَّا نتَّاثْ ذ ثَامژْيَانْثْ قَاعْ زِي مَارَّا زَّارِيعثْ نّغْنِي، خْمِي ثْمقَّارْ، ثدّكّْوَاڒْ ذ ثَامقّْرَانْثْ زِي \add مَارَّا\add* ثِيبِّي ؤُشَا ثْذكّْوَاڒْ ذ ثَاشجَّارْثْ مَاحنْذْ أَذْ غَارسْ د-أَسنْ يِيجْضَاضْ ن ؤُجنَّا ؤُشَا أَذْ ڭّنْ ڒعْوَاشّْ نْسنْ خْ ڒفْرُوعْ نّسْ.“
\b
\m 
\v 33 إِوْشَا أَسنْ \add عَاوذْ\add* إِجّْ ن ؤُمذْيَا نّغْنِي، إِنَّا: ”ثَاڭلْذِيثْ ن إِجنْوَانْ أَمْ ونْثُونْ، ثِيوْيِي ث-إِ-د إِشْثْ ن ثمْغَارْثْ ؤُشَا ثسّْنُوفَّارْ إِ-ث ذِي ثْڒَاثَا ن ڒمْذُوذْ ن وَارنْ، أَڒَامِي إِسّْممّْ \add وَارشْثِي\add* قَاعْ.“ \x ◘ \xo 13:‏33 \xt لك. 13‏:‏20، 21. \x*
\b
\m 
\v 34 مَارَّا مَانْ أَيَا إِسِّيوڒْ زَّايسْ يَاسُوع إِ ڒْغَاشِي س إِمتِّيڒنْ ؤُشَا بْڒَا أَمذْيَا وَارْ كِيسنْ إِسِّيوڒْ شَا، \x ◘ \xo 13:‏34 \xt مك. 4‏:‏33. \x*
\v 35 حِيمَا أَذْ إِتّْوَاكمّڒْ مِينْ خفْ إِسِّيوڒْ ؤُنَابِي إِ إِنَّانْ: ”أَذْ أَرزْمغْ أَقمُّومْ إِنُو س إِمذْيَا، أَذْ بَارّْحغْ س مِينْ إِنُّوفَارنْ زڭْ وَامِي إِتّْوَاڭّْ ذْسَاسْ ن دُّونشْثْ.“ \x ◘ \xo 13:‏35 \xt إِزهد. 78‏:‏2. \x*
\b
\s1 أَفسَّارْ ن ؤُمذْيَا ن ڒْحَايَّارْ ذِي ڒْوسْثْ ن يِيرْذنْ
\m 
\v 36 ڒَامِي إِسْمحْ يَاسُوع ذِي ڒْغَاشِي أَذْ ؤُيُورنْ، إِرُوحْ غَارْ ثَادَّارْثْ. ؤُسِينْ-د غَارسْ إِمحْضَارنْ نّسْ، قَّارنْ: ”إِنِي أَنغْ مِينْ إِخْسْ أَذْ يِينِي ؤُمذْيَا ن ڒْحَايَّارْ ذ إِيَّارْ!“
\v 37 يَارَّا-د، إِنَّا أَسنْ: ”ونِّي إِزَارّْعنْ زَّارِيعثْ ثَاصبْحَانْثْ نتَّا ذ مِّيسْ ن بْنَاذمْ.
\v 38 إِيَّارْ ذ دُّونشْثْ ؤُشَا زَّارِيعثْ ثَاصبْحَانْثْ نتَّاثْ ذ ثَارْوَا ن ثْڭلْذِيثْ ؤُشَا ڒْحَايَّارْ نتَّا ذ ثَارْوَا ن ؤُمْعفَّانْ.
\v 39 ڒعْذُو ونِّي ث إِزَارْعنْ، أَقَا نتَّا ذ شِّيطَانْ، ؤُشَا صَّابثْ، أَقَا نتَّاثْ ذ قطُّو ن دُّونشْثْ ؤُ إِنِّي إِمجَّارنْ، نِيثْنِي ذ لْمَالَاكَاثْ. \x ◘ \xo 13:‏39 \xt يُووِ. 4‏:‏13؛ أَسَا. 14‏:‏15. \x*
\v 40 أَمْ مَامّشْ سّْمُوننْ ڒْحَايَّارْ ؤُشَا سّْشمْضنْ ث س ثْمسِّي، أَمُّو إِ غَا يِيڒِي غَارْ قطُّو ن دُّونشْثْ-أَ.
\v 41 مِّيسْ ن بْنَاذمْ أَذْ د-إِسّكّْ لْمَالَاكَاثْ نّسْ، أَذْ سّْحيّْذنْثْ زِي ثْڭلْذِيثْ نّسْ قَاعْ ثِيعنْكْڒِيفِينْ ذ مَارَّا إِعفَّاننْ.
\v 42 أَذْ ثنْ نْضَارنْ ذِي ڒْكُوشّثْ ن ثْمسِّي مَانِي غَا يِيڒِينْ إِمطَّاونْ ذ ؤُغزِّي ن ثغْمَاسْ. \x ◘ \xo 13:‏42 \xt مت. 8‏:‏12؛ 22‏:‏13؛ 24‏:‏51؛ 25‏:‏30؛ لك. 13‏:‏28. \x*
\v 43 خنِّي إِمْسڭَّاذنْ أَذْ أَرْغنْ أَمْ ثْفُوشْثْ ذِي ثْڭلْذِيثْ ن بَابَاثْسنْ. ونِّي غَارْ إِدْجَا إِمزُّوغنْ إِ ؤُسدْجِي أَذْ إِسڒْ.“ \x ◘ \xo 13:‏43 \xt دَان. 12‏:‏3؛ 1 كُور. 15‏:‏42. \x*
\b
\s1 أَمذْيَا ن ڒْكنْزْ ذڭْ إِيَّارْ ذ ؤُمذْيَا ن ثْيَاقُوثْ
\m 
\v 44 ”ثَاڭلْذِيثْ ن إِجنْوَانْ عَاوذْ أَمْ يِيجّْ ن ڒْكنْزْ إِتّْوَاسّْنُوفَّارنْ ذڭْ إِيَّارْ، يُوفَا إِ-ث \add إِجّْ ن\add* ورْيَازْ، إِسّْنُوفَّارْ إِ-ث ؤُشَا ذِي ڒفْرَاحثْ نّسْ يُويُورْ، إِزّنْزْ قَاعْ مِينْ إِدْجَانْ غَارسْ ؤُشَا إِسْغَا إِيَّارْ نِّي.“ \x ◘ \xo 13:‏44 \xt فِيل. 3‏:‏7. \x*
\b
\m 
\v 45 ”ثَاڭلْذِيثْ ن إِجنْوَانْ عَاوذْ أَمْ يِيجّْ ن ؤُسبَّابْ إِ يَارزُّونْ ثِييَاقُوثِينْ ثِيصبْحَانِينْ.
\v 46 ڒَامِي يُوفَا إِشْثْ ن ثْيَاقُوثْ ثِيغْڒَا أَطَّاسْ، يُويُورْ، إِزّنْزْ مَارَّا مِينْ ثُوغَا غَارسْ، خنِّي إِسْغَا إِ-ت.“
\b
\s1 أَمذْيَا ن ثْرَاشَّا ن إِسڒْمَانْ
\m 
\v 47 ”ثَاڭلْذِيثْ ن إِجنْوَانْ عَاوذْ أَمْ ثْرَاشَّا مّنْضَارنْ ت ذِي ڒبْحَارْ، ثيْرُو عْڒَامْ كُوڒْ \add أَسْڒمْ\add*.
\v 48 خْمِي ثشُّورْ، سُّوفّْغنْ ت-إِ-د إِبحْرِييّنْ غَارْ ثْمَا ن ڒبْحَارْ، قِّيمنْ ؤُشَا فَارْزنْ \add زَّايسْ\add* مِينْ إِصبْحنْ ذِي ڒقْشُوعْ \add نْسنْ\add*، مَاشَا مِينْ وَارْ إِحْڒِينْ نْضَارنْ ث.
\v 49 أَمُّو إِ غَا ثِيڒِي ذِي قطُّو ن دُّونشْثْ. أَذْ د-فّْغنْثْ لْمَالَاكَاثْ، أَذْ فَارْننْثْ إِعفَّاننْ زِي ڒْوسْطْ ن إِمْسڭَّاذنْ.
\v 50 أَذْ ثنْ نْضَارنْثْ ذِي ڒْكُوشّثْ ن ثْمسِّي مَانِي غَا يِيڒِينْ إِمطَّاونْ ذ ؤُغزِّي ن ثغْمَاسْ.“ \x ◘ \xo 13:‏50 \xt مت. 13‏:‏42. \x*
\v 51 إِنَّا أَسنْ يَاسُوع: ”مَا ثْفهْممْ إِ مَارَّا مَانْ أَيَا؟“ نَّانْ أَسْ: ”وَاهْ، أَ سِيذِيثْنغْ!“
\v 52 \add خنِّي\add* إِنَّا أَسنْ: ”س ؤُيَا كُوڒْ أَمْسڒْمَاذْ ن إِذْلِيسنْ ونِّي إِذْوڒْ ذ أَمحْضَارْ ن ثْڭلْذِيثْ ن إِجنْوَانْ، أَقَا إِڭَّا أَمْ يِيجّْ ن بَابْ ن ثَادَّارْثْ إِسُّوفُّوغْ زِي ڒْكنْزْ نّسْ مِينْ إِدْجَانْ ذ جْذِيذْ ؤُ مِينْ إِدْجَانْ ذ أَقْذِيمْ.“
\v 53 أَوَارْنِي ڒَامِي إِكمّڒْ يَاسُوع إِمذْيَا-يَا، يُويُورْ سّنِّي.
\b
\s1 أَنَابِي وَارْ غَارسْ بُو شَّانْ ذِي ثنْذِينْثْ نّسْ
\m 
\v 54 ڒَامِي د-يُوسَا غَارْ ثمُّورْثْ نّسْ، إِكَّارْ إِسّڒْمَاذْ إِ-ثنْ ذِي ثمْزِيذَاوِينْ نْسنْ أَڒَامِي قِّيمنْ ثْبهْثنْ، نَّانْ: ”مَانِيسْ ذ أَسْ د-ثكَّا ثِيغِيثْ-أَ ذ ڒعْجَايبْ-أَ؟ \x ◘ \xo 13:‏54 \xt [مك. 6‏:‏1‏-‏6؛ لك. 4‏:‏16‏-‏30] \x*
\v 55 مَا وَارْ إِدْجِي وَا ذ مِّيسْ ن ؤُنجَّارْ؟ مَا وَارْ قَّارنْ إِ يمَّاسْ مَارْيَامْ، ذ أَيْثْمَاسْ مَا وَارْ ذ أَسنْ قَّارنْ يَاعْقُوبْ ذ يَاسِي ذ شِيمْعُونْ ذ يَاهُوذَا؟ \x ◘ \xo 13:‏55 \xt مت. 1‏:‏25؛ مك. 6‏:‏3؛ يُوح. 6‏:‏42. \x*
\v 56 مَا وَارْ دْجِينْثْ سُويثْمَاسْ قَاعْ غَارْنغْ؟ مَانِيسْ ذ أَسْ د-إِكَّا مَانْ أَيَا مَارَّا؟“
\v 57 ؤُشَا نْذرْفنْ زَّايسْ. مَاشَا يَاسُوع إِنَّا أَسنْ: ”أَنَابِيعمَّارْصْ وَارْ إِدْجِي بْڒَا شَّانْ، مْغِيرْ ذِي ثنْذِينْثْ نّسْ ؤُ ذِي ثَادَّارْثْ نّسْ.“ \x ◘ \xo 13:‏57 \xt مك. 6‏:‏4؛ لك. 4‏:‏24؛ يُوح. 4‏:‏44. \x*
\v 58 ؤُشَا وَارْ إِڭِّي ذِيهَا ڒعْجَايبْ أَطَّاسْ زِي سِّيبّثْ ن بْڒَا لْ-إِيمَانْ نْسنْ.
\b
\b
\c 14
\s1 ڒْموْثْ ن يُوحَانَّا أَمْسغْضَاصْ
\m 
\v 1 ذِي ڒْوقْثْ نِّي إِسْڒَا هِيرُوذُوسْ، ڒْحَاكمْ خْ إِجّْ ن أَرْبَاعْ ن ثمُّورْثْ، ڒخْبَارْ خْ يَاسُوع. \x ◘ \xo 14:‏1 \xt [مك. 6‏:‏14‏-‏29؛ لك. 9‏:‏7‏-‏9] \x*
\v 2 إِنَّا إِ يِيمْسخَّارنْ نّسْ: ”وَانِيثَا ذ يُوحَانَّا أَمْسغْضَاصْ. أَقَا إِتّْوَاسّْنكَّارْ-د زِي ثَادَّارْثْ ن إِمتِّيننْ، س ؤُينِّي تّْوَاڭّنْثْ زَّايسْ ڒعْجَايبْ نِّي.“
\v 3 مِينْزِي هِيرُوذُوسْ ثُوغَا إِطّفْ يُوحَانَّا، إِشَارْفْ إِ-ث، إِڭَّا إِ-ث ذِي ڒحْبسْ زِي سِّيبّثْ ن هِيرُوذِييَّا، ثنِّي ذ ثَامْغَارْثْ ن فِيلِيبُّوسْ، ونِّي ذ ؤُمَاسْ \add ن هِيرُوذُوسْ\add*، \x ◘ \xo 14:‏3 \xt مك. 6‏:‏17؛ لك. 3‏:‏19. \x*
\v 4 مِينْزِي يُوحَانَّا ثُوغَا إِقَّارْ أَسْ: ”وَارْ غَاركْ بُو تّسْرِيحْ أَقَا ثِيوْيذْ ت ذ ثَامْغَارْثْ نّشْ.“ \x ◘ \xo 14:‏4 \xt لَاوِي 18‏:‏16. \x*
\v 5 \add س ؤُيَا\add* ثُوغَا إِخْسْ أَذْ ث إِنغْ، \add مَاشَا\add* ثُوغَا إِڭّْوذْ زِي ڒْغَاشِي، مِينْزِي نِيثْنِي حسْبنْ ث ذ أَنَابِي. \x ◘ \xo 14:‏5 \xt مت. 21‏:‏26. \x*
\v 6 مَاشَا ڒَامِي د-يِيوضْ وَاسّْ ن وخْڒَاقْ ن هِيرُوذُوسْ، ثشْضحْ يدْجِيسْ ن هِيرُوذِييَّا زَّاثْ إِ \add إِنوْجِيونْ إِ ذِينِّي\add* إِقِّيمنْ، ؤُشَا ثعْجبْ أَسْ إِ هِيرُوذُوسْ. \x ◘ \xo 14:‏6 \xt أَمز. 40‏:‏20؛ مك. 6‏:‏21. \x*
\v 7 س ؤُينِّي إِنَّا أَسْ س إِشْثْ ن ثْجَادْجِيثْ أَذْ أَسْ إِوْشْ مَارَّا مِينْ إِ غَا ثتَّارْ \add زَّايسْ\add*. \x ◘ \xo 14:‏7 \xt ڒقض. 11‏:‏30. \x*
\v 8 ؤُشَا نتَّاثْ، أَمْ ت ثُوغَا ثتّْوَاعَارّنْ زڭْ يمَّاسْ، ثنَّا: ”أوْشْ أَيِي ذَا خْ طّبْصِي أَزدْجِيفْ ن يُوحَانَّا أَمْسغْضَاصْ!“
\v 9 إِشْضنْ ؤُجدْجِيذْ، مَاشَا ؤُمِي ثُوغَا إِجُّودْجْ ؤُ خْ سِّيبّثْ ن يِينِّي أَكِيذسْ إِقِّيمنْ، يُومُورْ أَذْ أَسْ إِمّوْشْ \add ؤُزدْجِيفْ\add*.
\v 10 إِسّكّْ حذْ \add غَارسْ\add*، حِيمَا أَذْ إِقسّْ أَزدْجِيفْ إِ يُوحَانَّا ذِي ڒحْبسْ.
\v 11 إِوْينْ-د أَزدْجِيفْ نّسْ ذِي طّبْصِي، إِمّوْشْ أَسْ إِ ثْحنْجِيرْثْ ؤُشَا نتَّاثْ ثِيوْيِي-ث إِ يمَّاسْ.
\v 12 ؤُسِينْ-د إِمحْضَارنْ نّسْ، كْسِينْ ڒْخشْبثْ، نضْڒنْ ت. ڒخْذنِّي رُوحنْ، خبَّارنْ يَاسُوع.
\b
\s1 لْمُوعْجِيزَا ن ؤُسشِّي أَمزْوَارُو
\m 
\v 13 ڒَامِي إِسْڒَا يَاسُوع مَانْ أَيَا، إِفّغْ سّنِّي ذڭْ ؤُغَارَّابُو غَارْ إِجّْ ن ومْشَانْ إِخْڒَانْ، \add ثُوغَا-ث ذِينْ\add* وحّْذسْ. إِسْڒَا ڒْغَاشِي خْ مَانْ أَيَا، ؤُشَا ضْفَارنْ ث خْ ثمُّورْثْ زِي ثْندَّامْ. \x ◘ \xo 14:‏13 \xt [مك. 6‏:‏30‏-‏44؛ لك. 9‏:‏10‏-‏17؛ يُوح. 6‏:‏1‏-‏14] — مت. 12‏:‏15؛ \x*
\v 14 ؤُمِي د-إِفّغْ يَاسُوع زِي ثْغَارَّابُوثْ، إِژْرَا أَطَّاسْ ن ڒْغَاشِي ؤُشَا إِحِينّْ خَاسنْ، إِسّْڭنْفَا إِمهْڒَاشْ نْسنْ. \x ◘ \xo 14:‏14 \xt مت. 9‏:‏36؛ يُوح. 6‏:‏5. \x*
\v 15 ڒَامِي د-ثِيوضْ ثْمذِّيثْ، ؤُسِينْ-د غَارسْ إِمحْضَارنْ نّسْ، نَّانْ: ”أَقَا أَمْشَانْ-أَ إِخْڒَا ؤُ ڒْوقْثْ ثعْذُو. زعْمَا سْقبّضْ ڒْغَاشِي، حِيمَا أَذْ ؤُيُورنْ غَارْ ڒذْشُورْ، أَذْ سْغنْ مِينْ غَا شّنْ إِ يِيخفْ نْسنْ.“ \x ◘ \xo 14:‏15 \xt مك. 6‏:‏35؛ لك. 9‏:‏12. \x*
\v 16 مَاشَا يَاسُوع إِنَّا أَسنْ: ”نْهْڒَا مَا رُوحنْ، وْشمْ أَسنْ كنِّيوْ مِينْ غَا شّنْ.“
\v 17 نَّانْ أَسْ: ”وَارْ ذَا وَالُو مْغِيرْ خمْسَا ن ثشْنِيفِينْ ذ ثْنَاينْ ن إِسڒْمَانْ.“
\v 18 إِنَّا: ”أَوْيمْ ثنْ-د ذَا غَارِي.“
\v 19 خنِّي يُومُورْ ڒْغَاشِي أَذْ قِّيمنْ خْ أَرْبِيعْ. \add خنِّي\add* إِطّفْ خمْسَا ن ثشْنِيفِينْ ذ ثْنَاينْ نِّي ن إِسڒْمَانْ، إِخْزَارْ غَارْ ؤُجنَّا، إِبَاركْ، يَارْژَا \add إِ-ثنْثْ\add* ؤُشَا إِوْشَا ثِيشْنِيفِينْ نِّي إِ إِمحْضَارنْ ؤُ إِمحْضَارنْ وْشِينْ \add ثنْثْ\add* إِ ڒْغَاشِي. \x ◘ \xo 14:‏19 \xt 1 صم. 9‏:‏13. \x*
\v 20 مَارَّا شِّينْ، جِّيوْننْ. ڒخْذنِّي كْسِينْ إِڒقّْوَازْ إِشطّنْ: ثُوغَا ذِينْ ثنْعَاشْ ن ثْسُودْجَاثِينْعمَّارنْثْ.
\v 21 إِنِّي شِّينْ ثُوغَا أَثنْ ذِي خمْسَا أَڒفْ ن يرْيَازنْ، بْڒَا ثِيمْغَارِينْ ذ إِحنْجِيرنْ.
\b
\s1 يَاسُوع إِڭُّورْ خْ وَامَانْ ن ڒبْحَارْ
\m 
\v 22 ذغْيَا إِزِييَّارْ يَاسُوع إِمحْضَارنْ نّسْ أَذْ نْينْ ذِي ثْغَارَّابُوثْ ؤُشَا أَذْ أَسْ إِزْوَارنْ غَارْ ؤُجمَّاضْ، أَمْ إِسّْقبّضْ نتَّا ڒْغَاشِي. \x ◘ \xo 14:‏22 \xt [مك. 6‏:‏45‏-‏56؛ يُوح. 6‏:‏16‏-‏21] \x*
\v 23 \add أَوَارْنِي\add* ڒَامِي إِسّْقبّضْ ڒْغَاشِي، إِڭعّذْ غَارْ وذْرَارْ وحّْذسْ، حِيمَا أَذْ إِژَّادْجْ. ڒَامِي د-ثِيوضْ ثْمذِّيثْ، ثُوغَا إِقِّيمْ ذِينْ وحّْذسْ. \x ◘ \xo 14:‏23 \xt مك. 6‏:‏46؛ يُوح. 6‏:‏15. \x*
\v 24 أَغَارَّابُو ثُوغَا ثِيڭّْوجْ خْ ثمُّورْثْ ’إِسْثَاذِييّنْ‘ أَطَّاسْ، ؤُشَا ثتّْوَاعَارْنْ زِي سَّا غَارْ ذِيهَا س ڒمْوَاجْ، مِينْزِي أَسمِّيضْ يُوسَا أَسنْ-د ذڭْ وُوذمْ.
\v 25 مَاشَا ذڭْ حطُّو وِيسّْ أَربْعَا ن دْجِيڒثْ، يُوسَا-د غَارْسنْ يَاسُوع أَمْ إِڭُّورْ خْ وَامَانْ \add ن ڒبْحَارْ\add*.
\v 26 ؤُمِي ث ژْرِينْ إِمحْضَارنْ إِڭُّورْ خْ وَامَانْ \add ن ڒبْحَارْ\add*، نّْخڒْعنْ، نَّانْ: ”وَا ذ ڒوْحِييْ أَغدَّارْ!“، ؤُشَا سْغُوينْ زِي ثِيڭّْوُوذِي.
\v 27 ذغْيَا إِسِّيوڒْ-د غَارْسنْ يَاسُوع، إِنَّا: ”ڭّمْ ؤُڒْ، أَقَا ذ نشّْ، وَارْ تّڭّْوذمْ شَا!“
\v 28 بُوطْرُوسْ يَارَّا-د خَاسْ، إِنَّا: ”\add أَ\add* سِيذِي، مَاڒَا ذ شكْ، وصَّا أَيِي أَذْ غَاركْ د-أَسغْ خْ وَامَانْ.“
\v 29 إِنَّا أَسْ: ”أَسْ-د!“ ؤُشَا إِهْوَا-د بُوطْرُوسْ زڭْ ؤُغَارَّابُو، يُويُورْ خْ وَامَانْ، حِيمَا أَذْ د-يَاوضْ غَارْ يَاسُوع.
\v 30 مَاشَا ؤُمِي إِژْرَا أَسمِّيضْ إِجْهذْ، ثڒْقفْ إِ-ث ثِيڭّْوُوذِي ؤُشَا، أَمْ إِبْذَا إِغَارّقْ، إِڒَاغَا، إِنَّا: ”\add أَ\add* سِيذِي، سنْجمْ أَيِي!“
\v 31 ذغْيَا إِسّْوِيژّضْ سِيذِيثْنغْ أَفُوسْ نّسْ، إِطّفْ ذَايسْ، إِنَّا أَسْ: ”\add أَ شكْ\add* ونِّي ذِي إِدْجَا ذْرُوسْ ن لْ-إِيمَانْ، مَايمِّي ذَايكْ يُوذفْ شّكْ؟“
\v 32 أَوَارْنِي ڒَامِي نْيِينْ ذڭْ ؤُغَارَّابُو، يَارْسَا ؤُسمِّيضْ.
\v 33 إِنِّي إِدْجَانْ ذڭْ ؤُغَارَّابُو، ؤُسِينْ-د غَارسْ، سجْذنْ أَسْ، نَّانْ: ”س ثِيذتّْ، شكْ ذ مِّيسْ ن أَربِّي!“
\b
\m 
\v 34 أَوَارْنِي ڒَامِي ژْوَانْ \add ڒبْحَارْ\add*، إِوْضنْ غَارْ ثمُّورْثْ ن جِينِّيسَارثْ.
\v 35 \add ڒَْامِي\add* ثعقْڒنْ يرْيَازنْ ن ثمُّورْثْ نِّي، سُّوفّْغنْ ڒخْبَارْ ذِي مَارَّا ذْشُورَاثْ إِ ذ أَسْ د-إِنّْضنْ، إِوْينْ-د غَارسْ مَارَّا إِنِّي ثُوغَا إِهڒْشنْ أَطَّاسْ،
\v 36 تَّارنْ زَّايسْ أَذْ ثنْ يجّْ أَذْ حَاذَانْ مْغِيرْ أَبحْڒُوڒْ ن ؤُجدْجَابْ نّسْ، ؤُ \add مَارَّا\add* إِنِّي ث إِحَاذَانْ، ذوْڒنْ ڭّنْفَانْ.
\b
\b
\c 15
\s1 شَّارِيعَا ن أَربِّي وَارْ ثتِّيسْ أَكْ-ذ ثْغُورِي ذ ثْوصَّا ن إِوْذَانْ
\m 
\v 1 ڒخْذنِّي ؤُسِينْ-د إِمْسڒْمَاذنْ ن إِذْلِيسنْ ذ إِفَارِيسِييّنْ زِي ؤُرْشَالِيمْ غَارْ يَاسُوع، نَّانْ: \x ◘ \xo 15:‏1 \xt [مك. 7‏:‏1‏-‏23] \x*
\v 2 ”مَايمِّي تّْعدَّانْ إِمحْضَارنْ نّشْ خْ ثُوبَّارْثْ ن إِمْغَارنْ \add نّغْ\add*. نِيثْنِي وَارْ سِّيرِيذنْ شَا إِفَاسّنْ نْسنْ قْبڒْ إِ غَا شّنْ أَغْرُومْ!“
\v 3 يَارَّا-د يَاسُوع، إِنَّا أَسنْ: ”مَايمِّي كنِّيوْ عَاوذْ ثتّْعدَّامْ خْ ثوْصيّثْ ن أَربِّي زِي سِّيبّثْ ن ثُوبَّارْثْ نْومْ؟
\v 4 مِينْزِي أَربِّي ثُوغَا إِنَّا: ’وقَّارْ بَابَاشْ ذ يمَّاشْ!‘ ؤُ: ’ونِّي إِ غَا إِخْزَانْ بَابَاسْ نِيغْ يمَّاسْ، إِتّْخصَّا أَسْ أَذْ إِمّثْ!‘ \x ◘ \xo 15:‏4 \xt ؤُف. 20‏:‏12؛ 21‏:‏17؛ لَاوِي 20‏:‏9؛ أَعَوذ. 5‏:‏16؛ أَوڒن. 20‏:‏20؛ أَفا. 6‏:‏2. \x*
\v 5 مَاشَا كنِّيوْ ثقَّارمْ: ’مَارَّا وِي غَا يِينِينْ إِ بَابَاسْ نِيغْ إِ يمَّاسْ: مَارَّا مِينْ ثْزمَّارمْ أَذْ زَّايِي ثْنفْعمْ، أَقَا ڭِّيغْ ث ذ ثَاوْهِيبْثْ \add إِ أَربِّي\add*! أَمُّو نتَّا وَارْ إِحْذِيجْ \add عَاذْ\add* أَذْ إِوقَّارْ بَابَاسْ نِيغْ يمَّاسْ \add س مَارَّا مَانْ أَيَا\add*!‘
\v 6 أَمُّو ثْبطّْڒمْ أَوَاڒْ ن أَربِّي ذِي طّْوعْ ن ثُوبَّارْثْ نْومْ. \x ◘ \xo 15:‏6 \xt مك. 7‏:‏13؛ 1 تِيم. 4‏:‏3؛ 2 تِيم. 3‏:‏2. \x*
\v 7 \add كنِّيوْ، أَ\add* إِمْنَافْقنْ! إِشَاعْيَا ثُوغَا إِتّْنَابَّا خَاومْ س صّحْ، إِنَّا:
\v 8 ’ڒْْڭنْسْ-أَ إِتّْشنّعْ أَيِي س إِينْشِيشنْ نْسنْ، مَاشَا ؤُڒْ نْسنْ إِڭّْوجْ خَافِي. \x ◘ \xo 15:‏8 \xt إِشا. 29‏:‏13؛ حِز. 33‏:‏31؛ مك. 7‏:‏6. \x*
\v 9 أَقَا نِيثْنِي شنّْعنْ أَيِي بَاطڒْ، \add مِينْزِي\add* نِيثْنِي سّڒْمَاذنْ ثِيغُورِيوِينْ نِّي إِدْجَانْ ذ ثِيوصَّا ن إِوْذَانْ.‘ “ \x ◘ \xo 15:‏9 \xt إِشا. 29‏:‏13؛ مك. 7‏:‏6، 7؛ كُول. 2‏:‏18، 20، 22. \x*
\m 
\v 10 ڒَامِي ذ إِڒَاغَا-د خْ ڒْغَاشِي غَارسْ، إِنَّا أَسنْ: ”سْڒمْ \add مْلِيحْ\add*، فهْممْ! \x ◘ \xo 15:‏10 \xt مك. 7‏:‏14. \x*
\v 11 وَارْ إِدْجِي مِينْ إِتَّاذْفنْ ذڭْ ؤُقمُّومْ إِسّخْمجْ بْنَاذمْ، مَاشَا مِينْ إِ د-إِتّفّْغنْ زڭْ ؤُقمُّومْ ذ مَانْ أَيَا إِ إِسّخْمَاجنْ بْنَاذمْ.“ \x ◘ \xo 15:‏11 \xt ڒخ. 10‏:‏15؛ رُوم. 14‏:‏17، 20؛ ثِيث. 1‏:‏15. \x*
\m 
\v 12 ڒخْذنِّي ؤُسِينْ-د غَارسْ إِمحْضَارنْ نّسْ، نَّانْ أَسْ: ”مَا ثسّْنذْ بلِّي إِفَارِيسِييّنْ نْذرْفنْ ذِي مَانْ أَيَا، ڒَامِي ث سْڒِينْ؟“
\v 13 مَاشَا نتَّا يَارَّا-د، إِنَّا أَسنْ: ”كُوڒْ أَغدُّو، وَارْ ث إِژُّو بَابَا، ونِّي إِدْجَانْ ذڭْ إِجنْوَانْ، أَذْ إِتّْوَاقْڒعْ. \x ◘ \xo 15:‏13 \xt يُوح. 15‏:‏2. \x*
\v 14 أجّْ إِ-ثنْ! نِيثْنِي ذ إِذَارْغَاڒنْ ندّْهنْ إِذَارْغَاڒنْ. مَاڒَا أَذَارْغَاڒْ إِندّهْ أَذَارْغَاڒْ، أَذْ وْضَانْ س ثْنَاينْ إِذْسنْ ذڭْ وحْفُورْ.“ \x ◘ \xo 15:‏14 \xt إِشا. 42‏:‏19؛ لك. 6‏:‏39. \x*
\m 
\v 15 يَارَّا-د شِيمْعُونْ بُوطْرُوسْ، إِنَّا أَسْ: ”\add أَ\add* سِيذِي، فسَّارْ أَنغْ أَمذْيَا-يَا!“ \x ◘ \xo 15:‏15 \xt مك. 7‏:‏17. \x*
\v 16 مَاشَا يَاسُوع إِنَّا أَسنْ: ”مَا كنِّيوْ عَاذْ بْڒَا ڒفْهَامثْ أَڒْ ڒخُّو؟
\v 17 مَا وَارْ ثفْهِيممْ شَا بلِّي مَارَّا مِينْ غَا يَاذْفنْ ذڭْ ؤُقمُّومْ، أَذْ إِرَاحْ غَارْ ؤُعذِّيسْ ؤُشَا سّنِّي أَذْ إِتّْوَاسُّوفّغْ بَارَّا إِ ؤُسِيزْذڭْ؟
\v 18 مَاشَا مِينْ إِ د-إِتّفّْغنْ زڭْ ؤُقمُّومْ إِتَّاسْ-د زڭْ وُوڒْ، أَقَا ذ مَانْ أَيَا إِ إِسّْخمَّاجنْ بْنَاذمْ.
\v 19 مِينْزِي زڭْ وُوڒْ ن إِوْذَانْ إِ د-تّفّْغنْ إِخَارِّيصنْ إِعفَّاننْ، زِّينَا، أَنْغَايْ، فَارْقْ-شّْغڒْ، ثُوشفّْرَا، شّْهَاذَاثْ س ژُورْ ذ ؤُشقّفْ. \x ◘ \xo 15:‏19 \xt أَمز. 6‏:‏5؛ 8‏:‏21؛ أَوڒن. 6‏:‏14؛ إِرْم. 17‏:‏9. \x*
\v 20 أَقَا ذ مَانْ أَيَا مِينْ إِسّْخمَّاجنْ بْنَاذمْ، مَاشَا مَاشَّا س إِفَاسّنْ وَارْ إِسِّيرْذنْ وَارْ ثسّْخمِّيجْ شَا بْنَاذمْ.“
\b
\s1 لْ‘إِمَانْ ن ثمْغَارْثْ زڭْ أَيْثْ ن كنْعَانْ
\m 
\v 21 ڒخْذنِّي إِفّغْ-د يَاسُوع سّنِّي، إِرُوحْ غَارْ جّْوَايهْ ن صُورْ ذ صَايْذُونْ. \x ◘ \xo 15:‏21 \xt [مك. 7‏:‏24‏-‏30] \x*
\v 22 ؤُ خْزَارْ، إِشْثْ ن ثمْغَارْثْ زڭْ أَيْثْ ن كنْعَانْ زِي جّْوَايهْ نِّي ثسْغُويْ، ثنَّا: ”\add أَ\add* سِيذِي، \add أَ\add* مِّيسْ ن ذَاوُوذْ، أَرْحمْ أَيِي! يدْجِي أَقَا ذَايسْ شِّيطَانْ إِسّْنخْڒَاعنْ.“
\v 23 مَاشَا نتَّا وَارْ خَاسْ د-يَارِّي شَا، ؤُڒَا س يِيجّْ ن وَاوَاڒْ. ؤُسِينْ-د غَارسْ إِمحْضَارنْ نّسْ، تَّارنْ زَّايسْ، نَّانْ: ”أَژّڒْ خَاسْ، مِينْزِي نتَّاثْ ثضْفَارْ أَنغْ-د س إِغُويَّانْ.“
\v 24 نتَّا يَارَّا-د، إِنَّا أَسنْ: ”نشّْ تّْوَاسّكّغْ-د غَارْ وُودْجِي إِودَّارنْ ن ثَادَّارْثْ ن إِسْرَائِيل وَاهَا.“ \x ◘ \xo 15:‏24 \xt مت. 10‏:‏6؛ ڒخ. 13‏:‏46. \x*
\v 25 مَاشَا نتَّاثْ ثُوسَا-د، ثسْجذْ أَسْ، ثنَّا: ”أَ سِيذِي، عَاونْ أَيِي!“
\v 26 مَاشَا نتَّا يَارَّا-د، إِنَّا: ”وَارْ إِعدّڒْ أَذْ إِمّكْسِي وغْرُومْ ن إِحنْجِيرنْ، مَاحنْذْ أَذْ إِمّنْضَارْ إِ يِيطَانْ.“
\v 27 مَاشَا نتَّاثْ ثنَّا: ”وَاهْ، أَ سِيذِي، مَاغَارْ ؤُڒَا ذ إِطَانْ تّتّنْ إِڒقّْوَازْ إِ د-إِوطَّانْ زِي طَّابْڒَا ن سِيذِيثْسنْ ؤُشَا \add تّْغِيمَانْ\add* دَّارنْ.“
\v 28 ڒخْذنِّي إِنَّا أَسْ يَاسُوع: ”أَ ثَامْغَارْثْ، لْ-إِيمَانْ نّمْ إِمْغَارْ! أَذْ يِيڒِي أَمْ مَامّشْ ڒْخَاضَارْ نّمْ.“ ؤُشَا يدْجِيسْ ثڭّنْفَا ذِي ثْسَاعّثْ نِّي.
\b
\s1 أَسْڭنْفِي ن إِنعْضَابْ، إِذَاڒْغَارنْ، إِڭْنَاونْ ذ إِقجْذَاحنْ
\m 
\v 29 ؤُشَا يُويُورْ يَاسُوع سّنِّي، يِيوضْ-د غَارْ ثْمَا ن ڒبْحَارْ ن لْجَالِيلْ، إِڭعّذْ غَارْ وذْرَارْ، إِقِّيمْ ذِينِّي. \x ◘ \xo 15:‏29 \xt مك. 7‏:‏31. \x*
\v 30 يُوسَا-د غَارسْ إِجّْ ن ؤُبَارُّو أَمقّْرَانْ ن ڒْغَاشِي، إِوْينْ-د أَكِيذْسنْ إِنعْضَابنْ ذ إِذَارْغَاڒنْ ذ إِڭْنَاونْ ذ إِقجْذَاحنْ ذ إِنّغْنِي أَطَّاسْ، سَّارْسنْ ثنْ غَارْ إِضَارنْ ن يَاسُوع ؤُشَا إِسّْڭنْفَا ثنْ، \x ◘ \xo 15:‏30 \xt إِشا. 29‏:‏18؛ 35‏:‏5؛ مت. 11‏:‏5؛ لك. 7‏:‏22. \x*
\v 31 أَڒَامِي إِثبْهثْ ڒْغَاشِي، أَقَا ژْرِينْ إِڭْنَاونْ سَّاوَاڒنْ، إِقجْذَاحنْ ڭّنْفَانْ، إِنعْضَابنْ ڭُّورنْ، إِذَارْغَاڒنْ تّْوَاڒَانْ، ؤُشَا سّْعُودْجنْ أَربِّي ن إِسْرَائِيل.
\b
\s1 لْمُوعْجِيزَا ن ؤُسشِّي إِ ثْوَاڒَا وِيسّْ ثْنَاينْ
\m 
\v 32 يَاسُوع إِڒَاغَا-د خْ إِمحْضَارنْ نّسْ، إِنَّا أَسنْ: ”حِينّغْ خْ ڒْغَاشِي مِينْزِي قِّيمنْ أَكِيذِي ثْڒَاثَا ن وُوسَّانْ، وَارْ غَارْسنْ مِينْ غَا شّنْ. وَارْ خْسغْ شَا أَذْ ثنْ سّْقبّْضغْ تّْژُومَانْ، حِيمَا وَارْ تّضْعِيفنْ شَا ذڭْ وبْرِيذْ.“ \x ◘ \xo 15:‏32 \xt [مك. 8‏:‏1‏-‏10] \x*
\v 33 نَّانْ أَسْ إِمحْضَارنْ نّسْ: ”مَانِيسْ ذ غَا نَاوِي أَغْرُومْ ذِي ڒخْڒَا\add -يَا\add* إِ زِي غَا نسّشّْ إِجّْ ن ڒْغَاشِي ذ أَمقّْرَانْ أَمْ وَانِيثَا؟“
\v 34 إِنَّا أَسنْ يَاسُوع: ”مشْحَاڒْ غَارْومْ ذ أَغْرُومْ؟“ نَّانْ أَسْ: ”سبْعَا \add ن ثشْنِيفِينْ\add* ذ شَا ن إِسڒْمَانْ إِمژْيَاننْ.“
\v 35 \add خنِّي\add* يُومُورْ ڒْغَاشِي، حِيمَا أَذْ قِّيمنْ ذِي ثمُّورْثْ.
\v 36 إِكْسِي سبْعَا ن ثشْنِيفِينْ ذ إِسڒْمَانْ \add نِّي\add*، إِقَاذَا، يَارْژَا إِ-ثنْثْ ؤُشَا إِوْشَا إِ-ثنْثْ إِ إِمحْضَارنْ نّسْ ؤُشَا إِمحْضَارنْ وْشِينْ ثنْثْ إِ إِوْذَانْ. \x ◘ \xo 15:‏36 \xt 1 صم. 9‏:‏13. \x*
\v 37 مَارَّا شِّينْ، جِّيوْننْ. خنِّي يَارْونْ-د إِڒقّْوَازْ إِشطّنْ: ثُوغَا ذِينْ سبْعَا ن ثْسُودْجَاثِينْعمَّارنْثْ.
\v 38 إِنِّي ثُوغَا إِشّنْ أَقَا أَثنْ ذِي أَربْعَا أَڒَافْ ن يرْيَازنْ بْڒَا ثِيمْغَارِينْ ذ إِحنْجِيرنْ.
\v 39 أَوَارْنِي ڒَامِي إِسّْقبّضْ ڒْغَاشِي، إِنْيَا ذڭْ ؤُغَارَّابُو ؤُشَا يِيوضْ غَارْ ويْمِيرْ \add ن جّْوَايهْ\add* ن مَاڭْذُو.
\b
\b
\c 16
\s1 إِفَارِيسِييّنْ تَّارنْ إِشْثْ ن ڒعْڒَامثْ
\m 
\v 1 ؤُسِينْ-د غَارسْ إِفَارِيسِييّنْ ذ إِصَاذُوقِييّنْ، سّقْسَانْ ث حِيمَا أَذْ ث جَارّْبنْ، مَاحنْذْ أَذْ أَسنْ إِسّْشنْ شَا ن ڒعْڒَامثْ زڭْ ؤُجنَّا. \x ◘ \xo 16:‏1 \xt [مك. 8‏:‏11‏-‏13؛ لك. 12‏:‏54‏-‏56] — مت. 12‏:‏38؛ لك. 11‏:‏29؛ يُوح. 6‏:‏30. \x*
\v 2 مَاشَا نتَّا يَارَّا-د، إِنَّا أَسنْ: ”غَارْ ثْمذِّيثْ أَذْ ثِينِيمْ: ’أَقَا ڒْحَاڒْ إِفّغْ!‘، مِينْزِي أَجنَّا ذ أَزڭّْوَاغْ. \x ◘ \xo 16:‏2 \xt لك. 12‏:‏54. \x*
\v 3 ؤُ غَارْ ڒفْجَارْ \add أَذْ ثِينِيمْ\add*: ’أَقَا أَسّْ-أَ أَذْ إِسُوضْ ؤُسمِّيضْ!‘، مِينْزِي أَجنَّا ذ أَزڭّْوَاغْ أَڒْ أَبَارْشَانْ. \add أَ\add* إِمْنَافْقنْ، كنِّيوْ ثسّْنمْ أَذْ ثْفَارْزمْ ؤُذمْ ن ؤُجنَّا، مَاشَا ڒعْڒَامَاثْ ن زّْمَانْ-أَ وَارْ ثْزمَّارمْ أَذْ ثنْثْ ثْفَارْزمْ.
\v 4 جِّيڒْ أَعفَّانْ إِزنَّانْ يَارزُّو إِشْثْ ن ڒعْڒَامثْ، \add مَاشَا\add* وَارْ ذ أَسْ إِتّْموْشِي ؤُڒَا ذ إِشْثْ ن ڒعْڒَامثْ مْغِيرْ ڒعْڒَامثْ ن يُونُوسْ، أَنَابِي!“ \add خنِّي\add* إِجَّا إِ-ثنْ، إِرُوحْ. \x ◘ \xo 16:‏4 \xt يُون. 2‏:‏1؛ مت. 12‏:‏39؛ لك. 11‏:‏29. \x*
\b
\s1 أَنْثُونْ ن إِفَارِيسِييّنْ ذ إِسَاضُوقِييّنْ
\m 
\v 5 ڒَامِي د-إِوْضنْ إِمحْضَارنْ نّسْ غَارْ ؤُجمَّاضْ \add ن ڒبْحَارْ\add*، تُّونْ أَذْ كِيسنْ د-أَوْينْ أَغْرُومْ. \x ◘ \xo 16:‏5 \xt [مك. 8‏:‏14‏-‏21] \x*
\v 6 إِنَّا أَسنْ يَاسُوع: ”حْضَامْ إِخفْ نْومْ زڭْ ونْثُونْ ن إِفَارِيسِييّنْ ذ إِصَاذُوقِييّنْ.“ \x ◘ \xo 16:‏6 \xt مك. 8‏:‏15؛ لك. 12‏:‏1. \x*
\v 7 نِيثْنِي مْشَاوَارنْ جَارْ أَسنْ \add خْ مَانْ أَيَا\add*، نَّانْ: ”أَقَا \add إِنَّا\add* مَانْ أَيَا مِينْزِي وَارْ ذ نِيوِي شَا أَغْرُومْ!“
\v 8 يَاسُوع، أَمْ ثُوغَا إِسّنْ مَانْ أَيَا، إِنَّا أَسنْ: ”\add أَ\add* كنِّيوْ إِ ذِي إِدْجَا ذْرُوسْ ن لْ-إِيمَانْ، مَايمِّي ثمْشَاوَارمْ جَارْ أَومْ أَقَا مَانْ أَيَا إِدْجَا ؤُمِي وَارْ د-ثِيوْيمْ أَغْرُومْ؟
\v 9 مَا عَاذْ وَارْ ثفْهِيممْ شَا؟ مَا وَارْ ثعْقِيڒمْ شَا خْ خمْسَا ن إِڒقّْوَازْ ن وغْرُومْ إِ خمْسَا-أَڒَافْ، ؤُ مشْحَاڒْ ن ثْسُودْجَاثِينْ إِ ثْيَارْومْ؟ \x ◘ \xo 16:‏9 \xt مت. 14‏:‏17؛ مك. 6‏:‏38؛ لك. 9‏:‏13؛ يُوح. 6‏:‏9. \x*
\v 10 نِيغْ خْ سبْعَا ن إِڒقّْوَازْ ن وغْرُومْ إِ أَربْعَا أَڒَافْ، ؤُ مشْحَاڒْ ن ثْسُودْجَاثِينْ إِ ثْيَارْومْ؟ \x ◘ \xo 16:‏10 \xt مت. 15‏:‏34. \x*
\v 11 مَا عَاذْ وَارْ ثفْهِيمنْ شَا بلِّي نشّْ وَارْ كِيومْ سِّيوْڒغْ شَا خْ وغْرُومْ ؤُمِي ذ أَومْ نِّيغْ: ’حْضَامْ إِخفْ نْومْ زڭْ ونْثُونْ ن إِفَارِيسِييّنْ ذ إِصَاذُوقِييّنْ‘؟“
\v 12 سّنِّي فهْمنْ أَقَا نتَّا وَارْ ذ أَسنْ إِنِّي، مَاحنْذْ أَذْ حْضَانْ إِخفْ نْسنْ زڭْ ونْثُونْ ن وغْرُومْ، مَاشَا زِي ثْغُورِي ن إِفَارِيسِييّنْ ذ إِصَاذُوقِييّنْ.
\b
\s1 لْمَاسِيحْ ذ مِّيسْ ن أَربِّي إِدَّارنْ
\m 
\v 13 ڒَامِي د-يِيوضْ يَاسُوع غَارْ ثمُّورْثْ ن قَايْصَارِييَا-فِيلِيبُّوسْ، إِسّقْسَا إِمحْضَارنْ نّسْ: ”مِينْ عْنِيغْ نشّْ، مِّيسْ ن بْنَاذمْ، عْلَاحْسَابْ مِينْ قَّارنْ إِوْذَانْ؟“ \x ◘ \xo 16:‏13 \xt [مك. 8‏:‏27‏-‏30؛ لك. 9‏:‏18‏-‏21] \x*
\v 14 نَّانْ أَسْ: ”شَا قَّارنْ ’ذ يُوحَانَّا أَمْسغْضَاصْ‘، ؤُ ونّغْنِي: ’ذ إِلِييَا‘، ؤُ ونّغْنِي عَاوذْ: ’ذ إِرْمِييَا‘ نِيغْ ’ذ إِجّنْ زڭْ إِنَابِييّنْ‘.“ \x ◘ \xo 16:‏14 \xt مت. 14‏:‏2؛ مك. 6‏:‏15؛ 8‏:‏28؛ لك. 9‏:‏8، 19\x*
\v 15 إِنَّا أَسنْ: ”مَاشَا كنِّيوْ، مِينْ خَافِي ثقَّارمْ؟“
\v 16 يَارَّا-د خَاسْ شِيمْعُونْ بُوطْرُوسْ، إِنَّا: ”شكْ ذ لْمَاسِيحْ، مِّيسْ ن أَربِّي إِدَّارنْ.“ \x ◘ \xo 16:‏16 \xt يُوح. 6‏:‏69. \x*
\v 17 يَارَّا-د خَاسْ يَاسُوع، إِنَّا أَسْ: ”سّعْذْ نّشْ، أَ شِيمْعُونْ، مِّيسْ ن يُونَا، مِينْزِي وَارْ إِدْجِي ذ أَيْسُومْ نِيغْ ذ إِذَامّنْ إِ ذ أَشْ إِمْڒنْ مَانْ أَيَا، مَاشَا ذ بَابَا إِ إِدْجَانْ ذڭْ إِجنْوَانْ. \x ◘ \xo 16:‏17 \xt مت. 11‏:‏25. \x*
\v 18 عَاوذْ نشّْ أَذْ أَشْ إِنِيغْ، أَقَا شكْ ذ ’بُوطْرُوسْ‘، \add ذ أَژْرُو\add*، ؤُ خْ وژْرُو-يَا أَذْ بْنِيغْ ثَامسْمُونْثْ إِنُو ؤُشَا ثِيوُّورَا ن ڒَاخَارْثْ وَارْ ذ أَسْ زمَّارنْثْ. \x ◘ \xo 16:‏18 \xt إِزهد. 118‏:‏22؛ إِشا. 28‏:‏16؛ 33‏:‏20؛ يُوح. 1‏:‏43؛ 1 كُور. 3‏:‏11. \x*
\v 19 ذ نشّْ أَذْ أَشْ وْشغْ ثِيسَارُوثِينْ ن ثْڭلْذِيثْ ن إِجنْوَانْ، ؤُ مَارَّا مِينْ غَا ثْشدّذْ ذِي ثمُّورْثْ، أَذْ يِيڒِي إِشدّْ ذڭْ إِجنْوَانْ، ؤُ مَارَّا مِينْ غَا ثْفسْيذْ ذِي ثمُّورْثْ، أَذْ يِيڒِي إِفْسِي ذڭْ إِجنْوَانْ.“ \x ◘ \xo 16:‏19 \xt مت. 18‏:‏18؛ يُوح. 20‏:‏22. \x*
\v 20 ڒخْذنِّي يُومُورْ إِمحْضَارنْ نّسْ، حِيمَا وَارْ خبَّارنْ حذْ بلِّي نتَّا ذ لْمَاسِيحْ.
\b
\s1 يَاسُوع إِسَّاوَاڒْ خْ ڒْموْثْ ذ ثْنُوكْرَا نّسْ إِ ثْوَاڒَا ثَامزْوَارُوثْ
\m 
\v 21 سّنِّي إِبْذَا يَاسُوع أَذْ إِسّْشنْ إِ إِمحْضَارنْ نّسْ بلِّي إِتّْخصَّا أَسْ أَذْ إِرَاحْ غَارْ ؤُرْشَالِيمْ، أَذْ إِودّبْ أَطَّاسْ زڭْ إِمْغَارنْ \add ن ڒْڭنْسْ\add* ؤُ زڭْ إِمقّْرَاننْ ن إِكهَّاننْ ذ إِمْسڒْمَاذنْ ن إِذْلِيسنْ، أَذْ إِتّْوَانغْ ؤُشَا أَذْ د-إِتّْوَاسّْنكَّارْ ذڭْ وَاسّْ وِيسّْ ثْڒَاثَا. \x ◘ \xo 16:‏21 \xt [مك. 8‏:‏31‏-‏9‏:‏1؛ لك. 9‏:‏22‏-‏27] — مت. 17‏:‏22؛ 20‏:‏18؛ مك. 9‏:‏31؛ 10‏:‏33؛ لك. 18‏:‏31؛ 24‏:‏7. \x*
\v 22 \add مَاشَا\add* بُوطْرُوسْ يِيوْيِي ث وحّْذسْ، إِبْذَا إِتّْوبّخْ إِ-ث، إِنَّا: ”وَارْ إِتِّيڒِي، \add أَ\add* سِيذِي! مَانْ أَيَا وَارْ ذ أَشْ إِتّمْسَارْعمَّارْصْ.“
\v 23 مَاشَا نتَّا إِنّقْڒبْ، إِنَّا إِ بُوطْرُوسْ: ”فّغْ خَافِي، \add أَ\add* شِّيطَانْ، شكْ ذ إِشْثْ ن ثْعنْكْرِيفْثْ إِ نشّْ، مِينْزِي وَارْ شكْ إِشْقِي مِينْ إِدْجَانْ ن أَربِّي، مَاشَا مِينْ إِدْجَانْ ن إِوْذَانْ.“ \x ◘ \xo 16:‏23 \xt 2 صم. 19‏:‏22. \x*
\v 24 ڒخْذنِّي إِنَّا يَاسُوع إِ إِمحْضَارنْ نّسْ: ”مَاڒَا شَا ن إِجّنْ إِخْسْ أَذْ أَيِي إِضْفَارْ، أَذْ إِنْكَارْ إِخفْ نّسْ، أَذْ إِكْسِي صَّالِيبْ نّسْ ؤُشَا أَذْ أَيِي إِضْفَارْ. \x ◘ \xo 16:‏24 \xt مت. 10‏:‏38؛ مك. 8‏:‏34؛ لك. 9‏:‏23؛ 14‏:‏27. \x*
\v 25 مِينْزِي ونِّي إِخْسنْ أَذْ إِسّنْجمْ ثُوذَارْثْ نّسْ، أَذْ ت إِودَّارْ، \add مَاشَا\add* ونِّي إِ غَا إِودَّارنْ ثُوذَارْثْ نّسْ ذِي طّْوعْ إِنُو أَذْ ت يَافْ. \x ◘ \xo 16:‏25 \xt مت. 10‏:‏39؛ مك. 8‏:‏35؛ لك. 9‏:‏24؛ 17‏:‏33؛ يُوح. 12‏:‏25. \x*
\v 26 مِينْزِي مَانْ ڒفْضڒْ إِ غَارسْ غَارْ بْنَاذمْ مَاڒَا يَارْبحْ دُّونشْثْ مَارَّا، \add مَاشَا\add* إِڒْقفْ إِ-ث ذْرُوشْثْ ذِي ڒعْمَارْ نّسْ؟ نِيغْ مِينْ غَا إِوْشْ بْنَاذمْ إِ وصْڒَاحْ ن ڒعْمَارْ نّسْ؟ \x ◘ \xo 16:‏26 \xt إِزهد. 49‏:‏9؛ مك. 8‏:‏37؛ لك. 9‏:‏25. \x*
\v 27 مِينْزِي مِّيسْ ن بْنَاذمْ أَذْ د-يَاسْ س ؤُعُودْجِي ن بَابَاسْ أَكْ-ذ لْمَالَاكَاثْ نّسْ، ؤُشَا خنِّي أَذْ إِخدْجصْ كُوڒْ إِجّنْ عْلَاحْسَابْ مِينْ إِڭَّا. \x ◘ \xo 16:‏27 \xt أَيُوبْ 34‏:‏11؛ إِزهد. 62‏:‏13؛ مت. 24‏:‏30؛ 25‏:‏31؛ 26‏:‏64؛ رُوم. 2‏:‏6. \x*
\v 28 س ثِيذتّْ نشّْ أَذْ أَومْ إِنِيغْ، أَقَا شَا زڭْ إِنَا إِ ذَا إِبدّنْ، وَارْ تّْقِيسِينْ شَا ڒْموْثْ أَڒْ غَا ژَترنْ مِّيسْ ن بْنَاذمْ إِتَّاسْ-د ذِي ثْڭلْذِيثْ نّسْ.“ \x ◘ \xo 16:‏28 \xt مك. 9‏:‏1؛ لك. 9‏:‏27. \x*
\b
\b
\c 17
\s1 يَاسُوع خْ وذْرَارْ أَكْ-ذ مُوسَا ذ إِلِييَا
\m 
\v 1 أَوَارْنِي ستَّا ن وُوسَّانْ يَاسُوع يِيوِي-د بُوطْرُوسْ ذ يَاعْقُوبْ ذ ؤُمَاسْ يُوحَانَّا أَكِيذسْ، يِيوْيِي إِ-ثنْ وحّذْسنْ غَارْ إِجّْ ن وذْرَارْ يُوعْڒَا. \x ◘ \xo 17:‏1 \xt [مك. 9‏:‏2‏-‏13؛ لك. 9‏:‏28‏-‏36] — 2 بُط. 1‏:‏17. \x*
\v 2 ؤُشَا إِتّْوَابدّڒْ وَادُّوذْ ن يَاسُوع قِيبَاتْشْ نْسنْ: ثُوغَا أَغمْبُوبْ نّسْ إِتّْشعْشِيعْ أَمْ ثْفُوشْثْ، إِذْوڒْ وَارُّوضْ نّسْ ذ أَشمْڒَاڒْ أَمْ ثْفَاوْثْ.
\v 3 ؤُڒَا ذ مُوسَا ذ إِلِييَا ضْهَارنْ أَسنْ-د، سَّاوَاڒنْ أَكِيذسْ.
\v 4 بُوطْرُوسْ إِطّفْ ذڭْ وَاوَاڒْ، إِنَّا إِ يَاسُوع: ”\add أَ\add* سِيذِي، أَقَا مْلِيحْ ؤُمِي إِ ذَا ندْجْ! مَاڒَا ثخْسذْ، أَذْ نوّثْ ذَانِيثَا ثْڒَاثَا ن إِعُوشُّوثنْ ن ثْسطَّا، إِجّنْ إِ شكْ، إِجّنْ إِ مُوسَا ؤُ إِجّنْ إِ إِلِييَا.“
\v 5 أَمْ ثُوغَا إِسَّاوَاڒْ عَاذْ، إِكَّا-د خَاسنْ إِجّْ ن ؤُسيْنُو إِتّْسقْسِيقْ، إِسّْذُورِييْ ثنْ س ثِيڒِي نّسْ ؤُشَا إِشْثْ ن ثْمِيجَّا زڭْ ؤُجنَّا ثنَّا: ”ذ وَا ذ مِّي إِعِيزّنْ، ذَايسْ ؤُفِيغْ أَرْضَا إِنُو، سْڒمْ غَارسْ!“ \x ◘ \xo 17:‏5 \xt أَعَوذ. 18‏:‏15؛ إِشا. 42‏:‏1؛ مت. 3‏:‏17؛ مك. 1‏:‏11؛ 9‏:‏7؛ لك. 3‏:‏22؛ 9‏:‏35؛ ڒخ. 3‏:‏22؛ كُول. 1‏:‏13؛ 2 بُط. 1‏:‏17. \x*
\v 6 ڒَامِي سْڒِينْ إِمحْضَارنْ مَانْ أَيَا، وْضَانْ خْ ؤُغمْبُوبْ نْسنْ ؤُشَا ڭّْوذنْ أَطَّاسْ.
\v 7 يُوسَا-د غَارْسنْ يَاسُوع، إِحَاذَا ثنْ، إِنَّا: ”كَّارمْ، وَارْ تّڭّْوذمْ شَا!“
\v 8 ڒَامِي سّْڭعّْذنْ ثِيطَّاوِينْ نْسنْ، وَارْ ژْرِينْ حذْ مْغِيرْ يَاسُوع.
\m 
\v 9 أَمْ د-هْوَانْ زڭْ وذْرَارْ، يُومُورْ إِ-ثنْ يَاسُوع، إِنَّا أَسنْ: ”وَارْ سِّيوِيڒمْ خْ ڒوْحِييْ-أَ أَمْ غَارْومْ إِدْجَا إِجّْ نّغْنِي أَڒْ د غَا إِكَّارْ مِّيسْ ن بْنَاذمْ جَارْ إِمتِّيننْ.“ \x ◘ \xo 17:‏9 \xt مك. 9‏:‏9؛ لك. 9‏:‏36. \x*
\v 10 إِمحْضَارنْ سّقْسَانْ ث، نَّانْ أَسْ: ”مَايمِّي قَّارنْ إِمْسڒْمَاذنْ ن إِذْلِيسنْ أَقَا إِلِييَا أَذْ د-يَاسْ ذ أَمزْوَارُو؟“ \x ◘ \xo 17:‏10 \xt مـَال. 3‏:‏23؛ مت. 11‏:‏14؛ مك. 9‏:‏11. \x*
\v 11 يَارَّا-د يَاسُوع، إِنَّا: ”إِلِييَا أَذْ د-يَاسْ ذ أَمزْوَارُو، حِيمَا أَذْ إِتّْوَاكمّڒْ مَارَّا.
\v 12 مَاشَا نشّْ أَذْ أَومْ إِنِيغْ، خْزَارْ، إِلِييَا أَقَا يُوسَا-د، وَارْ زَّايسْ سْثعْثَارِيفنْ، مَاشَا ڭِّينْ زَّايسْ مِينْ خْسنْ. أَمُّو ؤُڒَا ذ مِّيسْ ن بْنَاذمْ أَذْ زَّايْسنْ إِودّبْ.“
\v 13 ڒخْذنِّي فهْمنْ إِمحْضَارنْ، بلِّي ثُوغَا إِسَّاوَاڒْ أَكِيذْسنْ خْ يُوحَانَّا أَمْسغْضَاصْ.
\b
\s1 يَاسُوع إِسّْڭنْفَا أَحنْجِيرْ أَمَارْيَاحْ
\m 
\v 14 ڒَامِي د-ؤُسِينْ غَارْ ڒْغَاشِي، يُوسَا-د غَارسْ إِجّْ ن بْنَاذمْ، إِوْضَا \add أَسْ\add* غَارْ إِضَارنْ، إِنَّا أَسْ: \x ◘ \xo 17:‏14 \xt [مك. 9‏:‏14‏-‏29؛ لك. 9‏:‏37‏-‏43] \x*
\v 15 ”\add أَ\add* سِيذِي، زِّيدْجزْ إِ مِّي، مِينْزِي أَقَا نتَّا إِتّْبَارْكِيكِّيضْ، إِمَّارْنِي خَاسْ ڒْحَارْ، مَاغَارْ أَطَّاسْ ن ثْوَاڒَاوِينْ إِوْضَا ذِي ثْمسِّي ؤُ ذڭْ وَامَانْ.
\v 16 إِوْيغْ ث غَارْ إِمحْضَارنْ نّشْ، \add مَاشَا\add* نِيثْنِي وَارْ زمَّارنْ أَذْ ث سّْڭنْفَانْ.“
\v 17 يَاسُوع يَارَّا-د، إِنَّا: ”أَ جِّيڒْ إِ وَارْ يُومِيننْ ذ إِمُوفْرِيغنْ، مشْحَاڒْ إِ غَا قِّيمغْ عَاذْ أَكِيذْومْ، مشْحَاڒْ عَاذْ إِ غَا قِّيمغْ صْبَارغْ أَومْ؟ أَوْيمْ ث-إِ-د غَارِي!“
\v 18 خنِّي إِوبّخْ إِ-ث يَاسُوع ؤُشَا إِفّغْ زَّايسْ شِّيطَانْ ؤُشَا إِذْوڒْ ؤُحنْجِيرْ إِڭّنْفَا زِي ثْسَاعّثْ نِّي.
\m 
\v 19 ڒخْذنِّي ؤُسِينْ-د إِمحْضَارنْ وحّذْسنْ غَارْ يَاسُوع، نَّانْ أَسْ: ”مَايمِّي نشِّينْ وَارْ نْزمَّارْ أَذْ ث نسّْڭنْفَا؟“ \x ◘ \xo 17:‏19 \xt مك. 9‏:‏28. \x*
\v 20 إِنَّا أَسنْ يَاسُوع: ”زِي سِّيبّثْ ن بْڒَا لْ-إِيمَانْ نْومْ. س ثِيذتّْ أَذْ أَومْ إِنِيغْ، مَاڒَا ذَايْومْ لْ-إِيمَانْ أَنشْثْ ن إِشْثْ ن ثْحبُّوشْثْ ن زَّارِيعثْ ن ؤُخرْذلْ، أَذْ أَسْ ثِينِيمْ إِ وذْرَارْ-أَ: ’مُوطِّي سَّا!‘، خنِّي أَذْ إِمُّوطِّي، ؤُشَا وَارْ ذِينْ إِتِّيڒِي \add عَاذْ\add* ؤُڒَا ذ إِشْثْ ن ڒْحَاجّثْ وَارْ ذ أَسْ ثْزمَّارمْ \add عَاذْ\add*. \x ◘ \xo 17:‏20 \xt مت. 21‏:‏21؛ لك. 17‏:‏6. \x*
\v 21 مَاشَا دَّارْبْ-أَ وَارْ د-إِتّفّغْ مْغِيرْ س ثْژَادْجِيثْ ذ ؤُژُومِّي.“
\b
\s1 يَاسُوع إِسَّاوَاڒْ خْ ڒْموْثْ ذ ثْنُوكْرَا نّسْ إِ ثْوَاڒَا وِيسّْ ثْنَاينْ
\m 
\v 22 ڒَامِي ثُوغَا تّْسَارَانْ ذِي لْجَالِيلْ، إِنَّا أَسنْ يَاسُوع \add إِ إِمحْضَارنْ نّسْ\add*: ”مِّيسْ ن بْنَاذمْ أَذْ إِمّوْشْ ذڭْ إِفَاسّنْ ن إِوْذَانْ. \x ◘ \xo 17:‏22 \xt [مك. 9‏:‏30‏-‏32؛ لك. 9‏:‏43‏-‏45] — مت. 16‏:‏21؛ 20‏:‏18؛ مك. 8‏:‏31؛ 10‏:‏33؛ لك. 9‏:‏22؛ 18‏:‏31. \x*
\v 23 أَذْ ث نْغنْ ؤُشَا أَذْ د-إِتّْوَاسّْنكَّارْ ذڭْ وَاسّْ وِيسّْ ثْڒَاثَا.“ \add خنِّي\add* شضْننْ أَطَّاسْ.
\b
\s1 أَوَاڒْ ن يَاسُوع خْ ضَّارِيبَا إِ زَّاوشْثْ ثَامقّْرَانْثْ
\m 
\v 24 ڒَامِي د-ؤُسِينْ غَارْ كَافَارْنَاحُومْ، قَارّْبنْ-د أَيْثْ ن ضَّارِيبَا، إِنِّي إِطّْفنْ ثْنَاينْ ن ثبْيَاسِينْ نْ ’جُّوزِينْ‘ ن نُّوقَارْثْ إِ كُوڒْ  ؤُزدْجِيفْ \add إِ ضَّارِيبَا ن زَّاوشْثْ ثَامقّْرَانْثْ\add*، غَارْ بُوطْرُوسْ، نَّانْ: ”أَمْسڒْمَاذْ نْومْ، مَا وَارْ إِتّْخدْجِيصْ ثْنَاينْ ’جُّوزِينْ‘ \add إِ زَّاوشْثْ ثَامقّْرَانْثْ\add*؟“ إِنَّا: ”وَاهْ، \add أَذْ ثنْ إِخدْجسْ\add*!“
\v 25 أَڒَامِي د-يُوذفْ بُوطْرُوسْ غَارْ ثَادَّارْثْ، إِزْوَارْ أَسْ-د يَاسُوع، إِنَّا: ”شِيمْعُونْ، مَامّشْ ثْوَاڒِيذْ شكْ، وِي زِي طّْفنْ إِجدْجِيذنْ ن دُّونشْثْ ڒعْشُورْ ذ ثنْعَاشِينْ إِ إِزمّنْ إِ كُوڒْ أَزدْجِيفْ؟ مَا زِي ثَارْوَا نْسنْ نِيغْ زڭْ إِبَارَّانِييّنْ؟“ \x ◘ \xo 17:‏25 \xt مت. 22‏:‏21؛ رُوم. 13‏:‏7. \x*
\v 26 إِنَّا أَسْ شِيمْعُونْ: ”زڭْ إِبَارَّانِييّنْ!“ إِنَّا أَسْ يَاسُوع: ”س ؤُيَا دْجَانْ ثَارْوَا ذ إِحُورِّييّنْ!
\v 27 مَاشَا حِيمَا وَارْ ثنْ نسّنْذْرِيفْ \add أَذْ أَشْ ؤُمُورغْ\add*: رُوحْ غَارْ ڒبْحَارْ، نْضَارْ ثَاصنَّارْثْ ؤُشَا أَرْزمْ أَقمُّومْ إِ ثسْڒمْثْ ثَامزْوَارُوثْ إِ د غَا إِفّْغنْ ؤُشَا أَذْ ثَافذْ إِشْثْ ن ثبْيِيسْثْ ن ؤُصُولْضِي ن ’ؤُسْثَاثِيرْ‘. كْسِي ت ؤُشَا أوْشْ إِ-ت خَافِي ؤُ خْ يِيخفْ نّشْ.“
\b
\b
\c 18
\s1 مَانْ ونْ إِدْجَانْ ذ أَمقّْرَانْ ذِي ثْڭلْذِيثْ ن إِجنْوَانْ؟
\m 
\v 1 ذِي ثْسَاعّثْ نِّي ؤُسِينْ-د إِمحْضَارنْ غَارْ يَاسُوع، نَّانْ: ”مَانْ ونْ إِدْجَانْ ذ أَمقّْرَانْ ذِي ثْڭلْذِيثْ ن إِجنْوَانْ؟“ \x ◘ \xo 18:‏1 \xt [مك. 9‏:‏33‏-‏37؛ لك. 9‏:‏46‏-‏48] — لك. 22‏:‏24. \x*
\v 2 يَاسُوع إِڒَاغَا-د خْ إِجّْ ن ؤُحنْجِيرْ غَارسْ، إِسّْبدّْ إِ-ث ذِي ڒْوسْطْ نْسنْ،
\v 3 إِنَّا: ”س ثِيذتّْ نشّْ أَذْ أَومْ إِنِيغْ: مَاڒَا وَارْ تُّوبمْ ؤُ ثْذوْڒمْ أَمْ إِحنْجِيرنْ،عمَّارْصْ أَذْ ثَاذْفمْ غَارْ ثْڭلْذِيثْ ن إِجنْوَانْ. \x ◘ \xo 18:‏3 \xt مت. 19‏:‏14؛ 1 كُور. 14‏:‏20؛ 1 بُط. 2‏:‏2. \x*
\v 4 س ؤُيَا ونِّي إِ غَا إِسّْمژْينْ إِخفْ نّسْ أَمْ ؤُحنْجِيرْ-أَ، أَقَا ذ ونِّي ذ أَمقّْرَانْ ذِي ثْڭلْذِيثْ ن إِجنْوَانْ، \x ◘ \xo 18:‏4 \xt 1 بُط. 5‏:‏6. \x*
\v 5 ؤُ ونِّي إِ غَا إِقبْڒنْ إِجّْ \add ن ؤُحنْجِيرْ\add* إِ إِدْجَانْ أَمْ ؤُحنْجِيرْ-أَ س يِيسمْ إِنُو، إِقبّڒْ أَيِي. \x ◘ \xo 18:‏5 \xt مك. 9‏:‏37؛ لك. 9‏:‏48؛ يُوح. 13‏:‏20. \x*
\b
\s1 أَعْڒَامْ غَارْ ڒْڭنْسْ خْ مِينْ إِ غَا إِغَارّنْ إِ دّنْبْ
\m 
\v 6 \add مَاشَا\add* كُوڒْ إِجّنْ ونِّي إِ غَا إِسّنْقَارْضنْ إِجّنْ زڭْ إِمژْيَاننْ-أَ إِ زَّايِي إِتَّامْننْ، إِحْڒَا أَسْ أَذْ أَسْ ثتّْوَاڭّْ إِشْثْ ن ثصْضَارْثْ ن ثْسِيرْثْ ثذْقڒْ غَارْ يِيرِي نّسْ، أَذْ إِتّْوَاسّْغَارقْ ذِي ڒَادْجَاغْ ن ڒبْحَارْ. \x ◘ \xo 18:‏6 \xt [مك. 9‏:‏42‏-‏48؛ لك. 17‏:‏1‏-‏2] \x*
\v 7 ؤُشْثْ خْ دُّونشْثْ خْ سِّيبّثْ ن ثْعنْكْرِيفِينْ. إِوَا، إِتّْخصَّا أَذْ د-أَسنْثْ ثْعنْكْرِيفِينْ، مَاشَا أَمْشُومْ ن بْنَاذمْ نِّي إِتّڭّنْ ثَاعنْكْرِيفْثْ. \x ◘ \xo 18:‏7 \xt مت. 26‏:‏24؛ ڒخ. 2‏:‏23؛ 4‏:‏27، 28؛ 1 كُور. 11‏:‏19. \x*
\v 8 مَاڒَا إِسّنْقَارْضْ شكْ ؤُفُوسْ نّشْ نِيغْ أَضَارْ نّشْ، خنِّي قسّْ إِ-ث، نْضَارْ إِ-ث خَاكْ. إِحْڒَا أَشْ أَذْ ثَاذْفذْ غَارْ ثُوذَارْثْ ذ أَقجْذَاحْ نِيغْ ذ أَمعْضُوڒْ خْ ؤُمنْضَارْ س ثْنَاينْ ن إِفَاسّنْ نِيغْ س ثْنَاينْ ن إِضَارنْ ذِي ثْمسِّي إِ ڒبْذَا. \x ◘ \xo 18:‏8 \xt أَعَوذ. 13‏:‏7؛ مت. 5‏:‏29، 30؛ مك. 9‏:‏43. \x*
\v 9 مَاڒَا ثسّنْقَارْضْ شكْ ثِيطّْ نّشْ، خنِّي قڒْعْ إِ-ت، نْضَارْ إِ-ت خَاكْ، إِحْڒَا أَشْ أَذْ ثَاذْفذْ غَارْ ثُوذَارْثْ س إِشْثْ ن ثِيطّْ خْ ؤُوطُّو ذِي جهنَّامَا إِشُّورنْ س ثْمسِّي س ثْنَاينْ ن ثِيطَّاوِينْ.
\b
\s1 أَمذْيَا ن وُودْجِي إِودَّارنْ
\m 
\v 10 غَارْومْ أَذْ ثسّحْقَارمْ إِجّنْ زڭْ إِمژْيَاننْ-أَ. مِينْزِي نشّْ أَذْ أَومْ إِنِيغْ، أَقَا لْمَالَاكَاثْ نْسنْ ذڭْ إِجنْوَانْ أَقَا ڒبْذَا تّْوَاڒَانْثْ ثِيفْرَاسْ ن بَابَا إِ إِدْجَانْ ذڭْ إِجنْوَانْ. \x ◘ \xo 18:‏10 \xt إِزهد. 34‏:‏8؛ لك. 15‏:‏3‏-‏7 \x*
\v 11 مِينْزِي مِّيسْ ن بْنَاذمْ يُوسَا-د، حِيمَا أَذْ إِسّنْجمْ مِينْ ثُوغَا إِودَّارنْ. \x ◘ \xo 18:‏11 \xt لك. 19‏:‏10. \x*
\v 12 مَامّشْ إِ ذ أَومْ إِتّْغِيڒْ؟ مَاڒَا ذِينْ شَا ن بْنَاذمْ غَارسْ مْيَا ن وُودْجِي ؤُشَا إِجّنْ زَّايْسنْ إِودَّارْ، مَا خنِّي وَارْ إِتّجِّي ثسْعَا ؤُ-ثسْعِينْ ذڭْ إِذُورَارْ، أَذْ إِرَاحْ أَذْ يَارْزُو خْ ونِّي إِودَّارنْ؟ \x ◘ \xo 18:‏12 \xt لك. 15‏:‏3. \x*
\v 13 ؤُ مَاڒَا يُوفَا إِ-ث، س ثِيذتّْ نشّْ أَذْ أَومْ إِنِيغْ، أَذْ زَّايسْ إِفَارْحْ كْثَارْ زِي مِينْ غَا إِفَارْحْ زِي ثسْعَا ؤُ-ثسْعِينْ إِنِّي وَارْ إِودَّارنْ.
\v 14 أَمُّو ؤُڒَا ذ بَابَاثْومْ إِ إِدْجَانْ ذڭْ إِجنْوَانْ وَارْ إِخْسْ أَذْ إِودَّارْ ؤُڒَا ذ إِجّْ زڭْ إِمژْيَاننْ-أَ.“
\b
\s1 دّنْبْ ن إِجّْ ن ؤُمَا
\m 
\v 15 ”مَاڒَا إِخْضَا ؤُمَاشْ أَكِيذكْ، رُوحْ غَارسْ، وبّخْ إِ-ث \add مْغِيرْ\add* جَارْ أَشْ ذ جَارْ أَسْ \add وَاهَا\add*. مَاڒَا إِسْڒَا غَاركْ، أَقَا ثَارْبحذْ ؤُمَاشْ. \x ◘ \xo 18:‏15 \xt [لك. 17‏:‏3] — لَاوِي 19‏:‏17؛ أَوڒن. 17‏:‏10؛ يَاع. 5‏:‏19. \x*
\v 16 مَاڒَا وَارْ غَاركْ إِسْڒِي شَا، أَوِي أَكِيذكْ شَا ن إِجّنْ نّغْنِي نِيغْ ثْنَاينْ، حِيمَا خْ ؤُقمُّومْ ن ثْنَاينْ نِيغْ ن ثْڒَاثَا ن ڒشْهُوذْ أَذْ إِتّْوَاضْمنْ وَاوَاڒْ مَارَّا. \x ◘ \xo 18:‏16 \xt ڒخْڒ. 35‏:‏30؛ أَعَوذ. 17‏:‏6؛ 19‏:‏15؛ يُوح. 8‏:‏17؛ 2 كُور. 13‏:‏1؛ عبر. 10‏:‏28. \x*
\v 17 مَاڒَا نتَّا وَارْ غَارْسنْ إِسْڒِي، خنِّي إِنِي ت إِ ثْمسْمُونْثْ \add ن ڒْمُومِينِينْ\add*، ؤُشَا مَاڒَا وَارْ إِسْڒِي ؤُڒَا غَارْ ثْمسْمُونْثْ، خنِّي أجّْ إِ-ث أَذْ غَارْومْ يِيڒِي أَمْ يِيجّْ ن بُو-ضَّارِيبَا نِيغْ أَمْ يِيجّْ ن ؤُكَافْرِيوْ. \x ◘ \xo 18:‏17 \xt 1 كُور. 5‏:‏9؛ 2 تس. 3‏:‏14. \x*
\v 18 س ثِيذتّْ نشّْ أَذْ أَومْ إِنِيغْ: مَارَّا مِينْ غَا ثْشدّمْ ذِي ثمُّورْثْ، أَذْ يِيڒِي إِشدّْ ذڭْ ؤُجنَّا، ؤُشَا مَارَّا مِينْ غَا ثْفسْيمْ ذِي ثمُّورْثْ، أَذْ يِيڒِي إِفْسِي ذڭْ ؤُجنَّا. \x ◘ \xo 18:‏18 \xt مت. 16‏:‏19؛ يُوح. 20‏:‏23. \x*
\v 19 أَذْ أَومْ إِنِيغْ عَاوذْ، مَاڒَا ثْنَاينْ ن إِوْذَانْ أَذْ مّْسثْفَاقنْ خْ ثمُّورْثْ خْ شَا ن ڒْحَاجّثْ إِ غَا تَّارنْ، أَقَا ذ مَانْ أَيَا ذ أَسنْ إِ غَا إِتّْوَاڭّْ زِي بَابَا إِ إِدْجَانْ ذڭْ إِجنْوَانْ.
\v 20 مِينْزِي مَانِي غَا مُوننْ ثْنَاينْ نِيغْ ثْڒَاثَا س يِيسمْ إِنُو، نشّْ أَذْ ذِينْ إِڒِيغْ ذِي ڒْوسْطْ نْسنْ.“ \x ◘ \xo 18:‏20 \xt لك. 24‏:‏15، 36. \x*
\b
\s1 أَمذْيَا ن ؤُمْسخَّارْ أَعفَّانْ
\m 
\v 21 ڒخْذنِّي يُوسَا-د غَارسْ بُوطْرُوسْ، إِنَّا: ”أَ سِيذِي، مشْحَاڒْ ن ثْوَاڒَاوِينْ إِ غَا إِخْضَا أَكِيذِي ؤُمَا، نشّْ أَذْ أَسْ سَامْحغْ؟ مَا أَڒْ سبْعَا ن ثْوَاڒَاوِينْ؟“ \x ◘ \xo 18:‏21 \xt لك. 17‏:‏4. \x*
\v 22 إِنَّا أَسْ يَاسُوع: ”وَارْ ذ أَشْ قَّارغْ شَا أَڒْ سبْعَا، مَاشَا أَڒْ سبْعِينْ ذِي سبْعَا ن إِمُورنْ ذ سبْعَا \add ن إِمُورنْ\add*! \x ◘ \xo 18:‏22 \xt مت. 6‏:‏14؛ مك. 11‏:‏25؛ كُول. 3‏:‏13. \x*
\v 23 س ؤُيَا ثتَّاوِي-د ثْڭلْذِيثْ ن إِجنْوَانْ ذڭْ إِجّْ ن ورْيَازْ ذ أَجدْجِيذْ إِ إِخْسنْ أَذْ يڭّْ ڒحْسَابْ أَكْ-ذ إِمْسخَّارنْ نّسْ.
\v 24 ؤُمِي إِبْذَا أَذْ إِمْسحْسبْ، إِوْينْ-د غَارسْ إِجّْ ن \add بْنَاذمْ\add* إِتُّورْسْ أَسْعشْرَا-أَڒَافْ ثَالِينْثْ.
\v 25 أَمْ وَارْ ثُوغِي غَارسْ مِينْ زِي غَا يَارّْ \add أَمَارْوَاسْ\add*، يُومُورْ بَابْ نّسْ، حِيمَا أَذْ إِتّْوَامّنْزْ، نتَّا ذ ثمْغَارْثْ نّسْ ذ ثَارْوَا نّسْ ذ مَارَّا مِينْ غَارسْ، حِيمَا أَذْ إِتّْوَاخدْجصْ \add ؤُمَارْوَاسْ\add*. \x ◘ \xo 18:‏25 \xt مت. 5‏:‏25. \x*
\v 26 إِوْضَا أَسْ ؤُمْسخَّارْ \add نِّي غَارْ إِضَارنْ\add*، إِسْجذْ أَسْ، إِنَّا: ’\add أَ\add* سِيذِي، صْبَارْ خَافِي، أَذْ أَشْ أَرّغْ مَارَّا.‘
\v 27 أَقَا إِزِّيدْجزْ أَسْ بَابْ ن ؤُمْسخَّارْ نِّي، إِضْڒقْ أَسْ ؤُشَا إِسَامْحْ أَسْ ذڭْ ؤُمَارْوَاسْ.
\m 
\v 28 ڒَامِي د-إِفّغْ ؤُمْسخَّارْ نِّي، يُوفَا إِجّنْ زڭْ إِنِّي ثُوغَا ذ إِمْسخَّارنْ إِمْعَاشَارنْ نّسْ ؤُ وَانِيثَا إِتُّورْسْ أَسْ مْيَا ذِينَارْ. إِطّفْ إِ-ث، إِشبَّارْ أَسْ ذڭْ يِيرِي، إِنَّا أَسْ: ’خدْجصْ أَيِي مِينْ ذ أَشْ تُّورْسغْ!‘
\v 29 إِوْضَا يَاسْ ؤُمْسخَّارْ أَمْعَاشَارْ نّسْ غَارْ إِضَارنْ نّسْ، إِحشّمْ إِ-ث، إِنَّا: ’صْبَارْ خَافِي، أَذْ أَشْ أَرّغْ \add مَارَّا\add*!‘
\v 30 مَاشَا نتَّا وَارْ إِخْسْ، إِرُوحْ إِنْضَارْ إِ-ث ذِي ڒحْبسْ أَڒْ د غَا يَارّْ أَمَارْوَاسْ.
\m 
\v 31 ڒَامِي ژْڒِينْ إِمْسخَّارنْ إِمْعَاشَارنْ نّسْ مِينْ إِمْسَارنْ، شضْننْ أَطَّاسْ ؤُشَا رُوحنْ، نَّانْ ت إِ بَابْ نْسنْ.
\v 32 ؤُشَا إِڒَاغَا-د خَاسْ سِيذِيسْ، إِنَّا أَسْ: ’\add أَ شكْ\add* أَمْسخَّارْ أَعفَّانْ، مَارَّا مِينْ ذ أَشْ تُّورْسغْ، سَامْحغْ أَشْ، مِينْزِي ثتَّارذْ أَيِي.
\v 33 مَا وَارْ إِدْجِي زعْمَا ؤُڒَا ذ شكْ خَاكْ أَذْ أَشْ إِزِّيدْجزْ ونِّي ذ أَمْسخَّارْ أَمْعَاشَارْ نّشْ أَمْ مَامّشْ إِ ذ أَيِي ثزِّيدْجذْ شكْ؟‘
\v 34 خنِّي إِخيّقْ سِيذِيسْ، إِسّعْذُو ث ذڭْ إِفَاسّنْ ن إِمْعَادّبنْ أَڒْ غَا إِخدْجصْ مَارَّا مِينْ ذَايسْ ذ أَمَارْوَاسْ.
\v 35 أَمُّو إِ غَا يڭّْ بَابَا ونِّي إِدْجَانْ ذڭْ ؤُجنَّا إِ كنِّيوْ، مَاڒَا كنِّيوْ وَارْ ثْسِيمِيحمْ س وُوڒْ كُوڒْ إِجّنْ زَّايْومْ إِ ؤُمَاسْ إِخطَّانْ نّسْ.“ \x ◘ \xo 18:‏35 \xt مت. 6‏:‏14؛ مك. 11‏:‏26؛ يَاع. 2‏:‏13. \x*
\b
\b
\c 19
\s1 أَوَاڒنْ ن يَاسُوع خْ ڒمْڒَاشْ ذ وَادْجَافْ
\m 
\v 1 أَڒَامِي إِكمّڒْ يَاسُوع أَوَاڒنْ-أَ، إِفّغْ زِي لْجَالِيلْ، يِيوضْ غَارْ جّْوَايهْ ن \add ثمُّورْثْ ن\add* يَاهُوذِييَّا، غَارْ ؤُجمَّاضْ ن \add يغْزَارْ ن\add* لْ-ؤُرْذُونْ. \x ◘ \xo 19:‏1 \xt [مك. 10‏:‏1‏-‏12] \x*
\v 2 أَقَا إِضْفَارْ إِ-ث إِجّْ ن ڒْغَاشِي ذ أَمقّْرَانْ، إِسّْڭنْفَا إِ-ثنْ ذِينِّي.
\v 3 ؤُسِينْ-د غَارسْ ؤُڒَا ذ إِفَارِيسِييّنْ، ثُوغَا أَرزُّونْ أَذْ ث جَارّْبنْ، نَّانْ \add أَسْ\add*: ”مَا إِحدْجڒْ إِ ورْيَازْ أَذْ إِدْجفْ إِ ثمْغَارْثْ نّسْ زِي مْكُوڒْ سِيبّثْ؟“ \x ◘ \xo 19:‏3 \xt مك. 10‏:‏2. \x*
\v 4 يَارَّا-د، إِنَّا أَسنْ: ”مَا وَارْ ثغْرِيمْ شَا بلِّي ونِّي \add ثنْ\add* د-إِخڒْقنْ زڭْ ؤُمزْوَارُو، إِخْڒقْ إِ-ثنْ-د ذ أَوْثمْ ذ ثوْثمْثْ، \x ◘ \xo 19:‏4 \xt أَمز. 1‏:‏17، 2‏:‏24، 5‏:‏2 \x*
\v 5 ؤُشَا أَقَا إِنَّا: ’س ؤُينِّي أَذْ إِسْمحْ ورْيَازْ ذِي بَابَاسْ ذ يمَّاسْ، أَذْ إِقّنْ غَارْ ثمْغَارْثْ نّسْ، ؤُشَا ثْنَاينْ إِذْسنْ نِّي أَذْ إِڒِينْ ذ إِشْثْ ن دَّاثْ‘؟ \x ◘ \xo 19:‏5 \xt أَمز. 2‏:‏24؛ مت. 19‏:‏6؛ مك. 10‏:‏8؛ أَفا. 5‏:‏31؛ 1 كُور. 6‏:‏16. \x*
\v 6 س ؤُيَا وَارْ تِّيڒِينْ \add عَاذْ\add* ذ ثْنَاينْ، مَاشَا ذ إِشْثْ ن أَرِّيمثْ. س ؤُينِّي مِينْ إِسّْمُونْ أَربِّي، وَارْ ث إِبطِّي بْنَاذمْ.“ \x ◘ \xo 19:‏6 \xt 1 كُور. 7‏:‏10. \x*
\v 7 نَّانْ أَسْ: ”مَايمِّي يُومُورْ مُوسَا خنِّي، مَاحنْذْ أَذْ إِوْشْ ثَابْرَاثْ ن وَادْجَافْ، حِيمَا أَذْ أَسْ إِدْجفْ؟“ \x ◘ \xo 19:‏7 \xt أَعَوذ. 24‏:‏1؛ إِرْم. 3‏:‏1. \x*
\v 8 إِنَّا أَسنْ: ”مُوسَا إِجَّا كنِّيوْ أَذْ ثدْجْفمْ إِ ثمْغَارِينْ نْومْ زِي سِّيبّثْ ن ڒقْسَاحثْ ن وُوڒَاونْ نْومْ، مَاشَا وَارْ إِدْجِي أَمُّو زڭْ ؤُمزْوَارُو.
\v 9 مَاشَا نشّْ أَذْ أَومْ إِنِيغْ: ونِّي إِ غَا إِدْجْفنْ إِ ثمْغَارْثْ نّسْ، بْڒَا مَا ثزْنَا نتَّاثْ، ؤُشَا أَذْ يِيوِي إِشْثنْ نّغْنِي، أَقَا نتَّا إِزنَّا، ؤُ ونِّي إِ غَا إِوْينْ ثَامْغَارْثْ ثنِّي إِ إِدْجْفنْ، أَقَا ؤُڒَا ذ نتَّا إِزنَّا.“ \x ◘ \xo 19:‏9 \xt مت. 5‏:‏32؛ مك. 10‏:‏11؛ لك. 16‏:‏18؛ 1 كُور. 7‏:‏10. \x*
\m 
\v 10 إِمحْضَارنْ نّسْ نَّانْ أَسْ: ”مَاڒَا أَمُّو إِ ثدْجَا ثْمسْڒَاشْثْ جَارْ بْنَاذمْ ذ ثمْغَارْثْ نّسْ، خنِّي نْهْڒَا مَا أَذْ إِمْڒشْ.“
\v 11 مَاشَا نتَّا إِنَّا أَسنْ: ”وَارْ إِدْجِي مَارَّا زمَّارنْ أَذْ قبْڒنْ أَوَاڒْ-أَ مْغِيرْ إِنِّي ؤُمِي ثمّوْشْ \add أَذْ ث إِقْبڒْ\add*. \x ◘ \xo 19:‏11 \xt 1 كُور. 7‏:‏7، 17. \x*
\v 12 مِينْزِي أَقَا ذِينْ إِنِّي إِتّْوَاقسّنْ، مِينْزِي نِيثْنِي ذ إِنِّي د-إِتّْوَاخڒْقنْ أَمُّو زڭْ ؤُعذِّيسْ ن يمَّاثْسنْ، ؤُشَا أَقَا ذِينْ إِنِّي إِتّْوَاقسّنْ، مِينْزِي نِيثْنِي تّْوَاقسّنْ زڭْ \add إِفَاسّنْ ن\add* إِوْذَانْ، ؤُشَا أَقَا ذِينْ إِنِّي إِتّْوَاقسّنْ، مِينْزِي نِيثْنِي قسّنْ إِخفْ نْسنْ ذِي طّْوعْ ن ثْڭلْذِيثْ ن إِجنْوَانْ. ونِّي إِزمَّارنْ أَذْ ث إِقْبڒْ، أجّْ إِ-ث أَذْ ث إِقْبڒْ.“
\b
\s1 يَاسُوع إِبَاركْ إِحنْجِيرنْ إِمژْيَاننْ
\m 
\v 13 ڒخْذنِّي إِوْينْ أَسْ-د إِحنْجِيرنْ إِمژْيَاننْ مَاحنْذْ أَذْ خَاسنْ إِسَّارْسْ أَفُوسْ نّسْ ؤُشَا أَذْ \add أَسنْ\add* إِكْسِي س ڒْمعْرُوفْ، مَاشَا إِمحْضَارنْ نّسْ وبّْخنْ ثنْ. \x ◘ \xo 19:‏13 \xt [مك. 10‏:‏13‏-‏16؛ لك. 18‏:‏15‏-‏17] \x*
\v 14 مَاشَا يَاسُوع إِنَّا أَسنْ: ”جّمْ إِحنْجِيرنْ أَذْ غَارِي د-أَسنْ، وَارْ ثنْ منّْعمْ شَا، مِينْزِي ثَاڭلْذِيثْ ن إِجنْوَانْ إِ يِينِّي أَمْ نِيثْنِي.“ \x ◘ \xo 19:‏14 \xt مت. 18‏:‏3؛ 1 كُور. 14‏:‏20؛ 1 بُط. 2‏:‏2. \x*
\v 15 إِسَّارْسْ خَاسنْ أَفُوسْ نّسْ ؤُشَا إِرُوحْ سّنِّي.
\b
\s1 يَاسُوع أَكْ-ذ وبْڒِيغْ ونِّي ذ بَابْ ن وَاڭْڒَا
\m 
\v 16 ؤُشَا خْزَارْ، إِقَارّبْ-د إِجّنْ، إِنَّا أَسْ: ”\add أَ\add* أَمْسغَّارْ أَصبْحَانْ، مِينْ غَا ڭّغْ ذ أَصبْحَانْ حِيمَا أَذْ غَارِي ثِيڒِي ثُوذَارْثْ إِتّْذُومَانْ؟“ \x ◘ \xo 19:‏16 \xt [مك. 10‏:‏17‏-‏31؛ لك. 18‏:‏18‏-‏30] \x*
\v 17 إِنَّا أَسْ يَاسُوع: ”مَايمِّي ذ أَيِي ثْڒَاغِيذْ ’أَصبْحَانْ‘؟ وَارْ إِدْجِي حذْ ذ أَصبْحَانْ مْغِيرْ إِجّنْ، أَقَا-ث ذ أَربِّي. مَاشَا مَاڒَا ثخْسذْ أَذْ ثَاذْفذْ غَارْ ثُوذَارْثْ، طّفْ ذِي ثْوصَّا.“
\v 18 إِنَّا أَسْ: ”مَانْ ثِينَا؟“ إِنَّا أَسْ يَاسُوع: ”وَارْ نقّْ، وَارْ زنِّي، وَارْ تِّيشَارْ، وَارْ شهّذْ س ژُورْ، \x ◘ \xo 19:‏18 \xt ؤُف. 20‏:‏12؛ لَاوِي 19‏:‏18؛ أَعَوذ. 5‏:‏16‏-‏10؛ رُوم. 13‏:‏9. \x*
\v 19 وقَّارْ بَابَاشْ ذ يمَّاشْ ؤُشَا أَذْ ثخْسذْ جَّارْ نّشْ أَمْ يِيخفْ نّشْ.“ \x ◘ \xo 19:‏19 \xt لَاوِي 19‏:‏17؛ مت. 22‏:‏39؛ مك. 12‏:‏31؛ ڭال. 5‏:‏14؛ يَاع. 2‏:‏8. \x*
\v 20 أَبْڒِيغْ إِنَّا أَسْ: ”أَقَا ضْفَارغْ ثِيمسْڒَايِينْ-أَ مَارَّا زِي ثمْژِي إِنُو. مِينْ ذ أَيِي إِتّْخِيصّنْ عَاذْ؟“
\v 21 يَاسُوع إِنَّا أَسْ: ”مَاڒَا ثخْسذْ أَذْ ثِيڒِيذْ ثْكمّْڒذْ، رُوحْ، زنْزْ مَارَّا مِينْ غَاركْ، أوْشْ إِ-ث إِ إِمزْڒَاضْ ؤُشَا أَذْ غَاركْ يِيڒِي إِجّْ ن ڒْكنْزْ ذڭْ إِجنْوَانْ. \add خنِّي\add* أَسْ-د، ضْفَارْ أَيِي-د.“ \x ◘ \xo 19:‏21 \xt مت. 6‏:‏19؛ لك. 12‏:‏33؛ 16‏:‏9؛ 1 تِيم. 6‏:‏19. \x*
\v 22 ڒَامِي إِسْڒَا وبْڒِيغْ أَوَاڒْ-أَ، إِرُوحْ إِشْضنْ، مِينْزِي ثُوغَا غَارسْ أَطَّاسْ ن وَاڭْڒَا.
\m 
\v 23 \add خَاسْ ؤُشَا\add* إِنَّا يَاسُوع إِ إِمحْضَارنْ نّسْ: ”س ثِيذتّْ، نشّْ أَذْ أَومْ إِنِيغْ، أَقَا يوْعَارْ خْ بَابْ ن وَاڭْڒَا أَذْ يَاذفْ غَارْ ثْڭلْذِيثْ ن إِجنْوَانْ. \x ◘ \xo 19:‏23 \xt أَوڒن. 11‏:‏28؛ مك. 10‏:‏23؛ لك. 18‏:‏24. \x*
\v 24 ؤُشَا نشّْ أَذْ أَومْ إِنِيغْ عَاوذْ، أَقَا إِهْونْ إِ وڒْغمْ أَذْ يكّْ زِي ثِيطّْ ن ثْسِينفْثْ خْ بُو وَاڭْڒَا أَذْ يَاذفْ غَارْ ثْڭلْذِيثْ ن أَربِّي.“
\v 25 ؤُمِي ت سْڒِينْ إِمحْضَارنْ نّسْ، نّْخڒْعنْ، نَّانْ: ”وِي إِزمَّارنْ خنِّي أَذْ إِطّفْ ثُوذَارْثْ عَاذْ؟“
\v 26 أَمْ ثُوغَا ذَايْسنْ إِخزَّارْ يَاسُوع، إِنَّا أَسنْ: ”غَارْ إِوْذَانْ مَانْ أَيَا وَارْ إِزمَّارْ، مَاشَا غَارْ أَربِّي كُوڒْشِي ذِي ثْزمَّارْ نّسْ!“ \x ◘ \xo 19:‏26 \xt أَيُوبْ 42‏:‏2؛ إِرْم. 32‏:‏17؛ زَاك. 8‏:‏6؛ لك. 1‏:‏37؛ 18‏:‏27. \x*
\m 
\v 27 \add خنِّي\add* يَارَّا-د بُوطْرُوسْ، إِنَّا أَسْ: ”خْزَارْ، أَقَا نشِّينْ نجَّا كُوڒْشِي، نضْفَارْ إِ شكْ. مِينْ غَارْنغْ إِ غَا يِيڒِينْ؟“ \x ◘ \xo 19:‏27 \xt مت. 4‏:‏20؛ مك. 10‏:‏28؛ لك. 5‏:‏11؛ 18‏:‏28. \x*
\v 28 يَاسُوع إِنَّا أَسنْ: ”س ثِيذتّْ، نشّْ أَذْ أَومْ إِنِيغْ، إِ كنِّيوْ إِنِّي ذ أَيِي د-إِضْفَارنْ، أَقَا خْمِي غَا ثِيڒِي مَارَّا دُّونشْثْ ذ جْذِيذْ، خْمِي غَا إِقِّيمْ مِّيسْ ن بْنَاذمْ خْ ڒْعَارْشْ ن ؤُعُودْجِي نّسْ، أَقَا ؤُڒَا ذ كنِّيوْ أَذْ ثقِّيممْ خْ ثنْعَاشْ ن ڒكْرَاسِي إِڭلّْذنْ، حِيمَا أَذْ ثْحكْممْ خْ ثنْعَاشْ ن ثْقبَّاڒْ ن \add أَيْثْ ن\add* إِسْرَائِيل. \x ◘ \xo 19:‏28 \xt لك. 22‏:‏30. \x*
\v 29 كُوڒْ إِجّنْ ونِّي إِسمْحنْ ذِي ثُوذْرِينْ نِيغْ ذڭْ أَيْثْمَاسْ نِيغْ ذِي سُويثْمَاسْ نِيغْ ذِي بَابَاسْ نِيغْ ذڭْ يمَّاسْ نِيغْ ذِي ثمْغَارْثْ نّسْ ذ ثَارْوَا نّسْ ؤُڒَا ذڭْ ييَّارنْ ذِي طّْوعْ ن يِيسمْ إِنُو، أَذْ إِكْسِي مْيَا ن ثْسقَّارْ ؤُشَا أَذْ إِوَارْثْ ثُوذَارْثْ إِتّْذُومَانْ. \x ◘ \xo 19:‏29 \xt أَعَوذ. 33‏:‏9؛ أَيُوبْ 42‏:‏12. \x*
\v 30 مَاشَا أَطَّاسْ ن يِينِّي إِدْجَانْ ذ إِمزْوُورَا أَذْ إِڒِينْ ذ إِنڭُّورَا، ؤُشَا إِنڭُّورَا أَذْ إِڒِينْ ذ إِمزْوُورَا.“ \x ◘ \xo 19:‏30 \xt مت. 20‏:‏16؛ مك. 10‏:‏31؛ لك. 13‏:‏30. \x*
\b
\b
\c 20
\s1 أَمذْيَا ن إِخمَّاسنْ ذڭْ ؤُمَارْجُوعْ ن ؤُضِيڒْ
\m 
\v 1 ”مِينْزِي ثَاڭلْذِيثْ ن إِجنْوَانْ أَمْ يِيجّْ ن بَابْ ن ثَادَّارْثْ، إِفّغْ غَارْ صّْبحْ زِيشْ، حِيمَا أَذْ إِشْرَا إِخمَّاسنْ إِ ؤُمَارْجعْ نّسْ ن ؤُضِيڒْ.
\v 2 ڒَامِي إِكّسْ أَوَاڒْ أَكْ-ذ إِشوَّاڒنْ س يِيجّنْ ذِينَارْ إِ يِيجّنْ وَاسّْ، إِسّكّْ إِ-ثنْ غَارْ ؤُمَارْجعْ نّسْ ن ؤُضِيڒْ. \f ◼ \fr 20:‏2 \ft \bd ’ذِينَارْ‘\bd* - ذِي ڒْوقْثْ نِّي ثُوغَا ڒْمُونثْ إِ يِيجّْ ن وَاسّْ ذ إِجّْ ن ذِينَارْ.\f*
\v 3 ڒَامِي د-إِفّغْ نتَّا \add عَاوذْ\add* ذِي جّْوَايهْ ن ثْسَاعّثْ وِيسّْ ثْڒَاثَا، \add إِخْسْ أَذْ يِينِي غَارْ ثسْعَا ذِي صّْبحْ\add*، إِژْرَا إِنّغْنِي بدّنْ ذِي ڒْموْقفْ بْڒَا ڒْخذْمثْ.
\v 4 نتَّا إِنَّا أَسنْ: ’رُوحمْ ؤُڒَا ذ كنِّيوْ غَارْ ؤُمَارْجعْ \add إِنُو\add* ن ؤُضِيڒْ، أَذْ أَومْ وْشغْ مِينْ ذ أَومْ د-إِكَّارنْ!‘، ؤُشَا رُوحنْ.
\v 5 إِفّغْ-د عَاوذْ ذِي جّْوَايهْ ن ثْسَاعّثْ وِيسّْ ستَّا ذ وِيسّْ ثسْعَا، ؤُشَا إِڭَّا أَمنِّي عَاوذْ.
\v 6 ڒَامِي د-إِفّغْ ذِي جّْوَايهْ ن ثْسَاعّثْ وِيسّْ هِيطْعَاشْ، \add إِخْسْ أَذْ يِينِي غَارْ خمْسَا ن ثْمذِّيثْ\add*، يُوفَا ذِينْ \add عَاوذْ\add* إِنّغْنِي بدّنْ ذِينْ بْڒَا ڒْخذْمثْ، إِنَّا أَسنْ: ’مَايمِّي ثْبدّمْ ذَا أَسّْ إِكْمڒْ بْڒَا ڒْخذْمثْ؟‘
\v 7 نَّانْ أَسْ: ’مِينْزِي وَارْ ذ أَنغْ إِشْرِي حذْ.‘ إِنَّا أَسنْ: ’رُوحمْ ؤُڒَا ذ كنِّيوْ غَارْ ؤُمَارْجعْ \add إِنُو\add* ن ؤُضِيڒْ، أَذْ ثطّْفمْ مِينْ ذ أَومْ د-إِكَّارنْ.‘
\v 8 ڒَامِي د-ثِيوضْ ثْمذِّيثْ، إِنَّا بَابْ ن ؤُمَارْجعْ ن ؤُضِيڒْ إِ ؤُوقَّافْ نّسْ: ’ڒَاغَا-د خْ إِخمَّاسنْ، خدْجصْ أَسنْ ڒْمُونثْ، سِيزْوَارْ زڭْ \add إِنِّي د-يُوسِينْ ذ\add* إِنڭُّورَا ؤُشَا أَمُّو أَڒْ إِمزْوُورَا.‘
\v 9 ؤُشَا ؤُسِينْ-د إِنِّي \add ذ إِشْرَا\add* ذِي جّْوَايهْ ن ثْسَاعّثْ وِيسّْ حِيطَاشْ، ؤُشَا كُوڒْ إِجّنْ زَّايْسنْ إِطّفْ إِجّنْ ذِينَارْ.
\v 10 ڒَامِي د-ؤُسِينْ إِنِّي ثُوغَا ذ إِمزْوُورَا، إِتّْغِيڒْ أَسنْ أَذْ طّْفنْ كْثَارْ، \add مَاشَا\add* ؤُڒَا ذ نِيثْنِي طّْفنْ إِ كُوڒْ إِجّنْ زَّايْسنْ إِجّْ ن ذِينَارْ.
\v 11 ڒَامِي ث طّْفنْ، أَقَا خيّْقنْ خْ بَابْ ن ثَادَّارْثْ،
\v 12 نَّانْ: ’أَقَا إِنَا ذ إِنِّي ذ إِنڭُّورَا خذْمنْ إِشْثْ ن ثْسَاعّثْ ؤُ شكْ ثسّمْقُوذذْ إِ-ثنْ أَكِيذْنغْ، نشِّينْ إِنِّي يَاربُّونْ دّْقڒْ ن وَاسّْ ذ ڒحْمُو.‘
\v 13 مَاشَا نتَّا يَارَّا-د خْ إِجّنْ زَّايْسنْ، إِنَّا: ’\add أَ\add* أَمدُّوكّڒْ إِنُو، نشّْ وَارْ شكْ ضْڒِيمغْ، مَا وَارْ كِيذِي ثكِّيسذْ أَوَاڒْ خْ إِجّْ ن ذِينَارْ؟
\v 14 طّفْ مِينْ إِدْجَانْ نّشْ ؤُشَا ؤُيُورْ. نشّْ خْسغْ أَذْ وْشغْ إِ إِنَا ذ إِنِّي ذ إِنڭُّورَا أَنشْثْ مِينْ ذ أَشْ وْشِيغْ.
\v 15 نِيغْ مَا وَارْ غَارِي بُو ڒْحقّْ مَاحنْذْ أَذْ ڭّغْ مِينْ خْسغْ أَكْ-ذ مِينْ إِدْجَانْ إِنُو؟ نِيغْ ثِيطّْ نّشْ ذ ثَاعفَّانْثْ، مِينْزِي نشّْ ذ أَصبْحَانْ؟‘
\m 
\v 16 أَمُّو إِ غَا ذوْڒنْ إِنڭُّورَا ذ إِمزْوُورَا، ؤُشَا إِمزْوُورَا أَذْ ذوْڒنْ ذ إِنڭُّورَا، مِينْزِي أَطَّاسْ إِنِّي إِتّْوَاڒَاغَانْ، مَاشَا ذْرُوسْ إِنِّي إِتّْوَافَارْزنْ.“ \x ◘ \xo 20:‏16 \xt مت. 19‏:‏30؛ 22‏:‏14؛ مك. 10‏:‏31؛ لك. 13‏:‏30. \x*
\b
\s1 يَاسُوع إِسَّاوَاڒْ خْ ڒْموْثْ ذ ثْنُوكْرَا نّسْ إِ ثْوَاڒَا وِيسّْ ثْڒَاثَا
\m 
\v 17 ڒَامِي إِكَّارْ-د يَاسُوع مَاحنْذْ أَذْ إِڭعّذْ غَارْ ؤُرْشَالِيمْ، يِيوِي ثنْعَاشْ ن إِمحْضَارنْ نّسْ غَارْ ؤُغزْذِيسْ ذڭْ وبْرِيذْ، إِنَّا أَسنْ: \x ◘ \xo 20:‏17 \xt [مك. 10‏:‏32‏-‏34؛ لك. 18‏:‏31‏-‏34] — لك. 24‏:‏7. \x*
\v 18 ”خْزَارْ، أَذْ نْڭعّذْ غَارْ ؤُرْشَالِيمْ، ؤُشَا أَذْ إِمّوْشْ مِّيسْ ن بْنَاذمْ ذڭْ إِفَاسّنْ ن إِمقّْرَاننْ ن إِكهَّاننْ ذ إِمْسڒْمَاذنْ ن إِذْلِيسنْ، ؤُ نِيثْنِي أَذْ خَاسْ حكْمنْ س ڒْموْثْ.
\v 19 أَذْ ث سلّْمنْ إِ ڒڭْنُوسْ مَاحنْذْ أَذْ زَّايسْ سْثهْزَانْ، أَذْ ث هتّْكنْ س ؤُركُّوضْ ؤُشَا أَذْ ث صلّْبنْ، \add مَاشَا\add* ذڭْ وَاسّْ وِيسّْ ثْڒَاثَا أَذْ د-إِكَّارْ.“ \x ◘ \xo 20:‏19 \xt مت. 27‏:‏2؛ لك. 23‏:‏1؛ يُوح. 18‏:‏28، 31؛ ڒخ. 3‏:‏23. \x*
\b
\s1 ثُوثْرَا ن يمَّاسْ ن يَاعْقُوبْ ذ يُوحَانَّا
\m 
\v 20 ڒخْذنِّي ثُوسَا-د غَارسْ يمَّاسْ ن ثَارْوَا ن زَابْذِي أَكْ-ذ إِحنْجِيرنْ نّسْ، ثسْجذْ أَسْ، حِيمَا أَذْ زَّايسْ ثتَّارْ شَا ن ڒْحَاجّثْ. \x ◘ \xo 20:‏20 \xt [مك. 10‏:‏35‏-‏45] \x*
\v 21 إِنَّا أَسْ نتَّا: ”مِينْ ثخْسذْ؟“ ثنَّا أَسْ نتَّاثْ: ”إِنِي مَاحنْذْ أَذْ قِّيمنْ ثْنَاينْ ن إِحنْجِيرنْ-أَ إِنُو، إِجّنْ غَارْ ؤُفُوسِي نّشْ ؤُ ونّغْنِي غَارْ ؤُزڒْمَاضْ نّشْ، ذِي ثْڭلْذِيثْ نّشْ.“
\v 22 يَاسُوع يَارَّا-د خَاسنْ، إِنَّا: ”كنِّيوْ وَارْ ثسِّينمْ شَا مِينْ ثتَّارمْ. مَا ثْزمَّارمْ أَذْ ثسْومْ ڒْكَاسْ إِ غَا سْوغْ نشّْ، نِيغْ أَذْ ثتّْوَاسّْغضْصمْ س ؤُسغْضصْ إِ زِي غَا تّْوَاسّْغضْصغْ نشّْ؟“ نَّانْ أَسْ: ”نْزمَّارْ!“ \x ◘ \xo 20:‏22 \xt مك. 10‏:‏38، 39؛ لك. 12‏:‏50؛ رُوم. 8‏:‏26. \x*
\v 23 نتَّا إِنَّا أَسنْ: ”ڒْْكَاسْ إِنُو أَذْ ث ثسْومْ ؤُ أَسغْضصْ إِ زِي غَا تّْوَاسّْغضْصغْ، أَذْ زَّايسْ ثتّْوَاسّْغضْصمْ، مَاشَا أَغِيمِي غَارْ ؤُفُوسِي إِنُو ذ ؤُزڒْمَاضْ إِنُو وَارْ إِدْجِي إِ نشّْ، مَاحنْذْ أَذْ ث وْشغْ، مَاشَا \add أَذْ يِيڒِي\add* إِ يِينِّي ؤُمِي ث إِسّوْجذْ بَابَا.“ \x ◘ \xo 20:‏23 \xt مت. 25‏:‏34. \x*
\m 
\v 24 ڒَامِي سْڒِينْعشْرَا \add ن إِمحْضَارنْ\add* نّغْنِي مَانْ أَيَا، خيّْقنْ أَطَّاسْ خْ ثْنَاينْ ن وَاوْمَاثنْ.
\v 25 مَاشَا يَاسُوع إِڒَاغَا-د خَاسنْ غَارسْ، إِنَّا: ”كنِّيوْ أَقَا ثسّْنمْ بلِّي ڒْحُوكَّامْ ن ڒڭْنُوسْ حكّْمنْ خَاسنْ ؤُشَا ؤُڒَا ذ إِمقّْرَاننْ نْسنْ تّْصلَّاطنْ خَاسنْ. \x ◘ \xo 20:‏25 \xt مك. 10‏:‏42؛ لك. 22‏:‏25. \x*
\v 26 وَارْ إِتِّيڒِي أَمُّو جَارْ أَومْ، مَاشَا س ڒْمقْڒُوبْ: ونِّي إِخْسنْ أَذْ يِيڒِي ذ أَمقّْرَانْ جَارْ أَومْ، أَذْ يِيڒِي ذ أَمْسخَّارْ نْومْ، \x ◘ \xo 20:‏26 \xt 1 بُط. 5‏:‏3. \x*
\v 27 ؤُ ونِّي إِخْسنْ أَذْ يِيڒِي ذ أَمزْوَارُو جَارْ أَومْ، أَذْ يِيڒِي ذ أَمْسخَّارْ نْومْ، \x ◘ \xo 20:‏27 \xt مت. 23‏:‏11؛ مك. 9‏:‏35؛ 10‏:‏43. \x*
\v 28 أَمْ مَامّشْ مِّيسْ ن بْنَاذمْ وَارْ د-يُوسِي حِيمَا أَذْ خَاسْ سخَّارنْ، مَاشَا حِيمَا أَذْ خَاسنْ إِسخَّارْ ؤُشَا أَذْ إِوْشْ ثُوذَارْثْ نّسْ ذ أَصْڒَاحْ إِ وَاطَّاسْ \add ن يوْذَانْ\add*.“ \x ◘ \xo 20:‏28 \xt لك. 22‏:‏27؛ يُوح. 13‏:‏14؛ أَفا. 1‏:‏7؛ فِيل. 2‏:‏7؛ 1 تِيم. 2‏:‏6؛ 1 بُط. 1‏:‏19\x*
\b
\s1 يَاسُوع إِسّْڭنْفَا ثْنَاينْ ن إِذَارْغَاڒنْ
\m 
\v 29 ڒَامِي د-إِفّغْ يَاسُوع زِي أَرِيحَا، إِضْفَارْ إِ-ث-إِ-د أَطَّاسْ ن ڒْغَاشِي. \x ◘ \xo 20:‏29 \xt [مك. 10‏:‏46‏-‏52؛ لك. 18‏:‏35‏-‏43] \x*
\v 30 خْزَارْ، أَقَا ذِينْ ثْنَاينْ ن إِذَارْغَاڒنْ قِّيمنْ خْ طَّارْفْ ن وبْرِيذْ، ڒَامِي سْڒِينْ بلِّي يَاسُوع أَذْ إِعْذُو، ڒَاغَانْ، نَّانْ: ”أَ سِيذِي، مِّيسْ ن ذَاوُوذْ، أَرْحمْ أَنغْ!“
\v 31 مَاشَا ڒْغَاشِي إِزِييَّارْ خَاسنْ، حِيمَا أَذْ سْقَارنْ. مَاشَا نِيثْنِي سْغُوينْ س جّهْذْ كْثَارْ، نَّانْ: ”أَرْحمْ أَنغْ، \add أَ\add* سِيذِيثْنغْ، مِّيسْ ن ذَاوُوذْ!“
\v 32 خنِّي إِبدّْ يَاسُوع، إِڒَاغَا-د خَاسنْ، إِنَّا: ”مِينْ ثخْسمْ أَذْ أَومْ ڭّغْ؟“
\v 33 نَّانْ أَسْ نِيثْنِي: ”\add أَ\add* سِيذِيثْنغْ، مَاڒَا ثخْسذْ أَذْ تّْوَارزْمنْثْ ثِيطَّاوِينْ نّغْ.“
\v 34 يَاسُوع إِحِينّْ خَاسنْ، خنِّي إِحَاذَا ثِيطَّاوِينْ نْسنْ. ڒخْذنِّي ذوْڒنْثْ ثِيطَّاوِينْ نْسنْ تّْوَاڒَانْثْ، ؤُشَا نِيثْنِي ضْفَارنْ ث-إِ-د.
\b
\b
\c 21
\s1 أَذَافْ ن يَاسُوع غَارْ ؤُرْشَالِيمْ أَمْ ؤُجدْجِيذْ
\m 
\v 1 ڒَامِي د-قَارّْبنْ غَارْ ؤُرْشَالِيمْ، إِوْضنْ غَارْ بَايْثْ-فَاجِي، غَارْ ؤُغزْذِيسْ ن وذْرَارْ ن زِّيثُونْ، إِسّكّْ يَاسُوع ثْنَاينْ ن إِمحْضَارنْ نّسْ، إِنَّا أَسنْ: \x ◘ \xo 21:‏1 \xt [مك. 11‏:‏1‏-‏11؛ لك. 19‏:‏28‏-‏38] — يُوح. 12‏:‏12‏-‏19\x*
\v 2 ”رُوحمْ غَارْ ذْشَارْ نِّي قِيبَاتْشْ نْومْ. ذغْيَا أَذْ ثَافمْ إِشْثْ ن ثغْيُوتْشْ ثقّنْ ذ إِجّْ ن وسْنُوسْ أَكِيذسْ. فسْيمْ أَسنْ، ثَاوْيمْ ثنْ-د غَارِي.
\v 3 مَاڒَا إِنَّا أَومْ حذْ شَا، أَرّمْ خَاسْ أَمُّو: ’أَقَا سِيذِيثْنغْ إِحْذَاجْ إِ-ثنْ. نتَّا أَذْ ثنْ د-يَارّْ ذغْيَا.‘ “
\v 4 مَانْ أَيَا قَاعْ إِمْسَارْ، حِيمَا أَذْ إِتّْوَاكمّڒْ مَارَّا مِينْ إِتّْوَانَّانْ زڭْ ؤُنَابِي أَمْ إِنَّا:
\b
\m 
\v 5 \qt ”إِنِيمْ إِ يدْجِيسْ ن صِيهْيُونْ:\qt*
\m \qt ’خْزَارْ، أَجدْجِيذْ نّمْ أَذْ غَارمْ د-يَاسْ س ؤُوَاضعْ،\qt*
\m \qt ينْيَا خْ وغْيُوڒْ ذ وسْنُوسْ،\qt*
\m \qt أَقَا ذ مِّيسْ ن ثغْيُوتْشْ.“\qt* \x ◘ \xo 21:‏5 \xt 1 إِج. 1‏:‏38‏-‏40؛ إِشا. 62‏:‏11؛ زَاك. 9‏:‏9؛ يُوح. 12‏:‏15. \x*
\b
\m 
\v 6 رُوحنْ إِمحْضَارنْ ؤُشَا ڭِّينْ أَمْ مَامّشْ ثنْ يُومُورْ يَاسُوع.
\v 7 إِوْينْ-د أَغْيُوڒْ ذ وسْنُوسْ، سَارْسنْ أَرُّوضْ نْسنْ خْ وسْنُوسْ ؤُشَا إِنْيَا خَاسْ يَاسُوع. \x ◘ \xo 21:‏7 \xt 2 إِج. 9‏:‏13؛ يُوح. 12‏:‏14. \x*
\v 8 أَطَّاسْ زِي ڒْغَاشِي سُّونْ أَرُّوضْ نْسنْ ذڭْ وبْرِيذْ ؤُ إِنّغْنِي قسّنْ ڒفْرُوعْ زِي ثْشجُّورَا، نْضَارنْ ثنْ ذڭْ وبْرِيذْ.
\v 9 ؤُشَا أَبَارُّو ن ڒْغَاشِي نِّي ذ أَسْ إِزْوَارنْ ذ يِينِّي إِ-ث-إِ-د إِضْفَارنْ، ثُوغَا سْغُويُّونْ، نَّانْ:
\b
\m \qt ”ؤُصَانَّا إِ مِّيسْ ن ذَاوُوذْ!\qt*
\m \qt لْبَارَاكَا إِ ونِّي د-يُوسِينْ س يِيسمْ ن سِيذِي.\qt*
\m \qt ؤُصَانَّا، ذِي ڒُوعْڒَا خْ ڒُوعْڒَا \tl ن إِجنْوَانْ\tl*.“\qt* \x ◘ \xo 21:‏9 \xt إِزهد. 118‏:‏25، 26؛ مك. 11‏:‏9، 10؛ يُوح. 12‏:‏13\x*
\b
\m 
\v 10 ڒَامِي يُوذفْ غَارْ ؤُرْشَالِيمْ، ثْهَاجْ ثنْذِينْثْ قَاعْ، \add إِوْذَانْ\add* نَّانْ: ”مِينْ إِعْنَا وَا؟“
\v 11 ڒْغَاشِي إِنَّا: ”ذ وَا ذ أَنَابِي يَاسُوع زِي نَّاصِيرَا ذِي لْجَالِيلْ.“
\b
\s1 يَاسُوع ذِي زَّاوشْثْ ثَامقّْرَانْثْ
\m 
\v 12 يُوذفْ يَاسُوع غَارْ زَّاوشْثْ ثَامقّْرَانْثْ ن أَربِّي، إِسُّوفّغْ مَارَّا إِنِّي إِزّْنُوزَانْ ذ يِينِّي إِسَّاغنْ ذِي زَّاوشْثْ ثَامقّْرَانْثْ ؤُشَا إِقْڒبْ طّْوَابڒْ ن إِصَارَّافنْ \add ن ثنْعَاشِينْ\add* ذ ڒكْرَاسِي ن يِينِّي إِزّْنُوزَانْ إِذْبِيرنْ. \x ◘ \xo 21:‏12 \xt [مك. 11‏:‏15‏-‏19؛ لك. 19‏:‏45‏-‏48؛ يُوح. 2‏:‏13‏-‏22] — أَعَوذ. 14‏:‏26\x*
\v 13 إِنَّا أَسنْ: ”أَقَا ثُورَا: ’ثَادَّارْثْ إِنُو أَذْ ثتّْوَاسمَّا ’ثَادَّارْثْ ن ثْژَادْجِيثْ‘، مَاشَا كنِّيوْ ثَارِّيمْ ت ذ إِفْرِي ن إِشفَّارنْ.‘ “ \x ◘ \xo 21:‏13 \xt 1 إِج. 8‏:‏29؛ إِشا. 56‏:‏7؛ إِرْم. 7‏:‏11؛ لك. 19‏:‏46. \x*
\v 14 إِوْينْ-د غَارسْ ذِي زَّاوشْثْ ثَامقّْرَانْثْ إِذَارْغَاڒنْ ذ إِنعْضَابنْ ؤُشَا إِسّْڭنْفَا ثنْ.
\v 15 ؤُمِي ژْرِينْ إِمقّْرَاننْ ن إِكهَّاننْ ذ إِمْسڒْمَاذنْ ن إِذْلِيسنْ لْمُوعْجِيزَاثْ إِ يڭَّا ؤُ أَقَا إِحنْجِيرنْ تّْڒَاغَانْ ذِي زَّاوشْثْ ثَامقّْرَانْثْ، قَّارنْ: ”ؤُصَانَّا إِ مِّيسْ ن ذَاوُوذْ!“، خيّْقنْ أَطَّاسْ،
\v 16 نَّانْ أَسْ: ”مَا ثسْڒِيذْ مِينْ قَّارنْ يِينَا؟“ إِنَّا أَسنْ يَاسُوع: ”وَاهْ، مَا وَارْ ثغْرِيمْعمَّارْصْ: ’زڭْ إِقمُّومنْ ن إِحنْجِيرنْ ذ إِسيْمَانْ ثسّْوجْذذْ شكْ تّسْبِيحْ‘؟“ \x ◘ \xo 21:‏16 \xt إِزهد. 8‏:‏3. \x*
\v 17 ڒخْذنِّي إِسْمحْ ذَايْسنْ، إِفّغْ بَارَّا إِ ثنْذِينْثْ غَارْ بَايْثْ-عَانْيَا، إِنْسَا ذِينْ.
\b
\s1 أَرْثُو يُوژْغنْ
\m 
\v 18 غَارْ صّْبحْ زِيشْ ڒَامِي د-إِذْوڒْ غَارْ ثنْذِينْثْ، ثُوغَا ذَايسْ ڒَاژْ. \x ◘ \xo 21:‏18 \xt [مك. 11‏:‏12‏-‏14؛ 20‏-‏24] \x*
\v 19 إِژْرَا إِجّْ ن وَارْثُو خْ وبْرِيذْ، إِرُوحْ غَارسْ، وَارْ ذَايسْ يُوفِي مْغِيرْ ثِيفْرَايْ وَاهَا. \add خنِّي\add* إِنَّا \add إِ وَارْثُو\add*: ”وَارْ زَّايكْ تّفّغْ ڒْغِيدْجثْعمَّارْصْ.“ ڒخْذنِّي يُوژغْ وَارْثُو ذغْيَا. \x ◘ \xo 21:‏19 \xt حُوش. 9‏:‏10\x*
\v 20 ؤُمِي ژْرِينْ إِمحْضَارنْ مَانْ أَيَا، ثْبهْثنْ، نَّانْ: ”مَامّشْ إِڭَّا وَارْثُو يُوژغْ ذغْيَا؟“
\v 21 يَاسُوع يَارَّا-د، إِنَّا أَسنْ: ”س ثِيذتّْ نشّْ أَذْ أَومْ إِنِيغْ: مَاڒَا ذَايْومْ لْ-إِيمَانْ ؤُ وَارْ ثْشكِّيمْ شَا، أَقَا وَارْ ثتّڭّمْ مِينْ إِمْسَارنْ إِ وَارْثُو وَاهَا، مَاشَا عَاوذْ مَاڒَا ثنَّامْ إِ وذْرَارْ-أَ: ’مكْسِي، وْضَا ذِي ڒبْحَارْ!‘، أَذْ يِيڒِي. \x ◘ \xo 21:‏21 \xt مت. 17‏:‏20؛ لك. 17‏:‏6. \x*
\v 22 ذ قَاعْ مِينْ غَا ثتَّارمْ ذِي ثْژَادْجِيثْ س لْ-إِيمَانْ، أَذْ \add ث\add* ثطّْفمْ.“ \x ◘ \xo 21:‏22 \xt مت. 7‏:‏7؛ مك. 11‏:‏24؛ لك. 11‏:‏9؛ يُوح. 14‏:‏13؛ 16‏:‏24؛ يَاع. 1‏:‏5؛ 1 يُوح. 3‏:‏22. \x*
\b
\s1 أَسقْسِي خْ تّسْرِيحْ ن يَاسُوع
\m 
\v 23 ڒَامِي يُوذفْ غَارْ زَّاوشْثْ ثَامقّْرَانْثْ، ؤُسِينْ-د غَارسْ إِمقّْرَاننْ ن إِكهَّاننْ ذ إِمْغَارنْ ن ڒْڭنْسْ أَمْ ثُوغَا إِسّڒْمَاذْ، نَّانْ: ”س مَانْ صُّولْطَا إِ ثڭِّيذْ ثِيمسْڒَايِينْ-أَ؟ وِي ذ أَشْ إِوْشِينْ صُّولْطَا-يَا؟“ \x ◘ \xo 21:‏23 \xt [مك. 11‏:‏27‏-‏33؛ لك. 20‏:‏1‏-‏8] — ؤُف. 2‏:‏14؛ ڒخ. 4‏:‏7؛ 7‏:‏2. \x*
\v 24 يَاسُوع يَارَّا-د، إِنَّا أَسنْ ”ؤُڒَا ذ نشّْ أَذْ كنِّيوْ سّقْسِيغْ إِجّْ ن ؤُسقْسِي ؤُ مَاڒَا ثَارِّيمْ-د خَافِي ؤُڒَا ذ نشّْ أَذْ أَومْ إِنِيغْ س مَانْ صُّولْطَا إِ تّڭّغْ ثِيمسْڒَايِينْ-أَ.
\v 25 أَسغْضَاصْ ن يُوحَانَّا، مَانِيسْ نتَّا؟ زڭْ ؤُجنَّا نِيغْ زڭْ إِوْذَانْ؟“ مْشَاوَارنْ نِيثْنِي جَارْ أَسنْ، نَّانْ: ”مَاڒَا ننَّا: ’زڭْ ؤُجنَّا!‘، أَذْ أَنغْ إِنِي: ’مَايمِّي وَارْ زَّايسْ ثُومِينمْ؟‘،
\v 26 ؤُ مَاڒَا ننَّا: ’زڭْ إِوْذَانْ!‘، خنِّي ذَايْنغْ ثِيڭّْوُوذِي زِي ڒْغَاشِي، مِينْزِي مَارَّا حسّْبنْ يُوحَانَّا ذ أَنَابِي.“ \x ◘ \xo 21:‏26 \xt مت. 14‏:‏5؛ مك. 6‏:‏20. \x*
\v 27 أَرِّينْ-د، نَّانْ: ”وَارْ نسِّينْ.“ إِنَّا أَسنْ نتَّا: ”خنِّي ؤُڒَا ذ نشّْ وَارْ ذ أَومْ قَّارغْ س مَانْ صُّولْطَا إِ تّڭّغْ مَانْ أَيَا.“
\b
\s1 أَمذْيَا ن ثْنَاينْ ن وَاوْمَاثنْ
\m 
\v 28 ”مِينْ ذ أَومْ إِتّْغِيڒْ كنِّيوْ؟ إِجّْ ن ورْيَازْ ثُوغَا غَارسْ ثْنَاينْ ن إِحنْجِيرنْ. إِڒَاغَا خْ ؤُمزْوَارُو، إِنَّا: ’\add أَ\add* مِّي، ؤُيُورْ، أَسّْ-أَ أَذْ ثْخذْمذْ ذڭْ ؤُمَارْجعْ ن ؤُضِيڒْ!‘
\v 29 نتَّا يَارَّا-د، إِنَّا: ’نشّْ وَارْ خْسغْ شَا!‘، مَاشَا أَوَارْنِي مَانْ أَيَا إِنْذمْ ؤُشَا إِرُوحْ ذِينْ.
\v 30 ؤُشَا يُوسَا-د نتَّا غَارْ ونِّي وِيسّْ ثْنَاينْ، إِنَّا أَسْ أَمنِّي بعْذَا. وَانِيثَا يَارَّا-د خَاسْ: ’وَاهْ، أَ سِيذِي!‘، \add مَاشَا\add* وَارْ إِرُوحْ شَا!
\v 31 مَانْ ونْ زَّايْسنْ إِ إِڭِّينْ ڒْخَاضَارْ إِ بَابَاسْ؟“ نِيثْنِي أَرِّينْ-د خَاسْ: ”ونِّي ذ أَمزْوَارُو.“ يَاسُوع إِنَّا أَسنْ: ”س ثِيذتّْ، نشّْ أَذْ أَومْ إِنِيغْ، أَقَا أَيْثْ ن ضَّارِيبَا ذ ثمْغَارِينْ ن فَارْقْ-شّْغڒْ أَذْ أَومْ إِزْوَارنْ غَارْ ثْڭلْذِيثْ ن أَربِّي.
\v 32 مِينْزِي يُوحَانَّا يُوسَا-د غَارْومْ ذڭْ وبْرِيذْ ن ثْسڭْذَا، كنِّيوْ وَارْ زَّايسْ ثُومِينمْ، مَاشَا أَيْثْ ن ضَّارِيبَا ذ ثمْغَارِينْ ن فَارْقْ-شّْغڒْ أَقَا نِيثْنِي ؤُمْننْ زَّايسْ. ڒَامِي ثژْرِيمْ مَانْ أَيَا، وَارْ ثثُوبمْ شَا غَارْ ؤُنڭَّارُو، مَاحنْذْ أَذْ زَّايسْ ثَامْنمْ.“ \x ◘ \xo 21:‏32 \xt مت. 3‏:‏1. \x*
\b
\s1 أَمذْيَا ن إِخمَّاسنْ ذڭْ ؤُمَارْجُوعْ ن ثْزَايَارْثْ
\m 
\v 33 ”سْڒمْ \add عَاوذْ\add* إِ يِيجّْ ن ؤُمذْيَا نّغْنِي. ثُوغَا ذِينْ إِجّْ ن ورْيَازْ، بَابْ ن ثَادَّارْثْ، إِڭَّا إِجّْ ن ؤُمَارْجعْ ن ؤُضِيڒْ،  إِژُّو ذَايسْ ثِيزَايَارِينْ. نتَّا إِقُووَّارْ أَسْ-د س يِيجّْ ن وفْرَايْ، إِغْزَا ذَايسْ ثَاسِيرْثْ ن ؤُضِيڒْ ؤُشَا إِبْنَا ذَايسْ إِشْثْ ن صُّومْعثْ. خنِّي يَارْهنْ \add أَمَارْجعْ نِّي ن ؤُضِيڒْ\add* إِ شَا ن إِخمَّاسنْ ؤُشَا إِسَافَارْ. \x ◘ \xo 21:‏33 \xt [مك. 12‏:‏1‏-‏12؛ لك. 20‏:‏9‏-‏19] — إِزهد. 80‏:‏9؛ إِشا. 5‏:‏1‏-‏7؛ إِرْم. 2‏:‏21؛ 12‏:‏10؛ \x*
\v 34 ؤُمِي د-ثِيوضْ ڒْوقْثْ \add ن صَّابثْ\add* ن ڒْغِيدْجثْ، إِسّكّْ إِمْسخَّارنْ نّسْ غَارْ إِخمَّاسنْ \add نِّي\add* حِيمَا أَذْ د-أَوْينْ ڒْغِيدْجثْ نّسْ.
\v 35 إِخمَّاسنْ طّْفنْ إِمْسخَّارنْ نّسْ، وْثِينْ إِجّنْ، نْغِينْ نّغْنِي ؤُشَا أَرجْمنْ \add عَاوذْ\add* إِجّنْ نّغْنِي. \x ◘ \xo 21:‏35 \xt 2 إِم. 24‏:‏21. \x*
\v 36 عَاوذْ إِسّكّْ إِمْسخَّارنْ نّغْنِي، كْثَارْ زڭْ ؤُمزْوَارُو، ؤُشَا ڭِّينْ ذَايْسنْ عَاوذْ أَمنِّي.
\v 37 غَارْ ؤُنڭَّارْ إِسّكّْ أَسنْ-د مِّيسْ، إِنَّا: ’نِيشَانْ أَذْ وقَّارنْ مِّي‘.
\v 38 مَاشَا ڒَامِي ژْرِينْ إِخمَّاسنْ مِّيسْ، نَّانْ جَارْ أَسنْ: ’أَقَا ذ أَوْرِيثْ، زِيذمْ، أَذْ ث ننغْ، أَذْ أَسْ نكّسْ ڒْوَارْثْ إِ نشِّينْ.‘ \x ◘ \xo 21:‏38 \xt أَمز. 37‏:‏17؛ إِزهد. 2‏:‏1، 8؛ مت. 26‏:‏3؛ 27‏:‏1؛ يُوح. 11‏:‏53؛ عبر. 1‏:‏2. \x*
\v 39 طّْفنْ ث، نْضَارنْ ث بَارَّا إِ ؤُمَارْجعْ ن ؤُضِيڒْ ؤُشَا نْغِينْ ث.
\v 40 مَاڒَا يُوسَا-د بَابْ ن ؤُمَارْجعْ نِّي، مِينْ غَا يڭّْ ذڭْ إِخمَّاسنْ نِّي؟“
\v 41 نَّانْ أَسْ: ”أَذْ يَاردّدْجْ إِعفَّاننْ نِّي قَاعْ، ؤُشَا أَذْ إِوْشْ أَمَارْجعْ ن ؤُضِيڒْ إِ إِخمَّاسنْ نّغْنِي إِنِّي ذ أَسْ إِ غَا إِوْشنْ ڒْغِيدْجثْ ذِي ڒْوقْثْ نّسْ.“
\v 42 يَاسُوع إِنَّا أَسنْ: ”مَا وَارْ ثغْرِيمْعمَّارْصْ ذڭْ إِذْلِيسنْ:
\b
\m \qt ’أَژْرُو إِ إِعِيفّنْ إِبنَّاينْ،\qt*
\m \qt أَقَا إِذْوڒْ ذ \tl أَژْرُو\tl* أَزدْجِيفْ ن ثغْمَارْثْ.\qt*
\m \qt وَا يُوسَا-د زِي سِيذِي\qt*
\m \qt ؤُ مَانْ أَيَا ذ ڒعْجبْ ذِي ثِيطَّاوِينْ نّغْ.‘\qt* \x ◘ \xo 21:‏42 \xt إِزهد. 118‏:‏22‏-‏23؛ إِشا. 8‏:‏14؛ 28‏:‏16؛ مك. 12‏:‏10؛ لك. 20‏:‏17؛ ڒخ. 4‏:‏11؛ رُوم. 9‏:‏33؛ 1 بُط. 2‏:‏6. \x*
\b
\m 
\v 43 س ؤُينِّي أَذْ أَومْ إِنِيغْ، بلِّي ثَاڭلْذِيثْ ن أَربِّي أَذْ أَومْ ثتّْوَاكّسْ ؤُشَا أَذْ ثمّوْشْ إِ يِيجّْ ن ڒْڭنْسْ إِ غَا إِوْشنْ ڒْغِيدْجثْ نّسْ. \x ◘ \xo 21:‏43 \xt ؤُف. 32‏:‏10؛ إِشا. 55‏:‏5؛ مت. 8‏:‏12. \x*
\v 44 وِي غَا إِوْضَانْ خْ وژْرُو-يَا، أَذْ إِتّْوَاڒْبزْ، ؤُ وِي خفْ إِ غَا إِوْضَا، أَذْ ث إِڒْبزْ.“ \x ◘ \xo 21:‏44 \xt إِشا. 8‏:‏15؛ دَان. 2‏:‏34؛ زَاك. 12‏:‏3؛ لك. 20‏:‏18. \x*
\m 
\v 45 ڒَامِي سْڒِينْ إِمقّْرَاننْ ن إِكهَّاننْ ذ إِفَارِيسِييّنْ إِمذْيَا نّسْ، فهْمنْ بلِّي إِسَّاوَاڒْ خَاسنْ. \x ◘ \xo 21:‏45 \xt لك. 20‏:‏19. \x*
\v 46 أَرزُّونْ أَذْ ث طّْفنْ، \add مَاشَا\add* ڭّْوذنْ زِي ڒْغَاشِي، مِينْزِي \add ڒْغَاشِي\add* ثُوغَا إِحسّبْ إِ-ث ذ إِجّْ ن ؤُنَابِي. \x ◘ \xo 21:‏46 \xt لك. 7‏:‏16؛ يُوح. 7‏:‏40. \x*
\b
\b
\c 22
\s1 أَمذْيَا خْ إِنِّي إِتّْوَاعَارْضنْ غَارْ وُورَارْ
\m 
\v 1 إِطّفْ يَاسُوع عَاوذْ ذڭْ وَاوَاڒْ ؤُشَا إِسِّيوڒْ أَكِيذْسنْ عَاوذْ س إِمذْيَا، إِنَّا: \x ◘ \xo 22:‏1 \xt [لك. 14‏:‏15‏-‏24] \x*
\v 2 ”ثَاڭلْذِيثْ ن إِجنْوَانْ أَمْ يِيجّْ ن ورْيَازْ، إِجّْ ن ؤُجدْجِيذْ، إِڭَّا ؤُرَارْ إِ مِّيسْ. \x ◘ \xo 22:‏2 \xt لك. 14‏:‏6؛ أَسَا. 19‏:‏7. \x*
\v 3 إِسّكّْ-د إِمْسخَّارنْ نّسْ حِيمَا أَذْ ڒَاغَانْ خْ يِينِّي إِتّْوَاعَارْضنْ غَارْ وُورَارْ، \add مَاشَا\add* ؤُڭِينْ أَذْ د-أَسنْ.
\m 
\v 4 عَاوذْ إِسّكّْ-د إِمْسخَّارنْ نّغْنِي، إِنَّا: ’إِنِيمْ إِ يِينِّي إِتّْوَاعَارْضنْ: أَقَا سّْوجْذغْ أَومْ أَمشْڒِي، غَارْصغْ إِ إِينْذُوزنْ إِنُو ذ ڒْمَاڒْ إِنُو إِصحّنْ، أَقَا مَارَّا إِوْجذْ، أَسمْ-د غَارْ وُورَارْ!‘ “
\v 5 نِيثْنِي مَاشَا وَارْ وْشِينْ شَا ثَايْنِيثْ إِ مَانْ أَيَا، رُوحنْ، إِجّنْ غَارْ ڒعْرَاصِي نّسْ ؤُ ونّغْنِي غَارْ تِّيجَارَا نّسْ.
\v 6 إِنِّي إِقِّيمنْ طّْفنْ إِمْسخَّارنْ نّسْ،غزَّانْ ذَايْسنْ ؤُشَا نْغِينْ \add ثنْ\add*.
\m 
\v 7 \add ڒَْامِي\add* إِسْڒَا ؤُجدْجِيذْ مَانْ أَيَا، إِخيّقْ أَطَّاسْ، إِسّكّْ-د ڒْعسْكَارْ نّسْ ؤُشَا يَاريّبْ إِقتَّاڒنْ نِّي ؤُشَا إِسّشْمضْ ثَانْذِينْثْ نْسنْ.
\v 8 خنِّي إِنَّا إِ إِمْسخَّارنْ نّسْ: ’أَقَا ؤُرَارْ إِوْجذْ مَاشَا إِنِّي ثُوغَا إِتّْوَاعَارْضنْ وَارْ ث سْذِيهِيدْجنْ شَا.
\v 9 س ؤُيَا ؤُيُورمْ غَارْ مَانِي تّمْسبْضَانْ إِبْرِيذنْ، ڒَاغَامْ-د خْ مَارَّا إِنِّي إِ غَا ثَافمْ ذِينْ غَارْ وُورَارْ.‘
\m 
\v 10 \add خنِّي\add* فّْغنْ-د إِمْسخَّارنْ نِّي غَارْ إِبْرِيذنْ ؤُشَا سّْمُوننْ مَارَّا إِنِّي ؤُفِينْ، أَمْ يِيصبْحَاننْ أَمْ يِيعفَّاننْ، ؤُشَا ثَادَّارْثْ ن وُورَارْ ثذْوڒْ ثشُّورْ س \add إِنوْجِيونْ\add* إِ إِقِّيمنْ ذِينِّي.
\v 11 ڒَامِي د-يُوذفْ ؤُجدْجِيذْ، مَاحنْذْ أَذْ إِژَارْ \add إِنوْجِيونْ\add* نِّي إِقِّيمنْ ذِينِّي، إِحكَّارْ إِ يِيجّْ ن بْنَاذمْ وَارْ يَارْضْ شَا أَرُّوضْ ن وُورَارْ.
\v 12 إِنَّا أَسْ: ’\add أَ\add* أَمدُّوكّڒْ إِنُو، مَامّشْ د-ثُوذْفذْ ذَانِيثَا بْڒَا أَرُّوضْ ن وُورَارْ؟‘ مَاشَا نتَّا إِذْوڒْ إِڭْنُو.
\v 13 خنِّي إِنَّا ؤُجدْجِيذْ إِ إِمْسخَّارنْ: ’شَارْفمْ ث س إِفَاسّنْ ذ إِضَارنْ ؤُشَا نْضَارمْ ث بَارَّا غَارْ ؤُنڭَّارْ ن ثَادْجسْثْ مَانِي غَا إِڒِينْ إِمطَّاونْ ذ ؤُغزِّي ن ثغْمَاسْ.‘ \x ◘ \xo 22:‏13 \xt مت. 8‏:‏12؛ 13‏:‏42؛ 24‏:‏51؛ 25‏:‏30؛ لك. 13‏:‏28. \x*
\v 14 مِينْزِي أَقَا ذِينْ أَطَّاسْ إِنِّي إِتّْوَاڒَاغَانْ مَاشَا ذْرُوسْ إِنِّي إِتّْوَافَارْزنْ.“ \x ◘ \xo 22:‏14 \xt مت. 20‏:‏16. \x*
\b
\s1 أَسقْسِي خْ ضَّارِيبَا إِ قَايْصَارْ
\m 
\v 15 خنِّي رُوحنْ إِفَارِيسِييّنْ، مْشَاوَارنْ مَامّشْ أَذْ أَسْ ڭّنْ إِجّْ ن ڒْفخْ ذِي سِّيبّثْ ن وَاوَاڒْ\add أنْ\add* نّسْ. \x ◘ \xo 22:‏15 \xt [مك. 12‏:‏13‏-‏17؛ لك. 20‏:‏20‏-‏26] \x*
\v 16 سّكّنْ غَارسْ إِمحْضَارنْ نْسنْ أَكْ-ذ إِنِّي زِي ثَادَّارْثْ ن هِيرُوذُوسْ، نَّانْ: ”\add أَ\add* أَمْسغَّارْ، أَقَا نسّنْ بلِّي شكْ ذ ثِيذتّْ، ثسّڒْمَاذذْ أَبْرِيذْ ن أَربِّي س ثِيذتّْ، نْهْڒَا مَا ثسّڒْقِيذْ ؤُڒَا خْ يِيجّْ، مِينْزِي شكْ وَارْ ثتّڭّذْ س وُوذْمَاونْ.
\b
\m 
\v 17 إِوَا إِنِي أَنغْ مَامّشْ إِ ثْوَاڒِيذْ شكْ: مَا إِحقّْ \add عْلَاحْسَابْ شَّارِيعَا\add* أَذْ ثتّْوَاخدْجصْ ضَّارِيبَا إِ قَايْصَارْ نِيغْ لَّا؟“
\v 18 مَاشَا يَاسُوع إِسّنْ ثَاحْرَايْمشْثْ نْسنْ ؤُشَا إِنَّا: ”مَايمِّي ذ أَيِي ثتّْجَارَّابمْ، \add كنِّيوْ، أَ\add* إِمْنَافْقنْ؟
\v 19 سشّْنمْ أَيِي \add إِجّْ ن ؤُقِييَّا ن\add* ذِينَارْ ن ضَّارِيبَا خْ كُوڒْ أَزدْجِيفْ!“ إِوْينْ أَسْ-د إِجّْ ن ذِينَارْ.
\v 20 خنِّي إِنَّا أَسنْ: ”وِي يِيڒَانْ ثَاصْوِيرْثْ-أَ ذ ثِيرَا-يَا؟“ \x ◘ \xo 22:‏20 \xt مك. 12‏:‏16؛ لك. 20‏:‏24\x*
\v 21 نَّانْ أَسْ: ”ن قَايْصَارْ!“ خنِّي إِنَّا أَسنْ: ”وْشمْ إِ قَايْصَارْ مِينْ إِدْجَانْ إِ قَايْصَارْ ؤُ إِ أَربِّي مِينْ إِدْجَانْ إِ أَربِّي.“ \x ◘ \xo 22:‏21 \xt مت. 17‏:‏25؛ رُوم. 13‏:‏7. \x*
\v 22 ڒَامِي سْڒِينْ مَانْ أَيَا، ثْبهْثنْ، سمْحنْ ذَايسْ ؤُشَا رُوحنْ.
\b
\s1 أَسقْسِي ن إِصَاذُوقِييّنْ خْ ثْنُوكْرَا
\m 
\v 23 ذڭْ وَاسّْ نِّي ؤُسِينْ-د غَارسْ إِصَاذُوقِييّنْ، قَّارنْ أَسْ: ’أَقَا وَارْ ذِينْ بُو ثُوذَارْثْ \add إِ\add* إِمتِّيننْ!‘، ؤُشَا سّقْسَانْ ث، \x ◘ \xo 22:‏23 \xt [مك. 12‏:‏18‏-‏27؛ لك. 20‏:‏27‏-‏40] — ڒخ. 23‏:‏8. \x*
\v 24 نَّانْ أَسْ: ”\add أَ\add* أَمْسغَّارْ، مُوسَا أَقَا إِنَّا: ’مَاڒَا إِمُّوثْ حذْ وَارْ د-يجِّي بُو ثَارْوَا، إِتّْخصَّا إِ ؤُمَاسْ أَذْ إِمْڒشْ أَكْ-ذ ثمْغَارْثْ نّسْ أَذْ كِيذسْ د-يجّْ أَحنْجِيرْ إِ ؤُمَاسْ.‘ \x ◘ \xo 22:‏24 \xt أَعَوذ. 25‏:‏5‏-‏6؛ أَمز. 38‏:‏8. \x*
\v 25 ثُوغَا غَارْنغْ سبْعَا ن وَاوْمَاثنْ. أَمزْوَارُو إِمْڒشْ، إِمُّوثْ. ؤُمِي وَارْ د-يجِّي شَا ثَارْوَا، أَقَا إِجَّا ثَامْغَارْثْ نّسْ إِ ؤُمَاسْ.
\v 26 أَمُّو \add إِ إِمُّوثْ\add* ؤُڒَا ذ ونِّي وِيسّْ ثْنَاينْ ذ وِيسّْ ثْڒَاثَا أَڒْ ونِّي وِيسّْ سبْعَا.
\v 27 غَارْ ؤُنڭَّارُو نْسنْ مَارَّا ثمُّوثْ ثمْغَارْثْ.
\v 28 إِ مَانْ ونْ زَّايْسنْ إِ غَا ثِيڒِي ثمْغَارْثْ ذِي ثْنُوكْرَا، مِينْزِي نِيثْنِي مَارَّا إِوْينْ ت ذ ثَامْغَارْثْ؟“
\m 
\v 29 يَاسُوع يَارَّا-د، إِنَّا أَسنْ: ”أَقَا كنِّيوْ ثْودَّارمْ، مِينْزِي وَارْ ثسِّينمْ شَا ثِيرَا \add إِقدّْسنْ\add* ؤُڒَا ذ جّهْذْ ن أَربِّي.
\v 30 مِينْزِي ذِي ثْنُوكْرَا وَارْ تِّيوْينْ نِيثْنِي ثِيمْغَارِينْ، ؤُ ثِيمْغَارِينْ وَارْ تِّيڒِينْثْ إِ يرْيَازنْ، مَاشَا أَذْ إِڒِينْ أَمْ لْمَالَاكَاثْ ن أَربِّي ذڭْ ؤُجنَّا.
\v 31 \add مَاشَا\add* زِي جِّيهثْ ن ثْنُوكْرَا جَارْ إِمتِّيننْ، مَا وَارْ ثغْرِيمْ شَا مِينْ ذ أَومْ إِنَّا أَربِّي إِ إِقَّارنْ:
\v 32 ’أَقَا نشّْ ذ أَربِّي ن إِبْرَاهِيمْ، أَربِّي ن إِسْحَاقْ، أَربِّي ن يَاعْقُوبْ!‘ أَربِّي وَارْ إِدْجِي ذ أَربِّي ن إِمتِّيننْ مَاشَا ن يِينِّي إِدَّارنْ.“ \x ◘ \xo 22:‏32 \xt ؤُف. 3‏:‏6، 15. \x*
\v 33 ڒَامِي سْڒِينْ ڒْغَاشِي مَانْ أَيَا، ثْبهْثنْ ذڭْ ؤُسڒْمذْ نّسْ. \x ◘ \xo 22:‏33 \xt مت. 7‏:‏28. \x*
\b
\s1 ثَاوْصيّثْ ثَامقّْرَانْثْ
\m 
\v 34 ڒَامِي سْڒِينْ إِفَارِيسِييّنْ بلِّي نتَّا إِبلّعْ أَقمُّومْ ن إِصَاذُوقِييّنْ، مُوننْ جَارْ أَسنْ. \x ◘ \xo 22:‏34 \xt [مك. 12‏:‏28‏-‏34؛ لك. 10‏:‏25‏-‏28] \x*
\v 35 إِجّنْ زَّايْسنْ، إِجّنْ ونِّي إِسّْننْ شَّارِيعَا \add مْلِيحْ\add*، إِسّقْسَا ث حِيمَا أَذْ ث إِجَارّبْ: \x ◘ \xo 22:‏35 \xt لك. 10‏:‏25. \x*
\v 36 ”\add أَ\add* أَمْسغَّارْ، مَانْ ثَاوْصيّثْ إِ إِدْجَانْ ذ ثَامقّْرَانْثْ ذِي شَّارِيعَا؟“
\v 37 إِنَّا أَسْ يَاسُوع: ”أَذْ ثخْسذْ سِيذِي، أَربِّي نّشْ، س مَارَّا وُوڒْ نّشْ، س مَارَّا ڒعْمَارْ نّشْ، س مَارَّا جّهْذْ نّشْ ؤُ س مَارَّا ڒعْقڒْ نّشْ. \x ◘ \xo 22:‏37 \xt أَعَوذ. 6‏:‏5؛ 10‏:‏12؛ 30‏:‏6؛ مك. 12‏:‏30، 33؛ لك. 10‏:‏27. \x*
\v 38 ذ ثَا ذ ثَاوْصيّثْ ثَامقّْرَانْثْ ذ ثَامزْوَارُوثْ.
\v 39 ثنِّي وِيسّْ ثْنَاينْ ثَارْوسْ ذَايسْ، أَقَا نتَّاثْ: ’أَذْ ثخْسذْ جَّارْ نّشْ أَمشْنَاوْ إِخفْ نّشْ‘. \x ◘ \xo 22:‏39 \xt لَاوِي 19‏:‏18؛ مك. 12‏:‏31؛ رُوم. 13‏:‏9؛ ڭال. 5‏:‏14؛ أَفا. 5‏:‏2؛ 1 تس. 4‏:‏9؛ يَاع. 2‏:‏8. \x*
\v 40 خْ ثْنَاينْ ن ثْوصَّا-يَا ثتّْوَابْنَا مَارَّا شَّارِيعَا ذ إِنَابِييّنْ.“
\b
\s1 يَاسُوع إِسّقْسَا إِفَارِيسِييّنْ خْ مِّيسْ ن ذَاوُوذْ
\m 
\v 41 أَمْ ثُوغَا مُوننْ إِفَارِيسِييّنْ، إِسّقْسَا ثنْ يَاسُوع، \x ◘ \xo 22:‏41 \xt [مك. 12‏:‏35‏-‏37؛ لك. 20‏:‏41‏-‏44] \x*
\v 42 إِنَّا: ”مِينْ ثقَّارمْ خْ لْمَاسِيحْ؟ ؤُمِي إِڭَّا مِّيسْ؟“ نَّانْ أَسْ: ”مِّيسْ ن ذَاوُوذْ!“
\v 43 إِنَّا أَسنْ: ”مَامّشْ إِ غَا يڭّْ ذَاوُوذْ أَذْ أَسْ إِسمَّا زِي أَرُّوحْ ’سِيذِي‘، أَمْ إِقَّارْ:
\v 44 ’سِيذِي إِنَّا إِ سِيذِي إِنُو: قِّيمْ-د خْ ؤُفُوسِي إِنُو أَڒْ غَا ڭّغْ ڒْعذْيَانْ نّشْ سَاذُو إِضَارنْ نّشْ.‘ \x ◘ \xo 22:‏44 \xt إِزهد. 110‏:‏1؛ ڒخ. 2‏:‏34؛ 1 كُور. 15‏:‏25؛ عبر. 1‏:‏13؛ 10‏:‏13. \x*
\v 45 مَاڒَا ذَاوُوذْ إِڒَاغَا أَسْ ’سِيذِي‘، مَامّشْ غَا يِيڒِي ذ مِّيسْ؟“
\v 46 ؤُڒَا ذ إِجّنْ وَارْ إِزمَّارْ أَذْ خَاسْ د-يَارّْ ؤُ ؤُڒَا ذ إِجّْ وَارْ إِقِّيمْ إِزعّمْ إِتّْسقْسَا ث \add شَا\add* عَاذْ زڭْ وَاسّْ نِّي.
\b
\b
\c 23
\s1 أَوَاڒنْ إِقسْحنْ خْ إِمْسڒْمَاذنْ ن شَّارِيعَا ذ إِفَارِيسِييّنْ
\m 
\v 1 ڒخْذنِّي إِسِّيوڒْ يَاسُوع أَكْ-ذ ڒْغَاشِي ؤُ أَكْ-ذ إِمحْضَارنْ نّسْ، \x ◘ \xo 23:‏1 \xt [مك. 12‏:‏38‏-‏40؛ لك. 11‏:‏37‏-‏52؛ 13‏:‏34‏-‏35؛ 20‏:‏45‏-‏47] \x*
\v 2 إِنَّا: ”إِمْسڒْمَاذنْ ن إِذْلِيسنْ ذ إِفَارِيسِييّنْ سّْغِيمنْ سِيمَانْثْ نْسنْ خْ ڒْكُورْسِي ن مُوسَا. \x ◘ \xo 23:‏2 \xt نَاح. 8‏:‏4\x*
\v 3 س ؤُيَا مَارَّا مِينْ ذ أَومْ قَّارنْ مَاحنْذْ أَذْ ذَايسْ ثْشبَّارمْ، ڭّمْ ث، مَاشَا وَارْ تّڭّمْ عْلَاحْسَابْ ڒخْذَايمْ نْسنْ، مِينْزِي نِيثْنِي وَاخَّا قَّارنْ \add ث\add*، وَارْ \add ث\add* تّڭّنْ. \x ◘ \xo 23:‏3 \xt أَعَوذ. 17‏:‏19؛ مـَال. 2‏:‏6؛ رُوم. 2‏:‏19. \x*
\v 4 تّْشدَّانْ ڒحْمڒْ إِضقْڒنْ، سّْرُوسَانْ ثنْ خْ ثْغَارْذِينْ ن إِوْذَانْ، مَاشَا نِيثْنِي س يِيخفْ نْسنْ وَارْ خْسنْ أَذْ ثنْ سّنْهزّنْ ؤُڒَا س يِيجّْ ن ؤُضَاضْ. \x ◘ \xo 23:‏4 \xt إِشا. 10‏:‏1؛ لك. 11‏:‏46؛ ڒخ. 15‏:‏10. \x*
\v 5 مَارَّا ڒخْذَايمْ نْسنْ إِ إِتّڭّنْ، تّڭّنْ ثنْثْ حِيمَا أَذْ ثنْ ژَترنْ إِوْذَانْ مِينْزِي نِيثْنِي تّڭّنْ ثِيحزَّانِينْ نْسنْ ن ثْژَادْجِيثْ ذ إِمِيرِيونْ ؤُشَا ثِيشْرُورِينْ \add إِ إِدْجَانْ غَارْ ؤُبحْڒُوڒْ\add* ن ڒْكَاشْنِي ن ثْژَادْجِيثْ نْسنْ، ڭِّينْ ثنْثْ ذ ثِيمقّْرَانِينْ. \x ◘ \xo 23:‏5 \xt ڒخْڒ. 15‏:‏38؛ أَعَوذ. 6‏:‏8؛ 22‏:‏12؛ مت. 6‏:‏5. \x*
\v 6 نِيثْنِي تّخْسنْ إِمُوشَانْ إِصبْحنْ غَارْ ڒفْرُوحْ ؤُ ڒكْرَاسِي إِصبْحنْ ذِي ثمْزِيذَاوِينْ، \x ◘ \xo 23:‏6 \xt مك. 12‏:‏38، 39؛ لك. 11‏:‏43؛ 20‏:‏46. \x*
\v 7 ؤُڒَا ذ سّْڒَامْ ذِي ڒسْوَاقْ، ؤُشَا إِعْجبْ أَسنْ أَذْ أَسنْ ڒَاغَانْ إِوْذَانْ ’\add أَ\add* أَمْسڒْمَاذْ إِنُو!‘ \x ◘ \xo 23:‏7 \xt يَاع. 3‏:‏1. \x*
\v 8 مَاشَا كنِّيوْ وَارْ تّجِّيمْ أَذْ أَومْ ڒَاغَانْ ’\add أَ\add* أَمْسڒْمَاذْ إِنُو!‘، مِينْزِي أَمْسڒْمَاذْ نْومْ ذ إِجّنْ، مَاشَا كنِّيوْ مَارَّا ذ أَوْمَاثنْ.
\v 9 وَارْ تّجِّيمْ أَذْ أَومْ ڒَاغَانْ ذِي ثمُّورْثْ ’\add أَ\add* بَابَا!‘، مِينْزِي بَابَاثْومْ إِ إِدْجَانْ ذڭْ إِجنْوَانْ ذ إِجّنْ. \x ◘ \xo 23:‏9 \xt مـَال. 1‏:‏6. \x*
\v 10 وَارْ تّجِّيمْ أَذْ أَومْ ڒَاغَانْ ’إِمْڭوَّاذنْ‘، مِينْزِي إِجّنْ ذ ونِّي ذ أَمْڭوَّاذْ نْومْ، أَقَا-ث ذ لْمَاسِيحْ.
\v 11 مَاشَا أَمقّْرَانْ نْومْ أَذْ يِيڒِي ذ أَمْسخَّارْ نْومْ. \x ◘ \xo 23:‏11 \xt مت. 20‏:‏26. \x*
\v 12 ونِّي إِ غَا إِسُّوعْڒَانْ إِخفْ نّسْ، أَذْ إِتّْوَاسّمْژِي، ؤُ ونِّي إِ غَا إِسّْمژْينْ إِخفْ نّسْ، أَذْ إِتّْوَاسُّوعْڒَا.“ \x ◘ \xo 23:‏12 \xt أَيُوبْ 22‏:‏29؛ أَوڒن. 29‏:‏23؛ لك. 14‏:‏11؛ 18‏:‏14؛ يَاع. 4‏:‏6، 10؛ 1 بُط. 5‏:‏5. \x*
\b
\m 
\v 13 \bd ”ؤُشْثْ خَاومْ\bd*، \add أَ كنِّيوْ\add* إِمْسڒْمَاذنْ ن إِذْلِيسنْ ذ إِفَارِيسِييّنْ، \add كنِّيوْ، أَ\add* إِمْنَافْقنْ، كنِّيوْ ثتّتّمْ ثُوذْرِينْ ن ثِيجَّاڒْ أَمْ ثتَّارمْ ثِيوْهِيبِينْ ذِي طّْوعْ ن ثْژَادْجَاثِينْ نْومْ ثِيزِيرَارِينْ. س ؤُينِّي أَذْ ثكْسِيمْ ڒْحُوكْمْ ذ أَمقّْرَانْ. \x ◘ \xo 23:‏13 \xt لك. 11‏:‏52. \x*
\m 
\v 14 \bd ؤُشْثْ خَاومْ\bd*، \add أَ كنِّيوْ\add* إِمْسڒْمَاذنْ ن إِذْلِيسنْ ذ إِفَارِيسِييّنْ، \add كنِّيوْ، أَ\add* إِمْنَافْقنْ، كنِّيوْ ثتّْبلّْعمْ ثَاڭلْذِيثْ ن إِجنْوَانْ إِ إِوْذَانْ، مِينْزِي كنِّيوْ سِيمَانْثْ نْومْ وَارْ ت ثتِّيذْفمْ، ؤُشَا إِنِّي يَارزُّونْ أَذْ د-أَذْفنْ، وَارْ ثنْ ثتّجِّيمْ أَذْ د-أَذْفنْ. \x ◘ \xo 23:‏14 \xt مك. 12‏:‏40؛ لك. 20‏:‏47؛ 2 تِيم. 3‏:‏6؛ ثِيث. 1‏:‏11. \x*
\m 
\v 15 \bd ؤُشْثْ خَاومْ\bd*، \add أَ كنِّيوْ\add* إِمْسڒْمَاذنْ ن إِذْلِيسنْ ذ إِفَارِيسِييّنْ، \add كنِّيوْ، أَ\add* إِمْنَافْقنْ، كنِّيوْ ثكّمْ خْ ڒْبَارّْ ؤُ خْ ڒبْحَارْ، حِيمَا أَذْ د-ثَارّمْ إِجّنْ ذ أَمْعَاشَارْ ن دِّينْ ن وُوذَاينْ، ؤُ خْمِي إِ كِيذْومْ غَا يِيڒِي، ثتَّارَّامْ ث ذ مِّيسْ ن جهنَّامَا ذ أَعفَّانْ مَاهُو خْ كنِّيوْ ثْنَاينْ ن ثْسقَّارْ.
\m 
\v 16 \bd ؤُشْثْ خَاومْ\bd*، \add أَ كنِّيوْ\add* إِمْڭوَّاذنْ إِذَارْغَاڒنْ، إِنِّي إِقَّارنْ: ’ونِّي إِجِّيدْجنْ غَارْ زَّاوشْثْ ثَامقّْرَانْثْ، أَقَا ثَاجَادْجِيثْ نّسْ وَارْ ثسّكّْوِي وَالُو، مَاشَا ونِّي إِ غَا إِجِّيدْجنْ س وُورغْ إِ إِدْجَانْ ذِي زَّاوشْثْ ثَامقّْرَانْثْ، أَقَا نتَّا إِقّنْ غَارْ إِڒسْ نّسْ.‘
\v 17 \add أَ\add* إِفْغَاڒْ، \add أَ\add* إِذَارْغَاڒنْ، مِينْ إِسكّْوَانْ كْثَارْ، ؤُرغْ نِيغْ زَّاوشْثْ ثَامقّْرَانْثْ ثنِّي ثسّْقدّسْ ؤُرغْ؟
\v 18 ؤُشَا \add أَمُّو إِ ثقَّارمْ عَاوذْ\add*: ’ونِّي إِجِّيدْجنْ غَارْ ؤُعَالْطَارْ، أَقَا ثَاجَادْجِيثْ نّسْ وَارْ ثْسكّْوِي وَالُو، مَاشَا ونِّي إِ غَا إِجِّيدْجنْ س ثْموْشِي إِ خَاسْ إِمَّارْسنْ، أَقَا نتَّا إِقّنْ غَارْ إِڒسْ نّسْ.‘
\v 19 \add أَ\add* إِفْغَاڒْ، \add أَ\add* إِذَارْغَاڒنْ، مِينْ إِسكّْوَانْ كْثَارْ، ثَاموْشِي نِيغْ أَعَالْطَارْ ونِّي إِسّْقدّسْ ثَاموْشِي؟
\v 20 س ؤُيَا وِي غَا إِجَّادْجنْ \add خنِّي\add* غَارْ ؤُعَالْطَارْ، أَقَا إِجُّودْجْ غَارْ ؤُعَالْطَارْ ؤُ غَارْ مَارَّا مِينْ خَاسْ إِدْجَانْ.
\v 21 ؤُ وِي غَا إِجَّادْجنْ غَارْ زَّاوشْثْ ثَامقّْرَانْثْ، إِجُّودْجْ غَارسْ ؤُ غَارْ ونِّي ذَايسْ إِزدّْغنْ. \x ◘ \xo 23:‏21 \xt 1 إِج. 8‏:‏13؛ 2 إِم. 6‏:‏1، 2. \x*
\v 22 ؤُ وِي غَا إِجَّادْجنْ غَارْ ؤُجنَّا، أَقَا إِجُّودْجْ غَارْ ڒْعَارْشْ ن أَربِّي ذ ونِّي خَاسْ إِقِّيمنْ. \x ◘ \xo 23:‏22 \xt 2 إِم. 6‏:‏33؛ إِشا. 66‏:‏1؛ مت. 5‏:‏34؛ ڒخ. 7‏:‏49. \x*
\m 
\v 23 \bd ؤُشْثْ خَاومْ\bd*، \add أَ كنِّيوْ\add* إِمْسڒْمَاذنْ ن إِذْلِيسنْ ذ إِفَارِيسِييّنْ، \add كنِّيوْ، أَ\add* إِمْنَافْقنْ، مِينْزِي كنِّيوْ ثتِّيشمْ ثَاعْشَارْثْ ن نّعْنَاعْ ذ سَّانُودْجْ ذ ڒْشمُّومْ، مَاشَا وَارْ ذ أَومْ إِشْقِي مِينْ إِدْجَانْ ذ أَمقّْرَانْ ذِي شَّارِيعَا، أَقَا ڒْحُوكْمْ ذ أَرّحْمثْ ذ لْ-إِيمَانْ. إِنَا إِ إِتّْخصَّا أَذْ ثڭّمْ، وَارْ ذَايْسنْ ثْسمّْحمْ. \x ◘ \xo 23:‏23 \xt 1 صم. 15‏:‏22؛ حُوش. 6‏:‏6؛ مِيخَا 6‏:‏8؛ مت. 9‏:‏13؛ 12‏:‏7؛ لك. 11‏:‏42. \x*
\v 24 أَ إِمْڭوَّاذنْ إِذَارْغَاڒنْ إِنِّي إِفَارّْننْ ثِيزِيثْ، \add مَاشَا\add* ثسّْغدْجَايمْ أَڒْغمْ.
\m 
\v 25 \bd ؤُشْثْ خَاومْ\bd*، \add أَ كنِّيوْ\add* إِمْسڒْمَاذنْ ن إِذْلِيسنْ ذ إِفَارِيسِييّنْ، \add كنِّيوْ، أَ\add* إِمْنَافْقنْ، مِينْزِي ثسِّيزْذَاڭمْ بَارَّا ن ڒْكَاسْ ذ طّبْصِي، مَاشَا غَارْ ذَاخڒْ أَقَا شُّورنْ س ثْكشَّاضْثْ ذ مِينْ وَارْ إِسڭّْذنْ. \x ◘ \xo 23:‏25 \xt لك. 11‏:‏39. \x*
\v 26 \add أَ\add* إِفَارِيسِييّنْ إِذَارْغَاڒنْ، سِيزْذڭمْ أَمزْوَارْ ذَاخڒْ ن ڒْكَاسْ ذ طّبْصِي، مَاحنْذْ أَذْ يِيڒِي إِزْذِيڭْ ؤُڒَا مِينْ إِدْجَانْ غَارْ بَارَّا نْسنْ. \x ◘ \xo 23:‏26 \xt ثِيث. 1‏:‏15. \x*
\m 
\v 27 \bd ؤُشْثْ خَاومْ\bd*، \add أَ كنِّيوْ\add* إِمْسڒْمَاذنْ ن إِذْلِيسنْ ذ إِفَارِيسِييّنْ، \add كنِّيوْ، أَ\add* إِمْنَافْقنْ، مِينْزِي ثڭِّيمْ أَمْ يِيمضْڒَانْ إِنِّي إِتّْوَاجِييَّارنْ، تّْبَاننْ ذ إِصبْحَاننْ غَارْ بَارَّا، مَاشَا غَارْ ذَاخڒْ أَقَا شُّورنْ س إِغْسَانْ ن ڒْخشْبَاثْ ؤُ س مَارَّا ڒخْمجْ. \x ◘ \xo 23:‏27 \xt ڒخ. 23‏:‏3. \x*
\v 28 أَمنِّي كنِّيوْ عَاوذْ، أَقَا ثضْهَارمْ ذ إِمْسڭَّاذنْ قِيبَاتْشْ إِ إِوْذَانْ، مَاشَا غَارْ ذَاخڒْ أَقَا ثشُّورمْ س ڒْمُوعْصِييّثْ ؤُ س نِّيفَاقْ.
\m 
\v 29 \bd ؤُشْثْ خَاومْ\bd*، \add أَ كنِّيوْ\add* إِمْسڒْمَاذنْ ن إِذْلِيسنْ ذ إِفَارِيسِييّنْ، \add كنِّيوْ، أَ\add* إِمْنَافْقنْ، مِينْزِي ثْبنَّامْ إِمضْڒَانْ ن إِنَابِييّنْ ؤُ ثْزوّْقمْ ڒْقُوبَّاثْ ن إِمضْڒَانْ ن إِمْسڭَّاذنْ، \x ◘ \xo 23:‏29 \xt لك. 11‏:‏47. \x*
\v 30 ثقَّارمْ: ’مْڒِي ثُوغَا ندْجْ ذڭْ وُوسَّانْ ن ڒجْذُوذْ نّغْ، أَذْ يِيڒِي وَارْ نْشَارّشْ ذڭْ \add ؤُسِيزّڒْ ن\add* إِذَامّنْ ن إِنَابِييّنْ.‘
\v 31 س ؤُيَا ثْشهّْذمْ خْ يِيخفْ نْومْ بلِّي كنِّيوْ ذ ثَارْوَا ن يِينِّي إِنْغِينْ إِنَابِييّنْ. \x ◘ \xo 23:‏31 \xt ڒخ. 7‏:‏51؛ 1 تس. 2‏:‏15. \x*
\v 32 \add إِوَا\add* كمّْڒمْ كنِّيوْ \add خنِّي\add* ؤُڒَا ڒقْيَاسْ ن \add مِينْ ڭِّينْ\add* ڒجْذُوذْ نْومْ!
\v 33 أَ إِڒفْسَاونْ، ثَارْوَا ن إِفِيغْرَانْ، مَامّشْ غَا ثڭّمْ أَذْ ثتّْوَاسّْنجْممْ زِي ڒْحُوكْمْ \add ن ثْمسِّي\add* ن جهنَّامَا؟ \x ◘ \xo 23:‏33 \xt مت. 3‏:‏7. \x*
\v 34 س ؤُينِّي خْزَارمْ، نشّْ أَذْ غَارْومْ د-سّكّغْ إِنَابِييّنْ ذ إِمِيغِيسنْ ذ إِمْسڒْمَاذنْ ن إِذْلِيسنْ. شَا زَّايْسنْ أَذْ ثنْ ثنْغمْ، شَا زَّايْسنْ أَذْ ثنْ ثْصلّْبمْ ؤُ شَا زَّايْسنْ أَذْ ثنْ ثْهتّْكمْ س ؤُركُّوضْ ذِي ثمْزِيذَاوِينْ نْومْ ؤُشَا أَذْ خَاسنْ ثَاژّْڒمْ زِي ثنْذِينْثْ غَارْ ثنْذِينْثْ \add نّغْنِي\add*، \x ◘ \xo 23:‏34 \xt مت. 10‏:‏16، 17؛ لك. 10‏:‏3؛ 11‏:‏49؛ يُوح. 16‏:‏2؛ ڒخ. 7‏:‏52. \x*
\v 35 أَڒَامِي أَذْ خَاومْ إِڒِينْ مَارَّا إِذَامّنْ إِسڭّْذنْ إِ إِسِّيزّْڒنْ خْ ثمُّورْثْ، زڭْ إِذَامّنْ ن هَابِيلْ أَمْسڭَّاذْ أَڒْ إِذَامّنْ ن زَاكَارِييَّا، مِّيسْ ن بِيرِيخْيَا، إِ ثنْغِيمْ جَارْ زَّاوشْثْ ثَامقّْرَانْثْ ذ ؤُعَالْطَارْ. \x ◘ \xo 23:‏35 \xt أَمز. 4‏:‏8؛ 2 إِم. 24‏:‏21؛ عبر. 11‏:‏4. \x*
\v 36 س ثِيذتّْ، نشّْ أَذْ أَومْ إِنِيغْ: مَارَّا ثِيمسْڒَايِينْ-أَ أَذْ د-أَسنْثْ خْ جِّيڒْ-أَ.“
\b
\m 
\v 37 ”\add أَ\add* ؤُرْشَالِيمْ، \add أَ\add* ؤُرْشَالِيمْ، شمْ إِ إِنقّنْ إِنَابِييّنْ ؤُ يَارجّْمنْ إِنِّي ذ أَمْ د-إِتّْوَاسّكّنْ، مشْحَاڒْ ثُوغَا خْسغْ أَذْ سّْمُونغْ ثَارْوَا نّمْ أَمْ يِيشْثْ ن ثْيَاژِيضْثْ ثڭَّا إِفِيدْجُوسنْ نّسْ سَاذُو أَفْرِيونْ نّسْ، \add مَاشَا\add* كنِّيوْ ثُوغَا وَارْ ثتّخْسمْ. \x ◘ \xo 23:‏37 \xt إِزهد. 17‏:‏8؛ 91‏:‏4؛ مت. 21‏:‏35، 36؛ \x*
\v 38 خْزَارْ، ثَادَّارْثْ نْومْ أَذْ ثتّْوَاجّْ إِ شمْ ذ ڒْخَارْبثْ، \x ◘ \xo 23:‏38 \xt إِزهد. 69‏:‏26؛ إِشا. 1‏:‏7؛ إِرْم. 7‏:‏34؛ مِيخَا 3‏:‏12؛ ڒخ. 1‏:‏20. \x*
\v 39 مِينْزِي نشّْ أَذْ أَومْ إِنِيغْ: كنِّيوْ وَارْ ذ أَيِي ثْژَارّمْ أَڒْ غَا ثِينِيمْ: ’لْبَارَاكَا إِ ونِّي د-يُوسِينْ س يِيسمْ ن سِيذِي.‘ “ \x ◘ \xo 23:‏39 \xt إِزهد. 118‏:‏26. \x*  *
\b
\b
\c 24
\s1 أَوَاڒْ ن يَاسُوع خْ ثُوقَّاثْ ن دُّونشْثْ
\m 
\v 1 \add خنِّي\add* إِفّغْ يَاسُوع زِي زَّاوشْثْ ثَامقّْرَانْثْ مَاحنْذْ أَذْ يُويُورْ، \add مَاشَا\add* ؤُسِينْ-د غَارسْ إِمحْضَارنْ نّسْ، سّشْننْ أَسْ ڒبْنِييَّاثْ ن زَّاوشْثْ ثَامقّْرَانْثْ. \x ◘ \xo 24:‏1 \xt [مك. 13‏:‏1‏-‏37؛ لك. 12‏:‏41‏-‏48؛ 17‏:‏26‏-‏30، 34‏-‏36؛ 21‏:‏5‏-‏33] \x*  *
\b
\m 
\v 2 نتَّا إِنَّا أَسنْ: ”مَا وَارْ ثژْرِيمْ مَارَّا مَانْ أَيَا؟ س ثِيذتّْ، نشّْ أَذْ أَومْ إِنِيغْ: وَارْ ذَا إِتّْغِيمِي ؤُڒَا ذ إِجّْ ن وژْرُو خْ وژْرُو نّغْنِي إِ وَارْ إِتّْنهْذِيمْ.“ \x ◘ \xo 24:‏2 \xt 1 إِج. 9‏:‏7، 8؛ مِيخَا 3‏:‏12؛ لك. 19‏:‏44. \x*
\m 
\v 3 ؤُمِي ثُوغَا يَاسُوع إِقِّيمْ خْ وذْرَارْ ن زِّيثُونْ، ؤُسِينْ-د إِمحْضَارنْ نّسْ، ثُوغَا تّمْسَاوَاڒَانْ، نَّانْ أَسْ: ”إِنِي أَنغْ، مڒْمِي إِ غَا إِمْسَارْ أَيَا ؤُ مَانْ ڒعْڒَامثْ ن ثْوَاسِيثْ نّشْ ؤُ ن قطُّو ن دُّونشْثْ؟“ \x ◘ \xo 24:‏3 \xt مك. 13‏:‏1، 3؛ لك. 21‏:‏7؛ ڒخ. 1‏:‏6. \x*
\v 4 يَاسُوع يَارَّا-د، إِنَّا أَسنْ: ”حْضَامْ إِخفْ نْومْ، وَارْ كنِّيوْ إِخدّعْ حذْ. \x ◘ \xo 24:‏4 \xt إِرْم. 29‏:‏8؛ أَفا. 5‏:‏6؛ كُول. 2‏:‏18؛ 2 تس. 2‏:‏3؛ 1 يُوح. 4‏:‏1. \x*
\v 5 مِينْزِي أَطَّاسْ أَذْ د-أَسنْ س يِيسمْ إِنُو، أَذْ إِنِينْ: ’أَقَا نشّْ ذ لْمَاسِيحْ!‘، ؤُشَا أَذْ خذْعنْ أَطَّاسْ. \x ◘ \xo 24:‏5 \xt إِرْم. 14‏:‏14؛ 23‏:‏25؛ يُوح. 5‏:‏43. \x*
\v 6 ؤُشَا أَذْ ثسْڒمْ خْ ڭَارَّاثْ ؤُ خْ ڒخْبُورَاثْ ن إِمنْغَانْ. غَارْومْ أَقَا أَذْ ثڭّْوذمْ، مِينْزِي س ؤُغِيڒْ أَذْ يِيڒِي مَانْ أَيَا، مَاشَا وَارْ إِتِّيڒِي عَاذْ ذ أَنڭَّارْ.
\v 7 مِينْزِي ڒْڭنْسْ أَذْ إِغوّغْ خْ إِجّْ ن ڒْڭنْسْ \add نّغْنِي\add* ؤُ ثَاڭلْذِيثْ خْ ثْڭلْذِيثْ \add نّغْنِي\add*، أَذْ يِيڒِي ڒَاژْ ذ ڒهْڒَاشَاثْ يوْعَارنْ ذ إِنْهزَّانْ ن ثمُّورْثْ ذَا ذ ذِيهَا. \x ◘ \xo 24:‏7 \xt إِشا. 19‏:‏2. \x*
\v 8 مَارَّا مَانْ أَيَا ذ بدُّو ن ڒوْجعْ \add ن ثَارُوثْ\add*.
\v 9 خنِّي أَذْ كنِّيوْ د-أَوْينْ غَارْ ڒْمحْنثْ ؤُشَا أَذْ كنِّيوْ نْغنْ، ؤُ مَارَّا ڒڭْنُوسْ أَذْ كنِّيوْ شَارْهنْ زِي سِّيبّثْ ن يِيسمْ إِنُو. \x ◘ \xo 24:‏9 \xt مت. 10‏:‏17؛ لك. 21‏:‏11، 12؛ يُوح. 15‏:‏20؛ 16‏:‏2؛ أَسَا. 2‏:‏10. \x*
\v 10 ڒخْذنِّي أَذْ نْقَارْضنْ وَاطَّاسْ، أَذْ شَارْهنْ إِجّنْ ونّغْنِي ؤُشَا أَذْ سلّْمنْ إِجّنْ ونّغْنِي.
\v 11 أَذْ كَّارنْ وَاطَّاسْ ن إِنَابِييّنْ إِسّْخَارِّيقنْ ؤُشَا أَذْ غْوَانْ أَطَّاسْ. \x ◘ \xo 24:‏11 \xt 2 بُط. 2‏:‏1. \x*
\v 12 س وَاطَّاسْ ن ڒْمُوعْصِييّثْ أَذْ ثُوذْرُوسْ ثَايْرِي ن وَاطَّاسْ \add ن إِوْذَانْ\add*، \f ◼ \fr 24:‏12 \ft \bd ’ثَايْرِي‘\bd* - نِيغْ ’ڒمْحِيبّثْ‘.\f*  \x ◘ \xo 24:‏12 \xt 2 تِيم. 3‏:‏1. \x*
\v 13 مَاشَا وِي غَا إِصْبَارنْ غَارْ ؤُنڭَّارْ، أَقَا نتَّا أَذْ إِدَّارْ. \x ◘ \xo 24:‏13 \xt مت. 10‏:‏22؛ مك. 13‏:‏13؛ لك. 21‏:‏19؛ أَسَا. 2‏:‏7، 10؛ 3‏:‏10. \x*
\v 14 ڒخْبَارْ-أَ أَصبْحَانْ ن ثْڭلْذِيثْ أَذْ زَّايسْ بَارّْحنْ ذِي دُّونشْثْ مَارَّا ذ شّْهَاذثْ إِ مَارَّا ڒڭْنُوسْ ؤُشَا ڒخْذنِّي أَذْ د-يَاسْ ؤُنڭَّارْ.“
\b
\m 
\v 15 ”خْمِي غَا ثْژَارمْ ڒعْڒَامثْ ن نّْعِي ن وَاريّبْ، مِينْ خفْ إِسِّيوڒْ ؤُنَابِي ذَانِييَالْ، ذڭْ ومْشَانْ إِقدّْسنْ - أجّْ ونِّي ث إِ غَا إِغَارنْ أَذْ إِفْثنْ - \x ◘ \xo 24:‏15 \xt دَان. 9‏:‏27؛ مك. 13‏:‏14؛ لك. 21‏:‏20. \x*
\v 16 ڒخْذنِّي جّمْ إِنِّي إِدْجَانْ ذِي يَاهُوذِييَّا أَذْ أَروْڒنْ غَارْ إِذُورَارْ. \x ◘ \xo 24:‏16 \xt مك. 13‏:‏14؛ لك. 21‏:‏21\x*
\v 17 ونِّي إِدْجَانْ خْ ثْزقَّا وَارْ د-إِهكّْوِي شَا حِيمَا أَذْ إِكْسِي شَا زِي ثَادَّارْثْ نّسْ،
\v 18 ؤُ ونِّي إِدْجَانْ ذڭْ إِيَّارْ، وَارْ د-إِذِّيكّْوِيڒْ شَا حِيمَا أَذْ د-يَاوِي أَرُّوضْ نّسْ.
\v 19 ؤُشْثْ خْ ثِينِّي إِدْجَانْ س دّيْسثْ ذ ثِينِّي إِسُّوطُّوضنْ ذڭْ وُوسَّانْ نِّي!
\v 20 ژَتدْجمْ، حِيمَا وَارْ ثتِّيڒِي ثَاروْڒَا نْومْ ذِي ڒْمشْثَا نِيغْ ذِي سّبْثْ، \x ◘ \xo 24:‏20 \xt ڒخ. 1‏:‏12. \x*
\v 21 مِينْزِي ڒخْذنِّي أَذْ ثِيڒِي ڒْمحْنثْ ثَامقّْرَانْثْ إِ وَارْ إِمْسَارنْعمَّارْصْ زڭْ وَامِي ثدْجَا دُّونشْثْ أَڒْ إِ ڒخُّو ؤُعمَّارْصْ وَارْ ثتِّيڒِي عَاذْ. \x ◘ \xo 24:‏21 \xt دَان. 12‏:‏1. \x*
\v 22 مْڒِي ؤُسَّانْ نِّي وَارْ تّْوَاسّْمژْينْ، خنِّي وَارْ إِتّْوَاسّنْجمْ ؤُڒَا ذ إِجّْ ن بْنَاذمْ، مَاشَا \add ؤُسَّانْ نِّي\add* أَذْ تّْوَاسّْمژْينْ ذِي طّْوعْ ن يِينِّي إِتّْوَافَارْزنْ.
\v 23 مَاڒَا إِنَّا أَومْ حذْ: ’خْزَارمْ، أَقَا ذَا لْمَاسِيحْ!‘ نِيغْ: ’أَقَا-ث ذِيهَا!‘ وَارْ \add ث\add* تِّيمْنمْ. \x ◘ \xo 24:‏23 \xt مك. 13‏:‏21؛ لك. 21‏:‏8. \x*
\v 24 مِينْزِي أَذْ إِڒِينْ إِمَاسِيحنْ إِفَالْسُوثنْ ذ إِنَابِييّنْ إِسّْخَارِّيقنْ، أَذْ ڭّنْ ڒعْڒَامَاثْ مْغَارنْثْ، حِيمَا، مْڒِي زمَّارنْ، أَذْ خذْعنْ عَاوذْ إِنِّي إِتّْوَافَارْزنْ. \x ◘ \xo 24:‏24 \xt أَعَوذ. 13‏:‏2؛ 2 تس. 2‏:‏11. \x*
\v 25 خْزَارمْ، أَقَا نِّيغْ أَومْ ث قْبڒْ.
\v 26 مَاڒَا نَّانْ أَومْ: ’خْزَارمْ، نتَّا أَقَا-ث ذِي ڒخْڒَا!‘، وَارْ تّْرِيحمْ شَا ذِينْ، \add نِيغْ\add*: ’خْزَارمْ، نتَّا أَقَا-ث ذَاخڒْ إِ وخَّامْ!‘، وَارْ \add ت\add* تِّيمْنمْ. \x ◘ \xo 24:‏26 \xt لك. 17‏:‏23. \x*
\v 27 مِينْزِي أَمْ وَاجَّاجْ إِ د-إِتّفّْغنْ زِي شَّارْقْ ؤُشَا إِتّڭّْ ثَافَاوْثْ أَڒْ ڒْغَارْبْ، أَمُّو إِ غَا ثِيڒِي ثْوَاسِيثْ ن مِّيسْ ن بْنَاذمْ.
\v 28 مَانِي غَا ثِيڒِي أَرِّيمثْ ذِيهَا أَذْ مُوننْ إِڭِيذَارنْ.“ \x ◘ \xo 24:‏28 \xt أَيُوبْ 39‏:‏30؛ لك. 17‏:‏37. \x*
\b
\m 
\v 29 ”ڒخْذنِّي أَوَارْنِي ڒْمحْنثْ ن وُوسَّانْ نِّي، أَذْ ثْبَارْشنْ ثْفُوشْثْ ؤُ ثَازِيرِي وَارْ ثتِّيشْ عَاذْ طّْيَا نّسْ ؤُ إِثْرَانْ أَذْ د-وْضَانْ زڭْ ؤُجنَّا ؤُ صُّولَاطَاثْ ن إِجنْوَانْ أَذْ تّْوَانْهزّنْثْ. \x ◘ \xo 24:‏29 \xt إِشا. 13‏:‏10؛ 34‏:‏4؛ حِز. 32‏:‏7؛ يُووِ. 3‏:‏4؛ 3‏:‏15؛ مك. 13‏:‏24؛ لك. 21‏:‏25. \x*
\v 30 خنِّي أَذْ د-ثضْهَارْ ڒعْڒَامثْ ن مِّيسْ ن بْنَاذمْ ذڭْ ؤُجنَّا ؤُ مَارَّا ثِيقبَّاڒْ ن ثمُّورْثْ أَذْ وْثنْثْ أَڭجْذُورْ ؤُشَا أَذْ ژَترنْثْ مِّيسْ ن بْنَاذمْ يُوسَا-د خْ إِسيْنُوثنْ ن ؤُجنَّا س جّهْذْ ؤُ س ؤُعُودْجِي أَطَّاسْ. \x ◘ \xo 24:‏30 \xt دَان. 7‏:‏10؛ مت. 16‏:‏27؛ 25‏:‏31؛ 26‏:‏64؛ مك. 13‏:‏26؛ 14‏:‏62؛ لك. 21‏:‏27؛ ڒخ. 1‏:‏11؛ 2 تس. 1‏:‏10؛ أَسَا. 1‏:‏7. \x*
\v 31 نتَّا أَذْ إِسّكّْ لْمَالَاكَاثْ نّسْ س ڒْحسّْ إِجهْذنْ ن ؤُسُوضِي ذڭْ \bd ؤُيِيشّْ ن إِشَارِّي\bd*، ؤُشَا أَذْ د-سّْمُوننْثْ إِنِّي إِتّْوَافَارْزنْ زِي أَربْعَا ن إِغزْذِيسنْ ن ؤُسمِّيضْ، زِي طَّارْفْ أَنڭَّارُو ن إِجنْوَانْ أَڒْ ونّغْنِي.“ \x ◘ \xo 24:‏31 \xt 1 كُور. 15‏:‏52؛ 1 تس. 4‏:‏16. \x*
\m 
\v 32 ”ڒمْذمْ زڭْ ؤُمذْيَا ن وَارْثُو: خْمِي غَا ذوْڒنْ ڒفْرُوعْ نّسْ ذ إِڒقَّاغنْ، أَذْ د-سُّوفّْغنْ ثِيفْرَايْ، أَذْ ثسّْنمْ أَقَا أَنبْذُو يُوذسْ-د. \x ◘ \xo 24:‏32 \xt مك. 13‏:‏28؛ لك. 21‏:‏29. \x*
\v 33 أَمُّو عَاوذْ كنِّيوْ، خْمِي غَا ثْژَارمْ مَارَّا مَانْ أَيَا، أَذْ ثسّْنمْ أَقَا يُوذسْ-د، غَارْ ثوَّارْثْ.“
\m 
\v 34 ”س ثِيذتّْ، نشّْ أَذْ أَومْ إِنِيغْ: جِّيڒْ-أَ وَارْ إِعدُّو أَڒْ غَا إِمْسَارْ مَانْ أَيَا مَارَّا.
\v 35 أَجنَّا ذ ثمُّورْثْ أَذْ عْذُونْ، \add مَاشَا\add* أَوَاڒنْ إِنُو وَارْعدُّونْعمَّارْصْ. \x ◘ \xo 24:‏35 \xt إِزهد. 102‏:‏27؛ إِشا. 51‏:‏6؛ مك. 13‏:‏31؛ عبر. 1‏:‏11. \x*
\b
\m 
\v 36 \bd مَاشَا خْ وَاسّْ نِّي نِيغْ خْ ثَاسَاعّثْ نِّي وَارْ خَاسْ إِسِّينْ ؤُڒَا ذ إِجّْ\bd*، ؤُڒَا ذ لْمَالَاكَاثْ ن إِجنْوَانْ، مْغِيرْ بَابَا وحّْذسْ. \x ◘ \xo 24:‏36 \xt ڒخ. 1‏:‏7\x*
\v 37 أَمْ مَامّشْ ثُوغَا إِدْجَا ذڭْ وُوسَّانْ ن نُوحْ أَمُّو إِ غَا ثِيڒِي غَارْ ثْوَاسِيثْ ن مِّيسْ ن بْنَاذمْ. \x ◘ \xo 24:‏37 \xt أَمز. 6‏:‏2؛ لك. 17‏:‏26؛ 1 بُط. 3‏:‏20؛ 2 بُط. 2‏:‏5. \x*
\v 38 مِينْزِي أَمْ مَامّشْ ثنْ ثُوغَا \add ذڭْ وُوسَّانْ\add* قْبڒْ طُّوفَانْ، تّتّنْ، سسّنْ، مدْجْشنْ ؤُ سّْمدْجَاشنْ أَڒْ أَسّْ إِ ذِي يُوذفْ نُوحْ غَارْ ؤُغَارَّابُو، \f ◼ \fr 24:‏38 \ft \bd ’طُّوفَانْ‘\bd* - إِخْسْ أَذْ يِينِي ڒْحمْڒثْ ثَامقّْرَانْثْ خْ مَارَّا دُّونشْثْ ذڭْ وُوسَّانْ ن نُوحْ، عْڒَاحَاڒْ أَڒْفَايْنْ ؤُ-خمْسَا-مْيَا ن إِسڭّْوُوسَا قْبڒْ مَا أَذْ إِخْڒقْ لْمَاسِيحْ. خْزَارْ أَمز. 6.\f*  \x ◘ \xo 24:‏38 \xt أَمز. 7‏:‏7. \x*
\v 39 ؤُشَا وَارْ ؤُشِينْ وَالُو أَڒَامِي د-يُوسَا طُّوفَانْ، إِمْحَا إِ-ثنْ مَارَّا، أَمُّو إِ غَا ثِيڒِي غَارْ ثْوَاسِيثْ ن مِّيسْ ن بْنَاذمْ.
\v 40 ذِي ڒْوقْثْ نِّي أَذْ إِڒِينْ ثْنَاينْ ذڭْ إِيَّارْ، إِجّنْ أَذْ ث كْسِينْ ؤُ ونّغْنِي أَذْ ث جّنْ. \x ◘ \xo 24:‏40 \xt لك. 17‏:‏34؛ 1 تس. 4‏:‏17. \x*
\v 41 ثْنَاينْ ن ثمْغَارِينْ أَذْ حَارْينْثْ س ثْسِيرْثْ، إِشْثنْ أَذْ ت كْسِينْ ؤُ ثنّغْنِي أَذْ ت جّنْ.
\v 42 س ؤُيَا حْضَامْ، مِينْزِي وَارْ ثسِّينمْ شَا ذِي مَانْ ثَاسَاعّثْ إِ د غَا يَاسْ سِيذِيثْومْ. \x ◘ \xo 24:‏42 \xt مت. 25‏:‏13؛ مك. 13‏:‏33؛ لك. 12‏:‏40؛ 21‏:‏36. \x*
\v 43 مَاشَا سّْنمْ أَيَا: مَاڒَا بَابْ ن ثَادَّارْثْ إِسّنْ ذِي مَانْ حطُّو \add ن دْجِيڒثْ\add* إِ د غَا يَاسْ ؤُشفَّارْ، إِڒِي إِقِّيمْ إِحطَّا، وَارْ ث إِتّجِّي أَذْ يَاذفْ غَارْ ثَادَّارْثْ نّسْ. \x ◘ \xo 24:‏43 \xt لك. 12‏:‏39؛ 1 تس. 5‏:‏2؛ 2 بُط. 3‏:‏10؛ أَسَا. 3‏:‏3؛ 16‏:‏15. \x*
\v 44 س ؤُيَا، إِڒِيمْ ثْوجْذمْ، مِينْزِي مِّيسْ ن بْنَاذمْ أَذْ د-يَاسْ ذڭْ إِشْثْ ن ثْسَاعّثْ وَارْ ت ثتّْرِيجِيمْ.“
\b
\m 
\v 45 ”\bd وِي إِدْجَانْ خنِّي ذ أَمْسخَّارْ أَمْثِيقِّي ذ أَمِيغِيسْ\bd* إِ إِڭَّا بَابْ نّسْ، حِيمَا أَذْ إِبْضَا خْ أَيْثْبَابْ ن ثَادَّارْثْ نّسْ مِينْ غَا شّنْ ذِي ڒْوقْثْ نّسْ؟\x ◘ \xo 24:‏45 \xt مت. 25‏:‏21\x*
\v 46 سّعْذْ ن ؤُمْسخَّارْ ونِّي إِ غَا يَافنْ سِيذِيسْ إِڒْهَا أَمُّو خْمِي د غَا يَاسْ.
\v 47 س ثِيذتّْ، نشّْ أَذْ أَومْ إِنِيغْ، أَذْ ث إِڭّْ خْ مَارَّا أَڭْڒَا نّسْ.
\v 48 مَاشَا مَاڒَا أَمْسخَّارْ أَعفَّانْ نِّي أَذْ يِينِي ذڭْ وُوڒْ نّسْ: ’سِيذِي إِنُو إِعطَّاڒْ مَاحنْذْ أَذْ د-يَاسْ!‘،
\v 49 ؤُشَا إِبْذَا إِشَّاثْ إِمْسخَّارنْ إِمْعَاشَارنْ نّسْ، أَذْ إِشّْ أَذْ إِسُو أَكْ-ذ إِمسْكَارنْ،
\v 50 خنِّي أَذْ د-يَاسْ سِيذِيسْ ن ؤُمْسخَّارْ نِّي ذڭْ إِجّْ ن وَاسّْ إِ ذِي وَارْ ث إِتّْرِيجِي ؤُ ذڭْ إِشْثْ ن ثْسَاعّثْ وَارْ ت إِسِّينْ،
\v 51 أَذْ ث إِقسّْ ذ إِوثْوِيثنْ ؤُشَا أَذْ ثِيڒِي ثسْغَارْثْ نّسْ أَكْ-ذ إِمْنَافْقنْ. ذِينْ إِ غَا يِيڒِينْ إِمطَّاونْ ذ ؤُغزِّي ن ثغْمَاسْ.“ \x ◘ \xo 24:‏51 \xt مت. 8‏:‏12؛ 13‏:‏42؛ 22‏:‏13؛ 25‏:‏30؛ لك. 13‏:‏28. \x*
\b
\b
\c 25
\s1 أَمذْيَا نعشْرَا ن ثعْزَارِييِّينْ
\m 
\v 1 ”خنِّي أَذْ ثِيڒِي ثْڭلْذِيثْ ن إِجنْوَانْ أَمشْنَاوْعشْرَا ن ثعْزَارِييِّينْ إِوْينْثْ ڒفْنَارَاثْ نْسنْثْ، فّْغنْثْ، حِيمَا أَذْ مّڒْقنْثْ أَكْ-ذ وسْڒِي ذ ثسْڒِيثْ.
\v 2 خمْسَا زَّايْسنْثْ ذ ثِيمِيغِيسِينْ ؤُ خمْسَا ذ ثِيفْغَاڒْ.
\v 3 ثِينِّي إِدْجَانْ ذ ثِيفْغَاڒْ كْسِينْثْ ڒفْنَارَاثْ نْسنْثْ، مَاشَا وَارْ إِوْيِينْثْ شَا زّشْثْ.
\v 4 ثِيمِيغِيسِينْ إِوْينْثْ-إِ-د زّشْثْ ذِي ثْزِييَّاثِينْ نْسنْثْ أَكْ-ذ ڒفْنَارَاثْ نْسنْثْ.
\v 5 ڒَامِي إِعْضڒْ ؤُمُوڒَايْ، بْذَانْثْ تّْنُوذُومنْثْ مَارَّا ؤُشَا طّْصنْثْ.
\m 
\v 6 ذِي ڒْوسْطْ ن دْجِيڒثْ ثُوغَا ذِينْ ثْغُويِّيثْ: ’خْزَارمْ، أَقَا أَمُوڒَايْ يُوسَا-د، فّْغمْ-د، أَذْ ث ثڒْقَامْ!‘
\v 7 خنِّي كَّارنْثْ ثعْزَارِييِّينْ نِّي، سّوْجْذنْثْ-إِ-د ڒفْنَارَاثْ نْسنْثْ.
\v 8 ثِيفْغَاڒْ نَّانْثْ إِ ثْمِيغِيسِينْ: ’وْشنْثْ أَنغْ زِي زّشْثْ نْكنْثْ مِينْزِي ڒفْنَارَاثْ نّغْ خسْينْثْ.‘
\v 9 أَرِّينْثْ-إِ-د خَاسنْثْ ثْمِيغِيسِينْ، نَّانْثْ: ’عمَّارْصْ، وَارْ ذ أَنغْ إِتّْقذِّي إِ نشِّينْ ذ كنِّينْثْ. رُوحنْثْ غَارْ إِسبَّابنْ، مَاحنْذْ أَذْ ثسْغنْثْ إِ يِيخفْ نْكنْثْ.‘
\v 10 ڒَامِي رُوحنْثْ نِيثنْثِي حِيمَا أَذْ سْغنْثْ، يُوسَا-د ؤُمُوڒَايْ، ؤُ ثِينِّي ثُوغَا إِوجْذنْ ؤُذْفنْثْ أَكِيذسْ غَارْ ثَادَّارْثْ ن ڒفْرَاحثْ ن وُورَارْ ؤُشَا ثْبلّعْ ثوَّارْثْ.
\v 11 أَوَارْنِي مَانْ أَيَا ؤُسِينْثْ ثعْزَارِييِّينْ نّغْنِي، قَّارنْثْ: ’\add أَ\add* سِيذِيثْنغْ، \add أَ\add* سِيذِيثْنغْ، أَرْزمْ أَنغْ!‘
\v 12 نتَّا يَارَّا-د، إِنَّا: ’س ثِيذتّْ، نشّْ أَذْ أَكنْثْ إِنِيغْ، وَارْ كنِّينْثْ سِّينغْ.‘
\v 13 س ؤُينِّي حْضَامْ، مِينْزِي كنِّيوْ وَارْ ثسِّينمْ شَا أَسّْ ؤُڒَا ذ ثَاسَاعّثْ.“ \x ◘ \xo 25:‏13 \xt مت. 24‏:‏42؛ مك. 13‏:‏33، 35. \x*
\b
\s1 أَمذْيَا ن ثَالِينْثَاثْ
\m 
\v 14 ”مِينْزِي ثَامسْڒَاشْثْ أَمْ يِيجّْ ن بْنَاذمْ إِسَافَارْ بَارَّا إِ ثمُّورْثْ نّسْ، إِڒَاغَا-د خْ إِمْسخَّارنْ نّسْ ؤُشَا إِكلّفْ إِ-ثنْ خْ وَاڭْڒَا نّسْ. \x ◘ \xo 25:‏14 \xt [لك. 19‏:‏11‏-‏27] \x*
\v 15 إِوْشَا إِ يِيجّنْ خمْسَا ثَالِينْثْ، إِ ونّغْنِي ثْنَاينْ، إِ ونِّي وِيسّْ ثْڒَاثَا إِشْثنْ \add ن ثَالِينْثْ\add*، كُوڒْ إِجّنْ عْلَاحْسَابْ ثِيزمَّارْ نّسْ، ڒخْذنِّي إِكَّارْ، إِسَافَارْ ذغْيَا. \f ◼ \fr 25:‏15 \ft \bd ’ثَالِينْثَاثْ‘\bd* - إِشْثْ ن ثَالِينْثْ ثسّكّْوِي عْڒَاحَاڒْ 58-80 أَرْضڒْ ن وُورغْ نِيغْ ن نُّوقَارْثْ.\f*
\v 16 إِرُوحْ ونِّي إِطّْفنْ خمْسَا ثَالِينْثْ، إِسبّبْ ذَايْسنْ ؤُشَا يَارْبحْ خمْسَا.
\v 17 أَمنِّي عَاوذْ ونِّي إِطّْفنْ ثْنَاينْ \add ثَالِينْثْ\add*، يَارْبحْ ثْنَاينْ نّغْنِي.
\v 18 مَاشَا ونِّي إِطّْفنْ إِشْثْ \add ن ثَالِينْثْ\add*، إِرُوحْ، إِغْزَا ذِي ثمُّورْثْ ؤُشَا إِسّْنُوفَّار \add ثْمنْيَاثْ ن نُّوقَارْثْ\add* ن بَابْ نّسْ.
\m 
\v 19 ڒَامِي ثعْذُو أَطَّاسْ ن ڒْوقْثْ يُوسَا-د بَابْ ن إِمْسخَّارنْ نِّي ؤُشَا إِڭَّا أَكِيذْسنْ ڒحْسَابْ.
\v 20 \add خنِّي\add* يُوسَا-د ونِّي إِطّْفنْ خمْسَا ثَالِينْثْ، يِيوِي-د خمْسَا ثَالِينْثْ نّغْنِي، إِنَّا: ’أَ سِيذِي، ثوْشِيذْ أَيِي خمْسَا ثَالِينْثْ، أَقَا ذَا، أَربْحغْ خمْسَا نّغْنِي كْثَارْ.‘
\v 21 يَارَّا-د خَاسْ بَابْ نّسْ، إِنَّا: ’مْلِيحْ إِ ثڭِّيذْ، \add أَ\add* أَمْسخَّارْ أَصبْحَانْ ذ أَمْثِيقِّي. ثُوغَا شكْ ذ أَمْثِيقِّي خْ ذْرُوسْ، أَذْ أَشْ ڭّغْ خْ وَاطَّاسْ، أَذفْ-د غَارْ ڒفْرَاحثْ ن سِيذِي نّشْ.‘
\v 22 خنِّي يُوسَا-د عَاوذْ ونِّي إِطّْفنْ ثْنَاينْ ثَالِينْثْ، إِنَّا: ’\add أَ\add* سِيذِي، ثوْشِيذْ أَيِي ثْنَاينْ ثَالِينْثْ، أَقَا أَربْحغْ ثْنَاينْ نّغْنِي كْثَارْ.‘
\v 23 إِنَّا أَسْ سِيذِي نّسْ: ’مْلِيحْ إِ ثڭِّيذْ، \add أَ\add* أَمْسخَّارْ أَصبْحَانْ ذ أَمْثِيقِّي. ثُوغَا شكْ ذ أَمْثِيقِّي خْ ذْرُوسْ، أَذْ أَشْ ڭّغْ خْ وَاطَّاسْ، أَذفْ-د غَارْ ڒفْرَاحثْ ن سِيذِي نكّْ.‘
\m 
\v 24 مَاشَا ونِّي إِطّْفنْ إِشْثْ ن ثَالِينْثْ، يُوسَا-د عَاوذْ، إِنَّا: ’\add أَ\add* سِيذِي، سّْنغْ أَقَا شكْ ذ بْنَاذمْ ثْقسْحذْ، ثْمجَّارذْ مَانِي وَارْ ثْزَارّْعذْ، ثْيَارّْوذْ مَانِي وَارْ ثسَّارْوَاثذْ.
\v 25 \add س ؤُينِّي\add* ڭّْوذغْ ؤُشَا رُوحغْ، سّْنُوفَّارغْ ثَالِينْثْ نّشْ ذِي ثمُّورْثْ. أَغَاشْ ثنِّي نّشْ.‘
\v 26 يَارَّا-د سِيذِي نّسْ، إِنَّا أَسْ: ’\add أَ\add* أَمْسخَّارْ أَعفَّانْ أَمعْڭُوزْ، أَقَا ثسّْنذْ بلِّي أَقَا مْجَارغْ مَانِي وَارْ زَارْعغْ ؤُ يَارْوغْ مَانِي وَارْ سَّارْوثغْ.
\v 27 خنِّي مْڒِي ثِيوْيذْ نُّوقَارْثْ إِنُو غَارْ ڒْبَانْكُو، خنِّي نشّْ، خْمِي د غَا يَاسغْ، أَذْ تَّارغْ مِينْ إِدْجَانْ إِنُو س أَرِّيبَا.
\v 28 س ؤُيَا كّْسمْ أَسْ ثَالِينْثْ نِّي، أوْشْ إِ-ت إِ ونِّي غَارْ إِدْجَاعشْرَا ثَالِينْثْ!‘
\v 29 مِينْزِي إِ كُوڒْ إِجّنْ ونِّي غَارْ إِدْجَا أَذْ أَسْ إِمّوْشْ ؤُشَا أَذْ غَارسْ يِيڒِي س وَاطَّاسْ، مَاشَا ونِّي وَارْ غَارْ إِدْجِي، ؤُڒَا ذ مِينْ غَارسْ أَذْ أَسْ إِتّْوَاكّسْ. \x ◘ \xo 25:‏29 \xt مت. 13‏:‏12؛ مك. 4‏:‏25؛ لك. 8‏:‏18؛ 19‏:‏26. \x*
\v 30 نْضَارمْ أَمْسخَّارْ إِبطّْڒنْ غَارْ بَارَّا ذڭْ ؤُنڭَّارْ ن ثَادْجسْثْ مَانِي غَا إِڒِينْ إِمطَّاونْ ذ ؤُغزِّي ن ثغْمَاسْ.“ \x ◘ \xo 25:‏30 \xt مت. 8‏:‏12؛ 13‏:‏42؛ 22‏:‏13؛ 24‏:‏51؛ لك. 13‏:‏28. \x*
\b
\s1 ڒْحُوكْمْ ن مِّيسْ ن بْنَاذمْ خْ إِحُوڒِييّنْ ؤُ خْ إِغَايْضنْ
\m 
\v 31 ”خْمِي د غَا يَاسْ مِّيسْ ن بْنَاذمْ ذڭْ ؤُعُودْجِي نّسْ ؤُ مَارَّا لْمَالَاكَاثْ نّسْ إِقدّْسنْ أَكِيذسْ، خنِّي أَذْ إِقِّيمْ خْ ڒْعَارْشْ ن ؤُعُودْجِي نّسْ. \x ◘ \xo 25:‏31 \xt مت. 16‏:‏27؛ 26‏:‏64؛ مك. 14‏:‏62؛ لك. 21‏:‏27؛ ڒخ. 1‏:‏11؛ 1 تس. 4‏:‏16؛ 2 تس. 1‏:‏10؛ أَسَا. 1‏:‏7. \x*
\v 32 أَذْ سّْمُوننْ مَارَّا ڒڭْنُوسْ قِيبَاتْشْ نّسْ ؤُشَا نتَّا أَذْ ثنْ إِمْسّبْضَا أَمْ مَامّشْ أَمكْسَاوْ إِسّْبطَّا إِحُوڒِييّنْ خْ إِغَايْضنْ. \x ◘ \xo 25:‏32 \xt حِز. 34‏:‏17، 20؛ مت. 13‏:‏49. \x*
\v 33 نتَّا أَذْ إِڭّْ إِحُوڒِييّنْ خْ ؤُفُوسِي نّسْ، مَاشَا إِغَايْضنْ خْ ؤُزڒْمَاضْ نّسْ.
\m 
\v 34 ڒخْذنِّي أَذْ إِنِي ؤُجدْجِيذْ إِ يِينِّي خْ ؤُفُوسِي نّسْ: ’أَسمْ-د، \add أَ\add* كنِّيوْ إِنِّي إِتّْوَابَارْكنْ زِي بَابَا، وَارْثمْ ثَاڭلْذِيثْ إِ ذ أَومْ د-إِوجْذنْ زڭْ وَامِي ثتّْوَاڭّْ دُّونشْثْ. \x ◘ \xo 25:‏34 \xt مت. 20‏:‏23؛ مك. 10‏:‏40. \x*
\v 35 مِينْزِي ثُوغَا ذَايِي ڒَاژْ ؤُشَا كنِّيوْ ثسّشّمْ أَيِي. ثُوغَا فُّوذغْ، ثوْشِيمْ أَيِي أَذْ سْوغْ. ثُوغَا أَيِي ذ أَبَارَّانِي، كنِّيوْ ثسّْزذْغمْ أَيِي، \x ◘ \xo 25:‏35 \xt إِشا. 58‏:‏7؛ حِز. 18‏:‏7؛ عبر. 13‏:‏2. \x*
\v 36 ثُوغَا أَيِي ذ أَعَارْيَانْ، كنِّيوْ ثسّْيَارْضمْ أَيِي، ثُوغَا هڒْشغْ، كنِّيوْ ثسِّيجمْ-د خَافِي، ثُوغَا أَيِي ذِي ڒحْبسْ، كنِّيوْ ثُوسِيمْ-د غَارِي.‘ \x ◘ \xo 25:‏36 \xt إِشا. 58‏:‏7؛ 2 تِيم. 1‏:‏16؛ يَاع. 2‏:‏15، 16. \x*
\m 
\v 37 خنِّي أَذْ خَاسْ د-أَرّنْ إِمْسڭَّاذنْ، قَّارنْ: ’أَ سِيذِيثْنغْ، مڒْمِي شكْ نژْرَا ثْدْجُوژذْ ؤُشَا نسّشّْ إِ شكْ، نِيغْ \add مڒْمِي شكْ نژْرَا\add* ثفُّوذذْ ؤُشَا نوْشْ أَشْ أَذْ ثسْوذْ؟
\v 38 مڒْمِي شكْ نژْرَا ذ أَبَارَّانِي ؤُشَا نسّزْذغْ إِ شكْ، نِيغْ ذ أَعَارْيَانْ ؤُشَا نسّْيَارْضْ إِ شكْ؟
\v 39 مڒْمِي شكْ نژْرَا ثْهڒْشذْ نِيغْ ذِي ڒحْبسْ ؤُشَا نُوسَا-د غَاركْ؟‘
\m 
\v 40 أَذْ د-يَارّْ ؤُجدْجِيذْ، أَذْ أَسنْ يِينِي: ’س ثِيذتّْ، نشّْ أَذْ أَومْ إِنِيغْ، مِينْ إِ ثڭِّيمْ إِ يِيجّنْ زڭْ وَاوْمَاثنْ إِمژْيَاننْ إِنُو، إِ نشّْ ؤُمِي ث ثڭِّيمْ.‘ \x ◘ \xo 25:‏40 \xt أَوڒن. 19‏:‏17؛ مت. 10‏:‏42؛ مك. 9‏:‏41؛ يُوح. 13‏:‏20؛ 2 كُور. 9‏:‏6. \x*
\m 
\v 41 ڒخْذنِّي أَذْ يِينِي إِ يِينِّي إِدْجَانْ خْ ؤُزڒْمَاضْ نّسْ: ’بعّْذمْ خَافِي، أَ كنِّيوْ إِنِّي إِتّْوَانعْڒنْ، غَارْ ثْمسِّي ن ڒبْذَا إِ إِوجْذنْ إِ إِبْڒِيسْ ذ لْمَالَاكَاثْ نّسْ. \x ◘ \xo 25:‏41 \xt إِزهد. 6‏:‏9؛ إِشا. 30‏:‏33؛ مت. 7‏:‏23؛ لك. 13‏:‏25، 27؛ أَسَا. 19‏:‏20. \x*
\v 42 مِينْزِي ثُوغَا ذَايِي ڒَاژْ وَارْ ذ أَيِي ثسّشّمْ، فُّوذغْ وَارْ ذ أَيِي ثوْشِيمْ أَذْ سْوغْ.
\v 43 ثُوغَا أَيِي ذ أَبَارَّانِي، كنِّيوْ وَارْ ذ أَيِي ثسّْزذْغمْ، ثُوغَا أَيِي ذ أَعَارْيَانْ، وَارْ ذ أَيِي ثسّْيَارْضمْ، هڒْشغْ ؤُ تّْوَاحبْسغْ وَارْ خَافِي د-ثسِّيجمْ شَا.‘
\m 
\v 44 ڒخْذنِّي ؤُڒَا ذ نِيثْنِي أَذْ \add خَاسْ\add* د-أَرّنْ، أَذْ إِنِينْ: ’أَ سِيذِيثْنغْ، مڒْمِي شكْ نژْرَا ثدْجُوژذْ نِيغْ ثفُّوذذْ نِيغْ ذ أَبَارَّانِي نِيغْ ذ أَعَارْيَانْ نِيغْ ثْهڒْشذْ نِيغْ ذِي ڒحْبسْ، خنِّي نشِّينْ وَارْ خَاكْ نْسخَّارْ شَا؟‘
\v 45 خنِّي أَذْ خَاسنْ د-يَارّْ، أَذْ يِينِي: ’س ثِيذتّْ، نشّْ أَذْ أَومْ إِنِيغْ: مِينْ وَارْ ثڭِّيمْ إِ يِيجّنْ زڭْ إِمژْيَاننْ إِنُو، إِ نشّْ ؤُمِي وَارْ ث ثڭِّيمْ عَاوذْ.‘ \x ◘ \xo 25:‏45 \xt أَوڒن. 14‏:‏31؛ 17‏:‏5؛ زَاك. 2‏:‏12. \x*
\v 46 أَذْ رَاحنْ نِيثْنِي غَارْ ڒعْذَابْ إِتّْذُومَانْ، مَاشَا إِمْسڭَّاذنْ غَارْ ثُوذَارْثْ إِتّْذُومَانْ.“ \x ◘ \xo 25:‏46 \xt دَان. 12‏:‏2؛ يُوح. 5‏:‏29. \x*
\b
\b
\c 26
\s1 ثَامعْمُوتْشْ ن وُوذَاينْ مَاحنْذْ أَذْ نْغنْ يَاسُوع
\m 
\v 1 أَوَارْنِي ڒَامِي إِكمّڒْ يَاسُوع أَوَاڒنْ-أَ، إِنَّا إِ إِمحْضَارنْ نّسْ: \x ◘ \xo 26:‏1 \xt [مك. 14‏:‏1‏-‏2؛ لك. 22‏:‏1‏-‏2؛ يُوح. 11‏:‏45‏-‏53] \x*
\v 2 ”ثسّْنمْ بلِّي أَوَارْنِي ثْنَاينْ ن وُوسَّانْ أَذْ ثِيڒِي \add ڒْْعِيذْ ن ثْغَارْصْثْ ن\add* ؤُسعْذُو ؤُ ڒخْذنِّي أَذْ إِمّوْشْ مِّيسْ ن بْنَاذمْ، حِيمَا أَذْ إِتّْوَاصلّبْ.“ \x ◘ \xo 26:‏2 \xt مك. 14‏:‏1؛ لك. 22‏:‏1؛ يُوح. 13‏:‏1\x*
\v 3 ڒخْذنِّي مُوننْ إِمقّْرَاننْ ن إِكهَّاننْ ذ إِمْسڒْمَاذنْ ن إِذْلِيسنْ ذ إِمْغَارنْ ن ڒْڭنْسْ ذِي ڒمْرَاحْ ن أَرَّايْسْ ن إِكهَّاننْ، ونِّي ؤُمِي قَّارنْ قَايَافَا، \x ◘ \xo 26:‏3 \xt إِزهد. 2‏:‏2؛ يُوح. 11‏:‏47؛ ڒخ. 4‏:‏27. \x*
\v 4 ؤُشَا مْشَاوَارنْ مَامّشْ غَا طّْفنْ يَاسُوع س ثحْرَايْمشْثْ ؤُشَا أَذْ ث نْغنْ،
\v 5 نَّانْ: ”وَارْ إِتِّيڒِي ذِي ڒْعِيذْ حِيمَا وَارْ إِتّكَّارْ ؤُغوّغْ ذِي ڒْڭنْسْ.“
\b
\s1 أَذْهَانْ ن يَاسُوع ذِي بَايْثْ-عَانْيَا
\m 
\v 6 ڒَامِي ثُوغَا يَاسُوع ذِي بَايْثْ-عَانْيَا، ذِي ثَادَّارْثْ ن شِيمْعُونْ، ونِّي ذِي إِدْجَا ڒْبَارْصْ، \x ◘ \xo 26:‏6 \xt [مك. 14‏:‏3‏-‏9؛ يُوح. 12‏:‏1‏-‏8] \x*
\v 7 ثُوسَا-د غَارسْ إِشْثْ ن ثمْغَارْثْ س إِجّْ ن ؤُغَارَّافْ ن أَلَابَاسْثرْ إِشُّورْ س إِشْثْ ن زّشْثْ إِ وذْهَانْ إِغْڒَانْ، ؤُشَا ثْفَارّغْ إِ-ت خْ ؤُزدْجِيفْ نّسْ أَمْ إِقِّيمْ يَاسُوع \add غَارْ طَّابْڒَا\add*. \x ◘ \xo 26:‏7 \xt مك. 14‏:‏3؛ لك. 7‏:‏37؛ يُوح. 11‏:‏2؛ 12‏:‏3. \x*
\m 
\v 8 ؤُمِي ژْرِينْ إِمحْضَارنْ مَانْ أَيَا، إِقّسْ أَسنْ ڒْحَاڒْ أَطَّاسْ، نَّانْ: ”مِينْ ؤُمِي ثدْجَا ثْخسَّارْثْ-أَ؟
\v 9 ثُوغَا إِزمَّارْ أَذْ ثمّنْزْ \add زّشْثْ-أَ ن وذْهَانْ\add* س تَّامَانْ ذ أَمقّْرَانْ، ؤُشَا \add خنِّي\add* أَذْ ثمّوْشْ إِ إِمزْڒَاضْ.“
\v 10 مَاشَا يَاسُوع ثُوغَا إِسّنْ مَانْ أَيَا، إِنَّا: ”مَايمِّي ثْزِييَّارمْ خْ ثمْغَارْثْ-أَ، مِينْزِي نتَّاثْ ثڭَّا أَيِي إِشْثْ ن ڒْخذْمثْ ثصْبحْ.
\v 11 مِينْزِي إِمزْڒَاضْ أَقَا أَثنْ ڒبْذَا أَكِيذْومْ، مَاشَا نشّْ وَارْ كِيومْ تِّيڒِيغْ إِ ڒبْذَا. \x ◘ \xo 26:‏11 \xt أَعَوذ. 15‏:‏11؛ مك. 14‏:‏7؛ يُوح. 12‏:‏8. \x*
\v 12 مِينْزِي نتَّاثْ، مَاڒَا ثْفَارّغْ-د \add زّشْثْ-أَ إِ\add* وذْهَانْ خْ أَرِّيمثْ إِنُو، أَقَا ثڭَّا مَانْ أَيَا إِ ؤُسوْجذْ ن ونْضڒْ إِنُو.
\v 13 س ثِيذتّْ، نشّْ أَذْ أَومْ إِنِيغْ: مَانِي مَا إِ غَا إِتّْوَابَارّحْ زِي ڒخْبَارْ-أَ أَصبْحَانْ خَافِي ذِي مَارَّا دُّونشْثْ، أَذْ سِّيوْڒنْ عَاوذْ خْ مِينْ \add ذَايِي\add* ثڭَّا، ذ ڒِيضَارثْ إِ نتَّاثْ.“
\b
\s1 يَاهُوذَا إِزّنْزْ إِخفْ نّسْ مَاحنْذْ أَذْ إِسلّمْ يَاسُوع
\m 
\v 14 ڒخْذنِّي إِڒُوحْ إِجّنْ زِي ثنْعَاشْ، قَّارنْ أَسْ يَاهُوذَا إِسْخَارِييُوطِي، غَارْ إِمقّْرَاننْ ن إِكهَّاننْ، \x ◘ \xo 26:‏14 \xt مك. 14‏:‏10؛ لك. 22‏:‏4. \x*
\v 15 إِنَّا: ”مِينْ ذ أَيِي غَا ثوْشمْ مَاحنْذْ أَذْ أَومْ سلّْمغْ يَاسُوع؟“ ؤُشَا وَاعْذنْ \add ث\add* س ثْڒَاثِينْ \add ن ڒْوزْنَاثْ\add* ن نُّوقَارْثْ. \x ◘ \xo 26:‏15 \xt زَاك. 11‏:‏12. \x*
\v 16 سّنِّي ثُوغَا يَارزُّو إِشْثْ ن ثوَّارْثْ حِيمَا أَذْ ث إِسلّمْ.
\b
\s1 أَمنْسِي ن ثْغَارْصْثْ ن ؤُسعْذُو
\m 
\v 17 ذڭْ وَاسّْ أَمزْوَارُو ن \add وغْرُومْ\add* بْڒَا أَنْثُونْ، ؤُسِينْ-د إِمحْضَارنْ غَارْ يَاسُوع، نَّانْ: ”مَانِي ثخْسذْ أَذْ نسّوْجذْ إِ شكْ مَاحنْذْ أَذْ ثشّذْ \add أَمنْسِي ن\add* ؤُسعْذُو؟“ \x ◘ \xo 26:‏17 \xt [مك. 14‏:‏21‏-‏22؛ لك. 22‏:‏7‏-‏14، 21‏-‏23؛ يُوح. 13‏:‏21‏-‏30] — ؤُف. 12‏:‏17؛ \x*
\v 18 إِنَّا أَسنْ: ”ؤُيُورمْ غَارْ ثنْذِينْثْ غَارْ إِجّْ ن فْڒَانْ، إِنِيمْ أَسْ: ’أَمْسڒْمَاذْ نّغْ إِقَّارْ: أَقَا ڒْوقْثْ إِنُو ثِيوضْ-د، أَذْ غَاركْ ڭّغْ \add أَمنْسِي ن\add* ؤُسعْذُو أَكْ-ذ إِمحْضَارنْ إِنُو.‘ “
\v 19 إِمحْضَارنْ ڭِّينْ أَمْ مَامّشْ ثنْ إِوصَّا يَاسُوع ؤُشَا سّوْجْذنْ إِ \add ؤُمنْسِي ن\add* ؤُسعْذُو.
\v 20 ڒَامِي د-ثِيوضْ ثْمذِّيثْ، إِقِّيمْ \add غَارْ ؤُمنْسِي\add* أَكْ-ذ ثنْعَاشْ \add ن إِمحْضَارنْ نّسْ\add*. \x ◘ \xo 26:‏20 \xt مك. 14‏:‏17؛ لك. 22‏:‏14؛ يُوح. 13‏:‏21. \x*
\v 21 أَمْ تّتّنْ نِيثْنِي، إِنَّا: ”س ثِيذتّْ، نشّْ أَذْ أَومْ إِنِيغْ، إِجّنْ زَّايْومْ أَذْ أَيِي إِغْذَارْ.“ \x ◘ \xo 26:‏21 \xt ڒخ. 1‏:‏17. \x*
\v 22 نِيثْنِي ذوْڒنْ شضْننْ أَطَّاسْ ؤُشَا كُوڒْ إِجّنْ زَّايْسنْ إِبْذَا أَذْ أَسْ يِينِي: ”مَا وَارْ إِدْجِي ذ نشّْ، أَ سِيذِي؟“
\v 23 يَارَّا-د خَاسنْ، إِنَّا: ”ونِّي إِسِّيسْننْ أَفُوسْ أَكِيذِي ذِي طّبْصِي ذ نتَّا إِ ذ أَيِي غَا إِغْذَارنْ. \x ◘ \xo 26:‏23 \xt إِزهد. 41‏:‏10؛ لك. 22‏:‏21؛ يُوح. 13‏:‏18. \x*
\v 24 مِّيسْ ن بْنَاذمْ أَذْ إِرَاحْ أَمْ مَامّشْ خَاسْ ثُورَا، مَاشَا ؤُشْثْ خْ بْنَاذمْ نِّي إِ غَا إِغْذَارنْ مِّيسْ ن بْنَاذمْ. إِحْڒَا أَسْ إِ بْنَاذمْ نِّي وَارْ د-إِخْڒِيقْعمَّارْصْ.“
\v 25 يَاهُوذَا، أَغدَّارْ، يَارَّا-د، إِنَّا: ”مَا وَارْ إِدْجِي ذ نشّْ، \add أَ\add* أَمْسڒْمَاذْ إِنُو؟“ نتَّا إِنَّا أَسْ: ”أَقَا شكْ ثنِّيذْ \add ث\add*.“
\b
\s1 أَمنْسِي ن سِيذِيثْنغْ
\m 
\v 26 أَمْ ثُوغَا تّتّنْ، إِكْسِي يَاسُوع أَغْرُومْ ؤُ أَوَارْنِي ڒَامِي إِبَاركْ، يَارْژَا \add إِ-ث\add*، إِوْشَا \add إِ-ث\add* إِ إِمحْضَارنْ، إِنَّا: ”كْسِيمْ، شّمْ، ثَا ذ أَرِّيمثْ إِنُو.“ \x ◘ \xo 26:‏26 \xt [مك. 14‏:‏22‏-‏26؛ لك. 22‏:‏15‏-‏20؛ 1 كُور. 11‏:‏23‏-‏25] — إِرْم. 16‏:‏7\x*
\v 27 إِكْسِي ڒْكَاسْ، إِقَاذَا ؤُشَا إِوْشَا أَسنْ ث، إِنَّا: ”سْومْ زَّايسْ مَارَّا إِذْومْ،
\v 28 مِينْزِي وَا ذ إِذَامّنْ إِنُو ن ڒْعَاهْذْ ن جْذِيذْ إِنِّي إِ غَا إِتّْوَاسِّيزْڒنْ إِ وغْفَارْ ن دّْنُوبْ. \x ◘ \xo 26:‏28 \xt ؤُف. 24‏:‏8؛ إِرْم. 31‏:‏31؛ مت. 26‏:‏28، مك. 14‏:‏24، لك. 22‏:‏20، 1 كُور. 11‏:‏25، 2 كُور. 3‏:‏6، عبر. 8‏:‏6، 8، 13؛ 9‏:‏15؛ 12‏:‏24\x*
\v 29 نشّْ أَذْ أَومْ إِنِيغْ، زِي ڒخُّو ثْسَاونْثْ وَارْ سسّغْ عَاذْ زِي ڒْغِيدْجثْ ن ثْزَايَارْثْ أَڒْ أَسّْ إِ ذِي ت غَا سْوغْ زِي جْذِيذْ أَكِيذْومْ ذِي ثْڭلْذِيثْ ن بَابَا.“
\v 30 ؤُ \add أَوَارْنِي ڒَامِي\add*غنّْجنْ إِزْڒِي ن تّسْبِيحْ، فّْغنْ غَارْ وذْرَارْ ن زِّيثُونْ. \x ◘ \xo 26:‏30 \xt مك. 14‏:‏26؛ لك. 22‏:‏39؛ يُوح. 18‏:‏1. \x*
\b
\s1 يَاسُوع إِزْوَارْ إِسِّيوڒْ خْ ونْكَارْ زِي بُوطْرُوسْ
\m 
\v 31 خنِّي إِنَّا أَسنْ يَاسُوع: ”مَارَّا كنِّيوْ أَذْ ذَايِي ثنْذرْفمْ ذِي دْجِيڒثْ-أَ، مِينْزِي أَقَا ثُورَا: ’أَذْ وْثغْ أَمكْسَاوْ، ؤُشَا إِحُوڒِييّنْ ن ثْحِيمَارْثْ أَذْ تّْوَازُوزَّارنْ.‘ \x ◘ \xo 26:‏31 \xt [مك. 14‏:‏27‏-‏31؛ لك. 22‏:‏31‏-‏34؛ يُوح. 13‏:‏36‏-‏38] — زَاك. 13‏:‏7؛ يُوح. 16‏:‏32؛ \x*
\v 32 مَاشَا أَوَارْنِي ڒَامِي إِ د غَا تّْوَاسّْنكَّارغْ، أَذْ أَومْ إِزْوَارغْ غَارْ لْجَالِيلْ.“ \x ◘ \xo 26:‏32 \xt مك. 14‏:‏28؛ 16‏:‏7. \x*
\v 33 \add مَاشَا\add* بُوطْرُوسْ يَارَّا-د، إِنَّا أَسْ: ”مَاڒَا ذَايكْ إِ غَا نْذرْفنْ مَارَّا، نشّْ وَارْ ذَايكْ تّنْذْرِيفغْ شَاعمَّارْصْ!“ \x ◘ \xo 26:‏33 \xt لك. 22‏:‏33. \x*
\v 34 إِنَّا أَسْ يَاسُوع: ”س ثِيذتّْ، نشّْ أَذْ أَشْ إِنِيغْ، ذِي دْجِيڒثْ-أَ، قْبڒْ إِ غَا إِسّْقُوقعْ ؤُيَاژِيضْ، أَذْ أَيِي ثنْكَارذْ ثْڒَاثَا ن ثْوَاڒَاوِينْ.“ \x ◘ \xo 26:‏34 \xt يُوح. 13‏:‏38. \x*
\v 35 بُوطْرُوسْ إِنَّا أَسْ: ”وَاخَّا ثُوغَا إِتّْخصَّا أَيِي أَذْ مّْثغْ أَكِيذكْ، نشّْ وَارْ شكْ نكَّارغْعمَّارْصْ.“ أَمُّو إِ نَّانْ مَارَّا إِمحْضَارنْ عَاوذْ.
\b
\s1 ثَاژَادْجِيثْ ن يَاسُوع ذڭْ وحْوِيشْ ن خِيثْسِيمَانِييْ
\m 
\v 36 ڒخْذنِّي إِرُوحْ يَاسُوع أَكِيذْسنْ غَارْ إِجّْ ن ومْشَانْ قَّارنْ أَسْ خِيثْسِيمَانِييْ، إِنَّا إِ إِمحْضَارنْ نّسْ: ”قِّيممْ ذَانِيثَا، أَمْ إِ غَا ژَّادْجغْ \add ذِينْ\add*.“ \x ◘ \xo 26:‏36 \xt [مك. 14‏:‏32‏-‏42؛ لك. 22‏:‏39‏-‏46] — يُوح. 18‏:‏1. \x*
\v 37 أَمْ كِيسْ يِيوِي بُوطْرُوسْ ذ ثْنَاينْ ن إِحنْجِيرنْ ن زَابْذِي، إِبْذَا إِتّْنخْڒَاعْ، إِڭّْوذْ أَطَّاسْ.
\v 38 خنِّي إِنَّا أَسنْ: ”ڒعْمَارْ إِنُو إِسّْحِيسِّيفْ أَطَّاسْ أَڒْ ڒْموْثْ. قِّيممْ ذَا، حْضَامْ أَكِيذِي.“ \x ◘ \xo 26:‏38 \xt إِزهد. 69‏:‏2‏-‏4؛ يُوح. 12‏:‏27. \x*
\v 39 \add خنِّي\add* إِعْزڒْ شْوَايْثْ كْثَارْ، إِوْضَا خْ ؤُغمْبُوبْ نّسْ، إِتّْژَادْجْ، إِنَّا: ”أَ بَابَا، مَاڒَا إِعدّڒْ، أجّْ أَذْ خَافِي إِعْذُو ڒْكَاسْ-أَ! مَاشَا وَارْ إِتِّيڒِي أَمْ مَامّشْ خْسغْ نشّْ، مَاشَا أَمْ مَامّشْ \add ثخْسذْ\add* شكْ.“ \x ◘ \xo 26:‏39 \xt مت. 20‏:‏22، 23؛ مك. 14‏:‏35؛ لك. 22‏:‏42؛ يُوح. 6‏:‏38. \x*
\v 40 \add ڒخْذنِّي\add* إِذْوڒْ-د غَارْ إِمحْضَارنْ نّسْ ؤُشَا يُوفَا إِ-ثنْ طّْصنْ. إِنَّا إِ بُوطْرُوسْ: ”مَا وَارْ ثْزمَّارمْ أَذْ كِيذِي ثحْضَامْ ؤُڒَا ذ إِشْثْ ن ثْسَاعّثْ؟
\v 41 حْضَامْ، ژَّادْجمْ، حِيمَا وَارْ د-ثتِّيذْفمْ ذڭْ ؤُجَارّبْ. أَرُّوحْ أَقَا إِوْجذْ، مَاشَا دَّاثْ ثضْعفْ.“ \x ◘ \xo 26:‏41 \xt ڭال. 5‏:‏17. \x*
\m 
\v 42 يُويُورْ عَاوذْ إِ ؤُمُورْ وِيسّْ ثْنَاينْ ؤُشَا إِژُّودْجْ، إِنَّا: ”أَ بَابَا، مَاڒَا ڒْكَاسْ-أَ وَارْ إِزمَّارْ أَذْ خَافِي يكّْ مْغِيرْ مَاڒَا نشّْ سْوِيغْ ث، أَقَا أَذْ يِيڒِي مِينْ ثخْسذْ شكْ!“
\v 43 ڒَامِي د-إِذْوڒْ، يُوفَا إِ-ثنْ عَاوذْ طّْصنْ، مِينْزِي ثِيطَّاوِينْ نْسنْ ثُوغَا ضقّْڒنْثْ.
\m 
\v 44 إِجَّا إِ-ثنْ، يُويُورْ عَاوذْ ؤُشَا إِژُّودْجْ إِ ثْوَاڒَا وِيسّْ ثْڒَاثَا، إِقَّارْ أَوَاڒنْ-أَ عَاوذْ.
\v 45 ڒخْذنِّي إِذْوڒْ-د غَارْ إِمحْضَارنْ نّسْ، إِنَّا أَسنْ: ”كمّْڒمْ خْ يِيضصْ نْومْ ڒخُّو، أَريّْحمْ. خْزَارمْ، أَقَا ثْسَاعّثْ ثِيوضْ-د أَقَا مِّيسْ ن بْنَاذمْ أَذْ إِمّوْشْ ذڭْ إِفَاسّنْ ن إِمذْنَابْ.
\v 46 كَّارمْ، أَذْ نْرَاحْ. خْزَارمْ، ونِّي ذ أَيِي غَا إِغْذَارنْ، يُوذسْ-د.“
\b
\s1 ؤُضُوفْ ن يَاسُوع
\m 
\v 47 أَمْ ثُوغَا إِسَّاوَاڒْ عَاذْ، يُوسَا-د يَاهُوذَا، أَغدَّارْ، إِجّنْ زِي ثنْعَاشْ، أَكْ-ذ إِجّْ ن ڒْغَاشِي أَمقّْرَانْ س ڒسْيُوفْ ذ إِعُومَاذْ، ؤُسِينْ-د زڭْ إِمقّْرَاننْ ن إِكهَّاننْ ذ إِمْغَارنْ ن ڒْڭنْسْ. \x ◘ \xo 26:‏47 \xt [مك. 14‏:‏43‏-‏50؛ لك. 22‏:‏47‏-‏53؛ يُوح. 18‏:‏3‏-‏12] \x*
\v 48 يَاهُوذَا، أَغدَّارْ، أَقَا إِوْشَا أَسنْ إِشْثْ ن ڒعْڒَامثْ، إِنَّا: ”ونِّي إِ غَا سُّوذْمغْ ذ ونِّي نتَّا، طّْفمْ ث.“
\v 49 ڒخْذنِّي د-إِقَارّبْ غَارْ يَاسُوع، إِنَّا: ”سْڒَامْ خَاكْ، \add أَ\add* أَمْسڒْمَاذْ إِنُو!“، ؤُشَا إِسُّوذمْ إِ-ث.
\v 50 \add خَاسْ ؤُشَا\add* يَاسُوع إِنَّا أَسْ: ”\add أَ\add* أَمدُّوكّڒْ إِنُو، مِينْ خفْ د-ثُوسِيذْ ذَا؟“ ڒخْذنِّي قَارّْبنْ-د \add غَارسْ\add*، حَارْثنْ خْ يَاسُوع ؤُشَا طّْفنْ ث.
\v 51 ؤُ خْزَارْ، إِجّنْ زڭْ إِنِّي إِدْجَانْ أَكْ-ذ يَاسُوع، إِسّْوِيژّضْ أَفُوسْ نّسْ، إِجْبذْ سِّيفْ ؤُشَا إِوْثَا أَمْسخَّارْ ن أَرَّايْسْ ن إِكهَّاننْ، إِقسّْ أَسْ أَمزُّوغْ.
\v 52 خنِّي إِنَّا أَسْ يَاسُوع: ”أَرّْ سِّيفْ غَارْ ومْشَانْ نّسْ، مِينْزِي مَارَّا إِنِّي إِكسِّينْ سِّيفْ أَذْ مّْثنْ س سِّيفْ.
\v 53 نِيغْ إِتّْغِيڒْ أَشْ بلِّي نشّْ وَارْ زمَّارغْ أَذْ ژَّادْجغْ إِ بَابَا، أَقَا نتَّا أَذْ ذ أَيِي د-إِسّكّْ ڒخُّو كْثَارْ زِي ثنْعَاشْ ن إِلِيخِييُوننْ ن لْمَالَاكَاثْ؟ \f ◼ \fr 26:‏53 \ft \bd ’ثنْعَاشْ ن إِلِيخِييُوننْ‘\bd* - مَانْ أَيَا إِخْسْ أَذْ يِينِي عْڒَاحَاڒْ ستَّا أَڒَافْ ن لْمَالَاكَاثْ.\f*
\v 54 مَامّشْ خنِّي إِ غَا تّْوَاكمّْڒنْثْ ثِيرَا \add إِقدّْسنْ\add* \add إِ إِقَّارنْ\add* بلِّي إِتّْخصَّا أَذْ إِمْسَارْ أَمُّو؟“ \x ◘ \xo 26:‏54 \xt إِزهد. 22‏:‏7؛ 69‏:‏2، 10؛ لك. 24‏:‏25. \x*
\m 
\v 55 ذِي ثْسَاعّثْ نِّي عَاوذْ إِسِّيوڒْ يَاسُوع أَكْ-ذ ڒْغَاشِي: ”أَخْمِي خْ إِجّْ ن ؤُقْطَاطْعِييْ إِ د-ثفّْغمْ س ڒسْيُوفْ ذ إِعُومَاذْ مَاحنْذْ أَذْ أَيِي ثطّْفمْ. كُوڒْ أَسّْ ثُوغَا قِّيمغْ غَارْومْ، سّڒْمَاذغْ ذِي زَّاوشْثْ ثَامقّْرَانْثْ، وَارْ ذَايِي ثطِّيفمْ.
\v 56 مَاشَا مَانْ أَيَا مَارَّا إِمْسَارْ، حِيمَا أَذْ تّْوَاكمّْڒنْثْ ثِيرَا ن إِنَابِييّنْ.“ ڒخْذنِّي سمْحنْ ذَايسْ مَارَّا إِمحْضَارنْ ؤُشَا أَروْڒنْ. \x ◘ \xo 26:‏56 \xt أَيُوبْ 19‏:‏13؛ إِزهد. 88‏:‏9. \x*
\b
\s1 يَاسُوع زَّاثْ إِ جْمَاعثْ ثَامقّْرَانْثْ ن وُوذَاينْ
\m 
\v 57 إِنِّي إِطّْفنْ يَاسُوع، إِوْينْ ث غَارْ قَايَافَا، أَرَّايْسْ ن إِكهَّاننْ، ونِّي غَارْ ثُوغَا مُوننْ إِمْسڒْمَاذنْ ن إِذْلِيسنْ ذ إِمْغَارنْ \add ن ڒْڭنْسْ\add*. \x ◘ \xo 26:‏57 \xt [مك. 14‏:‏53‏-‏65؛ لك. 22‏:‏54‏-‏55، 63‏-‏71؛ يُوح. 18‏:‏13‏-‏14، 19‏-‏24] \x*
\v 58 شِيمْعُونْ بُوطْرُوسْ إِضْفَارْ إِ-ث-إِ-د زِي ڒَاڭّْوَاجْ أَڒَامِي ذ يِيوضْ غَارْ ڒمْرَاحْ ن أَرَّايْسْ ن إِكهَّاننْ ؤُ ڒَامِي يُوذفْ، إِقِّيمْ جَارْ إِعسَّاسنْ حِيمَا أَذْ إِژَارْ مَامّشْ إِ غَا ثفّغْ.
\v 59 إِمقّْرَاننْ ن إِكهَّاننْ ذ إِمْغَارنْ \add ن ڒْڭنْسْ\add* ؤُ مَارَّا جْمَاعثْ \add ثَامقّْرَانْثْ\add*، ثُوغَا أَرزُّونْ إِشهَّاذنْ إِسّْخَارِّيقنْ خْ يَاسُوع، مَاحنْذْ أَذْ ث نْغنْ. \x ◘ \xo 26:‏59 \xt مك. 14‏:‏55؛ ڒخ. 6‏:‏13. \x*
\v 60 مَاشَا وَارْ زمَّارنْ أَذْ ت أَفنْ، وَاخَّا ؤُسِينْ-د أَطَّاسْ ن ڒشْهُوذْ إِسّْخَارِّيقنْ. غَارْ ؤُنڭَّارْ ؤُسِينْ-د ثْنَاينْ
\v 61 إِ إِنَّانْ: ”وَا أَقَا إِنَّا: ’نشّْ زمَّارغْ أَذْ هذْمغْ زَّاوشْثْ ثَامقّْرَانْثْ ن أَربِّي ؤُ ذِي ثْڒَاثَا ن وُوسَّانْ أَذْ ت بْنِيغْ \add عَاوذْ\add*.‘ “ \x ◘ \xo 26:‏61 \xt يُوح. 2‏:‏19. \x*
\v 62 أَرَّايْسْ ن إِكهَّاننْ إِكَّارْ-د، إِنَّا أَسْ: ”مَا وَارْ د-ثَارِّيذْ س وَالُو؟ مِينْ خَاكْ شهّْذنْ إِنَا؟“ \x ◘ \xo 26:‏62 \xt مك. 14‏:‏60. \x*
\m 
\v 63 مَاشَا يَاسُوع إِسْقَارْ. إِنَّا أَسْ أَرَّايْسْ ن إِكهَّاننْ: ”نشّْ أَذْ شكْ جّغْ أَذْ ثجَّادْجذْ س أَربِّي إِدَّارنْ، بلِّي شكْ أَذْ أَنغْ ثِينِيذْ، مَا خنِّي شكْ ذ لْمَاسِيحْ، مِّيسْ ن أَربِّي؟“ \x ◘ \xo 26:‏63 \xt إِشا. 53‏:‏7؛ مت. 27‏:‏12، 14. \x*
\v 64 إِنَّا أَسْ يَاسُوع: ”شكْ ثنِّيذْ \add ث\add*. مَاشَا نشّْ أَذْ أَومْ إِنِيغْ: ’زِي سَّا ثْسَاونْثْ أَذْ ثْژَارمْ مِّيسْ ن بْنَاذمْ إِقِّيمْ خْ ؤُفُوسِي ن جّهْذْ خْمِي د غَا يَاسْ خْ إِسيْنُوثنْ ن ؤُجنَّا.“ \x ◘ \xo 26:‏64 \xt إِزهد. 110‏:‏1؛ دَان. 7‏:‏13؛ مت. 16‏:‏27؛ 24‏:‏30؛ مك. 14‏:‏62؛ لك. 22‏:‏69؛ ڒخ. 1‏:‏11؛ رُوم. 14‏:‏10؛ 1 تس. 4‏:‏16؛ أَسَا. 1‏:‏7. \x*
\m 
\v 65 ڒخْذنِّي إِشَارّڭْ أَرَّايْسْ ن إِكهَّاننْ أَرُّوضْ نّسْ، إِنَّا: ”نتَّا أَقَا إِشقّفْ \add ذِي أَربِّي\add*، مَايمِّي نحْذَاجْ عَاذْ ڒشْهُوذْ؟ خْزَارمْ، ڒخُّو أَقَا ثسْڒِيمْ إِ ؤُشقّفْ نّسْ.
\v 66 مِينْ ذ أَومْ إِتّْغِيڒْ كنِّيوْ؟“ نِيثْنِي أَرِّينْ-د خَاسْ، نَّانْ: ”نتَّا إِسْذَاهدْجْ ڒْموْثْ.“ \x ◘ \xo 26:‏66 \xt لَاوِي 24‏:‏16. \x*
\v 67 خنِّي بْذَانْ سُّوسُوفنْ \add أَسْ\add* خْ ؤُغمْبُوبْ، شَّاثنْ ث س ڒْپُونِييَّاثْ \add خْ ؤُزدْجِيفْ\add* ؤُ إِنّغْنِي وْثِينْ ث \add عَاوذْ\add*، \x ◘ \xo 26:‏67 \xt إِشا. 50‏:‏6. \x*
\v 68 نَّانْ: ”نَابّْ أَنغْ، \add أَ شكْ\add*، لْمَاسِيحْ، وِي شكْ إِوْثِينْ؟“ \x ◘ \xo 26:‏68 \xt أَيُوبْ 16‏:‏10؛ لك. 22‏:‏64؛ يُوح. 19‏:‏3. \x*
\b
\s1 أَنْكَارْ ن يَاسُوع زِي بُوطْرُوسْ
\m 
\v 69 بُوطْرُوسْ إِقِّيمْ غَارْ بَارَّا ذِي ڒمْرَاحْ. ثْقَارّبْ-د غَارسْ إِشْثْ ن ثَايَّا، ثنَّا: ”ؤُڒَا ذ شكْ ثُوغَا شكْ أَكْ-ذ يَاسُوع، زِي نَّاصِيرَا.“ \f ◼ \fr 26:‏69 \ft \bd ’زِي نَّاصِيرَا‘\bd* - إِخْسْ أَذْ يِينِي ’زِي ثنْذِينْثْ ن نَّاصِيرَا ذِي ثمُّورْثْ ن لْجَالِيلْ‘.\f*  \x ◘ \xo 26:‏69 \xt [مك. 14‏:‏66‏-‏72؛ لك. 22‏:‏56‏-‏62؛ يُوح. 18‏:‏15‏-‏18، 25‏-‏27] \x*
\v 70 مَاشَا نتَّا إِنْكَارْ زَّاثْ إِ مَارَّا، إِنَّا: ”وَارْ سِّينغْ مِينْ خفْ ثسَّاوَاڒذْ.“
\v 71 أَمْ إِڭُّورْ غَارْ ؤُسْقِيفْ ن ثوَّارْثْ، ثژْرَا إِ-ث إِشْثْ ن ثَايَّا نّغْنِي، ثنَّا أَسنْ إِ يِينِّي ذِينْ إِقِّيمنْ: ”ؤُڒَا ذ وَا ثُوغَا أَكْ-ذ يَاسُوع زِي نَّاصِيرَا.“
\v 72 نتَّا إِنْكَارْ عَاوذْ س إِشْثْ ن ثْجَادْجِيثْ، إِنَّا: ”وَارْ سِّينغْ بْنَاذمْ نِّي.“
\v 73 شْوَايْثْ غَارْ زَّاثْ قَارّْبنْ-د إِنِّي ذِينْ إِبدّنْ غَارْ بُوطْرُوسْ، نَّانْ: ”نِيشَانْ، ؤُڒَا ذ شكْ ذ إِجّنْ زَّايْسنْ، مِينْزِي ڒْهَارْذْ نّشْ إِسّْبيّنْ إِ شكْ.“
\v 74 خنِّي إِبْذَا إِنعّڒْ، إِتّْجَّادْجْ: ”نشّْ وَارْ سِّينغْ بْنَاذمْ نِّي.“ ڒخْذنِّي إِسّْقُوقعْ ؤُيَاژِيضْ
\v 75 ؤُشَا إِعْقڒْ بُوطْرُوسْ أَوَاڒْ إِ ذ أَسْ إِنَّا يَاسُوع: ”قْبڒْ إِ غَا إِسّْقُوقعْ ؤُيَاژِيضْ، أَذْ أَيِي ثنْكَارذْ ثْڒَاثَا ن ثْوَاڒَاوِينْ.“ ؤُشَا إِفّغْ، إِرُو س إِمطَّاونْ إِمرْزَاڭنْ. \x ◘ \xo 26:‏75 \xt مت. 26‏:‏34؛ مك. 14‏:‏30؛ لك. 22‏:‏61؛ يُوح. 13‏:‏38\x*
\b
\b
\c 27
\s1 أَنْذَامْ ن يَاهُوذَا ذ ڒْموْثْ نّسْ
\m 
\v 1 غَارْ صّْبحْ زِيشْ، أَقَا مَارَّا إِمقّْرَاننْ ن إِكهَّاننْ ذ إِمْغَارنْ ن ڒْڭنْسْ مْشَاوَارنْ خْ يَاسُوع، مَامّشْ إِ ث غَا نْغنْ. \x ◘ \xo 27:‏1 \xt [مك. 15‏:‏1؛ لك. 23‏:‏1‏-‏2؛ يُوح. 18‏:‏28‏-‏32] — إِزهد. 2‏:‏2؛ \x*
\v 2 ؤُشَا نِيثْنِي شَارْفنْ ث، إِوْينْ ث ؤُشَا سلّْمنْ ث إِ لْعَامِيلْ \add أَرُومَانِي\add*، قَّارنْ أَسْ بِيلَاطُوسْ. \x ◘ \xo 27:‏2 \xt ڒخ. 3‏:‏13. \x*
\v 3 ؤُمِي إِژْرَا يَاهُوذَا، أَغدَّارْ، بلِّي يَاسُوع إِتّْوَاحْكمْ، إِنْذمْ، ؤُشَا يَارَّا-د ثْڒَاثِينْ \add ن ڒْوزْنَاثْ\add* ن نُّوقَارْثْ غَارْ إِمقّْرَاننْ ن إِكهَّاننْ ذ إِمْغَارنْ \add ن ڒْڭنْسْ\add*.
\v 4 إِنَّا: ”نشّْ خْضِيغْ، أَقَا غْذَارغْ إِذَامّنْ إِمزْذَاڭنْ.“ مَاشَا نِيثْنِي نَّانْ: ”مِينْ ذ أَنغْ إِرُوحنْ؟ خْزَارْ-د شكْ.“
\v 5 أَوَارْنِي ڒَامِي إِنْضَارْ ڒْوزْنَاثْ ن نُّوقَارْثْ ذِي زَّاوشْثْ ثَامقّْرَانْثْ، إِفّغْ ؤُشَا إِرُوحْ، يُويڒْ إِخفْ نّسْ. \x ◘ \xo 27:‏5 \xt 2 صم. 17‏:‏23؛ ڒخ. 1‏:‏18. \x*
\v 6 إِمقّْرَاننْ ن إِكهَّاننْ كْسِينْ ڒْوزْنَاثْ ن نُّوقَارْثْ، نَّانْ: ”وَارْ إِشُووَّارْ أَذْ ثنْ نسَّارْسْ ذڭْ وخَّامْ ن صّْذَاقِي، مِينْزِي \add ڒْوزْنَاثْ نِّي\add* ذ تَّامَانْ ن ؤُسِيزّڒْ ن إِذَامّنْ.“
\v 7 كّْسنْ أَوَاڒْ جَارْ أَسنْ مَاحنْذْ أَذْ زَّايسْ سْغنْ إِيَّارْ ن بُو-ثْڒَاخْثْ، مَاحنْذْ أَذْ يِيڒِي إِ إِمضْڒَانْ ن إِبَارَّانِييّنْ. \f ◼ \fr 27:‏7 \ft \bd ’بُو-ثْڒَاخْثْ‘\bd* - إِخْسْ أَذْ يِينِي ’ونِّي إِتّْصنَّاعنْ ڒقْشُوعْ ن ثْڒَاخْثْ‘.\f*  \x ◘ \xo 27:‏7 \xt ڒخ. 1‏:‏19. \x*
\v 8 س ؤُينِّي إِتّْوَاسمَّا إِيَّارْ نِّي ’إِيَّارْ ن إِذَامّنْ‘ أَڒْ أَسّْ ن ڒخُّو.
\m 
\v 9 ڒخْذنِّي إِتّْوَاكمّڒْ مِينْ إِتّْوَانَّانْ زڭْ ؤُنَابِي إِ إِنَّانْ: ”كْسِيغْ ثْڒَاثِينْ \add ن ڒْوزْنَاثْ ن\add* نُّوقَارْثْ، ڒْقدّْ ن ونِّي إِغْڒَانْ، مِيخفْ إِنِّي زِي ثَارْوَا ن إِسْرَائِيل كّْسنْ أَوَاڒْ، \x ◘ \xo 27:‏9 \xt زَاك. 11‏:‏12. \x*
\v 10 ؤُشَا نشّْ وْشِيغْ ثنْثْ إِ إِيَّارْ ن بُو-ثْڒَاخْثْ، أَمْ مَامّشْ إِ ذ أَيِي يُومُورْ سِيذِي.“ \x ◘ \xo 27:‏10 \xt إِرْم. 32‏:‏6‏-‏9؛ زَاك. 11‏:‏12، 13\x*
\b
\s1 يَاسُوع قِيبَاتْشْ لْعَامِيلْ بِيلَاطُوسْ
\m 
\v 11 يَاسُوع ثُوغَا إِبدّْ قِيبَاتْشْ إِ لْعَامِيلْ. لْعَامِيلْ إِسّقْسَا أَسْ، إِنَّا: ”مَا شكْ ذ أَجدْجِيذْ ن وُوذَاينْ؟“ يَاسُوع إِنَّا أَسْ: ”شكْ أَقَا ثنِّيذْ \add ث\add*!“ \x ◘ \xo 27:‏11 \xt [مك. 15‏:‏2‏-‏15؛ لك. 23‏:‏3‏-‏5؛ 13‏-‏25؛ يُوح. 18‏:‏33‏-‏40؛ 19‏:‏1‏-‏16] \x*
\v 12 ؤُشَا ڒَامِي ث ثهْمنْ إِمقّْرَاننْ ن إِكهَّاننْ ذ إِمْغَارنْ \add ن ڒْڭنْسْ\add*، يَارَّا-د س وَالُو.
\v 13 خنِّي إِنَّا أَسْ بِيلَاطُوسْ: ”مَا وَارْ ثسْڒِيذْ مشْحَاڒْ خَاكْ شهّْذنْ؟“ \x ◘ \xo 27:‏13 \xt مت. 26‏:‏62. \x*
\v 14 نتَّا وَارْ خَاسْ د-يَارِّي ؤُڒَا س إِجّْ ن وَاوَاڒْ، أَڒَامِي إِقِّيمْ \add لْعَامِيلْ\add* إِتّبْهثْ أَطَّاسْ. \x ◘ \xo 27:‏14 \xt إِشا. 53‏:‏7؛ ڒخ. 8‏:‏32. \x*
\b
\m 
\v 15 ثُوغَا لْعَامِيلْ إِنُّومْ يَارخُّو ذِي كُوڒْ ڒْعِيذْ إِ يِيجّْ ن ؤُمحْبُوسْ إِ ڒْغَاشِي، ونِّي إِخْسنْ نِيثْنِي.
\v 16 ثُوغَا غَارْسنْ ذڭْ وُوسَّانْ نِّي إِجّْ ن ؤُمحْبُوسْ إِتّْوَاسّنْ، قَّارنْ أَسْ بَارْ-أَبَّاسْ. \x ◘ \xo 27:‏16 \xt مك. 15‏:‏7؛ لك. 23‏:‏19؛ يُوح. 18‏:‏40. \x*
\v 17 ڒَامِي مُوننْ، إِنَّا أَسنْ بِيلَاطُوسْ: ”وِي ثخْسمْ أَذْ أَومْ د-أَرْخُوغْ، بَارْ-أَبَّاسْ نِيغْ يَاسُوع ونِّي ؤُمِي قَّارنْ لْمَاسِيحْ؟“
\v 18 مِينْزِي بِيلَاطُوسْ إِسّنْ أَقَا نِيثْنِي سلّْمنْ ث زِي ڒحْسذْ.
\v 19 أَمْ ثُوغَا لْعَامِيلْ إِقِّيمْ خْ ڒْكُورْسِي ن ڒْحُوكْمْ، ثسّكّْ-د غَارسْ ثمْغَارْثْ نّسْ، ثنَّا: ”بَارَّا إِخفْ نّشْ زڭْ ؤُمْسڭَّاذْ نِّي، مِينْزِي أَقَا أَسّْ-أَ تّْوَاعدّْبغْ أَطَّاسْ ذِي ثَارْجِيثْ إِنُو ذِي سِّيبّثْ نّسْ.“
\v 20 مَاشَا إِمقّْرَاننْ ن إِكهَّاننْ ذ إِمْغَارنْ \add ن ڒْڭنْسْ\add* سّْقنْعنْ ڒْغَاشِي، حِيمَا أَذْ تَّارنْ بَارْ-أَبَّاسْ ؤُ حِيمَا أَذْ أَردّْدْجنْ يَاسُوع. \x ◘ \xo 27:‏20 \xt مك. 15‏:‏11؛ لك. 23‏:‏18؛ يُوح. 18‏:‏40؛ ڒخ. 3‏:‏14. \x*
\v 21 لْعَامِيلْ يَارَّا-د، إِنَّا أَسنْ: ”مَانْ ونْ زِي ثْنَاينْ-أَ إِ ثخْسمْ أَذْ أَرْخُوغْ إِ كنِّيوْ؟“ نَّانْ: ”بَارْ-أَبَّاسْ!“
\v 22 بِيلَاطُوسْ إِنَّا أَسنْ: ”مِينْ غَا ڭّغْ \add خنِّي\add* أَكْ-ذ يَاسُوع ؤُمِي قَّارنْ لْمَاسِيحْ؟“ نَّانْ أَسْ مَارَّا: ”صلّْبْ إِ-ث!“
\v 23 إِنَّا أَسنْ لْعَامِيلْ: ”مَانْ ثُوعفّْنَا إِ إِڭَّا؟“ سْغُويّنْ س جّهْذْ كْثَارْ، نَّانْ: ”صلّْبْ إِ-ث.“
\v 24 ڒَامِي إِژْرَا بِيلَاطُوسْ بلِّي وَارْ يِيوضْ غَارْ وَالُو، مَاهُو أَذْ إِكَّارْ ؤُغُووّغْ، إِكْسِي أَمَانْ، إِسِّيرْذْ إِفَاسّنْ نّسْ قِيبَاتْشْ إِ ڒْغَاشِي، إِنَّا: ”نشّْ وَارْ تُّورْسغْ شَا ذڭْ إِذَامّنْ ن ؤُمْسڭَّاذْ-أَ، خْزَارمْ كنِّيوْ!“
\v 25 ڒْڭنْسْ مَارَّا يَارَّا-د، إِنَّا: ”\add أجّْ\add* إِذَامّنْ نّسْ \add أَذْ\add* خَانغْ \add إِڒِينْ\add* ؤُ خْ ثَارْوَا نّغْ.“ \x ◘ \xo 27:‏25 \xt ڒخ. 5‏:‏28. \x*
\v 26 خنِّي يَارْخُو أَسنْ-د إِ بَارْ-أَبَّاسْ، مَاشَا أَوَارْنِي ڒَامِي إِهتّكْ يَاسُوع س ؤُركُّوضْ، إِسلّمْ إِ-ث حِيمَا أَذْ إِتّْوَاصلّبْ.
\b
\s1 أَسحْقَارْ ن يَاسُوع زِي ڒْعسْكَارْ
\m 
\v 27 ڒخْذنِّي إِوْينْ إِعسْكَارِييّنْ ن لْعَامِيلْ يَاسُوع غَارْ ثَادَّارْثْ ن شّْرَاعْ، \add ؤُمِي قَّارنْ ’بْرِيثُورِييُومْ‘\add*، ؤُشَا سّْمُوننْ خَاسْ مَارَّا ڒْكُومْبَانِييّثْ ن ڒْعسْكَارْ. \x ◘ \xo 27:‏27 \xt [مك. 15‏:‏16‏-‏20؛ يُوح. 19‏:‏2‏-‏3] \x*
\v 28 كّْسنْ أَسْ-د أَرُّوضْ، ؤُشَا أَرْضنْ أَسْ إِجّْ ن ؤُجدْجَابْ ذ أَزڭّْوَاغْ.
\v 29 نِيثْنِي مُوذنْ أَسْ إِجّْ ن تَّاجْ س إِسنَّاننْ، سَّارْسنْ ث خْ ؤُزدْجِيفْ نّسْ ؤُشَا ڭِّينْ أَسْ إِجّْ ن ؤُغَانِيمْ ذڭْ ؤُفُوسْ نّسْ أَفُوسِي، خنِّي وْضَانْ غَارْ إِضَارنْ نّسْ زَّاثسْ، قِّيمنْ تّْبُوصَارنْ خَاسْ، نَّانْ: ”أَزُولْ خَاكْ، أَ شكْ، \add أَ\add* أَجدْجِيذْ ن وُوذَاينْ!“
\v 30 سُّوسْفنْ أَسْ خْ ؤُغمْبُوبْ نّسْ، كْسِينْ أَغَانِيمْ ؤُشَا وْثِينْ ث \add زَّايسْ\add* غَارْ ؤُزدْجِيفْ.
\v 31 \add أَوَارْنِي ڒَامِي\add* ث ذدْجنْ، كْسِينْ خَاسْ أَسڒْهَامْ، أَرْضنْ أَسْ أَرُّوضْ نّسْ ؤُشَا نذْهنْ ث، مَاحنْذْ أَذْ ث صلّْبنْ.
\b
\s1 أَبْرِيذْ غَارْ صَّالِيبْ
\m 
\v 32 أَمْ فّْغنْ غَارْ بَارَّا \add ن ثنْذِينْثْ\add*، ؤُفِينْ إِجّْ ن ورْيَازْ زِي قَايْرَاوَانْ، قَّارنْ أَسْ شِيمْعُونْ، ؤُشَا زِييَّارنْ خَاسْ حِيمَا أَذْ يَارْبُو صَّالِيبْ نّسْ. \x ◘ \xo 27:‏32 \xt [مك. 15‏:‏21‏-‏41؛ لك. 23‏:‏26‏-‏39؛ 44‏-‏49؛ يُوح. 19‏:‏17‏-‏19؛ 28‏-‏30] \x*
\v 33 أَڒَامِي إِوْضنْ غَارْ ومْشَانْ ؤُمِي قَّارنْ ’جُولْجُوثَا‘، مِينْ إِخْسْ أَذْ يِينِي ’ثَاشقُّوفْثْ‘، \x ◘ \xo 27:‏33 \xt إِزهد. 69‏:‏22؛ مك. 15‏:‏22؛ لك. 23‏:‏33؛ يُوح. 19‏:‏17. \x*
\v 34 وْشِينْ أَسْ ڒْخدْجْ إِخدْجْضنْ س ثَارْزُوڭِي ؤُشَا ؤُمِي ث إِقَّاسْ، يُوڭِي أَذْ إِسُو.
\v 35 أَوَارْنِي ڒَامِي ث صلّْبنْ، بْضَانْ أَرُّوضْ نّسْ جَارْ أَسنْ ؤُمِي خَاسْ ڭِّينْ أَكشُّوضْ، \x ◘ \xo 27:‏35 \xt إِزهد. 22‏:‏19؛ مك. 15‏:‏24؛ يُوح. 19‏:‏23. \x*
\v 36 أَمْ قِّيمنْ ذِينِّي، تّْعسَّانْ خَاسْ.
\v 37 ڭِّينْ أَسْ سنّجْ إِ ؤُزدْجِيفْ نّسْ إِشْثْ ن ثِيرَا مَايمِّي خَاسْ حكْمنْ س ڒْموْثْ: ’وَا ذ يَاسُوع، أَجدْجِيذْ ن وُوذَاينْ.‘ \x ◘ \xo 27:‏37 \xt مك. 15‏:‏26؛ لك. 23‏:‏38؛ يُوح. 19‏:‏19. \x*
\v 38 خنِّي صلّْبنْ أَكِيذسْ ثْنَاينْ ن إِخوَّاننْ، إِجّنْ غَارْ ؤُفُوسِي نّسْ ؤُ إِجّنْ غَارْ ؤُزڒْمَاضْ نّسْ. \x ◘ \xo 27:‏38 \xt إِشا. 53‏:‏12. \x*
\v 39 إِنِّي ثُوغَا إِتّكَّانْ، تّْشقَّافنْ ذَايسْ، تّْهزَّانْ أَزدْجِيفْ نْسنْ، \x ◘ \xo 27:‏39 \xt إِزهد. 22‏:‏8؛ 69‏:‏21؛ مك. 15‏:‏29؛ لك. 23‏:‏35. \x*
\v 40 نَّانْ: ”أَ شكْ، ونِّي إِهذْمنْ زَّاوشْثْ ثَامقّْرَانْثْ ؤُ ذِي ثْڒَاثَا ن وُوسَّانْ أَذْ ت ثبْنِيذْ \add عَاوذْ\add*، سنْجمْ إِخفْ نّشْ. مَاڒَا شكْ ذ مِّيسْ ن أَربِّي، هْوَا-د خنِّي زِي صَّالِيبْ.“ \x ◘ \xo 27:‏40 \xt مت. 26‏:‏61؛ يُوح. 2‏:‏19. \x*
\v 41 ؤُڒَا ذ إِمقّْرَاننْ ن إِكهَّاننْ أَكْ-ذ إِمْسڒْمَاذنْ ن إِذْلِيسنْ ذ إِمْغَارنْ \add ن ڒْڭنْسْ\add* ذ إِفَارِيسِييّنْ سْثهْزَانْ زَّايسْ أَمنِّي، نَّانْ:
\v 42 ”إِسّنْجمْ إِنّغْنِي مَاشَا وَارْ إِزمَّارْ أَذْ إِسّنْجمْ خفْ نّسْ. مَاڒَا نتَّا ذ أَجدْجِيذْ ن إِسْرَائِيل، أجّْ إِ-ث أَذْ د-إِهْوَا زِي صَّالِيبْ، أَذْ زَّايسْ نَامنْ.
\v 43 إِتّْشڒْ خْ أَربِّي. أجّْ إِ-ث نتَّا أَذْ ث إِسّنْجمْ مَاڒَا يَارْضَا خَاسْ، مِينْزِي إِنَّا: ’نشّْ ذ مِّيسْ ن أَربِّي‘.“
\v 44 ؤُڒَا ذ إِخوَّاننْ، إِنِّي ثُوغَا إِتّْوَاصلّْبنْ أَكِيذسْ، ثُوغَا سّْفطَّاحنْ زَّايسْ أَمنِّي.
\b
\m 
\v 45 زِي ثْسَاعّثْ وِيسّْ ستَّا، \add أَقَا-ت ذ ضّْهُورْ\add*، ثوْضَا-د ثَادْجسْثْ خْ مَارَّا ثَامُّورْثْ أَڒْ ثَاسَاعّثْ وِيسّْ ثسْعَا، \add أَقَا-ت ذ ثْڒَاثَا ن ؤُعشِّي\add*.
\v 46 جّْوَايهْ ن ثْسَاعّثْ وِيسّْ ثسْعَا إِسْغُويْ يَاسُوع س ثْمِيجَّا إِجهْذنْ، إِنَّا: ”\add أَ\add* أَربِّي إِنُو، \add أَ\add* أَربِّي إِنُو، مَايمِّي ذَايِي ثْسمْحذْ؟“ \f ◼ \fr 27:‏46 \ft \bd ’إِلْ، إِلْ، لْمَانَا شَابَاقْثَانِي‘\bd* - ثُوغَا يَاسُوع إِسَّاوَاڒْ س يِيڒسْ ن ثْڒَامِيثْ أَمْ ث سَّاوَاڒنْ مَارَّا وُوذَاينْ ذِي ؤُرْشَالِيمْ ذ ثمُّورْثْ ن لْجَالِيلْ.\f*  \x ◘ \xo 27:‏46 \xt إِزهد. 22‏:‏2؛ عبر. 5‏:‏7. \x*
\v 47 ڒَامِي ذ أَسْ سْڒَانْ إِنِّي ذِينْ إِبدّنْ، نَّانْ شَا زَّايْسنْ: ”إِتّْڒَاغَا خْ إِلِييَا.“
\v 48 ذغْيَا يُوزّڒْ-د غَارسْ إِجّنْ زَّايْسنْ، إِكْسِي سْپُونْخَا، إِسُّوفّْ إِ-ت س ڒْخدْجْ، إِڭَّا إِ-ت خْ إِجّْ ن ؤُغَانِيمْ ؤُشَا إِوْشَا أَسْ أَذْ إِسُو. \x ◘ \xo 27:‏48 \xt إِزهد. 69‏:‏22؛ يُوح. 19‏:‏29. \x*
\v 49 إِنّغْنِي نَّانْ: ”أجّْ إِ-ث، أَذْ نْژَارْ، مَا أَذْ د-يَاسْ إِلِييَا حِيمَا أَذْ ث إِسّنْجمْ.“
\v 50 إِسْغُويّْ يَاسُوع عَاوذْ س ثْمِيجَّا إِجهْذنْ ؤُشَا إِسَّارْخُو أَرُّوحْ نّسْ. \x ◘ \xo 27:‏50 \xt لك. 23‏:‏46. \x*
\m 
\v 51 خْزَارْ، أَڒحَّافْ ن وَاذَافْ غَارْ زَّاوشْثْ ثَامقّْرَانْثْ إِتّْوَاشَارّڭْ خْ ثْنَاينْ زِي سنّجْ أَڒْ سْوَادَّايْ، ثَامُّورْثْ ثنْهزّْ، ثِيصُوضَارْ فدْجْقنْثْ، \f ◼ \fr 27:‏51 \ft \bd ’أَڒحَّافْ‘\bd* - نِيغْ ’أَرْوَاقْ‘.\f*  \x ◘ \xo 27:‏51 \xt 2 إِم. 3‏:‏14؛ مك. 15‏:‏38؛ لك. 23‏:‏45. \x*
\v 52 إِمضْڒَانْ تّْوَارزْمنْ ؤُشَا أَطَّاسْ ن أَرِّيمَاثْ ن إِمْقدَّاسنْ إِنِّي ثُوغَا إِطّْصنْ \add ذِينْ\add*، تّْوَاسّْنكَّارنْثْ-د.
\v 53 نِيثْنِي فّْغنْ \add زڭْ إِمضْڒَانْ\add*، ؤُشَا أَوَارْنِي إِ ثْنُوكْرَا نّسْ ؤُذْفنْ غَارْ ثنْذِينْثْ إِقدّْسنْ ؤُشَا بَاننْ-د إِ وَاطَّاسْ.
\v 54 ڒَامِي ڒْقبْطَانْ خْ مْيَا ذ يِينِّي ثُوغَا أَكِيذسْ إِحطَّانْ يَاسُوع، ژْرِينْ أَنْهزِّي ن ثمُّورْثْ ذ مِينْ إِمْسَارنْ، ڭّْوذنْ أَطَّاسْ، نَّانْ: ”س ثِيذتّْ ثُوغَا وَا ذ مِّيسْ ن أَربِّي.“ \x ◘ \xo 27:‏54 \xt مك. 15‏:‏39؛ لك. 23‏:‏47. \x*
\v 55 ثُوغَا ذِينْ أَطَّاسْ ن ثمْغَارِينْ ثِينِّي ثُوغَا إِخزَّارنْ زِي ڒَاڭّْوَاجْ، ضْفَارنْثْ يَاسُوع زِي لْجَالِيلْ حِيمَا أَذْ خَاسْ سخَّارنْثْ. \x ◘ \xo 27:‏55 \xt إِزهد. 38‏:‏12؛ مك. 15‏:‏40؛ لك. 8‏:‏2؛ 23‏:‏49. \x*
\v 56 جَارَاسنْثْ مَارْيَامْ ن مَاجْذَالَا ذ مَارْيَامْ، يمَّاسْ ن يَاعْقُوبْ ذ يَاسِي، ذ يمَّاسْ ن أَيْثْ ن زَابْذِي.
\b
\s1 أَنْضڒْ ن يَاسُوع
\m 
\v 57 ڒَامِي د-ثِيوضْ ثْمذِّيثْ، يُوسَا-د إِجّْ ن ورْيَازْ زِي رَامْثَا، قَّارنْ أَسْ يُوسُوفْ. نتَّا ثُوغَا عَاوذْ ذ أَمحْضَارْ ن يَاسُوع. \x ◘ \xo 27:‏57 \xt [مك. 15‏:‏42‏-‏47؛ لك. 23‏:‏50‏-‏56؛ يُوح. 19‏:‏38‏-‏42] \x*
\v 58 إِرُوحْ غَارْ بِيلَاطُوسْ، إِتَّارْ \add أَسْ\add* أَرِّيمثْ ن يَاسُوع. \add ڒخْذنِّي\add* إِوصَّا بِيلَاطُوسْ، مَاحنْذْ أَذْ أَسْ وْشنْ أَرِّيمثْ
\v 59 يُوسُوفْ إِكْسِي أَرِّيمثْ إِنّضْ إِ-ت ذڭْ إِشْثْ ن ثْخيَّاضْثْ ن ڒقْطنْ \add أَزْذَاذْ\add* إِصْفَانْ،
\v 60 إِسَّارْسْ إِ-ت ذڭْ إِجّْ ن ونْضڒْ ن جْذِيذْ إِ ثُوغَا إِغْزَا، ؤُشَا أَوَارْنِي ڒَامِي إِسّقْنُونِّي إِشْثْ ن ثصْضَارْثْ حِيمَا أَذْ إِقْفڒْ ثَاوَّارْثْ ن ونْضڒْ، إِرُوحْ. \x ◘ \xo 27:‏60 \xt مك. 15‏:‏46؛ لك. 23‏:‏53. \x*
\v 61 ثُوغَا ذِينْ مَارْيَامْ ن مَاجْذَالَا ذ مَارْيَامْ نّغْنِيثْ قِّيمنْثْ قِيبَاتْشْ إِ ونْضڒْ.
\b
\m 
\v 62 ثِيوشَّا نّسْ أَوَارْنِي \add أَسّْ ن\add* ؤُسوْجذْ، مُوننْ إِمقّْرَاننْ ن إِكهَّاننْ ذ إِفَارِيسِييّنْ غَارْ بِيلَاطُوسْ، \f ◼ \fr 27:‏62 \ft \bd ’أَسّْ ن ؤُسوْجذْ‘\bd* - نتَّا ذ أَسّْ قْبڒْ وَاسّْ ن سّبْثْ (‹مَاتَّا 27:62›) ن ڒْعِيذْ ن ثْغَارْصْثْ ن ؤُسعْذُو (قَّارنْ أَسْ 'بَاسْخَا') نِّي ذِي سّْوجْذنْ وُوذَاينْ إِجّْ ن يزْمَارْ إِ مَاشَّا، سِّيرْذنْ، يَارْضنْ أَرُّوضْ إِتّْخصّنْ ؤُمِي د-فّْغنْ زِي مِيصْرَا (ؤُفُّوغْ 11-13).\f*
\v 63 نَّانْ: ”أَ سِيذِيثْنغْ، نعْقڒْ بلِّي أَغشَّاشْ-أَ، أَمْ ثُوغَا \add عَاذْ\add* إِدَّارْ، إِنَّا: ’أَوَارْنِي ثْڒَاثَا ن وُوسَّانْ أَذْ كَّارغْ!‘ \x ◘ \xo 27:‏63 \xt مت. 16‏:‏21؛ 17‏:‏23؛ 20‏:‏19؛ مك. 8‏:‏31؛ 10‏:‏34؛ لك. 9‏:‏22؛ 18‏:‏33؛ 24‏:‏6. \x*
\v 64 س ؤُيَا ؤُمُورْ، حِيمَا أَذْ ضمْننْ أَنْضڒْ أَڒْ أَسّْ وِيسّْ ثْڒَاثَا، حِيمَا أَذْ ثَاغْ إِمحْضَارنْ نّسْ وَارْ د-تِّيسنْ س دْجِيڒثْ أَذْ ث أَشَارنْ، \add خنِّي\add* أَذْ إِنِينْ إِ ڒْڭنْسْ، أَقَا إِكَّارْ-د زِي ثَادَّارْثْ ن إِمتِّيننْ، ؤُشَا \add أَمُّو إِ\add* غَا يِيڒِي ؤُودَّارْ أَنڭَّارُو كْثَارْ خْ ؤُمزْوَارْ.“
\v 65 إِنَّا أَسنْ بِيلَاطُوسْ: ”أَقَا غَارْومْ إِعسَّاسنْ، رُوحمْ، ضمْننْ ث أَمْ مَامّشْ ثتّْوَاڒَامْ.“
\v 66 رُوحنْ حِيمَا أَذْعسّنْ خْ ونْضڒْ ؤُشَا ضمْننْ أَژْرُو، نِيثْنِي جْمِيعْ أَكْ-ذ إِعسَّاسنْ.
\b
\b
\c 28
\s1 ثَانُوكْرَا
\m 
\v 1 أَوَارْنِي ڒَامِي ثعْذُو سّبْثْ، غَارْ ڒفْجَارْ ن \add وَاسّْ\add* أَمزْوَارُو ن سِّيمَانَا، ثُوسَا-د مَارْيَامْ ن مَاجْذَالَا ذ مَارْيَامْ نّغْنِيثْ حِيمَا أَذْ سِّيجّنْثْ خْ ونْضڒْ. \x ◘ \xo 28:‏1 \xt [مك. 16‏:‏1‏-‏8؛ لك. 24‏:‏1‏-‏12؛ يُوح. 20‏:‏1‏-‏10] \x*
\v 2 خْزَارْ، إِمْسَارْ إِجّْ ن ونْهزِّي ن ثمُّورْثْ إِمْغَارْ، مِينْزِي لْمَالَاكْ ن سِيذِي إِهْوَا-د زڭْ ؤُجنَّا، إِقَارّبْ-د، إِسّقْنُونِّي ثَاصْضَارْثْ زڭْ وَاذَافْ ؤُشَا إِقِّيمْ خَاسْ.
\v 3 ثُوغَا صِّيفثْ نّسْ أَمْ وَاجَّاجْ ؤُ وَارُّوضْ نّسْ ذ أَشمْڒَاڒْ أَمْ وذْفڒْ. \x ◘ \xo 28:‏3 \xt دَان. 7‏:‏9؛ ڒخ. 1‏:‏10. \x*
\v 4 إِعسَّاسنْ فشْڒنْ زِي ثڭّْوُوذِي زَّايسْ ؤُشَا ذوْڒنْ أَمْ يِيمتِّيننْ.
\m 
\v 5 لْمَالَاكْ إِطّفْ ذڭْ وَاوَاڒْ، إِنَّا إِ ثمْغَارِينْ: ”وَارْ تّڭّْوذنْثْ شَا، مِينْزِي سّْنغْ أَقَا كنِّينْثْ ثَارزُّونْثْ خْ يَاسُوع ونِّي إِتّْوَاصلّْبنْ. \x ◘ \xo 28:‏5 \xt مك. 16‏:‏6؛ لك. 24‏:‏4. \x*
\v 6 وَارْ ذَا إِدْجِي، مِينْزِي نتَّا إِكَّارْ-د، أَمْ مَامّشْ إِنَّا. أَسنْثْ-إِ-د ذَا، خْزَارنْثْ أَمْشَانْ مَانِي ثُوغَا إِمَّارْسْ سِيذِيثْنغْ. \x ◘ \xo 28:‏6 \xt مت. 16‏:‏21؛ 17‏:‏23؛ 20‏:‏19؛ مك. 8‏:‏31؛ 9‏:‏31؛ 10‏:‏34؛ لك. 9‏:‏22؛ 18‏:‏33؛ 24‏:‏6. \x*
\v 7 رُوحنْثْ ذغْيَا، إِنِينْثْ إِ إِمحْضَارنْ نّسْ، أَقَا إِتّْوَاسّْنكَّارْ-د زِي ثَادَّارْثْ ن إِمتِّيننْ، ؤُ خْزَارْ نتَّا ذ أَومْ إِ غَا إِزْوَارنْ غَارْ لْجَالِيلْ. ذِينْ أَذْ ث ثْژَارمْ. خْزَارْ، أَقَا نِّيغْ أَومْ ت.“ \x ◘ \xo 28:‏7 \xt مت. 26‏:‏32؛ مك. 16‏:‏7. \x*
\b
\m 
\v 8 فّْغنْثْ نِيثنْثِي ذغْيَا زڭْ ونْضڒْ س ثِيڭّْوُوذِي ذ ڒفْرَاحثْ إِمْغَارنْ، تَّازّْڒنْثْ حِيمَا أَذْ ت خبَّارنْثْ إِمحْضَارنْ. \x ◘ \xo 28:‏8 \xt مك. 16‏:‏8؛ يُوح. 20‏:‏18. \x*
\v 9 ؤُشَا خْزَارْ، يَاسُوع إِڒْقَا ثنْثْ \add ذڭْ وبْرِيذْ\add*، إِنَّا أَسنْ: ”سْڒَامْ خَاكنْثْ!“ نِيثنْثِي ؤُسِينْثْ-إِ-د غَارسْ، طّْفنْثْ ذڭْ إِضَارنْ نّسْ ؤُشَا سجْذنْثْ أَسْ. \x ◘ \xo 28:‏9 \xt مك. 16‏:‏9؛ يُوح. 20‏:‏14. \x*
\v 10 ڒخْذنِّي إِنَّا أَسنْثْ يَاسُوع: ”وَارْ تّڭّْوذنْثْ شَا، سِّيوْضنْثْ ڒخْبَارْ\add -أَ\add* إِ أَيْثْمَا، حِيمَا أَذْ رَاحنْ غَارْ لْجَالِيلْ، ذِيهَا أَذْ أَيِي ژَترنْ.“ \x ◘ \xo 28:‏10 \xt ڒخ. 1‏:‏3؛ 13‏:‏31؛ 1 كُور. 15‏:‏5. \x*
\b
\m 
\v 11 أَمْ رُوحنْثْ، خْزَارْ، أَقَا شَا زڭْ إِعسَّاسنْ ؤُسِينْ-د غَارْ ثنْذِينْثْ، حِيمَا أَذْ خبَّارنْ إِمقّْرَاننْ ن إِكهَّاننْ خْ مَارَّا مِينْ إِمْسَارنْ.
\v 12 ڒخْذنِّي مُوننْ نِيثْنِي أَكْ-ذ إِمْغَارنْ \add ن ڒْڭنْسْ\add* ؤُشَا مْشَاوَارنْ أَكِيذْسنْ، \add ؤُشَا\add* وْشِينْ أَسنْ إِ إِعسَّاسنْ \add تّْمنْيَاثْ ن\add* نُّوقَارْثْ، وَارْ إِدْجِي ذْرُوسْ،
\v 13 نَّانْ: ”إِنِيمْ: ’إِمحْضَارنْ نّسْ ؤُسِينْ-د س دْجِيڒثْ ؤُشَا ؤُشَارنْ ث أَمْ ثُوغَا نطّصْ!‘
\v 14 مَاڒَا إِسْڒَا إِ-ث لْعَامِيلْ، أَذْ ث نسّقْنعْ ؤُشَا أَذْ نڭّْ وَارْ ثتِّيڒِيمْ ذڭْ إِمُونَاسْ.“
\v 15 طّْفنْ \add ثْمنْيَاثْ ن\add* نُّوقَارْثْ ؤُشَا ڭِّينْ أَمْ مَامّشْ ذ أَسنْعڒْمنْ. \add أَمُّو\add* إِ د-إِتّفّغْ ڒخْبَارْ-أَ جَارْ وُوذَاينْ أَڒْ أَسّْ ن يِيضَا.
\b
\s1 ڒُومُورْ أَمقّْرَانْ إِ ؤُبَارّحْ ن ڒخْبَارْ أَصبْحَانْ
\m 
\v 16 حِيطَاشْ ن إِمحْضَارنْ نِّي رُوحنْ غَارْ لْجَالِيلْ، غَارْ وذْرَارْ مَانِي ثنْ يُومُورْ يَاسُوع. \x ◘ \xo 28:‏16 \xt [مك. 16‏:‏14‏-‏18؛ لك. 24‏:‏36‏-‏49؛ يُوح. 20‏:‏19‏-‏23؛ ؤُف. 1‏:‏6‏-‏8] — مت. 26‏:‏32؛ \x*
\v 17 أَڒَامِي ث ژْرِينْ، سجْذنْ أَسْ، مَاشَا شَا شكّنْ.
\v 18 إِقَارّبْ-د غَارْسنْ يَاسُوع، إِسِّيوڒْ أَكِيذْسنْ، إِنَّا: ”ثمّوْشْ أَيِي مَارَّا صُّولْطَا ذڭْ ؤُجنَّا ؤُ خْ ثمُّورْثْ. أَمْ مَامّشْ إِ ذ أَيِي د-إِسّكّْ بَابَا، أَمُّو كنِّيوْ إِ غَا سّكّغْ نشّْ. \x ◘ \xo 28:‏18 \xt إِزهد. 8‏:‏7؛ مت. 11‏:‏27؛ لك. 10‏:‏22؛ يُوح. 3‏:‏35؛ 17‏:‏2؛ 1 كُور. 15‏:‏27؛ أَفا. 1‏:‏22؛ عبر. 2‏:‏8. \x*
\v 19 رُوحمْ، أَرّمْ مَارَّا ڒڭْنُوسْ ذ إِمحْضَارنْ إِنُو ؤُ سّْغضْصمْ ثنْ س يِيسمْ ن بَابَا ذ مِّيسْ ذ أَرُّوحْ إِقدّْسنْ، \x ◘ \xo 28:‏19 \xt مك. 16‏:‏15؛ يُوح. 15‏:‏16. \x*
\v 20 ؤُ سْڒمْذمْ أَسنْ أَذْ طّْفنْ ذِي مَارَّا مِينْ خفْ كنِّيوْ ؤُمُورغْ زَّايسْ، ؤُ خْزَارْ، نشّْ أَقَا أَيِي أَكِيذْومْ مَارَّا ؤُسَّانْ أَڒْ قطُّو ن دُّونشْثْ.“
\b
\m أَنڭَّارْ ن لْ-إِنْجِيلْ إِقدّْسنْ أَمْ مَامّشْ ث إِبَارّحْ مَاتَّا. \x ◘ \xo 28:‏20 \xt يُوح. 14‏:‏18. \x* 
