\v 16 Te \w dongah|strong="H9999"\w* \w hlang|strong="H0376"\w* loh \w BOEIPA|strong="H3068"\w* a \w rhih|strong="H3372"\w* uh he a \w rhihnah|strong="H3374"\w* khaw \w len|strong="H1419"\w*. \w BOEIPA|strong="H3068"\w* \w taengah|strong="H9997"\w* \w hmueih|strong="H2077"\w* a \w nawn|strong="H2076"\w* uh \w tih|strong="H9999"\w* \w olcaeng|strong="H5088"\w* khaw a \w caeng|strong="H5087"\w* uh.  
\v 17 \x - \xo 1.17 \xt Mat 12. 40.\x*\w Tedae|strong="H9999"\w* \w Jonah|strong="H3124"\w* aka \w dolh|strong="H1104"\w* \w hamla|strong="H9997"\w* \w nga|strong="H1709"\w* \w len|strong="H1419"\w* te \w BOEIPA|strong="H3068"\w* loh a \w khueh|strong="H4487"\w* coeng. Te \w dongah|strong="H9999"\w* \w Jonah|strong="H3124"\w* tah \w nga|strong="H1709"\w* \w bung|strong="H4578"\w* \w khuiah|strong="H9996"\w* \w khothaih|strong="H3117"\w* hnin \w thum|strong="H7969"\w* \w neh|strong="H9999"\w* \w khoyin|strong="H3915"\w* hnin \w thum|strong="H7969"\w* \w om|strong="H1961"\w*.   
\c 2  
\s1 Jonah kah Thangthuinah  
\p
\v 1 \w Jonah|strong="H3124"\w* tah \w nga|strong="H1710"\w* \w bung|strong="H4578"\w* khui \w lamloh|strong="H4480"\w* \w a|strong="H9909"\w* \w Pathen|strong="H0430"\w* \w BOEIPA|strong="H3068"\w* \w taengah|strong="H0413"\w* \w thangthui|strong="H6419"\w*.  
\v 2 Te \w vaengah|strong="H9999"\w*, “\w BOEIPA|strong="H3068"\w* \w te|strong="H0413"\w* \w kamah|strong="H9901"\w* \w kah|strong="H9997"\w* \w citcai|strong="H6869"\w* \w lamloh|strong="H4480"\w* ka \w khue|strong="H7121"\w* \w tih|strong="H9999"\w* \w kai|strong="H9901"\w* n'\w doo|strong="H6030"\w* coeng. \w Saelkhui|strong="H7585"\w* \w bung|strong="H0990"\w* khui \w lamloh|strong="H4480"\w* bomnah kam \w bih|strong="H7768"\w* vaengah \w ka|strong="H9901"\w* \w ol|strong="H6963"\w* na \w yaak|strong="H8085"\w* coeng.  
\v 3 \w Kai|strong="H9901"\w* he \w tuipuei|strong="H3220"\w* \w tuilung|strong="H3824"\w* \w neh|strong="H9999"\w* \w tuiva|strong="H5104"\w* \w laedil|strong="H4688"\w* \w la|strong="H9996"\w* nan \w voeih|strong="H7993"\w*. \w Kai|strong="H9901"\w* he \w na|strong="H9905"\w* \w tuiphu|strong="H4867"\w* \w boeih|strong="H3605"\w* loh m'\w vael|strong="H5437"\w* \w tih|strong="H9999"\w* \w na|strong="H9905"\w* \w lungkuk|strong="H1530"\w* loh \w kai|strong="H9901"\w* \w soah|strong="H5921"\w* n'\w thing|strong="H5674"\w*.  
