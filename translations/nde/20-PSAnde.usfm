\id PSA - Biblica® Open Ndebele Contemporary Bible
\h AmaHubo
\toc1 AmaHubo
\toc2 AmaHubo
\toc3 Hubo
\mt1 AmaHubo
\c 1
\ms1 Ugwalo 1
\mr AmaHubo 1 – 41
\cl Ihubo 1
\q1 
\v 1 Ubusisiwe umuntu
\q2 ongahambi ngezeluleko zababi;
\q1 ongemiyo endleleni yezoni;
\q2 ongahlaliyo esihlalweni sabaklolodayo.
\q1 
\v 2 Kodwa ukuthokoza kwakhe kusemthethweni \nd kaThixo\nd*,
\q2 futhi unakana ngomthetho wakhe imini lobusuku.
\q1 
\v 3 Unjengesihlahla esihlanyelwe emifuleni yamanzi,
\q2 esithela izithelo zaso ngesikhathi saso,
\q1 ohlamvu laso kalibuni.
\q2 Konke akwenzayo kuyaphumelela.
\b
\q1 
\v 4 Ababi kabanjalo!
\q2 Banjengamakhoba
\q2 aphetshulwa ngumoya.
\q1 
\v 5 Ngakho ababi kabayikuma ekwahlulelweni,
\q2 noma izoni enkundleni yabalungileyo.
\b
\q1 
\v 6 Ngoba \nd uThixo\nd* uyayilinda indlela yabalungileyo,
\q2 kodwa indlela yababi iya ekubhujisweni.
\c 2
\cl Ihubo 2
\q1 
\v 1 Kungani izizwe zixokozela,
\q2 labantu besakha amacebo ngeze?
\q1 
\v 2 Amakhosi omhlaba ayahloma ajame
\q2 lababusi bahlangana ndawonye
\q2 bemelana \nd loThixo\nd* njalo lalowo ogcotshiweyo wakhe besithi;
\q1 
\v 3 “Kasiwaqamuleni amaketane abo,
\q2 silahle izibopho zabo.”
\b
\q1 
\v 4 Yena osesihlalweni ezulwini uyahleka;
\q2 uThixo uyabahleka.
\q1 
\v 5 Abesebakhalimela ngolaka,
\q2 abathuthumelise ngentukuthelo yakhe, esithi,
\q1 
\v 6 “Sengiyibekile eyami inkosi phezu kweZiyoni,
\q2 intaba yami engcwele.”
\p 
\v 7 Ngizasimemezela isimiso \nd sikaThixo\nd* :
\q1 Wathi kimi, “UyiNdodana yami;
\q2 lamhla sengibe nguyihlo.
\q1 
\v 8 Cela kimi,
\q2 ngizakwenza izizwe zibe yilifa lakho,
\q2 imikhawulo yomhlaba kube yinotho yakho.
\q1 
\v 9 Uzazibusa ngentonga yobukhosi eyensimbi,
\q2 uzazibhidliza zicubuzeke njengebumba.”
\b
\q1 
\v 10 Ngakho-ke lina makhosi, limukani,
\q2 liyaxwayiswa lina babusi bomhlaba.
\q1 
\v 11 Mkhonzeni \nd uThixo\nd* ngokumesaba,
\q2 lithokozele umbuso wakhe ngokuthuthumela.
\q1 
\v 12 Ikhothameleni iNdodana, funa ithukuthele
\q2 beselibhujiswa endleleni yenu,
\q1 ngoba intukuthelo yakhe ingavutha ngesikhatshana.
\q2 Babusisiwe bonke abaphephela kuye.
\c 3
\cl Ihubo 3
\d Ihubo likaDavida ebalekela indodana yakhe u-Abhisalomu.
\q1 
\v 1 Oh \nd Thixo\nd* banengi kangaka abayizitha zami!
\q2 Banengi kangaka abangihlaselayo!
\q1 
\v 2 Abanengi bathi ngami,
\q2 “UNkulunkulu kayikumhlenga.”
\b
\q1 
\v 3 Kodwa wena uyisihlangu sokungivikela, Oh, \nd Thixo\nd*,
\q2 inkazimulo yami, uphakamisa ikhanda lami.
\q1 
\v 4 Ngikhala kakhulu \nd kuThixo\nd*
\q2 uyangiphendula esentabeni yakhe engcwele.
\b
\q1 
\v 5 Ngilala phansi ngijumeke;
\q2 ngibuye ngiphaphame, ngoba \nd uThixo\nd* uyangilondoloza.
\q1 
\v 6 Angiyikubesaba abangamatshumitshumi ezinkulungwane
\q2 abangihlaselayo inxa zonke.
\b
\q1 
\v 7 Phakama, awu \nd Thixo\nd*
\q2 Ngisindise, Oh Nkulunkulu wami.
\q1 Zibethe zonke izitha zami emhlathini;
\q2 akhumule amazinyo ababi.
\b
\q1 
\v 8 \nd KuThixo\nd* kuvela insindiso.
\q2 Sengathi isibusiso Sakho singaba sebantwini Bakho.
\c 4
\cl Ihubo 4
\d Kumqondisi wokuhlabela. Ngeziginci. Ihubo likaDavida.
\q1 
\v 1 Ngiphendula lapho ngikubiza,
\q2 Oh Nkulunkulu wami olungileyo.
\q1 Ake ungiphumuze ekuhlulukelweni engikukho;
\q2 woba lomusa kimi njalo uzwe umkhuleko wami.
\b
\q1 
\v 2 Koze kube nini, we bantu,
\q2 koze kube nini inkazimulo yami liyenza ihlazo?
\q1 Koze kube nini lithanda inkohliso
\q2 njalo lidinga onkulunkulu bamanga?
\q1 
\v 3 Yazini ukuthi \nd uThixo\nd*
\q2 usezehlukanisele labo abathembekileyo,
\q2 njalo \nd uThixo\nd* uyezwa nxa ngikhala kuye.
\b
\q1 
\v 4 Ekuthukutheleni kwenu lingoni;
\q2 nxa lisemibhedeni yenu
\q2 hlolani inhliziyo zenu, lithule.
\q1 
\v 5 Nikelani imihlatshelo eqondileyo,
\q2 limethembe \nd uThixo\nd*.
\b
\q1 
\v 6 Abanengi bayabuza bathi,
\q2 “Kuvele ngubani ongasitshengisa ukulunga na?”
\q1 Sengathi ukukhanya kobuso bakho
\q2 kungakhazimula phezu kwethu, Oh \nd Thixo\nd*.
\q1 
\v 7 Uyigcwalisile inhliziyo yami ngentokozo enkulu
\q2 eyedlula ubunengi bamabele abo lewayini labo elitsha.
\b
\q1 
\v 8 Ngizalala phansi ngijunywe yibuthongo ngilokuthula,
\q2 ngoba wena wedwa,
\q2 Oh \nd Thixo\nd*, uhlezi ungilondolozile.
\c 5
\cl Ihubo 5
\d Kumqondisi wokuhlabela. Kwabemifece. Ihubo likaDavida.
\q1 
\v 1 Zwana amazwi ami, Oh \nd Thixo\nd*,
\q2 hawukela ukububula kwami.
\q1 
\v 2 Lalela ukukhala kwami ngidinga uncedo,
\q2 Nkosi yami loNkulunkulu wami,
\q2 ngoba ngikhuleka kuwe.
\b
\q1 
\v 3 Ekuseni, Oh \nd Thixo\nd*, uyalizwa ilizwi lami;
\q2 ekuseni ngibeka izicelo zami phambi kwakho
\q2 ngilinde ngithembile.
\q1 
\v 4 Kawusuye uNkulunkulu othokoza ngobubi;
\q2 ababi ngeke bahlale lawe.
\q1 
\v 5 Iziqholo ngeke zime
\q2 phambi kwakho;
\q1 uyabazonda bonke abenza okubi.
\q2 
\v 6 Uyababhubhisa labo abaqamba amanga;
\q1 abomele igazi labakhohlisayo
\q2 \nd uThixo\nd* uyabenyanya.
\q1 
\v 7 Kodwa mina, ngomusa wakho omkhulu,
\q2 ngizangena endlini yakho;
\q1 ngizakhothamela phansi ngokuhlonipha
\q2 ngikhangele ethempelini lakho elingcwele.
\b
\q1 
\v 8 Ngikhokhele, Oh \nd Thixo\nd*, ngokulunga kwakho;
\q2 ngenxa yezitha zami
\q2 yenza iqonde indlela yakho phambi kwami.
\q1 
\v 9 Kalikho lalinye ilizwi lomlomo wabo elithembekileyo;
\q2 inhliziyo yabo igcwele ukubhidliza.
\q1 Umphimbo wabo ulingcwaba elikhamisileyo;
\q2 ngolimi lwabo bakhuluma inkohliso.
\q1 
\v 10 Tshono uthi balecala, Oh Nkulunkulu!
\q2 Akuthi amacebo abo abe yikuwa kwabo.
\q1 Baxotshele khatshana ngenxa yezono zabo ezinengi,
\q2 ngoba bakuhlamukele wena.
\q1 
\v 11 Kodwa akuthi bonke abaphephela kuwe bathokoze;
\q2 kabahlabelele njalonjalo ngenjabulo.
\q1 Basibekele ngovikelo lwakho,
\q2 kuthi labo abalithandayo ibizo lakho bajabule ngawe.
\b
\q1 
\v 12 Ngoba ngempela, Oh \nd Thixo\nd*,
\q2 uyababusisa abalungileyo;
\q2 uyabazungeza ngomusa wakho njengesihlangu.
\c 6
\cl Ihubo 6
\d Kumqondisi wokuhlabela. Ngeleziginci. Kulandelwa \tl isheminithi.\tl* Ihubo likaDavida.
\q1 
\v 1 Oh \nd Thixo\nd* ungangikhalimeli ngolaka lwakho
\q2 njalo ungangitshayi uthukuthele.
\q1 
\v 2 Woba lomusa kimi, \nd Thixo\nd*,
\q2 ngoba ngiphela amandla;
\q2 Oh \nd Thixo\nd*, ngisilisa,
\q2 ngoba amathambo ami alobuhlungu.
\q1 
\v 3 Umoya wami udabukile.
\q2 Koze kube nini, Oh \nd Thixo\nd*,
\q2 koze kube nini?
\b
\q1 
\v 4 Phenduka, Oh \nd Thixo\nd*, ungikhulule;
\q2 ngihlenga ngenxa yothando lwakho olungehlulekiyo.
\q1 
\v 5 Kakho okukhumbulayo nxa esefile.
\q2 Ngubani okukhonzayo esengcwabeni lakhe?
\b
\q1 
\v 6 Ngikhathele ngokububula;
\q2 ubusuku bonke umbheda wami uba manzi te ngikhala
\q2 umendlalo wami ngiwugcwalise ngezinyembezi.
\q1 
\v 7 Amehlo ami ayafiphala ngenxa yosizi;
\q2 ayanqundeka ngenxa yazo zonke izitha zami.
\b
\q1 
\v 8 Xekani kimi lina lonke elenza okubi,
\q2 ngoba \nd uThixo\nd* usekuzwile ukulila kwami.
\q1 
\v 9 \nd UThixo\nd* usekuzwile ukukhala kwami ngicela umusa;
\q2 \nd UThixo\nd* uyawamukela umkhuleko wami.
\q1 
\v 10 Zonke izitha zami zizayangeka zidaniswe;
\q2 zizatshibilika zibuyele emuva masinyane sezilehlazo.
\c 7
\cl Ihubo 7
\d \tl Ishigayoni\tl* kaDavida ayihlabelela \nd uThixo\nd* mayelana loKhushi umBhenjamini.
\q1 
\v 1 Oh \nd Thixo\nd* Nkulunkulu wami,
\q2 ngiphephela kuwe;
\q2 ngisindisa ungikhulule kubo bonke abangizingelayo,
\q1 
\v 2 ngoba bazanginithiza njengesilwane
\q2 bangiklebule iziqanyana kungekho ongangilamulela.
\b
\q1 
\v 3 Oh \nd Thixo\nd*, Nkulunkulu wami, nxa ngikwenzile lokhu
\q2 izandla zami zilecala,
\q1 
\v 4 nxa ngenze okubi kulowo ohlalisene kuhle lami
\q2 loba ngisuke ngaphanga isitha sami kungelasizatho,
\q1 
\v 5 nxa kunjalo akuthi isitha sami singihlasele;
\q2 masigxobagxobele impilo yami emhlabathini
\q2 singibhuqabhuqele phansi ebhuqwini.
\b
\q1 
\v 6 Vuka, Oh \nd Thixo\nd*, ngolaka lwakho;
\q2 vuka uvimbele ukuthukuthela kwezitha zami.
\q1 Vuka, Nkulunkulu wami,
\q2 memezela ukwahlulela okuhle.
\q1 
\v 7 Akuthi abantu bebuthene bakuhanqe
\q2 busa phezu kwabo usekuphakameni.
\q2 
\v 8 \nd UThixo\nd* kahlulele bonke abantu.
\q1 Ngahlulele, Oh \nd Thixo\nd* ngokwanele ukulunga kwami,
\q2 ngokwanele ubuqotho bami, wena oPhezukonke.
\q1 
\v 9 Oh Nkulunkulu olungileyo,
\q2 ohlolisisa imicabango lezinhliziyo,
\q1 qeda udlakela lwababi
\q2 ukuze abalungileyo bavikeleke.
\b
\q1 
\v 10 Isihlangu sami nguNkulunkulu oPhezukonke,
\q2 osindisa abaqotho ngenhliziyo.
\q1 
\v 11 UNkulunkulu ngumahluleli olungileyo,
\q2 uNkulunkulu obonisa ulaka lwakhe insuku zonke.
\q1 
\v 12 Nxa umuntu engadeli ububi bakhe
\q2 uzalola inkemba yakhe;
\q2 uzaligoba alithiye idandili lakhe.
\q1 
\v 13 Usezilungisile izikhali zakhe ezibulalayo;
\q2 uselungisa imitshoko yakhe evutha umlilo.
\b
\q1 
\v 14 Lowo osuthiswe ngobubi
\q2 akhulelwe yikona uzala ukuphumputheka.
\q1 
\v 15 Lowo omba umgodi awuphande
\q2 uwela kulowomgodi awumbileyo.
\q1 
\v 16 Inkathazo ayidalileyo iyamphendukela;
\q2 lesihluku sakhe sehlela phezu kwekhanda lakhe.
\b
\q1 
\v 17 Ngizambonga \nd uThixo\nd* ngenxa yokulunga kwakhe;
\q2 ngizahlabelela indumiso egameni \nd likaThixo\nd* oPhezukonke.
\c 8
\cl Ihubo 8
\d Kumqondisi wokuhlabela. Ngendlela \tl yegithithi.\tl* Ihubo likaDavida.
\q1 
\v 1 Oh \nd Thixo\nd*, \nd Thixo\nd* wethu,
\q2 ibizo lakho libabazeka kangaka emhlabeni wonke!
\b
\q1 Uyibekile inkazimulo yakho
\q2 ngaphezulu emazulwini.
\q1 
\v 2 Ukumisile ukudunyiswa yizindebe zabantwana lensane
\q2 ngenxa yezitha zakho,
\q2 ukuze uthulise isitha lomphindiseli.
\q1 
\v 3 Nxa nginakana ngamazulu akho,
\q2 umsebenzi weminwe yakho,
\q1 inyanga lezinkanyezi
\q2 ozibeke endaweni yazo,
\q1 
\v 4 uyini umuntu osungaze uzihluphe ngaye na,
\q2 indodana yomuntu ukuba uyinanze?
\b
\q1 
\v 5 Wamenza waba mncinyazana kulezingilosi,
\q2 wamethesa umqhele wodumo lobukhosi.
\q1 
\v 6 Wamenza umbusi phezu kwemisebenzi yezandla zakho;
\q2 wabeka zonke izinto ngaphansi kwezinyawo zakhe:
\q1 
\v 7 yonke imihlambi yezimvu
\q2 leyenkomo lezinyamazana zeganga,
\q1 
\v 8 izinyoni zasemkhathini
\q2 lenhlanzi zolwandle,
\q2 konke okuntsheza emanzini olwandle.
\b
\q1 
\v 9 Oh \nd Thixo\nd*, \nd Thixo\nd* wethu,
\q2 ibizo lakho libabazeka kangaka emhlabeni wonke!
\c 9
\cl Ihubo 9
\d Kumqondisi wokuhlabelela. Ihlatshelwa njengengoma ethi “Ukufa kweNdodana.” Ihubo likaDavida.
\q1 
\v 1 Ngizakudumisa, Oh \nd Thixo\nd*, ngenhliziyo yami yonke;
\q2 ngizafakaza ngazozonke izimangaliso zakho.
\q1 
\v 2 Ngizathokoza ngijabule ngawe,
\q2 ngizahlabelela indumiso egameni lakho,
\q2 wena oPhezukonke.
\b
\q1 
\v 3 Izitha zami ziyafulathela zibaleke;
\q2 ziyakhubeka zitshabalale phambi kwakho.
\q1 
\v 4 Ngoba ulisekele ilungelo lami;
\q2 usuhlalile esihlalweni sakho sobukhosi
\q2 wahlulela kakuhle.
\q1 
\v 5 Uzikhuzile izizwe,
\q2 wababhubhisa ababi;
\q1 wawesula amabizo abo
\q2 kuze kube nini lanini.
\q1 
\v 6 Ukubhidlika okungapheliyo kusehlele isitha sami,
\q2 wawasiphuna amadolobho aso;
\q2 lokukhunjulwa kwaso sekuphele nya.
\b
\q1 
\v 7 \nd UThixo\nd* uyabusa kuze kube nininini;
\q2 usesimisile isihlalo sakhe sobukhosi ukuze ahlulele.
\q1 
\v 8 Uzabusa umhlaba ngokulunga
\q2 njalo uzakwahlulela abantu ngokufaneleyo.
\q1 
\v 9 \nd UThixo\nd* uyisiphephelo sabancindezelweyo,
\q2 uyinqaba ezikhathini zokuhlupheka.
\q1 
\v 10 Labo abalaziyo ibizo lakho bazathemba kuwe,
\q2 ngoba wena, \nd Thixo\nd*, kawubafulatheli abakudingayo.
\b
\q1 
\v 11 Hlabelelani indumiso \nd kuThixo\nd* esebukhosini eZiyoni;
\q2 fakazani phakathi kwezizwe
\q2 ngalokho akwenzileyo.
\q1 
\v 12 Ngoba yena ophindiselayo kulowo ochitha igazi uyakhumbula;
\q2 akakudeli ukukhala kwabahlukuluzwayo.
\b
\q1 
\v 13 Oh \nd Thixo\nd*, ake ubone ukuthi izitha zami zingichukuluza njani!
\q2 Yiba lesihawu ungenyule emasangweni okufa,
\q1 
\v 14 ukuze ngifakaze indumiso yakho
\q2 emasangweni eNdodakazi yaseZiyoni
\q1 kuthi khonale ngithokoze
\q2 ngokusindisa kwakho.
\b
\q1 
\v 15 Izizwe ziwele emgodini eziwumbileyo;
\q2 inyawo zazo zibanjwe emambuleni eziwathiyileyo.
\q1 
\v 16 \nd UThixo\nd* waziwa ngokwahlulela kwakhe okulungileyo;
\q2 ababi babanjwa yizenzo zezandla zabo.
\q1 
\v 17 Ababi babuyela engcwabeni,
\q2 zonke izizwe ezikhohlwa uNkulunkulu.
\q1 
\v 18 Kodwa abaswelayo kabayikukhohlakala kokuphela,
\q2 njalo lethemba labahlukuluzwayo kaliyikutshabalala.
\b
\q1 
\v 19 Vuka \nd Thixo\nd*, ungayekeli umuntu anqobe;
\q2 akuthi izizwe zahlulelwe phambi kwakho.
\q1 
\v 20 Batshayise ngovalo, Oh \nd Thixo\nd*;
\q2 akuthi izizwe zikwazi ukuthi zingabantu nje.
\c 10
\cl Ihubo 10
\q1 
\v 1 Kungani, Oh \nd Thixo\nd*, umela khatshana?
\q2 Kungani uzifihla ngezikhathi zokuhlupheka?
\q1 
\v 2 Ngobuqholo bakhe umuntu omubi uzingela ababuthakathaka,
\q2 abayengeka ngamacebo awakhayo.
\q1 
\v 3 Uzikhukhumeza ngezinkanuko zenhliziyo yakhe;
\q2 ubusisa abayizihwaba athuke \nd uThixo\nd*.
\q1 
\v 4 Ngenxa yokuzigqaja kwakhe omubi kamdingi \nd uThixo\nd*;
\q2 kuyo yonke imicabango yakhe akulandawo kaNkulunkulu.
\q1 
\v 5 Izindlela zakhe ziyaphumelela;
\q2 uyadelela njalo lemithetho yakho ikhatshana laye
\q2 aneme lapho ebona izitha zakhe.
\q1 
\v 6 Uthi, “Akulalutho olungangixukuxa;
\q2 ukuthokoza ngokwami lanini,
\q2 angiyikufa ngahlupheka.”
\b
\q1 
\v 7 Umlomo wakhe ugcwele amanga lenhlamba lezithuko;
\q2 ulimi lwakhe luqukethe uhlupho lobubi.
\q1 
\v 8 Ucathama ngaphandle kwemizi;
\q2 avumbuluke lapho abulale abantu abamsulwa,
\q2 ahlale ecatheme ekusithekeni.
\q1 
\v 9 Uyacathama njengesilwane ekusithekeni;
\q2 ucathamela labo abangelamandla;
\q3 uyabadumela abahudulele emambuleni akhe.
\q1 
\v 10 Ababambileyo uyabachoboza baphangalale;
\q2 uyabawisa ngamandla akhe.
\q1 
\v 11 Uzitshela athi, “UNkulunkulu usekhohliwe;
\q2 uyabugubuzela ubuso bakhe angabe esabona.”
\b
\q1 
\v 12 Vuka, \nd Thixo!\nd* Phakamisa isandla sakho,
\q2 Oh Nkulunkulu. Ungabakhohlwa abazihluphekelayo.
\q1 
\v 13 Kungani umuntu omubi ethuka uNkulunkulu na?
\q2 Kungani na ezitshela esithi,
\q2 “Kazukungithonisisa?”
\q1 
\v 14 Kodwa wena, Oh Nkulunkulu, uyalubona uhlupho losizi;
\q2 uyakunanzelela ukuze ulamule.
\q1 Ongelamandla uzilahla kuwe;
\q2 wena ungumsizi wezintandane.
\q1 
\v 15 Yephula ingalo yomuntu oxhwalileyo;
\q2 mthonisise ngokuganga kwakhe
\q2 obekuzahlala kungaziwa.
\b
\q1 
\v 16 \nd UThixo\nd* ungumbusi kuze kube nini lanini;
\q2 izizwe zizabhubha elizweni lakhe.
\q1 
\v 17 Uyazizwa, Oh \nd Thixo\nd*, izifiso zabancindezelweyo;
\q2 uyabaqinisa, ulalele ukukhala kwabo,
\q1 
\v 18 ulamulele izintandane labancindezelweyo,
\q2 ukuze kuthi umuntu, ongowasemhlabeni,
\q2 angabe esesabeka futhi.
\c 11
\cl Ihubo 11
\d Kumqondisi wokuhlabela. ElikaDavida.
\q1 
\v 1 Mina ngiphephela \nd kuThixo\nd*.
\q2 Pho ungatsho kanjani kimi ukuthi:
\q2 “Balekela entabeni yakho njengenyoni.
\q1 
\v 2 Ngoba, khangela, ababi sebewanwebile amadandili abo;
\q2 imitshoko yabo sebeyixhume ezintanjeni
\q1 ukuthi batshoke becatshile emathunzini
\q2 beciba labo abaqotho ezinhliziyweni.
\q1 
\v 3 Kambe nxa kubhidlizwa izisekelo,
\q2 kuyini abangakwenza abalungileyo na?”
\b
\q1 
\v 4 \nd UThixo\nd* usethempelini lakhe elingcwele;
\q2 \nd uThixo\nd* usesihlalweni sakhe sobukhosi basezulwini.
\q1 Uyawakhangela amadodana abantu;
\q2 amehlo akhe ayabahlola.
\q1 
\v 5 \nd UThixo\nd* uyabahlola abalungileyo,
\q2 kodwa ababi lalabo abathanda udlakela
\q2 uyabazonda ngomoya wakhe wonke.
\q1 
\v 6 Ababi uzabehlisela amalahle avuthayo lesalufa etshisayo;
\q2 umoya otshisayo uzabahaqaza.
\b
\q1 
\v 7 Ngoba \nd uThixo\nd* ulungile,
\q2 uthanda ukwahlulela okuhle;
\q2 abaqotho bazabubona ubuso bakhe.
\c 12
\cl Ihubo 12
\d Kumqondisi wokuhlabela. Ngendlela \tl yesheminithi.\tl* Ihubo likaDavida.
\q1 
\v 1 Siza \nd Thixo\nd*, ngoba kabasekho abakholwayo;
\q2 abathembekileyo sebenyamalele kabasekho ebantwini.
\q1 
\v 2 Bonke baqamba amanga kubomakhelwane babo;
\q2 izindebe zabo eziyengayo
\q2 zihlezi zikhuluma inkohliso esezinhliziyweni zabo.
\b
\q1 
\v 3 Sengathi \nd uThixo\nd* angaziquma zonke izindebe ezikhohlisayo
\q2 kanye laluphi ulimi oluzikhukhumezayo
\q1 
\v 4 oluthi, “Sizanqoba ngendimi zethu;
\q2 izindebe zethu zizasilwela
\q2 ngubani oyinkosi yethu na?”
\b
\q1 
\v 5 “Ngenxa yokuncindezelwa kwabayanga lokububula kwabaswelayo,
\q2 sengizavuka khathesi,” kutsho \nd uThixo\nd*.
\q2 “Ngizabavikela kulabo ababachukuluzayo.”
\q1 
\v 6 Njalo amazwi \nd kaThixo\nd* amsulwa,
\q2 njengesiliva esicengwe esithandweni somlilo esebumba,
\q2 njengegolide elihlanjululwe kasikhombisa.
\b
\q1 
\v 7 Oh \nd Thixo\nd*, uzahlala usiphephisile
\q2 njalo usivikele ebantwini ababi nini lanini.
\q1 
\v 8 Ababi bayaklamasa santando
\q2 nxa bebona izinto ezilihlazo zidunyiswa ngabantu.
\c 13
\cl Ihubo 13
\d Kumqondisi wokuhlabela. Ihubo likaDavida.
\q1 
\v 1 Koze kube nini, Oh \nd Thixo?\nd* Uzangikhohlwa lanininini na?
\q2 Koze kube nini ungifihlela ubuso bakho na?
\q1 
\v 2 Koze kube nini ngitshukumisana lemicabango yami,
\q2 inhliziyo yami ihlale idabukile insuku zonke na?
\q2 Koze kube nini isitha sami sitshakala phezu kwami?
\b
\q1 
\v 3 Ngizwela ungiphendule, Oh \nd Thixo\nd* Nkulunkulu wami.
\q2 Khanyisela amehlo ami funa ngihle ngilale kokuphela;
\q1 
\v 4 isitha sami sizakuthi, “Sengimehlule,”
\q2 labangizondayo bathokoze nxa ngisiwa.
\b
\q1 
\v 5 Kodwa ngiyalwethemba uthando lwabo olungapheliyo;
\q2 inhliziyo yami iyathokoza ngensindiso yakho.
\q1 
\v 6 Ngizahlabelela \nd kuThixo\nd*,
\q2 ngoba ungenzele ukulunga.
\c 14
\cl Ihubo 14
\d Kumqondisi wokuhlabela. KaDavida.
\q1 
\v 1 Isiwula sithi enhliziyweni yaso,
\q2 “AkulaNkulunkulu.”
\q1 Baxhwalile, izenzo zabo zibolile;
\q2 kakho loyedwa owenza okuhle.
\b
\q1 
\v 2 \nd UThixo\nd* ukhangela phansi esezulwini
\q2 emadodaneni abantu
\q1 ingabe bakhona yini abazwisisayo,
\q2 abamdingayo uNkulunkulu.
\q1 
\v 3 Bonke baphambukile, bonke sebexhwalile;
\q2 kakho loyedwa owenza okuhle,
\q2 kakho lamunye.
\b
\q1 
\v 4 Kanti lezizixhwali kaziyikufa zafunda yini?
\b
\q1 Zona ezidla abantu bami ingathi zidla isinkwa,
\q2 ezingamkhonziyo \nd uThixo\nd*.
\q1 
\v 5 Kodwa yibo abagubhazeliswa luvalo
\q2 ngoba uNkulunkulu ukhona phakathi kwabalungileyo.
\q1 
\v 6 Lina benzi bobubi lifubisa amalungiselelo abayanga,
\q2 kodwa \nd uThixo\nd* uyisiphephelo sabo.
\b
\q1 
\v 7 Awu, sengathi insindiso ka-Israyeli ingaqhamuka eZiyoni!
\q2 Nxa \nd uThixo\nd* esebuyisela impumelelo yabantu bakhe,
\q2 kathokoze uJakhobe lo-Israyeli ajabule!
\c 15
\cl Ihubo 15
\d Ihubo likaDavida.
\q1 
\v 1 \nd Thixo\nd*, ngubani ongahlala endlini yakho engcwele na?
\q2 Ngubani ongahlala entabeni yakho engcwele na?
\b
\q1 
\v 2 Ngulowo okuhamba kwakhe kungelansolo
\q2 njalo owenza okulungileyo,
\q2 okhuluma iqiniso liphuma enhliziyweni yakhe,
\q1 
\v 3 ongachothoziyo ngolimi lwakhe,
\q2 ongoneli umakhelwane wakhe
\q2 futhi ongagconi umzalwane wakhe,
\q1 
\v 4 oweyisa umuntu oxhwalileyo
\q2 kodwa ohlonipha labo abesaba \nd uThixo\nd*,
\q2 ogcina isifungo sakhe loba kubuhlungu ukwenzenjalo,
\q1 
\v 5 owebolekisa imali yakhe engadingi inzuzo
\q2 njalo owalayo ukuthengwa ukuze kwetheswe umlandu kongelacala.
\b
\q1 Lowo owenza lezizinto
\q2 akayikuzanyazanyiswa lanini.
\c 16
\cl Ihubo 16
\d \tl Imikithamu\tl* kaDavida.
\q1 
\v 1 Ngilondoloza, Oh Nkulunkulu,
\q2 ngoba ngiphephela kuwe.
\b
\q1 
\v 2 Ngathi \nd kuThixo\nd*, \nd “UnguThixo\nd* wami;
\q2 ngaphandle kwakho angilakho okuhle.”
\q1 
\v 3 Labo abangcwele abakhona elizweni
\q2 bangabakhazimulayo engithokoza ngabo.
\q1 
\v 4 Labo abagijimela abanye onkulunkulu inhlupho zabo zizakwanda.
\q2 Angiyi kuyithulula iminikelo yegazi kubonkulunkulu labo
\q2 njalo amabizo abo kawayikuphuma kwezami izindebe.
\b
\q1 
\v 5 \nd Thixo\nd*, usungahlukanisele isabelo sami kanye lenkezo yami;
\q2 konke okwami usukumise kuhle.
\q1 
\v 6 Imingcele yesabelo sami idabula ezindaweni ezibukekayo;
\q2 ngeqiniso elami ilifa liyathokozisa.
\q1 
\v 7 Ngizamdumisa \nd uThixo\nd*, onguye ongelulekayo;
\q2 lasebusuku inhliziyo yami iyangiqondisa.
\q1 
\v 8 Ngikhangele \nd kuThixo\nd* kokuphela.
\q2 Njengoba esesandleni sami sokunene angiyi kunyikinywa.
\b
\q1 
\v 9 Ngakho-ke inhliziyo yami iyathokoza lolimi lwami luyajabula;
\q2 lomzimba wami uzaphumula uvikelekile,
\q1 
\v 10 ngoba kawuzukungiyekela ngize ngiye endaweni yabafileyo,
\q2 njalo kawusoze wekele othembekileyo wakho ezwe ukubola.
\q1 
\v 11 Usungazisile indlela yempilo;
\q2 uzangigcwalisa ngokuthaba phambi kwakho,
\q2 ngenjabulo engapheliyo kwesokunene sakho.
\c 17
\cl Ihubo 17
\d Umkhuleko kaDavida.
\q1 
\v 1 Zwana, Oh \nd Thixo\nd*, ukuncenga kwami okulungileyo;
\q2 lalela ukukhala kwami.
\q1 Zwana umkhuleko wami,
\q2 kawusuki ezindebeni ezikhohlisayo.
\q1 
\v 2 Ukugezwa kwami ecaleni kakuvele kuwe;
\q2 sengathi amehlo Akho angabona lokho okuqondileyo.
\b
\q1 
\v 3 Udungulule inhliziyo yami
\q2 wangihlola ebusuku wangilinga,
\q1 kawuyikufumana lutho olubi engiluhlelileyo;
\q2 sengizimisele ukuthi umlomo wami ungenzi sono.
\q1 
\v 4 Mayelana lezenzo zabantu,
\q2 mina ngizazithiba ezindleleni zobudlwangudlwangu
\q2 ngelizwi lezindebe zakho.
\q1 
\v 5 Izinyathelo zami zalela ezindleleni zakho;
\q2 inyawo zami kazizange zitshelele.
\b
\q1 
\v 6 Ngikhala kuwe, Oh Nkulunkulu ngoba uzangiphendula;
\q2 ngilalela uzwe umkhuleko wami.
\q1 
\v 7 Tshengisa ukumangalisa kothando lwakho olukhulu,
\q2 wena osindisa ngesandla sakho sokunene,
\q2 labo ababalekela kuwe ezitheni zabo.
\q1 
\v 8 Ngilondoloza njengegugu lakho;
\q2 ngifihla emthunzini wamaphiko akho
\q1 
\v 9 kwababi abangihlaselayo,
\q2 ezitheni zami ezimbi ezingihanqileyo.
\b
\q1 
\v 10 Bagcika inhliziyo zabo ezingelazwelo,
\q2 lemilomo yabo ikhuluma iqholoza.
\q1 
\v 11 Sebeze bangithola, manje sebengihanqile
\q2 bangiqhuzulele amehlo bafuna ukungilahla phansi.
\q1 
\v 12 Banjengesilwane silambele loba yini esingayidumela,
\q2 njengesilwane esesabekayo siquthile sicatshile.
\b
\q1 
\v 13 Phakama, Oh \nd Thixo\nd*, basukele, balahle phansi;
\q2 ngilamulela kwababi ngenkemba yakho.
\q1 
\v 14 Oh \nd Thixo\nd*, ngisindisa ngesandla sakho ebantwini abanjalo,
\q2 ebantwini bakulumhlaba omvuzo wabo ukuyonale impilo.
\q1 Udedisa iphango lalabo obathandayo;
\q2 amadodana abo akhomba ngophakathi;
\q2 baqoqela abantwababo inotho.
\b
\q1 
\v 15 Mina-ke ngenxa yokulunga ngizabubona ubuso bakho;
\q2 ngizakuthi ekuvukeni kwami nganeliswe yikubona isimo sakho.
\c 18
\cl Ihubo 18
\d Kumqondisi wokuhlabela. ElikaDavida inceku \nd kaThixo\nd* Wahlabelela uJehova amazwi alelihubo lapho uJehova wamsindisa esandleni sezitha zakhe zonke lasesandleni sikaSawuli. Wathi:
\q1 
\v 1 Ngiyakuthanda, Oh \nd Thixo\nd*, Mandla ami.
\b
\q1 
\v 2 \nd UThixo\nd* ulidwala lami, inqaba yami, lomsindisi wami;
\q2 uNkulunkulu wami ulidwala lami, lapho engiphephela khona,
\q2 isihlangu sami lophondo lokusindiswa kwami, inqaba yami.
\b
\q1 
\v 3 Ngakhuleka \nd kuThixo\nd* ofanele ukudunyiswa
\q2 njalo ngikhululwe ezitheni zami.
\q1 
\v 4 Izibopho zokufa zangihilela;
\q2 lezikhukhula zokubhubhisa zangikhulela.
\q1 
\v 5 Izibopho zengcwaba zangithandela;
\q2 imijibila yokufa yangijamela.
\b
\q1 
\v 6 Ekukhathazekeni kwami ngakhuleka \nd kuThixo\nd*;
\q2 ngakhala kuNkulunkulu wami ngicela usizo.
\q1 Walizwa ilizwi lami esethempelini lakhe;
\q2 ukukhala kwami kwafinyelela kuye,
\q2 ezindlebeni zakhe.
\q1 
\v 7 Umhlaba wagedezela wazamazama,
\q2 izisekelo zezintaba zanyikinyeka;
\q2 zagedezela ngoba wayethukuthele.
\q1 
\v 8 Intuthu yalanquka emakhaleni Akhe
\q2 umlilo ohangulayo waphuma emlonyeni wakhe,
\q2 amalahle avuthayo alavuka ephuma kuwo.
\q1 
\v 9 Waqhekeza amazulu wehlela phansi;
\q2 amayezi amnyama
\q2 ayengaphansi kwezinyawo zakhe
\q1 
\v 10 Wagada amakherubhi waphapha;
\q2 wantweza phezu kwamaphiko omoya.
\q1 
\v 11 Wenza umnyama isembeso sakhe,
\q2 isigubuzelo esimhanqileyo,
\q2 amayezi ezulu amnyama asemkhathini.
\q1 
\v 12 Phakathi kokukhazimula kobukhona bakhe
\q2 kwaqubuka amayezi,
\q2 kulesiqhotho lezikhatha zombane.
\q1 
\v 13 \nd UThixo\nd* wakhwaza esezulwini;
\q2 ilizwi loPhezukonke lanqenqetha.
\q1 
\v 14 Waciba imitshoko wazihlakaza izitha,
\q2 ngembane eminengi waziqothula.
\q1 
\v 15 Izigodi zolwandle zambulwa
\q2 lezisekelo zomhlaba zavezwa obala
\q1 ekukhuzeni kwakho \nd Thixo\nd*,
\q2 ngomfutho wokuphefumula kwamakhala akho.
\b
\q1 
\v 16 Welula isandla Sakhe esezulwini
\q2 wangibamba wangihlenga enzikini yamanzi.
\q1 
\v 17 Wangihlenga esitheni sami esilamandla,
\q2 ezitheni zami ezazingigabhela ngamandla.
\q1 
\v 18 Zangijamela mhla ngisebunzimeni,
\q2 kodwa \nd uThixo\nd* waba yinsika yami.
\q1 
\v 19 Wangikhupha wangibeka endaweni ebanzi
\q2 wangihlenga ngoba wayethokoza ngami.
\b
\q1 
\v 20 \nd UThixo\nd* ungenzele okulingene ukulunga kwami;
\q2 wanginika umvuzo ngokufanele ukuhlanzeka kwezandla zami.
\q1 
\v 21 Ngoba ngizigcinile izindlela \nd zikaThixo\nd*;
\q2 angenzanga okubi ngokufulathela uNkulunkulu wami.
\q1 
\v 22 Yonke imithetho yakhe ibiphambi kwami;
\q2 angizifulathelanga izimiso zakhe.
\q1 
\v 23 Ngibe ngilokhu ngimsulwa phambi kwakhe
\q2 njalo ngisixwayile isono.
\q1 
\v 24 \nd UThixo\nd* unginike umvuzo ngokufanele ukulunga kwami,
\q2 ngokufanele ukuhlanzeka kwezandla zami phambi Kwakhe.
\b
\q1 
\v 25 Kwabathembekileyo lawe uthembekile,
\q2 kwabamsulwa lawe umsulwa.
\q1 
\v 26 Kwabahlanzekileyo uziveza uhlanzekile
\q2 kodwa kwabangaqondanga uziveza ukhaliphile.
\q1 
\v 27 Uyabasindisa abathobekileyo;
\q2 kodwa uyabehlisela phansi labo abamehlo asesiphundu.
\q1 
\v 28 Wena, Oh \nd Thixo\nd*, gcina isibane sami sibhebha;
\q2 uNkulunkulu wami uguqula umnyama wami ube yikukhanya.
\q1 
\v 29 Ngosizo lwakho ngingaphuma ngimelane lebutho lempi;
\q2 ngoNkulunkulu wami ngingaweqa umduli.
\b
\q1 
\v 30 Izindlela zikaNkulunkulu uqobo lwakhe ziphelele;
\q2 ilizwi \nd likaThixo\nd* kalilasici.
\q2 Ulihawu labo bonke abaphephela kuye.
\q1 
\v 31 Ngoba ngubani uNkulunkulu ngaphandle \nd kukaThixo?\nd*
\q2 Njalo ngubani oliDwala ngaphandle kukaNkulunkulu wethu na?
\q1 
\v 32 NguNkulunkulu ongihlomisa amandla
\q2 enze indlela yami iphelele.
\q1 
\v 33 Wenza inyawo zami zibe njengezempala;
\q2 ungenza ngime ezingqongweni
\q1 
\v 34 Ufundisa izandla zami ukulwa impi;
\q2 izingalo zami zingaligobisa idandili lethusi.
\q1 
\v 35 Wena uyanginika isihlangu sakho sokunqoba,
\q2 lesandla sakho sokunene siyangiqinisa;
\q2 uyazehlisela phansi ukuze ungenze ngibe mkhulu.
\q1 
\v 36 Uqhelisa indlela enginyathela kuyo,
\q2 ukuze inqagala zami zingapheci.
\b
\q1 
\v 37 Ngaxotshana lezitha zami ngazifica;
\q2 kangiphendukanga ngingakazibhubhisi zonke.
\q1 
\v 38 Ngazichoboza, zazingeke zisavuka;
\q2 zawela ngaphansi kwezinyawo zami
\q1 
\v 39 Wangihlomisa ngamandla okulwa impi;
\q2 wenza abaxabana lami bakhothama ezinyaweni zami.
\q1 
\v 40 Wenza izitha zami zafulathela zabaleka,
\q2 njalo ngazibhubhisa izitha zami.
\q1 
\v 41 Bakhala becela uncedo, kodwa wayengekho owayengabalamulela
\q2 \nd kuThixo\nd*, kodwa kaphendulanga.
\q1 
\v 42 Ngabatshaya bacholeka njengothuli luphetshulwa ngumoya;
\q2 ngabathulula njengodaka ezindleleni.
\q1 
\v 43 Ungikhulule ekuhlaselweni yilababantu;
\q2 usungenze ngaba yinhloko yezizwe;
\q1 abantu engangingabazi sebebuswa yimi.
\q2 
\v 44 Bathi bengizwa nje ngendaba, bangilalele;
\q2 abezizweni bayatshotshobala phambi kwami.
\q1 
\v 45 Bonke badelile;
\q2 beza bethuthumela bevela ezinqabeni zabo.
\b
\q1 
\v 46 \nd Uthixo\nd* uyaphila!
\q2 Alidunyiswe iDwala lami!
\q2 Kaphakanyiswe uNkulunkulu uMsindisi wami!
\q1 
\v 47 UnguNkulunkulu ongiphindiselelayo,
\q2 onqoba izizwe zibe ngaphansi kwami,
\q2 
\v 48 ongisindisayo ezitheni zami.
\q1 Wena wangikhuphula ngaphezu kwezitha zami;
\q2 wangihlenga ebantwini bodlakela.
\q1 
\v 49 Ngakho ngizakudumisa phakathi kwezizwe, Oh \nd Thixo\nd*;
\q2 ngizahlabelela indumiso yebizo lakho.
\b
\q1 
\v 50 Upha inkosi yakhe ukunqoba okukhulu;
\q2 utshengisa umusa wakhe ongaphuthiyo kogcotshiweyo wakhe,
\q2 kuDavida kanye lezizukulwane zakhe kuze kube nininini.
\c 19
\cl Ihubo 19
\d Kumqondisi wokuhlabela. Ihubo likaDavida.
\q1 
\v 1 Amazulu afakaza inkazimulo kaNkulunkulu;
\q2 lomkhathi utshumayela umsebenzi wezandla zakhe.
\q1 
\v 2 Usuku ngosuku lezizinto ziyakhuluma;
\q2 ubusuku lobusuku zibonisa ulwazi.
\q1 
\v 3 Akula nkulumo, akula mazwi
\q2 ilizwi lazo alizwakali.
\q1 
\v 4 Kodwa Ilizwi lazo lizwakala emhlabeni wonke,
\q2 amazwi azo afika emikhawulweni yomhlaba.
\q1 Emazulwini uNkulunkulu uselakhele ithente ilanga.
\q2 
\v 5 Lona linjengomyeni ephuma exhibeni lakhe,
\q2 njengentshantshu ethakazelela ukugijima ibanga layo.
\q1 
\v 6 Liphuma emkhawulweni wamazulu
\q2 lihambe indlela yalo liyotshona ngakuloyana;
\q2 kakukho okusithekileyo ekutshiseni kwalo.
\b
\q1 
\v 7 Umthetho \nd kaThixo\nd* uphelele
\q2 uvuselela umphefumulo.
\q1 Izimiso \nd zikaThixo\nd* zithembekile,
\q2 zihlakaniphisa izithutha.
\q1 
\v 8 Iziqondiso \nd zikaThixo\nd* zilungile,
\q2 ziletha ukuthokoza enhliziyweni.
\q1 Imilayo \nd kaThixo\nd* isobala,
\q2 iletha ukukhanya emehlweni.
\q1 
\v 9 Ukumesaba \nd uThixo\nd* kuhlanzekile,
\q2 kumi kuze kube phakade.
\q1 Izahlulelo \nd zikaThixo\nd* ziqinisekile
\q2 njalo zilungile ngokupheleleyo.
\b
\q1 
\v 10 Ziligugu okudlula igolide,
\q2 okudlula igolide elinengi elicengekileyo;
\q1 zimnandi kuloluju,
\q2 uluju olujuluka ohlangeni.
\q1 
\v 11 Ngazo inceku yakho iyacetshiswa;
\q2 ukuzilandela kulomvuzo omkhulu.
\q1 
\v 12 Ngubani ongazizwisisa iziphambeko zakhe?
\q2 Thethelela iziphambeko zami ezisithekileyo.
\q1 
\v 13 Phephisa inceku yakho ezonweni zamabomo;
\q2 sengathi zingeze zabusa phezu kwami.
\q1 Lapho ngizakuba msulwa
\q2 ngingabi lacala lokona okukhulu.
\b
\q1 
\v 14 Sengathi amazwi omlomo wami leminakano yenhliziyo yami
\q2 kungathokozisa emehlweni akho,
\q2 Oh \nd Thixo\nd*, Dwala lami loMhlengi wami.
\c 20
\cl Ihubo 20
\d Kumqondisi wokuhlabela. Ihubo likaDavida.
\q1 
\v 1 Sengathi \nd uThixo\nd* angakuphendula nxa usenkathazweni;
\q2 sengathi ibizo likaNkulunkulu kaJakhobe lingakuvikela.
\q1 
\v 2 Sengathi angakuthumela usizo luvela endlini engcwele
\q2 njalo akunike ukuhlomulela kuvela eZiyoni.
\q1 
\v 3 Sengathi angakhumbula yonke imihlatshelo yakho
\q2 njalo emukele iminikelo yakho yokutshiswa.
\q1 
\v 4 Sengathi angakupha isifiso senhliziyo yakho
\q2 enze izimiso zakho zonke ziphumelele.
\q1 
\v 5 Sizamemeza ngokujabula lapho usunqobile,
\q2 siphakamise uphawu lwethu egameni likaNkulunkulu wethu.
\b
\q1 Sengathi \nd uThixo\nd* angakupha zonke izicelo zakho.
\b
\q1 
\v 6 Manje sengisazi ukuthi
\q2 \nd uThixo\nd* uyamhlenga ogcotshiweyo wakhe;
\q1 uyamphendula esezulwini lakhe elingcwele
\q2 ngamandla Akhe asindisayo awesandla Sakhe sokunene.
\q1 
\v 7 Abanye bathemba izinqola zempi,
\q2 abanye amabhiza,
\q2 kodwa thina sithemba ibizo \nd likaThixo\nd* uNkulunkulu wethu.
\q1 
\v 8 Bafuqelwa phansi bawe,
\q2 kodwa thina siyaphakama sime sigxile.
\q1 
\v 9 Oh \nd Thixo\nd*, sindisa inkosi!
\q2 Sabela lapho simemeza!
\c 21
\cl Ihubo 21
\d Kumqondisi wokuhlabela. Ihubo likaDavida.
\q1 
\v 1 Yebo \nd Thixo\nd* umbusi uyathokoza ngamandla akho.
\q2 Kukhulu ukuthokoza kwakhe ngokunqoba akuphiwa nguwe!
\b
\q1 
\v 2 Usumphile isiloyiso senhliziyo yakhe
\q2 njalo kawumncitshanga isicelo sezindebe zakhe.
\q1 
\v 3 Wamemukela ngezibusiso ezinhle
\q2 wamethesa umqhele wegolide elicengekileyo ekhanda lakhe.
\q1 
\v 4 Wacela kuwe ukusila,
\q2 wamupha ubude bezinsuku kuze kube nini lanini.
\q1 
\v 5 Ngokunqoba akuphiwe nguwe
\q2 lukhulu udumo lwakhe;
\q2 usumgqizise inkazimulo lobukhosi.
\q1 
\v 6 Ngempela usumuphe izibusiso ezingapheliyo
\q2 wamenza wajabula ngentokozo yobukhona Bakho.
\q1 
\v 7 Ngoba umbusi uyamthemba \nd uThixo\nd*;
\q2 ngothando loPhezukonke olungaphuthiyo
\q2 akayikuzanyazanyiswa.
\b
\q1 
\v 8 Isandla Sakho sizazibamba zonke izitha Zakho;
\q2 isandla Sakho sokunene sizabaxhakalaza abakuzondayo.
\q1 
\v 9 Kuzakuthi lapho uqhamuka wena
\q2 uzabenza babe njengomlilo wemvutho enkulu.
\q1 Ngenxa yentukuthelo yakhe \nd uThixo\nd* uzabaginya,
\q2 umlilo wakhe uzabaqothula.
\q1 
\v 10 Wena uzabhubhisa izizukulwane zabo emhlabeni,
\q2 inzalo yabo ebantwini.
\q1 
\v 11 Loba beceba okubi Ngawe
\q2 besakha amaqhinga amabi, abangeke baphumelele;
\q1 
\v 12 ngoba uzabenza bafulathele babaleke
\q2 nxa usubakhombela usulinwebile idandili.
\b
\q1 
\v 13 Phakanyiswa, Oh \nd Thixo\nd* ngamandla Akho;
\q2 sizahlabela sibabaze amandla Akho.
\c 22
\cl Ihubo 22
\d Kumqondisi wokuhlabela. Kulandela itshuni ethi, “Impalakazi yekuSeni.” Ihubo likaDavida.
\q1 
\v 1 Nkulunkulu wami, Nkulunkulu wami, kungani usungidelile na?
\q2 Kungani ukhatshana kokungisindisa,
\q2 khatshana kwamazwi okububula kwami?
\q1 
\v 2 Oh Nkulunkulu wami, ngiyakhala emini,
\q2 kodwa kawuphenduli;
\q2 ebusuku, kangithulanga.
\b
\q1 
\v 3 Kanti usesihlalweni sobukhosi uNguye oNgcwele
\q2 uyindumiso ka-Israyeli.
\q1 
\v 4 Obaba babeka ithemba labo Kuwe;
\q2 bona bathemba wena wabakhulula.
\q1 
\v 5 Bakhala kuwe bakhululwa;
\q2 bathemba kuwe kabaze badaniswa.
\b
\q1 
\v 6 Kodwa ngiyimpethu nje kangisumuntu,
\q2 ngihozwa ngabantu njalo abanengi bangeyise.
\q1 
\v 7 Bonke abangibonayo bayangihleka;
\q2 bayangithethisa baze banyikinye amakhanda:
\q1 
\v 8 “Uthemba \nd uThixo\nd*
\q2 lowo \nd Thixo\nd* kamkhulule.
\q2 Kamsindise njengoba ethokoza ngaye.”
\b
\q1 
\v 9 Kanti wena wangikhupha esiswini;
\q2 wangenza ngakuthemba kusukela ebeleni likamama.
\q1 
\v 10 Kusukela ekuzalweni kwami ngabekwa ezandleni Zakho;
\q2 kusukela esiswini sikamama ulokhu unguNkulunkulu wami.
\b
\q1 
\v 11 Ungabi khatshana kwami,
\q2 ngoba uhlupho luseduze njalo
\q2 kakho ongangisiza.
\b
\q1 
\v 12 Inkunzi ezinengi zingihanqile;
\q2 inkunzi ezilamandla zaseBhashani zingihonqolozele.
\q1 
\v 13 Izilwane ezibhongayo ezibamba zidabudabule
\q2 zingikhamisela imilomo yazo.
\q1 
\v 14 Ngiyathululeka njengamanzi,
\q2 njalo amathambo ami wonke akhumukile.
\q1 Inhliziyo yami isiphenduke yaba yingcino;
\q2 isincibilikile ngaphakathi kwami.
\q1 
\v 15 Amandla ami asetshile qhu ingathi ludengezi,
\q2 lolimi lwami luyanamathela elwangeni lwami;
\q2 uyangilalisa othulini lokufa.
\b
\q1 
\v 16 Izinja sezingihanqile;
\q2 ixuku labantu ababi selingihonqolozele,
\q2 sebengigwaze izandla lezinyawo.
\q1 
\v 17 Ngingawabala wonke amathambo ami;
\q2 abantu bayanginyonkoloza bangiklolodele.
\q1 
\v 18 Behlukaniselana izembatho zami
\q2 njalo benze inkatho ngezigqoko zami.
\b
\q1 
\v 19 Kodwa wena, \nd Thixo\nd*, ungabi kude lami.
\q2 Ungamandla ami, woza masinyane uzongisiza.
\q1 
\v 20 Phephisa impilo yami enkembeni,
\q2 impilo yami eligugu emandleni azo izinja.
\q1 
\v 21 Ngilamulela emlonyeni wezilwane;
\q2 ngisindisa empondweni zezinyathi.
\b
\q1 
\v 22 Ngizamemezela ibizo Lakho kubafowethu;
\q2 emphakathini ngizakudumisa.
\q1 
\v 23 Lina elimesabayo \nd uThixo\nd*, mdumiseni!
\q2 Lani lina zizukulwane zikaJakhobe, mbabazeni!
\q2 Mhlonipheni, lina lonke zizukulwane zika-Israyeli!
\q1 
\v 24 Ngoba keyisanga loba adelele
\q2 ukuhlupheka kwalowo ohlukuluzwayo;
\q1 kamfihlelanga ubuso bakhe
\q2 kodwa walalela ukukhala kwakhe ecela ukusizwa.
\b
\q1 
\v 25 Sivela kuwe isithathelo sokudumisa kwami emhlanganweni omkhulu;
\q2 ngizagcwalisa izifungo zami phambi kwalabo abakwesabayo.
\q1 
\v 26 Abayanga bazakudla basuthe
\q2 labo abamdingayo \nd uThixo\nd* bazamdumisa
\q2 sengathi inhliziyo zenu zingaphila nini lanini!
\b
\q1 
\v 27 Yonke imikhawulo yomhlaba
\q2 izakhumbula iphendukele \nd kuThixo\nd*,
\q1 njalo lezimuli zonke zezizwe
\q2 zizakhothama phansi phambi kwakhe,
\q1 
\v 28 ngoba umbuso \nd ungokaThixo\nd*
\q2 njalo uyabusa phezu kwezizwe.
\b
\q1 
\v 29 Zonke izinothi zomhlaba zizazitika ngokudla
\q2 njalo zikhonze;
\q1 bonke abangena othulini bazaguqa phambi Kwakhe
\q2 labo abangeke baziphilise.
\q1 
\v 30 Abesikhathi esizayo bazamkhonza;
\q2 izizukulwane zizakwaziswa ngoThixo.
\q1 
\v 31 Bazatshumayela ukulunga kwakhe,
\q2 ebantwini abangakazalwa
\q2 ngoba ukwenzile Yena.
\c 23
\cl Ihubo 23
\d Ihubo likaDavida.
\q1 
\v 1 \nd UThixo\nd* ungumelusi wami, angiyikuswela lutho.
\q2 
\v 2 Ungilalisa emadlelweni aluhlaza,
\q1 ungikhokhelela emanzini apholileyo,
\q2 
\v 3 uvuselela umphefumulo wami.
\q1 Uyangihola ezindleleni zokulunga
\q2 ngenxa yebizo lakhe.
\q1 
\v 4 Loba ngidabula
\q2 esigodini sethunzi lokufa,
\q1 angiyikwesaba okubi
\q2 ngoba wena ulami;
\q1 intonga Yakho lodondolo Lwakho
\q2 kuyangiduduza.
\b
\q1 
\v 5 Ulungisa itafula phambi kwami
\q2 emehlweni ezitha zami.
\q1 Ugcoba ikhanda lami ngamafutha;
\q2 inkomitsho yami igcwele iyaphuphuma.
\q1 
\v 6 Impela okuhle lothando kuzangilandela
\q2 zonke insuku zokuphila kwami,
\q1 njalo ngizahlala endlini \nd kaThixo\nd*
\q2 kuze kube nininini.
\c 24
\cl Ihubo 24
\d Ihubo likaDavida.
\q1 
\v 1 Umhlaba \nd ngokaThixo\nd*, lakho konke okukuwo,
\q2 ilizwe labo bonke abahlala kulo;
\q1 
\v 2 ngoba wenza isisekelo sawo phezu kolwandle
\q2 wawumisa phezu kwamanzi.
\b
\q1 
\v 3 Ngubani ongaqansa intaba \nd kaThixo\nd* na?
\q2 Ngubani ongema endaweni yakhe engcwele na?
\q1 
\v 4 Ngulowo olezandla ezihlanzekileyo lenhliziyo emhlophe,
\q2 ongaphakamiseli umphefumulo wakhe kunkulunkulu wamanga
\q2 loba afunge ngenkohliso.
\b
\q1 
\v 5 Uzakwamukela isibusiso \nd kuThixo\nd*
\q2 lokukhululwa kuNkulunkulu uMsindisi wakhe.
\q1 
\v 6 Sinjalo isizukulwane salabo abamdingayo,
\q2 abadinga ubuso Bakho, Oh Nkulunkulu kaJakhobe.
\b
\q1 
\v 7 Phakamisani amakhanda enu, lina masango;
\q2 phakamani, lina minyango yekadeni,
\q2 ukuba iNkosi yenkazimulo ingene.
\q1 
\v 8 Ngubani iNkosi yenkazimulo?
\q2 \nd NguThixo\nd* oqinileyo olamandla,
\q2 \nd uThixo\nd* olamandla empini.
\q1 
\v 9 Phakamisani amakhanda enu, lina masango;
\q2 aphakamiseni, lina minyango yekadeni,
\q2 ukuba iNkosi yenkazimulo ingene.
\q1 
\v 10 Ungubani na lowo \nd Thixo\nd* wenkazimulo?
\q2 \nd NguThixo\nd* uSomandla
\q2 iNkosi yenkazimulo.
\c 25
\cl Ihubo 25
\d ElikaDavida.
\q1 
\v 1 Kuwe, \nd Thixo\nd*,
\q2 ngiphakamisela umphefumulo wami.
\b
\q1 
\v 2 Ngethemba kuwe,
\q2 ungangiyekeli ngiyangeka,
\q2 futhi ungayekeli izitha zami zinginqobe.
\q1 
\v 3 Kakukho bani othemba lakhe likuwe
\q2 ozayangiswa lanini,
\q1 kodwa bazayangiswa
\q2 abadinga ukulimaza kungelasizatho.
\b
\q1 
\v 4 Ngibonisa izindlela Zakho, Oh \nd Thixo\nd*,
\q2 ngifundisa izindlela Zakho;
\q1 
\v 5 ngikhokhela eqinisweni Lakho ungifundise
\q2 ngoba unguNkulunkulu, uMsindisi wami,
\q2 lethemba lami likuwe insuku zonke.
\q1 
\v 6 Khumbula, Oh \nd Thixo\nd*, isihawu Sakho esikhulu kanye lothando,
\q2 ngoba konke kuvela ekadeni.
\q1 
\v 7 Ungakhumbuli izono zobutsha bami
\q2 lezindlela zokuhlamuka kwami;
\q1 ngikhumbula ngokufanele uthando Lwakho,
\q2 ngoba ulungile, Oh \nd Thixo\nd*.
\b
\q1 
\v 8 \nd UThixo\nd* ulungile, uqotho;
\q2 ngakho weluleka izoni ngezindlela zakhe.
\q1 
\v 9 Uhola abathobekileyo kulokho okuqondileyo
\q2 abafundise indlela yakhe.
\q1 
\v 10 Zonke izindlela \nd zikaThixo\nd* zilothando, ziyathembeka
\q2 kulabo abagcina izimiso zesivumelwano Sakhe.
\q1 
\v 11 Ngenxa yegama Lakho, Oh \nd Thixo\nd*,
\q2 thethelela ububi bami, loba bubukhulu.
\b
\q1 
\v 12 Ngubani-ke umuntu omesabayo \nd uThixo?\nd*
\q2 Uzameluleka ngaleyondlela ayimiselweyo.
\q1 
\v 13 Uzaphila insuku zakhe ekhomba ngophakathi,
\q2 lezizukulwane zakhe zizakudla ilifa lelizwe.
\q1 
\v 14 Bayathenjwa \nd nguThixo\nd* labo abamesabayo;
\q2 ubenza basazi isivumelwano Sakhe.
\q1 
\v 15 Amehlo ami ahlezi \nd ekuThixo\nd* lanini,
\q2 ngoba nguye kuphela ozakhumula inyawo zami esithiyweni.
\b
\q1 
\v 16 Phendukela kimi ube lobubele lami,
\q2 ngoba ngilesizungu, ngikhathazekile.
\q1 
\v 17 Inhlupheko zenhliziyo yami sezandile;
\q2 ngikhulula ekudabukeni kwami.
\q1 
\v 18 Khangela ukukhathazeka kwami lokuhawula kwami,
\q2 ususe zonke izono zami.
\q1 
\v 19 Ake ubone ukuthi izitha zami sezande kangakanani,
\q2 lokuthi zingizonda kubi kanjani!
\b
\q1 
\v 20 Linda impilo yami ungihlenge;
\q2 ungangiyekeli ngiyangeke,
\q2 ngoba ngizuza isiphephelo Kuwe.
\q1 
\v 21 Sengathi ubuqotho lokuqonda kungangivikela,
\q2 ngoba ngizuza isiphephelo Kuwe.
\b
\q1 
\v 22 Hlenga u-Israyeli, Oh Nkulunkulu,
\q2 kuzozonke inhlupheko zakhe.
\c 26
\cl Ihubo 26
\d ElikaDavida.
\q1 
\v 1 Veza ukungabi lacala kwami, \nd Thixo\nd*,
\q2 ngoba sengiphile impilo engelansolo;
\q1 ngihlezi ngimethemba \nd uThixo\nd*
\q2 ngingaxhamandi.
\q1 
\v 2 Ngilinga, Oh \nd Thixo\nd*, ungizame,
\q2 hlola inhliziyo yami lengqondo yami;
\q1 
\v 3 ngoba uthando Lwakho luhlezi luphambi kwami,
\q2 njalo kokuphela ngihamba eqinisweni Lakho.
\b
\q1 
\v 4 Kangidlelani labantu abakhohlisayo
\q2 njalo kangiwelelani labazenzisi;
\q1 
\v 5 ngiyawenyanya umbuthano wezigangi;
\q2 njalo ngiyala ukuhlala lezixhwali.
\q1 
\v 6 Ngigeza izandla zami ngokungelacala,
\q2 bese ngilizungeza i-alithari Lakho, Oh \nd Thixo\nd*,
\q1 
\v 7 ngimemezele ngamandla indumiso Yakho
\q2 ngibatshele bonke ngemisebenzi Yakho eyisimanga.
\b
\q1 
\v 8 Ngiyayithanda indlu ohlala kuyo, Oh \nd Thixo\nd*,
\q2 indawo lapho inkazimulo Yakho ehlala khona.
\q1 
\v 9 Ungamukisi umphefumulo wami ndawonye lowezoni,
\q2 impilo yami kanye lalabo abomele igazi,
\q1 
\v 10 ozandla zabo zilamacebo amabi,
\q2 ozandla zabo zokunene zifumbethe izivalamlomo.
\q1 
\v 11 Kodwa mina ngiphila impilo engelasici;
\q2 ngihlenga ube lesihawu kimi.
\b
\q1 
\v 12 Inyawo zami zimi emhlabathini ochayileyo;
\q2 ngizamdumisa \nd uThixo\nd* emhlanganweni omkhulu.
\c 27
\cl Ihubo 27
\d ElikaDavida.
\q1 
\v 1 \nd UThixo\nd* uyikukhanya kwami lensindiso yami
\q2 ngizakwesaba bani na?
\q1 \nd UThixo\nd* uyinqaba yokuphila kwami
\q2 ngubani engingamesaba na?
\b
\q1 
\v 2 Nxa ababi bengihlasela
\q2 bezodlithiza inyama yami,
\q1 lapho izitha zami labangizondayo bengihlasela,
\q2 bazakhubeka bawe.
\q1 
\v 3 Loba impi ingivimbezela,
\q2 inhliziyo yami kayizukwesaba;
\q1 loba ngivukelwa yimpi,
\q2 loba kunjalo ngizakuma isibindi.
\b
\q1 
\v 4 Yinye into engiyicelayo \nd kuThixo\nd*,
\q2 yilokhu engikudingayo:
\q1 ukuba ngihlale endlini \nd kaThixo\nd*
\q2 zonke insuku zokuphila kwami,
\q1 ngibuke ubuhle \nd bukaThixo\nd*,
\q2 lokuthi ngimdinge ethempelini lakhe.
\q1 
\v 5 Phela ngosuku lokuhlupheka
\q2 uzangilondoloza emzini wakhe,
\q1 uzangifihla esiphephelweni sethabanikeli lakhe
\q2 angimise phezulu kwedwala elisesiqongweni.
\b
\q1 
\v 6 Lapho-ke ikhanda lami lizaphakanyiswa
\q2 ngaphezu kwezitha ezingihanqileyo;
\q1 ethabanikeleni lakhe ngizakwenza umhlatshelo ngimemeza ngentokozo;
\q2 ngizahlabelela ingoma zendumiso \nd kuThixo\nd*.
\b
\q1 
\v 7 Zwana ilizwi lami lapho ngimemeza Oh \nd Thixo\nd*;
\q2 woba lomusa kimi ungiphendule.
\q1 
\v 8 Ithi inhliziyo yami Ngawe, “Dinga ubuso bakhe!”
\q2 Ubuso Bakho, \nd Thixo\nd* ngizabudinga.
\q1 
\v 9 Ungangifihleli ubuso Bakho,
\q2 ungayixotshi inceku yakho ngokuthukuthela;
\q2 wena ubungumsizi wami.
\q1 Ungangilahli loba ungidele,
\q2 Oh Nkulunkulu, Msindisi wami.
\q1 
\v 10 Loba obaba lomama bengangidela,
\q2 \nd uThixo\nd* uzangemukela.
\q1 
\v 11 Ngifundisa indlela Yakho, Oh \nd Thixo\nd*;
\q2 ngihola endleleni eqondileyo
\q2 ngenxa yabancindezeli bami.
\q1 
\v 12 Unganginikeli entandweni yabangizondayo,
\q2 ngoba ofakazi bamanga bayangivukela
\q2 bevutha ulaka.
\b
\q1 
\v 13 Ngilokhu ngilesibindi ngalokhu:
\q2 ngizakubona ukulunga \nd kukaThixo\nd*
\q2 emhlabeni wabaphilayo.
\q1 
\v 14 Lindela \nd uThixo\nd*
\q2 qina ume isibindi
\q2 ulindele \nd uThixo\nd*.
\c 28
\cl Ihubo 28
\d Ihubo likaDavida.
\q1 
\v 1 Ngikhala Kuwe, Oh \nd Thixo\nd*,
\q2 Dwala lami;
\q2 ungangivaleli indlebe Yakho.
\q1 Phela nxa ulokhu uthule
\q2 ngizakuba njengalabo asebengene egodini.
\q1 
\v 2 Zwana ukukhala kwami ngicela umusa,
\q2 nxa ngikhala Kuwe ngicela usizo,
\q1 nxa ngiphakamisela izandla zami
\q2 eNdaweni Yakho eNgcwelengcwele.
\b
\q1 
\v 3 Ungangihuduli ndawonye lababi,
\q2 lalabo abenza ububi,
\q1 abakhuluma kamnandi labomakhelwane
\q2 kodwa begcine ububi ezinhliziyweni zabo.
\q1 
\v 4 Bajezisele izenzo zabo
\q2 kanye lemisebenzi yabo emibi;
\q1 bajezisele imisebenzi yezandla zabo,
\q2 ubaphindisele ngokubafaneleyo.
\b
\q1 
\v 5 Njengoba bengananzi imisebenzi \nd kaThixo\nd*
\q2 lalokho okwenziwe yizandla zakhe,
\q1 uzababhidlizela phansi
\q2 angaphindi ababumbe futhi.
\b
\q1 
\v 6 Udumo kalube kuye \nd uThixo\nd*,
\q2 ngoba ukuzwile ukukhala kwami ngicela umusa.
\q1 
\v 7 \nd UThixo\nd* ungamandla ami lesihlangu sami;
\q2 inhliziyo yami yethemba Kuye, ngiyancedwa.
\q1 Inhliziyo yami iyaqolotsha ngentokozo
\q2 njalo ngizambonga ngehubo.
\b
\q1 
\v 8 \nd UThixo\nd* ungamandla abantu bakhe,
\q2 inqaba yensindiso yogcotshiweyo wakhe.
\q1 
\v 9 Sindisa abantu Bakho ubusise ilifa lakho;
\q2 woba ngumelusi wabo ubathwale lanininini.
\c 29
\cl Ihubo 29
\d Ihubo likaDavida.
\q1 
\v 1 Mupheni \nd uThixo\nd*, lina ziphakanyiswa,
\q2 mupheni \nd uThixo\nd* ubukhosi lamandla.
\q1 
\v 2 Mupheni \nd uThixo\nd* ubukhosi obufanele ibizo lakhe;
\q2 mkhonzeni \nd uThixo\nd* ekukhazimuleni kobungcwele bakhe.
\b
\q1 
\v 3 Ilizwi \nd likaThixo\nd* liyazulazula phezu kwamanzi;
\q2 uNkulunkulu wenkazimulo uyandindiza,
\q2 \nd uThixo\nd* uyandindiza phezu kwamanzi amanengi.
\q1 
\v 4 Ilizwi \nd likaThixo\nd* lilamandla;
\q2 ilizwi \nd likaThixo\nd* lilobukhosi.
\q1 
\v 5 Ilizwi \nd likaThixo\nd* lephula imisedari;
\q2 \nd uThixo\nd* uyiqamula ibe yizicucu imisedari yaseLebhanoni.
\q1 
\v 6 Wenza iLebhanoni itshakale njengethole,
\q2 iSiriyoni njengeguqa lenyathi.
\q1 
\v 7 Ilizwi \nd likaThixo\nd* litshaya
\q2 ngezikhatha zombane.
\q1 
\v 8 Ilizwi \nd likaThixo\nd* liyayizamazamisa inkangala;
\q2 \nd uThixo\nd* uyayizamazamisa iNkangala yaseKhadeshi.
\q1 
\v 9 Ilizwi \nd likaThixo\nd* liyayitshila imikusu
\q2 likhwebule izihlahla amagusu asale eze.
\q1 Njalo ethempelini lakhe bonke bazamemeza bathi,
\q2 “Inkazimulo!”
\b
\q1 
\v 10 \nd UThixo\nd* uhlezi ebukhosini phezu kwesikhukhula;
\q2 \nd uThixo\nd* unguMbusi lanininini.
\q1 
\v 11 \nd UThixo\nd* unika amandla ebantwini bakhe;
\q2 \nd uThixo\nd* ubusisa abantu bakhe ngokuthula.
\c 30
\cl Ihubo 30
\d Ihubo. Ingoma. Elokunikela ithempeli. ElikaDavida.
\q1 
\v 1 Ngizakuphakamisa, Oh \nd Thixo\nd*,
\q2 ngoba wangenyula ekujuleni
\q2 awaze wavumela izitha zami zijabule phezu kwami.
\q1 
\v 2 Awu \nd Thixo\nd*, Nkulunkulu wami,
\q2 ngacela Kuwe uncedo wangisilisa.
\q1 
\v 3 Yebo \nd Thixo\nd* wangenyula elibeni,
\q2 wangisiza ngaphepha ukungena egodini.
\b
\q1 
\v 4 Hlabelelani \nd kuThixo\nd* lina bathembekileyo bakhe;
\q2 dumisani ibizo lakhe elingcwele.
\q1 
\v 5 Ngoba ukuthukuthela Kwakhe ngokomzuzwana nje,
\q2 kodwa umusa wakhe ukhona okwempilo yonke;
\q1 ukulila kungaqhubeka ubusuku bonke,
\q2 kodwa ukuthokoza kuyafika ekuseni.
\b
\q1 
\v 6 Ngathi lapho ngizizwa ngihlezi kuhle ngathi,
\q2 “Kangisoze ngafa ngahlukuluzeka.”
\q1 
\v 7 Yebo \nd Thixo\nd*, wathi lapho ungizwela
\q2 wenza intaba yami yagxila qho;
\q1 kodwa kwathi lapho usufihle ubuso Bakho
\q2 ngaphelelwa lithemba.
\b
\q1 
\v 8 Ngakhala kuwe, \nd Thixo\nd*;
\q2 ngacela umusa eNkosini:
\q1 
\v 9 “Kulenzuzo bani ngokubhujiswa kwami na,
\q2 ngokutshona kwami egodini?
\q1 Kambe uthuli luzakudumisa na?
\q2 Lona luzafakaza na ngokuthembeka Kwakho?
\q1 
\v 10 Zwana, Oh \nd Thixo\nd*, ube lomusa kimi;
\q2 woba lusizo lwami.”
\b
\q1 
\v 11 Waguqula ukububula kwami kwaba ngumgido;
\q2 wangihlubula izigqoko zamasaka wangigqokisa ukuthokoza,
\q1 
\v 12 ukuze inhliziyo yami ikuhlabelele ingathuli.
\q2 Oh \nd Thixo\nd*, Nkulunkulu wami,
\q2 ngizakubonga nini lanini.
\c 31
\cl Ihubo 32
\d Kumqondisi wokuhlabela. Ihubo likaDavida.
\q1 
\v 1 Kuwe \nd Thixo\nd*, sengithole isiphephelo;
\q2 mangingayangiswa lanini;
\q2 ngihlenga ngokulunga Kwakho.
\q1 
\v 2 Ngilalela,
\q2 woza ngokuphangisa ungihlenge;
\q1 woba lidwala lami lokuphephela,
\q2 inqaba eqinileyo yokungisindisa.
\q1 
\v 3 Njengoba ulidwala lami lenqaba yami,
\q2 ngikhokhela ungihole ngenxa yegama Lakho.
\q1 
\v 4 Ngikhulula emjibileni othiyelwe mina,
\q2 ngoba uyisiphephelo sami.
\q1 
\v 5 Ezandleni Zakho nginikela umphefumulo wami;
\q2 ngihlenga, Oh \nd Thixo\nd*, Nkulunkulu weqiniso.
\b
\q1 
\v 6 Ngiyabazonda labo abanamathela izithombe eziyize;
\q2 ngithemba \nd kuThixo\nd*.
\q1 
\v 7 Ngizathokoza ngijabule othandweni Lwakho,
\q2 ngoba wakubona ukuhlupheka kwami
\q2 wabazi ubuhlungu bomphefumulo wami.
\q1 
\v 8 Kawungifuqelanga esitheni
\q2 kodwa ugxilise inyawo zami endaweni ebanzi.
\b
\q1 
\v 9 Woba lomusa kimi, Oh \nd Thixo\nd*, ngoba ngiyahlupheka;
\q2 amehlo ami ayafiphala ngenxa yosizi,
\q2 umphefumulo wami lomzimba wami ngokudabuka.
\q1 
\v 10 Impilo yami incitshiswa yikukhathazeka,
\q2 leminyaka yami yikububula;
\q1 amandla ami ayadeda ngenxa yokuhlupheka kwami,
\q2 lamathambo ami aphela amandla.
\q1 
\v 11 Ngenxa yezitha zami,
\q2 sengiyinhlekisa enjani kubomakhelwane;
\q1 sengiyinhlekisa kubangane bami
\q2 labo abangibonayo ezindleleni bayangibalekela.
\q1 
\v 12 Sebekhohliwe ngami kungathi sengafa;
\q2 senginjengembiza yebumba ehlephukileyo.
\q1 
\v 13 Ngoba ngizwa izingoma zabanengi;
\q2 kulezisongo inxa zonke;
\q1 bakha amasu okungilimaza,
\q2 njalo baceba ukuchitha impilo yami.
\b
\q1 
\v 14 Kodwa ngiyethemba Kuwe, \nd Thixo\nd*;
\q2 ngithi, “UnguNkulunkulu wami.”
\q1 
\v 15 Izikhathi zami zisezandleni Zakho;
\q2 ngisindisa ezitheni zami
\q2 lakulabo abangizingelayo.
\q1 
\v 16 Ubuso Bakho mabukhazimulele encekwini Yakho;
\q2 ngisindisa ngothando Lwakho olungehlulekiyo.
\q1 
\v 17 Mangingahlaziswa, Oh \nd Thixo\nd*,
\q2 ngoba sengikhalile Kuwe;
\q1 kodwa akuthi ababi bahlaziswe
\q2 balale bathule zwi ethuneni.
\q1 
\v 18 Akuthi izindebe zabo zamanga zithuliswe,
\q2 ezikhuluma ngokuzigqaja lokweyisa
\q2 bakhuluma ngobuqholo ngabantu abalungileyo.
\b
\q1 
\v 19 Kukhulu kangakanani ukulunga Kwakho
\q2 okugcinele labo abakwesabayo,
\q1 okunika obala abantu bebona
\q2 kulabo abaphephela Kuwe.
\q1 
\v 20 Uyabafihla ekusithekeni kobukhona Bakho
\q2 emaqingeni ababi
\q1 uyabagcina bevikelwe emzini wakhe
\q2 ezilimini ezichothozayo.
\b
\q1 
\v 21 Udumo alube \nd kuThixo\nd*
\q2 ngoba watshengisa uthando lwakhe olumangalisayo kimi
\q2 ngisedolobheni elihanqiweyo yimpi.
\q1 
\v 22 Ngiphakathi kokwethuka ngathi,
\q2 “Sengisusiwe kangisabonakali Kuwe!”
\q1 Kanti wakuzwa ukukhala kwami ngicela umusa,
\q2 lapho ngangicela kuwe ukusizwa.
\b
\q1 
\v 23 Mthandeni \nd uThixo\nd*,
\q2 lina bangcwele bakhe!
\q1 \nd UThixo\nd* uyabalondoloza abathembekileyo,
\q2 kodwa abazigqajayo uyabaphindisela ngokugcweleyo.
\q1 
\v 24 Qinani lime isibindi,
\q2 lonke lina elithemba \nd uThixo\nd*.
\c 32
\cl Ihubo 32
\d \tl Ihubo\tl* likaDavida.
\q1 
\v 1 Ubusisiwe lowo
\q2 oziphambeko zakhe zithethelelwe,
\q2 ozono zakhe zisibekelwe.
\q1 
\v 2 Ubusisiwe lowo
\q2 ongasoze abalelwe isono sakhe \nd nguThixo\nd*,
\q2 njalo ongelankohliso emoyeni wakhe.
\b
\q1 
\v 3 Ngathi lapho ngithule,
\q2 amathambo ami ababuthakathaka
\q2 ngenxa yokububula kwami ilanga lonke.
\q1 
\v 4 Ngoba imini lobusuku
\q2 isandla Sakho sasingelekile, singisinda;
\q1 amandla ami aphela
\q2 kwafana lesikhudumezi sehlobo.
\b
\q1 
\v 5 Lapho-ke ngasengisivuma isono sami Kuwe
\q2 angabe ngisasibekela ububi bami.
\q1 Ngathi, “Ngizazivuma iziphambeko zami \nd kuThixo\nd*,”
\q2 walithethelela icala lesono sami.
\b
\q1 
\v 6 Ngakho akuthi wonke umuntu othembekileyo akhuleke kuwe
\q2 usatholakala;
\q1 ngeqiniso kuzakuthi lapho impophoma seziqubuka,
\q2 kabayi kumfinyelela.
\q1 
\v 7 Uyindawo yami yokuphephela;
\q2 uzangivikela enkathazweni
\q2 ungizungeze ngezingoma zensindiso.
\b
\q1 
\v 8 Ngizakutshengisa ngikufundise indlela ofanele uhambe ngayo;
\q2 ngizakweluleka ngikulinde.
\q1 
\v 9 Ungabi njengebhiza loba imbongolo,
\q2 khona akulakuzwisisa
\q1 kodwa kumele kukhokhelwa ngamatomu
\q2 ukuze umuntu kumlalele.
\q1 
\v 10 Zinengi izikhalazo zababi,
\q2 kodwa uthando \nd lukaThixo\nd* olungaphuthiyo
\q2 luyamzungeza umuntu othemba kuye.
\b
\q1 
\v 11 Thokozani \nd kuThixo\nd*, lithabe lina balungileyo;
\q2 hlabelelani lonke lina eliqotho enhliziyweni!
\c 33
\cl Ihubo 33
\q1 
\v 1 Hlabelelani \nd kuThixo\nd* ngentokozo,
\q2 lina balungileyo;
\q2 kubafanele abaqotho ukumdumisa.
\q1 
\v 2 Dumisani \nd uThixo\nd* ngechacho;
\q2 mhlabeleleni ngesiginci sezintambo ezilitshumi.
\q1 
\v 3 Mhlabeleleni ingoma entsha;
\q2 tshayani kamnandi lihlokome ngentokozo.
\b
\q1 
\v 4 Ngoba ilizwi \nd likaThixo\nd* lilungile, liqinisile;
\q2 uthembekile kukho konke akwenzayo.
\q1 
\v 5 \nd UThixo\nd* uthanda ukulunga lokwahlulela okuqondileyo;
\q2 umhlaba ugcwele uthando lwakhe olungaphuthiyo.
\b
\q1 
\v 6 Ngelizwi \nd likaThixo\nd* amazulu enziwa,
\q2 ubunkanyankanya bezinkanyezi ngomoya womlomo wakhe.
\q1 
\v 7 Uyawaqoqa amanzi olwandle awathele enkonxeni;
\q2 athululele inziki zolwandle eziphaleni.
\q1 
\v 8 Umhlaba wonke kawesabe \nd uThixo\nd*;
\q2 akuthi bonke abantu bomhlaba bazithobe phambi Kwakhe.
\q1 
\v 9 Ngoba wakhuluma, kwahle kwaba khona;
\q2 wayala, kwema kwaqina nko.
\b
\q1 
\v 10 \nd UThixo\nd* uyawachitha amacebo ezizwe;
\q2 uyazinyampisa izinhloso zabantu.
\q1 
\v 11 Kodwa amacebo \nd kaThixo\nd* ami aqinile nini lanini,
\q2 izinhloso zenhliziyo yakhe kuzozonke izizukulwane.
\b
\q1 
\v 12 Sibusisekile isizwe uNkulunkulu waso \nd onguThixo\nd*,
\q2 abantu abakhethayo baba yilifa lakhe.
\q1 
\v 13 \nd UThixo\nd* ukhangele phansi esezulwini
\q2 ababone bonke abantu;
\q1 
\v 14 esemzini wakhe
\q2 uyababona bonke abahlala emhlabeni
\q1 
\v 15 yena owenza inhliziyo zabo bonke,
\q2 enanzelela konke abakwenzayo.
\b
\q1 
\v 16 Akulankosi esizwa yibukhulu bebutho layo;
\q2 akulaqhawe eliphunyuka ngamandla alo amakhulu.
\q1 
\v 17 Yikuthemba ize ukuthi ibhiza lingakusindisa;
\q2 loba lona lilamandla amakhulu ngeke lisindise.
\q1 
\v 18 Kodwa amehlo \nd kaThixo\nd* akulabo abamesabayo,
\q2 kulabo othemba labo lisethandweni lwakhe olungapheliyo,
\q1 
\v 19 ukubakhulula ekufeni
\q2 baphiliswe lanxa kulendlala.
\b
\q1 
\v 20 Simlindele \nd uThixo\nd* ngokwethemba;
\q2 ulusizo lwethu lesihlangu sethu.
\q1 
\v 21 Inhliziyo zethu zithokoza Ngaye,
\q2 ngoba sithembe ebizweni lakhe elingcwele.
\q1 
\v 22 Sengathi uthando Lwakho olungaphuthiyo, \nd Thixo\nd*, lungaba phezu kwethu
\q2 njengalokhu sibeka ithemba lethu kuwe.
\c 34
\cl Ihubo 34
\d ElikaDavida. Lapho azenza uhlanya ku-Abhimelekhi, owamxotshayo wahamba.
\q1 
\v 1 Ngizamphakamisa \nd uThixo\nd* ngezikhathi zonke;
\q2 indumiso yakhe izahlala isezindebeni zami.
\q1 
\v 2 Umphefumulo wami uzaziqhenya \nd Thixo\nd*
\q2 akuthi abahluphekileyo bezwe bajabule.
\q1 
\v 3 Bongani \nd uThixo\nd* kanye lami;
\q2 kasiphakamiseni ibizo lakhe sonke, ndawonye.
\b
\q1 
\v 4 Ngamdinga \nd uThixo\nd* wangiphendula;
\q2 wangikhulula kukho konke engangikwesaba.
\q1 
\v 5 Labo abakhangele Kuye bayakhazimula;
\q2 ubuso babo abungeke bembeswe lihlazo.
\q1 
\v 6 Isihlupheki lesi samemeza, \nd uThixo\nd* wasizwa;
\q2 wasisindisa kuzozonke inhlupheko zaso.
\q1 
\v 7 Ingilosi \nd kaThixo\nd* iyabazungeza
\q2 labo abamesabayo, ibakhulule.
\b
\q1 
\v 8 Nambithani libone ukuthi \nd uThixo\nd* ulungile;
\q2 ubusisiwe umuntu ophephela Kuye.
\q1 
\v 9 Mesabeni \nd Uthixo\nd*, lina bangcwele bakhe,
\q2 ngoba labo abamesabayo kabasweli lutho.
\q1 
\v 10 Izilwane zingaphela amandla zilambe,
\q2 kodwa labo abamdingayo \nd uThixo\nd* kabasweli lutho oluhle.
\q1 
\v 11 Wozani, bantwabami, lalelani kimi;
\q2 ngizalifundisa ukumesaba \nd uThixo\nd*.
\q1 
\v 12 Lowo othanda ukuphila
\q2 abone lezinsuku ezinhle kumele
\q1 
\v 13 anqande ulimi lwakhe kokubi
\q2 lezindebe zakhe ekukhulumeni inkohliso.
\q1 
\v 14 Tshiya ububi wenze okulungileyo;
\q2 funa ukuthula ukunxwanele.
\b
\q1 
\v 15 Amehlo \nd kaThixo\nd* akhangele abalungileyo
\q2 lezindlebe zakhe ziyezwa ukukhala kwabo;
\q1 
\v 16 ubuso \nd bukaThixo\nd* bumelana lalabo abenza okubi,
\q2 ukuba acitshe ukukhunjulwa kwabo emhlabeni.
\b
\q1 
\v 17 Abalungileyo bayakhala \nd kuThixo\nd* abezwe;
\q2 uyabakhulula kuzozonke inhlupheko zabo.
\q1 
\v 18 \nd UThixo\nd* useduze labo abalezinhliziyo ezephukileyo
\q2 asindise labo abadabukileyo emoyeni.
\b
\q1 
\v 19 Umuntu olungileyo angaba lezinhlupheko ezinengi,
\q2 kodwa \nd uThixo\nd* uyamkhulula kuzozonke.
\q1 
\v 20 Uyawavikela wonke amathambo akhe,
\q2 kungephuki loba lalinye.
\b
\q1 
\v 21 Ububi buzambulala oyisixhwali;
\q2 izitha zolungileyo zizalahlwa.
\q1 
\v 22 \nd UThixo\nd* uyazihlenga izinceku zakhe;
\q2 kakho ozalahlwa ophephela kuye.
\c 35
\cl Ihubo 35
\d ElikaDavida.
\q1 
\v 1 Xabana labo, \nd Thixo\nd* abaxabana lami;
\q2 lwana labo abalwa lami.
\q1 
\v 2 Thatha isihlangu lewisa;
\q2 phakama uzongilamulela.
\q1 
\v 3 Phakamisa umkhonto lesijula,
\q2 ukuqondise kwabangihlaselayo.
\q1 Ngitshela ukuthi,
\q2 “Ngiyikusindiswa kwakho.”
\b
\q1 
\v 4 Sengathi labo abazingela impilo yami
\q2 bangayangiswa bathelwe ngehlazo;
\q1 sengathi labo abazama ukungidiliza
\q2 bangabuyiselwa emuva bedumazekile.
\q1 
\v 5 Sengathi bangaba njengamakhoba emoyeni,
\q2 ingilosi \nd kaThixo\nd* ibe ibadudula ibaxotsha;
\q1 
\v 6 sengathi indlela yabo ingaba mnyama itshelele,
\q2 ingilosi \nd kaThixo\nd* ibe ibahlezi ezithendeni.
\b
\q1 
\v 7 Ngoba bangithiya ngamambule abo ngingonanga lutho,
\q2 baphinda bangembela umgodi kungelasizatho,
\q1 
\v 8 sengathi bangadilizwa belibele
\q2 lawomambule abawathiyileyo abahilele,
\q2 sengathi bangawela kulowomgodi babhidlizwe.
\q1 
\v 9 Lapho-ke umoya wami uzathokoza \nd kuThixo\nd*
\q2 ujabule ekusindiseni Kwakhe.
\q1 
\v 10 Mina qobo lwami ngizamemeza ngithi,
\q2 “Ngubani onjengawe, Oh \nd Thixo?\nd*
\q1 Uyabakhulula abahluphekayo kulabo abalamandla kulabo,
\q2 abahluphekayo labaswelayo kulabo ababantshontshelayo.”
\b
\q1 
\v 11 Ofakazi bolunya bayangivelela;
\q2 bangibuza ngezinto engingazaziyo.
\q1 
\v 12 Bangiphindisela okuhle ngokubi
\q2 umphefumulo wami usale usudabukile.
\q1 
\v 13 Ikanti kwathi bona begula ngembatha amasaka
\q2 ngazithoba ngazila ukudla.
\q1 Kwathi lapho imikhuleko yami ingaphendulwa
\q2 
\v 14 ngaba sesililweni
\q2 kwangathi ngililela umngane wami loba umfowethu.
\q1 Ngakhothamisa ikhanda lami ngokudabuka
\q2 kwangathi ngililela umama.
\q1 
\v 15 Kodwa ngathi sengikhubekile baqwebana bokha insini;
\q2 abahlaseli bangihlanganyela ngilibele.
\q2 Bangichothoza okungapheliyo.
\q1 
\v 16 Bakloloda ngomona njengabangakholwayo;
\q2 bangigedlela amazinyo abo.
\b
\q1 
\v 17 Nkosi, uzakuma ubukele kuze kube nini na?
\q2 Yenyula impilo yami ekungilimazeni kwabo,
\q2 impilo yami eligugu kulezizilwane.
\q1 
\v 18 Ngizakubonga phakathi komhlangano omkhulu;
\q2 ngikudumise ngiphakathi kwamaxuku abantu.
\q1 
\v 19 Ungabayekeli abayizitha zami ngingabonelanga lutho,
\q2 bantele phezu kwami.
\q1 Ungayekeli labo abangizondayo kungelasizatho,
\q2 banginyonkoloze ngomona.
\q1 
\v 20 Kabakhulumi okuqondileyo
\q2 kodwa babumba amacala amanga,
\q2 ngalabo abaphila ngokuthula elizweni.
\q1 
\v 21 Bangikhamisela imilomo bathi, “Hiya belo!
\q2 Sizibonele ngawethu amehlo la.”
\b
\q1 
\v 22 Oh \nd Thixo\nd*, usukubonile lokhu; ungathuli.
\q2 Ungabi khatshana kwami, Oh Nkosi.
\q1 
\v 23 Vuka, uphakame ungilamulele!
\q2 Ngilwela, Nkulunkulu Thixo wami.
\q1 
\v 24 Ngigeza ngokulunga Kwakho,
\q2 \nd Thixo\nd*, Nkulunkulu wami;
\q2 ungabayekeli bantele phezu kwami.
\q1 
\v 25 Ungabayekeli bacabange bathi, “Ehe, yikho ebesikufuna!”
\q2 loba bathi, “Sesimginyile.”
\b
\q1 
\v 26 Sengathi bonke abantela ngokuhlupheka kwami
\q2 bangathelwa ngehlazo basanganiseke;
\q1 sengathi bonke abazikhukhumezayo phezu kwami
\q2 bangembeswa ngokuyangeka langehlazo.
\q1 
\v 27 Sengathi labo abathokoza ngokugezwa kwami
\q2 bangahalalisa ngentokozo lenjabulo;
\q1 sengathi bangatsho kokuphela bathi,
\q2 “Makaphakanyiswe \nd uThixo\nd*
\q2 othokoza ngokuhlala kuhle kwenceku yakhe.”
\b
\q1 
\v 28 Ulimi lwami luzakhuluma ngokulunga Kwakho
\q2 langendumiso Yakho ilanga lonke.
\c 36
\cl Ihubo 36
\d Kumqondisi wokuhlabela. ElikaDavida inceku \nd kaThixo\nd*.
\q1 
\v 1 Ngilenkinga enhliziyweni yami
\q2 mayelana lokuxhwala kwesigangi:
\q1 Kakukho ukwesaba uNkulunkulu
\q2 engqondweni yaso.
\b
\q1 
\v 2 Phela kweyaso ingqondo siyazikhohlisa
\q2 size sehluleke ukubona kumbe ukuzonda isono saso.
\q1 
\v 3 Amazwi omlomo waso abolile alenkohliso;
\q2 kasiselakho ukuhlakanipha lokulunga.
\q1 
\v 4 Kwala loba silele siceba ububi;
\q2 sizinikela endleleni yobubi
\q2 njalo kasikulahli okubi.
\b
\q1 
\v 5 Uthando Lwakho, \nd Thixo\nd*, lufika emazulwini,
\q2 ukuthembeka Kwakho esibhakabhakeni.
\q1 
\v 6 Ukulunga Kwakho kunjengezintaba ezesabekayo,
\q2 ukwahlulela kuhle Kwakho njengolwandle olukhulu.
\q2 Oh \nd Thixo\nd*, uyamlondoloza umuntu kanye lenyamazana.
\q1 
\v 7 Luligugu elinganani uthando Lwakho olungaphuthiyo,
\q2 Oh Nkulunkulu!
\q1 Bonke abantu bazuza isiphephelo
\q2 emthunzini wamaphiko Akho.
\q1 
\v 8 Bayazitika ngokudla okunengi endlini Yakho;
\q2 ubapha okunathwayo okwemfuleni wakho wokuthokoza.
\q1 
\v 9 Ngoba kuwe kulomthombo wokuphila;
\q2 kokwakho ukukhanya sibona ukukhanya.
\b
\q1 
\v 10 Qhubeka ngothando Lwakho kulabo abakwaziyo,
\q2 ukuluga Kwakho kwabaqotho enhliziyweni.
\q1 
\v 11 Sengathi unyawo lwabazazisayo lungehluleka ukunginyathela,
\q2 loba ukuthi isandla sababi singangixotshi.
\q1 
\v 12 Bonani-ke ukuthi izigangi sezithe daca
\q2 ziwiselwe phansi, kazisavuki futhi!
\c 37
\cl Ihubo 37
\d ElikaDavida.
\q1 
\v 1 Ungazikhathazi ngabantu ababi
\q2 loba uhawukele labo abenza okungalunganga;
\q1 
\v 2 ngoba bazabuna masinyane njengotshani,
\q2 njengezimila eziluhlaza bazakufa masinyane.
\b
\q1 
\v 3 Themba \nd kuThixo\nd* wenze okulungileyo;
\q2 hlala elizweni ukholise amadlelo amahle.
\q1 
\v 4 Zithokozise \nd kuThixo\nd*
\q2 Yena uzakupha izifiso zenhliziyo yakho.
\b
\q1 
\v 5 Nikela indlela zakho \nd kuThixo\nd*;
\q2 themba kuye, Yena uzakwenzela lokhu:
\q1 
\v 6 Uzakwenza ukulunga kwakho kukhazimule njengentathakusa,
\q2 ubuqotho balokho okulwelayo njengelanga lemini enkulu.
\b
\q1 
\v 7 Chuma phambi \nd kukaThixo\nd*
\q2 umlindele ngesineke;
\q1 ungakhathazeki nxa abantu bephumelela ngezindlela zabo,
\q2 nxa bephutshisa amaqhinga abo amabi.
\b
\q1 
\v 8 Xwayana lokuzonda njalo ufulathele intukuthelo;
\q2 ungakhathazeki, kukhokhelela ebubini kuphela.
\q1 
\v 9 Ngoba abantu ababi bazasuswa,
\q2 kodwa labo abathemba \nd uThixo\nd* bazakudla ilifa lelizwe.
\b
\q1 
\v 10 Kuseyisikhatshana nje, ababi bazabe bengasekho;
\q2 loba usubadinga kabasayikufunyanwa.
\q1 
\v 11 Kodwa abathobekileyo bazakudla ilifa lelizwe
\q2 njalo bakholise ukuthula okukhulu.
\b
\q1 
\v 12 Ababi baceba ukulimaza abalungileyo
\q2 babagedlele amazinyo;
\q1 
\v 13 kodwa iNkosi iyabahleka ababi,
\q2 ngoba iyazi ukuthi usuku lwabo luyeza.
\b
\q1 
\v 14 Ababi bakhokha inkemba,
\q2 badonsa idandili
\q1 ngenhloso yokulimaza abahluphekayo labaswelayo,
\q2 lokubulala labo abahamba ngokulunga.
\q1 
\v 15 Kodwa izinkemba zabo zizagwaza ezabo inhliziyo,
\q2 lamadandili abo azakwephulwa.
\b
\q1 
\v 16 Kungcono ingcosana leyo abalayo abalungileyo
\q2 kulenotho yababi abanengi;
\q1 
\v 17 ngoba amandla ababi azaqedwa,
\q2 kodwa \nd uThixo\nd* uyabaxhasa abalungileyo.
\b
\q1 
\v 18 Insuku zabangelasici ziyaziwa \nd nguThixo\nd*,
\q2 ilifa labo lizakuma lanini.
\q1 
\v 19 Ngezikhathi zomonakalo abayikubuna;
\q2 ngezikhathi zendlala bazasutha.
\b
\q1 
\v 20 Kodwa ababi bazabhubha;
\q2 izitha \nd zikaThixo\nd* zinjengobuhle beganga,
\q2 zizanyamalala, zinyamalale njengentuthu.
\b
\q1 
\v 21 Ababi bayaboleka kodwa kababuyiseli,
\q2 kodwa abalungileyo bayapha kakhulu;
\q1 
\v 22 labo \nd uThixo\nd* ababusisayo bazakudla ilifa lelizwe;
\q2 kodwa labo abathukayo bazasuswa.
\b
\q1 
\v 23 Nxa \nd uThixo\nd* ethokoziswa yikuhamba komuntu,
\q2 uyaqinisa izinyathelo zakhe;
\q1 
\v 24 loba angakhubeka, kayikuwa,
\q2 ngoba \nd uThixo\nd* uyamsekela ngesandla sakhe.
\b
\q1 
\v 25 Ngangimutsha, manje sengiluphele,
\q2 kodwa angizange ngibone abalungileyo bedelwa
\q2 loba abantwababo becela isinkwa.
\q1 
\v 26 Bayaphana kokuphela njalo bayebolekana nje;
\q2 abantwababo bazabusiswa.
\b
\q1 
\v 27 Phendukani ebubini lenze ukulunga
\q2 lapho-ke lizahlala elizweni nini lanini.
\q1 
\v 28 Ngoba \nd uThixo\nd* uthanda abalungileyo
\q2 njalo kayikubadela abathembekileyo bakhe.
\b
\q1 Bazavikelwa kuze kube nini lanini
\q2 kodwa inzalo yababi izalahlwa;
\q1 
\v 29 abalungileyo bazazuza ilifa lelizwe
\q2 bahlale kulo lanini.
\b
\q1 
\v 30 Umlomo womuntu olungileyo ukhuluma ukuhlakanipha,
\q2 lolimi lwakhe lukhuluma okuqondileyo.
\q1 
\v 31 Umthetho kaNkulunkulu wakhe usenhliziyweni yakhe;
\q2 inyawo zakhe kazitsheleli.
\b
\q1 
\v 32 Ababi bacathamela abalungileyo
\q2 befuna impilo yabo qobo lwayo;
\q1 
\v 33 kodwa \nd uThixo\nd* kayikubayekela bazenzele abakuthandayo
\q2 kubo kumbe balahlwe licala nxa bethonisiswa.
\b
\q1 
\v 34 Lindelani \nd uThixo\nd* ligcine indlela yakhe.
\q2 Uzaliphakamisa lilithathe ilifa lelizwe;
\q2 lizakubona lokhu nxa ababi sebesusiwe.
\b
\q1 
\v 35 Sengike ngabona umuntu omubi olesihluku
\q2 kulokubhadala ehluma njengesihlahla,
\q2 esikhula kuhle emhlabathini waso wemvelo,
\q1 
\v 36 kodwa waphanga wafa kabe esabakhona;
\q2 ngathi loba sengimdinga ngamswela.
\b
\q1 
\v 37 Nanzelela abangelecala, qaphela abaqotho.
\q2 Likhona ikusasa kumuntu wokuthula.
\q1 
\v 38 Kodwa zonke izoni zizabhujiswa;
\q2 ikusasa lezigangi lizasuswa.
\b
\q1 
\v 39 Ukusindiswa kwabalungileyo kuvela \nd kuThixo\nd*;
\q2 uyinqaba yabo ngesikhathi sokuhlupheka.
\q1 
\v 40 \nd UThixo\nd* uyabasiza abakhulule;
\q2 abakhulule kwababi abasindise,
\q2 ngoba baphephela kuye.
\c 38
\cl Ihubo 38
\d Ihubo likaDavida. Isikhalazo.
\q1 
\v 1 Awu \nd Thixo\nd*, ungangikhuzi
\q2 ngolaka loba ungijezise uthukuthele.
\q1 
\v 2 Ngoba imitshoko yakho ingicibile,
\q2 njalo wangibhansula kakhulu ngesandla sakho.
\q1 
\v 3 Ngenxa yokuthukuthela kwakho kangiselakuphila emzimbeni wami;
\q2 amathambo ami kawasaqinanga ngenxa yesono sami.
\q1 
\v 4 Ukona kwami sekungisinda
\q2 njengomthwalo onzima ongathwalekiyo.
\b
\q1 
\v 5 Izilonda zami sezilobovu sezisenyanyeka
\q2 ngenxa yobuthutha bami besono.
\q1 
\v 6 Ngiyangiswe ngehliswa kakhulu;
\q2 sengitshona ngilila ilanga lonke.
\q1 
\v 7 Ngiphethwe liqolo ngobuhlungu obuqumayo;
\q2 umzimba wami kawuselampilo.
\q1 
\v 8 Sengibuthakathaka, sengicikizekile;
\q2 ngiyabubula ngobuhlungu benhliziyo.
\b
\q1 
\v 9 Zonke iziloyiso zami zisobala kuwe, Oh Thixo,
\q2 ukububula kwami kakufihlekanga kuwe.
\q1 
\v 10 Inhliziyo yami iyagubhazela, amandla ami ayaphela;
\q2 lokukhanya sekufiphele emehlweni ami.
\q1 
\v 11 Abangane bami labakhula bami sebengibalekela ngenxa yamanxeba ami;
\q2 omakhelwane bami sebehlalela khatshana
\q1 
\v 12 Labo abafuna impilo yami sebethiyile,
\q2 labo abafuna ukungilimaza bakhuluma ngokungidiliza;
\q2 ilanga lonke batshonela ukwakha amacebo enkohliso.
\b
\q1 
\v 13 Sengifana lesacuthe esingezwayo,
\q2 njengesimungulu esehluleka ukuvula umlomo waso;
\q1 
\v 14 senginjengomuntu ongezwayo,
\q2 olomlomo ongaphenduliyo.
\q1 
\v 15 Ngikulindele, Oh \nd Thixo\nd*,
\q2 uzaphendula, Oh Nkosi Nkulunkulu wami.
\q1 
\v 16 Ngoba ngathi, “Ungabayekeli baklolode
\q2 kumbe bazikhukhumeze phezu kwami nxa unyawo lwami lutshelela.”
\b
\q1 
\v 17 Ngoba sengiseduze lokuwa,
\q2 lobuhlungu bungiphethe njalonjalo.
\q1 
\v 18 Ngiyabuvuma ububi bami;
\q2 ngiyakhathazeka ngesono sami.
\q1 
\v 19 Banengi labo abayizitha zami ezitshisekayo,
\q2 labo abangizonda bengelasizatho banengi.
\q1 
\v 20 Labo abangiphindisela okuhle ngokubi
\q2 bayangigcona lapho ngisenza okulungileyo.
\b
\q1 
\v 21 Oh \nd Thixo\nd*, ungangideli;
\q2 ungabi khatshana lami, Oh Nkulunkulu wami.
\q1 
\v 22 Woza masinyane uzongisiza,
\q2 Nkosi yami loMsindisi wami.
\c 39
\cl Ihubo 39
\d Kumqondisi wokuhlabela. ElikaJeduthuni. Ihubo likaDavida.
\q1 
\v 1 Ngathi, “Ngizaziqaphela izindlela zami,
\q2 ngiluthinte ulimi lwami esonweni;
\q1 ngizawugcika umlomo wami
\q2 nxa ababi bekhona phambi kwami.”
\q1 
\v 2 Kodwa kwathi lapho ngithule ngithe zwi,
\q2 ngingatsho lutho loba lungoluhle
\q1 ubuhlungu benhliziyo yami bakhula.
\q2 
\v 3 Inhliziyo yami yavutha ngaphakathi kwami;
\q1 kwathi lapho ngizuliswa yimicabango, umlilo wavutha;
\q2 ngasengikhuluma ngolimi lwami:
\b
\q1 
\v 4 “Ngitshengisa, \nd Thixo\nd*, isiphetho sempilo yami
\q2 lobunengi bezinsuku zami;
\q2 ngazisa ukuthi impilo yami igijima kanganani.
\q1 
\v 5 Usuwenze insuku zami zaba lobubanzi besandla;
\q2 ububanzi beminyaka yami kabusilutho kuwe.
\q1 Impilo yabantu ingumoya kuphela,
\q2 kanye lalabo abakhanya behlalisekile.
\b
\q1 
\v 6 Umuntu uhambahamba njengesithunzi nje;
\q2 uyatshikatshika, kodwa konke akwenzayo kuyize lodwa;
\q2 ubuthelela inotho engazi ukuthi izakuba ngekabani.
\b
\q1 
\v 7 Kodwa okwamanje, Thixo, ngisafunani kambe?
\q2 Ithemba lami likuwe.
\q1 
\v 8 Ngisindisa kuzozonke iziphambeko zami;
\q2 ungangenzi inhlekisa yezitha.
\q1 
\v 9 Ngathula; ngangingeke ngiwuvule umlomo wami,
\q2 ngoba lokhu kwenziwe nguwe.
\q1 
\v 10 Susa uswazi lwakho kimi;
\q2 sengikhulelwa yisidutshulo sesandla sakho.
\q1 
\v 11 Abantu uyabakhuza ubajezisele isono sabo;
\q2 ucikiza inotho yabo njengenondo
\q2 ngempela umuntu ngamunye ungumoya nje.
\b
\q1 
\v 12 Zwana umkhuleko wami, Oh \nd Thixo\nd*,
\q2 lalela isikhalazo sami ngicela uncedo;
\q2 ungabi ligcikandlebe nxa ngikhala.
\q1 Phela ngihlala lawe nginjengesihambi, ngiyisethekeli
\q2 njengoba okhokho bonke babenjalo.
\q1 
\v 13 Ake ukhangele eceleni nje ukuze ngithokoze njalo,
\q2 ngingakasuki lapha ngibe ngongasekho.”
\c 40
\cl Ihubo 40
\d Kumqondisi wokuhlabela. ElikaDavida. Ihubo.
\q1 
\v 1 Ngamlindela ngesineke \nd uThixo\nd*;
\q2 waphendukela ngakimi wezwa ukukhala kwami.
\q1 
\v 2 Wangenyula emgodini otshonayo,
\q2 wangikhupha edakeni lexhaphozini;
\q1 wamisa inyawo zami edwaleni,
\q2 wangipha indawo eqinileyo yokuma.
\q1 
\v 3 Wangipha ingoma entsha emlonyeni wami,
\q2 ihubo lokudumisa kuNkulunkulu wethu.
\q1 Abanengi bazabona besabe
\q2 babeke ithemba labo \nd kuThixo\nd*.
\b
\q1 
\v 4 Ubusisiwe umuntu
\q2 owenza \nd uThixo\nd* abe lithemba lakhe,
\q1 ongathembi abazigqajayo,
\q2 lalabo abaqambukela kubonkulunkulu bamanga.
\q1 
\v 5 Zinengi, \nd Thixo\nd*, Nkulunkulu wami,
\q2 izimangaliso ozenzileyo.
\q1 Izinto owasilungiselela zona
\q2 kakho ongazibala kuwe;
\q1 aluba bengingakhuluma
\q2 loba ngilandise ngazo,
\q2 zingaba zinengi ngokweqileyo ukuzibalisa.
\b
\q1 
\v 6 Kawufisanga imihlatshelo leminikelo
\q2 kodwa indlebe zami uzikleklile;
\q2 iminikelo yokutshiswa leminikelo yesono kawuzange uyidinge.
\q1 
\v 7 Lapho-ke ngasengisithi, “Ngilapha, sengifikile
\q2 kulotshiwe ngami emqulwini.
\q1 
\v 8 Ngiyakunxwanela ukwenza intando yakho, Oh Nkulunkulu wami;
\q2 umthetho wakho usenhliziyweni yami.”
\b
\q1 
\v 9 Ngiyafakaza ngokulunga ngisemhlanganweni omkhulu;
\q2 angizivali izindebe zami, njengoba usazi, Oh \nd Thixo\nd*.
\q1 
\v 10 Ukulunga kwakho kangikufihli enhliziyweni yami;
\q2 ngikhuluma ngokuthembeka kwakho lokusindisa kwakho.
\q1 Kangilufihli uthando lwakho leqiniso lakho
\q2 emhlanganweni omkhulu.
\b
\q1 
\v 11 Ungasigodli isihawu sakho kimi, Oh \nd Thixo\nd*;
\q2 sengathi uthando lwakho leqiniso lakho kungahlala kungivikela.
\q1 
\v 12 Phela inhlupheko ezingelakubalwa zingihanqile;
\q2 izono zami sezingificile, kangisaboni.
\q1 Zinengi kulenwele zekhanda lami,
\q2 njalo inhliziyo yami isiphela amandla.
\q1 
\v 13 Jabula, awu \nd Thixo\nd*, ungisindise;
\q2 awu \nd Thixo\nd*, woza masinyane uzongisiza.
\b
\q1 
\v 14 Sengathi bonke abafuna ukuqeda impilo yami
\q2 bangayangiswa basanganiswe;
\q1 sengathi bonke abafisa ukungidiliza
\q2 bangabuyiselwa emuva beyangekile.
\q1 
\v 15 Sengathi bonke abathi kimi, “Ehe, Ehe!”
\q2 banganengwa lihlazo labo.
\q1 
\v 16 Kodwa akuthi bonke abakudingayo
\q2 bathokoze bajabule kuwe;
\q1 akuthi labo abathanda insindiso yakho bahlale besithi,
\q2 \nd “UThixo\nd* kadunyiswe!”
\b
\q1 
\v 17 Kodwa mina ngiyahlupheka, ngiyaswela;
\q2 sengathi iNkosi ingangikhumbula.
\q1 Ilusizo lwami lomkhululi wami;
\q2 Oh Nkulunkulu wami, ungalibali.
\c 41
\cl Ihubo 41
\d Kumqondisi wokuhlabela. Ihubo likaDavida.
\q1 
\v 1 Ubusisiwe lowo onanza abahluphekayo;
\q2 \nd uThixo\nd* uyamkhulula ngezikhathi zokuhlupheka.
\q1 
\v 2 \nd UThixo\nd* uzamvikela alondoloze impilo yakhe;
\q2 uzambusisa phakathi kwelizwe
\q2 akasoze amnikele emandleni ezitha zakhe.
\q1 
\v 3 \nd UThixo\nd* uzamqinisa lanxa elele egula
\q2 njalo amsilise avuke ekuguleni kwakhe.
\b
\q1 
\v 4 Ngathi, “Oh \nd Thixo\nd* ake ungihawukele;
\q2 ngisilisa, ngoba ngonile kuwe.”
\q1 
\v 5 Izitha zami ziyangigcona zithi,
\q2 “Uzakufa nini licitshe ibizo lakhe?”
\q1 
\v 6 Nxa omunye wabo efika ezongibona,
\q2 ukhuluma kuhle angikhohlise,
\q2 kodwa enhliziyweni yakhe egaya izibozi;
\q2 athi angaphuma ahambe esekhihliza ebantwini.
\b
\q1 
\v 7 Bonke abangizondayo banyenyezelana ngami;
\q2 bangicabangela wonke amanyala besithi,
\q1 
\v 8 “Usengenwe ngumkhuhlane omubi;
\q2 kasoze asile avuke futhi.”
\q1 
\v 9 Lomngane wami osekhwapheni,
\q2 ebengimthembile,
\q1 lowo obesidla lami isinkwa
\q2 usengihlamukele.
\b
\q1 
\v 10 Kodwa wena, Oh \nd Thixo\nd* ake ungihawukele;
\q2 ake ungivuse ukuze ngibakhawulise.
\q1 
\v 11 Ngiyazi ukuthi uyathokoza ngami,
\q2 ngoba isitha sami kasingehluli.
\q1 
\v 12 Ubuqotho bami busekelwa nguwe
\q2 njalo ungimisa phambi kwakho nini lanini.
\b
\b
\q1 
\v 13 Udumo alube kuye \nd uThixo\nd*, uNkulunkulu ka-Israyeli,
\q2 kusukela nininini kuze kube nininini.
\qc Ameni njalo Ameni!
\c 42
\ms1 Ugwalo 2
\mr AmaHubo 42 – 72
\cl Ihubo 42
\d Kumqondisi wokuhlabela. \tl Ihubo\tl* lamaDodana kaKhora.
\q1 
\v 1 Njengempala inxwanela imifula yamanzi,
\q2 kunjalo umphefumulo wami uyakunxwanela, Oh Nkulunkulu.
\q1 
\v 2 Umphefumulo wami womela uNkulunkulu, uNkulunkulu ophilayo.
\q2 Ngizahamba nini ngiyohlangana loNkulunkulu?
\q1 
\v 3 Inyembezi zami seziyikudla kwami
\q2 imini lobusuku,
\q1 lapho abantu besithi kimi ilanga lonke,
\q2 “Ungaphi uNkulunkulu wakho?”
\q1 
\v 4 Lezizinto ngiyazikhumbula
\q2 nxa ngizisola kakhulu ngidabukile:
\q1 Ngangihamba endlini kaNkulunkulu,
\q2 ngaphansi kwempiko zikaSomandla
\q1 sihlokoma ngentokozo langokubonga
\q2 lexuku elithakazelela umkhosi.
\b
\q1 
\v 5 Kungani wephukile na, wena mphefumulo wami?
\q2 Kungani udungekile kanje ngaphakathi kwami?
\q1 Beka ithemba lakho kuNkulunkulu,
\q2 ngoba ngisezakumdumisa,
\q2 uMsindisi wami loNkulunkulu wami.
\b
\q1 
\v 6 Umphefumulo wami wephukile ngaphakathi kwami;
\q2 ngakho ngizakukhumbula
\q1 kusukela esifundeni seJodani,
\q2 iziqongo zaseHemoni,
\q2 kusukela entabeni iMizari.
\q1 
\v 7 Inziki imemeza inziki
\q2 phakathi kwenhlokomo yezimpophoma zakho;
\q1 wonke amavinqo lokukhaphaka
\q2 sekugabhela phezu kwami.
\b
\q1 
\v 8 Emini \nd uThixo\nd* uyaluqondisa uthando lwakhe
\q2 ebusuku ingoma yakhe ikhona kimi
\q2 umkhuleko kuNkulunkulu wempilo yami.
\b
\q1 
\v 9 Ngithi kuNkulunkulu iDwala lami,
\q2 “Kutheni usungikhohliwe na?
\q1 Kutheni sengizula ngingolilayo,
\q2 ngincindezelwa yisitha na?”
\q1 
\v 10 Amathambo ami ezwa ubuhlungu obungiqedayo
\q2 lapho izitha zami zingihoza,
\q1 zisithi kimi ilanga lonke,
\q2 “Ungaphi uNkulunkulu wakho?”
\b
\q1 
\v 11 Kungani wephukile na, wena mphefumulo wami?
\q2 Kungani udungekile kanje ngaphakathi kwami?
\q1 Beka ithemba lakho kuNkulunkulu,
\q2 ngoba ngisezakumdumisa,
\q2 uMsindisi wami loNkulunkulu wami.
\c 43
\cl Ihubo 43
\q1 
\v 1 Ngigeza, awu Nkulunkulu,
\q2 ungimele
\q2 uphikise isizwe esingathembekanga;
\q1 ngikhulula ebantwini
\q2 ababi abalenkohliso.
\q1 
\v 2 UnguNkulunkulu inqaba yami.
\q2 Usungilahlelani na?
\q1 Kungani sengizula ngilila
\q2 ngincindezelwa yisitha sami na?
\q1 
\v 3 Thumela ukukhanya kwakho leqiniso lakho,
\q2 kakungikhokhele;
\q1 kakungilethe entabeni yakho engcwele,
\q2 endaweni lapho ohlala khona.
\q1 
\v 4 Lapho-ke ngizakuya e-alithareni likaNkulunkulu,
\q2 kuNkulunkulu, intokozo yami lenjabulo yami.
\q1 Ngizakudumisa ngechacho,
\q2 Oh Nkulunkulu, Nkulunkulu wami.
\b
\q1 
\v 5 Kungani wephukile, wena mphefumulo wami?
\q2 Kungani udungekile kanje ngaphakathi kwami?
\q1 Beka ithemba lakho kuNkulunkulu,
\q2 ngoba ngisezakumdumisa, uMsindisi wami
\q2 loNkulunkulu wami.
\c 44
\cl Ihubo 44
\d Kumqondisi wokuhlabela. \tl Ihubo\tl* lamaDodana kaKhora.
\q1 
\v 1 Sizizwele ngezethu indlebe, yebo Oh Nkulunkulu
\q2 obaba basitshela
\q1 owakwenzayo ensukwini zabo,
\q2 ensukwini zekadeni.
\q1 
\v 2 Ngezakho izandla wazixotsha izizwe
\q2 wagxumeka obaba;
\q1 wabahlifiza abantu
\q2 wenza obaba baphumelela.
\q1 
\v 3 Kwakungasinkemba zabo ezathumba ilizwe,
\q2 njalo kakusingalo yabo eyaletha ukunqoba;
\q1 kwaba yisandla sakho sokunene, ingalo yakho,
\q2 lokukhanya kobuso bakho, ngoba wawubathanda.
\b
\q1 
\v 4 UyiNkosi yami loNkulunkulu wami,
\q2 ophayo ukunqoba kuJakhobe.
\q1 
\v 5 Ngawe siyazihlehlisa izitha zethu;
\q2 ngebizo lakho siyazigxobagxoba izitha zethu.
\q1 
\v 6 Angilithembi idandili lami,
\q2 inkemba yami kayingiletheli ukunqoba;
\q1 
\v 7 kodwa wena usipha ukunqoba phezu kwezitha zethu,
\q2 abalwa lathi ubathela ihlazo.
\q1 
\v 8 Siyazincoma ngoNkulunkulu ilanga lonke,
\q2 njalo sizalidumisa ibizo lakho nini lanini.
\b
\q1 
\v 9 Kodwa manje ususilahlile wasiyangisa;
\q2 kawusaphelekezeli izimpi zethu.
\q1 
\v 10 Wasenza sahlehla phambi kwesitha,
\q2 abalwa lathi sebethethe impango.
\q1 
\v 11 Wasiyekela sadliwa njengezimvu
\q2 wasichithachitha phakathi kwezizwe.
\q1 
\v 12 Wathengisa abantu bakho ngengcosana nje
\q2 awazuza lutho ngalokho kuthengisa.
\b
\q1 
\v 13 Ususenze saba lihlazo kubomakhelwane,
\q2 inhlekisa lendumazo kwesihlalisene labo.
\q1 
\v 14 Ususenze saba yisiga phakathi kwezizwe;
\q2 abantu banyikinya amakhanda ngathi.
\q1 
\v 15 Ukuyangeka kwami kuyangilandela ilanga lonke,
\q2 ubuso bami buhuqwe ngehlazo,
\q1 
\v 16 ngokuhozwa yilabo abangisolayo
\q2 njalo abangenyanyayo,
\q2 ngenxa yesitha esijonge ukuphindisela.
\b
\q1 
\v 17 Konke lokhu kwenzakala kithi,
\q2 lanxa sasingakulibalanga;
\q2 asathembeka esivumelwaneni sakho.
\q1 
\v 18 Inhliziyo zethu zazingabuyelanga emuva;
\q2 inyawo zethu zazingaphambukanga endleleni yakho.
\q1 
\v 19 Kodwa wasichoboza saba yikudla kwamaganyane,
\q2 wasembesa ngomnyama omkhulu.
\b
\q1 
\v 20 Aluba sasesilikhohliwe ibizo likaNkulunkulu wethu
\q2 loba saphakamisela izandla zethu kunkulunkulu wezizweni,
\q1 
\v 21 kambe ngabe uNkulunkulu kakubonanga lokho na,
\q2 njengoba esazi imfihlo zenhliziyo?
\q1 
\v 22 Ikanti ngenxa yakho wena sikhangelane lokufa ilanga lonke;
\q2 sithathwa njengezimvu ezizahlatshwa.
\b
\q1 
\v 23 Vuka, Oh Thixo! Ulaleleni na?
\q2 Ziphaphamise! Ungasilahli kokuphela.
\q1 
\v 24 Ubufihlelani ubuso bakho na,
\q2 ukhohlwe ukuhlupheka kwethu lokuncindezelwa?
\b
\q1 
\v 25 Sesibhuqwe phansi othulini;
\q2 imizimba yethu isinamathele phansi.
\q1 
\v 26 Phakama usisize;
\q2 sihlenge ngenxa yothando lwakho olungaphuthiyo.
\c 45
\cl Ihubo 45
\d Kumqondisi wokuhlabela. Njengengoma ethi “Izimbali.” \tl Ihubo\tl* lamaDodana kaKhora. Ingoma yomtshado.
\q1 
\v 1 Inhliziyo yami iyagubhazela ngendaba enkulu
\q2 nxa ngivuma inkondlo yami ngiyihayela inkosi;
\q2 ulimi lwami lusiba lomlobi ololwazi.
\b
\q1 
\v 2 Uyilikhwa lamakhwa emadodeni wonke
\q2 lezindebe zakho ziconjwe kuhle ngobunono,
\q1 njengalokhu uNkulunkulu
\q2 ekubusisile lanininini.
\b
\q1 
\v 3 Hloma inkemba yakho okhalweni, wena omkhulu;
\q2 zembathise ngokukhazimula langobukhosi.
\q1 
\v 4 Usebukhosini bakho khwela enqoleni ulokunqoba
\q2 umele iqiniso lokuzithoba lokulunga;
\q2 akuthi isandla sakho sokunene senze izimanga.
\q1 
\v 5 Akuthi imitshoko yakho ecijileyo icibe inhliziyo zezitha zenkosi;
\q2 akuthi izizwe ziwe ngaphansi kwezinyawo zakho.
\q1 
\v 6 Isihlalo sakho sobukhosi,
\q2 Oh Nkulunkulu, sizakuma nini lanini;
\q1 intonga yokwahlulela okulungileyo
\q2 izakuba yintonga yombuso wakho.
\q1 
\v 7 Uyakuthanda ukulunga njalo uyabuzonda ububi;
\q2 ngakho uNkulunkulu, uNkulunkulu wakho
\q1 usekubeke ngaphezu kwabakhula bakho
\q2 ngokukugcoba ngamafutha entokozo.
\q1 
\v 8 Zonke izembatho zakho ziqholiwe ngemure,
\q2 langenhlaba langekhasiya;
\q1 ezigodlweni eziceciswe ngempondo zendlovu kuqhamuka
\q2 inhlokomo yeziginci ekuthokozisayo.
\q1 
\v 9 Amadodakazi amakhosi akhona
\q2 kanye labanye abesifazane abahloniphekayo;
\q1 kwesokunene sakho ngumlobokazi wesikhosini
\q2 oceciswe ngegolide lase-Ofiri.
\b
\q1 
\v 10 Lalela, ndodakazi, nanzelela uvule indlebe;
\q2 khohlwa abakini, lendlu yakwenu.
\q1 
\v 11 Inkosi iyaphelelwa ngobuhle bakho;
\q2 yihloniphe, ngoba iyinkosi yakho.
\q1 
\v 12 Indodakazi yaseThire izakuza lesipho,
\q2 amadoda anothileyo azazincengela kuwe.
\q1 
\v 13 Ngaphakathi exhibeni layo
\q2 inkosazana yibucwazicwazi;
\q2 isembatho sayo sicecisiwe ngegolide.
\q1 
\v 14 Isiwa enkosini yembethe izivunulo ezelukiweyo;
\q2 abakhaphi bayo bayayilandela
\q2 balethwe kuwe.
\q1 
\v 15 Bangeniswa lapho ngentokozo lenjabulo;
\q2 bangena esigodlweni senkosi.
\b
\q1 
\v 16 Amadodana enu azathatha isikhundla saboyihlo;
\q2 lizawenza abe ngamakhosana elizweni lonke.
\b
\q1 
\v 17 Ibizo lakho ngizalenza
\q2 likhunjulwe kokuphela yizizukulwane zonke;
\q2 yikho-ke izizwe zizakudumisa nini lanini.
\c 46
\cl Ihubo 46
\d Kumqondisi wokuhlabela. ElamaDodana kaKhora. Ingoma ngendlela \tl ye-alamothi\tl*.
\q1 
\v 1 UNkulunkulu uyisiphephelo sethu lamandla ethu,
\q2 usizo oluhlezi lukhona nxa kulohlupho.
\q1 
\v 2 Ngakho kangiyikwesaba, umhlaba ungaze ubhidlike
\q2 lezintaba ziwele ekujuleni kolwandle,
\q1 
\v 3 loba amanzi alo ehlokoma agubhazele
\q2 izintaba zivevezele ngokuqubuka kwalo.
\b
\q1 
\v 4 Kukhona umfula ozifudlana zawo zithokozisa idolobho likaNkulunkulu,
\q2 indawo engcwele okuhlala kuyo oPhezukonke.
\q1 
\v 5 UNkulunkulu ungaphakathi kwalo, kaliyikuwiswa;
\q2 uNkulunkulu uzalisiza ngovivi lokusa.
\q1 
\v 6 Izizwe ziyahlokoma, imibuso iyachitheka;
\q2 uphakamisa ilizwi lakhe umhlaba uncibilike.
\b
\q1 
\v 7 \nd UThixo\nd* uSomandla ulathi;
\q2 uNkulunkulu kaJakhobe uyinqaba yethu.
\b
\q1 
\v 8 Wozani libone imisebenzi \nd kaThixo\nd*,
\q2 incithakalo aseyenzile emhlabeni.
\q1 
\v 9 Uyathulisa izimpi
\q2 kuze kube semikhawulweni yomhlaba;
\q1 uyalephula idandili avadlaze lomkhonto,
\q2 utshisa izinqola ngomlilo.
\q1 
\v 10 “Thulani, lazi ukuba mina nginguNkulunkulu;
\q2 ngizaphakanyiswa phakathi kwezizwe;
\q2 ngizaphakanyiswa emhlabeni.”
\b
\q1 
\v 11 \nd UThixo\nd* uSomandla ulathi,
\q2 uNkulunkulu kaJakhobe uyinqaba yethu.
\c 47
\cl Ihubo 47
\d Kumqondisi wokuhlabela. ElamaDodana kaKhora. Ihubo.
\q1 
\v 1 Qakezani izandla zenu, zizwe zonke;
\q2 hlokomani kuNkulunkulu ngomsindo wokuthokoza.
\b
\q1 
\v 2 Wesabeka kangakanani \nd uThixo\nd* oPhezukonke,
\q2 iNkosi enkulu kuwo wonke umhlaba!
\q1 
\v 3 Wazehlula zonke izizwe zaba ngaphansi kwethu,
\q2 abantu babangaphansi kwezinyawo zethu.
\q1 
\v 4 Wasikhethela ilifa lethu,
\q2 igugu likaJakhobe amthandayo.
\b
\q1 
\v 5 UNkulunkulu usekhuphukile phakathi komsindo wentokozo,
\q2 \nd uThixo\nd* uphakathi kokukhala kwamacilongo.
\q1 
\v 6 Hlabelelani indumiso kuNkulunkulu, hlabelelani indumiso;
\q2 hlabelelani indumiso eNkosini yethu, hlabelelani indumiso.
\q1 
\v 7 Ngoba uNkulunkulu uyiNkosi yomhlaba wonke;
\q2 hlabelelani kuye ihubo lokudumisa.
\b
\q1 
\v 8 UNkulunkulu uyazibusa izizwe;
\q2 uNkulunkulu uhlezi esihlalweni sakhe sobukhosi esingcwele.
\q1 
\v 9 Izikhulu zezizwe ziyaqoqana
\q2 njengabantu bakaNkulunkulu ka-Abhrahama,
\q1 ngoba amakhosi omhlaba angakaNkulunkulu;
\q2 uphakeme kakhulukazi.
\c 48
\cl Ihubo 48
\d Ingoma. Ihubo lamaDodana kaKhora.
\q1 
\v 1 Umkhulu \nd uThixo\nd*, ufanele ngokuphindiweyo ukudunyiswa,
\q2 emzini kaNkulunkulu wethu, intaba yakhe engcwele.
\b
\q1 
\v 2 Muhle kakhulu ngokuphakama kwakhe,
\q2 uyintokozo yomhlaba wonke.
\q1 Njengeziqongo zeZafoni injalo intaba iZiyoni,
\q2 umuzi weNkosi eNkulu.
\q1 
\v 3 UNkulunkulu usemithangaleni yawo;
\q2 ubonisa ukuthi nguye oyinqaba yawo.
\b
\q1 
\v 4 Kwathi lapho amakhosi ehlanganisa izimpi zawo,
\q2 lapho ehlasela kanyekanye,
\q1 
\v 5 awubona umuzi lo ethuka
\q2 aphaphatheka esetshaywa luvalo.
\q1 
\v 6 Ahle athuthumela khonapho,
\q2 ezwa ubuhlungu obuzwiwa ngowesifazane ehelelwa.
\q1 
\v 7 Wena wabatshabalalisa njengemikhumbi yaseThashishi
\q2 ibhidlizwa ngumoya wempumalanga.
\b
\q1 
\v 8 Lokho esikuzwileyo
\q2 yikho esikubonileyo
\q1 emzini \nd kaThixo\nd* uSomandla,
\q2 emzini kaNkulunkulu wethu:
\q2 uNkulunkulu uzawuvikela lanini.
\b
\q1 
\v 9 Phakathi kwethempeli lakho, Oh Nkulunkulu,
\q2 siyacabanga ngothando lwakho olungaphuthiyo.
\q1 
\v 10 Njengebizo lakho, Oh Nkulunkulu,
\q2 udumo lwakho lufika emikhawulweni yomhlaba;
\q2 isandla sakho sokunene sigcwele ukulunga.
\q1 
\v 11 Intaba iZiyoni iyathokoza,
\q2 imizi yakoJuda iyathaba
\q2 ngezahlulelo zakho.
\b
\q1 
\v 12 Hambahamba eZiyoni, ibhode,
\q2 bala izilindo zayo eziphezulu,
\q1 
\v 13 nanzelela kuhle imithangala yayo,
\q2 hlola izinqaba zayo,
\q1 ukuze ukwazi ukulandisela
\q2 isizukulwane esizayo.
\b
\q1 
\v 14 Ngoba uNkulunkulu lo nguNkulunkulu wethu nini lanini;
\q2 uzakuba ngumholi wethu lasekupheleni.
\c 49
\cl Ihubo 49
\d Kumqondisi wokuhlabela. ElamaDodana kaKhora. Ihubo.
\q1 
\v 1 Zwanini lokhu lina bantu lonke;
\q2 lalelani, lonke elihlala kulo umhlaba,
\q1 
\v 2 abantukazana lezikhulu,
\q2 abanothileyo labayanga ngokufanayo:
\q1 
\v 3 Umlomo wami uzakhuluma amazwi okuhlakanipha;
\q2 amazwi aphuma enhliziyweni yami azanika ukuzwisisa.
\q1 
\v 4 Ngizabeka indlebe yami kuso isaga;
\q2 ngechacho ngizaliqhaqha ilibho:
\b
\q1 
\v 5 Ngingesabelani na nxa kufika insuku ezimbi,
\q2 lapho abakhohlisi ababi bengihanqa,
\q1 
\v 6 labo abathembe inotho yabo
\q2 abazitshaya isifuba ngenotho yabo enengi?
\q1 
\v 7 Kakho umuntu ongahlenga impilo yomunye
\q2 kumbe amkhuphele inhlawulo kuNkulunkulu,
\q1 
\v 8 ngoba ukuhlenga impilo yomuntu kuyadula,
\q2 akulambhadalo engakwenelisa,
\q1 
\v 9 ukuze aphile kokuphela
\q2 angaboni ukubola.
\q1 
\v 10 Phela bonke bayabona ukuthi izihlakaniphi ziyafa;
\q2 ngokunjalo iziwula labasangeneyo bayabhubha
\q2 batshiye inotho yabo kwabanye.
\q1 
\v 11 Amangcwaba abo ayizindlu zabo zanininini,
\q2 yimizi yabo okwezizukulwane ezingapheliyo,
\q2 lokuba nje basebeqambe iziqinti ngamabizo abo.
\b
\q1 
\v 12 Kodwa umuntu, lokuba elenotho, kaphili kokuphela;
\q2 unjengezinyamazana ezibhubhayo.
\b
\q1 
\v 13 Lesi yisiphetho salabo abazithembayo bona,
\q2 labalandeli babo, abavumelana labakutshoyo.
\q1 
\v 14 Njengezimvu bamiselwe ingcwaba,
\q2 ukufa kuzazitika kubo.
\q1 Abaqotho bazabusa phezu kwabo ekuseni;
\q2 izidumbu zabo zizabola engcwabeni,
\q2 kude lemizi yabo efana leyamakhosi.
\q1 
\v 15 Kodwa uNkulunkulu uzayihlenga eyami impilo engcwabeni;
\q2 ngempela uzangithatha angise kuye.
\q1 
\v 16 Ungasuki udangale kakhulu ngokubona omunye enotha;
\q2 nxa indlu yakhe igcwala ngobunkentshenkentshe;
\q1 
\v 17 phela kazukuhamba lalutho mhla esifa,
\q2 ubukhazikhazi lobo kayikwehla labo.
\q1 
\v 18 Loba wayesithi esaphila azibone engobusisiweyo
\q2 abantu bayakukhonza nxa uphumelela,
\q1 
\v 19 uzakuyahlangana lesizukulwane sabokhokho bakhe,
\q2 abangasayikuphinde bakubone ukukhanya kwempilo.
\b
\q1 
\v 20 Umuntu olenotho kodwa engaqedisisi
\q2 unjengezinyamazana ezibhubhayo.
\c 50
\cl Ihubo 50
\d Ihubo lika-Asafi.
\q1 
\v 1 USomandla, uNkulunkulu, \nd uThixo\nd*,
\q2 uyakhuluma, ubiza umhlaba
\q2 kusukela okuphuma khona ilanga kuze kufike lapho elitshona khona.
\q1 
\v 2 EseZiyoni, epheleleyo ngobuhle,
\q2 uNkulunkulu uyakhazimula.
\q1 
\v 3 UNkulunkulu wethu uyeza,
\q2 kayikuthula;
\q1 umlilo uyahangula phambi kwakhe,
\q2 emaceleni akhe kukhukhula isiphepho.
\q1 
\v 4 Ubiza amazulu ngaphezulu lomhlaba,
\q2 ukuze ehlulele abantu bakhe:
\q1 
\v 5 “Qoqani kimi abahlanjululiweyo bami,
\q2 abenza isivumelwano lami ngemihlatshelo.”
\q1 
\v 6 Lamazulu atshumayela ukulunga kwakhe;
\q2 ngoba uNkulunkulu ngumahluleli ngokwakhe.
\b
\q1 
\v 7 “Zwanini, bantu bami, ngizakhuluma;
\q2 yebo Israyeli, ngizafakaza ngimelane lawe;
\q2 nginguNkulunkulu, Nkulunkulu wakho
\q1 
\v 8 Kangikukhuzi ngemihlatshelo yakho
\q2 kumbe iminikelo yakho yokutshiswa,
\q2 ehlezi ikhona phambi kwami.
\q1 
\v 9 Angisweli inkunzi ephuma esibayeni sakho
\q2 kumbe imbuzi zesilugu sakho,
\q1 
\v 10 ngoba yiphi layiphi inyamazana yeganga ngeyami,
\q2 lenkomo ezisemaqaqeni azinkulungwane.
\q1 
\v 11 Ngazi zonke izinyoni ezisezintabeni,
\q2 lezidalwa zeganga ngezami.
\q1 
\v 12 Aluba ngangingolambayo ngangingekulitshela,
\q2 ngoba umhlaba ngowami, lakho konke okukuwo.
\q1 
\v 13 Ngidla inyama yezinkunzi yini
\q2 kumbe nginatha igazi lembuzi na?
\b
\q1 
\v 14 Yenzani imihlatshelo yokubonga kuNkulunkulu,
\q2 gcwalisani izifungo zenu koPhezukonke,
\q1 
\v 15 njalo lize kimi mhla lisekuhluphekeni;
\q2 ngizalikhulula, lani lizangidumisa.”
\p 
\v 16 Kodwa kwababi, uNkulunkulu uthi:
\q1 “Lilelungelo bani ukukhuluma imithetho yami
\q2 kumbe liphathe isivumelwano sami ezindebeni zenu na?
\q1 
\v 17 Liyazizonda iziqondiso zami,
\q2 lilahlela amazwi ami emuva kwenu.
\q1 
\v 18 Lithi lingabona isela lihle libambane lalo;
\q2 lisuka lingenelane lezifebe.
\q1 
\v 19 Lisebenzisa imilomo yenu ukukhuluma okubi
\q2 lifundise ulimi lwenu inkohliso.
\q1 
\v 20 Linyeya umfowenu njalonjalo,
\q2 limgcone umntakanyoko uqobo.
\q1 
\v 21 Lizenzile lezizinto ngazithulela;
\q2 lalikhumbula ukuthi ngifana lani.
\q1 Kodwa ngizalikhuza
\q2 ngilibonisa icala lenu obala.
\b
\q1 
\v 22 Nanzelelani lokhu, lina elikhohlwa uNkulunkulu,
\q2 funa ngilidabudabule, kungekho ongalilamulela:
\q1 
\v 23 Lowo onikela iminikelo yokubonga uyangidumisa,
\q2 njalo ulungisa indlela ukuze ngimtshengise insindiso yami.”
\c 51
\cl Ihubo 51
\d Kumqondisi wokuhlabela. Ihubo likaDavida. Lapho umphrofethi uNathani efike kuye emveni kokuba uDavida efebe loBhathishebha.
\q1 
\v 1 Ake ungihawukele, awu Nkulunkulu,
\q2 ngenxa yothando lwakho olungaphuthiyo;
\q1 ngenxa yesihawu sakho esikhulu
\q2 yesula iziphambeko zami.
\q1 
\v 2 Hlanza wonke amanyala ami
\q2 ungihlambulule esonweni sami.
\b
\q1 
\v 3 Phela ngiyazazi iziphambeko zami,
\q2 isono sami sihlezi siphambi kwami.
\q1 
\v 4 Ngenzile isono kuwe, wena wedwa,
\q2 ngenza okubi phambi kwakho,
\q1 ukuze kukhanye ukuthi wena uqondile nxa ukhuluma
\q2 njalo kube kufanele nxa usahlulela.
\q1 
\v 5 Ngeqiniso ngavele ngazalwa ngilesono,
\q2 ngaba yisoni ngiqalisa esiswini sikamama.
\q1 
\v 6 Ngempela wena ufuna iqiniso elisuka emibilini;
\q2 uyangifundisa ukuhlakanipha ngaphakathi kwami.
\b
\q1 
\v 7 Ngihlanza ngehisophi ngihlambuluke;
\q2 ngigezisa ngibemhlophe kuleliqhwa.
\q1 
\v 8 Mangizwe intokozo lokuthaba;
\q2 makuthi amathambo owacobozileyo ajabule.
\q1 
\v 9 Fihla ubuso bakho esonweni sami
\q2 ucitshe nya wonke amanyala ami.
\b
\q1 
\v 10 Dala phakathi kwami inhliziyo ehlanzekileyo, Oh Nkulunkulu
\q2 uvuselele ngaphakathi kwami umoya othembekileyo.
\q1 
\v 11 Ungangilahli ebusweni bakho
\q2 kumbe ususe kimi uMoya oNgcwele.
\q1 
\v 12 Buyisela kimi intokozo yokusindisa kwakho
\q2 njalo ungiphe umoya ovumayo ukuthi ungisekele.
\b
\q1 
\v 13 Lapho-ke ngizafundisa abonayo izindlela zakho,
\q2 lezoni zizabuyela kuwe.
\q1 
\v 14 Ngikhulula ecaleni lokuchitha igazi, Oh Nkulunkulu,
\q2 uNkulunkulu ongisindisayo,
\q2 njalo ulimi lwami luzahlabelela ukulunga kwakho.
\q1 
\v 15 Oh \nd Thixo\nd*, vula izindebe zami,
\q2 umlomo wami uzamemezela indumiso yakho.
\q1 
\v 16 Kawuthokoziswa yimihlatshelo, ngoba bengizawuletha;
\q2 kawuthakazeleli iminikelo yokutshiswa.
\q1 
\v 17 Imihlatshelo kaNkulunkulu iyinhliziyo edabukileyo;
\q2 inhliziyo edabukileyo, ezisolayo,
\q2 awu Nkulunkulu, kawuyikuyilahla.
\b
\q1 
\v 18 Nxa kuyintando yakho phumelelisa iZiyoni;
\q2 yakha imiduli yeJerusalema.
\q1 
\v 19 Lapho-ke kuzakuba lemihlatshelo elungileyo,
\q2 iminikelo yokutshiswa egcweleyo elungileyo,
\q2 lapho-ke inkunzi zizanikelwa e-alithareni lakho.
\c 52
\cl Ihubo 52
\d Kumqondisi wokuhlabela. \tl Ihubo\tl* likaDavida. Lapho uDoyegi umʼEdomi wayeye kuSawuli wamtshela wathi, “UDavida uye wayangena endlini ka-Ahimeleki.”
\q1 
\v 1 Kungani uncoma ngobubi, wena somandlase?
\q2 Kungani utshona untela ilanga lonke,
\q2 wena olihlazo emehlweni kaNkulunkulu?
\q1 
\v 2 Ulimi lwakho luceba incithakalo;
\q2 lunjengensingo eloliweyo,
\q2 wena owenza inkohliso.
\q1 
\v 3 Uthanda ububi kulobuhle,
\q2 amanga kulokukhuluma iqiniso.
\q1 
\v 4 Uyawathanda wonke amanga alimazayo,
\q2 wena limi olukhohlisayo!
\b
\q1 
\v 5 Ngeqiniso uNkulunkulu uzakwehlisela ukubhubha okungapheliyo:
\q2 Uzakuhlwitha akukhuphe ethenteni lakho;
\q2 uzakuquphula akususe elizweni labaphilayo.
\q1 
\v 6 Abalungileyo bazabona besabe;
\q2 bazamhleka bathi,
\q1 
\v 7 “Nangu-ke manje umuntu
\q2 lo ongenzanga uNkulunkulu inqaba yakhe
\q1 kodwa wathemba inotho yakhe enkulu
\q2 wakhula waba lamandla ngokuwisa abanye!”
\b
\q1 
\v 8 Kodwa mina nginjengesihlahla se-oliva
\q2 esikhula endlini kaNkulunkulu;
\q1 ngithembe uthando lukaNkulunkulu
\q2 olungaphuthiyo nini lanini.
\q1 
\v 9 Ngizakudumisa lanini ngalokho okwenzileyo;
\q2 ngizathemba ebizweni lakho,
\q1 ngoba lihle ibizo lakho.
\q2 Ngizakudumisa phambi kwabangcwele bakho.
\c 53
\cl Ihubo 53
\d Kumqondisi wokuhlabela. Ngendlela \tl yemahalathi\tl*. \tl Ihubo\tl* likaDavida.
\q1 
\v 1 Isiwula sithi enhliziyweni yaso,
\q2 “AkulaNkulunkulu.”
\q1 Baxhwalile, lezindlela zabo zibolile;
\q2 kakho loyedwa owenza okuhle.
\b
\q1 
\v 2 UNkulunkulu ukhangela phansi esezulwini
\q2 emadodaneni abantu
\q1 ingabe bakhona yini abazwisisayo,
\q2 abamdingayo uNkulunkulu.
\q1 
\v 3 Abantu bonke baphambukile,
\q2 bonke sebexhwalile;
\q1 kakho loyedwa owenza okuhle,
\q2 kakho lamunye.
\b
\q1 
\v 4 Kanti lezizixhwali kaziyikufa zafunda yini?
\b
\q1 Zona ezidla abantu bami ingathi zidla isinkwa,
\q2 ezingamkhonziyo uNkulunkulu.
\q1 
\v 5 Kodwa yibo abagubhazeliswa luvalo
\q2 khona kungelalutho olwesabekayo.
\q1 UNkulunkulu wawahlakaza amathambo alabo abalihlaselayo;
\q2 lina labayangisa ngoba uNkulunkulu wabeyisa.
\b
\q1 
\v 6 Sengathi insindiso ka-Israyeli ingaqhamuka eZiyoni!
\q2 Nxa uNkulunkulu esebuyisela impumelelo yabantu bakhe,
\q2 kathokoze uJakhobe lo-Israyeli ajabule!
\c 54
\cl Ihubo 54
\d Kumqondisi wokuhlabela. Kutshaywa iziginci. \tl Ihubo\tl* likaDavida. Lapho amaZifi aya kuSawuli afika athi, “Kanti uDavida kacatshanga yini phakathi kwethu?”
\q1 
\v 1 Ngisindisa, awu Nkulunkulu, ngebizo lakho;
\q2 ngigeza ecaleni ngamandla akho.
\q1 
\v 2 Zwana umkhuleko wami, Oh Nkulunkulu;
\q2 lalela amazwi omlomo wami.
\b
\q1 
\v 3 Ngihlaselwa ngabantu engingabaziyo;
\q2 izikliwi zifuna impilo yami
\q2 abantu abangamnanzanga uNkulunkulu.
\b
\q1 
\v 4 Ngeqiniso uNkulunkulu ulusizo lwami;
\q2 uThixo nguye ongisizayo.
\b
\q1 
\v 5 Akuthi ububi bubuyele phezu kwalabo abangigconayo;
\q2 ngokuthembeka kwakho babhubhise.
\b
\q1 
\v 6 Ngizakwenzela umhlatshelo owomnikelo wokuzithandela;
\q2 ngizalidumisa ibizo lakho, \nd Thixo\nd*, ngoba lihle.
\q1 
\v 7 Ngoba ingikhulule kuzozonke inhlupheko zami,
\q2 lamehlo ami akubonile ukunqotshwa kwezitha zami.
\c 55
\cl Ihubo 55
\d Kumqondisi wokuhlabela. Kutshaywa iziginci. \tl Ihubo\tl* likaDavida.
\q1 
\v 1 Lalela umkhuleko wami, Oh Nkulunkulu,
\q2 ungafulatheli isikhalazo sami;
\q2 
\v 2 ngizwa ungiphendule.
\q1 Imicabango yami iyangikhathaza, ngididekile
\q2 
\v 3 ngelizwi lesitha sami,
\q2 lokunyonkolozwa ngababi;
\q1 ngoba bangibangela
\q2 inhlupho bangithuka bethukuthele.
\b
\q1 
\v 4 Inhliziyo yami iyatshiseka ngaphakathi kwami;
\q2 ukwesaba ukufa kuyangiqinela.
\q1 
\v 5 Ukwesaba lokuthuthumela sekungihlasele;
\q2 isithuli sesingigabhela.
\q1 
\v 6 Ngathi, “He, aluba ngangilamaphiko njengejuba!
\q2 Ngangizaphapha ngizoziphumulela kude.
\q1 
\v 7 Ngangizabaleka ngiye kude
\q2 ngiyehlala enkangala;
\q1 
\v 8 ngangizaphanga ngiye enqabeni yami,
\q2 kude kwesikhukhula lesiphepho.”
\b
\q1 
\v 9 Sanganisa ababi, Oh Thixo,
\q2 sanganisa ukukhuluma kwabo,
\q2 ngoba ngibona udlakela lengxabano edolobheni.
\q1 
\v 10 Emini lebusuku bayacathama emidulini yalo;
\q2 umona lenzondo kugcwele lapho.
\q1 
\v 11 Imimoya yokubhidliza yiyo esibusa;
\q2 izisongo lamanga akusasuki emigwaqweni.
\b
\q1 
\v 12 Aluba ngithukwa yisitha
\q2 ngingakubhensela lokho;
\q1 aluba ongizondayo engivukela
\q2 ngingamcatshela.
\q1 
\v 13 Kodwa nguwe, umuntu njengami,
\q2 umkhula wami, umngane wami oseduze,
\q1 
\v 14 engake ngaba lobudlelwano obukhulu laye
\q1 lapho sasihamba ndawonye
\q2 labanengi endlini kaNkulunkulu.
\b
\q1 
\v 15 Yekela ukufa kuzijume izitha zami;
\q2 yekela bagqitshelwe bephila engcwabeni,
\q2 ngoba ububi buthe khoxo phakathi kwabo.
\b
\q1 
\v 16 Kodwa ngiyambiza uNkulunkulu,
\q2 \nd uThixo\nd* angisindise.
\q1 
\v 17 Kusihlwa, ekuseni lemini
\q2 ngiyakhala ngisosizini,
\q2 yena uyalizwa ilizwi lami.
\q1 
\v 18 Uyangihlenga ngingakalimali
\q2 kuleyompi engihlaselayo,
\q2 loba bebanengi abaxabana lami.
\q1 
\v 19 UNkulunkulu osesihlalweni sobukhosi lanininini,
\q2 uzabezwa abachithachithe
\q1 abantu abangaguqukiyo ezindleleni zabo
\q2 njalo abangamesabiyo uNkulunkulu.
\b
\q1 
\v 20 Umkhula wami uyabahlasela abangane bakhe;
\q2 wephula isivumelwano asenzayo.
\q1 
\v 21 Inkulumo yakhe ibutshelezi njengolaza,
\q2 kodwa kulempi enhliziyweni yakhe
\q1 amazwi akhe alolozela ukwedlula amafutha
\q2 kodwa abukhali kulensingo.
\b
\q1 
\v 22 Yethula inswelo zakho \nd kuThixo\nd*
\q2 yena uzakusekela;
\q2 akazukuyekela abalungileyo bawe.
\q1 
\v 23 Kodwa wena, Nkulunkulu
\q2 ababi uzabawisela egodini lokungcola;
\q1 abantu abomele igazi njalo abakhohlisayo
\q2 kabasoze bayiphile ingxenye yezinsuku zabo.
\b
\q1 Kodwa mina, ngithemba kuwe.
\c 56
\cl Ihubo 56
\d Kumqondisi wokuhlabela. Kulandelwa itshuni ethi, “Ijuba phezu kwemikusu ekude.” ElikaDavida. \tl Imikithamu\tl*. Lapho wayesethunjwe ngamafilistiya eGathi.
\q1 
\v 1 Woba lomusa kimi, Oh Nkulunkulu,
\q2 ngoba abantu baxotshana lami kubi;
\q2 ilanga lonke bayajujumezela bengihlasela.
\q1 
\v 2 Labo abangigconayo baxotshana lami ilanga lonke;
\q2 abanengi bangihlasela bekloloda.
\b
\q1 
\v 3 Nxa ngisesaba ngizathemba kuwe.
\q2 
\v 4 KuNkulunkulu, engidumisa ibizo lakhe,
\q1 ngithemba kuye uNkulunkulu; angiyikwesaba.
\q2 Umuntu wenyama angenzani kimi?
\b
\q1 
\v 5 Ilanga lonke batshona behlanekela amazwi ami;
\q2 beqoqa ukungibhidliza.
\q1 
\v 6 Bayabuthana bengicathamela
\q2 balandele izinyathelo zami
\q2 betshisekela ukucitsha impilo yami.
\q1 
\v 7 Loba sekutheni ungabayekeli baphunyuke;
\q2 ngokuthukuthela kwakho, Nkulunkulu, zidilize izizwe.
\b
\q1 
\v 8 Bhala phansi isililo sami;
\q2 bhala ithonsi ngalinye lezinyembezi zami emqulwini wakho
\q2 kazikho yini emibhalweni yakho?
\q1 
\v 9 Lapho-ke izitha zami zizafulathela
\q2 nxa sengicela uncedo.
\q2 Ngalokhu ngizakwazi ukuthi uNkulunkulu ulami.
\b
\q1 
\v 10 KuNkulunkulu, engidumisa ibizo lakhe,
\q2 \nd kuThixo\nd* engidumisa ibizo lakhe,
\q1 
\v 11 kuNkulunkulu ngiyathemba; angiyikwesaba.
\q2 Umuntu angenzani kimi na?
\b
\q1 
\v 12 Ngibanjwe yizifungo kuwe, Oh Nkulunkulu;
\q2 ngizakwethula umnikelo wami wokubonga kuwe.
\q1 
\v 13 Ngoba ungikhulule ekufeni
\q2 lezinyawo zami lapho ngikhubeka,
\q1 ukuze ngihambe phambi kukaNkulunkulu
\q2 ekukhanyeni kwempilo.
\c 57
\cl Ihubo 57
\d Kumqondisi wokuhlabela. Itshuni ethi, “Ungabhidlizi.” ElikaDavida. \tl Imikithamu.\tl* Ngesikhathi ebalekele uSawuli wacatsha ebhalwini.
\q1 
\v 1 Woba lesihawu kimi, Oh Nkulunkulu, woba lomusa kimi,
\q2 ngoba umphefumulo wami uphelela kuwe.
\q1 Ngizaphephela ethunzini lamaphiko akho
\q2 kuze kudlule incithakalo le.
\b
\q1 
\v 2 Ngiyakhala kuNkulunkulu oPhezukonke,
\q2 kuNkulunkulu ogcwalisa isimiso sakhe ngami.
\q1 
\v 3 Uyathumela esezulwini angisindise,
\q2 abakhwazele labo abafuna ukungilimaza.
\q2 UNkulunkulu uyehlisa uthando lwakhe lokwethembeka kwakhe.
\b
\q1 
\v 4 Ngiphakathi kwezilwane;
\q2 ngilala phakathi kwezilo eziqholozayo
\q1 abantu abamazinyo abo yimikhonto lemitshoko,
\q2 abanlimi zabo zinkemba ezibukhali.
\b
\q1 
\v 5 Mawuphakanyiswe, Oh Nkulunkulu, ngaphezu kwamazulu;
\q2 akuthi inkazimulo yakho ibesemhlabeni wonke.
\b
\q1 
\v 6 Bangithiya ngamambule ezinyaweni
\q2 ngaphela amandla ngokudabuka.
\q1 Bangimbela igodi endleleni
\q2 kodwa sebewele kulo bona.
\b
\q1 
\v 7 Inhliziyo yami ibambelele, kayiguquki Oh Nkulunkulu,
\q2 inhliziyo yami ibambelele;
\q2 ngizahlabela ngenze iculo elimnandi.
\q1 
\v 8 Vuka, mphefumulo wami!
\q2 Vukani, chacho lomqangala!
\q2 Ngizayivusa intathakusa.
\b
\q1 
\v 9 Ngizakudumisa, Oh Thixo, phakathi kwezizwe;
\q2 ngizahlabela ngawe phakathi kwabantu.
\q1 
\v 10 Ngoba lukhulu uthando lwakho, lufika emazulwini;
\q2 ukuthembeka kwakho kufinyelela esibhakabhakeni.
\b
\q1 
\v 11 Mawuphakanyiswe, Oh Nkulunkulu, ngaphezulu kwamazulu;
\q2 akuthi inkazimulo yakho ibesemhlabeni wonke.
\c 58
\cl Ihubo 58
\d Kumqondisi wokuhlabela. Itshuni ethi, “Ungabhidlizi.” ElikaDavida. \tl Imikithamu.\tl*
\q1 
\v 1 Lina babusi, kambe likhuluma okuqondileyo na?
\q2 Lahlulela ngobuqotho yini ebantwini?
\q1 
\v 2 Hatshi, ezinhliziyweni zenu lakha amacebo okubusa kubi,
\q2 lezandla zenu zijezisa ngochuku emhlabeni.
\b
\q1 
\v 3 Kwasekuzalweni ababi bayaphumputheka;
\q2 kwasekuzalweni baxhwalile, beqamba amanga.
\q1 
\v 4 Itshefu yabo ifana letshefu yenyoka,
\q2 ifana leyebululu elingezwa umsindo,
\q1 
\v 5 elingananzi lomculo wombumbi,
\q2 loba lowombumbi eligabazi elinganani.
\b
\q1 
\v 6 Khumula amazinyo emilonyeni yazo, awu Nkulunkulu;
\q2 zikhumule, Oh \nd Thixo\nd*, izingavula zezilwane!
\q1 
\v 7 Yekela zinyamalale njengamanzi agelezayo;
\q2 zithi lapho zinweba idandili,
\q2 kayithundubale imitshoko yazo.
\q1 
\v 8 Njengomnenke uncibilika uphele ulokhu uhamba,
\q2 njengomphunzo, kabangaliboni ilanga.
\b
\q1 
\v 9 Imbiza zakho zingakaqalisi ukutshisa
\q2 ngomlilo wenkuni zameva
\q1 loba ngezimanzi kumbe ngezomileyo
\q2 ababi bazakhukhulelwa khatshana.
\q1 
\v 10 Abalungileyo bazajabula nxa sebephindiselelwa,
\q2 nxa sebegeza inyawo zabo egazini lababi.
\q1 
\v 11 Lapho-ke abantu bazakuthi,
\q2 “Ngempela abalungileyo bajinge bathole umvuzo;
\q2 ngempela ukhona uNkulunkulu owahlulela umhlaba.”
\c 59
\cl Ihubo 59
\d Kumqondisi wokuhlabela. Itshuni ethi, “Ungabhidlizi.” ElikaDavida. \tl Imikithamu.\tl* Ngesikhathi uSawuli ethume amadoda ukuqaphela indlu kaDavida ukuze bambulale.
\q1 
\v 1 Ngikhulula ezitheni zami, awu Nkulunkulu;
\q2 ngivikela kulabo abangivukelayo.
\q1 
\v 2 Ngikhulula kubenzi bobubi
\q2 ungisindise ebantwini abomele igazi.
\b
\q1 
\v 3 Ake ubone ukuthi bangicathamela njani!
\q2 Amadoda esabekayo angakhela amacebo
\q2 kungelacala loba isono engisenzileyo, Oh \nd Thixo\nd*.
\q1 
\v 4 Angonanga lutho, kodwa balungele ukungihlasela.
\q2 Phakama ungisize; ake ubone umumo engikuwo!
\q1 
\v 5 Oh \nd Thixo\nd* Nkulunkulu Somandla,
\q2 Nkulunkulu ka-Israyeli,
\q1 ake uzivuse wena ukuze uzijezise zonke izizwe;
\q2 ungabazweli isihawu bonke abahlamuki ababi.
\b
\q1 
\v 6 Bathi bephenduka kusihlwa
\q2 babe behwabha njengezinja,
\q2 bahwede bebhoda ledolobho.
\q1 
\v 7 Ake ubone ukuthi baphihlizani emilonyeni yabo:
\q2 baphihliza izinkemba ezindebeni zabo,
\q2 bese besithi, “Ngubani osizwayo?”
\q1 
\v 8 Kodwa wena, Oh \nd Thixo\nd*, uyabahleka;
\q2 uyazigqabhazela zonke lezozizwe.
\b
\q1 
\v 9 Oh Mandla ami, ngiyakulindela;
\q2 wena, Oh Nkulunkulu, uyinqaba yami,
\q2 
\v 10 Nkulunkulu wami olothando.
\b
\q1 UNkulunkulu uzahamba phambi kwami
\q2 angenze ngiklolode phezu kwalabo abangingcolisayo.
\q1 
\v 11 Kodwa ungababulali, Nkosi hawu lethu,
\q2 funa abantu bakithi bakhohlwe.
\q1 Ngamandla akho
\q2 baphumputhekise njalo ubehlule wena Thixo, sihlangu sethu.
\q1 
\v 12 Ngenxa yezono zemilomo yabo,
\q2 ngenxa yamazwi ezindebe zabo,
\q2 kababanjwe belokhu bezigqaja benjalo.
\q1 Ngenxa yezethuko lamanga abawaqambayo,
\q2 
\v 13 babhuqe ngolaka, babhuqe bangabi khona futhi.
\q1 Lapho-ke kuzakwaziwa lasemikhawulweni yomhlaba
\q2 ukuthi uNkulunkulu uyabusa phezu kukaJakhobe.
\b
\q1 
\v 14 Bathi bephenduka kusihlwa
\q2 babe behwabha njengezinja,
\q2 bahambahambe becathama edolobheni.
\q1 
\v 15 Bayazula bedinga ukudla
\q2 bahlabe umkhulungwane nxa bengasuthanga.
\q1 
\v 16 Kodwa mina ngizahlabelela ngihaya amandla akho,
\q2 ekuseni ngizahlabelela ngihaya uthando lwakho,
\q1 ngoba wena uyinqaba yami,
\q2 isiphephelo sami ezikhathini zokuhlupheka.
\b
\q1 
\v 17 Oh wena Mandla ami, ngihlabelela indumiso kuwe;
\q2 wena, Oh Nkulunkulu uyinqaba yami,
\q2 Nkulunkulu wami olothando.
\c 60
\cl Ihubo 60
\d Kumqondisi wokuhlabelela. Kulandelwa itshuni ethi, “Iluba lesiVumelwano.” \tl Imikithamu\tl* kaDavida. Elokufundisa. Lapho alwa lo-Aramu Naharayimu lo-Aramu Zobha, njalo lapho uJowabi athi ekubuyeni kwakhe walahla phansi ama-Edomi azinkulungwane ezilitshumi lambili eSigodini seTswayi.
\q1 
\v 1 Ususilahlile, Oh Nkulunkulu, wabhidliza izinqaba zethu;
\q2 ubukade uthukuthele, manje ake usivuselele!
\q1 
\v 2 Usulizamazamisile ilizwe waliqhekeza;
\q2 namathisela iminkenke yalo ngoba selivevezela.
\q1 
\v 3 Ubabonisile abantu bakho izikhathi ezilukhuni;
\q2 usiphe iwayini elisenza sidiyazele.
\q1 
\v 4 Kodwa kulabo abakwesabayo usuphakamise uphawu
\q2 lokubahlanganisa ndawonye.
\b
\q1 
\v 5 Sisindise, usisize ngesandla sakho sokunene,
\q2 ukuze bonke labo obathandayo bakhululwe.
\q1 
\v 6 UNkulunkulu usekhulumile esendlini yakhe engcwele:
\q2 “Ngokunqoba ngizayaba iShekhemu,
\q2 ngihlole leSigodi saseSukhothi.
\q1 
\v 7 Ngeyami iGiliyadi, loManase ngowami;
\q2 u-Efrayimi yisivikelo sekhanda lami,
\q2 uJuda uyintonga yami yobukhosi.
\q1 
\v 8 IMowabi ngumganu wami wokugezela,
\q2 phezu kuka-Edomi ngiphosela amanyathelo ami;
\q2 phezu kweFilistiya ngihalalisa umkhosi wokunqoba.”
\b
\q1 
\v 9 Ngubani ozangisa emzini olenqaba na?
\q2 Ngubani ozangiholela e-Edomi na?
\q1 
\v 10 Kakusuwe na, Oh Nkulunkulu, wena osusilahlile,
\q2 ongasaphumi lathi ezimpini zethu?
\q1 
\v 11 Ake usisize ezitheni zethu,
\q2 ngoba usizo lomuntu luyize.
\q1 
\v 12 Nxa siloNkulunkulu sizanqoba,
\q2 njalo uzazinyathelela phansi izitha zethu.
\c 61
\cl Ihubo 61
\d Kumqondisi wokuhlabela. Kutshaywa iziginci. ElikaDavida.
\q1 
\v 1 Zwana ukukhala kwami, Oh Nkulunkulu;
\q2 lalela umkhuleko wami.
\b
\q1 
\v 2 Ngisemkhawulweni womhlaba ngiyakubiza,
\q2 ngiyabiza lapho inhliziyo yami isiphela amandla;
\q2 ngikhokhelela edwaleni eliphakeme kulami.
\q1 
\v 3 Ngoba ube uyisiphephelo sami,
\q2 inqaba eqinileyo evikela esitheni.
\b
\q1 
\v 4 Ngiyalangazelela ukuhlala ethenteni lakho laphakade
\q2 ngizifihle emthunzini wamaphiko akho.
\q1 
\v 5 Phela usuzizwile izifungo zami, Oh Nkulunkulu;
\q2 usungiphile ilifa lalabo abalesabayo ibizo lakho.
\b
\q1 
\v 6 Yandisa insuku zempilo yenkosi,
\q2 iminyaka yayo okwezizukulwane ezinengi.
\q1 
\v 7 Sengathi ingaba sesihlalweni iphambi kukaNkulunkulu nini lanini;
\q2 wabele uthando Lwakho lokuthembeka Kwakho kuyivikele.
\b
\q1 
\v 8 Lapho-ke ngizahlala ngihlabelela indumiso ebizweni Lakho
\q2 ngigcwalise izifungo zami insuku ngensuku.
\c 62
\cl Ihubo 62
\d Kumqondisi wokuhlabela. KuJeduthuni. Ihubo likaDavida.
\q1 
\v 1 Umphefumulo wami ufumana ukuphumula kuNkulunkulu kuphela;
\q2 ukusindiswa kwami kuvela kuye.
\q1 
\v 2 Yena yedwa uyilo idwala lami lensindiso yami;
\q2 uyinqaba yami, kangisoze ngihlukunyezwe lanini.
\b
\q1 
\v 3 Koze kube nini lilokhu lihlukuluza umuntu na?
\q2 Lonke lizamlahla phansi na
\q1 yena ongumduli otshekileyo,
\q2 oluthango olutebhayo?
\q1 
\v 4 Bazimisele ukumqethula
\q2 esikhundleni sakhe esiphezulu;
\q2 bathokoziswa ngamanga.
\q1 Ngemilomo yabo bayabusisa,
\q2 kodwa ezinhliziyweni zabo bayaqalekisa.
\b
\q1 
\v 5 Fumana ukuphumula, Oh mphefumulo wami,
\q2 kuNkulunkulu kuphela; ithemba lami livela kuye.
\q1 
\v 6 Yena yedwa ulidwala lami lensindiso;
\q2 uyinqaba yami, kangisoze ngihlukunyezwe.
\q1 
\v 7 Insindiso yami lodumo lwami kweyeme kuNkulunkulu;
\q2 ulidwala lami eliqinileyo, isiphephelo sami.
\q1 
\v 8 Thembani kuye ngezikhathi zonke, lina bantu;
\q2 likhuphe konke okusezinhliziyweni zenu kuye,
\q2 ngoba uNkulunkulu uyisiphephelo sethu.
\b
\q1 
\v 9 Abantukazana bangumoya nje,
\q2 izikhulu ziyinkohliso nje;
\q1 aluba belinganiswa esikalini kabasilutho;
\q2 bonke ndawonye bangumoya kuphela.
\q1 
\v 10 Lingathembi ukuqilibezela
\q2 kumbe lizikhukhumeze ngempahla zokwebiwa;
\q1 kungaze kube inotho yenu iyanda,
\q2 lingabeki inhliziyo zenu kuyo.
\b
\q1 
\v 11 Yinye into uNkulunkulu ayikhulumileyo,
\q2 zimbili izinto engizizwileyo,
\q1 ukuthi amandla wonke ngawakho wena, Oh Nkulunkulu.
\q2 
\v 12 Lokuthi wena, Thixo, ulothando olojulileyo,
\q1 umuntu ngamunye uzamupha umvuzo
\q2 ngalokho akwenzileyo.
\c 63
\cl Ihubo 63
\d Ihubo likaDavida eseNkangala yakoJuda.
\q1 
\v 1 Oh Nkulunkulu, unguNkulunkulu wami,
\q2 ngiyakudinga ngitshiseka;
\q1 umphefumulo wami uyakomela,
\q2 umzimba wami uyakudinga,
\q1 elizweni elomileyo eseligugile
\q2 lapho okungelamanzi khona.
\b
\q1 
\v 2 Ngikubonile endlini Yakho engcwele
\q2 ngawabona amandla Akho lenkazimulo Yakho.
\q1 
\v 3 Ngoba uthando Lwakho lungcono kulempilo,
\q2 izindebe zami zizakutsho inkazimulo Yakho.
\q1 
\v 4 Ngizakudumisa kokuphela nxa ngisaphila,
\q2 ngebizo lakho ngizaphakamisa izandla zami.
\q1 
\v 5 Umphefumulo wami uzasuthiswa ngokudla okuhle okuphilisayo;
\q2 ngezindebe ezihlabelayo umlomo wami uzakudumisa.
\b
\q1 
\v 6 Ngisembhedeni wami ngiyakhumbula;
\q2 ngiyakukhumbula lanxa ngisemlindweni wasebusuku.
\q1 
\v 7 Ngoba ulusizo lwami,
\q2 ngiyahlabelela ngisemthunzini wamaphiko Akho.
\q1 
\v 8 Umphefumulo wami unamathele Kuwe;
\q2 isandla sakho sokunene siyangisekela.
\b
\q1 
\v 9 Labo abazingela impilo yami bazabhujiswa;
\q2 bazakwehlela phansi ekujuleni komhlabathi.
\q1 
\v 10 Bazakwabelwa ukudliwa yinkemba
\q2 babe yikudla kwamakhanka.
\b
\q1 
\v 11 Kodwa inkosi izathokoza kuNkulunkulu;
\q2 bonke abafunga ngebizo likaNkulunkulu bazamdumisa,
\q2 ikanti imilomo yabaqamba amanga izathuliswa.
\c 64
\cl Ihubo 64
\d Kumqondisi wokuhlabela. Ihubo likaDavida.
\q1 
\v 1 Ake ungizwe, Oh Nkulunkulu, nxa ngiletha ukusola kwami;
\q2 vikela impilo yami ekusongelweni yisitha.
\b
\q1 
\v 2 Ngifihla emacebeni abantu ababi,
\q2 kulokho kuxokozela kwezixhwali.
\q1 
\v 3 Bayazilola inlimi zabo njengezinkemba
\q2 bakhombele amazwi abo njengemitshoko ebulalayo.
\q1 
\v 4 Batshoka becathemele umuntu ongonanga lutho;
\q2 bayaphanga ukumciba bengelavalo.
\b
\q1 
\v 5 Bayakhuthazana ngamacebo amabi,
\q2 bakhulumisana ngokufihla imijibila yabo;
\q2 bathi, “Sizabonwa ngubani?”
\q1 
\v 6 Baceba ukona besithi,
\q2 “Sesakhe icebo elihle kakhulu!”
\q1 Ngempela ingqondo yomuntu
\q2 lenhliziyo yakhe ilobuqili.
\b
\q1 
\v 7 Kodwa uNkulunkulu uzabaciba ngemitshoko;
\q2 ngokuphangisa nje bazalahlwa phansi.
\q1 
\v 8 Uzakwenza banyeyane bona bodwa bacine sebedilizana;
\q2 bonke abababonayo
\q2 bazanyikinya amakhanda babahleke.
\q1 
\v 9 Bonke abantu bomhlaba bazakwesaba;
\q2 bazafakaza imisebenzi kaNkulunkulu
\q2 banakane ngalokho akwenzileyo.
\b
\q1 
\v 10 Akuthi abalungileyo bathokoze \nd kuThixo\nd*
\q2 baphephele kuye;
\q2 akuthi bonke abaqotho ngenhliziyo bamdumise.
\c 65
\cl Ihubo 65
\d Kumqondisi wokuhlabela. Ihubo likaDavida. Ingoma.
\q1 
\v 1 Udumo lukulindele, Oh Nkulunkulu, eZiyoni;
\q2 kuwe izifungo zethu zizagcwaliseka.
\q1 
\v 2 Yebo, wena owuzwayo umkhuleko,
\q2 bonke abantu bazakuza kuwe.
\q1 
\v 3 Kwathi lapho sisancindezelwa yizono,
\q2 wazithethelela iziphambeko zethu.
\q1 
\v 4 Babusisiwe labo obakhethayo
\q2 ubasondeze bazohlala emagumeni Akho!
\q1 Sigcwalisiwe ngezinto ezinhle zendlu Yakho,
\q2 ezethempeli lakho elingcwele.
\q1 
\v 5 Uyasiphendula ngezenzo zokulunga ezimangalisayo,
\q2 Oh Nkulunkulu Msindisi wethu,
\q1 themba lemikhawulo yonke yomhlaba
\q2 lenlwandle ezikude,
\q1 
\v 6 owabumba izintaba ngamandla akho,
\q2 lapho wena usuziqinisile ngamandla,
\q1 
\v 7 owathulisa ukuduma kolwandle,
\q2 ukuduma kwamagagasi azo,
\q2 lokuhlokoma kwezizwe.
\q1 
\v 8 Labo abahlala khatshana bayazesaba izimangaliso zakho;
\q2 lapho okudabuka khona ukusa lokuhlwa okufiphala khona,
\q2 uhlabela izingoma zentokozo.
\b
\q1 
\v 9 Uyawunakekela umhlaba uwuthelezele ngamanzi;
\q2 uyawunothisa kakhulu.
\q1 Imifula kaNkulunkulu igcwalisiwe ngamanzi
\q2 ukuze abantu bazuze amabele,
\q2 ngoba ukumisile wena lokho.
\q1 
\v 10 Uyayigcwalisa imisele yawo ngamanzi
\q2 uyendlale kahle imibundu yawo;
\q2 uyawuthambisa ngemikhizo ubusise amabele awo.
\q1 
\v 11 Uyawuphelelisa umnyaka ngenala,
\q2 izinqola Zakho ziphuphume ngokugcwala.
\q1 
\v 12 Amadlelo asenkangala ayaphuphuma;
\q2 izintaba zigqokiswe ngenjabulo.
\q1 
\v 13 Amadlelo agcwele imihlambi yezimvu
\q2 lezigodi zisibekelwe ngamabele;
\q2 ziyamemeza ngentokozo zihlabelela.
\c 66
\cl Ihubo 66
\d Kumqondisi wokuhlabela. Ingoma. Ihubo.
\q1 
\v 1 Memezani ngentokozo kuNkulunkulu mhlaba wonke!
\q2 
\v 2 Hlabelani ngobukhosi bebizo lakhe;
\q2 yenzani udumo lwakhe lube lenkazimulo!
\q1 
\v 3 Yitshoni kuNkulunkulu lithi,
\q2 “Imangalisa kangaka imisebenzi yakho!
\q2 Izitha Zakho ziyethuka phambi Kwakho
\q1 
\v 4 Umhlaba wonke uyakhothama Kuwe;
\q2 bahlabela udumo Kuwe,
\q2 bahlabelela udumo ebizweni Lakho.”
\b
\q1 
\v 5 Wozani libone akwenzileyo uNkulunkulu,
\q2 ukumangalisa kwemisebenzi yakhe ayenzela abantu!
\q1 
\v 6 Waguqula ulwandle lwaba ngumhlabathi owomileyo,
\q2 badabula phakathi kwamanzi behamba ngezinyawo
\q2 wozani sithokoze Kuye.
\q1 
\v 7 Uyabusa laphakade ngamandla Akhe,
\q2 amehlo Akhe ayazikhangela izizwe
\q2 sengathi abahlamuki.
\b
\q1 
\v 8 Dumisani uNkulunkulu wethu, lina bantu lonke,
\q2 akuthi inhlokomo yokudunyiswa kwakhe izwakale;
\q1 
\v 9 uzilondolozile impilo zethu
\q2 wavikela inyawo zethu ukuze zingatsheleli.
\q1 
\v 10 Ngoba wena, Oh Nkulunkulu, wasilinga;
\q2 wasicenga njengesiliva.
\q1 
\v 11 Wasingenisa entolongweni
\q2 waseleka ngemithwalo emihlane yethu.
\q1 
\v 12 Wayekela abantu bakhwela bazehlela emakhanda ethu;
\q2 sedlula phakathi komlilo lamanzi,
\q2 kodwa wasiletha endaweni yenala.
\b
\q1 
\v 13 Ngizakuza ethempelini Lakho lomnikelo wokutshiswa
\q2 ngigcwalise izifungo zami Kuwe.
\q1 
\v 14 Izifungo ezathenjiswa yizindebe zami lomlomo wami
\q2 lapho ngisekuhluphekeni.
\q1 
\v 15 Ngizakuhlabela izifuyo ezinonileyo,
\q2 lomnikelo wenqama; ngizanikela ngenkunzi kanye lembuzi.
\b
\q1 
\v 16 Wozani lilalele, lina lonke elimesabayo uNkulunkulu;
\q2 wothani ngilitshele lokho angenzele khona.
\q1 
\v 17 Ngakhala Kuye ngomlomo wami;
\q2 indumiso yakhe yayisolimini lwami.
\q1 
\v 18 Aluba ngangigcine isono enhliziyweni yami,
\q2 iNkosi ngabe kayizange ingilalele;
\q1 
\v 19 kodwa ngeqiniso uNkulunkulu walalela
\q2 walizwa ilizwi lami ngikhuleka.
\q1 
\v 20 Kadunyiswe uNkulunkulu
\q2 ongawulahlanga umkhuleko wami
\q2 futhi ongagodlanga uthando lwakhe kimi.
\c 67
\cl Ihubo 67
\d Kumqondisi wokuhlabela. Kutshaywa iziginci. Ihubo. Ingoma.
\q1 
\v 1 Sengathi uNkulunkulu angaba lomusa kithi asibusise
\q2 akhazimulise ubuso bakhe kithi,
\q1 
\v 2 ukuze izindlela zakho zaziwe emhlabeni,
\q2 insindiso yakho kuzozonke izizwe.
\b
\q1 
\v 3 Sengathi abantu bangakudumisa, Oh Nkulunkulu;
\q2 sengathi bonke abantu bangakudumisa.
\q1 
\v 4 Sengathi izizwe zingajabula zihlabele ngentokozo,
\q2 ngoba wena ubusa abantu ngokulunga
\q2 ukhokhele izizwe zomhlaba.
\q1 
\v 5 Sengathi bonke abantu bangakudumisa Oh Nkulunkulu;
\q2 sengathi abantu bonke bangadumisa wena.
\b
\q1 
\v 6 Lapho-ke umhlaba uzathela isivuno,
\q2 uNkulunkulu, uNkulunkulu wethu, uzasibusisa.
\q1 
\v 7 UNkulunkulu uzasibusisa,
\q2 kuthi yonke imikhawulo yomhlaba izamesaba.
\c 68
\cl Ihubo 68
\d Kumqondisi wokuhlabelela. ElikaDavida. Ihubo. Ingoma.
\q1 
\v 1 UNkulunkulu kaphakame, izitha zakhe azihlakazwe;
\q2 izitha zakhe azimbalekele.
\q1 
\v 2 Njengentuthu iphetshulwa ngumoya lawe baphephulele kude;
\q2 njengengcino encibilikiswa ngumlilo,
\q2 ababi kababhubhe phambi kukaNkulunkulu.
\q1 
\v 3 Kodwa sekungathi abalungileyo bangajabula
\q2 bathokoze phambi kukaNkulunkulu;
\q2 sengathi bangathaba bathokoze.
\b
\q1 
\v 4 Hlabelelani kuNkulunkulu,
\q2 hlabelelani indumiso ebizweni lakhe,
\q1 mphakamiseni yena ohlezi phezu kwamayezi
\q2 lithokoze phambi kwakhe obizo lakhe \nd nguThixo\nd*.
\q1 
\v 5 Uyise wezintandane, umlamuleli wabafelokazi,
\q2 nguNkulunkulu emzini wakhe ongcwele.
\q1 
\v 6 UNkulunkulu uyabalungisela indawo ezimulini labo abalesizungu,
\q2 ukhokhela izibotshwa ngokuhlabela;
\q2 kodwa abahlamuki bahlala elizweni elomileyo.
\b
\q1 
\v 7 Kwathi lapho ukhokhela abantu bakho, Oh Nkulunkulu,
\q2 lapho wawudabula elizweni eliyinkangala,
\q1 
\v 8 umhlaba wanyikinyeka, umkhathi walithulula izulu,
\q2 phambi kukaNkulunkulu, onguYena oweSinayi,
\q2 phambi kukaNkulunkulu ka-Israyeli.
\q1 
\v 9 Wanisa izulu elinengi, Oh Nkulunkulu;
\q2 wavuselela ilifa lakho elaselikhathele.
\q1 
\v 10 Abantu bakho bahlala kulo bazinza,
\q2 kwathi ngokuphana kwakho Nkulunkulu,
\q2 wabaphakela abangabayanga.
\b
\q1 
\v 11 INkosi yalikhupha ilizwi,
\q2 kwaba labanengi kakhulu abalimemezelayo besithi,
\q1 
\v 12 “Makhosi lamabutho phangisani libaleke;
\q2 ezihonqweni amakhosikazi abelana impango.
\q1 
\v 13 Khonapho lisalele phakathi kwemililo yezihonqo,
\q2 impiko zejuba lami zihuqiwe ngesiliva,
\q2 izinsiba zalo ngegolide elikhazimulayo.”
\q1 
\v 14 Lapho uSomandla wawahlakaza amakhosi elizwe,
\q2 kwakunjengongqwaqwane eqoqene phezu kweZalimoni.
\b
\q1 
\v 15 Izintaba zeBhashani yizintaba ezilesithunzi;
\q2 zilezindongandonga izintaba zaseBhashani.
\q1 
\v 16 Kungani linyonkoloza ngomona,
\q2 lina zintaba ezindongandonga,
\q1 leyontaba uNkulunkulu akhetha ukubusa kuyo,
\q2 lapho \nd uThixo\nd* ngokwakhe uzahlala khona lanini?
\q1 
\v 17 Izinqola zikaNkulunkulu zingamatshumi ezinkulungwane;
\q2 lezinkulungwane zezinkulungwane;
\q2 iNkosi isifikile ivela eSinayi yangena endlini yayo engcwele.
\q1 
\v 18 Wathi ekukhuphukeni kwakho uqansa,
\q2 wakhokhela abathunjiweyo;
\q2 wemukela izipho ebantwini,
\q1 lakulabo abahlamukayo
\q2 ukuze wena, Oh \nd Thixo\nd* Nkulunkulu, uhlale khona.
\b
\q1 
\v 19 Udumo kalube kuThixo, kuNkulunkulu uMsindisi wethu,
\q2 othwala imithwalo yethu insuku zonke.
\q1 
\v 20 UNkulunkulu wethu nguNkulunkulu osindisayo;
\q2 \nd kuThixo\nd* wobukhosi kuvela ukuphepha ekufeni.
\q1 
\v 21 Ngeqiniso uNkulunkulu uzawachoboza amakhanda ezitha zakhe,
\q2 imiqhele eloboya yalabo abaqhubekayo ngezono zabo.
\q1 
\v 22 INkosi ithi, “Ngizabaletha besuka eBhashani;
\q2 ngizabaletha besuka ekujuleni kolwandle,
\q1 
\v 23 ukuze ligxamuze inyawo zenu egazini lezitha zenu,
\q2 lezilimi zezinja zenu zibe lesabelo sazo.”
\b
\q1 
\v 24 Udwendwe lwakho Nkulunkulu seluqhamuka, yebo
\q2 udwendwe lukaNkulunkulu wami leNkosi
\q2 lungena endlini engcwele.
\q1 
\v 25 Phambili ngabahlabeleli, kulandele abamachacho;
\q2 phakathi kwabo kulamantombazana atshaya amagedla.
\q1 
\v 26 Dumisani uNkulunkulu ebandleni elikhulu;
\q2 dumisani \nd uThixo\nd* embuthanweni ka-Israyeli.
\q1 
\v 27 Masinyane isizwana sakoBhenjamini sibakhokhele,
\q2 nantiyana ixuku elikhulu lamakhosana kaJuda,
\q2 njalo nankayana amakhosana kaZebhuluni lakaNafithali.
\b
\q1 
\v 28 Veza amandla akho, Oh Nkulunkulu,
\q2 sitshengise amandla akho Nkulunkulu,
\q2 njengowakwenza endulo.
\q1 
\v 29 Ngenxa yethempeli lakho eliseJerusalema
\q2 amakhosi azakulethela izipho.
\q1 
\v 30 Khuza isilo esiphakathi kwemihlanga
\q2 umhlambi wenkunzi phakathi kwamathole ezizwe.
\q1 Sezithotshisiwe kazilethe izibhebhedu zesiliva.
\q2 Hlakaza izizwe ezithokoza ngempi.
\q1 
\v 31 Amanxusa azavela eGibhithe;
\q2 iKhushi izazithoba kuNkulunkulu.
\b
\q1 
\v 32 Hlabelelani kuNkulunkulu, awu lina mibuso yomhlaba,
\q2 hlabelelani indumiso kuThixo,
\q1 
\v 33 kuye ohlala phezu kwesibhakabhaka sekadeni,
\q2 okhwaza ngelizwi elikhulu.
\q1 
\v 34 Fakazani ngamandla kaNkulunkulu,
\q2 obukhosi bakhe buphezu kuka-Israyeli;
\q2 omandla akhe asesibhakabhakeni.
\q1 
\v 35 Uyamangalisa, Oh Nkulunkulu, usendlini yakho engcwele;
\q2 uNkulunkulu ka-Israyeli upha amandla ebantwini bakhe.
\b
\q1 Indumiso kayibe kuNkulunkulu!
\c 69
\cl Ihubo 69
\d Kumqondisi wokuhlabela. Itshuni ethi, “Amaluba.” ElikaDavida.
\q1 
\v 1 Ngisindisa, Oh Nkulunkulu,
\q2 ngoba umsinga wamanzi usugamenxe ngentamo yami.
\q1 
\v 2 Ngiyagalula ezinzikini ezitotayo,
\q2 lapho okungekho ndawo yokugxila.
\q1 Sengifike enzikini;
\q2 impophoma sezingikhulela.
\q1 
\v 3 Sengidiniwe yikumemeza ngicela uncedo;
\q2 umphimbo wami usome qha.
\q1 Amehlo ami aseze efiphele,
\q2 edinga uNkulunkulu wami.
\q1 
\v 4 Labo abangizondayo kungelasizatho
\q2 banengi okwedlula inwele zekhanda lami;
\q1 banengi abayizitha zami kungelambangela,
\q2 labo abafuna ukungidiliza.
\q1 Ngiyaphoqelwa ukuhlawula
\q2 engingakuntshontshanga.
\b
\q1 
\v 5 Uyabazi ubuthutha bami, wena Nkulunkulu;
\q2 isono sami kasifihlakalanga kuwe.
\b
\q1 
\v 6 Akuthi labo abathemba kuwe
\q2 bangayangiswa ngenxa yami,
\q2 Oh Thixo, \nd Thixo\nd* Somandla;
\q1 akuthi labo abakudingayo,
\q2 bangahlaziswa ngenxa yami,
\q2 Oh Nkulunkulu ka-Israyeli.
\q1 
\v 7 Ngiyakubhensela ukugconwa ngenxa yakho,
\q2 ihlazo lihuqiwe ebusweni bami.
\q1 
\v 8 Ngingowemzini kubafowethu,
\q2 ngingowemzini emadodaneni kamama;
\q1 
\v 9 ngoba ukutshisekela indlu yakho kufuthelene kimi,
\q2 lezethuko zalabo abakuthukayo ziwela kimi.
\q1 
\v 10 Ngithi lapho ngilila ngizila ukudla,
\q2 ngibhensele ukwetheswa inhlamba;
\q1 
\v 11 kuthi lapho ngivunula amasaka
\q2 abantu badlale ngami.
\q1 
\v 12 Labo abalinda emasangweni bayangihleka,
\q2 ngiyingoma nje yezidakwa.
\b
\q1 
\v 13 Kodwa ngikhuleka kuwe, Oh \nd Thixo\nd*,
\q2 ngesikhathi somusa wakho;
\q1 ngothando lwakho olukhulu, Oh Nkulunkulu,
\q2 ngiphendula ngensindiso yakho eqinisekileyo.
\q1 
\v 14 Ngihlenga exhaphozini,
\q2 ungangiyekeli ngigalule;
\q1 ngikhulula kulabo abangizondayo,
\q2 emanzini atshonayo.
\q1 
\v 15 Ungayekeli izikhukhula zingigalulise
\q2 loba inziki zingiginye,
\q2 loba umgodi uvaleke umlomo wawo phezu kwami.
\b
\q1 
\v 16 Ngiphendula, Oh \nd Thixo\nd*, ngenxa yokulunga kothando lwakho;
\q2 emuseni wakho omkhulu phendukela kimi.
\q1 
\v 17 Ungayifihleli ubuso bakho inceku yakho;
\q2 ngiphendula masinyane, ngoba ngiphakathi kohlupho.
\q1 
\v 18 Sondela ungikhulule;
\q2 ngihlenga ngenxa yezitha zami.
\b
\q1 
\v 19 Uyakwazi ukuthi ngigconwa njani,
\q2 ngihlaziswa njalo ngiyangiswa;
\q2 zonke izitha zami ziphambi kwakho.
\q1 
\v 20 Ukugconwa sekuyephule inhliziyo yami
\q2 kwangitshiya esithubeni;
\q1 ngadinga uzwelo ngaluswela,
\q2 abaduduzi, kodwa ngabaswela.
\q1 
\v 21 Bathela inyongo ekudleni kwami
\q2 banginathisa iviniga nxa ngomile.
\b
\q1 
\v 22 Sengathi itafula eliphambi kwabo lingaba ngumjibila;
\q2 sengathi lingaba yisijeziso lesithiyo.
\q1 
\v 23 Sengathi amehlo abo angafiphala ukuze bangaboni,
\q2 lamaqolo abo akhokhobe kokuphela.
\q1 
\v 24 Thululela ulaka lwakho phezu kwabo;
\q2 akuthi ulaka lwakho olwesabekayo lubehlele.
\q1 
\v 25 Sengathi indawo yabo ingaba ngamanxiwa;
\q2 akungabi lamuntu ozahlala emathenteni abo.
\q1 
\v 26 Ngoba bahlupha labo obalimazayo
\q2 bakhulume ngobuhlungu balabo obalimazayo.
\q1 
\v 27 Bethese amacala phezu kwamacala;
\q2 ungayekeli bazuze isabelo sensindiso yakho.
\q1 
\v 28 Sengathi bangesulwa encwadini yokuphila
\q2 bangaze babalwa kanye labalungileyo.
\b
\q1 
\v 29 Ngisebuhlungwini, ngikhathazekile;
\q2 sengathi insindiso yakho, Oh Nkulunkulu ingangivikela.
\b
\q1 
\v 30 Ngizalidumisa ibizo likaNkulunkulu ngengoma,
\q2 ngilibabaze ngokubonga.
\q1 
\v 31 Lokhu kuzamthabisa \nd uThixo\nd* okwedlula inkabi,
\q2 okwedlula inkunzi yonke ilempondo lamangqina ayo.
\q1 
\v 32 Abayanga bazabona bajabule
\q2 lina elimdingayo uNkulunkulu,
\q2 sengathi inhliziyo zenu zingaphila!
\q1 
\v 33 \nd UThixo\nd* uyabezwa abaswelayo,
\q2 kabeyisi abantu bakhe abathunjiweyo.
\b
\q1 
\v 34 Akuthi izulu lomhlaba kumdumise,
\q2 inlwandle lakho konke okunyakaza kuzo,
\q1 
\v 35 ngoba uNkulunkulu uzayisindisa iZiyoni
\q2 ayakhe kutsha imizi yakoJuda.
\q1 Yikhona-ke abantu bazakwakha khona balithathe libe ngelabo;
\q2 
\v 36 abantwana bezinceku zayo lizakuba yilifa labo,
\q2 labalithandayo ibizo lakhe bazahlala khona.
\c 70
\cl Ihubo 70
\d Kumqondisi wokuhlabela. ElikaDavida. Isikhalazo.
\q1 
\v 1 Phangisa, Oh Nkulunkulu, ungisindise;
\q2 Oh \nd Thixo\nd*, woza masinyane uzongisiza.
\b
\q1 
\v 2 Sengathi labo abafuna impilo yami
\q2 bangayangiswa basanganiswe; sengathi
\q1 bonke abafisa ukuwa kwami
\q2 bangabuyiselwa emuva beyangekile.
\q1 
\v 3 Sengathi labo abathi kimi, “Ehe! Ehe!”
\q2 bangafulathela ngenxa yehlazo labo.
\q1 
\v 4 Kodwa akuthi bonke abakudingayo
\q2 bathokoze bajabule kuwe;
\q1 akuthi labo abathanda insindiso yakho bahlale besithi,
\q2 “\nd uThixo\nd* kadunyiswe!”
\b
\q1 
\v 5 Ikanti ngingumyanga ngiyaswela;
\q2 woza masinyane kimi, Oh Nkulunkulu.
\q1 Ulusizo lwami lomkhululi wami;
\q2 Oh \nd Thixo\nd*, ungaphuzi.
\c 71
\cl Ihubo 71
\q1 
\v 1 Kuwe \nd Thixo\nd*, sengithole isiphephelo;
\q2 mangingayangiswa lanini.
\q1 
\v 2 Ngihlenga ungikhulule ngokulunga kwakho;
\q2 ngilalela, woza ngokuphangisa ungisindise.
\q1 
\v 3 Woba lidwala lami lokuphephela,
\q2 lapho engingaya khona loba nini;
\q1 tshono umlayo wokuba ngisindiswe,
\q2 ngoba ulidwala lami lenqaba yami.
\q1 
\v 4 Ngikhulula, Oh Nkulunkulu, esandleni sababi,
\q2 emandleni abantu ababi abalochuku.
\b
\q1 
\v 5 Ngoba ube ulithemba lami, Oh \nd Thixo\nd* Wobukhosi,
\q2 ithemba lami kusukela ebutsheni bami.
\q1 
\v 6 Kusukela ekuzalweni kwami ngahle ngeyama kuwe;
\q2 nguwe owangikhuphayo esiswini sikamama.
\q2 Ngizakudumisa njalonjalo.
\q1 
\v 7 Senginjengomhlolo kwabanengi,
\q2 kodwa wena uyisiphephelo sami esiqinileyo.
\q1 
\v 8 Umlomo wami ugcwele udumo lwakho,
\q2 umemezela inkazimulo yakho ilanga lonke.
\b
\q1 
\v 9 Ungangilahleli kude nxa sengiluphele;
\q2 ungangifulatheli lapho amandla ami esephelile.
\q1 
\v 10 Ngoba izitha zami zikhuluma kubi ngami;
\q2 labo abalindele ukungibulala bahlangana ngami.
\q1 
\v 11 Bathi, “UNkulunkulu usemlahlile;
\q2 xotshanani laye limbambe,
\q2 ngoba kakho ozamlamulela.”
\q1 
\v 12 Ungabi khatshana kwami, Oh Nkulunkulu;
\q2 woza masinyane, Oh Nkulunkulu wami, uzongisiza.
\q1 
\v 13 Sengathi labo abangethesa amacala
\q2 bangabhubha beyangekile;
\q2 sengathi labo abafuna ukungilimaza
\q2 bangabhixwa ngehlazo lokuyangeka.
\b
\q1 
\v 14 Kodwa mina ngizahlala ngithembile;
\q2 ngizakudumisa kakhulu.
\b
\q1 
\v 15 Umlomo wami uzafakaza ngokulunga kwakho,
\q2 langensindiso yakho ilanga lonke,
\q2 lokuba ngingasazi isilinganiso sayo.
\q1 
\v 16 Ngizakuza ngifakaze ngemisebenzi yakho emikhulu,
\q2 Oh \nd Thixo\nd* Wobukhosi;
\q2 ngizafakaza ngokulunga kwakho, okwakho wedwa.
\q1 
\v 17 Kusukela ebutsheni bami, Oh Nkulunkulu, wangifundisa,
\q2 kuze kube lamuhla ngimemezela
\q2 imisebenzi yakho emangalisayo.
\q1 
\v 18 Lokuba sengiluphele sengiyimpunga
\q2 ungangideli, Oh Nkulunkulu,
\q1 ngize ngifakaze ngamandla akho esizukulwaneni esizayo,
\q2 amandla akho kubo bonke abalandelayo.
\b
\q1 
\v 19 Ukulunga kwakho kufika emkhathini, Oh Nkulunkulu,
\q2 wena osuwenze izinto ezinkulu.
\q2 Ngubani, Oh Nkulunkulu, onjengawe?
\q1 
\v 20 Loba usungenze ngabona inhlupheko
\q2 ezinengi lezibuhlungu,
\q2 uzangenyula njalo ekujuleni komhlabathi.
\q1 
\v 21 Uzalwandisa udumo lwami
\q2 ungiduduze futhi njalo.
\b
\q1 
\v 22 Ngizakudumisa ngechacho
\q2 ngenxa yokuthembeka kwakho,
\q2 Nkulunkulu wami;
\q1 ngizahlabelela indumiso kuwe ngomqangala,
\q2 wena oNgcwele ka-Israyeli.
\q1 
\v 23 Izindebe zami zizamemeza ngentokozo
\q2 lapho ngihlabelela indumiso kuwe
\q2 mina ongisindisileyo.
\q1 
\v 24 Ulimi lwami luzatshona lukhuluma ngokulunga kwakho
\q2 ilanga lonke,
\q1 ngoba labo abafuna ukungilimaza
\q2 sebeyangisiwe basanganiswa.
\c 72
\cl Ihubo 72
\d ElikaSolomoni.
\q1 
\v 1 Yiphe inkosi ukwahlulela kwakho, Oh Nkulunkulu,
\q2 lokulunga kwakho indodana yesikhosini.
\q1 
\v 2 Uzakwahlulela abantu bakho ngokulunga,
\q2 labahluphekayo bakho ngemfanelo.
\b
\q1 
\v 3 Izintaba zizaletha ukuphumelela ebantwini,
\q2 lamaqaqa azaletha izithelo zokulunga.
\q1 
\v 4 Uzabavikela abahlukuluzwayo phakathi kwabantu
\q2 asindise abantwana balabo abaswelayo
\q2 afohloze umncindezeli.
\q1 
\v 5 Uzaphila kokuphela njengelanga,
\q2 njengenyanga kuzozonke izizukulwane.
\q1 
\v 6 Uzakuba njengezulu lisina phezu kotshani obugundiweyo,
\q2 njengemikhizo ithelezela umhlabathi.
\q1 
\v 7 Ngezinsuku zayo abalungileyo bazaphumelela;
\q2 ukuphumelela kuzakwanda inyanga ize itshabalale.
\b
\q1 
\v 8 Uzabusa kusukela elwandle kusiya elwandle,
\q2 njalo kusukela eMfuleni kusiya emikhawulweni yomhlaba.
\q1 
\v 9 Izizwe ezihlala enkangala zizakhothama kuye,
\q2 izitha zakhe zizakhotha uthuli.
\q1 
\v 10 Amakhosi eThashishi lawemazweni akude
\q2 azaletha imithelo kuye;
\q1 amakhosi aseShebha leSebha
\q2 azayilethela izipho.
\q1 
\v 11 Wonke amakhosi azakhothama kuye
\q2 lezizwe zonke zizakhonza kuye.
\b
\q1 
\v 12 Ngoba uzabakhulula abaswelayo abakhalayo kuye,
\q2 abahluphekayo abangelamsizi.
\q1 
\v 13 Uzabahawukela ababuthakathaka
\q2 labaswelayo asindise abaswelayo ekufeni.
\q1 
\v 14 Uzabahlenga ekuncindezelweni lekuhlukuluzweni,
\q2 ngoba igazi labo liligugu kuye.
\b
\q1 
\v 15 Mayibe lempilo ende!
\q2 Mayiphiwe igolide laseShebha.
\q1 Abantu kabayikhulekele
\q2 bayenzele izibusiso ilanga lonke.
\q1 
\v 16 Akuthi amabele ande elizweni lonke;
\q2 azunguze eziqongweni zamaqaqa.
\q1 Izithelo zalo kazikhihlize njengeLebhanoni;
\q2 kaligcwale njengotshani egangeni.
\q1 
\v 17 Sengathi ibizo lakhe lingema njalo laphakade,
\q2 kalibe khona lanini nxa lilokhu lisekhona ilanga.
\b
\q1 Zonke izizwe zizabusiswa ngaye,
\q2 zizakuthi ubusisiwe.
\b
\b
\q1 
\v 18 Udumo alube kuye \nd uThixo\nd* uNkulunkulu, uNkulunkulu ka-Israyeli,
\q2 onguye yedwa owenza izinto ezimangalisayo.
\q1 
\v 19 Udumo kalube sebizweni lakhe elingcwele laphakade;
\q2 sengathi umhlaba wonke ungagcwala inkazimulo yakhe.
\qc Ameni njalo Ameni.
\b
\b
\q1 
\v 20 Lokhu yikho ukuphetha kwemikhuleko kaDavida indodana kaJese.
\c 73
\ms1 Ugwalo 3
\mr AmaHubo 73 – 89
\cl Ihubo 73
\d Ihubo lika-Asafi.
\q1 
\v 1 Ngempela uNkulunkulu ulungile ku-Israyeli,
\q2 kulabo abahlanzekileyo enhliziyweni.
\b
\q1 
\v 2 Kodwa mina, inyawo zami zaphose zatshelela;
\q2 ngaphose ngakhuthisa ukunyathela.
\q1 
\v 3 Ngasuka ngahawukela abaklolodayo
\q2 ngibona ukuphumelela kwezigangi.
\b
\q1 
\v 4 Kabalazo inhlungu;
\q2 imizimba yabo iphilile iqinile.
\q1 
\v 5 Kabalayo imithwalo enzima ejayelekileyo ebantwini;
\q2 kabahlukuluzwa loba yini njengabanye abantu.
\q1 
\v 6 Ngakho-ke ukuziqhenya kuyisigqizo sabo entanyeni;
\q2 bazigqokisa ngokwenza isihluku.
\q1 
\v 7 Ezinhliziyweni zabo ezingelazwelo kuphuma ububi;
\q2 iminakano emibi yezingqondo zabo ayilamikhawulo.
\q1 
\v 8 Bayakloloda, bakhulume ngomona;
\q2 bayaqholoza basongele ukuncindezela.
\q1 
\v 9 Imilomo yabo ithi izulu selingelabo,
\q2 lezilimi zabo zihle ziwuthathe umhlaba.
\q1 
\v 10 Yikho abantu bakibo bebakholwa,
\q2 bawanathe amanzi kakhulukazi.
\q1 
\v 11 Bathi, “UNkulunkulu angakwazi kanjani?
\q2 OPhezukonke ulalo ulwazi na?”
\b
\q1 
\v 12 Yikho lokhu abayikho khona ababi
\q2 bavele kabananzi, iyanda eyabo inotho.
\b
\q1 
\v 13 Ngempela bekuyize ukugcina inhliziyo yami ihlanzekile;
\q2 kube yize ukugeza izandla zami ngokungelacala.
\q1 
\v 14 Ilanga lonke ngitshona ngikhathazwa;
\q2 ngiyajeziswa ekuseni zonke insuku.
\b
\q1 
\v 15 Aluba ngangithe,
\q2 “Ngizakhuluma ngitsho njalo,”
\q2 ngabe ngangibakhohlisa abantwabakho.
\q1 
\v 16 Ngathi ngizama ukukuzwisisa konke lokhu
\q2 ngezwa kungisinda,
\q1 
\v 17 ngaze ngangena endlini engcwele kaNkulunkulu;
\q2 lapho-ke ngasengizwisisa isiphetho sabo.
\b
\q1 
\v 18 Ngempela uyababeka endaweni etshelelayo;
\q2 ubalahlela phansi ekubhujisweni.
\q1 
\v 19 Yeka, ukubhujiswa kwabo lula nje,
\q2 bakhuculwe nje yikwesaba!
\q1 
\v 20 Njengephupho nxa umuntu ephaphama
\q2 kuzakuba njalo lapho usuvuka, Thixo,
\q2 uzabeyisa njengemifanekiso yengqondo kuphela.
\b
\q1 
\v 21 Lapho inhliziyo yami yayifuthelene
\q2 lomoya wami uthukuthele,
\q1 
\v 22 ngangiyisithutha esingaziyo;
\q2 ngangiyinyamazana yeganga kuwe.
\b
\q1 
\v 23 Ikanti ngihlezi ngilawe;
\q2 uyangibamba ngesandla sami sokunene.
\q1 
\v 24 Uyangikhokhela ngokweluleka kwakho
\q2 kuthi ngemva kwalokho uzangithatha ungise ebukhosini.
\q1 
\v 25 Ngilobani na ezulwini ngaphandle kwakho?
\q2 Lomhlaba kawulakho engikufisayo ngaphandle kwakho.
\q1 
\v 26 Inyama yami lenhliziyo yami kungehluleka
\q2 kodwa uNkulunkulu ungamandla enhliziyo yami,
\q2 uyisabelo sami laphakade.
\b
\q1 
\v 27 Labo abakhatshana lawe bazabhubha;
\q2 uyababhidliza bonke abangathembekanga kuwe.
\q1 
\v 28 Kodwa mina kimi kuhle ukuba seduze loNkulunkulu.
\q2 Sengenze \nd uThixo\nd* Wobukhosi isiphephelo sami;
\q2 ngizafakaza ngazozonke izenzo zakho.
\c 74
\cl Ihubo 74
\d \tl Ihubo\tl* lika-Asafu
\q1 
\v 1 Kungani ususilahlile kokuphela na, awu Nkulunkulu?
\q2 Kungani ulaka lwakho luvutha phezu kwezimvu zedlelo lakho na?
\q1 
\v 2 Khumbula abantu owabathengayo ekadeni,
\q2 isizwe selifa lakho owasihlengayo
\q2 iNtaba iZiyoni, owawuhlala khona.
\q1 
\v 3 Phenduka ungene emanxiweni aphakade la,
\q2 incithakalo yonke le yenziwe yisitha endlini engcwele.
\b
\q1 
\v 4 Izitha zakho zazibhonga endaweni owawuhlangana lathi kuyo;
\q2 zamisa impawu zazo njengeziboniso.
\q1 
\v 5 Zenza njengabantu abaphakamise amahloka
\q2 ukuphendla indlela yabo eguswini.
\q1 
\v 6 Zafohloza konke okubaziweyo
\q2 ngamahloka azo langezando.
\q1 
\v 7 Zatshisa indlu yakho engcwele yaphela nya;
\q2 zangcolisa indawo ehlala iBizo lakho.
\q1 
\v 8 Zathi ngezinhliziyo zazo, “Sizababhuqa baphele nya!”
\q2 Zatshisa zonke izindawo zokukhonzela uNkulunkulu elizweni.
\b
\q1 
\v 9 Kasisaboniswa mimangaliso; kakuselabuphrofethi,
\q2 kakho kithi owaziyo ukuthi
\q2 kuzaze kube nini kunjalo.
\q1 
\v 10 Koze kube nini isitha sikuklolodela na, awu Nkulunkulu?
\q2 Izitha zizalithuka kokuphela ibizo lakho na?
\q1 
\v 11 Kungani ufinyeza isandla sakho sokunene na?
\q2 Sikhuphe ezingoxweni zezembatho zakho ubabhubhise.
\b
\q1 
\v 12 Kodwa wena Nkulunkulu uyiNkosi yami kwasekadeni;
\q2 uletha insindiso emhlabeni.
\b
\q1 
\v 13 Kwakunguwe owaqhekeza ulwandle ngamandla akho;
\q2 wafohloza amakhanda esilo phakathi kwamanzi.
\q1 
\v 14 Kwakunguwe owachoboza amakhanda kaLeviyathani
\q2 waba yikudla kwezidalwa zasenkangala.
\q1 
\v 15 Kwakunguwe owavula imithombo lemifula;
\q2 womisa qha imifula eyayihlala igeleza.
\q1 
\v 16 Imini ngeyakho, ngobakho njalo lobusuku;
\q2 walimisa ilanga kanye lenyanga.
\q1 
\v 17 Kwakunguwe owamisa imingcele yonke yomhlaba;
\q2 wenza ihlobo kanye lobusika.
\b
\q1 
\v 18 Khumbula ukuthi isitha besikuklolodela, \nd Thixo\nd*,
\q2 ukuthi iziwula bezihlambaza ibizo lakho.
\q1 
\v 19 Ungaqhubeli umphefumulo wejuba lakho ezinyamazaneni;
\q2 ungaze wakhohlwa kokuphela
\q2 impilo yabantu bakho abahluphekayo.
\q1 
\v 20 Nanzelela isivumelwano sakho,
\q2 ngoba izikhundla zobugebenga zigcwele
\q2 kulolonke ilizwe ezindaweni ezilamathunzi.
\q1 
\v 21 Ungayekeli abancindezelweyo babuyele beyangekile;
\q2 sengathi abayanga labaswelayo bangalidumisa ibizo lakho.
\q1 
\v 22 Phakama, awu Nkulunkulu, vikela okungokwakho;
\q2 khumbula ukuthi iziwula zikuhleka njani ilanga lonke.
\q1 
\v 23 Ungakulibali ukuvungama kwalabo abalwa lawe,
\q2 ukuxokozela kwezitha zakho, okuzwakala kokuphela.
\c 75
\cl Ihubo 75
\d Kumqondisi wokuhlabela. Iculo elithi, “Ungabhidlizi.” Ihubo lika-Asafi. Ingoma.
\q1 
\v 1 Siletha ukubonga kuwe, Oh Nkulunkulu,
\q2 siletha ukubonga, ngoba iBizo lakho liseduze;
\q2 abantu bakhuluma ngemisebenzi Yakho emangalisayo.
\b
\q1 
\v 2 Wena uthi, “Ngikhetha isikhathi esimisiweyo;
\q2 yimi engahlulela okuqondileyo.
\q1 
\v 3 Nxa umhlaba kanye labantu bawo kuzamazama,
\q2 yimi engizibamba ziqine izisekelo zawo.
\q1 
\v 4 Ngithi kwabayiziqholo, ‘Lingabe lisazincoma,’
\q2 ngithi kwababi, ‘Lingaziphakamisi impondo zenu.
\q1 
\v 5 Lingaphakamiseli uphondo lwenu phezulu ezulwini;
\q2 lingakhulumi liziqhenya.’ ”
\b
\q1 
\v 6 Kakho ovela empumalanga loba entshonalanga,
\q2 kumbe ovela enkangala ongaphakamisa umuntu.
\q1 
\v 7 Kodwa nguNkulunkulu owahlulelayo:
\q2 uyamehlisa omunye, amkhweze omunye.
\q1 
\v 8 Esandleni \nd sikaThixo\nd* kukhona inkezo
\q2 egcwele iwayini eliphuphumayo elixutshwe ngeziyoliso;
\q1 uyalithulula, kuthi bonke ababi bomhlaba
\q2 balinathe kanye lenzece zalo.
\b
\q1 
\v 9 Kodwa mina ngizamemezela lokhu lanini;
\q2 ngizahlabelela indumiso kuNkulunkulu kaJakhobe,
\q1 
\v 10 yena othi, “Ngizazithulisa zonke impondo zababi,
\q2 kodwa impondo zabalungileyo zizaphakanyiswa.”
\c 76
\cl Ihubo 76
\d Kumqondisi wokuhlabela. Kusetshenziswa iziginci. Ihubo lika-Asafi. Ingoma.
\q1 
\v 1 Uyaziwa uNkulunkulu koJuda
\q2 ibizo lakhe likhulu ko-Israyeli.
\q1 
\v 2 Ithente lakhe liseSalema,
\q2 indawo yakhe yokuhlala iseZiyoni.
\q1 
\v 3 Khonapho wayephula imitshoko ebenyezelayo,
\q2 izihlangu lezinkemba, izikhali zempi.
\b
\q1 
\v 4 Uyakhazimula ngokukhanya,
\q2 ulobukhosi obudlula izintaba ezigcwele izinyamazana.
\q1 
\v 5 Amadoda alezibindi alele ucaca aphangiwe,
\q2 alele ubuthongo bawo bokucina;
\q1 kakho loyedwa wamabutho lawo
\q2 ongaphakamisa izandla zakhe.
\q1 
\v 6 Uthi ungakhwaza wena, Oh Nkulunkulu kaJakhobe,
\q2 ibhiza lenqola kuhle kulale phansi kuthi zwi.
\b
\q1 
\v 7 Wena wedwa uyesatshwa.
\q2 Ngubani ongema phambi kwakho nxa usuthukuthele?
\q1 
\v 8 Wathi usezulwini wehlisa ukwahlulela kwakho,
\q2 ilizwe lesaba lathula,
\q1 
\v 9 lapho wena, Oh Nkulunkulu, waphakama ukwahlulela,
\q2 ukusindisa bonke abahluphekayo belizwe.
\q1 
\v 10 Ngempela ulaka lwakho ebantwini lukulethela indumiso,
\q2 kuthi bonke abasilileyo elakeni lwakho bathotshiswe.
\b
\q1 
\v 11 Yenzani izifungo \nd kuThixo\nd* uNkulunkulu wenu lizigcwalise;
\q2 akuthi wonke amazwe abomakhelwana
\q2 alethe izipho kuye Yedwa omele esatshwe.
\q1 
\v 12 Uyephula ubuqholo bababusi;
\q2 uyesatshwa ngamakhosi omhlaba.
\c 77
\cl Ihubo 77
\d Kumqondisi wokuhlabela. KuJeduthuni, Elika-Asafi. Ihubo.
\q1 
\v 1 Ngakhala kuNkulunkulu ngicela uncedo;
\q2 ngakhala kuNkulunkulu ukuthi angizwe.
\q1 
\v 2 Ngathi ngikhathazekile ngamdinga uThixo;
\q2 ebusuku ngazelula izandla azazezadinwa
\q2 lomphefumulo wami wala ukududuzeka.
\b
\q1 
\v 3 Ngakukhumbula, Oh Nkulunkulu, ngabubula;
\q2 ngacabanga, umoya wami wancipha.
\q1 
\v 4 Wala ukuthi amehlo ami avaleke;
\q2 ngangikhathazekile ngisehluleka ukukhuluma.
\q1 
\v 5 Ngakhumbula ngezinsuku ezedlulayo,
\q2 insuku zakudala;
\q1 
\v 6 ngakhumbula izingoma zami ebusuku.
\q2 Inhliziyo yami yacabanga lomoya wami wadinga:
\b
\q1 
\v 7 “INkosi izakhalala kokuphela na?
\q2 Ayisayikuphinde itshengise uthando lwayo njalo na?
\q1 
\v 8 Kanti uthando lwayo olungapheliyo selunyamalele kokuphela na?
\q2 Kanti isithembiso sayo sesiphelile kokuphela na?
\q1 
\v 9 Kanti uNkulunkulu usekhohliwe ukuba lesihawu na?
\q2 Usethe ngokuzonda wagodla uzwelo lwakhe na?”
\b
\q1 
\v 10 Ngasengikhumbula ngathi, “Yilokhu okunginqundayo,
\q2 ukuthi isandla sokunene soPhezukonke kasisekho phezu kwami.
\q1 
\v 11 Ngizayikhumbula imisebenzi \nd kaThixo\nd*;
\q2 yebo, ngizayikhumbula imimangaliso yakho yekadeni.
\q1 
\v 12 Ngizacabanga ngayo yonke imisebenzi yakho
\q2 nginakane ngazozonke izenzo zakho ezinkulu.”
\b
\q1 
\v 13 Izindlela zakho, Oh Nkulunkulu, zingcwele;
\q2 nguphi unkulunkulu omkhulu njengoNkulunkulu wethu na?
\q1 
\v 14 Nguwe Nkulunkulu owenza izimanga;
\q2 uyawatshengisa amandla akho ebantwini.
\q1 
\v 15 Ngengalo yakho elamandla wabakhulula abantu bakho,
\q2 izizukulwane zikaJakhobe loJosefa.
\b
\q1 
\v 16 Amanzi akubona wena, Oh Nkulunkulu,
\q2 amanzi akubona atshotshobala;
\q2 inziki zagonyuluka.
\q1 
\v 17 Amayezi awathulula amanzi,
\q2 isibhakabhaka sandindiza ngokuduma;
\q2 imitshoko yakho yaphazima yaya le lale.
\q1 
\v 18 Umdumo wakho wezwakala uphakathi kwesivunguzane,
\q2 umbane wakho wawukhanyisa umhlaba;
\q2 umhlaba wavevezela wanyikinyeka.
\q1 
\v 19 Indlela yakho yadabula olwandle,
\q2 umkhondo wakho phakathi kwamanzi,
\q2 kodwa izinyathelo zakho zazingabonakali.
\b
\q1 
\v 20 Wabahola abantu bakho njengomhlambi wezimvu
\q2 ngesandla sikaMosi lo-Aroni.
\c 78
\cl Ihubo 78
\d \tl Ihubo\tl* ka-Asafu
\q1 
\v 1 Zwanini imfundiso yami, bantu bami;
\q2 lilalele amazwi omlomo wami.
\q1 
\v 2 Ngizavula umlomo wami ngemifanekiso,
\q2 ngizakutsho izinto ezifihlekileyo, izinto zekadeni,
\q1 
\v 3 esakuzwayo lesikwaziyo
\q2 esakutshelwa ngokhokho bethu.
\q1 
\v 4 Kasizukuzifihlela abantwana babo;
\q2 sizasitshela isizukulwane esizayo
\q1 ngemisebenzi emangalisayo \nd kaThixo\nd*,
\q2 amandla akhe, lemimangaliso aseyenzile.
\q1 
\v 5 Wamisela uJakhobe imithetho
\q2 wabeka umlayo ko-Israyeli,
\q1 walaya okhokho bethu
\q2 ukuthi bawufundise abantwababo,
\q1 
\v 6 ukuze aziwe yisizukulwane esilandelayo,
\q2 kanye labantwana abazazalwa,
\q2 kuthi labo batshele abantwababo.
\q1 
\v 7 Yikho-ke bazabeka ithemba labo kuNkulunkulu
\q2 njalo abasoze bakhohlwa izenzo zakhe
\q2 kodwa bagcine imilayo yakhe.
\q1 
\v 8 Kabayikuba njengabokhokho babo
\q2 ababeyisizukulwana esilobuqholo lesihlamukayo,
\q1 onhliziyo zabo zazingazinikelanga kuNkulunkulu
\q2 omoya yabo yayingathembekanga kuye.
\b
\q1 
\v 9 Amadoda ako-Efrayimi, loba ayehlomile ngemitshoko,
\q2 afulathela mhla welanga lempi;
\q1 
\v 10 kabasigcinanga isivumelwano sikaNkulunkulu,
\q2 bala ukuphila ngomthetho wakhe.
\q1 
\v 11 Bakhohlwa lokho ayekwenzile,
\q2 izimanga ayebatshengise zona.
\q1 
\v 12 Wenza imimangaliso oyise bekhangele
\q2 elizweni laseGibhithe, esigodini saseZowani.
\q1 
\v 13 Walwahlukanisa ulwandle wabahola bachapha;
\q2 wenza amanzi ema aqina saka njengomduli.
\q1 
\v 14 Wabahola ngeyezi emini
\q2 njalo ngokukhanya komlilo ubusuku bonke.
\q1 
\v 15 Wawaqhekeza amadwala enkangala
\q2 wabapha amanzi amanengi njengolwandle;
\q1 
\v 16 wantshazisa impophoma emadwaleni amawa
\q2 wenza amanzi ageleza njengemifula.
\b
\q1 
\v 17 Kodwa baqhubeka besona phambi kwakhe,
\q2 bamhlamukela enkangala yena oPhezukonke.
\q1 
\v 18 Bamlinga uNkulunkulu ngabomo
\q2 ngokucela ukudla ababekutshisekela.
\q1 
\v 19 Bamchothoza uNkulunkulu
\q2 besithi, “Kambe uNkulunkulu angendlala itafula lokudlela
\q2 enkangala na?
\q1 
\v 20 Wathi lapho etshaya idwala,
\q2 amanzi antshantshaza,
\q2 kwageleza amanzi amanengi.
\q1 Kodwa angasipha njalo lokudla na?
\q2 Angabalethela inyama abantu bakhe na?”
\q1 
\v 21 \nd UThixo\nd* wathi ebezwa wathukuthela kakhulu;
\q2 umlilo wakhe wavuthela kuJakhobe,
\q2 ulaka lwakhe lwaqina ku-Israyeli,
\q1 
\v 22 ngoba kabamkholwanga uNkulunkulu
\q2 njalo kabawathembanga amandla okuhlenga kwakhe.
\q1 
\v 23 Loba kunjalo walaya umkhathi ngaphezulu
\q2 wavula iminyango yamazulu;
\q1 
\v 24 wanisa imana ukuthi badle abantu,
\q2 wabapha amabele asezulwini.
\q1 
\v 25 Abantu badla isinkwa sezingilosi;
\q2 wabathumela konke ukudla ababengakudla.
\q1 
\v 26 Wawukhulula umoya wempumalanga uvela emazulwini,
\q2 wawukhulula umoya weningizimu ngamandla akhe.
\q1 
\v 27 Wanisela inyama kubo njengothuli,
\q2 izinyoni eziphaphayo zaba njengetshebetshebe ogwini lolwandle.
\q1 
\v 28 Wazenza zehlela phakathi kwezihonqo zabo,
\q2 indawana yonke emathenteni abo.
\q1 
\v 29 Bazitika baze bakhangela,
\q2 ngoba wayebaphe ababekade bekukhalela.
\q1 
\v 30 Kodwa
\q2 bengakakutshiyi lokho kudla ababekukhalela belokhu
\q2 besakunambitha emilonyeni yabo,
\q1 
\v 31 ulaka lukaNkulunkulu lwavutha kubo;
\q2 wabulala zona iziqwabalanda zabo,
\q2 wawahemula amajaha ako-Israyeli.
\b
\q1 
\v 32 Phezu kwakho konke lokhu baqhubeka besona;
\q2 phezu kwezimanga zakhe, kabazange bakholwe.
\q1 
\v 33 Ngakho wenza insuku zabo zaphelela ezeni
\q2 njalo leminyaka yabo yagcwala ukwesaba.
\q1 
\v 34 Kwakusithi uNkulunkulu angababulala,
\q2 bamdinge; baphendukele kuye njalo ngokutshiseka.
\q1 
\v 35 Bakhumbula ukuthi uNkulunkulu wayelidwala labo,
\q2 ukuthi uNkulunkulu oPhezukonke wayenguMhlengi wabo.
\q1 
\v 36 Kodwa-ke kwakuyikumyenga ngemilomo yabo,
\q2 beqamba amanga kuye ngendimi zabo;
\q1 
\v 37 inhliziyo zabo zazingabambelelanga kuye,
\q2 babengathembekanga esivumelwaneni sakhe.
\q1 
\v 38 Kodwa wayelesihawu;
\q2 wazithethelela izono zabo
\q2 kaze ababhubhisa.
\q1 Isikhathi ngesikhathi waluthoba ulaka lwakhe
\q2 akaze akuqubula konke ukuthukuthela kwakhe.
\q1 
\v 39 Wakhumbula ukuthi babeyinyama nje
\q2 intshongolo eyedlulayo nje ingabe isabuya.
\b
\q1 
\v 40 Kodwa ukuthi bamhlamukela kanengi njani enkangala,
\q2 bamdabukisa egwaduleni!
\q1 
\v 41 Baphindaphinda ukulinga uNkulunkulu;
\q2 bamthukuthelisa oNgcwele ka-Israyeli.
\q1 
\v 42 Kabawakhumbulanga amandla akhe
\q2 usuku abakhulula ngalo kumncindezeli,
\q1 
\v 43 usuku lapho aveza khona izibonakaliso zakhe ezimangalisayo eGibhithe,
\q2 izimanga zakhe esigodini saseZowani.
\q1 
\v 44 Waguqula imifula yabo yaba ligazi;
\q2 behluleka ukunatha ezifuleni zabo.
\q1 
\v 45 Wathumela imihlambi yezibawu zabantinya,
\q2 lamaxoxo ababhuqayo.
\q1 
\v 46 Amabele abo wawathela izintethe,
\q2 izithelo zabo isikhongwane.
\q1 
\v 47 Wathintitha amavini abo ngesiqhotho
\q2 lemikhiwa yabo yesikhamore wayitshazisa ngongqwaqwane.
\q1 
\v 48 Inkomo zabo wazithela ngesiqhotho,
\q2 izifuyo zabo zadliwa yizikhatha zombane.
\q1 
\v 49 Wabathululela ulaka lwakhe oluvuthayo,
\q2 intukuthelo yakhe, ukucunuka lenzondo
\q2 ixuku lezingilosi ezibhubhisayo.
\q1 
\v 50 Wayilungisa indlela yolaka lwakhe;
\q2 kabaphephisanga ekufeni
\q2 kodwa wabanikela emikhuhlaneni.
\q1 
\v 51 Wawabulala wonke amazibulo aseGibhithe,
\q2 izithelo zabo zokuqala zokuba ngamadoda emathenteni kaHamu.
\q1 
\v 52 Kodwa wabakhupha abantu bakhe njengomhlambi wezimvu;
\q2 wabahola njengezimvu bedabula inkangala.
\q1 
\v 53 Wabakhokhela ngonanzelelo,
\q2 ngakho babengesabi;
\q2 kodwa ulwandle lwazigubuzela izitha zabo.
\q1 
\v 54 Kanjalo wabaletha emngceleni welizwe lakhe elingcwele,
\q2 elizweni lamaqaqa ayelithethe ngesandla sakhe sokunene.
\q1 
\v 55 Wazixotsha izizwe phambi kwabo
\q2 wabahlukanisela ilizwe lazo laba yilifa;
\q2 wahlalisa izizwana zako-Israyeli emizini yazo.
\b
\q1 
\v 56 Kodwa bamlinga uNkulunkulu,
\q2 bamhlamukela oPhezukonke;
\q2 kabayigcinanga imilayo yakhe.
\q1 
\v 57 Njengabokhokho babo babengathembekanga bengakholwa,
\q2 ungeke wathemba njengedandili elenziwe kubi.
\q1 
\v 58 Bamvusa ulaka ngezindawo zabo eziphezulu;
\q2 baqubula ubukhwele bakhe ngezithombe zabo.
\q1 
\v 59 Wathi uNkulunkulu ngokukuzwa lokho,
\q2 wathukuthela kakhulu;
\q2 wamlahla qobo lokumlahla u-Israyeli.
\q1 
\v 60 Walidela ithabanikeli lakhe eShilo,
\q2 ithente ayelakhile phakathi kwabantu.
\q1 
\v 61 Umphongolo wakhe wamandla wawusa ekuthunjweni,
\q2 inkazimulo yakhe ezandleni zesitha.
\q1 
\v 62 Abantu bakhe wabanikela ukudliwa yinkemba;
\q2 wayethukuthele kakhulu ngelifa lakhe.
\q1 
\v 63 Umlilo waziqeda izinsizwa zabo,
\q2 izintombi zabo zaswela izingoma zomtshado;
\q1 
\v 64 abaphristi babo babulawa ngenkemba,
\q2 abafelokazi babo behluleka ukulila.
\b
\q1 
\v 65 INkosi yasivuka njengokade esebuthongweni,
\q2 njengomuntu ephaphama ekudakweni yiwayini.
\q1 
\v 66 Wazitshaya zahlehla izitha zakhe;
\q2 waziyangisa okungapheliyo.
\q1 
\v 67 Khonapho-ke wawakhalala amathente kaJosefa,
\q2 akaze asikhetha isizwana sika-Efrayimi;
\q1 
\v 68 kodwa wakhetha isizwana sikaJuda,
\q2 iNtaba iZiyoni ayeyithanda.
\q1 
\v 69 Wakha indlu yakhe engcwele njengeziqongo,
\q2 njengomhlaba awumisela ingunaphakade.
\q1 
\v 70 Wakhetha uDavida inceku yakhe
\q2 wamthatha ezilugwini zezimvu;
\q1 
\v 71 wamsusa ekweluseni izimvu
\q2 wamletha ukuba ngumelusi wabantu bakhe uJakhobe,
\q2 baka-Israyeli ilifa lakhe.
\q1 
\v 72 Njalo uDavida wabelusa ngobuqotho benhliziyo;
\q2 wabakhokhela ngesandla sobungcitshi.
\c 79
\cl Ihubo 79
\d Ihubo lika-Asafi
\q1 
\v 1 Oh Nkulunkulu, izizwe sezilingenele ilifa lakho;
\q2 sezilingcolisile ithempeli lakho eligcwele,
\q2 iJerusalema isibhidliziwe yaba luthuli.
\q1 
\v 2 Izidumbu zezinceku zakho sebezilahlile
\q2 ukuba yikudla kwezinyoni zasemoyeni,
\q2 inyama yabangcwele bakho yaba yikudla kwezilo zelizwe.
\q1 
\v 3 Balichithile igazi njengamanzi
\q2 bahonqolozela ngalo iJerusalema,
\q2 kasekho ozangcwaba abafileyo.
\q1 
\v 4 Siyizinto zokuchothozwa kubomakhelwane bethu,
\q2 inhlekisa lokweyiswa yibo bonke esihlala labo.
\b
\q1 
\v 5 Koze kube nini, Oh \nd Thixo?\nd* Uzazonda kuze kube nininini na?
\q2 Koze kube nini ubukhwele bakho butshisa njengomlilo na?
\q1 
\v 6 Thululela intukuthelo yakho kulezozizwe
\q2 ezingakunanziyo,
\q2 ezingalibiziyo ibizo lakho
\q1 
\v 7 ngoba zimchithile uJakhobe
\q2 zalibhidliza ilizwe lakibo.
\b
\q1 
\v 8 Ungawethesi thina umlandu wabokhokho;
\q2 sengathi isihawu sakho singeza masinyane ukuzasivikela,
\q2 ngoba sesisebunzimeni obubi.
\q1 
\v 9 Sisize, awu Nkulunkulu Msindisi wethu,
\q2 ngenxa yobukhosi bebizo lakho;
\q1 sikhulule uthethelele izono zethu,
\q2 ngenxa yebizo lakho.
\q1 
\v 10 Kungani izizwe zisithi,
\q2 “Ungaphi uNkulunkulu wabo?”
\b
\q1 Yenza emehlweni ethu, kwaziwe phakathi kwezizwe
\q2 ukuthi uyaliphindisela igazi lezinceku zakho elachithwayo.
\q1 
\v 11 Sengathi ukububula kwezibotshwa kungafinyelela kuwe;
\q2 ngamandla engalo yakho sindisa labo abagwetshelwe ukufa.
\q1 
\v 12 Baphindisele kasikhombisa omakhelwane bethu
\q2 ngezinhlamba ababekuchaphaza ngazo, Thixo.
\q1 
\v 13 Kuzakuthi-ke thina abantu bakho,
\q2 izimvu zedlelo lakho, sikudumise laphakade;
\q1 kusuka esizukulwaneni kusiya esizukulwaneni
\q2 sizabalisa udumo lwakho.
\c 80
\cl Ihubo 80
\d Kumqondisi wokuhlabela. Itshuni ethi, “Amaluba esiVumelwano.” Elika-Asafi. Ihubo.
\q1 
\v 1 Sizwe, Oh Malusi ka-Israyeli,
\q2 wena okhokhela uJosefa njengomhlambi wezimvu;
\q1 wena ohlezi esihlalweni sobukhosi
\q2 uphahlwe ngamakherubhi,
\q2 benyezela
\q1 
\v 2 phambi kuka-Efrayimi loBhenjamini loManase.
\q2 Vusa amandla akho; woza usisindise.
\b
\q1 
\v 3 Sivuselele, Oh Nkulunkulu;
\q2 yenza ubuso bakho bukhanye phambi kwethu,
\q2 ukuze sisindiswe.
\b
\q1 
\v 4 Oh \nd Thixo\nd* Nkulunkulu Somandla,
\q2 koze kube nini ulaka lwakho luvutha
\q2 phezu kwemikhuleko yabantu bakho?
\q1 
\v 5 Usubafunzile ngesinkwa sezinyembezi;
\q2 ubenze banatha inyembezi ezigcwele umganu.
\q1 
\v 6 Ususenze saba yimbangela yengxabano kubomakhelwane bethu,
\q2 lezitha zethu ziyasihleka.
\b
\q1 
\v 7 Sivuselele, Oh Nkulunkulu Somandla;
\q2 khanyisa ubuso bakho kithi,
\q2 ukuze sisindiswe.
\b
\q1 
\v 8 Waletha ivini ulisusa eGibhithe;
\q2 wazixotsha izizwe waligxumeka,
\q1 
\v 9 walicentela indawo
\q2 labamba emhlabathini lagcwala ilizwe.
\q1 
\v 10 Izintaba zagcwala umthunzi walo,
\q2 imisedari emikhulu yathi silikici ngamagatsha alo.
\q1 
\v 11 Lakhulisa amagatsha alo anabela oLwandle,
\q2 amahlumela alo afika kude eMfuleni.
\b
\q1 
\v 12 Kungani na usudilize imiduli yalo
\q2 ukuze bonke abedlulayo baziqhululele izithelo zalo?
\q1 
\v 13 Ingulungunda ziyalivadlaza,
\q2 lezidalwa zeganga zizitika ngalo.
\q1 
\v 14 Buya kithi, Oh Nkulunkulu Somandla!
\q2 Khangela phansi usezulwini ubone!
\q1 Nakekela ivini leli,
\q2 
\v 15 impande ehlanyelwe yisandla sakho sokunene,
\q2 indodana ozondlele yona wena.
\b
\q1 
\v 16 Ivini lakho seliqunyiwe, selitshiswe ngomlilo;
\q2 ngokukhuza kwakho abantu bayabhubha.
\q1 
\v 17 Yeyamisa isandla sakho emuntwini ongakwesokunene kwakho,
\q2 indodana yomuntu ozondlele yona.
\q1 
\v 18 Yikho asiyikukufulathela, sivuselele,
\q2 ukuze sibize ibizo lakho.
\b
\q1 
\v 19 Sivuselele, Oh \nd Thixo\nd* Nkulunkulu Somandla;
\q2 khanyisa ubuso bakho kithi,
\q2 ukuze sisindiswe.
\c 81
\cl Ihubo 81
\d Kumqondisi wokuhlabela. Ngendlela \tl yegithithi.\tl* Elika-Asafi
\q1 
\v 1 Hlabelelani ngentokozo kuNkulunkulu ongamandla ethu;
\q2 memezani kakhulu kuNkulunkulu kaJakhobe!
\q1 
\v 2 Qalisani ukuhlabela, tshayani isigubhu,
\q2 khalisani ichacho elimnandi lomhubhe.
\b
\q1 
\v 3 Khalisani uphondo lwenqama ekuThwaseni kweNyanga,
\q2 lalapho inyanga isigcwele, ngelanga lomkhosi;
\q1 
\v 4 lesi yisimemezelo sika-Israyeli,
\q2 umthetho kaNkulunkulu kaJakhobe.
\q1 
\v 5 Wakumisa njengesimiso kuJosefa
\q2 lapho aphuma wavukela ilizwe leGibhithe,
\q1 lapho ezwa khona ulimi esasingaluzwa.
\b
\q1 Ngezwa ilizwi engingalaziyo lisithi:
\b
\q1 
\v 6 “Ngawethula umthwalo emahlombe abo;
\q2 izandla zabo zakhululwa engcebethwini.
\q1 
\v 7 Ekuhluphekeni kwenu lamemeza mina ngalikhulula.
\q2 Ngaliphendula ngiphakathi komdumo weyezi;
\q2 ngalilinga emanzini aseMeribha.
\q1 
\v 8 Zwanini, awu bantu bami, mina ngizalixwayisa
\q2 aluba lingangilalela, Oh Israyeli!
\q1 
\v 9 Lingabi lonkulunkulu wezizweni phakathi kwenu;
\q2 lingabokhothamela unkulunkulu ongaziwayo.
\q1 
\v 10 \nd NginguThixo\nd* uNkulunkulu wenu,
\q2 owalikhuphayo eGibhithe.
\q1 Vulani kakhulu umlomo wenu ngizawugcwalisa.
\b
\q1 
\v 11 Kodwa abantu bami kabangilalelanga;
\q2 u-Israyeli wala ukungithobela.
\q1 
\v 12 Ngakho ngasengibayekela ngezinhliziyo zabo zobuqholo
\q2 ukuthi balandele lokho abakufunayo.
\b
\q1 
\v 13 Aluba abantu bami bengangilalela,
\q2 aluba u-Israyeli engalandela izindlela zami,
\q1 
\v 14 masinyane nje ngingazibhuqa izitha zabo
\q2 ngiphakamisele isandla sami ezitheni zabo!
\q1 
\v 15 Labo abamzondayo \nd uThixo\nd* bangatshotshobala phambi kwakhe,
\q2 kuthi isijeziso sabo sibe ngesaphakade.
\q1 
\v 16 Kodwa lina lingaphiwa ingqoloyi enhle kakhulu;
\q2 ngilisuthise ngoluju oluphuma edwaleni.”
\c 82
\cl Ihubo 82
\d Ihubo lika-Asafi
\q1 
\v 1 UNkulunkulu usesihlalweni emhlanganweni omkhulu;
\q2 nguye owahlulelayo phakathi kwabo “nkulunkulu”:
\b
\q1 
\v 2 “Koze kube nini livikela ababi na
\q2 libonakala lithanda izigangi?
\q1 
\v 3 Lamlelani ababuthakathaka lezintandane;
\q2 melani amalungelo abayanga labahlukuluzwayo.
\q1 
\v 4 Lamlelani ababuthakathaka labaswelayo;
\q2 bephuleni esandleni sababi.
\b
\q1 
\v 5 Onkulunkulu kabazi lutho, kabazwisisi lutho.
\q2 Bayantula emnyameni;
\q2 zonke izisekelo zomhlaba zixukuxiwe.
\b
\q1 
\v 6 Ngathi, ‘Lingo “nkulunkulu”;
\q2 lonke lingamadodana akhe oPhezukonke.’
\q1 
\v 7 Kodwa lizakufa lingabantu nje;
\q2 lizakuwa njengamanye amakhosi wonke.”
\b
\q1 
\v 8 Phakama, Oh Nkulunkulu, yahlulela umhlaba,
\q2 ngoba zonke izizwe ziyilifa lakho.
\c 83
\cl Ihubo 83
\d Ingoma. Ihubo lika-Asafi.
\q1 
\v 1 Oh Nkulunkulu, ungathuli uthi zwi;
\q2 ungangincitshi indlebe yakho,
\q2 ungameli khatshana lami, Oh Nkulunkulu.
\q1 
\v 2 Akubone ukuthi ziphithizela kanjani izitha zakho,
\q2 ukuthi ziwaqaphisa kanganani amakhanda azo.
\q1 
\v 3 Ngobuqili zakhela abantu bakho amacebo;
\q2 zisongela labo obathembileyo.
\q1 
\v 4 Bathi, “Wozani kasibabhuqe du njengesizwe,
\q2 ukuze ibizo lika-Israyeli lingaphindi likhunjulwe.”
\b
\q1 
\v 5 Nganhliziyonye bawakha amacebo ndawonye;
\q2 bayahlangana beme ndawonye ukumelana lawe,
\q1 
\v 6 amathente ase-Edomi lama-Ishumayeli,
\q2 awamaMowabi lawamaHagari,
\q1 
\v 7 amaGebhali, lama-Amoni lama-Amaleki,
\q2 amaFilistiya labantu beThire.
\q1 
\v 8 Lama-Asiriya asebambene labo
\q2 ukuqinisa izizukulwane zikaLothi.
\b
\q1 
\v 9 Yenza kubo njengoba wenza eMidiyani,
\q2 njengowakwenza kuSisera loJabhini emfuleni iKhishoni,
\q1 
\v 10 ababhubha e-Endo
\q2 baba njengezibi emhlabathini.
\q1 
\v 11 Yenza izikhulu zabo zibe njengo-Orebhi loZebhi,
\q2 wonke amakhosana abo abe njengoZebha loZalimuna,
\q1 
\v 12 abathi, “Kasiwathumbe
\q2 amadlelo kaNkulunkulu.”
\b
\q1 
\v 13 Benze babe njengenkunkuma, Oh Nkulunkulu wami,
\q2 njengamakhoba ephetshulwa ngumoya.
\q1 
\v 14 Njengalokhu umlilo uhangula igusu
\q2 kumbe ilangabi lilumathisa izintaba,
\q1 
\v 15 kanjalo basukele ngesivunguvungu sakho
\q2 ubethuse ngesiphepho sakho.
\q1 
\v 16 Bahuqe ubuso babo ngehlazo
\q2 ukuze abantu balidinge ibizo lakho, Oh \nd Thixo\nd*.
\b
\q1 
\v 17 Sengathi bangayangeka lanini badunyazwe;
\q2 kungathi bangafa belehlazo.
\q1 
\v 18 Yenza bakwazi ukuthi wena, obizo lakho \nd unguThixo\nd*
\q2 ukuthi wena wedwa ungoPhezukonke emhlabeni wonke.
\c 84
\cl Ihubo 84
\d Kumqondisi wokuhlabela. Ngendlela \tl yegithithi.\tl* Elabantwana bakaKhora. Ihubo.
\q1 
\v 1 Yeka ubuhle bendlu yakho,
\q2 Oh \nd Thixo\nd* Somandla!
\q1 
\v 2 Umphefumulo wami uyalangazela, uze ungathi uyaphela,
\q2 ngifuna amaguma \nd kaThixo\nd*;
\q1 inhliziyo yami lenyama yami
\q2 kukhalela uNkulunkulu ophilayo.
\q1 
\v 3 Intaka layo ilizuzile ikhaya,
\q2 lenkonjane isidleke sayo,
\q2 lapho ingazalela khona abantwana bayo
\q1 indawo eduze kwe-alithari lakho,
\q2 Oh \nd Thixo\nd* Somandla, Nkosi yami loNkulunkulu wami.
\q1 
\v 4 Babusisiwe labo abahlala endlini yakho;
\q2 bahlala bekudumisa kokuphela.
\b
\q1 
\v 5 Babusisiwe labo abalamandla abo akuwe
\q2 asebebeke inhliziyo zabo ekulagiseni kuwe.
\q1 
\v 6 Bathi nxa bedabula esiGodini seBhaka
\q2 basenze sibe yindawo yemithombo;
\q2 izulu lekwindla lalo ligcwalise iziziba.
\q1 
\v 7 Ayakhula amandla abo ande,
\q2 ngulowo lalowo aze aqhamuke kuNkulunkulu eZiyoni.
\b
\q1 
\v 8 Zwana umkhuleko wami, Oh \nd Thixo\nd* Nkulunkulu Somandla;
\q2 akungilalele, Oh Nkulunkulu kaJakhobe.
\q1 
\v 9 Khangela isihlangu sethu, Oh Nkulunkulu;
\q2 khangela ngomusa kogcotshiweyo wakho.
\b
\q1 
\v 10 Lungcono usuku olulodwa emagumeni akho
\q2 kulensuku eziyinkulungwane kwenye indawo;
\q1 kungabangcono ngibe ngumlindimasango endlini kaNkulunkulu
\q2 kulokuhlala emathenteni ababi.
\q1 
\v 11 Ngoba \nd uThixo\nd* ulilanga lesihlangu;
\q2 \nd uThixo\nd* uyapha umusa lodumo;
\q1 kancitshani langaluphi ulutho oluhle
\q2 kulabo ozinyathelo zabo zingelansolo.
\b
\q1 
\v 12 Oh \nd Thixo\nd* Somandla,
\q2 ubusisiwe umuntu owethemba kuwe.
\c 85
\cl Ihubo 85
\d Kumqondisi wokuhlabela. Elamadodana kaKhora. Ihubo.
\q1 
\v 1 Ulithandile ilizwe lakho, Oh \nd Thixo\nd*;
\q2 uyibuyisile inhlanhla kaJakhobe.
\q1 
\v 2 Wazithethelela iziphambeko zabantu bakho
\q2 wazisibekela zonke izono zabo.
\q1 
\v 3 Walubuyisela eceleni lonke ulaka lwakho
\q2 wakufulathela ukuthukuthela kwakho okwesabekayo.
\b
\q1 
\v 4 Sivuselele njalo, Oh Nkulunkulu Msindisi wethu,
\q2 ukubeke khatshana ukukucunula kwethu.
\q1 
\v 5 Uzasizondela kuze kube phakade na?
\q2 Uzalugcina ulaka lwakho kuzozonke izizukulwane na?
\q1 
\v 6 Kawuzukusivuselela na,
\q2 ukuze abantu bakho bathokoze kuwe?
\q1 
\v 7 Sitshengise uthando lwakho olungaphuthiyo, Oh \nd Thixo\nd*,
\q2 usinike insindiso yakho.
\b
\q1 
\v 8 Ngizalalela lokho uNkulunkulu \nd uThixo\nd* azakutsho;
\q2 uthembisa abantu bakhe ukuthula, abangcwele bakhe
\q2 kodwa kabangabuyeli ebufebeni babo.
\q1 
\v 9 Ngempela insindiso iseduze kulabo abamesabayo,
\q2 ukuze inkazimulo yakhe ihlale elizweni lethu.
\b
\q1 
\v 10 Uthando lokuthembeka kuyahlangana ndawonye;
\q2 ukulunga lokuthula kuyangana.
\q1 
\v 11 Ukuthembeka kuqhamuka emhlabathini,
\q2 ukulunga kukhanya phansi kusezulwini.
\q1 
\v 12 Ngeqiniso \nd uThixo\nd* uzanika okulungileyo,
\q2 lelizwe lethu lizathela isivuno salo.
\q1 
\v 13 Ukulunga kuhamba phambi kwakhe
\q2 kulungisele izinyathelo zakhe indlela.
\c 86
\cl Ihubo 86
\d Umkhuleko kaDavida
\q1 
\v 1 Zwana, Oh \nd Thixo\nd*, ungiphendule,
\q2 ngoba ngingumyanga ngiyaswela.
\q1 
\v 2 Vikela impilo yami, ngoba ngizinikele kuwe;
\q2 sindisa inceku yakho ekuthembayo;
\q1 UnguNkulunkulu wami.
\q2 
\v 3 Woba lesihawu kimi, Oh Thixo,
\q2 ngoba ngitshona ngikubiza ilanga lonke.
\q1 
\v 4 Letha ukuthokoza encekwini yakho,
\q2 ngoba kuwe, Oh Thixo,
\q2 ngiphakamisela umphefumulo wami.
\b
\q1 
\v 5 Uyathethelela njalo ulungile, Oh Thixo,
\q2 ugcwele uthando kulabo abakhuleka kuwe.
\q1 
\v 6 Zwana umkhuleko wami, Oh \nd Thixo\nd*;
\q2 lalela ukukhala kwami ngicela umusa.
\q1 
\v 7 Mhla ngiphakathi kokuhlupheka ngizakhala kuwe,
\q2 ngoba uzangiphendula.
\b
\q1 
\v 8 Phakathi kwabonkulunkulu kakho onjengawe, Oh Thixo;
\q2 kakulazenzo ezingalinganiswa lezakho.
\q1 
\v 9 Zonke izizwe owazenzayo
\q2 zizakuza zikhonze kuwe, Nkosi;
\q2 zizaletha udumo ebizweni lakho.
\q1 
\v 10 Ngoba umkhulu njalo wenza imisebenzi emangalisayo;
\q2 wena wedwa unguNkulunkulu.
\b
\q1 
\v 11 Ngifundisa indlela yakho, Oh \nd Thixo\nd*,
\q2 ukuze ngihambe eqinisweni lakho;
\q1 ngipha inhliziyo engaxamalazanga,
\q2 ukuze ngilesabe ibizo lakho.
\q1 
\v 12 Ngizakudumisa, Nkosi Nkulunkulu wami,
\q2 ngenhliziyo yami yonke;
\q2 ngizalidumisa ibizo lakho laphakade.
\q1 
\v 13 Ngoba lukhulu uthando lwakho kimi;
\q2 ungenyule ekujuleni kwendawo yabafileyo.
\b
\q1 
\v 14 Iziqholo ziyangihlasela, Oh Nkulunkulu
\q2 iqembu lamadoda alesihluku lizingela impilo yami
\q2 abantu abangakunanziyo wena.
\q1 
\v 15 Kodwa wena, Nkosi, unguNkulunkulu olozwelo, olobubelo,
\q2 ophuza ukuzonda, owandayo ngothando lokuthembeka.
\q1 
\v 16 Phendukela ngakimi ube lesihawu kimi;
\q2 veza amandla akho ngenceku yakho,
\q1 ngisindise ngoba ngiyakukhonza,
\q2 njengokwenziwa ngumama.
\q1 
\v 17 Ngipha isiboniso sokulunga kwakho,
\q2 ukuze izitha zami zisibone ziyangeke,
\q2 ngoba wena, Oh \nd Thixo\nd*, usungisizile njalo wangiduduza.
\c 87
\cl Ihubo 87
\d Elamadodana kaKhora. Ihubo. Ingoma.
\q1 
\v 1 Usakhile isisekelo sakhe entabeni engcwele;
\q1 
\v 2 \nd uThixo\nd* uyawathanda amasango eZiyoni
\q2 okudlula yonke imizi kaJakhobe.
\b
\q1 
\v 3 Izinto ezinhle okumangalisayo ziyatshiwo ngawe,
\q2 we muzi kaNkulunkulu:
\q1 
\v 4 “Ngizabalisa uRahabi leBhabhiloni
\q2 phakathi kwalabo abathi bayangazi
\q1 iFilistiya leThire, kanye leKhushi
\q2 ngibe sengisithi, ‘Lo wazalelwa eZiyoni.’ ”
\q1 
\v 5 Ngempela kuzathiwa ngeZiyoni,
\q2 “Lo laloyana bazalelwa khona,
\q2 kuthi yena oPhezukonke uzaliqinisa.”
\q1 
\v 6 \nd UThixo\nd* uzaloba eluhlwini lwamabizo abantu:
\q2 “Lo wazalelwa eZiyoni.”
\b
\q1 
\v 7 Bazakuthi betshaya amachacho bahlabele bathi,
\q2 “Yonke imithombo yami ikuwe.”
\c 88
\cl Ihubo 88
\d Ingoma. Ihubo lamadodana kaKhora. Kumqondisi wokuhlabela. Itshuni ethi, \tl Mahalathi leyanothi\tl* (Ukuhlupheka lokuchukuluzwa) \tl Ihubo\tl* likaHemani umʼEzira.
\q1 
\v 1 Oh \nd Thixo\nd*, Nkulunkulu ongisindisayo,
\q2 ebusuku lemini ngikhala kuwe.
\q1 
\v 2 Akuthi umkhuleko wami ufinyelele kuwe;
\q2 phendula indlebe yakho izwe ukukhala kwami.
\b
\q1 
\v 3 Ngoba umphefumulo wami ugcwele inhlupheko
\q2 lempilo yami isilengela engcwabeni.
\q1 
\v 4 Ngibalwa ndawonye lalabo asebesiya egodini;
\q2 senginjengendoda engelamandla.
\q1 
\v 5 Sengahlukaniselwe kwabafileyo,
\q2 lezidumbu ezilele engcwabeni,
\q1 wena ongasabakhumbuliyo njalo,
\q2 abangasekho kulabo obanakekelayo.
\b
\q1 
\v 6 Usungifake egodini elitshona okudlulayo,
\q2 ekujuleni okumnyama bhuqe.
\q1 
\v 7 Intukuthelo yakho iyangeleka;
\q2 usungigalulisile ngawo wonke amagagasi akho.
\q1 
\v 8 Usungithathele abangane bami abasekhwapheni
\q2 wangenza ngaba lesidina kubo.
\q1 Ngivalelwe kangiselantuba;
\q2 
\v 9 amehlo ami asebona kalufifi ngenxa yosizi.
\b
\q1 Ngiyakubiza, Oh \nd Thixo\nd*, insuku zonke;
\q2 ngiphakamisela izandla zami kuwe.
\q1 
\v 10 Izimanga zakho uyazitshengisa kwabafileyo na?
\q2 Kambe labo asebefile bangavuka bakudumise na?
\q1 
\v 11 Uthando lwakho luyamenyezelwa engcwabeni yini,
\q2 ukuthembeka kwakho endaweni yokuBhubha na?
\q1 
\v 12 Izimanga zakho ziyaziwa yini endaweni yobumnyama,
\q2 kumbe izenzo zakho zokulunga elizweni lokungabikho na?
\b
\q1 
\v 13 Kodwa ngikhala kuwe ngoncedo, Oh \nd Thixo\nd*;
\q2 ekuseni umkhuleko wami uyafika kuwe.
\q1 
\v 14 Kungani, awu \nd Thixo\nd*, ungifulathela
\q2 ungifihlela ubuso bakho?
\b
\q1 
\v 15 Kusukela ebutsheni bami ngavele ngahlupheka ngaba seduze lokufa;
\q2 ngiphethwe yikwesatshiswa nguwe, sengize ngidangele.
\q1 
\v 16 Intukuthelo yakho isingigabhele;
\q2 ukwesaba wena sekungiqedile.
\q1 
\v 17 Ilanga lonke kungihanqile njengesikhukhula;
\q2 sekungigalulisa nya.
\q1 
\v 18 Usungithathele abakhula bami lengibathandayo;
\q2 ubumnyama sebunguyena mngane wami oseduze.
\c 89
\cl Ihubo 89
\d \tl Ihubo\tl* lika-Ethani umEzira
\q1 
\v 1 Ngizahlabelela ngothando \nd lukaThixo\nd* olukhulu lanininini;
\q2 ngomlomo wami ngizakwenza ukuthembeka kwakho kwaziwe
\q2 ezizukulwaneni zonke.
\q1 
\v 2 Ngizamemezela ukuthi uthando lwakho lumi luqinile laphakade,
\q2 ukuthi ukuthembeka kwakho wakugxilisa ezulwini uqobo.
\q1 
\v 3 Wathi, “Sengenze isivumelwano lalowo okhethiweyo wami,
\q2 sengifungile kuDavida inceku yami,
\q1 
\v 4 ‘Ngizawumisa umndeni wakho laphakade,
\q2 ngisiqinise isihlalo sakho sobukhosi
\q2 kuzozonke izizukulwane.’ ”
\b
\q1 
\v 5 Amazulu ayazidumisa izimanga zakho, Oh \nd Thixo\nd*,
\q2 lokuthembeka kwakho emhlanganweni wabangcwele.
\q1 
\v 6 Phela ngubani \nd onjengoThixo\nd* phakathi kwabaphilayo ezulwini na?
\q2 Ngubani \nd onjengoThixo\nd* phakathi kwabaphilayo ezulwini na?
\q1 
\v 7 Enhlanganisweni yabangcwele uNkulunkulu uyesatshwa kakhulu;
\q2 uyesabeka kulabo bonke abahlezi laye.
\q1 
\v 8 Yebo \nd Thixo\nd* Nkulunkulu Somandla, ngubani onjengawe na?
\q2 Ulamandla, Oh \nd Thixo\nd*, ukuthembeka kwakho kukuhonqolozele.
\b
\q1 
\v 9 Uyabusa phezu kolwandle olugubhazelayo;
\q2 lapho amavinqo alo equbuka, uyawathulisa.
\q1 
\v 10 Wamchoboza uRahabi njengomunye wababuleweyo;
\q2 ngengalo yakho elamandla wazichitha izitha.
\q1 
\v 11 Ngawakho amazulu, ngowakho njalo lomhlaba;
\q2 wawudala umhlaba lakho konke okukuwo.
\q1 
\v 12 Wayidala inyakatho kanye leningizimu;
\q2 iThabhori leHemoni zihlabelela ibizo lakho ngentokozo.
\q1 
\v 13 Ingalo yakho igcwele amandla;
\q2 isandla sakho siqinile, esokunene siphakeme.
\b
\q1 
\v 14 Ukulunga lokwahlulela kuhle yikho okuyinsika yesihlalo sakho sobukhosi;
\q2 uthando lokuthembeka kuhamba phambili kwakho.
\q1 
\v 15 Babusisiwe labo asebekufundile ukukubabaza,
\q2 abahamba ekukhanyeni kobukhona bakho, Oh \nd Thixo\nd*.
\q1 
\v 16 Bayathokoza ngebizo lakho ilanga lonke;
\q2 bayagubhazela ngokulunga kwakho.
\q1 
\v 17 Ngoba uyibukhosi babo lamandla abo,
\q2 kuthi ngomusa wakho uphakamise uphondo lwethu.
\q1 
\v 18 Ngempela isihlangu sethu \nd ngesikaThixo\nd*, iNkosi yethu
\q2 Kuye oYedwa oNgcwele ka-Israyeli.
\b
\q1 
\v 19 Endulo wakhuluma ngombono,
\q2 ebantwini bakho abathembekileyo wathi:
\q1 “Sengiwehlisele amandla phezu kweqhawe;
\q2 sengiphakamise insizwa phakathi kwabantu.
\q1 
\v 20 Sengifumane uDavida inceku yami;
\q2 ngamafutha ami angcwele sengimgcobile.
\q1 
\v 21 Isandla sami sizamsekela;
\q2 ngempela ingalo yami izamqinisa.
\q1 
\v 22 Akulasitha esizamncindezela ukuthi athele kuso;
\q2 kakho umuntu omubi ozamcindezela.
\q1 
\v 23 Ngizazichoboza izitha zakhe phambi kwakhe
\q2 ngibalahlele phansi abalwa laye.
\q1 
\v 24 Uthando lwami oluthembekileyo luzaba laye,
\q2 ukuthi ngebizo lami luphakanyiswe uphondo lwakhe.
\q1 
\v 25 Ngizabeka isandla sakhe phezu kolwandle,
\q2 isandla sakhe sokunene phezu kwemifula.
\q1 
\v 26 Uzamemeza kimi athi, ‘UnguBaba,
\q2 Nkulunkulu wami, iDwala elinguMsindisi wami.’
\q1 
\v 27 Njalo ngizamisa abe lizibulo lami,
\q2 inkosi ephakeme ngaphezu kwawo wonke amakhosi omhlaba.
\q1 
\v 28 Ngizalugcina uthando lwami kuye laphakade,
\q2 lesivumelwano sami laye kasiyikuphela.
\q1 
\v 29 Inzalo yakhe ngizayimisa nini lanini,
\q2 lesihlalo sakhe sobukhosi kasiyikufa saphela.
\b
\q1 
\v 30 Aluba amadodana akhe edela umlayo wami
\q2 angalandeli izimiso zami,
\q1 
\v 31 nxa besephula izimemezelo zami
\q2 behluleke ukugcina imiyalo yami,
\q1 
\v 32 ngizajezisa isono sabo ngoswazi,
\q2 lesiphambeko sabo ngokubatshaya;
\q1 
\v 33 kodwa kangiyikulususa uthando lwami kuye,
\q2 njalo kangisoze ngiguqule ukuthembeka kwami.
\q1 
\v 34 Kangiyikusephula isivumelwano sami
\q2 kumbe ngiguqule lokho okuphume ezindebeni zami.
\q1 
\v 35 Ngavele ngafunga kanye ngobungcwele bami
\q2 angiyikuqamba amanga kuDavida,
\q1 
\v 36 ukuthi inzalo yakhe izaqhubeka laphakade
\q2 lesihlalo sakhe sobukhosi sizakuma phambi kwami njengelanga;
\q1 
\v 37 sizakuma laphakade njengenyanga,
\q2 ufakazi othembekileyo yisibhakabhaka.”
\b
\q1 
\v 38 Kodwa usumalile, usumlahlile,
\q2 ubumthukuthelela kakhulu ogcotshiweyo wakho.
\q1 
\v 39 Ususikhalele isivumelwano lenceku yakho
\q2 wawubhuqela othulini umqhele wakhe.
\q1 
\v 40 Usuyibhidlizile yonke imiduli yakhe,
\q2 izinqaba zakhe wazenza amanxiwa.
\q1 
\v 41 Bonke abedlula khona bamphangile;
\q2 useyinhlekisa yabomakhelwane.
\q1 
\v 42 Usuphakamisile isandla sokunene sezitha zakhe;
\q2 usuwenze zonke izitha zakhe zathokoza.
\q1 
\v 43 Uyibuyisele emuva inkemba yakhe ebukhali
\q2 awaze wamsekela empini.
\q1 
\v 44 Usuyiqedile inkazimulo yakhe
\q2 wadilizela phansi isihlalo sakhe sobukhosi.
\q1 
\v 45 Uluqumile lwaba lufitshane usuku lobutsha bakhe;
\q2 usumembese ingubo yehlazo.
\b
\q1 
\v 46 Koze kube nini, Oh \nd Thixo?\nd* Uzazifihla kokuphela na?
\q2 Koze kube nini ulaka lwakho luvutha njengomlilo?
\q1 
\v 47 Khumbula ukwedlula masinyane kwempilo yami.
\q2 Ngoba wabadalela ize nje abantu!
\q1 
\v 48 Ngumuntu bani ongaphila angaze abona ukufa,
\q2 loba azisindise emandleni eliba na?
\q1 
\v 49 Oh Thixo, lungaphi uthando lwakho lwakudala olukhulu,
\q2 okwathi ngokuthembeka kwakho wafunga ngalo kuDavida?
\q1 
\v 50 Khumbula, Thixo ukuthi inceku yakho iklolodelwa njani,
\q2 ukuthi enhliziyweni yami ngithwele izigcono zezizwe,
\q1 
\v 51 izigcono izitha zakho eziklolode ngazo, Oh \nd Thixo\nd*,
\q2 okuthe ngazo zaklolodela ogcotshiweyo wakho kukho konke akwenzayo.
\b
\b
\q1 
\v 52 Udumo kalube \nd kuThixo\nd* laphakade!
\qc Ameni njalo Ameni.
\c 90
\ms1 Ugwalo 4
\mr AmaHubo 90 – 106
\cl Ihubo 90
\d Umkhuleko kaMosi umuntu kaNkulunkulu.
\q1 
\v 1 Thixo, wena ulikhaya lethu
\q2 kuzozonke izizukulwane.
\q1 
\v 2 Izintaba zingakabikhona
\q2 lalapho ungakawuvezi umhlaba kanye lelizwe,
\q2 kusukela phakade kuze kube phakade unguNkulunkulu.
\b
\q1 
\v 3 Ubuyisela abantu ethulini,
\q2 usithi, “Buyelani othulini, lina madodana abantu.”
\q1 
\v 4 Ngoba iminyaka eyinkulungwane ekuboneni kwakho
\q2 injengosuku olusanda kudlula,
\q2 kumbe njengomlindo webusuku.
\q1 
\v 5 Uyabakhucula abantu ebuthongweni bokufa;
\q2 banjengotshani obutsha obekuseni
\q1 
\v 6 lokuba ekuseni buhluma bubutsha,
\q2 kuthi ntambama sebomile sebubunile.
\b
\q1 
\v 7 Ulaka lwakho luyasitshabalalisa
\q2 sithuthumeliswe yikucaphuka kwakho.
\q1 
\v 8 Usubuchayile ububi bethu phambi kwakho,
\q2 izono zethu zensitha wazichaya ekukhanyeni kobukhona bakho.
\q1 
\v 9 Zonke insuku zethu ziyedlula ngaphansi kolaka lwakho;
\q2 leminyaka yethu siyiphetha ngokububula.
\q1 
\v 10 Ubude bezinsuku zethu buyiminyaka engamatshumi ayisikhombisa
\q2 loba amatshumi ayisificaminwembili, nxa silamandla;
\q1 kanti lelobanga layo liluhlupho losizi,
\q2 ngoba iphanga yedlule, lathi siphaphe nje sedlule.
\q1 
\v 11 Ngubani owaziyo amandla olaka lwakho na?
\q2 Ngoba intukuthelo yakho inkulu njengokwesatshwa okukufaneleyo.
\q1 
\v 12 Sifundise ukubala kuhle insuku zethu,
\q2 ukuze sizuze inhliziyo yenhlakanipho.
\b
\q1 
\v 13 Phola, Oh \nd Thixo!\nd* Koze kube nini kulokhu kunjalo na?
\q2 Woba lesihawu ezincekwini zakho.
\q1 
\v 14 Sisuthise ekuseni ngothando lwakho olungaphuthiyo,
\q2 ukuze sihlabelele ngentokozo sijabule zonke insuku zethu.
\q1 
\v 15 Senze sijabule okwensuku ezilingana ukusihlupha kwakho,
\q2 okwensuku ezilingana lalezo esesabona ngazo ukudubeka.
\q1 
\v 16 Sengathi imisebenzi yakho ingatshengiswa ezincekwini zakho,
\q2 inkazimulo yakho ebantwaneni babo.
\b
\q1 
\v 17 Sengathi umusa weNkosi uNkulunkulu wethu ungehlela kithi;
\q2 uqinise umsebenzi wezandla zethu
\q2 yebo, qinisa umsebenzi wezandla zethu.
\c 91
\cl Ihubo 91
\q1 
\v 1 Lowo ohlala ekusithekeni koPhezukonke
\q2 uzaphumula emthunzini kaSomandla.
\q1 
\v 2 Ngizakuthi \nd kuThixo\nd*, “Uyisiphephelo sami lenqaba yami,
\q2 uNkulunkulu wami, engithemba kuye.”
\b
\q1 
\v 3 Ngempela uzakuphephisa
\q2 emjibileni womthiyi
\q2 lasesifeni esibi esibulalayo.
\q1 
\v 4 Uzakusibekela ngezinsiba zakhe,
\q2 uzuze isiphephelo ngaphansi kwamaphiko akhe;
\q2 ukuthembeka kwakhe kuzakuba yisihlangu sakho lenqaba yakho.
\q1 
\v 5 Awuyikwesaba umnyama wobusuku,
\q2 loba umtshoko ontweza emini,
\q1 
\v 6 kumbe ingozi ehahabela emnyameni,
\q2 kumbe umkhuhlane obhubhisayo emini enkulu.
\q1 
\v 7 Abazinkulungwane bangawa eceleni lakho;
\q2 itshumi lezinkulungwane esandleni sakho sokunene,
\q2 kodwa kakusoze kusondele kuwe.
\q1 
\v 8 Uzaphosa nje amehlo akho
\q2 ubukele ubone ukujeziswa kwababi.
\b
\q1 
\v 9 Ungenza oPhezukonke abe likhaya lakho
\q2 yena \nd uThixo\nd* oyisiphephelo sami
\q1 
\v 10 lapho-ke akulangozi engakuwela,
\q2 akulamonakalo ozasondela ethenteni lakho.
\q1 
\v 11 Ngoba uzayala izingilosi zakhe ngawe
\q2 zikulinde kuzozonke izindlela zakho;
\q1 
\v 12 zizakuphakamisa ezandleni zazo,
\q2 ukuze ungakhubeki elitsheni.
\q1 
\v 13 Uzanyathela isilwane lephimpi;
\q2 uzasigxoba isilwane esikhulu lenyoka.
\b
\q1 
\v 14 “Ngoba uyangithanda,” kutsho \nd uThixo\nd*, “ngizamkhulula;
\q2 ngizamvikela, ngoba uyalinaka ibizo lami.
\q1 
\v 15 Uzangibiza, ngimphendule;
\q2 ngizakuba laye ekuhluphekeni,
\q2 ngizamkhulula ngimenzele udumo.
\q1 
\v 16 Ngizamsuthisa ngempilo ende
\q2 ngimtshengise insindiso yami.”
\c 92
\cl Ihubo 92
\d Ihubo. Ingoma. Elosuku lweSabatha.
\q1 
\v 1 Kuhle ukudumisa \nd uThixo\nd*
\q2 lokuhlabelela ebizweni lakho, wena oPhezukonke,
\q1 
\v 2 ukumemezela uthando lwakho ekuseni
\q2 lokuthembeka kwakho ebusuku,
\q1 
\v 3 ukutshaya iziginci ngomhubhe wezintambo ezilitshumi
\q2 lemvungamo emnandi yechacho.
\b
\q1 
\v 4 Ngoba uyangijabulisa ngezenzo zakho, Oh \nd Thixo\nd*;
\q2 ngihlala ngentokozo ngomsebenzi wezandla zakho.
\q1 
\v 5 Mikhulu kangaka imisebenzi yakho, Oh \nd Thixo\nd*,
\q2 izikile imicabango yakho!
\q1 
\v 6 Umuntu ongelangqondo akazi,
\q2 iziwula kazizwisisi,
\q1 
\v 7 ukuthi loba ababi bemila njengotshani
\q2 lezigangi zonke ziphumelela,
\q2 zizabhujiswa nini lanini.
\b
\q1 
\v 8 Kodwa wena \nd Thixo\nd*, uphakeme laphakade.
\b
\q1 
\v 9 Ngoba ngempela izitha zakho, Oh \nd Thixo\nd*,
\q2 ngempela izitha zakho zizabhubha;
\q2 zonke izigangi zizachithizwa.
\q1 
\v 10 Uluphakamisile uphondo lwami njengolwenyathi;
\q2 ngagcotshwa ngamakha amnandi.
\q1 
\v 11 Amehlo ami abonile ukwehlulwa kwezitha zami;
\q2 indlebe zami zizwile ngokuchithizwa kwezitha zami ezimbi.
\b
\q1 
\v 12 Abalungileyo bazaqhela njengesihlahla selala,
\q2 bazakhula njengomsedari waseLebhanoni;
\q1 
\v 13 ngoba behlanyelwe endlini \nd kaThixo\nd*,
\q2 bazaqhela emagumeni kaNkulunkulu wethu.
\q1 
\v 14 Bazabe belokhu bethela izithelo lanxa sebebadala,
\q2 bazahlala belokhu behluma beluhlaza,
\q1 
\v 15 bememezela besithi, “\nd UThixo\nd* uqotho;
\q2 uliDwala lami, kakukho bubi kuye.”
\c 93
\cl Ihubo 93
\q1 
\v 1 \nd UThixo\nd* uyabusa, ugqoke ubukhosi;
\q2 \nd uThixo\nd* ugqoke ubukhosi njalo uzihlome ngamandla.
\q2 Umhlaba ugxilile uqinile; ngeke ugudlulwe.
\q1 
\v 2 Isihlalo sakho saqiniswa ekadeni;
\q2 uNguwe kusukela phakade.
\b
\q1 
\v 3 Inlwandle seziphakamisile, Oh \nd Thixo\nd*,
\q2 inlwandle ziliphakamisile ilizwi lazo;
\q2 inlwandle ziwaphakamisile amagagasi azo agubhuzelayo.
\q1 
\v 4 Ngamandla adlula umdumo wamanzi amanengi,
\q2 ngamandla adlula awokugubhuza kolwandle
\q2 \nd uThixo\nd* ophezulu ulamandla.
\b
\q1 
\v 5 Izimiso zakhe zimi ziqinile;
\q2 ubungcwele bukhazimulisa indlu Yakho
\q2 okwensuku ezingapheliyo, Oh \nd Thixo\nd*.
\c 94
\cl Ihubo 94
\q1 
\v 1 Oh \nd Thixo\nd*, uNkulunkulu ophindiselayo,
\q2 Oh Nkulunkulu ophindiselayo, khanya uvele.
\q1 
\v 2 Phakama, awu Mahluli womhlaba;
\q2 baphindisele abazigqajayo ngokubafaneleyo.
\q1 
\v 3 Koze kube nini ababi, Oh \nd Thixo\nd*,
\q2 koze kube nini ababi beklamasa na?
\b
\q1 
\v 4 Bathulula amazwi okukloloda;
\q2 zonke izigangi zifuthelene ngokuzikhukhumeza.
\q1 
\v 5 Ziyabanyathezela abantu bakho, Oh \nd Thixo\nd*;
\q2 zincindezela ilifa lakho.
\q1 
\v 6 Zibulala umfelokazi kanye lowezizweni;
\q2 zibulala intandane.
\q1 
\v 7 Zithi, “\nd UThixo\nd* kaboni;
\q2 uNkulunkulu kaJakhobe kananzi.”
\b
\q1 
\v 8 Limukani, lina elingelangqondo phakathi kwabantu;
\q2 lina ziphukuphuku, lizahlakanipha nini?
\q1 
\v 9 Yena lowo owayigxumekayo indlebe kezwa yini?
\q2 Yena lowo owabumba ilihlo kaboni na?
\q1 
\v 10 Yena lowo oqondisa izizwe kajezisi yini?
\q2 Yena lowo ofundisa umuntu kalalwazi na?
\q1 
\v 11 \nd UThixo\nd* uyayazi imicabango yomuntu;
\q2 uyayazi ukuthi iyize nje.
\b
\q1 
\v 12 Ubusisiwe umuntu omqondisayo, Oh \nd Thixo\nd*,
\q2 umuntu omfundisa okomthetho wakho;
\q1 
\v 13 uyamphumuza ensukwini zokuhlupheka,
\q2 kuze kuthi ababi bembelwe igodi.
\q1 
\v 14 Ngoba \nd uThixo\nd* kazukwala abantu bakhe;
\q2 kasoze lanini afulathele ilifa lakhe.
\q1 
\v 15 Ukwahlulela kuzaphinda njalo kumiswe ngokulunga,
\q2 kuthi bonke abaqotho ngenhliziyo bakulandele.
\b
\q1 
\v 16 Ngubani ozangimela ekulweni lababi na?
\q2 Ngubani ozangelekelela ekulweni lezigangi na?
\q1 
\v 17 Aluba \nd uThixo\nd* wayengangelulekanga,
\q2 ngabe ngahle ngahlala ngathula zwi ekufeni.
\q1 
\v 18 Lapho ngasengisithi, “Unyawo lwami selutshelela,”
\q2 uthando lwakho, Oh \nd Thixo\nd*, lwangisekela.
\q1 
\v 19 Nxa ukunqineka kwase kungikhulela,
\q2 induduzo yakho yaletha intokozo emphefumulweni wami.
\b
\q1 
\v 20 Kambe isihlalo sobukhosi esixhwalileyo singema lawe yini
\q2 leso esiletha inhlupheko ngezimemezelo zaso?
\q1 
\v 21 Bayahlangana ukumelana labalungileyo
\q2 ongelacala agwetshelwe ukufa.
\q1 
\v 22 Kodwa \nd uThixo\nd* useyinqaba yami,
\q2 loNkulunkulu wami ulidwala engiphephela kulo.
\q1 
\v 23 Uzabaphindisela ngenxa yezono zabo
\q2 ababhubhise ngenxa yobubi babo;
\q2 \nd uThixo\nd* uNkulunkulu wethu uzababhubhisa.
\c 95
\cl Ihubo 95
\q1 
\v 1 Wozani sihlabelele ngentokozo \nd kuThixo\nd*;
\q2 kasihlokomeni kamnandi kulo iDwala lokusindiswa kwethu.
\q1 
\v 2 Kasizeni phambi kwakhe ngokubonga
\q2 simdumise ngamachacho langengoma.
\b
\q1 
\v 3 Ngoba \nd uThixo\nd* unguNkulunkulu omkhulu,
\q2 iNkosi enkulu ngaphezu kwabonkulunkulu bonke.
\q1 
\v 4 Inziki zomhlaba zisezandleni zakhe,
\q2 leziqongo zezintaba ngezakhe.
\q1 
\v 5 Ngolwakhe ulwandle ngoba walwenza,
\q2 lezandla zakhe zawenza umhlaba owomileyo.
\b
\q1 
\v 6 Wozani, kasikhothame simkhonze,
\q2 kasiguqe phambi \nd kukaThixo\nd* uMenzi wethu;
\q1 
\v 7 ngoba unguNkulunkulu wethu,
\q2 thina singabantu bedlelo lakhe,
\q2 umhlambi awunakekelayo.
\b
\q1 Lamhla, nxa lisizwa ilizwi lakhe,
\q1 
\v 8 lingazenzi lukhuni inhliziyo zenu njengoba lenzenjalo eMeribha,
\q2 njengelakwenza ngaleliyana ilanga eMasa enkangala,
\q1 
\v 9 lapho okhokho benu abangilinga khona
\q2 bengizama, lanxa babekubonile engakwenzayo.
\q1 
\v 10 Okweminyaka engamatshumi amane ngangisizondele lesosizukulwane;
\q2 ngathi, “Bangabantu onhliziyo zabo ziyahlanhlatha,
\q2 njalo kabazazanga izindlela zami.”
\q1 
\v 11 Ngakho ngamemezela ngesifungo ekuthukutheleni kwami
\q2 ngathi, “Kabayikungena ekuphumuleni kwami.”
\c 96
\cl Ihubo 96
\q1 
\v 1 Hlabelani \nd kuThixo\nd* ingoma entsha;
\q2 hlabelani \nd kuThixo\nd* mhlaba wonke.
\q1 
\v 2 Hlabelani \nd kuThixo\nd*, dumisani ibizo lakhe;
\q2 memezelani insindiso yakhe insuku ngezinsuku.
\q1 
\v 3 Fakazani ngobukhosi bakhe ezizweni zonke,
\q2 lemisebenzi yakhe emangalisayo phakathi kwabantu bonke.
\b
\q1 
\v 4 Ngoba umkhulu \nd uThixo\nd*, ufanele ukudunyiswa ngokuphindiweyo;
\q2 kumele esatshwe ngaphezu kwabonkulunkulu bonke.
\q1 
\v 5 Ngoba bonke onkulunkulu bezizwe bayizithombe,
\q2 kodwa \nd uThixo\nd* wadala amazulu.
\q1 
\v 6 Inkazimulo lobukhosi kuphambi Kwakhe;
\q2 amandla lobukhosi kusendlini yakhe engcwele.
\b
\q1 
\v 7 Mnikeni \nd uThixo\nd*, lina zizukulwane zezizwe.
\q2 Mnikeni \nd uThixo\nd* ubukhosi lamandla.
\q1 
\v 8 Mnikeni \nd uThixo\nd* udumo olufanele ibizo lakhe.
\q2 Lethani umnikelo libuye phambi kwakhe.
\q1 
\v 9 Mkhonzeni \nd uThixo\nd* enkazimulweni yobungcwele bakhe;
\q2 thuthumelani phambi kwakhe mhlaba wonke.
\q1 
\v 10 Wothini phakathi kwezizwe, “\nd UThixo\nd* uyabusa.”
\q2 Umhlaba ugxilile, ungeke wagudluzwa;
\q2 uzabehlulela abantu ngokubafaneleyo.
\b
\q1 
\v 11 Amazulu kawathokoze, lomhlaba ujabule;
\q2 ulwandle kaluhlokome, lakho konke okukulo;
\q1 
\v 12 amasimu kawathakazelele lakho konke okukuwo.
\q2 Lapho-ke izihlahla zonke zeganga zizahlabela ngentokozo;
\q1 
\v 13 phambi \nd kukaThixo\nd*, ngoba uyeza,
\q2 uyeza ukuzakwahlulela umhlaba.
\q1 Uzakwahlulela umhlaba ngokulunga,
\q2 ahlulele abantu ngeqiniso.
\c 97
\cl Ihubo 97
\q1 
\v 1 \nd UThixo\nd* uyabusa, umhlaba kawuthokoze;
\q2 akuthi amakhumbi akude ajabule.
\q1 
\v 2 Amayezi lomnyama omkhulu kumsibekele;
\q2 ukulunga lokwahlulela kuhle kuyisisekelo sesihlalo Sakhe sobukhosi.
\q1 
\v 3 Umlilo uhamba phambi Kwakhe
\q2 uzihangule izitha zakhe inxa zonke.
\q1 
\v 4 Umbane wakhe ukhanyisa umhlaba;
\q2 umhlaba ukubone lokho uthuthumele.
\q1 
\v 5 Izintaba zincibilika njengengcino phambi \nd kukaThixo\nd*,
\q2 phambi kweNkosi yomhlaba wonke.
\q1 
\v 6 Amazulu amemezela ukulunga kwayo,
\q2 labantu bonke bayayibona inkazimulo yayo.
\b
\q1 
\v 7 Bonke abakhonza izifanekiso bathelwa ihlazo,
\q2 labo abazikhukhumeza ngezithombe
\q2 mkhonzeni, lonke lina bonkulunkulu!
\b
\q1 
\v 8 IZiyoni iyezwa ithokoze
\q2 lemizi yakoJuda iyajabula
\q2 ngenxa yokwahlulela Kwakho, Oh \nd Thixo\nd*.
\q1 
\v 9 Ngoba wena, Oh \nd Thixo\nd* ungoPhezukonke kuwo wonke umhlaba;
\q2 uphakeme ngaphezulu kakhulu kwabonkulunkulu bonke.
\q1 
\v 10 Akuthi bonke abamthandayo, \nd uThixo\nd*, bazonde okubi,
\q2 ngoba uyazilinda impilo zabathembekileyo bakhe
\q2 abakhulule esandleni sababi.
\q1 
\v 11 Ukukhanya kuyehliselwa kwabalungileyo
\q2 lentokozo kwabaqotho enhliziyweni.
\q1 
\v 12 Thokozani \nd kuThixo\nd* lina elilungileyo,
\q2 lidumise ibizo lakhe elingcwele.
\c 98
\cl Ihubo 98
\d Ihubo
\q1 
\v 1 Hlabelelani \nd uThixo\nd* ingoma entsha,
\q2 ngoba wenzile izinto ezimangalisayo;
\q1 isandla sakhe sokunene lengalo yakhe engcwele
\q2 sekumenzele insindiso.
\q1 
\v 2 \nd UThixo\nd* useyenze yaziwa insindiso yakhe
\q2 waveza ukulunga kwakhe ezizweni.
\q1 
\v 3 Uselukhumbule uthando lwakhe
\q2 lokuthembeka Kwakhe endlini ka-Israyeli;
\q1 yonke imikhawulo yomhlaba
\q2 iyibonile insindiso kaNkulunkulu wethu.
\b
\q1 
\v 4 Hlokomani ngentokozo \nd kuThixo\nd*, mhlaba wonke,
\q2 hlabelani ingoma ngokujabula okukhulu,
\q2 litshaya amachacho;
\q1 
\v 5 yenzani umsindo \nd kuThixo\nd* ngomhubhe,
\q2 ngomhubhe langomsindo wokuhlabela,
\q1 
\v 6 ngamacilongo langomsindo wophondo lwenqama
\q2 hlokomani ngentokozo phambi \nd kukaThixo\nd*, iNkosi.
\b
\q1 
\v 7 Akuthi ulwandle luhlokome, lakho konke okuphakathi kwalo,
\q2 umhlaba labo bonke abahlala kuwo.
\q1 
\v 8 Akuthi imifula iqakeze izandla zayo,
\q2 akuthi izintaba zihlabele kanyekanye ngentokozo;
\q1 
\v 9 kazihlabele phambi \nd kukaThixo\nd*,
\q2 ngoba Uyeza ukuzakwahlulela umhlaba.
\q1 Uzakwahlulela umhlaba ngokulunga
\q2 labantu bonke ngokufaneleyo.
\c 99
\cl Ihubo 99
\q1 
\v 1 \nd UThixo\nd* uyabusa,
\q2 izizwe kazithuthumele;
\q1 uhlezi esihlalweni sobukhosi phakathi kwamakherubhi,
\q2 umhlaba kawuzamazame.
\q1 
\v 2 Mkhulu \nd uThixo\nd* eZiyoni;
\q2 uphakeme ngaphezu kwezizwe zonke.
\q1 
\v 3 Kabadumise ibizo Lakho elikhulu elesabekayo
\q2 Yena ungcwele.
\b
\q1 
\v 4 INkosi ilamandla, ithanda ukwahlulela okuhle
\q2 umisile ukwaba ngemfanelo;
\q2 kuJakhobe usuwenzile okuqondileyo lokulungileyo.
\q1 
\v 5 Dumisani \nd uThixo\nd* uNkulunkulu wethu
\q2 likhonze phansi kwesihlalo sakhe;
\q2 yena ungcwele.
\b
\q1 
\v 6 UMosi lo-Aroni babephakathi kwabaphristi bakhe,
\q2 uSamuyeli wayekulabo ababelibiza ibizo lakhe;
\q1 bambiza \nd uThixo\nd*
\q2 Yena wabaphendula.
\q1 
\v 7 Wabakhulumisa ephakathi kwensika yeyezi;
\q2 bagcina izimiso zakhe lezimemezelo azitshoyo kubo.
\b
\q1 
\v 8 Oh \nd Thixo\nd* Nkulunkulu wethu,
\q2 wabaphendula;
\q1 ku-Israyeli wawunguNkulunkulu othethelelayo,
\q2 lanxa wabajezisa ngenxa yezenzo zabo ezimbi.
\q1 
\v 9 Phakamisani \nd uThixo\nd* uNkulunkulu wethu,
\q2 limkhonze entabeni yakhe engcwele,
\q2 ngoba \nd uThixo\nd* uNkulunkulu wethu ungcwele.
\c 100
\cl Ihubo 100
\d Ihubo. Elokubonga.
\q1 
\v 1 Hlokomani ngentokozo \nd kuThixo\nd*, mhlaba wonke.
\q2 
\v 2 Mkhonzeni \nd uThixo\nd* ngenjabulo;
\q2 wozani phambi Kwakhe ngezingoma zokuthokoza.
\q1 
\v 3 Yazini ukuthi \nd uThixo\nd* unguNkulunkulu.
\q2 Nguye owasenzayo,
\q2 singabantu bakhe, izimvu zedlelo lakhe.
\b
\q1 
\v 4 Ngenani emasangweni akhe ngokubonga
\q2 lemagumeni akhe ngokudumisa;
\q2 mbongeni lidumise ibizo lakhe.
\q1 
\v 5 Ngoba \nd uThixo\nd* ulungile lothando lwakhe lumi kuze kube phakade;
\q2 ukuthembeka kwakhe kumi kuzozonke izizukulwane.
\c 101
\cl Ihubo 101
\d ElikaDavida. Ihubo.
\q1 
\v 1 Ngizahlabelela ngothando lwakho lokwahlulela kwakho okuhle;
\q2 kuwe, Oh \nd Thixo\nd*, ngizahlabelela indumiso.
\q1 
\v 2 Ngizananzelela ukuthi ngiphile impilo engasolekiyo
\q2 uzakuza nini kimi na?
\b
\q1 Ngizahamba endlini
\q2 yami ngenhliziyo engasolekiyo.
\q1 
\v 3 Phambi kwamehlo ami
\q2 angiyikubeka lutho olungcolileyo.
\b
\q1 Izenzo zabantu abangakholwayo ngiyazizonda;
\q2 kazizukunginamathela.
\q1 
\v 4 Abantu abalenhliziyo exhwalileyo bazakuba khatshana lami;
\q2 angiyikuhambelana lobubi.
\b
\q1 
\v 5 Lowo ochothoza umakhelwane wakhe ngasese,
\q2 lowo ngizamthulisa;
\q1 olamehlo asesiphundu lenhliziyo ezigqajayo,
\q2 lowo kangilasikhathi laye.
\b
\q1 
\v 6 Amehlo ami azakuba kwabathembekileyo elizweni,
\q2 ukuthi bahlale lami;
\q1 lowo okuhamba kwakhe kakulansolo
\q2 uzangisebenzela ekhonza kimi.
\b
\q1 
\v 7 Kakho othanda ukwenza inkohliso
\q2 ozahlala endlini yami;
\q1 kakho okhuluma amanga
\q2 ozakuma phambi kwami.
\b
\q1 
\v 8 Zonke insuku ekuseni ngizabathulisa
\q2 bonke ababi phakathi kwelizwe;
\q1 ngizamlahla phansi wonke umuntu oyisigangi
\q2 edolobheni \nd likaThixo\nd*.
\c 102
\cl Ihubo 102
\d Umkhuleko womuntu okhathazekileyo. Lapho esephela umoya eseqhinqa isililo phambi \nd kukaThixo\nd*.
\q1 
\v 1 Zwana umkhuleko wami, Oh \nd Thixo\nd*;
\q2 ukukhala kwami ngicela uncedo kakufike kuwe.
\q1 
\v 2 Ungangifihleli ubuso bakho
\q2 nxa ngikhathazekile.
\q1 Ngipha indlebe yakho;
\q2 nxa ngibiza ngiphendula masinyane.
\b
\q1 
\v 3 Ngoba insuku zami ziyanyamalala njengentuthu;
\q2 amathambo ami ayavutha njengamalahle abhebhayo.
\q1 
\v 4 Inhliziyo yami yonakele, ibunile njengotshani;
\q2 ngiyakhohlwa ukudla kwami.
\q1 
\v 5 Ngenxa yokububula kwami okukhulu sengiphelile,
\q2 isikhumba sesinamathela emathanjeni.
\q1 
\v 6 Sengifana lesikhova senkangala,
\q2 njengesikhova semanxiweni.
\q1 
\v 7 Ngilala ngikhangele;
\q2 senginjengenyoni ehlezi yodwa ephahleni.
\q1 
\v 8 Ilanga lonke izitha zami ziyangichukuluza;
\q2 labo abangichothozayo badlala ngebizo lami njengesethuko.
\q1 
\v 9 Ngoba ngidla umlotha njengokudla kwami,
\q2 ngixube okunathwayo kwami ngezinyembezi
\q1 
\v 10 ngenxa yokuthukuthela kwakho okukhulu,
\q2 ngoba ungiqukule wangilahlela eceleni.
\q1 
\v 11 Insuku zami zifana lesithunzi sakusihlwa;
\q2 ngiyabuna njengotshani.
\b
\q1 
\v 12 Kodwa wena, Oh \nd Thixo\nd*, uhlezi ebukhosini lanininini;
\q2 udumo lwakho lumi ezizukulwaneni zonke.
\q1 
\v 13 Uzaphakama uzwele iZiyoni isihawu,
\q2 ngoba sekuyisikhathi sokutshengisa umusa kuyo,
\q2 isikhathi esimisiweyo sesifikile.
\q1 
\v 14 Ngoba amatshe ayo aligugu ezincekwini zakho;
\q2 othuli lwayo nje lubalethela usizi.
\q1 
\v 15 Izizwe zizalesaba ibizo \nd likaThixo\nd*,
\q2 wonke amakhosi omhlaba azahlonipha inkazimulo yakhe.
\q1 
\v 16 Ngoba \nd uThixo\nd* uzayakha kutsha iZiyoni
\q2 avele enkazimulweni yakhe.
\q1 
\v 17 Uzaphendula imikhuleko yabahluphekayo;
\q2 kazukweyisa isicelo sabo.
\b
\q1 
\v 18 Lokhu kakulotshwe phansi kube ngokwesizukulwane sakusasa,
\q2 ukuze abantu abangakadalwa bamdumise \nd uThixo\nd* :
\q1 
\v 19 “\nd UThixo\nd* wakhangela phansi ephezulu endlini yakhe engcwele,
\q2 esezulwini wawuhlola umhlaba,
\q1 
\v 20 ukuze ezwe ukububula kwezibotshwa
\q2 lokukhulula labo ababegwetshelwe ukufa.”
\q1 
\v 21 Ngalokho-ke ibizo \nd likaThixo\nd* lizamenyezelwa eZiyoni
\q2 lodumo lwakhe eJerusalema,
\q1 
\v 22 lapha izizwe lemibuso
\q2 sekuhlangana ndawonye ukukhonza \nd uThixo\nd*.
\b
\q1 
\v 23 Wawanciphisa amandla ami ngisaphila;
\q2 waziphungula insuku zami.
\q1 
\v 24 Yikho ngasengisithi,
\q1 “Ungangithathi, Oh Nkulunkulu wami,
\q2 ngilokhu ngisephakathi kwensuku zami;
\q2 iminyaka yakho ihlala ikhona ezizukulwaneni zonke.
\q1 
\v 25 Ekuqaleni wabeka izisekelo zomhlaba,
\q2 lamazulu angumsebenzi wezandla zakho.
\q1 
\v 26 Konke kuzabhubha, kodwa wena uzasala;
\q2 konke kuzaguga njengesigqoko.
\q1 Njengesivunulo uzakuguqula
\q2 kucine sekulahlwa.
\q1 
\v 27 Kodwa wena uhlala unjalo,
\q2 leminyaka yakho kayiyikuphela.
\q1 
\v 28 Abantwana bezinceku zakho bazahlala besemehlweni akho;
\q2 izizukulwane zazo zizaqiniswa phambi kwakho.”
\c 103
\cl Ihubo 103
\d ElikaDavida.
\q1 
\v 1 Dumisa \nd uThixo\nd*, Oh mphefumulo wami;
\q2 konke okuphakathi kwami,
\q2 kakudumise ibizo lakhe elingcwele.
\q1 
\v 2 Dumisa \nd uThixo\nd*, Oh mphefumulo wami,
\q2 ungaze wakhohlwa konke okuhle okuthola kuye
\q1 
\v 3 othethelelayo zonke izono zakho
\q2 akusilise kuzozonke izifo zakho,
\q1 
\v 4 ohlenga impilo yakho egodini
\q2 akwethese uthando lesihawu,
\q1 
\v 5 osuthisa izifiso zakho ngezinto ezinhle
\q2 ukuze ubutsha bakho buvuselelwe njengengqungqulu.
\b
\q1 
\v 6 \nd UThixo\nd* ubenzela ukulunga
\q2 lokwahlulela okuhle labo abancindezelweyo.
\b
\q1 
\v 7 Izindlela zakhe wazazisa uMosi,
\q2 izenzo zakhe wazazisa abantu bako-Israyeli;
\q1 
\v 8 \nd uThixo\nd* ulesihawu njalo ulomusa,
\q2 uyaphuza ukuthukuthela, kodwa uyanda ngothando.
\q1 
\v 9 Kahlali ebeka imilandu
\q2 futhi kagcini ulaka lwakhe kokuphela;
\q1 
\v 10 kasiphathi ngokufanele izono zethu
\q2 kumbe asijezise ngokulingene iziphambeko zethu.
\q1 
\v 11 Ngoba njengokuphakama komkhathi ngaphezu komhlaba,
\q2 lukhulu kangako uthando lwakhe kulabo abamesabayo;
\q1 
\v 12 njengobukhatshana bempumalanga kuyo intshonalanga
\q2 kanjalo ususile iziphambeko zethu kithi.
\b
\q1 
\v 13 Ngendlela ubaba elozwelo ebantwaneni bakhe,
\q2 kanjalo \nd uThixo\nd* ulozwelo kulabo abamesabayo;
\q1 
\v 14 ngoba uyakwazi ukuthi sibunjwe njani,
\q2 uyakhumbula ukuthi siluthuli.
\q1 
\v 15 Umuntu yena insuku zakhe zinjengotshani,
\q2 ukhula amemetheke njengembali yeganga;
\q1 
\v 16 umoya uyayiphephetha ihle inyamalale,
\q2 indawo yakhe ingabe isayikhumbula lanini.
\q1 
\v 17 Kodwa kusukela phakade kusiya phakade
\q2 uthando \nd lukaThixo\nd* lukulabo abamesabayo,
\q2 lokulunga Kwakhe ebantwaneni babantwana
\q1 
\v 18 kulabo abagcina isivumelwano Sakhe
\q2 njalo bakhumbule ukulalela izimiso zakhe.
\b
\q1 
\v 19 \nd UThixo\nd* usemisile isihlalo sakhe sobukhosi ezulwini,
\q2 njalo ubukhosi bakhe buphezu kwakho konke.
\b
\q1 
\v 20 Dumisani \nd uThixo\nd*, lina zingilosi,
\q2 lina zinceku zakhe elenza intando yakhe,
\q2 elilalela ilizwi lakhe.
\q1 
\v 21 Dumisani \nd uThixo\nd*, lonke mabutho akhe asezulwini,
\q2 lina zinceku zakhe elenza intando yakhe.
\q1 
\v 22 Dumisani \nd uThixo\nd*, imisebenzi yakhe yonke
\q2 ezindaweni zonke embusweni wakhe.
\b
\q1 Dumisa \nd uThixo\nd*, Oh mphefumulo wami.
\c 104
\cl Ihubo 104
\q1 
\v 1 Dumisa \nd uThixo\nd*, Oh mphefumulo wami.
\b
\q1 Oh \nd Thixo\nd* Nkulunkulu wami, umkhulu kakhulu;
\q2 ugqoke inkazimulo lobukhosi.
\b
\q1 
\v 2 Uyazigoqela ngokukhanya kungathi njengesivunulo;
\q2 amazulu uyawelula njengethente
\q2 
\v 3 anqumise intungo zezindlu zangaphezulu zilale phezu kwamanzi.
\q1 Wenza amayezi inqola yakhe yamabhiza,
\q2 undiza ngezimpiko zomoya.
\q1 
\v 4 Wenza izikhatha zomoya zibe yizithunywa zakhe,
\q2 amalangabi omlilo izinceku zakhe.
\b
\q1 
\v 5 Wawugxilisa umhlaba ezisekelweni zawo;
\q2 ungeke wagudlulwa.
\q1 
\v 6 Wawembesa ngolwandle njengesivunulo;
\q2 amanzi ema ngaphezu kwezintaba.
\q1 
\v 7 Kodwa wathi ngokukhwaza amanzi abaleka,
\q2 ngomsindo wokuduma kwakho asibathela;
\q1 
\v 8 ageleza phezu kwezintaba,
\q2 ehlela ezigodini
\q2 endaweni owamisele kuyo.
\q1 
\v 9 Wamisa umkhawulo angeke aweqe;
\q2 kasayikubuya awugubuzele njalo umhlaba lanini.
\b
\q1 
\v 10 Wenza imithombo impompozele amanzi ezindongeni;
\q2 ageleza phakathi kwezintaba,
\q1 
\v 11 zipha amanzi kuzozonke izinyamazana zeganga;
\q2 labobabhemi beganga bacitsha lapho ukoma.
\q1 
\v 12 Izinyoni zomoya zakhela eduze kwamanzi;
\q2 ziyatshiloza phakathi kwezingatsha.
\q1 
\v 13 Uyazithelezela izintaba esezindlini zakhe eziphezulu;
\q2 umhlaba uyawusuthisa ngezithelo zomsebenzi wakhe.
\q1 
\v 14 Umilisela inkomo utshani,
\q2 ahlanyelele abantu bona bahlakule
\q2 kuzuzakale ukudla emhlabathini:
\q1 
\v 15 iwayini elijabulisa inhliziyo yomuntu,
\q2 amagcobo enza ubuso bakhe bukhazimule,
\q2 lesinkwa esilulamisa inhliziyo yakhe.
\q1 
\v 16 Izihlahla \nd zikaThixo\nd* ziyathelelwa okwaneleyo,
\q2 imisedari yeLebhanoni ayihlanyelayo.
\q1 
\v 17 Izinyoni zakhela kuyo izidleke zazo;
\q2 ingabuzane lakha indlu yalo ezihlahleni zephayini.
\q1 
\v 18 Izintaba eziphakemeyo ngezamagogo,
\q2 amawa ayisiphephelo sezimbila.
\b
\q1 
\v 19 Inyanga yehlukanisa izibanga zomnyaka,
\q2 lelanga liyazi ukuthi litshona nini.
\q1 
\v 20 Uletha umnyama, kube sebusuku,
\q2 lapho zonke izinyamazana zeganga zizingele.
\q1 
\v 21 Izilwane ziyabhonga zifuna inyama yazo
\q2 zidinga ukudla kwazo kuNkulunkulu.
\q1 
\v 22 Ilanga liyaphuma, zibe sezicatsha;
\q2 ziyabuyela ezikhundleni zazo zilale.
\q1 
\v 23 Umuntu abe esephuma aye emsebenzini wakhe,
\q2 ayotshikatshika kuze kube ntambama.
\b
\q1 
\v 24 Minengi kanganani imisebenzi yakho, Oh \nd Thixo!\nd*
\q2 Zonke wazenza ngenhlakanipho;
\q2 umhlaba ugcwele izidalwa zakho.
\q1 
\v 25 Nantuyana ulwandle, uthwaca olungakaya,
\q2 olunyakazela ngezidalwa ezingelakubalwa
\q2 izinto eziphilayo ezinkulu lezincinyane.
\q1 
\v 26 Kulapho imikhumbi endenda khona isiyale lale,
\q2 loleviyathani, isilo owasenza ukuthi sidlale khona.
\b
\q1 
\v 27 Zonke lezi zikhangele kuwe
\q2 ukuthi uziphe ukudla ngesikhathi esifaneleyo.
\q1 
\v 28 Uthi ungazipha bese zikubuthela ndawonye;
\q2 uthi ungavula isandla sakho,
\q2 zisuthiswe ngezinto ezinhle.
\q1 
\v 29 Uthi ungafihla ubuso bakho zitshaywe luvalo;
\q2 uthi ungathatha umphefumulo wazo,
\q2 zife zibuyele othulini.
\q1 
\v 30 Uthi ungathumela uMoya
\q2 wakho zidalwe,
\q2 uwenze ube muhle umhlaba.
\b
\q1 
\v 31 Sengathi inkazimulo \nd kaThixo\nd* ingema lanini;
\q2 sengathi \nd uThixo\nd* angathokoza ngemisebenzi yakhe
\q1 
\v 32 yena okhangela umhlaba uthuthumele,
\q2 othinta izintaba zithunqe intuthu.
\b
\q1 
\v 33 Ngizahlabelela \nd kuThixo\nd* impilo yami yonke;
\q2 ngizahlabelela indumiso kuNkulunkulu wami lanini nxa ngisaphila.
\q1 
\v 34 Sengathi iminakano yami ingamthokozisa,
\q2 ngoba ngiyathokoza \nd kuThixo\nd*.
\q1 
\v 35 Kodwa sengathi izoni zinganyamalala emhlabeni
\q2 lezigangi zingabe zisaba khona.
\b
\q1 Dumisa \nd uThixo\nd*, Oh Mphefumulo wami.
\b
\q1 Dumisa \nd uThixo\nd*, Oh Mphefumulo wami.
\c 105
\cl Ihubo 105
\q1 
\v 1 Bongani \nd uThixo\nd*, memezani ibizo lakhe;
\q2 lizazise phakathi kwabantu izenzo zakhe
\q1 
\v 2 Hlabelelani kuye, hlabelelani indumiso kuye;
\q2 likhulume ngezenzo zakhe zonke ezimangalisayo.
\q1 
\v 3 Jabulani ebizweni lakhe elingcwele;
\q2 kazithokoze inhliziyo zabo abamdingayo \nd uThixo\nd*.
\q1 
\v 4 Dingani \nd uThixo\nd* lamandla akhe,
\q2 limdinge yena njalonjalo.
\b
\q1 
\v 5 Khumbulani izenzo zakhe ezimangalisayo azenzayo,
\q2 izimangaliso azenzayo, lezahlulelo azikhulumayo,
\q1 
\v 6 lina zizukulwane zika-Abhrahama inceku yakhe,
\q2 lina madodana kaJakhobe, abakhethiweyo bakhe.
\q1 
\v 7 \nd UnguThixo\nd* uNkulunkulu wethu;
\q2 izahlulelo zakhe zisemhlabeni wonke.
\b
\q1 
\v 8 Uyasikhumbula isivumelwano sakhe nini lanini,
\q2 ilizwi lomlayo wakhe, okwezizukulwane ezizinkulungwane,
\q1 
\v 9 isivumelwano asenza lo-Abhrahama,
\q2 isifungo asifungayo ku-Isaka.
\q1 
\v 10 Wakuqinisa lokhu kuJakhobe
\q2 kwaba yisimiso ku-Israyeli njengesivumelwano saphakade:
\q1 
\v 11 wathi “Ngizalinika ilizwe laseKhenani
\q2 njengesabelo selifa lenu.”
\b
\q1 
\v 12 Kwathi besesebalutshwana,
\q2 bebalutshwana kakhulu, beyizihambi kulo,
\q1 
\v 13 bezula kuzizwe ngezizwe
\q2 besuka komunye umbuso besiya komunye.
\q1 
\v 14 Kavumelanga loba ngubani ukubancindezela;
\q2 wawakhuza amakhosi ngenxa yabo:
\q1 
\v 15 “Lingabathinti abagcotshiweyo bami;
\q2 lingahlukuluzi abaphrofethi bami.”
\b
\q1 
\v 16 Waletha indlala elizweni
\q2 wachitha zonke iziphala zokudla;
\q1 
\v 17 wathumela indoda yabandulela
\q2 uJosefa owathengiswa waba yisigqili.
\q1 
\v 18 Bambhonxula inyawo zakhe ngezibopho,
\q2 wabotshwa intamo ngezinsimbi,
\q1 
\v 19 kwaze kwathi lokho ayekutsho ngaphambili kwagcwaliseka,
\q2 kwaze kwathi ilizwi \nd likaThixo\nd*
\q2 latshengisa ukuthi wayeqinisile.
\q1 
\v 20 Inkosi yathumela ukuthi akhululwe,
\q2 umbusi wezizwe wamkhulula.
\q1 
\v 21 Wamenza umbusi wendlu yakhe,
\q2 umbusi wakho konke okwakungokwakhe,
\q1 
\v 22 ukuqondisa amakhosana akhe njengokubona kwakhe
\q2 lokufundisa abadala bakhe inhlakanipho.
\b
\q1 
\v 23 Kwathi-ke u-Israyeli wayangena eGibhithe;
\q2 uJakhobe wahlala njengowezizweni elizweni likaHamu.
\q1 
\v 24 \nd UThixo\nd* wenza abantu bakhe banda kakhulu;
\q2 wabenza baba banengi kakhulu bandela izitha zabo,
\q1 
\v 25 kwathi inhliziyo zabo wazenza zazonda abantu bakhe,
\q2 bakha amacebo amabi ngezinceku zakhe.
\q1 
\v 26 Wathuma uMosi inceku yakhe,
\q2 lo-Aroni ayebakhethile.
\q1 
\v 27 Benza iziboniso zakhe ezimangalisayo phakathi kwabo,
\q2 izimanga zakhe elizweni likaHamu.
\q1 
\v 28 Wathumela umnyama wenza ilizwe laba mnyama
\q2 kanti angithi babewahlamukele amazwi akhe?
\q1 
\v 29 Waguqula amanzi abo aba ligazi,
\q2 okwenza inhlanzi zawo zafa.
\q1 
\v 30 Ilizwe labo lanyakazela ngamaxoxo,
\q2 angena ezindlini zokulala ezababusi babo.
\q1 
\v 31 Wakhuluma, kwavela umtshitshi wezibawu,
\q2 lenswintila elizweni labo lonke.
\q1 
\v 32 Wenza izulu labo laba yisiqhotho,
\q2 laba lombane elizweni labo lonke;
\q1 
\v 33 wacakazela phansi amavini abo lemikhiwa,
\q2 waphundla izihlahla zelizwe labo.
\q1 
\v 34 Wakhuluma zatheleka izintethe,
\q2 izintethe ezingelakubalwa;
\q1 
\v 35 zadla yonke into eluhlaza elizweni labo,
\q2 zadla izithelo zomhlabathi wabo.
\q1 
\v 36 Ngemva kwalokho wasebulala amazibulo wonke elizweni labo,
\q2 izithelo zokuqala zobulisa babo.
\q1 
\v 37 Wamkhupha u-Israyeli, ethwele esisitheka isiliva legolide,
\q2 kakwaba lamunye phakathi kwezizwana zabo owehlulwa yikufa.
\q1 
\v 38 IGibhithe yathokoza ngokusuka kwabo,
\q2 ngoba base bemesaba kubi u-Israyeli.
\b
\q1 
\v 39 Wendlala iyezi lagubuzela,
\q2 lomlilo ukukhanyisa ebusuku.
\q1 
\v 40 Bacela wabalethela izagwaca,
\q2 wabasuthisa ngesinkwa sasezulwini.
\q1 
\v 41 Wavula ilitshe amanzi antshaza;
\q2 njengomfula ageleza enkangala.
\b
\q1 
\v 42 Ngoba wakhumbula isithembiso sakhe esingcwele
\q2 esaphiwa inceku yakhe u-Abhrahama.
\q1 
\v 43 Wabakhupha abantu bakhe ngokuthokoza,
\q2 abakhethiweyo bakhe ngenhlokomo yentokozo.
\q1 
\v 44 Wabapha amazwe ezizwe,
\q2 badla ilifa lalokho okwakuginqelwe ngabanye,
\q1 
\v 45 ukuze bagcine iziqondiso zakhe
\q2 njalo balalele imithetho yakhe.
\b
\q1 Dumisani \nd uThixo\nd*.
\c 106
\cl Ihubo 106
\q1 
\v 1 Dumisani \nd uThixo\nd*.
\b
\q1 Bongani \nd uThixo\nd*, ngoba ulungile;
\q2 uthando lwakhe lumi lanini.
\b
\q1 
\v 2 Ngubani ongamemezela imisebenzi emikhulu \nd kaThixo\nd*
\q2 loba atsho ngokugcweleyo udumo lwakhe na?
\q1 
\v 3 Babusisiwe labo abahlala besenza ngendlela enhle,
\q2 abahlezi besenza okulungileyo.
\b
\q1 
\v 4 Ungikhumbule, \nd Thixo\nd*, nxa usuveza umusa ebantwini bakho,
\q2 woza ungisize nxatshana usubasindisa,
\q1 
\v 5 ukuze lami ngikholise ukuphumelela kwalabo obakhethileyo,
\q2 ukuze ngabelwe entokozweni yesizwe sakho
\q2 ngihlanganyele lelifa lakho ekudumiseni.
\b
\q1 
