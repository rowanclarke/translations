\p 
\v 31 También \w hizo|strong="H6213"\w* templos en \w los|strong="H1121"\w* lugares \w altos|strong="H1116"\w* \w e|strong="H3068"\w* instituyó \w sacerdotes|strong="H3548"\w* \w de|strong="H1121"\w* \w entre|strong="H3808"\w* la \w gente|strong="H5971"\w* común, \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w eran|strong="H1961"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Leví|strong="H3878"\w*.
\v 32 \w Jeroboam|strong="H3379"\w* estableció una \w solemnidad|strong="H2282"\w* \w el|strong="H5921"\w* \w día|strong="H3117"\w* 15 \w del|strong="H5921"\w* \w mes|strong="H2320"\w* \w octavo|strong="H8066"\w*, \w semejante|strong="H3651"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w solemnidad|strong="H2282"\w* \w que|strong="H5921"\w* \w había|strong="H5975"\w* \w en|strong="H5921"\w* \w Judá|strong="H3063"\w*. \w Fue|strong="H3063"\w* \w al|strong="H5921"\w* \w altar|strong="H4196"\w* \w que|strong="H5921"\w* \w hizo|strong="H6213"\w* \w en|strong="H5921"\w* Bet-ʼEl \w para|strong="H5921"\w* ofrecer \w sacrificios|strong="H2076"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w becerros|strong="H5695"\w* \w que|strong="H5921"\w* \w hizo|strong="H6213"\w* \w y|strong="H5921"\w* holocaustos \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w altar|strong="H4196"\w*. \w También|strong="H3651"\w* estableció \w sacerdotes|strong="H3548"\w* \w en|strong="H5921"\w* Bet-ʼEl \w para|strong="H5921"\w* \w los|strong="H5921"\w* lugares \w altos|strong="H1116"\w* \w que|strong="H5921"\w* \w hicieron|strong="H6213"\w*.
\p 
\v 33 \w El|strong="H5921"\w* \w día|strong="H3117"\w* 15 \w del|strong="H5921"\w* \w mes|strong="H2320"\w* \w octavo|strong="H8066"\w*, fecha \w que|strong="H5921"\w* ideó \w por|strong="H5921"\w* su iniciativa propia, fue \w al|strong="H5921"\w* \w altar|strong="H4196"\w* \w que|strong="H5921"\w* \w hizo|strong="H6213"\w* \w en|strong="H5921"\w* Bet-ʼEl \w e|strong="H3068"\w* instituyó una \w solemnidad|strong="H2282"\w* \w para|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*. Fue \w al|strong="H5921"\w* \w altar|strong="H4196"\w* \w para|strong="H5921"\w* quemar incienso.
\c 13
\s1 Profecía sobre Josías
\p 
\v 1 \w Ciertamente|strong="H2009"\w* un varón \w de|strong="H5921"\w* \nd ʼElohim\nd*, \w por|strong="H5921"\w* revelación \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w fue|strong="H3063"\w* \w desde|strong="H5921"\w* \w Judá|strong="H3063"\w* \w a|strong="H3068"\w* Bet-ʼEl \add y llegó\add* cuando \w Jeroboam|strong="H3379"\w* \w estaba|strong="H5975"\w* \w junto|strong="H5921"\w* \w al|strong="H5921"\w* \w altar|strong="H4196"\w* \w para|strong="H5921"\w* quemar incienso.
\p 
\v 2 \w Por|strong="H5921"\w* mandato \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w clamó|strong="H7121"\w* \w contra|strong="H5921"\w* \w el|strong="H5921"\w* \w altar|strong="H4196"\w*: ¡\w Altar|strong="H4196"\w*, \w altar|strong="H4196"\w*! \nd \w Yavé|strong="H3068"\w*\nd* \w dice|strong="H1697"\w*: \wj \w Mira|strong="H2009"\w*, \w le|strong="H5921"\w* \w nacerá|strong="H3205"\w* un \w hijo|strong="H1121"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w David|strong="H1732"\w* \w que|strong="H5921"\w* \w se|strong="H5921"\w* \w llamará|strong="H7121"\w* \w Josías|strong="H2977"\w*, quien sacrificará \w sobre|strong="H5921"\w* \w ti|strong="H5921"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w sacerdotes|strong="H3548"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* lugares \w altos|strong="H1116"\w* \w que|strong="H5921"\w* queman incienso, \w y|strong="H5921"\w* \w quemarán|strong="H8313"\w* \w huesos|strong="H6106"\w* \w de|strong="H5921"\w* \w hombres|strong="H1121"\w*.\wj*
\p 
\v 3 \w Aquel|strong="H1931"\w* \w mismo|strong="H1931"\w* \w día|strong="H3117"\w* \w dio|strong="H5414"\w* una señal: \w Esta|strong="H2088"\w* \w es|strong="H1931"\w* \w la|strong="H1931"\w* señal \w que|strong="H1931"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w dio|strong="H5414"\w*: \wj ¡\w Ciertamente|strong="H2009"\w* \w el|strong="H1931"\w* \w altar|strong="H4196"\w* \w se|strong="H1931"\w* partirá, \w y|strong="H5921"\w* \w se|strong="H1931"\w* esparcirá \w la|strong="H1931"\w* ceniza \w que|strong="H1931"\w* \w está|strong="H2088"\w* \w sobre|strong="H5921"\w* \w él|strong="H1931"\w*!\wj*
\p 
\v 4 \w Sucedió|strong="H1961"\w* \w que|strong="H3808"\w* \w cuando|strong="H1961"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w oyó|strong="H8085"\w* \w la|strong="H5921"\w* \w palabra|strong="H1697"\w* \w que|strong="H3808"\w* \w el|strong="H5921"\w* varón \w de|strong="H5921"\w* \nd ʼElohim\nd* dijo \w contra|strong="H5921"\w* \w el|strong="H5921"\w* \w altar|strong="H4196"\w* \w de|strong="H5921"\w* Bet-ʼEl, \w Jeroboam|strong="H3379"\w* \w extendió|strong="H7971"\w* su \w mano|strong="H3027"\w* \w desde|strong="H5921"\w* \w el|strong="H5921"\w* \w altar|strong="H4196"\w* \w y|strong="H5921"\w* dijo: ¡Deténganlo! \w Y|strong="H3068"\w* \w al|strong="H5921"\w* momento \w se|strong="H1961"\w* \w le|strong="H5921"\w* \w secó|strong="H3001"\w* \w la|strong="H5921"\w* \w mano|strong="H3027"\w* \w que|strong="H3808"\w* \w extendió|strong="H7971"\w* \w contra|strong="H5921"\w* \w él|strong="H5921"\w*, \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w pudo|strong="H3201"\w* recogerla \w hacia|strong="H5921"\w* \w él|strong="H5921"\w*.
\v 5 Entonces el \w altar|strong="H4196"\w* \w se|strong="H4480"\w* partió, y la ceniza \w se|strong="H4480"\w* esparció, \w en|strong="H4480"\w* conformidad \w con|strong="H4480"\w* la señal \w que|strong="H4480"\w* el varón \w de|strong="H4480"\w* \nd ʼElohim\nd* \w dio|strong="H5414"\w* \w por|strong="H4480"\w* mandato \w de|strong="H4480"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\p 
\v 6 \w Entonces|strong="H7725"\w* el \w rey|strong="H4428"\w* tomó la palabra y dijo \w al|strong="H4428"\w* varón \w de|strong="H6440"\w* \nd ʼElohim\nd*: Te \w ruego|strong="H4994"\w* \w que|strong="H4994"\w* implores \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* y \w ores|strong="H6419"\w* \w por|strong="H1157"\w* \w mí|strong="H1961"\w*, \w para|strong="H1961"\w* \w que|strong="H4994"\w* \w sea|strong="H1961"\w* restaurada \w mi|strong="H1961"\w* \w mano|strong="H3027"\w*. \w Por|strong="H1157"\w* tanto el varón \w de|strong="H6440"\w* \nd ʼElohim\nd* imploró \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*. \w Le|strong="H1157"\w* \w fue|strong="H1961"\w* restaurada la \w mano|strong="H3027"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w* y \w volvió|strong="H7725"\w* \w a|strong="H3068"\w* ser \w como|strong="H1961"\w* \w antes|strong="H6440"\w*.
\p 
\v 7 Entonces el \w rey|strong="H4428"\w* \w dijo|strong="H1696"\w* \w al|strong="H4428"\w* varón \w de|strong="H5414"\w* \nd ʼElohim\nd*: Ven conmigo \w a|strong="H3068"\w* \w casa|strong="H1004"\w* y come, y te \w daré|strong="H5414"\w* un presente.
\p 
\v 8 Pero \w el|strong="H5973"\w* varón \w de|strong="H5973"\w* \nd ʼElohim\nd* contestó \w al|strong="H4428"\w* \w rey|strong="H4428"\w*: \w Aunque|strong="H3808"\w* \w me|strong="H5973"\w* \w des|strong="H5414"\w* la mitad \w de|strong="H5973"\w* tu \w casa|strong="H1004"\w*, \w no|strong="H3808"\w* iré \w contigo|strong="H5973"\w*, \w ni|strong="H3808"\w* comeré \w pan|strong="H3899"\w*, \w ni|strong="H3808"\w* \w beberé|strong="H8354"\w* \w agua|strong="H4325"\w* \w en|strong="H5973"\w* \w este|strong="H2088"\w* \w lugar|strong="H4725"\w*,
\v 9 \w porque|strong="H3588"\w* \w por|strong="H3588"\w* \w la|strong="H3588"\w* \w Palabra|strong="H1697"\w* \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w me|strong="H3588"\w* \w fue|strong="H1980"\w* \w ordenado|strong="H6680"\w*: \wj \w No|strong="H3808"\w* \w comas|strong="H3899"\w* \w pan|strong="H3899"\w*, \w ni|strong="H3808"\w* \w bebas|strong="H8354"\w* \w agua|strong="H4325"\w*, \w ni|strong="H3808"\w* \w vuelvas|strong="H7725"\w* \w por|strong="H3588"\w* \w el|strong="H3588"\w* \w camino|strong="H1870"\w* \w que|strong="H3588"\w* \w fuiste|strong="H1980"\w*.\wj*
\v 10 \w Salió|strong="H3212"\w* \w por|strong="H1870"\w* otro \w camino|strong="H1870"\w* y \w no|strong="H3808"\w* \w volvió|strong="H7725"\w* \w por|strong="H1870"\w* \w el|strong="H1008"\w* \w camino|strong="H1870"\w* \w por|strong="H1870"\w* \w el|strong="H1008"\w* cual \w fue|strong="H3212"\w* \w a|strong="H3068"\w* Bet-ʼEl.
\s1 Los dos profetas
\p 
\v 11 Un \w profeta|strong="H5030"\w* \w anciano|strong="H2205"\w* \w vivía|strong="H3427"\w* en Bet-ʼEl. Sus \w hijos|strong="H1121"\w* le informaron \w todo|strong="H3605"\w* \w lo|strong="H1697"\w* \w que|strong="H1697"\w* \w el|strong="H1008"\w* varón \w de|strong="H1121"\w* \nd ʼElohim\nd* \w hizo|strong="H6213"\w* \w aquel|strong="H3605"\w* \w día|strong="H3117"\w* en Bet-ʼEl. También \w contaron|strong="H1697"\w* \w a|strong="H3068"\w* su padre las \w palabras|strong="H1697"\w* \w que|strong="H1697"\w* \w habló|strong="H1696"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w*.
\p 
\v 12 \w Y|strong="H3068"\w* su padre les preguntó: ¿\w Por|strong="H1870"\w* cuál \w camino|strong="H1870"\w* salió? \w Y|strong="H3068"\w* sus \w hijos|strong="H1121"\w* le mostraron \w el|strong="H1121"\w* \w camino|strong="H1870"\w* \w por|strong="H1870"\w* donde salió \w el|strong="H1121"\w* varón \w de|strong="H1121"\w* \nd ʼElohim\nd* \w que|strong="H1121"\w* \w vino|strong="H1870"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*.
\p 
\v 13 \w Y|strong="H3068"\w* \w él|strong="H5921"\w* dijo \w a|strong="H3068"\w* sus \w hijos|strong="H1121"\w*: ¡Aparéjenme \w el|strong="H5921"\w* \w asno|strong="H2543"\w*! Entonces \w le|strong="H5921"\w* aparejaron \w el|strong="H5921"\w* \w asno|strong="H2543"\w*, montó \w sobre|strong="H5921"\w* \w él|strong="H5921"\w*
\v 14 y \w fue|strong="H3212"\w* tras aquel varón \w de|strong="H8478"\w* \nd ʼElohim\nd*. \w Al|strong="H8478"\w* hallarlo \w sentado|strong="H3427"\w* \w debajo|strong="H8478"\w* \w de|strong="H8478"\w* un roble, le preguntó: ¿Eres tú \w el|strong="H3427"\w* varón \w de|strong="H8478"\w* \nd ʼElohim\nd* que \w vino|strong="H3212"\w* \w de|strong="H8478"\w* \w Judá|strong="H3063"\w*? Le respondió: Sí, soy.
\p 
\v 15 Entonces le dijo: \w Ven|strong="H3212"\w* conmigo \w a|strong="H3068"\w* \w casa|strong="H1004"\w* y come \w pan|strong="H3899"\w*.
\p 
\v 16 Pero él dijo: \w No|strong="H3808"\w* \w puedo|strong="H3201"\w* \w volver|strong="H7725"\w* contigo, \w ni|strong="H3808"\w* entrar contigo. \w No|strong="H3808"\w* comeré \w pan|strong="H3899"\w*, \w ni|strong="H3808"\w* \w beberé|strong="H8354"\w* \w agua|strong="H4325"\w* contigo en \w este|strong="H2088"\w* \w lugar|strong="H4725"\w*,
\v 17 \w porque|strong="H3588"\w* \w por|strong="H3588"\w* revelación \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w me|strong="H3588"\w* \w fue|strong="H3212"\w* ordenado: \wj \w No|strong="H3808"\w* comerás \w pan|strong="H3899"\w*, \w ni|strong="H3808"\w* \w beberás|strong="H8354"\w* \w agua|strong="H4325"\w* \w allí|strong="H8033"\w*, \w ni|strong="H3808"\w* \w volverás|strong="H7725"\w* \w por|strong="H3588"\w* \w el|strong="H3588"\w* \w camino|strong="H1870"\w* \w que|strong="H3588"\w* \w fuiste|strong="H1980"\w*.\wj*
\p 
\v 18 Pero \w él|strong="H5030"\w* le \w dijo|strong="H1696"\w*: Yo \w también|strong="H1571"\w* soy \w profeta|strong="H5030"\w* \w como|strong="H1571"\w* tú. Un \w ángel|strong="H4397"\w* me \w habló|strong="H1696"\w* \w por|strong="H1697"\w* revelación \w de|strong="H1697"\w* \nd \w Yavé|strong="H3068"\w*\nd*: \wj Hazlo \w volver|strong="H7725"\w* contigo \w a|strong="H3068"\w* tu \w casa|strong="H1004"\w*, para \w que|strong="H1571"\w* coma \w pan|strong="H3899"\w* \w y|strong="H1571"\w* beba \w agua|strong="H4325"\w*.\wj* Pero le mintió.
\v 19 Se \w volvió|strong="H7725"\w* con él, comió \w pan|strong="H3899"\w* en su \w casa|strong="H1004"\w* y \w bebió|strong="H8354"\w* \w agua|strong="H4325"\w*.
\p 
\v 20 \w Aconteció|strong="H1961"\w* \w que|strong="H1697"\w* \w cuando|strong="H1961"\w* \w ellos|strong="H1992"\w* \w estaban|strong="H1961"\w* recostados, \w el|strong="H5030"\w* \w profeta|strong="H5030"\w* \w que|strong="H1697"\w* \w lo|strong="H1697"\w* devolvió \w tuvo|strong="H1961"\w* revelación \w de|strong="H1697"\w* \nd \w Yavé|strong="H3068"\w*,\nd*
\v 21 \w clamó|strong="H7121"\w* \w y|strong="H3588"\w* le dijo al varón \w de|strong="H3588"\w* \nd ʼElohim\nd* \w que|strong="H3588"\w* \w fue|strong="H3063"\w* \w de|strong="H3588"\w* \w Judá|strong="H3063"\w*: \nd \w Yavé|strong="H3068"\w*\nd* dice: \wj \w Porque|strong="H3588"\w* fuiste rebelde \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w Palabra|strong="H6310"\w* \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w guardaste|strong="H8104"\w* \w el|strong="H3588"\w* \w mandato|strong="H6310"\w* \w que|strong="H3588"\w* \w te|strong="H3588"\w* impuso \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd*,\wj*
\v 22 \wj \w sino|strong="H3808"\w* regresaste, comiste \w pan|strong="H3899"\w* y \w bebiste|strong="H8354"\w* \w agua|strong="H4325"\w* en este \w lugar|strong="H4725"\w*, \w del|strong="H8354"\w* cual \w se|strong="H3808"\w* te \w dijo|strong="H1696"\w*: \w No|strong="H3808"\w* comerás \w pan|strong="H3899"\w*, \w ni|strong="H3808"\w* \w beberás|strong="H8354"\w* \w agua|strong="H4325"\w*, tu cadáver \w no|strong="H3808"\w* entrará en el \w sepulcro|strong="H6913"\w* \w de|strong="H4325"\w* tus antepasados.\wj*
\p 
\v 23 \w Y|strong="H3068"\w* \w sucedió|strong="H1961"\w* \w que|strong="H1961"\w* comió \w pan|strong="H3899"\w* y \w bebió|strong="H8354"\w*. \w El|strong="H5030"\w* \w profeta|strong="H5030"\w* \w que|strong="H1961"\w* lo hizo devolver le aparejó \w el|strong="H5030"\w* \w asno|strong="H2543"\w*.
\v 24 \w Cuando|strong="H1961"\w* \w salió|strong="H3212"\w*, un león lo encontró \w en|strong="H5975"\w* el \w camino|strong="H1870"\w* y lo \w mató|strong="H4191"\w*. Su cadáver \w quedó|strong="H1961"\w* \w tendido|strong="H7993"\w* \w en|strong="H5975"\w* el \w camino|strong="H1870"\w*, y el \w asno|strong="H2543"\w* parado junto \w a|strong="H3068"\w* él. El león también \w quedó|strong="H1961"\w* parado junto al cadáver.
\v 25 Unos hombres \w pasaron|strong="H5674"\w* y \w vieron|strong="H7200"\w* \w el|strong="H5674"\w* cadáver \w tendido|strong="H7993"\w* \w en|strong="H5975"\w* \w el|strong="H5674"\w* \w camino|strong="H1870"\w* y al león junto al cadáver. Fueron y lo \w dijeron|strong="H1696"\w* \w en|strong="H5975"\w* la \w ciudad|strong="H5892"\w* donde \w vivía|strong="H3427"\w* \w el|strong="H5674"\w* \w profeta|strong="H5030"\w* \w anciano|strong="H2205"\w*.
\p 
\v 26 Cuando \w el|strong="H1931"\w* \w profeta|strong="H5030"\w* \w que|strong="H4480"\w* \w lo|strong="H1931"\w* \w hizo|strong="H5414"\w* devolver \w del|strong="H4480"\w* \w camino|strong="H1870"\w* \w oyó|strong="H8085"\w* \w esto|strong="H1697"\w*, \w dijo|strong="H1696"\w*: \w Es|strong="H1931"\w* \w el|strong="H1931"\w* varón \w de|strong="H4480"\w* \nd ʼElohim\nd* \w que|strong="H4480"\w* \w fue|strong="H1931"\w* desobediente \w a|strong="H3068"\w* \w la|strong="H1931"\w* \w Palabra|strong="H1697"\w* \w de|strong="H4480"\w* \nd \w Yavé|strong="H3068"\w*\nd*. \w Por|strong="H4480"\w* \w eso|strong="H1931"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w lo|strong="H1931"\w* \w entregó|strong="H5414"\w* \w al|strong="H4480"\w* león \w que|strong="H4480"\w* \w lo|strong="H1931"\w* destrozó y \w mató|strong="H4191"\w*, \w según|strong="H6310"\w* \w la|strong="H1931"\w* \w Palabra|strong="H1697"\w* \w que|strong="H4480"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w le|strong="H1931"\w* \w habló|strong="H1696"\w*.
\p 
\v 27 Entonces \w habló|strong="H1696"\w* \w a|strong="H3068"\w* sus \w hijos|strong="H1121"\w* y les \w dijo|strong="H1696"\w*: ¡Aparéjenme \w el|strong="H1121"\w* \w asno|strong="H2543"\w*! Ellos lo aparejaron,
\v 28 y él \w fue|strong="H3212"\w* y \w halló|strong="H4672"\w* el cadáver \w tendido|strong="H7993"\w* \w en|strong="H5975"\w* el \w camino|strong="H1870"\w*. El \w asno|strong="H2543"\w* y el león \w estaban|strong="H5975"\w* parados junto al cadáver. El león \w no|strong="H3808"\w* \w había|strong="H5975"\w* devorado el cadáver, \w ni|strong="H3808"\w* destrozó el \w asno|strong="H2543"\w*.
\v 29 \w El|strong="H5030"\w* \w profeta|strong="H5030"\w* \w levantó|strong="H5375"\w* \w el|strong="H5030"\w* cadáver del varón de \nd ʼElohim\nd*, lo colocó sobre \w el|strong="H5030"\w* \w asno|strong="H2543"\w* y lo \w llevó|strong="H5375"\w*. \w Y|strong="H3068"\w* \w el|strong="H5030"\w* \w profeta|strong="H5030"\w* \w anciano|strong="H2205"\w* fue \w a|strong="H3068"\w* la \w ciudad|strong="H5892"\w* \w a|strong="H3068"\w* hacer duelo por \w él|strong="H5030"\w* y sepultarlo.
\v 30 Depositó su cadáver \w en|strong="H5921"\w* su propio \w sepulcro|strong="H6913"\w*, \w lo|strong="H5921"\w* endecharon \w y|strong="H5921"\w* dijeron: ¡\w Ay|strong="H1945"\w*, hermano \w mío|strong="H5921"\w*!
