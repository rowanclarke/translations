\p 
\v 12 Joaquín, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*, \w salió|strong="H3318"\w* \w al|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Babilonia \w con|strong="H5921"\w* \w su|strong="H1931"\w* madre, \w sus|strong="H1931"\w* esclavos, \w sus|strong="H1931"\w* \w jefes|strong="H8269"\w* \w y|strong="H5921"\w* \w sus|strong="H1931"\w* funcionarios.
\p \w Así|strong="H1931"\w* \w que|strong="H1931"\w* \w el|strong="H1931"\w* \w año|strong="H8141"\w* octavo \w de|strong="H5921"\w* \w su|strong="H1931"\w* \w reinado|strong="H4427"\w*, \w el|strong="H1931"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Babilonia \w lo|strong="H1931"\w* \w tomó|strong="H3947"\w* cautivo.
