\id ROM
\h ROMANOS
\toc1 Si₂ carta a₂ca₂jmo₃ San Pablo ne₄ dsa₂ ROMANOS
\toc2 ROMANOS
\toc3 Ro.
\mt2 Si₂ carta a₂ca₂jmo₃ San Pablo ne₄ dsa₂
\mt1 ROMANOS
\c 1
\s1 Jmo₅ Pa₄ si₂ a₂chein₃ ne₄ Guá'₅ i₂chan₂ Roma
\p 
\v 1 Jniá₂ Pa₄, lɨ́ng₅ dsa₂ i₂jme₂ti₃ ne₄ Jesucristo; Diú₄ ca₂të₃ jniá₂, jaun₂ ca₂chei'₃ a₂léng₂ dsa₂ i₂chen₄ quiáin₅ ia₁jaun₂ qui₁'ë́₄ jág₁ dse₃ quió'₅.
\p 
\v 2 Ca₂'ë́₂ Diú₄ jág₁ dse₃ në₅ ca₂tó'₂ ne₄ Si₂ jŋió₅ quió'₅ ma₂lɨ́g'₂, ca₂cuë₃ të₂le₃ quian'₅₄ dsa₂ i₂jme₁'ë́₂ jág₁ quiáin₅,
\v 3 a₂'ɨin₂₃ ja₁ŋi'₅₄, i₂jme₁lɨ́n₄ tsɨ₁jon₂ David lia'₂ con'₂ lɨ́n₅ dsa₂ mɨ₂güɨ́g₃;
\v 4 lia'₂ con'₂ lë́₅ Jme₂dsí₂ Jŋió₅ në́₃ ca₂jme₃jnia₅ a₂lɨ́n₅ 'éi₂ Ja₁ŋi'₅₄ Diú₄ jme₁ca₂jein'₅₄ táng₃ jɨn₄ 'lag₄, quian'₅₄ juɨ₅bí₂ quió'₅, a₂'uain'₂. Jesucristo Te₁gui'₅₄ quián₂ jniog₄ bá₄ 'éi₂.
\v 5 Të₂le₃ quian'₅₄ Jesucristo, ton'₂ o₄quió'₄ 'éi₂ bá₄, ma₂jmo₃ Diú₄ dse₃ dsɨ́₅ ja₁con₂ jnia'₅₄, jaun₂ ca₂chei₃ jɨn₄ dsɨ₂nau₂ ia₁jaun₂ le₃chan₂ dsa₂ ca₂le₂con₂ juɨg₂ i₂jme₂ti₃ jág₁ quió'₅, ia₁ a₂'éin₂.
\v 6 Jɨn₄ dsa₂ 'éi₂ tián'₅ 'nia'₂ i₂ma₂të́'₃ Diú₄ ján₃, a₂lén'₂ 'nia'₂ i₂quián₅ Jesucristo.
\p 
\v 7 Jaun₂ tsɨ́ng₂ si₂ la₂ ne'₅₄ ca₂le₃jɨ́n'₃ 'nia'₂ i₂tián'₅ jë₄ juɨg₂ Roma, i₂lɨ́n₅ i₂'nio₃ Diú₄, jaun₂ ma₂të₂₃ a₂le₃chan'₂ 'nia'₂ lɨ́ng'₅ dsa₂ i₂lë́₅ 'í₁ i₂ma₂quiáin₅. Juɨ₁jme₂gu'₅₄ bá₄ Diú₄ juɨ₁le₂chan'₂ bá₄ 'nia'₂ dse₃, juɨ₁'ag₅₄ bá₄ tei₄ o₄quió'₄ Diú₄ Jmei₂ jniog₄, o₄quió'₄ Te₁gui'₅₄ Jesucristo në́₃.
\s1 'Nio₃ Pa₄ dsɨ₃jág₂ juɨg₂ Roma
\p 
\v 8 Jë₁le₂'uɨg₅₄, të₂le₃ quian'₅₄ Jesucristo cuë́₅ ti₁'mag'₄ Diú₄ quiáng₃ o₄quián'₂ 'nia'₂ ca₂le₃jɨ́ng'₃, ia₁ ca₂le₂con₂ bá₄ 'ei₅ jág₁ dsia₅ dsa₂ 'a₂ lia'₂ 'én'₂ 'nia'₂.
\v 9 Jaun₂ Diú₄, i₂jme₂tí₁ jniá₂ ne₄ ca₂le₃jë́₃ jme₂dsí₂ quió₃, a₂qui₂'ë́₅ jág₁ dse₃ quió'₅ Ja₁ŋi'₅₄, 'éi₂ bá₄ i₂lɨ́n₅ i₂jáng'₅ jág₁ dsau₅ 'a₂ lia'₂ dsau'₂ dsɨ₃ 'nia'₂ ca₂le₃jë́₃ jë₁chi₂lén'₂ jniá₂ Diú₄.
\v 10 Co₂tan₅₄ bá₄ mɨ₅ jniá₂ ne₄ Diú₄ juɨ₁le₅₄ bá₄ 'a₂ lia'₂ 'ŋio₂ dsɨ́₅, 'a₂ lia'₂ lé₂ a₂cuɨn₃ jmɨg₄, ca₂lia'₂ ca₂lë₃ a₂nei₅₄ i₁jɨng₁₂ 'nia'₂.
\v 11 Ia₁ 'ɨ́n₅ dsɨ₃ i₁jɨng₁₂ 'nia'₂, ton'₂ 'nio₃ jme₁'ong₁₂ 'e₂ caun₂ 'nió'₅ jme₁'ong₁₂ 'nia'₂ të₂le₃ quió'₅ jme₂dsí₂, ia₁jaun₂ le₃náu'₁ guë́₄ 'nia'₂ tiá₂;
\v 12 co₂'nió'₄ le₃jua'₅₄, ia₁jaun₂ lé₂ le₃cuë₅₄ lián'₂ rɨn'₅₄ le₂jau₂ le₂jau₂ quian'₅₄ a₂'éin₂ juɨ₁lia'₂ 'én'₂ 'nia'₂ juɨ₁lia'₂ 'én₂ jniá₂ ján₃.
\p 
\v 13 Rɨn'₅₄ jniog₄, 'nio₃ le₃ŋi'₅₄ 'nia'₂ 'lióng₂ ráun₂ bá₄ ma₂lë₅ dsɨ₃ a₂'nio₃ nei₅₄ i₁jɨng₁₂ 'nia'₂, la₁ ca₂lia'₂ jŋia'₅₄ rë₂në́₃ tsá₃ ma₂lë₅, ia₁ ma₂rë₂jnɨ₅ juɨ₅. 'Nio₃ nei₅₄ ia₁jaun₂ chi₁lo'₂ a₂ma₂rau₂ quió'₅ Jme₂dsí₂ jë₄ quián'₂ 'nia'₂, juɨ₁lia'₂ ma₂cag'₄ jniá₂ ján₃ juɨg₂ siá'₂, go₄ dsɨ₂nau₂ sián'₂ ján₃.
\v 14 Ia₁ jniá₂ bá₄ niog₅ ne₃ ca₂tɨ́ng₂ quian'₅₄ ca₂le₃jɨ́n₃, juɨ₁lɨ́n₄ dsa₂ 'e₂ lɨ́in₅, dsa₂ griego, o₃ dsɨ₂nau₂ 'e₂, dsa₂ i₂ŋɨ́'₂ dsɨ́₅, o₃ dsa₂ co₄ 'e₂;
\v 15 jaun₂ le₂në₅ bá₄ 'ɨ́n₅ dsɨ₃ a₂qui₂i₁'ë́₃ jág₁ dse₃ ja₁con₂ dsa₂ juɨg₂ go'₄ 'nia'₂ i₂chan₂ Roma ján₃.
\s1 Bí₂ a₂'io₅ jág₁ dse₃
\p 
\v 16 Ia₁ tsá₃ 'e₂ o₂guí'₃ jéin₅ jniá₂ quian'₅₄ jág₁ dse₃, ia₁ juɨ₅bí₂ quió'₅ Diú₄ bá₄ në₅ a₂lión₂ ca₂le₃jɨ́n₃ i₂'én₂: quió'₅ dsa₂ judíos de'₂ le₂'uɨg₅₄, ján₃ bá₄ le₂jaun₂ quió'₅ dsɨ₂nau₂.
\v 17 Ia₁ jág₁ dse₃ la₂ jáng'₅ jág₁ dsau₅ 'a₂ lia'₂ chei'₂ Diú₄ juɨ₅ co₂rë₂, juɨ₅ ja₁ma₂dsan₃ dsáu₁ dsa₂, juɨ₅ a₂jme₂lióg₃ a₂'én₂ dsa₂, ton'₂ a₂'én₂ dsa₂ ca₂lia'₂ jë₁ca₂tó'₂. Le₂në₅ juá'₂ ne₄ Si₂: “Dsa₂ i₂ŋɨ₅ juɨ₅ co₂rë₂ ia₁ a₂'éin₂, 'éi₂ bá₄ le₃chan₂.”\f + \fr 1:17 \ft Habacuc 2:4.\f*
\s1 A₂ma₂rë₂cán'₄ dsa₂ mɨ₂güɨ́g₃ guioin₅₄
\p 
\v 18 A₂juá'₅ jniá₂ le₂në₅, ia₁ a₂ne₄ bá₄ jniog₄ jaun₂, caun₂ jme₂jnia₅ Diú₄ a₂'nei₂ të₂ ja₁guá₄ guei'₅₄ i₂juɨ́G₃ ja₁con₂ dsa₂ i₂tsá₃ Diú₄ cuɨn₅, ja₁con₂ dsa₂ i₂tsá₃ tion'₅₄ juɨ₅ co₂dsau₅, dsa₂ i₂jnéi₅ juɨ₅ quió'₅ jág₁ dsau₅ të₂le₃ quian'₅₄ juɨ₅ 'lɨg'₅₄ ja₁i₂nioi₅₄.
\v 19 Ia₁ rë₂jniá₂ rë₂ bá₄ ca₂le₃jë́₃ a₂ŋi₅ dsa₂ 'a₂ lia'₂ lɨ́n₅ Diú₄, ia₁ a₂ma₂ca₂jme₃jniai₂₃ të₂le₃ quian'₅₄ a₂ma₂jmo₃,
\v 20 ia₁ ca₂le₃jë́₃ a₂tsá₃ rë₂jniá₂ quió'₅ Diú₄, lé₂ le₃cuɨ́'₅ dsa₂ të₂le₃ quian'₅₄ ca₂le₃jë́₃ a₂ma₂jmo₃; ma₂ca₂rë₃jniá₂ dse₃ lɨn₃ bá₄, ca₂le₃ ca₂jmo₃ Diú₄ mɨ₂güɨ́g₃ a₂lɨ́in₅ dsón'₂ Diú₄, ton'₂ a₂'io₂₃ juɨ₅bí₂ co₂tan₅₄ bá₄; jaun₂ le₂në₅ bá₄ tsá₃ ma₃'e₂ lé₂ le₃juá'₂ dsa₂ jua'₅₄ a₂tsá₃ ŋi₅.
\v 21 Ia₁ o₁jŋia'₅₄ ŋi₅ le₂në₅ a₂chan₂ Diú₄, la₁ tsá₃ ma₂ca₂jme₃juag'₂ lia'₂ con'₂ lë́₅ ca₂tɨ́n₂ Diú₄ le₃juɨin'₂, on₃ guë'₂ ma₂cuë́'₃ Diú₄ ti₁'mag'₄. Jë₂ bá₄ ma₂ja₂léin₂ qui₂'no'₂ dsɨ́₅ a₂tsá₃ ta₁ tí₄; tsá₃ të₂tsɨ'₅₄ dsɨ́₅, jaun₂ ma₂të₁'ŋiái₄ jë₄ qui₁né'₃.
\v 22 Juɨ₁'a₂ guë́₃ la₂ juá'₂ a₂lɨ́in₅ dsa₂ i₂cuɨ́'₅, a₂tɨin₂ a₂ŋi₅, la₁ dsa₂ co₄ bá₄ ca₂lɨin₃ jë₁ca₂tó'₂.
\v 23 Jaun₂ në́₃, 'nió'₄ a₂jme₁jme₃juɨin'₂ Diú₄ i₂tsá₃ ton₄ jmɨg₄ jón₂, ma₂ca₂jme₃tsɨ́in₃ bá₄ a₂co₂tág₅ co₂'né'₅ quió'₄ Diú₄ quian'₅₄ nió'₄ quió'₅ dsa₂ mɨ₂güɨ́g₃ i₂dsan₂, juɨ₁lia'₂ nió'₄ quió'₅ já'₂ i₂'ɨn₅, já'₂ i₂tsë́'₅ quió'₅, já'₂ i₂lë́₂ quén₂ mɨ₂tag₄ në́₃.
\p 
\v 24 'Uɨg₅₄ në₅ në́₃ co₂dsia₅ ma₂jáng'₄ Diú₄ juɨ₅ 'lɨg'₅₄ a₂'ɨ́n₅ dsɨ́₅ a₂tsá₃ le₁jë́₃, ia₁jaun₂ caun₂ i₃nioi₅₄ jmo₂₃-dsáu₅ cosa a₂o₂guí'₃ a₂jmái'₅ nɨ₁ŋɨ₁₂ quiain'₅₄ rɨin'₅₄ le₂jain₂ le₂jain₂,
\v 25 ia₁ ca₂jme₃tsɨ́in₃\f + \fr 1:25 \ft 'Nio'₂ ja₁ton₅ Jeremías 2.11.\f* jág₁ dsau₅ quió'₅ Diú₄ quian'₅₄ jág₁ të₂jág₁; jaun₂ ma₂ja₂léin₂ jme₂gó'₃ jme₂juɨin'₂ cosas a₂ca₂jmo₃ Diú₄, 'nió'₄ a₂jme₁jme₃juɨin'₂ Diú₄ 'ŋiog₅, i₂ca₂tɨ́n₂ dsón'₂ a₂jme₃juag'₂ dsa₂ co₂tan₅₄. ¡Le₂në₅ dsón'₂ bá₄! A₂méi₃.
\p 
\v 26 'Uɨg₅₄ në₅ co₂dsia₅ ma₂jáng'₂ juɨ₅ ja₁cuë́'₅ o₂'ŋió₃ o₂jŋia₃ dsɨ́₅ a₂lë́₅ o₂guí'₃, ia₁ ca₂le₂jiog₅ dsa₂ mɨ́₂ quiáin₅ bá₄ ca₂jme₃tsɨ́in₃ 'a₂ lia'₂ i₂nioi₅₄, a₂tsá₃ ma₃i₂nioi₅₄ lia'₂ con'₂ dsi₂ten₅₄ 'i₄ 'éi'₃ i₃nio₄ lia'₂ dsa₂ mɨ́₂ dsa₂ ŋe'₂.
\v 27 Ján₃ bá₄ guë'₂ le₂jaun₂ dsa₂ ŋe'₂ ma₂ca₂tí₂ bá₄ 'a₂ lia'₂ 'i₄ 'éi'₃ le₃chain₂ tiain'₃ quiain'₅₄ dsa₂ mɨ́₂; ma₂ja₂léin₂ chóg'₅ dséi₂ quiain'₅₄ dsa₂ ŋe'₂ rɨin'₅₄, jmo₂₃-dsáu₅ a₂o₂guí'₃ le₂jain₂ le₂jain₂, jaun₂ gue₂₃ uɨg₅ guioin₅₄ a₂ca₂tɨ́in₂ o₄quió'₄ juɨ₅ ja₁ca₂quiá₂ cau₅.
\p 
\v 28 Jaun₂, 'uɨg₅₄ ia₁ a₂lɨ́in₂ a₂tsá₃ 'e₂ quen₅ Diú₄, tsá₃ toin'₂ juɨ₅ 'éi₂, jaun₂ co₂dsia₅ ma₂jáng'₂ Diú₄ juɨ₅ ja₁dsɨ₂qui₂dsɨ₃jiog₅ dsɨ́₅ a₂'lɨg'₅₄, a₂dsɨ₂qui₂dsɨ₃cóin'₅ a₂'liain'₂, a₂jmo₃ a₂tsá₃ dsi₂ten₅₄.
\v 29 Ca₂lia'₂ qui₂rë₂rɨn₅ ca₂le₃jë́₃ ne₅₄ cosa 'lɨg'₅₄ jme₂dsí₂ quió'₅, qui₂'no₂₃ dso₄, jmá'₃ guioin₅₄ bá₄ 'nio₃ jme₁'ŋiói'₃, a₂qui₂'no'₂ dsɨ́₅ 'a₂ lia'₂ 'ë́'₃ uɨg₅ rɨin'₅₄. Rë₂can'₂ dsɨ́₅ a₂uɨg₅ dsɨ́₅ jɨ́in₂ rɨin'₅₄, a₂jme₂dsiain₂₃ rɨin'₅₄, a₂lë₁qui₂dsia₂₃ mɨ'₅₄, a₂qui₂jme₂gain₂₃ rɨin'₅₄, tsá₃ dsau₅ jág₁ quian₅, 'ŋio₅ 'ŋio₄ dsa₂, a₂co₂jmo₅ dsa₂ jág₁ të₂jág₁ jë₄ të₃co'₅₄.
\v 30 Ján₃ bá₄ le₂jaun₂ a₂lë₁chi₂'ag₅ dsa₂, 'ŋiai₅₄ bá₄ Diú₄, a₂lë₁co₂jmái'₂ rɨin'₅₄, a₂jme₂rón₂ guioin₅₄, dsia₂₃ jág₁ tá'₅, a₂qui₂'no'₂ dsɨ́₅ 'a₂ lia'₂ jmo₃ a₂'lɨg'₅₄, on₃ guë'₂ jmá'₃ jme₂gain₃ chog₅₄-jmei₂;
\v 31 tsá₃ të₂tsɨ'₅₄ dsɨ́₅ në́₃, on₃ guë'₂ jua'₅₄ jme₃ti₃ 'e₂ caun₂ jág₁ cuë₂₃ a₂jmo₃; tsá₃ 'ein₂ 'ɨin₂₃ 'i₁jan₂, tsá₃ tɨn₂ dsɨ́₅ 'éin₂ dso₄ quió'₅ rɨin'₅₄, on₃ guë'₂ ŋéi₂ dsɨ́₅.
\v 32 I₂ŋi₅ rë₂ bá₄ dsa₂ 'éi₂ 'a₂ lia'₂ lë́₅ 'éi'₃ ma₂quí'₃ Diú₄, ia₁ ca₂le₃jɨ́n₃ i₂jmo₅ le₂në₅ ca₂tɨ́in₂ dsiáin₃ bá₄; la₁ juɨ₁'e₂ guë́₃ ŋi₅ a₂jaun₂, on₃jua'₅₄ jmá'₃ guioin₅₄ caun₂ qui₂jmo₂₃, të₂le₃ të₅ dsɨ́₅ bá₄ a₂jmo₅ i₂sián'₂ ján₃.
\c 2
\s1 Diú₄ bá₄ con₂ 'í₁ co₂rë₂ 'a₂ lia'₂ con'₂ lë́₅ dsón'₂
\p 
\v 1 Jaun₂ në́₃, tsá₃ 'e₂ lé₂ le₃jua'₅₄ 'ne₂ jua'₅₄ a₂tsá₃ 'e₂ dso₄ rɨng'₂, 'ne₂ guë'₂ i₂con₂ 'í₁ ja₁con₂ i₂sián'₂, tsá₃ a₂nag₅₄ juɨ₁'ein₂ guë́₃ lɨ́ng'₅. Ia₁ në₁jua'₂ cáun'₂ 'í₁ ja₁con₂ rɨ́ng'₂, jaun₂ co₂'nió'₄ ma₂qui₂dsɨ́'₁ 'éi'₃ ja₁con'₂ 'ŋiag'₂, ton'₂ ján₃ bá₄ le₂jaun₂ jmo'₂ 'ne₂ 'ŋiag'₂ a₂cáun'₂ 'í₁ jaun₂.
\v 2 Ia₁ ne₄ bá₄ jniog₄ jaun₂, Diú₄ bá₄ i₂con₂ 'í₁ rë₂ 'a₂ lia'₂ con'₂ lë́₅ dsón'₂, ja₁con₂ dsa₂ i₂jmo₅ le₂në₅.
\v 3 Jaun₂ 'ne₂ në́₃ i₂cáun'₂ 'í₁ ja₁con₂ i₂sián'₂ ton'₂ a₂le₂jaun₂ bá₄ guë'₂ jmo'₂ 'ŋiag'₂, ¿'e₂ lɨ́ng'₂? ¿A₂lióng'₂ jë₁ma₂të́₂ rë₁con₂ Diú₄ 'í₁ ja₁cong'₂?
\v 4 ¿O₃ bá₄ tsá₃ dsáu₅ 'au'₂ ia₁ a₂ŋɨ́₄ lë₃ dse₃ 'ua₁ dsɨ́₅ Diú₄, a₂jmo₂₃ tió'₃ dsɨ́₅, a₂jme₂juɨin'₂ dsɨ́₅ në́₃? ¿Tsa₁ len'₅₄ 'ne₂, ta₁ a₂quí'₅ a₂dse₃ dsɨ́₅ Diú₄ a₂jaun₂ bá₄ jiog₂₃ a₂dsɨ₃quén'₅ 'au'₂?
\v 5 La₁ 'ŋio₅ 'ua'₂ 'au'₂ tsá₃ 'niog'₂ jme₁tsɨ́ng'₄ 'au'₂; 'uɨg₅₄ jaun₂ në́₃ caun₂ jme₁juɨ́'₁ bá₄ a₂jme₂'ne₅₄ Diú₄ ne₄ quiáng'₂ 'ŋiag'₂ a₂tɨng'₃ jmɨg₄ jaun₂ jë₁ma₂të́₂ rë₁jme₃jniai₂₃ a₂'nei₂, jë₁qui₃dsɨ₂₃ 'éi'₃ co₂rë₂.
\v 6 Ia₁ jma₃quén₅ qui₃ bá₄ Diú₄ 'lian'₅₄ le₂jan₂ le₂jan₂ 'a₂ lia'₂ con'₂ lë́₅ a₂ma₂ca₂jmo₃.\f + \fr 2:6 \ft 'Nio'₂ ja₁ton₅ Salmo 62:12; Proverbios 24:12.\f*
\v 7 Juɨ₁lia'₂ dsa₂ i₂jmo₅ tió'₃ dsɨ́₅ jmo₂₃ a₂dse₃, a₂qui₂'no'₂ a₂co₂tág₅ co₂'né'₅, ton'₂ 'no'₂ juɨ₅ 'a₂ lia'₂ jme₃gu'₅₄ Diú₄ quian'₅₄ caun₂ a₂dse₃, ton'₂ 'no'₂ juɨ₅ a₂tsá₃ dsiáin₃, 'éi₂ bá₄ cuë́'₃ Diú₄ a₂le₃chain₂ co₂tan₅₄.
\v 8 La₁ quian'₅₄ a₂'nei₂ cuë́'₃ uɨg₅ ca₂le₃jɨ́n₃ i₂dsia₅ mɨ'₅₄, i₂tsá₃ 'nio₃ cán₂ caun₂ juɨ₅ a₂nag₃ gau₂ jág₁ tí₅, i₂jmá'₃ juɨ₅ 'lɨg'₅₄ bá₄ 'nio₃ cán₂.
\v 9 Le₃cha₂ uɨg₅ o₂i₁ dsɨ₅ quió'₅ ca₂le₃jɨ́n₃ i₂jmo₅ a₂'lɨg'₅₄, jë₁le₂'uɨg₅₄ të₂le₃ quió'₅ dsa₂ judíos, ján₃ guë'₂ le₂jaun₂ le₃ja₁con₂ dsɨ₂nau₂.
\v 10 La₁ ja₁con₂ le₂jan₂ le₂jan₂ i₂jmo₅ a₂dse₃, cuë₃ Diú₄ a₂co₂tág₅ co₂'né'₅, ton'₂ cuë₃ caun₂ a₂dse₃, jmo₃ 'ei₅ tei₄, jë₁le₂'uɨg₅₄ quió'₅ dsa₂ judíos, ján₃ guë'₂ le₂jaun₂ le₃ja₁con₂ dsɨ₂nau₂.
\p 
\v 11 Ia₁ tsá₃ jma₃quén₅ jɨ́n₂ Diú₄ dsa₂ lia'₂ ca₂ton₂ ca₂ton₂;
\v 12 ia₁ ca₂le₃jɨ́n₃ i₂'no₅ dso₄ i₂tsá₃ ca₂tɨ́n₂ 'Éi'₃ quió'₅ Moisés, dsiáin₃ të₃ tsá₃ 'Éi'₃ jaun₂ ca₂tɨ́in₂; la₁ ján₃ guë'₂ le₂jaun₂ dsa₂ i₂'no₅ dso₄ në₁jua'₂ ron₅ bá₄ 'Éi'₃ quió'₅ Moisés në́₃, të₃dsɨ₅₄ bá₄ 'éi'₃ quió'₅, jióg'₂ 'í₁ lia'₂ con'₂ lë́₅ 'Éi'₃ jaun₂.
\v 13 Ia₁ on₃jua'₅₄ dsa₂ i₂nag₅ 'Éi'₃ i₂jɨ́n₂ Diú₄ a₂lɨ́in₅ dsa₂ i₂jme₂ti₃; dsa₂ i₂jmo₅ lia'₂ con'₂ lë́₅ 'Éi'₃ bá₄, i₂'éi₂ bá₄ i₂jɨ́n₂ Diú₄ a₂lɨ́in₅ dsa₂ i₂jme₂ti₃.
\v 14 Ia₁ juɨ₁lia'₂ dsɨ₂nau₂ në́₃, i₂tsá₃ 'Éi'₃ cha₂ ja₁coin₂, la₁ në₁jua'₂ chain₂ juɨ₅ a₂jme₂ti₃ con'₂ jaun₂ ma₂tɨn₂ dsɨ́₅, guion₅₄ bá₄ dsa₂ 'éi₂ ŋi₅ të₂dsɨ́₅ 'a₂ lia'₂ lë́₅ 'Éi'₃ quió'₅ Diú₄, o₁jŋia'₅₄ tsá₃ a₂jaun₂ ron₅ quió'₅.
\v 15 Ia₁ cuë₂₃ léi₄ 'a₂ lia'₂ lë́₅ chain₂, a₂rë₂ton₅ të₂dsɨ́₅ ta₁ a₂quí'₅ 'Éi'₃. Jaun₂ të₂dsɨ́₅ guioin₅₄ bá₄ jáng'₅ jág₁ dsau₅ o₄quió'₄, jaun₂ tsá₃ quɨn₅ 'a₂ lia'₂ dsɨ₂jiog₅ dsɨ́₅ guioin₅₄; a₂lɨn₅₄ jáng'₂, a₂lɨn₅₄ guë'₂ të₂le₃ lió₂.
\v 16 Le₂në₅ bá₄ lé₂ jë₁ma₂të́₂ jmɨg₄ jaun₂ a₂con₂ Diú₄ 'í₁ ca₂le₃jë́₃ a₂'ma₄ jlë₅ quió'₅ ca₂le₃jɨ́n₃ dsa₂, të₂le₃ quian'₅₄ Jesucristo, lia'₂ con'₂ lë́₅ jág₁ dse₃ a₂qui₂'ë́₅ jniá₂.
\s1 Dsa₂ judíos, quian'₅₄ 'Éi'₃ quió'₅ Moisés
\p 
\v 17 La₁ chi₂jua'₂ lɨ́n'₅ 'ne₂ dsa₂ judío jaun₂ dsia'₂ a₂chéng'₅ tiá₂ quian'₅₄ 'Éi'₃ quió'₅ Moisés, jaun₂ jmo'₂ táng'₅ ia₁ a₂cuɨng'₂ Diú₄;
\v 18 chi₂jua'₂ ma₂ca₂jme₃tɨn₅ dsa₂ 'ne₂ 'a₂ lia'₂ lë́₅ 'Éi'₃, jaun₂ ŋi'₅₄ 'a₂ lia'₂ 'nio₃ Diú₄, ton'₂ tɨng'₂ caun'₅₄ 'í₁ 'a₂ lia'₂ lë́₅ a₂dse₃;
\v 19 jaun₂ chi₂jua'₂ të₃dsón'₂ lɨ́ng'₂ a₂tɨng'₂ jang'₅₄ dsa₂ ten₄, chi₂jua'₂ ŋi'₅₄ 'a₂ lia'₂ téi'₄ si₂ ja₁con₂ dsa₂ i₂i₂nio₄ jë₄ qui₁né'₃,
\v 20 chi₂jua'₂ ŋi'₅₄ 'a₂ lia'₂ jme₁rë'₂ juɨ₅ a₂quian₅ dsa₂ co₄, chi₂jua'₂ ŋi'₅₄ 'a₂ lia'₂ cuë'₅₄ jág₁ i₂'nió'₄ i₂lɨ́n₅ chi'₂, ia₁ a₂ron₅ 'Éi'₃ ja₁cong'₂, a₂tén₅ ne₄ 'Éi'₃ 'a₂ lia'₂ 'nió'₅ le₃ŋi₅ dsa₂, 'a₂ lia'₂ lë́₅ jág₁ dsau₅;
\v 21 'ne₂ guë'₂ i₂jme₂tɨ́ng'₂ i₂sián'₂, ¿'e₂ guë'₂ 'uɨg₅₄ tsá₃ jme₂tɨ́ng'₁ guë'₂ 'ŋiag'₂? Chi₂jua'₂ 'ne₂ guë'₂ 'ë́'₅ jág₁ a₂tsá₃ ca₂tɨ́n₂ dsa₂ 'ang₃, ¿tsa₁ 'ang'₂ 'ŋiag'₂?
\v 22 Chi₂jua'₂ 'ne₂ juá'₂ tsá₃ ca₂tɨ́n₂ dsa₂ nió'₃ jág₁ quiain'₅₄ i₂tsá₃ lë́₅ dsɨ₂i₂gu₂, ¿tsa₁ nióg'₅ guë'₂ 'ne₂ jág₁ jaun₂ 'ŋiag'₂? Chi₂jua'₂ 'ne₂ 'ŋio₅ lɨn₃ 'ŋiag'₅₄ diú₄ lag₄, ¿tsa₁ 'ang'₂ 'ne₂ a₂quen₅ a₂te₁'i₁ dsi₂néi₂ 'né₅ quió'₅?
\v 23 'Ne₂ guë'₂ i₂jmo'₂ táng'₅ ja₁con₂ 'Éi'₃, ¿tsa₁ 'lɨg'₅₄ tsɨ́ng'₂ Diú₄ ia₁ tsá₃ jme₂tí'₁ 'Éi'₃ jaun₂?
\v 24 Ia₁ juɨ₁lia'₂ juá'₂ ne₄ Si₂:
\q1 'Ag₅ dsɨ₂nau₂ 'ɨin₂₃ 'lɨg'₅₄ Diú₄
\q2 'uɨg₅₄ quián'₂ 'nia'₂.\f + \fr 2:24 \ft Isaías 52:5; Ezequiel 36:22.\f*
\p 
\v 25 Dsón'₂ bá₄ dsau₅ quen₅ a₂ti₃ dsa₂ lo₅₄ në₁jua'₂ jme₂ti₃ 'Éi'₃ quió'₅ Moisés, la₁ në₁jua'₂ tsá₃ jme₂ti₃ dsa₂ në́₃, tsá₃ 'e₂ ta₁ jmo₃, në₂jag₄ bá₄ a₂tsá₃ 'e₂ rë₂uɨng₄ bá₄ quió'₅.
\v 26 Juɨ₁lia'₂ dsa₂ i₂tsá₃ 'e₂ ma₂rë₂uɨng₄ quió'₅, la₁ në₁jua'₂ jme₂ti₃ 'e₂ ta₁ quí'₅ 'Éi'₃, co₂jaun₂ bá₄ jɨ́n₂ Diú₄ dsa₂ 'éi₂ në₂jag₄ bá₄ i₂ma₂rë₂uɨng₄ quió'₅ o₁jŋia'₅₄ tsá₃ ma₂rë₂uɨng₄.
\v 27 Dsa₂ i₂tsá₃ 'e₂ rë₂uɨng₄ lo₄, la₁ në₁jua'₂ jme₂ti₃ 'a₂ lia'₂ juá'₂ 'Éi'₃, i₂'éi₂ bá₄ chen'₅ Diú₄ ne₄ juɨ₅ a₂con₂ 'í₁ ja₁con'₂ 'ne₂, ia₁ tsá₃ jme₂tí'₁, juɨ₁'e₂ guë́₃ ron₅ Si₂ tio'₅₄ 'Éi'₃ quiáng'₂, juɨ₁'e₂ guë́₃ rë₂uɨng₄ quiáng'₂ në́₃.
\v 28 Ia₁ juɨ₁lia'₂ jan₂ dsa₂ i₂lɨ́n₅ judío dsón'₂, on₃jua'₅₄ rë'₂ jŋia'₅₄ lɨ́n₅ dsa₂ léi₄ jmá'₃ le₃co'₅₄, on₃ guë'₂ le₂jaun₂ juɨ₁lia'₂ ta₁ dsón'₂ a₂quí'₅ a₂qui₂rë₂uɨng₄ lo₄ dsa₂, on₃jua'₅₄ jŋia'₅₄ rë₂uɨng₄ lɨ́in₅ léi₄ jmá'₃ le₃co'₅₄ nɨ₁ŋɨ́₅.
\v 29 Të₂le₃ a₂ca₂tɨ́n₂ bá₄ dsa₂ jmo₃, a₂lɨ́in₅ të₃dsón'₂ dsa₂ judío, a₂lɨ́in₅ ca₂të₂ dsɨ́₅; ján₃ guë'₂ le₂jaun₂ juɨ₁lia'₂ a₂lɨ́n₅ dsa₂ léi₄ a₂rë₂uɨng₄ quió'₅, a₂lë́₅ ca₂të₂ dsɨ́₅ bá₄ dsa₂; ton'₂ a₂gu₂dsí₂ bá₄ a₂jaun₂, on₃jua'₅₄ jmá'₃ lia'₂ con'₂ le₁ton₅ ne₄ Si₂ 'Éi'₃. Dsa₂ i₂lɨ́n₅ le₂në₅ chéin'₅ rë₂ quian'₅₄ Diú₄, on₃jua'₅₄ rë'₂ quiain'₅₄ dsa₂ mɨ₂güɨ́g₃.
\c 3
\p 
\v 1 Jaun₂ në́₃, ¿'e₂ ta₁ jmo₅ a₂quen₅ guë́₄ a₂lɨ́n₅ dsa₂ dsa₂ judío? ¿O₃ 'e₂ ta₁ jmo₅ a₂lɨ́n₅ dsa₂ léi₄ a₂rë₂uɨng₄ nɨ₁lo₁₂?
\v 2 'Lióng₂ bá₄ 'uɨg₅₄ cha₂. Jë₁le₂'uɨg₅₄, ca₂dsia₃ Diú₄ jág₁ dse₃ quió'₅ o₄gú₃ dsa₂ judíos.
\v 3 ¿La₁ 'e₂ bá₄ lé₂ në́₃ në₁jua'₂ chan₂ i₂lɨn₅₄ i₂tsá₃ ca₂rë₃ti'₅₄?\f + \fr 3:3 \ft o₃, “i₂tsá₃ ca₂rë₃'én₂.” \f* ¿O₃ bá₄ lɨ́n'₂ 'nia'₂ ján₃ a₂tsá₃ le₃ti'₅₄ Diú₄ jág₁ quió'₅ ia₁ a₂tsá₃ ca₂rë₃ti'₅₄ dsa₂ 'éi₂?
\v 4 ¡Dsón'₂ bá₄ tsá₃ le₂jaun₂! Juɨ₁le₂lei₅₄ bá₄ jniog₄, Diú₄ në́₃ jmo₃ bá₄ ca₂le₃jë́₃ lia'₂ con'₂ lë́₅ jág₁ tí₅ quió'₅, juɨ₁'e₂ guë́₃ ca₂le₃jɨ́n₃ dsa₂ tsá₃ tí₅ jág₁ quió'₅; ia₁ ne₄ Si₂ juá'₂:
\q1 ia₁jaun₂ le₃lí'₄ dsa₂ a₂lɨ́ng'₅ i₂dsen₃
\q2 juɨ₁lia'₂ jë₁dsia'₂ jág₁,
\q1 ia₁jaun₂ bá₄ léng'₂
\q2 jë₁ma₂të́₂ rë₁con₂ dsa₂ 'í₁ ja₁cong'₂.\f + \fr 3:4 \ft Salmo 51:4.\f*
\p 
\v 5 La₁ në₁jua'₂ tí₅ ta₁ dsáu₁ jniog₄ a₂rë₂jniá₂ Diú₄ a₂lɨ́in₅ i₂dsen₃, ¿'e₂ le₃jua'₅₄ jniog₄ në́₃? ¿'An₁ tsá₃ rë₂ qui₃dsɨ₅ Diú₄ 'éi'₃ në₁jua'₂ ca₂rë₃'néi₃ 'ë́₂ uɨg₅ ja₁con₂ jniog₄? (A₂lë₁juá'₅ jniá₂ lia'₂ jë₁juá'₂ dsa₂ mɨ₂güɨ́g₃ bá₄.)
\v 6 ¡Dsón'₂ bá₄ on₃jua'₅₄ le₂në₅! Ia₁ jua'₅₄ mei'₂ guë́₃ tsá₃ rë₂ qui₂dsɨ₅ Diú₄ 'éi'₃, ¿'a₂ bá₄ lia'₂ le₃con₂ 'í₁ ja₁con₂ dsa₂ mɨ₂güɨ́g₃?
\p 
\v 7 La₁ në₁jua'₂ jág₁ të₂jág₁ quió₃ tí₅ ta₁ ia₁jaun₂ lë́₅ a₂rë₂jniá₂ guë́₄ jág₁ dsau₅ quió'₅ Diú₄ ia₁jaun₂ të₂le₃ dse₃ guë́₄ chéin'₅, ¿'e₂ lë₃ qui₂dsɨ₅ Diú₄ 'éi'₃ a₂rɨn₂ jniá₂ dso₄?
\v 8 ¿Ja₁lɨn₃ guë́₄ dse₃ jua'₅₄ caun₂ a₂jmo₅₄ a₂'lɨg'₅₄, ia₁jaun₂ jiá₃ a₂dse₃? A₂le₂në₅ bá₄ chi₂'ag₅ i₂lɨn₅₄ 'ag₂₃ jnia'₅₄ a₂jme₂tɨ́n₂ jnia'₅₄ dsa₂. La₁ gue₃ bá₄ uɨg₅ dsa₂ i₂dsɨ₂jiog₅ dsɨ́₅ le₂në₅ 'a₂ con'₂ ca₂tɨ́in₂.
\s1 Ca₂le₃jág₃ bá₄ jniog₄ rë₂cáu'₄ dso₄
\p 
\v 9 ¿'E₂ jaun₂ në₃? ¿A₂dse₃ guë́₄ tióng₂ jnia'₅₄ dsa₂ judíos? ¡Dsau₅ bá₄ on₃jua'₅₄ le₂jaun₂! Ia₁ ma₂të₂tsɨ'₅₄ jág₁, co₂jaun₂ bá₄ dsa₂ judíos con'₂ dsɨ₂nau₂, caun₂ bá₄ juɨ₅ tioin'₅₄ 'uɨg₅₄ dsáu₁.
\v 10 Lë́₅ juɨ₁lia'₂ juá'₂ ne₄ Si₂:
\q1 Ca₂lia'₂ 'i₁jan₂ dsa₂ tsá₃ chan₂
\q2 i₂jme₂ti₃ 'Éi'₃ quió'₅ Diú₄,
\q2 ca₂lia'₂ 'i₁jan₂ tsá₃ chan₂;
\q1 
\v 11 tsá₃ i₂chan₂ jua'₅₄ i₂ŋɨ́'₂ dsɨ́₅,
\q2 'i₁jan₂ tsá₃ chan₂ jua'₅₄ i₂'nio₃ 'na'₂ Diú₄.
\q1 
\v 12 Ca₂le₃jɨ́n₃ bá₄ ma₂i₂nio₄ cau₅ juɨ₅ ma₂i₂cóin'₅,
\q2 co₂dsia₅ bá₄ ma₂i₃léin₂ juɨ₅ ja₁tsá₃ ta₁ tí₄.
\q1 Tsá₃ 'ein₂ chan₂ ca₂lia'₂ 'i₁jan₂
\q2 jua'₅₄ i₂qui₂jmo₅ a₂dse₃,
\q2 ca₂lia'₂ 'i₁jan₂ tsá₃ chan₂.\f + \fr 3:12 \ft Salmo 14:1-3; 53:1-3; Eclesiastés 7:20.\f*
\q1 
\v 13 'Uë́'₅ jág₁ 'lɨg'₅₄ le₂'o₅₄
\q2 juɨ₁lia'₂ ja₂ dsí₂ 'lɨg'₅₄ a₂'uë́'₅ tau₂ 'ŋio₅ a₂rë₂na₄;
\q1 quian'₅₄ le₁tsɨ'₂ jmo₂₃ a₂juɨ₁gain₂.\f + \fr 3:13 \ft Salmo 5:9.\f*
\q2 Në₂jag₄ bá₄ náu₁ dsɨ₂mɨ'₂ 'a₄ mɨ₂'o₅₄;\f + \fr 3:13 \ft Salmo 140:3.\f*
\q1 
\v 14 Jmá'₃ caun₂ a₂jaun₂ bá₄ juá'₂ dsa₂,
\q2 a₂uɨg₅ dsɨ́₅, a₂jme₃dsi'₃ ja₁con₂ rɨin'₅₄;\f + \fr 3:14 \ft Salmo 10:7.\f*
\q1 
\v 15 Ma₂në₃ bá₄ i₂ŋɨi₂₃ cán₂ tag₅₄
\q2 a₂dsɨ₃jme₁dsiain₂₃ rɨin'₅₄.
\q1 
\v 16 Léi₄ jë₁ca₂ŋɨi₅ ca₂quiog₂ caun₂ juɨ₅ a₂o₂i₁ dsɨ₅,
\q2 ja₁i₃'én₂ 'a₂ lia'₂ chan₂ dsa₂;
\q1 
\v 17 ia₁ tsá₃ cuɨ́'₅ dsa₂ 'éi₂ juɨ₅ 'ei₅ tei₄;\f + \fr 3:17 \ft Isaías 59:7-8.\f*
\q1 
\v 18 Tsá₃ a₂jaun₂ dsɨ₂jiog₅ dsɨ́₅
\q2 jua'₅₄ a₂gain₃ Diú₄.\f + \fr 3:18 \ft Salmo 36:1.\f*
\p 
\v 19 A₂ne₄ bá₄ jniog₄, ca₂le₃jë́₃ jág₁ a₂tio'₅₄ ne₄ Si₂ 'Éi'₃ quió'₅ Diú₄, a₂juá'₂ tsɨ́'₅ ca₂le₃jɨ́n₃ i₂ca₂tɨ́n₂ 'Éi'₃ jaun₂, ia₁jaun₂ jmo₃ tei₄ mɨ₂'o₄ ca₂le₃jɨ́n₃, ia₁jaun₂ ca₂le₃jɨ́n₃ dsa₂ mɨ₂güɨ́g₃ të₃tsɨin'₅₄ rë₂cáin'₄ ne₄ Diú₄.
\v 20 Ia₁ ca₂lia'₂ 'i₁jan₂ tsá₃ 'ein₂ jɨ́n₂ Diú₄ a₂tsá₃ dso₄ rë₂cáin'₄ jua'₅₄ a₂jme₃ti₃ a₂juá'₂ 'Éi'₃, ia₁ 'ŋiog₅ bá₄ 'Éi'₃ quí'₅ ta₁ a₂le₃ne₄ jniog₄ a₂lág₅ dsa₂ cha₂ dsáu₁.
\s1 A₂lión₂ dsa₂ të₂le₃ a₂jŋia'₅₄ quian'₅₄ a₂'éin₂ bá₄
\p 
\v 21 La₁ në₃ në́₃, ma₂ca₂jme₃jnia₅ bá₄ Diú₄ juɨ₅ a₂tsá₃ ma₃dso₄ rë₂cáu'₄ jniog₄, on₃jua'₅₄ të₂le₃ quian'₅₄ Si₂ 'Éi'₃, juɨ₁'e₂ guë́₃ jáng'₅ jág₁ dsau₅ juɨ₅ jaun₂ a₂juá'₂ ne₄ Si₂ tio'₅₄ 'Éi'₃, quian'₅₄ Si₂ a₂qui₂ca₂jmo₃ dsa₂ i₂jme₁'ë́₂ jág₁ quián₅ Diú₄ në́₃.
\v 22 Jáng'₅ jág₁ dsau₅ juɨ₅ dse₃ quió'₅ Diú₄ a₂tsá₃ dso₄ rë₂cán'₄ dsa₂, jŋia'₅₄ lia'₂ të₂le₃ quian'₅₄ a₂'éin₂ të₂le₃ quió'₅ Jesucristo; tsá₃ jma₃quén₅ jmo₂₃ ja₁con₂ juɨ₁'ein₂ guë́₃;
\v 23 ia₁ ca₂le₃jɨ́n₃ bá₄ ma₂qui₂ma₂'náu₂ dso₄, jaun₂ uɨ́ng₂ lɨn₃ bá₄ tióin₂ ja₁qui₂tág₅ co₂'né'₅ quió'₅ Diú₄.
\v 24 La₁ Diú₄ në́₃, ia₁ a₂'ua₁ dsɨ́₅ bá₄ 'ë́₂ jág₁ a₂tsá₃ dso₄ rë₂cáin'₄, on₃jua'₅₄ a₂'nió'₅ quí₃ 'lia'₅₄. A₂lë₁lió₂ bá₄ të₂le₃ quian'₅₄ Cristo Jesús i₂ca₂quí₃ o₄quió'₄ dsáu₁ dsa₂.
\v 25 Ca₂chen'₃ Diú₄ ja₁ŋi'₅₄ ia₁jaun₂ dsian₅ dsáu₁ dsa₂ mɨ₂güɨ́g₃ quian'₅₄ jmɨ₂ 'ain₅₄ a₂ca₂tein₃. A₂lë₁gue₅ bá₄ dsa₂ a₂jaun₂ jmá'₃ të₂le₃ quian'₅₄ a₂'éin₂. Le₂në₅ ca₂rë₃jniá₂ Diú₄ i₂lɨ́n₅ i₂qui₃dsɨ₅ 'éi'₃ rë₂, ia₁ a₂ma₂ca₂jme₃juɨin'₂ dsɨ́₅ a₂ma₂ca₂ŋág₃ bá₄ dsáu₁ dsa₂ a₂jme₁'no₂₃ ma₂lɨ́g'₂.
\v 26 Le₂në₅ ca₂jmo₃ Diú₄ a₂ca₂jme₃jniai₂₃ a₂rë₂ qui₃dsɨ₂₃ 'éi'₃, a₂ca₂jme₃jniai₂₃ a₂jɨ́in₂ dsa₂ i₂'én₂ të₂le₃ quió'₅ Jesús në₂jag₄ bá₄ a₂ca₂jme₃ti₃.
\p 
\v 27 ¿'E₂ bá₄ ca₂lë₃ jaun₂ në́₃ quian'₅₄ a₂jmo₅ dsa₂ táin'₅? Co₂dsia₅ të₂tsɨ'₅₄ cau₅ bá₄ a₂jaun₂. ¿'E₂ 'uɨg₅₄? ¿'An₁ 'uɨg₅₄ a₂jme₃ti₃ dsa₂ 'Éi'₃? Jan₂'ón₄. 'Uɨg₅₄ ia₁ a₂'én₂ bá₄ dsa₂.
\v 28 Ma₂në₂quiong₅₄ bá₄ jniog₄ 'í₁ jaun₂ në́₃, a₂jɨ́n₂ Diú₄ dsa₂ në₂jag₄ bá₄ a₂ca₂jme₃ti₃, 'uɨg₅₄ ia₁ a₂'éin₂, jaun₂ tsá₃ 'e₂ 'í₁ con₂ guë́₄ jua'₅₄ a₂ca₂jme₃ti₃ o₃ tsá₃ ca₂jme₃ti₃ 'e₂, con'₂ lë́₅ 'Éi'₃.
\p 
\v 29 ¿O₃ bá₄ lɨ́n₅ Diú₄ ca₂ne₅₄ jmá'₃ i₂quián₅ dsa₂ judíos? ¿On₁jua'₅₄ i₂quián₅ dsɨ₂nau₂ ján₃? Ján₅. I₂quián₅ 'éi₂ bá₄ ján₃,
\v 30 ia₁ jan₂ tan₅₄ bá₄ Diú₄ chan₂; jaun₂ 'éi₂ bá₄ jág₃ jɨ́n₂ dsa₂ i₂rë₂uɨng₄ nɨ₁lo₁ në₂jag₄ bá₄ a₂ca₂jme₂ti₃, 'uɨg₅₄ ia₁ a₂'éin₂; ján₃ bá₄ le₂jaun₂ jág₃ jɨ́in₂ dsa₂ i₂tsá₃ rë₂uɨng₄ nɨ₁lo₁ në₂jag₄ bá₄ a₂ca₂jme₃ti₃, o₄quió'₄ a₂'éin₂.
\v 31 ¿'E₂ jua'₂ jniog₄ jaun₂ në́₃? ¿A₂tsá₃ ta₁ tí₄ 'Éi'₃ ia₁ a₂'éin₂ jniog₄? ¡Dsón'₂ tsá₃ le₂jaun₂! 'Nió'₄ të₂le₃ cuë₂ bá₄ jniog₄ bí₂ a₂quen₅ 'Éi'₃.
\c 4
\s1 'A₂ lia'₂ të₂tsɨn'₅₄ Abraham ne₄ Diú₄
\p 
\v 1 ¿'E₂ lé₂ le₃jua'₅₄ jniog₄ jaun₂ në́₃? ¿'E₂ ca₂dsó'₂ Abraham dsa₂ juɨn'₂ quián₂ jnia'₅₄ ma₂lɨ́g'₂, lia'₂ jme₁lɨ́in₄ dsa₂ mɨ₂güɨ́g₃?
\v 2 Jua'₅₄ mei'₂ guë́₃ Diú₄ ca₂chi'₃ jág₁ jua'₅₄ a₂dsen₃ 'éi₂ të₂le₃ quian'₅₄ 'e₂ a₂ca₂jmo₃, jua'₅₄ a₂ca₂jme₃ti₃ 'Éi'₃, jaun₂ jme₁cha₂ juɨ₅ a₂jme₁jmo₃ róin₂. La₁ on₃jua'₅₄ ne₄ Diú₄.
\v 3 Jaun₂, ¿'e₂ juá'₂ ne₄ Si₂? “Ca₂rë₃'én₂ bá₄ Abraham jág₁ ca₂cuë₃ Diú₄; jaun₂ 'uɨg₅₄ ia₁ a₂ca₂rë₃'éin₂ jaun₂ në́₃, ca₂guéi'₂ Diú₄ në₂jag₄ bá₄ a₂ca₂jme₃ti₃.”\f + \fr 4:3 \ft Génesis 15:6. Ján₃ bá₄ le₂në₅ \f*
\v 4 Jaun₂ në́₃, juɨ₁lia'₂ jan₂ dsa₂ i₂jme₂ti₃ ta₁ quió'₅ jan₂ juɨg₅₄, cu₄ a₂lɨ́'₂ jaun₂ quió'₅, on₃jua'₅₄ a₂lë₁cuë₃ juɨg₅₄, ia₁ a₂ma₂rɨin₂₃ quió'₅ 'éi₂ 'lia'₅₄ ta₁ quió'₅.
\v 5 La₁ në₁jua'₂ 'ein₂ të₃tsá₃ 'e₂ jmo₂₃, 'éin₂ a₂guén'₅ Diú₄ dsa₂ i₂cha₂ dsáu₁, Diú₄ guéi'₂ quió'₅ në₂jag₄ bá₄ dsa₂ dsen₃, o₄quió'₄ a₂'éin₂.
\v 6 'Ŋiog₅ bá₄ David juá'₂ a₂dsen₃ juɨ₁lia'₂ dsa₂ i₂guéi'₂ Diú₄ në₂jag₄ bá₄ a₂tsá₃ ma₂'e₂ dsáu₁ cha₂, tsá₃ 'e₂ 'í₁ con₂ Diú₄ 'a₂ lia'₂ ca₂jme₃ti₃.
\v 7 Ca₂juá'₂ David:
\q1 'E₂ guë́₄ dsen₃ juɨ₁lia'₂ dsa₂ i₂ca₂'én₂ Diú₄ dsáu₁,
\q2 i₂ca₂jlë́₂ Diú₄ dso₄ a₂ca₂'náu₂.
\q1 
\v 8 'E₂ guë́₄ dsen₃ dsa₂ i₂ca₂jmo₃ Te₁gui'₅₄ dsɨ́₅
\q2 a₂tsá₃ dso₄ rɨin₂.\f + \fr 4:8 \ft Salmo 32:1-2.\f*
\p 
\v 9 A₂dse₃ në₅ në́₃, ¿a₁dse₃ jmá'₃ lia'₂ ca₂ne₅₄ quió'₅ dsa₂ i₂rë₂uɨng₄ nɨ₁lo₁, o₃ bá₄ le₂jiog₅ a₂dse₃ quió'₅ i₂tsá₃ 'e₂ rë₂uɨng₄ quió'₅ bá₄ ján₃? Ma₂në₂jua'₅₄ jnia'₅₄ a₂ca₂guén'₂ Diú₄ Abraham në₂jag₄ bá₄ a₂ca₂jme₃ti₃ 'éi'₃, 'uɨg₅₄ ia₁ a₂'éin₂.
\v 10 ¿'A₂ lia'₂ jme₁lɨ́n₄ Abraham lia'₂ con'₂ ca₂guéi'₂ jaun₂? ¿Ca₂guéi'₂ cang₂ lia'₂ con'₂ jme₁ma₂ti₃ Abraham quió'₅, o₃ le₂jŋiá₅ 'e₂? Le₂jŋiá₅ bá₄, on₃jua'₅₄ cang₂.
\v 11 Cang₂ jaun₂ bá₄ ca₂gue₃ Abraham 'éi'₃ jaun₂ a₂ti₃ nɨ₁lo₁₂, a₂lɨ́in₅ léi₄ co₂'nió'₄ caun₂ sello quió'₅ Diú₄ a₂ma₂guéi'₂, në₂jag₄ bá₄ dsa₂ i₂ca₂jme₃ti₃, 'uɨg₅₄ ia₁ a₂'éin₂. Le₂në₅ bá₄ ca₂dsióg₃ Abraham a₂ca₂lɨin₃ cho'₅₄ ca₂le₃jɨ́n₃ i₂'én₂ ján₃, o₁jŋia'₅₄ tsá₃ ma₂gue₃ 'éi'₃ jaun₂ a₂uɨ́ng₃ quió'₅. Jaun₂ le₂në₅ bá₄ guén'₂ Diú₄ ján₃ dsa₂ tsɨ₁jon₂ 'éi₂ në₂jag₄ bá₄ a₂lɨ́in₅ dsa₂ i₂ca₂jme₃ti₃.
\v 12 Dsau₅ bá₄ a₂lɨ́n₅ Abraham cho'₅₄ ca₂le₃jɨ́n₃ i₂ma₂gue₃ 'éi'₃ jaun₂ a₂uɨ́ng₃ quió'₅, la₁ on₃jua'₅₄ jmá'₃ 'uɨg₅₄ ia₁ a₂rë₂uɨng₄ quió'₅; ján₃ bá₄ 'uɨg₅₄ ia₁ a₂quian₅ juɨ₅ a₂'éin₂ jaun₂, juɨ₁lia'₂ ca₂can₃ Abraham jmei₂ jnia'₅₄ lia'₂ con'₂ tsá₃ ma₂uɨng₂ quió'₅.
\s1 Të₂le₃ quian'₅₄ a₂'én₂ bá₄ dsa₂ jme₃ti₃ Diú₄ jág₁ quió'₅ a₂ma₃cuë₃
\p 
\v 13 Jaun₂ ca₂cuë₃ Diú₄ jág₁ quió'₅ ca₂cuë́'₃ Abraham quiain'₅₄ chi'₂-guein₂ quiáin₅, a₂gue₃ gua'₅₄ 'uë₃ a₂cuë₃ Diú₄; la₁ on₃jua'₅₄ ia₁ a₂ca₂jme₃ti₃ Abraham 'Éi'₃, të₂le₃ ia₁ a₂caun₂ 'éin₂ jág₁ a₂cuë₅ Diú₄, ton'₂ ca₂guéi'₂ Diú₄ në₂jag₄ bá₄ a₂ca₂jme₃ti₃ 'Éi'₃.
\v 14 Jua'₅₄ mei'₂ guë́₃ jmá'₃ i₂jme₂ti₃ 'Éi'₃ bá₄ gue₅ a₂dse₃ a₂cuë₅ Diú₄ cuë́'₅ chi'₂-guein₂ quiáin₅, jaun₂ tsá₃ ma₃'e₂ ta₁ tí₄ a₂'én₂ dsa₂, ton'₂ ján₃ guë'₂ le₂jaun₂ jág₁ a₂cuë́₄ quió'₅ Diú₄ tsá₃ ma₃quen₅.
\v 15 Ia₁ juɨ₅ a₂'ne₂ Diú₄ bá₄ jiog₅ 'Éi'₃, la₁ ja₁tsá₃ 'Éi'₃ ca₂tɨ́n₂, tsá₃ 'ein₂ dsɨ₂juɨn₅₄ ja₁jaun₂.
\p 
\v 16 'Uɨg₅₄ jaun₂, o₄quió'₄ a₂'én₂ dsa₂ cuë₅ Diú₄ a₂dse₃ cuë́'₅ chi'₂-guein₂ quiáin₅, ia₁jaun₂ chi'₃ tiá₂ jág₁ a₂cuë́₄ ne₄ a₂'ua₁ dsɨ́₅, ia₁jaun₂ dsón'₂ jaun₂ bá₄ jág₁ a₂gue₃ ca₂le₃jɨ́n₃ tsɨ₁jon₂ Abraham, on₃jua'₅₄ jmá'₃ quió'₅ dsa₂ i₂qui₂rë₂ti'₅₄ 'Éi'₃; quió'₅ ca₂le₃jɨ́n₃ i₂'én₂ bá₄ ján₃ juɨ₁lia'₂ jme₁'én₂ Abraham. Jaun₂ 'éi₂ bá₄ já₅ co₂'nió'₄ lɨ́in₅ jmei₂ jniog₄ ca₂le₃jág₃.
\v 17 Juɨ₁lia'₂ juá'₂ ne₄ Si₂: “'Ne₂ ma₂tsɨ́n'₂ jniá₂ a₂lɨ́ng'₅ cho'₅₄ dsa₂ chan₂ 'lióng₂ juɨg₂ nación.”\f + \fr 4:17 \ft Génesis 17:5.\f* Jaun₂ 'éi₂ bá₄ i₂lɨ́n₅ jmei₂ jniog₄ ne₄ Diú₄, ton'₂ ca₂'éin₃ jág₁ quió'₅ Diú₄ 'éi₂ i₂ton'₂ jme₂dsí₂ dsa₂ i₂ma₂dsan₃, ján₃ guë'₂ të́'₂ a₂tsá₃ ma₂cha₂ në₂jag₄ bá₄ a₂ma₂cha₂.
\p 
\v 18 Juɨ₁'e₂ guë́₃ tsá₃ ma₃'e₂ jmɨg₄ jme₁ma₃cha₂ ja₁con₂ Abraham lia'₂ con'₂ lë́₅ lɨ́n₂ dsa₂ mɨ₂güɨ́g₃, të₂le₃ ia₁ a₂ca₂rë₃'éin₂ jág₁ quió'₅ Diú₄, ca₂dsióg₃ “a₂lɨ́in₅ jmei₂ dsa₂ chan₂ 'lióng₂ juɨg₂”, lia'₂ con'₂ lë́₅ ca₂juá'₂ Diú₄: “co₂në₅ tén₅ chi'₂-guein₂ dsió'₂ lé₂.”\f + \fr 4:18 \ft Génesis 15:5.\f*
\p 
\v 19 Juɨ₁'e₂ guë́₃ jme₁ma₂'en₅₄ Abraham con'₂ 'ŋiá₂-láu₂ ŋi₂, lí'₄ bá₄ 'ŋiog₅ a₂ma₂guen'₂ nɨ₁ŋɨ₁₂, ján₃ guë'₂ le₂jaun₂ Sara quiáin₅ në́₃ co₂në₅ a₂ma₂chain₂ dsiáin₃ bá₄, tsá₃ ma₃'ein₂ guein₂ lé₂ le₃cáin₂, la₁ tsá₃ ca₂'uáin₂ quian'₅₄ jág₁ a₂ma₂chan'₂.
\v 20 Tsá₃ ca₂'ág₂ caun₂-tɨn₃ dsɨ́₅ jua'₅₄ a₂tsá₃ 'éin₂ jág₁ a₂ca₂cuë₃ Diú₄, të₂le₃ ca₂i₃tsón₂ bá₄ bí₂ a₂'éin₂, ton'₂ ca₂jme₃juɨin'₂ Diú₄,
\v 21 caun₂ bá₄ 'ei₅ dsɨ́₅ a₂'io₅ Diú₄ juɨ₅bí₂ a₂jme₃ti₃ jág₁ quió'₅ a₂ca₂cuë₃.
\v 22 'Uɨg₅₄ jaun₂ ca₂guéi'₂ Diú₄ në₂jag₄ dsa₂ i₂ca₂jme₃ti₃.
\p 
\v 23 Jág₁ në₅, “a₂ca₂guéi'₂ Diú₄”, ca₂i₃to'₅₄ ne₄ si₂, on₃jua'₅₄ a₂'ɨin₂₃ jmá'₃ Abraham;
\v 24 a₂'ag₂₃ jniog₄ bá₄ ján₃. 'Uɨg₅₄ ia₁ a₂'éin₂ jniog₄, guéi'₂ Diú₄ a₂lág₅ jniog₄ në₂jag₄ bá₄ dsa₂ dsen₃ i₂ca₂jme₃ti₃ con'₂ i₂'én₂ të₂le₃ quió'₅ Diú₄ i₂ca₂jme₃jen'₅₄ Jesús jɨn₄ 'lag₄. Jesús bá₄ i₂lɨ́n₅ Te₁gui'₅₄ quián₂ jniog₄,
\v 25 i₂ca₂jɨ́n'₂ dsa₂ a₂jóin₂ ne₄ 'uɨg₅₄ dsáu₁ jniog₄, con'₂ siá'₂ ca₂jein'₅₄ táng₃ ia₁jaun₂ guéi'₂ Diú₄ jniog₄ në₂jag₄ dsa₂ dsen₃ i₂ca₂jme₃ti₃.
\c 5
\s1 Lé₂ le₃chong₂ jniog₄ 'ei₅ tei₄ quian'₅₄ Diú₄
\p 
\v 1 Le₂në₅ jaun₂, ia₁ a₂ma₂'ë́₂ Diú₄ jág₁ a₂tsá₃ 'e₂ dso₄ rë₂cáu'₄ jniog₄, 'uɨg₅₄ ia₁ a₂'éin₂, ma₂chong₂ jniog₄ 'ei₅ tei₄ quiain'₅₄, të₂le₃ quian'₅₄ Te₁gui'₅₄ Jesucristo quián₂.
\v 2 Ia₁ të₂le₃ quian'₅₄ Cristo 'éi₂ bá₄ ma₂i₁to'₅₄ jniog₄ ja₁jme₂gu'₅₄ Diú₄ ia₁ a₂'ua₁ dsɨ́₅, të₂le₃ ia₁ a₂'éin₂. Ja₁dse₃ në₅ në́₃, tióng₂ jniog₄ tiá₂ 'io'₂ jein₂, ia₁ 'ɨ́n₂ dsɨ₅ jniog₄ a₂dsón'₂ jme₁quian'₅₄ Diú₄ jë₄ co₂tág₅ co₂'né'₅ quió'₅.
\v 3 On₃ rë'₂ jua'₅₄ jmá'₃ a₂në₅; jmo₂ jniog₄ 'io'₂ ne₄ o₂i₁ dsɨ₅ a₂qui₂dsɨ₂ŋág₂; ia₁ ne₄ jniog₄, quian'₅₄ o₂i₁ dsɨ₅ bá₄ qui₂rë₂juɨn'₂ dsɨ₅ jniog₄.
\v 4 A₂juɨn'₂ dsɨ₅ jniog₄ jaun₂, jmo₅ a₂chei'₂ rë₂ jniog₄ 'a₂ lia'₂ lág₅; a₂tióng₂ jniog₄ rë₂ jaun₂ në́₃, jmo₅ a₂'ɨ́n₂ dsɨ₅ jniog₄ jmɨg₄ a₂le₃ti₃.
\v 5 Jmɨg₄ a₂'ɨ́n₂ dsɨ₅ jniog₄ jaun₂, tsá₃ lé₂ le₃jmo₃ jua'₅₄ jéin₂ jniog₄ o₂guí'₃, ia₁ 'ŋiog₅ Diú₄ ma₂ca₂jme₃cain'₂ jme₂dsí₂ quián₂ jniog₄ ia₁ a₂ŋɨ́₄ lë₃ 'nio₃ jniog₄, të₂le₃ quian'₅₄ Jme₂dsí₂ Jŋió₅ i₂ma₂cuɨin₃.
\p 
\v 6 Ia₁ lia'₂ con'₂ jme₁lág₄ jniog₄ dsa₂ mɨ₂güɨ́g₃ 'uan₅₄ i₂tsá₃ cha₂ juɨ₅ 'a₂ lia'₂ lion₄ guio₅₄, la₁ jme₁ca₂të́₂ jmɨg₄ a₂ca₂tióng₃ Diú₄, jaun₂ ca₂jon₃ bá₄ I₂rë₂'ɨ́n₁ quiáin₅ o₄quió'₄ dsa₂ i₂tsá₃ Diú₄ cuɨn₅.
\v 7 A₂quian₅ ta₁ lɨn₃ bá₄ jua'₅₄ mei'₂ guë́₃ jan₂ dsa₂ lé₂ le₃guein₃ 'mú₃ o₄quió'₄ jan₂ dsa₂ mɨ₂güɨ́g₃ rɨin'₅₄, ca₂lia'₂ jŋia'₅₄ o₄quió'₄ jan₂ dsa₂ i₂jmo₅ rë₂; 'an₁ mei'₂ tsá₃ chan₂ jan₂ i₂lé₂ le₃tiá₂ dsɨ́₅ guen₃ 'mú₃ o₄quió'₄ jan₂ dsa₂ i₂dse₃ dsɨ́₅ dsón'₂.
\v 8 La₁ ma₂ca₂cuë₃ bá₄ Diú₄ léi₄ a₂dsón'₂ 'nio₃ jniog₄, ia₁ a₂ca₂jon₃ Cristo 'uɨg₅₄ quián₂, lia'₂ con'₂ jme₁lág₄ guë́₄ dsa₂ cha₂ dsáu₁.
\v 9 A₂jaun₂ në́₃, 'uɨg₅₄ ia₁ a₂ma₂'ë́₂ Diú₄ jág₁ të₂le₃ quian'₅₄ jmɨ₄ Cristo a₂ca₂tang₂, a₂tsá₃ ma₂dso₄ rag₂, jaun₂ të₂le₃ i₂juɨ'₂ guë́₄ lió₂ jniog₄ të₂le₃ quian'₅₄ 'éi₂ a₂gau₂ a₂'ne₂ Diú₄ a₂jiá₃ jë₁ca₂tó'₂.
\v 10 Ia₁ chi₂jua'₂ ma₂ca₂'ág₂ Diú₄ caun₂ jág₁ quian'₅₄ jniog₄ të₂le₃ quian'₅₄ 'mú₃ a₂ca₂i₃ŋɨ́₂ Ja₁ŋi'₅₄ lia'₂ con'₂ jme₁lág₄ guë́₄ jniog₄ dsa₂ i₂'ŋia₅₄ 'éi₂, ján₃ bá₄ le₂jaun₂ të₂le₃ i₂juɨ'₂ guë́₄ lió₂ jniog₄ 'uɨg₅₄ ia₁ a₂chain₂, në₃ lia'₂ ma₂'ei₅ caun₂ jág₁ quiain'₅₄.
\v 11 Ia₁ on₃ guë'₂ jua'₅₄ jmá'₃ a₂në₅, ia₁ chong₂ jniog₄ jme₁'ŋió₄ dsɨ₅ ján₃ le₃quió'₅ Diú₄ të₂le₃ quian'₅₄ Te₁gui'₅₄ Jesucristo, ia₁ të₂le₃ quian'₅₄ Cristo bá₄ ca₂dsi₃náu₅ jniog₄ 'ei₅ caun₂ jág₁ quian'₅₄ Diú₄.
\s1 Adán quian'₅₄ Cristo
\p 
\v 12 Le₂në₅ jaun₂, juɨ₁lia'₂ të₂le₃ quian'₅₄ jan₂ dsa₂ ca₂rë₃chá₃ dsáu₁ dsa₂ mɨ₂güɨ́g₃, 'uɨg₅₄ në₅ bá₄ ca₂já₃ 'mú₃, le₂në₅ bá₄ ján₃ ca₂ŋag₅ 'mú₃ ja₁con₂ ca₂le₃jɨ́n₃ dsa₂ mɨ₂güɨ́g₃, ia₁ ca₂le₃jɨ́n₃ bá₄ ca₂'náu₂ dso₄.
\v 13 Le₂jŋiá₅, lia'₂ con'₂ tsá₃ 'Éi'₃ jme₁ma₂ron₅, ma₂qui₂'no₅ bá₄ dsa₂ dso₄ mɨ₂güɨ́g₃, la₁ tsá₃ lé₂ le₃jióg'₂ 'í₁ 'e₂ a₂rɨn₂ dsa₂ ja₁tsá₃ 'éi'₃ cha₂.
\v 14 La₁ ca₂le₃ jme₁chan₂ Adán, ca₂lia'₂ ca₂të́₂ jmɨg₄ a₂jme₁chan₂ Moisés, ca₂'io₃ 'mú₃ juɨ₅bí₂ ne₄ quió'₅ dsa₂ i₂qui₂ca₂'náu₂ dso₄, o₁jŋia'₅₄ dsáu₁ dsa₂ jaun₂ on₃jua'₅₄ a₂ca₂i₃juɨn₅₄ dsa₂ caun₂ 'éi'₃ juɨ₁lia'₂ ca₂jmo₃ Adán; jme₁lɨ́n₄ Adán co₂'nió'₄ caun₂ nió'₄ quió'₅ i₂jiá₃ chi₁quɨ́n₃.
\p 
\v 15 La₁ dsáu₁ Adán në́₃, tsá₃ lé₂ le₃quɨn₃ quian'₅₄ a₂lë₁cuë₅ Diú₄ jniog₄. Ia₁ juɨ₁lia'₂ o₄quió'₄ dsáu₁ jan₂ dsa₂, juɨn₅ i₂ca₂dsan₃, ján₃ bá₄ le₂jaun₂ të₂le₃ lë́₅ guë́₄ a₂'ua₁ dsɨ́₅ Diú₄ a₂lió₂ a₂lë₁ma₂cuë́'₃ co₂ŋɨ́₂ dsa₂ juɨn₅ të₂le₃ quian'₅₄ jan₂ tan₅₄ dsa₂ i₂'ua₁ dsɨ́₅. Dsa₂ 'éi₂ lɨ́n₅ Jesucristo.
\v 16 Dso₄ a₂ca₂'náu₂ jan₂ dsa₂ tsá₃ lé₂ le₃quɨn₃ quian'₅₄ a₂lió₂ Diú₄ a₂cuë₂₃ jniog₄; ia₁ jme₁ca₂cáun₂ Diú₄ 'í₁ dso₄ a₂ca₂rë₃cán'₂ jan₂ dsa₂, jaun₂ ca₂já₃ juɨ₅ a₂ca₂qui₃dsɨ₅ Diú₄ 'éi'₃ ja₁con₂ dsa₂ mɨ₂güɨ́g₃; la₁ juɨ₁lia'₂ a₂lión₂ dsa₂ në́₃, a₂lë₁'ë́₂ Diú₄ co₂ŋɨ́₂ bá₄ jág₁ a₂tsá₃ 'e₂ dso₄ rɨn₂ dsa₂, juɨ₁'a₂ guë́₃ la₂ qui₂ma₂'náu₂ 'lióng₂ dso₄.
\v 17 Chi₂jua'₂ ca₂'io₃ bí₂ 'mú₃ ne₄ ca₂le₃jɨ́n₃ dsa₂ o₄quió'₄ dsáu₁ jan₂ dsa₂, të₂le₃ i₂juɨ'₂ guë́₄ 'ŋio₅ tson₂ a₂'ua₁ dsɨ́₅ Diú₄ ja₁con₂ dsa₂ i₂guéin'₂ në₂jag₄ bá₄ a₂tsá₃ 'e₂ dso₄ rɨin₂, a₂'io₂₃ bí₂ a₂le₃chain₂ dse₃ të₂le₃ quian'₅₄ jan₂ dsa₂, i₂lɨ́n₅ Jesucristo.
\p 
\v 18 Jaun₂ lë₃, juɨ₁lia'₂ dsáu₁ Adán ca₂chein'₃ ca₂le₃jɨ́n₃ dsa₂ juɨ₅ ja₁'ë́₃ Diú₄ uɨg₅, le₂në₅ bá₄ ján₃, ta₁ a₂quí'₅ a₂dse₃ a₂ca₂jmo₃ Jesucristo ca₂cain₃ ca₂le₃jɨ́n₃ dsa₂ juɨ₅ ja₁lé₂ le₃chain₂ dse₃, ja₁guéi'₂ Diú₄ në₂jag₄ bá₄ a₂tsá₃ 'e₂ dso₄ rɨin₂.
\v 19 Co₂'nió'₄ le₃jua'₅₄, ia₁ juɨ₁lia'₂ tsá₃ gau₂ ca₂nág₂ jan₂ dsa₂ 'éi₂, jaun₂ juɨn₅ i₂ca₂rë₃chá₃ dsáu₁, ján₃ bá₄ le₂në₅, 'uɨg₅₄ ia₁ a₂ca₂nág₂ gau₂ jan₂ tan₅₄ dsa₂, jaun₂ juɨn₅ i₂guén'₂ Diú₄ në₂jag₄ bá₄ i₂ca₂jme₃ti₃.
\p 
\v 20 Ca₂të₁ron₅₄ 'Éi'₃ ia₁jaun₂ dsɨ₃juɨn₅₄ guë́₄ dso₄; la₁ ja₁'ŋio₅ lɨn₃ guë́₄ ca₂i₁juɨn₅₄ dso₄, jaun₂ 'ŋio₅ lɨn₃ guë́₄ ca₂jmo₃ Diú₄ ca₂i₃tsón₂ a₂'ua₁ dsɨ́₅.
\v 21 Jaun₂ le₂në₅ bá₄ juɨ₁lia'₂ ca₂tɨ́n₂ bí₂ dso₄ juɨ₅ a₂quian₅ 'mú₃, le₂në₅ bá₄ ján₃ ca₂'io₃ bí₂ a₂'ua₁ dsɨ́₅ Diú₄ a₂jág₂ jniog₄ në₂jag₄ bá₄ dsa₂ i₂ca₂jme₃ti₃, a₂cuë₃ a₂le₃chong₂ jniog₄ dse₃ co₂tan₅₄ të₂le₃ quian'₅₄ Te₁gui'₅₄ Jesucristo quián₂ jniog₄.
\c 6
\s1 Ma₂dsau₃ të₂le₃ quió'₅ dsáu₁, la₁ chong₂ le₃quió'₅ Cristo
\p 
\v 1 ¿'E₂ jua'₅₄ jniog₄ jaun₂ në́₃? ¿A₁caun₂ dse₃ 'nióg₁ bá₄ jniog₄ dso₄ ia₁jaun₂ caun₂ dsɨ₃tsón₃ a₂'ua₁ dsɨ́₅ Diú₄ quian'₅₄ jniog₄?
\v 2 ¡Dsón'₂ bá₄ on₃jua'₅₄ le₂në₅! Ia₁ ma₂ca₂dsau₃ bá₄ jniog₄ le₃quió'₅ dsáu₁; ¿'a₂ bá₄ lia'₂ lé₂ jaun₂ në́₃ jua'₅₄ a₂caun₂ chong₂ jniog₄ le₃quió'₅ dsáu₁?
\v 3 ¿Tsa₁ ŋi'₅₄ 'nia'₂, lia'₂ con'₂ jme₁ca₂tió'₄ jniog₄ jmɨg₂ le₃quió'₅ Cristo Jesús, ca₂tió'₄ jniog₄ 'mú₃ quió'₅?
\v 4 Ia₁ jme₁ca₂tió'₄ jniog₄ jmɨg₂, co₂'nió'₄ bá₄ ja₁jaun₂ ca₂'o₃ jniog₄ co₂lë₅ quian'₅₄ Cristo në₂jag₄ bá₄ a₂ca₂dsau₃, ia₁jaun₂ jein'₅₄ táng₃ a₂le₃chong₂ caun₂ jme₂dsí₂ 'mɨ́₂, juɨ₁lia'₂ ca₂jen'₅₄ Cristo a₂jme₁rë₂join₅₄, të₂le₃ quian'₅₄ juɨ₅bí₂ jlá'₁ quió'₅ Jmei₂.
\p 
\v 5 Ia₁ chi₂jua'₂ ca₂jme₁quiain'₅₄ jniog₄ ne₄ 'mú₃ quió'₅, ján₃ bá₄ le₂jaun₂ tion₅₄ bá₄ jme₁quiain'₅₄ jë₁ma₂ca₂jein'₅₄ jniog₄ juɨ₁lia'₂ ca₂jen'₅₄ 'éi₂.
\v 6 Ne₄ bá₄ jniog₄, lia'₂ con'₂ lë́₅ jme₁lág₄ le₂jŋiá₅, ne₄ cróg₄ bá₄ ca₂ŋó₃ a₂jaun₂ co₂lë₅ quian'₅₄ Cristo, ia₁jaun₂ dsɨ₃'én₂ juɨ₅bí₂ a₂'io₅ dsáu₁ ne₄ nɨ₁ŋɨ₁ jniog₄, ia₁jaun₂ tsá₃ ma₃lë́₅ jua'₅₄ a₂qui₂rë₂'ŋei'₅₄ guë́₄ a₂chong₂ qui₂jme₂tí₁ ta₁ ne₄ dsáu₁, në₂jag₄ bá₄ ne₄ jan₂ juɨg₅₄ jniog₄.
\v 7 Ia₁ juɨ₁lia'₂ i₂ma₂jon₅, tsá₃ ma₂'e₂ rë₂'ŋei'₅₄, ma₂lóin₂ bá₄ ne₄ dsáu₁.
\v 8 Chi₂jua'₂ ma₂ca₂dsau₃ jniog₄ quian'₅₄ Cristo, ján₃ bá₄ le₂jaun₂ 'éin₂ a₂le₃chong₂ quian'₅₄ 'éi₂,
\v 9 ia₁ ne₄ bá₄ jniog₄, con'₂ jme₁ca₂jen'₅₄ Cristo ne₄ 'mú₃, o₁lɨ́g'₂ jmɨg₄ tsá₃ ma₃lé₂ le₃jóin₂; tsá₃ ma₂'e₂ juɨ₅bí₂ 'io₅ 'mú₃ ne₄ quió'₅ 'éi₂.
\v 10 Ia₁ jme₁ca₂jon₃ Cristo, co₂ráun₂ bá₄ ca₂join₃ 'uɨg₅₄ dsáu₁ dsa₂; la₁ në₃ lia'₂ ma₂chain₂, chain₂ le₃quió'₅ Diú₄.
\v 11 Le₂në₅ bá₄ 'nia'₂ ján₃, jmo₄ bá₄ 'nia'₂ 'au'₂ a₂ma₂dsang'₃ të₂le₃ quió'₅ dso₄, la₁ chan'₂ bá₄ 'nia'₂ le₃quió'₅ Diú₄ të₂le₃ quian'₅₄ Cristo Jesús.
\p 
\v 12 A₂jaun₂ në́₃, 'a₃ cuë₂ 'nia'₂ jmɨg₄ jua'₅₄ a₂'io₃ guë́₄ juɨ₅bí₂ dsáu₁ ne₄ nɨ₁ŋɨ'₁ 'nia'₂ a₂siá'₃, a₂qui₂chi₃quióng₂ jmɨg₄ a₂jme₁ti'₄ 'nia'₂ a₂mɨ₅ nɨ₁ŋɨ́₅.
\v 13 'A₃ qui₁jɨn'₅₄ 'nia'₂ a₂tén₅ nɨ₁ŋɨ'₁ jua'₅₄ a₂'no₃ guë́₄ dso₄, co₂'nió'₄ a₂jmó'₂ ta₁ a₂jmo₃ a₂'lɨg'₅₄. Të₂le₃ ne₄ Diú₄ bá₄ jɨn'₅₄ 'nia'₂ a₂lɨ́ng'₅ co₂'nió'₄ dsa₂ i₂ma₂dsan₃, i₂ma₂jen'₅₄ táng₃. Jang'₅₄ 'nia'₂ a₂tén₅ nɨ₁ŋɨ'₁ le₃ja₁con₂ Diú₄, co₂'nió'₄ a₂jmó'₂ ta₁ a₂jmo₃ jmá'₃ a₂dse₃.
\v 14 Ia₁ tsá₃ 'io₃ guë́₄ bí₂ dsáu₁ ne₄ quián'₂ 'nia'₂ në₂jag₄ bá₄ jan₂ juɨg₅₄ 'nia'₂, ia₁ tsá₃ o₄gú₃ 'Éi'₃ tion'₅₄ 'nia'₂; të₂le₃ o₄gú₃ a₂'ua₁ dsɨ́₅ Diú₄ bá₄ tion'₅₄ 'nia'₂.
\p 
\v 15 ¿'E₂ bá₄ jaun₂ në́₃? ¿A₁caun₂ 'nióg₁ dso₄ bá₄ ia₁ tsá₃ o₄gú₃ 'Éi'₃ tio'₅₄ jniog₄, ia₁ ja₁'ua₁ dsɨ́₅ Diú₄ bá₄ tióng₂? ¡Dsón'₂ bá₄ on₃jua'₅₄ le₂në₅!
\v 16 ¿Tsa₁ ŋi'₅₄ 'nia'₂, në₁jua'₂ ca₂jɨn'₅₄ 'nia'₂ guiong'₅₄ o₄gú₃ jan₂ juɨg₅₄ a₂jme₁ti'₄ ta₁ ne₅₄, ma₂lɨ́ng'₅ jan₂ i₂ma₂chi₁'ŋe'₅₄ i₂quián₅ dsa₂ 'éi₂? Ján₃ bá₄ le₂jaun₂, në₁jua'₂ ca₂jɨn'₅₄ 'nia'₂ guiong'₅₄ ne₄ dsáu₁, dsáu₁ jaun₂ i₂ma₂lɨ́n₅ juɨg₅₄ 'nia'₂, jiog₅ juɨ₅ 'mú₃; o₃ në₁jua'₂ ca₂jɨn'₅₄ 'nia'₂ ne₄ a₂nág'₁ gau₂ jág₁ quió'₅ Diú₄, a₂jaun₂ bá₄ i₂ma₂lɨ́n₅ juɨg₅₄ 'nia'₂, jiog₅ juɨ₅ co₂dsau₅.
\v 17 Juɨ₁'e₂ guë́₃ jme₁rë₂qui₂rë₂'ŋe'₂ 'nia'₂ le₂jŋiá₅ ne₄ dsáu₁, la₁ rë₂në́₃ në́₃, ti₁'mag'₄ Diú₄, ma₂nei'₂ bá₄ 'nia'₂ gau₂ ca₂le₃jë́₃ jme₂dsí₂ quiáng'₂ jág₁ quen₅ a₂ma₂rë₂jɨn'₅₄ 'nia'₂, a₂jme₂tɨ́ng'₂.
\v 18 Jaun₂ në́₃ ma₂lón'₂ 'nia'₂ o₄gú₃ dsáu₁, ma₂tion'₅₄ bá₄ 'nia'₂ o₄gú₃ juɨ₅ co₂dsau₅.
\v 19 (Juá'₅ jniá₂ juɨ́g₂ 'nia'₂ lia'₂ con'₂ lë́₅ jág₁ dsia₅ dsa₂ mɨ₂güɨ́g₃, ia₁ dsón'₂ bá₄ quian₅ ta₁ le₃ŋɨ́'₂ 'au'₂ 'nia'₂ dse₃ ia₁ të₂le₃ a₂lɨ́n'₅ 'nia'₂ dsa₂ mɨ₂güɨ́g₃.) Ia₁ le₂jaun₂ bá₄ ján₃ juɨ₁lia'₂ qui₂ca₂jɨn'₅₄ 'nia'₂ le₂jŋiá₅ a₂tén₅ nɨ₁ŋɨ'₁ juɨ₅ ja₁tsá₃ nág'₂ gau₂, ja₁ca₂jme₁ti'₄ 'nia'₂ ta₁ ne₄ ca₂le₃jë́₃ ne₅₄ a₂'lɨg'₅₄, le₂në₅ bá₄ guë'₂ jang'₅₄ táng₃ 'nia'₂ a₂tén₅ nɨ₁ŋɨ'₁ ja₁jme₁ti'₄ ta₁ ne₄ juɨ₅ jŋió₅ ja₁caun₂ le₃dsen'₃ 'nia'₂.
\p 
\v 20 Lia'₂ con'₂ jme₁lɨ́ng'₄ guë́₄ dsa₂ i₂qui₂rë₂'ŋe'₅₄ le₃quió'₅ dsáu₁, tsá₃ jme₁rë₂'ŋeg'₅₄ jua'₅₄ a₂jme₂ti'₄ guë́₄ 'nia'₂ ta₁ ne₄ juɨ₅ co₂dsau₅.
\v 21 La₁ ¿'e₂ bá₄ a₂dse₃ ca₂lɨn'₃ 'nia'₂ ca₂le₃jë́₃ a₂jaun₂, a₂caun₂ lë₁o₂guí'₃ quián'₂ 'nia'₂ rë₂në́₃? Ia₁ jmá'₃ lia'₂ ca₂ne₅₄ a₂dsióg₄ ne₄ juɨ₅ 'mú₃ bá₄ a₂jaun₂.
\v 22 La₁ rë₂në́₃ në́₃, ma₂lón'₂ 'nia'₂ juɨ₅ ja₁jme₁qui₂rë₂'ŋe'₅₄ 'nia'₂ 'nau'₂ dso₄, ma₂i₂ton'₅₄ 'nia'₂ juɨ₅ ja₁jme₁ti'₄ ta₁ ne₄ Diú₄, jaun₂ lén'₂ 'nia'₂ juɨ₅ jŋió₅ ja₁caun₂ le₃dsen'₃ 'nia'₂, juɨ₅ ja₁dsióg₄ a₂le₃chan'₂ 'nia'₂ dse₃ co₂tan₅₄.
\v 23 Ia₁ jŋia'₅₄ lia'₂ 'mú₃ bá₄ lí'₂ dsa₂ co₂'nió'₄ 'lia'₅₄ dsáu₁, la₁ a₂lë₁cuë₅ bá₄ Diú₄ a₂le₃chan₂ dsa₂ dse₃ co₂tan₅₄ të₂le₃ quian'₅₄ Cristo Jesús i₂lɨ́n₅ Te₁gui'₅₄ quián₂ jniog₄.
\c 7
\s1 Caun₂ jág₁ a₂jáng'₅ léi₄ a₂jau'₂ juɨ₁lia'₂ ja₁con₂ dsa₂ i₂rë₂jen'₂ gu₂
\p 
\v 1 Rɨn'₅₄ jniog₄, 'nia'₂ dsa₂ i₂cuɨ́'₅ 'a₂ lia'₂ juá'₂ ne₄ Si₂ 'Éi'₃, ¿tsa₁ ŋi'₅₄ 'nia'₂ a₂'io₅ bí₂ 'Éi'₃ ja₁con₂ jan₂ dsa₂ jmá'₃ të₁lia'₂ chain₂?
\v 2 Juɨ₁lia'₂ jan₂ dsa₂ mɨ́₂ i₂chan₂ dsɨ₂i₂gu₂, co₂'nió'₄ a₂chi₁'ŋei'₅₄ bá₄ quiain'₅₄ dsɨ₂i₂gu₂ lia'₂ con'₂ lë́₅ ne₄ Si₂ 'Éi'₃, të₁lia'₂ chan₂ dsa₂ ŋe'₂. La₁ në₁jua'₂ ca₂jon₃ dsɨ₂i₂gu₂ në́₃, ca₂tsɨn'₂ bá₄ dsa₂ mɨ́₂ 'éi₂ të₂le₃ quió'₅ 'éi'₃ a₂jme₁le₁quian₅ quió'₅ quiain'₅₄ dsɨ₂i₂gu₂.
\v 3 Në₁jua'₂ ca₂guá₂ 'io₅₄ quiain'₅₄ dsa₂ ŋe'₂ sián'₂ të₃ chan₂ dsɨ₂i₂gu₂, dso₄ bá₄ 'no₂₃; la₁ në₁jua'₂ ca₂jon₃ dsɨ₂i₂gu₂ në́₃, ca₂tsɨn'₂ bá₄ 'io₅₄ të₂le₃ quió'₅ 'éi'₃, ma₂lé₂ bá₄ jéin'₂ táng₃ gu₂ quiain'₅₄ dsa₂ ŋe'₂ sián'₂, tsá₃ ma₃dso₄ 'no₂₃.
\p 
\v 4 Le₂në₅ bá₄ ján₃, 'nia'₂ rɨn'₅₄ jniog₄, ma₂dsan'₃ 'nia'₂ le₃quió'₅ 'Éi'₃ të₂le₃ quian'₅₄ ŋɨ₄ Cristo, ia₁jaun₂ téng'₄ ja₁con₂ i₂sián'₂: ja₁con₂ 'éi₂ i₂ca₂jen'₅₄ táng₃ ne₄ 'mú₃. Le₂në₅ ca₂lë₃ ia₁jaun₂ le₃chong₂ jniog₄ téi₅ ta₁ ne₄ Diú₄.
\v 5 Ia₁ lia'₂ con'₂ jme₁chong₂ jniog₄ lia'₂ jme₁jiog₅ nɨ₁ŋɨ₁ jniog₄, ta₁ jaun₂ ca₂quí'₃ 'Éi'₃ a₂ca₂ŋei₃ juɨ₅ nɨ₁ŋɨ₁ jniog₄ a₂ca₂lë₃ dsɨ₅ jmó₁ a₂'lɨg'₅₄, ca₂quí'₃ ta₁ a₂ca₂i₁jo₅₄ ne₄ 'mú₃.
\v 6 La₁ rë₂në́₃ në́₃, ma₂dsau₃ le₃quió'₅ Si₂ 'Éi'₃ a₂jme₁jiog₅ jme₁le₁'ŋei'₅₄, a₂jme₁ti₁ ne₄ Diú₄ juɨ₅ 'mɨ́₂ quió'₅ Jme₂dsí₂ quiáin₅. Jaun₂ tsá₃ ma₃tio'₅₄ jniog₄ le₁'ŋei'₅₄ ne₄ 'Éi'₃ a₂chi₁ton₅ ne₄ si₂.
\s1 Dso₄ a₂'i₄ ja₁con₂ jniá₂
\p 
\v 7 ¿'E₂ jua'₅₄ jniog₄ jaun₂ në́₃? ¿A₂lë́₅ dso₄ bá₄ 'Éi'₃ jaun₂? ¡Dsón'₂ bá₄ on₃jua'₅₄ le₂jaun₂! La₁ jniá₂ në́₃ tsá₃ ca₂rë₃guion₅₄ 'e₂ jaun₂ dsáu₅, jua'₅₄ mei'₂ guë́₃ tsá₃ 'Éi'₃ ron₅. Co₂'nió'₄ le₃jua'₅₄, tsá₃ 'e₂ ca₂rë₃guion₅₄, juɨ₁lia'₂ a₂'ɨ́n₅ dsɨ₃ a₂cha₂ quió'₅ i₂sián'₂, jua'₅₄ mei'₂ guë́₃ tsá₃ a₂juá'₂ 'Éi'₃ ne₄ Si₂: “Tsá₃ lë₁jmo₂ 'ɨ́n₅ 'au'₂ a₂quió'₅ dsa₂ sián'₂.”\f + \fr 7:7 \ft Éxodo 20:17; Deuteronomio 5:21.\f*
\p 
\v 8 La₁ dsáu₁ në́₃ ca₂jme₃'ŋiói'₃ bá₄ jág₁ në₅; 'ŋiog₅ bá₄ 'Éi'₃ ca₂cuë₃ jmɨg₄ ca₂ŋei₃ të₂dsɨ₃ ca₂le₃jë́₃ ne₅₄ a₂'ɨ́n₅ dsɨ₃ a₂cha₂ quió'₅ i₂sián'₂. Ia₁ juɨ₁lia'₂ ja₁tsá₃ 'Éi'₃ ron₅, tsá₃ léi₄ jniá₂ a₂cha₂ dsáu₅.
\v 9 Ján₃ bá₄ jme₁chang₂ caun₂ jmɨg₄ lia'₂ con'₂ tsá₃ 'Éi'₃ quió'₅ Moisés ma₂ca₂tɨ́ng₂. La₁ jme₁ca₂já₃ 'Éi'₃, co₂'nió'₄ a₂ca₂jen'₅₄ bá₄ táng₃ dsáu₁; jniá₂ guë'₂, co₂'nió'₄ a₂ca₂jong₃.
\v 10 Le₂në₅ bá₄ ca₂lë₃ quian'₅₄ 'ŋiog₅ 'Éi'₃ jaun₂; 'nió'₄ a₂jme₁cuë₃ bí₂ a₂le₃chan₂ jniá₂, të₂le₃ ca₂jiog₃ juɨ₅ 'mú₃ bá₄ a₂jaun₂.
\v 11 Ia₁ dsáu₁ në́₃, ca₂jme₃'ŋiói'₃ bá₄ ne₄ 'Éi'₃ ja₁con₂ jniá₂, ca₂jme₃gau₂₃. Jaun₂ quian'₅₄ 'ŋiog₅ bá₄ 'Éi'₃, ca₂cuë₃ 'mú₃.
\p 
\v 12 Jaun₂ në́₃, a₂jŋió₅ bá₄ Si₂ 'Éi'₃; ján₃ guë'₂ le₂jaun₂ ca₂le₃jë́₃ 'éi'₃ tio'₅₄, a₂jŋió₅, con₂ 'í₁ con'₂ dsi₂ten₅₄, a₂dse₃ lɨn₃ bá₄ a₂jaun₂.
\v 13 ¿'E₂ bá₄ jaun₂ në́₃? ¿Juɨ₁lia'₂ a₂dse₃ jaun₂ ca₂lë₃ 'mú₃ ja₁con₂ jniá₂? ¡Dsón'₂ on₃jua'₅₄ jaun₂! 'Uɨg₅₄ dsáu₅ bá₄ jniá₂ jaun₂, ca₂jiog₃ juɨ₅ 'mú₃, le₂në₅ ca₂cuë₃ léi₄ a₂lë́₅ dso₄ a₂jaun₂ a₂jme₁jmo₅ jniá₂; ca₂jmo₃ të₂le₃ quian'₅₄ a₂dse₃, jaun₂ le₂në₅ ca₂jme₃jnia₅ 'Éi'₃ 'e₂ a₂lë́₅ a₂juɨ₁si 'lɨg'₅₄ a₂lë́₅ dsáu₁.
\p 
\v 14 Ne₄ bá₄ jniog₄ jaun₂ a₂lë́₅ a₂gu₂dsí₂ bá₄ 'Éi'₃, la₁ dsa₂ nɨ₁ŋɨ́₅ bá₄ jniá₂; co₂'nió'₄ a₂rë₂'nɨ₅₄ bá₄ jniá₂ ne₄ dso₄.
\v 15 Ia₁ tsá₃ ŋɨ́'₂ dsɨ₃ 'e₂ lë₃ jmo₂₃ 'e₂ jmo₂₃, ia₁ tsá₃ lé₂ jmo₅₄ a₂'ɨ́n₅ dsɨ₃ jmo₅₄, ia₁ ca₂le₃jë́₃ a₂'io₄ jniá₂ a₂tsá₃ 'nio₃ jmo₅₄, a₂jaun₂ dé₄ dsón'₂ jmo₂₃.
\v 16 Ia₁ chi₂jua'₂ jmo₅ jniá₂ a₂tsá₃ të₅ dsɨ₃ jmo₅₄, jaun₂ jmo₅ jniá₂ dsɨ₃ a₂dse₃ bá₄ 'Éi'₃.
\v 17 Le₂në₅ bá₄ jaun₂, on₃jua'₅₄ jniá₂ 'ŋió₃ 'no₂₃ dso₄; dsáu₅ jniá₂ a₂'i₄ të₂dsɨ₃ bá₄, a₂jaun₂ bá₄ jmo₅.
\v 18 Ia₁ guion₄ jniá₂, 'i₁caun₂ a₂dse₃ tsá₃ cha₂ të₂dsɨ₃ jniá₂, co₂'nió'₄ le₃jua'₅₄ lia'₂ con'₂ lɨ́ng₅ dsa₂ nɨ₁ŋɨ́₅, ia₁ 'ɨ́n₅ bá₄ dsɨ₃ jmo₅₄ a₂dse₃, la₁ tsá₃ quɨ'₅₄ jmɨg₄ jmo₅₄.
\v 19 Tsá₃ qui₂jmo₅ jniá₂ a₂dse₃ a₂'nio₃ jmo₅₄; caun₂ jmo₅ bá₄ jniá₂ a₂'lɨg'₅₄ a₂tsá₃ 'nio₃ jmo₅₄.
\v 20 Jaun₂ në́₃, chi₂jua'₂ jmo₅ jniá₂ a₂tsá₃ të₅ dsɨ₃ jmo₅₄, on₃jua'₅₄ jniá₂ 'ŋió₃ jmo₂₃ a₂jaun₂; dsáu₅ jniá₂ a₂'i₄ të₂dsɨ₃ bá₄, a₂jaun₂ bá₄ jmo₅.
\p 
\v 21 Jaun₂ ma₂ca₂rë₃léi₄, cha₂ caun₂ 'éi'₃: jë₁ma₂të́₂ rë₁'nio₃ jmo₅₄ a₂dse₃, jŋia'₅₄ lia'₂ a₂'lɨg'₅₄ bá₄ cha₂ ja₁cong₂.
\v 22 Né'₃ jme₂dsí₂ quió₃, të₅ bá₄ dsɨ₃ 'Éi'₃ quió'₅ Diú₄;
\v 23 la₁ jág₅ jniá₂ ja₁con₂ a₂tén₅ nɨ₁ŋɨ₃, cha₂ caun₂ 'éi'₃ siá'₂ a₂jmo₅ 'nei₂ quian'₅₄ 'éi'₃ 'a₂ lia'₂ dsɨ₂jiog₅ dsi₃, a₂të₂ chi₁'ŋeg'₁ ne₄ 'éi'₃ quió'₅ dso₄ a₂jmo₅ ta₁ ja₁con₂ a₂tén₅ nɨ₁ŋɨ₃.
\p 
\v 24 ¡'E₂ guë́₄ juɨ́g₂ jniá₂! ¿'Ein₂ bá₄ jiá₃ lió₂ ne₄ nɨ₁ŋɨ₃ a₂jiog₅ 'mú₃ la₂?
\v 25 Ti₁'mag'₄ Diú₄, cha₂ bá₄ juɨ₅ 'a₂ lia'₂ lé₂ të₂le₃ quian'₅₄ Te₁gui'₅₄ Jesucristo quián₂ jniog₄.
\p Jaun₂ në́₃, 'ŋió₃ bá₄ jniá₂ quian'₅₄ 'a₂ lia'₂ dsɨ₂jiog₅ dsi₃, jme₂tí₁ ta₁ ne₄ 'Éi'₃ quió'₅ Diú₄, la₁ lia'₂ con'₂ lɨ́ng₅ dsa₂ nɨ₁ŋɨ́₅, jme₁tí₁ jniá₂ ne₄ 'éi'₃ quió'₅ dso₄.
\c 8
\s1 'A₂ lia'₂ chan₂ dsa₂ con'₂ lë́₅ jiog₅ Jme₂dsí₂ quián₅ Diú₄
\p 
\v 1 Në₃ në́₃ jaun₂, tsá₃ ma₂'e₂ uɨg₅ 'ë́₂ Diú₄ ne₄ quió'₅ dsa₂ i₂ma₂'ei₅ caun₂ jág₁ quian'₅₄ Cristo Jesús.\f + \fr 8:1 \ft A₂lɨn₅₄ chog₅₄ si₂ a₂ca₂lë₃ cang₂ guë́₄, juá'₂ le₂la₂ ján₃: “i₂i₂nio₄, on₃jua'₅₄ lia'₂ con'₂ lë́₅ jiog₅ nɨ₁ŋɨ₁₂, i₂i₂nio₄ lia'₂ con'₂ lë́₅ jiog₅ Jme₂dsí₂ bá₄.” \f*
\v 2 Ia₁ bí₂ a₂'io₅ 'éi'₃ quió'₅ Jme₂dsí₂ ma₂cuë₅ jmɨg₄ a₂chan₂ jniá₂ të₂le₃ quian'₅₄ Cristo Jesús, ia₁ ma₂ca₂lió₂ jniá₂ ne₄ 'éi'₃ quió'₅ dso₄, quió'₅ 'mú₃ në́₃.
\v 3 Ia₁ ma₂ca₂jmo₃ Diú₄ a₂tsá₃ ca₂quɨ'₅₄ jmɨg₄ Si₂ 'Éi'₃ jmo₃ ia₁ ca₂'uán₂ bá₄ 'Éi'₃ 'uɨg₅₄ dsáu₁ dsa₂ nɨ₁ŋɨ́₅: ca₂chein₃ ja₁ŋi'₅₄ 'ŋiog₅ o₄quió'₄ dsáu₁ dsa₂; ca₂jmo₃ a₂lɨ́n₅ 'éi₂ dsa₂ chi₁dsáin₃ lia'₂ lɨ́n₅ dsa₂ mɨ₂güɨ́g₃ i₂'no₅ dso₄, jaun₂ le₂në₅ bá₄ ca₂'ë́₂ uɨg₅ ne₄ dso₄, ia₁ a₂lɨ́in₅ dsa₂ chi₁dsáin₃.
\v 4 Le₂në₅ ca₂jmo₃ ia₁jaun₂ le₃ti₃ 'Éi'₃ a₂con₂ 'í₁ con'₂ dsɨ₂ten₅₄, ja₁con₂ jniog₄, i₂i₂nio₄, on₃jua'₅₄ lia'₂ con'₂ lë́₅ jiog₅ nɨ₁ŋɨ₁₂, i₂i₂nio₄ lia'₂ con'₂ lë́₅ jiog₅ Jme₂dsí₂ bá₄.
\p 
\v 5 Ia₁ dsa₂ i₂chan₂ lia'₂ con'₂ lë́₅ jiog₅ nɨ₁ŋɨ₁ qui₂dsɨ₂jiog₅ dsɨ́₅ juɨ₅ quió'₅ nɨ₁ŋɨ́₅, la₁ juɨ₁lia'₂ dsa₂ i₂ma₂chan₂ lia'₂ con'₂ lë́₅ jiog₅ Jme₂dsí₂ quián₅ Diú₄, qui₂dsɨ₂jiog₅ dsɨ́₅ a₂quió'₅ jme₂dsí₂ bá₄.
\v 6 Ia₁ juɨ₁lia'₂ a₂qui₂dsɨ₂jiog₅ dsɨ́₅ dsa₂ juɨ₅ quió'₅ nɨ₁ŋɨ́₅, a₂lë́₅ 'mú₃ bá₄ jaun₂; la₁ juɨ₁lia'₂ a₂qui₂dsɨ₂jiog₅ dsɨ́₅ dsa₂ le₃quió'₅ Jme₂dsí₂ quián₅ Diú₄, a₂jaun₂ bá₄ jmo₅ a₂le₃chan₂ dsa₂ dse₃, a₂'ag₃ tei₄ dsɨ́₅ dsa₂ në́₃.
\v 7 Ia₁ juɨ₁lia'₂ i₂qui₂dsɨ₂jiog₅ dsɨ́₅ juɨ₅ quió'₅ nɨ₁ŋɨ́₅, i₂'ŋia₅₄ Diú₄ bá₄ i₂le₂'éi₂, ia₁ tsá₃ 'nio₃, on₃ guë'₂ lé₂ jme₃ti₃ 'Éi'₃ quió'₅ Diú₄.
\v 8 'Uɨg₅₄ jaun₂ bá₄, juɨ₁lia'₂ i₂i₂nio₄ lia'₂ con'₂ jiog₅ nɨ₁ŋɨ₁₂, tsá₃ lé₂ le₃jmo₃ a₂të₅ dsɨ́₅ Diú₄.
\p 
\v 9 La₁ juɨ₁lia'₂ 'nia'₂ në́₃, tsá₃ ma₃i₂nio'₅₄ 'nia'₂ lia'₂ con'₂ jiog₅ nɨ₁ŋɨ́₅, ia₁ ma₂quian'₅₄ bá₄ 'nia'₂ Jme₂dsí₂, në₁jua'₂ guá₅ Jme₂dsí₂ quián₅ Diú₄ të₂'au'₂ 'nia'₂. Ia₁ juɨ₁lia'₂ dsa₂ i₂tsá₃ 'en₅₄ Jme₂dsí₂ quián₅ Cristo të₂dsɨ́₅, tsá₃ lɨ́in₅ i₂quián₅ 'éi₂.
\v 10 La₁ në₁jua'₂ 'en₅₄ Cristo të₂'au'₂ 'nia'₂, jaun₂ chan₂ bá₄ jme₂dsí₂ quián'₂ 'nia'₂ 'uɨg₅₄ ia₁ a₂ma₂jɨ́n₂ Diú₄ 'nia'₂ në₂jag₄ bá₄ a₂ma₂jme₂tí'₂ 'nia'₂, o₁jŋia'₅₄ 'io₅ 'mú₃ nɨ₁ŋɨ'₁ 'nia'₂ o₄quió'₄ dso₄.
\v 11 Chi₂jua'₂ chan₂ ja₁con'₂ 'nia'₂ Jme₂dsí₂ quián₅ i₂ca₂jme₃jen'₅₄ Cristo Jesús ne₄ 'mú₃, 'ŋiog₅ bá₄ 'éi₂ cuë₃ jme₂dsí₂ 'mɨ́₂ ne₄ nɨ₁ŋɨ'₁ 'nia'₂ a₂ca₂tɨ́n₂ 'mú₃, të₂le₃ quian'₅₄ Jme₂dsí₂ quián₅ Diú₄ i₂guá₅ të₂'au'₂ 'nia'₂.
\p 
\v 12 Le₂në₅ bá₄ jaun₂, 'nia'₂ rɨn'₅₄ jniog₄, cha₂ a₂ca₂tág₂ jniog₄ jmó₁, la₁ on₃jua'₅₄ rë'₂ ne₄ nɨ₁ŋɨ́₅ jua'₅₄ a₂'nió'₅ le₃chong₂ jniog₄ 'io₄ táng₃ lia'₂ con'₂ lë́₅ mɨ₅ nɨ₁ŋɨ₁.
\v 13 Ia₁ në₁jua'₂ chan'₂ 'nia'₂ lia'₂ con'₂ mɨ₅ nɨ₁ŋɨ'₁, dsián'₃ bá₄ 'nia'₂; la₁ në₁jua'₂ të₂le₃ quian'₅₄ Jme₂dsí₂, jŋɨ́'₅ 'nia'₂ a₂jmo₅ nɨ₁ŋɨ'₁, jaun₂ le₃chan'₂ bá₄ 'nia'₂.
\p 
\v 14 Ia₁ ca₂le₃jɨ́n₃ dsa₂ i₂i₂nio₄ lia'₂ con'₂ lë́₅ jiog₅ Jme₂dsí₂ quián₅ Diú₄, lɨ́in₅ chi'₂-guein₂ quián₅ Diú₄.
\v 15 Ia₁ Jme₂dsí₂ i₂ma₂guen'₅₄ 'nia'₂ on₃jua'₅₄ i₂lɨ́n₅ jme₂dsí₂ i₂qui₃'nei'₂ táng₃ jua'₅₄ a₂jmo₃ a₂le₃gan'₃ táng₃ 'nia'₂. Jme₂dsí₂ 'éi₂ bá₄ i₂ma₂guen'₅₄ 'nia'₂ i₂jmo₃ a₂lén'₂ 'nia'₂ chi'₂-guein₂ quián₅ Diú₄. Jme₁jua'₂ jniog₄ të₂le₃ quian'₅₄ 'éi₂: “¡Abba!\f + \fr 8:15 \ft Abba: co₂'nió'₄ le₃jua'₅₄: “Tia₅₄” quian'₅₄ jág₁ jmei₅ arameo.\f* ¡Tia₅₄ quiáng₃!”,
\v 16 jaun₂ 'ŋiog₅ bá₄ Jme₂dsí₂ në₅ jme₂quiain'₅₄ jme₂dsí₂ quián₂ jniog₄, jáng'₅ jág₁ dsau₅ juá'₂ a₂ma₂lág₅ jniog₄ chi'₂-guein₂ quián₅ Diú₄.
\v 17 Jaun₂ chi₂jua'₂ lág₅ jniog₄ ja₁ŋi'₅₄, ján₃ bá₄ ca₂tág₂ jniog₄ guéi₁ a₂dse₃ a₂ma₂lë́₅ jág₁ cuë₃ Diú₄ a₂cuë́'₃ chi'₂-guein₂ quiáin₅; guéi₁ jniog₄ a₂në₅ co₂lë₅ quian'₅₄ Cristo, chi₂jua'₂ quein'₅₄ jniog₄ quian'₅₄ jmɨ₁uɨg₅ quió'₅ ia₁jaun₂ quein'₅₄ jniog₄ cang₂ jë₄ co₂tág₅ co₂'né'₅ quió'₅.
\p 
\v 18 Ia₁ lɨ́n₂ jniá₂ on₃jua'₅₄ cha₂ 'e₂ uɨg₅ a₂ŋag₄ jniog₄ rë₂në́₃ on₃jua'₅₄ a₂quɨn₃ quian'₅₄ a₂co₂tág₅ co₂'né'₅ a₂jiá₃ a₂le₃jniá₂ ja₁con₂ jniog₄.
\v 19 Ia₁ ma₂chi₁jŋia₅ chi₁quian₅₄ jmɨg₄ ca₂le₃jë́₃ a₂ca₂jmo₃ Diú₄, a₂'ɨ́n₅ dsɨ́₅ jmɨg₄ jë₁ma₂të́₂ rë₁le₃jniá₂ chi'₂-guein₂ quián₅ Diú₄.
\v 20 Ia₁ ca₂le₃jë́₃ a₂ca₂jmo₃ Diú₄ në́₃ ma₂qui₂le₁'ŋei'₅₄ ne₄ juɨ₅ ja₁tsá₃ ta₁ tí₄, on₃jua'₅₄ ia₁ a₂ca₂rë₃'ŋió₃ dsɨ́₅ guioin₅₄, ia₁ le₂jaun₂ 'éi'₃ ca₂jmo₃ Diú₄ 'ŋiog₅ bá₄. A₂'ɨ́n₂ dsɨ́₅ ca₂le₃jë́₃ a₂në₅,
\v 21 jmɨg₄ a₂lió₂ Diú₄ a₂qui₂chi₁'ŋei'₅₄ ne₄ juɨ₅ a₂siá'₃ quió'₅, ia₁jaun₂ jme₃quiain'₅₄ chi'₂-guein₂ quián₅ Diú₄ jë₄ co₂tág₅ co₂'né'₅ juɨ₁lia'₂ i₂ma₂qui₂ca₂lón₂.
\v 22 Ia₁ ne₄ bá₄ jniog₄, ca₂lia'₂ jŋió₄ jmɨg₄ në₃, ca₂le₃jë́₃ a₂ca₂jmo₃ Diú₄, qui₂'ŋióg₂ qui₂'ŋia₂₃ co₂lë₅ chain₂ uɨg₅.
\v 23 On₃jua'₅₄ jmá'₃ a₂jaun₂; ján₃ bá₄ le₂jaun₂ jniog₄ në́₃, i₂'io₅ a₂le₂'uɨg₅₄ a₂ca₂ráu₃ quió'₅ Jme₂dsí₂, qui₂'ŋióg₅ qui₂'ŋia₂ të₂dsɨ₅ jniog₄ të₁lia'₂ chi₁jŋia₁ a₂'ɨ́n₅ dsɨ₅ jmɨg₄ jaun₂, a₂jme₃jnia₅ a₂lág₅ jniog₄ chi'₂-guein₂ quián₅ Diú₄, jmɨg₄ a₂lióin₂ nɨ₁ŋɨ₁ jniog₄ la₂.
\v 24 Ia₁ të₂le₃ quian'₅₄ jmɨg₄ a₂'ɨ́n₂ dsɨ₅ jniog₄ në₅ bá₄ ca₂lió₂; la₁ në₁jua'₂ ma₂jág₅ dsa₂ a₂'ɨ́n₂ dsɨ́₅, on₃jua'₅₄ ma₃le₃'ɨ́n₂ dsɨ́₅ dsa₂ juɨ₁lia'₂ a₂ma₂jág₅, tsá₃ ma₃tion₅₄ 'nió'₅ 'ɨ́n₂ dsɨ́₅.
\v 25 La₁ në₁jua'₂ 'ɨ́n₂ dsɨ₅ jniog₄ caun₂ a₂tsá₃ ma₂ne₅₄, juɨn'₂ bá₄ dsɨ₅ jŋia₄ a₂'ɨ́n₂ dsɨ₅.
\p 
\v 26 Ján₃ bá₄ le₂në₅ jme₂'o₅₄ Jme₂dsí₂ quián₅ Diú₄ a₂'uan₅₄ dsɨ₅ jniog₄. Ia₁ tsá₃ tag₂ chi₂len'₄ Diú₄ 'a₂ con'₂ dsi₂ten₅₄, la₁ 'ŋiog₅ bá₄ Jme₂dsí₂ Jŋió₅ në́₃ mɨ₂₃ ne₄ Diú₄ o₄quián₂ jniog₄, ca₂le₃jë́₃ qui₂'ŋióg₂ qui₂'ŋia₃ on₃jua'₅₄ a₂lé₂ le₃'ŋióg₃ jniog₄ quian'₅₄ jág₁.
\v 27 La₁ Diú₄ në́₃ i₂të₂li₅ të₂dsɨ́₅ dsa₂ mɨ₂güɨ́g₃, 'éi₂ bá₄ ŋi₅ 'e₂ 'nio₃ Jme₂dsí₂ 'éi₂ juá'₂; ia₁ mɨ₅ Jme₂dsí₂ Jŋió₅ lia'₂ con'₂ lë́₅ 'ŋio₂ dsɨ́₅ Diú₄, o₄quió'₄ dsa₂ jŋió₅ quiáin₅.
\s1 Të₂le₃ ŋag₅₄ guë́₄ léi₂ jniog₄
\p 
\v 28 Ne₄ bá₄ jniog₄, Diú₄ bá₄ i₂jmo₅ ne₄ ca₂le₃jë́₃, a₂dse₃ quió'₅ dsa₂ i₂'nio₃ Diú₄, quió'₅ dsa₂ i₂ma₂të́'₃ Diú₄ lia'₂ con'₂ lë́₅ ma₂i₂jiog₅ dsɨ́₅ jmo₃.
\v 29 Ia₁ i₂ma₂cuɨg₅ Diú₄ ca₂le₂jŋiá₅, ján₃ bá₄ ca₂chei'₃ ca₂'ɨin₃ 'éi₂ a₂léin₂ juɨ₁lia'₂ lɨ́n₅ Ja₁ŋi'₅₄, ia₁jaun₂ lén₂ Ja₁ŋi'₅₄ i₂le₂ne₁ jë₄ quió'₅ rɨin'₅₄ i₂juɨn₅.
\v 30 Dsa₂ i₂con'₂ ma₂ca₂chen'₃ Diú₄ lia'₂ ca₂le₂jŋiá₅, ca₂të́'₃ 'éi₂ ján₃; dsa₂ i₂con'₂ ca₂të́'₃ 'éi₂ në́₃, ján₃ bá₄ ca₂jág₂ në₂jag₄ a₂tsá₃ 'e₂ dso₄ rɨin₂; dsa₂ i₂con'₂ ca₂jág₂ Diú₄ a₂tsá₃ 'e₂ dso₄ rɨin₂ në́₃, ján₃ bá₄ ca₂jme₃jláin'₁.
\p 
\v 31 ¿'E₂ le₃jua'₅₄ jniog₄ në́₃, quian'₅₄ a₂në₅? Chi₂jua'₂ chén'₅ Diú₄ ne₄ jág₁ quián₂ jniog₄, ¿'ein₂ bá₄ quɨ'₅₄ jmɨg₄ jmóg'₂ jniog₄?
\v 32 Tsá₃ ca₂jmo₃ Diú₄ jua'₅₄ tsá₃ jme₁cuɨin₂₃ Ja₁ŋi'₅₄ 'ŋiog₅, të₂le₃ ca₂jáng'₂ bá₄, ca₂ŋó₃ 'éi₂ ne₄ 'mú₃ o₄quián₂ jniog₄; ¿'a₂ bá₄ lia'₂ jua'₅₄ a₂tsá₃ cuë₃ jniog₄ ján₃ co₂dsia₅ quian'₅₄ 'éi₂ ca₂le₃jë́₃?
\v 33 ¿'Ein₂ bá₄ lé₂ le₃'nɨ₃ dsa₂ i₂ma₂quión'₂ Diú₄? Ton'₂ 'ŋiog₅ bá₄ Diú₄ juá'₂ a₂tsá₃ 'e₂ rɨin₂.
\v 34 ¿'Ein₂ i₂lé₂ le₃'ë́₂ uɨg₅? Ia₁ Cristo Jesús bá₄ i₂ca₂jon₃; të₂le₃ lë́₅ bá₄ guë́₄, a₂ca₂jein'₅₄ táng₃, ton'₂ ma₂guá₅ le₃gu₂ ne₁ quió'₅ Diú₄, mɨ₂₃ o₄quián₂ jniog₄.
\v 35 ¿'Ein₂ bá₄ i₂lé₂ 'liog'₃ jniog₄ cau₅ ne₄ a₂'nio₃ Cristo? ¿O₃ bá₄ quɨ'₅₄ jmɨg₄ juɨ₁lia'₂ caun₂ jmɨ₁uɨg₅, o₃ juɨ₁lia'₂ caun₂ o₂i₁ dsɨ₅, o₃ jmɨg₄ juɨ₁lia'₂ a₂co₂'ein₅ dsa₂, o₃ jmɨg₄ juɨ₁lia'₂ jme₁'ɨn₂ a₂que₅₄, o₃ ia₁ a₂tsá₃ cha₂ a₂qui'₅₄ 'e₂ jniog₄, o₃ 'e₂ caun₂ a₂gau₂ cha₂, o₃ a₂go₃ jniog₄ a₂jme₃dsiog₅ dsa₂ quian'₅₄ ŋi₁tág₂?
\v 36 Juɨ₁lia'₂ rë₂ton₅ ne₄ Si₂:
\q1 O₄quián'₂ 'ne₂ bá₄ guei₂ jnia'₅₄ 'mú₃ co₂tan₅₄.
\q1 Jmo₅ dsa₂ dsɨ́₅ a₂lág₅ jnia'₅₄
\q2 në₂jag₄ bá₄ já'₂ cha'₂
\q2 i₂ma₂le₁te₂ dsa₂ a₂jme₃dsiog₂₃.\f + \fr 8:36 \ft Salmo 44:22.\f*
\p 
\v 37 La₁ jë₄ ca₂le₃jë́₃ a₂në₅, tson₂ guë́₄ léi₂ tián₂ jniog₄ të₂le₃ quian'₅₄ 'éi₂ i₂ma₂ca₂rë₃'nio₃ quián₂ jniog₄.
\v 38 Ia₁ caun₂ bá₄ 'ei₅ dsɨ₃, 'i₁caun₂ tsá₃ 'e₂ lé₂ le₃'liog'₃ cau₅ ne₄ a₂'nio₃ Diú₄ jniog₄. Tsá₃ quɨ'₅₄ jmɨg₄ 'mú₃, on₃ guë'₂ a₂chong₂, on₃ guë'₂ ángeles, on₃ guë'₂ dsɨ₂tan₅₄ quián₅ jme₂dsí₂, on₃ guë'₂ a₂cha₂ rë₂në́₃, on₃ guë'₂ a₂cha₂ jmɨg₄ ne₄ juɨ₅ në́₃, on₃ guë́₄ juɨ₅bí₂,
\v 39 on₃ guë'₂ i₂tion'₅₄ ja₁ŋei₅ lɨn₃, on₃ guë'₂ i₂tion'₅₄ ja₁'uɨn₃ lɨn₃, on₃ guë'₂ juɨ₁'e₂ guë́₃ a₂siá'₂ a₂ca₂jmo₃ Diú₄, jua'₅₄ le₃quɨ'₅₄ jmɨg₄ jmo₃ jua'₅₄ a₂tsá₃ ma₃jme₃'nio₃ Diú₄ jniog₄, të₂le₃ quian'₅₄ Cristo Jesús Te₁gui'₅₄ quián₂ jniog₄.
\c 9
\s1 Ma₂quión'₂ Diú₄ dsa₂ juɨg₂ Israel
\p 
\v 1 Jág₁ tí₅ dsón'₂ bá₄ juá'₅ jniá₂ le₃quió'₅ Cristo la₂, tsá₃ jme₂gau₅₄ jniá₂; të₂dsɨ₃ jniá₂ jiog₅ Jme₂dsí₂ Jŋió₅ juá'₂ tság₅ jniá₂ a₂dsón'₂ bá₄ dsau₅;
\v 2 'ŋio₅ lɨn₃ chang₂ go₂'i₃ quɨ'₂ dsɨ₃ co₂tan₅₄,
\v 3 ia₁ ca₂të₂ 'ŋió₃ jniá₂ jme₁'nio₃ jua'₅₄ dsɨ₃'éng₁, rë₂'na₄ jág₁ ja₁con₂ Cristo jua'₅₄ mei'₂ guë́₃ le₂jaun₂, o₄quió'₄ rɨ́ng'₃ dsa₂ go₃ jniá₂ le₃quió'₅ nɨ₁ŋɨ́₅.
\v 4 'Éi₂ bá₄ i₂lɨ́n₅ dsa₂ tsɨ₁jon₂ Israel;\f + \fr 9:4 \ft Israel: co₂'nió'₄ le₃jua'₅₄, Jacob. Génesis 35:10.\f* 'éi₂ bá₄ i₂lɨ́n₅ dsa₂ i₂ca₂guéi'₂ Diú₄ a₂lɨ́in₅ chi'₂-guein₂ quiáin₅; 'éi₂ bá₄ i₂ca₂të́₂ ne₄ a₂tág₅ co₂'né'₅ quió'₅ Diú₄; 'éi₂ bá₄ i₂ca₂lɨ́'₃ jág₁ quian'₅₄ Diú₄; 'éi₂ bá₄ i₂ca₂gue₃ Si₂ 'Éi'₃ ca₂cuë₃ Diú₄; 'éi₂ bá₄ i₂ca₂tɨ́n₂ jme₃ti₃ a₂qui₂jén'₃ ne₄ Diú₄; 'éi₂ bá₄ i₂ca₂cuë₃ Diú₄ jág₁ quió'₅ në́₃.
\v 5 'Éi₂ bá₄ i₂lɨ́n₅ tsɨ₁jon₂ dsa₂ can'₅₄ quián₂ jnia'₅₄ ma₂lɨ́g'₂. Jaun₂ të₂le₃ quian'₅₄ tsɨ₁jon₂ 'éi₂ në́₃, ca₂guan₃ I₂rë₂'ɨ́n₁ quián₅ Diú₄ chi₁dsáin₃, i₂lɨ́n₅ Diú₄ ne₄ quió'₅ ca₂le₃jë́₃, i₂jme₃juɨn'₂ dsa₂ co₂tan₅₄, a₂méi₃.
\p 
\v 6 On₃jua'₅₄ rë'₂ a₂tsá₃ ca₂rë₃ti₃ jág₁ a₂rë₂cuë́₄ quió'₅ Diú₄, ia₁ tsá₃ ca₂le₃jɨ́n₃ dsa₂ tsɨ₁jon₂ Israel lɨ́in₅ të₃dsón'₂ dsa₂ i₂tén₅ juɨg₂ Israel.
\v 7 On₃ guë'₂ lɨ́n₅ ca₂le₃jɨ́n₃ dsa₂ tsɨ₁jon₂ Abraham të₃dsón'₂ chi'₂-guein₂ quián₅ 'éi₂; ia₁ jme₁ca₂juá'₂ Diú₄ ca₂tsɨ́'₃ Abraham: “Të₂le₃ quian'₅₄ Isaac bá₄ ja₃lén₂ tsɨ₁jong'₂”.\f + \fr 9:7 \ft Génesis 21:12.\f*
\v 8 Jág₁ në₅, jein₅ jág₁, on₃jua'₅₄ chi'₂ dsio₄ le₃quió'₅ nɨ₁ŋɨ́₅ i₂lɨ́n₅ chi'₂-guein₂ quián₅ Diú₄; ton'₂ con'₂ i₂lɨ́n₅ guein₂ i₂ca₂rë₃chán₃ lia'₂ con'₂ lë́₅ jág₁ quió'₅ Diú₄ a₂jme₁ma₂cuë₃, jmá'₃ i₂'éi₂ bá₄ i₂jɨ́n₂ Diú₄ i₂lɨ́n₅ të₃dsón'₂ tsɨ₁jon₂ Abraham.
\v 9 Ia₁ jág₁ quió'₅ Diú₄ a₂ca₂cuë́'₃ Abraham, a₂la₂ bá₄ jaun₂: “Jein₂ rë₂në́₃ ŋi₂ caun₂, guio₅₄ jniá₂, jaun₂ le₃chan₂ jan₂ guein₂ quián₅ Sara.”\f + \fr 9:9 \ft Génesis 18:10,14.\f*
\v 10 On₃jua'₅₄ jmá'₃ a₂jaun₂. Qui₂ca₂can₃ Rebeca guein₂ quian'₅₄ jan₂ dsa₂ ŋe'₂ i₂lɨ́n₅ Isaac jmei₂ jnia'₅₄.
\v 11 La₁ tsá₃ jme₁ma₂ca₂rë₃chán₃ guein₂ quián₅ i₁Bé'₄, on₃ guë'₂ a₂'lɨg'₅₄ a₂dse₃ jme₁ma₂tɨin₂ jmo₃, jme₁ca₂jmo₃ Diú₄ jág₁, ia₁jaun₂ të₃'ŋiá₄ a₂ca₂tɨ́n₂ Diú₄ qui₃quió'₂ lia'₂ con'₂ lë́₅ niog₅ dsɨ́₅;
\v 12 on₃jua'₅₄ 'uɨg₅₄ ia₁ a₂jme₂ti₃ dsa₂, të₂le₃ 'uɨg₅₄ ia₁ a₂të́₂ Diú₄; ca₂juá'₂ Diú₄ ca₂tsɨ́'₃ i₁Bé'₄: “I₂lɨ́n₅ i₂juɨn'₂ jme₃ti₃ ne₄ i₂me'₂.”\f + \fr 9:12 \ft Génesis 25:23.\f*
\v 13 Juɨ₁lia'₂ chi₁ton₅ ne₄ Si₂: “Ca₂quio'₄ jniá₂ ca₂jme₁gu'₅₄ quió'₅ Jacob, lë́₅ guë́₄ con'₂ guë́₄ Esaú.”\f + \fr 9:13 \ft Malaquías 1:2-3; lit. “Ca₂jme₁'nió₄ jniá₂ Jacob, Esaú guë'₂ ca₂jme₁'ŋiai₅₄.” \f*
\p 
\v 14 ¿'E₂ bá₄ le₃jua'₅₄ në́₃? ¿On₃ bá₄ tsá₃ rë₂ qui₂dsɨ₅ Diú₄ 'éi'₃? ¡Dsón'₂ on₃jua'₅₄ le₂jaun₂!
\v 15 Ia₁ ca₂tsɨ́'₃ Moisés:
\q1 Dsia₅₄ jniá₂ ŋéi₂ dsɨ₃
\q2 ja₁con₂ i₂'nio₃ jniá₂ dsia₅₄ ŋéi₂ dsɨ₃ quiain'₅₄;
\q1 ján₃ bá₄ jmo₅₄ jniá₂ 'ua₁ dsɨ₃
\q2 ja₁con₂ i₂'nio₃ jniá₂ jmo₅₄ 'ua₁ dsɨ₃ quiain'₅₄.\f + \fr 9:15 \ft Éxodo 33:19.\f*
\m 
\v 16 Le₂në₅ bá₄ jaun₂, on₃jua'₅₄ rë'₂ ia₁ 'nio₃ jan₂ dsa₂, o₃ a₂quɨ́n'₃ bí₂ 'e₂; ton'₂ ia₁ a₂ŋéi₂ dsɨ́₅ Diú₄ bá₄.
\v 17 Ia₁ chi₁ton₅ ne₄ Si₂ 'a₂ lia'₂ ca₂juá'₂ Diú₄ ca₂tsɨ́'₃ Faraón:\f + \fr 9:17 \ft Faraón: co₂'nió'₄ le₃jua'₅₄, rag₅₄ quián₅ 'uë₃ Egipto.\f* “Ta₁ jaun₂ të₃dsón'₂ bá₄ ca₂tság'₂ jniá₂ a₂léng'₂ rag₅₄, ia₁jaun₂ jme₁jnia₅ jniá₂ juɨ₅bí₂ quió₃ të₂le₃ quian'₅₄ 'ne₂, ia₁jaun₂ guë́₄ le₃ŋi₅ dsa₂ ta₁caun₂ gua'₅₄ 'uë₃ 'a₂ lia'₂ lɨ́n₅ jniá₂.”\f + \fr 9:17 \ft Éxodo 9:16.\f*
\v 18 Jaun₂ lë₃, ca₂tɨ́n₂ Diú₄ dsia₃ ŋéi₂ dsɨ́₅ ja₁con₂ chi₂'ein₂ 'nio₃, ton'₂ ján₃ guë'₂ jme₃'ua'₂ dsɨ́₅ chi₂'ein₂ 'nio₃ jme₃'ua'₂ dsɨ́₅.
\v 19 La₁ jaun₂, lé₂ jua'₅₄ juɨg'₅₄ jniá₂: “Chi₂jua'₂ le₂në₅, ¿'e₂ lë₃ cuë́'₅ Diú₄ dso₄ dsa₂, jaun₂ në́₃? Ia₁, ¿'ein₂ bá₄ quɨ'₅₄ jmɨg₄ jné₃ a₂niog₅ dsɨ́₅ Diú₄ jmo₃?”
\v 20 ¡La₁ 'ne₂ në́₃! ¿I₂'ein₂ bá₄ lɨ́n'₅ 'ne₂ dsa₂ mɨ₂güɨ́g₃, jua'₅₄ a₂tsɨ́ng'₄ quian'₅₄ Diú₄? ¿O₃ bá₄ lé₂ le₃juá'₂ juɨ₁lia'₂ nɨ₁tɨ'₂ gua'₅₄, tsɨ́'₃ i₂ca₂jmo₃: “¿'E₂ lë₃ ca₂jmog'₅₄ jniá₂ le₂la₂?”\f + \fr 9:20 \ft Isaías 29:16; 45:9.\f*
\v 21 Juɨ₁lia'₂ jan₂ të₅ i₂jmo₅ tɨ'₂: ¿Tsa₁ ca₂tɨ́in₂ 'uë́'₃ quian'₅₄ ca₂bë'₅₄ ti₁jein₂ caun₂ nɨ₁tɨ'₂ a₂jmó'₂ dsa₂ ta₁ jmá'₃ lia'₂ a₂jlá'₁, caun₂ guë'₂ a₂jmó'₂ dsa₂ ta₁ lia'₂ 'ei₅ ne₅₄ cosa?\f + \fr 9:21 \ft 'Nio'₂ ja₁ton₅ 2 Timoteo 2:20.\f*
\p 
\v 22 ¿'E₂ guë'₂ lé₂ le₃jua'₅₄ 'ne₂ chi₂jua'₂ 'nio₃ Diú₄ jme₃jnia₅ a₂'nei₂, jme₃jnia₅ juɨ₅bí₂ quió'₅ në́₃, la₁ ca₂jmo₃ tió'₃ ca₂jme₃juɨin'₃ dsɨ́₅ 'ŋio₅ lɨn₃ quiain'₅₄ dsa₂ i₂jme₁ca₂tɨ́n₂ gue₃ uɨg₅ i₂jme₁'i₄ 'éi'₃ dsɨ₃'én₂?
\v 23 ¿'E₂ guë'₂ chi₂jua'₂ ca₂jmo₃ Diú₄ le₂jaun₂, ia₁jaun₂ qui₃le₃ŋi₅ dsa₂ a₂jláin'₁ a₂'uain'₂, a₂jme₂jnia₂₃ a₂ŋéi₂ dsɨ́₅ ja₁con₂ dsa₂ i₂ca₂jmói'₂ co₂jŋia₅₄ të₃jŋiá₅, ia₁jaun₂ tɨin₅₄ jë₁tág₅ co₂'né'₅ quió'₅?
\v 24 Jniog₄ bá₄ 'éi₂ i₂ca₂të́'₃ Diú₄, on₃jua'₅₄ jmá'₃ jë₄ quió'₅ dsa₂ judíos; ján₃ bá₄ ca₂të́'₃ dsa₂ jë₄ quió'₅ dsɨ₂nau₂.
\v 25 Juɨ₁lia'₂ juá'₂ ne₄ si₂ quió'₅ Oseas:
\q1 Dsa₂ i₂tsá₃ jme₁lɨ́n₄ dsa₂ juɨg₂ quiáng₃,
\q2 ca₂të́₃ dsa₂ juɨg₂ quiáng₃;
\q1 ján₃ guë'₂ co₂'nió'₄ 'io₅₄ i₂tsá₃ jme₁'nióg₃,
\q2 ca₂të́₃ bá₄ jniá₂ a₂niói₃ guë́₄ lɨn₃.\f + \fr 9:25 \ft Oseas 2:23.\f*
\p 
\v 26 Ján₃ bá₄ juá'₂:
\q1 Co₂dsau₅ jaun₂ ja₁jme₁juá'₂ dsa₂
\q2 a₂tsá₃ lɨ́n'₅ 'nia'₂ dsa₂ quiáng₃,
\q1 ja₁jaun₂ nág'₁ 'nia'₂ a₂të́₂ dsa₂
\q2 a₂lɨ́ng'₅ chi'₂-guein₂ quián₅ Diú₄ jén'₃.\f + \fr 9:26 \ft Oseas 1:10.\f*
\p 
\v 27 La₁ të₂le₃ quió'₅ dsa₂ israelitas në́₃, ca₂juá'₂ Isaías a₂dsen₅₄ dsɨ́₅: “Juɨ₁'a₂ guë́₃ la₂ juɨn₅ lɨn₃ tsɨ₁jon₂ dsa₂ juɨg₂ Israel téin₅ juɨ₁lia'₂ tí₅ ti₁tsag₁ cha₂ chei'₅₄ jmɨ₁ŋí'₄, la₁ me'₂ co₂ŋɨ́₂ bá₄ dsa₂ i₂juɨn₅ 'éi₂ tɨ́n'₄.
\v 28 Ia₁ qui₃dsɨ₅ bá₄ Diú₄ 'éi'₃ ne₄ gua'₅₄ 'uë₃, jme₃ti₃ ca₂le₃jë́₃ co₂ŋei'₅₄.”\f + \fr 9:28 \ft Isaías 10:22-23.\f*
\v 29 Juɨ₁lia'₂ ca₂juá'₂ 'ŋiog₅ Isaías le₂jŋiá₅:
\q1 Jua'₅₄ mei'₂ guë́₃ Te₁gui'₅₄ Juɨg₅₄ 'Lióg₂
\q2 tsá₃ ca₂dsiain₃ tsɨ₁jon₂ dsa₂ go₂ jniog₄,
\q1 le₂jaun₂ bá₄ jme₁dsi₁ŋág₂ jniog₄
\q2 juɨ₁lia'₂ ca₂i₃ŋɨ́₂ dsa₂ juɨg₂ Sodoma quian'₅₄ Gomorra.\f + \fr 9:29 \ft Isaías 1:9.\f*
\s1 Dsa₂ judíos quian'₅₄ jág₁ dse₃
\p 
\v 30 ¿'E₂ le₃jua'₅₄ jniog₄ jaun₂ në́₃? Juɨ₁lia'₂ dsɨ₂nau₂ i₂tsá₃ jme₁'no'₂ juɨ₅ ja₁guei₃ Diú₄ në₂jag₄ bá₄ a₂tsá₃ 'e₂ dso₄ rɨin₂, 'éi₂ bá₄ ma₂lɨ́'₂ juɨ₅ jaun₂, caun₂ juɨ₅ ja₁guéi'₂ Diú₄ në₂jag₄ bá₄ a₂ca₂jme₃ti₃, të₂le₃ a₂jŋia'₅₄ con'₂ a₂'éin₂ bá₄.
\v 31 La₁ dsa₂ juɨg₂ Israel guë'₂ në́₃, i₂jme₁tion'₅₄ 'Éi'₃ ia₁jaun₂ jme₁guéi'₂ Diú₄ 'uɨg₅₄ ia₁ a₂jme₂ti₃, lɨ́in₂, tsá₃ ca₂tió'₃ jme₃ti₃ 'Éi'₃ jaun₂.
\v 32 ¿'E₂ lë₃? Ia₁ jme₁'no'₂ juɨ₅ ja₁guéi'₂ Diú₄ jaun₂, on₃jua'₅₄ të₂le₃ quian'₅₄ a₂'éin₂, të₂le₃ quian'₅₄ a₂jme₁jmo₂₃ guioin₅₄ bá₄. 'Uɨg₅₄ jaun₂ qui₂ca₂niói₃ bá₄ quian'₅₄ “Nɨ₁cang₁ a₂nió₅ dsa₂.”
\v 33 Juɨ₁lia'₂ rë₂ton₅ ne₄ Si₂:
\q1 Ŋí₂ de'₂ 'nia'₂, tsɨn₅₄ jniá₂ jan₂ jë₄ juɨg₂ Sión
\q2 i₂lén₂ në₂jag₄ nɨ₁cang₁ a₂qui₂nió₅ dsa₂,
\q1 ján₃ guë'₂ co₂'nió'₄ nɨ₁'lau₂
\q2 a₂jmo₃ dsɨ₂gan'₅₄ dsa₂;
\q1 jaun₂ juɨ₁lia'₂ i₂'én₂ le₃quió'₅ 'éi₂,
\q2 tsá₃ dsi₁ŋɨ́i₂ o₂guí'₃.\f + \fr 9:33 \ft Isaías 8:14; 28:16.\f*
\c 10
\p 
\v 1 Rɨn'₅₄ jniog₄, a₂'ɨ́n₅ dsɨ₃ 'ŋio₅ lɨn₃, a₂chi₂leng'₅₄ Diú₄ o₄quió'₄ dsa₂ israelitas, ia₁jaun₂ tɨ́in'₄ bá₄.
\v 2 Ia₁ jáng'₅ bá₄ jniá₂ jág₁ dsau₅ ja₁coin₂, a₂dsen₅₄ dsɨ́₅ le₃quió'₅ Diú₄, la₁ia₁ on₃jua'₅₄ jaun₂ ŋɨ́'₂ dsɨ́₅.
\v 3 'Uɨg₅₄ ia₁ a₂tsá₃ ca₂tón'₃ juɨ₅ 'a₂ lia'₂ lë́₅ jaun₂ a₂guéi'₂ Diú₄, jaun₂ qui₂'no'₂ juɨ₅ quió'₅ guioin₅₄ bá₄, tsá₃ ca₂jme₃gó'₃ juɨ₅ a₂ca₂cuë₃ Diú₄.
\v 4 Ia₁ ca₂jme₃'ŋia₅ I₂rë₂'ɨ́n₁ quián₅ Diú₄ 'Éi'₃, ia₁jaun₂ guéi'₂ Diú₄ chi₂jua'₂ 'ein₂ i₂'én₂, në₂jag₄ bá₄ a₂ma₂can₃ caun₂ juɨ₅ co₂dsau₅.
\p 
\v 5 Ia₁ juɨ₁lia'₂ a₂guéi'₂ Diú₄ quió'₅ dsa₂ ia₁ a₂ca₂jme₃ti₃ 'Éi'₃, juá'₂ Moisés ne₄ Si₂: “Në₁jua'₂ ca₂can₃ dsa₂ caun₂ juɨ₅ co₂dsau₅ lia'₂ con'₂ lë́₅ chi₂quióng₂ jmɨg₄ Si₂ 'Éi'₃, të₂le₃ quian'₅₄ 'Éi'₃ jaun₂ le₃chain₂.”\f + \fr 10:5 \ft Levítico 18:5.\f*
\v 6 La₁ juɨ₁lia'₂ juɨ₅ co₂dsau₅ a₂já₅ 'uɨg₅₄ ia₁ a₂'én₂ dsa₂, juá'₂ Si₂ le₂la₂: “Tsá₃ jua'₅₄ 'ne₂ të₂le₃ juɨ₅ 'au'₂: ¿'Ein₂ bá₄ lé₂ le₃uɨ́g₂ guei'₅₄ i₂juɨ́g₃?\f + \fr 10:6 \ft Deuteronomio 30:12.\f* ―co₂'nió'₄ le₃jua'₅₄, ia₁jaun₂ sióin₂ I₂rë₂'ɨ́n₁ quián₅ Diú₄ ja₁con₂ jniog₄―;
\v 7 on₃ guë'₂ jua'₅₄ 'ne₂ ján₃: “¿'Ein₂ bá₄ lé₂ le₃sión₃ ca₂të₂ ja₁ca₂jein₃ chi₁dsio₅₄?”\f + \fr 10:7 \ft Deuteronomio 30:13.\f* ―co₂'nió'₄ le₃jua'₅₄, ia₁jaun₂ chóin'₂ táng₃ I₂rë₂'ɨ́n₁ quián₅ Diú₄, jɨn₄ 'lag₄.
\v 8 ¿La₁ 'e₂ bá₄ guë'₂ juá'₂ Si₂?
\q1 Cong'₂ bá₄ 'nia'₂ 'ei₅ jág₁ la₂,
\q2 'i₄ mɨ₂'o'₅₄, quian'₅₄ juɨ₅ të₂'au'₂,\f + \fr 10:8 \ft Deuteronomio 30:14.\f*
\m co₂'nió'₄ le₃jua'₅₄, jág₁ në₅ bá₄ lë́₅ jág₁ a₂'én₂ dsa₂ a₂qui₂'ë́₅ jnia'₅₄ dsa₂:
\v 9 Chi₂jua'₂ jmo'₂ jág₁ quian'₅₄ mɨ₂'o'₅₄ a₂lɨ́n₅ Jesús Te₁gui'₅₄, ján₃ guë'₂ chi₂jua'₂ 'éng'₂ juɨ₅ të₂'au'₂ a₂ca₂jme₃jein'₅₄ táng₃ Diú₄ a₂jme₁rë₂'lɨin₅₄, tɨ́ng'₄ bá₄.
\v 10 Ia₁ të₂le₃ juɨ₅ të₂dsɨ́₅ bá₄ dsa₂ rë₂'éin₂, ia₁jaun₂ guéi'₂ Diú₄ në₂jag₄ bá₄ a₂ca₂jme₃ti₃; ján₃ guë'₂ le₂jaun₂ të₂le₃ quian'₅₄ 'o₄ dsa₂ jmo₂₃ jág₁ ia₁jaun₂ tɨ́in'₄ bá₄.
\p 
\v 11 Ne₄ Si₂ juá'₂: “Juɨ₁lia'₂ i₂'én₂ le₃quió'₅ 'éi₂, tsá₃ dsɨ₃ŋɨ́i₂ o₂guí'₃.”\f + \fr 10:11 \ft Isaías 28:16.\f*
\v 12 Tsá₃ jma₃quén₅ jág₂ Diú₄ jɨ́in₂ dsa₂ judíos quian'₅₄ guë'₂ dsa₂ griegos; ia₁ 'ŋiog₅ bá₄ 'éi₂ lɨ́n₅ Te₁gui'₅₄ quián₅ ca₂le₃jɨ́n₃, ján₃ guë'₂ jme₂gu'₅₄ cuë₂₃ ca₂lia'₂ 'lióng₂ a₂dse₃ quió'₅, cuë́'₅ ca₂le₃jɨ́n₃ i₂chi₂léi'₂.
\v 13 Ia₁ juá'₂ le₂la₂: “Ca₂le₃jɨ́n₃ i₂chi₂lí'₂ ne₄ Te₁gui'₅₄, tɨ́in'₄ bá₄.”\f + \fr 10:13 \ft Joel 2:32.\f*
\v 14 La₁, ¿'A₂ bá₄ lia'₂ lé₂ chi₃lí'₂ ne₄ jan₂ i₂tsá₃ ma₂ca₂rë₃'éin₂ le₃quió'₅? Ján₃ guë'₂, ¿'a₂ bá₄ lia'₂ le₃'én₂ dsa₂ le₃quió'₅ në₁jua'₂ tsá₃ ma₂nág₂ guë'₂ 'ag₅ dsa₂ 'ɨin₂₃ 'éi₂? ¿'A₂ guë'₂ lia'₂ lé₂ nag₃ dsa₂ në₁jua'₂ tsá₃ 'ein₂ chan₂ i₂'ë́₂ jág₁ dse₃?
\v 15 ¿'A₂ bá₄ lia'₂ lé₂ dsi₁lén₂ i₂'ë́₂ jág₁ dse₃ në₁jua'₂ tsá₃ 'ein₂ chei₅? Juɨ₁lia'₂ ma₂rë₂ton₅ ne₄ Si₂: “¡'E₂ guë́₄ jlá'₁ gu₂-tag₄ i₂quian₅ jág₁ dse₃!”\f + \fr 10:15 \ft Isaías 52:7.\f*
\p 
\v 16 La₁ tsá₃ ca₂le₃jɨ́n₃ dsa₂ ca₂tón'₃ juɨ₅ jág₁ dse₃. Juɨ₁lia'₂ ca₂juá'₂ táng₃ Isaías: “¿Te₁gui'₅₄ 'ein₂ bá₄ i₂ma₂ca₂rë₃'én₂ jág₁ a₂ca₂'ë́₂ jniog₄?”\f + \fr 10:16 \ft Isaías 53:1.\f*
\v 17 Le₂në₅ bá₄ jaun₂, juɨ₁lia'₂ a₂'én₂ dsa₂, lë́₅ të₂le₃ quian'₅₄ a₂nag₅ dsa₂; a₂nag₅ dsa₂ jaun₂, lë́₅ të₂le₃ quian'₅₄ jág₁ quió'₅ I₂rë₂'ɨ́n₁ quián₅ Diú₄.
\p 
\v 18 La₁ ŋag₄ jniá₂, ¿O₃ bá₄ tsá₃ ca₂nág₂ dsa₂ jág₁ dse₃? ¡Ma₁ të₃dsón'₂ bá₄ ca₂nág₂! Ia₁ juá'₂ Si₂:
\q1 Ta₁caun₂ gua'₅₄ 'uë₃ bá₄ ca₂dsia₃ dsa₂;
\q2 ca₂le₂con₂ quióng₄ mɨ₂güɨ́g₃ bá₄
\q2 ma₂ca₂i₃'ág₃ jág₁ quió'₅.\f + \fr 10:18 \ft Salmo 19:4.\f*
\p 
\v 19 La₁ ŋag₄ táng₃ jniá₂, ¿O₃ bá₄ a₂tsá₃ ma₂ca₂rë₃lí'₄ 'e₂ dsa₂ juɨg₂ Israel? Ia₁ jë₁le₂'uɨg₅₄, juá'₂ Moisés:
\q1 Jmo₅₄ jniá₂ a₂lén'₂ 'nia'₂ dsa₂ i₂dsí'₅
\q2 ja₁con₂ dsa₂ i₂tsá₃ juɨg₂ nación lɨ́n₅;
\q1 ján₃ bá₄ jmo₅₄ jniá₂ le₃'ne'₂ 'nia'₂
\q2 o₄quió'₄ caun₂ juɨg₂ i₂tsá₃ ŋɨ́'₂ dsɨ́₅.\f + \fr 10:19 \ft Deuteronomio 32:21.\f*
\p 
\v 20 Con'₂ siá'₂, tiá₂ dsɨ́₅ Isaías a₂juá'₂, o₄quió'₄ Diú₄:
\q1 Dsa₂ i₂tsá₃ jme₁'nau'₂ jniá₂,
\q2 ca₂dsáu'₂ bá₄;
\q1 ca₂jme₁jnia₅ jniá₂
\q2 ja₁con₂ dsa₂ i₂tsá₃ jme₁ŋag₅ jniá₂.\f + \fr 10:20 \ft Isaías 65:1.\f*
\p 
\v 21 La₁ia₁ dsa₂ israelitas bá₄ jme₁tsɨ́'₅ Isaías, jme₁ca₂juá'₂: “Të₁ne₁ jmɨg₄ bá₄ jme₁chén'₄ jniá₂ chi₁jan₁₂ cu₃ ja₁con₂ juɨg₂ cang₄ mɨ₂dsi₄ i₂tsá₃ ne'₅₄.”\f + \fr 10:21 \ft Isaías 65:2.\f*
\c 11
\s1 Dsa₂ Israel i₂tɨ́n'₄
\p 
\v 1 Jaun₂ në́₃ ŋag₄ jniá₂, ¿O₃ bá₄ ma₂chen'₃ cau₅ Diú₄ dsa₂ juɨg₂ Israel quiáin₅? ¡On₃jua'₅₄ le₂jaun₂! Ia₁ 'ŋió₃ bá₄ jniá₂ lɨ́ng₅ jan₂ dsa₂ israelita, jan₂ chi'₂ dsio₄ Abraham, jan₂ tsɨ₁jon₂ Benjamín.
\v 2 Ca₂le₂jŋiá₅ ma₂lɨ́g'₂ lɨn₃ bá₄ ca₂quión'₂ Diú₄ dsa₂ juɨg₂ quiáin₅; jaun₂ rë₂në́₃ në́₃ tsá₃ jua'₅₄ ma₂ca₂téi₂. ¿Tsa₁ ŋi'₅₄ 'nia'₂ 'a₂ lia'₂ juá'₂ ne₄ Si₂ ja₁'ɨin₂₃ Elías, 'a₂ lia'₂ ca₂chi₃léin'₂ Diú₄ a₂ca₂'nɨi₃ dsa₂ Israel? Ca₂juá'₂:
\v 3 “Te₁gui'₅₄, ma₂ca₂jme₃dsian₅ bá₄ dsa₂, dsa₂ i₂jme₁'ë́₂ jág₁ quiáng'₂, ma₂qui₂ma₂'éin₂ ne₄chei₂ quiáng'₂ në́₃; jŋia'₅₄ lia'₂ jan₂ jniá₂ bá₄ chang₂ guë́₄, qui₂co₂'ein₅ dsa₂, ján₃ guë'₂ 'nio₃ jŋag'₃.”\f + \fr 11:3 \ft 1 Reyes 19:10,14.\f*
\p 
\v 4 Jaun₂, ¿'E₂ jág₁ ca₂jéin'₃ Diú₄? “Ma₂ca₂tsón₃ jniá₂ guion₃ mei₅ dsa₂ të₂le₃ quió₃ i₂tsá₃ ma₂qui₂ca₂jón'₂ mɨ₂jne₄ ne₄ Ba'al.”\f + \fr 11:4 \ft 1 Reyes 19:18.\f*
\v 5 Jaun₂ le₂në₅ bá₄ ján₃ rë₂tsón₂ ca₂dsion₄ dsa₂ 'éi₂ rë₂në́₃, jaun₂ Diú₄ në́₃ të₂le₃ ia₁ a₂'ua₁ dsɨ́₅ ma₂quióin'₂ 'éi₂.
\v 6 Chi₂jua'₂ të₂le₃ ia₁ a₂'ua₁ dsɨ́₅ Diú₄, on₃jua'₅₄ jaun₂ ia₁ a₂jmo₅ dsa₂ 'e₂ jmo₂₃. Ia₁ jua'₅₄ mei'₂ guë́₃ le₂në₅ në́₃, tsá₃ le₃jua'₅₄ jua'₅₄ a₂'ua₁ dsɨ́₅ Diú₄.
\v 7 ¿'E₂ jaun₂ në́₃? Tsá₃ ca₂tió'₃ dsa₂ juɨg₂ Israel dsio'₂ a₂jme₁'no'₂, la₁ dsa₂ i₂ca₂quión'₂ Diú₄ 'ŋiog₅ bá₄ ca₂dsáu'₂. I₂sián'₂ guë'₂ qui₂ca₂rë₃'uá'₃ dsɨ́₅,
\v 8 juɨ₁lia'₂ juá'₂ ne₄ Si₂:
\q1 Ca₂jmo₃ Diú₄ a₂le₃tɨn₄ dsa₂ 'éi₂ le₃quió'₅ jme₂dsí₂;
\q2 ca₂cuë₃ mɨ₂ne₅₄ a₂tsá₃ jniá₂,
\q1 ca₂cuë₃ rë₂gua₅₄ a₂tsá₃ nag₅,
\q2 le₂jŋió₄ jmɨg₄ në₃.\f + \fr 11:8 \ft Deuteronomio 29:4; Isaías 19:10.\f*
\p 
\v 9 Ján₃ bá₄ ca₂juá'₂ David:
\q1 Ca₂le₃jë́₃ a₂i₂tsón₃ jme₁cha₂ quió'₅
\q2 juɨ₁le₅₄ co₂'nió'₄ tsɨ₁liá₂ o₃ 'má₅ 'e₂,
\q2 ia₁jaun₂ qui₃niói₃, gue₃ 'liain'₅₄.
\q1 
\v 10 Juɨ₁le₅₄ tsá₃ jnió'₅ mɨ₂ne₅₄
\q2 juɨ₁guen'₅₄ mɨ₂ca'₅₄ co₂ŋei'₅₄.\f + \fr 11:10 \ft Salmo 69:22-23.\f*
\s1 Dsɨ₂nau₂ i₂tɨ́n'₄
\p 
\v 11 Ŋag₅ jniá₂ në́₃, ¿O₃ bá₄ co₂ŋei'₅₄ con'₂ ca₂sén'₂ jaun₂ bá₄ dsa₂ judíos jme₁ca₂niói₃? ¡On₃jua'₅₄ le₂jaun₂! Të₂le₃ jen₅ bá₄, jme₁ca₂i₃lén₂ dsa₂ judíos ca₂i₁juɨin₅₄, ca₂jmo₃ Diú₄ a₂ca₂dsó'₂ dsɨ₂nau₂ juɨ₅ ja₁tɨ́in'₄, ia₁jaun₂ le₃dsí'₅ 'éi₂.
\p 
\v 12 La₁ chi₂jua'₂ a₂ca₂i₁juɨn₅₄ 'éi₂ jaun₂, ca₂dsióg₃ të₂le₃ dse₃ bá₄ o₄quió'₄ dsa₂ mɨ₂güɨ́g₃, ján₃ bá₄ chi₂jua'₂ a₂ca₂i₃'én₂ quió'₅ 'éi₂, ca₂dsióg₃ a₂të₁dsɨ₅₄ quió'₅ dsɨ₂nau₂, ¡'e₂ guë́₄ dse₃ lé₂, jë₁ma₂ca₂rë₃'ŋia₅ táng₃ 'éi₂!
\p 
\v 13 La₁ a₂juá'₅ jniá₂ juɨ́g₂ 'nia'₂ i₂lɨ́n'₅ dsɨ₂nau₂: Ia₁ dsón'₂ lɨ́n₅ jniá₂ jan₂ dsa₂ i₂chen₄ ja₁con₂ dsɨ₂nau₂, jmo₅ jniá₂ dsɨ₃ 'ŋio₅ lɨn₃ dsen₅₄ ta₁ quió₃,
\v 14 con'₂ tsá₃ ŋó₅ në₁jua'₂ ca₂rë₃dsí'₅ dsa₂ go₃ jniá₂ ja₁con'₂ 'nia'₂, jaun₂ lé₂ lión₂ i₂lɨn₅₄ 'éi₂.
\v 15 Chi₂jua'₂ jme₁ca₂téi₂ Diú₄ quió'₅ dsa₂ judíos, ca₂lɨ́'₃ dsa₂ mɨ₂güɨ́g₃ a₂ca₂'ág₂ caun₂ jág₁ quian'₅₄ Diú₄, ¿'e₂ bá₄ lé₂ jaun₂ në́₃ jë₁ma₂të́₂ rë₁guéi'₂ Diú₄ quió'₅ dsa₂ 'éi₂? Lé₂ co₂'nió'₄ ca₂gue₃ táng₃ jme₂dsí₂ dsa₂ i₂jme₁ma₂rë₂'lɨn₄.
\p 
\v 16 Chi₂jua'₂ lë́₅ 'í₁ juɨ₁lia'₂ i₁ŋí'₄ a₂le₂'uɨg₅₄ a₂jén'₅ dsa₂ ne₄ Diú₄, ján₃ bá₄ le₂jaun₂ lë́₅ 'í₁ ta₁jë₂ ti₁can₁; ján₃ bá₄ chi₂jua'₂ lë́₅ 'í₁ le₃quió'₅ Diú₄ juɨ₁lia'₂ jmú₄ caun₂ nɨ₁'ma₂, ján₃ bá₄ le₂jaun₂ lë́₅ 'í₁ nɨ₁gu'₂ nei'₅₄ nɨ₁'ma₂ ján₃.
\p 
\v 17 Dsa₂ judíos i₂ca₂téi₂ Diú₄ 'éi₂ në́₃, lɨ́in₅ co₂'nió'₄ gu'₂-nei'₅₄ nɨ₁'ma₂ olivo a₂chein'₅₄, a₂ca₂uɨ́n'₂ a₂lɨn₅₄ nɨ₁gu'₂; në₃ në́₃, chi₂jua'₂ lɨ́n'₅ 'ne₂ jan₂ dsɨ₂nau₂ i₂ma₂rë₂'lión₅, në₂jag₄ bá₄ caun₂ nɨ₁gu'₂ olivo a₂cha₂ ja₁nau₂, ma₂qui₂ma₂guión'₃ jmɨ'₅₄ nɨ₁'ma₂ olivo a₂qui₂jme₂tan₅₄ nɨ₁gu'₂,
\v 18 tsá₃ jmó'₂ táng'₅ ja₁con₂ nɨ₁gu'₂ siá'₂. Chi₂jua'₂ le₂jaun₂ jmó'₂, dsá₂ 'au'₂ jmo₄, on₃jua'₅₄ 'ne₂ jme₂tang'₅₄ jmú₄; jmú₄ bá₄ jme₂tau₅₄ 'ne₂.
\p 
\v 19 Mei'₂ tsá₃ le₃ŋag'₅₄ 'ne₂, jaun₂ në́₃: “Ján₅, dsau₅ bá₄ në₅. La₁ia₁ a₂ca₂uɨ́n'₂ nɨ₁gu'₂ jaun₂ ia₁jaun₂ lén₂ jniá₂ jan₂ i₂rë₂'lión₅ ja₁jme₁ca₂tɨ́in₂.”
\v 20 Dse₃, la₁ ca₂uɨ́n'₂ nɨ₁gu'₂ jaun₂ 'uɨg₅₄ ia₁ a₂tsá₃ jme₁'éin₂, la₁ 'ne₂ guë'₂ në́₃ të₂'ŋiág'₄ 'uɨg₅₄ ia₁ a₂'éng'₂. Le₂në₅ bá₄ jaun₂, juɨ₁le₁gan'₃ 'nia'₂, tsá₃ lë₁jmo₂ róng'₂.
\v 21 Ia₁ chi₂jua'₂ tsá₃ ca₂dsia₃ Diú₄ ŋéi₂ dsɨ́₅ ja₁con₂ nɨ₁gu'₂ quió'₅ të₃dsón'₂ nɨ₁'ma₂ jaun₂, ján₃ bá₄ le₂jaun₂ tsá₃ dsia₃ ŋéi₂ dsɨ́₅ ja₁con'₂ 'ne₂ ján₃.
\p 
\v 22 Jag₄ jaun₂, 'e₂ guë́₄ dsen₃ Diú₄, la₁ ján₃ bá₄ rë₂ qui₂dsɨ₂₃ 'éi'₃. Ia₁ ma₂qui₂dsɨ₂₃ 'éi'₃ ja₁con₂ i₂ma₂ca₂sén'₂, la₁ dsein₃ bá₄ quian'₅₄ 'ne₂, chi₂jua'₂ caun₂ náu'₁ tiá₂ juɨ₅ ja₁'ua₁ dsɨ́₅ Diú₄. Ia₁ në₁jua'₂ tsá₃ le₂jaun₂, ján₃ bá₄ quéin'₂ 'ne₂.
\p 
\v 23 Juɨ₁lia'₂ 'éi₂ në́₃, në₁jua'₂ ca₂rë₃'éin₂ táng₃, lé₂ bá₄ le₃'lióin₃. Ia₁ 'io₅ Diú₄ bí₂ chóng'₃ táng₃.
\v 24 Ia₁ në₁jua'₂ 'ne₂, jan₂ dsɨ₂nau₂, co₂'nió'₄ caun₂ nɨ₁gu'₂ nau₂, ca₂queng'₃ dse₃ quian'₅₄ nɨ₁'ma₂ olivo a₂chein'₅₄, o₁jŋia'₅₄ lɨ́ng'₅ nɨ₁gu'₂ nɨ₁'ma₂ siá'₂, ¡'e₂ guë́₄ tson₂ lé₂ le₃quen'₃ 'éi₂, i₂lɨ́n₅ co₂'nió'₄ nɨ₁gu'₂ a₂caun₂ ne₅₄ quian'₅₄ nɨ₁'ma₂ olivo jaun₂!
\s1 A₂tɨ́n'₄ dsa₂ juɨg₂ Israel
\p 
\v 25 Rɨn'₅₄ jniog₄, tsá₃ 'nio₃ jniá₂ jua'₅₄ tsá₃ ŋi'₅₄ 'nia'₂ jág₁ a₂jme₁rë₂'ma₄ la₂, con'₂ tsá₃ ŋó₅ në₁jua'₂ ca₂jmo'₅₄ 'nia'₂ róng'₂ quian'₅₄ a₂ŋɨ́'₂ 'au'₂ 'nia'₂ guiong'₅₄. Juɨ₁lia'₂ ma₂jmo₃ i₂lɨn₅₄ dsa₂ juɨg₂ Israel, ca₂rë₃'uá'₃ dsɨ́₅, ca₂lia'₂ ca₂rë₃'ŋia₅ dsɨ₂nau₂ i₂con'₂ ca₂tɨ́n₂ tón'₃.
\v 26 Jaun₂ guë́₄ lión₂ ca₂le₃jɨ́n₃ dsa₂ juɨg₂ Israel, ia₁ juá'₂ ne₄ Si₂:
\q1 O₃'ɨn₅ dsa₂ i₂lió₂ juɨg₂ Sión,\f + \fr 11:26 \ft Sión: co₂'nió'₄ le₃jua'₅₄, juɨg₂ Jerusalén.\f*
\q2 co₂dsia₅ jŋiá'₂ a₂tsá₃ dse₃ jmo₅ tsɨ₁jon₂ Jacob.
\q1 
\v 27 Jaun₂ a₂la₂ bá₄ jág₁ quió₃ jmo₅₄ quiang'₅₄ dsa₂ 'éi₂:
\q2 jë₁ma₂të́₂ rë₁'éng₄ dsáu₁.\f + \fr 11:27 \ft Isaías 59:20-21; 27:9.\f*
\p 
\v 28 Juɨ₁lia'₂ të₂le₃ quian'₅₄ jág₁ dse₃ a₂lión₂ dsa₂, lɨ́in₅ co₂'nió'₄ dsa₂ i₂'ŋia₅₄ Diú₄, o₄quián'₂ 'nia'₂; la₁ lia'₂ ma₂'nio₃ jaun₂ bá₄ Diú₄ quió'₅ dsa₂ 'éi₂, ia₁ a₂ca₂quióin'₂ dsa₂ can'₅₄ quiáin₅ ma₂lɨ́g'₂.
\v 29 Ia₁ tsá₃ dsɨ₂quén'₅ dsɨ́₅ Diú₄ juɨ₁lia'₂ a₂cuë₂₃, on₃ guë'₂ juɨ₁lia'₂ a₂të́₂.
\v 30 Juɨ₁lia'₂ 'nia'₂ në́₃, i₂tsá₃ jme₁ne'₅₄ ja₁con₂ Diú₄ le₂jŋiá₅, ma₂ca₂tɨ́n'₂ 'nia'₂ a₂ŋéi₂ dsɨ́₅ Diú₄ rë₂në́₃, 'uɨg₅₄ ia₁ a₂tsá₃ ne'₅₄ dsa₂ 'éi₂,
\v 31 ján₃ bá₄ le₂në₅ tsá₃ ne'₅₄ dsa₂ 'éi₂ rë₂në́₃, ia₁jaun₂ të₂le₃ quian'₅₄ a₂ŋéi₂ dsɨ́₅ Diú₄ a₂ca₂tɨ́n'₂ 'nia'₂, tɨin₅₄ ján₃ a₂ŋéi₂ dsɨ́₅ Diú₄.
\v 32 Ia₁ Diú₄ në́₃ co₂rë₂ bá₄ 'ɨin₃ dsa₂ a₂tsá₃ ne'₅₄ dsa₂ le₂jain₂ le₂jain₂, ia₁jaun₂ co₂dsia₅ bá₄ dsia₃ ŋéi₂ dsɨ́₅ ja₁con₂ ca₂le₃jɨ́n₃.
\q1 
\v 33 ¡'E₂ guë́₄ 'ŋio₅ 'ei₄ lë́₅ ca₂le₃jë́₃ a₂jlá'₁ cha₂ quió'₅ Diú₄,
\q2 ca₂le₃jë́₃ a₂ŋɨ́'₂ dsɨ́₅, a₂ŋi₅ në́₃!
\q1 Ca₂lia'₂ tsá₃ lé₂ le₃quiong₅₄ 'í₁ a₂niog₅ dsɨ́₅,
\q2 on₃ guë'₂ lé₂ le₃ŋág'₂ dsɨ₅ juɨ₅ quió'₅.
\q1 
\v 34 “¿'Ein₂ bá₄ cuɨ́'₅ 'e₂ dsɨ₂jiog₅ dsɨ́₅ Te₁gui'₅₄,
\q2 o₃ 'ein₂ i₂ma₂tió'₃ cuë₃ jág₁ dse₃ cuë́'₃ 'éi₂?”\f + \fr 11:34 \ft Isaías 40:13.\f*
\q1 
\v 35 “¿'Ein₂ bá₄ ca₂cuë₃ 'e₂ ca₂cuë́'₃ 'éi₂ le₂'uɨg₅₄
\q2 ia₁jaun₂ jéin'₃ quí₃ quió'₅?”\f + \fr 11:35 \ft Job 41:11.\f*
\q1 
\v 36 Ia₁ ca₂le₃jë́₃ a₂niog₅ cha₂, ca₂lë₃
\q2 ja₁con₂ 'éi₂, të₂le₃ quian'₅₄ 'éi₂, o₄quió'₄ 'éi₂ në́₃.
\q1 ¡Juɨ₁jme₂juag'₂ bá₄ dsa₂ co₂tan₅₄! A₂méi₃.
\c 12
\s1 'A₂ lia'₂ i₂nio₄ dsa₂ i₂rë₂tson₄ quián₅ Diú₄
\p 
\v 1 Le₂në₅ bá₄ jaun₂ rɨn'₅₄ jniog₄, të₂le₃ quian'₅₄ a₂ŋéi₂ dsɨ́₅ Diú₄, mɨ₅ jniá₂ ne'₅₄ 'nia'₂, co₂dsia₅ jɨn'₄ 'nia'₂ nɨ₁ŋɨ'₁ guiong'₅₄, co₂'nió'₄ a₂rë₂jeng'₅₄ le₁jén'₃ ne₄ Diú₄, a₂rë₂tsong'₅₄, a₂'ŋio₂ dsɨ́₅ Diú₄, a₂dsi₂ten₅₄ jme₁ti'₄ ne₅₄.
\v 2 Tsá₃ i₁nio'₄ 'nia'₂ lia'₂ con'₂ lë́₅ i₂nio₄ dsa₂ mɨ₂güɨ́g₃ la₂. Të₂le₃ cuë₄ jmɨg₄ a₂jme₃tsɨ́n₃ Diú₄ 'a₂ lia'₂ qui₂dsɨ₂jŋia₅ 'au'₂ 'nia'₂, ia₁jaun₂ bá₄ qui₃le₃'mag'₂ táng₃ 'au'₂, ia₁jaun₂ lé₂ le₃caun'₅₄ 'nia'₂ 'í₁ 'a₂ lia'₂ lë́₅ a₂'ŋio₂ dsɨ́₅ Diú₄, a₂dse₃, a₂të₅ dsɨ́₅, a₂rë₂'ŋia₅ në́₃.
\p 
\v 3 Ia₁ o₄quió'₄ a₂'ua₁ dsɨ́₅ Diú₄ a₂ma₂dsia₃ gu₃ jniá₂, juɨ́g₂ jniá₂ le₂jan'₂ le₂jan'₂ 'nia'₂: tsá₃ lë₁juɨ₁qui₂dsi₂jŋia₅ 'au'₂ a₂lɨ́ng'₅ dseng'₅₄ ŋag₅₄ guë́₄ con'₂ ca₂tɨ́n'₂ 'nia'₂ dsɨ₃jŋia₅ 'au'₂; të₂le₃ juɨ₁qui₂dsi₃jiog₅ bá₄ 'au'₂ a₂'en₅₄ 'au'₂ 'nia'₂, 'a₂ con'₂ tí₅ ma₂ca₂rë₃'én'₂ 'nia'₂ a₂ma₂cuë₃ Diú₄.
\v 4 Ia₁ le₂në₅ juɨ₁lia'₂ lë́₅ caun₂ nɨ₁ŋɨ₁ jniog₄ le₂jau₂ le₂jau₂, 'lióng₂ a₂chei₂ le₂caun₂ le₂caun₂ a₂tén₅ quió'₅, tsá₃ ca₂ne₅₄ ta₁ jme₂ti₃,
\v 5 le₂në₅ bá₄ jniog₄ ján₃, juɨ₁'a₂ guë́₃ la₂ juag₅ jniog₄, caun₂ bá₄ nɨ₁ŋɨ₁₂ jniog₄ lág₅ le₃quió'₅ Cristo, téi₅ jniog₄ le₂jau₂ le₂jau₂ quian'₅₄ rɨn'₅₄.
\p 
\v 6 Jma₃quén₅ bá₄ qui₂'au₂ jniog₄ bí₂, lia'₂ con'₂ lë́₅ ma₂cuë₃ Diú₄ a₂'ua₁ dsɨ́₅. Jaun₂ ca₂tág₂ jniog₄ jmo'₄ ta₁ juɨ₅bí₂ a₂ma₂cuë₃. Juɨ₁lia'₂ dsa₂ i₂ma₂cuë₃ Diú₄ bí₂ a₂tɨin₂ a₂'ë́₂ jág₁ dse₃ a₂gue₂₃ quió'₅ Diú₄, juɨ₁'ë₅₄ bá₄ jág₁ 'a₂ con'₂ tí₅ a₂'éin₂;
\v 7 juɨ₁lia'₂ i₂ma₂cuë́'₃ juɨ₅bí₂ jme₃'o₅₄, juɨ₁jme₂'o₅₄; juɨ₁lia'₂ i₂'io₅ bí₂ jme₃tag₂₃, juɨ₁jme₂tɨin₂₃ bá₄ dsa₂;
\v 8 juɨ₁lia'₂ i₂tɨn₂ jmo₃ lián'₂ dsɨ́₅ i₂sián'₂, ca₂tɨ́in₂ bá₄ jmo₃ le₂jaun₂; juɨ₁lia'₂ i₂jmo₅ dsióg₁, juɨ₁cuë₁₂ a₂'ua₁ dsɨ́₅, on₃jua'₅₄ rë'₂ cha₂ a₂'ɨ́n₂ dsɨ́₅ 'ŋiog₅; juɨ₁lia'₂ i₂quian₅ ne₄ juɨ₅, juɨ₁jmo₁₂ bá₄ a₂dsen₅₄ dsɨ́₅; juɨ₁lia'₂ i₂dsia₅ ŋéi₂ dsɨ́₅, juɨ₁jmo₁₂ bá₄ quian'₅₄ o₂'ŋió₃ o₂jŋia₃ dsɨ́₅.
\s1 'A₂ lia'₂ ca₂tɨ́n₂ le₃chan₂ dsa₂ quián₅ Cristo
\p 
\v 9 Juɨ₁le₂chan'₂ 'nia'₂ të₃dsón'₂ bá₄ a₂'nió'₃ 'nia'₂ rɨ́ng'₂ le₂jang'₂ le₂jang'₂. Co₂dsia₅ jmo₄ 'nia'₂ 'ŋiag'₅₄ co₂ŋei'₅₄ a₂'lɨg'₅₄; chan'₂ bá₄ 'nia'₂ tiá₂ juɨ₁lia'₂ a₂dse₃.
\v 10 Jme₁'nió'₄ 'nia'₂ rɨ́ng'₂ a₂'ŋio₂ 'au'₂; jmo₄ 'nia'₂ a₂dsen₅₄ guë́₄ rɨ́ng'₂ le₂jang'₂ le₂jang'₂.\f + \fr 12:10 \ft o₃, “jme₁li₅₄ të₃jŋiá₅ a₂jme₂gan'₃ 'nia'₂ rɨ́ng'₂ le₂jang'₂ le₂jang'₂.” \f*
\p 
\v 11 Tsá₃ jmo₂ 'nia'₂ juɨ́ng'₅, 'ag₃ caun₂-tɨn₃ 'au'₂, të₂le₃ jme₁ti₁ ne₄ Te₁gui'₅₄ ca₂lia'₂ dsen₅₄ jme₂dsí₂ quiáng'₂.
\p 
\v 12 Juɨ₁chan'₂ 'nia'₂ o₂jŋia₃ 'au'₂, ia₁ ma₂lë́₅ bá₄ co₂jŋia₅₄ a₂'ɨ́n₂ 'au'₂ 'nia'₂. Jmo₄ 'nia'₂ juɨn'₂ 'au'₂ jmɨg₄ jme₁chan'₂ 'nia'₂ o₂i₁ dsɨ₅. O₁nió'₄ bá₄ 'nia'₂ co₂tan₅₄ a₂chi₂leng'₅₄ Diú₄.
\p 
\v 13 Jme₁'on₁ 'nia'₂ dsa₂ 'én₂ rɨ́ng'₂ chi₂jua'₂ 'e₂ niog₅ cha₂ a₂'nió'₅ quió'₅. Dse₃ guen₅₄ 'nia'₂ juɨ₁lia'₂ 'ein₂ niog₅ qui₂dsɨ₂jag₅₄ 'nia'₂.
\p 
\v 14 Jme₁gu'₅₄ bá₄ 'nia'₂ juɨ₁lia'₂ i₂jmóg'₂. Jua'₅₄ bá₄ 'nia'₂ jág₁ dse₃ on₃jua'₅₄ jág₁ uɨg₅.
\p 
\v 15 Jmo₄ 'nia'₂ 'io'₂ quian'₅₄ juɨ₁lia'₂ i₂jmo₅ 'io'₂; ján₃ guë'₂ quɨ'₂-'o₄ 'nia'₂ quian'₅₄ i₂'o₅.
\p 
\v 16 Juɨ₁le₂chan'₂ bá₄ 'nia'₂ a₂jeng'₂ le₂jang'₂ le₂jang'₂. Tsá₃ jmo₂ 'nia'₂ róng'₂, co₂rɨn'₂ bá₄ 'nia'₂ jmo₄ quiang'₅₄ dsa₂ te₂ŋé₂. Tsá₃ lë₁jmo₂ 'nia'₂ jua'₅₄ a₂ŋɨ́₄ lë₃ cuɨng'₂.
\p 
\v 17 Tsá₃ jein'₅₄ 'nia'₂ 'lɨg'₅₄ quian'₅₄ a₂'lɨg'₅₄. Quen'₂ 'nia'₂ bí₂ jmó'₂ con'₂ dsi₂ten₅₄ ja₁të₃ ne₄ ca₂le₃jɨ́n₃.
\v 18 Jmo₄ 'nia'₂ bí₂, 'a₂ con'₂ ca₂tɨ́ng'₂, 'a₂ con'₂ ja₁quɨ'₅₄ 'nia'₂ jmɨg₄, 'nau'₅₄ 'nia'₂ juɨ₅ ja₁'ag₃ tei₄ quian'₅₄ ca₂le₃jɨ́n₃.
\v 19 Rɨn'₅₄ jniog₄, tsá₃ lë₁jen'₅₄ 'nia'₂ guiong'₅₄ juɨ₁lia'₂ quió'₅ i₂jmóg'₂, të₂le₃ dsia₄ 'nia'₂ o₄gú₃ Diú₄ a₂jaun₂. Ia₁ ma₂rë₂ton₅ ne₄ Si₂: “Jniá₂ bá₄ ca₂tɨ́ng₂ jein'₅₄ uɨg₅; jniá₂ bá₄ quɨ́₄, juá'₂ Te₁gui'₅₄.”\f + \fr 12:19 \ft Deuteronomio 32:35.\f*
\v 20 La₁: “Chi₂jua'₂ i₁cón'₅ juɨ₁lia'₂ dsa₂ i₂'iog₅₄, cuë'₅₄ bá₄ 'nia'₂ a₂guë́'₃. Chi₂jua'₂ ŋɨ₂₃ rë₂quein₂ dsɨ́₅, cuë'₅₄ a₂'ɨ́n'₂. Ia₁ jë₁ma₂ca₂jmo'₅₄ le₂në₅, jmai'₅₄ tsáu₃ dséi₂ dsɨ₂ne₅₄,\f + \fr 12:20 \ft lit. “jmó'₂ nio₃ nɨ₁ta'₂ le₁guí'₂ si₂ ne₄ mɨ₂dsi₅₄.” \f* jéin'₄ o₂guí'₃.”\f + \fr 12:20 \ft Proverbios 25:21-22.\f*
\v 21 Tsá₃ cuɨ́n₅ jmɨg₄ jua'₅₄ a₂jo₃ a₂'lɨg'₅₄; të₂le₃ quen'₂ bí₂, tión₃ 'uë₃ a₂'lɨg'₅₄ të₂le₃ quian'₅₄ a₂dse₃.
\c 13
\p 
\v 1 Ca₂le₃jɨ́n₃ bá₄ ca₂tɨ́n₂ tón'₃ 'éi'₃ quió'₅ dsɨ₂tan₅₄ i₂gon₂. Ia₁ 'i₁jan₂ dsɨ₂tan₅₄ i₂chan₂, jua'₅₄ tsá₃ ca₂chei'₃ Diú₄. Jaun₂ ca₂le₃jɨ́n₃ dsɨ₂tan₅₄ i₂chan₂ në́₃, i₂dsián₁ quián₅ Diú₄ bá₄ 'éi₂.
\v 2 Jaun₂ le₂në₅, juɨ₁lia'₂ i₂nau₂ quen₅ ja₁con₂ dsɨ₂tan₅₄, nau₂ quein₂₃ ja₁con₂ i₂dsián₁ quián₅ Diú₄ bá₄. Jaun₂ gue₃ uɨg₅ juɨ₁lia'₂ i₂jmo₅ le₂jaun₂.
\v 3 Ia₁ tsá₃ ta₁ jaun₂ dsián₄ dsɨ₂tan₅₄ a₂jmo₃ gó'₅ juɨ₁lia'₂ i₂jmo₅ a₂dse₃; a₂jmo₃ gó'₅ dsa₂ i₂jmo₅-dsáu₅ a₂'lɨg'₅₄ bá₄. ¿'Niog'₂ 'ne₂ le₃chang'₂ a₂tsá₃ gang'₃ dsɨ₂tan₅₄? Jmo₄ bá₄ a₂dse₃, jaun₂ con₂ 'í₁ dsɨ₂tan₅₄ ja₁cong'₂, a₂lɨ́ng'₅ dsa₂ dsen₃.
\v 4 Ia₁ ta₁ jaun₂ tiáin'₅ jme₂ti₃ ne₄ Diú₄ bá₄, a₂dse₃ quiáng'₂. La₁ në₁jua'₂ ca₂jmo'₅₄ a₂'lɨg'₅₄ në́₃, ca₂tɨ́ng'₂ le₃gang'₃, ia₁ on₃jua'₅₄ a₂lë₁lë́₄ 'io₅ dsɨ₂tan₅₄ 'éi'₃ a₂chain₂ bí₂ cuë₃ uɨg₅. Jan₂ i₂jme₂ti₃ ne₄ Diú₄ bá₄ 'éi₂, a₂'ë́₂ uɨg₅ ja₁con₂ dsa₂ i₂jmo₅ a₂'lɨg'₅₄.
\v 5 Jaun₂ lë₃, tion₅₄ bá₄ 'nió'₅ tón'₃ dsa₂ 'éi'₃ quió'₅ dsɨ₂tan₅₄, on₃jua'₅₄ rë'₂ a₂jŋia'₅₄ ia₁jaun₂ tsá₃ gue₃ uɨg₅; të₂le₃ ia₁ a₂lë́₅ dsɨ́₅ le₂jaun₂ jmo₂₃ a₂dse₃.
\v 6 'Uɨg₅₄ në₅ bá₄ quɨ́'₂ 'nia'₂ 'lia'₅₄ a₂ca₂tɨ́n₂ dsɨ₂tan₅₄, ia₁ ca₂ne₅₄ jme₂ti₃ dsɨ₂tan₅₄ ta₁ a₂lɨ́in₅ ne₄ Diú₄.
\p 
\v 7 Cuë'₅₄ bá₄ 'nia'₂ dsa₂ 'e₂ niog₅ qui₂ca₂tɨ́in₂. Chi₂jua'₂ ca₂tɨ́n₂ dsɨ₂tan₅₄ 'lia'₅₄, qui₄ 'lia'₅₄; chi₂jua'₂ ca₂tɨ́in₂ mɨ₃ cu₄ te₁'éng'₂, cuë'₅₄ cu₄ jaun₂; chi₂jua'₂ 'ein₂ ca₂tɨ́n₂ jme₃go₃ dsa₂, jme₁gan₃ bá₄ 'éi₂; chi₂jua'₂ 'ein₂ ca₂tɨ́n₂ jme₃juag'₂ dsa₂, jme₁juɨin'₂ bá₄.
\v 8 Ja₁con₂ 'i₁jan₂ tsá₃ juɨ₁le₅₄ jua'₅₄ cha₂ a₂qui₂le₂rɨn'₂ 'nia'₂ uë́₂, jŋia'₅₄ lia'₂ a₂qui₂le₂rɨng'₂ a₂'nióg'₃ rɨ́ng'₂ le₂jang'₂ le₂jang'₂ bá₄; ia₁ juɨ₁lia'₂ i₂'nio₃ dsa₂ mɨ₂güɨ́g₃ rɨn'₅₄, ma₂ca₂jme₃ti₃ 'Éi'₃ quió'₅ Diú₄.
\v 9 Juá'₂ 'Éi'₃ quió'₅ Diú₄: “Tsá₃ nióg'₄ jág₁ quian'₅₄ i₂tsá₃ lɨ́n₅ dsɨ₂i₂gog'₂; tsá₃ jŋɨ́g'₄ dsa₂ mɨ₂güɨ́g₃ rɨ́ng'₂; tsá₃ 'áng'₁; tsá₃ jmó'₂ jág₁ të₂jág₁; tsá₃ jmó'₂ 'ɨ́n₅ 'au'₂ a₂quió'₅ i₂sián'₂.”\f + \fr 13:9 \ft Éxodo 20:13-15,17; Deuteronomio 5:17-19,21.\f* 'Éi'₃ në₅ quian'₅₄ guë́₄ ca₂le₃jë́₃ 'éi'₃ siá'₂ në́₃, qui₂rë₂tan₅₄ quian'₅₄ jág₁ la₂: “Jme₁'nió₄ dsa₂ mɨ₂güɨ́g₃ rɨ́ng'₂ juɨ₁lia'₂ 'nióg'₃ 'ŋiag'₂.”\f + \fr 13:9 \ft Levítico 19:18.\f*
\p 
\v 10 Juɨ₁lia'₂ dsa₂ i₂'nio₃ dsa₂ mɨ₂güɨ́g₃ rɨn'₅₄, tsá₃ 'e₂ 'lɨg'₅₄ jmo₂₃ ja₁coin₂. Le₂në₅ bá₄ jaun₂ ja₁'nio₃ dsa₂ rɨin'₅₄, co₂'nió'₄ ca₂rë₃ti₃ bá₄ 'Éi'₃ quí'₅ Si₂.
\p 
\v 11 Jë₄ ca₂le₃jë́₃ a₂në₅ në́₃, jmo₄ a₂ŋɨ́'₂ 'au'₂ juɨ₁lia'₂ jmɨg₄ chong₂ rë₂në́₃, a₂ma₂ca₂të́₂ hora a₂ŋéi₂ jniog₄ jë₄ le₁guág₃. Ia₁ jë₁lió₂ jniog₄ caun₂ ma₂ja₂quián₃ co₂ŋɨ́₂ bá₄ rë₂në́₃ lia'₂ con'₂ guë́₄ jme₁ca₂rë₃'éin₂ jniog₄ le₂'uɨg₅₄.
\v 12 Juɨ₁lia'₂ jë₄ 'uë₂ la₂ caun₂ qui₂dsɨ₂juɨn₅₄ bá₄; caun₂ ma₂ja₂quián₃ jnia₅₄ bá₄. 'Uɨg₅₄ jaun₂ bá₄ ca₂tág₂ jniog₄ tí₄ a₂tsá₃ ma₃jmó₁ juɨ₁lia'₂ a₂lë́₂ jë₄ qui₁né'₃, a₂quián₁ qui'₅₄ ca₂le₃jë́₃ a₂'nió'₅ quián₂, a₂jmo₅ 'í₁, a₂i₁nio₁ juɨ₁lia'₂ 'lióg₂ i₂i₂nio₄ jë₄ jniá₂ si₂.
\v 13 Juɨ₁i₁nio₁ jniog₄ lia'₂ con'₂ dsi₂ten₅₄, juɨ₁lia'₂ i₂nio₄ dsa₂ a₂jmɨ₂. Tsá₃ ma₃'nió'₅ le₃chong₂ i₁nio₁ le₁'ein₅, on₃ guë'₂ o₂'ŋió₃ o₂jŋia₃ dsɨ₅, on₃ guë'₂ nió'₄ jniog₄ jág₁ quian'₅₄ i₂tsá₃ lɨ́n₅ dsɨ₂i₂gu₂ jniog₄, on₃ guë'₂ jmó₁ a₂tsá₃ dsi₂ten₅₄, on₃ guë'₂ dsiá₁ mɨ'₅₄, on₃ guë'₂ qui₁jɨn₁ uɨn₅ dsɨ₅ rɨn'₅₄ në́₃.
\v 14 Të₂le₃ qui'₂ 'nia'₂ co₂'nió'₄ a₂qui₂rë₂lión'₃ 'nia'₂ lë́₅ 'í₁ të₂le₃ quian'₅₄ 'ŋiog₅ Te₁gui'₅₄ Jesucristo, tsá₃ ma₃juɨ₁dsi₂jiog₅ guë́₄ 'au'₂ 'a₂ lia'₂ mag'₂ dsɨ́₅ a₂mɨ₅ nɨ₁ŋɨ'₁ 'nia'₂.
\c 14
\s1 Tsá₃ chi₂'ɨ́ng'₄ uɨg₅ rɨ́ng'₂
\p 
\v 1 Chi₂jua'₂ chan₂ dsa₂ 'uan₅₄ të₂le₃ quian'₅₄ a₂'éin₂, qui₁guein₅₄ 'nia'₂, la₁ on₃jua'₅₄ ia₁jaun₂ qui₁tsɨ́n'₂ 'nia'₂ 'a₂ lia'₂ lë́₅ ŋɨ́i'₂.
\v 2 Chan₂ i₂lɨn₅₄ i₂'én₂ a₂lé₂ le₃guë́'₃ ca₂le₃jë́₃ juɨ₁'e₂ guë́₃, ton'₂ chan₂ guë'₂ táng₃ i₂lɨn₅₄ i₂'uan₅₄ dsɨ́₅ 'a₂ lia'₂ 'éin₂, i₂guë́'₅ jmá'₃ lia'₂ ca₂ne₅₄ mɨ₂ján'₅.
\v 3 Jaun₂ lë₃ i₂guë́'₅ lia'₂ 'ei₅ ne₄ në́₃, tsá₃ ca₂tɨ́in₂ jmo₃ jua'₅₄ tsá₃ jein₅₄ i₂tɨn₂ dsɨ́₅ guë́'₅ jmá'₃ lia'₂ a₂lɨn₅₄ má₃; ton'₂ ján₃ guë'₂ le₂jaun₂ juɨ₁lia'₂ i₂tsá₃ guë́'₅ le₃jë́₃, tsá₃ lë₁o₁quion₂ 'í₁ ja₁con₂ dsa₂ i₂guë́'₅ le₃jë́₃. Ia₁ ján₃ bá₄ ca₂guéi'₂ Diú₄ quió'₅ dsa₂ 'éi₂.
\p 
\v 4 'Ne₂ guë'₂, ¿'ein₂ bá₄ lɨ́ng'₅ jua'₅₄ a₂caun'₅₄ 'í₁ ja₁con₂ dsa₂ i₂jme₂ti₃ ne₄ i₂sián'₂? Ia₁ juɨg₅₄ bá₄ 'éi₂ i₂niog₅ ne₄ con₂ 'í₁ chi₂jua'₂ chén'₅ 'éi₂ rë₂, o₃ të₁tsɨin'₅₄ 'lɨg'₅₄ 'e₂. Jaun₂ të₃tsɨin'₅₄ bá₄ rë₂, ia₁ i₂quɨ'₅₄ jmɨg₄ Te₁gui'₅₄ jmo₃ a₂të₃tsɨn'₅₄ dsa₂ 'éi₂.
\p 
\v 5 Chan₂ guë'₂ i₂lɨn₅₄ táng₃ i₂jmo₅ dsɨ́₅, 'ŋio₅ guë́₄ quen₅ a₂lɨn₅₄ jmɨg₄ lia'₂ con'₂ guë́₄ jmɨg₄ siá'₂; chan₂ guë'₂ i₂lɨn₅₄ i₂'én₂ jmo₂₃ dsɨ́₅ a₂co₂rë₂ bá₄ ca₂le₃jë́₃ jmɨg₄. Le₂jan₂ le₂jan₂ 'nió'₅ jmo₃ 'ei₅ caun₂ dsɨ́₅ lia'₂ con'₂ lë́₅ dsɨ₂jŋia₅ dsɨ́₅ 'ŋiog₅.
\v 6 Juɨ₁lia'₂ dsa₂ i₂jme₂gó'₃ caun₂ jmɨg₄, le₃quió'₅ Te₁gui'₅₄ bá₄ jme₂gó'₃ jmɨg₄ jaun₂. Le₂në₅ bá₄ juɨ₁lia'₂ dsa₂ i₂guë́'₅ lia'₂ 'ei₅ ne₄ má₃, guë́'₅ le₃quió'₅ Te₁gui'₅₄, ia₁ cuë́'₅ ti₁'mag'₄ Diú₄. Ján₃ bá₄ le₂në₅ quian'₅₄ juɨ₁lia'₂ i₂tsá₃ guë́'₅ lia'₂ 'ei₅ ne₄ má₃, le₃quió'₅ Te₁gui'₅₄ bá₄ tsá₃ guë́'₅; ján₃ bá₄ cuë́'₅ ti₁'mag'₄ Diú₄.
\p 
\v 7 Ia₁ 'i₁jan₂ jniog₄ tsá₃ lé₂ le₃chong₂ le₃quián₂ guio₅₄, on₃ guë'₂ lé₂ le₃dsióg₃ le₃quián₂ guio₅₄ në́₃.
\v 8 Ia₁ të₁lia'₂ chong₂ jniog₄, chong₂ le₃quió'₅ Te₁gui'₅₄ bá₄, në₁jua'₂ ca₂dsau₃ guë'₂ në́₃, dsióg₃ le₃quió'₅ Te₁gui'₅₄ bá₄ ján₃. Le₂në₅ bá₄, të₁lia'₂ chong₂ o₃ jë₁ma₂dsau₃ 'e₂, lág₅ i₂quián₅ Te₁gui'₅₄ bá₄.
\v 9 'Uɨg₅₄ jaun₂ ca₂jon₃ Cristo, ton'₂ ca₂jein'₅₄ táng₃: ia₁jaun₂ léin₂ Te₁gui'₅₄ quián₅ dsa₂ i₂ma₂dsan₃, lia'₂ dsa₂ i₂chan₂ në́₃.
\p 
\v 10 La₁ 'ne₂ në́₃, ¿'e₂ 'uɨg₅₄ cáun'₂ 'í₁ ja₁con₂ rɨ́ng'₂? ¿O₃ 'e₂ lë₃ jɨng'₅₄ sion₅ rɨ́ng'₂? Ia₁ ca₂le₃jág₃ bá₄ jniog₄ dsi₁no₃ dsɨ₂jme₁jnia₅ ne₄ Diú₄ ia₁jaun₂ con₂ 'éi₂ 'í₁ quián₂.
\v 11 Ia₁ ne₄ Si₂ juá'₂:
\q1 Juɨ₁lia'₂ a₂dsón'₂ dsau₅ bá₄ a₂chan₂ jniá₂,
\q2 juá'₂ Te₁gui'₅₄,
\q1 le₂në₅ bá₄ dsau₅ dsón'₂,
\q2 ca₂le₃jɨ́n₃ bá₄ qui₃jóin'₂ jne₅₄ ne₃ jniá₂,
\q1 jaun₂ ca₂le₃jɨ́n₃ bá₄ jmo₃ jág₁ quian'₅₄ mɨ₂'o₅₄
\q2 le₃ne₄ Diú₄.\f + \fr 14:11 \ft Isaías 49:18; 45:23.\f*
\m 
\v 12 Le₂në₅ bá₄ jaun₂, le₂jau₂ le₂jau₂ bá₄ jniog₄ dsɨ₁jang'₅₄ jág₁ dsau₅ quián₂ ne₄ Diú₄.
\s1 Tsá₃ jmó'₂ jua'₅₄ qui₂nió₃ rɨ́ng'₂
\p 
\v 13 Jaun₂ lë₃, tsá₃ ma₃jua'₅₄ qui₁quiong₅₄ jniog₄ 'í₁ le₂jau₂ le₂jau₂ ja₁con₂ rɨn'₅₄. Të₂le₃ jmo₄ 'nia'₂ 'í₁, jmo₄ co₂ŋei'₅₄ tsá₃ 'e₂ jmó'₂ 'i₁caun₂ jua'₅₄ a₂qui₃nió₃ rɨ́ng'₂.
\v 14 Guion₄ bá₄ jniá₂, 'ei₅ caun₂ dsɨ₃ le₃quió'₅ Te₁gui'₅₄, 'i₁caun₂ tsá₃ cha₂ jua'₅₄ tsá₃ le₁jë́₃ con'₂ lë́₅ 'ŋiog₅. La₁ në₁jua'₂ chan₂ jan₂ jmo₂₃ dsɨ́₅, cha₂ caun₂ a₂tsá₃ le₁jë́₃, le₃quió'₅ 'ŋiog₅ bá₄, tsá₃ le₁jë́₃.
\v 15 Në₁jua'₂ ca₂jén'₃ quɨ'₂ dsɨ́₅ rɨ́ng'₂ o₄quió'₄ a₂quë́'₂ 'ne₂, tsá₃ ma₃jmo'₂ a₂'nióg'₃ rɨ́ng'₂. Tsá₃ jmo₂ jua'₅₄ cuë́'₁ juɨ₅ o₄quió'₄ a₂quë́'₂, a₂dsɨ₂'én₂ jan₂ rɨ́ng'₂, ia₁ ca₂jon₃ Cristo o₄quió'₄ 'éi₂ ján₃.
\v 16 Tsá₃ cuë₂ 'nia'₂ juɨ₅ jua'₅₄ a₂qui₃dsia₃ dsa₂ 'lɨg'₅₄ 'ë₃ juɨ₁lia'₂ a₂jmo'₂ 'au'₂ a₂dse₃.
\v 17 Ia₁ juɨ₁lia'₂ ja₁gon₂ Diú₄, tsá₃ lɨn₄ quen₅ juɨ₁lia'₂ a₂guë́'₅ dsa₂, a₂qui₂'ɨ́n'₂ dsa₂ në́₃; a₂jaun₂ bá₄ a₂quen₅ guë́₄ lɨn₃: a₂guéi'₂ Diú₄ jniog₄ në₂jag₄ bá₄ a₂tsá₃ 'e₂ dso₄ rag₂, a₂chong₂ jniog₄ tei₄ o₂'ŋió₃ o₂jŋia₃ dsɨ₅ të₂le₃ quian'₅₄ Jme₂dsí₂ Jŋió₅.
\v 18 Ia₁ juɨ₁lia'₂ i₂jme₂ti₃ ta₁ ne₄ Cristo le₂në₅, jmo₂₃ a₂'ŋio₂ dsɨ́₅ Diú₄, ton'₂ dse₃ 'ag₅ táng₃ dsa₂ mɨ₂güɨ́g₃.
\p 
\v 19 Le₂në₅ bá₄ jaun₂, caun₂ juɨ₁'niog'₅₄ jniog₄ jmá'₃ lia'₂ a₂cuë₅ juɨ₅ ja₁'ag₃ tei₄, a₂jme₂'o₅₄ dsɨ₃cau₅₄ jniog₄ të₂le₃ juɨ₅ jme₂dsí₂.
\v 20 Tsá₃ lë₁'én₅ 'ne₂ ta₁ quió'₅ Diú₄ o₄quió'₄ má₃. Dsón'₂ bá₄ jaun₂, a₂le₁jë́₃ ca₂le₃jë́₃ a₂niog₅ guë́'₅ dsa₂. La₁ tsá₃ dse₃ në₁jua'₂ o₄quió'₄ a₂quë́'₂ 'ne₂, tián'₂ dso₄ rɨ́ng'₂.
\v 21 Ja₂lɨn₃ guë́₄ dse₃ a₂tsá₃ quɨ́g'₂ ŋɨ́₅, on₃ guë'₂ 'ag'₅₄ vino, on₃ guë'₂ jmó'₂ juɨ₁'e₂ guë́₃ a₂lé₂ le₃qui₃nió₃ rɨ́ng'₂.
\v 22 Juɨ₁lia'₂ a₂'én'₂ 'ne₂, a₂'én'₂ 'ne₂ 'ŋiag'₂ bá₄ jaun₂ të₂le₃ ne₄ Diú₄. ¡'E₂ guë́₄ dsen₃ juɨ₁lia'₂ dsa₂ i₂con₂ 'í₁ ja₁con₂ 'ŋiog₅, i₂tsá₃ qui₂dsɨ₂jŋi₅ dsɨ́₅ o₄quió'₄ a₂cuë₂₃ jmɨg₄ 'ŋiog₅!
\v 23 La₁ juɨ₁lia'₂ dsa₂ i₂guë́'₅, i₂'ei₅ caun₂-tɨn₃ dsɨ́₅, ma₂gue₃ uɨg₅, ia₁ tsá₃ ca₂guë́'₃ të₂le₃ quian'₅₄ a₂'éin₂. Ia₁ ca₂le₃jë́₃ a₂jmo₅ dsa₂ a₂tsá₃ lë́₅ të₂le₃ quian'₅₄ a₂'éin₂, dso₄ bá₄ jaun₂.
\c 15
\s1 Jmo₄ a₂'ŋio₂ dsɨ́₅ dsa₂ mɨ₂güɨ́g₃ rɨ́ng'₂, on₃jua'₅₄ rë'₂ jmá'₃ a₂të₅ 'au'₂ 'ŋiag'₂
\p 
\v 1 Jniog₄ i₂tióng₂ tiá₂ a₂'éin₂, ca₂tág₂ guéi₁ co₂'nió'₄ caun₂ lio₅₄ quián₂, 'a₂ lia'₂ qui₂ŋɨ́'₂ dsɨ́₅ dsa₂ i₂'uan₅₄ 'a₂ lia'₂ 'éin₂, jaun₂ tsá₃ 'nió'₅ jmó₁ con'₂ a₂të₅ dsɨ₅ guio₅₄.
\v 2 Le₂jau₂ le₂jau₂ bá₄ jniog₄ ca₂tág₂ jmó₁ a₂të₅ dsɨ́₅ dsa₂ mɨ₂güɨ́g₃ rɨn'₅₄, a₂jmó₁ a₂lë́₅ a₂dse₃ ja₁coin₂, juɨ₁lia'₂ juɨ₅ ja₁lé₂ qui₂dsɨ₃cóin₃ le₃quió'₅ jme₂dsí₂.
\v 3 Ia₁ ca₂lia'₂ jŋia'₅₄ 'ŋiog₅ Cristo tsá₃ ca₂jmo₃ a₂të₅ dsɨ́₅ 'ŋiog₅. Të₂le₃ ca₂i₃ŋɨ́i₂ juɨ₁lia'₂ juá'₂ ne₄ Si₂:
\q1 Ca₂le₃jë́₃ jág₁ uɨg₅ a₂jme₁tsɨ́'₅ dsa₂ 'nia'₂,
\q2 ne₃ jniá₂ bá₄ ca₂të₁tsɨ'₅₄.\f + \fr 15:3 \ft Salmo 69:9.\f*
\m 
\v 4 Ia₁ ca₂le₃jë́₃ con'₂ lë́₅ jág₁ a₂ca₂i₃to'₅₄ ne₄ Si₂, a₂ca₂i₃to'₅₄ ia₁jaun₂ jme₁tag₅ jniog₄ rë₂në́₃, ia₁jaun₂ caun₂ chong₂ jniog₄ 'ɨ́n₂ dsɨ₅ le₃quió'₅ Diú₄, të₂le₃ quian'₅₄ a₂juɨn'₂ dsɨ₅, a₂lë́₂ lián'₂ dsɨ₅ a₂cuë₅ jág₁ a₂já₅ ne₄ Si₂ jaun₂.
\v 5 Juɨ₁jme₂'o₅₄ bá₄ Diú₄, i₂jmo₅ a₂juɨn'₂ dsɨ́₅ dsa₂, i₂cuë₅ lián'₂ në́₃, juɨ₁jme₂'oin₅₄ 'nia'₂ a₂tiáng'₄ a₂jen'₂ 'nia'₂ le₂jang'₂ le₂jang'₂ con'₂ lë́₅ i₂nio'₅₄ 'nia'₂ juɨ₅ quió'₅ Cristo Jesús,\f + \fr 15:5 \ft 'Nio'₂ ja₁ton₅ Filipenses 2:5.\f*
\v 6 ia₁jaun₂ ca₂le₃jɨ́n'₃ 'nia'₂ co₂dsia₅, caun₂ bá₄ jág₁, jme₁juɨn'₂ 'nia'₂ Diú₄ Jmei₂ Te₁gui'₅₄ Jesucristo quián₂.
\s1 Dsɨ₂'ag₅ jág₁ dse₃ ja₁con₂ dsɨ₂nau₂
\p 
\v 7 Le₂në₅ jaun₂, qui₂guen₅₄ 'nia'₂ rɨ́ng'₂ le₂jang'₂ le₂jang'₂ juɨ₁lia'₂ ca₂guéi'₂ Cristo guio₅₄ jniog₄, ia₁jaun₂ le₃juɨn'₂ Diú₄.
\v 8 Ia₁ a₂juá'₅ jniá₂ juɨ́g₂ 'nia'₂, ca₂guan₃ I₂rë₂'ɨ́n₁ quián₅ Diú₄, ca₂jme₃ti₃ ja₁con₂ jnia'₅₄ con'₂ lág₅ dsa₂ judíos,\f + \fr 15:8 \ft lit. “dsa₂ i₂rë₂uɨng₄ quió'₅.” \f* ia₁jaun₂ le₃ti₃ jág₁ ron₅ a₂ca₂ŋɨ₂ dsa₂ can'₅₄ quián₂ jnia'₅₄ ma₂lɨ́g'₂. Jaun₂ le₂në₅ bá₄ ca₂rë₃jniá₂ në́₃ i₂rë₂ti'₅₄ bá₄ Diú₄ jág₁ a₂cuë₂₃.
\v 9 Guain₃ ján₃ ia₁jaun₂ jme₃juag'₂ dsɨ₂nau₂ jme₃juɨin'₂ Diú₄ i₂ŋéi₂ dsɨ́₅, juɨ₁lia'₂ rë₂ton₅ ne₄ Si₂:
\q1 'Uɨg₅₄ jaun₂ jme₁juɨn'₂ jniá₂ 'ne₂ jɨn₄ dsɨ₂nau₂;
\q2 'ë₅₄ jniá₂ ne'₅₄ 'ne₂ a₂jme₁juag'₂.\f + \fr 15:9 \ft 2 Samuel 22:50; Salmo 18:49.\f*
\p 
\v 10 Con'₂ siá'₂ juá'₂ táng₃:
\q1 Jmo₄ 'io'₂, 'nia'₂ dsɨ₂nau₂,
\q2 quian'₅₄ dsa₂ juɨg₂ quiáin₅.\f + \fr 15:10 \ft Deuteronomio 32:43.\f*
\m 
\v 11 Ja₁siá'₂ táng₃ juá'₂:
\q1 Jme₁juɨn'₂ 'nia'₂ Te₁gui'₅₄,
\q2 'nia'₂ ca₂le₃jɨ́n₃ dsɨ₂nau₂,
\q1 juɨ₁jme₂juag'₂ bá₄ ca₂le₃jë́₃ juɨg₂.\f + \fr 15:11 \ft Salmo 117:1.\f*
\p 
\v 12 Ján₃ bá₄ juá'₂ Isaías:
\q1 'Ŋio₂ tsɨn₅ cho'₅₄ Isaí,
\q2 jaun₂ náu₃ jan₂ i₂qui₃dsɨ₅ 'éi'₃ ja₁con₂ dsɨ₂nau₂;
\q1 le₃quió'₅ 'éi₂ bá₄ qui₃le₃'ɨ́n₂ dsɨ́₅
\q2 le₂caun₂ le₂caun₂ juɨg₂.\f + \fr 15:12 \ft Isaías 11:10.\f*
\p 
\v 13 Jaun₂ Diú₄, i₂jmo₅ 'ei₅ caun₂ dsɨ₅ a₂'ɨ́n₂ dsɨ₅ jniog₄, juɨ₁jme₂cain'₂ bá₄ 'au'₂ 'nia'₂, a₂chang'₂ jmó'₂ 'nia'₂ 'io'₂, 'ag₃ tei₄ a₂'éng'₂ le₃quió'₅, ia₁jaun₂ rë₂tsón₂ a₂le₁'ág₄ caun₂ 'au'₂ a₂'ɨ́n₂ 'au'₂ 'nia'₂ quian'₅₄ juɨ₅bí₂ quió'₅ Jme₂dsí₂ Jŋió₅.
\p 
\v 14 Caun₂ bá₄ 'ei₅ dsɨ₃ jniá₂, rɨn'₅₄ jniog₄, ma₂qui₂le₁rɨn₅ 'au'₂ 'nia'₂ a₂ŋéi₂ 'au'₂ rɨ́ng'₂, ton'₂ qui₂le₁rɨn₅ 'au'₂ 'nia'₂ a₂tɨn'₂ 'nia'₂, jaun₂ quɨ'₅₄ 'nia'₂ jmɨg₄ tóng'₄ jág₁ rɨ́ng'₂ le₂jang'₂ le₂jang'₂.
\v 15 A₂tiá₂ dsɨ₃ jniá₂ ma₂në₂juá'₃ ja₁lɨn₅₄, ma₂në₂tó'₃ jniá₂ jág₁ ne₄ si₂ la₂ ne'₅₄ 'nia'₂, ia₁jaun₂ tsá₃ dsɨ₃'én₂ 'au'₂ 'nia'₂. A₂'ua₁ dsɨ́₅ bá₄ Diú₄ ma₂dsia₃ gu₃ ta₁ la₂,
\v 16 a₂jme₂tí₁ ne₄ Jesucristo jë₄ quió'₅ dsɨ₂nau₂, a₂qui₂jen'₄ jniá₂ ne'₅₄ 'nia'₂ jág₁ dse₃ a₂lión₂ dsa₂, ia₁jaun₂ lé₂ qui₁jen'₄ 'nia'₂ i₂lɨ́ng'₅ dsɨ₂nau₂, le₃ne₄ Diú₄, në₂jag₄ bá₄ caun₂ a₂rë₂jen'₅₄ a₂guéi'₃, co₂'nió'₄ dsa₂ i₂ma₂rë₂tson₄, ca₂jmo₃ Jme₂dsí₂ Jŋió₅.
\p 
\v 17 Jaun₂ lë₃, jmo₅ jniá₂ táng'₅ le₃quió'₅ Cristo Jesús, quian'₅₄ ta₁ a₂jmo₅ jniá₂ ne₄ Diú₄;
\v 18 on₃jua'₅₄ rë'₂ a₂tiá₂ dsɨ₃ jniá₂ le₃juá'₄ lë́₅ guë́₄ lia'₂ con'₂ guë́₄ juɨ₁lia'₂ a₂ma₂qui₂ma₂jmo₃ Cristo të₂le₃ quian'₅₄ jniá₂, a₂tsɨn'₅₄ jniá₂ dsɨ₂nau₂ ne₄ juɨ₅, quian'₅₄ jág₁ quió₃, quian'₅₄ ta₁ quió₃ në́₃, a₂le₃ne'₅₄ 'éi₂ ne₄ Diú₄.
\v 19 A₂lë́₅ ta₁ në₅ të₂le₃ quian'₅₄ juɨ₅bí₂ a₂'io₅ léi₄ juë'₂ a₂dsɨ₂gó'₃ dsɨ́₅ dsa₂, të₂le₃ quian'₅₄ juɨ₅bí₂ quió'₅ Jme₂dsí₂ Jŋió₅ në́₃. Le₂në₅ bá₄ ma₂ca₂jme₁'ŋiag₂₃ ta₁ ma₂qui₂ma₂'ë́₃ jág₁ dse₃ quió'₅ Cristo, ca₂jme₁lióg₄ jniá₂ juɨg₂ Jerusalén, jaun₂ guë́₄ ŋeg₅₄ ta₁caun₂ juɨ₅ le₃lág'₃, ca₂lia'₂ ca₂dsióg₃ të₂ 'uë₃ Ilírico.
\v 20 Le₂në₅ bá₄ ma₂ca₂jmo₃ dsen₅₄ dsɨ₃ ma₂qui₂ma₂'ë́₃ jág₁ le₂tan₅₄ juɨg₂ ja₁'i₁cón'₂ tsá₃ jme₁ma₂nág₂ dsa₂ a₂'ɨn₅ dsa₂ Cristo, ia₁jaun₂ tsá₃ cho₅₄ jniá₂ ta₁ ne₄ 'uɨg₅₄ 'ia'₂ a₂ma₂ca₂jme₃lióg₃ i₂sián'₂.
\v 21 La₁ juɨ₁lia'₂ juá'₂ ne₄ Si₂:
\q1 Jág₃ dsa₂ jɨ́in₃ 'éi₂
\q2 i₂tsá₃ jme₁ma₂gú'₃ jág₁ quió'₅;
\q1 jaun₂ le₃ŋɨ́'₂ dsɨ́₅
\q2 juɨ₁lia'₂ i₂tsá₃ jme₁ma₂nág₂ a₂'ɨn₅ 'éi₂.\f + \fr 15:21 \ft Isaías 52:15.\f*
\s1 Dsɨ₂jiog₅ dsɨ́₅ Pa₄ dsó₃ juɨ₅ Roma
\p 
\v 22 'Uɨg₅₄ në₅ ca₂jnɨ́₃ jniá₂ juɨ₅ 'lióng₂ ráun₂ lia'₂ con'₂ jme₁'nio₃ jme₁i₁jɨng₁₂ 'nia'₂.
\v 23 La₁ në₃ guë'₂ lia'₂ tsá₃ ma₃cha₂ ja₁jmo₅₄ ta₁ le₂tan₅₄ juɨg₂ te₁'i₁ le₃la₂, jaun₂ ma₂ne₁ŋó₄ bá₄ 'lióng₂ ŋi₂ jme₁'ɨ́n₅ dsɨ₃ jme₁nei₅₄ i₁jɨng₁₂ 'nia'₂,
\v 24 'ɨ́n₂ dsɨ₃ jniá₂ ŋɨg₅₄ juɨ₅ ja₁tion'₅₄ 'nia'₂ jë₁ma₂të́₂ rë₁nei₅₄ juɨ₅ España, ia₁jaun₂ lé₂ le₃tsag'₅₄ ne₄ juɨ₅ jaun₂, cang₂ jë₁ma₂ca₂mag'₂ dsɨ₃ jɨng₅₄ 'nia'₂.
\v 25 La₁ rë₂në́₃ në́₃, 'eng₅₄ juɨ₅ nei₅₄ juɨ₅ Jerusalén, a₂jme₁ti₁ jniá₂ ta₁ ja₁con₂ dsa₂ quián₅ Diú₄ ja₁jaun₂.
\v 26 Ia₁ i₂chan₂ Macedonia quian'₅₄ i₂chan₂ Acaya në́₃, ca₂jmo₃ dsɨ́₅ ca₂cág'₃ cu₄ a₂chein₃ ne₄ rɨn'₅₄ jniog₄ i₂të₂ŋé₂ i₂chan₂ juɨg₂ Jerusalén.
\v 27 A₂'ŋio₂ dsɨ́₅ ca₂jmo₃ le₂jaun₂, ia₁ dsau₅ bá₄ jaun₂ rɨin₂ le₃quió'₅ 'éi₂. Ia₁ chi₂jua'₂ ma₂qui₂ma₂quen'₅₄ dsɨ₂nau₂ a₂gu₂dsí₂ a₂ca₂cuë₃ dsa₂ judíos, ján₃ bá₄ le₂jaun₂ ca₂tɨ́in₂ jme₃'o₅₄ quian'₅₄ a₂'nió'₅ le₃quió'₅ nɨ₁ŋɨ́₅.
\v 28 Jaun₂ le₂në₅, jë₁ma₂ca₂dsan₃ jáng'₅ jniá₂ ne₅₄ a₂ma₂ca₂cág'₃ dsa₂ jaun₂, jaun₂ guë́₄ 'ú₄ juɨ₅ a₂nei₅₄ juɨ₅ España, a₂i₁jɨng₁₂ 'nia'₂ lia'₂ ma₂'eng₅₄ juɨ₅.
\v 29 Jaun₂ caun₂ bá₄ 'ei₅ dsɨ₃, a₂jme₃gu'₅₄ bá₄ Cristo lia'₂ rë₂'ŋia₅ jë₁ma₂të́₂ rë₁dsióg₄ jniá₂ a₂i₁jɨng₁₂ 'nia'₂.
\p 
\v 30 Rɨn'₅₄ jniog₄, mɨ₅ jniá₂ ja₁con'₂ 'nia'₂ lia'₂ con'₂ lë́₅ 'éi'₃ quió'₅ Te₁gui'₅₄ Jesucristo quián₂ jniog₄, ton'₂ ia₁ a₂cuë₅ Jme₂dsí₂ bí₂, a₂jme₁'nió₄ jniog₄ rɨn'₅₄: a₂jme₁quiong'₅₄ 'nia'₂ jniá₂, ne₄ 'nei₂ a₂chéng'₅, a₂chi₁len'₄ 'nia'₂ Diú₄ o₄quió₃.
\v 31 Mɨ₄ 'nia'₂ ne₄ Diú₄ juɨ₁lio₅₄ jniá₂ o₄gú₃ dsa₂ i₂tsá₃ 'én₂ i₂chan₂ Judea, le₂jaun₂ guë'₂ ján₃ juɨ₁gue₅₄ bá₄ rɨn'₅₄ jniog₄ juɨg₂ Jerusalén caun₂ dse₃ a₂i₁can₁₂ a₂jme₁'oin₁₂,
\v 32 ia₁jaun₂ chi₂jua'₂ 'nio₃ Diú₄ a₂dsióg₄ jniá₂, i₁jɨng₁₂ 'nia'₂ a₂'io'₂ jmo₂₃, a₂tág'₄ jme₂dsí₂ quió₃ co₂dsia₅ quian'₅₄ 'nia'₂.
\p 
\v 33 Juɨ₁quiong'₅₄ bá₄ Diú₄ i₂jmo₅ 'ei₅ tei₄, ca₂le₃jɨ́n'₃ 'nia'₂. A₂méi₃.
\c 16
\s1 Cuɨin₂₃ Diú₄ le₂jan₂ le₂jan₂
\p 
\v 1 Jme₂jnia₄ jniá₂ 'io₅₄ rɨn'₅₄ jniog₄ Febe, i₂ma₂já₅ jme₂ti₃ ja₁con₂ guá'₅ chan₂ Cencrea.
\v 2 Guein₅₄ bá₄ dse₃ o₄quió'₄ Te₁gui'₅₄, jmo₄ bá₄ con'₂ dsi₂ten₅₄ jmo₃ dsa₂ ja₁con₂ rɨin'₅₄ i₂'én₂,\f + \fr 16:2 \ft lit. “dsa₂ jŋió₅.” \f* ján₃ guë'₂ jme₁'oin₁₂ quian'₅₄ juɨ₁'e₂ guë́₃ a₂ca₂rë₃'nió'₃ quió'₅, ia₁ ma₂ca₂jme₃'o₅₄ bá₄ 'éi₂ 'ŋiog₅ ma₂ca₂jme₃'oin₅₄ juɨn₅, ján₃ guë'₂ le₂jaun₂ ma₂ca₂jme₃'o₅₄ jniá₂.
\p 
\v 3 Cuɨn₅₄ Diú₄ Priscila\f + \fr 16:3 \ft griego: Prisca.\f* quian'₅₄ Aquila, i₂lɨ́n₅ i₂quian'₅₄ jniá₂ jë₄ ta₁ a₂niog₅ quió'₅ Cristo Jesús.
\v 4 'Éi₂ bá₄ ca₂jmo₃ tén'₂ dsɨ́₅ o₄quió₃ jniá₂, o₁jŋia'₅₄ ca₂quí'₃ dsa₂ dsɨ₂lag₅₄. Jaun₂ cuë́₅ jniá₂ ti₁'mag'₄ 'éi₂. On₃ jua'₅₄ jmá'₃ jniá₂; ca₂le₃jɨ́n₃ dsɨ₂nau₂ i₂'én₂ cuë₂₃ ti₁'mag'₄ ján₃.
\p 
\v 5 Në₅ i₂cuɨ́ng'₅ Diú₄ ján₃ dsa₂ rɨn'₅₄ jniog₄ i₂ŋɨ'₂ dsi₂néi₂ quió'₅ Priscila quian'₅₄ Aquila në́₃. Cuɨn₅₄ Diú₄ Epeneto a₂mei₅₄ quiáng₃, dsa₂ i₂le₂'uɨg₅₄ i₂ca₂rë₃'én₂ le₃quió'₅ Cristo 'uë₃ Acaya.\f + \fr 16:5 \ft griego: Asia.\f*
\p 
\v 6 Cuɨn₅₄ co₂nio₄ Diú₄ María, ia₁ 'ŋio₅ lɨn₃ ma₂jmo₃ ta₁ o₄quián'₂ 'nia'₂.
\p 
\v 7 Cuɨn₅₄ co₂nio₄ Diú₄ Andrónico quian'₅₄ Junias, dsa₂ go₃ jniá₂ i₂quiang'₅₄ ca₂'ú₃ né'₃ 'má₃; co₂'nió'₄ dsa₂ i₂lén₄ i₂cuɨg₅ guë́₄ dsa₂ i₂chen₄ quián₅ Te₁gui'₅₄, co₂'nió'₄ dsa₂ i₂jme₁ma₂tion'₅₄ le₃quió'₅ Cristo le₂jŋiá₅ guë́₄ con'₂ guë́₄ jniá₂.
\p 
\v 8 Cuɨn₅₄ Diú₄ Amplias, jan₂ i₂'nió₃ jniá₂ le₃quió'₅ Te₁gui'₅₄.
\p 
\v 9 Cuɨn₅₄ co₂nio₄ Diú₄ ján₃ Urbano, dsa₂ i₂quian'₅₄ jniog₄ jmo₂ ta₁ quió'₅ Cristo Jesús, quian'₅₄ Estaquis në́₃ i₂lɨ́n₅ a₂mei₅₄ quiáng₃ i₂'nióg₃ guë́₄ lɨn₃.
\p 
\v 10 Cuɨn₅₄ Diú₄ Apeles, i₂ma₂já₅ cuë₂₃ léi₄ a₂ŋɨ₂₃ le₃quió'₅ Cristo, le₂jaun₂ bá₄ jmo₄ co₂nio₄ quian'₅₄ ca₂le₃jɨ́n₃ i₂chan₂ dsi₂néi₂ quió'₅ Aristóbulo ján₃.
\p 
\v 11 Cuɨn₅₄ Diú₄ Herodión, dsa₂ go₃ jniá₂, quian'₅₄ guë'₂ dsa₂ familia quián₅ Narciso i₂'én₂ le₃quió'₅ Te₁gui'₅₄.
\p 
\v 12 Cuɨn₅₄ bá₄ co₂nio₄ Diú₄ Trifena quian'₅₄ Trifosa në́₃, on₃ dsa₂ mɨ́₂ i₂jmo₅ ta₁ quió'₅ Te₁gui'₅₄, quian'₅₄ guë'₂ 'io₅₄ rɨn'₅₄ jniog₄ Pérsida i₂'nió₄ guë́₄ lɨn₃, i₂ŋɨ́₄ ma₂jmo₃ ta₁ quió'₅ Te₁gui'₅₄ ján₃.
\p 
\v 13 Cuɨn₅₄ bá₄ Diú₄ Rufo i₂lɨ́n₅ dsa₂ i₂ma₂quion'₅₄ quián₅ Te₁gui'₅₄, quian'₅₄ chog₅₄, i₂jɨng₅₄ në₂jag₄ bá₄ cha₃ ján₃.
\p 
\v 14 Cuɨn₅₄ Diú₄ Asíncrito, Flegonte, quian'₅₄ guë'₂ Hermas, Patrobas, Hermes në́₃, quian'₅₄ guë'₂ dsa₂ rɨn'₅₄ jniog₄ i₂quiain'₅₄ në́₃.
\p 
\v 15 Cuɨn₅₄ 'nia'₂ Diú₄ ján₃ i₂chen₂ Filólogo quian'₅₄ Julia, Nereo në́₃, quian'₅₄ 'io₅₄ rɨin'₅₄; cuɨn₅₄ 'nia'₂ Diú₄ Olimpas quian'₅₄ guë'₂ ca₂le₃jɨ́n₃ rɨn'₅₄ jniog₄ i₂'én₂\f + \fr 16:15 \ft lit. “dsa₂ jŋió₅.” \f* i₂tion'₅₄ quiain'₅₄.
\p 
\v 16 Cuɨn₅₄ 'nia'₂ Diú₄ rɨ́ng'₂ le₂jang'₂ le₂jang'₂ a₂qui₁chén'₁\f + \fr 16:16 \ft Caun₂ tag₄ a₂jme₁chí'₄ lia'₂ con'₂ ca₂jmo₃ Pa₄ si₂ la₂.\f* 'nia'₂ quió'₅ rɨ́ng'₂, a₂lë́₅ léi₄ a₂ma₂'ei₅ caun₂ jág₁ a₂le₁jë́₃ 'au'₂ quian'₅₄ rɨ́ng'₂. Ca₂le₃jɨ́n₃ bá₄ guá'₅ quián₅ Cristo dsiáin'₂ jág₁ a₂cuɨin₂₃ Diú₄ 'nia'₂.
\p 
\v 17 Rɨn'₅₄ jniog₄, mɨ₅ jniá₂ ne'₅₄ 'nia'₂, rë₂ de'₂ quion₂ 'nia'₂ 'í₁, 'ein₂ dsia₅ mɨ'₅₄ jmo₅ le₁dson'₅₄ guá'₅, 'ein₂ chi'₅ juɨ₅ a₂qui₂nió₃ dsa₂, a₂tsá₃ dsi₂ten₅₄ lia'₂ con'₂ lë́₅ jág₁ a₂ma₂ca₂rë₃tɨ́n'₃ 'nia'₂. Jaun₂ co₂dsia₅ chén'₂ 'nia'₂ cau₅ i₂jmo₅ le₂jaun₂.
\v 18 Ia₁ on₃jua'₅₄ dsa₂ i₂jme₂ti₃ ne₄ Te₁gui'₅₄ Jesucristo i₂le₂'éi₂; con'₂ jŋia'₅₄ jme₂ti₃ ne₄ a₂mɨ₅ nɨ₁ŋɨ₁ guioin₅₄ bá₄, qui₂jme₂gain₂₃ dsɨ́₅ juɨ₁lia'₂ dsa₂ i₂tsá₃ lɨn₄ ŋɨ́'₂ dsɨ́₅, quian'₅₄ jág₁ 'ua₁, jág₁ rau₂ në́₃.
\p 
\v 19 Ca₂le₃jɨ́n₃ bá₄ dsa₂ le₁ŋi₅ 'a₂ lia'₂ ma₂ja₂nó'₅ 'nia'₂ a₂neg'₅₄, jaun₂ 'io'₂ jmo₅ jniá₂ o₄quián'₂ 'nia'₂. La₁ia₁ 'nio₃ jniá₂ a₂lén'₂ 'nia'₂ 'ŋiog'₅₄ le₃quió'₅ a₂dse₃, ján₃ bá₄ le₂në₅ a₂léng'₂ dsa₂ i₂tsá₃ 'e₂ dsɨ₂jŋia₅ dsɨ́₅ ne₄ a₂'lɨg'₅₄.
\v 20 Jaun₂ Diú₄ i₂jmo₅ 'ei₅ tei₄, ŋi'₅₄ ta₁ jlein'₃ i₂së₃dsen₃ o₄tag'₄ 'nia'₂. Juɨ₁'ei₅ bá₄ a₂dse₃ dsɨ́₅ Te₁gui'₅₄ Jesús quián₂ jniog₄ ja₁con'₂ 'nia'₂.
\p 
\v 21 Timoteo, i₂quian'₄ jniá₂ jmo₂₃ ta₁, dsiáin'₂ jág₁ a₂cuɨin₂₃ Diú₄ 'nia'₂; le₂jaun₂ bá₄ ján₃ Lucio quian'₅₄ Jasón, Sosípater, i₂lɨ́n₅ dsa₂ go₃ jniá₂.
\p 
\v 22 Jniá₂ Tercio i₂tó'₃ jág₁ la₂ ne₄ si₂, ján₃ bá₄ cuɨ́n₅ jniá₂ Diú₄ 'nia'₂ o₄quió'₄ Te₁gui'₅₄.
\p 
\v 23 Gayo në́₃ dsiáin'₂ jág₁ a₂cuɨin₂₃ Diú₄ 'nia'₂. Dsi₂néi₂ quió'₅ 'éi₂ bá₄ 'eng₅₄. Ján₃ bá₄ cuë₂₃ dsi₂néi₂ quió'₅ cuë́'₅ ca₂le₃jɨ́n₃ dsa₂ quián₅ guá'₅. Erasto dsa₂ i₂niog₅ gu₂ cu₄ quió'₅ dsa₂ juɨg₂ në́₃, dsiáin'₂ jág₁ a₂cuɨin₂₃ Diú₄ 'nia'₂ ján₃; i₂chen₂ Cuarto rɨn'₅₄ jniog₄ në́₃.
\p 
\v 24 Juɨ₁jme₂gu'₅₄ bá₄ Te₁gui'₅₄ Jesucristo 'nia'₂ ca₂le₃jɨ́ng'₃, A₂méi₃.\f + \fr 16:24 \ft Chog₅₄ si₂ a₂dse₃ guë́₄ tsá₃ chi₁ton₅ \f*
\s1 'Ág'₃ jág₁ Pa₄ a₂jme₂juɨin'₂ Diú₄
\p 
\v 25 Në₃ në́₃, juɨ₁jme₁juɨn'₂ jniog₄ Diú₄. 'Éi₂ bá₄ lé₂ le₃jmo₃ a₂náu'₁ 'nia'₂ tiá₂ lia'₂ con'₂ lë́₅ jág₁ dse₃ quió'₅ Cristo a₂'ë́₅ jniá₂, lia'₂ con'₂ lë́₅ ca₂jme₃jnia₅ Diú₄ jág₁ quió'₅ a₂jme₁rë₂'ma₄ ca₃ma₂lɨ́g'₂ lɨn₃.
\v 26 Diú₄ i₂chan₂ co₂tan₅₄ 'éi₂ bá₄ ca₂jmo₃ 'éi'₃ a₂jmo₃ jág₁ dsa₂ i₂chen₄ quiáin₅ ma₂lɨ́g'₂, jág₁ a₂ca₂tó'₂ 'éi₂ ne₄ Si₂, ia₁jaun₂ le₃ŋi₅ dsa₂ chan₂ ca₂le₃jë́₃ juɨg₂ nación, ia₁jaun₂ le₃'éin₂ jág₁ jaun₂, le₃nei'₅₄ në́₃.
\p 
\v 27 ¡Diú₄ i₂jan₂ tan₅₄, i₂tɨn₂, i₂ŋi₅, juɨ₁le₂juɨin'₂ bá₄ të₂le₃ quian'₅₄ Jesucristo ca₂lia'₂ co₂tan₅₄! A₂méi₃.
\p Co₂në₅.
