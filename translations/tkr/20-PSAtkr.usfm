\id PSA – Tsakhur 
\toc3 Zab. 
\toc2 Zabur 
\toc1 Zabur 
\mt1 Zabur 
\c 1  
\cl Q'öble yəq 
\q1  
\v 1 Pisınbışde mı'sləhətıka 
\q2 yəq idyaak'anna, 
\q1 bınahnanbışika 
\q2 gyu'ur oza qidexhena, 
\q1 matsxar haa'anbışika 
\q2 gidiy'arna 
\q1 insan nimeecar baxtivariy! 
\q1  
\v 2 Mang'uname şadvalla saccu 
\q2 Rəbbine Q'aanunee vobna. 
\q1 Xəmbına-yiğbına mang'vee 
\q2 mana qəbəqqə, 
\q2 mançina haa'a. 
\q1  
\v 3 Mana xhyanbışde 
\q2 mıglek oozuna, 
\q3 şagav çine gahıl helena, 
\q3 çin t'eled hı'ç'diyğənna 
\q2 yiv xhinnee ixhes. 
\q1 Mang'vee ha'ane gırgıne karee 
\q2 barakat vuxhes. 
\b  
\q1  
\v 4 Pisın insanarmee 
\q2 məxbınbı deş vob, 
\q1 manbı mıtsın alixa'an 
\q2 balybiy xhinnee vooxhe. 
\q1  
\v 5 Mançil-allab pisınbışisse 
\q2 məhkamee, 
\q1 bınahnanbışisseb 
\q2 qopkuyn insanarnane maclisee 
\q1 ulyoozaras vəəxəs deş. 
\q1  
\v 6 Nya'a, Rəbbee qopkuynbışda yəq 
\q2 dişde havaace?! 
\q1 Pisınbışde yəqqı'nıb 
\q2 manbı gyapt'as hoot'al. 
\c 2  
\cl Allahee gixhxhına paççah 
\q1  
\v 1 Nişil-allane milletbı g'elil qeedaxhe? 
\q2 Nişil-allane manbışe cosse dəxəsde karbışda haa'a? 
\q1  
\v 2 Ç'iyene aq'valin paççahar, vuk'lek vukkekkanbı, 
\q2 Rəbbilqayiy 
\q2 Mang'vee g'əyxı'ng'ulqa, paççahılqa, 
\q3 g'elil qeebaxhe. 
\p  
\v 3 Manbışe eyhen: 
\q1 «Qudoora, Manbışda xamut qakkyaahas, 
\q1 şalin Manbışin zincirbı qoda'as!» 
\b  
\q1  
\v 4 Xəybışee taxtıl Gyu'uriyng'vee əqəna ha'as, 
\q1 Xudaavandee manbı matsxara haa'as. 
\q1  
\v 5 Qiyğa Mang'vee qəlın eyhesın. 
\q1 Manbıb Mang'une it'umne qəlıle qəvəəq'ənasınbı. 
\p  
\v 6 Mang'vee eyhen: 
\q1 «Zı Yizda paççah 
\q2 muq'addasne suval Sionul\f + \fr 2:6 \fq Sion: \ft İyerusalim alyav'una tepa vobna. İzrailyne paççahın xan-saray maaniy vod.\f* gi'ı». 
\b  
\p  
\v 7 [Paççahee eyhen:] 
\q1 Rəbbee uvhuyn zı şolqa hixhar ha'asın. 
\q1 Rəbbee zak'le uvhuyn: 
\q2 «Ğu Yizda dix vor, 
\q2 Zake g'iyna Vas dek ıxha. 
\q1  
\v 8 Zake heqqe, 
\q2 Zı vas gırgıne gahbışis milletbıyiy 
\q2 ç'iyeyn aq'va ç'əvxhesmeen gırgın cigabı 
\q3 Vas heles. 
\q1  
\v 9 Ğu manbışikın yivayne əsaaka ha'as, 
\q1 G'ı'bı'ne nyuq'vneke hı'iyn g'ab xhinnee 
\q2 xüvə-xüvəna qaa'as». 
\b  
\q1  
\v 10 Həşdiyle, paççahar, ək'elika vuxhe! 
\q2 Ç'iyene aq'valin haakimar, dars aleet'e! 
\q1  
\v 11 Rəbbile qəpq'ı'n Mang'us g'ullux hee'e! 
\q2 Qəvəq'neb, şadeepxheb. 
\q1  
\v 12 Allahne dixes, paççahıs, 
\q2 qəl mooxhecenva hı'rmat givxhe. 
\q1 Deşxheene, mang'una qəl 
\q2 zarabacab ts'ayılqa sapk'ıl, 
\q2 şokunud şu avquyne yəqqə ixhesın. 
\q1 Mang'ulqa yı'q' qizzıriynbı 
\q2 nimee baxtivarbayiy! 
\c 6  
\cl «Rəbbik'le zı geşşe g'ayxhiyn» 
\d  
\v 1 Maq'amne xərıng'us. Molyne simnane instrumentıkana Davudna mə'niy. 
\q1  
\v 2 Rəbb, qəl vuxha zas cazaa humoole, 
\q1 qəlın qoyxharmee, zake qəl qığmaaha. 
\q1  
\v 3 Rəbb, zas rəhı'm hee'e, 
\q2 Zaqa taq'at axu deş. 
\q1 Rəbb, zı yug qe'e, 
\q2 uts'uruke bark'vbışeeqa zeze aypxhı. 
\q1  
\v 4 Caneeqa it'umna zeze aypxhı. 
\q1 Rəbb, man mısılqameene ts'ıts'xhes? 
\b  
\q1  
\v 5 Rəbb, qora zas kumag he'e, 
\q1 Yiğne ç'əvcab dyooxhene yugvalika 
\q2 zı g'attixhan he'e! 
\q1  
\v 6 Qik'u ark'ınne insanee 
\q2 Ğu deş yik'el qalya'as. 
\q1 Şavaane qik'uyne cigeençe 
\q2 Vas şukur haa'as? 
\b  
\q1  
\v 7 Zı yizdecar hülöörxüyke orzulyna, 
\q1 yiğıscad xəmde geşşuyke 
\q2 zı g'ılexhan ciga çüvəda eyxhe, 
\q1 ulene nağıke 
\q2 yizın tyulyu çüvə qexhe. 
\q1  
\v 8 Uts'uruke yizın uleppı qeqqu. 
\q1 Duşmanaaşe zı geşşes ilekkançil-alla 
\q2 yizın uleppı ozzur. 
\b  
\q1  
\v 9 Rəbbik'le zı geşşe g'ayxhiyn! 
\q1 Pisın işbı g'ecenbı, zake əq'əna qeepxhe! 
\q1  
\v 10 Rəbbik'le, zı rəhı'm hee'eva eyhen, g'ayxhiyn, 
\q1 Rəbbee yizda düə q'abıl hav'una! 
\q1  
\v 11 Yizın gırgın duşmanar 
\q2 k'ap'ik'ıle avqa qeepxhes, 
\q1 Manbı qəpq'ı'n, 
\q2 manbışde caneeqa it'umna zeze avxhas, 
\q2 Matsxareepxha, manbı zaraba heepxasınbı. 
\c 8  
\cl «Nimee axtıdayiy Yiğın do ç'iyene aq'val!» 
\d Maq'amne xərıng'us. Davudna Gittitne instrumentıkana mə'niy. 
\q1  
\v 1-2 Ay Xudaavanda, yişda Rəbb, 
\q2 nimee axtıdayiy Yiğın do ç'iyene aq'val! 
\q1 Yiğna xəbvalla xəybışileb axtıba vob. 
\q1  
\v 3 Gyooqanbışded, uşaxaaşineb gyaaşuyle ğana 
\q2 Ğu guc haagvas, 
\q1 qəl qığaahane duşmanee 
\q2 nıq' aqqecenva. 
\b  
\q1  
\v 4 Yiğne xıleppışde işiqa: xəybışiqa, 
\q1 Ğu gyuvxhuyne vuzaqa, 
\q2 Ğu gitk'ınne xənebışiqa, ilyakkamee, 
\q1  
\v 5 Zı eyhen: «İnsan vuşune vor, 
\q2 Ğu mana yik'el aqqı? 
\q1 İnsanıke g'abiynbı hucoo eyxhen karne, 
\q2 Ğu manbışda haa'a?» 
\b  
\q1  
\v 6 Ğu insan malaaikıle 
\q2 sık'ırra avqana hı'ı. 
\q1 İnsan axtı qı'ı, 
\q2 tac xhineyid şöhrat huvu, 
\q1  
\v 7-9 İt'xhınne karalqa mana paççah gixhxhı. 
\q1 İn gırgın: çavra-vəq'ə, çolun həyvanar, 
\q2 Xəədın şit'yar, deryahbışeedın baluğar, 
\q2 Deryahbışeedın gırgıncad, 
\q1 Ğu mang'une g'elybışiqqa huvu. 
\b  
\q1  
\v 10 Ay Xudaavanda, yişda Rəbb, 
\q2 nimee axtıdayiy Yiğın do ç'iyene aq'val! 
\c 15  
\cl Ğu zı mısacar g'alerçes deş 
\d Davudna düə 
\q1  
\v 1 Allah, zı havace, 
\q2 Zı dyugulexhen ciga Vasnee vod. 
\b  
\q1  
\v 2 Zı Rəbbik'le uvhuyn: «Yizda Xudaavanda Ğu vorna. 
\q2 Vale ğayrı zaqa xoşbaxtıyvalla deşda». 
\q1  
\v 3 Ç'iyene aq'valin Rəbbina yəq avquyn insanar nimeecab yugunbıyiy! 
\q2 Saccu manbışe zı şad ha'a! 
\q1  
\v 4 Menne allahaaşiqab qihna əlyhəənbışde 
\q2 hasre vuk'lelqa geed yiğbı allecen. 
\q1 Zı mane allahaaşinemee q'urbanna eb k'yaa'as deş, 
\q2 Manbışin dobı ghalyaqa alyaat'as deş. 
\b  
\q1  
\v 5 Rəbb, zas ıkkanna saccu Ğu vorna, 
\q2 Yizda ı'mı'r nəxübiy ı'lğəə Vake vod. 
\q1  
\v 6 İnekke yugun cigabı Ğu zas huvu, 
\q2 Hək'ebab, zalqa gipxhına pay uftanna vuxha! 
\q1  
\v 7 Zas yəq haagvana Rəbb zı axtı qa'as, 
\q2 Xəmdeb zı fıkır ooxhan, 
\q2 nəxübna Ğu eyhəxüb ı'mı'r haa'as. 
\q1  
\v 8 Rəbb yizde k'ane ıxhay, zı mısacad yik'el hixan ha'a deş, 
\q2 Zı mançil-allar mısacar qaçaxaras deş. 
\b  
\q1  
\v 9 Zı yik'eençe şadexhe vor, 
\q2 Zı şadvalin xəybışeena xhinne ilexa vor, 
\q2 Zasse qı'dərq'ı'n manzil haa'as vəəxə. 
\q1  
\v 10 Ğu zı ahalee g'alerçes deş, 
\q2 Yiğna mu'mun Ğu nyuq'vnee qı'çes hassaras deş. 
\q1  
\v 11 Ğu zak'le ı'mı'r hoolena yəq haagu, 
\q2 Yiğne k'ane zı geer şadra vor, 
\q2 Yiğne xılen hammaşe zas yugun hele. 
\c 17  
\d  
\v 1 Maq'amne xərıng'us. Rəbbine g'uluna, Davudna mə'niy. Rəbbee Davud gırgıne cune duşmanaaşineyiy Şaulne xılençe g'attixhan hı'ımee, Davudee Rəbbis ina mə'niy qəbəqqə: 
\q1  
\v 2 Rəbb, zas Ğu ıkkanna! 
\q2 Ğu yizda guc vob. 
\q1  
\v 3 Rəbb yizda suva vobna, 
\q2 yizda g'ala, zı g'attixhan ha'ana vorna. 
\q1 Allah yizın ganz vodun, 
\q2 Mang'usne zı dyugul ixhes. 
\q1 Yizın g'alxan, zı g'attixhana'asda guc, 
\q2 it'umun ciga Mana vor. 
\q1  
\v 4 Şukur gyooxhane Rəbbilqa ona'as, 
\q2 yizde duşmanaaşine xılençer g'attixhanasda. 
\q1  
\v 5 Yizde hiqiy-alla gyabat'an torbı ıxha, 
\q2 zı gek'ane damabışile zı qəyq'ən ıxha. 
\q1  
\v 6 Ahalın t'ü'bı zalqa alitk'ır ıxha, 
\q2 gyapt'asde gugubışeqar zı girxhu ıxha. 
\b  
\q1  
\v 7 Dağamiyvalee zı Rəbbilqa onuiyn, 
\q2 Allah kumagıs qort'ul. 
\q1 Mang'uk'le yizın ses Cune Xaa g'ayxhiyn, 
\q2 yizın uts'ur Mang'une k'ıriysqa hitxhıriyn. 
\q1  
\v 8 Mang'us qəl vuxhal-alla 
\q2 ç'iye oyt'al, ı'ğiykaran, 
\q2 suvabışin xhebbı ı'ğiykar, manbı hoyharanbı. 
\q1  
\v 9 Mang'une quşeençe kuma qığeç'u, 
\q2 ghalençe gyooxhan haa'an ts'a ı'xiyxə. 
\q2 Mançikeb gyopxhanna ghadır k'yoohar. 
\q1  
\v 10 Mang'vee xəybı qaxı, ç'iyelqamee geç'ena. 
\q2 Miç'axiyvalla Mang'une g'elybışik avub vuxha. 
\q1  
\v 11 Sa keruvulil\f + \fr 17:11 \fq Keruv: \ft xılibınana malaaik vor.\f* alixı, 
\q2 mıtsıne xılibışil ilexa. 
\q1  
\v 12 Hiqiy-allan ciga xəmdilqa sak'al ha'a, 
\q2 xhineka gyatsts'ıyne k'aarıne buludbışike Culqa aççesın kar ha'a. 
\q1  
\v 13 Mang'une nuruke buludbı ileedaxva, 
\q2 Mang'uke dolu, gyotxhanan ts'a qı'ğəə ıxha. 
\q1  
\v 14 Rəbbee xəybı g'əhətqə'ə, 
\q2 Haq'-Ta'aalee ses gyayhe, 
\q1 dolu, gyotxhanan ts'a g'ıxele. 
\q1  
\v 15 Vukbı avhu, duşmanar ehevkaa'anbı, 
\q2 ts'ayılpan ı'xı'ı', manbı oot'al-ooxal haa'anbı. 
\q1  
\v 16 Ya Rəbb, Yiğne qəvəəq'ənasde sesıke, 
\q2 quşeençene qı'ğəəne it'umne nafasıke, 
\q1 deryahın k'oralybı g'ece giyğal, 
\q2 dyunyeyn xhebbı g'ece giyğal. 
\b  
\q1  
\v 17 Mang'vee xəybışeençe xıl hotku, zı aqqı, 
\q2 zı k'orane xhyanbışeençe qığavhu. 
\q1  
\v 18 Zı gucnane duşmanıke Mang'vee g'attixhan hı'ı, 
\q2 zı g'ımece eyxhenbışike, 
\q2 yizdemee geeb gucnanbışike g'attixhan hı'ı. 
\q1  
\v 19 Yizde pisde yiğıl manbı yizde ögiylqa qığeepç'ı, 
\q2 Rəbbeeme zı aqqı. 
\q1  
\v 20 Mang'vee zı dağamiyvalike hixu'u, 
\q2 zı ıkkiykın, zı g'attixhan hı'ı. 
\q1  
\v 21 Yizde qopkuvalis sik'ı Rəbbee zas huvu, 
\q2 yizde xılene məttıvalis sik'ı huvu. 
\q1  
\v 22 Mang'vee məxüd hı'iyn, zı Rəbbina yəq' avquva, 
\q2 pisda ıxha Allahılqa yı'q' sak'al hidi'ıva. 
\q1  
\v 23 Mang'un gırgın q'aanunbı yizde ögiyl vod, 
\q2 Mang'une g'aydabışiler hixu deş. 
\q1  
\v 24 Zı Mang'une ögiyl məttıne yik'eka ıxha, 
\q2 zıcar zı bınahıke havacına. 
\q1  
\v 25 Rəbbee yizde qopkuvalis sik'ı huvu, 
\q2 Cune ulene ögiyl yizde məttıne işbışis sik'ı huvu. 
\b  
\q1  
\v 26 Ğu saadik'ranang'uka saadik'ra eyxhe, 
\q2 kaamilinbışika kaamilyra vor. 
\q1  
\v 27 Məttınbışika məttıra, 
\q2 quç'opkuriynbışika, cone quç'opkuriys sik'ı eyxhe. 
\q1  
\v 28 Hooç'an-g'ooç'ananbı Ğu g'attivxhan haa'a, 
\q2 cocab-co axtıba vukkekanbışilqab Ğu ul giviyxhe, 
\q2 manbı k'ap'ik'ıle avqa qaa'a. 
\q1  
\v 29 Rəbb, Ğu yizın işix qayhe, 
\q2 Ğu yizda miç'axiyvalla nurulqa savaak'al haa'a. 
\q1  
\v 30 Zı Vakasana duşmanaaşikın ha'a, 
\q2 yizde Allahıka şaharbı aqqaqqa. 
\b  
\q1  
\v 31 Allahna yəq kaamilyba vob, 
\q2 Rəbbin cuvab məttıda vod! 
\q1 Mang'ulqa yı'q' qizzırna gırgına, 
\q2 Mang'vee g'attixhan ha'ana. 
\q1  
\v 32 Rəbbile ğayrı, Allah vuşune vor? 
\q2 Yişde Allahıle ğayrı, medın ganz nenne vod? 
\q1  
\v 33 Allahee zas dəv'ee guc hoole, 
\q2 Mang'vee yizda yəq qopku qaa'a. 
\q1  
\v 34 Mang'vee yizın g'elybı maralın g'elybı xhinne ek' qa'a, 
\q2 Zı axtıvalee it'umra aqqaqqa. 
\q1  
\v 35 Mang'vee yizın xıleppı dəv'əysın xhinne qa'a, 
\q2 zasse tuncıke hı'iyn vuk quç'okara'as əxən. 
\q1  
\v 36 Ğu zas g'attixhana'asın g'alxan huvu, 
\q2 Yiğne sağne xılen zı aqqaqqana. 
\q1 Ğu hı'iyne kumaagıka zı axtı qı'ı. 
\q1  
\v 37 Zasse saccu Vaka əq'ra iykaras əxə, 
\q2 zı məxür qaçayxarır deş. 
\b  
\q1  
\v 38 Zı duşmanaaşiqa qihna girxhu, manbışiqa avarq'ılyna, 
\q2 manbışikın ixhesmee yı'q'əlqar sak'ı deş. 
\q1  
\v 39 Zı manbı hööq'əv'u ç'əvxhana, 
\q2 manbışisse suğoots'asıb vəvxü deş. 
\q1  
\v 40 Dəv'əynemee Ğu zalqa guc alipk'ır, 
\q2 zalqa g'elil qeepxhaynbı Ğu yizde g'eliqqa huvu. 
\q1  
\v 41 Duşmanar zale heepxasınbı xhinne qaa'a, 
\q2 zı g'ımecenanbışikınıd zı hı'iyn. 
\q1  
\v 42 Manbışe kumagıs qopt'uleeyib, 
\q2 manbı g'attivxhan haa'anbı vuxha deş, 
\q1 Rəbbilqa onu'eeyid, Mang'vee alidghıniy quvu deş. 
\q1  
\v 43 Zı manbı k'ööq'ü, tooz xhinne qav'u, 
\q2 mıtsınıb manbı inyaqa-şaqa dağav'u. 
\q2 Zı manbı şahrabışeedın battağ xhinneeyib hööq'üynbı. 
\b  
\q1  
\v 44 Ğu zı, yizde milletne g'elil qeepxhayke g'attixhan hı'ı, 
\q2 zake milletbışda xərna hı'ı, 
\q2 zak'le dyats'ancad milletbı yizde xılyaqa quvu. 
\q1  
\v 45 Menne cigeençenbı yizde ögiyl k'yoozarav'uynbı, 
\q2 yizın do g'ayxhımee, eyhen ha'a. 
\q1  
\v 46 Menne cigeençenbı yizde ögiyl hapq'ıriynbı. 
\q2 Qəpq'ı'n zezebı atk'u, 
\q2 dyuguleepxhayne cigeençe qığeepç'iynbı. 
\b  
\q1  
\v 47 Rəbb vorna! Yizde Ganzıs şukur vuxhena! 
\q2 Zı g'attixhan hı'iyn Ganz, Allah, axtı qe'e! 
\q1  
\v 48 Allahee zal-alla qəl qığaaha, 
\q2 milletbı yizde xılyaqa qele. 
\q1  
\v 49 Mang'vee zı yizde duşmanaaşine xılençe g'attixhan ha'a, 
\q2 Mang'vee zı yizde duşmanaaşile ooqana ha'a, 
\q2 Zı eb ulyooğanbışde xılençe g'attixhan hı'ı. 
\q1  
\v 50 Rəbb, mançil-alla zı Ğu menne milletbışde yı'q'nee axtı qa'as, 
\q2 zı Yiğne doyus şukur haa'as! 
\b  
\q1  
\v 51 Allahee Cune paççahıs xədın ğamxhaybı heles, 
\q2 g'əyxı'yne Davudne nasıles gırgıne gahbışilycab yugvalla haagvas. 
\c 31  
\cl Allahee havacena 
\d Maskil\f + \fr 31:0 \fq Maskil:\ft  İne cuvabın cühüt'yaaşine mizel in mə'nabıd hele eyxhe: «ats'al, mı'sləhət», «uftanba gipk'ınna mə'niy».\f*, Davudna mə'niy. 
\q1  
\v 1 Şavunbıyiy bınahbı Rəbbe yik'elixanı'ı, 
\q2 Şavunbıyiy qotkuda hidi'iyn harakatbı hakkal hı'ı, nimee baxtivariy! 
\q1  
\v 2 Cuna bınah dyugulydyaa'ana, 
\q2 Rəbb bınahılee ilheç'una insan, nimee baxtivariy! 
\b  
\q1  
\v 3-4 Gardanaqa alyat'asmee zı əvəray hav'u. 
\q2 Yiğbına, xəmbına Yiğna yı'q'na xıl zal oğa vuxha. 
\q1 Yizda guç g'apt'ına g'ı'liyne pırane yiğıl qəhətxhayn çiy xhinne. 
\q2 Ik'arang'an xhineyid yizın bark'vbıd rı'hı'le g'a'atk'u. 
\b  
\q1  
\v 5 Manke zı bınah Yiğne ögiyl gardanaqa alyapt'ına, 
\q2 Yizın qotkuda hidi'iy Vale dyugul hı'ı deş. 
\q1 Qiyğa zı uvhuyn: «Zı bınahbı Rəbbine ögiyl gardanaqa alyat'anbı», 
\q2 Ğunar yizde bınahıle ilheç'una. 
\q1  
\v 6 Mançil-allab Yiğna yəq avquyng've, 
\q2 Ğu iveekemee Valqa düə hee'ecen. 
\q1 Məhrıng'uk xədın xhyanbıd qadıyng'a set'as deş. 
\q1  
\v 7 Zı dyugulexhen ciga Ğu vorna, 
\q2 Ğu zı dağamiyvalike g'attixhan ha'as, 
\q2 Ğamxhayn şadvalin mə'niybı, Ğu yizde hiqiy-alla alik'ara'a. 
\b  
\q1  
\v 8-9 Ğu eyhen: «Balkaniy g'atir xhinne ək'el kamba mexhe, 
\q2 Manbı salbaniy g'antarağa dena 
\q2 Ğu eyhençilqa qalya'as əxə deş. 
\q1 Zı vas ək'el hevles, 
\q2 Ğu əlyhəəsda yəq haagvas. 
\q1 Zı ğu hot'alasda, 
\q2 Yizda ul val vobna». 
\b  
\q1  
\v 10 Yəq avguynbışde vuk'lelqa xətta divanbı adaylenbı, 
\q2 Rəbbir culqa umud ha'anbışiqa 
\q2 Hammaşee yugra eyxhena. 
\q1  
\v 11 Qopkuyn insanar, vuşda şadvalla Rəbbil-alla vuxhecen. 
\q2 Yik' məttınbı, şadvalina mə'niy Rəbbinimee qəpqe. 
\c 89  
\cl 89 
\d  
\v 1 Allahne insanna Mısayna düə 
\q1  
\v 2 Nimee nasılbı badaledxheyid, 
\q2 Xudaavanda, şi Valqa yı'q' qizzır. 
\q1  
\v 3 Suvabıyiy ç'iyeyn aq'va, dyunye ixhanassecad Ğu Allah ıxha, 
\q2 Gırgıne gahbışilır Allahcar ixhes. 
\b  
\q1  
\v 4 Ğu insanar nyuq'nelqa savaak'al haa'a. 
\q2 Ğu manbışik'le eyhen: «Aadamın dixbı, nyuq'nelqa savk'le». 
\q1  
\v 5 Yiğne ulesqa aazır sen, sa ılğeç'uyn yiğ xhinne, 
\q2 Xəmdiyna sa-q'öble sə'ət xhinne qadayle. 
\q1  
\v 6 Selin xhinne Ğu insanar vukkeka, 
\q2 Manbı nyak' xhinne qabı avayk'an. 
\q1 Manbı miç'eeb alyabıyne ok'uk akar: 
\q2 miç'eeb k'atele qooxhe t'et'-t'ele g'ayhe, 
\q2 xəmdemee hı'ç'ı'bğı'n, qooqqana. 
\q1  
\v 7 Yiğne qəlan şi gyabat'anbı, 
\q2 Vaqa qəlnang'a şi nyaqame vuxhesınbı aaxva. 
\q1  
\v 8 Yişin taxsirbı Vak'le ats'a, 
\q2 Yişde dyugulene bınahbışilqa Yiğne aq'vayn nur gexha. 
\q1  
\v 9 Ğu qəllamışxheene yişda ı'mı'r cit'a qooxhe. 
\q2 Yişin senbı ul gyapxı aaqasse ılğeeç'enbı. 
\q1  
\v 10 Şi yights'al (70) sennana ı'mı'r haa'a, 
\q2 Vuk'diyk'ıree molyts'aleeqab (80) hiviyxharanbı. 
\q1 Mane senbışin g'ellesınbıd dağamiyvalee, ı'k'aree ı'lğəə, 
\q2 Yişda ı'mı'r zarabacab ç'əvooxhena, alivxu avayk'an. 
\q1  
\v 11 Şavuk'lene Yiğne qəlına guc vaats'a? 
\q2 Vale nimeeyiy qəvəyq'ən, 
\q2 Vaqa manimeenab qəl vob. 
\q1  
\v 12 I'mı'r cit'aba vuxhay şas yik'el qale'e, 
\q2 Şi ək'elika vuxhes. 
\b  
\q1  
\v 13 Ya Rəbb, şasqa sak'le! Nimeene gahnane inəxüd ixhes? 
\q2 Yiğne g'ulaaşis rəhı'm hee'e! 
\q1  
\v 14 Şi gırgıne gahbışil şadba vuxhecenva, 
\q2 Miç'eeb şalqa Yiğna yugvalla gyooğee'e. 
\q1  
\v 15 Şalqa ver ablyav'uyn yiğbımee, 
\q2 Balyaa ablyav'uyn senbımee, şi şad hee'e. 
\q1  
\v 16 Ğu hı'iynbı Yiğne g'ulaaşik'le, 
\q2 Yiğna xəbvallab cone uşaxaaşik'le g'avcecen. 
\q1  
\v 17 Ay Xudaavanda yişda Allah, şaqa yugra ixhe, 
\q2 Yişde xılen hı'iynçis baraka hevle, 
\q2 Hucoone ixhes, yişde xılen hı'iynçis baraka hevle. 
\c 111  
\cl Allahee qopkuyne insanaaşis xayir-düə hoole 
\q1  
\v 1 Rəbbilqa şukur hee'e! 
\b  
\q1 Nimee baxtivariy Rəbbile qəyq'ənna, 
\q2 Mang'un əmrbı yik'eençe ha'ana! 
\q1  
\v 2 Qəyq'anang'un uşaxar ç'iyeyne aq'val gucuka vuxhes, 
\q2 Qopkuyng'unbışde uşaxaaşeeb xayir-düə alyapt'as. 
\q1  
\v 3 Qopkuynbı karnanbı, barakatnanbı vuxhes, 
\q2 Manbışda qopkuvalla, mısacab aagvales deş. 
\q1  
\v 4 Miç'axiyvaleeyid qopkuynbışdemee nur ixhes, 
\q2 Manbı yugun, rəhı'mıkan, qopkuyn insanar vob. 
\q1  
\v 5 Qidiykkın borcbı helenbışiqayiy horbı hidya'anbışiqa 
\q2 yugna ı'mı'r vuxhes. 
\q1  
\v 6 Məxbın insanar mısacab qaçaaxaras deş, 
\q2 Qopkuyn insanar hammaşe yik'bışee aaxvas. 
\q1  
\v 7 Manbı pisde xabarıle qəvəəq'ənas deş, 
\q2 Rəbbilqa qibzırva manbışin yik'bı it'umda ixhes. 
\q1  
\v 8 Manbışin yik'bı it'umda vod, manbı qəvəəq'ənas deş, 
\q2 Manbışik'le con duşmanar avub aaxva g'avces. 
\q1  
\v 9 Manbışe con var-devlet, kar deşinbışis qidiykkın bit'al hı'ı, 
\q2 Manbışda qopkuvallab hammaşiys aaxvas, 
\q1 Manbışde gucus geeb hı'rmat gyuvxhes. 
\b  
\q1  
\v 10 Karaı'dəəne insanık'le man g'acu qəl vuxhes, 
\q2 Manbışe mizyar ats'ak'vanas, əəq'əsınbı. 
\q1 Manbışis ıkkananbı ixhes deş. 
\c 112  
\cl Rəbbik Allahık akarna vornane? 
\q1  
\v 1 Rəbbilqa şukur hee'e! 
\b  
\q1 Rəbbin nukarar, şukur hee'e, 
\q2 Rəbbine doyus şukur hee'e! 
\q1  
\v 2 G'iyniyke şaqa, gırgıne gahbışis 
\q2 Rəbbin do axtı qe'e! 
\q1  
\v 3 Şargıle garbılqamee 
\q2 Rəbbine doyus şukur hee'e! 
\b  
\q1  
\v 4 Rəbb gırgıne milletbışile axtıra vor, 
\q2 Mang'una xəbvallab xəybışileb axtıba vob! 
\q1  
\v 5 Axtıne xəybışeene taxtıl gyu'urne, 
\q2 Yişde Rəbbik Allahık akarna vornane? 
\q1  
\v 6 Xəəqə, ç'iyeyqa 
\q2 K'yorzul ilyakkana Mana vor. 
\b  
\q1  
\v 7 Mang'vee vuççud deşda, toozençe suğoots'a'a, 
\q2 Goreençena fağırır axtı qa'a, 
\q1  
\v 8 Manbı cone milletne ç'ak'ınbışika, 
\q2 Sacigee gyuv'ar haa'asva. 
\q1  
\v 9 Mang'vee uşax dexhene xhunaşşeys uşaxar hoole, 
\q2 Məxür məng'ı'ke baxtivarna yed hee'e. 
\b  
\q1 Rəbbilqa şukur hee'e! 
\c 150  
\cl Rəbbis şukur hee'e! 
\q1  
\v 1 Rəbbis şukur hee'e! 
\b  
\q1 Muq'addasne Cune cigee 
\q2 Allahıs şukur hee'e! 
\q1 Mang'vee Cuna guc 
\q2 xəybışeene taxtıl haagva. 
\q2 Mang'us şukur hee'e! 
\q1  
\v 2 Ç'ak'ıne işbışil-alla 
\q2 Mang'us şukur hee'e! 
\q1 Ç'əvcab dyooxhene Mang'une xəbvalis sik'ı 
\q2 Mang'us şukur hee'e! 
\b  
\q1  
\v 3 Gaçeençe\f + \fr 150:3 \fq Gaç: \ft İzrail ts'erna paççah taxtıl gyu'urva, gaçeençe syuty haa'a vuxha.\f* qı'ğəəne seseka 
\q2 Mang'us şukur hee'e! 
\q1 Arfaykayiy, lirayka 
\q2 Mang'us şukur hee'e! 
\q1  
\v 4 Dafıka, mık'ar ha'a-ha'a, 
\q2 Mang'us şukur hee'e! 
\q1 Sazıka, dyuttyak'ıka 
\q2 Mang'us şukur hee'e! 
\q1  
\v 5 İt'umda ses qı'ğəəne 
\q2 naq'rabışde seseka 
\q2 Mang'us şukur hee'e! 
\q1 G'avayghane sesnane naq'rabışika 
\q2 Mang'us şukur hee'e! 
\b  
\q1  
\v 6 Nafas hıxelen gırgınbı 
\q2 Rəbbis şukur hee'e! 
\b  
\q1 Rəbbis şukur hee'e!