\p \w The|strong="H6440"\w* \w king|strong="H4428"\w* shouted \w out|strong="H3318"\w*, “\w Is|strong="H1571"\w* \w he|strong="H1004"\w* \w even|strong="H1571"\w* \w going|strong="H3318"\w* \w to|strong="H7725"\w* \w rape|strong="H3533"\w* \w the|strong="H6440"\w* \w queen|strong="H4436"\w* \w here|strong="H5921"\w* \w in|strong="H5921"\w* \w the|strong="H6440"\w* \w palace|strong="H1004"\w*, \w right|strong="H1571"\w* \w in|strong="H5921"\w* \w front|strong="H6440"\w* \w of|strong="H4428"\w* \w me|strong="H6440"\w*?” \w As|strong="H1697"\w* soon \w as|strong="H1697"\w* \w the|strong="H6440"\w* \w king|strong="H4428"\w* \w said|strong="H1697"\w* \w this|strong="H1697"\w*, \w the|strong="H6440"\w* \w servants|strong="H6440"\w* \w covered|strong="H2645"\w* \w Haman|strong="H2001"\w*'s \w face|strong="H6440"\w*.
\p 
