\id JHN  
\h SAN JUAN 
\toc1 Tí tan jína chrónka chꞌín Juan 
\toc2 SAN JUAN 
\toc3 Jn. 
\mt1 Tí tan jína chrónka chꞌín Juan 
\c 1  
\s1 Tí nkexro chrónkaxín nkexrí tjen Dios mé kꞌóna ijnko chojni chjasintajni 
\p  
\v 1 12A̱ ntá tí xrankíxixín na̱xa̱ kꞌónahya tí chjasintajni a na mé xráxín tjen tí nkexro chrónkaxín nkexrí tjen Dios, na mé Cristo tíha, na mé kjuákꞌeko Dios na mé kja̱xin Dios tíha.  
\v 2 Tí xrankíxixín na mé tí nkexro xráxín kjuákꞌeko Dios  
\v 3 la ko kjuachaxin kuènte chꞌán na mé kꞌónaxín kaín xín nkehe siín jie. A̱ ntá kohya ninkehó nkehe kꞌónakoá, na mé kaín xín nkehe siín na mé kꞌónaxín tí kjuachaxin kuènte chꞌán.  
\v 4 Jehe chꞌán na mé kjuanjon kjuachaxin kaín nkehe síchón siín chjasintajni la ko jehe chꞌán mé xrohi tꞌinkaséyanxínhin jnkojnko nti̱e chojni chjasintajni.  
\v 5 Tí xrohi a mé tꞌinkaséyanxín tí sítié a. A̱ ntá tí sítié a mé tjinkaon chrókꞌókꞌa̱nka tí xrohi a, kjánchó kjuachahya kꞌókꞌa̱nka. 
\p  
\v 6 Ntá kjuákꞌe ijnko chojni kꞌue̱tue̱nhen Dios kui mé itꞌin chꞌán Juan.  
\v 7 Ikui chꞌán kjuákꞌechrónka chꞌán nkexrínchi tjen tí xrohi tꞌinkaséyanxín chjasintajni kíxin kaín xín chojni chrókuitekaon sín tí tjechrónka chꞌán a.  
\v 8 A̱ ntá tí chꞌín Juan la jehya tí xrohi a. Ó kꞌuítuenhón chꞌán kui chꞌán kíxin tsochrónka chꞌán nkerí kuènte tí xrohi a.  
\v 9 A̱ ntá tí xrohi chaxín tꞌinkaséyanxínhin kaín xín chojni na ó tsíki chꞌán chjasintajni jie. 
\p  
\v 10 Kjuákꞌe chꞌán chjasintajni na mé Dios tsíkjichꞌénaxín chꞌán chjasintajni tí kjuachaxin kuènte tí nkexro a na kjónté kjuákꞌe chꞌán chjasintajni na na̱xa̱ kjuátso̱anhya sín chꞌán.  
\v 11 Ikui chꞌán tí tjejó tí sín judío kꞌuaxrjeníxin chꞌán, kjánchó kuítekakuenhya sín chꞌán.  
\v 12 A̱ ntá tí sín kuítekaon sín chꞌán mé kꞌuáyéhe̱ sín kjuachaxin kíxin tsꞌóna sín xje̱en Dios.  
\v 13 Ntá yóe̱hya tsꞌaxrjeníxin sín itꞌé sín chjasintajni ntihyó la ko yóe̱hya ijnko itꞌé chrókjuenka̱yáxin chꞌán chrókjuichꞌéna chꞌán ijnko xjan. Náhí. Dios mé kjueyá chꞌán nkexro tsꞌóna xje̱en chꞌán. 
\p  
\v 14 A̱ ntá tí nkexro chrónkaxín nkexrí tjen Dios na mé kꞌóna ijnko chojni chjasintajni kjuákꞌenkákjanni chꞌán na mé imá kꞌuétjuèhé chꞌán chojni chjasintajni la ko imá ntoá chrónka chꞌán. Kuayeni kꞌuíkonni kíxin imá tꞌe̱to̱an chꞌán kíxin jehe chꞌán mé tí jnkoko̱áxón Xje̱en Itꞌéni tjen nkaya nka̱jní na mé xi̱kaha imá tꞌe̱to̱an chꞌán. 
\p  
\v 15 Chꞌín Juan mé chrónka chꞌán nkexrí tjen tí nkexro a. Ntáchro chꞌán kíxin: 
\p ―Senó kꞌuékjákohárá kíxin chrꞌéxi̱n tsi tí nkexro a, na mé a̱ntsí má tꞌe̱to̱an chꞌán, a̱ ntá janhan la náhí kíxin tí janhan na̱xa̱ kohyana la tí jehe chꞌán la ó xráxín tjen chꞌán ―mé xi̱kaha chrónka chꞌín Juan. 
\p  
\v 16 Kaínni ó kꞌuáyéhe̱ni tí kjuachaxin jié tjetjanjon chꞌán la ko a̱ntsí má tjencheyaonni chꞌán la ko tjencheyaonni chꞌán.  
\v 17 Dios mé tsíkꞌe̱tue̱nhen chꞌín Moisés kíxin tsokjin chꞌán tí ley. A̱ ntá Ìnchéni Jesucristo mé kjua̱ko̱xi̱n chꞌán kíxin nkexrí imá tjuèhé Dios tí chojni chjasintajni. A̱ ntá kaín nkehe chrónka chꞌán mé a̱ntsí ntoá.  
\v 18 Kohya ninkexró chjasintajni kꞌuíkon sín Dios a. A̱ ntá tí jnkoko̱áxón Xje̱en chꞌán na mé xráxín jnkoko̱á tjenka̱yáxinko Itꞌé chꞌán la mé jehe chꞌán mé ó kjuínchekónoheni chꞌán nkexrí tjen Itꞌé chꞌán nkaya nka̱jní. 
\s1 Chꞌín Juan mé chrónka chꞌán nkexrínchi tjen chꞌín Jesús 
\r (Mt. 3.11-12; Mr. 1.7-8; Lc. 3.15-17) 
\p  
\v 19 Iso tí sín judío kꞌuéjó sín chjasin Jerusalén na ntá ichrꞌán sín iso chojni ncha̱tꞌá la ko iso tí sín levita, ikui sín kuinixje̱he̱ sín tí chꞌin Juan kjuanchankíhi sín chꞌán kíxin: 
\p ―¿Nkexro tí jaha? ―ichro sín. 
\p  
\v 20 Ntá kjuínchemáhya chꞌán, ntáchro chꞌán kíxin: 
\p ―Náhí. Jehya janhan tí Cristo ―ichro chꞌán. 
\p  
\v 21 Ntá xíkjanchankíhi sín chꞌán ínaá, ntáchro sín kíxin: 
\p ―¿Xá nkexro tí jaha? ¿Á jaha tí profeta Elías? ―ichro sín. 
\p Ntá chꞌín Juan la xíkjate̱he chꞌán ntáchro chꞌán kíxin: 
\p ―Náhí. Jehya janhan Elías ―ichro chꞌán. 
\p Ntá xíkjanchankíhi sín chꞌán ínaá kíxin: 
\p ―¿Á jaha tí nkexro tjejóchónhenni itsi tsochrónka itén Dios? ―ichro sín. 
\p Na ntá ntáchro chꞌín Juan ínaá kíxin: 
\p ―Náhí. Janhya ―ichro chꞌán. 
\p  
\v 22 Ntá kjuanchankíhi sín chꞌán ínaá kíxin: 
\p ―¿Ntá nkexro jaha? Tꞌichjánxi̱n tso̱noheni tsochénkani tí sín ichrꞌánni ikuini. ¿Nkehe tso̱chro̱nka kíxin nkexro tí jaha? ―ichro sín. 
\p  
\v 23 Ntá kjuáte̱he chꞌín Juan ntáchro chꞌán kíxin: 
\p ―Janhan mé tí nkexro tsjakꞌe nte̱je̱ tsꞌèya tso̱xrja̱nka kíxin: “Takitje̱hérá ijnko nti̱a ntoí tsi̱xi̱n Ìnchéni” ―mé xi̱kaha ichro chꞌán kjuáte̱exín chꞌán itén chꞌín Isaías kꞌuéchrónka xroon itén Dios ósé.\f + \fr 1:23 \ft Isaías 40.3\f* 
\p  
\v 24 A̱ ntá tí sín fariseo mé tsíchrꞌán tí jehe sín kuikjanchankíhi sín tí chꞌín Juan.  
\v 25 A̱ ntá kjuanchankíhi sín chꞌán kíxin: 
\p ―Ó ntáchrua kíxin jahya tí Cristo tí nkexro tsaáxin chojni la ko jahya tí Elías, la ko jahya nijnko tí nkexro kꞌuéchrónka itén Dios ósé. ¿A̱ ntá nkekuènté tíki̱te chojni tí xi̱kaha? ―mé ichro sín. 
\p  
\v 26 Ntá ntáchro chꞌín Juan kíxin: 
\p ―Janhan na mé ìnta̱ ó tíki̱texián chojni. Ó ntihi tjenkákjan ijnko nkexro na̱xa̱ tjátso̱anhyará.  
\v 27 Jehe chꞌán mé tsi chꞌán nóton tí janhan. A̱ ntá a̱ntsí má tꞌe̱to̱an chꞌán, a̱ ntá janhan na kénhyó. A̱ ntá tósuàna chrókjuasínta̱nka̱ tí correa to̱ka̱té chꞌán ―ichro chꞌán. 
\p  
\v 28 Kaín tíha mé tsíkónhen tí chjasin itꞌin Betábara tí nó tji̱to̱xi̱n ya̱on tóhe tí nta̱río Jordán tí kjuákꞌe chꞌín Juan kui̱ki̱te chojni. 
\s1 Chꞌín Jesús na mé éxí yóhe̱ ijnko kolélo kuènte Dios 
\p  
\v 29 A̱ ntá tí ya̱on chrꞌéxi̱n mé kꞌuíkon chꞌín Juan kíxin ó tjekui chꞌín Jesús. Ntá nixje̱he̱ chꞌán tí sín tsíkóchjina ntáchro chꞌán kíxin: 
\p ―Tsjehérá tí nkexro tjekui mé tí Kolélo kuènte Dios jehe chꞌán. Tíha mé tsjìinxín iji̱é chojni chjasintajni.  
\v 30 Janhan mé kꞌuéxrja̱nka kíxin tí iton tí janhan mé tsichréhe̱ ijnko nkexro a̱ntsí tꞌe̱to̱an, a̱ ntá janhan la kénhyó této̱an kíxin na̱xa̱ kohyana na jehe chꞌán la ó xráxín tjen chꞌán.  
\v 31 Kja̱xin janhan na̱xa̱ chonhya nkexro tíha. A̱ ntá xra̱ ó kꞌuinka kjuakꞌé kuíki̱texián chojni ìnta̱ kíxin tí chojni nación Israel mé chrókjuátso̱anxín sín chꞌán ―ichro chꞌín Juan 
\p  
\v 32 Kjuintaxín ntáchro chꞌín Juan kíxin: 
\p ―Ó kꞌuíkua̱n kíxin tí Ncha̱kuen Dios mé kꞌuínkaji̱nxi̱n nkaya nka̱jní na éxí yóhe̱ ijnko kontóá kꞌuínkajin la ko kjuákꞌe va ntoí tí tjen chꞌán.  
\v 33 A̱ ntá janhan kja̱xin na̱xa̱ chonhya nkexro tíha. A̱ ntá tí nkexro kꞌue̱tua̱nna kíxin tsjakꞌé tsíki̱texián chojni ìnta̱ mé tsíchrónka chꞌán kíxin tí Ncha̱kuen Dios mé tsꞌinkajin tsjakꞌe ntoí tí tjen ijnko chojni na mé tsjatso̱anxián janhan kíxin tí nkexro a mé tsi̱ki̱texín chꞌán Ncha̱kuen Dios chojni.  
\v 34 A̱ ntá janhan jie mé ó kꞌuíkonxín kua̱n kíxin xi̱kaha kónhen tí jehe chꞌán, a̱ ntá xrja̱nkaxián kíxin táha mé Xje̱en Dios tíha ―mé xi̱kaha chrónka chꞌán. 
\s1 Tí sín sa̱oxín kjueyá chꞌín Jesús 
\p  
\v 35 Tí ya̱on chrꞌéxi̱n kjuákꞌe chꞌín Juan la ko iyó tí sín kꞌuájiko chꞌán,  
\v 36 a̱ ntá xrína̱hya kꞌuíkon chꞌán kꞌuátsínka chꞌín Jesús. Ntá ntáchro chꞌín Juan kíxin: 
\p ―Tsjehérá tí nkexro i mé tí Kolélo kuènte Dios ―ichro chꞌán. 
\p  
\v 37 Ntá kuínhin tí yóí sín kꞌuájiko chꞌín Juan na ntá sákjuíchréhe̱ sín tí chꞌín Jesús.  
\v 38 Ntá kuinkátjíá chꞌín Jesús kꞌuíkon chꞌán kíxin tinkáchréhe̱ sín ntá kjuanchankíhi chꞌán sín kíxin: 
\p ―¿Xá nkehe xritjéyárá? ―ichro chꞌán. 
\p Ntá ntáchro sín kíxin: 
\p ―Maestro, ¿xá nketí nchia itjen? ―ichro sín. 
\p  
\v 39 Ntá kjuáte̱he chꞌán ntáchro chꞌán kíxin: 
\p ―Ìntá sátsjini tsꞌikonrá nketí ―ichro chꞌán. 
\p Ntá kuinkáchréhe̱ sín chꞌán kꞌuíkon sín nketí nchia kjuákꞌe chꞌán ntá kꞌuéjóko sín chꞌán kuenté tí kónjín kíxin kjuíji sín ntiha como las cuatro kónjín. 
\p  
\v 40 A̱ ntá yóí sín tsíkinhin sín tí chrónka chꞌín Juan ntá sákjuíchréhe̱ sín tí chꞌín Jesús na mé ijnko mé itꞌin Andrés. Jehe chꞌán chónta chꞌán ijnko sa̱vé mé itꞌin Simón Pedro.  
\v 41 Na ntá tuénxín tí chꞌín Andrés sákjuíkjeyá chꞌán tí sa̱vé chꞌán Simón. Ntá chénka chꞌán tí sa̱vé chꞌán kíxin: 
\p ―Ó kꞌuitjani tí nkexro Mesías ―ichro chꞌán. Tíha mé tꞌaxrjexín kíxin Cristo. 
\p  
\v 42 A̱ ntá chꞌín Andrés mé kui̱ka̱o chꞌán tí sa̱vé chꞌán Simón tí tjen chꞌín Jesús. Ntá chꞌín Jesús mé komá chꞌán tí chꞌín Simón ntáchro chꞌán kíxin: 
\p ―Jaha mé Simón, itꞌá mé itꞌin Jonás. Ntá jie si̱ntakꞌian Cefas ―ichro chꞌán. A̱ ntá tí palabra Cefas la ko tí palabra Pedro na mé yóí mé tꞌaxrjexín kíxin ixro̱ tíha. 
\s1 Chꞌín Jesús mé kjueyá chꞌán tí chꞌín Felipe la ko tí chꞌín Natanael 
\p  
\v 43 A̱ ntá tí ya̱on chrꞌéxi̱n mé sáchrókjui chꞌín Jesús tí estado Galilea. Ntá kꞌuitja chꞌán tí chꞌín Felipe, na ntá ntáche chꞌán kíxin: 
\p ―Chréhé tí janhan ―ichro chꞌán. 
\p  
\v 44 A̱ ntá tí chꞌín Felipe mé chjasén chꞌán mé itꞌín Betsaida tí chjasén chꞌín Andrés la ko chꞌín Pedro.  
\v 45 Ntá tí chꞌín Felipe mé sákjuíkjeyá chꞌán tí chꞌín Natanael na ntá chénka chꞌán kíxin: 
\p ―Ó kꞌuitjani tí nkexro tsi éxí kꞌuéchrónka tí chꞌín Moisés tí tsíkjin chꞌán tí xroon chrónka tí nkehe kꞌue̱to̱an Dios. Kja̱xin tí sín kꞌuéchrónka tí itén Dios chrꞌéxi̱n mé kꞌuéchrónka sín kíxin itsi tí nkexro a. Na ntá ó kꞌuitjani chꞌán na mé jehe chꞌán mé itꞌin Jesús, la itꞌé mé itꞌin José, la mé chjasén chꞌán mé Nazaret ―ichro chꞌín Felipe. 
\p  
\v 46 A̱ ntá ntáchro chꞌín Natanael kíxin: 
\p ―¿Xá kjuánchí má chrókójína tí nkehe chrókꞌuaxrjexín tí chjasin Nazaret a? ―ichro chꞌán. 
\p Ntá kjuáte̱he chꞌín Felipe ntáchro chꞌán kíxin: 
\p ―Xrákiá tsꞌikuan ―ichro chꞌán. 
\p  
\v 47 Na ntá kꞌuíkon chꞌín Jesús kíxin ó kui tinkákóchjina chꞌín Natanael, na ntáchro chꞌán kíxin: 
\p ―Ó kui ijnko chꞌín chaxín israelita la kohya nijnko kjuachꞌia xriko chꞌán ―ichro chꞌán. 
\p  
\v 48 Na ntá ntáchro chꞌín Natanael kjuanchankíhi chꞌán tí chꞌín Jesús kíxin: 
\p ―¿Nkexrí kíxin tjátso̱anna? ―ichro chꞌán. 
\p Ntá kjuáte̱he chꞌín Jesús ntáchro chꞌán kíxin: 
\p ―Na̱xa̱ nixja̱ahya tí chꞌín Felipe mé kꞌuíkua̱n tí jaha tjenka̱nkiá tí nta tꞌóna to higo ―ichro chꞌán. 
\p  
\v 49 Na ntá ntáchro chꞌín Natanael kíxin: 
\p ―Maestro, jaha la chaxín tí Xje̱en Dios tjen nkaya nka̱jní tsétue̱nhén tí nación Israel ―ichro chꞌán. 
\p  
\v 50 Ntá kjuáte̱he chꞌín Jesús ntáchro chꞌán kíxin: 
\p ―Jehya tí nkehe ntáxrja̱n kꞌuíkua̱n tjenka̱nkiá nta tꞌóna to higo, jehya táhó tsítekákonxian. Náhí. Chrꞌéxi̱n xiki í jnko kjuaxroan a̱ntsí má jié tsꞌíkuan, a̱ ntá tíhi la kénhyó ―ichro chꞌán. 
\p  
\v 51 Kja̱xin ntáchro chꞌín Jesús kíxin: 
\p ―Ijnko nkehe ntoá tso̱xrja̱nka kíxin tsoxitje̱he̱ tí nka̱jní tsꞌikonrá itsi itsjé tí sín ángel kuènte Dios mé tsꞌi̱tꞌótjen la ko tsꞌinkajin tí tjén janhan mé tí Xje̱en Dios Kꞌóna Chojni ―ichro chꞌán. 
\c 2  
\s1 Chjasin Caná estado Galilea kóte̱he ijnko chojni 
\p  
\v 1 A̱ ntá iní ya̱on chrꞌéxi̱n ntá kóte̱he ijnko chꞌín chjasin Caná estado Galilea. Mé koí tí ìné chꞌín Jesús tsíkꞌíye̱he̱ sín tjan la ntiha tjen tjan koí.  
\v 2 Kja̱xin tsíkꞌíye̱he̱ sín tí chꞌín Jesús la ko tí sín kꞌuájiko chꞌán kíxin sátsji sín tí tsíkóte̱he sín ntiha.  
\v 3 Ntá ó tsíkꞌanke̱he̱ sín tí xranvino ikꞌuí sín na ntá tí ìné chꞌín Jesús mé ntáche tjan tí jehe chꞌán kíxin: 
\p ―Ó tsíkꞌànka̱ xranvino itsꞌi sín ―ichro tjan. 
\p  
\v 4 Ntá ntáchro chꞌín Jesús kíxin: 
\p ―Naná, ¿nkehe tso̱nhen chro̱nka? Na̱xa̱ kjuixrakáhya tí ya̱on tsjásian kjuaxroan ―ichro chꞌán. 
\p  
\v 5 A̱ ntá tí ìné chꞌán na mé ntáche tjan tí sín chꞌe xra̱ kíxin: 
\p ―Tí chrén nkehe chrókꞌue̱tua̱nhanrá chꞌán chrókjui̱nchexiteyárá ―ichro tjan. 
\p  
\v 6 A̱ ntá siín ntiha injon chi̱ tsíkꞌóna xro̱ na mé tíha tjiá nta̱ tꞌònti sín kíxin xi̱kaha mé tsꞌaxrjehe tí jie̱ chónta sín koí, mé xi̱kaha kuinkáchónki tí sín judío. Na mé jnkojnko chi̱ mé tjacha tikia ochenta litro la o̱ ciento litro nta̱.  
\v 7 Ntá kꞌue̱tue̱nhen chꞌín Jesús tí sín chꞌe xra̱ kíxin: 
\p ―Tíki̱a̱rá nta̱ kaín tí chi̱ a tso̱kaón ―ichro chꞌán. 
\p Ntá kjuínchexiteyá sín kjuínchekaón sín nta̱ jnkojnko tí chi̱ a.  
\v 8 A̱ ntá ntáche chꞌín Jesús tí jehe sín ínaá kíxin: 
\p ―Tákjá intsí nta̱ tjiá chi̱ tjikuehé tí chꞌín tꞌe̱to̱an tí kia a ―ichro chꞌán. 
\p Ntá xi̱kaha kjuíchꞌe sín kjuínchexiteyá sín.  
\v 9 A̱ ntá tí chꞌín tꞌe̱to̱an tí kia a mé tsjexín chꞌán tí nta̱ tsíkꞌóna xranvino kjónté noehya chꞌán nketí kui̱xi̱n tí xran a. Jehó tí sín chꞌe xra̱ kui̱ka̱o sín mé nohe sín kíxin jehe sín mé tsíkakitsje sín nta̱. Ntá tí chꞌín tꞌe̱to̱an mé kꞌuíye̱he̱ chꞌán tí chꞌín tsíkóte̱he.  
\v 10 Ntáche chꞌán kíxin: 
\p ―Xráxín tí sín tjasin kia la senó tí xranvino náxrjón tjanjon sín na tió chrókꞌuihya tí sín tsíkóchjina na ntá tjanjon sín tí xranvino náxrjónhya. A̱ ntá jaha la náhí. Senó kjuakéchji̱na tí xranvino a̱ntsí má náxrjón, a̱ ntá tí jie tjetjánjuan jaha ―ichro chꞌán. 
\p  
\v 11 Tí kjuaxroan a kjuíchꞌe chꞌín Jesús chjasin Caná estado Galilea mé tí kjuaxroan sa̱oxín kjuasin chꞌán mé kjua̱ko̱xi̱n chꞌán nkexrí imá jié tí kjuachaxin kuènte chꞌán, a̱ ntá tí sín kꞌuájiko chꞌán mé kuítekaon sín tí jehe chꞌán. 
\p  
\v 12 Ntá ó kꞌuátsínka kia, a̱ ntá sákjuí chꞌán chjasin Capernaum, sákjuíko chꞌán ìné chꞌán la ko kíchó chꞌán la ko tí sín kꞌuájiko chꞌán, kóxrjenhen sín ntiha iso ya̱on. 
\s1 Chꞌín Jesús mé kjuínchetjóá chꞌán tí ni̱nko jié 
\r (Mt. 21.12-13; Mr. 11.15-18; Lc. 19.45-46) 
\p  
\v 13 A̱ ntá ó kuichjina tí ya̱on kia kuènte pascua kuènte tí sín judío. Ntá chꞌín Jesús sákjui̱ chꞌán chjasin Jerusalén.  
\v 14 Ntá nkaxenhen tí ni̱nko jié ntiha kꞌuíkon chꞌán tí sín nchekjixin koxinta la ko kolélo la ko kontóá. La ko ntiha kja̱xin tjejótja̱xi̱n tí sín tjinkíxixín chichaon.  
\v 15 Ntá chꞌín Jesús mé kuákja chꞌán ihno̱ tsíxehe̱ sín ntiha, kjuíchꞌéna chꞌán ijnko chikoté, ntá kuakitsjexín chꞌán sín nkaxenhen ni̱nko kaín xín sín la ko tí kolélo la ko tí koxinta. Na ntá tí ntamesa tjinkítóxixín sín tí chichaon mé kótéka chꞌán tsíkjaminkí xènjin tí chichaon a.  
\v 16 Ntá kꞌue̱tue̱nhen chꞌán tí sín nchekji tí kontóá a kíxin: 
\p ―Takítsjerá kaín tí nkehe a. Chꞌénahyará ijnko ntasin tí nto̱e Tꞌaná ntihi ―ichro chꞌán. 
\p  
\v 17 Ntá xráxinkaon tí sín kꞌuájiko chꞌán ti nkehe tsíkjin sín ósé kíxin: “Éxí xrohi kꞌuákjen a̱senná nínka̱van kíxin tí nto̱a tjikosáyehya sín.” \f + \fr 2:17 \ft Salmo 69.9\f* 
\p  
\v 18 Ntá tí sín judío mé kjuanchankíhi sín chꞌán kíxin: 
\p ―¿Xá nkerí kjuaxroan tsjásixián tsjáko̱xian nketí kjuachaxin chonta kíxin xi̱kaha kjui̱chꞌe tíhi? ―ichro sín. 
\p  
\v 19 Ntá kjuáte̱he chꞌín Jesús kíxin: 
\p ―Tí tsꞌoxíkará tí ni̱nko i ntá iníkoá ya̱on la ó si̱tꞌána ni̱xin tsjakꞌe ínaá ―ichro chꞌán. 
\p  
\v 20 Na ntá ntáchro tí sín judío a kíxin: 
\p ―Cuarenta y seis nánó kꞌuéjó sín kjuíchꞌéna sín tí ni̱nko i, a̱ ntá jaha ntáchrua kíxin iní ya̱on koá si̱chꞌéna ínaá, ichrua ―ichro sín. 
\p  
\v 21 Kjánchó kienxínhya sín kíxin tí ni̱nko ntáchro chꞌín Jesús la tí cuerpo kuènte chꞌán.  
\v 22 Ntá tió kjuixin xechón chꞌán ntá xráxinkaon tí sín kꞌuájiko chꞌán kíxin xi̱kaha tsíchrónka chꞌán, ntá kuítekaon sín tí xroon itén Dios tsíkjin sín ósé la ko tí nkehe tsíchrónka chꞌán. 
\s1 Chꞌín Jesús mé nohe nkehe tónhen a̱sén kaín xín chojni 
\p  
\v 23 Tió kjuákꞌe chꞌín Jesús chjasin Jerusalén tí kia pascua, a̱ ntá itsjé chojni kuinkáchónki sín tí jehe chꞌán kíxin ó kꞌuíkon sín tí kjuaxroan kjuasin chꞌán.  
\v 24 Kjánchó chꞌín Jesús la kuítekakuenhya chꞌán tí jehe sín kíxin jehe chꞌán la ó nohe chꞌán jína nkexrí tónhen a̱sén jnkojnko chojni  
\v 25 a̱ ntá tꞌichjánxi̱enhya chꞌán kíxin ninkexró chróchenka chꞌán nkexrí tjenka̱yáxin chojni kíxin ó kónohe chꞌán kaín nkehe tónhen a̱sén kaín xín chojni.﻿ 
\c 3  
\s1 Chꞌín Nicodemo kuinixje̱he̱ chꞌán tí chꞌín Jesús 
\p  
\v 1 Kjuákꞌe ijnko chꞌán kuènte tí sín fariseo a mé itꞌin chꞌán Nicodemo. Jehe chꞌán mé ijnko nkexro imá tjetoan kuènte tí sín Israel.  
\v 2 A̱ ntá ijnko tie kjuíchréhe̱ chꞌán tí chꞌín Jesús a nixje̱he̱ chꞌán ntáchro chꞌán kíxin: 
\p ―Maestro, kónoheni kíxin Itꞌéni tjen nkaya nka̱jní mé tsíchrꞌán kꞌuinka tsjákohéni kíxin tí jehya Dios chrókjuakꞌekoa la xitjahya chrókjuásian kjuaxroan jié ―ichro chꞌán. 
\p  
\v 3 Ntá kjuáte̱he chꞌín Jesús ntáchro chꞌán kíxin: 
\p ―A̱ ntá tso̱tjo̱nka ijnko nkehe imá tjetoan. Tí nkexro tsokjíehya ni̱xien mé xitjahya tsꞌikon tí kjuachaxin tsꞌe̱to̱an Dios ―ichro chꞌán. 
\p  
\v 4 A̱ ntá chꞌín Nicodemo kjuanchankí chꞌán ntáchro chꞌán kíxin: 
\p ―Ó tádana, ¿nkexrí chrókokjína ni̱xien? ¿Á chrókꞌuíxa̱nha̱n tse̱e na̱ná ínaá ntá chrókokjína ni̱xien ní? ―ichro chꞌán. 
\p  
\v 5 Ntá kjuáte̱he chꞌín Jesús ntáchro kíxin: 
\p ―Ntá tso̱tjo̱nka ijnko nkehe imá tjetoan. Jehó tí sín tsíkokjíexín nta̱ la ko kja̱xin tsíkokjíexín Ncha̱kuen Dios mé tsꞌáyéhe̱ sín tí kjuachaxin kuènte Dios.  
\v 6 Tió ijnko xjan tsꞌaxrjeníxin chojni na mé tí xjan mé chojni ó. A̱ ntá tí Ncha̱kuen Dios tsokjíexín ni̱xien ijnko chojni na ntá tsꞌáyéhe̱ sín tí Ncha̱kuen Dios a.  
\v 7 Chrakonhya tí nkehe xrja̱nka kíxin “Kaín chojni tꞌichjánxi̱n tsokjíhi ni̱xien.”  
\v 8 Éxí yóhe̱ tí tinhín tí chjéhe xri̱nto̱ ntá noahya nketí kui̱xi̱n tí xri̱nto̱ la ko noahya nketí sátsji na mé kja̱xin xi̱kaha kónhen kaín tí nkexro tsíkokjíexín Ncha̱kuen Dios ―ichro chꞌán. 
\p  
\v 9 Ntá xíkjanchankí chꞌín Nicodemo ínaá kíxin: 
\p ―¿Nkekuènté kíxin xi̱kaha chrókónhen? ―ichro chꞌán. 
\p  
\v 10 Ntá kjuáte̱he chꞌín Jesús ntáchro chꞌán kíxin: 
\p ―¿Jaha ijnko maestro imá tꞌe̱to̱an tí nación Israel ntá na̱xa̱ tiénxinhya tí nkehe ní?  
\v 11 Chaxín tjétjo̱nka tí nkehe nòna la ko tí nkehe kꞌuíkua̱n ntá títekákonnahya jaha.  
\v 12 Tí nkehe tjétjo̱nka la kuènte chjasintajni ó ntá kjónté la títekákonnahya jaha. ¿Ntá nkexrí chrókuítekávan tí chrótjo̱nka nkehe kuènte nkaya nka̱jní?  
\v 13 Kohya í jnko nkexro kꞌui̱tꞌótjen chjasin nkaya nka̱jní. Jehó tí Xje̱en Dios Kꞌóna Chojni mé kjuákꞌe chjasin nkaya nka̱jní la ko ntiha kui̱xi̱n chꞌán.  
\v 14 Éxí yóhe̱ chꞌín Moisés tió kꞌuíxin sín tí nte̱je̱, a̱ ntá Dios mé kꞌue̱to̱an kíxin sinchekjano̱ya chꞌán ijnko konche tsja̱kꞌe̱nka̱ni chꞌán ijnko nta, ntá xi̱kaha kjuíchꞌe chꞌán kjua̱kꞌe̱nka̱ni chꞌán tí konche tí nta a komá sín tí konche ntá kuaá sín kꞌuénhya sín, \f + \fr 3:14 \ft Números 21.9 \f* mé xi̱kaha tso̱nhen tí Xje̱en Dios Kꞌóna Chojni mé tꞌichjánxi̱n kíxin tsjakꞌenkáni chꞌán ijnko ntacruz  
\v 15 kíxin mé xi̱kaha kaín nkexro tsinkáchónki tí jehe chꞌán mé tsaá sín tsochónta sín kjuachón jnkochríxín. 
\s1 Dios imá tjuèhe chꞌán tí chojni chjasintajni 
\p  
\v 16 ’Kíxin Dios mé imá tjuèhe chꞌán chojni chjasintajni ntá kjuanjon chꞌán jnkoko̱áxón Xje̱en chꞌán, kíxin ntá jnkojnko chojni tsinkáchónki tí Xje̱en chꞌán mé tsꞌitjáyanhya sín tsochónta sín kjuachón jnkochríxín.  
\v 17 Chrꞌánhya Dios tí Xje̱en chꞌán chjasintajni kíxin sinchekjasóte chojni kíxin tí jie̱ kjuasin sín. Náhí. Ó jehí ichrꞌán chꞌán tí Xje̱en chꞌán chjasintajni kíxin sinchekaá chojni. 
\p  
\v 18 ’Na mé tí sín tsitekaon tí Xje̱en Dios la tsjasótehya sín. A ntá tí sín titekakuenhya sín na mé ó kjuixin kjuínchekito̱exín Dios tí iji̱é sín tsjasóte sín kíxin titekakuenhya sín tí jnkoko̱áxón Xje̱en Dios.  
\v 19 Na mé xi̱kaha Dios sinchekjasóte sín jnkochríxín kíxin ó kui tí nkexro tꞌinkaséyanxín chjasintajni na kjónté ntá a̱ntsí má tóxrjínhi̱n sín tí sítié a. A̱ ntá tí tꞌinkaséyan la náhí kíxin na̱xa̱ tóxrjínhi̱n sín tí nkehe jínahya tjejóchꞌe sín.  
\v 20 Kaín tí sín tjejóchꞌe nkehe jínahya na mé tóxrjíe̱nhya sín tꞌinkaséyan chrókóchjinehya sín kíxin tso̱noxínhya tí nkehe jínahya tjejóchꞌe sín.  
\v 21 A̱ ntá tí sín tjejóchꞌe sín tí jína a na mé chéhe̱ sín tóchjinehe sín tí tꞌinkaséyan kuènte Dios kíxin tso̱noxín tí nkehe chꞌe sín kíxin ntá kaín xín chojni mé tsjatso̱an sín kíxin tjejóchꞌe sín tí nkehe tóxrjínhi̱n Dios. 
\s1 Chꞌín Juan Bautista chrónka ínaá kuènte chꞌín Jesús 
\p  
\v 22 Na ntá chrꞌéxi̱n chꞌín Jesús la ko tí sín kꞌuájiko chꞌán na sákjuí sín estado Judea. Ntaha kꞌuéjóko sín chꞌán kui̱ki̱te chꞌán chojni.  
\v 23 Kja̱xin chꞌín Juan kjuákꞌe chꞌán chjasin Enón chjino tí chjasin Salim na mé ntiha kjuákꞌe kui̱ki̱te chꞌán chojni kíxin ntiha mé yeé nta̱ siín. Na ntá nkáki sín kuíkite sín.  
\v 24 Mé xi̱kaha kónhen na̱xa̱ kjuákꞌechjinahya chꞌín Juan. 
\p  
\v 25 Ntá tí sín kꞌuájiko chꞌín Juan la ko tí sín judío mé kjua̱cha̱xi̱n kíchó sín kíxin nkexrí íchá jína chrókótjuáxin chojni, ichro sín.  
\v 26 A̱ ntá tí sín kꞌuájiko chꞌín Juan sákjuítsjehe sín chꞌán chénka sín chꞌán kíxin: 
\p ―Maestro, tí chꞌín kjuákꞌekoa tóhe nta̱río Jordán, na mé tí nkexro tsíchro̱nka kuènte chꞌán, la mé itjen chꞌán ti̱ki̱te chꞌán chojni la ko kaín xín chojni mé tjichréhe̱ sín chꞌán ―ichro sín. 
\p  
\v 27 Na ntá ntáchro chꞌín Juan kixin: 
\p ―Tí chrókjuanjonhya Dios kjuachaxin ntá chrokjuahya chrókꞌuáyéhe̱ chojni.  
\v 28 Ó kuínhínrá ntoá kꞌuéxrja̱nka senó kíxin janhya tí Cristo. Náhí. Janhan ó kuítuannuá kuíto̱nxián nti̱a tso̱xrja̱nka kíxin ó tsi chꞌán.  
\v 29 Éxí yóhe̱ ijnko chꞌín tso̱te̱he na mé jehe chꞌán mé tsꞌáyéhe̱ chꞌán tí ichjién chꞌán. A̱ ntá tí chꞌín chóxin chꞌán mé chéhe̱ a̱sén chꞌán tjetinhin chꞌán tjenixja tí chꞌín tsꞌáyéhe̱ ichjién a. Mé xi̱kaha janhan imá chàna kíxin xi̱kaha sítónhen kíxin itsjé chojni sítóchjinehe sín tí chꞌín Jesús tsinhin sín nkehe tí tjenixja chꞌán.  
\v 30 A̱ ntá jehe chꞌán tꞌichjánxi̱n a̱ntsí tsꞌe̱to̱an chꞌán. A̱ ntá janhan la kénhyó ―mé chro chꞌín Juan. 
\s1 Tí nkexro kui̱xi̱n nkaya nka̱jní 
\p  
\v 31 Tí nkexro kui̱xi̱n nkaya nka̱jní mé kaín nkehe tꞌe̱tue̱nhen chꞌán. A̱ ntá ijnko chojni kuènte chjasintajni ó mé chrónka kuènte chjasintajni ó. A̱ ntá tí nkexro kui̱xi̱n nkaya nka̱jní mé kaín nkehe tꞌe̱tue̱nhen chꞌán.  
\v 32 Jehe chꞌán mé chrónka chꞌán tí nkehe tsíkꞌikon chꞌán la ko tí nkehe tsíkinhin chꞌán. Kjánchó kohya chojni titekaon sín tí nkehe chrónka chꞌán.  
\v 33 A̱ ntá jnkojín nkexro titekaon sín tí nkehe chrónka chꞌán na mé xi̱kaha tja̱ko̱xi̱n chꞌán jie kíxin chaxín ntoá chrónka Dios  
\v 34 kíxin tí nkexro ichrꞌán Dios mé nixja itén Dios kíxin jehya intsíkoá tí Ncha̱kuen Dios kꞌuáyéhe̱ chꞌán. Náhí.  
\v 35 Itꞌéni Dios mé tjuèhe chꞌán tí Xje̱en chꞌán na mé xi̱kaha ó tsíchjéhe chꞌán kjuachaxin kíxin kaín xín nkehe tsꞌe̱tue̱nhen chꞌán.  
\v 36 A̱ ntá tí nkexro tsitekaon tí Xje̱en Dios mé xi̱kaha tsochónta sín tí kjuachón jnkochríxín. A̱ ntá tí sín titekakuenhya sín tí Xje̱en Dios mé tsochóntahya sín tí kjuachón jnkochríxín xi̱kaha. Tí sín a mé Dios sinchekjasóte sín jnkochríxín.﻿ 
\c 4  
\s1 Chꞌín Jesús ikjo chꞌán ijnko tjan samaritana 
\p  
\v 1 A̱ ntá tí sín fariseo mé kónohe sín kíxin a̱ntsí tsjé chojni chréhe̱ sín tí chꞌín Jesús kui̱ki̱te chꞌán sín na ntá tí chojni chréhe̱ sín tí chꞌín Juan la kánhyó tsjé sín.  
\v 2 Kjánchó jehya chꞌín Jesús kui̱ki̱te chꞌán chojni. Méxra̱ tí sín kꞌuájiko chꞌán mé kui̱ki̱te sín chojni.  
\v 3 A̱ ntá tió kónohe chꞌín Jesús kíxin xi̱kaha tsíkinhin tí sín fariseo ntá kꞌuaxrjexín chꞌán tí estado Judea xíkjan chꞌán estado Galilea ínaá. 
\p  
\v 4 Ntá tꞌichjánxi̱n tsꞌátsínka chꞌán estado Samaria.  
\v 5 A̱ ntá kjuíji chꞌán ijnko chjasin mé itꞌin Sicar kuènte estado Samaria, mé chjino tí nonte tsíkjincheki̱to̱nhe̱n chꞌín Jacob tí xje̱en chꞌán José.  
\v 6 La ó chjino tjen tí tòye̱ takitsje chojni ìnta̱ mé itꞌin Ìnté Jacob. Na ntá ó chonkíxin kjui sín ntiha. Méxra̱ tí chꞌín Jesús la imá kóxrjé chꞌán kíxin imá kjín tí nti̱a kjui̱xi̱n chꞌán ntá kjuákꞌetja̱xi̱n chꞌán chrínta tí tòye̱ takitsje sín ìnta̱.  
\v 7-8 Ntahó kuíto̱he chꞌán. A̱ ntá tí sín kꞌuájiko chꞌán sákjuí sín tí chjasin chjinaxón sákjuíkꞌe̱na sín nkehe sineko sín chꞌán. Ntá séhyó ikui ijnko tjan kuènte estado Samaria ikui tjan tsakitsje tjan ìnta̱. Ntá ntáchro tí chꞌín Jesús kíxin: 
\p ―Chjìna intsí nta̱ itsꞌia ―ichro chꞌán. 
\p  
\v 9 A̱ ntá tí tjan samaritana mé kjuanchankíhi tjan tí chꞌín Jesús kíxin: 
\p ―¿Nkekuènté kíxin jaha ijnko chojni judío mé chrókjuanchana nta̱ kíxin janhan ijnko chojni samaritana? ―mé chro tí tjan a. 
\p (Mé xi̱kaha kjuanchankí tjan kíxin tí sín judío mé ninkehó tꞌikonhya tí sín samaritano.)  
\v 10 Na ntá ntáchro chꞌín Jesús kíxin: 
\p ―Chrókónoha tí nkehe tjanjon Dios la ko chrókjuatso̱an jaha nkexro tí tjetjanchaha nta̱ ntá chrókjuanchana nta̱, ntá chrótja̱ha tí nta̱ tjechón chaxín ―ichro chꞌín Jesús. 
\p  
\v 11 Na ntá ntáchro tí tjan a kíxin: 
\p ―¿Ntá nkexrí kíxin xraahya jaha ninkehó nkehe tsakítsjeyá nta̱ kíxin tí tòye̱ i la imá ni̱nka? ¿Ntá nkexrí tsochjìna tí nta̱ tjechón tjimé?  
\v 12 Tí nkexro kꞌuaxrjeníxinni mé Jacob mé kuíto̱eheni tí tòye̱ tjiá nta̱ ntihi la ko kja̱xin ikꞌuí chꞌán tí nta̱ la ko kja̱xin ikꞌuí tí xje̱en chꞌán la ko tí iko kuènte chꞌán. ¿A̱ ntá xá jaha la xá a̱ntsí má tjetoan jaha, a̱ ntá jehe chꞌán la kénhyó ní? ―mé kjuanchankíhi tjan tí chꞌín Jesús. 
\p  
\v 13 Na ntá kjuáte̱he chꞌín Jesús ntáchro chꞌán kíxin: 
\p ―Tí sín itꞌi sín tí nta̱ ntihi tí tòye̱ i nánta̱xón itsꞌen sín nta̱ ínaá.  
\v 14 A̱ ntá tí sín itsꞌi sín tí nta̱ si̱ntaki̱to̱nha̱n sín mé í tsꞌenhya sín nta̱ ínaá. Tí nta̱ si̱ntaki̱to̱nha̱n sín mé tsꞌóna éxí yóhe̱ ijnko nta̱ tsꞌaxrje nkaya a̱sén sín mé tsinkákjanjon tí kjuachón tsochónta sín jnkochríxín ―ichro chꞌán. 
\p  
\v 15 Ntá ntáchro tí tjan a ínaá kíxin: 
\p ―Chjìna tí nta̱, a̱ ntá tsꞌénhyana nta̱ ínaá la ko tsꞌinkahya ntihi tsakítsje nta̱ ―ichro tjan. 
\p  
\v 16 Ntá kꞌue̱to̱an chꞌín Jesús kíxin: 
\p ―Sátjia tjíkꞌi̱ye̱hé xìá ntá tsꞌinkará ntihi ínaá ―ichro chꞌán. 
\p  
\v 17 Ntá ntáchro tjan kíxin: 
\p ―Chontahya xìná ―ichro tjan. 
\p Ntá ntáchro chꞌín Jesús kíxin: 
\p ―Chaxín ntáchrua kíxin chontahya jaha xìá.  
\v 18 Kꞌuéchonta jaha inꞌó xìá, a̱ ntá tí chꞌín chonta jie jehya xìá. Na mé chaxín tí nkehe ntáchrua kíxin chontahya xìá chaxín ―ichro chꞌán. 
\p  
\v 19 Na ntá kuínhin tjan tíha ntá ntáchro tjan kíxin: 
\p ―Tꞌíkua̱n kíxin jaha ijnko nkexro chrónka itén Dios.  
\v 20 A̱ ntá tí sín kꞌuaxrjeníxinni kꞌuíxin ósé mé kꞌuéxraxinkakonxín sín Dios tí jna̱ ntihi. Kjánchó jahará chojni judío mé ntáchrorá kíxin tí ni̱nko jié chjasin Jerusalén kaín ni chróxraxinkakonxínni Dios ―ichro tjan. 
\p  
\v 21 Ntá chꞌín Jesús ntáche chꞌán tjan kíxin: 
\p ―Títekávan kíxin tjetsi tí hora a tsoxráxinkákonxínhyará Itꞌéni Dios tí jna̱ ntihi la ko tsoxráxinkákonxínhyará chꞌán chjasin Jerusalén kja̱xin.  
\v 22 Jahará chojni samaritano chonhyará tí nkexro xráxinkáonrá. Ntá kaín ni chojnini judío mé chóxinni tí nkexro xráxinkaonni. Méxra̱ tí nkexro tsjakjìinhin chojni tí jie̱ yámá sín mé tsꞌaxrjeníxin tí sín judío.  
\v 23 Ntá tjetsi tí hora a na mé tí jie ó kui tí hora a na tí sín chaxín tjinkaon sín chróxraxinkaon sín Itꞌéni la mé a̱sén sín ó tsoxraxinkakonxín sín Itꞌéni Dios. Dios mé tóxrjínhi̱n chꞌán kíxin chojni xi̱kaha chrókjuichꞌe sín chróxraxinkakonxín sín chꞌán.  
\v 24 Jehe Dios na mé ncha̱kuen ó, a̱ ntá tí sín chróxraxinkaon sín chꞌán na mé tꞌichjánxi̱n kíxin a̱sén sín ó tsoxraxinkakonxín sín chꞌán ―mé xi̱kaha chrónka chꞌín Jesús. 
\p  
\v 25 A̱ ntá ntáchro tí tjan a kíxin: 
\p ―Ó nòna kíxin itsi tí nkexro Mesías, tí nkexro a mé Cristo. Tió tsi chꞌán ntá tsja̱ko̱he̱ni chꞌán kaín xín nkehe ―ichro tjan. 
\p  
\v 26 Ntá ntáchro chꞌín Jesús kíxin: 
\p ―Tí nkexro a la mé janhan tjétjuá jie ―ichro chꞌán. 
\p  
\v 27 Na ntá tí sín kꞌuájiko chꞌán mé kja̱nxi̱n sín tí chjasin a, ntá chrakon sín kꞌuíkon sín kíxin tjenixje̱he̱ chꞌán ijnko chojni chjin. Kjánchó nijnko sín kjuanchankíehya sín chꞌán kíxin nkehe tjinkaon chꞌán na nkekuènté nixje̱he̱ chꞌán tí tjan a.  
\v 28 A̱ ntá tí tjan mé kjuakꞌe tjan tí tóa nonte ntá sákjuí tjan tí chjasin ntaha ntáche tjan tí sín ntaha kíxin: 
\p  
\v 29 ―Ìntárá sátsjitsjeheni ijnko chꞌín chrónka chꞌán kaín xín nkehe kjui̱tꞌa tí senó a. ¿Xá chrókójehya tí nkexro i Cristo? ―ichro tjan. 
\p  
\v 30 Na ntá tí chojni a mé xrákua̱xi̱n sín tí chjasin a ntá kuitsjehe sín tí chꞌín Jesús.  
\v 31 Na̱xa̱ tihya sín nachrohe tí sín kꞌuájiko chꞌán mé chrónóe̱he̱ sín chꞌán ntáchro sín kíxin: 
\p ―Maestro, kja̱xian chrókjónte nkehe ―ichro sín. 
\p  
\v 32 Kjánchó ntáchro chꞌán kíxin: 
\p ―Ó chonta janhan nkehe siné. Jahará la kjá na̱xa̱ noahyará ―ichro chꞌán. 
\p  
\v 33 A̱ ntá tí sín kꞌuájiko chꞌán mé kjuanchankíhi sín kíchó sín kíxin: 
\p ―¿Xá jnkojín sín tsíki̱ka̱o sín nkehe kjóne chꞌán? ―ichro sín. 
\p  
\v 34 Kjánchó ntáchro chꞌín Jesús kíxin: 
\p ―Éxí yóhe̱ chrókjoné nkehe mé tí si̱tꞌa tí xra̱ la ko tsjixinna tí xra̱ kuènte tí nkexro chrꞌánna kꞌuinka.  
\v 35 Ntáchrorá kíxin: “Noó nitjó na̱xa̱ tꞌitjáyan tsochónhenni ntá tsotjáni noatrigo”, ichrorá. Kjánchó ntáxrja̱n kíxin chrótsjehérá tí no a kíxin ó tsícha la ko ó tinkáxámá kíxin ó jína chrótjáni.  
\v 36 Tí sín chꞌe xra̱ tjá sín mé tsoxenkehe sín. A̱ ntá tí nkehe tjá sín mé tsꞌáyéhe̱ kjuachón jnkochríxín. Ntá tí sín kꞌue̱nka̱ sín nonte la ko tí sín tjá sín jnkokón tso̱chéhe̱ sín.  
\v 37 Mé xi̱kaha tsoxiteyá tí nkehe ntáchro sín kíxin: “Ijnko nkexro mé tꞌe̱nka̱ noa, a̱ ntá ókjé sín tsotjá sín tí noa a”, ichro sín.  
\v 38 A̱ ntá janhan ichrꞌan tí jahará tso̱tja̱rá ijnko nonte tsíkꞌénka̱hyará. Na mé ókjé sín kjuíchꞌe sín xra̱ ntá jahará tsjachará tí xra̱ kjuíchꞌe tí sín a ―ichro chꞌán. 
\p  
\v 39 A̱ ntá itsjé tí sín samaritano kuènte tí chjasin ntiha mé kjuankíxin kuinkáchónki sín tí jehe chꞌán kíxin xi̱kaha chrónka tjan kíxin jehe chꞌán ó chrónka chꞌán kaín xín nkehe kjuíchꞌe tjan tí senó a.  
\v 40 A̱ ntá tió kuínhin sín tí nkehe chrónka tjan ntá kui sín tí tjen chꞌín Jesús ntá chrónóe̱he̱ sín chꞌán kíxin tsito̱he chꞌán ntiha. Ntá kuíto̱he chꞌán ntiha iyó ya̱on.  
\v 41 Ntá itsjé sín kja̱xin kuinkáchónki sín chꞌán kíxin tí nkehe kuínhin sín nixja chꞌán.  
\v 42 Ntá ntáche sín tí tjan a kíxin: 
\p ―Ntá jie jehya jehó tí nkehe chro̱nka kuítekaonni. Náhí. Tí jie ó kuínhinni nixja chꞌán ntá kónoheni kíxin jehe chꞌán chaxín tí nkexro Cristo sinchekaá tí chojni chjasintajni ―ichro sín. 
\s1 Chꞌín Jesús kjuínchekito̱he jína ijnko xje̱en ijnko chꞌín chꞌehe xra̱ gobierno 
\p  
\v 43 A̱ ntá kꞌuátsínka iyó ya̱on ntá chꞌín Jesús kꞌuaxrjexín chꞌán estado Samaria ntá sákjuí chꞌán nó estado Galilea.  
\v 44 A̱ ntá jehe chꞌán tsíntáchro chꞌán kíxin tí nkexro chrónka itén Dios la tí chjasén sín mé tjikosáyehya sín chꞌán.  
\v 45 Kjánchó tió kjuíji chꞌán tí estado Galilea na mé kꞌuáyéhe̱ sín chꞌán la ko kjuikosáyehe sín chꞌán jína kíxin kja̱xin sín sátsíkji̱ sín tí kia pascua chjasin Jerusalén tsíkꞌikon sín kaín tí kjuaxroan kjuasixín chꞌán tí kia ntiha. 
\p  
\v 46 Ntá xíkjan chꞌín Jesús ínaá chjasin Caná, estado Galilea, na mé ntiha tsíkjinchekjaminca chꞌán tí nta̱ tí xranvino a. Ntaha mé kjuákꞌe ijnko chꞌín chꞌehe xra̱ gobierno. A̱ ntá níhi tí xje̱en chꞌán ntoa itjen chjasin Capernaum.  
\v 47 Ntá kuínhin tí chꞌín chꞌehe xra̱ gobierno kíxin itjen chꞌín Jesús tí estado Galilea tsíki̱xi̱n chꞌán estado Judea ntá sákjuíchréhe̱ chꞌán chrónóe̱he̱ chꞌán tí chꞌín Jesús kíxin sáchrókjui chꞌín Jesús nto̱e chꞌán sinchekito̱he jína tí xje̱en chꞌán ó tjetꞌen xjan.  
\v 48 Ntá ntáchro chꞌín Jesús kíxin: 
\p ―Kja̱ tí jahará tí chrókꞌuikonhyará kjuaxroan chrókjuásian la chrókuinkachónkihyará tí janhan ―ichro chꞌán. 
\p  
\v 49 Ntá chrónòa tí chꞌín chꞌehe xra̱ gobierno ntáchro chꞌán kíxin: 
\p ―¿Á chrókójínahya sáchrókjui̱ni nto̱na jaí kíxin xja̱nna ó tjetꞌen? ―ichro tí chꞌín a. 
\p  
\v 50 Ntá kjuáte̱he chꞌín Jesús ntáchro chꞌán kíxin: 
\p ―Ikjan sátjia nto̱a kíxin tí xja̱an na ó jína tjen jie ―ichro chꞌán. 
\p Ntá kuítekaon chꞌán nkerí ichro chꞌín Jesús ntá sákjuí chꞌán.  
\v 51 A̱ ntá kjuíji chꞌán chjino nto̱e chꞌán ntá xrína̱hya tí sín chꞌehe sín chꞌán xra̱ kjuíxinhin sín nti̱a chrónka sín kíxin: 
\p ―Xja̱an la ó jína tjen ―ichro sín. 
\p  
\v 52 Ntá kjuanchankíhi chꞌán sín kíxin nkehora kjuankíxin kuíto̱he xjan jína, na ntá chrónka sín kíxin: 
\p ―Ijna la una kónjín mé kjuìin tí sóa ―ichro sín. 
\p  
\v 53 Ntá kónohe tí itꞌé xjan kíxin xi̱kaha tí hora tsíntáchro chꞌín Jesús kíxin tí xje̱en chꞌán na ó jína tjen. A̱ ntá jehe chꞌán la ko kaín tí sín siín nto̱e chꞌán mé kuinkáchónki sín tí chꞌín Jesús. 
\p  
\v 54 Tíha mé tí yóxin kjuaxroan kjuasin chꞌín Jesús tió kui̱xi̱n chꞌán estado Judea ikjan chꞌán estado Galilea. 
\c 5  
\s1 Chꞌín Jesús kjuínchekito̱he jína ijnko chꞌín tsíkꞌen to̱te chjasin Betesda 
\p  
\v 1 Ntá chrꞌéxi̱n tí sín judío mé kjuasin sín ijnko kia na ntá chꞌín Jesús xíkjan chꞌán chjasin Jerusalén ínaá.  
\v 2 A̱ ntá ntaha chjino tí ntója tꞌixenxín kolélo chjasin mé tjen ijnko pila tóxroyéya nta̱ mé nkìva hebreo tí nta̱ mé itꞌin Betesda. A̱ ntá chrínta tí pila siín inꞌó cuarto ntsíntsí.  
\v 3 Ntaha tjejótsínka nchónhya chojni níhi, iso sín tꞌikonhya la ko iso sín xitjahya tji la ko iso sín tsíkꞌen to̱té. Tjejóchónhen sín kíxin nkehora tsinkí nta̱  
\v 4 kíxin nánta̱xón kꞌuínkajin ijnko ángel kjuiánkí nta̱ kjuínchekinkí nta̱. A̱ ntá tí nkexro senó tsjiánkí nta̱ mé tsito̱he jína kjónté cualquiera chin chónta.  
\v 5 A̱ ntá ntaha kjuákꞌe ijnko chꞌín na mé chónta chꞌán treinta y ocho nánó níhi chꞌán.  
\v 6 A̱ ntá tió kꞌuíkon chꞌín Jesús kíxin tjetsínka tí chꞌín a la ko kónohe chꞌán kíxin ósé níhi chꞌán, ntá kjuanchankí chꞌán kíxin: 
\p ―¿Á tjinkávan tsito̱ha jína? ―ichro chꞌán. 
\p  
\v 7 Ntá ntáchro tí si̱nníhi kíxin: 
\p ―Chóntahyani ninkexró tsjinki̱tsani tsjiánkíni nta̱. A̱ ntá tí tjinkaonni chrókjuiánkíni nta̱ la ntá ókjé nkexro tjítaón nti̱a tjiánkí nta̱ senó ―mé chro tí si̱nníhi. 
\p  
\v 8 A̱ ntá kꞌue̱to̱an chꞌín Jesús kíxin: 
\p ―Ijie la tꞌinkatjen, tjatsíyan ka̱nia̱a, itjia ―ichro chꞌán. 
\p  
\v 9 Ntá tuénxín kuíto̱he chꞌán jína, ntá kjua̱tse̱n chꞌán ka̱nie̱e chꞌán kjuankíxin itji chꞌán. Kjánchó ya̱on sábado tíha mé tí ya̱on tꞌo̱kꞌéhe sín.  
\v 10 Mé xi̱kaha tí sín judío ntáche sín tí chꞌín kuíto̱he jína kíxin: 
\p ―Ijie tí ya̱on tꞌo̱kꞌéheni ntá kohya kjuachaxin tsamá ka̱nia̱a ―ichro sín. 
\p  
\v 11 A̱ ntá ntáchro tí chꞌín a kíxin: 
\p ―Tí nkexro kjuínchekito̱na jína mé kꞌue̱tua̱nna kíxin tsjatsíyan ka̱nia̱na la ko sátsjia ―ichro chꞌán. 
\p  
\v 12 Ntá kjuanchankíhi sín chꞌán kíxin: 
\p ―¿Nkexéhe tí nkexro kꞌue̱tua̱nhan kíxin tsjatsíyan ka̱nia̱a la ko sátsjia? ―ichro sín. 
\p  
\v 13 A̱ ntá tí chꞌín tsíkito̱he jína na í kjuátso̱anhya chꞌán tí nkexro kjuínchekito̱he chꞌán jína kíxin ntaha la siín nchónhya chojni, a̱ ntá ntahó kꞌuítjáyanxín chꞌín Jesús.  
\v 14 A̱ ntá chrꞌéxi̱n chꞌín Jesús xeta chꞌán tí chꞌín a nkaxenhen tí ni̱nko jié ntá ntáchro chꞌán kíxin: 
\p ―Tsjehé kíxin ijie la ó jína tjen jaha la í tjásinhya jie̱ ínaá. A̱ ntá tí tsjásian jie̱ ínaá a̱ ntá a̱ntsí má jínahya tso̱nhan ―ichro chꞌán. 
\p  
\v 15 A̱ ntá sákjuí tí chꞌín a ntá chénka chꞌán tí sín judío kíxin jehe chꞌín Jesús mé kjuínchekito̱he chꞌán jína.  
\v 16 Mé xi̱kaha tí sín judío kjuankíxin sín chónkíhi sín tí chꞌín Jesús la ko chrókꞌóyán sín chꞌán kíxin kjuínchekito̱he chꞌán chojni jína tí ya̱on tꞌo̱kꞌéhe sín.  
\v 17 Kjánchó chꞌín Jesús ntáche chꞌán tí jehe sín kíxin: 
\p ―Méxra̱ Tꞌaná na̱xa̱ tjechꞌe chꞌán xra̱. A̱ ntá janhan kja̱xin tjétꞌa̱ xra̱ ―ichro chꞌán. 
\p  
\v 18 Méxra̱ xi̱kaha tí sín judío a̱ntsí tjinkaon sín chrókꞌóyán sín chꞌán kíxin kuítekakuenhya chꞌán tí ley kuènte tí ya̱on tꞌo̱kꞌéhe sín la ko kja̱xin ntáchro chꞌán kíxin tí Itꞌé chꞌán la mé Dios, mé xi̱kaha ncheyóhe̱ chꞌán a̱sén chꞌán Dios. 
\s1 Tí kjuachaxin chónta tí Xje̱en Dios 
\p  
\v 19 Ntá ntáche chꞌín Jesús tí jehe sín kíxin: 
\p ―Ijnko nkehe tjetoan tso̱tjo̱nka̱rá kíxin tí Xje̱en Dios nkaya nka̱jní tí jehó kjuachaxin kuènte ó la mé xitjahya sichꞌe xra̱. Jehó tí xra̱ tꞌikon chꞌán tjechꞌe Itꞌé chꞌán mé kja̱xin chꞌán xi̱kaha chꞌe chꞌán.  
\v 20 A̱ ntá tí Itꞌé mé tjuèhe tí Xje̱en chꞌán, la ko tja̱ko̱he̱ chꞌán kaín xín xra̱ chꞌe chꞌán, la ko a̱ntsí tjetoan tí xra̱ na̱xa̱ tsja̱ko̱he̱ chꞌán kíxin ntá tsochrakonrá kíxin tsꞌikonrá tí xra̱ sichꞌe chꞌán.  
\v 21 Tí Itꞌé mé chónta kjuachaxin nchexechón tí sín tsíkꞌen la ko chjéhe chꞌán sín kjuachón. A̱ ntá tí Xje̱en kja̱xin chónta kjuachaxin tsochjéhe kjuachón tí nkexro tjinkaon tsochjéhe chꞌán.  
\v 22 A̱ ntá Itꞌé la í sinchekito̱exínhya chꞌán iji̱é ninkexró. Kaín tí kjuachaxin kuènte chꞌán chjéhe chꞌán tí Xje̱en kíxin sinchekito̱exín chꞌán iji̱é chojni chjasintajni  
\v 23 kíxin ntá kaín chojni tsjikosáyehe sín tí Xje̱en éxí yóhe̱ tjikosáyehe sín tí Itꞌé chꞌán. Tí sín tjikosáyehya tí Xje̱en xi̱kaha kja̱xin tjikosáyehya sín tí Itꞌé kíxin jehe chꞌán mé tsíchrꞌán tí Xje̱en. 
\p  
\v 24 ’Ijnko nkehe tjetoan tso̱tjo̱nka̱rá kíxin tí jnkojínrá tjejotinhínrá tí nkehe tjàkua la ko tinkachónkirá tí Tꞌaná, mé tí nkexro ichrꞌánna, na mé xi̱kaha ó chontará tí kjuachón la ko tsjasótiahyará, na mé kui̱to̱hérá tí nti̱a chrókꞌuénxinrá, la ntá jie kjuankíxinrá tsochontará tí kjuachón jnkochríxín.  
\v 25 Ijnko nkehe tjetoan tso̱tjo̱nka̱rá kíxin ó tsi tí ya̱on, na mé jie tíha, mé xi̱kaha tso̱nhen kíxin tí sín tsíkꞌen tsinhin sín tsonixja tí Xje̱en Dios. A̱ ntá tí sín tsitekaon sín na mé tsꞌejóchón sín.  
\v 26 Tí Itꞌé mé chónta chꞌán kjuachaxin tsjanjon chꞌán tí kjuachón la ko jehe chꞌán mé chjéhe chꞌán kjuachaxin tí Xje̱en kíxin kja̱xin tí Xje̱en tsjanjon tí kjuachón  
\v 27 la ko kja̱xin chjéhe chꞌán kjuachaxin tí Xje̱en chꞌán sinchekito̱exín tí iji̱é chojni chjasintajni kíxin jehe mé tí Xje̱en Dios Kꞌóna Chojni.  
\v 28 Chrakonhyará tjétjo̱nka̱rá xi̱kaha. Na mé ó tsi tí ya̱on kíxin kaín tí sín tsíkꞌen mé tsinhin sín tsonixja chꞌán.  
\v 29 A̱ ntá tsꞌaxrjexín sín tí tòye̱ la tí sín kjuíchꞌe sín xra̱ jína mé tsoxechón sín ntá tsochónta sín tí kjuachón. A̱ ntá tí sín kjuíchꞌe sín xra̱ jínahya na mé kja̱xin tsoxechón sín ntá sátsji sín tsjasóte sín. 
\s1 Tí kjuachaxin chónta chꞌín Jesús 
\p  
\v 30 ’Tí jehó kjuachaxin kuènta̱na xitjahya si̱tꞌa ninkehó xra̱. A̱ ntá jie nta̱kito̱axián tí ijie̱ éxí kꞌue̱tua̱nna Tꞌaná. A̱ ntá tí nkehe nta̱kito̱axián la jína ntoá kíxin tjínka̱konhya si̱tꞌa éxí tjínka̱van. Náhí. Éxí tjinkaon Tꞌaná, tí nkexro ichrꞌánna, mé xi̱kaha tjétꞌa̱.  
\v 31 A̱ ntá tí chróxrja̱nka kíxin nkexrí imá jína janhan la tíha la ninkehó kjuachaxin chróchóntahya.  
\v 32 Itjen í jnko nkexro tjechrónka nkexrí tjén janhan a̱ ntá ó nòna kíxin tí nkehe chrónka chꞌán la sínkí.  
\v 33 Jahará tsíkétue̱nhénrá chojni kjuíkjanchankíhi sín tí chꞌín Juan kíxin nkexrínchi tjén janhan. A̱ ntá tí nkehe tsíkjate̱he chꞌán la chaxín ntoá tiha.  
\v 34 Kjánchó cho̱ntia̱xi̱nhya tí nkehe tsochrónka nijnko chojni chjasintajni nkexrínchi tjén janhan. Jehí ntáxrja̱n tíha kíxin jahará jína chrókuaárá.  
\v 35 Tí chꞌín Juan kjuákꞌe éxí yóhe̱ ijnko xrohi kjuákꞌeche kꞌuínkaséyanxín la ko jahará kócháhará xi̱kaha, kjánchó séhya kóxrjínhanrá tí xrohi a.  
\v 36 Kjánchó siín nkehe a̱ntsí tjetoan tja̱ko̱xi̱n nkexrí tjén janhan, a̱ ntá kánhyó tjetoan tí nkehe tsíchrónka tí chꞌin Juan. Tí xra̱ tjétꞌa̱, mé tí xra̱ kjuanjon Tꞌaná si̱tꞌa tsjixinna tí xra̱, na mé tíha mé tja̱ko̱xi̱n kíxin chaxín Tꞌaná tsíchrꞌán kꞌuinka.  
\v 37 Kja̱xin jehe Tꞌaná, tí nkexro ichrꞌánna, mé chrónkaxín chꞌán nkexrí tjén janhan. A̱ ntá jahará na̱xa̱ kiénhyará tí nkehe nixja chꞌán la ko kꞌuíkonhyará chꞌán  
\v 38 la ko kja̱xin itén chꞌán kuíto̱ehya nkaya kjárá kíxin tjinkákonhyará tsítekáonrá tí Xje̱en Dios tsíchrꞌán tsíki.  
\v 39 Jahará nchekuáxinrá jína tí xroon tsíkjin tí sín tsíchrónka itén Dios ósé kíxin ntáchrorá kíxin ntaha tsꞌitjaxínrá tí kjuachón tsochontará jnkochríxín. A̱ ntá tí nkehe tsíkjin sín ósé mé chrónka kuènte janhan.  
\v 40 Kjánchó jahará tjinkákonhyará tsochjinará tí tjén janhan kíxin chrókꞌuayéhérá tí kjuachón a. 
\p  
\v 41 ’Janhan na tjéyáhya kíxin chojni chrókjuikosáyana sín.  
\v 42 A̱ ntá janhan ó nòna kíxin jahará la tjuèhyará Dios.  
\v 43 Mé kꞌuinkaxian janhan tí kjuachaxin kuènte Tꞌaná. Kjánchó jahará la títekákonnahyará. A̱ ntá tí chrókui í jnko nkexro kjuachaxin chrókuakitsjeníxin a̱sén ó, a̱ ntá tíha mé tjinkáonrá chrókuítekákonhénrá.  
\v 44 ¿Nkexrí chrókuítekáonrá jahará kíxin tjéyárá kíxin tí chojni chjasintajni chrókjuikosáyahará sín, a̱ ntá tjéyáhyará tí kjuachaxin chrókjuanjon jnkoko̱á Dios?  
\v 45 Tsontáchrohyará kíxin janhan tsjánchíá jie̱ tí jahará nkayakon Tꞌaná. Náhí. Chꞌín Moisés mé tsjanchia chꞌán jie̱ tí jahará kíxin tsontáchrorá kíxin jehe chꞌán kuinkachónkirá.  
\v 46 Kja̱ tí jahará chrókuítekáonrá nkehe tsíntáchro chꞌín Moisés ntá chrókuítekáonrá tí janhan kíxin tí xroon tsíkjin chꞌán mé chrónka kuènte tí janhan.  
\v 47 A̱ ntá tí títekákonhyará tí nkehe tsíkjin chꞌán, ¿ntá nkexrí chrókuítekákonnará nkehe ntáxrja̱n janhan? ―ichro chꞌán.﻿ 
\c 6  
\s1 Chꞌín Jesús kjuanjon chꞌán nkehe kjóne inꞌó mil chojni 
\r (Mt. 14.13-21; Mr. 6.30-44; Lc. 9.10-17) 
\p  
\v 1 A̱ ntá chrꞌéxi̱n ntá sákjuí chꞌín Jesús kꞌuátòye̱ chꞌán tí nta̱yaon Galilea na mé tí nta̱yaon Tiberias tíha.  
\v 2 A̱ ntá nchónhya chojni tinkáchréhe̱ sín kíxin kꞌuíkon sín tí kjuaxroan jié kjuasin chꞌán kjuínchekito̱he chꞌán jína tí si̱nníhi.  
\v 3 A̱ ntá jehe tí chꞌín Jesús chrìin chꞌán ijnko jna̱ na ntá ntaha kjuákꞌetja̱xi̱n chꞌán la koí tí sín kꞌuájiko chꞌán a.  
\v 4 A̱ ntá í séhya tsꞌixin tí kia pascua a mé kié tí sín judío a.  
\v 5 A̱ ntá tí chꞌín Jesús kꞌuíkon chꞌán kíxin nchónhya chojni chrìin sín kjuichréhe̱ sín chꞌán ntá kjuanchankíhi chꞌán tí chꞌín Felipe kíxin: 
\p ―¿Nketí chrókꞌue̱nani nkehe sine kaín tí chojni a? ―ichro chꞌán. 
\p  
\v 6 Mé xi̱kaha ntáchro chꞌán kíxin siná nkehe tsixro chꞌín Felipe. A̱ ntá tí chꞌín Jesús la ó nohe chꞌán nkehe tí kjuaxroan tsjasin chꞌán.  
\v 7 Ntá kjuáte̱he chꞌín Felipe ntáchro chꞌán kíxin: 
\p ―Kjónté doscientos chichaon denario chróchóntani chrókꞌuínáxin tí nio̱tja̱ la na̱xa̱ chrókjuachahya chrókꞌuáyéhe̱ jnkojnko sín to̱tꞌo̱ tí nio̱tja̱ a ―ichro chꞌán. 
\p  
\v 8 A̱ ntá chꞌín Andrés, ijnko tí sín kꞌuájiko chꞌín Jesús la sa̱vé mé chꞌín Simón Pedro mé ntáchro chꞌán kíxin: 
\p  
\v 9 ―Ntihi tjen ijnko xjan ntoa chónta inꞌó nio̱tja̱ tsíkꞌóna noa cebada la ko chónta chꞌán yaá koche. ¿Xá chrókjuacha tíhó kíxin nchónhya chojni siín? ―ichro chꞌán. 
\p  
\v 10 A̱ ntá ntáchro chꞌín Jesús kíxin: 
\p ―Tétue̱nhén tí sín siín a kíxin tsꞌixitja̱xi̱n sín ―ichro chꞌán. 
\p A̱ ntá nchónhya ika yoa siín na ntá ntaha kꞌuíxitja̱xi̱n sín na mé éxí inꞌó mil chojni kꞌuíxin sín.  
\v 11 A̱ ntá chꞌín Jesús kuákja chꞌán tí nio̱tja̱ ntá kjuanchehe chꞌán Dios kjuasáya ntá chjéhe chꞌán tí sín kꞌuájiko chꞌán. A̱ ntá jehe sín kꞌóxika̱ye̱he sín chjéhe sín kaín tí sín sítja̱xi̱n a. Xi̱kaha kja̱xin kꞌóxika̱ye̱he sín tí koche. A̱ ntá kaín sín kjóne sín éxí tjinkaon sín.  
\v 12 Kjuixin kjóne sín ntá kꞌue̱tue̱nhen chꞌín Jesús tí sín kꞌuájiko chꞌán ntáchro chꞌán kíxin: 
\p ―Tjénájínrá tí nkehe to̱tꞌo̱ síxèhe sín kíxin tsꞌitjáyanhya ninkehó ―ichro chꞌán. 
\p  
\v 13 Ntá xi̱kaha jehe sín kjuenájín sín kjuínchekaón sín teyó ntaxra tí to̱tꞌo̱ tí inꞌó nio̱tja̱ tsíkꞌóna noa cebada síxèhe sín tí kjuixin tsíkjine sín.  
\v 14 A̱ ntá tí sín kjóne tí nio̱tja̱ kꞌuíkon sín tí kjuaxroan jié kjuasin chꞌín Jesús ntáchro sín kíxin: 
\p ―Jehe chꞌán mé chaxín tí nkexro tsíchrꞌán Dios kíxin itsi tí chjasintajni tsja̱ko̱he̱ni chꞌán ―ichro sín. 
\p  
\v 15 Kjánchó chꞌín Jesús mé kónohe chꞌán kíxin tjinkaon sín sáchrókjuiko sín chꞌán chróchrꞌáxenhen sín chꞌán tí xra̱ rey kíxin chrókꞌue̱to̱an chꞌán. A̱ ntá jehe chꞌán tjinkakonhya chꞌán tíha ntá jehó chꞌán sáxíkji chꞌán nte̱je̱ ínaá kjuákꞌe chꞌán ntiha. 
\s1 Éxí ijnko nti̱a xi̱kaha kjuítaón chꞌín Jesús tí nta̱yaon 
\r (Mt. 14.22-27; Mr. 6.45-52) 
\p  
\v 16 A̱ ntá ó kóntó ntá tí sín kꞌuájiko chꞌín Jesús kꞌuínkaji̱nxi̱n sín jna̱ sákjuí sín chrínta nta̱yaon  
\v 17 kꞌui̱tꞌótjen sin ijnko ntabárco̱ kjuankíxin sín tsꞌatòye̱ sín nta̱yaon sátsji sín chjasin Capernaum. Na ó kꞌuíxin tie na na̱xa̱ kjanhya chꞌín Jesús.  
\v 18 Ntá kjuankíxin chjéhe xri̱nto̱ tsa̱nka̱ ntá kjuankíxin tinkákjaminkí nta̱.  
\v 19 A̱ ntá tió kjuacha sín á inꞌó o̱ injon kilómetro ntá xrína̱hya kꞌuíkon sín tí chꞌín Jesús tinkákóchjinehe chꞌán tí ntabárco̱, éxí ijnko nti̱a tjetjitaón chꞌán tí nta̱, ntá kꞌuíkon sín ntá imá chrakon sín.  
\v 20 Kjánchó ntáchro chꞌán kíxin: 
\p ―Janhan tíha. Chrakonhyará ―ichro chꞌán. 
\p  
\v 21 Ntá imá chéhe̱ sín kꞌui̱tꞌótjen chꞌán tí ntabárco̱. Ntá ó tuénxín kjuíji sín tí chjasin sátsji sín. 
\s1 Tí chojni xritjeyá sín tí chꞌín Jesús 
\p  
\v 22 A̱ ntá tí ya̱on chrꞌéxi̱n na mé tí sín kuíto̱he tóhe nta̱yaon na mé ó nohe sín kíxin jnkoko̱áxón ntabárco̱ kꞌuékjakꞌe ntiha la ko ó nohe sín kíxin chꞌín Jesús kjá ni sátsíkjikohya sín chꞌán na mé kꞌuíkon sín kíxin jehó tí sín kꞌuájiko chꞌán sátsíkji sín.  
\v 23 Kjánchó siín ntabárco̱ ti̱xi̱n chjasin Tiberias tinkákóchjinehe tí nó kjónexín sín tí nio̱tja̱ kjuanchaxín chꞌín Jesús kjuasáyé Dios.  
\v 24 A̱ ntá tió kꞌuíkon sín kíxin kohya chꞌín Jesús la ko kja̱xin kohya tí sín kꞌuájiko chꞌán, ntá jehe sín mé kꞌui̱tꞌótjen sín iso ntabárco̱ ntá sákjuí sín chjasin Capernaum sákjuíkjeyá sín tí chꞌín Jesús. 
\s1 Ìnchéni Jesús mé éxí nio̱tja̱ tjanjon kjuachón 
\p  
\v 25 A̱ ntá tóhe nta̱yaon xéta sín tí chꞌín Jesús ntá kjuanchankíhi sín chꞌán kíxin: 
\p ―Maestro, ¿nkesá kꞌuinka ntihi? ―ichro sín. 
\p  
\v 26 Ntá kjuáte̱he chꞌín Jesús ntáchro chꞌán kíxin: 
\p ―Ó nòna kíxin jahará tjéyárá tí janhan kíxin kjónterá nio̱tja̱ kókja̱hará, la jehya kíxin kiénxinrá tí kjuaxroan kjuásian.  
\v 27 Chrókjui̱chꞌehyará tí xra̱ chrókꞌuite tí nkehe chrókjónterá tjoka tsjeje̱ ó. Náhí. Chrókjuéyárá tí nkehe chrókjueje̱hya chrókjónterá chrókꞌuayéxínrá tí kjuachón jnkochríxín. Tí nkehe tjanjon tí Xje̱en Dios Kꞌóna Chojni mé chrókjónterá kíxin Itꞌé chꞌán mé tja̱ko̱xi̱n chꞌán kíxin tí Xje̱en chꞌán mé chónta kjua̱cha̱xién tí jehe chꞌán ―ichro chꞌín Jesús. 
\p  
\v 28 A̱ ntá kjuanchankíhi sín chꞌán kíxin: 
\p ―¿Nkexrí chrókjuichꞌeni chrokjuinchexiteyáni nkexrí tjinkaon Dios? ―ichro sín. 
\p  
\v 29 A̱ ntá kjuáte̱he chꞌín Jesús ntáchro chꞌán kíxin: 
\p ―Dios mé tjinkaon chꞌán kíxin chrókuinkachónkirá tí nkexro tsíchrꞌán chꞌán ―ichro chꞌán. 
\p  
\v 30 Ntá kjuanchankíhi sín chꞌán kíxin: 
\p ―¿Nkehe tí kjuaxroan chrókjuáko̱éxianni chrókꞌuikonni kíxin ntá chrókuitekaonni tí jaha? ¿Nkehe tí xra̱ chꞌe jaha?  
\v 31 Tí sín tsíkꞌaxrjeníxinni kꞌuéjó sín ósé mé kjóne sín maná kꞌóna nio̱tja̱ tió kꞌuíxin sín nte̱je̱ mé xi̱kaha tí xroon kuènte Dios tsíkjin ijnko nkexro ósé ntáchro kíxin: “Kjuanjon chꞌán tí nkehe kjóne sín mé nio̱tja̱ tsíki̱xi̱n nkaya nka̱jní”\f + \fr 6:31 \ft Salmo 78.24\f* ―ichro sín. 
\p  
\v 32 A̱ ntá kjuáte̱he chꞌín Jesús ntáchro chꞌán kíxin: 
\p ―Ijnko nkehe tjetoan tjo̱nka̱rá kíxin jehya chꞌín Moisés kjuanjon tí maná kꞌóna nio̱tja̱ kꞌuínkaji̱nxi̱n nkaya nka̱jní. Náhí. Tꞌaná mé tjetjanjon tí nio̱tja̱ chaxín jína kꞌuínkaji̱nxi̱n nkaya nka̱jní.  
\v 33 Tí nio̱tja̱ tjanjon Dios mé tí nkexro kꞌuínkaji̱nxi̱n nkaya nka̱jní tjejóchónxin chojni chjasintajni ―ichro chꞌán. 
\p  
\v 34 Na ntá kjuanchia sín kíxin: 
\p ―Jaha Ìnchéni, jnkochríxín chje̱héni tí nio̱tja̱ a ―ichro sín. 
\p  
\v 35 A̱ ntá ntáchro chꞌín Jesús kíxin: 
\p ―Janhan mé tí nio̱tja̱ tjanjon kjuachón. Tí sín tóchjina sín tí janhan í tsꞌenhya sín kjinta, la ko tí sín tsitekaon sín tí janhan í tsꞌenhya sín nta̱.  
\v 36 Kjánchó éxí kꞌuétjo̱nka̱rá senó na ó kꞌuíkonrá tí janhan na kjónté na̱xa̱ títekákonhyará.  
\v 37 A̱ ntá kaín tí sín chjìna Tꞌaná la tso̱chjina sín tí janhan. A̱ ntá kaín tí sín tjejótóchjinehe sín tí janhan la tsétua̱nhya sín kíxin sátsji sín.  
\v 38 Janhan kꞌuinkaxian nkaya nka̱jní jehya tí xra̱ tóxrjìna chrókjui̱tꞌa. Náhí. Kꞌuinka kíxin chrókjui̱tꞌa tí xra̱ tóxrjínhin tí nkexro tsíchrꞌánna.  
\v 39 A̱ ntá Tꞌaná mé tí nkexro tsíchrꞌánna mé tjinkaon chꞌán kíxin si̱ntakꞌitjáyanhya ninkexró tí sín chjìna chꞌán na mé tjinkaon chꞌán kíxin janhan mé si̱ntaxechón kaín sín tí ya̱on tsjixixín.  
\v 40 Mé xi̱kaha tjinkaon tí nkexro tsíchrꞌánna kíxin kaín tí sín tsꞌikon sín tí janhan mé tí Xje̱en Dios la ko tsitekaon sín tí janhan chrókꞌuáyéhe̱ sín kjuachón jnkochríxín. A̱ ntá janhan si̱ntaxechón sín tí ya̱on tsjixixín ―ichro chꞌán. 
\p  
\v 41 A̱ ntá tí sín judío kjuankíxin sín kjonta sín tí chꞌín Jesús kíxin tsíntáchro chꞌán kíxin jehe chꞌán mé tí nio̱tja̱ kꞌuínkaji̱nxi̱n nkaya nka̱jní.  
\v 42 Mé ntáchro sín kíxin: 
\p ―¿Á jehya tí Jesús, itꞌé mé itꞌín José, na mé chóxinni tí itꞌé la ko tí ìné chꞌán? ¿Ntá nkekuènté ntáchro chꞌán kíxin nka̱jní kꞌuínkaji̱nxi̱n chꞌán? ―ichro sín. 
\p  
\v 43 Ntá kjuáte̱he chꞌín Jesús ntáchro chꞌán kíxin: 
\p ―Ti̱to̱hérá tjóntahyará tí janhan.  
\v 44 Kohya nkexro chrókóchjina tí tjén janhan tí chrókjuínki̱tsahya Tꞌaná. A̱ ntá tí sín tóchjina na mé si̱ntaxechón sín tí ya̱on tsjixixín.  
\v 45 Na mé tí sín kꞌuéchrónka itén Dios ósé mé tsíkjin sín xroon ntáchro kíxin: “Dios mé tsja̱ko̱he̱ chꞌán kaín chojni.”\f + \fr 6:45 \ft Isaías 54.13\f* A̱ ntá kaín tí sín tsíkinhin tí nixja Tꞌaná la ko kjua̱ko̱he̱ chꞌán sín mé sítóchjina sín tí tjén janhan. 
\p  
\v 46 ’Jehya kíxin itjen ijnko chojni tsíkꞌikon Tꞌaná. Náhí. Jehó tí nkexro kui̱xi̱n tí tjen Dios mé tsíkꞌikon chꞌán Dios.  
\v 47 Chaxín tí nkehe tjéxrja̱nka kíxin tí sín titekaon sín tí janhan mé ó tsochónta sín kjuachón jnkochríxín.  
\v 48 Janhan na mé tí nio̱tja̱ tjanjon kjuachón.  
\v 49 Tí sín kꞌuaxrjeníxinrá kꞌuéjó ósé kjóne sín tí maná kꞌóna nio̱tja̱ tió kꞌuéjó sín nte̱je̱, a̱ ntá kjónté ikꞌuén sín kꞌuítjáyan sín.  
\v 50 Tí nkehe xrja̱nka mé tí nio̱tja̱ kꞌuínkaji̱nxi̱n nkaya nka̱jní, a̱ ntá tí sín sine tí nio̱tja̱ a mé tsꞌenhya sín.  
\v 51 Janhan mé tí nio̱tja̱ tjechón kꞌuínkaji̱nxi̱n nkaya nka̱jní. A̱ ntá tí sín sine tí nio̱tja̱ a mé tsꞌejóchón sín jnkochríxín. Tí nio̱tja̱ tsjánjuan tsꞌejóchónxin chojni chjasintajni mé nto̱na tíha ―ichro chꞌín Jesús. 
\p  
\v 52 A̱ ntá tí sín judío mé sítjité sín itjo sín kíchó sín ntáchro sín kíxin: 
\p ―¿Nkexrí chrókjuanjon chꞌán nto̱e chꞌán chrókjóneni? ―ichro sín. 
\p  
\v 53 A̱ ntá kjuáte̱he chꞌín Jesús ntáchro chꞌán kíxin: 
\p ―Ntá tso̱tjo̱nka̱rá kíxin tí sintehyará nto̱e tí Xje̱en Dios Kꞌóna Chojni, la ko tí tsꞌihyará ijni̱é chꞌán, ntá tsochontahyará kjuachón jahará.  
\v 54 Tí sinterá nto̱na la ko itꞌirá jni̱na ntá tsochontará kjuachón jnkochríxín la ko janhan mé si̱ntaxechónrá tí ya̱on tsjixixín.  
\v 55 Kíxin nto̱na na mé chaxín nkehe ine chojni la ko jni̱na na mé chaxín nkehe itꞌi chojni.  
\v 56 Tí sín ine nto̱na la ko itꞌi sín jni̱na mé jnkoko̱á tjenka̱yáxinkian sín la ko janhan mé xríki̱an sín.  
\v 57 Tꞌaná tsíchrꞌán chꞌán tí janhan mé chónta kjuachaxin, a̱ ntá janhan mé tjécho̱nxian tí jehe chꞌán. Ntá tí sín sine tí nto̱na mé tsꞌejóchónxin sín tí janhan.  
\v 58 A̱ ntá tjéníxja̱ kuènte tí nio̱tja̱ kꞌuínkaji̱nxi̱n nkaya nka̱jní na mé yóe̱hya tí maná tsíkꞌóna nio̱tja̱ kjóne tí sín tsíkꞌaxrjeníxinrá ósé kíxin jehe sín na kjóne sín na kjónté kꞌuén sín. A̱ ntá tí sinterá tí nio̱tja̱ kꞌuínkaji̱nxi̱n nkaya nka̱jní ntá tsꞌejochónrá jnkochríxín ―mé chro chꞌín Jesús. 
\p  
\v 59 Kaín tíha mé kjua̱ko̱he̱ chꞌán tí sín tsíkójnkotséxin tí ni̱nko Israel chjasin Capernaum. 
\s1 Tí nkehe chrónka chꞌín Jesús mé tjanjon kjuachón jnkochríxín 
\p  
\v 60 A̱ ntá tió kuínhin sín tí nkehe kjuako chꞌín Jesús ntá itsjé tí sín kꞌuájiko chꞌán ntáchro sín kíxin: 
\p ―Imá xra̱ tí nkehe chrónka chꞌán. ¿Xá nkexro chrókuinhin tíha? ―ichro sín. 
\p  
\v 61 A̱ ntá kónohe chꞌín Jesús kíxin xi̱kaha tóxakonhen sín kíenxínhya sín tí nkehe tsíntáchro chꞌán ntá kjuanchankíhi chꞌán sín kíxin: 
\p ―¿Á kja̱xinrá tjinkákonhyará tsinhínrá tíhi?  
\v 62 ¿Ntá nkexrí tso̱nhen chrókꞌuikonrá kíxin tí Xje̱en Dios Kꞌóna Chojni mé sátsji̱ chꞌán ínaá tí nó tsíki̱xi̱n chꞌán tí tsíkjakꞌe chꞌán ósé?  
\v 63 Tí Ncha̱kuen Dios mé tjanjon tí kjuachón, a̱ ntá tí nto la ninkehó sínkíhya. Na ntá tí nkehe tjétjo̱nka̱rá na mé kuènte tí Ncha̱kuen Dios na mé tjejóchónxin chojni.  
\v 64 Kjánchó isorá na̱xa̱ títekákonnahyará ―ichro chꞌán. 
\p Mé xi̱kaha ichro chꞌán kíxin tí xrankíxixín ó kónohe chꞌán kíxin nkexro tí sín tsitekakuenhya sín chꞌán la ko kónohe chꞌán kíxin nkexro sinchekji chꞌán.  
\v 65 A̱ ntá ntáchro chꞌán kíxin: 
\p ―Méxra̱ xi̱kaha kꞌuétjo̱nka̱rá kíxin ninkexró tso̱chjina tí tjén janhan tí tsjinki̱tsahya Tꞌaná ―ichro chꞌán. 
\p  
\v 66 A̱ ntá kjuixin tíha ntá nchónhya tí sín kꞌuékꞌajiko chꞌín Jesús ntá xrína̱hya kuíto̱he sín, í chrèhya sín chꞌán.  
\v 67 Ntá kjuanchankíhi chꞌán tí teyó sín kꞌuájiko chꞌán ntáchro chꞌán kíxin: 
\p ―¿Á kja̱xinrá tjinkáonrá xi̱kaha sáchrókjuirá? ―ichro chꞌán. 
\p  
\v 68 Ntá kjuáte̱he chꞌín Simón Pedro kíxin: 
\p ―Jaha Ìnchéni, ¿nkekuènté tjanchankíhíni á sáchrókjuini ókjé? Jaha tí tan chro̱nka a mé tsochóntaxínni kjuachón jnkochríxín  
\v 69 ntá kuítekaonni ntá ó noheni chaxín kíxin jaha tí Cristo mé Xje̱en Dios tjechón ―ichro chꞌán. 
\p  
\v 70 Ntá kjuáte̱he chꞌín Jesús ntáchro chꞌán kíxin: 
\p ―Janhan kjuéyá tí kaín rá teyórá la ko jnkojínrá ntihi mé tsꞌónará ijnko jínahya ―ichro chꞌán. 
\p  
\v 71 Tíha mé tꞌaxrjexín tí ntáchro chꞌín Jesús chrónka chꞌán kíxin chꞌín Judas Iscariote, tíha itꞌé mé itꞌin Simón, mé ijnko tí teyó sín tsíkjeyá chꞌán ntá kjónté sinchekji chꞌán tí chꞌín Jesús.﻿ 
\c 7  
\s1 Tí sín jnkoko̱á kíchó chꞌín Jesús mé kuítekakuenhya sín chꞌán 
\p  
\v 1 Ntá kjuixin tíha ntá kꞌuáji chꞌín Jesús tí estado Galilea. Chrókꞌuajihya chꞌán tí estado Judea kíxin tí sín judío tjinkaon sín chrókꞌóyán sín chꞌán.  
\v 2 Kjánchó ó kuichjina tí ya̱on kia ntá tí sín judío sichꞌéna sín itsjé itsꞌvan tsjasixín sín kia.\f + \fr 7:2 \ft Levítico 23.34\f* 
\v 3 A̱ ntá tí sín kíchó chꞌín Jesús ntáche sín chꞌán kíxin: 
\p ―Chrókuito̱ahya ntihi. Sáchrókjuia estado Judea kíxin ntá kja̱xin tí sín chréhe̱ tí jaha tjejó ntiha chrókꞌuikon sín tí kjuaxroan tsjásian.  
\v 4 Kíxin tió tjinkaon ijnko nkexro kíxin chojni tsochóxin sín chꞌán ntá móhya chrókjuichꞌe chꞌán xra̱. A̱ ntá tí chaxín tjetjásian kjuaxroan la jehya mó chrókjuásian kjuaxroan. Náhí. Chrókꞌuikon kaín xín chojni siín chjasintajni ―mé chro sín. 
\p  
\v 5 Xi̱kaha ntáchro tí sín kíchó chꞌán kíxin kja̱xin jehe sín titekakuenhya sín tí jehe chꞌán.  
\v 6 A̱ ntá kjuáte̱he chꞌín Jesús ntáchro chꞌán kíxin: 
\p ―Na̱xa̱ kjuixrakáhya tí hora kuènta̱na tsjásian kjuaxroan. Ntá jahará la cualquier hora tjinkáonrá jína chrókꞌuikonrá kjuaxroan.  
\v 7 Tí sín chjasintajni xitjahya tso̱nínkakonhanrá sín tí jahará. Ntá janhan na imá nínkakonna sín kíxin ntátjan sín kíxin jehya jína tí nkehe tjejóchꞌe sín.  
\v 8 Jahará la sátjírá tí kia a. A̱ ntá janhan la tjíhya kíxin na̱xa̱ kjuixrakáhya tí hora kuènta̱na ―ichro chꞌán. 
\p  
\v 9 Mé xi̱kaha ntáchro chꞌán ntá kuíto̱he chꞌán estado Galilea. 
\s1 Itjen chꞌín Jesús tí kia a 
\p  
\v 10 A̱ ntá ó kjuixin sátsíkji̱ tí sín jnkoko̱á kíchó chꞌín Jesús ntá jehe chꞌán la kja̱xin sákjui̱ chꞌán tí kia a kjánchó noxínhya xritjakꞌe chꞌán.  
\v 11 A̱ ntá tí sín judío mé xriteyá sín chꞌán tí kia a la ntáchro sín kíxin: 
\p ―¿Xá nketí tjen tí chꞌín a? ―ichro sín. 
\p  
\v 12 A̱ ntá itsjé sín ntiha mé kjo sín kíchó sín kíxin nkexrí tjen chꞌán. Iso sín ntáchro sín kíxin: “Jína chꞌán”; kjánchó í so sín ntáchro sín kíxin: “Jehya chojni jína chꞌán, méxra̱ imá chꞌiyehe chꞌán chojni”, ichro sín. 
\p  
\v 13 Kjánchó noxínhya kjo sín xi̱kaha kíxin chrako̱nhe̱n sín tí sín judío a. 
\p  
\v 14 A̱ ntá ó kjuíji jnko̱siné tí kia a ntá kꞌuíxenhen chꞌín Jesús tí ni̱nko jié ntá kjuankíxin chꞌán kjuako chꞌán.  
\v 15 A̱ ntá tí sín judío chrakon sín komá sín chꞌán ntáchro sín kíxin: 
\p ―¿Xá nkexrí nohe tí chꞌín i nchónhya tí nkehe kíxin tsíxrako̱e̱hya chꞌán? ―ichro sín. 
\p  
\v 16 Ntá kjuáte̱he chꞌín Jesús ntáchro chꞌán kíxin: 
\p ―Tí nkehe tjàkua la jehya kuènta̱na na mé tí xra̱ kuènte tí nkexro tsíchrꞌánna kꞌuinka.  
\v 17 Tí jnkojinrá tjinkáonrá chrókjui̱nchexiteyéhérá éxí tóxrjínhi̱n Dios la tso̱nohará á chaxín kuènte Dios tí nkehe tjàkua o̱ á kuènta̱na tíha.  
\v 18 A̱ ntá tí nkexro tjako tí nkehe tꞌaxrjeníxin kja sín ó mé xi̱kaha chꞌe kíxin tjinkaon sín kíxin tí chojni ó mé chróchóntehe sín chꞌán kjuasáya. A̱ ntá tí nkexro tjinkaon kíxin tí chojni a mé chrókjuikosáyehe sín tí nkexro tsíchrꞌán chꞌán na mé jehe chꞌán mé tjako chꞌán tí nkehe chaxín ntoá la ko ninkehó chꞌiyahya tí jehe chꞌán. 
\p  
\v 19 ’¿Á jehya chꞌín Moisés tjáhará tí itén Dios chrókuítekáonrá? Kjánchó nijnkorá kuítekákuenhyará tí nkehe tsíkjin chꞌán. ¿Méxra̱ nkekuènté tjinkáonrá chrókꞌoyánrá tí janhan? ―ichro chꞌán. 
\p  
\v 20 Ntá kjuáte̱he tí sín a ntáchro sín kíxin: 
\p ―Jaha chonta ijnko ncha̱kuen tí jínahya. ¿Xá nkexro chrókꞌóyán tí jaha? ―ichro sín. 
\p  
\v 21 Ntá kjuáte̱he chꞌín Jesús ntáchro chꞌán kíxin: 
\p ―Jnkoko̱á kjuaxroan kjuásian tí ya̱on tꞌo̱kꞌéheni ntá chrakonrá.\f + \fr 7:21 \ft Juan 5.2–9\f* 
\v 22 A̱ ntá chꞌín Moisés tsíkꞌe̱to̱an kíxin xja̱anrá ntoa itsa xjan xro̱ye, (kjánchó jehya chꞌín Moisés kjuankíxin chꞌán kjuako chꞌán tíha, na mé tí sín tsíkꞌaxrjeníxinrá kjuankíxin sín kjuako sín tíha). Mé xi̱kaha nchekará xjan tí xro̱ye a kjónté ya̱on tꞌo̱kꞌéheni.  
\v 23 A̱ ntá xi̱kaha nchekará xjan xro̱ye tí ya̱on tꞌo̱kꞌéheni kíxin xi̱kaha chrókjui̱nchekꞌitjáyankíhyará ninkehó tí nkehe kꞌue̱to̱an chꞌín Moisés, ¿ntá nkekuènté kíxin ninkákonnará tí janhan kíxin kjui̱ntaki̱to̱ha̱ jína ijnko chojni tí ya̱on tꞌo̱kꞌéheni?  
\v 24 Chrókjuanchahyará jie̱ kíxin tí nkehe tꞌikonxínrá ikonrá ó. Chrókjuenka̱yáxinrá tí nkehe jína tóxrjínhi̱n Dios ―mé chro chꞌín Jesús. 
\s1 Chꞌín Jesús chrónka kíxin nketí kꞌuaxrjeníxin chꞌán 
\p  
\v 25 A̱ ntá iso sín chjasin Jerusalén kjuankíxin sín kjo sín kíchó sín kjuanchankí sín kíxin: 
\p ―¿Á jehya tí chꞌín a xritjeyá sín chrókꞌóyán sín?  
\v 26 Ntá jie noxín tjen chꞌán nixja chꞌán kohya ninkexró nínkakonhen chꞌán. Kjá tí síxre̱é titekaon sín kíxin tí nkexro a chaxín Cristo tíha.  
\v 27 Kjánchó ó noheni nketí tsíkji̱xi̱n chꞌán. A̱ ntá tió tsi tí nkexro Cristo ntá ninkexró tso̱noehya nketí tsi̱xi̱n chꞌán ―ichro sín. 
\p  
\v 28 A̱ ntá chꞌín Jesús kjuákꞌekjako chꞌán tí ni̱nko jié ntá kuínhin chꞌán kíxin xi̱kaha kjo sín, ntá itsen nixja chꞌán ntáchro chꞌán kíxin: 
\p ―Chaxín choxinrá tí janhan la ko nohará nketí chjasin tsíkjíxian. Kjánchó jehya kíxin kꞌuinka si̱ntaxiteyá tí nkehe ntáchro a̱senná ó. Ó kꞌuinka kíxin ichrꞌánna tí nkexro chaxín tjechón tjen nkaya nka̱jní. Jahará na̱xa̱ chonhyará tí nkexro a.  
\v 29 Janhan la choxian chꞌán kíxin ntaha tsíkꞌinkaxian na mé jehe chꞌán mé tsíchrꞌánna chꞌán ―ichro chꞌín Jesús. 
\p  
\v 30 Ntá chrótsé sín chꞌán chrókjua̱kꞌe̱chji̱na sín chꞌán ntá kjónté ninkexró tséhya sín chꞌán kíxin na̱xa̱ kjuanjonhya Dios kjuachaxin chrótsé sín chꞌán.  
\v 31 Kjánchó itsjé chojni kuítekaon sín tí jehe chꞌán. A̱ ntá ntáchro sín kíxin: 
\p ―A̱ ntá tió chrókui tí Cristo la, ¿á má jié kjuaxroan chrókjuasin chꞌán, a̱ ntá tí chꞌín i la kénhyó ní? ―ichro sín. 
\s1 Tí sín fariseo ichrꞌán sín chojni policía tsotsé sín tí chꞌín Jesús tsja̱kꞌe̱chji̱na sín chꞌán 
\p  
\v 32 A̱ ntá tí sín fariseo kuínhin sín nkehe tí ntáchro chojni kíxin nkexrí tjen chꞌín Jesús, ntá jehe sín la ko tí sín ncha̱tꞌá tꞌe̱to̱an kꞌue̱tue̱nhen sín iso sín policía kuènte ni̱nko tsotsé sín chꞌán tsja̱kꞌe̱chji̱na sín chꞌán.  
\v 33 A̱ ntá ntáchro chꞌín Jesús kíxin: 
\p ―Kja̱xin í séhya tsjakꞌé ntihi tsꞌejóni ntá sáxikji̱ya tí tjen tí nkexro ichrꞌánna.  
\v 34 A̱ ntá jahará tsjéyárá tí janhan na tsꞌitjahyará kíxin xitjahya tsjasánrá tí tsjakꞌé janhan ―ichro chꞌán. 
\p  
\v 35 A̱ ntá tí sín judío kjuankíxin sín kjuanchankíhi sín kíchó sín kíxin: 
\p ―¿Ntá nketí nó sátsji̱ chꞌán kíxin tsjachahyani tsꞌitjani chꞌán? ¿Xá sátsjichréhe̱ chꞌán tí sín judío tjejóyákjan tí sín nixja nkìva griego kíxin ntá tsja̱ko̱he̱ chꞌán tí sín griego?  
\v 36 ¿Nkexrí tꞌaxrjexín tí nkehe ntáchro chꞌán kíxin tsjeyáni chꞌán na kjónté tsꞌitjahyani chꞌán la tsjachahyani tsjichréhe̱ni chꞌán tí tsjakꞌe chꞌán? ―ichro sín. 
\s1 Nta̱río tjechón 
\p  
\v 37 A̱ ntá tí ya̱on tsjixixín tí kia a mé tí ya̱on jié mé kꞌuínkatjen chꞌín Jesús, a̱ ntá itsen nixja chꞌán ntáchro chꞌán kíxin: 
\p ―Kja̱ tí jnkojínrá ikꞌuénrá nta̱ xrákirá itsꞌirá nta̱.  
\v 38 A̱ ntá éxí ntáchro xroon Itén Dios kíxin tí sín titekaon sín tí janhan na mé nkaya a̱sén sín tsꞌóna ijnko río tsꞌaxrje ìnta̱ tjechón ―ichro chꞌán. 
\p  
\v 39 Mé xi̱kaha chrónkaxín chꞌín Jesús nkexrí tjen tí Ncha̱kuen Dios tsꞌáyéhe̱ tí sín tsitekaon sín tí jehe chꞌán. Kjánchó na̱xa̱ tihya tí Ncha̱kuen Dios kíxin chꞌín Jesús na̱xa̱ sátji̱hya chꞌán nkaya nka̱jní. 
\s1 Jnkoko̱áhya kjuenkayáxin tí chojni 
\p  
\v 40 A̱ ntá iso sín tió kuínhin sín tí nkehe ntáchro chꞌín Jesús ntá ntáchro sín kíxin: 
\p ―Kja̱ chaxín tí chꞌín i mé tí profeta ó tsíkji ―ichro sín. 
\p  
\v 41 Ikjé sín ntáchro sín kíxin: 
\p ―Jehe chꞌán mé tí nkexro Cristo ―ichro sín. 
\p A̱ ntá í so sín ntáchro sín kíxin: 
\p ―¿Xá nkekuènté chrókjui̱xi̱n Galilea tí nkexro Cristo?  
\v 42 Tí xroon tsíkjin sín ósé mé chrónka kíxin tí nkexro Cristo mé tsꞌaxrjeníxin tí sín kꞌuaxrjeníxin tí chꞌín rey David la ko tsji̱xi̱n chꞌán chjasin Belén mé tí chjasin kꞌuékjakꞌe chꞌín David ―ichro sín. 
\p  
\v 43 Mé xi̱kaha jnkoko̱áhya kjuenka̱yáxin sín kaín sín kíxin nkexro tí chꞌín Jesús.  
\v 44 Iso sín tjinkaon sín sáchrókjuiko sín chꞌán chrókjuikjehe̱ sín chꞌán kjánchó ninkexró kjuíchꞌehya xi̱kaha. 
\s1 Tí síxre̱é kuítekakonhya sín tí chꞌín Jesús 
\p  
\v 45 A̱ ntá tí sín policía kuènte ni̱nko mé kjan sín tí tjejó tí sín fariseo la ko tí sín ncha̱tꞌá tꞌe̱to̱an. Ntá tí sín a mé kjuanchankíhi sín tí sín policía kíxin: 
\p ―¿Nkekuènté kjuíkoahyará chꞌán? ―ichro sín. 
\p  
\v 46 Ntá kjuáte̱he tí sín policía kíxin: 
\p ―Kohya ninkexró nixja éxí xi̱kaha nixja tí chꞌín a ―ichro sín. 
\p  
\v 47 Ntá ntáche tí sín fariseo tí sín policía kíxin: 
\p ―¿Á kja̱xinrá kui̱to̱hérá kjuítꞌayahará chꞌán?  
\v 48 ¿Á kuítekaon tí jehe chꞌán jnkojín tí sín tꞌe̱to̱an kuènténi o̱ tí sín fariseo?  
\v 49 A̱ ntá tí sín a mé chónhya sín tí ley na mé tsjasóte sín ―ichro sín. 
\p  
\v 50 A̱ ntá tí chꞌín Nicodemo, tí chꞌín kjuítsjehe tí chꞌín Jesús ijnko tie senó na mé jehe chꞌán fariseo chꞌán na ntá ntáche chꞌán sín kíxin: 
\p  
\v 51 ―Tí ley kuènténi la kohya kjuachaxin sinchekjasóteni ijnko chojni tí na̱xa̱ kíenhyani nkehe nixja chꞌán la ko kíenhyani tí jie̱ kjuasin chꞌán ―ichro chꞌán. 
\p  
\v 52 Ntá kjuáte̱he sín ntáchro sín kíxin: 
\p ―¿Á kja̱xian jaha kjuíxian estado Galilea ní? Nchekuáxian tí xroon itén Dios ntá tso̱noha kíxin nijnko tí sín kꞌuéchrónka itén Dios tsíkji̱xi̱nhya sín tí estado Galilea ―ichro sín. 
\s1 Ijnko tjan kjuasin jie̱ chónta ókjé chojni ntoa 
\p  
\v 53 Ntá jnkojnko tí sín xíka sín sákjuí sín nto̱e sín. 
\c 8  
\p  
\v 1 Ntá chꞌín Jesús mé sákjui̱ chꞌán tí jna̱ Olivo.  
\v 2 Ntá tí kóya̱on nchítjen ikjan chꞌán kꞌuíxenhen chꞌán tí ni̱nko jié a la ko kaín xín tí chojni mé kóchjinehe sín chꞌán. Ntá kjuákꞌetja̱xi̱n chꞌán kjuankíxin chꞌán kjuako chꞌán.  
\v 3 Ntá tí sín tjako tí ley la ko tí sín fariseo mé kjui̱ka̱o sín ijnko tjachjin kónoxíxin kíxin chónta tjan ókjé chojni ntoa. Ntá kjua̱kꞌe̱ sín tjan jnko̱siné tí sín tjejó ntiha.  
\v 4 Ntá ntáche sín tí chꞌín Jesús kíxin: 
\p ―Maestro, tí tjan i kónoxíxin kíxin kjuasin tjan jie̱ chónta tjan ókjé chojni ntoa.  
\v 5 A̱ ntá tí ley tsíkjin chꞌín Moisés mé tꞌe̱to̱an kíxin ixro̱ chrókꞌóyánxinni tí chojni chjin xi̱kaha chꞌe. ¿A̱ ntá jaha, nkechrua? ―ichro sín. 
\p  
\v 6 Mé xi̱kaha ichro sín kíxin tjinkaon sín kíxin áchꞌe ntoáhya chrókjuate̱he chꞌín Jesús ntá chrókjuanchia sín jie̱. Ntá chꞌín Jesús mé kꞌuísén chꞌán kji̱nxi̱n chꞌán dedo tja chꞌán nonte a.  
\v 7 Ntá na̱xa̱ tinkákjanchankíhi sín chꞌán. Ntá kꞌuínkatjen chꞌán kꞌue̱to̱an chꞌán kíxin: 
\p ―Xá nkexro tí tjejorá ntihi chóntahya ninkehó jie̱ mé sa̱oxín chróchjéhe sín tjan xro̱ ―ichro chꞌán. 
\p  
\v 8 Ntá xíkꞌisén chꞌán ínaá ikjin chꞌán tí nche ínaá.  
\v 9 Ntá tí sín a mé kuínhin sín tí nkehe kꞌue̱to̱an chꞌín Jesús ntá kósuèhe̱ sín kíxin koí sín chónta sín jie̱, ntá jnkojnko jnkojnko sín, sásítji sín na mé sa̱oxín tí chꞌín a̱ntsí má táda chꞌán sákjuí chꞌán, ntá kaín tí sín í so a sákjuí sín kja̱xin sín. 
\p Ntá jehó tí chꞌín Jesús la ko tí tjan a kuíto̱he sín ntiha.  
\v 10 Ntá xrentoá chꞌán la kjuanchankíhi chꞌán tjan kíxin: 
\p ―¿Nkekjá tí sín kjuanchia jie̱? ¿Á kohya ninkexró kjuínchekjasótiahya ní? ―ichro chꞌán. 
\p  
\v 11 Ntá ntáchro tjan kíxin: 
\p ―Náhí, Ìnchéni, ninkexró ―ichro tjan. 
\p Ntá ntáchro chꞌín Jesús kíxin: 
\p ―Kja̱xin janhan si̱ntakjasótiahya. Sátjia la í tjásinhya jie̱ ínaá ―ichro chꞌán. 
\s1 Chꞌín Jesús mé xrohi tꞌinkaséyanxín chjasintajni 
\p  
\v 12 Ntá chꞌín Jesús xínixje̱he̱ chꞌán tí sín tsíkóchjina ínaá ntáchro chꞌán kíxin: 
\p ―Janhan mé xrohi tꞌinkaséyanxín chjasintajni. Tí tsochréhérá tí janhan ntá tsꞌajirá tí tꞌinkaséyan tsochontaxínrá tí kjuachón a la ko í tsꞌajihyará tí sítié a ―ichro chꞌán. 
\p  
\v 13 Ntá tí sín fariseo ntáchro sín kíxin: 
\p ―Jahvá tjechro̱nka nkexrí tjen jaha na mé chaxínhya tíha kíxin jahvá tjechro̱nka ―ichro sín. 
\p  
\v 14 Ntá kjuáte̱he chꞌín Jesús ntáchro chꞌán kíxin: 
\p ―Janhván tjétjo̱nka̱rá nkexrí tjén na kjónté chaxín xrja̱nka kíxin ó nòna nketí nó kꞌuinkaxian la ko nòna nketí sátsjiyá. A̱ ntá jahará noahyará nketí kꞌuinkaxian la ko noahyará nketí sátsjiyá.  
\v 15 Jahará la éxí chojni chjasintajni ó tékará jie̱. A̱ ntá janhan la tékahya jie̱ ninkexró.  
\v 16 Kjánchó ntoá chrókjui̱ntakito̱axián iji̱é chojni kíxin jehya janhván tꞌa̱ tíha, Tꞌaná tjéki̱an, na mé tí nkexro kꞌue̱tua̱nna kꞌuinka ntihi na mé jehe chꞌán mé tjéki̱an chꞌán ntihi ntakito̱axínkian iji̱é chojni.  
\v 17 A̱ ntá tí ley tsíkjin chꞌin Moisés mé ntáchro kíxin tí tso̱noxín iyó sín tsochrónka á chaxín xi̱kaha tsíkónhen ntá chrókuitekaon chojni.  
\v 18 Ntá janhan na mé tjéxrja̱nka nkexrí tjén janhan la ko kja̱xin Tꞌaná mé tí nkexro kꞌue̱tua̱nna kꞌuinka mé jehe chꞌán kja̱xin chrónka chꞌán nkexrí tjén janhan ―ichro chꞌán. 
\p  
\v 19 Ntá kjuanchankíhi sín chꞌán kíxin: 
\p ―¿Nketí tjen Itꞌá? ―ichro sín. 
\p Ntá kjuáte̱he chꞌín Jesús ntáchro chꞌán kíxin: 
\p ―Jahará la chonhyará tí janhan la ko kja̱xin chonhyará Tꞌaná. Tí chrókóchoxinrá tí janhan ntá kja̱xin chrókóchoxinrá tí Tꞌaná ―ichro chꞌán. 
\p  
\v 20 Mé xi̱kaha chro chꞌín Jesús tí kjuákꞌekja̱ko̱xi̱n chꞌán tí ni̱nko jié chjino ntacajón tjetóxroyéya chichaon tjanjon sín. Kjánchó ninkexró tséhya sín chꞌán kíxin na̱xa̱ kjuixrakáhya tí hora tsotsé sín chꞌán. 
\s1 “Xitjahya tsjasánrá tí nó sátsjiyá janhan” 
\p  
\v 21 Ntá chꞌín Jesús ntáche chꞌán sín ínaá kíxin: 
\p ―Ntá sátsjiyá janhan. Ntá jahará tsjéyárá tí janhan, ntá tió tsꞌénrá na̱xa̱ yamárá iji̱árá. Xitjahya tsjasánrá tí nó sátsjiyá janhan ―ichro chꞌán. 
\p  
\v 22 Ntá ntáchro tí sín judío ikjo sín kíchó sín kíxin: 
\p ―¿Á tsꞌóyán chꞌán a̱sén chꞌán kíxin xi̱kaha ntáchro chꞌán kíxin xitjahya tsjijini tí nó sátsji̱ chꞌán? ―ichro sín. 
\p  
\v 23 Ntá ntáche chꞌín Jesús tí jehe sín kíxin: 
\p ―Jahará la nonte ntihi kꞌuaxrjéníxinrá. A̱ ntá janhan la nkaya nka̱jní kꞌuaxrjéníxia̱n. Jahará la kuènte chjasintajni ntihi. A̱ ntá janhan la janhya kuènte chjasintajni.  
\v 24 Mé xi̱kaha tjo̱nka̱rá kíxin tió tsꞌénrá na̱xa̱ tsochontará iji̱árá kíxin tí tsítekákonhyará tí janhan, mé tí nkexro xráxín tjen,\f + \fr 8:24 \ft Éxodo 3.14\f* ntá kjónté tsꞌénrá na̱xa̱ tsochontará tí iji̱árá ―ichro chꞌán. 
\p  
\v 25 Ntá kjuanchankí sín ntáchro sín kíxin: 
\p ―¿Nkexro tí jaha? ―ichro sín. 
\p Ntá kjuáte̱he chꞌín Jesús ntáchro chꞌán kíxin: 
\p ―Tí xrankíxixín kjuankíxian tjo̱nka̱rá kíxin nkexro tí janhan.  
\v 26 Itsjé nkehe chonta chróntáxrja̱n kíxin chrókjui̱ntakito̱axián tí jie̱ chontará. Kjánchó tí nkexro kꞌue̱tua̱nna kꞌuinka na mé tí nkehe chrónka chꞌán la chaxín. A̱ ntá jehó tí nkehe kui̱nha̱n chrónka chꞌán mé tjáko̱ha̱ tí sín chjasintajni ―ichro chꞌán. 
\p  
\v 27 Kjánchó jehe sín mé kíenxínhya sín kíxin nixja chꞌán kuènte Itꞌé chꞌán tjen nkaya nka̱jní.  
\v 28 A̱ ntá ntáchro chꞌán kíxin: 
\p ―Tió si̱nchekꞌi̱tꞌótjenrá noi tí Xje̱en Dios Kꞌóna Chojni, ntá tso̱nohará kíxin janhan mé tí nkexro xráxín tjen.\f + \fr 8:28 \ft Éxodo 3.14\f* Ntá tso̱nohará kíxin jehya janhan této̱an tí xra̱ tjétꞌa̱. Náhí. Jehó tí nkehe kjua̱ko̱na Tꞌaná mé tjétjàkua.  
\v 29 Tjéki̱an tí nkexro kꞌue̱tua̱nna kꞌuinka kíxin jehí xráxín Tꞌaná la kuíto̱nahya janhván kíxin xráxín nta̱xiteyáha̱ tí nkehe tóxrjínhi̱n chꞌán ―ichro chꞌán. 
\p  
\v 30 Mé xi̱kaha ntáchro chꞌán ntá nchónhya chojni kuítekaon sín tí jehe chꞌán. 
\s1 Nkexrí tjejó tí sín xje̱en Dios la ko nkexrí tjejó tí sín chrokjuahya tsíto̱he sín iji̱é sín 
\p  
\v 31 Ntá nixje̱he̱ chꞌín Jesús tí sín judío kuinkáchónki sín chꞌán ntáchro chꞌán kíxin: 
\p ―Tí tsi̱to̱éhyará tí tan kjuákohará ntá jahará chaxín discípulo kuènta̱na  
\v 32 la ko tsjátso̱anrá tí nkehe chaxín, la ko tí nkehe chaxín mé tsotjáhará kjuachaxin tsaáxinrá, a̱ ntá tso̱kohya nkehe tsꞌinkákonhe̱n ―ichro chꞌán. 
\p  
\v 33 Ntá kjuáte̱he sín ntáchro sín kíxin: 
\p ―Jeheni mé tsíkꞌaxrjeníxinni chꞌín Abraham na í xráxín kohya nkexro kꞌue̱na tí jeheni. ¿Nkekuènté ntáchrua jaha kíxin tsꞌáyéhe̱ni kjuachaxin tsaáxinni? ―ichro sín. 
\p  
\v 34 Ntá ntáchro chꞌín Jesús kíxin: 
\p ―Tjetoan tí nkehe tjétjo̱nka̱rá kíxin tí sín tjasin jie̱ mé éxí chojni kꞌuíná chrokjuahya tsito̱he sín iji̱é sín.  
\v 35 A̱ ntá ijnko chojni kꞌuíná la jnkochríxínhya tsjakꞌe chꞌán tí nto̱e tí nkexro a. A̱ ntá tí xje̱en tí nkexro na mé jnkochríxín tsito̱he ntiha.  
\v 36 Ntá tí tsaáxinrá tí Xje̱en Dios ntá chaxín tsochontará kjuachaxin, a̱ ntá tso̱kohya nkehe tsꞌinkákonhe̱n.  
\v 37 Ó nòna kíxin jahará tsíkꞌaxrjeníxinrá chꞌín Abraham. Kjánchó tjinkáonrá chrókꞌoyánrá tí janhan kíxin títekákonhyará tí nkehe tjéxrja̱nka.  
\v 38 Janhan xrja̱nka tí nkehe kꞌuíkua̱n kíxin nkexrí tjen Tꞌaná. A̱ ntá jahará tjejonchexiteyéhérá tí nkehe kuínhínrá chrónka itꞌárá ―ichro chꞌán. 
\p  
\v 39 A ntá jehe sín kjuáte̱he sín ntáchro sín kíxin: 
\p ―Itꞌéni mé chꞌín Abraham ―ichro sín. 
\p Kjánchó ntáchro chꞌín Jesús kíxin: 
\p ―A̱ ntá tí jahará chrókóchaxín xje̱en chꞌín Abraham ntá chrókjui̱chꞌerá éxí kjuíchꞌe chꞌán.  
\v 40 A̱ ntá tjétjo̱nka̱rá tí tan chaxín kui̱nha̱n chrónka Dios na kjónté chrókꞌoyánrá tí janhan. A̱ ntá chꞌín Abraham xi̱kahya kjuíchꞌe chꞌán.  
\v 41 Jahará tjejochꞌerá éxí kjuíchꞌe itꞌárá ―ichro chꞌán. 
\p Ntá ntáchro sín kíxin: 
\p ―Jehya kꞌónamá tí jeheni. Náhí. Chóntani jnkoko̱á Itꞌéni mé Dios ―ichro sín. 
\p  
\v 42 Ntá ntáche chꞌín Jesús tí jehe sín kíxin: 
\p ―Tí chrókóchaxín kíxin Dios mé Itꞌárá la ntá chrótjua̱nará kíxin janhan kja̱xin kꞌuaxrjeníxinna Dios kꞌuinkaxian tí tjen chꞌán. Jehya kíxin janhván kꞌuinka. Náhí. Dios mé ichrꞌánna kꞌuinka.  
\v 43 ¿Nkekuènté kíxin tiénxinhyará tí nkehe tjo̱nka̱rá? Jehí tjinkákonhyará chrókuinhínrá tí nkehe xrja̱nka.  
\v 44 Jahará mé xje̱en Tsochren la ko jahará tsíkꞌaxrjeníxinrá chꞌán la ko tjinkáonrá si̱nchexiteyárá tí nkehe tjinkaon chꞌán. Tsochren mé xrankíxixín kjuaya chꞌán. Nunca kꞌuénixja chꞌán ntoá. Xráxín chꞌia chꞌán kíxin xi̱kahó tjenka̱yáxin chꞌán. Jehe chꞌán mé itꞌé kaín tí kjuachꞌia.  
\v 45 A̱ ntá janhan tjétjo̱nka̱rá nkehe ntoá ntá títekákonnahyará.  
\v 46 ¿Á tjejorá jnkojínrá nohará nkerí jie̱ kjuásian janhan? A̱ ntá tí ntáxrja̱n tí nkehe ntoá, ¿ntá nkekuènté títekákonnahyará?  
\v 47 Tí sín tinkáchónki Dios mé tjinkaon sín chrókuinhin sín itén Dios. A̱ ntá jahará la tinkachónkihyará Dios ntá tjinkákonhyará chrókuinhínrá itén chꞌán ―ichro chꞌín Jesús. 
\s1 Cristo la ó xráxín tjen ntá chrꞌéxi̱n kjuákꞌe chꞌín Abraham 
\p  
\v 48 A̱ ntá tí sín judío ntáche sín tí chꞌín Jesús kíxin: 
\p ―Chaxín ntoá ntáchroni kíxin jaha mé ijnko chojni samaritano la ko chonta ijnko ncha̱kuen tí jínahya ―ichro sín. 
\p  
\v 49 Ntá kjuáte̱he chꞌín Jesús ntáchro chꞌán kíxin: 
\p ―Janhan chontahya ninkehó ncha̱kuen tí jínahya. Tí xra̱ tꞌa̱ mé tjikosáya̱ha̱ Tꞌaná. Ntá jahará mé chontahyará kjuasáyé tí janhan.  
\v 50 Janhan na tjéyáhya nkexro tsjikosáyana. Kjánchó itjen ijnko nkexro tjinkaon chꞌán chrókjuikosáyana chojni, a̱ ntá jehe chꞌán mé tsjanchia jie̱ tí sín kuítekakonhya.  
\v 51 Imá tjetoan tí nkehe tjétjo̱nka̱rá kíxin tí tsítekáonrá tí nkehe tjàkua la í tsꞌénhyará ―ichro chꞌán. 
\p  
\v 52 Ntá kjuáte̱he tí sín judío ntáchro sín kíxin: 
\p ―Ntá ó noheni kíxin chaxín chonta ijnko ncha̱kuen tí jínahya. Chꞌín Abraham la ko kaín tí sín kꞌuéchrónka itén Dios ósé la mé ikꞌuén sín. Ntá jaha ntáchrua kíxin tí tsitekaonni tí nkehe tjàkua jaha ntá í tsꞌenhyani, ichrua.  
\v 53 ¿Xá imá této̱an jaha la ntá kánhyó tꞌe̱to̱an itꞌéni Abraham? Jehe chꞌán la ikꞌuén chꞌán la ko kja̱xin ikꞌuén tí sín kꞌuéchrónka itén Dios ósé. ¿Xá nkexro tí jaha, ichrua? ―mé chro sín. 
\p  
\v 54 Ntá kjuáte̱he chꞌín Jesús ntáchro chꞌán kíxin: 
\p ―Tí chrókjuíkosáya̱ha̱ a̱senná na mé sínkíhya tíha. A̱ ntá Tꞌaná mé tjikosàyana chꞌán na ntá jahará ntáchrorá kíxin jehe chꞌán mé Dios kuèntárá.  
\v 55 Kjánchó chonhyará chꞌán. A̱ ntá janhan choxian chꞌán. Tí chróntáxrja̱n kíxin janhan chonhya chꞌán ntá chrókóyòna tí jahará chrókjui̱tꞌayahará. Kjánchó janhan na choxian chꞌán la ko nta̱xiteyáha̱ tí nkehe tꞌe̱to̱an chꞌán.  
\v 56 Chꞌín Abraham tí nkexro tsíkꞌaxrjeníxinrá la imá kóchéhe̱ chꞌán kíxin tsꞌikon chꞌán tí ya̱on tsꞌinka janhan. Ntá ó kjuixin kꞌuíkon chꞌán ntá kóchéhe̱ chꞌán ―ichro chꞌán. 
\p  
\v 57 A̱ ntá tí sín judío ntáche sín tí chꞌín Jesús kíxin: 
\p ―Jaha na̱xa̱ chontahya cincuenta nánó, ¿na ntá nkekuènté ntáchrua kíxin ó kꞌuíkuan tí chꞌín Abraham? ―ichro sín. 
\p  
\v 58 Ntá kjuáte̱he chꞌín Jesús ntáchro chꞌán kíxin: 
\p ―Imá tjetoan tí nkehe tjétjo̱nka̱rá kíxin na̱xa̱ kohya chꞌín Abraham mé xráxín itjén janhan ―ichro chꞌán. 
\p  
\v 59 Ntá kuákja sín xro̱ chróchjéhe sín tí chꞌín Jesús. Kjánchó kjuákꞌemá chꞌán ni̱nko ntá chrꞌéxi̱n kꞌuaxrjexín chꞌán ntiha. Kꞌuátsínka chꞌán jnko̱siné tí tjejó sín sákjuí chꞌán.﻿ 
\c 9  
\s1 Chꞌín Jesús kjuínchekito̱he jína ijnko chꞌín tsíkokjíexín tꞌikonhya chꞌán 
\p  
\v 1 Kꞌuátsínka sín ijnko nti̱a ntá kꞌuíkon chꞌín Jesús ntiha tjen ijnko chꞌín tsíkokjíexín tꞌikonhya chꞌán.  
\v 2 Ntá tí sín kꞌuájiko chꞌín Jesús kjuanchankíhi sín chꞌán kíxin: 
\p ―Maestro, ¿Nkekuènté tsíkokjíexín chꞌán tꞌikonhya chꞌán? ¿Á iji̱é itꞌé o̱ ìné chꞌán o̱ á iji̱é chꞌán? ―ichro sín. 
\p  
\v 3 Ntá kjuáte̱he chꞌín Jesús ntáchro chꞌán kíxin: 
\p ―Jehya iji̱é chꞌán la ko jehya iji̱é itꞌé la ko ìné chꞌan. Náhí. Jehí xi̱kaha tsíkónhen chꞌán kíxin tí kjua̱cha̱xién Dios tsja̱ko̱xi̱n kíxin tsito̱exín chꞌán jína.  
\v 4 Na̱xa̱ ncha̱kotjin tꞌichjánxi̱n si̱tꞌa tí xra̱ tjinkaon tí nkexro tsíchrꞌánna. Ntá tsꞌixin tie ntá kohya ninkexró tsjacha sichꞌe xra̱.  
\v 5 Na̱xa̱ itjén janhan mé ntihi chjasintajni na mé janhan xrohi tꞌinkaséyanxín tí chjasintajni ―ichro chꞌán. 
\p  
\v 6 Ntá ó kjuixin ntáchro chꞌán tíha ntá kui̱ki̱te chꞌán nta̱ten chꞌán intsí nche kꞌóna nche̱tꞌo̱ ntá kuátematóxin chꞌán ikon tí chꞌín tꞌikonhya.  
\v 7 Ntá kꞌue̱tue̱nhen chꞌán tí chꞌín tꞌikonhya kíxin: 
\p ―Sátjia tí pila tjiá nta̱ itꞌin Siloé tꞌontia kuan ―ichro chꞌán. (A̱ ntá tí ihni̱é Siloé mé tꞌaxrjexín nkíve̱e sín kíxin Kꞌuítuenhen.) 
\p Ntá sákjuí tí chꞌín tꞌikonhya kꞌónti chꞌán ikon chꞌán ntá kjan chꞌán kꞌuíkon chꞌán.  
\v 8 Ntá tí sín nto̱e chjinaxón nto̱e chꞌán la ko tí sín kꞌuékꞌikon sín kíxin tꞌikonhya chꞌán mé ntáchro sín kíxin: 
\p ―¿Á jehya tí chꞌín i kꞌuékjakꞌetja̱xi̱n chꞌán kꞌuékjanchakꞌá chꞌán? ―ichro sín. 
\p  
\v 9 Iso sín ntáchro sín kíxin: 
\p ―Kjá chaxín jehe chꞌán ―ichro sín. 
\p Ikjé sín ntáchro sín kíxin: 
\p ―Náhí, jehya jehe chꞌán. Tóyóhó chꞌán tí chꞌín a ―ichro sín. 
\p Kjánchó jehe chꞌán kjuáte̱he chꞌán kíxin: 
\p ―Chaxín janhan ―ichro chꞌán. 
\p  
\v 10 Ntá kjuanchankíhi sín chꞌán kíxin: 
\p ―¿Nkexrí kíxin jaí tꞌikuan jaha? ―ichro sín. 
\p  
\v 11 Ntá kjuáte̱he chꞌán ntáchro chꞌán kíxin: 
\p ―Ijnko chꞌín mé itꞌin Jesús mé kjuíchꞌéna chꞌán nche̱tꞌo̱ kuátematóxin chꞌán kua̱n la ntá kꞌue̱tua̱nna chꞌán kixin satsjia ti pila tjiá nta̱ nchekꞌin sín Siloé tsꞌontia kua̱n, ichro chꞌán. Ntá sákjuia kꞌontia, ntá xrína̱hya ó kꞌuíkua̱n ―ichro chꞌán. 
\p  
\v 12 Ntá kjuanchankíhi sín chꞌán ntáchro sín kíxin: 
\p ―¿Nketí tjen tí chꞌín a? ―ichro sín. 
\p Ntá kjuáte̱he chꞌan ntachro chꞌan kixin: 
\p ―Nonahya janhan ―ichro chꞌan. 
\s1 Tí sín fariseo tjanchankíhi sín tí chꞌín kꞌuékꞌikonhya kuíto̱he jína 
\p  
\v 13 Ntá tí sín a sákjuíko sín tí chꞌín kꞌuékꞌikonhya sákjuíchréhe̱ sín tí sín fariseo a.  
\v 14 A̱ ntá tí ya̱on tꞌo̱kꞌéhe sín mé tsíkjichꞌéna chꞌín Jesús tí nche̱tꞌo̱ kjuínchekito̱exín jína tí chꞌín kꞌuékꞌikonhya.  
\v 15 A̱ ntá tí sín fariseo xíkjanchankíhi sín chꞌán ínaá kíxin nkexrí kuíto̱he chꞌán jína tꞌikon chꞌán jie. Ntá kjuáte̱he chꞌán ntáchro chꞌán kíxin: 
\p ―Kuátematóxin chꞌán nche̱tꞌo̱ kua̱n, ntá kꞌontia kua̱n ntá jie tꞌíkua̱n ―ichro chꞌán. 
\p  
\v 16 Ntá iso tí sín fariseo ntáchro sín kíxin: 
\p ―Tí chojni a jehya kuènte Dios kíxin chóntahya chꞌán kjuasáyé tí ya̱on tꞌo̱kꞌéheni ―ichro sín. 
\p Kjánchó ikjé sín ntáchro sín kíxin: 
\p ―¿Xá nkexrí chrókjuasin chꞌán kjuaxroan jié tí chónta chꞌán jie̱? ―ichro sín. 
\p Mé xi̱kaha jnkokónhya kjuenka̱yáxin tí jehe sín.  
\v 17 Ntá xíkjanchankíhi sín tí chꞌín kꞌuékꞌikonhya ínaá kíxin: 
\p ―¿Ntá jaha nkechrua nkexro tíha tí nkexro kjuíntakꞌikuan? ―ichro sín. 
\p Ntá kjuáte̱he chꞌán ntáchro chꞌán kíxin: 
\p ―Janhan ntáxrja̱n kíxin jehe chꞌán mé ijnko nkexro chrónka itén Dios ―ichro chꞌán. 
\p  
\v 18 Kjánchó tí sín judío kuítekakonhya sín kíxin chaxín kꞌuékꞌikonhya chꞌán ntá jie tꞌikon chꞌán. Ntá kꞌuíye̱he̱ sín tí itꞌé la ko tí ìné tí chꞌín tsíkito̱he jína.  
\v 19 Kjuanchankíhi sín ntáchro sín kíxin: 
\p ―¿Á xja̱an tíhi tí ntáchrorá kíxin tí tsíkokjíexín chꞌán tꞌikonhya chꞌán? ¿Ntá nkexrí jie tꞌikon chꞌán? ―ichro sín. 
\p  
\v 20 Ntá kjuáte̱he tí itꞌé la ko tí ìné chꞌán ntáchro sín kíxin: 
\p ―Ó noheni kíxin xje̱enni chꞌán la ko noheni kíxin tí kokjíexín chꞌán tꞌikonhya chꞌán.  
\v 21 Kjánchó noehyani nkexrí kíxin tꞌikon chꞌán jie la ko noehyani nkexro kjuínchekito̱he chꞌán jína. Tjanchankíhírá chꞌán, ó nte̱to chꞌán, ntá jehe chꞌán tsochrónka chꞌán kíxin nkexrí kuíto̱he chꞌán jína ―ichro sín. 
\p  
\v 22 Mé xi̱kaha kjuáte̱he tí itꞌé la ko tí ìné chꞌán kíxin chrako̱nhe̱n sín tí sín judío kíxin ó kjuixin chrónka tí sín judío kíxin tsjanjonhya sín kjuachaxin tsꞌixenhen ni̱nko tí sín titekaon kíxin chꞌín Jesús mé tí nkexro Cristo.  
\v 23 Mé xi̱kaha ntáchro tí itꞌé la ko tí ìné chꞌán kíxin chrókjuanchankíhi sín chꞌán, ó nte̱to chꞌán, ichro sín. 
\p  
\v 24 Ntá yóxin xíkꞌíye̱he̱ tí sín judío tí chꞌín kꞌuékꞌikonhya ntá kꞌue̱tue̱nhen sín chꞌán kíxin: 
\p ―Tjetsjehe Dios ntá ntoá chro̱nka kíxin ó noheni kíxin tí chꞌín a na chónta chꞌan jie̱ ―ichro sín. 
\p  
\v 25 Ntá tí chꞌín kꞌuékꞌikonhya kjuáte̱he chꞌán kíxin: 
\p ―Nonahya á chónta chꞌán jie̱ o̱ á chóntahya chꞌán jie̱. Jnkoko̱á nkehe nòna kíxin senó kꞌuékꞌíko̱nhya ntá jie tꞌíkua̱n ―ichro chꞌán. 
\p  
\v 26 Ntá xíkjanchankíhi sín chꞌán ínaá kíxin: 
\p ―¿Nkexrí kjuíchꞌe chꞌán kíxin kjuíntakꞌikuan chꞌán? ―ichro sín. 
\p  
\v 27 Ntá kjuáte̱he chꞌán ntáchro chꞌán kíxin: 
\p ―Ó kjuixin tjo̱nka̱rá kjánchó títekákonhyará. ¿Nkekuènté tjinkáonrá kíxin tso̱tjo̱nka̱rá ínaá? ¿Á kja̱xinrá tjinkáonrá tsochréhérá chꞌán? ―ichro chꞌán. 
\p  
\v 28 Ntá kónínkakonhen sín chꞌán la kꞌuántaxínhi̱n sín chꞌán la ko kjuáte̱he sín kíxin: 
\p ―Jaha la chréhé tí chojni a. A̱ ntá jeheni na chréhe̱ni tí nkehe kꞌue̱to̱an chꞌín Moisés.  
\v 29 Ó noheni kíxin Dios kꞌuénixje̱he̱ chꞌín Moisés. A̱ ntá tí chꞌín a la noehyani nketí tsíkji̱xi̱n chꞌán ―ichro sín. 
\p  
\v 30 Ntá kjuáte̱he tí chꞌín ntáchro kíxin: 
\p ―Imá ókjé tíha. Tí chꞌín a mé kjuínchekꞌikonna. A̱ ntá jahará ntáchrorá kíxin noahyará nketí tsíkji̱xi̱n chꞌán.  
\v 31 Ó noheni kíxin tienhya Dios tí nkehe tjanchia tí chojni chónta jie̱. Jehó tinhin chꞌán tí nkehe tjanchia tí sín titekaon Dios la ko nchexiteyéhe̱ sín tí nkehe tjinkaon chꞌán.  
\v 32 Nunca kienhyéni kíxin ijnko nkexro chrókjuinchekꞌikon ijnko chojni tsíkokjíexín tꞌikonhya.  
\v 33 A̱ ntá tí nkexro a tí chrókui̱xi̱nhya chꞌán tí tjen Dios la kjá ninkehó nkehe xitjahya chrókjuichꞌe chꞌán ―ichro chꞌán. 
\p  
\v 34 Ntá kjuáte̱he tí sín fariseo ntáchro sín kíxin: 
\p ―Jaha la nchónhya jie̱ chonta tió kokjíha. A̱ ntá jie ¿á tjinkávan kíxin jaha chrókjuákohéni ní? ―ichro sín. 
\p Ntá kótéka sín tí chꞌín a kíxin tsꞌaxrjexín chꞌán tí ni̱nko a sátsji chꞌán. 
\s1 Ntakótán ncha̱kuen sín 
\p  
\v 35 Ntá kuínhin chꞌín Jesús kíxin xi̱kaha kꞌue̱tue̱nhen tí sín judío kíxin tsꞌaxrjexín ni̱nko tí chꞌín kꞌuékꞌikonhya. Ntá xeta chꞌín Jesús tí chꞌín a ntá kjuanchankí chꞌán kíxin: 
\p ―¿Á tinkachónkia tí Xje̱en Dios Kꞌóna Chojni? ―ichro chꞌán. 
\p  
\v 36 Ntá kjuáte̱he tí chꞌín a ntáchro chꞌán kíxin: 
\p ―Tjákohéni nkexro tíha kíxin ntá tsinkáchónkini chꞌán. 
\p  
\v 37 Ntá kjuáte̱he chꞌín Jesús ntáchro chꞌán kíxin: 
\p ―Ó kꞌuíkuan jaha. Janhan mé tí nkexro tjetjuá jaha ―ichro chꞌán. 
\p  
\v 38 Ntá kjuákꞌexín tochꞌin chꞌán to̱té chꞌín Jesús ntáchro chꞌán kíxin: 
\p ―Ijie kuíteka̱van tí jaha Ìnchéni ―ichro chꞌán. 
\p  
\v 39 Ntá ntáchro chꞌín Jesús kíxin: 
\p ―Kꞌuinka ntihi chjasintajni kíxin si̱ntakito̱axián iji̱é chojni kíxin ntá tí sín tꞌikonhya la mé tsꞌikon sín, a̱ ntá tí sín tꞌikon jie la í tsꞌikonhya sín ―ichro chꞌán. 
\p  
\v 40 A̱ ntá iso tí sín fariseo kꞌuéjóntaxín kuínhin sín kíxin xi̱kaha ntáchro chꞌín Jesús, ntá kjuanchankíhi sín chꞌán kíxin: 
\p ―¿Xá kja̱xin jeheni ntakótáni? ―ichro sín. 
\p  
\v 41 Ntá kjuáte̱he chꞌín Jesús ntáchro chꞌán kíxin: 
\p ―A̱ ntá tí jahará tí chaxín chrókꞌuikonhyará ntá chróchontahyará jie̱. Kjánchó ntáchrorá kíxin tꞌikonrá. Méxra̱ chontará jie̱ ―ichro chꞌán.﻿ 
\c 10  
\s1 Chꞌín Jesús ncheyóe̱xín tí tꞌinkachjina kolélo 
\p  
\v 1 Ntá ntáchro chꞌín Jesús kíxin: 
\p ―Imá tjetoan tí nkehe tjétjo̱nka̱rá kíxin tí tsꞌixenhen ijnko chojni tí tꞌinkachjina kolélo ntá jehya puerta tí corral tꞌixenxín chꞌán na mé ókjé chrokꞌuixenxín chꞌán na mé xíche̱e tíha la tjinkaon chrókueé.  
\v 2 A̱ ntá tí nkexro tꞌixenxín tí puerta na mé nkexro tꞌayakonhen tí kolélo a.  
\v 3 La ko tí chꞌín tjetꞌayakonhen tí puerta a mé tsakitje̱he̱ chꞌán tí puerta a kíxin tsꞌixenhen tí nkexro chaxín tꞌayakonhen tí kolélo a. A̱ ntá tí kolélo a mé tsjatso̱an va itén chꞌán. Ntá tꞌíye̱xi̱n chꞌán jnkojnko ihni̱é jnkojnko tí kolélo kuènte chꞌán ntá tsꞌaxrjexín va nto̱e va.  
\v 4 Ntá tꞌikon chꞌán kíxin kꞌuaxrje kaín va ntá kuítonhen chꞌán va nti̱a ntá tinkáchréhe̱ va kíxin tjatso̱an va itén chꞌán.  
\v 5 Chrohya va tjichréhe̱ va ijnko chojni ókjé na mé tsinkéhe va tí chojni a kíxin tjatso̱anhya va itén ókjé chojni ―ichro chꞌán. 
\p  
\v 6 Mé xi̱kaha ntáchro chꞌín Jesús kjuíncheyóe̱xin chꞌán. Kjánchó tienxínhya sín nkexrí tꞌaxrjexín tíha. 
\s1 Chꞌín Jesús mé tí pastor jína 
\p  
\v 7 Ntá chrónka chꞌín Jesús ínaá ntáchro chꞌán kíxin: 
\p ―Ijnko nkehe tjetoan tso̱tjo̱nka̱rá kíxin janhan la éxí tí puerta tꞌixenxín tí kolélo tí tꞌinkachjina va.  
\v 8 Kaín tí sín kuitónxin nti̱a kui senó mé xíche̱e la ko chrókueé. La ntá tí kolélo la ánto̱sén va tí nkehe ntáchro tí jehe sín.  
\v 9 Janhan mé tí puerta a mé tꞌixe̱nxínrá tí janhan mé tsaárá la mé tso̱yóha̱rá tí kolélo siín kjuachaxin tsꞌaxrjexín va tí kòrré va sátsjikjine va la ko siín kjuachaxin tsꞌixenhen va tí tsꞌinkachjina va ínaá. 
\p  
\v 10 ’A̱ ntá xíche̱e mé jehó chrókueé la ko tjinkaon chrókꞌóyán la ko chrókjuinchekꞌitjáyan kaín nkehe. A̱ ntá janhan kꞌuinka kíxin tsochontaxinrá kjuachón na mé kjuachón jnkochríxín.  
\v 11 Janhan mé ijnko pastor jína a̱ ntá tí pastor jína mé tsꞌenyákonhe̱n tí kolélo a.  
\v 12 A̱ ntá tí nkexro chꞌe xra̱ tjinkaon chrókjuacha ó na mé tsꞌikon chꞌán itsi ijnko kolobo tsíto̱he chꞌán tí kolélo sátsji chꞌán kíxin jehe chꞌán la jehya tí nkexro tꞌayakonhen tí kolélo la ko jehya kolélo kuènte chꞌán. Ntá tí kolobo mé tsotsé va tí kolélo ntá tsinká va la sátsjichroe va.  
\v 13 Mé xi̱kaha tí chojni tjinkaon chrókjuacha tí xra̱ chrókjuichꞌe ó la mé sátsji. A̱ ntá tí kolélo la ánto̱sén chꞌán kuáhya chꞌán kuenté tí jehe va. 
\p  
\v 14-15 ’A̱ ntá janhan mé ijnko pastor jína. Mé xi̱kaha Tꞌaná chóxin chꞌán tí janhan la ko kja̱xin janhan choxian tí jehe chꞌán mé xi̱kaha choxian janhan tí sín éxí kolélo kuènta̱na la ko jehe sín mé chóxin sín tí janhan. Ntá tsꞌényákonha̱n tí sín éxí kolélo kuènta̱na.  
\v 16 Kja̱xin chonta kolélo na̱xa̱ jehya kòrré va ntihi mé kja̱xin tꞌichjánxi̱n sátsjícakjián va. A̱ ntá tí tsitekakonna va ntá tsꞌóna jnkoko̱á kòrré va la ko jnkoko̱á nkexro tsꞌayakonhen va. 
\p  
\v 17 ’Tjua̱na Tꞌaná kíxin kjónté itsꞌén la tsoxechónna ínaá.  
\v 18 Kohya nkexro tsakitsjena tí kjuachón chonta janhan tí chrókjuánjonhya kjuachaxin. Chonta janhan kjuachaxin itsꞌén la ko chonta janhan kjuachaxin tsoxechónna ínaá. Tíhi mé kꞌue̱tua̱nna Tꞌaná ―ichro chꞌín Jesús. 
\p  
\v 19 Tió kuínhin tí sín judío tí nkehe ntáchro chꞌín Jesús ntá kjuankíxin jnkoko̱áhya kjuenka̱yáxin sín.  
\v 20 Nchónhya tí jehe sín ntáchro sín kíxin: 
\p ―¿Nkekuènté tinhínrá tí nkehe ntáchro chꞌán? Jehe chꞌán mé chónta chꞌán ncha̱kuen tí jínahya la ko lóco chꞌán ―ichro sín. 
\p  
\v 21 Ntá ikjé sín ntáchro sín kíxin: 
\p ―Xi̱kahya chrónixja ijnko chojni chónta ncha̱kuen tí jínahya. ¿Á ijnko ncha̱kuen tí jínahya la á jína chrókjuinchekꞌikon ijnko chojni tꞌikonhya? ―ichro sín. 
\s1 Tí sín judío kuítekakuenhya sín tí chꞌín Jesús 
\p  
\v 22 A̱ ntá tí ncha̱kuen kin tí chjasin Jerusalén kꞌuíxin kia xraxinkakonxín sín tí ya̱on tsíkjixin tsíkꞌóna ni̱nko.  
\v 23 Ntá chꞌín Jesús itjen chꞌán tí ni̱nko tí nta̱sin kuènte Salomón.  
\v 24 Ntá tí sín judío kꞌuántatjen sín tí chꞌín Jesús kjuanchankíhi sín chꞌán kíxin: 
\p ―¿Hasta nkesá tsꞌejóchónhenni tsinhinni jína? A̱ ntá jie chro̱nka ntoá kíxin á chaxín jaha tí Cristo ―ichro sín. 
\p  
\v 25 Ntá kjuáte̱he chꞌín Jesús kíxin: 
\p ―Ó tjo̱nka̱rá ntá na̱xa̱ títekákonhyará. Kaín tí xra̱ tjétꞌa̱ janhan tí kjuachaxin kuènte Tꞌaná mé tja̱ko̱xi̱n nkexro tí janhan.  
\v 26 Kjánchó jahará títekákonhyará kíxin jahará la jehya kolélo kuènta̱na éxí tjo̱nka̱rá senó.  
\v 27 Tí kolélo kuènta̱na mé tjatso̱an va tí tanná la ko kja̱xin janhan tjátso̱an tí jehe va la ko jehe va mé chréhe̱ va tí janhan.  
\v 28 Janhan mé tja̱ha̱ va tí kjuachón jnkochríxín la í tsꞌitjáyanhya va la ko ninkexró tsjachahya tsakitsjexín va tjaná.  
\v 29 Ó kjuanjon Tꞌaná, mé tí nkexro tjetóxin tꞌe̱to̱an, na ninkexró tsjacha tsakitsjexín va tí tja chꞌán.  
\v 30 Janhan la ko Tꞌaná na mé jnkoko̱á nkexro tíha ―ichro chꞌán. 
\p  
\v 31 Ntá tí sín judío kuákja sín xro̱ chróchjéhe sín chꞌán ínaá.  
\v 32 Ntá kjuáte̱he chꞌín Jesús ntáchro chꞌán kíxin: 
\p ―Nchónhya nkehe jína kꞌuíkonrá kjuáko̱xia̱n kjuachaxin kuènte Tꞌaná. ¿Ntá nkekuènté chróchjìnárá xro̱? ―mé chro chꞌán. 
\p  
\v 33 Ntá kjuáte̱he tí sín judío kíxin: 
\p ―Jehya tí kjuaxroan jína tjásian chrótjiáxiánni xro̱. Náhí. Jaha ijnko chojni ó ntá kjui̱ncheyóhé a̱sán Dios na mé tsotjiáxiánni xro̱ ―ichro sín. 
\p  
\v 34 Ntá ntáchro chꞌín Jesús kíxin: 
\p ―Ntá ntáchro xroon itén Dios tsíkjin sín ósé kíxin ntáchro Dios kíxin: “Kja̱xinrá éxí Dios tí jahará.”\f + \fr 10:34 \ft Salmo 82.6\f* 
\v 35 Ntá ó noheni nkehe ntáchro xroon itén Dios na ntá xitjahya tsitekakonhyani tíha. Mé xi̱kaha ntáchro Dios kíxin éxí Dios jnkojnko nkexro kꞌuáyéhe̱ itén chꞌán.  
\v 36 A̱ ntá kjueyána Dios ichrꞌánna chꞌán chjasintajni, ¿ntá nkekuènté ntáchrorá kíxin kꞌuántaxínha̱n Dios kíxin janhan ntáxrja̱n kíxin Xje̱en Dios tí janhan?  
\v 37 Kja̱ tí chrókjui̱tꞌahya tí xra̱ ichꞌe Tꞌaná la chrókuítekákonhyará.  
\v 38 A̱ ntá kjónté tjétꞌa̱ tí xra̱ a kjónté títekákonhyará tí janhan na mé chrókuítekáonrá tí xra̱ tjétꞌa̱ chrókónoaxínrá chrókiénxinrá kíxin Tꞌaná la ko janhan mé jnkoko̱á tjékian chꞌán ―ichro chꞌán. 
\p  
\v 39 Mé xi̱kaha chrótsé sín tí chꞌín Jesús ínaá chrókꞌuikjéhe̱ chꞌán ntá kjuachahya sín ntá sákjuí chꞌán. 
\p  
\v 40 Ntá chꞌín Jesús xíkjan chꞌán tí í jnko lado nta̱río Jordán ínaá tí kꞌuékjakꞌe chꞌín Juan kꞌuéki̱ki̱texín chꞌán chojni senó.  
\v 41 Ntá nchónhya chojni sákjuíchréhe̱ sín chꞌán tsꞌikon sín chꞌán ntáchro sín kíxin: 
\p ―Chaxín chꞌín Juan kjuasinhya chꞌán kjuaxroan jié la kjónté ntoá tí nkehe chrónka chꞌán kuènte tí chꞌín i ―ichro sín. 
\p  
\v 42 Ntá nchónhya sín kuítekaon sín tí chꞌín Jesús tí kjuíji sín ntiha.﻿ 
\c 11  
\s1 Ikꞌuén chꞌín Lázaro 
\p  
\v 1 Itjen ijnko chꞌín níhi mé itꞌin chꞌán Lázaro, chjasén chꞌán na mé Betania, mé tí chjasén tí tjan María la ko tí kja̱vé tjan Marta.  
\v 2 Tí tjan María mé jnkoko̱á kíchó tí chꞌín Lázaro mé tí chꞌín níhi na mé jehe tjan mé tí tjan kui̱ki̱texín aceite xraxé to̱té Ìnchéni la ko kjuínchexámáxin tjan ka̱xi̱hi tjan to̱té chꞌán.\f + \fr 11:2 \ft Juan 12.3\f* 
\v 3 A̱ ntá yóí tí kíchó chꞌán chjin ichrꞌán sín ijnko nkexro tsochénka tí chꞌín Jesús kíxin: 
\p ―Ìnchéni jaha, tí nkexro choxian tjuèhé la níhi chꞌán ―ichro chꞌán. 
\p  
\v 4 Ntá kuínhin chꞌín Jesús ntá ntáchro chꞌán kíxin: 
\p ―Tí chin chónta chꞌán jehya kíxin ónaá chrókꞌuitjáyanxón chꞌán tí tsꞌen chꞌán. Náhí. Tíha mé tsja̱ko̱xi̱n tí kjuachaxin jié kuènte tí Xje̱en Dios ―ichro chꞌán. 
\p  
\v 5 A̱ ntá tí chꞌín Jesús la imá tjuèhé chꞌán tí tjan Marta la ko tí tjan kíchó tjan la ko tí chꞌín Lázaro.  
\v 6 Na ntá tió kuínhin chꞌán kíxin níhi chꞌín Lázaro na kjónté kuíto̱he chꞌán iyó ya̱on ínaá tí nó kjuákꞌe chꞌán.  
\v 7 A̱ ntá chrꞌéxi̱n ntáche chꞌán tí sín kꞌuájiko chꞌán kíxin: 
\p ―Sátsjini estado Judea ínaá ―ichro chꞌán. 
\p  
\v 8 Ntá kjuáte̱he tí sín kꞌuájiko chꞌán kíxin: 
\p ―Maestro, na̱xa̱ séhya tí sín judío ntiha chrótjáha sín xro̱ tjinkaon sín chrókꞌóyánxian sín xro̱. ¿Á tjinkávan sátsjia ntiha ínaá? ―ichro sín. 
\p  
\v 9 Ntá ntáchro chꞌín Jesús kíxin: 
\p ―Jnkojnko ya̱on mé chónta teyó hora. Tió ixri chojni ncha̱kotjin tsóténki̱xi̱nhya sín ninkehó kíxin tꞌinkaséyanxín xrohi chjasintajni a.  
\v 10 Tí sín ixri tie mé tsóténki̱xi̱n sín nkehe kíxin chóntahya sín xrohi ―ichro chꞌán. 
\p  
\v 11 Ntá chrꞌéxi̱n ntáche chꞌín Jesús tí sín kꞌuájiko chꞌán kíxin: 
\p ―Ó kꞌuájua tí nkexro chóxinni mé chꞌín Lázaro. Ntá sátsjia si̱ntakjaya̱ha̱ chꞌán ―ichro chꞌán. 
\p  
\v 12 Ntá ntáchro tí sín kꞌuájiko chꞌán kíxin: 
\p ―Ìnchéni, tí kꞌuájua chꞌán la mé chrókuito̱he chꞌán jína ―ichro sín. 
\p  
\v 13 Kjánchó tí nkehe ntáchro chꞌín Jesús mé tꞌaxrjexín kíxin ó tsíkjixin tsíkꞌen tí chꞌín Lázaro. Ntá tí sín kꞌuájiko chꞌán kjuenka̱yáxin sín kíxin ó jehí tjejua chꞌín Lázaro.  
\v 14 Ntá ntoá chrónka chꞌín Jesús kíxin: 
\p ―Ó tsíkꞌen chꞌín Lázaro.  
\v 15 Ntá chàna kíxin kohyana ntiha kíxin mé xi̱kaha tsítekákonxínrá. A̱ ntá jie ìntárá sátsjitsjeheni chꞌán ―ichro chꞌán. 
\p  
\v 16 Ntá chꞌín Tomás, kja̱xin ti̱ki̱texín sín chꞌán chꞌín Nóhé, mé ntáche chꞌán tí í so sín kíxin: 
\p ―Sátsjini koíni kaín ni tsꞌenka̱oni Ìnchéni ―ichro chꞌán. 
\s1 Chꞌín Jesús ntáchro chꞌán kíxin sinchexechón chꞌán chojni ínaá 
\p  
\v 17 Ntá kjuíji chꞌín Jesús kuínhin chꞌán kíxin chꞌín Lázaro la ó chónta noó ya̱on tsíkji̱xravá chꞌán.  
\v 18 A̱ ntá tí chjasin Betania mé chjinaxón tí chjasin Jerusalén, chónta iyó kilómetro ko tꞌo̱ kjínxi̱n.  
\v 19 A̱ ntá itsjé tí sín judío sátsíkjitsjehe sín tí tjan Marta la ko tí tjan María tjejónixje̱he̱ sín kíxin kánhyó tsꞌává sín kíxin tsíkꞌén tí kíchó sín a.  
\v 20 Ntá kuínhin tjan Marta kíxin ó kui chꞌín Jesús ntá kꞌuaxrjexín tjan nchia tsjíxinhin nti̱a. A̱ ntá tí tjan María kuíto̱he tjan nchia.  
\v 21 Ntá tí tjan Marta ntáche tí chꞌín Jesús kíxin: 
\p ―Ìnchéni jaha. Chrókjuakꞌe ntihi ntá chrókꞌuenhya kíchó ni.  
\v 22 Kjánchó ó nòna kíxin Dios tso̱tjáha kaín nkehe tsjanchehé chꞌán ―ichro tjan. 
\p  
\v 23 Ntá ntáchro chꞌín Jesús kíxin: 
\p ―Tsoxechón kíchuá ínaá ―ichro chꞌán. 
\p  
\v 24 Ntá ntáchro tjan Marta kíxin: 
\p ―Ó nòna kíxin tsoxechón chꞌán tió tsoxechón kaín tí sín tsíkꞌen, tí ya̱on tsjixixín ―ichro tjan. 
\p  
\v 25 Ntá ntáchro chꞌín Jesús kíxin: 
\p ―Janhan mé nta̱xechón chojni la ko tsochónta sín kjuachón. Tí nkexro tsitekaon sín tí janhan na kjónté ó tsíkꞌen sín la na̱xa̱ si̱ntaxechón sín ínaá.  
\v 26 La ko kaín xín tí sín na̱xa̱ tjejóchón sín la tsitekaon sín tí janhan na tsꞌenhya sín. ¿Á títekávan xi̱kaha ní? ―ichro chꞌán. 
\p  
\v 27 Ntá ntáchro tjan kíxin: 
\p ―Chaxín Ìnchéni títeka̱van kíxin jaha mé Cristo, mé Xje̱en Dios, mé tí nkexro kui chjasintajni ―ichro tjan. 
\s1 Tsjánka chꞌín Jesús tí tsíkji̱xravá nkexro Lázaro 
\p  
\v 28 Ó kjuixin ntáchro tjan Marta xi̱kaha ntá sákjuíkꞌíye̱he̱ tjan kíchó tjan María ntá imó chénka tjan kíxin: 
\p ―Ntiha tjen Maestro tꞌiya̱há chꞌán ―ichro tjan. 
\p  
\v 29 Ntá kuínhin tjan María ntá tuénxín kꞌuínkatjen tjan sákjuítsjehe tjan tí chꞌín Jesús.  
\v 30 Na̱xa̱ tsíkꞌixenhya chꞌán chjasin na̱xa̱ tjen chꞌán tí xéta chꞌán tjan Marta.  
\v 31 Ntá tí sín judío tjejónixje̱he̱ tjan María kíxin kánhyó tsꞌává tjan, mé kꞌuíkon sín kíxin tjoka kꞌuaxrjexín tjan nchia, ntá kjuíchréhe̱ sín tjan kjuenka̱yáxin sín kíxin sátsji tjan tí tsíkji̱xravá kíchó tjan, ntaha tsjitsjánkàma̱ tjan chꞌán, ichro sín. 
\p  
\v 32 Ntá tí tjan María mé kjuíji tjan tí tjen chꞌín Jesús ntá kjuákꞌexín tochꞌin tjan to̱té chꞌán ntáchro tjan kíxin: 
\p ―Ìnchéni jaha, chrókjuakꞌe jaha ntihi ntá chrókꞌuenhya kíchiná ―ichro tjan. 
\p  
\v 33 Ntá kꞌuíkon chꞌín Jesús kíxin tsjánka tí tjan María la ko tí sín judío kjuikotoxi̱n tjan ntá imá kꞌuává chꞌán kóxakonhen a̱sén chꞌán.  
\v 34 Ntá kjuanchankí chꞌán kíxin: 
\p ―¿Nketí kjua̱várá chꞌán? ―ichro chꞌán. 
\p Ntá ntáchro sín kíxin: 
\p ―Ìnchéni, ¿á sátsjitsjehé? ―ichro sín. 
\p  
\v 35 Ntá tsjánka chꞌín Jesús.  
\v 36 Ntá ntáchro tí sín judío kíxin: 
\p ―Tsjehérá kíxin imá tjuèhe chꞌán tí chꞌín tsíkꞌen ―ichro sín. 
\p  
\v 37 Kjánchó í so sín ntáchro sín kíxin: 
\p ―Jehe chꞌán mé kjuínchekꞌikon tí chꞌín tꞌikonhya. ¿Á xitjahya chrókjuanjon chꞌán intsí kjuachaxin chrókꞌuenhya tí chꞌín Lázaro ní? ―ichro sín. 
\s1 Ó xechón chꞌín Lázaro 
\p  
\v 38 Ntá imá tꞌává a̱sén chꞌín Jesús kóchjinehe chꞌán tí tòye̱. Tí tòye̱ mé ijnko tjo̱, a̱ ntá tí ntója tí tjo̱ mé tsíkꞌikjèxin ijnko xro̱.  
\v 39 Ntá kꞌue̱to̱an chꞌín Jesús kíxin: 
\p ―Tjakjíyan tí xro̱ a ―ichro chꞌán. 
\p A̱ ntá tí tjan Marta mé kíchó tí nkexro kꞌuén mé ntáchro tjan kíxin: 
\p ―Ìnchéni, kjá noha kíxin kjá imá xra kíxin ó chónta noó ya̱on tsíkꞌen chꞌán ―ichro tjan. 
\p  
\v 40 Ntá kjuáte̱he chꞌín Jesús ntáchro chꞌán kíxin: 
\p ―Ó tjo̱nka kíxin tsítekávan ntá tsꞌikuan tí kjuachaxin jié kuènte Dios ―ichro chꞌán. 
\p  
\v 41 Ntá kjuakjìin sín tí xro̱ a. Ntá chꞌín Jesús konta chꞌán nka̱jní ntáchro chꞌán kíxin: 
\p ―Itꞌéni, tjáncháha kjuasáya kíxin ó kuínhín tí nkehe ntáxrja̱n.  
\v 42 Janhan na ó nòna kíxin xráxín tjetinhín tí nkehe ntáxrja̱n ntá xi̱kaha ntáxrja̱n jie kíxin tsinhin tí sín tjejóntaxín ntihi ntá tsitekaon sín kíxin jaha mé kuéto̱an kꞌuinka ―mé ichro chꞌín Jesús. 
\p  
\v 43 Ntá kjuixin nixja chꞌán tíha ntá itsen kꞌuèya chꞌán kíxin: 
\p ―¡Lázaro, tꞌaxrjéxian méhe̱! ―ichro chꞌán. 
\p  
\v 44 Ntá tí chꞌín tsíkꞌen kꞌuaxrjexín chꞌán tòye̱, na tí tja chꞌán la ko tí to̱té chꞌán na̱xa̱ tjejóchróntetoxín ka la ko tí nkayakon chꞌán tjekjèxin ijnko ka. Ntá kꞌue̱to̱an chꞌín Jesús kíxin: 
\p ―Tjasinta̱nka̱rá tí ka chróntetoxín chꞌán kíxin jína tsji chꞌán ―ichro chꞌán. 
\s1 Imó kjuenka̱yáxin sín kíxin nkexrí tsꞌóyán sín tí chꞌín Jesús 
\r (Mt. 26.1-5; Mr. 14.1-2; Lc. 22.1-2) 
\p  
\v 45 Ntá itsjé tí sín judío sákjuíkotoxi̱n sín tí tjan María mé kꞌuíkon sín tí kjuaxroan kjuasin chꞌín Jesús ntá kuítekaon sín tí jehe chꞌán.  
\v 46 Kjánchó iso tí jehe sín sákjuítsjehe sín tí sín fariseo kjuíchénka sín tí kjuaxroan tsíkjasin chꞌín Jesús.  
\v 47 Ntá tí sín fariseo la ko tí sín ncha̱tꞌá tꞌe̱to̱an jnkoko̱á kójnkotséko sín tí sín a̱ntsí tꞌe̱to̱an, la ntáchro sín kíxin: 
\p ―¿Xá nkexrí chrókjuichꞌeheni tí chꞌín a kíxin jehe chꞌán mé tjasin chꞌán kjuaxroan jié?  
\v 48 A̱ ntá tí chrókuíto̱heni chꞌán xi̱kahó ntá kaín xín chojni chrókuitekaon sín tí jehe chꞌán, ntá tsi tí sín romano tꞌe̱to̱an sinchekꞌitjáyan sín tí ni̱nko̱éni la ko tí xra̱ chóntani la ko tí nación kuènténi ―ichro sín. 
\p  
\v 49 Ntá chꞌín Caifás mé tí nkexro tꞌe̱tue̱nhen tí sín ncha̱tꞌá tí nánó a ntáche chꞌán tí jehe sín kíxin: 
\p ―Jahará la noahyará ninkehó tíha  
\v 50 la ko kjá ní tjenka̱yáxinhyará kíxin íchá jína kíxin jnkoko̱á chojni chrókꞌuenyákonhe̱n chjasénni kíxin ntá chrókꞌuitjáyanhya kuenté tí nación kuènténi ―ichro chꞌán. 
\p  
\v 51 Kjánchó chꞌín Caifás la jehya jehó chꞌán chrókjuenka̱yáxin chꞌán tíha. Náhí. Jehe chꞌán mé kꞌue̱tue̱nhen tí sín ncha̱tꞌá tí nánó, a̱ ntá tí Ncha̱kuen Dios kjuínchekónohe chꞌán kíxin chꞌín Jesús mé tsꞌenyákonhe̱n tí nación judía.  
\v 52 A̱ ntá jehya tí nación kuènte sín ó chrókꞌuenyákonhe̱n chꞌán. Náhí. Kja̱xin kíxin sinchekaá chꞌán kaín tí sín tsꞌóna xje̱en Dios tjejó sín kuenté chjasintajni.  
\v 53 A̱ ntá tí ya̱on a tí sín tꞌe̱tue̱nhen tí sín judío mé kjuankíxin sín kjuenka̱yáxin sín kíxin chrókꞌóyán sín tí chꞌín Jesús. 
\p  
\v 54 A̱ ntá chꞌín Jesús la í noxínhya kꞌuáji tí kꞌuéjó tí sín judío, na mé kꞌuaxrjexín chꞌán tí estado Judea, sákjuí chꞌán chjinaxón nte̱je̱, tí tjen ijnko chjasin itꞌin Efraín. Ntaha kuíto̱eko chꞌán tí sín kꞌuájiko chꞌán. 
\p  
\v 55 Ntá í séhya ntá tsꞌixin tí kia pascua mé ijnko kié tí sín judío. Ntá itsjé chojni kꞌuaxrjexín sín chjasén sín sákjui̱ sín chjasin Jerusalén kíxin ntaha tso̱yaxínhin sín kíxin tsotjóá sín kjónté na̱xa̱ xrankíxinhya tsꞌixin tí kia pascua.  
\v 56 Ntaha kꞌuájikjeyá sín tí chꞌín Jesús kꞌuéjóxenhen sín tí ni̱nko jié ntá kjuanchankíhi sín kíchó sín kíxin: 
\p ―¿Jahará nkechrorá? ¿Á chrókjui chꞌán tí kia ní o̱ náhí? ―ichro sín. 
\p  
\v 57 A̱ ntá tí sín fariseo la ko tí sín tꞌe̱tue̱nhen tí sín ncha̱tꞌá na ó kꞌue̱to̱an sín kíxin tí siín ijnko nkexro nohe nketí tjen chꞌín Jesús chróchrónka sín kíxin ntá jína chrókjuitsé sín chꞌán chrókjuinchenteto sín chꞌán la ko chrókjua̱kꞌe̱chji̱na sín chꞌán.﻿ 
\c 12  
\s1 Ijnko tjan kjuíncheká tjan aceite xraxé náxrjón to̱té tí chꞌín Jesús 
\r (Mt. 26.6-13; Mr. 14.3-9) 
\p  
\v 1 Na̱xa̱ tꞌitjáyan injon ya̱on ntá tsꞌixin tí kia pascua. A̱ ntá chꞌín Jesús sákjui̱ chꞌán chjasin Betania tí tjen chꞌín Lázaro. Tí chꞌín Jesús mé tsíkjinchexechón chꞌán.  
\v 2 Ntá ntiha kjóne sín ijnko kónjín kjuikosáyehe sín tí chꞌín Jesús. A̱ ntá tí tjan Marta mé kjuíncheyaxín tjan. A̱ ntá tí chꞌín Lázaro la ko í so sín kꞌuéjó sín kjóneko sín tí chꞌín Jesús.  
\v 3 Ntá tjan María kui̱ka̱o tjan itꞌo̱ litro aceite tsíkꞌóna xro̱a̱n nardo imá tjete tsíkꞌe̱naxín tjan ntá kjuíncheka tjan to̱té chꞌín Jesús ntá ka̱xi̱hi tjan kjuínchexámáxin tjan tí to̱té chꞌán. Na mé kuenté nkaxenhen nchia kókaxraxé tí xro̱a̱n.  
\v 4 Ntá chꞌín Judas Iscariote, itꞌé chꞌán mé itꞌin Simón, jehe chꞌán mé ijnko tí sín kꞌuájiko chꞌín Jesús, na mé tí chꞌín sinchekji tí chꞌín Jesús chrꞌéxi̱n, mé ntáchro chꞌán kíxin: 
\p  
\v 5 ―¿Nkekuènté kóxihya tí xro̱a̱n xraxé, chrókóxi̱xi̱n iní ciento chichaon denario kíxin chrókjuinki̱tsa tí sín nòa? ―ichro chꞌán. 
\p  
\v 6 Kjánchó chꞌín Judas la jehya ntáchro chꞌán xi̱kaha kíxin chrókui̱konóe̱he̱ chꞌán tí sín nòa. Náhí. Ntáchro chꞌán tíhi kíxin xráxín che̱e chꞌán kíxin jehe chꞌán tꞌayakonhen chꞌán tí nkehe tjinká chichaon ntá xráxín teé chꞌán tí chichaon tsíxrenájín ntiha.  
\v 7 Ntá ntáchro chꞌín Jesús kíxin: 
\p ―Nté ti̱to̱hérá tjan. Tsíkja̱kꞌe̱chji̱na tjan tí xro̱a̱n a kíxin tí ya̱on tsoxrávána.  
\v 8 Tí sín nòa jnkochríxín tsꞌejokoará sín. A̱ ntá janhan jnkochríxínhya tsꞌejóni ―ichro chꞌán. 
\s1 Tí sín judío itjo sín nkexrí chrókꞌóyán sín tí chꞌín Lázaro 
\p  
\v 9 A̱ ntá itsjé tí sín judío kꞌuíxikónohe sín kíxin chꞌín Jesús kjuákꞌe chꞌán tí chjasin Betania, a̱ ntá sákjuí sín ntiha. Jehya kíxin chrókjuitsjehe sín tí chꞌín Jesús ó. Náhí. Kja̱xin tjinkaon sín chrókjuitsjehe sín tí chꞌín Lázaro mé tí chꞌín tsíkjinchexechón chꞌín Jesús.  
\v 10 Ntá tí sín ncha̱tꞌá tꞌe̱to̱an mé kójnkotsé sín kjuenka̱yáxin sín chrókꞌóyán sín tí chꞌín Lázaro kja̱xin  
\v 11 kíxin itsjé tí sín judío kuítekaon sín tí chꞌín Jesús kíxin xi̱kaha kjuínchexechón chꞌán tí chꞌín Lázaro ntá kꞌuaxrjekjanxín sín tí sín ncha̱tꞌá. 
\s1 Kꞌuíxenhen chꞌín Jesús chjasin Jerusalén 
\r (Mt. 21.1-11; Mr. 11.1-11; Lc. 19.28-40) 
\p  
\v 12 Nchónhya chojni sátsíkji̱ sín chjasin Jerusalén kíxin tí kia pascua. A̱ ntá tí ya̱on chrꞌéxi̱n kꞌuíxikónohe sín kíxin tsjiji chꞌín Jesús tí chjasin ntiha.  
\v 13 Ntá kóchrínjin sín chaan ntakajni kjuíxinhin sín nti̱a itsji chꞌín Jesús, itsje sín, ntáchro sín kíxin: 
\p ―Tjancheheni Dios kjuasáya. Imá jína tí nkexro kui̱xi̱n tí kjua̱cha̱xién Itꞌéni tjen nkaya nka̱jní. Imá jína tí chꞌín Rey tsꞌe̱tue̱nhen tí nación Israel ―ichro sín itsje sín. 
\p  
\v 14 Ntá tsíkꞌitja chꞌín Jesús ijnko kolócho la ntá kjuákꞌekjen chꞌán, éxí nixja itén Dios kíxin: 
\q1  
\v 15 Chrakonhyará jahará tjejorá chjasin Jerusalén, 
\q1 tsjehérá ó tjekui tí chꞌín Rey kuèntárá, 
\q1 tjekjen chꞌán ijnko kolócho.\f + \fr 12:15 \ft Zacarías 9.9\f* 
\p  
\v 16 A̱ ntá tió kónhen tíha kíenxínhya tí sín kꞌuájiko chꞌín Jesús kíxin nkekuènté xi̱kaha kónhen. A̱ ntá chrꞌéxi̱n tió kjuixin sákjui̱jia chꞌán nkaya nka̱jní ntá xraxinkaon sín kíxin xi̱kaha tsíkjin tí sín kꞌuéchrónka itén Dios ósé nkexrí tso̱nhen chꞌán, na ntá xi̱kaha chaxín xiteyá tí chrónka sín senó kíxin xi̱kaha tso̱nhen chꞌán. 
\p  
\v 17 Mé xi̱kaha kaín tí sín tsíkójnkotsé tí kjuákꞌe chꞌín Jesús tió kꞌuíye̱he̱ chꞌán tí chꞌín Lázaro kíxin tsꞌaxrjexín chꞌán tí tòye̱ tsíkji̱xravá chꞌán ntá xechón chꞌán mé tí sín a mé chrónka sín tí nkehe kꞌuíkon sín.  
\v 18 Mé xi̱kaha sákjuíxinhin sín tí nti̱a tsji̱xi̱n chꞌín Jesús, kꞌuíxikónohe sín kíxin xi̱kaha tsíkjasin chꞌín Jesús tí kjuaxroan jié.  
\v 19 Mé xi̱kaha ntáchro tí sín fariseo itjo sín kíchó sín kíxin: 
\p ―Tsjehérá kaín rá, ninkehó tsjachahyani sichꞌeni kíxin kaín xín chojni sákjuíchréhe̱ tí jehe chꞌán ―ichro sín. 
\s1 Iso sín nkive̱e griego tjeyá sín tí chꞌín Jesús 
\p  
\v 20 Iso sín nixja griego kꞌuéjóyákjan tí sín sákjui̱ sín tí kia chjasin Jerusalén tsoxraxinkakonxín sín Dios.  
\v 21 Ntá kóchjinehe sín tí chꞌín Felipe, chjasén chꞌán mé Betsaida, estado Galilea, chrónóe̱he̱ sín chꞌán kíxin: 
\p ―Tjinkaonni chrókꞌuikonni tí chꞌín Jesús ―ichro sín. 
\p  
\v 22 Ntá chꞌín Felipe sákjuíchenka chꞌán tí chꞌín Andrés. Na ntá yóí sín sákjuíchenka sín tí chꞌín Jesús.  
\v 23 Ntá ntáchro chꞌín Jesús kíxin: 
\p ―Ó kjuixraká tí ya̱on, a̱ ntá tí Xje̱en Dios Kꞌóna Chojni mé sátsji̱ chꞌán tsꞌáyéhe̱ chꞌán tí kjuachaxin kuènte Itꞌé.  
\v 24 A̱ ntá tso̱tjo̱nka̱rá ijnko nkehe chaxín kíxin tí chrókjuítsínkahya ijnko noatrigo tí nche chrókꞌuenhya tí noa a, ntá jnkoko̱á noa chrókjuakꞌe. A̱ ntá tí chrókꞌuen tí noa a ntá chrókꞌóna nchónhya noa kíxin chrótjá sín.  
\v 25 A̱ ntá tí nkexro imá tjuèhe̱ a̱sén kíxin kohya nkehe chrókꞌuatsínka na mé tsochóntahya chꞌán kjuachón jnkochríxín. A̱ ntá tí nkexro tjekuènhya a̱sén kjónté chrókꞌuénxin ntihi chjasintajni tí chrónka chꞌán itén Dios na mé chrꞌéxi̱n tsochónta chꞌán kjuachón jnkochríxín.  
\v 26 A̱ ntá tí jnkojín nkexro tjinkaon chrókjuichꞌena sín xra̱ tꞌichjánxi̱n tsochréhe̱ sín tí janhan. A̱ ntá tí tjén janhan na mé kja̱xin tjejó tí sín chꞌena sín xra̱. A̱ ntá jnkojín sín sichꞌena sín xra̱ xi̱kaha na mé Tꞌaná mé tsjikosáyehe tí jehe sín. 
\s1 Chꞌín Jesús chrónka chꞌán kíxin itsꞌen chꞌán 
\p  
\v 27 ’Ntá jie imá tóxakonhen a̱senná. ¿Nkehe chróntáxrja̱n? ¿Á chrókjuáncháha̱ Tꞌaná kíxin sinchekaána chꞌán tí nkehe tso̱na jie o̱ náhí? Kjánchó xra̱ ó kꞌuinka xi̱kaha tso̱na.  
\v 28 Jaha Itꞌéni, tjáko̱xian tí kjuachaxin kuènte ihni̱á ―ichro chꞌán. 
\p Ntá kuínhin sín nixja ijnko nkexro nka̱jní ntáchro kíxin: 
\p ―Ó kjuixin kjuáko̱xia̱n tí kjuachaxin la ko xi̱kaha xikjáko̱xia̱n ínaá. 
\p  
\v 29 A̱ ntá tí sín tjejóntaxín tsíkinhin sín mé ntáchro sín kíxin kjónta, la ko í so sín ntáchro sín kíxin: 
\p ―Ijnko chꞌín ángel nixje̱he̱ chꞌán ―ichro sín. 
\p  
\v 30 Kjánchó ntáchro chꞌín Jesús kíxin: 
\p ―Náhí. Jehya kíxin janhan tí jie chrókui̱nha̱n tí nixja chꞌán. Náhí. Nixja chꞌán kíxin tsinhínrá jahará.  
\v 31 Ntá jie tsito̱exín tí iji̱é chojni chjasintajni na mé tí nkexro tꞌe̱to̱an chjasintajni mé tsꞌaxrjehe chꞌán tí xra̱ tꞌe̱to̱an chꞌán.  
\v 32 A̱ ntá tió tsjakꞌénka̱nia ijnko ntacruz ntá nchónhya sín tsꞌikon sín ntá tsitekaon sín tí janhan ―ichro chꞌán. 
\p  
\v 33 Mé xi̱kaha chrónkaxín chꞌán kíxin nkexrí tsꞌenxín chꞌán.  
\v 34 A̱ ntá kjuáte̱he tí sín ntiha ntáchro sín kíxin: 
\p ―Kuínhinni nchekuáxin sín tí xroon tsíkjin sín ósé chrónka kíxin Cristo la jnkochríxín tsjakꞌe chꞌán. ¿Ntá nkekuènté ntáchrua kíxin tí Xje̱en Dios Kꞌóna Chojni tꞌichjánxi̱n tsjakꞌenkáni chꞌán ijnko ntacruz? ¿Xá nkexéhe tí Xje̱en Dios Kꞌóna Chojni? ―ichro sín. 
\p  
\v 35 Ntá ntáchro chꞌín Jesús kíxin: 
\p ―Na̱xa̱ tjen tí xrohi tjejókoará, kjánchó í séhya tsjakꞌe. Chrókꞌuajirá tí na̱xa̱ tjen ti xrohi tꞌinkaséyanxín nti̱a. A̱ ntá náhí la ó tsꞌixin tie. A̱ ntá tí sín ixri tí sítié a mé noehya sín nketí sátsji sín.  
\v 36 Títekáonrá tí xrohi tí na̱xa̱ tjen tꞌinkaséyan kíxin mé tsꞌónará chojni kuènte tꞌinkaséyan ―ichro chꞌán. 
\p Ntá kjuixin chrónka chꞌín Jesús tíha ntá sákjuí chꞌán kjuákꞌeméhe chꞌán tí jehe sín. 
\s1 Tí sín judío kuítekakonhya sín tí chꞌín Jesús 
\p  
\v 37 Kꞌuékjasin chꞌín Jesús nchónhya kjuaxroan jié kꞌuíkonxín kon sín ntá kjónté kuítekakuenhya sín chꞌán  
\v 38 kíxin mé xi̱kaha tsoxiteyá tí nkehe tsíntáchro chꞌín Isaías tsíkjin chꞌán ósé kíxin: 
\q1 Ìnchéni, kohya nkexro kuítekaon tí nkehe chrónkani. 
\q1 Kohya nkexro kjuínchenohe Dios tí kjuachaxin jié kuènte chꞌán.\f + \fr 12:38 \ft Isaías 53.1\f* 
\m  
\v 39 Méxra̱ kuítekakuenhya sín tí chꞌín Jesús éxí tsíkjin chꞌín Isaías kja̱xin kíxin: 
\q1  
\v 40 Dios kjuínchekꞌikonhya chꞌán sín la ko kjuínchecha chꞌán a̱sén sín, 
\q1 kíxin ntá chrókꞌuikonhya sín, 
\q1 la ko chrókienxínhya sín, 
\q1 kíxin ntá chrókóchjinehya sín tí janhan kíxin chrókjui̱ntakito̱ha̱ sín jína.\f + \fr 12:40 \ft Isaías 6.10\f* 
\v 41 Xi̱kaha kꞌuéchrónka chꞌín Isaías imá ósé kíxin kꞌuékꞌikon chꞌán tí kjuachaxin jié kuènte Jesús ntá kꞌuéchrónka chꞌán nkexrí tsjakꞌe tí chꞌín Jesús. 
\p  
\v 42 Kjánchó itsjé tí sín judío tꞌe̱to̱an kuítekaon sín tí chꞌín Jesús kjánchó noxínhya chrónka sín. Chrako̱nhe̱n sín tí sín fariseo kíxin chrókónínkaon sín la í chrókjuanjonhya sín kjuachaxin chrókꞌuixenhen sín tí ni̱nko̱e sín judío.  
\v 43 Mé xi̱kaha imá kóxrjínhi̱n sín kíxin chojni chjasintajni chrókjuikosáyehe sín ntá kánhyó kjueyá sín kíxin chrókjuikosáyehe sín Dios. 
\s1 Tí nkehe ntáchro chꞌín Jesús mé tsito̱exíxin iji̱é chojni 
\p  
\v 44 Ntá itsen nixja chꞌín Jesús ntáchro chꞌán kíxin: 
\p ―Tí títekáonrá tí janhan na mé jehya janhván títekáonrá na mé kja̱xin títekáonrá Tꞌaná, mé tí nkexro kꞌue̱tua̱nna kꞌuinka.  
\v 45 Éxí tí tꞌikonrá tí janhan mé xi̱kaha tꞌikonrá tí nkexro kꞌue̱tua̱nna kꞌuinka.  
\v 46 A̱ ntá janhan mé xrohi kꞌuinka chjasintajni kíxin tí sín titekaon sín tí janhan tsꞌejóhya sín tí sítié a.  
\v 47 A̱ ntá tí jnkojínrá tinhínrá tí nkehe xrja̱nka ntá títekákonnahyará la jehya janhan si̱ntakjasótiará kíxin jehya kíxin kꞌuinka si̱ntakjasóte chojni chjasintajni. Náhí. Kꞌuinka kíxin si̱ntakaá chojni.  
\v 48 A̱ ntá tí títekákonhyará tí janhan la ko títekákonhyará tí tan kuènta̱na la ó siín nkexrí tsito̱exíxin iji̱árá, na mé éxí tí tan xrja̱nka mé Dios sinchekito̱exín iji̱árá tí ya̱on tsjixixín chjasintajni.  
\v 49 Jehya tí nkehe kuènta̱na tjéxrja̱nka. Náhí. Tꞌaná na mé tí nkexro kꞌue̱tua̱nna kꞌuinka mé kꞌue̱tua̱nna nkehe tso̱xrja̱nka la ko nkehe tsjàkua.  
\v 50 A̱ ntá nòna kíxin tí nkehe kꞌue̱to̱an Tꞌaná mé xranjonxín tí kjuachón jnkochríxín. Mé xi̱kaha tí nkehe ntáxrja̱n mé tjéxrja̱nka kíxin Tꞌaná mé kꞌue̱tua̱nna. 
\c 13  
\s1 Chꞌín Jesús kjuínchekꞌònti chꞌán to̱té tí sín kꞌuájiko chꞌán 
\p  
\v 1 A̱ ntá tí ya̱on xi̱ka tí ntóye tsjasin sín tí kia pascua. A̱ ntá chꞌín Jesús ó nohe chꞌán kíxin ó kjuixraká tí hora tsíto̱he chꞌán chjasintajni sátsji̱chréhe̱ chꞌán Itꞌé chꞌán. Xráxín tjuèhé chꞌán tí sín kuènte chꞌán chjasintajni, a̱ ntá jie tsja̱ko̱xi̱n chꞌán kíxin imá tjuèhe chꞌán tí jehe sín. 
\p  
\v 2 A̱ ntá tí chꞌín Tsochren tsíkꞌe̱tue̱nhen a̱sén chꞌín Judas Iscariote, itꞌé mé itꞌin Simón, kíxin sinchekji chꞌán tí chꞌín Jesús.  
\v 3 Ntá chꞌín Jesús la ó nohe chꞌán kíxin tsíki̱xi̱n chꞌán tí tjen Dios la ko xikjan chꞌán sátsji̱chréhe̱ chꞌán Dios ínaá. La ko ó nohe chꞌán kíxin Itꞌé chꞌán tsíkjanjon kjuachaxin tsꞌe̱tue̱nhen chꞌán kaín xín nkehe.  
\v 4 Ntá na̱xa̱ tjejóne sín ntá kꞌuínkatjen chꞌín Jesús kuakitsje chꞌán tí ka titsáte chꞌán la kuákja chꞌán ijnko ka xámáxin chojni tꞌónti kꞌuínkatꞌóxin chꞌán.  
\v 5 Ntá kui̱ki̱a̱ chꞌán ijnko nkehe nta̱, ntá kjuankíxin chꞌán kjuínchekꞌònti chꞌán to̱té jnkojnko tí sín kꞌuájiko chꞌán la ko kjuínchexámáxin chꞌán tí ka kꞌuínkatꞌóxin chꞌán. 
\p  
\v 6 Na ntá tió kjuíjixraká tí tjen chꞌín Pedro, a̱ ntá ntáchro chꞌín Pedro kíxin: 
\p ―Jaha Ìnchéni la, ¿nkekuènté chrókjui̱nchekꞌóntia to̱téni? ―ichro chꞌán. 
\p  
\v 7 Ntá kjuáte̱he chꞌín Jesús ntáchro chꞌán kíxin: 
\p ―Jaha la na̱xa̱ tiénxinhya tí nkehe tjétꞌa̱ janhan. Chrꞌéxi̱n ntá tsiénxian nkekuènté tjétꞌa̱ tíha ―ichro chꞌán. 
\p  
\v 8 Ntá ntáchro chꞌín Pedro kíxin: 
\p ―Jaha la si̱nchekꞌóntihya to̱téni ―ichro chꞌán. 
\p Ntá ntáchro chꞌín Jesús kíxin: 
\p ―Tí si̱ntakꞌóntihya tí jaha la kjá ninkehó tsochontahya tí janhan ―ichro chꞌán. 
\p  
\v 9 Ntá kjuáte̱he chꞌín Simón Pedro ntáchro chꞌán kíxin: 
\p ―Náhí, Ìnchéni. Jehya tí to̱téni ó chrókjui̱nchekꞌóntia. Kja̱xin itjani la ko ikjani chrókjui̱nchekꞌóntia ―ichro chꞌán. 
\p  
\v 10 Ntá ntáchro chꞌín Jesús ínaá kíxin: 
\p ―Tí sín tsíkjixin tsíkꞌónti la tꞌichjánxi̱nhya kuenté sín tsꞌónti sín ínaá. Náhí. Jehó to̱té sín ó mé tꞌichjánxi̱n na̱xa̱ tsꞌónti kíxin kuenté la ó tjóá. A̱ ntá jahará la ó tjóárá, kjónté kénhyará ―ichro chꞌán. 
\p  
\v 11 Mé xi̱kaha ntáchro chꞌín Jesús kíxin kénhya sín tjóá sín kíxin ó nohe chꞌán nkexro sinchekji chꞌán. 
\p  
\v 12 Ntá tió kjuixin kjuínchekꞌónti chꞌán to̱té sín kaín sín ntá xíkꞌinkáya chꞌán ínaá tí ka kuítsáte chꞌán ntá kjuákꞌetja̱xi̱n chꞌán tí kꞌuínkatje̱nxi̱n chꞌán. Ntá ntáchro chꞌán kíxin: 
\p ―¿Á kiénxinrá tí nkehe kjui̱tꞌa?  
\v 13 Jahará la ntáchrorá kíxin janhan Maestro kuèntárá la ko Ìnchárá. Chaxín ntoá ntáchrorá kíxin janhan tíha.  
\v 14 Janhan tí Maestro kuèntárá la ko ìnchárá kjui̱ntakꞌóntia to̱tárá. A̱ ntá jahará kja̱xin xi̱kaha chrókjui̱nchekꞌóntirá to̱té kíchuárá.  
\v 15 Janhan mé kjuáko̱xia̱n kíxin xi̱kaha chrókjui̱chꞌerá éxí kjui̱tꞌa janhan.  
\v 16 Ijnko nkehe chaxín tso̱tjo̱nka̱rá kíxin tí sín chꞌexón xra̱ mé tꞌe̱to̱anhya sín éxí tꞌe̱to̱an tí lámo̱e sín, la ko tí sín kꞌuáyéhe̱ sín ijnko xra̱ tꞌe̱to̱anhya sín éxí tꞌe̱to̱an tí sín kjuanjon tí xra̱ a.  
\v 17 Tí chrókiénxinrá nkehe tíha la ko chrókjui̱nchexiteyárá la chrókócháhará má. 
\p  
\v 18 ’Jehya kaín rá xi̱kaha ntáxrja̱n. Ó nòna kíxin nkexro kjuéyá janhan. Kjánchó tꞌichjánxi̱n tsoxiteyá tí nkehe tsíkjin sín ósé ntáchro kíxin: “Ijnko nkexro tjéne̱kian mé tsjanjo̱nkian.”\f + \fr 13:18 \ft Salmo 41.9\f* 
\v 19 Mé xi̱kaha tjétjo̱nka̱rá senó kíxin tió tsꞌatsínka tíha ntá tsítekáonrá kíxin janhan mé tí nkexro xráxín tjen.  
\v 20 Ijnko nkehe tjetoan tjétjo̱nka̱rá kíxin tí tsjánjonrá kjuachaxin tsito̱he tí chojni ichrꞌan janhan, mé éxí yóhe̱ chrókjuánjonrá kjuachaxin chrókuito̱he tí janhan, a̱ ntá tí tsjánjonrá kjuachaxin tsito̱na janhan mé éxí yóhe̱ chrókjuánjonrá kjuachaxin chrókuito̱he tí nkexro kꞌue̱tua̱nna kꞌuinka ―ichro chꞌín Jesús. 
\s1 Chꞌín Jesús chrónka kíxin chꞌín Judas sinchekji chꞌán 
\r (Mt. 26.20-25; Mr. 14.17-21; Lc. 22.21-23) 
\p  
\v 21 Ntá kjuixin chrónka chꞌín Jesús tíha, ntá kóxakonhen a̱sén chꞌán má ntá ntoá chrónka chꞌán kíxin: 
\p ―Ijnko nkehe tjetoan tso̱tjo̱nka̱rá kíxin jnkojínrá tjejorá ntihi mé si̱nchekjiráni ―ichro chꞌán. 
\p  
\v 22 Ntá tí sín kꞌuájiko chꞌán kjuanjíxin komáxin la ko í komáxin kíchó sín kíxin noehya sín nkexro tí ntáchro chꞌán.  
\v 23 A̱ ntá ijnko chꞌín kꞌuájiko chꞌín Jesús imá tjuèhe chꞌán itjen chꞌán chjinaxón tí tjen chꞌín Jesús tjejóne sín.  
\v 24 Ntá chꞌín Simón Pedro kjua̱ko̱exín seña kꞌue̱tue̱nhen chꞌán tí í jnko chꞌín a kíxin: 
\p ―Tjanchankíhí chꞌán nkexro tíha ―ichro chꞌán. 
\p  
\v 25 A̱ ntá tí chꞌín a na mé a̱ntsí kóchjinehe chꞌán tí chꞌín Jesús, ntá kjuanchankí chꞌán ntáchro chꞌán kíxin: 
\p ―Ìnchéni, ¿nkexro tíha? ―ichro chꞌán. 
\p  
\v 26 A̱ ntá kjuáte̱he chꞌín Jesús ntáche chꞌán tí chꞌín a kíxin: 
\p ―Si̱ntakjata itꞌo̱ nio̱tja̱, a̱ ntá tí nkexro tso̱tja̱ha̱ tí tꞌo̱ nio̱tja̱ a mé tí nkexro a ―ichro chꞌán. 
\p A̱ ntá mé xi̱kaha kjuínchekjata chꞌín Jesús itꞌo̱ nio̱tja̱ ntá chjéhe chꞌán tí chꞌín Judas Iscariote, itꞌé chꞌán mé itꞌin Simón.  
\v 27 Ntá kꞌuáyéhe̱ chꞌán tí nio̱tja̱ ntá tuénxín kꞌuíxenhen a̱sén chꞌán tí chꞌín Tsochren. Ntá ntáche chꞌín Jesús tí jehe chꞌán kíxin: 
\p ―Tí xra̱ tjinkávan si̱chꞌe la jaí tóxakonhan ―ichro chꞌán. 
\p  
\v 28 Kjánchó nijnko tí sín tjejóne ntiha kienxínhya sín nkekuènté xi̱kaha ntáchro chꞌán.  
\v 29 Chꞌín Judas la tꞌayakonhen chꞌán tí nkehe tjinká chichaon ntá iso sín kjuenka̱yáxin sín kíxin áchꞌe chꞌín Jesús mé kꞌue̱tue̱nhen chꞌán tí chꞌín Judas kíxin ichrén nkehe sátsjikꞌe̱na chꞌán kuènte tí kia a, o̱ áchꞌe ichrén nkehe sincheki̱to̱nhe̱n chꞌán tí sín nòa a.  
\v 30 Ntá kꞌuáyéhe̱ chꞌín Judas tí nio̱tja̱, a̱ ntá kꞌuaxrjexín chꞌán ntiha. A̱ ntá ó kꞌuíxin tie. 
\s1 Ijnko nkehe ni̱xin kꞌue̱to̱an chꞌín Jesús 
\p  
\v 31 A̱ ntá ó kjuixin sátsíkji chꞌín Judas, ntá ntáchro chꞌín Jesús kíxin: 
\p ―A̱ ntá jie tso̱noxín tí kjuachaxin jié kuènte tí Xje̱en Dios Kꞌóna Chojni la ko tsja̱ko̱xi̱n chꞌán tí kjuachaxin jié kuènte Dios.  
\v 32 Na mé xi̱kaha tí Xje̱en Dios Kꞌóna Chojni mé tsja̱ko̱xi̱n tí kjuachaxin jié kuènte Dios. A̱ ntá Dios mé tsja̱ko̱xi̱n chꞌán tí kjuachaxin kuènte Xje̱en chꞌán la tjoka tsoxiteyá.  
\v 33 Xje̱enni, í séhya na̱xa̱ tsjakꞌé janhan tsꞌejókoará ntihi. Ntá jahará mé tsꞌajikjéyárá tí janhan. Ntá éxí yóhe̱ kꞌuétja̱nka tí sín judío mé tjo̱nka̱rá kja̱xinrá kíxin: Ninkexró xitjahya tsjiji sín tí sátsjiyá janhan.\f + \fr 13:33 \ft Juan 7.33\f* 
\v 34 Ijnko nkehe ni̱xin tétua̱nhanrá ijie kíxin chrótjuèhérá kíchuárá éxí yóhe̱ tjua̱hará mé xi̱kaha chrótjuèhérá kíchuárá.  
\v 35 Tí tsotjuèhérá kíchuárá ntá tso̱noexín kaín xín chojni siín chjasintajni kíxin tinkachónkirá tí janhan ―ichro chꞌán. 
\s1 Chrónka chꞌín Jesús kíxin chꞌín Pedro sinchemá chꞌán kíxin chónhya chꞌán tí jehe chꞌán 
\r (Mt. 26.31-35; Mr. 14.27-31; Lc. 22.31-34) 
\p  
\v 36 Ntá kjuanchankíhi chꞌín Simón Pedro tí chꞌín Jesús kíxin: 
\p ―Ìnchéni, ¿nketí sátsjia? ―ichro chꞌán. 
\p Ntá kjuáte̱he chꞌín Jesús ntáchro chꞌán kíxin: 
\p ―Tí nó sátsjiyá xitjahya tsochréhérá jaí. Ntá chrꞌéxi̱n tsjasánchréhérá ntiha ―ichro chꞌán. 
\p  
\v 37 A̱ ntá ntáchro chꞌín Pedro kíxin: 
\p ―¿Nkekuènté xitjahya tsochráha̱ tí jaha jaí? Kjónté chrókꞌuényákonhán ―ichro chꞌán. 
\p  
\v 38 Ntá kjuáte̱he chꞌín Jesús ntáchro chꞌán kíxin: 
\p ―¿Á chaxín tsꞌenyákònna jaha? Ijnko nkehe chaxín tso̱tjo̱nka kíxin na̱xa̱ tsotsjehya tí kochínto̱a la ó tsjixin si̱nchemána níya kíxin chonhyana, tsixrua.﻿ 
\c 14  
\s1 Jesús mé nti̱a sátsji̱xinni tí tjen Itꞌéni tjen nkaya nka̱jní 
\p  
\v 1 ’Tóxakuanhyará jahará. Títekáonrá Dios la ko kja̱xin títekáonrá tí janhan.  
\v 2 Nto̱e Tꞌaná nchónhya nchia siín tsꞌejóni. A̱ ntá tí xi̱kahya chrókꞌuixin la xi̱kahya chrótjo̱nka̱rá. Méxra̱ sátsjiyá si̱ntayóxian tí chrókꞌuejóni.  
\v 3 A̱ ntá tí sátsjiyá si̱ntayóxian, ntá tió tsjixin ntá tsꞌinka ínaá, ntá sátsji̱ni kíxin jahará kja̱xin chrókꞌuejorá ntiha tí tsjakꞌé janhan.  
\v 4 Jahará la ó nohará nketí sátsjiyá la ko ó nohará tí nti̱a a ―ichro chꞌán. 
\p  
\v 5 Ntá kjuáte̱he chꞌín Tomás ntáchro chꞌán kíxin: 
\p ―Ìnchéni, noehyani nketí sátsjia jaha. ¿A̱ ntá nkexrí chrókónoheni tí nti̱a a? ―ichro chꞌán. 
\p  
\v 6 Ntá kjuáte̱he chꞌín Jesús ntáchro chꞌán kíxin: 
\p ―Janhan mé tí nti̱a la ko janhan mé tí tan chaxín la ko janhan mé tsjánjuan tí kjuachón. Jehó tí nkexro tsitekaon tí janhan mé jína tsjiji tí tjen Tꞌaná.  
\v 7 Tí chrókjuátso̱anrá tí janhan ntá xi̱kaha chrókjuátso̱anrá Tꞌaná kja̱xin. Na ntá ó choxínrá chꞌán jie la ko ó tjejókomárá chꞌán ―ichro chꞌán. 
\p  
\v 8 Ntá ntáchro chꞌín Felipe kíxin: 
\p ―Ìnchéni, ti̱to̱héni kíxin tsochóxinni Itꞌá. Táhó mé tjinkaonni ―ichro chꞌán. 
\p  
\v 9 Ntá kjuáte̱he chꞌín Jesús ntáchro chꞌán kíxin: 
\p ―Felipe, ósé tjejóni, ¿a̱ ntá na̱xa̱ tjátso̱anhya tí janhan ní? A̱ ntá xi̱kaha tí tꞌikonrá tí janhan na mé xi̱kaha chrókꞌuíkonrá Tꞌaná. ¿Nkekuènté tjanchàna kíxin chrókui̱to̱ha̱ chrókꞌuikonrá tí Tꞌaná?  
\v 10 ¿Á títekákonhya jaha kíxin janhan jnkoko̱á tjéki̱an Tꞌaná, la ko Tꞌaná tjen tí tjén janhan? Tí nkehe níxja janhan la jehya kuènta̱na. Náhí. Tꞌaná tjéki̱an janhan mé tjechꞌe chꞌán tí xra̱ kuènte chꞌán.  
\v 11 Títekáonrá kíxin jnkoko̱a tjéki̱an Tꞌáná, a̱ ntá Tꞌaná itjen tí tjén janhan. Kjónté kuítekákonhyará xi̱kaha la chrókuítekáonrá kíxin tí kjuaxroan jié kjuáko̱xia̱n kꞌuíkonrá.  
\v 12 Ijnko nkehe chaxín tjo̱nka̱rá kíxin tí chaxín tsítekáonrá tí janhan ntá kja̱xinrá tsjachará si̱chꞌerá xra̱ yóhe̱ tjétꞌa̱ la ko kja̱xin ixra̱ a̱ntsí jié tsjachará si̱chꞌerá kíxin janhan la ó sátsjiyá tí tjen Tꞌaná.  
\v 13 Kaín nkehe tsjanchatóxixínrá tí ni̱na na mé tsjánjuan kíxin xi̱kaha tsjáko̱xia̱n tí kjuachaxin kuènte Tꞌaná.  
\v 14 Tí chrén nkehe tsjanchatóxixínrá ni̱na la janhan la tsjánjuan. 
\s1 Chꞌín Jesús chrónka chꞌán kíxin chaxín tsochrꞌán chꞌán tí Ncha̱kuen Dios 
\p  
\v 15 ’Tí chaxín tjuèhérá tí janhan ntá chrókjui̱nchexiteyéhérá tí nkehe kuétua̱nhanrá.  
\v 16 Ntá tsoxrja̱nnóa̱ha̱ Tꞌaná kíxin tsochrꞌán chꞌán Ncha̱kuen chꞌán kíxin tsjinki̱tsa tí jahará la ko sinchechéhe̱ a̱sánrá la mé tsꞌejokoará jnkochríxín.  
\v 17 Jehe chꞌán mé Ncha̱kuen chaxín. Tí sín chjasintajni xitjahya tsꞌáyéhe̱ sín chꞌán kíxin tꞌikonhya sín chꞌán la ko chónhya sín chꞌán. Kjánchó jahará ó choxínrá chꞌán kíxin tjejokoará chꞌán la ko tsꞌejokoará chꞌán jnkochríxín.  
\v 18 Janhan na tsi̱to̱áhyará nòerá jahórá, na mé tsokjan ínaá kíxin tsꞌejóni.  
\v 19 A̱ ntá séhya ntá tí sín chjasintajni tsꞌikonhya sin tí janhan ínaá. Kjánchó jahará mé tsꞌikonrá tí janhan. Ntá kja̱xinrá tsꞌejochónrá kíxin janhan na tjéchua̱n.  
\v 20 A̱ ntá tí ya̱on a chrókónohará kíxin Tꞌaná la ko janhan jnkoko̱á tjéki̱an la ko kja̱xin jahará la ko janhan jnkoko̱á tjejóni.  
\v 21 Tí nkexro nohe tí nkehe této̱an la ko sinchexiteyéhe̱ sín mé xi̱kaha tsja̱ko̱xi̱n sín kíxin chaxín tjuèhe sín tí janhan. A̱ ntá tí tjuèhe sín tí janhan ntá Tꞌaná mé tsotjuèhe tí jehe sín la ko kja̱xin janhan tsotjua̱ha̱ sín la ko tsjáko̱xia̱n nkexrí tjén janhan ―ichro chꞌín Jesús. 
\p  
\v 22 A̱ ntá tí chꞌín Judas, jehya tí chꞌín Iscariote tíha, na mé kjuanchankí chꞌán kíxin: 
\p ―Ìnchéni, ¿nkekuènté jehóni tjákoxian, a̱ ntá tjáko̱éxinhya tí chojni chjasintajni? ―ichro chꞌán. 
\p  
\v 23 Ntá kjuáte̱he chꞌín Jesús ntáchro chꞌán kíxin: 
\p ―Tí nkexro tjuèhe tí janhan mé sinchexiteyéhe̱ tí nkehe této̱an. La ko Tꞌaná mé tsotjuèhe tí jehe sín la ntá Tꞌaná la ko janhan tsꞌejókoni sín.  
\v 24 A̱ ntá tí sín tjuèhya tí janhan la mé nchexiteyèhya sín tí nkehe tjàkua. A̱ ntá tí nkehe tjàkua tjejotinhínrá la jehya kuènta̱na. Náhí. Kuènte Tꞌaná tí nkexro kꞌue̱tua̱nna kꞌuinka. 
\p  
\v 25 ’Na̱xa̱ tjejóni la tjétjo̱nka̱rá kaín tíhi.  
\v 26 A̱ ntá Ncha̱kuen Tꞌaná tsochrꞌán chꞌán kjuachaxin ni̱na mé tsjinki̱tsa tí jahará la ko sinchechéhe̱ a̱sánrá la ko tsja̱ko̱hará kaín nkehe la ko sinchexraxinkaonrá kaín nkehe xrja̱nka. 
\p  
\v 27 ’Kjuaxróxin tsi̱to̱ha̱ la ko kjuaxróxin kuènta̱na tso̱tja̱hárá. Jehya éxí tí kjuaxróxin chrókjuanjon tí sín chjasintajni. Náhí. Chrókóxakuenhya a̱sánrá la ko chróchrakonhyará.  
\v 28 Ó kuínhínrá ntáxrja̱n kíxin sátsjiyá la ko tsokjan janhan tsꞌejóni ínaá. Tí chaxín tjuèhérá tí janhan ntá chrókócháhará tí kuínhínrá kíxin sátsjiyá tí tjen Tꞌaná kíxin a̱ntsí tꞌe̱to̱an chꞌán la kánhyó této̱an janhan.  
\v 29 Senó tjétjo̱nka̱rá tíhi kíxin tió tso̱nhen tíha la tsꞌikonrá ntá tsítekáonrá jahará. 
\p  
\v 30 ’Ntá jie la í séhya tsonixja̱hará kíxin tí jie itsi tí chꞌín Tsochren, mé tí nkexro tꞌe̱tue̱nhen tí sín chjasintajni. A̱ ntá jehe chꞌán la ninkehó tꞌe̱tua̱nnahya tí janhan.  
\v 31 Kjánchó tꞌichjánxi̱n kíxin xi̱kaha tso̱nhen ntá tí sín chjasintajni mé tso̱nohe sín kíxin tjua̱ha̱ Tꞌaná la ko nchexiteyáha̱ tí nkehe kꞌue̱tua̱nna chꞌán. Ntá jie tꞌinkatjenrá sátsjixínni ntihi. 
\c 15  
\s1 Tí nta tꞌóna to uva la ko tí chaan nta 
\p  
\v 1 ’Janhan mé éxí yóhe̱ ijnko ntanòa tjechón itsa to uva la ko Tꞌaná mé éxí yóhe̱ tí nkexro tꞌayakonhen tí nta a.  
\v 2 Tsochrínjin chꞌán tí chaan nta tꞌónahya to. A̱ ntá tí chaan nta tꞌóna to mé nchetjuákꞌá chꞌán kíxin ntá tsꞌóna a̱ntsí má tsjé to.  
\v 3 A̱ ntá jahará la kótjuáxinrá tí tanná kꞌuétjo̱nka̱rá senó.  
\v 4 Tí tsi̱to̱éhyará tí janhan ntá kja̱xin janhan tsi̱to̱a̱hya tí jahará. Mé xi̱kaha ijnko chaan nta tsꞌaxrjentehe tsjachahya jehó tsꞌóna to, la ko xi̱kaha jahórá tsjachahyará si̱chꞌerá tí xra̱ kuènta̱na tí tsi̱to̱hérá tí janhan. 
\p  
\v 5 ’Janhan na mé yóhe̱ tí ntanòa, a̱ ntá jahará la tí chaan tí ntanòa tsíkꞌayanta. Tí nkexro jnkoko̱á tjenka̱yáxinkian mé tsjacha tsꞌóna nchónhya to. A̱ ntá tí tsinkáchónkihya sín tí janhan la ninkehó xra̱ tsjachahya sín sichꞌe sín.  
\v 6 A̱ ntá tí nkexro jnkoko̱áhya tjenka̱yáxinkian na mé éxí yóhe̱ tí nta chꞌehya xra̱ tsíkóchrínjin sín tsíkꞌitjí sín chrínta tí nonte a tso̱xámá ntá tsoxrejo ntá tsoche. 
\p  
\v 7 ’Ntá tí chaxín tsi̱to̱éhyará tsinkachónkirá tí janhan la ko tsꞌitjáyanhyará tí nkehe kjuákohará ntá tsjanchiará ichrén nkehe tjinkáonrá la tsꞌayéhérá.  
\v 8 A̱ ntá Tꞌaná la tso̱chéhe̱ chꞌán tí tsꞌónará itsjé to. Mé xi̱kaha tsjáko̱xi̱nrá kíxin tinkachónkirá tí janhan.  
\v 9 Janhan tjua̱hará tí jahará éxí tjua̱na Tꞌaná. Chrókónohará kíxin tjua̱hará.  
\v 10 Tí tsítekáonrá tí nkehe kuétua̱nhanrá ntá tso̱nohará kíxin tjua̱hará éxí yóhe̱ kja̱xin janhan nta̱xiteyá tí nkehe kꞌue̱tua̱nna Tꞌaná ntá kónòna janhan kíxin tjua̱na chꞌán. 
\p  
\v 11 ’Mé xi̱kaha tjo̱nka̱rá kaín tíha kíxin ntá éxí chàna mé xi̱kaha tsjintaxín tso̱chéhe̱ a̱sánrá.  
\v 12 Tí nkehe kuétua̱nhanrá la mé tíhi kíxin chrótjuèhérá kíchuárá éxí tjua̱hará xi̱kaha.  
\v 13 Ninkexró chrókóyóhe̱ éxí tí nkexro imá tjuèhe tí sín chóxin chꞌán ntá tsꞌenyákonhe̱n chꞌán tí jehe sín.  
\v 14 Jahará la chojni choxian tí tsítekáonrá tí nkehe tétua̱nhanrá.  
\v 15 Ntáxrja̱nhya janhan kíxin jahará chojni chꞌexón xra̱ kíxin tí chojni xi̱kaha chꞌexón xra̱ mé noehya sín nkehe tí xra̱ chꞌe tí lámo̱e sín a. Náhí. A̱ ntá jahará la chojni choxian kíxin kaín xín nkehe kjua̱ko̱na Tꞌaná mé kjuákohárá.  
\v 16 Jehya kíxin jahará kjuéyárá tí janhan. Náhí. Janhan mé kjuéyá tí jahará kíxin tsotja̱hárá xra̱, a̱ ntá éxí yóhe̱ to xé mé chrókꞌuaxrje jína tí xra̱ si̱chꞌenará kíxin chrókꞌuitjáyanhya. A̱ ntá Tꞌaná mé tsotjáhará chꞌán kaín xín nkehe tsjanchexínrá ni̱na.  
\v 17 Mé xi̱kaha tétua̱nhanrá kíxin tsotjuèhérá kíchuárá. 
\s1 Tí sín chjasintajni nínkakonhen sín tí chꞌín Jesús la ko tí sín tinkáchónki chꞌán 
\p  
\v 18 ’Tí tso̱nínkakonhanrá tí chojni chjasintajni ntá chrókónohará kíxin senó janhan nínkakonna sín.  
\v 19 Tí chrókókuèntárá chjasintajni ntá tí sín chjasintajni chrótjuàhárá sín kíxin na̱xa̱ kjéhyará sín. Kjánchó janhan kjuéyá tí jahará kíxin chrókꞌuaxrjékjanxínrá tí sín siín chjasintajni. A̱ ntá tí sín chjasintajni nínkakonhanrá sín kíxin jahará jahyará kuèntárá chjasintajni.  
\v 20 Xráxinkáonrá tí nkehe tsítjo̱nka̱rá kíxin tí sín chꞌehe lámo̱e sín xra̱ tjetóxinhya tsꞌe̱to̱an sín.\f + \fr 15:20 \ft Juan 13.16\f* Éxí yóhe̱ chónkìna sín mé xi̱kaha tsochónkíhi sín tí jahará. A̱ ntá tí kuítekaon sín tí nkehe kjuáko̱ha̱ sín ntá kja̱xin tsitekaon sín tí nkehe na̱xa̱ tsjákohérá sín.  
\v 21 Mé xi̱kaha sitꞌahará sín kíxin jahará tinkachónkirá tí janhan la ko jehe sín chónhya sín tí nkexro ichrꞌánna kꞌuinka ntihi. 
\p  
\v 22 ’Tí chrókꞌuinkahya janhan ntihi chrónixja̱hya sín ntá chrókuamáhya sín jie̱. Ntá jié kohya nkerí tsaáxin sín kíxin tí jie̱ tinkákjasin sín.  
\v 23 Tí sín nínkakonna mé xi̱kaha nínkakonhen sín Tꞌaná.  
\v 24 Chróchóntahya sín jie̱ tí chrókꞌuejókianhya sín ntihi chrókjuásinhya janhan kjuaxroan jié éxí tsíkjasinhya ninkexró senó. Ntá jie ó kꞌuíkon sín kaín tí kjuaxroan, a̱ ntá kjónté nínkakonna sín tí janhan la ko nínkakonhen sín Tꞌaná kja̱xin.  
\v 25 Mé xi̱kaha tso̱nhen kaín tíha kíxin ntá tsoxiteyá tí nkehe ntáchro tí ley kuènte sín kíxin: “Kohya jie̱ kjuásian janhan ntá kjónté kónínkakonna sín.”\f + \fr 15:25 \ft Salmo 35.19; 69.4\f* 
\v 26 A̱ ntá tsi tí nkexro tsjinki̱tsa la ko sinchechéhe̱ a̱sánrá. Tíha mé tí Ncha̱kuen Dios chaxín. Janhan mé tsochrꞌan chꞌán kíxin tí kjuachaxin kuènte Tꞌaná. A̱ ntá jehe chꞌán mé tsochrónka nkexrí tjén janhan  
\v 27 la ko jahará kja̱xinrá tso̱chro̱nka̱rá nkexrí tjén janhan kíxin tí xrankíxixín la kꞌuéjóni jnkoko̱á.﻿ 
\c 16  
\p  
\v 1 ’Kaín tíhi tjétjo̱nka̱rá kíxin chrókui̱to̱éhyará tí nkehe kjuákohárá.  
\v 2 Tí sín judío tsjanjonhya sín kjuachaxin tsꞌixe̱nhenrá ni̱nko̱é sín la ko tsjixraká tí ya̱on kíxin tí sín tsꞌóyán sín tí jahará tsontáchro sín kíxin xi̱kaha mé tjejóchꞌe sín xra̱ kuènte Dios, tsixro sín.  
\v 3 Mé xi̱kaha sichꞌe sín kíxin chónhya sín Tꞌaná la ko chónhyana sín.  
\v 4 A̱ ntá tjo̱nka̱rá kaín tíhi kíxin tió tsjixraká tí ya̱on xi̱kaha tso̱nhen ntá tsoxráxinkáonrá kíxin ó kꞌuétjo̱nka̱rá senó a. 
\s1 Tí xra̱ chꞌe Ncha̱kuen Dios 
\p ’Tí xrankíxixín kꞌuétjo̱nka̱hyará tíhi kíxin jnkoko̱á kꞌuékꞌejóni.  
\v 5 Ntá jie sátsjiyá tí tjen tí nkexro ichrꞌánna kꞌuinka. Kjánchó nijnkorá tjanchankíhyará nketí sátsjiyá.  
\v 6 Ntá kjuixin tjo̱nka̱rá tíha ntá imá tꞌavárá kíxin kuínhínrá xi̱kaha xrja̱nka.  
\v 7 A̱ ntá chaxín tí nkehe tjétjo̱nka̱rá kíxin íchá jína sátsjiyá kíxin jahará jína chrókꞌuejorá. A̱ ntá tí sáchrókjuíhya ntá chrókuihya tí nkexro tsjinki̱tsará. A̱ ntá tí sátsjiyá janhan ntá tséto̱an kíxin itsi chꞌán ntihi.  
\v 8 A̱ ntá tió tsi chꞌán mé sinchexraxinkaon chꞌán tí chojni chjasintajni kíxin jehe sín mé tjasin sín jie̱, la ko itjen ijnko nti̱a ntoá chrókuakja sín la ko Dios mé sinchekito̱exín tí jie̱ kjuasin sín.  
\v 9 Xi̱kaha chónta sín jie̱ kíxin tinkáchónkihya sín tí janhan.  
\v 10 A̱ ntá tso̱nohe sín kíxin itjen tí nti̱a ntoá kíxin sátsjiyá tí tjen Tꞌaná ntá tsꞌikonhyará tí janhan ínaá,  
\v 11 la ko tso̱nohe sín kíxin Dios sinchekito̱exín ijie̱ kíxin ó kjuixin kuíto̱exín iji̱é tí nkexro tꞌe̱to̱an chjasintajni kíxin tsjasóte. 
\p  
\v 12 ’Na̱xa̱ chonta janhan itsjé nkehe chrótjo̱nka̱rá, kjánchó chrókjuachahyará chrókiénxinrá jie.  
\v 13 A̱ ntá tió tsi tí Ncha̱kuen Dios chaxín ntoá ntá jehe tí Ncha̱kuen Dios mé tsja̱ko̱hará chꞌán kaín xín nkehe ntoá. Méxra̱ jehya tí nkehe kuènte chꞌán tsochrónka chꞌán na mé tí nkehe tsinhin chꞌán mé tsochrónka chꞌán tsja̱ko̱hará chꞌán tí nkehe tso̱nhen chrꞌéxi̱n.  
\v 14 Jehe chꞌán mé tsjikosàyana chꞌán kíxin tsꞌáyéhe̱ chꞌán tí nkehe kuènta̱na ntá tsja̱ko̱hará chꞌán nkehe tíha.  
\v 15 Kaínxín nkehe chónta Tꞌaná na mé kuènta̱na. Mé xi̱kaha ntáxrja̱n kíxin tí Ncha̱kuen Dios chaxín ntoá mé tsꞌáyéhe̱ chꞌán tí nkehe kuènta̱na ntá tsja̱ko̱hará chꞌán nkehe tíha. 
\s1 Senó tsꞌává sín ntá chrꞌéxi̱n tso̱chéhe̱ sín 
\p  
\v 16 ’Ntá í séhya la í tsꞌikonhyará tí janhan. La ko kja̱xin séhya xikꞌikonrá tí janhan ínaá kíxin sátsjiyá tí tjen Tꞌaná ―ichro chꞌán. 
\p  
\v 17 Ntá iso tí sín kꞌuájiko chꞌán mé kjuanchankíhi sín kíchó sín kíxin: 
\p ―¿Nkexrí tꞌaxrjexín tí nkehe ntáchro chꞌán kíxin í séhya tsꞌikonhyani chꞌán la ko kja̱xin séhya ntá xikꞌikonni chꞌán ínaá kíxin sátsji̱ chꞌán tí tjen Itꞌé chꞌán?  
\v 18 ¿Nkexrí tꞌaxrjexín tí ntáchro chꞌán kíxin “í séhya”? Méxra̱ tienxínhya nkehe tí ntáchro chꞌán ―ichro sín. 
\p  
\v 19 Ntá kónohe chꞌín Jesús tí nkehe chrókjuanchankíhi sín chꞌán ntá ntáche chꞌán sín kíxin: 
\p ―Xi̱kaha tjo̱nka̱rá kíxin í séhya tsꞌikonhyará tí janhan la ko kja̱xin séhya xikꞌikonrá tí janhan ínaá. ¿Á tíha mé tjejotjanchankíhírá kíchuárá ní?  
\v 20 Tjétjo̱nka̱rá ijnko nkehe chaxín kíxin imá tsotsja̱nkará la ko tsꞌavárá. A̱ ntá tí chojni chjasintajni la tso̱chéhe̱ sín. A̱ ntá jahará tsꞌavárá la ko si̱ntaníhará kjónté chrꞌéxi̱n tso̱cháhará má.  
\v 21 Éxí yóhe̱ ijnko tjan sinchekokjíhi tjan xje̱en tjan mé imá tóxakonhen tjan kíxin ó kjuixraká tsjoté tjan. A̱ ntá tsjixin tsokjíhi xjan ntá í xraxinkakonhya tjan nkexrí kjoté tjan kíxin chéhe̱ tjan kokjíhi ijnko xjan ntihi chjasintajni.  
\v 22 Mé xi̱kaha jahará ijie tꞌavárá. Ntá xikꞌíkua̱n tí jahará ínaá ntá imá tso̱chéhe̱ a̱sánrá la ko tso̱kohya ninkexró tsakitsajahará tí kjuachéhe̱ tsochontará. 
\p  
\v 23 ’Tió tsi tí ya̱on a ntá tsjanchankínahyará ninkehó. Chaxín tí nkehe tjétjo̱nka̱rá kíxin Tꞌaná tsotjáhará chꞌán kaín nkehe tsjanchatóxixínrá ni̱na.  
\v 24 Na̱xa̱ kjuánchatóxixínhyará ninkehó tí ni̱na. Ntá jie tjanchiará la tsꞌayéhérá, a̱ ntá tsjintaxín tso̱cháhará. 
\s1 Ìnchéni Jesucristo mé kjuacha chꞌán kꞌue̱to̱an chꞌán, ntá chjasintajni la náhí 
\p  
\v 25 ’Tí nkehe tjétjo̱nka̱rá mé kjui̱ntayóa̱xián ó. Ntá tsjixraká tí ya̱on la í ninkehó si̱ntayóa̱xián na mé ntoá tso̱tjo̱nka̱rá nkexrí tjen Tꞌaná.  
\v 26 A̱ ntá tí ya̱on a mé tsjanchaxínrá nkehe ni̱na. Ntá ntáxrja̱nhya tíhi kíxin tsonixja̱yákonhanrá tí tjen Tꞌaná  
\v 27 kíxin jehe Tꞌaná mé tjuahará jahará. Na mé tjuahará chꞌán kíxin jahará tjua̱nará tí janhan la ko kíxin kuítekáonrá kíxin janhan kꞌuinkaxian tí tjen Dios.  
\v 28 Kꞌuaxrjéxian tí tjen Tꞌaná kꞌuinka chjasintajni. Ntá jie la ó tsi̱to̱ha̱ chjasintajni ntá sátsjiyá ínaá tí tjen Tꞌaná ―ichro chꞌán. 
\p  
\v 29 Ntá ntáchro tí sín kꞌuájiko chꞌán a kíxin: 
\p ―Ntá jie ntoá tjéchro̱nka ninkehó ncheyoéxinhya.  
\v 30 Ntá jie tienxínni kíxin jaha mé noha kaín xín nkehe la ko tꞌichjánxi̱nhya kíxin jnkojín nkexro chrókjuanchankíha sín ichrén nkehe. Méxra̱ xi̱kaha titekaonni kíxin jaha mé kꞌuinkaxian tí tjen Dios ―ichro sín. 
\p  
\v 31 Ntá kjuáte̱he chꞌín Jesús ntáchro chꞌán kíxin: 
\p ―¿Á jie kuítekáonrá ní?  
\v 32 Ntá tsi tí ya̱on na mé jie tíha na ntá tsochrakonrá jnkojnkorá tsoxíkará sátsjirá ntá tsi̱to̱nará janhván tsjakꞌé. Kjánchó jehya janhván tjén. Tꞌaná mé tjéki̱an.  
\v 33 Tjétjo̱nka̱rá kaín tíhi kíxin ntá kjuaxróxin tsꞌejó a̱sánrá tinkachónkirá tí janhan. A̱ ntá ntihi chjasintajni kjónté kjuaxróxinhya tjejorá tjejotjasóterá kjánchó chrakonhyará kíxin janhan mé ó kjuixin kjuacha tséto̱an. A ntá tí chjasintajni la kjuachahya tsꞌe̱to̱an ―ichro chꞌán.﻿ 
\c 17  
\s1 Chꞌín Jesús chrónóe̱he̱ chꞌán Itꞌé chꞌán kíxin chrókꞌuayakonhen tí sín kꞌuájiko chꞌán 
\p  
\v 1 Ntá ó kjuixin chrónka chꞌín Jesús kaín tíha ntá konta chꞌán nka̱jní ntáchro chꞌán kíxin: 
\p ―Jaha Itꞌéni, ó kjuixraká tí ya̱on a. A̱ ntá jie chróchje̱hé tí Xja̱an a̱ntsí má kjuachaxin kíxin kja̱xin tí Xja̱an chrókjuikosáyehe tí jaha.  
\v 2 Jaha tsíchje̱hé kjuachaxin tí Xja̱an kíxin tsꞌe̱tue̱nhen chꞌán kaín xín chojni na ntá jehe chꞌán tsochjéhe kjuachón jnkochríxín kaín tí sín tsíchje̱hé chꞌán.  
\v 3 Tí kjuachón jnkochríxín mé tꞌaxrjexín kíxin tsochóxian sín tí jaha tí jnkoko̱á Dios chaxín tjechón la ko kja̱xin tsochóxin sín Jesucristo la mé jaha kuétue̱nhén chꞌán kui chꞌán ntihi chjasintajni. 
\p  
\v 4 ’Ó kjuixin kjuíkosáya̱ha tí jaha ntihi chjasintajni kjuixinna tí xra̱ chjìna si̱tꞌa.  
\v 5 A̱ ntá jie Itꞌéni, chjìna jaha tí kjuachaxin jié kꞌuéchonta janhan tí kꞌuéjóni jnkoko̱á na̱xa̱ kꞌónahya chjasintajni. 
\p  
\v 6 ’Ó kjuixin kjuáko̱ha̱ tí sín chjìna chjasintajni kíxin nkexro tí jaha. Jaha mé kꞌuékuèntá sín tí ósé ntá jie chjìna tí janhan la ó kjuáko̱ha̱ sín itán la ntá ijie la ó kuítekaon sín.  
\v 7 Ntá jie ó kjuátso̱an sín kíxin kaín tí kjuachaxin chonta janhan la jaha tsíkjánjuan.  
\v 8 Kíxin ó kjuixin kjuáko̱ha̱ sín tí tán chjìna jaha, ntá kuítekaon sín, ntá kuíenxín sín kíxin mé chaxín tsíkꞌinkaxian tí tjen jaha, na mé kuítekaon sín kíxin jaha kuétua̱nna kꞌuinka. 
\p  
\v 9 ’Janhan mé xrja̱nóa̱ha kíxin chrókꞌuayakonhén tí jehe sín. Jehya kíxin xrja̱nnóa̱ha kíxin chrókꞌuayakonhén kaín tí chojni siín chjasintajni. Náhí. Jehó xrja̱nóa̱ha kíxin chrókꞌuayakonhén tí sín chjìna kíxin kuèntá sín.  
\v 10 A̱ ntá kaín tí nkehe chonta janhan na mé kuèntá jaha la ko kaín tí nkehe kuèntá la mé kuènta̱na kja̱xin. A̱ ntá tí kjuachaxin jié kuènta̱na mé tsꞌinkaséyanxín tí jehe sín. 
\p  
\v 11 ’A̱ ntá jie tsito̱nahya janhan ntihi chjasintajni. Kjánchó jehe sín na̱xa̱ tsito̱he sín chjasintajni. A̱ ntá jie tsjasán tí tjen jaha. Jaha Itꞌéni imá jína jaha, tꞌayakuenxián sín tí kjuachaxin tí ihni̱á kíxin ntá jnkoko̱á chrókjuenka̱yáxin sín éxí tí jaha la ko janhan jnkoko̱á tjenka̱yáxinni.  
\v 12 A̱ ntá tí na̱xa̱ kꞌuéjóki̱an tí jehe sín ntihi chjasintajni la kꞌuàyakuànxián sín tí kjuachaxin tí ihni̱á chjìna. Nijnko tí jehe sín kꞌuitjáyanhya sín. A̱ ntá jnkoko̱á nkexro mé kꞌuítjáyan mé tí chꞌín xráxín tsꞌitjáyan kíxin xi̱kaha tsoxiteyá éxí nixja tí xroon tsíkjin sín. 
\p  
\v 13 ’Ntá jie ó tsjasán tí tjen jaha. A̱ ntá na̱xa̱ itjén janhan chjasintajni mé ntáxrja̱n tíhi kíxin ntá tso̱chéhe̱ sín éxí yóhe̱ imá chàna.  
\v 14 Janhan mé kjuáko̱ha̱ sín itán jaha, a̱ ntá jie tí sín chjasintajni mé nínkakonhen tí jehe sín kíxin jehe sín la jehya kuènte chjasintajni éxí kja̱xin janhan na janhya kuènta̱na chjasintajni.  
\v 15 Tjáncháhya kíxin chrókuakítsjehé sín chjasintajni. Náhí. Tjáncháhá kíxin chrókꞌuayakonhén sín kíxin chrókjuichꞌiyehya sín tí Jínahya.  
\v 16 Jehe sín la jehya kuènte chjasintajni éxí yóhe̱ janhan kja̱xin janhya kuènte chjasintajni.  
\v 17 Nchetjuáxian sín tí kjuachaxin kuèntá kíxin itán jaha mé tí tan chaxín ntoá.  
\v 18 Éxí yóhe̱ jaha kuétua̱nna kꞌuinka chjasintajni mé xi̱kaha janhan tétua̱nha̱n sín kíxin chrókꞌuejóyákjan sín tí sín chjasintajni.  
\v 19 Jehó tí xra̱ kuèntá chrókjui̱tꞌa kíxin chrókjuinki̱tsa tí jehe sín, a̱ ntá jehe sín kja̱xin chrókjuichꞌe sín tí xra̱ kuèntá kíxin kuínhin sín itán chaxín ntoá. 
\p  
\v 20 ’Kjánchó jehya kíxin xrja̱nóa̱ha kíxin chrókjuínki̱tsa tí jehó sín. Náhí. Kja̱xin xrja̱nóa̱ha kíxin chrókjuínki̱tsa kaín tí sín tsitekaon sín chrꞌéxi̱n tsinhin sín tí nkehe tsochrónka tí sín a.  
\v 21 Mé xi̱kaha xrja̱nóa̱ha kíxin kaín tí jehe sín jnkoko̱á chrókjuenka̱yáxin sín éxí jaha Itꞌéni la ko janhan jnkoko̱á tjenka̱yáxinni mé xi̱kaha xrja̱nóa̱ha kíxin kaín tí jehe sín la ko jaha la ko janhan jnkoko̱á chrókjuenka̱yáxinni. A̱ ntá tí sín chjasintajni chrókuitekaon sín kíxin jaha tsíkétua̱nna kꞌuinka ntihi.  
\v 22 A̱ ntá tí kjuachaxin jié chjìna na mé tja̱ha̱ tí jehe sín kíxin ntá kaín sín jnkoko̱á chrókjuenka̱yáxin sín éxí yóhe̱ jaha la ko janhan jnkoko̱á tjenka̱yáxinni.  
\v 23 Janhan la ko jehe sín jnkoko̱á chrókjuenka̱yáxinni éxí jaha la ko janhan jnkoko̱á tjenka̱yáxinni. Mé xi̱kaha tí sín chjasintajni chrókónohe sín kíxin jaha kuétua̱nna kꞌuinka la ko kja̱xin chrókónohe sín kíxin jaha tjuèhé tí jehe sín éxí yóhe̱ tjua̱na tí jaha. 
\p  
\v 24 ’Jaha Itꞌéni, tí sín kjuánjuan la tjínka̱van kíxin tí jehe sín chrókꞌuejóki̱an sín tí tsjakꞌé janhan kíxin chrókꞌuikon sín tí kjuachaxin jié chjìna; kíxin xráxín na̱xa̱ kꞌónahya chjasintajni kꞌuétjua̱na jaha.  
\v 25 Itꞌéni jaha, imá jína jaha. Kjónté tí sín chjasintajni na̱xa̱ chónhya sín tí jaha, ntá janhan na ó xráxín choxian tí jaha la ko kaín tí sín i kja̱xin ó nohe sín kíxin jaha kuétua̱nna kꞌuinka.  
\v 26 Ó kjuáko̱ha̱ sín kíxin nkexro tí jaha la ko xi̱kaha na̱xa̱ tsjáko̱ha̱ sín, kíxin éxí tjua̱na jaha mé xi̱kaha chrótjuèhe sín kíchó sín la ko janhan chrókꞌuejóki̱an tí jehe sín ―mé xi̱kaha chrónóe̱he̱ chꞌín Jesús tí Itꞌé chꞌán.﻿ 
\c 18  
\s1 Chꞌín Jesús sákjuíko sín chꞌán tsjakꞌechjina chꞌán 
\r (Mt. 26.47-56; Mr. 14.43-50; Lc. 22.47-53) 
\p  
\v 1 Ó kjuixin ntáchro chꞌín Jesús kaín tíha ntá jehe chꞌán la ko tí sín kꞌuájiko chꞌán kꞌuaxrjexín sín ntiha kꞌuatòye̱ sín tí tsa̱ka Cedrón. Ntaha tjen ijnko nonte siín nchónhya nta kꞌuíxenhen chꞌín Jesús la ko tí sín kꞌuájiko chꞌán.  
\v 2 Kja̱xin chꞌín Judas tí chꞌín sinchekji tí chꞌín Jesús mé nohe chꞌán kíxin ntaha tjen tí huerto a kíxin ntaha jnkoya̱xón kójnkotséko chꞌín Jesús tí sín kꞌuájiko chꞌán a.  
\v 3 A̱ ntá chꞌín Judas ó kjui̱ka̱o chꞌán nchónhya sín soldado la ko iso sín policía kuènte ni̱nko tsíkꞌe̱tue̱nhen tí sín ncha̱tꞌá tꞌe̱to̱an la ko tí sin fariseo. Ntá kjui sín kaín sín xraá sín chica la ko kjui̱ka̱o sín xrohi tꞌinkaséyanxín tí kjui̱xi̱n sín.  
\v 4 A̱ ntá chꞌín Jesús ó nohe chꞌán kaín xín nkehe tsꞌatsínka chꞌán, ntá sákjuí chꞌán kjuanchankíhi chꞌán sín ntáchro chꞌán kíxin: 
\p ―¿Nkexro xritjéyárá? ―ichro chꞌán. 
\p  
\v 5 Ntá kjuáte̱he sín ntáchro sín kíxin: 
\p ―Tjeyáni tí chꞌín Jesús tsíkji̱xi̱n chjasin Nazaret ―ichro sín. 
\p Ntá kjuáte̱he chꞌín Jesús ntáchro chꞌán kíxin: 
\p ―Janhan tíha ―ichro chꞌán. 
\p A̱ ntá chꞌín Judas tí chꞌín tsíkjinchekji tí chꞌín Jesús mé koí tjenkákjan chꞌán tí jehe sín ntiha.  
\v 6 A̱ ntá tió kjuáte̱he chꞌín Jesús kíxin jehe chꞌán tíha, ntá jehe sín xráchonka sín kjuítsínka sín nonte.  
\v 7 Ntá xíkjanchankí chꞌín Jesús ínaá ntáchro chꞌán kíxin: 
\p ―¿Nkexro xritjéyárá? ―ichro chꞌán. 
\p Ntá xíntáchro sín kíxin: 
\p ―Tjeyáni tí chꞌín Jesús tsíkji̱xi̱n chjasin Nazaret ―ichro sín. 
\p  
\v 8 Ntá ntáchro chꞌín Jesús kíxin: 
\p ―Ó kjuixin tjo̱nka̱rá kíxin janhan tíha. Tí xritjéyárá tí janhan ntá ti̱to̱hérá sátsji tí í so sín xríki̱an ―ichro chꞌán. 
\p  
\v 9 Mé xi̱kaha ntáchro chꞌín Jesús kíxin ntá tsoxiteyá tí nkehe tsíntáchro chꞌán kíxin: “Tí sín kjuanjon Tꞌaná la ninkexró kjui̱ntakꞌitjáyanhya.”\f + \fr 18:9 \ft Juan 17.12\f* 
\v 10 Ntá chꞌín Simón Pedro kuakitsje chꞌán tí chica espada chrinkatoxi̱n chꞌán kóchrínjin chꞌán ta̱tsjon chjina ijnko chꞌín itꞌin Malco, mé ijnko chꞌín chꞌehe ncha̱tꞌá tꞌe̱to̱an xra̱.  
\v 11 Kjánchó chꞌín Jesús ntáche chꞌán tí chꞌín Pedro kíxin: 
\p ―Chrꞌa̱xenhén tjo̱e chica espada méhe̱. Kjá ntáchrua kíxin tsjasótehyana, kjá ichrua. Kjánchó Tꞌaná kjuanjon kjuachaxin kíxin nchónhya tsjasótena ―ichro chꞌán. 
\s1 Chꞌín Jesús kjuákꞌe nkayakon tí chꞌín tꞌe̱tue̱nhen tí sín ncha̱tꞌá 
\r (Mt. 26.57-58; Mr. 14.53-54; Lc. 22.54) 
\p  
\v 12 A̱ ntá tí sín soldado la ko tí chꞌín comandante tꞌe̱tue̱nhen sín la ko tí sín policía judío kuènte ni̱nko mé itsé sín tí chꞌín Jesús kjuínchenteto sín chꞌán.  
\v 13 A̱ ntá sákjuíko sín chꞌán nto̱e chꞌín Anás ichꞌe̱e tí chꞌín Caifás mé tí nkexro tsíkꞌáyéhe̱ xra̱ ncha̱tꞌá tꞌe̱to̱an tí nánó a.  
\v 14 A̱ ntá tí chꞌín Caifás, jehe chꞌán na mé tí nkexro tsíntáche tí sín judío kíxin íchá jína kíxin jnkoko̱á chojni chrókꞌuenyákonhe̱n kaín tí sín chjasén chꞌán.\f + \fr 18:14 \ft Juan 11.49–50\f* 
\s1 Chꞌín Pedro kjuínchemá chꞌán kíxin chóxin chꞌán tí chꞌín Jesús 
\r (Mt. 26.69-70; Mr. 14.66-68; Lc. 22.55-57) 
\p  
\v 15 Chꞌín Simón Pedro la ko í jnko chꞌín kꞌuékꞌajiko chꞌín Jesús mé kuinkáchréhe̱ sín chꞌán. Tí chꞌín ijnko a mé chóxin chꞌán tí ncha̱tꞌá tꞌe̱to̱an. Ntá kꞌuíxenko chꞌán tí chꞌín Jesús tí nta̱sin nto̱e tí ncha̱tꞌá tꞌe̱to̱an.  
\v 16 Kjánchó chꞌín Pedro kuíto̱he chꞌán ntója nta̱sin ó. Ntá tí chꞌín ijnko a chóxin tí ncha̱tꞌá tꞌe̱to̱an mé kꞌuaxrje chꞌán nta̱sin nixje̱he̱ chꞌán tí tjan tꞌayakonhen tí ntója nta̱sin chrónóe̱he̱ chꞌán tjan ntá xranjon kjuachaxin ntá kꞌuíxenhen chꞌín Pedro kja̱xin.  
\v 17 Na ntá tí tjan tꞌayakonhen tí ntója nta̱sin kjuanchankíhi tjan tí chꞌín Pedro kíxin: 
\p ―¿Á jahya kja̱xin xríkoa tí chꞌín a? ―ichro tjan. 
\p Ntá kjuáte̱he chꞌín Pedro kíxin: 
\p ―Náhí, janhya ―ichro chꞌán. 
\p  
\v 18 Ntá imá kin ntá tí sín chꞌexón xra̱ la ko tí sín policía kjuaka sín xrohi ntaha tjejóxin to̱té sín tjejóchjixro̱he sín. La ko koí chꞌín Pedro tjechjixro̱he chꞌán ntiha. 
\s1 Tí ncha̱tꞌá tꞌe̱to̱an mé kjuanchankíhi chꞌán tí chꞌín Jesús 
\r (Mt. 26.59-66; Mr. 14.55-64; Lc. 22.66-71) 
\p  
\v 19 Ntá tí ncha̱tꞌá tꞌe̱to̱an kjuankíxin kjuanchankíhi chꞌán tí chꞌín Jesús kíxin nkexro tí sín kꞌuájiko chꞌán la ko nkehe tí kjua̱ko̱he̱ chꞌán sín.  
\v 20 Ntá kjuáte̱he chꞌín Jesús ntáchro chꞌán kíxin: 
\p ―Noxín kjuakꞌé kjuàkua, la ntá kaín xín chojni kuínhin sín. Xráxín kꞌuékjáko̱xia̱n kaín xín tí ni̱nko ntsí la ko tí ni̱nko jié tójnkotséxin kaín xín sín judío. Ninkehó nkehe kjuákohya imó.  
\v 21 ¿Nkekuènté tjanchankìna tí janhan xi̱kaha? Chrókjuanchankíhí tí sín kuínhin kíxin nkexrí kjuáko̱ha̱ sín. Jehe sín mé nohe sín nkehe kjuáko̱ha̱ sín ―ichro chꞌán. 
\p  
\v 22 Kjuixin ntáchro chꞌín Jesús tíhi ntá ijnko chꞌín policía kuènte ni̱nko mé tjentaxín chꞌán ntiha chjéhe chꞌán nkayakon tí chꞌín Jesús ntáchro chꞌán kíxin: 
\p ―¿Á xi̱kaha jie̱he tsjáte̱hé tí ncha̱tꞌá tꞌe̱to̱an ní? ―ichro chꞌán. 
\p  
\v 23 Ntá kjuáte̱he chꞌín Jesús ntáchro chꞌán kíxin: 
\p ―Tí ntoáhya tí nkehe xrja̱nka ntá chro̱nka nkehe tí ntoáhya. A̱ ntá tí ntoá tí nkehe xrja̱nka, ¿ntá nkekuènté kíxin tjatena? ―ichro chꞌán. 
\p  
\v 24 Ntá kꞌue̱to̱an chꞌín Anás kíxin tjechróntetoxinhín chꞌín Jesús sátsji chꞌán tí tjen chꞌín Caifás tí ncha̱tꞌá tꞌe̱to̱an. 
\s1 Chꞌín Pedro xíkjinchemá chꞌán ínaá kíxin chóxin chꞌán tí chꞌín Jesús 
\r (Mt. 26.71-75; Mr. 14.69-72; Lc. 22.58-62) 
\p  
\v 25 Ntá chꞌín Simón Pedro mé na̱xa̱ tjexín to̱té chꞌán tjechjixro̱he chꞌán. Ntá kjuanchankíhi sín chꞌán kíxin: 
\p ―¿Á kja̱xinhya jaha xríkoa tí nkexro i ní? ―ichro sín. 
\p Ntá chꞌín Pedro kjuínchemá chꞌán ínaá ntáchro chꞌán kíxin: 
\p ―Náhí, janhya ―ichro chꞌán. 
\p  
\v 26 A̱ ntá ijnko chꞌín chꞌehe tí ncha̱tꞌá tꞌe̱to̱an xra̱, na mé tí chꞌín a mé na̱xa̱ kjéhya chꞌán tí chꞌín tsíkóchrínjin chꞌín Pedro ntatsjon, na mé kjuanchankí chꞌán kíxin: 
\p ―¿Á jehya jaha tí kꞌuíkua̱n tjekoa chꞌán tí huerto ní? ―ichro chꞌán. 
\p  
\v 27 Ntá chꞌín Pedro xíkjinchemá chꞌán ínaá kíxin jehya chꞌán, ichro chꞌán. Ntá xrína̱hya tuénxín itsje ijnko kochínto̱a. 
\s1 Chꞌín Jesús kjuákꞌe nkayakon tí chꞌín Pilato 
\r (Mt. 27.1-2, 11-14; Mr. 15.1-5; Lc. 23.1-5) 
\p  
\v 28 Ntá kꞌuaxrjexín sín nto̱e chꞌín Caifás, sákjuíko sín chꞌín Jesús tí palacio tꞌe̱to̱anxín tí chꞌín gobernador. Ntá ó kjuankíxin kꞌuínkaséyan kjuíji sín ntiha. A̱ ntá tí sín judío la mé í kꞌuíxenhya sín tí palacio kíxin tí xi̱kaha chrókꞌuixenhen sín tí nchia a la chrókuamá sín tí jie̱ siín ntiha la í xitjahya sine sín tí kia pascua, ichro sín.  
\v 29 A̱ ntá chꞌín Pilato kꞌuaxrjexín chꞌán tí nchia tꞌe̱to̱anxín chꞌán kjuanchankíhi chꞌán sín kíxin: 
\p ―¿Nkehe tí jie̱ chónta tí nkexro i? ―ichro chꞌán. 
\p  
\v 30 Ntá kjuáte̱he sín ntáchro sín kíxin: 
\p ―Tí chróchóntahya chꞌán jie̱ jié la chrókjui̱ko̱ahyani chꞌán ―ichro sín. 
\p  
\v 31 Ntá kꞌue̱to̱an chꞌín Pilato kíxin: 
\p ―Sátjíkoará chꞌán nchekito̱exínrá nkerí jie̱ chónta chꞌán kíxin éxí ntáchro tí ley kuèntárá ―ichro chꞌán. 
\p Ntá kjuáte̱he tí sín judío ntáchro sín kíxin: 
\p ―Jeheni chojni judíoni la chóntahyani kjuachaxin tsꞌóyánni ninkexró ―ichro sín. 
\p  
\v 32 Mé xi̱kaha tsoxiteyá tí nkehe tsíntachro chꞌín Jesús kíxin nkexrí tsꞌenxín chꞌán.  
\v 33 Ntá chꞌín Pilato xíkꞌixenhen chꞌán tí nchia tꞌe̱to̱anxín chꞌán ntá kꞌuíye̱he̱ chꞌán tí chꞌín Jesús kjuanchankíhi chꞌán kíxin: 
\p ―¿Á jaha tí nkexro Rey tꞌe̱tue̱nhen tí sín judío ní? ―ichro chꞌán. 
\p  
\v 34 Ntá ntáchro chꞌín Jesús kjuanchankí chꞌán kíxin: 
\p ―Tí nkehe tjanchankìná, ¿á jahyá kjuenka̱yáxian xi̱kaha, o̱ á í jnko nkexro kjuanchia jie̱ kíxin tí janhan? ―ichro chꞌán. 
\p  
\v 35 Ntá kjuáte̱he chꞌín Pilato ntáchro chꞌán kíxin: 
\p ―¿Á kjanhya janhan tí judío kíxin? Tí sín chjasán la ko tí sín ncha̱tꞌá tꞌe̱to̱an mé kjuikaán sín tí jaha. ¿Xá nkehe kjui̱chꞌe kíxin? ―ichro chꞌán. 
\p  
\v 36 Ntá kjuáte̱he chꞌín Jesús ntáchro chꞌán kíxin: 
\p ―Tí kjuachaxin chonta janhan jehya kíxin chjasintajni chrókuéto̱an. Náhí. Tí chrókuéto̱an chjasintajni ntá tí sín xríki̱an chrókjuanjo̱nko sín tí sín judío kíxin chrótséhyana sín la chrókjuikánhyana sín ntihi. Kjánchó tí kjuachaxin chonta janhan jehya kíxin chjasintajni chrókuéto̱an ―ichro chꞌán. 
\p  
\v 37 Ntá ntáchro chꞌín Pilato kíxin: 
\p ―¿Á jaha chaxín ijnko rey? ―ichro chꞌán. 
\p Ntá kjuáte̱he chꞌín Jesús ntáchro chꞌán kíxin: 
\p ―Janhan tí rey éxí ntáchrua jaha. Tí xra̱ ó kokjìna la ko tí xra̱ ó kꞌuinka chjasintajni kíxin tso̱xrja̱nka nkehe tí chaxín ntoá. Kaín tí sín titekaon tí nkehe chaxín ntoá mé tjejótinhin sín tí nkehe tjàkua ―ichro chꞌán. 
\p  
\v 38 Ntá ntáchro chꞌín Pilato kíxin: 
\p ―¿Xá nkehe tí nkehe chaxín ntoá, ichrua? ―ichro chꞌán. 
\s1 Chꞌín Pilato kjuanjon kjuachaxin kíxin itsꞌen chꞌín Jesús 
\r (Mt. 27.15-31; Mr. 15.6-20; Lc. 23.13-25) 
\p Ntá kjuixin kjuanchankí chꞌín Pilato tíha ntá kꞌuaxrjexín chꞌán ntiha ntá sákjuí chꞌán tí tjejó tí sin judío nixje̱he̱ chꞌán sín ntáchro chꞌán kíxin: 
\p ―Kꞌuítjáhya ninkehó jie̱ chónta tí nkexro i.  
\v 39 Kjánchó jahará la ó kuánhanrá kíxin tí kia pascua tsjánjuan kjuachaxin kíxin tsꞌatjánta ijnko nkexro tjechjina. ¿Á tjinkáonrá kíxin tsꞌatjánta tí chꞌín Rey tꞌe̱tue̱nhen tí sín judío? ―ichro chꞌán. 
\p  
\v 40 Ntá kaín sín kꞌóyako sín kjuanchia sín kíxin: 
\p ―Tí chꞌín a la náhí. Tꞌatjánta tí chꞌín Barrabás ―ichro sín. 
\p Kjánchó tí chꞌín Barrabás mé ijnko chojni che̱e tíha.﻿ 
\c 19  
\p  
\v 1 Ntá chꞌín Pilato mé kꞌue̱to̱an chꞌán kíxin tsjate sín tí chꞌín Jesús.  
\v 2 Ntá tí sín soldado kjuíchꞌéna sín ntachꞌi̱ ijnko corona ntá kjua̱kꞌe̱nka̱ya sín ikja tí chꞌín Jesús. La ko kjuínchekꞌinkáya sín chꞌán ijnko ka kjátse tié kíxin jehe sín tsjikosáyehe sín chꞌán éxí ijnko rey, kjánchó chaxínhya tíha.  
\v 3 Ntá kóchjinehe sín tí tjen chꞌán ntáchro sín kíxin: 
\p ―Isé tsjakꞌe tsétue̱nhén tí sín judío ―ichro sín. 
\p Kjánchó chaxínhya tíha kjuanoá sín chꞌán. La ntá tuénxín itja sín kjuatexín sín nkayakon chꞌán. 
\p  
\v 4 Ntá chꞌín Pilato kꞌuaxrjexín chꞌán tí nchia tꞌe̱to̱anxín chꞌán ínaá nixje̱he̱ chꞌán tí sín tsíkójnkotsé ntáchro chꞌán kíxin: 
\p ―Tsjehérá tsakítsjexián chꞌán ntihi kíxin tso̱nohará kíxin kꞌuítjáhya janhan ninkehó jie̱ chónta chꞌán ―ichro chꞌín Pilato. 
\p  
\v 5 Ntá kꞌuaxrjexín chꞌín Jesús ntiha tjenkáya kja chꞌán tí corona tsíkꞌóna ntachꞌi̱ la ko tjenkáya chꞌán tí ka kjátse tié. Ntá ntáchro chꞌín Pilato kíxin: 
\p ―Tsjehérá, ntihi tjen chꞌán ―ichro chꞌán. 
\p  
\v 6 A̱ ntá tió kꞌuíkon tí sín ncha̱tꞌá tꞌe̱to̱an la ko tí sín policía kuènte ni̱nko ntá kjuankíxin sín tꞌóyako sín ntáchro sín kíxin: 
\p ―¡Tjakénka̱nirá chꞌán ntacruz! ¡Tjakénka̱nirá chꞌan ntacruz! ―ichro sín. 
\p Ntá ntáchro chꞌín Pilato kíxin: 
\p ―Jahará tjíkoará chꞌán tjaké nka̱nirá chꞌán ntacruz kíxin janhan kꞌuítjáhya ninkehó jie̱ chónta tí jehe chꞌán ―ichro chꞌán. 
\p  
\v 7 Ntá kjuáte̱he tí sín judío kíxin: 
\p ―Jeheni chojni judío mé chóntani ijnko ley tꞌe̱to̱an kíxin chrókꞌuen chꞌán kíxin ncheyóhe̱ chꞌán a̱sén chꞌán kíxin Xje̱en Dios tí jehe chꞌán ―ichro sín. 
\p  
\v 8 Ntá tió kuínhin chꞌín Pilato tíha ntá a̱ntsí chrakon chꞌán  
\v 9 ntá xíkꞌixenhen chꞌán tí nchia tꞌe̱to̱anxín chꞌán ínaá kjuanchankíhi chꞌán tí chꞌín Jesús kíxin: 
\p ―¿Nketí kꞌuinkaxian jaha? ―ichro chꞌán. 
\p Ntá chꞌín Jesús ninkehó kjuáte̱ehya chꞌán. 
\p  
\v 10 Ntá ntáchro chꞌín Pilato kíxin: 
\p ―¿Jaha nkekuènté tjáte̱ehya nkehe tjánchánkíha? ¿Á noahya jaha kíxin chonta janhan kjuachaxin tséto̱an tsjakꞌenka̱nia ntacruz la ko kja̱xin chonta janhan kjuachaxin tsontáxrja̱n kíxin sátsjia kohya nkehe tso̱nhan? ―ichro chꞌán. 
\p  
\v 11 Ntá kjuáte̱he chꞌín Jesús ntáchro chꞌán kíxin: 
\p ―Ninkehó kjuachaxin chróchontahya jaha chrókuéto̱an chrókꞌuén o̱ sáchrókjuia tí Dios chrótjáhya tí kjuachaxin. A̱ ntá tí chojni kjuikaána tí tjen jaha la a̱ntsí jié jie̱ chónta sín, a̱ ntá jaha la kánhyó ―ichro chꞌán. 
\p  
\v 12 Ntá kuínhin chꞌín Pilato tíhi ntá kjuankíxin chꞌán kjueyá chꞌán nkexrí chrókꞌue̱to̱an chꞌán kíxin sáchrókjui chꞌín Jesús kohya nkehe chrókónhen chꞌán. Kjánchó tí sín judío kꞌóyako sín ntáchro sín kíxin: 
\p ―Kja̱ tí tsi̱to̱hé sátsji chꞌán kohya nkehe tso̱nhen chꞌán ntá jaha jnkoko̱áhya tjenka̱yáxinkoa tí chꞌín tꞌe̱tue̱nhen tí nación kuènténi. Tí nkexro chꞌéna a̱sén chꞌán éxí ijnko rey mé nínkakonhen chꞌán tí chꞌín tꞌe̱tue̱nhenni ―ichro sín. 
\p  
\v 13 Ntá kuínhin chꞌín Pilato tíhi ntá kꞌue̱to̱an chꞌán kíxin tsakitsje sín tí chꞌín Jesús ntója ntá chꞌín Pilato kjuákꞌetja̱xi̱n chꞌán tí silla nchekito̱exín chꞌán jie̱, mé nkìva hebreo mé itꞌin Gabata, mé tꞌaxrjexín kíxin tja̱tꞌo̱ noi jehó xro̱ tsíkꞌóna.  
\v 14 Na mé ó chjina chonkíxin ntá tí tso̱njín la mé ó tsjasin sín tí kia pascua. Ntá chꞌín Pilato ntáche chꞌán tí sín judío kíxin: 
\p ―Ntihi itjen tí chꞌín rey kuèntárá ―ichro chꞌán. 
\p  
\v 15 Kjánchó jehe sín kꞌóyako sín ntáchro sín kíxin: 
\p ―¡Itsꞌen chꞌán! ¡Itsꞌen chꞌán! ¡Tsjakꞌenkáni chꞌán ntacruz! ―ichro sín. 
\p Ntá ntáchro chꞌín Pilato kíxin: 
\p ―¿Á tjinkáonrá kíxin janhan chrókjuakénka̱nia ijnko ntacruz tí chꞌín rey kuèntárá ní? ―ichro chꞌán. 
\p Kjánchó tí sín ncha̱tꞌá tꞌe̱to̱an mé kjuáte̱he sín kíxin: 
\p ―Náhí. Chóntahyani í jnko rey, jehó tí chꞌín César ―ichro sín. 
\p  
\v 16 Ntá chꞌín Pilato kjuanjon chꞌán kjuachaxin sátsjiko sín tí chꞌín Jesús tsja̱kꞌe̱nka̱ni sín chꞌán ntacruz. Ntá sákjuíko sín chꞌán. 
\s1 Kjuákꞌenkáni chꞌín Jesús ntacruz 
\r (Mt. 27.32-44; Mr. 15.21-32; Lc. 23.26-43) 
\p  
\v 17 Ntá sákjuíko sín tí chꞌín Jesús kuámá chꞌán tí ntacruz tsjakꞌenkáni chꞌán. Ntá kjuíjiko sín chꞌán ijnko tjo ti̱ki̱texín sín Hueso Kja Chojni. A̱ ntá nkìva hebreo mé ti̱ki̱texín sín Gólgota.  
\v 18 Ntaha mé kjua̱kꞌe̱nka̱ni sín chꞌán tí ntacruz. Ntá kja̱xin yaá sín nánánko kꞌuéjó jnkojnko sín ntá jnko̱siné kjuákꞌe chꞌín Jesús.  
\v 19 Ntá kꞌue̱to̱an chꞌín Pilato kíxin tsokjin sín ijnko ntachiso tsja̱kꞌe̱nka̱ni sín ikja tí ntacruz ntáchro kíxin: “Chꞌín Jesús kjui̱xi̱n chꞌán chjasin Nazaret, mé tí chꞌín Rey kuènte tí sín judío”, tsixro.  
\v 20 A̱ ntá itsjé tí sín judío mé kjuínchekuáxin sín tí letra tsíkꞌóna kíxin chjino tí chjasin Jerusalén tsíkja̱kꞌe̱nka̱ni sín chꞌín Jesús ntacruz la ko iní nkìva tsíkjin sín, na mé ijnko nkìva la hebreo, la ijnko nkìva la griego, la ijnko nkìva la latín.  
\v 21 Ntá tí sín ncha̱tꞌá tꞌe̱to̱an kuènte tí sín judío mé ntáche sín tí chꞌín Pilato kíxin: 
\p ―Chrókjinhya jaha xi̱kaha kíxin jehe chꞌán mé tí “Chꞌín Rey kuènte tí sín judío.” Náhí. Íchá jína chrókjian jaha kíxin “Jehe chꞌán ntáchro chꞌán kíxin jehe chꞌán mé tí chꞌín Rey kuènte tí sín judío” ―ichro sín. 
\p  
\v 22 Kjánchó kjuáte̱he chꞌín Pilato kíxin: 
\p ―Tí letra kuéto̱an kꞌóna la ó kꞌóna, kjónté xi̱kahó tsito̱he ―ichro chꞌán. 
\p  
\v 23 Ntá tí sín soldado tió tsíkjixin tsíkja̱kꞌe̱nka̱ni sín tí chꞌín Jesús tí ntacruz ntá kuákja sín tí ké chꞌán la kꞌóxika̱ye̱he sín jnkojnko ka kuákja sín kanoé sín. La ko kja̱xin kuákja sín tí ka kjínjin kꞌuékꞌinkáya chꞌán. Tí ka mé tsíxro̱nhya ka la me jnkoko̱á ka tíha.  
\v 24 Ntá tí sín soldado kjo sín kíchó sín ntáchro sín kíxin: 
\p ―Tsótséchjehyani tí ké chꞌán. Íchá jína sichꞌexínni suerte ntá tsotsjeheni siná nkexro tsꞌáyéhe̱ tí ka. 
\p Mé xi̱kaha xiteyá éxí ntáchro xroon itén Dios tsíkjin sín ósé ntáchro kíxin: “Kjuíchꞌexín sín suerte ntá kꞌóxika̱ye̱he sín kaná.”\f + \fr 19:24 \ft Salmo 22.18\f* Mé xi̱kaha kjuíchꞌe tí sín soldado. 
\p  
\v 25 A̱ ntá chjino tí ntacruz kjuákꞌenkáni chꞌín Jesús mé kjuákꞌe tí ìné chꞌán la ko tí tjan kíchó tjan mé tjan María ichjién chꞌín Cleofas, la ko tí tjan María Magdalena.  
\v 26 A̱ ntá tió kꞌuíkon chꞌín Jesús kíxin itjen tí ìné chꞌán la ko chjino tjen tí chꞌín a̱ntsí tjuèhé chꞌán kꞌuékꞌajiko chꞌán, ntá nixje̱he̱ chꞌán tí ìné chꞌán, ntáchro chꞌán kíxin: 
\p ―Naná, tsjehé kíxin ntaha tjen xja̱an ―ichro chꞌán. 
\p  
\v 27 Ntá nixje̱he̱ chꞌín Jesús tí chꞌín a ntáchro chꞌán kíxin: 
\p ―Tsjehé kíxin ntaha itjen ìná ―ichro chꞌán. 
\p A̱ ntá tí chꞌín a mé kꞌuáyéhe̱ chꞌán tí tjan a sákjuíko chꞌán tjan nto̱e chꞌán kꞌóna éxí ìné chꞌán xi̱kaha. 
\s1 Ikꞌuén chꞌín Jesús 
\r (Mt. 27.45-56; Mr. 15.33-41; Lc. 23.44-49) 
\p  
\v 28 Ntá ó nohe chꞌín Jesús kíxin kaín xra̱ ó kjuixin xiteyá ntá tjinkaon chꞌán kíxin tsoxiteyá kaín nkehe ntáchro tí xroon tsíkjin sín ósé ntá xi̱kaha ntáchro chꞌán kíxin: 
\p ―Ikꞌuén nta̱. 
\p  
\v 29 Ntá ntiha tjen ijnko nchésen tsíkaón xranvino sán ntá kjuínchekjataxín sín ijnko ka tí xranvino, a̱ ntá tí ka a kjua̱kꞌe̱kjen sín ijnko nta kjínjin, ntá kjuínchechrìin sín tí tjen irꞌva chꞌán.  
\v 30 Ntá ikꞌuí chꞌín Jesús tí xranvino sán ntá ntáchro chꞌán kíxin: 
\p ―Ó kjuixin xiteyá kaín xín nkehe ―ichro chꞌán. 
\p Ntá kꞌuísén kja chꞌán ntá ó kjuixin kꞌuén chꞌán. 
\s1 Ijnko soldado chrꞌáte chꞌán chica yo tí chjia chꞌín Jesús 
\p  
\v 31 A̱ ntá xi̱kaha ya̱on ntóye mé tí ya̱on kia pascua ntá tí sín judío tjinkakonhya sín kíxin tí cuerpo kuènte tí sín tsíkꞌen na̱xa̱ tsꞌejóyáni tí ntacruz tí ya̱on tꞌo̱kꞌéhe sín kíxin tí ya̱on pascua mé ijnko ya̱on imá jié, ichro sín. Mé xi̱kaha kjuanchehe sín tí chꞌín Pilato kíxin tsꞌe̱to̱an chꞌán kíxin tsochjenjin to̱té tí sín tjejóyáni tí ntacruz la ko tsꞌinkajin tí cuerpo kuènte tí sín tsíkꞌen.  
\v 32 Ntá tí sín soldado sákjuí sín kꞌóchjenjin sín tí to̱té tí chꞌín sa̱oxín tjen la ko kꞌóchjenjin sín tí to̱té tí chꞌín tjen nánko a tjejóyáni sín tí ntacruz tí tjen chꞌín Jesús.  
\v 33 Ntá kjuíji sín tí tjen chꞌín Jesús ntá kꞌuíkon sín kíxin ó tsíkjixin tsíkꞌen chꞌán, ntá í kꞌóchjenjinhya sín to̱té chꞌán. 
\p  
\v 34 A̱ ntá ijnko chꞌín soldado mé chrꞌáte chꞌán chica yo tí chjia tí chꞌín Jesús ntá tuénxín kꞌuaxrje jni̱ la ko ìnta̱.  
\v 35 A̱ ntá janhan mé tjékjian tí xroon i mé kjuakꞌé ntiha kꞌuíkua̱n kíxin xi̱kaha kónhen ntá ntoá tjéxrja̱nka kíxin jahará kja̱xinrá chrókuítekáonrá.  
\v 36 Mé xi̱kaha kónhen tíha kíxin tsoxiteyá tí nkehe ntáchro xroon itén Dios tsíkjin sín ntáchro kíxin: “Kꞌóchjenjinhya sín ninkehó huéso̱e chꞌán.”\f + \fr 19:36 \ft Salmo 34.20\f* 
\v 37 Kja̱xin itjen í jnko nketí nixja tí xroon itén Dios tsíkjin sín ósé ntáchro kíxin: “Tsokomá sín tí nkexro tsíchrꞌáte sín chica.”\f + \fr 19:37 \ft Zacarías 12.10\f* 
\s1 Xravá chꞌín Jesús 
\r (Mt. 27.57-61; Mr. 15.42-47; Lc. 23.50-56) 
\p  
\v 38 Ntá ó kjuixin kónhen kaín tíha ntá chꞌín José, mé ijnko chꞌín kjui̱xi̱n chjasin Arimatea, mé kjuanchehe chꞌán tí chꞌín Pilato kjuachaxin kíxin tsjinkaji̱nxi̱n chꞌán tí ntacruz tí cuerpo kuènte chꞌín Jesús sátsjiko chꞌán tsja̱vá chꞌán. Jehe chꞌán imó kuinkáchónki chꞌán tí chꞌín Jesús kíxin chrako̱nhe̱n chꞌán tí sín judío. Ntá chꞌín Pilato mé kjuanjon chꞌán kjuachaxin ntá sákjuíko chꞌín José tí cuerpo kuènte chꞌín Jesús.  
\v 39 Kja̱xin chꞌín Nicodemo, tí chꞌín kjuínixje̱he̱ tí chꞌín Jesús ijnko tie a mé kjui chꞌán kjui̱ka̱o chꞌán treinta kilo xro̱a̱n xraxé tjiko xro̱a̱n mirra la ko xro̱a̱n áloes.  
\v 40 Mé xi̱kaha chꞌín José la ko chꞌín Nicodemo kꞌuáyéhe̱ sín tí cuerpo kuènte chꞌín Jesús kjuínchekꞌísímá sín ijnko ka kjínjin tsíka tí xro̱a̱n xraxé a kíxin xi̱kaha kꞌuékinkáchónki tí sín judío kꞌuékja̱vá sín chojni tsíkꞌen.  
\v 41 Tí kjuákꞌenkáni chꞌín Jesús ntacruz ntá chjinaxón ntiha tjen ijnko huerto itjen ijnko tòye̱ ni̱xin na̱xa̱ ninkexró tsíxráváhya ntiha.  
\v 42 Ntaha kjua̱vá sín tí chꞌín Jesús kíxin chjinaxón tjen tí tòye̱ a la ko í séhya tsoxrankíxin tí ya̱on tꞌo̱kꞌéhe tí sín judío.﻿ 
\c 20  
\s1 La ntá ó tsíxechón chꞌín Jesús 
\r (Mt. 28.1-10; Mr. 16.1-8; Lc. 24.1-12) 
\p  
\v 1 A̱ ntá tí ya̱on xrankíxixín semana ntá tí tjan María Magdalena na̱xa̱ sítié sákjui̱ tjan tí tjen tí tòye̱, ntá kꞌuíkon tjan kíxin ó tsíkjìin tí xro̱ tsíkꞌikjèxin tí tòye̱ a.  
\v 2 Ntá kuinká tjan sákjuí tjan tí tjen tí chꞌín Simón Pedro la ko tí chꞌín í jnko, mé tí nkexro imá kꞌuétjuèhe chꞌín Jesús, ntá ntáchro tjan kíxin: 
\p ―Ó tsíkakitsjexín sín tòye̱ tí cuerpo kuènte Ìnchéni ntá noehyani nketí tsíkjakꞌe sín ―ichro tjan. 
\p  
\v 3 Ntá chꞌín Pedro la ko tí chꞌín í jnko mé kuínhin sín xi̱kaha ntá sákjui̱ sín tí tjen tí tòye̱ a.  
\v 4 Ntá yóí sín kuinká sín sákjui̱ko kíchó sín. Kjánchó tí chꞌín í jnko a̱ntsí tji̱a̱n kuinká chꞌán ntá kánhyó tji̱a̱n kuinká chꞌín Pedro, ntá tí chꞌín í jnko senó chꞌán kjuíji chꞌán tí tjen tí tòye̱ a.  
\v 5 Kꞌuísén chꞌán tsjehe chꞌán nkaxenhen tí tòye̱ a. A̱ tí ka tsíkꞌisímá chꞌín Jesús mé na̱xa̱ tjejó kꞌuíkon chꞌán, kjánchó jehe chꞌán kꞌuíxenhya chꞌán tí tòye̱ a.  
\v 6 Ntá kjónté chrꞌéxi̱n kjuíji chꞌín Simón Pedro ntá kꞌuíxenhen chꞌán tí tòye̱ a. Ntá kja̱xin kꞌuíkon chꞌán kíxin tjejó tí ka tsíkꞌisímá chꞌín Jesús  
\v 7 la ko kꞌuíkon chꞌán tí ka tsíkꞌisímá ikja chꞌán na mé tí ka tsíxrèya ka la ókjé tjen ka, a̱ ntá tí í so ka na mé ókjé tjejó ka kja̱xin.  
\v 8 Na ntá tí chꞌín í jnko kꞌuékꞌajiko chꞌín Jesús, mé tí chꞌín tsíkjiji senó na kja̱xin kꞌuíxenhen chꞌán tí tòye̱ ntá kꞌuíkon chꞌán tí nkehe tsíkónhen ntá kuítekaon chꞌán.  
\v 9 Kíxin na̱xa̱ kꞌuékienxínhya sín tí nkehe kꞌuéchrónka xroon itén Dios kíxin tꞌichjánxi̱n tsoxechón tí chꞌín Jesús.  
\v 10 A̱ ntá tí sín sátsíkji̱tsjehe tòye̱ la xíkjan sín nto̱e sín. 
\s1 Titàya̱ kꞌuíkuèn tjan María Magdalena tí chꞌín Jesús 
\r (Mr. 16.9-11) 
\p  
\v 11 Ntá tjan María mé ntahó kuíto̱he tjan ntója tí tòye̱ tsjánka tjan. Na̱xa̱ tsjánka tjan kꞌuísén tjan tsjehe tjan nkaxenhen tí tòye̱  
\v 12 ntá xrína̱hya kꞌuíkon tjan yaá sín ángel tjejóyá sín ka tjóá tjejótja̱xi̱n sín tí tsíkjakꞌe tí cuerpo kuènte chꞌín Jesús na mé ijnko chꞌín ángel na mé tjen chꞌán tí tsíkjakꞌe ikja chꞌín Jesús la ko tí í jnko a itjen chꞌán tí tsíkꞌejó to̱té chꞌán.  
\v 13 A̱ ntá tí sín ángel mé kjuanchankí sín kíxin: 
\p ―Naná, ¿kuènte tsja̱nka? ―ichro sín. 
\p Ntá kjuáte̱he tjan ntáchro tjan kíxin: 
\p ―Sátsíkjiko sín Ìnchéni, ntá nonahya nketí tsíkjakꞌe sín chꞌán ―ichro tjan. 
\p  
\v 14 Kjuixin ntáchro tjan tíha ntá kuinkátjíá tjan ntá kꞌuíkon tjan kíxin itjen chꞌín Jesús, kjánchó kjuátso̱anhya tjan kíxin jehe chꞌán.  
\v 15 Ntá chꞌín Jesús kjuanchankíhi chꞌán tjan ntáchro chꞌán kíxin: 
\p ―Naná, ¿nkekuènté tsja̱nka? ¿Nkexro tjéyá? ―ichro chꞌán. 
\p A̱ ntá jehe tjan kjuenka̱yáxin tjan kíxin jehe chꞌán mé tꞌayakonhen chꞌán tí huerto, a̱ ntá ntáchro tjan kíxin: 
\p ―Kja̱ tí jaha sákjuíkoa chꞌán ntá jie chro̱nka nketí sákjuíkoa chꞌán kíxin janhan sátsji̱ki̱an chꞌán jie ―ichro tjan. 
\p  
\v 16 Ntá chꞌín Jesús mé nixje̱he̱ chꞌán tjan ntáchro chꞌán kíxin: 
\p ―¡María! ―ichro chꞌán. 
\p Ntá kuinkátjíá tjan ntá nixja̱xi̱n tjan nkìva hebreo ntáchro tjan kíxin: 
\p ―¡Raboni! ―ichro tjan. Tíha mé tꞌaxrjexín kíxin Maestro. 
\p  
\v 17 Ntá ntáchro chꞌín Jesús kíxin: 
\p ―Tatjántana kíxin na̱xa̱ sátjíhya janhan tí tjen Tꞌaná. Sátjia tjítsjehé tí sín kíchiná chénka sín kíxin sátsjiyá tí tjen Tꞌaná na mé kja̱xin Itꞌárá tí jahará na mé Dios kuènta̱na la ko kja̱xin Dios kuèntárá ―ichro chꞌán. 
\p  
\v 18 Ntá tí tjan María Magdalena sákjuíchénka tjan tí sín kꞌuékꞌajiko chꞌín Jesús chrónka tjan kíxin xi̱kaha tsíkꞌikon tjan Ìnchéni. La ko kja̱xin chrónka tjan kíxin xi̱kaha tsíntáchro chꞌán. 
\s1 Tí sín kꞌuékꞌajiko chꞌín Jesús titàya̱ kꞌuíkuèn sín chꞌán 
\r (Mt. 28.16-20; Mr. 16.14-18; Lc. 24.36-49) 
\p  
\v 19 A̱ ntá ó kónjín tí ya̱on a mé tí ya̱on xrankíxixín semana, a̱ ntá tí sín kꞌuékꞌajiko chꞌín Jesús jnkoko̱á kójnkotsé sín nkaxenhen nchia tsíkꞌikjehe̱ sín ntója nchia jína kíxin chrako̱nhe̱n sín tí sín judío. Ntá xrína̱hya titàya̱ kónohe sín kꞌuíkon sín kíxin jnko̱siné tí tjejó sín itjen chꞌín Jesús, ntá nixje̱he̱ chꞌán kjua̱jna̱ tí sín kꞌuékꞌajiko chꞌán ntáchro chꞌán kíxin: 
\p ―Jína tjejorá ―ichro chꞌán. 
\p  
\v 20 Ntá kjuixin ntáchro chꞌán tíhi ntá kjuako chꞌán itja chꞌán la ko chjia chꞌán. Ntá kóchéhe̱ tí sín kꞌuékꞌajiko chꞌán kíxin kꞌuíkon sín Ìnchéni.  
\v 21 Ntá ntáchro chꞌín Jesús ínaá kíxin: 
\p ―Kjuaxróxin tsꞌejorá. Yóhe̱ Tꞌaná kꞌue̱tua̱nna kꞌuinka, a̱ ntá jie la janhan tétua̱nhan tí jahará ―ichro chꞌán. 
\p  
\v 22 Ntá kꞌuánote chꞌán tí jehe sín ntáchro chꞌán kíxin: 
\p ―Tꞌayéhérá Ncha̱kuen Dios.  
\v 23 Tí tsꞌitjáyanhanrá tí jie̱ kjuasin jnkojín chojni ntá xi̱kaha tsjìin tí iji̱é sín. Ntá tí tsꞌitjáyanhyará tí jie̱ kjuasin jnkojín chojni ntá na̱xa̱ kjuìinhya tí iji̱é sín ―ichro chꞌán. 
\s1 Chꞌín Tomás kꞌuíkon chꞌán kíxin tsíxechón Ìnchéni 
\p  
\v 24 A̱ ntá tí chꞌín Tomás, ijnko tí teyóxin sín kꞌuékꞌajiko chꞌín Jesús mé kja̱xin ti̱ki̱texín sín chꞌín Nóhé mé kohya chꞌán tí kui chꞌín Jesús.  
\v 25 Ntá chrꞌéxi̱n tí í so sín kꞌuékꞌajiko chꞌín Jesús ntáche sín chꞌán kíxin: 
\p ―Ó kꞌuíkonni Ìnchéni ―ichro sín. 
\p Kjánchó ntáchro chꞌín Tomás kíxin: 
\p ―Tí tsꞌíko̱nhya janhan tí tsíkjiatexín chica clavo itja chꞌán la ko tsochrꞌánxianhya dedo tjaná ntiha la ko tí tsochrꞌánxianhya tjaná tí chjia chꞌán, ¿na mé nkexrí chrókuíteka̱van? ―ichro chꞌán. 
\p  
\v 26 A̱ ntá tí kꞌuátsínka ijnko semana ntá jnkoko̱á kójnkotsé sín nkaxenhen nchia la ko kja̱xin kjuákꞌeko sín chꞌín Tomás. Tsíkꞌikjehe̱ sín ntója nchia jína ntá xrína̱hya titàya̱ kónohe sín kꞌuíkon sín kíxin jnko̱siné tí tjejó sín itjen chꞌín Jesús, ntá nixje̱he̱ chꞌán tí jehe sín kꞌuékꞌajiko chꞌán ntáchro chꞌán kíxin: 
\p ―Kjuaxróxin tsꞌejorá ―ichro chꞌán. 
\p  
\v 27 Ntá ntáche chꞌán tí chꞌín Tomás kíxin: 
\p ―Chrꞌaxénhén dedo tjá tí tsíkjiatexín chica clavo tjaná la ko xrákoa tjá chrꞌaxénhén chji̱a̱na. Chróntáchrohya kíxin chaxínhya. Tsítekávan kíxin chaxín ―ichro chꞌán. 
\p  
\v 28 Ntá kjuáte̱he chꞌín Tomás ntáchro chꞌán kíxin: 
\p ―¡Ìnchéni jaha la ko Dios kuènta̱na! ―ichro chꞌán. 
\p  
\v 29 Ntá ntáche chꞌín Jesús tí chꞌín Tomás kíxin: 
\p ―Jaha Tomás kꞌuíkonjian ntá kuítekávan. Ntá a̱ntsí náxrjón tjejó tí sín kjónté kꞌuíkonhya la titekaon sín ―ichro chꞌán. 
\s1 Tíhi mé chrónka nkekuènte tsíkjin chꞌín Juan tí xroon i 
\p  
\v 30 Chꞌín Jesús kjuasin chꞌán itsjé í so kjuaxroan náxrjón kꞌuíkon tí sín kꞌuájiko chꞌán kjónté chrónkahya tí xroon i kíxin xi̱kaha kónhen.  
\v 31 Tí nkehe chrónka tí xroon i ikjian janhan kíxin chrókuítekáonrá jahará kíxin Jesús mé tí Cristo, mé tí Xje̱en Dios kíxin ntá kaín ni chróchóntani kjuachón jnkochríxín kíxin chrókuitekaonni chꞌán.﻿ 
\c 21  
\s1 Yato tí sín kꞌuékꞌajiko chꞌín Jesús xrína̱hya titàya̱ kꞌuíkon sín chꞌán 
\p  
\v 1 A̱ ntá chrꞌéxi̱n tí sín kꞌuékꞌajiko chꞌín Jesús titàya̱ xíkꞌikon sín tí jehe chꞌán ínaá chrínta nta̱yaon Tiberias. Mé xi̱kaha kónhen  
\v 2 kíxin jnkoko̱á kꞌuéjó sín chꞌín Simón Pedro la ko chꞌín Tomás, me tí chꞌín ti̱ki̱texín sín chꞌín Nóhé, la ko chꞌín Natanael kui̱xi̱n chꞌán chjasin Caná estado Galilea, la ko tí yaá xje̱en chꞌín Zebedeo la ko tí yaá sín ínaá kꞌuékꞌajiko chꞌín Jesús.  
\v 3 Ntá ntáchro chꞌín Simón Pedro kíxin: 
\p ―Sátsjitse̱ koche ―ichro chꞌán. 
\p Ntá kjuáte̱he sín kíxin: 
\p ―Koíni sátsjikoani ―ichro sín. 
\p Ntá sákjuí sín kꞌui̱tꞌótjen sín ijnko ntabárco̱. Kjánchó ninkehó koche tséhya sín kuenté tie.  
\v 4 A̱ ntá ó chjina tsꞌinkaséyan ntá xrína̱hya titàya̱ kꞌuíkon sín itjen chꞌín Jesús chrínta nta̱yaon, kjánchó kjuátso̱anhya tí sín kꞌuékꞌajiko chꞌán kíxin jehe chꞌán.  
\v 5 Ntá kjuanchankíhi chꞌán sín kíxin: 
\p ―Jahará ntasoá, ¿á na̱xa̱ ninkehó koche tse̱hyará? ―ichro chꞌán. 
\p Ntá kjuáte̱he sín ntáchro sín kíxin: 
\p ―Na̱xa̱ ninkehó ko tséhyani ―ichro sín. 
\p  
\v 6 Ntá chꞌín Jesús ntáche chꞌán sín kíxin: 
\p ―Itérá tí nchísén tí nánko chjia chjina tí ntabárco̱ la tso̱tse̱rá va ―ichro chꞌán. 
\p Ntá xi̱kaha kjuíchꞌe sín kꞌue sín nchísén ntá í tjachahya sín tsakitsjenkíxin sín nta̱ tí nchísén kíxin nchónhya koche tjinká.  
\v 7 A̱ ntá tí chꞌín a̱ntsí tjuèhe chꞌín Jesús mé ntáche chꞌán tí chꞌín Pedro kíxin: 
\p ―¡Ìnchéni tí méhe̱! ―ichro chꞌán. 
\p Ntá kuínhin chꞌín Simón Pedro kíxin Ìnchéni tíha ntá kꞌuinkáya chꞌán iké chꞌán ínaá (kíxin tsíkakitsje chꞌán iké chꞌán) ntá kjuiánkí chꞌán nta̱.  
\v 8 Tí í so sín kꞌuékꞌajiko chꞌín Jesús mé kjuíji sín tí chrínta nta̱yaon kjui̱ka̱o sín tí ntabárco̱ tinkánkákjentóxin tí nchísén tjinká koche chrítaón nta̱ kíxin ijnko ciento metro kjínxi̱n tí chrínta nta̱ kꞌuéjó sín.  
\v 9 Ntá kjuíji sín chrínta nta̱ ntá kꞌuínkaji̱nxi̱n sín tí ntabárco̱ ntá kꞌuíkon sín tjeche xrohi síxènki̱ xrinta ntá chrítaón tí xrinta tjekjen ijnko koche la ko nánko siín nio̱tja̱.  
\v 10 Ntá kjuanchia chꞌín Jesús ntáchro chꞌan kíxin: 
\p ―Xrákoará iso koche tsítse̱rá na̱ntá ―ichro chꞌán. 
\p  
\v 11 Ntá chꞌín Simón Pedro kꞌui̱tꞌótjen chꞌán tí ntabárco̱ kuákja chꞌán tí nchísén kuinkánkákjen chꞌán xráka̱o chꞌán tí nchísén tjinká koche iye na mé ijnko ciento cincuenta y tres va. Ntá kjónté nchónhya va la kꞌuichjehya tí nchísén a.  
\v 12 Ntá ntáchro chꞌín Jesús kíxin: 
\p ―Xrákirá, interá ―ichro chꞌán. 
\p A̱ ntá nijnko tí sín kꞌuékꞌajiko chꞌán chrókjuanchankíhi sín chꞌán kíxin nkexro tí jehe chꞌán kíxin ó kjuátso̱an sín kíxin Ìnchéni tíha.  
\v 13 Ntá kóchjina chꞌín Jesús kuákja chꞌán tí nio̱tja̱ chjéhe chꞌán tí jehe sín la ko xi̱kaha xíkjanjon chꞌán tí koche. 
\p  
\v 14 Tíhi mé níxin kꞌuíkon tí sín kꞌuékꞌajiko chꞌín Jesús kíxin tsíxechón chꞌán.\f + \fr 21:14 \ft Juan 20.19,26\f* 
\s1 Chꞌín Jesús itjo chꞌán tí chꞌín Simón Pedro 
\p  
\v 15 Kjuixin kjóne sín ntá kjuanchankíhi chꞌín Jesús tí chꞌín Simón Pedro kíxin: 
\p ―Jaha Simón, xje̱en Jonás, ¿á a̱ntsí tjua̱na jaha, a̱ ntá tí í so la kánhyó? ―ichro chꞌán. 
\p Ntá kjuáte̱he chꞌín Pedro ntáchro chꞌán kíxin: 
\p ―Jeén, Ìnchéni, ó noha kíxin tjínka̱van tí jaha ―ichro chꞌán. 
\p Ntá ntáchro chꞌín Jesús kíxin: 
\p ―Ntá xi̱kaha la tꞌayakonhén tí kolélo kuènta̱na ―ichro chꞌán. 
\p  
\v 16 Ntá yóxin kjuanchankí chꞌín Jesús ínaá kixin: 
\p ―Jaha Simón, xje̱en Jonás, ¿á tjua̱na jaha? ―ichro chꞌán. 
\p Ntá kjuáte̱he chꞌín Pedro ntáchro chꞌán kíxin: 
\p ―Jeén, Ìnchéni, ó noha kíxin tjínka̱van tí jaha ―ichro chꞌán. 
\p Ntá ntáchro chꞌín Jesús kíxin: 
\p ―Ntá xi̱kaha la tꞌayakonhén tí kolélo kuènta̱na ―ichro chꞌán. 
\p  
\v 17 Ntá níxin kjuanchankí chꞌín Jesús kíxin: 
\p ―Jaha Simón, xje̱en Jonás, ¿á tjinkávan tí janhan? ―ichro chꞌán. 
\p A̱ ntá kꞌuává chꞌín Pedro kíxin níxin kjuanchankí chꞌín Jesús kíxin á tjinkaon chꞌán tí jehe chꞌán ntá ntáchro chꞌán kíxin: 
\p ―Jaha Ìnchéni, ó noha kaín xín nkehe. Ó noha kíxin tjínka̱van tí jaha ―ichro chꞌán. 
\p Ntá ntáchro chꞌín Jesús kíxin: 
\p ―Ntá xi̱kaha tꞌayakonhén tí kolélo kuènta̱na.  
\v 18 Ntá ijnko nkehe chaxín tjétjo̱nka kíxin tí na̱xa̱ kꞌuéntasoyá jaha kꞌuékꞌinka̱ya ká jahvá la ko kꞌuékjia tí kꞌuékóxrjínhan jaha. A̱ ntá tió tso̱táda jaha ntá tsjéntoá tjá ntá í jnko nkexro sintakꞌinkáya ka la ko sátsjikoa sín tí tóxrjía̱nhya sáchrókjuia ―ichro chꞌán. 
\p  
\v 19 A̱ ntá tíhi mé chrónkaxín chꞌín Jesús kíxin nkexrí tsꞌenxín chꞌín Pedro na mé tꞌaxrjexín nkexrí tsochjéhe chꞌán Dios kjuasáya. Ntá kjuixin ntáchro chꞌín Jesús kíxin: 
\p ―Chréhé tí janhan ―ichro chꞌán. 
\s1 Nkehe tso̱nhen tí chꞌín a̱ntsí tjuèhe chꞌín Jesús 
\p  
\v 20 Ntá kuinkátjíá chꞌín Pedro ntá kꞌuíkon chꞌán kíxin tinkáchréhe̱ tí chꞌín a̱ntsí tjuèhe chꞌín Jesús, na mé tí nkexro kjuákꞌe chjinaxón tí kjuákꞌe chꞌín Jesús tí kjóne sín tsíkjanchankíhi chꞌán tí chꞌín Jesús kíxin nkexro sinchekji chꞌán.\f + \fr 21:20 \ft Juan 13.25\f* 
\v 21 Ntá chꞌín Pedro kꞌuíkon chꞌán kíxin tinkáchréhe̱ tí chꞌín a ntá kjuanchankíhi chꞌán tí chꞌín Jesús kíxin: 
\p ―Ìnchéni, ¿a̱ ntá tí chꞌín i la nkehe tso̱nhen chꞌán a? ―ichro chꞌán. 
\p  
\v 22 Ntá kjuáte̱he chꞌín Jesús kíxin: 
\p ―Tí tjínka̱van na̱xa̱ chrókjuakꞌechón chꞌán tí chrókjan la jaha la chrókjuia̱téhya tíha. Ntá jaha la chréhé tí janhan ―ichro chꞌán. 
\p  
\v 23 Ntá kjuankíxin kjo tí sín kꞌuékꞌajiko chꞌín Jesús kíxin tsꞌenhya tí chꞌín a. Ntá jehya kíxin ntáchro chꞌín Jesús kíxin chrókꞌuenhya tí chꞌín a. Náhí. Ó jehí ntáchro chꞌán kíxin tí tjinkaon chꞌán na̱xa̱ chrókjuakꞌechón tí chꞌín a tí chrókjan chꞌán chrókui chꞌán chrókjuiatéhya tí chꞌín Pedro chrókjuanchankí chꞌán nkehe tso̱nhen í jnko chojni. 
\p  
\v 24 A̱ ntá tí nkexro a mé tí nkexro chrónka kíxin chaxín kónhen kaín tíha la ko ikjin chꞌán tí xroon i. Ntá ó noheni kíxin tí nkehe tsíkjin chꞌán la chaxín ntoá tíha. 
\p  
\v 25 Na̱xa̱ siín nchónhya nkehe kjua̱ko̱xi̱n chꞌín Jesús kjinhya janhan. Tí chrókꞌóna jnkojnko jnkojnko tíha ntáxrja̱n kíxin kjá chrókjuachahya tí chjasintajni chrókꞌuinka kaín tí xroon chrókꞌóna xi̱kaha. Amén. Ó tjen.