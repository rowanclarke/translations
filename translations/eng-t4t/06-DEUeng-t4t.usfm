\p
\v 8 “Sometimes \w it|strong="H3588"\w* \w will|strong="H3068"\w* \w be|strong="H1697"\w* very \w difficult|strong="H6381"\w* \w for|strong="H3588"\w* \w a|strong="H3068"\w* \w judge|strong="H4941"\w* \w to|strong="H3068"\w* \w decide|strong="H4941"\w* \w what|strong="H1697"\w* really \w happened|strong="H1697"\w*. \w He|strong="H3588"\w* \w might|strong="H3068"\w* \w be|strong="H1697"\w* trying \w to|strong="H3068"\w* \w decide|strong="H4941"\w* \w whether|strong="H4480"\w*, \w when|strong="H3588"\w* someone injured \w or|strong="H4480"\w* killed \w another|strong="H5061"\w* \w person|strong="H5927"\w*, \w he|strong="H3588"\w* \w did|strong="H3068"\w* \w it|strong="H3588"\w* accidentally \w or|strong="H4480"\w* deliberately. \w Or|strong="H4480"\w* \w he|strong="H3588"\w* \w might|strong="H3068"\w* \w be|strong="H1697"\w* trying \w to|strong="H3068"\w* \w decide|strong="H4941"\w* \w if|strong="H3588"\w* \w some|strong="H4480"\w* \w person|strong="H5927"\w* \w is|strong="H3068"\w* suing \w another|strong="H5061"\w* \w person|strong="H5927"\w* unfairly. \w If|strong="H3588"\w* \w in|strong="H3068"\w* \w some|strong="H4480"\w* \w town|strong="H8179"\w* \w it|strong="H3588"\w* \w is|strong="H3068"\w* very \w difficult|strong="H6381"\w* \w to|strong="H3068"\w* know \w what|strong="H1697"\w* really \w happened|strong="H1697"\w*, \w with|strong="H3068"\w* \w the|strong="H3588"\w* \w result|strong="H4480"\w* \w that|strong="H3588"\w* \w the|strong="H3588"\w* \w judge|strong="H4941"\w* \w cannot|strong="H4480"\w* \w decide|strong="H4941"\w* \w it|strong="H3588"\w*, \w you|strong="H3588"\w* \w should|strong="H3068"\w* \w go|strong="H5927"\w* \w to|strong="H3068"\w* \w the|strong="H3588"\w* \w place|strong="H4725"\w* \w that|strong="H3588"\w* \w Yahweh|strong="H3068"\w* \w our|strong="H3068"\w* \w God|strong="H3068"\w* \w has|strong="H3068"\w* chosen \w for|strong="H3588"\w* \w you|strong="H3588"\w* \add to worship him\add*.  
