\id 2TI
\ide UTF-8
\h II. Timotheungu
\toc1 Pauluni Dakani jaura II. Timotheungu
\toc2 II. Timotheungu
\toc3 2 Tim
\mt1 Pauluni Dakani jaura II. Timotheungu.
\c 1
\p 
\v 1 Paululu, Jesuni Christuni Apostel Godaia jertapaterinandru, tepia talpadakani jaurandru Christungu Jesungu,
\p 
\v 2 Timotheungu, ngakani kupa ngantjaluni: Manjula, ja kalumiltjamiltjarina, ja murla Goda Ngaperandru, ja Christu Jesu, ngaianani Kaparandru.
\p 
\v 3 Ngato Goda jurakokala wapaia, nunkangu ngani wodatarana ngamai ngaperaia jankundru ngara ngaiala kulikirini, worderu ngato jinkangu milingeru ngundrai ngakani ngatjinani tinkani ja ditjini,
\p 
\v 4 Ja ngani wolkareli nganai jidna najila, ngato ngundranani jinkani milkigildini, ngani mankinali manamiri pantjinanto.
\p 
\v 5 Ngato matja ngundrana warai, morlalu ngundrana wata jeljujelju, nauja jinkangu nganai, naupini ngopera ngamana wonti kadninani jinkanani Lois ja ngandrini jinkanani Eunika, ja ngato morlalu ngundrai bakana jinkangu.
\p 
\v 6 Jendrangundruja ngato jidna mangatandra wilpa ngankai, jundru Godaia poto nakaldra pulkananto, naupini jinkangu parai ngakani mara kuraterinandru.
\p 
\v 7 Ngangau Godali ngaianangu wata japaia Jaola jinkina wonti, a‐ai, ngurulaia ja ngantjanaia ja ninta maraia.
\p 
\v 8 Jeruja ngaiananaia Kaparaia tinkari ngankanandru wata nintali nganau, ja bakana wata ngakangundru, nunkani kanjangarilandru, a‐ai, ngakangu jela ketjaketjamai ngantjani jauraia Godaia ngurulandru,
\p 
\v 9 Nulia ngaianana kulkana wonti ja karkana wonti karkani kulikirieli, wata ngaianani ngankanandru, a‐ai, nunkani ngopera ngundranandru ja manjulandru, ninaia Nulia ngaianangu jinkina wonti Christungu Jesungu miljaru nguralindru,
\p 
\v 10 Ja karari wondraterina wonti ngaiananaia Kulkanipirnaia Christuni Jesuni wondraterinali, Nulia nari palimana wonti, ja tepi ja watamudani praitjani kurana wonti ngantjani jaurali,
\p 
\v 11 Nunkanaia Nulia ngana karkana wonti mandra ja Apostel ja ngujangujara jinkinietja kana koni.
\p 
\v 12 Jendrangundruja ngani jenia ketjaketjala wapaia, ja wata ngani nunkangundru nintali nganai; ngangau ngani milkila, worangu ngato morlalu ngundrala wapaia; ja ngato morlalu ngundrai, Nauja ngurunguru nganai, ninaia mindrani poto, nina Nulia ngakangu jinkina wonti, ngamalkijiribala nganai nunkanguka ditjielu.
\p 
\v 13 Tepia jaura mudlamalka ngamalkamai, ninaia jundru ngakangundru ngaranala, morlalu ngundranani ja ngantjanani, naupini Christungu Jesungu nganai.
\p 
\v 14 Mindrani poto ngumu ngamalkamai Jaolali kulikirieli, ninaia jundru maninala, Nauja ngaianangu nganai.
\p 
\v 15 Jidni milkila, pratjana Asiani ngakangundru karitjinala, tanangundru Phygellus ja Hermogenes.
\p 
\v 16 Kaparali Onesiphoruni pungani kalumiltjamiltjarina bakujeli jinkiatimai, ngangau nulu pota marapu ngana ngara waripanala, ja ngakani kanjangarindru wata nintali ngananala;
\p 
\v 17 A‐ai, Nau Romani matja wokarana, nulu ngana jiglerali wontina warai, ja ngana mankamankana warai.
\p 
\v 18 Kaparali nunkangu jinkinanto, nulu kalumiltjamiltjarini mankamankananto Kaparani nunkanguka ditjini; ja worderu nulu Ephesungu ngakangu mili ngananala, jidni morla milkila.
\c 2
\p 
\v 1 Jidni, ngakani kupajai, ngurunguru pantjiau manjulani, nauja Christungu Jesungu nganai,
\p 
\v 2 Ja mina jundru ngakangundru kiririna wonti morlalu kuranietja worangu jela, jenia kana talkuni jinkiau, tana ngurunguru nganai bakana nguruni ngujangujara jinkila.
\p 
\v 3 Ketjaketjau Jesuni Christuni julja talkuni jeribaka.
\p 
\v 4 Wata kulno, nau tirimalinaia wapai, palkuja mangini manujeli ngundrai, ngangau nau nunkangu, nulu nina matja patana, murlali nganananto.
\p 
\v 5 Bakana kulno tirimalinani, nulu wata pirapira manila nganai, nulu wata talku tirimalinani.
\p 
\v 6 Mita ngankanietjali, nulu jiglerali ngankai, tandra buru ngopera ngamalkananto.
\p 
\v 7 Ngundramai mina ngani jatai, Kaparali jinkangu warupotuni ngujamani jinkila nganai.
\p 
\v 8 Tjurujeli patamai Jesus Christus, ninaia Nulia narindru jiritjibana wonti, Nauja Davidani ngatamurandru nganai, ngakani ngantjani jaurandru,
\p 
\v 9 Nunkangu ngani ketjaketjai kanjangarielu, madlentji ngankanietja jeribaka; windri Godaia jaura wata dupudupu nganai.
\p 
\v 10 Jendrangundruja ngato pratjana manujeli patai kalkalkanilandru, ngangau bakana tanali murla maninanto, naupini Christungu Jesungu nganai, pirnala ngurali jela.
\p 
\v 11 Morlalu naupini jaura nganai: Ngaiana nunkangu jela matja palina, ngaiana bakana nunkangu jela tepi ngamala nganai;
\p 
\v 12 Ngaiana ketjaketjanani, ngaiana bakana nunkangu jela jirijiribala nganai; ngaiana kutibanani, jeruja bakana Nulia ngaianana kutibala nganai,
\p 
\v 13 Ngaiana wata morlalu ngundranani, Nauja wonki nganai; ngangau Nulia ngandandariai munta kutibaterila.
\p 
\v 14 Jenia nakaldra wilpa ngankau tanangu, ja morlalu kurau Kaparani, tana jaurandru wata jatamalini ngankananto, ngangau jenia baku nganai, ja windri ngaranietja tjautjau ngankai,
\p 
\v 15 Jiglerali ngankamai Godani ngurunguru wondraterila ngankanietja ninta nguru jeribaka, nulu morlaluja jaura talku puntibai.
\p 
\v 16 Jaura baku ja murumurundru kutingamai, ngangau tana milingeru morla tjautjaulani wiringala nganai,
\p 
\v 17 Ja tanani jaura kima jeribaka tajiterila nganai. Tanangunto Hymenäus ja Philetus,
\p 
\v 18 Tana morlalulandru tjiringana warai, ja jatai: Narindru jiritj ni matja pantjina warai, ja jeruja tanali palpaia morlalu ngundrana kokulterkibai.
\p 
\v 19 Godaia marda kapara ngurunguru parai, ja nulia ninapini malka morlalu ngamalkai: „Kaparali nunkanina ngujamai;“ ja: „Talkula panindru pilkirianau, warle Christuni tala dikai.“
\p 
\v 20 Punga pirnani wata windri koko marda maraljendru ja marda bulundru parai, a‐ai, bakana pitandru ja mitandru; ja palpa pilki pirnalaia, palpa pilki nintaia.
\p 
\v 21 Kulno jendrangundrupara talku kulirkaterinani, nau pirnalaia koko nganala nganai, kulikiri ja ngumu pungaia Kaparani, ngankana ngumu pratjanani matja ngankingana.
\p 
\v 22 Teria milkirinandru japa mindriau, karipaterintiau talkulani, morlalu ngundranani, ngantjanani, murlani, tanangu jela, tanali Kapara karkai ngatjila ngara kulikirindru.
\p 
\v 23 Jatamalini jakalkijiribamalini tjikatjika ja patipati narrau, ngangau jidni milkila, tanangundru windri tirimalini dunkai.
\p 
\v 24 Kaparaia mili wata tirimalinanto, a‐ai, nau malti nganananto kana warupotuni, ja kiri, ngujangujara jinkila, ja madlentji ngankanani worani patananto,
\p 
\v 25 Nulu manjujeli tatakanietja kurukurubananto, Godali tanangu madlentjandru karitjini jinkinanto kara morlaluja ngujamanaia,
\p 
\v 26 Tana nakaldra kalunguru pantjinanto ja dukaraterinanto kutjia mintindru, nulu tanana dupudupu patai nunkani jertapaterinaia.
\c 3
\p 
\v 1 Jenia ngujamau, ditji ngadala worangu miljaru ngurunguru wokarala nganai.
\p 
\v 2 Ngangau kana nganala nganai: Muntapata, mardatandrani ngulku pirna, pirna ngundraterinietja, kiri ngundraterinietja, ngirkibanietja, ngaperani ja ngandrini delkinietja, jurakokani pani, murumuru,
\p 
\v 3 Wolkareli pani, turuturu, kuringulkuterkanietja, miran tjati, tirietja, wata ngumu ngantjani,
\p 
\v 4 Wondawondanietja, kintjakintjanietja, wombatjarinietja, tana milkirini morla ngantjala nganai Godani.
\p 
\v 5 Tanali talkulaia malka ngamalkai, ja nunkani ngurula kutibana warai. Tanangundru ngamalkateriau.
\p 
\v 6 Tanangundru jenipara nganai, tana pungani dampai ja widla karkarkai, tanali madlentji marapu ngamalkai, ja milkirini pilki ja pilkieli tanana wiralkai,
\p 
\v 7 Tana milingeru kiririai, ja ngurali ngandandariai morlalu ngujamanaia wokarala.
\p 
\v 8 Worderu Jannes ja Jambres Mosingu tatakana wonti, jeruja bakana tanapini morlalulani tatakai, tanapini tjuru tjautjau ja wata ngurunguru morlalu ngundranani.
\p 
\v 9 Windri tanali jenia wata juri ngankala nganai, ngangau tanani tjikatjika pratjanani tinkari pantjila nganai, worderu pudlangu pantjina wonti.
\p 
\v 10 Jidni karipaterina warai ngakani ngujangujarani, ngakangu nguna milini, ngakani ngundranani, ngakani morlalu ngundranani, ngakani manjuni, ngakani ngantjanani, ngakani manjulani,
\p 
\v 11 Ngakani tirikaripaterinani ja ketjaketjanani, tana ngakangu pantjina wonti Antiochiani, Ikoniuni, Lystrani, jenipara tirikaripaterinani ngani tataura terkana wonti; ja pratjanandru Kaparali ngana kulkana wonti.
\p 
\v 12 Ja pratjanali, tana jertapateriai tepini Godani murlali ngamala Christungu Jesungu, tirikaripaterinani ketjaketjala nganai.
\p 
\v 13 Kana madlentji ja jedibanietja milingeru morla madlentji pantjila nganai, ngangau tanali karkarkala nganai, ja munta karkarkani nganala nganai.
\p 
\v 14 Jundru jenia ngamalkamai, mina jundru kiririna wonti, ja morlalu ngundrana wonti, ngangau jidni milkila, worangundru jundru kiririnala,
\p 
\v 15 Ja bakana jundru kupandru jaura worana kulikiri ngujamai, tanaia ngurunguru nganai jidna kiri ngankala tepia, morlalu ngundranali Christungu Jesungu.
\p 
\v 16 Jaura pratjana Godali pulkana wonti, ja tananaia bakana ngumu ngujangujaraia, dikidikibanaia, kurukurubanaia, punkanaia talkulani.
\p 
\v 17 Ngangau Godaia kana manamiri nganananto, ngankana ngumu pratjanani matja ngankingana.
\c 4
\p 
\v 1 Ngato jidna morlalu kurai Godani ja Kapara Jesungu Christungu, Nulia tepini ja narilani kalala jinkila nganai nunkani wondraterinani ja nunkani mililani.
\p 
\v 2 Jaura kaukaubau, wata mudau ditji talkuni ja wata talkuni, karkarkamai, kurukurubamai, dikidikibamai manju pirnali ja ngujangujarali.
\p 
\v 3 Ngangau miljaru nganala nganai, nunkangupini tanali ngujangujara tepi wata ngantjala nganai, a ai, tanani jertapaterinani tanali ngujangujara mapala nganai, tana talpa karakararananto.
\p 
\v 4 Ja tanali morlalundru talpa karitjimalkala nganai, ja jaura bakuja tjiringala nganai.
\p 
\v 5 Jidni warupotuni kalunguru nganamai, ketjaketjana manju patamai, ngantjani jauraia mangini ngankamai, ngamalkijiribani jinkani talku ngankamai.
\p 
\v 6 Tanali ngana karari tapani poto ngumu jeribaka nangai, ja ngakani danini ditji kupiri nganai.
\p 
\v 7 Ngani tirimalini ngumu tirimalina warai, ngato mindrini mudana warai, ngato morlalu ngundrani kulkana warai.
\p 
\v 8 Ja talkulaia pirapira ngakangu matja parai, ninaia Kaparali, kalala jinkinietja talkujeli, ngakangu jinkila nganai nunkanguka ditjini, ja wata windri ngakangu, a‐ai, bakana pratjanani, tanali nunkani wondraterini ngantjana warai.
\p 
\v 9 Pitariau nurujeli ngakangu wokarala:
\p 
\v 10 Ngangau Demasali ngana worarana warai, ngangau nulu ninapini mitala ngantjana warai, ja nau Thessalonichaia palkana warai, ja Crescens Galatiaia, ja Titus Dalmatiaia.
\p 
\v 11 Windri Lucas kulnulu ngakangunto ngamai. Marcus patamai ja nina wokaralkamai, ngangau nau ngumu pirna nganai ngakangu ngamalkijiribanaia.
\p 
\v 12 Tychikus ngato Ephesia jinpana warai.
\p 
\v 13 Kati pirna, nina ngato Troangu Karpusuni pungani woraranala, wokaralkamai, jidni wokaranani, ja bakana dakani jaura worana, pilki Pergamenta.
\p 
\v 14 Alexander, marda ngankanietjali, ngakangu madlentji marapu ngankana wonti. Kaparali nunkangu kalala jinkila nganai nunkani ngankanandru;
\p 
\v 15 Nunkangundru bakana jidni ngamalkateriau; ngangau nulu jaurani ngaiananani pirna tjakakana wonti.
\p 
\v 16 Ngakani jurajuralkaterini ditjini ngoperalani wata kulno ngakangu pankini terkana wonti, a‐ai, pratjanali ngana worarana wonti; (Godali) jenia tanangu wata ngokananto.
\p 
\v 17 Kapara ngakangu pankini terkana wonti, ja ngana ngurunguru ngankana wonti, ngakangundru kaukaubani jaura manamiri pantjinanto, ja kana ko warupotujeli ninaia ngarananto; ja Nulia ngana kulkana wonti pandipandi manandru.
\p 
\v 18 Ja Kaparali ngana kulkala nganai ngankana madlentji warupotundru, ja ngana kurakala nganai nunkani mililaia pariwilpani. Nunkangu pirnala nganaiatimai nguralindru nguralia. Amen.
\p 
\v 19 Mandurini jaura jinkiau Priskangu ja Aquilangu ja Onesiphorusuni pungalani.
\p 
\v 20 Erastus Korinthungu ngamantina wonti, ngato Trophimus muntja Miletungu woraranala.
\p 
\v 21 Pitariau widrila kilpaia wokarala. Mandurini jaura jinkangu jinpai Eubulsulu ja Pudensulu ja Linusulu ja Claudiali ja ngatata pratjanali.
\p 
\v 22 Kapara Jesus Christus jinkangu jaolani nganaiatimai. Manjula jurangunto nganaiatimai! 
