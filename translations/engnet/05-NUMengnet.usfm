\s1 Moses’ Decision  
\p
\v 5  \w Then|strong="H1696"\w* \w Moses|strong="H4872"\w* \w gave|strong="H6680"\w* \w a|strong="H3068"\w* ruling \w to|strong="H1696"\w* \w the|strong="H5921"\w* \w Israelites|strong="H3478"\w* \w by|strong="H5921"\w* \w the|strong="H5921"\w* \w word|strong="H6310"\w* \w of|strong="H1121"\w* \w the|strong="H5921"\w* \nd \+w Lord|strong="H3068"\+w*\nd*: “\w What|strong="H6310"\w* \w the|strong="H5921"\w* \w tribe|strong="H4294"\w* \w of|strong="H1121"\w* \w the|strong="H5921"\w* Josephites \w is|strong="H3068"\w* \w saying|strong="H1696"\w* \w is|strong="H3068"\w* \w right|strong="H3651"\w*.  
\v 6  \w This|strong="H2088"\w* \w is|strong="H3068"\w* \w what|strong="H1697"\w* \w the|strong="H3068"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w has|strong="H3068"\w* \w commanded|strong="H6680"\w* \w for|strong="H3068"\w* \w Zelophehad|strong="H6765"\w*’s \w daughters|strong="H1323"\w*: ‘\w Let|strong="H1961"\w* \w them|strong="H6680"\w* \w marry|strong="H1961"\w* whomever \w they|strong="H3068"\w* \w think|strong="H5869"\w* \w best|strong="H2896"\w*, only \w they|strong="H3068"\w* must \w marry|strong="H1961"\w* within \w the|strong="H3068"\w* \w family|strong="H4940"\w* \w of|strong="H3068"\w* \w their|strong="H3068"\w* father’s \w tribe|strong="H4294"\w*.  
\v 7  \w In|strong="H3478"\w* \w this|strong="H3588"\w* way \w the|strong="H3588"\w* \w inheritance|strong="H5159"\w* \w of|strong="H1121"\w* \w the|strong="H3588"\w* \w Israelites|strong="H3478"\w* \w will|strong="H3478"\w* \w not|strong="H3808"\w* \w be|strong="H3808"\w* \w transferred|strong="H5437"\w* \w from|strong="H3478"\w* \w tribe|strong="H4294"\w* \w to|strong="H3478"\w* \w tribe|strong="H4294"\w*. \w But|strong="H3588"\w* \w every|strong="H1121"\w* \w one|strong="H3808"\w* \w of|strong="H1121"\w* \w the|strong="H3588"\w* \w Israelites|strong="H3478"\w* \w must|strong="H1121"\w* retain \w the|strong="H3588"\w* ancestral \w heritage|strong="H5159"\w*.  
\v 8  \w And|strong="H1121"\w* \w every|strong="H3605"\w* \w daughter|strong="H1323"\w* \w who|strong="H3605"\w* possesses \w an|strong="H1961"\w* \w inheritance|strong="H5159"\w* \w from|strong="H3478"\w* \w any|strong="H3605"\w* \w of|strong="H1121"\w* \w the|strong="H3605"\w* \w tribes|strong="H4294"\w* \w of|strong="H1121"\w* \w the|strong="H3605"\w* \w Israelites|strong="H3478"\w* \w must|strong="H1121"\w* \w become|strong="H1961"\w* \w the|strong="H3605"\w* wife \w of|strong="H1121"\w* \w a|strong="H3068"\w* \w man|strong="H1121"\w* \w from|strong="H3478"\w* \w any|strong="H3605"\w* \w family|strong="H4940"\w* \w in|strong="H3478"\w* \w her|strong="H3605"\w* \w father|strong="H1121"\w*’s \w tribe|strong="H4294"\w*, \w so|strong="H4616"\w* \w that|strong="H3605"\w* \w every|strong="H3605"\w* \w Israelite|strong="H3478"\w* \w may|strong="H1961"\w* \w retain|strong="H3423"\w* \w the|strong="H3605"\w* \w inheritance|strong="H5159"\w* \w of|strong="H1121"\w* \w his|strong="H3605"\w* fathers.  
\v 9  \w No|strong="H3808"\w* \w inheritance|strong="H5159"\w* \w may|strong="H3478"\w* pass \w from|strong="H3478"\w* \w tribe|strong="H4294"\w* \w to|strong="H3478"\w* \w tribe|strong="H4294"\w*. \w But|strong="H3588"\w* \w every|strong="H3588"\w* \w one|strong="H3808"\w* \w of|strong="H1121"\w* \w the|strong="H3588"\w* \w tribes|strong="H4294"\w* \w of|strong="H1121"\w* \w the|strong="H3588"\w* \w Israelites|strong="H3478"\w* \w must|strong="H1121"\w* retain \w its|strong="H3588"\w* \w inheritance|strong="H5159"\w*.”   
\p
\v 10  \w As|strong="H6213"\w* \w the|strong="H6213"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w had|strong="H3068"\w* \w commanded|strong="H6680"\w* \w Moses|strong="H4872"\w*, \w so|strong="H3651"\w* \w the|strong="H6213"\w* \w daughters|strong="H1323"\w* \w of|strong="H3068"\w* \w Zelophehad|strong="H6765"\w* \w did|strong="H6213"\w*.  
\v 11  \w For|strong="H1121"\w* \w the|strong="H1961"\w* \w daughters|strong="H1323"\w* \w of|strong="H1121"\w* \w Zelophehad|strong="H6765"\w* – \w Mahlah|strong="H4244"\w*, \w Tirzah|strong="H8656"\w*, \w Hoglah|strong="H2295"\w*, \w Milcah|strong="H4435"\w*, \w and|strong="H1121"\w* \w Noah|strong="H5270"\w* – \w were|strong="H1961"\w* married \w to|strong="H1961"\w* \w the|strong="H1961"\w* \w sons|strong="H1121"\w* \w of|strong="H1121"\w* \w their|strong="H1961"\w* uncles.  
\v 12  \w They|strong="H5921"\w* \w were|strong="H1961"\w* married \w into|strong="H5921"\w* \w the|strong="H5921"\w* \w families|strong="H4940"\w* \w of|strong="H1121"\w* \w the|strong="H5921"\w* Manassehites, \w the|strong="H5921"\w* \w descendants|strong="H1121"\w* \w of|strong="H1121"\w* \w Joseph|strong="H3130"\w*, \w and|strong="H1121"\w* \w their|strong="H5921"\w* \w inheritance|strong="H5159"\w* \w remained|strong="H1961"\w* \w in|strong="H5921"\w* \w the|strong="H5921"\w* \w tribe|strong="H4294"\w* \w of|strong="H1121"\w* \w their|strong="H5921"\w* \w father|strong="H1121"\w*’s \w family|strong="H4940"\w*.   
\p
\v 13  These \w are|strong="H1121"\w* \w the|strong="H5921"\w* \w commandments|strong="H4687"\w* \w and|strong="H1121"\w* \w the|strong="H5921"\w* \w decisions|strong="H4941"\w* \w that|strong="H3068"\w* \w the|strong="H5921"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w commanded|strong="H6680"\w* \w the|strong="H5921"\w* \w Israelites|strong="H3478"\w* \w through|strong="H3027"\w* \w the|strong="H5921"\w* \w authority|strong="H3027"\w* \w of|strong="H1121"\w* \w Moses|strong="H4872"\w*, \w on|strong="H5921"\w* \w the|strong="H5921"\w* \w plains|strong="H6160"\w* \w of|strong="H1121"\w* \w Moab|strong="H4124"\w* \w by|strong="H3027"\w* \w the|strong="H5921"\w* \w Jordan|strong="H3383"\w* \w River|strong="H3405"\w* \w opposite|strong="H5921"\w* \w Jericho|strong="H3405"\w*.   