\li1 
\v 33 लोद, हादीद व ओनोचे 725,
\li1 
\v 34 यरीहोचे 345,
\li1 
\v 35 सनाहाचे 3,630,
\b
\lh 
\v 36 याजकांचे वंशज:
\li1 यदायाहचे (येशूआच्या पितृकुळातील) 973,
\li1 
\v 37 इम्मेरचे 1,052,
\li1 
\v 38 पशहूरचे 1,247,
\li1 
\v 39 हारीमचे 1,017,
\b
\lh 
\v 40 लेवीचे वंशज:
\li1 येशूआ व कदमीएलचे (होदव्याहचे कुटुंबाद्वारे) 74,
\b
\lh 
\v 41 संगीतकार:
\li1 आसाफचे वंशज 128,
\b
\lh 
\v 42 मंदिराचे द्वारपाल: खालील लोकांचे वंशजः
\li1 शल्लूमचे, आतेरचे, तल्मोनचे, अक्कूबचे, हतीताचे व शोबाईचे 139,
\b
\lh 
\v 43 मंदिराचे सेवकांचे वंशज:
\li1 झीहाचे, हसूफाचे, तब्बावोथचे,
\li1 
\v 44 केरोसचे, सीआहाचे, पादोनचे,
\li1 
\v 45 लबानाहचे, हगाबाहचे, अक्कूबचे,
\li1 
