\id 2TI 2timpnq.sfm Panao Quechua 
\h 2 TIMOTEO 
\toc1 Timoteuman San Pablo cartacushan 2 
\toc2 2 TIMOTEO 
\toc3 2Ti 
\mt1 Timoteuman San Pablo cartacushan 2 
\io1 Tantiyacunanchipaj: 
\ip Pablo cay cartata isquirbiran Timoteuman. Timoteupita musyayta munar, 1 Timoteupa jallarinanta liguinqui. Cay cartata Roma carsilpita-pacha Pablo isquirbiran. Wañuchinanta mayar, Timoteo watucunanta munaran. Ichanga mana camäpacuranchu. Chaymi sumaj anyapänanpaj cartacuran. 
\io1 Pablo isquirbiran: 
\io2 Mana pingacullar Jesúspa alli willacuyninta willapäcunanpita: \ior 2 Timoteo 1.1–18\ior*. 
\io2 Alli murucu capitanninpa shiminta wiyacushan-jina Jesústa wiyacunanpita: \ior 2 Timoteo 2.1–26\ior*. 
\io2 Jipata achcaj pantachicuj ricarimunanpita, mana uticällar Tayta Diosninchipa shiminta tantiyachicunanpita: \ior 2 Timoteo 3.1–17\ior*. 
\io2 Wañuy jananćhu captinsi mana llaquicushanpita, watucuj aywananta munashanpita, janaj pachaćhu Tayta Jesús alli cawayman ćhurananpita: \ior 2 Timoteo 4.1–22\ior*. 
\c 1  
\s1 Pablo wamayashan 
\p  
\v 1 Timoteo, nuwa Pablo cartacamü. Washäcuj Jesúspa caćhanmi caycä. Tayta Diosninchi camacächiptin, shiminta willapäcur puriycä. Washäcuj Jesúspa shiminta ćhasquicuptinchi, alli cawayta tarichimänanchi.  
\v 2 Timoteo, wamrä-yupaymi canqui. Tayta Diosninchipis, Tayta Jesucristupis yanapayculläshunqui. Llaquipayculläshunqui. Allilla cawaycachilläshunqui. 
\s1 Tayta Diosninchita alliman ćhurashan 
\p  
\v 3 Unay yawar-masïcuna llapan shungunwan manchapacushan-jina nuwapis llapan shungüwan Tayta Diosninchita manchapacü. Shungüćhu ima juchatapis mana pacarächïchu. Timoteo, pagas-junajpis jampaj Tayta Diosninchita mañacuycä. Mana jungajchu.  
\v 4 Llaquicur wagashayquita yarpar, yapay tincuyta sumaj munaycä. Tincur, jatunpa cushicushäpaj.  
\v 5 Awillayqui Loidapis, mamayqui Eunicipis llapan shungunwan Tayta Diosninchita wiyacushanta musyä. Chaymi jampis Tayta Diosninchita llapan shunguyquiwan wiyacushayquita tantiyacushcä. 
\s1 Jesúspa shiminta willacur, ama pingacushuwanchu 
\p  
\v 6 Umayquiman maquïta ćhuraycur mañacuptï, Tayta Diosninchi yaćhayta camapushcashunqui. Ama jasacanquimanchu. Manchäga yaćhacushayquiman-tupu imatapis sumaj ruranquiman.  
\v 7 Tayta Diosninchi Espíritu Santuwan yanapaycämanchi. Chaymi imatapis ama manchacushuwanchu. Imaman ćhayaptinchisi, payga shacyächimanchi. Yanapämanchi runa-masinchitapis llaquinanchipaj, imatapis sumaj tantiyacurir rurananchipaj.  
\v 8 Chaymi Taytanchi Jesúspita willapäcushayqui-janan, carsilman wićhgachimashan-janan pampaman ćhurashuptiquisi, ama pingacunquichu. Manchäga Tayta Diosninchi shacyächimashanchiman-tupu shiminta willapäcushun runacuna ñacachimaptinchisi. 
\q1  
\v 9 Tayta Diosninchi jishpichimashcanchi. 
\q1 Acracamashcanchi maquillanćhu cawananchipaj 
\q1 Mana allita rurashanchipitachu acracamashcanchi. 
\q1 Manchäga llaquipämashpanchi shungun munaptin acracamashcanchi. 
\q1 Jishpichimänanchi-raycur Washäcuj Jesústa caćhamusha. 
\q1 Mana imasi caycaptillan, llapanta camacächisha. 
\q1  
\v 10 Tayta Diosninchi llaquipäcuj cashanta tantiyacushcanchina. 
\q1 Washäcuj Jesús ricarimushana. 
\q1 Payga Washämajninchi. 
\q1 Wañuytasi illarachisha. 
\q1 Alli willapatapis tantiyachimashcanchi. 
\q1 Shiminta wiyaptinchi, shungunchipis achicyacäcusha. 
\q1 Mana ushyacaj cawaytapis tarichimanchi. 
\p  
\v 11 Caycunata willapäcunäpaj Tayta Diosninchi cargüman ćhuramasha. Quiquin acracamasha caćhan canäpaj, shiminta willapäcunäpaj, shiminta tantiyachicunäpaj.  
\v 12 Cananga Tayta Diosninchipa shiminta willapäcur purishäpita carsilćhu ñacaycä. Chaypis mana pingacüchu. Nuwaga Tayta Diosninchiman yupachicü. Paypa maquinćhu cawaycä. Cargüta ćharcushä junajcaman mana caćharimangachu.  
\v 13 Chaymi Tayta Diosninchipa shungun munashanta ruranayquipaj shimïta wiyacunquiman. Washäcuj Jesúsman yupachicur, runa-masiquitapis llaquipanquiman.  
\v 14 Jesúspita willapäcushaga sumaj alli. Chaymi carguyquita ćharcunayquipaj Espíritu Santu yanapaycäshunqui. Payga maquinćhu purichimanchi. 
\p  
\v 15 Musyashayquinuypis Asia marcacunaćhu irmänucuna llapan-yupay jaguiraycamasha. Figeluwan Hermógenespis jaguiraycamasha.  
\v 16 Irmänu Onesíforutam ichanga wasinpa Tayta Jesús sumaj yanapaycullächun. Onesíforuga mana yamacällar shacyächimasha. Carsilarächimaptinsi, mana pingacushachu.  
\v 17 Manchäga Roma marcacaman shamusha. Mana tarimashancaman jamaytapis mana tarishachu.  
\v 18 Éfeso marcaćhu puriptïpis, sumaj yanapämasha. Yanapämashanta musyanqui. Chaymi payta llaquipashpan cutimushan junaj Tayta Jesús alli cawayman ćhuraycullächun. 
\c 2  
\s1 Jesús-janan ñacar, ama llaquicushuwanchu 
\p  
\v 1 Wawallau Timoteo, Washäcuj Jesúsga llaquipäcujmi. Payga imaćhüpis shacyächishunqui.  
\v 2 Llapan runapa ricay ñawinćhu willapäcushäcunata alli shungu runacunata willapanquiman. Paycunapis Tayta Diosninchipa shiminta tantiyachicunman. 
\p  
\v 3 Shiminta willapäcushanchipita tincuchiypa tantiyacushun. Alli murucucuna ñacashan-jina nuwanchipis Washäcuj Jesús-janan ñacayta ćhasquicushuwan.  
\v 4 Murucu cashancaman capitannin alli ricananta munar, ćhacranćhüpis manash arunchu.  
\v 5 Pucllajpis gänananpaj siñalashan räya ćhaupillanćhüshi pucllan.  
\v 6-7 Ćhacra runapis murupacushan puguptin, quiquinräshi puntata micun. Tincuchiypa willapashajcunata tantiyacunquiman. Tayta Diosninchipis yanapäshunquipämi sumaj tantiyacunayquipaj. 
\p  
\v 8 Unay mandaj Davidpa willcan Washäcuj Jesústa ama junganquichu. Payta wañushanpita Tayta Diosninchi cawarachimusha. Chay alli willapata willapäcur puriycä.  
\v 9 Jesúspa shiminta willapäcur purishäpita ñacaycächiman. Cadinarcurmi juyu runata-jina carsilaraycächiman. Tayta Diosninchipa shimintam ichanga carsilarächiyta mana camäpacunchu.  
\v 10 Chaymi imaman ćhayarpis, Tayta Diosninchipa shiminta willacur purinä-cashan mana rimacüchu. Chaynuy ruraptï, acracushan runacunatapis Washäcuj Jesús jishpichinga. Shiminta ćhasquicuptin, Tayta Diosninchipis ñaupanćhu mana ushyacaj cawayta tarichingapaj. 
\p  
\v 11 Rasuntaćhi rimapäcunpis: 
\q1 «Jesús-janan wañush carga, 
\q1 Jesúswanmi imaycamanpis cawashunpaj. 
\q1  
\v 12 Jesús-janan mana yamacällar ñacarpis, 
\q1 Jesústa mandäshishunpaj. 
\q1 Wasguiptinchim ichanga, 
\q1 Jesúspis wasguimäshunpaj. 
\q1  
\v 13 Shiminchita mana ćharcuptinchisi, 
\q1 Jesús shiminta ćharcun. 
\q1 Alli shungu cashannuylla imay-imaypis cawacun» nir. 
\s1 Mana tincupänacunanpaj willapashan 
\p  
\v 14 Willapashajta Tayta Diosninchipa ricay ñawinćhu irmänucunata willapanqui. Llapanta yarpächinqui. Quiquin-pura ama tincupänacuchunchu. Tincupänacurga, imatapis mana jurgunchu. Wiyajcunapis Tayta Diosninchiman mananaćhi yupachicunganachu.  
\v 15 Chaymi Tayta Diosninchipa shungunman tincunayquipaj alli aruj runa-jina aruyniquita sumaj mirachinqui. Willapäcurpis, Tayta Diosninchipa shimillanta tantiyachinquiman pingayman mana ćhayanayquipaj.  
\v 16 Tayta Diosninchita wasguipajcuna-jina ama rimanquichu. Paycunaga mana musyayninwan shimin atipashallanta riman. Tayta Diosninchitapis mana manchapacunchu.  
\v 17 Tincupänacujcunapa yarpashanga jiri-jina miran. Paycunapa llupinpa jatirmi, Himeneuwan Filetupis  
\v 18 llutanta rimar puriycan. «Wañushcuna mayna cawarimusha» niptin, waquin irmänunchicunapis Jesúsman manaćhi yupachicunganachu. 
\p  
\v 19 Tayta Diosninchi yarpashanmi ichanga mana imaypis rucacanchu. Paypa shiminćhu nin: «Maquinćhu cawajcunata Tayta Diosninchi ricsin.»\f * \fr 2:19 \ft Números 16.5.\f* Chaynuypis nin: «Tayta Diosninchita jayarajcuna jucha aparicuypita ashucunman.» 
\p  
\v 20 Tincuchiypa tantiyacushun. Puchuy-puchuy jananćhu cawaj runapa wasinćhu achcash lätuncuna caycan: waquinga juripitash, waquinnash jillaypita. Waquinshi ichanga jirullapita, mitullapita. Waquintash alli ñawinpa rican, waquintanash mana. Chay-jina runacunapis caycan.  
\v 21 Juchanpita wanacuptin, alli ñawinpana Tayta Diosninchi pitapis ricanga. Paypa shungun munashannuylla cawar, shungunmanpis tincunga. Shungun munashallanta rurar, cawanga. 
\p  
\v 22 Müsucuna shungun munapashallanta ruran. Jammi ichanga Tayta Diosninchipa shungun munashallanta ruranquiman. Payllaman yupachicunquiman. Runa-masiquita llaquipanquiman. Llapan irmänucunawan allilla cawanquiman. Paycuna llapan shungunwan jayarar, Tayta Diosninchita manchapacun.  
\v 23 Runa tincupänacushanman ama jaticanquichu. Paycuna upa cayninwan, mana musyayninwan chiquinacuyllaman ćhayan.  
\v 24 Tayta Diosninchipa maquinćhu cawaj runa runa-masinwan ama tincupänacunmanchu. Manchäga llapanwan alli tantiyanacunman. Tantiyayta mana atipaptinsi, alli shimillanpa tantiyachinman.  
\v 25 Tincupajcunataga alli shimillanpa piñacunman. Capasćhari Tayta Diosninchi camacächiptin, wanacunga. Wanacuptinga, shiminpis shungunman ćhayanga.  
\v 26 Chayrämi supaypa maquinćhu cawashanpita Tayta Diosninchi jishpichinga. Supaypis maquinćhu mana purichinganachu. 
\c 3  
\s1 Jipata sasa caway cananpaj willacushan 
\p  
\v 1 Timoteo, sumaj tantiyacunquiman. Jipataga sasa caway canga.  
\v 2 Waquin runacuna runa-masinta mana llaquipar, quiquillanpaj yarpaćhacunga. Jillayllapaj wañunga. Sumaj-tucur alli cashanta musyachicunga. Alli-tucullar puringa. Runa-masinta ashllinga. Maman-taytantapis mana wiyacungachu. Yupay-tucuyllaćhu cawanga. Tayta Diosninchita mana manchapacungachu.  
\v 3 Juyu cashpan cuyapäcuytapis mana yaćhangachu. Jagayash cashpan piwanpis alli ricanacuyta mana yaćhangachu. Tumpacullar puringa. Shungun munashallanta imatapis ruranga. Pasaypa juyu runa canga. Tayta Diosninchipa shungun munashannuy rurajcunatapis chiquinga.  
\v 4 Ishcay cära car, shimintapis mana ćharcungachu. Pishi-yarpayyuj canga. Pingacuyninpis ushyacash canga. Shungun munapashallanta imatapis rurar, Tayta Diosninchipäga mana imasi jucungachu.  
\v 5 Runa ricanallanpämi payta manchapacuj-tucunga. Shimintam ichanga wiyacuytapis mana munangachu. Chay-niraj runacunapita witicunquiman. 
\p  
\v 6 Waquincunana yaćhaj-tucur warmicuna-raycullar juc runacunapa wasinman aywan. Warmicunapis pishi-yarpayyuj car, juchacushanpita llaquish car, shungun munapashallanta ashij car,  
\v 7 runapa shimintapis ćhasquicuj-ćhasquicujlla shuyaycan. Ichanga chay warmicuna Tayta Jesús pï cashantapis mana imaysi tantiyacungachu.  
\v 8 Chay yaćhaj-tucuj runacunaga Janéswan, Jambréswan tincun. Paycuna Moisésta ticrapuran. Chaynuymi yaćhaj-tucujcunapis Tayta Diosninchita ticrapun. Jucha aparicuyllaman chutacun. «Tayta Diosninchiman yupachicü» nirpis, shimillan riman.  
\v 9 Yaćhaj-tucurpis, allićhüga mana llucshingachu. Upa cashanga llapan ricay musyacanga. Janéswan Jambrés pingayman ćhayashan-jina paycunapis pingayman ćhayanga. 
\s1 Timoteuta piñapashan 
\p  
\v 10 Timoteo, jammi ichanga sumaj purïshimashcanqui. Llapan shunguyquiwan shimïta ćhasquicushcanqui. Nuwa-jina cawashcanqui. Yarpashätapis tantiyacushcanqui. Yupachicushä-jina Tayta Diosninchiman yupachicuycanqui. Tantiyacushä-jina imapitapis tantiyacunqui. Llaquipäcushä-jina pï-maytapis llaquipanqui. Mana yamacashä-jina imaman ćhayarpis, ama yamacanquimanchu.  
\v 11 Antioquía marcaćhu, Iconio marcaćhu, Listra marcaćhu jaticaćhar ushyamashantapis, ñacachimashantapis musyanqui. Tucuy-jinanpa ñacachimaptinpis, Tayta Diosninchi jishpichimasha.  
\v 12 Pipis Washäcuj Jesúspa maquinćhu cawar Tayta Diosninchipa shungun munashanta rurarga, chiquir ushyash cawanga. Ñacaymanpis ćhayanga.  
\v 13 Yaćhaj-tucur juchaćhu arujcunapa shungunmi ichanga waran-waran juyu cayman ćhayanga. Paycunaga yaćhaj-tucursi, rimashanta mana musyanchu. Shiminta ćhasquicujcunatapis llutanta yaćhaycächin. 
\p  
\v 14 Timoteo, jammi ichanga sumaj yaćhacushcanqui. Shunguyquiman Tayta Diosninchipa shimin ćhayash caycaptin, ama junganquichu. Nuwacuna willapashajta musyanqui.  
\v 15 Wamralla cashayquipita-pacha Tayta Diosninchipa shiminta yaćhacushcanqui. Shiminta yaćhacur, shungun yarpashantapis tantiyacunquipaj. Chaymi Washäcuj Jesúsman yupachicushpanchi jishpichimänanchitapis tantiyacunchi.  
\v 16 Tayta Diosninchi quiquinmi shiminta isquirbichisha. Paypa shimin allim. Chaymi shungun yarpashallanta tantiyachicushuwan. Runa llutanta yarpaptinpis, shimin nishannuylla tantiyachicushuwan. Llutanta ruraptinpis, piñapäshuwan. Allilla cawananpaj anyapäshuwan.  
\v 17 Maquinćhu cawashpan shiminta tantiyacurmi, Tayta Diosninchipa shungun munashallanta rurar cawanga. 
\c 4  
\s1 Washäcuj Jesúspa willapanta imaysi willacunanpaj shacyächishan 
\p  
\v 1 Washäcuj Jesús cutimur, llapan runata maquinćhu purichinga. Wañushcunatapis, cawajcunatapis imata rurar cawashanpita tapunga. Chaymi cananga shimïta sumaj wiyacunayqui. Tayta Diosninchipa ricay ñawinćhüpis, Washäcuj Jesúspa ricay ñawinćhüpis willapaycaj.  
\v 2 Runacuna wiyaptinpis, mana wiyacuptinpis, Tayta Diosninchipa shiminta mana yamacällar willapäcunquiman. Llutanta yarpaptin, juchaćhu aruptin, piñapanquiman. Chaynuypis alli shimillayquipa shacyächinquiman. Tantiyacurir-tantiyacurir paycunata yaćhachinquiman.  
\v 3 Jipata runacuna Tayta Diosninchipa shiminta wiyayta mana munangachu. Manchäga shungunman tincushallanta rimajcunata ashinga. Paycunaga imatapis mishquichipayllapa yaćhachinga.  
\v 4 Tayta Diosninchipa shiminta mana wiyayta munar, upa-tucunga. Chaymi imatapis umanman ćhayashallanta rimar puricunga.  
\v 5 Jammi ichanga tantiyacushpayqui ama llutäpacunquichu. Runacuna ñacachishuptiquisi, ćhasquicunquiman. Mana yamacällar pï-maytapis Jesúspita willapanqui. Carguyquitapis sumaj ćharcunqui. 
\p  
\v 6 Wañuy janäćhüna caycan. Wañuchimaptin, Tayta Diosninchita jarashan-yupay yawarnïpis jićhash canga.  
\v 7 Murucucuna ñacashan-jina tucuy-jinanpa ñacashcä. Pucllajcuna callpan ushyacashancaman pucllashan-jina nuwapis llapan shungüwan cargüta ćharcushcä. Tayta Jesúspa shimin nishannuylla cawar, willapäcushcä.  
\v 8 Tayta Diosninchipa shungunman tincushäpita allita ćhasquij-ćhasquij-jina Tayta Jesús alliman ćhuramänanta shuyaraycä. Ichanga mana nuwallatachu alliman ćhuramanga. Manchäga allillata rurashpan llapan shungunwan cutimunanta shuyarajcunatapis alliman ćhuranga. Cutimushan junaj llapan runapa shungunta musyapar, allimanpis, mana allimanpis ćhuranga. 
\s1 Timoteuta yapay piñapashan 
\p  
\v 9 Timoteo, watucamaj juclla shamunqui, ari.  
\v 10 Irmänu Demás imancunapäpis alläpa yarpaćhacur, quiquilläta jaguiraycamar Tesalónica marcaman aywacusha. Crescentina Galacia quinranman aywacusha. Tituna Dalmacia quinranman aywacusha.  
\v 11 Lucasllana yanagaycäman. Chaymi Marcoswan ishcaniqui shamunqui. Payga Tayta Diosninchipa shiminta willapäcuptï, yanapämanga.  
\v 12 Tíquicuta Éfeso marcaman caćhashcä.  
\v 13 Shamurga, punchütapis apacamunqui. Tróade marcaćhu irmänu Carpupa wasinćhu jaguimushcä. Librücunatapis apacamunqui. Pitush-caj papilcunatapis jungamurunquiman. 
\p  
\v 14 Jïru tacaj Alejandrumi ichanga tucuy-jinanpa pampaman ćhuramasha. Llutanta rurashanman-tupu Tayta Diosninchi unyanta cutichinga.  
\v 15 Chay runaga imata willapäcushanchitapis pampaman ćhuraycan. Chaymi mayaj-mayajlla canayquipaj willapaycaj. 
\p  
\v 16 Puntata Roma marcaćhu auturdäman ćhayaptï, pipis mana nanachicamashachu. Llapanmi jaguiraycamasha. Jaguiramajcunapa unyanta Tayta Diosninchi ama yarparanmanchu.  
\v 17 Japallä caycaptïsi, Tayta Jesús mana caćharimashachu. Manchäga waran-waran shacyaycächiman. Chaymi shiminta sumaj willapäcushcä jäpa runacunapis wiyacunanpaj. Maquinćhu purichimar, wañuypitapis jishpichimasha. Micucuj liyunpita washämaj-jina wañuypitapis washämasha.  
\v 18 Juchallicujcunapa maquinpitapis Tayta Jesús washämanga. Janaj pachaman shuntacamanga. Ñaupallanćhu purichimanga. Chaymi paytaga imay-imaypis llapan runa alliman ćhuraycullächun. Chaynuy caycullächun. 
\s1 Cartapa ushyanan 
\p  
\v 19 «Pablush wamayaycäshunqui» ninqui mama Priscilata,\f * \fr 4:19 \ft «Priscila» mama Priscapa cuyay cutin caran.\f* runan Aquilata, Onesíforucunata.  
\v 20 Irmänu Erastuta Corinto marcaćhu jaguiycamushcä. Trófimutapis jishya chariptin, Mileto marcaćhu jaguiycamushcä.  
\v 21 Tamya quilla mana ćhayamushancamalla juclla shamunqui, ari. Irmänunchi Eúbulo, Pudente, Lino, irmäna Claudia, waquin irmänucunapis wamayaycäshunqui.  
\v 22 Tayta Jesús llapaniquita yanapayculläshunqui. Tayta Diosninchipis llaquipayculläshunqui. Chayllana.