\p
\v 15 \w He|strong="H1931"\w* hadn't \w even|strong="H5921"\w* \w finished|strong="H3615"\w* \w praying|strong="H1696"\w* \w when|strong="H1961"\w* \w he|strong="H1931"\w* \w saw|strong="H2009"\w* \w Rebekah|strong="H7259"\w* \w coming|strong="H3318"\w* \w to|strong="H1696"\w* \w get|strong="H3318"\w* water, carrying \w her|strong="H5921"\w* water \w jar|strong="H3537"\w* \w on|strong="H5921"\w* \w her|strong="H5921"\w* \w shoulder|strong="H7926"\w*. \w She|strong="H1931"\w* \w was|strong="H1961"\w* \w the|strong="H5921"\w* daughter \w of|strong="H1121"\w* \w Bethuel|strong="H1328"\w*, \w son|strong="H1121"\w* \w of|strong="H1121"\w* Milkah. Milkah \w was|strong="H1961"\w* \w the|strong="H5921"\w* \w wife|strong="H1696"\w* \w of|strong="H1121"\w* Abraham's brother \w Nahor|strong="H5152"\w*.  
