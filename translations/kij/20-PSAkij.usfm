\q2 deli ikatumtuwoli matausina metoya osilagi. 
\q1  
\v 34 E avai tuta wala bikatumati mimilisi, 
\q2 e kesalaga komwaidosi bitovilakaisi matauna, 
\q2 bininavilasi e bikayubabaisi baisa matauna. 
\q1  
