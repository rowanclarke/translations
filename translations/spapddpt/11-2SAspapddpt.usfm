\c 13
\s1 La violación de Tamar por Amnón
\p 
\v 1 Absalón, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w David|strong="H1732"\w*, \w tenía|strong="H1961"\w* una hija muy \w hermosa|strong="H3303"\w* \w llamada|strong="H8034"\w* Tamar. \w Aconteció|strong="H1961"\w* \w después|strong="H1961"\w* \w de|strong="H1121"\w* \w esto|strong="H3651"\w* \w que|strong="H1121"\w* Amnón, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w David|strong="H1732"\w*, \w se|strong="H1961"\w* enamoró \w de|strong="H1121"\w* ella.
