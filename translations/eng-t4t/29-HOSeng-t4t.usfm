\q2 there \w will|strong="H5971"\w* \w be|strong="H5971"\w* no rain \w to|strong="H5971"\w* water \w the|strong="H5971"\w* ground [MET].
\q1 
\v 4 \w I|strong="H3588"\w* \w will|strong="H3808"\w* \w not|strong="H3808"\w* pity \w the|strong="H6440"\w* \w people|strong="H3808"\w*,
\q2 \w because|strong="H3588"\w* \w they|strong="H3588"\w* \w have|strong="H3808"\w* \add abandoned me\add* \w as|strong="H3588"\w* [MET] prostitutes \w abandon|strong="H5493"\w* \w their|strong="H6440"\w* husbands.
\q1 
\v 5 \w Their|strong="H7760"\w* parents \w are|strong="H3117"\w* \w like|strong="H4057"\w* prostitutes [MET]: \w they|strong="H3117"\w* \w have|strong="H3117"\w* been unfaithful \add to me\add*,
