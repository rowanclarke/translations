\id HAB Habakkuk in Boko, Ross Jones 2/08
\h Abaku
\toc1 Abaku
\toc2 Abaku
\toc3 Abk
\mt1 ABAKU
\imt1 Yã́ pↄ́ kú láɛ bee guuↄ
\ip Lápi lɛ́ dɛ̃ɛ pↄ́ ãnabi Abaku kà yãpãsĩ gↄↄ bↄↄlɛkɛwɛ̃ɛ. Ì wɛ̃nadↄ̃ gbɛ̃́ↄnɛ, ì vãi pↄ́ aaì kɛↄ bↄnɛ́ gupuau, ì wiilɛ Luawa a yã́ musu, ì pↄnakɛ tó Lua a wabikɛa mà. A lápi kɛ̃̀ e wàↄ gɛ́ Yesu Kilisi ii wɛ̃̀ 700 taawa. Gↄↄ bee Babiloniↄ gbãa lɛ́ kã́fĩ mɛ́ Isailiↄ ku bíli guu ń kua zia yã́ ń ń kua ń Luaoo yã́ musu.
\ip Lua yãwè ãnabiwa, à yã'òɛ̀ aà gↄↄ gbɛ̃́ↄ yã́ musu ń gbɛ̃́ pↄ́ aaↄ ku gↄↄ bee gbɛaↄ lↄ à mɛ̀: À Lua náaikɛ, bee mɛ́ ì to gbɛ̃́ↄ aaↄ ku (2.4). À Lua náaikɛ, i mↄ dↄiálɛ (lɛɛ 3).
\ip Yãpãsĩ gↄↄ gbɛ̃́ↄ laai ì ta Abaku lá yã́wa, kɛ́ aa Lua náaikɛ aai sↄ̃dilɛ. Lua zĩna Pↄlu waasokɛ̀ Yesude káauↄnɛ à mɛ̀ luanaaikɛapi mɛ́ Yesu Kilisi náaikɛa ũ tia (Lom 1.17, Gal 3.11, Ɛbɛ 10.38).
\c 1
\s1 Abaku Lua tàae'ea
\q1 
\v 1 Yã́ pↄ́ ãnabi Abaku èn kɛ:
\q1 
\v 2 Málɛ wiilɛma à gɛ̃̀gɛ̃,
\q1 ńlɛ yãmaao, Dii.
\q1 Málɛ lɛzunzi yãpãsĩ yã́iɛ,
\q1 ńlɛ wá suabao.
\q1 
\v 3 Bↄ́yãi ni to mà vãikɛa ei?
\q1 Àkɛa niↄ dàakɛa gwai?
\q1 Kaalɛ ń yãpãsĩↄ ku ma aɛ,
\q1 sòle ń yãkeleo fɛ̀lɛ.
\q1 
\v 4 Bee yã́i ikoyã gↄ̃̀ plɛ̀gɛlɛgɛ,
\q1 wìli zĩkɛ yã́zɛdewao.
\q1 Gbɛ̃vãiↄ ì koezↄ̃ gbɛ̃maaↄzi,
\q1 ↄ̃ wì yã́zɛde fuangba.
\s1 Dii yã́zãsia Abakuwa
\q1 
\v 5 À buiↄ gwa à gwa, yã́ i diwá,
\q1 asa málɛ yãkɛ á gↄↄɛ,
\q1 tó wa sìuɛ́, á sio.\f + \fr 1.5 \ft Zĩn 13.41\f*
\q1 
\v 6 À gwa! Málɛ tɛ́kpa Kaladeↄgu.\f + \fr 1.6 \ft 2Kia 24.2\f*
\q1 Bui pãsĩ nↄnwãadepiↄ lɛ́ li dṹniaa píi,
\q1 aalɛ zↄ̃lɛkĩi pↄ́ dɛ ń pↄ́ ũoↄ símá.
\q1 
\v 7 Aaì to vĩa ń kṹ,
\q1 sↄ̃ ì kɛ̃ gbɛ̃́ↄgu.
\q1 Aali ikoyãdao,
\q1 aaì ńzĩa sɛ lɛsĩ.
\q1 
\v 8 An sↄ̃́ↄ wãa dɛ gbɛaanaa,
\q1 an pãsĩ dɛ àwalɛwan oosiɛlɛa.
\q1 An sↄ̃deↄ bↄ̀ bùsu zã̀zãu,
\q1 an sↄ̃́ↄ lɛ́ bàalɛ bìooo,
\q1 aaì kúu'o su pↄ́ lɛ́i.
\q1 
\v 9 Ampii aaì zɛ ń pãsĩo,
\q1 aaì su sãnusãnu lán guwaiwai ĩ́anawa,
\q1 aaì zĩ̀zↄↄ naaa lán bùsu'ũfãawa.
\q1 
\v 10 Aaì kíaↄ kɛ pↄ́ↄpↄↄ,
\q1 aaì gbãadeↄ yáalↄ,
\q1 aaì wɛ̃́lɛ bĩ́ideↄ àlafiikɛ,
\q1 aaì bùsu kãaa bĩ́izi aa sí.
\q1 
\v 11 Aaì gɛ̃ gɛ́ aɛ lán ĩ́anawa.
\q1 Tàaedeↄnɛ, an gbãa mɛ́ ń lua ũ.
\s1 Abaku ɛa Lua tàae'ea
\q1 
\v 12 Dii, ń kú za káaukaauɛ,
\q1 ma Lua pↄ́ n kua adoa, wá gao.
\q1 Dii, n buipi dìlɛ yã́kpalɛkɛawanↄ yã́iɛ,
\q1 ma gbɛsi, n buipi zɛ̀dↄ wá totoa yã́iɛ.
\q1 
\v 13 N kua adoa, n gɛ̃ wɛsia vãilɛa,
\q1 ńyↄ̃ fↄ̃ yãvãikɛa gwao.
\q1 Bↄ́yãi niↄ bↄnkpɛdeↄ gwa ń wɛ́oi?
\q1 Tó gbɛ̃vãiↄ lɛ́ gbɛ̃maaↄ mↄmↄ,
\q1 bↄ́yãi niↄ nílɛi?
\q1 
\v 14 N gbɛ̃nazĩna kɛ̀ lán ísia kpↄↄwa,
\q1 lán pↄ́ kelena pↄ́ aa kía vĩoↄwa.
\q1 
\v 15 Ibɛɛↄ ì ń kṹ ń kokoao,
\q1 aaì ń gá ń bↄ.
\q1 Aaì ń kṹ ń sↄo,
\q1 aaì ń naaa ń ń táaluo,
\q1 ↄ̃ aaì pↄnakɛ, aaìↄ yáalↄ.
\q1 
\v 16 A yã́i tò aaì ɛsɛkɛ táaluwa,
\q1 aaì tulaletikatɛa sↄɛ,
\q1 asa beeↄ mɛ́ tò aa ku nama guu,
\q1 aaì pↄ́ níside ble.
\q1 
\v 17 Aaↄ kpↄ bↄlɛ ń táaluu gↄↄpii yã̀?
\q1 Aaↄ buiↄ dɛdɛ ń wɛgwasai láasai yã̀?
\c 2
\s1 Dii yã́zãsia Abakuwa
\q1 
\v 1 Má zɛ ma gudↄ̃akĩi,
\q1 má tepɛ bĩ́iwa,
\q1 má itɛ̃kɛ mà gwa lá asu omɛɛ,
\q1 lá a a tàae pↄ́ málɛ e yã́zãsia.
\m 
\v 2 Ɔ̃ Dii òmɛɛ à mɛ̀:
\q1 Yã́ pↄ́ ń è dalau,
\q1 kɛ̃ gbɛ̀ pɛ̀pɛɛwa wásawasa,
\q1 kɛ́ kyokɛna e kɛ ń wãao.
\q1 
\v 3 Asa yã́pi gↄↄ dilɛaɛ,
\q1 yã́pi lɛ́ a kɛgↄↄ yá, a gí kɛio.
\q1 Baa tó a gↄↄ lɛ́ gɛ̃gɛ̃, ǹyↄ̃ dã́,
\q1 gↄↄpi a ká, wa sↄ̃òo.
\q1 
\v 4 Gwa! Gbɛ̃́ pↄ́ a nↄ̀sɛ maao a fu,
\q1 ãma gbɛ̃́ maa aↄ ku
\q1 ma náai pↄ́ àlɛ kɛ yã́i.\f + \fr 2.4 \ft Lom 1.17, Gal 3.11, Ɛbɛ 10.38\f*
\q1 
\v 5 Àizɛɛ náai vĩo,
\q1 yↄ̃̀ↄde sↄ̃ líↄ daa doũo.
\q1 A asia vĩ lán bɛdawaɛ,
\q1 ìli kã́o, a dɛ lán gawa.
\q1 Ì buiↄ kãaaazi,
\q1 ì bùsu píi gbɛ̃́ↄ kṹkũ zĩ̀zↄↄ ũ.
\q1 
\v 6 Aà yã́ a gↄ̃ ń baadeɛ yãa ũ,
\q1 aa aà àlafiikɛ aa aà láanikɛ aa mɛ:
\q1 Waiyoo n gbɛ̃́ pↄ́ ni dãↄ pↄ́ kãaa nzĩaɛ,
\q1 ni nzĩa dilɛ gbia gbɛ̃́ bↄ́ↄ'imia yã́ musu.
\q1 
\v 7 N fĩadeↄ fɛlɛnnↄ kã́ndoɛ,
\q1 aa vu iu, ní gↄ̃ ń lualuao,
\q1 ní gↄ̃ ń gbãablema ài ũ.
\q1 
\v 8 Lá bui pↄ́ n ń pↄ́ↄ sìmá yãaↄ dasi,
\q1 an kↄ̃naↄ n pↄ́ↄ sima sa sↄ̃ɛ,
\q1 asa n gbɛ̃́ↄ dɛ̀dɛ, n bùsuↄ kàalɛ
\q1 ń wɛ̃́lɛↄ ń gbɛ̃́ pↄ́ kúuↄ píiɛ.
\q1 
\v 9 Waiyoo n gbɛ̃́ pↄ́ ni n ua kã́fĩ ń ài vãio,
\q1 ni n sakpɛpi da musu,
\q1 kɛ́ músi su n leo yã́i.
\q1 
\v 10 N lɛkpàaĩ gbɛ̃dɛdɛa dasi yã́i,
\q1 ↄ̃ n widà n uawa,
\q1 ńyↄ̃ wɛ̃ni kɛ lↄo.
\q1 
\v 11 N kpɛ́ gbɛↄ mɛ́ aa wiidↄma,
\q1 a zaↄ i yã́pi zã́simá.
\q1 
\v 12 Waiyoo n gbɛ̃́ pↄ́ ni wɛ̃́lɛ kṹ ń gbɛ̃dɛao,
\q1 ni mɛɛwia kálɛ ń dìidiinkɛao.
\q1 
\v 13 Gbɛ̃nazĩnaↄ isimagakpaa gbɛ a gↄ̃ yàa ũɛ,
\q1 buiↄ ì ńzĩa kpasa pãɛ.
\q1 Dii Zĩgↄ̃de mɛ́ dìlɛ màao lò?
\q1 
\v 14 Asa Dii gawi dↄ̃a a li dṹniaaɛ,
\q1 lá í ì dagua ísiaiwa.\f + \fr 2.14 \ft Isa 11.9\f*
\q1 
\v 15 Waiyoo n gbɛ̃́ pↄ́ ni íkaka n gbɛ̃́deeↄnɛ,
\q1 ni naɛnaɛmá e ípi gɛ zↄ̃lɛomá,
\q1 kɛ́ ǹ e wɛ́tɛ an puizii yã́i.
\q1 
\v 16 Wí mɛ́ a n kṹ, i kɛ gawi no.
\q1 Imi, asa wa n puizi e sↄ̃ɛ.
\q1 Imibↄ pↄ́ kú Dii ↄzĩ lɛ́ suma,
\q1 wí i gↄ̃ n gawi gbɛu.
\q1 
\v 17 Yãpãsĩ pↄ́ ń kɛ̀ Libã a kúlɛmaɛ,
\q1 n nↄ̀bↄↄ kaalɛa yã́ a sↄ̃ kɛ̃ngu.
\q1 Asa n gbɛ̃́ↄ dɛ̀dɛ, n bùsuↄ ↄ̃̀ↄkpàɛ,
\q1 n wɛ̃́lɛↄ ń gbɛ̃́ pↄ́ kúuↄ kàalɛ píi.
\q1 
\v 18 Bↄ́ ài tã́aↄ vĩi? Gbɛ̃nazĩna mɛ́ ã̀.
\q1 Bↄ́ ài pↄ́ kásaa pↄ́ aaì ń da ɛɛupiↄ vĩi?
\q1 Gbɛ̃́ pↄ́ kɛ̀ ì a pↄkɛa náaikɛ,
\q1 ì tã́a pↄ́ lí fↄ̃ yã'òopiↄ kɛ.
\q1 
\v 19 Waiyoo n gbɛ̃́ pↄ́ ni o líɛ
\q1 aà yãmama,
\q1 ge ni o gbɛ̀ wɛ̃nisaiɛ àↄ ku.
\q1 A fↄ̃ dↄaanɛe?
\q1 Wà vua ge ã́nusu'i lɛ̀wà,
\q1 kási wɛ̃ni ku a guuo.
\q1 
\v 20 Dii ku a bɛ pↄ́ a kua adoau.
\q1 Dṹnia gbɛ̃́pii à kɛ kílikili aà aɛ.
\c 3
\s1 Abaku wabikɛa
\q1 
\v 1 Ãnabi Abaku wabikɛa.
\q1 
\v 2 Dii, ma n bao mà,
\q1 Dii, n yãkɛaↄ tò má n vĩa vĩ.
\q1 Ɛa yã́ bee taaↄ kɛ wá gↄↄ,
\q1 ní tó wà dↄ̃ wá gↄↄ.
\q1 Tó wá wɛgwaa dↄngu n pↄkũmagↄↄ.
\q1 
\v 3 Lua a bↄ Temani,
\q1 Kuaadoade a bↄ Palana gbɛ̀sĩsĩ musu.
\q1 Aà gawi a kúlɛ luabɛa,
\q1 aà táasilɛa a dṹnia pa.
\q1 
\v 4 Aà tɛkɛa aↄ dɛ lán ĩatɛ̃ bilɛawa,
\q1 gupua a pípi aà gbã̀tɛ̃ɛ ń gbã̀tɛ̃ɛo,
\q1 we aà gbãa ulɛau.
\q1 
\v 5 Gagyã bɛ aà aɛ,
\q1 tɛ́lɛpiↄ bɛ aà iau.
\q1 
\v 6 Tó à zɛ̀, dṹnia ì zãampapa,
\q1 tó à wɛtɛ̀i, buiↄ ì kɛ gã̀sĩ.
\q1 Gbɛ̀sĩsĩ ziↄ kwɛ̀,
\q1 sĩ̀sĩ pↄ́ kú za káauↄ gbòo.
\q1 Ì yãkɛ lá a kɛ̀ káaukaauwa.
\b
\q1 
\v 7 Ma Kusã zwã̀akpɛↄ è,
\q1 wàlɛ taasikɛu,
\q1 ma Madiã bùsu zwã̀akpɛↄ è,
\q1 gili gɛ̃̀ńgu we.
\q1 
\v 8 Dii, n pↄ pà swaↄzi yã̀?
\q1 N za fɛ̃̀ swa'ↄnaↄzi nɛe?
\q1 Kɛ́ ń di n sↄ̃́ↄ kpɛ ń n zĩblesↄ̃goↄ,
\q1 n mɛ fɛ̃̀ ísiazi yã̀?
\q1 
\v 9 N n sá bↄ̀ a bↄ̀ↄu,
\q1 n mɛ̀ wà mↄ́ ń kaↄ,
\q1 ↄ̃ n dṹnia pàapaa ń swaↄ.
\q1 
\v 10 Gbɛ̀sĩsĩↄ n e, aalɛ kↄ̃dɛ,
\q1 í dàgua, àlɛ gɛ̃,
\q1 ísi kↄ̃fĩ dↄ,
\q1 a ikooaↄ lɛ́ fɛlɛ musu.
\q1 
\v 11 Ĩatɛ̃ ń mↄvuao zɛ̀ gudoũ musumusu
\q1 n ka pↄ́ lɛ́ gɛ̃ fìoo tɛkɛa yã́i
\q1 ń n sↄ̃na pípia yã́o.
\q1 
\v 12 Ńlɛ tavaavaa'o dṹniau ń pↄkũmao,
\q1 ńlɛ buiↄ gbɛ̃ ń kyã̀wãao.
\q1 
\v 13 N bↄ n mↄ n gbɛ̃́ↄ boi,
\q1 n mↄ kía pↄ́ ń kpà suabai.
\q1 N gbɛ̃vãi mi wì,
\q1 n pↄ́ pìliwà à gↄ̃̀ láilai.
\q1 
\v 14 Kɛ́ aà zĩgↄ̃ↄ sìwázi wá fãaai,
\q1 aalɛ pↄnakɛ yɛ̃̀ɛɛsaide pↄ́ ulɛaↄ blea yã́ musu,
\q1 ↄ̃ n ń dↄaana mi fↄ̃̀ ń azĩa sↄ̃nao.
\q1 
\v 15 N ↄ̃zↄ̃̀ ísiawa ń n sↄ̃́ↄ,
\q1 n í zↄ̃ↄpi yà.
\b
\q1 
\v 16 Kɛ́ ma a baomà, sↄ̃ kɛ̃̀magu,
\q1 a kↄ̃fĩ ma lɛ́baa dèe, ma wá gà,
\q1 málɛ lualua ma zɛgbɛu.
\q1 Má mɛna màↄ gↄↄ pↄ́ wa yã́yia gbɛ̃́ pↄ́ lɛ̀lɛwáↄwa dã́.
\q1 
\v 17 Baa tó kaadↄɛna i nɛsoe kɛo,
\q1 mɛ́ vɛ̃ɛliↄ i nɛ'io,
\q1 baa tó ku i bↄo,
\q1 mɛ́ buapↄ́ↄ i kɛo,
\q1 baa tó sãↄ ku kaau lↄo,
\q1 mɛ́ zuↄ làa kpàsau,
\q1 
\v 18 ń beeo ma pↄ aↄ na Diiwaɛ,
\q1 má pↄnakɛ ń Lua ma Suabanao.
\q1 
\v 19 Dii Lua mɛ́ ma gbãa ũ,
\q1 ì ma wá nakṹ lán tuewa,\f + \fr 3.19 \ft 2Sam 22.34, Soũ 18.33\f*
\q1 ì to màↄ bɛ gulɛsĩↄwa.
