\v 8 Entonces \w Faraón|strong="H6547"\w* llamó \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w* \w y|strong="H5921"\w* \w a|strong="H3068"\w* Aarón, \w y|strong="H5921"\w* \w díjoles|strong="H1697"\w*: Orad \w al|strong="H5921"\w* \w SEÑOR|strong="H3068"\w* \w que|strong="H5921"\w* quite \w las|strong="H5921"\w* \w ranas|strong="H6854"\w* \w de|strong="H5921"\w* \w mí|strong="H5921"\w* \w y|strong="H5921"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w pueblo|strong="H5973"\w*; \w y|strong="H5921"\w* dejaré ir \w al|strong="H5921"\w* \w pueblo|strong="H5973"\w*, \w para|strong="H5921"\w* \w que|strong="H5921"\w* sacrifique \w al|strong="H5921"\w* \w SEÑOR|strong="H3068"\w*.   
\m
\v 9 \w Y|strong="H3068"\w* dijo \w Moisés|strong="H4872"\w* \w a|strong="H3068"\w* Faraón: Gloríate \w sobre|strong="H4480"\w* mí: ¿cuándo oraré \w por|strong="H4480"\w* \w ti|strong="H4480"\w*, y \w por|strong="H4480"\w* tus siervos, y \w por|strong="H4480"\w* \w tu|strong="H6213"\w* pueblo, \w para|strong="H4480"\w* \w que|strong="H4480"\w* las \w ranas|strong="H6854"\w* sean quitadas \w de|strong="H4480"\w* \w ti|strong="H4480"\w*, y \w de|strong="H4480"\w* tus \w casas|strong="H1004"\w*, y \w que|strong="H4480"\w* solamente \w se|strong="H4480"\w* queden \w en|strong="H4480"\w* \w el|strong="H6213"\w* río?   
\m
\v 10 \w Y|strong="H3068"\w* él dijo: Mañana. \w Y|strong="H3068"\w* \add Moisés\add* respondió: Se hará conforme \w a|strong="H3068"\w* tu palabra, para que conozcas que no hay como el SEÑOR nuestro Dios:   
\m
\v 11 \w Y|strong="H3068"\w* las ranas \w se|strong="H1961"\w* irán \w de|strong="H3588"\w* ti, \w y|strong="H3588"\w* \w de|strong="H3588"\w* tus casas, \w y|strong="H3588"\w* \w de|strong="H3588"\w* tus siervos, \w y|strong="H3588"\w* \w de|strong="H3588"\w* tu pueblo, \w y|strong="H3588"\w* \w solamente|strong="H3588"\w* \w se|strong="H1961"\w* quedarán \w en|strong="H3588"\w* \w el|strong="H3588"\w* río.   
\m
\v 12 Entonces salieron \w Moisés|strong="H4872"\w* y Aarón de con Faraón, y clamó \w Moisés|strong="H4872"\w* al \w SEÑOR|strong="H3068"\w* \w sobre|strong="H1961"\w* \w el|strong="H3605"\w* nego­cio de las ranas \w que|strong="H1961"\w* \w había|strong="H1961"\w* puesto \w a|strong="H3068"\w* Faraón.   
\m
\v 13 \w E|strong="H3068"\w* \w hizo|strong="H6213"\w* \w el|strong="H3605"\w* SEÑOR conforme \w a|strong="H3068"\w* \w la|strong="H3605"\w* palabra de Moisés, y murieron las ranas de las casas, de \w los|strong="H3605"\w* cor­tijos, y de \w los|strong="H3605"\w* campos.   
\m
\v 14 \w Y|strong="H3068"\w* las juntaron \w en|strong="H3318"\w* montones, y apestaban la tierra.   
\m
\v 15 \w Y|strong="H3068"\w* viendo \w Faraón|strong="H6547"\w* \w que|strong="H1931"\w* \w le|strong="H1931"\w* habí­an dado reposo, \w endureció|strong="H2388"\w* \w su|strong="H1931"\w* \w corazón|strong="H3820"\w*, y \w no|strong="H3808"\w* \w los|strong="H1931"\w* \w escuchó|strong="H8085"\w*; \w como|strong="H1931"\w* \w el|strong="H1931"\w* \w SEÑOR|strong="H3068"\w* \w lo|strong="H1931"\w* había \w dicho|strong="H1696"\w*.   
\m
\v 16 Entonces el \w SEÑOR|strong="H3068"\w* dijo \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: Di \w a|strong="H3068"\w* Aarón: \w Extiende|strong="H7971"\w* tu vara, \w y|strong="H3541"\w* hiere el polvo \w de|strong="H6440"\w* la tierra, \w para|strong="H3320"\w* \w que|strong="H5971"\w* \w se|strong="H5971"\w* vuelva piojos \w por|strong="H6440"\w* todo el país \w de|strong="H6440"\w* Egipto.   
\m
\v 17 \w Y|strong="H3068"\w* \w ellos|strong="H1992"\w* \w lo|strong="H5921"\w* hicieron \w así|strong="H1571"\w*; \w y|strong="H1571"\w* Aarón \w extendió|strong="H7971"\w* \w su|strong="H1992"\w* mano \w con|strong="H5921"\w* \w su|strong="H1992"\w* vara, \w e|strong="H3068"\w* hirió \w el|strong="H5921"\w* polvo \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra, \w el|strong="H5921"\w* \w cual|strong="H3588"\w* \w se|strong="H5921"\w* volvió piojos, \w así|strong="H1571"\w* \w en|strong="H5921"\w* \w los|strong="H1992"\w* hombres \w como|strong="H3588"\w* \w en|strong="H5921"\w* \w las|strong="H1992"\w* bestias: todo \w el|strong="H5921"\w* polvo \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w se|strong="H5921"\w* vol­vió piojos \w en|strong="H5921"\w* todo \w el|strong="H5921"\w* país \w de|strong="H5921"\w* Egipto.   
\m
\v 18 \w Y|strong="H3068"\w* \w los|strong="H5921"\w* encantadores hicieron \w así|strong="H3588"\w* también, \w para|strong="H4616"\w* sacar piojos \w con|strong="H5921"\w* \w sus|strong="H1931"\w* encantamientos; \w mas|strong="H3588"\w* \w no|strong="H3588"\w* pudieron. \w Y|strong="H3068"\w* \w había|strong="H1961"\w* piojos \w así|strong="H3588"\w* \w en|strong="H5921"\w* \w los|strong="H5921"\w* hombres \w como|strong="H3588"\w* \w en|strong="H5921"\w* \w las|strong="H5921"\w* bestias.   
\m
\v 19 Entonces \w los|strong="H1961"\w* magos dijeron \w a|strong="H3068"\w* Faraón: Dedo \w de|strong="H5971"\w* Dios \w es|strong="H1961"\w* \w este|strong="H2088"\w*. Mas el corazón \w de|strong="H5971"\w* Faraón \w se|strong="H1961"\w* endureció, y \w no|strong="H1961"\w* \w los|strong="H1961"\w* escuchó; \w como|strong="H1961"\w* el SEÑOR \w lo|strong="H2088"\w* \w había|strong="H1961"\w* dicho.   
\m
\v 20 \w Y|strong="H3068"\w* \w el|strong="H3605"\w* \w SEÑOR|strong="H3068"\w* dijo \w a|strong="H3068"\w* Moisés: Levántate \w de|strong="H6440"\w* mañana y ponte \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w Faraón|strong="H6547"\w*, he aquí \w él|strong="H3605"\w* sale \w a|strong="H3068"\w* las aguas; y díle: \w el|strong="H3605"\w* \w SEÑOR|strong="H3068"\w* ha dicho \w así|strong="H3651"\w*: Deja ir \w a|strong="H3068"\w* mi pueblo, para \w que|strong="H3605"\w* me sirva.   
\m
\v 21 Porque si no dejares \w ir|strong="H3212"\w* \w a|strong="H3068"\w* mi pueblo, he aquí yo enviaré sobre ti, y sobre tus siervos, y sobre tu pueblo, y sobre tus casas toda suerte de moscas; y las casas de los egipcios se henchirán de toda suerte de moscas, y asimismo la tierra donde ellos estuvieren.   
\m
\v 22 \w Y|strong="H3068"\w* \w aquel|strong="H6213"\w* día \w yo|strong="H3588"\w* apartaré \w la|strong="H3588"\w* tie­rra \w de|strong="H3588"\w* Gosén, \w en|strong="H3588"\w* \w la|strong="H3588"\w* \w cual|strong="H3588"\w* mi pue­blo habita, \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w ninguna|strong="H3808"\w* suerte \w de|strong="H3588"\w* moscas haya \w en|strong="H3588"\w* ella; \w a|strong="H3068"\w* fin \w de|strong="H3588"\w* \w que|strong="H3588"\w* sepas \w que|strong="H3588"\w* \w yo|strong="H3588"\w* soy \w el|strong="H3588"\w* \w SEÑOR|strong="H3068"\w* \w en|strong="H3588"\w* medio \w de|strong="H3588"\w* \w la|strong="H3588"\w* tie­rra.   
\m
\v 23 \w Y|strong="H3068"\w* yo pondré división entre mi pueblo y el tuyo. Mañana será esta señal.   
\m
\v 24 \w Y|strong="H3068"\w* el \w SEÑOR|strong="H3068"\w* \w lo|strong="H3808"\w* hizo así: \w que|strong="H3808"\w* \w vino|strong="H3212"\w* toda suerte de moscas molestísimas sobre la casa de \w Faraón|strong="H6547"\w*, y sobre las casas de sus siervos, y sobre todo el país de Egipto; y la tierra \w fue|strong="H3212"\w* corrompi­da \w a|strong="H3068"\w* causa de ellas.   
\m
\v 25 \w Entonces|strong="H5493"\w* \w Faraón|strong="H6547"\w* llamó \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w* y \w a|strong="H3068"\w* Aarón, y díjoles: Andad, \w sacrificad|strong="H2076"\w* \w a|strong="H3068"\w* vuestro \w Dios|strong="H3068"\w* \w en|strong="H5973"\w* la tierra.   
\m
\v 26 \w Y|strong="H3068"\w* \w Moisés|strong="H4872"\w* respondió: No \w con|strong="H5973"\w*­viene que hagamos \w así|strong="H5973"\w*, porque sacrificaríamos al \w SEÑOR|strong="H3068"\w* nues­tro \w Dios|strong="H3068"\w* la abominación \w de|strong="H5973"\w* \w los|strong="H5973"\w* egipcios. He aquí, si sacrificára­mos la abominación \w de|strong="H5973"\w* \w los|strong="H5973"\w* egipcios \w delante|strong="H5973"\w* \w de|strong="H5973"\w* ellos, ¿no nos apedrearían?   
\m
\v 27 Camino \w de|strong="H5971"\w* tres días \w iremos|strong="H5493"\w* \w por|strong="H1697"\w* \w el|strong="H6213"\w* desierto, y sacrificaremos al \w SEÑOR|strong="H3068"\w* nuestro \w Dios|strong="H3068"\w*, como \w él|strong="H6213"\w* nos dirá.   
\m
\v 28 \w Y|strong="H3068"\w* dijo \w Faraón|strong="H6547"\w*: Yo os \w dejaré|strong="H7971"\w* \w ir|strong="H7971"\w* \w para|strong="H5971"\w* \w que|strong="H3808"\w* sacrifiquéis al SEÑOR vuestro Dios en \w el|strong="H1571"\w* desierto, \w con|strong="H1571"\w* \w tal|strong="H2063"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* vayáis \w más|strong="H1571"\w* lejos: orad por mí.   
\m
\v 29 \w Y|strong="H3068"\w* respondió Moisés: He aquí, en saliendo yo de contigo, rogaré al SEÑOR que las diversas suer­tes de moscas se vayan de Faraón, y de sus siervos, y de su pueblo mañana; con tal que Faraón no falte más, no dejando ir al pueblo \w a|strong="H3068"\w* sacrificar al SEÑOR.   
\m
\v 30 Entonces Moisés salió de con Faraón, y oró al SEÑOR.   
\m
\v 31 \w Y|strong="H3068"\w* el SEÑOR hizo conforme \w a|strong="H3068"\w* la palabra de Moisés; y quitó todas aquellas moscas de Faraón, y de sus siervos, y de su pueblo, sin que quedara una.   
\m
\v 32 Mas Faraón endureció aún esta vez su corazón, y no dejó ir al pueblo.   
\c 9
\m
\v 1 ENTONCES el \w SEÑOR|strong="H3068"\w* \w dijo|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: Entra \w a|strong="H3068"\w* \w Faraón|strong="H6547"\w*, \w y|strong="H3541"\w* díle: el \w SEÑOR|strong="H3068"\w*, el \w Dios|strong="H3068"\w* \w de|strong="H5971"\w* los \w hebreos|strong="H5680"\w*, \w dice|strong="H1696"\w* \w así|strong="H3541"\w*: \w Deja|strong="H7971"\w* \w ir|strong="H7971"\w* \w a|strong="H3068"\w* mi \w pueblo|strong="H5971"\w*, \w para|strong="H5971"\w* \w que|strong="H5971"\w* \w me|strong="H3541"\w* sirvan;   
\m
\v 2 \w Porque|strong="H3588"\w* \w si|strong="H3588"\w* \w no|strong="H3588"\w* lo quieres dejar \w ir|strong="H7971"\w*, \w y|strong="H3588"\w* \w los|strong="H3588"\w* detuvieres \w aún|strong="H5750"\w*,   
\m
\v 3 He \w aquí|strong="H2009"\w* la \w mano|strong="H3027"\w* del \w SEÑOR|strong="H3068"\w* \w será|strong="H1961"\w* \w sobre|strong="H3515"\w* tus \w ganados|strong="H4735"\w* \w que|strong="H1961"\w* \w están|strong="H1961"\w* en el \w campo|strong="H7704"\w*, \w caballos|strong="H5483"\w*, \w asnos|strong="H2543"\w*, \w camellos|strong="H1581"\w*, \w vacas|strong="H1241"\w* \w y|strong="H1241"\w* \w ovejas|strong="H6629"\w*, con \w pestilencia|strong="H1698"\w* \w gravísima|strong="H3966"\w*:   
\m
\v 4 \w Y|strong="H3068"\w* \w el|strong="H3605"\w* \w SEÑOR|strong="H3068"\w* hará separación \w entre|strong="H3808"\w* \w los|strong="H1121"\w* \w ganados|strong="H4735"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* y \w los|strong="H1121"\w* \w de|strong="H1121"\w* \w Egipto|strong="H4714"\w*, \w de|strong="H1121"\w* modo \w que|strong="H3808"\w* \w nada|strong="H3808"\w* \w muera|strong="H4191"\w* \w de|strong="H1121"\w* \w todo|strong="H3605"\w* \w lo|strong="H1697"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*.   
\m
\v 5 \w Y|strong="H3068"\w* \w el|strong="H6213"\w* \w SEÑOR|strong="H3068"\w* señaló \w tiempo|strong="H4150"\w*, diciendo: \w Mañana|strong="H4279"\w* \w hará|strong="H6213"\w* \w el|strong="H6213"\w* \w SEÑOR|strong="H3068"\w* \w esta|strong="H2088"\w* \w cosa|strong="H1697"\w* en la tierra.   
\m
\v 6 \w Y|strong="H3068"\w* \w el|strong="H3605"\w* \w día|strong="H1121"\w* \w siguiente|strong="H4283"\w* \w el|strong="H3605"\w* \w SEÑOR|strong="H3068"\w* \w hizo|strong="H6213"\w* \w aquello|strong="H1697"\w*, y \w murió|strong="H4191"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w ganado|strong="H4735"\w* \w de|strong="H1121"\w* Egipto; \w mas|strong="H4191"\w* del gana­do \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w no|strong="H3808"\w* \w murió|strong="H4191"\w* uno.   
\m
