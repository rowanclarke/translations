\id EZK
\h حِيزْقِييَالْ
\toc1 حِيزْقِييَالْ
\toc2 حِيزْقِييَالْ
\toc3 حِز.
\mt1 حِيزْقِييَالْ
\c 1
\s1 أَضْهَارْ ن ؤُعُودْجِي ن سِيذِي
\m 
\v 1 \bd ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثْڒَاثِينْ، ذڭْ \bdit ؤُيُورْ\bdit* وِيسّْ أَربْعَا، ذڭْ وَاسّْ وِيسّْ خمْسَا ن ؤُيُورْ\bd*، ؤُمِي ذ أَيِي ثُوغَا ذِي ڒْوسْطْ ن أَيْثْ ن لْمنْفَا غَارْ يغْزَارْ ن خابُورْ، إِمْسَارْ بلِّي أَرزْمنْ إِجنْوَانْ ؤُشَا ژْرِيغْ إِوحَّانْ ن أَربِّي. \x ◘ \xo 1:‏1 \xt إِزهد. 137‏:‏1\x*
\v 2 \bd ذڭْ وَاسّْ وِيسّْ خمْسَا ن ؤُيُورْ - ثُوغَا ذ أَسڭّْوَاسْ وِيسّْ خمْسَا ن لْمنْفَا ن ؤُجدْجِيذْ يُويَاكِينْ -\bd*
\v 3 يُوسَا-د وَاوَاڒْ ن سِيذِي نِيشَانْ غَارْ حِيزْقِييَالْ، مِّيسْ ن بُوزِي، أَكهَّانْ، ذِي ثمُّورْثْ ن إِكَالْذَانِييّنْ، غَارْ يغْزَارْ ن خابُورْ. ثُوغَا ذِينْ خَاسْ أَفُوسْ ن سِيذِي.
\m 
\v 4 ژْرِيغْ، ؤُشَا خْزَارْ، يُوسَا-د ؤُسمِّيضْ ن ثْحَارْيَاضْثْ زِي شَّامَالْ، إِجّْ ن ؤُسيْنُو ذ أَمقّْرَانْ، ذ إِشْثْ ن ثْمسِّي ثتّْشعّڒْ، إِنّضْ أَسْ-د \add إِ ؤُسيْنُو\add* إِجّْ ن ؤُوسّڭْ. زِي ڒْوسْطْ نّسْ إِبَانْ-د \add شَا\add* أَمْ وُوزَّاڒْ إِتّْوسّْڭنْ، زِي ڒْوسْطْ ن ثْمسِّي. \x ◘ \xo 1:‏4 \xt ؤُف. 9‏:‏24\x*
\v 5 زِي ڒْوسْطْ نّسْ \add ثْبَانْ-د\add* صِّيفثْ ن أَربْعَا ن إِمُودَّارنْ. أَمُّو د-ضْهَارنْ يِينَا: ثُوغَا \add مَارَّا\add* غَارْسنْ صِّيفثْ ن بْنَاذمْ.
\v 6 كُوڒْ إِجّْ غَارسْ أَربْعَا ن وُوذْمَاونْ ؤُ كُوڒْ  إِجّْ غَارسْ أَربْعَا ن وَافْرِيونْ. \x ◘ \xo 1:‏6 \xt حِز. 10‏:‏14\x*
\v 7 إِضَارنْ نْسنْ ثُوغَا أَثنْ نِيشَانْ ؤُ ثِيڒقَّا ن إِضَارنْ نْسنْ أَمْ ثْڒقَّا ن إِضَارنْ ن ؤُعجْمِي ؤُشَا تِّيسِّيقنْثْ \add ثْڒقَّاثْ ن إِضَارنْ نْسنْ\add* أَمْ وُوذمْ ن نّْحَاسْ إِتّْوَاسُّويْذَانْ.\f ◼ \fr 1:‏7 \ft \bd ’أَمْوَا‘\bd* - نِيغْ ’أَينْذُوزْ‘ نِيغْ ’يُوڭُّو‘.\f*
\v 8 سَاذُو أَفْرِيونْ نْسنْ غَارْ أَربْعَا ن إِغزْذِيسنْ نْسنْ \add غَارْسنْ\add* إِفَاسّنْ ن بْنَاذمْ. أَربْعَا \add ن إِمُودَّارنْ\add* غَارْسنْ ؤُذْمَاونْ ذ وَافْرِيونْ. \x ◘ \xo 1:‏8 \xt حِز. 10‏:‏8\x*
\v 9 ثُوغَا أَفْرِيونْ نْسنْ مُوننْ إِجّْ أَكْ-ذ ونّغْنِي. نِيثْنِي وَارْ نّْقڒْبنْ شَا خْمِي ڭُّورنْ. ڭُّورنْ نِيثْنِي، كُوڒْ إِجّْ \add زَّايْسنْ إِڭُّورْ\add* نِيشَانْ غَارْ زَّاثْ.
\v 10 أَرْوَاسْ ن وُوذْمَاونْ نْسنْ \add ثُوغَا أَمْ\add* وُوذمْ ن بْنَاذمْ ؤُ غَارْ ؤُغزْذِيسْ أَفُوسِي ن أَربْعَا \add ن إِمُودَّارنْ نِّي\add* \add أَمْ\add* وُوذمْ ن ويْرَاذْ ؤُ غَارْ ؤُغزْذِيسْ أَزڒْمَاضْ ن أَربْعَا \add ن إِمُودَّارنْ نِّي\add* \add أَمْ\add* وُوذمْ ن ؤُفُونَاسْ ؤُشَا أَربْعَا \add ن إِمُودَّارنْ نِّي\add* غَارْسنْ عَاوذْ ؤُذمْ ن ؤُڭِيذرْ. \x ◘ \xo 1:‏10 \xt حِز. 10‏:‏14؛ أَسَا. 4‏:‏7\x*
\v 11 ؤُذْمَاونْ نْسنْ ذ وَافْرِيونْ نْسنْ تّْوَامْسبْضَانْ غَارْ ثِيوَا. ثْنَاينْ \add ن وَافْرِيونْ\add* ن كُوڒْ إِجّنْ تّْمُونَانْ أَكْ-ذ ونّغْنِي، ؤُ ثْنَاينْ ذْڒِينْ أَرِّيمَاثْ نْسنْ.
\v 12 نِيثْنِي ؤُيُورنْ، كُوڒْ إِجّْ نِيشَانْ غَارْ زَّاثْ. مَانِي مَا ثُوغَا إِخْسْ أَرُّوحْ أَذْ يُويُورْ، ڭُّورنْ نِيثْنِي. نِيثْنِي وَارْ تّْنقْڒِيبنْ شَا خْمِي ڭُّورنْ.
\v 13 خْ وَارْوَاسْ ن إِمُودَّارنْ \add نِّي\add*: أَقَا بَاننْ-د أَمْ ڒفْحمْ إِتّحْذُوذُوقنْ إِشمّْضنْ، أَمْ يِيصفْضَاونْ. ثُوغَا \add ثِيمسِّي\add* ثتّْرَاحْ ثتَّاسْ-د جَارْ إِمُودَّارنْ ؤُشَا ثِيمسِّي ثتِّيسِّيقْ ؤُ زِي ثْمسِّي تّفّْغنْ-د وَاسَّامنْ. \x ◘ \xo 1:‏13 \xt حِز. 10‏:‏2\x*
\v 14 إِمُودَّارنْ ثُوغَا تَّازّْڒنْ، ذكّْوَاڒنْ-د، إِتّْبَانْ أَمْ وَاسَّامنْ.
\m 
\v 15 \add ڒَْامِي\add* ژْرِيغْ إِمُودَّارنْ \add نِّي\add*، خْزَارْ إِشْثْ ن ثْجَارَّارْثْ \add ثْبدّْ\add* خْ ثمُّورْثْ زَّاثْ إِ إِمُودَّارنْ، غَارْ \add كُوڒْ إِجّْ زِي\add* أَربْعَا ن وُوذْمَاونْ.
\v 16 ثَاجَارَّارِينْ ذ ثْوَاڭِّيثْ نْسنْ بَاننْثْ-إِ-د أَمْ ثخْرِيسُولِيثْ ؤُ غَارْسنْ صِّيفثْ ذ إِشْثْ غَارْ أَربْعَا \add ن إِمُودَّارنْ\add*. مَامّشْ د-ضْهَارنْثْ ؤُ مَامّشْ تّْوَاڭّنْثْ ثُوغَا أَخْمِي إِشْثْ ن ثْجَارَّارْثْ \add ثُوغَا نِيشَانْ\add* ذِي ثْجَارَّارْثْ \add نّغْنِي\add*. \x ◘ \xo 1:‏16 \xt حِز. 10‏:‏9، 10\x*
\v 17 خْمِي ڭُّورنْ، ڭُّورنْ غَارْ أَربْعَا ن إِغزْذِيسنْ نْسنْ. نِيثْنِي وَارْ تّْنقْڒِيبنْ شَا خْمِي ڭُّورنْ.
\v 18 يَانْثَاثْ نْسنْ ثُوغَا أَثنْ ؤُعْڒَانْثْ ؤُ سَّاڭْوَاذنْثْ ؤُ يَانْثَاثْ نْسنْ شُّورنْثْ س ثِيطَّاوِينْ إِ ذ أَسنْثْ-إِ-د إِنّْضنْ، غَارْ أَربْعَا \add ن إِمُودَّارنْ نِّي\add*. \x ◘ \xo 1:‏18 \xt حِز. 10‏:‏12\x*
\v 19 خْمِي ڭُّورنْ إِمُودَّارنْ، ڭُّورنْثْ ؤُڒَا ذ ثْجَارَّارِينْ نِّي غَارْ زَّاثْ نْسنْ أَكِيذْسنْ، ؤُ خْمِي تّْوَاسّْڭعّْذنْ إِمُودَّارنْ زِي ثمُّورْثْ، تّْوَاسّْڭعّْذنْثْ ؤُڒَا ذ ثِيجَارَّارِينْ. \x ◘ \xo 1:‏19 \xt حِز. 10‏:‏16\x*
\v 20 أَڒْ مَانِي إِخْسْ أَرُّوحْ أَذْ يُويُورْ، ذِينْ ڭُّورنْ نِيثْنِي، مَانِي إِخْسْ أَرُّوحْ أَذْ إِرَاحْ، ؤُشَا ثِيجَارَّارِينْ غَارْ زَّاثْ نْسنْ تّْوَاسّْڭعّْذنْثْ، مَاغَارْ أَرُّوحْ ن إِمُودَّارنْ ثُوغَا ذِي ثْجَارَّارِينْ.
\v 21 خْمِي ڭُّورنْ نِيثْنِي، ڭُّورنْثْ ؤُڒَا ذ نِيثنْثِي، ؤُ خْمِي تّْبدَّانْ نِيثْنِي، بدّنْثْ ؤُڒَا ذ نِيثنْثِي ؤُ خْمِي تّْوَاسّْڭعّْذنْ نِيثْنِي، تّْوَاسّْڭعّْذنْثْ ؤُڒَا ذ ثِيجَارَّارِينْ أَكِيذْسنْ، مَاغَارْ أَرُّوحْ ن إِمُودَّارنْ ثُوغَا ذِي ثْجَارَّارِينْ.
\v 22 سنّجْ إِ إِزدْجِيفنْ ن ؤُمُودَّارْ ثُوغَا ذِينْ مِينْ يَاروْسنْ ذڭْ إِشْثْ ن ڒْقُوبّثْ، ثْبَانْ-د أَمْ \add يِيشْثْ ن ڒْقُوبّثْ\add* إِسَّاڭّْوَاذنْ ن وجْرِيسْ نِّي إِتّْوَابزّْعنْ سنّجْ إِ إِزدْجِيفنْ نْسنْ.
\v 23 سَاذُو ڒْقُوبّثْ ثُوغَا أَفْرِيونْ نْسنْ سڭّْمنْ، سّْوِيژَّاضنْ إِجّْ غَارْ ونّغْنِي. كُوڒْ إِجّْ غَارسْ ثْنَاينْ مَاحنْذْ أَذْ زَّايْسنْ إِسّْذُورِييْ إِخفْ نّسْ غَارْ ؤُغزْذِيسْ-س، ؤُشَا كُوڒْ إِجّْ غَارسْ \add عَاوذْ\add* ثْنَاينْ \add نّغْنِي\add* مَاحنْذْ أَذْ زَّايْسنْ إِسّْذُورِييْ إِخفْ نّسْ غَارْ ؤُغزْذِيسْ نِّي، \add ثُوغَا ذ مَانْ أَيَا إِ\add* أَرِّيمَاثْ نْسنْ. \x ◘ \xo 1:‏23 \xt حِز. 1‏:‏11\x*
\v 24 خْمِي ڭُّورنْ، سْڒِيغْ إِ ڒْحسّْ ن وَافْرِيونْ نْسنْ أَمْ زّْهِيرْ ن ڒبْحَارْ، أَمْ ثْمِيجَّا ن ؤُمْزمَّارْ خْ كُوڒْشِي، أَقَا ڒْحسّْ ذ أَمقّْرَانْ أَمْ ڒْحسّْ ن ڒْعسْكَارْ. ڒَامِي بدّنْ، سّهْوَانْ أَفْرِيونْ نْسنْ.
\v 25 ثُوغَا ذِينْ إِشْثْ ن ثْمِيجَّا سنّجْ إِ ڒْقُوبّثْ نِّي ثُوغَا سنّجْ إِ إِزدْجِيفنْ نْسنْ. ڒَامِي \add خنِّي\add* بدّنْ نِيثْنِي، سّهْوَانْ أَفْرِيونْ نْسنْ.
\v 26 سنّجْ إِ ڒْقُوبّثْ نِّي ثُوغَا خْ إِزدْجِيفنْ نْسنْ إِبَانْ-د \add شَا\add* أَمْ يِيجّْ ن ڒْعَارْشْ س وُوذمْ ن وژْرُو ن صَافِّيرْ أَزِيزَا ؤُ سنّجْ قَاعْ خْ مِينْ إِتّْبَاننْ أَمْ ڒْعَارْشْ، \add إِقِّيمْ\add* خَاسْ سنّجْ مِينْ إِتّْبَاننْ أَمْ صِّيفثْ ن بْنَاذمْ. \x ◘ \xo 1:‏26 \xt دَان. 7‏:‏9\x*
\v 27 ؤُشَا ژْرِيغْ \add أَقَا صْسِيفثْ\add* ثتّْبَانْ أَمْ وُوزَّاڒْ إِتّْوسّْڭنْ، ثْبَانْ-د أَمْ ثْمسِّي غَارْ ذَاخڒْ نّسْ ؤُ ذڭْ ونّضْ نّسْ. زِي ثجْعِينَّاثِينْ نّسْ أَڒْ سنّجْ ؤُ زِي مِينْ يَارْوسنْ ذِي ثجْعِينَّاثِينْ نّسْ أَڒْ وَادَّايْ، ژْرِيغْ \add ونِّي\add* د-إِتّْبَاننْ أَمْ ثْمسِّي ؤُشَا إِنّضْ أَسْ-د إِجّْ ن ؤُوسّڭْ.
\v 28 أَمْ مَامّشْ د-ثتّْبَانْ ثسْڒِيثْ ن ونْژَارْ ذڭْ إِسيْنُوثنْ ذڭْ إِجّْ ن وَاسّْ ن ونْژَارْ إِجهْذنْ، أَمُّو ثُوغَا شُّوفْ ن ؤُوسّڭْ نِّي إِ ذ \add أَسْ\add* د-إِنّْضنْ. وَانِيثَا ذ ؤُذمْ ن وَادُّوذْ ن ؤُعُودْجِي ن سِيذِي. \add ڒَْامِي\add* \add ث\add* ژْرِيغْ، وْضِيغْ س ؤُغمْبُوبْ إِنُو \add غَارْ ثمُّورْثْ\add* ؤُشَا سْڒِيغْ ثْمِيجَّا نِّي \add كِيذِي\add* إِسَّاوَاڒنْ. \x ◘ \xo 1:‏28 \xt دَان. 10‏:‏9\x*
\b
\b
\c 2
\s1 ثَاڒَاغِيثْ ن أَربِّي خْ حِيزْقِييَال
\m 
\v 1 إِنَّا أَيِي: ”\add أَ\add* مِّيسْ ن بْنَاذمْ، كَّارْ خْ إِضَارنْ نّشْ ؤُشَا نشّْ أَذْ كِيكْ سِّيوْڒغْ.“
\v 2 ڒَامِي أَكِيذِي إِسِّيوڒْ، يُوذفْ-د ذَايِي أَرُّوحْ ؤُشَا إِسّكَّارْ-د أَيِي خْ إِضَارنْ إِنُو ؤُ نشّْ سْڒِيغْ إِ ثْمِيجَّا ن ونِّي كِيذِي إِسَّاوَاڒنْ. \x ◘ \xo 2:‏2 \xt حِز. 3‏:‏24؛ دَان. 10‏:‏10\x*
\v 3 نتَّا إِنَّا أَيِي:
\b
\m ”\add أَ\add* مِّيسْ ن بْنَاذمْ، نشّْ سكّغْ شكْ غَارْ أَيْثْ ن إِسْرَائِيل، غَارْ ڒڭْنُوسْ إِغوّْغنْ، إِنِّي خَافِي إِغوّْغنْ. نِيثْنِي ذ ڒجْذُوذْ نْسنْعدَّانْ خَافِي أَڒْ أَسّْ-أَ. \x ◘ \xo 2:‏3 \xt إِرْم. 3‏:‏25\x*
\v 4 نِيثْنِي ذ أَرَّاوْ ن وُوذمْ إِقسْحنْ ذ وُوڒْ إِزلْڭنْ. نشّْ سكّغْ شكْ غَارْسنْ، إِتّْخصَّا أَشْ أَذْ أَسنْ ثِينِيذْ: ’أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي!‘
\v 5 مَا أَذْ \add أَشْ\add* سْڒنْ نِيغْ أَذْ سمْحنْ ذِي مَانْ أَيَا، مِينْزِي نِيثْنِي ذ إِشْثْ ن ثَادَّارْثْ إِغوّْغنْ، نِيثْنِي أَذْ سّْننْ بلِّي ثُوغَا أَنَابِي ذِي ڒْوسْطْ نْسنْ. \x ◘ \xo 2:‏5 \xt حِز. 33‏:‏33\x*
\v 6 ؤُشَا شكْ، \add أَ\add* مِّيسْ ن بْنَاذمْ، وَارْ زَّايْسنْ تّڭّْوذْ ؤُ وَارْ تّڭّْوذْ ؤُڒَا زڭْ وَاوَاڒنْ نْسنْ. وَاخَّا أَقَا ذِينْ غَاركْ ثِيزڭّْوُورَا ذ إِسنَّاننْ ؤُ وَاخَّا زدّْغنْثْ غَاركْ ثْغَارْضْمِيوِينْ، وَارْ تّڭّْوذْ شَا زڭْ وَاوَاڒنْ نْسنْ ؤُ وَارْ زَّايْسنْ تّْنخْڒِيعْ، مِينْزِي نِيثْنِي ذ إِشْثْ ن ثَادَّارْثْ إِغوّْغنْ. \x ◘ \xo 2:‏6 \xt إِرْم. 1‏:‏8، 17؛ حِز. 3‏:‏9؛ لك. 12‏:‏4؛ 1 بُط. 3‏:‏1\x*
\v 7 أَذْ كِيذْسنْ ثسِّيوْڒذْ س وَاوَاڒنْ إِنُو، مَا أَذْ سْڒنْ نِيغْ أَذْ سمْحنْ ذِي مَانْ أَيَا، مِينْزِي نِيثْنِي أَقَا تّْغوّْغنْ.
\v 8 \add مَاشَا\add* شكْ، \add أَ\add* مِّيسْ ن بْنَاذمْ، سڒْ مِينْ ذ أَشْ غَا إِنِيغْ، وَارْ تّْغوِّيغْ أَمْ ثَادَّارْثْ نِّي إِغوّْغنْ. أَرْزمْ أَقمُّومْ نّشْ نِيشَانْ ؤُشَا أشّْ مِينْ ذ أَشْ غَا وْشغْ.“ \x ◘ \xo 2:‏8 \xt أَسَا. 10‏:‏9\x*
\b
\m 
\v 9 ؤُشَا ژْرِيغْ، خْزَارْ، إِجّْ ن ؤُفُوسْ إِسّْوِيژّضْ-د غَارِي، ؤُ خْزَارْ، ذَايسْ إِجّْ ن وذْلِيسْ إِتّْوَانّْضنْ. \x ◘ \xo 2:‏9 \xt أَسَا. 10‏:‏8‏-‏11\x*
\v 10 نتَّا إِبزّعْ إِ-ث زَّاثِي. ثُوغَا يُورَا زِي سنّجْ ذ وَادَّايْ ؤُشَا تّْوَارِينْ ذَايسْ إِزْڒَانْ ن وشْضَانْ ذ ؤُسْقِينّفْ ذ ؤُوحْوحْ ن ثَامَارَا.
\b
\b
\c 3
\m 
\v 1 نتَّا إِنَّا أَيِي: ”\add أَ\add* مِّيسْ ن بْنَاذمْ، مِينْ ثتّْوَاڒِيذْ \add ذَانِيثَا\add*، أشّْ إِ-ث! أشّْ أَذْلِيسْ-أَ إِتّْوَانّْضنْ ؤُشَا ؤُيُورْ، سِيوڒْ أَكْ-ذ ثَادَّارْثْ ن إِسْرَائِيل.“ \x ◘ \xo 3:‏1 \xt إِرْم. 15‏:‏16؛ 2‏:‏8؛ أَسَا. 10‏:‏8‏-‏11\x*
\v 2 نشّْ أَرْزْمغْ أَقمُّومْ إِنُو ؤُ نتَّا إِسّشّْ أَيِي أَذْلِيسْ نِّي إِتّْوَانّْضنْ.
\v 3 إِنَّا أَيِي: ”\add أَ\add* مِّيسْ ن بْنَاذمْ، عْڒفْ أَعذِّيسْ نّشْ، شُّورْ ثَاكْرِيشْثْ نّشْ س وذْلِيسْ إِتّْوَانّْضنْ نِّي إِ ذ أَشْ غَا وْشغْ.“ \add خنِّي\add* شِّيغْ ؤُ ثُوغَا-ث ذ \add أَ\add*مِيژِيذْ ذڭْ ؤُقمُّومْ إِنُو أَمْ ثَامّنْثْ. \x ◘ \xo 3:‏3 \xt إِزهد. 19‏:‏11؛ 119‏:‏103؛ أَسَا. 10‏:‏10\x*
\m 
\v 4 \add خنِّي\add* إِنَّا أَيِي: ”\add أَ\add* مِّيسْ ن بْنَاذمْ، ؤُيُورْ، أَذفْ غَارْ ثَادَّارْثْ ن إِسْرَائِيل ؤُشَا سِيوڒْ أَوَاڒنْ إِنُو أَكِيذْسنْ. \x ◘ \xo 3:‏4 \xt إِرْم. 1‏:‏17\x*
\v 5 مِينْزِي وَارْ د-ثتّْوَاسّكّذْ شَا غَارْ إِجّْ ن ڒْڭنْسْ س إِجّْ ن يِيڒسْ إِوْعَارْ ؤُ س إِجّْ ن وَاوَاڒْ إِقْسحْ، مَاشَا غَارْ ثَادَّارْثْ ن إِسْرَائِيل،
\v 6 وَارْ إِدْجِي غَارْ ڒڭْنُوسْ أَطَّاسْ س إِجّْ ن يِيڒسْ إِوْعَارْ نِيغْ س إِجّْ ن وَاوَاڒْ إِقْسحْ، إِ زِي وَارْ ثْزمَّارذْ أَذْ ثْفهْمذْ أَوَاڒنْ نْسنْ. مَاڒَا سكّغْ شكْ غَارْسنْ نِيثْنِي، س ثِيذتّْ أَذْ أَشْ سْڒنْ.
\v 7 \add مَاشَا\add* ثَادَّارْثْ ن إِسْرَائِيل وَارْ إِخْسْ أَذْ غَاركْ إِسڒْ، مِينْزِي وَارْ خْسنْ أَذْ د-سْڒنْ غَارِي، مِينْزِي مَارَّا ثَادَّارْثْ ن إِسْرَائِيل، أَقَا نِيثْنِي \add غَارْسنْ\add* أَزدْجِيفْ إِقْسحْ ؤُ \add غَارْسنْ\add* ؤُڒْ يزْلڭْ.
\v 8 خْزَارْ، نشّْ ڭِّيغْ ؤُذمْ نّشْ إِقْسحْ أَمْ وُوذْمَاونْ نْسنْ، ؤُ ثَانْيَارْثْ نّشْ ڭِّيغْ ت ثقْسحْ أَمْ ثنْيَارِينْ نْسنْ. \x ◘ \xo 3:‏8 \xt إِرْم. 1‏:‏18؛ مِيخَا 3‏:‏8\x*
\v 9 نشّْ ڭِّيغْ ثَانْيَارْثْ نّشْ أَمْ يِيجّْ ن ؤُمسْمِيرْ إِ إِدْجَانْ إِقسْحنْ خْ إِشْثْ ن ثْخذْمشْثْ ن وژْرُو. وَارْ زَّايْسنْ تّڭّْوذْ شَا ؤُ وَارْ تّْنخْڒِيعْ شَا زڭْ وُوذْمَاونْ نْسنْ، مِينْزِي نِيثْنِي ذ إِشْثْ ن ثَادَّارْثْ إِغوّْغنْ.“ \x ◘ \xo 3:‏9 \xt إِرْم. 1‏:‏8، 17؛ 5‏:‏3؛ حِز. 2‏:‏6؛ 1 بُط. 3‏:‏14\x*
\m 
\v 10 نتَّا إِنَّا أَيِي: ”\add أَ\add* مِّيسْ ن بْنَاذمْ، حْضَا مَارَّا أَوَاڒنْ إِنُو نِّي إِ غَا سِّيوْڒغْ أَكِيذكْ ذڭْ وُوڒْ نّشْ ؤُشَا سڒْ غَارْسنْ س إِمزُّوغنْ نّشْ.
\v 11 ؤُيُورْ، أَذفْ غَارْ أَيْثْ ن لْمنْفَا غَارْ ثَارْوَا ن ڒْڭنْسْ نّشْ ؤُشَا سِيوڒْ أَكِيذْسنْ، إِنِي أَسنْ: ’أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي!‘، مَا أَذْ سْڒنْ نِيغْ أَذْ سمْحنْ ذِي مَانْ أَيَا.“ \x ◘ \xo 3:‏11 \xt حِز. 2‏:‏5، 7\x*
\b
\m 
\v 12 \add خنِّي\add* إِسّْڭعّذْ أَيِي أَرُّوحْ ؤُشَا سْڒِيغْ أَوَارْنِي أَيِي إِشْثْ ن ثْمِيجَّا ثدَّارْذِيحْ أَطَّاسْ، ثقَّارْ: ”أَذْ إِتّْوَابَاركْ ؤُعُودْجِي ن سِيذِي زڭْ ومْشَانْ \add ن ثْزذِّيغْثْ\add* نّسْ!“ \x ◘ \xo 3:‏12 \xt حِز. 8‏:‏3\x*
\v 13 سْڒِيغْ إِ ڒْحسّْ ن وَافْرِيونْ ن إِمُودَّارنْ نِّي إِڒقّْفنْ إِجّْ إِ ونّغْنِي ؤُڒَا إِ ڒْحسّْ ن ثْجَارَّارِينْ زَّاثْ نْسنْ ؤُ إِ ڒْحسّْ ن إِجّْ ن ؤُذَارْذِيحْ إِمْغَارْ.
\v 14 \add خنِّي\add* إِسّْڭعّذْ أَيِي أَرُّوحْ ؤُشَا إِكْسِي أَيِي. نشّْ ؤُيُورغْ، ذ أَمَارْزَاڭْ، إِتّحْذُوذُوقْ بُوحْبڒْ إِنُو \add ذَايِي\add* ؤُ أَفُوسْ ن سِيذِي ثُوغَا إِذْقڒْ خَافِي.
\v 15 \add أَمُّو إِ\add* د-ؤُسِيغْ غَارْ أَيْثْ ن لْمنْفَا ذِي ثَالْ-أَبِيبْ، إِنِّي إِزدّْغنْ غَارْ يغْزَارْ ن خابُورْ. نشّْ قِّيمغْ ذِينْ مَانِي ثُوغَا زدّْغنْ، \add وَاهْ،\add* قِّيمغْ ذِينْ سبْعَا ن وُوسَّانْ تّْبهْثغْ ڒَامِي ذ أَيِي ثُوغَا جَارْ أَسنْ. \x ◘ \xo 3:‏15 \xt أَيُوبْ 2‏:‏13\x*
\b
\s1 حِيزْقِييَالْ إِتّْوَاڒقّمْ ذ أَعسَّاسْ خْ إِسْرَائِيل
\m 
\v 16 إِمْسَارْ أَوَارْنِي ڒَامِي عْذُونْ سبْعَا ن وُوسَّانْ، أَقَا يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي. إِنَّا:
\v 17 ”\add أَ\add* مِّيسْ ن بْنَاذمْ، نشّْ ڭِّيغْ شكْ ذ أَعسَّاسْ خْ ثَادَّارْثْ ن إِسْرَائِيل. خْمِي غَا ثسْڒذْ إِ يِيجّْ ن وَاوَاڒْ زڭْ ؤُقمُّومْ إِنُو، إِتّْخصَّا شكْ أَذْ أَسنْ ثْعڒْمذْ زَّايِي. \x ◘ \xo 3:‏17 \xt إِشا. 62‏:‏6؛ حِز. 33‏:‏7؛ 1 تِيم. 3‏:‏1\x*
\v 18 خْمِي غَا إِنِيغْ إِ ؤُعفَّانْ ’س ثِيذتّْ أَذْ ثمّْثذْ!‘ ؤُشَا شكْ وَارْ ذ أَسْ ثعْڒِيمذْ شَا ؤُ وَارْ ثسِّيوْڒذْ حِيمَا أَذْ ثْعڒْمذْ أَعفَّانْ ذِي سِّيبّثْ ن وبْرِيذْ نّسْ أَعفَّانْ مَاحنْذْ أَذْ ث ثحْضِيذْ حِيمَا أَذْ إِقِّيمْ أَذْ إِدَّارْ، \add خنِّي\add* أَذْ إِمّثْ ؤُعفَّانْ نِّي ذِي ڒْغشّْ نّسْ، مَاشَا إِذَامّنْ نّسْ أَذْ ثنْ تَّارغْ زڭْ ؤُفُوسْ نّشْ. \x ◘ \xo 3:‏18 \xt حِز. 33‏:‏8\x*
\v 19 مَاشَا مَاڒَا ثْعڒْمذْ إِ ؤُعفَّانْ ؤُ نتَّا وَارْ إِبعّذْ شَا خْ ثُوعفّْنَا نّسْ ؤُ خْ وبْرِيذْ نّسْ إِعفّْننْ، \add خنِّي\add* نتَّا أَذْ إِمّثْ ذِي ڒْمُوعْصِييّثْ نّسْ، \add مَاشَا\add* ڒعْمَارْ نّشْ أَذْ إِنْجمْ.“
\m 
\v 20 ”مَاڒَا أَمْسڭّذْ إِبعّذْ خْ ثْسڭْذَا نّسْ ؤُشَا إِڭَّا ڒْمُوعْصِييّثْ خْمِي غَا سَّارْسغْ إِشْثْ ن سِّيبّثْ زَّاثسْ أَڒَامِي غَا إِخْضَا، \add خنِّي\add* أَذْ إِمّثْ. مِينْزِي شكْ وَارْ ذ أَسْ ثعْڒِيمذْ، أَذْ إِمّثْ ذِي دّنْبْ نّسْ ؤُشَا ثِيمڭَّا إِسڭّْذنْ إِ يڭَّا وَارْ ذَايْسنْثْ إِذَارنْ \add عَاذْ\add*. \add مَاشَا\add* إِذَامّنْ نّسْ أَذْ ثنْ تَّارغْ زڭْ إِفَاسّنْ نّشْ. \x ◘ \xo 3:‏20 \xt حِز. 18‏:‏24؛ 33‏:‏12، 13\x*
\v 21 \add مَاشَا\add* مَاڒَا ثْعڒْمذْ إِ ؤُمْسڭّذْ، حِيمَا وَارْ إِخطِّي ؤُمْسڭّذْ ؤُ نتَّا وَارْ إِخْضِي، \add خنِّي\add* أَذْ إِقِّيمْ إِدَّارْ س ثِيذتّْ مِينْزِي ثُوغَا إِتّْوَاعْڒمْ، ؤُ شكْ ثْفكّذْ ڒعْمَارْ نّشْ.“
\b
\s1 أَضْهَارْ وِيسّْ ثْنَاينْ ن ؤُعُودْجِي ن سِيذِي
\m 
\v 22 يُوسَا-د ذِينْ ؤُفُوسْ ن سِيذِي خَافِي ؤُشَا إِنَّا أَيِي: ”كَّارْ، فّغْ غَارْ ڒوْضَا \add ن ثغْزُورْثْ\add*، أَذْ كِيذكْ سِّيوْڒغْ ذِينِّي.“
\v 23 كَّارغْ ؤُشَا فّْغغْ غَارْ ڒوْضَا \add ن ثغْزُورْثْ\add*، خْزَارْ، أَعُودْجِي ن سِيذِي ثُوغَا إِتّْبدَّا ذِينِّي أَمْ ؤُعُودْجِي إِ ژْرِيغْ غَارْ يغْزَارْ ن خابُورْ ؤُشَا وْضِيغْ خْ ؤُغمْبُوبْ إِنُو \add غَارْ ثمُّورْثْ\add*. \x ◘ \xo 3:‏23 \xt حِز. 1‏:‏3\x*
\v 24 \add خنِّي\add* يُوذفْ ذَايِي أَرُّوحْ ؤُشَا إِسّكَّارْ أَيِي خْ إِضَارنْ إِنُو ؤُشَا إِسِّيوڒْ أَكِيذِي. نتَّا إِنَّا أَيِي: ”ؤُيُورْ، بلّعْ إِخفْ نّشْ ذَاخڒْ ذِي ثَادَّارْثْ نّشْ. \f ◼ \fr 3:‏24 \ft \bd ’ذَاخڒْ ذِي ثَادَّارْثْ نّكْ‘\bd* - س ثْعِيبْرَانِيثْ ’ذِي ڒْوسْثْ ن ثَادَّارْثْ نّكْ‘.\f*  \x ◘ \xo 3:‏24 \xt حِز. 2‏:‏2\x*
\v 25 ؤُ شكْ، \add أَ\add* مِّيسْ ن بْنَاذمْ، خْزَارْ، أَذْ أَشْ ڭّنْ إِسغْوَانْ ؤُ أَذْ شكْ شَارْفنْ زَّايْسنْ. وَارْ ثتّفّغْ شَا حِيمَا أَذْ ثَاذْفذْ جَارْ أَسنْ.
\v 26 أَذْ سّْڒسْقغْ إِڒسْ نّشْ غَارْ وَانغْ نّشْ. أَذْ ثْذوْڒذْ ذ أَزِينُونْ ؤُشَا وَارْ ثتِّيڒِيذْ ذ أَرْيَازْ جَارْ أَسنْ ونِّي ثنْ إِ غَا إِوبّْخنْ، مِينْزِي نِيثْنِي ذ إِشْثْ ن ثَادَّارْثْ ثْغوّغْ. \x ◘ \xo 3:‏26 \xt حِز. 2‏:‏5\x*
\v 27 \add مَاشَا\add* نشّْ، خْمِي كِيكْ إِ غَا سِّيوْڒغْ، أَذْ أَرْزْمغْ أَقمُّومْ نّشْ \add عَاوذْ\add* ؤُشَا أَذْ أَسنْ ثِينِيذْ: ’أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي! وِي إِتّسْڒَانْ، أَذْ إِسڒْ، ؤُشَا وِي إِسمّْحنْ ذِي مَانْ أَيَا، \add وَاخَّا\add* أَذْ ذَايسْ إِسْمحْ!‘، مِينْزِي نِيثْنِي ذ إِشْثْ ن ثَادَّارْثْ ثْغوّغْ.“ \x ◘ \xo 3:‏27 \xt حِز. 2‏:‏5، 7\x*
\b
\b
\c 4
\s1 أَرْشَامْ ن ؤُقوَّارْ ن ڒْعسْكَارْ ن ؤُرْشَالِيمْ
\m 
\v 1 ”شكْ، \add أَ\add* مِّيسْ ن بْنَاذمْ، كْسِي إِشْثْ ن لُوصَا ن ثْڒَاخْثْ ؤُشَا سَارْسْ إِ-ت زَّاثْ إِ وُوذمْ نّشْ ؤُشَا أَرْشمْ خَاسْ ثَانْذِينْثْ ن ؤُرْشَالِيمْ.
\v 2 قوَّارْ أَسْ ؤُشَا بْنَا خَاسْ إِجّْ ن لْبَارَاجْ ؤُشَا أڭّْ خَاسْ أَشْبَارْ، أڭّْ خَاسْ ڒمْرَاڭحْ ن ڒْعسْكَارْ ؤُشَا وّثْ خَاسْ ذڭْ ونّضْ نّسْ ڒقْشُوعْ ن وذْهَامْ. \x ◘ \xo 4:‏2 \xt 2 إِج. 25‏:‏1\x*
\v 3 ؤُشَا شكْ، كْسِي إِشْثْ ن مَارْمِيثَا ن وُوزَّاڒْ ؤُشَا أڭّْ إِ-ت أَمْ يِيجّْ ن ڒْحِيضْ ن وُوزَّاڒْ جَارْ شكْ ذ ثنْذِينْثْ. أَرّْ ؤُذمْ نّشْ خَاسْ مَاحنْذْ أَذْ ثتّْوَاحْصَارْ ؤُ شكْ أَذْ ت ثحْصَارذْ: مَانْ أَيَا أَذْ ثِيڒِي ذ ڒعْڒَامثْ إِ ثَادَّارْثْ ن إِسْرَائِيل.
\v 4 ؤُشَا شكْ، أَذْ ثزّْڒذْ خْ ؤُغزْذِيسْ نّشْ أَزڒْمَاضْ ؤُشَا أَذْ خَاسْ ثڭّذْ ڒْمُوعْصِييّثْ ن ثَادَّارْثْ ن إِسْرَائِيل. أَنشْثْ ن ؤُسَّانْ نِّي ذِي خَاسنْ إِ غَا ثزّْڒذْ، أَذْ ثَارْبُوذْ ڒْمُوعْصِييّثْ نْسنْ.
\v 5 مَاغَارْ نشّْ أَذْ خَاكْ ڭّغْ \add لْعَاذَاذْ ن\add* إِسڭّْوُوسَا ن ڒْمُوعْصِييّثْ نْسنْ أَمْ لْعَاذَاذْ ن وُوسَّانْ: \bd ثڒْثْ-مْيَا ؤُ-ثسْعِينْ ن وُوسَّانْ\bd* أَذْ ثَارْبُوذْ \bd ڒْمُوعْصِييّثْ ن ثَادَّارْثْ ن إِسْرَائِيل\bd*. \x ◘ \xo 4:‏5 \xt ڒخْڒ. 14‏:‏34\x*
\v 6 \add خْمِي\add* إِ غَا ثْكمّْڒذْ \add ؤُسَّانْ نِّي\add*، أَذْ ثزّْڒذْ عَاوذْ خْ ؤُغزْذِيسْ نّشْ أَفُوسِي ؤُشَا أَذْ ثَارْبُوذْ \bd ڒْْمُوعْصِييّثْ ن ثَادَّارْثْ ن يَاهُوذَا\bd*، \bd أَربْعِينْ ن وُوسَّانْ\bd*. إِجّْ ن وَاسّْ إِ يِيجّْ ن ؤُسڭّْوَاسْ، أَمْ مَامّشْ إِ ذ أَشْ ؤُمُورغْ. \f ◼ \fr 4:‏6 \ft \bd ’أَمْ مَامّشْ إِ ذ أَشْ ؤُمُورغْ‘\bd* - س ثْعِيبْرَانِيثْ ’أَمْ مَامّشْ ذ أَشْ وْشِيغْ‘.\f*
\v 7 أَذْ ثقِّيمذْ ثتَّارّذْ ؤُذمْ نّشْ غَارْ ڒحْصَارثْ ن ؤُرْشَالِيمْ ؤُشَا أَذْ ثْعَارِّيذْ أَغِيڒْ نّشْ، أَذْ ثْنبِّيذْ ضِيدّْ نّسْ. \x ◘ \xo 4:‏7 \xt إِشا. \x*
\v 8 خْزَارْ، نشّْ أَذْ خَاكْ ڭّغْ ثِيسْغُونِينْ أَڒَامِي وَارْ ثْزمَّارذْ أَذْ ثنّْقڒْبذْ زڭْ إِجّْ ن ؤُغزْذِيسْ غَارْ ؤُغزْذِيسْ نّغْنِي أَڒْ غَا ثْكمّْڒذْ ؤُسَّانْ ن ڒحْصَارثْ نّشْ.“
\m 
\v 9 ”كْسِي إِرْذنْ، إِمنْذِي، إِبَاونْ، ڒعْذسْ، ثَافْسَاوْثْ ذ كَارْصَانَا ؤُشَا أڭّْ إِ-ثنْ ذِي ثبْقشْثْ ؤُشَا أڭّْ زَّايْسنْ أَغْرُومْ إِ يِيخفْ نّشْ. أَذْ ثشّذْ أَيَا أَمْ مشْحَاڒْ لْعَاذَاذْ ن وُوسَّانْ نِّي إِ غَا ثزّْڒذْ خْ ؤُغزْذِيسْ نّشْ، ثڒْثْ-مْيَا ؤُ-ثسْعِينْ ن وُوسَّانْ. \f ◼ \fr 4:‏9 \ft \bd ’كَارْصَانَا‘\bd* - نِيغْ ’دُّوخْنْ‘ نِيغْ ’جَاوَارْسْ‘.\f*
\v 10 مَاشَّا نِّي إِ غَا ثشّذْ أَذْ ثتّْوَاوْزنْ: عِيشْرِينْ شِيقْلُو إِ يِيجّْ ن وَاسّْ. أَذْ ت ثشّذْ ذِي ثْسَاعّثِينْ إِتّْوَاڭّنْ.
\v 11 أَذْ ثسْوذْ أَمَانْ س ڒعْبَارْ: إِشْثْ ن ثْسِيتُّوثْ زڭْ إِجّْ ن ؤُهِينُو. أَذْ ت ثسْوذْ زِي ڒْوقْثْ أَڒْ ڒْوقْثْ \add نّغْنِي\add*. \f ◼ \fr 4:‏11 \ft \bd ’إِشْثْ ن ثْسِيتُّوثْ زڭْ إِجّْ ن ؤُهِينُو‘\bd* - عْڒَاحَاڒْ أَزْينْ لِيثْرُو.\f*
\v 12 أَذْ ثشّذْ إِشْثْ ن ثْخبَّازْثْ ن إِمنْذِي ؤُشَا أَذْ ت ثسّنْڭّْوذْ زَّاثْ إِ ثِيطَّاوِينْ نْسنْ خْ إِژَّانْ إِ د-إِفّْغنْ زِي بْنَاذمْ.“
\m 
\v 13 إِنَّا سِيذِي: ”أَمُّو إِ غَا شّنْ أَيْثْ ن إِسْرَائِيل أَغْرُومْ نْسنْ إِخمْجنْ جَارْ ڒڭْنُوسْ مَانِي ثنْ غَارْ إِ غَا سُّوفّْغغْ.“ \x ◘ \xo 4:‏13 \xt حُوش. 9‏:‏3\x*
\v 14 \add خنِّي\add* نِّيغْ: ”\add أَ،\add* سِيذِي إِنُو، سِيذِي، خْزَارْ، ڒعْمَارْ إِنُو وَارْ إِتّْوَاسّخْمجْعمَّارْصْ \add س مَاشَّا وَارْ إِحْڒِينْ\add*. زِي ثمْژِي إِنُو أَڒْ ڒخُّو نشّْ وَارْ شِّيغْ ڒْخشْبثْ نِيغْ مِينْ إِمزّْقنْ ؤُعمَّارْصْ وَارْ يُوذِيفْ ويْسُومْ ن جّْعِيفشْثْ غَارْ ؤُقمُّومْ إِنُو.“
\v 15 ؤُشَا نتَّا إِنَّا أَيِي: ”خْزَارْ، أَذْ أَشْ وْشِيغْ ڒغْبَارْ ن إِفُونَاسنْ ذڭْ ومْشَانْ ن ؤُبَارُّوضْ ن بْنَاذمْ. سوْجذْ خَاسْ أَغْرُومْ نّشْ.“
\m 
\v 16 \add خنِّي\add* إِنَّا أَيِي: ”شكْ، \add أَ\add* مِّيسْ ن بْنَاذمْ، خْزَارْ، أَذْ أَرْژغْ ڒعْوتْشْ ن وغْرُومْ ذِي ؤُرْشَالِيمْ ؤُشَا نِيثْنِي أَذْ شّنْ أَغْرُومْ س ڒوْزنْ س ؤُنخْڒِيعْ ؤُشَا س أَرْجفْ أَذْ سْونْ أَمَانْ س ڒعْبَارْ،\f ◼ \fr 4:‏16 \ft \bd ’ڒعْوتْشْ ن وغْرُومْ‘\bd* - س ثْعِيبْرَانِيثْ ’أَعْمُوذْ ن وغْرُومْ‘.\f*  \x ◘ \xo 4:‏16 \xt لَاوِي 26‏:‏26؛ إِشا. 3‏:‏1؛ حِز. 5‏:‏16؛ 14‏:‏13\x*
\v 17 مِينْزِي أَذْ أَسنْ إِتّْخصَّا وغْرُومْ ذ وَامَانْ. نِيثْنِي أَذْ خْزَارنْ أَيَاوْيَا س أَرْجفْ ؤُشَا أَذْ ذوْڒنْ أَرْصُوضنْ ذِي ڒْمُوعْصِييّثْ نْسنْ.“
\b
\b
\c 5
\m 
\v 1 ”ؤُشَا شكْ، \add أَ\add* مِّيسْ ن بْنَاذمْ، كْسِي إِجّْ ن ڒْمُوسْ إِقْضعْ، كْسِي إِجّْ ڒْمُوسْ ن ؤُحفَّافْ ؤُشَا سكّْ إِ-ث خْ ؤُزدْجِيفْ نّشْ ؤُ خْ ثْمَارْثْ نّشْ. \add خنِّي\add* أَذْ ثكْسِيذْ إِجّْ ن ڒْمِيزَانْ ؤُشَا \add أَشُوَّافْ\add* أَذْ ثنْ ثبْضِيذْ. \x ◘ \xo 5:‏1 \xt 2 صم. 10‏:‏4\x*
\v 2 \bd إِشْثْ ن تُّوڒُوثْ\bd* أَذْ ت ثسّْشمْضذْ ذِي ڒْوسْطْ ن ثنْذِينْثْ أَوَارْنِي ڒَامِي إِ غَا كمّْڒنْ وُوسَّانْ ن ڒحْصَارثْ \add ؤُشَا\add* أَذْ ثكْسِيذْ \bd إِشْثْ ن تُّوڒُوثْ\bd* \add نّغْنِي\add*، أَذْ ثوْثذْ س سِّيفْ نّشْ ذڭْ ونّضْ نّسْ ؤُشَا \bd إِشْثْ ن تُّوڒُوثْ\bd* \add نّغْنِي\add* أَذْ ت ثْزُوزَّارذْ ذڭْ ؤُسمِّيضْ ؤُ نشّْ أَذْ جبْذغْ سِّيفْ أَوَارْنِي أَسْ. \x ◘ \xo 5:‏2 \xt لَاوِي 26‏:‏33؛ زَاك. 13‏:‏8\x*
\v 3 سّنِّي أَذْ ثكْسِيذْ \bd شْوَايْثْ \bdit ن إِژطَّانْ\bdit*\bd* ؤُشَا أَذْ ثنْ ثْشدّذْ ذڭْ إِبحْرُورنْ \add ن ؤُپَارْثسُّو\add* نّشْ.
\v 4 أَذْ \bd زَّايسْ\bd* ثكْسِيذْ \bd عَاذْ شْوَايْثْ \bdit ن إِژطَّانْ\bdit*\bd* ؤُشَا أَذْ ثنْ ثنْضَارذْ ذِي ڒْوسْثْ ن ثْمسِّي ؤُشَا أَذْ ثنْ ثسّْشمْضذْ س ثْمسِّي. سّنِّي أَذْ ثفّغْ ثْمسِّي خْ مَارَّا ثَادَّارْثْ ن إِسْرَائِيل.“
\m 
\v 5 ”أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ثَا ذ ؤُرْشَالِيمْ إِ ژُّوغْ ذِي ڒْوسْطْ ن ڒڭْنُوسْ، أَكْ-ذ ثمُّورَا إِ ذ أَسْ د-إِنّْضنْ.
\v 6 \add مَاشَا\add* نتَّاثْ ثْغوّغْ خْ لْفَارَايِيضْ إِنُو مَاهُو ڒڭْنُوسْ، ؤُڒَا خْ ثْوصَّا إِنُو مَاهُو ثِيمُّورَا إِ ذ أَسْ د-إِنّْضنْ، مِينْزِي نِيثْنِي نْضَارنْ لْفَارَايِيضْ إِنُو ؤُ ثِيوصَّا إِنُو وَارْ ثنْثْ ضْفَارنْ.“
\v 7 ”س ؤُيَا، أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ’مِينْزِي كنِّيوْ ثڭِّيمْ مَاهُو ڒڭْنُوسْ إِ ذ أَومْ د-إِنّْضنْ، وَارْ ثُويُورمْ ذِي ثْوصَّا إِنُو ؤُ وَارْ ثڭِّيمْ لْفَارَايِيضْ إِنُو، عَاذْ وَارْ ثڭِّيمْ عْلَاحْسَابْ لْفَارَايِيضْ نْ ڒڭْنُوسْ إِ ذ أَومْ د-إِنّْضنْ‘، \x ◘ \xo 5:‏7 \xt لَاوِي 18‏:‏24، 28\x*
\v 8 س ؤُيَا، أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ’خْزَارْ، ؤُڒَا ذ نشّْ أَذْ خَامْ قڒْبغْ ؤُ أَذْ ڭّغْ ڒحْكَامَاثْ ذِي ڒْوسْطْ نّمْ زَّاثْ إِ ثِيطَّاوِينْ ن ڒڭْنُوسْ.
\v 9 أَذْ زَّايمْ ڭّغْ أَمْ مَامّشْعمَّارْصْ وَارْ ڭِّيغْ ؤُ وَارْ تّڭّغْعمَّارْصْ عَاذْ زِي سَّا ذ ثْسَاونْثْ، زِي سِّيبّثْ ن مَارَّا جّْعَايفْ نّمْ.
\v 10 س ؤُيَا إِبَابَاثنْ أَذْ شّنْ أَرَّاوْ ذِي ڒْوسْطْ نّمْ ؤُشَا أَرَّاوْ أَذْ شّنْ إِبَابَاثنْ نْسنْ. نشّْ أَذْ أَمْ ڭّغْ ڒحْكَامَاثْ ؤُ مَارَّا مِينْ زَّايمْ إِقِّيمنْ أَذْ ث زُوزَّارغْ غَارْ مَارَّا ثِيغمُّورَا ن ؤُسمِّيضْ.‘ “ \x ◘ \xo 5:‏10 \xt لَاوِي 26‏:‏29؛ أَعَوذ. 28‏:‏53؛ 2 إِج. 6‏:‏29؛ إِڭجذ. 4‏:‏10\x*
\m 
\v 11 ”س ؤُيَا، س ثِيذتّْ أَمْ دَّارغْ نشّْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي: \add س ثِيذتّْ\add*، ؤُڒَا ذ نشّْ أَذْ قضْعغْ، وَارْ زِّيدْجِيزغْ، وَارْ أَرحّْمغْ، ؤُمِي ثسّْخمْجذْ زَّاوشْثْ إِنُو إِقدّْسنْ س مَارَّا نّْعَاوَاثْ نّمْ ن لْ-أَصْنَامْ ؤُ س مَارَّا جّْعَايفْ نّمْ! \x ◘ \xo 5:‏11 \xt حِز. 7‏:‏4\x*
\v 12 \bd إِشْثْ ن تُّوڒُوثْ\bd* \add ن إِمزْذَاغْ\add* نّمْ أَذْ ثمّثْ س طَّاعُونْ ؤُ س ڒَاژْ ذِي ڒْوسْطْ نّمْ، ؤُشَا \bd إِشْثْ ن تُّوڒُوثْ\bd* \add نّغْنِي\add* أَذْ ثوْضَا س سِّيفْ ذڭْ ونّضْ نّمْ، ؤُ \add عَاذْ\add* \bd إِشْثْ ن تُّوڒُوثْ\bd* أَذْ ت زُوزَّارغْ غَارْ مَارَّا ثِيغمُّورَا ن ؤُسمِّيضْ ؤُ أَوَارْنِي أَسنْ أَذْ د-جبْذغْ سِّيفْ. \x ◘ \xo 5:‏12 \xt إِرْم. 15‏:‏2\x*
\v 13 أَغْضَابْ إِنُو أَذْ إِجِّيونْ أَڒْ ؤُنڭَّارْ ؤُشَا أَذْ خَاسنْ سَّارْسغْ أَسْعَارْ إِنُو. \add أَمُّو\add* إِ غَا سّْفوّْجغْ إِخفْ إِنُو ؤُ نِيثْنِي أَذْ سّْننْ، أَقَا نشّْ، سِيذِي، سِّيوْڒغْ ذِي ثُوسْمِي إِنُو \add إِقدّْسنْ\add*، خْمِي غَا كمّْڒغْ أَسْعَارْ إِنُو خَاسنْ.
\v 14 أَذْ شمْ أَرّغْ ذ ڒْخِيرْبثْ ذ إِشْثْ ن ڒْقشْعثْ ن ؤُسْثهْزِي جَارْ ڒڭْنُوسْ إِ ذ أَمْ د-إِنّْضنْ، زَّاثْ إِ ثِيطَّاوِينْ ن كُوڒْ إِجّْ نِّي إِ غَا إِعْذُونْ.
\v 15 أَذْ ثذْوڒْ \add ؤُرْشَالِيمْ\add* إِ ؤُسْثهْزِي ذ ڒْحڭْرَا، إِ \add ؤُمذْيَا ن\add* ؤُسقْسحْ ذ ؤُسِيڭّْوذْ إِ ڒڭْنُوسْ إِ ذ أَسْ د-إِنّْضنْ، خْمِي ذ أَسْ إِ غَا قْضغْ ڒحْكَامَاثْ س وغْضَابْ ؤُ س وسْعَارْ ؤُ س ثِييِيتَّا إِحْمَانْ. نشّْ، سِيذِي، أَقَا سِّيوْڒغْ! \x ◘ \xo 5:‏15 \xt أَعَوذ. 28‏:‏37\x*
\v 16 خْمِي ثنْ غَا وْثغْ س فْڒِيثْشَاثْ ن ڒَاژْ نِّي د غَا يَاوْينْ أَردّدْجْ، ثِينِّي غَا وْثغْ حِيمَا أَذْ كنِّيوْ سّْهلّْكغْ، \add خنِّي\add* أَذْ خَاومْ أَرْنِيغْ ڒَاژْ ؤُ أَذْ أَرْژغْ ڒعْوتْشْ ن وغْرُومْ \add نْومْ\add*. \x ◘ \xo 5:‏16 \xt لَاوِي 26‏:‏26؛ 2 إِج. 6‏:‏25؛ إِشا. 3‏:‏1؛ حِز. 4‏:‏16؛ 14‏:‏13\x*
\v 17 أَذْ خَاومْ سكّغْ ڒَاژْ ذ ڒوْحُوشْ إِوْعَارنْ نِّي إِ غَا إِكّْسنْ ثَارْوَا نّمْ. طَّاعُونْ ذ ؤُسِيزّڒْ ن إِذَامّنْ أَذْ كّنْ خَامْ ؤُ نشّْ أَذْ خَامْ سّكّغْ سِّيفْ. نشّْ، سِيذِي، أَقَا سِّيوْڒغْ!“ \x ◘ \xo 5:‏17 \xt لَاوِي 26‏:‏22\x*
\b
\b
\c 6
\s1 أَوَاڒْ ضِيدّْ إِ إِذُورَارْ ن إِسْرَائِيل
\m 
\v 1 يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا:
\v 2 ”\add أَ\add* مِّيسْ ن بْنَاذمْ، أَرّْ ؤُذمْ نّشْ غَارْ إِذُورَارْ ن إِسْرَائِيل ؤُشَا نَابّْ خَاسنْ \x ◘ \xo 6:‏2 \xt حِز. 36‏:‏1\x*
\v 3 ؤُشَا إِنِي: ’\add أَ\add* إِذُورَارْ ن إِسْرَائِيل، سْڒمْ إِ وَاوَاڒْ ن سِيذِي إِنُو، سِيذِي! أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي، إِ إِذُورَارْ ؤُ إِ ثوْرِيرِينْ، إِ ثْغزْرَاثِينْ ؤُ إِ ثغْزُورْثِينْ: خْزَارْ، نشّْ أَذْ خَاومْ سّكّغْ سِّيفْ ؤُشَا ڒڭْعُوذِي نْومْ \add مَانِي ثتّْوهَّابمْ دّْبَايحْ نْومْ\add* أَذْ ثنْثْ أَردّْدْجغْ.
\v 4 أَذْ تّْوَارذْدْجنْ إِعَالْطَارنْ نْومْ ؤُ إِپِيلَارنْ ن أَربِّي ن ثْفُوشْثْ نْومْ أَذْ تّْوَارْژنْ ؤُ نشّْ أَذْ نْضَارغْ إِنِّي إِتّْوَاسّْنُوقْبنْ زَّاثْ إِ وُوذمْ ن إِميْضَا ن \add لْ-أَصْنَامْ نْومْ\add*.
\v 5 أَذْ ڭّغْ ڒْخشْبَاثْ ن أَيْثْ ن إِسْرَائِيل زَّاثْ إِ إِميْضَا ن \add لْ-أَصْنَامْ نْسنْ\add* ؤُشَا أَذْ زُوزَّارغْ إِغْسَانْ نْومْ غَارْ مِينْ د-إِنّْضنْ إِ إِعَالْطَارنْ نْومْ.
\v 6 ذِي مَارَّا إِمُوشَانْ مَانِي ثْزدّْغمْ أَذْ تّْوَاردّْدْجنْثْ ثْندَّامْ ؤُشَا ڒڭْعُوذِي أَذْ ثنْثْ جّنْ، أَڒَامِي إِعَالْطَارنْ نْومْ أَذْ إِڒِينْ ذ ڒْخَارْبثْ ذ تّْوَاجّنْ، ؤُشَا إِميْضَا ن \add لْ-أَصْنَامْ نْومْ\add* أَذْ تّْوَارْژنْ ؤُ إِپِيلَارنْ نْومْ ن أَربِّي ن ثْفُوشْثْ أَذْ تّْوَاقسّنْ ؤُ ثِيمڭَّا نْومْ أَذْ تّْوَامْحَانْثْ.
\v 7 إِنِّي إِتّْوَانْغنْ أَذْ \add ذِينْ\add* إِڒِينْ ذِي ڒْوسْطْ نْومْ، ؤُشَا \add أَمُّو\add* إِ غَا ثسّْنمْ أَقَا نشّْ ذ سِيذِي.‘ “
\m 
\v 8 ”أَذْ ڭّغْ أَقَا إِنِّي إِتّْوَاسّْنجْمنْ زِي سِّيفْ جَارْ ڒڭْنُوسْ أَذْ قِّيمنْ دَّارنْ ؤُمِي كنِّيوْ غَا زُوزَّارغْ خْ ثمُّورَا.
\v 9 إِنِّي إِتّْوَانجْمنْ أَذْ خَافِيعقْڒنْ جَارْ رڭْنُوسْ مَانِي تّْوَاندّْهنْ ذ إِمحْبَاسْ، مِينْزِي نشّْ أَرْژِيغْ ؤُڒْ نْسنْ نِّي خَافِي إِتَّاڭّْوجنْ، إِشُّورنْ س فَارْقْ-شّْغڒْ ؤُشَا ؤُڒَا ذ ثِيطَّاوِينْ نْسنْ نِّي إِضْفَارنْ أَوَارْنِي إِ إِميْضَا ن \add لْ-أَصْنَامْ نْسنْ\add* شُّورنْثْ س فَارْقْ-شّْغڒْ. نِيثْنِي أَذْ عِيفّنْ إِخفْ نْسنْ زِي سِّيبّثْ ن ثْمڭَّا إِعفّْننْ نِّي ڭِّينْ س مَارَّا جَّاعَايفْ نْسنْ.
\v 10 نِيثْنِي أَذْ سّْننْ بلِّي نشّْ ذ سِيذِي. نشّْ وَارْ نِّيغْ أَمنِّي وَاهَا أَقَا نشّْ أَذْ ذَايْسنْ ڭّغْ ڒْغَارْ-أَ.“
\m 
\v 11 ”أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: وّثْ س ؤُفُوسْ نّشْ ؤُشَا ذَارّشْ س ؤُضَارْ نّشْ ؤُشَا إِنِي: ’أَيْ!‘ خْ مَارَّا نّْعَاوَاثْ ثِيعفَّانِينْ ن ثَادَّارْثْ ن إِسْرَائِيل، مَاغَارْ نِيثْنِي أَذْ وْضَانْ س سِّيفْ، س ڒَاژْ ؤُ س طَّاعُونْ! \x ◘ \xo 6:‏11 \xt حِز. 21‏:‏22\x*
\v 12 وِي إِدْجَانْ يِيڭّْوجْ أَذْ إِمّثْ س طَّاعُونْ ؤُ وِي إِدْجَانْ يُوذسْ أَذْ إِوْضَا س سِّيفْ ؤُ وِي إِقِّيمنْ ؤُ أَقَا إِتّْوَاحْصَارْ أَذْ إِمّثْ س ڒَاژْ، \add أَمُّو\add* أَذْ ذَايْسنْ كمّْڒغْ أَسْعَارْ إِنُو.
\v 13 إِتّْخصَّا أَذْ ثسّْنمْ بلِّي نشّْ ذ سِيذِي، خْمِي إِنِّي زَّايْسنْ إِتّْوَانْغنْ أَذْ \add ذِينْ\add* إِڒِينْ جَارْ إِميْضَا ن \add لْ-أَصْنَامْ نْسنْ\add* ذڭْ ونّضْ ن إِعَالْطَارنْ نْسنْ خْ كُوڒْ ثَاوْرِيرْثْ ثُوعْڒَا، خْ مَارَّا ثِيقِّيشَاثِينْ ن إِذُورَارْ، سَاذُو كُوڒْ ثَاشجَّارْثْ ثَازِيزَاوْثْ ؤُ سَاذُو كُوڒْ ثَاشجَّارْثْ ن يِيڭّْ س وَاطَّاسْ ن ثفْرَايْ، \add ذڭْ\add* ومْشَانْ مَانِي نُّومنْ سّوْجَاذنْ إِشْثْ ن ڒفْوَاحثْ إِتّْفُوحنْ إِ مَارَّا إِميْضَا ن \add لْ-أَصْنَامْ نْسنْ\add*. \f ◼ \fr 6:‏13 \ft \bd ’ثَاشجَّارْثْ‘\bd* - نِيغْ ’أَدَّاڭْ‘ (’إِدَّاڭنْ‘).\f*
\v 14 أَذْ سّْوِيژّْضغْ أَفُوسْ إِنُو ضِيدّْ نْسنْ ؤُشَا أَذْ ڭّغْ ثَامُّورْثْ ذ إِشْثْ ن ثمُّورْثْ إِتّْوَاردّْدْجنْ، إِشْثْ ن ثمُّورْثْ إِتّْوَاردّْدْجنْ مَاهُو ڒخْڒَا ن ذَابْلَا، ذِي مَارَّا إِمُوشَانْ مَانِي زدّْغنْ. ؤُشَا نِيثْنِي أَذْ سّْننْ بلِّي نشّْ ذ سِيذِي.“
\b
\b
\c 7
\s1 أَنڭَّارُو أَذْ د-يَاسْ!
\m 
\v 1 يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا:
\m 
\v 2 ”شكْ، \add أَ\add* مِّيسْ ن بْنَاذمْ، أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي، إِ ثمُّورْثْ ن إِسْرَائِيل:
\b
\m \qt ’أَنڭَّارْ، يُوسَا-د ؤُنڭَّارْ\qt*
\m \qt خْ أَربْعَا ن إِغزْذِيسنْ ن ثمُّورْثْ.\qt*
\m 
\v 3 \qt ڒخُّو يُوسَا-د خَامْ ؤُنڭَّارْ نّمْ،\qt*
\m \qt مِينْزِي أَذْ غَارمْ د-سكّغْ أَغْضَابْ إِنُو\qt*
\m \qt ؤُ أَذْ خَامْ حكْمغْ أَمْ يِيبْرِيذنْ نّمْ\qt*
\m \qt ؤُشَا أَذْ خَامْ ڭّغْ مَارَّا جّْعَايفْ نّمْ.\qt*
\m 
\v 4 \qt وَارْ ذ أَمْ زِّيدْجِيزنْثْ ثِيطَّاوِينْ إِنُو\qt*
\m \qt ؤُ وَارْ أَرحّْمغْ،\qt*
\m \qt مِينْزِي أَذْ أَرّغْ إِبْرِيذنْ نّمْ\qt*
\m \qt خْ ؤُزدْجِيفْ نّمْ\qt*
\m \qt ؤُ جّْعَايفْ نّمْ أَذْ شمْ ڒقْفنْثْ\qt*
\m \qt ذِي ڒْوسْطْ نّمْ.\qt*
\m \qt \tl أَمُّو إِ غَا\tl* ثسّْنمْ بلِّي نشّْ ذ سِيذِي.‘\qt* \x ◘ \xo 7:‏4 \xt حِز. 5‏:‏11؛ 8‏:‏18\x*
\b
\m 
\v 5 أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي:
\m \qt ’إِجّْ ن ڒْغَارْ، إِجّْ ن ڒْغَارْ إِفَارْزنْ،\qt*
\m \qt أَقَا أَذْ د-يَاسْ.\qt*
\m 
\v 6 \qt يُوسَا-د ؤُنڭَّارْ،\qt*
\m \qt أَنڭَّارْ يُوسَا-د،\qt*
\m \qt إِفَاقْ-د ضِيدّْ نّمْ،\qt*
\m \qt أَقَا أَذْ د-يَاسْ!\qt*
\m 
\v 7 \qt ثُوسَا-د غَاركْ ثْقدُّوحْثْ،\qt*
\m \qt \tl أَ\tl* أَمزْذُوغْ ن ثمُّورْثْ،\qt*
\m \qt ثَاسَاعّثْ ثُوسَا-د،\qt*
\m \qt أَسّْ ن ؤُخَارْوضْ إِقَارّبْ-د\qt*
\m \qt ؤُ وَارْ \tl ذِينْ\tl* أَسْڒِيوْڒوْ\qt*
\m \qt زڭْ إِذُورَارْ.\qt* \f ◼ \fr 7:‏7 \ft \bd ’ثَاسَاعّثْ‘\bd* - س ثْعِيبْرَانِيثْ ’ڒْوقْثْ‘.\f*
\m 
\v 8 \qt ڒخُّو ذغْيَا أَذْ خَامْ زدْجْعغْ أَسْعَارْ إِنُو\qt*
\m \qt ؤُشَا أَذْ ذَايمْ كمّْڒغْ أَغْضَابْ إِنُو.\qt*
\m \qt أَذْ خَامْ حكْمغْ أَنشْثْ ن إِبْرِيذنْ نّمْ\qt*
\m \qt ؤُشَا أَذْ خَامْ سِّيوْضغْ\qt*
\m \qt مَارَّا جّْعَايفْ نّمْ.\qt*
\m 
\v 9 \qt وَارْ زِّيدْجِيزغْ ؤُ وَارْ أَرحّْمغْ.\qt*
\m \qt أَذْ غَارمْ د-أَرّغْ\qt*
\m \qt مِينْ ثسّْذَاهدْجذْ،\qt*
\m \qt ؤُ جّْعَايفْ نّمْ أَذْ إِڒِينْثْ ذِي ڒْوسْطْ نّمْ\qt*
\m \qt ؤُ كنِّيوْ أَذْ ثسّْنمْ\qt*
\m \qt بلِّي أَقَا نشّْ ذ سِيذِي\qt*
\m \qt ونِّي كنِّيوْ إِشَّاثنْ.‘\qt*
\b
\m 
\v 10 \qt ’خْزَارْ، أَسّْ، خْزَارْ،\qt*
\m \qt أَقَا ذَا ثِيوضْ-د \tl ثْقدُّوحْثْ\tl*،\qt*
\m \qt ثقْضَا ثْقدُّوحْثْ،\qt*
\m \qt ثْنوَّارْ ثَاغَّارْشْثْ،\qt*
\m \qt ثسّنْذِي نّْفَاخثْ.\qt*
\m 
\v 11 \qt إِڭعّذْ لْعُونْفْ أَمْ ؤُزدْجَاضْ ن ڒْغَارْ.\qt*
\m \qt وَارْ زَّايْسنْ إِقِّيمْ ؤُڒَا ذ إِجّْ،\qt*
\m \qt وَالُو ن ڒْغَاشِي نْسنْ إِنْهوْڒنْ،\qt*
\m \qt وَالُو ن دّْرِيزْ نْسنْ\qt*
\m \qt ؤُ وَالُو ن ؤُسمْغَارْ أَذْ غَارْسنْ إِقِّيمْ عَاذْ.\qt*
\m 
\v 12 \qt ثُوسَا-د ثْسَاعّثْ، إِخشّذْ وَاسّْ.\qt*
\m \qt أجّْ ونِّي إِسْغِينْ وَارْ إِفَارّحْ\qt*
\m \qt ؤُ أجّْ ونِّي إِزّْنُوزَانْ وَارْ إِتّشْضِينْ،\qt*
\m \qt مِينْزِي ڒْحَاذُوقْ ن وغْضَابْ\qt*
\m \qt \tl أَقَا-ث\tl* خْ مَارَّا ڒْغَاشِي نّسْ إِنْهوْڒنْ.\qt*
\m 
\v 13 \qt مِينْزِي ونِّي إِزّْنُوزَانْ\qt*
\m \qt وَارْ د-إِذِّيكّْوِيڒْ\qt*
\m \qt غَارْ مِينْ إِمّنْزنْ،\qt*
\m \qt وَاخَّا نِيثْنِي قِّيمنْ دَّارنْ،\qt*
\m \qt مِينْزِي وَارْ إِبطِّيڒْ ڒوْحِييْ\qt*
\m \qt خْ مَارَّا ڒْغَاشِي إِنْهوْڒنْ ن ثمُّورْثْ،\qt*
\m \qt ؤُشَا ؤُڒَا ذ إِجّْ وَارْ إِزمَّارْ س ڒْمُوعْصِييّثْ نّسْ\qt*
\m \qt أَذْ إِقِّيمْ إِتّطّفْ ذِي ثُوذَارْثْ نّسْ.\qt*
\m 
\v 14 \qt نِيثْنِي سُوضنْ س جّهْذْ \tl ذِي ڒْبُوقْ\tl*\qt*
\m \qt ؤُشَا سّْوجْذنْ مَارَّا ڒحْوَايجْ،\qt*
\m \qt \tl مَاشَا\tl* ؤُڒَا ذ إِجّْ وَارْ إِتّفّغْ غَارْ ؤُمنْغِي،\qt*
\m \qt مِينْزِي ڒْحَاذُوقْ ن وغْضَابْ إِنُو\qt*
\m \qt \tl أَقَا-ث\tl* خْ مَارَّا ڒْغَاشِي إِنْهوْڒنْ ن ثمُّورْثْ.‘\qt*
\b
\m 
\v 15 \qt ’زِي بَارَّا سِّيفْ\qt*
\m \qt ؤُ زِي ذَاخڒْ طَّاعُونْ ذ ڒَاژْ.\qt*
\m \qt وِي إِدْجَانْ ذڭْ إِيَّارْ أَذْ إِمّثْ س سِّيفْ،\qt*
\m \qt وِي إِدْجَانْ ذِي ثنْذِينْثْ أَذْ ث يشّْ ڒَاژْ ذ طَّاعُونْ.\qt*
\m 
\v 16 \qt وِي زَّايْسنْ يَاروْڒنْ، \tl وَاهْ\tl* أَذْ نجْمنْ،\qt*
\m \qt مَاشَا أَذْ إِڒِينْ خْ إِذُورَارْ\qt*
\m \qt أَمْ إِذْبِيرنْ زِي ثغْزُورِينْ،\qt*
\m \qt أَذْ نّزْبَارنْ مَارَّا،\qt*
\m \qt كُوڒْ إِجّْ خْ ڒْمُوعْصِييّثْ نّسْ.\qt*
\m 
\v 17 \qt مَارَّا إِفَاسّنْ أَذْ هيّْفنْ،\qt*
\m \qt ؤُ مَارَّا إِفَادّنْ أَذْ ذوْڒنْ ذ أَمَانْ.‘\qt* \x ◘ \xo 7:‏17 \xt إِشا. 13‏:‏7؛ إِرْم. 6‏:‏24\x*
\b
\m 
\v 18 \qt ’أَذْ بيْسنْ س ثْخُونْشَايْ ن \tl وشْضَانْ\tl*،\qt*
\m \qt أَرْجفْ أَذْ ثنْ إِسّْذُورِييْ\qt*
\m \qt خْ مَارَّا ؤُذْمَاونْ \tl أَذْ يِيڒِي\tl* ڒحْيَا\qt*
\m \qt ؤُ خْ مَارَّا إِزدْجِيفنْ نْسنْ ثُوقشَّارْثْ.\qt* \x ◘ \xo 7:‏18 \xt إِشا. 15‏:‏2، 3؛ إِرْم. 48‏:‏37\x*
\m 
\v 19 \qt أَذْ نْضَارنْ نُّوقَارْثْ نْسنْ ذڭْ إِبْرِيذنْ\qt*
\m \qt ؤُ ؤُرغْ نْسنْ أَذْ يِيڒِي أَمْ شَا ن ڒْحَاجّثْ ثخْمجْ.\qt*
\m \qt نُّوقَارْثْ نْسنْ ذ وُورغْ نْسنْ\qt*
\m \qt وَارْ زمَّارنْ أَذْ ثنْ فكّنْ\qt*
\m \qt ذڭْ وَاسّْ ن ؤُذُوقّزْ \tl ن ؤُفُوڭمْ\tl* ن سِيذِي.\qt*
\m \qt وَارْ زمَّارنْ أَذْ زَّايْسنْ سّْجِيوْننْ\qt*
\m \qt ڒعْمَارْ نْسنْ\qt*
\m \qt نِيغْ أَذْ زَّايْسنْ شُّورنْ ثَاكْرِيشْثْ نْسنْ،\qt*
\m \qt مِينْزِي أَيَا ثُوغَا ذ سِّيبّثْ ن ؤُنقْرَاضْ\qt*
\m \qt إِ د-يِيوْينْ ڒْمُوعْصِييّثْ نْسنْ.\qt* \x ◘ \xo 7:‏19 \xt أَوڒن. 11‏:‏4؛ صَاف. 1‏:‏18\x*
\m 
\v 20 \qt أَژْرِي ن ثلْوِيزْثْ إِڭَّا إِ-ث ذ لْعَاضَامَا يُوعْڒَانْ،\qt*
\m \qt \tl مَاشَا\tl* نِيثْنِي ڭِّينْ ذَايسْ\qt*
\m \qt ڒخْيَاڒَاثْ ن نّْعَاوَاثْ نْسنْ ن لْ-أَصْنَامْ\qt*
\m \qt ؤُ ڒخْيَاڒَاثْ ن جّْعَايفْ نْسنْ.\qt*
\m \qt خْ ؤُيَا أَرِّيغْ \tl ثَالْوِيزْثْ\tl* ذ ثَاخْمُوجِي إِ نِيثْنِي.\qt*
\m 
\v 21 \qt نشّْ أَذْ ت وْشغْ ذ ثُوشّفّْرَا\qt*
\m \qt ذڭْ ؤُفُوسْ ن إِبَارَّانِييّنْ\qt*
\m \qt ؤُشَا \tl أَذْ ت وْشغْ\tl* ذ ثَاكشَّاضْثْ\qt*
\m \qt إِ إِعفَّاننْ ن ثمُّورْثْ،\qt*
\m \qt ؤُشَا نِيثْنِي أَذْ سّْعِيدْجْثنْ \tl ثَالْوِيزْثْ\tl*.\qt*
\m 
\v 22 \qt نشّْ أَذْ خَاسْ سّنْقڒْبغْ ؤُذمْ إِنُو\qt*
\m \qt ؤُ نِيثْنِي أَذْ سّْعِيدْجْثنْ ثَازذِّيغْثْ إِنُو إِنُّوفَارنْ،\qt*
\m \qt مَاغَارْ إِشفَّارنْ أَذْ ذِينْ أَذْفنْ\qt*
\m \qt ؤُشَا أَذْ سّْعِيدْجْثنْ \tl مَارَّا\tl*.‘\qt*
\b
\m 
\v 23 \qt ’سوْجذْ سّْنسْڒثْ،\qt*
\m \qt مِينْزِي ثَامُّورْثْ ثشُّورْ س ؤُسِيزّڒْ ن إِذَامّنْ\qt*
\m \qt ؤُ ثَانْذِينْثْ ثشُّورْ س لْعُونْفْ.\qt*
\m 
\v 24 \qt نشّْ أَذْ أَوْيغْ ڒڭْنُوسْ إِعفَّاننْ قَاعْ،\qt*
\m \qt ؤُ نِيثْنِي أَذْ طّْفنْ ثُوذْرِينْ نْسنْ،\qt*
\m \qt أَذْ سّْبدّنْ نّْفَاخثْ ن أَيْثْ ن جّهْذْ،\qt*
\m \qt ؤُشَا أَذْ تّْوَاسّْعِيدْجْثنْثْ\qt*
\m \qt ثْزَاوِييِّينْ نْسنْ إِقدّْسنْ.\qt*
\m 
\v 25 \qt أَذْ د-يَاسْ ؤُنخْڒِيعْ ذ أَمقّْرَانْ.\qt*
\m \qt نِيثْنِي أَذْ أَرْزُونْ ڒهْنَا،\qt*
\m \qt \tl مَاشَا\tl* وَارْ إِتِّيڒِي.\qt*
\m 
\v 26 \qt أَقَا أَذْ د-يَاسْ ؤُشڒْوَاوْ أَوَارْنِي إِ ؤُشڒْوَاوْ،\qt*
\m \qt أَذْ يِيڒِي ڒْهَارْذْ أَوَارْنِي إِ ڒْهَارْذْ.\qt*
\m \qt نِيثْنِي أَذْ أَرْزُونْ ڒوْحِييْ ن ؤُنَابِي،\qt*
\m \qt وَاخَّا ثقْضَا شَّارِيعَا ن ؤُكهَّانْ\qt*
\m \qt ذ شّْوَارْ ن إِمْغَارنْ\qt*
\m 
\v 27 \qt أَجدْجِيذْ أَذْ إِشْضنْ،\qt*
\m \qt ڒْحَاكمْ أَذْ يَارْضْ أَنخْڒِيعْ\qt*
\m \qt ؤُ إِفَاسّنْ ن ڒْڭنْسْ\qt*
\m \qt أَذْ قَارّْمنْ س ثِيڭّْوُوذِي.\qt*
\m \qt نشّْ أَذْ زَّايْسنْ ڭّغْ أَمْ وبْرِيذْ نْسنْ\qt*
\m \qt ؤُ نشّْ أَذْ خَاسنْ حكْمغْ\qt*
\m \qt أَمْ لْفَارَايِيضْ نْسنْ.\qt*
\m \qt \tl أَمُّو\tl* إِ غَا سّْننْ أَقَا نشّْ ذ سِيذِي.‘ “\qt*
\b
\b
\c 8
\s1 أَعْبذْ ن لْ-أَصْنَامْ ذِي زَّاوشْثْ ثَامقّْرَانْثْ ذِي ؤُرْشَالِيمْ
\m 
\v 1 \bd ذڭْ ؤُسڭّْوَاسْ وِيسّْ ستَّا، ذڭْ ؤُيُورْ وِيسّْ ستَّا، ذڭْ \bdit وَاسّْ\bdit* وِيسّْ خمْسَا ن ؤُيُورْ\bd*، \add ؤُمِي\add* ثُوغَا قِّيمغْ ذِي ثُوذَارْثْ إِنُو ؤُ إِمْغَارنْ ن يَاهُوذَا ثُوغَا قِّيمنْ زَّاثْ إِ وُوذمْ إِنُو، \add خنِّي\add* إِمْسَارْ أَقَا إِوْضَا-د خَافِي ذِينْ ؤُفُوسْ ن سِيذِي إِنُو، سِيذِي.
\v 2 نشّْ ژْرِيغْ، ؤُشَا خْزَارْ، ثُوغَا ذِينْ ونِّي صْسِيفثْ نّسْ يَارْوسنْ ذڭْ وُوذمْ ن ثْمسِّي. زِي ثجْعِينَّاثِينْ نّسْ غَارْ وَادَّايْ أَقَا إِبَانْ-د أَمْ ثْمسِّي ؤُ زِي ثجْعِينَّاثِينْ نّسْ أَڒْ سنّجْ \add ثُوغَا\add* أَخْمِي ثژْرِيذْ ثِيسِّيقْثْ، ثْبَانْ-د أَمْ وُوزَّاڒْ إِتّْوسّْڭنْ.
\v 3 إِسّْوِيژّضْ-د مِينْ يَارْوسنْ ذڭْ إِجّْ ن ؤُفُوسْ ؤُشَا نتَّا إِطّفْ أَيِي-د غَارْ إِشْثْ ن ثْزَارزْثْ ن ؤُزدْجِيفْ إِنُو، ؤُشَا أَرُّوحْ إِسّْڭعّذْ أَيِي جَارْ ؤُجنَّا ذ ثمُّورْثْ، إِنْذهْ أَيِي ذِي إِوحَّانْ ن أَربِّي غَارْ ؤُرْشَالِيمْ، غَارْ وَاذَافْ \add ن ثوَّارْثْ\add* ن ڒمْرَاحْ ن ذَاخڒْ نِّي إِخزَّارنْ غَارْ شَّامَالْ، مَانِي إِدْجَا ڒْكُورْسِي ن ڒخْيَاڒْ ن لْ-أَصْنَامْ ن ثُوسْمِي نِّي إِسّكَّارَانْ ثُوسْمِي. \x ◘ \xo 8:‏3 \xt دَان. 5‏:‏5\x*
\v 4 ؤُ خْزَارْ، ذِينْ إِ إِدْجَا ؤُعُودْجِي ن أَربِّي ن إِسْرَائِيل، إِتّْبَانْ-د أَمْ مَامّشْ \add ث\add* ژْرِيغْ ذِي ڒوْضَا ن ثغْزُورْثْ. \x ◘ \xo 8:‏4 \xt حِز. 3‏:‏23\x*
\v 5 نتَّا إِنَّا أَيِي: ”\add أَ\add* مِّيسْ ن بْنَاذمْ، سْڭعّذْ ڒخُّو ثَامُوغْڒِي نّشْ غَارْ شَّامَالْ!“ ؤُشَا سّْڭعّْذغْ ثَامُوغْڒِي إِنُو جِّيهثْ ن شَّامَالْ، ؤُ خْزَارْ، إِبدّْ \add ذِينْ\add* ڒخْيَاڒْ نِّي ن صَّانَامْ ن ثُوسْمِي غَارْ شَّامَالْ ن ثوَّارْثْ ن ؤُعَالْطَارْ ذڭْ وَاذَافْ.
\v 6 \add خَاسْ ؤُشَا\add* إِنَّا أَيِي: ”\add أَ\add* مِّيسْ ن بْنَاذمْ، مَا ثتّْوَاڒِيذْ مِينْ تّڭّنْ نِيثْنِي، جّْعَايفْ ثِيمقّْرَانِينْ نِّي ثتّڭّْ ثَادَّارْثْ ن إِسْرَائِيل ذَانِيثَا، أَڒَامِي إِتّْخصَّا أَذْ أَڭّْوجغْ خْ زَّاوشْثْ إِنُو إِقدّْسنْ. أَذْ ثْژَارذْ عَاذْ جّْعَايفْ ثِيمقّْرَانِينْ \add خْ ثِينَا\add*.“
\m 
\v 7 نتَّا يِيوْيِي أَيِي غَارْ وَاذَافْ نْ ڒمْرَاحْ. \add ؤُمِي\add* ژْرِيغْ، خْزَارْ، أَقَا ذِينْ إِجّْ ن وحْفُورْ ذِي ڒْحِيضْ.
\v 8 نتَّا إِنَّا أَيِي: ”\add أَ\add* مِّيسْ ن بْنَاذمْ، غَازْ خنِّي ڒْحِيضْ.“ نشّْ غْزِيغْ ڒْحِيضْ ؤُشَا خْزَارْ، أَقَا ذِينْ إِجّْ ن وَاذَافْ.
\v 9 \add خنِّي\add* إِنَّا أَيِي: ”أَذفْ، ؤُشَا خْزَارْ جّْعَايفْ ثِيمقّْرَانِينْ نِّي تّڭّنْ ذَانِيثَا.“
\v 10 ؤُذْفغْ ؤُشَا ژْرِيغْ، خْزَارْ، أَقَا ذِينْ عْڒَامْ كُوڒْ  إِنقَّاشنْ ن إِمُودَّارنْ إِتّْبُوعنْ، ن ڒْمَاڒْ أَمنْڭُوسْ ؤُ ن مَارَّا إِميْضَا \add ن لْ-أَصْنَامْ\add* ن ثَادَّارْثْ ن إِسْرَائِيل تّْوَانقْشنْ ذِي ڒْحِيذْ ذڭْ ونّضْ. \x ◘ \xo 8:‏10 \xt إِشا. 66‏:‏17\x*
\v 11 أَقَا سبْعِينْ ن يرْيَازنْ زڭْ إِمْغَارنْ ن ثَادَّارْثْ ن إِسْرَائِيل، أَكْ-ذ يَازَانْيَاهُو، مِّيسْ ن شَافَانْ، ذِي ڒْوسْثْ نْسنْ، بدّنْ زَّاثْسنْ ؤُ كُوڒْ إِجّْ س ڒْمجْمَارْ نّسْ ن ڒبْخُورْ ذڭْ ؤُفُوسْ نّسْ ؤُشَا ثُوڒِي ثجْنوْثْ ثشُّورْ س أَرِّيحثْ ن ڒبْخُورْ. \x ◘ \xo 8:‏11 \xt إِشا. 66‏:‏17\x*
\v 12 \add خنِّي\add* إِنَّا أَيِي: ”\add أَ\add* مِّيسْ ن بْنَاذمْ، مَا ثژْرِيذْ مِينْ تّڭّنْ إِمْغَارنْ ن إِسْرَائِيل ذِي ثَادْجسْثْ، كُوڒْ إِجّْ ذڭْ وخَّامْ ن ڒخْيَاڒْ نّسْ إِنقْشنْ، مَاغَارْ قَّارنْ: سِيذِي وَارْ ذ أَنغْ إِژْرِي، سِيذِي يجَّا ثَامُّورْثْ.“ \x ◘ \xo 8:‏12 \xt حِز. 9‏:‏9\x*
\v 13 نتَّا إِنَّا أَيِي: ”أَذْ ثْژَارذْ عَاذْ جّْعَايفْ ثِيمقّْرَانِينْ \add خْ ثِينَا\add* نِّي تّڭّنْ نِيثْنِي.“
\m 
\v 14 \add خنِّي\add* إِنْذهْ أَيِي غَارْ وَاذَافْ ن ثوَّارْثْ ن ثَادَّارْثْ ن سِيذِي، ونِّي إِدْجَانْ غَارْ شَّامَالْ، ؤُ خْزَارْ، قِّيمنْثْ ذِينْ ثمْغَارِينْ تّْرُونْثْ ذِي ثَامُّوزْ. \x ◘ \xo 8:‏14 \xt ؤُف. 38‏:‏8\x*
\v 15 نتَّا إِنَّا أَيِي: ”\add أَ\add* مِّيسْ ن بْنَاذمْ، مَا ثژْرِيذْ أَيَا! أَذْ ثْژَارذْ عَاذْ جّْعَايفْ مْغَارنْثْ خْ ثِينَا.“
\m 
\v 16 ؤُشَا يِيوْيِي أَيِي غَارْ ڒمْرَاحْ ن ذَاخڒْ ن ثَادَّارْثْ ن سِيذِي، ؤُشَا خْزَارْ، غَارْ ثوَّارْثْ ن زَّاوشْثْ ن سِيذِي، جَارْ وسْقِيفْ ذ ؤُعَالْطَارْ، أَقَا ذِينْ عْڒَاحَاڒْ خمْسَا ؤُ-عِيشْرِينْ ن يرْيَازنْ. إِعُورَارْ نْسنْ ذوْڒنْ غَارْ زَّاوشْثْ ن سِيذِي ؤُ ؤُذْمَاونْ نْسنْ غَارْ شَّارْقْ، ؤُشَا نِيثْنِي سجْذنْ غَارْ شَّارْقْ إِ ثْفُوشْثْ.
\v 17 \add خنِّي\add* إِنَّا أَيِي: ”\add أَ\add* مِّيسْ ن بْنَاذمْ، مَا ثژْرِيذْ أَيَا؟ مَا أَقَا ذْرُوسْثْ إِ ثَادَّارْثْ ن يَاهُوذَا مَاحنْذْ أَذْ ڭّنْ جّْعَايفْ-أَ ثِيمقّْرَانِينْ نِّي تّڭّنْ ذَانِيثَا؟ مَاغَارْ نِيثْنِي شُّورنْ ثَامُّورْثْ س لْعُونْفْ ؤُشَا قِّيمنْ ذوْڒنْ-د غَارِي حِيمَا أَذْ أَيِي سْعَارنْ. خْزَارْ، تّڭّنْ \add عَاذْ\add* ثَاسطَّا \add إِتّْوَاقضْعنْ\add* غَارْ ونْزَارنْ نْسنْ!
\v 18 \add خنِّي\add* ؤُڒَا ذ نشّْ أَذْ ڭّغْ س وسْعَارْ. وَارْ ذَايِي إِزِّيدْجِيزْ حذْ ؤُ وَارْ أَرحّْمغْ. وَاخَّا نِيثْنِي سْغُويُّونْ س ثْمِيجَّا إِجهْذنْ ذڭْ إِمزُّوغنْ إِنُو، نشّْ وَارْ د غَارْسنْ تّسْڒِيغْ.“ \x ◘ \xo 8:‏18 \xt أَوڒن. 1‏:‏28؛ إِشا. 1‏:‏15؛ إِرْم. 11‏:‏11؛ حِز. 5‏:‏11؛ 7‏:‏4\x*
\b
\b
\c 9
\s1 ڒْحُوكْمْ خْ ؤُرْشَالِيمْ
\m 
\v 1 \add خنِّي\add* إِڒَاغَا ذڭْ إِمزُّوغنْ إِنُو س ثْمِيجَّا ثجْهذْ، إِنَّا: ”أجّْ إِمحْضَاينْ ن ثنْذِينْثْ أَذْ د-قَارّْبنْ، كُوڒْ  إِجّْ س ڒسْنَاحْ نّسْ ن ؤُردّدْجْ ذڭْ ؤُفُوسْ نّسْ.“
\v 2 ؤُشَا خْزَارْ، ستَّا ن يرْيَازنْ ؤُسِينْ-د زڭْ وبْرِيذْ زِي ثوَّارْثْ يُوعْڒَانْ نِّي إِخزَّارنْ غَارْ شَّامَالْ ؤُ كُوڒْ إِجّْ غَارسْ ڒسْنَاحْ نّسْ إِ ؤُثحِّي ذڭْ ؤُفُوسْ نّسْ. ذِي ڒْوسْطْ نْسنْ ثُوغَا ذِينْ إِجّْ ن ورْيَازْ، ثُوغَا يَارْضْ ڒقْطنْ، يِيوِي ثَاذْوَاثْ ن ؤُمَارِيرْ غَارْ وبْيَاسْ نّسْ. ؤُذْفنْ نِيثْنِي ؤُشَا ڭِّينْ أَذْ بدّنْ غَارْ ؤُعَالْطَارْ ن نّْحَاسْ.
\v 3 أَعُودْجِي ن أَربِّي ن إِسْرَائِيل إِسّْڭعّذْ إِخفْ نّسْ زِي سنّجْ ن ؤُكِيرُوبْ نِّي خْ إِدْجَانْ، يُويُورْ غَارْ ثْنبْذَاثْ ن ثَادَّارْثْ ؤُشَا نتَّا إِڒَاغَا-د إِ ورْيَازْ نِّي يَارْضنْ ڒقْطنْ ذ ونِّي \add يِيوْينْ\add* ثَاذْوَاثْ ن ؤُمَارِيرْ غَارْ وبْيَاسْ نّسْ. \f ◼ \fr 9:‏3 \ft \bd ’أَخِيرُوبْ‘\bd* - إِشْثْ ن مَارْكَا ن لْمَالَاكَاثْ.\f*
\v 4 إِنَّا أَسْ سِيذِي: ”شُوقّْ ذِي ڒْوسْطْ ن ثنْذِينْثْ، ذِي ڒْوسْطْ ن ؤُرْشَالِيمْ، ؤُشَا أڭّْ كْرُوزْ \add ذ ڒعْڒَامثْ\add* خْ ثنْيَارِينْ ن يرْيَازنْ نِّي إِتّْنِيخْسِيسنْ ذ تّْوعّْضنْ خْ سِّيبّثْ ن مَارَّا جّْعَايفْ نِّي إِتّْوَاڭّنْ ذِي ڒْوسْطْ نّسْ.“
\v 5 ؤُمِي سْڒِيغْ، إِنَّا إِ إِنّغْنِي: ”شُوقّمْ ذِي ثنْذِينْثْ أَوَارْنِي أَسْ، نْغمْ، وَارْ زِّيدْجِيزمْ ؤُ وَارْ أَرحّْممْ!
\v 6 نْغمْ إِوسُّورَا، إِحُوضْرِييّنْ، ثِيعزْرِييِينْ، إِحنْجِيرنْ ذ ثمْغَارِينْ أَڒْ غَا تّْوَاهلّْكنْ قَاعْ، مَاشَا وَارْ تّْهَاذَامْ ؤُڒَا ذ إِجّْ خَاسْ كْرُوشْ \add ذ ڒعْڒَامثْ\add*. بْذَامْ زِي زَّاوشْثْ إِنُو إِقدّْسنْ.“ ؤُشَا نِيثْنِي بْذَانْ زڭْ إِوسُّورَا نِّي إِدْجَانْ زَّاثْ إِ ثَادَّارْثْ.
\v 7 ؤُشَا نتَّا إِنَّا أَسنْ: ”سْخمْجمْ ثَادَّارْثْ ؤُشَا شُّورمْ ڒمْرَاحَاثْ س \add ڒْْخشْبَاثْ ن\add* يِينِّي إِتّْوَانْغنْ. فّْغمْ!“ فّْغنْ نِيثْنِي ؤُشَا نْغِينْ \add إِوْذَانْ\add* ذِي ثنْذِينْثْ.
\m 
\v 8 ڒَامِي ثنْ نْغِينْ ؤُشَا قِّيمغْ نشّْ، إِمْسَارْ أَقَا نشّْ وْضِيغْ خْ ؤُغمْبُوبْ إِنُو \add غَارْ ثمُّورْثْ\add* ؤُشَا نِّيغْ: ”أَخْ، سِيذِي إِنُو، سِيذِي، مَا أَذْ ثَاردّْدْجذْ ڒخُّو مِينْ إِقِّيمنْ ن إِسْرَائِيل ؤُمِي غَا ثْزدْجْعذْ أَسْعَارْ نّشْ خْ ؤُرْشَالِيمْ؟“
\v 9 \add خنِّي\add* إِنَّا أَيِي: ”ڒْمُوعْصِييّثْ ن ثَادَّارْثْ ن إِسْرَائِيل ذ يَاهُوذَا ثمْغَارْ أَطَّاسْ ؤُ ثَامُّورْثْ ثشُّورْ س إِذَامّنْ ؤُ ثنْذِينْثْ ثشُّورْ س ؤُسْفَارْغْ ن ڒْحقّْ، مِينْزِي نِيثْنِي قَّارنْ: ’سِيذِي إِسْمحْ ذِي ثمُّورْثْ ؤُشَا سِيذِي وَارْ إِژَارّْ!‘
\v 10 \add س ؤُيَا\add* ؤُڒَا ذ نشّْ أَذْ ڭّغْ أَمُّو. ثِيطّْ إِنُو وَارْ ثْسمّحْ ؤُ نشّْ وَارْ تّْحِينِّيغْ. نشّْ أَذْ سّنْقڒْبغْ أَبْرِيذْ نْسنْ خْ ؤُزدْجِيفْ نْسنْ.“ \x ◘ \xo 9:‏10 \xt حِز. 5‏:‏11؛ 7‏:‏4؛ 8‏:‏18\x*
\m 
\v 11 ؤُشَا خْزَارْ، أَرْيَازْ نِّي يَارْضنْ ڒقْطنْ، ونِّي د-يِيوْينْ غَارْ وبْيَاسْ نّسْ ثَاذْوَاثْ \add ن ؤُمَارِيرْ\add*، أَقَا يَارَّا-د ڒخْبَارْ، إِنَّا: ”ڭِّيغْ أَمْ مَامّشْ إِ ذ أَيِي ثُومُورذْ.“
\b
\b
\c 10
\m 
\v 1 \add أَوَارْنِي أَيَا\add* ژْرِيغْ، خْزَارْ، سنّجْ إِ ڒْقُوبّثْ، سنّجْ إِ ؤُزدْجِيفْ ن إِكِيرُوبنْ، \add ثُوغَا ذِينْ شَا\add* أَمْ وژْرُو ن صَافِّيرْ، مِينْ د-إِتّْبَاننْ أَمْ وُوذمْ ن مِينْ يَارْوسنْ ذڭْ إِجّْ ن ڒْعَارْشْ، \add ؤُ\add* سنّجْ إِ نِيثْنِي إِضْهَارْ-د نتَّا.
\v 2 ؤُشَا إِسِّيوڒْ أَكْ-ذ ورْيَازْ نِّي يَارْضنْ أَرُّوذْ نْ ڒقْطنْ، إِنَّا: ”أَذفْ-د غَارْ ذَاخڒْ جَارْ ثْجَارَّارِينْ إِتّنّْضنْ، أَڒْ سَاذُو إِ إِكِيرُوبنْ، ؤُشَا شُّورْ إِفَاسّنْ نّشْ س ڒفْحمْ إِتّحْذُوذُوقنْ زِي جَارْ إِكِيرُوبنْ ؤُشَا زدْجعْ إِ-ث خْ ثنْذِينْثْ!“ ؤُشَا يُوذفْ-د \add جَارْ أَسنْثْ\add* زَّاثْ إِ ثِيطَّاوِينْ إِنُو. \f ◼ \fr 10:‏2 \ft \bd ’إِكِيرُوبنْ‘\bd* - إِشْثْ ن مَارْكَا ن لْمَالَاكَاثْ إِنِّي غَارْسنْ صُولْطَا ثَامقّْرَانْثْ.\f*  \x ◘ \xo 10:‏2 \xt حِز. 1‏:‏13\x*
\m 
\v 3 إِكِيرُوبنْ ثُوغَا بدّنْ غَارْ ؤُغزْذِيسْ أَفُوسِي ن ثَادَّارْثْ ؤُمِي د-يَاذفْ ورْيَازْ غَارْ ذَاخڒْ ؤُشَا أَسيْنُو إِشُّورْ ڒمْرَاحْ ن ذَاخڒْ.
\v 4 أَعُودْجِي ن سِيذِي إِسّْڭعّذْ إِخفْ نّسْ زِي سنّجْ ن ؤُخِيرُوبْ، \add إِعْذُو\add* خْ ثْنبْذَاثْ ن ثوَّارْثْ ن ثَادَّارْثْ ؤُشَا ثتّْوَاشُّورْ ثَادَّارْثْ س ؤُسيْنُو ؤُ ڒمْرَاحْ ن زَّاثْ ثُوغَا إِشُّورْ س ثسِّيقْثْ ن ؤُعُودْجِي ن سِيذِي.
\v 5 ذْرِيزّْ ن وَافْرِيونْ إِتّْوَاسڒْ-د أَڒْ ذَاخڒْ ذِي ڒمْرَاحْ ن بَارَّا، أَمْ ثْمِيجَّا ن أَربِّي، أَمْزمَّارْ خْ كُوڒْشِي، خْمِي إِسَّاوَاڒْ.
\m 
\v 6 إِمْسَارْ أَوَارْنِي ڒَامِي يُومُورْ نتَّا إِ ورْيَازْ نِّي يَارْضنْ ڒقْطنْ، إِنَّا: ”كْسِي ثِيمسِّي زِي جَارْ ثْجَارَّارِينْ إِتّنْضنْ، زِي جَارْ إِكِيرُوبنْ!“، أَقَا وَانِيثَا يُوذفْ-د ؤُشَا إِبدّْ زَّاثْ إِ ثْجَارَّارْثْ إِتّنْضنْ.
\v 7 \add خنِّي\add* إِسّْوِيژّضْ إِجّْ ن ؤُكِيرُوبْ أَفُوسْ نّسْ زِي جَارْ إِكِيرُوبنْ غَارْ ثْمسِّي نِّي ثُوغَا جَارْ أَسنْ، إِكْسِي زَّايسْ ؤُشَا إِسَّارْسْ إِ-ت ذڭْ إِفَاسّنْ ن ونِّي يَارْضنْ ڒقْطنْ. وَانِيثَا إِكْسِي ت ؤُشَا إِفّغْ.
\v 8 سَاذُو وَافْرِيونْ ن إِكِيرُوبنْ إِتّْوَاژَارْ شَا أَمْ صِّيفثْ ن ؤُفُوسْ ن بْنَاذمْ.
\m 
\v 9 \add خنِّي\add* ژْرِيغْ، خْزَارْ، أَقَا ذِينْ أَربْعَا ن ثْجَارَّارِينْ غَارْ ؤُغزْذِيسْ ن إِكِيرُوبنْ، إِشْثْ ن ثْجَارَّارْثْ غَارْ ؤُغزْذِيسْ ن إِجّْ ن ؤُكِيرُوبْ. ؤُذمْ ن ثْجَارَّارِينْ أَمْ وُوذمْ ن وژْرُو ن ثخْرِيسُولِيثْ. \x ◘ \xo 10:‏9 \xt حِز. 1‏:‏16\x*
\v 10 خْ مَامّشْ د-ضْهَارنْ، أَقَا أَربْعَا غَارْسنْ صِّيفثْ ذ إِشْثنْ، أَخْمِي إِشْثْ ن ثْجَارَّارْثْ \add ثتّْڒِيقْ نِيشَانْ\add* ذِي ڒْوسْطْ ن ثْجَارَّارْثْ \add نّغْنِي\add*.
\v 11 خْمِي ڭُّورنْ، ڭُّورنْ غَارْ أَربْعَا ن إِغزْذِيسنْ \add نْسنْ\add*. نِيثْنِي وَارْ تّْنقْڒِيبنْ شَا خْمِي ڭُّورنْ، مِينْزِي أَمْشَانْ مَانِي ثَارَّا \add ثْجَارَّارْثْ\add* ن زَّاثْ أَزدْجِيفْ نّسْ، أَقَا ضْفَارنْ ت-إِ-د. نِيثْنِي وَارْ نّْقڒْبنْ شَا خْمِي ڭُّورنْ.
\v 12 مَارَّا أَرِّيمثْ نْسنْ: إِعُورَارْ نْسنْ، إِفَاسّنْ نْسنْ ذ وَافْرِيونْ نْسنْ، ؤُشَا ؤُڒَا ذ ثِيجَارَّارِينْ نْسنْ شُّورنْ س ثِيطَّاوِينْ ذڭْ ونّضْ نْسنْ غَارْ \add مَارَّا\add* أَربْعَا \add إِمُودَّارنْ\add* نِّي، \add وَاهْ عَاذْ\add* ثِيجَارَّارِينْ نْسنْ.
\v 13 سْڒِيغْ \add إِشْثْ ن ثْمِيجَّا\add* أَقَا ثتّْڒَاغَا أَسنْثْ إِ ثْجَارَّارِينْ: ’ثَاجَارَّارْثْ ن دّوْرَانْ!‘
\v 14 كُوڒْ إِجّْ غَارسْ أَربْعَا ن وُوذْمَاونْ: ؤُذمْ أَمزْوَارُو \add ثُوغَا\add* ذ ؤُذمْ ن ؤُكِيرُوبْ، ؤُ ؤُذمْ وِيسّْ ثْنَاينْ ذ ؤُذمْ ن بْنَاذمْ، ؤُ \add ؤُذمْ\add* وِيسّْ ثْڒَاثَا ذ ؤُذمْ ن ويْرَاذْ، ؤُ \add ؤُذمْ\add* وِيسّْ أَربْعَا ذ ؤُذمْ ن ؤُڭِيذرْ.
\m 
\v 15 سّْڭعّْذنْ إِكِيرُوبنْ إِخفْ نْسنْ. وَا ذ سِيمَانْثْ ن ؤُمُودَّارْ إِ ژْرِيغْ غَارْ يغْزَارْ ن خابُورْ.
\v 16 ؤُمِي ؤُيُورنْ إِكِيرُوبنْ، ؤُيُورنْثْ ؤُڒَا ذ ثِيجَارَّارِينْ غَارْ ؤُغزْذِيسْ نْسنْ، ؤُمِي سّْڭعّْذنْ إِكِيرُوبنْ أَفْرِيونْ نْسنْ مَاحنْذْ أَذْ سّْڭعّْذنْ إِخفْ نْسنْ زِي ثمُّورْثْ، وَارْ قْنُونّْينْثْ ثْجَارَّارِينْ نِّي أَڒَامِي أَڭّْوجنْثْ خْ ؤُغزْذِيسْ نْسنْ. \x ◘ \xo 10:‏16 \xt حِز. 1‏:‏19\x*
\v 17 ؤُمِي بدّنْ نِيثْنِي، بدّنْثْ ؤُڒَا ذ نِيثنْثِي، ؤُمِي سّْڭعّْذنْ نِيثْنِي إِخفْ نْسنْ، سّْڭعّْذنْثْ ؤُڒَا ذ نِيثنْثِي إِخفْ نْسنْثْ، مِينْزِي بُوحْبڒْ ن إِمُودَّارنْ \add ثُوغَا-ث\add* ذَايْسنْثْ. \x ◘ \xo 10:‏17 \xt حِز. 1‏:‏20\x*
\m 
\v 18 \add خنِّي\add* إِفّغْ ؤُعُودْجِي ن سِيذِي زِي سنّجْ ن ثْنبْذَاثْ ن ثَادَّارْثْ ؤُشَا إِبدّْ سنّجْ إِ إِكِيرُوبنْ.
\v 19 إِكِيرُوبنْ سّْڭعّْذنْ أَفْرِيونْ نْسنْ ؤُشَا، ؤُمِي د-فّْغنْ، سّْڭعّْذنْ إِخفْ نْسنْ زِي ثمُّورْثْ زَّاثْ إِ ثِيطَّاوِينْ إِنُو ؤُشَا ؤُڒَا ذ ثِيجَارَّارِينْ غَارْ ؤُغزْذِيسْ نْسنْ. نِيثْنِي قِّيمنْ بدّنْ غَارْ وَاذَافْ ن ثوَّارْثْ ن شَّارْقْ ن ثَادَّارْثْ ن سِيذِي ؤُشَا أَعُودْجِي ن أَربِّي \add ثُوغَا-ث\add* خَاسنْ زِي سنّجْ.
\v 20 وَا ذ أَمُودَّارْ إِ ژْرِيغْ سَاذُو أَربِّي ن إِسْرَائِيل غَارْ يغْزَارْ ن خابُورْ. \add خنِّي\add* سّْنغْ بلِّي ثُوغَا أَثنْ ذ إِكِيرُوبنْ. \x ◘ \xo 10:‏20 \xt حِز. 1‏:‏3\x*
\v 21 كُوڒْ إِجّْ غَارسْ أَربْعَا ن وُوذْمَاونْ ؤُ كُوڒْ إِجّْ غَارسْ أَربْعَا ن وَافْرِيونْ ؤُ سَاذُو أَفْرِيونْ نْسنْ أَقَا ذِينْ مِينْ يَارْوسنْ ذڭْ إِفَاسّنْ ن إِوْذَانْ. \x ◘ \xo 10:‏21 \xt حِز. 1‏:‏6، 8؛ 10‏:‏8، 14\x*
\v 22 ؤُذْمَاونْ نْسنْ أَمْ وُوذْمَاونْ نِّي ژْرِيغْ غَارْ يغْزَارْ ن خابُورْ، مَامّشْ د-بَاننْ \add وُوذْمَاونْ نِّي\add*، ؤُڒَا ذ نِيثْنِي س يِيخفْ نْسنْ. نِيثْنِي ڭُّورنْ كُوڒْ إِجّْ نِيشَانْ غَارْ زَّاثْ نّسْ.
\b
\b
\c 11
\s1 ڒْحُوكْمْ خْ ڒْحُوكَّامْ
\m 
\v 1 \add خنِّي\add* إِسّْڭعّذْ أَيِي أَرُّوحْ \add عَاوذْ\add* ؤُشَا إِنْذهْ أَيِي غَارْ ثوَّارْثْ ن شَّارْقْ ن ثَادَّارْثْ ن سِيذِي نِّي إِدْجَانْ غَارْ شَّارْقْ، ؤُ خْزَارْ، غَارْ وَاذَافْ ن ثوَّارْثْ \add أَقَا ذِينْ\add* خمْسَا ؤُ-عِيشْرِينْ ن يرْيَازنْ ؤُ ذِي ڒْوسْطْ نْسنْ ژْرِيغْ يَازَانْيَا\add هُو\add*، مِّيسْ ن عَازُورْ، ؤُ فَالَاطْيَا، مِّيسْ ن بَانَايَا، ڒْحُوكَّامْ ن ڒْڭنْسْ.
\v 2 نتَّا إِنَّا أَيِي: ”\add أَ\add* مِّيسْ ن بْنَاذمْ، إِنَا ذ إِرْيَازنْ نِّي إِتّْخَارِّيصنْ ذِي دّدْجْ، تِّيشنْ شّْوَارْ أَعفَّانْ ذِي ثنْذِينْثْ-أَ،
\v 3 قَّارنْ: ’وَارْ بنَّامْ عَاذْ ثُوذْرِينْ ذڭْ وُوسَّانْ-أَ! ثَانِيثَا ذ مَارْمِيثَا ؤُشَا نشِّينْ ذ أَيْسُومْ!‘ “\f ◼ \fr 11:‏3 \ft \bd ’ثَانِيثَا‘\bd* - إِخْسْ أَذْ يِينِي ’ثَانْذِينْثْ-أَ‘.\f*
\m 
\v 4 ”س ؤُيَا نَابّْ خَاسنْ، نَابّْ، \add شكْ\add*، \add أَ\add* مِّيسْ ن بْنَاذمْ!“
\v 5 \add خنِّي\add* إِوْضَا-د أَرُّوحْ ن سِيذِي خَافِي ؤُشَا نتَّا إِنَّا أَيِي: ”إِنِي: ’أَمُّو إِ إِقَّارْ سِيذِي! أَمُّو إِ ثسِّيوْڒمْ كنِّيوْ، \add أَ\add* ثَادَّارْثْ ن إِسْرَائِيل، مَاغَارْ نشّْ سّْنغْ ڒحْوَايجْ نِّي إِتّْڭعَّاذنْ غَارْ بُوحْبڒْ نْومْ.
\v 6 ثَارْنِيمْ \add ڒْْخشْبَاثْ ن\add* يِينِّي إِتّْوَانْغنْ نْومْ ذِي ثنْذِينْثْ-أَ ؤُشَا ثشُّورمْ إِبْرِيذنْ نّسْ س \add ڒْْخشْبَاثْ ن\add* يِينِّي إِتّْوَانْغنْ!‘ “
\m 
\v 7 ”س ؤُيَا، أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ’إِنِّي زَّايْومْ إِتّْوَانْغنْ، إِنِّي ثسَّارْسمْ ذِي ڒْوسْطْ نّسْ، أَقَا أَثنْ ذ أَيْسُومْ ؤُ نتَّاثْ ذ مَارْمِيثَا، \add مَاشَا\add* نشّْ أَذْ كنِّيوْ سُّوفّْغغْ زِي ڒْوسْطْ نّسْ. \f ◼ \fr 11:‏7 \ft \bd ’ذَايسْ‘\bd* - س ثْعِيبْرَانِيثْ ’ذِي ڒْوسْثْ نّسْ‘.\f*
\v 8 سِّيفْ ثتّڭّْوْذمْ، ذ سِّيفْ أَذْ خَاومْ د-سّكّغْ، إِقَّارْ سِيذِي إِنُو، سِيذِي.
\v 9 نشّْ أَذْ كنِّيوْ نذْهغْ زِي ڒْوسْثْ نّسْ ؤُشَا أَذْ وْشغْ كنِّيوْ ذڭْ ؤُفُوسْ ن إِبَارَّانِييّنْ ؤُشَا أَذْ ڭّغْ ڒحْكَامَاثْ جَارْ أَومْ.
\v 10 س سِّيفْ أَذْ ثوْضَامْ. ذِي ثمُّورْثْ ن إِسْرَائِيل أَذْ خَاومْ حكْمغْ ؤُشَا أَذْ ثسّْنمْ بلِّي نشّْ ذ سِيذِي.
\v 11 ثَانْذِينْثْ-أَ وَارْ ذ أَومْ ثتِّيڒِي ذ مَارْمِيثَا ؤُ كنِّيوْ وَارْ ذَايسْ ثتِّيڒِيمْ ذ أَيْسُومْ. نشّْ أَذْ خَاومْ حكْمغْ ذِي ثمُّورْثْ ن إِسْرَائِيل.
\v 12 كنِّيوْ أَذْ ثسّْنمْ بلِّي نشّْ ذ سِيذِي، مِينْزِي وَارْ ثُويُورمْ ذِي ثْوصَّا إِنُو ؤُ وَارْ ثڭِّيمْ عْلَاحْسَابْ لْفَارَايِيضْ إِنُو، \add مَاشَا\add* ثڭِّيمْ أَمْ مَامّشْ لْفَارَايِيضْ نْ ڒڭْنُوسْ إِ ذ أَومْ د-إِتّنّْضنْ.‘ “
\m 
\v 13 ڒَامِي ثُوغَا تّْنَابِّيغْ، إِمْسَارْ أَقَا فَالَاطْيَا، مِّيسْ ن بَانَايَا، إِمُّوثْ. \add خنِّي\add* وْضِيغْ غَارْ ثمُّورْثْ س ؤُغمْبُوبْ إِنُو ؤُشَا ڒَاغِيغْ س ثْمِيجَّا إِجهْذنْ، نِّيغْ: ”أَ، سِيذِي إِنُو، سِيذِي، مَا أَذْ ثقْضِيذْ مِينْ إِقِّيمنْ زِي إِسْرَائِيل؟“
\m 
\v 14 \add خنِّي\add* يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا:
\v 15 ”\add أَ\add* مِّيسْ ن بْنَاذمْ، أَقَا ذ أَيْثْمَاشْ، أَيْثْمَاشْ، إِرْيَازنْ نِّي \add إِدْجَانْ\add* ذ إِمفْذِييّنْ نْومْ ذ مَارَّا ثَادَّارْثْ ن إِسْرَائِيل، أَقَا-ثنْ مَارَّا ذ إِنِّي إِ ذ أَسنْ نَّانْ إِمزْذَاغْ ن ؤُرْشَالِيمْ: ’أَڭّْوجمْ خْ سِيذِي، ثَامُّورْثْ-أَ ثمّوْشْ أَنغْ ذ ثَاسْغَارْثْ!‘ “
\v 16 ”س ؤُيَا إِنِي: ’أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: وَاخَّا نشّْ سِّيڭّْوجغْ ثنْ جَارْ ڒڭْنُوسْ، وَاخَّا نشّْ بزّْعغْ ثنْ خْ ثمُّورَا، س مَارَّا أَيَا أَذْ أَسنْ إِڒِيغْ \add عَاذْ\add* شْوَايْثْ ذ زَّاوشْثْ إِقدّْسنْ ذِي ثمُّورَا مَانِي غَا يَاوْضنْ.‘ “
\v 17 ”س ؤُيَا إِنِي: ’أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: نشّْ ڭُّورْ أَذْ كنِّيوْ سّْمُونغْ زِي ڒڭْنُوسْ، أَذْ كنِّيوْ سّْمُونغْ زِي ثمُّورَا مَانِي غَا ثتّْوَابزّْعمْ ؤُ نشّْ أَذْ أَومْ وْشغْ ثَامُّورْثْ ن إِسْرَائِيل.
\v 18 نِيثْنِي أَذْ ذِينْ أَوْضنْ ؤُ أَذْ زَّايسْ كّْسنْ مَارَّا نّْعَاوَاثْ نّسْ ن لْ-أَصْنَامْ ذ مَارَّا جّْعَايفْ نّسْ.
\v 19 نشّْ أَذْ أَسنْ وْشغْ إِجّْ ن وُوڒْ ذ إِجّْ ن بُوحْبڒْ ن جْذِيذْ ذِي ذَاخڒْ نْومْ. أَذْ كّْسغْ ؤُڒْ ن وژْرُو زِي أَرِّيمثْ نْسنْ ؤُ أَذْ أَسنْ وْشغْ ؤُڒْ ن ويْسُومْ، \x ◘ \xo 11:‏19 \xt إِرْم. 32‏:‏39؛ حِز. 36‏:‏26\x*
\v 20 حِيمَا أَذْ ؤُيُورنْ ذِي ثْوصَّا إِنُو ؤُ أَذْ حْضَانْ لْفَارَايِيضْ إِنُو ؤُ أَذْ \add زَّايْسنْثْ\add* ڭّنْ. أَذْ إِڒِينْ ذ ڒْڭنْسْ إِنُو ؤُ نشّْ أَذْ إِڒِيغْ ذ أَربِّي نْسنْ. \x ◘ \xo 11:‏20 \xt إِرْم. 24‏:‏7؛ 30‏:‏22؛ 31‏:‏1؛ 32‏:‏38\x*
\v 21 \add مَاشَا\add* \add إِنِّي\add* ؤُڒْ \add نْسنْ\add* أَذْ إِضْفَارْ ؤُڒْ نْ نّْعَاوَاثْ نْسنْ ن لْ-أَصْنَامْ ذ جّْعَايفْ نْسنْ، نشّْ أَذْ ڭّغْ إِبْرِيذنْ نْسنْ خْ ؤُزدْجِيفْ نْسنْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي.‘ “ \x ◘ \xo 11:‏21 \xt حِز. 9‏:‏10\x*
\m 
\v 22 \add خنِّي\add* سّْڭعّْذنْ إِكِيرُوبنْ أَفْرِيونْ نْسنْ ؤُ ثِيجَارَّارِينْ \add ثُوغَا\add* زَّاثْسنْ ؤُشَا أَعُودْجِي ن أَربِّي ن إِسْرَائِيل \add ثُوغَا-ث\add* خَاسنْ سنّجْ نْسنْ. \f ◼ \fr 11:‏22 \ft \bd ’إِكِيرُوبنْ‘\bd* - إِشْثْ ن مَارْكَا ن لْمَالَاكَاثْ.\f*
\v 23 \add خَاسْ ؤُشَا\add* إِڭعّذْ ؤُعُودْجِي ن سِيذِي زِي ڒْوسْطْ ن ثنْذِينْثْ ؤُشَا \add إِقِّيمْ\add* إِتّْبدَّا خْ وذْرَارْ نِّي \add إِدْجَانْ\add* غَارْ شَّارْقْ ن ثنْذِينْثْ.
\v 24 \add خنِّي\add* إِسّْڭعّذْ أَيِي-د أَرُّوحْ ؤُشَا يِيوِي أَيِي ذڭْ إِجّْ ن ڒوْحِييْ س أَرُّوحْ ن أَربِّي غَارْ \add ثمُّورْثْ\add* ن إِكَالْذَانِييّنْ غَارْ أَيْثْ ن لْمنْفَا. \add أَوَارْنِي مَانْ أَيَا\add* إِڭعّذْ زَّايِي ڒوْحِييْ إِ ژْرِيغْ،
\v 25 ؤُ نِّيغْ إِ أَيْثْ ن لْمنْفَا مَارَّا مِينْ ثُوغَا ذ أَيِي إِسّْشنْ سِيذِي.
\b
\b
\c 12
\s1 أَرْشَامْ ن ثْمحْبَاسْثْ
\m 
\v 1 يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا:
\v 2 ”\add أَ\add* مِّيسْ ن بْنَاذمْ، شكْ ثْزدّْغذْ ذڭْ إِشْثْ ن ثَادَّارْثْ إِغوّْغنْ، مَاغَارْ نِيثْنِي غَارْسنْ ثِيطَّاوِينْ مَاحنْذْ أَذْ تّْوَاڒَانْ، \add مَاشَا\add* وَارْ تّْوِيڒِينْ، ؤُڒَا ذ إِمجَّاننْ مَاحنْذْ أَذْ سْڒنْ، \add مَاشَا\add* وَارْ تّسْڒِينْ، مِينْزِي نِيثْنِي ذ إِشْثْ ن ثَادَّارْثْ إِغوّْغنْ. \x ◘ \xo 12:‏2 \xt إِشا. 6‏:‏9، 10؛ إِرْم. 5‏:‏21؛ حِز. 2‏:‏3‏-‏8؛ 3‏:‏26، 27\x*
\v 3 شكْ، \add أَ\add* مِّيسْ ن بْنَاذمْ، سوْجذْ ڒحْوَايجْ إِ لْمنْفَا ؤُشَا ؤُيُورْ ذِي لْمنْفَا زَّاثْ إِ ثِيطَّاوِينْ نْسنْ. أَذْ ثُويُورذْ ذِي لْمنْفَا زَّاثْ إِ ثِيطَّاوِينْ نْسنْ زڭْ ومْشَانْ نّشْ غَارْ إِجّْ ن ومْشَانْ نّغْنِي. أَذْ ثَاغْ أَذْ نعْمنْ أَقَا أَثنْ ذ إِشْثْ ن ثَادَّارْثْ إِغوّْغنْ.
\v 4 أَذْ ثسُّوفّْغذْ ڒحْوَايشْ نّشْ ذڭْ ؤُزِيڒْ زَّاثْ إِ ثِيطَّاوِينْ نْسنْ أَمْ ڒحْوَايشْ إِ لْمنْفَا، أَذْ ثفّْغذْ ذِي ثْمذِّيثْ زَّاثْ إِ ثِيطَّاوِينْ نْسنْ، أَمشْنَاوْ \add إِوْذَانْ\add* إِنِّي إِڭُّورنْ ذِي لْمنْفَا.
\v 5 أڭّْ أَنُوقِّيبْ ذِي ڒْحِيضْ زَّاثْ إِ ثِيطَّاوِينْ نْسنْ ؤُشَا سُوفّغْ \add مَارَّا أَيَا\add* زَّايسْ.
\v 6 زَّاثْ إِ ثِيطَّاوِينْ نْسنْ أَذْ ثَاوْيذْ \add أَيَا\add* خْ ثْغَارْضِينْ نّشْ، ذِي ثْبَامْبَاسْثْ أَذْ ثسُّوفّْغذْ \add أَيَا\add*. أَذْ ثفَّارذْ ؤُذمْ نّشْ، \add أَڒَامِي\add* وَارْ ثْژَارّذْ ثَامُّورْثْ، مِينْزِي ڭِّيغْ شكْ ذ ڒعْڒَامثْ ن ڒعْجبْ إِ ثَادَّارْثْ ن إِسْرَائِيل.“
\v 7 نشّْ ڭِّيغْ أَمْ مَامّشْ إِ ذ أَيِي إِوصَّا. س ؤُزِيڒْ سُّوفّْغغْ ڒحْوَايشْ إِنُو أَمْ ڒحْوَايشْ إِ لْمنْفَا. غَارْ ثْمذِّيثْ غْزِيغْ س ؤُفُوسْ إِنُو خْ ڒْحِيضْ ؤُ ذِي دْجِيڒثْ سُّوفّْغغْ \add مَارَّا\add* غَارْ بَارَّا ؤُشَا إِوْيغْ ث خْ ثْغَارْضِينْ \add إِنُو\add* زَّاثْ إِ ثِيطَّاوِينْ نْسنْ.
\m 
\v 8 يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي خْ ثُوفُّوثْ، إِنَّا:
\v 9 ”\add أَ\add* مِّيسْ ن بْنَاذمْ، مَا وَارْ ذ أَشْ ثنَّا ثَادَّارْثْ ن إِسْرَائِيل، ثَادَّارْثْ إِغوّْغنْ \add نِّي\add*: ’مِينْ ثتّڭّذْ؟‘
\v 10 إِنِي أَسنْ: ’أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي! ڒْحُوكْمْ إِسَّاڭّْوَاذنْ وَانِيثَا \add أَذْ يِيڒِي خْ\add* ڒْحَاكمْ ذِي ؤُرْشَالِيمْ ؤُ خْ مَارَّا ثَادَّارْثْ ن إِسْرَائِيل، إِنِّي إِزدّْغنْ جَارْ أَسنْ.‘
\v 11 إِنِي: ’نشّْ ذ ڒعْڒَامثْ ن ڒعْجبْ إِ كنِّيوْ. أَمْ مَامّشْ ڭِّيغْ نشّْ، أَمُّو إِ غَا ڭّنْ ذَايْسنْ، أَذْ تّْوَانذْهنْ ذِي لْمنْفَا، ذِي ثْمحْبَاسْثْ.
\v 12 ڒْحَاكمْ نِّي \add إِدْجَانْ\add* ذِي ڒْوسْطْ نْسنْ، أَذْ يَارْبُو \add ڒحْوَايشْ\add* خْ ثغْرُوضْثْ نّسْ ذِي دْجِيڒثْ ؤُشَا أَذْ إِفّغْ. نِيثْنِي أَذْ غْزَانْ خْ ڒْحِيضْ مَاحنْذْ أَذْ زَّايسْ ث سُّوفّْغنْ. نتَّا أَذْ إِذڒْ أَغمْبُوبْ نّسْ أَڒَامِي غَا إِقِّيمْ وَارْ إِزمَّارْ أَذْ إِژَارْ \add عَاذْ\add* ثَامُّورْثْ س ثِيطّْ\add أَوِينْ\add* \add نّسْ\add*. \x ◘ \xo 12:‏12 \xt 2 إِج. 25‏:‏4\x*
\v 13 نشّْ أَذْ خَاسنْ بزّْعغْ ثْرَاشَّا إِنُو أَڒَامِي غَا إِذْوڒْ ذ أَمحْبُوسْ ذِي ڒْفخْ إِنُو ؤُشَا أَذْ ث أَوْيغْ غَارْ بَابِيلْ، \add غَارْ\add* ثمُّورْثْ ن إِكَالْذَانِييّنْ. نتَّا \add مَاشَا\add* وَارْ ت إِژَارّْ، \add مَاشَا وَاخَّا أَمنِّي\add* أَذْ ذِينْ إِمّثْ. \x ◘ \xo 12:‏13 \xt حِز. 17‏:‏20\x*
\v 14 مَارَّا إِنِّي ذ أَسْ د-إِنّْضنْ مَاحنْذْ أَذْ ث عَاوْننْ ذ مَارَّا بَانْذِييَّاثْ ن ڒْعسْكَارْ نّسْ، أَذْ ثنْ بزّْعغْ إِ مَارَّا ثِيغمُّورَا ن ؤُسمِّيضْ ؤُشَا أَذْ جبْذغْ سِّيفْ أَوَارْنِي أَسنْ. \x ◘ \xo 12:‏14 \xt حِز. 5‏:‏10، 12\x*
\v 15 \add أَمُّو إِ\add* غَا سّْننْ بلِّي نشّْ ذ سِيذِي، خْمِي ثنْ غَا بزّْعغْ جَارْ ڒڭْنُوسْ ؤُشَا أَذْ ثنْ زُوزَّارغْ ذِي ثمُّورَا.
\v 16 مَاشَا أَذْ زَّايْسنْ جّغْ شَا ن يرْيَازنْ \add إِنِّي إِنجْمنْ\add* زِي سِّيفْ، زِي ڒَاژْ ؤُ زِي طَّاعُونْ، حِيمَا أَذْ عَاوْذنْ إِ ڒڭْنُوسْ مَانِي غَا يَاوْضنْ، خْ مَارَّا جّْعَايفْ نْسنْ نِّي ڭِّينْ. \add خنِّي\add* أَذْ سّْننْ بلِّي نشّْ ذ سِيذِي.‘ “
\m 
\v 17 يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا:
\v 18 ”\add أَ\add* مِّيسْ ن بْنَاذمْ، أَذْ ثشّذْ أَغْرُومْ نّشْ س ثَارْجِيجِي ؤُشَا أَذْ ثسْوذْ أَمَانْ نّشْ س وَارْجفْ ذ وشْضَانْ.
\v 19 أَذْ ثِينِيذْ إِ ڒْڭنْسْ ن ثمُّورْثْ: ’أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي، خْ إِمزْذَاغْ ن ؤُرْشَالِيمْ \add إِ يدْجَانْ\add* خْ وُوذمْ ن ثمُّورْثْ ن إِسْرَائِيل: نِيثْنِي أَذْ شّنْ أَغْرُومْ نْسنْ س وشْضَانْ ؤُ أَذْ سْونْ أَمَانْ نْسنْ س وجْعَارْ، مِينْزِي مَارَّا أَعمَّارْ نّسْ أَذْ إِتّْوَاكّسْ زِي ثمُّورْثْ زِي سِّيبّثْ ن لْعُونْفْ ن مَارَّا إِنِّي ذَايسْ إِزدّْغنْ. \x ◘ \xo 12:‏19 \xt حِز. 4‏:‏16\x*
\v 20 ثِيندَّامْ إِزدّْغنْ أَذْ ذوْڒنْثْ ذ ڒْخِيرْبثْ ؤُشَا ثَامُّورْثْ أَذْ ثتّْوَاردّدْجْ. أَذْ ثسّْنمْ بلِّي نشّْ ذ سِيذِي.‘ “
\b
\s1 ڒْحُوكْمْ أَقَا إِقَارّبْ-د
\m 
\v 21 يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا:
\v 22 ”\add أَ\add* مِّيسْ ن بْنَاذمْ، مَانْ أَمذْيَا نِّي غَارْومْ ذِينْ ذِي ثمُّورْثْ ن إِسْرَائِيل، ؤُمِي ثقَّارمْ: ”عدُّونْ وُوسَّانْ ؤُشَا وَارْ د-إِفِّيغْ ؤُرَا ذ إِجّْ ن ڒوْحِييْ‘؟“
\m 
\v 23 ”س ؤُيَا إِنِي أَسنْ: ’أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: نشّْ أَذْ سّْبدّغْ أَمذْيَا-يَا، أَڒَامِي غَا قِّيمنْ وَارْ قَّارنْ عَاذْ مَانْ أَيَا أَمْ ؤُمذْيَا ذِي إِسْرَائِيل.‘ “
\m ”س ؤُيَا سِيوڒْ أَكِيذْسنْ \add أَمُّو\add*: ’أَقَا إِوْضنْ-د ؤُسَّانْ \add نِّي\add*، ؤُشَا ؤُڒَا ذ أَسقْفڒْ ن كُوڒْ ڒوْحِييْ!‘
\v 24 مِينْزِي وَارْ إِتِّيڒِي عَاذْ ڒوْحِييْ وَارْ إِدْجِينْ ؤُڒَا ذ ثَاڭزَّانْثْ س وَاوَاڒنْ إِمِيزِيضنْ ذِي ثَادَّارْثْ ن إِسْرَائِيل.
\v 25 مِينْزِي نشّْ، سِيذِي، أَذْ سِّيوْڒغْ. أَوَاڒْ إِ غَا سِّيوْڒغْ، أَذْ يِيڒِي، وَارْ إِتّْعطَّاڒْ عَاذْ، مِينْزِي ذڭْ وُوسَّانْ نْومْ، \add أَ\add* ثَادَّارْثْ إِغوّْغنْ، أَذْ سِّيوْڒغْ إِجّْ ن وَاوَاڒْ ؤُشَا أَذْ ث ڭّغْ، إِقَّارْ سِيذِي إِنُو، سِيذِي.“
\m 
\v 26 يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا:
\v 27 ”\add أَ\add* مِّيسْ ن بْنَاذمْ، خْزَارْ، إِنِّي ن ثَادَّارْثْ ن إِسْرَائِيل، إِنِّي إِقَّارنْ: ’ڒوْحِييْ نِّي إِتّْوَاڒَا أَقَا-ث إِ \add يِيجّْ ن ڒْوقْثْ أَوَارْنِي\add* إِ وَاطَّاسْ ن وُوسَّانْ، إِتّْنَابَّا خْ \add وُوسَّانْ ن\add* زّْمَانَاثْ إِڭّْوجنْ أَطَّاسْ.‘ “
\v 28 ”س ؤُيَا إِنِي أَسنْ: ’أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: وَارْ إِتّْعطَّاڒْ عَاذْ ؤُڒَا ذ إِجّْ زڭْ وَاوَاڒنْ إِنُو. أَوَاڒْ إِ نِّيغْ، أَذْ يِيڒِي، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي.‘ “
\b
\b
\c 13
\s1 أَوَاڒْ ضِيدّْ إِ إِنَابِييّنْ إِسّْخَارِّيقنْ
\m 
\v 1 يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا:
\v 2 ”\add أَ\add* مِّيسْ ن بْنَاذمْ، نَابّْ ضِيدّْ إِ إِنَابِييّنْ ن إِسْرَائِيل إِنِّي إِتّْنبَّانْ، ؤُشَا إِنِي إِ يِينِّي إِتّْنبَّانْ غَارْ \add مژْرِي\add* ن وُوڒْ نْسنْ: ’سْرمْ إِ وَاوَاڒْ ن سِيذِي!
\v 3 أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ؤُشْثْ خْ إِنَابِييّنْ إِبُوحَاڒِييّنْ نِّي إِڭُّورنْ أَوَارْنِي إِ بُوحْبڒْ نْ يِيخفْ نْسنْ ؤُ أَوَارْنِي مِينْ وَارْ ژْرِينْ!
\v 4 \add أَ\add* إِسْرَائِيل، إِنَابِييّنْ نْومْ ذوْڒنْ أَمْ يِيشعْبَاونْ جَارْ ڒْخِيرْبَاثْ.
\v 5 وَارْ ثُوڒْيمْ غَارْ ثِيزّيِّينْ \add ذِي ڒحْيُوضْ ن ثنْذِينْثْ\add* نِيغْ ثبْنَامْ ڒْحِيضْ إِ ثَادَّارْثْ ن إِسْرَائِيل، حِيمَا أَذْ ثقِّيممْ ثتّْبدَّامْ ذڭْ ؤُمنْغِي ذڭْ وَاسّْ ن سِيذِي.
\v 6 نِيثْنِي تّْوَاڒِينْ مِينْ وَارْ إِدْجِينْ، ؤُشَا \add سَّاوَاڒنْ\add* ثَاڭزَّانْثْ إِسّْخَارِّيقنْ، أَقَا إِنِّي إِقَّارنْ: سِيذِي إِقَّارْ!، وَاخَّا سِيذِي وَارْ ثنْ إِسّكّْ شَا، \add عَاذْ\add* سِيتِّيمنْ بلِّي أَوَاڒْ أَذْ إِفّغْ.
\v 7 مَا كنِّيوْ وَارْ ثژْرِيمْ \add خنِّي\add* إِوحَّانْ وَارْ إِدْجِينْ، نِيغْ وَارْ ثسِّيوِيڒمْ كنِّيوْ ثَاڭزَّانْثْ إِسّْخَارِّيقنْ ؤُمِي ثقَّارمْ: سِيذِي إِقَّارْ!، \add وَاخَّا\add* نشّْ وَارْ سِّيوِيڒغْ شَا؟‘ “
\m 
\v 8 ”س ؤُيَا، أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ’مِينْزِي ثسَّاوَاڒمْ ڒْبَاطڒْ ؤُ ثتّْوَاڒَامْ \add إِوحَّانْ\add* إِسّْخَارِّيقنْ، س ؤُيَا، خْزَارْ، نشّْ أَقَا أَيِي خَاومْ، إِقَّارْ سِيذِي إِنُو، سِيذِي.
\v 9 أَذْ يِيڒِي ؤُفُوسْ إِنُو ضِيدّْ إِ إِنَابِييّنْ نِّي إِتّْوَاڒَانْ ڒْبَاطڒْ ؤُ تّْڭزَّاننْ س إِخَارِّيقنْ. نِيثْنِي وَارْ تّْغِيمِينْ شَا ذڭْ وڭْرَاوْ ن ڒْڭنْسْ إِنُو ؤُ وَارْ تّْوَازمِّيمنْ شَا ذِي لِيسْثَا ن ثَادَّارْثْ ن إِسْرَائِيل ؤُ وَارْ د-تَّاسنْ خْ وُوذمْ ن ثمُّورْثْ ن إِسْرَائِيل. كنِّيوْ أَذْ ثسّْنمْ بلِّي نشّْ، سِيذِي، ذ سِيذِي.‘ “
\m 
\v 10 ”مِينْزِي، \add وَاهْ،\add* مِينْزِي نِيثْنِي تّْغَارَّانْ ڒْڭنْسْ إِنُو، قَّارنْ: ’ڒهْنَا!‘ أَمْ وَارْ إِدْجِي ڒهْنَا، \add أَمُّو\add* إِ غَا إِبْنَا \add ڒْڭنْسْ\add* إِجّْ ن ڒْحِيضْ إِتّنْهزَّانْ. ؤُشَا خْزَارمْ، \add خنِّي\add* تّْڒحَّافنْ أَسْ \add عَاوذْ\add* س جَّارْ.
\v 11 إِنِي إِ يِينِّي إِتّْڒحَّافنْ \add ڒْْحِيضْ\add* س جَّارْ، بلِّي أَذْ إِوْضَا. أَذْ د-يَاسْ ونْژَارْ إِجهْذنْ ؤُشَا كنِّيوْ، \add أَ\add* إِبْقُوقنْ إِمقّْرَاننْ ن ثبْرُورِي، أَذْ ثوْضَامْ، ؤُشَا إِسمِّيضنْ ن ثْحَارْيَاضْثْ أَذْ د-فّْغنْ س جّهْذْ.
\v 12 ؤُشَا خْزَارْ، خْمِي إِوْضَا ڒْحِيضْ، مَا وَارْ ذ أَومْ قَّارنْ: ’مَانِي إِدْجَا جَّارْ إِ زِي ذ أَسْ ثْڒحّْفمْ؟‘ “
\m 
\v 13 ”س ؤُيَا، أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ’ذڭْ وسْعَارْ إِنُو أَذْ ث أَرْژغْ س إِسمِّيضنْ ن ثْحَارْيَاضْثْ ؤُ س وغْضَابْ إِنُو أَذْ يِيڒِي ونْژَارْ إِجهْذنْ أَطَّاسْ ؤُ س وسْعَارْ إِنُو \add أَذْ وْضَانْ\add* إِبْقُوقنْ إِمقّْرَاننْ ن ثبْرُورِي أَڒَامِي غَا إِقْضَا. \f ◼ \fr 13:‏13 \ft \bd ’خَاسْ‘\bd* - إِخْسْ أَذْ يِينِي ’خْ ڒْحِيضْ‘.\f*  \x ◘ \xo 13:‏13 \xt أَسَا.16‏:‏21\x*
\v 14 \add أَمُّو\add* إِ غَاغضْڒغْ ڒْحِيضْ نِّي ثْڒحّْفمْ س جَّارْ إِفسْينْ ؤُ نشّْ أَذْ ث مّنْضَارغْ غَارْ ثمُّورْثْ أَڒَامِي غَا إِتّْوَاعَارَّا ذْسَاسْ نّسْ. أَذْ ثوْضَا ثنْذِينْثْ ؤُ كنِّيوْ أَذْ ثتّْوَاهلّْكمْ ذِي ڒْوسْطْ نّسْ ؤُشَا أَذْ ثسّْنمْ بلِّي نشّْ ذ سِيذِي.
\v 15 أَذْ نْضَارغْ أَسْعَارْ إِنُو خْ ڒْحِيضْ ؤُ خْ يِينِّي ث إِذْڒِينْ س جَّارْ ؤُشَا أَذْ أَومْ إِنِيغْ: وَارْ ذِينْ إِدْجِي \add عَاذْ\add* ڒْحِيضْ ؤُڒَا ذ يِينِّي ذ أَسْ إِڒحّْفنْ،
\v 16 إِنَابِييّنْ ن إِسْرَائِيل نِّي إِنبَّانْ خْ ؤُرْشَالِيمْ ؤُشَا ثْوَاڒِينْ إِجّْ ن ڒوْحِييْ ن ڒهْنَا إِ نتَّاثْ أَمْ وَارْ إِدْجِي ڒهْنَا!‘، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي.“
\b
\s1 أَوَاڒْ ضِيدّْ إِ ثْنَابِّييِينْ إِسّْخَارِّيقنْ
\m 
\v 17 ”شكْ، \add أَ\add* مِّيسْ ن بْنَاذمْ، أَرّْ ؤُذمْ نّشْ غَارْ يسِّيسْ ن ڒْڭنْسْ نّشْ، ثِينِّي إِتّْنبَّانْ زڭْ وُوڒْ ن يِيخفْ نْسنْثْ، ؤُ نبَّا خَاسنْثْ،
\v 18 إِنِي: ’أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ؤُشْثْ \add خْ ثمْغَارِينْ\add* نِّي إِتّْخيَّاضنْ ڒشْفنْ خْ مَارَّا ڒمْفَاصڒْ ن إِفَاسّنْ إِنُو ؤُشَا تّڭّنْثْ إِڒحَّافْ خْ ؤُزدْجِيفْ ن ؤُمقّْرَانْ ذ ؤُمژْيَانْ مَاحنْذْ أَذْ ڭْمَارنْثْ ڒعْمُورْ! مَا ثخْسنْثْ أَذْ ثڭْمَارنْثْ ڒعْمُورْ ن ڒْڭنْسْ إِنُو ؤُ أَذْ ثحْضَانْثْ ثُوذَارْثْ ن يِيخفْ نْكنْثْ؟
\v 19 مَا ثخْسنْثْ أَذْ أَيِي ثسّْفسْذنْثْ غَارْ ڒْڭنْسْ إِنُو ذِي طّْوعْ ن شَا ن وُورَاونْ ن إِمنْذِي ذ شَا ن إِڒقّْوَازْ ن وغْرُومْ، مَاحنْذْ أَذْ ثنْغنْثْ ڒعْمُورْ، نِّي وَارْ إِعدّڒْ أَذْ مّْثنْ ؤُ مَاحنْذْ أَذْ ثحْضَانْثْ ثُوذَارْثْ ن ڒعْمُورْ نِّي وَارْ إِعدّڒْ أَذْ قِّيمنْ دَّارنْ، س إِخَارِّيقنْ نْكنْثْ غَارْ ڒْڭنْسْ إِنُو نِّي إِسّْحسَّانْ غَارْ ؤُخَارِّيقْ؟‘ “ \x ◘ \xo 13:‏19 \xt مِيخَا 3‏:‏5\x*
\m 
\v 20 ”س ؤُيَا، أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ’خْزَارْ، أَذْ أَرّغْ ڒشْفنْ نْكنْثْ إِ زِي ثْيمَّارنْثْ ذِينْ، أَذْ ضْونْ أَكْ-ذ ڒعْمُورْ. أَذْ ثنْ قڒْعغْ زڭْ إِغَادْجنْ نْكنْثْ ؤُشَا أَذْ ذڒْقغْ إِ ڒعْمُورْ إِ ثْيمَّارنْثْ، \add أَذْ ڭّغْ\add* ڒعْمُورْ أَذْ ضْونْ.
\v 21 أَذْ شَارّْڭغْ إِڒحَّافنْ نْكنْثْ ؤُشَا أَذْ سّْنجْمغْ ڒْڭنْسْ إِنُو زڭْ إِفَاسّنْ نْكنْثْ أَڒَامِي نِيثْنِي وَارْ تِّيڒِينْ عَاذْ ذ ثَاكشَّاضْثْ ذڭْ إِفَاسّنْ نْكنْثْ. \add خنِّي\add* كنِّينْثْ أَذْ ثسّْننْثْ بلِّي نشّْ ذ سِيذِي،
\v 22 مِينْزِي كنِّينْثْ ثسّْخيّْقنْثْ ؤُڒْ ن ؤُمْسڭّذْ س إِخَارِّيقنْ، ؤُمِي نشّْ سِيمَانْثْ إِنُو وَارْ ذَايسْ ڭِّيغْ ڒحْرِيقْ ؤُ مِينْزِي كنِّينْثْ ثسّْجهْذنْثْ إِفَاسّنْ ن إِعفَّاننْ أَڒَامِي أَعفَّانْ وَارْ د-إِذْوِيڒْ زڭْ وبْرِيذْ نّسْ أَعفَّانْ مَاحنْذْ أَذْ إِقِّيمْ إِدَّارْ.“
\m 
\v 23 ”س ؤُيَا وَارْ ثْژَارّمْ عَاذْ \add إِوحَّانْ\add* وَارْ إِدْجِينْ ؤُ وَارْ ثتّڭّمْ عَاذْ س ثْڭزَّانْثْ. نشّْ أَذْ سّْنجْمغْ ڒْڭنْسْ إِنُو زڭْ ؤُفُوسْ نْومْ ؤُ كنِّيوْ أَذْ ثسّْنمْ بلِّي نشّْ ذ سِيذِي.“
\b
\b
\c 14
\s1 أَوَاڒْ ضِيدّْ إِ ينِّي إِعبّْذنْ لْ-أَصْنَامْ
\m 
\v 1 ؤُسِينْ-د غَارِي \bd يرْيَازنْ زڭْ إِمْغَارنْ ن إِسْرَائِيل\bd* ؤُشَا قِّيمنْ زَّاثِي. \x ◘ \xo 14:‏1 \xt حِز. 20‏:‏1\x*
\v 2 \add خنِّي\add* يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا:
\v 3 ”\add أَ\add* مِّيسْ ن بْنَاذمْ، إِرْيَازنْ-أَ سّْڭعّْذنْ إِميْضَا \add ن لْ-أَصْنَامْ نْسنْ\add* ذڭْ وُوڒْ نْسنْ ؤُشَا ڭِّينْ ثَاعنْكْرِيفْثْ إِ د-يِيوْينْ ڒْمُوعْصِييّثْ نْسنْ نِيشَانْ زَّاثْ إِ يِيخفْ نْسنْ. مَا نشّْ أَذْ ثنْ جّغْ عَاذْ أَذْ تَّارنْ شّْوَارْ زَّايِي؟“
\v 4 ”س ؤُيَا، شكْ، سِيوڒْ أَكِيذْسنْ ؤُشَا إِنِي أَسنْ: ’أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: كُوڒْ أَرْيَازْ زِي ثَادَّارْثْ ن إِسْرَائِيل نِّي إِسّْڭعّْذنْ إِميْضَا ن لْ-أَصْنَامْ ذڭْ وُوڒْ نّسْ ؤُشَا إِڭَّا ثَاعنْكْرِيفْثْ إِ د-يِيوْينْ ڒْمُوعْصِييّثْ نّسْ نِيشَانْ زَّاثْ إِ وُوذمْ نّسْ ؤُشَا \add خنِّي\add* أَذْ د-يَاسْ غَارْ ؤُنَابِي، نشّْ، سِيذِي، أَذْ خَاسْ د-يَارّْ، مَاڒَا إِتَّاسْ-د، أَنشْثْ \add ڒْقدّْ ن\add* ؤُبَارُّو ن إِميْضَا نّسْ ن لْ-أَصْنَامْ،
\v 5 حِيمَا أَمُّو إِ غَا ڒقْفغْ ثَادَّارْثْ ن إِسْرَائِيل ذڭْ وُوڒْ نْسنْ، مَاغَارْ أَڭّْوجنْ خَافِي مَارَّا زِي سِّيبّثْ ن إِميْضَا نْسنْ ن لْ-أَصْنَامْ.‘ “
\m 
\v 6 ”س ؤُيَا، إِنِي إِ ثَادَّارْثْ ن إِسْرَائِيل: ’أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ذوْڒمْ-د ؤُشَا قڒْبمْ خْ إِميْضَا نْومْ ن لْ-أَصْنَامْ ؤُشَا أَرّمْ إِغمْبَابْ نْومْ خْ مَارَّا جّْعَايفْ نْومْ.‘
\v 7 مِينْزِي إِ كُوڒْ أَرْيَازْ زِي ثَادَّارْثْ ن إِسْرَائِيل ؤُ زِي إِبَارَّانِي\add يّنْ\add* نِّي إِزدّْغنْ ذِي إِسْرَائِيل - ونِّي إِ غَا يَاڭّْوجنْ زِي ضفَّارْ إِنُو ؤُ إِتّجَّا أَذْ د-أَذْفنْ إِميْضَا ن لْ-أَصْنَامْ غَارْ وُوڒْ نّسْ ؤُشَا إِڭَّا ثَاعنْكْرِيفْثْ إِ د-إِتَّاوْينْ ڒْمُوعْصِييّثْ نّسْ نِيشَانْ زَّاثْ إِ وُوذمْ نّسْ ؤُشَا \add خنِّي\add* أَذْ د-يَاسْ غَارْ ؤُنَابِي، مَاحنْذْ أَذْ يَارْزُو زَّايسْ شّْوَارْ - أَقَا نشّْ ذ سِيذِي أَذْ خَاسْ د-أَرّغْ.
\v 8 نشّْ أَذْ أَرّغْ ؤُذمْ إِنُو ضِيدّْ إِ ورْيَازْ نِّي ؤُشَا أَذْ ث سّْجْعَارغْ أَڒَامِي \add إِ غَا إِذْوڒْ\add* ذ إِشْثْ ن ڒعْڒَامثْ ذ إِجّْ ن ؤُمذْيَا. نشّْ أَذْ ث قضْعغْ زِي ڒْوسْطْ ن ڒْڭنْسْ إِنُو ؤُ كنِّيوْ أَذْ ثسّْنمْ أَقَا نشّْ ذ سِيذِي.‘ “ \x ◘ \xo 14:‏8 \xt أَعَوذ. 28‏:‏37؛ حِز. 5‏:‏15\x*
\m 
\v 9 ” ’خْمِي إِجّْ ن ؤُنَابِي إِجَّا إِخفْ نّسْ أَذْ أَسْ غَارّنْ ؤُشَا إِسِّيوڒْ إِجّْ ن وَاوَاڒْ، \add خنِّي\add* نشّْ، سِيذِي، أَذْ غَارّغْ أَنَابِي نِّي ؤُشَا أَذْ سّْوِيژّْضغْ أَفُوسْ إِنُو ضِيدّْ نّسْ ؤُشَا أَذْ ث ثحِّيغْ زِي ڒْوسْثْ ن ڒْڭنْسْ إِنُو ن إِسْرَائِيل. \x ◘ \xo 14:‏9 \xt حِز. 13‏:‏1، 2، 9\x*
\v 10 نِيثْنِي أَذْ أَرْبُونْ ڒْمُوعْصِييّثْ نْسنْ. أَنشْثْ ن ڒْمُوعْصِييّثْ ن يِينِّي يَارزُّونْ شّْوَارْ، أَمُّو إِ غَا ثِيڒِي ڒْمُوعْصِييّثْ ن ؤُنَابِي \add نِّي\add*،
\v 11 حِيمَا ثَادَّارْثْ ن إِسْرَائِيل وَارْ ثتّْودَّارْ \add عَاذْ\add* زِي ضفَّارْ إِنُو ؤُ نِيثْنِي وَارْ سّْخمَّاجنْ \add عَاذْ\add* إِخفْ نْسنْ س مَارَّا إِخطَّانْ نْسنْ. \add خنِّي\add* أَذْ أَيِي إِڒِينْ ذ ڒْڭنْسْ ؤُ نشّْ أَذْ إِڒِيغْ ذ أَربِّي نْسنْ!‘، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي.“
\b
\s1 ثْڒَاثَا ن إِمْسڭَّاذنْ ذ أَربْعَا ن ڒحْكَامَاثْ
\m 
\v 12 يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا:
\v 13 ”\add أَ\add* مِّيسْ ن بْنَاذمْ، مَاڒَا ثخْضَا إِشْثْ ن ثمُّورْثْ أَكِيذِي أَمْ ثتّڭّْ س ڒْغذْرَانْ أَمقّْرَانْ، \add خنِّي\add* نشّْ أَذْ سّْوِيژّْضغْ أَفُوسْ إِنُو ضِيدّْ نّسْ. أَذْ أَرْژغْ ڒعْوتْشْ ن وغْرُومْ نّسْ ؤُ أَذْ سّكّغْ ذَايسْ ڒَاژْ ؤُ أَمُّو إِ غَا ثحِّيغْ أَمْ بْنَاذمْ أَمْ ڒْمَاڒْ. \x ◘ \xo 14:‏13 \xt لَاوِي 26‏:‏26؛ حِز. 4‏:‏16؛ 5‏:‏16\x*
\v 14 مَاڒَا ثُوغَا أَثنْ ذِي ڒْوسْثْ نّسْ ثْڒَاثَا ن يرْيَازنْ-أَ، نُوحْ ذ ذَانِييِيلْ ذ أَيُوبْ، أَذْ فكّنْ نِيثْنِي مْغِيرْ ڒعْمَارْ \add ن يِيخفْ نْسنْ\add* س ثْسڭْذَا نْسنْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي.“ \x ◘ \xo 14:‏14 \xt إِرْم. 15‏:‏1\x*
\m 
\v 15 ”مَاڒَا ڭِّيغْ أَذْ ژْوَانْ إِمُودَّارنْ ن ڒخْڒَا خْ ثمُّورْثْ ؤُشَا أَذْ زَّايسْ كشّْضنْ إِحنْجِيرنْ، أَڒَامِي ثذْوڒْ ذ إِشْثْ ن ثمُّورْثْ إِتّْوَاردّْدْجنْ، أَڒَامِي وَارْ يدْجِي وِي سّنِّي إِ غَا يعْذُونْ زِي سِّيبّثْ ن ڒوْحُوشْ إِوْعَارنْ،
\v 16 \add وَاخَّا ثُوغَا\add* ثْڒَاثَا ن يرْيَازنْ نِّي ذِي ڒْوسْطْ نّسْ، س ثِيذتّْ أَمْ دَّارغْ نشّْ، إِسَّاوَاڒْ سِيذِي إِنُو، سِيذِي، وَارْ زمَّارنْ نِيثْنِي أَذْ فكّنْ إِحنْجِيرنْ نِيغْ ثِيحنْجِيرِينْ، أَذْ فكّنْ مْغِيرْ إِخفْ نْسنْ، \add مَاشَا\add* ثَامُّورْثْ أَذْ ثذْوڒْ ذ إِشْثْ ن ثمُّورْثْ إِتّْوَاردّْدْجنْ.“
\m 
\v 17 ”نِيغْ أَذْ سِّيوْضغْ سِّيفْ خْ ثمُّورْثْ نِّي، أَذْ إِنِيغْ: ’سِّيفْ، أكّْ خْ ثمُّورْثْ!‘، أَڒَامِي زَّايسْ إِ غَا قضْعغْ بْنَاذمْ ذ ڒْمَاڒْ،
\v 18 س ثِيذتّْ أَمْ دَّارغْ نشّْ، إِقَّارْ سِيذِي إِنُو، سِيذِي، وَاخَّا \add ثُوغَا\add* ثْڒَاثَا ن يرْيَازنْ نِّي ذِي ڒْوسْطْ نّسْ، وَارْ زمَّارنْ نِيثْنِي أَذْ فكّنْ إِحنْجِيرنْ نِيغْ ثِيحنْجِيرِينْ، أَذْ فكّنْ مْغِيرْ إِخفْ نْسنْ.“
\m 
\v 19 ”نِيغْ أَذْ سّكّغْ طَّاعُونْ غَارْ ثمُّورْثْ نِّي ؤُشَا أَذْ سّْفَارْغغْ أَسْعَارْ إِنُو \add إِخدْجْضنْ\add* س إِذَامّنْ أَڒَامِي زَّايسْ إِ غَا قضْعغْ بْنَاذمْ ذْ ڒْمَاڒْ،
\v 20 \add س ثِيذتّْ أَمْ\add* دَّارغْ نشّْ، إِقَّارْ سِيذِي إِنُو، سِيذِي، \add وَاخَّا ثُوغَا\add* نُوحْ ذ ذَانِييَالْ ذ أَيُوبْ ذِي ڒْوسْطْ نّسْ، وَارْ زمَّارنْ نِيثْنِي أَذْ فكّنْ إِحنْجِيرنْ نِيغْ ثِيحنْجِيرِينْ، أَذْ فكّنْ مْغِيرْ إِخفْ نْسنْ س ثْسڭْذَا نْسنْ.“ \x ◘ \xo 14:‏20 \xt إِرْم. 15‏:‏1\x*
\m 
\v 21 ”مِينْزِي أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: مَاهُو خْمِي غَا سّكّغْ ضِيدّْ إِ ؤُرْشَالِيمْ أَربْعَا ن ڒحْكَامَاثْ إِنُو إِقسْحنْ \add مَارَّا\add*: سِّيفْ ذ ڒَاژْ ذ ڒْمَاڒْ ن ڒخْڒَا ذ طَّاعُونْ، مَاحنْذْ أَذْ زَّايسْ قضْعغْ بْنَاذمْ ذ ڒْمَاڒْ!
\v 22 ؤُشَا خْزَارْ، أَذْ ذَايسْ قِّيمنْ \add عَاذْ\add* إِنِّي إِنّجْمنْ ؤُ نِيثْنِي أَذْ تّْوَانذْهنْ بَارَّا، \add أَمْ\add* إِحنْجِيرنْ \add أَمْ\add* ثْحنْجِيرِينْ. خْزَارْ، أَذْ غَارْومْ د-فّْغنْ ؤُشَا كنِّيوْ أَذْ ثْژَارمْ أَبْرِيذْ نْسنْ ذ ڒخْذَايمْ نْسنْ ؤُشَا كنِّيوْ أَذْ تّْوَاسّْفوّْجمْ خْ ڒْغَارْ نِّي سِّيوْضغْ خْ ؤُرْشَالِيمْ، \add وَاهْ،\add* خْ مَارَّا مِينْ خَاسْ سِّيوْضغْ.
\v 23 نِيثْنِي أَذْ كنِّيوْ سّْفوّْجنْ خْمِي غَا ثْژَارمْ أَبْرِيذْ نْسنْ ذ ڒخْذَايمْ نْسنْ ؤُشَا كنِّيوْ أَذْ ثسّْنمْ بلِّي مَارَّا مِينْ ذَايسْ ڭِّيغْ، وَارْ ث ڭِّيغْ بْڒَا سِّيبّثْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي.“
\b
\b
\c 15
\s1 ثَازَايَارْثْ ن ؤُرْشَالِيمْ
\m 
\v 1 يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا:
\v 2 ”\add أَ\add* مِّيسْ ن بْنَاذمْ، مِينْ إِعْنَا ؤُكشُّوضْ ن ثْزَايَارْثْ كْثَارْ زڭْ ؤُكشُّوضْ \add نّغْنِي\add*، \add كْثَارْ زڭْ\add* ؤُكشُّوضْ نِّي ذِينْ \add إِدْجَانْ\add* جَارْ ثْشجُّورَا ن وزْغَارْ؟ \f ◼ \fr 15:‏2 \ft \bd ’أَزْغَارْ‘\bd* - نِيغْ ’ڒْغَابثْ‘ نِيغْ ’ثَازْڭَانْثْ‘.\f*
\v 3 مَا إِزمَّارْ \add بْنَاذمْ\add* أَذْ زَّايسْ إِكْسِي أَكشُّوضْ مَاحنْذْ أَذْ زَّايسْ إِڭّْ إِشْثْ ن ڒْقشْعثْ إِنفّْعنْ إِ ڒْخذْمثْ؟ مَا إِتّْوَاكّْسِي زَّايسْ إِشْثْ ن ڒوْثذْ حِيمَا أَذْ ذَايسْ ثَايْڒذْ شَا ن ڒْقشْعثْ؟
\v 4 خْزَارْ، أَذْ إِمّوْشْ ذ مَاشَّا إِ ثْمسِّي. ثِيمسِّي أَذْ ثشّْ ثْنَاينْ ن طّْرُوفَا نّسْ ؤُ أَغزْذِيسْ نْ ڒْوسْثْ إِتّْوَاشمْضْ. مَا أَذْ إِصْڒحْ \add ؤُكشُّوضْ نِّي عَاذْ\add* إِ يِيشْثْ نْ ڒْقشْعثْ إِ ڒْخذْمثْ؟
\v 5 خْزَارْ، ؤُمِي ثُوغَا \add عَاذْ\add* إِمُونْ، وَارْ زَّايسْ ثتّْوَاڭّْ إِشْثْ ن ڒْقشْعثْ إِ ڒْخذْمثْ. مشْحَاڒْ قلّْ عَاذْ ؤُمِي ث ثشَّا ثِيمسِّي، إِشْمضْ \add ؤُكشُّوضْ\add*. مَا أَذْ زَّايسْ ڭّنْ عَاذْ شَا نْ ڒْقشْعثْ إِ ڒْخذْمثْ؟“
\m 
\v 6 ”س ؤُيَا، أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ’مَامّشْ إِ وْشِيغْ أَكشُّوضْ ن ثْزَايَارْثْ جَارْ ؤُكشُّوضْ ن وزْغَارْ إِ ثِيمسِّي، حِيمَا أَذْ إِتّْوَاشّْ، أَمُّو إِ غَا سلّْمغْ ؤُڒَا ذ إِمزْذَاغْ ن ؤُرْشَالِيمْ \add إِ ثْمسِّي\add*!
\v 7 مَاغَارْ نشّْ أَذْ أَرّغْ ؤُذمْ إِنُو ضِيدّْ نْسنْ. \add خْمِي\add* إِ غَا خْسنْ أَذْ د-فّْغنْ زِي ثْمسِّي، أَذْ ثنْ ثسّشْمضْ ثْمسِّي ؤُ كنِّيوْ أَذْ ثسّْنمْ بلِّي نشّْ ذ سِيذِي، ؤُمِي ڭِّيغْ ؤُذمْ إِنُو ضِيدّْ نْسنْ.
\v 8 أَذْ أَرّغْ ثَامُّورْثْ ذ إِشْثْ ن ثمُّورْثْ إِتّْوَاردّْدْجنْ، مِينْزِي نِيثْنِي غْذَارنْ أَيِي س إِشْثْ ڒغْذَارثْ إِقسْحنْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي.‘ “
\b
\b
\c 16
\s1 ڒغْذَارْ ن ؤُرْشَالِيمْ إِ سِيذِي أَربِّي
\m 
\v 1 يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا:
\v 2 ”\add أَ\add* مِّيسْ ن بْنَاذمْ، سْشنْ إِ ؤُرْشَالِيمْ جّْعَايفْ نّسْ،
\v 3 ؤُشَا إِنِي: ’أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي، إِ ؤُرْشَالِيمْ: خْ لْ-أَصلْ نّمْ ذ وخْڒَاقْ نّمْ أَقَا شمْ زِي ثمُّورْثْ ن أَيْثْ ن كنْعَانْ. ثُوغَا بَابَامْ ذ أَمُورِي ؤُ يمَّامْ ذ ثَاحِيتِّيثْ.
\v 4 \add غَارْ\add* ثْڒَاڒِيثْ نّمْ، ذڭْ وَاسّْ نِّي ذِي د-ثتّْوَاخڒْقذْ، وَارْ ذ أَمْ قسّنْ ثَاعبُّوثْ نِيغْ سِّيرْذنْ شمْ س وَامَانْ، حِيمَا أَذْ شمْ سِّيزْذڭنْ. وَارْ شمْ مدْجْحنْ س ثْمدْجَاحْثْ نِيغْ شمْ سّنّْضنْ س ثحْڒُوشِينْ.
\v 5 ثُوغَا وَارْ ثْخزَّارْ إِ شمْ ؤُڒَا ذ إِشْثْ ن ثِيطّْ، حِيمَا أَذْ أَمْ يڭّْ شَا زِي دّڭَّا، حِيمَا أَذْ أَمْ ثزِّيدْجزْ، \add مَاشَا\add* ثمّنْضَارذْ خْ وُوذمْ ن ييَّارْ س ڒْحڭْرَا ن ڒعْمَارْ نّمْ ذڭْ وَاسّْ نِّي ذِي د-ثتّْوَاخڒْقذْ.‘ “
\m 
\v 6 ”\add ؤُمِي\add* ژْوِيغْ زَّاثكْ، ژْرِيغْ شمْ ثتّْنقْڒَابذْ ذڭْ إِذَامّنْ نّمْ. نشّْ نِّيغْ أَمْ ؤُمِي شمْ ثُوغَا ذڭْ إِذَامّنْ نّمْ: ’دَّارْ!‘، \add وَاهْ،\add* نشّْ نِّيغْ أَمْ ؤُمِي ثُوغَا شمْ ذڭْ إِذَامّنْ نّمْ: ’دَّارْ!‘
\v 7 أَرْنِيغْ ذَايكْ أَڒَامِي ثْفيّْضذْ أَمْ ؤُغمُّويْ ن ييَّارْ. شمْ ثيْمِيذْ، ثمْغَارذْ ؤُشَا ثِيوْضذْ أَذْ ثِيڒِيذْ ثشْنِيذْ أَطَّاسْ. إِذْمَارنْ نّمْ جمْذنْ ؤُ ؤُشُوَّافْ نّمْ إِمْغَارْ، \add مَاشَا\add* ثُوغَا شمْ ذ ثَاعَارْيَانْثْ ذ ثَاقذِّيذْثْ.
\v 8 \add ؤُمِي\add* ژْوِيغْ زَّاثمْ، ژْرِيغْ شمْ ؤُشَا خْزَارْ، ؤُسَّانْ نّمْ \add إِوْضنْ\add*، ؤُسَّانْ ن ثَايْرِي. نشّْ سّْوِيژّْضغْ أَفْرِيوْ\add أنْ\add* إِنُو خَامْ ؤُشَا ذْڒِيغْ ثُوعَّارْينْثْ نّمْ. جُّودْجغْ إِشْثْ ن ثْجَادْجِيثْ ذِي طّْوعْ نّمْ ؤُشَا ؤُذْفغْ غَارْ ڒْعَاهْذْ أَكِيذمْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي، ؤُشَا \add أَمُّو إِ\add* ثْذوْڒذْ إِنُو. \x ◘ \xo 16:‏8 \xt أَمز. 22‏:‏16؛ 24‏:‏7\x*
\v 9 سِّيرْذغْ شمْ س وَامَانْ ؤُشَا سْڒِيڒغْ إِذَامّنْ نّمْ زَّايمْ ؤُشَا ذهْنغْ شمْ س زّشْثْ.
\v 10 نشّْ سّْيَارْضغْ شمْ س وَارُّوضْ نْ ؤُبُورْضَا س ثِينْثَاثْ إِفَارْزنْ ؤُشَا سّْغُونغْ شمْ س ثْسِيڒَا ن ثڒْمشْثْ ن دّنْفِيڒْ ؤُشَا سّْبيْسغْ شمْ س ڒقْطنْ أَزْذَاذْ ؤُشَا ذْڒِيغْ شمْ س ڒهْرِيرْ.
\v 11 قّْنغْ شمْ س ڒهْزُوطْ ؤُشَا ڭِّيغْ أَمْ ثْمقْيَاسِينْ غَارْ إِفَاسّنْ نّمْ ذ إِشْثْ ن ثْسدّشْثْ ذڭْ يِيرِي نّمْ.
\v 12 ڭِّيغْ ثَاخَاذنْثْ ذِي ثِينْزَارْثْ نّمْ ذ ثخْرَازِينْ ذڭْ إِمجَّانْ نّمْ ذ تَّاجْ إِشْنَانْ خْ ؤُزدْجِيفْ نّمْ.
\v 13 \add أَمُّو إِ\add* ثتّْوَازهّْجذْ س وُورغْ ذ نُّوقَارْثْ ؤُشَا أَرُّوضْ نّمْ ثُوغَا-ث س ڒقْثنْ أَزْذَاذْ ذ ڒهْرِيرْ ذ ؤُبُورْضَارْ س ثِينْثَاثْ إِفَارْزنْ. شمْ ثُوغَا ثشِّيذْ أَرنْ أَزْذَاذْ ذ ثَامّنْثْ ذ زّشْثْ. ثُوغَا شمْ ثشْنِيذْ أَطَّاسْ ؤُشَا ثْفڒْحذْ أَڒَامِي ثْذوْڒذْ ثسّْذَاهْجذْ ثَاڭلْذَا.
\v 14 إِفّغْ زَّايكْ إِجّْ ن يِيسمْ جَارْ ڒڭْنُوسْ زِي سِّيبّثْ ن وَاژْرِي نّمْ، مِينْزِي ثُوغَا أَژْرِي نّمْ نِيشَانْ زڭْ ؤُشوَّارْ إِنُو إِ خَامْ سَّارْسغْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي.“
\m 
\v 15 ”\add مَاشَا\add* ثتِّيقّذْ ذڭْ وژْرِي \add ن يِيخفْ\add* نّمْ ؤُشَا ثسّفْسذْ إِخفْ نمْ \add أَمْ ثتِّيقّذْ\add* ذڭْ يِيسمْ نّمْ ؤُشَا ثْفَارّْغذْ فَارْقْ-شّْغڒْ نّمْ خْ مَارَّا وِي يعْذُونْ: إِ وَانِيثَا ثُوغَا أَژْرِي نّمْ.
\v 16 ثكْسِيذْ شَا زڭْ وَارُّوضْ نّمْ، ثڭِّيذْ ڒڭْعُوذِي س ثِينْثَاثْ أَطَّاسْ إِ يِيخفْ نّمْ ؤُشَا ثسّفّْسذذْ إِخفْ نّمْ ذِينْ. أَمْ مَانْ أَيَاعمَّارْصْ وَارْ إِمْسَارْ ؤُعمَّارْصْ وَارْ إِتِّيڒِي عَاذْ.
\v 17 ثكْسِيذْ ڒهْزُوطْ ن وُورغْ إِنُو ذ نُّوقَارْثْ إِنُو نِّي ذ أَشْ وْشِيغْ ؤُشَا ثڭِّيذْ زِي مَانْ أَيَا ڒخْيَاڒَاثْ ن يرْيَازنْ إِ يِيخفْ نّمْ ؤُشَا ثسّفْسذذْ إِخفْ نّمْ زَّايْسنْ.
\v 18 ثكْسِيذْ أَرُّوضْ ن ؤُبُورْضَارْ س ثِينْثَاثْ إِفَارْزنْ ؤُشَا ثْڒحّْفذْ أَسنْ \add زَّايسْ\add* ؤُشَا ثسَّارْسذْ زّشْثْ إِنُو ذ ڒبْخُورْ إِنُو زَّاثْسنْ.
\v 19 أَغْرُومْ إِنُو نِّي ذ أَمْ وْشِيغْ، وَارنْ أَزْذَاذْ ذ زّشْثْ ذ ثَامّنْثْ إِ زِي شمْ سّشّغْ، أَقَا ثسَّارْسذْ أَيَا ذ أَرِّيحثْ إِتّْفُوحنْ زَّاثْسنْ، \add أَمُّو إِ\add* إِمْسَارْ، إِقَّارْ سِيذِي إِنُو، سِيذِي.
\m 
\v 20 إِحنْجِيرنْ نّمْ ذ يسِّيمْ نِّي د-ثُورْوذْ إِ نشّْ، أَقَا ثكْسِيذْ ثنْ ؤُشَا ثْقدّْمذْ ثنْ ذ مَاشَّا إِ نِيثْنِي. مَا \add خنِّي\add* فَارْقْ-شّْغڒْ نّمْ ذ ذْرُوسْثْ وَاهَا،
\v 21 أَڒَامِي ثْغَارْصذْ إِ إِحنْجِيرنْ إِنُو ؤُشَا ثزّنْزذْ ثنْ ؤُمِي ثنْ ثسّكّذْ خْ ثْمسِّي؟ \x ◘ \xo 16:‏21 \xt إِشا. 57‏:‏5\x*
\v 22 غَارْ مَارَّا جّْعَايفْ نّمْ ذ فَارْقْ-شّْغڒْ نّمْ وَارْ ثِيذَارذْ ذڭْ وُوسَّانْ ن ثمْژِي نّمْ ؤُمِي ثُوغَا شمْ ذ ثَاعَارْيَانْثْ، ثتّْوَاعَارِّيذْ \add ؤُ\add* ثتّْنقْڒَابذْ ذڭْ إِذَامّنْ نّمْ.
\v 23 أَوَارْنِي مَارَّا ڒْغَارْ إِ ثڭِّيذْ - أَيْ، أَيهَّاثْ خَامْ، إِقَّارْ سِيذِي إِنُو، سِيذِي - إِمْسَارْ
\v 24 أَقَا شكْ ثبْنِيذْ إِ يِيخفْ نّمْ إِشْثْ ن ڒْڭعّْذثْ ؤُشَا ثڭِّيذْ إِ يِيخفْ نّمْ ذِي مَارَّا أَزَّايْ إِشْثْ ن ڒْڭعّْذثْ \add حِيمَا أَذْ ذِينْ وهّْبنْ ثِيغَارْصَا\add*.
\v 25 ذِي مَارَّا أَزدْجِيفْ ن وبْرِيذْ ثبْنِيذْ ڒڭْعُوذِي إِ يِيخفْ نّمْ. ثْجيّْحذْ أَژْرِي نّمْ س إِجّْ ن نّْعِي ن وبْرِيذْ ؤُشَا ثسّْوِيژّْضذْ إِضَارنْ نّمْ إِ كُوڒْ إِجّْ وِي يعْذُونْ ؤُشَا ثَارْنِيذْ أَطَّاسْ ذِي فَارْقْ-شّْغڒْ نّمْ.
\v 26 ثسّْفسْذذْ إِخفْ نّمْ ؤُڒَا س أَيْثْ ن مِيصْرَا، جِّيرَانْ نّمْ نِّي إِقّْبُوبُّوزنْ س ويْسُومْ \add نْسنْ\add*. ثَارْنِيذْ أَمُّو أَطَّاسْ ذِي فَارْقْ-شّْغڒْ نّمْ مَاحنْذْ أَذْ أَيِي ثسْعَارذْ.
\v 27 خْزَارْ، خنِّي نشّْ سّْوِيژّْضغْ أَفُوسْ إِنُو ضِيدّْ نّمْ ؤُشَا سّْنقْصغْ ثَاسْغَارْثْ نّمْ إِ ذ أَمْ د-إِتَّاسنْ ؤُشَا سلّْمغْ شمْ غَارْ مژْرِي ن يِينِّي شمْ إِشَارّْهنْ، \add غَارْ\add* يسِّيسْ ن إِفِيلِيسْطِينِييّنْ، ثِينِّي تّْسضْحَانْثْ زڭْ وبْرِيذْ نّمْ إِفضْحنْ. \x ◘ \xo 16:‏27 \xt 2 إِم. 28‏:‏18\x*
\v 28 ثسّفْسذذْ إِخفْ نّمْ أَكْ-ذ أَيْثْ ن أَشُّورْ، ؤُمِي وَارْ ثجِّيوْنذْ. ثسّفْسذذْ إِخفْ نّمْ أَكِيذْسنْ، \add مَاشَا\add* وَارْ ثُوفِيذْ أَجِيونْ.
\v 29 ثَارْنِيذْ أَطَّاسْ ذِي فَارْقْ-شّْغڒْ نّمْ أَڒْ ذِي ثمُّورْثْ ن إِسبَّابنْ، \add ثَامُّورْثْ ن\add* إِكَالْذَانِييّنْ، ؤُشَا ؤُڒَا س ؤُيَا وَارْ ثجِّيوْنذْ.
\v 30 مشْحَاڒْ إِهْڒشْ وُوڒْ نّمْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي، أَقَا ثڭِّيذْ مَارَّا أَيَا، ڒْخذْمثْ ن إِشْثْ ن ثمْغَارْثْ ن فَارْقْ-شّْغڒْ إِغوّْغنْ،
\v 31 ؤُمِي ثبْنِيذْ إِشْثْ ن ڒْڭعّْذثْ غَارْ ؤُزدْجِيفْ ن كُوڒْ أَبْرِيذْ، ثڭِّيذْ إِشْثْ ن ڒْڭعّْذثْ \add إِ ثوْهِيبْثْ ن ثْغَارْصَا\add* ذِي كُوڒْ أَزَّايْ، بْڒَا مَا ثدْجِيذْ \add ذ ثِيذتّْ\add* ذ ثَامْغَارْثْ ن فَارْقْ-شّْغڒْ ؤُمِي ثسّحْقَارذْ ڒخْڒَاصْ \add نّمْ ن فَارْقْ-شّْغڒْ\add*.
\v 32 \add أَ شمْ،\add* ثَامْغَارْثْ إِزنَّانْ، ثنِّي إِتّطّْفنْ إِبَارَّانِييّنْ ذڭْ ومْشَانْ ن ورْيَازْ نّسْ.
\v 33 إِ مَارَّا ثِيمْغَارِينْ ن فَارْقْ-شّْغڒْ وْشِينْ أَسنْثْ ڒْمُونثْ، \add مَاشَا\add* شمْ ثوْشِيذْ ثِيموْشَا إِ مَارَّا إِنِّي شمْ إِتّخْسنْ ؤُشَا \add أَمُّو إِ\add* ثنْ ثسّغْوِيذْ س فَارْقْ-شّْغڒْ نّمْ، مَاحنْذْ أَذْ غَارمْ د-أَسنْ زِي مَارَّا إِغزْذِيسنْ.
\v 34 أَمُّو، س فَارْقْ-شّْغڒْ نّمْ، أَذْ كِيذمْ إِمْسَارْ ڒْعكْسْ ن مِينْ إِمْسَارنْ إِ ثمْغَارِينْ \add نّغْنِي\add*، مِينْزِي وَارْ شمْ ضفَّارنْ شَا مَاحنْذْ أَذْ زَّايمْ ڭّنْ س فَارْقْ-شّْغڒْ \add نْسنْ\add*. مَاڒَا شمْ ثوْشِيذْ أَسنْ ڒخْڒَاصْ ن ثمْغَارْثْ ن فَارْقْ-شّْغڒْ، وَارْ ثطّْفذْ شَا ڒخْڒَاصْ ن ثمْغَارْثْ ن فَارْقْ-شّْغڒْ، \add خنِّي\add* أَقَا شمْ ثْذوْڒذْ ذ ڒْعكْسْ زَّايْسنْ.“
\m 
\v 35 ”س ؤُيَا، \add أَ\add* ثَامْغَارْثْ ن فَارْقْ-شّْغڒْ، سڒْ إِ وَاوَاڒْ ن سِيذِي.
\v 36 أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ’مِينْزِي ثسّْفَارّْغذْ نّْحَاسْ نّمْ \add إِتّْوَاڒحّْفنْ س دّْرَا\add* ؤُ ثسّْعَارِّيذْ ڒحْيَا نّمْ س فَارْقْ-شّْغڒْ نّمْ أَكْ-ذ يِينِّي إِ شمْ إِتّخْسنْ ؤُ أَكْ-ذ مَارَّا إِميْضَا نّمْ ن لْ-أَصْنَامْ ن جّْعَايفْ نّمْ، ؤُ ؤُمِي ذ أَسنْ ثوْشِيذْ إِذَامّنْ ن إِحنْجِيرنْ نّمْ،
\v 37 خْزَارْ، س ؤُيَا أَذْ سّْمُونغْ مَارَّا إِنِّي ثُوغَا شمْ إِتّخْسنْ نِّي ثُوغَا إِ ذ أَمْ إِتّعْجِيبنْ ؤُ مَارَّا إِنِّي ثخْسذْ \add جْمِيعْ\add* أَكْ-ذ مَارَّا إِنِّي ثْشَارْهذْ. نشّْ أَذْ ثنْ د-سّْمُونغْ خَامْ زِي مَارَّا إِغزْذِيسنْ ؤُشَا أَذْ سّْعَارِّيغْ ڒحْيَا نّمْ، \add أَڒْ\add* إِ غَا ژَترنْ مَارَّا ڒحْيَا نّمْ.
\v 38 نشّْ أَذْ خَامْ شَارّْعغْ عْلَاحْسَابْ لْفَارَايِيضْ إِ ثِينِّي إِزنَّانْ ذ ثِينِّي إِسِّيزّْڒنْ إِذَامّنْ ؤُشَا أَذْ شمْ سلّْمغْ غَارْ \add إِجّْ ن ؤُسِيزّڒْ ن\add* إِذَامّنْ إِ د-إِفّْغنْ زڭْ وسْعَارْ ذ ثُوسْمِي.
\v 39 نشّْ أَذْ وْشغْ شمْ ذڭْ ؤُفُوسْ نْسنْ ؤُشَا نِيثْنِي أَذْ أَرْژنْ ڒْڭعّْذثْ نّمْ ؤُشَا أَذْ أَردّْدْجنْ ڒڭْعُوذِي نّمْ ؤُشَا أَذْ أَمْ كّْسنْ أَرُّوضْ نّمْ، أَذْ أَوْينْ ڒهْزُوطْ نّمْ ؤُشَا أَذْ شمْ جّنْ ذ ثَاعَارْيَانْثْ ذ ثَاقذِّيذْثْ.
\v 40 أَوَارْنِي أَيَا أَذْ خَامْ سِّيوْضنْ إِجّْ ن وڭْرَاوْ \add ذ أَمقّْرَانْ\add* ؤُشَا أَذْ شمْ أَرجْمنْ ؤُشَا أَذْ شمْ قسّنْ س ڒسْيُوفْ نْسنْ.
\v 41 نِيثْنِي أَذْ سّْشمْضنْ ثُوذْرِينْ نّمْ س ثْمسِّي ؤُشَا أَذْ خَامْ د-سّهْوَانْ ڒحْكَامَاثْ زَّاثْ إِ ثِيطَّاوِينْ ن وَاطَّاسْ ن ثمْغَارِينْ. نشّْ أَذْ ڭّغْ أَذْ ثسّْبدّذْ زِي فَارْقْ-شّْغڒْ نّمْ، وَارْ ثْبطِّيذْ عَاذْ ڒخْڒَاصْ ن فَارْقْ-شّْغڒْ. \x ◘ \xo 16:‏41 \xt 2 إِج. 25‏:‏9؛ إِرْم. 52‏:‏13\x*
\v 42 \add أَمُّو\add* إِ غَا سَّارْسغْ أَسْعَارْ إِنُو خَامْ ؤُشَا ثُوسْمِي إِنُو \add إِقدّْسنْ\add* أَذْ خَامْ ثْبعّذْ ؤُ نشّْ أَذْ ذوْڒغْ أَريّْحغْ، وَارْ تّْعسِّيبغْ عَاذْ.
\v 43 مِينْزِي وَارْ ثِيذَارذْ ذڭْ وُوسَّانْ ن ثمْژِي نّمْ، ؤُمِي ذ أَيِي ثسْعَارذْ س مَارَّا أَيَا، أَقَا ذَا نشّْ عَاوذْ أَذْ أَوْيغْ أَبْرِيذْ نّمْ خْ يِيخفْ نّمْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي.عمَّارْصْ أَذْ ڭّغْ ڒفْضِيحثْ سنّجْ إِ مَارَّا جّْعَايفْ نّمْ \add ؤُمِي نشّْ وَارْ شمْ تّْعِيقِيبغْ شَا\add*.‘ “\f ◼ \fr 16:‏43 \ft \bd أَفسَّارْ\bd* - خْزَارْ لَاوِي 19‏:29.\f*  \x ◘ \xo 16:‏43 \xt حِز. 9‏:‏10؛ 11‏:‏21؛ لَاوِي 19‏:‏29\x*
\m 
\v 44 ”خْزَارْ، مَارَّا ونِّي إِسَّاوَاڒنْ س وَاوَاڒنْ إِوزْننْ، أَذْ خَامْ إِسَّاوَاڒْ أَوَاڒْ-أَ، أَذْ يِينِي: ’أَمْ يمَّاسْ، أَمْ يدْجِيسْ!‘
\v 45 أَقَا شمْ ذ يدْجِيسْ ن يمَّامْ نِّي إِعِيفّنْ أَرْيَازْ نّسْ ذ إِحنْجِيرنْ نّسْ ؤُ شمْ ذ ؤُتْشْمَاسْ ن سُويثْمَامْ نِّي إِعِيفّنْ زڭْ يرْيَازنْ نْسنْثْ ذ إِحنْجِيرنْ نْسنْثْ. ثُوغَا يمَّامْ ذ ثَاحِيتِّيثْ ؤُ بَابَامْ ذ أَمُورِي.
\v 46 ؤُتْشْمَامْ ثَامقّْرَانْثْ أَقَا-ت سَامَارْيَا، نتَّاثْ ذ يسِّيسْ نّسْ زدّْغنْ غَارْ ؤُژرْمَاضْ نّمْ، ؤُ ؤُتْشْمَامْ ثنِّي ذ ثَامژْيَانْثْ زَّايمْ، ثْزدّغْ غَارْ يفُوسْ نّمْ، أَقَا-ت ذ سَاذُومْ ذ يسِّيسْ.
\v 47 شمْ وَارْ ثڭُّورذْ ذڭْ إِبْرِيذنْ نْسنْثْ ؤُ وَارْ ثڭِّيذْ أَمْ جّْعَايفْ نْسنْثْ. \add مَاشَا\add* أَخْمِي مَامّشْ دّڭَّا ثُوغَا ذْرُوسْثْ \add وَاهَا\add*، ثْفسْذذْ مَارَّا إِبْرِيذنْ نّمْ كْثَارْ زَّايْسنْثْ.
\v 48 س ثِيذتّْ أَمْ دَّارغْ نشّْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي: أَقَا سَاذُومْ، ؤُتْشْمَامْ أَكْ-ذ يسِّيسْ،عمَّارْصْ وَارْ ثڭِّي أَمْ ثڭِّيذْ شمْ ذ يسِّيمْ.
\v 49 خْزَارْ، ثَا ذ ڒْمُوعْصِييّثْ ن ؤُتْشْمَامْ سَاذُومْ: نّْفَاخثْ، ثْيَاوَانْثْ ن وغْرُومْ ذ إِشْثْ ن ثُوذَارْثْ ذِي ڒْهُوذْنثْ بْڒَا أَمْنُوسْ، \add أَمُّو إِ\add* إِدْجَا ؤُمدُّورْ نّسْ ؤُ ن يسِّيسْ، \add مَاشَا\add* أَفُوسْ ن ونِّي إِتّْوَاحْصَارنْ ؤُ ن ؤُمزْڒُوضْ وَارْ ذ أَسْ ثسّجْهذْ.
\v 50 نِيثنْثِي نّفْخنْثْ ؤُشَا ڭِّينْثْ جّْعِيفشْثْ زَّاثْ إِ وُوذمْ إِنُو. ؤُمِي ژْرِيغْ أَيَا، نْضَارغْ ثنْثْ. \x ◘ \xo 16:‏50 \xt أَمز. 19‏:‏24\x*
\v 51 \add مَاشَا\add* سَامَارْيَا وَارْ ثْخطِّي ؤُڒَا ذڭْ وزْينْ ن دّْنُوبْ نّمْ ؤُشَا شمْ ثڭِّيذْ جّْعَايفْ كْثَارْ زَّايسْ. س مَارَّا جّْعَايفْ إِ ثڭِّيذْ، ثَارّذْ سُويثْمَامْ بَاننْثْ سڭّْذنْثْ.
\v 52 \add خنِّي\add* شمْ عَاوذْ، كْسِي ڒفْضِيحثْ نّمْ، مِينْزِي ثوْثِيذْ خْ سُويثْمَامْ. ؤُمِي ثڭِّيذْ دّْنُوبْ ذ جّْعِيفشْثْ كْثَارْ زَّايْسنْثْ، بَاننْثْ نِيثنْثِي سڭّْذنْثْ خَامْ. سضْحَا ؤُ كْسِي ڒفْضِيحثْ نّمْ، مِينْزِي ثَارِّيذْ سُويثْمَامْ بَاننْثْ سڭّْذنْثْ.
\v 53 خْمِي غَا بطّْڒغْ ثَامحْبَاسْثْ نْسنْثْ، ثَامحْبَاسْثْ ن سَاذُومْ ذ يسِّيسْ، ؤُڒَا ذ ثَامحْبَاسْثْ ن سَامَارْيَا ذ يسِّيسْ، \add خنِّي\add* أَذْ بطّْڒغْ \add عَاوذْ\add* ثَامحْبَاسْثْ نّمْ ذِي ڒْوسْطْ نْسنْثْ،
\v 54 حِيمَا أَذْ ثكْسِيذْ ڒفْضِيحثْ نّمْ ؤُشَا أَذْ ثْسضْحِيذْ زِي مَارَّا مِينْ ثڭِّيذْ، ڒَامِي شمْ ثنْثْ ثسّْفوّْجذْ.
\v 55 مَاڒَا سُويثْمَامْ، سَاذُومْ ذ يسِّيسْ، أَذْ د-ذوْڒنْثْ غَارْ ؤُمدُّورْ نْسنْثْ أَمزْوَارُو، ؤُشَا ؤُڒَا ذ سَامَارْيَا ذ يسِّيسْ أَذْ د-ذوْڒنْثْ غَارْ ؤُمدُّورْ نْسنْثْ أَمزْوَارُو، \add خنِّي\add* أَذْ د-ثْذوْڒذْ ؤُڒَا ذ شمْ ذ يسّْمَامْ غَارْ ؤُمدُّورْ نْكنْثْ أَمزْوَارُو.
\v 56 ذڭْ وَاسّْ ن نّْفَاخثْ نّمْ وَارْ إِتّْوَاسڒْ شَا زڭْ ؤُقمُّومْ نّمْ خْ \add مِينْ إِمْسَارنْ إِ\add* ؤُتْشْمَامْ سَاذُومْ،
\v 57 قْبڒْ مَا إِعَارَّا ثُوعفّْنَا نّمْ، أَمْ مَامّشْ \add إِ إِمْسَارْ\add* ذِي ڒْوقْثْ ن ڒْحڭْرَا س ؤُفُوسْ ن يسِّيسْ ن أَرَامْ ذ مَارَّا إِنِّي ذ أَسْ د-إِنّْضنْ، يسِّيسْ ن إِفِيلِيسْطِينِييّنْ نِّي شمْ إِسّحْقَارنْ غَارْ مَارَّا إِغزْذِيسنْ نّمْ. \x ◘ \xo 16:‏57 \xt إِشا. 9‏:‏10‏-‏16\x*
\v 58 ڒفْضَايحْ نّمْ ذ جّْعَايفْ نّمْ أَذْ ثنْثْ ثكْسِيذْ!، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.“
\m 
\v 59 ”مِينْزِي أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ’نشّْ أَذْ زَّايمْ ڭّغْ أَمْ مَامّشْ ثڭِّيذْ شمْ ؤُمِي ثسّحْقَارذْ ثَاجَادْجِيثْ س ثْرژِّيثْ ن ڒْعَاهْذْ.
\v 60 \add مَاشَا عَاذْ\add* أَذْعقْڒغْ خْ ڒْعَاهْذْ إِنُو أَكِيذمْ ذڭْ وُوسَّانْ ن ثمْژِي نّمْ ؤُشَا أَذْ ڭّغْ إِجّْ ن ڒْعَاهْذْ إِ ڒبْذَا إِ شمْ.
\v 61 خنِّي أَذْ ثِيذَارذْ ذڭْ إِبْرِيذنْ نّمْ ؤُشَا أَذْ ثْسضْحِيذْ خْمِي غَا ثَاوْيذْ سُويثْمَامْ نِّي مْغَارنْثْ زَّايمْ، \add جْمِيعْ\add* أَكْ-ذ ثِينِّي ثِيمَاژُوژِينْ خَامْ. نشّْ أَذْ أَمْ ثنْثْ وْشِيغْ ذ يسِّيمْ، \add مَاشَا\add* وَارْ إِدْجِي س وبْرِيذْ ن ڒْعَاهْذْ نّمْ.
\v 62 \add مَاشَا\add* نشّْ أَذْ ڭّغْ ڒْعَاهْذْ إِنُو أَكِيذمْ ؤُشَا أَذْ ثسّْنذْ، أَقَا نشّْ ذ سِيذِي،
\v 63 حِيمَا أَذْ ثِيذَارذْ ذَايسْ ؤُشَا أَذْ ثْسضْحِيذْ ؤُشَا وَارْ ثَارزّْمذْعمَّارْصْ عَاذْ أَقمُّومْ نّمْ زِي سِّيبّثْ ن ڒفْضِيحثْ نّمْ، خْمِي غَا ڭّغْ أَصْڒَاحْ إِ شمْ خْ مَارَّا مِينْ ثڭِّيذْ!، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي.‘ “
\b
\b
\c 17
\s1 ڒْغذْرَانْ ن صِيذْقِييَا
\m 
\v 1 يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا:
\v 2 ”\add أَ\add* مِّيسْ ن بْنَاذمْ، عَاوذْ إِشْثْ ن طْحَاجِيثْ ن ثْوَافِيثْ ؤُ أوْشْ إِجّْ ن ؤُمذْيَا إِ ثَادَّارْثْ ن إِسْرَائِيل
\v 3 ؤُشَا إِنِي:
\b
\m ’أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي!
\m \qt أَڭِيذرْ ذ أَمقّْرَانْ س وَافْرِيونْ أَرزْمنْ،\qt*
\m \qt ذَايْسنْ ڒوْثَاذْ إِزِيرَارنْ شُّورنْ\qt*
\m \qt س وَارِّيشْ ذ ثِينْثَاثْ إِفَارْزنْ،\qt*
\m \qt يُوسَا-د غَارْ إِذُورَارْ ن لُوبْنَانْ\qt*
\m \qt ؤُشَا إِكّسْ ثُوشّنْثْ ن ثْشجَّارْثْ ن ثنْڭلْثْ.\qt*
\m 
\v 4 \qt أَزدْجِيفْ ن ڒفْرُوعْ نّسْ إِسّنْذَاينْ إِكّسْ إِ-ث،\qt*
\m \qt ؤُشَا يِيوْيِي ث غَارْ إِشْثْ ن ثمُّورْثْ ن تِّيجَارَا\qt*
\m \qt ؤُشَا إِسَّارْسْ إِ-ث\qt*
\m \qt ذڭْ إِشْثْ ن ثنْذِينْثْ ن إِسبَّابنْ.\qt*
\m 
\v 5 \qt إِكْسِي زِي زَّارِيعثْ ن ثمُّورْثْ\qt*
\m \qt ؤُشَا إِڭَّا إِ-ت ذڭْ إِجّْ ن ييَّارْ \tl إِشْنَا\tl* إِ وزْرَاعْ.\qt*
\m \qt إِكْسِي ت، إِژُّو ت\qt*
\m \qt أَمْ ثْشجَّارْثْ ن ؤُصفْصَافْ غَارْ وَامَانْ أَطَّاسْ.\qt*
\m 
\v 6 \qt ثغْمِي-د \tl زَّارِيعثْ\tl*\qt*
\m \qt ؤُشَا ثذْوڒْ ذ ثَازَايَارْثْ\qt*
\m \qt س ڒفْرُوعْ وسّْعنْ\qt*
\m \qt أَكْ-ذ ثْرُونْكُو ذ أَقُوضَاضْ\qt*
\m \qt نِّي زِي ذوْڒنْثْ ثْسضْوِينْ \tl غَارْ ؤُڭِيذرْ\tl*،\qt*
\m \qt \tl أَمْ\tl* ثُوغَا إِژوْرَانْ نّسْ قِّيمنْ سَاذُو نّسْ.\qt*
\m \qt أَمُّو إِ ثذْوڒْ ذ إِشْثْ ن ثْزَايَارْثْ\qt*
\m \qt نِّي إِسُّوفّْغنْ ثِيسضْوِينْ\qt*
\m \qt ؤُشَا ثڭَّا أَذْ سّنْذْينْ إِفثْوَانْ.\qt*
\b
\m 
\v 7 \qt ثُوغَا عَاوذْ إِجّْ ن ؤُڭِيذرْ أَمقّْرَانْ نّغْنِي\qt*
\m \qt س وَافْرِيونْ إِمْغَارنْ ذ وَاطَّاسْ ن أَرِّيشْ\qt*
\m \qt ؤُشَا خْزَارْ، ثَازَايَارْثْ ثَارَّا إِژوْرَانْ نّسْ غَارسْ\qt*
\m \qt ؤُشَا ثسّْوِيژّضْ ثِيسضْوِينْ نّسْ غَارسْ\qt*
\m \qt زڭْ إِيَّارْ مَانِي ثتّْوَاژُّو\qt*
\m \qt حِيمَا أَڭِيذرْ أَذْ أَسْ إِسّسُّو.\qt*
\m 
\v 8 \qt ثُوغَا ثتّْوَاژُّو ذڭْ إِجّْ ن ييَّارْ إِسْبحْ زَّاثْ إِ وَامَانْ أَطَّاسْ\qt*
\m \qt حِيمَا أَذْ ثسُّوفّغْ ثِيسضْوِينْ ؤُشَا أَذْ ثوْشْ ڒْغِيدْجثْ،\qt*
\m \qt حِيمَا أَذْ ثذْوڒْ ذ ثَازَايَارْثْ ثشُّورْ.‘\qt*
\b
\m 
\v 9 إِنِي \add خنِّي\add*:
\m ’أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي:
\m \qt مَا أَذْ إِفّغْ مَانْ أَيَا مْلِيحْ؟\qt*
\m \qt مَا وَارْ إِتّكّسْ \tl ؤُڭِيذرْ أَمقّْرَانْ\tl*\qt*
\m \qt إِژوْرَانْ نّسْ\qt*
\m \qt ؤُشَا أَذْ إِقْضعْ ڒْغِيدْجثْ نّسْ\qt*
\m \qt أَڒَامِي إِ غَا ثَاژغْ؟\qt*
\m \qt \tl وَاهْ\tl* أَذْ ثَاژغْ س مَارَّا ثِيفْرَايْ نِّي\qt*
\m \qt غَارسْ إِغمّْينْ،\qt*
\m \qt وَارْ إِتّْوَاحْذِيجْ \tl عَاذْ\tl* \qt*
\m \qt ُغِيڒْ إِجهْذنْ نِيغْ ڒْغَاشِي أَطَّاسْ\qt*
\m \qt حِيمَا أَذْ ت سّْڭعّْذنْ زڭْ إِژوْرَانْ نّسْ.\qt*
\m 
\v 10 \qt خْزَارْ، وَاخَّا ژُّونْ ت،\qt*
\m \qt \tl مَاشَا\tl* مَا \tl خنِّي\tl* أَذْ ثفْڒحْ؟\qt*
\m \qt مَا وَارْ ثتِّيژغْ\qt*
\m \qt خْمِي ت غَا إِڒْقفْ ؤُسمِّيضْ ن ڒْغَارْبْ؟\qt*
\m \qt \tl وَاهْ\tl*، أَذْ ثَاژغْ خْ إِعُورَارْ ن ڒعْرَاصِي\qt*
\m \qt مَانِي د-ثْغمِّي.‘ “\qt*
\b
\m 
\v 11 يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا:
\v 12 ”إِنِي ڒخُّو إِ ثَادَّارْثْ إِغوّْغنْ: ’مَا وَارْ ثسِّينمْ مِينْ عْنَانْثْ ثْمسْڒَايِينْ-أَ؟‘ إِنِي: ’خْزَارْ، أَجدْجِيذْ ن بَابِيلْ يُوسَا-د غَارْ ؤُرْشَالِيمْ ؤُشَا إِطّفْ أَجدْجِيذْ نّسْ ذ ڒْحُوكَّامْ نّسْ ؤُشَا يِيوْيِي ثنْ غَارسْ ذِي بَابِيلْ.
\v 13 إِطّفْ \add عَاوذْ إِجّنْ\add* زِي زَّارِيعثْ إِڭلّْذنْ ؤُشَا إِڭَّا أَكِيذسْ إِجّْ ن ڒْعَاهْذْ ؤُشَا يَارَّا إِ-ث أَذْ إِوْشْ ثَاجَادْجِيثْ ؤُ أَيْثْ ن جّهْذْ ذِي ثمُّورْثْ، أَقَا إِكّسْ إِ-ثنْ،
\v 14 حِيمَا أَذْ ثِيڒِي ثْڭلْذِيثْ ثْوَاضعْ ؤُ وَارْ ثسّْڭِيعِّيذْ إِخفْ نّسْ ؤُ حِيمَا أَذْ ثحْضَا ڒْعَاهْذْ نّسْ، أَذْ ثقِّيمْ ثتّْبدَّا.
\v 15 \add مَاشَا\add* نتَّا إِغوّغْ خَاسْ، إِسّكّْ إِرقَّاسنْ نّسْ غَارْ مِيصْرَا، مَاحنْذْ أَذْ أَسْ وْشنْ إِيْسَانْ ذ \add إِجّْ ن ؤُبَارُّو ن\add* ڒْڭنْسْ. مَا أَذْ إِفّغْ أَيَا مْلِيحْ؟ مَا إِزمَّارْ أَذْ يَارْوڒْ ونِّي إِڭِّينْ أَيَا؟ مَا إِزمَّارْ ونِّي يَارْژِينْ ڒْعَاهْذْ أَذْ يَارْوڒْ؟‘ “ \x ◘ \xo 17:‏15 \xt إِرْم. 37‏:‏5\x*
\m 
\v 16 ”س ثِيذتّْ أَمْ دَّارغْ نشّْ، إِقَّارْ سِيذِي إِنُو، سِيذِي: ’ذڭْ ومْشَانْ \add مَانِي إِزدّغْ\add* ؤُجدْجِيذْ نِّي ث إِڭِّينْ ذ أَجدْجِيذْ، ونِّي زِي إِسّحْقَارْ نتَّا ثَاجَادْجِيثْ \add إِ ذ أَسْ إِجِّيدْجْ\add*، ذ ونِّي زِي يَارْژْ ڒْعَاهْذْ \add إِ كِيذسْ إِڭَّا\add*، \add أَقَا ذِينْ\add* غَارسْ، ذِي ڒْوسْثْ ن بَابِيلْ، أَذْ إِمّثْ!
\v 17 وَارْ إِزمَّارْ فِيرْعُونْ س إِجّْ ن ڒْعسْكَارْ أَمقّْرَانْ ذ إِجّْ ن وڭْرَاوْ إِمْغَارْ أَذْ يڭّْ ؤُڒَا ذ إِشْثْ ن ڒْحَاجّثْ ذِي طّْوعْ نّسْ ذڭْ ؤُمنْغِي، خْمِي غَا سّْڭعّْذنْ إِجّْ ن ڒْحِيضْ ؤُشَا خْمِي غَا بْنَانْ إِجّْ ن وشْبَارْ مَاحنْذْ أَذْ نْغنْ أَطَّاسْ ن إِوْذَانْ. \f ◼ \fr 17:‏17 \ft \bd ’إِوْذَانْ‘\bd* - س ثْعِيبْرَانِيثْ ’ڒعْمُورْ‘.\f*  \x ◘ \xo 17:‏17 \xt 2 إِج. 25‏:‏1؛ إِشا. 29‏:‏3؛ حِز. 4‏:‏2\x*
\v 18 أَقَا إِسّحْقَارْ ثَاجَادْجِيثْ ؤُمِي يَارْژَا ڒْعَاهْذْ إِ خْ إِوْشَا أَفُوسْ نّسْ. \add مِينْزِي\add* نتَّا إِڭَّا مَارَّا مَانْ أَيَا، وَارْ إِتّْرَاكّْوَاڒْ.‘ “
\m 
\v 19 ”س ؤُيَا، أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ’س ثِيذتّْ أَمْ دَّارغْ نشّْ، ثَاجَادْجِيثْ إِ ذ أَيِي \add إِجِّيدْجْ\add* ؤُشَا \add خنِّي\add* إِسّحْقَارْ إِ-ت، ؤُڒَا ذ ڒْعَاهْذْ إِ كِيذِي إِڭَّا ؤُشَا \add خنِّي\add* يَارْژَا إِ-ث، أَذْ ثنْ-إِ-د أَرّغْ خْ ؤُزدْجِيفْ نّسْ!
\v 20 أَذْ خَاسْ بزّْعغْ ثْرَاشَّا إِنُو مَاحنْذْ أَذْ يِيڒِي إِشَارْفْ ذِي ڒْفخْ إِنُو. أَذْ ث أَوْيغْ غَارْ بَابِيلْ ؤُشَا أَذْ خَاسْ شَارّْعغْ ذِينْ زِي سِّيبّثْ ن ڒغْذَارثْ نّسْ إِ زِي ذ أَيِي إِغْذَارْ. \x ◘ \xo 17:‏20 \xt إِرْم. 4‏:‏12؛ 25‏:‏31؛ حِز. 12‏:‏13؛ 32‏:‏3\x*
\v 21 مَارَّا إِنِّي زَّايسْ يَاروْڒنْ \add جْمِيعْ\add* أَكْ-ذ مَارَّا ڒْعسْكَارْ نّسْ، أَذْ وْضَانْ س سِّيفْ، ؤُشَا إِنِّي إِقِّيمنْ أَذْ تّْوَازدْجْعنْ غَارْ مَارَّا ثِيغمُّورَا ن ؤُسمِّيضْ. \add خنِّي\add* كنِّيوْ أَذْ ثسّْنمْ بلِّي نشّْ، سِيذِي، سِّيوْڒغْ.‘ “ \x ◘ \xo 17:‏21 \xt حِز. 5‏:‏10، 12؛ 12‏:‏14؛ 16‏:‏40\x*
\m 
\v 22 ”أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ’نشّْ أَذْ كّْسغْ \add إِجّْ ن ؤُفثْوِي ن\add* ثُوشّنْثْ ن ثْشجَّارْثْ ن ثنْڭلْثْ يُوعْڒَانْ ؤُشَا أَذْ ث ژُّوغْ. زڭْ ؤُزدْجِيفْ أَكْ-ذ ثْسضْوِينْ نّسْ أَذْ قڒْعغْ إِشْثْ ن ثْسطَّا ثَارْهفْ ؤُشَا أَذْ ت ژُّوغْ خْ إِجّْ ن وذْرَارْ يُوعْڒَانْ.
\v 23 أَذْ ت ژُّوغْ خْ وذْرَارْ يُوعْڒَانْ قَاعْ ذِي إِسْرَائِيل. ثَانِيثَا أَذْ ثَاوِي ثِيسضْوِينْ ؤُشَا أَذْ ثَارّْ ڒْغِيدْجثْ، أَذْ ثذْوڒْ ذ ثَاشجَّارْثْ ن ثنْڭلْثْ إِجهْذنْ. عْڒَامْ كُوڒْ إِجْضَاضْ س عْڒَامْ كُوڒْ أَفْرِيونْ أَذْ زذْغنْ سَاذُو نّسْ، \add وَاهْ،\add* ذِي ثِيڒِي نّسْ أَذْ زذْغنْ نِيثْنِي،
\v 24 ؤُشَا أَذْ سّْننْ مَارَّا ثِيشجُّورَا ن ييَّارْ، أَقَا نشّْ، سِيذِي، سّهْوِيغْ ثَاشجَّارْثْ يُوعْڒَانْ ؤُشَا سّْڭعّْذغْ ثَاشجَّارْثْ ثَاقُوضَاضْثْ ؤُ سِّيژْغغْ ثَاشجَّارْثْ ثَازيْزَاثْ ؤُشَا أَرِّيغْ ثَاشجَّارْثْ يُوژْغنْ أَذْ ثْنوَّارْ. نشّْ، سِيذِي، سِّيوْڒغْ ؤُشَا أَذْ ث ڭّغْ.‘ “ \f ◼ \fr 17:‏24 \ft \bd ’ثَاشجَّارْثْ‘\bd* - نِيغْ ’أَدَّاڭْ‘ (’إِدَّاڭنْ‘).\f*
\b
\b
\c 18
\s1 دّنْبْ ن ثْبَابَاثْ ذ ثْممِّيثْ
\m 
\v 1 يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا:
\v 2 ”مِينْ كنِّيوْ يُوغِينْ أَڒَامِي إِ غَا ثِيوْيمْ أَوَاڒْ-أَ غَارْ وُوذمْ ن ثمُّورْثْ ن إِسْرَائِيل ؤُشَا ثقَّارمْ: ’إِبَابَاثنْ شِّينْ أَضِيڒْ أَسمَّاغْ ؤُشَا ثِيغْمَاسْ ن وَارَّاوْ ذوْڒنْثْ حَارشْونْثْ‘؟ \x ◘ \xo 18:‏2 \xt إِرْم. 31‏:‏29\x*
\v 3 س ثِيذتّْ أَمْ دَّارغْ نشّْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي: ’\add ؤُشْثْ خَاومْ\add* مَاڒَاعمَّارْصْ عَاذْ أَذْ ثَاوْيمْ أَوَاڒْ-أَ ذِي إِسْرَائِيل!
\v 4 خْزَارْ، مَارَّا ڒعْمُورْ إِنُو، أَمْ ڒعْمَارْ ن بَابَاسْ ؤُڒَا ذ ڒعْمَارْ ن مِّيسْ إِنُو. ڒعْمَارْ نِّي إِخْضَانْ، أَذْ إِمّثْ.‘ “
\m 
\v 5 ”مَاڒَا شَا ن يِيجّنْ ذ أَمْسڭّذْ \add إِ يدْجَا\add*، إِتّڭّْ ڒْحقّْ ذ مِينْ إِسڭّْذنْ:
\v 6 وَارْ إِتّتّْ \add دّْبَايحْ\add* خْ إِذُورَارْ، وَارْ إِسّْڭِيعِّيذْ ثِيطَّاوِينْ نّسْ غَارْ إِميْضَا \add ن لْ-أَصْنَامْ\add* ن ثَادَّارْثْ ن إِسْرَائِيل، وَارْ إِسّخْمِيجْ ثَامْغَارْثْ ن جَّارْ نّسْ ؤُ وَارْ د-إِتّْقَارِّيبْ غَارْ ثمْغَارْثْ نِّي إِعزّْڒنْ \add ؤُمِي خَاسْ إِذَامّنْ\add*، \x ◘ \xo 18:‏6 \xt لَاوِي 15‏:‏19، 20 ؛ إِشا. 57‏:‏7؛ 65‏:‏7\x*
\v 7 وَارْ إِحصَّارْ ؤُڒَا ذ إِجّْ، إِتَّارَّا-د دِّييّثْ إِ بُو-أَمَارْوَاسْ، وَارْ إِتّْكشَّاضْ، ونِّي إِدْجُوژنْ إِتِّيشْ أَسْ وغْرُومْ نّسْ ؤُ ونِّي ذ أَعَارْيَانْ إِسّْدُّورِي إِ-ث س وَارُّوضْ، \x ◘ \xo 18:‏7 \xt ؤُف. 22‏:‏21، 26؛ لَاوِي 19‏:‏13؛ 25‏:‏14؛ أَعَوذ. 15‏:‏7؛ 24‏:‏12؛ إِشا. 58‏:‏7؛ مت. 25‏:‏3\x*
\v 8 نتَّا وَارْ يَارطّڒْ س أَرِّيبَا نِيغْ أَذْ إِكْسِي أَرْبحْ، أَفُوسْ نّسْ إِتّڭّْوجْ خْ مِينْ وَارْ إِسڭّْذنْ، نتَّا إِحكّمْ نِيشَانْ جَارْ ورْيَازْ ذ إِجّْ ن ورْيَازْ \add نّغْنِي\add*، \x ◘ \xo 18:‏8 \xt ؤُف. 22‏:‏25؛ لَاوِي 25‏:‏35، 36\x*
\v 9 إِڭُّورْ ذِي ثْوصَّا إِنُو ؤُشَا إِحطَّا لْفَارَايِيضْ إِنُو ؤُمِي غَا يڭّْ س ڒَامَانْ، \add خنِّي\add* أَقَا نتَّا ذ أَمْسڭّذْ، أَذْ إِدَّارْ س ثِيذتّْ!‘، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي.
\v 10 مَاڒَا يجّْ-د مِّيسْ ذ أَشفَّارْ، ونِّي إِسِّيزَّاڒنْ إِذَامّنْ ذ ونِّي إِتّڭّنْ إِشْثنْ زِي ثْمسْڒَايِينْ-أَ،
\v 11 \add وَاخَّا\add* نتَّا \add س يِيخفْ نّسْ أَمْ بَابَاسْ\add* وَارْ إِتّڭّْ ثِيمسْڒَايِينْ-أَ، \add مَاشَا\add* مِّيسْ وَانِيثَا إِتّتّْ \add ثِيوْهِيبِينْ\add* خْ إِذُورَارْ، إِسّخْمجْ ثَامْغَارْثْ ن جَّارْ نّسْ،
\v 12 إِحصَّارْ ڒْمسْكِينْ ذ ؤُمزْڒُوضْ، إِتّْكشَّاضْ، وَارْ د-يَارِّي دِّييّثْ، إِسّْڭعَّاذْ ثِيطَّاوِينْ نّسْ غَارْ إِميْضَا ن لْ-أَصْنَامْ، إِتّڭّْ إِشْثْ ن جّْعِيفشْثْ،
\v 13 يَارطّڒْ س أَرِّيبَا، إِتّطّفْ أَرْبحْ، مَا \add خنِّي\add* أَذْ إِقِّيمْ \add مِّيسْ\add* وَانِيثَا إِدَّارْ؟ وَارْ إِتّْغِيمِي إِدَّارْ ؤُمِي إِڭَّا مَارَّا جّْعَايفْ نِّي. أَذْ إِتّْوَانغْ نِيشَانْ، إِذَامّنْ نّسْ أَذْ خَاسْ إِڒِينْ.“
\m 
\v 14 ”خْزَارْ، \add مَاڒَا\add* أَذْ د-يجّْ مِّيسْ نِّي إِتّْوَاڒَا مَارَّا دّْنُوبْ نِّي إِتّڭّْ بَابَاسْ ؤُشَا إِخزَّارْ \add وَاهَا\add* \add أَمْ\add* نتَّا \add س يِيخفْ نّسْ\add* وَارْ إِتّڭّْ ثِيمسْڒَايِينْ نِّي،
\v 15 \add إِخْسْ أَذْ يِينِي\add* وَارْ إِتّتّْ خْ إِذُورَارْ، وَارْ إِسّْڭِيعِّيذْ ثِيطَّاوِينْ نّسْ غَارْ إِميْضَا \add ن لْ-أَصْنَامْ\add* ن ثَادَّارْثْ ن إِسْرَائِيل، وَارْ إِسّخْمِيجْ ثَامْغَارْثْ ن جَّارْ نّسْ،
\v 16 وَارْ إِحصَّارْ ؤُڒَا ذ إِجّْ، وَارْ إِمنّعْ دِّييّثْ، وَارْ إِتّْكشَّاضْ، إِتِّيشْ أَغْرُومْ نّسْ إِ ونِّي إِدْجُوژنْ، إِسّْذُورُّويْ إِ ؤُعَارْيَانْ س وَارُّوضْ،
\v 17 إِتَّاڭّْوجْ س ؤُفُوسْ نّسْ خْ ؤُمزْڒُوضْ، وَارْ إِكسِّي أَرِّيبَا ذ وَارْبحْ، إِتّڭّْ س ثْسڭْذَا ؤُشَا إِحطَّا ثِيوصَّا إِنُو، أَقَا مِّيسْ وَانِيثَا وَارْ إِتّْمتِّي زِي سِّيبّثْ ن ڒْمُوعْصِييّثْ ن بَابَاسْ، أَذْ إِدَّارْ س ثِيذتّْ.
\v 18 بَابَاسْ أَذْ إِمّثْ ذِي ڒْمُوعْصِييّثْ نّسْ، خْ ؤُمِي إِڭَّا بزّزْ \add خْ إِوْذَانْ\add* س ڒخْشُونثْ، إِكشّضْ أَڭْڒَا ؤُشَا إِڭَّا مِينْ وَارْ إِحْڒِينْ ذِي ڒْوسْطْ ن ڒْڭنْسْ نّسْ.“
\m 
\v 19 ”\add مَاشَا\add* كنِّيوْ ثقَّارمْ: ’مَايمِّي مِّيسْ وَارْ إِكسِّي ڒْمُوعْصِييّثْ ن بَابَاسْ؟ \add مِينْزِي\add* مِّيسْ ثُوغَا إِتّڭّْ ڒْحقّْ ذ ثْسڭْذَا ؤُشَا إِحْضَا مَارَّا ثِيوصَّا إِنُو ؤُشَا إِڭَّا إِ-ثنْثْ، نتَّا أَذْ إِقِّيمْ إِدَّارْ س ثِيذتّْ. \x ◘ \xo 18:‏19 \xt أَعَوذ. 24‏:‏16؛ 2 إِج. 14‏:‏6؛ 2 إِم. 25‏:‏4\x*
\v 20 ڒعْمَارْ نِّي إِخْضَانْ، أَذْ إِمّثْ. مِّيسْ وَارْ إِكسِّي شَا ڒْمُوعْصِييّثْ ن بَابَاسْ ؤُشَا بَابَاسْ وَارْ إِكسِّي شَا ڒْمُوعْصِييّثْ ن مِّيسْ. ثَاسڭْذَا ن ؤُمْسڭّذْ أَذْ ثِيڒِي خْ يِيخفْ نّسْ ؤُ ثُوعفّْنَا ن ؤُعفَّانْ أَذْ ثِيڒِي خْ يِيخفْ نّسْ.
\v 21 \add مَاشَا\add* مَاڒَا أَعفَّانْ إِذْوڒْ-د زِي دّْنُوبْ نِّي إِڭَّا، أَذْ إِحْضَا مَارَّا ثِيوصَّا إِنُو ؤُشَا أَذْ يڭّْ ڒْحقّْ ذ ثْسڭْذَا، \add خنِّي\add* أَذْ إِقِّيمْ إِدَّارْ س ثِيذتّْ، وَارْ إِتّْمتِّي شَا.
\v 22 مَارَّا إِعذِّيينْ نّسْ نِّي إِڭَّا، وَارْ ذ أَسْ تّْوَاحسّْبنْ شَا. س ثْسڭْذَا نّسْ نِّي إِڭَّا، أَذْ إِدَّارْ.
\v 23 مَا أَذْ أَرْضِيغْ س ثِيذتّْ ڒْموْثْ ن إِعفَّاننْ؟‘، إِقَّارْ سِيذِي إِنُو، سِيذِي. ’مَا نتَّا وَارْ \add إِتّْغِيمِي\add* إِدَّارْ خْمِي د غَا إِذْوڒْ؟ \x ◘ \xo 18:‏23 \xt حِز. 33‏:‏11\x*
\v 24 \add مَاشَا\add* مَاڒَا أَمْسڭّذْ إِحيّذْ خْ ثْسڭْذَا نّسْ ؤُشَا أَذْ إِڭّْ دّدْجْ عْلَاحْسَابْ مَارَّا جّْعَايفْ نِّي إِتّڭّْ ؤُعفَّانْ، أَذْ إِڭّْ \add أَمنِّي\add* ؤُڒَا ذ نتَّا، مَا \add خنِّي\add* أَذْ إِقِّيمْ إِدَّارْ؟ وَارْ ثتّْوَاعْقِيڒْ \add عَاذْ\add* مَارَّا ثَاسڭْذَا نِّي إِڭَّا. س ڒغْذَارثْ نّسْ إِ زِي إِغْذَارْ ؤُ س دّْنُوبْ نّسْ إِ زِي إِدّنْبْ، س يِينَا أَذْ إِمّثْ.‘ “
\m 
\v 25 ”ثقَّارمْ \add عَاوذْ\add*: ’أَبْرِيذْ ن سِيذِي وَارْ إِدْجِي شَا نِيشَانْ!‘. سْڒمْ، \add أَ\add* ثَادَّارْثْ ن إِسْرَائِيل، مَا أَبْرِيذْ إِنُو وَارْ إِدْجِي نِيشَانْ؟ مَا وَارْ دْجِينْ \add س ثِيذتّْ\add* أَقَا إِبْرِيذنْ نْومْ وَارْ سڭّْمنْ؟ \x ◘ \xo 18:‏25 \xt حِز. 33‏:‏17، 20\x*
\v 26 مَاڒَا إِحيّذْ ؤُمْسڭّذْ خْ ثْسڭْذَا نّسْ ؤُشَا إِتّڭّْ دّدْجْ ؤُ س مَانْ أَيَا أَذْ إِمّثْ، \add خنِّي\add* أَذْ إِمّثْ ذِي دّدْجْ نّسْ نِّي إِڭَّا.
\v 27 \add مَاشَا\add* مَاڒَا إِذْوڒْ-د ؤُعفَّانْ زِي ثْمڭَّا نّسْ ثِيعفَّانِينْ نِّي إِڭَّا ؤُشَا أَذْ إِڭّْ ڒْحقّْ ذ ثْسڭْذَا، \add خنِّي\add* أَذْ يَارّْ ڒعْمَارْ نّسْ أَذْ إِقِّيمْ إِدَّارْ.
\v 28 إِذْوڒْ إِتّْوَاڒَا ؤُشَا إِذْوڒْ-د زِي مَارَّا إِعذِّيينْ نّسْ نِّي إِڭَّا. أَذْ إِدَّارْ س ثِيذتّْ، وَارْ إِتّْمتِّي شَا.
\v 29 إِنِّي زِي ثَادَّارْثْ ن إِسْرَائِيل يَارنَّانْ قَّارنْ: ’أَبْرِيذْ ن سِيذِي وَارْ إِسڭّمْ!‘ مَا إِبْرِيذنْ إِنُو وَارْ سڭّْمنْ، \add أَ\add* ثَادَّارْثْ ن إِسْرَائِيل؟ \add ذ ثِيذتّْ\add* مَا وَارْ دْجِينْ إِبْرِيذنْ نْومْ وَارْ سڭّْمنْ؟“
\v 30 ”س ؤُيَا نشّْ أَذْ خَاومْ شَارّْعغْ، \add أَ\add* ثَادَّارْثْ ن إِسْرَائِيل، كُوڒْ إِجّْ أَنشْثْ إِبْرِيذنْ نّسْ، إِقَّارْ سِيذِي إِنُو، سِيذِي.عقْبمْ، ذوْڒمْ-د زِي مَارَّا إِعذِّيينْ نْومْ، \add خنِّي\add* وَارْ ثتِّيڒِي ڒْمُوعْصِييّثْ نْومْ ذ ثَاعنْكْرِيفْثْ إِ د-يِيوْينْ ڒْمُوعْصِييّثْ إِ كنِّيوْ. \x ◘ \xo 18:‏30 \xt مت. 3‏:‏2\x*
\v 31 نْضَارمْ ڒْمُوعْصِييّثْ نْومْ إِ زِي ثْعدَّامْ. ڭّمْ ؤُڒْ \add نْومْ\add* ذ أَمَايْنُو ؤُ بُوحْبڒْ \add نْومْ\add* ذ أَمَايْنُو. مَاغَارْ إِ غَا ثمّْثمْ، \add أَ\add* ثَادَّارْثْ ن إِسْرَائِيل؟ \x ◘ \xo 18:‏31 \xt إِرْم. 32‏:‏39؛ حِز. 11‏:‏19؛ 36‏:‏26\x*
\v 32 مِينْزِي نشّْ وَارْ أَرْضِيغْ ذِي ڒْموْثْ ن ونِّي إِتّْخصَّا أَذْ إِمُّوثْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي، ذوْڒمْ-د ؤُشَا دَّارمْ.“ \x ◘ \xo 18:‏32 \xt حِز. 33‏:‏11\x*
\b
\b
\c 19
\s1 إِزْڒِي ن وشْضَانْ خْ ڒْحُوكَّامْ ن إِسْرَائِيل
\m 
\v 1 ”شكْ \add خنِّي\add*، سْڭعّذْ إِجّْ ن يژْرِي ن وشْضَانْ
\m خْ ڒْحُوكَّامْ ن إِسْرَائِيل
\v 2 ؤُشَا إِنِي:
\b
\m \qt ’مَامّشْ ثُوغَا ثزّڒْ يمَّاثْومْ\qt*
\m \qt أَمْ ثيْرَاذْثْ ثزّڒْ جَارْ ثيْرَاذِينْ!\qt*
\m \qt ثسّْيمْ إِمژْيَاننْ نّسْ\qt*
\m \qt جَارْ وَايْرَاذنْ إِمژْيَاننْ!\qt*
\m 
\v 3 \qt نتَّاثْ ثسْيمْ إِجّْ زڭْ إِمژْيَاننْ نّسْ.\qt*
\m \qt وَانِيثَا إِذْوڒْ ذ أَيْرَاذْ أَمژْيَانْ،\qt*
\m \qt إِڒْمذْ أَذْ إِشَارّڭْ ثَايْمَارْثْ نّسْ،\qt*
\m \qt \tl عَاذْ\tl* إِوْذَانْ إِشَّا إِ-ثنْ\qt*.
\m 
\v 4 \qt \tl ڒَْامِي\tl* سْڒِينْ ڒڭْنُوسْ مَانْ أَيَا،\qt*
\m \qt حبّْسنْ ث ذڭْ \tl وحْفُورْ ن\tl* ثُورْصُوضِي نْسنْ،\qt*
\m \qt ؤُشَا إِوْينْ ث س ثْسنَّارِينْ \tl ذڭْ ونْزَارْ نّسْ\tl*\qt*
\m \qt غَارْ ثمُّورْثْ ن مِيصْرَا.‘\qt* \x ◘ \xo 19:‏4 \xt 2 إِج. 23‏:‏33؛ إِرْم. 22‏:‏11\x*
\b
\m 
\v 5 \qt ’\tl ؤُمِي\tl* ثژْرَا أَقَا ڒَايَاسْ نّسْ إِرُوحْ، إِبْضڒْ،\qt*
\m \qt \tl خنِّي\tl* ثكْسِي إِجّنْ زڭْ إِمژْيَاننْ نّسْ،\qt*
\m \qt ؤُشَا إِڭَّا إِ-ث ذ أَيْرَاذْ أَمژْيَانْ.\qt*
\m 
\v 6 \qt وَانِيثَا ثُوغَا إِڭُّورْ جَارْ وَايْرَاذنْ،\qt*
\m \qt ؤُشَا إِذْوڒْ ذ أَيْرَاذْ ذ أَمژْيَانْ،\qt*
\m \qt إِڒْمذْ أَذْ إِشَارّڭْ ثَايْمَارْثْ نّسْ،\qt*
\m \qt \tl عَاذْ\tl* إِوْذَانْ إِشَّا إِ-ثنْ.\qt*
\m 
\v 7 \qt نتَّا إِغْصبْ ثِيجَّاڒْ نْسنْ،\qt*
\m \qt يَاردّدْجْ ثِيندَّامْ نْسنْ،\qt*
\m \qt أَڒَامِي ثْسُوسمْ ثمُّورْثْ ذ مَارَّا مِينْ ذَايسْ\qt*
\m \qt زِي سِّيبّثْ ن ڒْحسّْ ن ؤُزهَّارْ نّسْ.\qt*
\m 
\v 8 \qt \tl خنِّي\tl* سّْبدّنْ خَاسْ ڒڭْنُوسْ\qt*
\m \qt زِي ثمُّورَا إِ ذ أَسْ د-إِنّْضنْ\qt*
\m \qt ؤُشَا بزّْعنْ خَاسْ ثْرَاشَّا نْسنْ،\qt*
\m \qt طّْفنْ ث ذڭْ \tl وحْفُورْ نْسنْ ن\tl* ثُورْصُوضِي.\qt*
\m 
\v 9 \qt نِيثْنِي بلّْعنْ خَاسْ ذڭْ إِجّْ ن ڒقْفزْ\qt*
\m \qt س ثْسنَّارِينْ \tl ذڭْ ونْزَارنْ نّسْ\tl*،\qt*
\m \qt حِيمَا أَذْ ث أَوْينْ غَارْ ؤُجدْجِيذْ ن بَابِيلْ.\qt*
\m \qt نِيثْنِي إِوْينْ ث ذِي لْقلْعَاثْ،\qt*
\m \qt أَڒَامِي وَارْ إِتّْوَاسڒْ \tl عَاذْ\tl* ثْمِيجَّا نّسْ\qt*
\m \qt خْ إِذُورَارْ ن إِسْرَائِيل.‘\qt* \x ◘ \xo 19:‏9 \xt 2 إِم. 36‏:‏6\x*
\b
\m 
\v 10 \qt ’ثُوغَا يمَّاشْ أَمْ ثْزَايَارْثْ\qt*
\m \qt ذِي ڒْوقْثْ ن أَرَّاحثْ نّشْ،\qt*
\m \qt ثتّْوَاژُّو غَارْ وَامَانْ أَطَّاسْ.\qt*
\m \qt ثُوغَا س ڒْغِيدْجثْ ؤُ س وَاطَّاسْ ن ثْسضْوِينْ،\qt*
\m \qt زِي سِّيبّثْ ن وَاطَّاسْ ن وَامَانْ.\qt*
\m 
\v 11 \qt ثُوغَا غَارسْ ثِيسضْوِينْ إِجهْذنْ\qt*
\m \qt أَمْ إِزدْجَاضْ ن ڒْحُوكَّامْ.\qt*
\m \qt ثْرُونْكُو \tl ن يِيجّنْ\tl* زَّايسْ\qt*
\m \qt إِڭعّذْ جَارْ إِسيْنُوثنْ،\qt*
\m \qt ؤُشَا س ڒُوعْڒَا نّسْ إِتّْوَاژَارْ نِيشَانْ،\qt*
\m \qt س وَاطَّاسْ ن ڒفْرُوعْ نّسْ.\qt*
\m 
\v 12 \qt \tl مَاشَا ثَازَايَارْثْ\tl* ثتّْوَاقْڒعْ\qt*
\m \qt س \tl إِجّْ ن ؤُذُوقّزْ ن\tl* وسْعَارْ،\qt*
\m \qt ثمّنْضَارْ غَارْ ثمُّورْثْ،\qt*
\m \qt ؤُشَا أَسمِّيضْ زِي شَّارْقْ يُوژغْ ڒْغِيدْجثْ نّسْ.\qt*
\m \qt أَرْژنْ ؤُشَا ؤُژْغنْ ڒفْرُوعْ نّسْ إِجهْذنْ،\qt*
\m \qt ثِيمسِّي ثشَّا إِ-ثنْ.\qt*
\m 
\v 13 \qt ڒخُّو ژُّونْ ث ذِي  ڒخْڒَا،\qt*
\m \qt ذڭْ إِشْثْ ن ثمُّورْثْ يُوژْغنْ ذ إِفُّوذنْ.\qt*
\m 
\v 14 \qt ثفّغْ-د ثْمسِّي زڭْ إِشْثْ ن ثْسطَّا\qt*
\m \qt زِي جَارْ ثْزرْمِينْ نّسْ،\qt*
\m \qt ثشَّا ڒْغِيدْجثْ نّسْ،\qt*
\m \qt أَڒَامِي وَارْ غَارسْ ثقِّيمْ عَاذْ ثْسطَّا إِجهْذنْ\qt*
\m \qt \tl ؤُڒَا ذ\tl* أَزدْجَاضْ مَاحنْذْ أَذْ إِحْكمْ.‘ “\qt*
\b
\m وَا ذ إِجّْ ن يژْرِي ن وشْضَانْ ؤُشَا أَذْ إِذْوڒْ ذ إِجّْ ن يژْرِي ن وشْضَانْ \add س ثِيذتّْ\add*.
\b
\b
\c 20
\s1 أَغوّغْ ن إِسْرَائِيل
\m 
\v 1 \bd ذڭْ ؤُسڭّْوَاسْ وِيسّْ سبْعَا، ذڭْ ؤُيُورْ وِيسّْ خمْسَا، ذڭْ \bdit وَاسّْ\bdit* وِيسّْعشْرَا ن ؤُيُورْ\bd* إِمْسَارْ بلِّي ؤُسِينْ-د \bd إِرْيَازنْ زڭْ إِمْغَارنْ ن إِسْرَائِيل\bd*، مَاحنْذْ أَذْ سّقْسَانْ سِيذِي، ؤُشَا قِّيمنْ زَّاثِي.
\v 2 يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا:
\v 3 ”\add أَ\add* مِّيسْ ن بْنَاذمْ، سِيوڒْ أَكْ-ذ إِمْغَارنْ ن إِسْرَائِيل، ؤُشَا إِنِي أَسنْ: ’أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: مَا ثُوسِيمْ-د مَاحنْذْ أَذْ أَيِي ثسّقْسَامْ؟ س ثِيذتّْ أَمْ دَّارغْ نشّْ، وَارْ كنِّيوْ تّجِّيغْ أَذْ كِيذِي ثمْشَاوَارنْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي.
\v 4 ’مَا ثخْسذْ أَذْ خَاسنْ ثْحكْمذْ، مَا ثخْسذْ أَذْ \add خَاسنْ\add* ثْحكْمذْ، \add أَ\add* مِّيسْ ن بْنَاذمْ؟ سْشنْ أَسنْ جّْعَايفْ ن ڒجْذُوذْ نْسنْ \x ◘ \xo 20:‏4 \xt حِز. 22‏:‏2؛ 23‏:‏36\x*
\v 5 ؤُشَا إِنِي أَسنْ: أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ذڭْ وَاسّْ نِّي ذِي إِخْضَارغْ إِسْرَائِيل، سّْڭعّْذغْ نشّْ أَفُوسْ إِنُو، \add جُّودْجغْ\add* إِ زَّارِيعثْ ن ثَادَّارْثْ ن يَاعْقُوبْ ؤُشَا سّشْنغْ إِخفْ نّسْ غَارْسنْ ذِي ثمُّورْثْ ن مِيصْرَا. نشّْ سّْڭعّْذغْ أَفُوسْ إِنُو ذِي طّْوعْ نْسنْ، نِّيغْ: نشّْ ذ سِيذِي، أَربِّي نْومْ. \x ◘ \xo 20:‏5 \xt ؤُف. 3‏:‏8؛ 4‏:‏31؛ 6‏:‏7 \x*
\v 6 \bd ذڭْ وَاسّْ نِّي\bd* سّْڭعّْذغْ أَسنْ أَفُوسْ إِنُو \add جُّودْجغْ،\add* مَاحنْذْ أَذْ ثنْ سُّوفّْغغْ زِي ثمُّورْثْ ن مِيصْرَا غَارْ ثمُّورْثْ نِّي إِخْضَارغْ نشّْ إِ نِيثْنِي، \add ثَامُّورْثْ\add* إِفيّْضنْ س ؤُغِي ذ ثَامّنْثْ، أَقَا-ت ذ ثَالْوِيزْثْ ن مَارَّا ثِيمُّورَا.
\v 7 نِّيغْ أَسنْ: أجّْ كُوڒْ إِجّْ أَذْ إِمّنْضَارْ نّْعَاوَاثْ نّسْ ن لْ-أَصْنَامْ زَّاثْ إِ ثِيطَّاوِينْ نّسْ، إِتّْخصَّا وَارْ سّْخمِّيجنْ نِيثْنِي إِخفْ نْومْ س إِميْضَا ن لْ-أَصْنَامْ ن مِيصْرَا، نشّْ ذ سِيذِي، أَربِّي نْومْ.‘ “
\m 
\v 8 ”\add مَاشَا\add* نِيثْنِيغوّْغنْ خَافِي ؤُشَا وَارْ خِيسنْ أَذْ غَارِي د-سْڒنْ. وَارْ نْضَارنْ نّْعَاوَاثْ نْسنْ ن لْ-أَصْنَامْ زَّاثْ إِ ثِيطَّاوِينْ نْسنْ \add ؤُ\add* وَارْ جِّينْ إِميْضَا نْسنْ ن لْ-أَصْنَامْ \add نِّي د-إِوْينْ\add* زِي مِيصْرَا. \add خنِّي\add* نِّيغْ أَذْ خَاسنْ زدْجْعغْ أَسْعَارْ إِنُو مَاحنْذْ أَذْ خَاسنْ كمّْڒغْ لْغَاضَابْ إِنُو ذِي ڒْوسْطْ ن ثمُّورْثْ ن مِيصْرَا.
\v 9 نشّْ ڭِّيغْ ث ذِي طّْوعْ ن يِيسمْ إِنُو أَڒَامِي وَانِيثَا وَارْ إِتّْوَاسّفْسَاذْ زَّاثْ إِ ثِيطَّاوِينْ ن ڒڭْنُوسْ نِّي ثُوغَا زدّْغنْ جَارْ أَسنْ، إِ ؤُمِي سشْنغْ إِخفْ إِنُو زَّاثْ إِ ثِيطَّاوِينْ نْسنْ خْمِي ثنْ سُّوفّْغغْ زِي ثمُّورْثْ ن مِيصْرَا.
\v 10 سُّوفّْغغْ ثنْ-د زِي ثمُّورْثْ ن مِيصْرَا ؤُشَا نذْهغْ ثنْ غَارْ ڒخْڒَا. \x ◘ \xo 20:‏10 \xt ؤُف. 13‏:‏18\x*
\v 11 وْشِيغْ أَسنْ ثِيوصَّا إِنُو ؤُشَا سَّارْڭْبغْ ثنْ خْ لْفَارَايِيضْ  إِنُو إِ زِي غَا إِدَّارْ بْنَاذمْ نِّي زَّايْسنْثْ إِ غَا يڭّْ. \x ◘ \xo 20:‏11 \xt لَاوِي 18‏:‏5؛ أَعَوذ. 30‏:‏15، 16، 19، 20؛ رُوم. 10‏:‏5؛ ڭال. 3‏:‏12\x*
\v 12 وْشِيغْ أَسنْ عَاوذْ ؤُسَّانْ إِنُو ن سّبْثْ مَاحنْذْ أَذْ إِڒِينْ ذ ڒعْڒَامثْ جَارْ أَيِي ذ نِيثْنِي، حِيمَا أَذْ سّْننْ، أَقَا نشّْ ذ سِيذِي ونِّي ثنْ إِسّْقدّْسنْ. \x ◘ \xo 20:‏12 \xt ؤُف. 20‏:‏8؛ 31‏:‏13‏-‏17؛ 35‏:‏2\x*
\v 13 \add مَاشَا\add* ثَادَّارْثْ ن إِسْرَائِيل ثْغوّغْ خَافِي ذِي ڒخْڒَا. نِيثْنِي وَارْ ؤُيُورنْ شَا عْلَاحْسَابْ ثِيوصَّا إِنُو ؤُشَا مّنْضَارنْ لْفَارَايِيضْ إِنُو إِ زِي غَا إِدَّارْ بْنَاذنْ نِّي ثنْثْ إِڭِّينْ ؤُشَا نِيثْنِي سّْعِيدْجْثنْ ؤُسَّانْ ن سّبْثْ إِنُو أَڒَامِي نِّيغْ ثُوغَا خْسغْ أَذْ خَاسنْ فَارّْغغْ أَسْعَارْ إِنُو ذِي ڒخْڒَا حِيمَا أَذْ خَاسنْ قْضِيغْ. \x ◘ \xo 20:‏13 \xt ؤُف. 16‏:‏28\x*
\v 14 \add مَاشَا\add* نشّْ ڭِّيغْ ث ذِي طّْوعْ ن يِيسمْ إِنُو، حِيمَا وَانِيثَا وَارْ إِتّْوَاسّْعِيدْجِيثْ شَا زَّاثْ إِ ثِيطَّاوِينْ ن ڒڭْنُوسْ نِّي ثُوغَا إِتّْوَاڒِينْ ؤُمِي سُّوفّْغغْ \add ثَادَّارْثْ ن إِسْرَائِيل\add* زِي \add مِيصْرَا\add*.
\v 15 نشّْ سّْڭعّْذغْ أَفُوسْ إِنُو ضِيدّْ نْسنْ ذِي ڒخْڒَا \add ؤُشَا جُّودْجغْ\add* أَقَا وَارْ ثنْ تَّاوْيغْ غَارْ ثمُّورْثْ نِّي ذ أَسنْ وْشِيغْ، ثَامُّورْثْ إِفيّْضنْ س ؤُغِي ذ ثَامّنْثْ، ثنِّي يدْجَانْ ذ ثَالْوِيزْثْ ن مَارَّا ثِيمُّورَا،
\v 16 مِينْزِي نِيثْنِي نْضَارنْ لْفَارَايِيضْ  إِنُو، وَارْ ؤُيُورنْ ذِي ثْوصَّا إِنُو ؤُ سّْعِيدْجْثنْ ؤُسَّانْ إِنُو ن سّبْثْ، مَاغَارْ ؤُڒْ نْسنْ إِضْفَارْ إِميْضَا نْسنْ ن لْ-أَصْنَامْ.
\v 17 \add مَاشَا\add* سمْحغْ أَسنْ ذِي ثِيطَّاوِينْ إِنُو أَڒَامِي نشّْ وَارْ ثنْ أَردّْدْجغْ ؤُ وَارْ خَاسنْ قْضِيغْ ذِي ڒخْڒَا.“
\m 
\v 18 ”نشّْ نِّيغْ إِ إِحنْجِيرنْ نْسنْ ذِي ڒخْڒَا: ’وَارْ ڭُّورمْ ذِي ثْوصَّا ن ڒجْذُوذْ نْومْ، وَارْ تّطّْفمْ ذِي لْفَارَايِيضْ نْسنْ ؤُ وَارْ سّْخمِّيجمْ إِخفْ نْومْ س إِميْضَا نْسنْ ن لْ-أَصْنَامْ.
\v 19 نشّْ ذ سِيذِي، أَربِّي نْومْ! ؤُيُورمْ ذِي ثْوصَّا إِنُو ؤُ حْضَامْ لْفَارَايِيضْ إِنُو ؤُشَا ڭّمْ زَّايْسنْثْ.
\v 20 سْقدّْسمْ ؤُسَّانْ إِنُو ن سّبْثْ، \add مَاحنْذْ\add* أَذْ إِڒِينْ ذ ڒعْڒَامثْ جَارْ أَيِي ذ كنِّيوْ، حِيمَا أَذْ ثسّْنمْ بلِّي نشّْ ذ سِيذِي، أَربِّي نْومْ.‘
\v 21 \add مَاشَا\add* عَاذْ أَرَّاوْ \add نْسنْ\add*غوّْغنْ خَافِي: وَارْ ڭُّورنْ ذِي ثْوصَّا إِنُو ؤُ وَارْ حْضِينْ لْفَارَايِيضْ  إِنُو مَاحنْذْ أَذْ ذَايْسنْثْ ؤُيُورنْ، مِينْ زِي بْنَاذمْ نِّي ثنْثْ إِتّڭّنْ أَذْ زَّايْسنْثْ إِدَّارْ. نِيثْنِي سّْعِيدْجْثنْ ؤُسَّانْ إِنُو ن سّبْثْ \add أَڒَامِي\add* نِّيغْ، أَذْ خَاسنْ فَارّْغغْ أَسْعَارْ إِنُو، مَاحنْذْ أَذْ أَسنْ كمّْڒغْ \add أَمُّو\add* أَغْضَابْ إِنُو ذِي ڒخْڒَا.
\v 22 نشّْ أَرِّيغْ-د أَفُوسْ إِنُو \add إِ ثُوغَا إِسّْوِيژّْضنْ ضِيدّْ نْسنْ\add*. ڭِّيغْ ث ذِي طّْوعْ ن يِيسمْ إِنُو، حِيمَا وَارْ إِتّْوَاسّخْمِيجْ \add إِسمْ إِنُو\add* زَّاثْ إِ ثِيطَّاوِينْ نْ ڒڭْنُوسْ، \add مَاغَارْ\add* زَّاثْ إِ ثِيطَّاوِينْ نْسنْ سُّوفّْغغْ ثنْ-د زِي مِيصْرَا.
\v 23 \add عَاوذْ\add* سّْڭعّْذغْ أَفُوسْ إِنُو ذِي ڒخْڒَا، \add جُّودْجغْ\add* أَذْ ثنْ بزّْعغْ جَارْ ڒڭْنُوسْ ؤُ أَذْ ثنْ زُوزَّارغْ ذِي ثمُّورَا،
\v 24 مِينْزِي وَارْ ڭُّورنْ ذِي لْفَارَايِيضْ  إِنُو، \add مَاشَا\add* نْضَارنْ ثِيوصَّا إِنُو ؤُ سّْعِيدْجْثنْ ؤُسَّانْ إِنُو ن سّبْثْ، ؤُ \add مِينْزِي\add* ثِيطَّاوِينْ نْسنْ ضفَّارنْثْ أَوَارْنِي إِ إِميْضَا ن لْ-أَصْنَامْ ن ڒجْذُوذْ نْسنْ.
\v 25 \add خنِّي\add* نشّْ وْشِيغْ أَسنْ ثِيوصَّا وَارْ إِحْڒِينْ ذ لْفَارَايِيضْ إِ زِي وَارْ زمَّارنْ نِيثْنِي أَذْ دَّارنْ.
\v 26 نشّْ سّْخمْجغْ ثنْ س ثوْهِيبِينْ نْسنْ ؤُمِي نِيثْنِي أَرِّينْ مَارَّا مِينْ يَارزْمنْ ڒمْڒَاوثْ \add ذ أَمزْوَارُو\add* أَذْ يكّْ ثِيمسِّي، \add ڭِّيغْ ت\add* حِيمَا أَذْ ثنْ ثحِّيغْ أَڒَامِي غَا سّْننْ أَقَا نشّْ ذ سِيذِي.“\x ◘ \xo 20:‏26 \xt حِز. 16‏:‏21\x*
\m 
\v 27 ”س ؤُيَا، \add أَ\add* مِّيسْ ن بْنَاذمْ، سِيوڒْ أَكْ-ذ ثَادَّارْثْ ن إِسْرَائِيل، إِنِي أَسنْ: ’أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ؤُڒَا س مَانْ أَيَا ثُوغَا ڒجْذُوذْ نْومْ تّْشقَّافنْ ذَايِي ؤُمِي ثُوغَا ذَايِيغدَّارنْ أَطَّاسْ.
\v 28 \add ڒَْامِي\add* ثنْ سِّيذْفغْ ذِي ثمُّورْثْ ثنِّي خْ سّْڭعّْذغْ أَفُوسْ إِنُو مَاحنْذْ أَذْ ثنْ ت وْشغْ، خزَّارنْ نِيثْنِي غَارْ كُوڒْ ثَاوْرِيرْثْ يُوعْڒَانْ ؤُ غَارْ وزْغَارْ إِمْشُوبّْشنْ ؤُشَا إِوْينْ ذِينْ ثِيغَارْصَا نْسنْ ؤُ قدّْمنْ ذِينْ ثِيوْهِيبِينْ نْسنْ \add إِ ذ أَيِي\add* سْعَارنْثْ، ؤُ قّذْمنْ ذِينْ أَرِّيحثْ نْسنْ إِتّْفُوحنْ ؤُ سيّْبنْ ذِينْ ثِيوْهِيبِينْ نْسنْ ن ؤُسيّبْ.
\v 29 \add خنِّي\add* نِّيغْ أَسنْ: ’مَانْ ڒْڭعّْذثْ نِّي غَارْ غَا ثْرَاحمْ؟ إِسمْ نّسْ ’بَامَاهْ‘، \add إِخْسْ أَذْ يِينِي ’ڒْڭعّْذثْ‘\add*، أَڒْ أَسّْ-أَ.‘ “
\m 
\v 30 ”س ؤُيَا، إِنِي إِ ثَادَّارْثْ ن إِسْرَائِيل: ’أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: مَا \add وَارْ\add* ثسّْخمِّيجمْ كنِّيوْ إِخفْ نْومْ خْ سِيمَانْثْ ن وبْرِيذْ ن ڒجْذُوذْ نْومْ ؤُ \add وَارْ\add* ثسّفْسِيذمْ ؤُڒَا ذ كنِّيوْ إِخفْ نْومْ أَمْ ثْضفَّارَامْ نّْعَاوَاثْ نْسنْ ن لْ-أَصْنَامْ؟
\v 31 أَمْ ثسّْڭعَّاذمْ ثِيوْهِيبِينْ نْومْ، ثسّكَّامْ إِحنْجِيرنْ نْومْ خْ ثْمسِّي ؤُ ثسّْخمَّاجمْ إِخفْ نْومْ س إِميْضَا نْومْ ن لْ-أَصْنَامْ أَڒْ أَسّْ-أَ؟ مَا نشّْ \add خنِّي\add* أَذْ كنِّيوْ جّغْ أَذْ أَيِي ثسّقْسَامْ، \add أَ\add* ثَادَّارْثْ ن إِسْرَائِيل؟ س ثِيذتّْ أَمْ دَّارغْ نشّْ، إِقَّارْ سِيذِي إِنُو، سِيذِي، نشّْ وَارْ تِّيجِّيغْ كنِّيوْ أَذْ أَيِي ثسّقْسَامْ!
\v 32 مِينْ د-إِڭعّْذنْ ذِي بُوحْبڒْ نْومْ، وَارْ إِتِّيڒِي، مِينْ ثقَّارمْ كنِّيوْ: نشِّينْ أَذْ نِيڒِي أَمْ ڒڭْنُوسْ ؤُ أَمْ ڒَادْجَاثْ ن ثمُّورَا ؤُمِي غَا نعْبذْ \add صَّانَامْ\add* ن ؤُكشُّوضْ ذ وژْرُو.
\v 33 س ثِيذتّْ أَمْ دَّارغْ نشّْ، إِقَّارْ سِيذِي إِنُو، سِيذِي: نشّْ أَذْ خَاومْ صلّْطغْ س ؤُفُوسْ إِجهْذنْ ؤُ س ؤُغِيڒْ إِسّْوِيژّْضنْ ؤُ س ؤُفَارّغْ ن وسْعَارْ \add إِنُو\add*!
\v 34 مَاغَارْ نشّْ أَذْ كنِّيوْ سُّوفّْغغْ زِي ڒڭْنُوسْ ؤُشَا أَذْ كنِّيوْ سّْمُونغْ زِي ثمُّورَا مَانِي ذِي ثتّْوَابزّْعمْ كنِّيوْ، س ؤُفُوسْ إِجهْذنْ ذ ؤُغِيڒْ  إِسّْوِيژَّاضنْ ؤُ س ؤُفَارّغْ ن وسْعَارْ \add إِنُو\add*.
\v 35 أَذْ كنِّيوْ أَوْيغْ غَارْ ڒخْڒَا ن ڒڭْنُوسْ، ؤُشَا ذِينْ أَذْ كنِّيوْ شَارّْعغْ، ؤُذمْ ذ ؤُذمْ.
\v 36 أَمْ مَامّشْ حكْمغْ خْ ڒجْذُوذْ نْومْ ذِي ڒخْڒَا ن ثمُّورْثْ ن مِيصْرَا، أَمُّو إِ خَاومْ غَا حكْمغْ، إِقَّارْ سِيذِي إِنُو، سِيذِي.
\v 37 أَذْ كنِّيوْ سّكّغْ سَاذُو ؤُزدْجَاذْ \add ن ؤُمكْسَاوْ\add* ؤُشَا أَذْ كنِّيوْ سِّيذْفغْ ذِي تَّارْبِييّثْ ن ڒْعَاهْذْ. \x ◘ \xo 20:‏37 \xt حِز. 34\x*
\v 38 نشّْ أَذْ زَّايْومْ زُوزَّارغْ إِمْغوَّاغنْ ذ يِينِّي خَافِي إِتّْعدَّانْ. نشّْ أَذْ ثنْ سُّوفّْغغْ زِي ثمُّورْثْ ن ڒْغُوبِّييثْ نْسنْ مَانِي زدّْغنْ أَمْ يِيبَارَّانِييّنْ، \add مَاشَا\add* وَارْ د-تِّيكّْوِيضنْ شَا غَارْ ثمُّورْثْ ن إِسْرَائِيل. \add أَمُّو\add* إِ غَا ثسّْنمْ بلِّي نشّْ ذ سِيذِي.‘ “
\m 
\v 39 ”ؤُشَا كنِّيوْ، \add أَ\add* ثَادَّارْثْ ن إِسْرَائِيل، أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي، أجّْ كُوڒْ إِجّْ أَذْ يُويُورْ غَارْ إِميْضَا نّسْ ن لْ-أَصْنَامْ. \add مَاشَا\add* أَوَارْنِي أَسْ أَذْ غَارِي ثسْڒمْ س ثِيذتّْ. \add خنِّي\add* وَارْ ثسّخْسَارَامْ عَاذْ إِسمْ إِنُو س ثوْهِيبِينْ نْومْ ذ إِميْضَا نْومْ ن لْ-أَصْنَامْ.
\v 40 مِينْزِي خْ وذْرَارْ إِنُو إِقدّْسنْ، خْ وذْرَارْ يُوعْڒَانْ ن إِسْرَائِيل، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي، ذِينْ أَذْ أَيِي ثْسخَّارْ قَاعْ ثَادَّارْثْ ن إِسْرَائِيل، مَارَّا نِيثْنِي. ذِينْ أَذْ خَاسنْ أَرْضِيغْ ؤُشَا ذِينْ أَذْ تَّارغْ ثِيوْهِيبِينْ نْومْ ن ؤُسْڭعّذْ ؤُڒَا ذ ثْمنْزُوثْ ن مِينْ غَا ثسّْڭعّْذمْ زِي مَارَّا ثِيوْهِيبِينْ نْومْ إِقدّْسنْ. \x ◘ \xo 20:‏40 \xt حِز. 40‏:‏2؛ حِز. 43‏:‏12\x*
\v 41 نشّْ أَذْ خَاومْ أَرْضِيغْ زِي سِّيبّثْ ن أَرِّيحثْ إِتّْفُوحنْ خْمِي كنِّيوْ غَا سُّوفّْغغْ زِي ڒڭْنُوسْ ؤُ أَذْ كنِّيوْ سّْمُونغْ زِي ثمُّورَا مَانِي كنِّيوْ زُوزَّارغْ ؤُشَا أَذْ تّْوَاقدّْسغْ زَّايْومْ زَّاثْ إِ-ث ثِيطَّاوِينْ ن ڒڭْنُوسْ
\v 42 ؤُشَا أَذْ ثسّْنمْ بلِّي نشّْ ذ سِيذِي، ڒَامِي كنِّيوْ د-إِوْيغْ عَاوذْ غَارْ ثمُّورْثْ ن إِسْرَائِيل، غَارْ ثمُّورْثْ خْ ثنِّي ؤُمِي سّْوِيژّْضغْ أَفُوسْ إِنُو، \add جُّودْجغْ\add* أَذْ ت وْشغْ إِ ڒجْذُوذْ نْومْ.
\v 43 ذِينْ أَذْ ثِيذَارمْ إِبْرِيذنْ نْومْ ذ مَارَّا ثِيمڭَّا نْومْ نِّي زِي ثسّْخمْجنْ إِخفْ نْومْ ؤُشَا كنِّيوْ أَذْ ثْشَارْهمْ إِخفْ نْومْ زِي سِّيبّثْ ن مَارَّا ثِيمڭَّا نْومْ إِعفّْننْ إِ ثڭِّيمْ.
\v 44 كنِّيوْ أَذْ ثسّْنمْ بلِّي نشّْ ذ سِيذِي، ڒَامِي ڭِّيغْ أَكِيذْومْ ذِي طّْوعْ ن يِيسمْ إِنُو \add ؤُشَا\add* وَارْ إِدْجِي عْلَاحْسَابْ إِبْرِيذنْ نْومْ إِعفّْننْ، \add ؤُ وَارْ إِدْجِي\add* عْلَاحْسَابْ ثِيمڭَّا نْومْ إِغشّنْ، \add أَ\add* ثَادَّارْثْ ن إِسْرَائِيل!‘، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي.“
\b
\b
\c 21
\s1 ڒْحُوكْمْ خْ ثمُّورْثْ ن لْجَانُوبْ
\m 
\v 1 يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا:
\v 2 ”\add أَ\add* مِّيسْ ن بْنَاذمْ، أڭّْ ؤُذمْ نّشْ غَارْ لْجَانُوبْ، أجّْ \add أَوَاڒنْ نّشْ\add* أَذْ ؤُذُومنْ جِّيهثْ ن لْجَانُوبْ ؤُشَا نَابّْ ضِيدّْ إِ وزْغَارْ ن ييَّارْ ذِي \add ثمُّورْثْ ن\add* لْجَانُوبْ. \f ◼ \fr 21:‏2 \ft \bd ’أَزْغَارْ‘\bd* - نِيغْ ’ڒْغَابثْ‘ نِيغْ ’ثَازْڭَانْثْ‘.\f*
\v 3 إِنِي إِ وزْغَارْ ن \add ثمُّورْثْ ن\add* لْجَانُوبْ: ’سڒْ إِ وَاوَاڒْ ن سِيذِي: أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: خْزَارْ، نشّْ أَذْ سَّارْغغْ ذَايمْ إِشْثْ ن ثْمسِّي، ثنِّي إِ غَا إِشّنْ كُوڒْ ثَاشجَّارْثْ ثَازِيزَاوْثْ ؤُ كُوڒْ ثَاشجَّارْثْ يُوژْغنْ. أَشعَّاڒْ ن ڒْعابُوقْ وَارْ إِتّْوَاخسِّي ؤُ س ؤُيَا أَذْ تّْوَاشمْضنْ مَارَّا إِغمْبَابْ زِي لْجَانُوبْ أَڒْ شَّامَالْ \x ◘ \xo 21:‏3 \xt لك. 23‏:‏31\x*
\v 4 ؤُشَا مَارَّا إِوْذَانْ ذ ڒْمَاڒْ أَذْ ژَترنْ أَقَا نشّْ، سِيذِي، ذ ونِّي إِسَّارْغنْ \add ثِيمسِّي\add*. وَارْ ثتّْوَاخسِّي شَا.‘ \f ◼ \fr 21:‏4 \ft \bd ’مَارَّا إِوْذَانْ ذ ڒْمَاڒْ‘\bd* - س ثْعِيبْرَانِيثْ ’مَارَّا أَيْسُومْ‘.\f*
\v 5 نِّيغْ نشّْ: ’أَ، سِيذِي إِنُو، سِيذِي، عَاذْ نِيثْنِي قَّارنْ خَافِي: ’مَا وَارْ إِسِّيوڒْ نتَّا س ثْحُوجَا ن ثْوَافِيثْ \add وَاهَا\add*؟‘!“
\b
\s1 ڒْحُوكْمْ ن سِيذِي خْ ؤُرْشَالِيمْ
\m 
\v 6 يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا:
\v 7 ”\add أَ\add* مِّيسْ ن بْنَاذمْ، أڭّْ ؤُذمْ نّشْ غَارْ ؤُرْشَالِيمْ، أجّْ \add أَوَاڒنْ نّشْ\add* أَذْ ؤُذُومنْ ضِيدّْ إِ ثْزَاوِييِّينْ إِقدّْسنْ ؤُشَا نَابّْ ضِيدّْ إِ ثمُّورْثْ ن إِسْرَائِيل.
\v 8 إِنِي إِ ثمُّورْثْ ن إِسْرَائِيل: ’أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: خْزَارْ، أَقَا غَارمْ، نشّْ أَذْ د-جبْذغْ سِّيفْ إِنُو زڭْ ؤُفُورُّو ن وغْڒَافْ نّسْ ؤُشَا أَذْ قضْعغْ أَمْ ؤُمْسڭّذْ أَمْ ؤُعفَّانْ.
\v 9 مِينْزِي أَذْ قضْعغْ أَمْ ؤُمْسڭّذْ أَمْ ؤُعفَّانْ زِي ڒْوسْطْ نّمْ، س ؤُيَا أَذْ د-إِفّغْ سِّيفْ إِنُو زڭْ ؤُفُورُّو ن وغْڒَافْ نّسْ، ضِيدّْ إِ مَارَّا \add إِنِّي غَارْسنْ أَرِّيمثْ ن\add* ويْسُومْ، زِي لْجَانُوبْ أَڒْ شَّامَالْ،
\v 10 ؤُشَا مَارَّا \add إِنِّي غَارْسنْ أَرِّيمثْ ن\add* ويْسُومْ أَذْ سّْننْ، بلِّي نشّْ، سِيذِي، جبْذغْ سِّيفْ إِنُو زڭْ ؤُفُورُّو ن وغْڒَافْ.عمَّارْصْ وَارْ \add غَارسْ\add* د-إِذِّيكّْوِيڒْ.‘ “
\m 
\v 11 ”\add مَاشَا\add* شكْ، \add أَ\add* مِّيسْ ن بْنَاذمْ، سْغُونْفَا، سْغُونْفَا زَّاثْ إِ ثِيطَّاوِينْ نْسنْ س ثجْعِينَّاثِينْ تّْوَارْژنْثْ ذ ثَارْزُوڭِي.
\v 12 أَذْ إِمْسَارْ خْمِي ذ أَشْ إِ غَا إِنِينْ: ’مَاغَارْ ثسّْغُونْفِيذْ \add أَمُّو\add*؟‘، أَقَا شكْ أَذْ ثِينِيذْ: ’زِي سِّيبّثْ ن مِينْ سْڒِيغْ، مَاغَارْ أَذْ د-يَاسْ ؤُشَا كُوڒْ ؤُڒْ أَذْ إِفْسِي ؤُ مَارَّا إِفَاسّنْ أَذْ هيّْفنْ ؤُ مَارَّا بُوحْبڒْ أَذْ يَارْخُو ؤُ مَارَّا إِفَادّنْ أَذْ أَرْذْبنْ أَمْ وَامَانْ. خْزَارْ، أَذْ د-يَاسْ ؤُشَا أَذْ يِيڒِي، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي.‘ “ \x ◘ \xo 21:‏12 \xt إِرْم. 6‏:‏24؛ 49‏:‏23؛ حِز. 4‏:‏17؛ 7‏:‏17\x*
\b
\m 
\v 13 يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا:
\v 14 ”\add أَ\add* مِّيسْ ن بْنَاذمْ، نَابّْ ؤُشَا إِنِي: ’أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي!‘ ؤُشَا إِنِي:
\b
\m \qt ’سِّيفْ، سِّيفْ،\qt*
\m \qt أَقَا إِتّْوَاسّقْضعْ ؤُ إِتّْوَاسُّويْذَا.\qt*
\m 
\v 15 \qt إِتّْوَاسّقْضعْ مَاحنْذْ أَذْ إِغَارْصْ ثِيغَارْصَا،\qt*
\m \qt إِتّْوَاسُّويْذَا مَاحنْذْ أَذْ إِللّشْ.‘\qt*
\b
\m \qt نِيغْ إِتّْخصَّا إِ نشِّينْ أَذْ نْفَارّحْ، \tl أَذْ نِينِي:\tl*\qt*
\m \qt ’أَزدْجَاضْ \tl ن ڒحْكَامثْ\tl* ن مِّي\qt*
\m \qt إِسّحْقَارْ كُوڒْ أَكشُّوضْ \tl نّغْنِي\tl*؟‘\qt* \f ◼ \fr 21:‏15 \ft \bd ’مِّي‘\bd* - أَقَا-ث ذ يَاهُوذَا (خْزَارْ أَمز. 49‏:9) \bd ’أَزدْجَاضْ‘\bd* - أَقَا-ث ذ أَزدْجَاضْ (ن صُّولْطَا) ن يَاهُوذَا (خْزَارْ أَمز. 49‏:10). ذڭْ أَمز. 49:‏10 نتَّافْ أَقَا أَزدْجَاضْ-أَ وَارْ د-إِتّْوَاكّسْ زِي يَاهُوذَا. ڒخُّو حِيزْقِييَالْ، ؤُمِي ڒْڭنْسْ إِسّنْ أَقَا إِخْسْ أَذْ إِطّفْ ذِي لْوَاعْذْ-أَ، إِسّقْسَا ’مَا أَذْ ثقِّيمْ صُّولْطَا ن يَاهُوذَا أَمْ مَامّشْ ذ أَسْ إِتّْغِيڒْ إِ ڒْڭنْسْ خْ ذْسَاسْ ن لْوَاعْذْ نِيغْ لَّا؟ مِينْزِي نِيثْنِي قَّارنْ س يِيخفْ نْسنْ ’أَزدْجَاضْ ن مِّي إِسّحْقَارْ كُوڒْ أَكشُّوضْ (نّغْنِي)‘، إِخْسْ أَذْ يِينِي لْوَاعْذْ أَذْ إِقِّيمْ ؤُشَا أَجدْجِيذْ ن بَابِيلْ (’سِّيفْ‘) وَارْ ذ أَنغْ إِزمَّارْ. خنِّي يَارَّا-د سِيذِي بلِّي ڒْڭنْسْ ن يَاهُوذَا أَذْ إِتّْوَاڒْقفْ س سِّيفْ ن ؤُجدْجِيذْ ن بَابِيلْ ؤُ نتَّا أَذْ ثنْ إِسُّوفّغْ ذِي ثْمحْبَاسْثْ غَارْ بَابِيلْ، مَاشَا لْوَاعْذْ إِ يَاهُوذَا ذِي أَمز. 49‏:10 أَذْ إِقِّيمْ ؤُشَا أَذْ إِتّْوَاكمّڒْ ذِي لْمَاسِيحْ ونِّي د إِ غَا إِتّْوَاخڒْقنْ أَوَارْنِي عْڒَاينْ 500 ن إِسڭّْوُوسَا ذِي بَايْثْ-لَاحْمْ، ثَانْذِينْثْ ن يَاهُوذَا، زِي أَرُّوحْ إِقدّْسنْ، زڭْ ؤُعذِّيسْ ن مَارْيَامْ، ثنِّي ثُوغَا إِتّْوَاخْضْبنْ إِ يُوسُوفْ. يُوسُوفْ ذ مَارْيَامْ ثُوغَا-ثنْ س ثْنَاينْ إِذْسنْ زِي ثْوَاشُونْثْ ن ذَاوُوذْ، زڭْ إِشْثْ ن ثْوَاشُونْثْ إِڭلّْذنْ، وَاخَّا ؤُذَاينْ وَارْ غَارْسنْ أَجدْجِيذْ زڭْ يِيخفْ نْسنْ ذِي ڒْوقْثْ نِّي مَاغَارْ هِيرُوذُوسْ زِي إِذُومْ ثُوغَا ذ أَجدْجِيذْ خْ ڒُومُورْ ن إِرُومَانِييّنْ.\f*
\b
\m 
\v 16 \qt ’إِمّوْشْ مَاحنْذْ أَذْ إِتّْوَاسُّويْذَا،\qt*
\m \qt مَاحنْذْ أَذْ ث طّْفنْ ذڭْ ؤُفُوسْ.\qt*
\m \qt سِّيفْ إِتّْوَاقْضعْ ؤُ إِتّْوَاسُّويْذَا،\qt*
\m \qt مَاحنْذْ أَذْ إِتّْوَاڭّْ ذڭْ ؤُفُوسْ ن ؤُقتَّاڒْ.\qt*
\m 
\v 17 \qt سْغُويّْ ؤُشَا ثْرُوذْ، \tl أَ\tl* مِّيسْ ن بْنَاذمْ،\qt*
\m \qt مَاغَارْ أَذْ يِيڒِي خْ ڒْڭنْسْ إِنُو،\qt*
\m \qt أَذْ يِيڒِي خْ مَارَّا ڒْحُوكَّامْ ن إِسْرَائِيل.\qt*
\m \qt أَقَا مّوْشنْ إِ سِّيفْ \tl مُوننْ\tl*\qt*
\m \qt أَكْ-ذ ڒْڭنْسْ إِنُو.\qt*
\m \qt س ؤُيَا، وّثْ خْ ثْمصَّاضْثْ نّشْ.‘\qt* \x ◘ \xo 21:‏17 \xt حِز. 6‏:‏11؛ 7‏:‏27\x*
\b
\m 
\v 18 \qt ’وَاهْ، \tl سِّيفْ\tl* إِتّْوَاقدْجبْ.\qt*
\m \qt \tl مَاشَا\tl* مَانَا، مَاڒَا أَزدْجَاضْ\qt*
\m \qt نِّي إِسّحْقَارنْ \tl مَارَّا أَكشُّوضْ\tl*\qt*
\m \qt وَارْ د-إِتِّيڒِي \tl عَاذْ\tl*؟‘،\qt*
\m \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي. \x ◘ \xo 21:‏18 \xt إِشا. 1‏:‏5؛ إِرْم. 6‏:‏28‏-‏30\x*
\b
\m 
\v 19 \qt ’شكْ، \tl أَ\tl* مِّيسْ ن بْنَاذمْ، نَابّْ،\qt*
\m \qt ؤُشَا وّثْ إِفَاسّنْ إِجّْ ذڭْ ونّغْنِي،\qt*
\m \qt مَاغَارْ سِّيفْ أَذْ إِوّثْ ثْنَاينْ،\qt*
\m \qt \tl وَاهْ\tl*، ثْڒَاثَا ن إِمُورنْ.\qt*
\m \qt أَقَا-ث ذ سِّيفْ ن يِينِّي إِتّْوَانْغنْ،\qt*
\m \qt سِّيفْ ن ؤُمقّْرَانْ نِّي إِتّْوَانغْ،\qt*
\m \qt سِّيفْ نِّي غَارْسنْ إِتَّاذْفنْ،\qt*
\m 
\v 20 \qt حِيمَا \tl خنِّي\tl* ؤُڒْ أَذْ إِفْسِي\qt*
\m \qt ؤُشَا أَذْ مَّارنْينْثْ ثْعنْكْرِيفِينْ.\qt*
\m \qt ڒقْضعْ ن سِّيفْ ڭِّيغْ ث\qt*
\m \qt خْ مَارَّا ثِيوُّورَا نْسنْ.\qt*
\m \qt أَيْ، أَقَا \tl سِّيفْ\tl* إِوْجذْ مَاحنْذْ أَذْ إِللّشْ،\qt*
\m \qt أَقَا إِتّْوَاجبّْ-د زڭْ ؤُفُورُّو ن وغْڒَافْ\qt*
\m \qt مَاحنْذْ أَذْ إِغَارْصْ.\qt* \x ◘ \xo 21:‏20 \xt حِز. 21‏:‏32\x*
\m 
\v 21 \qt سْمُونْ جّهْذْ نّشْ، قسّْ غَارْ ؤُفُوسِي،\qt*
\m \qt بدّْ، قسّْ غَارْ ؤُزڒْمَاضْ،\qt*
\m \qt أَرّْ ڒقْضعْ نّشْ مَانِي مَا ثخْسذْ.‘\qt*
\b
\m 
\v 22 \qt ’ؤُڒَا ذ نشّْ أَذْ وْثغْ إِفَاسّنْ إِنُو\qt*
\m \qt إِجّْ ذڭْ ونّغْنِي\qt*
\m \qt ؤُشَا أَذْ سَّاريّْحغْ أَسْعَارْ إِنُو.\qt*
\m \qt نشّْ، سِيذِي، أَقَا سِّيوْڒغْ.‘ “\qt*
\b
\m 
\v 23 يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا:
\v 24 ”شكْ، \add أَ\add* مِّيسْ ن بْنَاذمْ، أڭّْ ثْنَاينْ ن إِبْرِيذنْ زِي مَانِي د غَا يَاسْ سِّيفْ ن ؤُجدْجِيذْ ن بَابِيلْ. زڭْ إِشْثْ ن ثمُّورْثْ أَذْ فّْغنْ نِيثْنِي س ثْنَاينْ إِذْسنْ. نْقشْ إِجّْ ن ؤُشِييَّارْ غَارْ \add ؤُ\add*بطُّو ن وبْرِيذْ، نْقشْ \add إِ-ث\add* غَارْ \add ؤُ\add*بطُّو ن وبْرِيذْ غَارْ ثنْذِينْثْ.
\v 25 أَذْ ثْنيّْشذْ أَبْرِيذْ س مَانِيسْ د غَا يَاسْ سِّيفْ غَارْ رَابَّا ن أَيْثْ ن عَامُّونْ ؤُ غَارْ يَاهُوذَا أَڒْ ذَاخڒْ ذِي ثنْذِينْثْ إِتّْوَاسّْجهْذنْ: ؤُرْشَالِيمْ.
\v 26 مِينْزِي أَجدْجِيذْ ن بَابِيلْ أَذْ إِبدّْ غَارْ مَانِي فَارْقنْ إِبْرِيذنْ، غَارْ \add ؤُ\add*بدُّو ن ثْنَاينْ ن إِبْرِيذنْ نِّي مَاحنْذْ أَذْ إِعزّمْ. أَذْ إِزّرْزْ فْڒِيثْشَاثْ ن ڒْقوْصْ، أَذْ إِسّقْسَا ڒخْيَاڒَاثْ ن لْ-أَصْنَامْ، أَذْ إِخْزَارْ ثْسَا.
\v 27 ذڭْ ؤُفُوسْ نّسْ ؤُفُوسِي يُوسَا-د وشْثَابْ ن ’ؤُرْشَالِيمْ!‘، مَاحنْذْ أَذْ \add ذِينْ\add* يڭّْ ڒقْشُوعْ ن وذْهَامْ، مَاحنْذْ أَذْ يَارْزمْ أَقمُّومْ \add نّسْ\add* س إِغُويَّانْ ن ونْغِي، مَاحنْذْ أَذْ إِسّْڭعّذْ ثْمِيجَّا \add نّسْ\add* س إِغُويَّانْ \add ن ؤُمنْغِي\add*، مَاحنْذْ أَذْ إِڭّْ ڒقْشُوعْ ن وذْهَامْ ضِيدّْ إِ ثوُّورَا، مَاحنْذْ أَذْ يڭّْ أَشْبَارْ، مَاحنْذْ أَذْ إِڭّْ لْبَارَاجَاثْ. \x ◘ \xo 21:‏27 \xt حِز. 4‏:‏2؛ 17‏:‏17\x*
\v 28 مَاشَا مَانْ أَيَا أَذْ غَارْسنْ يِيڒِي أَمْ ؤُڭزّنْ إِغشّنْ ذِي ثِيطَّاوِينْ نْسنْ، \add مَاغَارْ نِيثْنِي\add* أَقَا غَارْسنْ ثِيجَادْجَاثِينْ إِمثْننْ، \add مَاشَا\add* نتَّا أَذْ إِسّعْقڒْ خْ ڒْمُوعْصِييّثْ نْسنْ، مَاحنْذْ أَذْ تّْوَاطّْفنْ \add نِيثْنِي\add*.“
\m 
\v 29 ”س ؤُيَا، أَمُّو إِ إِقَّارْ سِيذِي إِنُو سِيذِي: ’مِينْزِي ثسّعْقِيڒمْ خْ ڒْمُوعْصِييّثْ نْومْ ؤُمِي إِعذِّيينْ نْومْ تّْبَاننْ نِيشَانْ، خْمِي تّْوَاژَارّنْ دّْنُوبْ نْومْ س مَارَّا مِينْ ثتّڭّمْ، \add وَاهْ،\add* مِينْزِي ثْسّعْقِيڒمْ \add خْ ڒْمُوعْصِييّثْ نْومْ\add*، \add س ؤُيَا\add* أَذْ كنِّيوْ طّْفنْ س ؤُفُوسْ.‘
\v 30 ؤُ شكْ، أَعفَّانْ إِيزّْمنْ إِ ڒْموْثْ، \add شكْ،\add* \add أَ\add* ڒْحَاكمْ ن إِسْرَائِيل، ونِّي أَسّْ نّسْ أَذْ د-يَاسْ ذِي ڒْوقْثْ ن ڒحْسَابْ أَنڭَّارُو ن ڒْمُوعْصِييّثْ،
\v 31 أَمُّو إِ \add ذ أَشْ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي: ’كّسْ أَرژّثْ نِّي، كّسْ تَّاجْ نِّي. \add أَمُّو\add* وَارْ إِتِّيڒِي عَاذْ. مِينْ إِسّهْوَانْ، أَذْ إِتّْوَاسُّوعْڒَا، ؤُ مِينْ إِسُّوعْڒَانْ، أَذْ د-إِتّْوَاسّهْوَا.
\v 32 أَذْ أَرّغْ أَيَا ذ ڒْخَارْبثْ، ذ ڒْخَارْبثْ، \add وَاهْ،\add* أَذْ ث أَرّغْ ذ ڒْخَارْبثْ. \add مَاشَا\add* \add مَارَّا\add* أَيَا وَارْ إِتّْغِيمِي عَاذْ، \add مْغِيرْ\add* أَڒْ د غَا يَاسْ ونِّي غَارْ إِدْجَانْ ڒْحقّْ ؤُشَا نشّْ أَذْ أَسْ ث وْشغْ.‘ “ \x ◘ \xo 21:‏32 \xt أَمز. 49‏:‏10\x*
\b
\s1 ڒْحُوكْمْ ن سِيذِي خْ إِعَامُّونِييّنْ
\m 
\v 33 ”ؤُ شكْ، \add أَ\add* مِّيسْ ن بْنَاذمْ، نَابّْ ؤُشَا إِنِي: ’أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي، خْ أَيْثْ نْ عَامُّونْ ؤُ خْ ؤُسحْقَارْ نْسنْ!‘ إِنِي:
\b
\m \qt ’سِّيفْ، سِّيفْ إِتّْوَاجبْذْ-د،\qt*
\m \qt إِتّْوَاسُّويْذَا مَاحنْذْ أَذْ يشّْ،\qt*
\m \qt مَاحنْذْ أَذْ إِللّشْ، ...\qt*
\b
\m 
\v 34 - وَاخَّا نِيثْنِي تّْوَاڒَانْ إِ شكْ إِجّْ ن ڒوْحِييْ وَارْ إِدْجِينْ، وَاخَّا نِيثْنِي تّْڭزّْننْ إِ شكْ إِجّْ ن ؤُڭزّنْ إِسّْخَارِّيقنْ -
\b
\m \qt \tl ... أَقَا سِّيفْ إِتّْوَاجبْذْ-د\tl*\qt*
\m \qt مَاحنْذْ أَذْ شكْ يَارّْ\qt*
\m \qt غَارْ إِرَاونْ ن إِعفَّاننْ إِتّْوَاسّْنُوقّْبنْ\qt*
\m \qt نِّي زِي د-يُوسَا وَاسّْ نْسنْ\qt*
\m \qt ذِي ڒْوقْثْ ن ڒحْسَابْ أَنڭَّارُو ن ڒْمُوعْصِييّثْ.\qt*
\m 
\v 35 \qt أَرّْ \tl سِّيفْ\tl* غَارْ ؤُفُورُّو ن وغْڒَافْ نّسْ.\qt*
\m \qt ذڭْ ومْشَانْ مَانِي د-ثتّْوَاخڒْقذْ،\qt*
\m \qt ذِي ثمُّورْثْ ن لْ-أَصلْ نّشْ\qt*
\m \qt أَذْ شكْ حكْمغْ.\qt*
\m 
\v 36 \qt أَذْ خَاكْ زدْجْعغْ وسْخضْ إِنُو.\qt*
\m \qt س ثْمسِّي ن ؤُذُوقّزْ إِنُو \tl ن ؤُفُوڭمْ\tl*\qt*
\m \qt أَذْ خَاكْ سُوضغْ ؤُشَا أَذْ شكْ ڭّغْ\qt*
\m \qt ذڭْ ؤُفُوسْ ن أَيْثْ ن بُو -غزُّو\qt*
\m \qt نِّي إِسّْننْ أَذْ ذدْجنْ.\qt*
\m 
\v 37 \qt أَذْ ثِيڒِيذْ ذ مَاشَّا إِ ثْمسِّي،\qt*
\m \qt إِذَامّنْ نّشْ أَذْ ثنْ سِّيزّْڒنْ ذِي ڒْوسْطْ ن ثمُّورْثْ.\qt*
\m \qt وَارْ ثتِّيڒِي قَاعْ ڒِيذَارثْ ذَايكْ،\qt*
\m \qt مَاغَارْ نشّْ، سِيذِي، أَقَا سِّيوْڒغْ.‘ “\qt*
\b
\b
\c 22
\s1 دّْنُوبْ ن ؤُرْشَالِيمْ
\m 
\v 1 يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا:
\v 2 ”شكْ، \add أَ\add* مِّيسْ ن بْنَاذمْ، مَا ثخْسذْ أَذْ ثْحكْمذْ، مَا ثخْسذْ أَذْ ثْحكْمذْ خْ \bd ثنْذِينْثْ ن إِذَامّنْ\bd*؟ سْشنْ أَسْ \add خنِّي\add* جّْعَايفْ نّسْ، \x ◘ \xo 22:‏2 \xt حِز. 20‏:‏4؛ 23‏:‏36\x*
\v 3 إِنِي: ’أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: \add شمْ\add*، \add أَ\add* ثَانْذِينْثْ، ثنِّي إِسِّيزّْڒنْ \bd إِذَامّنْ\bd* ذِي ڒْوسْطْ نّسْ، أَڒَامِي د-ثِيوضْ ڒْوقْثْ نّسْ، \add أَ\add* ثَانْذِينْثْ، ثنِّي إِڭِّينْ إِميْضَا ن لْ-أَصْنَامْ خْ يِيخفْ نّسْ مَاحنْذْ أَذْ زَّايْسنْ ثسّخْمجْ إِخفْ نّسْ!
\v 4 س \bd إِذَامّنْ\bd* نِّي ثسِّيزّْڒذْ، ثْذوْڒذْ س ؤُمَارْوَاسْ ؤُ س إِميْضَا نّمْ ن لْ-أَصْنَامْ نِّي ثڭِّيذْ، أَقَا ثسّْخمْجذْ إِخفْ نّمْ، ثسِّيوْضذْ ؤُسَّانْ نّمْ ؤُشَا ثْرهّْڭذْ أَڒْ إِسڭّْوُوسَا نّمْ. خْ ؤُيَا وْشِيغْ شمْ إِ ڒڭْنُوسْ إِ ؤُسحْقَارْ ؤُ إِ ثمُّورَا إِ ؤُسْثهْزِي. \x ◘ \xo 22:‏4 \xt 2 إِج. 21‏:‏16؛ حِز. 5‏:‏14؛ 20‏:‏30، 31 \x*
\v 5 إِنِّي يُوذْسنْ ذ يِينِّي إِڭّْوجنْ أَذْ زَّايمْ سْثهْزَانْ: \add ‘شمْ، أَ\add* ثَامخْمُوجْثْ ن يِيسمْ، \add شمْ، ثنِّي\add* إِشُّورنْ س ؤُصدّعْ!
\v 6 خْزَارْ، ڒْحُوكَّامْ ن إِسْرَائِيل ثُوغَا أَثنْ ذَايمْ، كُوڒْ إِجّْ خْ ڒحْسَابْ جّهْذْ نّسْ، مَاحنْذْ أَذْ سِيزّْڒنْ \bd إِذَامّنْ\bd*.
\v 7 سّحْقَارنْ بَابَاثْسنْ ذ يمَّاثْسنْ ذَايمْ، ڭِّينْ س ؤُغِيڒْ أَكْ-ذ ؤُبَارَّانِي ذِي ڒْوسْطْ نّمْ، حْصَارنْ أَيُوجِيڒْ ذ ثَاجَّاتْشْ إِ ذَايمْ.
\v 8 مِينْ إِدْجَانْ إِقدّْسنْ إِ نشّْ، أَقَا ثسّحْقَارذْ ث، ؤُشَا ؤُسَّانْ ن سّبْثْ إِنُو ثسّْعِيدْجْثذْ إِ-ثنْ.
\v 9 إِمْشقَّافنْ ثُوغَا أَثنْ ذَايمْ مَاحنْذْ أَذْ سِّيزْڒنْ \bd إِذَامّنْ\bd*. نِيثْنِي قِّيمنْ شِّينْ خْ إِذُورَارْ نِّي \add ذِينِّي\add* غَارمْ، أَقَا ڭِّينْ ڒفْضِيحثْ ذِي ڒْوسْطْ نّمْ. \x ◘ \xo 22:‏9 \xt حِز. 18‏:‏6، 11\x*
\v 10 نِيثْنِي سّْعَارَّانْ ڒْعَارْ ن بَابَامْ نِّي ذِينْ غَارمْ، ؤُ ثنِّي ثُوغَا ثخْمجْ ؤُمِي خَاسْ إِذَامّنْ، أَقَاغصْبنْ ت ذَايمْ. \x ◘ \xo 22:‏10 \xt لَاوِي 18‏:‏8، 19؛ حِز. 18‏:‏6\x*
\v 11 إِجّنْ إِڭَّا نّْعِي أَكْ-ذ ثْمطُّوثْ ن وَاجَّارْ نّسْ، ؤُشَا إِجّنْ نّغْنِي إِسّخْمجْ ثَامْغَارْثْ ن مِّيسْ، \add إِتّڭّْ\add* ڒفْضِيحثْ \add أَكِيذسْ\add*، ؤُشَا \add عَاوذْ\add* إِجّنْ نّغْنِي إِغْصبْ ؤُتْشْمَاسْ، يدْجِيسْ ن بَابَاسْ، \add ذِينْ\add* غَارمْ.\x ◘ \xo 22:‏11 \xt لَاوِي 18‏:‏15، 20؛ إِرْم. 5‏:‏8\x*
\v 12 أَقَا طّْفنْ ذِينْ غَارمْ أَرّشْوثْ، مَاحنْذْ أَذْ سِّيزّْڒنْ \bd إِذَامّنْ\bd*، ثكْسِيذْ أَرِّيبَا ذ أَرْبحْ ؤُشَا ثْبعّْجذْ أَجَّارْ نّشْ س ؤُغِيڒْ، مَاشَا ثتُّوذْ أَيِي!‘، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي.“
\m 
\v 13 ”خْزَارْ، وْثِيغْ إِفَاسّنْ إِنُو إِجّْ ذڭْ ونّغْنِي زِي سِّيبّثْ ن ؤُبعّجْ إِ ثڭِّيذْ ؤُ زِي سِّيبّثْ ن \bd إِذَامّنْ\bd* نِّي إِسِّيزّْڒنْ ذِي ڒْوسْطْ نّمْ. \f ◼ \fr 22:‏13 \ft \bd ’ؤُبعّجْ ... إِذَامّنْ‘\bd* - س ثْعِيبْرَانِيثْ ’ؤُبعّجْ نّمْ ... إِذَامّنْ نّمْ‘.\f*  \x ◘ \xo 22:‏13 \xt حِز. 21‏:‏22\x*
\v 14 مَا أَذْ إِقِّيمْ ؤُڒْ نّمْ إِمْثنْ؟ مَا أَذْ إِڒِينْ إِفَاسّنْ نّمْ جهْذنْ ذڭْ وُوسَّانْ نِّي ذِي غَا ڭّغْ \add مِينْ إِدْجَانْ\add* ضِيدّْ نّمْ. نشّْ، سِيذِي، أَقَا سِّيوْڒغْ ؤُشَا أَذْ ث ڭّغْ. \x ◘ \xo 22:‏14 \xt حِز. 17‏:‏24\x*
\v 15 أَذْ شمْ زُوزَّارغْ جَارْ ڒڭْنُوسْ، أَذْ شمْ بزّْعغْ خْ ثمُّورَا، ؤُ أَذْ كمّْڒغْ ثَاخْمُوجِي نّمْ قَاعْ. \x ◘ \xo 22:‏15 \xt حِز. 12‏:‏14، 15\x*
\v 16 \add أَمُّو\add* إِ غَا ثتّْوَاسّْعِيدْجْثذْ زڭْ يِيخفْ نّمْ زَّاثْ إِ ثِيطَّاوِينْ ن ڒڭْنُوسْ ؤُ شمْ أَذْ ثسّْنذْ بلِّي نشّْ ذ سِيذِي.“
\b
\m 
\v 17 يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا:
\v 18 ”\add أَ\add* مِّيسْ ن بْنَاذمْ، إِنِّي ن ثَادَّارْثْ ن إِسْرَائِيل ذوْڒنْ أَيِي أَمْ كُوفُّو. مَارَّا نِيثْنِي ذوْڒنْ ذ نّْحَاسْ ذ إِسْثَانْيُو ذ وُوزَّاڒْ ذ ڒخْفِيفْ ذِي ڒْوسْطْ ن ثفْقُونْثْ، أَقَا أَثنْ ذوْڒنْ كُوفُّو ن نُّوقَارْثْ.“ \x ◘ \xo 22:‏18 \xt إِشا. 1‏:‏22\x*
\m 
\v 19 ”س ؤُيَا، أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي، مِينْزِي مَارَّا كنِّيوْ ثْذوْڒمْ أَمْ كُوفُّو، س ؤُيَا، خْزَارْ، نشّْ أَذْ كنِّيوْ سّْمُونغْ ذِي  ؤُرْشَالِيمْ.
\v 20 أَخْمِي يَارْونْ نّْحَاسْ ذ إِسْثَانْيُو ذ وُوزَّاڒْ ذ ڒخْفِيفْ ذِي ثفْقُونْثْ، حِيمَا أَذْ خَاسنْ شعّْڒنْ ثِيمسِّي مَاحنْذْ أَذْ سّْفسْينْ مَانْ أَيَا \add مَارَّا\add*، أَمُّو إِ \add كنِّيوْ\add* غَا سّْمُونغْ ذڭْ وغْضَابْ إِنُو ؤُ ذڭْ وسْعَارْ إِنُو. أَذْ كنِّيوْ سَّارْسغْ ذِينِّي ؤُشَا أَذْ كنِّيوْ سّْفسْيغْ.
\v 21 نشّْ أَذْ كنِّيوْ سّْمُونغْ ؤُشَا أَذْ خَاومْ سُوضغْ س ثْمسِّي ن ؤُذُوقّزْ إِنُو \add ن ؤُفُوڭمْ\add* أَڒَامِي كنِّيوْ أَذْ ثتّْوَافسْيمْ ذِي ڒْوسْطْ نّسْ.
\v 22 أَخْمِي سّْفسْينْ نُّوقَارْثْ ذِي ثفْقُونْثْ، أَمُّو إِ غَا ثتّْوَاسّْفسْيمْ كنِّيوْ ذَايسْ ؤُشَا أَذْ ثسّْنمْ أَقَا نشّْ، سِيذِي، سّْفَارْغغْ خَاومْ أَسْعَارْ إِنُو.“
\b
\m 
\v 23 يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا:
\v 24 ”\add أَ\add* مِّيسْ ن بْنَاذمْ، إِنِي إِ \add ثمُّورْثْ\add*: ’شمْ ذ إِشْثْ ن ثمُّورْثْ إِ وَارْ إِتّْوَاسِّيزْذِيڭنْ، \add إِشْثْ ن ثمُّورْثْ\add* إِ وَارْ إِتّْوَاسُوفّنْ س ونْژَارْ إِجهْذنْ ذڭْ وَاسّْ ن وسْخضْ.
\v 25 أَقَا ذِينْ إِشْثْ ن ثْمعْمُوتْشْ ن إِنَابِييّنْ \add نّسْ\add* ذِي ڒْوسْطْ نّسْ. أَمْ ويْرَاذْ إِزهَّارنْ إِسَارْضْ ثَايْمَارْثْ نّسْ، \add أَمُّو إِ\add* شِّينْ نِيثْنِي ڒعْمُورْ. كّْسنْ \add مِينْ إِدْجَانْ ذ\add* ثَاخَابشْثْ ذ مِينْ إِغْڒَانْ. نِيثْنِي أَرْنِينْ ثِيجَّاڒْ نّسْ ذِي ڒْوسْطْ نّسْ. \x ◘ \xo 22:‏25 \xt مت. 23‏:‏14\x*
\v 26 إِكهَّاننْ نْسنْ سّْعِيدْجِيثنْ شَّارِيعَا إِنُو ؤُشَا سّْخمَّاجنْ ثِيمسْڒَايِينْ إِنُو إِقدّْسنْ. نِيثْنِي وَارْ فَارّْزنْ شَا جَارْ مِينْ إِقدّْسنْ ذ مِينْ إِتّْوَاسّْعِيدْجْثنْ، وَارْ سّْشَانَانْ شَا لْفَارْقْ جَارْ مِينْ إِخمْجنْ ذ مِينْ إِزْذِيڭنْ ؤُشَا تّْبلَّاعنْ ؤُڒَا ذ ثِيطَّاوِينْ نْسنْ إِ وُوسَّانْ إِنُو ن سّبْثْ ؤُشَا \add أَمُّو\add* تّْوَاسّْعِيدْجِيثغْ ذِي ڒْوسْطْ نْسنْ. \x ◘ \xo 22:‏26 \xt لَاوِي 10‏:‏10؛ حِز. 44‏:‏23\x*
\v 27 ڒْحُوكَّامْ نّسْ ذِي ڒْوسْطْ نّسْ ڭِّينْ أَمْ وُوشَّاننْ نِّي إِشَارّْڭنْ ثَايْمَارْثْ مَاحنْذْ أَذْ سِّيزّْڒنْ \bd إِذَامّنْ\bd* ؤُ مَاحنْذْ أَذْ أَردّْدْجنْ ڒعْمُورْ، حِيمَا أَذْ طّْفنْ أَرْبحْ وَارْ إِحْڒِينْ. \x ◘ \xo 22:‏27 \xt مِيخَا 3‏:‏11؛ صَاف. 3‏:‏3\x*
\v 28 إِنَابِييّنْ نّسْ ذْڒِينْ ثنْ س جِّيڒْ يُوژْغنْ. نِيثْنِي تّْوَاڒَانْ إِوحَّانْ وَارْ إِدْجِينْ ؤُشَا سَّاوَاڒنْ غَارْسنْ س ثْڭزَّانْثْ إِسّْخَارِّيقنْ. نِيثْنِي قَّارنْ: أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي!، \add أَمْ\add* سِيذِي ثُوغَا وَارْ إِنِي وَالُو. \x ◘ \xo 22:‏28 \xt حِز. 13‏:‏7، 9، 10؛ 21‏:‏29، 22‏:‏12\x*
\v 29 ڒْڭنْسْ ن ثمُّورْثْ إِڭَّا بزّزْ \add خْ إِوْذَانْ\add* س ڒخْشُونثْ، كشّْضنْ ثَاكشَّاضْثْ، حصَّارنْ ڒْمسْكِينْ ذ ؤُمزْڒُوضْ، ؤُشَا ذدْجنْ أَبَارَّانِي بْڒَا مَا \add غَارْسنْ يِيڒِي\add* ڒْحقّْ.
\v 30 أَرْزُوغْ جَارْ أَسنْ إِجّْ ن ورْيَازْ نِّي إِ غَا إِسّْبدّنْ إِجّْ ن ڒْحِيضْ ؤُشَا أَذْ إِبدّْ ذِي ثَازِّيثْ ذِي طّْوعْ ن ثمُّورْثْ أَڒَامِي وَارْ ت تَّارذْدْجغْ، مَاشَا وَارْ ث ؤُفِيغْ. \x ◘ \xo 22:‏30 \xt إِزهد. 106‏:‏23\x*
\v 31 \add خَاسْ ؤُشَا\add* سّْفَارْغغْ خَاسنْ أَسْخضْ إِنُو. س ثْمسِّي ن ؤُذُوقّزْ إِنُو \add ن ؤُفُوڭمْ\add* قْضِيغْ خَاسنْ، أَبْرِيذْ نْسنْ أَرِّيغْ ث خْ ؤُزدْجِيفْ نْسنْ!‘، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي.‘ “ \x ◘ \xo 22:‏31 \xt حِز. 9‏:‏10؛ 11‏:‏21؛ 16‏:‏43\x*
\b
\b
\c 23
\s1 ؤُهُولَا ذ ؤُهُولِيبَا
\m 
\v 1 يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا:
\v 2 ”\add أَ\add* مِّيسْ ن بْنَاذمْ، ثُوغَا \add ذِينْ\add* ثْنَاينْ ن ثمْغَارِينْ، يسِّيسْ ن إِشْثْ ن ثمْغَارْثْ.
\v 3 نِيثنْثِي سّْفسْذنْثْ إِخفْ نْسنْ ذِي مِيصْرَا، ذِي ثمْژِي نْسنْثْ سّْفسْذنْثْ إِخفْ نْسنْثْ. ذِينْ ثُوغَاعبْزنْثْ ذڭْ إِذْمَارنْ نْسنْثْ ؤُشَا ذِينْ حَاذَانْ إِبَّاشْ نْسنْثْ إِعُوزْرْينْ. \x ◘ \xo 23:‏3 \xt حِز. 20‏:‏8\x*
\v 4 إِسْمَاونْ نْسنْثْ ثُوغَا ؤُهُولَا، ثَامقّْرَانْثْ نْسنْثْ، ذ ؤُتْشْمَاسْ ؤُهُولِيبَا. نِيثنْثِي ذوْڒنْثْ إِنُو ؤُشَا ؤُرْونْثْ إِحنْجِيرنْ ذ ثْحنْجِيرِينْ. إِنَا ذ إِسْمَاونْ نْسنْثْ: سَامَارْيَا ذ ؤُهُولَا، ؤُ ؤُرْشَالِيمْ ذ ؤُهُولِيبَا.
\v 5 ؤُهُولَا ثسّفْسذْ إِخفْ نّسْ غَارِي ؤُ ثعْشقْ إِنِّي ت إِتّخْسنْ، أَيْثْ ن أَشُّورْ، جِّيرَانْ \add نّسْ\add*،
\v 6 \add إِرْيَازنْ\add* نِّي أَرْضنْ أَرُّوضْ أَذحْمِي، لْوُولَاثْ ذ إِمْضبَّارنْ، مَارَّا إِحُوذْرِييّنْ إِشنّْعنْ، إِمْنَاينْ نِّي ينْيِينْ س ؤُيِيسْ.
\v 7 س فَارْقْ-شّْغڒْ نّسْ ثوْشَا إِخفْ نّسْ إِ نِيثْنِي، غَارْ ڒمْخيَّارْ ن أَيْثْ ن أَشُّورْ، غَارْ مَارَّا نِيثْنِي ؤُشَا نتَّاثْ ثتّْوَاسّخْمجْ س مَارَّا وِي ثتّخْسْ، س مَارَّا إِميْضَا نْسنْ نْ صَّانَامْ.
\v 8 نتَّاثْ وَارْ ثجِّي فَارْقْ-شّْغڒْ نّسْ أَكْ-ذ إِمِيصْرِييّنْ، مِينْزِي ذِي ثمْژِي نّسْ طّْسنْ أَكِيذسْ ؤُشَا حَاذَانْ إِبَّاشْ نّسْ إِعُوزْرْينْ ؤُشَا سّْفَارّْغنْ خَاسْ فَارْقْ-شّْغڒْ نْسنْ.“
\m 
\v 9 ”س ؤُيَا وْشِيغْ ت ذڭْ ؤُفُوسْ ن يِينِّي ثُوغَا ت إِتّخْسنْ، ذڭْ ؤُفُوسْ ن أَيْثْ ن أَشُّورْ إِ ثُوغَا ثعْشقْ. \x ◘ \xo 23:‏9 \xt 2 إِج. 17؛ 18\x*
\v 10 نِيثْنِي سّْعَارَّانْ ڒْعَارْ نّسْ ؤُشَا كّْسنْ إِحنْجِيرنْ نّسْ ذ ثْحنْجِيرِينْ نّسْ ؤُشَا نْغِينْ ت س سِّيفْ. ثذْوڒْ أَسْ إِجّْ ن يِيسمْ وَارْ إِشْنِيعْ جَارْ ثمْغَارِينْ ؤُشَا نِيثْنِي سِّيوْضنْ خَاسْ ڒحْكَامَاثْ.“
\m 
\v 11 ”\add ؤُمِي\add* ثژْرَا مَانْ أَيَا ؤُتْشْمَاسْ، ؤُهُولِيبَا، أَقَا ثَارْنِي عَاذْ ذڭْ وعْشقْ نّسْ ؤُشَا ثَارْنِي ؤُڒَا ذِي فَارْقْ-شّْغڒْ نّسْ كْثَارْ خْ فَارْقْ-شّْغڒْ ن ؤُتْشْمَاسْ.
\v 12 نتَّاثْ ثعْشقْ أَيْثْ ن أَشُّورْ، لْوُولَاثْ ذ إِمْضبَّارنْ، جِّيرَانْ نِّي يَارْضنْ أَرُّوضْ ذ لمْلِيحْ قَاعْ، إِمْنَاينْ نِّي ينْيِينْ خْ ييْسَانْ، مَارَّا إِحُوذْرِييّنْ إِشنّْعنْ. \x ◘ \xo 23:‏12 \xt 2 إِج. 16‏:‏7\x*
\v 13 ژْرِيغْ أَقَا نتَّاثْ ثسّخْمجْ إِخفْ نّسْ. نِيثنْثِي س ثْنَاينْ إِذْسنْثْ ؤُيُورنْثْ أَبْرِيذْ ذ إِجّنْ.
\v 14 \add مَاشَا\add* نتَّاثْ ثَارْنِي \add عَاذْ\add* ذِي فَارْقْ-شّْغڒْ نّسْ. \add ؤُمِي\add* ثژْرَا إِرْيَازنْ، حنّْشنْ ثنْ خْ ڒْحِيضْ، ثْصَاوَارْ ن يرْيَازنْ، أَرْشَامنْ ذِي ثِينْثَاثْ ثِيزڭّْوَاغِينْ،
\v 15 بيْسنْ س وبْيَاسْ غَارْ ثجْعِينَّاثِينْ نْسنْ، س إِرژَّاثْ س ثِينْثَاثْ إِفَارْقنْ خْ إِزدْجِيفنْ نْسنْ، مَارَّا غَارْسنْ شُّوفْ أَمْ يِينغْرَافنْ \add ن ڒْعسْكَارْ\add*، أَروْسنْ ذِي أَيْثْ ن بَابِيلْ، \add إِرْيَازنْ\add* زِي \add ثمُّورْثْ ن\add* إِكَالْذَانِييّنْ، ثَامُّورْثْ مَانِي خڒْقنْ.
\v 16 أَمُّو إِ ثذْوڒْ نتَّاثْ ثتّخْسْ إِ-ثنْ ؤُمِي ثِيطَّاوِينْ نّسْ ژْرِينْثْ \add ثنْ\add* ؤُشَا نتَّاثْ ثسّكّْ غَارْسنْ إِرقَّاسنْ، غَارْ \add ثمُّورْثْ ن\add* إِكَالْذَانِييّنْ.
\v 17 ؤُسِينْ-د غَارسْ أَيْثْ ن بَابِيلْ مَاحنْذْ أَذْ طّْصنْ أَكِيذسْ ذِي قَامَا ن ثْمخْسَا ؤُشَا سّْخمْجنْ ت س فَارْقْ-شّْغڒْ نْسنْ ؤُشَا نتَّاثْ ثسّخْمجْ إِخفْ نّسْ زَّايْسنْ. \add خنِّي\add* إِڭّْوجْ خَاسنْ ڒعْمَارْ نّسْ.
\v 18 ثسّفْسذْ نتَّاثْ إِخفْ نّسْ س بْطَايْطَايْ ؤُشَا ثسّْعَارَّا ڒْعَارْ نّسْ. \add خنِّي\add* إِڭّْوجْ خَاسْ ڒعْمَارْ إِنُو أَمْ مَامّشْ ثُوغَا إِڭّْوجْ ڒعْمَارْ إِنُو ؤُڒَا خْ ؤُتْشْمَاسْ.
\v 19 ثسّفْسذْ إِخفْ نّسْ أَطَّاسْ ؤُمِي ثعْقڒْ خْ وُوسَّانْ ن ثمْژِي نّسْ ڒَامِي ثُوغَا ثسّفْسذْ إِخفْ نّسْ ذِي ثمُّورْثْ ن مِيصْرَا.
\v 20 نتَّاثْ ثعْشقْ إِنِّي ت إِتّخْسنْ، إِنِّي أَيْسُومْ نْسنْ أَمْ ويْسُومْ ن إِغْيَاڒْ ؤُ إِنِّي أَذْعَاقْ نْسنْ أَمْ وذْعَاقْ ن إِيْسَانْ.
\v 21 أَقَا ثعْقبْ-د غَارْ ڒفْضِيهثْ ن ثمْژِي نّمْ، أَڒَامِي إِمِيصْرِييّنْ حَاذَانْ إِذْمَارنْ نّمْ ن ثمْژِي.“
\m 
\v 22 ”س ؤُيَا، ؤُهُولِيبَا، أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ’خْزَارْ، نشّْ أَذْ خَامْ سّكَّارغْ إِنِّي شمْ إِتّخْسنْ إِ خْ ثُوغَا إِڭّْوجْ ڒعْمَارْ نّمْ ؤُشَا أَذْ ڭّغْ أَذْ خَامْ د-أَسنْ زڭْ ونّضْ نّمْ:
\v 23 ثَارْوَا ن بَابِيلْ ذ مَارَّا إِكَالْذَانِييّنْ، إِمحْضَاينْ ذ إِمْشنّْعنْ ذ ثَارْوَا ن ثَاصِيڒثْ ؤُ مَارَّا أَيْثْ ن أَشُّورْ أَكِيذْسنْ، إِحُوذْرِييّنْ إِجبّْذنْ مژْرِي، لْوُولَاثْ، مَارَّا نِيثْنِي ذ إِمْضبَّارنْ، إِنغْرَافنْ \add ن ڒْعسْكَارْ\add* ذ يرْيَازنْ س يِيسمْ، أَقَا مَارَّا نِيثْنِي ذ إِمْنَاينْ إِنِّي ينْيِينْ خْ ييْسَانْ.
\v 24 نِيثْنِي أَذْ خَامْ د-ؤُسِينْ س إِكَارُّوثنْ إِ ؤُمنْغِي أَكْ-ذ ثْجَارَّارِينْ إِقَارْقْبنْ ؤُ س إِجّْ ن وڭْرَاوْ ن ڒڭْنُوسْ، س ثْسدَّارِييِينْ \add ن ؤُعسْكَارِي\add* ثِيمقّْرَانِينْ ذ ثْسدَّارِييِينْ ثِيمژْيَانِينْ، ؤُڒَا س لْكَاسْكْ خْ ؤُزدْجِيفْ. نِيثْنِي أَذْ سّْبدّنْ إِخفْ نْسنْ ذڭْ ونّضْ نّمْ ؤُ نشّْ أَذْ أَسنْ وْشغْ دّعْوثْ ؤُ نِيثْنِي أَذْ شمْ حكْمنْ عْلَاحْسَابْ شَّارِيعَا نْسنْ.
\v 25 نشّْ أَذْ ڭّغْ ثُوسْمِي إِنُو \add إِقدّْسنْ\add* ضِيدّْ إِ شمْ ؤُشَا نِيثْنِي أَذْ زَّايمْ ڭّنْ س وسْعَارْ. نِيثْنِي أَذْ قّْسنْ ثِينْزَارِينْ نّمْ ذ ثِيطَّاوِينْ نّمْ ؤُشَا مِينْ زَّايمْ إِقِّيمنْ أَذْ إِوْضَا س سِّيفْ. نِيثْنِي أَذْ كّْسنْ إِحنْجِيرنْ نّمْ ذ يسِّيمْ نّمْ ؤُشَا مِينْ إِقِّيمنْ أَذْ إِتّْوَاشّْ س ثْمسِّي.
\v 26 أَذْ كّْسنْ أَرُّوضْ نّمْ ؤُشَا أَذْ كّْسنْ ڒهْزُوطْ نّمْ. \x ◘ \xo 23:‏26 \xt حِز. 16‏:‏39\x*
\v 27 \add أَمُّو\add* إِ غَا سّْبدّغْ ڒفْضِيحثْ نّمْ ؤُڒَا ذ فَارْقْ-شّْغڒْ نّمْ زِي ثمُّورْثْ ن مِيصْرَا ؤُشَا وَارْ غَارْسنْ ثسّْڭِيعّْذذْ عَاذْ ثِيطَّاوِينْ نّمْ ؤُ وَارْ ثِيذَارذْ عَاذْ مِيصْرَا.‘
\v 28 مِينْزِي أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ’خْزَارْ، نشّْ أَذْ شمْ ڭّغْ ذڭْ ؤُفُوسْ ن يِينِّي شمْ إِشَارّْهنْ، ذڭْ ؤُفُوسْ ن يِينِّي إِ خْ ثُوغَا إِڭّْوجْ ڒعْمَارْ نّمْ. \x ◘ \xo 23:‏28 \xt حِز. 16‏:‏37، حِز. 23‏:‏17\x*
\v 29 أَذْ زَّايمْ ڭّنْ أَمْ وشْرَاهْ نْسنْ ؤُ أَذْ كّْسنْ مَارَّا إِ ؤُمِي ثَارْبْرذْ ؤُشَا أَذْ شمْ جّنْ أَوَارْنِي أَسنْ ثتّْوَاعَارِّيذْ ذ ثُوعَارْيَانْثْ أَڒَامِي إِتّْوَاعَارَّا ڒْعَارْ ن فَارْقْ-شّْغڒْ نّمْ ؤُڒَا ذ ڒفْضِيهثْ نّمْ ذ فَارْقْ-شّْغڒْ نّمْ. \x ◘ \xo 23:‏29 \xt حِز. 16‏:‏39، حِز. 23‏:‏25، 26\x*
\v 30 أَذْ زَّايمْ ڭّنْ أَيَا مِينْزِي ثضْفَارذْ ڒڭْنُوسْ أَمْ إِڭُّورْ بْنَاذمْ أَوَارْنِي إِ ثمْغَارْثْ ن فَارْقْ-شّْغڒْ ؤُ مِينْزِي ثسّْخمْجذْ إِخفْ نّمْ س إِميْضَا نْ صَّانَامْ نْسنْ.
\v 31 ثُويُورذْ ذڭْ وبْرِيذْ ن ؤُتْشْمَامْ، ؤُشَا أَذْ أَمْ وْشغْ ڒْكَاسْ نّسْ ذڭْ ؤُفُوسْ نّمْ.‘ “
\m 
\v 32 ”أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي:
\b
\m \qt ’أَذْ ثسْوذْ ڒْكَاسْ ن ؤُتْشْمَامْ\qt*
\m \qt ونِّي يُودْجْغنْ ؤُ إِوسْعنْ،\qt*
\m \qt أَڒَامِي ڒْقدّْ نّسْ أَذْ يَارّْ \tl ڒْعذْيَانْ\tl*\qt*
\m \qt أَذْ \tl زَّايمْ\tl* ذهْشنْ س ڒْحڭْرَا\qt*
\m \qt ؤُ أَذْ \tl زَّايمْ\tl* سْثهْزَانْ.\qt*
\m 
\v 33 \qt أَذْ ثشُّورذْ س وسْشَارْ ذ وشْضَانْ.\qt*
\m \qt ڒْْكَاسْ ن ؤُتْشْمَامْ سَامَارْيَا ذ إِجّْ نْ ڒْكَاسْ\qt*
\m \qt ن ؤُنخْڒِيعْ ذ وَاردّدْجْ.\qt*
\m 
\v 34 \qt أَذْ ث ثسْوذْ ؤُشَا أَذْ ث ثْژمّذْ،\qt*
\m \qt أَذْ ثْغزّذْ شْقُوفْ نّسْ\qt*
\m \qt ؤُشَا أَذْ ثْقبْشذْ \tl زَّايسْ\tl* إِذْمَارنْ نّمْ،\qt*
\m \qt مِينْزِي نشّْ نِّيغْ \tl ث\tl*!‘،\qt*
\m \qt \tl أَمُّو إِ\tl* إِقَّارْ سِيذِي إِنُو، سِيذِي.\qt*
\m 
\v 35 \qt ’س ؤُيَا، أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي:\qt*
\m \qt ’ؤُمِي ذَايِي ثتُّوذْ ؤُشَا ثمّنْضَارذْ أَيِي\qt*
\m \qt أَوَارْنِي إِ وعْرُورْ نّمْ،\qt*
\m \qt س ؤُيَا إِتّْخصَّا شمْ\qt*
\m \qt أَذْ ثَارْبُوذْ س يِيخفْ نّمْ\qt*
\m \qt ؤُڒَا ذ ڒفْضِيحثْ نّمْ ذ فَارْقْ-شّْغڒْ نّمْ.‘ “\qt*\x ◘ \xo 23:‏35 \xt إِرْم. 2‏:‏32؛ 3‏:‏21؛ 13‏:‏25؛ 18‏:‏15؛ حِز. 22‏:‏12\x*
\b
\m 
\v 36 إِنَّا أَيِي سِيذِي: ”\add أَ\add* مِّيسْ ن بْنَاذمْ، مَا ثخْسذْ أَذْ ثْشَارّْعذْ ؤُهُولَا ذ ؤُهُولِيبَا؟ إِنِي أَسنْثْ \add خنِّي\add* جّْعَايفْ نْسنْثْ. \x ◘ \xo 23:‏36 \xt حِز. 20‏:‏4؛ 22‏:‏2\x*
\v 37 مِينْزِي زنَّانْثْ ؤُشَا إِذَامّنْ ڒصْقنْ غَارْ إِفَاسّنْ نْسنْثْ ؤُ زنَّانْثْ أَكْ-ذ إِميْضَا ن لْ-أَصْنَامْ نْسنْثْ. سنّجْ إِ ؤُيَا أَرِّينْثْ إِحنْجِيرنْ نْسنْثْ، إِنِّي ؤُرْونْثْ إِ نشّْ، أَذْ ژْوَانْ ثِيمسِّي ذ مَاشَّا إِ إِميْضَا ن لْ-أَصْنَامْ نْسنْثْ. \x ◘ \xo 23:‏37 \xt حِز. 16‏:‏21؛ 20‏:‏26، 31\x*
\v 38 مَارَّا أَيَا ڭِّينْثْ ذَايِي: \bd ذڭْ وَاسّْ نِّي\bd* سّْخمْجنْثْ نِيثنْثِي زَّاوشْثْ إِنُو إِقدّْسنْ ؤُشَا سّْعِيدْجْثنْثْ ؤُسَّانْ إِنُو ن سّبْثْ. \x ◘ \xo 23:‏38 \xt حِز. 22‏:‏8\x*
\v 39 مِينْزِي ؤُمِي غَارْصنْ إِ ثَارْوَا نْسنْثْ إِ إِميْضَا نْسنْثْ ن لْ-أَصْنَامْ، ؤُسِينْثْ-إِ-د \bd ذڭْ وَاسّْ نِّي\bd* سِيمَانْثْ نّسْ ذِي زَّاوشْثْ إِنُو إِقدّْسنْ مَاحنْذْ أَذْ ت سّْعِيدْجْثنْثْ. خْزَارْ، أَمُّو إِ ڭِّينْثْ ذِي ڒْوسْطْ ن ثَادَّارْثْ إِنُو. \x ◘ \xo 23:‏39 \xt 2 إِج. 21‏:‏4‏-‏7؛ حِز. 16‏:‏21، حِز. 20‏:‏13، 16\x*
\v 40 عَاذْ سّكّنْثْ خْ يرْيَازنْ إِ د-يُوسِينْ زِي ڒَاڭّْوَاجْ. سّكّنْ أَرقَّاسْ غَارْسنْ، ؤُ خْزَارْ، ؤُسِينْ-د نِيثْنِي، إِنِّي إِ خْ ثسِّيرْذذْ إِخفْ نّمْ، إِ خْ ثْكُولَارذْ ثِيطَّاوِينْ نّمْ ؤُشَا ثْهزْطذْ س ثلْوِيزْثْ.
\v 41 ثقِّيمذْ خْ إِجّْ ن ڒشْثُو يشْنَا، ثُوغَا زَّاثسْ طَّابْڒَا إِسّْوجْذنْ إِ خْ ثسَّارْسذْ ڒبْخُورْ إِنُو ذ زّشْثْ إِنُو. \x ◘ \xo 23:‏41 \xt أَوڒن. 7‏:‏17\x*
\v 42 \add ڒَْامِي\add* إِسُّوسمْ ڒْحسّْ ن ڒْغَاشِي إِنْهوْڒنْ \add نِّي ذِينْ\add* غَارسْ، تّْوَانذْهنْ إِسْكَارْجِييّنْ زِي ڒخْڒَا غَارْ يرْيَازنْ نِّي \add إِدْجَانْ\add* زِي ڒْغَاشِي ن إِوْذَانْ، ؤُشَا نِيثْنِي ڭِّينْ ثِيمقْيَاسِينْ غَارْ إِفَاسّنْ نْسنْثْ ؤُڒَا ذ إِجّْ ن ثَاجّْ إِزوّْقنْ خْ إِزدْجِيفنْ نْسنْثْ.
\v 43 \add خنِّي\add* نِّيغْ نشّْ: أَقَا أَثنْ زنَّانْ أَكْ-ذ إِشْثْ ن ثمْغَارْثْ ن فَارْقْ-شّْغڒْ دُّويْسَارنْ. ڒخُّو فَارْقْ-شّْغڒْ نّسْ سِيمَانْثْ نّسْ أَذْ إِسّفْسذْ إِخفْ نّسْ ؤُشَا نتَّاثْ \add ثُويُورْ أَكِيذسْ ذَايسْ\add*.
\v 44 نِيثْنِي ؤُذْفنْ خَاسْ أَمْ ؤُذْفنْ خْ إِشْثْ ن ثمْغَارْثْ ن فَارْقْ-شّْغڒْ. أَمُّو ؤُذْفنْ خْ ؤُهُولَا ؤُ خْ ؤُهُولِيبَا، ثِيمْغَارِينْ نِّي إِتّْوَافضْحنْ.
\v 45 إِرْيَازنْ إِسڭّْذنْ أَذْ ثنْثْ حكْمنْ عْلَاحْسَابْ ڒْحقّْ ن ثِينِّي إِزنَّانْ ؤُ عْلَاحْسَابْ ڒْحقّْ ن ثِينِّي إِسِّيزَّاڒنْ إِذَامّنْ، مِينْزِي نِيثنْثِي ذ ثِيمْغَارِينْ إِزنَّانْ ؤُشَا إِذَامّنْ ڒصْقنْ غَارْ إِفَاسّنْ نْسنْثْ.“ \x ◘ \xo 23:‏45 \xt حِز. 16‏:‏38\x*
\m 
\v 46 ”مِينْزِي أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ’نشّْ أَذْ خَاسنْثْ سّكَّارغْ إِجّْ ن وڭْرَاوْ ؤُشَا أَذْ ثنْثْ أَرّغْ ذ \add إِشْثْ ن ڒْقشْعثْ ن\add* ؤُنخْڒِيعْ ذ ثَاكشَّاضْثْ.
\v 47 أَڭْرَاوْ ن ڒْڭنْسْ أَذْ ثنْثْ يَارْجمْ ؤُشَا أَذْ ثنْثْ قضْعنْ س ڒسْيُوفْ. إِحنْجِيرنْ نْسنْثْ ذ ثْحنْجِيرِينْ نْسنْثْ أَذْ ثنْ نْغنْ ؤُشَا أَذْ سّْشمْضنْ ثُوذْرِينْ نْسنْثْ س ثْمسِّي. \x ◘ \xo 23:‏47 \xt حِز. 16‏:‏41\x*
\v 48 \add أَمُّو\add* إِ غَا سّْبدّغْ ڒفْضَايحْ نْسنْثْ ذِي ثمُّورْثْ أَڒَامِي غَا تّْوَاعڒْمنْثْ مَارَّا ثِيمْغَارِينْ ؤُشَا وَارْ تّڭّنْثْ عَاذْ أَمْ ڒفْضَايحْ نْسنْثْ.
\v 49 \add أَمُّو إِ\add* خَاكنْثْ غَا ڭّنْ ڒفْضِيحثْ نْكنْثْ ؤُشَا أَذْ ثَارْبُونْثْ دّْنُوبْ ن \add وعْبذْ ن\add* إِميْضَا نْكنْثْ ن لْ-أَصْنَامْ ؤُشَا أَذْ ثسّْننْثْ، أَقَا نشّْ سِيذِي ذ سِيذِي!‘ “ \x ◘ \xo 23:‏49 \xt حِز. 16‏:‏58. \x*
\b
\b
\c 24
\s1 ؤُرْشَالِيمْ ذ إِشْثْ ن مَارْمِيثَا ذَايسْ دّْرَا
\m 
\v 1 يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي \bd ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثسْعَا، ذڭْ ؤُيُورْ وِيسّْعشْرَا، ذڭْ \bdit وَاسّْ\bdit* وِيسّْعشْرَا ن ؤُيُورْ\bd*، إِنَّا:
\v 2 ”\add أَ\add* مِّيسْ ن بْنَاذمْ، أَرِي إِ يِيخفْ نّشْ إِسمْ ن أَسّْ-أَ، \add إِسمْ ن\add* أَسّْ ن يِيضَا. ذڭْ وَاسّْ-أَ نِّيثْ أَذْ إِحْصَارْ ؤُجدْجِيذْ ن بَابِيلْ ؤُرْشَالِيمْ.
\v 3 سِيوڒْ إِجّْ ن ؤُمذْيَا إِ ثَادَّارْثْ إِغوّْغنْ نِّي، إِنِي أَسنْ: ’أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي:
\b
\m \qt أڭّْ إِجْث ن ثيْذُورْثْ،\qt*
\m \qt أڭّْ إِ-ت ؤُشَا كبّْ ذَايسْ أَمَانْ.\qt* \x ◘ \xo 24:‏3 \xt إِرْم. 1‏:‏13\x*
\m 
\v 4 \qt أڭّْ ذَايسْ ثِيفتُّوثِينْ \tl ن ويْسُومْ\tl*،\qt*
\m \qt مَارَّا ثِيفتُّوثِينْ إِشْنَانْ،\qt*
\m \qt ثَامصَّاضْثْ ذ ثغْرُوضْثْ،\qt*
\m \qt عمَّارْ \tl إِ-ت\tl* س يغْسَانْ ذ لمْلِيحْ قَاعْ.\qt*
\m 
\v 5 \qt كْسِي لمْلِيحْ ن وُودْجِي\qt*
\m \qt ؤُشَا أَرّْ ؤُڒَا ذ أَكشُّوضْ سَاذُو نْسنْ.\qt*
\m \qt أجّْ أَذْ سهْذنْ \tl مَارَّا\tl* مْلِيحْ\qt*
\m \qt أَڒَامِي عَاذْ إِغْسَانْ نّسْ أَذْ ذَايسْ تّْوَاننَّانْ.‘ “\qt*
\b
\m 
\v 6 ”س ؤُيَا، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي:
\b
\m ’\bdit ؤُشْثْ خْ ثنْذِينْثْ ن إِذَامّنْ!\bdit*
\m \qt ثَايْذُورْثْ إِ زِي ڒخْمجْ نّسْ \tl عَاذْ\tl* ذَايسْ،\qt*
\m \qt ثنِّي زِي وَارْ يكِّيسْ ڒخْمجْ نّسْ!\qt*
\m \qt كّسْ زَّايسْ ثَافتُّوثْ\qt*
\m \qt أَوَارْنِي إِ ثْفتُّوثْ \tl نّغْنِي\tl*\qt*
\m \qt بْڒَا أَذْ خَاسْ ثڭِّيذْ ثَاقدُّوحْثْ.\qt* \x ◘ \xo 24:‏6 \xt حِز. 22‏:‏2\x*
\m 
\v 7 \qt مِينْزِي إِذَامّنْ نّسْ أَقَا ذِي ڒْوسْثْ نّسْ،\qt*
\m \qt ثسِّيزڒْ إِ-ثنْ خْ إِشْثْ ن ثصْضَارْثْ ثَاقشَّارْثْ.\qt*
\m \qt وَارْ ثنْ ثسِّيزِّيڒْ خْ ثمُّورْثْ\qt*
\m \qt مَاحنْذْ أَذْ ثنْ ثذِّيڒْ س ؤُشَاڒْ.\qt*
\m 
\v 8 \qt حِيمَا أَذْ إِتّْوَاسّكَّارْ وسْعَارْ،\qt*
\m \qt حِيمَا أَذْ يِيڒِي ونْقَامْ،\qt*
\m \qt ڭِّيغْ إِذَامّنْ إِ ثسِّيزّڒْ نتَّاثْ\qt*
\m \qt خْ ثصْضَارْثْ ثَاقشَّارْثْ،\qt*
\m \qt حِيمَا وَارْ دَّاڒنْ \tl إِذَامّنْ نّسْ\tl*.‘ “\qt*
\b
\m 
\v 9 ”س ؤُيَا، أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي:
\m \bdit ’ؤُشْثْ خْ ثنْذِينْثْ ن إِذَامّنْ!\bdit*
\m \qt نشّْ س يِيخفْ إِنُو أَذْ ڭّغْ أَقلِّيجْ ن ؤُكشُّوضْ\qt*
\m \tl إِ ؤُشعَّاڒْ ن ثْمسِّي إِمْغَارْ!\tl* \x ◘ \xo 24:‏9 \xt نَحُم. 3‏:‏1؛ حَاب. 2‏:‏12\x*
\m 
\v 10 \qt أَرْنِي أَكشُّوضْ، أجّْ ثِيمسِّي أَذْ ثَارغْ أَطَّاسْ،\qt*
\m \qt شنّفْ أَيْسُومْ مْلِيحْ\qt*
\m \qt ؤُشَا أجّْ أَخدْجضْ ن ڒبْژَارْ\qt*
\m \qt أَذْ إِتّخْتّخْ مْلِيحْ\qt*
\m \qt ؤُشَا أجّْ إِغْسَانْ أَذْ شمْضنْ.\qt*
\m 
\v 11 \qt أَرّْ خنِّي ثَايْذُورْثْ إِخْوَانْ \tl عَاوذْ\tl*\qt*
\m \qt خْ ڒفْحمْ نّسْ إِتّحْذُوذُوقنْ،\qt*
\m \qt حِيمَا أَذْ إِحْمَا أَذْ إِشْمضْ\qt*
\m \qt دّْرَا نّسْ ن نّْحَاسْ\qt*
\m \qt ؤُشَا أَذْ ثفْسِي زَّايسْ ثخْمُوجِي إِ ذَايسْ إِدْجَانْ\qt*
\m \qt \tl ؤُ خنِّي\tl* أَذْ إِتّْوَاقْضِي ڒخْمجْ.\qt*
\m 
\v 12 \qt \tl مَارَّا\tl* أَمَارّثْ أَقَا-ث ذِي بَاطڒْ.\qt*
\m \qt ڒخْمجْ نّسْ إِفيّْضنْ وَارْ د-إِفِّيغْ زَّايسْ.\qt*
\m \qt أَرّْ ڒخْمجْ نِّي ذِي ثْمسِّي!\qt*
\m 
\v 13 \qt ذِي ثخْمُوجِي نّمْ \add ثدْجِي\add* ڒفْضِيحثْ نّمْ،\qt*
\m \qt مِينْزِي نشّْ ثُوغَا خْسغْ أَذْ شمْ سِّيزذْڭغْ\qt*
\m \qt ؤُشَا \tl خنِّي\tl* وَارْ ثتّْوَاسِّيزْذِيڭذْ.\qt*
\m \qt خْ ؤُيَا وَارْ ثتّْوَاسِّيزْذِيڭذْ\qt*
\m \qt زِي ڒخْمجْ نّمْ\qt*
\m \qt أَڒْ خَامْ إِ غَا سِّيوْضغْ أَسْعَارْ إِنُو.\qt*
\m 
\v 14 \qt نشّْ، سِيذِي، سِّيوْڒغْ.\qt*
\m \qt أَذْ إِفّغْ ؤُ نشّْ أَذْ ث ڭّغْ.\qt*
\m \qt وَارْ سمْحغْ ذڭْ إِمرْوُوسَا\qt*
\m \qt ؤُ وَارْ زِّيدْجْزغْ ؤُ وَارْ نْذِيمغْ.\qt*
\m \qt أَذْ خَامْ حكْمنْ\qt*
\m \qt إِبْرِيذنْ نّمْ ذ ثْمڭَّا نّمْ!‘،\qt*
\m \tl أَمُّو إِ\tl* إِقَّارْ سِيذِي إِنُو، سِيذِي.“\x ◘ \xo 24:‏14 \xt حِز. 5‏:‏11؛ 23‏:‏24\x*
\b
\s1 ڒْموْثْ ن ثمْغَارْثْ ن حِيزْقِييَال
\m 
\v 15 يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا:
\v 16 ”\add أَ\add* مِّيسْ ن بْنَاذمْ، خْزَارْ، س إِشْثْ ن ثشْثِي نشّْ أَذْ كسّغْ مژْرِي نّشْ زَّاثْ إِ ثِيطَّاوِينْ نّشْ. وَارْ تّتّْرُو، وَارْ تّجِّي أَذْ ؤُزّْڒنْ إِمطَّاونْ نّشْ.
\v 17 سْغُويّْ ذڭْ ؤُهدّنْ، وَارْ شطّنْ خْ ؤُمتِّينْ. قّنْ أَرژّثْ نّشْ خَاكْ ؤُشَا أڭّْ ثِيسِيڒَا نّشْ ذڭْ إِضَارنْ نّشْ، ؤُ وَارْ تّْڒحِّيفْ أَشْڒَاغمْ غَارْ ؤُينْشِيشْ نِيغْ أَذْ ثشّذْ أَغْرُومْ نِّي د غَا يَاوْينْ إِوْذَانْ \add إِ وشْضَانْ\add*.“
\b
\m 
\v 18 غَارْ ثُوفُّوثْ سِّيوْڒغْ إِ ڒْڭنْسْ ؤُ غَارْ ثْمذِّيثْ ثمُّوثْ ثْمطُّوثْ إِنُو ؤُ ذِي ثْوشَّا ڭِّيغْ أَمْ مَامّشْ إِ ذ أَيِي إِتّْوَاوصَّا.
\m 
\v 19 إِنَّا أَيِي ڒْڭنْسْ: ”مَا وَارْ ثخْسذْ أَذْ أَنغْ ثسّشْنذْ مِينْ عْنَانْثْ ثْمسْڒَايِينْ-أَ، مَايمِّي إِ ثڭّذْ أَمُّو؟“
\v 20 نشّْ نِّيغْ أَسنْ: ”يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا:
\v 21 ’إِنِي إِ ثَادَّارْثْ ن إِسْرَائِيل: أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي! خْزَارْ، نشّْ أَذْ سّْعِيدْجْثغْ زَّاوشْثْ إِنُو إِقدّْسنْ \add ثنِّي ذ\add* أَعُودْجِي ن جّهْذْ نْومْ ذ ؤُمژْرِي ن ثِيطَّاوِينْ نْومْ ذ ڒهْزُوطْ إِ ڒعْمَارْ نْومْ، ؤُڒَا ذ إِحنْجِيرنْ نْومْ ذ ثْحنْجِيرِينْ نْومْ نِّي ثجِّيمْ ذِينْ أَذْ وْضَانْ س سِّيفْ.
\v 22 \add خنِّي\add* أَذْ ثڭّمْ أَمْ مَامّشْ ڭِّيغْ نشّْ. وَارْ ثتّْڒحِّيفمْ أَشْڒَاغمْ غَارْ ؤُينْشِيشْ ؤُشَا أَغْرُومْ \add إِ د-يِيوْينْ\add* إِرْيَازنْ، وَارْ \add ث\add* ثتّتّمْ.
\v 23 أَرژَّاثْ نْومْ أَذْ إِڒِينْثْ خْ إِزدْجِيفنْ نْومْ ؤُ سَانْذَالِييَاثْ نْومْ ذڭْ إِضَارنْ نْومْ. وَارْ ثْشطّْنمْ ؤُ وَارْ ثتّْرُومْ. أَذْ ثثحَّامْ ذِي ڒْمُوعْصِييّثْ نْومْ ؤُشَا أَذْ ثْوحْوحمْ إِجّنْ خْ ونّغْنِي. \x ◘ \xo 24:‏23 \xt حِز. 4‏:‏17\x*
\v 24 أَمُّو إِ غَا يِيڒِي حِيزْقِييَالْ ذ ڒعْڒَامثْ ن ڒعْجبْ إِ كنِّيوْ. أَذْ ثڭّمْ نِيشَانْ أَمْ مَامّشْ إِڭَّا نتَّا. خْمِي د غَا يَاسْ دّڭَّا، أَذْ ثسّْنمْ، بلِّي نشّْ سِيذِي، ذ سِيذِي.‘ “ \x ◘ \xo 24:‏24 \xt حِز. 12‏:‏6\x*
\m 
\v 25 ”ؤُشَا شكْ، \add أَ\add* مِّيسْ ن بْنَاذمْ، مَا وَارْ إِتِّيڒِي أَقَا ذڭْ وَاسّْ إِ زَّايْسنْ إِ غَا كسّغْ لْبُورْجْ نْسنْ، ڒفْرَاحثْ خْ ثلْوِيزْثْ نْسنْ، ؤُڒَا ذ مژْرِي ن ثِيطَّاوِينْ نْسنْ ذ إِحنْجِيرنْ ذ ثْحنْجِيرِينْ نْسنْ نِّي يَاربُّونْ نِيثْنِي ذڭْ وُوڒْ،
\v 26 أَقَا \bd ذڭْ وَاسّْ نِّي\bd* سِيمَانْثْ نّسْ أَذْ غَاركْ د-يَاسْ إِجّنْ ونِّي يَاروْڒنْ مَاحنْذْ أَذْ يڭّْ ثْنَاينْ ن إِمزُّوغنْ نّشْ أَذْ سْڒنْ \add ؤُيَا\add*.
\v 27 \bd ذڭْ وَاسّْ نِّي\bd* أَذْ يَارْزمْ ؤُقمُّومْ نّشْ أَكْ-ذ \add ؤُقمُّومْ\add* ن ونِّي يَاروْڒنْ ؤُشَا أَذْ ثسِّيوْڒذْ، وَارْ ثتِّيڒِيذْ عَاذْ ذ أَيْنَاوْ. شكْ أَذْ أَسنْ ثِيڒِيذْ ذ ڒعْڒَامثْ نْ ڒعْجبْ ؤُشَا نِيثْنِي أَذْ سّْننْ بلِّي نشّْ ذ سِيذِي.“
\b
\b
\c 25
\s1 أَوَاڒْ ضِيدّْ إِ أَيْثْ ن عَامُّونْ
\m 
\v 1 يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا:
\v 2 ”\add أَ\add* مِّيسْ ن بْنَاذمْ، أَرّْ ؤُذمْ نّشْ غَارْ \bd أَيْثْ ن عَامُّونْ\bd* ؤُشَا نَابّْ خَاسنْ. \x ◘ \xo 25:‏2 \xt إِرْم. 49‏:‏1 \x*
\v 3 إِنِي إِ أَيْثْ نْ عَامُّونْ: ’سْڒمْ إِ وَاوَاڒْ ن سِيذِي إِنُو، سِيذِي! أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ؤُمِي ثنِّيذْ ’يَا، أَيُوزْ!‘ خْ زَّاوشْثْ إِنُو إِقدّْسنْ ؤُمِي ت سّْعِيدْجْثنْ، ؤُ خْ ثمُّورْثْ ن إِسْرَائِيل ؤُمِي ت أَردّْدْجنْ، ؤُڒَا خْ ثَادَّارْثْ ن يَاهُوذَا ڒَامِي ثنْ إِوْينْ غَارْ لْمنْفَا،
\v 4 س ؤُيَا، خْزَارْ، نشّْ أَذْ وْشغْ شمْ \add أَ، ثَامُّورْثْ ن عَامُّونْ\add* ذ ثَاسْغَارْثْ إِ يِينِّي د-يُوسِينْ زِي شَّارْقْ ؤُشَا نِيثْنِي أَذْ ڭّنْ ڒمْرَاڭحْ نْسنْ ذَايمْ ؤُشَا أَذْ أَرّنْ ثِيزذِّيغِينْ نْسنْ ذَايمْ. نِيثْنِي أَذْ شّنْ ڒْغِيدْجثْ نّمْ ؤُشَا أَذْ سْونْ أَشفَّايْ نّمْ. \f ◼ \fr 25:‏4 \ft \bd ’ذَايمْ‘\bd* - إِخْسْ أَذْ يِينِي ’ذِي ثمُّورْثْ. \bd ’ڒْغِيدْجثْ نّمْ‘\bd* - إِخْسْ أَذْ يِينِي ’ڒْغِيدْجثْ ن ثمُّورْثْ‘.\f*
\v 5 نشّْ أَذْ ڭّغْ رَابَّا ذ أَمْشَانْ ن أَرَّاحثْ إِ إِڒغْمَانْ ؤُشَا \add ثَامُّورْثْ ن\add* أَيْثْ ن عَامُّونْ ذ دّْمَانِي ن وَاريّحْ إِ وُودْجِي ؤُشَا كنِّيوْ أَذْ ثسّْنمْ بلِّي نشّْ ذ سِيذِي.‘
\v 6 مِينْزِي أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ’ؤُمِي ثوْثِيذْ إِفَاسّنْ نّشْ إِجّْ ذڭْ ونّغْنِي \add س ڒفْرَاحثْ\add*، ثذْزذْ س ؤُضَارْ ؤُ ثْفَارْحذْ س مَارَّا نّْفَاخثْ نّشْ ذِي ڒعْمَارْ خْ ثمُّورْثْ ن إِسْرَائِيل،
\v 7 س ؤُيَا، خْزَارْ، نشّْ أَذْ سّْوِيژّْضغْ أَفُوسْ إِنُو ضِّيذْ نّشْ ؤُشَا أَذْ شكْ أَرّغْ ذ ثَاكشَّاضْثْ إِ ڒڭْنُوسْ ؤُ أَذْ شكْ قضْعغْ زِي جَارْ ڒڭْنُوسْ ؤُشَا أَذْ شكْ ثحِّيغْ زِي ثمُّورَا. أَذْ شكْ أَردّْدْجغْ ؤُشَا أَذْ ثسّْنذْ أَقَا نشّْ ذ سِيذِي.‘ “
\b
\s1 أَوَاڒْ ضِيدّْ إِ مُوآبَ
\m 
\v 8 ”أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ’ؤُمِي \bd مُوآبَ\bd* ذ سَاعِيرْ قَّارنْ: خْزَارْ، ثَادَّارْثْ ن يَاهُوذَا \add ثدْجَا\add* أَمْ مَارَّا ڒڭْنُوسْ!، \x ◘ \xo 25:‏8 \xt إِرْم. 48‏:‏1‏-‏49‏:‏7‏-‏22\x*
\v 9 س ؤُيَا، خْزَارْ، نشّْ أَذْ أَرْزْمغْ أَغزْذِيسْ ن زَّاثْ ن مُوآبَ، زِي ثْندَّامْ، زِي ثْندَّامْ نّسْ نِّي \add إِدْجَانْ\add* غَارْ طَّارْفْ قَاعْ \add ن ثمُّورْثْ نّسْ\add*، ثِينِّي ذ ثَالْوِيزْثْ ن ثمُّورْثْ: بَايْثْ-يَاشِيمُوثْ، بَاعْلْ-مَاعُونْ ذ قَارْيَاثَايِيمْ.
\v 10 نشّْ أَذْ ثنْثْ وْشغْ ذ ثَاسْغَارْثْ إِ أَيْثْ ن شَّارْقْ \add جْمِيعْ\add* أَكْ-ذ \add ثمُّورْثْ ن\add* أَيْثْ ن عَامُّونْ، حِيمَا وَارْ ثتِّيڒِي \add عَاذْ\add* ڒِيذَارثْ ذڭْ أَيْثْ ن عَامُّونْ جَارْ ڒڭْنُوسْ. \x ◘ \xo 25:‏10 \xt حِز. 21‏:‏37\x*
\v 11 أَذْ سِّيوْضغْ ڒحْكَامَاثْ خْ مُوآبَ ؤُ نِيثْنِي أَذْ سّْننْ، بلِّي نشّْ ذ سِيذِي.‘ “
\b
\s1 أَوَاڒْ ضِيدّْ إِ إِذُومْ
\m 
\v 12 ”أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ’ؤُمِي \bd إِذُومْ\bd* إِڭَّا س نّقْمثْ وَاهَا ضِيدّْ إِ ثَادَّارْثْ ن يَاهُوذَا ؤُشَا ؤُمِي إِذْوڒْ ذَايْسنْ ڒْعِيبْ أَطَّاسْ ؤُمِي زَّايْسنْ نقْمنْ،
\v 13 س ؤُيَا، أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي، أَذْ سّْوِيژّْضغْ أَفُوسْ إِنُو ضِيدّْ إِ إِذُومْ ؤُشَا أَذْ زَّايسْ قضْعغْ بْنَاذمْ ذ ڒْمَاڒْ ؤُشَا أَذْ ث ڭّغْ ذ ڒْخِيرْبثْ زِي ثَايْمَانْ، ؤُشَا أَذْ وْضَانْ س سِّيفْ أَڒْ ذَاذَانْ.
\v 14 نشّْ أَذْ سِّيوْضغْ نّقْمثْ إِنُو خْ إِذُومْ س ؤُفُوسْ ن ڒْڭنْسْ إِنُو إِسْرَائِيل. ؤُ نِيثْنِي أَذْ ڭّنْ أَكْ-ذ إِذُومْ عْلَاحْسَابْ أَغْضَابْ إِنُو ؤُ عْلَاحْسَابْ أَسْعَارْ إِنُو، أَذْ سّْننْ نّقْمثْ إِنُو!‘، إِقَّارْ سِيذِي إِنُو، سِيذِي.“
\b
\s1 أَوَاڒْ ضِيدّْ إِ إِفِيلِيسْطِينِييّنْ
\m 
\v 15 ”أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ’ؤُمِي \bd إِفِيلِيسْطِينِييّنْ\bd* ڭِّينْ س نّقْمثْ ؤُ نقْمنْ س نّْفَاخثْ ن وُوڒْ ؤُمِي أَردّْدْجنْ نِيثْنِي زِي ڒعْذَاوثْ إِتّْذُومَانْ،
\v 16 س ؤُيَا، أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: خْزَارْ، نشّْ أَذْ سّْوِيژّْضغْ أَفُوسْ إِنُو ضِيدّْ إِ إِفِيلِيسْطِينِييّنْ ؤُشَا أَذْ قضْعغْ إِكَارِيثِييّنْ ؤُشَا أَذْ أَردّْدْجغْ مِينْ إِقِّيمنْ خْ ثْمَا ن ڒبْحَارْ. \f ◼ \fr 25:‏16 \ft \bd ’ڒبْحَارْ‘\bd* - نِيغْ ’إِلْ‘.\f*
\v 17 نّقْمَاثْ ثِيمقّْرَانِينْ س لعْقَايبْ إِقسْحنْ أَذْ ذَايْسنْ ڭّغْ ؤُ نِيثْنِي أَذْ سّْننْ بلِّي نشّْ ذ سِيذِي، خْمِي غَا كمّْڒغْ نّقْمثْ إِنُو ذَايْسنْ.‘ “
\b
\b
\c 26
\s1 أَوَاڒْ ضِيدّْ إِ صُورْ
\m 
\v 1 \bd ذڭْ ؤُسڭّْوَاسْ وِيسّْ حِيطْعَاشْ، ذڭْ \bdit وَاسّْ\bdit* أَمزْوَارُو ن ؤُيُورْ\bd* إِمْسَارْ بلِّي يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا:
\v 2 ”\add أَ\add* مِّيسْ ن بْنَاذمْ، ؤُمِي ثنَّا \add ثنْذِينْثْ ن\add* صُورْ خْ ؤُرْشَالِيمْ: ’يَا أَيُوزْ، أَقَا ثتّْوَارژَّا، ثَاوَّارْثْ ن ڒڭْنُوسْ ثتّْوَارْزمْ غَارِي. أَذْ غَارِي يِيڒِي \add وَاڭْڒَا\add* أَطَّاسْ، ؤُمِي نتَّاثْ ثتّْوَاردّدْجْ \add ڒخُّو\add*!‘،
\v 3 س ؤُيَا، أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ’خْزَارْ، نشّْ دْجِيغْ ضِيدّْ نّشْ، \add أَ\add* صُورْ! أَذْ خَامْ سّكَّارغْ أَطَّاسْ ن ڒڭْنُوسْ، أَمْ مَامّخْ إِسّْڭعّذْ ڒبْحَارْ ڒمْوَاجْ نّسْ.
\v 4 نِيثْنِي أَذْ أَردّْدْجنْ ڒهْيُوضْ ن \add ثنْذِينْثْ ن\add* صُورْ ؤُشَا أَذْ أَرْژنْ صُّومْعَاثْ نّسْ ؤُ نشّْ أَذْ خَاسْ كّْسغْ أَشَاڒْ نّسْ ؤُشَا أَذْ ت أَرّغْ ذ ثَاصْضَارْثْ ثَاقشَّارْثْ.
\v 5 أَذْ \add ذِينْ\add* ثِيڒِي ذِي ڒْوسْثْ ن ڒبْحَارْ، مَاحنْذْ أَذْ خَاسْ بزّْعنْ ثِيرَاشِّيوِينْ إِ ثْنيْمَارْثْ ن إِسڒْمَانْ، مِينْزِي نشّْ نِّيغْ \add ث\add*، أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي، ؤُ نتَّاثْ أَذْ ثِيڒِي ذ ثَاكشَّاضْثْ إِ ڒڭْنُوسْ.
\v 6 يسِّيسْ نِّي \add إِدْجَانْ\add* ذڭْ إِيَّارْ \add خْ ڒْبَارّْ\add*، أَذْ تّْوَانْغنْثْ س سِّيفْ ؤُ نِيثْنِي أَذْ سّْننْ بلِّي نشّْ ذ سِيذِي.‘ “
\m 
\v 7 ”مِينْزِي أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ’خْزَارْ، زِي شَّامَالْ أَذْ سِّيوْضغْ نابُوخَاذْرَاصَّارْ، أَجدْجِيذْ ن بَابِيلْ، أَجدْجِيذْ ن إِجدْجِيذنْ، خْ صُورْ أَكْ-ذ إِيْسَانْ ذ إِكَارُّوثنْ، أَكْ-ذ إِمْنَاينْ ؤُ أَكْ-ذ إِجّْ ن وڭْرَاوْ ذ إِجّْ ن ڒْڭنْسْ أَمقّْرَانْ. \f ◼ \fr 26:‏7 \ft \bd ’أَكْ-ذ إِيْسَانْ ذ إِكَارُّوثنْ‘\bd* - س ثْعِيبْرَانِيثْ ’أَكْ-ذ ؤُيِيسْ ذ ؤُكَارُّو‘.\f*
\v 8 أَذْ إِنغْ س سِّيفْ يسِّيمْ نِّي يدْجَانْ ذڭْ إِيَّارْ، أَذْ إِسّْبدّْ ڒْقَامَّاثْ ضِيدّْ نّمْ، أَذْ إِبْنَا إِجّْ ن وشْبَارْ ضِيدّْ نّمْ ؤُ أَذْ إِسّْبدّْ ضِيدّْ نّمْ إِشْثْ ن ثسْقِيفْثْ \add تّْوَاڭّنْ ت س\add* ثْسدَّارِييِينْ ثِيمقّْرَانِينْ.
\v 9 نتَّا أَذْ إِڭّْ إِشَارِّييّنْ ن وذْهَامْ ضِيدّْ إِ ڒحْيُوضْ نّمْ ؤُشَا أَذْ إِسّْحيّذْ سُّومْعَاثْ نّمْ س ڒسْيُوفْ نّسْ.
\v 10 أَذْ أَمْ إِذڒْ ڒعْجَاجْ ن ؤُبَارُّو ن ييْسَانْ نّسْ، س زّْهِيرْ ن إِمْنَاينْ ذ ؤُقَارْقبْ ن ثْجَارَّارِينْ ذ \add دّْرِيزْ ن\add* إِكَارُّوثنْ أَذْ أَرْجِيجنْ ڒحْيُوضْ نّمْ خْمِي غَا يَاذفْ خْ ثوُّورَا نّمْ أَمْ د-ؤُذْفنْ خْ إِشْثْ ن ثنْذِينْثْ ثتّْوَاهْذمْ.
\v 11 س إِشُوشَّا ن ييْسَانْ نّسْ أَذْ إِعْفسْ خْ إِبْرِيذنْ نّمْ مَارَّا، أَذْ إِنغْ ڒْڭنْسْ نّمْ س سِّيفْ ؤُشَا إِپِيلَارنْ نّمْ إِجهْذنْ \add إِقدّْسنْ\add* أَذْ وْضَانْ غَارْ ثمُّورْثْ. \f ◼ \fr 26:‏11 \ft \bd ’إِبِيلَارنْ نّكْ إِجهْذنْ‘\bd* - أَقَا-ثنْ ذ إِبِيلَارنْ ن وعْبذْ ن بَاعَالْ ذِي زَّاوشْثْ ن هِيرْكُولِيسْ ذِي صُورْ. وَارْ دْجِينْ ذ ڒخْيَاڒَاثْ ن صَّانَامْ مَاشَا ذ إِبِيلَارنْ.\f*  \x ◘ \xo 26:‏11 \xt إِشا. 5‏:‏28؛ إِرْم. 47‏:‏3\x*
\v 12 نِيثْنِي أَذْ أَشَارنْ أَڭْڒَا نّمْ أَذْ كشّْضنْ ثَاسبَّابْثْ نّمْ، أَذْ أَردّْدْجنْ ڒحْيُوضْ نّمْ، أَذْغضْڒنْ ثُوذْرِينْ نّمْ إِعِيزّنْ. إِژْرَا نّمْ ذ ثْحنْيَا ن ؤُكشُّوذْ نّمْ ذ ڒعْجَاجْ نّمْ أَذْ ثنْ مّنْضَارنْ ذڭْ وَامَانْ.
\v 13 \add أَمُّو\add* إِ غَا سّسْقَارغْ دّْرِيزْ ن إِژْڒَانْ نّمْ ؤُشَا ڒْحسّْ ن ڒْڭَامْبْرِييَاثْ نّمْ وَارْ إِتّْوَاسڒْ عَاذْ. \x ◘ \xo 26:‏13 \xt إِشا. 24‏:‏7، 8؛ إِرْم. 7‏:‏34؛ 16‏:‏9\x*
\v 14 أَذْ شمْ أَرّغْ ذ ثَاصْضَارْثْ ثَاقشَّارْثْ إِ وفْسَارْ ن ثْرَاشِّيوِينْ إِ ثْنيْمَارْثْ ن إِسڒْمَانْ.عمَّارْصْ أَذْ ثتّْوَابْنِيذْ \add عَاوذْ\add*، مِينْزِي نشّْ، سِيذِي، نِّيغْ ث!، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي.‘ “
\b
\m 
\v 15 ”أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي إِ \add ثڭْزِيرْثْ ن\add* صُورْ: ’مَا وَارْ تَّارْجِيجِينْثْ ثڭْزِيرِينْ س ڒْحسّْ ن ؤُوطُّو نّمْ، خْمِي سّْبُوعْرُورنْ إِنِّي إِتّْوَايزّْمنْ إِ ڒْموْثْ، خْمِي غَا ثمْسَارْ إِشْثْ ن ثشْثِي إِنقّنْ ذِي ڒْوسْثْ نّمْ؟
\v 16 مَارَّا ڒْحُوكَّامْ ن ڒبْحَارْ أَذْ د-هْوَانْ زِي ڒكْرَاسِي نْسنْ إِڭلّْذنْ ؤُشَا أَذْغضْڒنْ إِحَاشنْ نْسنْ، أَذْ كّْسنْ أَرُّوضْ نْسنْ إِبُورْضَارنْ س ثِينْثَاثْ إِفَارْزنْ. أَذْ ڒحّْفنْ س ڒْعُورّثْ، أَذْ قِّيمنْ خْ ثمُّورْثْ ؤُشَا أَذْ أَرْجِيجنْ ذِي كُوڒْ ڒْوقْثْ ؤُشَا أَذْ خَامْ نْخڒْعنْ.
\v 17 أَذْ خَامْ سِّيڒْينْ إِجّْ ن وزْڒِي ن وشْضَانْ، أَذْ أَمْ إِنِينْ:
\b
\m \qt مَامّشْ ثتّْوَاثحِّيذْ،\qt*
\m \qt \tl أَ شمْ\tl*، ثنِّي إِ ذِي زذْغنْ\qt*
\m \qt إِنِّي \tl د-إِفّْغنْ\tl* زِي ڒبْحَارْ،\qt*
\m \qt \tl أَ شمْ\tl* ثَانْذِينْثْ إِشنّْعنْ،\qt*
\m \qt ثنِّي إِجهْذنْ أَطَّاسْ ذِي ڒبْحَارْ،\qt*
\m \qt \tl شمْ،\tl* \tl أَ صُورْ\tl* ذ إِمزْذَاغْ نّسْ،\qt*
\m \qt ثنِّي إِتّڭّنْ أَرْجفْ جَارْ أَسنْ\qt*
\m \qt ذِي مَارَّا إِنِّي ذَايسْ إِزذْغنْ.\qt* \f ◼ \fr 26:‏17 \ft \bd ’إِنِّي \bdit د-إِفّْغنْ\bdit* زِي ڒبْحَارْ‘\bd* - إِمزْذَاغْ ن صُورْ ثُوغَا أَرْوسنْ ذڭْ إِمزْذَاغْ نْ ڒبْحَارْ مِينْزِي ثُوغَا ثَاڭْزِيرْثْ ثْڭَاعّذْ-د زِي ڒبْحَارْ أَكْ-ذ إِمزْذَاغْ نّسْ ؤُمِي غَارسْ د-ثخْزَارذْ زِي ڒَاڭّْوَاجْ، زِي ثمُّورْثْ. \bd ’ثنِّي إِتّڭّنْ أَرْجفْ ... ‘\bd* - مَانْ أَيَا وَارْ إِخْسْ أَذْ يِينِي أَقَا إِمزْذَاغْ ن صُورْ ثُوغَا سِّيڭّْوِيذنْ إِجّْ زڭْ ونّغْنِي، مَاشَا، ؤُمِي غَارْسنْ إِجّْ ن إِسمْ إِشنْعنْ زِي سِّيبّثْ ن ثْسبَّابْثْ نْسنْ ذِي مَارَّا دُّونشْثْ، أَقَا أَرْجْفنْ ؤُمِي ژْرِينْ نِيثْنِي شَّانْ ن ثنْذِينْثْ نْسنْ، ؤُشَا ؤُڒَاونْ نْسنْ ذوْڒنْ شُّورنْ س ؤُوقَّارْ أَڒَامِي ثَانْذِينْثْ ثْحوّسْ إِ-ثنْ س يِيسمْ نّسْ إِشنْعنْ.\f*  \x ◘ \xo 26:‏17 \xt أَسَا. 18‏:‏9‏-‏19\x*
\m 
\v 18 \qt ڒخُّو أَذْ أَرْجِيجنْثْ ثڭْزِيرِينْ\qt*
\m \qt ذڭْ وَاسّْ ن ؤُوطُّو نّمْ،\qt*
\m \qt \tl وَاهْ\tl* ثِيڭْزِيرِينْ ذِي ڒبْحَارْ\qt*
\m \qt أَذْ نّْخڒْعنْثْ س ؤُنڭَّارْ نّشْ.‘ “\qt*
\b
\m 
\v 19 ”مِينْزِي أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ’خْمِي نشّْ أَذْ شمْ يَارّغْ ذ ثَانْذِينْثْ إِتّْوَارذْدْجنْ أَمْ ثْندَّامْ نِّي وَارْ إِزْذِيغنْ، خْمِي خَامْ إِ غَا سِّيوْضغْ \add أَمَانْ\add* إِهوْڒنْ ؤُشَا \add خْمِي\add* أَطَّاسْ ن وَامَانْ أَذْ شمْ ذْڒنْ،
\v 20 \add خنِّي\add* أَذْ شمْ د-سّهْوِيغْ أَكْ-ذ يِينِّي د-إِهْوَانْ ذڭْ وحْفُورْ \add ن ونْضڒْ\add*، غَارْ ڒْڭنْسْ ن ڒْوقْثْ ن زِيشْ. أَذْ شكْ سَّارْسغْ ذِي ڒَادْجَاغْ ن ثمُّورْثْ، ذِي ڒْخِيرْبَاثْ ن ڒْوقْثْ ن زِيشْ، غَارْ إِنِّي د-إِهْوَانْ ذڭْ \add وحْفُورْ ن\add* ونْضڒْ، حِيمَا وَارْ ذَايمْ تِّيڒِينْ إِمزْذَاغْ عَاذْ. \add مَاشَا\add* ذِي ثمُّورْثْ ن يِينِّي إِدَّارنْ أَذْ وْشغْ ڒْعزّْ.
\v 21 أَذْ شمْ أَرّغْ ذ إِجّْ ن ؤُمذْيَا ن وَارْجفْ ؤُشَا وَارْ ثتِّيڒِيذْ \add عَاذْ\add*. أَذْ خَامْ أَرْزُونْ ؤُشَا وَارْ ثتّْوِيفِيذْعمَّارْصْ إِ ڒبْذَا!‘، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو سِيذِي.“
\b
\b
\c 27
\s1 إِزْڒِي ن وشْضَانْ خْ صُورْ
\m 
\v 1 يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا:
\v 2 ”شكْ، \add أَ\add* مِّيسْ ن بْنَاذمْ، سْڭعّذْ إِجّْ ن وژْرِي ن وشْضَانْ، خْ صُورْ.
\v 3 إِنِي إِ صُورْ، \add ثَانْذِينْثْ\add* إِ ذِينْ إِزدّْغنْ غَارْ ثوُّورَا ن ڒبْحَارْ، \add ثَانْذِينْثْ\add* نِّي إِتّْسبَّابنْ أَكْ-ذ ڒڭْنُوسْ \add نِّي إِزدّْغنْ\add* ذِي ثڭْزِيرِينْ أَطَّاسْ: ’أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي:
\b
\m \qt \tl أَ\tl* صُورْ، شمْ ثقَّارذْ:\qt*
\m \qt نشّْ أَقَا أَيِي نِيشَانْ ذڭْ وَاژْرِي!‘\qt* \x ◘ \xo 27:‏3 \xt حِز. 28‏:‏12\x*
\m 
\v 4 \qt إِسغْوَانْ \tl ن ؤُيڒْزِيمْ\tl* نّمْ\qt*
\m \qt أَقَا أَثنْ ذڭْ وُوڒْ ن ڒبْحُورْ،\qt*
\m \qt إِنِّي شمْ إِبْنَانْ\qt*
\m \qt أَقَا ڭِّينْ أَژْرِي نّمْ نِيشَانْ.\qt*
\m 
\v 5 \qt مَارَّا ثِيڒْوِيحِينْ ن ثْفڒْوِينْ ن ثْغَارُّوبَا نّمْ\qt*
\m \qt ڭِّينْ ثنْثْ إِ شمْ\qt*
\m \qt ذِي ثْنَاينْ زِي ثْشجُّورَا ن ؤُمرْزِي،\qt*
\m \qt إِوْينْ ثِيشجُّورَا ن ثنْڭلْثْ زِي لُوبْنَانْ،\qt*
\m \qt مَاحنْذْ أَذْ أَمْ ڭّنْ ثِيحنْيَا إِ ڒْبَاشَّاثْ.\qt* \f ◼ \fr 27:‏5 \ft \bd ’أَمرْزِي‘\bd* - نِيغْ ’أَمضْزِي‘.\f*
\m 
\v 6 \qt زِي ثْشجُّورَا ن ڒْبدْجُوضْ ن بَاشَانْ\qt*
\m \qt ڭِّينْ ڒمْقَاذفْ نّمْ\qt*،
\m \qt ڒْبَانْكُووَاثْ نّمْ \tl إِ إِقدَّافنْ\tl* أَقَا أَثنْثْ زِي ڒْعَاجْ\qt*
\m \qt إِتّْوَاڭّْ ذڭْ ؤُكشُّوذْ ن ثنْڭلْثْ،\qt*
\m \qt \tl إِوْينْ ث\tl* زِي ثڭْزِيرِينْ ن أَيْثْ ن كِيتِّيمْ.\qt* \f ◼ \fr 27:‏6 \ft \bd ’كِيتِّيمْ‘\bd* - إِخْسْ أَذْ يِينِي ’قُوبْرُوسْ‘.\f*  \x ◘ \xo 27:‏6 \xt إِشا. 2‏:‏13\x*
\m 
\v 7 \qt ڒْْبَاشّْ نّمْ ثُوغَا-ث س ڒقْطنْ أَزْذَاذْ زِي مِيصْرَا،\qt*
\m \qt خيّْضنْ ث س وَاطَّاسْ ن ثِينْثَاثْ.\qt*
\m \qt \tl ڒْْبَاشّْ\tl* ثُوغَا إِ شمْ ذ ثَاعدْجَانْثْ،\qt*
\m \qt ثَاسْقِيفْثْ ن ؤُقِيضُونْ نّمْ ثُوغَا-ت\qt*
\m \qt زڭْ \tl ؤُفِيڒُو\tl* ؤُذهْمَانِي ذ أَرْجُووَانِي\qt*
\m \qt زِي ثڭْزِيرِينْ ن إِلِيشَا.\qt*
\m 
\v 8 \qt إِمزْذَاغْ ن صِيذُونْ ؤُ ن أَرْوَاذْ ثُوغَا أَثنْ\qt*
\m \qt ذ إِقدَّافنْ نّمْ.\qt*
\m \qt إِمِيغِيسنْ نّمْ، \tl أَ\tl* صُورْ، نِّي ذَايمْ إِدْجَانْ،\qt*
\m \qt ثُوغَا أَثنْ ذ إِندَّاهنْ نّمْ.\qt*
\b
\m 
\v 9 \qt إِوسُّورَا ن جُوبَايْلْ ذ إِمِيغِيسنْ نّسْ\qt*
\m \qt ثُوغَا أَثنْ ذَايمْ،\qt*
\m \qt عدّْڒنْ \tl مَارَّا\tl* ثِيزَّا نّمْ.\qt*
\b
\m مَارَّا ثِيغَارُّوبَا نْ ڒبْحَارْ ذ إِبحْرِييّنْ نْسنْ ؤُسِينْ-د غَارمْ حِيمَا أَذْ كِيذمْ سبّْ\add أ\add*بنْ.
\m 
\v 10 أَيْثْ ن لْفُورْصْ، ن لُوذْ ؤُ ن فُوطْ ثُوغَا أَثنْ ذِي ڒْعسْكَارْ نّمْ، إِرْيَازنْ إِعسْكَارِييّنْ. ؤُيْڒنْ ذَايمْ ثَاسدَّارْثْ \add نْسنْ\add* ذ لْكَاسْكْ \add نْسنْ\add* ؤُشَا وْشِينْ أَمْ ڒْعزّْ.
\m 
\v 11 أَيْثْ ن أَرْوَاذْ ذ ڒْعسْكَارْ نّمْ ثُوغَا أَثنْ خْ ڒحْيُوضْ نّمْ ؤُشَا إِڭَامَّاذِييّنْ، \add أَيْثْ ن بُو-ثرْيَاسْثْ نّمْ\add*، \add بدّنْ\add* خْ سُّومْعَاثْ نّمْ. ثِيسدَّارِييّنْ نْسنْ إِقسْحنْ ن ؤُسڒْقِي إِ ثُوغَا ؤُيْڒنْثْ ذڭْ ونّضْ خْ ڒحْيُوضْ، أَرْنِينْثْ ذڭْ وَاژْرِي نّمْ أَطَّاسْ.
\m 
\v 12 ثَارْشِيسْ ثُوغَا ثتّْسبَّابْ أَكِيذمْ إِ سِّيبّثْ ن ؤُفيّضْ ن عْڒَامْ كُوڒْ إِڭڒْوَانْ. نِيثْنِي وْشِينْ أَمْ نُّوقَارْثْ، ؤُزَّاڒْ، أَسْثَانْيُو ذ ڒخْفِيفْ ذِي طّْوعْ \add ن سّڒْعثْ\add* نِّي \add ذ أَسنْ\add* ثزّنْزذْ.
\m 
\v 13 يَاوَانْ ذ ثُوبَالْ ذ مَاشِيخْ ثُوغَا أَثنْ ذ إِسبَّابنْ نّمْ. نِيثْنِي وْشِينْ أَمْ ڒعْمُورْ ن إِوْذَانْ ذ ڒقْشُوعْ ن نّْحَاسْ ذِي طّْوعْ ن سّڒْعثْ نّمْ.
\m 
\v 14 زِي ثَادَّارْثْ \add ن إِجدْجِيذنْ\add* ن ثُوجَارْمَا وْشِينْ أَمْ يِييْسَانْ ذ إِمْنَاينْ ذ إِسرْذَانْ ذِي طّْوعْ \add ن سّڒْعثْ\add* نِّي \add ذ أَسنْ\add* ثزّنْزذْ.
\m 
\v 15 أَرَّاوْ ن ذَاذَانْ ثُوغَا أَثنْ ذ إِسبَّابنْ ذِي طّْوعْ نّمْ. أَطَّاسْ ن ثڭْزِيرِينْ ثُوغَا خْسنْثْ أَذْ طّْفنْثْ سّڒْعثْ زڭْ ؤُفُوسْ نّمْ. ثِيغْمَاسْ ثِيمقّْرَانِينْ ن ڒْفِيڒْ ذ ؤُكشُّوضْ ن وبْنُوسْ أَرِّينْثْ أَمْ ثنْثْ-إِ-د ذ أَرِّيغَالُوثنْ. \f ◼ \fr 27:‏15 \ft \bd ’أَكشُّوضْ ن وبْنُوسْ‘\bd* - إِشْثْ ن مَارْكَا ن ؤُكشُّوضْ ذ ثَابَارْشَانْثْ نِّي إِوزْننْ كْثَارْ زڭْ وَامَانْ أَڒَامِي أَذْ د-إِهْوَا ؤُكشُّوضْ ن ’إِبْنُوسْ‘ ؤُمِي إِتّْوَامنْضَارْ ذڭْ وَامَانْ.\f*
\m 
\v 16 أَرَامْ ثُوغَا إِتّْسبَّابْ أَكِيذمْ خْ وَاطَّاسْ ن ڒقْشُوعْ إِ ثْصنّْعذْ. نِيثْنِي وْشِينْ أَمْ كَارْبُونْكلْ ذ أَجُورْوَانِي ذ لْبُورْضَا س ثِينْثَاثْ إِفَارْزنْ ذ ڒقْطنْ أَزْذَاذْ ذ ڒْمَارْجَانْ ذ ڒعْقَاقْ إِزڭّْوَاغنْ ذِي طّْوعْ ن سّڒْعثْ نِّي \add ذ أَسنْ ثْقدّْمذْ\add*.
\m 
\v 17 يَاهُوذَا ذ ثمُّورْثْ ن إِسْرَائِيل ثُوغَا تّْسبَّابنْ أَكِيذمْ. نِيثْنِي وْشِينْ أَمْ يِيمنْذِي زِي مِينِّيثْ ؤُڒَا ذ حَالَاوِيثْ، ثَامّنْثْ، زّشْثْ ذ بَالْسَامْ ذِي طّْوعْ ن سّڒْعثْ نّمْ.
\m 
\v 18 ذِيمَاشْقْ ثُوغَا إِتّْسبَّابْ أَكِيذمْ ذڭْ وَاطَّاسْ ن ڒقْشُوعْ إِ ثْصنّْعذْ، خْ مَارَّا إِڭڒْوَانْ نّمْ، س بِينُو ن خِيلْبُونْ ذ ثْضُوفْثْ ثَاشمْڒَاڒْثْ.
\m 
\v 19 ذِي طّْوعْ ن \add سّڒْعثْ\add* نِّي \add ذ أَسنْ\add* ثزّنْزذْ، وْشِينْ أَمْ وَاذَانْ ذ يَاوَانْ ؤُزَّاڒْ ن ومْزِيڒْ ذ قَاسِّييَا ذ ؤُغَانِيمْ أَحمُّومْ إِتّْفُوحنْ زِي ؤُزَالْ.
\m 
\v 20 ذَاذَانْ ثُوغَا إِتّْسبَّابْ أَكِيذمْ س ورُّوضْ ن ثْبَارْذِيوِينْ إِ ؤُندَّاهْ.
\m 
\v 21 إِعْرَابنْ \add ذِي ڒْوَاطَاثْ\add* ذ مَارَّا ڒْحُوكَّامْ ن قِيذَارْ ثُوغَا تّْسبَّابنْ أَكِيذمْ. ذڭْ إِزمْرَاونْ ذ إِشَارِّييّنْ ذ إِغَايْضنْ ثُوغَا تّْسبَّابنْ أَكِيذمْ.
\m 
\v 22 إِسبَّابنْ ن شَابَا ذ يِينِّي ن رَاعْمَا ثُوغَا أَثنْ ذ إِسبَّابنْ نّمْ. نِيثْنِي وْشِينْ ڒمْخيّرْ ن ڒعْطُورْ ذ عْڒَامْ كُوڒْ إِژْرَا إِغْڒَانْ ذ وُورغْ ذِي طّْوعْ ن سّڒْعَاثْ نِّي ذ أَسنْ ثْقدّْمذْ.
\m 
\v 23 حَارَانْ ذ كِينَّا ذ عَاذَانْ، إِسبَّابنْ ن شَابَا، أَشُّورْ \add ذ\add* كِيلْمَاذْ، ثُوغَا تّْسبَّابنْ أَكِيذمْ.
\v 24 نِيثْنِي ثُوغَا تّْسبَّابنْ أَكِيذمْ ذڭْ ڒعْبَايَاثْ إِشنّْعنْ ذ إِسڒْهَامنْ إِذحْمِييّنْ ذ لْبُورْضَاثْ ثِيقَارْقَاشِينْ ؤُ ذِي ڒْكتَّانْ إِغْڒَانْ س \add إِفِيڒَانْ ن\add* ثِينْثَاثْ إِفَارْزنْ نِّي \add إِدْجَانْ\add* جَارْ سّڒْعثْ نّمْ س ثسْغُونِينْ إِجهْذنْ إِتّْوَامُوذنْ.
\b
\m 
\v 25 إِغَارُّوبَا ن ثَارْشِيشْ ثُوغَا أَثنْ ذ إِكَارَابَاننْ نّمْ ذ سّڒْعثْ نّمْ.
\b
\m \qt ثُوغَا شمْ \tl ذِينِّي\tl*،\qt*
\m \qt ثشُّورذْ ؤُ ثْذقْڒذْ أَطَّاسْ\qt*
\m \qt ذڭْ وُوڒْ نْ ڒبْحُورْ.\qt*
\m 
\v 26 \qt إِقدَّافنْ \tl نّمْ\tl* إِوْينْ شمْ\qt*
\m \qt غَارْ وَامَانْ يُوعْڒَانْ،\qt*
\m \qt أَسمِّيضْ زِي شَّارْقْ يَارْژَا شمْ\qt*
\m \qt ذڭْ وُوڒْ نْ ڒبْحُورْ.\qt* \x ◘ \xo 27:‏26 \xt حِز. 17‏:‏1\x*
\b
\m 
\v 27 \qt إِڭڒْوَانْ نّمْ ذ سّڒْعثْ نِّي ثزّنْزذْ\qt*
\m \qt ذ ثْسبَّابْثْ نّمْ،\qt*
\m \qt إِبحْرِييّنْ نّمْ ذ إِندَّاهنْ نّمْ\qt*
\m \qt ذ يِينِّي إِعدّْڒنْ ثِيرژَّا نّمْ،\qt*
\m \qt ذ إِسبَّابنْ نِّي إِتّْسبَّابنْ أَكِيذمْ،\qt*
\m \qt ذ مَارَّا إِعسْكَارِييّنْ \tl إِنِّي\tl* أَكِيذمْ\qt*
\m \qt ؤُ أَكْ-ذ مَارَّا أَڭْرَاوْ ذِي ڒْوسْطْ نّمْ،\qt*
\m \qt أَذْ وْضَانْ \tl مَارَّا\tl* ذڭْ وُوڒْ ن ڒبْحُورْ\qt*
\m \qt ذڭْ وَاسّْ ن ؤُوطُّو نّمْ.\qt* \x ◘ \xo 27:‏27 \xt أَسَا. 18‏:‏9‏-‏19\x*
\b
\m 
\v 28 \qt زِي ڒْحسّْ ن ثْغُويِّيثْ ن إِندَّاهنْ نّمْ\qt*
\m \qt أَذْ أَرْجِيجنْ ذْشُورَاثْ نّمْ.\qt* \x ◘ \xo 27:‏28 \xt حِز. 26‏:‏10، 15\x*
\m 
\v 29 \qt أَذْ هْوَانْ زِي ثْغَارُّوبَا\qt*
\m \qt مَارَّا إِنِّي إِطّْفنْ ثِيمقْذَافِينْ،\qt*
\m \qt مَارَّا إِبحْرِييّنْ ذ مَارَّا إِندَّاهنْ نّمْ.\qt*
\m \qt نِيثْنِي أَذْ بدّنْ خْ ثمُّورْثْ،\qt*
\m 
\v 30 \qt ؤُشَا أَذْ سّْڭعّْذنْ ثْمِيجَّا نْسنْ،\qt*
\m \qt أَذْ سْغُوينْ س \tl إِمطَّاونْ إِمَارْزَاڭنْ\tl*،\qt*
\m \qt أَذْ نْضَارنْ \tl أَ\tl*شَاڒْ خْ إِزدْجِيفنْ نْسنْ،\qt*
\m \qt أَذْ زُوزَّارنْ إِغّضْ خْ يِيخفْ نْسنْ،\qt*
\m 
\v 31 \qt ؤُشَا أَذْ حفّنْ إِخفْ نْسنْ زِي سِّيبّثْ نّمْ.\qt*
\m \qt نِيثْنِي أَذْ بيْسنْ س ثْخُونْشَايْ \tl ن وشْضَانْ\tl*\qt*
\m \qt ؤُشَا أَذْ خَامْ رُونْ س ڒعْمَارْ \tl إِشُّورْ\tl* س ثَارْزُوڭِي\qt*
\m \qt ؤُ أَذْ سّْڭعّْذنْ إِشْثْ ن ثْغُويِّيثْ ثَامرْزَاڭْثْ.\qt* \x ◘ \xo 27:‏31 \xt إِرْم. 48‏:‏37\x*
\m 
\v 32 \qt أَمْ تّْوحْوِيحنْ أَذْ خَامْ سّْڭعّْذنْ\qt*
\m \qt إِجّْ ن إِزْڒِي ن وشْضَانْ،\qt*
\m \qt ؤُشَا أَذْ خَامْ وْثنْ أَڭجْذُورْ،\qt*
\m \qt أَذْ إِنِينْ: مَانْ ونْ \tl إِدْجَانْ\tl* أَمْ صُورْ،\qt*
\m \qt أَمْ \tl ثنْذِينْثْ\tl* إِتّْوَاهذْمنْ\qt*
\m \qt ذِي ڒْوسْطْ ن ڒبْحَارْ؟\qt*
\b
\m 
\v 33 \qt ڒَْامِي د-إِوْينْ سّڒْعثْ نّمْ\qt*
\m \qt زڭْ \add ؤُجمَّاضْ ن\add* ڒبْحُورْ،\qt*
\m \qt ثُوغَا ثسّْجِيوْنذْ أَطَّاسْ ن ڒڭْنُوسْ.\qt*
\m \qt س وَاطَّاسْ ن إِڭڒْوَانْ نّمْ ذ ثْسبَّابْثْ نّمْ\qt*
\m \qt ثَارِّيذْ إِجدْجِيذنْ ن ثمُّورْثْ ذ تّْوَاجَارنْ.\qt*
\m 
\v 34 \qt ذِي ثْسَاعّثْ نِّي ذِي ثتّْوَارْژذْ س ڒبْحُورْ،\qt*
\m \qt ذِي ڒْمهْمُوذْ ن وَامَانْ،\qt*
\m \qt ثُوغَا ثوْضَا ثْسبَّابْثْ نّمْ مَارَّا\qt*
\m \qt ؤُ مَارَّا أَڭْرَاوْ إِ غَارمْ \tl ذِي ڒبْحَارْ\tl*.\qt*
\b
\m 
\v 35 \qt مَارَّا إِمزْذَاغْ ن ثڭْزِيرِينْ تّْبهْثنْ\qt*
\m \qt ؤُ إِجدْجِيذنْ نْسنْ تَّارْجِيفنْ،\qt*
\m \qt تّْنخْڒَاعنْ ؤُذْمَاونْ نْسنْ.\qt*
\m 
\v 36 \qt إِسبَّابنْ جَارْ ڒڭْنُوسْ أَذْ خَامْ صفَّارنْ،\qt*
\m \qt أَقَا ثْذوْڒذْ ذ إِجّْ ن ؤُمذْيَا إِ وَارْجفْ،\qt*
\m \qt ؤُشَا وَارْ ثتِّيڒِيذْ عَاذْ إِ ڒبْذَا.‘ “\qt* \x ◘ \xo 27:‏36 \xt حِز. 26‏:‏21\x*
\b
\b
\c 28
\s1 أَوَاڒْ خْ ڒْحَاكمْ ن صُورْ
\m 
\v 1 يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا:
\v 2 ”\add أَ\add* مِّيسْ ن بْنَاذمْ، إِنِي إِ ڒْحَاكمْ ن صُورْ: ’أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: مِينْزِي ثسّْڭعّْذذْ ؤُڒْ نّشْ، ثنِّيذْ: نشّْ ذ أَربِّي، نشّْ تّْغِيمِيغْ خْ ڒْكُورْسِي ن أَربِّي ذِي ڒْوسْطْ ن ڒبْحُورْ!، وَاخَّا شكْ ذ بْنَاذمْ، وَارْ ثدْجِيذْ ذ أَربِّي، أَقَا ثڭِّيذْ ؤُڒْ نّشْ \add خنِّي\add* أَمْ وُوڒْ ن أَربِّي. \x ◘ \xo 28:‏2 \xt إِشا. 31‏:‏3\x*
\v 3 خْزَارْ، شكْ ذ أَمِيغِيسْ خْ ذَانِييِيلْ، وَارْ ذِينْ \add إِدْجِي\add* ؤُڒَا ذ إِجّْ ن سِّيرّْ خَاكْ إِنُّوفَّارنْ.
\v 4 س ثِيغِيثْ نّشْ ذ ڒفْهَامثْ نّشْ أَقَا ثسّْمُونذْ إِ يِيخفْ نّشْ إِڭڒْوَانْ \add مْغَارنْ\add* ؤُ ثڭِّيذْ ؤُرغْ ذ نُّوقَارْثْ ذڭْ إِخَّامنْ نّشْ ن ثْخُوبَايْ.
\v 5 س ثِيغِيثْ نّشْ إِمْغَارنْ غَارْ ثْسبَّابْثْ نّشْ، ثَارْنِيذْ ذڭْ إِڭڒْوَانْ نّشْ ؤُشَا ذِي سِّيبّثْ ن إِڭڒْوَانْ نّشْ \add مْغَارنْ،\add* إِسّْڭعّذْ وُوڒْ نّشْ إِخفْ نّسْ.‘
\v 6 س ؤُيَا، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي: ’ؤُمِي ثڭِّيذْ ؤُڒْ نّشْ أَمْ وُوڒْ ن أَربِّي،
\v 7 س ؤُيَا، خْزَارْ، نشّْ أَذْ خَاكْ د-أَوْيغْ إِبَارَّانِييّنْ، ڒڭْنُوسْ إِقسْحنْ أَطَّاسْ. نِيثْنِي أَذْ د-جبْذنْ ڒسْيُوفْ نْسنْ ضِيدّْ إِ وژْرِي ن ثِيغِيثْ نّشْ ؤُشَا أَذْ سّْفسْذنْ ثِيسِّيقْثْ نّشْ. \x ◘ \xo 28:‏7 \xt إِرْم. 6‏:‏23\x*
\v 8 نِيثْنِي أَذْ شكْ سّهْوَانْ غَارْ \add وحْفُورْ ن\add* ثُورْصُوضِي ؤُشَا أَذْ ثمّْثذْ ڒْموْثْ ن يِينِّي إِتّْوَاسّْنُوقّْبنْ ذڭْ وُوڒْ ن ڒبْحُورْ.
\v 9 مَا ثْزعْمذْ س ثِيذتّْ أَذْ ثِينِيذْ زَّاثْ إِ وُوذمْ ن يِينِّي شكْ إِ غَا إِنْغنْ: ’نشّْ ذ أَربِّي‘؟ أَقَا شكْ ذ بْنَاذمْ، وَارْ إِدْجِي ذ أَربِّي ذڭْ ؤُفُوسْ ن يِينِّي إِ شكْ إِ غَا إِذدْجنْ.
\v 10 أَذْ ثمّْثذْ س ؤُفُوسْ ن إِبَارَّانِييّنْ أَمْ يِينِّي وَارْ إِتّْوَاخثْننْ، مَاغَارْ نشّْ نِّيغْ \add ث\add*!، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي.‘ “
\b
\m 
\v 11 يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا:
\v 12 ”\add أَ\add* مِّيسْ ن بْنَاذمْ، سْڭعّذْ \bd إِجّْ ن يزْڒِي ن وشْضَانْ خْ ؤُجدْجِيذْ ن صُورْ\bd* ؤُشَا إِنِي أَسْ:
\b
\m ’أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي:
\m \qt \tl أَ\tl* شكْ، ونِّي ذ ڒْخَاثمْ ن ڒبْنِي إِفَارْزنْ،\qt*
\m \qt ثشُّورذْ س ثِيغِيثْ ؤُ ثْكمّْڒذْ ذڭْ وژْرِي!\qt* \x ◘ \xo 28:‏12 \xt حِز. 27‏:‏3\x*
\m 
\v 13 \qt ثُوغَا شكْ ذِي عَاذْنْ، ذِي جّنّثْ ن أَربِّي.\qt*
\m \qt ثُوغَا ذْڒِينْ شكْ س عْڒَامْ كُوڒْ إِژْرَا إِغْڒَانْ،\qt*
\m \qt س ڒعْقَاقْ، ثْيَاقُوثْ ذ ذْيَامَانْثِي،\qt*
\m \qt س ثخْرِيسُولِيثْ، ؤُنِيكْسْ ذ يَاسْبِيسْ،\qt*
\m \qt س صَافِّيرْ أَزِيزَا، كَارْبُونْكلْ، سْمَارَاخْثْ ذ وُورغْ.\qt*
\m \qt ڒْْخذْمثْ ن إِبنْذِيرنْ نّشْ\qt*
\m \qt ذ ؤُبَارُّو ن ثمْغَارِينْ نّشْ \tl ثُوغَا\tl* ذَايكْ،\qt*
\m \qt ذڭْ وَاسّْ نِّي ذِي د-ثتّْوَاخڒْقذْ ثُوغَا وجْذنْثْ\qt*.
\m 
\v 14 \qt ثُوغَا شكْ ذ إِجّْ ن ؤُكِيرُوبْ\qt*
\m \qt ذ أَمذْهُونْ إِسّْذُورُّوينْ،\qt*
\m \qt \tl أَمُّو إِ\tl* ڭِّيغْ شكْ \tl ذِينْ\tl*.\qt*
\m \qt ثُوغَا شكْ خْ وذْرَارْ إِقدّْسنْ ن أَربِّي،\qt*
\m \qt ثڭُّورذْ ذِي ڒْوسْطْ ن إِژْرَا إِتّحْذُوذُوقنْ.\qt* \f ◼ \fr 28:‏14 \ft \bd ’إِكِيرُوبنْ‘\bd* - إِشْثْ ن مَارْكَا ن لْمَالَاكَاثْ.\f*
\m 
\v 15 \qt ثُوغَا شكْ ثْكمّْڒذْ ذڭْ إِبْرِيذنْ نّشْ،\qt*
\m \qt زڭْ وَاسّْ نِّي ذِي د-ثتّْوَاخڒْقذْ،\qt*
\m \qt أَڒْ ذَايكْ ثتّْوَافْ ڒْمُوعْصِييّثْ.\qt*
\m 
\v 16 \qt س ڒمْغَارثْ ن ثْسبَّابْثْ نّشْ،\qt*
\m \qt إِشُّورْ ذَاخڒْ نّشْ س ڒخْشُونثْ\qt*
\m \qt ؤُشَا \tl خنِّي\tl* ثخْضِيضْ.\qt*
\m \qt \tl س ؤُيَا\tl* أَذْ شكْ سِّيڭّْوجغْ\qt*
\m \qt خْ وذْرَارْ ن أَربِّي،\qt*
\m \qt أَذْ شكْ مْحِيغْ زِي ڒْوسْطْ ن إِژْرَا إِتّحْذُوذُوقنْ،\qt*
\m \qt \tl أَ\tl* شكْ أَكِيرُوبْ إِسّْذُورُّوينْ!\qt*
\m 
\v 17 \qt ؤُڒْ نّشْ إِسّْڭعّذْ إِخفْ نّسْ س وَاژْرِي نّشْ،\qt*
\m \qt أَقَا ثسّْعِيدْجْثذْ ثِيغِيثْ نّشْ\qt*
\m \qt ذِي طّْوعْ ن ثِيسِّيقْثْ نّشْ \tl إِعفَّارنْ\tl*.\qt*
\m \qt نشّْ نْضَارغْ شكْ خْ ثمُّورْثْ\qt*
\m \qt ؤُشَا ڭِّيغْ شكْ زَّاثْ إِ وُوذمْ ن إِجدْجِيذنْ،\qt*
\m \qt أَڒَامِي زمَّارنْ أَذْ غَاركْ خْزَارنْ س ڒْحڭْرَا.\qt*
\m 
\v 18 \qt زِي سِّيبّثْ ن وَاطَّاسْ ن ڒْمُوعْصِييّثْ نّشْ\qt*
\m \qt ذ ڒْغشّْ ن ثْسبَّابْثْ نّشْ،\qt*
\m \qt أَقَا ثْغسْبذْ ثِيزَاوِييِّينْ نّشْ إِقدّْسنْ.\qt*
\m \qt \tl س ؤُينِّي\tl* أَرِّيغْ ثِيمسِّي ثفّغْ-د\qt*
\m \qt زِي ڒْوسْطْ نّشْ،\qt*
\m \qt ثنِّي شكْ إِشّنْ،\qt*
\m \qt ؤُشَا أَرِّيغْ شكْ ذ إِغّضْ خْ ثمُّورْثْ\qt*
\m \qt زَّاثْ إِ ثِيطَّاوِينْ ن مَارَّا إِنِّي شكْ إِتّْوَاڒَانْ.\qt*
\m 
\v 19 \qt مَارَّا إِنِّي شكْ إِسّْننْ جَارْ ڒڭْنُوسْ،\qt*
\m \qt أَرجْفنْ زَّايكْ.\qt*
\m \qt ثْذوْڒذْ ذ إِجّْ ن ؤُمذْيَا ن وَارْجفْ\qt*
\m \qt ؤُ وَارْ ثتِّيڒِيذْ \tl عَاذْ\tl* إِ ڒبْذَا.\qt*‘ “
\b
\s1 أَوَاڒْ ضِيدّْ إِ صُورْ
\m 
\v 20 يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا:
\v 21 ”\add أَ\add* مِّيسْ ن بْنَاذمْ، أَرّْ ؤُذمْ نّشْ غَارْ صِيذُونْ ؤُشَا نَابّْ ضِيدّْ نّسْ،
\v 22 ؤُشَا إِنِي: ’أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: خْزَارْ، نشّْ أَقَا أَيِي ضِيدّْ نّمْ، \add أَ\add* ثَانْذِينْثْ ن صِيذُونْ! نشّْ أَذْ تّْوَاسّْعُودْجغْ ذِي ڒْوسْثْ نّشْ. ؤُشَا نِيثْنِي أَذْ سّْننْ بلِّي نشّْ ذ سِيذِي خْمِي إِ غَا ڭّغْ ڒحْكَامَاثْ ذِي \add صِيذُونْ\add* ؤُشَا أَذْ ذَايسْ تّْوَاقدّْسغْ.
\v 23 أَذْ سّكّغْ طَّاعُونْ ذِي ڒْوسْطْ نّسْ ؤُڒَا ذ إِذَامّنْ ذڭْ إِبْرِيذنْ نّسْ ؤُ ونِّي إِتّْوَانْغنْ أَذْ إِوْضَا ذِي ڒْوسْطْ نّسْ س سِّيفْ نِّي خَاسْ \add إِ غَا يِيڒِينْ\add* زڭْ ونّضْ نّسْ. \add خنِّي\add* أَذْ سّْننْ، بلِّي نشّْ ذ سِيذِي،
\v 24 ؤُشَاعمَّارْصْ عَاذْ أَذْ يِيڒِي إِ ثَادَّارْثْ ن إِسْرَائِيل أَسنَّانْ إِقبْشنْ نِيغْ ثَازڭّْوَارْثْ إِتّقّْسنْ زڭْ إِنِّي ذ أَسنْ د-إِنّْضنْ، إِنِّي ثنْ إِسّحْقَارَانْ. نِيثْنِي أَذْ سّْننْ بلِّي نشّْ ذ سِيذِي، ذ سِيذِي \add إِ دْجِيغْ\add*.‘ “
\m 
\v 25 ”أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ’خْمِي غَا سّْمُونغْ ثَادَّارْثْ ن إِسْرَائِيل زِي ڒڭْنُوسْ نِّي مَانِي تّْوَابزّْعنْ نِيثْنِي ؤُشَا نشّْ سّشْنغْ إِخفْ إِنُو ذ أَمْقدّسْ ذَايْسنْ زَّاثْ إِ ثِيطَّاوِينْ ن ڒڭْنُوسْ، \add خنِّي\add* أَذْ زذْغنْ ذِي ثمُّورْثْ نِّي وْشِيغْ إِ ؤُمْسخَّارْ إِنُو يَاعْقُوبْ.
\v 26 نِيثْنِي أَذْ زذْغنْ ذِي ڒَامَانْ ؤُشَا أَذْ بْنَانْ ثُوذْرِينْ، أَذْ ڭّنْ إِمَارْجَاعنْ ن ؤُضِيڒْ ؤُ أَذْ ذَايْسنْ ژُّونْ ثِيزَايَارِينْ، \add وَاهْ،\add* نِيثْنِي أَذْ \add ذِينْ\add* زذْغنْ ذِي ڒَامَانْ أَوَارْنِي ڒَامِي ڭِّيغْ ڒحْكَامَاثْ خْ مَارَّا إِنِّي ثنْ إِكشّْضنْ زِي \add ثمُّورَا\add* إِ ذ أَسنْ د-إِنّْضنْ. \add خنِّي\add* أَذْ سّْننْ بلِّي نشّْ ذ سِيذِي، أَربِّي نْسنْ.‘ “ \x ◘ \xo 28:‏26 \xt إِرْم. 31‏:‏5\x*
\b
\b
\c 29
\s1 أَوَاڒْ خْ مِيصْرَا أَمْ إِشْثْ ن ڒْهَايْشثْ
\m 
\v 1 يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي \bd ذڭْ ؤُسڭّْوَاسْ وِيسّْعشْرَا، ذڭْ ؤُيُورْ وِيسّْعشْرَا، ذڭْ \bdit وَاسّْ\bdit* وِيسّْ ثنْعَاشْ ن ؤُيُورْ\bd*، إِنَّا:
\v 2 ”\add أَ\add* مِّيسْ ن بْنَاذمْ، أَرّْ ؤُذمْ نّشْ غَارْ فِيرْعُونْ، أَجدْجِيذْ ن مِيصْرَا ؤُشَا نَابّْ خَاسْ ؤُ خْ مَارَّا \add ثَامُّورْثْ ن\add* مِيصْرَا.
\v 3 سِيوڒْ، إِنِي:
\b
\m ’أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي:
\m \qt خْزَارْ، نشّْ ضِيدّْ نّشْ،\qt*
\m \qt \tl أَ\tl* فِيرْعُونْ، أَجدْجِيذْ ن مِيصْرَا،\qt*
\m \qt \tl شكْ\tl* ذ ڒْهَايْشثْ ثَامقّْرَانْثْ\qt*
\m \qt نِّي إِزّْڒنْ ذِي ڒْوسْطْ ن إِغزْرَانْ نّسْ،\qt*
\m \qt ثنِّي إِقَّارنْ: إِغْزَارْ إِنُو،\qt*
\m \qt نشّْ ڭِّيغْ \tl ث\tl* إِ يِيخفْ إِنُو!\qt* \x ◘ \xo 29:‏3 \xt إِزهد. 74‏:‏13، 14؛ إِشا. 27‏:‏1؛ 51‏:‏9\x*
\m 
\v 4 \qt نشّْ أَذْ ڭّغْ ثِيسنَّارِينْ ذڭْ ؤُغسْمَارْ نّشْ،\qt*
\m \qt أَذْ سّْڒسْقغْ إِسڒْمَانْ ن إِغزْرَانْ نّشْ\qt*
\m \qt غَارْ ثقْشُورِينْ نّشْ.\qt*
\m \qt أَذْ شكْ د-جبْذغْ زِي ڒْوسْطْ ن إِغزْرَانْ نّشْ\qt*
\m \qt ؤُشَا مَارَّا إِسڒْمَانْ ن إِغزْرَانْ نّشْ\qt*
\m \qt أَذْ ڒسْقنْ غَارْ ثقْشُورِينْ نّشْ.\qt* \x ◘ \xo 29:‏4 \xt حِز. 38‏:‏4\x*
\m 
\v 5 \qt نشّْ أَذْ شكْ نْضَارغْ \tl بَارَّا\tl* ذِي ڒخْڒَا،\qt*
\m \qt شكْ ذ مَارَّا إِسڒْمَانْ ن إِغزْرَانْ نّشْ.\qt*
\m \qt خْ وُوذمْ ن ييَّارْ أَذْ ثوْضِيذْ.\qt*
\m \qt وَارْ \tl ذِينْ\tl* ونِّي شكْ إِ غَا يَاوْينْ\qt*
\m \qt نِيغْ شكْ إِ غَا إِطّْفنْ.\qt*
\m \qt نشّْ أَذْ شكْ وْشغْ ذ مَاشَّا\qt*
\m \qt إِ ڒوْحُوشْ ن ثمُّورْثْ\qt*
\m \qt ؤُ إِ إِجْضَاضْ ن ؤُجنَّا.\qt*
\m 
\v 6 \qt مَارَّا إِمزْذَاغْ ن مِيصْرَا أَذْ سّْننْ\qt*
\m \qt بلِّي نشّْ ذ سِيذِي،\qt*
\m \qt مَاغَارْ نِيثْنِي ثُوغَا أَثنْ ذ أَزدْجَاضْ ن ؤُغَانِيمْ\qt*
\m \qt إِ \tl خْ ثُوغَا ثْسنّذْ\tl* ثَادَّارْثْ ن إِسْرَائِيل.\qt* \x ◘ \xo 29:‏6 \xt 2 إِج. 18‏:‏21؛ إِشا. 36‏:‏6\x*
\m 
\v 7 \qt مَاڒَا نِيثْنِي كْسِينْ شكْ س ؤُفُوسْ نّشْ،\qt*
\m \qt ثْفدْجْقذْ ؤُشَا ثسّْنُوقّْبذْ غَارْسنْ\qt*
\m \qt ثَاغْرُوضْثْ نْسنْ مَارَّا،\qt*
\m \qt ؤُ مَاڒَا خَاكْ سّنْذنْ،\qt*
\m \qt ثَارْژِيذْ ؤُشَا ثسَّارْجِيجذْ\qt*
\m \qt ثِيجْعِينَّاثِينْ \tl نْسنْ\tl* مَارَّا.‘ “\qt*
\b
\m 
\v 8 ”\bd س ؤُيَا\bd*، أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ’خْزَارْ، نشّْ أَذْ خَاكْ سّعْذُوغْ سِّيفْ ؤُشَا أَذْ قسّغْ زَّايكْ بْنَاذمْ ذ ڒْمَاڒْ.
\v 9 ثَامُّورْثْ ن مِيصْرَا أَذْ ثذْوڒْ إِ ؤُردّدْجْ ؤُ إِ ڒْخِيرْبثْ ؤُشَا نِيثْنِي أَذْ سّْننْ بلِّي نشّْ ذ سِيذِي، مِينْزِي نتَّا إِنَّا: ’إِغْزَارْ إِنُو ؤُ نشّْ ڭِّيغْ \add ث\add*!‘ “
\m 
\v 10 ”\bd س ؤُيَا\bd*، خْزَارْ، نشّْ خَاكْ ؤُ خْ إِغزْرَانْ نّشْ ؤُ نشّْ أَذْ ڭّغْ ثَامُّورْثْ ن مِيصْرَا ذ ڒخْرَابِي، \add وَاهْ،\add* ذ إِشْثْ نْ ڒْخِيرْبثْ ن وَاردّدْجْ زِي مَاجْذَالْ أَڒْ أَسْوَانْ، أَڒْ أَيْمِيرْ ن \add ثمُّورْثْ ن\add* كُوشْ.
\v 11 ؤُڒَا ذ إِجّْ ن بْنَاذمْ وَارْ زَّايسْ إِژكّْوِي خْ ؤُضَارْ ؤُ ؤُڒَا ذ إِجّْ ن ؤُضَارْ ن ڒْمَاڒْ أَذْ خَاسْ إِژْوَا. وَارْ ذَايكْ تِّيڒِينْ إِمزْضَاغْ إِ يِيجّْ ن ڒْمِيجَارْ ن \bd أَربْعِينْ ن إِسڭّْوُوسَا\bd*.
\v 12 \add مِينْزِي\add* نشّْ أَذْ ڭّغْ ثَامُّورْثْ ن مِيصْڒَا ذ أَردّدْجْ ذِي ڒْوسْطْ ن ثمُّورَا تّْوَارذْدْجنْثْ ؤُشَا ثِيندَّامْ أَذْ إِڒِينْثْ ذ أَردّدْجْ ذِي ڒْوسْطْ ن ثْندَّامْ \add نّغْنِي\add* نِّي إِذوْڒنْ ذ ڒْخِيرْبَاثْ، \add ڒْمِيجَارْ ن\add* \bd أَربْعِينْ ن إِسڭّْوُوسَا\bd*، ؤُ نشّْ أَذْ سُّويْسغْ إِمِيصْرِييّنْ جَارْ ڒڭْنُوسْ ؤُشَا أَذْ ثنْ بزّْعغْ خْ ثمُّورَا.“
\m 
\v 13 ”مَاشَا أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ’أَوَارْنِي ڒَامِي إِ غَا عْذُونْ \bd أَربْعِينْ ن إِسڭّْوُوسَا\bd* نشّْ أَذْ سّْمُونغْ إِمِيصْرِييّنْ زِي ڒڭْنُوسْ نِّي مَانِي ثُوغَا تّْوَابزّْعنْ.
\v 14 نشّْ أَذْ بدّْڒغْ ثَامحْبَاسْثْ ن إِمِيصْرِييّنْ ؤُشَا أَذْ ثنْ سّْعقْبغْ ذِي ثمُّورْثْ ن فَاثْرُوسْ، ذِي ثمُّورْثْ إِ زَّايسْ د-إِفّْغنْ، ؤُشَا ذِينِّي أَذْ إِڒِينْ ذ إِشْثْ ن ثْڭلْذِيثْ ثَامعْنَانُوشْثْ.
\v 15 ثَاڭلْذِيثْ نْسنْ أَذْ ثِيڒِي ذ ثَامعْنَانُوشْثْ زِي ثْڭلْذَاثِينْ نّغْنِي ؤُ وَارْ ثسّْڭعَّاذْ إِخفْ نّسْ عَاذْ خْ ڒڭْنُوسْ، مِينْزِي نشّْ أَذْ ثنْ سّْمژْيغْ أَڒَامِي وَارْ تّْصلّْطنْ عَاذْ خْ ڒڭْنُوسْ.
\v 16 وَارْ ثتِّيڒِي عَاذْ إِ ثَادَّارْثْ ن إِسْرَائِيل ذ أَثشْڒِي نِّي ثنْ إِ غَا إِسِّيذَارْ ڒْمُوعْصِييّثْ، ڒَامِي ذوْڒنْ غَارْسنْ، ضفَّارنْ ثنْ. نِيثْنِي أَذْ سّْننْ بلِّي نشّْ ذ سِيذِي، ذ سِيذِي \add إِ دْجِيغْ\add*.‘ “ \x ◘ \xo 29:‏16 \xt إِڭجذ. 4‏:‏17\x*
\b
\s1 ڒْمُونثْ ن نَاپُوخَاذْرَاصَّارْ خْ ؤُمنْغِي نّسْ ضِيدّْ ن صُورْ
\m 
\v 17 \bd ذڭْ ؤُسڭّْوَاسْ وِيسّْ سبْعَا ؤُ-عِيشْرِينْ، ذڭْ ؤُيُورْ وِيسّْ أَمزْوَارُو، ذڭْ \bdit وَاسّْ\bdit* أَمزْوَارُو ن ؤُيُورْ\bd* إِمْسَارْ بلِّي يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا:
\m 
\v 18 ”\add أَ\add* مِّيسْ ن بْنَاذمْ، نابُوخَاذْرَاصَّارْ، أَجدْجِيذْ ن بَابِيلْ، يَارَّا ڒْعسْكَارْ نّسْ أَذْ يڭّْ إِشْثْ ن ڒْخذْمثْ ثَامقّْرَانْثْ ضِيدّْ إِ صُورْ. مَارَّا أَزدْجِيفْ إِقِّيمْ ذ أَقشَّارْ ؤُ مَارَّا ثَاغْڒُوضْثْ ثَارْكشْ، \add مَاشَا\add* وَارْ غَارسْ ثُوغِي ڒخْڒَاصْ زِي \add ثنْذِينْثْ ن\add* صُورْ، إِ نتَّا ؤُ إِ ڒْعسْكَارْ نّسْ خْ ڒْخذْمثْ إِ يڭَّا ضِيدّْ نّسْ.
\m 
\v 19 \bd س ؤُيَا\bd*، أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ’خْزَارْ، نشّْ أَذْ وْشغْ ثَامُّورْثْ ن مِيصْرَا إِ نابُوخَاذْرَاصَّارْ، أَجدْجِيذْ ن بَابِيلْ. نتَّا أَذْ \add زَّايسْ\add* د-يَاوِي أَفيّضْ ن وَاڭْڒَا نّسْ ؤُشَا أَذْ إِكشّضْ ثَاكشَّاضْثْ نّسْ ؤُشَا أَذْ إِكّسْ ثُوكَّارْضَا. أَيَا أَذْ يِيڒِي ذ ڒخْڒَاصْ نّسْ إِ ڒْعسْكَارْ نّسْ.
\v 20 خْ ڒْخذْمثْ نِّي يڭَّا ضِيدّْ \add صُورْ\add* وْشِيغْ أَسْ ثَامُّورْثْ ن مِيصْرَا ذ ڒخْڒَاصْ، مِينْزِي نِيثْنِي ڭِّينْ ت ذِي طّْوعْ إِنُو، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي.
\v 21 \bd ذڭْ وَاسّْ نِّي\bd* أَذْ أَرّغْ إِشّْ ن إِسْرَائِيل أَذْ د-إِفّغْ ؤُشَا أَذْ أَرْزْمغْ أَقمُّومْ نّشْ ذِي ڒْوسْطْ نْسنْ. \add خنِّي\add* أَذْ سّْننْ بلِّي نشّْ ذ سِيذِي.‘ “
\b
\b
\c 30
\s1 ڒْحُوكْمْ خْ مِيصْرَا س سِّيفْ
\m 
\v 1 يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا:
\v 2 ”\add أَ\add* مِّيسْ ن بْنَاذمْ، نَابّْ ؤُشَا إِنِي:
\b
\m ’أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي:
\m \qt رُومْ! أَيّهَّاثْ خْ وَاسّْ نِّي!\qt*
\m 
\v 3 \qt مِينْزِي يُوذسْ إِ يدْجَا وَاسّْ \tl نِّي\tl*،\qt*
\m \qt يُوذسْ إِ يدْجَا وَاسّْ إِ سِيذِي،\qt*
\m \qt أَسّْ ن إِسيْنُوثنْ.\qt*
\m \qt أَذْ يِيڒِي ذ ثَاسَاعّثْ ن ڒڭْنُوسْ.\qt*
\m 
\v 4 \qt أَذْ د-يَاسْ سِّيفْ ذِي مِيصْرَا.\qt*
\m \qt أَذْ يِيڒِي وَارْجفْ أَمقّْرَانْ\qt*
\m \qt ذِي \tl ثمُّورْثْ ن\tl* كُوشْ،\qt*
\m \qt خْمِي غَا وْضَانْ إِنِّي إِتّْوَاسّْنُوقّْبنْ ذِي مِيصْرَا،\qt*
\m \qt مِينْزِي أَذْ أَوْينْ أَفيّضْ ن وَاڭْڒَا نّسْ،\qt*
\m \qt أَذْ أَردّْدْجنْ ذْسُوسَا نّسْ.\qt*
\m 
\v 5 \qt كُوشْ ذ فُوطْ ذ لُوذْ ذ عْڒَامْ كُوڒْ  إِبَارَّانِييّنْ،\qt*
\m \qt ذ كُوبْ ذ أَيْثْ ن ثمُّورْثْ ن ڒْعَاهْذْ\qt*
\m \qt أَذْ كِيسنْ وْضَانْ س سِّيفْ.‘ “\qt*
\b
\m 
\v 6 ”أَمُّو إِ إِقَّارْ سِيذِي:
\m \qt ’إِنِّي إِتّْشَاڒنْ خْ مِيصْرَا أَذْ وْضَانْ\qt*
\m \qt ؤُ نّْفَاخثْ ن صُّولْطَا نّسْ أَذْ ثْغَارْقْ.\qt*
\m \qt زِي مَاجْذَالْ أَڒْ أَسْوَانْ أَذْ وْضَانْ\qt*
\m \qt س سِّيفْ ذِي ثمُّورْثْ!‘،\qt*
\m \qt \tl أَمُّو إِ\tl* إِقَّارْ سِيذِي إِنُو، سِيذِي.\qt* \f ◼ \fr 30:‏6 \ft \bd ’ذِي ثمُّورْثْ‘\bd* - س ثْعِيبْرَانِيثْ ’ذَايسْ‘.\f*
\m 
\v 7 \qt ‘نِيثْنِي أَذْ تّْوَارذْدْجنْ\qt*
\m \qt ذِي ڒْوسْطْ ن ثمُّورَا إِتّْوَارذْدْجنْثْ\qt*
\m \qt ؤُ ثِيندَّامْ نّسْ أَذْ إِڒِينْثْ\qt*
\m \qt ذِي ڒْوسْطْ ن ثْندَّامْ \tl نّغْنِي\tl* إِتّْوَاخَارّْبنْ.\qt*
\m 
\v 8 \qt \tl خنِّي\tl* أَذْ سّْننْ بلِّي نشّْ ذ سِيذِي،\qt*
\m \qt خْمِي غَا سَّارْغغْ ثِيمسِّي ذِي مِيصْرَا\qt*
\m \qt ؤُشَا مَارَّا إِنِّي ت إِتّْعَاوَاننْ أَذْ تّْوَارْژنْ.‘\qt*
\m 
\v 9 \bdit ’ذڭْ وَاسّْ نِّي\bdit*
\m \qt أَذْ فّْغنْ إِرقَّاسنْ س ثْغَارُّوبَا\qt*
\m \qt زِي زَّاثْ ن وُوذمْ إِنُو،\qt*
\m \qt مَاحنْذْ أَذْ سِّيڭّْوذنْ كُوشْ\qt*
\m \qt ونِّي ؤُمِي إِتّْغِيڒْ أَقَا نتَّا ذِي ڒَامَانْ.\qt*
\m \qt أَذْ ذَايْسنْ يِيڒِي وَارْجفْ أَمقّْرَانْ،\qt*
\m \qt أَمشْنَاوْ ذڭْ وَاسّْ نِّي ن مِيصْرَا،\qt*
\m \qt مَاغَارْ خْزَارْ، أَذْ د-يَاسْ!‘ “\qt*
\b
\m 
\v 10 \qt ”أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي:\qt*
\m \qt ’نشّْ أَذْ سّْبدّغْ ڒْغَاشِي إِنْهوْڒنْ ن مِيصْرَا\qt*
\m \qt س ؤُفُوسْ ن نابُوخَاذْرَاصَّارْ، أَجدْجِيذْ ن بَابِيلْ.\qt*
\m 
\v 11 \qt نتَّا ذ ڒْڭنْسْ نّسْ أَكِيذسْ،\qt*
\m \qt إِمْسَاڭّْوَاذنْ قَاعْ ن ڒڭْنُوسْ\qt*
\m \qt أَذْ د-أَسنْ حِيمَا أَذْ ثحَّانْ ثَامُّورْثْ.\qt*
\m \qt نِيثْنِي أَذْ سُّوفّْغنْ ڒسْيُوفْ نْسنْ ضِيدّْ إِ مِيصْرَا\qt*
\m \qt ؤُشَا أَذْ شُّورنْ ثَامُّورْثْ\qt*
\m \qt س يِينِّي إِتّْوَاسّْنُوقّْبنْ.\qt* \x ◘ \xo 30:‏11 \xt حِز. 28‏:‏7\x*
\m 
\v 12 \qt نشّْ أَذْ سِّيژْغغْ إِغزْرَانْ\qt*
\m \qt ؤُشَا أَذْ زّنْزغْ ثَامُّورْثْ إِ إِعفَّاننْ\qt*
\m \qt ؤُ نشّْ أَذْ أَردّْدْجغْ ثَامُّورْثْ ذ مَارَّا مِينْ ذَايسْ\qt*
\m \qt س ؤُفُوسْ ن إِبَارَّانِييّنْ.\qt*
\m \qt نشّْ، سِيذِي، ونِّي إِنَّانْ \tl أَيَا\tl*.‘ “\qt* \f ◼ \fr 30:‏12 \ft \bd ’مَارَّا مِينْ ذَايسْ‘\bd* - س ثْعِيبْرَانِيثْ ’ثَاشُورّثْ نّسْ‘.\f*
\b
\m 
\v 13 ”أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي:
\m \qt ’نشّْ أَذْ أَردّْدْجغْ إِميْضَا ن لْ-أَصْنَامْ\qt*
\m \qt ؤُشَا أَذْ قْضِيغْ خْ لْ-أَصْنَامْ زِي نُوفْ.\qt*
\m \qt وَارْ إِتّْغِيمِي عَاذْ ؤُڒَا ذ إِجّْ ن ڒْحَاكمْ زِي مِيصْرَا.\qt*
\m \qt نشّْ أَذْ سِّيذْفغْ ڒْعُورّثْ ذِي ثمُّورْثْ ن مِيصْرَا.\qt*
\m 
\v 14 \qt نشّْ أَذْ أَردّْدْجغْ فَاثْرُوسْ\qt*
\m \qt ؤُ أَذْ سَّارْغغْ صُوعَانْ\qt*
\m \qt ؤُ أَذْ أَوْيغْ ڒحْكَامَاثْ إِنُو ذِي نُو.\qt*
\m 
\v 15 \qt نشّْ أَذْ سّْفَارْغغْ أَسْعَارْ إِنُو خْ سِينْ،\qt*
\m \qt لْبُورْجْ ن مِيصْرَا،\qt*
\m \qt أَذْ قضْعغْ ڒْغَاشِي إِنْهوْڒنْ ن نُو.\qt*
\m 
\v 16 \qt نشّْ أَذْ سِّيذْفغْ ثِيمسِّي غَارْ مِيصْرَا،\qt*
\m \qt سِينْ أَذْ ثفْسِي س ڒحْرِيقْ،\qt*
\m \qt \tl ثَامُّورْثْ ن\tl* نُو أَذْ ثتّْوَافدْجقْ\qt*
\m \qt ؤُ نُوفْ أَذْ ثِيڒِي ذِي ڒحْصَارثْ كُوڒْ أَسّْ.\qt*
\m 
\v 17 \qt إِحُوذْرِييّنْ زِي أَوَانْ ذ فِيبِيسْثَا\qt*
\m \qt أَذْ وْضَانْ س سِّيفْ\qt*
\m \qt ؤُ \tl ثِيمْغَارِينْ\tl* أَذْ ؤُيُورنْثْ ذِي ثْمحْبَاسْثْ.\qt*
\m 
\v 18 \qt أَسّْ أَذْ إِتّْبَارْشنْ ذِي ثَاحْفَاحِيسْ\qt*
\m \qt خْمِي غَا \tl يْ\tl*أَرْژغْ نشّْ أَزَايْڒُو ن مِيصْرَا،\qt*
\m \qt ؤُ أَذْ أَسْ سّْبدّغْ\qt*
\m \qt نّْفَاخثْ ن جّهْذْ نّسْ ذِينِّي.\qt*
\m \qt إِجّْ ن ؤُسيْنُو أَذْ ت إِسّْذُورِّي\qt*
\m \qt ؤُشَا يسِّيسْ أَذْ ؤُيُورنْثْ\qt*
\m \qt ذِي ثْمحْبَاسْثْ.\qt*
\m 
\v 19 \qt نشّْ أَذْ سِّيوْضغْ ڒحْكَامَاثْ خْ مِيسْڒَا\qt*
\m \qt ؤُ نِيثْنِي أَذْ سّْننْ بلِّي نشّْ ذ سِيذِي.‘ “\qt*
\b
\s1 ڒْحُوكْمْ خْ فِيرْعُونْ ذ ؤُزُّوزَارْ ن ڒْڭنْسْ نّسْ
\m 
\v 20 \bd ذڭْ ؤُسڭّْوَاسْ وِيسّْ حِيطَاشْ، ذڭْ ؤُيُورْ أَمزْوَارُو، ذڭْ \bdit وَاسّْ\bdit* وِيسّْ سبْعَا ن ؤُيُورْ\bd* إِمْسَارْ بلِّي يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا:
\m 
\v 21 ” ’\add أَ\add* مِّيسْ ن بْنَاذمْ، نشّْ أَرْژِيغْ أَغِيڒْ ن فِيرْعُونْ، أَجدْجِيذْ ن مِيصْرَا. خْزَارْ، وَارْ ث إِجبَّارْ ؤُڒَا ذ إِجّنْ مَاحنْذْ أَذْ إِتّْوَاسّْڭنْفَا، وَارْ ث تّنّْضنْ س بِينْذَاثْ أَڒَامِي زَّايْسنْثْ ث غَا سّْجهْذنْ، حِيمَا أَذْ إِطّفْ سِّيفْ \add عَاوذْ\add*!‘
\v 22 \bd س ؤُيَا\bd*، أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ’خْزَارْ، نشّْ خْ فِيرْعُونْ، أَجدْجِيذْ ن مِيصْڒَا، ؤُ نشّْ أَذْ أَرْژغْ إِغَادْجنْ نّسْ، \add أَمْ ؤُغِيڒْ\add* إِجهْذنْ \add عَاذْ\add* أَمْ ونِّي إِتّْوَارْژِينْ. نشّْ أَذْ أَرّغْ سِّيفْ نّسْ أَذْ إِوْضَا زڭْ ؤُفُوسْ نّسْ.
\v 23 نشّْ أَذْ زُوزَّارغْ إِمِيصْرِييّنْ جَارْ ڒڭْنُوسْ ؤُ أَذْ ثنْ بزّْعغْ خْ ثمُّورَا.
\v 24 نشّْ أَذْ سّْجهْذغْ إِغَادْجنْ ن ؤُجدْجِيذْ ن بَابِيلْ ؤُشَا أَذْ وْشغْ سِّيفْ إِنُو ذڭْ ؤُفُوسْ نّسْ، \add مَاشَا\add* إِغَادْجنْ ن فِيرْعُونْ أَذْ ثنْ أَرْژغْ، \add أَڒَامِي\add* إِ غَا إِسْغُويْ أَمْ إِسْغُويُّو ونِّي إِسّْنُوقْبنْ.
\v 25 \add وَاهْ\add* نشّْ أَذْ سّْجهْذغْ إِغَادْجنْ ن ؤُجدْجِيذْ ن بَابِيلْ، \add مَاشَا\add* إِغَادْجنْ ن فِيرْعُونْ أَذْ وْضَانْ. \add خنِّي\add* أَذْ سّْننْ بلِّي نشّْ ذ سِيذِي، خْمِي غَا ڭّغْ سِّيفْ إِنُو ذڭْ ؤُفُوسْ ن ؤُجدْجِيذْ ن بَابِيلْ ؤُ نتَّا أَذْ ث إِسّْوِيژّضْ خْ ثمُّورْثْ ن مِيصْرَا.
\v 26 نشّْ أَذْ زُوزَّارغْ إِمِيصْرِييّنْ جَارْ ڒڭْنُوسْ، أَذْ ثنْ بزّْعغْ خْ ثمُّورَا. \add أَمُّو\add* إِ غَا سّْننْ بلِّي نشّْ ذ سِيذِي.‘ “
\b
\b
\c 31
\s1 أَشُّورْ أَقَا-ث ذ إِجّْ ن وعْڒمْ إِ مِيصْرَا
\m 
\v 1 \bd ذڭْ ؤُسڭّْوَاسْ وِيسّْ حِيطَاشْ، ذڭْ ؤُيُورْ وِيسّْ ثْڒَاثَا، ذڭْ \bdit وَاسّْ\bdit* أَمزْوَارُو ن ؤُيُورْ\bd* إِمْسَارْ بلِّي يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا:
\v 2 ”\add أَ\add* مِّيسْ ن بْنَاذمْ، إِنِي إِ فِيرْعُونْ، أَجدْجِيذْ ن مِيصْرَا، ؤُ إِ مَارَّا ڒْغَاشِي نّسْ إِنْهوْڒنْ:
\b
\m \qt ’وِي أَكِيذكْ إِمْقُودَّانْ\qt*
\m \qt س \tl مَارَّا\tl* ڒمْغَارثْ نّشْ؟\qt*
\m 
\v 3 \qt خْزَارْ، ثُوغَا أَشُّورْ ذ ثَاشجَّارْثْ ن ثنْڭلْثْ\qt*
\m \qt خْ \tl إِذُورَارْ ن\tl* لُوبْنَانْ\qt*
\m \qt أَكْ-ذ ثْسضْوِينْ إِشْنَانْ ذ ثِيفْرَايْ إِ إِتِّيشنْ ثِيڒِي مْلِيحْ\qt*
\m \qt ؤُ أَكْ-ذ ثِيذِّي ذ أَزِيرَارْ يُوعْڒَانْ،\qt*
\m \qt أَڒَامِي ثُوشّنْثْ نّسْ\qt*
\m \qt ثِيوضْ-د أَڒْ إِسيْنُوثنْ.\qt* \x ◘ \xo 31:‏3 \xt دَان. 4‏:‏7\x*
\m 
\v 4 \qt أَمَانْ أَرِّينْ ت أَذْ إِيْمَا،\qt*
\m \qt \tl أَمَانْ\tl* إِهوْڒنْ سّْڭعّْذنْ ت أَطَّاسْ.\qt*
\m \qt إِغزْرَانْ ن وَامَانْ نّسْ سِّيزّْڒنْ\qt*
\m \qt ذڭْ ونّضْ ن ثبْهِيرْثْ نّسْ\qt*
\m \qt ؤُشَا \tl أَمَانْ إِهوْڒنْ\tl* أَرِّينْ\qt*
\m \qt إِغزْرَانْ نّسْ أَذْ رَاحنْ\qt*
\m \qt غَارْ مَارَّا ثِيشجُّورَا ن ييَّارْ.\qt*
\m 
\v 5 \qt خْ ؤُيَا إِتّْوَاسُّوعْڒَا ثِيذِّي نّسْ\qt*
\m \qt خْ مَارَّا ثِيشجُّورَا ن ييَّارْ،\qt*
\m \qt ؤُ ثِيسضْوِينْ نّسْ ذوْڒنْثْ س وَاطَّاسْ\qt*
\m \qt ؤُ إِفثْوَانْ نّسْ زُّوڭَّارْثنْ\qt*
\m \qt س وَامَانْ إِفيّْضنْ،\qt*
\m \qt خْمِي ثُوغَا ثسّْغمِّي.\qt*
\m 
\v 6 \qt مَارَّا إِجْضَاضْ ن ؤُجنَّا\qt*
\m \qt ڭِّينْ ڒْعُوشّْ نْسنْ ذِي ثْسضْوِينْ نّسْ،\qt*
\m \qt مَارَّا ڒْمَاڒْ ن ييَّارْ\qt*
\m \qt فرْخنْ سَاذُو إِفثْوَانْ نّسْ\qt*
\m \qt ؤُ مَارَّا ڒڭْنُوسْ مْغَارنْ\qt*
\m \qt ثُوغَا تّْغِيمَانْ ذِي ثِيڒِي نّسْ.\qt* \x ◘ \xo 31:‏6 \xt دَان. 4‏:‏9\x*
\m 
\v 7 \qt ثُوغَا-ت ثشْنَا س ڒمْغَارثْ نّسْ\qt*
\m \qt ؤُ س ثُوزّڭَّارْثْ ن ثْسضْوِينْ نّسْ،\qt*
\m \qt مَاغَارْ أَژْوَارْ نّسْ\qt*
\m \qt ثُوغَا-ث أَكْ-ذ وَاطَّاسْ ن وَامَانْ.\qt*
\m 
\v 8 \qt ثِيشجُّورَا ن ثنْڭلْثْ ذِي جّنّثْ ن أَربِّي\qt*
\m \qt وَارْ خَاسْ عْذُونْثْ،\qt*
\m \qt ثِيشجُّورَا ن ؤُمرْزِي\qt*
\m \qt وَارْ سكّْوِينْثْ ثْسضْوِينْ نّسْ\qt*
\m \qt ؤُشَا ثِيشجُّورَا ن ذُولْبْ\qt*
\m \qt وَارْ سكّْوِينْثْ إِفثْوَانْ نّسْ.\qt*
\m \qt ؤُڒَا ذ إِشْثْ ن ثْشجَّارْثْ ذِي جّنّثْ ن أَربِّي\qt*
\m \qt ثَارْوسْ ذَايسْ ذڭْ وَاژْرِي نّسْ.\qt* \f ◼ \fr 31:‏8 \ft \bd ’ثِيشجُّورَا‘\bd* - نِيغْ ’إِدَّاڭنْ‘. \bd ’أَمرْزِي‘\bd* - نِيغْ ’أَمضْزِي‘.\f*  \x ◘ \xo 31:‏8 \xt أَمز. 2‏:‏8\x*
\m 
\v 9 \qt ڭِّيغْ ت ثشْنَا أَكْ-ذ وَاطَّاسْ ن ثْسضْوِينْ نّسْ،\qt*
\m \qt أَڒَامِي زَّايسْ ؤُسْمنْثْ\qt*
\m \qt مَارَّا ثِيشجُّورَا ن عَاذْنْ،\qt*
\m \qt ثِينِّي ثُوغَا ذِي جّنّثْ ن أَربِّي.‘ “\qt*
\b
\m 
\v 10 ”\bdit س ؤُيَا\bdit*، أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي:
\m \qt ’ؤُمِي ثسّْڭعّْذذْ إِخفْ نّمْ س ثِيذِّي نّمْ،\qt*
\m \qt \tl وَاهْ\tl* نتَّاثْ ثڭَّا ثُوشّنْثْ نّسْ\qt*
\m \qt جَارْ إِسيْنُوثنْ\qt*
\m \qt ؤُ ؤُڒْ نّسْ إِسّْڭعّذْ إِخفْ نّسْ\qt*
\m \qt زِي سِّيبّثْ ن ڒُوعْڒَا نّسْ،\qt*
\m 
\v 11 \qt س ؤُينِّي وْشِيغْ ت ذڭْ ؤُفُوسْ\qt*
\m \qt ن ونِّي ذ أَمْزمَّارْ قَاعْ جَارْ ڒڭْنُوسْ،\qt*
\m \qt \tl ونِّي\tl* إِڭِّينْ س ثِيذتّْ\qt*
\m \qt أَمْ د-إِتّْڒِيقنْ أَكْ-ذ ثُوعفّْنَا نّسْ،\qt*
\m \qt \tl ؤُشَا\tl* أَمُّو إِ ؤُژّْڒغْ خَاسْ.\qt*
\m 
\v 12 \qt زذْمنْ ت إِبَارَّانِييّنْ،\qt*
\m \qt ڒڭْنُوسْ إِقسْحنْ أَطَّاسْ،\qt*
\m \qt زذْمنْ ث ؤُشَا جِّينْ ت.\qt*
\m \qt ثِيسضْوِينْ نّسْ وْضَانْثْ خْ إِذُورَارْ\qt*
\m \qt ؤُ ذِي مَارَّا ثِيغْزُورْثِينْ،\qt*
\m \qt إِفثْوَانْ نّسْ تّْوَارْژنْ\qt*
\m \qt ذِي مَارَّا ثِيغزْرَاثِينْ ن ثمُّورْثْ\qt*
\m \qt ؤُ مَارَّا ڒڭْنُوسْ ن ثمُّورْثْ\qt*
\m \qt هْوَانْ-د زِي \tl سَاذُو\tl* ثِيڒِي نّسْ\qt*
\m \qt ؤُشَا جِّينْ ت.\qt* \x ◘ \xo 31:‏12 \xt حِز. 28‏:‏7؛ 30‏:‏11\x*
\m 
\v 13 \qt مَارَّا إِجْضَاضْ ن ؤُجنَّا زذْغنْ\qt*
\m \qt خْ \tl ؤُكشُّوضْ\tl* نّسْ نِّي إِوْضَانْ\qt*
\m \qt ؤُشَا مَارَّا ڒْمَاڒْ ن ييَّارْ\qt*
\m \qt ثُوغَا أَثنْ خْ إِفثْوَانْ نّسْ.\qt*
\m 
\v 14 \qt \tl نشّْ ڭِّيغْ ت\tl*،\qt*
\m \qt حِيمَا مَارَّا ثِيشجُّورَا وَارْ ذِيكّْوِيڒنْثْ عَاذْ\qt*
\m \qt تّْنفّْخنْثْ س ثِيذِّي نْسنْثْ\qt*
\m \qt ؤُشَا أَذْ ڭّنْثْ ثُوشّنْثْ نْسنْ ذڭْ إِسيْنُوثنْ،\qt*
\m \qt ؤُ مَارَّا \tl ثِيشجُّورَا\tl* نِّي إِسْوِينْ أَمَانْ\qt*
\m \qt س ؤُفيّضْ،\qt*
\m \qt وَارْ تّْبذِّينْثْ عَاذْ س يِيخفْ نْسنْثْ\qt*
\m \qt ذِي نّْفَاخثْ نْسنْثْ،\qt*
\m \qt مَاغَارْ نِيثنْثِي مَارَّا\qt*
\m \qt تّْوَاموْشنْثْ إِ ڒْموْثْ،\qt*
\m \qt غَارْ ڒَادْجَاغْ ن ثمُّورْثْ،\qt*
\m \qt ذِي ڒْوسْطْ ن ثَارْوَا ن بْنَاذمْ،\qt*
\m \qt أَكْ-ذ إِنِّي إِهكّْوَانْ\qt*
\m \qt ذڭْ وحْفُورْ \tl ن ونْضڒْ\tl*.‘ “\qt*
\b
\m 
\v 15 ”أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي:
\m \qt ’ذڭْ وَاسّْ نِّي ذِي ثهْوَا غَارْ ڒَاخَارْثْ،\qt*
\m \qt ڭِّيغْ إِجّْ وشْضَانْ.\qt*
\m \qt ذِي طّْوعْ نّسْ ذْڒِيغْ \tl أَمَانْ\tl* إِهوْڒنْ\qt*
\m \qt ؤُشَا سّْبدّغْ إِغزْرَانْ نّسْ\qt*
\m \qt ؤُشَا فشْڒنْ وَامَانْ إِمْغَارنْ.\qt*
\m \qt ذِي طّْوعْ نّسْ سّْبَارّشْنغْ\qt*
\m \qt \tl إِذُورَارْ ن\tl* لُوبْنَانْ\qt*
\m \qt ؤُشَا مَارَّا ثِيشجُّورَا ن ييَّارْ شضْننْثْ خَاسْ.\qt*
\m 
\v 16 \qt س دّْرِيزْ ن ؤُوطُّو نّسْ سَّارْجِيجغْ ڒڭْنُوسْ،\qt*
\m \qt ؤُمِي ت سّهْوِيغْ غَارْ ڒَاخَارْثْ\qt*
\m \qt أَكْ-ذ إِنِّي إِهكّْوَانْ ذڭْ وحْفُورْ \tl ن ونْضڒْ\tl*.\qt*
\m \qt مَارَّا ثِيشجُّورَا ن عَاذْنْ،\qt*
\m \qt ثِينِّي إِعِيزّنْ أَطَّاسْ ذ ثِينِّي إِشْنَانْ قَاعْ\qt*
\m \qt زِي لُوبْنَانْ،\qt*
\m \qt ثِينِّي إِسْوِينْ \tl أَطَّاسْ ن\tl* وَامَانْ مَارَّا،\qt*
\m \qt أَقَا تّْوَاسّْفوّْجنْثْ \tl س مَانْ أَيَا\tl*\qt*
\m \qt ذِي ڒَادْجَاغْ ن ثمُّورْثْ.\qt* \x ◘ \xo 31:‏16 \xt إِشا. 14‏:‏9\x*
\m 
\v 17 \qt ؤُڒَا ذ نِيثنْثِي هْوَانْثْ أَكِيذسْ غَارْ ڒَاخَارْثْ،\qt*
\m \qt غَارْ إِنِّي إِتّْوَانْغنْ س سِّيفْ،\qt*
\m \qt إِنِّي ثُوغَا أَغِيڒْ نّسْ \tl إِجهْذنْ\tl*،\qt*
\m \qt إِنِّي ثُوغَا إِقِّيمنْ ذِي ثِيڒِي نّسْ\qt*
\m \qt ذِي ڒْوسْثْ ن ڒڭْنُوسْ.\qt*
\m 
\v 18 \qt أَكْ وِي ثْسَاوِيذْ أَمُّو ذِي ڒْعزّْ ذ ڒمْغَارثْ\qt*
\m \qt جَارْ ثْشجُّورَا ن عَاذْنْ؟\qt*
\m \qt \tl وَاخَّا أَمنِّي\tl* أَذْ ثتّْوَاسّهْوِيذْ\qt*
\m \qt أَكْ-ذ ثْشجُّورَا نْ عَاذْنْ\qt*
\m \qt أَڒْ رَادْجَاغْ ن ثمُّورْثْ.\qt*
\m \qt أَذْ ثْبُوزّْڒذْ ذِي ڒْوسْثْ ن يِينِّي وَارْ إِتّْوَاخثْننْ،\qt*
\m \qt أَكْ-ذ إِنِّي إِتّْوَانْغنْ س سِّيفْ.\qt*
\m \qt \tl ؤُشَا أَذْ إِنِينْ:\tl* وَا ذ فِيرْعُونْ\qt*
\m \qt ذ مَارَّا ڒْغَاشِي نّسْ إِنْهوْڒنْ!‘،\qt*
\m \qt \tl أَمُّو إِ\tl* إِقَّارْ سِيذِي إِنُو، سِيذِي.“\qt* \x ◘ \xo 31:‏18 \xt حِز. 28‏:‏10\x*
\b
\b
\c 32
\s1 إِزْڒِي ن وشْضَانْ خْ فِيرْعُونْ
\m 
\v 1 \bd ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثنْعَاشْ، ذڭْ ؤُيُورْ وِيسّْ ثنْعَاشْ، ذڭْ \bdit وَاسّْ\bdit* أَمزْوَارُو ن ؤُيُورْ\bd* إِمْسَارْ بلِّي يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا:
\v 2 ”\add أَ\add* مِّيسْ ن بْنَاذمْ، سْڭعّذْ إِجّْ ن يزْڒِي ن وشْضَانْ خْ فِيرْعُونْ، أَجدْجِيذْ ن مِيصْرَا، ؤُشَا إِنِي أَسْ:
\b
\m \qt ’ثُوغَا شكْ أَمْ ويْرَاذْ ذ أَمژْيَانْ\qt*
\m \qt جَارْ ڒڭْنُوسْ\qt*
\m \qt ؤُ ثُوغَا شكْ أَمْ ڒْهَايْشثْ ذِي ڒبْحُورْ.\qt*
\m \qt ثْغضْڒذْ إِخفْ نّشْ ذڭْ إِغزْرَانْ،\qt*
\m \qt ثسّنْهزّذْ أَمَانْ س إِضَارنْ نّشْ\qt*
\m \qt ؤُشَا ثسّفْسَاذْ إِغزْرَانْ نْسنْ.‘\qt* \x ◘ \xo 32:‏2 \xt حِز. 29‏:‏3\x*
\b
\m 
\v 3 أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي:
\m \qt ’نشّْ أَذْ خَاكْ سّْوِيژّْضغْ ثْرَاشَّا إِنُو،\qt*
\m \qt س يِيجّْ ن وڭْرَاوْ ن ڒڭْنُوسْ أَطَّاسْ.\qt*
\m \qt نِيثْنِي أَذْ شكْ سِّيڒْينْ أَكْ-ذ ثْرَاشَّا إِنُو.\qt* \x ◘ \xo 32:‏3 \xt حِز. 12‏:‏13؛ 17‏:‏20\x*
\m 
\v 4 \qt نشّْ أَذْ شكْ جّغْ ذِي ثمُّورْثْ،\qt*
\m \qt أَذْ شكْ نْضَارغْ خْ وُوذمْ ن ييَّارْ.\qt*
\m \qt أَذْ خَاكْ سّْزذْغغْ مَارَّا إِجْضَاضْ ن ؤُجنَّا\qt*
\m \qt ؤُشَا أَذْ زَّايكْ سّْجِيوْنغْ إِمُودَّارنْ\qt*
\m \qt زِي مَارَّا ثَامُّورْثْ.\qt*
\m 
\v 5 \qt أَذْ ڭّغْ ويْسُومْ نّشْ خْ إِذُورَارْ\qt*
\m \qt ؤُشَا أَذْ شُّورغْ ثِيغْزُورِينْ\qt*
\m \qt س ڒڭْعُوذِي \tl ن وَارَّايمْ\tl* نّشْ.\qt*
\m 
\v 6 \qt نشّْ أَذْ سّسْوغْ ثَامُّورْثْ أَڒْ إِذُورَارْ،\qt*
\m \qt س ؤُفيّضْ ن إِذَامّنْ نّشْ،\qt*
\m \qt ؤُشَا ثِيغزْرَاثِينْ أَذْ شُّورنْثْ زَّايكْ.‘\qt*
\b
\m 
\v 7 \qt ’نشّْ أَذْ سّْذُورْيغْ أَجنَّا\qt*
\m \qt خْمِي شكْ غَا سّْخسْيغْ.\qt*
\m \qt أَذْ سّْبَارّشْنغْ إِثْرَانْ نّسْ،\qt*
\m \qt أَذْ سّْذُورْيغْ ثَافُوشْثْ س إِسيْنُوثنْ،\qt*
\m \qt ؤُشَا ثَازِيرِي وَارْ تّجِّي \tl عَاذْ\tl*\qt*
\m \qt أَذْ ثَارْغَا ثْفَاوْثْ نّسْ.\qt* \x ◘ \xo 32:‏7 \xt إِشا. 13‏:‏10؛ يُووِ. 3‏:‏4. \x*
\m 
\v 8 \qt مَارَّا ثِيفَاوِينْ يَارقّنْ ذڭْ ؤُجنَّا\qt*
\m \qt أَذْ ثنْثْ سّْبَارّشْنغْ ذِي طّْوعْ نّشْ\qt*
\m \qt ؤُشَا أَذْ سّكّغْ ثَادْجسْثْ خْ ثمُّورْثْ نّشْ!‘،\qt*
\m \qt \tl أَمُّو\tl* إِ إِقَّارْ سِيذِي إِنُو، سِيذِي.\qt*
\m 
\v 9 \qt ’نشّْ أَذْغزِّيغْ ؤُڒْ ن وَاطَّاسْ ن ڒڭْنُوسْ،\qt*
\m \qt ؤُمِي إِ غَا يَاوْيغْ \tl ڒخْبَارْ\tl* ن ثْرژِّيثْ نّشْ\qt*
\m \qt غَارْ ڒڭْنُوسْ، غَارْ ثمُّورَا\qt*
\m \qt إِ وَارْ ثنْثْ ثسِّينذْ شَا.\qt*
\m 
\v 10 \qt نشّْ أَذْ سّْنخْڒْعغْ أَطَّاسْ نْ ڒڭْنُوسْ\qt*
\m \qt ذِي سِّيبّثْ نّشْ\qt*
\m \qt ؤُ أَشُوَّافْ ن إِجدْجِيذنْ نْسنْ\qt*
\m \qt أَذْ ڭعّْذنْ \tl زڭْ وَارْجفْ\tl* ذِي طّْوعْ نّشْ،\qt*
\m \qt خْمِي غَا سّنْهزّغْ سِّيفْ إِنُو \tl سَّا ذ سَّا\tl*\qt*
\m \qt زَّاثْ إِ وُوذْمَاونْ نْسنْ.\qt*
\m \qt نِيثْنِي أَذْ أَرْجِيجنْ ڒبْذَا،\qt*
\m \qt كُوڒْ إِجّْ ذِي سِّيبّثْ ن ثُوذَارْثْ نّسْ،\qt*
\m \qt ذڭْ وَاسّْ ن ؤُوطُّو نّشْ.‘\qt* \f ◼ \fr 32:‏10 \ft \bd ’ثُوذَارْثْ‘\bd* - س ثْعِيبْرَانِيثْ ’ڒعْمَارْ‘.\f*
\b
\m 
\v 11 مِينْزِي أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي:
\m \qt ’سِّيفْ ن ؤُجدْجِيذْ ن بَابِيلْ أَذْ خَاكْ يمَّارْسْ.\qt*
\m 
\v 12 \qt س ڒسْيُوفْ ن أَيْثْ ن بُو-ثغْرُوضْثْ\qt*
\m \qt أَذْغضْڒغْ ڒْغَاشِي نّشْ إِنْهوْڒنْ.\qt*
\m \qt أَقَا-ثنْ ڒڭْنُوسْ إِقسْحنْ أَطَّاسْ مَارَّا،\qt*
\m \qt نِيثْنِي أَذْ قْضَانْ خْ نّْفَاخثْ ن مِيصْرَا\qt*
\m \qt ؤُشَا مَارَّا ڒْغَاشِي نّسْ إِنْهوْڒنْ\qt*
\m \qt أَذْ إِتّْوَاثحَّا.\qt* \x ◘ \xo 32:‏12 \xt حِز. 28‏:‏7؛ 31‏:‏12؛ 31‏:‏2، 18؛ 32‏:‏16 \x*
\m 
\v 13 \qt نشّْ أَذْ قْضِيغْ خْ إِمُودَّارنْ نّسْ\qt*
\m \qt إِنِّي \tl إِدْجَانْ\tl* غَارْ وَاطَّاسْ ن وَامَانْ،\qt*
\m \qt ؤُڒَا ذ إِجّْ ن ؤُضَارْ ن بْنَاذمْ\qt*
\m \qt أَذْ ثنْ إِسَّارْوِي عَاوذْ\qt*
\m \qt ؤُشَا ؤُڒَا ذ إِشْثْ ن ثشْضشْثْ ن ڒْمَاڒْ\qt*
\m \qt أَذْ ثنْ ثسَّارْوِي \tl عَاذْ\tl*.‘\qt*
\b
\m 
\v 14 \qt ’خنِّي أَذْ سّهْوِيغْ أَمَانْ نْسنْ\qt*
\m \tl أَڒَامِي إِ غَا صْفَانْ\tl*
\m \qt ؤُ نشّْ أَذْ ڭّغْ إِغزْرَانْ نْسنْ\qt*
\m \qt أَذْ سِّيزّْڒنْ أَمْ زّشْثْ!‘،\qt*
\m \add أَمُّو\add* إِ إِقَّارْ سِيذِي إِنُو، سِيذِي.
\m 
\v 15 \qt ’أَڒَامِي ڭِّيغْ ثَامُّورْثْ ن مِيصْرَا ذ أَردّدْجْ\qt*
\m \qt ؤُشَا أَذْ ثِيڒِي ثمُّورْثْ ثتّْوَاردّدْجْ،\qt*
\m \qt ثحْفَا زِي مَارَّا مِينْ ذَايسْ،\qt*
\m \qt أَڒَامِي وْثغْ مَارَّا إِنِّي ذَايسْ إِزدّْغنْ،\qt*
\m \qt \tl خنِّي\tl* أَذْ سّْننْ بلِّي نشّْ ذ سِيذِي.‘ “\qt*
\b
\m 
\v 16 ”وَا ذ إِزْڒِي ن وشْضَانْ ؤُشَا أَذْ ثغنّْجنْ أَمْ يزْڒِي ن وشْضَانْ، يسِّيثْسنْثْ ن ثمُّورَا أَذْ ثغنّْجنْثْ أَمْ يزْڒِي ن وشْضَانْ، أَذْ ثغنّْجنْثْ أَمْ \bd يزْڒِي ن وشْضَانْ خْ مِيصْرَا ؤُ خْ مَارَّا ڒْغَاشِي نّسْ إِنْهوْڒنْ!\bd*، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي.“
\b
\s1 إِژْرِي ن وشْضَانْ غَارْ ونْضڒْ ن فِيرْعُونْ أَكْ-ذ ؤُبَارُّو نّسْ
\m 
\v 17 \bd ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثنْعَاشْ، \bdit ذڭْ ؤُيُورْ وِيسّْ ثنْعَاشْ\bdit*، ذڭْ \bdit وَاسّْ\bdit* وِيسّْ خمّسْطَاشْ ن ؤُيُورْ\bd* إِمْسَارْ بلِّي يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا:
\b
\m 
\v 18 \qt ”\tl أَ\tl* مِّيسْ ن بْنَاذمْ،\qt*
\m \qt وّثْ أَڭجْذُورْ خْ ڒْغَاشِي إِنْهوْڒنْ ن\qt* \bdit مِيصْرَا\bdit*.
\m \qt أجّْ إِ-ث أَذْ إِهْوَا،\qt*
\m \qt \tl مِيصْرَا\tl* أَكْ-ذ يسِّيسْ ن ڒڭْنُوسْ إِجهْذنْ،\qt*
\m \qt ذِي ڒَادْجَاغْ ن ثمُّورْثْ،\qt*
\m \qt أَكْ-ذ يِينِّي إِهْوَانْ ذڭْ وحْفُورْ \tl ن ونْضڒْ\tl*.\qt*
\m 
\v 19 \qt مَا شكْ إِعِيزّنْ خْ مَانْ مَّا؟\qt*
\m \qt هْوَا، أجّْ أَذْ شكْ سَّارْسنْ\qt*
\m \qt أَكْ-ذ يِينِّي وَارْ إِتّْوَاخثْننْ.\qt*
\m 
\v 20 \qt أَذْ وْضَانْ ذِي ڒْوسْطْ\qt*
\m \qt ن يِينِّي إِتّْوَانْغنْ س سِّيفْ.\qt*
\m \qt أَقَا إِمّوْشْ سِّيفْ.\qt*
\m \qt جَارّْ \tl مِيصْرَا\tl* \tl زڭْ وبْرِيذْ\tl*\qt*
\m \qt أَكْ-ذ مَارَّا ڒْغَاشِي نّسْ إِنْهوْڒنْ.\qt*
\m 
\v 21 \qt إِنِّي غَارْ ثدْجَا صُّولْطَا أَطَّاسْ\qt*
\m \qt زڭْ أَيْثْ ن بُو-ثغْرُوضْثْ\qt*
\m \qt أَذْ سِّيوْڒنْ أَكِيذسْ\qt*
\m \qt ؤُ أَكْ-ذ يِينِّي ث إِعَاوَاننْ\qt*
\m \qt زِي ڒْوسْطْ ن ڒَاخَارْثْ.\qt*
\m \qt هْوَانْ نِيثْنِي، أَقَا زّْڒنْ \tl ذِينِّي\tl*،\qt*
\m \qt إِنِّي وَارْ إِتّْوَاخثْننْ،\qt*
\m \qt إِنِّي إِتّْوَانْغنْ س سِّيفْ.‘\qt*
\b
\m 
\v 22 \qt ’ذِيهَا إِدْجَا\qt* \bdit أَشُّورْ\bdit* \qt أَكْ-ذ مَارَّا أَڭْرَاوْ نّسْ،\qt*
\m \qt نّْضنْ أَسْ-د إِمضْڒَانْ نّسْ.\qt*
\m \qt مَارَّا نِيثْنِي تّْوَانْغنْ، وْضَانْ س سِّيفْ.\qt*
\m 
\v 23 \qt إِمضْڒَانْ نّسْ أَقَا أَثنْ ذِي ثْغمَّارْ\qt*
\m \qt ن وحْفُورْ \tl ن ونْضڒْ\tl*\qt*
\m \qt ؤُ أَڭْرَاوْ نّسْ أَقَا-ث ذڭْ ونّضْ ن ونْضڒْ نّسْ.\qt*
\m \qt مَارَّا نِيثْنِي تّْوَاسّْنُوقّْبنْ،\qt*
\m \qt وْضَانْ س سِّيفْ،\qt*
\m \qt إِنِّي ثُوغَا إِسَّاڭّْوَاذنْ\qt*
\m \qt ذِي ثمُّورْثْ ن يِينِّي إِدَّارنْ.‘\qt*
\b
\m 
\v 24 \qt ’ذِيهَا\qt* \bdit عِيلَامْ\bdit* \qt ذ مَارَّا ڒْغَاشِي نّسْ إِنْهوْڒنْ\qt*
\m \qt ذڭْ ونّضْ ن ونْضڒْ نّسْ.\qt*
\m \qt مَارَّا نِيثْنِي تّْوَاسّْنُوقّْبنْ، وْضَانْ س سِّيفْ،\qt*
\m \qt هْوَانْ بْڒَا أَخْثَانْ ذِي ڒَادْجَاغْ ن ثمُّورْثْ،\qt*
\m \qt إِنِّي ثُوغَا إِسَّاڭّْوَاذنْ\qt*
\m \qt ذِي ثمُّورْثْ ن يِينِّي إِدَّارنْ.\qt*
\m \qt نِيثْنِي إِوْينْ ڒفْضِيحثْ نْسنْ أَكِيذْسنْ،\qt*
\m \qt أَكْ-ذ يِينِّي إِهكّْوَانْ\qt*
\m \qt ذڭْ وحْفُورْ \tl ن ونْضڒْ\tl*.\qt*
\m 
\v 25 \qt ڭِّينْ أَسْ إِجّْ ن ومْشَانْ ن أَرَّاحثْ\qt*
\m \qt ذِي ڒْوسْثْ ن يِينِّي إِتّْوَانْغنْ،\qt*
\m \qt غَارْ مَارَّا ڒْغَاشِي نّسْ إِنْهوْڒنْ.\qt*
\m \qt إِمضْڒَانْ نّسْ نّْضنْ أَسْ-د.\qt*
\m \qt مَارَّا نِيثْنِي وَارْ إِتّْوَاخثْننْ،\qt*
\m \qt وْضَانْ س سِّيفْ،\qt*
\m \qt مِينْزِي ثُوغَا سَّاڭّْوَاذنْ \tl إِوْذَانْ\tl*\qt*
\m \qt ذِي ثمُّورْثْ ن يِينِّي إِدَّارنْ.\qt*
\m \qt نِيثْنِي إِوْينْ ڒفْضِيحثْ نْسنْ أَكِيذْسنْ،\qt*
\m \qt \tl جْمِيعْ\tl* أَكْ-ذ يِينِّي إِهكّْوَانْ\qt*
\m \qt ذڭْ وحْفُورْ \tl ن ونْضڒْ\tl*.\qt*
\m \qt أَقَا نتَّا إِتّْوَاسَّارْسْ\qt*
\m \qt ذِي ڒْوسْثْ ن يِينِّي إِتّْوَانْغنْ.‘\qt*
\b
\m 
\v 26 \qt ذِيهَا\qt* \bdit مَاشِيخْ-ثُوبَالْ\bdit*
\m \qt ذ مَارَّا ڒْغَاشِي نّسْ إِنْهوْڒنْ.\qt*
\m \qt نّْضنْ أَسْ-د إِمضْڒَانْ نّسْ.\qt*
\m \qt مَارَّا نِيثْنِي وَارْ تّْوَاخثْننْ،\qt*
\m \qt تّْوَاسّْنُوقّْبنْ س سِّيفْ،\qt*
\m \qt مَاغَارْ نِيثْنِي ثُوغَا سَّاڭّْوَاذنْ \tl إِوْذَانْ\tl*\qt*
\m \qt ذِي ثمُّورْثْ ن يِينِّي إِدَّارنْ.\qt*
\m 
\v 27 \qt إِنِّي إِوْضَانْ زڭْ يِينِّي وَارْ إِتّْوَاخثْننْ\qt*
\m \qt وَارْ زِّيڒنْ أَكْ-ذ أَيْثْ ن بُو-ثغْرُوضْثْ\qt*
\m \qt نِّي إِهْوَانْ غَارْ ڒَاخَارْثْ\qt*
\m \qt أَكْ-ذ ڒسْنَاحْ نْسنْ ن ؤُمنْغِي.\qt*
\m \qt مَّارْسنْ ڒسْيُوفْ نْسنْ سَاذُو إِزدْجِيفنْ نْسنْ\qt*
\m \qt ؤُشَا ڒْمُوعْصِييّثْ نْسنْ أَقَا-ت خْ ييْسَانْ نْسنْ،\qt*
\m \qt وَاخَّا ثُوغَا نِيثْنِي ذ ثِيڭّْوُوذِي إِ أَيْثْ ن بُو-ثغْرُوضْثْ\qt*
\m \qt ذِي ثمُّورْثْ ن يِينِّي إِدَّارنْ.\qt*
\m 
\v 28 \qt ؤُڒَا ذ شكْ أَذْ ثِيڒِيذْ ثَارْژذْ\qt*
\m \qt ذِي ڒْوسْطْ ن يِينِّي وَارْ إِتّْوَاخثْننْ\qt*
\m \qt ؤُشَا أَذْ ثزّْڒذْ\qt*
\m \qt أَكْ-ذ يِينِّي إِتّْوَاسّْنُوقْبنْ س سِّيفْ.‘\qt*
\b
\m 
\v 29 \qt ’ذِيهَا\qt* \bdit إِذُومْ،\bdit* \qt إِجدْجِيذنْ نّسْ ذ مَارَّا ڒْحُوكَّامْ نّسْ،\qt*
\m \qt إِنِّي \tl إِ ذِينْ إِتّْوَاڭّنْ\tl*\qt*
\m \qt س \tl مَارَّا\tl* صُّولْثَا نْسنْ\qt*
\m \qt أَكْ-ذ يِينِّي إِتّْوَاسّْنُوقّْبنْ س سِّيفْ.\qt*
\m \qt زّْڒنْ \tl ذِينِّي\tl* أَكْ-ذ يِينِّي وَارْ إِتّْوَاخثْننْ\qt*
\m \qt ؤُ أَكْ-ذ يِينِّي إِهْوَانْ\qt*
\m \qt ذڭْ وحْفُورْ \tl ن ونْضڒْ\tl*.‘\qt*
\b
\m 
\v 30 \qt ’ذِيهَا\qt* \bdit أَيْثْ ن بُو-صُّولْطَا زِي شّْمَالْ،\bdit*
\m \qt مَارَّا نِيثْنِي، ؤُ مَارَّا\qt* \bdit أَيْثْ ن صِيذُونْ،\bdit*
\m \qt إِنِّي إِهْوَانْ أَكْ-ذ يِينِّي إِتّْوَانْغنْ.\qt*
\m \qt أَقَا تّْسضْحَانْ \tl ذِينِّي\tl*،\qt*
\m \qt وَاخَّا ثُوغَا سَّاڭّْوَاذنْ \tl إِوْذَانْ\tl*\qt*
\m \qt س ثرْيَاسْثْ نْسنْ ن أَيْثْ ن بُو-ثغْرُوضْثْ.\qt*
\m \qt أَقَا زّْڒنْ ذِينِّي بْڒَا أَخْثَانْ\qt*
\m \qt أَكْ-ذ يِينِّي إِتّْوَانْغنْ س سِّيفْ\qt*
\m \qt ؤُشَا أَربُّونْ ڒفْضِيحثْ نْسنْ\qt*
\m \qt أَكْ-ذ يِينِّي إِهْوَانْ ذڭْ وحْفُورْ \tl ن ونْضڒْ\tl*.‘\qt*
\b
\m 
\v 31 \qt ’فِيرْعُونْ أَذْ ثنْ إِژَارْ ؤُشَا أَذْ إِتّْوَاسّْفوّجْ\qt*
\m \qt زِي مَارَّا ڒْغَاشِي نّسْ إِنْهوْڒنْ،\qt*
\m \qt إِنِّي إِتّْوَاسّْنُوقّْبنْ س سِّيفْ،\qt*
\m \qt فِيرْعُونْ ذ مَارَّا ڒْعسْكَارْ نّسْ،\qt*
\m \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي٬‘ “
\m 
\v 32 \qt ’مِينْزِي نشّْ جِّيغْ ث أَذْ إِسِّيڭّْوذْ\qt*
\m \qt إِنِّي ذِي ثمُّورْثْ ن يِينِّي إِدَّارنْ.\qt*
\m \qt نتَّا أَذْ إِمَّارْسْ ذِي ڒْوسْطْ\qt*
\m \qt ن يِينِّي وَارْ إِتّْوَاخثْننْ،\qt*
\m \qt غَارْ يِينِّي إِتّْوَاسّْنُوقّْبنْ س سِّيفْ،\qt*
\m \qt فِيرْعُونْ ذ مَارَّا ڒْغَاشِي نّسْ إِنْهوْڒنْ،‘\qt*
\m \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي.“
\b
\b
\c 33
\s1 حِيزْقِييَالْ ذ أَعسَّاسْ خْ إِسْرَائِيل إِ ثْوَاڒَا وِيسّْ ثْنَاينْ
\m 
\v 1 يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا:
\v 2 ”\add أَ\add* مِّيسْ ن بْنَاذمْ، سِيوڒْ أَكْ-ذ ثَارْوَا ن ڒْڭنْسْ نّشْ، إِنِي أَسنْ: ’خْمِي غَا \add يْ\add*أَوْيغْ سِّيفْ خْ ثمُّورْثْ ؤُشَا ڒْڭنْسْ ن ثمُّورْثْ أَذْ إِكْسِي إِجّْ ن ورْيَازْ زِي طّْرُوفَا نّسْ ؤُشَا أَذْ ث ڭّنْ ذ أَعسَّاسْ إِ يِيخفْ نْسنْ
\v 3 ؤُشَا وَانِيثَا إِثْوَاڒَا يُوسَا-د سِّيفْ خْ ثمُّورْثْ، \add خنِّي\add* إِتّْسُوضْ ذڭْ ؤُيِيشّْ ن إِشَارِّي ؤُشَا إِعدْجمْ إِ ڒْڭنْسْ،
\v 4 ؤُشَا أَقَا ذِينْ إِجّنْ إِسْڒَا إِ ؤُسُوضِي ذڭْ ؤُيِيشّْ ن إِشَارِّي، \add مَاشَا\add* وَارْ إِجِّي إِخفْ نّسْ أَذْ زَّايسْ إِتّْوَاعْڒمْ ؤُشَا يُوسَا-د سِّيفْ، إِكّسْ إِ-ث، \add خنِّي\add* إِذَامّنْ نّسْ أَذْ إِڒِينْ خْ ؤُزدْجِيفْ نّسْ.
\v 5 نتَّا إِسْڒَا إِ ڒْحسّْ ن ؤُسُوضِي ذڭْ ؤُيِيشّْ ن إِشَارِّي، \add مَاشَا\add* وَارْ إِجِّي إِخفْ نّسْ أَذْ إِتّْوَاعْڒمْ، إِذَامّنْ نّسْ أَقَا أَثنْ خَاسْ، \add مَاشَا\add* ڒعْمَارْ ن ونِّي إِجِّينْ إِخفْ نّسْ أَذْ إِتّْوَاعْڒمْ، أَذْ إِنْجمْ.
\m 
\v 6 مَاشَا مَاڒَا أَعسَّاسْ إِثْوَاڒَا سِّيفْ يُوسَا-د ؤُشَا وَارْ إِسُوضْ ذڭْ ؤُيِيشّْ ن إِشَارِّي، \add أَڒَامِي\add* وَارْ إِتّْوَاعْڒمْ ڒْڭنْسْ ؤُشَا سِّيفْ يُوسَا-د، إِكّسْ إِجّْ ن ڒعْمَارْ جَارْ أَسنْ، \add خنِّي\add* أَقَا نتَّا إِمّكْسِي زِي سِّيبّثْ ن ڒْمُوعْصِييّثْ \add ن يِيخفْ\add* نّسْ، \add مَاشَا\add* نشّْ أَذْ تَّارغْ إِذَامّنْ نّسْ زڭْ ؤُفُوسْ ن ؤُعسَّاسْ.‘ “
\b
\m 
\v 7 ”شكْ، \add أَ\add* مِّيسْ ن بْنَاذمْ، نشّْ ڭِّيغْ شكْ ذ أَعسَّاسْ خْ ثَادَّارْثْ ن إِسْرَائِيل. أَذْ ثسْڒذْ إِجّْ ن وَاوَاڒْ زڭْ ؤُقمُّومْ إِنُو ؤُشَا أَذْ أَسنْ ثْعڒْمذْ زَّايِي. \x ◘ \xo 33:‏7 \xt حِز. 3‏:‏1enz.\x*
\v 8 ؤُمِي نشّْ نِّيغْ إِ ؤُعفَّانْ: ’\add أَ\add* أَعفَّانْ، شكْ أَذْ ثمّْثذْ ڒْموْثْ!‘، ؤُ شكْ وَارْ ثسِّيوِيڒذْ مَاحنْذْ أَذْ ثْعڒْمذْ إِ ؤُعفَّانْ خْ وبْرِيذْ نّسْ \add إِودَّارنْ\add*، \add خنِّي\add* أَذْ إِمّثْ ؤُعفَّانْ \add نِّي\add* س ڒْمُوعْصِييّثْ نّسْ، \add مَاشَا\add* نشّْ أَذْ تَّارغْ إِذَامّنْ نّسْ زڭْ ؤُفُوسْ نّشْ.
\v 9 \add مَاشَا\add* مَاڒَا شكْ ثْعڒْمذْ إِ ؤُعفَّانْ خْ وبْرِيذْ نّسْ، مَاحنْذْ أَذْ أَسْ إِحيّذْ ؤُشَا نتَّا وَارْ إِحيّذْ خْ وبْرِيذْ نّسْ، \add خنِّي\add* نتَّا أَذْ إِمّثْ س ڒْمُوعْصِييّثْ نّسْ، \add مَاشَا\add* شكْ ثسّْنجْمذْ ڒعْمَارْ نّشْ.“
\m 
\v 10 ”شكْ، \add أَ\add* مِّيسْ ن بْنَاذمْ، إِنِي إِ ثَادَّارْثْ ن إِسْرَائِيل: ’\add أَمُّو إِ\add* ثسَّاوَاڒمْ، ثقَّارمْ: ’إِعذِّييّنْ نّغْ ذ دّْنُوبْ نّغْ \add أَقَا أَثنْ\add* خَانغْ ؤُشَا نْهلّكْ ذَايْسنْ، \add خنِّي\add* مَامّشْ غَا \add نقِّيمْ\add* ندَّارْ؟‘ \x ◘ \xo 33:‏10 \xt حِز. 24‏:‏23\x*
\v 11 إِنِي أَسنْ: ’\add س ثِيذتّْ أَمْ\add* دَّارغْ نشّْ، إِقَّارْ سِيذِي إِنُو، سِيذِي،عمَّارْصْ وَارْ أَرطِّيغْ خْ ڒْموْثْ ن ؤُعفَّانْ، مَاشَا أَذْ أَرْضغْ أَعفَّانْ خْمِي غَا إِثُوبْ زڭْ وبْرِيذْ نّسْ ؤُشَا أَذْ إِدَّارْ. ثُوبمْ، ثُوبمْ زڭْ وبْرِيذنْ نْومْ إِعفّْننْ، مَاغَارْ مَايمِّي غَا ثمّْثذْ، \add أَ\add* ثَادَّارْثْ ن إِسْرَائِيل؟‘ “ \x ◘ \xo 33:‏11 \xt حِز. 18‏:‏23، 32\x*
\m 
\v 12 ”شكْ، \add أَ\add* مِّيسْ ن بْنَاذمْ، إِنِي إِ ثَارْوَا ن ڒْڭنْسْ نّشْ: ’ثَاسڭْذَا ن ؤُمْسڭّذْ وَارْ ث إِسّْنجِّيمْ ذڭْ وَاسّْ نِّي ذِي غَا إِخْضَا ؤُشَا ثُوعفّْنَا ن ؤُعفَّانْ وَارْ زَّايسْ إِ غَا إِنْقَارضْ ذڭْ وَاسّْ نِّي ذِي غَا إِثُوبْ زِي ثُوعفّْنَا نّسْ. أَمْسڭّذْ وَارْ إِزمَّارْ أَذْ إِقِّيمْ إِدَّارْ س ثْسڭْذَا نّسْ ذڭْ وَاسّْ نِّي ذِي غَا إِخْضَا.\x ◘ \xo 33:‏12 \xt حِز. 18‏:‏24\x*
\v 13 ؤُمِي نِّيغْ نشّْ إِ ؤُمْسڭّذْ، أَقَا نتَّا أَذْ إِدَّارْ س ثِيذتّْ، \add مَاشَا\add* نتَّا إِتِّيقّْ ذِي ثْسڭْذَا نّسْ ؤُشَا إِڭَّا ڒْمُوعْصِييّثْ، \add خنِّي\add* وَارْ ثتِّيڒِي عَاذْ ڒِيذَارثْ ذِي ثْسڭْذَا نّسْ، مَاشَا ذِي ڒْغشّْ نّسْ نِّي إِڭَّا، أَقَا أَذْ ذَايسْ إِمّثْ.
\v 14 مَاڒَا نشّْ نِّيغْ إِ ؤُعفَّانْ: ڒْموْثْ إِ غَا ثمّْثذْ!، ؤُشَا نتَّا إِثُوبْ خْ دّنْبْ نّسْ ؤُشَا أَذْ إِڭّْ ڒْحقّْ ذ ثْسڭْذَا،
\v 15 - أَقَا أَعفَّانْ أَذْ إِسّعْقبْ دِّييّثْ نّسْ، أَذْ إِخدْجصْ مِينْ إِتّْوَاشَارنْ، أَذْ يُويُورْ ذِي ثْوصَّا ن ثُوذَارْثْ بْڒَا مَا أَذْ إِڭّْ ڒْغشّْ - \add خنِّي\add* أَذْ إِدَّارْ س ثِيذتّْ، وَارْ إِتّْمتِّي شَا.
\v 16 مَارَّا دّْنُوبْ نِّي إِڭَّا، وَارْ د أَسْ تّْوَاحسّْبنْ شَا. إِڭَّا ڒْحقّْ ذ ثْسڭْذَا، أَذْ إِدَّارْ س ثِيذتّْ.‘ “
\b
\m 
\v 17 ”ثَارْوَا نْ ڒْڭنْسْ نّشْ قَّارنْ: ’أَبْرِيذْ ن سِيذِي إِنُو وَارْ إِدْجِي شَا نِيشَانْ!‘، ؤُمِي أَبْرِيذْ ن سِيمَانْثْ نْسنْ وَارْ إِدْجِي شَا نِيشَانْ. \x ◘ \xo 33:‏17 \xt حِز. 18‏:‏25، 29؛ 33‏:‏20\x*
\v 18 مَاڒَا أَمْسڭّذْ إِحيّذْ خْ ثْسڭْذَا نّسْ ؤُشَا إِتّڭّْ ڒْغشّْ، \add خنِّي\add* أَذْ ذَايسْ إِمّثْ،
\v 19 ؤُشَا خْمِي غَا إِثُوبْ ؤُعفَّانْ خْ ثُوعفّْنَا نّسْ ؤُشَا أَذْ إِڭّْ ڒْحقّْ ذ ثْسڭْذَا، \add خنِّي\add* أَذْ زَّايسْ إِدَّارْ.
\v 20 \add عَاذْ\add* ثقَّارمْ: ’أَبْرِيذْ ن سِيذِي وَارْ إِدْجِي شَا نِيشَانْ!‘ نشّْ أَذْ خَاومْ حكْمغْ، \add أَ\add* ثَادَّارْثْ ن إِسْرَائِيل، كُوڒْ  إِجّْ أَمْ يِيبْرِيذنْ نّسْ.“
\b
\s1 ڒخْبَارْ خْ ؤُوطُّو ن ؤُرْشَالِيمْ
\m 
\v 21 \bd ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثنْعَاشْ ن لْمنْفَا نّغْ، ذڭْ ؤُيُورْ وِيسّْعشْرَا، ذڭْ \bdit وَاسّْ\bdit* وِيسّْ خمْسَا ن ؤُيُورْ\bd* إِمْسَارْ بلِّي يُوسَا-د غَارِي إِجّْ ن ؤُمَارْوَاڒْ زِي ؤُرْشَالِيمْ، إِنَّا: ”ثَانْذِينْثْ ثتّْوَاغلّبْ!“\x ◘ \xo 33:‏21 \xt 2 إِج. 25؛ حِز. 24‏:‏26\x*
\v 22 غَارْ دْجِيڒثْ ثُوغَا أَفُوسْ ن سِيذِي خَافِي، قْبڒْ د غَا يَاسْ ؤُمَارْوَاڒْ ؤُ نتَّا يَارْزمْ أَيِي أَقمُّومْ ؤُمِي د-يُوسَا ؤُمَارْوَاڒْ غَارِي ذِي ضّْبحْ. ثُوغَا أَقمُّومْ إِنُو إِتّْوَارْزمْ ؤُشَا وَارْ تِّيڒِيغْ عَاذْ ذ أَيْنَاوْ.
\m 
\v 23 يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا:
\v 24 ”\add أَ\add* مِّيسْ ن بْنَاذمْ، إِمزْذَاغْ ن ڒْخِيرْبَاثْ-أَ ذِي ثمُّورْثْ ن إِسْرَائِيل سَّاوَاڒنْ، قَّارنْ: ’إِبْرَاهِيمْ ثُوغَا-ث ذ إِجّْ ؤُشَا إِوَارْثْ ثَامُّورْثْ-أَ. نشِّينْ \add ڒخُّو\add* ذڭْ وَاطَّاسْ، ثمّوْشْ أَنغْ ثمُّورْثْ ذ ثَاسْغَارْثْ!‘
\v 25 \bd س ؤُيَا\bd*، إِنِي أَسنْ: أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: كنِّيوْ ثتّثمْ \add أَيْسُومْ\add* أَكْ-ذ إِذَامّنْ ؤُشَا ثسّْڭعَّاذمْ ثِيطَّاوِينْ نْومْ غَارْ إِميْضَا ن \add لْ-أَصْنَامْ نْومْ\add* ؤُشَا ثسِّيزَّاڒمْ إِذَامّنْ. مَا إِعدّڒْ أَذْ ثطّْفمْ كنِّيوْ ثَامُّورْثْ ذ ڒْوَارْثْ؟ \x ◘ \xo 33:‏25 \xt أَمز. 9‏:‏4؛ لَاوِي 3‏:‏17\x*
\v 26 ثتّْبدَّامْ خْ سِّيفْ نْومْ، ثتّڭّمْ جّْعِيفشْثْ ؤُ كُوڒْ أَرْيَازْ إِسّْخمَّاجْ ثَامْغَارْثْ ن جَّارْ نّسْ. مَا إِعدّڒْ أَذْ ثطّْفمْ كنِّيوْ ثَامُّورْثْ ذ ڒْوَارْثْ؟‘
\v 27 أَمُّو إِ ذ أَسنْ غَا ثِينِيذْ: ’أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: \add س ثِيذتّْ أَمْ\add* دَّارغْ نشّْ، أَقَا إِنِّي إِدْجَانْ خْ ڒْخِيرْبَاثْ أَذْ وْضَانْ س سِّيفْ، ؤُ ونِّي إِدْجَانْ خْ وُوذمْ ن ييَّارْ أَذْ ث وْشغْ إِ ڒوْحُوشْ ن ڒخْڒَا مَاحنْذْ أَذْ ث صَارْضنْ ؤُشَا إِنِّي إِدْجَانْ ذِي لْقلْعَاثْ ؤُ ذڭْ إِفْرَانْ أَذْ مّْثنْ س طَّاعُونْ!
\v 28 \add مَاغَارْ\add* نشّْ أَذْ أَرّغْ ثَامُّورْثْ ذ أَردّدْجْ ذ إِجّْ ن ؤُمذْيَا ن وَارْجفْ ؤُشَا نّْفَاخثْ ن صُّولْطَا نّسْ أَذْ ثتّْوَاسّْبدّْ. إِذُورَارْ ن إِسْرَائِيل أَذْ تّْوَاردّْدْجنْ أَڒَامِي وَارْ ذِينْ وِي خَاسنْ إِ غَا إِژْوَانْ.
\v 29 \add خنِّي\add* أَذْ سّْننْ بلِّي نشّْ ذ سِيذِي، خْمِي غَا أَرّغْ ثَامُّورْثْ ذ أَردّدْجْ ذ إِجّْ ن ؤُمذْيَا ن وَارْجفْ زِي سِّيبّثْ ن جّْعَايفْ نْسنْ نِّي ڭِّينْ.‘ “
\m 
\v 30 ”شكْ، \add أَ\add* مِّيسْ ن بْنَاذمْ، أَيْثْ ن ڒْڭنْسْ نّشْ سَّاوَاڒنْ خَاكْ غَارْ ڒحْيُوضْ ؤُ غَارْ وَاذَافْ ن ثُوذْرِينْ. إِجّْ إِسَّاوَاڒْ أَكْ-ذ ونّغْنِي، كُوڒْ إِجّْ أَكْ-ذ ؤُمَاسْ، ؤُشَا إِقَّارْ: ’أَسمْ-د خنِّي ؤُشَا سْڒمْ مَانْ أَوَاڒْ إِ د إِفّغْ \add زڭْ ؤُقمُّومْ\add* ن سِيذِي!‘
\v 31 نِيثْنِي أَذْ غَاركْ د-أَسنْ أَمْ مَامّشْ إِ د-يُوسَا \add إِجّْ ن ؤُبَارُّو ن\add* ڒْڭنْسْ، أَذْ قِّيمنْ زَّاثكْ أَمْ ڒْڭنْسْ إِنُو ؤُشَا أَذْ سْڒنْ إِ وَاوَاڒنْ نّشْ، مَاشَا وَارْ زَّايْسنْ تّڭّنْ، مَاغَارْ س ؤُقمُّومْ نْسنْ سّْنِيعْمِيڒنْ ثَايْرِي، مَاشَا ؤُڒْ نْسنْ إِڭُّورْ أَوَارْنِي إِ ڒفْضڒْ ن \add يِيخفْ\add* نْسنْ. \x ◘ \xo 33:‏31 \xt حِز. 14‏:‏1‏-‏3؛ 20‏:‏1‏-‏3\x*
\v 32 ؤُشَا خْزَارْ، أَقَا شكْ غَارْسنْ أَمْ ونِّي إِتّْغنَّاجنْ إِزْڒَانْ س ثْمِيجَّا ثصْبحْ، \add أَمشْنَاوْ\add* ونِّي إِزمَّارنْ أَذْ إِڭَّا \add لْمُوسِيقَا\add* مْلِيحْ. نِيثْنِي أَذْ سْڒنْ غَارْ وَاوَاڒنْ نّشْ، \add مَاشَا\add* وَارْ زَّايْسنْ تّڭّنْ.
\v 33 \add مَاشَا\add* ڒَامِي أَذْ د-يَاسْ أَيَا - خْزَارْ، أَذْ د-يَاسْ! - \add خنِّي\add* أَذْ سّْننْ بلِّي ثُوغَا إِجّْ ن ؤُنَابِي ذِي ڒْوسْطْ نْسنْ.“
\b
\b
\c 34
\s1 سِيذِي ذ أَمكْسَاوْ أَصبْحَانْ خْ ڒْڭنْسْ نّسْ
\m 
\v 1 يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا:
\v 2 ”\add أَ\add* مِّيسْ ن بْنَاذمْ، نَابّْ ضِيدّْ إِ إِمكْسَاونْ ن إِسْرَائِيل ؤُشَا إِنِي أَسنْ: ’أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي! ؤُشْثْ خْ إِمكْسَاونْ ن إِسْرَائِيل نِّي يَاركّْوسنْ إِخفْ نْسنْ! مَا وَارْ إِتّْخصِّي إِ إِمكْسَاونْ أَذْ أَروْسنْ ؤُدْجِي؟ \f ◼ \fr 34:‏2 \ft \bd ’إِمكْسَاونْ‘\bd* - نِيغْ ’إِنِيتْشَانْ‘.\f*  \x ◘ \xo 34:‏2 \xt إِرْم. 23‏:‏1\x*
\v 3 كنِّيوْ ثتّتّمْ ثَاذُونْثْ ؤُشَا ثَارّْضمْ ثَاضُوفْثْ، ثْغَارّْصمْ إِ ڒْمَاڒْ إِمسّْڒنْ مْلِيحْ، \add مَاشَا\add* وَارْ ثَاركّْوِيسمْ ؤُدْجِي.
\v 4 وَارْ ثسّْمعْزمْ مِينْ إِهيّْفنْ، وَارْ ثتّسّْڭنْفِيمْ مِينْ إِحڒْشنْ، مِينْ إِتّْوَارْژِينْ وَارْ ث ثْشفّْنمْ، مِينْ إِودَّارنْ وَارْ ث ثتَّارِّيمْ ؤُ مِينْ إِخْسَارنْ وَارْ خَاسْ ثَارزُّومْ، \add مَاشَا\add* س ؤُقابُو ذ ؤُفُوسْ إِقسْحنْ ثْحكّْممْ خَاسنْ. \x ◘ \xo 34:‏4 \xt 1 بُط. 5‏:‏3\x*
\v 5 \add أَمُّو إِ\add* تّْوَازُوزَّارنْ، مِينْزِي وَارْ ذِينْ ثُوغِي بُو ؤُمكْسَاوْ. نِيثْنِي ذوْڒنْ ذ ثيْمَارْثْ ن ڒوْحُوشْ ن بَارَّا نِّي إِدْجَانْ ذِي ڒخْڒَا ؤُشَا \add أَمُّو إِ\add* تّْوَابزّْعنْ.
\v 6 ؤُيُورنْ ودَّارنْ ؤُدْجِي إِنُو خْ مَارَّا إِذُورَارْ ؤُ خْ كُوڒْ ثَاوْرِيرْثْ يُوعْڒَانْ، ؤُدْجِي إِنُو تّْوَابزّْعنْ خْ مَارَّا ثَامُّورْثْ. وَارْ ذِينْ وِي \add خَاسنْ\add* إِ غَا إِسّقْسَانْ ؤُشَا وَارْ ذِينْ وِي \add خَاسنْ\add* يَارزُّونْ.‘ “
\m 
\v 7 ”\bd س ؤُيَا\bd*، \add أَ\add* إِمكْسَاونْ، سْڒمْ إِ وَاوَاڒْ ن سِيذِي:
\v 8 ’\add س ثِيذتّْ أَمْ\add* دَّارغْ نشّْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي، مَا وَارْ \add تِّيڒِيغْ\add* نشّْ \add خَاسنْ\add*؟ مِينْزِي ؤُدْجِي إِنُو ذوْڒنْ ذ ثَايْمَارْثْ ؤُ ؤُدْجِي إِنُو ذوْڒنْ ذ مَاشَّا إِ ڒوْحُوشْ ن ڒخْڒَا، ؤُمِي وَارْ ذِينْ إِدْجِي ؤُمكْسَاوْ ؤُ مِينْزِي إِمكْسَاونْ إِنُو وَارْ تّْسقْسَانْ شَا خْ وُودْجِي إِنُو ؤُ ؤُمِي إِمكْسَاونْ إِنُو أَروْسنْ إِخفْ نْسنْ، وَارْ إِدْجِي ؤُدْجِي إِنُو!‘ “
\m 
\v 9 ”\bd س ؤُيَا\bd*، \add أَ\add* إِمكْسَاونْ، سْڒمْ إِ وَاوَاڒْ ن سِيذِي!
\v 10 أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ’خْزَارْ، نشّْ أَقَا أَيِي ضِيدّْ إِ إِمكْسَاونْ \add نِّي\add*! نشّْ أَذْ تَّارغْ ؤُدْجِي إِنُو زڭْ ؤُفُوسْ نْسنْ ؤُشَا أَذْ ثنْ سّْبدّغْ زڭْ وَارْوَاسْ ن وُودْجِي، أَڒَامِي إِمكْسَاونْ وَارْ يَاركّْوسنْ عَاذْ إِخفْ نْسنْ. نشّْ أَذْ سّْنجْمغْ ؤُدْجِي إِنُو زڭْ ؤُقمُّومْ نْسنْ، أَڒَامِي وَارْ ذ أَسنْ تِّيڒِينْ عَاذْ ذ مَاشَّا.‘
\v 11 مِينْزِي أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ’خْزَارْ، نشّْ أَذْ سّقْسِيغْ خْ وُودْجِي إِنُو ؤُ أَذْ خَاسنْ أَرْزُوغْ.
\v 12 أَمْ ؤُمكْسَاوْ أَذْ إِسّْمُونْ ثَاحِيمَارْثْ نّسْ ذڭْ وَاسّْ نِّي ذِي يدْجَا ذِي ڒْوسْثْ ن وُودْجِي نّسْ إِبزّْعنْ، أَمنِّي إِ غَا \add يْ\add*أَرْزُوغْ نشّْ خْ وُودْجِي إِنُو. نشّْ أَذْ ثنْ سّْنجْمغْ زِي مَارَّا إِمُوشَانْ مَانِي تّْوَابزّْعنْ، ذڭْ وَاسّْ ن إِسيْنُوثنْ ذ ثَادْجسْثْ.
\v 13 نشّْ أَذْ ثنْ سُّوفّْغغْ زِي ڒڭْنُوسْ، أَذْ ثنْ سّْمُونغْ زِي ثمُّورَا ؤُشَا أَذْ ثنْ أَوْيغْ غَارْ ثمُّورْثْ نْسنْ. نشّْ أَذْ ثنْ أَروْسغْ خْ إِذُورَارْ ن إِسْرَائِيل، غَارْ ثْغزْرَاثِينْ ؤُ ذِي مَارَّا إِمُوشَانْ إِ إِتّْڒِيقنْ إِ ثْزذِّيغْثْ ذِي ثمُّورْثْ. \x ◘ \xo 34:‏13 \xt حِز. 28‏:‏25\x*
\v 14 نشّْ أَذْ ثنْ أَروْسغْ خْ إِشْثْ ن دّمْنثْ ن ثَاروْسَا ذ ثَاصبْحَانْثْ. خْ إِذُورَارْ يُوعْڒَانْ ن إِسْرَائِيل أَذْ يِيڒِي ڒْمذْوڒْ ن ثَاروْسَا نْسنْ. ذِينِّي أَذْ أَريّْحنْ ذڭْ إِشْثْ ن دّمْنثْ ن ثَاروْسَا ثَاصبْحَانْثْ ؤُ أَذْ أَروْسنْ ذڭْ إِشْثْ ن دّمْنثْ ن ثَاروْسَا ذ لمْلِيحْ أَطَّاسْ، خْ إِذُورَارْ ن إِسْرَائِيل.
\v 15 نشّْ أَذْ أَروْسغْ ؤُدْجِي إِنُو ؤُشَا أَذْ ثنْ سَّاريّْحغْ!‘، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي.
\v 16 ’نشّْ أَذْ أَرْزُوغْ مِينْ إِخْسَارنْ ؤُشَا مِينْ إِودَّارنْ أَذْ ث أَرّغْ ؤُ مِينْ إِتّْوَارْژِينْ أَذْ ث شفْنغْ ؤُ مِينْ إِهڒْشنْ أَذْ ث سّْجهْذغْ، \add مَاشَا\add* مِينْ إِمسّْڒنْ ذ مِينْ إِجهْذنْ أَذْ ث أَردّْدْجغْ. نشّْ أَذْ ثنْ أَروْسغْ سْ ڒْحقّْ.
\v 17 ؤُ كنِّيوْ، \add أَ\add* ؤُدْجِي إِنُو، أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي، خْزَارْ، نشّْ أَذْ حكْمغْ جَارْ إِجّنْ زڭْ وُودْجِي ذ وُودْجِي نّغْنِي، جَارْ إِشَارِّييّنْ ذ إِغَايْضنْ.
\v 18 مَا ذْرُوسْثْ أَومْ ؤُمِي ثشِّيمْ دّمْنثْ ن ثَاروْسَا إِنُو ذ ثَاصبْحَانْثْ؟ مَا ثخْسمْ \add خنِّي عَاوذْ\add* أَذْ ثْعفْسمْ خْ مِينْ إِقِّيمنْ إِ ثَاروْسَا س إِضَارنْ نْومْ؟ مَا ثخْسمْ أَذْ ثسْومْ أَمَانْ إِصْفَانْ ؤُشَا \add خنِّي\add* أَذْ ثسَّارْوْينْ مِينْ إِقِّيمنْ س إِضَارنْ نْومْ؟
\v 19 مَا إِتّْخصَّا \add خنِّي\add* إِ وُودْجِي إِنُو أَذْ شّنْ مِينْ خفْعفْسنْ إِضَارنْ نْومْ ؤُ أَذْ سْونْ مِينْ سَّارْوْينْ إِضَارنْ نْومْ؟‘ “
\m 
\v 20 ”\bd س ؤُيَا\bd* أَمُّو إِ ذ أَسنْ إِقَّارْ سِيذِي إِنُو، سِيذِي: ’خْزَارْ، نشّْ أَذْ شَارّْعغْ جَارْ وُودْجِي إِمسّْڒنْ ذ وُودْجِي إِكُّوشْضنْ،
\v 21 مِينْزِي مَارَّا ؤُدْجِي إِضعْفنْ ثْعَارْنمْ إِ-ثنْ س ؤُغزْذِيسْ ؤُ س ثغْرُوضْثْ ؤُ ثسّْقَارْبمْ ثنْ س وَاشَّاونْ نْومْ، أَڒَامِي ثنْ ثْبزّْعمْ ذِي بَارَّا.
\v 22 نشّْ أَذْ سّْنجْمغْ ؤُدْجِي إِنُو أَڒَامِي وَارْ تِّيڒِينْ عَاذْ إِ ثيْمَارْثْ ؤُ نشّْ أَذْ شَارّْعغْ جَارْ إِجّنْ زڭْ وُودْجِي ذ وُودْجِي نّغْنِي.
\v 23 نشّْ أَذْ خَاسنْ سّكَّارغْ إِجّْ ن ؤُمكْسَاوْ نِّي ثنْ إِ غَا يَاروْسنْ: أَمْسخَّارْ إِنُو ذَاوُوذْ. نتَّا أَذْ ثنْ يَارْوسْ ؤُ نتَّا أَذْ أَسنْ يِيڒِي ذ أَمكْسَاوْ. \x ◘ \xo 34:‏23 \xt إِشا. 40‏:‏11؛ 42‏:‏1؛ 50‏:‏10؛ 52‏:‏13؛ 53‏:‏11؛ إِرْم. 30‏:‏9؛ حِز. 20‏:‏35‏-‏38؛ يُوح. 10‏:‏11\x*
\v 24 نشّْ، سِيذِي، أَذْ أَسنْ إِڒِيغْ ذ أَربِّي ؤُ أَمْسخَّارْ إِنُو ذَاوُوذْ أَذْ يِيڒِي ذ ڒْحَاكمْ ذِي ڒْوسْطْ نْسنْ، نشّْ، سِيذِي، أَقَا نِّيغْ ث. \x ◘ \xo 34:‏24 \xt إِشا. 55‏:‏4\x*
\v 25 نشّْ أَذْ ڭّغْ إِجّْ ن ڒْعَاهْذْ ن ڒهْنَا أَكِيذْسنْ ؤُشَا أَذْ كّْسغْ ڒوْحُوشْ إِوْعَارنْ زِي ثمُّورْثْ. نِيثْنِي أَذْ زذْغنْ ذِي ڒخْڒَا سْ ڒَامَانْ ؤُشَا أَذْ طّْصنْ ذڭْ إِزغْرَانْ. \f ◼ \fr 34:‏25 \ft \bd ’أَزْغَارْ‘\bd* - نِيغْ ’ڒْغَابثْ‘ نِيغْ ’ثَازْڭَانْثْ‘.\f*
\v 26 أَذْ ڭّغْ مِينْ إِنّْضنْ إِ وذْرَارْ إِنُو ذ لْبَارَاكَا ؤُ نشّْ أَذْ د-سّهْوِيغْ أَنْژَارْ ذِي ڒْوقْثْ نّسْ. أَذْ ذِينْ يِيڒِي ونْژَارْ أَطَّاسْ س لْبَارَاكَا.
\v 27 ثِيشجُّورَا ن ييَّارْ أَذْ وْشنْثْ ڒْغِيدْجثْ نْسنْثْ ؤُشَا ثَامُّورْثْ أَذْ ثوْشْ صَّابثْ نّسْ ؤُشَا نِيثْنِي أَذْ زذْغنْ ذِي ڒَامَانْ ذِي ثمُّورْثْ نْسنْ. \add خنِّي\add* أَذْ سّْننْ بلِّي نشّْ ذ سِيذِي، خْمِي غَا أَرْژغْ إِمْقدْجَاذنْ ن زَّايْڒثْ نْسنْ ؤُشَا أَذْ ثنْ قڒْعغْ زڭْ ؤُفُوسْ ن يِينِّي ثنْ إِجِّينْ أَذْ أَسنْ سخَّارنْ.
\v 28 وَارْ تِّيڒِينْ عَاذْ ذ ثَاكشَّاضْثْ إِ ڒڭْنُوسْ ؤُشَا ڒوْحُوشْ ن ثمُّورْثْ وَارْ ثنْ صَارّْضنْ عَاذْ، \add مَاشَا\add* نِيثْنِي أَذْ زذْغنْ ذِي ڒَامَانْ ؤُ وَارْ ثنْ إِسّْنخْڒِيعْ ؤُڒَا ذ إِجّْ.
\v 29 نشّْ أَذْ أَسنْ سّْذُوقّْزغْ إِجّْ ن ؤُغمُّويْ، أَذْ يِيڒِي إِ يِيجّْ ن يِيسمْ \add إِشنّْعنْ\add*. \add خنِّي\add* وَارْ تّْمكْسِينْ عَاذْ س ڒَاژْ زِي ثمُّورْثْ ؤُشَا وَارْ أَربُّونْ عَاذْ ڒْحڭْرَا ن ڒڭْنُوسْ. \x ◘ \xo 34:‏29 \xt حِز. 36‏:‏6‏-‏38\x*
\v 30 \add خنِّي\add* أَذْ سّْننْ بلِّي نشّْ، سِيذِي أَربِّي نْسنْ، أَقَا أَيِي كِيذْسنْ، ؤُشَا نِيثْنِي ذ ڒْڭنْسْ إِنُو، ثَادَّارْثْ ن إِسْرَائِيل!، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي.
\v 31 كنِّيوْ، \add أَ\add* ؤُدْجِي إِنُو، ؤُدْجِي ن ڒْمذْوڒْ إِنُو ن ثَاروْسَا، كنِّيوْ ذ بْنَاذمْ، \add مَاشَا\add* نشّْ ذ أَربِّي نْومْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي.‘ “ \x ◘ \xo 34:‏31 \xt يُوح. 10‏:‏11\x*
\b
\b
\c 35
\s1 أَنقَّامْ ن سِيذِي خْ إِذُومْ
\m 
\v 1 يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا:
\v 2 ”\add أَ\add* مِّيسْ ن بْنَاذمْ، أَرّْ ؤُذمْ نّشْ غَارْ إِذُورَارْ ن سَاعِيرْ ؤُ نَابّْ خَاسْ،
\v 3 \add وَاهْ،\add* إِنِي أَسْ: ’أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي! خْزَارْ، نشّْ \add أَذْ\add* غَاركْ \add د-أَسغْ\add*، \add أَ،\add* إِذُورَارْ ن سَاعِيرْ ؤُشَا أَذْ سّْوِيژّْضغْ أَفُوسْ إِنُو ضِيدّْ نّشْ ؤُشَا أَذْ شكْ أَرّغْ ذ ثَاردّدْجْثْ ذ ڒخْڒَا.
\v 4 نشّْ أَذْ أَرّغْ ثِيندَّامْ نّشْ ذ ڒْخَارْبثْ ؤُ شكْ أَذْ ثْذوْڒذْ ذ ثَاردّدْجْثْ ؤُ شكْ أَذْ ثسّْنذْ بلِّي نشّْ ذ سِيذِي،
\v 5 مِينْزِي غَاركْ ڒعْذَاوَاثْ إِتّْذُومَانْ ؤُ \add مِينْزِي\add* ثْسلّْمذْ أَيْثْ ن إِسْرَائِيل إِ ثْزمَّارْ ن سِّيفْ ذِي ڒْوقْثْ ن ؤُضيّعْ نْسنْ، ذِي ڒْوقْثْ ن لْحِيسَابْ أَنڭَّارْ خْ ڒْمُوعْصِييّثْ.‘ “ \x ◘ \xo 35:‏5 \xt حِز. 25‏:‏15\x*
\m 
\v 6 ”\bd س ؤُيَا\bd*، \add س ثِيذتّْ أَمْ\add* دَّارغْ نشّْ، إِقَّارْ سِيذِي إِنُو، سِيذِي: ’نشّْ أَذْ شكْ أَرّغْ ذ إِذَامّنْ \add قَاعْ\add* ؤُ إِذَامّنْ أَذْ شكْ ضْفَارنْ. \add وَاهْ\add* ؤُمِي وَارْ ثْشَارْهذْ شَا أَسِيزّڒْ ن إِذَامّنْ، أَذْ شكْ ضْفَارنْ إِذَامّنْ.
\v 7 نشّْ أَذْ أَرّغْ إِذُورَارْ ن سَاعِيرْ ذ ثَاردّدْجْثْ ذ ڒْخَارْبثْ. نشّْ أَذْ زَّايسْ قسّغْ وِي إِعدُّونْ ذ وِي د-إِذكّْوَاڒنْ.
\v 8 نشّْ أَذْ شُّورغْ إِذُورَارْ نّسْ س يِينِّي إِتّْوَانْغنْ، ثِيوْرِيرِينْ نّشْ ذ ثغْزُورْثِينْ نّشْ، \add وَاهْ،\add* إِنِّي إِتّْوَانْغنْ س سِّيفْ أَذْ وْضَانْ ذِي مَارَّا ثِيغزْرَاثِينْ نّشْ.
\v 9 نشّْ أَذْ شكْ ڭّغْ ذ ثِيردّدْجِينْ إِ ڒبْذَا ؤُ ثِيندَّامْ نّشْعمَّارْصْ وَارْ ذَايْسنْثْ تّْوِيفنْ \add عَاذْ\add* إِمزْذَاغْ ؤُ كنِّيوْ أَذْ ثسّْنمْ بلِّي نشّْ ذ سِيذِي،
\v 10 مِينْزِي ثنِّيذْ: ثْنَاينْ ن ڒڭْنُوسْ نِّي ذ ثْنَاينْ ن ثمُّورَا نِّي أَذْ إِڒِينْثْ إِنُو ؤُ نشِّينْ أَذْ ثنْثْ طّْفنْ ذ ڒْوَارْثْ!، \add أَمْ\add* سِيذِي أَقَا-ث ذِينْ.‘ “ \x ◘ \xo 35:‏10 \xt إِزهد. 83‏:‏13\x*
\m 
\v 11 ”\bd س ؤُيَا\bd*، \add س ثِيذتّْ أَمْ\add* دَّارغْ نشّْ، إِقَّارْ سِيذِي إِنُو، سِيذِي: ’نشّْ أَذْ أَشْ ڭّغْ أَنشْثْ ن وغْضَابْ نّشْ ؤُ أَنشْثْ ن ثُوسْمِي نّشْ نِّي ثُوغَا غَاركْ ذڭْ وشْرَاهْ نّشْ زَّايْسنْ، \add مَاشَا\add* نِيثْنِي أَذْ أَيِي سّْننْ خْمِي خَاكْ غَا حكْمغْ.
\v 12 أَذْ ثسّْنذْ، بلِّي نشّْ، سِيذِي، سْڒِيغْ إِ مَارَّا أَشقَّافْ نّشْ نِّي ثسِّيوْڒذْ ضِيدّْ إِ إِذُورَارْ ن إِسْرَائِيل، ثنِّيذْ: أَقَا ثْوَاردّْدْجنْ، مّوْشنْ أَنغْ ذ مَاشَّا.
\v 13 \add أَمُّو إِ\add* خَافِي ثْقڒْبمْ س ؤُقمُّومْ نْومْ إِشُّورْ س ؤُكبَّارْ ؤُشَا ثَارْنِيمْ ثْفَارّْغمْ أَوَاڒنْ نْومْ خَافِي أَطَّاسْ. نشّْ سْڒِيغْ ث.‘
\v 14 أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ’أَمْ ثْفَارّحْ مَارَّا ثَامُّورْثْ، نشّْ أَذْ شكْ أَرّغْ ذ إِشْثْ ن ثمُّورْثْ إِتّْوَاردّْدْجنْ.
\v 15 أَمْ مَامّشْ ثْفَارْحذْ س ثسْغَارْثْ ن ثَادَّارْثْ ن إِسْرَائِيل، مِينْزِي أَقَا ثتّْوَاردّدْجْ، نشّْ أَذْ كِيكْ ڭّغْ أَمُّو، \add أَ كنِّيوْ،\add* إِذُورَارْ ن سَاعِيرْ، \add شمْ\add* مَارَّا \add ثَامُّورْثْ\add* ن إِذُومْ، أَذْ ثِيڒِيذْ ذ ثَاردّدْجْثْ! ؤُشَا نِيثْنِي أَذْ سّْننْ، بلِّي نشّْ ذ سِيذِي.‘ “
\b
\b
\c 36
\s1 أَسِيزْذڭْ ذ ؤُرقّعْ ن إِسْرَائِيل
\m 
\v 1 ”شكْ، \add أَ\add* مِّيسْ ن بْنَاذمْ، نَابّْ إِ إِذُورَارْ ن إِسْرَائِيل، إِنِي: ’إِذُورَارْ ن إِسْرَائِيل، سْڒمْ إِ وَاوَاڒْ ن سِيذِي!\x ◘ \xo 36:‏1 \xt حِز. 6‏:‏2\x*
\v 2 أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: مِينْزِي ڒعْذُو إِنَّا خَاومْ: إِيَا، أَقَا ڒڭْعُوذِي نْ ڒبْذَا ذوْڒنْثْ أَنغْ ذ ثَاسْغَارْثْ! ... \x ◘ \xo 36:‏2 \xt حِز. 35‏:‏10\x*
\m 
\v 3 ... \bd س ؤُيَا\bd* نَابّْ، إِنِي: أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: مِينْزِي أَردّْدْجنْ ؤُ صَارْضنْ كنِّيوْ زِي مَارَّا إِغزْذِيسنْ، حِيمَا أَذْ ثْذوْڒمْ ذ ثَاسْغَارْثْ ن مِينْ إِقِّيمنْ نْ ڒڭْنُوسْ ؤُ \add مِينْزِي\add* ثتّْوَاسّكَّارنْ خَاومْ أَوَاڒنْ ؤُشَا ثْذوْڒمْ إِ ؤُشقَّافْ جَارْ ڒْڭنْسْ،
\m 
\v 4 ... \bd س ؤُيَا\bd*، إِذُورَارْ ن إِسْرَائِيل، سْڒمْ إِ وَاوَاڒْ ن سِيذِي إِنُو، سِيذِي! أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي، إِ إِذُورَارْ ذ ثوْرِيرِينْ، إِ ثْغزْرَاثِينْ ذ ڒْوَاطَاثْ، إِ ڒْخِيرْبَاثْ تّْوَاردّْدْجنْثْ ؤُ إِ ثْندَّامْ إِ إِجِّينْ، ثِينِّي إِذوْڒنْ إِ ثْكشَّاضْثْ ذ ڒْحڭْرَا إِ مِينْ إِقِّيمنْ ن ڒڭْنُوسْ نِّي د أَومْ د-إِنّْضنْ،
\m 
\v 5 ... \bd س ؤُيَا\bd*، أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: س ثِيذتّْ، أَقَا ذِي ثْمسِّي ن ثُوسْمِي إِنُو \add إِقدّْسنْ\add* سِّيوْڒغْ ضِيدّْ إِ مِينْ إِقِّيمنْ ن ڒڭْنُوسْ ؤُ ضِيدّْ إِ مَارَّا \add ثَامُّورْثْ\add* ن إِذُومْ، إِنِّي إِوْشِينْ ثَامُّورْثْ إِنُو ذ ثَاسْغَارْثْ إِ يِيخفْ نْسنْ، س ڒفْرَاحثْ ن وُوڒْ مَارَّا، س ڒعْمَارْ \add إِشُّورنْ\add* س ؤُسحْقَارْ، مَاحنْذْ دّْمَانِي ن ثَاروْسَا أَذْ أَسنْ إِڒِينْثْ ذ ثَاكشَّاضْثْ!
\m 
\v 6 ... \bd س ؤُيَا\bd*، نَابّْ ضِيدّْ إِ ثمُّورْثْ ن إِسْرَائِيل ؤُشَا إِنِي إِ إِذُورَارْ ذ ثوْرِيرِينْ ؤُ إِ ثْغزْرَاثِينْ ذ ڒْوَاطَاثْ: أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي، خْزَارْ، نشّْ سِيوْڒغْ ذِي ثُوسْمِي إِنُو \add إِقدّْسنْ\add* ؤُ ذڭْ وسْعَارْ إِنُو، مِينْزِي كنِّيوْ أَقَا ثَارْبُومْ ڒْحڭْرَا ن ڒڭْنُوسْ. \x ◘ \xo 36:‏6 \xt حِز. 34‏:‏29\x*
\m 
\v 7 ... \bd س ؤُيَا\bd*، أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي، نشّْ سّْڭعّْذغْ أَفُوسْ إِنُو، \add ژُودْجغْ\add*: س ثِيذتّْ، ڒڭْنُوسْ إِ ذ أَومْ د-إِنّْضنْ أَذْ أَرْبُونْ ڒْحڭْرَا س يِيخفْ نْسنْ!
\v 8 \add مَاشَا\add* كنِّيوْ، إِذُورَارْ ن إِسْرَائِيل، أَذْ ثوْشمْ \add عَاوذْ\add* ڒفْرُوعْ نْومْ ؤُشَا أَذْ د-ثَاوْيمْ ڒْغِيدْجثْ نْومْ إِ ڒْڭنْسْ إِنُو إِسْرَائِيل، مِينْزِي عْڒَاحَاڒْ أَذْ د-أَسنْ.
\v 9 مَاغَارْ خْزَارْ، نشّْ \add أَذْ إِڒِيغْ\add* أَكِيذْومْ ؤُشَا نشّْ أَذْ غَارْومْ نْقڒْبغْ ؤُ كنِّيوْ، \add أَ إِذُورَارْ\add*، أَذْ خَاومْ شَارْزنْ \add عَاوذْ\add* ؤُ أَذْ خَاومْ زَارّْعنْ.
\v 10 نشّْ أَذْ أَرْنِيغْ إِوْذَانْ خَاومْ، مَارَّا ثَادَّارْثْ ن إِسْرَائِيل، \add وَاهْ،\add* مَارَّا نتَّاثْ، ؤُشَا أَذْ سّْزذْغنْ ثِيندَّامْ ؤُ أَذْ بْنَانْ ڒْخِيرْبَاثْ \add عَاوذْ\add*.
\v 11 أَذْ خَاومْ أَرْنِيغْ إِوْذَانْ ذ ڒْمَاڒْ ؤُ نِيثْنِي أَذْ أَرْنِينْ ذڭْ يِيخفْ نْسنْ ؤُ أَذْ د-جّنْ ڒْغِيدْجثْ ؤُ نشّْ أَذْ كنِّيوْ سّْزذْغغْ \add ذِينْ\add* عَاوذْ، أَمْ ذڭْ وُوسَّانْ ن وشْحَاڒْ ؤُيَا، \add وَاهْ،\add* نشّْ أَذْ أَرّغْ ڒْحَاڒْ حْسنْ خْ ؤُمزْوَارْ نْومْ ؤُ كنِّيوْ أَذْ ثسّْنمْ بلِّي نشّْ ذ سِيذِي.
\v 12 أَذْ جّغْ إِوْذَانْ أَذْ خَاومْ ؤُيُورنْ: ڒْڭنْسْ إِنُو إِسْرَائِيل. نِيثْنِي أَذْ شكْ طّْفنْ ذ ڒْوَارْثْ، \add أَ ڒْڭنْسْ إِنُو\add*، ؤُ كنِّيوْ، \add أَ إِذُورَارْ ن إِسْرَائِيل،\add* أَذْ أَسنْ ثِيڒِيمْ ذ ڒْوَارْثْ، ؤُ كنِّيوْ وَارْ ثتّْكشَّاضمْ عَاذْ أَرَّاوْ \add نْسنْ\add*.
\v 13 أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: مِينْزِي قَّارنْ أَومْ: شمْ ثتّذْ إِوْذَانْ ؤُ شمْ ذ \add إِشْثْ ن ثمُّورْثْ\add* إِ إِتّْكشَّاضنْ أَرَّاوْ ن ڒْڭنْسْ نّمْ! ...
\m 
\v 14 ... \bd س ؤُيَا\bd* وَارْ ثشّذْ عَاذْ إِوْذَانْ ؤُ وَارْ ثسّْنقْرَاضذْ عَاذْ ڒْڭنْسْ نّمْ!، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي.
\v 15 نشّْ أَذْ ڭّغْعمَّارْصْ أَذْ ثتّْوَاسڒْ عَاذْ ڒْحڭْرَا نْ ڒڭْنُوسْ خَامْ ؤُ وَارْ ثْكسِّيذْ عَاذْ أَسْثهْزِي ن ڒڭْنُوسْ ؤُ وَارْ ثسّْنقْرَاضذْ عَاذْ ڒْڭنْسْ نّمْ!، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي.‘ “
\b
\m 
\v 16 يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا:
\v 17 ”\add أَ\add* مِّيسْ ن بْنَاذمْ، \add ؤُمِي\add* ثُوغَا ثَادَّارْثْ ن إِسْرَائِيل ثْزدّغْ ذِي ثمُّورْثْ نّسْ، أَقَا سّْخمّْجنْ ت س وبْرِيذْ نْسنْ ذ ثْمڭَّا نْسنْ. أَبْرِيذْ نْسنْ ثُوغَا-ث أَمْ ڒخْمجْ ن ثمْغَارْثْ إِ خْ دْجَانْ إِذَامّنْ \add ذڭْ وُوسَّانْ ن\add* وعْزَاڒْ \add نّسْ\add*.
\v 18 نشّْ سّْفَارّْغغْ خَاسنْ أَسْعَارْ إِنُو زِي سِّيبّثْ ن إِذَامّنْ نِّي سِّيزّْڒنْ خْ ثمُّورْثْ ؤُ زِي سِّيبّثْ ن إِميْضَا ن \add لْ-أَصْنَامْ نْسمْ\add* إِ زِي ت سّْخمْجنْ.
\v 19 نخّْ سّْبزّْعغْ ثنْ جَارْ ڒڭْنُوسْ ؤُ نِيثْنِي تّْوَاسُّويْسنْ ذِي ثمُّورَا. نشّْ حكْمغْ خَاسنْ عْلَاحْسَابْ ثُويُورْثْ نْسنْ ؤُ عْلَاحْسَابْ ڒخْذَايمْ نْسنْ.
\v 20 \add ؤُمِي\add* إِوْضنْ غَارْ ڒڭْنُوسْ مَانِي ثُوغَا ؤُيُورنْ، سّْفضْحنْ إِسمْ إِقدّْسنْ إِنُو، مِينْزِي إِتّْوَانَّا خَاسنْ: ’إِنَا ذ ڒْڭنْسْ ن سِيذِي، \add مَاشَا\add* ثُوغَا إِتّْخصَّا أَذْ فّْغنْ زِي ثمُّورْثْ نّسْ.‘ \x ◘ \xo 36:‏20 \xt إِشا. 52‏:‏5؛ رُوم. 2‏:‏24\x*
\v 21 مَاشَا نشّْ سّْعِيزّغْ ثنْ ذِي طّْوعْ ن يِيسمْ إِنُو إِقدّْسنْ نِّي ثسّفْضحْ ثَادَّارْثْ ن إِسْرَائِيل جَارْ ڒڭْنُوسْ مَانِي ثُوغَا ؤُيُورنْ نِيثْنِي ...
\m 
\v 22 ... \bd س ؤُيَا\bd*، إِنِي إِ ثَادَّارْثْ ن إِسْرَائِيل: أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: وَارْ ت تّڭّغْ ذِي طّْوعْ نْومْ، \add أَ\add* ثَادَّارْثْ ن إِسْرَائِيل، مَاشَا ذِي طّْوعْ ن يِيسمْ إِنُو إِقدّْسنْ نِّي ثسّْفضْحمْ كنِّيوْ جَارْ ڒڭْنُوسْ مَانِي ثُوغَا ثُويُورمْ.
\v 23 مَاغَارْ أَذْ سّْقدّْسغْ إِسمْ إِنُو إِمْغَارنْ نِّي ثسّْفضْحمْ ذِي ڒْوسْثْ نْسنْ، ؤُشَا ڒڭْنُوسْ أَذْ سّْننْ أَقَا نشّْ ذ سِيذِي، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي، خْمِي غَا تّْوَاقدّْسغْ ذَايْومْ زَّاثْ إِ ثِيطَّاوِينْ نْسنْ.
\v 24 مِينْزِي أَذْ كنِّيوْ كْسِيغْ زِي ڒڭْنُوسْ، أَذْ كنِّيوْ سّْمُونغْ زِي مَارَّا ثِيمُّورَا ؤُشَا أَذْ كنِّيوْ أَوْيغْ غَارْ ثمُّورْثْ نْومْ.
\v 25 أَذْ خَاومْ زدْجْعغْ أَمَانْ إِزْذِيڭنْ ؤُشَا أَذْ تّْوَاسِّيزْذڭمْ. نشّْ أَذْ كنِّيوْ سِّيزْذڭغْ زِي مَارَّا ڒخْمُوجَاثْ نْومْ ؤُ زِي مَارَّا إِميْضَا نْومْ \add ن لْ-أَصْنَامْ\add*.
\v 26 أَذْ أَومْ وْشغْ ؤُڒْ ن جْذِيذْ ؤُ أَذْ ڭّغْ بُوحْبڒْ أَمَايْنُو ذِي ذَاخڒْ نْومْ ؤُشَا أَذْ كّْسغْ زِي أَرِّيمثْ نْومْ ؤُڒْ ن وژْرُو ؤُشَا أَذْ أَومْ وْشغْ ؤُڒْ ن ويْسُومْ. \f ◼ \fr 36:‏26 \ft \bd ’أَمَايْنُو‘\bd* - نِيغْ ’جْذِيذْ‘.\f*  \x ◘ \xo 36:‏26 \xt إِرْم. 32‏:‏39؛ حِز. 11‏:‏19\x*
\v 27 أَذْ ڭّغْ أَرُّوحْ إِنُو ذِي ذَاخڒْ نْومْ ؤُ أَذْ أَرّغْ كنِّيوْ أَذْ ثڭّمْ ثِيوصَّا إِنُو ؤُ أَذْ ثحْضَامْ لْفَارَايِيضْ إِنُو ؤُ أَذْ زَّايْسنْثْ ثڭّمْ.
\v 28 أَذْ ثْزذْغمْ ذِي ثمُّورْثْ نِّي وْشِيغْ إِ ڒجْذُوذْ نْومْ، ؤُشَا كنِّيوْ أَذْ ثِيڒِيمْ ذ ڒْڭنْسْ إِنُو ؤُشَا نشّْ أَذْ إِڒِيغْ ذ أَربِّي نْومْ.
\v 29 نشّْ أَذْ كنِّيوْ سّْنجْمغْ زِي مَارَّا ڒخْمُوجَاثْ نْومْ. أَذْ ڒَاغِيغْ إِ إِمنْذِي ؤُشَا أَذْ ذَايسْ أَرْنِيغْ أَطَّاسْ ؤُ وَارْ ذ أَومْ تِّيشغْ ڒَاژْ. \x ◘ \xo 36:‏29 \xt حِز. 34‏:‏29\x*
\v 30 أَذْ أَرْنِيغْ \add أَمنِّي\add* ڒْغِيدْجثْ ن ثْشجُّورَا ؤُ ن ييَّارْ، حِيمَا وَارْ خَاومْ ثكّْ عَاذْ ڒْحڭْرَا ن ڒَاژْ جَارْ ڒڭْنُوسْ.
\v 31 \add خنِّي\add* أَذْ ثِيذَارمْ ذڭْ إِبْرِيذنْ نْومْ إِعفّْننْ ذ ثْمڭَّا نْومْ وَارْ إِصبْحنْ ؤُ كنِّيوْ أَذْ ثْعِيفّمْ زڭْ يِيخفْ نْومْ ؤُ زِي جّْعَايفْ نْومْ. \x ◘ \xo 36:‏31 \xt حِز. 6‏:‏9؛ 20‏:‏43؛ 16‏:‏61، 63\x*
\v 32 \add مَاشَا\add* وَارْ ت تّڭّغْ ذِي طّْوعْ نْومْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي، سْنمْ ت مْلِيحْ! سضْحَامْ ؤُ سّْنمْ ڒفْضِيحثْ ن إِبْرِيذنْ نْومْ، \add أَ\add* ثَادَّارْثْ ن إِسْرَائِيل.“
\m 
\v 33 ”أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ’\bd ذڭْ وَاسّْ نِّي\bd* أَذْ سِّيزذْڭغْ مَارَّا ڒْمُوعْصِييَّاثْ نْومْ، أَذْ سّْزذْغغْ ثِيندَّامْ \add عَاوذْ\add* ؤُشَا أَذْ بْنِيغْ \add عَاوذْ\add* ڒْخِيرْبَاثْ.
\v 34 ثَامُّورْثْ إِتّْوَاردّْدْجنْ أَذْ ثتّْوَاشَارْزْ ذڭْ ومْشَانْ إِ غَا ثِيڒِي ثتّْوَاردّدْجْ زَّاثْ إِ ثِيطَّاوِينْ ن مَارَّا إِنِّي ت إِژكّْوَانْ.
\v 35 أَذْ إِنِينْ: ثَامُّورْثْ نِّي ثُوغَا ثتّْوَاردّدْجْ، ثذْوڒْ أَمْ جّنّثْ ن عَاذْنْ ؤُ ثِيندَّامْ تّْوَاخَارَّابنْثْ ذ تّْوَاردّْدْجنْثْ ذ تّْوَاهذْمنْثْ، أَقَا تّْوَاسّْجهْذنْثْ ؤُ زدّْغنْ ذَايْسنْثْ إِمزْذَاغْ \add عَاوذْ\add*. \x ◘ \xo 36:‏35 \xt إِشا. 51‏:‏3؛ حِز. 28‏:‏13\x*
\v 36 \add خنِّي\add* أَذْ سّْننْ ڒڭْنُوسْ نِّي إِقِّيمنْ ذڭْ ونّضْ نْومْ، أَقَا نشّْ، سِيذِي، أَذْ بْنِيغْ مِينْ إِتّْوَاهذْمنْ \add عَاوذْ\add* ؤُ أَذْ ژُّوغْ خْ مِينْ إِتّْوَاردّْدْجنْ. نشّْ، سِيذِي، سِّيوْڒغْ ؤُ نشّْ أَذْ ث ڭّغْ.‘ “ \x ◘ \xo 36:‏36 \xt حِز. 17‏:‏24؛ 22‏:‏14؛ 37‏:‏14\x*
\m 
\v 37 ”أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ’أَذْ أَيِي ثتَّارْ ثَادَّارْثْ ن إِسْرَائِيل ؤُڒَا ذ مَانْ أَيَا حِيمَا أَذْ أَسنْ ث ڭّغْ. نشّْ أَذْ ذَايْسنْ أَرْنِيغْ \add إِوْذَانْ\add*، \add أَڒَامِي أَذْ ذِينْ إِڒِينْ\add* أَنشْثْ ن إِوْذَانْ أَمْ وُودْجِي.
\v 38 أَنشْثْ إِدْجَانْ ن وُودْجِي إِقدّْسنْ أَمْ وُودْجِي إِ شُّورنْ \add ثَانْذِينْثْ ن\add* ؤُرْشَالِيمْ ذِي ڒعْيُوذَاثْ نّسْ إِتّْوَاڭّنْ، أَمُّو إِ غَا إِڒِينْثْ ثْندَّامْ إِتّْوَاردّْدْجنْ شُّورنْثْ س وُودْجِي ذ إِوْذَانْ ؤُ نِيثْنِي أَذْ سّْننْ أَقَا نشّْ ذ سِيذِي.‘ “
\b
\b
\c 37
\s1 ثَانُوكْرَا ن إِسْرَائِيل
\m 
\v 1 ثُوغَا ؤُفُوسْ ن سِيذِي خَافِي ؤُشَا سِيذِي إِسُّوفّغْ أَيِي-د ذِي أَرُّوحْ ؤُشَا إِسَّارْسْ أَيِي ذِي ڒْوسْطْ ن ڒوْضَا نِّي ثُوغَا يشُّورنْ س إِغْسَانْ.
\v 2 نتَّا إِنْذهْ أَيِي ذڭْ ونّضْ نّسْ، ؤُ خْزَارْ، أَقَا ذِينْ أَطَّاسْ س وَاطَّاسْ \add ن إِغْسَانْ\add* خْ وُوذمْ ن ڒوْضَا، ؤُ خْزَارْ، أَقَا أَثنْ ؤُژْغنْ أَطَّاسْ.
\v 3 نتَّا إِنَّا أَيِي: ”\add أَ\add* مِّيسْ ن بْنَاذمْ، مَا أَذْ دَّارنْ إِغْسَانْ-أَ \add عَاوذْ\add*؟“ نِّيغْ نشّْ: ”\add أَ\add* سِيذِي إِنُو، سِيذِي، شكْ ثسّْنذْ \add ث\add*!“
\v 4 \add خنِّي\add* إِنَّا أَيِي: ”نَابّْ خْ يغْسَانْ-أَ، إِنِي أَسنْ: ’\add أَ\add* إِغْسَانْ ؤُژْغنْ، سْڒمْ إِ وَاوَاڒْ ن سِيذِي.
\v 5 أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي، إِ إِغْسَانْ-أَ: خْزَارْ، نشّْ أَذْ ذَايْومْ سِّيذْفغْ بُوحْبڒْ ؤُشَا أَذْ ثدَّارمْ \add عَاوذْ\add*.
\v 6 أَذْ خَاومْ ڭّغْ إِژوْرَانْ ؤُ أَذْ خَاومْ سّْڭعّْذغْ أَيْسُومْ ؤُشَا أَذْ كنِّيوْ ذْڒغْ س إِڒمْ ؤُشَا أَذْ ذَايْومْ ڭّغْ بُوحْبڒْ، أَذْ ثدَّارمْ \add عَاوذْ\add*. \add خنِّي\add* أَذْ ثسّْنمْ بلِّي نشّْ ذ سِيذِي.‘ “
\m 
\v 7 \add ڒَامِي\add* ثُوغَا تّْنَابّغْ أَمْ مَامّشْ ذ أَيِي إِتّْوَاوصَّا، ؤُشَا ثُوغَا \add ذِينْ\add* إِجّْ ن ڒْحسّْ ڒَامِي ثُوغَا تّْنَابّغْ، ؤُ خْزَارْ، \add أَقَا ذَا\add* إِشْثْ ن ثَارْجِيجِيثْ ؤُشَا إِغْسَانْ مُوننْ، \add كُوڒْ\add* إِغسْ أَكْ-ذ إِغسْ نّسْ.
\v 8 ژْڒِيغْ، ؤُ خْزَارْ، أَقَا ذوْڒنْ خَاسنْ-د إِژوْرَانْ ؤُ يُوڒِي خَاسنْ ويْسُومْ ؤُ نتَّا إِذْڒَا إِ-ثنْ س يِيڒمْ سنّجْ نْسنْ، \add مَاشَا\add* وَارْ ذَايْسنْ ثُوغِي \add عَاذْ\add* بُوحْبڒْ.
\v 9 نتَّا إِنَّا أَيِي: ”نَابّْ إِ أَرُّوحْ، نَابّْ، \add أَ\add* مِّيسْ ن بْنَاذمْ، ؤُشَا إِنِي إِ أَرُّوحْ: ’أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: أَسْ-د زِي أَربْعَا ن ثْغمُّورَا ن ؤُسمِّيضْ، \add أَ\add* أَرُّوحْ، ؤُ سُوضْ ذڭْ إِنَا إِنِّي إِتّْوَانْغنْ، \add حِيمَا\add* أَذْ دَّارنْ.‘ “
\v 10 \add خنِّي\add* نَابّغْ أَمْ مَامّشْ إِ ذ أَيِي إِتّْوَاوصَّا. ؤُشَا يُوذفْ أَرُّوحْ ذَايْسنْ ؤُشَا دَّارنْ \add عَاوذْ\add* ؤُشَا \add كَّارنْ\add* بدّنْ خْ إِضَارنْ نْسنْ، \add أَقَا\add* ذ إِجّْ ن ڒْعسْكَارْ ذ أَمقّْرَانْ أَطَّاسْ س وَاطَّاسْ.
\m 
\v 11 \add خنِّي\add* إِنَّا أَيِي: ”\add أَ\add* مِّيسْ ن بْنَاذمْ، إِغْسَانْ-أَ \add أَقَا أَثنْ\add* مَارَّا ثَادَّارْثْ ن إِسْرَائِيل. خْزَارْ، نِيثْنِي قَّارنْ: ’إِغْسَانْ نّغْ ؤُژْغنْ ؤُشَا ڒَايَاسْ نّغْ إِودَّارْ ؤُ نشِّينْ نتّْوَاقْضعْ!‘
\v 12 \bd س ؤُيَا\bd*، نَابّْ، إِنِي أَسنْ: ’أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: خْزَارْ، نشّْ أَذْ أَرْزْمغْ إِمضْڒَانْ نْومْ، أَذْ كنِّيوْ سّْڭعّْذغْ زڭْ إِمضْڒَانْ نْومْ، \add أَ\add* ڒْڭنْسْ إِنُو، ؤُ نشّْ أَذْ كنِّيوْ أَوْيغْ خْ وُوذمْ ن ثمُّورْثْ ن إِسْرَائِيل.
\v 13 كنِّيوْ أَذْ ثسّْنمْ، بلِّي نشّْ ذ سِيذِي، ؤُمِي أَرْزْمغْ إِمضْڒَانْ نْومْ ؤُشَا سُّوفّْغغْ-د كنِّيوْ زڭْ إِمضْڒَانْ نْومْ، \add أَ\add* ڒْڭنْسْ إِنُو.
\v 14 نشّْ أَذْ ڭّغْ أَرُّوحْ إِنُو ذَايْومْ \add ذِي ذَاخڒْ نْومْ\add* ؤُ كنِّيوْ أَذْ ثدَّارمْ \add عَاوذْ\add* ؤُ نشّْ أَذْ كنِّيوْ سَّارْسغْ خْ وُوذمْ ن ثمُّورْثْ نْومْ ؤُ كنِّيوْ أَذْ ثسّْنمْ بلِّي نشّْ، سِيذِي، سِّيوْڒغْ ؤُشَا ڭِّيغْ \add ث\add*، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.‘ “
\b
\s1 أَسْمُونِي ن إِسْرَائِيل ذ يَاهُوذَا
\m 
\v 15 يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا:
\v 16 ”شكْ، \add أَ\add* مِّيسْ ن بْنَاذمْ، كْسِي إِجّْ ن ؤُزدْجَاضْ \add ن ؤُكشُّوضْ\add* ؤُشَا أَرِي ذَايسْ: ’إِ يَاهُوذَا ؤُ إِ أَرَّاوْ ن إِسْرَائِيل، إِمْعَاشَارنْ نّسْ!‘ كْسِي أَوَارْنِي أَسْ أَزدْجَاضْ نّغْنِي ؤُشَا أَرِي ذَايسْ: ’إِ يُوسُوفْ، أَزدْجَاذْ ن إِفْرَايِيمْ، ؤُ \add إِ\add* مَارَّا ثَادَّارْثْ ن إِسْرَائِيل، إِمدُّوكَّاڒْ نّسْ!‘
\v 17 سْمُونْ ثنْ خنِّي إِجّْ أَكْ-ذ ونّغْنِي، \add أڭّْ زَّايْسنْ\add* إِجّْ ن ؤُزدْجَاضْ إِ شكْ. أَذْ ذوْڒنْ ذ إِجّْ ذڭْ ؤُفُوسْ نّشْ.
\m 
\v 18 خْمِي كِيكْ إِ غَا إِسِّيوْڒنْ ثَارْوَا ن ڒْڭنْسْ نّشْ، أَذْ إِنِينْ: ’مَا وَارْ ثخْسذْ أَذْ أَنغْ ثسّشْنذْ مِينْ إِخْسْ أَذْ إِنِينْثْ ثْمسْڒَايِينْ-أَ إِ شكْ؟‘،
\v 19 إِنِي أَسنْ: ’أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: خْزَارْ، نشّْ أَذْ كْسِيغْ أَزدْجَاضْ ن يُوسُوفْ، ونِّي إِدْجَانْ ذڭْ ؤُفُوسْ ن إِفْرَايِيمْ، \add أَزدْجَاضْ\add* ن ثْقبَّاڒْ ن إِسْرَائِيل، إِمْعَاشَارنْ نّسْ، ؤُشَا أَذْ ثنْ سّْمُونغْ أَكْ-ذ ؤُزدْجَاضْ ن يَاهُوذَا ؤُشَا أَذْ ثنْ ڭّغْ ذ إِجّْ ن ؤُزدْجَاضْ ؤُشَا أَذْ ذوْڒنْ ذ إِجّْ ذڭْ ؤُفُوسْ إِنُو.‘
\v 20 إِزدْجَاضنْ زڭْ ؤُكشُّوضْ إِ خْ ثُورِيذْ، \add أَذْ إِڒِينْ\add* ذڭْ ؤُفُوسْ نّشْ زَّاثْ إِ ثِيطَّاوِينْ نْسنْ.
\v 21 \add خنِّي\add* إِنِي أَسنْ: ’أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: خْزَارْ، نشّْ أَذْ طّْفغْ أَيْثْ ن إِسْرَائِيل زِي ڒْوسْثْ نْ ڒڭْنُوسْ مَانِي غَارْ ؤُيُورنْ ؤُشَا أَذْ ثنْ سّْمُونغْ زڭْ ونّضْ ؤُشَا أَذْ ثنْ أَوْيغْ غَارْ وُوذمْ ن ثمُّورْثْ نْسنْ.
\v 22 نشّْ أَذْ ثنْ ڭّغْ ذ إِجّْ ن ڒْڭنْسْ ذِي ثمُّورْثْ، خْ إِذُورَارْ ن إِسْرَائِيل، ذ إِجّْ ن ؤُجدْجِيذْ أَذْ يِيڒِي إِ مَارَّا إِذْسنْ ذ أَجدْجِيذْ ؤُشَاعمَّارْصْ عَاذْ أَذْ إِڒِينْ إِ ثْنَاينْ نْ ڒڭْنُوسْ ؤُعمَّارْصْ عَاذْ أَذْ تّْوَابْضَانْ ذِي ثْنَاينْ ن ثْڭلْذِيوِينْ. \x ◘ \xo 37:‏22 \xt يُوح. 10‏:‏16\x*
\v 23 وَارْ سّْخمَّاجنْ عَاذْ إِخفْ نْسنْ س إِميْضَا نْسنْ ن لْ-أَصْنَامْ، س نّْعَاوَاثْ نْسنْ ن لْ-أَصْنَامْ ؤُ س ڒْمُوعْصِييَّاثْ نْسنْ. نشّْ أَذْ ثنْ سّْنجْمغْ زِي مَارَّا ثِيندَّامْ نْسنْ إِ ذِي خْضِينْ نِيثْنِي ؤُ نشّْ أَذْ ثنْ سِّيزذْڭغْ. \add خنِّي\add* نِيثْنِي أَذْ أَيِي إِڒِينْ ذ ڒْڭنْسْ ؤُ نشّْ أَذْ أَسنْ إِڒِيغْ ذ أَربِّي.
\v 24 أَمْسخَّارْ إِنُو ذَاوُوذْ أَذْ خَاسنْ يِيڒِي ذ أَجدْجِيذْ ؤُشَا أَذْ ذِينْ يِيڒِي إِجّْ ن ؤُمكْسَاوْ إِ مَارَّا نِيثْنِي. نِيثْنِي أَذْ ضْفَارنْ لْفَارَايِيضْ إِنُو ؤُشَا أَذْ حْضَانْ ثِيوصَّا إِنُو، أَذْ زَّايْسنْثْ ڭّنْ. \f ◼ \fr 37:‏24 \ft \bd ’أَمكْسَا‘\bd* - نِيغْ ’أَنِيتْشْ إِ‘.\f*  \x ◘ \xo 37:‏24 \xt إِشا. 40‏:‏11؛ إِرْم. 30‏:‏9؛ حِز. 34‏:‏23\x*
\v 25 أَذْ زذْغنْ ذِي ثمُّورْثْ نِّي وْشِيغْ إِ ؤُمْسخَّارْ إِنُو يَاعْقُوبْ، إِ ذِي ثُوغَا زدّْغنْ ڒجْذُوذْ نْومْ، \add وَاهْ،\add* نِيثْنِي أَذْ ذَايسْ زذْغنْ إِ ڒبْذَا، نِيثْنِي ذ إِحنْجِيرنْ نْسنْ ذ إِحنْجِيرنْ ن إِحنْجِيرنْ نْسنْ، ؤُشَا أَمْسخَّارْ إِنُو ذَاوُوذْ أَذْ يِيڒِي ذ ڒْحَاكمْ نْسنْ إِ ڒبْذَا.
\v 26 نشّْ أَذْ كِيذْسنْ قضْعغْ إِجّْ ن ڒْعَاهْذْ ن ڒهْنَا، أَذْ يِيڒِي ذ ڒْعَاهْذْ إِ ڒبْذَا. نشّْ أَذْ ثنْ بَارْكغْ ؤُ أَذْ ذَايْسنْ أَرْنِيغْ أَطَّاسْ ؤُ نشّْ أَذْ ڭّغْ زَّاوشْثْ إِنُو إِقدّْسنْ ذِي ڒْوسْطْ نْسنْ إِ ڒبْذَا. \x ◘ \xo 37:‏26 \xt إِزهد. 89‏:‏4؛ حِز. 34‏:‏25؛ 2 كُور. 6‏:‏16\x*
\v 27 أَذْ غَارْسنْ ثِيڒِي ثْزذِّيغْثْ إِنُو ؤُ نشّْ أَذْ إِڒِيغْ ذ أَربِّي نْسنْ ؤُ نِيثْنِي أَذْ إِڒِينْ ذ ڒْڭنْسْ إِنُو، \x ◘ \xo 37:‏27 \xt حِز. 11‏:‏20؛ 14‏:‏11\x*
\v 28 ؤُشَا أَذْ سّْننْ ڒڭْنُوسْ، بلِّي نشّْ ذ سِيذِي نِّي إِسّْقدّْسنْ إِسْرَائِيل خْمِي غَا ثِيڒِي زَّاوشْثْ إِنُو إِقدّْسنْ ذِي ڒْوسْطْ نْسنْ إِ ڒبْذَا.‘ “
\b
\b
\c 38
\s1 أَهْجَامْ ن هَاجُوجْ
\m 
\v 1 يُوسَا-د غَارِي وَاوَاڒْ ن سِيذِي، إِنَّا:
\v 2 ”\add أَ\add* مِّيسْ ن بْنَاذمْ، أَرّْ ؤُذمْ نّشْ غَارْ \add هَا\add*جُوجْ \add زِي\add* ثمُّورْثْ ن مَاجُوجْ، ڒْحَاكمْ ن رُوشْ، مَاشِيكْ ذ ثُوبَالْ، ؤُشَا نَابّْ ضِيدّْ نّسْ، \f ◼ \fr 38:‏2 \ft \bd ’هَاجُوجْ‘\bd* - نِيغْ ’جُوجْ‘، نِيغْ ’خُوخْ‘، نِيغْ ’ڭُوڭْ‘. \bd ’مَاجُوجْ‘\bd* - نِيغْ ’مَاخُوخْ‘، نِيغْ ’مَاڭُوڭْ‘.\f*  \x ◘ \xo 38:‏2 \xt أَسَا. 20‏:‏8\x*
\v 3 إِنِي: ’أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: خْزَارْ، نشّْ أَقَا أَيِي ضِيدّْ نّشْ، \add أَ\add* \add هَا\add*جُوجْ، ڒْحَاكمْ ن رُوشْ، مَاشِيكْ ذ ثُوبَالْ. \f ◼ \fr 38:‏3 \ft \bd ’هَاجُوجْ‘\bd* - نِيغْ ’جُوجْ‘، نِيغْ ’خُوخْ‘، نِيغْ ’ڭُوڭْ‘.\f*
\v 4 نشّْ أَذْ شكْ قمّْعغْ ؤُ أَذْ ڭّغْ ثِيسنَّارِينْ ذڭْ إِقَابْسِيونْ نّشْ ؤُشَا أَذْ شكْ سُّوفّْغغْ، شكْ ذ مَارَّا ڒْعسْكَارْ نّشْ، إِيْسَانْ ذ إِمْنَاينْ، مَارَّا أَرْضنْ أَرُّوضْ مْلِيحْ أَطَّاسْ، إِجّْ ن وڭْرَاوْ ذ أَمقّْرَانْ أَطَّاسْ، س ثْسدَّارْثْ ثَامقّْرَانْثْ ذ ثْسدَّارْثْ ثَامژْيَانْثْ \add ن ؤُعسْكَارِي\add*، مَارَّا نِيثْنِي غَارْسنْ ثِيزمَّارْ ذڭْ ؤُمنْغِي س سِّيفْ. \x ◘ \xo 38:‏4 \xt حِز. 29‏:‏4؛ 39‏:‏2\x*
\v 5 أَيْثْ ن لْفُورْسْ، ن كُوشْ ؤُ ن فُوطْ أَكِيذْسنْ، مَارَّا إِذْسنْ س ثْسدَّارْثْ \add ن ؤُعسْكَارِي\add* ذ لْكَاسْكْ \add ن ؤُعسْكَارِي\add*،
\v 6 جُومَارْ أَكْ-ذ مَارَّا ڒْعسْكَارْ نّسْ، ذ ثَادَّارْثْ ن ثُوجَارْمَا زِي طّْرُوفَا ن شَّامَالْ قَاعْ أَكْ-ذ مَارَّا ڒْعسْكَارْ نّسْ، \add وَاهْ،\add* أَطَّاسْ ن ڒڭْنُوسْ \add أَذْ د-أَسنْ\add* أَكِيذكْ.
\v 7 إِڒِي ثْوجْذذْ ؤُ سوْجذْ إِخفْ نّشْ، شكْ ذ مَارَّا أَڭْرَاوْ نّشْ نِّي ثسّْمُونذْ غَاركْ، ؤُ إِڒِي ذ أَمحْضَايْ نْسنْ.
\v 8 أَوَارْنِي وَاطَّاسْ ن وُوسَّانْ أَذْ ثتّْوَاڒَاغِيذْ، أَوَارْنِي ڒَامِي عْذُونْ أَطَّاسْ ن إِسڭّْوُوسَا أَذْ د-ثَاسذْ غَارْ ثمُّورْثْ نِّي إِتّْوَاعذْڒنْ زِي سِّيفْ، \add غَارْ إِجّْ ن ڒْڭنْسْ\add* إِ إِتّْوَاسّْمُوننْ زِي ڒڭْنُوسْ خْ إِذُورَارْ ن إِسْرَائِيل نِّي ثُوغَا ذ ڒْخِيرْبثْ إِ يِيجّْ ن ڒْوقْثْ ذ أَزِيرَارْ، \add غَارْ إِجّْ ن ڒْڭنْسْ\add* نِّي إِتّْوَاسُّوفّْغنْ زِي ڒڭْنُوسْ، ؤُ مَارَّا نِيثْنِي زدّْغنْ \add ذِينِّي\add* ذِي ڒَامَانْ.
\v 9 \add خنِّي\add* أَذْ ثْڭعّْذذْ أَمْ ثْحَارْيَاضْثْ، أَمْ ؤُسيْنُو مَاحنْذْ أَذْ ثذْڒذْ ثَامُّورْثْ، شكْ ذ مَارَّا ڒْعسْكَارْ نّشْ ؤُڒَا ذ أَطَّاسْ ن ڒڭْنُوسْ نِّي كِيكْ \add إِدْجَانْ\add*.‘ “\x ◘ \xo 38:‏9 \xt حِز. 30‏:‏18\x*
\m 
\v 10 ”أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ’\bd ذڭْ وَاسّْ نِّي\bd* أَذْ إِمْسَارْ، أَقَا أَذْ أَذْفنْ إِخَارِّيصنْ ذڭْ وُوڒْ نّشْ ؤُ شكْ أَذْ ثْخَارّْصذْ ذِي ثْمعْمُوتْشْ ثَاعفَّانْثْ.
\v 11 أَذْ ثِينِيذْ: أَذْ ڭعّْذغْ غَارْ إِشْثْ ن ثمُّورْثْ س ثْندَّامْ بْڒَا ڒحْيُوضْ، أَذْ د-أَسغْ غَارْ \add ينِّي ذِينْ\add* إِدَّارنْ ذِي ڒهْنَا ؤُ \add غَارْ يِينِّي ذِينْ\add* إِزدّْغنْ ذِي ڒَامَانْ، إِنِّي ذِينْ إِزدّْغنْ مَارَّا بْڒَا ڒْحِيضْ ؤُ بْڒَا زّكْرُونَاثْ نِيغْ ثِيوُّورَا،
\v 12 مَاحنْذْ أَذْ كشّْضغْ ؤُ أَذْ أَشَارغْ أَڭْڒَا! \add وَاهْ،\add* مَاحنْذْ أَذْ ثَارّذْ أَفُوسْ نّشْ خْ ڒْخِيرْبَاثْ نِّي ذِي زدّْغنْ \add عَاوذْ إِوْذَانْ\add*، خْ يِيجّْ نْ ڒْڭنْسْ نِّي إِتّْوَاسّْمُوننْ زِي ڒڭْنُوسْ، ونِّي إِكسْبنْ ڒْمَاڒْ ذ وَاڭْڒَا، ونِّي إِزدّْغنْ خْ ثْعبُّوضْثْ ن ثمُّورْثْ.
\v 13 شَابَا ذ ذَاذَانْ ذ تُّوجَارْ ن ثَارْشِيشْ ذ مَارَّا أَيْرَاذنْ إِمژْيَانِينْ نْسنْ أَذْ أَشْ إِنِينْ: مَا د-ثُوسِيذْ مَاحنْذْ أَذْ ثطّْفذْ ثَاكشَّاضْثْ؟ مَا ثسّْمُونذْ أَڭْرَاوْ نّشْ مَاحنْذْ أَذْ ثْكشّْضذْ، حِيمَا أَذْ ثكْسِيذْ نُّوقَارْثْ ذ وُورغْ، حِيمَا أَذْ ثطّْفذْ ڒْمَاڒْ ذ وَاڭْڒَا، حِيمَا أَذْ ثَاشَارذْ ثَاكشَّاضْثْ ثَامقّْرَانْثْ؟‘ “
\m 
\v 14 ”\bd س ؤُيَا\bd*، نَابّْ، \add أَ\add* مِّيسْ ن بْنَاذمْ، ؤُشَا إِنِي إِ \add هَا\add*جُوجْ ’أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: \bd ذڭْ وَاسّْ نِّي\bd*، خْمِي غَا إِزْذغْ ڒْڭنْسْ إِنُو إِسْرَائِيل ذِي ڒَامَانْ، مَا شكْ وَارْ ثسِّينذْ \add مِينْ إِتّْخصَّا أَذْ ث ثڭّذْ\add*؟ \f ◼ \fr 38:‏14 \ft \bd ’هَاجُوجْ‘\bd* - نِيغْ ’جُوجْ‘، نِيغْ ’خُوخْ‘، نِيغْ ’ڭُوڭْ‘.\f*
\v 15 أَذْ د-ثَاسذْ زڭْ ومْشَانْ نّشْ، زِي طّْرُوفَا ن شَّامَالْ قَاعْ، شكْ ذ وَاطَّاسْ نْ ڒڭْنُوسْ أَكِيذكْ. مَارَّا نِيثْنِي ذ إِمْنَاينْ س إِيْسَانْ، إِجّْ ن وڭْرَاوْ ذ أَمقّْرَانْ ذ يِيجّْ ن ڒْعسْكَارْ إِجهْذنْ.
\v 16 أَذْ ثْڭعّْذذْ ضِيدّْ إِ ڒْڭنْسْ إِنُو إِسْرَائِيل، أَمْ يِيجّْ ن ؤُسيْنُو، مَاحنْذْ أَذْ ثذْڒذْ ثَامُّورْثْ. أَذْ يِيڒِي ذڭْ ؤُنڭَّارْ ن وُوسَّانْ. نشّْ أَذْ شكْ سِّيوْضغْ خْ ثمُّورْثْ إِنُو، حِيمَا ڒڭْنُوسْ أَذْ أَيِي سّْننْ، خْمِي زَّايكْ إِ غَا تّْوَاقدّْسغْ زَّاثْ إِ ثِيطَّاوِينْ نْسنْ، \add أَ\add* \add هَا\add*جُوجْ!‘ \f ◼ \fr 38:‏16 \ft \bd ’هَاجُوجْ‘\bd* - نِيغْ ’جُوجْ‘، نِيغْ ’خُوخْ‘، نِيغْ ’ڭُوڭْ‘.\f*
\v 17 أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ’مَا أَقَا شكْ ذ ونِّي خْ سِّيوْڒغْ ذڭْ وُوسَّانْ ن زِيشْ، س ؤُفُوسْ ن إِمْسخَّارنْ إِنُو، إِنَابِييّنْ ن إِسْرَائِيل نِّي ثُوغَا إِتّْنَابّنْ ذڭْ وُوسَّانْ نِّي، \add ڒْْمِيجَاڒْ ن\add* وَاطَّاسْ ن إِسڭّْوُوسَا، بلِّي نشّْ أَذْ شكْ سِّيوْضغْ ضِيدّْ نْسنْ؟
\v 18 \bd ذڭْ وَاسّْ نِّي\bd*، ذڭْ وَاسّْ إِ ذِي د غَا يَاسْ \add هَا\add*جُوجْ ضِيدّْ إِ ثمُّورْثْ ن إِسْرَائِيل، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي، أَقَا أَذْ يَاڒِي وسْعَارْ إِنُو ذڭْ ونْزَارنْ إِنُو. \f ◼ \fr 38:‏18 \ft \bd ’هَاجُوجْ‘\bd* - نِيغْ ’جُوجْ‘، نِيغْ ’خُوخْ‘، نِيغْ ’ڭُوڭْ‘.\f*
\v 19 ذِي ثُوسْمِي إِنُو \add إِقدّْسنْ\add*، ذِي ثْمسِّي ن ؤُذُوقّزْ إِنُو \add ن ؤُفُوڭمْ\add* نِّيغْ: \add س ثِيذتّْ، أَمْ دَّارغْ نشّْ\add*، مَاڒَا \bd ذڭْ وَاسّْ نِّي\bd* وَارْ إِتِّيڒِي إِجّْ ن ونْهزِّي ن ثمُّورْثْ أَمقّْرَانْ ذِي ثمُّورْثْ ن إِسْرَائِيل، \x ◘ \xo 38:‏19 \xt حِز. 36‏:‏5، 6؛ أَسَا. 16‏:‏18\x*
\v 20 \add أَڒَامِي\add* إِسڒْمَانْ ن ڒبْحَارْ ذ إِجْضَاضْ ن ؤُجنَّا ذ ڒْمَاڒْ ن ييَّارْ ذ مَارَّا ڒْمَاڒْ نِّي إِتّْبُوعنْ خْ ثمُّورْثْ ذ مَارَّا إِوْذَانْ نِّي \add إِدْجَانْ\add* خْ وُوذمْ ن ثمُّورْثْ أَذْ أَرْجِيجنْ، ؤُ إِذُورَارْ أَذْ تّْوَامنْضَارنْ ؤُ ڒجْرُوفْ إِعُودْجنْ أَذْ هْرُورَانْ ذ مَارَّا ڒحْيُوضْ أَذْ وْضَانْ. \f ◼ \fr 38:‏20 \ft \bd ’ڒبْحَارْ‘\bd* - نِيغْ ’إِلْ‘.\f*
\v 21 نشّْ أَذْ د-ڒَْاغِيغْ خْ سِّيفْ ضِيدّْ نّسْ خْ مَارَّا إِذُورَارْ إِنُو، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي. سِّيفْ ن كُوڒْ إِجّْ أَذْ يِيڒِي خْ ؤُمَاسْ.
\v 22 نشّْ أَذْ خَاسْ حكْمغْ س طَّاعُونْ ؤُ س إِذَامّنْ ؤُشَا أَذْ خَاسْ ڭّغْ ؤُ خْ ڒْعسْكَارْ نّسْ ؤُ خْ وَاطَّاسْ ن ڒڭْنُوسْ نِّي كِيذسْ إِ غَا يِيڒِينْ، أَنْژَارْ إِجهْذنْ ذ إِبْقُوقنْ إِمقّْرَاننْ ن ثبْرُورِي ذ ثْمسِّي ذ ڒشْبَارِييّثْ. \x ◘ \xo 38:‏22 \xt أَسَا. 16‏:‏20.\x*
\v 23 نشّْ أَذْ سّشْنغْ إِخفْ إِنُو ذ أَمقّْرَانْ ذ أَمْقدَّاسْ ؤُ أَذْ تّْوَاسّْنغْ زَّاثْ إِ ثِيطَّاوِينْ ن ڒڭْنُوسْ. نِيثْنِي أَذْ سّْننْ بلِّي نشّْ ذ سِيذِي.‘ “
\b
\b
\c 39
\s1 ثَاغَارْصْثْ ثَامقّْرَانْثْ خْ إِذُورَارْ ن إِسْرَائِيل
\m 
\v 1 ”\add خنِّي\add* ڒخُّو، \add أَ\add* مِّيسْ ن بْنَاذمْ، نَابّْ ضِيدّْ إِ \add هَا\add*جُوجْ ؤُشَا إِنِي: ’أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: خْزَارْ، أَقَا أَيِي خَاكْ، \add أَ، شكْ\add* \add هَا\add*جُوجْ، ڒْحَاكمْ ن رُوشْ، مَاشِيكْ ذ ثُوبَالْ. \f ◼ \fr 39:‏1 \ft \bd ’هَاجُوجْ‘\bd* - نِيغْ ’جُوجْ‘، نِيغْ ’خُوخْ‘، نِيغْ ’ڭُوڭْ‘.\f*
\v 2 نشّْ أَذْ شكْ سّْعقْبغْ ؤُ أَذْ ذَايكْ ڭّغْ ثِيسنَّارِينْ ؤُ أَذْ شكْ سّْڭعّْذغْ زِي طّْرُوفَا ن شَّامَالْ ؤُشَا أَذْ شكْ ڭوّْذغْ خْ إِذُورَارْ ن إِسْرَائِيل. \x ◘ \xo 39:‏2 \xt حِز. 29‏:‏4؛ 38‏:‏4\x*
\v 3 أَذْ وْثغْ ڒْقوْسْ زڭْ ؤُفُوسْ نّشْ أَزڒْمَاضْ ؤُشَا أَذْغضْڒغْ فْڒِيثْشَاثْ نّشْ زڭْ ؤُفُوسْ نّشْ أَفُوسِي.
\v 4 أَذْ ثوْضِيذْ خْ إِذُورَارْ ن إِسْرَائِيل، شكْ ذ مَارَّا ڒْعسْكَارْ نّشْ ذ ڒڭْنُوسْ نِّي \add إِدْجَانْ\add* أَكِيذكْ. نشّْ وْشِيغْ شكْ ذ مَاشَّا إِ عْڒَامْ كُوڒْ إِجْضَاضْ إِتّْكشَّاضنْ ؤُ إِ ڒْمَاڒْ نْ ڒخْڒَا. \x ◘ \xo 39:‏4 \xt حِز. 33‏:‏27\x*
\v 5 خْ وُوذمْ ن ييَّارْ أَذْ ثوْضِيذْ، مِينْزِي نشّْ نِّيغْ ث، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي.
\v 6 نشّْ أَذْ سّكّغْ ثِيمسِّي خْ مَاجُوجْ ؤُ خْ إِنِّي إِزدّْغنْ س ڒحْنَا ذِي ثڭْزِيرِينْ ؤُ نِيثْنِي أَذْ سّْننْ بلِّي نشّْ ذ سِيذِي. \f ◼ \fr 39:‏6 \ft \bd ’مَاجُوجْ‘\bd* - نِيغْ ’مَاخُوخْ‘، نِيغْ ’مَاڭُوڭْ‘.\f*
\v 7 نشّْ أَذْ سّْبَانغْ إِسمْ إِنُو إِقدّْسنْ ذِي ڒْوسْثْ ن ڒْڭنْسْ إِسْرَائِيل ؤُ نشّْ وَارْ تّجِّيغْ عَاذْ أَذْ سّْخمْجنْ إِسمْ إِنُو إِقدّْسنْ. ڒڭْنُوسْ أَذْ سّْننْ بلِّي نشّْ ذ سِيذِي، أَمْقدَّاسْ ذِي إِسْرَائِيل.
\v 8 خْزَارْ، أَذْ د-يَاسْ ؤُ أَذْ إِمْسَارْ!، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي. وَا ذ أَسّْ نِّي خْ سِّيوْڒغْ.‘ “
\m 
\v 9 ”إِمزْذَاغْ ن ثْندَّامْ ن إِسْرَائِيل أَذْ فّْغنْ ؤُشَا أَذْ سَّارْغنْ ثِيمسِّي أَذْ سّْشمْضنْ \add مَارَّا\add* ڒسْنَاحْ: أَمْ ثْسدَّارِييِينْ ثِيمژْيَانِينْ أَمْ ثْسدَّارِييِينْ ثِيمقّْرَانِينْ ؤُڒَا ذ ڒْقوْسْ ذ فْڒِيثْشَاثْ ذ إِعُومَاذْ إِ يِيفَاسّنْ ذ إِحْرِيشنْ. \bd سبْعَا ن إِسڭّْوُوسَا\bd* أَذْ زَّايْسنْ سَّارْغنْ ثِيمسِّي.
\v 10 وَارْ د-تِّيوْينْ أَكشُّوضْ زڭْ إِيَّارْ ؤُ وَارْ تّْقسِّينْ ثَافْڒَاوْثْ زڭْ إِزغْرَانْ، \add مِينْزِي\add* سَّارْغنْ ثِيمسِّي س ڒسْنَاهْ ؤُشَا أَذْ كشّْضنْ إِنِّي ثنْ إِكشّْضنْ ؤُشَا أَذْ أَشَارنْ إِ يِينِّي ذ أَسنْ يُوشَارنْ!‘، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي.“\f ◼ \fr 39:‏10 \ft \bd ’أَزْغَارْ‘\bd* - نِيغْ ’ڒْغَابثْ‘ نِيغْ ’ثَازْڭَانْثْ‘.\f*
\m 
\v 11 \bd ”ذڭْ وَاسّْ نِّي\bd* أَذْ إِمْسَارْ، أَقَا نشّْ أَذْ سّْوجْذغْ ذِينْ أَمْشَانْ إِ \add هَا\add*جُوجْ إِجّْ ن ونْضڒْ ذِي إِسْرَائِيل، ڒوْضَا ن يِينِّي إِژكّْوَانْ، غَارْ شَّارْقْ ن ڒبْحَارْ، ؤُ ثَانِيثَا أَذْ ثْبلّعْ \add أَبْرِيذْ\add* إِ يِينِّي \add إِخْسنْ\add* أَذْ ژكّْوَانْ. ذِينْ إِ غَا نضْڒنْ \add هَا\add*جُوجْ ذ مَارَّا ڒْغَاشِي نّسْ إِنْهوْڒنْ ؤُ أَذْ خَاسْ ڒَاغَانْ: ڒوْضَا ن ڒْغَاشِي إِنْهوْڒنْ ن \add هَا\add*جُوجْ. \f ◼ \fr 39:‏11 \ft \bd ’هَاجُوجْ‘\bd* - نِيغْ ’جُوجْ‘، نِيغْ ’خُوخْ‘، نِيغْ ’ڭُوڭْ‘.\f*
\v 12 ثَادَّارْثْ ن إِسْرَائِيل أَذْ ثنْ ثنْضڒْ، مَاحنْذْ أَذْ سِّيزْذڭنْ ثمُّورْثْ، \add ڒْْمِيجَاڒْ ن\add* سبْعَا ن إِيُورنْ.
\v 13 مَارَّا ڒْڭنْسْ ن ثمُّورْثْ أَذْ \add ثنْ\add* نضْڒنْ ؤُشَا أَيَا أَذْ أَسنْ يِيڒِي إِ شَّانْ، ذڭْ وَاسّْ إِ ذِي غَا تّْوَاسّْعُودْجغْ!‘، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي.\f ◼ \fr 39:‏13 \ft \bd ’أَيَا أَذْ أَسنْ يِيڒِي إِ شَّانْ‘\bd* - س ثْعِيبْرَانِيثْ ’ؤُشَا (أَيَا) أَذْ أَسنْ يِيڒِي إِ يِيسمْ‘.\f*
\v 14 ’أَذْ فَارْزنْ عَاوذْ إِرْيَازنْ مَاحنْذْ أَذْ ژْوَانْ نِيثْنِي ثَامُّورْثْ بْڒَا قطُّو مَاحنْذْ أَذْ نضْڒنْ إِنِّي خَاسْ إِكِّينْ، إِنِّي ثُوغَا إِقِّيمنْ بُوزّْڒنْ خْ وُوذمْ ن ثمُّورْثْ، حِيمَا أَذْ سِّيزذْڭنْ \add ثَامُّورْثْ\add*. أَوَارْنِي سبْعَا ن إِيُورنْ أَذْ قدْجْبنْ نِيثْنِي.
\v 15 إِنِّي إِ ذ أَسنْ إِتّْخصَّا أَذْ ژْوَانْ ثَامُّورْثْ أَذْ ت ژْوَانْ ؤُ خْمِي إِتّْوَاڒَا حذْ إِجّْ ن يِيغسْ ن بْنَاذمْ، أَذْ يڭّْ غَارسْ إِشْثْ ن ڒْمَارْكَا أَڒْ ث غَا نضْڒنْ إِنِّي إِنطَّاڒنْ ذِي ڒوْضَا ن ڒْغَاشِي إِنْهوْڒنْ ن \add هَا\add*جُوجْ.
\v 16 عَاوذْ \add أَذْ يِيڒِي\add* إِسمْ ن إِشْثْ ن ثنْذِينْثْ ’ڒْْغَاشِي إِنْهوْڒنْ‘. نِيثْنِي أَذْ سِيزذْڭنْ ثَامُّورْثْ.‘ “
\m 
\v 17 ”شكْ، \add أَ\add* مِّيسْ ن بْنَاذمْ، أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ’إِنِي إِ مَارَّا ڒْمَارْكَاثْ ن إِجْضَاضْ ؤُ إِ مَارَّا ڒْمَاڒْ ن ييَّارْ: مُونمْ-د \add ذَا\add*، أَسمْ-د، سدّمْ إِخفْ نْومْ زڭْ ونّضْ غَارْ ثْغَارْصْثْ إِنُو نِّي غَارْصغْ إِ كنِّيوْ، ثَاغَارْصْثْ ثَامقّْرَانْثْ خْ إِذُورَارْ ن إِسْرَائِيل، ؤُشَا أَذْ ثشّمْ أَيْسُومْ، أَذْ ثسْومْ إِذَامّنْ.
\v 18 أَذْ ثشّمْ أَيْسُومْ ن أَيْثْ ن بُو-ڒخْشُونثْ ؤُ أَذْ ثسْومْ إِذَامّنْ ن ڒْحُوكَّامْ ن دُّونشْثْ، ن إِشَارِّييّنْ ذ إِزْمَارنْ ذ إِغَايْضنْ ذ إِفُونَاسنْ إِمژْيَاننْ، أَقَا أَثنْ مَارَّا ذوْسنْ ذِي بَاسَانْ.
\v 19 أَذْ ثشّمْ ثَاذُونْثْ أَڒْ غَا ثجِّيوْنمْ ؤُشَا أَذْ ثسْومْ إِذَامّنْ أَڒْ غَا ثسْشَارمْ زِي ثْغَارْصْثْ إِنُو إِ غَارْصغْ إِ كنِّيوْ.
\v 20 كنِّيوْ أَذْ ثجِّيوْنمْ غَارْ طَّابْڒَا إِنُو س إِيْسَانْ ذ إِمْنَاينْ، س أَيْثْ ن بُو-ثغْرُوضْثْ ؤُ س مَارَّا إِعسْكَارِييّنْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي.
\v 21 أَذْ ڭّغْ أَعُودْجِي إِنُو جَارْ ڒڭْنُوسْ ؤُشَا مَارَّا ڒڭْنُوسْ أَذْ ژَترنْ ڒْحُوكْمْ إِنُو نِّي ڭِّيغْ، ؤُڒَا ذ أَفُوسْ نِّي جَارْ أَسنْ سَّارْسغْ.
\v 22 ثَادَّارْثْ ن إِسْرَائِيل أَذْ ثسّنْ، أَقَا نشّْ، سِيذِي، ذ أَربِّي نْسنْ، زڭْ وَاسّْ نِّي ؤُ زِي سَّا ثْسَاونْثْ.
\v 23 أَذْ سّْننْ ڒڭْنُوسْ أَقَا إِنِّي ن ثَادَّارْثْ ن إِسْرَائِيل تّْوَانذْهنْ ذِي لْمنْفَا زِي سِّيبّثْ ن ڒْمُوعْصِييّثْ نْسنْ، مِينْزِيغدَّارنْ أَيِي ؤُشَا نشّْ فَّارغْ خَاسنْ ؤُذمْ إِنُو ؤُشَا وْشِيغْ ثنْ ذڭْ ؤُفُوسْ ن إِغْرِيمنْ نْسنْ ؤُ \add خنِّي\add* وْضَانْ مَارَّا س سِّيفْ.
\v 24 نشّْ ڭِّيغْ أَسنْ أَمْ مَامّشْ ثَاخْمُوجِي نْسنْ ؤُ أَمْ مَامّشْ ڒْمُوعْصِييّثْ نْسنْ ؤُ نشّْ فَّارغْ زَّايْسنْ ؤُذمْ إِنُو.‘ “
\m 
\v 25 ”\bd س ؤُيَا\bd*، أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ’ڒخُّو أَذْ سّْعقْبغْ إِمحْبَاسْ ن يَاعْقُوبْ، أَذْ حِينّغْ خْ مَارَّا ثَادَّارْثْ ن إِسْرَائِيل. أَذْ ؤُسْمغْ ذِي طّْوعْ ن يِيسمْ إِنُو إِقدّْسنْ.
\v 26 نِيثْنِي أَذْ أَرْبُونْ ڒفْضِيحثْ نْسنْ ذ مَارَّا ڒْمُوعْصِييّثْ نْسنْ إِ زِي ذ أَيِي غْضَارنْ خْمِي نِيثْنِي عَاذْ زذْغنْ ذِي ڒَامَانْ ذِي ثمُّورْثْ نْسنْ ؤُ وَارْ إِدْجِي وِي ثنْ إِ غَا إِسِّيڭّْوذنْ.
\v 27 خْمِي ثنْ إِ غَا سّْعقْبغْ زِي ڒڭْنُوسْ ؤُ أَذْ ثنْ سّْمُونغْ زِي ثمُّورَا ن ڒْعذْيَانْ نْسنْ ؤُ نشّْ أَذْ تّْوَاقدّْسغْ زَّايْسنْ زَّاثْ إِ ثِيطَّاوِينْ ن وَاطَّاسْ نْ ڒڭْنُوسْ،
\v 28 \add خنِّي\add* أَذْ سّْننْ بلِّي نشّْ ذ سِيذِي، أَربِّي نْسنْ، مِينْزِي نشّْ نذْهغْ ثنْ ذ إِمحْبَاسْ جَارْ ڒڭْنُوسْ ؤُ نشّْ سّْمُونغْ ثنْ \add عَاوذْ\add* ذِي ثمُّورْثْ نْسنْ، وَارْ \add ذِينْ\add* جِّيغْ ؤُڒَا ذ إِجّنْ زَّايْسنْ.
\v 29 نشّْ وَارْ خَاسنْ تّفَّارغْ عَاذْ ؤُذمْ إِنُو، خْمِي أَقَا سّْفَارّْغغْ أَرُّوحْ إِنُو خْ ثَادَّارْثْ ن إِسْرَائِيل!‘، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي.“ \x ◘ \xo 39:‏29 \xt يُووِ. 3‏:‏1؛ ڒخ. 2‏:‏17\x*
\b
\b
\c 40
\s1 ثِيوُّورَا ذ ڒمْرَاحَاثْ ن زَّاوشْثْ ثَامقّْرَانْثْ ن جْذِيذْ
\m 
\v 1 \bd ذڭْ ؤُسڭّْوَاسْ وِيسّْ خمْسَا ؤُ-عِيشْرِينْ ن لْمنْفَا نّغْ، غَارْ ؤُمزْوَارْ ن ؤُسڭّْوَاسْ، ذڭْ \bdit وَاسّْ\bdit* وِيسّْعشْرَا ن ؤُيُورْ، ذڭْ ؤُسڭّْوَاسْ وِيسّْ أَرْبعْطَاشْ أَوَارْنِي مَا وْثِينْ ثَانْذِينْثْ، ذڭْ وَاسّْ نِّي \bdit نِّيثْ\bdit*\bd*، ثُوغَا أَفُوسْ ن سِيذِي خَافِي ؤُشَا إِنْذهْ أَيِي ذِينْ. \x ◘ \xo 40:‏1 \xt حِز. 33‏:‏21\x*
\v 2 ذِي إِوحَّانْ ن أَربِّي إِنْذهْ أَيِي غَارْ ثمُّورْثْ ن إِسْرَائِيل ؤُشَا إِسَّارْسْ أَيِي خْ \bd إِجّْ ن وذْرَارْ يُوعْڒَانْ مِيخفْ ثُوغَا شَا ن ڒبْنِي أَمْ يِيشْثْ ن ثنْذِينْثْ غَارْ ؤُغزْذِيسْ ن لْجَانُوبْ نّسْ\bd*. \x ◘ \xo 40:‏2 \xt حِز. 20‏:‏40؛ حِز. 43‏:‏12\x*
\v 3 يِيوْيِي أَيِي ذِينْ، ؤُ خْزَارْ، إِجّْ ن ورْيَازْ. صِّيفثْ نّسْ أَمْ صِّيفثْ ن نّْحَاسْ ؤُ ذڭْ ؤُفُوسْ نّسْ إِجّْ ن ؤُفِيڒُو ن ڒقْطنْ ذ إِجّْ ن ؤُغَانِيمْ ن ڒعْبَارْ. نتَّا ثُوغَا إِبدّْ غَارْ ثوَّارْثْ.
\v 4 إِسِّيوڒْ أَكِيذِي ورْيَازْ \add نِّي\add*: ”\add أَ\add* مِّيسْ ن بْنَاذمْ، خْزَارْ س ثِيطَّاوِينْ نّشْ، سڒْ س إِمزُّوغنْ نّشْ ؤُشَا سَارْسْ ؤُڒْ نّشْ إِ مَارَّا نِّي إِ ذ أَشْ غَا سّشْنغْ، مَاغَارْ ثتّْوَاسّْقبْذذْ غَارْ ذَا حِيمَا أَذْ أَشْ ث سّشْنغْ. مَارَّا مِينْ ثْوَاڒِيذْ، إِنِي ث إِ ثَادَّارْثْ ن إِسْرَائِيل!“
\b
\m 
\v 5 خْزَارْ، \bd غَارْ بَارَّا ن ثَادَّارْثْ ثُوغَا ذِينْ إِجّْ ن وغْبَارْ\bd* نِّي ثُوغَا إِ ذ أَسْ د-إِنّْضنْ كُوڒْشِي. ذڭْ ؤُفُوسْ ن ورْيَازْ ثُوغَا ذ إِجّْ ن ؤُغَانِيمْ ن ڒعْبَارْ ن ستَّا ن إِغَادْجنْ، \add كُوڒْ إِجّنْ زَّايْسنْ ذ\add* إِجّْ ن ؤُغِيڒْ ذ إِجّْ شْبَارْ ن ؤُفُوسْ. نتَّا إِعْبَارْ ثِيرُو ن ڒْحِيضْ نِّي، أَقَا-ث ذ إِجّْ ن ؤُغَانِيمْ، ؤُ ڒُوعْڒَا \add نّسْ\add* ؤُڒَا ذ إِجّْ ن ؤُغَانِيمْ. \f ◼ \fr 40:‏5 \ft \bd ’ثَادَّارْثْ‘\bd* - أَوَاڒْ-أَ إِخْسْ أَذْ يِينِي ’ثَادَّارْثْ ن أَربِّي‘ نِيغْ ’زَّاوشْثْ إِقدّْسنْ‘. \bd ’ثِيرُو ن ڒْحِيضْ‘\bd* - س ثْعِيبْرَانِيثْ ’ثِيرُو ن ڒبْنِي‘.\f*
\m 
\v 6 \add خنِّي\add* يُوسَا-د أَڒْ \bd \bdit ڒبْنِي ن\bdit* ثوَّارْثْ نِّي إِخزَّارنْ غَارْ شَّارْقْ\bd* ؤُشَا إِڭعّذْ خْ دّْرُوجْ نّسْ، ؤُشَا إِعْبَارْ ثَانبْذَاثْ ن ثوَّارْثْ، ثِيرُو نّسْ أَنشْثْ ن إِجّْ ن ؤُغَانِيمْ ؤُ ثِيرُو ن ثْنبْذَاثْ نّغْنِي ؤُڒَا ذ إِجّْ ن ؤُغَامِينْ.
\v 7 ثُوزڭَّارْثْ ن إِشْثْ ن ثخَّامْثْ \add ن ثوَّارْثْ\add* ذ إِجّْ ن ؤُغَانِيمْ ؤُ ثِيرُو نّسْ ؤُڒَا ذ إِجّْ ن ؤُغَانِيمْ. جَارْ ثخَّامِينْ \add ن ثوَّارْثْ\add* \add ثُوغَا ذِينْ\add* خمْسَا ن إِغَادْجنْ ؤُ ثَانبْذَاثْ \add ن ڒبْنِي\add* ن ثوَّارْثْ غَارْ ؤُغزْذِيسْ ن وسْقِيفْ ن \add ڒبْنِي ن\add* ثوَّارْثْ غَارْ ؤُغزْذِيسْ ن ثَادَّارْثْ، \add أَقَا-ت\add* ذ إِجّْ ن ؤُغَانِيمْ.
\v 8 نتَّا إِعْبَارْ أَسْقِيفْ \add ن ڒبْنِي\add* ن ثوَّارْثْ غَارْ ذَاخڒْ، أَقَا-ث ذ إِجّْ ن ؤُغَانِيمْ.
\v 9 إِعْبَارْ أَسْقِيفْ ن ڒبْنِي ن ثوَّارْثْ، أَقَا-ث ذِي ثْمنْيَا ن إِغَادْجنْ، ؤُشَا ڒضْرُوفْ ن ڒْحِيضْ نّسْ \add ثُوغَا أَثنْ\add* ذِي ثْنَاينْ ن إِغَادْجنْ. أَسْقِيفْ ن \add ن ڒبْنِي\add* ن ثوَّارْثْ ثُوغَا غَارْ ؤُغزْذِيسْ ن ثَادَّارْثْ.
\v 10 زِي جِّيهثْ ن ثخَّامِينْ ن ثوَّارْثْ غَارْ ؤُغزْذِيسْ ن شَّارْقْ \add ن ڒبْنِي ن ثوَّارْثْ\add*، أَقَا ذِينْ ثْڒَاثَا \add زَّايْسنْثْ\add* غَارْ ؤُغزْذِيسْ-أَ ؤُ ثْڒَاثَا \add زَّايْسنْثْ\add* غَارْ ؤُغزْذِيسْ نّغْنِي. أَقَا أَثنْثْ غَارْسنْثْ ذ إِجّْ ن ڒعْبَارْ. ڒضْرُوفْ نْ ڒْحِيذْ \add غَارْسنْ\add* ذ ڒعْبَارْ ذ إِجّنْ غَارْ ؤُغزْذِيسْ-أَ ؤُ غَارْ ؤُغزْذِيسْ نّغْنِي.
\v 11 إِعْبَارْ ثِيرُو ن وَاذَافْ \add ن ڒبْنِي\add* ن ثوَّارْثْ، أَقَا-ث ذِيعشْرَا ن إِغَادْجنْ، ؤُڒَا ذ ثُوزّڭَّارْثْ \add ن ڒبْنِي\add* ن ثوَّارْثْ، أَقَا-ت ذِي ثْڒطَّاشْ ن إِغَادْجنْ.
\v 12 تَّاسِيعْ زَّاثْ إِ ثخَّامِينْ ن ثوَّارْثْ \add ثُوغَا\add* إِجّْ ن ؤُغِيڒْ \add غَارْ ؤُغزْذِيسْ-أَ\add* ؤُشَا غَارْ ؤُغزْذِيسْ نّغْنِي \add ثُوغَا\add* تَّاسِيعْ ؤُڒَا ذ إِجّْ ن ؤُغِيڒْ. إِشْثْ ن ثخَّامْثْ غَارسْ ستَّا ن إِغَادْجنْ غَارْ إِجّْ ن ؤُغزْذِيسْ ذ ستَّا إِغَادْجنْ غَارْ إِجّْ ن ؤُغزْذِيسْ نّغْنِي.
\v 13 إِعْبَارْ \add عَاوذْ\add* \add ڒبْنِي ن\add* ثوَّارْثْ زِي ثْزقَّا ن إِشْثْ ن ثخَّامْثْ أَڒْ ثَازقَّا ن ونّغْنِي. ثِيرُو \add نّسْ ثُوغَا-ث\add* ذِي خمْسَا ؤُ-عِيشْرِينْ ن إِغَادْجنْ، أَذَافْ أَرنْذَاذْ ن وَاذَافْ \add نّغْنِي\add*.
\v 14 إِڭَّا \add ؤُڒَا ذ ڒعْبَارْ\add* غَارْ ڒضْرُوفْ ن ڒْحِيضْ: ستِّينْ ن إِغَادْجنْ، ؤُشَا ڒمْرَاحْ إِكَّا خْ طَّارْفْ ن ڒْحِيضْ، إِنّضْ أَسْ-د \add ڒمْرَاحْ\add* إِ \add ڒبْنِي ن\add* ثوَّارْثْ مَارَّا.
\v 15 زِي زَّاثْ ن ثوَّارْثْ ن وَاذَافْ أَڒْ زَّاثْ ن وسْقِيفْ ن ثوَّارْثْ ن ذَاخڒْ، \add أَقَا ذِينْ\add* خمْسِينْ ن إِغَادْجنْ.
\v 16 \add ثُوغَا\add* ڒكْوَازِي حْصَارنْ غَارْ ثخَّامِينْ ن ثوَّارْثْ ؤُ غَارْ ڒضْرُوفْ نْ ڒْحِيضْ غَارْ ؤُغزْذِيسْ ن ذَاخڒْ \add ن ڒبْنِي\add* ن ثوَّارْثْ ذڭْ ونّضْ، ؤُڒَا ذِي ڒحْيُوضْ نْ بَارَّا ؤُ ثُوغَا ڒكْوَازِي ذڭْ ونّضْ خزَّارنْ غَارْ ذَاخڒْ ؤُ خْ \add كُوڒْ إِجّْ زِي\add* ڒضْرُوفْ ن ڒْحِيضْ ثتَّافذْ ذِينْ ثِيشجُّورَا ن ثِينِي.
\m 
\v 17 إِنْذهْ أَيِي-د غَارْ ڒمْرَاحْ ن بَارَّا، ؤُشَا خْزَارْ، \add أَقَا ذِينْ\add* إِخَّامنْ ذ إِشْثْ ن ثِيسِي ن زّلِّيجْ إِتّْوَاڭّنْ ذڭْ ونّضْ ن ڒمْرَاحْ. \add ثُوغَا ذِينْ\add* ثْڒَاثِينْ ن إِخَّامنْ غَارْ ثِيسِي ن زّلِّيجْ \add نِّي\add*.
\v 18 ثِيسِي ن زّلِّيجْ \add ثُوغَا-ت\add* غَارْ ؤُغزْذِيسْ ن \add ڒبْنِييَّاثْ ن\add* ثوَّارْثْ، ثقّنْ نِيشَانْ إِ ثُوزّڭَّارْثْ ن \add ڒبْنِييَّاثْ ن\add* ثوَّارْثْ. ثَانِيثَا ثُوغَا-ت ذ ثِيسِي ن زّلِّيجْ إِ إِدْجَانْ وَادَّايْ.
\m 
\v 19 نتَّا إِعْبَارْ ثِيرُو زِي زَّاثْ \add ن ڒبْنِي\add* ن ثوَّارْثْ إِ إِدْجَانْ غَارْ وَادَّايْ \add ن ڒمْرَاحْ\add* أَڒْ ڒمْرَاحْ ن ذَاخڒْ غَارْ ؤُغزْذِيسْ نّسْ ن بَارَّا، مْيَا ن إِغَادْجنْ. \add أَمُّو إِ إِعْبَارْ\add* شَّارْقْ ذ شَّامَالْ \add نْ ڒمْرَاحْ\add*.
\m 
\v 20 زِي \add ڒبْنِي ن\add* ثوَّارْثْ نِّي إِخزَّارنْ غَارْ شَّامَالْ، غَارْ ڒمْرَاحْ ن بَارَّا، إِعْبَارْ ثُوزّڭَّارْثْ نّسْ ذ ثِيرُو نّسْ.
\v 21 ثُوغَا ثْڒَاثَا ن ثخَّامِينْ نّسْ غَارْ ؤُغزْذِيسْ-أَ ذ ثْڒَاثَا غَارْ ؤُغزْذِيسْ نّغْنِي، ذ ڒضْرُوفْ نّسْ ن ڒْحِيضْ ؤُڒَا ذ ڒحْيُوضْ نّسْ ن بَارَّا غَارْسنْ ذ ڒعْبَارْ ذ إِجّنْ أَمْ \add ڒبْنِي ن\add* ثوَّارْثْ ثَامزْوَارُوثْ. ثُوزُّوڭَّارْثْ ثُوغَا-ت خمْسِينْ ن إِغَادْجنْ ذ ثِيرُو نّسْ ثُوغَا-ت خمْسَا ؤُ-عِيشْرِينْ ن إِغَادْجنْ.
\v 22 ڒكْوَازِي نّسْ ذ ڒحْيُوضْ نّسْ ن بَارَّا ؤُڒَا ذ ثِيشجُّورَا نّسْ ن ثِينِي ثُوغَا غَارْسنْ ڒعْبَارْ ذ إِجّنْ أَمْ \add ڒبْنِي ن\add* ثوَّارْثْ نِّي إِخزَّارنْ غَارْ شَّارْقْ. تّْڭعَّاذنْ غَارسْ خْ \add إِجّْ ن دّْرُوجْ أَكْ-ذ\add* \bd سبْعَا ن ثْرفِّيذِينْ\bd* ؤُشَا ڒحْيُوضْ نّسْ ن بَارَّا ثُوغَا أَثنْ غَارْ ؤُغزْذِيسْ ن زَّاثْ.
\v 23 \add ڒبْنِي ن\add* ثوَّارْثْ ن ڒمْرَاحْ ن ذَاخڒْ ثُوغَا-ت زَّاثْ \add ن ڒبْنِي\add* ن ثوَّارْثْ ن شَّامَالْ ذ ثنِّي ن شَّارْقْ. زڭْ ڒبْنِي ن ثوَّارْثْ \add ن بَارَّا\add* أَڒْ ڒبْنِي ن ثوَّارْثْ \add ن ذَاخڒْ\add* إِعْبَارْ مْيَا ن إِغَادْجنْ.
\m 
\v 24 \add خنِّي\add* إِنْذهْ أَيِي غَارْ ؤُغزْذِيسْ ن لْجَانُوبْ، ؤُ خْزَارْ، ثُوغَا ذِينْ إِجّْ ن \add ڒبْنِي ن\add* ثوَّارْثْ نِّي إِخزَّارنْ غَارْ لْجَانُوبْ. إِعْبَارْ ڒضْرُوفْ ن ڒْحِيضْ ذ ڒحْيُوضْ نّسْ ن بَارَّا \add ؤُشَا\add* ڒعْبُورَاثْ نْسنْ ثُوغَا أَثنْ ذ إِجّْ.
\v 25 \add ڒبْنِي ن\add* ثوَّارْثْ غَارسْ ڒكْوَازِي ؤُشَا ؤُڒَا ذ ڒحْيُوضْ نْ بَارَّا ذَايْسنْ ڒكْوَازِي أَمْ ونّغْنِي. ثُوزُّوڭَّارْثْ \add نّسْ\add* ثُوغَا-ت ذِي خمْسِينْ ن إِغَادْجنْ ؤُ ثِيرُو \add نّسْ\add* ذِي خمْسَا ؤُ-عِيشْرِينْ ن إِغَادْجنْ.
\v 26 ذْرُوجّْ ذَايسْ سبْعَا ن ثْرفِّيذِينْ ؤُ ڒحْيُوضْ نّسْ ن بَارَّا \add ثُوغَا أَثنْ\add* غَارْ زَّاثْ. ثُوغَا غَارسْ ثِيشجُّورَا ن ثِينِّي خْ ڒضْرُوفْ ن ڒْحِيضْ، إِشْثنْ غَارْ إِجّْ ن ؤُغزْذِيسْ ؤُ إِشْثنْ غَارْ ؤُغزْذِيسْ \add نّغْنِي\add*.
\v 27 \add ثُوغَا ذِينْ عَاوذْ\add* إِشْثْ ن \add ڒبْنِي ن\add* ثوَّارْثْ غَارْ ڒمْرَاحْ ن ذَاخڒْ نِّي إِخزَّارنْ غَارْ لْجَانُوبْ. إِعْبَارْ زڭْ إِشْثْ ن \add ڒبْنِي ن\add* ثوَّارْثْ أَڒْ \add ڒبْنِي ن\add* ثوَّارْثْ \add نّغْنِي\add* غَارْ ؤُغزْذِيسْ ن لْجَانُوبْ: مْيَا ن إِغَادْجنْ.
\v 28 \add خنِّي\add* يِيوِي أَيِي غَارْ \add ڒبْنِي ن\add* ثوَّارْثْ ن لْجَانُوبْ غَارْ ڒمْرَاحْ ن ذَاخڒْ. إِعْبَارْ \add ڒبْنِي ن\add* ثوَّارْثْ ن لْجَانُوبْ، \add ثُوغَا\add* ڒعْبُورَاثْ نّسْ ذ إِجّنْ.
\v 29 إِخَّامنْ نّسْ ذ ڒضْرُوفْ نّسْ ن ڒْحِيضْ ؤُڒَا ذ ڒحْيُوضْ نّسْ ن بَارَّا \add غَارْسنْ\add* ذ ڒعْبُورَاثْ ذ إِجّنْ. \add ڒبْنِي ن ثوَّارْثْ\add* ثُوغَا غَارسْ ڒكْوَازِي ؤُشَا ؤُڒَا ذ ڒحْيُوضْ نّسْ ن بَارَّا غَارْسنْ \add ڒكْوَازِي ذ إِجّنْ أَمْ ثِينِّي\add*. ثُوزُّوڭَّارْثْ \add نّسْ\add* \add ثُوغَا-ت\add* ذِي خمْسِينْ ن إِغَادْجنْ ؤُ ثِيرُو \add نّسْ\add* ذِي خمْسَا ؤُ-عِيشْرِينْ ن إِغَادْجنْ.
\v 30 نّْضنْ أَسْ-د ڒحْيُوضْ ن بَارَّا. ثُوزُّوڭَّارْثْ \add نّسْ\add* ثُوغَا-ث ذِي خمْسَا ؤُ-عِيشْرِينْ ن إِغَادْجنْ ؤُ ثِيرُو \add نّسْ\add* ذِي خمْسَا ن إِغَادْجنْ.
\v 31 ثُوغَا ڒحْيُوضْ نّسْ ن بَارَّا غَارْ ڒمْرَاحْ ن بَارَّا. \add ثُوغَا ذِينْ\add* ثِيشجُّورَا ن ثِينِي خْ ڒضْرُوفْ ن ڒْحِيضْ ؤُ دّْرُوجْ نّسْ ذَايسْ ثْمنْيَا ن ثْرفِّيذِينْ.
\m 
\v 32 \add خنِّي\add* يِيوِي أَيِي غَارْ ڒمْرَاحْ ن ذَاخڒْ، غَارْ ؤُغزْذِيسْ ن شَّارْقْ. إِعْبَارْ \add ڒبْنِي ن\add* ثوَّارْثْ ن لْجَانُوبْ، \add ثُوغَا\add* ڒعْبُورَاثْ نّسْ ذ إِجّنْ.
\v 33 ثِيخَّامِينْ نّسْ ذ ڒضْرُوفْ نّسْ نْ ڒْحِيضْ ؤُڒَا ذ ڒحْيُوضْ نّسْ ن بَارَّا \add غَارْسنْ\add* ذ ڒعْبُورَاثْ ذ إِجّنْ. \add ڒبْنِي ن ثوَّارْثْ\add* ثُوغَا غَارسْ ڒكْوَازِي ؤُشَا ؤُڒَا غَارْ ڒحْيُوضْ نّسْ ن بَارَّا إِ د أَسنْ إِنّْضنْ مَارَّا. ثُوزُّوڭَّارْثْ \add نّسْ\add* \add ثُوغَا-ت\add* ذِي خمْسِينْ ن إِغَادْجنْ ؤُ ثِيرُو \add نّسْ\add* ذِي خمْسَا ؤُ-عِيشْرِينْ ن إِغَادْجنْ.
\v 34 ڒحْيُوضْ نّسْ ن بَارَّا \add ثُوغَا أَثنْ\add* غَارْ ڒمْرَاحْ ن بَارَّا. \add ثُوغَا ذِينْ\add* ثِيشجُّورَا ن ثِينِي خْ ڒضْرُوفْ ن ڒْحِيضْ نّسْ، \add أَمْ\add* غَارْ ؤُغزْذِيسْ\add -أَ\add* \add ؤُڒَا\add* غَارْ ؤُغزْذِيسْ \add نّغْنِي\add*، ؤُ دّْرُوجْ نّسْ ذَايسْ ثْمنْيَا ن ثْرفِّيذِينْ.
\m 
\v 35 \add خنِّي\add* يِيوِي أَيِي غَارْ \add ڒبْنِي ن\add* ثوَّارْثْ ن شَّامَالْ ؤُشَا إِعْبَارْ \add خنِّي\add* ڒعْبُورَاثْ ذ إِجّنْ.
\v 36 ثِيخَّامِينْ نّسْ ن ثوَّارْثْ ذ ڒضْرُوفْ نّسْ نْ ڒْحِيذْ ذ ڒحْيُوضْ نّسْ ن بَارَّا غَارْسنْ ڒكْوَازِي ذڭْ ونّضْ نْسنْ. ثُوزُّوڭَّارْثْ \add نّسْ\add* \add ثُوغَا\add* ذِي خمْسِينْ ن إِغَادْجنْ ؤُشَا ثِيرُو \add نّسْ\add* ذِي خمْسَا ؤُ-عِيشْرِينْ ن إِغَادْجنْ.
\v 37 ڒضْرُوفْ نّسْ ن ڒْحِيضْ \add ثُوغَا أَثنْ\add* غَارْ ڒمْرَاحْ ن بَارَّا. \add ثُوغَا ذِينْ\add* ثِيشجُّورَا ن ثِينِي غَارْ ؤُغزْذِيسْ\add -أَ\add* ؤُ غَارْ ؤُغزْذِيسْ \add نّغْنِي\add* خْ ڒضْرُوفْ نّسْ. دّْرُوجْ نّسْ \add ذَايسْ\add* ثْمنْيَا ن ثْرفِّيذِينْ.
\m 
\v 38 \add ثُوغَا ذِينْ\add* إِجّْ ن وخَّامْ س إِشْثْ ن ثوَّارْثْ غَارْ ڒضْرُوفْ نْ ڒحْيُوضْ ن \add ڒبْنِييَّاثْ\add* ن ثوَّارْثْ، أَذْ ذِينْ سِّيرْذنْ ثَاغَارْصْثْ ن وشْمَاضْ.
\v 39 ذِي ذَاخڒْ ن وسْقِيفْ \add ن ڒبْنِي\add* ن ثوَّارْثْ ثُوغَا ذِينْ ثْنَاينْ ن طَّابْڒَاثْ غَارْ ؤُغزْذِيسْ\add -أَ\add* ؤُ ثْنَاينْ ن طَّابْڒَاثْ غَارْ ؤُغزْذِيسْ \add نّغْنِي\add* حِيمَا أَذْ خَاسنْثْ غَارْصنْ ثَاغَارْصْثْ ن وشْمَاضْ ذ ثْغَارْصْثْ ن دّنْبْ ذ ثْغَارْصْثْ ن ؤُمَارْوَاسْ.
\v 40 بَارَّا غَارْ إِجّْ ن ؤُغزْذِيسْ ن زَّاثْ غَارْ مَانِي ڭعّْذنْ غَارْ وَاذَافْ \add ن ڒبْنِي\add* ن ثوَّارْثْ ن شَّامَالْ \add ثُوغَا ذِينْ\add* ثْنَاينْ ن طَّابْڒَاثْ، ؤُ غَارْ ؤُغزْذِيسْ ن زَّاثْ نّغْنِي غَارْ وسْقِيفْ \add ن ڒبْنِي\add* ن ثوَّارْثْ \add ثُوغَا ذِينْ\add* عَاوذْ ثْنَاينْ ن طَّابْڒَاثْ.
\v 41 \add أَمُّو ثُوغَا ذِينْ\add* أَربْعَا ن طَّابْڒَاثْ غَارْ \add إِجّْ ن\add* ؤُغزْذِيسْ ؤُ أَربْعَا ن طَّابْڒَاثْ غَارْ ؤُغزْذِيسْ \add نّغْنِي\add* غَارْ إِغزْذِيسْ\add أنْ\add* \add ن ڒبْنِي\add* ن ثوَّارْثْ، أَقَا ذِينْ ثْمنْيَا ن طَّابْڒَاثْ إِ مِينْ خفْ زمَّارنْ أَذْ غَارْصنْ.
\v 42 \add ثُوغَا ذِينْ\add* أَربْعَا ن طَّابْڒَاثْ زِي ثْصُوضَارْ إِتّْوَانقْشنْ غَارْ دّْرُوجْ \add ن ڒبْنِي ن ثوَّارْثْ\add*. ثُوزُّوڭَّارْثْ \add ن طَّابْڒَا\add* \add ثُوغَا-ت\add* ذ إِجّْ ن ؤُغِيڒْ ذ وزْينْ ؤُ ثِيرُو \add نّسْ\add* ذ إِجّْ ن ؤُغِيڒْ ذ وزْينْ ؤُ ڒُوعْڒَا \add نّسْ\add* ذ إِجّْ ن ؤُغِيڒْ. مَّارْسنْ خَاسْ ڒقْشُوعْ إِ زِي غَارّْصنْ ثَاغَارْصْثْ ن وشْمَاضْ ذ ثوْهِيبْثْ ن ثْغَارْصْثْ.
\v 43 ثَارْيِيوِينْ ن إِجّْ ن شْبَارْ ن ؤُفُوسْ تّْوَاڭّنْثْ ذڭْ ونّضْ غَارْ ذَاخڒْ \add ن وسْقِيفْ نْ ڒبْنِي ن ثوَّارْثْ\add*، ؤُ \add ثُوغَا إِتّْخصَّا أَذْ مَّارْسنْ\add* أَيْسُومْ إِ ثوْهِيبْثْ ن ثْغَارْصْثْ خْ طَّابْڒَاثْ \add إِ ذِينْ إِدْجَانْ\add*.
\m 
\v 44 غَارْ بَارَّا \add ن ڒبْنِي\add* ن ثوَّارْثْ ن ذَاخڒْ \add ثُوغَا ذِينْ\add* ثِيخَّامِينْ ن إِمغْنَاجنْ ذِي ڒمْرَاحْ ن ذَاخڒْ نِّي \add إِدْجَانْ\add* غَارْ ؤُغزْذِيسْ ن زَّاثْ \add ن ڒبْنِي\add* ن ثوَّارْثْ ن شَّامَالْ. ؤُذمْ نّسْ غَارْ زَّاثْ ثُوغَا إِخزَّارْ غَارْ لْجَانُوبْ. ثَاوَّارْثْ نِّي غَارْ ؤُغزْذِيسْ \add ن ڒبْنِي\add* ن ثوَّارْثْ ن شَّارْقْ \add ثُوغَا\add* ثْخزَّارْ غَارْ شَّامَالْ.
\v 45 نتَّا إِسِّيوڒْ أَكِيذِي: ”ثَاخَّامْثْ-أَ نِّي زِي إِخزَّارْ وُوذمْ نّسْ غَارْ لْجَانُوبْ، أَقَا-ت إِ إِكهَّاننْ نِّي إِحطَّانْ خْ ثْسخَّارْثْ ن ثَادَّارْثْ.
\v 46 ثَاخَّامْثْ نِّي ثْخزَّارْ وُوذمْ نّسْ غَارْ شَّامَالْ، أَقَا-ت إِ إِكهَّاننْ نِّي إِحطَّانْ خْ ثْسخَّارْثْ ن ؤُعَالْطَارْ. نِيثْنِي ذ أَيْثْ نْ صَاذُوقْ نِّي غَا د-إِقَارّْبنْ غَارْ سِيذِي زڭْ أَيْثْ ن لَاوِي، مَاحنْذْ أَذْ أَسْ سخَّارنْ.“
\v 47 إِعْبَارْ ڒمْرَاحْ: ثُوزّڭَّارْثْ \add نّسْ\add* مْيَا ن إِغَادْجنْ ؤُ ثِيرُو نّسْ مْيَا ن إِغَادْجنْ، إِجّْ ن ؤُكْوَاذْرُونْ. أَعَالْثَارْ ثُوغَا-ث زَّاثْ ن ثَادَّارْثْ.
\b
\m 
\v 48 \add خنِّي\add* يِيوِي أَيِي غَارْ \bd وسْقِيفْ ن ثَادَّارْثْ\bd* ؤُشَا إِعْبَارْ ڒضْرُوفْ ن ڒْحِيضْ ن وسْقِيفْ، خمْسَا ن إِغَادْجنْ غَارْ \add إِجّْ ن\add* ؤُغزْذِيسْ ؤُ خمْسَا ن إِغَادْجنْ غَارْ ؤُغزْذِيسْ \add نّغْنِي\add*، ؤُڒَا ذ ثِيرُو ن ثوَّارْثْ، ثْڒَاثَا ن إِغَادْجنْ غَارْ \add إِجّْ ن\add* ؤُغزْذِيسْ ؤُ ثْڒَاثَا ن إِغَادْجنْ غَارْ ؤُغزْذِيسْ \add نّغْنِي\add*.
\v 49 ثُوزُّوڭَّارْثْ ن وسْقِيفْ ثُوغَا-ت عِيشْرِينْ ن إِغَادْجنْ ؤُ ثِيرُو نّسْ حِيطَاشْ ن إِغَادْجنْ، ذ مَانْ أَيَا غَارْ \add ؤُغزْذِيسْ ن\add* ثْرفِّيذِينْ \add ن دّْرُوجْ\add* إِ زِي زمَّارنْ أَذْ ڭعّْذنْ. \add ثُوغَا ذِينْ\add* عَاوذْ إِپِيلَارنْ غَارْ ڒضْرُوفْ ن ڒْحِيضْ، إِجّْ غَارْ ؤُغزْذِيسْ\add -أَ\add* ؤُ إِجّْ غَارْ ؤُغزْذِيسْ \add نّغْنِي\add*. *
\b
\b
\c 41
\s1 ثَادَّارْثْ ن زَّاوشْثْ ثَامقّْرَانْثْ ن جْذِيذْ
\m 
\v 1 نتَّا يِيوِي أَيِي غَارْ \add وخَّامْ\add* ن زَّاوشْثْ ثَامقّْرَانْثْ ؤُشَا إِعْبَارْ ڒضْرُوفْ ن ڒْحِيضْ. ثُوغَا-ثنْ ستَّا ن إِغَادْجنْ غَارْ ؤُغزْذِيسْ\add -أَ\add* ؤُ ستَّا ن إِغَادْجنْ غَارْ ؤُغزْذِيسْ \add نّغْنِي\add*، خْ ثِيرُو ن ؤُقِيضُونْ. *
\b
\m 
\v 2 ثِيرُو ن وَاذَافْ ثُوغَا-تعشْرَا ن إِغَادْجنْ ؤُشَا ؤُذْمَاونْ ن ڒحْيُوضْ غَارْ ؤُغزْذِيسْ ن وَاذَافْ \add ثُوغَا أَثنْ\add* خمْسَا ن إِغَادْجنْ غَارْ ؤُغزْذِيسْ\add -أَ\add* ؤُ خمْسَا ن إِغَادْجنْ غَارْ ؤُغزْذِيسْ \add نّغْنِي\add*. إِعْبَارْ ثُوزّڭَّارْثْ نّسْ: أَربْعِينْ ن إِغَادْجنْ، ؤُشَا ثِيرُو نّسْ: عِيشْرِينْ ن إِغَادْجنْ.
\v 3 يُوذفْ-د غَارْ ذَاخڒْ ؤُشَا إِعْبَارْ ڒْحِيضْ نِّي غَارْ طَّارْفْ ن وَاذَافْ \add ن وخَّامْ ن ذَاخڒْ\add*: ثْنَاينْ ن إِغَادْجنْ ؤُشَا ثوَّارْثْ \add ثُوغَا-ت\add* ستَّا ن إِغَادْجنْ ؤُشَا ثِيرُو ن وَاذَافْ سبْعَا ن إِغَادْجنْ.
\v 4 إِعْبَارْ ثُوزّڭَّارْثْ \add ن وخَّامْ ن ذَاخڒْ\add*: عِيشْرِينْ ن إِغَادْجنْ، ؤُشَا ثِيرُو \add نّسْ\add*: عِيشْرِينْ ن إِغَادْجنْ غَارْ زَّاثْ \add ن وخَّامْ\add* ن زَّاوشْثْ ثَامقّْرَانْثْ. \add خنِّي\add* إِنَّا أَيِي: ”وَا ذ أَقْذَاسْ خْ ؤُقدَّاسْ!“
\m 
\v 5 إِعْبَارْ ڒْحِيضْ ن ثَادَّارْثْ: ستَّا ن إِغَادْجنْ، ؤُشَا ثِيرُو ن كُوڒْ أَخَّامْ ن ؤُغزْذِيسْ \add ثُوغَا-ث\add* ذِي أَربْعَا ن إِغَادْجنْ ذڭْ ونّضْ ن ثَادَّارْثْ مَارَّا.
\v 6 ثِيخَّامِينْ ن ؤُغزْذِيسْ \add ثُوغَا أَثنْثْ\add* ثَاخَّامْثْ زَّاثْ إِ ثخَّامْثْ \add نّغْنِي\add*، ثْڒَاثَا \add ذِي ڒُوعْڒَا\add*، ؤُشَا \add أَمنِّي\add* ثْڒَاثِينْ ن ثْوَاڒَاوِينْ إِشْثْ ن ثخَّامْثْ. ؤُشَا \add ثِيخَّامِينْ نِّي\add* إِوْضنْثْ أَڒْ ڒْحِيضْ ن ثَادَّارْثْ نِّي \add ذِينْ إِدْجَانْ\add* إِ ثخَّامِينْ إِ ذ أَسْ د-إِنّْضنْ، مَاحنْذْ أَذْ إِقدّمْ أَسنّذْ \add إِ ثْحنْيَا ن ثخَّامِينْ\add*. وَارْ إِعدّڒْ أَذْ أَوْضنْثْ \add ثْحنْيَا\add* أَڒْ ذَاخڒْ ذِي ڒْحِيضْ ن ثَادَّارْثْ.
\v 7 غَارْ سنّجْ ذڭْ ونّضْ إِمَّارْنِي ذِي تَّاسِيعْ نِّي \add إِدْجَانْ\add* غَارْ إِخَّامنْ ن ؤُغزْذِيسْ خْ كُوڒْ طّبْقثْ مَاغَارْ خْ كُوڒْ طّبْقثْ ن ثَادَّارْثْ إِنّضْ-د إِجّْ ن ؤُكُولْوَارْ إِ ثَادَّارْثْ مَارَّا. خْ ؤُيَا ثذْوڒْ ثَادَّارْثْ ذَايسْ تَّاسِيعْ كْثَارْ سنّجْ ؤُ أَمُّو إِ إِزمَّارْ \add بْنَاذمْ\add* أَذْ د-إِڭعّذْ زڭْ وَادَّايْ غَارْ طّبْقثْ سنّجْ س طّبْقثْ ن ڒْوسْطْ.
\m 
\v 8 ژْرِيغْ \bd إِشْثْ ن ڒْڭعّْذثْ إِ ذ أَسْ د-إِنّْضنْ إِ ثَادَّارْثْ مَارَّا\bd*، أَقَا-ت ذ ذْسُوسَا ن إِخَّامنْ ن ؤُغزْذِيسْ: إِجّْ ن ؤُغَانِيمْ \add ن ڒعْبَارْ\add* إِكمّْڒنْ، ستَّا ن إِغَادْجنْ أَڒْ مَانِي إِوْضنْ \add غَارْ ثِيسِي\add*.
\v 9 ثِيرُو ن ڒْحِيضْ نِّي \add إِڭَّا\add* أَغزْذِيسْ ن بَارَّا ن ڒبْنِي أَكْ-ذ إِخَّامنْ ن ؤُغزْذِيسْ، \add ثُوغَا-ت\add* خمْسَا ن إِغَادْجنْ، ؤُشَا \add أَمُّو ؤُڒَا ذ\add* تَّاسِيعْ يَارزْمنْ إِ إِقِّيمنْ غَارْ ثَادَّارْثْ \add أَكْ-ذ\add* إِخَّامنْ ن ؤُغزْذِيسْ، \add تَّاسِيعْ\add* إِ د-يُوسِينْ-د أَكْ-ذ ثَادَّارْثْ.
\v 10 ؤُشَا \add مِينْ إِقِّيمنْ عَاذْ\add* أَقَا ذ إِجّْ ن تَّاسِيعْ جَارْ إِخَّامنْ \add ذِي ڒمْڒَاحْ غَارْ شَّامَالْ ذ يِينِّي غَارْ لْجَانُوبْ\add* ن عِيشْرِينْ ن إِغَادْجنْ، ذڭْ ونّضْ ن ثَادَّارْثْ، ذڭْ ونّضْ نّسْ مَارَّا.
\v 11 \add ثفّغْ\add* ثوَّارْثْ ن ڒبْنِي ن إِخَّامنْ ن ؤُغزْذِيسْ غَارْ تَّاسِيعْ يَارزْمنْ إِ إِقِّيمنْ، إِشْثْ ن ثوَّارْثْ \add ثفّغْ\add* غَارْ شَّامَالْ ؤُشَا ثَاوَّارْثْ نّغْنِي \add ثفّغْ\add* غَارْ لْجَانُوبْ. ثِيرُو ن تَّاسِيعْ إِقِّيمنْ \add ثُوغَا-ت\add* ذِي خمْسَا ن إِغَادْجنْ ذڭْ ونّضْ نّسْ مَارَّا.
\m 
\v 12 \bd ڒبْنِي غَارْ وُوذمْ ن ڒمْرَاحْ إِتّْوَاعزْڒنْ غَارْ ڒْغَارْبْ\bd* ثُوغَا غَارسْ إِشْثْ ن ثِيرُو ن سبْعِينْ ن إِغَادْجنْ ؤُشَا ڒْحِيضْ ن ڒبْنِي ثُوغَا-ث ذِي خمْسَا ن إِغَادْجنْ ذڭْ ونّضْ نّسْ مَارَّا، ؤُشَا ثُوزّڭَّارْثْ نّسْ \add ثُوغَا-ت\add* ذِي ثسْعِينْ ن إِغَادْجنْ.
\v 13 نتَّا إِعْبَارْ ثُوزّڭَّارْثْ ن ثَادَّارْثْ: مْيَا ن إِغَادْجنْ. ڒمْرَاحْ إِتّْوَاعزْڒنْ ذ ڒبْنِي \add إِ ذَايسْ إِدْجَانْ\add* أَكْ-ذ ڒحْيُوضْ نّسْ، أَقَا \add غَارْسنْ\add* ثُوزّڭَّارْثْ ذ إِشْثْ: مْيَا ن إِغَادْجنْ.
\v 14 \add أَمْ\add* ثِيرُو ن وُوذمْ ن ثَادَّارْثْ غَارْ ؤُغزْذِيسْ \add نّسْ ن ضفَّارْ\add* \add أَمْ\add* ڒمْرَاحْ إِتّْوَاعزْڒنْ غَارْ ؤُغزْذِيسْ نّسْ ن شَّارْقْ \add ثُوغَا\add* مْيَا ن إِغَادْجنْ.
\v 15 إِعْبَارْ \add ؤُڒَا ذ\add* ثُوزّڭَّارْثْ ن ڒبْنِي نِّي ثُوغَا غَارْ زَّاثْ ن ڒمْرَاحْ إِتّْوَاعزْڒنْ أَڒْ ضفَّارْ نّسْ. إِكُولْوَارنْ نّسْ غَارْ ؤُغزْذِيسْ\add -أَ\add* ؤُ غَارْ ؤُغزْذِيسْ \add نّغْنِي\add* ثُوغَا أَثنْ ذِي مْيَا ن ؤُغِيڒْ.
\m ذَاخڒْ ن زَّاوشْثْ ثَامقّْرَانْثْ، إِسْقِيفنْ غَارْ ڒمْرَاحْ ن زَّاثْ،
\v 16 ثِينبْذَاثِينْ ذ ڒكْوَازِي إِحْصَارنْ ذ ڒبْنِييَّاثْ س إِكُولْوَارنْ إِ ذ أَسْ د-إِنّْضنْ إِ ثْڒَاثَا \add ن ڒفْوَاقِي نْسنْثْ\add* زَّاثْ إِ ثْنبْذَاثِينْ \add ن ثوُّورَا\add*، \add مَارَّا\add* أَيَا ثُوغَا إِتّْوَاسّْذُورِي \add س ثڒْوِيحِينْ ن\add* ؤُكشُّوذْ، \add زِي\add* ثمُّورْثْ أَڒْ ڒكْوَازِي ؤُشَا ڒكْوَازِي \add سِيمَانْثْ نْسنْ\add* ثُوغَا تّْوَاسّْذُورْينْ.
\v 17 خْ \add وُوذمْ إِ إِدْجَانْ\add* سنّجْ إِ وَاذَافْ، \add أَمْ\add* خْ وُوذمْ ن ذَاخڒْ \add أَمْ\add* خْ وُوذمْ ن بَارَّا ن ثَادَّارْثْ ؤُ خْ مَارَّا ڒْحِيضْ غَارْ ذَاخڒْ ؤُ غَارْ بَارَّا \add ثُوغَا ذِينْ\add* ثِيڒْوِيحِينْ \add ن ؤُكشُّوضْ\add*.
\v 18 ثُوغَا تّْوَاڭّنْ خَاسنْ إِكِيرُوبنْ ذ ثْشجُّورَا ن ثِينِي. أَقَا ذِينْ إِشْثْ ن ثْشجَّارْثْ ن ثِينِي جَارْ إِجّْ ن ؤُكِيرُوبْ ذ إِجّْ ن ؤُكِيرُوبْ \add نّغْنِي\add* ؤُشَا كُوڒْ أَكِيرُوبْ غَارسْ ثْنَاينْ ن وُوذْمَاونْ: \f ◼ \fr 41:‏18 \ft \bd ’إِكِيرُوبنْ‘\bd* - إِشْثْ ن مَارْكَا ن لْمَالَاكَاثْ.\f*
\v 19 ؤُذمْ ن بْنَاذمْ نِّي إِخزَّارنْ غَارْ ثْشجَّارْثْ ن ثِينِي غَارْ إِجّْ ن ؤُغزْذِيسْ ذ وُوذمْ ن وَايْرَاذْ أَمژْيَانْ إِخزَّارنْ غَارْ ثْشجَّارْثْ ن ثِينِي غَارْ ؤُغزْذِيسْ \add نّغْنِي\add*. \add أَمُّو إِ\add* ثنْ ڭِّينْ ذڭْ ونّضْ ن مَارَّا ثَادَّارْثْ.
\v 20 زِي ثمُّورْثْ أَڒْ سنّجْ ن ثوَّارْثْ تّْوَاڭّنْ إِكِيرُوبنْ ذ ثْشجُّورَا ن ثِينِي ؤُشَا عَاوذْ خْ ڒْحِيضْ ن زَّاوشْثْ ثَامقّْرَانْثْ.
\v 21 ڒضْرُوفْ غَارْ ؤُغزْذِيسْ ن ثوَّارْثْ ن زَّاوشْثْ ثَامقّْرَانْثْ ڭِّينْ إِجّْ ن ؤُكْوَاذْرُونْ ؤُشَا شُّوفْ ن ؤُقدَّاسْ إِضْهَارْ-د أَمْ شُّوفْ \add ن زَّاوشْثْ\add*.
\m 
\v 22 \bd أَعَالْطَارْ\bd* ثُوغَا-ث ن ؤُكشُّوضْ ؤُ ڒُوعْڒَا نّسْ ثُوغَا-ث ثْڒَاثَا ن إِغَادْجنْ ؤُ ڒبْنِي سَاذُو نّسْ ثْنَاينْ ن إِغَادْجنْ ذِي ڒُوعْڒَا نّسْ. غَارسْ ثِيغمُّورَا ؤُشَا ڒبْنِي سَاذُو نّسْ ذ إِغزْذِيسنْ نّسْ \add ثُوغَا أَثنْ\add* زڭْ ؤُكشُّوضْ. نتَّا إِسِّيوڒْ أَكِيذِي: ”ثَا ذ ثَازوْضَا نِّي \add إِدْجَانْ\add* زَّاثْ إِ وُوذمْ ن سِيذِي.“
\v 23 زَّاوشْثْ ثَامقّْرَانْثْ ذ وقْذَاسْ غَارْسنْ ثْنَاينْ ن ثوُّورَا.
\v 24 ثُوغَا غَارْ ثِيوُّورَا، \add غَارْ كُوڒْ إِشْثنْ زَّايْسنْثْ،\add* ثْنَاينْ ن ثڒْوِيحِينْ أَمْ وَافْرِيونْ، ثْنَاينْ ن ثڒْوِيحِينْ نِّي زمَّارنْ أَذْ نُوقَّارنْ، ثْنَاينْ إِ يِيشْثْ ن ثوَّارْثْ ؤُ ثْنَاينْ إِ \add ثوَّارْثْ\add* نّغْنِي.
\v 25 ذِي ثوُّورَا ن زَّاوشْثْ ثَامقّْرَانْثْ تّْوَاڭّنْ إِكِيرُوبنْ ذ ثْشجُّورَا ن ثِينِي نِّي إِتّْوَاڭّنْ أَمْ يِينِّي خْ ڒحْيُوضْ. ثُوغَا ذِينْ ثَاسْقِيفْثْ ن ؤُكشُّوضْ غَارْ وُوذمْ ن وسْقِيفْ غَارْ بَارَّا.
\v 26 \add ثُوغَا ذِينْ\add* ڒكْوَازِي حْسَارنْ ذ ثْشجُّورَا ن ثِينِي غَارْ ؤُغزْذِيسْ\add -أَ\add* ؤُ غَارْ ؤُغزْذِيسْ \add نّغْنِي\add*، غَارْ ثْنَاينْ ن إِغزْذِيسنْ ن وسْقِيفْ، \add غَارْ\add* إِخَّامنْ إِ إِدْجَانْ غَارْ ؤُغزْذِيسْ ن ثَادَّارْثْ ؤُ غَارْ ثسْقِيفِينْ. *
\b
\b
\c 42
\s1 إِخَّامنْ ن إِكهَّاننْ
\m 
\v 1 نتَّا إِسُّوفّغْ أَيِي-د بَارَّا غَارْ ڒمْرَاحْ ن بَارَّا نِّي \add إِدْجَانْ\add* غَارْ شَّامَالْ. نتَّا إِنْذهْ أَيِي غَارْ \add ڒبْنِي ن\add* إِخَّامْ\add أنْ\add* نِّي إِدْجَانْ غَارْ ؤُغزْذِيسْ ن ڒمْرَاحْ إِتّْوَاعزْڒنْ ؤُ غَارْ ؤُغزْذِيسْ ن ڒبْنِي \add ن زَّاوشْثْ ثَامقّْرَانْثْ\add*، غَارْ ؤُغزْذِيسْ ن شَّامَالْ،
\v 2 غَارْ ؤُغزْذِيسْ \add نّسْ\add* ذ أَزِيرَارْ ن مْيَا ن إِغَادْجنْ، \add غَارْ\add* وَاذَافْ ن شَّامَالْ، \add مَاشَا\add* ثِيرُو \add نّسْ ثُوغَا\add* ذِي خمْسِينْ ن إِغَادْجنْ.
\v 3 ثُوغَا ڒبْنِي زَّاثْ إِ \add تَّاسِيعْ يَارزْمنْ ن\add* عِيشْرِينْ \add ن إِغَادْجنْ\add* ن ڒمْرَاحْ ن ذَاخڒْ ؤُ زَّاثْ إِ زّلِّيجْ ن ڒمْرَاحْ ن بَارَّا. إِجّْ ن ؤُكُولْوَارْ \add أَكْ-ذ إِخَّامنْ نّسْ\add* ثُوغَا \add إِسنّذْ\add* خْ ؤُكُولْوَارْ نّغْنِي، ؤُشَا أَقَا ذِينْ ثْڒَاثَا ن طّبْقَاثْ.
\m 
\v 4 زَّاثْ ن إِخَّامنْ \add ثُوغَا ذِينْ\add* إِجّْ ن ؤُكُولْوَارْ غَارْ ذَاخڒْ س إِشْثْ ن ثِيرُو نعشْرَا ن إِغَادْجنْ، إِشْثْ ن ثبْرِيذْثْ \add ن مْيَا\add* ن إِغَادْجنْ، ؤُشَا ثِيوُّورَا ن وَاذَافْ نْسنْ \add ثُوغَا أَثنْثْ\add* غَارْ شَّامَالْ.
\v 5 إِخَّامنْ ن سنّجْ \add ثُوغَا أَثنْ\add* حْصَارنْ، مَاغَارْ إِكُولْوَارنْ كّْسنْ \add كْثَارْ تَّاسِيعْ\add* زَّايْسنْ خْ \add يخَّامنْ ن\add* وَادَّايْ ؤُ \add خْ يخَّامنْ\add* غَارْ ڒْوسْثْ ن ڒبْنِي.
\v 6 مِينْزِي \add ثُوغَا أَثنْ\add* ذِي ثْڒَاثَا \add ن ڒفْوَاقِي\add*، مَاشَا وَارْ غَارْسنْ إِپِيلَارنْ أَمْ يِيپِيلَارنْ نْ ڒمْرَاحَاثْ. خْ ؤُيَا ثُوغَا أَثنْ إِخَامّنْ نِّي حْسَارنْ كْثَارْ خْ يِينِّي ن وَادَّايْ ذ يِينِّي ذِي ڒْوسْطْ \add أَمْ غَارْسنْ ثْخزَّارذْ\add* زِي ثمُّورْثْ.
\m 
\v 7 ڒْحِيضْ نِّي ثُوغَا غَارْ بَارَّا قِيبَاتْشْ إِ يخَّامنْ، \add ڒْحِيضْ\add* نِّي إِدْجَانْ غَارْ ؤُغزْذِيسْ ن ڒمْرَاحْ ن بَارَّا، إِ د-إِتّكّنْ زَّاثْ إِ يخَّامنْ، \add ثُوغَا غَارسْ\add* ثُوزّڭَّارْثْ ن خمْسِينْ ن إِغَادْجنْ.
\v 8 مِينْزِي ثُوزّڭَّارْثْ ن \add مَارَّا\add* إِخَّامنْ نِّي \add إِدْجَانْ\add* غَارْ ڒمْرَاحْ ن بَارَّا، ثُوغَا-ت ذِي خمْسِينْ ن إِغَادْجنْ. \add مَاشَا\add* خْزَارْ، غَارْ ؤُغزْذِيسْ ن زَّاوشْثْ ثَامقّْرَانْثْ ثُوغَا-ت ذِي مْيَا ن إِغَادْجنْ.
\v 9 سْوَادَّايْ ن إِخَّامنْ-أَ \add ثڭُّورْ\add* ثبْرِيذْثْ زِي شَّارْقْ خْمِي د غَارْسنْ ثِيوْضذْ زِي ڒمْرَاحْ ن بَارَّا.
\m 
\v 10 غَارْ ثِيرُو ن ڒْحِيضْ نْ ڒمْرَاحْ غَارْ شَّارْقْ، \add ڒْحِيضْ\add* زَّاثْ إِ ڒمْرَاحْ إِتّْوَاعزْڒنْ ؤُ غَارْ ؤُغزْذِيسْ ن ڒبْنِي، \add ثُوغَا ذِينْ عَاوذْ ڒبْنِييَّاثْ ن\add* إِخَّامنْ،
\v 11 ؤُشَا أَكُولْوَارْ إِ د-إِتّكّنْ زَّاثْسنْ \add ثُوغَا\add* أَمْ ثنِّي ن إِخَّامنْ نِّي \add إِدْجَانْ\add* غَارْ ؤُغزْذِيسْ ن شَّامَالْ، أَنشْثْ ثُوزّڭَّارْثْ أَنشْثْ ثِيرُو ؤُ مَارَّا ؤُفُّوغنْ نّسْ ثُوغَا أَثنْ أَمْ صّنْعَاثْ ذ وَاذَافنْ نّسْ \add غَارْ ؤُغزْذِيسْ ن إِخَامّنْ غَارْ شَّامَالْ\add*.
\v 12 أَمْ مَامّشْ \add ذِينْ\add* أَذَافنْ غَارْ ثخَّامِينْ ثِينِّي إِوجّْهنْ غَارْ لْجَانُوبْ، \add أَمنِّي إِ ذِينْ\add* إِدْجَا ؤُڒَا ذ إِجّْ ن وَاذَافْ غَارْ بدُّو ن ثبْرِيذْثْ، ثَابْرِيذْثْ نِّي إِتّفّْغنْ زِي زَّاثْ إِ ڒْحِيذْ ن ڒمْرَاحْ إِتّْوَاعزْڒنْ ؤُشَا ثتَّاكّْوَاضْ غَارْ وبْرِيذْ إِ خْ د غَا يَاسْ بْنَاذمْ زِي شَّارْقْ غَارْ ڒمْرَاحْ إِتّْوَاعزْڒنْ.
\m 
\v 13 \add خنِّي\add* إِنَّا أَيِي: ”إِخَّامنْ نِّي إِدْجَانْ غَارْ شَّامَالْ ؤُ إِخَّامنْ نِّي إِدْجَانْ غَارْ لْجَانُوبْ، إِنِّي إِدْجَانْ غَارْ زَّاثْ ن ڒمْرَاحْ إِتّْوَاعزْڒنْ، أَقَا أَثنْ ذ إِخَّامنْ إِقدّْسنْ مَانِي إِكهَّاننْ، إِنِّي إِ غَا د-إِقَارّْبنْ غَارْ سِيذِي، أَذْ شّنْ ثِيوْهِيبِينْ إِقدّْسنْ أَطَّاسْ. ذِينْ إِتّْخصَّا أَذْ سَارْسنْ نِيثْنِي ثِيوْهِيبِينْ إِقدّْسنْ أَطَّاسْ: ثَاوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* ذ ثوْهِيبْثْ ن دّنْبْ ذ ثوْهِيبْثْ ن ؤُمَارْوَاسْ، مِينْزِي أَمْشَانْ إِقدّسْ قَاعْ.
\v 14 خْمِي غَا ؤُذْفنْ إِكهَّاننْ، وَارْ إِعدّڒْ أَذْ ؤُيُورنْ زِي زَّاوشْثْ إِقدّْسنْ غَارْ ڒمْرَاحْ ن بَارَّا. أَذْ سَّارْسنْ أَرُّوضْ نْسنْ ن ثْسخَّارْثْ، مَاغَارْ وَانِيثَا ذ أَمْقدّسْ. أَذْ أَرْضنْ أَرُّوضْ نّغْنِي ؤُشَا \add خنِّي\add* أَذْ د-قَارّْبنْ غَارْ \add ڒمْرَاحْ\add* نِّي إِدْجَانْ إِ ڒْڭنْسْ.“ *
\b
\s1 زَّاوشْثْ ثَامقّْرَانْثْ ن جْذِيذْ - جِّيهثْ إِقدّْسنْ
\m 
\v 15 ؤُمِي إِكمّڒْ نتَّا ڒعْبَارْ ن مِينْ إِدْجَانْ ذَاخڒْ ن ثَادَّارْثْ، إِسُّوفُّوغْ أَيِي-د زڭْ وبْرِيذْ ن ثوَّارْثْ نِّي إِخزَّارنْ غَارْ شَّارْقْ ؤُشَا إِكْسِي ڒعْبَارْ ن جِّيهثْ إِقدّْسنْ ذڭْ ونّضْ مَارَّا.
\v 16 إِعْبَارْ أَغزْذِيسْ ن شَّارْقْ س ؤُغَانِيمْ ن ڒعْبَارْ: خمْسَا-مْيَا ن إِغُونَامْ س ؤُغَانِيمْ ن ڒعْبَارْ ذڭْ ونّضْ.
\v 17 إِعْبَارْ أَغزْذِيسْ ن شَّامَالْ، خمْسَا-مْيَا ن إِغُونَامْ س ؤُغَانِيمْ ن ڒعْبَارْ ذڭْ ونّضْ.
\v 18 إِعْبَارْ أَغزْذِيسْ ن لْجَانُوبْ، خمْسَا-مْيَا ن إِغُونَامْ س ؤُغَانِيمْ ن ڒعْبَارْ.
\v 19 إِنُوقَّارْ غَارْ ؤُغزْذِيسْ ن لْغَارْبْ ؤُشَا إِعْبَارْ خمْسَا-مْيَا ن إِغُونَامْ س ؤُغَانِيمْ ن ڒعْبَارْ.
\v 20 نتَّا إِعْبَارْ \add ڒبْنِي ن زَّاوشْثْ ثَامقّْرَانْثْ\add* غَارْ أَربْعَا ن ثْغمُّورَا \add نّسْ\add*. \add ثُوغَا\add* غَارسْ ذڭْ ونّضْ نّسْ إِجّْ ن ڒْحِيضْ س إِشْثْ ن ثُوزّڭَّارْثْ ن خمْسَا-مْيَا \add ن إِغُونَامْ ن ڒعْبَارْ\add* ذ إِشْثْ ن ثِيرُو ن خمْسَا-مْيَا \add ن إِغُونَامْ ن ڒعْبَارْ\add* مَاحنْذْ أَذْ إِفَارْزْ جَارْ مِينْ \add إِدْجَانْ\add* إِقدّْسنْ ذ مِينْ وَارْ \add إِدْجِينْ\add* إِقدّْسنْ.
\b
\b
\c 43
\s1 أَعُودْجِي ن سِيذِي إِذْوڒْ-د غَارْ زَّاوشْثْ ثَامقّْرَانْثْ
\m 
\v 1 \add خنِّي\add* إِنْذهْ أَيِي غَارْ ثوَّارْثْ، \add غَارْ\add* ثوَّارْثْ نِّي إِخزَّارنْ غَارْ شَّارْقْ.
\v 2 خْزَارْ، يُوسَا-د ؤُعُودْجِي ن أَربِّي ن إِسْرَائِيل زِي جِّيهثْ ن شَّارْقْ ؤُشَا ثْمِيجَّا نّسْ ثُوغَا-ت أَمْ ڒْهسّْ ن وَامَانْ أَطَّاسْ ؤُشَا ثَامُّورْثْ ثْشعْشعْ س ؤُعُودْجِي نّسْ.
\v 3 ؤُذمْ ن ڒوْحِييْ إِ ژْرِيغْ ثُوغَا أَمْ ڒوْحِييْ إِ ژْرِيغْ ؤُمِي د-ؤُسِيغْ حِيمَا أَذْ أَردّْدْجغْ ثَانْذِينْثْ. أَقَا ذ إِوحَّانْ أَمْ ڒوْحِييْ إِ ژْرِيغْ غَارْ يغْزَارْ ن خابُورْ، ؤُشَا وْضِيغْ س وُوذمْ إِنُو \add غَارْ ثمُّورْثْ\add*. \x ◘ \xo 43:‏3 \xt حِز. 1‏:‏4؛ 8‏:‏4\x*
\v 4 أَعُودْجِي ن سِيذِي يُوذفْ غَارْ ثَادَّارْثْ س ثوَّارْثْ نِّي إِخزَّارنْ غَارْ شَّارْقْ.
\v 5 \add خنِّي\add* إِسّْڭعّذْ أَيِي-د أَرُّوحْ ؤُشَا إِسِّيذفْ أَيِي غَارْ ڒمْرَاحْ ن ذَاخڒْ، ؤُشَا خْزَارْ، أَعُودْجِي ن سِيذِي إِشُّورْ ثَادَّارْثْ. \x ◘ \xo 43:‏5 \xt حِز. 3‏:‏14، حِز. 11‏:‏24\x*
\v 6 ؤُشَا سْڒِيغْ \add إِشْثْ ن ثْمِيجَّا\add* ثسَّاوَاڒْ أَكِيذِي زِي ذَاخڒْ ن ثَادَّارْثْ ؤُشَا أَرْيَازْ إِبدّْ غَارْ ؤُغزْذِيسْ إِنُو.
\v 7 نتَّا إِنَّا أَيِي: ”\add أَ\add* مِّيسْ ن بْنَاذمْ، وَا ذ أَمْشَانْ ن ڒْعَارْشْ إِنُو ؤُ أَمْشَانْ ن ثْڒقَّا ن إِضَارنْ إِنُو، مَانِي غَا زذْغغْ ذِي ڒْوسْطْ ن أَيْثْ ن إِسْرَائِيل إِ ڒبْذَا. ؤُشَا نِيثْنِي، ثَادَّارْثْ ن إِسْرَائِيل، نِيثْنِي ؤُڒَا ذ إِجدْجِيذنْ نْسنْ، وَارْ سّْخمَّاجنْ عَاذْ إِسمْ إِنُو إِقدّْسنْ س فَارْقْ-شّْغڒْ نْسنْ ؤُ س ڒْخشْبَاثْ ن \add لْ-أَصْنَامْ ن\add* إِجدْجِيذنْ نْسنْ خْ ڒڭْعُوذِي نْسنْ \add مَانِي تّْقدَّامنْ ثِيوْهِيبِينْ نْسنْ\add* \x ◘ \xo 43:‏7 \xt إِرْم. 16‏:‏18\x*
\v 8 أَمْ ڭِّينْ ثَانبْذَاثْ نْسنْ زَّاثْ إِ ثْنبْذَاثْ إِنُو، ذ طَّارْفْ ن ثوَّارْثْ نْسنْ غَارْ طَّارْفْ \add ن ثوَّارْثْ\add* إِنُو، \add إِقِّيمْ\add* مْغِيرْ إِجّْ ن وغْبَارْ جَارْ أَيِي-د ذ نِيثْنِي. \add أَمُّو إِ\add* سّخْمجنْ إِسمْ إِنُو إِقدّْسنْ س جّْعَايفْ نْسنْ نِّي ڭِّينْ، أَڒَامِي شِّيغْ ثنْ ذڭْ وغْضَابْ إِنُو.
\v 9 نِيثْنِي أَذْ خَافِي سِّيڭّْوجنْ فَارْقْ-شّْغڒْ نْسنْ ذ ڒْخشْبَاثْ ن \add لْ-أَصْنَامْ ن\add* إِجدْجِيذنْ نْسنْ، مَاحنْذْ أَذْ زمَّارغْ أَذْ زذْغغْ ذِي ڒْوسْثْ نْسنْ إِ ڒبْذَا.
\v 10 شكْ، \add أَ\add* مِّيسْ ن بْنَاذمْ، بَارّحْ س ثَادَّارْثْ-أَ إِ ثَادَّارْثْ ن إِسْرَائِيل حِيمَا أَذْ سضْحَانْ زِي سِّيبّثْ ن ڒْمُوعْصِييَّاثْ نْسنْ ؤُشَا أجّْ إِ-ثنْ أَذْ عْبَارنْ شّكْلْ نّسْ.
\v 11 مَاڒَا سضْحَانْ زِي مَارَّا مِينْ ڭِّينْ، سْشنْ أَسنْ \add خنِّي\add* شّكْلْ ن ثَادَّارْثْ ذ ثِيسَارْسْ نّسْ، ؤُفُّوغنْ نّسْ ذ أَذَافنْ نّسْ ذ مَارَّا شّكْلْ نّسْ ذ مَارَّا لْفَارَايِيضْ نّسْ، \add وَاهْ،\add* مَارَّا إِشْكَالنْ نّسْ ذ مَارَّا ثِيوصَّا نّسْ ؤُشَا أَرِي \add مَارَّا\add* مَانْ أَيَا زَّاثْ إِ ثِيطَّاوِينْ نْسنْ، حِيمَا خنِّي أَذْ حْضَانْ مَارَّا شّكْلْ نّسْ ذ مَارَّا لْفَارَايِيضْ نّسْ، ؤُشَا أَذْ زَّايْسنْ ڭّنْ.“
\s1 أَعَالْطَارْ ذ ؤُذشّنْ نّسْ
\m 
\v 12 ”ثَا ذ شَّارِيعَا ن ثَادَّارْثْ: خْ ثْقِيشَّاثْ ن وذْرَارْ أَذْ يِيڒِي ومْشَانْ نّسْ ذڭْ ونّضْ نّسْ إِقدّْسنْ قَاعْ. ثَا ذ شَّارِيعَا ن ثَادَّارْثْ.“ \x ◘ \xo 43:‏12 \xt حِز. 20‏:‏40؛ حِز. 40‏:‏2\x*
\m 
\v 13 ”إِنَا ذ ڒعْبُورَاثْ ن \bd ؤُعَالْطَارْ\bd* س إِغَادْجنْ: \bd إِجّْ ن ؤُغِيڒْ أَقَا-ث ذ إِجّْ ن ؤُغِيڒْ ذ إِجّْ شْبَارْ ن ؤُفُوسْ.\bd* ثَارْيَا نّسْ ذ إِجّْ ن ؤُغِيڒْ  ؤُ ثِيرُو نّسْ ذ إِجّْ ن ؤُغِيڒْ. ثْمَا نّسْ غَارْ طَّارْفْ نّسْ إِ ذ أَسْ د-إِنّْضنْ أَقَا ذ إِجّْ ن وزْينْ ن ؤُغِيڒْ. وَا ذ ذْسَاسْ ن ؤُعَالْطَارْ. \f ◼ \fr 43:‏13 \ft \bd ’أَحْسِينْ‘\bd* - نِيغْ ’أَبحْرُورْ‘.\f*
\v 14 زِي ثَارْيَا ذِي ثمُّورْثْ أَڒْ ثَارفِّيذثْ ن وَادَّايْ \add ن ؤُعَالْطَارْ\add*: ثْنَاينْ ن إِغَادْجنْ، ؤُ ثِيرُو \add نّسْ\add*: إِجّْ ن ؤُغِيڒْ، ؤُ زِي ثْرفِّيذثْ ن وَادَّايْ \add ن ؤُعَالْطَارْ\add* أَڒْ ثَارفِّيذثْ ن سنّجْ \add ن ؤُعَالْطَارْ\add*: أَربْعَا ن إِغَادْجنْ ؤُ ثِيرُو \add نّسْ\add* إِجّْ ن ؤُغِيڒْ.
\v 15 ڒبْنِي غَارْ سنّجْ، \add أَذْرَارْ ن أَربِّي‘،\add* \add إِڭَّا\add* أَربْعَا ن إِغَادْجنْ \add ذِي ڒُوعْڒَا\add* ؤُ زڭْ ؤُفُورْنُو ن ؤُعَالْطَارْ \add ڭعّْذنْ-د زَّايسْ\add* أَربْعَا ن وَاشَّاونْ سنّجْ نّسْ.
\v 16 أَفُورْنُو ن ؤُعَالْطَارْ غَارسْ إِشْثْ ن ثُوزّڭَّارْثْ ن ثنْعَاشْ \add ن إِغَادْجنْ\add* ذ إِشْثْ ن ثِيرُو ن ثنْعَاشْ \add ن إِغَادْجنْ\add*، إِجّْ ن ؤُكْوَاذْرُونْ س أَربْعَا ن إِغزْذِيسنْ \add نّسْ\add*.
\v 17 ثَارفِّيذثْ نّسْ \add سنّجْ\add* غَارسْ إِشْثْ ن ثُوزّڭَّارْثْ ن أَرْبعْطَاشْ \add ن إِغَادْجنْ\add* ذ إِشْثْ ن ثِيرُو ن أَرْبعْطَاشْ \add ن إِغَادْجنْ\add* غَارْ أَربْعَا ن إِغزْذِيسنْ نّسْ، ؤُ ثْمَا نّسْ إِ ذ أَسْ د-إِنّْضنْ أَقَا ذ أَزْينْ ن ؤُغِيڒْ، ؤُشَا ثَارْيَا نّسْ ذ إِجّْ ن ؤُغِيڒْ ذڭْ ونّضْ نّسْ ؤُشَا ثَارفِّيذِينْ ن دّْرُوجْ نّسْ خزَّارنْ غَارْ شَّارْقْ.“ *
\b
\m 
\v 18 نتَّا إِنَّا أَيِي: ”\add أَ\add* مِّيسْ ن بْنَاذمْ، أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ’ثِينَا ذ لْفَارَايِيضْ  إِنُو إِ ؤُعَالْطَارْ ذڭْ وَاسّْ إِ ذِي ث غَا ڭّنْ، مَاحنْذْ أَذْ خَاسْ سّْڭعّْذنْ ثَاغَارْصْثْ ن ثْمسِّي ؤُ مَاحنْذْ أَذْ خَاسْ زدْجْعنْ إِذَامّنْ.‘
\v 19 \add أَمُّو\add* إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ’أَذْ ثوْشذْ إِجّْ ن ؤُفُونَاسْ، أَمژْيَانْ ن إِشْثْ ن ثْفُونَاسْثْ، ذ ثَاوْهِيبْثْ ن ثْغَارْصْثْ ن دّنْبْ إِ إِكهَّاننْ زڭْ إِلَاوِييّنْ، إِ يِينِّي د-إِقَّارْصنْ زِي صَاذُوقْ، إِنِّي غَارِي د-إِقَارّْبنْ مَاحنْذْ أَذْ أَيِي سخَّارنْ.
\v 20 أَذْ ثكْسِيذْ زڭْ إِذَامّنْ نّسْ ؤُشَا أَذْ ثنْ ثڭّذْ غَارْ أَربْعَا ن وَاشَّاونْ \add ن ؤُعَالْطَارْ\add* ؤُ غَارْ أَربْعَا ن ثْغمُّورَا ن ثْرفِّيذثْ ؤُ خْ ثْمَا نّسْ إِ ذ أَسْ د-إِنّْضنْ غَارْ طَّارْفْ نّسْ. إِتّْخصَّا أَذْ زَّايسْ ثكّْسذْ دّنْبْ نّسْ ؤُ أَذْ ث ثْصڒْحذْ.
\v 21 \add أَوَارْنِي أَسْ\add* أَذْ ثكْسِيذْ أَفُونَاسْ نِّي أَمژْيَانْ ن ثْغَارْصْثْ ن دّنْبْ. إِتّْخصَّا أَسنْ أَذْ ث سّْشمْضنْ ذڭْ ومْشَانْ إِتّْوَاڭّنْ ن ثَادَّارْثْ بَارَّا إِ زَّاوشْثْ إِقدّْسنْ.
\v 22 ذڭْ وَاسّْ وِيسّْ ثْنَاينْ أَذْ د-ثسّْقَارّْبذْ إِجّْ ن ؤُمْيَانْ زڭْ إِغَايْضنْ إِشْنَانْ أَطَّاسْ ذ ثَاغَارْصْثْ ن دّنْبْ. أَذْ زَّايسْ كّْسنْ دّنْبْ زڭْ ؤُعَالْطَارْ أَمْ مَامّشْ زَّايسْ كّْسنْ دّنْبْ س ؤُفُونَاسْ أَمژْيَانْ.
\v 23 خْمِي غَا ثْكمّْڒذْ ثَاكسِّيثْ ن دّنْبْ، أَذْ د-ثسّْقَارّْبذْ إِجّْ ن ؤُفُونَاسْ، أَمژْيَانْ ن ثْفُونَاسْثْ إِشْنَانْ قَاعْ، ؤُڒَا ذ إِجّْ ن إِشَارِّي إِشْنَانْ أَطَّاسْ زڭْ وُودْجِي.
\v 24 أَذْ ثنْ د-ثسّْقَارّْبذْ زَّاثْ إِ وُوذمْ ن سِيذِي ؤُشَا إِكهَّاننْ أَذْ خَاسْ سُّويُوسنْ ثَامدْجَاحْثْ ؤُ أَذْ ثنْ سّْڭعّْذنْ أَمْ ثْغَارْصْثْ ن وشْمَاضْ إِ سِيذِي.
\v 25 سبْعَا ن وُوسَّانْ أَذْ ثسّْوجْذذْ ذِي كُوڒْ أَسّْ إِجّْ ن ؤُمْيَانْ ذ ثَاغَارْصْثْ ن دّنْبْ. أَذْ سّْوجْذنْ \add عَاوذْ\add* إِجّْ ن ؤُفُونَاسْ، أَمژْيَانْ ن ثْفُونَاسْثْ، ؤُڒَا ذ إِجّْ ن إِشَارِّي ن وُودْجِي، إِتّْخصَّا أَذْ إِڒِينْ شْنَانْ أَطَّاسْ.
\v 26 سبْعَا ن وُوسَّانْ أَذْ ثڭّذْ أَصْڒَاحْ إِ ؤُعَالْطَارْ ؤُشَا أَذْ ث سِّيزذْڭنْ ؤُ أَذْ ث سّْقدّْسنْ.
\v 27 مَاڒَا كمّْڒنْ نِيثْنِي ؤُسَّانْ-أَ، \add خنِّي\add* أَذْ يِيڒِي ذڭْ وَاسّْ وِيسّْ ثْمنْيَا، بلِّي إِكهَّاننْ أَذْ سّْوجْذنْ ثْغَارْصَا نْومْ ن وشْمَاضْ ذ ثوْهِيبِينْ نْومْ ن ؤُقَاذِي خْ ؤُعَالْطَارْ ؤُ نشّْ أَذْ خَاومْ أَرْضِيغْ!‘، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي.“
\b
\b
\c 44
\s1 ڒْحَاكمْ ذ إِكهَّاننْ
\m 
\v 1 \add خنِّي\add* يَارَّا أَيِي عَاوذْ غَارْ ثوَّارْثْ ن بَارَّا ن زَّاوشْثْ إِقدّْسنْ نِّي إِخزَّارنْ غَارْ شَّارْقْ. ثُوغَا ثْبلّعْ.
\v 2 \bd إِنَّا أَيِي سِيذِي:\bd* ”ثَاوَّارْثْ-أَ أَذْ ثقِّيمْ ثْبلّعْ، وَارْ ثَارْزمْ شَا ؤُشَا ؤُڒَا ذ إِجّْ أَذْ زَّايسْ يَاذفْ. مِينْزِي سِيذِي، أَربِّي ن إِسْرَائِيل، يُوذفْ زَّايسْ، خْ ؤُيَا أَذْ ثقِّيمْ ثْبلّعْ.
\v 3 ڒْحَاكمْ \add وَاهَا\add* إِ يدْجَانْ ذ ڒْحَاكمْ، أَذْ ذِينْ إِقِّيمْ حِيمَا أَذْ يشّْ أَغْرُومْ زَّاثْ إِ وُوذمْ ن سِيذِي. أَذْ يَاذفْ س ؤُكُولْوَارْ ن وسْقِيفْ \add ن ڒبْنِي\add* ن ثوَّارْثْ ؤُشَا أَذْ إِفّغْ س ؤُكُولْوَارْ نّسْ.“
\m 
\v 4 \add أَوَارْنِي أَسْ\add* إِنْذهْ أَيِي \add س\add* ثوَّارْثْ ن شَّامَالْ غَارْ زَّاثْ ن ثَادَّارْثْ. خزَّارغْ، ؤُشَا خْزَارْ، أَعُودْجِي ن سِيذِي إِشُّورْ ثَادَّارْثْ ن سِيذِي. \add خنِّي\add* وْضِيغْ س ؤُغمْبُوبْ إِنُو \add غَارْ ثمُّورْثْ\add*.
\v 5 إِنَّا أَيِي سِيذِي: ”\add أَ\add* مِّيسْ ن بْنَاذمْ، أڭّْ ؤُڒْ نّشْ، خْزَارْ س ثِيطَّاوِينْ نّشْ ؤُشَا سڒْ س إِمزُّوغنْ نّشْ مَارَّا مِينْ ذ أَشْ غَا سِّيوْڒغْ خْ مَارَّا ثِيوصَّا ن ثَادَّارْثْ ن سِيذِي ؤُ خْ مَارَّا إِزرْفَانْ نّسْ. أڭّْ ؤُڒْ نّشْ خْ \add كُوڒْ إِجّنْ\add* إِ إِتَّاذْفنْ ثَادَّارْثْ س مَارَّا ؤُفُّوغنْ ن زَّاوشْثْ إِقدّْسنْ
\v 6 ؤُشَا إِنِي إِ يِينِّي إِتّْغوّْغنْ، إِ ثَادَّارْثْ ن إِسْرَائِيل: ’أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: شْفَا مَارَّا جّْعَايفْ نْومْ، \add أَ\add* ثَادَّارْثْ ن إِسْرَائِيل،
\v 7 مَاغَارْ كنِّيوْ ثسِّيذْفمْ إِبَارَّانِييّنْ، إِنِّي وَارْ إِتّْوَاخثْننْ ن وُوڒْ ؤُ إِنِّي وَارْ إِتّْوَاخثْننْ ن أَرِّيمثْ، مَاحنْذْ أَذْ إِڒِينْ ذِي زَّاوشْثْ إِنُو إِقدّْسنْ ؤُ أَذْ سّْعِيدْجْثنْ \add أَمُّو\add* ثَادَّارْثْ إِنُو، ڒَامِي كنِّيوْ ثِيوْيمْ أَغْرُومْ إِنُو، \add إِخْسْ أَذْ يِينِي\add* ثَاذُونْثْ ذ إِذَامّنْ، ؤُ أَرْژِينْ نِيثْنِي ڒْعَاهْذْ إِنُو سنّجْ إِ مَارَّا جّْعَايفْ \add إِ ثڭِّيمْ س يِيخفْ\add* نْومْ.
\v 8 كنِّيوْ وَارْ ثحْضِيمْ أَحطُّو خْ مِينْ \add إِدْجَانْ\add* إِقدّْسنْ إِ نشّْ ؤُشَا ثڭِّيمْ إِمحْضَاينْ إِ يِيخفْ نْومْ مَاحنْذْ أَذْ حْضَانْ خْ زَّاوشْثْ إِنُو إِقدّْسنْ.“
\m 
\v 9 ”أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ’ؤُڒَا ذ إِجّْ ن ڒْبَارَّانِي نِّي وَارْ إِتّْوَاخثْننْ ؤُڒْ نّسْ ؤُ وَارْ إِتّْوَاخثْننْ أَيْسُومْ نّسْ أَذْ يَاذفْ غَارْ زَّاوشْثْ إِنُو إِقدّْسنْ. أَمُّو إِ غَا يِيڒِي إِ كُوڒْ ڒْبَارَّانِي نِّي إِدْجَانْ ذِي ڒْوسْطْ ن أَيْثْ ن إِسْرَائِيل.
\v 10 إِلَاوِييّنْ نِّي يَاڭّْوجنْ خَافِي أَطَّاسْ ؤُمِي زَّايِي إِودَّارْ إِسْرَائِيل، فّْغنْ زڭْ وبْرِيذْ، \add ؤُيُورنْ\add* أَوَارْنِي إِميْضَا نْسنْ ن لْ-أَصْنَامْ. أَقَا نِيثْنِي أَذْ أَرْبُونْ ڒْمُوعْصِييّثْ نْسنْ.
\v 11 أَذْ حْضَانْ ذِي زَّاوشْثْ إِنُو إِقدّْسنْ غَارْ \add ڒبْنِييَّاثْ ن\add* ثوَّارْثْ ن ثَادَّارْثْ ؤُشَا أَذْ سخَّارنْ \add عَاوذْ\add* ذِي ثَادَّارْثْ. نِيثْنِي أَذْ غَارْصنْ ثَاغَارْصْثْ ن وشْمَاضْ ذ ثْغَارْصْثْ إِ ڒْڭنْسْ ؤُشَا أَذْ بدّنْ زَّاثْ إِ وُوذمْ ن ڒْڭنْسْ مَاحنْذْ أَذْ أَسنْ سخَّارنْ.
\v 12 ؤُمِي ثُوغَا تّْسخَّارنْ زَّاثْ إِ وُوذمْ ن إِميْضَا نْسنْ ن لْ-أَصْنَامْ ؤُ ؤُمِي ثنْ ثُوغَا ذ إِشْثْ ن سِّيبّثْ إِ د-يِيوْينْ ڒْمُوعْصِييّثْ إِ ثَادَّارْثْ ن إِسْرَائِيل، خْ ؤُيَا أَقَا سّْڭعّْذغْ نشّْ أَفُوسْ إِنُو خَاسنْ ؤُ نِيثْنِي أَذْ أَرْبُونْ ڒْمُوعْصِييّثْ نْسنْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي.
\v 13 وَارْ إِعدّڒْ أَذْ غَارِي د-قَارّْبنْ مَاحنْذْ أَذْ أَيِي إِڒِينْ ذ إِكهَّاننْ ؤُ مَاحنْذْ أَذْ د-قَارّْبنْ غَارْ مَارَّا ثِيمسْڒَايِينْ إِقدّْسنْ إِنُو، غَارْ ثْمسْڒَايِينْ إِقدّْسنْ قَاعْ. نِيثْنِي أَذْ أَرْبُونْ ڒفْذِيحثْ نْسنْ ذ جّْعَايفْ إِ ڭِّينْ.
\v 14 أَذْ ثنْ ڭّغْ مَاحنْذْ أَذْ حْضَانْ خْ ثْسخَّارْثْ ذِي ثَادَّارْثْ، خْ مَارَّا ڒْخذْمثْ نّسْ ؤُ خْ مَارَّا مِينْ إِتّْخصَّا أَذْ ذَايسْ إِتّْوَاڭّْ.‘ “
\m 
\v 15 ”\add مَاشَا\add* إِكهَّاننْ إِلَاوِييّنْ، أَيْثْ ن صَاذُوقْ، إِنِّي إِحْضَانْ أَحطُّو ن زَّاوشْثْ إِنُو إِقدّْسنْ خْمِي خَافِي إِڭّْوجنْ أَيْثْ ن إِسْرَائِيل، أَذْ غَارِي د-قَارّْبنْ مَاحنْذْ أَذْ أَيِي سخَّارنْ. نِيثْنِي أَذْ بدّنْ زَّاثْ إِ وُوذمْ إِنُو مَاحنْذْ أَذْ غَارِي د-أَوْينْ ثَاذُونْثْ ذ إِذَامّنْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي.
\v 16 نِيثْنِي أَذْ أَذْفنْ غَارْ زَّاوشْثْ إِنُو إِقدّْسنْ ؤُشَا أَذْ د-قَارّْبنْ غَارْ طَّابْڒَا إِنُو مَاحنْذْ أَذْ أَيِي سخَّارنْ ؤُ أَذْ حْضَانْ ثَاسخَّارْثْ إِنُو.
\v 17 أَذْ يِيڒِي خْمِي غَا يَاذْفنْ غَارْ \add ڒبْنِييَّاثْ ن\add* ثوَّارْثْ ن ڒمْرَاحْ ن ذَاخڒْ، أَذْ أَرْضنْ أَرُّوضْ ن ڒقْطنْ. وَارْ إِعدّڒْ أَذْ أَرْضنْ شَا ن ثَاضُوفْثْ خْمِي غَا سخَّارنْ ذِي \add ڒبْنِييَّاثْ ن\add* ثوَّارْثْ ن ڒمْرَاحْ ن ذَاخڒْ ؤُ غَارْ ذَاخڒْ نّسْ.
\v 18 أَرژَّاثْ ن ڒقْطنْ أَذْ إِڒِينْ خْ إِزدْجِيفنْ نْسنْ ؤُ سّْرَاوڒْ نْ ڒقْطنْ أَذْ إِڒِينْ خْ ثجْعِينَّاثِينْ نْسنْ، وَارْ بيْسنْ شَا مِينْ زِي غَا سُّوفّْغنْ ثِيذِي.
\v 19 خْمِي غَا فّْغنْ غَارْ ڒمْرَاحْ ن بَارَّا، غَارْ ڒمْرَاحْ ن بَارَّا غَارْ ڒْڭنْسْ، \add خنِّي\add* أَذْ كّْسنْ أَرُّوضْ نْسنْ إِ ذِي سخَّارنْ ؤُشَا أَذْ ث سَّارْسنْ ذڭْ إِخَّامنْ إِقدّْسنْ. \add أَوَارْنِي أَسْ\add* أَذْ أَرْضنْ أَرُّوضْ نّغْنِي، حِيمَا وَارْ سّْقدَّاسنْ ڒْڭنْسْ س وَارُّوذْ نْسنْ.
\v 20 وَارْ سّْقُوشَّارنْ أَزدْجِيفْ نْسنْ ؤُ وَارْ تّجِّينْ ثِيجطَّايِينْ \add نْسنْ\add* أَذْ أَيْڒنْثْ أَمنِّي \add وَاهَا\add*. نِيثْنِي أَذْ قسّنْ \add أَشُوَّافْ ن\add* ؤُزدْجِيفْ نْسنْ مْلِيحْ.
\v 21 وَارْ إِعدّڒْ ؤُڒَا إِ يِيجّْ ن ؤُكهَّانْ أَذْ إِسُو بِينُو، خْمِي غَا يَاذفْ غَارْ ڒمْرَاحْ ن ذَاخڒْ.
\v 22 وَارْ ذ أَسنْ إِعدّڒْ \add إِ إِكهَّاننْ\add* مَاحنْذْ أَذْ أَوْينْ إِشْثْ ن ثَاجَّاتْشْ نِيغْ إِشْثْ ن ثْنُوڒُوفْثْ ذ ثَامْغَارْثْ إِ يِيخفْ نْسنْ. إِعدّڒْ مَاحنْذْ أَذْ أَوْينْ مْغِيرْ ثِيعْزُورَايْ زِي زَّارِيعثْ ن ثَادَّارْثْ ن إِسْرَائِيل إِشْثْ ن ثَاجَّاتْشْ ثنِّي ذ ثَاجَّاتْشْ ن إِجّْ ن ؤُكهَّانْ. \x ◘ \xo 44:‏22 \xt لَاوِي 21‏:‏13، 14\x*
\v 23 أَذْ سّْڒمْذنْ ڒْڭنْسْ إِنُو ڒْفَارْقْ جَارْ مِينْ \add إِدْجَانْ\add* إِقدّْسنْ ذ مِينْ وَارْ \add إِدْجِينْ\add* إِقدّْسنْ ؤُشَا أَذْ ثنْ سَّارڭْبنْ ڒْفَارْزْ جَارْ مِينْ إِخمْجنْ ذ مِينْ إِزْذِيڭنْ.
\v 24 ذڭْ ؤُمْشُوبّشْ أَذْ كَّارنْ حِيمَا أَذْ شَارّْعنْ. أَذْ ثنْ حَاكْمنْ عْلَاحْسَابْ لْفَارَايِيضْ إِنُو. نِيثْنِي أَذْ حْضَانْ ثِيوصَّا إِنُو ذ لْفَارَايِيضْ إِنُو ذِي مَارَّا ڒعْيُوذَاثْ إِنُو إِتّْوَاڭّنْ ؤُشَا أَذْ سّْقدّْسنْ ؤُسَّانْ إِنُو ن سّبْثْ.
\v 25 وَارْ إِعدّڒْ أَذْ إِرحّڭْ \add ؤُكهَّانْ\add* غَارْ إِجّْ ن بْنَاذمْ إِمُّوثنْ أَڒَامِي غَا إِسّخْمجْ إِخفْ نّسْ. إِعدّڒْ \add وَاهَا\add* أَذْ سّْخمْجنْ إِخفْ نْسنْ مْغِيرْ إِ بَابَاثْسنْ نِيغْ إِ يمَّاثْسنْ نِيغْ إِ مِّيثْسنْ نِيغْ إِ يدْجِيثْسنْ نِيغْ إِ ؤُمَاثْسنْ نِيغْ إِ ؤُتْشْمَاثْسنْ نِّي وَارْ إِمْڒِيشنْعمَّارْصْ.
\v 26 أَوَارْنِي ؤُسِيزْذڭْ نّسْ إِتّْخصَّا أَسنْ أَذْ حسّْبنْ سبْعَا ن وُوسَّانْ إِ نتَّا.
\v 27 ذڭْ وَاسّْ نِّي إِ غَا يَاذفْ غَارْ ؤُقدَّاسْ، غَارْ ڒمْرَاحْ ن ذَاخڒْ، مَاحنْذْ أَذْ إِسخَّارْ ذڭْ ؤُقدَّاسْ، إِتّْخصَّا أَسْ أَذْ د-إِسّْقَارّبْ ثَاغَارْصْثْ ن دّنْبْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي.“
\m 
\v 28 ”وَا أَذْ يِيڒِي ذ ڒْوَارْثْ نْسنْ: نشّْ ذ ڒْوَارْثْ نْسنْ. وَارْ ذ أَسنْ ثتِّيشِيمْ ؤُڒَا ذ إِجّْ ن وَاڭْڒَا \add ن ثمُّورْثْ\add* ذِي إِسْرَائِيل: نشّْ ذ أَڭْڒَا نْسنْ. \x ◘ \xo 44:‏28 \xt ڒخْڒ. 18‏:‏20؛ أَعَوذ. 18‏:‏1\x*
\v 29 إِعدّڒْ أَذْ شّنْ ثَاوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* ذ ثْغَارْصْثْ ن دّنْبْ ذ ثْغَارْصْثْ ن ؤُمَارْوَاسْ. مَارَّا مِينْ إِتّْوَاحَارّْمنْ ذِي إِسْرَائِيل أَذْ أَسنْ يِيڒِي.
\v 30 مُومُّو ن ثْمنْزُوثْ ن مَارَّا ؤُ مَارَّا ثَاوْهِيبْثْ ن ؤُسْڭعّذْ، زِي مَارَّا ثِيوْهِيبِينْ نْومْ ن ؤُسْڭعّذْ، أَذْ يِيڒِي إِ إِكهَّاننْ. ثَامزْوَارُوثْ ن وَارشْثِي نْومْ أَذْ ت ثوْشذْ إِ ؤُكهَّانْ، حِيمَا أَذْ ثَارْسَا لْبَارَاكَا خْ ثَادَّارْثْ نّشْ. \x ◘ \xo 44:‏30 \xt ؤُف. 13‏:‏2؛ 22‏:‏29، 30؛ ڒخْڒ. 18‏:‏11\x*
\v 31 ؤُڒَا ذ إِشْثْ ن ڒْخشْبثْ نِيغْ مِينْ إِتّْوَاشَارّْڭنْ ن إِجْضَاضْ نِيغْ نْ ڒبْحَايمْ، وَارْ إِعدّڒْ أَذْ ث شّنْ إِكهَّاننْ.“ \x ◘ \xo 44:‏31 \xt لَاوِي 22‏:‏8\x*
\b
\b
\c 45
\s1 ثَاسْغَارْثْ ن ثمُّورْثْ إِ إِدْجَانْ إِ سِيذِي
\m 
\v 1 ”خْمِي غَا ثبْضَامْ ثَامُّورْثْ ذ ڒْوَارْثْ \add س ثْقدُّوحْثْ\add*، أَذْ ثْوهّْبمْ إِشْثْ ن ثوْهِيبْثْ ن ؤُسْڭعّذْ إِ سِيذِي، إِشْثْ ن ثسْغَارْثْ إِقدّْسنْ زِي ثمُّورْثْ: ثُوزّڭَّارْثْ نّسْ \add أَذْ ثِيڒِي\add* خمْسَا ؤُ-عِيشْرِينْ-أَڒفْ \add ن إِغُونَامْ ن ڒعْبَارْ\add* ذ ثِيرُو نّسْعشْرَا-أَڒَافْ \add ن إِغُونَامْ ن ڒعْبَارْ\add*. مَارَّا ثَامُّورْثْ إِ ذ أَسْ د-إِنّْضنْ أَذْ ثِيڒِي ثْقدّسْ.
\v 2 خمْسَا-مْيَا ذِي خمْسَا-مْيَا \add ن إِغُونَامْ ن ڒعْبَارْ\add* غَارْ أَربْعَا إِغزْذِيسنْ نّسْ أَذْ زَّايسْ إِڒِينْ إِ زَّاوشْثْ إِقدّْسنْ. ؤُشَا ذڭْ ونّضْ نّسْ خمْسِينْ ن إِغَادْجنْ أَذْ إِڒِينْ ذ دّْمَانِي ن ثَاروْسَا.
\v 3 س ڒعْبَارْ-أَ أَذْ ثعْبَارذْ ذِي ثُوزّڭَّارْثْ خمْسَا ؤُ-عِيشْرِينْ-أَڒفْ ؤُ ذِي ثِيرُوعشْرَا-أَڒَافْ \add ن إِغُونَامْ ن ڒعْبَارْ\add* ؤُ زَّاوشْثْ إِقدّْسنْ أَذْ ذَايسْ ثِيڒِي، \add إِخْسْ أَذْ يِينِي\add* أَقْذَاسْ خْ ؤُقدَّاسْ.
\v 4 أَذْ ثِيڒِي ذ إِشْثْ ن ثمُّورْثْ إِقدّْسنْ. أَذْ ثِيڒِي إِ إِكهَّاننْ نِّي إِتّْسخَّارنْ ذِي زَّاوشْثْ إِقدّْسنْ، إِنِّي د-إِقَارّْبنْ مَاحنْذْ أَذْ سخَّارنْ إِ سِيذِي. أَذْ ثِيڒِي إِ نِيثْنِي ذ أَمْشَانْ ن ثْزذِّيغِينْ \add نْسنْ\add* ذ إِجّْ ن ومْشَانْ إِقدّْسنْ إِ زَّاوشْثْ إِقدّْسنْ.
\m 
\v 5 \add إِشْثْ ن ثمُّورْثْ\add* س إِشْثْ ن ثُوزّڭَّارْثْ ن خمْسَا ؤُ-عِيشْرِينْ-أَڒفْ ؤُ س إِشْثْ ن ثِيرُو نعشْرَا-أَڒَافْ \add ن إِغُونَامْ ن ڒعْبَارْ\add* أَذْ ثِيڒِي إِ إِلَاوِييّنْ نِّي إِتّْسخَّارنْ ذِي ثَادَّارْثْ، \add أَذْ ثِيڒِي\add* ذ ڒْمُولْكْ إِ نِيثْنِي، \add س\add* عِيشْرِينْ ن ڒبْنِييَّاثْ ن إِخَّامنْ.
\m 
\v 6 أَذْ ثوْشمْ \add إِشْثْ ن ثمُّورْثْ\add* س إِشْثْ ن ثِيرُو ن خمْسَا-أَڒَافْ ؤُ س إِشْثْ ن ثُوزّڭَّارْثْ ن خمْسَا ؤُ-عِيشْرِينْ-أَڒفْ \add ن إِغُونَامْ ن ڒعْبَارْ\add* ذ ثَامُّورْثْ إِ ثنْذِينْثْ، زَّاثْ إِ \add ثمُّورْثْ ن\add* ثوْهِيبْثْ إِقدّْسنْ ن ؤُسْڭعّذْ. أَذْ ثِيڒِي إِ مَارَّا ثَادَّارْثْ ن إِسْرَائِيل.
\v 7 ثَاسْغَارْثْ \add ن ثمُّورْثْ\add* ن ڒْحَاكمْ أَذْ ثِيڒِي غَارْ إِجّْ ن ؤُغزْذِيسْ ؤُڒَا غَارْ ؤُغزْذِيسْ نّغْنِي ن \add ثمُّورْثْ ن\add* ثوْهِيبْثْ إِقدّْسنْ ن ؤُسْڭعّذْ ؤُ ن ثسْغَارْثْ \add ن ثمُّورْثْ\add* ن ثنْذِينْثْ، زَّاثْ إِ ثوْهِيبْثْ إِقدّْسنْ ن ؤُسْڭعّذْ ؤُ زَّاثْ إِ ثسْغَارْثْ \add ن ثمُّورْثْ\add* ن ثنْذِينْثْ، زڭْ ؤُغزْذِيسْ ن ڒْغَارْبْ غَارْ ڒْغَارْبْ ؤُ زڭْ ؤُغزْذِيسْ ن شَّارْقْ غَارْ شَّارْقْ. ثُوزُّوڭَّارْثْ أَذْ ثِيڒِي نِيشَانْ زَّاثْ إِ ؤُغزْذِيسْ ن إِشْثنْ زِي ثْسقَّاڒْ ن ڒْوَارْثْ، زڭْ ويْمِيرْ إِ إِدْجَانْ غَارْ ڒْغَارْبْ أَڒْ ويْمِيرْ إِ إِدْجَانْ غَارْ شَّارْقْ.
\v 8 ثَامُّورْثْ أَذْ ثِيڒِي نّسْ، ثَاسْغَارْثْ نّسْ ذِي إِسْرَائِيل. ؤُ ڒْحُوكَّامْ إِنُو وَارْ حسَّارنْ عَاذْ ڒْڭنْسْ إِنُو، \add مَاشَا\add* أَذْ وْشنْ ثَامُّورْثْ إِ ثَادَّارْثْ ن إِسْرَائِيل، إِ ثْقبَّاڒْ نْسنْ.“
\b
\s1 ڒْحقّْ ن ڒْحَاكمْ ذ مِينْ خَاسْ إِدْجَانْ
\m 
\v 9 ”أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ’شْفَا أَومْ، \add أَ كنِّيوْ،\add* ڒْحُوكَّامْ ن إِسْرَايِيلْ! سْبعّذْ خَاومْ لْعُونْفْ ؤُ ڭّمْ ڒْحقّْ ذ ثْسڭْذَا ؤُشَا كّْسمْ إِبعَّاجْ نْومْ خْ ڒْڭنْسْ إِنُو، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي.
\v 10 إِتّْخصَّا أَذْ غَارْومْ يِيڒِي إِجّْ ن ڒْمِيزَانْ نِيشَانْ ذ إِجّْ ن إِفَا نِيشَانْ ذ إِجّْ ن ؤُبَاثُو نِيشَانْ. \f ◼ \fr 45:‏10 \ft \bd ’أَبَاثُو‘\bd* - إِجّْ ن ’ؤُبَاثُو‘ عْرَاحَاڒْ 20 نِيغْ 40 لِيثْرُو.\f*  \x ◘ \xo 45:‏10 \xt لَاوِي 19‏:‏35، 36؛ أَعَوذ. 25‏:‏13‏-‏16.\x*
\v 11 إِتّْخصَّا أَذْ يِيڒِي \add ڒعْبَارْ ن\add* إِفَا ذ \add ڒعْبَارْ ن\add* ؤُبَاثُو ذ ڒعْبَارْ ذ إِجّْ، حِيمَا أَذْ يِيڒِي ؤُبَاثُو ذ إِشْثْ زِي ثْعشَّارْثْ ن ؤُحُومِيرْ، ؤُشَا إِشْثْ ن ثْعشَّارْثْ ن ؤُحُومِيرْ \add أَذْ ثسْوَا\add* إِفَا. ڒقْيَاسْ ن ڒعْبَارْ نْسنْ أَذْ يِيڒِي زڭْ ؤُحُومِيرْ. \f ◼ \fr 45:‏11 \ft \bd ’أَبَاثُو‘\bd* - إِجّْ ن ’ؤُبَاثُو‘ عْرَاحَاڒْ 20 نِيغْ 40 لِيثْرُو.\f*
\v 12 أَشِيقْلْ أَقَا-ث عِيشْرِينْ جِيرَا. عِيشْرِينْ شِيقْلُو، خمْسَا ؤُ -عشْرِينْ شِيقْلُو، خمّسْطَاشْ شِيقْلُو، أَذْ أَومْ يِيڒِي إِجّنْ مِينَا.‘ “ \x ◘ \xo 45:‏12 \xt ؤُف. 30‏:‏13؛ لَاوِي 27‏:‏25؛ ڒخْڒ. 3‏:‏47\x*
\m 
\v 13 ”ثَا ذ ثوْهِيبْثْ ن ؤُسْڭعّذْ نِّي إِ غَا ثسّْڭعّْذمْ: إِشْثْ ن ثْسِيتُّوثْ ن إِجّْ ن إِفَا زڭْ إِجّْ ن ؤُحُومِيرْ ن يِيرْذنْ ؤُشَا أَذْ ثوْشمْ ؤُڒَا ذ إِشْثْ ن ثْسِيتُّوثْ ن إِجّْ ن ؤُحُومِيرْ ن إِمنْذِي.
\v 14 خْ ثوْصيّثْ ن زّشْثْ، \add ثَاوْصِييّثْ ن\add* \add ڒْْقدّْ ن\add* ؤُبَاثُو ن زّشْثْ: أَقَا إِشْثْ ن ثعْشَارْثْ ن ؤُبَاثُو ن إِجّْ ن ؤُكُورُو، \add أَكُورُو نِّي إِسكّْوِينْ\add* إِجّْ ن ؤُحُومِيرْ نعشْرَا إِبَاثُوثنْ، مِينْزِيعشْرَا إِبَاثُوثنْ ذ إِجّْ ن ؤُحُومِيرْ. \f ◼ \fr 45:‏14 \ft \bd ’أَبَاثُو‘\bd* - إِجّْ ن ’ؤُبَاثُو‘ عْرَاحَاڒْ 20 نِيغْ 40 لِيثْرُو.\f*
\v 15 \add خنِّي\add* إِجّْ \add زڭْ وُودْجِي\add* خْ مِيثَاينْ ن وُودْجِي زِي \add دّْمَانِي ن ثَاروْسَا ن\add* ثمُّورْثْ ن إِسْرَائِيل إِ إِفيّْضنْ س وَامَانْ، أَمْ ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* ؤُ أَمْ ثْغَارْصْثْ ن وشْمَاضْ ؤُ أَمْ ثوْهِيبْثْ ن ڒهْنَا، مَاحنْذْ أَذْ ثڭّذْ أَصْڒَاحْ إِ نِيثْنِي، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي.
\v 16 مَارَّا ڒْڭنْسْ ن ثمُّورْثْ، \add مَارَّا\add* نِيثْنِي أَذْ شَارْشنْ ذِي ثوْهِيبْثْ ن ؤُسْڭعّذْ إِ ڒْحَاكمْ ذِي إِسْرَائِيل.
\v 17 أَذْ يِيڒِي خْ ڒْحَاكمْ مَاحنْذْ \add أَذْ يڭّْ\add* ثِيغَارْصَا ن وشْمَاضْ ذ ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* ذ ثْغَارْصْثْ \add ن ؤُسيّبْ\add* ذِي ڒعْيُوذَاثْ ؤُ ذڭْ وُوسَّانْ ن ؤُيُورْ ن جْذِيذْ ؤُ خْ وُوسَّانْ ن سّبْثْ، \add وَاهْ،\add* خْ مَارَّا ؤُسَّانْ ن ڒعْيُوذَاثْ ن ثَادَّارْثْ ن إِسْرَائِيل. نتَّا أَذْ إِسّوْجذْ ثَاغَارْصْثْ ن دّنْبْ ذ ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* ذ ثوْهِيبْثْ ن وشْمَاضْ ذ ثوْهِيبِينْ ن ڒهْنَا، مَاحنْذْ أَذْ إِڭّْ أَصْڒَاحْ إِ ثَادَّارْثْ ن إِسْرَائِيل.“ \f ◼ \fr 45:‏17 \ft \bd ’إِفْذِي‘\bd* - خْزَارْ إِزهد. 78‏:35.\f*
\b
\s1 ڒعْيُوذَاثْ ذ ثوْهِيبِينْ
\m 
\v 18 ”أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ’ذڭْ ؤُيُورْ أَمزْوَارُو، ذڭْ وَاسّْ أَمزْوَارْ ن ؤُيُورْ، أَذْ ثكْسِيذْ إِجّْ ن ؤُفُونَاسْ إِشْنَانْ أَطَّاسْ، أَمژْيَانْ ن ثْفُونَاسْثْ، ؤُشَا أَذْ زَّايسْ ثكّْسذْ دّنْبْ زِي زَّاوشْثْ إِقدّْسنْ.
\v 19 أَكهَّانْ أَذْ إِكْسِي زڭْ إِذَامّنْ ن ثْغَارْصَا ن دّنْبْ ؤُشَا أَذْ ثنْ يڭّْ خْ ڒضْرُوفْ إِ إِدْجَانْ غَارْ ؤُغزْذِيسْ ن ثوُّورَا ن ثَادَّارْثْ، غَارْ أَربْعَا ن ثْغمُّورَا ن ثْرفِّيذثْ ن ؤُعَالْطَارْ ؤُ خْ ڒضْرُوفْ ن ثوَّارْثْ ن ڒمْرَاحْ ن ذَاخڒْ.
\v 20 أَمُّو إِ غَا ثڭّذْ ذڭْ وَاسّْ وِيسّْ سبْعَا ن ؤُيُورْ، ذِي طّْوعْ ن ونِّي إِودَّارنْ \add ذڭْ وبْرِيذْ\add* ؤُ ذِي طّْوعْ ن ؤُقُوبَّانِي، أَمُّو إِ غَا ثڭّمْ أَصْڒَاحْ إِ ثَادَّارْثْ.‘ “
\m 
\v 21 ”ذڭْ \add ؤُيُورْ\add* أَمزْوَارُو، ذڭْ وَاسّْ وِيسّْ أَرْبعْطَاشْ ن ؤُيُورْ أَذْ ثِيڒِي \add ثْغَارْصْثْ ن\add* ؤُسعْذُو إِ كنِّيوْ، أَذْ يِيڒِي ڒْعِيذْ إِ يِيجّْ ن ڒْمِيجَاڒْ ن سبْعَا ن وُوسَّانْ، أَذْ شّنْ أَغْرُومْ بْڒَا أَنْثُونْ. \x ◘ \xo 45:‏21 \xt ؤُف. 12‏:‏3؛ 23‏:‏15؛ لَاوِي 23‏:‏5؛ ڒخْڒ. 9‏:‏3؛ 28‏:‏16، 17؛ أَعَوذ. 16‏:‏1\x*
\v 22 \bd ذڭْ وَاسّْ نِّي\bd* أَذْ إِسّوْجذْ ڒْحَاكمْ إِجّْ ن ؤُفُونَاسْ أَمژْيَانْ \add أَمْ\add* ثْغَارْصْطْ ن دّنْبْ إِ يِيخفْ نّسْ ؤُ إِ مَارَّا ڒْڭنْسْ ن ثمُّورْثْ.
\v 23 \add ذِي\add* سبْعَا ن وُوسَّانْ ن ڒْعِيذْ أَذْ إِسّوْجذْ إِشْثْ ن ثْغَارْصْثْ ن وشْمَاضْ إِ سِيذِي: سبْعَا ن إِفُونَاسنْ إِمژْيَاننْ ذ سبْعَا ن إِشَارِّييّنْ إِشْنَانْ، \add مَارَّا\add* سبْعَا ن وُوسَّانْ نِّي، ؤُڒَا ذ إِشْثْ ن ثْغَارْصْثْ ن دّنْبْ ن إِجّْ ن ؤُمْيَانْ زڭْ إِغَايْضنْ كُوڒْ أَسّْ.
\v 24 أَذْ إِسّوْجذْ \add عَاوذْ\add* ثَاوْهِيبْثْ \add ن ڒْغِيدْجثْ\add*: إِجّْ ن إِفَا إِ يِيجّْ ن ؤُفُونَاسْ أَمژْيَانْ ؤُ إِجّْ ن إِفَا إِ يِيجّْ ن إِشَارِّي ؤُ إِجّْ ن ؤُهِينُو ن زّشْثْ إِ يِيجّْ ن إِفَا.
\v 25 ذڭْ \add يُويُورْ\add* وِيسّْ سبْعَا، ذڭْ وَاسّْ وِيسّْ خمّسْطَاشْ ن ؤُيُورْ إِتّْخصَّا أَسْ أَذْ يڭّْ \add أَمُّو\add* \add مَارَّا\add* مَانْ أَيَا ذِي ڒْعِيذْ، سبْعَا ن وُوسَّانْ: أَمْ ثْغَارْصْثْ ن دّنْبْ أَمْ ثْغَارْصْثْ ن وشْمَاضْ، أَمْ ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* أَمْ زّشْثْ.“ \x ◘ \xo 45:‏25 \xt لَاوِي 23‏:‏33؛ ڒخْڒ. 29‏:‏12؛ أَعَوذ. 16‏:‏13\x*
\b
\b
\c 46
\m 
\v 1 ”أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ’ثَاوَّارْثْ ن ڒمْرَاحْ ن ذَاخڒْ نِّي إِخزَّارنْ غَارْ شَّارْقْ أَذْ ثِيڒِي ثْبلّعْ ذِي ستَّا ن وُوسَّانْ ن ڒْخذْمثْ. ذڭْ وَاسّْ ن سّبْثْ أَذْ ثنُّورْزمْ ؤُڒَا خْ وَاسّْ ن ؤُيُورْ ن جْذِيذْ أَذْ ثنُّورْزمْ.
\v 2 أَذْ د-يَاذفْ ڒْحَاكمْ زِي بَارَّا س ؤُكُولْوَارْ ن وسْقِيفْ \add ن ڒبْنِي\add* ن ثوَّارْثْ ؤُشَا أَذْ إِبدّْ غَارْ طَّارْفْ \add ن ڒبْنِي\add* ن ثوَّارْثْ. إِكهَّاننْ أَذْ سّْوجْذنْ ثِيغَارْصَا نّسْ ن وشْمَاضْ ذ ثْغَارْصَا نّسْ ن ثْمسِّي ؤُ نتَّا أَذْ إِسْجذْ خْ ثْنبْذَاثْ ن ثوَّارْثْ ؤُشَا أَذْ \add زَّايسْ\add* إِفّغْ \add عَاوذْ\add*. وَارْ تّْبلِّيعنْ ثَاوَّارْثْ أَڒْ ثَامذِّيثْ.
\v 3 ڒْڭنْسْ ن ثمُّورْثْ أَذْ إِسْجذْ زَّاثْ إِ وَاذَافْ \add ن ڒبْنِي\add* ن ثوَّارْثْ خْ وُوسَّانْ ن سّبْثْ ؤُ خْ وُوسَّانْ ن ؤُيُورْ ن جْذِيذْ زَّاثْ إِ وُوذمْ ن سِيذِي.
\v 4 ثَاغَارْصْثْ ن وشْمَاضْ نِّي إِ غَا د-إِسّْقَارّبْ ڒْحَاكمْ إِ سِيذِي ذڭْ وَاسّْ ن سّبْثْ، أَذْ ثِيڒِي ستَّا ن إِزْمَارنْ إِشْنَانْ ذ إِجّْ ن إِشَارِّي إِشْنَا.
\v 5 ثَاوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* \add أَذْ ثِيڒِي\add* إِجّْ ن إِفَا إِ يِيجّْ ن إِشَارِّي، ؤُ إِ إِزْمَارنْ \add أَذْ ثِيڒِي\add* ثوْهِيبْثْ \add ن رْغِيدْجثْ\add* مِينْ إِزمَّارْ ؤُفُوسْ نّسْ أَذْ ث يَاوِي ؤُشَا \add خنِّي أَرْنِي\add* إِجّْ ن ؤُهِينُو ن زّشْثْ إِ كُوڒْ إِفَا.
\v 6 ذڭْ وَاسّْ ن ؤُيُورْ ن جْذِيذْ: إِجّْ ن ؤُفُونَاسْ إِشْنَانْ أَطَّاسْ، أَمژْيَانْ ن ثْفُونَاسْثْ، ؤُ ستَّا ن إِزْمَارنْ ذ إِجّْ ن إِشَارِّي. إِتّْخصَّا أَذْ إِڒِينْ شْنَانْ أَطَّاسْ.
\v 7 أَذْ إِسّوْجذْ إِجّْ ن إِفَا إِ كُوڒْ أَفُونَاسْ أَمژْيَانْ ؤُ إِجّْ ن إِفَا إِ كُوڒْ إِشَارِّي ذ ثَاوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* ؤُ إِ إِزْمَارنْ أَنشْثْ إِزمَّارْ ؤُفُوسْ نّسْ أَذْ ث يَاوِي، ؤُ \add زِي\add* زّشْثْ إِتّْخصَّا أَذْ إِسّوْجذْ إِجّْ ن ؤُهِينُو إِ كُوڒْ إِفَا.‘ “
\m 
\v 8 ”خْمِي غَا يَاذفْ ڒْحَاكمْ، أَذْ يَاذفْ زڭْ ؤُكُولْوَارْ ن وسْقِيفْ \add ن ڒبْنِي\add* ن ثوَّارْثْ ؤُشَا أَذْ إِفّغْ زڭْ ؤُكُولْوَارْ نّسْ \add عَاوذْ\add*.
\v 9 خْمِي د غَا يَاسْ ڒْڭنْسْ ن ثمُّورْثْ زَّاثْ إِ وُوذمْ ن سِيذِي ذڭْ وُوسَّانْ إِتّْوَاڭّنْ ن ڒعْيُوذَاثْ، إِتّْخصَّا وِي غَا يَاذْفنْ زڭْ ؤُكُولْوَارْ \add ن ڒبْنِي\add* ن ثوَّارْثْ ن شَّامَالْ مَاحنْذْ أَذْ \add أَسْ\add* إِبنْذقْ، أَذْ إِفّغْ س ؤُكُولْوَارْ \add ن ڒبْنِي\add* ن ثوَّارْثْ ن لْجَانُوبْ، ؤُ وِي غَا يَاذْفنْ س ؤُكُولْوَارْ \add ن ڒبْنِي\add* ن ثوَّارْثْ ن لْجَانُوبْ، أَذْ إِفّغْ س ؤُكُولْوَارْ \add ن ڒبْنِي\add* ن ثوَّارْثْ ن شَّامَالْ. وَارْ إِذِّيكّْوِيڒْ زِي ڒبْنِي ن ثوَّارْثْ مَانِي د-يُوذفْ، مَاشَا أَذْ د-إِفّغْ زِي ثنِّي يدْجَانْ أَرنْذَاذْ نّسْ.
\v 10 ڒْحَاكمْ أَذْ يَاذفْ ذِي ڒْوسْثْ نْسنْ. خْمِي غَا يَاذْفنْ ؤُ خْمِي د غَا فّْغنْ، أَذْ د-فّْغنْ \add جْمِيعْ\add*.“
\m 
\v 11 ”ذِي ڒعْيُوذَاثْ ؤُ ذڭْ وُوسَّانْ إِتّْوَاڭّنْ ن ڒْعِيذْ أَذْ ثِيڒِي ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* ذ إِجّْ ن إِفَا إِ كُوڒْ أَفُونَاسْ أَمژْيَانْ ؤُ إِجّْ ن إِفَا إِ كُوڒْ إِشَارِّي ؤُ إِ إِزْمَارنْ أَنشْثْ إِزمَّارْ ؤُفُوسْ نّسْ أَذْ ث يَاوِي، ؤُشَا \add خنِّي أَرْنِي\add* إِجّْ ن ؤُهِينُو ن زّشْثْ إِ كُوڒْ إِفَا.“
\m 
\v 12 ”خْمِي غَا إِسّوْجذْ ڒْحَاكمْ إِشْثْ ن ثوْهِيبْثْ ن ڒْخَاضَارْ، إِشْثْ ن ثْغَارْصْثْ ن وشْمَاضْ نِيغْ ثِيوْهِيبِينْ ن ڒهْنَا أَمْ ثوْهِيبْثْ نْ ڒْخَاضَارْ إِ سِيذِي، \add خنِّي\add* أَذْ أَسْ أَرْزْمنْ ثَاوَّارْثْ نِّي إِخزَّارنْ غَارْ شَّارْقْ. نتَّا أَذْ إِسّوْجذْ ثَاغَارْصْثْ نّسْ ن وشْمَاضْ ذ ثوْهِيبِينْ نّسْ ن ڒهْنَا، أَمْ مَامّشْ ثنْثْ إِسّوْجذْ ذڭْ وَاسّْ ن سّبْثْ، ؤُ خْمِي غَا إِفّغْ أَذْ بلّْعنْ ثَاوَّارْثْ أَوَارْنِي ڒَامِي إِفّغْ نتَّا.“
\m 
\v 13 ”كُوڒْ صّْبحْ أَذْ ثسّْوجْذذْ إِجّْ ن إِزْمَارْ ن إِجّْ ن ؤُسڭّْوَاسْ إِشْنَانْ قَاعْ أَمْ ثوْهِيبْثْ ن وشْمَاضْ إِ سِيذِي.
\v 14 إِتّْخصَّا أَذْ كِيذسْ ثسّْوجْذذْ ذِي كُوڒْ صّْبحْ إِشْثْ ن ثْسِيتُّوثْ ن إِجّْ ن إِفَا ذ إِشْثْ ن تُّوڒُوثْ ن إِجّْ ن ؤُهِينُو ن زّشْثْ مَاحنْذْ أَذْ زَّايسْ ثسُّوفّذْ أَرنْ أَزْذَاذْ أَمْ ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* إِ سِيذِي. \add أَقَا\add* ذ ثِيوصَّا إِتّْذُومَانْ، إِ ڒبْذَا.
\v 15 نِيثْنِي أَذْ سّْوجْذنْ إِزْمَارْ ذ ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* ذ زّشْثْ ذِي كُوڒْ ثِيوشَّا أَمْ ثْغَارْصْثْ ن ثْمسِّي ن ڒبْذَا.“
\m 
\v 16 ”أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ’خْمِي غَا إِوْشْ ڒْحَاكمْ إِشْثْ ن ثَارْزفْثْ إِ يِيجّْ زڭْ إِحنْجِيرنْ نّسْ، \add خنِّي\add* مَانْ أَيَا أَذْ ثِيڒِي ذ ڒْوَارْثْ نّسْ. أَذْ ثِيڒِي إِ إِحنْجِيرنْ نّسْ، أَقَا-ث ذ أَڭْڒَا نّسْ ذِي ڒْوَارْثْ.
\v 17 \add مَاشَا\add* مَاڒَا إِوْشَا زِي ڒْوَارْثْ نّسْ إِشْثْ ن ثَارْزفْثْ إِ يِيجّنْ زڭْ إِمْسخَّارنْ نّسْ، \add خنِّي\add* أَذْ ثِيڒِي نّسْ أَڒْ أَسڭّْوَاسْ ن ثْڒلِّي. \add خنِّي\add* أَذْ د-ثذْوڒْ \add ثسْغَارْثْ\add* غَارْ ڒْحَاكمْ، مِينْزِي أَقَا-ت ذ ڒْوَارْثْ نّسْ، أَذْ ثِيڒِي إِ إِحنْجِيرنْ نّسْ. \f ◼ \fr 46:‏17 \ft \bd ’أَذْ ثِيڒِي نّسْ‘\bd* - إِخْسْ أَذْ يِينِي أَقَا ثَاسْغَارْثْ أَذْ ثِيڒِي إِ ؤُمْسخَّارْ نّسْ.\f*
\v 18 وَارْ إِعدّڒْ إِ ڒْحَاكمْ أَذْ إِكّسْ شَا زِي ثسْغَارْثْ ن ڒْڭنْسْ أَڒَامِي غَا إِكشّضْ أَڭْڒَا نْسنْ. نتَّا أَذْ إِسّْوَارْثْ ثَاسْغَارْثْ إِ إِحنْجِيرنْ نّسْ زڭْ وَاڭْڒَا نّسْ، حِيمَا وَارْ إِتّْوَازُوزَّارْ ڒْڭنْسْ إِنُو، \add ؤُمِي\add* إِ غَا إِتّْوَاقْڒعْ كُوڒْ  إِجّْ زڭْ وَاڭْڒَا نّسْ.‘ “
\m 
\v 19 \add خنِّي\add* إِنْذهْ أَيِي أَمْ د-إِكَّا خْ ثبْرِيذْثْ نِّي غَارْ ؤُغزْذِيسْ \add ن ڒبْنِي\add* ن ثوَّارْثْ أَڒْ إِخَّامنْ إِقدّْسنْ ن إِكهَّاننْ نِّي ثُوغَا إِوَاڒَانْ شَّامَالْ. ؤُ خْزَارْ، أَقَا ذِينْ إِجّْ ن ومْشَانْ غَارْ ضفَّارْ ن ثْنَاينْ ن إِغزْذِيسنْ \add نّسْ\add*، غَارْ ڒْغَارْبْ.
\v 20 نتَّا إِنَّا أَيِي: ”وَا ذ أَمْشَانْ مَانِي غَا سّنْونْ إِكهَّاننْ ثَاغَارْصْثْ ن \add ثِيكّسْثْ ن\add* ؤُمَارْوَاسْ ذ ثْغَارْصْثْ ن دّنْبْ ؤُ مَانِي غَا سّنْڭّْونْ ثَاوْهِيبْثْ \add ن ڒْغِيدْجثْ\add*، حِيمَا وَارْ ت سُّوفّْغنْ شَا بَارَّا غَارْ ڒمْرَاحْ ن بَارَّا، أَڒَامِي إِ غَا سّْقدّْسنْ ڒْڭنْسْ \add أَمُّو\add*.“
\m 
\v 21 \add خنِّي\add* إِسُّوفّغْ أَيِي بَارَّا غَارْ ڒمْرَاحْ ن بَارَّا ؤُشَا إِنْذهْ أَيِي غَارْ أَربْعَا ن ثْغمُّورَا ن ڒمْرَاحْ. ؤُ خْزَارْ، ذِي كُوڒْ ثَاغْمَارْثْ ن ڒمْرَاحْ أَقَا ذِينْ إِجّْ ن ڒمْرَاحْ \add نّغْنِي\add*، إِجّْ ن \add ومْشَانْ إِفَارْزنْ ذِي\add* ڒمْرَاحْ ذِي \add كُوڒْ\add* ثَاغْمَارْثْ نْ ڒمْرَاحْ.
\v 22 ذِي أَربْعَا ن ثْغمُّورَا ن ڒمْرَاحْ ن زَّاثْ \add ثُوغَا ذِينْ إِخَّامنْ أَمْ\add* ڒمْرَاحَاثْ إِسقّْفنْ س إِشْثْ ن ثُوزّڭَّارْثْ ن أَربْعِينْ \add ن إِغَادْجنْ\add* ذ إِشْثْ ن ثِيرُو ن ثْڒَاثِينْ \add ن إِغَادْجنْ\add*. \add إِخَّامنْ ذڭْ\add* أَربْعَا ن ثْغمُّورَا غَارْسنْ ڒعْبَارْ ذ إِجّْ.
\v 23 ذڭْ ونّضْ ن أَربْعَا \add ن إِخَامّنْ\add* نِّي ثُوغَا ذِينْ إِشْثْ ن ثْسذِّييْثْ إِ ذ أَسنْ-د إِنّْضنْ. أَقَا ڭِّينْ ڒْمجْمَارَاثْ سَاذُو إِ ثْسدّْيِينْ إِ ذ أَسْ د-إِنّْضنْ.
\v 24 نتَّا إِنَّا أَيِي: ”ثِينَا ذ كُوزِينَاثْ مَانِي غَا سّنْڭّْونْ إِمْسخَّارنْ ن ثَادَّارْثْ ثَاغَارْصْثْ نْ ڒْڭنْسْ.“ *
\b
\b
\c 47
\s1 إِغْزَارْ إِ د-إِفّْغنْ زِي زَّاوشْثْ ثَامقّْرَانْثْ
\m 
\v 1 \add أَوَارْنِي أَيَا\add* يِيوِي أَيِي عَاوذْ غَارْ وَاذَافْ ن ثَادَّارْثْ، ؤُ خْزَارْ، زِي سَاذُو ثَانبْذَاثْ ن ثَادَّارْثْ تّفّْغنْ وَامَانْ غَارْ شَّارْقْ، مِينْزِي أَغزْذِيسْ ن زَّاثْ ن ثَادَّارْثْ ثُوغَا-ث غَارْ شَّارْقْ ؤُ ثُوغَا تَّازّْڒنْ هكّْوَانْ أَمَانْ زِي سْوَادَّايْ ن ؤُغزْذِيسْ أَزڒْمَاضْ ن ثَادَّارْثْ، غَارْ \add ؤُغزْذِيسْ ن\add* لْجَانُوبْ ن ؤُعَالْطَارْ.
\v 2 إِسُّوفّغْ أَيِي-د زڭْ ؤُكُولْوَارْ \add ن ڒبْنِي\add* ن ثوَّارْثْ ن شَّامَالْ ؤُشَا إِنْذهْ أَيِي غَارْ ثبْرِيذْثْ نِّي غَارْ بَارَّا، جِّيهثْ ن ثوَّارْثْ ن بَارَّا، \add غَارْ\add* ؤُكُولْوَارْ نِّي إِخزَّارنْ غَارْ شَّارْقْ، ؤُ خْزَارْ، أَمَانْ تَّازّْڒنْ زِي ثغْمَارْثْ ن زَّاثْ أَفُوسِي.
\m 
\v 3 \add ؤُمِي\add* د-إِفّغْ ورْيَازْ غَارْ شَّارْقْ، ثُوغَا غَارسْ أَفِيڒُو ن ڒعْبَارْ ذڭْ ؤُفُوسْ نّسْ ؤُشَا إِعْبَارْ أَڒفْ ن إِغَادْجنْ. إِسّژْوَا أَيِي خْ وَامَانْ ؤُشَا أَمَانْ \add إِوْضنْ\add* أَڒْ ثِيشعْبِينْ.
\v 4 إِعْبَارْ \add عَاوذْ\add* أَڒفْ \add ن إِغَادْجنْ\add* ؤُشَا إِسّژْوَا أَيِي خْ وَامَانْ ؤُشَا أَمَانْ إِوْضنْ أَڒْ  إِفَادّنْ. \add عَاوذْ\add* إِعْبَارْ أَڒفْ \add ن إِغَادْجنْ\add* ؤُشَا إِسّژْوَا أَيِي عَاذْ كْثَارْ ؤُشَا أَمَانْ إِوْضنْ أَڒْ ثِيجْعِينَّاثِينْ.
\v 5 إِعْبَارْ \add ثْوَاڒَاثْ نّغْنِي\add* أَڒفْ \add ن إِغَادْجنْ\add* ؤُشَا \add أَمَانْ\add* ذوْڒنْ ذ إِجّْ ن إِغْزَارْ وَارْ زْمِيرغْ أَذْ ث ژْوِيغْ \add خْ إِضَارنْ\add*، مَاغَارْ أَمَانْ ڭعّْذنْ أَڒَامِي ثُوغَا إِتّْخصَّا أَذْ إِعُومّْ بْنَاذمْ، أَقَا-ث ذ إِجّْ ن إِغْزَارْ إِ وَارْ إِزمَّارْ حذْ أَذْ ث إِژْوَا \add خْ إِضَارنْ\add*.
\m 
\v 6 نتَّا إِنَّا أَيِي: ”مَا ثژْرِيذْ ت، \add أَ\add* مِّيسْ ن بْنَاذمْ؟“ \add خنِّي\add* إِنْذهْ أَيِي أَمْ ڭُّورغْ نّشْ ؤُشَا يَارَّا أَيِي غَارْ ثْمَا ن إِغْزَارْ.
\v 7 \add ؤُمِي\add* د-ذوْڒغْ نشّْ، خْزَارْ، \add بدّنْثْ ذِينْ\add* أَطَّاسْ ن ثْشجُّورَا خْ ثْمَا ن إِغْزَارْ، أَمْ غَارْ ثْمَا-يَا أَمْ غَارْ ثْمَا نِّي. \x ◘ \xo 47:‏7 \xt أَسَا. 22‏:‏2\x*
\v 8 \add خنِّي\add* إِنَّا أَيِي: ”أَمَانْ-أَ تَّازّْڒنْ غَارْ جِّيهثْ ن شَّارْقْ ؤُشَا هكّْوَانْ غَارْ ڒوْضَا ؤُشَا تَّاكّْوَاضنْ غَارْ ڒبْحَارْ \add إِمُّوثنْ\add*. \add خنِّي\add* تَّازّْڒنْ ذِي ڒبْحَارْ ؤُشَا أَذْ تّْوَاسّْڭّنْفَانْ أَمَانْ \add عَاوذْ\add*.
\v 9 أَذْ إِمْسَارْ، بلِّي كُوڒْ ڒعْمَارْ إِ ذِينْ إِتّنْهزَّانْ أَذْ إِدَّارْ، مَانِي مَا إِ د غَا \add يْ\add*أَوْضنْ ثْنَاينْ ن إِغزْرَانْ. أَذْ \add ذِينْ\add* إِڒِينْ إِسڒْمَانْ أَطَّاسْ، مِينْزِي أَمَانْ-أَ تَّازّْڒنْ ذِينِّي ؤُشَا أَذْ تّْوَاسّْڭنْفَانْ \add وَامَانْ ن ڒبْحَارْ\add*. مَانِي مَا إِ د غَا يَاسْ يغْزَارْ-أَ، أَذْ ذِينْ ثِيڒِي ثُوذَارْثْ.
\v 10 أَذْ إِمْسَارْ بلِّي أَذْ إِڒِينْ إِيمَّارنْ ن إِسڒْمَانْ زِي عَايْنْ-جَاذْيِي أَڒْ عَايْنْ-عِيڭْلَايِيمْ. أَذْ ذِينْ إِڒِينْ إِمُوشَانْ إِ ؤُجفَّافْ ن ثْرَاشَّاوِينْ. أَسْڒمْ نْسنْ أَذْ يِيڒِي عْلَاحْسَابْ مَارْكَا نّسْ، أَمْ وسْڒمْ ن ڒبْحَارْ أَمقّْرَانْ، أَطَّاسْ س وَاطَّاسْ،
\v 11 \add مَاشَا\add* ثِينْذَاثْ نّسْ ذ إِيڒْمَامنْ نّسْ وَارْ تّْوَاڭّنْفَانْ، أَذْ قِّيمنْ مدْجْحنْ.
\v 12 غَارْ يغْزَارْ، خْ ثْمَا نّسْ، خْ ثْمَا-يَا ؤُ خْ ثْمَا نِّي، أَذْ إِڒِينْ عْڒَامْ كُوڒْ ثِيشجُّورَا، مَاحنْذْ أَذْ زَّايْسنْثْ شّنْ، ثِينِّي ؤُمِي ثَافَارْثْ نْسنْثْ وَارْ ثتِّيسْڒَاوْ ؤُ ڒْغِيدْجثْ نْسنْثْ وَارْ ث قطِّي شَا. كُوڒْ أَيُورْ أَذْ وْشنْثْ ڒْغِيدْجثْ ذ طّْرِي، مَاغَارْ أَمَانْ ن \add يغْزَارْ\add* فّْغنْ-د زِي زَّاوشْثْ إِقدّْسنْ. ڒْغِيدْجثْ نْسنْثْ أَذْ ثِيڒِي إِ مَاشَّا ذ ثَافَارْثْ نْسنْثْ إِ ؤُڭنْفُو.“ \x ◘ \xo 47:‏12 \xt أَسَا. 22‏:‏2\x*
\b
\s1 إِيْمِيرنْ ذ ؤُبطُّو ن ثمُّورْثْ
\m 
\v 13 ”أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ’وَا \add أَذْ يِيڒِي\add* ذ أَيْمِيرْ إِ خْ إِ غَا ثوْشِيمْ ثَامُّورْثْ ذ ڒْوَارْثْ إِ ثنْعَاشْ ن ثْقبَّاڒْ ن إِسْرَائِيل. يُوسُوفْ أَذْ إِكْسِي ثْنَاينْ ن ثْسقَّارْ.
\v 14 كنِّيوْ أَذْ ت ثْوَارْثمْ، إِجّْ أَمْ ونّغْنِي، إِ ؤُيَا سّْڭعّْذغْ أَفُوسْ إِنُو \add ؤُشَا جُّودْجغْ\add* أَذْ ت وْشغْ إِ ڒجْذُوذْ نْومْ. ثَامُّورْثْ-أَ أَذْ ثِيڒِي ذ ثَاسْغَارْثْ نْومْ. \x ◘ \xo 47:‏14 \xt أَمز. 12‏:‏7؛ 17‏:‏8؛ 26‏:‏3؛ 28‏:‏13\x*
\v 15 وَا \add أَذْ يِيڒِي\add* ذ أَيْمِيرْ ن ثمُّورْثْ: غَارْ ؤُغزْذِيسْ ن شَّامَالْ، زِي ڒبْحَارْ أَمقّْرَانْ خْ وبْرِيذْ غَارْ حِيثْلُونْ أَڒْ د-ثُوسِيذْ غَارْ صَاذَاذْ،
\v 16 \add خنِّي غَارْ\add* حَامَاثْ، بَايْرُوثَا، سِيبْرَايِيمْ نِّي يدْجَا جَارْ ويْمِيرْ \add ن ثمُّورْثْ ن\add* ذِيمَاشْقْ ذ ويْمِيرْ \add ن ثمُّورْثْ ن\add* حَامَاثْ، \add خنِّي غَارْ\add* حَاصْرْ-هَاثِيخُونْ نِّي يدْجَا غَارْ ويْمِيرْ ن حَاوْرَانْ.
\v 17 زِي ڒبْحَارْ أَذْ د-إِفّغْ ويْمِيرْ غَارْ حَاسْرْ-عَايْنُونْ، \add خْ ؤُغزْذِيسْ ن\add* ويْمِيرْ ن ذِيمَاشْقْ ؤُشَا \add خنِّي\add* غَارْ شَّامَالْ، غَارْ شَّامَالْ ؤُ \add خْ ؤُغزْذِيسْ ن\add* ويْمِيرْ ن حَامَاثْ. وَا أَذْ يِيڒِي ذ أَغزْذِيسْ ن شَّامَالْ.
\m 
\v 18 أَغزْذِيسْ ن شَّارْقْ \add إِتّكّْ\add* زِي جَارْ حَاوْرَانْ ذ ذِيمَاشْقْ ؤُ زِي جَارْ جِيلْعَاذْ ذ ثمُّورْثْ ن إِسْرَائِيل \add خْ\add* لْ-ؤُرْذُونْ. كنِّيوْ أَذْ ث ثْعبَّارمْ زڭْ ويْمِيرْ أَڒْ ڒبْحَارْ ن شَّارْقْ. وَا \add أَذْ يِيڒِي\add* ذ أَغزْذِيسْ ن شَّارْقْ.
\m 
\v 19 أَغزْذِيسْ ن لْجَانُوبْ، أَقَا-ث غَارْ لْجَانُوبْ زِي ثَامَارْ أَڒْ أَمَانْ ن مَارِيبُوثْ-قَاذَاشْ \add ؤُشَا إِتّكّْ خْ\add* ثغْزُورْثْ ن ثغْزَارْثْ \add ن مِيصْرَا\add* أَڒْ ڒبْحَارْ أَمقّْرَانْ. وَا أَذْ يِيڒِي ذ أَغزْذِيسْ ن لْجَانُوبْ غَارْ لْجَانُوبْ.
\m 
\v 20 أَغزْذِيسْ ن ڒْغَارْبْ ذ ڒبْحَارْ أَمقّْرَانْ، زڭْ ويْمِيرْ \add نِّي إِدْجَانْ غَارْ لْجَانُوبْ\add* أَڒْ أَرنْذَاذْ ن وبْرِيذْ غَارْ حَامَاثْ، وَا أَذْ يِيڒِي ذ أَغزْذِيسْ ن لْغَارْبْ.‘ “
\b
\m 
\v 21 ”أَذْ ثبْضَامْ ثَامُّورْثْ-أَ جَارْ أَومْ عْلَاحْسَابْ ثِيقبَّاڒْ ن إِسْرَائِيل.
\v 22 كنِّيوْ أَذْ ت جّنْ ذ ڒْوَارْثْ إِ كنِّيوْ ؤُ إِ إِبَارَّانِييّنْ ذِي ڒْوسْطْ نْومْ، إِنِّي ؤُرْونْ إِحنْجِيرنْ ذِي ڒْوسْطْ نْومْ. نِيثْنِي أَذْ أَومْ إِڒِينْ أَمْ يِينِّي د-إِتّْوَاخڒْقنْ ذِي ثمُّورْثْ جَارْ أَيْثْ ن إِسْرَائِيل. أَذْ أَسنْ ثِيڒِي ثَاسْغَارْثْ أَكِيذْومْ ذِي ڒْوسْطْ ن ثْقبَّاڒْ ن إِسْرَائِيل.
\v 23 غَارْ ثقْبِيتْشْ إِ غَارْ غَا إِزْذغْ أَمْ ؤُبَارَّانِي، ذِينْ أَذْ أَسْ ثوْشمْ ثَاسْغَارْثْ نّسْ! \add أَمُّو إِ\add* غَا ثِيڒِي، إِقَّارْ سِيذِي إِنُو، سِيذِي.‘ “
\b
\b
\c 48
\m 
\v 1 ”إِنَا ذ إِسْمَاونْ ن ثْقبَّاڒْ.
\b
\m زِي طَّارْفْ ن شَّامَالْ قَاعْ، خْ وبْرِيذْ ن حِيثْلُونْ أَڒَامِي غَا ثَاوْضذْ غَارْ حَامَاثْ، حَاصَارْ-عِينَانْ، ثَامُّورْثْ ن ويْمِيرْ ن ذِيمَاشْقْ، خْ ؤُغزْذِيسْ ن شَّامَالْ نْ حَامَاثْ ؤُمِي خَاسْ ثتّكّذْ: أَذْ أَسْ يِيڒِي أَمْ ؤُغزْذِيسْ ن شَّارْقْ أَمْ ؤُغزْذِيسْ ن ڒبْحَارْ، إِشْثْ \add ن ثسْغَارْثْ إِ\add* دَان.
\m 
\v 2 خْ ويْمِيرْ ن ذَانْ، زڭْ ؤُغزْذِيسْ ن شَّارْقْ أَڒْ ڒبْحَارْ:
\m إِشْثْ \add ن ثسْغَارْثْ إِ\add* أَشِيرْ.
\m 
\v 3 خْ ويْمِيرْ ن أَشِيرْ، زڭْ ؤُغزْذِيسْ ن شَّارْقْ أَڒْ ڒبْحَارْ:
\m إِشْثْ \add ن ثسْغَارْثْ إِ\add* نَافْثَالِي.
\m 
\v 4 خْ ويْمِيرْ ن نَافْثَالِي، زڭْ ؤُغزْذِيسْ ن شَّارْقْ أَڒْ ڒبْحَارْ:
\m إِشْثْ \add ن ثسْغَارْثْ إِ\add* مَانَاسَّا.
\m 
\v 5 خْ ويْمِيرْ ن مَانَاسَّا، زڭْ ؤُغزْذِيسْ ن شَّارْقْ أَڒْ ڒبْحَارْ:
\m إِشْثْ \add ن ثسْغَارْثْ إِ\add* إِفْرَايِيمْ.
\m 
\v 6 خْ ويْمِيرْ ن إِفْرَايِيمْ، زڭْ ؤُغزْذِيسْ ن شَّارْقْ أَڒْ ڒبْحَارْ:
\m إِشْثْ \add ن ثسْغَارْثْ إِ\add* رُوبِينْ.
\m 
\v 7 خْ ويْمِيرْ ن رُوبِينْ، زڭْ ؤُغزْذِيسْ ن شَّارْقْ أَڒْ ڒبْحَارْ:
\m إِشْثْ \add ن ثسْغَارْثْ إِ\add* يَاهُوذَا.
\b
\m 
\v 8 خْ ويْمِيرْ ن يَاهُوذَا، زڭْ ؤُغزْذِيسْ ن شَّارْقْ أَڒْ ثْمَا ن ڒبْحَارْ، \add أَذْ ثِيڒِي\add* \bd ثوْهِيبْثْ ن ؤُسْڭعّذْ\bd*، ثنِّي إِ غَا ثْوهّْبمْ، س إِشْثْ ن ثِيرُو ن خمْسَا ؤُ-عِيشْرِينْ-أَڒفْ \add ن إِغُونَامْ ن ڒعْبَارْ\add* ؤُ س إِشْثْ ن ثُوزّڭَّارْثْ أَمْ \add ثُوزّڭَّارْثْ ن\add* إِشْثنْ زِي ثْسقَّارْ \add إِنّغْنِي\add* زڭْ ؤُغزْذِيسْ ن شَّارْقْ أَڒْ ثْمَا ن ڒبْحَارْ. زَّاوشْثْ إِقدّْسنْ أَذْ ثِيڒِي ذِي ڒْوسْثْ نّسْ.
\b
\m 
\v 9 ثَاوْهِيبْثْ ن ؤُسْڭعّذْ إِ سِيذِي نِّي إِ غَا ثسّْڭعّْذمْ، \add أَذْ ثِيڒِي\add* س إِشْثْ ن ثُوزّڭَّارْثْ ن خمْسَا ؤُ-عِيشْرِينْ-أَڒفْ \add ن إِغُونَامْ ن ڒعْبَارْ\add* ؤُ س إِشْثْ ن ثِيرُو نعشْرَا-أَڒَافْ \add ن إِغُونَامْ ن ڒعْبَارْ\add*.
\b
\m 
\v 10 ثَاوْهِيبْثْ إِقدّْسنْ ن ؤُسْڭعّذْ أَذْ ثِيڒِي إِ إِنَا:
\b
\m إِ إِكهَّاننْ: غَارْ شَّامَالْ خمْسَا ؤُ-عِيشْرِينْ-أَڒفْ \add ن إِغُونَامْ ن ڒعْبَارْ\add*، ؤُ غَارْ ڒْغَارْبْ ثِيرُو \add نّسْ\add*عشْرَا-أَڒَافْ \add ن إِغُونَامْ ن ڒعْبَارْ\add*، ؤُ غَارْ شَّارْقْ ثِيرُو \add نّسْ\add*عشْرَا-أَڒَافْ \add ن إِغُونَامْ ن ڒعْبَارْ\add*، ؤُ غَارْ لْجَانُوبْ ثُوزّڭَّارْثْ \add نّسْ\add* خمْسَا ؤُ-عِيشْرِينْ-أَڒفْ \add ن إِغُونَامْ ن ڒعْبَارْ\add*. زَّاوشْثْ إِقدّْسنْ ن سِيذِي أَذْ ثِيڒِي ذِي ڒْوسْثْ نّسْ.
\m 
\v 11 \add أَذْ ثِيڒِي\add* ثمُّورْثْ-أَ إِقدّْسنْ إِ إِكهَّاننْ زڭْ أَيْثْ ن صَاذُوقْ، إِنِّي إِحْضَانْ أَحطُّو إِنُو، إِنِّي وَارْ د-إِفّْغنْ شَا زڭْ وبْرِيذْ زِي سِّيبّثْ ن ؤُودَّارْ ن أَيْثْ ن إِسْرَائِيل، أَمْ فّْغنْ ؤُڒَا ذ أَيْثْ ن لَاوِي.
\v 12 أَذْ ثِيڒِي ذ إِشْثْ ن ثوْهِيبْثْ ن ؤُسْڭعّذْ إِ نِيثْنِي زِي ثوْهِيبْثْ ن ثمُّورْثْ، أَذْ ثِيڒِي ثْقدّسْ قَاعْ، \add أَذْ ثِيڒِي\add* خْ ويْمِيرْ ن إِلَاوِييّنْ.
\b
\m 
\v 13 غَارْ ويْمِيرْ أَكْ-ذ إِكهَّاننْ \add أَذْ غَارْسنْ ثِيڒِي\add* إِ إِلَاوِييّنْ \add إِشْثْ ن ثمُّورْثْ\add* س إِشْثْ ن ثُوزّڭَّارْثْ ن خمْسَا ؤُ-عِيشْرِينْ أَڒفْ \add ن إِغُونَامْ ن ڒعْبَارْ\add*، س إِشْثْ ن ثِيرُو نعشْرَا-أَڒَافْ \add ن إِغُونَامْ ن ڒعْبَارْ\add*. مَارَّا ثُوزّڭَّارْثْ \add أَذْ ثِيڒِي\add* خمْسَا ؤُ-عِيشْرِينْ-أَڒفْ \add ن إِغُونَامْ ن ڒعْبَارْ\add*، ؤُ ثِيرُو نّسْ \add أَذْ ثِيڒِي عَاوذْ\add*عشْرَا-أَڒَافْ \add ن إِغُونَامْ ن ڒعْبَارْ\add*.
\v 14 وَارْ إِعدّڒْ أَذْ زّنْزنْ ؤُڒَا ذ شَا زَّايسْ، وَارْ إِعدّڒْ أَذْ \add ت\add* بدّْڒنْ نِيغْ أَذْ \add ت\add* سّعْذُونْ، \add أَقَا-ت\add* ذ ڒمْخيّرْ ن ثمُّورْثْ، مِينْزِي أَقَا-ت ذ ثَامْقدَّاسْثْ قَاعْ.
\b
\m 
\v 15 خمْسَا-أَڒَافْ \add ن إِغُونَامْ ن ڒعْبَارْ\add* نِّي إِ غَا إِقِّيمنْ غَارْ ثِيرُو، غَارْ زَّاثْ ن خمْسَا ؤُ-عِيشْرِينْ-أَڒفْ \add ن إِغُونَامْ ن ڒعْبَارْ\add*، أَذْ إِڒِينْ إِ ثُوذَارْثْ ن كُوڒْ أَسّْ ذِي ثنْذِينْثْ، إِ ثْزذِّيغْثْ ؤُ إِ دّْمَانِي ن ثَاروْسَا. أَذْ ثِيڒِي ثنْذِينْثْ ذِي ڒْوسْطْ نّسْ.
\m 
\v 16 إِنَا أَذْ إِڒِينْ ذ ڒعْبُورَاثْ نّسْ: غَارْ ؤُغزْذِيسْ ن شَّامَالْ خمْسَا ؤُ-ربْعِينْ-مْيَا \add ن إِغُونَامْ ن ڒعْبَارْ\add*، غَارْ ؤُغزْذِيسْ ن لْجَانُوبْ خمْسَا ؤُ-ربْعِينْ-مْيَا \add ن إِغُونَامْ ن ڒعْبَارْ\add*، غَارْ ؤُغزْذِيسْ ن شَّارْقْ خمْسَا ؤُ-ربْعِينْ-مْيَا \add ن إِغُونَامْ ن ڒعْبَارْ\add*، غَارْ ؤُغزْذِيسْ ن ڒبْحَارْ خمْسَا ؤُ-ربْعِينْ-مْيَا \add ن إِغُونَامْ ن ڒعْبَارْ\add*. \f ◼ \fr 48:‏16 \ft \bd ’غَارْ ؤُغزْذِيسْ ن ڒبْحَارْ‘\bd* - نِيغْ ’غَارْ ؤُغزْذِيسْ ن ڒْغَارْبْ‘.\f*
\m 
\v 17 دّْمَانِي ن ثَاروْسَا ن ثنْذِينْثْ: غَارْ شَّامَالْ أَذْ إِڒِينْثْ مِيثَاينْ ؤُ-خمْسِينْ \add نْ  إِغُونَامْ ن ڒعْبَارْ\add*، غَارْ لْجَانُوبْ مِيثَاينْ ؤُ-خمْسِينْ \add نْ  إِغُونَامْ ن ڒعْبَارْ\add*، غَارْ شَّارْقْ مِيثَاينْ ؤُ-خمْسِينْ \add نْ  إِغُونَامْ ن ڒعْبَارْ\add*، غَارْ ڒْغَارْبْ مِيثَاينْ ؤُ-خمْسِينْ \add نْ  إِغُونَامْ ن ڒعْبَارْ\add*.
\m 
\v 18 مِينْ إِقِّيمنْ زِي ثُوزّڭَّارْثْ غَارْ زَّاثْ ن ثوْهِيبْثْ إِقدّْسنْ ن ؤُسْڭعّذْ،عشْرَا-أَڒَافْ \add ن إِغُونَامْ ن ڒعْبَارْ\add* غَارْ شَّارْقْ ذعشْرَا-أَڒَافْ \add نْ  إِغُونَامْ ن ڒعْبَارْ\add* غَارْ ؤُغزْذِيسْ نْ ڒْغَارْبْ، أَذْ يِيڒِي زَّاثْ \add ن ثمُّورْثْ\add* ن ثوْهِيبْثْ إِقدّْسنْ ن ؤُسْڭعّذْ. صَّابثْ نّسْ أَذْ ثِيڒِي ذ مَاشَّا إِ إِمْسخَّارنْ ن ثنْذِينْثْ.
\v 19 إِمْسخَّارنْ ن ثنْذِينْثْ، أَقَا أَذْ ت سخَّارنْ زِي مَارَّا ثِيقبَّاڒْ ن إِسْرَائِيل.
\b
\m 
\v 20 مَارَّا ثَاوْهِيبْثْ ن ؤُسْڭعّذْ \add أَذْ ثِيڒِي\add* خمْسَا ؤُ-عِيشْرِينْ-أَڒفْ خْ خمْسَا ؤُ-عِيشْرِينْ-أَڒفْ \add ن إِغُونَامْ ن ڒعْبَارْ\add*. أَذْ سّْڭعّْذنْ ثَاوْهِيبْثْ ن ؤُسْڭعّذْ ذ إِجّْ ن ؤُكْوَاذْرُونْ أَكْ-ذ ثسْغَارْثْ ن ثنْذِينْثْ \add إِ ذَايسْ\add*.
\b
\m 
\v 21 مِينْ إِقِّيمنْ أَذْ يِيڒِي إِ ڒْحَاكمْ، غَارْ إِجّْ ن ؤُغزْذِيسْ ؤُ غَارْ ؤُغزْذِيسْ نّغْنِي ن ثوْهِيبْثْ إِقدّْسنْ ن ؤُسْڭعّذْ ؤُ ن ثسْغَارْثْ ن ثنْذِينْثْ. \add مِينْ إِدْجَانْ\add* غَارْ ؤُغزْذِيسْ ن زَّاثْ ن خمْسَا ؤُ-عِيشْرِينْ-أَڒفْ \add ن إِغُونَامْ ن ڒعْبَارْ\add* ن ثوْهِيبْثْ ن ؤُسْڭعّذْ أَڒْ أَيْمِيرْ ن شَّارْقْ، ؤُ غَارْ ؤُغزْذِيسْ ن ڒْغَارْبْ غَارْ زَّاثْ ن خمْسَا ؤُ-عِيشْرِينْ-أَڒفْ \add ن إِغُونَامْ ن ڒعْبَارْ\add* أَڒْ أَيْمِيرْ ن ڒْغَارْبْ غَارْ ڒبْحَارْ، زَّاثْ إِ ثْسقَّارْ نّغْنِي \add ن ثمُّورْثْ\add*، \add ذ مَانْ أَيَا أَذْ يِيڒِي\add* إِ ڒْحَاكمْ.
\b
\m أَذْ ثِيڒِي ذ إِشْثْ ن ثوْهِيبْثْ إِقدّْسنْ \add ن ثمُّورْثْ\add* نِّي إِ غَا سّْڭعّْذنْ، ؤُ زَّاوشْثْ إِقدّْسنْ ن ثَادَّارْثْ أَذْ ثِيڒِي ذِي ڒْوسْثْ نّسْ.
\v 22 زِي \add مِينْ إِدْجَانْ ذ\add* ثَاسْغَارْثْ ن إِلَاوِييّنْ ؤُ \add زِي مِينْ إِدْجَانْ ذ\add* ثَاسْغَارْثْ ن ثنْذِينْثْ نِّي \add إِدْجَانْ\add* ذِي ڒْوسْطْ ن مِينْ غَا يِيڒِي إِ ڒْحَاكمْ، أَذْ يِيڒِي \add مَارَّا\add* مِينْ إِدْجَانْ جَارْ ثمُّورْثْ ن يَاهُوذَا ذ ثمُّورْثْ ن بِينْيَامِينْ، إِ ڒْحَاكمْ.
\b
\m 
\v 23 مِينْ إِقِّيمنْ ن ثْقبَّاڒْ زڭْ ؤُغزْذِيسْ ن شَّارْقْ أَڒْ ڒبْحَارْ:
\m إِشْثْ \add ن ثسْغَارْثْ\add* إِ بِينْيَامِينْ.
\m 
\v 24 خْ ويْمِيرْ ن بِينْيَامِينْ، زڭْ ؤُغزْذِيسْ ن شَّارْقْ أَڒْ ڒبْحَارْ:
\m إِشْثْ \add ن ثسْغَارْثْ إِ\add* شِيمْعُونْ.
\m 
\v 25 خْ ويْمِيرْ ن شِيمْعُونْ، زڭْ ؤُغزْذِيسْ ن شَّارْقْ أَڒْ ڒبْحَارْ:
\m إِشْثْ \add ن ثسْغَارْثْ إِ\add* إِسَّاكَارْ.
\m 
\v 26 خْ ويْمِيرْ ن إِسَّاكَارْ، زڭْ ؤُغزْذِيسْ ن شَّارْقْ أَڒْ ڒبْحَارْ:
\m إِشْثْ \add ن ثسْغَارْثْ إِ\add* زابُولُونْ.
\m 
\v 27 خْ ويْمِيرْ ن زابُولُونْ، زڭْ ؤُغزْذِيسْ ن شَّارْقْ أَڒْ ڒبْحَارْ:
\m إِشْثْ \add ن ثسْغَارْثْ إِ\add* جَاذْ.
\m 
\v 28 خْ ويْمِيرْ ن جَاذْ، غَارْ ؤُغزْذِيسْ ن لْجَانُوبْ ذِي جِّيهثْ ن لْجَانُوبْ، أَذْ يِيڒِي ويْمِيرْ زِي ثَامَارْ أَڒْ أَمَانْ ن مَارِيبَا-قَاذَاشْ، \add خنِّي أَذْ يكّْ\add* خْ ثغْزَارْثْ \add ن مِيصْرَا\add* أَڒْ ڒبْحَارْ أَمقّْرَانْ.
\b
\m 
\v 29 ثَا ذ ثمُّورْثْ نِّي إِتّْخصَّا كنِّيوْ أَذْ ت ثبْضَامْ ذ ثَاسْغَارْثْ ن ڒْوَارْثْ إِ ثْقبَّاڒْ ن إِسْرَائِيل ؤُ ثِينَا ذ ثِيسقَّارْ نْسنْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي.“ *
\b
\s1 ثَانْذِينْثْ إِقدّْسنْ
\m 
\v 30 ”ذ يِينَا إِ غَا يِيڒِينْ ذ \bd ؤُفُّوغنْ ن ثنْذِينْثْ\bd*:
\b
\m \bd غَارْ شَّامَالْ\bd* \add أَقَا ذِينْ\add* خمْسَا ؤُ-ربْعِينْ-مْيَا ن ڒعْبُورَاثْ.
\v 31 ثِيوُّورَا ن ثنْذِينْثْ \add أَذْ تّْوَاڒَاغَانْثْ\add* عْلَاحْسَابْ إِسْمَاونْ ن ثْقبَّاڒْ ن إِسْرَائِيل: ثْڒَاثَا ن ثوُّورَا \add أَذْ إِڒِينْثْ\add* غَارْ شَّامَالْ: إِشْثنْ ن رُوبِينْ، إِشْثنْ ن يَاهُوذَا، إِشْثنْ ن لَاوِي.
\m 
\v 32 \bd غَارْ ؤُغزْذِيسْ ن شَّارْقْ\bd* \add أَقَا ذِينْ\add* خمْسَا ؤُ-ربْعِينْ-مْيَا ن ڒعْبُورَاثْ، \add أَكْ-ذ\add* ثْڒَاثَا ن ثوُّورَا: إِشْثنْ ن يُوسُوفْ، إِشْثنْ ن بِينْيَامِينْ، إِشْثنْ ن دَان.
\m 
\v 33 \bd غَارْ ؤُغزْذِيسْ ن لْجَانُوبْ\bd* \add أَقَا ذِينْ\add* خمْسَا ؤُ-ربْعِينْ-مْيَا ن ڒعْبُورَاثْ، \add أَكْ-ذ\add* ثْڒَاثَا ن ثوُّورَا: إِشْثنْ ن شِيمْعُونْ، إِشْثنْ ن إِسَّاكَارْ، إِشْثنْ ن زابُولُونْ.
\m 
\v 34 \bd غَارْ ؤُغزْذِيسْ ن ڒْغَارْبْ\bd* \add أَقَا ذِينْ\add* خمْسَا ؤُ-ربْعِينْ-مْيَا \add ن ڒعْبُورَاثْ\add*، \add أَكْ-ذ\add* ثْڒَاثَا ن ثوُّورَا نْسنْ: إِشْثنْ ن جَاذْ، إِشْثنْ ن أَشِيرْ، إِشْثنْ ن نَافْثَالِي.
\b
\m 
\v 35 \add ڒعْبَارْ\add* ذڭْ ونّضْ \add ن ثنْذِينْثْ\add* \add أَقَا-ث\add* ذِي ثْمنْطَاشْ-أَڒفْ \add ن ڒعْبُورَاثْ\add* ؤُ زڭْ وَاسّْ \add نِّي\add* أَذْ يِيڒِي يِيسمْ ن ثنْذِينْثْ ذ وَا:
\b
\m \bd ’سِيذِي \bdit أَقَا-ث\bdit* ذِينْ!‘\bd* “ 
