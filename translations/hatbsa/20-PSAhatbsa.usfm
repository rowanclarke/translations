\id PSA  
\h Sòm Yo 
\toc1 SÒM YO 
\toc2 Sòm Yo 
\toc3 Sòm 
\mt1 SÒM YO  
\c 1  
\ms1 Liv I  
\q1
\v 1 Beni se nonm ki \x + \xo 1:1 \xt Pwov 4:14\x*pa mache nan konsèy  
\q1 mechan yo  
\q1 ni kanpe nan pa pechè yo, ni chita nan chèz mokè yo,   
\q1
\v 2 men \x + \xo 1:2 \xt Sòm 119:14-35\x*gran plezi li se \x + \xo 1:2 \xt Jos 1:8\x*nan lalwa SENYÈ a.  
\q1 Sou lalwa Li, li reflechi lajounen kon lannwit.   
\q1
\v 3 Li va tankou yon \x + \xo 1:3 \xt Sòm 92:12-14\x*pyebwa ki plante  
\q1 bò kote flèv dlo ki bay fwi li nan sezon li.  
\q1 Fèy li p ap janm fane, e tout sa li fè byen reyisi.   
\q1
\v 4 Mechan yo pa konsa.  
\q1 Yo tankou \x + \xo 1:4 \xt Sòm 5:5\x*pay ke van an pouse ale.   
\q1
\v 5 Pou sa, mechan yo p ap kanpe nan chèz \x + \xo 1:5 \xt Sòm 9:7,8,16\x*jijman an,  
\q1 ni pechè yo nan asanble ak moun dwat yo.   
\q1
\v 6 Paske SENYÈ a \x + \xo 1:6 \xt Na 1:7\x*konnen chemen  
\q1 a sila ki dwat yo,  
\q1 men chemen a mechan yo va disparèt.   
\c 2  
\q1
\v 1 Poukisa nasyon yo ap boulvèse konsa,  
\q1 e pèp yo fòmante yon vye bagay?   
\q1
\v 2 Wa latè yo pran pòz yo e chèf yo  
\q1 pran konsèy ansanm kont SENYÈ a,  
\q1 e \x + \xo 2:2 \xt Jn 1:41\x*kont onksyone pa Li a:   
\q1
\v 3 “Annou \x + \xo 2:3 \xt Jr 5:5\x*chire chenn sa yo,  
\q1 e jete kòd ki mare nou yo!”   
\q1
\v 4 Sila ki chita nan syèl la \x + \xo 2:4 \xt Sòm 37:13\x*ri;  
\q1 SENYÈ a ap moke yo.   
\q1
\v 5 Anplis, Li va pale avèk yo nan \x + \xo 2:5 \xt Sòm 21:8-9\x*kòlè Li.  
\q1 Li va fè yo sezi nan kòlè Li.   
\q1
\v 6 Men pou Mwen menm,  
\q1 Mwen fin plase Wa Mwen an sou Sion,  
\q1 \x + \xo 2:6 \xt Sòm 48:1-2\x*mòn sen Mwen an.   
\q1
\v 7 Anverite, Mwen va pale selon deklarasyon SENYÈ a;  
\q1 SENYÈ a te di Mwen: “Ou se \x + \xo 2:7 \xt Trav 13:33\x*Fis Mwen.  
\q1 Se jodi a, Mwen te fè Ou.   
\q1
\v 8 Mande Mwen, e Mwen va bay Ou  
\q1 \x + \xo 2:8 \xt Sòm 22:27\x*nasyon yo kon eritaj,  
\q1 jis rive nan \x + \xo 2:8 \xt Sòm 67:7\x*dènye pwent latè  
\q1 kon posesyon pa Ou.   
\q1
\v 9 Ou va \x + \xo 2:9 \xt Rev 2:26-27\x*kase yo avèk yon baton fè,  
\q1 Ou va \x + \xo 2:9 \xt Sòm 28:5\x*kraze yo tankou veso kanari.”   
\q1
\v 10 Konsa, O wa yo, \x + \xo 2:10 \xt Pwov 8:15\x*sèvi ak sajès.  
\q1 Fè atansyon, O jij sou latè yo.   
\q1
\v 11 Adore SENYÈ a avèk gran respè e  
\q1 rejwi avèk \x + \xo 2:11 \xt Sòm 119:119-120\x*tranbleman.   
\q1
\v 12 Fè omaj a Fis la, pou L pa vin fache,  
\q1 epi ou ta mouri nan chemen an.  
\q1 Paske gwo chalè Li kab limen ase vit.  
\q1 A la beni se tout sila ki \x + \xo 2:12 \xt Sòm 5:11\x*kache nan Li.   
\c 3  
\d Yon Sòm a David lè l te sove ale devan Absalom, fis li a  
\q1
\v 1 O SENYÈ, gade kijan \x + \xo 3:1 \xt II Sam 15:12\x*lènmi mwen  
\q1 yo ap miltipliye;  
\q1 Anpil moun leve kont mwen.   
\q1
\v 2 Anpil moun pale de nanm mwen,  
\q1 “Nanpwen \x + \xo 3:2 \xt Sòm 22:7-8\x*delivrans pou li nan Bondye.” \qs Tan\qs*   
\q1
\v 3 Men Ou menm, O SENYÈ, se yon pwotèj ki antoure mwen,  
\q1 glwa mwen, ak Sila ki \x + \xo 3:3 \xt Sòm 27:5\x*fè tèt mwen leve a.   
\q1
\v 4 Mwen t ap kriye a SENYÈ a ak vwa mwen;  
\q1 Li te \x + \xo 3:4 \xt Sòm 4:3\x*reponn mwen soti nan mòn sen Li an \qs Tan\qs*   
\q1
\v 5 Mwen \x + \xo 3:5 \xt Lev 26:6\x*te kouche e dòmi;  
\q1 mwen te leve, paske se SENYÈ a ki ban m fòs.   
\q1
\v 6 Mwen p ap pè menm dè milye de moun  
\q1 ki ta \x + \xo 3:6 \xt Sòm 118:10-13\x*pran pozisyon kont mwen de tout kote.   
\q1
\v 7 Leve, O SENYÈ!  
\q1 Sove mwen, O Bondye mwen!  
\q1 Paske Ou te souflete tout lènmi mwen yo.  
\q1 Ou te \x + \xo 3:7 \xt Sòm 57:4\x*kraze dan a mechan yo.   
\q1
\v 8 \x + \xo 3:8 \xt Sòm 28:8\x*Delivrans se nan SENYÈ a.  
\q1 Ke benediksyon Ou toujou poze sou pèp Ou a.   
\c 4  
\d Pou direktè koral la; sou enstriman ak fil yo; yon sòm David  
\q1
\v 1 Reponn mwen lè m rele Ou, O Bondye ladwati mwen;  
\q1 Ou te fè m pran souf nan gran twoub mwen an.  
\q1 \x + \xo 4:1 \xt Sòm 25:16\x*Fè m gras e tande lapriyè mwen.   
\q1
\v 2 O fis a lòm yo, jiskilè laglwa Mwen va devni yon repwòch?  
\q1 Jiskilè ou va renmen sa ki san valè  
\q1 e \x + \xo 4:2 \xt Sòm 31:18\x*tante twonpe moun? \qs Tan\qs*   
\q1
\v 3 Men konnen ke SENYÈ a te mete nonm Bondye a apa pou Li menm.  
\q1 SENYÈ a \x + \xo 4:3 \xt Sòm 6:8-9\x*tande lè m fè apèl Li.   
\q1
\v 4 Tranble, men \x + \xo 4:4 \xt Ef 4:26\x*pa fè peche.  
\q1 \x + \xo 4:4 \xt Sòm 77:6\x*Reflechi nan kè ou sou kabann ou, e rete kalm. \qs Tan\qs*   
\q1
\v 5 Ofri sakrifis ladwati yo.  
\q1 \x + \xo 4:5 \xt Sòm 37:3-5\x*Mete konfyans nan SENYÈ a.   
\q1
\v 6 Anpil ap di: \x + \xo 4:6 \xt Job 7:7\x*“Kilès ki kab montre nou yon bagay ki bon?”  
\q1 SENYÈ, leve wo limyè a vizaj Ou devan nou!   
\q1
\v 7 Ou te mete \x + \xo 4:7 \xt És 9:3\x*lajwa nan kè m plis pase  
\q1 lè gwo rekòlt sereyal mi ak diven nèf vin parèt.   
\q1
\v 8 Anpè, mwen va kouche pou dòmi,  
\q1 paske Ou sèl, SENYÈ, fè m viv ansekirite.   
\c 5  
\d Pou Direktè koral yo; fèt pou akonpanye ak flit. Yon Sòm David.  
\q1
\v 1 \x + \xo 5:1 \xt Sòm 54:2\x*Prete zòrèy Ou a pawòl mwen yo, O SENYÈ.  
\q1 Konsidere refleksyon mwen yo.   
\q1
\v 2 Koute bri kri sekou mwen yo,  
\q1 \x + \xo 5:2 \xt Sòm 84:3\x*Wa mwen e Bondye mwen.  
\q1 Pou Ou menm, mwen ap priye.   
\q1
\v 3 Nan maten O SENYÈ, Ou va tande vwa mwen.  
\q1 Nan maten mwen va vèse bay Ou lapriyè mwen yo.  
\q1 M ap\x + \xo 5:3 \xt Sòm 130:5\x*tann, m ap veye.   
\q1
\v 4 Paske Ou se pa yon Bondye ki gen plezi nan mechanste.  
\q1 \x + \xo 5:4 \xt Sòm 92:15\x*Nanpwen mal ki rete avèk Ou.   
\q1
\v 5 Sila ki plen ògèy p ap kab kanpe devan zye Ou.  
\q1 \x + \xo 5:5 \xt Sòm 11:5\x*Ou rayi tout sila ki fè inikite yo.   
\q1
\v 6 Ou \x + \xo 5:6 \xt Sòm 52:4-5\x*detwi sila ki pale sa ki fo yo.  
\q1 SENYÈ a rayi yon nonm ki vèse san,  
\q1 ki twonpe moun.   
\q1
\v 7 Men pou mwen, pa gran lanmou  
\q1 dous Ou a mwen va antre lakay Ou.  
\q1 Nan tanp sen Ou an mwen va pwostène  
\q1 mwen nèt an adorasyon.   
\q1
\v 8 O SENYÈ, mennen m \x + \xo 5:8 \xt Sòm 31:1\x*nan ladwati Ou akoz lènmi mwen yo.  
\q1 Fè chemen Ou dwat devan mwen.   
\q1
\v 9 Nanpwen anyen stab nan pawòl pa yo.  
\q1 Anndan yo se pouriti menm.  
\q1 \x + \xo 5:9 \xt Wo 3:13 \x*Gòj yo se yon tonm ki louvri.  
\q1 Yo fè flatè ak lang yo.   
\q1
\v 10 Kenbe yo koupab, O Bondye.  
\q1 Selon pwòp manèv pa yo, kite yo tonbe!  
\q1 Nan fòs kantite peche yo pouse yo deyò, paske se \x + \xo 5:10 \xt Sòm 107:10 \x*rebèl yo ye kont Ou.   
\q1
\v 11 Men kite tout sila ki pran refij nan Ou yo, \x + \xo 5:11 \xt Sòm 64:10\x*fè kè kontan.  
\q1 Kite yo toujou chante ak kè kontan,  
\q1 akoz Ou fè abri pou yo.  
\q1 Kite sila ki renmen non Ou yo kapab  
\q1 fè kè kontan nan Ou.   
\q1
\v 12 Paske se Ou menm ki beni nonm ki dwat la, O SENYÈ,  
\q1 Ou ki \x + \xo 5:12 \xt Sòm 32:7-10\x*antoure li avèk gras Ou,  
\q1 tankou yon boukliye.   
\c 6  
\d Pou direktè koral la; avèk enstriman ak fil yo sou yon gita uit kòd.  
\d Yon sòm David.  
\q1
\v 1 O SENYÈ, \x + \xo 6:1 \xt Sòm 38:1\x*pa repwoche mwen nan kòlè Ou,  
\q1 ni ban m chatiman nan fache Ou.   
\q1
\v 2 Fè m gras, O SENYÈ, paske mwen  
\q1 chagren anpil.  
\q1 \x + \xo 6:2 \xt Os 6:1\x*Geri mwen, O SENYÈ, paske zo m yo rele anmwey,   
\q1
\v 3 epi \x + \xo 6:3 \xt Sòm 88:3\x*nanm mwen fè gwo chagren.  
\q1 Men Ou, O SENYÈ,—jiskilè?   
\q1
\v 4 Retounen, O SENYÈ, \x + \xo 6:4 \xt Sòm 17:13\x*fè nanm mwen chape.  
\q1 Sove mwen akoz lanmou dous Ou a.   
\q1
\v 5 Paske mò yo \x + \xo 6:5 \xt Ekl 9:10\x*pa rele non Ou.  
\q1 Nan andwa kote mò yo ye a,  
\q1 se kilès k ap bay Ou remèsiman?   
\q1
\v 6 Mwen bouke ak plent ki sòti anndan m.  
\q1 Chak nwit, kabann mwen vin naje ak dlo.  
\q1 \x + \xo 6:6 \xt Sòm 42:3\x*Dlo ki sòt nan zye m yo fin gate kabann nan.   
\q1
\v 7 \x + \xo 6:7 \xt Job 17:7\x*Zye m pouri nèt ak gwo doulè.  
\q1 Yo vin vye nèt akoz tout advèsè mwen yo.   
\q1
\v 8 \x + \xo 6:8 \xt Mat 7:23\x*Sòti sou mwen, nou tout ki fè mechanste yo,  
\q1 paske SENYÈ a te tande gwo kri mwen.   
\q1
\v 9 SENYÈ a te tande demand priyè mwen.  
\q1 SENYÈ a \x + \xo 6:9 \xt Sòm 66:19-20\x*te resevwa lapriyè mwen.   
\q1
\v 10 Tout lènmi mwen yo va wont e deranje nèt.  
\q1 Yo va vire fè bak \x + \xo 6:10 \xt Sòm 73:19\x*sibitman.  
\q1 Yo va vin wont anpil.   
\c 7  
\d Yon Sòm David, ke li te chante a SENYÈ a pou yon moun tribi Benjamin ki te rele Cush.  
\q1
\v 1 O SENYÈ Bondye mwen an, \x + \xo 7:1 \xt Sòm 31:1\x*nan Ou mwen kache.  
\q1 Sove mwen de tout sila k ap kouri dèyè m yo e fè m sekou,   
\q1
\v 2 sof ke li ta chire nanm mwen \x + \xo 7:2 \xt Sòm 57:4\x*tankou yon lyon,  
\q1 epi rale m akote pandan pa gen moun pou delivre m.   
\q1
\v 3 O SENYÈ mwen, si mwen menm te fè sa,  
\q1 si gen \x + \xo 7:3 \xt I Sam 24:11\x*enjistis nan men m,   
\q1
\v 4 si mwen te rekonpanse mal a zanmi mwen,  
\q1 oswa te \x + \xo 7:4 \xt I Sam 24:7\x*piyaje sila ki te lènmi mwen a san koz la,   
\q1
\v 5 kite lènmi an kouri dèyè nanm mwen  
\q1 jiskaske li pran l,  
\q1 epi kite li foule lavi mwen jis atè.  
\q1 Fè glwa mwen kouche nèt nan pousyè a. \qs Tan\qs*   
\q1
\v 6 Leve, O SENYÈ, nan kòlè Ou;  
\q1 leve Ou menm kont \x + \xo 7:6 \xt Sòm 138:7\x*raj ladvèsè mwen yo.  
\q1 Leve Ou menm pou mwen;  
\q1 Ou menm ki te etabli jijman an.   
\q1
\v 7 Kite asanble \x + \xo 7:7 \xt Sòm 22:27\x* a tout pèp yo antoure Ou.  
\q1 Gouvènen yo, depi an wo.   
\q1
\v 8 Se SENYÈ a ki jije pèp yo.  
\q1 \x + \xo 7:8 \xt Sòm 18:20\x*Fè m jistis O SENYÈ,  
\q1 selon ladwati mwen ak jan mwen kanpe fèm.   
\q1
\v 9 Alò, mete fen a mechanste malfektè yo,  
\q1 men etabli sila ki dwat yo.  
\q1 Paske se ladwati Bondye ki \x + \xo 7:9 \xt Jr 11:20\x*fè prèv  
\q1 nan kè avèk panse moun.   
\q1
\v 10 Boukliye mwen se avèk Bondye,  
\q1 ki \x + \xo 7:10 \xt Sòm 97:10-11\x*sove sila ki dwat yo.   
\q1
\v 11 Bondye se yon jij ki jis  
\q1 e ki \x + \xo 7:11 \xt Sòm 90:9\x* rayi enjistis chak jou.   
\q1
\v 12 Si yon nonm pa repanti, L ap \x + \xo 7:12 \xt Det 32:41\x*file nepe Li.  
\q1 Li deja koube banza Li; Li prèt.   
\q1
\v 13 Anplis, Li fin prepare pou kont Li zam mòtèl yo.  
\q1 Li fè flèch ak shaf ki brile yo.   
\q1
\v 14 Gade byen, l ap lite nan mechanste.  
\q1 Wi, li plante jèm mechanste a,  
\q1 epi li \x + \xo 7:14 \xt És 59:4\x*vin bay nesans a tout sa ki fo.   
\q1
\v 15 Li te fouye yon twou, kreve l nèt,  
\q1 e vin \x + \xo 7:15 \xt Job 4:8\x*tonbe nan twou ke li te fè a.   
\q1
\v 16 \x + \xo 7:16 \xt Est 9:25\x*Mechanste li va retounen sou pwòp tèt li,  
\q1 e vyolans pa l ap desann sou pwòp fwon li.   
\q1
\v 17 Mwen va bay remèsiman a SENYÈ a \x + \xo 7:17 \xt Sòm 71:15-16\x*selon ladwati Li.  
\q1 Mwen va chante lwanj a non SENYÈ a,Toupwisan an.   
\c 8  
\d Pou direktè koral la; jwe sou gitia la.  
\d Yon sòm David.  
\q1
\v 1 O SENYÈ, Senyè nou an,  
\q1 A la non Ou gran sou tout latè!  
\q1 Ou te \x + \xo 8:1 \xt Sòm 57:5-11\x*fè parèt klè mayifisans Ou  
\q1 piwo pase syèl yo!   
\q1
\v 2 \x + \xo 8:2 \xt Mat 21:16\x*Soti nan bouch a ti bebe ki fenk fèt yo, ak timoun k ap tete yo,  
\q1 Ou te etabli pwisans Ou, akoz advèsè Ou yo,  
\q1 pou fè lènmi an avèk vanjè a sispann.   
\q1
\v 3 Lè m reflechi sou syèl Ou yo, zèv men Ou yo,  
\q1 \x + \xo 8:3 \xt Sòm 136:9\x*lalin ak zetwal ke Ou te fè yo,   
\q1
\v 4 \x + \xo 8:4 \xt Sòm 144:3\x*Kisa lòm nan ye, pou Ou reflechi sou li?  
\q1 Oswa fis a lòm nan, pou Ou pran swen li?   
\q1
\v 5 Malgre, Ou te fè li yon \x + \xo 8:5 \xt Jen 1:26\x*ti kras pi ba pase Bondye,  
\q1 e te kouwone li ak glwa avèk lonè!   
\q1
\v 6 Ou fè li regne sou zèv men Ou yo.  
\q1 Ou \x + \xo 8:6 \xt Ef 1:22\x*te mete tout bagay anba pye li:   
\q1
\v 7 Tout mouton yo ak bèf yo, avèk bèt sovaj nan chan,   
\q1
\v 8 zwazo nan syèl yo, avèk pwason lanmè yo,  
\q1 ak tout sa ki pase nan chemen lanmè yo.   
\q1
\v 9 O SENYÈ, mèt nou an, a la non Ou gran sou tout latè a.   
\c 9  
\d Pou direktè koral la; Yon sòm David  
\q1
\v 1 Mwen va bay remèsiman a SENYÈ a ak \x + \xo 9:1 \xt Sòm 86:12\x*tout kè m;  
\q1 Mwen va pale tout mèvèy Ou yo.   
\q1
\v 2 Mwen va fè kè kontan e rejwi nan Ou;  
\q1 Mwen va chante lwanj non Ou, O \x + \xo 9:2 \xt Sòm 83:18\x*Pi Wo a.   
\q1
\v 3 Lè lènmi m yo vire fè bak, yo \x + \xo 9:3 \xt Sòm 27:2\x*tonbe e peri devan Ou.   
\q1
\v 4 Paske Ou te bay soutyen a dwa m,  
\q1 avèk koz mwen ki jis;  
\q1 Ou chita sou twòn Ou e fè jijman avèk ladwati.   
\q1
\v 5 Ou te fè chatiman nasyon yo;  
\q1 Ou te detwi mechan yo;  
\q1 Ou te \x + \xo 9:5 \xt Sòm 69:28\x*efase non yo jis pou tout tan e pou tout tan.   
\q1
\v 6 Lènmi an te rive a nan fen, e li te kraze nèt.  
\q1 Ou te dechouke vil yo, jiskaske \x + \xo 9:6 \xt Sòm 34:1\x*memwa a yo vin disparèt.   
\q1
\v 7 Men \x + \xo 9:7 \xt Sòm 89:14\x*SENYÈ a la jis pou tout tan;  
\q1 Li te etabli twòn Li pou jijman.   
\q1
\v 8 Li va jije mond lan avèk ladwati;  
\q1 Li va rann jijman pou pèp yo avèk jistis.   
\q1
\v 9 SENYÈ a va osi yon sitadèl pou sila ki oprime yo;  
\q1 yon sitadèl nan tan twoub la.   
\q1
\v 10 Sila ki konnen non Ou yo, va mete konfyans yo nan Ou,  
\q1 paske Ou menm, SENYÈ, pa janm abandone  
\q1 sila ki mete konfyans nan Ou yo.   
\q1
\v 11 Chante lwanj a SENYÈ a, ki \x + \xo 9:11 \xt Sòm 76:2\x*rete nan Sion;  
\q1 deklare pami pèp yo zèv Li yo.   
\q1
\v 12 Paske Sila ki egzije san an sonje yo;  
\q1 Li pa janm bliye kri a sila ki oprime yo.   
\q1
\v 13 Fè m gras, O SENYÈ;  
\q1 gade byen soufrans mwen akoz sila ki rayi mwen yo,  
\q1 e \x + \xo 9:13 \xt Sòm 30:3\x*fè m leve soti nan pòtay lanmò yo,   
\q1
\v 14 pou m kab pale tout lwanj a Ou menm.  
\q1 Konsa, nan pòtay a fi Sion yo,  
\q1 mwen kapab \x + \xo 9:14 \xt Sòm 13:5\x*rejwi nan delivrans Ou.   
\q1
\v 15 Nasyon yo fin fonse kole nan twou fòs yo te fè a;  
\q1 nan \x + \xo 9:15 \xt Sòm 57:6\x*pèlen yo te fè, pwòp pye yo vin kole ladann.   
\q1
\v 16 Senyè a te \x + \xo 9:16 \xt Egz 7:5\x*leve tèt Li pou yo wè;  
\q1 Li te rann jijman an.  
\q1 Nan zèv a pwòp men Li, mechan an  
\q1 kole nan pwòp pèlen li. \qs Tan\qs*   
\q1
\v 17 \x + \xo 9:17 \xt Sòm 49:14\x*Mechan yo va retounen nan sejou lanmò a;  
\q1 menm tout nasyon ki bliye Bondye yo.   
\q1
\v 18 Paske \x + \xo 9:18 \xt Sòm 9:12\x*malere yo p ap bliye jis pou tout tan,  
\q1 ni espwa a aflije yo p ap peri pou tout tan.   
\q1
\v 19 Leve, \x + \xo 9:19 \xt Nonb 10:35\x*O SENYÈ, pa kite lòm vin genyen;  
\q1 kite nasyon yo jije devan Ou.   
\q1
\v 20 Bay yo lakrent, O SENYÈ;  
\q1 fè nasyon yo konnen ke se sèlman \x + \xo 9:20 \xt Sòm 62:9\x*lòm yo ye. \qs Tan\qs*   
\c 10  
\q1
\v 1 Poukisa Ou kanpe tèlman lwen, O Senyè?  
\q1 Poukisa \x + \xo 10:1 \xt Sòm 22:1\x*Ou kache Ou menm nan tan twoub yo?   
\q1
\v 2 Nan ògèy pa yo, mechan yo kouri cho dèyè aflije yo.  
\q1 Kite yo \x + \xo 10:2 \xt Sòm 7:16\x*kenbe nan menm pèlen ke yo te fè a.   
\q1
\v 3 Paske mechan an ap vin ògeye sou \x + \xo 10:3 \xt Sòm 94:3\x*dezi kè li a;  
\q1 li beni moun voras la,  
\q1 e eksprime madichon pou l rejte SENYÈ a.   
\q1
\v 4 Mechan an nan wotè rega li, refize chache Bondye,  
\q1 Tout panse li se ke: \x + \xo 10:4 \xt Sòm 14:1\x*“Nanpwen Bondye.”   
\q1
\v 5 Chemen pa li yo reyisi tout tan;  
\q1 Jijman Ou yo tèlman wo, li pa wè yo.  
\q1 Selon lènmi li yo, li giyonnen yo.   
\q1
\v 6 Li di a pwòp tèt li: \x + \xo 10:6 \xt Rev 18:7\x*“Mwen p ap ebranle menm;  
\q1 Pandan tout jenerasyon yo,  
\q1 mwen p ap gen pwoblèm ditou.”   
\q1
\v 7 \x + \xo 10:7 \xt Wo 3:14\x*Bouch li plen ak malediksyon, avèk  
\q1 twonpe moun avèk oprime moun.  
\q1 Anba lang li, se twonpe moun avèk mechanste.   
\q1
\v 8 Li chita nan anbiskad pou veye vil yo;  
\q1 nan anbiskad yo, li \x + \xo 10:8 \xt Sòm 94:6\x*touye inosan yo.  
\q1 Zye li yo veye san bat sila ki pa gen espwa yo.   
\q1
\v 9 Li kache yon kote an kachèt tankou lyon nan nan kav li.  
\q1 Li kache pou kenbe aflije yo;  
\q1 li kenbe aflije yo lè l rale mennen yo rive nan pèlen \x + \xo 10:9 \xt Sòm 140:5\x*an.   
\q1
\v 10 Li akwoupi, li pare kò l;  
\q1 konsa malere a vin tonbe  
\q1 pa grif pwisan li yo.   
\q1
\v 11 Li pale a tèt li: \x + \xo 10:11 \xt Sòm 10:4\x*“Bondye bliye.  
\q1 Li kache figi Li; Li p ap janm wè sa.”   
\b  
\q1
\v 12 Leve O SENYÈ!  
\q1 O Bondye, \x + \xo 10:12 \xt Sòm 17:7\x*leve men Ou wo!  
\q1 Pa bliye aflije yo!   
\q1
\v 13 Poukisa mechan an te meprize Bondye?  
\q1 Li te di nan tèt li: “Ou p ap egzije m sa”.   
\q1
\v 14 Ou te wè sa, paske Ou te wè kont  
\q1 mechanste ak agase moun pou pran sa an men.  
\q1 Malere a ap depann de Ou menm;  
\q1 Se Ou ki konn ede \x + \xo 10:14 \xt Sòm 68:5\x*òfelen an.   
\q1
\v 15 \x + \xo 10:15 \xt Sòm 37:17\x*Kase bra a mechan yo avèk malfektè a!  
\q1 Dekouvri mechanste li yo jiskaske  
\q1 Ou pa twouve l ankò.   
\q1
\v 16 SENYÈ a se Wa a pou tout tan!  
\q1 \x + \xo 10:16 \xt Det 8:20\x*Nasyon yo va peri disparèt de peyi Li a.   
\q1
\v 17 O SENYÈ, Ou te tande \x + \xo 10:17 \xt Sòm 9:18\x*dezi a enb yo;  
\q1 Ou va ranfòse kè yo, Ou va enkline zòrèy Ou,   
\q1
\v 18 pou bay jistis a òfelen an avèk \x + \xo 10:18 \xt Sòm 9:9\x*oprime a,  
\q1 pou lòm ki mache sou tè a, pa koze laperèz ankò.   
\c 11  
\d Pou direktè koral la; yon sòm David  
\q1
\v 1 Se nan SENYÈ a ke m \x + \xo 11:1 \xt Sòm 2:12\x*kache.  
\q1 Kijan ou kapab di a nanm mwen:  
\q1 “Sove ale kon yon zwazo nan mòn ou;   
\q1
\v 2 Paske, gade byen, mechan yo koube banza,  
\q1 Yo \x + \xo 11:2 \xt Sòm 64:3 \x*fè flèch yo parèt sou kòd la,  
\q1 pou tire nan fènwa sou sila ak kè ki dwat yo.   
\q1
\v 3 Si \x + \xo 11:3 \xt Sòm 82:5\x*fondasyon yo vin detwi,  
\q1 se kisa moun dwat yo kab fè?”   
\q1
\v 4 SENYÈ a nan sen tanp Li an.  
\q1 \x + \xo 11:4 \xt Rev 4:2 \x*SENYÈ a sou twon Li nan syèl la.  
\q1 Zye Li veye.  
\q1 Pòpyè zye Li sonde fis a lòm yo.   
\q1
\v 5 SENYÈ a \x + \xo 11:5 \xt Jen 22:1\x*sonde sila ki jis yo avèk sila ki mechan yo;  
\q1 men sila ki renmen vyolans, Li rayi nan kè L.   
\q1
\v 6 Sou mechan yo, Li va \x + \xo 11:6 \xt Sòm 18:13-14\x*voye chabon cho tankou lapli;  
\q1 dife avèk souf avèk chabon brile va mele nan bwason yo.   
\q1
\v 7 Paske Bondye dwat.  
\q1 Li renmen ladwati.  
\q1 Sila ki kanpe dwat yo va \x + \xo 11:7 \xt Sòm 16:11\x*wè figi Li.   
\c 12  
\d Pou direktè koral la; sou yon gita uit kòd  
\d Yon sòm David.  
\q1
\v 1 Sekou, SENYÈ, paske \x + \xo 12:1 \xt És 57:1\x*moun ladwati yo sispann egziste,  
\q1 Paske fidèl yo vin disparèt pami fis a lòm yo.   
\q1
\v 2 Yo pale sa ki fo a youn lòt.  
\q1 \x + \xo 12:2 \xt Wo 16:18\x*Lèv flatè yo ak kè doub yo pale.   
\q1
\v 3 Ke SENYÈ a vin koupe tout lèv flatè yo,  
\q1 ak lang ki \x + \xo 12:3 \xt Dan 7:8\x*pale gwo bagay yo;   
\q1
\v 4 ki \x + \xo 12:4 \xt Sòm 73:8-9\x*te di: “Avèk lang nou, nou va reyisi.  
\q1 Lèv nou se pou nou.  
\q1 Se kilès ki kab mèt sou nou?”   
\q1
\v 5 “Akoz dega a aflije yo, akoz kri a malere yo,  
\q1 koulye a, \x + \xo 12:5 \xt És 33:10\x*Mwen va leve”, pale SENYÈ a;  
\q1 “Mwen va mete li ansekirite de sila ki maltrete l la.”   
\q1
\v 6 Pawòl a SENYÈ a se pawòl ki san tach;  
\q1 tankou ajan ki \x + \xo 12:6 \xt Pwov 30:5\x*teste nan founo,  
\q1 rafine nan tè sèt fwa.   
\q1
\v 7 Ou menm, O SENYÈ, va pwoteje yo.  
\q1 Ou va \x + \xo 12:7 \xt Sòm 37:28\x*prezève yo soti nan  
\q1 jenerasyon sila a jis pou tout tan.   
\q1
\v 8 Mechan yo pwomennen toupatou tout kote  
\q1 lè \x + \xo 12:8 \xt És 32:5 \x*bagay ki lèd vin leve wo  
\q1 pami fis a lòm yo.   
\c 13  
\d Pou direktè koral la; yon sòm David  
\q1
\v 1 Jiskilè SENYÈ?  
\q1 Èske Ou ap \x + \xo 13:1 \xt Job 13:24\x*bliye mwen jis pou tout tan?  
\q1 Pou konbyen de tan, Ou va kache figi Ou de mwen?   
\q1
\v 2 Pou konbyen de tan mwen va oblije  
\q1 \x + \xo 13:2 \xt Sòm 42:4\x*depann sou pwòp konsèy tèt mwen,  
\q1 ak tristès nan kè m tout lajounen?  
\q1 Jiskilè lènmi m va vin leve wo sou mwen?   
\q1
\v 3 Okipe m, e reponn mwen, O SENYÈ, Bondye mwen;  
\q1 \x + \xo 13:3 \xt Esd 9:8\x*Fè zye m wè, pou m pa mouri;   
\q1
\v 4 pou lènmi mwen an pa di: “Mwen fin genyen l,”  
\q1 \x + \xo 13:4 \xt Sòm 25:2\x*epi advèsè mwen yo rejwi lè m pran chòk.   
\q1
\v 5 Men mwen va \x + \xo 13:5 \xt Sòm 52:8\x*mete konfyans mwen nan lanmou dous Ou a;  
\q1 Kè m va rejwi nan delivrans ou   
\q1
\v 6 Mwen va \x + \xo 13:6 \xt Sòm 96:1\x*chante a SENYÈ a,  
\q1 paske Li te aji ak bon kè avè m.   
\c 14  
\d Pou direktè koral la; yon sòm David  
\q1
\v 1 Moun fou a di nan kè l: “Nanpwen Bondye.”  
\q1 Yo konwonpi.  
\q1 Yo te fè zak abominab.  
\q1 \x + \xo 14:1 \xt Wo 3:10-12\x*Nanpwen ki fè sa ki bon.   
\q1
\v 2 SENYÈ a te gade anba soti nan syèl la  
\q1 sou fis a lòm yo pou wè si genyen  
\q1 ki \x + \xo 14:2 \xt Sòm 92:6\x*konprann, k ap chache Bondye.   
\q1
\v 3 Yo tout te vire akote.  
\q1 Ansanm yo te vin konwonpi.  
\q1 \x + \xo 14:3 \xt Sòm 143:2\x*Nanpwen ki fè sa ki bon, pa menm youn.   
\q1
\v 4 Èske tout malfektè inikite yo pa konnen,  
\q1 sila Ki \x + \xo 14:4 \xt Jr 10:25\x*manje pèp mwen yo  
\q1 tankou y ap manje pen an,  
\q1 san yo pa rele SENYÈ a?   
\q1
\v 5 La, yo nan gwo danje,  
\q1 paske Bondye rete avèk jenerasyon ki dwat la.   
\q1
\v 6 Nou meprize bezwen aflije a,  
\q1 men SENYÈ a se \x + \xo 14:6 \xt Sòm 46:1\x*refij li.   
\q1
\v 7 O ke sali Israël la ta sòti nan Sion!  
\q1 Lè SENYÈ a \x + \xo 14:7 \xt Sòm 85:1-2\x*restore pèp kaptif li a,  
\q1 Jacob va rejwi, e Israël va gen kè kontan.   
\c 15  
\d Yon sòm David  
\q1
\v 1 O SENYÈ, se kilès ki kab rete nan tant Ou?  
\q1 Kilès ki kab demere sou \x + \xo 15:1 \xt Sòm 24:3\x* mòn sen Ou an?   
\q1
\v 2 Sila ki mache nan entegrite a e ki fè zèv ladwati yo;  
\q1 li ki pale verite a nan kè li a;   
\q1
\v 3 ki pa fè kout lang sou lòt,  
\q1 ni fè vwazen li mal,  
\q1 ni patisipe nan fè repwòch kont zanmi li;   
\q1
\v 4 nan zye a sila yon vagabon meprize a,  
\q1 men ki \x + \xo 15:4 \xt Trav 28:10\x*bay lonè a sila ki fè lakrent SENYÈ yo;  
\q1 li sèmante a pwòp pèt li, menm lè l fè l mal,  
\q1 e li pa chanje menm;   
\q1
\v 5 Li pa vèse bay lajan li avèk enterè,  
\q1 ni \x + \xo 15:5 \xt Egz 23:8\x*li pa aksepte yon kado anba tab kont inosan an.  
\b  
\q1 Sila ki fè bagay sa yo p ap janm ebranle.   
\c 16  
\d Yon Sòm David  
\q1
\v 1 Pwoteje m O Bondye, paske \x + \xo 16:1 \xt Sòm 7:1\x*mwen kache nan Ou.   
\q1
\v 2 Mwen te di a SENYÈ, Ou se Senyè mwen.  
\q1 Mwen pa gen anyen ki bon sof ke Ou menm.   
\q1
\v 3 Selon sen sou latè yo, se moun manyifik yo ye;  
\q1 sou yo menm mwen pran tout plezi m yo.   
\b  
\q1
\v 4 Doulè a sila ki te fè donn a yon lòt dye va vin ogmante;  
\q1 Mwen p ap vin vide ofrann bwason san pa yo,  
\q1 ni non yo \x + \xo 16:4 \xt Egz 23:13 \x*p ap sòti sou lèv mwen.   
\q1
\v 5 SENYÈ a se \x + \xo 16:5 \xt Sòm 73:26\x*pòsyon eritaj mwen ak tas mwen;  
\q1 Se Ou menm ki bay soutyen a pati pa m nan.   
\b  
\q1
\v 6 \x + \xo 16:6 \xt Sòm 78:55\x*Lizyè yo vin tonbe nan kote ki tèlman bèl pou mwen.  
\q1 Anverite, eritaj mwen bèl pou mwen.   
\q1
\v 7 Mwen va beni SENYÈ a ki te ban m konsèy la.  
\q1 Anverite, \x + \xo 16:7 \xt Sòm 77:6\x*panse mwen toujou vin enstwi mwen pandan lannwit.   
\q1
\v 8 \x + \xo 16:8 \xt Sòm 16:8-11\x*Mwen te mete SENYÈ a devan zye m tout tan.  
\q1 Akoz Li se men dwat mwen, mwen p ap ebranle menm.   
\q1
\v 9 Pou sa, \x + \xo 16:9 \xt Sòm 4:7\x*kè m kontan e glwa mwen fè rejwisans.  
\q1 Anplis, chè m va toujou pwoteje.   
\q1
\v 10 Paske Ou p ap abandone nanm mwen  
\q1 nan sejou mò yo;  
\q1 ni Ou p ap \x + \xo 16:10 \xt Trav 13:35\x*pèmèt Sila Ki Sen Ou an vin tonbe an pouriti.   
\q1
\v 11 Ou va fè m rekonèt \x + \xo 16:11 \xt Sòm 139:24\x*chemen lavi a.  
\q1 Nan prezans Ou, se lajwa ki an abondans nèt.  
\q1 Nan men dwat Ou, se plezi ki dire jis pou tout tan.   
\c 17  
\d Yon Priyè a David  
\q1
\v 1 Koute yon koz ki jis, O SENYÈ e okipe kri mwen.  
\q1 Prete zòrèy a lapriyè mwen,  
\q1 ki pa sòti nan \x + \xo 17:1 \xt És 29:13\x*lèv k ap twonpe moun.   
\q1
\v 2 Kite \x + \xo 17:2 \xt Sòm 103:6\x*pawòl mwen parèt akoz prezans Ou;  
\q1 Kite zye Ou gade avèk jistis.   
\q1
\v 3 Ou te teste kè m.  
\q1 Ou te vizite mwen pandan lannwit.  
\q1 Ou te \x + \xo 17:3 \xt I Pi 1:7\x*sonde mwen e Ou pa t jwenn anyen.  
\q1 Mwen te fè desizyon eksprè pou bouch mwen pa fè tò.   
\q1
\v 4 Alò, pou zèv a lòm yo, \x + \xo 17:4 \xt Sòm 119:9\x*selon pawòl a lèv Ou yo,  
\q1 Mwen te evite chemen a vyolan yo.   
\q1
\v 5 \x + \xo 17:5 \xt Job 23:11\x*Pye mwen yo te kenbe fèm nan chemen pa W la.  
\q1 Pye mwen pat janm glise.   
\q1
\v 6 Mwen \x + \xo 17:6 \xt Sòm 86:7\x*te rele Ou, paske Ou va reponn mwen, O Bondye.  
\q1 Enkline zòrèy W bò kote m.  
\q1 Tande pawòl mwen yo.   
\q1
\v 7 Kon mèvèy Ou yo, montre m lanmou dous Ou a,  
\q1 O Sovè a sila ki kache nan men dwat Ou yo, kont sila ki leve kont yo.   
\q1
\v 8 Kenbe m tankou \x + \xo 17:8 \xt Det 32:10\x*de zye nan tèt Ou.  
\q1 Kache mwen anba lonbraj a zèl Ou,   
\q1
\v 9 kont mechan ki depouye m yo,  
\q1 \x + \xo 17:9 \xt Sòm 31:20\x*lènmi mòtèl mwen yo ki antoure m.   
\q1
\v 10 Yo fin fèmen kè rèd yo.  
\q1 \x + \xo 17:10 \xt Job 15:27\x*Avèk bouch yo, yo pale awogans.   
\q1
\v 11 Koulye a, yo fin \x + \xo 17:11 \xt Sòm 88:17\x*antoure nou pandan n ap mache.  
\q1 Yo fikse zye yo sou nou pou jete nou atè.   
\q1
\v 12 Se tankou yon lyon ki anvi devore,  
\q1 tankou yon jenn lyon k ap \x + \xo 17:12 \xt Sòm 10:9 \x*kache  
\q1 nan fènwa.   
\q1
\v 13 Leve, O SENYÈ, konfwonte li e bese li;  
\q1 Delivre nanm mwen de mechan yo avèk \x + \xo 17:13 \xt Sòm 22:20 \x*nepe Ou,   
\q1
\v 14 Depi nan men mesye yo avèk men Ou, O SENYÈ,  
\q1 depi nan men lòm de mond sa yo,  
\q1 \x + \xo 17:14 \xt Sòm 73:3-7\x*k ap resevwa pòsyon pa yo nan vi sa a.  
\q1 Men Ou menm plen vant a sila Ou renmen yo.  
\q1 Fis ou yo gen kont,  
\q1 e yo mete an rezèv pou pitit pa yo.   
\q1
\v 15 Pou mwen menm, mwen va \x + \xo 17:15 \xt Sòm 11:7\x*wè figi Ou nan ladwati a;  
\q1 mwen va satisfè avèk vizaj Ou  
\q1 lè m ouvri zye m.   
\c 18  
\d Pou direktè koral la. Yon sòm David, sèvitè SENYÈ a, ki te pale a SENYÈ a, pawòl a chan ke li te adrese bay SENYÈ a apre Li te delivre li soti nan men a tout lènmi li yo, e soti nan men a Saül. Konsa li te di:  
\q1
\v 1 Mwen renmen Ou, O SENYÈ, fòs mwen.   
\q1
\v 2 SENYÈ a se \x + \xo 18:2 \xt Det 32:18\x* wòch mwen, sitadèl mwen e Delivrans mwen;  
\q1 Bondye mwen, wòch mwen, nan sila mwen jwenn pwoteksyon an.   
\q1
\v 3 Mwen rele SENYÈ a, ki dign pou bay lwanj;  
\q1 epi mwen \x + \xo 18:3 \xt Sòm 34:6\x*sove de lènmi mwen yo.   
\q1
\v 4 \x + \xo 18:4 \xt Sòm 116:3\x*Kòd lanmò yo te antoure mwen.  
\q1 Flèv mal ki sòti nan peyi a mò yo te teworize m.   
\q1
\v 5 Kòd peyi lanmò yo te antoure mwen;  
\q1 pèlen lanmò yo te parèt devan m.   
\q1
\v 6 Nan gwo twoub mwen, mwen te rele SENYÈ a,  
\q1 e te kriye a Bondye pou sekou.  
\q1 Depi nan tanp li an, li te tande vwa m.  
\q1 \x + \xo 18:6 \xt Sòm 34:15\x*Kri mwen pou sekou devan L  
\q1 te rive nan zòrèy Li.   
\q1
\v 7 Konsa, latè a te tranble.  
\q1 Fondasyon a mòn yo te tranble.  
\q1 Yo te ebranle nèt, akoz kòlè Li.   
\q1
\v 8 Lafimen te sòti nan nen L.  
\q1 \x + \xo 18:8 \xt Sòm 50:3\x*Dife a devoran te soti nan bouch Li.  
\q1 Chalè li te limen chabon.   
\q1
\v 9 Anplis, Li te bese syèl la e te desann  
\q1 avèk \x + \xo 18:9 \xt Sòm 97:2\x*fènwa byen pwès anba pye Li.   
\q1
\v 10 Li te monte sou yon cheriben, e te vole;  
\q1 Li te vole sou \x + \xo 18:10 \xt Sòm 104:3\x*zèl a van yo.   
\q1
\v 11 Li te sèvi \x + \xo 18:11 \xt Det 4:11\x*fènwa a tankou kote pou L kache, yon tant ki pou kouvri L.  
\q1 Fènwa nan dlo yo, nwaj pwès nan syèl yo.   
\q1
\v 12 Soti nan gran \x + \xo 18:12 \xt Sòm 104:2\x*klate devan L,  
\q1 gwo nwaj pwès Li yo,  
\q1 Lagrèl avèk chabon dife te pase.   
\q1
\v 13 Anplis, SENYÈ a te eklate nan syèl yo.  
\q1 Pi Pwisan an te fè vwa l sone:  
\q1 wòch lagrèl yo avèk chabon dife.   
\q1
\v 14 Li te \x + \xo 18:14 \xt Sòm 144:6\x*voye flèch li yo deyò e te gaye yo.  
\q1 Avèk anpil gwo klate, Li te fè yo sove ale.   
\q1
\v 15 Konsa, gwo kanal dlo yo te parèt;  
\q1 Fondasyon mond yo te vin toutouni;  
\q1 ak repwòch Ou, O SENYÈ,  
\q1 \x + \xo 18:15 \xt Sòm 106:9\x*lè gwo souf sòti nan nen Ou.   
\q1
\v 16 Li te voye soti an wo.  
\q1 Li te pran m.  
\q1 Li te rale mwen sòti nan pil dlo yo.   
\q1
\v 17 Li te \x + \xo 18:17 \xt Sòm 59:1\x*delivre mwen nan men  
\q1 advèsè mwen byen fò;  
\q1 de sila yo ki te rayi mwen yo,  
\q1 paske yo te twò fò pou mwen.   
\q1
\v 18 Yo te konfwonte mwen nan jou malè mwen,  
\q1 men \x + \xo 18:18 \xt Sòm 16:8\x*SENYÈ a te pwotèj mwen.   
\q1
\v 19 Li te mennen mwen fè m parèt nan yon bèl plas byen laj.  
\q1 Li te fè m sekou, akoz \x + \xo 18:19 \xt Sòm 37:23\x*Li te pran plezi nan mwen.   
\q1
\v 20 SENYÈ a te byen \x + \xo 18:20 \xt I Sam 24:19\x*rekonpanse mwen selon ladwati mwen.  
\q1 Selon men m ki pwòp, Li fè m rekonpans.   
\q1
\v 21 Paske mwen te kenbe chemen SENYÈ a,  
\q1 epi mwen pa t janm kite Bondye mwen an.   
\q1
\v 22 Paske tout \x + \xo 18:22 \xt Sòm 119:30\x*òdonans Li yo te devan m.  
\q1 Mwen pa t janm mete règleman Li yo akote.   
\q1
\v 23 Anplis, mwen te toujou san fot devan L,  
\q1 e mwen te \x + \xo 18:23 \xt Sòm 19:12,13\x*rete lib de inikite m.   
\q1
\v 24 Pou sa, SENYÈ a te \x + \xo 18:24 \xt I Sam 26:23\x*fè m rekonpans selon ladwati mwen,  
\q1 selon men pwòp ke Li te wè yo.   
\q1
\v 25 Avèk sila ki gen bon kè, Ou montre kè ki bon.  
\q1 Avèk sila ki san fot, Ou vin parèt san fot.   
\q1
\v 26 Avèk sila ki san tach, Ou montre li san tach Ou. \x + \xo 18:26 \xt Job 25:5\x*  
\q1 Epi avèk sila ki kwochi a, Ou parèt koken.   
\q1
\v 27 Paske Ou sove yon pèp aflije,  
\q1 men sila ak zye ki leve wo yo, Ou bese yo.   
\q1
\v 28 Paske SENYÈ a va limen lanp mwen.  
\q1 Se Bondye mwen an ki klere tenèb mwen.   
\q1
\v 29 Paske avèk Ou, mwen kapab \x + \xo 18:29 \xt Sòm 18:33\x*kouri sou yon ekip lame.  
\q1 Avèk Bondye mwen, mwen kab vòltije sou yon mi.   
\q1
\v 30 Pou Bondye, chemen Li \x + \xo 18:30 \xt Rev 15:3\x*san fot.  
\q1 Pawòl SENYÈ a pase a leprèv.  
\q1 Li se yon boukliye pou tout moun  
\q1 k ap pran sekou nan Li.   
\q1
\v 31 Paske \x + \xo 18:31 \xt Sòm 86:8-10\x*se kilès ke Bondye ye, sof ke SENYÈ a?  
\q1 Epi se kilès ki wòch la, sof ke Bondye nou an.   
\q1
\v 32 Bondye ki \x + \xo 18:32 \xt És 45:5\x*mare senti m ak fòs,  
\q1 epi fè chemen mwen san fot la?   
\q1
\v 33 Li fè pye m yo vin tankou sèf,  
\q1 epi \x + \xo 18:33 \xt Det 32:13 \x*fè m vin plase kote ki wo yo.   
\q1
\v 34 Li antrene men m pou batay la,  
\q1 jiskaske men m ka koube banza ki fèt an bwonz.   
\q1
\v 35 Anplis, Ou te ban mwen  
\q1 \x + \xo 18:35 \xt Sòm 33:20\x*boukliye sali Ou e  
\q1 men dwat Ou te ban m soutyen.  
\q1 Se bonte Ou ki fè m gran.   
\q1
\v 36 Ou \x + \xo 18:36 \xt Sòm 18:33\x*fè longè pa m yo lonje pi laj anba m,  
\q1 epi pye m pa t janm chape.   
\q1
\v 37 Mwen te \x + \xo 18:37 \xt Sòm 44:5\x*kouri dèyè lènmi m yo, e mwen te pran yo.  
\q1 Mwen pa t fè bak jiskaske yo tout te fin manje nèt.   
\q1
\v 38 Mwen va frape yo jiskaske yo pa kab leve.  
\q1 Yo va tonbe \x + \xo 18:38 \xt Sòm 47:3 \x*anba pye mwen.   
\q1
\v 39 Ou te mare senti m avèk fòs pou batay la.  
\q1 Ou te \x + \xo 18:39 \xt Sòm 18:47\x*soumèt anba m sila ki te leve kont mwen yo.   
\q1
\v 40 Ou te, anplis, fè lènmi m yo vire do yo ban mwen;  
\q1 konsa mwen te \x + \xo 18:40 \xt Sòm 94:23\x*detwi sila ki te rayi mwen yo.   
\q1
\v 41 Yo te kriye sekou, men \x + \xo 18:41 \xt Sòm 50:22\x*pa t gen moun pou sove yo;  
\q1 menm a SENYÈ a, men Li pa t reponn yo.   
\q1
\v 42 Mwen te bat yo kraze fen tankou \x + \xo 18:42 \xt Sòm 83:13\x*pousyè devan van;  
\q1 mwen te vide jete yo tankou labou nan lari.   
\q1
\v 43 Ou te delivre mwen devan yon pèp plen ak konfli;  
\q1 Ou te plase mwen kon \x + \xo 18:43 \xt II Sam 8:1-18\x*chèf an tèt a nasyon yo;  
\q1 Yon pèp ke m pa menm konnen,  
\q1 se sèvitè mwen yo ye.   
\q1
\v 44 Depi yo tande, yo obeyi mwen.  
\q1 Etranje yo \x + \xo 18:44 \xt Sòm 66:3\x*soumèt devan m.   
\q1
\v 45 Etranje yo vin disparèt devan m,  
\q1 epi vin sòti tranblan nan fò yo.   
\q1
\v 46 SENYÈ a \x + \xo 18:46 \xt Job 19:25\x*viv! Beni se wòch mwen an.  
\q1 Leve byen wo, se Bondye a sali mwen an.   
\q1
\v 47 Bondye ki egzekite vanjans pou mwen an,  
\q1 e ki fè pèp yo soumèt anba m nan.   
\q1
\v 48 Se Li menm ki delivre m de lènmi mwen yo.  
\q1 Anverite, Ou leve m pi wo de sila ki  
\q1 fè rebèl kont mwen yo.  
\q1 Ou delivre mwen kont men lòm \x + \xo 18:48 \xt Sòm 11:5\x*vyolans lan.   
\q1
\v 49 Pou sa, mwen va \x + \xo 18:49 \xt Wo 15:9\x*bay remèsiman  
\q1 a Ou menm pami nasyon yo, O SENYÈ,  
\q1 epi mwen va chante lwanj a non Ou.   
\q1
\v 50 Li bay gran delivrans a wa Li a,  
\q1 epi montre lanmou dous Li a \x + \xo 18:50 \xt Sòm 28:8\x*onksyone Li a,  
\q1 a David avèk desandan li yo jis pou tout tan.   
\c 19  
\d Pou direktè koral la; yon sòm David  
\q1
\v 1 \x + \xo 19:1 \xt Sòm 8:1\x*Syèl yo ap pale glwa Bondye a.  
\q1 Jan yo tèlman gran deklare zèv men Li yo.   
\q1
\v 2 Jou apre jou, l ap pale san rete;  
\q1 \x + \xo 19:2 \xt Sòm 139:12\x*Nwit apre nwit, li revele konesans.   
\q1
\v 3 Nanpwen langaj, ni pa gen pawòl  
\q1 kote nou pa tande vwa yo.   
\q1
\v 4 \x + \xo 19:4 \xt Wo 10:18\x* Sepandan, eko yo retanti sou tout latè,  
\q1 ak sa yo pale jis nan ekstremite latè a.  
\q1 Nan mitan yo, Li te plase yon tant pou solèy la,   
\q1
\v 5 ki tankou yon jennonm ki fenk marye  
\q1 k ap sòti nan chanm li.  
\q1 Li rejwi kon yon nonm fò k ap fè kous.   
\q1
\v 6 Li \x + \xo 19:6 \xt Sòm 113:3\x*leve soti nan yon pwent syèl,  
\q1 pou fè wonn li rive jis nan lòt pwent lan.  
\q1 Anyen pa chape devan chalè li.   
\b  
\q1
\v 7 Lalwa SENYÈ a \x + \xo 19:7 \xt Sòm 119:160\x*pafè  
\q1 Li rekonfòte nanm.  
\q1 Temwayaj SENYÈ a vrè,  
\q1 k ap fè saj yo senp.   
\q1
\v 8 Prensip a SENYÈ yo dwat,  
\q1 ki fè kè rejwi.  
\q1 Kòmandman SENYÈ a san tach.  
\q1 Li \x + \xo 19:8 \xt Sòm 36:9 \x*fè zye yo limen.   
\q1
\v 9 Lakrent SENYÈ a pi;  
\q1 Li dire jis pou tout tan.  
\q1 Jijman SENYÈ yo vrè;  
\q1 Yo \x + \xo 19:9 \xt Sòm 119:138 \x*jis san manke.   
\q1
\v 10 Yo \x + \xo 19:10 \xt Sòm 119:72\x*pi chè pase lò, wi, pase anpil lò fen.  
\q1 Yo pi dous pase myèl, pase siwo a  
\q1 ki tonbe nan gato myèl la.   
\q1
\v 11 Anplis, se pa yo menm ke sèvitè Ou a  
\q1 resevwa avètisman pou fè atansyon.  
\q1 Pou sila ki kenbe yo, gen gran \x + \xo 19:11 \xt Sòm 24:5-6\x*rekonpans.   
\q1
\v 12 Se kilès ki kab rekonèt fot li?  
\q1 Padone mwen \x + \xo 19:12 \xt Sòm 139:23-24\x*pou fot ke m pa konnen yo.   
\b  
\q1
\v 13 Anplis, pwoteje sèvitè ou a kont peche ògèy yo.  
\q1 Pa kite yo vin domine m.  
\q1 Konsa, mwen kab rete san fot,  
\q1 epi va inosan a gran peche.   
\q1
\v 14 Kite pawòl bouch mwen a avèk  
\q1 \x + \xo 19:14 \xt Sòm 104:34\x*refleksyon kè m  
\q1 vin akseptab devan zye Ou,  
\q1 O SENYÈ, wòch mwen, ak sovè mwen an.   
\c 20  
\d Pou direktè koral la; Yon sòm David  
\q1
\v 1 Ke SENYÈ a kapab reponn ou \x + \xo 20:1 \xt Sòm 50:15\x*nan jou gran twoub la!  
\q1 Ke non Bondye Jacob la kapab  
\q1 kenbe ou ansekirite an wo!   
\q1
\v 2 Ke Li kapab voye bay ou èd soti nan  
\q1 sanktyè a,  
\q1 epi \x + \xo 20:2 \xt Sòm 110:2 \x*bay ou soutyen soti nan Sion.   
\q1
\v 3 Ke Li kapab \x + \xo 20:3 \xt Trav 10:4\x*sonje tout ofrann sereyal ou yo,  
\q1 ke Li twouve tout ofrann brile ou yo byen akseptab!   
\q1
\v 4 Ke Li kapab bay ou dezi a kè ou,  
\q1 e \x + \xo 20:4 \xt Sòm 145:19 \x*akonpli tout plan ou yo!   
\q1
\v 5 Nou va chante avèk jwa akoz viktwa ou.  
\q1 Nan non Bondye nou an, nou va monte drapo nou yo.  
\q1 Ke SENYÈ a kapab \x + \xo 20:5 \xt I Sam 1:17\x*akonpli tout priyè ou yo.   
\q1
\v 6 Alò, mwen konnen ke SENYÈ a  
\q1 va delivre moun onksyone pa Li a.  
\q1 Li va \x + \xo 20:6 \xt És 58:9\x*reponn li soti nan syèl sen Li an,  
\q1 avèk delivrans pwisan men dwat Li a.   
\q1
\v 7 Genyen kèk ki fè konfyans nan cha yo, e kèk nan cheval yo,  
\q1 \x + \xo 20:7 \xt II Kwo 32:8\x*Men nou va fè konfyans nan non SENYÈ a, Bondye nou an.   
\q1
\v 8 Yo te pliye e yo te tonbe,  
\q1 men \x + \xo 20:8 \xt Sòm 37:24\x*nou te leve e nou te kanpe dwat.   
\q1
\v 9 Delivre nou O SENYÈ!  
\q1 Ke \x + \xo 20:9 \xt Sòm 3:7\x*Wa a kapab reponn nou nan jou ke nou rele Non Li an.   
\c 21  
\d Pou direktè koral la; Yon sòm David  
\q1
\v 1 O SENYÈ, \x + \xo 21:1 \xt Sòm 59:16-17\x*nan fòs Ou, Wa a va fè kè kontan.  
\q1 Nan delivrans Ou, ki gran rejwisans li va gen!   
\q1
\v 2 Ou te bay li dezi a kè li,  
\q1 ni Ou pa t refize demand a lèv li yo.   
\q1
\v 3 Paske Ou te vin rankontre Li avèk  
\q1 benediksyon de tout bon bagay.  
\q1 Ou te mete yon \x + \xo 21:3 \xt II Sam 12:30 \x*kouwòn sou tèt li.   
\q1
\v 4 Li te mande Ou lavi e Ou te bay li.  
\q1 Yon vi ki long ak \x + \xo 21:4 \xt Sòm 91:16\x*jou k ap dire  
\q1 jis pou tout tan.   
\q1
\v 5 Glwa li gran nan sali pa Ou.  
\q1 \x + \xo 21:5 \xt Sòm 96:6 \x*Onè ak majeste Ou te mete sou li.   
\q1
\v 6 Paske Ou te fè li beni pase tout moun, jis pou tout tan;  
\q1 Ou te fè li plen ak lajwa \x + \xo 21:6 \xt Sòm 43:4\x*avèk kè kontan nan prezans Ou.   
\q1
\v 7 Paske wa a mete konfyans li nan SENYÈ a.  
\q1 Epi akoz lanmou dous a Pi Wo a,  
\q1 \x + \xo 21:7 \xt Sòm 112:6\x*Li p ap ebranle menm.   
\q1
\v 8 Men ou va \x + \xo 21:8 \xt És 10:10\x*dekouvri tout lènmi ou yo.  
\q1 Men dwat ou va jwenn sila ki rayi ou yo.   
\q1
\v 9 Ou va fè yo tankou yon founo k ap brile nan tan kòlè ou.  
\q1 SENYÈ a va \x + \xo 21:9 \xt Lam 2:2\x*vale yo nèt nan kòlè Li,  
\q1 epi dife va devore yo.   
\q1
\v 10 Ou va detwi posterite pa yo soti sou latè,  
\q1 epi \x + \xo 21:10 \xt Sòm 37:28\x*desandan yo ap disparèt pami fis a lòm yo.   
\q1
\v 11 Malgre yo te anvizaje mal kont Ou,  
\q1 e te \x + \xo 21:11 \xt Sòm 10:2\x*fòme yon konplo,  
\q1 yo p ap reyisi.   
\q1
\v 12 Paske Ou va fè yo vire do yo.  
\q1 Ou va pwente \x + \xo 21:12 \xt Sòm 7:12-13\x*banza sou figi yo  
\q1 ak bon kontwòl.   
\q1
\v 13 Ke Ou leve wo, O SENYÈ,  
\q1 ak tout fòs Ou!  
\q1 Nou va \x + \xo 21:13 \xt Sòm 59:16\x*chante e bay lwanj a pwisans Ou.   
\c 22  
\d Pou direktè koral la, avèk mizik bich granmaten an;  
\d Yon sòm David.  
\q1
\v 1 \x + \xo 22:1 \xt Mat 27:46\x*Bondye mwen, Bondye mwen, poukisa Ou  
\q1 te abandone m?  
\q1 Kri a doulè sa a lwen delivrans mwen.   
\q1
\v 2 O Bondye mwen, mwen \x + \xo 22:2 \xt Sòm 42:3\x*kriye pandan lajounen, men Ou pa reponn.  
\q1 E nan lannwit men m pa jwenn repo.   
\q1
\v 3 Sepandan, Ou sen;  
\q1 Ou menm ki \x + \xo 22:3 \xt Det 10:21\x*sou twòn lwanj pèp Israël la.   
\q1
\v 4 Nan Ou menm, zansèt nou yo te mete konfyans yo.  
\q1 Yo te mete konfyans yo nan Ou,  
\q1 e Ou te \x + \xo 22:4 \xt Sòm 107:6\x*delivre yo.   
\q1
\v 5 A Ou menm, yo te kriye, e yo te delivre.  
\q1 \x + \xo 22:5 \xt És 49:23\x*Nan Ou, yo te mete konfyans yo, epi pa t desi.   
\q1
\v 6 Men mwen se yon \x + \xo 22:6 \xt Job 25:6\x*vè,  
\q1 mwen pa menm yon moun.  
\q1 Parèt abominab devan lèzòm,  
\q1 e meprize pa tout moun.   
\q1
\v 7 Tout moun ki wè m vin moke mwen.  
\q1 Yo \x + \xo 22:7 \xt Mat 27:39\x*separe avèk lèv yo e yo  
\q1 souke tèt yo pou di:   
\q1
\v 8 Li mete konfyans nan SENYÈ a.  
\q1 Kite Li menm delivre li.  
\q1 Kite Li sove li, paske Li pran plezi nan li.   
\q1
\v 9 Sepandan, Ou menm se Sila ki te  
\q1 fè m sòti nan vant manman m nan.  
\q1 Ou te fè m gen konfyans depi m  
\q1 t ap souse tete manman m.   
\q1
\v 10 Sou Ou, mwen te depann \x + \xo 22:10 \xt És 46:3\x*depi nesans mwen.  
\q1 Ou te Bondye mwen depi nan vant manman m.   
\q1
\v 11 \x + \xo 22:11 \xt Sòm 71:12\x*Pa rete lwen mwen, paske gwo twoub la toupre.  
\q1 Paske nanpwen moun ki pou ede m.   
\q1
\v 12 Anpil towo vin antoure m.  
\q1 Towo fò a \x + \xo 22:12 \xt Det 32:14\x*Basan yo te ansèkle m.   
\q1
\v 13 Yo ouvri bouch yo byen laj sou mwen,  
\q1 tankou yon \x + \xo 22:13 \xt Sòm 10:9\x*lyon voras k ap rele fò.   
\q1
\v 14 Mwen vin vide tankou dlo.  
\q1 Tout zo m fin dejwente.   
\q1
\v 15 Fòs mwen vin sèch tankou cha kanari.  
\q1 Lang mwen kole akote nan bouch mwen.  
\q1 \x + \xo 22:15 \xt Jn 19:28\x*Ou fè m kouche nan pousyè lanmò a.   
\q1
\v 16 Konsa, chen yo vin antoure mwen.  
\q1 Yon bann malfektè vin ansèkle m.  
\q1 Yo te \x + \xo 22:16 \xt Mat 27:35\x*pèse dwat mwen avèk pye m.   
\q1
\v 17 Mwen kab kontwole tout zo m yo.  
\q1 Yo \x + \xo 22:17 \xt Luc 23:27-35\x*gade mwen, yo fikse zye yo sou mwen.   
\q1
\v 18 Yo \x + \xo 22:18 \xt Mat 27:35\x*divize rad mwen pami yo.  
\q1 Pou vètman m, yo tire osò.   
\q1
\v 19 Men Ou menm, O SENYÈ, pa rete lwen!  
\q1 Ou menm, sekou mwen, \x + \xo 22:19 \xt Sòm 70:5\x*fè vit, vin rive ede m!   
\q1
\v 20 Delivre nanm mwen devan \x + \xo 22:20 \xt Sòm 37:14\x*nepe a,  
\q1 lavi mwen devan pouvwa a chen an.   
\q1
\v 21 Fè m sekou soti nan bouch a \x + \xo 22:21 \xt Sòm 22:13\x*lyon an,  
\q1 soti sou kòn a bèf mawon.  
\q1 Wi, Ou menm te reponn mwen.   
\b  
\q1
\v 22 Mwen va \x + \xo 22:22 \xt Sòm 40:10\x*pale non Ou a frè m yo.  
\q1 Nan mitan asanble a, mwen va louwe Ou.   
\q1
\v 23 \x + \xo 22:23 \xt Sòm 135:19-20\x*Ou menm ki krent SENYÈ a, louwe Li.  
\q1 Nou tout, desandan Jacob yo, bay Li glwa!  
\q1 Kanpe byen sezi devan L,  
\q1 nou tout, desandan Israël yo.   
\q1
\v 24 Paske Li pa t meprize ni  
\q1 rayi afliksyon a aflije yo.  
\q1 Ni Li pa t kache figi Li a li menm,  
\q1 men \x + \xo 22:24 \xt Sòm 31:22\x*lè li te kriye a Li pou sekou, Li te tande.   
\b  
\q1
\v 25 Se depi a Ou menm ke lwanj mwen sòti  
\q1 nan gran asanble a;  
\q1 Mwen va \x + \xo 22:25 \xt Sòm 61:8\x*akonpli ve mwen yo devan sila ki krent Li yo.   
\q1
\v 26 Aflije yo va manje e \x + \xo 22:26 \xt Sòm 107:9\x*va satisfè.  
\q1 Sila ki chache Li yo, va louwe SENYÈ a.  
\q1 Ke kè Ou kapab viv jis pou tout tan!   
\q1
\v 27 Tout \x + \xo 22:27 \xt Sòm 2:8\x*ekstremite tè a nèt va sonje.  
\q1 Yo va vire bò kote SENYÈ a.  
\q1 Konsa, tout fanmi nan nasyon yo va  
\q1 adore devan Ou.   
\q1
\v 28 Paske \x + \xo 22:28 \xt Za 14:9\x*wayòm nan se pou SENYÈ a,  
\q1 e pouvwa Li se sou tout nasyon yo.   
\q1
\v 29 Tout moun \x + \xo 22:29 \xt Hab 1:16\x* byen reyisi sou latè va manje e adore.  
\q1 Tout sila ki desann nan pousyè a va bese devan Li,  
\q1 Menm sila ki pa kab fè nanm li viv la.   
\q1
\v 30 Jenerasyon yo va sèvi Li.  
\q1 Yo va pale de SENYÈ a  
\q1 a \x + \xo 22:30 \xt Sòm 102:18\x*desandan yo k ap vini an.   
\q1
\v 31 Yo va vini.  
\q1 Yo va deklare ladwati Li  
\q1 a yon pèp ki \x + \xo 22:31 \xt Sòm 78:6\x*va vin fèt.  
\q1 Paske Li te reyisi fè tout bagay sa a.   
\c 23  
\d Yon sòm David  
\q1
\v 1 Bondye se \x + \xo 23:1 \xt Éz 34:11-13\x*bèje mwen;  
\q1 mwen p ap janm manke anyen.   
\q1
\v 2 Li fè m kouche nan patiraj vèt yo.  
\q1 Li \x + \xo 23:2 \xt Rev 7:17\x*mennen m akote dlo pezib yo.   
\q1
\v 3 Li restore nanm mwen.  
\q1 Li gide mwen nan \x + \xo 23:3 \xt Pwov 4:11 \x*chemen ladwati yo,  
\q1 akoz non sen Li an.   
\q1
\v 4 Malgre mwen ta mache nan vale  
\q1 lonbraj lanmò a,  
\q1 mwen p ap pè okenn mal, paske Ou avè m.  
\q1 \x + \xo 23:4 \xt Mi 7:14 \x*Baton Ou avèk kwòk Ou fè m gen konfyans.   
\q1
\v 5 Ou ranje yon tab devan mwen  
\q1 nan prezans lènmi mwen yo.  
\q1 Ou onksyone tèt mwen avèk lwil.  
\q1 \x + \xo 23:5 \xt Sòm 16:5 \x*Tas mwen fin debòde nèt.   
\q1
\v 6 Anverite, bonte Ou avèk lanmou dous Ou  
\q1 va swiv mwen pou tout jou lavi mwen yo,  
\q1 E mwen va \x + \xo 23:6 \xt Sòm 27:4-6\x*viv lakay  
\q1 SENYÈ a jis pou tout tan.   
\c 24  
\d Yon sòm David  
\q1
\v 1 Tè a se pou SENYÈ a, avèk \x + \xo 24:1 \xt I Kor 10:26\x*tout sa ki ladann;  
\q1 lemonn avèk tout sila ki rete ladann yo.   
\q1
\v 2 Li te \x + \xo 24:2 \xt Sòm 104:3-5\x*fonde li sou lanmè yo,  
\q1 e te etabli li sou rivyè yo.   
\b  
\q1
\v 3 Se kilès ki kab monte sou kolin SENYÈ a?  
\q1 Epi kilès ki kab kanpe nan \x + \xo 24:3 \xt Sòm 65:4\x*lye sen pa Li an?   
\q1
\v 4 Sila ki gen men pwòp avèk yon kè ki san tach,  
\q1 ki pa \x + \xo 24:4 \xt Éz 18:15\x*leve nanm li vè sa ki fo,  
\q1 ni ki pa fè fo temwayaj.   
\q1
\v 5 Li va resevwa yon benediksyon soti nan SENYÈ a,  
\q1 ak \x + \xo 24:5 \xt Sòm 36:10\x*ladwati soti nan Bondye delivrans li an.   
\q1
\v 6 Sa se jenerasyon a sila k ap \x + \xo 24:6 \xt Sòm 27:4-8\x*chache Li yo,  
\q1 k ap chache figi Ou—menm Jacob. \qs Tan\qs*   
\b  
\q1
\v 7 Leve wo lento ou yo, o pòtay yo!  
\q1 Leve wo, o pòt ansyen yo!  
\q1 Pou Wa \x + \xo 24:7 \xt Trav 7:2\x*glwa a kapab antre!   
\q1
\v 8 Se kilès ki Wa a glwa a?  
\q1 SENYÈ fò e pwisan an,  
\q1 SENYÈ a \x + \xo 24:8 \xt Sòm 76:3-6\x*pwisan nan batay la.   
\q1
\v 9 Leve wo lento ou yo, O Pòtay yo!  
\q1 Leve wo, O pòt ansyen yo!  
\q1 Pou Wa \x + \xo 24:9 \xt Sòm 26:8\x*glwa a kapab antre!   
\q1
\v 10 Se kilès ki Wa glwa a?  
\q1 SENYÈ dèzame \x + \xo 24:10 \xt II Sam 5:10\x* yo!  
\q1 Se Li menm ki Wa glwa a. \qs Tan.\qs*   
\c 25  
\d Yon sòm David  
\q1
\v 1 A Ou menm, O SENYÈ, mwen \x + \xo 25:1 \xt II Sam 5:10\x*leve nanm mwen.   
\q1
\v 2 O Bondye mwen, nan Ou, mwen mete konfyans mwen.  
\q1 Pa kite mwen vin wont;  
\q1 pa kite \x + \xo 25:2 \xt Sòm 13:4\x*lènmi m yo fè fèt sou mwen.   
\q1
\v 3 Anverite, nanpwen nan sila ki tann Ou yo ki va wont;  
\q1 sila ki \x + \xo 25:3 \xt Hab 1:13\x*fè konplo kont Ou san koz yo, va wont.   
\b  
\q1
\v 4 \x + \xo 25:4 \xt Egz 33:13\x*Fè m konnen pa Ou yo, O SENYÈ;  
\q1 enstwi m nan chemen Ou yo.   
\q1
\v 5 Mennen mwen nan verite Ou e enstwi mwen,  
\q1 Paske se Ou menm ki \x + \xo 25:5 \xt Sòm 79:9\x*Bondye delivrans mwen;  
\q1 se Ou m ap tann tout lajounen.   
\q1
\v 6 Sonje, O SENYÈ, mizerikòd Ou ak lanmou dous Ou a,  
\q1 Paske se yo ki la \x + \xo 25:6 \xt Sòm 103:17\x*depi tan ale nèt.   
\q1
\v 7 Pa sonje \x + \xo 25:7 \xt Job 13:26\x*peche jenès mwen yo, ni transgresyon mwen yo.  
\q1 Selon lanmou dous Ou, sonje mwen,  
\q1 Pou koz a bonte Ou, O SENYÈ.   
\q1
\v 8 Bon e plen ladwati, se SENYÈ a;  
\q1 pou sa, Li enstwi pechè yo nan chemen an.   
\q1
\v 9 Li \x + \xo 25:9 \xt Sòm 23:3\x*dirije enb yo nan jistis, e  
\q1 Li va enstwi enb yo nan chemen Li.   
\q1
\v 10 Tout chemen Bondye se nan  
\q1 lanmou dous avèk verite  
\q1 pou \x + \xo 25:10 \xt Sòm 103:18\x*sila ki kenbe akò Li yo ak  
\q1 temwayaj Li yo.   
\q1
\v 11 Pou koz a non Ou, O SENYÈ,  
\q1 \x + \xo 25:11 \xt Egz 34:9\x*padone inikite mwen, paske li anpil.   
\q1
\v 12 Kilès nonm nan ki gen krent SENYÈ a?  
\q1 Li va \x + \xo 25:12 \xt Sòm 25:8 \x*enstwi li nan chemen li ta dwe chwazi a.   
\q1
\v 13 Nanm li va viv alèz.  
\q1 Desandan li yo va resevwa eritaj peyi a.   
\q1
\v 14 \x + \xo 25:14 \xt Pwov 3:32\x*Lamitye SENYÈ a se pou sila ki  
\q1 gen lakrent Li yo.  
\q1 Li va fè yo konnen akò Li.   
\b  
\q1
\v 15 Zye m toujou vè SENYÈ a,  
\q1 paske Li va \x + \xo 25:15 \xt Sòm 124:7 \x*retire pye mwen nan pèlen an.   
\q1
\v 16 \x + \xo 25:16 \xt Sòm 69:16\x*Vire vè mwen e fè m gras,  
\q1 paske mwen abandone e aflije.   
\q1
\v 17 Twoub a kè m yo vin plis.  
\q1 Mennen m sòti nan gwo detrès sa a.   
\q1
\v 18 Gade sou afliksyon mwen avèk twoub mwen yo,  
\q1 e \x + \xo 25:18 \xt Sòm 103:3\x*padone tout peche mwen yo.   
\q1
\v 19 Gade sou tout lènmi mwen yo, paske yo anpil.  
\q1 Epi yo \x + \xo 25:19 \xt Sòm 9:13\x*rayi mwen avèk yon rayisman ki vyolan.   
\q1
\v 20 Gade nanm mwen e delivre mwen.  
\q1 Pa kite m \x + \xo 25:20 \xt Sòm 25:2\x*vin wont, paske mwen  
\q1 pran refij nan Ou menm.   
\q1
\v 21 Kite \x + \xo 25:21 \xt Sòm 41:12\x*entegrite avèk ladwati pwoteje mwen,  
\q1 paske se Ou m ap tann.   
\q1
\v 22 Delivre Israël, O Bondye, sou  
\q1 tout twoub li yo.   
\c 26  
\d Yon sòm David  
\q1
\v 1 Fè m jistis, O SENYÈ, paske mwen te mache nan entegrite mwen.  
\q1 Mwen te mete konfyans mwen nan SENYÈ a san varye.   
\q1
\v 2 Chache anndan m, O SENYÈ, e pase mwen a leprèv.  
\q1 \x + \xo 26:2 \xt Sòm 7:9\x*Sonde panse mwen avèk kè m.   
\q1
\v 3 Paske lanmou dous Ou a devan zye m.  
\q1 Mwen \x + \xo 26:3 \xt II Wa 20:3\x*te mache nan verite Ou.   
\q1
\v 4 Mwen pa \x + \xo 26:4 \xt Sòm 1:1\x*chita avèk mesye k ap twonpe moun yo.  
\q1 Ni mwen pa pale avèk sila k ap pran pòz yo.   
\q1
\v 5 Mwen rayi asanble malfektè yo, e  
\q1 mwen pa chita avèk mechan yo.   
\q1
\v 6 Mwen va lave men m nan inosans, e  
\q1 mwen va antoure lotèl Ou, O SENYÈ,   
\q1
\v 7 pou m kapab pwoklame avèk vwa remèsiman a,  
\q1 e deklare tout mèvèy Ou yo.   
\q1
\v 8 O SENYÈ, Mwen renmen abitasyon lakay Ou,  
\q1 avèk kote ke \x + \xo 26:8 \xt Sòm 24:7\x*glwa Ou rete a.   
\q1
\v 9 Pa retire nanm mwen ansanm avèk pechè yo,  
\q1 ni lavi m avèk \x + \xo 26:9 \xt Sòm 139:19\x*mesye ki vèse san yo,   
\q1
\v 10 nan men a sila ki gen manèv mechan yo,  
\q1 ki nan mechanste pote \x + \xo 26:10 \xt Sòm 15:5\x*kado vèse anba tab yo.   
\b  
\q1
\v 11 Men pou mwen, mwen va mache nan entegrite mwen.  
\q1 \x + \xo 26:11 \xt Sòm 44:26\x*Delivre mwen e fè m gras.   
\q1
\v 12 Pye m kanpe sou yon plas byen plat.  
\q1 Nan \x + \xo 26:12 \xt Sòm 22:22\x*asanble a, mwen va beni SENYÈ a.   
\c 27  
\d Yon sòm David  
\q1
\v 1 SENYÈ a se limyè mwen e \x + \xo 27:1 \xt És 33:2\x*sali mwen.  
\q1 Se kilès pou m ta pè? SENYÈ a se  
\q1 defans lavi mwen.  
\q1 Se kilès k ap fè m gen laperèz?   
\q1
\v 2 Lè malfektè yo te rive sou mwen  
\q1 pou yo ta devore chè m,  
\q1 advèsè mwen yo ak lènmi m yo  
\q1 te \x + \xo 27:2 \xt Sòm 9:3\x*chape tonbe.   
\q1
\v 3 Malgre yon lame ta fè kan kont mwen, kè m p ap pè.  
\q1 Malgre lagè leve kont mwen,  
\q1 malgre sa, m ap gen \x + \xo 27:3 \xt Job 4:6\x*konfyans.   
\q1
\v 4 Yon sèl bagay ke m te mande a SENYÈ a;  
\q1 se li mwen va chache:  
\q1 pou m ta kab rete lakay SENYÈ a  
\q1 tout jou lavi m yo,  
\q1 pou m kab gade bèlte SENYÈ a, e  
\q1 reflechi jis nan fon kè m nan tanp Li an.   
\q1
\v 5 Paske nan jou twoub la,  
\q1 Li va \x + \xo 27:5 \xt Sòm 31:20 \x*kache mwen nan tabènak Li.  
\q1 Nan plas sekrè kote tant Li an ye a,  
\q1 se la Li va fè m kache.  
\q1 Li va leve mwen sou yon wòch.   
\q1
\v 6 Epi koulye a, \x + \xo 27:6 \xt Sòm 3:3\x*tèt mwen va vin leve wo  
\q1 sou lènmi m ki antoure m yo.  
\q1 Konsa, mwen va ofri nan tant Li sakrifis avèk gwo kri lajwa.  
\q1 Mwen va chante, wi, mwen va chante lwanj a SENYÈ a.   
\b  
\q1
\v 7 \x + \xo 27:7 \xt Sòm 4:3\x*Tande, O SENYÈ, lè m kriye avèk vwa m.  
\q1 Fè m gras e reponn mwen.   
\q1
\v 8 Lè Ou te di m: \x + \xo 27:8 \xt Sòm 105:4\x*“Chache wè figi Mwen”,  
\q1 kè m te di Ou: “Figi Ou menm, O SENYÈ,  
\q1 se li mwen va chache.”   
\q1
\v 9 Pa kache figi Ou de mwen.  
\q1 Pa detounen sèvitè Ou a pa deyò nan kòlè Ou.  
\q1 Se Ou ki konn sekou mwen.  
\q1 Pa abandone mwen, ni \x + \xo 27:9 \xt Sòm 37:28 \x*kite m sèl,  
\q1 O Bondye delivrans mwen an.   
\q1
\v 10 Paske papa m ak manman m te abandone mwen,  
\q1 Men \x + \xo 27:10 \xt És 40:11 \x*SENYÈ a va ranmase mwen.   
\q1
\v 11 \x + \xo 27:11 \xt Sòm 25:4\x*Enstwi mwen nan chemen Ou, O SENYÈ.  
\q1 Mennen m nan yon wout ki a nivo, akoz lènmi mwen yo.   
\q1
\v 12 Pa livre mwen de dezi lènmi mwen yo,  
\q1 paske \x + \xo 27:12 \xt Mat 26:60\x*fo temwen yo vin leve kont mwen,  
\q1 sila k ap respire vyolans yo.   
\q1
\v 13 Mwen toujou gen konfyans sa a:  
\q1 ke m va wè \x + \xo 27:13 \xt Sòm 31:19\x*bonte SENYÈ a nan peyi a vivan yo.   
\q1
\v 14 Tann SENYÈ a.  
\q1 \x + \xo 27:14 \xt Sòm 31:24\x*Kenbe fòs Ou e kite kè Ou pran kouraj.  
\q1 Wi, tann SENYÈ a.   
\c 28  
\d Yon sòm David  
\q1
\v 1 A Ou menm, O SENYÈ, mwen rele!  
\q1 Wòch mwen an, pa vin soud devan m,  
\q1 paske si Ou \x + \xo 28:1 \xt Sòm 83:1\x*rete silan devan mwen,  
\q1 mwen va devni kon sila ki desann nan twou fòs la nèt.   
\q1
\v 2 Tande \x + \xo 28:2 \xt Sòm 140:6\x*vwa a siplikasyon mwen yo  
\q1 lè m kriye a Ou menm pou sekou,  
\q1 lè m leve men m vè sanktyè sen Ou an.   
\q1
\v 3 \x + \xo 28:3 \xt Sòm 26:9\x*Pa rale m sòti avèk mechan yo,  
\q1 avèk sila ki fè inikite yo, ki pale lapè avèk vwazen yo,  
\q1 pandan mechanste nan kè yo.   
\q1
\v 4 Rekonpanse yo \x + \xo 28:4 \xt Rev 18:6\x*selon zèv yo ak selon mechanste yo abitye fè yo.  
\q1 Rekonpanse yo selon zèv men yo.  
\q1 Remèt yo tout rekonpans pa yo.   
\q1
\v 5 Akoz yo \x + \xo 28:5 \xt És 5:12\x*pa okipe zèv a SENYÈ yo,  
\q1 ni travay men Li yo.  
\q1 Pou sa, Li va chire yo desann, e Li p ap fè yo remonte.   
\b  
\q1
\v 6 Beni se SENYÈ a,  
\q1 akoz Li \x + \xo 28:6 \xt Sòm 28:2\x*te tande vwa a siplikasyon mwen yo.   
\q1
\v 7 SENYÈ a se fòs mwen ak boukliye mwen.  
\q1 Kè m \x + \xo 28:7 \xt Sòm 13:5\x*mete konfyans nan Li, e mwen  
\q1 jwenn sekou.  
\q1 Pou sa, kè m leve wo nèt.  
\q1 Avèk chanson mwen, mwen va di Li mèsi.   
\q1
\v 8 SENYÈ a se \x + \xo 28:8 \xt Sòm 20:6\x*fòs yo.  
\q1 Li se yon defans pou sove onksyone Li yo.   
\q1
\v 9 \x + \xo 28:9 \xt Sòm 80:1\x* Sove pèp Ou a, e beni eritaj pa Ou a.  
\q1 Devni bèje yo tou,  
\q1 e bay yo soutyen jis pou tout tan.   
\c 29  
\d Yon sòm David  
\q1
\v 1 \x + \xo 29:1 \xt I Kwo 16:28-29\x*Bay a SENYÈ a, O Fis a moun pwisan yo,  
\q1 bay a SENYÈ a, glwa avèk gwo fòs.   
\q1
\v 2 Bay a SENYÈ a, glwa ke non Li merite a.  
\q1 Adore SENYÈ a \x + \xo 29:2 \xt II Kwo 20:21\x*avèk tout sa ki sen.   
\b  
\q1
\v 3 Vwa SENYÈ a sou dlo yo.  
\q1 Bondye glwa a \x + \xo 29:3 \xt Job 37:4,5\x* fè tonnè gwonde, eklate.  
\q1 SENYÈ a sou anpil dlo.   
\q1
\v 4 Vwa SENYÈ a gen \x + \xo 29:4 \xt Sòm 68:33\x*gwo fòs.  
\q1 Vwa SENYÈ a ranpli ak majeste.   
\q1
\v 5 Vwa SENYÈ a fann bwa sèd yo.  
\q1 Wi, SENYÈ a fann an mòso \x + \xo 29:5 \xt Sòm 104:16\x* bwa sèd Liban yo.   
\q1
\v 6 Li fè Liban sote. Li ponpe tankou yon ti bèf, e  
\q1 \x + \xo 29:6 \xt Det 3:9\x*Sirion tankou yon jèn bèf mawon.   
\q1
\v 7 Vwa SENYÈ a koupe fè flanm dife.   
\q1
\v 8 Vwa SENYÈ a souke savann nan.  
\q1 Vwa SENYÈ a souke savann Kadès la.   
\q1
\v 9 Vwa SENYÈ a fè \x + \xo 29:9 \xt Job 39:1\x*bich la fè pitit.  
\q1 Li fè forè a vin toutouni.  
\q1 Nan tanp Li a, tout moun ki la yo rele: “Glwa”!   
\b  
\q1
\v 10 SENYÈ a te chita kon Wa nan gran inondasyon an.  
\q1 Wi, SENYÈ a chita kon \x + \xo 29:10 \xt Sòm 10:16 \x*Wa jis pou tout tan.   
\q1
\v 11 SENYÈ a va bay fòs a pèp Li a.  
\q1 SENYÈ a va beni pèp li a avèk \x + \xo 29:11 \xt Sòm 72:3 \x*lapè.   
\c 30  
\d Yon Sòm; yon chan nan Dedikasyon Kay La; Yon Sòm David  
\q1
\v 1 Mwen va leve Ou wo, O SENYÈ, paske Ou \x + \xo 30:1 \xt Sòm 3:3\x*te leve mwen.  
\q1 Ou pa t kite lènmi m yo rejwi sou mwen.   
\q1
\v 2 O SENYÈ, Bondye mwen an, mwen te kriye a Ou menm,  
\q1 e Ou te \x + \xo 30:2 \xt És 53:5\x*geri mwen.   
\q1
\v 3 O SENYÈ, Ou te fè nanm mwen monte kite sejou lanmò yo.  
\q1 Ou te kenbe m vivan, pou m pa t desann nan gwo fòs la.   
\q1
\v 4 Chante lwanj a SENYÈ a, nou menm ki fidèl Li yo.  
\q1 Bay remèsiman a \x + \xo 30:4 \xt Os 12:5 \x*sen non Li.   
\q1
\v 5 Paske kòlè Li se sèlman pou yon moman,  
\q1 men Bonte Li se pou tout tan.  
\q1 Kriye a kapab dire \x + \xo 30:5 \xt II Kwo 4:17 \x*pou nwit lan,  
\q1 men kri lajwa a vin parèt nan maten.   
\q1
\v 6 Alò, pou mwen, mwen te di nan bon tan mwen,  
\q1 “Mwen \x + \xo 30:6 \xt Sòm 10:6\x*p ap janm ebranle.”   
\q1
\v 7 O SENYÈ, pa gras Ou, Ou te fè mòn mwen an kanpe fèm.  
\q1 Lè Ou te kache figi Ou, mwen te dekouraje nèt.   
\q1
\v 8 A Ou menm, SENYÈ, mwen te rele.  
\q1 A SENYÈ mwen an, mwen te fè siplikasyon mwen yo:   
\q1
\v 9 “Ki benefis ki genyen nan san mwen  
\q1 si mwen \x + \xo 30:9 \xt Sòm 28:1\x*desann nan gwo fòs la?  
\q1 Èske pousyè a kab louwe Ou?  
\q1 Èske li va deklare fidelite Ou?   
\q1
\v 10 Tande, O SENYÈ e fè m gras.  
\q1 O SENYÈ, \x + \xo 30:10 \xt Sòm 27:9\x*ban m soutyen.”   
\q1
\v 11 Ou te chanje doulè mwen, e  
\q1 sa te fè m vin danse ak lajwa;  
\q1 Ou te \x + \xo 30:11 \xt És 20:2\x*demare rad twal sak mwen an,  
\q1 e te mare senti m avèk kè kontan.   
\q1
\v 12 Konsa, pou kè m kab chante lwanj Ou, e pa rete an silans.  
\q1 O SENYÈ, Bondye mwen an, mwen va  
\q1 bay Ou glwa pou tout tan, nèt.   
\c 31  
\d Yon Sòm David  
\q1
\v 1 Nan Ou menm, SENYÈ, mwen kache.  
\q1 Pa janm kite mwen \x + \xo 31:1 \xt Sòm 25:2\x*vin wont.  
\q1 Nan ladwati Ou, delivre mwen.   
\q1
\v 2 Panche zòrèy W bò kote mwen.  
\q1 Delivre mwen byen vit.  
\q1 Devni pou mwen \x + \xo 31:2 \xt Sòm 18:2\x*wòch ki ban m fòs,  
\q1 yon sitadèl ki pou sove m.   
\q1
\v 3 Paske Ou se wòch mwen ak sitadèl mwen,  
\q1 konsa, pou koz a non Ou, Ou va gide mwen.   
\q1
\v 4 Ou va rale m sòti nan filè ke yo te  
\q1 prepare an sekrè pou mwen an,  
\q1 paske se Ou ki fòs mwen.   
\q1
\v 5 \x + \xo 31:5 \xt Luc 23:46\x*Nan men Ou, mwen mete lespri mwen.  
\q1 Ou te rachte m, O SENYÈ, Bondye verite a.   
\q1
\v 6 Mwen rayi sila ki fè rega a fo zidòl yo,  
\q1 men nan Bondye, mwen \x + \xo 31:6 \xt Sòm 52:8\x*mete konfyans mwen.   
\q1
\v 7 Mwen va rejwi e fè kè kontan nan  
\q1 lanmou dous Ou, akoz Ou te wè soufrans mwen.  
\q1 Ou te \x + \xo 31:7 \xt Sòm 10:14\x*wè soufrans a nanm mwen.   
\q1
\v 8 \x + \xo 31:8 \xt Det 32:30\x*Ou pa t lage mwen nan men a lènmi an.  
\q1 Ou te mete pye mwen nan yon kote byen laj.   
\q1
\v 9 Fè m gras, O SENYÈ, paske mwen nan gwo twoub.  
\q1 Zye m ak kò m ak nanm mwen;  
\q1 tout fin gate nèt akoz doulè m.   
\q1
\v 10 Paske lavi m fin pase nèt ak gwo doulè m,  
\q1 ane mwen yo avèk soupi.  
\q1 \x + \xo 31:10 \xt Sòm 39:11\x*Fòs mwen fin ale akoz inikite m.  
\q1 Kò mwen fin epwize.   
\q1
\v 11 Akoz tout advèsè mwen yo, mwen te  
\q1 devni yon objè \x + \xo 31:11 \xt Sòm 69:19\x*abominab,  
\q1 sitou a vwazen mwen yo, e yon  
\q1 objè laperèz a sila ki rekonèt mwen yo.  
\q1 Sila ki wè m nan lari yo sove ale devan m.   
\q1
\v 12 Mwen fin \x + \xo 31:12 \xt Sòm 88:5\x*bliye tankou yon moun mouri,  
\q1 disparèt nan panse moun.  
\q1 Mwen tankou yon veso ki fin kraze.   
\q1
\v 13 Paske mwen konn tande kout lang  
\q1 anpil moun, laperèz toupatou.  
\q1 \x + \xo 31:13 \xt Mat 27:1\x*Yo pran konsèy ansanm kont mwen.  
\q1 Yo te fè konplo pou rache lavi m.   
\q1
\v 14 Men pou mwen, mwen mete konfyans nan Ou, O SENYÈ.  
\q1 Mwen di: \x + \xo 31:14 \xt Sòm 140:6\x*“Se Ou menm ki Bondye mwen”.   
\q1
\v 15 Moman mwen yo nan men Ou.  
\q1 \x + \xo 31:15 \xt Sòm 143:9 \x*Delivre mwen nan men a lènmi mwen yo,  
\q1 avèk sila ki pèsekite mwen yo.   
\q1
\v 16 Fè limyè figi Ou vin parèt sou sèvitè Ou a.  
\q1 \x + \xo 31:16 \xt Sòm 6:4\x*Sove mwen nan lanmou dous Ou a.   
\q1
\v 17 Pa kite mwen fè wont, O SENYÈ,  
\q1 paske se Ou ke m rele.   
\q1
\v 18 Kite lèv ki manti yo sispann,  
\q1 sila yo k ap \x + \xo 31:18 \xt Jd 15 \x*pale ak awogans kont moun dwat yo,  
\q1 k ap fè ògèy pou desann moun.   
\q1
\v 19 Men a la gran, \x + \xo 31:19 \xt És 64:4\x*bonte ke Ou  
\q1 te konsève pou sila ki krent Ou yo,  
\q1 ke Ou te fòje pou sila ki kache nan Ou yo, devan fis a lòm yo!   
\q1
\v 20 Ou kache yo nan kote sekrè a prezans Ou, kont tout \x + \xo 31:20 \xt Sòm 37:12 \x*manèv a lòm.  
\q1 Ou konsève yo an sekrè nan yon pwotèj  
\q1 kont konplo a tout lang lèzòm.   
\q1
\v 21 Beni se SENYÈ a,  
\q1 paske li te fè mèvèy a lanmou dous Li a  
\q1 anvè mwen nan yon \x + \xo 31:21 \xt I Sam 23:7 \x*vil byen fò.   
\q1
\v 22 Pou mwen, mwen te di ak kè sote mwen:  
\q1 “Mwen \x + \xo 31:22 \xt És 38:11-12\x*koupe retire nèt devan zye Ou”.  
\q1 Sepandan, Ou te tande vwa a siplikasyon mwen yo  
\q1 lè m te kriye a Ou menm.   
\q1
\v 23 O renmen SENYÈ a, nou tout, moun fidèl yo!  
\q1 SENYÈ a toujou \x + \xo 31:23 \xt Sòm 145:20\x*prezève moun fidèl yo,  
\q1 e bay pwòp rekonpans a sila ki plen ògèy yo.   
\q1
\v 24 Kenbe fèm e \x + \xo 31:24 \xt Sòm 27:14\x*kite kè ou pran kouraj,  
\q1 nou tout ki mete espwa nan SENYÈ a.   
\c 32  
\d Yon Sòm David. Yon Sòm Refleksyon  
\q1
\v 1 \x + \xo 32:1 \xt Sòm 85:2\x*A la beni se sila ki padone pou transgresyon li,  
\q1 pou peche li ki kouvri a!   
\q1
\v 2 A la nonm beni se sila SENYÈ a pa jije kon koupab la,  
\q1 e nan lespri a sila \x + \xo 32:2 \xt Jn 1:47\x* ki pa gen manti a.   
\q1
\v 3 Lè m te \x + \xo 32:3 \xt Sòm 39:2-3\x*kenbe silans selon peche mwen,  
\q1 kò m te desann bese nèt e mwen t ap plenyen tout lajounen.   
\q1
\v 4 Paske lajounen kon lannwit,  
\q1 \x + \xo 32:4 \xt I Sam 5:6\x*men Ou te lou sou mwen.  
\q1 Fòs mwen te epwize vin bese  
\q1 tankou gwo chalè nan gran sezon ete. \qs Tan\qs*   
\q1
\v 5 Mwen te vin rekonèt peche m devan Ou,  
\q1 e inikite mwen, mwen pa t ankò kache.  
\q1 Mwen te di: \x + \xo 32:5 \xt I Jn 1:9\x*“Mwen va konfese transgresyon mwen yo a SENYÈ a”,  
\q1 epi Ou te padone koupabilite m pou peche mwen yo.   
\q1
\v 6 Konsa, kite tout sila ki fidèl yo priye vè Ou menm,  
\q1 \x + \xo 32:6 \xt Sòm 69:13\x*nan yon lè ke Ou toujou disponib.  
\q1 Anverite, nan gran flèv dlo yo,  
\q1 yo p ap kab rive kote Li ankò.   
\q1
\v 7 Ou se kote ke m konn kache a.  
\q1 Ou \x + \xo 32:7 \xt Sòm 121:7 \x*pwoteje mwen kont gwo twoub.  
\q1 Ou antoure mwen avèk chanson delivrans yo.   
\q1
\v 8 Mwen va \x + \xo 32:8 \xt Sòm 25:8\x*enstwi ou e fè ou aprann chemen  
\q1 nan sila ou dwe ale a.  
\q1 Mwen va bay ou konsèy avèk zye M sou ou.   
\q1
\v 9 Pa fè \x + \xo 32:9 \xt Pwov 26:3\x*tankou cheval oswa milèt ki pa gen konprann menm,  
\q1 ki nan tout sikonstans, oblije gen brid ak bosal ki pou ralanti yo.  
\q1 Otreman, yo p ap vin kote ou.   
\q1
\v 10 Anpil se \x + \xo 32:10 \xt Wo 2:9\x*tristès a mechan yo,  
\q1 men sila ki mete konfyans li nan SENYÈ a,  
\q1 se lanmou dous ki va antoure li.   
\q1
\v 11 Fè kè kontan nan SENYÈ a e rejwi, nou menm ki jis!  
\q1 Rele avèk jwa, nou tout \x + \xo 32:11 \xt Sòm 7:10\x*ki dwat nan kè nou yo.   
\c 33  
\q1
\v 1 Rejwi ak lajwa nan SENYÈ a, O moun ladwati yo!  
\q1 Lwanj \x + \xo 33:1 \xt Sòm 92:1\x*bèl lè l sòti nan moun ki dwat.   
\q1
\v 2 \x + \xo 33:2 \xt Sòm 71:22\x*Bay remèsiman a SENYÈ avèk gita.  
\q1 Chante lwanj a Li menm avèk ap dis kòd.   
\q1
\v 3 Chante a Li menm yon chan tounèf.  
\q1 Jwe ak kapasite e fò avèk yon \x + \xo 33:3 \xt Sòm 98:4\x*gwo kri lajwa.   
\q1
\v 4 Paske pawòl SENYÈ a dwat.  
\q1 Tout zèv Li yo fèt \x + \xo 33:4 \xt Sòm 119:90 \x*avèk fidelite.   
\q1
\v 5 Li \x + \xo 33:5 \xt Sòm 11:7\x*renmen ladwati avèk jistis.  
\q1 Latè ranpli avèk lanmou dous SENYÈ a.   
\q1
\v 6 Avèk pawòl SENYÈ a syèl yo te fèt:  
\q1 pa souf a bouch Li, \x + \xo 33:6 \xt Jen 2:1\x*tout lame syèl yo.   
\q1
\v 7 Li ranmase tout \x + \xo 33:7 \xt Egz 15:8\x*dlo lanmè yo ansanm pou fè yon gwo pil.  
\q1 Li fè tout pwofondè yo kouche fè kay depo.   
\q1
\v 8 Kite \x + \xo 33:8 \xt Sòm 67:7\x*tout latè krent SENYÈ a.  
\q1 Kite tout sila ki rete nan mond lan  
\q1 kanpe etone nèt pa Li menm.   
\q1
\v 9 Paske \x + \xo 33:9 \xt Jen 1:3\x*Li te pale e mond lan te fèt.  
\q1 Li te kòmande e li te kanpe fèm.   
\q1
\v 10 SENYÈ a \x + \xo 33:10 \xt Sòm 2:1-3\x*ranvèse konsèy a nasyon yo.  
\q1 Li anile pwojè a pèp yo.   
\q1
\v 11 \x + \xo 33:11 \xt Job 23:12\x*Konsèy SENYÈ a kanpe jis pou tout tan,  
\q1 e pwojè a kè Li yo de jenerasyon an jenerasyon.   
\q1
\v 12 Beni se nasyon ki gen Bondye kon SENYÈ yo,   
\q1
\v 13 pèp ke Li te \x + \xo 33:13 \xt Egz 19:5 \x*chwazi pou pwòp eritaj Li a.  
\q1 SENYÈ a \x + \xo 33:13 \xt Job 28:24\x*gade depi nan syèl la.  
\q1 Li wè tout fis a lòm yo.   
\q1
\v 14 Soti nan \x + \xo 33:14 \xt I Wa 8:39-43\x*abitasyon Li an,  
\q1 Li veye sou tout sila ki rete sou latè yo.   
\q1
\v 15 Li menm ki \x + \xo 33:15 \xt Job 10:8\x*fòme kè a yo tout,  
\q1 Li menm ki konprann tout zèv yo.   
\q1
\v 16 \x + \xo 33:16 \xt Sòm 44:6\x*Wa a pa sove pa yon lame pwisan.  
\q1 Yon gèrye pa delivre pa gran fòs Li.   
\q1
\v 17 Yon cheval se yon \x + \xo 33:17 \xt Sòm 20:7\x*fo espwa pou viktwa a,  
\q1 ni li p ap delivre pèsòn ak pwisans li.   
\q1
\v 18 Veye byen, zye SENYÈ a sou sila ki krent Li yo,  
\q1 sou sila ki \x + \xo 33:18 \xt Sòm 32:10\x*mete espwa yo nan lanmou dous Li a,   
\q1
\v 19 pou \x + \xo 33:19 \xt Sòm 56:13\x*delivre nanm pa yo devan lanmò,  
\q1 e kenbe yo vivan nan gwo grangou.   
\q1
\v 20 Nanm nou \x + \xo 33:20 \xt És 8:17\x*ap tann SENYÈ a.  
\q1 Se Li menm ki sekou nou ak boukliye nou.   
\q1
\v 21 Paske \x + \xo 33:21 \xt Za 10:7\x*kè nou rejwi nan Li, akoz  
\q1 nou mete konfyans nou nan sen non Li.   
\q1
\v 22 Kite lanmou dous Ou, O SENYÈ, vin poze sou nou,  
\q1 selon esperans ke nou te mete nan Ou a.   
\c 34  
\d Yon Sòm David lè l te parèt tankou moun fou devan Abimélec ki te pouse l ale, epi konsa, li te pati.  
\q1
\v 1 Mwen va \x + \xo 34:1 \xt Ef 5:20\x*beni SENYÈ a nan tout tan.  
\q1 Lwanj Li va toujou nan bouch mwen.   
\q1
\v 2 Nanm mwen va \x + \xo 34:2 \xt Jr 9:24\x*fè glwa li nan SENYÈ a.  
\q1 Enb yo va tande l, e yo va rejwi.   
\q1
\v 3 O leve SENYÈ a byen wo avè m.  
\q1 Annou \x + \xo 34:3 \xt Sòm 18:46\x*leve non L wo ansanm.   
\q1
\v 4 Mwen te \x + \xo 34:4 \xt Mat 7:7\x*chache SENYÈ a e Li te reponn mwen,  
\q1 epi te delivre mwen de tout perèz mwen yo.   
\q1
\v 5 Yo te gade vè Li, e te vin ranpli ak limyè.  
\q1 Figi yo \x + \xo 34:5 \xt Sòm 25:3\x*p ap janm wont.   
\q1
\v 6 Malere sila a te rele, e SENYÈ a te tande li,  
\q1 epi \x + \xo 34:6 \xt Sòm 34:4\x*te sove li sòti nan tout twoub li yo.   
\q1
\v 7 \x + \xo 34:7 \xt Sòm 91:11\x*Zanj SENYÈ a fè kan antoure sila ki krent Li yo,  
\q1 epi li sove yo nan gwo twoub.   
\q1
\v 8 O goute e wè ke Bondye bon.  
\q1 A la beni nonm \x + \xo 34:8 \xt Sòm 2:12\x*ki kache nan Li a beni!   
\q1
\v 9 Krent SENYÈ a, O nou menm ki \x + \xo 34:9 \xt Sòm 31:23\x*sen Li yo.  
\q1 Pou sila ki krent Li yo, anyen pa manke.   
\q1
\v 10 Jenn ti lyon yo konn manke manje e soufri grangou,  
\q1 men sila ki chache SENYÈ yo,  
\q1 \x + \xo 34:10 \xt Sòm 84:11\x*p ap manke okenn bon bagay.   
\b  
\q1
\v 11 Vini, pitit, koute mwen.  
\q1 Mwen va enstwi ou nan \x + \xo 34:11 \xt Sòm 111:10\x*lakrent SENYÈ a.   
\q1
\v 12 Se ki moun ki dezire lavi, e renmen  
\q1 jou li yo pou li kapab \x + \xo 34:12 \xt Ekl 3:13\x*wè sa ki bon?   
\q1
\v 13 Kenbe \x + \xo 34:13 \xt Pwov 13:3\x*lang ou apa de sa ki mal,  
\q1 e lèv ou pou pa bay manti.   
\q1
\v 14 Kite sa ki mal la epi fè sa ki bon.  
\q1 \x + \xo 34:14 \xt És 1:16\x*Chache lapè e fè efò pou twouve li.   
\q1
\v 15 \x + \xo 34:15 \xt Job 36:7\x*Zye a SENYÈ a sou sila ki dwat yo.  
\q1 Zòrèy Li koute kri yo.   
\q1
\v 16 Figi SENYÈ a kont malfektè yo,  
\q1 pou \x + \xo 34:16 \xt Am 9:4\x*efase memwa yo sou tè a.   
\q1
\v 17 \x + \xo 34:17 \xt Sòm 34:6\x*Moun dwat kriye.  
\q1 SENYÈ a tande e vin delivre yo tout nan tout twoub yo.   
\q1
\v 18 SENYÈ a pre sila ak kè kase yo,  
\q1 epi sove sila ki \x + \xo 34:18 \xt És 57:15\x*kraze nan lespri yo.   
\q1
\v 19 Anpil, se \x + \xo 34:19 \xt II Tim 3:11\x*afliksyon a moun dwat la,  
\q1 men SENYÈ a delivre li sòti nan yo tout.   
\q1
\v 20 Li konsève tout zo li yo.  
\q1 \x + \xo 34:20 \xt Jn 19:33-36\x*Pa menm youn nan yo va kase.   
\q1
\v 21 Se \x + \xo 34:21 \xt Sòm 94:23\x*mechanste ki va touye mechan an.  
\q1 Sila ki rayi moun ladwati yo va kondane.   
\q1
\v 22 SENYÈ a rachte nanm a sèvitè Li yo.  
\q1 P ap gen nan sila ki \x + \xo 34:22 \xt Sòm 37:40\x*kache nan Li yo  
\q1 k ap kondane.   
\c 35  
\d Yon Sòm David  
\q1
\v 1 Fè fòs SENYÈ, kont sila k ap sèvi ak fòs kont mwen yo.  
\q1 Goumen ak sila k ap \x + \xo 35:1 \xt Sòm 56:2\x*goumen kont mwen yo.   
\q1
\v 2 Pran an men boukliye ak pwotèj la,  
\q1 epi leve kon \x + \xo 35:2 \xt Sòm 44:26\x*sekou mwen.   
\q1
\v 3 Anplis rale lans ak rach batay la pou  
\q1 rankontre sila k ap kouri dèyè m yo.  
\q1 Pale ak nanm mwen “Se Mwen ki delivrans ou”!   
\q1
\v 4 Kite sila k ap chache lavi m yo vin wont e dezonore.  
\q1 Kite sa yo ki anvizaje mal pou mwen  
\q1 Vire do fè bak plen imiliyasyon.   
\q1
\v 5 Kite yo vin \x + \xo 35:5 \xt Sòm 83:13\x*tankou pay nan van,  
\q1 avèk zanj SENYÈ a k ap pouse yo ale.   
\q1
\v 6 \x + \xo 35:6 \xt Sòm 73:18\x*Kite wout yo plen avèk tenèb e vin glisan,  
\q1 Avèk zanj SENYÈ a k ap kouri dèyè yo.   
\q1
\v 7 Paske san koz, yo te kache \x + \xo 35:7 \xt Sòm 9:15\x*pèlen yo pou mwen.  
\q1 San koz, yo te fouye yon fòs pou nanm mwen.   
\q1
\v 8 Kite l \x + \xo 35:8 \xt I Tes 5:3\x*fin detwi nèt san l pa konnen.  
\q1 Kite pèlen ke li te prepare a, kenbe li menm.  
\q1 Kite l tonbe nan destriksyon sa a.   
\b  
\q1
\v 9 Nanm mwen va rejwi nan SENYÈ a.  
\q1 Li va \x + \xo 35:9 \xt Sòm 9:14\x*leve wo nan delivrans Li.   
\q1
\v 10 Tout zo m menm va di: “SENYÈ, se \x + \xo 35:10 \xt Egz 15:11\x*kilès ki tankou Ou menm?  
\q1 Kilès ki delivre aflije yo nan men a sila ki twò fò pou li yo?  
\q1 Wi, ak aflije e malere yo k ap soti  
\q1 nan men a sila menm k ap vòlè yo?”   
\q1
\v 11 \x + \xo 35:11 \xt Sòm 27:12\x*Fo temwen sovaj yo leve.  
\q1 Yo mande mwen bagay ke m pa menm konnen.   
\q1
\v 12 Yo \x + \xo 35:12 \xt Jr 18:20\x*remèt mwen mal pou byen,  
\q1 jiskaske gwo tristès antre nan nanm mwen.   
\b  
\q1
\v 13 Men pou mwen menm, lè yo te malad,  
\q1 \x + \xo 35:13 \xt Sòm 69:11\x*rad mwen te vin twal sak;  
\q1 Mwen te imilye nanm mwen nan fè jèn,  
\q1 epi lapriyè m te kontinye retounen  
\q1 nan kè m.   
\q1
\v 14 Mwen te ale toupatou konsi se te zanmi mwen, oswa frè mwen.  
\q1 Mwen te \x + \xo 35:14 \xt Sòm 38:6\x*koube ak gwo tristès,  
\q1 tankou yon moun ta fè dèy pou manman li.   
\q1
\v 15 Men moman ke m te chape tonbe a,  
\q1 yo te \x + \xo 35:15 \xt Ab 12\x*rejwi, e te reyini yo ansanm.  
\q1 San ke mwen pa menm konnen,  
\q1 agresè sa yo te rasanble kont mwen.  
\q1 Yo t ap chire m san rete.   
\q1
\v 16 Kon giyon vilgè, yo te \x + \xo 35:16 \xt Sòm 37:12\x*fè konsi yo  
\q1 ta mòde m ak dan yo.   
\q1
\v 17 SENYÈ, \x + \xo 35:17 \xt Hab 1:13\x*jiskilè Ou va kontinye  
\q1 gade bagay sa a konsa?  
\q1 Sove nanm mwen kont ravaj yo,  
\q1 Sèl lavi mwen genyen kont lyon yo.   
\q1
\v 18 Mwen va \x + \xo 35:18 \xt Sòm 22:22\x*bay Ou remèsiman nan gran asanble a.  
\q1 Mwen va bay Ou glwa pami yon gran foul.   
\q1
\v 19 Pa kite sila ki lènmi m san koz yo, rejwi sou mwen.  
\q1 Ni pa kite sila ki rayi mwen san koz yo, fè kout zye sou mwen.   
\q1
\v 20 Paske yo pa pale lapè,  
\q1 men yo divize pawòl nan \x + \xo 35:20 \xt Jr 9:7\x*twonpe sila ki kalm nan peyi yo.   
\q1
\v 21 Yo te ouvri bouch yo laj kont mwen.  
\q1 Yo te di: \x + \xo 35:21 \xt Sòm 40:15 \x*“Men li, men li, zye nou te wè l!”   
\q1
\v 22 Ou te wè sa, O SENYÈ, pa rete an silans  
\q1 O SENYÈ, \x + \xo 35:22 \xt Sòm 10:1\x*pa rete lwen m.   
\q1
\v 23 \x + \xo 35:23 \xt Sòm 7:6\x*Reveye Ou! Reveye Ou pou dwa m ak koz mwen,  
\q1 Bondye mwen ak SENYÈ mwen.   
\q1
\v 24 \x + \xo 35:24 \xt Sòm 9:4\x*Jije mwen, O SENYÈ, Bondye mwen an, selon dwati Ou.  
\q1 Pa kite yo rejwi sou mwen.   
\q1
\v 25 Pa kite yo di nan kè yo:  
\q1 “Men konsa, men sa nou pi pito a!”  
\q1 Pa kite yo di: “Nou gen tan \x + \xo 35:25 \xt Pwov 1:12\x*fin vale li nèt!”   
\q1
\v 26 Kite sila ki rejwi nan gwo twoub mwen yo wont.  
\q1 Kite sila ki leve yo menm sou mwen yo vin abiye ak wont avèk imilyasyon.   
\b  
\q1
\v 27 Kite sila ki vle wè kòz dwat mwen yo rele avèk jwa e rejwi.  
\q1 Kite yo di tout tan: “Leve SENYÈ a wo,  
\q1 Li ki \x + \xo 35:27 \xt Sòm 147:11 \x*pran plezi lè sèvitè li byen reyisi.”   
\q1
\v 28 Konsa, lang mwen va deklare ladwati Ou  
\q1 avèk lwanj Ou tout lajounen.   
\c 36  
\d Pou direktè koral la; Yon Sòm David, sèvitè SENYÈ a  
\q1
\v 1 Se Peche ki pale nan fon kè a lòm ki san Bondye.  
\q1 Nanpwen \x + \xo 36:1 \xt Wo 3:18\x*krent Bondye devan zye l.   
\q1
\v 2 Jan li kontan ak pwòp tèt li,  
\q1 li pa janm wè pwòp peche pa l la.   
\q1
\v 3 \x + \xo 36:3 \xt Sòm 10:7\x*Pawòl a bouch li se mechanste avèk manti.  
\q1 Li fè yon chemen ki pa bon.   
\q1
\v 4 Sou kabann li, li fè plan mechan;  
\q1 Li antre nan yon wout ki p ap sòti byen;  
\q1 Li \x + \xo 36:4 \xt Wo 12:9\x*pa rayi mal.   
\b  
\q1
\v 5 \x + \xo 36:5 \xt Sòm 57:10\x*Lanmou dous Ou, O SENYÈ, rive jis nan syèl yo,  
\q1 fidelite Ou nan syèl la.   
\q1
\v 6 Ladwati Ou se tankou mòn Bondye yo,  
\q1 e\x + \xo 36:6 \xt Wo 11:33\x*jijman Ou yo tankou yon gran pwofondè.  
\q1 O SENYÈ, Ou prezève ni lòm, ni bèt.   
\q1
\v 7 Lanmou dous Ou chè, O Bondye!  
\q1 Pitit a lòm yo \x + \xo 36:7 \xt Rt 2:12\x*pran azil anba lonbraj zèl Ou.   
\q1
\v 8 Yo \x + \xo 36:8 \xt És 25:6\x*bwè jiskaske yo vin plen an abondans lakay Ou.  
\q1 Konsa,Ou bay yo bwè nan rivyè plezi Ou yo.   
\q1
\v 9 Paske avèk Ou, se \x + \xo 36:9 \xt Jr 2:13\x*fontèn dlo lavi a.  
\q1 Nan limyè pa Ou a, nou wè limyè.   
\q1
\v 10 O bay toujou lanmou dous Ou a pou sila ki konnen Ou yo,  
\q1 ak \x + \xo 36:10 \xt Sòm 24:5\x*ladwati Ou pou sila ki dwat nan kè yo.   
\q1
\v 11 Pa kite pye ògèy vini sou mwen,  
\q1 ni pa kite men a mechan yo chase mwen ale.   
\q1
\v 12 Se la \x + \xo 36:12 \xt Sòm 140:10\x*sila k ap fè inikite yo gen tan fin tonbe.  
\q1 Yo te peze desann ak fòs, e yo p ap kab leve ankò.   
\c 37  
\d Yon Sòm David  
\q1
\v 1 Pa twouble tèt ou akoz mechan yo. Pa vin \x + \xo 37:1 \xt Sòm 73:3\x*pote lanvi pou malfektè yo.   
\q1
\v 2 Paske yo va \x + \xo 37:2 \xt Job 14:2\x*fennen vit tankou zèb chan,  
\q1 e disparèt tankou zèb ki vèt.   
\q1
\v 3 Mete konfyans ou nan SENYÈ a, e fè sa ki bon.  
\q1 \x + \xo 37:3 \xt Éz 34:13-14\x*Demere nan peyi a e kiltive nan bon tè.   
\q1
\v 4 Pran plezi ou nan SENYÈ a.  
\q1 Konsa, Li va \x + \xo 37:4 \xt Sòm 145:19\x*bay ou tout dezi a kè ou.   
\q1
\v 5 \x + \xo 37:5 \xt Pwov 16:3\x*Dedye chemen ou a SENYÈ a.  
\q1 Mete konfyans nan Li, e sa L ap fè:   
\q1
\v 6 Li va mennen fè parèt ladwati ou kon limyè,  
\q1 Ak jijman ou klere \x + \xo 37:6 \xt Job 11:17 \x*kon midi.   
\q1
\v 7 Pran repo nan SENYÈ a, e \x + \xo 37:7 \xt Sòm 40:1\x*tann Li ak pasyans;  
\q1 Pa twouble ou akoz sila ki reyisi nan chemen li an,  
\q1 Akoz nonm nan ki reyisi fè manèv mechan li yo.   
\q1
\v 8 Sispann fache pou l pa mennen ou nan fè mal.  
\q1 Pa kite kè ou twouble; l ap mennen ou nan mechanste   
\q1
\v 9 Konsa, \x + \xo 37:9 \xt Sòm 37:2-22\x*malfektè yo va koupe retire nèt,  
\q1 men sila k ap tann SENYÈ yo,  
\q1 va vin genyen peyi a kon eritaj yo.   
\q1
\v 10 Men yon \x + \xo 37:10 \xt Job 24:24\x*ti tan ankò, mechan an va disparèt.  
\q1 Ou va chache avèk atansyon plas li,  
\q1 men li p ap egziste.   
\q1
\v 11 Konsa, \x + \xo 37:11 \xt Mat 5:5\x*enb yo va fè eritaj peyi a.  
\q1 Yo va pran plezi yo nan reyisi anpil.   
\q1
\v 12 Mechan an \x + \xo 37:12 \xt Sòm 31:13-20\x*fè konplo kont sila ki dwat yo.  
\q1 Li manje dan l sou li.   
\q1
\v 13 SENYÈ a ri sou li, paske Li wè ke \x + \xo 37:13 \xt I Sam 26:10 \x*jou li a ap rive.   
\q1
\v 14 Mechan yo rale nepe e \x + \xo 37:14 \xt Lam 2:4\x*koube banza yo,  
\q1 pou jete aflije yo avèk malere a,  
\q1 pou touye sila ki dwat nan kondwit yo.   
\q1
\v 15 Nepe yo va antre nan pwòp kè yo.  
\q1 \x + \xo 37:15 \xt I Sam 2:4\x*Banza yo ap kase.   
\q1
\v 16 \x + \xo 37:16 \xt Pwov 15:16\x*Pi bon se ti kras a moun dwat yo,  
\q1 pase abondans anpil a mechan yo.   
\q1
\v 17 Paske bra a mechan yo va kase,  
\q1 men SENYÈ a va ranfòse moun dwat yo.   
\q1
\v 18 SENYÈ a \x + \xo 37:18 \xt Sòm 1:6\x*konnen jou a sila ki dwat yo.  
\q1 Eritaj yo va dire jis pou tout tan.   
\q1
\v 19 Yo p ap wont nan move tan.  
\q1 Nan \x + \xo 37:19 \xt Job 5:20\x*jou gwo grangou yo, y ap jwenn kont.   
\b  
\q1
\v 20 Men mechan yo va peri.  
\q1 Lènmi a SENYÈ a, tankou laglwa a bèl chan yo.  
\q1 Yo va vin disparèt.  
\q1 Tankou \x + \xo 37:20 \xt Sòm 68:2 \x*lafimen,  
\q1 yo ale nèt.   
\q1
\v 21 Mechan an prete, men li pa remèt,  
\q1 men moun dwat la \x + \xo 37:21 \xt Sòm 112:5-9\x*ranpli ak gras pou l ka bay an abondans.   
\q1
\v 22 Paske sila ke Bondye beni yo, va \x + \xo 37:22 \xt Pwov 3:33\x*eritye peyi a,  
\q1 men sila ke Li modi yo, va vin koupe retire nèt.   
\q1
\v 23 \x + \xo 37:23 \xt I Sam 2:9\x*Pa a yon nonm etabli pa SENYÈ a.  
\q1 Konsa, Li pran plezi nan chemen li.   
\q1
\v 24 Lè \x + \xo 37:24 \xt Pwov 24:15\x*li tonbe, li p ap voye tèt anba nèt,  
\q1 paske SENYÈ a se Sila ki kenbe men li an.   
\q1
\v 25 Mwen te jèn e koulye a, mwen fin granmoun,  
\q1 men \x + \xo 37:25 \xt Eb 13:5\x*mwen poko wè moun dwat ki abandone,  
\q1 ni desandan li yo k ap mande pen.   
\q1
\v 26 Tout lajounen, \x + \xo 37:26 \xt Det 15:8\x* moun dwat la  
\q1 plen ak gras pou prete moun.  
\q1 Desandan li yo se yon benediksyon.   
\q1
\v 27 Kite mal e fè sa ki bon,  
\q1 pou ou kab viv \x + \xo 37:27 \xt Sòm 102:28 \x*jis pou tout tan.   
\q1
\v 28 Paske SENYÈ a renmen jistis,  
\q1 e li pa abandone fidèl li yo.  
\q1 Yo prezève pou tout tan,  
\q1 men mechan yo va vin koupe retire nèt.   
\q1
\v 29 Moun ladwati yo va \x + \xo 37:29 \xt Sòm 37:9\x*eritye peyi a,  
\q1 pou viv ladann pou tout tan.   
\b  
\q1
\v 30 Bouch a moun dwat yo va eksprime sajès,  
\q1 epi lang li va \x + \xo 37:30 \xt Sòm 119:13 \x*pale jistis.   
\q1
\v 31 \x + \xo 37:31 \xt Det 6:6\x*Lalwa Bondye nan kè li.  
\q1 Pa li yo pa janm glise.   
\q1
\v 32 Mechan an ap veye dwat la  
\q1 pou \x + \xo 37:32 \xt Sòm 37:14\x*chache touye li.   
\q1
\v 33 SENYÈ a p ap kite l lantre nan men li,  
\q1 ni \x + \xo 37:33 \xt Sòm 34:22\x*kite li kondane lè li jije.   
\q1
\v 34 Tann SENYÈ a e kenbe chemen Li an.  
\q1 Konsa, Li va leve ou wo pou eritye peyi a.  
\q1 Lè \x + \xo 37:34 \xt Sòm 52:5-6\x*mechan yo koupe retire, ou va gen tan wè l.   
\b  
\q1
\v 35 Mwen konn \x + \xo 37:35 \xt Job 5:3\x*wè yon nonm mechan e vyolan  
\q1 Ki gaye kò l tankou yon gwo pyebwa nan tè peyi natal li.   
\q1
\v 36 Konsa, li mouri nèt, e vwala, li \x + \xo 37:36 \xt Job 20:5\x*pa t la ankò.  
\q1 Mwen te chache li, men li pa t kab twouve.   
\q1
\v 37 Byen remake nonm san tò a,  
\q1 epi gade byen nonm ladwati a,  
\q1 paske nonm lapè a va gen \x + \xo 37:37 \xt És 57:1-2\x*posterite.   
\q1
\v 38 Men pechè a va detwi nèt.  
\q1 Posterite a mechan an va \x + \xo 37:38 \xt Sòm 37:9\x*koupe retire nèt.   
\q1
\v 39 Men \x + \xo 37:39 \xt Sòm 3:8\x*delivrans a moun dwat yo soti nan SENYÈ a.  
\q1 Se Li menm ki fòs yo nan tan twoub la.   
\q1
\v 40 SENYÈ a ede yo e delivre yo.  
\q1 Li delivre yo soti nan men mechan yo e sove yo.  
\q1 Li sove yo, akoz se nan Li ke yo \x + \xo 37:40 \xt I Kwo 5:20 \x*kache.   
\c 38  
\d Youn Sòm David; tankou yon sonj memorab  
\q1
\v 1 O SENYÈ, \x + \xo 38:1 \xt Sòm 6:1\x*pa repwoche mwen nan kòlè Ou,  
\q1 ni fè m chatiman nan kòlè Ou k ap brile.   
\q1
\v 2 Paske \x + \xo 38:2 \xt Job 6:4\x*flèch Ou yo fin antre fon anndan m,  
\q1 epi men Ou fin peze m.   
\q1
\v 3 \x + \xo 38:3 \xt És 1:6\x*Nanpwen anyen ki ansante nan chè m,  
\q1 akoz endiyasyon Ou.  
\q1 Nanpwen lasante nan zo m yo  
\q1 akoz peche mwen.   
\q1
\v 4 Paske \x + \xo 38:4 \xt Esd 9:6\x*inikite mwen yo fin monte sou tèt mwen.  
\q1 Tankou yon fado lou, yo peze twòp pou mwen.   
\q1
\v 5 Blesi mwen yo vin santi e anfle akoz \x + \xo 38:5 \xt Sòm 69:5\x*foli mwen.   
\q1
\v 6 Mwen fin koube nèt e \x + \xo 38:6 \xt Sòm 35:14\x*bese anpil.  
\q1 Mwen ap fè doulè tout lajounen.   
\q1
\v 7 Paske ren mwen plen ak \x + \xo 38:7 \xt Sòm 102:3\x*brile.  
\q1 Nanpwen anyen ansante nan chè m.   
\q1
\v 8 Mwen \x + \xo 38:8 \xt Lam 1:13-20\x*pa kab santi anyen ankò.  
\q1 Mwen fin kraze nèt.  
\q1 Vwa m plenyen akoz kè m ajite.   
\q1
\v 9 SENYÈ, tout volonte m devan Ou.  
\q1 Tout \x + \xo 38:9 \xt Sòm 6:5 \x*plent a vwa m yo pa kache a Ou menm.   
\q1
\v 10 Kè m bat fò, \x + \xo 38:10 \xt Sòm 31:10\x*fòs mwen kite m.  
\q1 Menm limyè a zye m, menm sa fin kite mwen.   
\q1
\v 11 Pwòch mwen yo avèk zanmi mwen yo  
\q1 kanpe nan distans akoz touman m.  
\q1 Fanmi m yo \x + \xo 38:11 \xt Luc 23:49\x*kanpe byen lwen.   
\q1
\v 12 Sila ki chache lavi m yo, ap prepare pyèj yo pou mwen.  
\q1 Sila ki chache fè m donmaj yo ap fè menas destriksyon.  
\q1 Y ap manniganse trayizon tout lajounen.   
\q1
\v 13 Men mwen menm, tankou yon moun mouri,  
\q1 mwen pa tande;  
\q1 Epi se tankou yon bèbè, ki pa ouvri bouch li.   
\q1
\v 14 Wi, mwen tankou yon nonm ki pa tande.  
\q1 E nan bouch mwen, pa gen repons.   
\q1
\v 15 Paske mwen mete espwa m nan Ou, O SENYÈ.  
\q1 Ou \x + \xo 38:15 \xt Sòm 17:6\x*va reponn, O SENYÈ, Bondye mwen an.   
\q1
\v 16 Paske mwen te di: “Ke yo pa vin rejwi sou mwen.  
\q1 Pou lè pye m chape, pou yo \x + \xo 38:16 \xt Sòm 35:26\x*ta vante tèt yo kont mwen.”   
\q1
\v 17 Paske mwen prèt pou tonbe.  
\q1 \x + \xo 38:17 \xt Sòm 13:2\x*Tristès mwen devan m tout tan.   
\q1
\v 18 Konsa, mwen konfese inikite mwen.  
\q1 Mwen ranpli avèk \x + \xo 38:18 \xt II Kor 7:9-10 \x*regrè akoz peche m.   
\q1
\v 19 Men lènmi m yo plen kouraj e fò.  
\q1 Yo anpil ki \x + \xo 38:19 \xt Sòm 35:19\x*rayi mwen san koz.   
\q1
\v 20 Sila ki remèt mal pou byen yo  
\q1 se lènmi m akoz mwen swiv sa ki bon.   
\q1
\v 21 Pa abandone m, O SENYÈ.  
\q1 O Bondye m nan, \x + \xo 38:21 \xt Sòm 22:19\x*pa rete lwen m!   
\q1
\v 22 Fè vit pou ede mwen,  
\q1 O SENYÈ, delivrans mwen an!   
\c 39  
\d Pou direktè koral la. Pou Jeduthyèn. Yon Sòm David  
\q1
\v 1 Mwen te di, mwen va veye chemen mwen,  
\q1 pou m pa \x + \xo 39:1 \xt Job 2:10\x*fè peche ak lang mwen.  
\q1 Mwen va veye bouch mwen,  
\q1 konsi li gen yon brid ladann  
\q1 toutotan mechan yo rete nan prezans mwen.   
\q1
\v 2 Mwen te \x + \xo 39:2 \xt Sòm 38:13\x*tankou bèbè e mwen te rete an silans.  
\q1 Mwen te evite menm sa ki ta kab bon.  
\q1 Konsa, tristès mwen te vin pi mal.   
\q1
\v 3 \x + \xo 39:3 \xt Sòm 32:4\x*Kè m te cho anndan m.  
\q1 Pandan mwen t ap reflechi dife a t ap brile.  
\q1 Konsa, mwen te pale ak lang mwen:   
\q1
\v 4 SENYÈ, fè m konnen \x + \xo 39:4 \xt Job 6:11\x*longè a jou mwen yo.  
\q1 Fè m konnen ke m fèb anpil.   
\q1
\v 5 Gade byen, Ou te fè jou mwen yo kontwole  
\q1 tankou lajè a men m ki louvri.  
\q1 Lavi mwen konsi li pa anyen devan zye Ou.  
\q1 Anverite, lavi chak moun, \x + \xo 39:5 \xt Sòm 89:47\x*se yon sèl grenn souf.   
\q1
\v 6 Anverite, tout moun mache toupatou tankou yon lonbraj.  
\q1 \x + \xo 39:6 \xt I Kor 7:31\x*Anverite, yo fè gwo zen pou ryen.  
\q1 Li ranmase byen yo, men l pa konnen kilès k ap rasanble yo.   
\q1
\v 7 Konsa, SENYÈ, kisa m ap tann nan?  
\q1 \x + \xo 39:7 \xt Sòm 38:15\x*Espwa m se nan Ou.   
\q1
\v 8 \x + \xo 39:8 \xt Sòm 51:9-14\x*Delivre mwen de tout transgresyon mwen yo.  
\q1 Pa fè m repwòch a moun san sajès yo.   
\q1
\v 9 Mwen tounen tibebe.  
\q1 Mwen pa ouvri bouch mwen,  
\q1 akoz se \x + \xo 39:9 \xt II Sam 16:10\x*Ou ki te fè sa.   
\q1
\v 10 \x + \xo 39:10 \xt Job 9:34\x*Rete touman Ou sou mwen.  
\q1 Kou men Ou venk mwen.  
\q1 M ap peri.   
\q1
\v 11 Avèk repwòch, Ou fè chatiman  
\q1 a yon nonm pou inikite li.  
\q1 Ou \x + \xo 39:11 \xt Job 13:28\x*manje tankou mit nan rad sa ki konsidere  
\q1 pi chè pou li menm nan.  
\q1 Anverite, tout moun se sèlman yon souf.   
\q1
\v 12 Tande lapriyè mwen, O SENYÈ e  
\q1 prete zòrèy Ou a kri mwen.  
\q1 Pa rete an silans lè dlo ap koule nan zye m.  
\q1 Paske mwen se yon etranje devan Ou,  
\q1 yon vwayajè tankou tout papa zansèt mwen yo.   
\q1
\v 13 \x + \xo 39:13 \xt Job 7:19\x*Vire rega figi Ou lwen m, pou m kab ri ankò,  
\q1 avan ke m mouri pou m pa la ankò.”   
\c 40  
\d Pou direktè koral la; Yon Sòm David  
\q1
\v 1 Mwen te \x + \xo 40:1 \xt Sòm 25:5\x*tann avèk pasyans SENYÈ a.  
\q1 Li te enkline vè mwen e te tande kri mwen.   
\q1
\v 2 Li te mennen mwen sòti nan fòs k ap detwi a,  
\q1 sòti deyò gwo ma ajil la.  
\q1 Li te mete pye m sou wòch la e  
\q1 te \x + \xo 40:2 \xt Sòm 37:23\x*fè m kanpe byen fèm.   
\q1
\v 3 Li te mete yon \x + \xo 40:3 \xt Sòm 32:7\x*chanson nèf nan bouch mwen,  
\q1 yon chan lwanj Bondye nou an.  
\q1 Anpil moun va wè, vin gen lakrent e va  
\q1 mete konfyans nan Bondye.   
\q1
\v 4 A la \x + \xo 40:4 \xt Sòm 34:8\x*beni se nonm ki mete konfyans li nan SENYÈ a,  
\q1 e ki pa t vire vè moun ògèy yo,  
\q1 ni a sila ki vin vire nan sa ki fo yo.   
\q1
\v 5 Anpil, O SENYÈ Bondye mwen an,  
\q1 se \x + \xo 40:5 \xt Job 5:9\x*mèvèy ke Ou te fè yo,  
\q1 ak panse Ou yo anvè nou.  
\q1 Nanpwen ki kab konpare avèk Ou.  
\q1 Si m ta deklare yo e pale sou yo tout,  
\q1 yo ta vin twòp pou m ta kab konte.   
\q1
\v 6 \x + \xo 40:6 \xt I Sam 15:22\x*Sakrifis avèk ofrann sereyal,  
\q1 Ou pa t dezire yo.  
\q1 Ou te ouvri zòrèy mwen.  
\q1 Ofrann brile avèk ofrann peche yo,  
\q1 Ou pa t mande yo.   
\q1
\v 7 Konsa mwen te di: “Gade byen, mwen vini.  
\q1 Nan woulo liv la, li ekri de mwen menm.   
\q1
\v 8 \x + \xo 40:8 \xt Jn 4:34\x*Mwen pran plezi nan fè volonte pa Ou, O SENYÈ.  
\q1 Lalwa Ou nan kè m.”   
\q1
\v 9 Mwen te \x + \xo 40:9 \xt Sòm 22:22\x*pwoklame bòn nouvèl ladwati yo nan gran asanble a;  
\q1 Gade byen, mwen p ap anpeche lèv mwen;  
\q1 O SENYÈ, Ou konnen.   
\q1
\v 10 Mwen pa t kache ladwati Ou anndan kè m.  
\q1 Mwen te pale selon fidelite Ou, avèk sali Ou.  
\q1 Mwen pa t kache lanmou dous Ou avèk  
\q1 verite Ou devan gran asanble a.   
\q1
\v 11 Ou menm O SENYÈ, p ap refize mwen.  
\q1 \x + \xo 40:11 \xt Sòm 43:3\x*Lanmou dous Ou avèk verite Ou va  
\q1 prezève mwen tout tan.   
\q1
\v 12 Paske malè ki depase kontwòl yo te antoure mwen.  
\q1 \x + \xo 40:12 \xt Sòm 38:4\x*Inikite mwen yo te fin pran m nèt  
\q1 jiskaske mwen pa t kab wè.  
\q1 Yo plis pase cheve sou tèt mwen.  
\q1 Kè m fin fè fayit.   
\q1
\v 13 \x + \xo 40:13 \xt Sòm 22:19\x*Fè l plezi Ou, O SENYÈ, pou delivre mwen.  
\q1 Fè vit, O SENYÈ, pou ede mwen.   
\q1
\v 14 Kite sila yo vin wont e imilye ansanm,  
\q1 sila ki \x + \xo 40:14 \xt Sòm 63:9\x*chache lavi mwen pou detwi li.  
\q1 Kite sila yo vire fè bak e dezonore,  
\q1 sila ki pran plezi nan fè m mal yo.   
\q1
\v 15 Kite sila yo etone nèt akoz wont yo,  
\q1 sila ki \x + \xo 40:15 \xt Sòm 35:21\x*di mwen: “Wayan, wayan!”   
\q1
\v 16 Kite tout sila ki wè Ou yo rejwi e  
\q1 fè kè kontan nan Ou.  
\q1 Kite tout sila ki renmen sali Ou yo  
\q1 \x + \xo 40:16 \xt Sòm 35:27\x*pale tout tan: “Ke SENYÈ a kapab  
\q1 leve wo!”   
\q1
\v 17 Akoz mwen aflije e nan gwo bezwen,  
\q1 \x + \xo 40:17 \xt Sòm 40:5\x*kite SENYÈ a toujou sonje mwen.  
\q1 Se Ou menm ki soutyen mwen ak delivrans mwen.  
\q1 Pa fè reta, O Bondye mwen an.   
\c 41  
\d Pou direktè koral la; Yon Sòm David  
\q1
\v 1 A la beni sila ki konsidere ka malere a beni!  
\q1 SENYÈ a va delivre li \x + \xo 41:1 \xt Sòm 27:5\x*nan jou twoub li.   
\q1
\v 2 SENYÈ a va pwoteje li e fè l viv.  
\q1 Li va rele beni sou latè a.  
\q1 Ni li \x + \xo 41:2 \xt Sòm 27:12 \x*p ap livre a volonte lènmi li yo.   
\q1
\v 3 SENYÈ a va bay li soutyen lè l malad sou kabann nan.  
\q1 Nan maladi li, li va restore li a lasante.   
\q1
\v 4 Konsa, pou mwen, mwen te di: “O SENYÈ, fè m gras.  
\q1 Geri nanm mwen paske \x + \xo 41:4 \xt Sòm 51:4 \x*mwen te peche kont Ou.”   
\q1
\v 5 Lènmi m yo \x + \xo 41:5 \xt Sòm 38:12\x*pale mal kont mwen:  
\q1 “Kilè l ap mouri pou non li disparèt?”   
\q1
\v 6 Si li vin wè m, li \x + \xo 41:6 \xt Sòm 12:2\x*bay manti.  
\q1 Kè li ranmase mechanste pou kont li.  
\q1 Lè l sòti deyò, li pale sa.   
\q1
\v 7 Tout sila ki rayi mwen yo  
\q1 soufle ti pawòl nan zòrèy youn lòt.  
\q1 Kont mwen, yo \x + \xo 41:7 \xt Sòm 56:5\x*fè plan pou  
\q1 donmaje mwen epi yo di:   
\q1
\v 8 “Yon bagay mechan gen tan pran l,  
\q1 pou lè l kouche, pou l \x + \xo 41:8 \xt Sòm 71:10-11\x*pa leve ankò.”   
\q1
\v 9 Menm \x + \xo 41:9 \xt II Sam 15:12\x*zanmi ki te pre m nan,  
\q1 nan sila mwen te mete konfyans la,  
\q1 li ki te manje pen mwen an,  
\q1 te leve talon li kont mwen.   
\b  
\q1
\v 10 Men Ou menm, O SENYÈ, fè m gras e \x + \xo 41:10 \xt Sòm 3:3\x*fè m leve  
\q1 pou m kab bay yo rekonpans yo.   
\q1
\v 11 Se konsa \x + \xo 41:11 \xt Sòm 37:23\x*mwen konnen ke Ou pran plezi nan mwen.  
\q1 Akoz lènmi mwen an pa kriye viktwa sou mwen.   
\q1
\v 12 Pou mwen menm, Ou soutni mwen nan entegrite m,  
\q1 epi Ou mete mwen \x + \xo 41:12 \xt Job 36:7\x*nan prezans Ou  
\q1 jis pou tout tan.   
\b  
\q1
\v 13 \x + \xo 41:13 \xt Sòm 72:18-19\x*Beni se SENYÈ a, Bondye Israël la,  
\q1 soti pou tout tan, jis rive pou tout tan.  
\q1 Amen e amen.   
\c 42  
\ms1 LIV 2  
\d Pou direktè koral la. Yon refleksyon pa fis Kore yo.  
\q1
\v 1 Jan sèf la \x + \xo 42:1 \xt Sòm 119:131\x*rale souf ak swaf pou dlo ravin nan,  
\q1 Konsa nanm mwen rale souf pou Ou, O Bondye.   
\q1
\v 2 Nanm mwen swaf pou Bondye,  
\q1 Pou Bondye vivan an.  
\q1 Se kilè mwen kab vini pou \x + \xo 42:2 \xt Egz 23:17\x* parèt devan Bondye?   
\q1
\v 3 Se dlo nan zye m ki manje mwen lajounen kon lannwit.  
\q1 Pandan y ap \x + \xo 42:3 \xt Sòm 79:10\x*di m tout lajounen:  
\q1 “Kote Bondye ou a?”   
\q1
\v 4 Bagay sa yo mwen sonje e mwen  
\q1 \x + \xo 42:4 \xt I Sam 1:15\x*vide nanm mwen nèt anndan m.  
\q1 Paske mwen te konn ale ansanm ak foul la,  
\q1 pou pran devan nan pwosesyon pou rive lakay Bondye,  
\q1 avèk yon vwa lajwa, ak remèsiman, yon gran foul k ap fè fèt sakre a.   
\q1
\v 5 Poukisa, o nanm mwen, ou nan dezespwa?  
\q1 Epi poukisa ou twouble anndan m?  
\q1 Mete espwa ou nan Bondye, paske mwen  
\q1 va louwe Li ankò akoz \x + \xo 42:5 \xt Sòm 44:3\x*sekou a prezans Li an.   
\q1
\v 6 O Bondye mwen, nanm mwen pèdi espwa anndan mwen.  
\q1 Pou sa, mwen sonje Ou soti nan peyi  
\q1 Jourdain an avèk tèt mòn Hermon yo, soti kanpe nan Mòn Mitsear.   
\q1
\v 7 Pwofondè a rele pwofondè a nan son kaskad dlo Ou yo.  
\q1 Tout \x + \xo 42:7 \xt Sòm 69:1-2\x*gwo dlo ak move lanmè Ou yo fin koule sou mwen.   
\b  
\q1
\v 8 SENYÈ a va òdone lanmou dous Li a nan lajounen,  
\q1 chan Li yo va avèk mwen \x + \xo 42:8 \xt Job 35:10\x*pandan nwit lan:  
\q1 Yon lapriyè a Bondye lavi mwen an.   
\q1
\v 9 Mwen va di a Bondye, wòch mwen an:  
\q1 “Poukisa Ou te bliye mwen?  
\q1 Poukisa mwen antre nan tristès akoz \x + \xo 42:9 \xt Sòm 17:9\x*opresyon lènmi an?”   
\q1
\v 10 Se tankou tout zo mwen yo kraze,  
\q1 jan advèsè mwen yo anmède mwen,  
\q1 pandan y ap \x + \xo 42:10 \xt Sòm 42:3\x*di m tout lajounen:  
\q1 “Kote Bondye Ou a”?   
\q1
\v 11 Poukisa ou nan dezespwa, O nanm mwen?  
\q1 Epi poukisa ou vin twouble anndan mwen?  
\q1 Mete espwa ou nan Bondye, paske m ap louwe Li ankò,  
\q1 O soutyen kè mwen an, e Bondye mwen an.   
\c 43  
\q1
\v 1 \x + \xo 43:1 \xt Sòm 26:1\x*Deklare m inosan, O Bondye mwen!  
\q1 Plede ka mwen kont yon nasyon enfidèl.  
\q1 O delivre mwen soti nan men  
\q1 a lèzòm mantè e enjis yo!   
\q1
\v 2 Paske Ou se Bondye fòs mwen an.  
\q1 Poukisa Ou rejte m?  
\q1 Poukisa mwen \x + \xo 43:2 \xt Sòm 42:9\x*fè dèy akoz opresyon a lènmi an?   
\q1
\v 3 Voye \x + \xo 43:3 \xt Sòm 36:9\x*limyè Ou deyò avèk verite Ou;  
\q1 kite yo mennen mwen.  
\q1 Kite yo mennen m nan mòn sen Ou an ak kote Ou abite yo.   
\q1
\v 4 Konsa, mwen va ale vè lotèl Bondye a,  
\q1 Bondye \x + \xo 43:4 \xt Sòm 21:6\x*lajwa m ki depase limit lan.  
\q1 Konsa, sou gita a, mwen va bay Ou lwanj,  
\q1 O Bondye, Bondye mwen an.   
\q1
\v 5 \x + \xo 43:5 \xt Sòm 42:5-11\x*Poukisa ou nan dezespwa, O nanm mwen?  
\q1 E poukisa ou twouble anndan m?  
\q1 Mete espwa ou nan Bondye!  
\q1 Paske m ap louwe Li ankò:  
\q1 O sove m, soutyen mwen an,  
\q1 ak Bondye m.   
\c 44  
\d Pou direktè koral la; Yon Sòm refleksyon pa fis a Koré yo  
\q1
\v 1 O Bondye, nou te tande avèk zòrèy nou.  
\q1 Zansèt nou yo te pale nou  
\q1 \x + \xo 44:1 \xt Det 32:7\x*travay ke Ou te fè nan jou pa yo,  
\q1 nan jou ansyen yo.   
\q1
\v 2 Ou menm, avèk pwòp men Ou,  
\q1 Ou te \x + \xo 44:2 \xt Jos 3:10\x*chase mete nasyon yo deyò,  
\q1 men Ou te plante yo.  
\q1 Ou te foule yo anba. Ou te aflije yo,  
\q1 Ou te gaye yo toupatou.   
\q1
\v 3 Konsa, \x + \xo 44:3 \xt Det 8:17-18\x*se pa ak pwòp nepe pa yo ke yo te posede peyi a,  
\q1 ni se pa pwòp bra yo ki te sove yo,  
\q1 men se men dwat Ou avèk bra Ou,  
\q1 ak limyè prezans Ou an,  
\q1 akoz Ou te bay yo favè.   
\q1
\v 4 Se Ou menm ki \x + \xo 44:4 \xt Sòm 74:12\x*Wa m, O Bondye.  
\q1 Òdone viktwa pou Jacob.   
\q1
\v 5 Ak pouvwa Ou menm, nou va pouse fè advèsè nou fè bak;  
\q1 Nan non Ou, nou va \x + \xo 44:5 \xt Sòm 108:13\x*pile fè desann  
\q1 sila ki leve kont nou yo.   
\q1
\v 6 Paske mwen \x + \xo 44:6 \xt I Sam 17:47\x*p ap mete konfyans nan banza mwen,  
\q1 ni se pa nepe m k ap sove mwen.   
\q1
\v 7 Men Ou \x + \xo 44:7 \xt Sòm 136:24\x*te sove nou kont advèsè nou yo,  
\q1 Epi Ou te fè tout sila ki rayi nou yo wont.   
\q1
\v 8 Nan Bondye, nou te \x + \xo 44:8 \xt Sòm 34:2\x*louwe tout lajounen.  
\q1 Nou va bay remèsiman a non Ou jis pou tout tan.   
\b  
\q1
\v 9 Alò, koulye a, Ou rejte nou,  
\q1 e mennen nou nan gwo wont.  
\q1 Ou \x + \xo 44:9 \xt Sòm 60:10\x*pa sòti ankò avèk lame nou yo.   
\q1
\v 10 Ou fè nou vire \x + \xo 44:10 \xt Lev 26:17\x*fè bak devan advèsè a,  
\q1 epi sila ki rayi nou yo fè piyaj pou kont yo.   
\q1
\v 11 Ou te fè nou kon mouton,  
\q1 tankou mouton ki te livre pou manje,  
\q1 epi te \x + \xo 44:11 \xt Lev 26:33 \x*gaye nou pami nasyon yo.   
\q1
\v 12 Ou \x + \xo 44:12 \xt Det 32:30\x*vann pèp Ou bon mache e Ou pa fè pwofi nan vant lan.   
\q1
\v 13 Ou fè nou repwòche devan vwazen nou yo,  
\q1 yon objè ki moke e \x + \xo 44:13 \xt Sòm 80:6\x*giyonnen pa sila ki antoure nou yo.   
\q1
\v 14 Ou fè nou \x + \xo 44:14 \xt II Wa 19:21\x*tounen yon vye mò pami nasyon yo,  
\q1 Yon rizib ki fè moun ri pami pèp yo.   
\q1
\v 15 Tout lajounen dezonè sa a rete la devan m,  
\q1 epi imilyasyon mwen kraze m nèt.   
\q1
\v 16 Akoz vwa a sila ki \x + \xo 44:16 \xt Sòm 74:10\x*fè m repwòch e ki meprize mwen,  
\q1 akoz prezans lènmi an avèk vanjè a.   
\q1
\v 17 Tout sa gen tan rive sou nou,  
\q1 men nou pa te bliye Ou,  
\q1 ni nou pa t \x + \xo 44:17 \xt Sòm 78:57\x*aji nan manti selon akò Ou a.   
\q1
\v 18 Kè nou pa t vire fè bak, ni pa nou yo  
\q1 \x + \xo 44:18 \xt Job 23:11 \x*pa t varye soti nan chemen Ou.   
\q1
\v 19 Malgre, Ou te kraze nou nan landwa chen mawon yo,  
\q1 e te kouvri nou avèk \x + \xo 44:19 \xt Job 3:5\x*lonbraj lanmò a.   
\q1
\v 20 Si nou te bliye non a Bondye nou an,  
\q1 oswa lonje men nou vè yon \x + \xo 44:20 \xt Det 6:14 \x*lòt dye etranje,   
\q1
\v 21 èske Bondye pa ta \x + \xo 44:21 \xt Sòm 139:1-2\x*dekouvri sa a?  
\q1 Paske Li konnen tout sekrè a kè yo.   
\q1
\v 22 Men \x + \xo 44:22 \xt Wo 8:36\x*pou lakoz a Ou menm, nou vin touye tout lajounen.  
\q1 Nou konsidere tankou mouton k ap rive labatwa.   
\q1
\v 23 Leve Ou menm! Poukisa Ou ap dòmi, O SENYÈ?  
\q1 Leve nan dòmi! \x + \xo 44:23 \xt Sòm 77:7\x*Pa rejte nou nèt.   
\q1
\v 24 Poukisa Ou \x + \xo 44:24 \xt Job 13:24\x*kache figi Ou e bliye ke n ap soufri e oprime?   
\q1
\v 25 Paske \x + \xo 44:25 \xt Sòm 119:25\x*nanm nou te neye jis rive nan pousyè.  
\q1 Kò nou kole jis rive atè.   
\q1
\v 26 \x + \xo 44:26 \xt Sòm 35:2\x*Leve monte! Bannou sekou!  
\q1 Rachte nou pou koz  
\q1 lanmou dous Ou a.   
\c 45  
\d Pou direktè koral la; selon “Flè Lis Yo.” Yon Sòm a fis a Koré yo.  
\d Yon Chanson Fèt Maryaj  
\q1
\v 1 Kè m debòde avèk yon bèl sijè.  
\q1 Mwen resite vèsè mwen yo pou Wa a.  
\q1 Lang mwen se plim a yon ekriven byen prepare.   
\q1
\v 2 Ou pi bo pase tout lòt nan fis a lòm yo.  
\q1 \x + \xo 45:2 \xt Luc 4:22\x*Lagras debòde sou lèv ou.  
\q1 Pou sa, Bondye te beni ou jis pou tout tan.   
\q1
\v 3 Mete nepe Ou sou kwis ou, O Sila Ki Pwisan an,  
\q1 nan bèlte Ou avèk majeste Ou!   
\q1
\v 4 Nan majeste Ou, Ou va monte nèt an viktwa.  
\q1 Pou koz verite avèk \x + \xo 45:4 \xt So 2:3\x*imilite, avèk ladwati,  
\q1 kite men dwat Ou enstwi Ou bagay mèvèy yo.   
\q1
\v 5 Flèch Ou yo filè.  
\q1 Tout nasyon yo tonbe anba Ou,  
\q1 epi flèch Ou yo \x + \xo 45:5 \xt II Sam 18:14 \x*lantre nan kè lènmi a Wa a.   
\q1
\v 6 Twòn Ou, O SENYÈ, se pou tout tan e pou tout tan;  
\q1 Baton \x + \xo 45:6 \xt Sòm 98:9 \x*ladwati a se baton wayal a wayòm Ou an.   
\q1
\v 7 Ou te renmen ladwati e te rayi mechanste.  
\q1 Pou sa, Bondye, Bondye pa Ou a,  
\q1 te \x + \xo 45:7 \xt Sòm 2:2\x*onksyone Ou avèk lwil lajwa plis ke moun parèy Ou yo.   
\q1
\v 8 Tout vètman Ou yo santi tankou lami, womaren ak sitwonèl.  
\q1 Soti nan palè livwa yo,lenstriman a kòd yo vin fè Ou kontan.   
\q1
\v 9 Fi a wa yo vin pami fanm pi onore yo.  
\q1 Sou \x + \xo 45:9 \xt I Wa 2:19\x*men dwat Ou, kanpe rèn nan, abiye an lò ki sòti Ophir a.   
\q1
\v 10 Koute byen, O fi, prete atansyon e panche zòrèy ou.  
\q1 \x + \xo 45:10 \xt Det 21:13\x*Bliye pèp ou a avèk lakay papa ou.   
\q1
\v 11 Konsa, wa a va dezire bèlte ou.  
\q1 Akoz li se senyè ou, \x + \xo 45:11 \xt Ef 5:33\x*vin bese ba devan L.   
\q1
\v 12 Fi \x + \xo 45:12 \xt Sòm 87:4\x*Tyr la va vini avèk yon kado.  
\q1 Moun gwo richès pami pèp yo k ap chache favè ou.   
\q1
\v 13 Lamarye a wa a bèl nèt anndan.  
\q1 Vètman li \x + \xo 45:13 \xt Egz 39:2-3\x*trese antre sòti avèk lò.   
\q1
\v 14 Li va \x + \xo 45:14 \xt So 1:4\x*mennen kote Wa a nan yon zèv bwodri.  
\q1 Vyèj yo, konpanyen li yo, k ap swiv li va mennen bò kote Ou.   
\q1
\v 15 Yo va mennen fè parèt avèk kè kontan ak anpil rejwisans.  
\q1 Yo va antre nan palè a wa a.   
\q1
\v 16 Nan plas a papa zansèt ou yo, va gen fis ou yo.  
\q1 Ou va fè yo prens sou tout latè.   
\q1
\v 17 Mwen va fè \x + \xo 45:17 \xt Mal 1:11\x*non Ou sonje nan tout jenerasyon yo.  
\q1 Akoz sa, tout pèp yo va bay Ou  
\q1 remèsiman pou tout tan e pou tout tan.   
\c 46  
\d Yon Sòm a fis a Koré yo, selon Alamot; Yon chanson  
\q1
\v 1 Bondye se \x + \xo 46:1 \xt Sòm 14:6\x*pwotèj nou ak fòs nou,  
\q1 yon sekou ki toujou la nan tan twoub la.   
\q1
\v 2 Pou sa, nou \x + \xo 46:2 \xt Sòm 23:4\x*p ap pè anyen, malgre latè  
\q1 ta chanje e malgre mòn yo  
\q1 ta chape antre nan fon lanmè.   
\q1
\v 3 Malgre dlo li yo ta fè laraj e kimen,  
\q1 malgre mòn yo souke nan anfle ak ògèy yo. \qs Tan\qs*   
\b  
\q1
\v 4 Genyen yon rivyè ak flèv li yo  
\q1 ki fè kè vil Bondye a kontan;  
\q1 lye sen a kote Pi Wo a \x + \xo 46:4 \xt Sòm 43:3\x*demere a.   
\q1
\v 5 Bondye nan mitan li. Li p ap deplase menm.  
\q1 Bondye va ede li vin parèt nan maten.   
\q1
\v 6 Nasyon yo te fè gwo boulvèsman.  
\q1 Wayòm yo te souke.  
\q1 Li te leve vwa l e latè te \x + \xo 46:6 \xt Am 9:5\x*fonn.   
\q1
\v 7 SENYÈ dèzame yo \x + \xo 46:7 \xt Nonb 14:9\x*avèk nou.  
\q1 Bondye Jacob la se sitadèl nou.   
\b  
\q1
\v 8 Vini, \x + \xo 46:8 \xt Sòm 66:5\x*gade byen zèv a SENYÈ yo  
\q1 ki gwo dega Li fè nan tout latè.   
\q1
\v 9 Li fè lagè yo sispann jis rive nan ekstremite latè.  
\q1 Li kase banza a, e koupe lans lan an de bout.  
\q1 Li brile cha yo avèk dife.   
\q1
\v 10 “Kanpe la e \x + \xo 46:10 \xt Sòm 100:3\x*konnen ke se Mwen menm ki Bondye.  
\q1 Mwen va leve wo pami nasyon yo.  
\q1 Mwen va leve wo sou tè a.”   
\q1
\v 11 SENYÈ dèzame yo avèk nou.  
\q1 Bondye Jacob la se sitadèl nou. \qs Tan\qs*   
\b  
\c 47  
\d Pou direktè koral la; Yo Sòm pa fis Koré yo.  
\q1
\v 1 O bat men nou ansanm, tout pèp yo.  
\q1 Rele fò a Bondye avèk yon vwa plen viktwa.   
\q1
\v 2 Paske SENYÈ Pi Wo a merite lakrent.  
\q1 Li se \x + \xo 47:2 \xt Mal 1:1\x*Gran Wa a sou tout latè a.   
\q1
\v 3 Li fè soumèt pèp yo anba nou,  
\q1 ak nasyon yo anba pye nou.   
\q1
\v 4 Pou nou menm, Li chwazi eritaj nou,  
\q1 \x + \xo 47:4 \xt Am 6:8\x*glwa a Jacob la, ke Li renmen an. \qs Tan\qs*   
\q1
\v 5 Bondye te monte avèk yon gwo rèl,  
\q1 SENYÈ a avèk \x + \xo 47:5 \xt Sòm 98:6\x*son twonpèt la.   
\q1
\v 6 Chante lwanj Bondye a, chante lwanj yo!  
\q1 Chante lwanj \x + \xo 47:6 \xt Sòm 89:18\x*Wa nou an, chante lwanj yo!   
\q1
\v 7 Paske Bondye se Wa a tout tè a.  
\q1 Chante lwanj yo \x + \xo 47:7 \xt I Kor 14:15\x*avèk yon chan byen bèl.   
\q1
\v 8 Bondye \x + \xo 47:8 \xt I Kwo 16:31\x*regne sou nasyon yo.  
\q1 Bondye chita sou twòn wayal Li a.   
\q1
\v 9 Prens a pèp yo rasanble yo ansanm,  
\q1 \x + \xo 47:9 \xt Wo 4:11-12\x*pèp a Bondye Abraham nan.  
\q1 Paske tout boukliye sou latè yo se pou Bondye.  
\q1 Li leve byen wo.   
\c 48  
\d Yon Chan; yon Sòm fis a Koré yo.  
\q1
\v 1 Gran se Bondye e gran se lwanj Li merite a,  
\q1 nan Jérusalem, vil Bondye nou an, mòn sen pa Li a.   
\q1
\v 2 Bèl nan wotè li, jwa tout latè a,  
\q1 se Mòn Sion nan pati nò a,  
\q1 \x + \xo 48:2 \xt Mat 5:35 \x*Vil gran Wa a.   
\q1
\v 3 Bondye te parèt nan sitadèl li yo.  
\q1 La, Li te fè tèt Li rekonèt kon yon \x + \xo 48:3 \xt Sòm 46:7\x*refij.   
\q1
\v 4 Men gade, \x + \xo 48:4 \xt II Sam 10:6-19\x*wa yo te rasanble yo.  
\q1 Yo pase akote vil la ansanm.   
\q1
\v 5 Yo te wè li, e yo te etone.  
\q1 Yo te \x + \xo 48:5 \xt Egz 15:15\x*sezi nèt, yo te kouri nan laperèz.   
\q1
\v 6 La, yo pèdi ekilib yo nèt.  
\q1 Doulè ak sezisman te pran yo tankou \x + \xo 48:6 \xt És 13:8\x*fanm k ap akouche.   
\q1
\v 7 Avèk \x + \xo 48:7 \xt Jr 18:17\x*van lès la, Ou te kraze bato Tarsis yo.   
\q1
\v 8 Jan nou konn tande a, se konsa nou vin wè,  
\q1 nan vil SENYÈ dèzame yo,  
\q1 nan vil Bondye pa nou an.  
\q1 Bondye va \x + \xo 48:8 \xt Sòm 87:5\x*etabli li nèt, jis pou tout tan.   
\q1
\v 9 Nou te reflechi sou \x + \xo 48:9 \xt Sòm 26:3\x*lanmou dous  
\q1 Ou a, O Bondye, nan mitan tanp Ou a.   
\q1
\v 10 Jan \x + \xo 48:10 \xt Det 28:58\x*non Ou ye a, O Bondye,  
\q1 Se konsa Lwanj Ou ye, jis rive nan dènye pwent tè a;  
\q1 Men dwat Ou plen ladwati.   
\q1
\v 11 Kite Mòn Sion fè kè kontan!  
\q1 Kite \x + \xo 48:11 \xt Sòm 97:8\x* fi a Juda yo rejwi akoz jijman Ou yo.   
\q1
\v 12 Mache toupatou nan Sion e antoure li.  
\q1 \x + \xo 48:12 \xt Né 3:1-27\x*Konte fò wo li yo.   
\q1
\v 13 Konsidere ranpa li yo.  
\q1 Antre nan palè li yo, pou ou kab  
\q1 \x + \xo 48:13 \xt Sòm 78:5-7 \x*pale jenerasyon k ap vini an.   
\q1
\v 14 Paske Bondye se Bondye pa nou an jis pou tout tan.  
\q1 \x + \xo 48:14 \xt Sòm 23:4\x*Li va gide nou jiska lanmò.   
\c 49  
\d Pou direktè koral la; Yon Sòm fis a Koré yo  
\q1
\v 1 Tande sa, tout pèp yo!  
\q1 Prete zòrèy nou, tout sila ki rete nan mond lan!   
\q1
\v 2 Ni \x + \xo 49:2 \xt Sòm 62:9\x*ba, ni wo, rich ak malere ansanm.   
\q1
\v 3 Bouch mwen va \x + \xo 49:3 \xt Sòm 37:30\x*pale sajès,  
\q1 epi meditasyon a kè m va vin konprann.   
\q1
\v 4 Mwen va apiye zòrèy mwen vè yon pwovèb.  
\q1 Mwen va eksprime yon \x + \xo 49:4 \xt Nonb 12:8 \x*devinèt sou ap la.   
\q1
\v 5 Poukisa mwen ta gen \x + \xo 49:5 \xt Sòm 23:4\x*krent nan move jou yo,  
\q1 Lè inikite a lènmi m yo antoure m?   
\q1
\v 6 Malgre sila ki \x + \xo 49:6 \xt Job 31:24\x*mete konfyans nan richès yo,  
\q1 ak ògeye nan kantite fòs lajan yo—   
\q1
\v 7 nanpwen moun ki kab sou okenn mwayen \x + \xo 49:7 \xt Mat 25:8-9\x*sove frè li,  
\q1 ni li p ap kab bay Bondye yon racha pou li.   
\q1
\v 8 Paske \x + \xo 49:8 \xt Mat 16:26\x*redanmsyon nanm li koute chè.  
\q1 Kèlkeswa sa li peye pa janm ase,   
\q1
\v 9 pou l ta \x + \xo 49:9 \xt Sòm 22:29\x*viv toujou jis pou letènite,  
\q1 pou li \x + \xo 49:9 \xt Sòm 16:10 \x*pa ta janm tonbe nan pouriti menm.   
\q1
\v 10 Paske li wè ke menm moun saj yo mouri.  
\q1 Sila ki bèt ak sila ki fou yo mouri menm jan.  
\q1 Yo \x + \xo 49:10 \xt Sòm 39:6\x*kite byen yo pou lòt yo.   
\q1
\v 11 Yo \x + \xo 49:11 \xt Jen 4:17\x*reflechi anndan kè yo ke kay yo se pou tout tan,  
\q1 epi kote yo rete a se pou tout jenerasyon yo.  
\q1 Yo te rele peyi yo a menm non ak yo.   
\q1
\v 12 Men yon \x + \xo 49:12 \xt Sòm 49:20\x*nonm, malgre gran ògèy li, p ap dire.  
\q1 Li tankou bèt yo ki peri.   
\b  
\q1
\v 13 Konsa, sa se \x + \xo 49:13 \xt Jr 17:11\x*chemen a sila ki manke sajès yo,  
\q1 ak sila ki swiv yo, e ki vin dakò avèk pawòl yo.   
\q1
\v 14 Tankou mouton, yo fin apwente pou rive nan sejou lanmò.  
\q1 Lanmò va bèje yo.  
\q1 Moun dwat yo va domine sou yo nan maten.  
\q1 Men fòm yo va \x + \xo 49:14 \xt Job 24:19\x*fini nèt pa sejou lanmò a, lwen gran kay yo.   
\q1
\v 15 Men \x + \xo 49:15 \xt Jen 5:24\x*Bondye va rachte nanm mwen soti nan  
\q1 pouvwa a sejou lanmò a,  
\q1 paske Bondye va resevwa m.   
\q1
\v 16 Ou pa bezwen pè \x + \xo 49:16 \xt Sòm 37:7\x*lè yon nonm vin rich,  
\q1 lè glwa lakay li vin ogmante.   
\q1
\v 17 Paske lè l mouri li p ap pote anyen ale.  
\q1 Glwa li a p ap swiv li desann.   
\q1
\v 18 Sepandan, pandan l ap viv, li \x + \xo 49:18 \xt Det 29:19\x*bat bravo pou pwòp tèt li—  
\q1 Malgre moun ta bay ou glwa lè ou fè byen pou pwòp tèt ou—   
\q1
\v 19 li va ale nan jenerasyon a zansèt li yo.  
\q1 Yo p ap janm wè \x + \xo 49:19 \xt Job 33:30\x*limyè a.   
\q1
\v 20 Lòm, nan pwòp glwa avèk ògèy li,  
\q1 poutan, san konprann,  
\q1 Se tankou bèt ki peri.   
\c 50  
\d Yon Sòm Asaph  
\q1
\v 1 Sila Ki Pwisan Nèt la, Bondye, SENYÈ a, fin pale.  
\q1 Li rele lemonn lan soti nan \x + \xo 50:1 \xt Sòm 113:3 \x*leve solèy la  
\q1 jis rive nan kote li kouche a.   
\q1
\v 2 Soti nan Sion, \x + \xo 50:2 \xt Sòm 48:2\x*bèlte pafè a,  
\q1 Bondye fè limyè Li parèt.   
\q1
\v 3 Bondye nou \x + \xo 50:3 \xt Sòm 96:13\x*vin parèt.  
\q1 Li pa rete an silans.  
\q1 Dife devore devan L, e tanpèt yo antoure L.   
\q1
\v 4 Li \x + \xo 50:4 \xt Det 4:26\x*rele tout syèl yo anwo,  
\q1 avèk latè pou jije pèp Li a:   
\q1
\v 5 “Rasanble fidèl Mwen yo kote M,  
\q1 Sila ki te fè yon akò sakrifis yo avè M.   
\q1
\v 6 Epi syèl yo deklare ladwati Li,  
\q1 paske \x + \xo 50:6 \xt Sòm 75:7\x*Bondye, Li menm, se Jij. \qs Tan\qs*   
\q1
\v 7 “Koute O pèp Mwen an e Mwen va pale.  
\q1 O Israël, Mwen va fè temwayaj kont ou.  
\q1 Mwen se Bondye, \x + \xo 50:7 \xt Egz 20:2\x*Bondye pa ou a.   
\q1
\v 8 Mwen pa \x + \xo 50:8 \xt Sòm 40:6\x*repwoche ou pou sakrifis ou yo.  
\q1 Ofrann brile nou yo devan m tout tan.   
\q1
\v 9 Mwen pa bezwen okenn \x + \xo 50:9 \xt Sòm 69:31\x*jenn towo sòti lakay ou,  
\q1 Ni mal kabrit ki sòti nan pak ou yo.   
\q1
\v 10 Paske \x + \xo 50:10 \xt Sòm 104:24\x*tout bèt nan forè yo se pou mwen,  
\q1 ak tout bèt domestik sou mil kolin yo.   
\q1
\v 11 Mwen konnen tout \x + \xo 50:11 \xt Mat 6:26\x*zwazo nan mòn yo.  
\q1 Tout sa ki fè mouvman nan chan yo se pou Mwen.   
\q1
\v 12 Si mwen te grangou, mwen pa t ap di ou sa,  
\q1 paske tout \x + \xo 50:12 \xt Egz 19:5\x*mond lan se pou Mwen, avèk tout sa ki ladann.   
\q1
\v 13 Èske m ta manje chè \x + \xo 50:13 \xt Sòm 50:9\x*towo yo,  
\q1 oswa bwè san a mal kabrit yo?   
\q1
\v 14 Ofri a Bondye \x + \xo 50:14 \xt Sòm 27:6\x*yon sakrifis remèsiman  
\q1 e peye ve ou yo a Pi Wo a.   
\q1
\v 15 Rele Mwen nan jou twoub la.  
\q1 Mwen va \x + \xo 50:15 \xt Sòm 81:7\x*delivre ou e ou va onore M.”   
\b  
\q1
\v 16 Men a mechan yo Bondye di:  
\q1 “Ki dwa ou genyen pou pale sou règleman Mwen yo,  
\q1 pou pran \x + \xo 50:16 \xt És 29:13\x*akò Mwen an nan bouch ou?   
\q1
\v 17 Paske ou \x + \xo 50:17 \xt Pwov 5:12\x*rayi disiplin, e jete pawòl Mwen yo dèyè w.   
\q1
\v 18 Lè ou wè yon vòlè, ou vin dakò avè l,  
\q1 epi ou asosye ou avèk moun adiltè yo.   
\b  
\q1
\v 19 Ou lage bouch ou nèt nan mechanste.  
\q1 \x + \xo 50:19 \xt Sòm 36:3\x*Lang ou fè ankadreman pou manti.   
\q1
\v 20 Ou chita \x + \xo 50:20 \xt Job 19:18\x*pale kont frè ou.  
\q1 Ou fè kout lang fò kont pwòp pitit manman ou.   
\q1
\v 21 Bagay sa yo, ou te fè yo,  
\q1 e Mwen pa t di yon mo.  
\q1 Ou te konprann ke M te menm jan ak ou.  
\q1 Mwen va \x + \xo 50:21 \xt Sòm 90:8\x*repwoche ou  
\q1 e pale ka a an lòd devan zye ou.   
\b  
\q1
\v 22 Alò, konsidere sa, nou menm ki \x + \xo 50:22 \xt Job 8:13\x*bliye Bondye,  
\q1 oswa, Mwen va chire nou an mòso,  
\q1 e p ap gen pèsòn ki pou sove nou.   
\q1
\v 23 Sila ki ofri yon sakrifis remèsiman onore M,  
\q1 epi a sila ki fè chemen li dwat la,  
\q1 Mwen va montre li sali Bondye a.”   
\c 51  
\d Yon Sòm David lè pwofèt la, Nathan te rive kote li lè l te fin ale kote Bath-Schéba.  
\q1
\v 1 Fè m gras, O Bondye, selon lanmou dous Ou a.  
\q1 Selon grandè a mizerikòd ou,  
\q1 \x + \xo 51:1 \xt Sòm 51:9\x*efase transgresyon mwen yo.   
\q1
\v 2 Lave m nèt de inikite mwen yo e  
\q1 netwaye m de peche mwen an.   
\q1
\v 3 Paske mwen konnen transgresyon mwen yo.  
\q1 Peche mwen yo devan m tout tan.   
\q1
\v 4 Kont Ou, Ou menm sèlman, mwen te peche,  
\q1 e te fè mal devan zye Ou.  
\q1 Akoz sa, \x + \xo 51:4 \xt Wo 3:4\x*Ou jis lè Ou pale, e san tò lè Ou jije.   
\q1
\v 5 Gade byen, mwen te fèt nan inikite,  
\q1 e se nan peche manman m te vin ansent mwen.   
\q1
\v 6 Men vwala, Ou vle verite a menm nan pati anndan m nèt.  
\q1 Nan pati kache anndan m, Ou va \x + \xo 51:6 \xt Pwov 2:6\x*fè m konnen sajès.   
\q1
\v 7 Pirifye m ak izòp e mwen va pwòp.  
\q1 Lave mwen e mwen va \x + \xo 51:7 \xt És 1:18\x*pi blan ke lanèj.   
\q1
\v 8 Fè m tande lajwa avèk kè kontan,  
\q1 pou \x + \xo 51:8 \xt Sòm 35:10\x*zo ke Ou te kase yo, vin rejwi.   
\q1
\v 9 \x + \xo 51:9 \xt Jr 16:17\x*Kache figi Ou de peche m yo.  
\q1 Efase tout inikite mwen yo.   
\q1
\v 10 Kreye nan mwen yon kè pwòp, O SENYÈ,  
\q1 epi refè yon lespri ki \x + \xo 51:10 \xt Sòm 78:37\x*dwat anndan m.   
\q1
\v 11 Pa jete mwen lwen prezans Ou e  
\q1 pa retire \x + \xo 51:11 \xt És 63:10-11\x*Lespri Sen Ou an sou mwen.   
\q1
\v 12 Restore nan mwen lajwa sali Ou a.  
\q1 Ranfòse m avèk yon lespri bòn volonte.   
\q1
\v 13 Konsa, mwen va enstwi transgresè yo chemen Ou yo,  
\q1 e \x + \xo 51:13 \xt Sòm 22:27\x*pechè yo va konvèti a Ou menm.   
\q1
\v 14 Delivre mwen de \x + \xo 51:14 \xt II Sam 12:9\x*koupabilite san vèse a,  
\q1 O Bondye, Bondye a sali mwen an.  
\q1 Konsa, lang mwen va chante avèk jwa  
\q1 selon ladwati a Ou menm nan.   
\q1
\v 15 O Mèt mwen an, \x + \xo 51:15 \xt Egz 4:15\x*ouvri lèv mwen  
\q1 pou m kab deklare lwanj Ou.   
\q1
\v 16 Paske Ou \x + \xo 51:16 \xt I Sam 15:22\x*pa pran plezi nan sakrifis.  
\q1 Otreman, mwen ta bay li.  
\q1 Ofrann brile yo pa fè Ou kontan.   
\q1
\v 17 Sakrifis a Bondye yo se yon \x + \xo 51:17 \xt Sòm 34:18\x*espri ki kraze.  
\q1 Yon kè brize e ki repantan, O Bondye,  
\q1 Ou p ap meprize l.   
\b  
\q1
\v 18 Avèk \x + \xo 51:18 \xt Sòm 69:35\x*bonte Ou, fè byen pou Sion.  
\q1 Bati miray a Jérusalem yo.   
\q1
\v 19 Konsa, Ou va rejwi nan \x + \xo 51:19 \xt Sòm 4:5\x*sakrifis ladwati yo,  
\q1 nan ofrann brile avèk ofrann brile nèt yo.  
\q1 Konsa, jenn towo yo va ofri sou lotèl Ou a.   
\c 52  
\d Pou direktè koral la. Yon Sòm David, lè Doeg, Edomit lan te vin di Saül “David gen tan rive lakay Achimélic.”  
\q1
\v 1 Poukisa ou ògeye nan mechanste ou, O lòm pwisan?  
\q1 Lanmou dous Bondye a dire tout lajounen.   
\q1
\v 2 Lang ou envante destriksyon,  
\q1 tankou yon razwa ki file, plen desepsyon.   
\q1
\v 3 Ou \x + \xo 52:3 \xt Sòm 36:4\x*renmen mechanste plis pase sa ki bon.  
\q1 Fo bagay plis pase pale verite a.   
\q1
\v 4 Ou renmen tout pawòl ki devore,  
\q1 yon lang \x + \xo 52:4 \xt Sòm 120:3\x*mantè.   
\q1
\v 5 Men Bondye va kase fè ou desann nèt;  
\q1 Li va kenbe ou byen vit e \x + \xo 52:5 \xt És 22:18-19\x*chire fè ou  
\q1 sòti nan tant ou an,  
\q1 Epi dechouke fè ou sòti nan peyi vivan yo. \qs Tan\qs*   
\q1
\v 6 Moun dwat yo va \x + \xo 52:6 \xt Sòm 37:34\x*wè, va gen lakrent;  
\q1 yo va ri sou li epi di:   
\q1
\v 7 “Gade byen, men nonm ki refize pran refij nan Bondye a,  
\q1 men ki te mete konfyans nan abondans richès li yo.  
\q1 Li te ranfòse tèt li ak mechanste.”   
\q1
\v 8 Men pou mwen menm, mwen tankou yon pye doliv vèt lakay Bondye.  
\q1 Mwen mete \x + \xo 52:8 \xt Sòm 13:5 \x*konfyans mwen nan lanmou dous Bondye a  
\q1 pou tout tan e pou tout tan.   
\q1
\v 9 Mwen va \x + \xo 52:9 \xt Sòm 30:12\x*bay Ou remèsiman pou tout tan, paske Ou te fè sa.  
\q1 Mwen va mete espwa nan non Ou,  
\q1 paske sa bon nan prezans a fidèl Ou yo.   
\c 53  
\d Pou direktè koral la; selon mizik Mahalath  
\d Yon refleksyon pa David  
\q1
\v 1 Moun fou a di nan kè li: “Nanpwen Bondye”.  
\q1 Yo konwonpi!  
\q1 Yo fè zak enjis ki abominab.  
\q1 \x + \xo 53:1 \xt Wo 3:10\x*Nanpwen ki fè sa ki bon.   
\q1
\v 2 Bondye te gade anba soti nan syèl la sou fis a lòm yo,  
\q1 pou wè si genyen \x + \xo 53:2 \xt Wo 3:11\x*youn ki gen bon konprann, k ap chache Bondye.   
\q1
\v 3 \x + \xo 53:3 \xt Wo 3:12\x*Yo tout te vire akote.  
\q1 Ansanm yo vin konwonpi.  
\q1 Nanpwen nan yo ki fè byen, pa menm youn.   
\q1
\v 4 Èske malfektè a mechanste sila yo pa gen okenn konesans,  
\q1 k ap \x + \xo 53:4 \xt Jr 4:22\x*manje pèp Mwen an konsi se pen yo manje,  
\q1 epi ki pa rele Bondye?   
\q1
\v 5 La, yo te nan gwo laperèz kote pa te gen laperèz,  
\q1 paske Bondye te gaye zo a sila ki fè kan kont ou yo.  
\q1 Ou te fè yo vin wont, akoz \x + \xo 53:5 \xt II Wa 17:20\x*Bondye te rejte yo.   
\q1
\v 6 O ke \x + \xo 53:6 \xt Sòm 14:7\x*delivrans Israël ta parèt sòti Sion!  
\q1 Lè Bondye restore pèp kaptif Li a,  
\q1 kite Jacob rejwi, kite Israël fè kè kontan.   
\c 54  
\d Pou direktè koral la; sou enstriman ak kòd yo. Yon sòm  
\d a David, lè Zifyen yo te vin di Saül: “Èske David pa kache pami nou?”  
\q1
\v 1 Sove mwen, O Bondye, ak non Ou  
\q1 e fè vanjans mwen ak pouvwa Ou.   
\q1
\v 2 Koute lapriyè mwen, O Bondye.  
\q1 \x + \xo 54:2 \xt Sòm 5:1\x*Prete zòrèy a pawòl a bouch mwen.   
\q1
\v 3 Paske etranje yo fin leve kont mwen.  
\q1 Moun vyolans yo te chache lavi mwen.  
\q1 Yo \x + \xo 54:3 \xt Sòm 36:1 \x*pa t mete Bondye devan yo.   
\q1
\v 4 Gade byen, Bondye se èd mwen.  
\q1 SENYÈ a se \x + \xo 54:4 \xt Sòm 37:17-24 \x*soutyen a nanm mwen.   
\q1
\v 5 Li va rekonpanse mal a lènmi mwen yo.  
\q1 Detwi yo \x + \xo 54:5 \xt Sòm 89:49 \x*nan fidelite Ou.   
\q1
\v 6 \x + \xo 54:6 \xt Nonb 15:3\x*Avèk bòn volonte, mwen va fè sakrifis a Ou.  
\q1 Mwen va bay remèsiman a non Ou, O SENYÈ, paske li bon.   
\q1
\v 7 Paske Li te \x + \xo 54:7 \xt Sòm 34:6\x*delivre mwen nan tout twoub.  
\q1 Konsa, zye mwen te wè ak kè kontan, defèt lènmi m yo.   
\c 55  
\d Pou direktè koral la; sou enstriman ak kòd yo  
\d Yon Refleksyon David  
\q1
\v 1 Prete zòrèy a lapriyè mwen, O Bondye.  
\q1 \x + \xo 55:1 \xt Sòm 27:9\x*Pa kache Ou menm a siplikasyon mwen yo.   
\q1
\v 2 Prete atansyon a mwen e reponn mwen.  
\q1 Mwen pa alèz nan plent mwen yo.  
\q1 Anverite, mwen deranje nèt   
\q1
\v 3 akoz vwa lènmi an,  
\q1 akoz presyon mechan an.  
\q1 Paske yo \x + \xo 55:3 \xt II Sam 16:7-8\x*pote twoub desann sou mwen.  
\q1 Nan kòlè yo, yo pote rankin kont mwen.   
\q1
\v 4 \x + \xo 55:4 \xt Sòm 38:8\x*Kè m twouble anndan m.  
\q1 Sezisman lanmò fin tonbe sou mwen.   
\q1
\v 5 Laperèz avèk tranbleman fin rive sou mwen.  
\q1 Mwen \x + \xo 55:5 \xt 21:6 \x*etone jiskaske m debòde.   
\q1
\v 6 Mwen te di: “O ke m te gen zèl kon toutrèl la!  
\q1 Konsa, mwen ta sove ale pou \x + \xo 55:6 \xt Job 3:13\x*twouve repo.  
\q1 Mwen ta demere nan dezè a.”   
\q1
\v 7 Tande byen, mwen ta rive byen lwen.  
\q1 Mwen ta \x + \xo 55:7 \xt I Sam 23:14\x*ale rete nan savann nan. \qs Tan\qs*   
\q1
\v 8 Mwen ta fè vit rive kote pou m kache kont \x + \xo 55:8 \xt És 4:6\x*van tanpèt la,  
\q1 kont move tan an.   
\q1
\v 9 Mete yo nan konfizyon, O SENYÈ, \x + \xo 55:9 \xt Jen 11:9\x*divize lang yo,  
\q1 paske mwen te wè vyolans avèk goumen nan vil la.   
\q1
\v 10 Lajounen kon lannwit, yo antoure vil la sou miray li yo.  
\q1 Inikite avèk mechanste nan mitan li.   
\q1
\v 11 Destriksyon ladann.  
\q1 \x + \xo 55:11 \xt Sòm 10:7\x*Opresyon avèk desepsyon pa janm kite lari li yo.   
\q1
\v 12 Paske \x + \xo 55:12 \xt Sòm 41:9\x*se pa lènmi an ki fè m repwòch.  
\q1 Konsa, mwen ta kab sipòte l.  
\q1 Ni se pa yon moun ki rayi mwen ki vin leve kont mwen.  
\q1 Konsa, mwen ta kab kache de li.   
\q1
\v 13 Men se ou menm, yon nonm parèy mwen, konpanyen mwen ak zanmi mwen.   
\q1
\v 14 Nou menm, ki te fè kominyon dous ansanm,  
\q1 ki te \x + \xo 55:14 \xt Sòm 42:4\x*mache nan kay Bondye a nan mitan tout pèp la.   
\q1
\v 15 Pou sa a Kite lanmò rive sibitman sou yo.  
\q1 Kite yo \x + \xo 55:15 \xt Nonb 16:30-33\x*desann tou vivan kote mò yo ye.  
\q1 Paske mechanste a nan abitasyon yo, pami yo, kote yo rete a.   
\q1
\v 16 Pou mwen, mwen va \x + \xo 55:16 \xt Sòm 57:2-3\x*rele Bondye.  
\q1 SENYÈ a va sove mwen.   
\q1
\v 17 \x + \xo 55:17 \xt Sòm 141:2\x*Nan aswè, nan maten ak midi, mwen va plenyen e bougonnen.  
\q1 Li va tande vwa m.   
\q1
\v 18 Li te rachte nanm mwen anpè,  
\q1 soti nan batay ki kont mwen an,  
\q1 malgre yo \x + \xo 55:18 \xt Sòm 56:2 \x*anpil, k ap lite avè m yo.   
\q1
\v 19 Bondye ki sou fotèy L jis pou tout tan,  
\q1 va tande e reponn \x + \xo 55:19 \xt Sòm 36:1 \x*yo. \qs Tan\qs*  
\b  
\q1 Nan sila pa gen chanjman an.  
\q1 Yo pa gen krent Bondye a.   
\q1
\v 20 Li te lonje men li kont moun ki te nan lapè avèk li a.  
\q1 Li te \x + \xo 55:20 \xt Nonb 30:2 \x*vyole akò li a.   
\q1
\v 21 Pawòl li te pi dous pase bè,  
\q1 men ak kè, li te fè lagè.  
\q1 Pawòl li yo te \x + \xo 55:21 \xt Sòm 12:2\x*pi dous pase lwil,  
\q1 men se nepe rale yo te ye.   
\b  
\q1
\v 22 \x + \xo 55:22 \xt Sòm 37:5\x*Voye fado ou sou SENYÈ a, e Li va bay ou soutyen.  
\q1 Li p ap janm kite moun ladwati yo ebranle.   
\q1
\v 23 Men Ou menm, O Bondye, va rale yo desann nan fòs destriksyon an.  
\q1 \x + \xo 55:23 \xt Sòm 5:6\x*Moun ki vèse san e ki bay manti  
\q1 p ap rive fè mwatye nan jou yo.  
\q1 Men mwen menm va mete konfyans nan Ou.   
\c 56  
\d Pou direktè koral la. Yon powèm David lè Filisten yo te sezi li Gath.  
\d Chante pa melodi “Toutrèl San Chanson Nan Peyi Lwen An”  
\q1
\v 1 Fè m gras, O Bondye, paske lòm fin foule m anba pye;  
\q1 Nan goumen tout lajounen, li vin \x + \xo 56:1 \xt Sòm 17:9\x*oprime mwen.   
\q1
\v 2 Lènmi m yo vle vale m tout lajounen.  
\q1 Yo anpil! Tout sila ki goumen ak ògèy kont mwen yo.   
\q1
\v 3 Lè mwen pè, mwen va mete konfyans nan Ou.   
\q1
\v 4 Nan Bondye, mwen fè lwanj pawòl Li!  
\q1 Nan Bondye, mwen te mete konfyans mwen.  
\q1 Mwen p ap pè.  
\q1 \x + \xo 56:4 \xt Sòm 118:6\x*Kisa lòm ka fè m?   
\q1
\v 5 Tout lajounen, yo \x + \xo 56:5 \xt II Pi 3:16\x*tòde pawòl mwen yo.  
\q1 Tout panse yo kont mwen se pou mal.   
\q1
\v 6 Yo atake, yo kache, yo veye pa mwen yo.  
\q1 Y ap \x + \xo 56:6 \xt Sòm 71:10\x*tann pou rache lavi m.   
\q1
\v 7 Akoz mechanste sa a, \x + \xo 56:7 \xt Sòm 36:12\x*jete yo deyò.  
\q1 Nan kòlè Ou, fè desann moun sa yo, O Bondye!   
\q1
\v 8 Ou te byen konte tout egare mwen fè.  
\q1 Mete tout gout dlo ki sòti nan zye m yo nan boutèy Ou.  
\q1 Èske yo tout pa ekri nan \x + \xo 56:8 \xt Mal 3:16\x*liv Ou a?   
\q1
\v 9 Konsa, lènmi mwen yo va vire fè bak nan jou ke m rele a.  
\q1 Men sa m byen konnen: Bondye pou mwen.   
\q1
\v 10 Nan Bondye, ma louwe pawòl li.  
\q1 Nan SENYÈ a, ma louwe pawòl li.   
\q1
\v 11 Nan Bondye, mwen te mete konfyans mwen.  
\q1 Mwen p ap pè. Kisa lòm ka fè m?   
\q1
\v 12 \x + \xo 56:12 \xt Sòm 50:14\x*Ve Ou yo mare sou mwen, O Bondye.  
\q1 Mwen va rann ofrann remèsiman a Ou menm.   
\q1
\v 13 Paske Ou te delivre nanm mwen soti nan lanmò.  
\q1 Ou te anpeche \x + \xo 56:13 \xt Sòm 116:8\x*pye mwen glise tonbe,  
\q1 pou m ta kab mache devan Bondye  
\q1 nan limyè a moun vivan yo.   
\c 57  
\d Pou direktè koral la; jwe a son Al-tashheth  
\d Yon Mikhtam David, lè l te sove ale devan Saül nan kav la  
\q1
\v 1 Fè m gras, SENYÈ, O Bondye, fè m gras,  
\q1 paske nanm mwen kache nan Ou.  
\q1 Wi, nan \x + \xo 57:1 \xt Rt 2:12\x*lonbraj a zèl Ou, mwen va kache,  
\q1 jiskaske destriksyon an fin pase.   
\q1
\v 2 Mwen va kriye a Bondye Pi Wo a,  
\q1 a Bondye ki \x + \xo 57:2 \xt Sòm 138:8\x*acheve tout sa m mande an.   
\q1
\v 3 Li va \x + \xo 57:3 \xt Sòm 18:16\x*voye sòti nan syèl la pou sove mwen.  
\q1 Li fè repwòch a sila ki foule mwen an. \qs Tan\qs*  
\q1 Bondye va voye fè rive lanmou dous Li ak verite Li.   
\q1
\v 4 Nanm mwen rete pami \x + \xo 57:4 \xt Sòm 35:17\x*lyon yo.  
\q1 Mwen oblije kouche pami sila k ap respire dife yo.  
\q1 Fis a lòm yo menm ak dan kon frenn file,  
\q1 epi lang yo kon yon epe file.   
\q1
\v 5 \x + \xo 57:5 \xt Sòm 57:11\x*Leve anwo syèl yo, O Bondye;  
\q1 Kite glwa Ou vin pi wo sou tout latè!   
\b  
\q1
\v 6 Yo te prepare yon gwo filè pou pa mwen yo;  
\q1 Nanm mwen koube ba.  
\q1 Yo te \x + \xo 57:6 \xt Sòm 7:15\x*fouye yon fòs devan m.  
\q1 Yo te tonbe nan mitan li. \qs Tan\qs*   
\q1
\v 7 \x + \xo 57:7 \xt Sòm 112:7\x*Kè m kanpe fèm, O Bondye,  
\q1 kè m fèm.  
\q1 Mwen va chante, wi mwen va chante lwanj!   
\q1
\v 8 Leve, \x + \xo 57:8 \xt Sòm 16:9\x*glwa mwen! Leve ap avèk gita!  
\q1 Mwen va fè maten vin leve.   
\q1
\v 9 \x + \xo 57:9 \xt Sòm 108:3\x*Mwen va bay Ou remèsiman, O SENYÈ, pami pèp yo.  
\q1 Mwen va chante lwanj ou pami nasyon yo.   
\q1
\v 10 Paske \x + \xo 57:10 \xt Sòm 36:5\x*lanmou dous Ou a gran jis rive nan syèl yo,  
\q1 epi verite Ou jis rive nan nwaj yo.   
\q1
\v 11 \x + \xo 57:11 \xt Sòm 57:5\x*Leve anwo syèl yo, O Bondye.  
\q1 Ke Glwa Ou kapab vin pi wo ke tout latè.   
\c 58  
\d Pou direktè koral la; Nan melodi la “Pa Detwi”. Yon Sòm David  
\q1
\v 1 Vrèman, èske nou pale ladwati, O lòt dye yo?  
\q1 Èske nou \x + \xo 58:1 \xt Sòm 82:2\x* jije san fot, O fis a lòm yo?   
\q1
\v 2 Non, nan kè, nou \x + \xo 58:2 \xt Mal 3:15\x* fòmante inikite.  
\q1 Sou latè, nou peze balans pou separe  
\q1 bay vyolans ak men nou.   
\q1
\v 3 Mechan yo pèvès depi nan vant.  
\q1 Sila ki bay manti yo fè move wout depi nesans yo.   
\q1
\v 4 Yo gen pwazon tankou \x + \xo 58:4 \xt Det 32:33\x*pwazon sèpan.  
\q1 Kon vipè soud ki bouche zòrèy li,   
\q1
\v 5 pou li pa tande vwa a sila k ap chame li yo,  
\q1 malgre se yon \x + \xo 58:5 \xt Ekl 10:11\x* majisyen abil k ap fè wanga.   
\q1
\v 6 O Bondye, \x + \xo 58:6 \xt Job 4:10\x*kraze dan nan bouch yo!  
\q1 Kase gwo dan a jenn lyon an, O SENYÈ.   
\q1
\v 7 Kite yo \x + \xo 58:7 \xt Jos 2:11\x*koule disparèt tankou dlo k ap kouri sou tè.  
\q1 Lè flèch li yo parèt, kite yo fèt tankou shaf san tèt.   
\q1
\v 8 Kite yo tankou kalmason ki fonn,  
\q1 ki vin disparèt pandan l ap mache,  
\q1 tankou \x + \xo 58:8 \xt Job 3:16\x*avòtman a yon fanm ki p ap janm wè solèy la.   
\q1
\v 9 Avan chodyè ou yo kab santi dife pikan yo,  
\q1 Li va \x + \xo 58:9 \xt Job 27:21\x*bale yo fè yo disparèt nan van toubiyon;  
\q1 vèt ak sila kap brile yo, ansanm.   
\q1
\v 10 Moun ladwati a va rejwi lè l wè \x + \xo 58:10 \xt Det 32:43\x*vanjans lan.  
\q1 Li va lave pye li nan san a mechan yo,   
\q1
\v 11 pou moun yo di: “Anverite, gen yon rekonpans pou moun ladwati yo.  
\q1 Anverite, genyen yon Bondye k ap jije latè!”   
\c 59  
\d Pou direktè koral la; Nan melodi la “Pa Detwi”. Yon powèm David lè Saül te voye yo lakay pou touye l.  
\q1
\v 1 \x + \xo 59:1 \xt Sòm 143:9\x*Delivre mwen de lènmi m yo, O Bondye mwen;  
\q1 Plase mwen byen wo an sekirite  
\q1 byen lwen de sila ki leve kont mwen yo.   
\q1
\v 2 Delivre m de sila ki fè inikite yo,  
\q1 e sove mwen de \x + \xo 59:2 \xt Sòm 26:9\x*moun ki vèse san yo.   
\q1
\v 3 Paske gade byen, yo \x + \xo 59:3 \xt Sòm 56:6\x*fè anbiskad pou lavi m.  
\q1 Mesye fewòs ki fè atak kont mwen yo,  
\q1 pa akoz transgresyon mwen, ni peche m, O SENYÈ.   
\q1
\v 4 Se pa akoz mwen koupab ke yo vin kouri mete yo kont mwen an.  
\q1 \x + \xo 59:4 \xt Sòm 7:6\x*Leve Ou menm pou wè, e fè m sekou!   
\q1
\v 5 Ou menm, O SENYÈ Bondye dèzame yo, Bondye Israël la,  
\q1 leve e pini tout nasyon yo.  
\q1 Pa bay gras a moun mechan yo ki fè trèt nan inikite. \qs Tan\qs*   
\q1
\v 6 Yo retounen nan aswè.  
\q1 Yo rele tankou \x + \xo 59:6 \xt Sòm 22:16 \x*chen pandan yo antoure lavil la.   
\q1
\v 7 Gade byen, yo fè pete gwo gaz ak bouch yo.  
\q1 \x + \xo 59:7 \xt Sòm 57:4\x*Nepe yo nan lèv yo, paske yo di:  
\q1 “Kilès ki tande”?   
\q1
\v 8 Men Ou menm, O SENYÈ, \x + \xo 59:8 \xt Sòm 37:13\x*ri sou yo!  
\q1 Ou menm, giyonnen tout nasyon sa yo.   
\q1
\v 9 O Fòs mwen, m ap veye tann Ou.  
\q1 Bondye se \x + \xo 59:9 \xt Sòm 9:9\x* sitadèl mwen.   
\q1
\v 10 Bondye mwen an ak lanmou dous Li a, va devan m.  
\q1 Bondye va kite mwen \x + \xo 59:10 \xt Sòm 54:7 \x*triyonfè sou advèsè mwen yo.   
\q1
\v 11 Pa fin touye yo, \x + \xo 59:11 \xt Det 4:9\x* sinon moun mwen yo ka bliye.  
\q1 Gaye yo avèk pouvwa Ou, e rale fè yo desann,  
\q1 O SENYÈ, boukliye nou an.   
\q1
\v 12 Akoz peche a bouch yo avèk pawòl lèv yo,  
\q1 Kite yo \x + \xo 59:12 \xt So 3:11 \x*sezi pran nan pwòp ògèy yo.  
\q1 Paske se malediksyon avèk manti yo bay.   
\q1
\v 13 Detwi yo nan kòlè Ou!  
\q1 Detwi yo pou yo disparèt nèt.  
\q1 Pou Moun kab \x + \xo 59:13 \xt Sòm 83:18 \x*konnen se Bondye k ap renye sou Jacob,  
\q1 jis rive sou tout latè. \qs Tan\qs*   
\q1
\v 14 Kite yo \x + \xo 59:14 \xt Sòm 59:6\x*retounen nan aswè.  
\q1 Kite yo rele anlè tankou chen, pandan yo antoure vil la.   
\q1
\v 15 Y ap \x + \xo 59:15 \xt Job 15:23\x*gaye toupatou.  
\q1 Yap tann tout lanwit si yo pa satisfè.   
\b  
\q1
\v 16 Men pou mwen, mwen va chante de fòs Ou.  
\q1 Wi, avèk jwa, mwen va chante sou lanmou dous Ou nan maten.  
\q1 Paske Ou te toujou sitadèl mwen,  
\q1 yon \x + \xo 59:16 \xt II Sam 22:3 \x*pwotèj nan jou gran twoub mwen an.   
\q1
\v 17 A Ou menm, gran fòs mwen, mwen va chante lwanj a Ou menm.  
\q1 Paske Bondye se sitadèl mwen,  
\q1 Bondye ki montre mwen lanmou dous la.   
\c 60  
\d Pou direktè koral la; selon melodi “Lis Akò La”.  
\d Yon powèm David, pou enstwi; lè l te lite avèk Aram-Naharaim e avèk Aram-Zobah; epi, Joab te retounen e te frape douz-mil Edomit nan Vale Sèl la.  
\q1
\v 1 O Bondye, \x + \xo 60:1 \xt Sòm 44:9\x* Ou te rejte nou.  
\q1 Ou te kraze nou.  
\q1 Ou te fache.  
\q1 O restore nou ankò.   
\q1
\v 2 Ou te fè \x + \xo 60:2 \xt Sòm 18:7\x* latè tranble.  
\q1 Ou te fann li pou l ouvri.  
\q1 Geri brèch li yo, paske l ap sekwe.   
\q1
\v 3 Ou te \x + \xo 60:3 \xt Sòm 66:12\x* fè pèp Ou a wè anpil bagay di.  
\q1 Ou te bay nou diven pou bwè ki fè nou toudi.   
\q1
\v 4 Ou te bay yon drapo pou sila ki gen lakrent Ou yo,  
\q1 pou fè l byen parèt akoz verite a. \qs Tan\qs*   
\b  
\q1
\v 5 Pou \x + \xo 60:5 \xt Det 33:12\x* byeneme Ou yo kab delivre,  
\q1 Sove avèk men dwat Ou e reponn nou!   
\q1
\v 6 Bondye te pale nan sentete Li:  
\q1 “Mwen va triyonfe!  
\q1 Mwen va divize Sichem  
\q1 e tire yon lin nan vale \x + \xo 60:6 \xt Jen 33:17\x*Succoth la.   
\q1
\v 7 Galaad se pou Mwen e Manassé se pa M.  
\q1 Anplis, Éphraïm se kas sou tèt Mwen.  
\q1 Juda se \x + \xo 60:7 \xt Jen 49:10\x*baton wayal Mwen an.   
\q1
\v 8 Moab se basen lave Mwen.  
\q1 Sou \x + \xo 60:8 \xt II Sam 8:2-14\x*Edom, Mwen va jete soulye Mwen.  
\q1 Mwen rele viktwa sou peyi Filisten yo.”   
\b  
\q1
\v 9 Kilès k ap fè m rive nan vil fòterès la?  
\q1 Kilès k ap mennen mwen antre Edom?   
\q1
\v 10 Èske Ou menm, SENYÈ a, pa t \x + \xo 60:10 \xt Sòm 60:1\x* rejte nou?  
\q1 Epi èske Ou p ap sòti avèk lame nou yo, O Bondye?   
\q1
\v 11 O bannou sekou kont advèsè a,  
\q1 paske delivrans pa lòm se an ven.   
\q1
\v 12 Nan Bondye, nou va fè bèl bagay yo ak gwo kouraj.  
\q1 Se Li menm ki va foule lènmi nou yo anba pye.   
\c 61  
\d Pou direktè koral la; sou yon enstriman a kòd; Yon Sòm David  
\q1
\v 1 Koute kri mwen, O Bondye.  
\q1 Prete atansyon a lapriyè mwen.   
\q1
\v 2 Soti nan dènye pwent latè,  
\q1 mwen rele Ou lè kè m fèb;  
\q1 Mennen mwen sou wòch  
\q1 ki pi wo pase m nan.   
\q1
\v 3 Paske Ou te yon refij pou mwen,  
\q1 yon fò ki wo,  
\q1 yon gran fòs kont lènmi yo.   
\q1
\v 4 Kite mwen \x + \xo 61:4 \xt Sòm 23:6\x* rete nan tant Ou an jis pou tout tan.  
\q1 Kite mwen pran refij anba zèl Ou. \qs Tan\qs*   
\q1
\v 5 Paske Ou te koute ve mwen yo, O Bondye.  
\q1 Ou te ban mwen eritaj a sila ki \x + \xo 61:5 \xt Det 28:58 \x*gen krent non Ou yo.   
\q1
\v 6 Ou va fè lavi a wa a byen long.  
\q1 Ane li yo va tankou anpil jenerasyon.   
\q1
\v 7 Li va abite devan SENYÈ a jis pou tout tan.  
\q1 Senyè, bay li \x + \xo 61:7 \xt Sòm 40:11\x*lanmou dous avèk verite pou li kapab andire.   
\q1
\v 8 Konsa, mwen va chante lwanj Ou jis pou tout tan.  
\q1 Konsa, m kapab peye ve mwen yo jou apre jou.   
\c 62  
\d Pou direktè koral la; selon Jeduthun; Yon Sòm David  
\q1
\v 1 Nanm mwen ap poze sèl nan Bondye.  
\q1 Sali m se nan Li.   
\q1
\v 2 Se Li sèl ki \x + \xo 62:2 \xt Sòm 89:26\x* wòch mwen, sali mwen, ak sitadèl mwen.  
\q1 Menm gwo sò p ap boulvèse m.   
\q1
\v 3 Pou jiskilè, nou va atake yon nonm?  
\q1 Alò, èske nou ta touye li, nou tout,  
\q1 tankou yon \x + \xo 62:3 \xt És 30:13\x* miray k ap panche?  
\q1 Tankou yon kloti k ap kraze?   
\q1
\v 4 Yo plen entansyòn pou pouse li soti nan wo pozisyon li.  
\q1 Yo \x + \xo 62:4 \xt Sòm 4:2\x* pran plezi nan tout sa ki fo.  
\q1 Yo beni avèk bouch yo, men anndan yo bay madichon.   
\q1
\v 5 Nanm mwen \x + \xo 62:5 \xt Sòm 62:1\x* tann an silans sèlman Bondye.  
\q1 Paske espwa mwen se nan Li.   
\q1
\v 6 Li se sèl ki \x + \xo 62:6 \xt Sòm 62:2\x* wòch mwen, sali mwen, ak sitadèl mwen.  
\q1 Mwen p ap ebranle menm.   
\q1
\v 7 \x + \xo 62:7 \xt Sòm 85:9\x* Sali mwen an, avèk glwa mwen rete nan Bondye.  
\q1 Wòch fòs mwen an, ak kote pou m kache, se nan Bondye.   
\q1
\v 8 Mete konfyans nan Li tout tan, O pèp la.  
\q1 \x + \xo 62:8 \xt I Sam 1:15 \x*Vide kè nou devan Li.  
\q1 Bondye se yon refij pou nou.   
\q1
\v 9 Moun nan \x + \xo 62:9 \xt Sòm 49:2\x* pozisyon ba yo se sèl yon souf nan van.  
\q1 Moun ki plase wo yo se manti.  
\q1 Nan pèz balans yo, se monte, yap monte.  
\q1 Ansanm menm, yo pi fay ke yon souf.   
\q1
\v 10 Pa mete konfyans nan peze kou moun desann.  
\q1 Ni pa mete fo espwa nan \x + \xo 62:10 \xt És 61:8 \x*vòlè.  
\q1 Si richès nou ogmante, pa mete kè nou sou yo.   
\q1
\v 11 Yon fwa, Bondye te pale.  
\q1 De fwa, mwen gen tan tande sa:  
\q1 Ke pouvwa, se pou Bondye.   
\q1
\v 12 Epi anplis, lanmou dous se pou Ou, O Senyè.  
\q1 Paske Ou bay rekonpans a lòm selon  
\q1 zèv li yo.   
\c 63  
\d Yon Sòm David, lè l te nan dezè Juda a.  
\q1
\v 1 O Bondye, Ou se Bondye mwen.  
\q1 Mwen va chache Ou ak tout kè m.  
\q1 Nanm mwen \x + \xo 63:1 \xt Sòm 42:2\x* swaf pou Ou.  
\q1 Chè m anvi Ou nan yon peyi epwize e sèch kote nanpwen dlo.   
\q1
\v 2 Konsa, mwen \x + \xo 63:2 \xt Sòm 27:4\x* te wè Ou nan sanktyè a,  
\q1 ak pouvwa Ou, ak laglwa Ou.   
\q1
\v 3 Akoz \x + \xo 63:3 \xt Sòm 69:16\x* lanmou dous Ou pi bon pase lavi,  
\q1 lèv mwen va louwe Ou.   
\q1
\v 4 Pou sa, mwen va beni Ou \x + \xo 63:4 \xt Sòm 104:33\x* tout tan ke m viv.  
\q1 Mwen va leve men m nan non Ou.   
\q1
\v 5 Nanm mwen \x + \xo 63:5 \xt Sòm 36:8\x* satisfè konsi avèk ma zo ak grès,  
\q1 e bouch mwen ap ofri lwanj  
\q1 avèk lèv ranpli de jwa.   
\q1
\v 6 Lè m sonje Ou sou kabann mwen,  
\q1 mwen medite sou Ou nan \x + \xo 63:6 \xt Sòm 16:7 \x*vèy de nwi an.   
\q1
\v 7 Paske Ou te konn sekou mwen.  
\q1 Nan \x + \xo 63:7 \xt Sòm 17:8\x* lonbraj a zèl Ou, mwen chante ak jwa.   
\q1
\v 8 Nanm mwen \x + \xo 63:8 \xt Nonb 32:12\x* kole ak Ou.  
\q1 Men dwat Ou fè m kenbe.   
\q1
\v 9 Men sila ki chache lavi mwen pou detwi li yo,  
\q1 va desann \x + \xo 63:9 \xt Sòm 55:15 \x*jis nan fon latè.   
\q1
\v 10 Yo va \x + \xo 63:10 \xt Jr 18:21\x* livre a pouvwa nepe.  
\q1 Yo va tounen manje pou rena mawon.   
\q1
\v 11 Men Wa a va rejwi nan Bondye.  
\q1 Tout moun ki sèmante pa Li menm yo, va twouve glwa.  
\q1 Paske bouch a sila ki bay manti yo, va fèmen.   
\c 64  
\d Pou direktè koral la. Yon Sòm David.  
\q1
\v 1 Tande vwa m, O Bondye nan plent mwen an.  
\q1 \x + \xo 64:1 \xt Sòm 140:1\x*Konsève lavi m kont laperèz lènmi an.   
\q1
\v 2 Pwoteje m kont konsèy sekrè a malfektè yo,  
\q1 kont boulvèsman a \x + \xo 64:2 \xt Sòm 59:2\x*sila ki fè mechanste yo.   
\q1
\v 3 Ki te file lang yo tankou nepe.  
\q1 Yo te pwente flèch pawòl anmè yo,   
\q1
\v 4 pou tire an kachèt sou sila ki inosan yo.  
\q1 Sibitman yo tire sou li, san lakrent.   
\q1
\v 5 Yo kenbe fèm a pwòp desen mechan yo.  
\q1 Yo pale sou \x + \xo 64:5 \xt Sòm 140:5\x* pyèj ke y ap fòme an sekrè yo.  
\q1 Yo di: “Se kilès ki kab wè yo?”   
\q1
\v 6 Yo fè manèv pou enjistis e di:  
\q1 “Nou prè pou yon konplo byen fòme”.  
\q1 Paske panse lenteryè a moun se byen fon.   
\q1
\v 7 Men \x + \xo 64:7 \xt Sòm 7:12-13\x* Bondye va tire sou yo avèk yon flèch.  
\q1 Sibitman, yo va blese.   
\q1
\v 8 Konsa, yo va \x + \xo 64:8 \xt Sòm 9:3\x* chape tonbe.  
\q1 Pwòp lang pa yo va kont yo.  
\q1 Tout moun ki wè yo va souke tèt yo.   
\q1
\v 9 Nan moman sa a, tout moun va krent.  
\q1 Konsa, yo va \x + \xo 64:9 \xt Jr 51:10\x* deklare zèv Bondye yo.  
\q1 Ak sajès yo va konsidere sa Li te fè a.   
\q1
\v 10 Nonm ladwati a va \x + \xo 64:10 \xt Job 22:19\x* kontan nan SENYÈ a!  
\q1 Yo va pran refij nan Li,  
\q1 epi tout moun dwat yo va fè kè kontan.   
\c 65  
\d Pou direktè koral la; yon Sòm David. Yon chan.  
\q1
\v 1 Se lwanj k ap tann Ou, O Bondye nan Sion.  
\q1 Ve yo va fèt anvè Ou.   
\q1
\v 2 O Ou menm ki tande priyè yo,  
\q1 a Ou menm \x + \xo 65:2 \xt Sòm 86:9\x*tout moun vini.   
\q1
\v 3 Inikite m t ap kanpe kont mwen;  
\q1 men pou transgresyon nou yo,  
\q1 Ou kouvri yo.   
\q1
\v 4 A la \x + \xo 65:4 \xt Sòm 33:12\x* beni se sila ke Ou chwazi a e mennen toupre,  
\q1 pou l ka rete nan lakou Ou.  
\q1 Nou va satisfè ak tout bagay ki bon lakay Ou,  
\q1 sen tanp Ou a.   
\q1
\v 5 Avèk \x + \xo 65:5 \xt Sòm 45:4\x* zèv mèvèy e dwat, Ou reponn nou,  
\q1 O Bondye sali nou an.  
\q1 Se Ou menm ki espwa tout pwen latè a,  
\q1 jis rive nan lanmè pi lwen an.   
\q1
\v 6 Ki etabli mòn yo pa pwisans Ou,  
\q1 Akoz Ou \x + \xo 65:6 \xt Sòm 93:1 \x*pran zam pwisans Ou.   
\q1
\v 7 Ou kalme raj vag lanmè yo,  
\q1 Avèk gwo boulvèsman lanm yo.   
\q1
\v 8 Sila ki rete jis nan \x + \xo 65:8 \xt Sòm 2:8\x* dènye pwent latè yo  
\q1 kanpe byen etone a mèvèy Ou yo.  
\q1 Ou fè maten avèk aswè kriye ak jwa.   
\q1
\v 9 Ou vizite tè a e fè li gen abondans.  
\q1 Ou anrichi li anpil.  
\q1 Flèv Bondye a plen ak dlo.  
\q1 Ou prepare sereyal yo, paske se konsa ou òganize l.   
\q1
\v 10 Ou wouze tranch li yo an abondans.  
\q1 Ou fè do li vin poze.  
\q1 Ou fè l vin mou \x + \xo 65:10 \xt Det 32:2\x* ak lapli an abondans;  
\q1 Ou beni kwasans plant li.   
\q1
\v 11 Ou te kouwone ane a avèk \x + \xo 65:11 \xt Sòm 104:28\x* bonte Ou.  
\q1 Kabwa yo plen pwodwi rekòlt la.   
\q1
\v 12 \x + \xo 65:12 \xt Job 38:26-27\x* Patiraj nan dezè yo gen abondans,  
\q1 Epi kolin yo mare senti yo ak jwa.   
\q1
\v 13 Chan yo \x + \xo 65:13 \xt Sòm 144:13\x* abiye menm ak bann mouton.  
\q1 Vale yo fin ranpli ak sereyal.  
\q1 Yo rele fò ak lajwa!  
