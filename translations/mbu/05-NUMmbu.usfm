\id NUM - Mbula
\h Ɓalban
\toc1 Inea Malǝmce mala Musa mǝnana à kǝ tunǝi ama Ɓalban ngga
\toc2 Ɓal
\toc3 Ɓal
\mt1 Ɓalban
\imt1 MƏNCAU
\im Malǝmce mala \bk Ɓalban \bk* ngga kǝ bang cau mala amǝ Isǝrayila tite a bàkú mǝnana à nying Nkono Saina bà yiu malea a njar-takuli mala nzong-nzali mala nzali mǝnana Ɓakuli akdǝmba pàcau ama nǝ̀ pea wia ka. Lullǝu mǝnia à pè mǝnia yì malǝmce ka, nda amur mugula gir mǝnana a ɓalǝi ka, yì ɓalban mǝnana Musa ɓal làkkì mala amǝ Isǝrayila a Nkono Saina sǝ à lo aban o ka; andǝ ɓalban mǝnana à ɓallia a Mowap, a njar-takuli mala Jodan, anzǝm nza mwashat mana yi kútí ka. Aɓa bákú mǝnana a nre ka amǝnia yì aɓalban ɓari ka, amǝ Isǝrayila wari a Kadesh Baniya, a njar-nzali mala nzong-nzali Kan'ana, sǝama à gandǝ kúti aɓa nzali pacauni ɗàng. Anzǝm mǝnana à malna apǝlǝkia pas a ban mǝno ka, à wari a bu-nzali mǝnana a njartakuli mala Nggeasala Jodan ngga, a ban mǝnana bare aɓwana malea duk kam, sǝ cilia gilǝrǝia ace yàl-nkaring nggeasala ace kutio aɓa Kan'ana ka.
\ip Malǝmce mala \bk Ɓalban\bk* ngga bǝlɓacau na amur aɓwana mǝnana à kum ɓabum-ɓungya kusǝ pas sǝ à lǝmdǝ ɓangciu lang à kùtí aɓa mǝkwane ka, sǝ à mgbicau arǝ Ɓakuli, sǝ arǝ Musa, yì ɓwa mǝnana Ɓakuli twali ɓǝ̀ gingnǝia ka. Kǝɓicau na amur domǝsǝcau mala Ɓakuli andǝ ɗenyinǝban male mǝnana camarǝ lǝmdǝi aɓwana male, kat andǝ rǝɓungya andǝ mgbikiru malea ka. Ɗǝm ngga nda amur paɓamuru mala Musa aban Ɓakuli andǝ aɓwana male, andǝ ɗwanyi dǝurǝo male arǝ acau, kat andǝ amani ama ɓè fara ka ndanǝ ɗwanyi munyi ka.
\iot Agir mǝnana a ɓalǝi ka
\io1 Amǝ'Isǝrayila gilǝrǝia ace nying Nkono Saina \ior 1:1--9:23\ior*
\io2 1. Ɓalban mǝdǝmbe \ior 1:1--4:49\ior*
\io2 2. Anggurcau andǝ anzongcau ɗàngɗáng \ior 5:1--8:26\ior*
\io2 3. Ɓaria Lamsan Yàlîmurû \ior 9:1-23\ior*
\io1 Lo a Nkono Saina aban ká Mowap \ior 10:1--21:35\ior*
\io1 Agir mǝnana à kumban a Mowap ka \ior 22:1--32:42\ior*
\io1 Kàrkún acau mala gya, twal a Masar aban ká Mowap \ior 33:1-49\ior*
\io1 Akwarkiru ace yàl-nkaring Nggeasala Jodan \ior 33:50--36:13\ior*
\c 1
\s1 À ɓal amǝ'lwa mala amǝ Isǝrayila
\p 
\v 1 Yahweh nacau nǝ Musa aɓa Tara Ban-peri,\f + \fr 1:1 \ft Ɓalli aɓa: \xt Pur 27:21; 40:2,6-7\xt*\ft .\f* a ɓabondo Saina,\f + \fr 1:1 \ft Ɓalli aɓa: \xt Pur 19:1; Ɓal 33:16\xt*\ft .\f* a pwari mǝdǝmbe mala ɓaria zongŋo, a ɓaria pǝlǝa, anzǝm mana amǝ Isǝrayila purni ɓá nzali Masar ka, ama,
\v 2 <<Ɓal ɓinala amǝ Isǝrayila kat; ɓallia arǝ atau, arǝ aɓala-kàu malea; gilǝ lullǝ koya mwashat aɓalǝ aburana,
\v 3 twal a pǝlǝa lumi-ɓari aban ká dǝmba, mala koya ɓwabura mǝnana nǝ̀ gandǝ ká lwa a Isǝrayila ka; we wunǝ Haruna ka wun nǝ̀ gilǝ làkkì mala amǝ'lwa malea.
\v 4 Wu twal ɓwa mwashat a koya tàu, mǝnana ɓwamǝgule na a ɓala-kàu male ka, atà wun, ɓǝ̀ dupa wun gbasha.
\v 5 Amǝnia ka à nda ka alullǝ aburana mǝnana à nǝ̀ dupa wun gbasha ka:
\li1 Elizur muna-ɓwabura mala Shedeur a tàu mala Ruben;
\li1 
\v 6 Shelumiyel muna-ɓwabura mala Zurishaddai a tàu mala Shimiyon;
\li1 
\v 7 Nashon muna-ɓwabura mala Aminadap a tàu mala Yahuda;
\li1 
\v 8 Netanel muna-ɓwabura mala Zuar a tàu mala Isaka;
\li1 
\v 9 Eliyap muna-ɓwabura mala Helon a tàu mala Zebulu;
\li1 
\v 10 atà amǝkà Yisǝfu ka:
\li2 Elishama muna-ɓwabura mala Ammihud a tàu mala Ifǝrem, sǝ
\li2 Gamaliyel muna-ɓwabura mala Pedazur a tàu mala Manasa;
\li1 
\v 11 Abidan muna-ɓwabura mala Gidiyoni a tàu mala Benjami;
\li1 
\v 12 Ahieza muna-ɓwabura mala Amishaddai a tàu mala Dan;
\li1 
\v 13 Pagiyel muna-ɓwabura mala Okran a tàu mala Asha;
\li1 
\v 14 Eliyasaf muna-ɓwabura mala Dewel a tàu mala Gad;
\li1 
\v 15 sǝ Ahira muna-ɓwabura mala Enan a tàu mala Naftali.
\m 
\v 16 Amǝnia ka à nda ka aburana mǝnana à tària aɓa ɓwabundǝa ace túró ka; à nda ka amúrû amur atau mala akeâ; à nda ka aɓwana-mǝgule amur aɓala mala amǝ Isǝrayila.>>
\p 
\v 17 Nda Musa andǝ Haruna twal aburana mǝnia à tunǝ alullǝia ka,
\v 18 sǝ à tunǝ ramba mala ɓwabundǝa kat a banɓwáná, a pwari mǝdǝmbe mala ɓaria zongŋo. Pǝlǝa à gilǝ làkkì mala aɓwana kat arǝ atau sǝ arǝ aɓala-kàu malea, koya ɓwabura mǝnana pǝlǝa male bingŋǝna lumi-ɓari aban ká dǝmba ka à gilǝ lullǝi,
\v 19 kǝla mana Yahweh banggi Musa ka. Anggo sǝ gilǝ làkkì malea a ɓabondo Saina.
\p 
\v 20 Tite nǝ amǝkà Ruben, muna-dǝmba mala Isǝrayila, à gilǝ lullǝ koya mwashat atà aburana arǝ atau, arǝ aɓala-kàu malea, kǝla mǝnana làkkì mala alullǝia pàk ka mwashat-mwashat, koya ɓwabura mǝnana pǝlǝa male bingŋǝna lumi-ɓari aban ká dǝmba, mǝnana nǝ̀ gandǝ ká lwa ka;
\v 21 à kum làkkì mala aburana a tàu mala Ruben ɓwa á-lumi-ine-bwamdǝ-tongno-nong-mwashat nǝ gbǝman-tongno (46,500).
\p 
\v 22 Atà amǝkà Shimiyon ngga, à gilǝ lullǝ koya mwashat atà aburana arǝ atau, arǝ aɓala-kàu malea, kǝla mǝnana làkkì mala alullǝia pàk ka mwashat-mwashat, koya ɓwabura mǝnana pǝlǝa male bingŋǝna lumi-ɓari aban ká dǝmba, mǝnana nǝ̀ gandǝ ká lwa ka;
\v 23 à kum làkkì mala aburana a tàu mala Shimiyon, ɓwa á-lumi-tongno-bwamdǝ-tongno-nong-ine nǝ gbǝman-tàrú (59,300).
\p 
\v 24 Atà amǝkà Gad ka, à gilǝ lullǝ koya mwashat atà aburana arǝ atau, arǝ aɓala-kàu malea, kǝla mǝnana làkkì mala alullǝia pàk ka mwashat-mwashat, koya ɓwabura mǝnana pǝlǝa male bingŋǝna lumi-ɓari aban ká dǝmba, mǝnana nǝ̀ gandǝ ká lwa ka;
\v 25 à kum làkkì mala aburana a tàu mala Gad ɓwa á-lumi-ine-bwamdǝ-tongno nǝ gbǝman-tongno-nong-mwashat nǝ lumi-tongno (45,650).
\p 
\v 26 Atà amǝkà Yahuda ka, à gilǝ lullǝ koya mwashat atà aburana arǝ atau, arǝ aɓala-kàu malea, kǝla mǝnana làkkì mala alullǝia pàk ka mwashat-mwashat, koya ɓwabura mǝnana pǝlǝa male bingŋǝna lumi-ɓari aban ká dǝmba, mǝnana nǝ̀ gandǝ ká lwa ka;
\v 27 à kum làkkì mala aburana a tàu mala Yahuda ɓwa á-lumi-tongno-nong-ɓari-bwamdǝ-ine nǝ gbǝman-tongno-nong-mwashat (74,600).
\p 
\v 28 Atà amǝkà Isaka ka, à gilǝ lullǝ koya mwashat atà aburana arǝ atau, arǝ aɓala-kàu malea, kǝla mǝnana làkkì mala alullǝia pàk ka mwashat-mwashat, koya ɓwabura mǝnana pǝlǝa male bingŋǝna lumi-ɓari aban ká dǝmba, mǝnana nǝ̀ gandǝ ká lwa ka;
\v 29 à kum làkkì mala aburana a tàu mala Isaka ɓwa á-lumi-tongno-bwamdǝ-ine nǝ gbǝman-ine (54,400).
\p 
\v 30 Atà amǝkà Zebulu ka, à gilǝ lullǝ koya mwashat atà aburana arǝ atau, arǝ aɓala-kàu malea, kǝla mǝnana làkkì mala alullǝia pàk ka mwashat-mwashat, koya ɓwabura mǝnana pǝlǝa male bingŋǝna lumi-ɓari aban ká dǝmba, mǝnana nǝ̀ gandǝ ká lwa ka;
\v 31 à kum làkkì mala aburana a tàu mala Zebulu ɓwa á-lumi-tongno-bwamdǝ-tongno-nong-ɓari nǝ gbǝman-ine (57,400).
\p 
\v 32 Atà amǝkà Yisǝfu, nǝban muna-ɓwabura male Ifǝrem ngga, à gilǝ lullǝ koya mwashat atà aburana arǝ atau, arǝ aɓala-kàu malea, kǝla mǝnana làkkì mala alullǝia pàk ka mwashat-mwashat, koya ɓwabura mǝnana pǝlǝa male bingŋǝna lumi-ɓari aban ká dǝmba, mǝnana nǝ̀ gandǝ ká lwa ka;
\v 33 à kum làkkì mala aburana a tàu mala Ifǝrem ɓwa á-lumi-ine nǝ gbǝman-tongno (40,500).
\v 34 Sǝ nǝban muna-ɓwabura male Manasa ka, à gilǝ lullǝ koya mwashat atà aburana arǝ atau, arǝ aɓala-kàu malea, kǝla mǝnana làkkì mala alullǝia pàk ka mwashat-mwashat, koya ɓwabura mǝnana pǝlǝa male bingŋǝna lumi-ɓari aban ká dǝmba, mǝnana nǝ̀ gandǝ ká lwa ka;
\v 35 à kum làkkì mala aburana a tàu mala Manasa ɓwa á-lumi-tàrú-nong-ɓari nǝ gbǝman-ɓari (32,200).
\p 
\v 36 Atà amǝkà Benjami ka, à gilǝ lullǝ koya mwashat atà aburana arǝ atau, arǝ aɓala-kàu malea, kǝla mǝnana làkkì mala alullǝia pàk ka mwashat-mwashat, koya ɓwabura mǝnana pǝlǝa male bingŋǝna lumi-ɓari aban ká dǝmba, mǝnana nǝ̀ gandǝ ká lwa ka;
\v 37 à kum làkkì mala aburana a tàu mala Benjami ɓwa á-lumi-tàrú-bwamdǝ-tongno nǝ gbǝman-ine (35,400).
\p 
\v 38 Atà amǝkà Dan ngga, à gilǝ lullǝ koya mwashat atà aburana arǝ atau, arǝ aɓala-kàu malea, kǝla mǝnana làkkì mala alullǝia pàk ka mwashat-mwashat, koya ɓwabura mǝnana pǝlǝa male bingŋǝna lumi-ɓari aban ká dǝmba, mǝnana nǝ̀ gandǝ ká lwa ka;
\v 39 à kum làkkì mala aburana a tàu mala Dan ɓwa á-lumi-tongno-nong-mwashat-nong-ɓari nǝ gbǝman-tongno-nong-ɓari (62,700).
\p 
\v 40 Atà amǝkà Asha ka, à gilǝ lullǝ koya mwashat atà aburana arǝ atau, arǝ aɓala-kàu malea, kǝla mǝnana làkkì mala alullǝia pàk ka mwashat-mwashat, koya ɓwabura mǝnana pǝlǝa male bingŋǝna lumi-ɓari aban ká dǝmba, mǝnana nǝ̀ gandǝ ká lwa ka;
\v 41 à kum làkkì mala aburana a tàu mala Asha ɓwa á-lumi-ine-nong-mwashat nǝ gbǝman-tongno (41,500).
\p 
\v 42 Atà amǝkà Naftali ka, à gilǝ lullǝ koya mwashat atà aburana arǝ atau, arǝ aɓala-kàu malea, kǝla mǝnana làkkì mala alullǝia pàk ka mwashat-mwashat, koya ɓwabura mǝnana pǝlǝa male bingŋǝna lumi-ɓari aban ká dǝmba, mǝnana nǝ̀ gandǝ ká lwa ka;
\v 43 à kum làkkì mala aburana a tàu mala Naftali ɓwa á-lumi-tongno-bwamdǝ-á-tàrú nǝ gbǝman-ine (53,400).
\p 
\v 44 Mǝnia ka nda làkkì mala aburana mǝnana Musa andǝ Haruna ɓallia ka, atārǝia andǝ aburana lum-nong-ɓari, aɓwana-mǝgule amur amǝ Isǝrayila mǝnana koyan ngga nda ace ɓala-kàu male ka.
\v 45 Amǝ Isǝrayila mǝnana kat pǝlǝa malea bingŋǝna lumi-ɓari aban ká dǝmba, mǝnana à nǝ̀ gandǝ ká lwa a Isǝrayila ka, à ɓallia kǝla mana à pa arǝ aɓala-kàu malea ka.
\v 46 Làkkì malea kat-kat ka nda á-gbǝman-tongno-nong-mwashat-bwamdǝ-tàrú nǝ gbǝman-tongno nǝ lumi-tongno (603,550).
\p 
\v 47 Sǝama Amǝ'Lawi\f + \fr 1:47 \ft Ɓalli aɓa: \xt Tite 34:25,30; 49:5-7; Pur 32:26-29; Ɓal 3:6,12-13,40-43; 8:16-19; 18:1; Nggur 10:8-9; 18:1-2; 21:5; Jes 13:14,33\xt*\ft .\f* a tàu mala akeâ ka, à ɓallia atà aɓwana ɗàng.
\v 48 Nda acemǝnana Yahweh bangŋǝ́nì Musa cau ama,
\v 49 <<She kǝ tàu mala Lawi nda mǝnana a pà nǝ ɓalli raka, sǝ a pà nǝ gilǝ làkkì malea atà amǝ Isǝrayila ɗàng.
\v 50 A kún mani ka awu nǝ twal Amǝ'Lawi ɓǝà duk amǝ'tsǝkir Taragula mala Acau-nakûn, andǝ agirtúró male kat, andǝ agir mǝnana kat à nda ace ka. À nda à nǝ̀ nggǝ twal Taragula andǝ agirtúró male kat ka; à nda à nǝ̀ ɗenyinǝi sǝ à nǝ̀ tsǝki agumli malea ɓǝà kàrì a tsùrú mala kàttì ka.
\v 51 A pwari mǝnana kat à nǝ̀ panzǝ Taragula ace tùr là-gumli ka, Amǝ'Lawi na à nǝ̀ panzǝki ka, sǝ a ban mǝnana kat à nǝ̀ kwaki Taragula kàm ngga, Amǝ'Lawi na à nǝ̀ pàk túrè ka. Ɓǝ̀ ɓwa-ɗàng\f + \fr 1:51 \fq ɓwa-ɗàng \ft ko ɓwa mǝnana ɓwa-Lawi na raka\f* gbashi banì ka ɓǝà wal-luí.
\v 52 Amǝ Isǝrayila nǝ̀ tsǝk agumli malea, koya tàu ka a kàttì male, sǝ koya ɓwa ka a ban tútà mala tàu male, arǝ anggǝsan mala amǝ'lwa malea.
\v 53 Sǝ Amǝ'Lawi ka, à nǝ̀ tsǝki agumli malea ɓǝà kàrì Taragula mala Acau-nakûn a tsùrú, ace mǝnana bumlulla mem ɓǝkǝa sulǝo amur ɓinado mala amǝ Isǝrayila raka. Amǝ'Lawi ka à nda mǝnana túró yál Taragula mala Acau-nakûn na amúrià ka.>>
\p 
\v 54 Amǝ Isǝrayila pàk koya gìr kǝla mana Yahweh banggi Musa ka.
\c 2
\s1 Came mala agumli arǝ akattì mala amǝ Isǝrayila
\p 
\v 1 Yahweh banggi Musa andǝ Haruna ama:
\v 2 <<Amǝ Isǝrayila ɓǝà tsǝki agumli arǝ akattì malea zak nǝ ban Tara Ban-peri, koya gumli a kàttì ka ɓǝ̀ ɓamǝsǝi pǝlǝ nǝban Tara Ban-peri a koya buì; koyan ngga a ban tútà nǝ baji mala ɓala-kàu malea.
\v 3 Amǝ Isǝrayila mǝnana à nǝ̀ tsǝk agumli malea a njar-takuli, a buì mala eauwe mala pwari ka, à nda ka anggǝsan mala amǝ'lwa aɓata tútà mala kàttì mala Yahuda. Ɓwa mǝnana nǝ̀ duk ɓwamǝgule amur amǝkà Yahuda ka nda Nashon, muna-ɓwabura mala Aminadap;
\v 4 amǝ'lwa mǝnana à ɓallia a nggǝsan male ka, làkkì malea na á-lumi-tongno-nong-ɓari-bwamdǝ-ine nǝ gbǝman-tongno-nong-mwashat (74,600).
\v 5 Amǝnana à nǝ̀ tsǝk agumli malea a nkanggaria ka nda tàu mala Isaka, sǝ ɓwamǝgule amur amǝkà Isaka ka nda Netanel, muna-ɓwabura mala Zuar;
\v 6 amǝ'lwa mǝnana à ɓallia a nggǝsan male ka, làkkì malea na á-lumi-tongno nǝ á-ine nǝ gbǝman-ine (54,400).
\v 7 Pǝlǝa tàu mala Zebulu nǝ̀ kpa; ɓwamǝgule amur amǝ'kà Zebulu ka nda Eliyap, muna-ɓwabura mala Helon,
\v 8 sǝ amǝ'lwa mǝnana à ɓallia a nggǝsan male ka, làkkì malea na á-lumi-tongno nǝ á-tongno-nong-ɓari nǝ gbǝman-ine (57,400).
\v 9 Yià mǝno kat à ɓallia arǝ anggǝsan mala amǝ'lwa malea a kàttì mala Yahuda ka, làkkì malea na á-gbǝman-mwashat nǝ á-lumi-tongno-nong-tàrú nǝ á-tongno-nong-mwashat nǝ gbǝman-ine (186,400). Yia na à nǝ̀ tita lo gya ka.
\p 
\v 10 <<Amǝ Isǝrayila mǝnana a njar-kunmur ka, à nda ka anggǝsan mala amǝ'lwa mala kàttì mala Ruben aɓata tútà malea; ɓwamǝgule amur amǝkà Ruben ngga nda Elizur, muna-ɓwabura mala Shedeur;
\v 11 amǝ'lwa mǝnana à ɓallia a nggǝsan male ka, làkkì malea na á-lumi-ine nǝ á-tongno-nong-mwashat nǝ gbǝman-tongno (46,500).
\v 12 Sǝ aɓwana mǝnana à nǝ̀ tsǝk agumli malea a nkanggaria ka nda tàu mala Shimiyon; ɓwamǝgule amur amǝkà Shimiyon ngga nda Shelumiyel, muna-ɓwabura mala Zurishaddai;
\v 13 amǝ'lwa mǝnana à ɓallia a nggǝsan male ka, làkkì malea na á-lumi-tongno nǝ á-tongno-nong-ine nǝ gbǝman-tàrú (59,300).
\v 14 Pǝlǝa tàu mala Gad nǝ̀ kpa, sǝ ɓwamǝgule amur amǝkà Gad ka nda Eliyasaf, muna-ɓwabura mala Rewel;
\v 15 amǝ'lwa mǝnana à ɓallia a nggǝsan male ka, làkkì malea na á-lumi-ine nǝ á-tongno nǝ gbǝman-tongno-nong-mwashat nǝ lumi-tongno (45,650).
\v 16 Yià mǝno kat à ɓallia arǝ anggǝsan mala amǝ'lwa malea a kàttì mala Ruben ngga, làkkì malea na á-gbǝman-mwashat nǝ á-lumi-tongno nǝ á-mwashat nǝ gbǝman-ine nǝ lumi-tongno (151,450). À nda ka ɓaria aɓwana aɓa lo gya.
\p 
\v 17 <<Anzǝm Ruben ngga Amǝ'Lawi nǝ agir mala Tara Ban-peri a buia ka, à nǝ̀ lo gya a tsùrú mala akattì; à nǝ̀ lo gya kǝla mana à tsǝì ace bwal kàttì ka, koyan ngga a ban male aɓata tútà male.
\p 
\v 18 <<Amǝ Isǝrayila mǝnana à nǝ̀ pa a njar-nzali ka, à nda ka anggǝsan mala amǝ'lwa mala kàttì mala Ifǝrem aɓata tútà malea; ɓwamǝgule amur amǝkà Ifǝrem ngga nda Elishama, muna-ɓwabura mala Ammihud;
\v 19 amǝ'lwa mǝnana à ɓallia a nggǝsan male ka, làkkì malea na á-lumi-ine nǝ gbǝman-tongno (40,500).
\v 20 Aɓwana mǝnana a nkanggaria ka nda tàu mala Manasa; ɓwamǝgule amur amǝkà Manasa ka nda Gamaliyel, muna-ɓwabura mala Pedazur;
\v 21 amǝ'lwa mǝnana à ɓallia a nggǝsan male ka, làkkì malea na á-lumi-tàrú nǝ á-ɓari nǝ gbǝman-ɓari (32,200).
\v 22 Pǝlǝa tàu mala Benjami nǝ̀ kpa, sǝ ɓwamǝgule amur amǝkà Benjami ka nda Abidan, muna-ɓwabura mala Gidiyoni;
\v 23 amǝ'lwa mǝnana à ɓallia a nggǝsan male ka, làkkì malea na á-lumi-tàrú nǝ á-tongno nǝ gbǝman-ine (35,400).
\v 24 Yià mǝno kat à ɓallia arǝ anggǝsan mala amǝ'lwa malea a kàttì mala Ifǝrem ngga, làkkì malea na á-gbǝman-mwashat nǝ á-tongno-nong-tàrú nǝ gbǝman-mwashat (108,100). À nda ka tàruia aɓwana aɓa lo gya.
\p 
\v 25 <<Amǝ Isǝrayila mǝnana à nǝ̀ pà a njar-nza ka, à nda ka anggǝsan mala amǝ'lwa mala kàttì mala Dan aɓata tútà malea; ɓwamǝgule amur amǝkà Dan ngga nda Ahieza, muna-ɓwabura mala Amishaddai;
\v 26 amǝ'lwa mǝnana à ɓallia a nggǝsan male ka, làkkì malea na á-lumi-tongno-nong-mwashat nǝ á-ɓari nǝ gbǝman-tongno-nong-ɓari (62,700).
\v 27 Aɓwana mǝnana à nǝ̀ tsǝk agumli malea a nkanggaria ka nda tàu mala Asha; ɓwamǝgule amur amǝkà Asha ka nda Pagiyel, muna-ɓwabura mala Okran;
\v 28 amǝ'lwa mǝnana à ɓallia a nggǝsan male ka, làkkì malea na á-lumi-ine nǝ á-mwashat nǝ gbǝman-tongno (41,500).
\v 29 Pǝlǝa tàu mala Naftali nǝ̀ kpa, sǝ ɓwamǝgule amur amǝkà Naftali ka nda Ahira, muna-ɓwabura mala Enan;
\v 30 amǝ'lwa mǝnana à ɓallia a nggǝsan male ka, làkkì malea na á-lumi-tongno nǝ á-tàrú nǝ gbǝman-ine (53,400).
\v 31 Yià mǝno kat à ɓallia a kàttì mala Dan ngga, làkkì malea na á-gbǝman-mwashat nǝ á-lumi-tongno nǝ á-tongno-nong-ɓari nǝ gbǝman-tongno-nong-mwashat (157,600). À nda ka amǝ'tànkwàng aɓa lo gya.>>
\p 
\v 32 Amǝnia ka à nda ka amǝ Isǝrayila mana à ɓallia arǝ aɓala-kàu malea ka. Yià mǝno kat à ɓallia arǝ akattì malea, arǝ anggǝsan mala amǝ'lwa malea ka, làkkì malea na á-gbǝman-tongno-nong-mwashat nǝ á-tàrú nǝ gbǝman-tongno nǝ lumi-tongno (603,550).
\v 33 Sǝama Amǝ'Lawi ka à ɓallia atà amǝ Isǝrayila ɗàng, kǝla mana Yahweh banggi Musa ka.
\p 
\v 34 Anggo sǝ amǝ Isǝrayila pa. À kpata cau mǝnana kat Yahweh banggi Musa ka, sǝ anggo sǝ à duk kàttì aɓata atútà malea, sǝ anggo gbal sǝ à puro aban ká, koyan ngga a tàu andǝ ɓala-kàu male.
\c 3
\s1 Amuna-burana mala Haruna
\p 
\v 1 Amǝnia ka à nda ka amuna andǝ amǝkà Haruna andǝ Musa mǝnana à gilǝia a bàkú mana Yahweh bangcau nǝ Musa a Nkono Saina ka.
\v 2 Amuna-burana mala Haruna ka à nda ka Nadap muna-dǝmba, andǝ Abihu, andǝ Eleaza sǝ Itamar.
\v 3 Amǝnia ka à nda ka alullǝ amuna-burana mala Haruna mǝnana à ɗārǝia sǝ à kùria wia túró-pǝris ka.
\v 4 Sǝama Nadap andǝ Abihu ka à wǔ a ɓadǝm Yahweh acemǝnana à pàgir nǝ bǝsa mǝnana mala Ɓakuli na raka, a ɓadǝm Yahweh a ɓabondo Saina,\f + \fr 3:4 \ft Ɓalli aɓa: \xt Pǝris 10:1-2\xt*\ft .\f* sǝ à pànǝ amuna ɗang. Acemani ka, kǝ Eleaza andǝ Itamar na à pàk túró-pǝris atà tárrià Haruna ka.
\p 
\v 5 Pǝlǝa Yahweh nacau nǝ Musa ama,
\v 6 <<Yinǝ tàu mala Lawi ɓǝà sung tù sǝ ɓǝà yi came a ɓadǝm Haruna pǝris, ace mǝnana ɓǝà pàkki wi gbasha aɓa túró ka.
\v 7 À nǝ̀ pàkki atúró mǝnana amale na ka, sǝ à nǝ̀ pàkkî amǝ Isǝrayila atúró mǝnana à nda cea a ɓinalea ka, a ɓadǝm Tara Ban-peri, a ban pàk túró aɓa Taragula.
\v 8 Yià na à nǝ̀ yál agir mǝnana aɓa Tara Ban-peri ka, sǝ à nǝ̀ pàk atúró mǝnana nda ace amǝ Isǝrayila, a ban túró aɓa Taragula ka.
\v 9 Twal Amǝ'Lawi, pè Haruna andǝ amuna-burana male; ǝn tarnia aɓalǝ amǝ Isǝrayila kat ace bwali wi túró.
\v 10 Awu nǝ twal Haruna andǝ amuna-burana male ɓǝà bwal dobuno-pǝris malea. Sǝ ɓǝ̀ ɓekǝ ɓwa-ɗàng gbàshìban ban-mǝfele ka, dumǝna púp à nǝ̀ wal-luí.>>
\p 
\v 11 Ɗǝm ngga Yahweh bangcau nǝ Musa ama,
\v 12 <<Sǝni, ǝn twalǝna Amǝ'Lawi aɓalǝ amǝ Isǝrayila a kúnì koya muna-dǝmba mǝnana nda tita puro a bum nggé atà amǝ Isǝrayila ka. Amǝ'Lawi nǝ̀ duk amem,
\v 13 acemǝnana amuna-dǝmba kat ka amem na. A pwari mǝno ǝn wal amuna-dǝmba kat aɓa nzali Masar ka,\f + \fr 3:13 \ft Ɓalli aɓa: \xt Pur 13:15-16\xt*\ft .\f* ǝn tárì ɓamúràm amuna-dǝmba kat a Isǝrayila, amala aɓwapǝndǝa andǝ amala agirkusǝu kǝm. À nǝ̀ duk amem: Mǝ nda Yahweh.>>
\p 
\v 14 Yahweh nacau nǝ Musa a ɓabondo Saina, ama,
\v 15 <<Ɓal amuna-burana mala Lawi arǝ aɓala-kàu malea sǝ arǝ anggurkwar malea; koya muna-ɓwabura mǝnana à ɓǝli pàngŋǝ̀nà zongŋo mwashat aban ká dǝmba ka awu nǝ ɓalli.>>
\v 16 Nda Musa ɓallia kǝla mana Yahweh banggi wi ka.
\v 17 Sǝ amǝnia ka à nda ka alullǝ amuna-burana mala Lawi: Gashon andǝ Kohat andǝ Merari.
\v 18 Sǝ amǝnia ka à nda ka amuna-burana mala Gashon: Libǝni andǝ Shimeyi; koyan ngga a nggurkwar male.
\v 19 Sǝ amuna-burana mala Kohat ka à nda ka: Amram, andǝ Izǝhar, andǝ Hebǝron, andǝ Uziyel; koyan ngga a nggurkwar male.
\v 20 Amuna-burana mala Merari ka, à nda ka: Mali andǝ Mushi; koyan ngga a nggurkwar male. Amǝnia ka, à nda ka anggurkwar mala Amǝ'Lawi, arǝ aɓala-kàu malea.
\p 
\v 21 Aɓwana a nggurkwar mala Amǝ'Libǝni andǝ nggurkwar mala Amǝ'Shimeyi ka à nda ka amǝɓala mala Gashon. À nda ka amǝ'Gashon arǝ anggurkwar malea.
\v 22 Amuna-burana mǝnana à ɓǝlia, à pàngŋǝ̀nà zongŋo mwashat aban ká dǝmba, mǝnana à ɓallia ka, làkkì malea na á-tongno-nong-ɓari nǝ gbǝman-tongno (7,500).
\v 23 Aɓwana mana arǝ anggurkwar mala amǝ'Gashon ngga à nǝ̀ tsǝk kàttì malea anzǝm Taragula a njar-nzali,
\v 24 sǝ Eliyasaf, muna-ɓwabura mala Layel ka nda nǝ̀ duk múrû amur ɓala-kàu mala amǝ'Gashon ngga.
\v 25 Túró mala amuna-burana mala Gashon ngga nda yál Taragula, andǝ Tara mǝfele andǝ alagìr male mana à gìrì ka, andǝ lagìr gbar bankutio male,
\v 26 andǝ alagìr mǝnana à kàrì patal ka, andǝ lagìr mala gbar bankutio aɓa patal mǝnana kàrì Taragula andǝ gyangŋan ngga, andǝ anggur, andǝ agirtúró mǝnana kat à kǝ pangŋǝ̀nà túró nǝia ka.
\p 
\v 27 Amǝkà Kohat ka, à nda ka nggurkwar mala Amǝ'Amram, andǝ nggurkwar mala Amǝ'Izǝhar, andǝ nggurkwar mala Amǝ'Hebǝron, andǝ nggurkwar mala Amǝ'Uziyel; yià mǝnia ka à nda ka anggurkwar mala amǝ'Kohat.
\v 28 Aɓa ɓal koya muna-ɓwabura mǝnana à ɓǝli pàngŋǝ̀nà zongŋo mwashat aban ká dǝmba ka, à kum làkkì malea á-tongno-nong-tàrú nǝ gbǝman-tongno-nong-mwashat (8,600). Túró yál ban-mǝfele ka nda a buia.
\v 29 Anggurkwar mala amuna andǝ amǝkà Kohat nǝ̀ tsǝk kàttì malea a buì mala Taragula mǝnana sǝn njar-kunmur ka,
\v 30 sǝ Elizafan, muna-ɓwabura mala Uziyel na nǝ̀ duk ɓwamǝgule amur aɓala-kàu mala anggurkwar mala amǝ'Kohat ka.
\v 31 Túró malea nda yál Akwati, andǝ kpamgbang-tsǝk-agir, andǝ gìr-tàmsǝ pitǝla, andǝ agyangŋan, andǝ agirtúró mǝnana apǝris kǝ pangŋǝ̀nà túró nǝia a ban-mǝfele ka, andǝ lagìr-kasǝbân;\f + \fr 3:31 \fq lagìr-kasǝbân \ft mǝnana gau nre ban nggea-mǝfele andǝ ban-mǝfele ka.\f* koya túró mǝnana kat je amǝnia yì agir ka, à nǝ̀ pè.
\v 32 Sǝ Eleaza muna-ɓwabura mala Haruna, yì pǝris ka nda nǝ̀ duk múrû amur aɓwana-mǝgule mala Amǝ'Lawi, sǝ nǝ̀ tsǝk-mǝsǝì arǝ aɓwana mǝnana kat à kǝ̀ pàkki atúró aɓa ban-mǝfele ka.
\p 
\v 33 Amǝkà Merari ka, à nda ka nggurkwar mala Amǝ'Mali, andǝ nggurkwar mala Amǝ'Mushi: Amǝnia ka à nda ka anggurkwar mala Merari.
\v 34 Aɓwana mǝnana à ɓallia, yì amuna-burana mǝnana kat ɓǝlia ka, à pàngŋǝ̀nà zongŋo mwashat aban ká dǝmba ka, à kum làkkì malea á-tongno-nong-mwashat nǝ gbǝman-ɓari (6,200).
\v 35 Sǝ ɓwamǝgule amur ɓala-kàu mala anggurkwar mala Merari ka nda Zuriyel, muna-ɓwabura mala Abihel. À nda à nǝ̀ tsǝk kàttì malea a buì mala Taragula mǝnana sǝn njar-nza ka.
\v 36 Sǝ túró mǝnana à kàsǝî amuna-burana mala Merari ka nda tsǝkir anggun-tara mala Taragula, andǝ anggun-gangndea, andǝ anggun-ɓalǝu, andǝ agumtǝli-tǝrteà, andǝ agirtúró male kat; koya túró mǝnana kat je amǝnia yì agir ka, à nǝ̀ pè;
\v 37 ɗǝm ngga à nǝ̀ tsǝkir anggun-kala mǝnana à kàrì patal ka, andǝ agumtǝli-tǝrteà, andǝ ankpako tara, andǝ anggúr malea.
\p 
\v 38 Aɓwana mǝnana à nǝ̀ tsǝk kàttì malea aɓadǝm Taragula a buì mǝnana sǝn njar-takuli, aɓadǝm Tara Ban-peri a buì mala eauwe mala pwari ka, à nda ka Musa andǝ Haruna andǝ amuna-burana male. Tsǝkir Taragula andǝ yálè ka nda a buia ace lùmsǝ atúró mǝnana à nǝ̀ peǎ ace amǝ Isǝrayila ka. Sǝ ɓǝ̀ ɓekǝ ɓwa-ɗàng gbàshìbanì ka à nǝ̀ wal-luí
\v 39 Làkkì mala Amǝ'Lawi mǝnana Yahweh banggi Musa andǝ Haruna ama ɓǝà ɓallia arǝ anggurkwar malea, koya muna-ɓwabura mǝnana à ɓǝli pàngŋǝ̀nà zongŋo mwashat aban ká dǝmba ka, nda á-lumi-ɓari-nong-ɓari (22,000).
\s1 Akmúr muna-dǝmba
\p 
\v 40 Sǝ Yahweh banggi Musa ama, <<Ɓal amuna-dǝmba amuna-burana mala amǝ Isǝrayila kat, amǝnana ɓǝlia ka, à pàngŋǝ̀nà zongŋo mwashat aban ká dǝmba ka, sǝ wu gilǝ alullǝia.
\v 41 Ak Amǝ'Lawi ɓǝà duk amem, a kúnì amuna-dǝmba kat atà amǝ Isǝrayila, sǝ agirkusǝu mala Amǝ'Lawi a kúnì amuna-dǝmba kat mala agirkusǝu mala amǝ Isǝrayila. Mǝ nda Yahweh.>>
\v 42 Nda Musa ɓal amuna-dǝmba kat mala amǝ Isǝrayila, kǝla mana Yahweh banggi wi ka.
\v 43 Làkkì mala amuna-dǝmba amuna-burana kat-kat, mǝnana ɓǝlia ka à pàngŋǝ̀nà zongŋo mwashat aban ká dǝmba, kǝla mana à gilǝ alullǝia ka, à nda á-lumi-ɓari-nong-ɓari nǝ gbǝman-ɓari nǝ lumi-tongno-nong-ɓari nǝ mǝsǝi tàrú (22,273).
\p 
\v 44 Sǝ Yahweh bangcau nǝ Musa, ama,
\v 45 <<Ak Amǝ'Lawi a kúnì amuna-dǝmba mala amǝ Isǝrayila kat, sǝ agirkusǝu mala Amǝ'Lawi a kúnì amalea. Amǝ'Lawi nǝ̀ duk amem. Mǝ nda Yahweh.
\v 46 Sǝ ace mbwe boalo akmúr amuna-dǝmba mǝnia gbǝman-ɓari nǝ lumi-tongno-nong-ɓari nǝ mǝsǝi tàrú (273) mana làkkì malea eauwe amur làkkì mala Amǝ'Lawi ka,
\v 47 awu nǝ ak shekel\f + \fr 3:47 \fq shekel \ft ka nda mǝsǝbolo-azǝrfa mǝnana à kārǝ́ dǝmbǝrya male sǝ à earna amurí a Tara-mǝfele ka. (Shekel mwashat ka mǝtyang lum-nong-ɓari na.)\f* tongno a kúnì koyan ateà; ak boale aɓa kpata dǝmbǝrya mala shekel, yì mǝsǝbolo-azǝrfa mǝnana à kārǝ́ dǝmbǝrya male sǝ à earna amurí a Tara-mǝfele ka.
\v 48 Pè Haruna andǝ amuna-burana male boalo mala akmúr amǝ Isǝrayila mǝnia mana làkkì malea eau ka.>>
\p 
\v 49 Nda Musa ak boalo mala akmúrú mǝnia ka a bu aɓwana mana làkkì malea eapi mala aɓwana mana Amǝ'Lawi akmúria ka.
\v 50 A bu amuna-dǝmba mala amǝ Isǝrayila ka, ak boalo shekel á-mwashat nǝ gbǝman-tàrú nǝ lumi-tongno-nong-mwashat nǝ mǝsǝi tongno (1,365); À kpata shekel mala Tara-mǝfele.
\v 51 Sǝ Musa pè Haruna andǝ amuna-burana male boalo mala akmúrú mǝnia ka, kǝla mana Yahweh banggi wi ka.
\c 4
\s1 Atúró mala amǝ'Kohat
\p 
\v 1 Yahweh bangcau nǝ Musa andǝ Haruna, ama,
\v 2 <<Ɓal làkkì mala amuna-burana mala Kohat aɓalǝ Amǝ'Lawi, arǝ anggurkwar malea sǝ arǝ aɓala-kàu malea.
\v 3 Ɓal aburana mǝnana kat pǝlǝa malea na lumi-tàrú aban ká lumi-tongno, mǝnana à kārǝ́na à nǝ̀ pàk túró aɓa Tara Ban-peri ka.
\p 
\v 4 <<Túró mala amǝ'Kohat aɓa Tara Ban-peri ka nda tsǝkir agir nggea-mǝfele andǝ yália.
\v 5 Lang kàttì nǝ̀ lo ace o ka, Haruna andǝ amuna-burana male nǝ̀ kùtí aɓa Ban Nggea Mǝfele, sǝ à nǝ̀ sulǝ lagìr-kasǝbân sǝ à nǝ̀ gìr Akwati mala Acau-nakûn nǝi.
\v 6 Pǝlǝa à nǝ̀ kùmsǝi wi nggu-mbulpǝndǝa\f + \fr 4:6 \fq nggu-mbulpǝndǝa \ft ko nggu mǝɓǝlke.\f* amurí, sǝ à nǝ̀ sárǝ́ nggubyau mǝnana mùr-rǝì ka mǝlùre na kat ka amurí, sǝ à nǝ̀ oasǝi wi agare.
\p 
\v 7 <<À nǝ̀ sárǝ́ nggubyau mǝlùre amúr kpamgbang mala Bǝredi Ɓadǝm Yahweh.\f + \fr 4:7 \ft Ɓalli aɓa: \xt Pur 25:30; Pǝris 24:5-7\xt*\ft .\f* Amur nggubyau man ngga, à nǝ̀ tsǝk aparanti, andǝ atasau (ace muku-gìr loasǝ yele mǝ'rǝmɓoarne), andǝ amuna-nkenye, andǝ amuna-bàng ace pàgir mala girnùná; sǝ bǝredi mana ndakam koya pwari ka,\f + \fr 4:7 \ft Ɓalli aɓa: \xt Pur 25:30; Pǝris 24:5-9\xt*\ft .\f* nǝ̀ pàk kàm gbal.
\v 8 Pǝlǝa à nǝ̀ sárǝ́ nggubyau mǝbangye amúrià, à nǝ̀ kùmsǝ múrià nǝ nggu-mbulpǝndǝa, sǝ à nǝ̀ oasǝi wi agare.
\p 
\v 9 <<À nǝ̀ twal nggubyau mǝlùre sǝ à nǝ̀ gìrna gìr-tàmsǝ pitǝla mana nda ace pà tǎlaban ngga, atārǝia andǝ apitǝla male, andǝ amǝmyal\f + \fr 4:9 \fq amǝmyal \ft ace kǝtǝriki tú kún bùgìr-bǝsa.\f* male, andǝ atasau-bǝsa, andǝ adú male kat mala mùrú olif mǝnana à kǝ soapi wi ka.
\v 10 Sǝ à nǝ̀ kàrrì andǝ agirtúró male kat aɓa girkàrre mala nggu-mbulpǝndǝa, sǝ à nǝ̀ tsǝì amur gambǝlam\f + \fr 4:10 \fq gambǝlam \ft ko <<gabǝlang>>\f* twal gìr.
\p 
\v 11 <<Gyangŋan bolo-njengǝlan ngga à nǝ̀ sárǝ́ nggubyau mǝlùre amurí ɓǝ̀ gìrì, à nǝ̀ kùmsǝi wi nggu-mbulpǝndǝa, sǝ à nǝ̀ oasǝi wi agare.
\v 12 Sǝ agirtúró kat mala túróperi aɓa ban-mǝfele ka, à nǝ̀ pwania sǝ à nǝ̀ kàrria aɓa nggubyau mǝlùre, à nǝ̀ kùmsǝia wia gìrkùmsǝo mala nggu-mbulpǝndǝa amúrià, sǝ à nǝ̀ tsǝia amur gambǝlam twal gìr.
\p 
\v 13 <<À nǝ̀ pwan tú mana aɓa gyangŋan bolo-bángŋá ka sǝ à nǝ̀ sárǝì wi nggubyau mǝwanye amurí.
\v 14 Pǝlǝa à nǝ̀ tsǝk agirtúró mala gyangŋanì kat amurí: atasau-bǝsa, andǝ ashokali-soagìr, andǝ ashebǝl, andǝ ankenye, yì agirtúró kat mala gyangŋan; à nǝ̀ sárǝ́ gìrkùmsǝo mala nggu-mbulpǝndǝa amurí sǝ à nǝ̀ oasǝi wi agare a ban malea.
\p 
\v 15 <<Anzǝm mǝnana Haruna andǝ amuna-burana male malna gìrki agir mǝfele andǝ agirtúró kat mala ban-mǝfele ka, sǝ lang kàttì gilǝnarǝì nǝ̀ lo gya ka, amǝ'Kohat nǝ̀ yiu ace twal agirnì. Sǝama à pà nǝ̀ jeka agir mǝfele ɗàng, ɓǝ̀ ana raka à nǝ̀ wǔ. Amǝ'Kohat na à nǝ̀ pwan agir mǝnana aɓa Tara Ban-peri ka.
\p 
\v 16 <<Túró mala Eleaza muna-ɓwabura mala Haruna pǝris ka, nda tsǝkir mùrú ace pà tǎlaban, andǝ muku-gìr loasǝ yele mǝrǝmɓoarne, andǝ pàgir mala mǝsǝsa mana à pākiyi pwari-pwari ka, andǝ mùrú-ɗārǝ́bân. Ɗǝm ngga yì na nǝ̀ nggǝ tsǝk-mǝsǝì arǝ Taragula andǝ agir mǝnana kat aɓalǝi ka, kat andǝ ban-mǝfele andǝ agirtúró ɓalǝi.>>
\p 
\v 17 Yahweh banggi Musa andǝ Haruna ama,
\v 18 <<Wu kǝa ɗeki amuna andǝ amǝkau mǝnana aɓalǝ amǝ'Lawi a nggurkwar mala Kohat ka tea ɓǝ̀ twal ɗàng.
\v 19 Ace amsǝia, ɓǝà kǝa wuki raka, lang à nǝ̀ sung tù a ban agir nggea-mǝfele ka, pàk mǝnia ka acea: Haruna andǝ amuna-burana male ɓǝà kùtí aɓa ban-mǝfele, sǝ ɓǝà pè koyan atea ka túró male andǝ gìr mǝnana nǝ̀ twal ka.
\v 20 Sǝama amǝ'Kohat pà nǝ̀ kúti ace sǝn agir mǝfele ɗàng ko bǝti, ɓǝ̀ ana raka à nǝ̀ wǔ.>>
\s1 Atúró mala amǝ'Gashon
\p 
\v 21 Yahweh nacau nǝ Musa ama,
\v 22 <<Ɓal làkkì mala amuna-burana mala Gashon gbal, arǝ aɓala-kàu sǝ arǝ anggurkwar malea.
\v 23 Ɓal aburana mǝnana kat pǝlǝa malea na lumi-tàrú aban ká lumi-tongno, mǝnana à kārǝ́na à nǝ̀ pàk túró aɓa Tara Ban-peri ka.
\v 24 Mǝnia ka nda túró mana amuna andǝ amǝ'kàu arǝ anggurkwar mala amǝ'Gashon nǝ̀ pak ka, aɓa túró andǝ twaltwalo ka:
\v 25 Yià na à nǝ̀ twal alagìr\f + \fr 4:25 \ft Ɓalli aɓa: \xt Pur 26:1-13; 36:8-17\xt*\ft .\f* mala Taragula, sǝ Tara Ban-peri andǝ lagìr-murí, andǝ nggu-mbulpǝndǝa mǝnana gìr múrià ka, andǝ lagìr gbar bankutio aɓa Tara Ban-peri,
\v 26 andǝ alagìr mǝnana à kàrì patal, andǝ lagìr ace gbar kún patal mana kàrì Taragula andǝ gyangŋan ngga, andǝ anggur malea, andǝ agirtúró ace túró malea kat. Amǝ'Gashon na à nǝ̀ pàk gìr mǝnana kat ɓoaro ɓǝà pè nǝ amǝnia yì agir ka.
\v 27 Atúró mǝnana kat amuna-burana mala amǝ'Gashon nǝ̀ pè, ko mala twaltwalo, ko aɓea atúró ka, à nǝ̀ pè aɓata gingnǝban mala Haruna andǝ amuna-burana male. Sǝ awu nǝ pea wia agir mǝnana kat à nǝ̀ twal ka, ɓǝ̀ duk túró malea.
\v 28 Mǝnia ka nda túró mǝnana nda ace amuna andǝ amǝkà Gashon, aɓa Tara Ban-peri ka. Sǝ túró mana à nǝ̀ pea wia ka, nda aɓata gingnǝban mala Itamar muna-ɓwabura mala Haruna pǝris.
\s1 Atúró mala amǝ'Merari
\p 
\v 29 <<Ɓal làkkì mala amǝkà Merari arǝ anggurkwar malea sǝ arǝ aɓala-kàu malea.
\v 30 Ɓal aburana mǝnana kat pǝlǝa malea na lumi-tàrú aban ká lumi-tongno, mǝnana à kārǝ́na à nǝ̀ pàk túró aɓa Tara Ban-peri ka.
\v 31 Túró malea aɓa Tara Ban-peri, aɓa túró mǝnana kat à nǝ̀ pè ka, nda twal anggun-tara mala Taragula, andǝ anggun-gangndea male, andǝ anggun-ɓalǝu male, andǝ agumtǝli-tǝrteà,
\v 32 kat andǝ anggun-kala mana à kàrì patal ka, andǝ agumtǝli-tǝrteà, andǝ ankpako malea, andǝ anggúr malea, andǝ agirtúró malea kat, andǝ acili agir mǝnana kat à nǝ̀ pà gbasha arǝ túró ka.
\v 33 Mǝnia ka nda túró mǝnana nda ace amuna andǝ amǝkà Merari, aɓa Tara Ban-peri ka. Sǝ túró mana à nǝ̀ pea wia ka, nda aɓata gingnǝban mala Itamar muna-ɓwabura mala Haruna pǝris.>>
\s1 Kàsǝetù
\p 
\v 34 Nda Musa andǝ Haruna andǝ aɓwana-mǝgule mala ɓwabundǝa ɓal amuna andǝ amǝkà Kohat arǝ anggurkwar, sǝ arǝ aɓala-kàu malea ka.
\v 35 À ɓal aburana mǝnana kat pǝlǝa malea na lumi-tàrú aban ká lumi-tongno, mǝnana à kārǝ́na à nǝ̀ pàk túró aɓa Tara Ban-peri ka;
\v 36 sǝ yià mǝnana à ɓallia arǝ anggurkwar mala Kohat ka, à nda á-ɓari nǝ gbǝman-tongno-nong-ɓari nǝ lumi-tongno (2,750).
\v 37 Amǝnia ka nda làkkì mala aɓwana mǝnana à ɓallia arǝ anggurkwar mala amǝ'Kohat, yià mǝnana kat à pàktúró aɓa Tara Ban-peri, mana Musa andǝ Haruna ɓallia, kǝla mana Yahweh bangŋi nǝ kún Musa ka.
\p 
\v 38 À ɓal amuna andǝ amǝkà Gashon, arǝ anggurkwar, sǝ arǝ aɓala-kàu malea,
\v 39 twal a ban ɓwa mǝnana pǝlǝa male na lumi-tàrú aban ká lumi-tongno, mǝnana kārǝ́na nǝ̀ pàk túró aɓa Tara Ban-peri ka;
\v 40 yià mǝnana à ɓallia arǝ anggurkwar malea, sǝ arǝ aɓala-kàu malea ka à nda á-ɓari nǝ gbǝman-tongno-nong-mwashat nǝ lumi-tàrú (2,630).
\v 41 Mǝnia ka nda làkkì mala amuna andǝ amǝkau a nggurkwar mala Gashon, mǝnana à kārǝ́na à nǝ̀ pàk túró aɓa Tara Ban-peri, mana Musa andǝ Haruna ɓallia kǝla mana Yahweh bang ngga.
\p 
\v 42 Aburana mǝnana à ɓallia arǝ anggurkwar mala amuna andǝ amǝkà Merari, sǝ arǝ aɓala-kàu malea,
\v 43 twal a ban ɓwa mǝnana pǝlǝa male na lumi-tàrú aban ká lumi-tongno, mǝnana kārǝ́na nǝ̀ pàk túró aɓa Tara Ban-peri ka,
\v 44 yià mǝno à ɓallia arǝ anggurkwar malea ka, à nda á-tàrú nǝ gbǝman-ɓari (3,200).
\v 45 Mǝnia ka nda làkkì mala amuna andǝ amǝkau a nggurkwar mala Merari, mana Musa andǝ Haruna ɓallia kǝla mana Yahweh bangŋi nǝ kún Musa ka.
\p 
\v 46 Nda Musa andǝ Haruna andǝ aɓwana-mǝgule mala Isǝrayila ɓal Amǝ'Lawi arǝ anggurkwar sǝ arǝ aɓala-kàu malea ka.
\v 47 Aɓwana mǝnana kat pǝlǝa malea na lumi-tàrú aban ká lumi-tongno, mǝnana à kārǝ́na à nǝ̀ pàk túró andǝ twaltwalo mala agir mala Tara Ban-peri ka,
\v 48 làkkì malea na á-tongno-nong-tàrú nǝ gbǝman-tongno nǝ lumi-tongno-nong-tàrú (8,580).
\v 49 À ɓallia aɓa kpata nzongcau mala Yahweh nǝ kún Musa, koyan ngga nǝ túró male mǝnana nǝ̀ pàk ka ko gìr mǝnana nǝ̀ twal ka. Anggo sǝ à ɓallia kǝla mana Yahweh banggi Musa ka.
\c 5
\s1 À pusǝki amǝɓeami a kàttì
\p 
\v 1 Yahweh nacau nǝ Musa, ama,
\v 2 <<Banggi amǝ Isǝrayila ama ɓǝà pusǝ koyan mǝnana ndanǝ kwánó nggû,\f + \fr 5:2 \ft Ɓalli aɓa: \xt Pǝris 13\xt*\ft .\f* andǝ koyan mǝnana mùrgìr kǝ pur arǝì, andǝ koyan mǝnana pǝndǝki rǝì nǝ je lú ka, ɓǝà purî ɓá kàttì;
\v 3 ko ɓwabura ko ɓwama na ka, wun nǝ̀ pusǝia, ɓǝà purî ɓá kàttì, ace mǝnana ɓǝà kǝa pǝndǝki akàttì malea, mǝnana mǝ ndakam nǝdo aɓalǝia ka ɗàng.>>
\p 
\v 4 Amǝ Isǝrayila pàk mǝno; à pusǝkia à purî ɓá kàttì. Kǝla mana Yahweh banggi Musa ka, anggo sǝ amǝ Isǝrayila pǎ.
\s1 Bang-cauɓikea andǝ mbwegìr-akúnì
\p 
\v 5 Sǝ Yahweh nacau nǝ Musa, ama,
\v 6 <<Banggi amǝ Isǝrayila ama: Lang ɓwabura ko ɓwama yàl nzongcau mala Yahweh nǝ pakkì ɓì mǝɓane a koya buì, sǝ ɓwê yì ear cauɓikea male ka,
\v 7 dumǝna púp ɓwê nǝ̀ bang cauɓikea male mǝnana pàk ka. Sǝ dumǝna púp nǝ̀ mbwegìr puppup a kúnì gìr mǝnana kat kiɗiki ka, sǝ nǝ̀ tsǝk banì mwashat aɓa gauwe tongno mala gìrnî amurí, sǝ nǝ̀ pè ɓwa mǝno pàkki wi mǝɓane ka.
\v 8 Sǝ ɓǝ̀ ɓwê pànǝ kǝ mǝliɓala mǝnana à nǝ̀ kánǝ mǝno yì mbwegìr-akúnì ka abani raka, yì mbwegìr-akúnì ka pǝlǝna mala Yahweh sǝ dumǝna púp à nǝ̀ pè pǝris, atārǝia andǝ gam mala shawuɗiban mǝnana à nǝ̀ shawuɗi ɓwê nǝi ace mǝɓane mǝnana pàk ka.
\v 9 Sǝ koya ɓoro mala apagir mǝfele mala amǝ Isǝrayila, mǝnana à kǝ yinǝia aban pǝris ka, à nǝ̀ duk mala pǝris.
\v 10 Agir mǝfele mala koya ɓwa ka amale na, sǝ ɓǝ̀ mana kat ɓwa pè pǝris ka mala pǝris na.>>
\s1 Ɓwama mana burí tsǝki wi cau arǝì ka
\p 
\v 11 Yahweh nacau nǝ Musa, ama,
\v 12-14 <<Banggi amǝ Isǝrayila ama: Ɓǝ̀ ɓwabura tsǝki māmí cau arǝì, mala kyanggî njar, ama māmí lǝmdǝna ɗwanyi-domǝsǝcau a baní, nǝ nongŋo-nda andǝ ɓe ɓwabura, sǝ burí sǝlǝce ɗàng, sǝ kǝ ɓwa sǝlǝce raka (acemǝnana kǝ ɓwa sǝni ko bwali aban pe raka), sǝ ɓǝ̀ burí pàk mɓali, sǝ nusǝ māmí nǝ pǝndǝki rǝì, ko mɓali bwali sǝ nusǝ māmí, kat andǝ amani ama māmí pǝndǝki rǝì raka,
\v 15 ɓǝ̀ kyan nǝ māmí aban pǝris. Sǝ ɗǝm ngga ɓǝ̀ yinǝ pagìr amur māmí: tyang mwashat mala muku mǝssa-bálì; sǝama pà nǝ̀ so kǝ mùrú amurí ɗàng, sǝ pà nǝ̀ kpapi wi myang-kwarra aɓalǝi ɗàng, acemǝnana pàgir mǝsǝsa na mala nusǝban-mɓali, sǝ pàgir na ace kasǝɓalǝu, mala nyesǝ ɗenyicau arǝ pě-mǝɓane mala ɓwa.
\p 
\v 16 <<Sǝ Pǝris nǝ̀ yinǝi ɓwame ɓǝ̀ yi came aɓadǝm Yahweh.
\v 17 Pǝlǝa pǝris nǝ̀ so mùr mǝfele aɓa nkwaring dǝɓang sǝ nǝ̀ ɗàrǝ́ tú a nzali aɓa Taragula sǝ nǝ̀ soe aɓa mùr mǝnia.
\v 18 Sǝ pǝris nǝ̀ tamsǝ ɓwame aɓadǝm Yahweh, nǝ̀ panzǝki nyang múr ɓwame, sǝ nǝ̀ tsǝki wi pàgir mǝsǝsa mala kasǝɓalǝu, mǝnana nda pàgir mǝsǝsa mala nusǝban-mɓali ka, a ɓabui, sǝ yì pǝris ka nǝ̀ twal mùr mǝlulle mǝnana kǝ yinǝ suban ngga a buì.
\v 19 Pǝlǝa pǝris nǝ̀ tsǝk ɓwame ɓǝ̀ kángìr, nǝ̀ ne ɓwame ama, <Ɓǝ̀ ɓekǝ ɓwabura mǝnana burio na raka nongnǝ we ɗang, sǝ a pǝlǝmì njar a kútímá a ɓeami, kǝla ɓwama aɓata burí raka, ɓǝ̀ suban mǝnana mǝnia yì mùr mǝlulle kǝ yinǝi ka ɓǝ̀ yàllî muro.
\v 20 Sǝama ɓǝ̀ a kyangŋǝ́nì njar, mǝnana a nda aɓata burio, a pǝndǝkina ɓamurò, sǝ ɓè ɓwabura mǝnana burio na raka nongŋǝna nǝ we ka,
\v 21 suban mǝnia ka nǝ̀ sulǝo amuro.> Pǝlǝa pǝris ka nǝ̀ tsǝk ɓwame ɓǝ̀ kána, kángìr mala suban, sǝ pǝris nǝ̀ banggi ɓwame ama, <Ɓǝ̀ aɓwana mô sǝlǝ ama suban mala Yahweh na amuro, lang Yahweh tsǝngŋǝ̀nà abyalo kwetǝna, sǝ tabumo mwarna ka;
\v 22 ɓǝ̀ mùr mǝnia mǝnana kǝ yinǝ suban ngga, ɓǝ̀ kùtí a bumo, ɓǝ̀ tsǝk tabumo ɓǝ̀ mwaro sǝ abyalo ɓǝà eamdǝe.>
\p <<Pǝlǝa ɓwame ka nǝ̀ ear ama, <Amin, Ɓǝ̀ do anggo.>
\p 
\v 23 <<Pǝlǝa pǝris ka nǝ̀ gilǝ asuban mǝnia ka aɓa mbu-malǝmce, sǝ nǝ̀ lea nǝ mùr, ɓǝà solǝo aɓa mùr mǝlulle mǝno.
\v 24 Sǝ nǝ̀ tsǝk ɓwame ɓǝ̀ nu mùr mǝlulle mǝnia mana kǝ yinǝ suban ngga, sǝ yì mùr ka nǝ̀ kùtí a bumi sǝ nǝ̀ yinǝi wi nǝ tanni mǝlulle.
\v 25 Sǝ pǝris nǝ̀ ak pàgir mǝsǝsa mala nusǝban-mɓali a bu ɓwame, sǝ nǝ̀ lǝmdǝí a kuli aɓadǝm Yahweh, sǝ nǝ̀ yinǝi aban gyangŋan.
\v 26 Sǝ pǝris nǝ̀ ɗàrǝ́ aɓa pàgir mǝsǝsa mǝno ka, ɓǝ̀ lùmsǝ ɓabui, ɓǝ̀ duk kāmbe male mala kasǝɓalǝu, sǝ nǝ̀ pisǝi amur gyangŋan; anzǝm mǝno ka, nǝ̀ tsǝk ɓwame ɓǝ̀ nu mùr mǝno.
\p 
\v 27 <<Anzǝm mana tsǝ̀ngŋǝ̀nà ɓwame nuna mùrnî, sǝ ɓǝ̀ do ama ɓwame pǝndǝkina ɓamurì, lǝmdǝna ɗwanyi-domǝsǝcau aban burí ka, mùr mala yinǝ suban ngga nǝ̀ kùtí a bumi, sǝ nǝ̀ yinǝi wi nǝ tanni mǝlulle, sǝ tabumi nǝ̀ mwaro, sǝ abyali nǝ̀ kpami, sǝ ɓwame nǝ̀ pǝlǝ gìr suban aɓalǝ aɓwana male.
\v 28 Sǝama ɓǝ̀ ɓwame ka pǝndǝki ɓamurì ɗàng, nda aɓa ɓoarnsari ka, nǝ̀ pà atàrǝì, kǝgìr mǝɓane pà nǝ̀ kumi ɗàng, sǝ nǝ̀ kum ɓǝlmuna.
\p 
\v 29 <<Mǝnia ka nda nggurcau mǝnana à nǝ̀ kpate amur mɓali ka, lang ɓwama mǝnana ndanǝ bura amurí ka kyanggî njar, sǝ kya pǝndǝki ɓamurì,
\v 30 ko a pwari mana ɓwabura ka mɓali bwali sǝ pàk mɓali ace māmí ka. Yì ka nǝ̀ yinǝ māmí aɓadǝm Yahweh sǝ pǝris nǝ̀ kpata acau mala nggurcau mǝnia amur ɓwame.
\v 31 Yì bura ɓwama ka, à pà nǝ̀ sǝni nǝ cauɓikea ɗàng,\f + \fr 5:31 \fq à pà nǝ̀ sǝni nǝ cauɓikea ɗàng \ft ko <<à pà nǝ̀ tsǝkîcau arǝì ama pàngŋǝ́nì māmí gìr mǝɓane ɗàng>> \f* sǝ ɓwama ka, bafe mala cauɓikea male mǝnana pàk ka nǝ̀ do amurí.>>
\c 6
\s1 Pacau mala Ɓwa-nazir
\p 
\v 1 Yahweh nacau nǝ Musa, ama,
\v 2 <<Nacau nǝ amǝ Isǝrayila sǝ wu banggia wia ama: Lang ɓwabura ko ɓwama nǝ̀ twal kanggǝrang pàcau nǝ-shambum, mala duk ɓwa-nazir, ace tàr ɓamurì aban Yahweh ka,
\v 3 dumǝna púp nǝ̀ yál ɓamurì arǝ nu mùr-anap andǝ mba. Dumǝna púp pà nǝ̀ nu ɓekǝ mùr-hangŋa mǝnana à pè nǝ mùr-anap, ko mùr-hangŋa mana à pè nǝ mba ka ɗàng; sǝ pà nǝ̀ nu ɓekǝ girnùná mǝnana à kàmbi arǝ ɓǝla-anap ka ɗàng; sǝ pà nǝ̀ lì ɓǝla-anap, pwàlè ko imè ɗàng.
\v 4 Aɓalǝ anonggio kat mala tàrɓamuru male ka, pà nǝ̀ lì ɓekǝ gìr mǝnana kat pùro arǝ nggun-anap, ko amǝsǝi na ko nggwate na ka ɗàng.
\p 
\v 5 <<Aɓalǝ anonggio mala pàcau nǝ-shambum mala tàrɓamuru male kat ka, ɓekǝ nkembu pa nǝ̀ je ɓamúrí ɗàng, she pwari mǝnana anonggio mala do male kǝla ɓwa-nazir aban Yahweh lùmsǝna ka. Yì ka nǝ̀ duk mǝfele sǝ nǝ̀ nying nyang ɓamúrí ɓǝ̀ dāh'rya.
\p 
\v 6 <<Aɓalǝ anonggio kat mala tàrɓamuru male aban Yahweh ka, dumǝna púp pà nǝ̀ ká amur lú ɗàng.
\v 7 Dumǝna púp, pà nǝ̀ pǝndǝki ɓamurì ɗàng ko ɓǝ̀ nda ace lú mala tárrí, ko nggè, ko mǝ'eambi-ɓwabura, ko mǝ'eambi-ɓwama ka ɗàng. Mǝnia ka nda acemǝnana nyang mǝnana a múrí, mana lǝmdǝ tàrɓamuru male aban Ɓakuli ka, nda a ɓamúrí.
\v 8 Aɓalǝ anonggio mala tàrɓamuru male kat ka, nǝ̀ duk mǝfele aban Yahweh.
\p 
\v 9 <<Ɓǝ̀ kǝ ɓwa kasǝa wǔ aɓa yasǝlǝban a nkanggari, mǝnana nǝ̀ tsǝa nyang ɓamúrí mala tàrɓamuru male nǝ̀ pǝndǝki ka, dumǝna púp nǝ̀ mwa nyang ɓamúrí a pwari lakban male; nǝ̀ mwe a tongno-nong-ɓaria pwari.
\v 10 A tongno-nong-tàruià pwari ka nǝ̀ yinǝ akutugangyi ɓari ko amuna-kutumurǝm ɓari aban pǝris, a bankutio aɓa Tara Ban-peri.
\v 11 Pǝris nǝ̀ pà mwashat kǝla pàgir ace cauɓikea, sǝ ɓè ka ace pàgir mala pisǝe kǝring, sǝ nǝ̀ shawuɗì, acemǝnana lú mǝno wù a nkanggari tù ka, nunbi wi cauɓikea amurí, sǝ dumǝna púp ama àkǝ̀ pwari mǝno ka nǝ̀ tsǝk ɓamúrí ɓǝ̀ duk mǝfele ɗǝm.
\v 12 Dumǝna púp nǝ̀ tàr ɓamurì ɗǝm ace anonggio male, mala do ɓwa-nazir aban Yahweh, sǝ nǝ̀ yinǝ muna-gam mǝnana mbule mwashat ka ace pàgir mala kumcau. Sǝ anonggio mǝɗiɗyalni ka, à nǝ̀ ueɓà acemǝnana tàrɓamuru male pǝndǝkina.
\p 
\v 13 <<Mǝnia ka nda nggurcau mǝnana à nǝ̀ kpate ace ɓwa-nazir, lang anonggio mala tàrɓamuru male lùmsǝna ka: à nǝ̀ yinǝi a bankutio aɓa Tara Ban-peri;
\v 14 sǝ yì ka nǝ̀ yinǝ pàgir male aban Yahweh ani: muna-gam mǝnana mbule mwashat, sǝ ɓè kǝgìr mǝɓane pà kàm arǝì raka, ace pàgir mala pisǝe kǝring, andǝ muna-nzur mǝnana mbule mwashat ka, ace pàgir mala gǝshi cauɓikea, andǝ gam mana ɓè kǝgìr mǝɓane pà kàm arǝì raka, ace pàgir mala dotarǝu,
\v 15 atārǝia andǝ apagir mala mǝsǝsa andǝ apagir mala girnùná malea, andǝ zace mala agbatali bǝredi mana yis pà arǝì raka, mana à pea nǝ muku mǝɓǝlke mana à zurì nǝ mùrú olif ka, andǝ abiskit mana à pea nǝ yis raka, sǝ à hasǝkia wia mùrú olif arǝia ka.
\p 
\v 16 <<Sǝ pǝris nǝ̀ yinǝ agir mǝnia kat ka tù aɓadǝm Yahweh, sǝ nǝ̀ pà gir'nkila mala pàgir mala gǝshi cauɓikea male, yì ɓwa-nazir, andǝ pàgir male ace pisǝe kǝring.
\v 17 Pǝlǝa nǝ̀ pà gir'nkila nǝ gam mala pàgir ace dotarǝu aban Yahweh, atārǝia andǝ bǝredi mana yis pà arǝì raka, mǝnana nda aɓa zace ka; sǝ a masǝlǝate ka nǝ̀ pàgir mala mǝsǝsa atārǝia andǝ pàgir mala girnùná.
\p 
\v 18 <<Anzǝm mǝno ka, yì ɓwa-nazir ka nǝ̀ mwa ɓamúrí mala tàrɓamuru male, a bankutio aɓa Tara Ban-peri, sǝ nyang ɓamúrí mala tàrɓamuru male ka, nǝ̀ twali sǝ nǝ̀ tsǝì amur bǝsa mǝnana nda aɓata gir'nkila mala apagir mala dotarǝu ka.
\v 19 Anzǝm mana ɓwa-nazir mwana nyang mala tàrɓamuru male ka, pǝlǝa pǝris nǝ̀ twal bù gam, mǝnana à lamni ka, sǝ nǝ̀ twal gbatali bǝredi mwashat mǝnana yis pà arǝì raka, andǝ biskit mwashat mana yis pà arǝì raka, amǝnana aɓa zace ka, sǝ nǝ̀ tsǝia arǝ abú ɓwa-nazir.
\v 20 Pǝlǝa pǝris nǝ̀ loasǝia a kuli, ɓǝ̀ duk pàgir mǝnana à loasǝi a kuli aɓadǝm Yahweh ka. Akāmbe mǝfele na ace pǝris, atārǝia andǝ kikil gam mana à loasǝi a kuli, andǝ byali mana à pàna ɓoro nǝi ka.\f + \fr 6:20 \ft Ɓalli gbal aɓa: \xt Pur 29:27-28; Pǝris 7:14,32,34\xt*\ft .\f* Anzǝm mǝno ka, yì ɓwa-nazir ka à earǝ́nì wi ɓǝ̀ nu mùr-anap.
\p 
\v 21 <<Mǝnia ka nda nggurcau amur ɓwa-nazir mǝnana pàcau nǝ-shambum, sǝ amur pàgir male mǝnana nǝ̀ pà aban Yahweh ace tàrɓamuru male ka. Dumǝna púp nǝ̀ yinǝ pàgir mǝnia ka, sǝ ɓǝ̀ nǝ̀ gandǝi ka, ɓǝ̀ yinǝ aɓea amur mǝno, aɓa kpata nggurcau mala tàrɓamuru male.>>
\s1 Tsǝkbu mala apǝris amur aɓwana
\p 
\v 22 Yahweh ne Musa ama,
\v 23 <<Banggi Haruna andǝ amuna-burana male ama: Ani sǝ wun nǝ̀ tsǝki amǝ Isǝrayila bù. Wun nǝ̀ banggia wia ama,
\q1 
\v 24 << <Ɓǝ̀ Yahweh tsǝka wun bù,
\q2 ɓǝ̀ yál wun;
\q1 
\v 25 Ɓǝ̀ Yahweh tsǝa ɓamǝsǝi ɓǝ̀ tǎ amur wun,
\q2 ɓǝ̀ lǝmdǝa wun ɓwamuru;
\q1 
\v 26 Ɓǝ̀ Yahweh sǝn mǝsǝswatǝr ma'wun,
\q2 ɓǝ̀ pa wun dorǝpwala.>
\p 
\v 27 <<Anggo ka à nǝ̀ tsǝk lullǝam amur amǝ Isǝrayila, sǝ mǝ nǝ tsǝkia wia bù.>>
\c 7
\s1 Apagir ace tàr Taragula
\p 
\v 1 Lang Musa malǝna loasǝ Taragula ka,\f + \fr 7:1 \ft Ɓalli aɓa: \xt Pur 40:17,18\xt*\ft .\f* pǝlǝa ɗārǝi sǝ tàrì andǝ agirtúró male kat. Ɗǝm ngga ɗārǝ gyangŋan sǝ tàrì andǝ agirtúró male kat.
\v 2 Sǝ à yinǝ aɓwana-mǝgule mala Isǝrayila, amúrû amur aɓala-kàu malea, mǝnana à nda ka amǝdǝmba mala atau ka. Yia na mǝnana à tsǝia amur aɓwana mǝnana à ɓallia ka; à yiu sǝ à cam tù,
\v 3 sǝ à yinǝ apagir malea aɓadǝm Yahweh: akeke-ndá tongno-nong-mwashat andǝ ajamnda lum-nong-ɓari; keke-ndá mwashat ace ɓari atà amúrû mala atau, sǝ jamnda mwashat ace koyan ateà. À yinǝia a ɓadǝm Taragula.
\p 
\v 4 Pǝlǝa Yahweh ne Musa ama,
\v 5 <<Ak agir mǝnia ka a buia, sǝ wu pe amǝ'Lawi ace túró twal agir mǝfele mala Tara Ban-peri, koyan ateà ka kǝla mana túró male nǝ̀ pàk ka.>>
\p 
\v 6 Nda Musa ak akeke-ndá andǝ ajamnda mǝno sǝ pè amǝ'Lawi ka.
\v 7 Pè amǝ'Gashon akeke-ndá ɓari andǝ ajamnda ine, kǝla mana kún túró malea pàk ka.
\v 8 Pè amǝ'Merari akeke-ndá ine andǝ ajamnda tongno-nong-tàrú, kǝla mana kún túró malea pà aɓata gingnǝban mala Itamar muna-ɓwabura mala Haruna pǝris ka.
\v 9 Sǝ amǝ'Kohat ka Musa pea wia kǝgìr ɗàng acemǝnana túró malea ka nda tsǝkir agir ɓá ban-mǝfele, mǝnana a kwàrú sǝ à nǝ̀ twalia ka.
\mi1 
\v 10 A pwari mǝnana à nǝ̀ ɗārǝ gyangŋan ngga, amúrû mala atau pāki apagir ace tàre; à yinǝ apagir malea a ɓadǝm gyangŋanì.
\v 11 Yahweh banggi Musa ama, <<Aɓa pwari mwashat ka ɓwamǝgule mwashat na nǝ̀ yinǝ pàgir male ace tàr gyangŋan ngga.>>
\m 
\v 12 Ɓwamǝgule mǝnana yinǝ pàgir male a pwari mǝdǝmbe ka nda Nashon muna-ɓwabura mala Aminadap, a tàu mala Yahuda.
\mi1 
\v 13 Sǝ pàgir male ka paranti na mǝnana à pè nǝ bolo-azǝrfa sǝ dǝmbǝrya male ka shekel gbǝman-mwashat nǝ lumi-tàrú na (130), andǝ tasau mǝnana à pè nǝ bolo-azǝrfa sǝ dǝmbǝrya male ka shekel lumi-tongno-nong-ɓari na ka (70); à kpata shekel mǝnana à ear amurí a ban-mǝfele ka. Yià kǝm ngga à lùmsǝia nǝ muku mǝɓǝlke mǝnana à zurì nǝ mùrú olif ace pàgir mala mǝsǝsa ka.
\v 14 Ɗǝm ngga yinǝ muna-nkenye mǝnana à pè nǝ bolo-njengǝlan sǝ dǝmbǝrya male ka shekel lum na ka, sǝ à lùmsǝì nǝ muku-gìr loasǝ yele mǝ'rǝmɓoarne;
\v 15 andǝ lo-jamnda, andǝ gam, andǝ muna-gam mǝnana mbule mwashat ka, ace pàgir mala pisǝe kǝring;
\v 16 andǝ gbato ace pàgir mala gǝshi cauɓikea;
\v 17 sǝ ace gir'nkila mala apagir mala dotarǝu\f + \fr 7:17 \ft Ɓalli aɓa: \xt Pǝris 3:1\xt*\ft .\f* ka yinǝ andá ɓari, agam tongno, agbato tongno, andǝ amuna-gam tongno mǝnana mbulea mwashat-mwashat ka. Mǝnia ka nda pàgir mala Nashon muna-ɓwabura mala Aminadap.
\m 
\v 18 A ɓaria pwari ka Netanel muna-ɓwabura mala Zuar, múr-là mala Isaka, yinǝ pàgir male.
\mi1 
\v 19 Pàgir male mǝnana pà ka paranti na mǝnana à pè nǝ bolo-azǝrfa sǝ dǝmbǝrya male ka shekel gbǝman-mwashat nǝ lumi-tàrú na (130), andǝ tasau mǝnana à pè nǝ bolo-azǝrfa sǝ dǝmbǝrya male ka shekel lumi-tongno-nong-ɓari na ka (70); à kpata shekel mǝnana à ear amurí a ban-mǝfele ka. Yià kǝm ngga à lùmsǝia nǝ muku mǝɓǝlke mǝnana à zurì nǝ mùrú olif ace pàgir mala mǝsǝsa ka.
\v 20 Ɗǝm ngga yinǝ muna-nkenye mǝnana à pè nǝ bolo-njengǝlan sǝ dǝmbǝrya male ka shekel lum na, sǝ à lùmsǝì nǝ muku-gìr loasǝ yele mǝ'rǝmɓoarne ka;
\v 21 andǝ lo-jamnda, andǝ gam, andǝ muna-gam mǝnana mbule mwashat ka, ace pàgir mala pisǝe kǝring;
\v 22 andǝ gbato ace pàgir mala gǝshi cauɓikea;
\v 23 sǝ ace gir'nkila mala apagir mala dotarǝu ka yinǝ andá ɓari, agam tongno, agbato tongno, andǝ amuna-gam tongno mǝnana mbulea mwashat-mwashat ka. Mǝnia ka nda pàgir mala Netanel muna-ɓwabura mala Zuar.
\m 
\v 24 A tàruià pwari ka Eliyap muna-ɓwabura mala Helon, múr-là mala amǝkà Zebulu yinǝ pàgir male.
\mi1 
\v 25 Pàgir male ka paranti na mǝnana à pè nǝ bolo-azǝrfa sǝ dǝmbǝrya male ka shekel gbǝman-mwashat nǝ lumi-tàrú na (130), andǝ tasau mǝnana à pè nǝ bolo-azǝrfa sǝ dǝmbǝrya male ka shekel lumi-tongno-nong-ɓari na ka (70); à kpata shekel mǝnana à ear amurí a ban-mǝfele ka. Yià kǝm ngga à lùmsǝia nǝ muku mǝɓǝlke mǝnana à zurì nǝ mùrú olif ace pàgir mala mǝsǝsa ka.
\v 26 Ɗǝm ngga yinǝ muna-nkenye mǝnana à pè nǝ bolo-njengǝlan sǝ dǝmbǝrya male ka shekel lum na, sǝ à lùmsǝì nǝ muku-gìr loasǝ yele mǝ'rǝmɓoarne ka;
\v 27 andǝ lo-jamnda, andǝ gam, andǝ muna-gam mǝnana mbule mwashat-mwashat na ka ace pàgir mala pisǝe kǝring;
\v 28 andǝ gbato ace pàgir mala gǝshi cauɓikea;
\v 29 sǝ ace gir'nkila mala apagir mala dotarǝu ka yinǝ andá ɓari, agam tongno, agbato tongno, andǝ amuna-gam tongno mǝnana mbulea mwashat-mwashat ka. Mǝnia ka nda pàgir mala Eliyap muna-ɓwabura mala Helon.
\m 
\v 30 A inea pwari ka Elizur muna-ɓwabura mala Shedeur, múr-là mala amǝkà Ruben yinǝ pàgir male.
\mi1 
\v 31 Pàgir male ka paranti na mǝnana à pè nǝ bolo-azǝrfa sǝ dǝmbǝrya male ka shekel gbǝman-mwashat nǝ lumi-tàrú na (130), andǝ tasau mǝnana à pè nǝ bolo-azǝrfa sǝ dǝmbǝrya male ka shekel lumi-tongno-nong-ɓari na ka (70); à kpata shekel mǝnana à ear amurí a ban-mǝfele ka. Yià kǝm ngga à lùmsǝia nǝ muku mǝɓǝlke mǝnana à zurì nǝ mùrú olif ace pàgir mala mǝsǝsa ka.
\v 32 Ɗǝm ngga yinǝ muna-nkenye mǝnana à pè nǝ bolo-njengǝlan sǝ dǝmbǝrya male ka shekel lum na, sǝ à lùmsǝì nǝ̀ muku-gìr loasǝ yele mǝ'rǝmɓoarne ka;
\v 33 andǝ lo-jamnda, andǝ gam, andǝ muna-gam mǝnana mbule mwashat ka, ace pàgir mala pisǝe kǝring;
\v 34 andǝ gbato ace pàgir mala gǝshi cauɓikea;
\v 35 sǝ ace gir'nkila mala apagir mala dotarǝu ka yinǝ andá ɓari, agam tongno, agbato tongno, andǝ amuna-gam tongno mǝnana mbulea mwashat-mwashat ka. Mǝnia ka nda pàgir mala Elizur muna-ɓwabura mala Shedeur.
\m 
\v 36 A tongnoia pwari ka Shelumiyel muna-ɓwabura mala Zurishaddai, múr-là mala amǝkà Shimiyon yinǝ pàgir male.
\mi1 
\v 37 Pàgir male ka paranti na mǝnana à pè nǝ bolo-azǝrfa sǝ dǝmbǝrya male ka shekel gbǝman-mwashat nǝ lumi-tàrú na (130), andǝ tasau mǝnana à pè nǝ bolo-azǝrfa sǝ dǝmbǝrya male ka shekel lumi-tongno-nong-ɓari na ka (70); à kpata shekel mǝnana à ear amurí a ban-mǝfele ka. Yià kǝm ngga à lùmsǝia nǝ muku mǝɓǝlke mǝnana à zurì nǝ mùrú olif ace pàgir mala mǝsǝsa ka.
\v 38 Ɗǝm ngga yinǝ muna-nkenye mǝnana à pè nǝ bolo-njengǝlan sǝ dǝmbǝrya male ka shekel lum na, sǝ à lùmsǝì nǝ muku-gìr loasǝ yele mǝ'rǝmɓoarne ka;
\v 39 andǝ lo-jamnda a domwan, andǝ gam, andǝ muna-gam mǝnana mbule mwashat ka, ace pàgir mala pisǝe kǝring;
\v 40 andǝ gbato ace pàgir mala gǝshi cauɓikea;
\v 41 sǝ ace gir'nkila mala apagir mala dotarǝu ka yinǝ andá ɓari, agam tongno, agbato tongno, andǝ amuna-gam tongno mǝnana mbulea mwashat-mwashat ka. Mǝnia ka nda pàgir mala Shelumiyel muna-ɓwabura mala Zurishaddai.
\m 
\v 42 A tongno-nong-mwashatia pwari ka Eliyasaf muna-ɓwabura mala Dewel, múr-là mala amǝkà Gad yinǝ pàgir male.
\mi1 
\v 43 Pàgir male ka paranti na mǝnana à pè nǝ bolo-azǝrfa sǝ dǝmbǝrya male ka shekel gbǝman-mwashat nǝ lumi-tàrú na (130), andǝ tasau mǝnana à pè nǝ bolo-azǝrfa sǝ dǝmbǝrya male ka shekel lumi-tongno-nong-ɓari na ka (70); à kpata shekel mǝnana à ear amurí a ban-mǝfele ka. Yià kǝm ngga à lùmsǝia nǝ muku mǝɓǝlke mǝnana à zurì nǝ mùrú olif ace pàgir mala mǝsǝsa ka.
\v 44 Ɗǝm ngga yinǝ muna-nkenye mǝnana à pè nǝ bolo-njengǝlan sǝ dǝmbǝrya male ka shekel lum na, sǝ à lùmsǝì nǝ muku-gìr loasǝ yele mǝ'rǝmɓoarne ka;
\v 45 andǝ lo-jamnda, andǝ gam, andǝ muna-gam mǝnana mbule mwashat ka, ace pàgir mala pisǝe kǝring;
\v 46 andǝ gbato ace pàgir mala gǝshi cauɓikea;
\v 47 sǝ ace gir'nkila mala apagir mala dotarǝu ka yinǝ andá ɓari, agam tongno, agbato tongno, andǝ amuna-gam tongno mǝnana mbulea mwashat-mwashat ka. Mǝnia ka nda pàgir mala Eliyasaf muna-ɓwabura mala Dewel.
\m 
\v 48 A tongno-nong-ɓaria pwari ka Elishama muna-ɓwabura mala Ammihud, múr-là mala amǝkà Ifǝrem yinǝ pàgir male.
\mi1 
\v 49 Pàgir male ka paranti na mǝnana à pè nǝ bolo-azǝrfa sǝ dǝmbǝrya male ka shekel gbǝman-mwashat nǝ lumi-tàrú na (130), andǝ tasau mǝnana à pè nǝ bolo-azǝrfa sǝ dǝmbǝrya male ka shekel lumi-tongno-nong-ɓari na ka (70); à kpata shekel mǝnana à ear amurí a ban-mǝfele ka. Yià kǝm ngga à lùmsǝia nǝ muku mǝɓǝlke mǝnana à zurì nǝ mùrú olif ace pàgir mala mǝsǝsa ka.
\v 50 Ɗǝm ngga yinǝ muna-nkenye mǝnana à pè nǝ bolo-njengǝlan sǝ dǝmbǝrya male ka shekel lum na, sǝ à lùmsǝì nǝ muku-gìr loasǝ yele mǝ'rǝmɓoarne ka;
\v 51 andǝ lo-jamnda, andǝ gam, andǝ muna-gam mǝnana mbule mwashat ka, ace pàgir mala pisǝe kǝring;
\v 52 andǝ gbato ace pàgir mala gǝshi cauɓikea;
\v 53 sǝ ace gir'nkila mala apagir mala dotarǝu ka yinǝ andá ɓari, agam tongno, agbato tongno, andǝ amuna-gam tongno mǝnana mbulea mwashat-mwashat ka. Mǝnia ka nda pàgir mala Elishama muna-ɓwabura mala Ammihud.
\m 
\v 54 A tongno-nong-tàruià pwari ka Gamaliyel muna-ɓwabura mala Pedazur, múr-là mala amǝkà Manasa, yinǝ pàgir male.
\mi1 
\v 55 Pàgir male mǝnana pà ka paranti na mǝnana à pè nǝ bolo-azǝrfa sǝ dǝmbǝrya male ka shekel gbǝman-mwashat nǝ lumi-tàrú na (130), andǝ tasau mǝnana à pè nǝ bolo-azǝrfa sǝ dǝmbǝrya male ka shekel lumi-tongno-nong-ɓari na ka (70); à kpata shekel mǝnana à ear amurí a ban-mǝfele ka. Yià kǝm ngga à lùmsǝia nǝ muku mǝɓǝlke mǝnana à zurì nǝ mùrú olif ace pàgir mala mǝsǝsa ka.
\v 56 Ɗǝm ngga yinǝ muna-nkenye mǝnana à pè nǝ bolo-njengǝlan sǝ dǝmbǝrya male ka shekel lum na, sǝ à lùmsǝì nǝ muku-gìr loasǝ yele mǝ'rǝmɓoarne ka;
\v 57 andǝ lo-jamnda, andǝ gam, andǝ muna-gam mǝnana mbule mwashat ka, ace pàgir mala pisǝe kǝring;
\v 58 andǝ gbato ace pàgir mala gǝshi cauɓikea;
\v 59 sǝ ace gir'nkila mala apagir mala dotarǝu ka yinǝ andá ɓari, agam tongno, agbato tongno, andǝ amuna-gam tongno mǝnana mbulea mwashat-mwashat ka. Mǝno ka nda pàgir mala Gamaliyel muna-ɓwabura mala Pedazur.
\m 
\v 60 A tongno-nong-inea pwari ka Abidan muna-ɓwabura mala Gidiyoni, múr-là mala amǝkà Benjami yinǝ pàgir male.
\mi1 
\v 61 Pàgir male ka paranti na mǝnana à pè nǝ bolo-azǝrfa sǝ dǝmbǝrya male ka shekel gbǝman-mwashat nǝ lumi-tàrú na (130), andǝ tasau mǝnana à pè nǝ bolo-azǝrfa sǝ dǝmbǝrya male ka shekel lumi-tongno-nong-ɓari na ka (70); à kpata shekel mǝnana à ear amurí a ban-mǝfele ka. Yià kǝm ngga à lùmsǝia nǝ muku mǝɓǝlke mǝnana à zurì nǝ mùrú olif ace pàgir mala mǝsǝsa ka.
\v 62 Ɗǝm ngga yinǝ muna-nkenye mǝnana à pè nǝ bolo-njengǝlan sǝ dǝmbǝrya male ka shekel lum na, sǝ à lùmsǝì nǝ muku-gìr loasǝ yele mǝ'rǝmɓoarne ka;
\v 63 andǝ lo-jamnda, andǝ gam, andǝ muna-gam mǝnana mbule mwashat ka ace pàgir mala pisǝe kǝring;
\v 64 andǝ gbato ace pàgir mala gǝshi cauɓikea;
\v 65 sǝ ace gir'nkila mala apagir mala dotarǝu ka yinǝ andá ɓari, agam tongno, agbato tongno, andǝ amuna-gam tongno mǝnana mbulea mwashat-mwashat ka. Mǝnia ka nda pàgir mala Abidan muna-ɓwabura mala Gidiyoni.
\m 
\v 66 A lumia pwari ka Ahieza muna-ɓwabura mala Amishaddai, múr-là mala amǝkà Dan yinǝ pàgir male.
\mi1 
\v 67 Pàgir male ka paranti na mǝnana à pè nǝ bolo-azǝrfa sǝ dǝmbǝrya male ka shekel gbǝman-mwashat nǝ lumi-tàrú na (130), andǝ tasau mǝnana à pè nǝ bolo-azǝrfa sǝ dǝmbǝrya male ka shekel lumi-tongno-nong-ɓari na ka (70); à kpata shekel mǝnana à ear amurí a ban-mǝfele ka. Yià kǝm ngga à lùmsǝia nǝ muku mǝɓǝlke mǝnana à zurì nǝ mùrú olif ace pàgir mala mǝsǝsa ka.
\v 68 Ɗǝm ngga yinǝ muna-nkenye mǝnana à pè nǝ bolo-njengǝlan sǝ dǝmbǝrya male ka shekel lum na, sǝ à lùmsǝì nǝ muku-gìr loasǝ yele mǝ'rǝmɓoarne ka;
\v 69 andǝ lo-jamnda, andǝ gam, andǝ muna-gam mǝnana mbule mwashat ka, ace pàgir mala pisǝe kǝring;
\v 70 andǝ gbato ace pàgir mala gǝshi cauɓikea;
\v 71 sǝ ace gir'nkila mala apagir mala dotarǝu ka yinǝ andá ɓari, agam tongno, agbato tongno, andǝ amuna-gam tongno mǝnana mbulea mwashat-mwashat ka. Mǝnia ka nda pàgir mala Ahieza muna-ɓwabura mala Amishaddai.
\m 
\v 72 A lum-nong-mwashatia pwari ka Pagiyel muna-ɓwabura mala Okran, múr-là mala amǝkà Asha yinǝ pàgir male.
\mi1 
\v 73 Pàgir male ka paranti na mǝnana à pè nǝ bolo-azǝrfa sǝ dǝmbǝrya male ka shekel gbǝman-mwashat nǝ lumi-tàrú na (130), andǝ tasau mǝnana à pè nǝ bolo-azǝrfa sǝ dǝmbǝrya male ka shekel lumi-tongno-nong-ɓari na ka (70); à kpata shekel mǝnana à ear amurí a ban-mǝfele ka. Yià kǝm ngga à lùmsǝia nǝ muku mǝɓǝlke mǝnana à zurì nǝ mùrú olif ace pàgir mala mǝsǝsa ka.
\v 74 Ɗǝm ngga yinǝ muna-nkenye mǝnana à pè nǝ bolo-njengǝlan sǝ dǝmbǝrya male ka shekel lum na, sǝ à lùmsǝì nǝ muku-gìr loasǝ yele mǝ'rǝmɓoarne ka;
\v 75 andǝ lo-jamnda, andǝ gam, andǝ muna-gam mǝnana mbule mwashat ka, ace pàgir mala pisǝe kǝring;
\v 76 andǝ gbato ace pàgir mala gǝshi cauɓikea;
\v 77 sǝ ace gir'nkila mala apagir mala dotarǝu ka yinǝ andá ɓari, agam tongno, agbato tongno, andǝ amuna-gam tongno mǝnana mbulea mwashat-mwashat ka. Mǝnia ka nda pàgir mala Pagiyel muna-ɓwabura mala Okran.
\m 
\v 78 A lum-nong-ɓaria pwari ka Ahira muna-ɓwabura mala Enan, múr-là mala amǝkà Naftali yinǝ pàgir male.
\mi1 
\v 79 Pàgir male ka paranti na mǝnana à pè nǝ bolo-azǝrfa sǝ dǝmbǝrya male ka shekel gbǝman-mwashat nǝ lumi-tàrú na (130), andǝ tasau mǝnana à pè nǝ bolo-azǝrfa sǝ dǝmbǝrya male ka shekel lumi-tongno-nong-ɓari na ka (70); à kpata shekel mǝnana à ear amurí a ban-mǝfele ka. Yià kǝm ngga à lùmsǝia nǝ muku mǝɓǝlke mǝnana à zurì nǝ mùrú olif ace pàgir mala mǝsǝsa ka.
\v 80 Ɗǝm ngga yinǝ muna-nkenye mǝnana à pè nǝ bolo-njengǝlan sǝ dǝmbǝrya male ka shekel lum na, sǝ à lùmsǝì nǝ muku-gìr loasǝ yele mǝ'rǝmɓoarne ka;
\v 81 andǝ lo-jamnda, andǝ gam, andǝ muna-gam mǝnana mbule mwashat ka, ace pàgir mala pisǝe kǝring;
\v 82 andǝ gbato ace pàgir mala gǝshi cauɓikea;
\v 83 sǝ ace gir'nkila mala apagir mala dotarǝu ka yinǝ andá ɓari, agam tongno, agbato tongno, andǝ amuna-gam tongno mǝnana mbulea mwashat-mwashat ka. Mǝnia ka nda pàgir mala Ahira muna-ɓwabura mala Enan.
\p 
\v 84 Amǝnia ka à nda ka apagir mala amúrû mala atau mala Isǝrayila ace tàr gyangŋan lang à ɗārǝi ka: aparanti bolo-azǝrfa lum-nong-ɓari, atasau bolo-azǝrfa lum-nong-ɓari, amuna-nkenye bolo-njengǝlan lum-nong-ɓari,
\v 85 koya paranti bolo-azǝrfa ka dǝmbǝrya male ka shekel gbǝman-mwashat nǝ lumi-tàrú na (130), sǝ koya tasau bolo-azǝrfa ka dǝmbǝrya male na shekel lumi-tongno-nong-ɓari (70). Dǝmbǝrya kat-kat mala atanggǝla bolo-azǝrfa ka shekel á-ɓari nǝ gbǝman-ine na (2,400); à kpata shekel mǝnana à ear amurí a Tara-mǝfele ka.
\v 86 Komǝye atà amuna-nkenye bolo-njengǝlan lum-nong-ɓari mǝnana à lùmsǝia nǝ muku-gìr loasǝ yele mǝ'rǝmɓoarne ka, dǝmbǝrya male na shekel lum; à kpata shekel mǝnana à ear amurí a ban-mǝfele ka. Yià amuna-nkenye bolo-njengǝlan kat ka dǝmbǝrya malea na shekel gbǝman-mwashat nǝ lumi-ɓari (120).
\v 87 Agirkusǝu mǝnana kat à yinǝia ace pàgir mala pisǝe kǝring ngga à nda ka: ajamnda lum-nong-ɓari, agam lum-nong-ɓari, amuna-gam mǝnana mbulea mwashat-mwashat ka lum-nong-ɓari, atārǝia andǝ pàgir mala mǝsǝsa malea; andǝ agbato lum-nong-ɓari ace pàgir mala gǝshi cauɓikea.
\v 88 Làkkì mala agirkusǝu kat-kat ace pà gir'nkila mala pàgir mala dotarǝu ka à nda ka: ajamnda lumi-ɓari-nong-ine, agam lumi-tongno-nong-mwashat, agbato lumi-tongno-nong-mwashat, amuna-gam lumi-tongno-nong-mwashat mǝnana mbulea mwashat-mwashat ka. Amǝnia ka à nda ka apagir ace tàr gyangŋan anzǝm ɗārǝè.
\p 
\v 89 A koya pwari sǝ Musa kúti aɓa Tara Ban-peri nǝ̀ nacau nǝ Yahweh ka, kǝ ok gì Yahweh aban ne wi cau a nre ka acerup ɓari mǝnana à mǝn abuia a kùli amur buno sǝntǝ̀r, mǝnana nda amur Akwati mala Acau-nakûn ngga; anggo sǝ Yahweh kǝ ne wi cau.
\c 8
\s1 Tsǝki apitǝla
\p 
\v 1 Yahweh ne Musa cau, ama,
\v 2 <<Nacau nǝ Haruna sǝ wu banggi wi ama, <Lang awu nǝ tamsǝki apitǝla ka, tsǝia a njar mǝnana à nǝ̀ nggǝ pa tǎlaban a ɓadǝm gìr-tamsǝia ka.> >>
\p 
\v 3 Anggo sǝ Haruna pǎ; tsǝki apitǝla à pǝlǝ nǝ ɓadǝm gìr-tamsǝia, kǝla mǝnana Yahweh banggi Musa ka.
\v 4 Ani sǝ à pàk gìr-tàmsǝ apitǝla: à pè nǝ bolo-njengǝlan mǝnana à walki ka, twal a kusǝì aban ká arǝ nyoulǝa rǝi mala tǒ mala afufe. Anggo sǝ pè kǝla mǝnana Yahweh lǝmdǝì Musa ka.
\s1 Lak amǝ'Lawi andǝ tària
\p 
\v 5 Yahweh banggi Musa ama:
\v 6 <<Pusǝ amǝ'Lawi aɓalǝa amǝ Isǝrayila sǝ wu leǎ.
\v 7 Ace leǎ ka pàk mǝnia: Watsǝkia wia mùr lakban amúrià; sǝ wu tsǝia ɓǝà mwa nyang mǝnana a rǝia ka kat, sǝ ɓǝà lakki agir'nggūrǝia. Anggo sǝ à nǝ̀ lak ɓamuria.
\v 8 Anzǝm mǝno ka ɓǝà yinǝ jamnda, atārǝia andǝ pàgir mala mǝsǝsa male, mǝnana muku mǝɓǝlke na à zurì nǝ mùrú olif ka; sǝ awu nǝ twal ɓè jamnda a domwan ace pàgir mala gǝshi cauɓikea.\f + \fr 8:8 \fq pàgir mala gǝshi cauɓikea \ft ko \fqa pàgir mala lakban;\ft anggo gbal a mǝsǝì 12\f*
\v 9 Pǝlǝa awu nǝ yinǝ amǝ'Lawi aɓadǝm Tara Ban-peri, sǝ wu ram ɓinala amǝ Isǝrayila kat.
\v 10 Lang a yinanǝ amǝ'Lawi aɓadǝm Yahweh ka, pǝlǝa aɓwana-mǝgule mala amǝ Isǝrayila nǝ̀ nongsǝ abuia amur amǝ'Lawi.
\v 11 Pǝlǝa Haruna nǝ̀ yinǝ amǝ'Lawi aɓadǝm Yahweh, ɓǝà do kǝla pàgir mana à loasǝi a kuli mǝnana amǝ Isǝrayila pa, ace mǝnana ɓǝà do nǝ gilǝrǝu ace pak túró mala Yahweh ka.
\p 
\v 12 <<Pǝlǝa amǝ'Lawi ka ɓǝà nongsǝ abuia a ɓamur ajamnda, mǝnana mwashat ka nda ace pàgir aban Yahweh mala gǝshi cauɓikea, sǝ ɓè ka nda ace pàgir mala pisǝe kǝring, ace shawuɗi amǝ'Lawi.
\v 13 Awu nǝ tsǝk amǝ'Lawi ɓǝà came aɓadǝm Haruna andǝ amuna-burana male, sǝ awu nǝ tària ɓǝà duk pàgir mǝnana à loasǝi a kuli aban Yahweh ka.
\v 14 Anggo sǝ awu nǝ pusǝ amǝ'Lawi aɓalǝa amǝ Isǝrayila, sǝ amǝ'Lawi ka à nǝ̀ duk amem.
\p 
\v 15 <<Anzǝm mǝnana a langŋǝna amǝ'Lawi sǝ a tarnia kǝla pàgir mana à nǝ̀ loasǝi a kuli ka, à nǝ̀ ká ace pàktúró a Tara Ban-peri.
\v 16 À nda ka amǝ Isǝrayila mǝnana à panamia kǝring ngga. Ən twalnia ɓǝà duk amem a kúnì aɓwana mǝnana kat à tita puro a bum ngga, yì amuna-dǝmba aburana mala amǝ Isǝrayila kat.
\v 17 Koya muna-dǝmba muna-ɓwabura a Isǝrayila, ɓwapǝndǝa ko girkusǝu ka, mem na. Lang ǝn wal amuna-dǝmba kat a Masar ka, ǝn taria ace ɓamúràm.
\v 18 Sǝ ǝn twalna amǝ'Lawi a kúnì amuna-dǝmba amuna-burana kat a Isǝrayila.
\v 19 Aɓalǝa amǝ Isǝrayila kat ka, ǝn pana amǝ'Lawi kǝla ɓoro aban Haruna andǝ amuna-burana male ace pàktúró a Tara ban-peri a kúnì amǝ Isǝrayila, sǝ ɓǝà shawuɗia, ace mǝnana ɓǝ̀ ɓekǝ gìr'mur'mwana ɓǝkǝa wal amǝ Isǝrayila ɗàng lang à nǝ̀ gbàshìban ban-mǝfele ka.>>
\p 
\v 20 Musa, andǝ Haruna andǝ ɓinala amǝ Isǝrayila kat pàngnǝ amǝ'Lawi kǝla mana Yahweh banggi Musa ka.
\v 21 Amǝ'Lawi lak ɓamuria sǝ à lakki agir'nggūrǝia. Pǝlǝa Haruna tària kǝla pàgir mǝnana à loasǝi a kuli aɓadǝm Yahweh ka, sǝ shawuɗia ace leǎ.
\v 22 Anzǝm mǝno ka amǝ'Lawi wari ace pàktúró malea aɓa Tara Ban-peri aɓata gingnǝban mala Haruna andǝ amuna-burana male. À pàngnǝ amǝ'Lawi kǝla cau mana Yahweh banggi Musa ka.
\p 
\v 23 Yahweh banggi Musa ama,
\v 24 <<Cau mǝnia ka nda arǝ amǝ'Lawi: Ɓwabura mǝnana pǝlǝa male na lumi-ɓari-bwamdǝ-tongno andǝ mana kútì ka nǝ̀ yiu ace pàk túró aɓa Tara Ban-peri.
\v 25 Sǝ lang ɓwabura bingŋǝnà pǝlǝa lumi-tongno ka, nǝ̀ nyingbuì arǝ túró mǝnana pàkiyi pwari-pwari ka, sǝ pà nǝ̀ pàk túró ɗǝm ɗàng.
\v 26 Yì ka nǝ̀ gandǝ bwali amǝ'eambi arǝ pakki atúró malea aɓa Tara Ban-peri, sǝama pà nǝ̀ pàk túrè nǝ nggearǝì ɗàng. Anggo sǝ awu nǝ pàkkî amǝ'Lawi aɓa kasǝia wia atúró mǝnana nda acea ka.>>
\c 9
\s1 Lamsan Yàlîmurû
\p 
\v 1 Yahweh nacau nǝ Musa a pǝɗanban Saina, a zongŋo mǝdǝmbe mala ɓaria pǝlǝa anzǝm mana amǝ Isǝrayila purnì nzali Masar ka, ama,
\v 2 <<Amǝ Isǝrayila ɓǝà kǝ pak lamsan mala Yàlîmurû a kǝ pwari mǝnana à tsǝì ace ka.
\v 3 Wu pàk lamsan male a kǝ pwari mǝnana à tsǝk ka, nǝ pwarikpǝra a lum-nong-inea pwari mala mǝnia yì zongŋo ka; dumǝna púp wun nǝ̀ pàk lamsan male nǝ kpata angguracau male kat, andǝ anê male kat.>>
\p 
\v 4 Nda Musa banggi amǝ Isǝrayila ɓǝà pak lamsan mala Yàlîmurû ka.
\v 5 Sǝ yià ka à pak lamsan Yàlîmurû a lum-nong-inea pwari mala zongŋo mǝdǝmbe, nǝ pwarikpǝra a pǝɗanban mala Saina. Amǝ Isǝrayila pàk koman kat kǝla mǝnana Yahweh banggi Musa ka.
\p 
\v 6 Sǝ càu kumban ama aɓea aburana pǝlǝ gìr'ɓeami atàcau mala je lú ɓeɓwa, sǝ gìrnî tsǝa à gandǝ pak lamsan mala Yàlîmurû amǝno yì pwari ka ɗàng. Aburana mǝnia yiu aɓadǝm Musa andǝ Haruna amǝno yì pwari.
\v 7 À ne Musa ama, <<Mǝsǝcau sǝm pǝlǝna gìr'ɓeami atàcau mala je lú ɓeɓwa. Sǝama palang sǝ mǝno ka tsǝa à tàmsǝ sǝm arǝ yinǝ pagìr mala Yahweh atà amǝ Isǝrayila a pwari mǝnana à tsǝì ace ka?>>
\p 
\v 8 Musa earia wia ama, <<Wu kúndǝô, mǝ ok cau mǝnana Yahweh nǝ̀ bang ace wun ngga.>>
\p 
\v 9 Pǝlǝa Yahweh bangcau nǝ Musa ama,
\v 10 <<Banggi amǝ Isǝrayila ama: Ɓǝ̀ kǝɓwa aɓalǝ wun, ko atà amǝ'kà wun pǝlǝ gìr'ɓeami atàcau mala je lú, ko twal bǝri mǝsauwe ka, ɓwê nǝ̀ gandǝ pak lamsan mala Yàlîmurû abanam Yahweh.
\v 11 Sǝama à nǝ̀ pè a lum-nong-inea pwari mala ɓaria zongŋo nǝ pwarikpǝra. À nǝ̀ shak nyam muna-gam mala Yàlîmurû nǝ bǝredi mana yis pà arǝì raka nǝ mbúgir mǝ'lùlle\f + \fr 9:11 \ft Ɓalli gbal aɓa: \xt Pur 12:8,15; Nggur 16:3-4,8\xt*\ft .\f* atè.
\v 12 Dumǝna púp à pà nǝ̀ nying kǝ cili ɓǝ̀ ueo ba dǝmbari ɗàng, sǝ à pà nǝ̀ ɓun kǝ mui ɗàng;\f + \fr 9:12 \ft Sǝni gbal aɓa: \xt Pur 12:10,46; Ang 34:20; Yoh 19:36\xt*\ft .\f* sǝ dumǝna púp à nǝ̀ pàk lamsanì nǝ kpata angguracau mala Yàlîmurû kat.
\v 13 Sǝama ɓǝ̀ ɓwa ka mǝɓoarnsari na, sǝ twal bǝri ɗang, sǝ gatti pàk lamsan mala Yàlîmurû ka, mǝno yì ɓwa ka à nǝ̀ pusǝ lullǝì aɓalǝ aɓwana male, acemǝnana yinǝ pagìr acem Yahweh a pwari mana à tsǝk ka ɗàng; mǝno yì ɓwa ka bafe mala cauɓikea male nǝ̀ ueo amurí.
\p 
\v 14 <<Ɓǝ̀ ɓwa-kúnɗàngna do aɓalǝ wun, sǝ earce nǝ̀ pàk lamsan mala Yàlîmurû abanam Yahweh ka, dumǝna púp nǝ̀ kpata angguracau andǝ anê mala Yàlîmurû. Kǝ nggurcau mǝmwashati na ace ɓwa-kúnɗàngna andǝ ɓwa Isǝrayila.>>
\s1 Pǝrɓang amur Taragula
\p 
\v 15 A pwari mǝnana à loasǝ Taragula ka, pǝrɓangnî yi gìr múr Taragula, yì Tara mala Acau-nakûn,\f + \fr 9:15 \ft Ɓalli gbal aɓa: \xt Pur 40:17,34; Ɓal 7:1\xt*\ft .\f* sǝ à sǝni kǝla bǝsa amur Taragula, twal a pwarikpǝra aban ká dǝmbari.
\v 16 Anggo sǝ pǎ koya pwari: pǝrɓangnî gìr múr Taragula, sǝ nǝ du ka, à sǝni kǝla bǝsa.
\v 17 Sǝ ɓǝ̀ aya pwari sǝ pǝrɓangnî loapì múr tara ka, zuku ka amǝ Isǝrayila nǝ̀ lo gya, sǝ ban mǝnana kat pǝrɓangnî kya cam kam ngga, a banì sǝ amǝ Isǝrayila nǝ̀ duk kàttì.\f + \fr 9:17 \ft Ɓalli gbal aɓa: \xt Pur 40:36-38; Ɓal 10:11,33-34\xt*\ft .\f*
\v 18 Amǝ Isǝrayila kǝ lo gya kǝla mana Yahweh na ka, sǝ à kǝ duk kàttì kǝla mana na ka. Ɓǝ̀ lang sǝ pǝrɓangnî ka banì sauwa aban ueo amur Taragula ka, anggo sǝ à nǝ̀ ueo a kàttì.
\v 19 Ko ɓǝ̀ pǝrɓangnî lidǝmba nǝ came amur Taragula arǝ anongŋo pas ka, amǝ Isǝrayila nǝ̀ okî Yahweh, à pà nǝ̀ lo gya ɗang.
\v 20 Aɓea bákú ka, pǝrɓangnî nǝ̀ twal anongŋo bǝti aban ueo amur Taragula. Sǝ kǝla mana Yahweh bang ngga, à nǝ̀ ueo aɓa kàttì, sǝ kǝla mana Yahweh bang ngga, à nǝ̀ lo gya.
\v 21 Sǝ arǝ aɓea apwari ka, pǝrɓangnî ueo, twal a pwarikpǝra aban ká dǝmbari, sǝ lang pǝrɓangnî lo nǝ bari ka, à lo gya. Ko nda nǝ pwari ko nǝ dú, pwari mǝnana kat pǝrɓangnî lo ka, à lo gya.
\v 22 Ko ɓǝ̀ pǝrɓangnî twal nongŋo ɓari, ko zongŋo, ko banì sauwa nda piu amur Taragula ka, amǝ Isǝrayila ueo aɓa kàttì, à lo gya ɗang; sǝ lang longŋǝna ka, à lo gya.
\v 23 Aɓa nê mala Yahweh ka, à tsǝk kàttì, sǝ aɓa nê mala Yahweh ka, à lo gya. À kpata kwarkiru mala Yahweh; sǝ cau mǝnana kat Yahweh banggi Musa ama ɓǝà pàk ka, à pè.
\c 10
\s1 Anjawe bolo-azǝrfa
\p 
\v 1 Yahweh bangcau nǝ Musa ama,
\v 2 <<Wu tùl anjawe bolo-azǝrfa ɓari. Wun nǝ̀ pàngŋǝ̀nà-túró nǝia ace tunǝ ramba mala ɓwabundǝa, sǝ ace loapi kàttì.
\v 3 Lang à twang anjawe mǝnia kǝm ngga, ɓwabundǝa puppup nǝ̀ ramba a bano a bankutio mala Tara Ban-peri.
\v 4 Sǝ ɓǝ̀ njawe mǝdǝmbe na à twang ngga, amúrû, yì amǝdǝmba mala atau mala amǝ Isǝrayila na mǝnana à nǝ̀ ram rǝia a bano ka.
\v 5 Sǝ lang wu ɓua njawe-lwa ka, akàttì mǝnana à tsǝk agumli malea a takuli ka, à nǝ̀ lo gya.
\v 6 Sǝ lang wu ɓua ɓaria njawe-lwa ka, akàttì mǝnana à tsǝk agumli malea a njar-kunmur ka, à nǝ̀ lo gya. Ɓǝ̀ aya pwari sǝ à nǝ̀ lo gya ka, à nǝ̀ ɓua njawe-lwa.
\v 7 Sǝ lang wun nǝ̀ ram ɓwabundǝa a banɓwáná ka, wun nǝ̀ twang njawe tè ɓǝ̀ sauwa, sǝama pà wun nǝ̀ ɓua njawe-lwa ɗang.
\v 8 Sǝ amuna-burana mala Haruna, yià apǝris ka, à nda à nǝ̀ nggǝ twang anjawe ka. Twang-njawe ka nǝ̀ dupa wun nggurcau mǝnana wun nǝ̀ nggǝ pê arǝ anza ma'wun kat ka.
\v 9 Lang wun nǝ̀ o a lwa aɓa nzali ma'wun arǝ aɓiwun amǝbura mǝnana à kǝ yinǝ munǝo arǝ wun ngga, wu ɓua njawe-lwa, ace mǝnana Yahweh Ɓakuli ma'wun ɓǝ̀ ɗenyinǝ wun, sǝ ɓǝ̀ amsǝ wun a ɓabù aɓiwun amǝbura.
\v 10 A pwari bumpwasǝa ma'wun gbal, sǝ a kúnì mala alamsan, andǝ apakkiɗire mala bǝsa azongŋo ma'wun ngga, wun nǝ̀ twang anjawe amur apagir ma'wun mǝnana à nǝ̀ pisǝia kǝring ngga, sǝ amur agir'nkila mala apagir ma'wun ace dotarǝu. À nǝ̀ duk gìr kasǝɓalǝ Ɓakuli arǝ wun; Mǝ nda Yahweh Ɓakuli ma'wun.>>
\s1 Amǝ Isǝrayila nying Nkono Saina
\p 
\v 11 A lumi-ɓaria nongŋo mala ɓaria zongŋo mala ɓaria pǝlǝa ka, pǝrɓangnî loapì múr Taragula mala Acau-nakûn,
\v 12 sǝ amǝ Isǝrayila lo gya, à nying pǝɗanban Saina, à kǝ turki bǝti-bǝti arǝ abân. Sǝ pǝrɓangnî yi came a pǝɗanban Paran.
\v 13 Mǝnia ka nda tadǝmbe mǝnana Yahweh banggi Musa cau ama ɓǝ̀ tsǝk amǝ Isǝrayila ɓǝà lo gya ka.
\p 
\v 14 Anggǝsan mala amǝ'lwa aɓata tútà mala kàttì mala Yahuda ka, à nda à tita lo gya ka, sǝ ɓwamǝgule amur anggǝsan mala amǝ'lwa malea ka, nda Nashon, muna-ɓwabura mala Aminadap.
\p 
\v 15 Netanel, muna-ɓwabura mala Zuar ka, nda ɓwamǝgule amur nggǝsan mala tàu mala amǝkà Isaka.
\v 16 Sǝ ɓwa mǝnana nda ɓwamǝgule amur nggǝsan mala tàu mala amǝkà Zebulu ka, nda Eliyap muna-ɓwabura mala Helon.
\p 
\v 17 Sǝ lang à panzǝkina Taragula à sulǝni ka, amǝkà Gashon, andǝ amǝkà Merari, mǝnana à twal agir mala Taragula ka, à lo gya.
\p 
\v 18 Aɓwana mǝnana à kpatea ka à nda ka anggǝsan mala amǝ'lwa mala kàttì mala Ruben, aɓata tútà malea, sǝ ɓwamǝgule amur anggǝsan malea ka, nda Elizur muna-ɓwabura mala Shedeur.
\v 19 Sǝ Shelumiyel muna-ɓwabura mala Zurishaddai ka, nda ɓwamǝgule amur nggǝsan mala tàu mala amǝkà Shimiyon.
\v 20 Sǝ ɓwamǝgule amur nggǝsan mala tàu mala amǝkà Gad ka, nda Eliyasaf muna-ɓwabura mala Duwel.
\v 21 Pǝlǝa amǝ'Kohat lo gya, nǝ agir mǝfele a buia; sǝ kaniama à nǝ̀ bwal ka, à (amǝkà Gashon andǝ amǝkà Merari) loasǝna Taragula.
\v 22 Sǝ anggǝsan mala amǝ'lwa a kàttì mala amǝkà Ifǝrem, aɓata tútà malea kpatea, sǝ ɓwamǝgule amur anggǝsan malea ka, nda Elishama muna-ɓwabura mala Ammihud.
\v 23 Gamaliyel muna-ɓwabura mala Pedazur ka, nda ɓwamǝgule amur nggǝsan mala tàu mala amǝkà Manasa,
\v 24 sǝ Abidan muna-ɓwabura mala Gidiyoni nda ɓwamǝgule amur nggǝsan mala tàu mala amǝkà Benjami.
\p 
\v 25 Sǝ tútà mala kàttì mala amǝkà Dan mǝnana do kǝla mǝ'yal-nzǝm akàttì kat ka, à lo gya arǝ anggǝsan mala amǝ'lwa malea, sǝ ɓwamǝgule amur nggǝsan mala amǝ'lwa malea ka, nda Ahieza muna-ɓwabura mala Amishaddai.
\v 26 Sǝ ɓwamǝgule amur nggǝsan mala amǝ'lwa mala tàu mala amǝkà Asha ka, nda Pagiyel muna-ɓwabura mala Okran.
\v 27 Sǝ Ahira muna-ɓwabura mala Enan ngga, nda ɓwamǝgule amur nggǝsan mala amǝ'lwa mala tàu mala amǝkà Naftali.
\v 28 Mǝnia ka nda, tsaɗi mala lo gya mala amǝ Isǝrayila arǝ anggǝsan mala amǝ'lwa malea lang à tùr kàttì ka.
\p 
\v 29 Sǝ Musa ne Hobap muna-ɓwabura mala Rewel ɓwa Midiyan, nkil Musa ama, <<Sǝm nda aban lo o a ban mǝnana Yahweh bang ama, <Mǝ nǝ pa wuni ka.> Yiu atà sǝm, sǝ sǝm nǝ̀ pàkkô mǝɓoarne, acemǝnana Yahweh panacau mala agir mǝɓoarne ace Isǝrayila.>>
\p 
\v 30 Sǝ yì ka bang ama, <<Pa mǝ nǝ ká ɗàng. Mǝ nǝ nyar a nzali mem, aban aɓwana mem.>>
\p 
\v 31 Sǝ Musa ne wi ama, <<Ida, cè a nying sǝm ɗàng, acemǝnana we ka, a súrǝ́nà rǝ ban mǝnana ɓoaro sǝm nǝ̀ duk kàttì kam aɓa pǝɗanban ngga, sǝ awu nǝ do kǝla mǝsǝu aban sǝm.
\v 32 Sǝ ɓǝ̀ a o atà sǝm ngga, gìr mǝɓoarne mǝnana Yahweh nǝ̀ pàkka sǝm ngga, nda sǝm nǝ̀ pàkkô ka.>>
\p 
\v 33 Nda à loapi nkono mala Yahweh, à twal gya mala nongŋo tàrú. Akwati Kùrcau mala Yahweh akia wia dǝmba aban ká aɓalǝ anongŋo tàrú mǝno ace kúmbia wia ban usǝlǝo.
\v 34 Sǝ pǝrɓang mala Yahweh ueo amúrià nǝ pwari, a koya pwari mǝnana à loapì kàttì ka.
\p 
\v 35 Sǝ koya pwari mǝnana à tita gya nǝ Akwati ka, Musa nǝ̀ na ama:
\q1 <<Lo, Yahweh, sǝ ɓǝ̀ aɓio-amǝbura ɓǝà tǝlli,
\q1 sǝ aɓwana mǝnana à ɓinǝmǝsǝo ka,
\q2 ɓǝà ɓangŋa a ɓadǝmbo.>>
\p 
\v 36 Sǝ lang à kya camǝna ka, nǝ̀ na ama:
\q1 <<Nyare, Yahweh, aban á-mǝlàkke mala amǝ Isǝrayila mǝnana à pà nǝ̀ gandǝ ɓallia raka.>>
\c 11
\s1 Amǝ Isǝrayila nggwani
\p 
\v 1 Lang Yahweh ok nggwani mǝnana aɓwe kǝ pè ace tanni malea ka, bumlulla male pì kǝ̀rkǝ́r arǝia,\f + \fr 11:1 \ft Ɓalli aɓa: \xt Pur 22:24; 32:10-11; Nggur 6:15\xt*\ft .\f* bǝsa mala Yahweh lo earke aɓalǝia, sǝ pisǝ aɓea ankanggariban mala kàttì.
\v 2 Pǝlǝa ɓwabundǝa ɓua aban Musa, sǝ Musa ɓua aban Yahweh, sǝ bǝsa limge.
\v 3 Nda sǝ à pè banì lullǝu ama, Tabera ka, acemǝnana bǝsa mala Yahweh earke aɓalǝia.
\v 4 Sǝ amǝ'kúnɗàngna\f + \fr 11:4 \ft Ɓalli aɓa: \xt Pur 12:38\xt*\ft .\f* mǝnana aɓalǝ amǝ Isǝrayila ka, à lo pàk suno\f + \fr 11:4 \ft Ɓalli gbal aɓa: \xt Ang 78:29-31; 106:14-15; 1Kor 10:5-6\xt*\ft .\f* mala aɓea agirlina. Sǝ amǝ Isǝrayila ɓua ɗǝm à kǝ na ama, <<Yana nǝ̀ pà sǝm nyama mǝnana sǝm nǝ̀ lì ka!
\v 5 Ɓalǝ sǝm kasǝa arǝ nji mǝnana sǝm lì a Masar,\f + \fr 11:5 \ft Ɓalli gbal aɓa: \xt Pur 16:3\xt*\ft .\f* sǝm nggǝ mbwe kǝgir ace raka, andǝ ambwario, ajiri, aɓui, ahatǝm, andǝ hangale.
\v 6 Sǝ ado ka, rǝcandǝa malǝnì rǝ sǝm,\f + \fr 11:6 \fq rǝcandǝa malǝnì rǝ sǝm, \ft ko <<tàmyal sǝm imǝna>>\f* sǝ kǝgir pà kàm sǝm sǝn ɗàng shekǝ mǝnia yì manna ka.>>
\v 7 (Manna ka, nda kǝla mǝsǝ mbulara-ɓa-mbyau, sǝ pǎ male na kǝla myang nggun.
\v 8 Aɓwe kǝ pur pwane sǝ à kǝ goe a taligo ko à kǝ soe a nkinggiring sǝ à nǝ̀ lambi a nkwaring, à nǝ̀ pàngŋǝ̀nà kyak nǝi. Lang à oe ka nda kǝla kyak mǝnana à pè nǝ mùrú ka.
\v 9 Lang ncimna kpa a kàttì nǝ du ka, manna kǝ sulǝ andǝi.)
\v 10 Musa ok aɓwana aban ɓua a koya ban arǝ atau malea, koya ɓwa ka a kún gumli male. Bumlulla mala Yahweh earki nggǝr-nggǝr, sǝ Musa ka banɓiki wi.
\v 11 Musa ne Yahweh ama, <<Ace mana sǝ a pakkì guro mò mǝɓane anggo? Sǝ man tsǝa sǝ a ginǝ lǝmdǝam murɓoarna, yimana a tsǝkam twalo mala aɓwana man kat amuram ngga?
\v 12 Mǝ nda ǝn twal aɓwana man kat a bumam ngga le? Mǝ nda ǝn ɓǝlia ka le, sǝ awu nǝ nam ama, <Twalia a kikilo, kǝla mǝnana mǝ'iulo kǝ twal bangna-muna ka,> aban ká a nzali mǝnana a kán ama, awu nǝ pè atárrià ka?
\v 13 Ake sǝ mǝ nǝ kum nyama mǝnana mǝ nǝ pè aɓwana mǝnia kat ka? Acemǝnana à kǝ ɓuakam ama, <Pà sǝm nyama, ɓǝ̀ sǝm lì.>
\v 14 Pà mǝ nǝ gandǝ twal aɓwana mǝnia kat ka nǝmurǝam ɗàng; twalê dǝmbǝriam kǝ̀rkǝ́r.
\v 15 Ɓǝ̀ nda anggo sǝ awu nǝ pàngnǝ mim ngga, ida, wal-luem ado, ɓǝ̀ mǝ ndanǝ murɓoarna a bano ka, ace mǝnana mǝ nggá sǝn tàpùra mem ɗàng.>>
\s1 À twal aɓwana-mǝgule ɓǝà pàkkî Musa gbasha
\p 
\v 16 Pǝlǝa Yahweh ne Musa ama, <<Rambam aɓwana-mǝgule mala Isǝrayila lumi-tongno-nong-ɓari, mǝnana a súrǝ̀ia à nda ka aɓwana-mǝgule amur aɓwana, sǝ à nda ka amǝbuno amúrià ka, sǝ wu yinǝa a bankutio aɓa Tara Ban-peri, ɓǝà cam kano atò.
\v 17 Sǝ mǝ nǝ sulǝo mǝ nǝ bangcau nǝ we kano. Sǝ mǝ nǝ twal aɓa Bangŋo mǝnana amuro ka, mǝ nǝ tsǝì amúrià; sǝ à nǝ̀ bwalo twal dǝmbǝrya mala aɓwana, ace mǝnana ɓǝkǝa do amuro nǝmurǝo ɗàng.
\p 
\v 18 <<Ne aɓwe ama, <Wu tàr ɓamur rǝ wun, ace lí, wun nǝ̀ shak nyama, acemǝnana ɓua ma'wun warina a kir Yahweh, ama, <<Yana nǝ̀ pà sǝm nyama mǝnana sǝm nǝ̀ shak ka? Acemǝnana do ma'sǝm a Masar ka ɓoaribanì.>> Acemani ka, Yahweh nǝ̀ pa wun nyama, sǝ wun nǝ̀ shè.
\v 19 Pà aɓa nongŋo mwashat, ko anongŋo ɓari, ko anongŋo tongno, ko anongŋo lum, ko anongŋo lumi-ɓari na wun nǝ̀ shè ka ɗàng,
\v 20 wun nǝ̀ shè aɓa zongŋo kat, sheɓǝ̀ ce'shirina wun, pǝlǝna wun gìr'ɓeakǝno ka, acemǝnana wu ginǝkina Yahweh mǝnana nda aɓalǝ wun ngga, sǝ wu ɓuanî wi ama, <<Mana tsǝa sǝ sǝm nying Masar?>> > >>\f + \fr 11:20 \ft Ɓalli aɓa: \xt Pur 17:3\xt*\ft .\f*
\p 
\v 21 Sǝ Musa na ama, <<Aɓwana mǝnana mǝ nda aɓalǝia ka, amǝ'lwa á-gbǝman-tongno-nong-mwashat na, nǝ kusǝia, sǝ a bang ama, <Mǝ nǝ pea wia nyama, mǝnana à nǝ̀ shè aɓa zongŋo kat ka!>
\v 22 Adomwan mala ambul andǝ mala andá na à nǝ̀ wallia wia sǝ nǝ̀ karǝia ka le, ko ana raka à nǝ̀ rambia wia nji mǝnana a nggeamùr kat ka, sǝ nǝ̀ karǝia le?>>
\v 23 Sǝ Yahweh ne Musa ama, <<Bù Yahweh gatti le? Ado ka awu nǝ sǝni ko cau mem nǝ̀ purmǝsǝi a bano ko pà nǝ̀ purmǝsǝi ɗàng.>>
\p 
\v 24 Pǝlǝa Musa puro kya ne aɓwe acau mǝnana Yahweh bang ngga. Sǝ yi ramba aburana lumi-tongno-nong-ɓari mala aɓwana-mǝgule mala aɓwe, sǝ yi tsǝia à came à kàrì Tara.
\v 25 Pǝlǝa Yahweh sulǝo aɓa pǝrɓang yi bangcau nǝi, sǝ twal aɓa Bangŋo mǝnana nda amurí ka, sǝ tsǝì amur aɓwana-mǝgule mǝno lumi-tongno-nong-ɓari ka. Sǝ lang Bangŋo sulǝo amúrià ka, à ɓangnǝ-ɓangnǝa. Sǝama à lidǝmba aban pé ɗàng.
\p 
\v 26 Aɓa mǝno anggo ka, aɓwana nakam ɓari à ueo aɓa kàttì, mwashat ka, à tunǝi ama, Eldat, sǝ ɓè ka, à tunǝ ama, Medat; Bangŋo sulǝo amúrià. À nda aɓalǝ aɓwana mǝnana à gilǝ alullǝia ka, sǝama à puro à wari a Tara ɗang; à ɓangnǝa aɓa kàttì.
\v 27 Sǝ ɓè lagga ɓangŋa kya ne Musa ama, <<Eldat andǝ Medat ka, à nda aban ɓangnǝ-ɓangnǝa aɓa kàttì.>>
\v 28 Sǝ Jesǝwa muna-ɓwabura mala Nun, mǝnana twal a lo-ɓwa male ka, nda kǝ pakkî Musa gbasha ka, na ama, <<Mǝtalem Musa, tamsǝia.>>
\v 29 Sǝ Musa banggi wi ama, <<A ndarǝ pak mɓali acem le? Eare mem ngga, ɓǝ́ aɓwana mala Yahweh kat ka à dumǝna amǝ'ɓangnǝa, ɓǝ́ Yahweh nǝ̀ tsǝk Bangŋo male amúrià!>>
\v 30 Pǝlǝa Musa andǝ aɓwana-mǝgule mala amǝ Isǝrayila nyare a kàttì.
\s1 Yahweh tasǝ ankwar
\p 
\v 31 Pǝlǝa gung mǝnana pur nǝban Yahweh ka, lo ɓua; loasǝ ankwar a ban nggeamùr, sǝ yinǝia, à yi sukkio a nzali a gírí kàttì; à gumbǝli a koya buì, o ɗār kǝla gya mala pwari mwashat. Gwali malea amur rǝarǝia a nzali ka dāh'rya bik kǝla ɓakusǝu tàrú.
\v 32 Sǝ aɓa pwari andǝ du mǝno kat aban ká ɓaria pwari kat ka, aɓwana lo sǝ à camarǝ pwan nkwar. Aɓwana mǝnana à pwan bǝti ka, à nda mana à pwan zace lum ngga; à anzǝia à gumbǝlina kàttì nǝi.
\p 
\v 33 Nyama na a kunia à nǝ̀ nggǝ shè, à malaká mal raka, bumlulla mala Yahweh lo earke arǝia, sǝ Yahweh kwak aɓwana a nzali, nǝ nggea gìr'mur'mwana mǝgule.
\v 34 Nda sǝ à tunǝ banì ama, Kibǝrot-hatava, acemǝnana a banì sǝ à tsǝk amǝ'suno a ɓembe.
\p 
\v 35 À loapi Kibǝrot-hatava aban ká Hazerot, sǝ à kya ueo a Hazerot.
\c 12
\s1 Miriyam andǝ Haruna nacau amur Musa
\m 
\v 1 Miriyam andǝ Haruna nacau amur Musa ace ɓwama Kush mǝnana Musa al ka, acemǝnana Musa ka, al ɓwama Kush.
\v 2 Sǝ à na ama, <<Nggeari ka Musa na nǝmurǝi Yahweh kǝ nacau nǝi ka le? Kǝ nacau nǝ sǝm gbal re?>> Cau mǝnana à ne ka Yahweh oè.
\v 3 (Musa ka nda ɓukɓuk, kútì aɓwana mǝnana a ɓanza kat ka nǝ ɓukɓuka.)
\p 
\v 4 Àkǝ banì Yahweh ne Musa andǝ Haruna andǝ Miriyam ama, <<Wu puro wun tàrú, wu kya bankutio aɓa Tara Ban-peri.>> Sǝ yia tàrú ka à puro.
\v 5 Pǝlǝa Yahweh sulǝo aɓa pǝrɓang mana pǝrapǝra ka, yi came a bankutio aɓa Tara sǝ tunǝ Haruna andǝ Miriyam yia kǝm, sǝ à puro.
\v 6 Sǝ bang ama, <<Wu ok cau mem:
\q1 <<Ɓǝ̀ ɓekǝ mǝɓangnǝa nakam aɓalǝ wun ngga,
\q1 Mim Yahweh ka, ǝn nggǝ lǝmdǝ ɓamúràm a baní aɓa sǝna;
\q1 ǝn nggǝ ne wi cau aɓa lòrǝo.
\q1 
\v 7 Pa anggo nǝ guro mem Musa ɗàng.
\q1 Yì ka ndanǝ domǝsǝcau aɓa ɓala mem kat.
\q1 
\v 8 Ən nggǝ nacau nǝi bwāng,
\q1 kún andǝ kún, pà aɓa cauɓaɓe ɗàng,
\q1 sǝ yì ka kǝ sǝn pǎ mem Mim Yahweh.
\m Mana tsǝa sǝ wu ginǝ ɓanggi nacau amur guro mem Musa?>>
\p 
\v 9 Nda bumlulla mala Yahweh earke arǝia sǝ nying bania.
\v 10 Sǝ lang pǝrɓang longŋǝni múr Tara ka, kara Miriyam bwal nǝ kwánó nggû, pwasǝo kǝla talimbulo. Sǝ Haruna pǝlǝa aban Miriyam, sǝ sǝni ka, kwánó nggû bwalǝni.
\v 11 Sǝ Haruna ne Musa ama, <<Ida, mǝtalem, cè a pa sǝm tanni ɗàng, acemǝnana sǝm pàngŋǝ̀nà gìr ɓwaɓana, sǝ sǝm pàngŋǝ̀nà cauɓikea.
\v 12 Ən nggǝ zǝmbo, cè a eare ɓǝ̀ pǎ kǝla lú bangna-muna, mǝnana lang purî bum ngge ka, ngguí kpattíkínà ka ɗàng.>>
\p 
\v 13 Sǝ Musa ɓua aban Yahweh ama, <<We Ɓakuli, ida sonzǝi, ǝn nggǝ zǝmbô.>>
\p 
\v 14 Sǝama Yahweh ne Musa ama, <<Ɓǝ̀ tárrí tappi wi ntara a ɓamǝsǝi ka, pà nǝ̀ do aɓa kirsakya anongŋo tongno-nong-ɓari re? Ɓǝà pusǝì anzǝm kàttì\f + \fr 12:14 \ft Ɓalli aɓa: \xt Pǝris 13:46; Ɓal 5:1-4; 2Amur 15:5\xt*\ft .\f* ɓǝ̀ ue kano ba anongŋo tongno-nong-ɓari, sǝ anzǝm mǝno ka, wu nyesǝi aɓa kàttì ɗǝm.>>
\v 15 Anggo sǝ à pusǝ Miriyam anzǝm kàttì sǝ ue kano ba anongŋo tongno-nong-ɓari, sǝ aɓwe ka, à lo gya ɗang she lang à nyesǝna Miriyam aɓa kàttì ɗǝm ngga.
\v 16 Anzǝm mǝno ka, aɓwe lo à nying Hazerot, sǝ à yi duk kàttì a pǝɗanban Paran.
\c 13
\s1 À tasǝ amǝ'shenzǝban a Kan'ana
\p 
\v 1 Yahweh bangcau nǝ Musa ama,
\v 2 <<Tasǝ aburana ɓǝà kya shenzǝ nzali Kan'ana, mǝnana ǝn nggǝ pè amǝ Isǝrayila ka. Aɓa koya tàu mala akeâ ka, à nǝ̀ tasǝ ɓwa mwashat mǝnana múrû na aɓalǝia ka.>>
\v 3 Pǝlǝa Musa tasǝia, à lo a pǝɗanban Paran, kǝla mǝnana Yahweh bang ngga, yia kat ka, amúrû mala amǝ Isǝrayila na.
\v 4 Alullǝia nia ka: A tàu mala Ruben ngga, nda Shamuwa muna-ɓwabura mala Zakkur;
\v 5 a tàu mala Shimiyon ngga, nda Shafat muna-ɓwabura mala Hori;
\v 6 a tàu mala Yahuda ka, nda Kalip muna-ɓwabura mala Jefune;
\v 7 a tàu mala Isaka ka, nda Igal muna-ɓwabura mala Yisǝfu;
\v 8 a tàu mala Ifǝrem ngga, nda Hoshiya\f + \fr 13:8 \fq Hoshiya \ft mǝnia ka nda Musa nggaɗi wi lullǝu ama Jesǝwa ka.\f* muna-ɓwabura mala Nun;
\v 9 a tàu mala Benjami ka, nda Palti muna-ɓwabura mala Rafu;
\v 10 a tàu mala Zebulu ka, nda Gadiyel muna-ɓwabura mala Sodi;
\v 11 a tàu mala Manasa (mǝnana a tàu mala Yisǝfu ka), nda Gaddi muna-ɓwabura mala Susi;
\v 12 a tàu mala Dan ngga, nda Amiyel muna-ɓwabura mala Gemalli;
\v 13 a tàu mala Asha ka, nda Setur muna-ɓwabura mala Makel;
\v 14 a tàu mala Naftali ka, nda Nabi muna-ɓwabura mala Vopsi;
\v 15 a tàu mala Gad ka, nda Gewel muna-ɓwabura mala Maci.
\v 16 Amǝnia ka à nda ka alullǝ aburana mǝnana Musa tasǝia ɓǝà shenzǝ nzalî ka. Sǝ Musa pè Hoshiya muna-ɓwabura mala Nun lullǝu ama Jesǝwa.
\v 17 Musa tasǝia ɓǝà shenzǝ nzali Kan'ana sǝ nea wia ama, <<Wu eauwe, wu kàr nǝ Negev, sǝ wu kya eauwe a nzali múr ankono,
\v 18 sǝ wu sǝn ko lang sǝ nzalî pa, sǝ ko aɓwana mǝnana à do aɓalǝi ka à ndanǝ rǝcandǝa ko amǝ'rǝwukea na, ko à nda kpokyak ko à bundǝo,
\v 19 sǝ ko nzali mana à do aɓalǝi ka mǝɓoarne na ko mǝɓane na, sǝ ko anggea-là mǝnana à do aɓalǝia ka, akàttì na ko akanggǝrang ala na,
\v 20 sǝ ko nzali gǝna na ko nzali tǝle na, sǝ ko anggun na aɓalǝi ko à pà kàm ɗàng. Wu dumnǝ mǝsǝ'kang'kangŋa wu yinǝ aɓea aɓǝla-nggun mala nzalî.>> Ado ka nda kún tita bangŋa mala aɓǝla-anap.
\v 21 Pǝlǝa à eauwe à wario à kya shenzǝ nzalî nǝ bu pǝɗanban Zin aban ká Rehop, tù nǝ Lebo Hamat.
\v 22 À eauwe à o a Negev sǝ à yiu a Hebǝron. Aɓwana mala atau mala Ahiman, Sheshai, andǝ Talmai, amǝkà Anak ka, à nda kano. (Hebǝron ngga à ɓè, apǝlǝa tongno-nong-ɓari sǝ à yi ɓak Zowan a Masar.)
\v 23 Sǝ lang à yiu a Ɓangŋaban Eshkol ka, à kasǝ bu-nggun nǝ dangŋanshi ɓǝla-anap, sǝ aɓwana ɓari twali arǝ gara; ɗǝm ngga à yinǝ aɓǝla mɓǝring andǝ vwari.
\v 24 Mǝno yì ban ngga à tunǝi ama Ɓangŋaban Eshkol, ace dangŋanshi ɓǝla-anap mǝnana amǝ Isǝrayila kasǝ kano ka.
\s1 Bǝlkun mala amǝ'shenzǝban
\p 
\v 25 A masǝlǝata anongŋo lumi-ine ka, à nyarî shenzǝ nzalî.
\v 26 Sǝ à yiu aban Musa andǝ Haruna andǝ ɓwabundǝa mala amǝ Isǝrayila a pǝɗanban Paran a Kadesh. À yinǝ cau sǝ à yi bǝlì Musa andǝ Haruna kunia andǝ ɓwabundǝa kat, sǝ à lǝmdǝia wia aɓǝla-nggun mala nzalî.
\v 27 Sǝ à ne Musa ama, <<Sǝm warina a nzali mana a túr sǝm kam ngga. Mur-nyi andǝ kiura kǝ ɓang kam, sǝ mǝnia ka nda ɓǝlanggun male.
\v 28 Sǝama aɓwana mǝnana à do a nzalî ka, amǝ'candǝe na, sǝ anggea-là ka, à gulkio sǝ à kària nǝ asheran. Sǝ ɗǝm ngga, sǝm sǝn amǝkà Anak kàm.
\v 29 Amǝ'Amalek ka, à ndanǝdo a Negev. Amǝ'Hiti andǝ amǝ'Jebus, andǝ amǝ'Amor ka, à do a nzali múr ankono. Sǝ amǝ'Kan'ana ka, à do a kún nggeamùr, sǝ a nkanggari Jodan.>>
\p 
\v 30 Pǝlǝa Kalip pwasǝlǝ aɓwana a ɓadǝm Musa, sǝ bang ama, <<Ɓǝ̀ sǝm lo ado ɓǝ̀ sǝm kya ak nzalî, acemǝnana sǝm ndanǝ rǝcandǝa pepè mala limurǝm amurí!>>
\v 31 Sǝ aɓwana mǝnana à wari andǝia ka, à na ama, <<Pà sǝm nǝ̀ gandǝ ká a munǝo arǝ amǝno yì aɓwana ka ɗàng, acemǝnana à kútì sǝm nǝ rǝcandǝa!>>
\v 32 Anggo sǝ à yinǝì amǝ Isǝrayila cau mǝɓane amur nzali mana à kya shenzǝi ka, ama, <<Nzali mana sǝm wari aɓalǝi a shenzǝe ka, nzali na mǝnana kǝ shak aɓwana mǝnana à do aɓalǝi ka, sǝ aɓwana mana kat sǝm sǝnia aɓalǝi ka, à dāh'riki mwat-mwat.
\v 33 Akano ka, sǝm sǝn akwatǝman-aɓwana,\f + \fr 13:33 \ft Ɓalli aɓa: \xt Tite 6:4\xt*\ft .\f* amǝ'kà Anak, mǝnana pur a tàu mala akwatǝman-aɓwana ka.\f + \fr 13:33 \ft Ɓalli aɓa: \xt Nggur 2:10-11,20-21\xt*\ft .\f* Sǝm sǝn ɓamúr rǝ sǝm abania kǝla adoshi, sǝ anggo gbal sǝ à sǝn sǝm.>>
\c 14
\s1 Aɓwe mgbicau
\p 
\v 1 Pǝlǝa ɓwabundǝa loasǝ gia à soɓua, à ɓua aɓa dù mǝno.
\v 2 Sǝ amǝ Isǝrayila kat nggwanî Musa andǝ Haruna.\f + \fr 14:2 \ft Ɓalli gbal aɓa: \xt Pur 16:2,7-8; 17:3; Ɓal 14:27; 16:11,41; Ang 59:15\xt*\ft .\f* Ɓwabundǝa puppup banggia wia ama, <<Eare ma'sǝm ngga, ɓǝ́ sǝm wukina a nzali Masar, ko aɓa mǝnia yì pǝɗanban ngga!
\v 3 Mana tsǝa sǝ Yahweh kǝ yinǝ sǝm a nzali man ɓǝà wal-lu sǝm nǝ nggeabyau? Amālá sǝm, andǝ amuna ma'sǝm ngga à nǝ̀ pwania kǝla agirkuma. Pà nǝ̀ ɓoaribanì yi mana ɓǝ̀ sǝm nyare a Masar ka re?>>\f + \fr 14:3 \ft Ɓalli gbal aɓa: \xt Ɓal 11:5; Nggur 17:16; Nehe 9:17; Atúró 7:39\xt*\ft .\f*
\v 4 Pǝlǝa à ne a rǝia ama, <<Ɓǝ̀ sǝm twal ɓwa ɓǝ̀ dupa sǝm a dǝmba ɓǝ̀ sǝm nyare a Masar.>>
\v 5 Pǝlǝa Musa andǝ Haruna kpa nǝ ɓamǝsǝia a nzali a ɓadǝm ɓwabundǝa mala ɓinala amǝ Isǝrayila.
\v 6 Sǝ Jesǝwa muna-ɓwabura mala Nun, andǝ Kalip muna-ɓwabura mala Jefune, yià mana à nda aɓalǝ amǝ'shenzǝ nzali ka, à sàngi adaura malea,
\v 7 sǝ à banggi ɓwabundǝa mala amǝ Isǝrayila kat ama, <<Nzali mǝnana sǝm kùtí nǝ ɓalǝi ace shenzǝe ka, nggea nzali mǝɓoarne na kǝ̀rkǝ́r.
\v 8 Ɓǝ̀ bum Yahweh pwasǝ arǝ sǝm ngga, nǝ̀ yinǝ sǝm a nzali man, sǝ nǝ̀ pasǝmì, yì nzali mǝnana mùr-nyì andǝ kiura à kǝ ɓang kam ngga.\f + \fr 14:8 \ft Ɓalli gbal aɓa: \xt Pur 3:8; Pǝris 20:24; Ɓal 13:17; 16:13-14\xt*\ft .\f*
\v 9 Wu kǝa na ama wun nǝ̀ mgbikî Yahweh cau ɗàng, sǝ ɓangciu ɓǝkǝa pàkka wun arǝ aɓwana mǝnana à do a nzalî ka ɗàng. Agirlina na aban sǝm. Yalban pâ a buia ɗàng, sǝ Yahweh na atà sǝm; ɓangciu ɓǝkǝa pàkka wun arǝia ɗàng.>>
\p 
\v 10 Pǝlǝa ɓwabundǝa lo ama à nǝ̀ ɓukkia nǝ atali. Sǝama ɓoarɓwa mala Yahweh lǝmdǝrǝì aɓa Tara Ban-peri, aban amǝ Isǝrayila kat.
\p 
\v 11 Sǝ Yahweh banggi Musa ama, <<Nǝ̀ sau lang sǝ aɓwana mǝnia nǝ̀ nyesǝcem-ɓà? Sǝ nǝ̀ sau lang sǝ à nǝ̀ ginǝ earnǝ mim, kat andǝ agir'lǝmndǝa mana kat ǝn pea aɓalǝia ka?\f + \fr 14:11 \ft Ɓalli aɓa: \xt Pur 4:1--12:31; 14:11,21-22; Ɓal 14:22\xt*\ft .\f*
\v 12 Mǝ nǝ koea nǝ kwánó-ɓikea, mǝ nǝ vwakibuam arǝia, sǝ mǝ nǝ pusǝ nzali mǝnana mǝgule na sǝ candǝe kútiǎ ka, nǝ we.>>
\s1 Musa pwanzali ace aɓwe
\p 
\v 13 Sǝama Musa ne Yahweh ama, <<Pǝlǝa amǝ Masar ka à nǝ̀ okce; acemǝnana a pusǝ aɓwana man aɓalǝia nǝ rǝcandǝa mò,
\v 14 sǝ à nǝ̀ bangce aban aɓwana mǝnana a nzali man ngga. Yia ka à ongŋǝna ama we Yahweh ka, a nda aɓalǝ amǝnia yì aɓwana ka. We Yahweh ka aɓwana man sǝnǝno ɓamǝsǝu andǝ ɓamǝsǝu, sǝ pǝrɓang mò kǝ cam amúrià, sǝ a kǝ gya a ɓadǝmbia nǝ pwari aɓa pǝrɓang mǝnana cam pǝrapǝra ka, sǝ nǝ du ka aɓa ɓǝsa mǝnana cam pǝrapǝra ka.\f + \fr 14:14 \ft Ɓalli aɓa: \xt Pur 13:21-22; Ɓal 9:16-17; Nggur 1:33\xt*\ft .\f*
\v 15 Ado ka ɓǝ̀ a wal-lú ka aɓwana mǝnia, a twaltea ka, anzali mala aɓwapǝndǝa mǝnana à okce zǝ́kí mala lullǝo ka, à nǝ̀ na ama,
\v 16 <Nda acemǝnana Yahweh gandǝ yinǝ aɓwana mǝnia ka a nzali mana kángìr ama nǝ̀ pea wia ka\f + \fr 14:16 \ft Ɓalli aɓa: \xt Tite 12:7; 13:14-17; 15:7; Atúró 7:5\xt*\ft .\f* raka, nda tsǝa sǝ wal-luia aɓa pǝɗanban ngga.>
\v 17 Sǝ ado ka, ida, ɗeki rǝcandǝa mala Mǝtala sǝm ɓǝ̀ dumnǝ gulo kǝla mana a pacau, ama,
\v 18 <Yahweh kǝ kaurǝa pak bumlulla ɗàng, sǝ pěmǝɓoarne aɓa earcearǝu male mana kǝ dǝurǝ raka nda nyangsang, kǝ twalban cauɓikea andǝ mgbikiru; sǝama pà nǝ̀ nying ɓwa mǝnana kumcau ka ɓǝ̀ ukɓà ɗàng; kǝ yinǝ ɓashi ace acauɓikea mala atárrú amur amunia andǝ amǝ'keà, aban ká tàruià andǝ inea nza.>\f + \fr 14:18 \ft Ɓalli gbal aɓa: \xt Pur 20:5; 34:6-7; Nggur 5:9; Ir 32:18\xt*\ft .\f*
\v 19 Ida, twalban cauɓikea mala amǝnia yì aɓwana ka, atàcau mala gulo mala pěmǝɓoarne aɓa earcearǝu mô mana kǝ dǝurǝ raka, kǝla mana a twali amǝnia yì aɓwana banì aɓa Masar ba ado ka.>>
\s1 Ɓakuli pacau mala ɓashi
\p 
\v 20 Pǝlǝa Yahweh bang ama, <<Ən twalǝnabanì, kǝla mǝnana a bang ngga.
\v 21 Sǝama aɓa mǝsǝcau, mbak-kàngkàng mǝ ndanǝ yilǝmu sǝ ɓanza lumsǝ nǝ gulo mem ngga,\f + \fr 14:21 \ft Ɓalli gbal aɓa: \xt Ang 72:19; Hab 2:14\xt*\ft .\f*
\v 22 kǝɓwa pà kàm atà aɓwana mǝnia mǝnana à sǝn gulo mem andǝ agir-lǝmdǝa, mana ǝn pea a Masar andǝ ɓá pǝɗanban, sǝ kat andǝ amani ka, à karǝkiam kusǝ lum man, sǝ à kwakikiria arǝ giem raka,
\v 23 mǝnana à nǝ̀ sǝn nzali mana ǝn kánbì atárrià ace ka ɗàng. Sǝ kǝɓwa pà kàm atà aɓwana mǝno à nyesǝcem-ɓà ka,\f + \fr 14:23 \ft Ɓalli aɓa: \xt Ɓal 14:11; Nggur 31:20\xt*\ft .\f* nǝ̀ sǝni ɗàng.
\v 24 Sǝama guro mem Kaleb, acemǝnana bangŋo male na ɗàng, sǝ kpatam kat-kat ka, mǝ nǝ yinǝi a nzali mǝnana wari kam ngga, sǝ nǝ̀ duk girkuma mala amuni andǝ amǝkè.\f + \fr 14:24 \ft Ɓalli gbal aɓa: \xt Jes 14:6-15; Akas 1:10-12,20\xt*\ft .\f*
\v 25 Ado ka, acemǝnana amǝ Amalek andǝ amǝ'Kan'ana na kam nǝ do arǝ aɓangŋaban ngga, lí ka wu pǝlǝa wu dǝshi pǝɗanban nǝ njar Nggeamùr Nzuno.>>
\p 
\v 26 Sǝ Yahweh bangcau nǝ Musa andǝ Haruna ama,
\v 27 <<Nǝ̀ sau lang sǝ mǝ nǝ twalgàndǝá nǝ mǝnia yì ɓwabundǝa mǝɓealɓike mǝnana à camarǝ nggwaniam ngga? Ən ongŋǝna nggwani mana amǝ Isǝrayila kǝ nggwaniam ngga.\f + \fr 14:27 \ft Ɓalli aɓa: \xt Pur 16:2,7-8; 17:3; Ɓal 14:29,36; 16:11,41; Nggur 1:27\xt*\ft .\f*
\v 28 Banggia wia ama, <Ən kán nǝ yilǝmem, mim Yahweh ama, gìr mǝnana wu ne sǝ ǝn oê ka, nda mǝ nǝ pàkka wun ngga:
\v 29 alú wun nǝ̀ bwamdǝ a mǝnia yì pǝɗanban ngga; sǝ atà aburana mǝnana kat à ɓallia a ɓalban, twal aban ɓwa mǝnana apǝlǝa malea na lumi-ɓari andǝ mana kútì ka, mǝnana à nggwaniam ngga,
\v 30 kǝ mwashat atea pà kàm mǝnana nǝ̀ kùtí aɓa nzali mana ǝn kángìr\f + \fr 14:30 \fq kángìr \ft ko <<ǝn loasǝ buam a kuli>>\f* ama mǝ nǝ dumsǝ wun kàm ngga ɗàng, she Kaleb muna-ɓwabura mala Jefune andǝ Jesǝwa muna-ɓwabura mala Nun.
\v 31 Sǝama amuna mǝkeke ma'wun, mǝnana wu na ama à nǝ̀ bwalkia ko à nǝ̀ wal-luia ka, mǝ nǝ yinǝia aɓalǝi, sǝ à nǝ̀ súrǝ̀\f + \fr 14:31 \fq súrǝ̀ \ft ko <<ok banɓoarnado mala>>\f* nzali mǝnana wu ginǝce ka.
\v 32 Sǝ wun ngga, alú wun nǝ̀ bwamdǝ aɓa pǝɗanban mǝnia ka.
\v 33 Amuna ma'wun nǝ̀ duk ayalgir a pǝɗanban apǝlǝa lumi-ine, sǝ à nǝ̀ tanni àtàcau mala ɗwanyi-domǝsǝcau ma'wun, sheɓǝ̀ masǝlǝata alú wun bwamdǝna a pǝɗanban ngga.
\v 34 Kǝla làkkì mala anongŋo mǝnana wu pa aban shenzǝ nzali, anongŋo lumi-ine ka, anggo sǝ wun nǝ̀ nutanni mala acauɓikea ma'wun apǝlǝa lumi-ine, koya pǝlǝa mwashat ka a kúnì nongŋo mwashat,\f + \fr 14:34 \ft Ɓalli gbal aɓa: \xt Ɓal 13:25; 32:13; Nggur 2:14; Ang 95:10; Ezǝk 4:6\xt*\ft .\f* sǝ wun nǝ̀ súrǝ̀ bumkiɗikea mem.>
\v 35 Mim Yahweh ka, ǝn bangŋǝni. Mǝnia yì gìr ka, ǝn kána mǝ nǝ pàkkî mǝnia yì ɓwabundǝa puppup mǝɓealɓike, mǝnana à kpapikunia arǝàm ngga:\f + \fr 14:35 \ft Ɓalli aɓa: \xt Ɓal 16:11; 27:3\xt*\ft .\f* àkǝ ɓá pǝɗanban man sǝ masǝlǝatea nǝ yiu kat-kat, sǝ a banì sǝ à nǝ̀ wukio.>>
\p 
\v 36 Aburana mana Musa túriá ɓǝà shenzǝ nzali, mǝnana à nyare à yi tsǝk ɓwabundǝa à nggwanî wi nǝ yinǝ cau mǝɓane amur nzalî,
\v 37 yì aburana mǝno à yi mesǝ cau mǝɓane amur nzalî ka, gìr'mur'mwana wal-luia a ɓadǝm Yahweh.
\v 38 Aɓalǝ aburana mǝno à wari a shenzǝ nzali ka, kǝ Jesǝwa muna-ɓwabura mala Nun andǝ Kaleb muna-ɓwabura mala Jefune na à ue nǝyilǝmu ka.
\s1 À lì amǝ Isǝrayila a lwa
\p 
\v 39 Lang Musa banggi amǝ Isǝrayila kat amǝnia yì acau ka, aɓwe pak bumkiɗikea kǝ̀rkǝ́r.
\v 40 Sǝ à lo nǝ dǝmbari ɗiɗyal, à eauwe amur ankono mala nzalî, sǝ à na ama, <<Sǝm ndya ka, mǝsǝcau sǝm pàngŋǝ̀nà cauɓikea, sǝama sǝm nǝ̀ eauwe ace ká a ban mǝnana Yahweh pacau ace ka.>>\f + \fr 14:40 \ft Ɓalli aɓa: \xt Nggur 1:41-44\xt*\ft .\f*
\p 
\v 41 Sǝ Musa ka bang ama, <<Palang ado sǝ wu kǝ yàl nzongcau mala Yahweh, yima pě mǝno anggo ka pà nǝ̀ yinǝ limurǝm raka?
\v 42 Wu kǝa ká ɗàng, acemǝnana Yahweh pà aɓalǝ wun ɗàng; ɓǝ̀ ana raka aɓiwun amǝbura nǝ̀ lì wun.
\v 43 Amǝ'Amalek andǝ amǝ'Kan'ana ka à nda kana, à nǝ̀ dǝshi wun, sǝ à nǝ̀ gandǝ wun nǝ nggeabyau. Acemǝnana wu pǝlǝna nzǝm wun arǝ kpata Yahweh ka, Yahweh pà nǝ̀ pa atà wun ɗàng.>>
\p 
\v 44 Sǝ yià ka à twalkicau ama à nǝ̀ eauwe amur ankono mala nzalî, kat andǝ amani ama Musa andǝ Akwati Kùrcau nying kàttì raka.
\v 45 Pǝlǝa amǝ'Amalek andǝ amǝ'Kan'ana mǝnana à do arǝ ala amur ankono ka, à sulǝ ateà, à yi gandǝia, à pǝrtea aban ká Horma.
\c 15
\s1 Anggurcau amur pāki agir'nkila
\p 
\v 1 Yahweh bangcau nǝ Musa ama,
\v 2 <<Bangcau nǝ amǝ Isǝrayila, nea wia ama, <Lang wu yina aɓa nzali mǝnana ǝn nggǝ pa wun, wun nǝ̀ duk kam,
\v 3 sǝ wun nǝ̀ pàgir nǝ bǝsa aban Yahweh ka, wu pà jamnda ko gam ko gbato. Wu panagir nǝi kǝla pàgir mala pisǝe kǝring, ko mala gir'nkila ace lumsǝ pàcau nǝ-shambum,\f + \fr 15:3 \ft Sǝni aɓa: \xt Pǝris 22:21; 27:2; Ɓal 15:8\xt*\ft .\f* ko mala eare mala ɓabum, ko mǝnana wu kǝ pa pwari-pwari ace alamsan ma'wun ngga, ace pa rǝmban mǝɓoarne mǝnana kǝ pwasǝbumam Yahweh ka.
\v 4 Ɓwa mǝnana kǝ yinǝ pàgir male aban Yahweh ka, dumǝna púp nǝ̀ yinǝi atārǝia andǝ pàgir mala mǝsǝsa, muku mǝɓǝlke tyang mwashat, mǝnana à zurì nǝ mùrú olif, dù-lita mwashat ka.
\v 5 Lang wun nǝ̀ pà muna-gam ace pagir mala pisǝe kǝring ko gir'nkila nǝi ka, dumǝna púp awu nǝ yinǝi atārǝia andǝ dù-lita mwashat mala mùr-anap ace pàgir mala girnùná.
\p 
\v 6 << <Ɓǝ̀ gam na ka, dumǝna púp awu nǝ yinǝ tyang ɓari mala muku mǝɓǝlke mǝnana à zurì nǝ dù-lita mwashat nǝ gauwa-tsùrú mala mùrú olif ka, ace pàgir mala mǝsǝsa;
\v 7 ɗǝm ngga awu nǝ pàgir mala girnùná, dù-lita mwashat nǝ gauwa-tsùrú mala mùr-anap, ace pà rǝmban mǝɓoarne mǝnana kǝ pwasǝbumam Yahweh ka.
\p 
\v 8 << <Lang jamnda na awu nǝ pa kǝla pàgir mala pisǝe kǝring ko gir'nkila, ace lumsǝ pàcau nǝ-shambum, ko kǝla pàgir mala dotarǝu aban Yahweh ka,
\v 9 dumǝna púp awu nǝ pà mǝno yi jamnda ka andǝ tyang tàrú mala muku mǝɓǝlke mǝnana à zurì nǝ dù-lita ɓari mala mùrú olif ka;
\v 10 ɗǝm ngga dumǝna púp awu nǝ pa dù-lita ɓari mala mùr-anap kǝla pàgir mala girnùná. Pàgir na nǝ bǝsa, mala pa rǝmban mǝɓoarne mana kǝ pwasǝbumam Yahweh ka.
\v 11 Anggo sǝ à nǝ̀ gilǝkice koya jamnda ko gam, koya muna-gam ko muna-gbato.
\v 12 Dumǝna púp ama, awu nǝ pàk mǝnia ka ace komǝye atea, kǝla mana làkkì malea pàk ka.
\p 
\v 13 << <Koya ɓwa mǝnana kat à ɓǝli ɓwa Isǝrayila na ka, dumǝna púp nǝ̀ pàk agir mǝnia ka anggo lang nǝ̀ yinǝ pàgir nǝ bǝsa, ace pa rǝmban mǝɓoarne mana kǝ pwasǝbumam Yahweh ka.
\v 14 Arǝ anza mǝnana kat à kǝ yiu ka, ɓǝ̀ ɓwa-kúnɗàngna yiu a do bǝti atà wun, sǝ ko ɓǝ̀ yana mǝnana ndanǝdo aɓalǝ wun sǝ earce ama nǝ̀ yinǝ pàgir nǝ bǝsa, ace pa rǝmban mǝɓoarne mana kǝ pwasǝbumam Yahweh ka, dumǝna púp nǝ̀ pè a pě ma'wun.
\v 15 Nggurcau mǝmwashati na ace ɓwabundǝa kat, ace wun andǝ ɓwa-kúnɗàngna mana ndanǝdo aɓalǝ wun ngga; nê na mǝnana pà nǝ̀ nggaɗi raka arǝ anza ma'wun kat. Wun, sǝ yià amǝkúnɗàngna ka, wu nda mwashat a ɓadǝm Yahweh.
\v 16 Anggurcau andǝ akwarkiru mǝmwashati na ace wun sǝ ace ɓwa-kúnɗàngna mana do aɓalǝ wun ngga.> >>
\p 
\v 17 Yahweh nacau nǝ Musa ama,
\v 18 <<Bangcau nǝ amǝ Isǝrayila sǝ wu nea wia ama, <Lang wu kutina aɓa nzali mǝnana ǝn nggǝ yinǝ wun kam ngga,
\v 19 nǝ̀ yia do ama, lang wu lina girlina mala nzalî ka, dumǝna púp wun nǝ̀ yinǝ pàgir mala loasǝe a kuli abanam Yahweh.\f + \fr 15:19 \fq yinǝ pàgir mala loasǝe a kuli abanam Yahweh \ft ko <<san ɓè bare ace pàgir mǝnana à tàrì acem Yahweh ka.>>\f*
\v 20 Wun nǝ̀ yinǝ kyak mǝnana à pè nǝ muku mana wu goe a dǝmba ka, sǝ wun nǝ̀ tàrì ɓǝ̀ duk pàgir mǝnana à loasǝi a kuli aban Yahweh ka, kǝla mana wu kǝ pangnǝ mǝsǝsa mǝdǝmbe mana pur a katǝra ka.
\v 21 Dumǝna púp ama koya pǝlǝa, arǝ anza ma'wun kat ka, wun nǝ̀ nggǝ pê Yahweh pàgir mana à loasǝi a kuli ka aɓa muku mǝdǝmbe mǝnana wu goe ka.
\s1 Anggurcau amur acauɓikea mana à pea aɓa ɓwarkio ka
\p 
\v 22 << <Lang wu ɓwarkio, wu gatti kpata anzongcau man mǝnana kat Yahweh banggi Musa ka,
\v 23 nggearǝ agir mana kat Yahweh na wun nǝ kún Musa, twal a pwari mana Yahweh pana nzongcau nǝi aban ká dǝmba, arǝ anza ma'wun kat ka,
\v 24 sǝ ɓǝ̀ mǝnia ka wu pè kpakpak ɗang, sǝ pà a mǝsǝ ɓwabundǝa raka, ɓwabundǝa kat nǝ̀ pà lo-jamnda, kǝla pàgir mala pisǝe kǝring, ace pà rǝmban mǝɓoarne mǝnana kǝ pwasǝbumam Yahweh ka, atārǝia andǝ pàgir mala girlina andǝ pàgir mala girnùná male, kǝla mana nggurcau kanì ka, andǝ gbato mwashat ace pàgir mala gǝshi cauɓikea.
\v 25 Pǝris nǝ shawuɗi ɓwabundǝa mala amǝ Isǝrayila sǝ à nǝ̀ twalia wia banì, acemǝnana ɓwarkio na, sǝ ɗǝm ngga à yinanǝ pàgir malea, yì pàgir nǝ bǝsa aban Yahweh andǝ pàgir mala gǝshi cauɓikea malea aban Yahweh, ace ɓwarkio malea.
\v 26 Sǝ ɓwabundǝa mala amǝ Isǝrayila kat ka, à nǝ̀ twalia wia banì, yia andǝ amǝkúnɗàngna mǝnana à do aɓalǝia ka, acemǝnana mǝno yì gìr à pè ka kum aɓwana kat aɓa ɗwanyi-sǝlǝe.
\p 
\v 27 << <Ɓǝ̀ ɓwa mwashat pàk cauɓikea aɓa ɗwanyi-sǝlǝe ka, dumǝna púp ama nǝ̀ pà gir'nkila nǝ mamǝna mbul mǝnana mbule mwashat ka, kǝla pàgir mala gǝshi cauɓikea.
\v 28 Sǝ ɓwa mǝno ɓwarkio, lang pàk cauɓikea aɓa ɗwanyi-sǝlǝe ka, pǝris nǝ̀ shawuɗi a ɓadǝm Yahweh. Nǝ̀ shawuɗì sǝ à nǝ̀ twali wi banì.
\v 29 Nggurcau na mwashat ace ɓwa mǝnana pàk cauɓikea aɓa ɗwanyi-sǝlǝe ka, ko ɓwê ka à ɓǝlì ɓwa Isǝrayila na, ko ɓwa-kúnɗàngna na, mǝnana do aɓalǝ wun ngga.
\p 
\v 30 << <Sǝ ɓwa mǝnana pàk gìr kpakpak ka, ko ɓwa Isǝrayila na ko ɓwa-kúnɗàngna na ka, ndarǝ ɓǝsǝki Yahweh. Mǝno yì ɓwa ka à nǝ̀ pusǝì aɓalǝ aɓwana male.
\v 31 Acemǝnana nyesǝna cau mala Yahweh ɓà, sǝ yàlni nzongcau male ka, mǝno yì ɓwa ka, à nǝ̀ kasǝì aɓalǝ aɓwana male kat-kat. Bafe male nǝ̀ ueo amurí.> >>
\s1 À wal-lú ɓeɓwa ace yàl nzongcau mala Sabbat
\p 
\v 32 Lang amǝ Isǝrayila na aɓa pǝɗanban ngga, à kum ɓeɓwa aban tarki gimsa a pwari Sabbat.\f + \fr 15:32 \ft Sǝni aɓa: \xt Pur 35:2-3\xt*\ft .\f*
\v 33 Aɓwana mǝnana à kumi aban tarki gimsa ka, à warinǝi aban Musa andǝ Haruna, andǝ ɓwabundǝa kat.
\v 34 À gìrì a ndà, acemǝnana à malaká kasǝcau amur gìr mǝnana à nǝ̀ pàngnǝi ka ɗàng.
\p 
\v 35 Yahweh banggi Musa ama, <<Mǝno yì ɓwa ka, dumǝna púp à nǝ̀ wal-luí; ɓwabundǝa ɓǝà ɓukkí nǝ atali zak nǝ kàttì.>>
\v 36 Nda ɓwabundǝa puppup pusǝì zak nǝ kàttì, sǝ à ɓukki nǝ atali wǔ, kǝla mǝnana Yahweh banggi Musa ka.
\p 
\v 37 Yahweh bang cau nǝ Musa ama,
\v 38 <<Nacau nǝ amǝ Isǝrayila, sǝ wu banggia wia ama, <Arǝ anza malea kat ka, ɓǝà ɓolǝ ankonggúr ace ɗúrkia arǝ abankara mala kún anggea-daura malea, sǝ arǝ koya ɓolǝo-nkonggúr ka, à nǝ̀ tsǝki wi nkonggúr mǝlùre.
\v 39 Nǝ̀ duk ɓolǝo-nkonggúr ace wun, ace mǝnana ɓǝ̀ wu sǝni, sǝ ɓalǝ wun ɓǝ̀ kasǝa arǝ anzongcau mala Yahweh kat, sǝ wu kpatea, sǝ wu kǝa gya atà ɓabum wun andǝ mǝsǝ wun, mǝnana nǝ̀ kánǝ wun a gyatarǝu atà aɓea aɓakuli ka ɗàng.
\v 40 Anggo sǝ wun nǝ ɗenyinǝ, sǝ wun nǝ̀ kpata anzongcau mem kat, sǝ wun nǝ̀ duk amǝfele aban Ɓakuli ma'wun.
\v 41 Mǝ nda Yahweh Ɓakuli ma'wun, mǝnana pusǝ wun aɓa nzali Masar ace duk Ɓakuli ma'wun ngga. Mǝ nda Yahweh Ɓakuli ma'wun.> >>
\c 16
\s1 Mgbicau mala Kora
\p 
\v 1 A ɓe pwari ka, Kora muna-ɓwabura mala Iza, muna-ɓwabura mala Kohat, muna-ɓwabura mala Lawi, twal Datan andǝ Abiram, amuna-burana mala Eliyap, andǝ On muna-ɓwabura mala Pele, amǝkà Ruben, atè.
\v 2 Sǝ à lo arǝ Musa, atārǝia andǝ aɓea aburana gbǝman-ɓari nǝ lumi-tongno, mǝnana à súrǝ̀ia pepè, sǝ amǝ Isǝrayila twalia ɓǝà duk aɓwana-mǝgule amur ɓwabundǝa ka.
\v 3 À kya ram rǝia a banɓwáná arǝ Musa andǝ Haruna sǝ à banggia wia ama, <<Wu umá ɗār! Koyan aɓa ɓwabundǝa mǝnia kat ka mǝfele na, sǝ Yahweh ka nda aɓalǝia! Sǝ palang sǝ wu kǝ loasǝ ɓamur rǝ wun amur ɓwabundǝa mala Yahweh?>>
\p 
\v 4 Lang Musa ok cau man ngga, kara kpa nǝ ɓamǝsǝi a nzali,
\v 5 sǝ ne Kora andǝ aɓwana mǝnana kat atè ka, ama, <<Nǝ dǝmbari ka, Yahweh nǝ̀ lǝmdǝ yana nda male, sǝ yana nda mǝfele andǝ ɓwa mǝnana nǝ̀ yinǝi tù a baní ka. Ɓwa mǝnana Yahweh nǝ̀ twal ka, nǝ̀ yinǝi tù a baní.
\v 6 We Kora wunǝ aɓwana mô kat, wu pàk mǝnia ka: wu twal atasau-bǝsa;\f + \fr 16:6 \ft Ɓalli aɓa: \xt Pur 27:3; 38:3; Ɓal 4:9,14; 16:17,37-39\xt*\ft .\f*
\v 7 lí ka, wu tsǝk bǝsa aɓalǝia, sǝ wu so muku-gìr loasǝ yele mǝ'rǝmɓoarne amúrià aɓadǝm Yahweh.\f + \fr 16:7 \ft Ɓalli gbal aɓa: \xt Pǝris 10:1-2; 16:12\xt*\ft .\f* Ɓwa mǝnana Yahweh nǝ̀ twal ka, nǝ̀ duk ɓwa mǝnana mǝfele na ka. Wun amuna-burana mala Lawi ka, wu umá ɗār!>>
\p 
\v 8 Pǝlǝa Musa ne Kora ama, <<Wu ǒ, wun amuna-burana mala Lawi:
\v 9 Wu kǝ sǝni ama gìr mǝkyauwe na, mǝnana Ɓakuli mala amǝ Isǝrayila tàr wun aɓa ɓwabundǝa mala Isǝrayila, ace yinǝ wun tù a baní, ɓǝ̀ wu pàk túró a Taragula mala Yahweh, sǝ ɓǝ̀ wu came a ɓadǝm ɓwabundǝa ace pakkia wia túró ka,
\v 10 sǝ ɗǝm ngga yinanǝ wun tù a baní, wun kat andǝ amǝ'eam wun amuna-burana mala Lawi ka le? Wu ndarǝ alta dobuno-pǝris gbal le?
\v 11 Acemani ka, nda arǝ Yahweh sǝ wun, wunǝ amǝ kpata wun ngga, wu ram rǝwun! Yana nda Haruna mǝnana wu kǝ nggwani wi ka?>>
\p 
\v 12 Sǝ Musa túrban ɓǝà tunǝ Datan andǝ Abiram, amuna-burana mala Eliyap ɓǝà yiu; sǝ à bang ama, <<Pà sǝm nǝ̀ ká ɗàng!
\v 13 A kǝ sǝni kǝla gìr mǝkyauwe na mǝnana a pusǝ sǝm, sǝm purî ɓá nzali mǝnana mur-nyi andǝ kiura kǝ ɓang kàm ngga, ace wal-lú sǝm aɓa pǝɗanban ngga, sǝ ado ka a kǝ earce lǝmdǝ do-ɓwamǝgule amur sǝm gbal le?
\v 14 Sǝ yale a malaká yinǝ sǝm a nzali mǝnana mur'nyi andǝ kiura kǝ ɓang kàm ngga ɗàng, sǝ a pa sǝm aɓaban-mǝssa andǝ aɓaban-anap ɓǝà duk agirkuma ma'sǝm ɗàng. A kǝ sǝnì kǝla sǝm pànǝ ɗenyicau re? Awo, pà sǝm nǝ ká ɗàng!>>
\p 
\v 15 Bum Musa lul kǝ̀rkǝ́r, sǝ ne Yahweh ama, <<Cè a ak apagir malea ɗàng. Ən ak kǝ mǝdambǝriso a bu kǝɓwa ateà ɗàng, sǝ ǝn pakkì kǝɓwa ateà kǝgir mǝɓane ɗàng.>>
\p 
\v 16 Sǝ Musa ne Kora ama, <<Lí ka, we wunǝ amǝ'tò kat, wu kya ɓadǝm Yahweh; we, yià sǝ Haruna.
\v 17 Koyan atà wun ngga ɓǝ̀ twal tasau-bǝsa male, sǝ ɓǝ̀ so muku-gìr loasǝ yele mǝ'rǝmɓoarne aɓalǝi, sǝ koyan ngga ɓǝ yinǝ tasau-bǝsa male aɓadǝm Yahweh, atasau-bǝsa gbǝman-ɓari nǝ lumi-tongno; we gbal, sǝ Haruna, koyan nǝ tasau-bǝsa male.>>
\p 
\v 18 Koyan ateà ka, twal tasau-bǝsa male, tsǝk bǝsa aɓalǝi, sǝ so muku-gìr loasǝ yele mǝ'rǝmɓoarne amurí, sǝ came a bankutio aɓa Tara Ban-peri, atārǝia andǝ Musa andǝ Haruna.
\v 19 Kora ram ɓwabundǝa arǝia a bankutio aɓa Tara Ban-peri.
\p Ɓoarɓwa mala Yahweh pusǝrǝi aban ɓwabundǝa kat.
\v 20 Yahweh ne Musa andǝ Haruna ama,
\v 21 <<Wu gǝ́shìban ɓinala aɓwana mǝnia ka, ace mǝnana mǝ twaltea akǝ dyadyan!>>
\p 
\v 22 Sǝama Musa andǝ Haruna kpa nǝ ɓamǝsǝia, sǝ à bang ama, <<We Ɓakuli, Ɓakuli mala abangŋo mala aɓwapǝndǝa kat, ɓwa mwashat nǝ̀ pàk cauɓikea sǝ awu nǝ pak-bumlulla nǝ ɓwabundǝa kat le?>>
\p 
\v 23 Pǝlǝa Yahweh nacau nǝ Musa, ama,
\v 24 <<Banggi ɓwabundǝa ama, <Wu gǝ́shìban agumli mala Kora, Datan andǝ Abiram!> >>
\p 
\v 25 Pǝlǝa Musa lo wari aban Datan andǝ Abiram; sǝ aɓwana-mǝgule mala Isǝrayila o atè.
\v 26 Sǝ banggi ɓwabundǝa ama, <<Ida, wu upi ban agumli mala aburana amǝɓealɓike man, sǝ wu kǝa je kǝgir malea ɗàng, ɓǝ̀ ana raka à nǝ̀ twalta wun aɓalǝ acauɓikea malea kat!>>
\v 27 Nda à gǝ́shìban agumli mala Kora, Datan andǝ Abiram, a koya buì. Datan andǝ Abiram puro à cam a kún agumli malea andǝ amālea, amuna-burana malea andǝ amuna mǝkèke malea.
\v 28 Musa bang ama, <<Nǝ mǝnia ka sǝ wun nǝ̀ sǝlǝa ama Yahweh túrǎm ɓǝn pakki atúró mǝnia ka; à pur aɓa ɗenyicau mem ɗàng.
\v 29 Ɓǝ̀ aɓwana mǝnia wú kǝla mana aɓwana kat kǝ wú ka, ko ana raka, ɓǝ̀ gìr mǝnana kumgiyi aɓwana nda mana nǝ̀ kumia ka, Yahweh nǝ̀ túrǎm ɗang.
\v 30 Sǝama ɓǝ̀ Yahweh pàk gìr mǝbǝshe, sǝ nzali mǝn kúni myalia kat andǝ agir mana amalea na, sǝ à kùtí nǝmǝsǝia a Shewol ka, sǝ wun nǝ̀ sǝlǝa ama aburana man ɓǝsǝkina Yahweh.>>
\p 
\v 31 Lang malǝna naki acau mǝnia ka, kara nzali mǝnana à cam amurí ka gauwa mǝnna.
\v 32 Nzali mǝn kúni, sǝ myalia andǝ amǝɓala malea, aɓwana mala Kora kat, andǝ agirkuma malea.
\v 33 Anggo sǝ yia, andǝ agirkuma malea kat ka, à ko nǝmǝsǝia a Shewol; sǝ nzali gir amúrià, tea-twalî ɓá ɓwabundǝa.
\v 34 Makki'zwalo malea tsǝk amǝ Isǝrayila mǝnana kat à kàrìbania ka à lo nǝ mire; à bang ama, <<Cè nzali myal sǝm ɗàng!>>
\v 35 Bǝsa sulǝ nǝban Yahweh, pisǝ aɓwana mǝno gbǝman-ɓari nǝ lumi-tongno mǝnana à pàgir mala loasǝ yele mǝ'rǝmɓoarne ka.
\p 
\v 36 Yahweh bangcau nǝ Musa ama,
\v 37 <<Banggi Eleaza muna-ɓwabura mala Haruna yì pǝris, ama ɓǝ̀ pwangi atasau-bǝsa aɓa pibǝsa, acemǝnana amǝfele na. Sǝ ɓǝ̀ mesǝki ankalang-bǝsanì kuko nǝ kàttì.
\v 38 Atasau-bǝsa mala aɓwana mǝnia à pàk cauɓikea sǝ warinǝia à ɗwanyi yilǝmia ka, ɓǝà walkia lapat-lapat, ace gìr-rǝ gyangŋan nǝia, acemǝnana à panagir nǝia aban Yahweh. Acemani ka amǝfele na. À nǝ̀ duk gìr'lǝmdǝa aban amǝ Isǝrayila.>>
\v 39 Nda Eleaza yì pǝris twal amǝnia yì atasau-bǝsa mala bolo-bángŋá, mǝnana aɓwana mana à pisǝia ka, à panagir nǝia ka, sǝ walkia lapat-lapat, à pǝlǝ gìr gìr-rǝ gyangŋan,
\v 40 kǝla mana Yahweh banggi wi nǝ kún Musa ka. Mǝno ka nǝ̀ duk gir kasǝɓalǝu aban amǝ Isǝrayila ama kǝ ɓwa-ɗàng pà kàm, mǝnana pur a tàu mala Haruna raka, nǝ̀ sung tù ama nǝ̀ pàgir mala pisǝ muku-gìr loasǝ yele mǝ'rǝmɓoarne aɓadǝm Yahweh ka ɗang, ace mǝnana ɓǝ̀ kǝa pa kǝla Kora andǝ amǝtè ka ɗàng.
\p 
\v 41 Sǝama lang ban yi fana ka, ɓwabundǝa mala amǝ Isǝrayila nggwanî Musa andǝ Haruna ama, <<Wu walna-lú aɓwana mala Yahweh!>>
\v 42 Sǝ lang ɓwabundǝa yi ramba arǝ Musa andǝ Haruna ka, à pǝlǝ mǝsǝia nǝban Tara Ban-peri. Kara à sǝni ka pǝrɓang girna murí, sǝ ɓoarɓwa mala Yahweh pusǝrǝi.
\v 43 Pǝlǝa Musa andǝ Haruna yiu a bankutio aɓa Tara Ban-peri,
\v 44 Yahweh nacau nǝ Musa ama,
\v 45 <<Wu gǝ́shìban ɓwabundǝa mǝnia ka, ace mǝnana ɓǝn twaltea adyan.>> Sǝama à kpa nǝ ɓamǝsǝia a nzali.
\v 46 Sǝ Musa ne Haruna ama, <<Twal tasau-bǝsa mò, ɗàrǝ́ nkalang-bǝsa mana nda amur gyangŋan ngga aɓalǝi, sǝ wu so muku-gìr loasǝ yele mǝ'rǝmɓoarne amurí. Kyane akaurǝa aban ɓwabundǝa sǝ wu shawuɗia, acemǝnana bumlulla sulǝna nǝban Yahweh! Kwánó-ɓikea tinate.>>
\v 47 Nda Haruna pa kǝla mana Musa banggi wi ka; twal tasau-bǝsa male, sǝ ɓangŋa wari a tsùrú mala ɓwabundǝa, sǝ sǝni ka kwánó-ɓikea tinate aɓalǝ aɓwana. Pǝlǝa so muku-gìr loasǝ yele mǝ'rǝmɓoarne, sǝ shawuɗi aɓwe.
\v 48 Yi came a nre ka alú andǝ amǝyilǝmu, sǝ à tamsǝ kwánó-ɓikea, lidǝmba ɗàng.
\v 49 Làkkì mala aɓwana mǝnana à wù atàcau mala kwánó-ɓikea mǝnia ka, à nda á-lum-nong-ine nǝ gbǝman-tongno-nong-ɓari (14,700), amur amǝno à wu a gìr-kumban mala Kora ka.
\v 50 Anzǝm mǝnana à tàmsǝna kwánó-ɓikea ka, Haruna nyar aban Musa a bankutio aɓa Tara Ban-peri.
\c 17
\s1 Gara mala Haruna tò-mbuí
\p 
\v 1 Yahweh banggi Musa ama,
\v 2 <<Nacau nǝ amǝ Isǝrayila, sǝ wu ak agara lum-nong-ɓari a buia, mwashat ace koya ɓala-kàu,\f + \fr 17:2 \fq ɓala-kàu \ft ko tàu\f* a bu amúrû kat arǝ aɓala-kàu malea. Gilǝ lullǝ koya múrû arǝ gara male,
\v 3 sǝ wu gilǝ lullǝ Haruna amur gara mala Lawi. Koya múrû mala koya ɓala-kàu ka nǝ̀ pàngnǝ gara mwashat.
\v 4 Tsǝk agara mǝnia ka aɓa Tara Ban Peri, aɓadǝm Akwati mala Acau-nakûn, ban mǝnana ǝn nggǝ je sǝnǝ we kam ngga.
\v 5 Sǝ gara mala ɓwa mǝnana ǝn twal ka nǝ̀ tò-mbuí. Anggo sǝ mǝ nǝ tamsǝ nggwani mala amǝ Isǝrayila mǝnana à kǝ̀ yinǝi tùtù amuro ka.>>
\p 
\v 6 Nda Musa nacau nǝ amǝ Isǝrayila ka; sǝ koyan atà amúrû malea pe wi gara, mwashat ace koya múrû mala koya ɓala-kàu, agara lum-nong-ɓari, sǝ gara mala Haruna ka nda aɓalǝ amalea.
\v 7 Musa pǝlǝa tsǝk agara mǝnia ka, aɓadǝm Yahweh, aɓa Tara mala Acau-nakûn.
\p 
\v 8 Lang ban fana ka, Musa kúti aɓa Tara mala Acau-nakûn, kara sǝni ka, gara mala Haruna, mana nda ace tàu mala Lawi ka, tongŋǝna sǝ pusǝna mbuí arǝì, sàngŋǝ̀nà pwasǝe, sǝ pusǝna aɓǝla-almon mǝnana à bangŋǝ́nà ka.
\v 9 Musa pǝlǝa pusǝ agara mǝno a ɓadǝm Yahweh, yinǝia aban amǝ Isǝrayila kat. Pǝlǝa à sǝnggi agare kat, sǝ koya múrû ka twal gara male.
\p 
\v 10 Sǝ Yahweh banggi Musa ama, <<Nyesǝ gara mala Haruna tsǝì aɓadǝm Akwati mala Acau-nakûn,\f + \fr 17:10 \ft Ɓalli gbal aɓa: \xt Ib 9:4\xt*\ft .\f* ace mǝnana ɓǝ̀ duk gir'lǝmdǝa aban amǝ'mgbicau. Mǝnia ka nǝ̀ tamsǝ nggwani malea arǝàm, ɓǝ̀ ana raka à nǝ̀ wukio.>>\f + \fr 17:10 \ft Ɓalli gbal aɓa: \xt Pur 28:35; 30:20-21; Pǝris 8:35; 10:6,9; 15:31; 16:2,13; Ɓal 4:19; 18:3,32\xt*\ft .\f*
\v 11 Anggo sǝ Musa pa, kǝla mǝnana Yahweh pe wi nzongcau ama ɓǝ̀ pàk ka.
\p 
\v 12 Sǝ amǝ Isǝrayila banggi Musa ama, <<Sǝni, ma'sǝm malǝna! Sǝm wukina! Sǝm kiɗikina!
\v 13 Koyan mǝnana sung tù, mǝnana gbàshì ban Taragula mala Yahweh ka, nǝ̀ wǔ. Sǝm kat ka, sǝm nǝ̀ wuki le?>>
\c 18
\s1 Atúró mala Apǝris andǝ Amǝ'Lawi
\p 
\v 1 Yahweh banggi Haruna ama, <<We, wunǝ amuna-burana mô andǝ ɓala-kàu mò atò ka wun nda à nǝ̀ tsǝka wun cau arǝ wun mala koya gìr mǝɓane mǝnana kum agir mǝnana à nda aɓa Tara-mǝfele ka. Sǝ we wunǝ amuna-burana mô atò ka, wun nda à nǝ̀ tsǝka wun cau arǝ wun ɓǝ̀ apǝris ɗwanyi kpata nggurcau mala túró pǝris ma'wun ngga.
\v 2 Ɗǝm ngga, amǝ'eambo a tàu mala Lawi, yì tàu mala akeô ka, awu nǝ yinǝia ace mǝnana ɓǝà pàkkô gbasha; sǝ we wunǝ amuna-burana mô mana atò ka, wun nǝ̀ pa aɓadǝm Tara mala Acau-nakûn.\f + \fr 18:2 \ft Ɓalli aɓa: \xt Ɓal 8:5-26\xt*\ft .\f*
\v 3 Yia ka, à nǝ̀ kpata cau mò andǝ bwal túró mǝnana à nǝ̀ nggǝ pa aɓa Taragula kat ka. Sǝama, dumǝna púp, à pà nǝ̀ yiu tù aban agirtúró mala Ban-mǝfele ko gyangŋan ɗàng, ɓǝ̀ ana raka à nǝ̀ wǔ, sǝ awu nǝ wǔ.
\v 4 Yia ka, dumǝna púp à nǝ̀ kpapibu nǝ we ace tsǝkir Tara Ban-peri andǝ pakki atúró mala Tara Ban-peri kat. Ɓwa-ɗàng pà nǝ̀ gbàshìban wun ɗàng.
\p 
\v 5 <<Wun nda wu nǝ̀ nggǝ pakki atúró mala Tara-mǝfele andǝ atúró mala gyangŋan ngga, ace mǝnana bumlulla mala Yahweh ɓǝkǝa sulǝo amur amǝ Isǝrayila ɗǝm raka.\f + \fr 18:5 \ft Ɓalli aɓa: \xt Ɓal 1:53; 16; 17:12-13\xt*\ft .\f*
\v 6 Sǝni, Mim nǝ ɓamúràm ngga, ǝn tarna amǝ'eambo Amǝ'Lawi, aɓalǝ amǝ Isǝrayila. À nda ka ɓoro a bano, mana à pànî Yahweh, ace pàk túró mala Tara Ban-peri ka.
\v 7 Sǝama, we wunǝ amuna-burana mô ka, wun nǝ̀ pàk túró-dopǝris ma'wun ace koman kat mala gyangŋan andǝ gìr mǝnana à nǝ̀ pe aɓa Ban Nggea Mǝfele ka. Wun nǝ̀ pàk túró-pǝris. Mǝ ndaban pa wun túró-dopǝris kǝla ɓoro ace túrô. Sǝ ɓwa-ɗàng mǝnana yiu tù aban Tara-mǝfele ka, dumǝna púp à nǝ̀ wal-lui.>>
\s1 Pàgir ace Apǝris andǝ Amǝ'Lawi
\p 
\v 8 Pǝlǝa Yahweh banggi Haruna ama, <<Sǝni, Mim nǝ ɓamúràm, ǝn tsǝ́ngŋǝ̀nó amur apagir mana à yinǝia abanam ngga, yì aɓoro mǝfele mana kat amǝ Isǝrayila pa abanam ngga. We wunǝ amuna-burana mô andǝ amǝ'keo ka wun nǝ̀ kum kāmbe mana à pusǝì aɓalǝ aɓoro mǝfele mǝnia ka; dumǝna nê mana à nǝ̀ kpate ka tàtǝ́k.
\v 9 Kāmbe aɓalǝ apagir nggea mǝfele mana à pisǝia kǝring raka, komǝye atà apagir malea mǝnana à pà abanam, koya pàgir mala mǝsǝsa, andǝ koya pàgir mala gǝshi cauɓikea, andǝ koya pàgir mala kumcau, mǝnana à nǝ̀ pà abanam ngga, à nǝ̀ duk nggea mǝfele aceo sǝ ace amunio andǝ amǝ'keò.
\v 10 Wun nǝ̀ lì a ban nggea mǝfele. Koya muna-ɓwabura ka nǝ̀ gandǝ li. Nǝ̀ duk gìr mǝfele aban wun.
\p 
\v 11 <<Mǝnia gbal ka, mona: kāmbe mǝnana à twal aɓa pàgir mala aɓoro malea, yì apagir mǝnana kat amǝ Isǝrayila pà abanam nǝ loasǝe a kuli ka. Ən pano wia, we wunǝ amuna-burana andǝ amuna-mamǝna mô atò. Dumǝna nê mana à nǝ̀ kpate ka tàtǝ́k. Koya ɓwa mǝnana nda aɓa ɓoarnsari a ɓala mò ka, nǝ̀ gandǝ li.
\p 
\v 12 <<Mùrú olif kat nggea-mǝɓoarne mǝnana à tita kàmbe, andǝ mùr-anap kat nggea-mǝɓoarne mǝnana à tita kàmbe, andǝ mǝsǝsa nggea-mǝɓoarne mǝnana à tita pwane, yì aɓǝlagir mǝdǝmbe malea mǝnana à kǝ yinǝia ace pè abanam Mim Yahweh ka, ǝn pano wia.
\v 13 Aɓǝlagir mǝdǝmbe mala koman kat, mǝnana nda aɓa nzali malea, mǝnana à kǝ yinǝia aban Yahweh ka, amona. Koya ɓwa mǝnana nda aɓa ɓoarnsari a ɓala mò ka, nǝ̀ gandǝ li.
\p 
\v 14 <<Koya gìr a Isǝrayila, mana à tàrni acem Yahweh ka, dumǝna mona.
\v 15 Koya muna-dǝmba mala agir mǝnana nǝyilǝmu, mana tita puro a bum ngge, ko ɓwapǝndǝa ko girkusǝu na, mana à kǝ panagir nǝi abanam Yahweh ka, mona. Sǝama, dumǝna púp, aɓwana nǝ̀ akmúr muna-dǝmba mala ɓwapǝndǝa,\f + \fr 18:15 \ft Ɓalli aɓa: \xt Pur 13:11-16\xt*\ft .\f* sǝ à nǝ̀ akmúr muna-dǝmba mala girkusǝu mǝɓeami.
\v 16 Akmúria lang à lùmsǝ̀nà zongŋo mwashat anzǝm ɓǝlia ka. Boalo akmúria ka shekel tongno mala mǝsǝbolo-azǝrfa na. Kpata shekel mǝnana à kārǝ́ dǝmbǝrya male sǝ à earna amurí a Tara-mǝfele (mǝnana shekel mwashat ka mǝtyang lum-nong-ɓari na ka).
\p 
\v 17 <<Sǝama muna-dǝmba mala ndǎ, ko muna-dǝmba mala nzur, ko muna-dǝmba mala mbulpǝndǝa ka, à pà nǝ̀ akmúria ɗàng; amǝfele na. Awu nǝ watsǝki nkilea amur gyangŋan, sǝ awu nǝ pisǝ mùrú-nyama malea kǝla pàgir nǝ bǝsa mǝnana kǝ pa rǝmban mǝɓoarne mana kǝ pwasǝbumam Yahweh ka.
\v 18 Nyam agirkusǝu mǝnia ka, dumǝna mona, kǝla mana nyam kikil girkusǝu andǝ byali mǝlì mana à pàgir nǝi nǝ loasǝe a kuli ka, amona ka.
\v 19 Apagir mǝfele mana amǝ Isǝrayila kǝ yinǝia ace pè Yahweh ka, ǝn pano, we wunǝ amuna-burana andǝ amuna-mamǝna mô atò, kǝla nê mana à nǝ̀ kpate ka tàtǝ́k. Mǝnia ka dumǝna kùrcau mala tuɓamur,\f + \fr 18:19 \fq kùrcau mala tuɓamur \ft ko <<pacau mǝnana nggaɗe pà kàm raka>>\f* mana pà nǝ̀ mal raka, aɓadǝm Yahweh, aceo andǝ amǝ'keò atò.>>
\p 
\v 20 Pǝlǝa Yahweh banggi Haruna ama, <<Wun apǝris ka pà wu nǝ̀ kum kǝ nzali ace liɓala atà amǝ Isǝrayila ɗàng, sǝ pà wu nǝ̀ kum kǝ kāmbe ama ma'wun na ateà ɗàng. Mǝ nda kāmbe mana wun nǝ̀ kum ngga andǝ gìr liɓala ma'wun aɓalǝ amǝ Isǝrayila.
\p 
\v 21 <<Sǝni, ǝn panì Amǝ'Lawi banì-mwashat-aɓa-lum mala agirkuma kat a Isǝrayila\f + \fr 18:21 \ft Ɓalli aɓa: \xt Nggur 26:12; 2Kpa 31:12; Nehe 10:37-38; Ib 7:5\xt*\ft .\f* ɓǝ̀ duk gìr liɓala malea, a kúnì túró mǝnana à kǝ pak ka, yì túró mala Tara Ban-peri.
\v 22 Amǝ Isǝrayila pà nǝ̀ gbàshìban Tara Ban-peri ɗǝm ɗàng, ɓǝ̀ ana raka à nǝ̀ twal cauɓikea amúrià, sǝ à nǝ̀ wǔ.
\v 23 Amǝ'Lawi na mǝnana à earia wia ɓǝà pak túró mala Tara Ban-peri ka, sǝ à nǝ̀ twal bafe mala cauɓikea malea amúrià. Mǝnia ka nggurcau na mǝnana nggaɗe pà kàm raka arǝ anza ma'wun kat. Amǝ'Lawi pànǝ kǝ nzali ace liɓala atà amǝ Isǝrayila ɗàng;\f + \fr 18:23 \ft Ɓalli aɓa: \xt Nggur 10:8-9; 18:1-2; Jes 13:14,33\xt*\ft .\f*
\v 24 Pàgir mala banì-mwashat-aɓa-lum mǝnana amǝ Isǝrayila kǝ yinǝi ace pàgir aban Yahweh ka, ǝn pania wia ɓǝ̀ duk gìr liɓala malea. Acemani ka, ǝn banggia wia nǝma à pànǝ kǝ nzali ace liɓala atà amǝ Isǝrayila ɗàng.>>
\p 
\v 25 Pǝlǝa Yahweh banggi Musa ama,
\v 26 <<Nacau nǝ Amǝ'Lawi sǝ wu banggia wia ama: <Lang wu angŋa banì-mwashat-aɓa-lum mala agirkuma a bu amǝ Isǝrayila, mana ǝn pana wuni ɓǝ̀ duk gir liɓala ma'wun ngga, dumǝna púp wun nǝ̀ pusǝ banì-mwashat-aɓa-lum male, wun nǝ̀ panagir nǝi aban Yahweh; mǝnia ka nda banì-mwashat-aɓa-lum mala banì-mwashat-aɓa-lum.
\v 27 Mǝnia yì pàgir ma'wun ngga Yahweh nǝ̀ ɗenyinǝi kǝla weama pàgir na mǝnana puro arǝ aɓaban ma'wun, mala bǝsa mǝsǝsa mǝnana à nyé a katǝra, andǝ mala mùr-anap mana à kambi arǝ ɓǝle mǝbangŋe ka, sǝ nǝ̀ ɓwangsǝ wun aceì.
\v 28 Acemani ka, dumǝna púp wun nǝ̀ yinǝ pàgir gbal aban Yahweh. Aɓa koya banì-mwashat-aɓa-lum mǝnana wu ak a bu amǝ Isǝrayila ka, wun nǝ̀ pusǝ kāmbe mǝnana nda ace pàgir aban Yahweh ka, wun nǝ̀ pè Haruna, yì pǝris.
\v 29 Aɓa koya ɓoro mǝnana aɓwe pà wun ngga, dumǝna púp wun nǝ̀ pusǝ kāmbe mǝnana nda acem Yahweh ka; kāmbe nggea-mǝɓoarne mala komǝye ka, nda wun nǝ̀ tàrì acem Yahweh ka.>
\p 
\v 30 <<Banggi Amǝ'Lawi ama, <Lang wu pana kāmbe nggea-mǝɓoarne mala banì-mwashat-aɓa-lum ngga, à nǝ̀ ɓwangsǝ wun, wun Amǝ'Lawi aceì, kǝla weama wu pusǝ aɓǝlagirì a katǝra andǝ ban-kam-anap.
\v 31 Sǝ wun Amǝ'Lawi, andǝ amǝ'ɓala ma'wun ngga, wun nǝ̀ gandǝ li girline a koya ban mǝnana wu earce ka. Mǝnia ka, nda tangnakusǝ wun ace túró mana wu kǝ pa aɓa Tara Ban-peri ka.
\v 32 À pà nǝ̀ na ama, wu pàngŋǝ̀nà gìr mǝɓane nǝ twal banì-mwashat-aɓa-lum mala Yahweh ɗàng,\f + \fr 18:32 \ft Ɓalli aɓa: \xt Pǝris 19:8; 22:16\xt*\ft .\f* ɓǝ̀ wu pànî apǝris kāmbe nggea-mǝɓoarne malea ka. Sǝama, wu tsǝkir wun, wu kǝa nyesǝ apagir mǝfele mala amǝ Isǝrayila, kǝla gìr mǝkyauwe ɗàng. Ɓǝ̀ wu pàk anggo ka, wun nǝ̀ wǔ.> >>\f + \fr 18:32 \ft Ɓalli gbal aɓa: \xt Pǝris 22:2,15\xt*\ft .\f*
\c 19
\s1 Anggurcau mala lakban arǝ je lú
\p 
\v 1 Yahweh nacau nǝ Musa andǝ Haruna ama,
\v 2 <<Mǝnia ka nda nê mala nggurcau mǝnana Yahweh tsǝk ka: Banggi amǝ Isǝrayila ɓǝà yinǝo nǝ muna-ndá mǝbangŋe, mǝnana pànǝ ɓekǝ doak arǝì ɗàng, pànǝ ɓekǝ gìr mǝɓane arǝì ɗàng, sǝ à malaká tsǝki wi nggun-rya a myali a kǝ fara raka.
\v 3 Awu nǝ pè Eleaza, pǝris; sǝ yì ka nǝ̀ kánǝi anzǝm kàttì, sǝ à nǝ̀ pwanmeali a ɓadǝmbi.
\v 4 Pǝlǝa Eleaza pǝris nǝ̀ ɗàrǝ́ aɓa nkile nǝ munabui, sǝ nǝ̀ watsǝki kusǝ tongno-nong-ɓari, nǝ njar ɓadǝm Tara Ban-peri.
\v 5 Pǝlǝa à nǝ̀ pisǝ muna-ndá man a mǝsǝi; ngguí, andǝ nyami, andǝ nkile andǝ ciute ka, à nǝ̀ pisǝia a bǝsa.
\v 6 Sǝ pǝris ka, nǝ̀ twal nggun-seda andǝ bondo-hisop andǝ bugir mǝbangŋe, sǝ nǝ̀ túriá aɓa bǝsa mǝnana muna-ndá kǝ pi aɓalǝi ka.
\v 7 Pǝlǝa pǝris ka, dumǝna púp nǝ̀ lakki agir'nggūrǝì, sǝ nǝ̀ sussǝo; anzǝm mǝno ka, nǝ̀ gandǝ kutio a kàttì, sǝ kat andǝ amani ka, nǝ̀ ueo aɓa do-ɓeami ba pwarikpǝra.
\v 8 Sǝ ɓwa mana pisǝ mǝno yì muna-ndá ka, dumǝna púp yì gbal ka nǝ̀ lakki agir'nggūrǝì, sǝ nǝ̀ sussǝo; sǝ kat andǝ amani ka nǝ̀ ueo aɓa do-ɓeami ba pwarikpǝra.
\p 
\v 9 <<Ɓwa mǝnana mǝɓoarnsari na ka, nǝ̀ ram tú muna-ndá mǝnia ka, sǝ nǝ̀ soe a ban mǝɓoarnsari anzǝm kàttì. Nǝ̀ duk gir mǝnana ɓwabundǝa mala amǝ Isǝrayila nǝ̀ tsǝkce ka, ace mǝnana à nǝ̀ zurì a mùr ace lak ɓwa mǝnana kpa aɓa ɓeami ka. Pàgir na ace lak cauɓikea.\f + \fr 19:9 \ft Ɓalli aɓa: \xt Pǝris 4\xt*\ft .\f*
\v 10 Sǝ ɓwa mǝnana ram tú muna-ndá ka, dumǝna púp nǝ̀ lakki agir'nggūrǝì, sǝ kat andǝ amani ka nǝ̀ ueo aɓa do-ɓeami ba pwarikpǝra. Mǝnia ka, nǝ̀ duk nggurcau mǝnana málá male pà kàm raka aban amǝ Isǝrayila, sǝ aban amǝ'kúnɗàngna mana à do aɓalǝia ka.
\p 
\v 11 <<Ɓwa mǝnana je lú ɓwapǝndǝa ka, nǝ̀ duk mǝɓeami ba nongŋo tongno-nong-ɓari.
\v 12 Yì ka, dumǝni wi púp nǝ̀ lak ɓamurì arǝ do-ɓeami male nǝ mùr a tàruia pwari andǝ tongno-nong-ɓaria pwari, sǝ nǝ̀ ɓoarnsari; sǝ ɓǝ̀ lak ɓamurì a tàruia pwari andǝ tongno-nong-ɓaria pwari raka, pà nǝ̀ ɓoarnsari ɗang.
\v 13 Ɓwa mǝnana kat je rǝ ɓwa mǝnana wuna, sǝ lak rǝì raka, nǝ̀ tsǝk Taragula mala Yahweh nǝ̀ pǝndǝkya; sǝ mǝno yì ɓwa ka à nǝ̀ kasǝì a Isǝrayila. Yì ka, nǝ̀ ueo aɓa do-ɓeami acemǝnana à watsǝki wi mùr lakban amurí ɗàng. Do-ɓeami male ka nda arǝì piu.
\p 
\v 14 <<Mǝnia ka nda nggurcau mana à nǝ̀ kpate ɓǝ̀ ɓwa wǔ aɓa gumli ka: ɓwa mǝnana kat kúti aɓa gumli mǝnia andǝ koyan mǝnana kat nda aɓa gumli mǝnia ka, nǝ̀ pa aɓa do-ɓeami mala anongŋo tongno-nong-ɓari.
\v 15 Sǝ koya kwár aɓa gumli mǝnia, mǝnana nda atarǝì, à kumsǝi wi gìrkúni raka, dumǝna mǝɓeami.
\p 
\v 16 <<Sǝ ɓwa mana kat, nda a ɓawanban, sǝ je rǝ ɓwa mana à wal-luí nǝ nggeabyau, ko mǝnana wǔ atarǝì ka, ko je mǔ ɓwapǝndǝa, ko ɓembe ka, nǝ̀ pà aɓa do-ɓeami mala anongŋo tongno-nong-ɓari.
\p 
\v 17 <<Ace lak ɓwa mǝnana mǝɓeami na ka, à nǝ̀ ɗàrǝ́ aɓa tú mala pàgir ace gǝshi cauɓikea, mǝnana à pisǝì kǝring ngga, à nǝ̀ soé a dù, sǝ à nǝ̀ soapi wi mùr mana kǝ ɓang ngga amurí.
\v 18 Ɓwa mǝnana mǝɓoarnsari na ka, nǝ̀ twal bondo-hisop, nǝ̀ oasǝi a mùrî, sǝ nǝ̀ watsǝki arǝ gumli mǝnia ɓwa wù kam ngga, sǝ arǝ agir mǝnana aɓalǝi ka, andǝ aɓwana mǝnana à ndakam ngga. Yì ɗǝm ngga, nǝ̀ watsǝki arǝ ɓwa mǝnana kat je mǔ ɓwapǝndǝa, ko ɓembe, ko je rǝ ɓwa mana wǔ atarǝì, ko ɓwa mana à wal-luí ka.
\p 
\v 19 <<Sǝ ɓwa mǝnana mǝɓoarnsari na ka, nǝ̀ watsǝki ɓwa mana mǝɓeami na ka a tàruia pwari andǝ tongno-nong-ɓaria pwari; sǝ a tongno-nong-ɓaria pwari ka nǝ̀ lé arǝ do-ɓeami male. Sǝ ɓwa mǝnana à kǝ lé ka, dumǝna púp nǝ̀ lakki agir'nggūrǝì, sǝ nǝ̀ sussǝo, sǝ nǝ pwarikpǝra ka, nǝ̀ duk mǝɓoarnsari.
\v 20 Sǝama ɓǝ̀ ɓwa ka duk mǝɓeami, sǝ ɓinǝ lak rǝì arǝ do-ɓeami male ka, mǝno yì ɓwa ka à pà nǝ̀ eari wi ɓǝ̀ do aɓa ɓwabundǝa mala Isǝrayila ɗàng, acemǝnana pǝndǝkina Ban-mǝfele mala Yahweh.\f + \fr 19:20 \ft Ɓalli gbal aɓa: \xt 1Kor 6:19-20\xt*\ft .\f* Acemǝnana à watsǝki wi mùr lakban arǝ do-ɓeami amurí raka, mǝɓeami na.
\v 21 Mǝnia ka, nǝ̀ duk nggurcau mǝnana málá male pà kàm raka acea. Sǝ ɓwa mǝnana watsǝkiyi mùr lakban ngga, dumǝna púp, yi gbal ka, nǝ̀ lakki agir'nggūrǝì, sǝ ɓwa mǝnana kat je mǝnia yì mùr lakban arǝ do-ɓeami ka, nǝ̀ ueo aɓa do-ɓeami ba pwarikpǝra.
\v 22 Gìr mǝnana kat ɓwa mǝɓeami je ka, gìrnî nǝ̀ duk mǝɓeami; sǝ ɓwa mǝnana kat je gìrnî ka, nǝ̀ duk mǝɓeami ba pwarikpǝra.>>
\c 20
\s1 Mùr ɓùn aɓa tali
\p 
\v 1 Sǝ ɓwabundǝa mala amǝ Isǝrayila puppup yiu aɓa pǝɗanban Zin, a zongŋo mǝdǝmbe. Aɓwe yi tsǝk là-gumli a Kadesh. Miriyam paklú kano, sǝ à tsǝkluí kano.
\p 
\v 2 A ban mǝno ka mùr pà kàm ace ɓwabundǝa ɗàng; pǝlǝa à ram rǝia sǝ à mgbicau arǝ Musa, sǝ arǝ Haruna.
\v 3 Kún aɓwe ɓua arǝ Musa ama, <<Ɓǝ̀ sǝm wukina atà amǝ'eam sǝm a pwari mǝno à wuki a ɓadǝm Yahweh ka, ɓǝ́ nǝ̀ ɓoaribani!
\v 4 Palang sǝ a yinǝ ɓwabundǝa mala Yahweh a ɓabondo man? A yinǝ sǝm ace mǝnana sǝm, sǝnǝ agirkusǝu ma'sǝm ngga, ɓǝ̀ sǝm yi wuki kani ka le?
\v 5 Palang sǝ a pusǝ sǝm, sǝm purî nzali Masar? A pusǝ sǝm ace yinǝ sǝm a ban mǝɓike mǝnia ka le? Ban mǝnana kǝ mǝsǝsa, ko nggun-bwari, ko nggun-anap, ko nggun-mɓǝring pà kàm ɗàng, sǝ kǝ mùr pà kàm mana sǝm nǝ̀ nu ka raka!>>
\p 
\v 6 Pǝlǝa Musa andǝ Haruna, nying ɓadǝm ɓwabundǝa, à yiu a bankutio aɓa Tara Ban-peri, sǝ à kpa, nǝ ɓamǝsǝia a nzali. Kara ɓoarɓwa mala Yahweh pusǝrǝi abania.
\v 7 Yahweh banggi Musa ama,
\v 8 <<Twal garè\f + \fr 20:8 \fq garè \ft ko <<gara mala mǝ'eambo Haruna.>>\f* a buo, sǝ we wunǝ mǝ'eambo Haruna ka, wu ram ɓwabundǝa, sǝ wu ne tali mǝno cau a mǝsǝia, ɓǝ̀ pusǝ mùr male ɓǝ̀ solǝo. Anggo sǝ awu nǝ pusǝia wia mùr nǝ ɓá talinì, sǝ awu nǝ pè ɓwabundǝa andǝ agirkusǝu malea mùr ɓǝà nǔ.>>
\p 
\v 9 Anggo, sǝ Musa twal garè a ɓadǝm Yahweh, kǝla mana banggi wi ka.
\v 10 Yì andǝ Haruna ka à ram ɓwabundǝa a banɓwáná a ɓadǝm talinì, sǝ Musa banggia wia ama, <<Wu kwaki kir wun ado, wun amǝ'mgbicau! Dumǝna púp ama sǝm nǝ̀ pusǝa wun mùr aɓa tali mǝnia ka le?>>
\v 11 Pǝlǝa Musa loasǝ bui, wal talinì nǝ gara male kusǝ ɓari. Kara mùr pur aɓalǝi kpǝm, sǝ ɓwabundǝa andǝ agirkusǝu malea nǔ.
\p 
\v 12 Sǝama, Yahweh banggi Musa andǝ Haruna ama, <<Acemǝnana wu earnǝ mim, mǝnana wun nǝ̀ pam gulo kǝla mǝfele aɓadǝm amǝ Isǝrayila raka, pà wu nǝ̀ kánǝ ɓwabundǝa mǝnia a nzali mǝnana ǝn pania wia ka ɗàng.>>
\v 13 Mùr mǝno ka à tunǝi ama mùr mala Meriba,\f + \fr 20:13 \fq Meriba \ft ka ɓalǝi nda <<kúnɓuana.>>\f* acemǝnana nda ban mǝnana kún amǝ Isǝrayila ɓua arǝ Yahweh kam ngga, sǝ yì ka lǝmdǝ ɓamurì mǝfele na aɓalǝia.
\s1 Edom ginǝ nyinggi Isǝrayila njar ɓǝ̀ kutio
\p 
\v 14 Pǝlǝa Musa tasǝ amǝ'na-túrbân, à lo a Kadesh aban ká aban murǝm Edom nǝ cau ama: <<Mǝnia ka, nda cau mǝnana mǝ'eambo Isǝrayila kǝ bang ngga: A súrǝ́nà rǝ gir mana kat kum sǝm, yì tanni mǝnana yiu amur sǝm,
\v 15 lang aká sǝm sulǝo, à wari a nzali Masar, sǝ sǝm duk kano arǝ apǝlǝa pas, sǝ amǝ Masar pakka sǝm mǝɓike, sǝm sǝnǝ atár sǝm andǝ aká sǝm ngga.
\v 16 Sǝama, lang sǝm yinǝ ɓua ma'sǝm aban Yahweh ka, yi ka, ok gì sǝm, pǝlǝa tasǝ mǝturonjar, mana yi pusǝ sǝm aɓa nzali Masar ka. Adyan ngga, sǝm ndya a Kadesh, yì là mǝnana a nzong-nzali mô ka.
\v 17 Ida, ɗeki sǝm, ɓǝ̀ sǝm kùtí nǝɓa nzali mô. Pà sǝm nǝ̀ kùtí a ɓaban-mǝssa ko ɓaban-anap ɗàng; yale pà sǝm nǝ̀ nu mùr a kǝ tūli-mùr ɗàng. Sǝm nǝ̀ ging cat amur njar-mǝgule mala murǝm, aban o; pà sǝm nǝ̀ kyang a bu-mǝli ko bu-mǝnggare ɗàng, sheɓǝ̀ sǝm kya kutina, sǝm purni bu-nzali mô ka.>>
\p 
\v 18 Sǝama, Edom pe wi eare ama, <<Pà wun nǝ̀ kùtí aɓa nzali man ɗang, sǝ ɓǝ̀ wu ɓinǝ ama wun nǝ̀ kùtí kani ka, mǝ nǝ kánǝ amǝ'lwa mem arǝ wun.>>
\p 
\v 19 Amǝ Isǝrayila eari wi ama, <<Sǝm ngga, sǝm nǝ̀ o cat amur njargula-mǝgule, sǝ ɓǝ̀ sǝm, ko agirkusǝu ma'sǝm nu mùr ma'wun ngga, sǝm nǝ̀ mbwe boale. Eara sǝm, kutio na nǝmurǝì sǝm nǝ̀ kùtí ka, nǝ kusǝ sǝm; pà sǝm nǝ̀ pak ɓekǝ gir mana nda ɗàng ngga ɗàng, ko bǝti.>>
\p 
\v 20 Murǝm Edom nyesǝ cau ama, <<Pà wun nǝ̀ kùtí kani ɗang.>> Pǝlǝa pur nǝ akanggǝrang amǝ'lwa pas nǝ agirbura mǝcandǝe a buia, ace kánǝ munǝo arǝ amǝ Isǝrayila.
\v 21 Anggo sǝ Edom ɓinǝ nyinggi Isǝrayila njar ɓǝ̀ kùtí nǝɓa bu-nzali male; nda Isǝrayila wulimúrí, nying kutio nǝɓa nzalinì ka.
\s1 Lú mala Haruna
\p 
\v 22 Pǝlǝa ɓwabundǝa mala amǝ Isǝrayila puppup loapi Kadesh sǝ à twal gya, à yiu a Nkono Hor.
\v 23 Yahweh nacau nǝ Musa andǝ Haruna a Nkono Hor, a nzong-nzali Edom, ama,
\v 24 <<Haruna ka ndo nǝ̀ o atà aɓwana male. Pà nǝ̀ kùtí a nzali mana ǝn nggǝ pè amǝ Isǝrayila ka ɗàng, acemǝnana wun kǝm ngga, wu okam ɗàng, wu kpata zongcau mem a ban mur Meriba ɗàng.
\v 25 Twal Haruna andǝ muna-ɓwabura male, Eleaza, wu eau wunǝia, amur Nkono Hor.
\v 26 Akano ka swárì Haruna adaura-pǝris male, sǝ wu oasǝia arǝ muna-ɓwabura male, Eleaza. Haruna ka nǝ̀ o atà aɓwana male; nǝ̀ nggá wǔ kano.>>
\p 
\v 27 Nda Musa pa, kǝla mǝnana Yahweh banggi wi ka. À eauwe amur Nkono Hor, a mǝsǝ ɓwabundǝa kat.
\v 28 Musa pǝlǝa swárì Haruna adaura-pǝris male, sǝ oasǝì Eleaza, muna-ɓwabura male. Sǝ Haruna paklú kano a ɓong nkono. Pǝlǝa Musa andǝ Eleaza sulǝî mur nkono.
\v 29 Lang ɓwabundǝa sǝni ama Haruna wuna ka, ɓala mala Isǝrayila kat, pak anonggio lumi-tàrú aban ɓua-luí.
\c 21
\s1 À gandǝ murǝm Arat a lwa
\p 
\v 1 Lang ɓwa Kan'ana, murǝm Arat, mana ndanǝdo a Negev, ok ama, amǝ Isǝrayila na aban yiu nǝ njargula Atarim ngga, kara yinǝ munǝo arǝia, bwalki aɓea ɓwana atà amǝ Isǝrayila.
\v 2 Pǝlǝa amǝ Isǝrayila pàcau nǝ-shambum aban Yahweh, ama, <<Ɓǝ̀ mbak-kàngkàng awu nǝ tsǝk aɓwana mǝnia ɓǝà kpa aɓa bù sǝm ngga, sǝm nǝ̀ tària aban Yahweh ace twalta alá malea kat-kat.>>
\p 
\v 3 Yahweh ok zǝmba mala amǝ Isǝrayila, pǝlǝa pà amǝ'Kan'ana aɓata rǝcandǝa malea, sǝ à twaltea kat, à kiɗiki alá malea. À tunǝ lullǝ banì ama, Horma.\f + \fr 21:3 \fq Horma \ft ka ɓalǝi nda <<mǝnana à kiɗiki ka.>>\f*
\s1 N'yau mana à pè nǝ bolo-bángŋá ka
\p 
\v 4 Pǝlǝa à lo gya, twal a Nkono Hor, nǝ njargula mala Nggeamùr Nzuno, à kàrìban arǝ nzong-nzali mala amǝ'Edom. Sǝama, aɓwe gandǝ twalgàndǝá nǝ gyê ɗàng.
\v 5 À na mǝɓane arǝ Ɓakuli andǝ Musa, ama, <<Palang sǝ a pusǝ sǝm a nzali Masar, ace mǝnana ɓǝ̀ sǝm yi wukio a ɓabondo ka? Girlina pa kàm ɗàng! Mùr pà kàm ɗàng! Sǝ sǝm aulǝna nǝ girlina mǝɓike man!>>
\p 
\v 6 Pǝlǝa Yahweh tasǝ an'yau barya aɓalǝ aɓwe; an'yau kwarkia, gandǝa pas atà amǝ Isǝrayila wukio.
\v 7 Nda aɓwe yiu aban Musa, sǝ à bang ama, <<Sǝm pangŋa cauɓikea, mǝnana sǝm na mǝɓane amur Yahweh, sǝ sǝm na mǝɓane amuro ka. Pàk hiwi aban Yahweh ama ɓǝ̀ pǝr an'yau mǝnia ka, ɓǝà upiban sǝm.>> Anggo, sǝ Musa pàk hiwi ace aɓwe.
\p 
\v 8 Yahweh pǝlǝa banggi Musa, ama, <<Pàk ɓǝ̀nzál mala n'yau barya, sǝ wu loasǝi a kuli, amur tondong. Ɓwa mǝnana kat n'yau kwarí, sǝ loasǝ mǝsǝi, sǝni ka, nǝ̀ auwa.>>\f + \fr 21:8 \ft Ɓalli gbal aɓa: \xt 2Amur 18:4; Yoh 3:14-15\xt*\ft .\f*
\v 9 Anggo sǝ Musa pàk n'yau nǝ bolo-bángŋá, pǝlǝa tsǝì amur tondong, sǝ loasǝi tamsǝi. Ɓǝ̀ n'yau kwarna kǝɓwa, sǝ lang loasǝ mǝsǝi sǝn n'yau mala bolo-bángŋá man ngga, ɓwê nǝ̀ auwa.
\s1 Gya mala amǝ Isǝrayila aban ká a Mowap
\p 
\v 10 Amǝ Isǝrayila lo gya à yi tsǝk kàttì a Obot.
\v 11 À loapi Obot ka, à kya tsǝk kàttì a Iye-abarim, a ɓabondo mana kǝ sǝn ɓamǝsǝarǝia andǝ Mowap, nǝ njartakuli ka.
\v 12 À loapi ban mǝno ka, à yi tsǝk kàttì a Ɓangŋaban Zeret.
\v 13 À loapi ban mǝno ka, à lo gya à kya tsǝk kàttì a ɓè nkaring mala Nggeasala Arnon, mana nda a ɓabondo mǝnana pur nǝ nzong-nzali mala amǝ'Amor ka. Nggeasala Arnon ngga nda a nzong-nzali mala Mowap, a nre Mowap andǝ nzali Amor.
\v 14 Nda gìr mǝnana tsǝa sǝ Malǝmce mala A'lwa mala Yahweh, bang ama,
\q1 <<Wahep aɓa Sufa, andǝ amuna-mùr mala Nggeasala Arnon,
\q1 
\v 15 andǝ bum aɓangŋaban mǝnana sárǝ́ aban ká a là Ar,
\q1 sǝ eangnǝ arǝ nzong-nzali Mowap ka.>>
\p 
\v 16 Twal a ban mǝno ka, à lidǝmba, aban ká Biya,\f + \fr 21:16 \fq Biya \ft ka ɓalǝi nda <<tūli-mùr.>>\f* yì tūli-mùr mǝnana Yahweh banggi Musa cau amurí, ama, <<Ramba aɓwana abanɓwáná, ace mǝnana ɓǝn pea wia mùr ka.>>
\p 
\v 17 Pǝlǝa amǝ Isǝrayila tù mǝnia yì nggyal ka, ama:
\q1 <<Tù mùr, we tūli-mùr!
\q1 Tùkî wi nggyal,
\q2 
\v 18 yì tūli-mùr mǝnana amǝgulo tǝmi ka;
\q2 mǝnana aɓwana-mǝgule mala aɓwana busǝlǝi
\q2 nǝ gara-gulo andǝ agara-gya malea ka.>>
\p Pǝlǝa à nying ɓabondo mǝno à o a Matana.
\v 19 À nying Matana ka, à o a Nahaliyel. À nying Nahaliyel ka, à o a Bamot.
\v 20 À nying Bamot ka, à o a ɓangŋaban mǝnana nda aɓa nzali Mowap, tù a ban amgbangban Pisga, mǝnana à cam ɓong-ɓong amur pǝɗanban ngga.
\s1 Limurǝm amur Sihon andǝ Og
\p 
\v 21 Isǝrayila tasǝ amǝ'na-túrbân ɓǝà kya ne Sihon, murǝm mala amǝ'Amor,\f + \fr 21:21 \fq Sihon, murǝm mala amǝ'Amor: \ft Ɓalli gbal aɓa: \xt Ɓal 32:33; Nggur 1:4; 2:24--4:46\xt*\ft .\f* ama,
\v 22 <<Eara sǝm ɓǝ̀ sǝm kùtí nǝɓa nzali mô. Pà sǝm nǝ̀ kùtí a ɓaban-mǝssa ko ɓaban-anap ɗàng. Pà sǝm nǝ̀ nu mùr a kǝ tūli-mùr ɗàng. Sǝm nǝ̀ ging cat, amur njar-mǝgule mala murǝm, ba purî ɓá nzali mô.>>
\p 
\v 23 Sǝama, Sihon eare ɓǝ̀ Isǝrayila kùtí aɓa nzali male ɗàng. A kún mani ka, ramba amǝ'lwa male puppup, sǝ à puro à nǝ̀ ká nǝ munǝo arǝ Isǝrayila aɓa pǝɗanban. Lang à yina a Jahaz ka, à soa munǝo arǝ amǝ Isǝrayila.
\v 24 Amǝ Isǝrayila gandǝia nǝ kún nggeabyau, sǝ à ak nzali malea arǝia, twal a ban Nggeasala Arnon kya bik Nggeasala Jabok, sǝama à kya go a nzong-nzali mala amǝ'Amon; acemǝnana nzong-nzali mala amǝ'Amon ngga mǝcandǝe na.
\v 25 Isǝrayila ak alá mala amǝ'Amor kat, sǝ duk kam aɓalǝia, kat andǝ nggea-là Heshbon, andǝ amuna-là mǝnana à nda aɓate ka.
\p 
\v 26 Heshbon ngga, nda nggea-là mala Sihon, murǝm mala amǝ'Amor, mana ɗiɗyal munǝo andǝ murǝm Mowap, sǝ ak nzali male arǝì kat, kya bwal ban Nggeasala Arnon ngga.
\p 
\v 27 Nda gìr mǝnana tsǝa, sǝ amǝ'nggyal bang ama,
\q1 <<Yiu a Heshbon, ace mǝnana ɓǝà ɓè ka;
\q1 nggea-là mala Sihon ngga ɓǝà ɓè, kusǝì ɓǝ̀ cam kàngkàng.
\q1 
\v 28 Bǝsa pur aɓa Heshbon,
\q1 lasǝ-bǝsa pur a nggea-là mala Sihon.
\q1 Bǝshe yi li Ar, là mala nzali Mowap,
\q1 yi twalta amǝtala amgbangban ndàka-lú a kún nggeasala Arnon.
\q1 
\v 29 Caukwanban nǝ we Mowap!
\q1 Ma'wun malna, wun aɓwana mala Kemosh!
\q1 Kemosh pànà amuna-burana male ɓǝà umnǝia a bǝri-nzali,
\q1 sǝ amuna-mamǝna male ka à umna nǝia a guro
\q1 aban murǝm Sihon ɓwa Amor.
\q1 
\v 30 Sǝm gandǝna Mowap kat-kat;
\q1 Heshbon ngga, à kiɗikini yi pur a Dibon.
\q1 Sǝm yinǝ kiɗikiban arǝì yi pur a Nofa,
\q1 mǝnana kya go a Medeba ka.>>
\p 
\v 31 Nda Isǝrayila do a nzali mala amǝ'Amor ka.
\v 32 Anzǝm mana Musa tasǝna amǝ'shenzǝban a Jaza ka, amǝ Isǝrayila kya aki amuna-là mǝnana à kàrìbanì ka, sǝ à pǝr amǝ'Amor mana à duk kam ngga.
\p 
\v 33 Pǝlǝa amǝ Isǝrayila wulio, à um nǝ njargula ká Bashan, sǝ Og, murǝm Bashan, andǝ amǝ'lwa male puppup, wari nǝ munǝo arǝia a Edǝri.
\p 
\v 34 Yahweh banggi Musa ama, <<Kǝa ɓanggi wi ɗàng, acemana ǝn pano wi, yì andǝ aɓwana male kat, andǝ nzali male. Pàkki wi kǝla mana a pakkì Sihon, murǝm mala amǝ'Amor ka, mana do a Heshbon ngga.>>
\p 
\v 35 Anggo sǝ à wal-luí, yì andǝ amuna-burana male, andǝ aɓwana male kat, yale kǝɓwa au ateà ɗàng, sǝ amǝ Isǝrayila ak nzali male pǝlǝ malea.
\c 22
\s1 Balak túrban ata Bil'am
\p 
\v 1 Pǝlǝa amǝ Isǝrayila gya, à wario à kya tsǝk kàttì a ɓawanban mala Mowap, a nkanggari Nggeasala Jodan a nkaring mala Jeriko.
\v 2 Balak\f + \fr 22:2 \fq Balak: \ft Ɓal cau male aɓa: \xt Jes 24:9-10; Akas 11:25; Mik 6:5; Sǝn 2:14\xt*\ft .\f* murǝm mala amǝ'Mowap, muna-ɓwabura mala Zippor, sǝn gìr mǝnana kat Isǝrayila pàkkî amǝ'Amor ka.\f + \fr 22:2 \ft Ɓalli aɓa: \xt Nggur 4:46; Jes 10:12\xt*\ft . \f*
\v 3 Sǝ amǝ'Mowap ka, nggea ǝn'o bwalia arǝ amǝ Isǝrayila acemǝnana à làkkì kǝ̀rkǝ́r. Amǝ'Mowap ka à lùmsǝ nǝ ɓangciu atàcau mala amǝ Isǝrayila.
\v 4 Nda amǝ'Mowap banggi aɓwana-mǝgule mala amǝ Midiyan ama, <<Nggea ɓwabundǝa mǝnia ka à nǝ̀ ya mal sǝm kǝla mana jamnda kǝ murǝ bondo ɓá garang ngga.>>
\p Sǝ Balak, muna-ɓwabura mala Zippor, mǝnana nda murǝm Mowap a nza mǝno ka,
\v 5 tasǝ amǝ'na-túrbân, aban Bil'am,\f + \fr 22:5 \fq Bil'am: \ft Ɓal cau male aɓa: \xt Nggur 23:3-5; Jes 24:9-10; Mik 6:5; 2Bit 2:15-16; Yahu 11; Sǝn 2:14\xt*\f* muna-ɓwabura mala Beyo, mǝnana ndanǝdo a Peto, a kún Nggeasala a nzali mala aɓwana male ka, ama ɓǝà tunǝi ɓǝ̀ yiu, nǝ cau ama, <<Sǝni, aɓwana mala ɓè kûn nya à yiu, mana à purî ɓá Masar ka; à aki múr nzali kat, sǝ ndya à do a nkanggariam ngga.
\v 6 Yiu adyan, ida sukàm amǝnia yì aɓwana ka, acemǝnana rǝcandǝa malea kútì mem kǝ̀rkǝ́r. Yakǝla, mǝ nǝ gandǝ limurǝm amúrià sǝ mǝ nǝ pǝria, ɓǝà upi nzali man. Mǝnia ka nda acemǝnana, ǝn sǝlǝna nǝma, aɓwana mana kat a tsǝkbuo amúrià ka, à kumǝna tsǝkbu, sǝ aɓwana mǝnana kat a suia ka, suban dumǝna amúrià.>>
\p 
\v 7 Nda aɓwana-mǝgule mala amǝ'Mowap, andǝ amala amǝ Midiyan lo, sǝ à bwal-njar aban ká, nǝ boalo a buia, mana à nǝ̀ nggá mbwena Bil'am nǝi ace túró ɓangnǝ-ɓangnǝa male ka. Lang à yina aban Bil'am ngga, à banggi wi cau mǝnana Balak bang ngga.
\p 
\v 8 Sǝ Bil'am bang ama, <<Wu nong kani yalung, mǝ nǝ yia na wun cau mana Yahweh nǝ̀ banggam ngga.>> Anggo sǝ amǝnia yì amǝgulo mala Mowap ka, à ueo atà Bil'am.
\p 
\v 9 Pǝlǝa Ɓakuli yiu aban Bil'am, sǝ ɗì ama, <<Ayana nda ka aburana mǝnia atò ka?>>
\v 10 Bil'am banggi Ɓakuli ama, <<Balak, muna-ɓwabura mala Zippor, murǝm Mowap, nda tasǝia abanam nǝ mǝnia yì cau ka, ama,
\v 11 <Sǝni, aɓwana mala ɓè kûn nya à yiu, mana à purî ɓá Masar ka; à aki múr nzali kat. Yiu adyan, tsǝkam suban amúrià. Yakǝla, mǝ nǝ gandǝia a lwa sǝ mǝ nǝ pǝria ɓǝà puro.> >>
\p 
\v 12 Sǝ Ɓakuli banggi Bil'am ama, <<Kǝa na ama, awu nǝ ká ateà ɗàng; sǝ a pà nǝ súka aɓwana mǝnia ɗàng, acemǝnana à ndanǝ tsǝkbu mem amúrià.>>
\p 
\v 13 Ban fana ka, Bil'am lo, sǝ banggi amǝgulo mala Balak ama, <<Wu nyare a nzali ma'wun, acemǝnana Yahweh ɓinǝna, ama mǝ nggá ká ata wun ɗàng.>>
\p 
\v 14 Nda amǝgulo mala Mowap lo à nyare aban Balak, sǝ à banggi wi ama, <<Bil'am, ɓinǝna yiu atà sǝm.>>
\p 
\v 15 Balak tasǝ amǝgulo ɗǝm, mǝnana à kútì amana à wari a tadǝmbe ka nǝ lakkì andǝ gulo ka.
\v 16 À wari aban Bil'am, sǝ à ne wi ama, <<Mǝnia ka nda cau mǝnana Balak, muna-ɓwabura mala Zippor bang ngga: <Ida, kǝa eare kǝgìr ɓǝ̀ tàmsǝo arǝ yiu abanam ɗàng;
\v 17 nda acemǝnana mǝ nǝ loasǝo wu kum gulo kǝ̀rkǝ́r, sǝ gìr mǝnana kat awu nǝ banggam ngga mǝ nǝ pè. Yiu, sukàm amǝnia yì aɓwana ka.> >>
\p 
\v 18 Sǝama Bil'am nyesǝcau sǝ banggi amǝtúró mala Balak ama, <<Ko ɓǝ̀ Balak nǝ̀ pam palta male, lumsǝ nǝ bolo-azǝrfa andǝ bolo-njengǝlan ngga, pà mǝ nǝ pàk ɓè kǝgir mǝgule ko mǝkyauwe, mana nda ɗàng'andǝ nzongcau mala Yahweh, Ɓakuli mem ngga ɗàng.
\v 19 Acemani ka, ida, wu nong kani, kǝla mana aɓwana mǝnana à yiu a dǝmbe, à pàk ka, ace mǝnana mǝ súrǝ̀ mana ɗǝm Yahweh nǝ̀ banggam.>>
\p 
\v 20 Ɓakuli yiu aban Bil'am sǝ banggi wi ama, <<Acemǝnana aburana man yina ace tunǝo ka, lo kyan wunǝia. Sǝama, shekǝ gìr mǝnana ǝn banggo ka nda awu nǝ pàk ka.>>
\s1 Bil'am andǝ mǝdambǝriso male
\p 
\v 21 Pǝlǝa Bil'am, lo nǝ dǝmbari, tsǝk gìr-do-anzǝm mǝdambǝriso male, sǝ o andǝ amǝgulo mala Mowap.
\v 22 Sǝ Ɓakuli ka, bumi lul kǝ̀rkǝ́r, acemǝnana Bil'am na rǝ ká ka, nda sǝ mǝturonjar mala Yahweh, yi came a njar ace mǝnana nǝ̀ ɓinǝi wi ka. Bil'am ngga, nda a nzǝm mǝdambǝriso male aban ká, sǝ amǝ'túró-ɓala male ɓari na atè.
\p 
\v 23 Lang mǝdambǝriso sǝn mǝturonjar mala Yahweh aban came a njar nǝ nggeabyau mana kwetǝnì, a bui ka, kara kyanggî njar kúti a bondo. Bil'am wal mǝdambǝriso, ace mǝnana nǝ̀ tsǝì ɓǝ̀ nyar amur njar ka.
\p 
\v 24 Pǝlǝa mǝturonjar mala Yahweh wario kya came amur njar mǝɓweari a nre ka aɓaban-anap ɓari, nǝ sheran tali a koya buì.
\v 25 Lang mǝdambǝriso sǝn mǝturonjar mala Yahweh ka, nggiki rǝì arǝ sheran, gandǝa gosǝ kusǝ Bil'am arǝ sheran. Sǝ Bil'am wal mǝdambǝriso ɗǝm.
\v 26 Pǝlǝa mǝturonjar mala Yahweh o a dǝmba amur njar, sǝ kya came a ban mana nda ɓwear, mǝnana kǝ ban pǝlǝa pà kàm ko a bu-mǝli ko a bu-mǝnggare raka.
\p 
\v 27 Lang mǝdambǝriso sǝn mǝturonjar mala Yahweh ka, kara nong a nzali aɓata Bil'am. Sǝ yì ka, bumi lúllô, wal mǝdambǝriso nǝ gara male.
\v 28 Pǝlǝa Yahweh mǝn kún mǝdambǝriso, sǝ mǝdambǝriso banggi Bil'am cau, ama, <<Mana ǝn pakko, mana tsǝa sǝ a walam kusǝ tàrú mǝnia ka?>>
\p 
\v 29 Bil'am, pǝlǝa pè mǝdambǝriso eare ama, <<Nda acemǝnana a ɓangginǝ mim ngga! Ɓǝ̀ mǝ ndanǝ nggeabyau a buam ngga, mǝ nǝ wal-luio ado!>>
\p 
\v 30 Pǝlǝa mǝdambǝriso banggi Bil'am ama, <<Mǝ nda mǝdambǝriso mǝnana a kwakiyi a do mô kat ba yalung ngga re? Mǝ ndanǝ ɓealu mala pàkkô ani le?>>
\p Pǝlǝa Bil'am ne wi ama, <<Awo.>>
\p 
\v 31 Pǝlǝa Yahweh mǝn amǝsǝ Bil'am, sǝ sǝn mǝturonjar mala Yahweh aban came amur njar, nǝ nggeabyau male, mana kwetǝnì ka, a bui. Bil'am pǝlǝa ti múrí, sǝ ɓunno, nǝ ɓamǝsǝi a nzali.
\p 
\v 32 Pǝlǝa mǝturonjar mala Yahweh ɗi ama, <<Ace mana sǝ a wal mǝdambǝriso mò kusǝ tàrú mǝnia? Sǝni, ǝn yipo kǝla ɓimǝbura, acemǝnana ká mo mǝnia ka, mǝɓike na abanam.
\v 33 Mǝdambǝriso sǝnam, sǝ kyanggam kusǝ tàrú mǝnia ka. Ɓǝ̀ mǝdambǝriso kyangmam raka, mǝsǝcau, ɓǝ́ ado ka ǝn walǝna-luio, sǝ ǝn amsǝna yilǝmi.>>
\p 
\v 34 Bil'am banggi mǝturonjar mala Yahweh ama, <<Ən pangŋa cauɓikea. Acemǝnana ǝn sǝlǝa nǝma a nda ban came a njar, ace ɓinǝàm ɗàng. Sǝ adyan ngga, ɓǝ̀ mǝnia yì gìr ka pwasǝbumo raka, mǝ nǝ nyare.>>
\p 
\v 35 Pǝlǝa mǝturonjar mala Yahweh, banggi Bil'am ama, <<Kyan wunǝ aburane, sǝama, kǝ cau mǝnana ǝn banggo ka, nda awu nǝ na ka.>>
\p Nda Bil'am kutio wario andǝ amǝgulo mala Balak ka. \fig Mǝturonjar pusǝrǝi aban Bilʻam|alt="Angel apperard to Balaam" src="CO00868B.TIF" size="col" loc="22:35" copy="Cook OT" ref="22:31-35"\fig*
\p 
\v 36 Lang Balak ok ama, Bil'am na aban yiu ka, puro ace mǝnana nǝ̀ nggá kullì a nggea-là mala amǝ'Mowap a kún Nggeasala Arnon mǝnana nda a nzong-nzali male ka.
\p 
\v 37 Balak, pǝlǝa banggi Bil'am ama, <<Ən túrban atò tsuk-tsuk nǝma ɓǝà tunǝo re? Palang sǝ a ɓinǝ yiu abanam? Mbak-kàngkàng, mim ngga, pa mǝ nǝ gandǝ loasǝo wu kum gulo re?>>
\p 
\v 38 Sǝ Bil'am nyesǝi wi ama, <<Ndya ǝn yiu a bano ka! Sǝama, mǝ ndanǝ rǝcandǝa mala na kǝ cau mǝnana mǝ nǝ gandǝ ne ka le? Dumǝna púp, cau mǝnana Ɓakuli nǝ̀ tsǝkam a kunam ngga, nda mǝ nǝ na ka.>>
\p 
\v 39 Pǝlǝa Bil'am wari atà Balak, a Kiriyat Huzot.\f + \fr 22:39 \fq Kiriyat Huzot \ft ka ɓālǝi nda <<nggea-là mala anjar-mǝgule.>>\f*
\p 
\v 40 Sǝ Balak pà gir'nkila nǝ andá, andǝ anzur, sǝ aɓea ka, pè Bil'am andǝ amǝgulo mana à nda atè ka.
\p 
\v 41 Ban fana, nǝ dǝmbari ka, Balak twal Bil'am sǝ à eauwe andǝi a Bamot Ba'al.\f + \fr 22:41 \fq Bamot Ba'al \ft ka ɓālǝi nda <<Amgbangban ndàka-lú mala Ba'al.>>\f* Akano sǝ sǝn bare amǝ Isǝrayila.
\c 23
\s1 Bil'am tsǝki Isǝrayila bù
\p 
\v 1 Bil'am pǝlǝa bang ama, <<Ɓakkam agyangŋan tongno-nong-ɓari kani; yinǝam nǝ ajamnda tongno-nong-ɓari, andǝ agam tongno-nong-ɓari, sǝ wu gilikiamia.>>
\p 
\v 2 Balak pa kǝla mana Bil'am bang ngga; sǝ amur koya gyangŋan ngga, Balak andǝ Bil'am pàgir nǝ jamnda mwashat andǝ gam mwashat.
\p 
\v 3 Pǝlǝa Bil'am banggi Balak ama, <<Came a ban pàgir mala pisǝe kǝring mò, sǝ mǝ nǝ o. Yakǝla Yahweh nǝ̀ yiu abanam, sǝ gìr mǝnana kat lǝmdǝàm ngga, mǝ nǝ banggo.>> Pǝlǝa Bil'am o amur ɓè kpakan mgbangban.
\p 
\v 4 Ɓakuli yiu aban Bil'am, sǝ Bil'am banggi wi ama, <<Ən gilikina agyangŋan tongno-nong-ɓari, sǝ amur koya gyangŋan ngga, ǝn panagir nǝ jamnda andǝ gam.>>
\p 
\v 5 Pǝlǝa Yahweh tsǝk cau a kun Bil'am, sǝ na ama, <<Nyare kya aban Balak, ne wi mǝnia yì cau ka.>>
\p 
\v 6 Anggo, sǝ Bil'am nyare, wario kya kum Balak aban came a nkanggari pàgir mala pisǝe kǝring male, andǝ amǝgulo mala Mowap.
\v 7 Sǝ Bil'am ar cau-pasǝlǝe male, ama:
\q1 <<Balak, murǝm Mowap yinǝ mim, ǝn pur a Aram
\q2 aɓalǝa ankono mǝnana nǝ takuli ka.
\q1 Banggam ama, <Yiu, súam Yakupu,
\q2 yiu, na mǝɓike arǝ Isǝrayila!>
\q1 
\v 8 Lang sǝ mǝ nǝ gandǝ sú ɓwa mǝnana Ɓakuli suí raka?
\q2 Lang sǝ mǝ nǝ gandǝ na mǝɓike arǝ ɓwa mǝnana Yahweh na mǝɓike arǝì raka?
\q1 
\v 9 A ɓong atali ǝn nggǝ sǝnia,
\q2 amur amgbangban ǝn nggǝ pelǝkia.
\q1 Ən nggǝ sǝn nggǝsanì aɓwana mana à tàr ɓamúrià,
\q2 sǝ à ɓal ɓamúrià aɓalǝ anzali raka.
\q1 
\v 10 Yana nǝ̀ gandǝ ɓal tú-nzali mala Yakupu,
\q2 ko nǝ̀ súrǝ̀ inea bare làkkì mala Isǝrayila?
\q1 Ɗekiam ɓǝn wú, ulang lú mala mǝɓealɓoarna.
\q2 Ɓǝ̀ masǝlǝata do mem pǎ kǝla male!>>
\p 
\v 11 Pǝlǝa Balak banggi Bil'am ama, <<Mana mǝnia a pàkkam anggo ka? Ən twalo ace mǝnana wu sú aɓiam-mǝbura, sǝ ndya, yale tsǝkbu na a tsǝkia wia ka!>>
\p 
\v 12 Pǝlǝa Bil'am, pa eare ama, <<Gìr mǝnana Yahweh tsǝkam a kunam ngga nda dumǝna púp, mǝ nǝ tsǝkiram arǝì, mǝ nǝ bangŋi ka re?>>
\s1 Ɓaria cau-pasǝlǝe mala Bil'am nǝban Ɓakuli
\p 
\v 13 Pǝlǝa Balak banggi Bil'am ama, <<Ida, yiu atàm, sǝm nǝ̀ ká a ɓè ban, ban mǝnana awu nǝ sǝnia kam ngga. Akano ka awu nǝ sǝn barebania, a pà nǝ sǝnia kat ɗàng. Sǝ wu súkamia.>>
\p 
\v 14 Nda Balak twal Bil'am, um nǝi a banfana mala Zofim, a ɓong Nkono Pisga. Ɓak agyangŋan tongno-nong-ɓari kam, sǝ pàgir nǝ jamnda andǝ gam amur koya gyangŋan.
\p 
\v 15 Pǝlǝa Bil'am banggi Balak ama, <<Cam kani a nkanggari pàgir mala pisǝe kǝring mò, sǝ mim ngga mǝ nǝ ká akano ace gasǝ sǝnǝ Yahweh.>>
\p 
\v 16 Pǝlǝa Yahweh yiu aban Bil'am, sǝ tsǝki wi cau a kúni, sǝ banggi wi ama, <<Nyar aban Balak sǝ wu bang mǝnia yì cau ka.>>
\p 
\v 17 Pǝlǝa Bil'am nyar aban Balak, sǝ yi kumi ka nda aban came a nkanggari pàgir mala pisǝe kǝring male, sǝ amǝgulo mala Mowap ka à nda baní. Sǝ Balak ɗì Bil'am ama, <<Mana nda gìr mǝnana Yahweh na ka?>>
\p 
\v 18 Pǝlǝa Bil'am ar cau-pasǝlǝe male sǝ na ama,
\q1 <<Lo, Balak, sǝ wu ó!
\q2 Kwakikiro arǝàm, we muna-ɓwabura mala Zippor;
\q1 
\v 19 Ɓakuli ka, ɓwapǝndǝa na ɗang, mǝnana nǝ̀ na nyir ka,
\q2 sǝ yi ka, muna mala ɓwa na ɗang, mǝnana nǝ̀ nggaɗi kúni ka;
\q1 Nanacau, sǝ pà nǝ̀ pè re?
\q2 Ko ana raka, bangŋǝna cau, sǝ pà nǝ̀ lùmsǝì re?
\q1 
\v 20 Sǝni, mim ngga à tsǝkam nzongcau ɓǝn tsǝkbu;
\q1 Yì ka tsǝngŋǝnabu, sǝ pà mǝ nǝ gandǝ nggaɗi ɗàng.
\q1 
\v 21 Kǝ gìr múrɓikea pà kàm à pelǝì aɓa Yakupu ɗàng,
\q2 À sǝnma kǝ gìr bumkiɗikea aɓa Isǝrayila ɗàng.
\q1 Yahweh, Ɓakuli malea na ateà;
\q2 Gawan murǝm na aɓalǝia.
\q1 
\v 22 Ɓakuli pusǝia aɓa Masar;
\q1 Yì ka nda kǝla anjawe ndwakan abania.
\q1 
\v 23 Kǝ ɓuri pà kàm nǝ̀ li arǝ Yakupu ɗàng,
\q2 kǝ ɗǐ kàm arǝ Isǝrayila ɗàng.
\q1 Adyan ngga à nǝ̀ banggi Yakupu, sǝ à nǝ̀ banggi Isǝrayila
\q2 gìr mǝnana Ɓakuli pangŋǝ̀nì ka!
\q1 
\v 24 Sǝni, à nda ka aɓwana mana à kǝ lo kǝla nggeàɓwaná-im
\q2 aɓa gilǝrǝu nǝ̀ kánǝ munǝo;
\q2 kǝla mana im kǝ loasǝ rǝì ka,
\q2 sǝ pà nǝ̀ nongnǝ-nongŋo ɗang sheɓǝ̀ shanŋǝ̀nà nyama,
\q2 sǝ nuna nkila mala nyama mǝnana wal ka.>>
\p 
\v 25 Pǝlǝa Balak banggi Bil'am ama, <<Ɓǝ̀ a pà wu nǝ suia raka, ko bǝti, kǝa tsǝkia wia bu ɗàng!>>
\p 
\v 26 Pǝlǝa Bil'am pe Balak eare ama, <<Nggearǝì ka, ǝn banggo mbak nǝma, kǝgir mǝnana Yahweh banggam ngga, nda mǝ nǝ pàk ka, re?>>
\s1 Tàruià cau-pasǝlǝe mala Bil'am nǝban Ɓakuli
\p 
\v 27 Pǝlǝa Balak banggi Bil'am ama, <<Yiu atàm, mǝ nǝ kánǝ we, a ɓè ban mwashat ɗǝm. Ear ka, nǝ̀ pwasǝbum Ɓakuli, ace mǝnana ɓǝ̀ earô wu suia acem, akano ka.>>
\p 
\v 28 Pǝlǝa Balak twal Bil'am, sǝ à eau andǝi amur Nkono Piyor, mana sǝngiyi pǝɗanban ngga.
\p 
\v 29 Pǝlǝa Bil'am bang ama, <<Ɓakkam agyangŋan, tongno-nong-ɓari, sǝ wu gilikiam jamnda tongno-nong-ɓari, andǝ agam tongno-nong-ɓari.>>
\p 
\v 30 Pǝlǝa Balak pa, kǝla mana Bil'am bang ama ɓǝà pè ka. Pǝlǝa pàgir nǝ jamnda andǝ gam, amur koya gyangŋan.
\c 24
\p 
\v 1 Adyan ngga, lang Bil'am sǝnǝni ama, girî pwasǝbum Yahweh, acemǝnana tsǝki amǝ Isǝrayila bù ka, nyare wario kǝla mana ɗiɗyal ka nǝ̀ nggá ɓangnǝ-ɓangnǝa ɗang. A kún mǝno ka, pǝlǝ ɓamǝsǝi nǝ njar ɓabondo.
\v 2 Lang Bil'am loasǝ mǝsǝì sǝ sǝn amǝ Isǝrayila, aban do a kàttì, arǝ atau malea ka, Bangŋo mala Ɓakuli sulǝo amurí,
\v 3 sǝ ar cau-pasǝlǝe male, ama:
\q1 <<Cau-pasǝlǝe mala Bil'am, muna-ɓwabura mala Beyo,
\q2 cau mala ɓwa mǝnana mǝsǝi kǝ sǝn agir pepè ka;
\q2 
\v 4 yì cau mala ɓwa mǝnana kǝ ok gi Ɓakuli;
\q2 yì ɓwa mǝnana kǝ sǝn sǝna nǝban Mǝ'kàrmúr-gulo kat;
\q1 yì ɓwa mǝnana kǝ sárǝ́ nǝ múrbumi a nzali, sǝ amǝsǝì na mǝnna ka:
\q1 
\v 5 Wu sǝn ɓoarsǝna mala agumli ma'wun, We Yakupu,
\q2 nggearǝ abando ma'wun, We Isǝrayila!
\q1 
\v 6 À sarǝa kǝla aɓangŋaban,
\q2 kǝla aɓaban-girpwala a kún nggeasala,
\q1 kǝla agwalan mǝnana Yahweh nǝ̀ pandǝia ka,
\q2 kǝla anggun-seda a kún amúr.
\q1 
\v 7 Wun wunǝ amǝkà wun ngga wun nǝ̀ lidǝmba kǝla ɓaban-girpwala a myalmúr;
\q1 Murǝm malea nǝ̀ dumnǝ gulo mana kúti gulo mala Agag ka;
\q2 sǝ domurǝm malea ka nǝ̀ kum loasǝ́bân a kuli.
\q1 
\v 8 Ɓakuli pusǝia, à purî nzali Masar;
\q1 yia ka, à ndanǝ rǝcandǝa mala ndwakan;
\q1 à nǝ̀ lika anzali mǝnana aɓia-mǝbura na ka;
\q1 à nǝ̀ arki amuia raka-rakas;
\q1 à nǝ̀ tāki aɓia-mǝbura nǝ amundi malea.
\q1 
\v 9 Kǝla im, à nǝ̀ ɓun amur ankūnǝia aban nongŋo,
\q1 kǝla nggeàɓwaná-im, yana ɓwe kārǝa nǝ zorǝia?
\q1 Aɓwana mana à tsǝka wun bù ka, ɓǝà kum tsǝkbu,
\q2 sǝ aɓwana mana à sú wun ngga, ɓǝà kum suban!>>
\p 
\v 10 Kara bumlulla mala Balak earbǝsa arǝ Bil'am. Balak wal abui aɓalǝarǝia, sǝ banggi Bil'am ama, <<Ən tunǝo nǝma, wu sukàm aɓiam-mǝbura, sǝ ndya ka a tsǝ́ngŋǝ́niabu kusǝ tàrú mǝnia.
\v 11 Ado ka, nying ban mǝnia ka tsuk-tsuk, o a là! Ən bang nǝma mǝ nǝ mbweo pepè, sǝama Yahweh tsǝ̀ngŋǝ̀nó a ɗwanyini mbweban mana ɓǝ́ awu nǝ kum ngga.>>
\p 
\v 12 Pǝlǝa Bil'am pè Balak eare ama, <<Ən bangmì amǝ'na-túrbân mana a túriá abanam ngga re?
\v 13 Ən nana nǝma, ko ɓǝ̀ Balak nǝ̀ pam palta male, lumsǝ nǝ bolo-azǝrfa andǝ bolo-njengǝlan ngga, pà mǝ nǝ pàk ɓè kǝgir mala ɓamúràm, ko mǝɓoarne ko mǝɓane, mǝnana yàlî nzongcau mala Yahweh ka ɗàng; Dumǝnam púp, mǝ nǝ bang kǝ gir mǝnana Yahweh kǝ na ka.
\v 14 Adyan ngga, mǝ ndya mǝ nǝ nyare, mǝ nǝ o aban aɓwana mem. Sǝama, came mǝ nunkiro amur gir mǝnana aɓwana mǝnia, nǝ̀ yia pàkkî aɓwana mô arǝ apwari mana à kǝ yiu ka.>>
\s1 Inea cau-pasǝlǝe mala Bil'am nǝban Ɓakuli
\p 
\v 15 Pǝlǝa Bil'am ar cau-pasǝlǝe male ama:
\q1 <<Cau-pasǝlǝe mala Bil'am, muna-ɓwabura mala Beyo,
\q2 cau mala ɓwa mǝnana mǝsǝi kǝ sǝn agir pepè ka;
\q2 
\v 16 yì cau mala ɓwa mǝnana kǝ ok gi Ɓakuli,
\q2 yì ɓwa mǝnana ndanǝ súrǝ̀gir nǝban Mǝ'Karban Kat ka,
\q2 yì ɓwa mǝnana kǝ kum sǝna nǝban Mǝ'rǝcandǝa kat ka;
\q2 yì ɓwa mǝnana kǝ sárǝ́ nǝ múrbumi a nzali, sǝ amǝsǝì na mǝnna ka:
\q1 
\v 17 Ən nggǝ sǝni, sǝama pà ado ɗàng;
\q1 Ən nggǝ pelǝkì, sǝama pà abanam tù ɗàng.
\q1 Nlero nǝ̀ puro aɓa Yakupu;
\q1 gara-murǝm nǝ̀ yia lo aɓa Isǝrayila,
\q2 sǝ nǝ̀ yia arki akundǝmba amǝ'Mowap,
\q2 yì ankpoulo-ɓamur amuna-burana mala Shet.
\q1 
\v 18 Edom ngga, à nǝ̀ lì nǝ lwa;
\q1 Seyir, ɓimǝbura malea ka, à nǝ̀ lì nǝ lwa,
\q2 sǝama Isǝrayila ka, nǝ̀ gulo nǝ̀ dumnǝ rǝcandǝa.
\q1 
\v 19 Mǝ'yálmúrû nǝ̀ pur aɓa Yakupu,
\q2 sǝ nǝ̀ yia kiɗiki acili aɓwana mala nggea-lê.>>
\s1 Masǝlǝata cau-pasǝlǝe mala Bil'am
\p 
\v 20 Pǝlǝa Bil'am sǝn amǝ Amalek, sǝ ar cau-pasǝlǝe male ama:
\q1 <<Amalek ka, nda mǝdǝmba aɓalǝ anzali,
\q2 sǝama, à nǝ̀ kiɗiki kat a masǝlǝate.>>
\p 
\v 21 Pǝlǝa sǝn amǝ Ken, sǝ ar cau male ama:
\q1 <<Bando ma'wun ngga, nda aɓata gbasha,
\q2 sǝ mpù ma'wun ngga, à kwakite aɓa tali;
\q1 
\v 22 kat andǝ amani ka, wun amǝ Ken ngga, à nǝ̀ kiɗiki wun,
\q2 lang Asshur nǝ̀ yia bwal wun aguro ka.>>
\p 
\v 23 Pǝlǝa nyare ar cau-pasǝlǝe male ama:
\q1 <<Oi, sǝ yana nǝ̀ auwa, lang Ɓakuli nǝ̀ pàk mǝnia ka?
\q1 
\v 24 Awaru-mur nǝ̀ puro arǝ akunto mala Kitim;
\q2 à nǝ̀ yia gandǝ Asshur andǝ Eba,
\q2 sǝ yià gbal ka, à nǝ̀ kìɗìkya.>>
\p 
\v 25 Pǝlǝa Bil'am lo sǝ nyare a là, sǝ Balak ka o a o male.
\c 25
\s1 Amǝ Isǝrayila peri aban Ba'al a Piyor
\p 
\v 1 Mana amǝ Isǝrayila na a bando a Shitim ngga, aburana mala amǝ Isǝrayila kùtí a nongginǝ amamǝna mala amǝ'Mowap.
\v 2 Pǝlǝa amamǝna mǝnia tunǝ aburana man ɓǝà kyane aban apa'girnkila mala aɓakuli malea. Pǝlǝa amǝnia yì aburana ka, à lì girlina ɗārǝâ, sǝ à peri aban aɓakuli mala amǝ'Mowap.
\v 3 Anggo, sǝ amǝ Isǝrayila kùtí a peri aban Ba'al Piyor, sǝ bum Yahweh pi arǝia kǝ̀rkǝ́r.
\p 
\v 4 Sǝ Yahweh ne Musa ama, <<Twal aɓwana-mǝgule mala mǝnia yì aɓwana mǝnana à pàk gìr man ngga, sǝ wu wal-luia nǝ gyarban a pwari, aɓadǝmbam Yahweh, ace mǝnana nggea bumlulla mem Yahweh ka ɓǝ̀ sulǝî múr Isǝrayila.>>
\p 
\v 5 Pǝlǝa Musa banggi amǝ'ɓashi mala amǝ Isǝrayila ama, <<Koyan atà wun ngga, ɓǝ̀ wal-lú aɓwana male mana à oasǝ múrià aɓa peri aban Ba'al Piyor ka.>>
\p 
\v 6 Sǝ mwashat atà amǝ Isǝrayila yinǝ ɓè ɓwama Midiyan\f + \fr 25:6 \fq Midiyan: \ft À pàktúró nǝi akani kǝla lullǝu mana kpapi akûn mala aɓwapǝndǝa ɗàngɗáng mǝnana à do a takuli mala Nggeasala Jodan ngga. Aɓea atà aɓwapǝndǝa man ngga yakǝla ɓwa Mowap nda murǝm amúrià; sǝni a \xt Tite 36:35; Ɓal 31:8; Jes 13:21\xt*\ft .\f* aban aɓwana male, a mǝsǝ Musa ngguont, sǝ a mǝsǝ amǝ Isǝrayila puppup, yi mana à nda ban ɓua a bankutio aɓa Tara Ban-peri ka.
\v 7 Lang Finehas muna-ɓwabura mala Eleaza, muna-ɓwabura mala Haruna, pǝris, sǝni ka, lo nying ɓwabundǝa, kya twal nzo a bui,
\v 8 pǝlǝa o atà ɓwa Isǝrayila mǝno aɓa gumli male. Kara zuɓia yià kǝm, yì ɓwabure, ɓwa Isǝrayila andǝ ɓwame, kya sa a bum ɓwame. Kara kwánó-ɓikea mana nda amur amǝ Isǝrayila ka came.
\v 9 Sǝama aɓwana mana à wǔ aɓa kwánó-ɓikea mǝnia ka à nda á-lumi-ɓari-nong-ine (24,000).
\s1 Ɓabumpina mala Finehas
\p 
\v 10 Sǝ Yahweh ne Musa ama,
\v 11 <<Finehas muna-ɓwabura mala Eleaza, muna-ɓwabura mala Haruna, pǝris ka, pwasǝlǝna nggea bumlulla mem arǝ amǝ Isǝrayila, acemǝnana yì ka, ndanǝ ulang bumpina mem aɓalǝi. Acemani ka, Ən twalta amǝ Isǝrayila aɓa bumpina mem ɗàng.
\v 12 Acemani ka, ne wi ama, <Mǝ ndaban kùrcau nǝi mala dorǝpwala mem.
\v 13 Sǝ yì andǝ amǝ'ke atè ka, ǝn kurnacau mala lidǝmba malea aɓa dobuno-pǝris, acemǝnana pàk bumpina ace Ɓakuli male, sǝ shawuɗi amǝ Isǝrayila.> >>
\p 
\v 14 Lullǝ ɓwa Isǝrayila mana à wal-lui andǝ ɓwama Midiyan ngga, nda Zǝmri, muna-ɓwabura mala Salu, ɓwamǝgule a ɓala-kàu a tàu mala Shimiyon.
\p 
\v 15 Sǝ lullǝ ɓwama Midiyan mana à wal-lui ka nda Kosbi muna-ɓwama mala Zur, ɓwamǝgule amur ɓala-kau mala ɓè tau mala amǝ Midiyan.
\p 
\v 16 Pǝlǝa Yahweh nacau nǝ Musa ama,
\v 17 <<Kyan nǝ munǝo arǝ amǝ'Midiyan, kǝla aɓiwun-amǝbura, wu walia.
\v 18 Acemǝnana à pàngnǝ wun kǝla aɓia-mǝbura nǝ swarkiban mǝnana à swarki wun a cau mala Piyor, sǝ a cau mala Kosbi, nsarile ɓwamǝgule mala amǝ Midiyan, mǝ'eambia muna-ɓwama mana à wal-lui a pwari mala kwánó-ɓikea atàcau mala Piyor ka.>>
\c 26
\s1 Ɓaria ɓalban
\p 
\v 1 Anzǝm mana kwánó-ɓikea malǝna ka, Yahweh bangcau nǝ Musa andǝ Eleaza muna-ɓwabura mala Haruna, yì pǝris ama,
\v 2 <<Wu ɓal làkkì mala aɓwana arǝ atau mala amǝ Isǝrayila a ɓinalea kat, koya ɓwabura mǝnana pǝlǝa-ɓǝlban male bingŋǝna lumi-ɓari aban ká dǝmba ka; mǝnana karǝna-ɓwa nǝ̀ gandǝ ká lwa ka.>>
\v 3 Pǝlǝa Musa andǝ Eleaza pǝris bangcau nǝ aɓwana mǝnia ka, aɓa ɓawanban mala Mowap, a nkaring Nggeasala Jodan, a Jeriko, ama,
\v 4 <<Wu ɓal làkkì mala aburana mana pǝlǝa-ɓǝlban malea bingŋǝna lumi-ɓari aban ká dǝmba,>> kǝla mana Yahweh banggi Musa ka.
\p Amǝnia ka à nda ka amǝ Isǝrayila mǝnana à purî ɓá nzali Masar ka.
\s1 Tàu mala Ruben
\p 
\v 5 Amǝkà Ruben, muna-dǝmba mala Yakupu, arǝ anggurkwar malea ka à nda ka:
\li1 Amǝ'Hanok a nggurkwar mala muni Hanok;
\li1 Amǝ'Palu a nggurkwar mala muni Palu;
\li1 
\v 6 Amǝ'Hezǝron a nggurkwar mala muni Hezǝron, sǝ
\li1 Amǝ'Karmi a nggurkwar mala muni Karmi.
\m 
\v 7 Amǝnia ka à nda ka aɓala mala amuna andǝ amǝkà Ruben kǝla mana à ɓallia ka, aburana á-lumi-ine-bwamdǝ-á-tàrú nǝ gbǝman-tongno-nong-ɓari nǝ lumi-tàrú (43,730).
\p 
\v 8 Palu nda tár Eliyap,
\v 9 sǝ amuna-burana mala Eliyap ka à nda ka Nemuyel, andǝ Datan sǝ Abiram. Amǝnia ka à nda ka kǝ Datan andǝ Abiram mǝnana ɓwabundǝa twalia ɓǝà duk amǝgulo amur aɓwana, sǝ à yì mgbicau arǝ Musa andǝ Haruna ka; ɗǝm ngga à nda atà aɓwana mǝnana à kpata Kora à yì mgbicau arǝ Yahweh ka;\f + \fr 26:9 \ft Ɓalli aɓa: \xt Ɓal 16:1-3\xt*\ft .\f*
\v 10 sǝ nzali mǝn kúni myalia kat, atārǝia andǝ Kora, mǝnana amǝtè wǔ, lang bǝsa yi twalta aburana gbǝman-ɓari nǝ lumi-tongno ka (250).\f + \fr 26:10 \ft Ɓalli aɓa \xt Ɓal 16:31-35\xt*\ft .\f* Mǝno ka yi duk gir nunkiru aban acili amǝ Isǝrayila kat.
\v 11 Sǝama amuna-burana mala Kora ka à wù ɗàng.
\s1 Tàu mala Shimiyon
\p 
\v 12 Amǝkà Shimiyon arǝ anggurkwar malea ka à nda ka:
\li1 Amǝ'Nemuyel a nggurkwar mala muni Nemuyel;
\li1 Amǝ'Jamin a nggurkwar mala muni Jamin;
\li1 Amǝ'Jakin a nggurkwar mala muni Jakin;
\li1 
\v 13 Amǝ'Zera a nggurkwar mala muni Zera, sǝ
\li1 Amǝ'Shawul a nggurkwar mala muni Shawul.
\m 
\v 14 Amǝnia ka à nda ka aɓala mala amuna andǝ amǝkà Shimiyon kǝla mana à ɓallia ka, aburana á-lumi-ɓari-bwamdǝ-á-ɓari nǝ gbǝman-ɓari (22,200).
\s1 Tàu mala Gad
\p 
\v 15 Amǝkà Gad arǝ anggurkwar malea ka à nda ka:
\li1 Amǝ'Zefon a nggurkwar mala muni Zefon;
\li1 Amǝ'Hagi a nggurkwar mala muni Hagi
\li1 Amǝ'Shuni a nggurkwar mala muni Shuni;
\li1 
\v 16 Amǝ'Ozǝni a nggurkwar mala muni Ozǝni;
\li1 Amǝ'Eri a nggurkwar mala muni Eri;
\li1 
\v 17 Amǝ'Arodi a nggurkwar mala muni Arodi, sǝ
\li1 Amǝ'Areli a nggurkwar mala muni Areli.
\m 
\v 18 Amǝnia ka, à nda ka aɓala mala amuna andǝ amǝkà Gad kǝla mana à ɓallia ka, aburana á-lumi-ine nǝ gbǝman-tongno (40,500).
\s1 Tàu mala Yahuda
\p 
\v 19 Amuna-burana mala Yahuda ka à nda ka Er andǝ Onan, sǝ yià ka à wǔ aɓa nzali Kan'ana.\f + \fr 26:19 \ft Ɓalli aɓa: \xt Tite 38:3-4,6-11\xt*\ft .\f*
\m 
\v 20 Amǝkà Yahuda arǝ anggurkwar malea ka à nda ka:
\li1 Amǝ'Shela a nggurkwar mala muni Shela;
\li1 Amǝ'Perez a nggurkwar mala muni Perez;
\li1 Amǝ'Zera a nggurkwar mala muni Zera.
\li1 
\v 21 Amǝkà Perez ka à nda ka:
\li2 Amǝ'Hezǝron a nggurkwar mala muni Hezǝron, sǝ
\li2 Amǝ'Hamul a nggurkwar mala muni Hamul.
\m 
\v 22 Amǝnia ka, à nda ka aɓala mala amuna andǝ amǝkà Yahuda kǝla mana à ɓallia ka, aburana á-lumi-tongno-nong-ɓari-bwamdǝ-tongno-nong-mwashat nǝ gbǝman-tongno (76,500).
\s1 Tàu mala Isaka
\p 
\v 23 Amǝkà Isaka arǝ anggurkwar malea ka à nda ka:
\li1 Amǝ'Tola a nggurkwar mala muni Tola;
\li1 Amǝ'Puwa a nggurkwar mala muni Puwa;
\li1 
\v 24 Amǝ'Jashup a nggurkwar mala muni Jashup, sǝ
\li1 Amǝ'Shimiron a nggurkwar mala muni Shimiron.
\m 
\v 25 Amǝnia ka, à nda ka aɓala mala amuna andǝ amǝkà Isaka kǝla mana à ɓallia ka, aburana á-lumi-tongno-nong-mwashat-bwamdǝ-á-ine nǝ gbǝman-tàrú (64,300).
\s1 Tàu mala Zebulu
\p 
\v 26 Amǝkà Zebulu arǝ anggurkwar malea ka à nda ka:
\li1 Amǝ'Seret a nggurkwar mala muni Seret;
\li1 Amǝ'Elon a nggurkwar mala muni Elon, sǝ
\li1 Amǝ'Jali a nggurkwar mala muni Jali.
\m 
\v 27 Amǝnia ka, à nda ka aɓala mala amuna andǝ amǝkà Zebulu kǝla mana à ɓallia ka, aburana á-lumi-tongno-nong-mwashat nǝ gbǝman-tongno (60,500).
\s1 Tàu mala Manasa
\p 
\v 28 Amǝkà Yisǝfu arǝ anggurkwar malea nǝban amuna-burana male Manasa andǝ Ifǝrem ngga à nda ka:
\li1 
\v 29 Amǝkà Manasa:
\li2 a nggurkwar mala muni Makir ka à nda ka Amǝ'Makir; sǝ Makir ka nda tár Gilǝyat;
\li3 Amǝ'kau a nggurkwar mala Gilǝyat ka à nda ka Amǝ'Gilǝya.
\v 30 Sǝ amǝkà Gilǝyat ka à nda ka:
\li4 Amǝ'Iyeza a nggurkwar mala muni Iyeza;
\li4 Amǝ'Helek a nggurkwar mala muni Helek;
\li4 
\v 31 Amǝ'Asǝriyel a nggurkwar mala muni Asǝriyel;
\li4 Amǝ'Shekem a nggurkwar mala muni Shekem;
\li4 
\v 32 Amǝ'Shemida a nggurkwar mala muni Shemida, andǝ
\li4 Amǝ'Hefa a nggurkwar mala muni Hefa.
\li4 
\v 33 Zelofihat, muna-ɓwabura mala Hefa ka, kum kǝ muna-ɓwabura ɗàng; amuni ka amuna-mamǝna na, sǝ alullǝia ka à nda ka Mahla, andǝ Noha, andǝ Hogǝla, andǝ Milka, sǝ Tǝrza.
\m 
\v 34 Amǝnia ka, à nda ka aɓala mala amuna andǝ amǝkà Manasa kǝla mana à ɓallia ka, aburana á-lumi-tongno-bwamdǝ-á-ɓari nǝ gbǝman-tongno-nong-ɓari (52,700).
\s1 Tàu mala Ifǝrem
\p 
\v 35 Amǝkà Ifǝrem ngga à nda ka:
\li1 Amǝ'Shutela a nggurkwar mala muni Shutela;
\li1 Amǝ'Beka a nggurkwar mala muni Beka, andǝ
\li1 Amǝ'Tahan a nggurkwar mala muni Tahan.
\lim1 
\v 36 Amǝkà Shutela ka à nda ka:
\li3 Amǝ'Eran a nggurkwar mala muni Eran;
\m 
\v 37 Amǝnia ka, à nda ka aɓala mala amuna andǝ amǝkà Ifǝrem kǝla mana à ɓallia ka, aburana á-lumi-tàrú-bwamdǝ-á-ɓari nǝ gbǝman-tongno (32,500). Yià mǝnia ka, à nda ka amǝkà Yisǝfu arǝ anggurkwar malea.
\s1 Tàu mala Benjami
\p 
\v 38 Amǝkà Benjami arǝ anggurkwar malea ka à nda ka:
\li1 Amǝ'Bela a nggurkwar mala muni Bela;
\li1 Amǝ'Ashbel a nggurkwar mala muni Ashbel;
\li1 Amǝ'Ahiram a nggurkwar mala muni Ahiram;
\li1 
\v 39 Amǝ'Shufam a nggurkwar mala muni Shefufam, andǝ
\li1 Amǝ'Hufam a nggurkwar mala muni Hufam.
\lim1 
\v 40 Amǝkà Bela nǝban amuni Arǝd andǝ Naaman ngga à nda ka:
\li3 Amǝ'Arǝd a nggurkwar mala Arǝd, andǝ
\li3 Amǝ'Naaman a nggurkwar mala Naaman.
\m 
\v 41 Amǝnia ka, à nda ka aɓala mala amuna andǝ amǝkà Benjami kǝla mana à ɓallia ka, aburana á-lumi-ine-bwamdǝ-á-tongno nǝ gbǝman-tongno-nong-mwashat (45,600).
\s1 Tàu mala Dan
\p 
\v 42 Amǝkà Dan arǝ anggurkwar malea ka à nda ka:
\li1 Amǝ'Shuham a nggurkwar mala muni Shuham.
\m Amǝnia ka, à nda ka aɓala mala muna andǝ amǝkà Dan arǝ anggurkwar malea.
\v 43 Amǝ'Shuham kat arǝ anggurkwar malea, kǝla mana à ɓallia ka, aburana á-lumi-tongno-nong-mwashat-bwamdǝ-á-ine nǝ gbǝman-ine na (64,400).
\s1 Tàu mala Asha
\p 
\v 44 Amǝkà Asha arǝ anggurkwar malea ka à nda ka:
\li1 Amǝ'Imǝna a nggurkwar mala muni Imǝna;
\li1 Amǝ'Ishvi a nggurkwar mala muni Ishvi, andǝ
\li1 Amǝ'Beriya a nggurkwar mala muni Beriya.
\lim1 
\v 45 Beriya ka amǝkè nda ka:
\li3 Amǝ'Heba a nggurkwar mala muni Heba, andǝ
\li3 Amǝ'Malkiyel a nggurkwar mala muni Malkiyel.
\li1 
\v 46 Asha ka ndanǝ muna-ɓwama, à tunǝki ama Sera.
\m 
\v 47 Amǝnia ka, à nda ka aɓala mala amuna andǝ amǝkà Asha kǝla mana à ɓallia ka, aburana á-lumi-tongno-bwamdǝ-á-tàrú nǝ gbǝman-ine (53,400).
\s1 Tàu mala Naftali
\p 
\v 48 Amǝkà Naftali arǝ anggurkwar malea ka à nda ka:
\li1 Amǝ'Jazil a nggurkwar mala muni Jazil;
\li1 Amǝ'Guni a nggurkwar mala muni Guni;
\li1 
\v 49 Amǝ'Jeza a nggurkwar mala muni Jeza, andǝ
\li1 Amǝ'Shilem a nggurkwar mala muni Shilem.
\m 
\v 50 Amǝnia ka, à nda ka aɓala mala amuna andǝ amǝkà Naftali kǝla mana à ɓallia ka, aburana á-lumi-ine nǝ á-tongno nǝ gbǝman-ine (45,400).
\s1 Làkkì malea kat-kat andǝ gau nzali
\p 
\v 51 Làkkì mala aburana mala amǝ Isǝrayila kat-kat ka, á-gbǝman-tongno-nong-mwashat nǝ á-mwashat nǝ gbǝman-tongno-nong-ɓari nǝ lumi-tàrú na (601,730).
\p 
\v 52 Yahweh banggi Musa ama,
\v 53 <<Awu nǝ gau nzali amur amǝnia ka, ɓǝ̀ duk girkuma malea, nǝ kpata làkkì mala alullǝ aɓwana mǝnana à ɓallia ka.
\v 54 Tàu mǝnana gul ka, kasǝia wia nzali liɓala kpǝm, sǝ tàu mǝnana kyau ka, kasǝia wia nzali liɓala bǝti; koya tàu ka ɓǝ̀ kum nzali kǝla mana làkkì mala aɓwana mana à ɓallia, pàk ka.
\v 55 Sǝama dumǝna púp ama nzali ka à nǝ̀ gakki nǝ bwal-shishar. Nzali liɓala mǝnana koya tàu nǝ̀ kum ngga awu nǝ kārǝi arǝ làkkì mala alullǝ aɓwana aɓalǝi.
\v 56 Gau nzali liɓala amur atau mǝgulke andǝ atau mǝkeke ka, awu nǝ kpate nǝ bwal-shishar.>>\f + \fr 26:56 \ft Ɓalli gbal aɓa: \xt Ɓal 33:53-54; 34:13; 36:2; Jes 14:2; 18:6-11; 19:51; 21:4-8; 1Kpa 6:61,63,65; Ang 78:55; Ezǝk 45:1\xt*\ft .\f*
\s1 Tàu mala Lawi
\p 
\v 57 Aɓwana mǝnana à ɓallia arǝ anggurkwar malea a tàu mala Lawi ka, à nda ka:
\li1 Amǝ'Gashon a nggurkwar mala muni Gashon;
\li1 Amǝ'Kohat a nggurkwar mala muni Kohat, sǝ
\li1 Amǝ'Merari a nggurkwar mala muni Merari.
\m 
\v 58 Anggurkwar mala Lawi ka, à nda ka:
\li1 Nggurkwar mala Amǝ'Libǝni;
\li1 Nggurkwar mala Amǝ'Hebǝron;
\li1 Nggurkwar mala Amǝ'Mali;
\li1 Nggurkwar mala Amǝ'Mushi, sǝ
\li1 Nggurkwar mala Amǝ'Kora.\f + \fr 26:58 \ft Ɓalli gbal aɓa: \xt Pur 6:21,24; Ɓal 3:17-20\xt*\ft .\f*
\p Kohat ka, nda kà Amram.\f + \fr 26:58 \ft Ɓalli gbal aɓa: \xt Pur 6:18-20\xt*\ft .\f*
\v 59 Mālá Amram ngga, nda Jochebet, mǝkà Lawi, mǝnana à ɓǝlî Lawi a Masar ka. Jochebet ɓǝlî Amram amuna mǝnia ka: Haruna andǝ Musa sǝ Miriyam mǝ'eambia muna-ɓwama.
\v 60 À ɓǝlî Haruna amuna-burana mǝnia ka: Nadap andǝ Abihu, andǝ Eleaza sǝ Itamar.\f + \fr 26:60 \ft Ɓalli gbal aɓa: \xt Pur 6:23; 24:1,9; 28:1; Ɓal 3:2,4; 1Kpa 6:3\xt*\ft .\f*
\v 61 Sǝama Nadap andǝ Abihu ka à yi wú lang à pàgir nǝ bǝsa mǝnana à earnǝi raka aɓadǝm Yahweh.\f + \fr 26:61 \ft Ɓalli gbal aɓa: \xt Pǝris 10:1-7; 1Kpa 24:1-2\xt*\ft .\f*
\m 
\v 62 Aburana mala Amǝ'Lawi mana à ɓallia, yià mǝnana twal a ɓǝlban malea ka à bingŋǝ́nà zongŋo mwashat aban ká dǝmba ka, à nda á-lumi-ɓari-bwamdǝ-tàrú (23,000). Yia ka à ɓallia atà aɓia amǝ Isǝrayila ɗàng acemǝnana à pea wia kǝ nzali liɓala ɗàng.
\p 
\v 63 Amǝnia ka à nda ka aɓwana mana Musa andǝ Eleaza pǝris ɓallia, lang à nda aban ɓal amǝ Isǝrayila a ɓawanban Mowap a kún Nggeasala Jodan a Jeriko ka.
\v 64 Sǝama aɓalǝ amǝnia yì aɓwana ka, kǝɓwa pà kàm atà aɓwana mala nza mǝnana Musa andǝ Haruna pǝris ɓal amǝ Isǝrayila a pǝɗanban Saina ka ɗàng.\f + \fr 26:64 \ft Ɓalli aɓa: \xt Ɓal 1:17-54; 3:39\xt*\ft .\f*
\v 65 Mǝnia ka nda acemǝnana Yahweh bángŋǝ́nià amǝno yì amǝ Isǝrayila ama à nǝ̀ wukio a ɓabondo, sǝ kǝɓwa pà kàm mana à nyi ka ɗàng, she Kalip muna-ɓwabura mala Jefune andǝ Jesǝwa muna-ɓwabura mala Nun.\f + \fr 26:65 \ft Ɓalli aɓa: \xt Ɓal 14:26-35\xt*\ft .\f*
\c 27
\s1 À pè amuna-mamǝna mala Zelofihat nzali
\p 
\v 1 Pǝlǝa aɓoarnsarile Zelofihat sungŋo a dǝmba; Zelofihat ka nda muna-ɓwabura mala Hefa, muna-ɓwabura mala Gilǝyat, muna-ɓwabura mala Makir, muna-ɓwabura mala Manasa, mana nda a ɓala-kàu mala Manasa muna-ɓwabura mala Yisǝfu ka. Alullǝ aɓoarnsarile ka à nda ka: Mahla, andǝ Noha, andǝ Hogǝla, andǝ Milka, sǝ Tǝrza.
\v 2 À came aɓadǝm Musa, andǝ Eleaza pǝris, andǝ aɓwana-mǝgule, andǝ ɓwabundǝa kat, a bankutio aɓa Tara Ban-peri, sǝ à bang ama,
\v 3 <<Tár sǝm wǔ a ɓabondo. Yì ka pà aɓalǝ aɓwana mala Kora, mana à ram rǝia arǝ Yahweh ka ɗàng; wǔ ace cauɓikea male, sǝ pànǝ kǝ muna-ɓwabura ɗang.
\v 4 Ace mana sǝ lullǝ tar sǝm nǝ̀ ndǝrmi anggo aɓa tàu male acemǝnana pànǝ muna-ɓwabura raka? Wu pà sǝm gìr liɓala atà amǝ'eam tár sǝm.>>
\p 
\v 5 Pǝlǝa Musa yinǝ cau malea aɓadǝm Yahweh,
\v 6 sǝ Yahweh ne wi ama,
\v 7 <<Cau mana aɓoarnsarile Zelofihat na ka nda jik. Dumǝna púp awu nǝ pea wia kāmbe malea mala nzali mana ɓǝ́ tárrià nǝ̀ kumo atà amǝ'eambi ka.
\v 8 Ne amǝ Isǝrayila ama, <Ɓǝ̀ ɓwa wǔ sǝ pànǝ muna-ɓwabura raka, muna-ɓwama male ɓǝ̀ liɓala male.
\v 9 Ɓǝ̀ pànǝ muna-ɓwama raka, amǝ'eambi aburana ɓǝà liɓala male.
\v 10 Sǝ ɓǝ̀ pànǝ amǝ'eambu aburana raka, awu nǝ pè amǝ'eam tárrí aburana kāmbe mala liɓala male.
\v 11 Ɓǝ̀ tárrí pànǝ mǝ'eambu ɓwabura raka, awu nǝ pè ɓǝla male mana nda tù abani a tàu male ka, ɓǝ̀ li nzali male.> Mǝnia ka nǝ̀ duk nê andǝ nggurcau aban amǝ Isǝrayila, kǝla mana Mim Yahweh ǝn banggo ka.>>
\s1 À twal Jesǝwa ɓǝ̀ duk ɓwamǝgule amur amǝ Isǝrayila
\p 
\v 12 Yahweh ne Musa ama, <<Eauwe amur nkono mǝnia ka, Nkono Abarim, sǝ wu sǝn nzali mǝnana ǝn pani amǝ Isǝrayila ka.
\v 13 Anzǝm mana a sǝnǝni ka, awu nǝ wǔ kǝla mala mǝ'eambo Haruna,
\v 14 acemǝnana wun kǝm ngga, wu ginǝ kpata cau mem aɓa pǝɗanban Zin. Lang ɓwabundǝa mgbicau arǝàm ngga, wu ɓinǝ pam gulo kǝla mǝfele a mǝsǝia a ban mùr.>> (Mùr mǝno ka nda mùr Meriba a Kadesh aɓa pǝɗanban Zin.)
\v 15 Musa ne Yahweh ama,
\v 16 <<Ɓǝ̀ Yahweh, Ɓakuli mala abangŋo mala aɓwana kat, twal ɓeɓwa amur ɓwabundǝa man,
\v 17 mǝnana nǝ̀ dupia wia a dǝmba, nǝ̀ gingnǝia aɓalǝ acau kat ka, ace mǝnana aɓwana mala Yahweh ɓǝà kǝa pa kǝla anzur mana à ɗwanyi yalu ka ɗàng.>>
\p 
\v 18 Osso Yahweh ne Musa ama, <<Twal Jesǝwa muna-ɓwabura mala Nun, ɓwa mǝnana Bangŋo na aɓalǝi ka, tsǝk buo amurí.
\v 19 Kyan nǝi kya tamsǝi aɓadǝm Eleaza pǝris sǝ a ɓadǝm ɓwabundǝa puppup, sǝ wu pe wi \f + \fr 27:19 \ft Ɓalli gbal aɓa: \xt Nggur 3:28; 31:7,8\xt*\ft .\f*gara mala pàktúró a mǝsǝia.
\v 20 Awu nǝ pe wi gara mala bancame mô, ace mǝnana ɓwabundǝa mala amǝ Isǝrayila kat ɓǝà oki wi ka.
\v 21 Ace súrǝ̀ nê mem ngga Jesǝwa nǝ̀ cam aɓadǝm Eleaza pǝris, mǝnana nǝ̀ paktúró nǝ Urim aɓadǝm Yahweh ace ɗìbancau aceì abanam ngga. Nǝ sà'arǝban male sǝ yì andǝ ɓwabundǝa mala amǝ Isǝrayila puppup ka à nǝ̀ puro, sǝ nǝ sà'arǝban male sǝ à nǝ̀ nyare.>>
\v 22 Musa pa kǝla mana Yahweh banggi wi ka. Warinǝ Jesǝwa sǝ kya tamsǝi aɓadǝm Eleaza pǝris, sǝ a ɓadǝm ɓwabundǝa puppup.
\v 23 Pǝlǝa tsǝki wi buì amurí sǝ tsǝì a túrô, kǝla mana Yahweh ne wi ka.
\c 28
\s1 Apagir mala koya pwari
\pi1 
\v 1 Yahweh banggi Musa ama,
\v 2 <<Nacau nǝ amǝ Isǝrayila sǝ wu banggia wia ama, <Wu sǝlǝa ma, wun nǝ̀ pà ɓoro mem, yì pàgir mala girlina mem, mǝnana à pè nǝ bǝsa, mala pà rǝmban mǝɓoarne mǝnana kǝ pwasǝbumam ngga; wun nǝ̀ pè a pwari mǝnana ǝn tsǝk ka.>
\v 3 Awu nǝ banggia wia ama, <Mǝnia ka nda pàgir nǝ bǝsa mǝnana wun nǝ̀ yinǝi abanam Yahweh ka:\f + \fr 28:3 \ft Ɓalli gbal aɓa: \xt Pur 29:38-41\xt*\ft .\f* amuna-gam ɓari mǝnana mbulea mwashat-mwashat sǝ kǝgìr mǝɓane pà kàm arǝia raka, kǝla pàgir mala pisǝe kǝring mana wun nǝ̀ nggǝ pa ba koya pwari ka.
\v 4 Wun nǝ̀ pà muna-gam mwashat nǝ dǝmbari, sǝ ɓè ka nǝ pwarikpǝra,
\v 5 atārǝia andǝ pàgir mala mǝsǝsa, tyang mwashat mala muku mǝɓǝlke mǝnana à zurì nǝ dù-lita mwashat mala mùrú olif ka.
\v 6 Mǝnia nda pàgir mala pisǝe kǝring mǝnana à nǝ̀ nggǝ pa pwari-pwari, mǝnana à kwakite a Nkono Saina ka. Pàgir na nǝ bǝsa abanam Yahweh ace pà rǝmban mǝɓoarne mǝnana kǝ pwasǝbumam ngga.
\v 7 A masǝlǝate ka, komǝye atà apa'girnkila mǝnia yià kǝm ngga, wun nǝ̀ so dù-lita mwashat mala mùr-anap amur gyangŋan, ɓǝ̀ duk pàgir mala girnùná mǝcandǝe abanam Yahweh a ban-mǝfele.
\v 8 Pàgir nǝ ɓaria muna-gam ngga, ɓǝà pè nǝ pwarikpǝra atārǝia andǝ pàgir mala mǝsǝsa andǝ pàgir mala girnùná mǝmwashati andǝ mǝnana wu pà nǝ dǝmbari ka. Mǝnia ka pàgir na nǝ bǝsa abanam Yahweh ace pà rǝmban mǝɓoarne mǝnana kǝ pwasǝbumam ngga.
\s1 Apagir mala Sabbat
\p 
\v 9 << <A pwari Sabbat ka, wun nǝ̀ pà amuna-gam ɓari mǝnana mbulea mwashat-mwashat sǝ ɓè kǝgìr mǝɓane pà kàm arǝia raka, andǝ pàgir mala mǝsǝsa, tyang ɓari mala muku mǝɓǝlke mana à zurì nǝ mùrú olif ka, andǝ pàgir mala girnùná male:
\v 10 Mǝnia ka nda pàgir mala pisǝe kǝring a koya pwari Sabbat, tsǝa-amur pàgir mala pisǝe kǝring mǝnana à pākiyi pwari-pwari ka, atārǝia andǝ pàgir mala girnùná male.
\s1 Apagir mala koya zongŋo
\p 
\v 11 << <A pwari mǝdǝmbe mala koya zongŋo ka, wun nǝ̀ yinǝ pàgir mala pisǝe kǝring abanam Yahweh: ajamnda ɓari, andǝ gam mwashat, andǝ amuna-gam tongno-nong-ɓari mana mbulea mwashat-mwashat sǝ ɓè kǝgir mǝɓane pà kàm arǝia raka.
\v 12 Atà koya jamnda ka wun nǝ̀ pà tyang tàrú mala muku mǝɓǝlke mana à zurì nǝ mùrú olif ka, ɓǝ̀ duk pàgir mala mǝsǝsa male; atà gam ngga wun nǝ̀ pà tyang ɓari mala muku mǝɓǝlke mana à zurì nǝ mùrú olif ka, ɓǝ̀ duk pàgir mala mǝsǝsa male;
\v 13 sǝ atà koya muna-gam ngga, wun nǝ̀ pà tyang mwashat mala muku mǝɓǝlke mana à zurì nǝ mùrú olif ka, ɓǝ̀ duk pàgir mala mǝsǝsa male. Mǝnia ka nda ace pàgir mala pisǝe kǝring, pàgir na nǝ bǝsa mala pà rǝmban mǝɓoarne abanam Yahweh mǝnana kǝ pwasǝbumam ngga.
\v 14 Wun nǝ̀ pà ɓoro mala girnùná, dù-lita ɓari mala mùr-anap atà koya jamnda, dù-lita mwashat nǝ gauwa-tsùrú male atà gam, sǝ dù-lita mwashat atà koya muna-gam. Mǝnia ka nda pàgir mala pisǝe kǝring, mala koya zongŋo aɓalǝ azongŋo mala pǝlǝa.
\v 15 Ɗǝm ngga wun nǝ̀ pà gbato mwashat abanam Yahweh ɓǝ̀ duk pàgir mala gǝshi cauɓikea; wun nǝ̀ pà mǝnia yì pàgir ka ɓǝ̀ tsǝa-amur pàgir mala pisǝe kǝring mǝnana à pākiyi pwari-pwari ka, atārǝia andǝ pàgir mala girnùná male.
\s1 Apagir mala Lamsan mala bǝredi // mana yis pà arǝì raka
\p 
\v 16 << <Lum-nong-inea pwari mala zongŋo mǝdǝmbe ka, nda pwari Yàlîmurû ace gusǝlǝam Yahweh.
\v 17 A lum-bwamdǝ-tongnoia pwari mala mǝnia yì zongŋo ka, à nǝ̀ tita lamsan; wun nǝ̀ twal anongŋo tongno-nong-ɓari, bǝredi mana yis pa arǝì raka nda wun nǝ̀ lì ka.
\v 18 A pwari mǝdǝmbe ka, wun nǝ̀ yiu ace ramba-banɓwáná mǝfele; pà wu nǝ̀ pàk kǝ túró mǝnana wu pàkiyi pwari-pwari ka ɗàng.
\v 19 A kún mani ka, wu pà ɓoro mala pisǝe kǝring, yì pàgir nǝ bǝsa abanam Yahweh: ajamnda ɓari, gam mwashat, sǝ amuna-gam tongno-nong-ɓari mana mbulea mwashat-mwashat, sǝ ɓè kǝgir mǝɓane pà kàm arǝia raka.
\v 20 Atà koya jamnda ka wu pà tyang tàrú mala muku mǝɓǝlke mana à zurì nǝ mùrú olif ka, ɓǝ̀ duk pàgir mala mǝsǝsa male; atà gam ngga wu pà tyang ɓari;
\v 21 sǝ atà koya mwashat atà amuna-gam tongno-nong-ɓari ka, wu pà tyang mwashat.
\v 22 Ɗǝm ngga wun nǝ̀ pà gbato mwashat ɓǝ̀ duk pàgir mala gǝshi cauɓikea, ace shawuɗi wun.
\v 23 Wun nǝ̀ pà amǝnia ka ɓǝà tsǝa-amur pàgir mala pisǝe kǝring mǝnana wu pākiyi pwari-pwari nǝ dǝmbari ka.
\v 24 Ani sǝ wun nǝ̀ pà girlina mala pàgir nǝ bǝsa koya pwari arǝ anongŋo tongno-nong-ɓari, ace pà rǝmban mǝɓoarne abanam Yahweh. Wun nǝ̀ pà amǝnia ka ɓǝà tsǝa-amur pàgir mala pisǝe kǝring, mǝnana wu pākiyi pwari-pwari atārǝia andǝ pàgir mala girnùná male ka.
\v 25 A tongno-nong-ɓaria pwari ka, wun nǝ̀ yiu ace ramba-banɓwáná mǝfele, sǝ pà wu nǝ̀ pàk kǝ túró mǝnana wu pàkiyi pwari-pwari ka ɗàng.
\s1 Apagir ace lamsan mala Alimo
\p 
\v 26 << <Lang wun nǝ̀ pàgir mala bǝsa mǝsǝsa a pwari mala aɓǝlagir-mǝdǝmbe abanam Yahweh, a tita lamsan mala alimo ka, wun nǝ̀ yiu ace ramba-banɓwáná mǝfele, sǝ pà wu nǝ̀ pàk kǝ túró mǝnana wu pàkiyi pwari-pwari ka ɗàng.
\v 27 A kún mani ka, wun nǝ̀ pàgir mala pisǝe kǝring, mala pa rǝmban mǝɓoarne abanam Yahweh: ajamnda ɓari, gam mwashat, sǝ amuna-gam tongno-nong-ɓari mana mbulea mwashat-mwashat ka;
\v 28 Atà koya jamnda ka wun nǝ̀ pà tyang tàrú mala muku mǝɓǝlke mana à zurì nǝ mùrú olif ka, ɓǝ̀ duk pàgir mala mǝsǝsa male; atà gam ngga wu pà tyang ɓari;
\v 29 sǝ atà koya mwashat atà amuna-gam tongno-nong-ɓari ka, wu pà tyang mwashat.
\v 30 Ɗǝm ngga wun nǝ̀ pà gbato mwashat ace shawuɗi wun.
\v 31 Wu pà amǝnia ka atārǝia andǝ apagir mala girnùná malea, ɓǝà tsǝa-amur pàgir mala pisǝe kǝring mǝnana wu pākiyi pwari-pwari ka atārǝia andǝ pàgir mala mǝsǝsa male. Wu tsǝkir wun ama agirkusǝu mǝnia ka ɓǝà kǝa pàngnǝ ɓè kǝgir mǝɓane arǝia ɗàng.
\c 29
\s1 Apagir mala Lamsan mala twanggi Anjawe
\p 
\v 1 << <A pwari mǝdǝmbe mala tongno-nong-ɓaria zongŋo ka, wun nǝ̀ yiu ace ramba-banɓwáná mǝfele. Pà wun nǝ̀ pàk kǝ túró mǝnana wu pàkkiyi pwari-pwari ka ɗàng. Nǝ̀ dupa wun pwari twanggi anjawe.
\v 2 Wun nǝ̀ yinǝ pàgir mala pisǝe kǝring abanam Yahweh ace pà rǝmban mǝɓoarne mǝnana kǝ pwasǝbumam ngga: jamnda mwashat, gam mwashat, sǝ amuna-gam tongno-nong-ɓari mana mbulea mwashat-mwashat, sǝ ɓekǝ gìr mǝɓane pà kàm arǝia raka.
\v 3 Sǝ pàgir mala mǝsǝsa malea ka, nǝ̀ duk muku mǝɓǝlke mǝnana à zurì nǝ mùrú olif ka: tyang tàrú ace jamnda, tyang ɓari ace gam,
\v 4 sǝ tyang mwashat ace koya mwashat atà muna-gam tongno-nong-ɓari.
\v 5 Ɗǝm ngga wun nǝ̀ pà gbato mwashat ɓǝ̀ duk pàgir mala gǝshi cauɓikea, ace shawuɗi wun;
\v 6 apagir mǝnia ka à nǝ̀ tsǝa-amur pàgir mala pisǝe kǝring mǝnana wu pākiyi a koya zongŋo andǝ pàgir mala mǝsǝsa male ka, andǝ pàgir mala pisǝe kǝring mǝnana à kǝ pà pwari-pwari ka, nǝ malea yì pàgir mala mǝsǝsa andǝ pagir mala girnùná malea kǝla mana nggurcau malea kanì ka; pàgir na nǝ bǝsa abanam Yahweh, mala pà rǝmban mǝɓoarne mǝnana kǝ pwasǝbumam ngga.
\s1 Agir'nkila a Pwari Mǝgule mala Twalban cauɓikea
\p 
\v 7 << <A lumia pwari mala mǝnia yì tongno-nong-ɓaria zongŋo ka, wun nǝ̀ yiu ace ramba-banɓwáná mǝfele, sǝ wun nǝ̀ ginǝì ɓamur rǝ wun agir. Pà wun nǝ̀ pàk kǝ túró aɓalǝi ɗàng.
\v 8 A kún mani ka, wun nǝ̀ yinǝ pàgir mala pisǝe kǝring abanam Yahweh, ace pà rǝmban mǝɓoarne mǝnana kǝ pwasǝbumam ngga: jamnda mwashat, gam mwashat, sǝ amuna-gam tongno-nong-ɓari mana mbulea mwashat-mwashat sǝ ɓekǝ gìr mǝɓane pà kàm arǝia raka.
\v 9 Sǝ pàgir mala mǝsǝsa malea ka, nǝ̀ duk muku mǝɓǝlke mana à zurì nǝ mùrú olif ka: tyang tàrú ace jamnda, tyang ɓari ace gam,
\v 10 sǝ tyang mwashat ace koya mwashat atà muna-gam tongno-nong-ɓari.
\v 11 Ɗǝm ngga wun nǝ̀ pà gbato mwashat ace pàgir mala gǝshi cauɓikea, ɓǝ̀ tsǝa-amur pàgir mala gǝshi cauɓikea ace shawuɗiban, andǝ pàgir mala pisǝe kǝring mǝnana à kǝ pa pwari-pwari ka, andǝ pàgir mala mǝsǝsa male, andǝ apagir mala girnùná malea.
\s1 Pàgir ace Lamsan mala Do aɓalǝ Agumli
\p 
\v 12 << <A lum-bwamdǝ-tongnoia pwari mala tongno-nong-ɓaria zongŋo ka, wun nǝ̀ yiu ace ramba-banɓwáná mǝfele, sǝ pà wun nǝ̀ pàk kǝ túró mǝnana wu pàkkiyi pwari-pwari ka ɗàng. Wun nǝ̀ pàk lamsan mala nongŋo tongno-nong-ɓari abanam Yahweh.
\v 13 Sǝ wun nǝ̀ yinǝ pàgir mala pisǝe kǝring, pàgir nǝ bǝsa, mala pà rǝmban mǝɓoarne abanam Yahweh, mǝnana kǝ pwasǝbumam ngga: ajamnda lum-nong-tàrú, agam ɓari, amuna-gam lum-nong-ine, mǝnana mbulea mwashat-mwashat, sǝ ɓekǝ gìr mǝɓane pà kàm arǝia raka;
\v 14 sǝ pàgir mala mǝsǝsa malea ka, nǝ̀ duk muku mǝɓǝlke mana à zurì nǝ mùrú olif ka: tyang tàrú ace komǝye atà ajamnda tongno-nong-tàrú, tyang ɓari ace komǝye atà agam ɓari,
\v 15 sǝ tyang mwashat ace koya mwashat atà amuna-gam lum-nong-ine;
\v 16 sǝ gbato mwashat ace pàgir mala gǝshi cauɓikea, ɓǝ̀ tsǝa-amur pàgir mala pisǝe kǝring mana à pākiyi pwari-pwari, andǝ pàgir mala mǝsǝsa male, andǝ pàgir mala girnùná male.
\p 
\v 17 << <A ɓaria pwari ka wun nǝ̀ pàgir nǝ ajamnda lum-nong-ɓari, agam ɓari, sǝ amuna-gam lum-nong-ine mǝnana mbulea mwashat-mwashat, sǝ ɓekǝ gìr mǝɓane pà kàm arǝia raka;
\v 18 atārǝia andǝ pàgir mala mǝsǝsa andǝ apagir mala girnùná ace ajamnda, ace agam, sǝ ace amuna-gam mǝnia ka, ɓǝà karǝa arǝ làkkì malea kǝla mana nggurcau kanì ka;
\v 19 sǝ gbato mwashat ace pagir mala cauɓikea, ɓǝ̀ tsǝa-amur pàgir mala pisǝe kǝring mǝnana à pākiyi pwari-pwari, andǝ pàgir mala mǝsǝsa male andǝ apagir mala girnùná malea.
\p 
\v 20 << <A tàruià pwari ka, wun nǝ̀ pà ajamnda lum-nong-mwashat, agam ɓari, sǝ amuna-gam lum-nong-ine mǝnana mbulea mwashat-mwashat sǝ ɓekǝ gìr mǝɓane pà kàm arǝia raka;
\v 21 atārǝia andǝ pàgir mala mǝsǝsa andǝ apagir mala girnùná ace ajamnda, ace agam, sǝ ace amuna-gam mǝnia ka, ɓǝà karǝa arǝ làkkì malea kǝla mana nggurcau kanì ka;
\v 22 andǝ gbato mwashat ace pàgir mala gǝshi cauɓikea, ɓǝ̀ tsǝa-amur pàgir mala pisǝe kǝring mǝnana à pākiyi pwari-pwari, andǝ pàgir mala mǝsǝsa male andǝ pàgir mala girnùná male.
\p 
\v 23 << <A inea pwari ka, wun nǝ̀ pà ajamnda lum, agam ɓari, sǝ amuna-gam lum-nong-ine mǝnana mbulea mwashat-mwashat sǝ ɓekǝ gìr mǝɓane pà kàm arǝia raka;
\v 24 atārǝia andǝ pàgir mala mǝsǝsa andǝ apagir mala girnùná ace ajamnda, ace agam, sǝ ace amuna-gam mǝnia ka, ɓǝà karǝa arǝ làkkì malea kǝla mana nggurcau kanì ka;
\v 25 andǝ gbato mwashat ace pàgir mala gǝshi cauɓikea, ɓǝ̀ tsǝa-amur pàgir mala pisǝe kǝring mǝnana à pākiyi pwari-pwari ka, andǝ pàgir mala mǝsǝsa male andǝ pàgir mala girnùná male.
\p 
\v 26 <<<A tongnoia pwari ka, wun nǝ̀ pà ajamnda tongno-nong-ine, agam ɓari, sǝ amuna-gam lum-nong-ine mǝnana mbulea mwashat-mwashat sǝ ɓekǝ gìr mǝɓane pà kàm arǝia raka;
\v 27 atārǝia andǝ pàgir mala mǝsǝsa andǝ apagir mala girnùná ace ajamnda, ace agam, sǝ ace amuna-gam mǝnia ka, ɓǝà karǝa arǝ làkkì malea kǝla mana nggurcau kanì ka;
\v 28 andǝ gbato mwashat ace pàgir mala gǝshi cauɓikea, ɓǝ̀ tsǝa-amur pàgir mala pisǝe kǝring mǝnana à pākiyi pwari-pwari, andǝ pàgir mala mǝsǝsa male andǝ pàgir mala girnùná male.
\p 
\v 29 << <A tongno-nong-mwashatia pwari ka, wun nǝ̀ pà ajamnda tongno-nong-tàrú, agam ɓari, sǝ amuna-gam lum-nong-ine mǝnana mbulea mwashat-mwashat sǝ ɓekǝ gìr mǝɓane pà kàm arǝia raka;
\v 30 atārǝia andǝ pàgir mala mǝsǝsa andǝ apagir mala girnùná ace ajamnda, ace agam, sǝ ace amuna-gam mǝnia ka, ɓǝà karǝa arǝ làkkì malea kǝla mana nggurcau kanì ka;
\v 31 andǝ gbato mwashat ace pàgir mala gǝshi cauɓikea, ɓǝ̀ tsǝa-amur pàgir mala pisǝe kǝring mǝnana à pākiyi pwari-pwari, andǝ pàgir mala mǝsǝsa male andǝ pàgir mala girnùná male.
\p 
\v 32 <<<A tongno-nong-ɓaria pwari ka, wun nǝ̀ pà ajamnda tongno-nong-ɓari, agam ɓari, sǝ amuna-gam lum-nong-ine mǝnana mbulea mwashat-mwashat sǝ ɓekǝ gìr mǝɓane pà kàm arǝia raka;
\v 33 atārǝia andǝ pàgir mala mǝsǝsa andǝ apagir mala girnùná ace ajamnda, ace agam, sǝ ace amuna-gam mǝnia ka, ɓǝà karǝa arǝ làkkì malea kǝla mana nggurcau kanì ka;
\v 34 andǝ gbato mwashat ace pàgir mala gǝshi cauɓikea, ɓǝ̀ tsǝa-amur pàgir mala pisǝe kǝring mǝnana à pākiyi pwari-pwari, andǝ pàgir mala mǝsǝsa male andǝ pàgir mala girnùná male.
\p 
\v 35 << <A tongno-nong-tàruià pwari ka, wun nǝ̀ ramba abanɓwáná ace peri. Pà wun nǝ̀ pàk kǝ túró mǝnana wu pàkkiyi pwari-pwari ka ɗàng;
\v 36 a kún mani ka, wun nǝ̀ pàgir mala pisǝe kǝring, pàgir nǝ bǝsa abanam Yahweh, ace pà rǝmban mǝɓoarne mǝnana kǝ pwasǝbumam ngga: jamnda mwashat, gam mwashat, sǝ amuna-gam tongno-nong-ɓari mǝnana mbulea mwashat-mwashat sǝ ɓekǝ gìr mǝɓane pà kàm arǝia raka;
\v 37 atārǝia andǝ pàgir mala mǝsǝsa andǝ apagir mala girnùná ace jamnda, ace gam, sǝ ace amuna-gam mǝnia ka, ɓǝà karǝa arǝ làkkì malea kǝla mana nggurcau kanì ka;
\v 38 andǝ gbato mwashat ace pàgir mala gǝshi cauɓikea, ɓǝ̀ tsǝa-amur pàgir mala pisǝe kǝring mǝnana à pākiyi pwari-pwari, andǝ pàgir mala mǝsǝsa male andǝ pàgir mala girnùná male.
\p 
\v 39 << <Wun nǝ̀ yinǝ apagir mǝnia ka abanam Yahweh arǝ apwari mala alamsan mǝnana à tsǝk ka, ɓǝà tsǝa-amur apagir mala pàcau nǝ-shambum ma'wun, andǝ apagir mala eare mala ɓabum wun, ace apagir mala pisǝe kǝring ma'wun, sǝ ace apagir mala mǝsǝsa ma'wun, sǝ ace apagir mala girnùná ma'wun, sǝ ace apagir mala dotarǝu ma'wun.> >>
\p 
\v 40 Musa bangcau nǝ amǝ Isǝrayila amur agir mǝnana kat Yahweh banggi wi ka.
\c 30
\s1 Anggurcau mala pàcau aban Yahweh
\p 
\v 1 Musa bangcau nǝ amúrû mala atau mala amǝ Isǝrayila ama, <<Mǝnia ka nda cau mǝnana Yahweh na ka.
\v 2 Ɓǝ̀ ɓwa pàcau nǝ-shambum abanam Yahweh, ko kùr ɓamurì nǝ kána ama nǝ̀ pàk gìr ka, ɓwe ɓǝkǝa nggaɗi kúni ɗàng; ɓǝ̀ pàk gìr mǝnana kat pur a kúni ka.
\p 
\v 3 <<Ɓǝ̀ ɓwama kǝla lo-ɓwa, mǝnana nda a ɓala mala tárrí, pàcau nǝ-shambum abanam Yahweh sǝ kùr ɓamurì nǝ kána amur ɓè gìr,
\v 4 sǝ tárrí ok pàcau nǝ-shambum male andǝ kána mǝnana kùrna ɓamurì nǝi, sǝ ne ɓwame kǝ cau raka, dumǝna púp ama ɓwame nǝ̀ lùmsǝ apacau male andǝ koya kána mǝnana kùrna ɓamurì nǝi ka.
\v 5 Sǝama ɓǝ̀ tárrí ɓinǝi wi a pwari mǝnana okce ka, ɓwame purni bwalban mala pàcau nǝ-shambum male, ko kána mǝnana kùrna ɓamurì nǝi ka. Sǝ Mim Yahweh ka, mǝ nǝ twali-wi-bani, acemǝnana tárrí ɓinǝni wi ka.
\p 
\v 6 <<Ɓǝ̀ ɓwama mǝnana malaká albura ɗang pàcau nǝ-shambum, ko mburkuni kaurǝa pàcau mǝnana kùr ɓamurì nǝi, sǝ nǝnzǝ́mò ka, yi albura,
\v 7 sǝ burí okce ka; sǝ lang burí okce ka ne wi kǝ cau amurí raka, dumǝna púp ɓwame nǝ̀ lùmsǝ pàcau nǝ-shambum male andǝ kána mǝnana kùrna ɓamurì nǝi ka.
\v 8 Sǝama ɓǝ̀ burí ɓinǝì wi, lang okce ka, burí nǝ̀ panzǝi ɓǝ̀ purî mǝno yì pàcau nǝ-shambum amurí, andǝ cau mǝnana mburkuni bangŋi aɓa kaurǝa sǝ kùrna ɓamurì nǝi ka. Sǝ Mim Yahweh ka, mǝ nǝ twali-wi-bani.
\p 
\v 9 <<Sǝama mā-lú ko ɓwama mana à gauwuna doɓala ka, dumǝna púp nǝ̀ bwal koya pàcau nǝ-shambum mǝnana twal andǝ kána mǝnana kùrna ɓamurì nǝi ka.
\p 
\v 10 <<Sǝ ɓǝ̀ ɓwama mǝnana nda a ɓala mala burí pàcau nǝ-shambum, ko kùr ɓamurì nǝ kána,
\v 11 sǝ burí okce sǝ na kǝ cau ɗang, sǝ ɓinǝi wi raka, dumǝna púp ɓwame nǝ̀ lùmsǝ gìr mǝnana kat pàcau ace nǝ-shambum, ko kána mǝnana kùrna ɓamurì nǝi ka.
\v 12 Sǝama ɓǝ̀ burí pǝrki arǝ lùmsǝ mǝno yì pàcau nǝ-shambum, a pwari mǝnana okce ka, gìr mǝnana kat pur a kún ɓwame amur pàcau nǝ-shambum male, ko amur kána mǝnana kùrna ɓamurì nǝi ka, pà nǝ̀ cam ɗang. Sǝ Mim Yahweh ka, mǝ nǝ twali-wi-bani, acemǝnana burí ɓinǝni wi ka.
\v 13 Bura ɓwama nǝ̀ gandǝ eari wi, sǝ nǝ̀ gandǝ ɓinǝi wi arǝ koya pàcau nǝ-shambum ko kána mǝnana twalo nǝ̀ ginǝi ɓamurì gìr ka.
\v 14 Sǝama ɓǝ̀ burí na kǝ cau ɗàng, nongŋo anzǝm nongŋo ka, lǝmdǝ ama earna nǝ apacau nǝ-shambum kat andǝ akána mǝnana kat amur māmí ka. Ɗwanyi na kǝ cau male aban māmí lang ok acê ka lǝmdǝ ama earna nǝia.
\v 15 Sǝama ɓǝ̀ tamsǝ māmí arǝ lùmsǝ amǝno yì apacau ko akána, anzǝm mǝnana okce ka, dumǝna púp bafe mala cauɓikea mala māmí nǝ̀ pà amurí.>>
\p 
\v 16 Amǝnia ka à nda ka anggurcau mana Yahweh pe Musa amur cau mala ɓwabura andǝ māmí, sǝ amur cau mala tárrû andǝ nsarile mǝnana lo-ɓwa na piu a ɓala mala tárrí ka.
\c 31
\s1 Mbweban-tanni amur amǝ Midiyan
\p 
\v 1 Sǝ Yahweh nacau nǝ Musa, ama,
\v 2 <<Kyan nǝ mbweban-tanni amur amǝ Midiyan ace gìr mǝnana à pàkkî amǝ Isǝrayila ka.\f + \fr 31:2 \fq amǝ Midiyan ace gìr mǝnana à pàkkî amǝ Isǝrayila ka; \ft ɓalli aɓa: \xt Ɓal 25:1-18\xt*\ft .\f* Anzǝm mana a pángŋǝ̀nà mǝno ka, sǝ awu nǝ wǔ a nǝ o atà akeô.>>\f + \fr 31:2 \ft Ɓalli gbal aɓa: \xt Ɓal 20:24-26; 27:13; Nggur 32:50\xt*\ft .\f*
\p 
\v 3 Pǝlǝa Musa bangcau nǝ aɓwana ama, <<Wu twal aburana aɓalǝ wun ɓǝà mārǝ́ rǝia ace kánǝ lwa arǝ amǝ Midiyan, ace pa mbweban-tanni mala Yahweh\f + \fr 31:3 \ft Ɓalli aɓa: \xt Ang 18:47; 79:10; 94:1; Ir 11:20\xt*\ft .\f* amur amǝ Midiyan.
\v 4 Aburana á-mwashat ɓǝà puro a koya tàu mala Isǝrayila sǝ wun nǝ tasǝia aban ká lwa.>>
\v 5 Nda à tàrki aburana á-lum-nong-ɓari (12,000) mǝnana à marǝna rǝia ace lwa ka, aburana á-mwashat a koya tàu mala amǝ Isǝrayila.
\v 6 Sǝ Musa tasǝia ɓǝà kya lwa-lwa, amǝ'lwa á-mwashat a koya tàu, atārǝia andǝ Finehas muna-ɓwabura mala Eleaza pǝris, mǝnana twal atanggǝla mala ban-mǝfele, andǝ anjawe tunǝban ace lwa ka, a buì.
\v 7 À lwa-lwa arǝ amǝ Midiyan, kǝla mana Yahweh banggi Musa ka, sǝ à wal-lú koya ɓwabura.
\v 8 Atà acili aɓwana mǝnana à walia ka, à wal amurǝma mala amǝ Midiyan: Evi, andǝ Rekem, andǝ Zur, andǝ Hur, andǝ Reba, yìa ka amurǝma na tongno mala amǝ Midiyan.\f + \fr 31:8 \ft Ɓalli gbal aɓa: \xt Jes 13:21-22\xt*\ft .\f* Sǝ Bil'am muna-ɓwabura mala Beyo\f + \fr 31:8 \ft Ɓalli aɓa: \xt Ɓal 22:5--24:25\xt*\ft .\f* gbal ka à wal-luí nǝ nggeabyau.
\v 9 Amǝ Isǝrayila bwalki amamǝna andǝ amuna mǝkeke mala amǝ Midiyan. À pwan adomwan mala andá andǝ anzur andǝ ambul malea, andǝ agirkuma malea kat kǝla gǝna-lwa.
\v 10 À pisǝki alá andǝ abân mǝnana kat amǝ Midiyan duk kam ngga, kat andǝ akàttì malea.
\v 11 À pwan gǝna-lwa kat andǝ aguro-lwa kat, mala aɓwapǝndǝa andǝ agirkusǝu, à umnǝia.
\v 12 À yinǝ aɓwana mǝnana à bwalia kǝla aguro-lwa ka, andǝ akume-lwa aban Musa andǝ Eleaza pǝris, andǝ ɓwabundǝa mala amǝ Isǝrayila, a là-gumli a ɓawanban mala nzali Mowap, a nkanggari nggeasala Jodan a nkaring Jeriko.
\p 
\v 13 Musa andǝ Eleaza pǝris, andǝ aɓwana-mǝgule mala ɓwabundǝa puro ace ká kullia anzǝm là-gumli.
\v 14 Sǝ Musa ka pak-bumlulla nǝ amǝgulo mala amǝ'lwa, andǝ aburana mǝnana à nda ka amǝ'sàrǝ̀ban amur á-á mala amǝ'lwa andǝ amana amur gbǝman-gbǝman mala amǝ'lwa, mǝnana à nyàrî lwa ka.
\p 
\v 15 Ɗia ama, <<Ace mana sǝ wu nying amamǝna mǝnia ka kat nǝyilǝmu?
\v 16 Kǝ à nda mǝnana à kpata kanigir mala Bil'am\f + \fr 31:16 \fq kanigir mala Bil'am \ft Ɓalli gbal aɓa: \xt Ɓal 24:14; 2Bit 2:15; Sǝn 2:14\xt*\ft .\f*\f + \fr 31:16 \ft Ɓalli aɓa: \xt Ɓal 25:1-9\xt*\ft .\f* sǝ à tsǝk amǝ Isǝrayila à dumnǝ ɗwanyi-mǝsǝcau arǝ Yahweh atàcau mala Piyor ka re? Yià na à tsǝa sǝ kwánó-twàl-là wal ɓwabundǝa mala Yahweh ka.\f + \fr 31:16 \ft Ɓalli aɓa: \xt Ɓal 25; Nggur 20:18; 2Bit 2:15; Sǝn 2:14\xt*\ft .\f*
\v 17 Adyan ngga, wu wal-lú amuna aburana. Sǝ wu wal-lú koya ɓwama mǝnana súrǝ́nà ɓwabura ka.
\v 18 Sǝ amuna mamǝna mǝnana à malaká súrǝ̀ ɓwabura raka, wu ɗekia nǝyilǝmu ace ɓamurǝ wun.\f + \fr 31:18 \ft Ɓalli gbal aɓa: \xt Nggur 21:10-14\xt*\ft .\f*
\v 19 Koyan atà wun mǝnana wal-lú kǝɓwa ko je lú ka, dumǝna púp nǝ̀ do anzǝm kàttì ba nongŋo tongno-nong-ɓari. A tàruià nongŋo andǝ tongno-nong-ɓaria nongŋo ka, dumǝna púp wun nǝ̀ lak ɓamur rǝ wun andǝ aguro-ɓwa ma'wun.
\v 20 Sǝ koya gìr'nggūrǝu ma'wun gbal ka wun nǝ̀ le, kat andǝ koya gìr mǝnana à pè nǝ nggú, andǝ koya gìr mǝnana à pè nǝ nyang mbul, andǝ koya gìr mǝnana à pè nǝ nggun ngga.>>
\p 
\v 21 Pǝlǝa Eleaza pǝris banggi amǝlwa mǝnana à wari a lwa ka, ama, <<Mǝnia ka nda nê mala nggurcau mǝnana Yahweh pè Musa ka:
\v 22-23 Koya gìr mǝnana nǝ̀ gandǝ cambi bǝsa, kǝla bolo-njengǝlan, andǝ bolo-azǝrfa, andǝ bolo-bángŋá, andǝ bolo-candǝa, andǝ bolo-gwan'gwang, andǝ bolo-dànà ka, wun nǝ̀ oasǝi a bǝsa, sǝ nǝ̀ ɓoarnsari. Sǝama dumǝna púp wun nǝ̀ lé nǝ mùr lakban gbal. Sǝ gìr mǝnana kat pà nǝ̀ gandǝ cambi bǝsa raka, wun nǝ̀ lé nǝ mùr mǝno.
\v 24 A tongno-nong-ɓaria pwari ka, wun nǝ̀ lakki agir-nggūrǝu ma'wun, sǝ wun nǝ̀ ɓoarnsari. Anzǝm mǝno ka wun nǝ̀ gandǝ kùtí a kàttì.>>
\s1 Gau gǝna-lwa
\p 
\v 25 Yahweh banggi Musa ama,
\v 26 <<We wunǝ Eleaza pǝris, wunǝ aɓwana-mǝgule amur aɓala-kàu mala ɓwabundǝa, wu gilǝ koman mǝnana kat à pwani arǝ amǝ Midiyan ngga, kat andǝ aɓwapǝndǝa andǝ agirkusǝu,
\v 27 sǝ wu gau gǝna-lwa arǝ abanì ɓari; banì mwashat ace amǝ'lwa mǝnana à wari a munǝo ka, sǝ ɓè banì ka ace cili ɓwabundǝa.
\v 28 Aɓa gìr mǝnana mala amǝ'lwa na ka, wu pusǝ mwashat aɓa koya gbǝman-tongno mala aguro-ɓwa, andǝ mwashat aɓa koya gbǝman-tongno mala andá, andǝ mala amǝdambǝriso, andǝ mala anzur, andǝ mala ambul, sǝ wu tsǝia ɗàng ace pà cemi aban Yahweh.
\v 29 Twal agir cemi mǝnia mǝnana à pusǝì aɓa kāmbe mala amǝ'lwa ka sǝ wu pe Eleaza pǝris, ɓǝ̀ duk gìr pǎ aban Yahweh.
\v 30 Aɓa kāmbe mǝnana nda ace amǝ Isǝrayila ka, twal mwashat aɓa koya lumi-tongno mala aguro-ɓwa, andǝ mala andá, andǝ mala amǝdambǝriso, andǝ mala anzur, andǝ mala ambul, yì anyam-lǝsǝa kat, sǝ wu pê Amǝ'Lawi mǝnana à pàkkiyi túró ɓá Taragula mala Yahweh ka.>>
\v 31 Nda Musa andǝ Eleaza pǝris pàk kǝla mǝnana Yahweh banggi Musa ka.
\v 32 Cili gir mǝnana ueo aɓa gǝna-lwa mǝnana amǝ'lwa pwan ngga nda:
\li1 anzur á-gbǝman-tongno-nong-mwashat nǝ á-lumi-tongno-nong-ɓari nǝ á-tongno (675,000),
\li1 
\v 33 andá á-lumi-tongno-nong-ɓari nǝ á-ɓari (72,000),
\li1 
\v 34 amǝdambǝriso á-lumi-tongno-nong-mwashat nǝ á-mwashat (61,000),
\li1 
\v 35 ansarina mǝnana à malaká súrǝ̀ ɓwabura raka á-lumi-tàrú nǝ á-ɓari (32,000).
\p 
\v 36 Sǝ kāmbe mǝnana kúti a bu amǝ'lwa ka:
\li1 anzur á-gbǝman-tàrú nǝ á-lumi-tàrú-bwamdǝ-tongno-nong-ɓari nǝ gbǝman-tongno (337,500) na,
\li1 
\v 37 sǝ cemi mala anzur ace Yahweh ka gbǝman-tongno-nong-mwashat nǝ lumi-tongno-nong-ɓari nǝ mǝsǝi tongno (675) na.
\li1 
\v 38 Andá ka á-lumi-tàrú-bwamdǝ-tongno-nong-mwashat na (36,000),
\li1 sǝ aɓalǝia ka à pusǝ cemi, andá á-tongno-nong-ɓari nǝ mǝsǝi ɓari (72) ace Yahweh.
\li1 
\v 39 Amǝdambǝriso ka á-lumi-tàrú nǝ gbǝman-tongno na (30,500),
\li1 sǝ aɓalǝia ka à pusǝ cemi, amǝdambǝriso lumi-tongno-nong-mwashat nǝ mǝsǝi mwashat (61) ace Yahweh.
\li1 
\v 40 Aguro-ɓwa ka, á-lum-bwamdǝ-tongno-nong-mwashat na (16,000),
\li1 sǝ aɓalǝia ka à pusǝ cemi, aguro-ɓwa lumi-tàrú nǝ mǝsǝi ɓari (32) ace Yahweh.
\m 
\v 41 Pǝlǝa Musa pè Eleaza pǝris cemi mǝnia ɓǝ̀ duk pàgir aban Yahweh, kǝla mǝnana Yahweh banggi Musa ka.
\p 
\v 42 Kāmbe mǝnana nda ace amǝ Isǝrayila, mǝnana Musa tàrì tsǝì ɗàng nǝ mala amǝ'lwa mana à wari a munǝo,
\v 43 yì kāmbe mala ɓwabundǝa ka nda ani:
\li1 anzur á-gbǝman-tàrú nǝ á-lumi-tàrú-bwamdǝ-tongno-nong-ɓari nǝ gbǝman-tongno (337,500),
\li1 
\v 44 andá á-lumi-tàrú-bwamdǝ-tongno-nong-mwashat (36,000),
\li1 
\v 45 amǝdambǝriso á-lumi-tàrú nǝ gbǝman-tongno (30,500),
\li1 
\v 46 ansarina á-lum-bwamdǝ-tongno-nong-mwashat (16,000).
\m 
\v 47 Aɓa kāmbe mala amǝ Isǝrayila ka Musa tàrki mwashat-mwashat aɓa koya lumi-tongno mala ansarina andǝ mala agirkusǝu, sǝ kǝla mǝnana Yahweh banggi wi ka, pè Amǝ'Lawi mǝnana à kǝ tsǝkir Taragula mala Yahweh ka.
\p 
\v 48 Pǝlǝa amǝgulo mala amǝ'lwa andǝ amǝ'sàrǝ̀ban mǝnana amur amǝ'lwa á-á, andǝ amǝ'sàrǝ̀ban amur amǝ'lwa gbǝman-gbǝman ngga à yiu aban Musa.
\v 49 À banggi wi ama, <<Sǝm aguro mò ka sǝm ɓalna amǝ'lwa mǝnana à wari a munǝo aɓata sǝm ngga, sǝ kǝɓwa pà kàm mǝnana ɓwar aɓalǝ sǝm ngga ɗàng.
\v 50 Sǝ ndya sǝm yinǝi Yahweh ɓoro mala agir njengǝlan mǝnana koyan atà sǝm pwan ngga; ambaga, andǝ agirgarabu, andǝ agirmunabu, andǝ agirkiru, sǝ anlang-ɓamyalu. Mǝnia ka nda ace shawuɗi ayilǝmi sǝm aɓadǝm Yahweh.>>
\p 
\v 51 Sǝ Musa andǝ Eleaza pǝris ak agir mǝno kat à tùllia nǝ bolo-njengǝlan ngga a buia.
\v 52 Dǝmbǝrya mala bolo-njengǝlan mǝnana amǝ'sàrǝ̀ban amur amǝ'lwa á-á, andǝ amǝ'sàrǝ̀ban amur amǝ'lwa gbǝman-gbǝman yinǝi sǝ à pà ɓoro nǝi aban Yahweh kat-kat ka, shekel á-lum-bwamdǝ-tongno-nong-mwashat nǝ gbǝman-tongno-nong-ɓari nǝ lumi-tongno na (16,750).
\v 53 Koya mǝ'lwa ka pwan gǝna-lwa ace ɓamurì.
\v 54 Sǝ Musa andǝ Eleaza pǝris ka à ak bolo-njengǝlan mǝno a bu amǝ'sàrǝ̀ban amur amǝ'lwa á-á, andǝ amǝ'sàrǝ̀ban amur amǝ'lwa gbǝman-gbǝman, sǝ à yinǝi aɓa Tara Ban-peri, ace mǝnana ɓǝ̀ duk gìr kasǝɓalǝu\f + \fr 31:54 \ft Ɓalli gbal aɓa: \xt Pur 30:16\xt*\ft .\f* aɓadǝm Yahweh ka.
\c 32
\s1 Atau a njartakuli mala Nggeasala Jodan
\p 
\v 1 Aɓwana a tàu mala Ruben andǝ tàu mala Gad ka à ndanǝ agirkusǝu kǝ̀rkǝ́r mǝnana à kǝ yália ka. Lang à sǝni ama nzali Jaza andǝ nzali Gilǝyat ka abân mǝɓoarne na ace yál agirkusǝu ka,
\v 2 à wari aban Musa andǝ Eleaza pǝris, sǝ aban aɓwana-mǝgule mala ɓwabundǝa, sǝ à bang ama,
\v 3 <<Bu-nzali mala alá Atarot, Dibon, andǝ Jaza, andǝ Nimra, andǝ Heshbon, andǝ Eleyale, andǝ Sebam, andǝ Nebo, sǝ Beyon,
\v 4 yì nzali mǝnana Yahweh lì nǝ lwa aɓadǝm ɓwabundǝa mala amǝ Isǝrayila ka, nzali mǝɓoarne na ace yál agirkusǝu, sǝ sǝm aguro mò ka, sǝm ndanǝ andá, andǝ ambulpǝndǝa andǝ anzur pas.
\v 5 Ida, pà sǝm nzali man ɓǝ̀ duk girkuma ma'sǝm. Kǝa kyan nǝ sǝm a nkaring Nggeasala Jodan ɗàng.>>
\p 
\v 6 Sǝ Musa earî aburana mala tàu mala Gad andǝ aburana mala tàu mala Ruben, ama, <<Wu kǝ earce ama wun nǝ̀ duk kani sǝ cili amǝ'eam wun amǝ Isǝrayila ka ɓǝà o a lwa le?
\v 7 Ace mana sǝ wun nǝ̀ ɓungi ɓabum amǝ Isǝrayila arǝ eauwe a nkaring aban ká aɓa nzali mǝnana Yahweh pania wia ka?
\v 8 Mǝnia nda gìr mǝnana aká wun pǎ lang ǝn turia a Kadesh-Baniya ɓǝà kya sǝn nzalî ka.
\v 9 Lang à warina a ɓangŋaban Eshkol sǝ à sǝna nzalî ka, à ɓungi ɓabuma amǝ Isǝrayila arǝ ká aɓa nzali mǝnana Yahweh angŋa dǝmba pània wia ka.
\v 10 Nda bumlulla mala Yahweh earke a pwari mǝno, sǝ kángìr ama,
\v 11 <Acemǝnana aburana mǝno à pur a Masar, mǝnana pǝlǝa malea lumi-ɓari aban ká dǝmba, mǝnana à kpatam nǝ ɓabumia kat raka, mǝsǝcau kǝɓwa pà kàm ateà mǝnana nǝ̀ sǝn nzali mana ǝn kángìr ama mǝ nǝ pè Ibǝrayim, sǝ Ishaku, sǝ Yakupu ka ɗàng,
\v 12 she Kalip muna-ɓwabura mala Jefune ɓwa-Keniz, andǝ Jesǝwa muna-ɓwabura mala Nun; kǝ yia nǝmurǝia à nda mǝnana à kpatam nǝ ɓabumia mwashat ka.>
\v 13 Nda bumlulla mala Yahweh earbǝsa arǝ Isǝrayila, tsǝa à camarǝ gali a ɓabondo apǝlǝa lumi-ine, she lang nza mala aɓwana mǝnana à pàk ɓealɓikea a ɓamǝsǝ Yahweh ka, teà twalna ka.
\v 14 Sǝ ado ka, wun yì bǝsa nza mala amǝ'cauɓikea ka, ndya wu longŋǝ́nà a kusǝ aká wun, ace tsǝk bumlulla kàm piu amur bumlulla mǝ'earke mala Yahweh arǝ Isǝrayila ka!
\v 15 Ɓǝ̀ wu pǝlǝ nzǝm wun arǝ kpate ka, nǝ̀ vwakibuì ɗǝm arǝ aɓwana mǝnia ka a ɓabondo, sǝ à nǝ̀ bwal wun nǝ cau mala yinǝ kiɗiki malea.>>
\p 
\v 16 Pǝlǝa à sungŋo a baní sǝ à na ama, <<Sǝm nǝ̀ ɓakki ankāndan ace agirkusǝu ma'sǝm akani, sǝ sǝm nǝ̀ gumbǝli anggea-là nǝ asheran ace amuna mǝkeke ma'sǝm;
\v 17 sǝ sǝm ngga, sǝm nǝ̀ kùr rǝ sǝm aɓa gilǝrǝu ace ká lwa, sǝ sǝm nǝ̀ akì acili atau mala Isǝrayila dǝmba aban kánǝ munǝo sheɓǝ̀ sǝm yina nǝia à dumǝna a ban mǝnana nǝ̀ duk malea ka. Anggo ka amuna mǝkeke ma'sǝm nǝ̀ do aɓalǝ anggea-là mǝnana sǝm gumbǝlinia nǝ asheran ngga ace yália arǝ aɓwana mala nzali man.
\v 18 Sǝm ngga, pà sǝm nǝ̀ nyare arǝ aɓala ma'sǝm ɗàng, she pwari mǝnana koya ɓwa Isǝrayila kumǝna nzali liɓala male ka.
\v 19 Sǝm ngga, pà sǝm nǝ̀ twal kǝ nzali liɓala sǝnǝia a nkaring Nggeasala Jodan andǝ ban mǝnana o a dǝmba ka ɗàng, acemǝnana sǝm angŋa dǝmba sǝm kumǝna nzali liɓala ma'sǝm a mǝnia yì buì mala Nggeasala Jodan a njartakuli ka.>>
\p 
\v 20 Pǝlǝa Musa banggia wia ama, <<Ɓǝ̀ mbak wun nǝ̀ pàk mǝnia ka, akani aɓadǝm Yahweh, wu kùr rǝ wun ace ká lwa.
\v 21 Wun aburana mǝnana wu kùrna rǝ wun ngga, wun nǝ̀ yàlî nggeasala Jodan aɓadǝm Yahweh, ace kánǝ munǝo arǝ aɓimǝbura bà pwari mǝnana Yahweh linamurǝm amúrià,
\v 22 sǝ nzalî ka à yinanǝi aɓata rǝcandǝa mala Yahweh ka. Anzǝm mǝno ka wun nǝ̀ gandǝ nyare wun nǝ̀ o, acemǝnana anggo ka wu lùmsǝ̀nà túró ma'wun aban Yahweh, sǝ aban Isǝrayila. Sǝ nzali mǝnia ka nǝ̀ duk girkuma ma'wun aɓadǝm Yahweh.
\v 23 Sǝama ɓǝ̀ pà wun nǝ̀ pàk anggo raka, mǝsǝcau wu pàngŋǝ́nì Yahweh cauɓikea, sǝ ɓǝ̀ wu sǝlǝa ama cauɓikea ma'wun nǝ̀ pusǝta wun.
\v 24 Wu gumbǝlî amuna mǝkeke ma'wun anggea-là nǝ asheran, sǝ wu ɓakkî agirkusǝu ma'wun ankāndan, sǝ wu pàk gìr mǝnana wu pàcau ama wun nǝ̀ pàk ka.>>
\p 
\v 25 Pǝlǝa aburana mala tàu mala Gad andǝ aburana mala tàu mala Ruben banggi Musa ama, <<Sǝm aguro mò ka, sǝm nǝ̀ pa kǝla mǝnana we ɓwamǝgule ma'sǝm a bang ngga.
\v 26 Amuna ma'sǝm, andǝ amālá sǝm, andǝ anzur andǝ ambul ma'sǝm, andǝ andá ma'sǝm kat ka, à nǝ̀ ue kani aɓalǝ anggea-là mala Gilǝyat;
\v 27 sǝ sǝm aguro mò, koya ɓwabura mǝnana kùrna rǝì ace lwa ka, nǝ̀ yàl a nkaring Jodan ace ká munǝo aɓadǝm Yahweh, kǝla mǝnana we ɓwamǝgule ma'sǝm a bang ngga.>>
\p 
\v 28 Pǝlǝa Musa bangcau nǝ Eleaza pǝris, andǝ Jesǝwa muna-ɓwabura mala Nun, andǝ aɓwana-mǝgule amur aɓala-kàu mala atau mala amǝ Isǝrayila, amúr cau mala aburana mǝno ka.
\v 29 Musa banggia wia ama, <<Ɓǝ̀ aburana mala tàu mala Gad andǝ aburana mala tàu mala Ruben, koyan mǝnana kùrna rǝì ace ká lwa ka, nǝ̀ yàlî Jodan atarǝ wun wunǝia aɓadǝm Yahweh, sǝ à nǝ̀ bwala wun nggam sheɓǝ̀ nzalî nyarna aɓata wun ngga, wun nǝ̀ pea wia nzali Gilǝyat ɓǝ̀ duk girkuma malea.
\v 30 Sǝ ɓǝ̀ à yàlî Jodan atà wun aɓa kùrrǝu raka, dumǝna púp à nǝ̀ pea wia kāmbe mala girkuma aɓa nzali Kan'ana, kǝla mana wun nǝ̀ kum ngga.>>
\v 31 Pǝlǝa aburana mala tàu mala Gad andǝ aburana mala tàu mala Ruben, ear ama, <<Gìr mǝnana Yahweh bangga sǝm, sǝm aguro mò ka, nda gìr mǝnana sǝm nǝ̀ pàk ka.
\v 32 Sǝm nǝ̀ yàlî Jodan nǝ agirbura aɓadǝm Yahweh ace ká munǝo aɓa nzali Kan'ana. Sǝama nzali mǝnana nǝ̀ duk girkuma ma'sǝm ace liɓala ka, nǝ̀ pàk kani a nkaring Jodan.>>
\p 
\v 33 Nda Musa pè aburana mala tàu mala Gad, andǝ aburana mala tàu mala Ruben, andǝ aburana mala gauwa-tsùrú mala tàu mala Manasa, muna-ɓwabura mala Yisǝfu, bu-nzali andǝ anggea-là andǝ abân mǝnana à kària ka, mǝnana ɗiɗyal ka à nda aɓata domurǝm mala Sihon, murǝm mala amǝ'Amor ka, andǝ bu-nzali andǝ anggea-là andǝ abân mǝnana à kària, mǝnana ɗiɗyal ka à nda aɓata domurǝm mala Og murǝm Bashan ngga. Pea wia nzali mǝno kat, andǝ anggea-là mǝnana aɓalǝi ka andǝ abân mǝnana kat à kària ka.
\p 
\v 34 Pǝlǝa aburana a tàu mala Gad ɓǝsǝlǝ ɓak alá Dibon, andǝ Atarot, andǝ Aruwa,
\v 35 andǝ Atǝrot-Shofan, andǝ Jaza, andǝ Jogbeha,
\v 36 andǝ Bet-Nimra andǝ Bet-Haran. À ɓakki asheran à gumbǝli anggea-lê, sǝ à ɓakki ankāndan ace tsǝk ambul andǝ anzur malea.
\p 
\v 37 Aburana a tàu mala Ruben ɓǝsǝlǝ ɓak alá Heshbon, andǝ Eleyale, andǝ Kiriyatem,
\v 38 andǝ Nebo, andǝ Baal-Meyon, andǝ Sipma. Lang à ɓǝsǝlǝ ɓak Nebo andǝ Baal-Meyon ngga, à nggaɗì anggea-là mǝnia alullǝia.
\p 
\v 39 Sǝ amǝkà Makir muna-ɓwabura mala Manasa ka, à o a Gilǝyat, à kya ak nzalinì arǝ amǝ'Amor mǝnana à do aɓalǝi ka.
\v 40 Nda Musa pè amǝkà Makir bu-nzali Gilǝyat, sǝ à do aɓalǝi ka.
\p 
\v 41 Sǝ Jayir a tàu mala Manasa wario kya ak amuna-là a bu-nzali mǝno sǝ pea wia bǝsa lullǝu ama Havot-Jayir.\f + \fr 32:41 \fq Havot-Jayir: \ft ko <<amuna-là mala Jayir>> \f*
\p 
\v 42 Noba gbal ka wario sǝ kya ak là Kenat andǝ amuna-là mǝnana abanì ka, sǝ pè wi lullǝu ama Noba.
\c 33
\s1 Bǝlɓa gya mala amǝ Isǝrayila twal a Masar aban ká Jodan
\p 
\v 1 Amǝnia ka à nda ka alullǝ abân mǝnana amǝ Isǝrayila wari kam aɓa gya malea, lang à purî ɓá nzali Masar arǝ atau malea aɓata gingnǝban mala Musa andǝ Haruna ka.
\v 2 Kǝla mǝnana Yahweh tsǝki wi nzongcau ka, Musa gilǝ alullǝ abân mala agya malea lo a ɓè bân aban ká ɓè. Mǝnia ka nda gya malea njak-njak:
\pi1 
\v 3 Amǝ Isǝrayila lo a Rameses a lum-bwamdǝ-tongnoia pwari mala zongŋo mǝdǝmbe, yì pwari mana kpata Yàlîmurû ka. À puro aban o nǝ jali, a mǝsǝ amǝ Masar kat.
\v 4 Lang à ndarǝ o ka, amǝ Masar na aban tsǝk alú amuna-dǝmba malea mǝnana kat Yahweh wal-luia aɓalǝia ka. Ɗǝm ngga Yahweh yinǝ ɓashi amur aɓakuli malea.
\pi1 
\v 5 Amǝ Isǝrayila lo gya a Rameses, sǝ à yi tsǝk kàttì a Sukkot.
\pi1 
\v 6 À loapi Sukkot ka à twal gya sǝ à yi tsǝk kàttì a Etam, mǝnana nda a gírí pǝɗanban ngga.
\pi1 
\v 7 À loapi Etam ngga à nyare aban ká Pi-Hahirot mǝnana nda a njar-takuli mala Ba'al-Zefon ngga, sǝ à tsǝk kàttì aɓadǝm Migdol.
\pi1 
\v 8 Pǝlǝa à loapi Hahirot sǝ à kùtí nǝ tsùrú mala nggeamùr, à kya pur aɓa pǝɗanban; sǝ à twal gya mala nongŋo tàrú aɓa Pǝɗanban Etam, sǝ à yi tsǝk kàttì a Mara.
\pi1 
\v 9 À loapi Mara ka à twal gya à yiu a Elim; a Elim ngga amáɗí-mùr nakam lum-nong-ɓari andǝ anggun nkangga lumi-tongno-nong-ɓari (70), sǝ à tsǝk kàttì abanì.
\pi1 
\v 10 À loapi Elim ngga à twal gya sǝ à yi tsǝk kàttì a kún Nggeamùr Nzuno.
\pi1 
\v 11 À loapi Nggeamùr Nzuno ka à twal gya sǝ à yi tsǝk kàttì aɓa Pǝɗanban Sin.
\pi1 
\v 12 À loapi Pǝɗanban Sin ngga à twal gya sǝ à yi tsǝk kàttì a Dofka.
\pi1 
\v 13 À loapi Dofka ka à twal gya sǝ à yi tsǝk kàttì a Alush.
\pi1 
\v 14 À loapi Alush ka à twal gya sǝ à yi tsǝk kàttì a Rifidim, ban mǝnana murnuna pa kàm ace aɓwe raka.
\pi1 
\v 15 À loapi Rifidim ngga à twal gya sǝ à yi tsǝk kàttì a Pǝɗanban Saina.
\pi1 
\v 16 À loapi Pǝɗanban Saina ka à twal gya sǝ à yi tsǝk kàttì a Kibǝrot-hatava.
\pi1 
\v 17 À loapi Kibǝrot-hatava ka à twal gya sǝ à yi tsǝk kàttì a Hazerot.
\pi1 
\v 18 À loapi Hazerot ka à twal gya sǝ à yi tsǝk kàttì a Ritma.
\pi1 
\v 19 À loapi Ritma ka à twal gya sǝ à yi tsǝk kàttì a Rimon-perez.
\pi1 
\v 20 À loapi Rimon-perez ka à twal gya sǝ à yi tsǝk kàttì a Libna.
\pi1 
\v 21 À loapi Libna ka à twal gya sǝ à yi tsǝk kàttì a Rissa.
\pi1 
\v 22 À loapi Rissa ka à twal gya sǝ à yi tsǝk kàttì a Kehelata.
\pi1 
\v 23 À loapi Kehelata ka à twal gya sǝ à yi tsǝk kàttì a Nkono Shefer.
\pi1 
\v 24 À loapi Nkono Shefer ka à twal gya sǝ à yi tsǝk kàttì a Harada.
\pi1 
\v 25 À loapi Harada ka à twal gya sǝ à yi tsǝk kàttì a Makelot.
\pi1 
\v 26 À loapi Makelot ka à twal gya sǝ à yi tsǝk kàttì a Tahat.
\pi1 
\v 27 À loapi Tahat ka à twal gya sǝ à yi tsǝk kàttì a Tera.
\pi1 
\v 28 À loapi Tera ka à twal gya sǝ à yi tsǝk kàttì a Mitka.
\pi1 
\v 29 À loapi Mitka ka à twal gya sǝ à yi tsǝk kàttì a Hashmona.
\pi1 
\v 30 À loapi Hashmona ka à twal gya sǝ à yi tsǝk kàttì a Mosera.
\pi1 
\v 31 À loapi Mosera ka à twal gya sǝ à yi tsǝk kàttì a Bene-Jaakan.
\pi1 
\v 32 À loapi Bene-Jaakan ngga à twal gya sǝ à yi tsǝk kàttì a Hor-haggidgad.
\pi1 
\v 33 À loapi Hor-haggidgad ka à twal gya sǝ à yi tsǝk kàttì a Jotbata.
\pi1 
\v 34 À loapi Jotbata ka à twal gya sǝ à yi tsǝk kàttì a Abrona.
\pi1 
\v 35 À loapi Abrona ka à twal gya sǝ à yi tsǝk kàttì a Eziyon-Geba.
\pi1 
\v 36 À loapi Eziyon-Geba ka à twal gya sǝ à yi tsǝk kàttì a Kadesh, a ɓabondo Zin.
\pi1 
\v 37 À loapi Kadesh ka, à twal gya sǝ à yi tsǝk kàttì a Nkono Hor, a nzong-nzali Edom.
\v 38 Pǝlǝa Yahweh bangcau ama ɓǝ̀ Haruna pǝris ɓǝ̀ eau a Nkono Hor; kàm sǝ Haruna kya wú, a pwari mǝdǝmbe mala tongnoia zongŋo mala lumi-inea pǝlǝa, anzǝm puro mala amǝ Isǝrayila a nzali Masar.\f + \fr 33:38 \ft Ɓalli aɓa: \xt Ɓal 20:23-29\xt*\ft .\f*
\v 39 Haruna ka ndanǝ apǝlǝa gbǝman-mwashat nǝ lumi-ɓari nǝ mǝsǝi tàrú sǝ wú amur Nkono Hor.
\p 
\v 40 Murǝm Arat, ɓwa Kan'ana mǝnana ndanǝdo a Negev a nzali Kan'ana ka ok cau mala yiu mala amǝ Isǝrayila.
\pi1 
\v 41 Amǝ Isǝrayila loapi Nkono Hor ka, à twal gya sǝ à yi tsǝk kàttì a Zalmona.
\pi1 
\v 42 À loapi Zalmona ka, à twal gya sǝ à yi tsǝk kàttì a Punon.
\pi1 
\v 43 À loapi Punon ngga, à twal gya sǝ à yi tsǝk kàttì a Oboh.
\pi1 
\v 44 À loapi Oboh ka, à twal gya sǝ à yi tsǝk kàttì a Iye-abarim, a nzong-nzali Mowap.
\pi1 
\v 45 À loapi Iye-abarim ngga, à twal gya sǝ à yi tsǝk kàttì a Dibon-gad.
\pi1 
\v 46 À loapi Dibon-gad ka, à twal gya sǝ à yi tsǝk kàttì a Almon-diblatayim.
\pi1 
\v 47 À loapi Almon-diblatayim ngga, à twal gya sǝ à yi tsǝk kàttì aɓalǝ ankono Abarim tù aban Nebo.
\pi1 
\v 48 À loapi ɓalǝ ankono Abarim ngga, à twal gya sǝ à yi tsǝk kàttì a ɓawanban mala nzali Mowap, a kún Nggeasala Jodan a Jeriko.
\v 49 À tsǝk là-gumli a kún Nggeasala Jodan, twal a Beth-jeshimot kya pur a Abel-shittim, a ɓawanban mala Mowap.
\s1 Nzongcau mala Yahweh ɓǝà ak nzali Kan'ana nǝ lwa
\p 
\v 50 Pǝlǝa Yahweh nacau nǝ Musa a ɓawanban mala nzali Mowap a kún Nggeasala Jodan, a Jeriko, ama,
\v 51 <<Bangcau nǝ amǝ Isǝrayila ama, <Lang wu yàlnà a nkaring Nggeasala Jodan, aɓa nzali Kan'ana ka,
\v 52 dumǝna púp wun nǝ̀ pǝr aɓwapǝndǝa\f + \fr 33:52 \fq aɓwapǝndǝa \ft Ɓalli aɓa: \xt Pur 23:23-24,31-33; 34:12-13; Nggur 7:1-5; 12:2-3\xt*\ft .\f* mǝnana à dukiyi kam ngga ɓǝà o. Wu arki aɓǝ̀nzál tali malea kat, wu kiɗiki aɓǝ̀nzál bolo malea, sǝ wu bǝbbǝriki amgbangban ndàka-lú malea.
\v 53 Sǝ wun nǝ̀ ak nzalî kat ɓǝ̀ duk girkuma ma'wun, wu duk kam aɓalǝi; ǝn pana wun nzalinì ɓǝ̀ duk ma'wun.
\v 54 Wun nǝ̀ gau nzalinì amur atau ma'wun nǝ bwal-shishar. Tàu mǝnana mǝgule na ka, wu kasǝia wia nzali kpǝm, sǝ tàu mǝnana mǝkyauwe na ka, wu pea wia nzali bǝti. Nzali liɓala mǝnana ɓwa kumo nǝ bwal-shishar ka, nda nǝ̀ duk male ka. Wun nǝ̀ gau nzalinì amur atau mala aká wun.
\p 
\v 55 << <Sǝama ɓǝ̀ wu pǝr aɓwana mǝnana à do a nzalinì, wu ak nzali arǝia raka, yià mǝno wu ɗekia sǝ à ue ka, à nǝ̀ dupa wun kǝla kwa a mǝsǝ wun, sǝ kǝla azwe a nkanggari wun; à nǝ̀ zunggǝli wun aɓa nzali mǝnana wun nǝ̀ duk kam ngga.
\v 56 Sǝ kǝla mana ǝn kanì mǝ nǝ pangnǝia ka, anggo sǝ mǝ nǝ pàngnǝ wun.> >>
\c 34
\s1 Kasǝki anzong-nzali a nzali Kan'ana
\p 
\v 1 Yahweh bangcau nǝ Musa, ama,
\v 2 <<Nacau nǝ amǝ Isǝrayila sǝ wu banggia wia ama, <Wun ndo wun nǝ̀ kùtí aɓa nzali Kan'ana, nzali mǝnana nǝ̀ duk ma'wun ace liɓala ka. Amǝnia ka à nda ka anzong ɓá nzalinì, yì nzali Kan'ana:
\pi1 
\v 3 << <Nzong-nzali mǝnana a njar-kunmur ka, nǝ̀ nongŋo a bare pǝɗanban Zin mǝnana sárǝ́ arǝ nzong-nzali mala nzali Edom ngga. Nǝ̀ tite nǝ takuli a masǝlǝata Nggeamùr Tuɓamur a buì mǝnana nǝ njar-kunmur ka.
\v 4 Nǝ̀ lo kano ka nǝ̀ sárǝ́ aban ká Eauwe Akrabbim, nǝ̀ lidǝmba nǝ ká aɓa Pǝɗanban Zin, sǝ nǝ̀ nggá go a Kadesh-Baniya nǝ njar-kunmur. Nǝ̀ lo kano ka, nǝ̀ sarǝa aban ká Hazar-addar, sǝ nǝ̀ bik Azǝmon.
\v 5 Lo a Azǝmon ngga nzong-nzalinì nǝ̀ kàr aban ká ɓangŋaban nzong-nzali Masar, sǝ nǝ̀ masǝlǝa a Nggeamùr Mediterani.
\pi1 
\v 6 << <Nzong-nzali mǝnana a njar-nzali ka, nda kún Nggeamùr Mediterani. Mǝno ka nǝ̀ duk nzong mala nzali ma'wun a njar-nzali.
\pi1 
\v 7 << <Nzong-nzali ma'wun a njar-nza ka nǝ̀ lo a kún Nggeamùr Mediterani aban ká Nkono Hor.
\v 8 Twal kano ka nǝ̀ sarǝa aban ká Lebo-Hamat. Nǝ̀ lidǝmba aban ká a Zedat,
\v 9 sǝ aban ká Zifǝron, sǝ nǝ̀ masǝlǝa a Hazar-enan. Mǝnia ka nda nzong-nzali ma'wun a njar-nza.
\pi1 
\v 10 << <Nzong-nzali ma'wun a njar-takuli ka, nǝ̀ tite a Hazar-enan aban o a Shefam.
\v 11 Nǝ̀ twal a Shefam sǝ nǝ̀ sarǝa aban ká Ribǝla a njar-takuli mala Ayin. Pǝlǝa nǝ̀ lidǝmba a kusǝ ankono mǝnana a njar-takuli mala Nggeamùr Galili ka.
\v 12 Nzong-nzali man nǝ̀ sulǝo nǝ̀ yia pǝlǝa a kún Nggeasala Jodan sǝ nǝ̀ nggá masǝlǝa a Nggeamùr Tuɓamur.
\pi1 << <Mǝnia ka nda nǝ̀ duk nzali ma'wun, nǝ anzong-nzali male a koya buì ka.> >>
\p 
\v 13 Pǝlǝa Musa banggi amǝ Isǝrayila ama, <<Mǝnia nda nzali mǝnana wun nǝ̀ gauwi nǝ bwal-shishar ka, yì nzali mana Yahweh pà nzongcau ama ɓǝà pè atau tongno-nong-ine nǝ gauwa-tsùrú mala tàu ka.
\v 14 Amǝkà Ruben a tàu malea, andǝ amǝkà Gad a tàu malea, andǝ gauwa-tsùrú mala amǝkà Manasa a tàu malea ka, à angŋǝna dǝmba à kumǝna nzali liɓala malea.
\v 15 Yì atau ɓari andǝ gauwa-tsùrú mala tàu mǝnia ka, à pania wia nzali liɓala malea a nkaring Nggeasala Jodan a nkāɓe Jeriko.>>
\s1 Aɓwana-mǝgule mǝnana à nǝ̀ gau nzali ka
\p 
\v 16 Yahweh bangcau nǝ Musa ama,
\v 17 <<Amǝnia ka, à nda ka alullǝ aburana mǝnana à nǝ̀ gapa wun nzali ace liɓala ka: Eleaza pǝris andǝ Jesǝwa muna-ɓwabura mala Nun.
\v 18 Sǝ awu nǝ twal múrû mwashat aɓa koya tàu ace bwalia wia arǝ túró gau nzali liɓala.
\v 19 Amǝnia ka à nda ka alullǝ aburane:
\li1 <<A tàu mala Yahuda ka, Kalip muna-ɓwabura mala Jefune;
\li1 
\v 20 <<A tàu mala amǝkà Shimiyon ngga, Shemuyel muna-ɓwabura mala Ammihud;
\li1 
\v 21 <<A tàu mala Benjami ka, Elidad muna-ɓwabura mala Chislon;
\li1 
\v 22 <<A tàu mala amǝkà Dan ngga, ɓwamǝgule Bukki, muna-ɓwabura mala Jogǝli;
\li1 
\v 23 <<Atà amuna-burana mala Yisǝfu:
\li1 <<A tàu mala amǝkà Manasa ka, ɓwamǝgule Haniyel, muna-ɓwabura mala Efot;
\li1 
\v 24 <<A tàu mala amǝkà Ifǝrem ngga, ɓwamǝgule Kemuyel, muna-ɓwabura mala Shiftan;
\li1 
\v 25 <<A tàu mala amǝkà Zebulu ka, ɓwamǝgule Elizafan, muna-ɓwabura mala Parnach;
\li1 
\v 26 <<A tàu mala amǝkà Isaka ka, ɓwamǝgule Paltiyel, muna-ɓwabura mala Azzan;
\li1 
\v 27 <<A tàu mala amǝkà Asha ka, ɓwamǝgule Ahihud, muna-ɓwabura mala Shelomi;
\li1 
\v 28 <<A tàu mala amǝkà Naftali ka, ɓwamǝgule Pedahel, muna-ɓwabura mala Ammihud.>>
\m 
\v 29 Amǝnia ka à nda ka aɓwana mǝnana Yahweh tsǝa ama ɓǝà gau nzali liɓala amur amǝ Isǝrayila aɓa nzali Kan'ana ka.
\c 35
\s1 Anggea-là ace Amǝ'Lawi
\p 
\v 1 Yahweh bangcau nǝ Musa a ɓawanban mala nzali Mowap a nkanggari Nggeasala Jodan a nkaring Jeriko ama,
\v 2 <<Banggi amǝ Isǝrayila ama: Aɓa liɓala mala nzali mǝnana girkuma malea na ka, ɓǝà pè Amǝ'Lawi aɓea anggea-là mǝnana à nǝ̀ duk kam ngga, andǝ nzali-yálgìr tù aban anggea-lê.
\v 3 Anggea-lê nǝ̀ duk mala Amǝ'Lawi ace do malea, sǝ aɓawanban malea ace yál agir ka, à nǝ̀ pà ace andá, andǝ anzur, andǝ ambul, andǝ acili agirkusǝu malea.
\p 
\v 4 <<Ban-yálgìr mala nggea-là, mǝnana wun nǝ̀ pè Amǝ'Lawi ka, dumǝna púp tangŋa male, twal arǝ asheran mala nggea-lê ka, ɓǝ̀ pàk mita gbǝman-ine nǝ lumi-tongno (450) a koya buì.
\v 5 Ɗǝm ngga wun nǝ̀ kasǝ banfana mǝnana tangŋa male ka mita gbǝman-tongno-nong-ine (900) na ka, zak nǝ nggea-là a koya buì, a njar-takuli, a njar-kunmur, a njar-nzali sǝ a njar-nza, ɓǝ̀ tsǝk nggea-là a tsùrú. Banfana mǝnia ka nǝ̀ duk ban-yálgìr ace anggea-là.\f + \fr 35:5 \fq anggea-là \ft ko acilia anggea-là\f*
\s1 Anggea-là mala kum-àwá
\p 
\v 6 <<Tongno-nong-mwashat atà anggea-là mǝnana wun nǝ̀ pè Amǝ'Lawi ka, à nǝ̀ duk anggea-là mala kum-àwá,\f + \fr 35:6 \ft Ɓalli gbal aɓa: \xt Pur 21:12-14; Nggur 4:41-43; 19:1-13; Jes 20:2-9\xt*\ft .\f* mǝnana ɓǝ̀ ɓwa wal-lú ka nǝ̀ gandǝ ɓangŋa nǝ̀ ká kàm ngga.
\v 7 Anggea-là kat-kat mǝnana dumǝna púp wun nǝ̀ pè Amǝ'Lawi, atārǝia andǝ abân-yálgìr malea ka, à nǝ̀ pàk lumi-ine bwamdǝ tongno-nong-tàrú (48).
\v 8 Làkkì mala anggea-là mǝnana amǝ Isǝrayila nǝ̀ pè Amǝ'Lawi aɓalǝ girkuma malea ka, à nǝ̀ kārǝi arǝ gulo mala gìr'liɓala mǝnana koya tàu kum ngga: Tàu mǝnana ndanǝ anggea-là pas ka, à nǝ̀ pà pas, sǝ tàu mǝnana ndanǝia bǝti ka, à nǝ̀ pà bǝti.>>
\p 
\v 9 Pǝlǝa Yahweh banggi Musa ama:
\v 10 <<Nacau nǝ amǝ Isǝrayila sǝ wu banggia wia ama: Anzǝm mana wu yalnì Nggeasala Jodan sǝ wu dumǝna a nzali Kan'ana ka,
\v 11 wu tàr aɓea anggea-là ɓǝà duk anggea-là mala kum-àwá, mǝnana ɓǝ̀ ɓwa wal-lú aɓa turturo ka nǝ̀ ɓangŋa nǝ̀ ká kàm ngga.
\v 12 Anggea-lê nǝ̀ duk abân-auwa ace mǝ'wal-lú ɓǝ̀ apî ɓalbura mala ɓǝla mala ɓwa mǝnana à wal-lui ka, ace mǝnana mǝ'wal-lú ka ɓǝ̀ kǝa wǔ ɗàng she cê ka aɓwana-mǝgule dumǝna-ɓashi male ka.
\v 13 Anggea-là mǝno tongno-nong-mwashat wun nǝ̀ pà ka, à nǝ̀ duk anggea-là ma'wun mala kum-àwá.
\v 14 Wun nǝ̀ pà anggea-là tàrú a nkaring Jodan sǝ anggea-là tàrú aɓa nzali Kan'ana; à nǝ̀ duk anggea-là mala kum-àwá.
\v 15 Anggea-là mǝno tongno-nong-mwashat ka, à nǝ̀ duk abân-auwa ace amǝ Isǝrayila andǝ amǝ'kúnɗàngna mǝnana à ndanǝdo aɓalǝ wun ngga, ace mǝnana koyan mana wal-lú ɓwa aɓa-turturo ka, nǝ̀ gandǝ ɓangŋa nǝ̀ ká kàm.
\p 
\v 16 << <Ɓǝ̀ ɓwa tùl ɓeɓwa nǝ gìr bolo-candǝa sǝ lú pùr-aɓalǝi ka, ɓwê dumǝna mǝ'wal-lú, sǝ yì mǝ'wal-lú ka dumǝna púp à nǝ̀ wal-luí.
\v 17 A ɓè njar ka, ɓǝ̀ ɓwa nanǝ tali a buì sǝ ɓù ɓeɓwa nǝi, gandǝa wal-luí ka, ɓwê dumǝna mǝ'wal-lú, sǝ yì mǝ'wal-lú ka dumǝna púp à nǝ̀ wal-luí.
\v 18 A ɓè njar ɗǝm ngga, ɓǝ̀ ɓwa nanǝ girtúró mala nggun a buì, mǝnana nǝ̀ gandǝ wal-lú, sǝ walna ɓeɓwa nǝi, gandǝa wal-luí ka, ɓwê ka dumǝna mǝ'wal-lú, sǝ yì mǝ'wal-lú ka dumǝna púp à nǝ̀ wal-luí.
\v 19 Ɓǝla mala ɓwa mǝno à wal-luí ka nda ɓwa mǝnana nǝ̀ wal-lú mǝ'wal-lú ka. Lang kumǝni ka ɓǝ̀ wal-luí.
\v 20 Anggo gbal, ɓǝ̀ ɓwa nanǝ bumkpǝmna sǝ jambǝrǝ ɓeɓwa, ko kùmsǝi wi sǝ ɓuì nǝ ɓekǝgìr gandǝa wal-luí,
\v 21 ko tùllì nǝ bui aɓa ɓinǝmǝsǝu, sǝ wal-luí ka, ɓwê ka dumǝna púp à nǝ̀ wal-luí; yì ka mǝ'wal-lú na. Ɓǝ̀ ɓǝla mala ɓwa mǝno à wal-luí ka ɓǝ̀ wal-lú ɓwê a pwari mana à je ka.
\p 
\v 22 << <Sǝama ɓǝ̀ ɓwa jambǝrǝ ɓeɓwa hǝrkit sǝ bumkpǝmna pà kàm aɓalǝi ɗàng, ko túr ɓekǝgìr arǝ ɓeɓwa, sǝ shambi nǝ kǝ mǝɓane ɗàng,
\v 23 ko ɓwa twal tali mǝdǝmbǝre a buì mǝnana nǝ̀ gandǝ wal-lú, sǝ tsǝk-mǝsǝì ɗàng, pǝlǝa nying buì arǝ tali sǝ yi kpa amur ɓeɓwa sǝ wal-luí, sǝ ɓwê ka à pà aɓa ɓike andǝi ɗàng, sǝ yì ka pà aban alte nǝ̀ tsǝki wi npenye raka,
\v 24 aɓwana a nggea-là ɓǝà kùtí aɓa cê ɓǝà pàkɓashi anre mǝ'túrtúro andǝ ɓǝla mala lú mǝnana kǝ ɓalbure ka; ɓashinì ka ɓǝà pè nǝ kpata anzongcau mǝnia ka:
\v 25 Dumǝna púp aɓwana a nggea-là nǝ̀ amsǝ mǝ'túrtúro a bù ɓǝla mala lú mǝnana kǝ ɓalbure ka, sǝ à nǝ̀ tsǝkte ɓǝ̀ nyare a nggea-là mala kum-àwá mǝnana ɓangŋa wari kam ngga. Dumǝna púp nǝ̀ ue kano ba lú mala Pǝris Mǝgule.
\v 26 Sǝama ɓǝ̀ mǝ'túrtúro, a koya pwari, sǝ purî ɓá nggea-là mala kum-àwá mana ɓangŋa wari kam,
\v 27 sǝ ɓǝla mala lú mana kǝ ɓalbure ka kumi a nza nǝ nggea-là mala kum-àwá ka, ɓǝla mala lú mǝnana kǝ ɓalbure ka nǝ̀ gandǝ wal-luí, sǝ à pà nǝ̀ sǝni nǝ cauɓikea mala wal-lú ɗàng.
\v 28 Dumǝna púp mǝ'túrtúro ka nǝ̀ ueo aɓa nggea-là mala kum-àwá ba lú mala Pǝris Mǝgule. Anzǝm lú mala Pǝris Mǝgule ka, mǝ'túrtúro nǝ̀ nyare a nzali mala liɓala male.
\p 
\v 29 << <Agir mǝnia ka à nǝ̀ duk anê andǝ acáu mǝnana dumǝna púp wun nǝ̀ kpatea arǝ anza mǝnana kat à kǝ yiu ka, a koya ban mana wu duk kam ngga.
\v 30 Ɓǝ̀ kǝɓwa wal-lú ɓeɓwa ka, à nǝ̀ wal-luí, ɓǝ̀ à kum amǝ'nakún ɓari ka; sǝama à pà nǝ̀ wal-lú kǝɓwa amur nakun mala ɓwa mwashat ɗang.
\p 
\v 31 << <Pà wun nǝ̀ ak kǝ mbweban ace akmúr yilǝmi ɓwa mǝnana pàngŋǝ̀nà cauɓikea mala wal-lú ka ɗàng; dumǝna púp ɓwê ka à nǝ̀ wal-luí.
\p 
\v 32 << <Pà wun nǝ̀ ak kǝ mbweban ace earî ɓwa mǝnana ɓangŋǝna warina a nggea-là male mala kum-àwá ka ama nǝ̀ nyare a là ace do a nzali male sǝ Pǝris Mǝgule malaká wù raka.
\p 
\v 33 << <Wu kǝa tsǝk nzali ma'wun mǝnana wu do aɓalǝi ka ɓǝ̀ duk gìr'ɓeami ɗàng; súkkí-nkila ka kǝ tsǝk nzali ɓǝ̀ duk gìr'ɓeami, sǝ kǝ shawuɗiban pa kàm à nǝ̀ pè ace nzali mǝnana à sukki nkila amurí ka ɗàng, she nǝ nkila mala ɓwa mǝnana súkkì nkile ka.
\v 34 Acemani ka nzali mǝnana wu do aɓalǝi, mǝnana mǝ ndakam nǝdo gbal aɓalǝi ka, pà wun nǝ̀ pǝndǝkì ɗàng. Mim Yahweh ka mǝ ndanǝdo aɓalǝ amǝ Isǝrayila.> >>
\c 36
\s1 Nzali ace amuna-mamǝna mala Zelofihat
\p 
\v 1 Amúrû amur aɓala-kàu mala anggurkwar mala amǝkà Gilǝyat, muna-ɓwabura mala Makir, muna-ɓwabura mala Manasa, mǝnana à purki arǝ anggurkwar mala amǝkà Yisǝfu ka, à sung tù sǝ à nacau aɓadǝm Musa sǝ ɓadǝm aɓwana-mǝgule, yì amúrû amur aɓala-kàu mala amǝ Isǝrayila.
\v 2 À bang ama, <<Lang Yahweh po cau, we ɓwamǝgule ma'sǝm, ama ɓǝ̀ wu gakì atau mala amǝ Isǝrayila nzali liɓala acea nǝ bwal-shishar ka, banggo ama wu pa nzali liɓala mǝnana nda ace mǝ'eam sǝm Zelofihat ka aban amuna-mamǝna male.\f + \fr 36:2 \ft Ɓalli aɓa: \xt Ɓal 26:33; 27:1-11; Jes 17:3; 1Kpa 7:15\xt*\ft .\f*
\v 3 Sǝ ɓǝ̀ yi do ama amuna-mamǝna male alki aburana aɓalǝ aɓea atau mala amǝ Isǝrayila ka, nzali liɓala acea ka pà nǝ̀ duk mala tàu ma'sǝm ɗǝm ɗàng. Nǝ̀ duk kàɓé amur nzali liɓala mala tàu mǝno à albura kam ngga. Anggo ka nzali mǝnana nda ace tàu ma'sǝm ngga nǝ̀ amsǝa.
\v 4 Sǝ lang pǝlǝa mala pàkkiɗire-banɓoarnado\f + \fr 36:4 \fq pǝlǝa mala pàkkiɗire-banɓoarnado: \ft pǝlǝa mǝnana à nǝ̀ nyesǝ anzali mǝnana à mea ka a bù amǝtale mana a nggea dǝmbe ka, sǝ aguro kat ka à nǝ̀ panzǝa ɓǝà kum kumɓamuru.\f*\f + \fr 36:4 \ft Ɓalli aɓa: \xt Pǝris 25:8-55\xt*\ft .\f* mala amǝ Isǝrayila nǝ̀ kàr ka, pà sǝm nǝ̀ kum nzali mala Zelofihat ɓǝ̀ nyare a bù sǝm ɗàng; nǝ̀ duk mala tàu mǝnana amuna-mamǝna male albura kam ngga.>>
\p 
\v 5 Pǝlǝa Musa pà nzongcau mǝnia mǝnana pur nǝban Yahweh ka aban amǝ Isǝrayila ama, <<Cau mala amǝkau a tàu mala Yisǝfu ka nda a njarì.
\v 6 Mǝnia ka nda cau mǝnana Yahweh bang amur amuna-mamǝna mala Zelofihat ka ama, <Wu ɗekia ɓǝà al aburana mǝnana bumia twal ka; sǝama à nǝ̀ albura a tàu mala tárrià.>
\v 7 Anggo ka nzali mǝnana mala amǝ Isǝrayila na ka pà nǝ̀ purî bù ɓè tàu aban ká bù ɓè tàu ɗàng. Koya ɓwa Isǝrayila ka nǝ̀ bwal nzali mala akê a tàu male.
\v 8 Koya muna-ɓwama mǝnana kum liɓala mala nzali a koya tàu mala Isǝrayila ka dumǝna púp nǝ̀ albura a tàu mala tárrí, ace mǝnana koya ɓwa Isǝrayila ka ɓǝ̀ bwal nzali mǝnana mala akê na ka.
\v 9 Kǝ nzali pa nǝ̀ purî bù kǝɓwa a ɓè tàu aban ká ɓè ɗàng, ace mǝnana koya tàu mala Isǝrayila ka ɓǝ̀ bwal nzali mǝnana kumo a bù akê ka.>>
\p 
\v 10-11 Nda amuna-mamǝna mala Zelofihat, yià Mahla, andǝ Tǝrza, andǝ Hogǝla, andǝ Milka, sǝ Noha ka, à pà kǝla mana Yahweh banggi Musa ka; à alki aburana atà amuna-burana mala akinea.
\v 12 Aburana mǝnana à alia ka à nda arǝ anggurkwar mala amǝkà Manasa muna-ɓwabura mala Yisǝfu. Nda anzali malea ueo aɓa nggurkwar andǝ tàu mala tárria ka.
\p 
\v 13 Amǝnia ka à nda ka anzongcau andǝ acáu mǝnana Yahweh pè amǝ Isǝrayila nǝ kún Musa, a ɓawanban Mowap a nkanggari Nggeasala Jodan a nkaring Jeriko ka.
