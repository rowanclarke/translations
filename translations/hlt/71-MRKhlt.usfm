\p
\v 13 Te \w dongah|strong="G2532"\w* \w amih|strong="G0846"\w* te a caeh \w sak|strong="G2010"\w*. \w Tedae|strong="G2532"\w* \w mueihla|strong="G4151"\w* \w thae|strong="G0169"\w* rhoek \w tah|strong="G3588"\w* \w cet|strong="G1831"\w* uh tih, \w ok|strong="G5519"\w* \w khuiah|strong="G1519"\w* \w kun|strong="G1525"\w* uh. Te \w dongah|strong="G2532"\w* ok \w hui|strong="G0034"\w* tah \w laengpoeng|strong="G2911"\w* \w ah|strong="G2596"\w* \w tuili|strong="G2281"\w* \w khuila|strong="G1519"\w* \w cu|strong="G3729"\w* uh \w tih|strong="G2532"\w* \w thawnghnih|strong="G1367"\w* \w tluk|strong="G5613"\w* tah \w tuili|strong="G2281"\w* \w ah|strong="G1722"\w* \w buek|strong="G4155"\w* uh.  
\v 14 \w Ok|strong="G5519"\w* aka \w luempuei|strong="G1006"\w* \w rhoek|strong="G3588"\w* \w khaw|strong="G2532"\w* \w rhaelrham|strong="G5343"\w* \w tih|strong="G2532"\w* \w khopuei|strong="G4172"\w* \w khui|strong="G1519"\w* \w neh|strong="G2532"\w* \w lohma|strong="G0068"\w* \w ah|strong="G1519"\w* khaw \w puen|strong="G0518"\w* uh. Te \w dongah|strong="G2532"\w* aka \w thoeng|strong="G1096"\w* hno \w te|strong="G3588"\w* \w metla|strong="G5101"\w* a \w om|strong="G2076"\w* khaw \w hmuh|strong="G3708"\w* hamla \w cet|strong="G2064"\w* uh.  
\v 15 \w Jesuh|strong="G2424"\w* \w taengla|strong="G4314"\w* a \w pawk|strong="G2064"\w* uh \w vaengah|strong="G2532"\w* \w rhaithae aka kaem|strong="G1139"\w* a \w ngol|strong="G2521"\w* \w te a\w* \w hmuh|strong="G2334"\w* uh. Anih te \w yol|strong="G2439"\w* uh \w tih|strong="G2532"\w* \w muet|strong="G4993"\w* uh. \w Anih|strong="G3588"\w* te caempuei \w caempa|strong="G3003"\w* a \w khueh|strong="G2192"\w* \w dongah|strong="G2532"\w* a \w rhih|strong="G5399"\w* uh.  
\v 16 Te \w vaengah|strong="G2532"\w* rhaithae aka \w kaem|strong="G1139"\w* \w taengah|strong="G3588"\w* aka \w thoeng|strong="G1096"\w* hno \w neh|strong="G2532"\w* \w ok|strong="G5519"\w* \w kawng|strong="G4012"\w* te aka \w hmu|strong="G3708"\w* rhoek \w loh|strong="G3588"\w* \w amih|strong="G0846"\w* taengah a \w thui|strong="G1334"\w* pa uh.  
\v 17 Te \w dongah|strong="G2532"\w* \w amih|strong="G0846"\w* \w vaang|strong="G3725"\w* \w lamloh|strong="G0575"\w* \w nong|strong="G0565"\w* hamla \w Jesuh|strong="G2424"\w* \w te a\w* \w hloep|strong="G3870"\w* uh.  
\v 18 \w Lawng|strong="G4143"\w* \w khuiah|strong="G1519"\w* \w a|strong="G0846"\w* \w kun|strong="G1684"\w* \w vaengah|strong="G2532"\w* rhaithae aka \w kaem|strong="G1139"\w* \w loh|strong="G3588"\w* \w a|strong="G0846"\w* \w taengah|strong="G3326"\w* \w om|strong="G5600"\w* \w ham|strong="G2443"\w* a \w bih|strong="G3870"\w*.  
\v 19 Te \w vaengah|strong="G2532"\w* \w anih|strong="G0846"\w* \w te a\w* \w hlah|strong="G0863"\w* pak \w moenih|strong="G3756"\w*. \w Tedae|strong="G0235"\w* \w amah|strong="G0846"\w* te, \wj “ \+w Namah|strong="G4675"\+w* \+w im|strong="G3624"\+w* \+w la|strong="G1519"\+w* \+w cet|strong="G5217"\+w* \+w lamtah|strong="G2532"\+w* \+w na|strong="G4674"\+w*huiko \+w rhoek|strong="G3588"\+w* \+w taengah|strong="G4314"\+w* \+w Boeipa|strong="G2963"\+w* \+w loh|strong="G3588"\+w* \+w nang|strong="G4671"\+w* ham a \+w saii|strong="G4160"\+w* \+w tih|strong="G2532"\+w* \+w nang|strong="G4571"\+w* ng'\+w rhen|strong="G1653"\+w* \+w boeih|strong="G3745"\+w* te \+w amih|strong="G0846"\+w* taengah \+w puen|strong="G0518"\+w* pah,” \wj* a \w ti|strong="G3004"\w* nah.   
\p
\v 20 Te \w dongah|strong="G2532"\w* \w cet|strong="G0565"\w* \w tih|strong="G2532"\w*, \w Jesuh|strong="G2424"\w* loh \w anih|strong="G0846"\w* ham a \w saii|strong="G4160"\w* \w boeih|strong="G3745"\w* te \w Decapolis|strong="G1179"\w* \w ah|strong="G1722"\w* a \w tong|strong="G0756"\w* tih a \w hoe|strong="G2784"\w* \w hatah|strong="G2532"\w* hlang \w boeih|strong="G3956"\w* loh a \w ngaihmang|strong="G2296"\w* uh.   
\s1 Huta Panit Hoeih  
\p
\v 21 \w Jesuh|strong="G2424"\w* te \w lawng|strong="G4143"\w* \w neh|strong="G1722"\w* \w rhalvangan|strong="G4008"\w* \w la|strong="G1519"\w* \w koep|strong="G3825"\w* a \w hlaikan|strong="G1276"\w* \w hatah|strong="G2532"\w* \w a|strong="G0846"\w* \w taengah|strong="G1909"\w* \w hlangping|strong="G3793"\w* \w hut|strong="G4183"\w* a \w tingtun|strong="G4863"\w* pa \w tih|strong="G2532"\w* \w tuili|strong="G2281"\w* \w kaengah|strong="G3844"\w* vik \w om|strong="G2258"\w*.  
