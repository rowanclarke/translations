\p
\v 1  \w When|strong="H1961"\w* \w King|strong="H4428"\w* \w Hezekiah|strong="H2396"\w* \w heard|strong="H8085"\w* \w this|strong="H3068"\w*, \w he|strong="H3068"\w* \w tore|strong="H7167"\w* \w his|strong="H3068"\w* clothes, \w put|strong="H3068"\w* \w on|strong="H3068"\w* \w sackcloth|strong="H8242"\w*, \w and|strong="H3068"\w* \w went|strong="H3068"\w* \w to|strong="H3068"\w* \w the|strong="H8085"\w* \nd \+w Lord|strong="H3068"\+w*\nd*’s \w temple|strong="H1004"\w*.  
