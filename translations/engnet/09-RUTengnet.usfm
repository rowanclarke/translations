\s1 Ruth Returns to Naomi
\p 
\v 18 \w She|strong="H5892"\w* \w carried|strong="H5375"\w* \w it|strong="H5414"\w* \w back|strong="H3318"\w* \w to|strong="H3318"\w* \w town|strong="H5892"\w*, \w and|strong="H5892"\w* \w her|strong="H5414"\w* \w mother-in-law|strong="H2545"\w* \w saw|strong="H7200"\w* how \w much|strong="H3498"\w* grain \w she|strong="H5892"\w* \w had|strong="H5414"\w* \w gathered|strong="H3950"\w*. \w Then|strong="H3318"\w* Ruth \w gave|strong="H5414"\w* \w her|strong="H5414"\w* \w the|strong="H7200"\w* roasted grain \w she|strong="H5892"\w* \w had|strong="H5414"\w* \w saved|strong="H3498"\w* \w from|strong="H3318"\w* mealtime.
\v 19 \w Her|strong="H5046"\w* \w mother-in-law|strong="H2545"\w* asked \w her|strong="H5046"\w*, “Where \w did|strong="H6213"\w* \w you|strong="H3117"\w* \w gather|strong="H3950"\w* grain \w today|strong="H3117"\w*? Where \w did|strong="H6213"\w* \w you|strong="H3117"\w* \w work|strong="H6213"\w*? \w May|strong="H1961"\w* \w the|strong="H6213"\w* \w one|strong="H6213"\w* \w who|strong="H6213"\w* \w took|strong="H1961"\w* \w notice|strong="H5234"\w* \w of|strong="H3117"\w* \w you|strong="H3117"\w* \w be|strong="H1961"\w* \w rewarded|strong="H1288"\w*!” \w So|strong="H6213"\w* \w Ruth|strong="H5234"\w* \w told|strong="H5046"\w* \w her|strong="H5046"\w* \w mother-in-law|strong="H2545"\w* \w with|strong="H5973"\w* whom \w she|strong="H5973"\w* \w had|strong="H1961"\w* \w worked|strong="H6213"\w*. \w She|strong="H5973"\w* said, “\w The|strong="H6213"\w* \w name|strong="H8034"\w* \w of|strong="H3117"\w* \w the|strong="H6213"\w* man \w with|strong="H5973"\w* whom \w I|strong="H3117"\w* \w worked|strong="H6213"\w* \w today|strong="H3117"\w* \w is|strong="H3117"\w* \w Boaz|strong="H1162"\w*.”
