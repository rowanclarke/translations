\p
\v 24 \w Estos|strong="H1931"\w* son \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Zibeón|strong="H6649"\w*: Aja y \w Aná|strong="H6034"\w*. (\w Este|strong="H1931"\w* \w Aná|strong="H6034"\w* \w es|strong="H1931"\w* \w el|strong="H1931"\w* \w que|strong="H1931"\w* \w halló|strong="H4672"\w* aguas termales en \w el|strong="H1931"\w* \w desierto|strong="H4057"\w* cuando \w apacentaba|strong="H7462"\w* \w los|strong="H1121"\w* \w asnos|strong="H2543"\w* \w de|strong="H1121"\w* \w su|strong="H1931"\w* padre \w Zibeón|strong="H6649"\w*.)   
\p
