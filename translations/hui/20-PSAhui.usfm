\q1
\v 5 Ngode Datagaliwabe-o i̱na í̠hondo ogoale bule lalu lowigi birugo bibahende  
\q2 í̠ hale hai harigoni.  
\q1 Wali agali í̠naga mini yaraga haga karuhondo migi biaga birilidagua  
\q2 í̠na i̱bi karulape ngiaga kegoni.   
\b  
\q1
\v 6 Kini ibu dindini tubagi helo ndo mali dewaore helo helabe.  
\q2 Ibu dindini luore helo helabe.   
\q1
\v 7 Ngode Datagaliwabe-o kini ibu í̠naga deni luore haabo helo helabe.  
\q2 Í̠na gubaliniore ho haabo haga kegome  
\q2 ibu baya hangu handayaho haabo habe.   
\b  
\q1
\v 8 I̱na bamba í̠hondo ogoale buleore lalu bi lowirugo damene\x + \xo 61.8 \xt Iba 56.12\x*  
\q2 horo bibahendengi i̱na talialu bialu  
\q2 í̠naga mini yaraga halu iba ganaru lalu haabo holebero.   
