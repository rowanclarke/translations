\id TIT - Okphela 
\h iTatọ 
\toc1 iTatọsi 
\toc2 iTatọsi 
\toc3 iTatọ 
\mt2 Ebe ni iPọlu ọ kẹkẹ ghi 
\mt1 ITatọsi 
\c 1  
\s1 Otsẹ 
\p  
\v 1 Mhẹmhẹ iPọlu ni a zẹ abi ọni ọọ ga ọyi Ẹshinẹgba ali aghiusomhi na kẹẹ ọyi iJesu iKirisiti, mhi kẹkẹ ebe ona. Eri a ghie mhẹ ni mhi ya zese irudunga oyi eni Ẹshinẹgba ọ zẹ-a, ali ni mhi rẹwẹ khasẹ igẹsikia ni o ya sẹsẹ wẹ abi e li ya la agbọ ni o ri egbe ẹ mu Ẹshinẹgba.  
\v 2 Oni irudunga ali ilẹsẹ ona o migha nga irudushi oyi agbọ na agbọagbọ, ni Ẹshinẹgba ni ọa ya lo ẹgbhọli ọ ri nga na awa neni a mẹ igbaekẹle oyi agbọ.  
\v 3 Ẹghẹghẹ ni o ghọle Ẹshinẹgba, ọ la rọte ungmemhi oyọli ni ọ rọ nga mhẹ obọ ri usomhi oyọli khasẹ gboo. Ẹshinẹgba ọni ọ mie awa pfuese ọ lighọ mhẹsẹ ọli. 
\p  
\v 4 Mhi kẹkẹ ebe ona ghi iTatọsi omimhẹ esheshi elemhi irudunga, ni mhẹmhẹ ali lọli anye ga la elemhi imiesuọ oghuo. 
\p Ẹshinẹgba Ita iJesu iKirisiti ọni ọ mie awa pfuese ọ ka li okhale nẹ, ọ ri opfọmhẹ nẹ.\f + \fr 1:4 \ft Li zẹ \fq 2 iKọri 8.23; iGal 2.3; 2 iTimo 4.10\f* 
\s1 Akanya ni iTatọsi ọ ya gbe ẹoli iKirẹti 
\p  
\v 5 Emini o zẹ ni mhi rọ zẹ obọ shi iKirẹti khi, ni u mẹ asha pfuse ikanya ni e kpọle nya gbe, ali ni u zẹ egbhali shi igbaa nya eyi eni e mie iJesu iKirisiti suọ na ukhomhi ẹoli ni e la iKirẹti nya. Sato abi mhi gueyẹ khi:  
\v 6 Ọni ọ khi ọgbhali shi elemhi igbaa oyi eni e mie iJesu iKirisiti suọ ọ mema ya khi ọgbọ ni ọ guẹ ẹ ngeli, ini a khi mẹ asha gue ẹzọ shi ọli egbe. Ọ mema ya khi ọni ọ rue ọkpotso ọghuo shi. Imi ọli e khi eni e miesuọ ni ẹa khi eniyẹ ni e gbakaa ni ẹa ya suọ esọ.  
\v 7 Aborọkhia khi eri a ri akanya oyi Ẹshinẹgba nga ọni ọ ralo na igbaa oyi eni e mie iJesu iKirisiti suọ nya obọ eghọ, ọ̀ọ́ mema khi ọgbọ ni ọ guẹ ẹ ngeli ini a khi gue ẹzọ shi ọli egbe. Ọ khi khi ọgbọ ni ọ ri imẹbie ẹ ngeli deba ẹgbọ. Ọ khi khi ọni elemhi e kẹlẹ ẹ bi. Ọ khi khi ọgbọ ni ọ da onyọ pfuẹchẹ egbe-a. Ọ khi khi ọgbọ ni ọ kẹlẹ ẹ pfi obọ, wẹkhi ọgbọ ni ingme ukpaghọ o ghọ mu egbe dọsẹ odẹ.  
\v 8 Ochoghọ ọ khi ọni ọ ghẹlẹ ẹ mu ẹgbọ, ni ọọ nono eminete. Ọ khi ọgbọ ni ọ guẹ ri egbọli ẹ kia. Ọ khi ọgbọ igẹsikia, ali ọgbọ ni ọ pfuasẹ. Ọ khi ọgbọ ni ọ mu ekpẹ shi egbọli egbe.  
\v 9 Ọ mema mu oni usomhi onete ni o mhọli iregbenga mhuẹ jijiji, abi a li sẹsẹ ọli. Lọli ọ rọ dobẹ ya ri osẹsẹ igẹsikia ni ọọ sẹsẹ ẹgbọẹse ke ri udu shi wẹ ọ, ali ni ọ gbo ri ida-odẹ oyi eni e nu wẹ ẹ khakọ khasẹ, khi ẹgbhọli ẹẹ lo.\f + \fr 1:9 \ft Li zẹ \fq 1 iTimo 3.2-7\f* 
\p  
\v 10 Irari khi ẹgbọ iJu ebubu eghuo ni e miesuọ ni ẹ pfi ozughu, e la ọ, ni ẹẹ ngme ingmemhi afuẹ ni ẹẹ di ẹgbọ. Wẹwẹ ẹ sẹsẹ odẹ ẹgbhọli khi a mema shẹlẹ ọgbọa neni ọ khi ọni ọ miesuọ.  
\v 11 O ti ni a pfi wẹ okpẹ unu, itobọ khi eri e ri emini ẹ sẹsẹ yese udu oyi ọmhuẹ-apfẹ ebubu-a. Itobọ ini e ba mẹ asha ke ti ukpaghọ ma, e rọ lighọ sẹsẹ.  
\v 12 Egbegbi ọmekẹguele ọyẹwẹ, ọ ke ngme ọli ghue, ọọ, “Ẹgbọ iKirẹti, ẹgbọ ẹgbhọli, ali ẹgbọ ebe ali ẹgbọ iwaza elemhi-gbidi-a, a khi.”  
\v 13 Igẹsikia oni ungmemhi ona o khi. Irarighọ, ga lolo gbe omama ku wẹ, ni irudunga oyẹwẹ o mẹ asha migha.  
\v 14 Ẹghẹghẹ aghọ, ẹa kẹ ke ri esọ shi okhẹ afuẹ oyi ẹgbọ iJu ali ishi eyi ẹgbọ eni e kie igẹsikia.  
\v 15 Eri emhi nya e pfuasẹ shi odalo oyi ẹgbọ ni e pfuasẹ. Ama emhikhọghuo ọa ya pfuasẹ shi ẹloe oyi ẹgbọ ni ẹa pfuasẹ ni ẹa miesuọ, irari khi a she kẹsẹ wẹ udu ali isamhi-a.  
\v 16 E ma liẹ khi wẹwẹ e lẹsẹ Ẹshinẹgba, ama eri angeli oyẹwẹ o rọkhasẹ gboo, khi ẹa lẹsẹ ọli. Ẹgbọ ni aa ti ẹ mama ali ẹgbọ umha-suesọ e khi, ni ẹa ti okiẹ wẹẹ itọtọ. 
\c 2  
\s1 Osẹsẹ ni a ya ke sẹsẹ iku ẹgbọ ọdọda 
\p  
\v 1 Ghe i! Yẹyẹ oyẹ, u mema ya ke sẹsẹ emini o lama shi egbegbi osẹsẹ ọ.  
\v 2 Sẹsẹ emọse ni e she khi egbhali, e ke ri abọ mu udu. E khi eni a mu ekpẹ na, e khi ẹgbọ ni e guẹ ri egbewẹ kia. E zẹ ni irudunga ali inono ali iregbemie oyẹwẹ o lolo mu ekẹ. 
\p  
\v 3 Gbo lighọ sẹsẹ ikpotso eni egbhali e ke ngeli abi ikpotso egbhali ni e la agbọ ipfuasẹ. E khi khi eni e ri unu ẹ yese ẹgbọ a, e khi ditsẹ onyọ idada a, ama e ke sẹsẹ ẹgbọ ingeli enete.  
\v 4 Isheghọ ni e ke sẹsẹ izele ikpotso e nono ingme oyi ọdọ wẹ ali imi wẹ.  
\v 5 E khi ẹgbọ ni e guẹ ri egbewẹ ẹ kia, e khi eni e pfuasẹ. E khi shitọ ni ẹa mhọli oni ẹẹ gbe owa. E khi eni e mhọli isomhelemhi. E ke nyẹsẹ ukhomhi na ọdọ wẹ pfo. Ini ọgbọkhọghuo ọ khi mẹ asha ngme ungmemhi imẹbie deba usomhi onete oyi Ẹshinẹgba. 
\p  
\v 6 Gbo li lighọ gueyẹ eni izẹo e khi ẹgbọ ni e guẹ ri egbewẹ ẹ kia.  
\v 7 Zẹ ni emini u wa riẹlẹ nya e khi eminete ni ẹgbọ nya e ya ke khọnya. Ri igẹsikia ali ọmuegbe ke khasẹ elemhi osẹsẹ ni u wa sẹsẹ.  
\v 8 Ke ri ingmemhi ni e gba pfo ni ọgbọkhọghuo ọa mẹ te ya ke zẹ ifue ngme ungmemhi oyẹ. Ini ebe awa e khi mẹ emini ọa ti okhọghuo ngme shi awa egbe, ni omama o mu wẹ. 
\p  
\v 9 Sẹsẹ ighumha e ri egbewẹ na ega eyẹwẹ pfo nya, e ga ke riẹlẹ emini o ri egbe ẹ ke mu wẹ odẹkhodẹ. E khi ke sọlọ shi wẹ ọ ini e nu wẹ ẹ wola.  
\v 10 E khi bẹna ke do wẹ ughiatọ. E ri ochoghọ ke rọkhasẹ khi ẹgbọ enete ni ẹ gbe akanya te odẹ igẹsikia wẹwẹ e khi. Ẹghẹghẹ aghọ ni e ri osẹsẹ ungmemhi oyi Ẹshinẹgba ni ọ mie awa pfuese ke ghọle. 
\p  
\v 11 Irari khi okhale oyi Ẹshinẹgba ni o ri imiepfuese bhale o she ri egbọli khasẹ ọgbọkpa.  
\v 12 Lọli o sẹsẹ awa, awa ke kie ingeli ni ẹa ghọle Ẹshinẹgba ali ọghuẹmhẹ oyi emhi agbọ, ni ọgbọgbọ ọ ke nu egbọli ngme. Awa a ngeli angeli ni o migha shi ipfuasẹ ẹghẹghẹ ni awa la memena.  
\v 13 Abi awa li ri ukpẹloe shi ekẹ ẹ khẹ ogbẹlẹ ni Ẹshinẹgba ni ọ funẹ Ọmiepfuese iJesu iKirisiti ọyawa o rọ ya nyenẹ egbe bhale.  
\v 14 IJesu iKirisiti ni ọ ri egbọli bhale rọ pfa awa shi ekẹ rọte obọ oyi ọkhọlọ nya lasele, ali ni ọ rọ khuẹsẹ ẹgbọ eyọli-a, ikhi ẹgbọ ni ikanya enete igbegbe ẹ ghọle.\f + \fr 2:14 \ft Li zẹ \fq Iwolo 130.8; Okiali 19.5; iDẹut 4.20; 7.6; 14.2; 1 iPit 2.9\f* 
\p  
\v 15 Enana e khi emini u wa ke sẹsẹ. Ri afu ni mhi rọ nẹ ke ri udu shi wẹ ọ, u gbo tse agua yẹ wẹ. Khi zẹ ni ọgbọkhọghuo ọ ri ukpẹloe gbe ẹ. 
\c 3  
\s1 Abi eni e miesuọ e liẹ ke ngeli 
\p  
\v 1 Ke yele eni ẹgbọ le, e ke nyẹsẹ ukhomhi na enighie ali eni ẹ mhẹsẹ, ali e ri ungmemhi oyẹwẹ ke gbe akanya. E mu egbe ni e rọ ke gbe ikanya enete.  
\v 2 E khi lo ẹgbhọli yese ọgbọkhọghuo eva-a, e khi ẹgbọ opfọmhẹ, e khi nu egbewẹ ke wola, ama e khi eni e ri ikuegbe-a a ngeli deba ọgbọkpa. 
\p  
\v 3 Irari khi awa kpẹ li riẹlẹ ingme ọyẹghẹ ali umha-suesọ. Awa khi eni a di, ni a ri ọghuẹmhẹ egbe, ali aruele mu shi igha. Awa la angeli ubọgbọ ali ofuma ikpekpe. Áá biselemhi awa, awa gbolo biselemhi egbe.  
\v 4 Ama abi isomhelemhi ali inono oyi Ẹshinẹgba Ọmiepfuese ọyawa o rọ feli lasele.  
\v 5 Ọ mie awa pfuese, ni ọa khi itobọ ingeli ni e migha shi ipfuasẹ ni awa ngeli, ama itobọ ilẹlemhi oyọli. Ọ rọte iriẹlẹ bia ali ikhuẹsẹ-pfuasẹ oyi Ayẹmhẹ-nọ-pfuasẹ tsumhi awa. Ọ ri agbọ onogbọ na awa.  
\v 6 Eri Ẹshinẹgba ọ tutu Ayẹmhẹ-nọ-pfuasẹ ku awa tuọ itobọ emini iJesu iKirisiti ọ riẹlẹ na awa.  
\v 7 Ẹghẹghẹ aghọ, awa kha khi eni ọ rọte okhale oyọli rọ pfuasẹ se, awa mele imi ọli a ni e mhọli ọli shi udu khi e mhuẹ obọ shi ugu agbọ na agbọagbọ.  
\v 8 Egbegbi ungmemhi ni a ri egbe ẹ nga ona o khi. 
\p Mhia nono ni u lolo gue ọli ye wẹ jijiji, ini eni e she kpẹ regbenga Ẹshinẹgba, ni e kuegbe-a ke gbe ikanya enete. Eni emhi ena e ma ti gba irari khi e ma ri eleli ẹ na ọgbọkpa. 
\p  
\v 9 Khi nu ẹgbọ khẹ akọ shi ingme afuẹ, ali itọnọ utetọ oyi ẹchẹli idada. Khi wola ali khi khọli shi ingme Ishi eyi iMosisi, itobọ khi afuẹ ali emini ẹa ri eleli a bhale e khi.  
\v 10 Kpẹ tse agua yẹ ọgbọ ozughu iteva, ini ọa kie suọ, u ti gbe mẹ ọli na, ini emhikhọghuo e khi ku ẹ gbe.  
\v 11 Lọli u rọ ya lẹsẹ khi ẹgbọ enana e she de odẹ khi odẹ, olamhẹ e ke la. Angeli oyẹwẹ o she pfa ẹzọ mu wẹ. 
\s1 Omhẹsẹ ni o kpukhokho 
\p  
\v 12 Mhi kha da lẹsẹ ghie Atẹmasi ghi ẹ ne o ke khi iTakikọsi, rọshẹka ni u bhale ya ẹ mhẹ iNikapolisi irari khi mhi she ri ọli shi udu khi oobọ mhi ya la ẹghẹghẹ oruamẹ.\f + \fr 3:12 \ft Li zẹ \fq Ika 20.4; Ẹfi 6.21-22; iKolo 4.7-8; 2 iTimo 4.12\f* 
\v 13 Abibi o riẹ li, rọshẹka kpaghiẹ iZẹnasi ọni ọ khi ilọya ali Apolosi obọ, ini ẹẹ vu. Ri emini ẹ nono nya na wẹ.\f + \fr 3:13 \ft Li zẹ \fq Ika 18.24; 1 iKọri 16.12\f* 
\v 14 Ẹgbọ eyawa e khi eni e wẹna abi a liẹ gbe akanya enete, ni e dobẹ ke riẹlẹ emini ẹẹ nono elemhi ogbẹlẹ na egbewẹ, ini e khi la agbọ ighalaba. 
\p  
\v 15 Ẹgbọ ni e nu mhẹ la ana nya e ga tsẹ ẹ. A tsẹ eni e li miesuọ ali eni e nono ingme oyi anye. 
\p Okhale oyi Ẹshinẹgba o ka nu ẹ la.