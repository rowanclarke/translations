\id ECC .01, Ecclesiastes 1, Motu, PNG, RTWP 11/92
\h KOHELETE
\toc1 KOHELETE (HARORO TAUNA)
\toc2 KOHELETE
\mt1 KOHELETE
\mt2 (HARORO TAUNA)
\c 1
\p 
\v 1 Ini na Haroro Tauna ena hereva; ia be David natuna, Ierusalem pavapavana.
\v 2 Haroro Tauna na eto:
\q1 Asi anidia ḡaudia, asi anidia ḡaudia;
\q2 ḡau iboudiai be asi anidia.
\q1 
\v 3 Tau ta ena hekwarahi idoinai dina henunai e karaiamu
\q2 anina be dahaka?
\q1 
\v 4 Uru ta e lao bubunimu, ma uru ta e vara isimu;
\q2 a tanobada na e mia hanaihanaimu.
\q1 
\v 5 Dina e daemu, ma e dihomu;
\q2 bena ena dae gabuna ma e ḡava heniamu.
\q1 
\v 6 Lai ese diho kahana e toa heniamu,
\q2 bena e toa heḡeḡemu, mirigini kahana e toa heniamu;
\q1 e toa heḡeḡe-heḡeḡemu,
\q2 ena dala gunadia ai ma e toa loumu.
\q1 
\v 7 Sinavai iboudiai na davara ai e aru lasimu,
\q2 a davara na se honumu;
\q1 sinavai ese e aru henidia gunava gabudia
\q2 ma e aru henidia loumu.
\q1 
\v 8 Ḡau iboudiai na hekwarahi ai e honumu;
\q2 tau ta basine herevalaia diba.
\q1 Mata be basine itaia ore;
\q2 taia be basine kamonai ḡuḡuru.
\q1 
\v 9 E vara guna ḡauna ma baine vara lou;
\q2 e karaia guna karana ma bae karaia lou;
\q2 ḡau matamatana ta se miamu, dina henunai.
\q1 
\v 10 Ḡau be edena, bae herevalaia, baeto
\q2 “A itaia, ina na matamata”?
\q1 Lasi, nega gunadia ai e miava,
\q2 ita do asita vara negadia ai.
\q1 
\v 11 E vara guna ḡaudia na ta ese se lalodia taomu,
\q2 bona do bae vara ḡaudia na ta ese basine lalodia tao,
\q2 gabeai bae vara urudia lalodiai.
\p 
\v 12 Lau, Haroro Tauna, ese Israel taudia na biagudia Ierusalem ai.
\v 13 Bena guba henunai e karamu karadia iboudiai na tahudia, mai lalogu idoinai bona mai aonegagu ida. Dirava ese taunimanima natudia unu vada e hahekwarahidia tomamu.
\v 14 Dina henunai e karamu karadia iboudiai vada na itadia; iboudiai na asi anidia, lai ianina na heto.
\q1 
\v 15 Ḡau gageva-gagevana na basie hamaoromaoroa diba,
\q2 bona lasihidia ḡaudia na basie duahidia diba.
\b
\p 
\v 16 Lalogu ai nato: Aonega badana vada na abia; egu aonega ese Ierusalem e biagua gunava taudia iboudiai edia aonega na e hereadiamu; oibe, lalogu ese aonega bona lalo-parara vada e dibadia bada.
\v 17 Bena lalogu na hadaia, aonega baina dibaia, bona kavakava bona lebulebu baina dibadia. Bena lalogu vada e parara, ina danu lai ianina mo.
\b
\q1 
\v 18 Badina be aonega bada lalonai lalo-hekwarahi danu bada;
\q2 bona lalo-parara e habadaiamu tauna ese lalo-hisihisi danu e habadaiamu.
\c 2
\p 
\v 1 Lalogu ai nato: Be, moale baina dibaia; ba hahemoale. To una danu na asi anina.
\v 2 Kiri na herevalaia, nato “Ia na kavakava”; bona moale na herevalaia, nato “Ena namo be dahaka?”
\v 3 Tau-anigu ihanamona dalana vine ranuna i'inuna amo na lalogu ai na tahua; ḡau tamona, lalogu ese dounu aonega e badinaiava. Kavakava idogo-taona dalana danu na tahua, baina itaia nato, taunimanima natuna na edia mauri dinadia oreoredia guba henunai ede bae namo toma.
\v 4 Ḡaukara badadia na kara: ruma na hadai, bona vine imeadia na hado egu.
\v 5 Uma bona imea na kara, bona huahua audia idau-idau na idia lalodiai na hado.
\v 6 Ranu gabudia na ḡei, egu imea audia ihapariparidia.
\v 7 Hesiai taudia bona hahinedia na hoidia, bona hesiai memerodia bona kekenidia na egu ruma ai e vara. Egu nani bona egu mamoe seridia na momo herea, Ierusalem ai e gunalaigu taudia iboudiai edia e hereadia.
\v 8 \it Silver\it* bona \it gold\it* na haboudia egu; bona pavapava idau-idau edia kohu bona tano idau-idau kohudia danu. Ane-abi taudia bona hahinedia danu na abidia; bona hahine momo na adavadia, taunimanima edia moale dalana bunai.
\p 
\v 9 Unu amo na herea dae; Ierusalem ai e gunalaigu taudia iboudiai na na hereadiava, bona egu aonega na egu ai e miava danu.
\v 10 Matagu edia ura ta ediai asina rua, bona lalogu ena moale dalana ta enai asina laoa ahu; badina be lalogu ese egu hekwarahi idoinai e moalelaiava, egu hekwarahi idoinai ahuna bunai.
\v 11 Bena imagu ḡaukaradia iboudiai bona ikaradia hekwarahidia idoidiai na haerodia; bena lalogu e parara, idoinai na asi anina, lai ianina mo. Ihanamogu ḡauna ta lasi dina henunai.
\p 
\v 12 Bena aonega bona kavakava bona lebulebu ma na haerodia; badina be hanua pavapavana murina amo e maimu tauna na ede baine kara toma? E kara gunava karadia mo, ani.
\v 13 Bena lalogu e parara, aonega ese kavakava e hereaiamu, diari ese dibura e hereaiamu na heto.
\v 14 Aonega tauna matana na kwarana ai, a kavakava tauna na dibura ai e rakamu; ḡau tamona na diba, iboudiai dokodia be tamona mo.
\v 15 Bena lalogu ai nato: Kavakava tauna enai e kaumu ḡauna na lauegu ai danu baine kau; matona, na aonega hereamu anina be dahaka? Ma lalogu ai nato: Ina danu asi anina.
\v 16 Aonega tauna bona kavakava tauna na raruosi basie lalodia tao daudau; badina be dina gabedia ai iboudiai na bae lalodia boio vaitani. Aonega tauna na e masemu, kavakava tauna heḡereḡerena.
\v 17 Taunabunai, mauri na inai heniava; badina be dina henunai e karava karadia na lalogu ese e hisihisilaiva. Badina be iboudiai na asi anidia, Iai ianina mo.
\p 
\v 18 Dina henunai na hekwarahilaiva ḡaudia iboudiai na na inai henidiava; badina be murigu ai bainema tauna enai baina rakatanidia.
\v 19 Bona daika dibana ia na baine aonega eiava baine kavakava? A mai aonegagu ida dina henunai na hekwarahilaiva ḡaudia iboudiai na ia ese baine biagudia. Ina danu asi anina.
\v 20 Taunabunai, lalogu na na haloua bona daragu e doko, egu hekwarahi idoinai ai dina henunai na ḡaukaralaiva ḡaudia daidiai;
\v 21 badina be nega haida tau ta ese mai aonegana bona mai lalo-pararana bona mai idibakana ida e karava ḡaudia iboudiai na baine rakatanidia, bena se hekwarahilaiva tauna ese baine moalelai. Ina danu asi anina, bona dika herea.
\v 22 Tau ta ena ḡaukara iboudiai bona ena hekwarahi idoinai dina henunai davadia be dahaka baine abi?
\v 23 Badina be ena dina iboudiai na hisihisi ai e honumu, bona ena ḡaukara na lalo-hekwarahi ḡauna; hanuaboi ai danu ia lalona se laḡa animu. Ina danu asi anina.
\p 
\v 24 Tau ta ena dala namo-hereana binai: baine aniani, baine inuinu, bona ena hekwarahi baine moalelaia. Bena lalogu e parara, ina danu be Dirava imana amo;
\v 25 badina be bema ia dauhai, daika bema aniani eiava bema moale?
\v 26 Badina be Dirava ese e lalo namo heniamu tauna na aonega bona lalo-parara bona moale e heniamu; a kara dika tauna na ina hekwarahi e heniamu, ia ese kohu baine habou bona baine hasenu, Dirava ese e lalo namo heniamu tauna ihenina totona. Ina danu asi anina, lai ianina mo.
\c 3
\p 
\v 1 Ḡau iboudiai na mai edia nega korikori, bona ḡaukara iboudiai guba henunai e karamu be mai negadia:
\q1 
\v 2 vara mai negana, mase mai negana;
\q2 hadohado mai negana, ḡeiḡei mai negana;
\q1 
\v 3 ala-ala mai negana, hahemauri mai negana;
\q2 ruma irohona mai negana, ruma ihadaina mai negana;
\q1 
\v 4 taitai mai negana, kiri mai negana;
\q2 lalo-hisihisi mai negana, mavaru mai negana;
\q1 
\v 5 nadi inegedia mai negana, nadi ihaboudia mai negana;
\q2 haherahu mai negana, basie haherahu na mai negana;
\q1 
\v 6 itahuna mai negana, ihaboiona mai negana;
\q2 ikahu-taona mai negana, ikahu-negena mai negana;
\q1 
\v 7 dabua idarena mai negana, dabua iturina mai negana;
\q2 asi reḡereḡeda baita noho na mai negana, baita herevahereva na mai negana;
\q1 
\v 8 heura-heheni mai negana, heinai-heheni mai negana;
\q2 tuari mai negana, maino mai negana.
\q1 
\v 9 Ḡaukara tauna ena hekwarahi
\q2 anina be dahaka baine abia?
\b
\p 
\v 10 Dirava ese taunimanima natudia vada e henidia bae hekwarahilai ḡaukaradia vada na itadia.
\v 11 Ia ese ḡau iboudiai vada e hahairaidia, ta ta ena nega ena nega ai; a taunimanima lalodia vada e haduhudia, idia ese Dirava ena ḡaukara, matamana ela bona dokona, basie davaria diba.
\v 12 Lau dibagu taunimanima edia dala namona tamona binai: bae moale, edia mauri dinadia iboudiai lalodiai bae hahemoale.
\v 13 Ina danu, iboudiai bae aniani bona bae inuinu, bona edia hekwarahi idoinai bae moalelaia; una na Dirava ena harihari ḡauna taunimanima ediai.
\v 14 Lau dibagu Dirava ena kara Iboudiai na bae mia hanaihanai; ḡau ta ma basie atoa kau eiava basie abia oho; Dirava ese unu vada e karaia toma, taunimanima na ia vairanai bae gari helaoreana.
\v 15 Harihari e miamu ḡaudia na gunaguna e miava, bona do bae vara ḡaudia danu gunaguna e miava; bona Dirava ese vada e heabi oho ḡaudia na e tahudiamu.
\p 
\v 16 Dina henunai ma na itaia, hahemaoro ḡoevaḡoeva gabuna ai kara dika e miava, bona kara maoromaoro gabuna ai kara gageva-gagevadia danu e miava.
\v 17 Lalogu ai nato: Dirava ese kara maoromaoro taudia bona kara dika taudia baine hahemaoro henidia; badina be ia ese bae vara ḡaudia iboudiai bona ḡaukara iboudiai edia nega vada e gwaurai.
\v 18 Lalogu ai ma nato: Dirava ese taunimanima natudia e tohodiamu, baine hahedinarai henidia idia na boroma mo.
\v 19 Badina be taunimanima natudia ediai e varamu bona boroma ediai e varamu dalana be tamona; ta e masemu heḡereḡerena, ma ta danu e masemu. Iboudiai laḡadia na heḡereḡere, taunimanima ese boroma asie hereadiamu; badina be iboudiai na asi anidia.
\v 20 Iboudiai na gabu tamona e laomu; iboudiai na ḡahu amo, bona iboudiai na ḡahu ai ma baela.
\v 21 Daika dibana taunimanima laumana na e daemu bona boroma laumana na tano ai e dihomu eiava?
\v 22 Taunabunai vada na diba, taunimanima ena dala namo-hereana binai, ena ḡaukara baine moalelaia, badina be ia ahuna bunai. Ia murinai bae vara ḡaudia na daika ese baine haheitalaia.
\c 4
\p 
\v 1 Ma na roha lao, hahehisi karadia iboudiai dina henunai e karamu na itadia. Hahehisi ese e hahisidiamu taudia iruru-matadia na itadia, bona tau ta ese taudia se halodia. Siahu na hahehisi taudia ediai; bona taudia ihalodia tauna ta lasi.
\v 2 Bena na laloa, vada e mase guna taudia na nanamo; idia ese doini e maurimu taudia na e hereadiamu.
\v 3 A herea-daena be do se vara bena kara dikadia dina henunai e karamu na do se ita tauna hari.
\p 
\v 4 Bena na itaia, hekwarahi idoinai bona ima-idibaka ḡaukaradia iboudiai na tau ta ese dekena tauna e vaḡeḡelai heniamu amo e varamu. Ina danu asi anina, lai ianina mo.
\p 
\v 5 Kavakava tauna ese imana e lokumu, bona sibona tau-anina e aniamu.
\p 
\v 6 Ima tamona na laḡa-ani amo baine honu be namo; ima ruaosi na hekwarahi bona lai ianina amo bae honu na dika.
\p 
\v 7 Bena kara asi anina dina henunai ma na itaia. Kara na binai:
\v 8 tau ta na asi bamona ta, asi natuna, asi tadikakana; ḡau tamona ena hekwarahi na se dokomu, bona ena roharoha ai ena taḡa na nega ta se heḡereḡeremu; bena nega ta se henanadaimu, seto “Daika bagunai na hekwarahimu bona moale ai na dabumu?” Ina danu asi anina, kara asi moalena.
\p 
\v 9 Rarua ese tamona e hereaiamu; badina be edia hekwarahi davana namona e abiamu.
\v 10 Badina be ta bema keto, bamona ese bema abia isi; a ta bema raka edea bena bema keto negana ai asi iabi-isina tauna, ia madi ihabaina.
\v 11 Ina danu, rarua bema hekure hebou, tau-anidia bema siahu; a ta bema hekure edea, tauna ede bema siahu toma?
\v 12 Tau ta ese tau tamona baine hadarerea diba reana, a tatau rarua ese bae laoa ahu diba. Varo ere toi na basie motu haraḡa.
\p 
\v 13-14 Eregabe tauna mai aonegana, ena be ia na e vara ogoḡami tauna mo basileia lalonai bena dibura rumana lalona amo e raka lasi pavapava ai ela, to ia ese pavapava burukana mai ena kavakava, aonega taudia edia hahealo iabi-daena vada e rakatania tauna, na e hereaiamu.
\v 15 Mauri taudia iboudiai dina henunai e raka eva-evamu na itadia, bona una pavapava burukana baine boloa eregabena danu.
\v 16 Unu taunimanima iboudiai na asi iduahidia; ia ese iboudiai e biagudiava. Ḡau tamona, gabeai baema taudia ese basie moalelaia. Momokani, ina danu asi anina, bona lai ianina.
\c 5
\p 
\v 1 Dirava ena dubu ai ba raka vareai negadia ai na aemu ba nari; ikamonaina totona ba raka kahira be namo, kavakava taudia edia boubou ḡaudia ihahelaḡadia na e hereaiamu, badina be idia na asi dibadia e kara dikamu.
\v 2 Udumu basine hereva haraga-haraga, bona lalomu na hereva ta igwauraina ai basine haraḡa Dirava vairanai; badina be Dirava na guba ai a oi na tanobada ai, una dainai emu hereva na bae gadoi.
\p 
\v 3 Badina be nihi na hekwarahi momo amo e varamu, bona hereva momo na kavakava tauna gadona amo.
\p 
\v 4 Dirava ba gwau hamata henia negana ai, anina ikarana ai basio halahe; badina be ia ese kavakava taudia se moalelaidiamu. Emu gwauhamata anina ba karaia.
\v 5 Basioma gwau hamata be namo, a ba gwau hamata bena anina basio karaia na dika.
\v 6 Udumu ba naria, kara dika ai basine hakaumu vareai; bona gwaukau tauna vairanai basioto “Na kerere”. Namona be dahaka Dirava ese eremu baine badulaia, bona imamu ḡaukaradia baine habuadia tari?
\p 
\v 7 Badina be nihi bae momo negadia ai, hereva asi anidia bae vara momo; a oi ese Dirava garina ba gari.
\p 
\v 8 Basileia ta ai ogoḡami taudia e hahisidiamu bona hahemaoro ḡoevaḡoeva bona ahu korikori e dadihaidiamu boma itaia negana ai basioma hoalaia; badina be herea tauna na herea-dae tauna henunai, bona idia raruosi daediai na herea mikamika taudia haida.
\v 9 A e birulaiamu tanona na pavapava ese baine biagua, una na namo.
\p 
\v 10 Moni e ura heniamu tauna ese moni baine abi, to lalona basine heḡereḡere; bona taḡa e ura heniamu tauna ese ena taḡa baine habadaia, to lalona basine heḡereḡere. Ina danu asi anina.
\p 
\v 11 Kohu bae momo, to iha oredia taudia danu bae hoho; bena kohu biaguna ese anidia basine abi, a matana amo baine itadia mo, ani?
\p 
\v 12 Ḡaukara tauna na bogana baine kunu eiava baine hitolo, to ena mahuta baine namo; a taḡa tauna na baine ani paru dainai basine mahuta diba.
\p 
\v 13 Dika badana ta guba henunai vada na itaia: taḡa tauna na ena taḡa igogosina ai e dika;
\v 14 hekwakwanai negana ai una taḡa e boio, bena ia na mai natuna, to imana e tuna.
\v 15 Sinana bogana amo ema heḡereḡerena ai ma bainela, ḡaḡaena ai, ema heḡereḡerena; ena hekwarahi danu asi anina, ḡau ta na imana ai basine laohaia.
\v 16 Ina danu dika badana ta: ema heḡereḡerena ai ma bainela; ia na lai iabina e hekwarahilaia,
\v 17 bona ena dina iboudiai na dibura bona lalo-hisihisi bona lalo-hekwarahi bona gorere bona tudaga lalodiai e ha-oredia, anina be dahaka?
\p 
\v 18 Vada na itaia, ina na namo bona heḡereḡere: taunimanima na btine aniani, bona baine inuinu, bona ena hekwarahi idoinai Dirava ese ena mauri dinadia oreoredia dina henunai vada e henia lalodiai baine moalelaia; badina be ia ahuna korikori bunai.
\v 19 Dirava ese taḡa bona kohu vada e henidia taudia iboudiai na siahu danu vada e henidia, bae moalelaidia, bona ahudia bae abi dae, bona edia hekwarahi ai bae moale; una na Dirava ena harihari ḡauna.
\v 20 Badina be idia ese edia mauri dinadia basie lalodia bada; badina be Dirava ese e hamoalediamu, bona una mo bae laloa bada.
\c 6
\p 
\v 1 Dika ta vada na itaia dina henunai, taunimanima e hametaudiamu ḡauna:
\v 2 tau ta be Dirava ese taḡa bona kohu bona dagi e heniamu, bena ena ura ḡauna ta ai se dabumu; ḡau tamona, Dirava ese imoalelaina siahuna se heniamu, a idau tauna ta ese e moalelaidiamu. Ina na asi anina, hahehisi badana.
\v 3 Tau ta natuna bema sinahu-ta, bona ena mauri bema daudau, ela bona ena mauri laḡanidia bema momo herea, a ena mauri ihanamona ḡaudia basinema moalelaidia bona ena mase negana ai basiema ḡuria; lau na tomamu masena ai e vara merona ese ia e hereaiamu.
\v 4 Badina be ena mai na asi anina, ena lao be dibura e lao heniamu, bona ia ladana na dibura ai e bubunimu;
\v 5 oibe, dina na se itaia, bona ḡau ta asi dibana, ḡau tamona ia na laḡa-ani e davariamu; a una tau be lasi.
\v 6 Ena be ena mauri laḡanidia bema daha rua, to ḡau namona ta basinema moalelaia: be, iboudiai na gabu tamona se laomu a?
\p 
\v 7 Taunimanima edia hekwarahi idoinai na ududia daidiai; ḡau tamona, bogadia na asie kunumu.
\v 8 Aonega tauna ese kavakava tauna ede e hereaia tomamu? Ogoḡami tauna na mauri taudia vairadiai ede baine kara toma bema mai dibana, to ahuna be dahaka namona?
\v 9 Matada e itamu ḡaudia ese ta lalo haguhilaimu ḡaudia na e hereadiamu; ina danu asi anina, lai ianina mo.
\p 
\v 10 Vada e vara ḡaudia iboudiai na ladadia vada e hato guna, bona dibada taunimanima be dahaka, bona dibada ia ese goada-herea tauna basine hepapahuahu henia diba.
\v 11 Hereva bae momo, kavakava danu baine bada; idia ese taunimanima ede bae hanamodia toma?
\v 12 Badina be daika dibana taunimanima ena namo be dahaka, ena mauri asi anina dinadia oreoredia lalodiai? E raka hanaimu laulau ta na heto, ani? Badina be daika ese baine hamaoroa, ia murinai dahaka baine hedinarai dina henunai?
\c 7
\q1 
\v 1 Lada namona ese dehoro namo-hereana e hereaiamu,
\q2 bona mase dinana ese vara dinana e hereaiamu.
\q1 
\v 2 Taitai rumana ilao-henina be namo,
\q2 aria rumana ilao-henina na dika;
\q1 badina be taunimanima iboudiai ini e doko tomamu,
\q2 bona mauri taudia ese bae helalolaia.
\q1 
\v 3 Lalo-hisihisi ese kiri e hereaiamu;
\q2 badina be vaira ḡegeva ese lalona e hamoaleamu.
\q1 
\v 4 Aonega taudia lalodia na taitai rumana ai,
\q2 a kavakava taudia lalodia na kiri rumana ai.
\q1 
\v 5 Aonega tauna ena gwau-gwau e hakala heniamu tauna be namo,
\q2 kavakava taudia edia ane e kamonaimu tauna na dika.
\q1 
\v 6 Kavakava taudia edia kiri na
\q2 au ginigini uro henunai e aramu reḡedia na heheto;
\q2 ina danu asi anina.
\q1 
\v 7 Momokani, hahehisi ese aonega tauna e hakavaiamu.
\q2 bona koikoi henitaona ese lalona e hamiroamu.
\q1 
\v 8 Kara dokona ese kara matamana e hereaiamu,
\q2 bona lalo-manau ese lalo-heaḡi e hereaiamu.
\q1 
\v 9 Basio badu haraḡa,
\q2 badina be badu ese kavakava taudia lalodia e noho henidiamu.
\q1 
\v 10 Basioto “Dahaka dainai nega gunadia ese ina nega e hereaia?”
\q2 Badina be dia aonega amo so henanadaimu.
\q1 
\v 11 Kohu iabina mai aonegana ida be namo,
\q2 dina e itaiamu taudia ihanamodia;
\q1 
\v 12 badina be aonega ena hegima na moni ena hegima na heto,
\q2 bona lalo-parara ena hahenamo be aonega ese lalo-parara tauna e naria balahenimu.
\q1 
\v 13 Dirava ena ḡaukara ba haeroa:
\q2 ia ese vada e hagagevaia ḡauna na daika ese baine hamaoromaoroa.
\b
\p 
\v 14 Emu namo e badamu dinana ai ba moale, bona emu dika e badamu dinana ai ba laloa, Dirava ese unu ruaosi vada e karadia, taunimanima na basie diba dahaka dahaka ia murinai bae vara helaoreana.
\p 
\v 15 Egu mauri asi anina lalonai, ḡau iboudiai vada na itadia: kara maoromaoro tauna na ena kara maoromaoro ai e masemu, bona kara dika tauna na ena kara dika ai ena mauri e hadaudauamu.
\v 16 Metaira ba kara maoromaoro, metaira ba aonega; sibomu ba heala anina be dahaka?
\v 17 Metaira ba kara dika, bona basio kavakava; emu nega do basine ore ai vada ba mase anina be dahaka?
\v 18 Ina na ba kahua tao bona una na basio kahua nege be namo; badina be Dirava garina e garimu tauna na idia iboudiai bogaragidia amo baine raka lasi.
\p 
\v 19 Aonega ese aonega tauna e hagoadaiamu; bena ia ese hanua lohiadia gwauta e hereadiamu.
\p 
\v 20 Momokani, asi kara-maoromaoro tauna ta tanobada ai e kara namomu mo, bona nega ta se kara dikamu.
\p 
\v 21 Taunimanima edia hereva iboudiai basio hakala henidia, emu hesiai tauna baine uduguiraimu bena ena hereva ba kamonai na garina.
\v 22 Lalomu ai vada o diba, nega momo oi ese haida na vada o uduguiraidia.
\p 
\v 23 Ina idoinai aonega amo vada na tohoa. Lau nato “Baina aonega”; to aonega egu amo na idauhai.
\v 24 E miamu ḡauna na idauhai; ia na dobu, dobu masemase. Daika ese baine davaria diba?
\v 25 Lalogu na haloua, baina diba, bona aonega bona ḡau badidia baina tahudia; bona kara dika ena kavakava bona kavakava ena kava kukuha baina dibadia.
\v 26 Bena ḡau idita-hereana ta na davaria, mase iditana e hereaiamu ḡauna; una ḡau be lalona na idoa bona huo bona imana na gadea hahinena. Dirava e hamoaleamu tauna na iena amo e roho maurimu; a kara dika tauna na ia ese e abiamu.
\v 27 Haroro Tauna e tomamu: A itaia, ina na vada na davaria. Lalo-hadai idau-idau vada na haboudia, ede bae hatamona toma;
\v 28 Ialogu ai vada na tahua loulou, to asina davaria. Daha ta lalodia amo tau tamona na davaria, a ini iboudiai lalodia amo hahine ta asina davaria.
\v 29 A itaia, ina mo vada na davaria: Dirava ese taunimanima e karadia mai edia maoromaoro, a idia ese dala idau-idau vada e tahudia.
\c 8
\q1 
\v 1 Daika na aonega tauna heḡereḡerena;
\q2 Daika na ḡau anidia mai dibana?
\q1 Tau na aonega ese vairana e hahururu-hururuamu,
\q2 bona ena vaira auka e abia ohomu.
\b
\p 
\v 2 Hanua pavapavana ena haheḡani ba badinaia, bona emu gwauhamata helaḡana dainai kudoumu basine hetaha.
\v 3 Ia vairana amo ba raka oho; ena be ḡaukara mamina na dika to basio halahe, badina be ia ese ena ura iboudiai heḡereḡeredia ai e karamu.
\v 4 Badina be hanua pavapavana ena hereva na herea; daika ese baine nanadaia, baineto “Dahaka o karamu?”
\v 5 Haheḡani e badinaiamu tauna na basine dika; bona aonega tauna lalona baine parara, nega bona dala be ededia.
\v 6 Badina be, ena be taunimanima edia hekwarahi na metau, to ḡaukara iboudiai na mai negadia bona mai daladia.
\v 7 Badina be ia na asi dibana dahaka baine vara, bena daika ese baine hamaoroa diba ede baine vara toma?
\v 8 Asi tauna ta mai siahuna ia laumana baine dogoa tao eiava mai siahuna ena mase dinana enai. Tuari ai tau ta basine raka siri diba; bona dika ese kara dika tauna basine hamauria.
\v 9 Ina idoinai na itaia, kara iboudiai dina henunai e karamu na haerodia negana ai. Na itaia danu, taunimanima haida ese bamodia e biagudiamu bona e hahisidiamu.
\p 
\v 10 Na itaia danu, kara dika taudia na e guridia; gunaguna-idia na gabu helaḡana ai e raka vareai e raka lasi, bona hanua lalonai e imodaidia edh kara daidiai. Ina danu asi anina.
\v 11 Kara dika davadia na asie heni haraḡamu dainai, taunimanima natudia lalodia ese kara dika e ura heni badamu.
\v 12 Ena be kara dika tauna na nega sinahu-ta e kara dikamu bona ena mauri e hadaudauamu, to lau dibagu Dirava garina e garimu taudia na bae namo, badina be ia vairanai e garimu.
\v 13 A kara dika tauna basine namo; ena mauri basine hadaudaua laulau na heto; badina be ia na Dirava vairanai se garimu.
\p 
\v 14 Kara ta tanobada ai na asi anina: kara namo taudia haida na kara dika taudia ahudia heḡereḡeredia ai e abimu, bona kara dika taudia haida na kara namo taudia ahudia heḡereḡeredia ai e abimu. Lau nato una danu asi anina.
\v 15 Moale na hanamoamu, badina be taunimanima na asi ena ḡau namona ta dina henunai; a baine aniani, baine inuinu bona baine moale; badina be unu ese ena hekwarahi ai bae bamoa, ena mauri dinadia Dirava ese dina henunai baine henia lalodiai.
\p 
\v 16 Lalogu na hadaia, aonega baina diba, bona tanobada ai e karaiamu ḡaukarana baina itaia; e kara boimu e kara ranimu, matadia asie mahutamu.
\v 17 Bena Dirava ena kara idoinai na itaia, dina henunai e karamu ḡaukaradia anidia na taunimanima ese basine davaridia diba. Ena be itahudia ai baine hekwarahi bada, to basine davaridia; ena be aonega tauna baineto mai dibana, to basine davaridia diba.
\c 9
\p 
\v 1 Ina idoinai na laloa bona na haeroa: kara maoromaoro taudia bona aonega taudia bona edia kara danu na Dirava imana ai; taunimanima na asi dibadia ia ese e ura henidiamu eiava e inai henidiamu. Ḡau iboudiai idia vairadiai na asi anidia;
\v 2 badina be kara tamona na iboudiai ediai e kaumu, kara maoromaoro tauna enai bona kara dika tauna enai, tau namona enai bona tau dikana enai, lalo-ḡoevaḡoeva tauna enai bona lalo-bodaga tauna enai, boubou ḡauna e hahelaḡaiamu tauna enai bona boubou ḡauna se hahelaḡaiamu tauna enai. Kara namo tauna bona kara dika tauna na heḡereḡere; e gwau hamatamu tauna bona gwauhamata se uramu tauna na heḡereḡere.
\v 3 Dina henunai e karamu karadia iboudiai edia dika ta binai: kara tamona na iboudiai ediai e kaumu. Ina danu, taunimanima lalodia na dika ai e honu honu daemu, edia mauri dinadia ai lalodia na kakavakava, una murinai mase gabuna e laomu.
\v 4 To mauri taudia iboudiai ida e heturamu tauna na mai ena helaro; badina be e maurimu sisiana ese vada e mase leonana na e hereaiamu.
\v 5 Badina be mauri taudia na dibadia do bae mase; a mase taudia na ḡau ta asi dibadia, bona asi ahudia, a ilalo-taodia na e boiomu.
\v 6 Edia heura-heni bona edia heinai-heni bona edia vaḡeḡe vada e ore vaitani; bona dina henunai e karamu karadia iboudiai lalodiai idia na asi ahudia, ela bona hanaihanai.
\p 
\v 7 Aola, amu bavania mai moalemu ida, bona emu vine ranuna ba inua mai lalo-namomu ida; badina be Dirava ese emu kara vada e hanamoa guna.
\p 
\v 8 Nega iboudiai dabua kurokurodia ba hahedokilai; dehoro na kwaramu ai baine mia hanaihanai.
\p 
\v 9 Adavamu, o ura heniamu hahinena, ida ba moale hebou, emu mauri asi anina dinadia Dirava ese dina henunai vada e henimu iboudiai lalodiai, badina be oi ahumu bunai emu mauri ai, bona dina henunai o hekwarahilaimu ḡaukaradia lalodiai.
\v 10 Oi imamu ese baine davaria ḡaukarana na ba karaia mai goada-badamu ida; badirla be o lao heniamu gabuna, mase taudia edia gabu, lalonai na asi ḡaukara ta, asi lalo-hadai ta, asi lalo-parara ta, bona asi aonega ta.
\p 
\v 11 Dina henunai ma na itaia lou: heau helulu ai heau haraḡa taudia asie gunamu, bona tuari ai goada taudia asie kwalimumu, bona aonega taudia ese aniani asie aniamu, bona lalo-parara taudia ese taḡa asie abiamu, bona idibaka taudia na asie lalo-namo henidiamu; a nega bona kara na e vara kavamu mo, iboudiai ediai.
\v 12 Badina be taunimanima ese ena nega se dibaiamu. Gwarume na hekoi rekena ai e hetoamu eiava manu na idoa ai e heidoamu na heto, taunimanima natudia na unu e heidoa tomamu, nega dika ese e hahoadiamu negana ai.
\p 
\v 13 Ina aonega toana na dina henunai vada na itaia danu; bona na laloa, ia na ḡau badana.
\v 14 Hanua maragina ta ena taunimanima na dia hoho; bena hanua pavapavana badana ta ese e tuari henia, e koua heḡeḡe, bona tano e larebaia heḡeḡe ia iabina totona.
\v 15 A una hanua lalonai na ogoḡami tauna ta mai aonegana; bona ia ese ena aonega amo una hanua e hamauria. A asi tauna ta ese una ogoḡami tauna e laloa tao.
\v 16 A lau na tomamu, ena be ogoḡami tauna ena aonega e dadaraiamu bona ena hereva asie kamonaimu, to aonega ese goada e hereaiamu.
\p 
\v 17 Aonega tauna ena hereva asi regerege gabuna ai e gwauraimu ese lohia ena haroro kavakava taudia bogaragidiai na e hereaiamu.
\v 18 Aonega ese tuari ḡaudia na e hereadiamu, a kara dika tauna tamona ese ḡau namodia diagau e hadikadiamu.
\c 10
\q1 
\v 1 Muramura mai bonadia ikaradia tauna ena dehoro lalonai lao e masemu,
\q2 bena una dehoro bonana na e dikamu;
\q1 unuhetomana kavakava sisina ese
\q2 aonega bona matau e hadikadiamu.
\q1 
\v 2 Aonega tauna lalona ese idiba kahana e hakaua laomu,
\q2 a kavakava tauna lalona ese lauri kahana e hakaua laomu.
\q1 
\v 3 Kavakava tauna, ena be dala ai e rakamu, to lalona se pararamu;
\q2 ia ese taunimanima iboudiai e hamaorodiamu ia na kavakava.
\q1 
\v 4 Hanua pavapavana ese bema badu henimu, emu gabu basioma rakatania;
\q2 badina be hemataurai ese kerere badadia e tahunidiamu.
\b
\p 
\v 5 Dika ta vada na itaia dina henunai, hanua pavapavana ena kerere ta na heto reana.
\v 6 Kererena binai: kavakava na atai gabudia ai e abia daemu, a taḡa taudia na henu ai e helaimu.
\v 7 Hesiai taudia vada na itadia, hosi ai e guimu; bona hanua lohiadia vada na itadia, aedia amo e rakamu, hesiai taudia na heheto.
\b
\q1 
\v 8 Guri e ḡeiamu tauna na una guri lalonai baine moru;
\q2 bona haba e dareamu tauna na gaigai ese baine koria.
\q1 
\v 9 Nadi e taradiamu tauna na nadi ese bae haberoa;
\q2 bona au e poladiamu tauna na au ese bema hadikaia reana.
\q1 
\v 10 Auri asi ganona basie segea negana ai, ḡaukara tauna ena hekwarahi baine bada,
\q2 a aonega ese ḡaukara e haheauamu.
\q1 
\v 11 Mea tauna ese gaigai do se hamanadaia negana ai ia na bema hekori,
\q2 mea tauna iboirina na asi anina.
\q1 
\v 12 Aonega tauna uduna herevadia ese taunimanima edia hahenamo e abiamu,
\q2 a kavakava tauna bibinana ese e ha-oreamu.
\q1 
\v 13 Ia uduna herevadia matamadia na kavakava,
\q2 bona ena hereva dokona na kava bona dika rohoroho.
\q1 
\v 14 Kavakava tauna ena hereva na momo,
\q2 a tau ta asi dibana dahaka baine vara,
\q2 bona daika ese baine hamaoroa ia murinai dahaka baine vara.
\q1 
\v 15 Kavakava tauna na ena hekwarahi ai e hesikumu;
\q2 una dainai hanua lao dalana na asi dibana.
\q1 
\v 16 Tano e, pavapavamu bema mero bona emu lohia na daba ai bema ani lava dae negana ai,
\q2 madi ihabaimu!
\q1 
\v 17 Tano e, pavapavamu bema ura-kwalimu taudia natudia,
\q2 bona emu lohia na hora korikorina ai bema aniani,
\q1 goada iabina helaoreana, dia bae kekero totona,
\q2 oi na ba moale!
\q1 
\v 18 Lahedo dainai ruma guhina e kohumu,
\q2 bona medu na ruma lalonai e hetuturu dobimu.
\q1 
\v 19 Aniani na kiri ihavarana ḡauna,
\q2 bona vine ranuna ese taunimanima edia mauri e hamoaleamu,
\q2 bona moni ese ḡau iboudiai e havaramu.
\q1 
\v 20 Lalomu ai hanua pavapavana basio uduguiraia,
\q2 bona emu mahuta gabuna ai taḡa taudia basio uduguiraidia;
\q1 badina be atai manuna ta ese gadomu baine roholaia,
\q2 eiava roho manuna ta ese harina baine piua.
\c 11
\q1 
\v 1 Amu aniani na davara kopina ai ba negea,
\q2 badina be dina momo muridiai ma ba davaria.
\q1 
\v 2 Hahitu eiava taurahani ahudia ba henidia,
\q2 badina be asi dibamu dahaka hahedika ḡaudia na tanobada ai bae vara.
\q1 
\v 3 Dagadaga na ranu ai bema honu,
\q2 idia ese medu bema hadihoa tanobada latanai;
\q1 bona au na diho kahana eiava mirigini kahana bema gari henia,
\q2 ia na e gari heniamu gabuna ai bema mia.
\q1 
\v 4 Lai e nariamu tauna na uhe basine hado,
\q2 bona dagadaga e ita taomu tauna na basine geiḡei.
\b
\p 
\v 5 Lai ede e toa tomamu na asi dibamu; mero matamatana turiana na sinana bogana ai ede e vara tomamu danu asi dibamu; benaini, ḡau iboudiai ikaradia Diravana ena ḡaukara danu asi dibamu.
\p 
\v 6 Daba ai emu uhe ba hado, bona adorahi ai danu basio hesiku; badina be asi dibamu ina baine namo eiava una baine namo, eiava ruaosi bae namo.
\p 
\v 7 Diari be namo, bona matada ese dina e itaiamu na mai moalena.
\p 
\v 8 Badina be tau ta ena mauri dinadia bema hoho, ia ese iboudiai baine moalelaidia; to, baine laloa, dibura dinadia bae hoho. E varamu ḡaudia iboudiai na asi anidia.
\p 
\v 9 Eregabe taumu e, eregabemu ai ba moale, eregabemu dinadia ai lalomu ese baine hamoalemu; lalomu ena ura bona matamu ena ita-ita daladia ai ba raka. A ba diba, ini ḡau iboudiai daidiai Dirava ese baine hahemaoro henimu.
\p 
\v 10 Lalo-hekwarahi na lalomu amo bavatoa lasi, bona hisihisi na taumu anina amo bavabia oho; badina be tauhau bona eregabe negadia na asi anidia.
\c 12
\p 
\v 1 Eregabemu dinadia ai ikaramu Diravana na ba laloa tao, hahedika dinadia do asie kau ai, bona ba herevalaidia baoto “Asina moalelaidiamu” laḡanidia do asie kahira-kahira ai;
\v 2 dina bona diari bona hua bona hisiu do asie dibura bona medu murinai dagadaga do asie hahebou lou negana ai.
\v 3 Una dina ai ruma igimana taudia na bae heude-heude, bona goada taudia dorudia bae laoho; uit iriridia bae hadoko badina be, idia na gagadoi mo, bona gaba-mauru amo e igo lasimu hahinedia na matadia bae valahu-valahu,
\v 4 bona ariara ai ruma iduaradia bae hekou. Una dina ai uit iririna reḡena baine maraḡi, bona ta baine noga haraḡa manu ena tai ai, bona ane-abi hahinedia eredia bae manoka.
\v 5 Una dina ai. atai gabudia garidia bae gari, bona dala ai danu hahegari ḡaudia bae mia. Una dina ai sakada\f + \fr 12:5 \ft “Sakada” na au ta ladana Heberu gado ai; una au burena na kuroka-kuroka herea.\f* auna baine burea, bona kwadi baine bainabaina lao, bona heḡahusi baine ore. Badina be taunimanima na baine noho henia hanaihanai gabuna e laomu, bona taitai taudia na ariara ai e tai loaloamu.
\v 6 Ia ba laloa tao, \it silver\it* varona do se motu, eiava \it gold\it* dihuna do se makohi, eiava hodu na ranu gabuna ai do se hesea rohoroho, eiava ava keikeina na ranu gurina isena ai do se kwaidu ai;
\v 7 ḡahu ese tano do se lou henia, oromana gunana heḡereḡerena do se abia, bona lauma na e henia Diravana dekena do se lou lao negana ai.
\v 8 Haroro Tauna na e tomu: Asi anidia ḡaudia, ḡau iboudiai be asi anidia.
\p 
\v 9 Haroro Tauna na mai aonegana, bona ia ese taunimanima e ha-aonegadiava. Hereva lada-isidia e tahudia, bona e haerodia, bona e haboudia ḡoevaḡoeva.
\v 10 Haroro Tauna na hereva mai mamidia e tahudia, bona hereva momokanidia e tore maoromaoro.
\p 
\v 11 Aonega taudia edia hereva na ikodo na heheto; bona e haboudia herevadia na e kokodia kau ikokodia na heheto; idia na Hereḡu Tauna tamona ese e heni.
\v 12 Natugu e, ini e hereadiamu ḡaudia nahuadia ba toho. Buka momo itoredia na asi dokona, bona ihaerodia ese hesiku e havaraiamu.
\p 
\v 13 Ḡaukara dokona binai; hereva iboudiai vada o kamonai. Dirava garina ba gari, bona ena haheḡani ba badinadia; badina be una na taunimanima ena kara korikori idoinai.
\v 14 Badina be Dirava ese kara iboudiai bona ḡau hehunidia iboudiai, namodia bona dikadia, na baine hahemaorg henidia. 
