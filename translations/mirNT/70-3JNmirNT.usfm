\id 3JN
\h 3 Juan
\toc1 3 Juan
\toc2 3 Juan
\toc3 3 Jn.
\mt1 3 Juan
\c 1
\p 
\v 1 Juánhøch nxøhaty. Mäguꞌughajpä Gayo, míic̈hhøch hädaa nocy nyajnäjaayøøby. Tøyhájthøch miic̈h ndsocy nbaꞌhäyoy.
\p 
\v 2 Ween miic̈hä Dios hoyhajt weenhajt xmioꞌoy. Nnajuǿøbiøch jaduhṉ coo miic̈h hoy mwädity.
\v 3 Tøøc̈hä hermanohajxy hoy näjeꞌe xyhawaaṉä coo miic̈hä Diosmädiaꞌagy hamuumduꞌjoot mbanøcxy. Páadyhøch jootcujc nnijiäwøꞌøyii.
\v 4 Cooc̈h nmädoyhaty cooc̈h njamiøødä Diosmädiaꞌagy hajxy hamuumduꞌjoot pianøcxy, jaanc̈h tehm̱ xiooṉdáacpøch jaduhṉ.
\p 
\v 5 Hoy miic̈hä Diosmädiaꞌagy mgudiuṉ̃ coo jaꞌa hermanohajxy mbuhbety, jaꞌa hajxy jäguem̱gajpt‑tsohm̱bä.
\v 6 Tøø hajxy ñägapxy maa jaꞌa tsajtøjcän coo miic̈h hajxy mjaanc̈h tehm̱ chocy mjaanc̈h tehm̱ piaꞌhäyoy. Y coo hajxy hänajty jiaac tuꞌubøgaaṉnä, mmóꞌowäp hajxy tijaty hajxy hänajty yajmaajiajpy.
\v 7 Hix̱, jaꞌa Jesucristocøxpä hajxy wiädity. Jaꞌa Diosmädiaꞌagy hajxy yajwaꞌxyp. Y cab hajxy tii miäyujwaꞌañ jaꞌa Diosmädiaꞌagy hajxy caꞌa panøcxpä.
\v 8 Paady jaduhṉ yhahixøꞌøy coo jaꞌa hermano hajxy nbuhbéjtämät; jaduhṉ hajxy hoy nmøødtúuṉämät maa jaꞌa Diostuuṉg jaduhṉ myiṉ̃än.
\p 
\v 9 Tøøc̈hä hermano nocy hajxy tuꞌug nja yajnäjaayøꞌøy, pero cábøc̈hä Diótrefes nmädiaꞌagy xquiudiunaaṉä, jeꞌeguiøxpä coo jaꞌa yhamdsoo mädiaꞌagy jaduhṉ yajtunaꞌañ maa jaꞌa hermanohajxiän.
\v 10 Haxøøgjátyhøch nax̱y xñänøm̱y. Y maas haxøøg jaduhṉ jiatcøꞌøy coo jaꞌa hermano cuhdujt hajxy quiaꞌa moꞌoy coo hajxy jiøjpøgǿꞌøwät jaꞌa Diosmädiaꞌagy hajxy yajwaꞌxpä. Y coo pøṉ hänajty jiøjpøgøꞌøwaꞌañ, mänitä Diótrefes miänaꞌañ coo yajpädsǿøm̱änät maa jaꞌa tsajtøjcän. Cooc̈h jim̱ nnǿcxät maa mijtsän, mänítøch ngøx̱y nägápxät nebiaty jiatcøꞌøy.
\v 11 Miic̈h mäguꞌughajpä, cab jaduhṉ mänaa mbajatcǿꞌøwät. Pøṉ jaduhṉ jatcøøby, cabä Diosmädiaꞌagy miäbøcy. Pero pøṉ hoy wädijp homiänaajä, miäbøjpiä Diosmädiaꞌagy jeꞌe. Jaduhṉ miic̈h mbahíxät.
\p 
\v 12 Pero jaꞌa Demetrio, cab jaduhṉ jiatcøꞌøy nebiä Diótrefes jiatcøꞌøyän. Tøyhajtä Demetrio jaꞌa Diosmädiaꞌagy pianøcxy hamuumduꞌjoot. Cumáayyäp jaduhṉ nägøx̱iä, y ngumáabiøch høøc̈hpä. Mnajuøøby miic̈h jaduhṉ cooc̈hä tøyhajt nmøødä.
\p 
\v 13 Madiúꞌujøch miic̈h nja hawaaṉáaṉäm. Pero cábøch njaayaaṉnä.
\v 14 Chójpiøch njoot jaduhṉ cooc̈h jim̱ nnǿcxät maa miic̈hän. Mänit haawhaam nmädiáacämät.
\p 
\v 15 Ween miic̈h jootcujc mmähmøꞌøy. Xyajpooꞌxp miic̈h jaꞌa mmäguꞌughajpähajxy yaabä. Tuṉä mayhajt, yajpóoꞌxäc højts nmäguꞌughajpähajxy jim̱bä nägøx̱iä.
