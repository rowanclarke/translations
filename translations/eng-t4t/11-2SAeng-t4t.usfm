\c 24
\s1 David ordered a census to be taken
\p 
\v 1 \w Yahweh|strong="H3068"\w* \w was|strong="H3068"\w* \w angry|strong="H2734"\w* \w with|strong="H3068"\w* \w the|strong="H3068"\w* Israeli people \w again|strong="H3254"\w*, \w so|strong="H3254"\w* \w he|strong="H3068"\w* \w incited|strong="H5496"\w* \w David|strong="H1732"\w* \w to|strong="H3478"\w* cause trouble \w for|strong="H3068"\w* \w them|strong="H3068"\w*. \w He|strong="H3068"\w* said \w to|strong="H3478"\w* \w David|strong="H1732"\w*, “Send \add some men\add* \w to|strong="H3478"\w* \w count|strong="H4487"\w* \w the|strong="H3068"\w* people \w of|strong="H3068"\w* \w Israel|strong="H3478"\w* \w and|strong="H3063"\w* \w Judah|strong="H3063"\w*.”
