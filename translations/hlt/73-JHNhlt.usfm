\v 22 \w Jesuh|strong="G2424"\w* \w loh|strong="G3588"\w*, \wj “ \w Anih|strong="G0846"\w* te ka \w lo|strong="G2064"\w* \w due|strong="G2193"\w* \w naeh|strong="G3306"\w* sak ham ka \w ngaih|strong="G2309"\w* \w cakhaw|strong="G1437"\w* \w nang|strong="G4571"\w* \w ham|strong="G4314"\w* \w balae|strong="G5101"\w* a ti eh? \w Nang|strong="G4771"\w* te \w kai|strong="G3427"\w* m'\w vai|strong="G0190"\w* ngawn,” \wj* a \w ti|strong="G3004"\w* nah.
\p 
\v 23 \w Te\w* \w dongah|strong="G3767"\w*, “\w Tekah|strong="G1565"\w* \w hnukbang|strong="G3101"\w* \w tah|strong="G3588"\w* \w duek|strong="G0599"\w* \w mahpawh|strong="G3756"\w* \w a \w*\w ti \w* \w olka|strong="G3056"\w* \w te|strong="G3754"\w* \w manuca|strong="G0080"\w* \w rhoek \w* \w taengah|strong="G1519"\w* yilh \w cet|strong="G1831"\w*. \w Tedae|strong="G1161"\w* \w Jesuh|strong="G2424"\w* \w loh|strong="G3588"\w* \w anih|strong="G0846"\w* \w te \w*, “\w Duek|strong="G0599"\w* \w mahpawh|strong="G3756"\w*,” \w a\w* \w ti|strong="G2036"\w* \w moenih|strong="G3756"\w*. “\wj \w Anih|strong="G0846"\w* te ka \w pawk|strong="G2064"\w* \w duela|strong="G2193"\w* \w naeh|strong="G3306"\w* sak ka \w ngaih|strong="G2309"\w* \w cakhaw|strong="G1437"\w* \w nang|strong="G4571"\w* \w ham|strong="G4314"\w* \w balae|strong="G5101"\w* a ti eh?,” \wj* ti ni a thui.
\s1 Ol Bawtnah
\p 
\v 24 \w He|strong="G3778"\w* \w tah\w* \w hnukbang|strong="G3101"\w* \w rhoek \w* \w loh|strong="G3588"\w* \w a\w* \w phong|strong="G3140"\w* \w tih|strong="G2532"\w* \w a\w* \w daek|strong="G1125"\w* \w rhoek \w* \w te|strong="G4012"\w* \w ni|strong="G2076"\w*. \w Te\w* \w dongah|strong="G2532"\w* \w a|strong="G0846"\w* \w olphong|strong="G3141"\w* \w aka \w*\w om|strong="G2076"\w* \w tah|strong="G3588"\w* \w oltak|strong="G0227"\w* \w tila|strong="G3754"\w* m'\w ming|strong="G1492"\w* \w uh\w*.
