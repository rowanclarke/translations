\toc1 Primer libro de los Reyes
\mt1 1 Reyes
\c 1
\s1 La llegada de Abisag sunamita al palacio real
\p 
\v 1 \w Cuando|strong="H3117"\w* el \w rey|strong="H4428"\w* \w David|strong="H1732"\w* era anciano, avanzado en \w días|strong="H3117"\w*, \w lo|strong="H3808"\w* \w cubrían|strong="H3680"\w* con ropas, pero \w no|strong="H3808"\w* \w se|strong="H3808"\w* calentaba.
\v 2 \w Por|strong="H6440"\w* tanto le dijeron sus esclavos: \w Que|strong="H1961"\w* \w busquen|strong="H1245"\w* \w para|strong="H1961"\w* \w mi|strong="H1961"\w* \tl ʼadón\tl* el \w rey|strong="H4428"\w* una joven \w virgen|strong="H1330"\w*. \w Que|strong="H1961"\w* ella \w esté|strong="H1961"\w* \w delante|strong="H6440"\w* del \w rey|strong="H4428"\w*, lo abrigue y duerma \w a|strong="H3068"\w* su lado \w para|strong="H1961"\w* \w que|strong="H1961"\w* \w mi|strong="H1961"\w* \tl ʼadón\tl* el \w rey|strong="H4428"\w* pueda calentarse.
\p 
\v 3 Entonces \w buscaron|strong="H1245"\w* \w a|strong="H3068"\w* \w una|strong="H4672"\w* joven bella \w por|strong="H4428"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* territorio de \w Israel|strong="H3478"\w*. \w Hallaron|strong="H4672"\w* \w a|strong="H3068"\w* Abisag \w sunamita|strong="H7767"\w* y \w la|strong="H3605"\w* llevaron \w al|strong="H4428"\w* \w rey|strong="H4428"\w*.
\v 4 La joven \w era|strong="H1961"\w* \w muy|strong="H3966"\w* bella. Ella atendía \w al|strong="H5704"\w* \w rey|strong="H4428"\w* \w y|strong="H5704"\w* le \w servía|strong="H8334"\w*, pero el \w rey|strong="H4428"\w* \w no|strong="H3808"\w* cohabitó \w con|strong="H5704"\w* ella.
\s1 La rebelión de Adonías
\p 
\v 5 Entonces Adonías, \w hijo|strong="H1121"\w* \w de|strong="H6440"\w* Haguit, se enalteció y dijo: ¡\w Yo|strong="H6213"\w* \w reinaré|strong="H4427"\w*! \w Y|strong="H3068"\w* se consiguió una carroza y \w jinetes|strong="H6571"\w*, y 50 \w hombres|strong="H1121"\w* \w que|strong="H1121"\w* corrieran \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w él|strong="H1121"\w*.
\v 6 \w Su|strong="H1931"\w* padre \w nunca|strong="H3808"\w* \w lo|strong="H1931"\w* amonestó \w ni|strong="H3808"\w* \w le|strong="H1931"\w* dijo: ¿\w Por|strong="H4069"\w* \w qué|strong="H1931"\w* actúas \w así|strong="H3602"\w*? \w También|strong="H1571"\w* \w era|strong="H1931"\w* hombre de \w muy|strong="H3966"\w* \w buena|strong="H2896"\w* presencia, \w y|strong="H1571"\w* \w nació|strong="H3205"\w* después de Absalón.
\p 
\v 7 Consultó \w con|strong="H5973"\w* \w Joab|strong="H3097"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5973"\w* Sarvia, y \w con|strong="H5973"\w* \w el|strong="H5973"\w* \w sacerdote|strong="H3548"\w* Abiatar, y ellos respaldaron \w a|strong="H3068"\w* Adonías.
\v 8 Pero \w el|strong="H5973"\w* \w sacerdote|strong="H3548"\w* \w Sadoc|strong="H6659"\w*, \w Benaías|strong="H1141"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5973"\w* \w Joiada|strong="H3077"\w*, \w el|strong="H5973"\w* \w profeta|strong="H5030"\w* Natán, Simei, Rei y \w los|strong="H1121"\w* \w valientes|strong="H1368"\w* \w que|strong="H3808"\w* \w tenía|strong="H1961"\w* \w David|strong="H1732"\w*, \w no|strong="H3808"\w* \w seguían|strong="H1961"\w* \w a|strong="H3068"\w* Adonías.
\p 
\v 9 Adonías \w sacrificó|strong="H2076"\w* \w ovejas|strong="H6629"\w*, \w bueyes|strong="H1241"\w* \w y|strong="H1241"\w* \w animales|strong="H1121"\w* gordos \w junto|strong="H5973"\w* \w a|strong="H3068"\w* \w la|strong="H3605"\w* piedra \w de|strong="H5973"\w* Zohélet, \w que|strong="H1121"\w* está \w cerca|strong="H5973"\w* \w de|strong="H5973"\w* \w la|strong="H3605"\w* fuente \w de|strong="H5973"\w* Roguel, \w e|strong="H3068"\w* invitó \w a|strong="H3068"\w* \w todos|strong="H3605"\w* sus hermanos, \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w del|strong="H5973"\w* \w rey|strong="H4428"\w* \w y|strong="H1241"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hombres|strong="H1121"\w* \w de|strong="H5973"\w* \w Judá|strong="H3063"\w*, esclavos \w del|strong="H5973"\w* \w rey|strong="H4428"\w*,
\v 10 pero \w no|strong="H3808"\w* invitó al \w profeta|strong="H5030"\w* Natán, \w ni|strong="H3808"\w* \w a|strong="H3068"\w* \w Benaías|strong="H1141"\w*, \w ni|strong="H3808"\w* \w a|strong="H3068"\w* los \w valientes|strong="H1368"\w*, \w ni|strong="H3808"\w* \w a|strong="H3068"\w* su hermano \w Salomón|strong="H8010"\w*.
\v 11 \w Entonces|strong="H3588"\w* Natán habló \w a|strong="H3068"\w* Betsabé, madre \w de|strong="H3588"\w* \w Salomón|strong="H8010"\w*: ¿\w No|strong="H3808"\w* \w oíste|strong="H8085"\w* \w que|strong="H3588"\w* \w reina|strong="H4427"\w* Adonías, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* Haguit, \w y|strong="H3588"\w* nuestro \tl ʼadón\tl* \w David|strong="H1732"\w* \w no|strong="H3808"\w* \w lo|strong="H3808"\w* \w sabe|strong="H3045"\w*?
\v 12 \w Ahora|strong="H6258"\w* \w pues|strong="H4994"\w*, \w ven|strong="H3212"\w*, permíteme darte un \w consejo|strong="H6098"\w* \w para|strong="H6258"\w* \w que|strong="H6258"\w* salves tu \w vida|strong="H5315"\w* y la \w vida|strong="H5315"\w* \w de|strong="H1121"\w* tu \w hijo|strong="H1121"\w* \w Salomón|strong="H8010"\w*:
\v 13 \w Vé|strong="H3212"\w*, preséntate \w al|strong="H5921"\w* \w rey|strong="H4428"\w* \w David|strong="H1732"\w* \w y|strong="H3588"\w* dile: ¿\w No|strong="H3808"\w* \w juraste|strong="H7650"\w* \w a|strong="H3068"\w* tu servidora, \w oh|strong="H1121"\w* \w rey|strong="H4428"\w* \tl ʼadón\tl* \w mío|strong="H5921"\w*: Tu \w hijo|strong="H1121"\w* \w Salomón|strong="H8010"\w* \w reinará|strong="H4427"\w* \w después|strong="H5921"\w* \w de|strong="H5921"\w* \w mí|strong="H5921"\w* \w y|strong="H3588"\w* \w se|strong="H1931"\w* sentará \w en|strong="H5921"\w* \w mi|strong="H5921"\w* \w trono|strong="H3678"\w*? ¿\w Por|strong="H5921"\w* \w qué|strong="H3588"\w* \w entonces|strong="H3588"\w* \w reina|strong="H4427"\w* Adonías?
\v 14 \w Mira|strong="H2009"\w*, \w mientras|strong="H5750"\w* tú \w aún|strong="H5750"\w* hablas \w allí|strong="H8033"\w* \w con|strong="H5973"\w* \w el|strong="H5973"\w* \w rey|strong="H4428"\w*, \w yo|strong="H2009"\w* entraré después \w de|strong="H5973"\w* \w ti|strong="H5973"\w* y confirmaré tus \w palabras|strong="H1697"\w*.
\p 
\v 15 Entonces Betsabé entró en el dormitorio del \w rey|strong="H4428"\w*, quien estaba \w muy|strong="H3966"\w* anciano. \w Y|strong="H3068"\w* Abisag \w sunamita|strong="H7767"\w* cuidaba \w al|strong="H4428"\w* \w rey|strong="H4428"\w*.
\p 
\v 16 Betsabé \w se|strong="H4100"\w* \w inclinó|strong="H6915"\w* ante el \w rey|strong="H4428"\w*, y el \w rey|strong="H4428"\w* preguntó: ¿\w Qué|strong="H4100"\w* deseas?
\p 
\v 17 \w Y|strong="H3068"\w* \w ella|strong="H1931"\w* \w le|strong="H1931"\w* respondió: \tl ʼAdón\tl* \w mío|strong="H5921"\w*, tú \w juraste|strong="H7650"\w* \w a|strong="H3068"\w* tu servidora \w por|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd*: Tu \w hijo|strong="H1121"\w* \w Salomón|strong="H8010"\w* \w reinará|strong="H4427"\w* \w después|strong="H5921"\w* \w de|strong="H5921"\w* \w mí|strong="H5921"\w*, \w y|strong="H3588"\w* \w él|strong="H1931"\w* \w se|strong="H1931"\w* sentará \w en|strong="H5921"\w* \w mi|strong="H5921"\w* \w trono|strong="H3678"\w*.
\v 18 Pero \w ahora|strong="H6258"\w* \w mira|strong="H2009"\w*, Adonías \w reina|strong="H4427"\w*, y tú, \w mi|strong="H2009"\w* \tl ʼadón\tl* el \w rey|strong="H4428"\w*, \w no|strong="H3808"\w* \w lo|strong="H3808"\w* \w sabes|strong="H3045"\w*.
\v 19 \w Él|strong="H3605"\w* \w sacrificó|strong="H2076"\w* becerros, \w animales|strong="H1121"\w* gordos \w y|strong="H7794"\w* \w ovejas|strong="H6629"\w* en \w abundancia|strong="H7230"\w*, \w e|strong="H3068"\w* invitó \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* del \w rey|strong="H4428"\w*, \w al|strong="H4428"\w* \w sacerdote|strong="H3548"\w* Abiatar \w y|strong="H7794"\w* \w Joab|strong="H3097"\w*, \w general|strong="H8269"\w* del \w ejército|strong="H6635"\w*, pero \w a|strong="H3068"\w* \w Salomón|strong="H8010"\w* tu esclavo \w no|strong="H3808"\w* \w lo|strong="H3808"\w* invitó.
\v 20 \w Sobre|strong="H5921"\w* \w ti|strong="H5921"\w*, \w oh|strong="H4310"\w* \w rey|strong="H4428"\w* \tl ʼadón\tl* \w mío|strong="H5921"\w*, \w están|strong="H3427"\w* \w los|strong="H3427"\w* \w ojos|strong="H5869"\w* \w de|strong="H5921"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* \w para|strong="H5921"\w* \w que|strong="H4310"\w* \w les|strong="H5921"\w* declares \w quién|strong="H4310"\w* \w se|strong="H5921"\w* sentará \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w trono|strong="H3678"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \tl ʼadón\tl* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w después|strong="H5921"\w* \w de|strong="H5921"\w* \w él|strong="H5921"\w*.
\v 21 \w De|strong="H5973"\w* otra manera, \w acontecerá|strong="H1961"\w* \w que|strong="H1121"\w* \w cuando|strong="H1961"\w* \w mi|strong="H1961"\w* \tl ʼadón\tl* \w el|strong="H5973"\w* \w rey|strong="H4428"\w* repose \w con|strong="H5973"\w* sus antepasados, \w mi|strong="H1961"\w* \w hijo|strong="H1121"\w* \w Salomón|strong="H8010"\w* y yo \w seremos|strong="H1961"\w* considerados \w como|strong="H5973"\w* ofensores.
\p 
\v 22 \w Ciertamente|strong="H2009"\w*, \w mientras|strong="H5750"\w* ella \w aún|strong="H5750"\w* \w hablaba|strong="H1696"\w* \w con|strong="H5973"\w* \w el|strong="H5973"\w* \w rey|strong="H4428"\w*, llegó \w el|strong="H5973"\w* \w profeta|strong="H5030"\w* Natán.
\v 23 Informaron \w al|strong="H5921"\w* \w rey|strong="H4428"\w*: \w Aquí|strong="H2009"\w* \w está|strong="H5921"\w* \w el|strong="H5921"\w* \w profeta|strong="H5030"\w* Natán. \w Y|strong="H3068"\w* \w él|strong="H5921"\w* entró \w ante|strong="H6440"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w y|strong="H5921"\w* \w se|strong="H5921"\w* inclinó rosto \w en|strong="H5921"\w* tierra \w ante|strong="H6440"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w*.
\p 
\v 24 \w Y|strong="H3068"\w* Natán dijo: ¿Dijo \w mi|strong="H5921"\w* \tl ʼadón\tl* \w el|strong="H1931"\w* \w rey|strong="H4428"\w*: Adonías \w reinará|strong="H4427"\w* \w después|strong="H5921"\w* \w de|strong="H5921"\w* \w mí|strong="H5921"\w* \w y|strong="H5921"\w* \w él|strong="H1931"\w* \w se|strong="H1931"\w* sentará \w en|strong="H5921"\w* \w mi|strong="H5921"\w* \w trono|strong="H3678"\w*?
\v 25 \w Porque|strong="H3588"\w* \w hoy|strong="H3117"\w* \w él|strong="H3588"\w* bajó \w y|strong="H3588"\w* \w sacrificó|strong="H2076"\w* \w bueyes|strong="H7794"\w*, \w animales|strong="H1121"\w* gordos \w y|strong="H3588"\w* \w ovejas|strong="H6629"\w* \w en|strong="H3588"\w* \w abundancia|strong="H7230"\w*, \w e|strong="H3068"\w* invitó \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w del|strong="H8354"\w* \w rey|strong="H4428"\w*, \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w capitanes|strong="H8269"\w* \w del|strong="H8354"\w* \w ejército|strong="H6635"\w* \w y|strong="H3588"\w* \w al|strong="H4428"\w* \w sacerdote|strong="H3548"\w* Abiatar. \w Ciertamente|strong="H3588"\w* comen \w y|strong="H3588"\w* \w beben|strong="H8354"\w* \w ante|strong="H6440"\w* \w él|strong="H3588"\w*, \w y|strong="H3588"\w* dijeron: ¡\w Viva|strong="H2421"\w* \w el|strong="H3588"\w* \w rey|strong="H4428"\w* Adonías!
\v 26 Pero \w no|strong="H3808"\w* me invitaron \w a|strong="H3068"\w* mí, tu esclavo, \w ni|strong="H3808"\w* al \w sacerdote|strong="H3548"\w* \w Sadoc|strong="H6659"\w*, \w ni|strong="H3808"\w* \w a|strong="H3068"\w* \w Benaías|strong="H1141"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Joiada|strong="H3077"\w*, \w ni|strong="H3808"\w* \w a|strong="H3068"\w* tu esclavo \w Salomón|strong="H8010"\w*.
\v 27 ¿Hizo \w esto|strong="H2088"\w* \w mi|strong="H5921"\w* \tl ʼadón\tl* \w el|strong="H5921"\w* \w rey|strong="H4428"\w*, \w sin|strong="H3808"\w* informar \w a|strong="H3068"\w* tus esclavos \w quién|strong="H4310"\w* debía sentarse \w después|strong="H5921"\w* \w de|strong="H5921"\w* \w él|strong="H5921"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w trono|strong="H3678"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* amo \w el|strong="H5921"\w* \w rey|strong="H4428"\w*?
\p 
\v 28 Entonces el \w rey|strong="H4428"\w* \w David|strong="H1732"\w* \w respondió|strong="H6030"\w*: Llámenme \w a|strong="H3068"\w* Betsabé. \w Y|strong="H3068"\w* ella entró \w ante|strong="H6440"\w* el \w rey|strong="H4428"\w* y \w estuvo|strong="H5975"\w* \w en|strong="H5975"\w* \w pie|strong="H5975"\w* \w ante|strong="H6440"\w* él.
\p 
\v 29 \w Y|strong="H3068"\w* \w el|strong="H3605"\w* \w rey|strong="H4428"\w* \w juró|strong="H7650"\w*: \w Vive|strong="H2416"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w Quien|strong="H3605"\w* rescató \w mi|strong="H5315"\w* \w alma|strong="H5315"\w* de \w toda|strong="H3605"\w* \w angustia|strong="H6869"\w*,
\v 30 \w que|strong="H3588"\w* \w como|strong="H3588"\w* \w te|strong="H5921"\w* \w juré|strong="H7650"\w* \w por|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w el|strong="H1931"\w* \nd ʼElohim\nd* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*: ¡\w Ciertamente|strong="H3588"\w* \w tu|strong="H6213"\w* \w hijo|strong="H1121"\w* \w Salomón|strong="H8010"\w* \w reinará|strong="H4427"\w* \w después|strong="H5921"\w* \w de|strong="H5921"\w* \w mí|strong="H5921"\w*. \w Él|strong="H1931"\w* \w se|strong="H1931"\w* sentará \w en|strong="H5921"\w* \w mi|strong="H5921"\w* \w trono|strong="H3678"\w* \w en|strong="H5921"\w* \w mi|strong="H5921"\w* \w lugar|strong="H8478"\w*, \w así|strong="H3651"\w* \w lo|strong="H1931"\w* \w haré|strong="H6213"\w* \w hoy|strong="H3117"\w* \w mismo|strong="H1931"\w*!
\p 
\v 31 Betsabé se \w inclinó|strong="H6915"\w* rostro en tierra ante el \w rey|strong="H4428"\w* y dijo: ¡\w Viva|strong="H2421"\w* mi \tl ʼadón\tl* el \w rey|strong="H4428"\w* \w David|strong="H1732"\w* para \w siempre|strong="H5769"\w*!
\s1 Unción de Salomón como rey
\p 
\v 32 \w El|strong="H1121"\w* \w rey|strong="H4428"\w* \w David|strong="H1732"\w* dijo: ¡Llámenme \w al|strong="H4428"\w* \w sacerdote|strong="H3548"\w* \w Sadoc|strong="H6659"\w*, \w al|strong="H4428"\w* \w profeta|strong="H5030"\w* Natán y \w a|strong="H3068"\w* \w Benaías|strong="H1141"\w*, \w hijo|strong="H1121"\w* \w de|strong="H6440"\w* \w Joiada|strong="H3077"\w*! \w Y|strong="H3068"\w* ellos entraron \w ante|strong="H6440"\w* \w el|strong="H1121"\w* \w rey|strong="H4428"\w*.
\v 33 \w Y|strong="H3068"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w les|strong="H5973"\w* dijo: \w Tomen|strong="H3947"\w* \w con|strong="H5973"\w* ustedes \w a|strong="H3068"\w* \w los|strong="H1121"\w* esclavos \w de|strong="H5921"\w* su \tl ʼadón\tl*, \w y|strong="H5921"\w* digan \w a|strong="H3068"\w* \w mi|strong="H5921"\w* \w hijo|strong="H1121"\w* \w Salomón|strong="H8010"\w* \w que|strong="H5921"\w* monte \w sobre|strong="H5921"\w* \w mi|strong="H5921"\w* propia mula, \w y|strong="H5921"\w* bájenlo \w a|strong="H3068"\w* Gihón.
\v 34 \w El|strong="H5921"\w* \w sacerdote|strong="H3548"\w* \w Sadoc|strong="H6659"\w* \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w profeta|strong="H5030"\w* Natán \w lo|strong="H5921"\w* ungirán \w allí|strong="H8033"\w* \w como|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, soplarán \w la|strong="H5921"\w* \w corneta|strong="H7782"\w* \w y|strong="H5921"\w* gritarán: ¡\w Viva|strong="H2421"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w Salomón|strong="H8010"\w*!
\v 35 \w Después|strong="H5921"\w* ustedes \w subirán|strong="H5927"\w* tras \w él|strong="H1931"\w*. \w Y|strong="H3068"\w* \w él|strong="H1931"\w* \w vendrá|strong="H1961"\w*, \w se|strong="H1961"\w* sentará \w en|strong="H5921"\w* \w mi|strong="H5921"\w* \w trono|strong="H3678"\w* \w y|strong="H5921"\w* \w reinará|strong="H4427"\w* \w en|strong="H5921"\w* \w mi|strong="H5921"\w* \w lugar|strong="H8478"\w*, \w pues|strong="H1931"\w* \w lo|strong="H1931"\w* designé soberano \w sobre|strong="H5921"\w* \w Israel|strong="H3478"\w* \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* \w Judá|strong="H3063"\w*.
\p 
\v 36 \w Benaías|strong="H1141"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Joiada|strong="H3077"\w*, \w respondió|strong="H6030"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w*: ¡Amén! ¡\w Así|strong="H3651"\w* lo haga \nd \w Yavé|strong="H3068"\w*, ʼElohim\nd* \w de|strong="H1121"\w* \w mi|strong="H6030"\w* \tl ʼadón\tl* \w el|strong="H1121"\w* \w rey|strong="H4428"\w*!
\v 37 \w Así|strong="H3651"\w* \w como|strong="H5973"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w estuvo|strong="H1961"\w* \w con|strong="H5973"\w* \w mi|strong="H1431"\w* \tl ʼadón\tl* \w el|strong="H5973"\w* \w rey|strong="H4428"\w*, \w así|strong="H3651"\w* \w esté|strong="H1961"\w* \w Él|strong="H5973"\w* \w con|strong="H5973"\w* \w Salomón|strong="H8010"\w*, y engrandezca su \w trono|strong="H3678"\w* más \w que|strong="H1961"\w* \w el|strong="H5973"\w* \w trono|strong="H3678"\w* \w de|strong="H5973"\w* \w mi|strong="H1431"\w* amo \w el|strong="H5973"\w* \w rey|strong="H4428"\w* \w David|strong="H1732"\w*.
\p 
\v 38 \w El|strong="H5921"\w* \w sacerdote|strong="H3548"\w* \w Sadoc|strong="H6659"\w*, \w el|strong="H5921"\w* \w profeta|strong="H5030"\w* Natán \w y|strong="H5921"\w* \w Benaías|strong="H1141"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Joiada|strong="H3077"\w*, \w junto|strong="H5921"\w* \w con|strong="H5921"\w* \w los|strong="H1121"\w* cereteos \w y|strong="H5921"\w* \w los|strong="H1121"\w* peleteos, \w bajaron|strong="H3381"\w* \w y|strong="H5921"\w* montaron \w a|strong="H3068"\w* \w Salomón|strong="H8010"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* mula \w del|strong="H5921"\w* \w rey|strong="H4428"\w* \w David|strong="H1732"\w* \w y|strong="H5921"\w* \w lo|strong="H5921"\w* condujeron \w a|strong="H3068"\w* Gihón.
\v 39 Entonces \w el|strong="H3605"\w* \w sacerdote|strong="H3548"\w* \w Sadoc|strong="H6659"\w* \w tomó|strong="H3947"\w* \w el|strong="H3605"\w* \w cuerno|strong="H7161"\w* \w de|strong="H4480"\w* \w aceite|strong="H8081"\w* \w del|strong="H4480"\w* Tabernáculo y \w ungió|strong="H4886"\w* \w a|strong="H3068"\w* \w Salomón|strong="H8010"\w*. Soplaron \w la|strong="H3605"\w* \w corneta|strong="H7782"\w*, y \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* exclamó: ¡\w Viva|strong="H2421"\w* \w el|strong="H3605"\w* \w rey|strong="H4428"\w* \w Salomón|strong="H8010"\w*!
\v 40 \w Todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* \w subió|strong="H5927"\w* tras \w él|strong="H3605"\w*, y \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* tocaba \w flautas|strong="H2485"\w* y \w se|strong="H5971"\w* regocijaba con tal regocijo \w que|strong="H5971"\w* \w la|strong="H3605"\w* tierra \w se|strong="H5971"\w* hundía con \w el|strong="H3605"\w* clamor \w de|strong="H5971"\w* \w ellos|strong="H3605"\w*.
\p 
\v 41 Adonías y \w todos|strong="H3605"\w* \w los|strong="H1992"\w* huéspedes \w que|strong="H1992"\w* estaban con \w él|strong="H3605"\w* \w oyeron|strong="H8085"\w* eso cuando terminaron de comer. \w Y|strong="H3068"\w* cuando \w Joab|strong="H3097"\w* \w oyó|strong="H8085"\w* \w el|strong="H3605"\w* \w sonido|strong="H6963"\w* de \w la|strong="H3605"\w* \w corneta|strong="H7782"\w*, dijo: ¿\w Por|strong="H4069"\w* \w qué|strong="H1992"\w* hay tanto bullicio y tanto alboroto en \w la|strong="H3605"\w* \w ciudad|strong="H7151"\w*?
\p 
\v 42 \w Mientras|strong="H5750"\w* \w él|strong="H3588"\w* \w aún|strong="H5750"\w* \w hablaba|strong="H1696"\w*, ahí llegaba Jonatán, \w hijo|strong="H1121"\w* del \w sacerdote|strong="H3548"\w* Abiatar, \w y|strong="H3588"\w* Adonías le \w dijo|strong="H1696"\w*: Entra, \w porque|strong="H3588"\w* eres \w hombre|strong="H1121"\w* digno \w y|strong="H3588"\w* traes \w buenas|strong="H2896"\w* noticias.
\p 
\v 43 Pero Jonatán \w respondió|strong="H6030"\w* \w a|strong="H3068"\w* Adonías: \w Al|strong="H4428"\w* contrario, nuestro \tl ʼadón\tl* el \w rey|strong="H4428"\w* \w David|strong="H1732"\w* designó como \w rey|strong="H4428"\w* \w a|strong="H3068"\w* \w Salomón|strong="H8010"\w*.
\v 44 \w El|strong="H5921"\w* \w rey|strong="H4428"\w* \w envió|strong="H7971"\w* \w con|strong="H5921"\w* \w él|strong="H5921"\w* \w al|strong="H5921"\w* \w sacerdote|strong="H3548"\w* \w Sadoc|strong="H6659"\w*, \w al|strong="H5921"\w* \w profeta|strong="H5030"\w* Natán, \w a|strong="H3068"\w* \w Benaías|strong="H1141"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Joiada|strong="H3077"\w*, \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* cereteos \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* peleteos, \w y|strong="H5921"\w* \w lo|strong="H5921"\w* montaron \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* mula \w del|strong="H5921"\w* \w rey|strong="H4428"\w*.
\v 45 \w El|strong="H1931"\w* \w sacerdote|strong="H3548"\w* \w Sadoc|strong="H6659"\w* y \w el|strong="H1931"\w* \w profeta|strong="H5030"\w* Natán \w lo|strong="H1931"\w* \w ungieron|strong="H4886"\w* \w como|strong="H1931"\w* \w rey|strong="H4428"\w* en Gihón, y \w subieron|strong="H5927"\w* desde \w allí|strong="H8033"\w* con gran regocijo, de modo \w que|strong="H1931"\w* \w la|strong="H1931"\w* \w ciudad|strong="H7151"\w* \w está|strong="H1931"\w* alborotada. \w Ese|strong="H1931"\w* \w es|strong="H1931"\w* \w el|strong="H1931"\w* bullicio \w que|strong="H1931"\w* \w oyeron|strong="H8085"\w*.
\s1 Salomón, rey de Israel
\p 
\v 46 \w Además|strong="H5921"\w*, \w Salomón|strong="H8010"\w* \w se|strong="H5921"\w* sentó \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w trono|strong="H3678"\w* \w del|strong="H5921"\w* \w reino|strong="H4410"\w*,
\v 47 \w y|strong="H1571"\w* \w también|strong="H1571"\w* \w los|strong="H5921"\w* esclavos \w del|strong="H5921"\w* \w rey|strong="H4428"\w* llegaron \w a|strong="H3068"\w* bendecir \w a|strong="H3068"\w* nuestro \tl ʼadón\tl*, \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w David|strong="H1732"\w*, \w y|strong="H1571"\w* dijeron: ¡Tu \nd ʼElohim\nd* haga \w el|strong="H5921"\w* \w nombre|strong="H8034"\w* \w de|strong="H5921"\w* \w Salomón|strong="H8010"\w* \w más|strong="H1571"\w* ilustre \w que|strong="H5921"\w* tu \w nombre|strong="H8034"\w*, \w y|strong="H1571"\w* engrandezca su \w trono|strong="H3678"\w* \w más|strong="H1571"\w* \w que|strong="H5921"\w* \w el|strong="H5921"\w* tuyo! \w Y|strong="H3068"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w le|strong="H5921"\w* hizo reverencia \w sobre|strong="H5921"\w* su \w cama|strong="H4904"\w*.
\p 
\v 48 \w Y|strong="H3068"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w también|strong="H1571"\w* dijo: ¡\w Bendito|strong="H1288"\w* sea \nd \w Yavé|strong="H3068"\w*, ʼElohim\nd* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w que|strong="H5921"\w* actuó \w para|strong="H5921"\w* \w que|strong="H5921"\w* uno \w se|strong="H5921"\w* siente \w en|strong="H5921"\w* \w mi|strong="H5921"\w* \w trono|strong="H3678"\w* \w hoy|strong="H3117"\w*, \w y|strong="H1571"\w* \w que|strong="H5921"\w* \w mis|strong="H5414"\w* \w ojos|strong="H5869"\w* \w lo|strong="H5921"\w* \w vean|strong="H7200"\w*!
\p 
\v 49 Entonces \w todos|strong="H3605"\w* \w los|strong="H3605"\w* huéspedes de Adonías se estremecieron, se \w levantaron|strong="H6965"\w* y \w cada|strong="H3605"\w* uno se \w fue|strong="H3212"\w* \w por|strong="H1870"\w* su \w camino|strong="H1870"\w*.
\v 50 Pero Adonías \w tuvo|strong="H3372"\w* \w temor|strong="H3372"\w* \w a|strong="H3068"\w* \w Salomón|strong="H8010"\w* y se \w levantó|strong="H6965"\w*. \w Fue|strong="H3212"\w* y se agarró \w de|strong="H6440"\w* los \w cuernos|strong="H7161"\w* \w del|strong="H4196"\w* \w altar|strong="H4196"\w*.
\p 
\v 51 Informaron \w a|strong="H3068"\w* \w Salomón|strong="H8010"\w* y le dijeron: \w Mira|strong="H2009"\w*, Adonías \w teme|strong="H3372"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w* \w Salomón|strong="H8010"\w*, \w porque|strong="H2009"\w* se agarró \w de|strong="H3372"\w* los \w cuernos|strong="H7161"\w* \w del|strong="H4196"\w* \w altar|strong="H4196"\w* y \w dijo|strong="H5046"\w*: ¡\w Júreme|strong="H7650"\w* \w hoy|strong="H3117"\w* el \w rey|strong="H4428"\w* \w Salomón|strong="H8010"\w* \w que|strong="H3117"\w* no \w matará|strong="H4191"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w* \w a|strong="H3068"\w* su esclavo!
\p 
\v 52 \w Salomón|strong="H8010"\w* dijo: \w Si|strong="H3808"\w* \w él|strong="H5307"\w* \w es|strong="H1961"\w* un \w hombre|strong="H1121"\w* digno, \w ni|strong="H3808"\w* uno \w de|strong="H1121"\w* sus cabellos \w caerá|strong="H5307"\w* \w a|strong="H3068"\w* la tierra, pero \w si|strong="H3808"\w* \w es|strong="H1961"\w* hallada en \w él|strong="H5307"\w* perversidad, \w morirá|strong="H4191"\w*.
\v 53 \w El|strong="H5921"\w* \w rey|strong="H4428"\w* \w Salomón|strong="H8010"\w* ordenó \w que|strong="H5921"\w* \w lo|strong="H5921"\w* sacaran \w del|strong="H5921"\w* \w altar|strong="H4196"\w*. \w Y|strong="H3068"\w* \w él|strong="H5921"\w* \w fue|strong="H3212"\w* \w y|strong="H5921"\w* \w se|strong="H5921"\w* inclinó ante \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w Salomón|strong="H8010"\w*, quien \w le|strong="H5921"\w* dijo: \w Vete|strong="H3212"\w* \w a|strong="H3068"\w* tu \w casa|strong="H1004"\w*.
\c 2
\s1 Consejos finales de David a Salomón
\p 
\v 1 \w Cuando|strong="H3117"\w* se acercaban \w los|strong="H1121"\w* \w días|strong="H3117"\w* \w de|strong="H1121"\w* la \w muerte|strong="H4191"\w* \w de|strong="H1121"\w* \w David|strong="H1732"\w*, dio órdenes \w a|strong="H3068"\w* su \w hijo|strong="H1121"\w* \w Salomón|strong="H8010"\w*:
\v 2 Yo sigo \w el|strong="H3605"\w* \w camino|strong="H1870"\w* de \w todos|strong="H3605"\w* en \w la|strong="H3605"\w* tierra. \w Por|strong="H1870"\w* tanto, ¡\w esfuérzate|strong="H2388"\w* y \w sé|strong="H1961"\w* valiente!
\v 3 \w Guarda|strong="H8104"\w* \w la|strong="H8104"\w* encomienda de \nd \w Yavé|strong="H3068"\w*\nd* \w tu|strong="H6213"\w* \nd ʼElohim\nd* \w para|strong="H4616"\w* \w andar|strong="H3212"\w* \w en|strong="H3212"\w* sus \w caminos|strong="H1870"\w*, y \w guardar|strong="H8104"\w* sus \w Estatutos|strong="H2708"\w*, \w Mandamientos|strong="H4687"\w*, \w Ordenanzas|strong="H4941"\w* y Testimonios, como están \w escritos|strong="H3789"\w* \w en|strong="H3212"\w* \w la|strong="H8104"\w* \w Ley|strong="H8451"\w* de \w Moisés|strong="H4872"\w*, \w para|strong="H4616"\w* \w que|strong="H4616"\w* tengas éxito \w en|strong="H3212"\w* \w todo|strong="H3605"\w* \w lo|strong="H6213"\w* \w que|strong="H4616"\w* \w hagas|strong="H6213"\w* y dondequiera \w que|strong="H4616"\w* \w vayas|strong="H3212"\w*,
\v 4 \w para|strong="H4616"\w* \w que|strong="H3808"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w cumpla|strong="H6965"\w* su \w Palabra|strong="H1697"\w* \w que|strong="H3808"\w* \w habló|strong="H1696"\w* \w acerca|strong="H5921"\w* \w de|strong="H5921"\w* \w mí|strong="H5921"\w*, cuando \w dijo|strong="H1696"\w*: \wj \w Si|strong="H3808"\w* tus \w hijos|strong="H1121"\w* \w guardan|strong="H8104"\w* sus \w caminos|strong="H1870"\w*, \w si|strong="H3808"\w* andan \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w Mí|strong="H5921"\w* \w con|strong="H5921"\w* fidelidad, \w con|strong="H5921"\w* \w todo|strong="H3605"\w* su \w corazón|strong="H3824"\w* \w y|strong="H5921"\w* \w con|strong="H5921"\w* \w toda|strong="H3605"\w* su \w alma|strong="H5315"\w*, \w jamás|strong="H3808"\w* \w te|strong="H5921"\w* \w faltará|strong="H3772"\w* varón \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w trono|strong="H3678"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.\wj*
\p 
\v 5 Ahora, \w tú|strong="H6213"\w* \w sabes|strong="H3045"\w* \w lo|strong="H6213"\w* \w que|strong="H1571"\w* me \w hizo|strong="H6213"\w* \w Joab|strong="H3097"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Sarvia, \w lo|strong="H6213"\w* \w que|strong="H1571"\w* \w hizo|strong="H6213"\w* \w a|strong="H3068"\w* \w dos|strong="H8147"\w* \w generales|strong="H8269"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w ejércitos|strong="H6635"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*: \w a|strong="H3068"\w* Abner, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Ner|strong="H5369"\w*, \w y|strong="H1571"\w* \w a|strong="H3068"\w* \w Amasa|strong="H6021"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Jeter|strong="H3500"\w*, \w a|strong="H3068"\w* quienes \w mató|strong="H2026"\w*. Derramó \w sangre|strong="H1818"\w* \w de|strong="H1121"\w* \w guerra|strong="H4421"\w* en tiempo \w de|strong="H1121"\w* \w paz|strong="H7965"\w*, \w y|strong="H1571"\w* \w puso|strong="H7760"\w* \w sangre|strong="H1818"\w* \w de|strong="H1121"\w* \w guerra|strong="H4421"\w* en \w el|strong="H1121"\w* cinturón \w que|strong="H1571"\w* llevaba en su cintura \w y|strong="H1571"\w* en \w el|strong="H1121"\w* calzado \w que|strong="H1571"\w* tenía en sus \w pies|strong="H7272"\w*.
\v 6 \w Haz|strong="H6213"\w* conforme \w a|strong="H3068"\w* \w tu|strong="H6213"\w* \w sabiduría|strong="H2451"\w*, pero \w no|strong="H3808"\w* permitas \w que|strong="H3808"\w* sus canas \w desciendan|strong="H3381"\w* en \w paz|strong="H7965"\w* al \tl Seol\tl*.
\p 
\v 7 \w Pero|strong="H3588"\w* muestra benevolencia \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* Barzilai galadita. \w Que|strong="H3588"\w* ellos \w estén|strong="H1961"\w* \w entre|strong="H3588"\w* \w los|strong="H1121"\w* \w que|strong="H3588"\w* comen \w a|strong="H3068"\w* \w tu|strong="H6213"\w* \w mesa|strong="H7979"\w*, \w porque|strong="H3588"\w* \w se|strong="H1961"\w* colocaron \w a|strong="H3068"\w* \w mi|strong="H1961"\w* lado \w cuando|strong="H3588"\w* \w yo|strong="H3588"\w* \w huía|strong="H1272"\w* \w de|strong="H3588"\w* \w tu|strong="H6213"\w* hermano Absalón.
\p 
\v 8 \w Mira|strong="H2009"\w*, tienes \w contigo|strong="H5973"\w* \w a|strong="H3068"\w* Simei, \w hijo|strong="H1121"\w* \w de|strong="H5973"\w* \w Gera|strong="H1617"\w*, \w benjamita|strong="H1121"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5973"\w* Bahurim, \w quien|strong="H1931"\w* \w me|strong="H5973"\w* \w maldijo|strong="H7043"\w* \w con|strong="H5973"\w* una cruel \w maldición|strong="H7045"\w* \w el|strong="H1931"\w* \w día|strong="H3117"\w* \w cuando|strong="H3117"\w* \w yo|strong="H2009"\w* \w iba|strong="H3212"\w* \w a|strong="H3068"\w* \w Mahanaim|strong="H4266"\w*. Pero \w él|strong="H1931"\w* bajó \w a|strong="H3068"\w* recibirme al \w Jordán|strong="H3383"\w*, por \w lo|strong="H1931"\w* \w que|strong="H1931"\w* \w le|strong="H1931"\w* \w juré|strong="H7650"\w* por \nd \w Yavé|strong="H3068"\w*\nd*: No \w te|strong="H5973"\w* \w mataré|strong="H4191"\w* \w con|strong="H5973"\w* \w la|strong="H1931"\w* \w espada|strong="H2719"\w*.
\v 9 \w Pero|strong="H3588"\w* \w ahora|strong="H6258"\w*, \w no|strong="H6213"\w* \w lo|strong="H6213"\w* absolverás, \w pues|strong="H3588"\w* eres hombre \w sabio|strong="H2450"\w*, \w sabes|strong="H3045"\w* \w cómo|strong="H3588"\w* debes hablar \w con|strong="H3588"\w* \w él|strong="H3588"\w* \w y|strong="H3588"\w* \w harás|strong="H6213"\w* bajar sus canas \w con|strong="H3588"\w* \w sangre|strong="H1818"\w* \w al|strong="H5352"\w* \tl Seol\tl*.
\s1 Muerte de David
\p 
\v 10 \w David|strong="H1732"\w* \w durmió|strong="H7901"\w* \w con|strong="H5973"\w* sus antepasados y fue \w sepultado|strong="H6912"\w* \w en|strong="H5973"\w* la \w ciudad|strong="H5892"\w* \w de|strong="H5973"\w* \w David|strong="H1732"\w*.
\v 11 \w Los|strong="H5921"\w* \w días|strong="H3117"\w* \w que|strong="H5921"\w* \w David|strong="H1732"\w* \w reinó|strong="H4427"\w* \w sobre|strong="H5921"\w* \w Israel|strong="H3478"\w* \w fueron|strong="H1732"\w* 40 \w años|strong="H8141"\w*: \w siete|strong="H7651"\w* \w años|strong="H8141"\w* \w reinó|strong="H4427"\w* \w en|strong="H5921"\w* \w Hebrón|strong="H2275"\w*, \w y|strong="H5921"\w* 33 \w años|strong="H8141"\w* \w reinó|strong="H4427"\w* \w en|strong="H5921"\w* Jerusalén.
\v 12 \w Salomón|strong="H8010"\w* \w se|strong="H5921"\w* sentó \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w trono|strong="H3678"\w* \w de|strong="H5921"\w* su padre \w David|strong="H1732"\w*, \w y|strong="H5921"\w* su \w reino|strong="H4428"\w* fue firmemente \w establecido|strong="H3559"\w*.
\p 
\v 13 Pero Adonías, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Haguit, fue \w a|strong="H3068"\w* Betsabé, madre \w de|strong="H1121"\w* \w Salomón|strong="H8010"\w*, y ella le preguntó: ¿Es pacífica tu visita?
\p \w Y|strong="H3068"\w* \w él|strong="H1121"\w* respondió: Es pacífica.
\v 14 \w Y|strong="H3068"\w* agregó: \w Tengo|strong="H1696"\w* \w algo|strong="H1697"\w* \w que|strong="H1697"\w* decirte.
\p Ella respondió: \w Habla|strong="H1696"\w*.
\p 
