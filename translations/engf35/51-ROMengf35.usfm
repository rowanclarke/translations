\c 16  
\ms1 Closing remarks  
\s1 Phoebe  
\m
\v 1 \w I|strong="G1473"\w* \w commend|strong="G4921"\w* \w to|strong="G2532"\w* \w you|strong="G5210"\w* \w our|strong="G2532"\w* sister \w Phoebe|strong="G5402"\w*, \w who|strong="G3588"\w* \w is|strong="G1510"\w* \w a|strong="G2532"\w* \w servant|strong="G1249"\w* \w of|strong="G2532"\w* \w the|strong="G1722"\w* \w congregation|strong="G1577"\w* \w in|strong="G1722"\w* \w Cenchrea|strong="G2747"\w*,  
\v 2 \w so|strong="G2443"\w* \w that|strong="G2443"\w* \w you|strong="G5210"\w* \w may|strong="G2532"\w* \w receive|strong="G4327"\w* \w her|strong="G1438"\w* \w in|strong="G1722"\w* \w the|strong="G1722"\w* \w Lord|strong="G2962"\w* \w in|strong="G1722"\w* \w a|strong="G1096"\w* manner worthy \w of|strong="G2532"\w* \w the|strong="G1722"\w* saints, \w and|strong="G2532"\w* \w assist|strong="G3936"\w* \w her|strong="G1438"\w* \w in|strong="G1722"\w* \w whatever|strong="G3739"\w* \w matter|strong="G4229"\w* \w she|strong="G2532"\w* \w may|strong="G2532"\w* \w need|strong="G5535"\w* \w from|strong="G2532"\w* \w you|strong="G5210"\w*; \w for|strong="G1063"\w* \w indeed|strong="G2532"\w* \w she|strong="G2532"\w* \w herself|strong="G1438"\w* \w has|strong="G2962"\w* \w been|strong="G1096"\w* \w a|strong="G1096"\w* \w helper|strong="G4368"\w* \w of|strong="G2532"\w* \w many|strong="G4183"\w*, \w including|strong="G4368"\w* \w my|strong="G1722"\w* \w own|strong="G1438"\w* self.   
\s1 Greetings  
\p
\v 3 Greet \w Prisca|strong="G4251"\w* \w and|strong="G2532"\w* Aquila, \w my|strong="G1722"\w* \w fellow|strong="G4904"\w* \w workers|strong="G4904"\w* \w in|strong="G1722"\w* \w Christ|strong="G5547"\w* \w Jesus|strong="G2424"\w*,  
\v 4 \w who|strong="G3739"\w* \w risked|strong="G5294"\w* \w their|strong="G1438"\w* \w own|strong="G1438"\w* \w necks|strong="G5137"\w* \w for|strong="G5228"\w* \w my|strong="G3956"\w* \w life|strong="G5590"\w*;\f + \fr 16:4 \ft So far as I know, we do not have a record of just how, when or where this happened.\f* \w to|strong="G2532"\w* \w whom|strong="G3739"\w* \w not|strong="G3756"\w* \w only|strong="G3441"\w* \w I|strong="G1473"\w* \w give|strong="G2168"\w* \w thanks|strong="G2168"\w*, \w but|strong="G2532"\w* \w also|strong="G2532"\w* \w all|strong="G3956"\w* \w the|strong="G2532"\w* congregations \w of|strong="G2532"\w* \w the|strong="G2532"\w* \w Gentiles|strong="G1484"\w*.  
\v 5 \w And|strong="G2532"\w* greet \w the|strong="G2532"\w* \w congregation|strong="G1577"\w* \w that|strong="G3739"\w* \w is|strong="G1510"\w* \w in|strong="G1519"\w* \w their|strong="G2532"\w* \w house|strong="G3624"\w*.\f + \fr 16:5 \ft In the beginning, congregations met in people's homes. This avoids the expense of erecting buildings. I believe the days are upon us when all serious followers of Jesus Christ will be increasingly persecuted, including in North America and Europe. An underground Church will have little use for ‘buildings’.\f*  
\p Greet \w my|strong="G1473"\w* beloved \w Epaenetus|strong="G1866"\w*, \w who|strong="G3739"\w* \w is|strong="G1510"\w* \w the|strong="G2532"\w* \w first|strong="G3588"\w* convert \w to|strong="G1519"\w* \w Christ|strong="G5547"\w* \w from|strong="G2532"\w* Achaia.\f + \fr 16:5 \ft 4% of the Greek manuscripts read “Asia” instead of “Achaia” (these are very different places), to be followed by NIV, NASB, TEV, LB, etc.—an inferior proceeding.\f*  
\v 6 Greet \w Mary|strong="G3137"\w*, \w who|strong="G3748"\w* \w worked|strong="G2872"\w* \w very|strong="G4183"\w* \w hard|strong="G4183"\w* \w for|strong="G1519"\w* \w you|strong="G5210"\w*.\f + \fr 16:6 \ft Although scarcely a fourth of the Greek manuscripts read “you” (instead of “us”), that fourth includes the best line of transmission.\f*  
\v 7 Greet Andronicus \w and|strong="G2532"\w* \w Junias|strong="G2458"\w*, \w my|strong="G1722"\w* countrymen \w and|strong="G2532"\w* \w my|strong="G1722"\w* \w fellow|strong="G4869"\w* \w prisoners|strong="G4869"\w*, \w who|strong="G3739"\w* \w are|strong="G1510"\w* \w outstanding|strong="G1978"\w* \w among|strong="G1722"\w* \w the|strong="G1722"\w* apostles, \w and|strong="G2532"\w* \w who|strong="G3739"\w* \w were|strong="G1510"\w* \w in|strong="G1722"\w* \w Christ|strong="G5547"\w* \w before|strong="G4253"\w* \w me|strong="G1473"\w*.  
\v 8 Greet Amplias, \w my|strong="G1722"\w* beloved \w in|strong="G1722"\w* \w the|strong="G1722"\w* \w Lord|strong="G2962"\w*.  
\v 9 Greet \w Urbanus|strong="G3773"\w*, \w our|strong="G2532"\w* \w fellow|strong="G4904"\w* \w worker|strong="G4904"\w* \w in|strong="G1722"\w* \w Christ|strong="G5547"\w*, \w and|strong="G2532"\w* \w my|strong="G1722"\w* beloved \w Stachys|strong="G4720"\w*.  
\v 10 Greet Apelles, \w approved|strong="G1384"\w* \w in|strong="G1722"\w* \w Christ|strong="G5547"\w*. Greet \w those|strong="G3588"\w* \w who|strong="G3588"\w* \w are|strong="G3588"\w* \w of|strong="G1537"\w* \w the|strong="G1722"\w* household \w of|strong="G1537"\w* Aristobulus.  
\v 11 Greet Herodian, \w my|strong="G1722"\w* countryman. Greet \w those|strong="G3588"\w* \w who|strong="G3588"\w* \w are|strong="G1510"\w* \w of|strong="G1537"\w* \w the|strong="G1722"\w* household \w of|strong="G1537"\w* \w Narcissus|strong="G3488"\w*, \w who|strong="G3588"\w* \w are|strong="G1510"\w* \w in|strong="G1722"\w* \w the|strong="G1722"\w* \w Lord|strong="G2962"\w*.  
\v 12 Greet \w Tryphena|strong="G5170"\w* \w and|strong="G2532"\w* \w Tryphosa|strong="G5173"\w*, \w who|strong="G3588"\w* \w have|strong="G2532"\w* \w worked|strong="G2872"\w* \w hard|strong="G4183"\w* \w in|strong="G1722"\w* \w the|strong="G1722"\w* \w Lord|strong="G2962"\w*. Greet \w the|strong="G1722"\w* beloved \w Persis|strong="G4069"\w*, \w who|strong="G3588"\w* \w has|strong="G2962"\w* \w worked|strong="G2872"\w* \w very|strong="G4183"\w* \w hard|strong="G4183"\w* \w in|strong="G1722"\w* \w the|strong="G1722"\w* \w Lord|strong="G2962"\w*.\f + \fr 16:12 \ft The three in this verse are women.\f*  
\v 13 Greet \w Rufus|strong="G4504"\w*, \w chosen|strong="G1588"\w* \w in|strong="G1722"\w* \w the|strong="G1722"\w* \w Lord|strong="G2962"\w*, \w also|strong="G2532"\w* \w his|strong="G1722"\w* \w mother|strong="G3384"\w*, \w and|strong="G2532"\w* \w mine|strong="G1473"\w*.\f + \fr 16:13 \ft If Rufus were his physical brother, presumably Paul would have expressed himself differently, so the ‘mother’ here is not literally Paul's.\f*  
\v 14 Greet Asyncritus, \w Phlegon|strong="G5393"\w*, \w Hermas|strong="G2057"\w*, \w Patrobas|strong="G3969"\w*, \w Hermes|strong="G2060"\w*, \w and|strong="G2532"\w* \w the|strong="G2532"\w* brothers \w who|strong="G3588"\w* \w are|strong="G3588"\w* \w with|strong="G4862"\w* \w them|strong="G3588"\w*.  
\v 15 Greet \w Philologus|strong="G5378"\w* \w and|strong="G2532"\w* \w Julia|strong="G2456"\w*, \w Nereus|strong="G3517"\w* \w and|strong="G2532"\w* \w his|strong="G3956"\w* sister, \w also|strong="G2532"\w* Olympus \w and|strong="G2532"\w* \w all|strong="G3956"\w* \w the|strong="G2532"\w* saints \w who|strong="G3588"\w* \w are|strong="G3588"\w* \w with|strong="G4862"\w* \w them|strong="G3588"\w*.\f + \fr 16:15 \ft Since Paul had never been to Rome, so far, I wonder how he knew so many believers who were there (he knew them well enough to give details about them). I suppose most of them had migrated there from places Paul had been, and he would have to know about that migration.\f*  
\v 16 Greet \w one|strong="G3956"\w* \w another|strong="G3588"\w* \w with|strong="G1722"\w* \w a|strong="G1722"\w* holy \w kiss|strong="G5370"\w*. \w The|strong="G1722"\w* congregations \w of|strong="G1577"\w* \w Christ|strong="G5547"\w* greet \w you|strong="G5210"\w*.   
\s1 Warning  
\p
\v 17 \w Now|strong="G1161"\w* \w I|strong="G3739"\w* \w exhort|strong="G3870"\w* \w you|strong="G5210"\w*, brothers, \w to|strong="G2532"\w* \w watch|strong="G4648"\w* \w out|strong="G2532"\w* \w for|strong="G1161"\w* \w those|strong="G3588"\w* \w who|strong="G3739"\w* \w cause|strong="G4160"\w* \w divisions|strong="G1370"\w* \w and|strong="G2532"\w* offenses, \w contrary|strong="G3844"\w* \w to|strong="G2532"\w* \w the|strong="G2532"\w* \w doctrine|strong="G1322"\w* \w you|strong="G5210"\w* \w have|strong="G2532"\w* \w learned|strong="G3129"\w*, \w and|strong="G2532"\w* \w avoid|strong="G1578"\w* \w them|strong="G3588"\w*.  
\v 18 \w Because|strong="G1223"\w* \w such|strong="G5108"\w* \w people|strong="G3588"\w* \w do|strong="G2532"\w* \w not|strong="G3756"\w* \w serve|strong="G1398"\w* \w our|strong="G2532"\w* \w Lord|strong="G2962"\w* \w Jesus|strong="G2532"\w*\f + \fr 16:18 \ft Some 13% of the Greek manuscripts omit “Jesus”, as in NIV, NASB, LB, TEV, etc.\f* \w Christ|strong="G5547"\w*, \w but|strong="G2532"\w* \w their|strong="G1438"\w* \w own|strong="G1438"\w* \w belly|strong="G2836"\w*, \w and|strong="G2532"\w* \w by|strong="G1223"\w* \w smooth|strong="G5542"\w* talk \w and|strong="G2532"\w* \w flattery|strong="G2129"\w* \w they|strong="G2532"\w* \w deceive|strong="G1818"\w* \w the|strong="G2532"\w* \w hearts|strong="G2588"\w* \w of|strong="G1223"\w* \w the|strong="G2532"\w* unsuspecting.\f + \fr 16:18 \ft Guileless people are often not prepared to recognize guile in others. So those who are responsible for the spiritual welfare of the flock need to warn the people about who should be avoided.\f*  
\v 19 \w I|strong="G1161"\w* \w rejoice|strong="G5463"\w* \w over|strong="G1909"\w* \w you|strong="G5210"\w* \w because|strong="G1063"\w* \w your|strong="G3956"\w* \w obedience|strong="G5218"\w* \w has|strong="G1510"\w* \w become|strong="G1510"\w* known \w to|strong="G1519"\w* \w all|strong="G3956"\w*, \w but|strong="G1161"\w* \w I|strong="G1161"\w* \w want|strong="G2309"\w* \w you|strong="G5210"\w* \w to|strong="G1519"\w* \w be|strong="G1510"\w* \w wise|strong="G4680"\w* \w as|strong="G1519"\w* \w to|strong="G1519"\w* \w what|strong="G3588"\w* \w is|strong="G1510"\w* \w good|strong="G3956"\w*, \w yet|strong="G1161"\w* innocent \w as|strong="G1519"\w* \w to|strong="G1519"\w* \w what|strong="G3588"\w* \w is|strong="G1510"\w* \w evil|strong="G2556"\w*.\f + \fr 16:19 \ft When the first pair ate of the forbidden tree, this was not the result.\f*  
\v 20 \w The|strong="G1722"\w* \w God|strong="G2316"\w* \w of|strong="G5259"\w* \w peace|strong="G1515"\w* \w will|strong="G2316"\w* \w quickly|strong="G5034"\w* \w crush|strong="G4937"\w* \w Satan|strong="G4567"\w* \w under|strong="G5259"\w* \w your|strong="G2962"\w* \w feet|strong="G4228"\w*!\f + \fr 16:20 \ft The sooner, the better!\f*  
\s1 Sign-off  
\p \w The|strong="G1722"\w* \w grace|strong="G5485"\w* \w of|strong="G5259"\w* \w our|strong="G2316"\w* \w Lord|strong="G2962"\w* \w Jesus|strong="G2424"\w* \w Christ|strong="G5547"\w*\f + \fr 16:20 \ft 1% of the Greek manuscripts (of objectively inferior quality) omit “Christ”, to be followed by NIV and NASB—an inferior proceeding.\f* \w be|strong="G2316"\w* \w with|strong="G3326"\w* \w you|strong="G5210"\w*.  
\v 21 \w Timothy|strong="G5095"\w*, \w my|strong="G1473"\w* \w fellow|strong="G4904"\w* \w worker|strong="G4904"\w*, greets \w you|strong="G5210"\w*, \w as|strong="G2532"\w* \w do|strong="G2532"\w* \w Lucius|strong="G3066"\w*, \w Jason|strong="G2394"\w* \w and|strong="G2532"\w* \w Sosipater|strong="G4989"\w*, \w my|strong="G1473"\w* countrymen.   
\p
\v 22 \w I|strong="G1473"\w*, \w Tertius|strong="G5060"\w*, \w who|strong="G3588"\w* penned \w this|strong="G3588"\w* \w letter|strong="G1992"\w* \w in|strong="G1722"\w* \w the|strong="G1722"\w* \w Lord|strong="G2962"\w*, greet \w you|strong="G5210"\w*.  
\v 23 \w Gaius|strong="G1050"\w*, \w host|strong="G3581"\w* \w to|strong="G2532"\w* \w me|strong="G1473"\w* \w and|strong="G2532"\w* \w the|strong="G2532"\w* \w whole|strong="G3650"\w* \w congregation|strong="G1577"\w*, greets \w you|strong="G5210"\w*. \w Erastus|strong="G2037"\w*, \w the|strong="G2532"\w* \w city|strong="G4172"\w* \w treasurer|strong="G3623"\w*, greets \w you|strong="G5210"\w*, \w as|strong="G2532"\w* does brother \w Quartus|strong="G2890"\w*.\f + \fr 16:23 \ft One gains the clear impression that the people mentioned in verse 23 knew that Tertius was penning this letter. Not only that, they asked to be included! I wonder who Quartus may have been.\f*   
\p
\v 24 \w The|strong="G3956"\w* \w grace|strong="G5485"\w* \w of|strong="G5485"\w* \w our|strong="G2424"\w* \w Lord|strong="G2962"\w* \w Jesus|strong="G2424"\w* \w Christ|strong="G5547"\w* \w be|strong="G3956"\w* \w with|strong="G3326"\w* us\f + \fr 16:24 \ft I have followed perhaps 20% of the Greek manuscripts, including the best line of transmission, in putting ‘us’ rather than the familiar ‘you’. If verses 22-24 were not dictated by Paul, then the first person is especially appropriate, coming from Tertius.\f* \w all|strong="G3956"\w*! Amen.\f + \fr 16:24 \ft 3.2% of the Greek manuscripts omit verse 24, while 7.2% supply 14:24-26 at this point.\f*   