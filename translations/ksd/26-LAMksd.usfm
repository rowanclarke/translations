\id LAM Niligur Lamentations 1 Tinata Tuna - PNG, WWH, 08/98 
\h Niligur 
\toc1 A Umana Kakailai Na Niligur 
\toc2 Niligur 
\toc3 Niligur 
\mt1 A UMANA KAKAILAI NA NILIGUR  
\c 1  
\s1 A umana mangana niligur kai ra tarai Sion ba dia ki na vilavilau  
\q1
\v 1 Ua, ra pia na pal nina i ga kor ma ra tarai i ki na lingling ika!  
\q1 Ua, i da ra ua na vavina, nina i ga ngala pire ra lavur vuna tarai!  
\q1 Ua, nina i ga tadar na vavina ta ra umana papapar i tar ki na vilavilau!   
\q1
\v 2 I tangtangi tuna ra marum, ma ra lur na matana i varababakai ta ra pagupagu na ngiene;  
\q1 Ta diat par dia lalaure pa ta na i vamaram ia;  
\q1 A umana talaina par dia tar vagu pa ia, dia tar ki na vargegelenai me.   
\q1
\v 3 Iuda i tar mareng, tago i ki na malari, ma tago ra papalum i tup ia;  
\q1 I ki livuan ta ra umana Tematana, ma pa i tikan tadav ra ningo;  
\q1 Diat par dia korot mur ia dia tar korot tadav ia ba i ki na malari.   
\q1
\v 4 A umana nga Sion dia ki na niligur, tago pa ta na mulai i vana ta ra ngala na lukara;  
\q1 Kana lavur mataniolo dia kapakapana ka, kana umana tena tinabar dia riri;  
\q1 Kana umana inip na vavina a umana biaui, ma ia iat i ki ma ra niligur.   
\q1
\v 5 Diat dia ki na vargegelenai me dia tar ki na lua, kana umana ebar dia tamtavua;  
\q1 Tago ra Luluai i tar vakadik ia ure kana peal varpiam;  
\q1 Kana umana bul ikilik dia tar vana ta ra kini na vilavilau ta ra luaina mata i ra ebar.   
\q1
\v 6 Ma ra minamar par i tar panie kan natu i Sion;  
\q1 Kana umana luluai dia varogop ma ra umana me ba pa dia tikan tadav ta pia na vura,  
\q1 Ma dia tar lop kan nina i korot mur diat, tago pa ta ongor i diat.   
\q1
\v 7 Ta ra e i ki na kinadik tana, ma ta ra e i malari tana,  
\q1 Ierusalem i nuk pa kana lavur vakak na tabarikik, nina i ga vatur vake papa ania iat;  
\q1 Ba kana tarai dia virua ta ra lima i ra ebar, pa ta na i maravut ia;  
\q1 Diat dia ki na vargegelenai me dia ga gire, ma dia ga varkulumai ure kana binilua.   
\q1
\v 8 Ierusalem i tar varpiam tuna, kari i da ra magit i kerek;  
\q1 Diat par dia ga ru ia go dia pidimuane, tago dia tar gire ra pakana tuna;  
\q1 Maia, i oir, ma i tur tapuku.   
\q1
\v 9 Kana mal i keo; pa i ga nuk pa ra mutuaina;  
\q1 Kari i tar bura vakaian; pa ta na i vamaram ia;  
\q1 Luluai, una bobe ra magit i tup iau; tago ra ebar i tar vangala pa mule.   
\q1
\v 10 Nina dir ki na vargegelenai me i tar tulue ra limana upi kana lavur vakak na magit;  
\q1 Tago i tar gire ba ra umana Tematana dia tar ruk ta kana pal i gomgom,  
\q1 Nina u ga vartuluai tana ba koko diat a ruk ta kaum kivung.   
\q1
\v 11 Kana tarai par dia oir, dia nuk upi ra nian;  
\q1 Dia tar kia kadia lavur vakak na magit upi ra magit na nian, upi ra bala i diat na lagar tana;  
\q1 Luluai, una gire, ma una bobe, tago iau tar ki kaina.   
\q1
\v 12 Avat par ba ava vana pakit, pa ava mari iau vang?  
\q1 Ea, avat a gire upi ta niligur ba dir varogop ma kaugu niligur, nina di pait ia tagu,  
\q1 Nina ra Luluai i tar vatakunuan ra balagu me ta ra bung i ngangal na kulot tana.   
\q1
\v 13 Marama liu i tar tulue ra iap ta ra umana urugu, ma i tar ongor pa diat;  
\q1 I tar vatur ra ubene ure ra kaugu, i tar tulue vatalil iau;  
\q1 I tar li iau, ma iau bilua ra bungbung parika.   
\q1
\v 14 Ra limana i tar vi tar ra kip i vuna ta kaugu lavur varpiam;  
\q1 Di tar vi guve diat, dia tar ki taun ra inoagu; i tar vapanie ra dekdekigu;  
\q1 A Luluai i tar tul tar iau ta ra lima i diat ba pa i tale iau pi ina tur bat diat.   
\q1
\v 15 A Luluai i tar pidimuane kaugu lavur lebe piragu;  
\q1 I tar vatut ra ngala na kor ure iau upi na ubu vue kaugu umana barmana;  
\q1 A Luluai i tar rua ra inip na vavina Iuda da ta ra tung na vain.   
\q1
\v 16 Ure go ra lavur magit iau tangtangi, ma ra matagu i lur;  
\q1 Tago ra tena varmaram ba na valagar ra balagu i tar ki vailik kan iau;  
\q1 A umana natugu dia tar lingling ika, tago ra ebar i tar ongor.   
\b  
\q1
\v 17 Sion i tultulue ra limana; pa ta na akari ba na vamaram ia;  
\q1 A Luluai i tar vartuluai ure Iakob ba diat dia ki kikil ia diat a vargegelenai me;  
\q1 Ierusalem i da ra magit i kerek pire diat.   
\q1
\v 18 A Luluai i tar takodo; tago iau tar piam vue kana vartuluai;  
\q1 Ea, avat ra lavur vuna tarai par, avat a valongore, ma avat a gire kaugu niligur;  
\q1 Kaugu lavur inip na vavina ma kaugu lavur barmana dia tar vana ta ra kini na vilavilau.   
\q1
\v 19 Iau ga oro upi ra umana talaigu, ma dia ga tuam pa iau;  
\q1 Kaugu umana tena tinabar ma kaugu umana patuana dia tar mat ta ra pia na pal,  
\q1 Ba dia ga tikan upi ra magit na nian upi diat a valagar ra bala i diat me.   
\q1
\v 20 Ea Luluai, una gire; iau tar ki na malari; ra balagu i purpuruan;  
\q1 I tapuku ra balagu, tago iau tar varpiam tuna;  
\q1 Aro irai a pakat na vinarubu i varvaligur, ma ati ra pia na pal a minat.   
\q1
\v 21 Di tar valongore kaugu niriri; pa ta na ati ba na vamaram iau;  
\q1 Kaugu lavur ebar par dia tar valongore ra varvai ure kaugu kini na purpuruan; dia gugu, tago u tar pait ia;  
\q1 Ta kaum vartuluai na ga vut boko ra bung u ga vatang ia, ma diat a vardada ma iau.   
\q1
\v 22 Boina ba kadia lavur varpiam diat a tur rikai ta ra luaina matam;  
\q1 Ma una babali pire diat, da u ga bali kaugu lavur varpiam piragu;  
\q1 Tago mangoro kaugu niriri, ma ra balagu i tar bilua.   
\c 2  
\s1 A umana mangana niligur kai ra tarai Sion dia vana rikai tai ra Luluai  
\q1
\v 1 Ua, ra Luluai i tar turup natu i Sion ma ra bakut i ta ta kana kankan!  
\q1 I tar rapue ra minamar i Israel marama ra bala na bakut ura ra pia,  
\q1 Ma pa i ga nuk pa ra ruarua na kauna ta ra bung i kankan tana.   
\q1
\v 2 Ra Luluai i tar konom vue ra lavur kuba i Iakob par, ma pa i ga varmari;  
\q1 Ta kana kulot i tar rapue ra umana dekdek na pia na pal kai natu i Iuda;  
\q1 I tar vue tar diat ra pia iat; i tar vakaina ra kiki na varkurai ma ra umana luluai tana.   
\q1
\v 3 Ta kana nginangal na kulot i tar kutu vue ra ram u Israel par;  
\q1 I tar tak vue ra limana tuna ta ra luaina mata i ra ebar;  
\q1 Ma i tar vaimur Iakob da ra biro na iap nina i vaimur ra magit kikil ia.   
\q1
\v 4 I tar lale kana panak da ra ebar, i tar tur ta ra papar a lima tuna da ra tena tur varbat,  
\q1 Ma i tar ubu doko diat par dia vakak ta ra mata i diat ta ra kuba i natu i Sion.  
\q1 I tar lolonge kana karangap na kankan da ra iap.   
\q1
\v 5 A Luluai i tar varogop ma ra ebar, i tar vamutue Israel;  
\q1 I tar vamutue kana lavur pal na luluai; i tar nila vue kana lavur dekdek na pia na pal;  
\q1 Ma i tar vangala ra tabunuk ma ra tinangi ta ra natu i Iuda.   
\q1
\v 6 I tar re vakaina vue ra kubana da ra pal na uma, ma i tar li vue kana pal na kivung;  
\q1 A Luluai i tar kure ba da valubane ra ngala na kivung ma ra Bung Sabat ta ra gunan Sion.  
\q1 Ma ta kana ngala na kulot i tar pidimuane ra king ma ra tena tinabar.   
\q1
\v 7 A Luluai i tar vung vue kana uguugu na vartabar, i tar milikuane kana pal i gomgom,  
\q1 I tar nur tar ra umana kakamir ta kana lavur pal na luluai ta ra lima i ra ebar;  
\q1 Dia tar urung ta ra kuba i ra Luluai da ta ra bung i ra ngala na kivung.   
\q1
\v 8 A Luluai i tar kure ba na re vue ra liplip kikil natu i Sion;  
\q1 I tar vung tar ra vinau na valavalar, pa i tak vue ra limana kan ra nila;  
\q1 I tar vabilua ra bobokon ma ra liplip; dir par dir tarip.   
\q1
\v 9 Kana umana banbanu dia tar tapunang ra pia; i tar re vue kana lavur kinalat, ma i tar bubur diat;  
\q1 Kana king ma kana umana luluai dia ki livuan ta ra umana Tematana; pa ta vartovo na varkurai mulai;  
\q1 Kana umana propet bula pa dia vatur vake ta ninana tai ra Luluai.   
\q1
\v 10 A umana patuana kai natu i Sion dia ki ra pia ka, dia ki mut uka;  
\q1 Dia tar imire ra tobon ta ra ulu i diat, dia vi pit ma ra mal na tabun;  
\q1 A umana inip na vavina Ierusalem dia ula tadoko.   
\q1
\v 11 A matagu i tar gavul ma ra tinangi, a balagu i purpuruan;  
\q1 A katigu i tar bura ra pia ure ra vinirua i tadav kaugu tarai;  
\q1 Tago ra umana bul ikilik ma ra umana kuramana dia matmat ika ta ra lavur nga na pia na pal.   
\q1
\v 12 Dia tir ra umana na i diat dari: Akave ta kon ma ta vain?  
\q1 Ba i talili ra mata i diat da ra mata i ra tarai dia kinkin ta ra lavur nga na pia na pal,  
\q1 Ba dia vung vue ra tulungea i diat ta ra bongbongo i ra umana na i diat.   
\q1
\v 13 Ava ra magit ina ve tar ia tam? Ava ra magit ina valarue amur me, u natu i  
\q1 Ierusalem?  
\q1 Ava ra magit ina valar tar ia tam upi ina vamaram u me, natu i Sion, a inip na vavina?  
\q1 Tago kaum kinkin i ngala da ra ta; to ia na valagar u?   
\q1
\v 14 Kaum umana propet dia tar gire ra umana ninana ure u, a umana ninana vakuku ma ra umana ninana na papaua;  
\q1 Ma pa dia vaarike kaum varpiam upi da vatalil u kan ra kini na vilavilau;  
\q1 Dia gire ke ra magit vakuku ure u, ma ra magit i vuna ta kaum kini na vilavilau.   
\q1
\v 15 Diat par dia vana pakit dia papar tam;  
\q1 Dia ititinga, ma dia loe ra ulu i diat ta ra natu i Ierusalem, ma dia biti dari:  
\q1 Dave, go di vatang ia vang ba, Ra minamar kakit, Ra pia na pal ba ra rakarakan a gunagunan i gugu tana?   
\q1
\v 16 Kaum lavur ebar par dia panganga ure u;  
\q1 Dia ititinga, ma dia vangvangia ra pal a ngie i diat; dia biti dari: Ave tar konom vapar ia;  
\q1 A dovotina ave ga nuk upi go ra bung; ave tar laun tadav ia, ave tar gire.   
\b  
\q1
\v 17 A Luluai i tar pait ra magit i ga nuk upi ia; i tar pait ot pa kana tinata;  
\q1 Da i ga vartuluai amana tana, i tar rapue ma pa i ga varmari;  
\q1 Ma i tar tul tar ra ebar upi na gugu ma u, i tar vangala ra ram u diat ava vargegelenai ma diat.   
\q1
\v 18 A bala i diat i ga tangi tadav ra Luluai;  
\q1 U a liplip kikil natu i Sion, boina ba ra lur na matam na varababakai ra keake ma ra marum da ra tava alir;  
\q1 Koko una talanguan; koko ra kiau na matam na ngo.   
\b  
\q1
\v 19 Una tut, una kukula ra marum ta ra lavur varkia na monamono;  
\q1 Una lolonge vaarike ra nuknukim da ra tava ta ra luaina mata i ra Luluai.  
\q1 Una tulue ra limam tadav ia upi na valaun kaum umana bul ikilik,  
\q1 Nina dia matmat ta ra lavur ngu na nga par.   
\b  
\q1
\v 20 Ea Luluai, una gire; ia nam u ga pait ra dari pirana?  
\q1 Dave, ra vaden diat a en ra vuai ra paka i diat, ra umana bul ba dia tal diat?  
\q1 Dave, da ubu doko ra tena tinabar ma ra propet ta ra pal i gomgom kai ra Luluai?   
\q1
\v 21 A barmana ma ra kua dir va ra pia ta ra umana nga;  
\q1 Kaugu umana inip na vavina ma kaugu umana barmana dia tar virua ta ra pakat na vinarubu;  
\q1 U ga ubu diat ta ra bung u kulot i tana; u ga vardodoko, ma vakir u ga varmari.   
\q1
\v 22 Da ta ra bung i ra ngala na kivung, u ga oro upi ra lavur magit iau dadadar tana ta ra lavur papar.  
\q1 Ma pa ta na i ga pila, ma pa ta na i ki valili ta ra bung ra Luluai i kulot i tana;  
\q1 Diat iau ga rite diat, ma iau ga vangala diat, kaugu ebar i tar vapanie diat.   
\c 3  
\s1 A varmari kai God na valaun pa diat  
\q1
\v 1 Iau ra tutana ba i tar kairane ra kinadik ta ra vivirit kai kana kankan.   
\q1
\v 2 I tar agur pa iau, ma i tar ben pa iau upi ina vana ta ra bobotoi, ma vakir ta ra kapa.   
\q1
\v 3 A dovotina i tar tur bat vatikene iau ra bungbung parika.   
\q1
\v 4 I tar vabibian ra vio na pakagu ma ra pal a pakagu; i tar bubur ra umana urugu.   
\q1
\v 5 I tar papait bat iau, ma i tar vaki ra magit i mapak tuna kikil iau, ma ra kinadik i tup iau.   
\q1
\v 6 I tar vaki iau ta ra umana gunan na bobotoi, da diat dia tar mat amana tana.   
\q1
\v 7 I tar liplip bat iau upi koko ina irop; i tar vamamat ra agu vinau na palariam.   
\q1
\v 8 Maia, ba iau oro ma iau kail upi na maramaravut iau, i banu bat vue kaugu niaring.   
\q1
\v 9 I tar pore kaugu nga ma ra vat di ga mut ia, i tar vagene kaugu lavur nga.   
\q1
\v 10 I da ra bear\f + \fr 3:10 \ft A bear, tika na mangana leing, a tena varkarat, ma i ngala ra dekdekina.\f* piragu ba i kiki uai, da ra leon ta ra lokor.   
\q1
\v 11 I tar varara iau na nga, ma i tar kadal iau; i tar valingling iau.   
\q1
\v 12 I tar lale kana panak, ma i valabat upi iau ma ra pu.   
\q1
\v 13 I tar go ra balagu ma ra umana pu ta kana popopoi.   
\q1
\v 14 Iau ra magit na varkulumai pire kaugu tarai par; ma dia varvaula ure iau ra bungbung par.   
\q1
\v 15 I tar vabuka iau ma ra magit i mapak, i tar tabar vamaur iau ma ra kini na malari.   
\q1
\v 16 I tar bubur ra pal a ngiegu ma ra raga, i tar tuba iau ma ra kabu na iap.   
\q1
\v 17 Ma u tar kari vavailik vue ra balagu kan ra malmal; iau ga valubane ra bo na kini.   
\q1
\v 18 Ma iau ga biti: A dekdekigu i tar panie, ma pa iau nuk upi mule ta magit tai ra Luluai.   
\b  
\q1
\v 19 Una nuk pa kaugu kinadik ma kaugu kini na malari, ra magit i mapak ma ra tava i mapak.   
\q1
\v 20 A balagu pa i valubane dir boko, ma i ki na niligur.   
\q1
\v 21 Iau nuk pa go, kari iau papait na nurnur.   
\q1
\v 22 A varmari kai ra Luluai i vuna tago pa da tar imur, tago kana varmar i tur tukum.   
\q1
\v 23 I kalamana vatikai ta ra bungbung na malana; ma u dovot tuna.   
\q1
\v 24 A tulungeagu i biti: A Luluai kaugu tiniba, kari ina nurnur tana.   
\q1
\v 25 A Luluai i mari diat dia nurnur tana, i mari nina i tikatikan upi ia.   
\q1
\v 26 I topa ia ba ra tutana na ki nunur ma na ki vovovon upi ra valavalaun kai ra Luluai.   
\q1
\v 27 I topa ra tutana ba na. puak pa ra kip ba i barmana boko.   
\q1
\v 28 Boina ba na ki varkolono ma na ki mut uka, tago i tar vung tar ia.   
\q1
\v 29 Boina ba na vung ra ngiene ta ra tobon; ona damana kan na boina mulai.   
\q1
\v 30 Boina ba na pukue tar ra pagupagu na ngiene ta nina i par ia; boina ba na tup ia ra varvul pirana.   
\q1
\v 31 Tago ra Luluai pa na varvarokoloi pa na mutu.   
\q1
\v 32 Tago ba i varvatakunuan, namur i varmari mulai varogop ma kana ngala na varmari.   
\q1
\v 33 Tago vakir i gugu pi na vakadik ra tarai, ba upi na vatakunuan ra bala i diat.   
\b  
\q1
\v 34 Ba di rua bereng ra umana vilavilau ta ra rakarakan a gunagunan,   
\q1
\v 35 Ba di kure varara ra takodo na magit kai ta tikai ta ra luaina mata i ra Ngala Kakit,   
\q1
\v 36 Ba di pukue varara ra varkurai ure tika na tutana, ra Luluai pa i manane nam.   
\q1
\v 37 To ia i tatike ra tinata ba da pait ot pa ia, ona ra Luluai pa i vartuluai tana?   
\q1
\v 38 Dave, ra boina ma ra kaina pa i vana rikai ta ra ngie i ra Ngala Kakit vang?   
\q1
\v 39 Ta ra ava ra tutana a launa i tata na urur, ra tutana di bali kana varpiam pirana?   
\q1
\v 40 Boina dat a tikatikan ta kada lavur mangamangana, ma dat a valar ia, ma dat a vana tapuku tadav ra Luluai.   
\q1
\v 41 Boina ba ra nuknuk i dat ma ra lima i dat na araring tadav God arama ra bala na bakut.   
\q1
\v 42 Ave tar varpiam, ma ave tar tut na varpiam; ma pa u ga nuk vue.   
\q1
\v 43 U tar punang taun avet ma ra kankan, ma u tar korot mur avet; u tar vardodoko, ma pa u ga varmari.   
\q1
\v 44 U tar pulu mule u ma ra bakut upi koko kaveve niaring na ruk piram.   
\q1
\v 45 U tar vaki avet da ra magit i kerek, ma da ra puta livuan ta ra umana Tematana.   
\q1
\v 46 Kaveve lavur ebar par dia tar manga panganga tadav avet.   
\q1
\v 47 A bunurut ma ra tung dir tadav avet, a nila ma ra vinirua.   
\q1
\v 48 A lur na matagu i varababakai da ra tava i alir ure ra vinirua i tadav kaugu tarai.   
\q1
\v 49 A matagu i manga lur vatikai, ma pa i ngo pit,   
\q1
\v 50 Tuk tar ta ra bung ra Luluai i gigira ba, ma i bobe marama ra bala na bakut.   
\q1
\v 51 I kadik ra balagu ta ra magit iau gire ba i tadav ra vaden ta kaugu pia na pal.   
\b  
\q1
\v 52 Diat dia ebar vakuku tadav iau dia tar korot vakaina iau da di korot vakaina ra beo.   
\q1
\v 53 Dia tar vamutue kaugu nilaun ta ra pal na banubat, dia tar tupar iau ma ra vat.   
\q1
\v 54 A ulugu i dudu ta ra lubu; iau ga biti dari: Iau tar virua.   
\q1
\v 55 Iau ga kail upi ra iangim, Luluai, mara iat ra tung.   
\q1
\v 56 U tar valongore ra nilaigu; koko una ang bat ra talingam ba iau kakail upi ra maramaravut.   
\q1
\v 57 U ga kakari maravai ta ra bung iau ga kail u; u ga biti: Koko u burut.   
\q1
\v 58 Luluai, u ga varkurai maravut iau; u ga valaun iau.   
\q1
\v 59 Luluai, u tar gire ra kaina magit di pait ia tagu; una varkurai ure iau.   
\q1
\v 60 U tar gire kadia varobo par ma kadia lavur varpit upi iau.   
\q1
\v 61 U tar valongore kadia varvul; Luluai, ma kadia lavur varpit upi iau;   
\q1
\v 62 Ra tinata kadiat dia tut na vinarubu ure iau, ma ra magit di nuk vakuku pa ia ure iau ta ra bung parika.   
\q1
\v 63 Una gire ba dia kiki ma ba dia tut; dia kakailai na varkulumai ure iau.   
\q1
\v 64 Luluai, una babali pire diat varogop ma ra papalum na lima i diat.   
\q1
\v 65 Una valeo ra bala i diat; kaum varvabilak na tadav diat.   
\q1
\v 66 Una korot diat ma ra kankan, ma una ga vamutue diat kan ra vavai ra bala na bakut kai ra Luluai.   
\c 4  
\s1 I tar ot ra balbali pire ra tarai Sion  
\q1
\v 1 Ua, ra goled i tar kubar! Ua, ra goled i tar kaina, nina i ga ngatngat muka!  
\q1 Di tar lolonge guve ra umana vat na pal i gomgom ta ra lavur ngu na nga.   
\q1
\v 2 A umana ngatngat na natu i Sion, diat dia varogop ma ra vakak na goled,  
\q1 Di tar varogopane diat ma ra pal a tava, ra papalum kai ra tena pait la na pia!   
\q1
\v 3 Ea, ra umana kuabar na pap dia tul tar ra u i diat, dia vau ra umana natu i diat;  
\q1 Ma ra umana vaden ta kaugu tarai dia dekdek da ra umana murup ta ra bil.   
\q1
\v 4 A karamea i ra kuramana i ki petep ta ra ul a ngiene, tago i mar;  
\q1 A umana bul ikilik dia lul upi ta nian, ma pa ta na i tabar diat.   
\q1
\v 5 Diat dia ga en ra magit ma ra nangnang dia mulmulum na nga;  
\q1 Diat dia ga mong ma ra mal meme ba dia ga bul dia va ta ra umana ul a puta.   
\q1
\v 6 Tago ra kaina mangamangana ba kaugu tarai dia ga pait ia i ngala ta ra kaina mangamangana kai Sodom,  
\q1 Nina di ga vue pukue vue da ta ra kopono pitu mata, ma pa ta lima i ra tarai i ga bili ia.   
\q1
\v 7 Kana umana luluai dia ga barabara tuna, ma ra tava pata; dia ga pua tuna, ma ra polo na u pa i pua damana;  
\q1 A paka i diat i ga mong ma ra bo na nilaun, ma i ga bagabagele da ra ngatngat na vat;   
\q1
\v 8 Go ra mata i diat i korakorong ma ra teke na mi pata; vakir da nunure diat ta ra lavur nga;  
\q1 A pal a paka i diat i petep ta ra uru i diat; i tar maranga, i tar da ra davai.   
\q1
\v 9 Diat ba ra pakat na vinarubu i ubu diat, dia ti doan ta diat ba dia virua ta ra mulmulum;  
\q1 Tago go diat dia kuvakuvoro, tago dia iba upi ra vuai ra uma.   
\q1
\v 10 A umana vavina, a umana tena varmari, dia tar kabalane ra umana natu i diat;  
\q1 Dia ga da ra adia magit na nian ta ra e ba ra vinirua i ga tadav kaugu tarai.   
\q1
\v 11 A Luluai i tar pait ot pa kana karangap na kankan, i tar lolonge kana nginangal na kulot;  
\q1 Ma i tar vautunge ra iap aro Sion, ma ra iap i tar vaimur ra vunapaina.   
\q1
\v 12 A umana king ta ra rakarakan a gunagunan ma ra tarai par dia ki ra pia pa dia kapupi ia,  
\q1 Ba ra tena vargegelenai ma ra ebar dir a olo ta ra mataniolo Ierusalem.   
\q1
\v 13 Tago kana umana propet dia ga varpiam, ma kana umana tena tinabar dia ga rara,  
\q1 Ma dia ga ubu ra umana tena takodo tana.   
\q1
\v 14 Dia pepere da ra umana pula ta ra lavur nga, a gap i vadur diat.  
\q1 Ma damana i dekdek upi ra tarai diat a bili kadia mal.   
\q1
\v 15 Dia biti ta diat: Avat a vana! A umana dur! Avat a vana! Avat a vana! Koko da varbili!  
\q1 Ba dia vilau ma dia tenten vurvurbit, ra tarai dia biti pire ra umana Tematana: Koko diat a kiki mulai ati.   
\q1
\v 16 A mata i ra Luluai iat i tar korot varbabaiane diat; pa na nuk pa mule diat;  
\q1 Pa di ga ru ra umana tena tinabar, pa di ga mari ra umana patuana.   
\q1
\v 17 A mata i dat i gavul boko ma ra ginigira upi ra tena maramaravut vakuku;  
\q1 Ba da ga makmakila, da ga ki pa ra tarai ba pa i topa diat upi diat a valaun dat.   
\q1
\v 18 Di tikan mur ra pal a kau i dat ma i dekdek ba dat a vana ta kada lavur nga.  
\q1 A mutuai dat i tar maravai, kada kilala i tar ot; tago ra. mutuai dat i tar pot.   
\q1
\v 19 Diat dia korot mur dat dia lulut tuna, ra umana minigulai liu pa dia lulut damana.  
\q1 Dia ga korakorot dat ta ra lualuana, dia ga kiki uai upi dat ta ra pupui.   
\q1
\v 20 A vuvu na bilau i dat, nina ra Luluai i ga tar ku ia, i tar virua ta kadia umana ubu;  
\q1 Nina da ga biti ure dari: Livuan ta ra umana vuna tarai dat a laun ta ra maluruna.   
\b  
\q1
\v 21 Una gugu ma una ga, natu i Edom, u ba u ki ta ra gunan Us;  
\q1 Ra momamomo na tadav u bula; una longlong boko ma ra nimomo, ma una ga pala vue kaum mal.   
\q1
\v 22 Natu i Sion, i tar par ra balbali ure kaum varpiam; pa na kap vavilavilau vue mule u;  
\q1 Natu i Edom, na bali kaum kaina papalum; na vaarike kaum varpiam.   
\c 5  
\s1 A niaring upi ra varmari  
\q1
\v 1 Luluai, una nuk pa ra magit i tar tadav avet;  
\q1 Boina una gire kaveve kini na vavirvir.   
\q1
\v 2 A gunan nina ave ga kale pa ia di tul tar ia ta ra umana vaira,  
\q1 A kubakuba i vevet ta ra umana Tematana.   
\q1
\v 3 A umana nat na ling avet, pa ta tama i vevet,  
\q1 A umana na i vevet dia da ra umana ua na vavina.   
\q1
\v 4 Ave tar kia kaveve mani upi ta tava na nimomo;  
\q1 Di ivure kaveve davai pire vevet.   
\q1
\v 5 Diat dia korot mur avet dia ki taun ra inoa i vevet;  
\q1 Ave tar talanguan, ma pa ave ngo ta ik.   
\q1
\v 6 Ave tar lulul ma ra tarai Aigipto.  
\q1 Ma damana ma ra tarai Asiria, upi avat a en ta magit.   
\q1
\v 7 A umana tama i vevet dia tar varpiam, ma dia tar panie;  
\q1 Ma ave kairane ra balbali ure kadia varpiam.   
\q1
\v 8 A umana tultul uka dia kure avet,  
\q1 Ma pa ta na akari ba na valaun avet kan ra lima i diat.   
\q1
\v 9 Ave varurue ra aveve magit, ma ave to na virua tana,  
\q1 Ure ra pakat na vinarubu arima ra pupui.   
\q1
\v 10 A pal a paka i vevet i avian da ra ubu  
\q1 Ure ra ngala na oao ta ra mulmulum.   
\q1
\v 11 Dia ga vakaina ra vaden Sion,  
\q1 Ma ra umana inip na vavina ta ra lavur pia na pal Iuda.   
\q1
\v 12 Di tar al vatokobe ra umana luluai ta ra lima i diat;  
\q1 Pa di ru ra mata i ra umana patuana.   
\q1
\v 13 A umana barmana dia puapuak ra vat na uduudu;  
\q1 Ma ra umana bul dia burabura ba dia kakave ra davai.   
\q1
\v 14 A umana patuana pa dia ki mulai ta ra mataniolo.  
\q1 Ma ra umana barmana dia tar ngo ta ra malagene.   
\q1
\v 15 A gugu ta ra bala i vevet i tar par;  
\q1 Di tar pukue kaveve malamalagene pi na varogop ma ra tinangi.   
\q1
\v 16 A kere na luluai i tar bura kan ra ulu i vevet;  
\q1 A umana biaui avet! Tago ave tar varpiam.   
\q1
\v 17 Ure go, ra nuknuk i vevet i tar bilua;  
\q1 Ure go ra lavur magit, ra mata i vevet i tar gamgavul;   
\q1
\v 18 Ure ra luana Sion nina i tar lingling;  
\q1 A umana kuabar na pap dia limlibur tana.   
\q1
\v 19 U Luluai, u kiki vatikai,  
\q1 Kaum kiki na king i tur vatikai ta ra lavur taun tarai pa na mutu.   
\q1
\v 20 Ta ra ava u valubane vatikene avet,  
\q1 Ma u ki kan avet mangoro na kilakilala?   
\q1
\v 21 Luluai, una valilikun avet piram, ma avet a lilikun;  
\q1 Una vakalamane kaveve kini da amana.   
\q1
\v 22 Ba kan u tar okole vakakit vue avet,  
\q1 Ma u kankanuane tuna avet bar?   