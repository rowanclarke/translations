\v 22 \w Namah|strong="H0859"\w* loh hlang \w tloe|strong="H0312"\w* na \w tap|strong="H7043"\w* \w te|strong="H0834"\w* \w na|strong="H9905"\w* \w lungbuei|strong="H3820"\w* loh a \w voei|strong="H6471"\w* a \w yet|strong="H7227"\w* \w khaw|strong="H1571"\w* a \w ming|strong="H3045"\w*.   
