\id ECC
\h أَمْبَارّحْ 
\toc1 أَمْبَارّحْ 
\toc2 أَمْبَارّحْ 
\toc3 أَمب. 
\mt1 أَمْبَارّحْ  
\c 1
\s1 أَقَا كُوڒْشِي ذِي ڒْبَاطڒْ  
\m
\v 1 أَوَاڒنْ ن ؤُمْبَارّحْ، مِّيسْ ن ذَاوُوذْ، أَجدْجِيذْ ذِي ؤُرْشَالِيمْ.   
\b  
\m
\v 2 ذ إِبطَّاڒنْ قَاعْ، إِقَّارْ ؤُمْبَارّحْ، ذ إِبطَّاڒنْ قَاعْ، أَقَا كُوڒْشِي ذِي ڒْبَاطڒْ. \x ◘ \xo 1:‏2 \xt إِزهد. 62‏:‏10؛ 144‏:‏4\x*  
\v 3 مَانْ ڒفْضڒْ إِ إِدْجَانْ غَارْ بْنَاذمْ ذِي مَارَّا أَرْبرْ إِ زِي إِتّْمَارّثْ سَاذُو ثْفُوشْثْ؟ \x ◘ \xo 1:‏3 \xt أَمب. 2‏:‏22؛ 3‏:‏9\x*  
\v 4 جِّيڒْ  إِڭُّورْ، إِجّْ ن جِّيڒْ \add نّغْنِي\add* إِتَّاسْ-د، \add مَاشَا\add* ثَامُّورْثْ أَذْ ثقِّيمْ ثْبدّْ إِ ڒبْذَا. \x ◘ \xo 1:‏4 \xt إِزهد. 104‏:‏5\x*  
\v 5 ثْنقَّارْ-د ثْفُوشْثْ ؤُ ثْغدْجِي ثْفُوشْثْ \add عَاوذْ\add*، \add خنِّي\add* أَذْ د-ثذْوڒْ ذغْيَا غَارْ مَانِيسْ إِ د-ثْنقَّارْ.  
\v 6 إِڭُّورْ \add ؤُسمِّيضْ\add* غَارْ لْجَانُوبْ ؤُ إِتّنّضْ \add عَاوذْ\add* غَارْ شَّامَالْ. أَمْ إِڭُّورْ إِتّنّضْ، إِتّنّضْ ؤُسمِّيضْ، ؤُشَا إِتّْغِيمَا ؤُسمِّيضْ إِدَّاكّْوَاڒْ-د غَارْ ؤُذُووَّارْ نّسْ.  
\v 7 مَارَّا إِغزْرَانْ تّْكبَّانْ ذِي ڒبْحَارْ، \add مَاشَا\add* وَارْ إِتّْشُّورِي ڒبْحَارْ. غَارْ مَانِيسْ د-تَّازّْڒنْ إِغزْرَانْ، ذِينِّي تّْغِيمنْ تَّازّْڒنْ \add عَاوذْ\add*. \x ◘ \xo 1:‏7 \xt أَيُوبْ 38‏:‏8، 9، 10؛ إِزهد. 104‏:‏9، 10\x*  
\v 8 مَارَّا ثِيمسْڒَايِينْ سَّاحَاڒنْثْ \add بْڒَا قطُّو\add*، ؤُڒَا ذ إِجّنْ وَارْ إِزمَّارْ أَذْ خَاسْ يِينِي شَا.عمَّارْصْ ثِيطّْ أَذْ ثجَّاونْ زڭْ وژْرِي ؤُشَا أَمزُّوغْعمَّارْصْ أَذْ إِجَّاونْ زڭْ ؤُثسْڒِي.  
\v 9 مِينْ ثُوغَا إِدْجَانْ أَذْ يِيڒِي، مِينْ إِتّْوَاڭّنْ أَذْ إِتّْوَاڭّْ \add عَاوذْ\add*. وَارْ \add ذِينْ\add* إِدْجِي جْذِيذْ سَاذُو ثْفُوشْثْ. \x ◘ \xo 1:‏9 \xt أَمب. 3‏:‏15\x*  
\v 10 مَا أَقَا ذِينْ شَا ن ڒْحَاجّثْ قَّارنْ خَاسْ: ”خْزَارْ، مَانْ أَيَا ذ جْذِيذْ!“؟، أَقَا-ت ذِينْ ذِي زّْمَانَاثْ نِّي ثُوغَا إِدْجَانْ قْبڒْ إِ نشِّينْ.  
\v 11 وَارْ ذِينْ دْجِينْ ذ إِخَارِّيصنْ خْ يِينِّي ثُوغَا ذ إِمزْوُورَا، ؤُشَا ؤُڒَا خْ يِينِّي إِ غَا يِيڒِينْ ذ إِنڭُّورَا، وَارْ خَاسنْ تِّيڒِينْ إِخَارِّيصنْ غَارْ يِينِّي د غَا يَاسنْ أَوَارْنِي أَسنْ \add عَاذْ\add*.   
\b  
\m  
\s1 ثَارزُّوثْ ن ؤُمْبَارّحْ  
\m
\v 12 نشّْ، أَمْبَارّحْ، ثُوغَا أَيِي ذ أَجدْجِيذْ خْ إِسْرَائِيل، ذِي ؤُرْشَالِيمْ.  
\v 13 نشّْ ثُوغَا كّْسغْ ذڭْ وُوڒْ  إِنُو أَذْ أَرْزُوغْ ؤُ أَذْ بقّْشغْ س ثِيغِيثْ ذِي مَارَّا مِينْ إِمْسَارنْ سَاذُو ؤُجنَّا. مَانْ أَيَا ذ إِجّْ ن شّْغڒْ إِوْعَارْ، إِوْشَا إِ-ث أَربِّي إِ ثَارْوَا ن بْنَاذمْ حِيمَا أَذْ ذَايسْ ڒْهَانْ.  
\v 14 نشّْ ژْرِيغْ مَارَّا ثِيمڭَّا إِ إِتّْوَاڭّنْ سَاذُو ثْفُوشْثْ، ؤُ خْزَارْ، مَارَّا أَيَا ثُوغَا-ث ذِي ڒْبَاطڒْ ذ وضْفَارْ ن ؤُسمِّيضْ.  
\v 15 مِينْ إِفَارْغنْ وَارْ إِزمَّارْ أَذْ إِتّْوَاسڭّمْ، ؤُ مِينْ إِتّْخصَّانْ وَارْ إِزمَّارْ أَذْ إِتّْوَاحْسبْ.  
\v 16 نشّْ نِّيغْ ذڭْ وُوڒْ إِنُو: ”خْزَارْ، نشّْ سّمْغَارغْ ثِيغِيثْ إِنُو ؤُشَا أَرْنِيغْ ذَايسْ، مَاهُو مَارَّا إِنِّي ثُوغَا إِزدّْغنْ ذِي ؤُرْشَالِيمْ قْبڒْ إِنُو. ؤُڒْ إِنُو إِژْرَا أَطَّاسْ ن ثِيغِيثْ ذ ثُوسّْنَا.  
\v 17 نشّْ ڭِّيغْ ؤُڒْ إِنُو، مَاحنْذْ أَذْ د-أَوْيغْ ثِيغِيثْ، \add مَاحنْذْ\add* أَذْ سّْنغْ ثُوبُّوهڒْيَا ذ جّْهڒْ. نشّْ ؤُفِيغْ ؤُڒَا ذ مَانْ أَيَا أَقَا ذ أَضْفَارْ ن ؤُسمِّيضْ.  
\v 18 مَاغَارْ ذڭْ وَاطَّاسْ ن ثِيغِيثْ، ذَايسْ أَطَّاسْ ن ڒْهمّْ، ؤُ ونِّي يَارنِّينْ ذِي ثُوسّْنَا، يَارنِّي ذڭْ ومْنُوسْ.   
\b  
\b  
\m  
\c 2
\s1 أَبَارّعْ ن ثْمسْڒَايِينْ ن ثُوذَارْثْ  
\m
\v 1 نشّْ نِّيغْ ذڭْ وُوڒْ إِنُو: ”أَسْ-د، أَذْ شكْ قدْجْبغْ س ڒفْرَاحثْ. خْزَارْ غَارْ مِينْ إِشْنَانْ!“ ؤُفِيغْ ؤُڒَا ذ مَانْ أَيَا أَقَا-ث ذِي ڒْبَاطڒْ. \x ◘ \xo 2:‏1 \xt لك. 12‏:‏19\x*  
\v 2 إِ ثَاذحَّاشْثْ نِّيغْ نشّْ: ”ذ ثابُوهَاڒِيثْ \add شمْ\add*!“، ؤُ إِ ڒفْرَاحثْ: ”مِينْ د غَا ثَاوِي أَمنِّي؟“  
\v 3 نشّْ أَرْزُوغْ ذڭْ وُوڒْ إِنُو ؤُمِي سَّارشَّاقغْ أَرِّيمثْ إِنُو س بِينُو - ذِي ڒْوقْثْ مَانِي ؤُڒْ إِنُو إِقِّيمْ إِتّطّفْ \add سْڒَايمْ ن ثُوذَارْثْ إِنُو\add* س ثِيغِيثْ - ؤُ ؤُمِي قِّيمغْ ڒسّْقغْ ذِي ثُوبُّوهڒْيَا\add -يَا\add*، أَڒَامِي أَذْ ژَترغْ مِينْ إِدْجَانْ حْسنْ قَاعْ إِ ثَارْوَا ن بْنَاذمْ، مَاحنْذْ أَذْ ث ڭّنْ سَاذُو ؤُجنَّا أَمْ حسّْبنْ سْ ڒْمقْڒُوبْ ڒْقدّْ ن وُوسَّانْ ن ثُوذَارْثْ نْسنْ.   
\m
\v 4 نشّْ أَرْنِيغْ ذِي ڒمْغَارثْ ن مِينْ ڭِّيغْ. نشّْ سّْبدّغْ إِ يِيخفْ إِنُو ثُوذْرِينْ، ژُّوغْ ثِيزَايَارِينْ ذڭْ إِمَارْجَاعنْ إِ يِيخفْ إِنُو.  
\v 5 نشّْ ڭِّيغْ إِحْوِيشنْ ذ إِفْثِيسنْ أَمْ يِينِّي ن جّنّثْ ؤُشَا ژُّوغْ ذَايْسنْ عْڒَامْ كُوڒْ ثِيشجُّورَا ن فْرُوثَا.  
\v 6 نشّْ ڭِّيغْ إِيڒْمَامنْ شُّورنْ س وَامَانْ حِيمَا أَذْ زَّايْسنْ سّسْوغْ أَزْغَارْ، مَاحنْذْ أَذْ سُّوفّْينْثْ ثْشجُّورَا. \f ◼ \fr 2:‏6 \ft \+bd ’أَزْغَارْ‘\+bd* - نِيغْ ’ڒْغَابثْ‘ نِيغْ ’ثَازْڭَانْثْ‘.\f*  
\v 7 نشّْ سْغِيغْ إِسمْغَانْ ذ ثِييَّا، ؤُشَا ذوْڒنْ غَارِي إِمْسخَّارنْ إِتّْوَارْونْ ذِي ثَادَّارْثْ \add إِنُو\add*. ثُوغَا غَارِي ؤُڒَا ذ إِشْثْ ن ثْحِيمَارْثْ ذ ثَامقّْرَانْثْ ن إِفُونَاسنْ ذ وُودْجِي، أَطَّاسْ خْ مَارَّا إِنِّي ثُوغَا إِدْجَانْ ذِي ؤُرْشَالِيمْ قْبڒْ خَافِي. \f ◼ \fr 2:‏7 \ft \+bd ’إِمْسخَّارنْ إِتّْوَارْونْ ذِي ثَادَّارْثْ إِنُو‘\+bd* - س ثْعِيبْرَانِيثْ ’أَيْثْ ن ثَادَّارْثْ‘، إِخْسْ أَذْ يِينِي ’إِسمْغَانْ نِيغْ إِمْسخَّارنْ‘ نِّي إِتّْوَارْونْ ذِي ثَادَّارْثْ ن بَابْ نْسنْ، وَارْ د-تّْوَاسْغنْ زِي بَارَّا. إِجّْ ن ؤُمْسخَّارْ أَمْ وَانِيثَا إِتّْوَاحْسبْ ذ أَمزْوَارُو ن مَارَّا إِسمْغَانْ ذِي ثَادَّارْثْ ن سِيذسْ.\f*  
\v 8 نشّْ سّْمُونغْ إِ يِيخفْ إِنُو ؤُڒَا ذ نُّوقَارْثْ ذ وُورغْ ذ ڒكْنُوزْ ن إِجدْجِيذنْ ؤُ زِي لْعَامَالَاثْ. نشّْ ضبَّارغْ-د إِ يِيخفْ إِنُو إِمغْنُوجنْ ذ ثْمغْنُوجِينْ ؤُڒَا ذ مِينْ ذِي مژْرنْ ثَارْوَا ن بْنَاذمْ: ثَامْغَارْثْ ذ ثمْغَارِينْ.  
\v 9 نشّْ أَرْنِيغْ ذِي ڒمْغَارثْ إِنُو ؤُشَا أَرْنِيغْ-د أَطَّاسْ، مَاهُو مَارَّا إِنِّي إِدْجَانْ قْبڒْ إِ نشّْ ذِي ؤُرْشَالِيمْ، \add مَاشَا\add* ثِيغِيثْ ثقِّيمْ ثْبدّْ أَكِيذِي.  
\v 10 مَارَّا مِينْ إِدْجَانْ ذ مژْرِي ذِي ثِيطَّاوِينْ إِنُو، وَارْ ذ أَسنْثْ قْضِيعغْ. وَارْ منْعغْ إِ وُوڒْ إِنُو ؤُڒَا ذ إِشْثْ ن ڒْحَاجّثْ، مَاغَارْ ؤُڒْ إِنُو إِفَارْحْ زِي سِّيبّثْ ن مَارَّا ثَامَارَا إِنُو: ثَا ذ ثَاسْغَارْثْ ن مَارَّا أَمَارّثْ إِنُو.  
\v 11 \add خَاسْ ؤُشَا\add* ڭِّيغْ ؤُذمْ إِنُو غَارْ مَارَّا ثِيمڭَّا إِنُو، مِينْ ڭِّينْ إِفَاسّنْ إِنُو، ؤُ غَارْ ؤُمَارّثْ نِّي ڭِّيغْ أَمْ ذ أَيِي ثُوغَا تّْمَارَّاثغْ مَاحنْذْ أَذْ ڭّغْ \add مَارَّا أَيَا\add*. خْزَارْ، \add ؤُفِيغْ\add* مَانْ أَيَا مَارَّا أَقَا-ث ذِي ڒْبَاطڒْ ذ وضْفَارْ ن ؤُسمِّيضْ ؤُشَا وَارْ \add ذَايسْ\add* إِدْجِي بُو ڒفْضڒْ سَاذُو ثَافُوشْثْ.   
\b  
\m  
\s1 ثِيغِيثْ ذ ثُوبُّوهڒْيَا  
\m
\v 12 نشّْ ڭِّيغْ ؤُذمْ إِنُو مَاحنْذْ أَذْ ژَترغْ ثِيغِيثْ، ؤُڒَا ذ ثُوبُّوهڒْيَا ذ ثَاغْيُوڒِي، مَاغَارْ مِينْ إِعْنَا بْنَاذمْ نِّي د غَا إِضْفَارنْ أَجدْجِيذْ نِّي يَارشّْحنْ أَطَّاسْ زڭْ وَامِي؟ \x ◘ \xo 2:‏12 \xt أَمب. 1‏:‏17؛ 7‏:‏23\x*  
\v 13 نشّْ ژْرِيغْ أَقَا ثِيغِيثْ ثعْذُو خْ ثُوبُّوهڒْيَا، أَمْ ثعْذُو ثْفَاوْثْ خْ ثَادْجسْثْ.  
\v 14 أَمِيغِيسْ غَارسْ ثِيطَّاوِينْ ذڭْ ؤُزدْجِيفْ نّسْ، \add مَاشَا\add* أَبُوهَاڒِي إِڭُّورْ ذِي ثَادْجسْثْ. \add خنِّي\add* ؤُفِيغْ أَقَا ثْڒقّفْ إِ-ثنْ مَارَّا ثِيرَا ذ إِشْثْ.  
\v 15 \add خنِّي\add* نِّيغْ ذڭْ وُوڒْ إِنُو: ”مَاڒَا ثڒْقفْ أَبُوهَاڒِي، أَذْ ثڒْقفْ ؤُڒَا ذ نشّْ. مَايمِّي غَا ميّْزغْ س ثِيغِيثْ؟“ \add ؤُشَا\add* نِّيغْ ذڭْ وُوڒْ إِنُو: ”ؤُڒَا ذ مَانْ أَيَا أَقَا-ث ذِي ڒْبَاطڒْ.“  
\v 16 مَاغَارْ إِ ڒبْذَا وَارْ إِتِّيڒِي ڒْعقْڒَانْ خْ ؤُمِيغِيسْ ؤُڒَا خْ ؤُبُوهَاڒِي. ذڭْ وُوسَّانْ إِ د غَا يَاسنْ أَذْ إِتّْوَاتُّو مَارَّا. مَا وَارْ إِمُّوثْ ؤُمِيغِيسْ أَمْ ؤُبُوهَاڒِي؟   
\m
\v 17 ؤُشَا بْذِيغْ أَذْ شَارْهغْ ثُوذَارْثْ، مَاغَارْ مِينْ إِتّْوَاڭّنْ سَاذُو ثَافُوشْثْ، ثوْضَا-د خَافِي \add مْغِيرْ\add* ذ ثَامَارَا، مَاغَارْ مَانْ أَيَا مَارَّا أَقَا-ث ذِي ڒْبَاطڒْ ذ وضْفَارْ ن ؤُسمِّيضْ.  
\v 18 بْذِيغْ عَاوذْ أَذْ شَارْهغْ أَمَارّثْ إِنُو إِ زِي مَارّْثغْ سَاذُو ثَافُوشْثْ، مَاحنْذْ أَذْ ث جّغْ إِ يِيجّْ ن بْنَاذمْ نِّي إِ غَا يِيڒِينْ أَوَارْنِي أَيِي.  
\v 19 وِي إِسّْننْ مَا نتَّا أَذْ يِيڒِي ذ أَمِيغِيسْ نِيغْ ذ أَبُوهَاڒِي؟ أَقَا ڭُّورْ أَذْ إِصلّطْ خْ مَارَّا أَمَارّثْ إِنُو إِ زِي مَارّْثغْ ؤُ إِ زِي ثُوغَا دْجِيغْ ذ أَمِيغِيسْ سَاذُو ثْفُوشْثْ. أَقَا ؤُڒَا ذ مَانْ أَيَا أَقَا-ث ذِي ڒْبَاطڒْ.   
\m
\v 20 \add ڒخْذنِّي\add* نّْقڒْبغْ حِيمَا أَذْ ڭّغْ ؤُڒْ إِنُو أَذْ إِقْنضْ خْ مَارَّا أَمَارّثْ إِنُو إِ زِي ثُوغَا مَارّْثغْ سَاذُو ثْفُوشْثْ.  
\v 21 مَاغَارْ \add وَاخَّا\add* أَقَا ذِينْ إِجّْ ن بْنَاذمْ إِ ؤُمِي د-يُوسَا أَمَارّثْ نّسْ أَكْ-ذ ثِيغِيثْ ذ ثُوسّْنَا ذ ثْزمَّارْ، \add عَاذْ\add* إِتّْخصَّا أَشْ أَذْ ث إِوْشْ إِ يِيجّْ ن بْنَاذمْ إِ وَارْ إِمَارّْثنْ إِ مَانْ أَيَا. ؤُڒَا ذ مَانْ أَيَا أَقَا-ث ذِي ڒْبَاطڒْ ذ إِشْثْ ن ثُوعفّْنَا ذ ثَامقّْرَانْثْ.  
\v 22 مَاغَارْ مَانْ ڒفْضڒْ غَارْ بْنَاذمْ زِي مَارَّا أَمَارّثْ نّسْ ؤُ زِي ثَارزُّوثْ ن وُوڒْ نّسْ إِ زِي إِتّْمَارَّاثْ سَاذُو ثْفُوشْثْ؟ \x ◘ \xo 2:‏22 \xt أَمب. 1‏:‏3؛ 3‏:‏9\x*  
\v 23 مَاغَارْ مَارَّا ؤُسَّانْ نّسْ مْغِيرْ ذ أَمْنُوسْ ؤُ شّْغڒْ نّسْ \add يِيوِيضْ\add* ڒْهمّْ. عَاذْ ذِي دْجِيڒثْ وَارْ يَاريّحْ وُوڒْ نّسْ. ؤُڒَا ذ مَانْ أَيَا أَقَا-ث ذِي ڒْبَاطڒْ.   
\m
\v 24 وَارْ ذِينْ إِدْجِي ذ لمْلِيحْ إِ بْنَاذمْ خْ مَاشَّا ذ ثْسسْوِيثْ ؤُڒَا خْ ؤُمِي إِغبَّا ڒعْمَارْ نّسْ غَارْ \add مَارَّا\add* أَمَارّثْ نّسْ. نشّْ ژْرِيغْ أَقَا ؤُڒَا ذ مَانْ أَيَا \add يُوسَا-د\add* زڭْ ؤُفُوسْ ن أَربِّي. \x ◘ \xo 2:‏24 \xt أَمب. 3‏:‏12، 22؛ 5‏:‏18؛ 8‏:‏15\x*  
\v 25 مَاغَارْ مَانْ ونْ إِزمَّارنْ أَذْ يشّْ نِيغْ مَانْ ونْ إِزمَّارنْ أَذْ يَاوِي أَڒِيقِّي بَارَّا إِ نشّْ؟  
\v 26 مَاغَارْ نتَّا إِتِّيشْ ثِيغِيثْ ذ ثُوسّْنَا ذ ڒفْرَاحثْ إِ بْنَاذمْ نِّي إِشْنَانْ زَّاثْ إِ وُوذمْ نّسْ. \add مَاشَا\add* إِ ؤُمذْنُوبْ إِتِّيشْ أَسْ شّْغڒْ مَاحنْذْ أَذْ إِيَارْوْ ؤُ أَذْ إِسّْمُونْ، حِيمَا أَذْ ث إِوْشْ \add خنِّي\add* إِ ونِّي إِدْجَانْ إِشْنَانْ زَّاثْ إِ وُوذمْ ن أَربِّي. ؤُڒَا ذ مَانْ أَيَا أَقَا-ث ذِي ڒْبَاطڒْ ذ وضْفَارْ ن ؤُسمِّيضْ. \x ◘ \xo 2:‏26 \xt أَيُوبْ 27‏:‏16، 17؛ أَوڒن. 28‏:‏8؛ أَمب. 3‏:‏13\x*   
\b  
\b  
\m  
\c 3
\s1 مَارَّا غَارسْ ثْسَاعّثْ نّسْ  
\m
\v 1 مَارَّا غَارسْ ڒْمِيجَاڒْ نّسْ ؤُ أَقَا ذِينْ \add عَاوذْ\add* ثَاسَاعّثْ \add إِتّْوَاڭّنْ\add* إِ كُوڒْ أَنْوَايْ سَاذُو أَجنَّا.   
\b  
\m
\v 2 أَقَا ذِينْ إِشْثْ ن ثْسَاعّثْ ن ثَارْوَا  
\m ذ إِشْثْ ن ثْسَاعّثْ ن ڒْموْثْ،  
\m إِشْثْ ن ثْسَاعّثْ ن ثَاژُّوثْ  
\m ذ إِشْثْ ن ثْسَاعّثْ ن وقْڒَاعْ ن مِينْ إِثْوَاژُّونْ،   
\m
\v 3 إِشْثْ ن ثْسَاعّثْ ن ثْمنْغِيوْثْ  
\m ذ إِشْثْ ن ثْسَاعّثْ ن ؤُسْڭنْفِي،  
\m إِشْثْ ن ثْسَاعّثْ ن وهْذَامْ  
\m ذ إِشْثْ ن ثْسَاعّثْ ن ڒبْنِي،   
\m
\v 4 إِشْثْ ن ثْسَاعّثْ ن إِمطَّاونْ  
\m ذ إِشْثْ ن ثْسَاعّثْ ن ثْضحَّاشْثْ،  
\m إِشْثْ ن ثْسَاعّثْ ن وشْضَانْ  
\m ذ إِشْثْ ن ثْسَاعّثْ ن شّْضِيحْ،   
\m
\v 5 إِشْثْ ن ثْسَاعّثْ ن ؤُحجَّارْ ن وژْرُو  
\m ذ إِشْثْ ن ثْسَاعّثْ ن وجْرَاوْ ن وژْرُو،  
\m إِشْثْ ن ثْسَاعّثْ ن ؤُذَارّعْ  
\m ذ إِشْثْ ن ثْسَاعّثْ ن ڒَاڭّْوَاجْ خْ ؤُذَارّعْ، \x ◘ \xo 3:‏5 \xt 1 كُور. 7‏:‏5\x*   
\m
\v 6 إِشْثْ ن ثْسَاعّثْ ن ثَارزُّوثْ  
\m ذ إِشْثْ ن ثْسَاعّثْ ن ؤُودَّارْ،  
\m إِشْثْ ن ثْسَاعّثْ ن ؤُخمّرْ  
\m ذ إِشْثْ ن ثْسَاعّثْ ن ونْضَارْ،   
\m
\v 7 إِشْثْ ن ثْسَاعّثْ ن ؤُشَارّڭْ  
\m ذ إِشْثْ ن ثْسَاعّثْ ن ؤُخيّضْ،  
\m إِشْثْ ن ثْسَاعّثْ ن ؤُسغْذِي  
\m ذ إِشْثْ ن ثْسَاعّثْ ن ڒْهَارْذْ،   
\m
\v 8 إِشْثْ ن ثْسَاعّثْ ن ثَايْرِي  
\m ذ إِشْثْ ن ثْسَاعّثْ ن وشْرَاهْ،  
\m إِشْثْ ن ثْسَاعّثْ ن ڭَارَّا  
\m ذ إِشْثْ ن ثْسَاعّثْ ن ڒهْنَا.   
\b  
\m
\v 9 مَانْ ثِيزِي غَارْ ونِّي إِخدّْمنْ خْ مِينْ خفْ يَاربّرْ؟ \x ◘ \xo 3:‏9 \xt أَمب. 1‏:‏3\x*  
\v 10 نشّْ ژْرِيغْ شّْغڒْ نِّي إِوْشَا أَربِّي إِ ثَارْوَا ن بْنَاذمْ مَاحنْذْ أَذْ زَّايسْ سِّيحْڒنْ إِخفْ نْسنْ.  
\v 11 نتَّا إِڭَّا مَارَّا ذ أَصبْحَانْ ذِي ڒْوقْثْ نّسْ. إِڭَّا ؤُڒَا ذ ڒْوقْثْ ن ڒبْذَا ذڭْ وُوڒْ نْسنْ، بْڒَا مَا إِزمَّارْ بْنَاذمْ أَذْ إِحَاكَا ذِي ثْمڭَّا نِّي إِڭَّا أَربِّي زڭْ ؤُمزْوَارُو أَڒْ أَنڭَّارُو.  
\v 12 نشّْ ؤُفِيغْ وَارْ غَارْسنْ إِدْجِي مِينْ إِحْڒَانْ خْ مِينِّي فَارّْحنْ \add إِوْذَانْ\add* نِيغْ أَذْ أَرّنْ مژْرِي مڒْمِي نِيثْنِي \add عَاذْ\add* ذِي ثُوذَارْثْ نْسنْ،  
\v 13 ؤُ عَاوذْ أَقَا كُوڒْ بْنَاذمْ أَذْ إِشّْ، أَذْ إِسُو ؤُشَا أَذْ يَارّْ مژْرِي ذِي مِينْ إِصبْحنْ ذِي مَارَّا أَمَارّثْ نّسْ. أَيَا ذ إِشْثْ ن ثَارْزفْثْ ن أَربِّي.   
\m
\v 14 نشّْ سّْنغْ أَقَا مَارَّا مِينْ إِتّڭّْ أَربِّي، أَذْ يِيڒِي إِ ڒبْذَا. وَارْ إِزمَّارْ أَذْ غَارسْ إِتّْمَارْنِي وَالُو ؤُ وَارْ زَّايسْ إِتّْوَاسّنْقِيسْ وَالُو. أَربِّي إِڭَّا \add إِ-ث\add* مَاحنْذْ أَذْ ڭّْوذنْ زَّاثْ إِ وُوذمْ نّسْ.  
\v 15 مِينْ إِدْجَانْ، ثُوغَا إِدْجَا قْبڒْ ؤُشَا مِينْ إِ غَا يِيڒِينْ، ثُوغَا إِدْجَا \add قْبڒْ\add*. أَربِّي يَارزُّو خْ مِينْ إِعْذُونْ \add عَاذْ\add*.   
\b  
\m  
\s1 أَشْثَابْ ن ؤُمْسڭّذْ ذ يِينِّي وَارْ إِسڭّْذنْ  
\m
\v 16 أَقَا ژْرِيغْ سَاذُو ثْفُوشْثْ عَاوذْ أَمْشَانْ ن ڒْحقّْ: أَقَا إِسلّطْ ذِينْ ڒْغشّْ، \add ؤُشَا ژْرِيغْ\add* ؤُڒَا ذ أَمْشَانْ ن ثْسڭْذَا: أَقَا \add إِسلّطْ\add* ذِينْ ڒْغَارْ.  
\v 17 نشّْ نِّيغْ ذڭْ وُوڒْ إِنُو: ”أَربِّي أَذْ إِحْكمْ أَمْسڭّذْ ذ ؤُعفَّانْ، مَاغَارْ ذِينِّي إِشْثْ ن ثْسَاعّثْ إِ كُوڒْ أَنْوَايْ ؤُ إِ قَاعْ ڒْخذْمثْ.“  
\v 18 نشّْ نِّيغْ ذڭْ وُوڒْ إِنُو: ”أَقَا ذِي طّْوعْ ن ثَارْوَا ن بْنَاذمْ، أَقَا أَربِّي أَذْ ثنْ إِسِّيففْ ؤُ نِيثْنِي أَذْ ثْوَاڒَانْ أَقَا نِيثْنِي أَمْ ڒْمَاڒْ، نِيثْنِي س يِيخفْ نْسنْ.“  
\v 19 مَاغَارْ خْ ثِيرَا ن ثَارْوَا ن بْنَاذمْ ؤُ خْ ثِيرَا ن ڒْمَاڒْ: نِيثْنِي غَارْسنْ ثِيرَا ذ إِشْثْ. أَمْ مَامّشْ إِمُّوثْ وَا، إِمُّوثْ ؤُڒَا ذ ونّغْنِي، مَارَّا إِذْسنْ غَارْسنْ ذ ثْوَارِّيثْ ن نّفْسْ ذ إِجّْ. وَارْ ذِينْ إِدْجِي ڒفْضڒْ إِ بْنَاذمْ خْ ڒْمَاڒْ، مَاغَارْ مَارَّا أَقَا-ث ذِي ڒْبَاطڒْ.  
\v 20 مَارَّا إِذْسنْ ڭُّورنْ غَارْ إِجّْ ن ومْشَانْ، مَارَّا نِيثْنِي زڭْ ؤُشَاڒْ ؤُشَا أَذْ د-ذوْڒنْ غَارْ ؤُشَاڒْ. \x ◘ \xo 3:‏20 \xt أَمز. 3‏:‏19\x*  
\v 21 وِي إِسّْننْ، مَا بُوحْبڒْ ن ثَارْوَا ن بْنَاذمْ أَذْ إِڭعّذْ غَارْ سنّجْ ؤُ بُوحْبڒْ ن ڒْمَاڒْ أَذْ د-إِهْوَا غَارْ ثمُّورْثْ؟  
\v 22 أَمُّو إِ تّْوَاڒِيغْ، وَارْ إِدْجِي مِينْ إِحْڒَانْ خْ مِينِّي إِفَارّحْ بْنَاذمْ ذِي ثْمڭَّا نّسْ، مَاغَارْ مَانْ أَيَا ذ ثَاسْغَارْثْ نّسْ، مِينْزِي مَانْ ونْ إِزمَّارنْ أَذْ ث يَارّْ أَڒْ غَا إِژَارْ مِينْ غَا يِيڒِينْ أَوَارْنِي أَسْ؟   
\b  
\b  
\m  
\c 4
\s1 ونِّي إِحصَّارنْ ذ ونِّي إِتّْوَاحْصَارنْ  
\m
\v 1 ژْرِيغْ عَاوذْ مَارَّا دّدْجْ إِ إِتّْوَاڭّنْ سَاذُو ثْفُوشْثْ. خْزَارْ، أَقَا ذَا إِمطَّاونْ ن يِينِّي إِتّْوَاذدْجنْ، \add مَاشَا\add* وَارْ غَارْسنْ بُو ؤُمْفوّجْ. إِفّغْ-د لْعُونْفْ زڭْ ؤُفُوسْ ن يِينِّي ثنْ إِتّذْدْجَانْ، \add مَاشَا\add* وَارْ غَارْسنْ بُو ؤُمْفوّجْ.  
\v 2 \add خنِّي\add* صبّْحغْ إِمتِّيننْ نِّي إِمُّوثنْ عَاذْ \add أَطَّاسْ زڭْ وَامِي\add*، زڭْ إِنِّي إِدَّارنْ، إِنِّي عَاذْ إِدَّارنْ.  
\v 3 \add مَاشَا\add* إِحْڒَانْ خَاسنْ س ثْنَاينْ إِذْسنْ نِّي ذ ونِّي وَارْ إِدْجِينْ عَاذْ، ذ ونِّي وَارْ إِژْرِينْ \add عَاذْ\add* ثِيمڭَّا ثِيعفَّانِينْ نِّي إِتّْوَاڭّنْثْ سَاذُو ثْفُوشْثْ.   
\m
\v 4 ؤُشَا نشّْ ژْرِيغْ مَارَّا أَمَارّثْ ذ مَارَّا ثِيزمَّارْ ذِي ڒْخذْمثْ، أَقَا-ث مْغِيرْ ذ أَمْعَانَاذْ ن إِجّْ أَكْ-ذ ونّغْنِي. ؤُڒَا ذ مَانْ أَيَا أَقَا-ث ذِي ڒْبَاطڒْ ذ وضْفَارْ ن ؤُسمِّيضْ.  
\v 5 أَبُوهَاڒِي إِضْفسْ إِفَاسّنْ نّسْ ؤُشَا إِتّتّْ أَيْسُومْ \add ن إِخفْ\add* نّسْ. \x ◘ \xo 4:‏5 \xt أَوڒن. 6‏:‏10؛ 24‏:‏33\x*  
\v 6 إِحْڒَا إِجّْ ن وُورُو \add ن ؤُفُوسْ\add* إِشُّورْ س ڒْهُوذْنثْ ؤُڒَا ثْنَاينْ ن إِفَاسّنْ شُّورنْ س ؤُمَارّثْ ذ وضْفَارْ ن ؤُسمِّيضْ.   
\b  
\m  
\s1 أَمَارّثْ ن ونِّي وحّْذسْ  
\m
\v 7 عَاوذْ ژْرِيغْ \add شَا\add* مِينْ إِدْجَانْ ذِي ڒْبَاطڒْ سَاذُو ثْفُوشْثْ.  
\v 8 أَقَا \add ذِينْ\add* إِجّنْ \add أَقَا ث حَافِي\add* ؤُ وَارْ ذِينْ ونِّي ذ وِيسّْ ثْنَاينْ إِ إِبدّنْ غَارسْ. ؤُڒَا وَارْ غَارسْ إِدْجِي ؤُحنْجِيرْ ؤُ وَارْ غَارسْ ؤُمَاسْ. وَارْ إِدْجِي ؤُنڭَّارْ غَارْ مَارَّا أَمَارّثْ نّسْ، ؤُڒَا وَارْ ثتّْيِيوِيننْثْ ثِيطَّاوِينْ نّسْ زڭْ وَاڭْڒَا. ”إِ ؤُمِي تّڭّغْ ثَامَارَا ؤُ سّكِّيغْ ت ذِي ڒعْمَارْ إِنُو زِي ثْشُونِي؟“ ؤُڒَا ذ مَانْ أَيَا ذِي ڒْبَاطڒْ ذ إِجّْ ن شّْغڒْ إِوْعَارْ إِ يدْجَا.  
\v 9 ثْنَاينْ حْسنْ زڭْ إِجّنْ وَاهَا، مَاغَارْ نِيثْنِي غَارْسنْ ڒْمُونثْ ذ لمْلِيحْ ذڭْ ؤُمَارّثْ نْسنْ.  
\v 10 مَاغَارْ مَاڒَا نِيثْنِي وْضَانْ، أَذْ إِسّْنكَّارْ إِجّنْ زڭْ ؤُمْعَاشَارْ نّسْ عَاوذْ. \add مَاشَا\add* أَخيّبْ إِ ونِّي إِدْجَانْ وحّْذسْ مَاڒَا نتَّا إِوْضَا، مِينْزِي وَارْ ذِينْ إِتِّيڒِي حذْ، مَاحنْذْ أَذْ ث إِسّْنكَّارْ أَذْ إِبدّْ.  
\v 11 عَاوذْ مَاڒَا ثْنَاينْ طّْسنْ مُوننْ، أَذْ غَارْسنْ يِيڒِي ڒحْمُو، \add مَاشَا\add* مَامّشْ غَا إِڭّْ إِجّنْ وحّْذسْ أَذْ إِحْمَا؟  
\v 12 مَاڒَا ذِينْ إِجّنْ يَارْنَا خْ إِجّنْ إِ إِدْجَانْ وحّْذسْ، \add مَاشَا\add* ثْنَاينْ أَذْ غَارسْ بدّنْ \add جْمِيعْ\add*. إِجّْ ن وسْغُونْ إِمُوذنْ خْ ثْڒَاثَا وَارْ إِقطُّو ذغْيَا.   
\b  
\m  
\s1 أَجدْجِيذْ أَحنْجِيرْ ذ ؤُمِيغِيسْ  
\m
\v 13 إِحْرَا إِجّْ ن ؤُحُوذْرِي ذ أَمزْڒُوضْ ذ أَمِيغِيسْ زڭْ إِجّْ ن ؤُجدْجِيذْ إِوْسَارْ ذ أَبُوهَاڒِي إِ وَارْ إِفهّْمنْ عَاذْ إِ وعْڒَامْ.  
\v 14 مَاغَارْ أَذْ د-إِفّغْ زِي ڒحْبسْ مَاحنْذْ أَذْ إِذْوڒْ ذ أَجدْجِيذْ وَاخَّا نتَّا إِتّْوَاخْڒقْ-د ذ أَمزْڒُوضْ ذِي ثْڭلْذِيثْ نّسْ.  
\v 15 نشّْ ژْرِيغْ مَارَّا إِنِّي إِدَّارنْ إِ إِڭُّورنْ سَاذُو ثْفُوشْثْ، \add جْمِيعْ\add* أَكْ-ذ ؤُحُوذْرِي، ونِّي ذ وِيسّْ ثْنَاينْ نِّي إِ غَا إِبدّنْ ذڭْ ومْشَانْ نّسْ.  
\v 16 وَارْ ذِينْ أَنڭَّارْ غَارْ ڒْڭنْسْ نِّي أَمْ إِكْمڒْ نِّي زِي إِزْوَارْ نتَّا \add أَمْ يِيخفْ\add*. \add وَاخَّا أَمنِّي\add* ؤُڒَا ذ إِنِّي د غَا يَاسنْ أَوَارْنِي أَسْ، وَارْ زَّايسْ فَارّْحنْ. ؤُڒَا ذ مَانْ أَيَا أَقَا-ث ذِي ڒْبَاطڒْ ذ وضْفَارْ ن ؤُسمِّيضْ.   
\b  
\m  
\s1 خْ ڒْوُوعُوذْ إِ أَربِّي  
\m
\v 17 حْضَا أَصُورِيفْ نّشْ مَاڒَا شكْ ثڭُّورذْ غَارْ ثَادَّارْثْ ن أَربِّي. أَقَارّبْ حِيمَا أَذْ ثسْحسّذْ، حْسنْ زڭْ ؤُوهّبْ ن ثْغَارْصْثْ س \add ؤُفُوسْ ن\add* إِپُوهَاڒِييّنْ، مَاغَارْ نِيثْنِي وَارْ سِّيننْ أَقَا نِيثْنِي تّڭّنْ ثُوعفّْنَا.   
\b  
\b  
\m  
\c 5
\m
\v 1 وَارْ ثْقدْجِيقْ س ؤُقمُّومْ نّشْ ؤُ حْضَا أَقَا ؤُڒْ نّشْ وَارْ إِتّمْحِيزْوَارْ أَذْ إِنْطقْ أَوَاڒْ زَّاثْ إِ أَربِّي. مَاغَارْ أَربِّي ذڭْ ؤُجنَّا، \add مَاشَا\add* شكْ ذِي ثمُّورْثْ. خْ ؤُيَا أجّْ أَذْ إِڒِينْ وَاوَاڒنْ نّشْ ؤُذْرُوسنْ.  
\v 2 مَاغَارْ أَمْ ثَارْجِيثْ ثتَّاسْ-د س وَاطَّاسْ ن ڒهُّو، أَمُّو ؤُڒَا ذ ڒْهَارْذْ ن ؤُبُوهَاڒِي س وَاطَّاسْ ن وَاوَاڒنْ.   
\m
\v 3 مَاڒَا شكْ ثڭِّيذْ إِ أَربِّي إِشْثْ ن ثْجَادْجِيثْ، وَارْ تّْرَاجَا شَا \add خنِّي\add* مَاحنْذْ أَذْ ت ثْكمّْڒذْ، مَاغَارْ وَارْ ذ أَسْ تّعْجِيبنْ إِبُوهَاڒِييّنْ. مِينْ ثْوَاعْذذْ، إِتّْخصَّا أَذْ ث تّْكمّْڒذْ. \x ◘ \xo 5:‏3 \xt ڒخْڒ. 30‏:‏3؛ أَعَوذ. 23‏:‏20\x*  
\v 4 إِهْڒَا مَاڒَا وَارْ ثْوَاعْذذْ خْ مَاڒَا شكْ ثْوَاعْذذْ، \add مَاشَا\add* وَارْ ثْكمّْڒذْ. \x ◘ \xo 5:‏4 \xt أَعَوذ. 23‏:‏20، 21\x*  
\v 5 وَارْ تّجِّي أَقَا أَقمُّومْ نّشْ أَذْ يَارّْ أَرِّيمثْ نّشْ أَذْ ثخْضَا ؤُ وَارْ ثقَّارْ زَّاثْ إِ وُوذمْ ن لْمَالَاكْ، أَقَا مَانْ أَيَا ذ أَودَّارْ وَاهَا. مَايمِّي غَا إِفُّوڭمْ أَربِّي خْ مِينْ ثقَّارذْ ؤُ أَذْ يَاردّدْجْ ڒْخذْمثْ ن إِفَاسّنْ نّشْ؟  
\v 6 مَاغَارْ ذڭْ وَاطَّاسْ ن ثِيرْجَا، أَقَا ذَايْسنْثْ مِينْ إِدْجَانْ ذِي ڒْبَاطڒْ، أَمُّو ؤُڒَا ذڭْ وَاطَّاسْ ن وَاوَاڒنْ. س ؤُيَا: ڭّْوذْ أَربِّي!\x ◘ \xo 5:‏6 \xt أَوڒن. 10‏:‏19\x*   
\b  
\m  
\s1 ڒحْصَارثْ ذ ؤُسْفَارْغْ ن ڒْحقّْ  
\m
\v 7 مَاڒَا شكْ ثْحكَّارذْ ڒحْصَارثْ ن إِمزْڒَاضْ ؤُڒَا ذ أَمْنَاعْ نْ ڒْحقّْ ذ ثْسڭْذَا ذِي لْعَامَالَا، وَارْ تَّارْجِيفْ شَا أَقَا \add مَانْ أَيَا\add* يُوسَا-د \add أَسنْ\add* س ڒْخَاضَارْ، مَاغَارْ خْ يِيجّْ ن ؤُمقّْرَانْ أَقَا ذِينْ ونِّي ذ أَمقّْرَانْ \add خَاسْ\add* ؤُشَا خَاسنْ بدّنْ إِنِّي ذ إِمقّْرَاننْ \add عَاذْ\add*.  
\v 8 إِجّْ ن ؤُجدْجِيذْ إِتّْشطَّارنْ إِ ثمُّورْثْ \add ن ثْفدْجَاحْثْ\add*، أَقَا نتَّا ذْ ڒفْضڒْ إِ ثمُّورْثْ ذِي مَارَّا إِغزْذِيسنْ.   
\b  
\m  
\s1 أَذْ إِفْنَا وَاڭْڒَا ذ بْنَاذمْ  
\m
\v 9 ونِّي إِتّخْسنْ ثْمنْيَاثْ، وَارْ إِتّْجِيوِينْعمَّارْصْ ثْمنْيَاثْ، ؤُ ونِّي إِتّخْسنْ أَڭْڒَا،عمَّارْصْ \add وَارْ إِتّْجِيوِينْ\add* ڒْمُونثْ \add نّسْ\add*. ؤُڒَا ذ مَانْ أَيَا أَقَا-ث ذِي ڒْبَاطڒْ.   
\m
\v 10 مَانِي إِتّْمَارْنِي وَاڭْڒَا، أَمُّو تّْمَارْنِينْ ؤُڒَا ذ إِنِّي ث إِ غَا إِشّنْ. مَانْ ڒفْضڒْ إِ غَا إِقِّيمنْ إِ أَيْثْبَابْ نّسْ مْغِيرْ ثِيطَّاوِينْ نْسنْ زمَّارنْثْ أَذْ خْزَارنْثْ \add أَيَا\add*؟  
\v 11 إِضصْ ن ؤُخدَّامْ ذ مِيژِيذْ، مَا نتَّا غَارسْ ذْرُوسْ نِيغْ أَطَّاسْ ن مَاشَّا، \add مَاشَا\add* إِ بُو-وَاڭْڒَا أَفيّضْ نّسْ وَارْ ث إِتّجِّي أَذْ إِطّصْ.   
\b  
\m
\v 12 أَقَا ذِينْ إِجّْ ن ڒْغَارْ إِ ژْرِيغْ سَاذُو ثْفُوشْثْ، \add إِجّْ ن ڒْغَارْ\add* إِتّڭّْ أَمْ ڒهْڒَاشْ: أَڭْڒَا إِتّْعسّْ خَاسْ بَابْ نّسْ إِ ذْرُوشْثْ إِ إِخفْ نّسْ.  
\v 13 إِفْنَا \add زعْمَا\add* وَاڭْڒَا نّسْ س إِشْثْ ن ثمْسَارْثْ ذ ثَاعفَّانْثْ ؤُشَا نتَّا ثُوغَا يجّْ-د مِّيسْ، \add خنِّي\add* وَارْ غَارسْ إِقِّيمْ وَالُو \add عَاذْ\add* ذڭْ ؤُفُوسْ نّسْ.  
\v 14 أَمْ مَامّشْ د-إِفّغْ نتَّا زڭْ ؤُعذِّيسْ ن يمَّاسْ، \add أَمُّو إِ غَا\add* إِعْقبْ ذ أَعَارْيَانْ. أَذْ يُويُورْ أَمْ مَامّشْ إِ د-يُوسَا. س \add مَارَّا\add* أَمَارّثْ نّسْ إِ زِي إِمَارّثْ، وَارْ \add إِزمَّارْ\add* أَذْ \add كِيذسْ\add* إِكْسِي ؤُڒَا ذ إِشْثْ ڒْحَاجّثْ ذڭْ ؤُفُوسْ نّسْ. \x ◘ \xo 5:‏14 \xt إِزهد. 49‏:‏18\x*  
\v 15 ؤُڒَا ذ ثَا ذ إِشْثْ ن ثْمسْڒَاشْثْ ذ ثَاعفَّانْثْ: نِيشَانْ مَامّشْ إِ د-يُوسَا نتَّا، أَذْ يُويُورْ. مَانْ ڒفْضڒْ نّسْ \add خنِّي\add* إِ ونِّي إِمَارّْثنْ إِ ؤُسمِّيضْ \add وَاهَا\add*؟  
\v 16 عَاوذْ إِتّْغِيمَا إِتّتّْ ذِي ثَادْجسْثْ مَارَّا ؤُسَّانْ نّسْ أَمْ كمْڒنْ. إِتّْوَامَارّثْ \add س\add* ڒحْڒَاشْ نّسْ ذ ؤُذُوقّزْ نّسْ ن وغْضَابْ.   
\b  
\m
\v 17 خْزَارْ، مِينْ تّْوَاڒِيغْ ذ مَانْ أَيَا: أَقَا ذ لمْلِيحْ ؤُ إِشْنَا أَقَا \add إِجّْ\add* أَذْ إِشّْ، أَذْ إِسُو ؤُ أَذْ إِژَارْ مَارَّا ڒْخَارْ إِ مَارَّا أَمَارّثْ نّسْ إِ ؤُمِي إِتّْمَارَّاثْ \add بْنَاذمْ\add* سَاذُو ثَافُوشْثْ ذِي ڒْقدّْ ن وُوسَّانْ ن ثُوذَارْثْ إِ ذ أَسْ د-يَارْزفْ أَربِّي، مَاغَارْ ثَا ذ ثَاسْغَارْثْ نّسْ. \x ◘ \xo 5:‏17 \xt أَمب. 2‏:‏10، 24؛ 3‏:‏12، 22؛ 9‏:‏7؛ 11‏:‏9\x*   
\m
\v 18 عَاوذْ كُوڒْ بْنَاذمْ إِ ؤُمِي إِوْشَا أَربِّي أَڭْڒَا ذ ثْخُوبَايْ ؤُ إِ ؤُمِي إِوْشَا ثِيزمَّارْ مَاحنْذْ أَذْ زَّايسْ إِشّْ ؤُ أَذْ زَّايسْ يَارْبُو ثَاسْغَارْثْ نّسْ ؤُ أَذْ زَّايسْ إِفَارْحْ غَارْ ؤُمَارّثْ نّسْ، أَقَا-ت ذ ثَارْزفْثْ ن أَربِّي.  
\v 19 مَاغَارْ نتَّا وَارْ إِتِّيذَارْ \add عَاذْ\add* أَطَّاسْ ذڭْ وُوسَّانْ ن ثُوذَارْثْ نّسْ، مِينْزِي أَربِّي إِسْڒَا أَسْ ؤُمِي \add ذ أَسْ\add* إِوْشَا ڒفْرَاحثْ ذڭْ وُوڒْ نّسْ.   
\b  
\b  
\m  
\c 6
\s1 أَڭْڒَا نِّي زَّايْسنْ بَابْ نْسنْ وَارْ د-يَارّْ مژْرِي  
\m
\v 1 أَقَا ذِينْ إِجّْ نْ ڒْغَارْ نِّي ژْرِيغْ سَاذُو ثْفُوشْثْ نِّي إِمْسَارنْ أَطَّاسْ جَارْ إِوْذَانْ:  
\v 2 إِجّنْ يَارْزفْ أَسْ أَربِّي أَڭْڒَا ذ ثْخُوبَايْ ذ شَّانْ. أَقَا وَارْ إِتّْخصِّي وَالُو إِ ڒعْمَارْ نّسْ زِي مَارَّا مِينْ ذَايسْ ذ مژْرِي، \add مَاشَا\add* أَربِّي وَارْ ث إِجِّي أَذْ زَّايسْ إِشّْ، \add مَاغَارْ\add* إِجّْ ن ؤُبَارَّانِي أَذْ ث إِشّْ. أَقَا ؤُڒَا ذ مَانْ أَيَا ذِي ڒْبَاطڒْ ذ إِجّْ ن ڒْغَارْ ذ أَعفَّانْ.   
\m
\v 3 مَاڒَا إِجّْ ن ورْيَازْ يجّْ-د مْيَا ن إِحنْجِيرنْ ؤُ إِدَّارْ أَطَّاسْ ن إِسڭّْوُوسَا، أَڒَامِي ذوْڒنْ وُوسَّانْ ن ثُوذَارْثْ نّسْ ذڭْ وَاطَّاسْ، \add مَاشَا\add* ڒعْمَارْ نّسْ وَارْ إِجِّيونْ شَا س ڒْخَارْ ؤُ وَارْ إِتّْوِيفْ ونْضڒْ إِ نتَّا، نشّْ أَذْ إِنِيغْ: إِجّْ ن وغْرَايْ إِشْنَا أَسْ خْ نتَّا.  
\v 4 مَاغَارْ يُوسَا-د ذِي ڒْبَاطڒْ ؤُشَا إِفّغْ ذِي ثَادْجسْثْ ؤُ س ثَادْجسْثْ إِتّْوَاڒحّفْ إِسمْ نّسْ.  
\v 5 نتَّا عَاوذْ وَارْ إِژْرِي ثَافُوشْثْ ؤُ وَارْ ت إِسِّينْ. \add أَمُّو\add* غَارْ \add وغْرَايْ-أَ\add* ڒْهُوذْنثْ كْثَارْ خْ \add ورْيَازْ\add* نِّي، \x ◘ \xo 6:‏5 \xt أَيُوبْ 3‏:‏16؛ إِزهد. 58‏:‏9\x*  
\v 6 وَاخَّا نتَّا إِدَّارْ أَڒْفَاينْ ن إِسڭّْوُوسَا، \add مَاشَا\add* بْڒَا مَا أَذْ إِژَارْ ڒْخَارْ! مَا وَارْ إِڭُّورنْ كُوڒْ إِجّْ غَارْ ومْشَانْ ذ إِجّْ؟   
\m
\v 7 مَارَّا أَمَارّثْ ن بْنَاذمْ إِ ؤُقمُّومْ نّسْ، وَاخَّا أَمنِّيعمَّارْصْ وَارْ إِتّْشُّورِي ڒعْمَارْ نّسْ.  
\v 8 مَاغَارْ مَانْ ڒفْضڒْ إِ ؤُمِيغِيسْ خْ ؤُبُوهَاڒِي؟ \add مَانْ ڒفْضڒْ إِ\add* ؤُمزْڒُوضْ نِّي إِسّْننْ أَذْ يُويُورْ قِيبَاتْشْ إِ يِينِّي إِدَّارنْ؟  
\v 9 إِحْڒَا أَذْ ثژْرِيذْ مِينْ إِدْجَانْ زَّاثْ إِ ثِيطَّاوِينْ خْ وثْلَاعْ ن ڒعْمَارْ. ؤُڒَا ذ مَانْ أَيَا ذِي ڒْبَاطڒْ ذ وضْفَارْ ن ؤُسمِّيضْ.   
\m
\v 10 مِينْ مَا إِدْجَا شَا ن إِجّنْ، أَقَا إِسمْ نّسْ إِتّْوَاڒَاغَا قْبڒْ، ؤُ ثُوغَا إِتّْوَاسّنْ مِينْ غَا يِيڒِي بْنَاذمْ: نتَّا وَارْ إِزمَّارْ أَذْ إِمْشُوبّشْ أَكْ-ذ ونِّي خَاسْ إِجهْذنْ. \x ◘ \xo 6:‏10 \xt إِشا. 45‏:‏9؛ رُوم. 9‏:‏20. \x*  
\v 11 مَاغَارْ أَقَا ذِينْ أَطَّاسْ ن وَاوَاڒنْ نِّي يَارنّْينْ ذِي مِينْ إِدْجَانْ ذِي ڒْبَاطڒْ. مَانْ ڒفْضڒْ \add ن ؤُيَا\add* إِ بْنَاذمْ؟  
\v 12 مَاغَارْ وِي إِزمَّارنْ أَذْ إِسّنْ مِينْ إِحْڒَانْ إِ بْنَاذمْ ذِي ثُوذَارْثْ \add نّسْ\add* ذِي ڒْوقْثْ ن ڒْقدّْ ن وُوسَّانْ ن ثُوذَارْثْ \add نّسْ\add* إِفنَّانْ نِّي إِسّْعدُّو أَمْ ثِيڒِي؟ مَاغَارْ وِي إِزمَّارنْ أَذْ إِسّْشنْ إِ بْنَاذمْ مِينْ غَا إِمْسَارنْ أَوَارْنِي أَسْ سَاذُو ثْفُوشْثْ؟ \x ◘ \xo 6:‏12 \xt أَمب. 8‏:‏7؛ إِزهد. 144‏:‏4؛ يَاع. 4‏:‏13، 14\x*   
\b  
\b  
\m  
\c 7
\s1 ثَادَّارْثْ ن ڒفْرَاحثْ ذ ثَادَّارْثْ ن وشْضَانْ  
\m
\v 1 إِسمْ إِصْبحْ إِحْڒَا خْ زّشْثْ إِصبْحنْ، أَسّْ ن ڒْموْثْ \add إِحْڒَا\add* خْ وَاسّْ ن ثَارْوَا. \x ◘ \xo 7:‏1 \xt أَوڒن. 22‏:‏1\x*  
\v 2 ثحْڒَا ثْوَاحِيثْ غَارْ ثَادَّارْثْ ن وشْضَانْ خْ ثْوَاحِيثْ غَارْ ثَادَّارْثْ \add مَانِي تّْقدَّامنْ\add* إِشْثْ ن زَّارْذثْ، \add مِينْزِي ذِينْ\add* إِدْجَا قطُّو ن بْنَاذمْ مَارَّا، ؤُ ونِّي إِدَّارنْ إِتّڭّْ إِ-ت ذڭْ وُوڒْ نّسْ. \x ◘ \xo 7:‏2 \xt يُوح. 11‏:‏31\x*  
\v 3 إِحْڒَا وشْضَانْ خْ ثْذحَّاشْثْ، مَاغَارْ س إِجّْ ن ؤُغمْبُوبْ إِشضْننْ إِدَّاكّْوَاڒْ وُوڒْ حْسنْ.  
\v 4 ؤُڒْ ن إِمِيغِيسنْ \add أَقَا-ث\add* ذِي ثَادَّارْثْ ن وشْضَانْ، \add مَاشَا\add* ؤُڒْ نْ إِبُوهَاڒِييّنْ \add أَقَا-ث\add* ذِي ثَادَّارْثْ ن ڒفْرَاحثْ.   
\m
\v 5 إِحْڒَا أَذْ ثسْڒذْ غَارْ ؤُوبّخْ زڭْ إِمِيغِيسنْ خْ وسْحسِّي إِ يزْڒِي ن إِبُوهَاڒِييّنْ. \x ◘ \xo 7:‏5 \xt أَوڒن. 13‏:‏18؛ 15‏:‏31، 32\x*  
\v 6 مَاغَارْ أَمْ ؤُثَارْثكْ ن إِسنَّاننْ سَاذُو ؤُمقْرَاجْ، أَمُّو إِ ثڭَّا ثْضحَّاشْثْ ن ؤُبُوهَاڒِي. ؤُڒَا ذ مَانْ أَيَا أَقَا-ث ذِي ڒْبَاطڒْ. \x ◘ \xo 7:‏6 \xt إِزهد. 58‏:‏10\x*   
\b  
\m  
\s1 إِعْڒَامنْ  
\m
\v 7 مَاغَارْ ڒحْصَارثْ أَذْ ثسّْبُوهْڒِي أَمِيغِيسْ، ؤُ ثَارْزفْثْ \add ن أَرّشْوثْ\add* ثسّخْسَارَا ؤُڒْ.   
\m
\v 8 أَنڭَّارُو ن ثْمسْڒَاشْثْ ثحْڒَا خْ ؤُمزْوَارُو نّسْ. ونِّي غَارْ إِدْجَا تَّاسِيعْ نْ ڒْخَاضَارْ أَطَّاسْ إِحْڒَا خْ ؤُمْعفَّارْ.   
\m
\v 9 وَارْ سخّضْ ذغْيَا ذِي بُوحْبڒْ نّشْ، مَاغَارْ ذڭْ وحْسِينْ ن إِبُوهَاڒِييّنْ إِزدّغْ ؤُخيّقْ. \f ◼ \fr 7:‏9 \ft \+bd ’أَحْسِينْ‘\+bd* - نِيغْ ’أَبحْرُورْ‘.\f*   
\m
\v 10 وَارْ ثقَّارْ: ”مِينْ ثُوغَا \add ذِينْ\add*، أَقَا ؤُسَّانْ ن زِيشْ إِحْڒَانْ خْ مَامّشْ دْجَانْ وُوسَّانْ-أَ؟“ مَاغَارْ أَسقْسِي-يَا وَارْ \add إِزمَّارْ أَذْ إِفّغْ\add* زِي ثِيغِيثْ.   
\m
\v 11 ثِيغِيثْ إِ د-إِتَّاسنْ أَكْ-ذ ثسْغَارْثْ ثشْنَا، ؤُ \add ثِيغِيثْ\add* أَقَا ذ ڒفْضڒْ إِ يِينِّي إِتّْوَاڒَانْ ثَافُوشْثْ.   
\m
\v 12 مَاغَارْ أَمْ مَامّشْ ثِيغِيثْ ثدْجَا ذ ثَاسدَّارْثْ \add إِ ؤُسڒْقِي\add*، \add أَمُّو\add* ؤُڒَا ذ ثْمنْيَاثْ أَقَا أَثنْثْ ذ ثَاسدَّارْثْ \add إِ ؤُسڒْقِي\add*. ڒفْضڒْ ن ثُوسّْنَا أَقَا ثِيغِيثْ ثتِّيشْ ثُوذَارْثْ إِ أَيْثْبَابْ نّسْ.   
\m
\v 13 خْزَارْ مِينْ إِڭَّا أَربِّي، مَاغَارْ وِي إِزمَّارنْ أَذْ إِسڭّمْ مِينْ إِسّْفَارْغْ نتَّا؟   
\m
\v 14 أَرّْ مژْرِي س ڒْخَارْ ذڭْ وَاسّْ ن وفْڒَاحْ، \add مَاشَا\add* ذڭْ وَاسّْ ن أَرْژِييّثْ، خْزَارْ \add خنِّي\add*، مَاغَارْ أَربِّي إِڭَّا وَا ؤُڒَا ذ ثَا، حِيمَا بْنَاذمْ وَارْ إِزمَّارْ أَذْ يَافْ أَوَارْنِي أَسْ وَالُو. \f ◼ \fr 7:‏14 \ft \+bd ’أَوَارْنِي أَسْ‘\+bd* - مَانْ أَيَا إِخْسْ أَذْ يِينِي ’أَوَارْنِي إِ ڒْموْثْ نّسْ‘.\f*   
\b  
\m  
\s1 ؤُيُورْ خْ وبْرِيذْ ن ڒْوسْثْ  
\m
\v 15 مَارَّا أَيَا إِ ژْرِيغْ ذڭْ وُوسَّانْ \add ن ثُوذَارْثْ إِنُو\add* إِفنَّانْ. أَقَا ذِينْ أَمْسڭّذْ نِّي إِتّْوَاهلّْكنْ ذِي ثْسڭْذَا نّسْ ؤُشَا أَقَا ذِينْ أَعفَّانْ نِّي إِسّْزُوڭَّارْثنْ \add ؤُسَّانْ نّسْ\add* ذِي مَارَّا ثُوعفّْنَا نّسْ.  
\v 16 وَارْ تّڭّْ إِخفْ نّشْ ذ أَمْسڭّذْ أَطَّاسْ، ؤُ وَارْ تّڭّْ إِخفْ نّشْ ذ أَمِيغِيسْ أَطَّاسْ. مَايمِّي غَا ثَاردّْدْجذْ إِخفْ نّشْ؟  
\v 17 وَارْ تِّيڒِي ذ أَعفَّانْ أَطَّاسْ ؤُ وَارْ تِّيڒِي عَاوذْ ذ أَبُوهَاڒِي أَطَّاسْ. مَايمِّي غَا ثمّْثذْ مَاڒَا وَارْ د-يِيوِيضْ عَاذْ ڒْمِيجَاڒْ نّشْ؟  
\v 18 مْلِيحْ مَاڒَا شكْ ثْشبَّارذْ ذِي ثَا، \add أَمْ\add* وَارْ يَارخُّو ؤُفُوسْ نّشْ ذِي ثِينْ، مَاغَارْ ونِّي إِتّڭّْوذنْ أَربِّي، أَذْ إِتّْوَافكّْ زِي مَارَّا أَيَا.   
\m
\v 19 ثِيغِيثْ ثسّجْهذْ أَمِيغِيسْ \add خْ\add*عشْرَا ن أَيْثْ ن بُو-صُّولْطَا نِّي إِدْجَانْ ذڭْ إِشْثْ ن ثنْذِينْثْ.   
\m
\v 20 وَاهْ نِيشَانْ، وَارْ إِدْجِي ؤُڒَا ذ إِجّْ ن بْنَاذمْ ذ أَمْسڭّذْ خْ ثمُّورْثْ، \add ؤُڒَا ذ إِجّْ\add* إِتّڭّْ ڒْخَارْ ؤُ وَارْ إِخطِّي شَا. \x ◘ \xo 7:‏20 \xt 1 إِج. 8‏:‏46، 47؛ 2 إِم. 6‏:‏36؛ أَوڒن. 20‏:‏9؛ 1 يُوح. 1‏:‏8؛ رُوم. 3‏:‏10‏-‏12\x*   
\m
\v 21 وَارْ تِّيشْ ثَايْنِيثْ نّشْ إِ مَارَّا أَوَاڒنْ نِّي قَّارنْ إِوْذَانْ، حِيمَاعمَّارْصْ وَارْ ثتّسْڒِيذْ أَقَا أَمْسخَّارْ نّشْ أَذْ شكْ إِنْعڒْ.  
\v 22 مَاغَارْ ؤُڒْ نّشْ يُوشَا أَطَّاسْ ن ثْوَاڒَاوِينْ، أَقَا ؤُڒَا ذ شكْ ثْنعْڒذْ إِنّغْنِي.   
\b  
\m  
\s1 ثَارزُّوثْ ذ ثِيذتّْ ثِيوِي-د بْنَاذمْ غَارْ أَربِّي  
\m
\v 23 مَارَّا أَيَا بقّْشغْ ث س ثِيغِيثْ. نشّْ نِّيغْ: ”خْسغْ أَذْ كسْبغْ ثِيغِيثْ!“، \add مَاشَا\add* ثِيغِيثْ ثقِّيمْ أَيِي غَارْ ڒَاڭّْوَاجْ.  
\v 24 \add مَاغَارْ\add* مِينْ إِڭّْوجنْ ذ مِينْ يُودْجْغنْ، \add وَاهْ،\add* يُودْجْغنْ، مَانْ ونْ إِزمَّارنْ أَذْ ث يَافْ؟  
\v 25 نّْقڒْبغْ، ؤُڒَا ذ ؤُڒْ إِنُو \add أَكِيذِي\add*، مَاحنْذْ أَذْ أَفغْ ثُوسّْنَا، مَاحنْذْ أَذْ بقّْشغْ، أَذْ أَرْزُوغْ ثِيغِيثْ ذ ونْوَايْ \add إِ ذَايسْ\add*، مَاحنْذْ أَذْ سّْنغْ \add س ثِيذتّْ\add* أَقَا ڒْغَارْ ذ ثَاغْيُوڒِي ؤُ ثَاغْيُوڒِي \add ذَايسْ\add* أَطمّسْ أَطَّاسْ. \x ◘ \xo 7:‏25 \xt أَمب. 1‏:‏17؛ 2‏:‏12\x*   
\m
\v 26 ؤُفِيغْ مِينْ إِدْجَانْ ذ أَمرْزَاڭْ خْ ڒْموْثْ: ثَامْغَارْثْ \add ثنِّي إِدْجَانْ أَمْ\add* ثْرَاشَّاوِينْ ؤُ ؤُڒْ نّسْ \add أَمشْنَاوْ\add* ڒفْخُوخْ \add إِنقّنْ\add* ؤُ إِفَاسّنْ نّسْ \add أَمشْنَاوْ\add* إِشذِّييّنْ. ونِّي يَارْضَانْ زَّاثْ إِ وُوذمْ ن أَربِّي، إِزمَّارْ أَذْ زَّايسْ إِنْفكّْ، \add مَاشَا\add* أَمذْنُوبْ أَذْ زَّايسْ إِمْخُومْبرْ. \x ◘ \xo 7:‏26 \xt أَوڒن. 5‏:‏3؛ 6‏:‏24‏-‏35؛ 7‏:‏6‏-‏27؛ 22‏:‏14\x*   
\m
\v 27 خْزَارْ، أَيَا إِ ؤُفِيغْ، إِقَّارْ ؤُمْبَارّحْ، \add ؤُمِي أَرنْيغْ\add* إِشْثْ \add ن ڒْحَاجّثْ\add* إِ يِيشْثنْ \add نّغْنِي\add* مَاحنْذْ \add أَمُّو إِ\add* غَا يَافغْ ڒْحَاسُوڒْ \add نّسْ\add*:  
\v 28 مِينْ ثُوغَا يَارزُّو ڒعْمَارْ إِنُو عَاذْ، \add مَاشَا\add* وَارْ ث ؤُفِيغْ. \add وَاهْ\add* ؤُفِيغْ إِجّْ ن ورْيَازْ ذڭْ وَاڒفْ، \add مَاشَا\add* إِشْثْ ن ثمْغَارْثْ وَارْ ت ؤُفِيغْ جَارْ مَارَّا يِينَا.  
\v 29 خْزَارْ، إِشْثْ وَاهَا إِ ؤُفِيغْ، أَقَا أَربِّي إِڭَّا بْنَاذمْ نِيشَانْ، \add مَاشَا\add* نِيثْنِي أَرْزُونْ ذڭْ وَاطَّاسْ ن يبْرِيذنْ إِحْرَايْميّنْ.   
\b  
\b  
\m  
\c 8
\s1 ثِيغِيثْ ثطَّاعْ  
\m
\v 1 وِي إِدْجَانْ أَمْ ؤُمِيغِيسْ ؤُ وِي إِسّْننْ أَذْ إِفكّْ إِشْثْ ن ثْمسْڒَاشْثْ؟ ثِيغِيثْ ن بْنَاذمْ ثتَّارَّا أَغمْبُوبْ نّسْ إِتّْنوَّارْ ؤُشَا ثْبدّڒْ \add ثِيفْرَاسْ\add* ن ڒقْسحْ ن ؤُغمْبُوبْ نّسْ. \f ◼ \fr 8:‏1 \ft \+bd ’أَذْ إِفكّْ‘\+bd* - س ثْعِيبْرَانِيثْ ’أَذْ إِسّنْ‘.\f*  
\v 2 نشّْ \add قَّارغْ\add*: ”حْضَا أَضبَّارْ ن ؤُجدْجِيذْ!“ ؤُ \add مَانْ أَيَا\add* ذِي سِّيبّثْ ن ثْجَادْجِيثْ ن أَربِّي. \x ◘ \xo 8:‏2 \xt أَوڒن. 24‏:‏21\x*  
\v 3 وَارْ تِّيڭّْوِيجْ س ثَازْڒَا خْ وُوذمْ نّسْ، وَارْ تّڭّْ أَزدْجِيفْ نّشْ ذِي ثْمسْڒَاشْثْ ثَاعفَّانْثْ، مَاغَارْ نتَّا إِڭَّا مَارَّا مِينْ خفْ يَارْضَا.  
\v 4 أَوَاڒْ ن ؤُجدْجِيذْ ذَايسْ صُّولْطَا ثمْغَارْ. مَانْ ونْ إِزمَّارنْ أَذْ أَسْ يِينِي: ”مِينْ ثتّڭّذْ شكْ؟“   
\m
\v 5 ونِّي إِحطَّانْ ثَاوْصيّثْ، وَارْ ث إِڒقّفْ \add وَالُو ن\add* مِينْ إِدْجَانْ ذ أَعفَّانْ. ؤُڒْ ن ؤُمِيغِيسْ إِسّنْ ڒْحَاڒْ ذ ڒْحُوكْمْ. \x ◘ \xo 8:‏5 \xt رُوم. 13‏:‏3\x*  
\v 6 مَاغَارْ إِ كُوڒْ أَنْوَايْ إِجّْ ن ڒْحَاڒْ ذ إِجّْ ن ڒْحُوكْمْ، مَاغَارْ ثُوعفّْنَا ن بْنَاذمْ ثسّذْقَاڒْ إِ-ث.   
\m
\v 7 مَاغَارْ نتَّا وَارْ إِسِّينْ مِينْ غَا إِمْسَارنْ، مَاغَارْ مَانْ ونْ إِ ذ أَسْ ث إِ غَا إِسّْشْننْ مَامّشْ غَا يِيڒِي أَيَا؟ \x ◘ \xo 8:‏7 \xt أَمب. 6‏:‏12\x*  
\v 8 وَارْ \add ذِينْ\add* إِدْجِي ؤُڒَا ذ إِجّْ ن بْنَاذمْ إِزمَّارْ خْ ؤُسُوضِي ن ؤُسمِّيضْ أَڒَامِي إِزمَّارْ أَذْ خَاسْ إِبلّعْ. وَارْ \add ذِينْ\add* إِدْجِي ؤُڒَا ذ إِجّْ غَارسْ صُّولْطَا خْ وَاسّْ ن ڒْموْثْ، ؤُ وَارْ \add ذِينْ\add* إِدْجِي ؤُڒَا ذ إِجّْ إِزمَّارْ أَذْ إِكْسِي تّسْرِيحْ ذڭْ ؤُمنْغِي، ؤُ ثُوعفّْنَا وَارْ ثجِّي أَذْ نجْمنْ أَيْثْبَابْ نّسْ. \x ◘ \xo 8:‏8 \xt أَيُوبْ 14‏:‏5؛ إِزهد. 39‏:‏6\x*  
\v 9 مَارَّا أَيَا ژْرِيغْ ث، ؤُمِي سّنْقڒْبغْ ؤُڒْ إِنُو غَارْ مَارَّا مِينْ إِتّْوَاڭّنْ سَاذُو ثْفُوشْثْ، ذِي ڒْوقْثْ ڒَامِي إِصلّطْ بْنَاذمْ خْ بْنَاذمْ نّغْنِي إِ ذْرُوشْثْ نّسْ.   
\b  
\m  
\s1 ثَاسڭْذَا ن أَربِّي أَقَا-ت ثْنُوفَّارْ  
\m
\v 10 أَمُّو إِ ژْرِيغْ إِعفَّاننْ نِّي ثُوغَا إِتّْوَانضْڒنْ، ؤُذْفنْ \add غَارْ ونْضڒْ\add*، \add ؤُمِي\add* يِينِّي إِڭِّينْ مِينْ إِدْجَانْ نِيشَانْ فّْغنْ زڭْ ومْشَانْ أَمْقدَّاسْ، تّْوَاتُّونْ ذِي ثنْذِينْثْ. ؤُڒَا ذ مَانْ أَيَا ذِي ڒْبَاطڒْ.  
\v 11 مَاغَارْ ڒْحُوكْمْ خْ ثْعفَّانْثْ وَارْ إِتّْوَاڭّْ ذغْيَا، خْ ؤُيَا إِشُّورْ وُوڒْ ن ثَارْوَا ن بْنَاذمْ مَاحنْذْ أَذْ ڭّنْ مِينْ إِدْجَانْ ذ أَعفَّانْ.  
\v 12 وَاخَّا أَمذْنُوبْ إِتّڭّْ ثَاعفَّانْثْ مْيَا ن ثْوَاڒَاوِينْ ؤُ إِدَّارْ أَطَّاسْ، وَاخَّا أَمنِّي سّْنغْ أَقَا إِنِّي إِتّڭّْوذنْ أَربِّي أَذْ فڒْحنْ، إِنِّي زَّايسْ إِتّڭّْوذنْ. \x ◘ \xo 8:‏12 \xt إِزهد. 37‏:‏9، 10، 11، 12، 18، 19، 20؛ أَوڒن. 1‏:‏33؛ إِشا. 3‏:‏10\x*  
\v 13 أَعفَّانْ \add مَاشَا\add* وَارْ إِتِّيڒِي مْلِيحْ ؤُ وَارْ غَارسْ ثتِّيڒِي ثُوذَارْثْ ذ ثَازِيرَارْثْ. نتَّا أَذْ يِيڒِي أَمْ ثِيڒِي، مَاغَارْ وَارْ إِتّڭّْوذْ أَربِّي.   
\m
\v 14 أَقَا ذِينْ شَا مِينْ إِتّْوَاڭّنْ خْ ثمُّورْثْ نِّي إِدْجَانْ ذِي ڒْبَاطڒْ: أَقَا ذِينْ إِمْسڭَّاذنْ إِتّمّْسَارْ أَسنْ أَخْمِي تّڭّنْ أَمْ يِيعفَّاننْ، ؤُ أَقَا ذِينْ إِعفَّاننْ إِتّمْسَارْ أَسنْ أَخْمِي تّڭّنْ ثَاسڭْذَا. نشّْ نِّيغْ: ؤُڒَا ذ مَانْ أَيَا ذِي ڒْبَاطڒْ.  
\v 15 س ؤُينِّي إِ تّْصبَّاحغْ ڒفْرَاحثْ، مَاغَارْ وَارْ ذِينْ إِدْجِي إِ بْنَاذمْ مِينْ إِدْجَانْ حْسنْ \add ذِي ثُوذَارْثْ نّسْ\add* سَاذُو ثْفُوشْثْ مْغِيرْ مَاڒَا نتَّا إِتّتّْ، إِسسّْ ؤُ إِفَارّحْ. إِڒِي أَيَا أَذْ ث إِعَاشَارْ ذڭْ ؤُمَارّثْ نّسْ ذِي مَارَّا ؤُسَّانْ ن ثُوذَارْثْ نّسْ إِ ذ أَسْ يَارْزفْ أَربِّي سَاذُو ثْفُوشْثْ. \x ◘ \xo 8:‏15 \xt أَمب. 2‏:‏24؛ 3‏:‏12، 22؛ 5‏:‏18؛ 9‏:‏7\x*   
\m
\v 16 ؤُمِي ثُوغَا ڭِّيغْ ؤُڒْ إِنُو مَاحنْذْ أَذْ سّْنغْ ثِيغِيثْ ؤُ مَاحنْذْ أَذْ خْزَارغْ مَانْ ثَاسبَّابْثْ إِ إِڭُّورنْ خْ ثمُّورْثْ - مَاغَارْ أَمْ س وَاسّْ أَمْ س دْجِيڒثْ بْنَاذمْ وَارْ إِتِّيشْ شَا أَرَّاحثْ إِ ثِيطَّاوِينْ نّسْ -  
\v 17 ژْرِيغْ مَارَّا مِينْ إِڭَّا أَربِّي، أَقَا بْنَاذمْ وَارْ إِزمَّارْ أَذْ يَافْ مِينْ إِتّْوَاڭّنْ، \add إِخْسْ أَذْ يِينِي\add* مِينْ إِتّْوَاڭّنْ سَاذُو ثْفُوشْثْ. مَاغَارْ مَامّشْ إِ غَا إِمَارّثْ بْنَاذمْ أَمْ يَارزُّو، وَارْ إِتِّيفْ وَالُو. وَاخَّا أَمِيغِيسْ أَذْ يِينِي بلِّي نتَّا إِسّنْ، نتَّا وَارْ إِزمَّارْ مَاشَا أَذْ ث يَافْ.   
\b  
\b  
\m  
\c 9
\s1 بْنَاذمْ وَارْ إِزمَّارْ أَذْ إِحْكمْ ثَاسْغَارْثْ نّسْ  
\m
\v 1 مَاغَارْ نشّْ ڭِّيغْ مَارَّا أَيَا غَارْ وُوڒْ إِنُو، مَاحنْذْ أَذْ أَرْزُوغْ ذِي مَارَّا أَيَا، أَقَا إِمْسڭَّاذنْ ذ إِمِيغِيسنْ ذ ثْمڭَّا نْسنْ ذڭْ ؤُفُوسْ ن أَربِّي. ثَايْرِي ذ وشْرَاهْ وَارْ ثنْ إِسِّينْ بْنَاذمْ، أَقَا مَارَّا إِدْجَا زَّاثسْ.  
\v 2 مَارَّا \add إِدْجَا\add* أَمْ مَامّشْ \add إِدْجَا\add* غَارْ مَارَّا: ثِيرَا ذ إِشْثْ ثْڒقّفْ أَمْسڭّذْ ذ ؤُعفَّانْ، أَمْ ؤُصبْحَانْ ذ ؤُمزْذَاڭْ أَمْ ؤُمخْمُوجْ، ونِّي إِقدّْمنْ ثَاغَارْصْثْ ذ ونِّي وَارْ إِقدّْمنْ ثَاغَارْصْثْ، أَصبْحَانْ ذ ؤُمذْنُوبْ، ونِّي إِتّْجَّادْجَانْ ذ ونِّي إِتّڭّْوذنْ مَاحنْذْ أَذْ إِجَّادْجْ. \x ◘ \xo 9:‏2 \xt إِزهد. 73‏:‏12، 13\x*  
\v 3 مَانْ أَيَا ذ إِجّْ ن ڒْغَارْ غَارْ مَارَّا مِينْ إِمْسَارنْ سَاذُو ثْفُوشْثْ، أَقَا مَارَّا \add إِوْذَانْ\add* إِڒْقفْ إِ-ثنْ ثِيرَا ذ إِشْثْ، ؤُشَا ؤُڒَا ؤُڒْ نْ ثَارْوَا ن بْنَاذمْ إِشُّورْ س ڒْغَارْ، ؤُ أَقَا ذِينْ أَطمّسْ ذڭْ وُوڒْ نْسنْ ذِي ڒْوقْثْ ن ثُوذَارْثْ نْسنْ، ؤُ أَوَارْنِي إِ ؤُيَا \add أَذْ ؤُيُورنْ نِيثْنِي\add* غَارْ إِمتِّيننْ.  
\v 4 مَاغَارْ إِ ونِّي إِقّْننْ إِ مَارَّا إِنِّي إِدَّارنْ أَقَا ذِينْ أَسِيثمْ، مِينْزِي ڒْحَاڒْ إِ وقْزِينْ إِدَّارنْ حْسنْ زِي \add ڒْحَاڒْ\add* إِ ويْرَاذْ إِمُّوثنْ.  
\v 5 مَاغَارْ إِنِّي إِدَّارنْ سّْننْ، أَقَا نِيثْنِي أَذْ مّْثنْ، \add مَاشَا\add* إِمتَّانْ وَارْ سِّيننْ وَالُو قَاعْ. نِيثْنِي وَارْ تّطّْفنْ وَالُو زِي ڒْمُونثْ، مَاغَارْ ڒِيذَارثْ خَافْسنْ ثتّْوَاتُّو.  
\v 6 أَقَا ثَايْرِي نْسنْ ذ وشْرَاهْ نْسنْ ذ ثُوسْمِي نْسنْ فْنَانْ. إِ ڒبْذَا وَارْ غَارْسنْ بُو ثسْغَارْثْ عَاذْ ذِي مَارَّا مِينْ إِتّمْسَارنْ سَاذُو ثْفُوشْثْ.   
\m
\v 7 ؤُيُورْ \add خنِّي\add*، إِوَا أشّْ س ڒفْرَاحثْ أَغْرُومْ نّشْ، سُو س وُوڒْ إِفَارْحنْ بِينُو نّشْ، مَاغَارْ إِعْجبْ أَسْ إِ أَربِّي ثِيمڭَّا نّشْ أَطَّاسْ زڭْ وَامِي.  
\v 8 أجّْ أَذْ يِيڒِي أَرُّوضْ نّشْ ذ أَشمْڒَاڒْ ڒبْذَا ؤُعمَّارْصْ وَارْ إِتّْخصِّي زّشْثْ خْ ؤُزدْجِيفْ نّشْ.  
\v 9 بَارّعْ خْ ثُوذَارْثْ أَكْ-ذ ثمْغَارْثْ نِّي ثتّخْسذْ، مَارَّا ؤُسَّانْ ن ثُوذَارْثْ نّشْ إِفنَّانْ نِّي ذ أَسْ إِوْشَا أَربِّي سَاذُو ثْفُوشْثْ، مَاڒَا ؤُسَّانْ ن لْحَاضَارْ نّشْ إِفنَّانْ ذَانِيثَا، مَاغَارْ ثَا ذ ثَاسْغَارْثْ نّشْ ذِي ثُوذَارْثْ-أَ ؤُ غَارْ ؤُمَارّثْ إِ زِي ثْمَارّْثذْ سَاذُو ثْفُوشْثْ.  
\v 10 مَارَّا مِينْ غَا يَافْ ؤُفُوسْ نّشْ مَاحنْذْ أَذْ ث يڭّْ، أڭّْ إِ-ث عْلَاحْسَابْ جّهْذْ نّشْ، مَاغَارْ وَارْ إِدْجِي ذِي ڒَاخَارْثْ مَانِي غَا ثُويُورذْ مِينْ غَا ثڭّذْ، نِيغْ أَخَارّصْ نِيغْ ثُوسّْنَا ؤُڒَا ذ ثِيغِيثْ.   
\m
\v 11 عَاوذْ ژْرِيغْ سَاذُو ثْفُوشْثْ أَقَا أَيْثْ ن بُو-ثَازْڒَا وَارْغدْجْبنْ \add ڒبْذَا\add* ذِي حَامَاثْ، نِيغْ أَيْثْ ن بُو-ثغْرُوضْثْ \add ڒبْذَا\add* ذڭْ ؤُمنْغِي، ؤُ إِمِيغِيسنْ وَارْ غَارْسنْ إِدْجِي وغْرُومْ \add ڒبْذَا\add* ؤُ يِينِّي س ڒعْقڒْ وَارْ غَارْسنْ إِدْجِي وَاڭْڒَا \add ڒبْذَا\add*، ؤُڒَا ذ إِنِّي س ڒفْهَامثْ وَارْ غَارْسنْ إِدْجِي أَرْضَا \add ڒبْذَا\add*، مَاغَارْ ڒْحَاڒْ ذ ثِيرَا ڒقّْفنْ ؤُڒَا ذ مَارَّا نِيثْنِي.  
\v 12 مَاغَارْ بْنَاذمْ وَارْ إِسِّينْ ڒْمِيجَاڒْ نّسْ، أَمْ يِيسڒْمَانْ إِنْحصْرنْ ذِي ثْرَاشَّا ن أَرْژِييّثْ، ؤُ أَمْ يِيجْضَاضْ إِنّْحصْرنْ ذِي ڒْفخْ. أَمُّو ؤُڒَا ذ ثَارْوَا ن بْنَاذمْ تّْوَاطّْفنْ ذِي ڒْفخْ ذڭْ إِشْثْ ن ڒْوقْثْ ذ ثَاعفَّانْثْ، خْمِي خَاسنْ د-ثْوطَّا \add ثْرَاشَّا\add* ذغْيَا.   
\b  
\m  
\s1 ثِيغِيثْ وَارْ غَارسْ بُو ؤُوقَّارْ  
\m
\v 13 ؤُڒَا ذ مَانْ أَيَا بْذِيغْ أَذْ ذَايسْ ژْرِيغْ ثِيغِيثْ سَاذُو ثْفُوشْثْ، ثُوسَا أَيِي-د ذ ثَامقّْرَانْثْ أَطَّاسْ.  
\v 14 ثُوغَا ذِينْ إِشْثْ ن ثنْذِينْثْ ذ ثَامژْيَانْثْ ذَايسْ ذْرُوسْ ن يوْذَانْ \add وَاهَا\add*. إِفّغْ خَاسْ إِجّْ ن ؤُجدْجِيذْ ذ أَمقّْرَانْ، إِحوّسْ إِ-ت، ؤُ إِسّْبدّْ خَاسْ لْبَارَاجَاثْ ثِيمقّْرَانِينْ.  
\v 15 إِتّْوَافّْ ذَايسْ إِجّْ ن ورْيَازْ ذ أَمزْڒُوضْ ذ أَمِيغِيسْ ونِّي إِفكّنْ ثَانْذِينْثْ س ثِيغِيثْ نّسْ، \add مَاشَا\add* ؤُڒَا ذ إِجّْ ن بْنَاذمْ إِعْقڒْ \add عَاذْعمَّارْصْ\add* خْ ورْيَازْ نِّي.  
\v 16 \add خنِّي\add* نِّيغْ نشّْ: ”ثِيغِيثْ ثحْڒَا خْ جّْهذْ!“، وَاخَّا ثتّْوَاسّحْقَارْ ثِيغِيثْ ن ؤُمزْڒُوضْ ؤُ أَوَاڒنْ نّسْ وَارْ ثتّْوَاسْڒنْ. \x ◘ \xo 9:‏16 \xt أَوڒن. 21‏:‏22؛ 24‏:‏5؛ أَمب. 7‏:‏19\x*   
\m
\v 17 أَوَاڒنْ ن إِمِيغِيسنْ نِّي غَارْ تّسْڒَانْ \add إِوْذَانْ\add* ذِي ڒْهُوذْنثْ، حْسنْ زڭْ ؤُغُويِّي نْ ڒْحَاكمْ جَارْ إِبُوهَاڒِييّنْ.  
\v 18 ثِيغِيثْ ثحْڒَا خْ ڒسْنَاحْ ن ؤُمنْغِي، \add مَاشَا\add* إِجّْ ن ؤُمذْنُوبْ \add وَاهَا\add* إِهدّمْ أَطَّاسْ.   
\b  
\b  
\m  
\c 10
\s1 أَقَارِّي ن ثُوبُّوهڒْيَا  
\m
\v 1 إِزَانْ إِنقّنْ تَّارَّانْ زّشْثْ ن وذْهَانْ ن ؤُعطَّارْ أَذْ ثَارْصُوضْ ؤُ أَذْ ثسْممْ. ذْرُوسْ ن ثُوبُّوهڒْيَا ثْوزّنْ أَطَّاسْ خْ ثِيغِيثْ ذ شَّانْ.  
\v 2 ؤُڒْ ن ؤُمِيغِيسْ أَقَا-ث \add إِ نتَّا\add* أَفُوسْ نّسْ أَفُوسِي، \add مَاشَا\add* ؤُڒْ ن ؤُبُوهَاڒِي \add إِ وَانِيثَا\add* أَفُوسْ نّسْ أَزڒْمَاضْ.  
\v 3 ؤُڒَا ذڭْ وبْرِيذْ مِينْ خفْ إِڭُّورْ ؤُبُوهَاڒِي، ؤُڒْ نّسْ وَارْ إِمْثِينْ، إِقَّارْ إِ مَارَّا أَقَا نتَّا ذ أَبُوهَاڒِي.  
\v 4 مَاڒَا خَاكْ إِخيّقْ بُوحْبڒْ ن بُو-جّهْذْ، وَارْ تّڭّْوِيجْ خْ ومْشَانْ نّشْ، مَاغَارْ مَانْ أَيَا ذ دّْوَا، يَارسَّا دّْنُوبْ إِمقّْرَاننْ.   
\m
\v 5 أَقَا ذِينْ إِجّْ نْ ڒْغَارْ نّغْنِي نِّي ژْرِيغْ سَاذُو ثْفُوشْثْ، أَقَا-ث ذ إِجّْ ن ؤُودَّارْ إِ د-إِفّْغنْ زڭْ إِجّْ ن بُو-صُّولْطَا:  
\v 6 أَسْڭعَّاذْ أَطَّاسْ ن ثُوبُّوهڒْيَا، \add أَمْ\add* تّْغِيمَانْ أَيْثْ ن بُو-وَاڭْڒَا سْوَادَّايْ.  
\v 7 نشّْ ژْرِيغْ إِمْسخَّارنْ نْيِينْ خْ ييْسَانْ ؤُڒَا ذ ڒْحُوكَّامْ نِّي إِڭُّورنْ أَمْ يِيمْسخَّارنْ \add خْ إِضَارنْ نْسنْ\add* خْ ثمُّورْثْ.   
\b  
\m
\v 8 ونِّي إِتّقَّازنْ أَحْفُورْ، أَذْ ذَايسْ إِوْضَا \add س يِيخفْ نّسْ\add*، ونِّي إِسّْنُوقّْبنْ ڒْحِيضْ، إِزمَّارْ أَذْ أَسْ إِقّسْ ؤُفِيغَارْ. \x ◘ \xo 10:‏8 \xt أَوڒن. 26‏:‏27\x*   
\m
\v 9 ونِّي إِكّْسنْ إِژْرَا، أَذْ \add زَّايْسنْ\add* إِيْزمْ \add إِخفْ نّسْ\add*، ونِّي إِتّْفتّْقنْ أَكشُّوضْ، أَذْ يِيڒِي ذِي لْخَاطَارْ.   
\m
\v 10 مَاڒَا ؤُزَّاڒْ \add ن شَّاقُورْ\add* إِذْوڒْ إِحْفَا ؤُ \add بَابْ نّسْ\add* وَارْ ث إِسّقْضعْ، خنِّي إِتّْخصَّا أَسْ جّْهذْ كْثَارْ، \add مَاشَا\add* ثِيغِيثْ ثشْنَا أَطَّاسْ حِيمَا أَذْ إِفْڒحْ بْنَاذمْ.  
\v 11 مَاڒَا إِزْعفْ ؤُفِيغَارْ قْبڒْ أَعزّمْ، وَارْ ذِينْ ڒفْضڒْ إِ ؤُعزَّامْ.   
\b  
\m
\v 12 أَوَاڒنْ زڭْ ؤُقمُّومْ ن ؤُمِيغِيسْ ذَايْسنْ أَرْضَا، \add مَاشَا\add* إِينْشِيشنْ ن ؤُبُوهَاڒِي صَارْضنْ ث سِيمَانْثْ نّسْ.  
\v 13 بدُّو ن وَاوَاڒنْ زڭْ ؤُقمُّومْ نّسْ ذ ثُوبُّوهڒْيَا ؤُ أَنڭَّارُو ن مِينْ د-إِفّْغنْ زڭْ ؤُقمُّومْ نّسْ ذ أَطمّسْ أَعفَّانْ.  
\v 14 أَبُوهَاڒِي إِتّْكتَّارْ ڒْهَارْذْ أَطَّاسْ، مَاشَا بْنَاذمْ وَارْ إِسِّينْ مِينْ غَا إِمْسَارنْ، ؤُ مِينْ غَا إِمْسَارنْ أَوَارْنِي أَسْ، وِي ذ أَسْ ث إِ غَا إِعَاوْذنْ؟  
\v 15 أَمَارّثْ ن إِبُوهَاڒِييّنْ إِتَّارَّا إِ-ثنْ ؤُحْڒنْ، مَاغَارْ نِيثْنِي وَارْ سِّيننْ مَامّشْ غَا يُويُورنْ غَارْ ثنْذِينْثْ.   
\b  
\m
\v 16 ؤُشْثْ خَامْ، \add أَ\add* ثَامُّورْثْ، مَاڒَا أَجدْجِيذْ نّمْ ذ أَحنْجِيرْ \add عَاذْ\add*، ؤُ ڒْحُوكَّامْ نّمْ غَارْ ثفُّوثْ تّتّنْ! \x ◘ \xo 10:‏16 \xt إِشا. 3‏:‏3، 4؛ حُوش. 13‏:‏11؛ عَام. 6‏:‏4\x*  
\v 17 سّعْذْ نّمْ، \add أَ\add* ثَامُّورْثْ، مَاڒَا أَجدْجِيذْ نّمْ ذ مِّيسْ ن ثَارْوَا ن ثَاصِيڒثْ، ؤُ ڒْحُوكَّامْ نّمْ تّتّنْ غَارْ ڒْوقْثْ إِتّْوَاڭّنْ، مَاحنْذْ أَذْ تّْوَامحْذنْ، وَارْ إِدْجِي مَاحنْذْ أَذْ سْكَارنْ.   
\m
\v 18 س ڒعْڭزْ إِ هكّْوَانْثْ ثِيحنْيَا ؤُ س إِفَاسّنْ يَارهْفنْ أَذْ ثُوذُومْ ثَادَّارْثْ.  
\v 19 \add بْنَاذمْ\add* إِتّڭّْ أَغْرُومْ مَاحنْذْ أَذْ إِضْحشْ، بِينُو إِسّْفَارَّاحْ إِنِّي إِدَّارنْ ؤُ ثْمنْيَاثْ نفّْعنْثْ إِ مَارَّا مِينْ إِدْجَانْ.   
\m
\v 20 وَارْ نعّڒْ أَجدْجِيذْ \add عَاذْ\add* ذِي ڒْبَاڒْ نّشْ، ذڭْ وخَّامْ ن يِيضصْ وَارْ نعّڒْ بُو-وَاڭْڒَا، مَاغَارْ إِجْضَاضْ ن ؤُجنَّا زمَّارنْ أَذْ سُّويُورنْ ڒْحسّْ \add ن وَاوَاڒنْ نّشْ\add* ؤُ \add أَمُّو مَارَّا\add* وِي غَارْ دْجَانْ وَافْرِيونْ إِزمَّارْ أَذْ إِسّعْذُو أَوَاڒْ. \x ◘ \xo 10:‏20 \xt ؤُف. 22‏:‏28\x*   
\b  
\b  
\m  
\c 11
\s1 إِخَارِّيصنْ وَارْ زمَّارنْ أَذْ بضْڒنْ ڒْخذْمثْ  
\m
\v 1 سكّْ أَغْرُومْ نّشْ ثِيوَا إِ وَامَانْ، مَاغَارْ أَوَارْنِي إِ أَطَّاسْ ن وُوسَّانْ أَذْ ث ثَافذْ \add عَاوذْ\add*.  
\v 2 بْضَا ث ذِي سبْعَا نِيغْ عَاذْ ذِي ثْمنْيَا، مَاغَارْ شكْ وَارْ ثسِّينذْ مَانْ ڒْغَارْ إِ غَا يِيڒِينْ ذِي ثمُّورْثْ. \x ◘ \xo 11:‏2 \xt 2 كُور. 9‏:‏10\x*   
\m
\v 3 مَاڒَا شُّورنْ إِسيْنُوثنْ، تّْزدْجَاعنْ أَنْژَارْ خْ ثمُّورْثْ. مَا ثَاشجَّارْثْ ثوْضَا غَارْ لْجَانُوبْ نِيغْ غَارْ شَّامَالْ، ذڭْ ومْشَانْ مَانِي ثوْضَا، ثتّْغِيمَا ذِينْ \add ثزّڒْ\add*. \f ◼ \fr 11:‏3 \ft \+bd ’ثَاشجَّارْثْ‘\+bd* - نِيغْ ’أَدَّاڭْ‘ (’إِدَّاڭنْ‘).\f*   
\m
\v 4 ونِّي إِخزَّارنْ ڒبْذَا غَارْ ؤُسمِّيضْ، وَارْ إِتِّيوِيضْ أَذْ إِزَارْعْ، ونِّي إِحطَّانْ ڒبْذَا إِسيْنُوثنْ، وَارْ إِتِّيوِيضْ أَذْ إِمْجَارْ.   
\m
\v 5 أَمْ مَامّشْ شكْ وَارْ ثسِّينذْ أَبْرِيذْ ن ؤُسمِّيضْ، أَمُّو \add إِ وَارْ ثسِّينذْ ؤُڒَا\add* مَامّشْ تّْوَاڭّنْ إِغْسَانْ ذڭْ ؤُعذِّيسْ ن ثمْغَارْثْ س دّيْسثْ. أَمُّو إِ وَارْ ثسِّينذْ ؤُڒَا ذ ثْمڭَّا ن أَربِّي ونِّي إِتّڭّنْ مَارَّا \add مِينْ إِدْجَانْ\add*. \x ◘ \xo 11:‏5 \xt يُوح. 3‏:‏8\x*  
\v 6 زَارْعْ زَّارِيعثْ نّشْ غَارْ ثُوفُّوثْ ؤُ وَارْ تّكّسْ أَفُوسْ نّشْ غَارْ ثْمذِّيثْ، مَاغَارْ شكْ وَارْ ثسِّينذْ مِينْ إِ غَا إِفْڒحْ، ثَا نِيغْ ثَا، نِيغْ عَاذْ س ثْنَاينْ إِذْسنْثْ أَذْ إِڒِينْثْ صبْحنْثْ.   
\b  
\m  
\s1 خَارِّيصْ ذِي ثمْژِي نّكْ ذِي ڒْحُوكْمْ ن أَربِّي  
\m
\v 7 ثَافَاوْثْ ذ ثْمِيژِيذْثْ ؤُشَا مْلِيحْ إِ ثِيطَّاوِينْ أَذْ ژَترنْثْ ثْفُوشْثْ.  
\v 8 وَاهْ، مَاڒَا أَرْيَازْ إِدَّارْ أَطَّاسْ ن إِسڭّْوُوسَا، أجّْ إِ-ث أَذْ إِفَارْحْ ذِي مَارَّا \add إِسڭّْوُوسَا نِّي\add*، ؤُ أجّْ إِ-ث أَذْ إِعْقڒْ \add عَاوذْ\add*، أَقَا ؤُسَّانْ إِبَارْشَاننْ أَذْ إِڒِينْ ذڭْ وَاطَّاسْ. مَارَّا مِينْ إِ ذ غَا يَاسنْ \add عَاذْ\add*، أَقَا-ث ذِي ڒْبَاطڒْ.   
\m
\v 9 فَارْحْ، \add أَ شكْ\add* أَحُوذْرِي، ذِي ثمْژِي نّشْ، سْفَارْحْ ؤُڒْ نّشْ ذڭْ وُوسَّانْ ن ثمْژِي نّشْ. ؤُيُورْ ذڭْ إِبْرِيذنْ ن وُوڒْ نّشْ ؤُ ذِي مِينْ تّْوَاڒَانْثْ ثِيطَّاوِينْ نّشْ، مَاشَا سّنْ أَقَا سِيذِي أَذْ شكْ إِسّكّْ خْ مَارَّا أَيَا إِ شّْرعْ.  
\v 10 سِيڭّْوجْ ڒْهمّْ خْ وُوڒْ نّشْ ؤُ سْحيّذْ ڒْغَارْ خْ أَرِّيمثْ نّشْ، مَاغَارْ ثمْژِي ذ ڒْوقْثْ س ؤُشُوَّافْ أَبَارْشَانْ \add ن ثمْژِي\add* أَقَا أَثنْ ذِي ڒْبَاطڒْ.   
\b  
\b  
\m  
\c 12
\s1 ثمْژِي ذ ثَاوسَّارْثْ  
\m
\v 1 إِذَارْ ونِّي شكْ د-إِخڒْقنْ ذڭْ وُوسَّانْ ن ثمْژِي نّشْ، \bd قْبڒْ\bd* إِ د غَا يَاوْضنْ وُوسَّانْ ن ڒْغَارْ إِ زِي غَا ثِينِيذْ: ”وَارْ ذَايْسنْ ؤُفِيغْ ڒفْرَاحثْ!“،  
\v 2 \bd قْبڒْ\bd* أَذْ ثتّْوَابَارْشنْ ثْفُوشْثْ ذ ثْفَاوْثْ ذ ثْزِيرِي ذ إِثْرَانْ ؤُشَا أَذْ د -عقْبنْ إِسيْنُوثنْ أَوَارْنِي إِ ونْژَارْ،  
\v 3 غَارْ وَاسّْ مِينْ ذِي إِعسَّاسنْ ن ثَادَّارْثْ أَذْ أَرْجِيجنْ، إِرْيَازنْ إِجهْذنْ أَذْ قوْسنْ، ثِينِّي إِحَارّْينْ ثَاسِيرْثْ أَذْ سّْبدّنْثْ \add ثَاوُّورِي نْسنْثْ\add*، مِينْزِي نِيثنْثِي قِّيمنْثْ ذْرُوسْ إِذْسنْثْ، ؤُشَا \add ثِيمْغَارِينْ\add* نِّي د-إِسَّاجَّانْ زِي ڒْكْوَازِي، أَذْ تّْوَاڒحّْفنْثْ س ثَادْجسْثْ،  
\v 4 ؤُ ثْنَاينْ ن ثوُّورَا غَارْ زّنْقّثْ أَذْ تّْوَابلّْعنْثْ، خْمِي دّْرِيزْ ن ثْسِيرْثْ أَذْ إِسّغْذْ ؤُشَا ڒْحسّْ ن ؤُجْضِيضْ أَذْ ث إِسِّيڭّْوذْ ذڭْ يِيضسْ ؤُ مَارَّا يسِّيسْ ن ؤُغنِّيجْ أَذْ ذوْڒنْثْ قوْسنْثْ،  
\v 5 ؤُ \add بْنَاذمْ\add* أَذْ إِڭّْوذْ زِي مَارَّا مِينْ إِدْجَانْ يُوعْڒَانْ، ؤُشَا أَذْ ذِينْ إِڒِينْثْ \add عْڒَامْ كُوڒْ ڒحْوَايجْ\add* إِنخْڒِيعنْ ذڭْ وبْرِيذْ، ؤُ ثَاشجَّارْثْ ن دْجوْزْ أَذْ ثْنوَّارْ ؤُ أَبُورْخسْ أَذْ إِذْوڒْ ذ ثَامَارَا ؤُ ثَانوَّاشْثْ ن ’ؤُكبَّاسْ‘ وَارْ ذ أَسْ د-يُوسِي عَاذْ غَارْ ڒْبَاڒْ - مَاغَارْ بْنَاذمْ إِڭُّورْ غَارْ ثَادَّارْثْ نّسْ ن ڒبْذَا ؤُ إِنِّي إِشطّْننْ أَذْ رَاحنْ أَذْ د-ثَاسنْ ذڭْ إِبْرِيذنْ - \f ◼ \fr 12:‏5 \ft \+bd ’ثَانوَّاشْثْ ن ؤُكبَّاسْ‘\+bd* - إِسمْ-أَ ن ثْنوَّاشْثْ ثَانِيثَا س ثُوثْلَايْثْ ن ثْلَاثِينِيثْ: ’شَابَّارِيسْ‘. س ثعْرَابْثْ ’الكَبَر‘.\f*   
\m
\v 6 \bd قْبڒْ\bd* إِ غَا ثتّْوَارْخُو ثسْغُونْثْ ن نُّوقَارْثْ، أَذْ ثتّْوَارْژْ طَّاوْيّثْ ن وُورغْ، أَذْ إِنّفْرَارْ وقْبُوشْ غَارْ ثَاڒَا ؤُشَا أَذْ ثقْضُو ثْجَارَّارْثْ ذڭْ وَانُو،  
\v 7 ؤُشَا ؤُشَاڒْ أَذْ د-إِعْقبْ غَارْ ثمُّورْثْ أَمْ مَامّشْ ث-ثُوغَا، ؤُ بُوحْبڒْ أَذْ د-إِعْقبْ غَارْ أَربِّي، ونِّي ث إِوْشِينْ. \x ◘ \xo 12:‏7 \xt أَمز. 2‏:‏7؛ 3‏:‏19؛ ڒخْڒ. 16‏:‏22\x*   
\b  
\m  
\s1 أَوَاڒْ أَنڭَّارُو  
\m
\v 8 ذ إِبطَّاڒنْ قَاعْ، إِقَّارْ ؤُمْبَارّحْ، أَقَا كُوڒْشِي ذِي ڒْبَاطڒْ. \x ◘ \xo 12:‏8 \xt إِزهد. 62‏:‏10؛ 144‏:‏4؛ أَمب. 1‏:‏2\x*   
\b  
\m
\v 9 سنّجْ إِ ؤُيَا، مِينْزِي أَمْبَارّحْ ثُوغَا-ث ذ أَمِيغِيسْ، إِسّڒْمذْ عَاوذْ ثُوسّْنَا إِ ڒْڭنْسْ، ثُوغَا إِتّْبَاڒُو، إِتّْبقَّاشْ مْلِيحْ، ؤُشَا إِعْذڒْ أَطَّاسْ ن وَاوَاڒنْ إِوزْننْ. \x ◘ \xo 12:‏9 \xt 1 إِج. 5‏:‏26\x*  
\v 10 يَارْزُو ؤُمْبَارّحْ مَاحنْذْ أَذْ يَافْ أَوَاڒنْ إِعذْڒنْ، ؤُ مِينْ يُورَا، أَقَا-ث نِيشَانْ، أَوَاڒنْ ن ثِيذتّْ.  
\v 11 أَوَاڒنْ ن إِمِيغِيسنْ أَمْ يِيسنَّاننْ ؤُ أَمشْنَاوْ إِمسْمِيرنْ إِتّْوَاسِّيذْفنْ، إِ زَّايْسنْ إِ-د-تَّاسنْثْ أَطَّاسْ ن ثْمسْڒَايِينْ، أَقَا-ثنْ مّوْشنْ زڭْ ؤُينِّي ن ؤُمكْسَاوْ. \f ◼ \fr 12:‏11 \ft \+bd ’أَمكْسَاوْ‘\+bd* - نِيغْ ’أَنِيتْشيِ‘.\f*   
\m
\v 12 سنّجْ إِ مَارَّا أَيَا، \add أَ\add* مِّي، حْضَا إِخفْ نّشْ: وَارْ ذِينْ أَقطُّو ن ثِيرَا ن وَاطَّاسْ ن إِذْلِيسنْ ؤُ أَطَّاسْ ن ثْغُورِي ثسَّاحَاڒْ أَرِّيمثْ.   
\m
\v 13 أَوَاڒْ أَنڭَّارُو ن مَارَّا مِينْ ثسْڒِيذْ، أَقَا ث ذ وَا: ”ڭّْوذْ أَربِّي ؤُ حْضَا ثِيوصَّا نّسْ!“، مَاغَارْ مَانْ أَيَا \add إِ يُورِينْ\add* إِ كُوڒْ إِجّْ ن بْنَاذمْ. \x ◘ \xo 12:‏13 \xt أَعَوذ. 6‏:‏2؛ 10‏:‏12؛ أَوڒن. 3‏:‏7\x*  
\v 14 مَاغَارْ سِيذِي أَذْ يَاوِي كُوڒْ ثَامڭِّيثْ زَّاثْ إِ ثَادَّارْثْ ن شّْرعْ خْ مَارَّا مِينْ إِنُّوفَّارنْ، مَا ثُوغَا إِصْبحْ نِيغْ ثُوغَا وَارْ إِحْڒِي.\x ◘ \xo 12:‏14 \xt 1 كُور. 4‏:‏5؛ 2 كُور. 5‏:‏10\x*   