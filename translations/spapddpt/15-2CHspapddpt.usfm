\v 9 Después el \w sacerdote|strong="H3548"\w* \w Joiada|strong="H3077"\w* \w entregó|strong="H5414"\w* \w a|strong="H3068"\w* los \w jefes|strong="H8269"\w* \w de|strong="H8269"\w* centenas las lanzas, los \w escudos|strong="H4043"\w* pequeños y los \w escudos|strong="H4043"\w* grandes del \w rey|strong="H4428"\w* \w David|strong="H1732"\w* que estaban en la \w Casa|strong="H1004"\w* \w de|strong="H8269"\w* \nd ʼElohim\nd*.  
\v 10 Colocó \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w la|strong="H5921"\w* \w gente|strong="H5971"\w* \w en|strong="H5921"\w* orden \w alrededor|strong="H5439"\w* \w del|strong="H5921"\w* \w rey|strong="H4428"\w*, \w cada|strong="H3605"\w* uno \w con|strong="H5921"\w* su espada \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w mano|strong="H3027"\w*, \w desde|strong="H5704"\w* \w el|strong="H5921"\w* \w lado|strong="H3802"\w* \w derecho|strong="H3233"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w Casa|strong="H1004"\w* \w hasta|strong="H5704"\w* \w el|strong="H5921"\w* \w lado|strong="H3802"\w* \w izquierdo|strong="H8042"\w*, \w delante|strong="H5921"\w* \w del|strong="H5921"\w* \w altar|strong="H4196"\w* \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w Casa|strong="H1004"\w*.   
