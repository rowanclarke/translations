\v 6 Ester dijo: ¡El adversario y \w enemigo|strong="H6862"\w* \w es|strong="H2088"\w* \w este|strong="H2088"\w* perverso \w Amán|strong="H2001"\w*!
\p \w Y|strong="H3068"\w* \w Amán|strong="H2001"\w* quedó aterrorizado \w delante|strong="H6440"\w* del \w rey|strong="H4428"\w* y \w de|strong="H6440"\w* la \w reina|strong="H4436"\w*.
\s1 Muerte de Amán
\p 
\v 7 \w Entonces|strong="H3588"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w se|strong="H5921"\w* \w levantó|strong="H6965"\w* enfurecido \w del|strong="H5921"\w* \w banquete|strong="H4960"\w* \w y|strong="H3588"\w* \w se|strong="H5921"\w* fue \w al|strong="H5921"\w* jardín \w del|strong="H5921"\w* palacio, \w pero|strong="H3588"\w* \w Amán|strong="H2001"\w* \w se|strong="H5921"\w* \w quedó|strong="H5975"\w* \w para|strong="H5921"\w* rogar \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w reina|strong="H4436"\w* Ester \w por|strong="H5921"\w* \w su|strong="H3588"\w* \w vida|strong="H5315"\w*, \w porque|strong="H3588"\w* \w vio|strong="H7200"\w* \w que|strong="H3588"\w* \w el|strong="H5921"\w* \w mal|strong="H7451"\w* ya \w estaba|strong="H5975"\w* determinado \w contra|strong="H5921"\w* \w él|strong="H5921"\w* \w de|strong="H5921"\w* parte \w del|strong="H5921"\w* \w rey|strong="H4428"\w*.
\p 
\v 8 \w Cuando|strong="H1571"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w volvió|strong="H7725"\w* \w del|strong="H5921"\w* jardín \w del|strong="H5921"\w* palacio \w al|strong="H5921"\w* lugar \w donde|strong="H5921"\w* bebía \w el|strong="H5921"\w* \w vino|strong="H3196"\w*, ¡ahí \w estaba|strong="H1004"\w* \w Amán|strong="H2001"\w* \w caído|strong="H5307"\w* \w encima|strong="H5921"\w* \w del|strong="H5921"\w* reclinatorio \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w cual|strong="H5973"\w* \w estaba|strong="H1004"\w* recostada Ester!
