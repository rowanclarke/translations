\v 25 \w C|strong="G3778"\w*’\w est|strong="G3588"\w* \w pourquoi|strong="G5101"\w* \w je|strong="G2532"\w* \w vous|strong="G5210"\w* \w dis|strong="G3004"\w* : \w Ne|strong="G2532"\w* \w vous|strong="G5210"\w* \w inquiétez|strong="G3309"\w* \w pas|strong="G3361"\w* \w pour|strong="G2532"\w* \w votre|strong="G2532"\w* \w vie|strong="G5590"\w*, \w de|strong="G2532"\w* \w ce|strong="G3778"\w* \w que|strong="G2532"\w* \w vous|strong="G5210"\w* \w mangerez|strong="G5315"\w* \w ou|strong="G2532"\w* boirez ; \w ni|strong="G2532"\w* \w pour|strong="G2532"\w* \w votre|strong="G2532"\w* \w corps|strong="G4983"\w*, \w de|strong="G2532"\w* \w quoi|strong="G5101"\w* \w vous|strong="G5210"\w* \w le|strong="G2532"\w* vêtirez. \w La|strong="G2532"\w* \w vie|strong="G5590"\w* \w n|strong="G3361"\w*’est-elle \w pas|strong="G3361"\w* \w plus|strong="G2532"\w* \w que|strong="G2532"\w* \w la|strong="G2532"\w* \w nourriture|strong="G5160"\w*, \w et|strong="G2532"\w* \w le|strong="G2532"\w* \w corps|strong="G4983"\w* \w plus|strong="G2532"\w* \w que|strong="G2532"\w* \w le|strong="G2532"\w* \w vêtement|strong="G1742"\w* ?
