\id 2JN Matupi Chin Standard Bible
\h 2 JOHAN
\toc1 2JOHAN
\toc2 2Johan
\toc3 2Jn
\mt1 JOHAN CAPAT
\mt2 A Pabae Nah
\mt4 (John’s Second Letter)
\is2 JOHAN CAPAT KAWNG
\im Khrihca rhoek kah khosaknah dongah lungnah he olpuei tila Johan loh koep a tael bal. He cabu dongah “boeinu” neh “oingaih” ti ollung te a hnonah. Lungnah neh oltak hmaih cet rhoi yoeyah saeh. Jesuh tah hlanghing pum la ha coeng tak tih khat neh khat lungnah ham khaw a thuinuet.
\iot Sawt Yoeinah
\io1 Kuttuknah then thangthuinah \ior (1-3)\ior*
\io1 Oltak neh lungnah \ior (4-11)\ior*
\io1 Phinah olrho \ior (12,13)\ior*
\c 1
\s1 Uemnah Ol
\p 
\v 1 A \w ham|strong="G4245"\w* kai \w loh|strong="G3588"\w* a coelh \w boeinu|strong="G2959"\w* \w neh|strong="G2532"\w* \w a|strong="G0846"\w* \w ca|strong="G5043"\w* \w rhoek\w* \w te|strong="G3588"\w* kan yaak sak. \w Oltak|strong="G0225"\w* \w dongah|strong="G1722"\w* \w amih|strong="G3739"\w* \w te\w* \w kai|strong="G1473"\w* loh ka \w lungnah|strong="G0025"\w*. \w Te\w* \w dongah|strong="G2532"\w* \w kai|strong="G1473"\w* \w bueng|strong="G3441"\w* \w long\w* \w pawt|strong="G3756"\w* \w tih|strong="G0235"\w* \w oltak|strong="G0225"\w* \w aka\w* \w ming|strong="G1097"\w* \w rhoek|strong="G3588"\w* \w boeih|strong="G3956"\w* \w long\w* \w khaw|strong="G2532"\w* a lungnah.
