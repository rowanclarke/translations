\id JHN
\h SAN JUAN
\toc1 Jág₁ Dse₃ quió'₅ Diú₄ a₂ca₂tó'₂ San Juan₅₄ ne₄ Si₂
\toc2 SAN JUAN
\toc3 Jn.
\mt1 Jág₁ Dse₃ quió'₅ Diú₄ a₂ca₂tó'₂ San Juan₅₄ ne₄ Si₂
\c 1
\s1 Jág₁ quió'₅ Diú₄ a₂lɨ́n₅ dsa₂ mɨ₂güɨ́g₃
\p 
\v 1 Lia'₂ con'₂ le₂'uɨg₅₄ jme₁ca₂rë₃lióg₃, jme₁ma₂chan₂ i₂të́'₂ Jág₁; jaun₂ i₂'éi₂ i₂lɨ́n₅ Jág₁ në́₃, jme₁'ein₅₄ quian'₅₄ Diú₄; Diú₄ bá₄ jme₁lɨ́in₄ ján₃.
\v 2 Jaun₂ lia'₂ con'₂ le₂'uɨg₅₄, 'éi₂ në́₃, jme₁'ein₅₄ quian'₅₄ Diú₄.
\v 3 Të₂le₃ quian'₅₄ 'éi₂ bá₄, ca₂lë₃ ca₂le₃jë́₃ 'e₂ a₂cha₂; ca₂lia'₂ 'i₁caun₂ tsá₃ ca₂rë₃chá₃ jua'₅₄ tsá₃ ca₂jmo₃ 'éi₂.
\p 
\v 4 Ja₁con₂ 'éi₂ bá₄ já₅ bí₂ a₂le₃chan₂ dsa₂; bí₂ jaun₂ në́₃, lë́₅ Si₂ a₂tág₅ ja₁con₂ dsa₂ mɨ₂güɨ́g₃.
\v 5 Tág₅ Si₂ jaun₂ jë₄ qui₁né'₃, la₁ qui₁né'₃ në́₃, tsá₃ ma₂ca₂tió'₃.
\p 
\v 6 Ca₂rë₃chán₃ jan₂ dsa₂ i₂chen₄ quián₅ Diú₄, i₂chen₂ Juan₅₄.
\v 7 Ca₂guain₃ ca₂jáng'₃ jág₁ dsau₅ të₂le₃ quió'₅ 'éi₂ i₂lɨ́n₅ Si₂, ia₁jaun₂ të₂le₃ quian'₅₄ jág₁ dsau₅ a₂jáng'₅ në₅, le₃'én₂ ca₂le₃jɨ́n₃ dsa₂.
\p 
\v 8 On₃jua'₅₄ Juan₅₄ 'éi₂ i₂jme₁lɨ́n₄ Si₂; jŋia'₅₄ con'₂ i₂jáng'₅ jág₁ dsau₅ bá₄ jme₁lɨ́in₄, juɨ₁lia'₂ le₃quió'₅ Si₂.
\p 
\v 9 Jme₁ma₂guán₂ i₂lɨ́n₅ Si₂ të₃dsón'₂, a₂tág₃ ja₁con₂ le₂jan₂ le₂jan₂ dsa₂ mɨ₂güɨ́g₃.
\p 
\v 10 I₂'éi₂ i₂lɨ́n₅ Jág₁ jme₁'ein₅₄ mɨ₂güɨ́g₃; jaun₂, o₁jŋia'₅₄ ca₂lë₃ mɨ₂güɨ́g₃ të₂le₃ quian'₅₄ 'éi₂, tsá₃ ca₂rë₃cuɨg₅ dsa₂ mɨ₂güɨ́g₃.
\p 
\v 11 Guain₃ jɨn₄ dsa₂ go₅₄, la₁ dsa₂ go₅₄ në́₃, tsá₃ ca₂guei₃.
\p 
\v 12 La₁ia₁ i₂con'₂ ca₂guei₃, i₂ca₂rë₃'én₂ të₂le₃ quió'₅, dsa₂ 'éi₂ në́₃ ca₂cuë́'₃ bí₂ a₂léin₂ chi'₂-guein₂ quián₅ Diú₄.
\p 
\v 13 Juɨ₁lia'₂ chi'₂-guein₂ 'éi₂, on₃jua'₅₄ ca₂rë₃cháin₃ lia'₂ con'₂ lë́₅ jmɨ₄ dsa₂ mɨ₂güɨ́g₃, on₃ guë'₂ lia'₂ con'₂ lë́₅ dsɨ́₅ dsa₂ mɨ₂güɨ́g₃, on₃ guë'₂ lia'₂ con'₂ lë́₅ dsɨ́₅ jan₂ dsa₂ ŋe'₂, ton'₂ ca₂rë₃cháin₃ le₃quió'₅ Diú₄ bá₄.
\p 
\v 14 I₂'éi₂ në́₃ i₂lɨ́n₅ Jág₁, ca₂can₃ ŋɨ₄ dsa₂ mɨ₂güɨ́g₃, ca₂guá₂ jë₄ quián₂ jniog₄. Jnia'₅₄ në́₃ ma₂ca₂jag₅₄ a₂co₂'né'₅ quió'₅, co₂'nió'₄ a₂co₂'né'₅ quió'₅ jan₂ tan₅₄ Ja₁ŋi'₅₄ Diú₄, i₂já₅ ja₁con₂ Jmei₂, rë₂rɨn₅ a₂dse₃ dsɨ́₅, a₂rë₂ti'₅₄ në́₃.
\p 
\v 15 Ca₂jáng'₃ Juan₅₄ jág₁ dsau₅ të₂le₃ quió'₅ 'éi₂, ca₂juá'₂ tiá₂:
\p ―I₂la₂ bá₄ 'éi₂ i₂'ɨ́n₅ jniá₂, lia'₂ con'₂ jme₁ca₂juá'₃: “I₂já₅ cang₂ guë́₄ con'₂ guë́₄ jniá₂, dsein₅₄ guë́₄ con'₂ guë́₄ jniá₂, ia₁ jme₁ma₂chain₂ jŋiá₅ guë́₄ con'₂ guë́₄ jniá₂.”
\p 
\v 16 Ca₂le₃jág₃ bá₄ jniog₄ ma₂qui₂ma₂guéi₂ a₂tson₂ a₂dse₃ dsɨ́₅ 'éi₂, caun₂ qui₂jme₂gu'₅₄ bá₄ Diú₄ jniog₄ lia'₂ i₂gú'₃.
\p 
\v 17 Ca₂ŋag₂ jniog₄ Si₂ 'Éi'₃ të₂le₃ quian'₅₄ Moisés, la₁ia₁ të₂le₃ quian'₅₄ Jesucristo bá₄ ca₂já₃ a₂dse₃ dsɨ́₅ Diú₄, ca₂rë₃ti₃ jág₁ dsau₅ në́₃.
\p 
\v 18 Lia'₂ 'i₁jan₂ tsá₃ 'ein₂ ma₂jɨ́n₂ Diú₄ lia'₂ 'i₁cón'₂; la₁ia₁ Ja₁ŋi'₅₄ i₂jan₂ tan₅₄ 'éi₂ quiáin₅, i₂'en₅₄ ja₁con₂ Jmei₂, i₂'éi₂ bá₄ ma₂jmo₃ jág₁ dsau₅ 'a₂ lia'₂ lɨ́n₅ Diú₄.
\s1 Jáng'₅ jág₁ dsau₅ Juan₅₄ i₂chon₅ dsa₂ jmɨg₂, juɨ₁lia'₂ i₂'ein₂ 'éi₂ Jesucristo
\r (Mateo 3:11-12; Marcos 1:7-8; Lucas 3:15-17)
\p 
\v 19 Jaun₂ le₂la₂ jág₁ a₂ca₂jáng'₃ Juan₅₄ jme₁ca₂chen₃ dsa₂ can'₅₄ quián₅ dsa₂ judíos i₂tion'₅₄ Jerusalén ca₂chein₃ jme₂dsa₂ quiain'₅₄ levitas ne₄ Juan₅₄, a₂i₁ŋag₁₂ i₂'ein₂ 'éi₂.
\p 
\v 20 'Éi₂ në́₃ ca₂jmo₃ jág₁ lia'₂ rë₂jiá₃, ca₂juá'₂:
\p ―On₃jua'₅₄ jniá₂ lɨ́ng₅ I₂rë₂'ɨ́n₁ quián₅ Diú₄.
\p 
\v 21 Jaun₂ ca₂ŋag₃ táng₃ dsa₂:
\p ―¿'Ein₂ 'ne₂ jaun₂? ¿'Ne₂ lɨ́ng'₅ Elías i₂jme₁'ë́₂ jág₁ o₄quió'₄ Diú₄?
\p Jaun₂ ca₂juá'₂ Juan₅₄:
\p ―On₃jua'₅₄ 'éi₂ jniá₂.
\p Dsɨ₂juɨ₅ le₂jaun₂ bá₄ ca₂ŋag₃ táng₃ dsa₂:
\p ―¿On₃ bá₄ 'ne₂ lɨ́ng'₅ i₂'ë́₂ jág₁ 'éi₂, i₂lë́₅ jág₁ jiá₃?
\p Jaun₂ ca₂ŋag₃ Juan₅₄:
\p ―Jan₂'ón₄.
\p 
\v 22 Jaun₂ bá₄ ca₂juá'₂ dsa₂ ca₂tsɨ́'₃ Juan₅₄:
\p ―¿'Ein₂ lɨ́n'₅ 'ne₂, jaun₂ në́₃? Jua'₅₄, ia₁jaun₂ dsɨ₁con₁ jnia'₅₄ jág₁ dsau₅ ne₄ dsa₂ i₂ca₂chei₃. ¿'Ein₂ juá'₂ 'ne₂ lɨ́ng'₅?
\p 
\v 23 Jaun₂ ca₂ŋag₃ Juan₅₄:
\p ―Jniá₂ bá₄ lɨ́ng₅ i₂'éi₂ i₂juá'₂ jág₁ tiá₂ caun₂ 'uë₃ quein₂ co₂'ŋiog₅ i₁juá'₄: “Nia₄ 'nia'₂ caun₂ juɨ₅ co₂dsau₅ quió'₅ Te₁gui'₅₄.”\f + \fr 1:23 \ft Isaías 40:3.\f*
\p 
\v 24 Dsa₂ i₂i₁len₅₄ i₁dsia₂ jág₁ quian'₅₄ Juan₅₄, dsa₂ i₂chen₄ quián₅ dsa₂ fariseos bá₄ 'éi₂,
\v 25 jaun₂ ca₂ŋag₃ ca₂ŋɨ́i'₃ táng₃ Juan₅₄:
\p ―Chi₂jua'₂ on₃jua'₅₄ 'ne₂ lɨ́ng'₅ I₂rë₂'ɨ́n₁ quián₅ Diú₄, on₃ guë'₂ Elías, on₃ guë'₂ jan₂ i₂'ë́₂ jág₁ o₄quió'₄ Diú₄ në́₃, ¿'e₂ ta₁ 'eng'₅₄ tsóng'₅ dsa₂ jmɨg₂?\f + \fr 1:25 \ft lit. “¿'e₂ ta₁ 'eng'₅₄ tiáng'₅ dsa₂ jmɨg₂?” \f*
\p 
\v 26 Jaun₂ ca₂juá'₂ Juan₅₄:
\p ―Jniá₂ tiáng₅ dsa₂ jmɨg₂; la₁ia₁ jɨn₄ 'nia'₂ chan₂ jan₂ i₂tsá₃ cuɨn'₂ 'nia'₂.
\v 27 Já₅ jan₂ cang₂ guë́₄ con'₂ guë́₄ jniá₂, on₃jua'₅₄ 'ein₂ lɨ́n₅ jniá₂ jua'₅₄ ca₂tɨ́ng₂ tsɨ'₅₄ lau₂ ton₅ tag₅₄.
\p 
\v 28 Ca₂le₃jë́₃ a₂la₂ ca₂lë₃ caun₂ ja₁chei₂ Betania,\f + \fr 1:28 \ft A₂lɨn₅₄ chog₅₄ si₂: “Betábara.” Juɨg₂ Betania siá'₂ cau₅ Cuá₃ Jordán, uɨ́ng₂ ja₁niog₅ Jerusalén; on₃jua'₅₄ Betania ja₁jme₁guá₄ Lázaro quiain'₅₄ 'io₅₄ rɨin'₅₄.\f* a₂niog₅ të₂le₃ ja₁'ia₂ 'iog₂ të₂le₃ quióng₄ Cuá₃ Jordán, ja₁jme₁'en₅₄ Juan₅₄ choin₂₃ dsa₂ jmɨg₂.\f + \fr 1:28 \ft lit. “ja₁jme₁'en₅₄ Juan₅₄ tiáin₂ dsa₂ jmɨg₂.” \f*
\s1 Jesús i₂lɨ́n₅ Guein₂ Já'₂ Cha'₂ quián₅ Diú₄
\p 
\v 29 Jme₁jnia₃ jaun₂, ca₂jɨ́n₂ Juan₅₄ Jesús a₂já₅ ja₂quiáin₃ ja₁chéin'₄, jaun₂ ca₂juá'₂:
\p ―Jag₄ 'nia'₂, i₂në₅ bá₄ Guein₂ Já'₂ Cha'₂ quián₅ Diú₄, i₂jŋiá'₂ dsáu₁ dsa₂ mɨ₂güɨ́g₃.
\v 30 I₂në₅ bá₄ 'éi₂ i₂'ɨ́n₅ jniá₂, lia'₂ con'₂ jme₁ca₂juá'₃: “I₂já₅ cang₂ guë́₄ con'₂ guë́₄ jniá₂, dsein₅₄ guë́₄ con'₂ guë́₄ jniá₂, ia₁ jme₁ma₂chain₂ jŋiá₅ guë́₄ con'₂ guë́₄ jniá₂.”
\v 31 Lia'₂ jŋia'₅₄ 'ŋió₃, tsá₃ jme₁guion₅₄ 'ein₂ 'éi₂; la₁ia₁ chóng₅ dsa₂ jmɨg₂ ma₂guio₃,\f + \fr 1:31 \ft lit. “la₁ia₁ tiáng₅ dsa₂ jmɨg₂ ma₂guio₃.” \f* ia₁jaun₂ le₃cuɨg₅ dsa₂ juɨg₂ Israel 'ein₂ 'éi₂.
\p 
\v 32 Ján₃ bá₄ ca₂jáng'₃ Juan₅₄ jág₁ dsau₅ la₂, ca₂juá'₂:
\p ―Ca₂jɨn₄ jniá₂ Jme₂dsí₂ Jŋió₅ ca₂sióin₃ guei'₅₄ i₂juɨ́g₃ i₂jniá₂ lia'₂ jniá₂ jan₂ i₁ju₂, ca₂të₁gua₁ ne₄ quió'₅ 'éi₂.
\v 33 Tsá₃ jme₁ma₂guion₄ bá₄ guë́₄ jniá₂ i₂'ein₂ 'éi₂; la₁ia₁ i₂ca₂chei₃ jniá₂ a₂chóng₄ dsa₂ jmɨg₂,\f + \fr 1:33 \ft lit. “la₁ia₁ i₂ca₂chei₃ jniá₂ a₂tiáng₄ dsa₂ jmɨg₂.” \f* ca₂tság₃ jniá₂: “Jë₁ma₂ca₂jɨng'₅₄ Jme₂dsí₂ sióin₅ ne₄ quió'₅ jan₂ dsa₂ ŋe'₂, i₂'éi₂ bá₄ qui₃tián₂ dsa₂ Jme₂dsí₂ Jŋió₅.”
\v 34 Ma₂ca₂jɨin₅₄ bá₄ jniá₂, jaun₂ jáng'₅ jniá₂ jág₁ dsau₅, a₂lɨ́n₅ 'éi₂ Ja₁ŋi'₅₄ Diú₄.
\s1 I₂le₂'uɨg₅₄ dsa₂ guia₃-tɨ́n₂ quián₅ Jesús
\p 
\v 35 Jme₁jnia₃ jaun₂, jme₁'en₅₄ táng₃ Juan₅₄ ja₁jaun₂ quian'₅₄ guë́₄ on₃ dsa₂ i₂i₂nio₄ quiain'₅₄.
\p 
\v 36 Jaun₂ jme₁ca₂jág₃ Juan₅₄ ca₂ŋɨ₅ Jesús, jaun₂ ca₂juá'₂:
\p ―Jag₄ 'nia'₂, i₂në₅ bá₄ Guein₂ Já'₂ Cha'₂ quián₅ Diú₄.
\p 
\v 37 Jaun₂ ca₂nág₂ le₃on₃ dsa₂ 'éi₂ a₂ca₂juá'₂, jaun₂ i₃léin₂ chi₁co'₅₄ quió'₅ Jesús.
\p 
\v 38 Jaun₂ në́₃ ca₂jén'₃ Jesús të₂le₃ ca'₃, ca₂jɨ́in₂ dsa₂ i₂i₃lén₂ chi₁co'₅₄ quió'₅, jaun₂ ca₂juá'₂ ca₂tsɨ́'₃ 'éi₂:
\p ―¿'E₂ 'náu'₂ 'nia'₂?
\p Jaun₂ ca₂juá'₂ dsa₂ 'éi₂ ca₂tsɨ́'₃ Jesús:
\p ―Rabbí ―co₂'nió'₄ le₃jua'₅₄: Të₅―, ¿Já'₄ ŋéi'₂ 'ne₂?
\p 
\v 39 Jaun₂ ca₂ŋag₃ Jesús:
\p ―I₂nó'₅ 'nia'₂ i₂jag₄.
\p Jaun₂ i₃léin₂ i₁jag₅₄ já'₄ guá₅ Jesús, jaun₂ quian'₅₄ 'éi₂ bá₄ ca₂tóin'₂ të₁lia'₂ ca₂'láu₂ jmɨg₄ jaun₂; ia₁ jme₁ma₂ca₂të́₂ con'₂ hora ŋí₁ quén₂ të₂le₃ ca₂'láu₂.\f + \fr 1:39 \ft lit. “hora guia₃.” \f*
\p 
\v 40 Jan₂ i₂on₃ 'éi₂ i₂ca₂nág₂ a₂ca₂juá'₂ Juan₅₄, i₂i₃lén₂ chi₁co'₅₄ quió'₅ Jesús, jme₁chen₂ Drë́₄ i₂lɨ́n₅ rɨn'₅₄ Si₂mu₅₄ i₂të́'₂ dsa₂ Pe₄.
\p 
\v 41 Dsɨ₂juɨ₅ né'₃ guë́₄ jaun₂ bá₄ ŋe₄ Drë́₄, i₁'nai'₂ Si₂mu₅₄ rɨin'₅₄, jaun₂ ca₂juá'₂ ca₂tsɨ́'₃ 'éi₂:
\p ―Ma₂dsán'₅ jnia'₅₄ Mesías, (co₂'nió'₄ le₃jua'₅₄, dsa₂ I₂rë₂'ɨ́n₁ quián₅ Diú₄).
\p 
\v 42 Jaun₂ i₁jŋia₃ Drë́₄, Si₂mu₅₄ rɨin'₅₄ ja₁'en₅₄ Jesús, jaun₂ jme₁ca₂jág₂ Jesús në́₃, ca₂juá'₂:
\p ―'Ne₂ lɨ́ng'₅ Si₂mu₅₄, ja₁ŋi'₅₄ Jonás. La₁ia₁ le₃cheng'₂ Cefas.
\p Lia'₂ chen₂ Cefas në₅, co₂'nió'₄ le₃jua'₅₄ Pe₄.\f + \fr 1:42 \ft Co₂'nió'₄ le₃jua'₅₄, “Nɨ₁cang₁.” Le₂në₅ juá'₂ jág₁ “Cefas” quian'₅₄ jág₁ jmei₅ arameo; co₂jaun₂ juá'₂ “Petros” (ja₁já₅ jág₁ piedra, Pedro në́₃) quian'₅₄ jág₁ jmei₅ griego.\f*
\s1 Të́'₂ Jesús Felipe quian'₅₄ Natanael
\p 
\v 43 Jme₁jnia₃ jaun₂, ca₂lë₃ dsɨ́₅ Jesús dsó₃ 'uë₃ Galilea, jaun₂ ca₂dsáin'₂ Felipe, jaun₂ ca₂juá'₂ ca₂tsɨ́'₃ 'éi₂:
\p ―Jme₁quiong'₅₄ jniá₂.
\p 
\v 44 Felipe 'éi₂ në́₃, jme₁chain₂ juɨg₂ Betsaida, ján₃ bá₄ ja₁jme₁chan₂ Drë́₄ quian'₅₄ Pe₄ në́₃.
\p 
\v 45 Fe₂li₄ 'éi₂ në́₃, ŋei₅₄ i₁'niai'₂ Natanael, jaun₂ ca₂juá'₂ ca₂tsɨ́'₃ 'éi₂:
\p ―Ma₂dsán'₅ jnia'₅₄ dsa₂ 'éi₂ i₂'ɨn₅ Moisés ne₄ Si₂ 'Éi'₃, i₂'ɨn₅ dsa₂ i₂'ë́₂ jág₁ quián₅ Diú₄ në́₃. Jesús bá₄ 'éi₂, ja₁ŋi'₅₄ José, i₂chan₂ juɨg₂ Nazaret.
\p 
\v 46 Jaun₂ ca₂juá'₂ Natanael:
\p ―¿Lé₂ le₃o₃'ag₅ caun₂ a₂dse₃ juɨg₂ Nazaret?
\p Jaun₂ ca₂ŋag₃ Fe₂li₄:
\p ―Ŋia₅ de'₂ i₂jag₄.
\p 
\v 47 Jaun₂ jme₁ca₂jág₃ Jesús a₂ma₂ja₂quián₃ Natanael, ca₂juá'₂:
\p ―La₂ dé₄ dsón'₂ já₅ jan₂ dsa₂ israelita të₃dsón'₂, i₂tsá₃ cha₂ mai₅₄ ja₁con₂.
\p 
\v 48 Jaun₂ ca₂ŋag₃ Natanael ca₂ŋɨ́i'₃ Jesús:
\p ―¿'A₂ lia'₂ cuɨg'₂ jniá₂?
\p Jaun₂ ca₂juá'₂ Jesús:
\p ―Jniá₂ në₂jɨng₅₄ 'ne₂ jŋiá₅, né'₃ guë́₄ a₂dsɨ₃té₂ Fe₂li₄, lia'₂ con'₂ jme₁ŋéi'₂ né'₃ nɨ₁'ma₂ higuera.
\p 
\v 49 Jaun₂ në́₃ ca₂juá'₂ Natanael ca₂tsɨ́'₃ Jesús:
\p ―Të₅, 'ne₂ bá₄ lɨ́ng'₅ Ja₁ŋi'₅₄ Diú₄; 'ne₂ bá₄ lɨ́ng'₅ Rag₅₄ quián₅ dsa₂ juɨg₂ Israel.
\p 
\v 50 Jaun₂ ca₂ŋag₃ Jesús ca₂tsɨ́'₃ 'éi₂:
\p ―¿A₁jaun₂ 'éng'₂ ia₁ në₂juá'₃ a₂në₂jɨn₄ jniá₂ 'ne₂, ŋéi'₂ né'₃ nɨ₁'ma₂ higuera? La₁ia₁ në₃ guë́₄ të₃ ne'₅₄ 'lióng₂ léi₄ juë'₂ guë́₄ con'₂ guë́₄ a₂la₂.
\p 
\v 51 Ján₃ bá₄ ca₂juá'₂ Jesús:
\p ―A₂dsɨ₂jó'₃ juɨ́g₂ jniá₂ 'nia'₂, jag'₅₄ 'nia'₂ rë₂na₄ guei'₅₄ i₂juɨ́g₃, jɨn'₅₄ 'nia'₂ ángeles quián₅ Diú₄ në́₃, qui₂tsau₂ qui₂tsɨ₂sioin₂ ne₄ Jaun₅ dsa₂ mɨ₂güɨ́g₃.
\c 2
\s1 Ca₂jen'₂ gu₂ dsa₂ jë₄ juɨg₂ Caná juɨg₂ tén₅ Galilea
\p 
\v 1 'Nɨ₅ jmɨg₄ cang₂ guë́₄ jaun₂, ca₂nio₃ jmɨg₄ ca₂jen'₂ gu₂ dsa₂ jë₄ juɨg₂ Caná, a₂niog₅ 'uë₃ Galilea. Ja₁jaun₂ jme₁'en₅₄ chog₅₄ Jesús në́₃;
\v 2 ján₃ bá₄ ca₂të́'₃ dsa₂ Jesús quiain'₅₄ dsa₂ i₂quiain'₅₄, ja₁jen'₂ gu₂ dsa₂ jaun₂.
\p 
\v 3 Jme₁ca₂dsa₃ vino, jaun₂ ca₂juá'₂ chog₅₄ Jesús ca₂tsɨ́'₃ 'éi₂:
\p ―Tsá₃ ma₃cha₂ vino quió'₅ dsa₂ tioin'₅₄.
\p 
\v 4 La₁ ca₂ŋag₃ Jesús:
\p ―'Io₅₄, ¿'e₂ lë₃ juɨg'₂ jniá₂ a₂në₅? Ia₁ tsá₃ ma₂të́₂ guë́₄ hora quió₃.
\p 
\v 5 La₁ ca₂juá'₂ chog₅₄ ca₂tsɨ́'₃ dsa₂ i₂tion'₅₄ tia'₅:
\p ―Jmo₄ 'nia'₂ chi₂'e₂ juá'₂ i₂në₅.
\p 
\v 6 Jme₁tióng₂ ja₁jaun₂ jŋéi₂ tɨ'₂ cang₄, juɨ₁lia'₂ a₂jme₁jmó'₂ dsa₂ judíos ta₁ a₂jme₁qui₂jmo₂₃ le₁jɨ́in₃, con'₂ lë́₅ tag₄ jme₁chí'₄ quió'₅. Lia'₂ caun₂ nɨ₁tɨ'₂ cang₄ jaun₂ 'a₄ con'₂ të₂láu₃-guiá₂, o₃ caun₂ 'ŋiá₂-láu₂ litro jmɨg₂.
\p 
\v 7 Jaun₂ ca₂juá'₂ Jesús ca₂tsɨ́'₃ dsa₂ i₂tia'₅:
\p ―Jme₁can'₂ 'nia'₂ nɨ₁tɨ'₂ tióng₂ la₂ quian'₅₄ jmɨg₂.
\p Ca₂jme₃can'₂ bá₄ guë'₂ dsa₂ lia'₂ ca₂rɨn₅ rë₂ lɨn₃.
\v 8 Jaun₂ ca₂juá'₂ Jesús ca₂tsɨ́'₃ dsa₂ 'éi₂:
\p ―Në₃ në́₃, dsen₅₄ ca₂juɨg₄, o₂can₄ ne₄ dsa₂ i₂niog₅ ne₄ jmɨg₄.
\p Jaun₂ i₁can₅ dsa₂.
\p 
\v 9 Dsa₂ i₂niog₅ ne₄ jmɨg₄ jaun₂, ca₂tí₂ 'o₅₄ jmɨg₂ a₂ca₂lë₃ vino jaun₂, të₃ tsá₃ ŋi₅ a₂já'₄ já₃; jŋia'₅₄ lia'₂ dsa₂ i₂ca₂dsen₅ jmɨg₂ bá₄ jme₁ŋi₅. Jaun₂ në́₃ ca₂të₃ dsa₂ i₂niog₅ ne₄ jmɨg₄, ca₂të́'₃ dsa₂ ŋe'₂ i₂jen'₂ gu₂,
\v 10 jaun₂ ca₂tsɨ́'₃ 'éi₂:
\p ―Ca₂le₃jɨ́n₃ bá₄ dsa₂ tɨin₂₃ tia'₃ le₂'uɨg₅₄ vino dse₃, jaun₂ jë₁ma₂le₁'en₅ dsa₂, jaun₂ guë́₄ tia'₃ vino ga₂. La₁ 'ne₂ në́₃ në₂'ma'₅₄ vino dse₃ ca₂të₂ jë₁ca₂tó'₂.
\p 
\v 11 Jë₄ juɨg₂ Caná a₂tén₅ 'uë₃ Galilea jaun₂, ca₂jmo₃ Jesús léi₄ juë'₂ le₂'uɨg₅₄. Le₂në₅ ca₂jme₃jniai₂₃ 'ein₂ lɨ́in₅ të₂le₃ quian'₅₄ juɨ₅bí₂ quió'₅, jaun₂ ca₂rë₃'én₂ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅.
\p 
\v 12 Cang₂ guë́₄ jaun₂ ca₂ŋó₃ jë₄ juɨg₂ Capernaum, lia'₂ jma₃quiain'₅₄ chog₅₄, rɨin'₅₄, chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅ në́₃; ja₁jaun₂ ca₂tóin'₂ tɨn₃-'nɨ₅ jmɨg₄.
\s1 Ca₂chí₃ Jesús i₁dsi₅ guá'₅
\r (Mateo 21:12-13; Marcos 11:15-18; Lucas 19:45-46)
\p 
\v 13 Jme₁ma₂ja₂quián₃ Jmɨg₄ Të₂'ɨn₅₄ quió'₅ dsa₂ judíos, jaun₂ ca₂uɨ́g₂ Jesús juɨ₅ Jerusalén.
\p 
\v 14 Ja₁jaun₂ ca₂dsáin'₂ i₁dsi₅ guá'₅ templo dsa₂ i₂'nɨ₅ ca₁juɨ₅, i₂'nɨ₅ já'₂ cha'₂, i₂'nɨ₅ i₁ju₂ në́₃, quian'₅₄ dsa₂ i₂qui₂jme₂tsɨ́n₃ cu₄ quió'₅ dsa₂.
\p 
\v 15 Jme₁ca₂jág₃ Jesús a₂jaun₂, ca₂jmo₃ caun₂ látigo a₂lë́₅ quian'₅₄ tsɨ₁'nei₅₄, jaun₂ ca₂'uɨ́in'₂ ca₁'né₄ ca₂le₃jɨ́n₃ i₂tion'₅₄ i₁dsi₅ lia'₂ jma₃quiain'₅₄ já'₂ cha'₂ quiáin₅, ca₁juɨ₅ në́₃. Ca₂jein₃ 'uë₃ cu₄ quió'₅ dsa₂ i₂jme₂tsɨ́n₃ cu₄, qui₂ca₂jéin'₃ nɨ₁mesa në́₃.
\p 
\v 16 Jaun₂ ca₂tsɨ́'₃ i₂'nɨ₅ i₁ju₂:
\p ―¡'Uë'₅₄ 'nia'₂ ca₂le₃jë́₃ a₂në₅ ja₁lá₃! ¡Tsá₃ lë₁jmo₂ 'nia'₂ ja₁'ma'₅₄ ja₁quió'₄ Ŋe'₃!
\p 
\v 17 Jaun₂ ca₂dsáu'₃ dsɨ́₅ dsa₂ i₂jme₁quiain'₅₄, a₂chi₁ton₅ ne₄ Si₂ le₂la₂:
\q1 Në₂jag₄ bá₄ a₂ca₂cóng₂ 'uɨg₅₄ ia₁ a₂ŋɨ́₄ lë₃ dsí'₅ dsɨ₃
\q2 o₄quió'₄ dsi₂néi₂ quiáng'₂.\f + \fr 2:17 \ft Salmo 69:9\f*
\p 
\v 18 Jaun₂ në́₃ ca₂ŋag₃ dsa₂ judíos ca₂ŋɨ́i'₃ Jesús:
\p ―¿'E₂ léi₄ le₃'ë́'₂ jnia'₅₄ a₂jáng'₅ jág₁ dsau₅ a₂ca₂tɨ́n'₂ 'ne₂ jmó'₂ le₂në₅?
\p 
\v 19 Jaun₂ ca₂ŋag₃ Jesús:
\p ―'Én₂ 'nia'₂ guá'₅ la₂, jaun₂ tsɨ'₅₄ táng₃ jniá₂ quian'₅₄ 'nɨ₅ jmɨg₄.
\p 
\v 20 Jaun₂ në́₃ ca₂juá'₂ dsa₂ judíos ca₂tsɨ́'₃ Jesús:
\p ―Të₂láu₃-jŋéi₂ ŋi₂ ca₂rë₃'ɨ́n₅ dsa₂ jme₁ca₂chi'₃ guá'₅ la₂. ¿'En₁ jmá'₃ jaun₂, lé₂ le₃jmog'₅₄ tsɨ'₅₄ quian'₅₄ 'nɨ₅ jmɨg₄?
\p 
\v 21 La₁ia₁ guá'₅ a₂'ë₅ Jesús jaun₂, nɨ₁ŋɨ₄ 'ŋiog₅ bá₄ Jesús 'ë₂₃.
\p 
\v 22 Jaun₂ lë₃, lia'₂ con'₂ jme₁ca₂jen'₅₄ Jesús a₂jme₁rë₂'lɨin₅₄, ca₂dsáu'₃ dsɨ́₅ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅ jág₁ jaun₂. Jaun₂ ca₂rë₃'éin₂ jág₁ a₂juá'₂ ne₄ Si₂ quió'₅ Diú₄, quian'₅₄ jág₁ a₂jme₁ca₂juá'₂ Jesús jaun₂.
\s1 I₂cuɨn₅ bá₄ Jesús ca₂le₃jɨ́n₃ dsa₂
\p 
\v 23 Lia'₂ con'₂ jme₁'en₅₄ Jesús Jerusalén Jmɨg₄ Të₂'ɨn₅₄, ca₂rë₃'én₂ juɨn₅ lɨn₃ dsa₂ të₂le₃ quió'₅ Jesús, jme₁ca₂jág₃ léi₄ a₂ma₂qui₂ma₂jmo₃.
\p 
\v 24 La₁ tsá₃ jme₁'én₂ Jesús quió'₅ dsa₂ 'éi₂, ia₁ i₂cuɨin₂₃ bá₄ ca₂le₃jɨ́n₃ dsa₂, 'a₂ lia'₂ lë́₅ të₂dsɨ́₅.
\p 
\v 25 Tsá₃ 'e₂ ca₂rë₃'nió'₅ quió'₅, jua'₅₄ a₂jáng'₃ dsa₂ jág₁ dsau₅ juɨ₁lia'₂ quió'₅ 'i₁jan₂, ia₁ ma₂ŋi₅ rë₂ bá₄ Jesús 'e₂ a₂qui₂dsɨ₂jŋia₅ dsɨ́₅ dsa₂ mɨ₂güɨ́g₃.
\c 3
\s1 Jme₂tag₅ Jesús jme₂tɨin₂₃ Nicodemo
\p 
\v 1 Jme₁chan₂ jan₂ dsa₂ fariseo i₂jme₁chen₂ Nicodemo, i₂jme₁lɨ́n₄ jan₂ dsa₂ dsen₅₄ quián₅ dsa₂ judíos.
\p 
\v 2 Ŋe₄ 'éi₂ ca₂i₁jɨin₁₂ Jesús të₂le₃ ca₂nei₂, jaun₂ ca₂juá'₂ ca₂tsɨ́'₃ Jesús:
\p ―Të₅, ne₄ bá₄ jnia'₅₄ a₂lɨ́n'₅ 'ne₂ jan₂ të₅ i₂chen₄ quián₅ Diú₄, ia₁ ca₂lia'₂ 'i₁jan₂ tsá₃ lé₂ le₃jmo₃ léi₄ juë'₂ le₂në₅, juɨ₁lia'₂ jmo'₂ 'ne₂, jua'₅₄ tsá₃ quiong'₅₄ Diú₄.
\p 
\v 3 Jaun₂ në́₃ ca₂juá'₂ Jesús ca₂tsɨ́'₃ Nicodemo:
\p ―A₂dsɨ₂jó'₃ juɨ́g₂ jniá₂ 'ne₂, në₁jua'₂ tsá₃ rë₂chan₂ táng₃ dsa₂, tsá₃ lé₂ le₃jág₃ ja₁gon₂ Diú₄.
\p 
\v 4 Jaun₂ ca₂ŋag₃ Nicodemo:
\p ―¿'A₂ bá₄ lia'₂ lé₂ le₃chan₂ táng₃, jan₂ dsa₂ ma₂juɨn'₂? ¿Lé₂ le₃'í₂ táng₃ né'₃ të₂dsɨ́₅ chog₅₄, jaun₂ le₃chain₂ táng₃?
\p 
\v 5 Jaun₂ ca₂ŋag₃ Jesús:
\p ―A₂dsɨ₂jó'₃ juɨ́g₂ jniá₂ 'ne₂, juɨ₁lia'₂ i₂tsá₃ rë₂chan₂ le₃quió'₅ jmɨg₂, quian'₅₄ le₃quió'₅ Jme₂dsí₂, tsá₃ lé₂ le₃'í₂ ja₁gon₂ Diú₄.
\v 6 Juɨ₁lia'₂ i₂rë₂chan₂ le₃quió'₅ nɨ₁ŋɨ́₅, jan₂ dsa₂ nɨ₁ŋɨ́₅ bá₄ 'éi₂; juɨ₁lia'₂ i₂rë₂chan₂ le₃quió'₅ Jme₂dsí₂, jan₂ dsa₂ i₂gu₂dsí₂ bá₄ lɨ́n₅ 'éi₂.
\v 7 Tsá₃ juɨ₁dsi₂gó'₃ 'au'₂ 'ne₂ a₂juá'₅ jniá₂: “Tion₅₄ bá₄ le₃chan'₂ 'nia'₂ táng₃.”
\v 8 'Ag₅ dsí₂ juɨ₁'a₂ guë́₃ já'₄ 'nio₃ 'ag₃; nag'₂ bá₄ 'ne₂ mɨ'₅₄ a₂lë́₂, la₁ia₁ tsá₃ ŋi'₅₄ a₂já'₄ já₅, on₃ guë'₂ a₂já'₄ dsó₃. Ján₃ bá₄ le₂në₅ lɨ́n₅ ca₂le₃jɨ́n₃ i₂rë₂chan₂ le₃quió'₅ Jme₂dsí₂.
\p 
\v 9 Jaun₂ në́₃ ca₂ŋag₃ táng₃ Nicodemo:
\p ―¿'A₂ bá₄ lia'₂ lé₂ le₃lé₂ a₂juá'₂ 'ne₂ në₅?
\p 
\v 10 Jaun₂ ca₂ŋag₃ Jesús:
\p ―¿'Ne₂ guë'₂ lɨ́ng'₅ jan₂ të₅ quián₅ dsa₂ juɨg₂ Israel, ton'₂ tsá₃ ŋɨ́'₂ bá₄ guë́₄ 'au'₂ jág₁ në₅?
\v 11 A₂dsɨ₂jó'₃ juɨ́g₂ jniá₂ 'ne₂, juɨ₁lia'₂ a₂ma₂tag₂ bá₄ jnia'₅₄, dsia₂; ján₃ bá₄ jang'₂ jnia'₅₄ jág₁ dsau₅ juɨ₁lia'₂ a₂ma₂të́₂ ne₄ jnia'₅₄. La₁ 'nia'₂ në́₃ tsá₃ gue'₂ jág₁ dsau₅ a₂jang'₂ jnia'₅₄.
\v 12 Chi₂jua'₂ ma₂në₂juá'₃ jniá₂ a₂'ë₂₃ juɨ₁lia'₂ a₂cha₂ mɨ₂güɨ́g₃ la₂, ton'₂ tsá₃ 'én'₂ bá₄ guë'₂ 'nia'₂, ¿'a₂ bá₄ guë'₂ lia'₂ le₃'én'₂ 'nia'₂ jág₁ quió₃ në₁ca₂juá'₃ jniá₂ ca₂juɨ́g₂ 'nia'₂ a₂'ë₂₃ juɨ₁lia'₂ a₂cha₂ guei'₅₄ i₂juɨ́g₃?
\p 
\v 13 ’Ca₂lia'₂ 'i₁jan₂ tsá₃ 'ein₂ ma₂uɨ́g₂ guei'₅₄ i₂juɨ́g₃, jŋia'₅₄ lia'₂ 'éi₂ i₂ca₂sión₃ guei'₅₄ i₂juɨ́g₃; co₂'nió'₄ 'ŋiog₅ Jaun₅ dsa₂ mɨ₂güɨ́g₃.\f + \fr 3:13 \ft A₂lɨn₅₄ chog₅₄ si₂ juá'₂ ján₃: “i₂'en₅₄ guei'₅₄ i₂juɨ́g₃.” \f*
\v 14 Juɨ₁lia'₂ ca₂chón'₂ Moisés dsɨ₂mɨ'₂ guei'₅₄ ja₁lë́₄ 'uë₃ quein₂ co₂'ŋiog₅ jaun₂, ján₃ bá₄ le₂jaun₂ 'i₄ 'éi'₃ chón'₂ dsa₂ guei'₅₄ Jaun₅ dsa₂ mɨ₂güɨ́g₃,
\v 15 ia₁jaun₂ ca₂le₃jɨ́n₃ i₂'én₂ të₂le₃ quió'₅ 'éi₂, le₃chain₂ co₂tan₅₄.
\s1 'Nio₃ Diú₄ dsa₂ mɨ₂güɨ́g₃
\p 
\v 16 ’Jaun₂, 'uɨg₅₄ ia₁ a₂ŋɨ́₄ lë₃ ca₂rë₃'nio₃ Diú₄ ca₂rë₃'nioi₃ dsa₂ mɨ₂güɨ́g₃, ca₂cuɨin₃ Ja₁ŋi'₅₄ i₂jan₂ tan₅₄ quiáin₅, ia₁jaun₂ ca₂le₃jɨ́n₃ i₂'én₂ të₂le₃ quió'₅ 'éi₂, tsá₃ dsɨ₃'éin₂, ton'₂ le₃chain₂ bá₄ co₂tan₅₄.
\v 17 Ia₁ on₃jua'₅₄ jaun₂ ca₂chei₃ Diú₄ ca₂chein₃ Ja₁ŋi'₅₄ mɨ₂güɨ́g₃ a₂qui₃'ë́₂ uɨg₅ ja₁con₂ dsa₂ mɨ₂güɨ́g₃; a₂jaun₂ bá₄ ca₂chei₃ ia₁jaun₂ lión₂ dsa₂ mɨ₂güɨ́g₃ të₂le₃ quian'₅₄ 'éi₂.
\v 18 Juɨ₁lia'₂ dsa₂ i₂'én₂ të₂le₃ quió'₅ 'éi₂, tsá₃ rë₂'ë́₂ uɨg₅ ja₁coin₂; la₁ia₁ juɨ₁lia'₂ i₂tsá₃ 'én₂ guë'₂ në́₃, ma₂rë₂'ë́₂ uɨg₅ ja₁coin₂, 'uɨg₅₄ ia₁ a₂tsá₃ 'éin₂ të₂le₃ quió'₅ Ja₁ŋi'₅₄ i₂jan₂ tan₅₄ quián₅ Diú₄.
\v 19 A₂la₂ bá₄ uɨg₅ a₂rë₂'ë́₂ jaun₂: a₂ma₂gua₅ si₂ ja₁con₂ dsa₂ mɨ₂güɨ́g₃, la₁ ca₂rë₃'nio₃ guë́₄ dsa₂ jë₄ qui₁né'₃ lia'₂ con'₂ guë́₄ ja₁tág₅ si₂, ia₁ a₂'lɨg'₅₄ bá₄ jme₁jmo₂₃-dsáu₅.
\v 20 Ca₂le₃jɨ́n₃ dsa₂ i₂jmo₅ a₂'lɨg'₅₄, 'io'₅₄ si₂, jaun₂ tsá₃ jme₂quiáin₃ ja₁tág₅ si₂, ia₁jaun₂ tsá₃ le₃jniá₂ a₂'lɨg'₅₄ a₂jmo₂₃-dsáu₅.
\v 21 La₁ia₁ juɨ₁lia'₂ dsa₂ i₂chan₂ caun₂ juɨ₅ co₂dsau₅, jme₂quiáin₃ ja₁tág₅ si₂, ia₁jaun₂ le₃jniá₂, le₃quió'₅ Diú₄ bá₄ já₅ a₂dse₃ a₂jmo₅ 'éi₂.
\s1 Jáng'₅ táng₃ jág₁ dsau₅ Juan₅₄ i₂chon₅ dsa₂ jmɨg₂ juɨ₁lia'₂ 'ein₂ 'éi₂ Jesús
\p 
\v 22 Cang₂ jaun₂, ŋó₃ Jesús juɨ₅ 'uë₃ Judea quiain'₅₄ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅, jaun₂ ja₁jaun₂ ca₂'í₃ ca₂la₂ uë́₂ quiain'₅₄ 'éi₂, qui₂choin₂₃ jmɨg₂ dsa₂.\f + \fr 3:22 \ft lit. “qui₂tiáin₂ dsa₂ jmɨg₂.” \f*
\p 
\v 23 Ján₃ bá₄ le₂jaun₂ jme₁'en₅₄ Juan₅₄ në́₃, choin₂₃ jmɨg₂ dsa₂,\f + \fr 3:23 \ft lit. “tiáin₂ dsa₂ jmɨg₂.” \f* caun₂ ja₁chei₂ Enón, ma₂quián₅ Salim, ia₁ ja₁jaun₂ jme₁cha₂ 'lióng₂ jmɨg₂; jaun₂ jme₁ja₂lén₂ dsa₂ ia₁jaun₂ qui₃cho₃ Juan₅₄ jmɨg₂.\f + \fr 3:23 \ft lit. “ia₁jaun₂ qui₃tióg₃ Juan₅₄ jmɨg₂.” \f*
\p 
\v 24 (A₂la₂ ca₂lë₃ né'₃ guë́₄ a₂ton'₂ dsa₂ Juan₅₄ né'₃ 'má₃.)
\p 
\v 25 Jaun₂ në́₃, i₂lɨn₅₄ dsa₂ i₂quian'₅₄ Juan₅₄ ca₂tsɨ́in₂ quian'₅₄ jan₂ dsa₂ judío ne₄ jág₁ juɨ₁lia'₂ a₂jmo₅ dsa₂ le₁jɨ́in₃.
\p 
\v 26 Jaun₂ i₃léin₂ i₁chi'₄ Juan₅₄:
\p ―Të₅, dsa₂ i₂jme₁'en₅₄ quian'₅₄ 'ne₂ të₂le₃ ja₁'ia₂ 'iog₂ të₂le₃ quióng₄ Cuá₃ Jordán, dsa₂ i₂'ɨ́n'₅ 'ne₂ 'éi₂, jë₂ bá₄ choin₂₃ jmɨg₂ dsa₂,\f + \fr 3:26 \ft lit. “jë₂ bá₄ tiáin₂ dsa₂ jmɨg₂.” \f* jaun₂ ca₂le₃jɨ́n₃ bá₄ dsa₂ dsɨ₂léin₂ ja₁coin₂.
\p 
\v 27 Jaun₂ ca₂ŋag₃ Juan₅₄:
\p ―Ca₂lia'₂ 'i₁caun₂ tsá₃ 'e₂ lé₂ le₃cha₂ quió'₅ dsa₂ jua'₅₄ tsá₃ ŋei₂ guei'₅₄ i₂juɨ́g₃.
\v 28 Ca₂nei'₂ bá₄ 'nia'₂ guiong'₅₄ jme₁ca₂juá'₃: “On₃jua'₅₄ jniá₂ lɨ́ng₅ I₂rë₂'ɨ́n₁ quián₅ Diú₄; jan₂ dsa₂ i₂chen₄ ne₄ juɨ₅ quió'₅ 'éi₂ bá₄ lɨ́ng₅.”
\v 29 I₂ca₂tɨ́n₂ dsa₂ ŋe'₂ i₂jen'₂ gu₂ bá₄, dsa₂ mɨ́₂ i₂jen'₂ gu₂ quiain'₅₄. Jaun₂ dsa₂ a₂mei₅₄ quián₅ dsa₂ ŋe'₂ në́₃, chi₁jŋia₁ nag₂₃. Jaun₂ 'io'₂ jén'₅ jë₁ma₂nág₂ jág₁ quió'₅ 'éi₂. Ján₃ bá₄ le₂jaun₂ jniá₂ në́₃, rë₂'ŋia₅ a₂'io'₂ jén'₅ dsɨ₃.
\s1 Juɨ₁lia'₂ i₂já₅ guei'₅₄ i₂juɨ́g₃
\p 
\v 30 ’'Éi₂ ca₂tɨ́n₂ le₃dsein₅₄ guë́₄; jniá₂ guë'₂ ca₂tɨ́ng₂ le₃meg'₂.
\v 31 Juɨ₁lia'₂ i₂já₅ juɨ₅ guei'₅₄ i₂juɨ́g₃, dsen₅₄ guë́₄ ne₄ quió'₅ ca₂le₃jɨ́n₃. Juɨ₁lia'₂ i₂já₅ gua'₅₄ 'uë₃, jan₂ i₂chan₂ gua'₅₄ 'uë₃ bá₄ 'éi₂. Jaun₂ dsia₂₃ juɨ₁lia'₂ a₂quió'₅ gua'₅₄ 'uë₃. La₁ia₁ juɨ₁lia'₂ i₂já₅ guei'₅₄ i₂juɨ́g₃, dsen₅₄ guë́₄ ne₄ quió'₅ ca₂le₃jɨ́n₃.
\v 32 Jáng'₅ 'éi₂ jág₁ dsau₅ juɨ₁lia'₂ a₂ma₂të́₂ ne₅₄, juɨ₁lia'₂ a₂ma₂nág₂ në́₃; la₁ 'i₁jan₂ tsá₃ 'ein₂ tón'₂ juɨ₅ jág₁ dsau₅ a₂jáng'₅ 'éi₂.
\v 33 La₁ia₁ juɨ₁lia'₂ i₂tón'₂ juɨ₅, ma₂cáun₅ 'í₁ a₂dsón'₂ bá₄ tí₅ jág₁ a₂juá'₂ Diú₄;
\v 34 ia₁ i₂ca₂chen₃ Diú₄ në́₃, dsia₂₃ jág₁ quió'₅ Diú₄, ia₁ cuɨn₅ Diú₄ Jme₂dsí₂ quiáin₅ ca₂lia'₂ tsá₃ niog₅ 'éi'₃.
\v 35 A₂'nio₃ Diú₄ Jmei₂ 'nioi₃ Ja₁ŋi'₅₄, jaun₂ o₄gú₃ 'éi₂ ma₂dsia₃ ca₂le₃jë́₃.
\v 36 Juɨ₁lia'₂ i₂'én₂ të₂le₃ quió'₅ Ja₁ŋi'₅₄ Diú₄, le₃chain₂ bá₄ co₂tan₅₄; la₁ juɨ₁lia'₂ i₂tsá₃ ne'₅₄ le₃quió'₅ Ja₁ŋi'₅₄ Diú₄, tsá₃ të₃ ne₅₄ a₂le₃chain₂ rë₂'ŋiai₂₃, ton'₂ të₂le₃ të₃gua₄ 'nei₂ dsɨ́₅ Diú₄ ja₁coin₂.
\c 4
\s1 Dsia₅ Jesús jág₁ quian'₅₄ jan₂ 'io₅₄ i₂chan₂ Samaria
\p 
\v 1 Jme₁ca₂rë₃ŋi₅ Te₁gui'₅₄ a₂ma₂nág₂ dsa₂ fariseos jág₁, 'ŋio₅ lɨn₃ guë́₄ juɨn₅ dsa₂ i₂ma₂quian'₅₄ Jesús, qui₂ma₂cho₃ jmɨg₂\f + \fr 4:1 \ft lit. “qui₂ma₂tióg₃ jmɨg₂.” \f* lia'₂ con'₂ guë́₄ Juan₅₄;
\v 2 (o₁jŋia'₅₄ on₃jua'₅₄ 'ŋiog₅ Jesús choin₂₃ jmɨg₂ dsa₂,\f + \fr 4:2 \ft lit. “tiáin₂ dsa₂ jmɨg₂.” \f* jŋia'₅₄ lia'₂ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅ bá₄),
\v 3 jaun₂ ca₂o₃'ɨ́in₃ 'uë₃ Judea, a₂ŋái'₃ táng₃ juɨ₅ 'uë₃ Galilea.
\v 4 Ja₁tioin'₅₄ juɨ₅ jaun₂, ca₂tɨ́in₂ ŋɨ́i₃ 'uë₃ Samaria.
\v 5 Jaun₂ në́₃ ca₂dsi₃léin₂ caun₂ juɨg₂ ja₁tén₄ Samaria a₂chei₂ Sicar, ma₂quián₅ ca₂jne₄ 'uë₃ a₂jme₁ca₂cuë₃ Jacob ma₂lɨ́g'₂ ca₂cuë́'₃ ja₁ŋi'₅₄ i₂chen₂ Së́₄.
\p 
\v 6 Ja₁jaun₂ jme₁dsi₅₄ caun₂ tau₂ pozo a₂të́'₂ dsa₂ a₂quió'₅ Jacob. Jaun₂ ca₂guá₂ Jesús cau₅, ia₁ a₂ca₂'ú'₃ 'ein₅₄ juɨ₅. Jme₁ma₂ca₂të́₂ con'₂ dsi₂ŋí'₃ jaun₂.
\p 
\v 7 Të₃ guá₅ jaun₂ ca₂dsióg₃ jan₂ 'io₅₄ i₂chan₂ Samaria a₂i₃dsein₂₃ jmɨg₂ pozo jaun₂. Jaun₂ ca₂juá'₂ Jesús ca₂tsɨ́'₃ 'io₅₄ 'éi₂:
\p ―Cuë₄ ca₂juɨg₄ jmɨg₂ guɨ'₅₄.
\p 
\v 8 Të₁lia'₂ jaun₂, i₁len₅₄ jë₄ juɨg₂ chi'₂ dsɨ₂guia₃-tɨ́n₂, i₁lia₅ má₃ a₂guë́'₃.
\p 
\v 9 Jaun₂ në́₃ ca₂juá'₂ 'io₅₄ chan₂ Samaria 'éi₂ ca₂tsɨ́'₃ Jesús:
\p ―¿'A₂ lia'₂ lë́₅ jaun₂, 'ne₂ jan₂ dsa₂ i₂lɨ́n₅ judío, mɨ'₂ jmɨg₂ ne₃ jniá₂, jan₂ 'io₅₄ chan₂ Samaria?
\p (Ia₁ tsá₃ jág₁ 'ei₅ dsa₂ judíos quian'₅₄ dsa₂ chan₂ Samaria.)\f + \fr 4:9 \ft o₃, “tsá₃ jmó'₂ dsa₂ judíos ta₁ juɨ₁lia'₂ nɨ₁uɨng₅ a₂jmó'₂ dsa₂ chan₂ Samaria ta₁.” \f*
\p 
\v 10 Jaun₂ në́₃ ca₂ŋag₃ Jesús:
\p ―Jua'₅₄ mei'₂ guë́₃ ŋi'₅₄ 'ne₂ 'e₂ jaun₂ a₂cuë₅ Diú₄, quian'₅₄ 'ein₂ i₂mɨ₅ jmɨg₂ ne'₅₄, jme₁mɨ́'₂ ne₃ jniá₂, jaun₂ jniá₂ në́₃ cuë₅₄ jmɨg₂ jén'₃.
\p 
\v 11 Jaun₂ ca₂juá'₂ 'io₅₄ ca₂tsɨ́'₃ Jesús:
\p ―Gui'₅₄, tsá₃ ŋí₁ cubeta cha₂ quiáng'₂ a₂dséng'₄ jmɨg₂, ton'₂ a₂jɨ'₂ bá₄ tau₂ pozo. ¿'A₂ guë'₂ já'₄ cán'₁ jmɨg₂ jén'₃ a₂cuë́'₂ jniá₂?
\v 12 ¿'E₂, 'ne₂ lɨ́ng'₅ i₂juɨn'₂ guë́₄ con'₂ guë́₄ 'lag₄ jmei₂ jniog₄ Jacob, i₂ca₂cuë₃ pozo la₂? Jme₁cán₂ 'éi₂ jmɨg₂ a₂'ɨ́n'₂ 'ŋiog₅ quian'₅₄ chi'₂ quiáin₅, quian'₅₄ já'₂ quiáin₅ në́₃.
\p 
\v 13 Jaun₂ ca₂ŋag₃ Jesús:
\p ―Ca₂le₃jɨ́n₃ juɨ₁lia'₂ dsa₂ i₂'ɨ́n'₂ jmɨg₂ la₂, lé₂ táng₃ dsɨ́₅ i₁'ɨ́n'₂ jmɨg₂;
\v 14 la₁ia₁ juɨ₁lia'₂ i₂'ɨ́n'₂ jmɨg₂ a₂cuë́₄ jniá₂, lia'₂ o₁lɨ́g'₂ jmɨg₄ tsá₃ ma₃lé₂ dsɨ́₅ i₁'ɨ́n'₂ jmɨg₂. Ia₁ juɨ₁lia'₂ jmɨg₂ a₂cuë́₄ jniá₂, lé₂ në₂jag₄ bá₄ caun₂ o₄tu₁ jmɨg₂ të₂le₃ quió'₅, a₂qui₃'iá₃ jmɨg₂ a₂gu₂dsí₂ a₂jmo₃ a₂le₃chain₂ co₂tan₅₄.
\p 
\v 15 Jaun₂ në́₃ ca₂juá'₂ 'io₅₄ ca₂tsɨ́'₃ Jesús:
\p ―Gui'₅₄, cuë₄ jmɨg₂ a₂'ë'₂ në₅, ia₁jaun₂ tsá₃ ma₃le₃quein₂ dsɨ₃, on₃ guë'₂ caun₂ guio₅₄ guë́₄ ca₂të₂ la₂ i₁dséng₃ jmɨg₂.
\p 
\v 16 Jaun₂ ca₂juá'₂ Jesús:
\p ―Guan'₂ o₂te'₂ dsɨ₂i₂gog'₂, jaun₂ ŋe'₅₄ táng₃ ja₁lá₃.
\p 
\v 17 Jaun₂ ca₂ŋag₃ 'io₅₄ 'éi₂:
\p ―Tsá₃ dsɨ₂i₂gu₃ jniá₂ chan₂.
\p Jaun₂ në́₃ ca₂juá'₂ Jesús:
\p ―Tí₅ bá₄ jág₁ quiáng'₂ a₂në₂jua'₅₄, a₂tsá₃ chan₂ dsɨ₂i₂gog'₂;
\v 18 ia₁ 'ŋiá₂ dsɨ₂i₂gog'₂ i₂ma₂ca₂né'₂ quiang'₅₄, jaun₂ i₂ŋéi'₂ quiang'₅₄ rë₂në́₃ ján₃, on₃jua'₅₄ dsɨ₂i₂gog'₂ 'éi₂. Dsón'₂ bá₄ tí₅ jág₁ quiáng'₂ a₂në₂jua'₅₄.
\p 
\v 19 Jme₁ca₂nág₂ 'io₅₄ jág₁ në₅, ca₂juá'₂ ca₂tsɨ́'₃ Jesús:
\p ―Te₁gui'₅₄, dsón'₂ bá₄ lɨ́n'₅ 'ne₂ jan₂ dsa₂ i₂'ë́₂ jág₁ quián₅ Diú₄, lɨ́n₂ jniá₂.
\v 20 Ja₁chí'₄ má'₂ la₂ ca₂jme₃juɨn'₂ dsa₂ can'₅₄ quián₂ jnia'₅₄ ca₂jme₃juɨin'₂ Diú₄ ma₂lɨ́g'₂, la₁ia₁ 'nia'₂ i₂lɨ́ng'₅ dsa₂ judíos në́₃, juá'₂ Jerusalén bá₄ ja₁ca₂tɨ́n₂ dsa₂ jme₃juɨin'₂ Diú₄.
\p 
\v 21 Jaun₂ ca₂ŋag₃ Jesús:
\p ―Juɨ₁le₂'éng'₂ bá₄ a₂juá'₅ jniá₂: já₅ caun₂ jmɨg₄ a₂jme₁juɨn'₂ 'nia'₂ Diú₄, on₃jua'₅₄ i₁nóg'₅ má'₂ la₂, on₃ guë'₂ o₁nó'₅ 'nia'₂ Jerusalén.
\v 22 'Nia'₂ jme₂juɨ́ng'₁ të₃ tsá₃ ŋi'₅₄ 'ein₂ jme₂juɨ́ng'₁; a₂dsau₅ bá₄ jnia'₅₄, ne₄ jnia'₅₄ 'éin₂ i₂jme₂juɨ́n'₂; ia₁ të₂le₃ quió'₅ dsa₂ judíos bá₄ já₅ jág₁ a₂lión₂ dsa₂.
\v 23 La₁ já₅ hora, ton'₂ ma₂të́₂ dsón'₂, a₂jme₃juɨn'₂ dsa₂ Jmei₂, juɨ₁lia'₂ dsa₂ i₂jme₂juag'₂ të₃dsón'₂, jme₃juag'₂ të₂le₃ gu₂dsí₂ ton'₂ të₂le₃ quian'₅₄ jág₁ dsau₅. Ia₁ i₂le₂'éi₂ bá₄ 'na'₂ Jmei₂ jme₃juag'₂.
\v 24 A₂lɨ́n₅ Diú₄ jme₂dsí₂; jaun₂ juɨ₁lia'₂ i₂jme₂juag'₂, ca₂tɨ́in₂ jme₃juag'₂ të₂le₃ gu₂dsí₂ ton'₂ të₂le₃ quian'₅₄ jág₁ dsau₅.
\p 
\v 25 Jaun₂ ca₂juá'₂ 'io₅₄:
\p ―Guion₄ jniá₂ a₂jiá₃ Mesías, (i₂të́'₂ dsa₂ I₂rë₂'ɨ́n₁ quián₅ Diú₄). Jë₁ma₂guain₂₃, jaun₂ guë́₄ juá'₂ ca₂le₃jë́₃ lia'₂ rë₂jiá₃.
\p 
\v 26 Jaun₂ ca₂juá'₂ Jesús:
\p ―Jniá₂ bá₄ 'éi₂, i₂dsia₅ jág₁ quian'₅₄ 'ne₂.
\p 
\v 27 Të₁lia'₂ jaun₂, ca₂o₃len₃ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅, jaun₂ ca₂i₃gó'₃ dsɨ́₅ jme₁ca₂jág₃ a₂dsia₅ Jesús jág₁ quian'₅₄ jan₂ 'io₅₄. La₁ia₁ lia'₂ 'i₁jan₂ tsá₃ ca₂tiá₂ dsɨ́₅ ŋag₃ 'e₂ 'no'₂, 'e₂ jág₁ dsia₂₃ quiain'₅₄ 'io₅₄ 'éi₂.
\p 
\v 28 Jaun₂, ja₁jaun₂ ca₂chi'₃ 'io₅₄ nɨ₁dsɨg₁ quió'₅, jaun₂ ŋái'₃ jë₄ juɨg₂, jaun₂ ca₂juá'₂ ca₂tsɨ́'₃ dsa₂:
\p 
\v 29 ―I₂nó'₅ 'nia'₂ i₂jɨn₄ jan₂ dsa₂ ŋe'₂ i₂ma₂në₂juá'₂ ca₂le₃jë́₃ 'e₂ a₂ma₂jmo₃ jniá₂. ¿On₁jua'₅₄ mei'₂ tsá₃ 'éi₂ lɨ́n₅ I₂rë₂'ɨ́n₁ quián₅ Diú₄?
\p 
\v 30 Jaun₂ në́₃ ca₂'uɨn₂ dsa₂ jë₄ juɨg₂ ca₂i₃léin₂ ja₁guá₄ Jesús.
\p 
\v 31 Të₁lia'₂ jaun₂, ca₂chi₃quióng₂ jmɨg₄ chi'₂ dsɨ₂guia₃-tɨ́n₂ chi₂quiáin₂ jmɨg₄ Jesús a₂guë́'₃, juá'₂:
\p ―Të₅, qué'₂ ca₂la₂.
\p 
\v 32 Jaun₂ ca₂juá'₂ Jesús:
\p ―Cha₂ caun₂ má₃ a₂guë'₅₄ jniá₂, a₂tsá₃ cuɨn'₂ 'nia'₂.
\p 
\v 33 Jaun₂ në́₃ qui₂ca₂ŋɨ́'₃ chi'₂ dsɨ₂guia₃-tɨ́n₂ rɨin'₅₄, jain₂ jain₂:
\p ―¿On₃ bá₄ chan₂ jan₂ i₂ma₂o₃can₅ má₃ a₂guë́'₃?
\p 
\v 34 La₁ ca₂juá'₂ Jesús ca₂tsɨ́'₃ 'éi₂:
\p ―A₂jaun₂ bá₄ má₃ quió₃ jniá₂, a₂jmo₅₄ 'éi'₃ a₂'ŋio₂ dsɨ́₅ i₂ca₂chei₃, a₂jme₁'ŋiag₅ ta₁ quió'₅ në́₃.
\v 35 ¿'On₁ juá'₂ guë'₂ 'nia'₂: “'Ei₅ bá₄ guë́₄ quén₂ tsɨ'₂ a₂ráu₃”? La₁ia₁ jniá₂ juɨ́g₂ 'nia'₂, jag₄ 'a₂ lia'₂ ma₂tion'₅₄ dsa₂ le₁jŋia₂₃, në₂jag₄ bá₄ a₂le₁chein'₂ ja₁nau₂ ca₂ron₂, ma₂lé₂ bá₄ cág'₃.
\v 36 Juɨ₁lia'₂ dsa₂ i₂jmo₅ ta₁ ja₁nau₂ në́₃ gue₂₃ 'liain'₅₄. Juɨ₁lia'₂ a₂ráu₃, a₂cág'₃ ja₁nau₂ jaun₂, a₂jiog₃ co₂tan₅₄ bá₄ jaun₂, ia₁jaun₂ co₂lë₅ bá₄ jmo₃ 'io'₂, lia'₂ dsa₂ i₂jne₅, lia'₂ dsa₂ i₂cág'₅ në́₃.
\v 37 Le₂në₅ dsón'₂ bá₄ quio₃\f + \fr 4:37 \ft quio₃: Jág₁ quió'₅ dsa₂ Jen'₅₄, co₂'nió'₄ le₃jua'₅₄, caun₂ jág₁ a₂ŋɨ́'₂ dsɨ́₅ a₂ca₂quiog₂ dsa₂ can'₅₄, a₂dsia₅ dsa₂.\f* a₂dsia₅ dsa₂: “Jan₂ i₂jne₅, i₂sián'₂ i₂cág'₅.”
\v 38 Jniá₂ ma₂tsɨ́ng₂ 'nia'₂ a₂o₁cag'₄ ja₁tsá₃ ta₁ ma₂jmo'₅₄ 'nia'₂ guiong'₅₄, ta₁ ma₂jmo₃ i₂sián'₂; jaun₂ 'nia'₂ në́₃ ca₂lɨng'₃ ta₁ quió'₅ dsa₂ 'éi₂.
\p 
\v 39 Juɨn₅ dsa₂ i₂chan₂ Samaria i₂tián'₅ juɨg₂ jaun₂ ca₂rë₃'éin₂ të₂le₃ quió'₅ Jesús jme₁ca₂nág₂ jág₁ dsau₅ a₂ca₂jáng'₃ 'io₅₄, jme₁ca₂juá'₂: “Në₂juá'₂ 'éi₂ ca₂le₃jë́₃ 'e₂ a₂ma₂jmo₃ jniá₂.”
\p 
\v 40 'Uɨg₅₄ jaun₂ në́₃, jme₁ca₂o₃lén₂ dsa₂ chan₂ Samaria, ca₂chi₃quiáin₂ jmɨg₄ Jesús a₂jme₁jŋia₃ 'éi₂ quiong'₅₄. Jaun₂ ca₂jŋia₃ Jesús tɨn₃ jmɨg₄ ja₁jaun₂.
\p 
\v 41 Jaun₂ të₂le₃ juɨn₅ guë́₄ dsa₂ ca₂rë₃'én₂ jme₁ca₂nág₂ jág₁ a₂juá'₂ 'ŋiog₅ Jesús.
\p 
\v 42 Jaun₂ ca₂juá'₂ dsa₂ ca₂tsɨ́'₃ 'io₅₄:
\p ―Në₃ guë́₄ në́₃ 'éin₂ jnia'₅₄, on₃jua'₅₄ 'uɨg₅₄ jág₁ a₂ca₂jua'₅₄ 'ne₂, ia₁ a₂ma₂në₂néi₁ jnia'₅₄ guio₅₄ jág₁ quió'₅, jaun₂ ne₄ jnia'₅₄, të₃dsón'₂ bá₄ 'éi₂ lɨ́n₅ dsa₂ i₂lión₂ dsa₂ mɨ₂güɨ́g₃.\f + \fr 4:42 \ft A₂lɨn₅₄ chog₅₄ si₂: “Të₃dsón'₂ bá₄ 'éi₂ lɨ́n₅ I₂rë₂'ɨ́n₁ quián₅ Diú₄, i₂lión₂ dsa₂ mɨ₂güɨ́g₃.” \f*
\s1 Ca₂jme₃'lión₂ Jesús jan₂ ja₁ŋi'₅₄ jan₂ dsa₂ dsen₅₄ quián₅ dsɨ₂tan₅₄
\p 
\v 43 Jme₁ca₂dsan₃ tɨn₃ jmɨg₄ jaun₂, ca₂o₃'ɨ́in₃ ja₁jaun₂, ca₂'í₃ juɨ₅ ŋái'₃ juɨ₅ 'uë₃ Galilea.
\p 
\v 44 Ia₁ juɨ₁lia'₂ ca₂juá'₂ 'ŋiog₅ Jesús, juɨ₁lia'₂ jan₂ dsa₂ i₂'ë́₂ jág₁ o₄quió'₄ Diú₄, tsá₃ jme₂go₃ dsa₂ juɨg₂ go₅₄.
\p 
\v 45 Jme₁ca₂dsiáin'₃ 'uë₃ Galilea në́₃, ca₂guei₃ bá₄ dsa₂ dse₃ ja₁jaun₂, ia₁ jme₁ma₂ca₂jág₃ bá₄ ca₂le₃jë́₃ 'e₂ a₂ca₂jmo₃ Jesús juɨg₂ Jerusalén jme₁ca₂të́₂ Jmɨg₄ Të₂'ɨn₅₄, ia₁ ján₃ bá₄ jme₁i₁len₅₄ 'éi₂ jmɨg₄.
\p 
\v 46 Jaun₂ në́₃, ca₂dsióg₃ táng₃ juɨg₂ Caná a₂tén₅ 'uë₃ Galilea ja₁ca₂jme₃tsɨ́in₃ jmɨg₂ ca₂jmo₃ vino. Ja₁jaun₂ jme₁'en₅₄ jan₂ dsa₂ i₂jme₂ti₃ ta₁ ne₄ rag₅₄, i₂chan₂ jan₂ chi'₂ dso'₅₄ quiáin₅, jë₄ juɨg₂ Capernaum.
\p 
\v 47 Jme₁ca₂rë₃ŋi₅ dsa₂ 'éi₂ a₂ma₂ŋɨ₅ Jesús 'uë₃ Galilea, 'ein₅₄ juɨ₅ a₂o₂'ɨ́in₃ 'uë₃ Judea, jaun₂ ŋei₅₄ ca₂i₁jɨin₁₂ Jesús, jaun₂ ca₂chi₃quióng₂ jmɨg₄ tion₅₄-jan₃ a₂dsó₃ 'éi₂ ja₁quió'₄ a₂jme₃'lióin₂ ja₁ŋi'₅₄ i₂ron₅ ma₂i₁jón₂.
\p 
\v 48 Jaun₂ në́₃ ca₂juá'₂ Jesús:
\p ―Tsá₃ 'én'₂ 'nia'₂ në₁jua'₂ tsá₃ ca₂jag'₅₄ léi₄ juë'₂ a₂dsɨ₂gó'₃ 'au'₂.
\p 
\v 49 Jaun₂ ca₂juá'₂ dsa₂ i₂jme₂ti₃ ta₁ ne₄ rag₅₄ 'éi₂:
\p ―Te₁gui'₅₄, i₂ŋáu'₂ uë́₃ ŋia₅, né'₃ guë́₄ a₂jón₂ chi'₂ quiáng₃.
\p 
\v 50 Jaun₂ në́₃ ca₂juá'₂ Jesús:
\p ―Guan'₂ bá₄ quiáng'₂; ia₁ i₂chan₂ bá₄ chi'₂ quiáng'₂.
\p Ca₂rë₃'én₂ bá₄ dsa₂ jág₁ a₂ca₂juá'₂ Jesús, jaun₂ ca₂ŋái'₃.
\p 
\v 51 Jaun₂ jme₁ma₂'ein₅₄ juɨ₅ dsiáin'₂, jaun₂ ca₂jme₃jein'₂ dsa₂ i₂jme₂ti₃ ta₁ ne₅₄, jaun₂ ca₂juá'₂ 'éi₂:
\p ―I₂chan₂ bá₄ chi'₂ quiáng'₂.
\p 
\v 52 Jaun₂ ca₂ŋag₃ 'e₂ hora ca₂tág'₃ dsɨ́₅. Jaun₂ ca₂juá'₂ dsa₂ 'éi₂:
\p ―Dsióg₂ con'₂ hora ŋí₁ caun₂ të₂le₃ ca₂'láu₂,\f + \fr 4:52 \ft lit. “hora guio₃.” \f* ca₂jŋia₃ dséi₂ a₂jme₁'i₁.
\p 
\v 53 Jaun₂ ca₂rë₃lí'₄ jmei₂ chi'₂ 'éi₂, hora jaun₂ dé₄ ca₂juá'₂ Jesús: “I₂chan₂ bá₄ chi'₂ quiáng'₂.” Jaun₂ ca₂rë₃'én₂ dsa₂ 'éi₂, quiain'₅₄ ta₁jɨn₂ dsa₂ dsi₂néi₂ quió'₅.
\p 
\v 54 A₂në₅ jë₁ca₂të́₂ táng₃ léi₄ juë'₂ a₂ca₂jmo₃ Jesús, jme₁ca₂o₃'ɨ́in₃ Judea, jme₁guáin'₃ Galilea.
\c 5
\s1 Ca₂jme₃'lión₂ Jesús jan₂ dsa₂ 'lian'₂ i₂ron₅ cau₅ Dsiog₅ Betesda
\p 
\v 1 Cang₂ jaun₂ ca₂jmo₃ dsa₂ judíos caun₂ jmɨg₄, jaun₂ ca₂uɨ́g₂ táng₃ Jesús juɨ₅ Jerusalén.
\p 
\v 2 Jë₄ juɨg₂ Jerusalén jaun₂, cau₅ ja₁lë́₄ caun₂ o₄'né₄ a₂chei₂ quió'₅ Já'₂ Cha'₂, niog₅ caun₂ dsiog₅ a₂chei₂ Betesda\f + \fr 5:2 \ft A₂lɨn₅₄ chog₅₄ si₂: “Betzata”; a₂siá'₂ në́₃: “Betsaida.” \f* quian'₅₄ jág₁ arameo, ja₁lë́₄ 'ŋiá₂ corredor.
\p 
\v 3 Ja₁jaun₂ jme₁tián'₄ 'uë₃ juɨn₅ dsa₂ i₂qui₂le₁dso'₅₄, jë́₃ dsa₂ ten₄, dsa₂ guian'₅₄ quian'₅₄ dsa₂ 'lian'₂ në́₃, a₂chi₁jŋia₂₃ a₂qui₃jë́'₂ jmɨg₂.
\v 4 Ia₁ jme₁lɨn₅₄, sión₅ jan₂ ángel quián₅ Te₁gui'₅₄ ja₁niog₅ dsiog₅ jaun₂, jaun₂ jmo₂₃ qui₂jë́'₂ jmɨg₂. Jaun₂ juɨ₁lia'₂ dsa₂ dso'₅₄ i₂'í₂ le₂'uɨg₅₄ jmɨg₂ jë₁ma₂i₂bi₅₄, jme₁jŋia₅ quió'₅, chi₂jua'₂ 'e₂ dso₄ jme₁lɨ́in₄.\f + \fr 5:4 \ft Chog₅₄ si₂ a₂dse₃ guë́₄ tsá₃ chi₁ton₅ versículo 4.\f*
\p 
\v 5 Ja₁jaun₂ jme₁ron₅ jan₂ dsa₂ dso'₅₄, jme₁ma₂të́₂ guióg₂-guiá₂-jŋiá₂ ŋi₂ roin₂₃ dso'₅₄.
\p 
\v 6 Jme₁ca₂jág₃ Jesús ron₅ dsa₂ dso'₅₄ ja₁jaun₂, jaun₂ jme₁ca₂rë₃lí'₄ ma₂lɨ́g'₂ bá₄ lɨ́in₅ le₂jaun₂, ca₂ŋag₃:
\p ―¿'Niog'₂ 'lióng'₂?
\p 
\v 7 Jaun₂ ca₂ŋag₃ dsa₂ dso'₅₄:
\p ―Gui'₅₄, tsá₃ 'ein₂ chan₂ to'₂ jniá₂ 'ŋió'₃ dsiog₅ jë₁ma₂të́₂ rë₁qui₃jë́'₂ jmɨg₂. Lia'₂ co₂ráun₂ 'nio₃ 'ú₄, i₂sián'₂ bá₄ sión₅ le₂'uɨg₅₄.
\p 
\v 8 Jaun₂ ca₂juá'₂ Jesús:
\p ―Nau₂, chog'₅₄ tsɨ₁jein₁ quiáng'₂, ŋɨ₄ në́₃.
\p 
\v 9 Dsɨ₂juɨ₅ le₂jaun₂ bá₄ ca₂jŋia₃ quió'₅ dsa₂ 'éi₂. Ca₂chóg'₃ tsɨ₁jein₁ quió'₅, jaun₂ ca₂jme₃lióg₃ ca₂ŋɨ₃. A₂jaun₂ ca₂lë₃ caun₂ jmɨg₄ sa₅₄.
\p 
\v 10 Jaun₂ ca₂juá'₂ dsa₂ judíos ca₂tsɨ́'₃ dsa₂ i₂ca₂'lón₂ 'éi₂:
\p ―Jmɨg₄ sa₅₄ bá₄ në₃; tsá₃ 'i₄ 'éi'₃ caun'₅₄ tsɨ₁jein₁ quiáng'₂ jmɨg₄ në₃.
\p 
\v 11 Jaun₂ ca₂ŋag₃ dsa₂ 'éi₂:
\p ―I₂në₂jme₃'lió₂ jniá₂, në₂juá'₂: “Chog'₅₄ tsɨ₁jein₁ quiáng'₂, ŋɨ₄ në́₃.”
\p 
\v 12 Jaun₂ në́₃ ca₂ŋag₃ táng₃ dsa₂ 'éi₂:
\p ―¿'Ein₂ 'éi₂ në₂juá'₂ a₂caun'₅₄ tsɨ₁jein₁ quiáng'₂, a₂ŋɨ́'₂ në́₃?
\p 
\v 13 La₁ tsá₃ ŋi₅ 'ein₂ 'éi₂ i₂në₂jme₃'lió₂ quió'₅, ia₁ jme₁ma₂i₂cón'₅ Jesús jɨn₄ dsa₂ juɨn₅ i₂jme₁tion'₅₄ ja₁jaun₂.
\p 
\v 14 Cang₂ jaun₂ ca₂jen'₂ Jesús ca₂jein'₂ dsa₂ 'éi₂ i₁dsi₅ guá'₅ templo, jaun₂ ca₂juá'₂:
\p ―Jag₄ de'₂, në₃ lia'₂ ma₂'lóng'₂, tsá₃ ma₃lë₁'nau₂ dso₄, ia₁jaun₂ tsá₃ dsɨ₃ŋɨ́g'₂ caun₂ jmɨ₁uɨg₅ 'ŋio₅ guë́₄ con'₂ guë́₄ a₂jme₁lɨ́ng'₄ le₂jŋiá₅.
\p 
\v 15 Jaun₂ ŋá'₃ bá₄ dsa₂ 'éi₂, jaun₂ ca₂i₁chi'₄ dsa₂ judíos, Jesús bá₄ 'éi₂ i₂ca₂jme₃'lió₂ quió'₅.
\p 
\v 16 'Uɨg₅₄ jaun₂ qui₂ca₂co₃'ein₃ dsa₂ judíos quió'₅ Jesús,\f + \fr 5:16 \ft A₂lɨn₅₄ chog₅₄ si₂ a₂me'₂ guë́₄ juá'₂ ján₃: “a₂jme₁'nio₃ jŋag'₃.” \f* ia₁ jme₁tɨn₂ Jesús jme₁jmo₂₃ le₂në₅ jmɨg₄ sa₅₄.
\p 
\v 17 La₁ ca₂juá'₂ Jesús ca₂tsɨ́'₃ dsa₂ judíos:
\p ―Lia'₂ jmo₅ jaun₂ Ŋe'₃ ta₁ jŋia'₅₄ jmɨg₄ në₃; ján₃ bá₄ le₂jaun₂ jmo₅ jniá₂ ta₁.
\p 
\v 18 'Uɨg₅₄ jaun₂, të₂le₃ i₂juɨ'₂ guë́₄ jme₁'nio₃ jŋag'₃ dsa₂ judíos, ia₁ on₃jua'₅₄ jmá'₃ 'éi'₃ jmɨg₄ sa₅₄ jmo₂₃ cau₅, ján₃ bá₄ ca₂të₂ jmo₂₃ a₂lɨ́in₅ co₂rɨin₂ quian'₅₄ Diú₄, ia₁ a₂juá'₂ Diú₄ bá₄ lɨ́n₅ Jmei₂.
\s1 'Éi'₃ a₂ron₅ quió'₅ Ja₁ŋi'₅₄ Diú₄.
\p 
\v 19 Jaun₂ në́₃ ca₂juá'₂ Jesús ca₂tsɨ́'₃ dsa₂ judíos:
\p ―A₂dsɨ₂jó'₃ juɨ́g₂ jniá₂ 'nia'₂, tsá₃ 'e₂ lé₂ le₃jmo₃ Ja₁ŋi'₅₄ 'i₁caun₂ 'ŋiog₅; a₂jaun₂ bá₄ jmo₂₃ juɨ₁lia'₂ a₂jág₅ jmo₅ Jmei₂. Juɨ₁lia'₂ 'e₂ ta₁ a₂jmo₅ Jmei₂, a₂jaun₂ bá₄ jmo₅ Ja₁ŋi'₅₄ ján₃.
\v 20 Ia₁ 'nio₃ Jmei₂ 'nioi₃ Ja₁ŋi'₅₄, jaun₂ 'ë₂₃ 'ë́'₅ Ja₁ŋi'₅₄ ca₂le₃jë́₃ 'e₂ a₂jmo₂₃. Të₂le₃ lë́₅ guë́₄ juë'₂ ta₁ qui₃'ë₃, con'₂ guë́₄ a₂le₂la₂, ia₁jaun₂ qui₂dsɨ₃gó'₃ 'au'₂ 'nia'₂.
\v 21 Ia₁, juɨ₁lia'₂ jme₂jen'₅₄ Jmei₂ jme₂jein'₅₄ 'lag₄, cuë₂₃ jme₂dsí₂ a₂le₃chain₂, ján₃ bá₄ le₂jaun₂ cuë₅ Ja₁ŋi'₅₄ jme₂dsí₂ cuë́'₅ juɨ₁lia'₂ i₂'nio₃ cuë́'₃.
\v 22 Ján₃ guë'₂, tsá₃ con₂ Jmei₂ 'í₁ quió'₅ 'i₁jan₂; o₄gú₃ Ja₁ŋi'₅₄ bá₄ ma₂dsia₃ ca₂le₃jë́₃ 'éi'₃ a₂con₂ 'í₁,
\v 23 ia₁jaun₂ jme₃go₃ ca₂le₃jɨ́n₃ dsa₂ jme₃gain₃ Ja₁ŋi'₅₄, juɨ₁lia'₂ jme₂gain₃ Jmei₂. Juɨ₁lia'₂ i₂tsá₃ jme₂gan₃ Ja₁ŋi'₅₄, tsá₃ jme₂gain₃ Jmei₂ i₂ca₂chei₃.
\p 
\v 24 ’A₂dsɨ₂jó'₃ juɨ́g₂ jniá₂ 'nia'₂: juɨ₁lia'₂ i₂nag₅ i₂tón'₂ juɨ₅ jág₁ quió₃, ton'₂ 'éin₂ të₂le₃ quió'₅ i₂ca₂chei₃, le₃chain₂ bá₄ co₂tan₅₄. Tsá₃ 'í₁ jióg'₂ ja₁coin₂, ia₁ ma₂ca₂ŋɨi₅ ne₄ 'mú₃, ma₂ca₂dsióg₃ ja₁le₃chain₂ co₂tan₅₄.
\v 25 A₂dsɨ₂jó'₃ juɨ́g₂ jniá₂ 'nia'₂, já₅ jmɨg₄ ton'₂ ma₂të́₂ dsón'₂, jë₁ma₂të́₂ rë₁nag₃ 'lag₄ jág₁ quió'₅ Ja₁ŋi'₅₄ Diú₄. Juɨ₁lia'₂ i₂ne'₅₄ në́₃, le₃chain₂ bá₄.
\v 26 Ia₁ juɨ₁lia'₂ 'io₅ bí₂ Jmei₂ a₂le₃chain₂ 'ŋiog₅, ján₃ bá₄ le₂në₅ ma₂cuë́'₃ Ja₁ŋi'₅₄ juɨ₅bí₂ a₂le₃chain₂ 'ŋiog₅.
\v 27 Ján₃ bá₄ ma₂cuë₃ juɨ₅bí₂ a₂con₂ 'í₁ qui₃dsɨ₂₃ 'éi'₃, ia₁ lɨ́in₅ Jaun₅ dsa₂ mɨ₂güɨ́g₃.
\v 28 Tsá₃ lë₁juɨ₁dsi₂gó'₃ 'au'₂ 'nia'₂ jág₁ a₂në₂juá'₃ jniá₂ la₂, ia₁ já₅ hora a₂nag₃ ca₂le₃jɨ́n₃ dsa₂ i₂le₁'on₅ tau₂ 'ŋio₅, jág₁ quió'₅,
\v 29 jaun₂ 'uɨ́in₃ ja₁jaun₂. Juɨ₁lia'₂ i₂ca₂jmo₃ a₂dsi₂ten₅₄, jein'₅₄ a₂dsi₁lein₅ ja₁le₃chain₂ co₂tan₅₄; la₁ia₁ juɨ₁lia'₂ i₂ca₂jmo₃ a₂'lɨg'₅₄, jein'₅₄ a₂të₃dsɨ₅₄ 'éi'₃ ja₁coin₂.
\s1 Jau'₂ 'í₁ a₂dsón'₂ 'io₅ Jesús bí₂
\p 
\v 30 ’Tsá₃ 'e₂ lé₂ le₃jmo₅₄ jniá₂ jua'₅₄ a₂jmo₅₄ con'₂ tɨng₂ 'ŋió₃. Qui₂dsɨ́₂ jniá₂ 'éi'₃ lia'₂ con'₂ lë́₅ jág₁ a₂nég'₄ ja₁con₂ Ŋe'₃, jaun₂ dsi₂ten₅₄ bá₄ 'éi'₃ a₂qui₂dsɨ́₂ jniá₂, ia₁ tsá₃ a₂jaun₂ jmo₅ jniá₂ lia'₂ con'₂ lë́₅ a₂'ŋio₂ dsɨ₃ 'ŋió₃; a₂jaun₂ bá₄ jmo₅ jniá₂ lia'₂ con'₂ lë́₅ a₂'ŋio₂ dsɨ́₅ 'éi₂ i₂ca₂chei₃ jniá₂.
\v 31 Në₁jua'₂ jáng'₅ jniá₂ jág₁ dsau₅ ja₁cong₂ 'ŋió₃, jág₁ jaun₂ a₂jáng'₅, tsá₃ quen₅.
\v 32 La₁ia₁ chan₂ guë́₄ jan₂ i₂sián'₂ i₂jáng'₅ jág₁ dsau₅ të₂le₃ quió₃ jniá₂, jaun₂ guion₄ jniá₂ juɨ₁lia'₂ a₂juá'₂ 'éi₂ 'ag₂₃ jniá₂, tí₅ bá₄ jág₁ a₂jáng'₅.
\v 33 Ca₂chen'₂ 'nia'₂ dsa₂ a₂ca₂i₁ŋag₁₂ ne₄ Juan₅₄, jaun₂ dsón'₂ tí₅ bá₄ jág₁ dsau₅ a₂ca₂jáng'₃ 'éi₂.
\v 34 La₁ia₁ on₃jua'₅₄ jaun₂ chén'₅ jniá₂ rë₂ ia₁ a₂jáng'₅ dsa₂ mɨ₂güɨ́g₃ jág₁ dsau₅ të₂le₃ quió₃ jniá₂; a₂jaun₂ bá₄ juɨ́g₂ jniá₂ 'nia'₂ jág₁ la₂ ia₁jaun₂ lé₂ le₃lión'₂ 'nia'₂.
\v 35 Jme₁lɨ́n₄ Juan₅₄ në₂jag₄ caun₂ si₂ nɨ₁tsɨ́₅ a₂cau₂ a₂tág₅. Jaun₂ 'nia'₂ në́₃, jme₁ma₂'éi'₂ caun₂ 'au'₂ a₂jmó'₂ co₂'na₂ 'io'₂ ja₁tág₅ si₂ quió'₅.
\v 36 La₁ia₁ jniá₂ në́₃, 'ŋio₅₄ jan₂ i₂jáng'₅ jág₁ dsau₅ i₂juɨn'₂ guë́₄ lia'₂ con'₂ guë́₄ Juan₅₄. Ia₁ juɨ₁lia'₂ léi₄ a₂jmo₅ jniá₂, a₂jaun₂ ca₂cuë₃ Ŋe'₃ a₂jmo₅₄. A₂jaun₂ bá₄ jáng'₅ jág₁ dsau₅ a₂dsón'₂ bá₄ ca₂chei₃ Ŋe'₃.
\v 37 Ján₃ bá₄ le₂jaun₂, 'ŋiog₅ bá₄ Ŋe'₃ jniá₂ i₂ca₂chei₃, jáng'₅ 'éi₂ jág₁ dsau₅ të₂le₃ quió₃ jniá₂. 'Nia'₂ në́₃, lia'₂ 'i₁cón'₂ tsá₃ ma₂nei'₂ 'nia'₂ jág₁ quió'₅, on₃ guë'₂ ma₂jɨin'₅₄ 'nia'₂ 'a₂ lia'₂ lɨ́in₅,
\v 38 on₃ guë'₂ ma₂të₁gua₁ jág₁ quió'₅ të₂'au'₂, ia₁ tsá₃ 'én'₂ 'nia'₂ të₂le₃ quió'₅ 'ŋiog₅ i₂ca₂chein₃.
\v 39 A₂'ɨ'₂ 'nia'₂ Si₂ quió'₅ Diú₄ ca₂lia'₂ dsen₅₄ 'au'₂, ia₁ lɨ́n'₂ 'nia'₂ a₂le₃chan₂ 'nia'₂ co₂tan₅₄ të₂le₃ quian'₅₄ Si₂ jaun₂. Si₂ jaun₂ bá₄ jáng'₅ jág₁ dsau₅ 'ag₂₃ jniá₂.
\v 40 Jaun₂ 'nia'₂ në́₃, tsá₃ 'niog'₂ i₁nóg'₅ ne₃ jniá₂ ia₁jaun₂ le₃chan'₂ 'nia'₂.
\p 
\v 41 ’Tsá₃ gue₅ jniá₂ a₂jme₂juag'₂ dsa₂ mɨ₂güɨ́g₃.
\v 42 La₁ cuɨ́n₅ jniá₂ 'nia'₂, jaun₂ guion₄ jniá₂ a₂tsá₃ jaun₂ le₁'i₁ të₂'au'₂ 'nia'₂ a₂niog₅ dsɨ́₅ Diú₄ a₂'nioi₃ 'nia'₂.
\v 43 O₄quió'₄ Ŋe'₃ bá₄ jniá₂ guio₃, 'nia'₂ guë'₂ tsá₃ guéi'₅ jniá₂; la₁ia₁ në₁jua'₂ ca₂já₃ jan₂ o₄quió'₄ 'ŋiog₅, i₂'éi₂ bá₄ guén'₄ 'nia'₂.
\v 44 ¿'A₂ lia'₂ lé₂ le₃'én'₂ 'nia'₂, chi₂jua'₂ jaun₂ 'náu'₂ a₂tióng'₂ rë₂ quiang'₅₄ rɨ́ng'₂, tsá₃ guë'₂ 'náu'₂ 'nia'₂ a₂qui₁náu'₂ rë₂ quiang'₅₄ Diú₄?
\v 45 Tsá₃ o₁len'₂ 'nia'₂ jua'₅₄ a₂'nág₄ jniá₂ ne₄ Ŋe'₃; chan₂ jan₂ i₂'nag₅: Moisés bá₄ 'éi₂. Le₃quió'₅ 'éi₂ bá₄ 'ɨ́n₂ 'au'₂ 'nia'₂.
\v 46 Ia₁ jua'₅₄ mei'₂ guë́₃ ca₂rë₃'éng'₂ jág₁ quió'₅ Moisés, ján₃ bá₄ le₂jaun₂ jme₁le₃'éng'₂ jág₁ quió₃, ia₁ jniá₂ bá₄ ca₂'ag₃ Moisés ne₄ Si₂.
\v 47 La₁ chi₂jua'₂ tsá₃ 'én'₂ guë'₂ 'nia'₂ jág₁ a₂ca₂tó'₂ 'éi₂ ne₄ Si₂, ¿'a₂ guë'₂ lia'₂ lé₂ le₃'én'₂ 'nia'₂ jág₁ a₂juá'₅ jniá₂?
\c 6
\s1 Ca₂ŋɨ'₃ Jesús 'ŋiá₂ mei₅ dsa₂
\r (Mateo 14:13-21; Marcos 6:30-44; Lucas 9:10-17)
\p 
\v 1 Cang₂ jaun₂ ca₂ŋó₃ Jesús të₂le₃ quióng₄ ca₂taun₂ jmɨ₁ŋí'₄ Galilea, (a₂chei₂ jmɨ₁ŋí'₄ Tiberias).
\v 2 Jaun₂ ca₂i₃lén₂ juɨn₅ lɨn₃ dsa₂ chi₁co'₅₄ quió'₅, ia₁ ma₂jág₃ léi₄ juë'₂ a₂ma₂jmo₃, a₂qui₂ma₂ca₂jme₂'lióin₂ dsa₂ i₂jme₁le₁dso'₅₄.
\v 3 Jaun₂ në́₃ ca₂uɨ́g₂ Jesús caun₂ má'₂, jaun₂ ca₂guá₂ ja₁jaun₂ quiain'₅₄ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅.
\p 
\v 4 Jmɨg₄ jaun₂, jme₁ma₂ja₂quián₃ Jmɨg₄ Të₂'ɨn₅₄, co₂'nió'₄ jmɨg₄ quió'₅ dsa₂ judíos.
\p 
\v 5 Jme₁ca₂jág₃ Jesús ca₂jɨ́in₂ juɨn₅ lɨn₃ dsa₂ i₂ja₂lén₂, jaun₂ ca₂juá'₂ ca₂tsɨ́'₃ Felipe:
\p ―¿A₂já'₄ dsɨ₁liá₄ má₃ a₂guë́'₃ ca₂le₃jɨ́n₃ dsa₂ në₅?
\p 
\v 6 A₂jaun₂ bá₄ ca₂juá'₂ Jesús le₂në₅ o₁ne₄ 'e₂ jme₁ŋag₃ Fe₂li₄, ia₁ jme₁ma₂ŋi₅ rë₂ bá₄ Jesús 'ŋiog₅ 'e₂ a₂jmo₃.
\p 
\v 7 Jaun₂ në́₃ ca₂ŋag₃ Fe₂li₄:
\p ―Tɨn₃ 'ŋiá₂-láu₂ denario i₁ŋí'₄ tsá₃ len₅ bá₄ guë́₄ a₂ŋe₂ jma₃ca₂juɨg₄ le₂jan₂ le₂jan₂ dsa₂.
\p 
\v 8 Jaun₂ në́₃ ca₂ŋag₃ guë́₄ jan₂ chi'₂ dsɨ₂guia₃-tɨ́n₂ quián₅ Jesús, i₂jme₁chen₂ Drë́₄ rɨn'₅₄ Si₂mu₅₄ Pe₄:
\p 
\v 9 ―Jë₄ la₂ 'en₅₄ jan₂ i₂bë'₅₄ i₂quian₅ 'ŋiá₂ i₁ŋí'₄ cebada, quian'₅₄ guë'₂ on₃ ju₄; la₁ia₁, ¿'e₂ bá₄ cha₂ 'e₂ jaun₂, ja₁con₂ dsa₂ juɨn₅ le₂në₅?
\p 
\v 10 Jaun₂ në́₃ ca₂juá'₂ Jesús:
\p ―Chei'₅₄ dsa₂ ca₂le₃jɨ́in₃ juɨ₁tiain'₂₃.
\p 'Lióng₂ ŋi₂ma'₂ jme₁cha₂ ja₁jaun₂, jaun₂ ca₂tián'₂ dsa₂ ŋe'₂, i₂jme₁lë́₂ con'₂ 'ŋiá₂ mei₅ dsa₂.
\p 
\v 11 Jaun₂ në́₃ ca₂can₃ Jesús i₁ŋí'₄, jaun₂ jme₁ma₂në₂cuë́'₃ ti₁'mag'₄ Diú₄, qui₂ca₂dsió'₃ ca₂cuë́'₃ ca₂le₃jɨ́n₃ dsa₂ i₂jme₁tián'₄ ja₁jaun₂.\f + \fr 6:11 \ft A₂lɨn₅₄ chog₅₄ si₂ a₂me'₂ guë́₄ juá'₂: “jme₁ma₂në₂cuë́'₃ ti₁'mag'₄ Diú₄, jaun₂ ca₂cuë́'₃ chi'₂ dsɨ₂guia₃-tɨ́n₂, jaun₂ chi'₂ dsɨ₂guia₃-tɨ́n₂ në́₃ qui₂ca₂dsió'₃ ca₂cuë́'₃ ca₂le₃jɨ́n₃ dsa₂.” \f* Ján₃ bá₄ le₂jaun₂ ca₂jmo₃ quian'₅₄ dsɨ₂ju₄ 'éi₂, ca₂cuë́'₃ ca₂le₃jɨ́n₃ dsa₂ 'a₂ con'₂ jŋia'₅₄ 'nio₃.
\p 
\v 12 Jaun₂ jme₁ma₂lɨ́'₃ dsa₂ guë́'₅, ca₂juá'₂ Jesús ca₂tsɨ́'₃ chi'₂ dsɨ₂guia₃-tɨ́n₂:
\p ―Cag'₅₄ 'nia'₂ nɨ₁jne₁ i₁ŋí'₄ a₂ca₂chóng₃, ia₁jaun₂ tsá₃ 'e₂ dsɨ₃'én₂.
\p 
\v 13 Jaun₂ ca₂cág'₃, jaun₂ ca₂jme₃cain'₂ guia₃-tɨ́n₂ tsɨ₁mɨ'₂ tá₂, quian'₅₄ nɨ₁jne₁ a₂ca₂chóng₃ a₂'ŋiá₂ i₁ŋí'₄ cebada jaun₂.
\p 
\v 14 Jaun₂ në́₃, jme₁ca₂jág₃ dsa₂ léi₄ a₂ca₂jmo₃ Jesús, ca₂juá'₂:
\p ―Dsón'₂ bá₄ lɨ́n₅ dsa₂ në₅ dsa₂ i₂'ë́₂ jág₁ quián₅ Diú₄, i₂lë́₅ jág₁ jiá₃ mɨ₂güɨ́g₃.
\p 
\v 15 La₁ ca₂rë₃lí'₄ bá₄ Jesús a₂'nio₃ dsa₂ jme₁të₂ tion₅₄, a₂jme₁jmói'₂ 'éi₂ rag₅₄, jaun₂ ca₂ŋái'₃ bá₄ táng₃ ca₂'í₃ má'₂ con'₂ 'ŋiog₅.
\s1 Ca₂ŋɨ₃ Jesús ne₄ jmɨg₂ jmɨ₁ŋí'₄
\r (Mateo 14:22-27; Marcos 6:45-52)
\p 
\v 16 Jme₁ca₂nei₂ jaun₂, ca₂sión₃ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅ ca₂të₂ jmɨ₁ŋí'₄.
\p 
\v 17 Jaun₂ ca₂tóin'₂ 'ŋió'₃ caun₂ tsɨ₁mu₅, jaun₂ ca₂jme₃lióg₃ ca₂'ain₃ jmɨ₁ŋí'₄ a₂dsɨ₃léin₂ Capernaum. Jme₁ma₂tó'₂ nei₂ bá₄ jaun₂, tsá₃ jme₁ma₂quiong'₅₄ bá₄ guë́₄ Jesús.
\p 
\v 18 Jaun₂ ca₂rë₃lióg₃ ca₂'ág₂ dsí₂ tiá₂ lɨn₃, jaun₂ qui₂ca₂ron'₂ jmɨ₁ŋí'₄.
\p 
\v 19 Jme₁ma₂'ain₂ con'₂ 'ŋiá₂-jŋéi₂ kilómetros, jaun₂ ca₂jág₃ a₂ja₂quián₃ Jesús cau₅ tsɨ₁mu₅, a₂ŋɨ₂₃ ne₄ jmɨg₂; jaun₂ ca₂rë₃gó'₅ 'ŋio₅ lɨn₃.
\p 
\v 20 La₁ia₁ ca₂juá'₂ Jesús:
\p ―¡Jniá₂ bá₄ la₂; tsá₃ lë₁jmo₂ 'nia'₂ gang'₃!
\p 
\v 21 Jaun₂ në́₃ ca₂lia'₂ 'io'₂ jén'₅ bá₄ ca₂guein₃\f + \fr 6:21 \ft o₃, “jme₁guein₃.” \f* Jesús 'ŋió'₃ tsɨ₁mu₅, jaun₂ quian'₅₄ ca₂tiá₂ co₂lág₂ bá₄ ca₂dsi₃léin₂ chei'₅₄ 'uë₃ ja₁jme₁tioin'₅₄ juɨ₅ i₃léin₂.
\s1 'Nau'₂ dsa₂ 'nai'₂ Jesús
\p 
\v 22 Jme₁ca₂jnia₃ jaun₂, ca₂rë₃lí'₄ dsa₂ i₂të₁'ŋiá₄ të₂le₃ quióng₄ ca₂taun₂ jmɨ₁ŋí'₄, a₂jme₁chí'₄ caun₂ tan₅₄ tsɨ₁mu₅ ja₁jaun₂, ton'₂ tsá₃ ca₂'í₃ Jesús 'ŋió'₃ jaun₂ quiain'₅₄ chi'₂ dsɨ₂guia₃-tɨ́n₂; guion₅₄ bá₄ chi'₂ dsɨ₂guia₃-tɨ́n₂ i₃léin₂.
\p 
\v 23 La₁ të₁lia'₂ jaun₂, o₃lé₂ tsɨ₁mu₅ siá'₂ a₂ja₂lei₃ juɨg₂ Tiberias, ca₂o₃lé₂ quián₅ ja₁ca₂guë́'₃ i₁ŋí'₄ le₂jŋiá₅ jme₁ca₂lë₃ cuë́'₅ Te₁gui'₅₄ ti₁'mag'₄ Diú₄.\f + \fr 6:23 \ft A₂lɨn₅₄ chog₅₄ si₂ tsá₃ chi₁ton₅ “jme₁ca₂lë₃ cuë́'₅ Te₁gui'₅₄ ti₁'mag'₄ Diú₄.” \f*
\p 
\v 24 Jaun₂ në́₃, jme₁ca₂rë₃lí'₄ dsa₂ a₂tsá₃ Jesús chan₂ ja₁jaun₂, on₃ guë'₂ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅, ca₂i₃toin'₅₄ 'ŋió'₃ tsɨ₁mu₅, ca₂i₃léin₂ juɨ₅ Capernaum ca₂i₁'niog'₂.
\s1 Jesús bá₄ lɨ́n₅ i₁ŋí'₄ a₂le₃chan₂ dsa₂ co₂tan₅₄
\p 
\v 25 Jme₁ca₂dsi₃lén₂ dsa₂ të₂le₃ quióng₄ ca₂taun₂ jmɨ₁ŋí'₄, ca₂dsáin'₂ Jesús, jaun₂ ca₂ŋag₃:
\p ―Të₅, ¿lɨ́g'₂ guang'₃ ja₁lá₃?
\p 
\v 26 La₁ia₁ ca₂ŋag₃ Jesús ca₂tsɨ́'₃ dsa₂ 'éi₂:
\p ―A₂dsɨ₂jó'₃ juɨ́g₂ jniá₂ 'nia'₂, a₂'nau'₂ jniá₂ i₂niog'₅₄, ia₁ ca₂qué'₂ 'nia'₂ lia'₂ 'ág'₃ 'au'₂ i₁ŋí'₄, on₃jua'₅₄ rë'₂ ia₁ a₂ca₂rë₃ŋɨ́'₂ 'nia'₂ léi₄ jaun₂.
\v 27 Tsá₃ lë₁jmo₂ 'nia'₂ ta₁ o₄quió'₄ má₃ a₂jŋia'₅₄ con'₂ dsɨ₃'én₂, të₂le₃ o₄quió'₄ má₃ a₂jiog₅ co₂tan₅₄ bá₄ jmo₄ 'nia'₂ ta₁, a₂cuë₅ Jaun₅ dsa₂ mɨ₂güɨ́g₃. Ia₁ ne₄ 'éi₂ ma₂tióng₃ 'ŋiog₅ bá₄ Diú₄ Jmei₂ léi₄ quió'₅.
\p 
\v 28 Jaun₂ në́₃ ca₂ŋag₃ dsa₂:
\p ―¿'E₂ 'nió'₅ jmó₁ jnia'₅₄ ia₁jaun₂ lé₂ le₃jmó₁ jnia'₅₄ ta₁ a₂'nio₃ Diú₄ jmó₁?
\p 
\v 29 Jaun₂ ca₂ŋag₃ Jesús:
\p ―A₂la₂ bá₄ ta₁ quió'₅ Diú₄: a₂le₃'én'₂ 'nia'₂ të₂le₃ quió'₅ i₂chen₄ quiáin₅.
\p 
\v 30 Jaun₂ në́₃ ca₂ŋag₃ dsa₂:
\p ―¿'E₂ léi₄ lé₂ le₃'ë́'₂ jnia'₅₄, ia₁jaun₂ jag₅₄ jnia'₅₄ jaun₂ le₃'éin₂ jnia'₅₄ quiáng'₂? ¿'E₂ léi₄ jmó'₂?
\v 31 Dsa₂ can'₅₄ quián₂ jnia'₅₄ ma₂lɨ́g'₂, ca₂guë́'₃ i₁ŋí'₄ maná, lia'₂ con'₂ jme₁tioin'₅₄ 'uë₃ quein₂ co₂'ŋiog₅ jaun₂, juɨ₁lia'₂ juá'₂ ne₄ Si₂ quió'₅ Diú₄: “Ca₂cuë₃ Moisés ca₂guë́'₃ 'éi₂ i₁ŋí'₄ a₂ca₂já₃ guei'₅₄ i₂juɨ́g₃.”\f + \fr 6:31 \ft Éxodo 16:4; Nehemías 9:15; Salmo 78:24-25.\f*
\p 
\v 32 Jaun₂ ca₂ŋag₃ Jesús:
\p ―A₂dsɨ₂jó'₃ juɨ́g₂ jniá₂ 'nia'₂: on₃jua'₅₄ Moisés i₂ca₂cuë₃ i₁ŋí'₄ a₂já₅ guei'₅₄ i₂juɨ́g₃; Ŋe'₃ bá₄ jniá₂ i₂cuë́'₅ 'nia'₂ i₁ŋí'₄ të₃dsón'₂ a₂já₅ guei'₅₄ i₂juɨ́g₃.
\v 33 Ia₁ juɨ₁lia'₂ i₁ŋí'₄ a₂já₅ ja₁con₂ Diú₄, i₂'éi₂ bá₄ lɨ́n₅, i₂ca₂sión₃ guei'₅₄ i₂juɨ́g₃, i₂jmo₅ a₂le₃chan₂ dsa₂ co₂tan₅₄.
\p 
\v 34 Jaun₂ në́₃ ca₂juá'₂ dsa₂ ca₂tsɨ́'₃ Jesús:
\p ―Te₁gui'₅₄, cuë₄ lia'₂ o₂jmɨg₄ i₁ŋí'₄ a₂'ë'₂ 'ne₂ në₅.
\p 
\v 35 Jaun₂ ca₂juá'₂ Jesús:
\p ―Jniá₂ bá₄ lɨ́ng₅ i₁ŋí'₄ a₂jmo₅ a₂le₃chan₂ dsa₂. Juɨ₁lia'₂ i₂ja₂ ja₁con₂ jniá₂, lia'₂ o₁lɨ́g'₂ jmɨg₄ tsá₃ ma₃lé₂ i₁cón'₅; ján₃ bá₄ le₂jaun₂ juɨ₁lia'₂ i₂'én₂ të₂le₃ quió₃ jniá₂, lia'₂ o₁lɨ́g'₂ jmɨg₄ tsá₃ ma₃le₃quein₂ dsɨ́₅.
\v 36 La₁ juɨ₁lia'₂ ma₂në₂juɨ́g₂ jniá₂ 'nia'₂, tsá₃ 'én'₂ 'nia'₂ o₁jŋia'₅₄ ma₂në₂jag'₅₄ 'nia'₂ jniá₂.
\v 37 Ca₂le₃jɨ́n₃ juɨ₁lia'₂ dsa₂ i₂cuɨn₅ Ŋe'₃ cuɨg₂₃ jniá₂, ja₃léin₂ ja₁con₂ jniá₂; jaun₂ juɨ₁lia'₂ i₂ja₂ ja₁con₂ jniá₂, lia'₂ o₁'e₂ guë́₃ tsá₃ dséin₄ jniá₂.
\v 38 Ia₁ on₃jua'₅₄ jaun₂ guio₃ jniá₂ ca₂sióng₃ guei'₅₄ i₂juɨ́g₃ jua'₅₄ a₂jmo₅₄ a₂'ŋio₂ dsɨ₃ 'ŋió₃; a₂jaun₂ bá₄ guio₃ a₂jmo₅₄ a₂'ŋio₂ dsɨ́₅ i₂ca₂chei₃.
\v 39 A₂la₂ bá₄ a₂'ŋio₂ dsɨ́₅ i₂ca₂chei₃: a₂tsá₃ qui₂dsɨ₃cón'₅ 'i₁jan₂ i₂ma₂cuɨn₃ 'éi₂ jniá₂, të₂le₃ a₂jme₁jein'₅₄ bá₄ jniá₂ jmɨg₄ jë₁ca₂tó'₂.
\v 40 A₂la₂ bá₄ a₂'ŋio₂ dsɨ́₅ Ŋe'₃: juɨ₁lia'₂ ca₂le₃jɨ́n₃ i₂jɨ́n₂ Ja₁ŋi'₅₄ ton'₂ 'éin₂ të₂le₃ quió'₅, juɨ₁le₂chain₂ co₂tan₅₄, jaun₂ jniá₂ në́₃ jme₁jein'₅₄ jmɨg₄ jë₁ca₂tó'₂.
\p 
\v 41 Quian'₅₄ jág₁ në₅ ca₂jme₃lióg₃ dsa₂ judíos qui₂ca₂dsia₃ guioin₅₄, ca₂chi₃'ɨin₃ Jesús ia₁ jme₁ma₂në₂juá'₂: “Jniá₂ bá₄ lɨ́ng₅ i₁ŋí'₄ i₂ca₂sión₃ guei'₅₄ i₂juɨ́g₃.”
\p 
\v 42 Jaun₂ ca₂juá'₂:
\p ―¿On₃jua'₅₄ i₂në₅ Jesús ja₁ŋi'₅₄ Së́₄? I₂cuɨn₅ bá₄ jniog₄ chog₅₄-jmei₂ i₂në₅. ¿'A₂ guë'₂ lia'₂ juá'₂ a₂ca₂sióin₃ guei'₅₄ i₂juɨ́g₃?
\p 
\v 43 Jaun₂ në́₃ ca₂juá'₂ Jesús:
\p ―Tsá₃ lë₁ma₃chi₂'ág₅ 'nia'₂.
\v 44 Lia'₂ 'i₁jan₂ tsá₃ lé₂ jiá₃ ja₁con₂ jniá₂, jua'₅₄ tsá₃ o₂jiog₃ Ŋe'₃ i₂ca₂chei₃; jaun₂ jniá₂ jme₁jein'₅₄ jmɨg₄ jë₁ca₂tó'₂.
\v 45 Le₂la₂ ca₂tó'₂ ne₄ Si₂ dsa₂ i₂jme₁'ë́₂ jág₁ o₄quió'₄ Diú₄: “Diú₄ bá₄ jme₃tag₅ jme₃tɨin₂₃ ca₂le₃jɨ́n₃ dsa₂.”\f + \fr 6:45 \ft Isaías 54:13.\f* Jaun₂ ca₂le₃jɨ́n₃ juɨ₁lia'₂ i₂nag₅ jág₁ quió'₅ Ŋe'₃, ton'₂ qui₂rë₂tɨin₂ 'e₂ a₂jmo₅ 'éi₂, ja₃léin₂ bá₄ ja₁con₂ jniá₂.
\v 46 On₃jua'₅₄ rë'₂ ia₁ 'ein₂ ma₂jɨ́n₂ Jmei₂. Jŋia'₅₄ lia'₂ i₂ca₂já₃ ja₁con₂ Diú₄; i₂'éi₂ bá₄ ma₂jɨ́n₂ Jmei₂.
\v 47 A₂dsón'₂ juɨ́g₂ jniá₂ 'nia'₂, juɨ₁lia'₂ i₂'én₂,\f + \fr 6:47 \ft A₂lɨn₅₄ chog₅₄ si₂ juá'₂: “i₂'én₂ të₂le₃ quió₃ jniá₂.” \f* le₃chain₂ co₂tan₅₄.
\v 48 Jniá₂ bá₄ lɨ́ng₅ i₁ŋí'₄ a₂jmo₅ a₂le₃chan₂ dsa₂.
\v 49 Qui₂ca₂guë́'₃ dsa₂ can'₅₄ quián'₂ 'nia'₂ i₁ŋí'₄ maná, lia'₂ con'₂ jme₁tioin'₅₄ 'uë₃ quein₂ co₂'ŋiog₅ jaun₂, la₁ ca₂dsain₃ bá₄.
\v 50 A₂la₂ bá₄ lë́₅ i₁ŋí'₄ a₂ca₂sió₃ guei'₅₄ i₂juɨ́g₃ ia₁jaun₂ në₁jua'₂ 'ein₂ ca₂guë́'₃, tsá₃ dsiáin₃.
\v 51 Jniá₂ bá₄ lɨ́ng₅ i₁ŋí'₄ jén'₃ i₂ca₂sión₃ guei'₅₄ i₂juɨ́g₃ jaun₂; juɨ₁lia'₂ i₂guë́'₅ i₁ŋí'₄ la₂, le₃chain₂ co₂tan₅₄. I₁ŋí'₄ juɨ₁lia'₂ a₂juá'₅ jniá₂ cuë₅₄, nɨ₁ŋɨ₃ 'ŋió₃ bá₄ jniá₂ 'ë₂₃, a₂jáng'₄ jniá₂ ia₁jaun₂ le₃chan₂ dsa₂ mɨ₂güɨ́g₃.
\p 
\v 52 Jaun₂ në́₃ qui₂ca₂chen₃ dsa₂ judíos guioin₅₄, a₂juá'₂:
\p ―¿'A₂ lia'₂ lé₂ le₃cuë₃ i₂në₅ ŋɨ₅₄ 'ŋiog₅ a₂que₅₄ jniog₄?
\p 
\v 53 Jaun₂ ca₂juá'₂ Jesús:
\p ―A₂dsɨ₂jó'₃ juɨ́g₂ jniá₂ 'nia'₂, në₁jua'₂ tsá₃ ca₂qué'₂ 'nia'₂ ŋɨ₄ Jaun₅ dsa₂ mɨ₂güɨ́g₃, në₁jua'₂ tsá₃ ca₂'én'₂ 'nia'₂ jmɨ₂ 'ain₅₄ në́₃, tsá₃ jén'₃ 'nia'₂ të₁lia'₂ chang'₂.
\v 54 Juɨ₁lia'₂ i₂guë́'₅ ŋɨ₃ jniá₂, ton'₂ 'ɨ́n'₂ jmɨ₃ jniá₂ në́₃, le₃chain₂ bá₄ co₂tan₅₄; jaun₂ jniá₂ jme₁jein'₅₄ jmɨg₄ jë₁ca₂tó'₂.
\v 55 Ia₁ nɨ₁ŋɨ₃ jniá₂ bá₄ lë́₅ má₃ a₂tí₅ dsón'₂; ján₃ bá₄ le₂jaun₂ jmɨ₃ jniá₂ lë́₅ jmɨg₂ a₂'ág'₃ dsɨ́₅ të₃dsón'₂.
\v 56 Juɨ₁lia'₂ i₂guë́'₅ ŋɨ₃ jniá₂, ton'₂ 'ɨ́n'₂ jmɨ₃ jniá₂ në́₃, të₂'ŋiai₅₄ le₃quió₃ jniá₂; jniá₂ guë'₂ le₃quió'₅ 'éi₂.
\v 57 Juɨ₁lia'₂ ca₂chei₃ Ŋe'₃ jén'₃ ca₂chei₃ jniá₂, jaun₂ chan₂ jniá₂ 'uɨg₅₄ quió'₅ 'éi₂, ján₃ bá₄ le₂jaun₂, juɨ₁lia'₂ i₂guë́'₅ quió₃ jniá₂, le₃chain₂ 'uɨg₅₄ quió₃ jniá₂.
\v 58 A₂la₂ bá₄ 'ë₂₃ i₁ŋí'₄ i₂ca₂sión₃ guei'₅₄ i₂juɨ́g₃. Qui₂ca₂guë́'₃ dsa₂ can'₅₄ quián'₂ 'nia'₂ i₁ŋí'₄ maná, la₁ ca₂dsain₃; la₁ juɨ₁lia'₂ i₂guë́'₅ i₁ŋí'₄ la₂, le₃chain₂ bá₄ co₂tan₅₄.
\p 
\v 59 Jág₁ në₅ ca₂juá'₂ Jesús të₁lia'₂ ca₂jme₃tag₂₃ dsi₂néi₂ guá'₅ sinagoga jë₄ juɨg₂ Capernaum.
\s1 Jág₁ a₂le₃chan₂ dsa₂ co₂tan₅₄
\p 
\v 60 Jme₁ca₂nág₂ dsa₂ jág₁ jaun₂ a₂jme₂tag₅ Jesús, juɨn₅ dsa₂ i₂quian'₅₄ Jesús ca₂juá'₂:
\p ―Jág₁ a₂juá'₂ në₅ 'ŋio₅ lɨn₃ juɨ́'₅, quian₅ ta₁ guéi₁. ¿'Ein₂ bá₄ lé₂ le₃tón'₂ juɨ₅ quió'₅?
\p 
\v 61 Jaun₂ në́₃ ca₂rë₃lí'₄ Jesús 'e₂ jág₁ chen₅ dsa₂ tioin'₅₄, o₄quió'₄ jág₁ jaun₂, jaun₂ ca₂juá'₂:
\p ―¿O₃ bá₄ tsá₃ dse₃ ca₂tɨ́n'₂ 'nia'₂ jág₁ në₅?
\v 62 ¿'E₂ bá₄ lé₂ jaun₂ në₁jua'₂ ca₂jɨng'₅₄ 'nia'₂ Jaun₅ dsa₂ mɨ₂güɨ́g₃ a₂uɨ́g₂ táng₃ ja₁jme₁'ein₅₄ le₂jŋiá₅?
\v 63 Jme₂dsí₂ bá₄ i₂jmo₅ a₂chan₂ dsa₂; juɨ₁lia'₂ nɨ₁ŋɨ₁ dsa₂ në́₃, tsá₃ ta₁ tí₄. La₁ jág₁ a₂ma₂në₂juɨ́g₂ jniá₂ 'nia'₂, a₂gu₂dsí₂ bá₄ jaun₂, ton'₂ jmo₅ a₂chan₂ dsa₂.
\v 64 La₁ tion'₅₄ bá₄ guë́₄ i₂lɨn₅₄ 'nia'₂ i₂tsá₃ 'én₂.
\p Ia₁ jme₁ma₂ŋi₅ bá₄ Jesús lia'₂ con'₂ le₂'uɨg₅₄ i₂'ein₂ 'éi₂ tsá₃ 'én₂, i₂'ein₂ guë'₂ i₂jáng'₂ cang₂.
\p 
\v 65 Jaun₂ ca₂juá'₂:
\p ―'Uɨg₅₄ jaun₂ ma₂në₂juɨ́g₂ jniá₂ 'nia'₂, lia'₂ 'i₁jan₂ tsá₃ lé₂ jiá₃ ja₁con₂ jniá₂ jua'₅₄ tsá₃ o₂jiog₃ Ŋe'₃.
\p 
\v 66 Ca₂le₃jaun₂, juɨn₅ dsa₂ i₂jme₁i₂nio₄ quiain'₅₄ Jesús ca₂i₃uɨ́in₂ cau₅, tsá₃ ma₃jme₁i₂nioi₅₄ quiain'₅₄ 'éi₂.
\p 
\v 67 Jaun₂ në́₃ ca₂ŋag₃ Jesús ca₂ŋɨ́i'₃ chi'₂ dsɨ₂guia₃-tɨ́n₂:
\p ―¿O₃ bá₄ 'niog'₂ 'nia'₂ o₁nog'₁ ján₃?
\p 
\v 68 La₁ ca₂ŋag₃ Si₂mu₅₄ Pe₄:
\p ―Te₁gui'₅₄, ¿ne₄ 'ein₂ lé₂ dsɨ₁náu₄ jnia'₅₄? Ia₁ 'ne₂ bá₄ 'au'₂ jág₁ a₂le₃chong₂ jnia'₅₄ co₂tan₅₄.
\v 69 Ma₂ca₂rë₃'éin₂ bá₄ jnia'₅₄, jaun₂ ne₄ jnia'₅₄, 'ne₂ bá₄ lɨ́ng'₅ I₂jŋió₅ quián₅ Diú₄.\f + \fr 6:69 \ft A₂lɨn₅₄ chog₅₄ si₂ juá'₂: “'Ne₂ bá₄ lɨ́ng'₅ I₂rë₂'ɨ́n₁ quián₅ Diú₄; 'ne₂ bá₄ lɨ́ng'₅ Ja₁ŋi'₅₄ Diú₄ jén'₃.” \f*
\p 
\v 70 Jaun₂ ca₂ŋag₃ Jesús:
\p ―¿On₁jua'₅₄ jniá₂ ca₂quiong'₅₄ 'nia'₂ ta₁guia₃-tɨ́n'₂? La₁ia₁, jan₂ i₂'en₅₄ jë₄ quián'₂ 'nia'₂ lɨ́n₅ i₂'lɨn'₅₄.
\p 
\v 71 (A₂ca₂juá'₂ Jesús le₂në₅ a₂'ɨin₂₃ Judas bá₄, ja₁ŋi'₅₄ Si₂mu₅₄ Iscariote,\f + \fr 6:71 \ft A₂lɨn₅₄ chog₅₄ si₂ juá'₂: “Judas Iscariote, ja₁ŋi'₅₄ Si₂mu₅₄.” \f* ia₁ Judas bá₄ i₂jáng'₂ quió'₅, o₁jŋia'₅₄ lɨ́in₅ jan₂ dsa₂ guia₃-tɨ́n₂.)
\c 7
\s1 Tsá₃ 'én₂ rɨn'₅₄ Jesús jág₁ quió'₅
\p 
\v 1 Cang₂ jaun₂, ca₂ŋɨ₃ Jesús 'uë₃ Galilea; a₂tsá₃ 'nio₃ dsɨ₃ŋɨ́₃ jë₄ 'uë₃ Judea, ia₁ ja₁jaun₂ jme₁'nio₃ dsa₂ judíos jŋag'₃.
\p 
\v 2 La₁ia₁ jme₁ma₂ja₂quián₃ Jmɨg₄ quió'₅ Tsɨ₁'io₅ Láu₃, jmɨg₄ quió'₅ dsa₂ judíos,
\v 3 jaun₂ ca₂juá'₂ rɨn'₅₄ Jesús:
\p ―Tsá₃ lë₁jan₁ ja₁lá₃; gua₂ juɨ₅ Judea, ia₁jaun₂ jág₃ dsa₂ i₂quiang'₅₄ léi₄ a₂jmo'₂.
\v 4 Ia₁ juɨ₁lia'₂ i₂'nio₃ a₂le₃cuɨg₅ dsa₂ quió'₅, tsá₃ jmo₂₃ juɨ₁lia'₂ a₂tɨin₂₃ jë₄ chi₁'ma₁. Chi₂jua'₂ dsón'₂ jmo'₂ léi₄ le₂në₅, jmo₄ të₃ jág₅ dsa₂ juɨn₅.
\p 
\v 5 Ia₁ ca₂lia'₂ jŋia'₅₄ rɨn'₅₄ bá₄ Jesús tsá₃ jme₁'éin₂ le₃quió'₅.
\p 
\v 6 Jaun₂ në́₃, ca₂juá'₂ Jesús ca₂tsɨ́'₃ rɨin'₅₄:
\p ―Tsá₃ ma₂të́₂ bá₄ guë́₄ hora quió₃ jniá₂, la₁ia₁ të₂le₃ quián'₂ 'nia'₂, jua'₅₄ 'e₂ guë́₃ hora bá₄ dse₃.
\v 7 Tsá₃ lé₂ le₃jme₃'iog₅₄ dsa₂ mɨ₂güɨ́g₃ jme₃'ŋiai₅₄ 'nia'₂; la₁ia₁ 'iog₅₄ bá₄ jniá₂, 'uɨg₅₄ ia₁ a₂jáng'₅ jniá₂ jág₁ dsau₅ ja₁con₂ 'éi₂, a₂'lɨg'₅₄ bá₄ a₂jmo₂₃-dsáu₅.
\v 8 O₂nó'₅ 'nia'₂ guiong'₅₄ jmɨg₄; tsá₃ nei₅₄ jniá₂, ia₁ tsá₃ ma₂dsɨn₃ guë́₄ hora quió₃.
\p 
\v 9 Jme₁ma₂në₂chí'₃ rɨin'₅₄ le₂në₅, ca₂jŋia₃ jë₄ 'uë₃ Galilea.
\s1 Ŋó₃ Jesús Jmɨg₄ quió'₅ Tsɨ₁'io₅ Láu₃
\p 
\v 10 La₁ cang₂ guë́₄ jaun₂, jme₁ma₂i₂lén₂ rɨn'₅₄ Jesús, ján₃ bá₄ ca₂ŋó₃ 'éi₂ jmɨg₄ jaun₂, o₁jŋia'₅₄ ca₂ŋó₃ të₃ tsá₃ jme₂li₅₄ jɨn₄ dsa₂ juɨn₅. Mei'₂ tsá₃ con'₂ të₃co'₅₄ bá₄ ŋó₃.
\p 
\v 11 Jaun₂ lë₃, ca₂i₁nio₁ dsa₂ judíos 'nai'₂ Jesús ja₁niog₅ jmɨg₄, jaun₂ juá'₂:
\p ―¿A₂já'₄ 'en₅₄ dsa₂ 'éi₂?
\p 
\v 12 Jɨn₄ dsa₂ guë'₂, juɨn₅ i₂dsia₅ të₂'ua₁ jɨn₄ rɨin'₅₄ a₂'ɨin₂₃ 'éi₂. I₂lɨn₅₄ juá'₂: “Dsa₂ dsen₃ bá₄ 'éi₂”, la₁ i₂sián'₂ guë'₂ juá'₂: “On₃jua'₅₄ dsa₂ dsen₃ 'éi₂, ia₁ jme₂gain₂₃ dsa₂.”
\p 
\v 13 La₁ia₁ lia'₂ 'i₁jan₂ tsá₃ ca₂dsia₃ lia'₂ rë₂jiá₃ jág₁ a₂'ɨin₂₃ 'éi₂, ia₁ a₂gain₃ dsa₂ judíos.
\p 
\v 14 Con'₂ tɨn₃ dso'₅₄ jmɨg₄ jme₁ma₂të́₂, jaun₂ ca₂'í₃ Jesús i₁dsi₅ guá'₅ templo, jaun₂ ca₂jme₃lióg₃ ca₂jme₃tɨin₂₃ dsa₂.
\p 
\v 15 Jaun₂ ca₂i₃gó'₃ dsɨ́₅ dsa₂ judíos jaun₂ ca₂juá'₂:
\p ―¿'A₂ lia'₂ ŋɨ́₄ lë₃ ma₂tɨn₂ si₂ i₂në₅ të₃ tsá₃ si₂ ca₂'ɨ́₂?
\p 
\v 16 Jaun₂ ca₂ŋag₃ Jesús:
\p ―Juɨ₁lia'₂ a₂jme₂tág₂ jniá₂ la₂, on₃jua'₅₄ jág₁ quió₃ 'ŋió₃ juá'₅; jág₁ quió'₅ i₂ca₂chei₃ bá₄ la₂.
\v 17 Chi₂jua'₂ 'ein₂ jan₂ ma₂'ei₅ dsɨ́₅ jmo₃ a₂'ŋio₂ dsɨ́₅ Diú₄, le₃ŋi₅ bá₄ 'éi₂ 'a₂ lia'₂ lë́₅ jág₁ a₂jme₂tág₂ jniá₂, chi₂jua'₂ já₅ ja₁con₂ Diú₄, o₃ chi₂jua'₂ dsia₂₃ 'a₂ con'₂ tɨng₂ 'ŋió₃.
\v 18 Juɨ₁lia'₂ i₂dsia₅ o₄quió'₄ 'ŋiog₅, jmo₂₃ le₂jaun₂ ia₁jaun₂ jme₃juag'₂ dsa₂. La₁ juɨ₁lia'₂ i₂'no'₂ a₂le₃juɨn'₂ i₂ca₂chei₃, i₂të₃dsón'₂ bá₄ 'éi₂; 'i₁caun₂ a₂'lɨg'₅₄ tsá₃ cha₂ ja₁coin₂.
\p 
\v 19 ’¿On₁jua'₅₄ Moisés ca₂cuë₃ 'Éi'₃ ca₂cuë́'₃ 'nia'₂? La₁ia₁, ca₂lia'₂ 'i₁jan'₂ 'nia'₂ tsá₃ jme₂tí'₁ Si₂ 'Éi'₃. ¿'E₂ lë₃ 'niog'₂ 'nia'₂ jŋág'₄ jniá₂?
\p 
\v 20 Jaun₂ ca₂ŋag₃ dsa₂:
\p ―'En₅₄ je₂na'₅₄ të₂'au'₂; ¿'ein₂ 'nio₃ jŋɨ'₃ 'ne₂?
\p 
\v 21 Jaun₂ ca₂juá'₂ Jesús:
\p ―Caun₂ léi₄ ca₂jmo₃ jniá₂ jmɨg₄ sa₅₄, jaun₂ ca₂i₃gó'₃ 'au'₂ 'nia'₂ ca₂le₃jɨ́ng'₃.
\v 22 Jaun₂ në́₃, ca₂jmo₃ Moisés 'éi'₃ a₂ti₃ dsa₂ nɨ₁lo₁, (la₁ia₁ on₃jua'₅₄ Moisés i₂ca₂jme₃lióg₃; dsa₂ can'₅₄ bá₄ ca₂jme₃lióg₃ ma₂lɨ́g'₂). 'Uɨg₅₄ jaun₂ ti'₂ 'nia'₂ nɨ₁lo₄ guein₂, o₁jŋia'₅₄ të₃ lë́₅ jmɨg₄ sa₅₄.
\v 23 Dse₃ bá₄ jaun₂, chi₂jua'₂ jaun₂ ti'₂ 'nia'₂ nɨ₁lo₄ guein₂ jmɨg₄ sa₅₄ ia₁jaun₂ tsá₃ dsó₃ 'uë₃ 'Éi'₃ quió'₅ Moisés, ¿'e₂ lë₃ 'ne'₂ 'nia'₂ quian'₅₄ jniá₂, ia₁ ca₂jme₁'liong₁₂ jan₂ dsa₂ ta₁jain₂, të₃ jmɨg₄ sa₅₄?
\v 24 Tsá₃ lë₁cáun₂ 'nia'₂ 'í₁ a₂jŋia'₅₄ con'₂ jniá₂ le₃co'₅₄. Quion₂ bá₄ 'nia'₂ 'í₁ con'₂ dsi₂ten₅₄.
\s1 Dsia₅ Jesús a₂juá'₂ a₂já'₄ já₅
\p 
\v 25 Jaun₂ në́₃ ca₂jme₃lióg₃ qui₂ca₂ŋag₃ i₂lɨn₅₄ dsa₂ chan₂ Jerusalén qui₂ca₂ŋɨ́i'₃ rɨin'₅₄:
\p ―¿On₁jua'₅₄ i₂në₅ 'na'₂ dsa₂ a₂jŋag'₃ i₂nioi₅₄?
\v 26 Ó₃ bá₄ guë'₂ 'ein₅₄ dsia₂₃ lia'₂ rë₂jiá₃ jág₁ jɨn₄ dsa₂ juɨn₅, tsá₃ 'ein₂ juá'₂ 'i₁caun₂ quió'₅. ¿O₃ bá₄ dsón'₂ ma₂ca₂rë₃ŋi₅ dsɨ₂tan₅₄, a₂lɨ́n₅ dsa₂ në₅ I₂rë₂'ɨ́n₁ quián₅ Diú₄?
\v 27 La₁ ne₄ bá₄ jniog₄ a₂já'₄ já₅ i₂në₅; a₂dsau₅, jë₁ma₂të́₂ rë₁jiá₃ I₂rë₂'ɨ́n₁ quián₅ Diú₄, lia'₂ 'i₁jan₂ tsá₃ le₃ŋi₅ a₂já'₄ já₅.
\p 
\v 28 Jaun₂ lë₃, të₁lia'₂ 'en₅₄ Jesús jme₂tɨin₂₃ dsa₂ i₁dsi₅ guá'₅ templo, jaun₂ ca₂juá'₂ tiá₂:
\p ―¡Cuɨg'₂ bá₄ 'nia'₂ jniá₂, jaun₂ ŋi'₅₄ bá₄ 'nia'₂ 'a₂ guë'₂ guio₃ jniá₂! La₁ on₃jua'₅₄ o₄quió₃ 'ŋió₃ guio₃; të₂le₃ o₄quió'₄ i₂ca₂chei₃ i₂të₃dsón'₂ bá₄ guang₃. I₂'éi₂ guë'₂, tsá₃ cuɨn'₂ 'nia'₂.
\v 29 La₁ia₁ jniá₂ cuɨ́in₅, ia₁ ja₁con₂ 'éi₂ bá₄ guio₃, jaun₂ 'éi₂ bá₄ ca₂chei₃.
\p 
\v 30 Jaun₂ në́₃, jme₁'nio₃ dsa₂ jme₁tsáun'₂; la₁ lia'₂ 'i₁jan₂ tsá₃ ca₂téi₂ gu₂, ia₁ tsá₃ jme₁ma₂të́₂ bá₄ guë́₄ hora quió'₅.
\p 
\v 31 La₁ia₁ juɨn₅ dsa₂ 'éi₂ ca₂rë₃'én₂ jág₁ quió'₅, jaun₂ juá'₂:
\p ―Jë₁ma₂të́₂ rë₁jiá₃ I₂rë₂'ɨ́n₁ quián₅ Diú₄, ¿O₃ bá₄ le₃quɨ'₅₄ jmɨg₄ jmo₃ léi₄ a₂juë'₂ guë́₄ lia'₂ con'₂ guë́₄ a₂jmo₅ i₂në₅?\f + \fr 7:31 \ft 'Nio'₂ ja₁ton₅ Isaías 35:5-6.\f*
\s1 Ca₂chen₃ dsa₂ fariseos chi'₂ 'ɨ'₅₄ quián₅ guá'₅ a₂tsáin'₂ Jesús
\p 
\v 32 Ca₂nág₂ bá₄ dsa₂ fariseos jág₁ a₂ca₂juá'₂ dsa₂ a₂'ɨin₂₃ Jesús; jaun₂ dsa₂ fariseos 'éi₂ quiain'₅₄ juɨg₅₄ jme₂dsa₂, ca₂chein₃ chi'₂ 'ɨ'₅₄ quián₅ guá'₅ a₂tsáin'₂ Jesús jaun₂ të₂.
\v 33 Jaun₂ në́₃ ca₂juá'₂ Jesús:
\p ―Me'₂ bá₄ jmɨg₄ 'ú₄ jniá₂ jɨn'₂ 'nia'₂, jaun₂ guë́₄ nég'₄ táng₃ ja₁con₂ i₂ca₂chei₃.
\v 34 'Nau'₅₄ 'nia'₂ jniá₂ i₁niog'₄, la₁ia₁ tsá₃ dsiog'₂ 'nia'₂; ia₁ tsá₃ lé₂ o₁nó'₅ 'nia'₂ ja₁nég'₄.
\p 
\v 35 Jaun₂ në́₃, ca₂jme₃lióg₃ dsa₂ judíos qui₂ca₂ŋɨ́i'₃ rɨin'₅₄:
\p ―¿A₂já'₄ dsɨ₂jiog₅ dsɨ́₅ i₂në₅ dsó₃, a₂tsá₃ dsiain'₂ jniog₄? ¿On₃ bá₄ dsó₃ jɨn₄ dsa₂ go₄ jniog₄ i₂tián'₅ tsɨ₁rë₂jan₅₄ jɨn₄ dsa₂ griegos, ia₁jaun₂ jme₃tɨin₂₃ dsa₂ griegos?
\v 36 ¿'E₂ jein₅ jág₁ a₂në₂juá'₂ në₅: “'Nau'₅₄ 'nia'₂ jniá₂ i₁niog'₄, la₁ia₁ tsá₃ dsiog'₂ 'nia'₂, ia₁ tsá₃ lé₂ o₁nó'₅ 'nia'₂ ja₁nég'₄”?
\s1 Juɨ₁lia'₂ caun₂ jmɨg₂ cuá₃ jén'₃
\p 
\v 37 Jmɨg₄ juë'₂ dé₄ dsón'₂ jë₁ca₂tó'₂ quió'₅ jmɨg₄, ca₂nau₂ Jesús, jaun₂ ca₂juá'₂ tiá₂:
\p ―Në₁jua'₂ 'ein₂ rë₂quein₂ dsɨ́₅, juɨ₁jia₂ ja₁con₂ jniá₂, juɨ₁'en'₅₄ jmɨg₂.
\v 38 Juɨ₁lia'₂ juá'₂ Si₂, juɨ₁lia'₂ dsa₂ i₂'én₂ të₂le₃ quió₃ jniá₂, 'iá₃ të₂tsɨ́₅ në₂jag₄ bá₄ jmɨg₂ cuá₃ a₂jén'₃.\f + \fr 7:38 \ft 'Nio'₂ ja₁ton₅ Isaías 44:3; 55:1.\f*
\p 
\v 39 La₁ a₂juá'₂ le₂në₅ a₂'ɨin₂₃ Jme₂dsí₂ Jŋió₅ i₂jme₁ma₂'i₄ 'éi'₃ guen₃ dsa₂ i₂'én₂ të₂le₃ quió'₅; ia₁ tsá₃ jme₁ma₂guan₅ bá₄ guë́₄ Jme₂dsí₂, ia₁ tsá₃ guë́₄ jme₁ma₂ca₂rë₃juɨn'₂ Jesús.
\s1 Ca₂lë₃ le₁dson'₅₄ dsa₂
\p 
\v 40 I₂lɨn₅₄ dsa₂ i₂jme₁tion'₅₄ ja₁jaun₂, jme₁ca₂nág₂ a₂juá'₂ Jesús, ca₂juá'₂:
\p ―Dsón'₂ bá₄ i₂në₅ dsa₂ i₂'ë́₂ jág₁ quián₅ Diú₄ i₂lë́₅ jág₁ jiá₃ 'éi₂.
\p 
\v 41 I₂lɨn₅₄ guë'₂ juá'₂:
\p ―I₂rë₂'ɨ́n₁ quián₅ Diú₄ bá₄ në₅.
\p La₁ia₁ i₂sián'₂ guë'₂ ca₂juá'₂:
\p ―¿'A₂ bá₄ lia'₂ lé₂ le₃chan₂ Galilea I₂rë₂'ɨ́n₁ quián₅ Diú₄?
\v 42 ¿Tsa₁ juá'₂ Si₂, tsɨ₁jon₂ Rag₅₄ David bá₄ tion₅₄ lén₂ I₂rë₂'ɨ́n₁ quián₅ Diú₄, jaun₂ jë₄ juɨg₂ Belén bá₄ le₃chain₂, juɨg₂ go₄ David 'ŋiog₅?
\p 
\v 43 Jaun₂ në́₃, le₁dson'₅₄ bá₄ dsa₂ ca₂lë₃ o₄quió'₄ Jesús.
\p 
\v 44 Jme₁'nio₃ i₂lɨn₅₄ tsáun'₂, la₁ ca₂lia'₂ 'i₁jan₂ tsá₃ 'ein₂ ca₂téi₂ gu₂.
\s1 Tsá₃ 'én₂ dsa₂ can'₅₄ të₂le₃ quió'₅ Jesús
\p 
\v 45 Jaun₂ ca₂dsi₃len₃ táng₃ chi'₂ 'ɨ'₅₄ quián₅ guá'₅ ja₁jme₁tion'₅₄ juɨg₅₄ jme₂dsa₂ quian'₅₄ dsa₂ fariseos, jaun₂ ca₂ŋag₃ 'éi₂ ca₂ŋɨ́i'₃ chi'₂ 'ɨ'₅₄:
\p ―¿'E₂ 'uɨg₅₄ tsá₃ në₂te'₅₄ 'nia'₂ 'éi₂?
\p 
\v 46 Jaun₂ ca₂ŋag₃ chi'₂ 'ɨ'₅₄:
\p ―¡Lia'₂ 'i₁cón'₂ tsá₃ 'ein₂ dsa₂ ma₂juá'₂ jág₁ juɨ₁lia'₂ juá'₂ dsa₂ 'éi₂!
\p 
\v 47 Jaun₂ në́₃ ca₂juá'₂ dsa₂ fariseos:
\p ―¿O₃ bá₄ ma₂jme₃gau₅ dsa₂ 'éi₂ quián'₂ 'nia'₂ ján₃?
\v 48 'I₁jan₂ dsa₂ can'₅₄ juɨg₅₄ jniog₄, on₃ guë'₂ dsa₂ fariseos, tsá₃ ma₂ca₂rë₃'én₂ le₃quió'₅ 'éi₂, jme₁né₄.
\v 49 La₁ dsa₂ lë₁dsa₂ i₂tion'₅₄ në₅, tsá₃ cuɨ́'₅ Si₂ 'Éi'₃. Ma₂tioin'₅₄ ne₄ jmɨ₁uɨg₅ a₂ma₂rë₂'ë́₂ ja₁coin₂.\f + \fr 7:49 \ft 'Nio'₂ ja₁ton₅ Deuteronomio 27:14-26.\f*
\p 
\v 50 Jɨn₄ dsa₂ fariseos 'éi₂ jme₁'en₅₄ Nicodemo, i₂jme₁ma₂ŋe₄ i₁jɨin₅₄ Jesús le₂jŋiá₅.\f + \fr 7:50 \ft A₂lɨn₅₄ chog₅₄ si₂ juá'₂: “i₁jɨin₅₄ Jesús a₂'uë₂ jaun₂.” \f* 'Éi₂ në́₃ ca₂ŋag₃:
\p 
\v 51 ―Juɨ₁lia'₂ con'₂ lë́₅ juá'₂ Si₂ 'Éi'₃ quián₂, ¿lé₂ le₃qui₁dsɨ₅ 'éi'₃ ja₁con₂ jan₂ dsa₂, të₃ tsá₃ ma₂në₂néi₂ jág₁ quió'₅, a₂juá'₂ 'e₂ a₂ma₂jmo₃?
\p 
\v 52 Jaun₂ në́₃ ca₂ŋag₃ rɨin'₅₄:
\p ―¿Ján₃ bá₄ lɨ́n'₅ 'ne₂ jan₂ dsa₂ i₂chan₂ Galilea? 'Í₂ dse₃ ne₄ Si₂, jaun₂ jag'₅₄, lia'₂ 'i₁jan₂ dsa₂ i₂'ë́₂ jág₁ quián₅ Diú₄ tsá₃ já₅ 'uë₃ Galilea.\f + \fr 7:52 \ft Ne₄ chog₅₄ si₂ a₂gui'₅₄ guë́₄, tsá₃ le₁ton₅ Juan 7:53–8:11.\f*
\p 
\v 53 Jaun₂ guë́₄ i₃len₃ le₂jan₂ le₂jan₂ dsa₂ ja₁quió'₄.
\c 8
\s1 Jan₂ 'io₅₄ i₂ca₂tán'₂ dso₄
\p 
\v 1 La₁ ca₂ŋó₃ bá₄ Jesús juɨ₅ Má'₂ Olivos.
\v 2 Jme₁jnia₃ jaun₂ táng₃, ca₂guáin'₃ i₁dsi₅ guá'₅ templo. Ja₁jaun₂ ca₂jme₃quián₃ ca₂le₃jɨ́n₃ dsa₂. Jaun₂ ca₂guá₂ Jesús, jaun₂ ca₂jme₃lióg₃ jme₂tɨin₂₃ dsa₂.
\v 3 Jaun₂ në́₃, ca₂o₃jŋia₃ të₅juá'₅ quian'₅₄ dsa₂ fairseos ca₂o₃jŋiai₃ jan₂ 'io₅₄ i₂ca₂join₃ jme₁'ein₅₄ quian'₅₄ dsa₂ ŋe'₂. Jaun₂ ca₂chei'₃ dsi₂jo₂ jë₄ quió'₅ dsa₂ i₂tion'₅₄ ja₁jaun₂.
\p 
\v 4 Jaun₂ ca₂juá'₂ ca₂tsɨ́'₃ Jesús:
\p ―Të₅, ca₂jón₂ 'io₅₄ la₂ nió'₅ jág₁ quian'₅₄ dsa₂ ŋe'₂ on₃jua'₅₄ dsɨ₂i₂gu₂.
\v 5 Në₃ në́₃, ne₄ Si₂ 'Éi'₃, juá'₂ Moisés a₂jŋɨ́'₄ jnia'₅₄ jan₂ 'io₅₄ le₂la₂, a₂qui₁dsɨin₅ jnia'₅₄ cang₄. ¿'Ne₂ guë'₂, 'a₂ lia'₂ juá'₂?
\p 
\v 6 Ca₂juá'₂ dsa₂ le₂në₅ ia₁ a₂cáin₂ táu₂ Jesús, ia₁jaun₂ cuɨn₃ jmɨg₄ bóg'₂ dso₄. La₁ ca₂guá₂ Jesús i₁sióg'₅ 'uë₃, jaun₂ ca₂jme₃lióg₃ ca₂jmóg'₃ letras ne₄ 'uë₃ quian'₅₄ nei'₅₄ chi₁gú₃.
\p 
\v 7 La₁ caun₂ tioin'₅₄ qui₂ŋag₂₃ qui₂ŋɨ́i'₂ Jesús, jaun₂ ca₂nau₂, ca₂juá'₂ ca₂tsɨ́'₃ dsa₂:
\p ―Chi₂jua'₂ 'ein₂ jan₂ 'nia'₂ i₂tsá₃ dso₄ rë₂cán'₄, o₁tiong₅₄ le₂'uɨg₅₄ ca₂mɨ́g₂ nɨ₁cang₁ juɨ₁qui'₅₄ quió'₅ 'io₅₄.
\p 
\v 8 Jaun₂ ca₂guá₂ táng₃ i₁sióg'₅ 'uë₃, jmóg'₅ letras a₂tsáng₂ 'uë₃.
\p 
\v 9 La₁ jme₁ca₂nág₂ dsa₂ jág₁ a₂ca₂juá'₂ Jesús,\f + \fr 8:9 \ft A₂lɨn₅₄ chog₅₄ si₂ juá'₂ ján₃: “ca₂jéin'₃ o₂guí'₃ ia₁ rë₂cáin'₄ dso₄ guioin₅₄.” \f* jaun₂ ca₂jme₃lióg₃ qui₂ca₂'uɨin₂ bá₄ le₂jain₂ le₂jain₂, jŋiá₅ de'₂ dsa₂ i₂ma₂guen'₂ ca₂'uɨin₂ ne₄ juɨ₅. Jaun₂ jme₁ma₂ca₂'uɨn₂ ca₂le₃jɨ́n₃ dsa₂, 'ŋiog₅ bá₄ Jesús të₁tsɨin'₅₄ quiain'₅₄ 'io₅₄ 'éi₂, i₂chén'₅ dsi₂jo₂ jaun₂.
\p 
\v 10 Jaun₂ në́₃ ca₂nau₂ Jesús,\f + \fr 8:10 \ft A₂lɨn₅₄ chog₅₄ si₂ juá'₂ ján₃: “ia₁ tsá₃ ca₂jág₃ jua'₅₄ tión₂ guë́₄ i₂sián'₂, jŋia'₅₄ lia'₂ 'io₅₄ 'éi₂.” \f* jaun₂ ca₂juá'₂ ca₂tsɨ́'₃ 'io₅₄:
\p ―'Io₅₄, ¿na₅ dsa₂?\f + \fr 8:10 \ft A₂lɨn₅₄ chog₅₄ si₂ juá'₂ ján₃: “i₂'nag₅ quiáng'₂.” \f* ¿Tsa₁ 'ein₂ në₂'ë́₂ uɨg₅?
\p 
\v 11 Jaun₂ ca₂juá'₂ 'io₅₄:
\p ―Jan₂'ón₄. Lia'₂ 'i₁jan₂ dsa₂, Te₁gui'₅₄.
\p Jaun₂ në́₃ ca₂juá'₂ Jesús:
\p ―On₃ guë'₂ jniá₂ 'ë́₄ uɨg₅ quiáng'₂; guan'₂ në́₃, la₁ tsá₃ ma₃lë₁'nau₂ dso₄.
\s1 Lɨ́n₅ Jesús si₂ a₂tág₅ quió'₅ dsa₂ mɨ₂güɨ́g₃
\p 
\v 12 Ca₂juá'₂ táng₃ Jesús tsɨ́'₅ dsa₂, a₂juá'₂:
\p ―Jniá₂ lɨ́ng₅ si₂ i₂jmo₅ tág₅ juɨ₅ quió'₅ dsa₂ mɨ₂güɨ́g₃; juɨ₁lia'₂ i₂'ein₅ jniá₂, lia'₂ o₁lɨ́g'₂ tsá₃ ma₃ŋɨ₃ jë₄ qui₁né'₃, ton'₂ qui₃'io₃ si₂ a₂jmo₅ a₂chain₂.
\p 
\v 13 Jaun₂ në́₃ ca₂juá'₂ dsa₂ fariseos ca₂tsɨ́'₃ Jesús:
\p ―'Ne₂ jáng'₂ jág₁ dsau₅ të₂le₃ quián'₂ 'ŋiag'₂; 'uɨg₅₄ jaun₂ tsá₃ quen₅ jág₁ quiáng'₂ a₂jáng'₂.
\p 
\v 14 Jaun₂ ca₂ŋag₃ Jesús ca₂tsɨ́'₃ dsa₂:
\p ―Juɨ₁lia'₂ a₂juá'₅ jniá₂, quen₅ bá₄, o₁jŋia'₅₄ 'ŋió₃ jniá₂ jáng'₅ jág₁ dsau₅ të₂le₃ quió₃ 'ŋió₃. Ia₁ guion₄ bá₄ jniá₂ a₂já'₄ guio₃, a₂já'₄ nég'₄ në́₃; la₁ia₁ 'nia'₂ në́₃, tsá₃ ŋi'₅₄ 'nia'₂ a₂já'₄ guio₃, on₃ guë'₂ a₂já'₄ nég'₄.
\v 15 'Nia'₂ guë'₂ cáun'₂ 'í₁ lia'₂ con'₂ lë́₅ 'éi'₃ quió'₅ dsa₂ mɨ₂güɨ́g₃. Jniá₂ në́₃ tsá₃ 'í₁ cáun₅ jniá₂ jua'₅₄ a₂qui₂dsɨ́₂ 'éi'₃ ja₁con₂ 'i₁jan₂.
\v 16 La₁ia₁ chi₂jua'₂ cáun₅ jniá₂ 'í₁, dse₃ dsi₂ten₅₄ bá₄ 'éi'₃ a₂qui₂dsɨ́₂ jniá₂, ia₁ on₃jua'₅₄ jniá₂ 'ŋió₃ cáun₅ 'í₁; qui₂dsɨ́₂ jniá₂ 'éi'₃ co₂lë₅ quiang'₅₄ i₂ca₂chei₃ bá₄.
\v 17 Ján₃ bá₄ ca₂të₂ ne₄ Si₂ 'Éi'₃ quián'₂ 'nia'₂, rë₂ton₅ juá'₂, në₁jua'₂ on₃ dsa₂ lë́₂ i₂jáng'₅ jág₁ dsau₅, a₂quen₅ bá₄ jág₁ quió'₅.
\v 18 Jniá₂ lɨ́ng₅ i₂jáng'₅ jág₁ dsau₅ të₂le₃ quió₃ 'ŋió₃; Ŋe'₃ jniá₂ i₂ca₂chei₃ guë'₂, lɨ́n₅ táng₃ jan₂ i₂jáng'₅ jág₁ dsau₅.
\p 
\v 19 Jaun₂ në́₃ ca₂ŋag₃ dsa₂ fariseos ca₂ŋɨ́i'₃ Jesús:
\p ―¿Na₅ ŋéi'₅ 'ne₂?
\p Jaun₂ ca₂ŋag₃ Jesús:
\p ―Tsá₃ cuɨg'₂ 'nia'₂ jniá₂, on₃ guë'₂ Ŋe'₃ jniá₂ cuɨn'₂ 'nia'₂; jua'₅₄ mei'₂ guë́₃ cuɨg'₂ 'nia'₂ jniá₂, ján₃ bá₄ jme₁le₃cuɨn'₂ 'nia'₂ Ŋe'₃.
\p 
\v 20 Ca₂juá'₂ Jesús le₂në₅ të₁lia'₂ jme₁'ein₅₄ jme₂tɨin₂₃ dsa₂ i₁dsi₅ guá'₅ templo, cau₅ ja₁jme₁tióng₂ tsɨ₁gu₅ quió'₅ cu₄ guá'₅. La₁ia₁, lia'₂ 'i₁jan₂ tsá₃ 'ein₂ ca₂jŋau'₃, ia₁ tsá₃ jme₁ma₂të́₂ bá₄ guë́₄ hora quió'₅.
\s1 “Juɨ₁lia'₂ ja₁né'₄ jniá₂, tsá₃ lé₂ o₁nó'₅ 'nia'₂”
\p 
\v 21 Con'₂ siá'₂ táng₃ ca₂juá'₂ Jesús ca₂tsɨ́'₃ dsa₂:
\p ―Né'₄ jniá₂; jaun₂ 'nia'₂ guë'₂, 'náu'₂ jniá₂ i₁niog'₄, la₁ia₁ dsián'₃ 'nia'₂ të₃ rë₂cán'₄ 'nia'₂ dsáu'₂; ja₁né'₄ jniá₂, tsá₃ lé₂ o₁nó'₅ 'nia'₂.
\p 
\v 22 Jaun₂ në́₃ ca₂juá'₂ dsa₂ judíos:
\p ―¿O₃ bá₄ a₂jŋɨi'₃ 'e₂ 'ŋiog₅, jaun₂ guë'₂ juá'₂ tsá₃ lé₂ dsɨ₁náu₄ jniog₄ ja₁dsáin'₃?
\p 
\v 23 Jaun₂ ca₂juá'₂ Jesús:
\p ―Dsa₂ chan₂ gua'₅₄ 'uë₃ la₂ bá₄ lɨ́n'₅ 'nia'₂; jniá₂ në́₃, lɨ́ng₅ i₂chan₂ guei'₅₄. Dsa₂ i₂tén₅ mɨ₂güɨ́g₃ la₂ bá₄ lɨ́n'₅ 'nia'₂; jniá₂ në́₃ tsá₃ téng₅ mɨ₂güɨ́g₃ la₂.
\v 24 'Uɨg₅₄ jaun₂ bá₄ në₂juɨ́g₂ jniá₂ 'nia'₂ a₂dsiáng'₃ të₃ rë₂cáng'₄ jaun₂ dsáu'₂. Ia₁ chi₂jua'₂ tsá₃ 'én'₂ 'nia'₂, jniá₂ bá₄ lɨ́ng₅ 'éi₂,\f + \fr 8:24 \ft o₃, “jniá₂ bá₄ lɨ́ng₅.” \f* dsiáng'₃ 'nia'₂ qui₂rë₂cáng'₄ dsáu'₂.
\p 
\v 25 Jaun₂ në́₃ ca₂ŋag₃ dsa₂ judíos ca₂ŋɨ́i'₃ Jesús:
\p ―¿'Ein₂ bá₄ lɨ́n'₅ 'ne₂?
\p Jaun₂ ca₂ŋag₃ Jesús:
\p ―Le₂jaun₂ juɨ₁lia'₂ ma₂qui₂ma₂juɨ́g₂ jniá₂ 'nia'₂ ca₃le₂'uɨg₅₄.\f + \fr 8:25 \ft o₃, “¿'E₂ jaun₂ ma₂qui₂ma₂juɨ́g₂ jniá₂ 'nia'₂ ca₃le₂'uɨg₅₄?” \f*
\v 26 'Lióng₂ bá₄ 'uɨg₅₄ cha₂ a₂le₃juá'₄ jniá₂ a₂qui₁dsɨ₅ jniá₂ 'éi'₃ ja₁con'₂ 'nia'₂. La₁ tí₅ bá₄ jág₁ quió'₅ i₂ca₂chei₃. Jaun₂ jniá₂ në́₃, jág₁ a₂ma₂nag₃ ja₁coin₂, a₂jaun₂ bá₄ juɨ́g₂ jniá₂ dsa₂ mɨ₂güɨ́g₃.
\p 
\v 27 La₁ tsá₃ ca₂rë₃ŋɨ́'₂ dsa₂, a₂jme₁juá'₂ Jesús tsɨ́'₅ dsa₂ 'éi₂, a₂'ɨin₂₃ Jmei₂.
\p 
\v 28 'Uɨg₅₄ jaun₂ ca₂juá'₂ Jesús:
\p ―Jë₁ma₂të́₂ rë₁chóng'₄ 'nia'₂ Jaun₅ dsa₂ mɨ₂güɨ́g₃, jaun₂ guë́₄ le₃ŋi'₅₄ 'nia'₂ a₂lɨ́n₅ jniá₂ 'éi₂;\f + \fr 8:28 \ft o₃, “le₃ŋi'₅₄ 'nia'₂, jniá₂ lɨ́ng₅.” \f* le₃ŋi'₅₄ 'nia'₂, a₂tsá₃ jmo₅ jniá₂ 'i₁caun₂ të₂le₃ o₄quió₃ 'ŋio₃, jŋia'₅₄ lia'₂ a₂jaun₂ bá₄ juá'₅ jniá₂ juɨ₁lia'₂ a₂ma₂ca₂jme₃tag₅ Ŋe'₃.
\v 29 Ia₁ i₂ca₂chei₃ 'ein₅₄ quian'₅₄ jniá₂, tsá₃ jua'₅₄ ma₂téin₂ jniá₂ 'ŋió₃, ia₁ lia'₂ co₂tan₅₄ bá₄ jmo₅ jniá₂ a₂'ŋio₂ dsɨ́₅ 'éi₂.
\p 
\v 30 Lia'₂ jme₁juá'₂ Jesús jág₁ në₅, juɨn₅ lɨn₃ dsa₂ ca₂rë₃'én₂ le₃quió'₅.
\s1 Chi'₂-guein₂ quián₅ Diú₄, quian'₅₄ dsa₂ i₂qui₂le₁'ŋe'₅₄ 'uɨg₅₄ dsáu₁
\p 
\v 31 Jaun₂ në́₃ ca₂juá'₂ Jesús ca₂tsɨ́'₃ dsa₂ judíos i₂ca₂rë₃'én₂ le₃quió'₅:
\p ―Në₁jua'₂ të₁'ŋiá'₄ 'nia'₂ le₃quió'₅ jág₁ quió₃, dsón'₂ bá₄ lɨ́n'₅ 'nia'₂ dsa₂ i₂quian'₅₄ jniá₂;
\v 32 jaun₂ le₃cuɨn'₂ 'nia'₂ jág₁ dsau₅, jaun₂ jág₁ dsau₅ në́₃, jmo₃ qui₃chen'₂ 'nia'₂.
\p 
\v 33 Jaun₂ ca₂ŋag₃ dsa₂ 'éi₂ ca₂tsɨ́'₃ Jesús:
\p ―Lág₅ jnia'₅₄ dsa₂ tsɨ₁jon₂ Abraham, jaun₂ lia'₂ 'i₁cón'₂ tsá₃ ma₂lag₃ jnia'₅₄ dsa₂ i₂le₁'ŋe'₅₄ ne₄ 'i₁jan₂. ¿'A₂ guë'₂ lia'₂ juá'₂ 'ne₂ jaun₂ a₂qui₃chei'₂ jnia'₅₄?
\p 
\v 34 Jaun₂ ca₂juá'₂ Jesús:
\p ―A₂dsɨ₂jó'₃ juɨ́g₂ jniá₂ 'nia'₂, juɨ₁lia'₂ ca₂le₃jɨ́n₃ dsa₂ i₂'no₅ dso₄, qui₂le₁'ŋei'₅₄ ne₄ dsáu₁.
\v 35 Juɨ₁lia'₂ jan₂ dsa₂ i₂chi₁'ŋe'₅₄ në́₃, tsá₃ jua'₅₄ të₃'ŋiái₄ co₂tan₅₄ dsi₂néi₂ quió'₅ juɨg₅₄; la₁ia₁ chi'₂ ja₁ŋi'₅₄ në́₃, co₂tan₅₄ bá₄ téin₅ dsi₂néi₂ jaun₂.
\v 36 Jaun₂ në́₃, chi₂jua'₂ ca₂chéi'₂ Ja₁ŋi'₅₄ ca₂chéin'₂ 'nia'₂, jaun₂ bá₄ lén'₂ 'nia'₂ dsa₂ i₂le₁tsɨn'₁ të₃dsón'₂.
\v 37 Ma₂guion₄ bá₄ jniá₂ jaun₂ a₂lɨ́n'₅ 'nia'₂ tsɨ₁jon₂ Abraham; la₁ia₁ 'niog'₂ 'nia'₂ jŋág'₄ jniá₂, ia₁ a₂tsá₃ guei'₂ 'nia'₂ 'e₂ a₂juá'₅ jniá₂.
\v 38 Jniá₂ në́₃ juá'₅ juɨ́g₂ 'nia'₂ juɨ₁lia'₂ 'e₂ a₂ma₂jág₃ ja₁con₂ Ŋe'₃; 'nia'₂ në́₃, jmo'₂ 'e₂ a₂ma₂nei'₂ 'nia'₂ ja₁con₂ ŋéi'₅.
\p 
\v 39 Jaun₂ ca₂ŋag₃ dsa₂ 'éi₂ ca₂tsɨ́'₃ Jesús:
\p ―Abraham bá₄ jme₁lɨ́n₄ jmei₂ jnia'₅₄ ma₂lɨ́g'₂.
\p La₁ ca₂juá'₂ Jesús ca₂tsɨ́'₃ dsa₂ 'éi₂:
\p ―Jua'₅₄ mei'₂ guë́₃ lɨ́n'₅ 'nia'₂ chi'₂-guein₂ quián₅ Abraham, jaun₂ jme₁jmó'₂ 'nia'₂ juɨ₁lia'₂ a₂ca₂jmo₃ 'éi₂.
\v 40 La₁ia₁ 'nia'₂ në́₃ 'niog'₂ jŋág'₄ jniá₂, o₁jŋia'₅₄ ma₂në₂juɨ́g₂ jniá₂ 'nia'₂ jág₁ tí₅ të₃dsón'₂ a₂ma₂ca₂jme₃tag₅ Diú₄ jniá₂. Tsá₃ le₂në₅ ca₂jmo₃ Abraham.
\v 41 'Nia'₂ në́₃, le₂jaun₂ bá₄ jmo'₂ juɨ₁lia'₂ jmo₅ ŋéi'₅.
\p Jaun₂ në́₃ ca₂juá'₂ dsa₂ 'éi₂:
\p ―La₁ on₃jua'₅₄ jnia'₅₄ lág₅ guein₂ i₂lë₁chan₂; jan₂ bá₄ jmei₂ jnia'₅₄ chan₂: i₂'éi₂ lɨ́n₅ Diú₄.
\p 
\v 42 Jaun₂ në́₃ ca₂juá'₂ Jesús:
\p ―Jua'₅₄ mei'₂ guë́₃ të₃dsón'₂ Diú₄ lɨ́n₅ ŋéi'₅ 'nia'₂, jme₁jme₁'nió'₄ bá₄ 'nia'₂ jniá₂, ia₁ ja₁con₂ Diú₄ bá₄ 'uɨ́n₂ jniá₂; jaun₂ la₂ ma₂guio₃. On₃jua'₅₄ o₄quió₃ 'ŋió₃ guio₃; o₄quió'₄ i₂ca₂chei₃ bá₄ jniá₂ guio₃.
\v 43 ¿'E₂ lë₃ tsá₃ lé₂ le₃ŋɨ́'₂ 'nia'₂ jág₁ a₂juá'₅ jniá₂? 'Uɨg₅₄ ia₁ a₂tsá₃ tian'₃ 'nia'₂ nág'₁ jág₁ a₂'ë́₅ jniá₂.
\v 44 'Nia'₂ bá₄ rë'₂ téng'₅ le₃quió'₅ i₂së₃dsen₃ ŋéi'₅ 'nia'₂. Jaun₂ 'ɨ́n₅ 'au'₂ jmó'₂ 'e₂ a₂'ŋio₂ dsɨ́₅ 'éi₂. Lia'₂ con'₂ le₂'uɨg₅₄ bá₄ jaun₂ lɨ́in₅ jan₂ i₂jme₂dsian₅ dsa₂. Tsá₃ le₃quió'₅ jág₁ dsau₅ chéin'₅, ia₁ 'i₁ca₂mɨ́g₂ jág₁ dsau₅ tsá₃ cha₂ ja₁coin₂. Jë₁ma₂ca₂juá'₂ jág₁ të₂jág₁, juá'₂ bá₄ juɨ₁lia'₂ tɨin₂ 'ŋiog₅, ia₁ i₂të₂jɨ́n₁ bá₄ 'éi₂, jaun₂ lɨ́in₅ jmei₂ dsa₂ të₂jɨ́n₁.
\v 45 La₁ia₁, 'uɨg₅₄ ia₁ a₂juá'₅ jniá₂ jág₁ dsau₅ në́₃, tsá₃ 'éng'₂ jág₁ quió₃.
\v 46 ¿I₂'ein₂ 'nia'₂ quɨ'₅₄ jmɨg₄ cáun₂ 'í₁ a₂rɨn₂ jniá₂ dso₄? Chi₂jua'₂ juá'₅ jniá₂ jág₁ dsau₅, ¿'E₂ lë₃ tsá₃ 'én'₂ 'nia'₂ jág₁ quió₃?
\v 47 Juɨ₁lia'₂ i₂tén₅ le₃quió'₅ Diú₄, nag₂₃ jág₁ quió'₅ Diú₄. 'Uɨg₅₄ jaun₂ bá₄ tsá₃ nag'₂ 'nia'₂ jág₁: ia₁ tsá₃ tén'₅ 'nia'₂ le₃quió'₅ Diú₄.
\s1 Né'₃ guë́₄ a₂le₃chan₂ Abraham, jme₁ma₂chan₂ bá₄ Te₁gui'₅₄
\p 
\v 48 Jaun₂ në́₃ ca₂ŋag₃ dsa₂ judíos ca₂ŋɨ́i'₃ Jesús:
\p ―¿Tsa₁ dsau₅ jág₁ a₂jua'₂ jnia'₅₄, dsa₂ chan₂ Samaria bá₄ lɨ́n'₅ 'ne₂; a₂'en₅₄ jan₂ je₂na'₅₄ të₂'au'₂ në́₃?
\p 
\v 49 Jaun₂ ca₂ŋag₃ Jesús:
\p ―Lia'₂ 'i₁jan₂ je₂na'₅₄ tsá₃ 'en₅₄ të₂dsɨ₃. A₂jaun₂ bá₄ jmo₅ jniá₂ a₂jme₂juɨ́n'₁ jniá₂ Ŋe'₃; 'nia'₂ guë'₂, tsá₃ jme₂go'₃ jniá₂.
\v 50 Tsá₃ a₂jaun₂ 'náu'₅ jniá₂ a₂jme₃juag'₂ dsa₂, la₁ chan₂ jan₂ i₂'no'₂ a₂jme₃juag'₂ dsa₂ jniá₂, ton'₂ 'éi₂ bá₄ con₂ jág₁ dsau₅.
\v 51 A₂dsɨ₂jó'₃ juɨ́g₂ jniá₂ 'nia'₂, chi₂jua'₂ 'ein₂ dsa₂ i₂tón'₂ juɨ₅ jág₁ quió₃, lia'₂ o₁lɨ́g'₂ jmɨg₄ tsá₃ dsɨ₃ŋɨi₅₄ 'mú₃.
\p 
\v 52 Jaun₂ në́₃ ca₂ŋag₃ dsa₂ judíos:
\p ―Në₃ guë́₄ dsón'₂ jag₂ jnia'₅₄ a₂'en₅₄ jan₂ je₂na'₅₄ të₂'au'₂. Ia₁ ma₂ca₂jon₃ Abraham lia'₂ jma₃quian'₅₄ dsa₂ i₂qui₂ca₂'ë́₂ jág₁ quián₅ Diú₄; 'ne₂ guë'₂ juá'₂: “Juɨ₁lia'₂ i₂tón'₂ juɨ₅ jág₁ quió₃, tsá₃ lɨ́g'₂ dsɨ₃ŋɨi₅₄ 'mú₃.”
\v 53 ¿O₃ bá₄ 'ŋio₅ lɨn₃ guë́₄ juɨn'₂ 'ne₂ lia'₂ con'₂ guë́₄ Abraham 'lag₄ jmei₂ jnia'₅₄? Ca₂jon₃ bá₄ 'éi₂, ján₃ bá₄ le₂jaun₂ qui₂ca₂dsan₃ dsa₂ i₂jme₁'ë́₂ jág₁ quián₅ Diú₄. ¿'Ein₂ lɨ́n'₂ 'ne₂ lɨ́ng'₅?
\p 
\v 54 Jaun₂ ca₂ŋag₃ Jesús:
\p ―Chi₂jua'₂ 'ŋió₃ jniá₂ jme₂juɨ́ng'₂, tsá₃ 'e₂ quen₅ a₂jaun₂. La₁ia₁ juɨ₁lia'₂ i₂jme₂juag'₂ jniá₂, Ŋe'₃ bá₄ jniá₂ 'éi₂, i₂'ɨ́n'₅ 'nia'₂ lɨ́n₅ Diú₄ quiáng'₂.
\v 55 O₁jŋia'₅₄ tsá₃ cuɨn'₂ 'nia'₂ 'éi₂, la₁ cuɨ́n₅ bá₄ jniá₂ 'éi₂. Jua'₅₄ mei'₂ guë́₃ juá'₅ jniá₂ a₂tsá₃ cuɨ́in₅, jme₁lén₂ jniá₂ jan₂ i₂të₂jɨ́n₁ juɨ₁lia'₂ lɨ́n'₅ 'nia'₂. La₁ia₁ dsón'₂ bá₄ cuɨ́n₅ jniá₂ 'éi₂, jaun₂ tón'₅ bá₄ jniá₂ juɨ₅ jág₁ quió'₅.
\v 56 Ca₂jmo₃ 'io'₂ Abraham, 'lag₄ ŋéi'₅ 'nia'₂, ia₁ jme₁'ɨ́n₂ dsɨ́₅ jág₃ jmɨg₄ i₁guan₃ jniá₂; jaun₂ ca₂jág₃, jaun₂ 'ŋio₅ lɨn₃ 'io'₂ ca₂jén'₃.
\p 
\v 57 Jaun₂ në́₃ ca₂juá'₂ dsa₂ judíos ca₂tsɨ́'₃ Jesús:
\p ―Tsá₃ ma₂'eng'₅₄ bá₄ guë́₄ të₂láu₃-guiá₂ ŋi₂. ¿'A₂ guë'₂ lia'₂ juá'₂ 'ne₂ a₂ma₂jɨng'₅₄ 'lag₄ Abraham?
\p 
\v 58 Jaun₂ ca₂ŋag₃ Jesús:
\p ―A₂dsɨ₂jó'₃ juɨg₂ jniá₂ 'nia'₂, né'₃ guë́₄ a₂le₃chan₂ Abraham, jniá₂ lɨ́ng₅.\f + \fr 8:58 \ft Jág₁ “jniá₂ lɨ́ng₅” co₂'nió'₄ jein₅ jág₁ lia'₂ chen₂ Jehová. 'Nio'₂ ja₁ton₅ Éxodo 3:14.\f*
\p 
\v 59 Jaun₂ në́₃ qui₂ca₂jŋa'₃ cang₄ a₂jme₁qui'₃ quió'₅. La₁ ca₂'ma₃ bá₄ Jesús, jaun₂ o₂'ɨ́in₃ i₁dsi₅ guá'₅ templo.\f + \fr 8:59 \ft A₂lɨn₅₄ chog₅₄ si₂ juá'₂ ján₃: “jaun₂ ca₂ŋɨ́i₃ jɨn₄ dsa₂ 'éi₂, ca₂ŋái'₃.” \f*
\c 9
\s1 Ca₂jme₃'lión₂ Jesús jan₂ dsa₂ i₂ten₄ ca₂rë₃chán₃
\p 
\v 1 Jme₁ca₂ŋɨi₅ jaun₂, ca₂jɨ́in₂ jan₂ dsa₂ i₂ten₄ ca₂rë₃chán₃.
\v 2 Jaun₂ ca₂ŋag₃ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅:
\p ―Të₅, ¿'ein₂ bá₄ ca₂'náu₂ dso₄? ¿Dsa₂ la₂, o₃ chog₅₄-jmei₂ 'e₂, a₂ca₂rë₃cháin₃ tein₅₄?
\p 
\v 3 Jaun₂ ca₂juá'₂ Jesús:
\p ―On₃jua'₅₄ 'uɨg₅₄ dsáu₂ 'ŋiog₅, on₃ guë'₂ 'uɨg₅₄ dsáu₁ chog₅₄-jmei₂; a₂jaun₂ bá₄ ca₂lë₃ ia₁jaun₂ le₃jniá₂ juɨ₅bí₂ quió'₅ Diú₄ ja₁coin₂.
\v 4 Ca₂tág₂ jniog₄ jmó₁ ta₁\f + \fr 9:4 \ft A₂lɨn₅₄ chog₅₄ si₂: Ca₂tɨ́n₂ jniá₂ jmo₅₄ ta₁.\f* quió'₅ i₂ca₂chei₃ jniá₂ të₁lia'₂ jniá₂ guë́₄; ia₁ ma₂ja₂quián₃ néi₃, jë₁tsá₃ ma₃'ein₂ lé₂ le₃jmo₃ ta₁.
\v 5 Të₁lia'₂ 'en₅₄ jniá₂ mɨ₂güɨ́g₃ la₂, lɨ́ng₅ si₂ a₂tág₅ ja₁con₂ dsa₂ mɨ₂güɨ́g₃.
\p 
\v 6 Jme₁ca₂dsan₃ juá'₂ le₂në₅, jaun₂ ca₂'ŋéi₃ 'uë₃, ca₂jmo₃ ca₂juɨg₄ jein₂ quian'₅₄ jmɨ₁'ë́'₅ quió'₅, jaun₂ ca₂tsáng₂ jme₁ne₁ dsa₂ ten₄.
\v 7 Jaun₂ ca₂juá'₂ ca₂tsɨ́'₃ dsa₂ 'éi₂:
\p ―Gua₂ o₂rang₂ quiáng'₂ Dsiog₅ Siloé ―co₂'nió'₄ le₃jua'₅₄ jág₁, I₂chen₄, a₂chei₂ dsiog₅ jaun₂.
\p Jaun₂ ca₂ŋó₃ i₁rang₂ quió'₅, jaun₂ jme₁guáin'₃ táng₃ jaun₂, ma₂jág₅ bá₄.
\p 
\v 8 Jaun₂ qui₂ca₂ŋag₃ dsa₂ i₂tián'₅ cau₅ quió'₅, quian'₅₄ dsa₂ i₂jme₁ma₂ca₂jág₂ mɨ₅ 'éi₂ cu₄ le₂jŋiá₅, ca₂juá'₂:
\p ―¿On₁jua'₅₄ dsa₂ në₅ 'éi₂ i₂jme₁gua₂ mɨ₅ a₂jme₃'o₅₄ dsa₂ cu₄?
\p 
\v 9 I₂lɨn₅₄ juá'₂:
\p ―'Éi₂ bá₄ në₅.
\p I₂sián'₂ guë'₂ juá'₂:
\p ―On₃jua'₅₄ 'éi₂ në₅, la₁ia₁ mei'₂ tsá₃ le₂jaun₂ jniái₂.
\p La₁ ca₂juá'₂ dsa₂ 'éi₂ 'ŋiog₅:
\p ―Jniá₂ bá₄ 'éi₂.
\p 
\v 10 Jaun₂ në́₃ ca₂ŋag₃ dsa₂ ca₂ŋɨ́i'₃ 'éi₂:
\p ―¿'A₂ guë'₂ lia'₂ lë₃ ca₂jnióg₃ jme₁ne'₄ 'ne₂?
\p 
\v 11 Jaun₂ ca₂ŋag₃ dsa₂ 'éi₂:
\p ―Dsa₂ i₂të́'₂ dsa₂ Jesús në₂jmo₃ ti₁jéin₃, jaun₂ në₂tsáng₂ jme₁ne₃ jniá₂, jaun₂ në₂juá'₂ tság₅ jniá₂: “Gua₂ Dsiog₅ Siloé, o₂rang₂ quiáng'₂.” Jaun₂ ŋe₄ jniá₂, jaun₂ jme₁ca₂lë₃ rang₂₃ quió₃, co₂tan₅₄ lia'₂ në₂jág₃.
\p 
\v 12 Jaun₂ ca₂ŋag₃ dsa₂ ca₂ŋɨ́i'₃ dsa₂ i₂jme₁ten₄ 'éi₂:
\p ―¿Na₅ dsa₂ 'éi₂?
\p Jaun₂ ca₂juá'₂:
\p ―Tsá₃ guion₄ jniá₂.
\s1 Ca₂ŋag₃ dsa₂ fariseos jág₁ dsau₅ ne₄ dsa₂ i₂jme₁ten₄ i₂ca₂jme₃'lió₂ Jesús
\p 
\v 13 Jaun₂ në́₃ ca₂i₁jŋia₃ dsa₂ ne₄ dsa₂ fariseos dsa₂ i₂jme₁ten₄ 'éi₂.
\p 
\v 14 La₁ jmɨg₄ lia'₂ con'₂ jme₁ca₂jmo₃ Jesús ti₁jéin₃ a₂ca₂tsáng₂ mɨ₂ne₄ dsa₂ i₂jme₁ten₄ 'éi₂, jaun₂ dé₄ jmɨg₄ sa₅₄ bá₄ jaun₂.
\v 15 Jaun₂ ca₂ŋag₃ táng₃ dsa₂ fariseos ca₂ŋɨ́i'₃ dsa₂ 'éi₂, 'a₂ bá₄ lia'₂ jaun₂ ma₂lé₂ jág₃. Jaun₂ ca₂juá'₂ dsa₂ i₂jme₁ten₄ 'éi₂:
\p ―Në₂tsáng₂ ti₁jéin₃ jme₁ne₃ jniá₂, jaun₂ në₂rang₃ jniá₂ quió₃, jaun₂ lë₃ ma₂jág₅ jniá₂.
\p 
\v 16 Jaun₂ në́₃ ca₂juá'₂ i₂lɨn₅₄ dsa₂ fariseos:
\p ―Dsa₂ i₂në₂jmo₃ a₂në₅, on₃jua'₅₄ dsa₂ quián₅ Diú₄ 'éi₂, ia₁ tsá₃ jme₂gó'₃ jmɨg₄ sa₅₄.
\p La₁ i₂lɨn₅₄ guë'₂ juá'₂:
\p ―¿'A₂ lia'₂ lé₂ le₃jmo₃ jan₂ dsa₂ i₂cha₂ dsáu₁ léi₄ juë'₂ le₂në₅?
\p Jaun₂ lë₃ ca₂lë₃ le₁dson'₅₄ dsa₂.
\p 
\v 17 Jaun₂ ca₂ŋag₃ táng₃ dsa₂ ca₂ŋɨ́i'₃ dsa₂ i₂jme₁ten₄ 'éi₂:
\p ―¿'E₂ guë'₂ juá'₂ 'ne₂ lɨ́in₅, ia₁ jme₁ne'₄ 'ne₂ bá₄ në₂niá₃?
\p Jaun₂ ca₂ŋag₃ dsa₂ 'éi₂:
\p ―A₂lɨ́in₅ jan₂ dsa₂ i₂'ë́₂ jág₁ quián₅ Diú₄ bá₄.
\p 
\v 18 La₁ dsa₂ judíos në́₃, tsá₃ jme₁'éin₂ bá₄ guë́₄ a₂dsón'₂ jme₁ten₄ dsa₂ 'éi₂, ton'₂ ca₂tɨ́in'₃ jme₁ne₁₂, ca₂lia'₂ ca₂të́'₃ chog₅₄-jmei₂ dsa₂ 'éi₂.
\p 
\v 19 Jaun₂ ca₂ŋag₃ dsa₂ fariseos ca₂ŋɨ́i'₃ chog₅₄-jmei₂ 'éi₂:
\p ―¿Chi'₂ ja₂ŋí'₂ 'nia'₂ la₂, i₂juá'₂ 'nia'₂ i₂ten₄ ca₂rë₃chán₃? ¿'A₂ guë'₂ lia'₂ ma₂jág₅ në₃?
\p 
\v 20 Jaun₂ ca₂ŋag₃ chog₅₄-jmei₂:
\p ―Ne₄ bá₄ jnia'₅₄, chi'₂ quián₂ bá₄ jnia'₅₄ në₅, i₂ca₂rë₃chán₃ ten₄;
\v 21 la₁ tsá₃ ne₄ jnia'₅₄ 'a₂ guë'₂ lia'₂ në₃ ma₂lé₂ jág₃, on₃ guë'₂ ne₄ jnia'₅₄ 'ein₂ ca₂jmo₃ ca₂jŋia₃ mɨ₂ne₅₄. Ŋag₄ caun₂ 'nia'₂ guiong'₅₄; i₂ma₂juɨn'₂ bá₄ në₅, jaun₂ lé₂ bá₄ juá'₂ 'ŋiog₅ 'a₂ lia'₂ ca₂lë₃.
\p 
\v 22 Ca₂juá'₂ chog₅₄-jmei₂ le₂në₅ 'uɨg₅₄ ia₁ a₂gó'₅ gain₃ dsa₂ judíos, ia₁ jme₁ma₂ca₂jmo₃ 'éi₂ caun₂ jág₁ a₂'uág'₂ 'uɨ́in'₂ dsa₂ ja₁le₁toin₂₃ ne₄ si₂ guá'₅ sinagoga juɨ₁'ein₂ guë́₃ i₂juá'₂, Jesús bá₄ lɨ́n₅ I₂rë₂'ɨ́n₁ quián₅ Diú₄.
\v 23 'Uɨg₅₄ jaun₂ bá₄ ca₂juá'₂ chog₅₄-jmei₂: “Ŋag₄ caun₂ 'nia'₂ guiong'₅₄, i₂ma₂juɨn'₂ bá₄ në₅.”
\p 
\v 24 Jaun₂ bá₄ ca₂të₃ táng₃ dsa₂ judíos ca₂të́'₃ dsa₂ i₂jme₁ten₄ 'éi₂, jë₁ca₂të́₂ táng₃ ráun₂, jaun₂ ca₂juá'₂:
\p ―Jua'₅₄ jág₁ dsau₅ të₃dsón'₂ ne₄ Diú₄;\f + \fr 9:24 \ft lit. “jme₁juɨn'₂ Diú₄”, co₂'nió'₄ quian'₅₄ jág₁ në₅ jme₁jmo₅ dsɨ₂tan₅₄ 'éi'₃ ja₁con₂ dsa₂, a₂juá'₂ tion₅₄ jág₁ tí₅ dsón'₂. 'Nio'₂ ja₁ton₅ Josué 7:19, Mateo 26:63.\f* ne₄ bá₄ jnia'₅₄ jan₂ dsa₂ i₂cha₂ dsáu₁ bá₄ 'éi₂.
\p 
\v 25 Jaun₂ në́₃ ca₂ŋag₃ dsa₂ 'éi₂:
\p ―Tsá₃ a₂jaun₂ guion₄ jniá₂ jua'₅₄ jan₂ dsa₂ cha₂ dsáu₁ 'éi₂, o₃ tsá₃ dsáu₁ cha₂ 'e₂. Jŋia'₅₄ lia'₂ a₂jaun₂ bá₄ guion₅₄, a₂jme₁ten₄ bá₄ jniá₂, la₁ në₃ ma₂lé₂ bá₄ jág₄.
\p 
\v 26 Jaun₂ ca₂ŋag₃ táng₃ dsa₂ fariseos:
\p ―¿'E₂ ca₂jmo₃ quiáng'₂? ¿'A₂ lia'₂ ca₂jmo₃ dsa₂ 'éi₂ a₂ca₂jnia₃ mɨ₂ne'₅₄?
\p 
\v 27 Jaun₂ ca₂ŋag₃ dsa₂ 'éi₂:
\p ―Ma₂në₂juá'₃ guë'₂ jniá₂. Tsá₃ tón'₂ guë'₂ 'nia'₂ juɨ₅ 'e₂ juá'₅ jniá₂. ¿'E₂ lë₃ 'niog'₂ 'nia'₂ nág'₂ táng₃? ¿O₃ bá₄ ján₃ guë'₂ 'niog'₂ 'nia'₂ le₃'éng'₂ le₃quió'₅ 'éi₂?
\p 
\v 28 Jaun₂ qui₂ca₂jnáu'₂ dsa₂ jág₁ uɨg₅, jaun₂ ca₂juá'₂:
\p ―'Ne₂ 'éng'₂ le₃quió'₅ dsa₂ 'éi₂, la₁ia₁ jnia'₅₄ guë'₂ 'éin₂ le₃quió'₅ Moisés.
\v 29 Ne₄ jnia'₅₄, a₂ca₂dsia₃ Diú₄ jág₁ quian'₅₄ Moisés, la₁ dsa₂ 'éi₂ guë'₂ në́₃, tsá₃ ne₄ a₂já'₄ já₅.
\p 
\v 30 Jaun₂ ca₂ŋag₃ dsa₂ 'éi₂ në́₃ ca₂juá'₂:
\p ―¡Dsón'₂ bá₄ jaun₂ dsɨ₂gó'₃ dsɨ₅ a₂jaun₂: a₂tsá₃ ŋi'₅₄ 'nia'₂ a₂já'₄ já₅, ton'₂ ca₂jme₃jnio₅₄ jme₁ne₃!
\v 31 Ma₂ne₄ rë₂ bá₄ jniog₄ jaun₂, a₂tsá₃ nag₅ Diú₄ jág₁ quió'₅ dsa₂ i₂cha₂ dsáu₁; jmá'₃ lia'₂ jág₁ quió'₅ dsa₂ i₂jme₂gan₃ Diú₄, i₂qui₂jmo₅ a₂'ŋio₂ dsɨ́₅ 'éi₂: quió'₅ 'éi₂ bá₄ nag₂₃.
\v 32 Lia'₂ 'i₁cón'₂ tsá₃ 'ein₂ ma₂nág₂ ca₂le₂jŋiá₅ jua'₅₄ chan₂ dsa₂ i₂lé₂ le₃jme₃'lión₂ jan₂ dsa₂ i₂ten₄ ca₂rë₃chán₃.
\v 33 Jua'₅₄ mei'₂ guë́₃ tsá₃ já₅ dsa₂ 'éi₂ ja₁con₂ Diú₄, tsá₃ 'e₂ lé₂ jme₁jmo₃.
\p 
\v 34 Jaun₂ në́₃ ca₂ŋag₃ dsa₂ fariseos:
\p ―Co₂ŋei'₅₄ bá₄ ne₄ dsáu'₂ ca₂rë₃cháng'₃. ¿I₂'ein₂ bá₄ lɨ́n'₅ 'ne₂ jaun₂ jme₁tag'₅ jnia'₅₄?
\p Jaun₂ ca₂dsei₅ dsa₂.
\s1 Juɨ₁lia'₂ dsa₂ ten₄ të₂le₃ gu₂dsí₂
\p 
\v 35 Jaun₂ ca₂rë₃ŋi₅ Jesús jág₁ a₂ca₂dsen₅ dsa₂ ca₂dsein₂₃ dsa₂ i₂jme₁ten₄ 'éi₂. Jaun₂ jme₁ca₂jein'₂, ca₂juá'₂:
\p ―¿'Én'₂ 'ne₂ të₂le₃ quió'₅ Jaun₅ dsa₂ mɨ₂güɨ́g₃?\f + \fr 9:35 \ft A₂lɨn₅₄ chog₅₄ si₂ juá'₂: “¿'Én'₂ 'ne₂ të₂le₃ quió'₅ Ja₁ŋi'₅₄ Diú₄?” \f*
\p 
\v 36 Jaun₂ ca₂juá'₂ dsa₂ 'éi₂:
\p ―Gui'₅₄, ¿i₂'ein₂ bá₄ 'éi₂, ia₁jaun₂ lé₂ le₃'én₂ jniá₂ le₃quió'₅?
\p 
\v 37 Jaun₂ ca₂ŋag₃ Jesús:
\p ―Ma₂në₂jɨin'₅₄ bá₄, jaun₂ jniá₂ bá₄ 'éi₂ i₂dsia'₂ jág₁ quiang'₅₄.
\p 
\v 38 Jaun₂ bá₄ ca₂chi₃jné₃ dsa₂ 'éi₂ ne₄ Jesús, jaun₂ ca₂juá'₂:
\p ―'Én₂ bá₄ jniá₂, Te₁gui'₅₄.
\p 
\v 39 Jaun₂ ca₂juá'₂ Jesús:
\p ―A₂qui₁dsɨ₅ 'éi'₃ bá₄ jniá₂ guio₃ mɨ₂güɨ́g₃ la₂, ia₁jaun₂ jág₃ juɨ₁lia'₂ dsa₂ ten₄, ton'₂ ia₁jaun₂ le₃ten₄ juɨ₁lia'₂ dsa₂ i₂jág₅.
\p 
\v 40 Jaun₂ qui₂ca₂nág₂ jág₁ jaun₂ i₂lɨn₅₄ dsa₂ fariseos i₂jme₁tion'₅₄ quian'₅₄ Jesús, jaun₂ ca₂ŋag₃:
\p ―¿O₃ bá₄ dsa₂ ten₄ lág₅ jnia'₅₄ ján₃?
\p 
\v 41 Jaun₂ ca₂ŋag₃ Jesús:
\p ―Jua'₅₄ mei'₂ guë́₃ lɨ́n'₅ 'nia'₂ dsa₂ ten₄, tsá₃ dso₄ jme₁qui₂le₃cán'₂ 'nia'₂. La₁ia₁, 'uɨg₅₄ ia₁ a₂juá'₂ 'nia'₂, “ne₄ jnia'₅₄”, jaun₂ të₂'ŋiá₄ dsáu'₂ 'nia'₂.
\c 10
\s1 Jág₁ jáng'₅ léi₄ juɨ₁lia'₂ dsa₂ i₂jmo₅ 'í₁ já'₂ cha'₂
\p 
\v 1 'A₂dsɨ₂jó'₃ juɨ́g₂ jniá₂ 'nia'₂, juɨ₁lia'₂ i₂tsá₃ tón'₅ të₂le₃ juɨ₅ o₄'né₄ tsɨ₁jnɨ́₂ ja₁tion'₅₄ já'₂ cha'₂, a₂uɨ́g₂ juɨ₅ siá'₂, dsa₂ 'ang₂ bá₄ 'éi₂.
\v 2 La₁ia₁ juɨ₁lia'₂ i₂'í₂ të₂le₃ o₄'né₄, dsa₂ i₂jmo₅ 'í₁ já'₂ cha'₂ bá₄ 'éi₂.
\v 3 O₄quió'₄ 'éi₂ bá₄ niá₅ dsa₂ i₂jmo₅ 'í₁ o₄'né₄, jaun₂ já'₂ cha'₂ në́₃, rë₂cuɨ́'₅ jág₁ quió'₅ 'éi₂. Jaun₂ të́'₂ já'₂ cha'₂ quiáin₅ 'ŋiog₅ lia'₂ chein₂, jaun₂ 'uág'₂.
\v 4 Jë₁ma₂ca₂lë₃ 'uɨ́in'₂ ca₂le₃jɨ́n₃ con'₂ i₂quiáin₅ 'ŋiog₅, jaun₂ cán₂ ne₄ juɨ₅, dsó₅ ne₄ já'₂ cha'₂. Já'₂ cha'₂ në́₃ dsɨ₂léin₂ chi₁co'₅₄ quió'₅, ia₁ rë₂cuɨ́'₅ bá₄ jág₁ quió'₅.
\v 5 La₁ tsá₃ 'ein₂₃ juɨ₁lia'₂ dsa₂ i₂tsá₃ cuɨin₂₃; të₂le₃ cuɨng₂₃ bá₄ ja₁con₂ 'éi₂, ia₁ tsá₃ cuɨ́'₅ jág₁ quió'₅ dsa₂ sián'₂.
\p 
\v 6 Ca₂juá'₂ Jesús jág₁ a₂jáng'₅ léi₄ në₅, la₁ tsá₃ ca₂rë₃ŋɨ́'₂ dsa₂, 'e₂ jein₅ jág₁ jaun₂ a₂juá'₂.
\s1 Jan₂ Jesús i₂dsen₃ i₂jmo₅ 'í₁ já'₂ cha'₂
\p 
\v 7 Jaun₂ në́₃ ca₂juá'₂ táng₃ Jesús ca₂tsɨ́'₃ dsa₂:
\p ―A₂dsɨ₂jó'₃ juɨ́g₂ jniá₂ 'nia'₂, jniá₂ bá₄ lɨ́ng₅ o₄'né₄ juɨ₅ ja₁dsɨ₂ton'₅₄ já'₂ cha'₂.
\v 8 Ca₂le₃jɨ́n₃ i₂ma₂o₃lén₂ jŋiá₅ guë́₄ con'₂ guë́₄ jniá₂, dsa₂ 'ang₂ bá₄ 'éi₂; la₁ já'₂ cha'₂ në́₃, tsá₃ juɨ₅ ca₂ton'₂ quió'₅.
\v 9 Jniá₂ lɨ́ng₅ o₄'né₄; juɨ₁lia'₂ i₂tón'₅ juɨ₅ le₃quió₃, tɨ́in'₄ bá₄. Jaun₂ qui₃dsɨ₃toin'₅₄, qui₃'uɨ́in₃, jaun₂ dsio'₂ bá₄ ŋi₂ma'₂ a₂guë́'₃.
\p 
\v 10 ’Dsa₂ 'ang₂ në́₃, jmá'₃ ta₁ jaun₂ bá₄ ja₂: a₂'ang₃, a₂jme₃dsiog₂₃, a₂qui₃'éin₂ në́₃; jniá₂ në́₃ guio₃ ia₁jaun₂ le₃chain₂, a₂le₃chain₂ qui₂rë₂tsón₂.
\v 11 Jniá₂ bá₄ lɨ́ng₅ juɨg₅₄ dsen₃ i₂jmo₅ 'í₁ já'₂ cha'₂.\f + \fr 10:11 \ft 'Í₂ Ezequiel 34.\f* Guen₅ 'mú₃ juɨg₅₄ dsen₃ o₄quió'₄ já'₂ cha'₂;
\v 12 la₁ juɨ₁lia'₂ dsa₂ i₂jmo₅ ta₁ a₂'liain'₅₄, jë₁ma₂ca₂jág₃ já₅ dsɨ₂jɨ'₅₄ náu₂, téin₂ bá₄ já'₂ cha'₂ jaun₂ cuɨng₂₃ bá₄ 'ŋiog₅, ia₁ on₃jua'₅₄ juɨg₅₄ i₂quián₅ já'₂ cha'₂ 'éi₂. Jaun₂ dsɨ₂jɨ'₅₄ náu₂ në́₃, tsáin'₂ já'₂ cha'₂, jaun₂ jmo₂₃ le₁jan₅₄ já'₂.
\v 13 Dsa₂ 'éi₂ në́₃, cuɨng₂₃ ia₁ a₂'liain'₅₄ bá₄ jmo₂₃ 'í₁; tsá₃ dsan₂ dsɨ́₅ já'₂.
\v 14 Jniá₂ bá₄ lɨ́ng₅ juɨg₅₄ dsen₃; i₂cuɨ́n₅ bá₄ jniá₂ já'₂ cha'₂ quiáng₃; 'éi₂ në́₃ cuɨg₂₃ jniá₂.
\v 15 Le₂jaun₂ juɨ₁lia'₂ cuɨg₅ Ŋe'₃ jniá₂, ján₃ bá₄ cuɨ́n₅ jniá₂ 'éi₂ në́₃. Guén₅ jniá₂ 'mú₃ o₄quió'₄ já'₂ cha'₂ quiáng₃.
\v 16 Ján₃ bá₄ tion'₅₄ já'₂ cha'₂ sián'₂ quiáng₃ i₂tsá₃ tion'₅₄ 'ŋió'₃ jnɨ́₁ la₂; ján₃ bá₄ ca₂tɨ́n₂ jniá₂ i₁te₁ 'éi₂. Ján₃ bá₄ le₃ne'₅₄ 'éi₂ jág₁ quió₃, jaun₂ co₂nió'₃ bá₄ lé₂, jan₂ guë'₂ juɨg₅₄.
\p 
\v 17 ’'Uɨg₅₄ jaun₂ bá₄ 'nio₃ Ŋe'₃ jniá₂: ia₁ jáng'₅ jme₂dsí₂ quió₃,\f + \fr 10:17 \ft 'Nio'₂ ja₁ton₅ Juan 19:30.\f* ia₁jaun₂ tɨ́ng'₄ táng₃.
\v 18 Lia'₂ 'i₁jan₂ tsá₃ jŋiá'₂ jme₂dsí₂ a₂chan₂ jniá₂, ia₁ jáng'₅ bá₄ jniá₂ jme₂dsí₂ a₂chang₂ a₂'ŋio₂ dsɨ₃ 'ŋió₃. Jniá₂ bá₄ 'o₂₃ bí₂ jáng'₅, jaun₂ 'o₂₃ bí₂ tɨ́ng'₄ táng₃. 'Éi'₃ në₅ ca₂ŋɨg₂ ja₁con₂ Ŋe'₃.
\p 
\v 19 Jaun₂ ca₂lë₃ le₁dson'₅₄ táng₃ dsa₂ judíos, jme₁ca₂nág₂ jág₁ në₅.
\p 
\v 20 Juɨn₅ i₂'éi₂ juá'₂:
\p ―I₂'en₅₄ jan₂ jme₂dsí₂ je₂na'₅₄ të₂dsɨ́₅ bá₄ në₅, të₂'ɨ₂₃ a₂ŋái₅ në́₃. ¿'E₂ lë₃ tón'₂ 'nia'₂ juɨ₅ jág₁ quió'₅?
\p 
\v 21 La₁ i₂lɨn₅₄ guë'₂ juá'₂:
\p ―On₃jua'₅₄ jág₁ quió'₅ jan₂ i₂'en₅₄ je₂na'₅₄ të₂dsɨ́₅ në₅. ¿Lé₂ le₃jmo₃ je₂na'₅₄ a₂jág₃ juɨ₁lia'₂ dsa₂ ten₄?
\s1 Tsá₃ ca₂guen₃ dsa₂ judíos Jesús
\p 
\v 22 Jmɨg₄ jaun₂, jme₁tion'₅₄ dsa₂ juɨg₂ Jerusalén jmo₂₃ Jmɨg₄ quió'₅ Si₂. Jein₂ güɨ́g₂ jme₁lë́₄,
\v 23 jaun₂ jme₁i₂ŋɨ₅₄ Jesús i₁dsi₅ guá'₅ templo ja₁lë́₄ corredor a₂chei₂ Quió'₅ Salomón,
\v 24 jaun₂ qui₂ca₂o₃lio₃ dsa₂ judíos quió'₅, jaun₂ ca₂juá'₂:
\p ―¿'A₂ con'₂ jmó'₂ 'ne₂ 'ag₃ guë́₄ caun₂-tɨn₃ dsɨ₅ jnia'₅₄? Chi₂jua'₂ dsón'₂ lɨ́n'₅ 'ne₂ I₂rë₂'ɨ́n₁ quián₅ Diú₄, co₂ŋei'₅₄ jua'₅₄ rë₂jiá₃ jág₁.
\p 
\v 25 Jaun₂ ca₂ŋag₃ Jesús:
\p ―Ma₂në₂juá'₃ bá₄ jniá₂, la₁ tsá₃ ca₂rë₃'én'₂ guë'₂ 'nia'₂. Qui₂jáng'₅ bá₄ jág₁ dsau₅ o₄quió₃, léi₄ a₂jmo₅ jniá₂;
\v 26 la₁ tsá₃ 'én'₂ 'nia'₂, ia₁ tsá₃ lɨ́n'₅ 'nia'₂ já'₂ cha'₂ quiáng₃.
\v 27 Ne'₅₄ bá₄ já'₂ cha'₂ quiáng₃ jág₁ quió₃; i₂cuɨg₅ bá₄ 'éi₂ jniá₂, jaun₂ ja₂'ein₂₃ chi₁co'₅₄ quió₃.
\v 28 Cuë́₅ jniá₂ jme₂dsí₂ a₂le₃chain₂ co₂tan₅₄, jaun₂ lia'₂ o₁lɨ́g'₂ jmɨg₄ tsá₃ dsiáin₃, on₃ guë́₄ lia'₂ 'i₁jan₂ tsá₃ lé₂ le₃jŋiái'₂ 'éi₂ o₄gu₃ jniá₂.
\v 29 Ŋe'₃ jniá₂, i₂ma₂cuag₃ 'éi₂, lɨ́n₅ i₂juɨn'₂ guë́₄ lia'₂ con'₂ guë́₄ ca₂le₃jɨ́n₃; jaun₂ lia'₂ 'i₁jan₂ tsá₃ lé₂ jŋióg'₂ o₄gú₃ Ŋe'₃.
\v 30 Jniá₂ quian'₅₄ Ŋe'₃, ca₂ne₅₄ bá₄ lág₅ jnia'₅₄.
\p 
\v 31 Jaun₂ në́₃ ca₂jŋa'₃ táng₃ dsa₂ judíos nɨ₁cang₁ a₂qui'₃ quió'₅.
\v 32 Jaun₂ ca₂juá'₂ Jesús:
\p ―'Lióng₂ lɨn₃ léi₄ dse₃ ma₂'ë́₃ jniá₂ 'nia'₂ të₂le₃ quian'₅₄ juɨ₅bí₂ quió'₅ Ŋe'₃; ¿o₄quió'₄ 'e₂ caun₂ a₂ma₂jmo₃ jniá₂ jaun₂, a₂qui₁jnau'₅₄ 'nia'₂ jniá₂ nɨ₁cang₁?
\p 
\v 33 Jaun₂ ca₂ŋag₃ dsa₂ judíos:
\p ―Tsá₃ o₄quió'₄ léi₄ dse₃ qui₁jna'₅₄ jnia'₅₄ 'ne₂ nɨ₁cang₁; a₂jaun₂ bá₄ ia₁ a₂'ɨ́ng'₅ 'lɨg'₅₄ Diú₄, a₂jmo'₂ 'ne₂ a₂lɨ́ng'₅ Diú₄, ton'₂ jan₂ dsa₂ mɨ₂güɨ́g₃ bá₄ lɨ́ng'₅.
\p 
\v 34 Jaun₂ në́₃ ca₂juá'₂ Jesús tsɨ́'₅ dsa₂ judíos:
\p ―¿Tsa₁ chi₁ton₅ ne₄ Si₂ 'Éi'₂ quián'₂ 'nia'₂: “A₂ma₂juá'₃ jniá₂, a₂lɨ́n'₅ 'nia'₂ diú₄”?\f + \fr 10:34 \ft Salmo 82:6.\f*
\v 35 Chi₂jua'₂ ca₂të́'₃ “diú₄” dsa₂ i₂ca₂ŋɨ₂ jág₁ quió'₅ Diú₄, (jaun₂ tsá₃ lé₂ jua'₅₄ tsá₃ le₃ti₃ Si₂);
\v 36 'ë₂ guë́₄ bá₄ 'éi₂ i₂ca₂jmo₃ Diú₄ rë₂tson₄, i₂ca₂chein₃ mɨ₂güɨ́g₃. ¿'Nia'₂ juɨg'₂ 'ɨ́ng'₅ 'lɨg'₅₄ Diú₄ ia₁ jniá₂ në₂juá'₃ a₂lɨ́ng₅ Ja₁ŋi'₅₄ Diú₄?
\v 37 Chi₂jua'₂ tsá₃ jmo₅ jniá₂ ta₁ quió'₅ Ŋe'₃, tsá₃ juɨ₁le₂'én'₂ 'nia'₂ le₃quió₃ jniá₂.
\v 38 La₁ chi₂jua'₂ jmo₅ guë'₂ jniá₂, juɨ₁'a₂ guë́₃ la₂ tsá₃ 'én'₂ 'nia'₂ të₂le₃ quió₃ jniá₂, juɨ₁le₂'én'₂ bá₄ 'nia'₂ të₂le₃ quió'₅ ta₁ a₂jmo₅ jniá₂, ia₁jaun₂ le₃ŋi'₅₄ bá₄, ia₁jaun₂ le₃ŋɨ́'₂ 'au'₂ 'nia'₂,\f + \fr 10:38 \ft A₂lɨn₅₄ chog₅₄ si₂ juá'₂: “ia₁jaun₂ le₃'én'₂ 'nia'₂.” \f* a₂'en₅₄ Ŋe'₃ ja₁cong₂, le₂jaun₂ guë'₂ táng₃, a₂'en₅₄ jniá₂ ja₁con₂ Ŋe'₃.
\p 
\v 39 Jaun₂ jme₁'nio₃ táng₃ dsa₂ jme₁tsáun'₂, la₁ ca₂lóin₂ bá₄ o₄gú₃ 'éi₂.
\p 
\v 40 Jaun₂ në́₃, ŋó₃ táng₃ Jesús të₂le₃ quióng₄ Cuá₃ Jordán, jaun₂ ca₂jŋia₃ ja₁jaun₂ ja₁jme₁'en₅₄ Juan₅₄ le₂jŋiá₅ choin₂₃ jmɨg₂ dsa₂.\f + \fr 10:40 \ft lit. “tiáin₂ dsa₂ jmɨg₂” \f*
\v 41 Juɨn₅ lɨn₃ dsa₂ ca₂i₁len₅₄ i₁jag₅₄, qui₂ca₂juá'₂:
\p ―Të₃dsón'₂ bá₄, o₁jŋia'₅₄ tsá₃ 'e₂ léi₄ juë'₂ ca₂jmo₃ Juan₅₄, la₁ ca₂le₃jë́₃ 'e₂ a₂ca₂juá'₂ a₂'ɨin₂₃ dsa₂ në₅, dsau₅ bá₄.
\p 
\v 42 Ja₁jaun₂ ca₂rë₃'én₂ juɨn₅ dsa₂ le₃quió'₅ Jesús.
\c 11
\s1 Ca₂jon₃ Lázaro
\p 
\v 1 Jme₁chan₂ jan₂ dsa₂ dso'₅₄ i₂jme₁chen₂ Lázaro, i₂jme₁chan₂ juɨg₂ Betania, juɨg₂ ja₁guá₄ María quian'₅₄ 'io₅₄ rɨin'₅₄ i₂chen₂ Marta.
\p 
\v 2 María në₅ në́₃ i₂rɨn'₅₄ Si₁Lia₁ dsa₂ dso'₅₄, 'éi₂ bá₄ i₂ca₂'ág₂ no'₅₄ mɨ₂juɨg₂ mɨ₂tag₄ Te₁gui'₅₄ jaun₂ ca₂chí₃, ca₂jme₃quéin₃ quian'₅₄ jŋi₂ dsi₅₄.
\p 
\v 3 Jaun₂ në́₃, ca₂chen₃ le₃on₃ 'io₅₄ jág₁ ne₄ Jesús:
\p ―Te₁gui'₅₄, a₂ron₅ dso'₅₄ dsa₂ i₂'nio₄ quiáng'₂.
\p 
\v 4 Jaun₂ jme₁ca₂nág₂ Jesús, ca₂juá'₂:
\p ―On₃jua'₅₄ dso₄ a₂jiog₅ juɨ₅ 'mú₃ jaun₂; të₂le₃ ia₁jaun₂ le₃juɨn'₂ Diú₄ bá₄, le₂jaun₂ guë'₂ Ja₁ŋi'₅₄ Diú₄ ján₃ le₃juɨin'₂ të₂le₃ quian'₅₄ dso₄ jaun₂.
\p 
\v 5 Jesús në́₃, jme₁'nioi₃ 'ŋio₅ lɨn₃ Marta quian'₅₄ 'io₅₄ rɨin'₅₄, quian'₅₄ Si₁Lia₁.
\v 6 Jaun₂ lë₃, jme₁ca₂juá'₂ dsa₂ a₂dso'₅₄ Si₁Lia₁, ca₂jŋia₃ guë́₄ tɨn₃ jmɨg₄ ja₁jme₁'ein₅₄ jaun₂.
\v 7 Cang₂ jaun₂, ca₂juá'₂ ca₂tsɨ́'₃ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅:
\p ―Ma₃dsau₅₄ táng₃ juɨ₅ Judea.
\p 
\v 8 Jaun₂ në́₃ ca₂juá'₂ chi'₂ dsɨ₂guia₃-tɨ́n₂:
\p ―Të₅, i₁jáun₃ në₅ cón'₅ jme₁'nio₃ dsa₂ judíos jme₁qui₃jnáu'₂ cang₄; ¿con'₂ guë'₂ lia'₂ 'niog'₂ gog'₅₄ táng₃ ja₁jaun₂?
\p 
\v 9 Jaun₂ ca₂ŋag₃ Jesús:
\p ―¿On₁ dsón'₂ quian₅ guia₃-tɨ́n₂ horas caun₂ jmɨg₄? Në₁jua'₂ i₂nio₄ dsa₂ a₂jmɨ₂, tsá₃ qui₂niói₅, ia₁ jág₅ si₂ a₂tág₅ ja₁con₂ dsa₂ mɨ₂güɨ́g₃;
\v 10 la₁ në₁jua'₂ i₂nio₄ dsa₂ jë₄ qui₁né'₃ qui₂niói₅ ia₁ tsá₃ si₂ cha₂ ja₁coin₂.
\p 
\v 11 Cang₂ jme₁ma₂në₂juá'₂ le₂në₅, jaun₂ ca₂juá'₂:
\p ―Ma₂ca₂güɨn₂ bá₄ Si₁Lia₁ a₂mei₅₄ quián₂ jniog₄; la₁ nei₅₄ jniá₂ i₁ŋei₁₂.
\p 
\v 12 Jaun₂ në́₃ ca₂juá'₂ chi'₂ dsɨ₂guia₃-tɨ́n₂:
\p ―Te₁gui'₅₄, chi₂jua'₂ ma₂ca₂güɨin₂, co₂'nió'₄ jŋia₃ bá₄ quió'₅.
\p 
\v 13 La₁ a₂jaun₂ bá₄ jme₁'nio₃ Jesús juá'₂ a₂jme₁ma₂jon₅ bá₄ 'éi₂; la₁ jaun₂ bá₄ lɨ́n₂ chi'₂ dsɨ₂guia₃-tɨ́n₂ a₂'ë₅ Jesús juɨ₁lia'₂ a₂güɨn₂ dsa₂ jë₁ma₂ca₂nei₂.
\p 
\v 14 Jaun₂ në́₃ ca₂juá'₂ Jesús lia'₂ rë₂jiá₃ jág₁:
\p ―Ma₂ca₂jon₃ bá₄ Si₁Lia₁.
\v 15 Jéin₅ jniá₂ 'io'₂ o₄quián'₂ 'nia'₂, a₂tsá₃ jme₁'eng₅₄ ja₁jaun₂, ia₁jaun₂ le₃'én'₂ 'nia'₂. La₁ ma₃dsau₅₄ ma₃dsɨ₁jɨin₅₄.
\p 
\v 16 Jaun₂ në́₃ ca₂juá'₂ To₁má₄ i₂të́'₂ dsa₂ Dsa₂ Tsɨn'₅₄, ca₂tsɨ́'₃ chi'₂ dsɨ₂guia₃-tɨ́n₂ rɨin'₅₄:
\p ―Ján₃ guë'₂ dsau₅₄ jniog₄, ia₁jaun₂ dsióg₃ co₂lë₅ quian'₅₄ i₂në₅.
\s1 Jesús bá₄ i₂jmo₅ a₂jen'₅₄ dsa₂, i₂cuë₅ jme₂dsí₂ a₂le₃chan₂ dsa₂
\p 
\v 17 Jme₁ma₂të́₂ quén₂ jmɨg₄ 'en₅₄ Si₁Lia₁ tau₂ 'ŋio₅, jme₁dsióg₃.
\p 
\v 18 Juɨg₂ Betania jaun₂, jme₁niog₅ cau₅ ma₂quián₅ Jerusalén con'₂ tɨn₃ kilómetros të₂ ca₂jau₅₄.
\p 
\v 19 Jaun₂ ca₂i₁len₅₄ juɨn₅ dsa₂ judíos ca₂i₁jɨin₁₂ Marta quian'₅₄ María rɨin'₅₄, ca₂i₁jmo₅₄ lián'₂ dsɨ́₅ 'éi₂, ia₁ ca₂jon₃ Si₁Lia₁ rɨin'₅₄.
\p 
\v 20 Jaun₂ Marta në́₃, jme₂ca₂rë₃ŋi₅ a₂ma₂já₅ Jesús, jaun₂ ca₂o₃'ɨ́in₃ ca₂i₁jme₁jein'₂. La₁ María në́₃ ca₂jŋia₃ bá₄ dsi₂néi₂.
\p 
\v 21 Jaun₂ ca₂juá'₂ Marta ca₂tsɨ́'₃ Jesús:
\p ―Te₁gui'₅₄, jua'₅₄ mei'₂ bá₄ jme₁'eng'₅₄ ja₁lá₃, tsá₃ jme₁jón₂ dsó₂ rɨ́ng'₃.
\v 22 La₁ia₁ guion₄ jniá₂, o₁jŋia'₅₄ con'₂ lë́₅ la₂, chi₂jua'₂ 'e₂ a₂mɨ'₂ 'ne₂ ja₁con₂ Diú₄, cuë₃ bá₄ 'éi₂.
\p 
\v 23 Jaun₂ ca₂juá'₂ Jesús:
\p ―Le₃chan₂ bá₄ táng₃ rɨ́ng'₂.
\p 
\v 24 Jaun₂ ca₂juá'₂ Marta:
\p ―Guion₄ bá₄ jniá₂ a₂le₃chain₂ táng₃ jë₁ma₂të́₂ rë₁jein'₅₄ jɨn₄ 'lag₄, jmɨg₄ jë₁ca₂tó'₂.
\p 
\v 25 Jaun₂ në́₃ ca₂juá'₂ Jesús:
\p ―Jniá₂ bá₄ lɨ́ng₅ i₂jmo₅ a₂jen'₅₄ dsa₂, i₂cuë₅ jme₂dsí₂ a₂le₃chan₂ dsa₂ në́₃. Juɨ₁lia'₂ i₂'én₂ të₂le₃ quió₃ jniá₂, o₁jŋia'₅₄ ma₂join₂₃, le₃chain₂ bá₄;
\v 26 jaun₂ chi₂jua'₂ 'ein₂ i₂chan₂ guë́₄, në₁jua'₂ ca₂rë₃'éin₂ të₂le₃ quió₃ jniá₂, lia'₂ o₁lɨ́g'₂ jmɨg₄ tsá₃ jóin₂. ¿'Éng'₂ jág₁ në₅?
\p 
\v 27 Jaun₂ ca₂juá'₂ Marta:
\p ―Ján₅, Te₁gui'₅₄. Ma₂ca₂rë₃'én₂ bá₄ jniá₂ a₂lɨ́n'₅ 'ne₂ Ja₁ŋi'₅₄ Diú₄ I₂rë₂'ɨ́n₁ quiáin₅, i₂lë́₅ jág₁ jiá₃ mɨ₂güɨ́g₃.
\s1 Ca₂'o₃ Jesús cau₅ tau₂ 'ŋio₅ quió'₅ Si₁Lia₁
\p 
\v 28 Jme₁ca₂lë₃ juá'₂ Marta jág₁ në₅, ŋái'₃ i₁te'₂ María rɨin'₅₄; jaun₂ ca₂juá'₂ jág₁ con'₂ të₃co'₅₄:
\p ―La₂ ma₂'en₅₄ të₅, jaun₂ 'ne₂ të́'₂.
\p 
\v 29 Dsɨ₂juɨ₅ jme₁ca₂nág₂ María jág₁ në₅, ca₂nau₂, jaun₂ ŋó₃ i₁jɨin₂₃ Jesús.
\p 
\v 30 Tsá₃ jme₁ma₂dsióg₃ guë́₄ Jesús të₃jë₄ juɨg₂; jaun₂ bá₄ jme₁'ein₅₄ ja₁ca₂jein'₂ Marta.
\p 
\v 31 Dsa₂ judíos i₂tion'₅₄ dsi₂néi₂ i₂cuë₅ lián'₂ dsɨ₅ në́₃, jme₁ca₂jág₃ ca₂nau₂ María ca₂o₃'ɨ́in₃ co₂chi'₅₄, ca₂i₃léin₂ chi₁co'₅₄ quió'₅, ia₁ a₂lɨ́in₂ ŋó₅ 'éi₂ tau₂ 'ŋio₅ a₂i₂'áu₂ ja₁jaun₂.
\p 
\v 32 Jaun₂ në́₃, jme₁ca₂dsióg₃ María ja₁jme₁'en₅₄ Jesús, ca₂chi₃jné₃ ne₄ 'éi₂,\f + \fr 11:32 \ft lit. “ca₂tóin₂ 'uë₃ cau₅ mɨ₂tag₄ 'éi₂.” 'Nio'₂ ja₁ton₅ Apocalipsis 4:10.\f* jaun₂ ca₂juá'₂:
\p ―Te₁gui'₅₄, jua'₅₄ mei'₂ bá₄ jme₁'eng'₅₄ ja₁lá₃, tsá₃ jme₁jón₂ dsó₂ rɨ́ng'₃.
\p 
\v 33 Jme₁ca₂jág₃ Jesús 'a₂ lia'₂ jme₁'o₅ María, 'a₂ lia'₂ jme₁tion'₅₄ guë'₂ dsa₂ judíos 'o₂₃ në́₃, i₂ja₂lén₂ quiain'₅₄, jaun₂ ca₂'ŋia₃ i₃mé'₂ dsɨ́₅, ca₂'í₃ quɨ'₂ dsɨ́₅ në́₃.
\v 34 Jaun₂ ca₂ŋag₃:
\p ―¿A₂já'₄ ca₂i₁'óin'₄ 'nia'₂?
\p Jaun₂ ca₂juá'₂ dsa₂:
\p ―Te₁gui'₅₄, ŋia₅ i₂jag₄.
\p 
\v 35 Jaun₂ ca₂'o₃ Jesús.
\p 
\v 36 Jaun₂ në́₃ ca₂juá'₂ dsa₂ judíos:
\p ―Jag₄ de'₂ 'a₂ lia'₂ jme₁'nioi₃ 'éi₂.
\p 
\v 37 La₁ ca₂juá'₂ i₂lɨn₅₄:
\p ―¿Tsa₁ cha₂ lé₂ le₃jme₁jmo₃ i₂në₅ i₂ca₂jme₃'lión₂ dsa₂ ten₄ 'éi₂, ia₁jaun₂ tsá₃ jme₁jón₂ guë'₂ dsó₂ rɨn'₅₄ 'io₅₄ në₅?
\s1 Ca₂jen'₅₄ Si₁Lia₁
\p 
\v 38 Con'₂ siá'₂ táng₃ ca₂'ŋia₃ Jesús a₂i₃mé'₂ dsɨ́₅ lia'₂ con'₂ ca₂dsióg₃ ja₁dsi₅₄ tau₂ 'ŋio₅. Caun₂ tsɨ₁të₂'lau₂ bá₄ jme₁lë́₄ a₂jaun₂, jme₁chí'₄ ca₂mɨ́g₂ nɨ₁cang₁ a₂rë₂jlë₅ o₄'né₄.
\p 
\v 39 Jaun₂ ca₂juá'₂ Jesús:
\p ―Jŋiá'₃ nɨ₁cang₁ në₅.
\p Jaun₂ ca₂juá'₂ Marta rɨn'₅₄ 'lag₄ ca₂tsɨ́'₃ Jesús:
\p ―Te₁gui'₅₄, mei'₂ tsá₃ ma₂ja₂ ma₂'lɨg'₅₄ quió'₅, ia₁ ma₂të́₂ quén₂ jmɨg₄ ca₂join₃.
\p 
\v 40 La₁ ca₂juá'₂ Jesús:
\p ―¿Tsa₁ në₂juá'₃ jniá₂, në₁jua'₂ 'éng'₂, jag'₅₄ juɨ₅bí₂ jlá'₁ quió'₅ Diú₄?
\p 
\v 41 Jaun₂ në́₃ ca₂jŋiá'₂ dsa₂ nɨ₁cang₁. Jaun₂ ca₂chóg'₃ Jesús ne₅₄, ca₂juá'₂:
\p ―Tia₅₄, cuë́₅ jniá₂ ti₁'mag'₄ 'ne₂ ia₁ ma₂nei'₂ bá₄ jág₁ quió₃.
\v 42 A₂guion₄ bá₄ jniá₂, a₂nag'₂ co₂tan₅₄. La₁ në₂juá'₃ le₂në₅ o₄quió'₄ dsa₂ i₂tion'₅₄ ja₁lá₃, ia₁jaun₂ le₃'éin₂ a₂ca₂chei'₂ jniá₂.
\p 
\v 43 Jme₁ca₂lë₃ juá'₂ le₂në₅, ca₂juá'₂ tiá₂:
\p ―¡Lázaro! ¡Jú₅ ja₁në₅!
\p 
\v 44 Jaun₂ o₂'ɨ́n₃ 'lag₄ ja₁jaun₂ qui₂rë₂quein₅ gu₂-tag₅₄ quian'₅₄ 'nau₅₄ tsɨ́n'₅ tsɨ₁'mɨ'₂ jang₄. Dsɨ₂ne₅₄ në́₃ jme₁chi₁quein₅ quian'₅₄ tsɨ₁'mɨ'₂ tióg₃. Jaun₂ ca₂juá'₂ Jesús ca₂tsɨ́'₃ dsa₂:
\p ―Chi'₅₄ quió'₅, cuë₄ jmɨg₄ juɨ₁dsiain'₅₄.
\s1 Ca₂jmo₃ dsa₂ caun₂ jág₁ a₂tsáin'₂ Jesús
\r (Mateo 26:1-5; Marcos 14:1-2; Lucas 22:1-2)
\p 
\v 45 Jaun₂ në́₃, juɨn₅ dsa₂ judíos 'éi₂, i₂ca₂i₁len₅₄ quiain'₅₄ María, i₂qui₂ca₂të́₂ ne₄ 'e₂ a₂ca₂jmo₃ Jesús jaun₂, ca₂rë₃'éin₂ të₂le₃ quió'₅ 'éi₂.
\p 
\v 46 La₁ i₂lɨn₅₄ guë'₂ në́₃ ca₂i₁lein₅₄ ja₁con₂ dsa₂ fariseos, ca₂i₁jua'₄ 'e₂ a₂ca₂jmo₃ Jesús.
\p 
\v 47 Jaun₂ në́₃, ca₂ŋɨ'₂ dsa₂ fariseos quiain'₅₄ juɨg₅₄ jme₂dsa₂, quiain'₅₄ dsɨ₂tan₅₄ quián₅ guá'₅, jaun₂ ca₂juá'₂:
\p ―¿'E₂ bá₄ jmó₁ jniog₄? Ia₁ në₅ bá₄ ŋɨ₅ dsa₂ 'éi₂ jmo₂₃ 'lióng₂ léi₄ juë'₂.
\v 48 Chi₂jua'₂ caun₂ cuë₂ jniog₄ jmɨg₄ jmo₃ lia'₂ ma₂jmo₂₃ në₅, le₃'én₂ bá₄ ca₂le₃jɨ́n₃ dsa₂ të₂le₃ quió'₅; jaun₂ qui₂ja₃lén₂ dsa₂ romanos qui₃'éin₂ ja₁jŋió₅ quián₂ jniog₄ la₂, lia'₂ jma₃quian'₅₄ juɨg₂ nación quián₂ në́₃.
\p 
\v 49 La₁ jan₂ dsa₂ 'éi₂, i₂chen₂ Caifás, i₂jme₁lɨ́n₄ jme₂dsa₂ dsen₅₄ ŋi₂ jaun₂, ca₂juá'₂:
\p ―Tsá₃ 'e₂ cuɨn'₂ 'nia'₂ 'i₁caun₂,
\v 50 on₃ guë'₂ len'₅₄ 'nia'₂, a₂jmo₅ bá₄ quián₂ jniog₄,\f + \fr 11:50 \ft A₂lɨn₅₄ chog₅₄ si₂ juá'₂: “a₂jmo₅ bá₄ quián'₂ 'nia'₂.” \f* a₂jón₂ jan₂ dsa₂ o₄quió'₄ ca₂le₃jɨ́n₃, ia₁jaun₂ tsá₃ dsɨ₃'én₂ ta₁caun₂ juɨg₂.
\p 
\v 51 La₁ on₃jua'₅₄ con'₂ tɨn₂ 'ŋiog₅ Caifás ca₂juá'₂ le₂në₅; a₂jaun₂ bá₄ ca₂juá'₂ le₂në₅ ia₁ a₂jme₁lɨ́in₄ jme₂dsa₂ dsen₅₄ ŋi₂ jaun₂: ca₂'ë́₂ jág₁ o₄quió'₄ Diú₄, a₂'i₄ 'éi'₃ jón₂ Jesús o₄quió'₄ dsa₂ juɨg₂ judíos.
\p 
\v 52 La₁ on₃jua'₅₄ rë'₂ jmá'₃ o₄quió'₄ dsa₂ juɨg₂ judíos, ján₃ bá₄ ia₁jaun₂ chi₃loin'₃ jmói'₂ ca₂ne₅₄ ca₂le₃jɨ́n₃ chi'₂-guein₂ quián₅ Diú₄ i₂qui₂i₂nio₄ tsɨ₁rë₂jan₅₄ në́₃.
\p 
\v 53 Jaun₂ në́₃, ca₂le₃ jmɨg₄ jaun₂, ca₂jmo₃ jág₁ dsɨ₂tan₅₄ quián₅ dsa₂ judíos a₂jŋɨi'₃ Jesús.
\p 
\v 54 'Uɨg₅₄ jaun₂ tsá₃ ma₃jme₁ŋɨ₅ Jesús dsi₁ne₁ jɨn₄ dsa₂ judíos, të₂le₃ ca₂o₃'ɨ́in₃ bá₄ ja₁jaun₂. Jaun₂ ŋó₃ caun₂ 'uë₃ ma₂quián₅ ja₁lë́₄ 'uë₃ quein₂ co₂'ŋiog₅, caun₂ juɨg₂ a₂chei₂ Efraín. Ja₁jaun₂ ca₂jŋia₃ quiain'₅₄ chi'₂ dsɨ₂guia₃-tɨ́n₂.
\p 
\v 55 Jme₁ma₂ja₂quián₃ Jmɨg₄ Të₂'ɨn₅₄ quió'₅ dsa₂ judíos. Jaun₂ juɨn₅ bá₄ dsa₂ ca₂'uɨin₂ juɨg₂ gu'₂, qui₂ca₂uɨ́g₂ juɨ₅ Jerusalén né'₃ a₂të₅₄ Jmɨg₄ Të₂'ɨn₅₄, ia₁jaun₂ qui₃jmo₃ le₁jɨ́in₃.
\p 
\v 56 Jaun₂ jme₁i₂nio₄ dsa₂ 'nai'₂ Jesús, jaun₂ qui₂ŋɨ́i'₂ rɨin'₅₄ tióin₂ i₁dsi₅ guá'₅ templo:
\p ―¿'A₂ lia'₂ lɨ́n'₂ 'nia'₂? ¿Jiá₃ jmɨg₄, o₃ bá₄ tsá₃ jiá₃ 'e₂?
\p 
\v 57 Jme₁ma₂ca₂cuë₃ 'éi'₃ dsa₂ fariseos quiain'₅₄ juɨg₅₄ jme₂dsa₂ në́₃, jme₁ma₂juá'₂, në₁jua'₂ 'ein₂ ca₂rë₃ŋi₅ a₂já'₄ 'en₅₄ Jesús, juɨ₁jmo₁₂ jág₁ ia₁jaun₂ cuɨn₃ jmɨg₄ tsáun'₂.
\c 12
\s1 Jan₂ 'io₅₄ ca₂tsɨ́in₂ no'₅₄ mɨ₂juɨg₂ Jesús
\r (Mateo 26:6-13; Marcos 14:3-9)
\p 
\v 1 Jŋéi₂ jmɨg₄ né'₃ a₂të₅₄ Jmɨg₄ Të₂'ɨn₅₄, ŋó₃ Jesús juɨ₅ Betania ja₁jme₁chan₂ Lázaro, dsa₂ i₂ca₂jme₃jen'₅₄ Jesús jme₁rë₂'lɨn₄ 'éi₂.
\p 
\v 2 Ja₁jaun₂ ca₂jmo₃ dsa₂ caun₂ má₃ o₄quió'₄ Jesús, a₂jme₂juag'₂. Ca₂tia'₃ Marta má₃; Si₁Lia₁ guë'₂ jme₁lɨ́n₄ jan₂ dsa₂ i₂tián'₅ ne₄ mesa guë́'₅ co₂lë₅ quiain'₅₄ Jesús.
\p 
\v 3 Jaun₂ në́₃ ca₂can₃ María con'₂ mei'₂ tsá₃ ca₂'nau₅₄ litro no'₅₄ mɨ₂juɨg₂ nardo, a₂quen₅ 'mu'₅₄ 'ŋio₅ lɨn₃, jaun₂ ca₂tsáng₂ mɨ₂tag₄ Jesús, jaun₂ ca₂chí₃ quian'₅₄ jŋi₂ dsi₅₄. Ta₁caun₂ dsi₂néi₂ qui₂ca₂can'₂ dsió'₁ mɨ₂juɨg₂.
\p 
\v 4 Jaun₂ në́₃, ca₂juá'₂ Judas Iscariote,\f + \fr 12:4 \ft A₂lɨn₅₄ chog₅₄ si₂ juá'₂ bá₄ ján₃: “ja₁ŋi'₅₄ Si₂mu₅₄.” \f* i₂jme₁lɨ́n₄ jan₂ dsa₂ guia₃-tɨ́n₂ quián₅ Jesús, i₂'éi₂ dé₄ i₂jáng'₂ quió'₅ Jesús, ca₂juá'₂:
\p 
\v 5 ―¿'E₂ 'uɨg₅₄ tsá₃ ca₂i₃'nag₄ co₂ŋei'₅₄ no'₅₄ mɨ₂juɨg₂ në₅ quian'₅₄ 'nɨ₅ 'ŋiá₂-láu₂ 'éi'₃ cu₄ denario, a₂jme₁jme₁'on₁ dsa₂ te₂ŋé₂?
\p 
\v 6 La₁ on₃jua'₅₄ jaun₂ ca₂juá'₂ Judas le₂në₅ jua'₅₄ a₂dsón'₂ dsan₂ dsɨ́₅ ja₁con₂ dsa₂ te₂ŋé₂; a₂jaun₂ bá₄ ca₂juá'₂ le₂në₅ ia₁ a₂jme₁lɨ́in₄ jan₂ dsa₂ 'ang₂ bá₄, ton'₂ jme₁niog₅ gu₂ tsɨ₁të₂lau₂ ja₁jme₁tó'₅ cu₄, jaun₂ jme₁cán₂ a₂jme₁tio'₅₄ 'ŋió'₃.
\p 
\v 7 Jaun₂ në́₃ ca₂juá'₂ Jesús ca₂tsɨ́'₃ Judas:
\p ―Tsá₃ lë₁lein'₅₄; ta₁ jaun₂ bá₄ ca₂'ma₃ a₂në₅, jaun₂ ma₂lë́₅ co₂jŋia₅₄ jmɨg₄ jë₁ma₂të́₂ rë₁'on₃ jniá₂.
\v 8 Ca₂le₃jë́₃ jmɨg₄ bá₄ i₂nio₄ dsa₂ te₂ŋé₂ jɨn'₄ 'nia'₂, la₁ jniá₂ në́₃ tsá₃ ma₃uë́₂ 'en₅₄ jniá₂ quian'₅₄ 'nia'₂.
\s1 Ca₂jmo₃ dsa₂ caun₂ jág₁ a₂jŋɨi'₃ Lázaro
\p 
\v 9 Jaun₂ në́₃, ca₂rë₃ŋi₅ juɨn₅ dsa₂ judíos a₂'en₅₄ Jesús jë₄ juɨg₂ Betania, jaun₂ i₁lein₅₄ ja₁jaun₂, on₃jua'₅₄ jmá'₃ ca₂ne₅₄ a₂i₁jɨin₁₂ Jesús, ján₃ bá₄ ca₂i₁jɨin₁₂ Si₁Lia₁ i₂ca₂jme₃jen'₅₄ Jesús jme₁rë₂'lɨin₅₄.
\p 
\v 10 Jaun₂ në́₃, ca₂jmo₃ juɨg₅₄ jme₂dsa₂ caun₂ jág₁ a₂jŋɨi'₃ Si₁Lia₁ ján₃,
\v 11 ia₁ o₄quió'₄ 'éi₂ bá₄ juɨn₅ dsa₂ ma₂i₂uɨ́in₂ ja₁con₂ dsa₂ judíos, a₂rë₂'éin₂ të₂le₃ quió'₅ Jesús.
\s1 Ca₂dsióg₃ Jesús Jerusalén
\r (Mateo 21:1-11; Marcos 11:1-11; Lucas 19:28-40)
\p 
\v 12 Jme₁jnia₃ jaun₂, ca₂dsi₃lén₂ juɨn₅ lɨn₃ dsa₂ Jerusalén, ja₁niog₃ jmɨg₄. Jaun₂ jme₁ca₂rë₃ŋi₅ a₂dsióg₄ Jesús jë₄ juɨg₄ Jerusalén,
\v 13 ca₂can₃ mog'₅₄ 'ma₂tsɨ́n₅, jaun₂ ca₂'uɨin₂ ca₂i₁jŋiai₅₄ Jesús, jaun₂ qui₂ca₂juá'₂ tiá₂:
\p ―¡Juɨ₁le₂juɨn'₂ bá₄ i₂në₅!\f + \fr 12:13 \ft lit. “Hosana”, co₂'nió'₄ le₃jua'₅₄: “¡Lio₄ jmɨg₄ në₃!” A₂jme₁juá'₂ dsa₂ le₂në₅ tsɨ́'₅ Diú₄, qui₂mɨ₂₃ a₂jiá₃ dsa₂ I₂rë₂'ɨ́n₁ quiáin₅.\f* ¡Juɨ₁le₂jŋió₃ i₂já₅ o₄quió'₄ Te₁gui'₅₄!\f + \fr 12:13 \ft Salmo 118:25-26.\f* ¡Juɨ₁le₂jŋió₃ Rag₅₄ quián₅ Israel!
\p 
\v 14 Ca₂dsán'₂ Jesús jan₂ i₂bú'₄ 'mɨ́₂, jaun₂ ca₂co₃dsɨin₅₄ já'₂, juɨ₁lia'₂ chi₁ton₅ ne₄ Si₂:
\q1 
\v 15 Tsá₃ lë₁jmo₂ gang'₃,
\q2 'nia'₂ dsa₂ chan₂ ciudad Sión:
\q1 jag₄, já₅ Rag₅₄ quiáng'₂,
\q2 co₂dsɨin₅₄ jan₂ bú'₄.\f + \fr 12:15 \ft Zacarías 9:9.\f*
\p 
\v 16 Tsá₃ a₂jaun₂ ca₂rë₃ŋɨ́'₂ dsɨ́₅ chi'₂ dsɨ₂guia₃-tɨ́n₂ le₂'uɨg₅₄; la₁ia₁ cang₂ jaun₂, jme₁ma₂ca₂lë₃ rë₂juɨn'₂ Jesús, jaun₂ bá₄ ca₂dsáu'₃ dsɨ́₅ guioin₅₄ jág₁ në₅ a₂tio'₅₄ ne₄ Si₂ a₂'ɨin₂₃ 'éi₂. Ca₂dsáu'₃ dsɨ́₅ ján₃, dsau₅ bá₄ le₂jaun₂ ca₂jmo₃ dsa₂ juɨg₂ ja₁con₂ Jesús.
\p 
\v 17 Qui₂ca₂jáng'₃ jág₁ dsau₅ dsa₂ juɨn₅ i₂jme₁quian'₅₄ Jesús lia'₂ con'₂ jme₁ca₂të́'₃ Si₁Lia₁ né'₃ tau₂ 'ŋio₅, jme₁ca₂jme₃jein'₅₄ 'éi₂ jme₁rë₂'lɨin₅₄.
\v 18 'Uɨg₅₄ jaun₂ bá₄ ca₂'uɨn₂ dsa₂ juɨn₅, a₂ca₂i₁jŋiai₁₂ Jesús, ia₁ ca₂rë₃ŋi₅ a₂ca₂jmo₃ 'éi₂ léi₄ juë'₂ jaun₂.
\p 
\v 19 Jaun₂ në́₃ ca₂juá'₂ dsa₂ fariseos qui₂ca₂tsɨ́'₃ rɨin'₅₄:
\p ―Në₅ bá₄ jág'₂ 'nia'₂, tsá₃ 'e₂ quɨ'₅₄ 'nia'₂ jmɨg₄ jmó'₂ 'i₁caun₂. Jag₄ de'₂ 'nia'₂, ma₂i₂lén₂ ta₁caun₂ mɨ₂güɨ́g₃ le₃quió'₅ i₂në₅.
\s1 I₂lɨn₅₄ dsa₂ griegos 'nai'₂ Jesús
\p 
\v 20 Jɨn₄ dsa₂ i₂i₁len₅₄ Jerusalén i₂jme₂juɨn'₂ Diú₄ ja₁niog₅ jmɨg₄, jme₁tion'₅₄ i₂lɨn₅₄ dsa₂ griegos.
\v 21 Dsa₂ 'éi₂ në́₃, ca₂jme₃quiáin₃ ja₁con₂ Felipe i₂chan₂ juɨg₂ Betsaida, ja₁niog₅ 'uë₃ Galilea, jaun₂ ca₂mɨ₃ ne₄ 'éi₂, ca₂juá'₂:
\p ―Gui'₅₄, 'niog₂ jnia'₅₄ né₄ Jesús.
\p 
\v 22 Jaun₂ ŋe₄ Fe₂li₄ ca₂i₁chi'₄ Drë́₄; jaun₂ le₂oin₃ ca₂i₁dsia₂ a₂ca₂i₁chi'₄ Jesús.
\v 23 Jaun₂ në́₃ ca₂ŋag₃ Jesús:
\p ―Ma₂ca₂të́₂ hora a₂le₃juɨn'₂ Jaun₅ dsa₂ mɨ₂güɨ́g₃.
\v 24 A₂dsɨ₂jó'₃ juɨ́g₂ jniá₂ 'nia'₂, në₁jua'₂ tsá₃ tiá'₃ né'₃ 'uë₃ juɨ₁lia'₂ ca₂mɨ́g₂ mɨ₂cuɨg₂,\f + \fr 12:24 \ft lit. “trigo.” \f* a₂dsɨ₃'én₂ në́₃, a₂lë₁të₂ron₅₄ 'ŋiog₅; la₁ia₁ në₁jua'₂ ca₂jon₃ në́₃, 'lióng₂ rau₂.
\v 25 Juɨ₁lia'₂ i₂ŋɨ́₄ lë₃ 'nio₃ jme₂dsí₂ a₂chain₂, dsɨ₂'én₂ bá₄ jme₂dsí₂ jaun₂; la₁ia₁ juɨ₁lia'₂ i₂tén'₂ dsɨ́₅ jme₂dsí₂ quió'₅ a₂chain₂ mɨ₂güɨ́g₃ la₂, a₂lé₂ quió'₅ bá₄ co₂tan₅₄.
\v 26 Juɨ₁lia'₂ i₂jme₂ti₃ ta₁ ne₃ jniá₂, 'nió'₅ jiá₃ chi₁co'₅₄ quió₃ jniá₂, jaun₂ juɨ₁lia'₂ ja₁'en₅₄ jniá₂, ján₃ bá₄ ja₁jaun₂ 'en₅₄ guë'₂ i₂jme₂ti₃ ta₁ ne₃. Jaun₂ juɨ₁lia'₂ i₂jme₂ti₃ ta₁ ne₃, guéi'₂ bá₄ Ŋe'₃ rë₂.
\s1 Ca₂'ë́₂ Jesús jág₁ a₂jóin₂
\p 
\v 27 ’'Ŋio₅ lɨn₃ quian₄ jniá₂ o₂i₁ dsɨ₅. ¿'E₂ bá₄ juá'₄ jniá₂? ¿Juá'₄ 'e₂: “Tia₅₄, lio₄ jniá₂ 'e₂ niog₅ a₂qui₂dsɨ₃ŋɨ́₂ jniá₂ hora la₂”? La₁ on₃jua'₅₄ le₂jaun₂, ia₁ ta₁ jaun₂ guio₃ guë'₂ jniá₂ hora la₂.
\v 28 Tia₅₄ jme₁jnia₅ 'a₂ lia'₂ jláng'₁.
\p Jaun₂ në́₃ ca₂né'₂ caun₂ jág₁ guei'₅₄ mɨ₂güɨ́g₃ a₂ca₂juá'₂:
\p ―Ma₂ca₂jme₁jnia₅ bá₄ jniá₂, jaun₂ con'₂ siá'₂ jme₁jnia₅ táng₃.
\p 
\v 29 Jme₁ca₂nág₂ dsa₂ juɨn₅ i₂jme₁tión₂ cau₅ jaun₂, ca₂juá'₂:
\p ―Ŋí'₃ bá₄ në₂quiá'₃.
\p La₁ i₂sián'₂ guë'₂ juá'₂:
\p ―Jan₂ ángel bá₄ në₂juá'₂ jág₁ quió'₅.
\p 
\v 30 Jaun₂ në́₃ ca₂juá'₂ Jesús ca₂tsɨ́'₃ dsa₂:
\p ―On₃jua'₅₄ o₄quió₃ jniá₂ a₂ca₂né'₂ jág₁ në₅; o₄quián'₂ 'nia'₂ bá₄ a₂ca₂né'₂.
\v 31 Në₃ guë́₄ në́₃ ca₂të́₂ jmɨg₄ a₂të₃dsɨ₅₄ 'éi'₃ mɨ₂güɨ́g₃ la₂; në₃ guë́₄ dsein₂₃ i₂gon₂ mɨ₂güɨ́g₃ la₂.
\v 32 Jaun₂ jniá₂ në́₃, jë₁ma₂ca₂chó'₂ dsa₂ guei'₅₄ gua'₅₄ 'uë₃, jme₁quián₄ jniá₂ ca₂le₃jɨ́n₃ ja₁cong₂.
\p 
\v 33 Ca₂juá'₂ le₂në₅ a₂'ë₂₃ 'e₂ ne₅₄ 'mú₃ dsɨ₃ŋɨ́i₂.
\p 
\v 34 Jaun₂ ca₂ŋag₃ dsa₂:
\p ―Ma₂néi₂ jnia'₅₄ a₂'ɨ₅ dsa₂ ne₄ Si₂ 'Éi'₃ a₂juá'₂ a₂le₃chan₂ I₂rë₂'ɨ́n₁ quián₅ Diú₄ co₂tan₅₄. ¿'A₂ guë'₂ lia'₂ juá'₂ 'ne₂ tion₅₄ chón'₂ dsa₂ Jaun₅ dsa₂ mɨ₂güɨ́g₃? ¿'Ein₂ 'éi₂ i₂lɨ́n₅ Jaun₅ dsa₂ mɨ₂güɨ́g₃?
\p 
\v 35 Jaun₂ në́₃ ca₂juá'₂ Jesús:
\p ―Jŋia'₅₄ lia'₂ co₂'na₂ bá₄ tág₅ guë́₄ si₂ jɨn'₄ 'nia'₂. La₁ i₂nio'₄ 'nia'₂ të₁lia'₂ tág₅ si₂, con'₂ tsá₃ ŋó₅ në₁jua'₂ ca₂tó'₂ nei₂. Ia₁ juɨ₁lia'₂ dsa₂ i₂ŋɨ₅ jë₄ qui₁né'₃, tsá₃ ŋi₅ 'a₂ juɨ₅ dsó₃.
\v 36 Juɨ₁le₂'én'₂ 'nia'₂ le₃quió'₅ si₂, të₁lia'₂ cha₂ si₂ jɨn'₄ 'nia'₂, ia₁jaun₂ lén'₂ 'nia'₂ dsa₂ quián₅ si₂.
\p Jme₁ca₂dsan₃ juá'₂ Jesús le₂në₅, ŋái'₃, jaun₂ ca₂'mai₃ ja₁con₂ dsa₂ 'éi₂.
\s1 'E₂ lë₃ tsá₃ jme₁'én₂ dsa₂ judíos le₃quió'₅ Jesús
\p 
\v 37 La₁ juɨ₁'a₂ guë́₃ la₂ ca₂jmo₃ Jesús 'lióng₂ léi₄ ne₄ dsa₂ 'éi₂, tsá₃ ca₂rë₃'én₂ bá₄ guë́₄ dsa₂ 'éi₂ le₃quió'₅.
\v 38 Le₂në₅ ca₂rë₃ti₃ jág₁ a₂ca₂'ë́₂ Isaías o₄quió'₄ Diú₄, jme₁ca₂juá'₂:
\q1 Te₁gui'₅₄, ¿'ein₂ ma₂ca₂rë₃'én₂ jág₁ a₂'ë́₅ jniog₄?
\q2 ¿Ja₁con₂ 'ein₂ ma₂ca₂jme₃jnia₅ Te₁gui'₅₄
\q2 juɨ₅bí₂ quió'₅?\f + \fr 12:38 \ft Isaías 53:1.\f*
\p 
\v 39 'Uɨg₅₄ jaun₂ tsá₃ lé₂ le₃'én₂ dsa₂ 'éi₂, ia₁ con'₂ siá'₂ ca₂juá'₂ táng₃ Isaías:
\q1 
\v 40 “Ma₂ca₂jmo₃ Diú₄ a₂tén₂ dsa₂ 'éi₂,
\q2 a₂ca₂lë₃ cang₄ dsi₅₄ në́₃,
\q1 ia₁jaun₂ tsá₃ jág₃ quian'₅₄ mɨ₂ne₅₄,
\q2 on₃ guë'₂ le₂ŋɨ́i'₂ të₂le₃ të₂dsɨ́₅,
\q1 on₃ guë'₂ qui₃jéin'₃ dsɨ́₅,
\q2 ia₁jaun₂ jme₁'lioin₁₂ jniá₂.”\f + \fr 12:40 \ft Isaías 6:10.\f*
\p 
\v 41 Ca₂juá'₂ Isaías le₂në₅ ia₁ ca₂jág₃ le₂jŋiá₅ juɨ₅bí₂ jlá'₁ quió'₅ Jesús, jaun₂ ca₂dsia₃ 'ɨin₂₃ 'éi₂.
\p 
\v 42 La₁ia₁ tion₅₄ bá₄ ca₂rë₃'én₂ dsa₂, le₂jiog₅ bá₄ i₂lɨn₅₄ dsa₂ can'₅₄. La₁ tsá₃ ca₂jmo₃ jág₁, ia₁ a₂gó'₅ gain₃ dsa₂ fariseos, con'₂ tsá₃ ŋó₅ në₁jua'₂ ca₂'uág'₂ dsa₂ quió'₅, ja₁le₁toin₂₃ ne₄ si₂ guá'₅ sinagoga.
\p 
\v 43 Ia₁ a₂'nio₃ guë́₄ të₃tsɨin'₅₄ dse₃ quian'₅₄ dsa₂ mɨ₂güɨ́g₃, lia'₂ con'₂ guë́₄ a₂jme₁të₃tsɨin'₅₄ dse₃ quian'₅₄ Diú₄.
\s1 Jág₁ quió'₅ Jesús bá₄ a₂qui₃dsɨ₅ 'éi'₃ ja₁con₂ dsa₂ mɨ₂güɨ́g₃
\p 
\v 44 Ca₂juá'₂ Jesús jág₁ tiá₂:
\p ―Juɨ₁lia'₂ i₂'én₂ të₂le₃ quió₃ jniá₂, on₃jua'₅₄ jmá'₃ le₃quió₃ jniá₂ 'éin₂; ján₃ bá₄ 'éin₂ le₃quió'₅ Ŋe'₃ i₂ca₂chei₃ jniá₂.
\v 45 Juɨ₁lia'₂ i₂jág₂ jniá₂, jɨ́in₂ i₂ca₂chei₃ jniá₂.
\v 46 Ma₂guan₅ jniá₂ mɨ₂güɨ́g₃ la₂, a₂lɨ́ng₅ si₂, ia₁jaun₂ i₂'én₂ të₂le₃ quió₃ jniá₂, tsá₃ të₃'ŋiái₄ jë₄ qui₁né'₃.
\v 47 Jaun₂ chi₂jua'₂ 'ein₂ i₂nag₅ jág₁ quió₃, la₁ tsá₃ guë'₂ tón'₂ juɨ₅, on₃jua'₅₄ jniá₂ qui₁dsɨ₅ 'éi'₃ quió'₅ 'éi₂; ia₁ on₃jua'₅₄ ta₁ jaun₂ guio₃ jniá₂ a₂qui₁dsɨ₅ 'éi'₃ ja₁con₂ dsa₂ mɨ₂güɨ́g₃; të₂le₃ a₂loin₅₄ bá₄ jniá₂.
\v 48 Juɨ₁lia'₂ i₂tsá₃ jei₅₄ jniá₂, on₃ guë'₂ tón'₂ juɨ₅ jág₁ quió₃, cha₂ bá₄ caun₂ a₂qui₃dsɨ₅ 'éi'₃ quió'₅. Jág₁ a₂ma₂qui₂ma₂juá'₃ bá₄ jniá₂, a₂jaun₂ bá₄ qui₃dsɨ₅ 'éi'₃ quió'₅, jmɨg₄ jë₁ca₂tó'₂.
\v 49 Ia₁ on₃jua'₅₄ o₄quió₃ 'ŋió₃ ma₂qui₂ma₂juá'₃; Ŋe'₃ jniá₂ i₂ca₂chei₃ bá₄ ma₂ca₂cuë₃ 'éi'₃ juɨ₁'e₂ a₂juá'₅ jniá₂ quian'₅₄ 'e₂ a₂jme₂tɨ́ng₂ dsa₂.
\v 50 Jaun₂ guion₄ jniá₂, a₂jiog₅ 'éi'₃ quió'₅ Ŋe'₃ juɨ₅ ja₁le₃chan₂ dsa₂ co₂tan₅₄; jaun₂ lë₃, jág₁ a₂juá'₅ jniá₂, juá'₅ lia'₂ con'₂ lë́₅ 'éi'₃ ca₂cuë₃ Ŋe'₃.
\c 13
\s1 Ca₂rɨ́n'₃ Jesús mɨ₂tag₄ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅
\p 
\v 1 Ca₂juɨg₄ jme₁'nió'₅ guë́₄ a₂të₅₄ Jmɨg₄ Të₂'ɨn₅₄. Jme₁ma₂ŋi₅ bá₄ Jesús a₂ma₂ca₂të́₂ hora a₂o₃'ɨin₅ mɨ₂güɨ́g₃ la₂ a₂dsáin'₃ táng₃ ja₁con₂ Jmei₂. Lia'₂ co₂tan₅₄ bá₄ ca₂jme₃'nio₃ 'éi₂ dsa₂ quiáin₅ i₂jme₁tion'₅₄ mɨ₂güɨ́g₃; la₁ në₃ në́₃, ca₂jme₃jniai₂₃ 'a₂ con'₂ ca₂dsióg₃ ca₂rë₃'nioi₃ 'éi₂.\f + \fr 13:1 \ft o₃, “në₃ në́₃, ca₂rë₃'nioi₃ ca₂të₂ jë₁ca₂tó'₂.” \f*
\p 
\v 2 Jme₁ma₂lë₅ má₃ të₂le₃ ca₂nei₂, jaun₂ jme₁ma₂jmo₃ i₂së₃dsen₃ a₂i₂jiog₅ dsɨ́₅ Judas Iscariote, ja₁ŋi'₅₄ Si₂mu₅₄, a₂jɨ́in'₂ Jesús.
\v 3 Jme₁ma₂ŋi₅ bá₄ Jesús a₂ma₂ca₂dsia₃ Jmei₂ ca₂le₃jë́₃ o₄gú₃; jme₁ma₂ŋi₅ bá₄ ján₃ a₂já₅ ja₁con₂ Diú₄, jaun₂ ja₁con₂ Diú₄ bá₄ dsáin'₃ táng₃.
\v 4 Jaun₂ lë₃, lia'₂ con'₂ jme₁tiáin'₄ guë́'₅, ca₂nau₂ ja₁jme₁guá₄, jaun₂ ca₂dsia₃ cau₅ tsɨn'₅₄ a₂jme₁qui'₂ të₂le₃ co'₅₄, jaun₂ ca₂jén'₃ caun₂ 'mɨ'₂ toalla o₄'ŋei'₂.
\p 
\v 5 Jaun₂ në́₃ ca₂tia'₃ jmɨg₂ 'ŋió'₃ caun₂ nɨ₁'ɨ́₅, jaun₂ ca₂jme₃lióg₃ ca₂rang₃ mɨ₂tag₄ chi'₂ dsɨ₂guia₃-tɨ́n₂. Jaun₂ ca₂jme₃quéin'₂ quian'₅₄ tsɨ₁'mɨ'₂ toalla a₂jme₁chi₁jén'₅ o₄'ŋei'₂.
\p 
\v 6 Jaun₂ jme₁ca₂dsióg₃ ja₁con₂ Si₂mu₅₄ Pe₄, ca₂juá'₂ 'éi₂ ca₂tsɨ́'₃ Jesús:
\p ―Te₁gui'₅₄, ¿'ne₂ ráng'₂ tag₃ jniá₂?
\p 
\v 7 Jaun₂ ca₂ŋag₃ Jesús:
\p ―Tsá₃ ŋɨ́'₂ guë́₄ 'au'₂ 'ne₂ 'e₂ a₂jmo₅ jniá₂ në₃, la₁ cang₂ guë́₄ le₃ŋɨ́g'₂.
\p 
\v 8 La₁ ca₂juá'₂ Pe₄:
\p ―Lia'₂ o₁lɨ́g'₂ co₂ŋɨ́₂ tsá₃ ráng'₂ 'ne₂ tag₃ jniá₂.
\p Jaun₂ ca₂juá'₂ Jesús:
\p ―Në₁jua'₂ tsá₃ ca₂rang₃ jniá₂ quiáng'₂, tsá₃ quen'₅₄ 'ne₂ ja₁con₂ jniá₂.
\p 
\v 9 Jaun₂ në́₃ ca₂juá'₂ Si₂mu₅₄ Pe₄:
\p ―Chi₂jua'₂ le₂jaun₂, Te₁gui'₅₄, on₃jua'₅₄ jmá'₃ mɨ₂tag₃ ráng'₂; ján₃ bá₄ rang₄ mɨ₂gu₃ quian'₅₄ mɨ₂dsi₃.
\p 
\v 10 La₁ ca₂juá'₂ Jesús:
\p ―Juɨ₁lia'₂ i₂lia'₂ ca₂lë₃ ló'₅, jmá'₃ mɨ₂tag₅₄ bá₄ 'nió'₅ rɨn'₂, ia₁ ma₂le₁jɨ́in₃ bá₄ ta₁jain₂. Ma₂le₁jɨ́n'₃ bá₄ 'nia'₂, la₁ia₁ on₃jua'₅₄ ca₂le₃jɨ́ng'₃.
\p 
\v 11 Ca₂juá'₂: “Tsá₃ le₁jɨ́n'₃ 'nia'₂ le₃jɨ́ng'₃”, ia₁ ma₂ŋi₅ bá₄ i₂'ein₂ i₂jáng'₂ quió'₅.
\p 
\v 12 Jme₁ca₂lë₃ rang₅ Jesús mɨ₂tag₄ chi'₂ dsɨ₂guia₃-tɨ́n₂, jaun₂ ca₂quɨ́'₂ táng₃ nɨ₁tsɨn'₅₄ le₃co'₅₄, jaun₂ ca₂guá₂ táng₃ ne₄ mesa. Jaun₂ ca₂juá'₂ ca₂tsɨ́'₃ chi'₂ dsɨ₂guia₃-tɨ́n₂:
\p ―¿Ŋɨ́'₂ 'nia'₂ 'e₂ a₂në₂jmo₃ jniá₂ quián'₂ 'nia'₂?
\v 13 'Ág'₅ 'nia'₂ jniá₂ Të₅, quian'₅₄ Te₁gui'₅₄. Tí₅ bá₄ jág₁ quián'₂ 'nia'₂, ia₁ dsón'₂ bá₄ le₂jaun₂ lɨ́ng₅.
\v 14 Jaun₂ në́₃, chi₂jua'₂ le₂në₅ jniá₂ i₂lɨ́ng₅ Të₅ quian'₅₄ Juɨg'₂ 'nia'₂, në₂rang₃ mɨ₂tag'₅₄ 'nia'₂, ján₃ bá₄ le₂jaun₂ 'nió'₅ jmó'₂ 'nia'₂: a₂qui₁ráng'₂ mɨ₂tag₄ rɨ́ng'₂ le₂jang'₂ le₂jang'₂.
\v 15 Ia₁ ma₂në₂can₃ jniá₂ caun₂ juɨ₅, ia₁jaun₂ jmó'₂ 'nia'₂ le₂jaun₂, juɨ₁lia'₂ ma₂në₂jmo₃ jniá₂ ja₁con'₂ 'nia'₂.
\v 16 A₂dsɨ₂jó'₃ juɨ́g₂ jniá₂ 'nia'₂, lia'₂ 'i₁jan₂ dsa₂ i₂jme₂ti₃ ta₁, tsá₃ juɨin'₂ guë́₄ con'₂ guë́₄ juɨg₅₄; ján₃ bá₄ lia'₂ 'i₁jan₂ dsa₂ i₂chen₄, tsá₃ juɨin'₅₄ guë́₄ lia'₂ con'₂ guë́₄ dsa₂ i₂chei₅.
\v 17 Chi₂jua'₂ ŋɨ́'₂ 'au'₂ 'nia'₂ a₂në₅, 'e₂ bá₄ dsen'₃ 'nia'₂ chi₂jua'₂ le₂jaun₂ qui₂jmo'₂.
\p 
\v 18 ’On₃jua'₅₄ ca₂le₃jɨ́n'₃ 'nia'₂ 'ɨ́n₅ jniá₂; guion₄ bá₄ jniá₂ i₂'ein₂ 'éi₂ i₂ma₂ca₂quiong'₅₄. La₁ia₁, 'nió'₅ le₃ti₃ lia'₂ con'₂ juá'₂ ne₄ Si₂: “Juɨ₁lia'₂ i₂guë́'₅ co₂lë₅ quian'₅₄ jniá₂, ca₂nau₂ quen₅ të₂le₃ ja₁con₂ jniá₂.”\f + \fr 13:18 \ft Salmo 41:9.\f*
\v 19 Jaun₂ juɨ́g₂ jniá₂ 'nia'₂ në₃, të₃jŋiá₅, ia₁jaun₂ jë₁ma₂të́₂ rë₁lé₂, le₃'én'₂ 'nia'₂, jniá₂ bá₄ lɨ́ng₅ 'éi₂.\f + \fr 13:19 \ft o₃, “jniá₂ lɨ́ng₅” co₂'nió'₄ jein₅ jág₁ lia'₂ chen₂ Jehová. 'Nio'₂ ja₁ton₅ Éxodo 3:14, Isaías 43:10, Juan 8:58.\f*
\v 20 A₂dsɨ₂jó'₃ juɨ́g₂ jniá₂ 'nia'₂, juɨ₁lia'₂ i₂guen₅ dsa₂ i₂chen₄ quián₃ jniá₂, guei₂₃ jniá₂; jaun₂ juɨ₁lia'₂ i₂guei₅ jniá₂ guein₂₃ i₂ca₂chei₃ jniá₂.
\s1 Ca₂juá'₂ Jesús a₂jáng'₂ Judas quió'₅
\r (Mateo 26:20-25; Marcos 14:17-21; Lucas 22:21-23)
\p 
\v 21 Jme₁ca₂lë₃ juá'₂ jág₁ në₅, ca₂can₃ o₂i₁ dsɨ₅ ca₂të₂ jme₂dsí₂, jaun₂ ca₂jáng'₃ jág₁ dsau₅ lia'₂ rë₂jiá₃ jág₁, ca₂juá'₂:
\p ―A₂dsɨ₂jó'₃ juɨ́g₂ jniá₂ 'nia'₂, jan₂ 'nia'₂ jáng'₂ jniá₂.
\p 
\v 22 Jaun₂ në́₃ qui₂ca₂jɨ́n₂ chi'₂ dsɨ₂guia₃-tɨ́n₂ rɨin'₅₄ le₂jain₂ le₂jain₂, i₂gó'₃ dsɨ́₅ 'nio₃ le₃ŋi₅ 'ein₂ bá₄ 'ɨn₅ Jesús.
\p 
\v 23 Jan₂ chi'₂ dsɨ₂guia₃-tɨ́n₂ i₂ŋɨ́₄ lë₃ jme₁'nio₃ Jesús, jme₁guá₄ le₃jén'₃ quió'₅.
\v 24 Jaun₂ ca₂jmo₃ Si₂mu₅₄ Pe₄ caun₂ léi₄ ne₄ 'éi₂, ca₂juá'₂:
\p ―Chei'₅₄ 'ein₂ bá₄ 'ɨin₂₃.
\p 
\v 25 Jaun₂ në́₃ ca₂jme₃quián₃ 'éi₂ të₂cau₅ guë́₄ quió'₅ Jesús, jaun₂ ca₂ŋag₃:
\p ―Te₁gui'₅₄, ¿'ein₂ 'éi₂?
\p 
\v 26 Jaun₂ ca₂ŋag₃ Jesús:
\p ―I₂'éi₂ bá₄ i₂cuë́₄ jniá₂ ca₂jne₄ i₁ŋí'₄ la₂, jë₁ma₂ca₂tiá₃ nɨ₁uɨng₅.
\p Jaun₂ në́₃, jme₁ma₂në₂tiá₂ i₁ŋí'₄, jaun₂ ca₂cuë́'₃ Judas Iscariote, ja₁ŋi'₅₄ Si₂mu₅₄.
\p 
\v 27 Jaun₂ dsɨ₂juɨ₅ le₂jaun₂ jme₁ca₂gue₃ Judas i₁ŋí'₄ jaun₂, ca₂'í₃ i₂së₃dsen₃ të₂dsɨ́₅. Jaun₂ në́₃ ca₂juá'₂ Jesús:
\p ―A₂jaun₂ a₂niog₅ 'au'₂ jmó'₂, jmo₄ në₃ cón'₅.
\p 
\v 28 La₁ lia'₂ 'i₁jan₂ i₂tián'₅ guë́'₅ ne₄ mesa tsá₃ ca₂rë₃ŋɨ́'₂ 'e₂ 'uɨg₅₄ ca₂juá'₂ Jesús ca₂tsɨ́'₃ Judas le₂jaun₂.
\p 
\v 29 Ia₁ jme₁niog₅ gu₂ Judas 'éi₂ nɨ₁lau₂ tio'₅₄ cu₄; jaun₂ ca₂lɨn₃ i₂lɨn₅₄, a₂ca₂juá'₂ Jesús tsɨ́'₅ 'éi₂ a₂cha₂ jme₁lá₃ quió'₅ jmɨg₄, o₃ jme₃'oin₅₄ ca₂la₂ cu₄ dsa₂ te₂ŋé₂ 'e₂.
\p 
\v 30 Jaun₂ dsɨ₂juɨ₅ jme₁ma₂në₂gue₃ 'éi₂ i₁ŋí'₄, o₂'ɨ́in₃. Jme₁ma₂ca₂nei₂ bá₄ le₂jaun₂.
\s1 Caun₂ 'éi'₃ 'mɨ́₂
\p 
\v 31 Jme₁ma₂o₂'ɨ́n₃ Judas jaun₂, ca₂juá'₂ Jesús:
\p ―Në₃ në́₃, jë₁ma₂le₃jniá₂ juɨ₅bí₂ jlá'₁ quió'₅ Jaun₅ dsa₂ mɨ₂güɨ́g₃; ján₃ bá₄ le₃jniá₂ juɨ₅bí₂ quió'₅ Diú₄, ja₁con₂ 'éi₂.
\v 32 Chi₂jua'₂ le₃jnia₅ juɨ₅bí₂ quió'₅ Diú₄ ja₁con₂ 'éi₂,\f + \fr 13:32 \ft A₂lɨn₅₄ chog₅₄ si₂, tsá₃ juá'₂ con'₂ táng₃: “chi₂jua'₂ le₃jnia₅ juɨ₅bí₂ quió'₅ Diú₄ ja₁con₂ 'éi₂.” \f* Diú₄ në́₃, jme₃jnia₅ juɨ₅bí₂ jlá'₁ quió'₅ Ja₁ŋi'₅₄ ja₁con₂ 'ŋiog₅, ton'₂ jme₃jniai₂₃ ŋi'₅₄ ta₁.
\v 33 'Nia'₂ chi'₂-guein₂ quiáng₃, tsá₃ ma₂uë́₂ 'en₅₄ jniá₂ jɨn'₄ 'nia'₂. Qui₁'nau'₅₄ 'nia'₂ jniá₂; la₁ juɨ₁lia'₂ ma₂ca₂juɨ́g₂ jniá₂ dsa₂ judíos, ján₃ bá₄ le₂jaun₂ juɨ́g₂ jniá₂ 'nia'₂ në́₃: tsá₃ lé₂ o₁nó'₅ 'nia'₂ ja₁né'₄ jniá₂.
\v 34 Caun₂ 'éi'₃ 'mɨ́₂ la₂ cuë́₄ jniá₂ 'nia'₂: a₂jme₁'nió'₄ 'nia'₂ rɨ́ng'₂ le₂jang'₂ le₂jang'₂. Juɨ₁lia'₂ ca₂jme₁'nió₄ jniá₂ 'nia'₂, 'nia'₂ në́₃ 'nió'₅ jme₁'nió'₄ 'nia'₂ rɨ́ng'₂.
\v 35 Le₂në₅ bá₄ le₃ŋi₅ ca₂le₃jɨ́n₃ dsa₂ a₂lɨ́n'₅ 'nia'₂ dsa₂ i₂ma₂ca₂rë₃tɨ́n₃ quiáng₃: në₁jua'₂ caun₂ qui₂ca₂jme₁'nió'₄ 'nia'₂ rɨ́ng'₂ le₂jang'₂ le₂jang'₂.
\s1 Ca₂juá'₂ Jesús a₂tsá₃ tion₃ Pe₄ a₂cuɨg₂₃
\r (Mateo 26:31-35; Marcos 14:27-31; Lucas 22:31-34)
\p 
\v 36 Jaun₂ ca₂ŋag₃ Si₂mu₅₄ Pe₄ ca₂ŋɨ́i'₃ Jesús:
\p ―Te₁gui'₅₄, ¿a₂já'₄ guang'₅₄?
\p Jaun₂ ca₂ŋag₃ Jesús:
\p ―Ja₁né'₄ jniá₂, tsá₃ lé₂ le₃'éin'₄. La₁ 'éin'₄ bá₄ 'nia'₂ cang₂.
\p 
\v 37 Jaun₂ në́₃ ca₂juá'₂ Pe₄ ca₂tsɨ́'₃ Jesús:
\p ―Te₁gui'₅₄, ¿'e₂ lë₃ tsá₃ lé₂ le₃'éin₄ jniá₂ të₂në₃? Ma₂chan₂ co₂jŋia₅₄ bá₄ jniá₂ a₂gue₅₄ 'mú₃ o₄quián'₂ 'ne₂.
\p 
\v 38 Jaun₂ ca₂ŋag₃ Jesús:
\p ―¿Dsón'₂ ma₂'ei₅ caun₂ 'au'₂ a₂gue'₂ 'mú₃ o₄quió₃ jniá₂? A₂dsɨ₂jó'₃ juɨ́g₂ jniá₂ 'ne₂, né'₃ guë́₄ a₂'o₃ të₁guí₄ dsó₂, hora jaun₂ dé₄ tsá₃ tón'₄ 'ne₂ a₂cuɨg'₂ jniá₂, ta₁'nɨ₅ ráun₂.
\c 14
\s1 Jesús bá₄ lɨ́n₅ juɨ₅ a₂dsi₁len₃ dsa₂ ja₁con₂ Jmei₂
\p 
\v 1 ’Tsá₃ lë₁can₂ 'nia'₂ o₂i₁ 'au'₂. Juɨ₁lia'₂ 'én'₂ 'nia'₂ të₂le₃ quió'₅ Diú₄, ján₃ bá₄ le₂jaun₂ juɨ₁le₂'én'₂ 'nia'₂ të₂le₃ quió₃ jniá₂.
\v 2 Ja₁quió'₄ Ŋe'₃, 'lióng₂ dsi₂néi₂ cha₂ a₂jo₂; jua'₅₄ mei'₂ guë́₃ tsá₃ le₂jaun₂ në́₃, ¿lɨ́n'₂ 'nia'₂ a₂jme₁juɨg₅₄ jniá₂ 'nia'₂ a₂nég'₄ i₁jmo₃ co₂jŋia₅₄ dsi₂néi₂ quián'₂ 'nia'₂?\f + \fr 14:2 \ft o₃, “jua'₅₄ mei'₂ guë́₃ tsá₃ le₂jaun₂ në́₃, jme₁juɨg₅₄ guë'₂ jniá₂ 'nia'₂. Nég'₄ i₁jmo₃ co₂jŋia₅₄ dsi₂néi₂ quián'₂ 'nia'₂.” \f*
\v 3 Cang₂ jë₁ma₂dsián'₃ jniá₂, jë₁ma₂ca₂lë₃ jmo₂₃ co₂jŋia₅₄ ja₁o₁tión'₂ 'nia'₂, jaun₂ bá₄ guio₅₄ táng₃ a₂i₁te₁₂ 'nia'₂ ja₁cong₂, ia₁jaun₂ ja₁i₁'ú₃ jniá₂, ján₃ bá₄ lé₂ o₁tión'₂ 'nia'₂.
\v 4 Ŋi'₅₄ bá₄ 'nia'₂ a₂já'₄ né'₄ jniá₂; cuɨn'₂ bá₄ 'nia'₂ juɨ₅ në́₃.
\p 
\v 5 Jaun₂ ca₂juá'₂ To₁má₄:
\p ―Te₁gui'₅₄, tsá₃ ne₄ jnia'₅₄ a₂já'₄ guang'₅₄; ¿'a₂ guë'₂ lia'₂ le₃cuag₅ jnia'₅₄ juɨ₅?
\p 
\v 6 Jaun₂ ca₂ŋag₃ Jesús:
\p ―Jniá₂ bá₄ lɨ́ng₅ juɨ₅, ján₃ bá₄ lɨ́ng₅ jág₁ dsau₅, ján₃ bá₄ lɨ́ng₅ i₂jmo₅ a₂le₃chan₂ dsa₂. 'I₁jan₂ tsá₃ dsióg₄ ja₁con₂ Ŋe'₃ jua'₅₄ tsá₃ të₂le₃ quian'₅₄ jniá₂.
\v 7 Jua'₅₄ mei'₂ guë́₃ dsón'₂ ŋi'₅₄ 'nia'₂ 'ein₂ lɨ́n₅ jniá₂, ján₃ bá₄ jme₁le₃cuɨn'₂ 'nia'₂ Ŋe'₃ ján₃;\f + \fr 14:7 \ft A₂lɨn₅₄ chog₅₄ si₂ juá'₂: “chi₂jua'₂ dsón'₂ ma₂cuɨg'₂ 'nia'₂ jniá₂, le₃cuɨn'₂ 'nia'₂ Ŋe'₃ ján₃.” \f* jaun₂ në₃ në́₃, të₂le₃ ne₄ juɨ₅, le₃cuɨin'₂ 'nia'₂, ton'₂ ma₂jɨin'₅₄ 'nia'₂.
\p 
\v 8 Jaun₂ në́₃ ca₂juá'₂ Fe₂li₄ ca₂tsɨ́'₃ Jesús:
\p ―Te₁gui'₅₄, cuë₄ jmɨg₄ a₂jɨn₄ jnia'₅₄ Ŋéi'₅, jaun₂ co₂jaun₂ guë́₄ dsáu₅ dsɨ₅ jnia'₅₄.
\p 
\v 9 Jaun₂ ca₂ŋag₃ Jesús:
\p ―¿Tsa₁ cuɨg'₂ 'ne₂ jniá₂ Fe₂li₄, o₁jŋia'₅₄ ma₂ŋó₅ jmɨg₄ 'en₅₄ jniá₂ quian'₅₄ 'nia'₂? Chi₂jua'₂ 'ein₂ dsa₂ ma₂jág₂ jniá₂, ján₃ bá₄ ma₂jɨ́in₂ Ŋe'₃. ¿'A₂ bá₄ lia'₂ juá'₂ 'ne₂: “Cuë₄ jmɨg₄ a₂jɨn₄ jnia'₅₄ Ŋéi'₅”?
\v 10 ¿Tsa₁ 'én'₂ 'ne₂ a₂'en₅₄ jniá₂ ja₁con₂ Ŋe'₃, ton'₂ 'en₅₄ guë'₂ Ŋe'₃ táng₃ ja₁con₂ jniá₂? Juɨ₁lia'₂ jág₁ a₂juɨ́g₂ jniá₂ 'nia'₂, tsá₃ juá'₅ jniá₂ o₄quió₃ 'ŋió₃. Të₂le₃, Ŋe'₃ jniá₂ i₂të₁'ŋiá₄ ja₁con₂ jniá₂, i₂'éi₂ bá₄ jmo₅ ta₁ quió'₅.
\v 11 Juɨ₁le₂'én'₂ bá₄ 'nia'₂ a₂juá'₅ jniá₂, a₂'eng₅₄ ja₁con₂ Ŋe'₃, a₂'en₅₄ guë'₂ Ŋe'₃ ja₁con₂ jniá₂; o₃ në₁jua'₂ tsá₃ le₂jaun₂, jmá'₃ lia'₂ të₂le₃ quian'₅₄ léi₄ a₂jmo₂₃, juɨ₁le₂'én'₂ 'nia'₂.
\v 12 A₂dsɨ₂jó'₃ juɨ́g₂ jniá₂ 'nia'₂, juɨ₁lia'₂ i₂'én₂ le₃quió₃ jniá₂, ján₃ bá₄ jmo₃ juɨ₁lia'₂ a₂jmo₅ jniá₂; jaun₂ të₂le₃ 'ŋio₅ guë́₄ juë'₂ a₂jmo₃, ia₁ nég'₄ ja₁con₂ Ŋe'₃.
\v 13 Jaun₂ chi₂jua'₂ 'e₂ a₂mɨ'₂ 'nia'₂ lia'₂ con'₂ lë́₅ 'éi'₃ quió₃ jniá₂, jmo₅₄ bá₄ jniá₂, ia₁jaun₂ le₃juɨn'₂ Jmei₂ o₄quió'₄ Ja₁ŋi'₅₄.
\v 14 Lé₂ bá₄ mɨ́'₁ 'nia'₂ lia'₂ con'₂ lë́₅ 'éi'₃ quió₃ jniá₂, chi₂jua'₂ 'e₂ caun₂ a₂'niog'₂ 'nia'₂, jaun₂ jmo₅₄ bá₄ jniá₂.
\s1 Ca₂cuë₃ Jesús jág₁ quió'₅ a₂chein₃ Jme₂dsí₂ Jŋió₅
\p 
\v 15 ’Chi₂jua'₂ 'nióg'₃ 'nia'₂ jniá₂, nei₂ gau₂ 'éi'₃ quió₃.
\v 16 Jaun₂ mɨ₅₄ jniá₂ ne₄ Ŋe'₃ a₂cuiɨn₃ jan₂ i₂sián'₂ i₂cuë́'₃ bí₂ 'au'₂ 'nia'₂, ia₁jaun₂ 'í₂ 'éi₂ co₂tan₅₄ quian'₅₄ 'nia'₂.
\v 17 Jme₂dsí₂ quió'₅ jág₁ tí₅ bá₄ 'éi₂. Tsá₃ lé₂ le₃guei₃ dsa₂ mɨ₂güɨ́g₃, ia₁ tsá₃ jág₂, on₃ guë'₂ cuɨg₂₃ cuɨin₂₃ 'éi₂. La₁ 'nia'₂ në́₃, ma₂cuɨin'₂ bá₄ 'nia'₂, ia₁ guá₅ ja₁con'₂ 'nia'₂, ton'₂ të₃'ŋiái₄ le₃quián'₂ 'nia'₂.
\v 18 On₃jua'₅₄ a₂tén₄ jniá₂ 'nia'₂ co₂ŋei'₅₄ në₂jag₄ bá₄ chi'₂ 'nág₂. Guio₅₄ bá₄ táng₃ ja₁con'₂ 'nia'₂.
\v 19 Tsá₃ ma₃uë́₂ jág₂ dsa₂ mɨ₂güɨ́g₃ jniá₂, la₁ia₁ jag'₅₄ bá₄ 'nia'₂. 'Uɨg₅₄ ia₁ a₂chan₂ jniá₂, le₃chang'₂ bá₄ 'nia'₂.
\v 20 Jmɨg₄ jaun₂ le₃len'₅₄ 'nia'₂ a₂'en₅₄ jniá₂ ja₁con₂ Ŋe'₃, 'nia'₂ guë'₂ tiong'₅₄ ja₁con₂ jniá₂, jaun₂ jniá₂ guë'₂ në́₃ 'eng₅₄ ja₁con'₂ 'nia'₂.
\v 21 Juɨ₁lia'₂ i₂gue₅, i₂né'₂ 'éi'₃ quió₃, 'éi₂ bá₄ i₂të₃dsón'₂ 'nio₃ jniá₂. Juɨ₁lia'₂ i₂'nio₃ jniá₂ në́₃, jme₃'nio₃ Ŋe'₃. Ján₃ bá₄ le₂jaun₂ jniá₂ jme₁'niói₄, jaun₂ jme₁jnia₅ jniá₂ ja₁coin₂.
\p 
\v 22 Jaun₂ ca₂juá'₂ Judas, (on₃jua'₅₄ Iscariote):
\p ―Te₁gui'₅₄, ¿'e₂ lë₃ ja₁con₂ jnia'₅₄ jme₁jnag'₅, on₃jua'₅₄ rë'₂ ja₁con₂ dsa₂ mɨ₂güɨ́g₃?
\p 
\v 23 Jaun₂ ca₂ŋag₃ Jesús:
\p ―Juɨ₁lia'₂ i₂'nio₃ jniá₂, tón'₂ bá₄ juɨ₅ jág₁ quió₃; jaun₂ jme₃'nio₃ Ŋe'₃ jme₃'nioi₃ 'éi₂, jaun₂ qui₂ja₁náu₄ jnia'₅₄ ja₁coin₂ ja₁'io₁ quian'₅₄ 'éi₂.
\v 24 Juɨ₁lia'₂ i₂tsá₃ 'nio₃ jniá₂, tsá₃ tón'₂ juɨ₅ jág₁ quió₃. Jág₁ a₂nag'₂ 'nia'₂ la₂, on₃jua'₅₄ a₂quió₃, a₂quió'₅ Ŋe'₃ i₂ca₂chei₃ bá₄.
\p 
\v 25 ’Ca₂le₃jë́₃ a₂la₂ juá'₅ jniá₂ juɨ́g₂ 'nia'₂ të₁lia'₂ 'eng₅₄ guë́₄ quian'₅₄ 'nia'₂;
\v 26 la₁ia₁ i₂cuë₃ bí₂ 'au'₂ 'nia'₂ 'éi₂, i₂lɨ́n₅ Jme₂dsí₂ Jŋió₅, i₂chen₃ Ŋe'₃ o₄quió₃ jniá₂, 'éi₂ bá₄ jme₃tag₅ jme₃tɨin₂₃ 'nia'₂, jaun₂ jmo₃ a₂qui₃dsiog'₂ 'au'₂ 'nia'₂ ca₂le₃jë́₃ 'e₂ a₂ma₂qui₂ma₂juɨ́g₂ jniá₂ 'nia'₂.
\p 
\v 27 ’'Ág'₅ jniá₂ jág₁ a₂jmo₃ 'ag₃ tei₄ ja₁con'₂ 'nia'₃. A₂tei₄ a₂'ei₅ ja₁con₂ jniá₂, a₂jaun₂ bá₄ cuë́₅ jniá₂ 'nia'₂. La₁ on₃jua'₅₄ lia'₂ cuë₅ dsa₂ mɨ₂güɨ́g₃, cuë́₅ jniá₂ 'nia'₂. Tsá₃ lë₁can₂ 'nia'₂ o₂i₁ dsɨ₅, on₃ guë'₂ jmó'₂ 'nia'₂ gang'₃.
\v 28 Ma₂qui₂ma₂nei'₂ 'nia'₂ a₂juá'₅ jniá₂: a₂nég'₄, jaun₂ guio₅₄ táng₃ ja₁con'₂ 'nia'₂. Në₁jua'₂ të₃dsón'₂ 'nióg'₃ 'nia'₂ jniá₂, jme₁jmó'₂ 'nia'₂ 'io'₂ jme₁ca₂rë₃ŋi'₅₄ 'nia'₂ a₂né'₄ jniá₂ ja₁con₂ Ŋe'₃, ia₁ i₂juɨn'₂ guë́₄ 'éi₂ lia'₂ con'₂ guë́₄ jniá₂.
\v 29 Jaun₂ ma₂juɨ́g₂ jniá₂ 'nia'₂ a₂la₂ të₃jŋiá₅, ia₁jaun₂ le₃'én'₂ 'nia'₂ jë₁ma₂të́₂ rë₁lé₂ a₂jaun₂.
\p 
\v 30 ’Tsá₃ ma₂'lióng₂ jág₁ dsia₅₄ jniá₂ quian'₅₄ 'nia'₂; ia₁ ma₂já₅ i₂gon₂ mɨ₂güɨ́g₃ la₂, o₁jŋia'₅₄ tsá₃ 'e₂ juɨ₅bí₂ 'io₅ 'éi₂ ja₁con₂ jniá₂.
\v 31 La₁ia₁ 'nió'₅ le₃ŋi₅ dsa₂ mɨ₂güɨ́g₃, a₂'nió₃ jniá₂ Ŋe'₃, jaun₂ lia'₂ con'₂ lë́₅ 'éi'₃ a₂ma₂cuë₃ Ŋe'₃ jniá₂, a₂jaun₂ bá₄ jmo₅ jniá₂.
\p 'Nau₂ 'nia'₂. Ma₃dsau'₅₄ jniog₄ ja₁lá₃.
\c 15
\s1 Cho'₅₄ chi₁uɨ́ng₃ uvas, quian'₅₄ gu'₂ nei'₅₄ quió'₅
\p 
\v 1 ’Jniá₂ lɨ́ng₅ cho'₅₄ nɨ₁uɨng₂ uvas, ja₁já₅ bí₂ dsón'₂. Ŋe'₃ guë'₂ lɨ́n₅ i₂jmo₅ 'í₁ ja₁nau₂.
\v 2 Jŋiá'₂ 'éi₂ ca₂le₃jë́₃ nɨ₁gu'₂ quió₃ a₂tsá₃ mɨ́g₂ 'ag₅; la₁ia₁ qui₂jɨ́'₅ qui₂'uɨin₂₃ nɨ₁gu'₂ a₂'ag₅ mɨ́g₂, ia₁jaun₂ ráu₃ guë́₄ 'lióng₂.
\v 3 Ma₂le₁jɨ́n'₃ bá₄ 'nia'₂ të₂le₃ quian'₅₄ jág₁ a₂qui₂ma₂juɨ́g₂ jniá₂ 'nia'₂.
\v 4 Caun₂ juɨ₁të₂'ŋiá'₄ bá₄ 'nia'₂ ja₁con₂ jniá₂, juɨ₁lia'₂ të₂'ŋiá₄ jniá₂ ja₁con'₂ 'nia'₂. 'I₁caun₂ nɨ₁gu'₂ tsá₃ lé₂ le₃'ag₃ mɨ́g₂ con'₂ 'ŋiog₅ le₂jaun₂, në₁jua'₂ tsá₃ rë₂tsán'₂ quian'₅₄ cho'₅₄; ján₃ bá₄ le₂jaun₂ juɨ₁lia'₂ 'nia'₂ në́₃, tsá₃ 'e₂ lé₂ le₃ráu₃ quián'₂ 'nia'₂ në₁jua'₂ tsá₃ të₂'ŋiág'₄ ja₁con₂ jniá₂.
\p 
\v 5 ’Jniá₂ lɨ́ng₅ cho'₅₄; 'nia'₂ guë'₂ lɨ́ng'₅ gu'₂ nei'₅₄. Juɨ₁lia'₂ dsa₂ i₂të₂'ŋiá₄ rë₂tsán'₂ quian'₅₄ jniá₂, juɨ₁lia'₂ të₂'ŋiá₄ jniá₂ ja₁con₂ 'éi₂, 'lióng₂ ráu₃ quió'₅. Ia₁ 'i₁caun₂ tsá₃ 'e₂ lé₂ le₃jmó'₂ 'nia'₂ jua'₅₄ tsá₃ quiong'₅₄ jniá₂.
\v 6 Juɨ₁lia'₂ i₂tsá₃ të₂'ŋiá₄ ja₁con₂ jniá₂, lɨ́in₅ në₂jag₄ bá₄ caun₂ nɨ₁gu'₂ a₂dsɨ₂guia'₂ dsa₂ cau₅, jaun₂ rë₂quein₂. Nɨ₁gu'₂ le₂në₅ qui₂cág'₅ dsa₂, qui₂tó'₅ dsa₂ dsi₂si₂, jaun₂ cau₂.
\p 
\v 7 ’Chi₂jua'₂ të₂'ŋiá'₄ 'nia'₂ ja₁con₂ jniá₂, ton'₂ të₂'ŋiá₄ jág₁ quió₃ ja₁con'₂ 'nia'₂, jaun₂ mɨ₄ 'nia'₂ chi₂jua'₂ 'e₂ caun₂ 'niog'₂, jaun₂ guéi'₁ bá₄ 'nia'₂.
\v 8 Le₂la₂ bá₄ rë₂juɨn'₂ Ŋe'₃: a₂qui₂ráu₂ 'lióng₂ 'e₂ a₂jmo'₂ 'nia'₂.\f + \fr 15:8 \ft 'Nio'₂ ja₁ton₅ Isaías 61:3.\f* Le₂në₅ jme₂jniá'₂ 'nia'₂ a₂lɨ́ng'₅ dsa₂ i₂ca₂rë₃tɨ́n₃ quián₃ jniá₂.
\v 9 Juɨ₁lia'₂ 'nio₃ Ŋe'₃ jniá₂, ján₃ bá₄ le₂jaun₂ 'nió₃ jniá₂ 'nia'₂; caun₂ juɨ₁i₂nio₄ bá₄ 'nia'₂ juɨ₅ a₂'nió₃ jniá₂ 'nia'₂.
\v 10 Në₁jua'₂ caun₂ né'₂ 'nia'₂ gau₂ 'éi'₃ quió₃, le₂në₅ të₃'ŋiá'₄ 'nia'₂ juɨ₅ a₂'nió₃ jniá₂ 'nia'₂, juɨ₁lia'₂ caun₂ nag₅ jniá₂ gau₂ 'éi'₃ quió'₅ Ŋe'₃, ton'₂ të₂'ŋiá₄ jniá₂ juɨ₅ a₂'nio₃ 'éi₂ jniá₂.
\p 
\v 11 ’Jág₁ në₅ ma₂në₂juɨ́g₂ jniá₂ 'nia'₂ ia₁jaun₂ a₂ŋɨ́₄ lë₃ jéin₅ jniá₂ 'io'₂, cuë́₄ jniá₂ 'nia'₂, ia₁jaun₂ le₃'ŋia₅ bá₄ a₂jén'₂ 'nia'₂ 'io'₂.
\v 12 A₂la₂ bá₄ 'éi'₃ quió₃: a₂jme₁'nió'₄ 'nia'₂ rɨ́ng'₂ le₂jang'₂ le₂jang'₂, juɨ₁lia'₂ ma₂ca₂jme₁'nió₄ jniá₂ 'nia'₂.
\v 13 'I₁jan₂ tsá₃ lé₂ le₃'nio₃ guë́₄ lɨn₃ rɨin'₅₄, lia'₂ con'₂ guë́₄ i₂guein₅ 'mú₃ o₄quió'₄ a₂mei₅₄ quiáin₅.
\v 14 'Nia'₂ bá₄ lɨ́ng'₅ dsa₂ a₂mei₅₄ quiáng₃ chi₂jua'₂ jmo'₂ 'nia'₂ 'e₂ te₂nei'₄ jniá₂.
\v 15 Tsá₃ ma₃të́₅ jniá₂ 'nia'₂ dsa₂ i₂jme₂ti₃ ne₃, ia₁ tsá₃ ŋi₅ juɨ₁lia'₂ jan₂ dsa₂ i₂jme₂ti₃ ta₁, 'e₂ a₂jmo₅ juɨg₅₄. Të́₅ jniá₂ a₂mei₅₄ quiáng₃ bá₄ 'nia'₂, ia₁ ma₂ca₂jme₁jnia₅ bá₄ jniá₂ ja₁con'₂ 'nia'₂, ca₂le₃jë́₃ 'e₂ a₂ma₂ca₂juá'₂ Ŋe'₃.
\v 16 On₃jua'₅₄ 'nia'₂ ca₂quio'₅₄ jniá₂; jniá₂ bá₄ ma₂quion'₄ 'nia'₂, jaun₂ ma₂ca₂dsia₃ jniá₂ gog'₂ 'nia'₂ a₂o₁nó'₅ 'nia'₂ a₂qui₂rau₂ 'lióng₂ quián'₂ 'nia'₂ a₂jiog₃ uë́₂. Jaun₂ le₂në₅ cuë₃ Ŋe'₃ jniá₂ cuë́'₃ 'nia'₂ chi₂'e₂ caun₂ a₂mɨ́'₁ 'nia'₂ lia'₂ con'₂ lë́₅ 'éi'₃ quió₃ jniá₂.
\v 17 A₂la₂ bá₄ 'éi'₃ quió₃ jaun₂ në́₃: a₂jme₁'nió'₄ 'nia'₂ rɨ́ng'₂ le₂jang'₂ le₂jang'₂.
\s1 'Iog₅₄ dsa₂ mɨ₂güɨ́g₃ 'ŋiai₅₄ Jesús quian'₅₄ dsa₂ quiáin₅
\p 
\v 18 ’Chi₂jua'₂ 'iog₅₄ dsa₂ mɨ₂güɨ́g₃ quián'₂ 'nia'₂, juɨ₁le₂ŋi'₅₄ 'nia'₂, jniá₂ bá₄ ca₂rë₃'iog₅₄ dsa₂ le₂'uɨg₅₄.
\v 19 Jua'₅₄ mei'₂ guë́₃ lɨ́n'₅ 'nia'₂ dsa₂ i₂tén₅ mɨ₂güɨ́g₃, jme₁jme₃'nio₃ bá₄ dsa₂ mɨ₂güɨ́g₃ juɨ₁lia'₂ 'nioi₃ dsa₂ quiáin₅. La₁ 'uɨg₅₄ ia₁ a₂tsá₃ tén'₅ 'nia'₂ mɨ₂güɨ́g₃, ton'₂ ma₂quion'₄ jniá₂ 'nia'₂ jɨn₄ dsa₂ mɨ₂güɨ́g₃; 'uɨg₅₄ jaun₂ në́₃, 'ŋiai₅₄ 'nia'₂.
\v 20 Dsá₂ 'au'₂ 'nia'₂ jmo₄, jág₁ a₂ma₂juɨ́g₂ jniá₂ 'nia'₂: “Lia'₂ 'i₁jan₂ dsa₂ i₂jme₂ti₃ ta₁, tsá₃ juɨin'₂ guë́₄ con'₂ guë́₄ juɨg₅₄”. Chi₂jua'₂ ma₂qui₂ca₂co₃'ein₃ dsa₂ jniá₂, ján₃ bá₄ le₂jaun₂ qui₃co₃'en₃ dsa₂ 'nia'₂; chi₂jua'₂ ma₂tón'₂ dsa₂ juɨ₅ jág₁ a₂ma₂ca₂jme₁tɨin₅ jniá₂, ján₃ bá₄ le₂jaun₂ qui₃tón'₂ dsa₂ juɨ₅ jág₁ quián'₂ 'nia'₂.
\v 21 La₁ ca₂le₃jë́₃ a₂në₅ dsɨ₃ŋɨ́'₂ 'nia'₂ qui₃co₃jmóg'₂ dsa₂ 'uɨg₅₄ quió₃ jniá₂, ia₁ tsá₃ cuɨin₂₃ i₂ca₂chei₃ jniá₂.
\p 
\v 22 ’Tsá₃ jme₁le₃cáin'₄ jua'₅₄ mei'₂ guë́₃ tsá₃ guan₃ jniá₂ a₂o₂juá'₃ ja₁con₂ 'éi₂; la₁ në₃ në́₃, tsá₃ ma₃'e₂ lé₂ le₃juá'₂ jua'₅₄ tsá₃ ŋi₅.
\v 23 Ia₁ juɨ₁lia'₂ i₂'iog₅₄ jniá₂, ján₃ bá₄ 'ŋiai₅₄ Ŋe'₃ jniá₂.
\v 24 Tsá₃ jme₁le₃cáin'₄ jua'₅₄ mei'₂ tsá₃ léi₄ jaun₂ ca₂jmo₃ jniá₂ jɨn₄ dsa₂ 'éi₂ a₂tsá₃ 'ein₂ sián'₂ ma₂jmo₃; la₁ia₁ o₁jŋia'₅₄ la₂ ma₂ca₂jág₃ bá₄ léi₄ jaun₂, tion₅₄ bá₄ 'iog₅₄ dsa₂ jniá₂, lia'₂ Ŋe'₃ në́₃, 'ŋiai₅₄.
\v 25 La₁ia₁ qui₂lë́₂ ia₁jaun₂ le₃ti₃ jág₁ a₂tio'₅₄ ne₄ Si₂ 'Éi'₃ quió'₅ a₂juá'₂: “Ca₂rë₃'iog₅₄ dsa₂ të₃ tsá₃ 'e₂ cha₂ lë₃.”\f + \fr 15:25 \ft Salmo 35:19; 69:4.\f*
\p 
\v 26 ’La₁ia₁ jë₁ma₂të́₂ rë₁jiá₃ i₂cuë₃ bí₂ 'au'₂ 'nia'₂, i₂tsɨn₅₄ jniá₂ ja₁con'₂ 'nia'₂ i₂jiá₃ të₂le₃ ja₁guá₄ Ŋe'₃: Jme₂dsí₂ tí₅ dsón'₂ i₂o₂'ɨn₅ ja₁con₂ Ŋe'₃, i₂'éi₂ bá₄ jáng'₃ jág₁ dsau₅ të₂le₃ quió₃ jniá₂.
\v 27 Ján₃ bá₄ le₂jaun₂ 'nió'₅ jang'₅₄ 'nia'₂ jág₁ dsau₅, ia₁ ca₂le₃'uɨg₅₄ bá₄ ma₂qui₂ma₂tión'₂ 'nia'₂ quian'₅₄ jniá₂.
\c 16
\p 
\v 1 ’Le₂në₅ juɨ́g₂ jniá₂ 'nia'₂ ia₁jaun₂ tsá₃ qui₃dsi₃uɨ́n'₂ 'nia'₂ a₂'éng'₂.
\v 2 Qui₃'uág'₂ dsa₂ 'uɨ́in'₂ 'nia'₂ ja₁lë₁tong'₂ ne₄ si₂ guá'₅ sinagoga, ca₂le₃jë́₃ já₅ caun₂ jmɨg₄, lɨ́n₂ juɨ₁lia'₂ i₂jme₃dsiog₅ 'nia'₂, a₂jén'₃ ta₁ jaun₂ quió'₅ ne₄ Diú₄.
\v 3 Ca₂le₃jë́₃ a₂në₅ jmo₃\f + \fr 16:3 \ft A₂lɨn₅₄ chog₅₄ si₂: “jmo₃ jmái'₂ 'nia'₂.” \f* ia₁ tsá₃ ma₂ca₂rë₃cuɨin₂₃ Ŋe'₃, on₃ guë'₂ jniá₂ ma₂ca₂rë₃cuɨg₂₃.
\v 4 Jaun₂ juɨ́g₂ jniá₂ 'nia'₂ le₂në₅ ia₁jaun₂ jë₁ma₂të́₂ rë₁të₅₄ jmɨg₄ jaun₂, dsiog'₂ 'au'₂ 'nia'₂ a₂ca₂juɨ́g₂ jniá₂ 'nia'₂ jág₁ la₂.
\s1 Ta₁ a₂jmo₅ Jme₂dsí₂ Jŋió₅
\p ’Tsá₃ ca₂juá'₃ jniá₂ le₂në₅ lia'₂ con'₂ le₂'uɨg₅₄, ia₁ jme₁'en₅₄ bá₄ jniá₂ quian'₅₄ 'nia'₂.
\v 5 La₁ia₁ në₃ në́₃, ma₂nég'₄ i₁'ú₃ quiang'₅₄ i₂ca₂chei₃; jaun₂ lia'₂ 'i₁jan'₂ 'nia'₂ tsá₃ 'ein₂ ŋag₅: “¿A₂já'₄ guang'₅₄?”
\v 6 La₁ qui₂ca₂tá'₂ quɨ'₂ 'au'₂ 'nia'₂ 'uɨg₅₄ ia₁ a₂në₂juɨ́g₂ jniá₂ 'nia'₂ a₂në₅.
\v 7 La₁ jág₁ dsau₅ bá₄ juɨ́g₂ jniá₂ 'nia'₂: të₂le₃ a₂dse₃ quián'₂ 'nia'₂ bá₄ a₂né'₄ jniá₂. Ia₁ në₁jua'₂ tsá₃ ca₂ŋá'₃ jniá₂, tsá₃ jiá₃ i₂cuë₃ bí₂ 'au'₂ 'nia'₂; la₁ia₁ chi₂jua'₂ né'₄ jniá₂ në́₃, tsɨn₅₄ jniá₂ 'éi₂ ja₁con'₂ 'nia'₂.
\v 8 Jë₁ma₂të́₂ rë₁jiá₃ 'éi₂, jme₃jniai₂₃ a₂rë₂gan₂ dsa₂ mɨ₂güɨ́g₃ cuente quió'₅ dsáu₁, quió'₅ juɨ₅ dse₃, quió'₅ a₂jáu'₅ 'í₁ ja₁coin₂ në́₃.
\v 9 Cuente quió'₅ dsáu₁, 'uɨg₅₄ ia₁ a₂tsá₃ 'éin₂ le₃quió₃ jniá₂;
\v 10 cuente quió'₅ juɨ₅ dse₃, ia₁ a₂nég'₄ ja₁con₂ Ŋe'₃, jaun₂ tsá₃ ma₃jniá₂ jag'₅₄ 'nia'₂;
\v 11 ján₃ bá₄ cuente quió'₅ a₂jáu'₅ 'í₁, ia₁ ma₂jáu'₅ 'í₁ ja₁con₂ i₂'éi₂ i₂gon₂ mɨ₂güɨ́g₃ la₂.
\p 
\v 12 ’'Lióng₂ bá₄ jág₁ cha₂ guë́₄ a₂juɨg₅₄ jniá₂ 'nia'₂, la₁ia₁ tsá₃ quɨ'₅₄ 'nia'₂ jmɨg₄ le₃ŋɨ́g'₂ jë₂ në₃.
\v 13 La₁ jë₁ma₂të́₂ rë₁jiá₃ Jme₂dsí₂ tí₅ dsón'₂, i₂'éi₂ bá₄ jiog₃ 'nia'₂ juɨ₅ a₂tí₅ jág₁; ia₁ tsá₃ a₂jaun₂ juá'₂ 'éi₂ o₄quió'₄ 'ŋiog₅; a₂jaun₂ bá₄ juá'₂ ca₂le₃jë́₃ a₂nag₃, ton'₂ 'ë́₂ jág₁ juɨ₁lia'₂ 'e₂ niog₅ lé₂.
\v 14 Jme₃juag'₂ 'éi₂ jniá₂, ia₁ ŋei₂ juɨ₁lia'₂ a₂lë́₅ quió₃ jniá₂, jaun₂ 'éi₂ në́₃, jmo₃ jág₁ ja₁con'₂ 'nia'₂.
\v 15 Ca₂le₃jë́₃ a₂cha₂ quió'₅ Ŋe'₃, ján₃ bá₄ lë́₅ quió₃ jniá₂; jaun₂ bá₄ lë₃ në₂juá'₃ jniá₂ a₂ŋe₂ 'éi₂ juɨ₁lia'₂ a₂lë́₅ quió₃ jniá₂, jaun₂ jmo₃ jág₁ ja₁con'₂ 'nia'₂.
\s1 Juɨ₁lia'₂ a₂'lia'₂ dsɨ́₅ dsa₂ le₃tsɨ́n₃ a₂lé₂ a₂qui₃jmo₃ 'io'₂
\p 
\v 16 ’Ŋi'₅₄ ta₁, tsá₃ ma₃jag'₅₄ guë́₄ 'nia'₂ jniá₂; la₁ ŋi'₅₄ ta₁ bá₄, jag'₅₄ táng₃ jniá₂, ia₁ né'₄ jniá₂ ja₁con₂ Ŋe'₃.\f + \fr 16:16 \ft A₂lɨn₅₄ chog₅₄ si₂ tsá₃ le₁ton₅ jág₁: “ia₁ né'₄ jniá₂ ja₁con₂ Ŋe'₃.” \f*
\p 
\v 17 Jaun₂ në́₃, qui₂ca₂ŋag₃ i₂lɨn₅₄ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅ ca₂ŋɨ́i'₃ rɨin'₅₄ le₂jain₂ le₂jain₂:
\p ―¿I₂'e₂ 'nio₃ juá'₂ a₂juá'₂ tság₅ jniog₄ le₂në₅: “Ŋi'₅₄ ta₁, tsá₃ ma₃jag'₅₄ guë́₄ 'nia'₂ jniá₂; la₁ ŋi'₅₄ ta₁ bá₄, jag'₅₄ táng₃ jniá₂, ia₁ né'₄ jniá₂ ja₁con₂ Ŋe'₃”?
\v 18 ¿I₂'e₂ 'nio₃ juá'₂: “Ŋi'₅₄ ta₁”? Tsá₃ ne₄ i₂'e₂ jaun₂ 'ë₂₃.
\p 
\v 19 Jaun₂ ca₂rë₃lí'₄ Jesús i₂'e₂ 'nio₃ ŋag₃ tioin'₅₄, jaun₂ ca₂juá'₂:
\p ―¿A₁qui₂ŋɨ'₄ 'nia'₂ rɨ́ng'₂ 'uɨg₅₄ ia₁ a₂në₂juá'₃ jniá₂: “Ŋi'₅₄ ta₁, tsá₃ ma₃jag'₅₄ guë́₄ 'nia'₂ jniá₂; la₁ ŋi'₅₄ ta₁ bá₄, jag'₅₄ táng₃ jniá₂”?
\v 20 A₂dsɨ₂jó'₃ juɨ́g₂ jniá₂ 'nia'₂, a₂tóng'₂ 'nia'₂ qui₁'áu'₂, a₂'lia'₂ 'au'₂ në́₃, të₁lia'₂ jmo₃ dsa₂ mɨ₂güɨ́g₃ 'io'₂. La₁ia₁ le₃tsɨ́n₃ bá₄ a₂'lia'₂ 'au'₂ 'nia'₂ jaun₂ a₂qui₃jmó'₂ táng₃ 'io'₂.
\v 21 Juɨ₁lia'₂ lɨ́n₅ jan₂ 'io₅₄ jë₁rë₂chan₂ guein₂ quiain₅, 'lia'₂ dsɨ́₅ ia₁ ma₂ca₂të́₂ hora quió'₅; la₁ cang₂ jë₁ma₂ca₂rë₃chán₃ guein₂ quiáin₅, tsá₃ ma₃dsau'₂ dsɨ́₅ a₂ca₂rë₃quɨ́'₃ quió'₅, ia₁ a₂ŋɨ́₄ lë₃ 'io'₂ jén'₅, ia₁ a₂ca₂rë₃chán₃ jan₂ guein₂ mɨ₂güɨ́g₃ la₂.
\v 22 Ján₃ bá₄ le₂jaun₂ 'nia'₂ në́₃; 'lia'₂ 'au'₂ 'nia'₂ rë₂në́₃, la₁ jɨng₅₄ bá₄ táng₃ 'nia'₂, jaun₂ guë́₄ në́₃ jmó'₂ 'nia'₂ 'io'₂ të₂'au'₂, a₂'lio'₂ jén'₂ 'nia'₂ jaun₂ ca₂lia'₂ 'i₁jan₂ tsá₃ 'ein₂ lé₂ le₃jŋiá'₂.
\p 
\v 23 ’Jmɨg₄ jaun₂ tsá₃ ma₃'e₂ qui₁ŋag'₁ 'nia'₂ jniá₂ 'i₁caun₂. A₂dsɨ₂jó'₃ juɨ́g₂ jniá₂ 'nia'₂, chi₂jua'₂ 'e₂ a₂mɨ'₂ 'nia'₂ lia'₂ con'₂ lë́₅ 'éi'₃ quió₃ jniá₂, cuë₃ bá₄ Ŋe'₃.
\v 24 Ca₂lia'₂ jŋió₄ jmɨg₄ në₃, tsá₃ 'e₂ ma₂mɨ'₅₄ 'nia'₂ 'i₁caun₂ lia'₂ con'₂ lë́₅ 'éi'₃ quió₃. Mɨ₄ 'nia'₂, jaun₂ guéi'₁ 'nia'₂, ia₁jaun₂ le₃'ŋia₅ a₂o₂'ŋió₃ o₂jŋia₃ 'au'₂.
\s1 Jesucristo bá₄ ca₂tió'₃ mɨ₂güɨ́g₃ la₂
\p 
\v 25 ’Jág₁ la₂ ma₂në₂juɨ́g₂ jniá₂ 'nia'₂ quian'₅₄ jág₁ a₂jáng'₅ léi₄. La₁ jiá₃ hora a₂tsá₃ ma₃juɨg₅₄ jniá₂ 'nia'₂ quian'₅₄ jág₁ a₂jáng'₅ léi₄; lia'₂ rë₂jiá₃ jág₁ bá₄ juá'₄ jniá₂ juɨg₅₄ 'nia'₂ a₂'ɨ́ng₄ Ŋe'₃.
\v 26 Jmɨg₄ jaun₂ mɨ́'₁ 'nia'₂ ne₄ Ŋe'₃ lia'₂ con'₂ lë́₅ 'éi'₃ quió₃ jniá₂. Tsá₃ ma₃tion₅₄ juá'₄ jniá₂ a₂mɨ₅₄ jniá₂ ne₄ Ŋe'₃ o₄quián'₂ 'nia'₂,
\v 27 ia₁ ŋiog₅ bá₄ Ŋe'₃ 'nioi₃ 'nia'₂, ia₁ 'nióg'₃ 'nia'₂ jniá₂, ia₁ ma₂ca₂rë₃'én'₂ 'nia'₂ a₂guio₃ jniá₂ ja₁con₂ Diú₄.
\v 28 Ca₂o₃'ɨ́n₃ jniá₂ ja₁con₂ Ŋe'₃ a₂ca₂guang₃ mɨ₂güɨ́g₃ la₂; la₁ia₁ në₃ në́₃ o₃'ɨng₅ mɨ₂güɨ́g₃ la₂, jaun₂ nég'₄ táng₃ ja₁con₂ Ŋe'₃.
\p 
\v 29 Jaun₂ ca₂juá'₂ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅:
\p ―Në₃ guë́₄ në́₃ juá'₂ 'ne₂ lia'₂ rë₂jiá₃ jág₁; on₃jua'₅₄ quian'₅₄ jág₁ a₂jáng'₅ léi₄.
\v 30 Në₃ guë́₄ në́₃ ma₂ne₄ jnia'₅₄ a₂ŋi'₅₄ bá₄ 'ne₂ ca₂le₃jë́₃, jaun₂ tsá₃ 'e₂ 'nió'₅ quiáng'₂ jua'₅₄ tsá₃ ŋi'₅₄ 'e₂ qui₃ŋag₃ dsa₂ qui₃ŋɨ́i'₃ 'ne₂. 'Uɨg₅₄ jaun₂ 'éin₂ jnia'₅₄ a₂ŋe'₃ 'ne₂ ja₁con₂ Diú₄.
\p 
\v 31 Jaun₂ ca₂ŋag₃ Jesús:
\p ―¿Dsón'₂ jua'₅₄, në₃ guë́₄ 'én'₂ 'nia'₂?
\v 32 ¡Jag₄ 'nia'₂! Ma₂ja₂quián₃ hora, ton'₂ të₂në₃ dsón'₂ bá₄, a₂cuɨ́ng'₂ 'nia'₂ lé₂, a₂o₁nog'₄ tsɨ₁rë₂jang'₅₄ le₂jang'₂ le₂jang'₂ o₁nog'₄ jma₃quén₅ quiáng'₂; jaun₂ téi'₄ 'nia'₂ jniá₂ të₃tsɨng'₅₄ 'ŋió₃ lé₂. La₁ia₁ tsá₃ 'ŋió₃ jniá₂ të₃tsɨng'₅₄, ia₁ quiong'₅₄ bá₄ Ŋe'₃ jniá₂.
\v 33 Juɨ́g₂ jniá₂ 'nia'₂ le₃jë́₃ a₂la₂, ia₁jaun₂ 'ag₃ tei₄ 'au'₂ 'nia'₂ le₃quió₃ jniá₂. Mɨ₂güɨ́g₃ la₂ tion₅₄ rë'₂ qui₁cán'₂ 'nia'₂ quɨ'₂ 'au'₂; la₁ia₁ tiá₂ dsia₄ 'nia'₂ 'au'₂, ia₁ ma₂ca₂tió₃ bá₄ jniá₂ ja₁con₂ mɨ₂güɨ́g₃ la₂.
\c 17
\s1 Ca₂chi₃lén'₂ Jesús Diú₄ Jmei₂ o₄quió'₄ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅
\p 
\v 1 Jme₁ma₂ca₂juá'₂ Jesús le₂në₅, ca₂chóg'₃ ne₅₄ guei'₅₄ i₂juɨ́g₃, jaun₂ ca₂juá'₂:
\p ―Tia₅₄, ma₂të́₂ hora quió₃. Jme₁jnia₅ 'a₂ lia'₂ jlán'₁ ja₂ŋí'₂, ia₁jaun₂ jme₃jnia₅ ja₂ŋí'₂ 'a₂ lia'₂ jlán'₁ 'ne₂.
\v 2 Ia₁ ma₂ca₂cuë'₅₄ 'éi₂ 'éi'₃ ne₄ quió'₅ ca₂le₃jɨ́n₃ dsa₂, ia₁jaun₂ jmo₃ a₂le₃chan₂ co₂tan₅₄ ca₂le₃jɨ́n₃ i₂ma₂cuɨin'₅₄.
\v 3 A₂la₂ lë́₅ a₂chan₂ dsa₂ co₂tan₅₄: a₂le₃cuɨn₅ dsa₂ 'ne₂ i₂lɨ́ng'₅ i₂jan₂ tan₅₄ Diú₄ të₃dsón'₂, a₂le₃cuɨin₂₃ Jesucristo në́₃ i₂ca₂chen'₂ 'ne₂.
\p 
\v 4 ’Ma₂ca₂jme₁jnia₅ jniá₂ ne₄ gua'₅₄ 'uë₃ la₂ 'a₂ lia'₂ jlán'₁ 'ne₂, ia₁ ma₂ca₂jme₁'ŋia₅ jniá₂ ta₁ a₂ca₂cuë'₅₄ jmo₅₄.
\v 5 Në₃ në́₃, jaun₂, Tia₅₄, jmo₄ jlán'₁ jniá₂ ja₁cong'₂, juɨ₁lia'₂ jme₁lɨ́n₄ jniá₂ ja₁cong'₂ lia'₂ con'₂ né'₃ guë́₄ a₂nio₃ mɨ₂güɨ́g₃.
\p 
\v 6 ’Ma₂ca₂jme₁jnia₅ jniá₂ ne₄ dsa₂ i₂ca₂cuag'₅₄ jniá₂ jɨn₄ dsa₂ mɨ₂güɨ́g₃, i₂'ein₂ lɨ́n'₅ 'ne₂. I₂quiáng'₂ bá₄ jme₁lɨ́in₄, jaun₂ ma₂ca₂cuag'₅₄ jniá₂; ma₂qui₂ca₂'í₃ të₂dsɨ́₅ 'éi₂ jág₁ quiáng'₂.
\v 7 Ma₂ca₂rë₃ŋi₅ 'éi₂, ca₂le₃jë́₃ a₂ca₂cuë'₅₄ jniá₂ já₅ ja₁con'₂ 'ne₂;
\v 8 ia₁ ma₂ca₂cuë́₃ bá₄ jniá₂ jág₁ jaun₂ a₂ca₂cuë'₅₄ 'ne₂ jniá₂, jaun₂ ca₂gue₃ bá₄ 'éi₂ në́₃. Ma₂ca₂rë₃ŋi₅ lia'₂ con'₂ tí₅ jág₁, ja₁con'₂ 'ne₂ bá₄ o₂'ɨ́n₃ jniá₂, ton'₂ ca₂rë₃'éin₂ a₂ca₂chei'₂ 'ne₂ jniá₂.
\p 
\v 9 ’O₄quió'₄ 'éi₂ bá₄ mɨ₅ jniá₂, on₃jua'₅₄ o₄quió'₄ dsa₂ mɨ₂güɨ́g₃. O₄quió'₄ dsa₂ i₂ca₂cuag'₅₄ bá₄ mɨ₅ jniá₂, ia₁ i₂quiáng'₂ 'ne₂ bá₄ 'éi₂.
\v 10 Ia₁ ca₂le₃jɨ́n₃ dsa₂ quiáng₃, ján₃ bá₄ quiáng'₂ 'éi₂; ton'₂ ca₂le₃jɨ́n₃ dsa₂ quiáng'₂ në́₃, i₂quiáng₃ bá₄ 'éi₂ ján₃, jaun₂ rë₂jniá₂ a₂jlán'₁ jniá₂ të₂le₃ quian'₅₄ 'éi₂.
\p 
\v 11 ’Tsá₃ ma₃jan₄ jniá₂ mɨ₂güɨ́g₃ la₂; la₁ia₁ 'éi₂ në́₃ të₂'ŋiái₄ mɨ₂güɨ́g₃, jaun₂ nég'₄ ja₁con'₂ 'ne₂. Tia₅₄ Jŋió₅, jmo₄ 'í₁ 'éi₂ i₂ma₂cuag'₅₄ quian'₅₄ juɨ₅bí₂ a₂lɨ́ng'₅,\f + \fr 17:11 \ft A₂lɨn₅₄ chog₅₄ si₂: “jmo₄ 'í₁ 'éi₂ quian'₅₄ juɨ₅bí₂ a₂lɨ́ng'₅, a₂ma₂jmo'₅₄ a₂lɨ́n₅ jniá₂ ján₃.” \f* ia₁jaun₂ ca₂ne₅₄ bá₄ léin₂ co₂tan₅₄, juɨ₁lia'₂ lág₅ jniog₄.
\v 12 Lia'₂ con'₂ jme₁'en₅₄ jniá₂ quiang'₅₄ 'éi₂ mɨ₂güɨ́g₃ la₂,\f + \fr 17:12 \ft A₂lɨn₅₄ chog₅₄ si₂ tsá₃ chi₁ton₅: “mɨ₂güɨ́g₃ la₂.” \f* ma₂qui₂ma₂jmo₃ jniá₂ 'í₁ i₂ma₂cuag'₅₄ quian'₅₄ juɨ₅bí₂ a₂lɨ́ng'₅.\f + \fr 17:12 \ft A₂lɨn₅₄ chog₅₄ si₂: “ma₂qui₂ma₂jmo₃ jniá₂ 'í₁ quian'₅₄ juɨ₅bí₂ a₂lɨ́ng'₅, a₂ma₂jmo'₅₄ a₂lɨ́n₅ jniá₂ ján₃.” \f* Ma₂qui₂ma₂jmo₃ jniá₂ 'í₁, jaun₂ lia'₂ 'i₁jan₂ 'éi₂ tsá₃ ca₂i₃cón'₅, jŋia'₅₄ lia'₂ jan₂ bá₄ i₂'i₄ 'éi'₃ dsɨ₃'én₂, ia₁jaun₂ le₃ti₃ Si₂.
\p 
\v 13 ’Në₃ në́₃, nég'₄ ja₁cong'₂; la₁ia₁ të₁lia'₂ 'eng₅₄ guë́₄ mɨ₂güɨ́g₃, juá'₅ jniá₂ jág₁ la₂ ia₁jaun₂ le₃'ŋia₅ ja₁con₂ 'éi₂ a₂'io'₂ jéin₅ jniá₂.
\v 14 Ma₂ca₂cuë́₃ bá₄ jniá₂ jág₁ quiáng'₂, la₁ia₁ dsa₂ mɨ₂güɨ́g₃ në́₃, 'iog₅₄ quió'₅, ia₁ tsá₃ tén₅ 'éi₂ mɨ₂güɨ́g₃, juɨ₁lia'₂ jniá₂ në́₃, tsá₃ téng₅ mɨ₂güɨ́g₃.
\v 15 On₃jua'₅₄ rë'₂ mɨ₅ jniá₂ jua'₅₄ a₂'uɨin'₅₄ mɨ₂güɨ́g₃, a₂jaun₂ bá₄ mɨ₅ jniá₂ a₂jmó'₂ 'í₁ ia₁jaun₂ tsá₃ jo₃ i₂së₃dsen₃.
\v 16 Tsá₃ mɨ₂güɨ́g₃ téin₅, juɨ₁lia'₂ jniá₂ në́₃, tsá₃ téng₅ mɨ₂güɨ́g₃.
\v 17 Chon₄ dsa₂ 'éi₂ të₂le₃ quian'₅₄ jág₁ tí₅; ia₁ jág₁ quiáng'₂ bá₄ lë́₅ jág₁ tí₅.
\v 18 Juɨ₁lia'₂ ca₂chei'₂ 'ne₂ jniá₂ jɨn₄ dsa₂ mɨ₂güɨ́g₃, ján₃ bá₄ le₂jaun₂ tsɨn₅₄ jniá₂ 'éi₂ jɨn₄ dsa₂ mɨ₂güɨ́g₃.\f + \fr 17:18 \ft 'Nio'₂ ja₁ton₅ Juan 20:21.\f*
\v 19 O₄quió'₄ 'éi₂ bá₄ tsón₄ jniá₂ 'ŋio₃, ia₁jaun₂ ján₃ bá₄ le₂jaun₂ 'éi₂ në₃, lé₂ rë₂tsoin₅₄ le₃quió'₅ jág₁ tí₅.
\p 
\v 20 ’La₁ia₁ on₃jua'₅₄ jmá'₃ o₄quió'₄ 'éi₂ mɨ₅ jniá₂; ján₃ bá₄ le₂jiog₅ o₄quió'₄ i₂le₃'én₂ le₃quió₃, të₂le₃ quian'₅₄ jág₁ quió'₅,
\v 21 ia₁jaun₂ léin₂ ca₂ne₅₄ ca₂le₃jɨ́in₃, juɨ₁lia'₂ 'ne₂, Tia₅₄, 'eng'₅₄ ja₁con₂ jniá₂, ton'₂ 'en₅₄ guë'₂ jniá₂ ja₁con'₂ 'ne₂, ia₁jaun₂ 'éi₂ në́₃, dsɨ₃toin'₅₄ ja₁con₂ jniog₄, ia₁jaun₂ qui₃le₃'én₂ dsa₂ mɨ₂güɨ́g₃ a₂ca₂chei'₂ jniá₂.
\v 22 Ma₂ca₂cuë́₃ jniá₂ 'éi₂ a₂jlá'₁ quió₃ a₂ca₂cuë'₅₄ 'ne₂ jniá₂, ia₁jaun₂ lén₂ 'éi₂ ca₂ne₅₄, juɨ₁lia'₂ lág₅ jniog₄ ca₂ne₅₄ ján₃.
\v 23 Jniá₂ le₃quió'₅ 'éi₂, 'ne₂ guë'₂ le₃quió₃ jniá₂, ia₁jaun₂ le₃'ŋia₅ 'éi₂ a₂léin₂ ca₂ne₅₄, ia₁jaun₂ le₃ŋi₅ dsa₂ mɨ₂güɨ́g₃ a₂ca₂chei'₂ jniá₂, ton'₂ ca₂jme₁'nióg'₄ 'éi₂ juɨ₁lia'₂ ca₂jme₁'nióg'₄ jniá₂.
\p 
\v 24 ’Tia₅₄, 'nio₃ jniá₂ a₂dsɨ₃ton'₅₄ 'éi₂ i₂ca₂cuag'₅₄ ja₁cong₂, ia₁jaun₂ të₃ ne₅₄ a₂jlá'₁ quió₃ a₂ca₂cuë'₅₄ 'ne₂, ia₁ ca₂jme₁'nió'₄ 'ne₂ jniá₂, né'₃ guë́₄ a₂nio₃ mɨ₂güɨ́g₃.
\v 25 Tia₅₄ i₂dsen₃ guë́₄ lɨn₃, tsá₃ cuɨn₅ dsa₂ mɨ₂güɨ́g₃ 'ne₂, la₁ia₁ jniá₂ cuɨ́ng₅ 'ne₂, jaun₂ ma₂ŋi₅ bá₄ dsa₂ la₂ quiáng'₂ a₂ca₂chei'₂ 'ne₂ jniá₂.
\v 26 Ma₂ca₂jme₁jnia₅ jniá₂ ja₁con₂ 'éi₂ 'ein₂ lɨ́n'₅ 'ne₂, jaun₂ caun₂ jme₁jnia₅ bá₄ jniá₂ 'ne₂, ia₁jaun₂ juɨ₁lia'₂ a₂'nióg'₃ 'ne₂ jniá₂ të₃'ŋiá₄ ja₁con₂ 'éi₂, ton'₂ 'ú₄ jniá₂ ja₁coin₂.
\c 18
\s1 Ca₂jŋa'₃ dsa₂ Jesús
\r (Mateo 26:47-56; Marcos 14:43-50; Lucas 22:47-53)
\p 
\v 1 Jme₁ma₂ca₂dsan₃ juá'₂ Jesús le₂në₅, ca₂o₃'ɨ́in₃ quiain'₅₄ chi'₂ dsɨ₂guia₃-tɨ́n₂, qui₂ca₂'ain₃ Jɨ'₅₄ Jma₃ Cedrón. Le₂quióng₄ ja₁jaun₂, jme₁cha₂ caun₂ ja₁jme₁cha₂ nɨ₁'ma₂ 'ag₅ mɨ́g₂, ja₁ca₂'í₃ Jesús quiain'₅₄ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅.
\v 2 Ján₃ bá₄ le₂jaun₂ Judas i₂jme₁ma₂'en₅₄ juɨ₅ jáng'₂ quió'₅, jme₁ma₂cuɨ́'₅ bá₄ ja₁jaun₂, ia₁ 'lióng₂ ráun₂ ca₂ŋɨ'₂ Jesús ja₁jaun₂ quiain'₅₄ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅.
\v 3 Jaun₂ lë₃ ca₂dsióg₃ Judas ja₁jaun₂ quiain'₅₄ co₂nió'₃ 'lióg₂, quiain'₅₄ co₂nió'₃ guë'₂ chi'₂ 'ɨ'₅₄ quián₅ guá'₅, i₂chen₄ quián₅ juɨg₅₄ jme₂dsa₂ quian'₅₄ dsa₂ fariseos në́₃. Ca₂dsi₃lén₂ dsa₂ 'éi₂ qui₂le₁quian₅ ŋi₁tág₂, nɨ₁'ma₂, quian'₅₄ si₂ nɨ₁tsɨ́₅, nɨ₁quɨ₂ a₂le₁guí'₃ si₂ në́₃.
\v 4 La₁ia₁ Jesús në́₃, jme₁ma₂ŋi₅ bá₄ ca₂le₃jë́₃ 'e₂ a₂dsɨ₃ŋɨ́i₂, jaun₂ o₂'ɨ́in₃ ja₁jaun₂ ca₂i₁jme₁jein'₂ dsa₂, jaun₂ ca₂ŋɨ́i'₃ dsa₂ 'éi₂:
\p ―¿I₂'ein₂ 'nag'₂ 'nia'₂?
\p 
\v 5 Jaun₂ ca₂ŋag₃ dsa₂ 'éi₂:
\p ―Jesús i₂chan₂ Nazaret bá₄ 'nia'₂ jnia'₅₄.
\p Jaun₂ ca₂ŋag₃ Jesús:
\p ―Jniá₂ bá₄ 'éi₂.
\p Jaun₂ bá₄ jme₁chén'₄ Judas i₂jáng'₂ quió'₅, quiain'₅₄ dsa₂ 'éi₂.
\p 
\v 6 Jaun₂ jme₁ca₂juá'₂ Jesús ca₂tsɨ́'₃ dsa₂: “Jniá₂ bá₄ 'éi₂”, jaun₂ i₃léin₂ le₃ca'₃ i₃gain'₅₄ 'uë₃.
\p 
\v 7 Jaun₂ në́₃ ca₂ŋag₃ táng₃ Jesús ca₂ŋɨ́i'₃ dsa₂ 'éi₂:
\p ―¿I₂'ein₂ 'nag'₂ 'nia'₂?
\p Jaun₂ ca₂ŋag₃ táng₃ dsa₂:
\p ―Jesús i₂chan₂ Nazaret bá₄.
\p 
\v 8 Jaun₂ ca₂ŋag₃ táng₃ Jesús:
\p ―Ma₂në₂juɨ́g₂ jniá₂ 'nia'₂, jniá₂ bá₄ lɨ́ng₅ 'éi₂.\f + \fr 18:8 \ft lit. “Jniá₂ lɨ́ng₅”, co₂'nió'₄ jein₅ jág₁ lia'₂ chen₂ Jehová. 'Nio'₂ ja₁ton₅ Éxodo 3:14.\f* Chi₂jua'₂ jniá₂ 'nau'₂ 'nia'₂, cuë₄ jmɨg₄ juɨ₁dsi₂len₅ bá₄ i₂la₂.
\p 
\v 9 A₂la₂ ca₂lë₃ ia₁jaun₂ le₃ti₃ lia'₂ con'₂ lë́₅ a₂jme₁ca₂juá'₂ Jesús tsɨ́'₅ Jmei₂: “Juɨ₁lia'₂ i₂ca₂cuag'₅₄ 'ne₂ jniá₂, tsá₃ 'ein₂ ca₂i₃cón'₅ 'i₁jan₂.”
\p 
\v 10 Jaun₂ në́₃ jme₁quian₅ Si₂mu₅₄ Pe₄ ŋi₁tág₂, jaun₂ ca₂dsí₃ ca₂quí'₃ rë₂gua₄ ne₁ quió'₅ jan₂ dsa₂ i₂jme₁chen₂ Malco, i₂jme₂ti₃ ta₁ ne₄ jme₂dsa₂ dsen₅₄.
\p 
\v 11 La₁ ca₂juá'₂ Jesús ca₂tsɨ́'₃ Pe₄:
\p ―Tio'₂ táng₃ ŋi₁tág₂ ja₁jme₁'i₄. ¿'E₂ lɨ́n'₂ 'ne₂ a₂tsá₃ ca₂tɨ́n₂ jniá₂ dsɨ₃ŋɨ́g₂ a₂ma₂juá'₂ Ŋe'₃?\f + \fr 18:11 \ft lit. “¿'E₂ lɨ́n'₂ 'ne₂ a₂tsá₃ guɨ'₅₄ jniá₂ tion₅₄ jmɨg₂ dsi'₃ a₂ma₂cuë₃ Ŋe'₃?” \f*
\s1 Ŋó₃ Jesús ne₄ jme₂dsa₂ dsen₅₄
\r (Mateo 26:57-58; Marcos 14:53-54; Lucas 22:54)
\p 
\v 12 Jaun₂ në́₃ ca₂jŋau'₃ co₂nió'₃ 'lióg₂ lia'₂ jma₃quiain'₅₄ juɨg₅₄, quiain'₅₄ chi'₂ 'ɨ'₅₄ quián₅ guá'₅ në́₃, ca₂jŋai'₃ Jesús, jaun₂ qui₂ca₂'nei'₂ në́₃.
\v 13 Jaun₂ ca₂i₁jiog₃ le₂'uɨg₅₄ ja₁quió'₄ Anás. Anás 'éi₂ në́₃ jme₁lɨ́n₄ dsɨ₂jmei₂ Caifás, i₂jme₁lɨ́n₄ ta₁ jme₂dsa₂ dsen₅₄ ŋi₂ jaun₂.
\p 
\v 14 Caifás 'éi₂ në́₃ i₂jme₁ca₂juá'₂ ca₂tsɨ́'₃ dsa₂ judíos, a₂jmo₅ jón₂ jan₂ dsa₂ o₄quió'₄ dsa₂ juɨg₂.\f + \fr 18:14 \ft Juan 11:50.\f*
\s1 Tsá₃ ca₂tion₃ Pe₄ a₂cuɨin₂₃ Jesús
\r (Mateo 26:69-70; Marcos 14:66-68; Lucas 22:55-57)
\p 
\v 15 Jaun₂ ca₂ŋó₃ Si₂mu₅₄ Pe₄ quiain'₅₄ guë́₄ jan₂ dsa₂ i₂guia₃-tɨ́n₂ sián'₂ në́₃, chi₁co'₅₄ quió'₅ Jesús. Dsa₂ guia₃-tɨ́n₂ jan₂ 'éi₂ në́₃ jme₁cuɨg₅ bá₄ jme₂dsa₂ dsen₅₄ quió'₅, jaun₂ bá₄ ca₂'í₃ co₂lë₅ quiain'₅₄ Jesús i₁dsi₅ quió'₅ jme₂dsa₂ dsen₅₄.
\v 16 La₁ Pe₄ në́₃, jaun₂ bá₄ ca₂nau₂ o₄'né₄ të₂le₃ ca₁'né₄. 'Uɨg₅₄ jaun₂ ca₂o₃'ɨ́n₃ dsa₂ guia₃-tɨ́n₂ i₂ma₂cuɨg₅ jme₂dsa₂ dsen₅₄ quió'₅, jaun₂ ca₂juá'₂ ca₂tsɨ́'₃ 'io₅₄ i₂niog₅ ne₄ o₄'né₄, jaun₂ ca₂ŋɨ́i₂ Pe₄ të₂le₃ dsi₂néi₂.
\p 
\v 17 Jaun₂ në́₃ ca₂ŋag₃ 'io₅₄ i₂jmo₅ 'í₁ o₄'né₄ ca₂ŋɨ́i'₃ Pe₄:
\p ―On₃jua'₅₄ 'ne₂ lɨ́ng'₅ jan₂ i₂ca₂rë₃tɨ́n₃ quián₅ dsa₂ në₅, ¿lia'₅₄?
\p Jaun₂ ca₂juá'₂:
\p ―Jan₂'ón₄, on₃jua'₅₄ jniá₂ 'éi₂.
\p 
\v 18 Ja₁jaun₂ jme₁tión₂ dsa₂ i₂jme₂ti₃ ta₁, quiain'₅₄ chi'₂ 'ɨ'₅₄ quián₅ guá'₅. Jme₁ma₂ca₂dsia₃ ca₂jo'₅₄ si₂, ia₁ a₂jme₁güɨ́g₂, jaun₂ tióin₂ qui₂jme₂dsioin'₂. Ján₃ bá₄ jë₄ jaun₂ jme₁chén'₄ Pe₄ jme₂dsioin'₂.
\s1 Chén'₅ Jesús ne₄ jme₂dsa₂ dsen₅₄
\r (Mateo 26:59-66; Marcos 14:55-64; Lucas 22:66-71)
\p 
\v 19 Jaun₂ ca₂ŋag₃ jme₂dsa₂ dsen₅₄ ca₂ŋɨ́i'₃ Jesús cuente quió'₅ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅, cuente quió'₅ juɨ₁lia'₂ jág₁ a₂jme₂tag₂₃ në́₃.
\p 
\v 20 Jaun₂ ca₂ŋag₃ Jesús:
\p ―Ma₂qui₂ma₂juá'₃ bá₄ jniá₂ lia'₂ rë₂jiá₃ jág₁ të₃ne₄ ca₂le₃jɨ́n₃ dsa₂; jme₁qui₂jme₁tɨ́n₂ jniá₂ tián₂ dsa₂ dsi₂néi₂ guá'₅ sinagoga quian'₅₄ i₁dsi₅ guá'₅ templo në́₃, ja₁qui₂ŋɨ'₂ ca₂le₃jɨ́n₃ dsa₂ judíos. Tsá₃ 'e₂ jág₁ ma₂juá'₃ jniá₂ 'i₁caun₂ të₃ chi₁'ma₁.
\v 21 ¿'E₂ 'uɨg₅₄ ŋag'₅₄ 'ne₂ jniá₂ jaun₂? Ŋɨ'₅₄ juɨ₁lia'₂ dsa₂ i₂qui₂ma₂nág₂ jág₁ quió₃, 'e₂ ma₂juɨ́g₂ jniá₂. Jag₄ de'₂, i₂ŋi₅ bá₄ 'éi₂ juɨ₁lia'₂ i₂'e₂ jág₁ a₂ma₂juá'₃ jniá₂.
\p 
\v 22 Jme₁ca₂juá'₂ Jesús le₂në₅, jan₂ chi'₂ 'ɨ'₅₄ quián₅ guá'₅ i₂jme₁chén'₄ cau₅, ca₂quein₃ dsɨ₂ne₄ Jesús, jaun₂ ca₂juá'₂:
\p ―¿Le₁në₅ bá₄ ŋag'₅₄ 'ne₂ ne₄ jme₂dsa₂ dsen₅₄?
\p 
\v 23 Jaun₂ ca₂ŋag₃ Jesús:
\p ―Chi₂jua'₂ 'lɨg'₅₄ në₂juá'₃ jniá₂, jua'₅₄, jme₁jnia₅ chi₂jua'₂ já'₄ ca₂'lian'₂ jniá₂ jaun₂. La₁ chi₂jua'₂ dsau₅ bá₄ jág₁ a₂në₂juá'₃, ¿'e₂ guë'₂ lë₃ quein'₂ quió₃?
\p 
\v 24 Jaun₂ në́₃ ca₂chei₃ Anás ca₂chein₃ Jesús chi₁'ŋei'₅₄ ne₄ Caifás, i₂lɨ́n₅ jme₂dsa₂ dsen₅₄.
\s1 Con'₂ siá'₂ táng₃ tsá₃ ca₂tion₃ Pe₄ a₂cuɨin₂₃ Jesús
\r (Mateo 26:71-75; Marcos 14:69-72; Lucas 22:58-62)
\p 
\v 25 Të₁lia'₂ jaun₂ në́₃, jaun₂ bá₄ chén'₅ Pe₄ jme₂dsioin'₂ cau₅ si₂, jaun₂ ca₂ŋag₃ dsa₂ ca₂ŋɨ́i'₃ Pe₄:
\p ―¿On₁jua'₅₄ 'ne₂ lɨ́ng'₅ jan₂ i₂ca₂rë₃tɨ́n₃ quián₅ dsa₂ në₅?
\p Tsá₃ ca₂tion₃ Pe₄ jaun₂, ca₂juá'₂:
\p ―Jan₂'ón₄. On₃jua'₅₄ jniá₂ 'éi₂.
\p 
\v 26 Jaun₂ në́₃ ca₂ŋag₃ jan₂ i₂jme₂ti₃ ta₁ ne₄ jme₂dsa₂ dsen₅₄, i₂lɨ́n₅ jan₂ o₁rɨn'₅₄ dsa₂ i₂ca₂quí'₃ Pe₄ rë₂gua₄, ca₂juá'₂:
\p ―¿Tsa₁ në₂jɨn₄ jniá₂ 'ne₂ ja₁cha₂ nɨ₁'ma₂ jaun₂, co₂lë₅ quian'₅₄ 'éi₂?
\p 
\v 27 Jaun₂ con'₂ siá'₂ táng₃ tsá₃ ca₂tion₃ Pe₄ a₂cuɨin₂₃ Jesús. Jaun₂ lia'₂ ma₂të₂dsi₅₄ jaun₂, ca₂'o₃ të₁guí₄ dsó₂.
\s1 Chén'₅ Jesús ne₄ Dsi₄má'₂ Pilato
\r (Mateo 27:1-2, 11―14; Marcos 15:1-5; Lucas 23:1-5)
\p 
\v 28 Jaun₂ në́₃ ca₂dsen₅ dsa₂ Jesús ja₁quió'₄ Caifás ca₂i₁jiog₃ të₂ ne₄ta₁ quió'₅ dsi₄má'₂. Jme₁ma₂jnia₃ mɨ₂güɨ́g₃, jaun₂ tsá₃ ca₂tón'₂ dsa₂ judíos dsi₂néi₂ ne₄ta₁ quió'₅ dsi₄má'₂, ia₁jaun₂ tsá₃ le₃'iog₅ quió'₅, ia₁ 'nio₃ jme₁guë́'₃ má₃ quió'₅ Jmɨg₄ Të₂'ɨn₅₄.
\p 
\v 29 'Uɨg₅₄ jaun₂ në́₃ ca₂o₃'ɨ́n₃ Pilato 'ŋiog₅ ja₁tion'₅₄ 'éi₂, jaun₂ ca₂juá'₂:
\p ―¿'E₂ dso₄ bon'₄ 'nia'₂ dsa₂ la₂?
\p 
\v 30 Jaun₂ ca₂ŋag₃ dsa₂:
\p ―Jua'₅₄ mei'₂ guë́₃ tsá₃ rɨn₅ dsa₂ në₅ dso₄, tsá₃ o₄gog'₂ 'ne₂ jme₁jɨin'₅₄ jnia'₅₄.
\p 
\v 31 Jaun₂ në́₃ ca₂juá'₂ Pilato ca₂tsɨ́'₃ dsa₂:
\p ―Te₅₄ 'nia'₂ jaun₂, qui₂dsɨ₅ 'nia'₂ 'éi'₃ quió'₅ lia'₂ con'₂ lë́₅ 'Éi'₃ quián'₂ 'nia'₂ guiong'₅₄.
\p Jaun₂ ca₂ŋag₃ dsa₂ judíos:
\p ―La₁ia₁ tsá₃ 'i₄ 'éi'₃ a₂jŋɨ́'₄ jnia'₅₄ jan₂ dsa₂.
\p 
\v 32 Le₂në₅ ca₂rë₃ti₃ jág₁ a₂ca₂juá'₂ Jesús 'e₂ ne₅₄ 'mú₃ a₂dsɨ₃ŋɨ́i₂.
\p 
\v 33 Jaun₂ ca₂'í₃ táng₃ Pilato të₂le₃ dsi₂néi₂ ne₄ta₁ quió'₅, jaun₂ ca₂të́'₃ Jesús jaun₂ ca₂ŋɨ́i'₃ 'éi₂:
\p ―¿Lɨ́n'₅ 'ne₂ Rag₅₄ quián₅ dsa₂ judíos?
\p 
\v 34 Jaun₂ ca₂ŋag₃ Jesús:
\p ―¿A₂ŋag'₅₄ 'a₂ con'₂ dsɨ₂jiog₅ 'au'₂ 'ŋiag'₂ a₂juá'₂ në₅, o₃ chan₂ i₂sián'₂ a₂ma₂juá'₂ 'ag₂₃ jniá₂?
\p 
\v 35 Jaun₂ ca₂ŋag₃ Pilato:
\p ―¿O₃ bá₄ dsa₂ judío lɨ́n₅ jniá₂? Dsa₂ juɨg₂ quiáng'₂, quian'₅₄ juɨg₅₄ jme₂dsa₂ bá₄ në₂jáng'₂ quiáng'₂ o₄gu₃ jniá₂. ¿'E₂ ma₂jmo'₅₄?
\p 
\v 36 Jaun₂ në́₃ ca₂ŋag₃ Jesús:
\p ―On₃jua'₅₄ mɨ₂güɨ́g₃ la₂ ja₁gon₂ jniá₂. Jua'₅₄ mei'₂ guë́₃ mɨ₂güɨ́g₃ la₂ ja₁gon₂ jniá₂, jme₁náu₃ 'nei₂ bá₄ dsa₂ i₂quiong'₅₄ jniá₂ ia₁jaun₂ tsá₃ jme₁jáng'₂ dsa₂ ne₄ dsa₂ judíos. La₁ on₃jua'₅₄ ja₁lá₃ ja₁gon₂ jniá₂.
\p 
\v 37 Jaun₂ në́₃ ca₂juá'₂ Pilato ca₂tsɨ́'₃ Jesús:
\p ―¿Dsón'₂ bá₄ lɨ́n'₅ 'ne₂ rag₅₄ jaun₂ në́₃?
\p Jaun₂ ca₂ŋag₃ Jesús:
\p ―Dsau₅ bá₄ juá'₂ 'ne₂, a₂lɨ́n₅ jniá₂ rag₅₄. Ta₁ jaun₂ ca₂rë₃cháng₃, ta₁ jaun₂ guang₃ mɨ₂güɨ́g₃, ia₁jaun₂ jáng'₄ jág₁ dsau₅ o₄quió'₄ jág₁ tí₅. Ca₂le₃jɨ́n₃ i₂tión₂ le₃quió'₅ jág₁ tí₅, nag₂₃ jág₁ quió₃.
\p 
\v 38 Jaun₂ ca₂juá'₂ Pilato ca₂tsɨ́'₃ Jesús:
\p ―¿I₂'e₂ jaun₂ jág₁ tí₅?
\s1 Ca₂o₃'ág₃ 'éi'₃ a₂jón₂ Jesús
\r (Mateo 27:15-31; Marcos 15:6-20; Lucas 23:13-25)
\p Jme₁ca₂dsan₃ juá'₂ Pilato le₂në₅, ca₂o₃'ɨ́in₃ táng₃, ca₂dsia₃ táng₃ jág₁ quian'₅₄ dsa₂ judíos. Jaun₂ ca₂juá'₂:
\p ―Tsá₃ dso₄ dso'₂ jniá₂ ja₁con₂ dsa₂ la₂.
\v 39 La₁ chí'₅ caun₂ tag₄ quián'₂ 'nia'₂ a₂tén₅ jniá₂ jan₂ dsa₂ ja₁con'₂ 'nia'₂ jme₁të₅ Jmɨg₄ Të₂'ɨn₅₄. ¿'Niog'₂ 'nia'₂ jaun₂ a₂tén₄ jniá₂ Rag₅₄ quián₅ dsa₂ judíos?
\p 
\v 40 Jaun₂ në́₃, ca₂tóin'₂ co₂mɨ'₅₄ ca₂juá'₂:
\p ―¡On₃jua'₅₄ i₂në₅! ¡Barrabás bá₄ tén₃!
\p Barrabás 'éi₂ në́₃, jme₁lɨ́in₄ jan₂ dsa₂ 'ang₂ i₂ca₂nau₂ 'nei₂.\f + \fr 18:40 \ft 'Nio'₂ ja₁ton₅ Marcos 15:7.\f*
\c 19
\p 
\v 1 Jaun₂ në́₃ ca₂jmo₃ Pilato 'éi'₃ a₂ca₂i₁ban₅ dsa₂ Jesús quian'₅₄ tsɨ₁'nei₅₄ a₂co₂taun₅.
\v 2 Jaun₂ ca₂jmo₃ 'lióg₂ caun₂ nɨ₁tsag₂ corona a₂lë́₅ jméi₁ nɨ₁uɨng₂ taun₅, jaun₂ ca₂tó'₂ mɨ₂dsi₄ Jesús. Jaun₂ ca₂quen'₃ dsa₂ Jesús caun₂ tsɨ₁'mɨ'₂ chen'₅₄ a₂jniá₂ 'uɨ'₃ guéin₂.
\v 3 Jaun₂ në́₃ qui₂ca₂jme₃quiáin₃ ja₁con₂ 'éi₂, a₂juá'₂:
\p ―¡Sian'₃ 'ne₂, Rag₅₄ quián₅ dsa₂ judíos!
\p Jaun₂ qui₂ca₂quein₃ dsɨ₂ne₄ Jesús.
\p 
\v 4 Jaun₂ në́₃ o₂'ɨ́n₃ táng₃ Pilato, jaun₂ ca₂juá'₂ ca₂tsɨ́'₃ dsa₂:
\p ―Nei₂ 'nia'₂, dséin₄ jniá₂ ja₁lá₃ le₃ja₁con'₂ 'nia'₂, ia₁jaun₂ le₃len'₅₄ 'nia'₂ ca₂lia'₂ 'i₁caun₂ dso₄ tsá₃ dso'₂ jniá₂ ja₁coin₂.
\p 
\v 5 Jaun₂ o₂'ɨ́n₃ Jesús, 'i₄ dsi₅₄ corona lë́₅ nɨ₁uɨng₂ taun₅, ján₃ bá₄ qui'₂ tsɨ₁'mɨ'₂ chen'₅₄ 'uɨ'₃ jaun₂. Jaun₂ në́₃ ca₂juá'₂ Pilato ca₂tsɨ́'₃ dsa₂:
\p ―¡Jɨn₄ 'nia'₂ dsa₂!
\p 
\v 6 Jaun₂ jme₁qui₂ca₂jág₂ juɨg₅₄ jme₂dsa₂ quian'₅₄ chi'₂ 'ɨ'₅₄ quián₅ guá'₅ në́₃, jaun₂ ca₂jme₃lióg₃ qui₂ca₂tóin'₂ co₂mɨ'₅₄, ca₂juá'₂:
\p ―¡Tióin₃ cróg₄! ¡Tióin₃ cróg₄!
\p Jaun₂ ca₂juá'₂ Pilato:
\p ―Te₅₄ 'nia'₂ jaun₂, tióin₃ 'nia'₂ cróg₄ guiong'₅₄, ia₁ jniá₂ në́₃, 'i₁caun₂ dso₄ tsá₃ dso'₂ jniá₂ ja₁coin₂.
\p 
\v 7 La₁ia₁ ca₂ŋag₃ dsa₂ judíos:
\p ―Ron₅ caun₂ 'éi'₃ quián₂ jnia'₅₄, jaun₂ lia'₂ con'₂ lë́₅ juá'₂ 'éi'₃ jaun₂, a₂'nió'₅ jóin₂ bá₄; ia₁ a₂jmo₂₃ a₂lɨ́in₅ Ja₁ŋi'₅₄ Diú₄.
\p 
\v 8 Jme₁ca₂nág₂ Pilato jág₁ në₅, 'ŋio₅ lɨn₃ guë́₄ ca₂i₃gó'₃ dsɨ́₅.
\v 9 Jaun₂ ca₂'í₃ táng₃ të₂le₃ dsi₂néi₂ ne₄ta₁ quió'₅, jaun₂ ca₂ŋag₃ ca₂ŋɨ́i'₃ Jesús:
\p ―¿A₂já'₄ chan'₂ 'ne₂?
\p La₁ tsá₃ 'e₂ ca₂ŋag₃ Jesús, 'i₁caun₂.
\v 10 Jaun₂ në́₃, ca₂juá'₂ Pilato:
\p ―¿Tsa₁ ŋag'₅₄ 'ne₂ jág₁ quió₃ jniá₂? ¿Tsa₁ ŋi'₅₄ 'ne₂ jaun₂ a₂'o₂ jniá₂ juɨ₅bí₂ a₂jmo₅₄ 'éi'₃ a₂tion₃ dsa₂ cróg₄ 'ne₂, ján₃ bá₄ le₂jaun₂ guë'₂ ján₃, a₂'o₂ jniá₂ juɨ₅bí₂ a₂long₅₄ 'ne₂?
\p 
\v 11 Jaun₂ ca₂ŋag₃ Jesús:
\p ―Ca₂lia'₂ 'i₁caun₂ juɨ₅bí₂ tsá₃ 'au'₂ 'ne₂ ja₁con₂ jniá₂, jua'₅₄ tsá₃ Diú₄ ca₂cuë₃. 'Uɨg₅₄ jaun₂, juɨ₁lia'₂ i₂në₂jáng'₂ jniá₂ ne'₅₄ 'ne₂, 'ŋio₅ lɨn₃ guë́₄ juë'₂ dso₄ rë₂cáin'₄ con'₂ guë́₄ 'ne₂.
\p 
\v 12 Ca₂le₃ jaun₂ ca₂'náu'₃ dsɨ́₅ Pilato 'a₂ lia'₂ cuɨn₅ jmɨg₄ a₂jme₁lióin₂ Jesús; la₁ dsa₂ judíos në́₃ qui₂ca₂tóin'₂ co₂mɨ'₅₄ ca₂juá'₂:
\p ―¡Në₁jua'₂ ca₂lioin'₅₄, tsá₃ lɨ́ng'₅ a₂mei₅₄ quián₅ dsɨ₂tan₅₄ emperador! ¡Ia₁ në₁jua'₂ 'ein₂ jmo₅ lɨ́in₅ rag₅₄, lɨ́in₅ jan₂ dsa₂ i₂'ŋia₅₄ emperador!
\p 
\v 13 Jaun₂ në́₃ jme₁ca₂nág₂ Pilato jág₁ jaun₂, ca₂dsein₂₃ Jesús. Jaun₂ ca₂guá₂ ne₄ta₁ ja₁qui₂dsɨ₂₃ 'éi'₃; ja₁jaun₂ ja₁chei₂ Gabata quian'₅₄ jág₁ jmei₅ hebreo, co₂'nió'₄ a₂juá'₂, ja₁lë́₄ 'uë₃ cang₄.
\v 14 Jme₁lë́₄ jmɨg₄ a₂jmo₅ dsa₂ co₂jŋia₅₄ Jmɨg₄ Të₂'ɨn₅₄; jme₁ma₂të́₂ con'₂ dsi₂ŋí'₃; jaun₂ ca₂juá'₂ Pilato ca₂tsɨ́'₃ dsa₂ judíos:
\p ―¡Jɨn₄ 'nia'₂ rag₅₄ quiáng'₂!
\p 
\v 15 La₁ ca₂tóin'₂ co₂mɨ'₅₄ ca₂juá'₂:
\p ―¡Cau₅ jŋiai'₃! ¡Cau₅ jŋiai'₃! ¡Tióin₃ cróg₄!
\p Jaun₂ ca₂juá'₂ Pilato:
\p ―¿A₁'niog'₂ 'nia'₂ tóng₄ cróg₄ rag₅₄ quián'₂ 'nia'₂?
\p La₁ qui₂ca₂ŋag₃ juɨg₅₄ jme₂dsa₂ ca₂juá'₂:
\p ―Tsá₃ rag₅₄ sián'₂ chan₂ quián₂ jnia'₅₄, jŋia'₅₄ lia'₂ jan₂ emperador bá₄.
\p 
\v 16 Jaun₂ bá₄ ca₂jáng'₂ Pilato ca₂jɨ́in'₂ Jesús ia₁jaun₂ tio₃ dsa₂ ne₄ cróg₄. Jaun₂ ca₂tág₃ dsa₂.
\s1 Ca₂tion₃ dsa₂ cróg₄ Jesús
\r (Mateo 27:32-44; Marcos 15:21-32; Lucas 23:26-43)
\p 
\v 17 O₂'ɨ́n₃ Jesús jaun₂, quian₅ cróg₄ quió'₅, a₂ŋó₃ juɨ₅ ja₁të́'₂ dsa₂ Dsɨ₂con'₂ Nɨ₁mu₅ Mɨ₂dsi₄ 'Lag₄. Quian'₅₄ jág₁ jmei₅ arameo guë'₂, chei₂ Gólgota.
\v 18 Ja₁jaun₂ ca₂tion₃ dsa₂ ne₄ cróg₄, ján₃ bá₄ ca₂tion₃ guë́₄ dsa₂ on₃ dsa₂ sián'₂ co₂lë₅ quian'₅₄ Jesús, jma₃jan₂ lia'₂ ca₂ton₂ quió'₅; 'ŋiog₅ guë'₂ Jesús të₁toin₅₄ dsi₂jo₂.
\p 
\v 19 Jaun₂ ca₂tióng₃ Pilato letras dsi₄ cróg₄ co₂'nió'₄ a₂juá'₂: “JESÚS CHAN₂ NAZARET, RAG₅₄ QUIÁN₅ DSA₂ JUDÍOS.”
\m 
\v 20 Jaun₂ juɨn₅ dsa₂ judíos ca₂'ɨ́₂ letras jaun₂, ia₁ ma₂quián₅ chei'₅₄ juɨg₂ ciudad bá₄ ja₁ca₂tion₃ dsa₂ cróg₄ Jesús jaun₂. Jme₁chi₁ton₅ letras jaun₂ quian'₅₄ jág₁ jmei₅ hebreo, griego, quian'₅₄ jág₁ jmei₅ latín në́₃.
\v 21 'Uɨg₅₄ jaun₂, ca₂juá'₂ juɨg₅₄ jme₂dsa₂ quian'₅₄ dsa₂ judíos, ca₂tsɨ́'₃ Pilato:
\p ―Tsá₃ lë₁taun₂ “Rag₅₄ quián₅ dsa₂ judíos”; ja₂lɨn₃ guë́₄ dse₃ taun'₅₄“I₂juá'₂ a₂lɨ́n₅ Rag₅₄ quián₅ dsa₂ judíos.”
\p 
\v 22 La₁ ca₂ŋag₃ Pilato:
\p ―Juɨ₁lia'₂ a₂ma₂në₂táun₂ jniá₂, co₂në₅ ma₂në₂táun₂.
\p 
\v 23 Jme₁ma₂ca₂lë₃ tion₅ 'lióg₂ Jesús ne₄ cróg₄, jaun₂ ca₂can₃ tsɨ₁'mɨ'₂ quió'₅ Jesús, jaun₂ ca₂jmo₃ quén₂ dso'₅₄, jma₃jan₂ 'lióg₂ lia'₂ ca₂dso'₅₄. Ján₃ bá₄ le₂jaun₂ ca₂can₃ nɨ₁tsɨn'₅₄ Jesús. La₁ nɨ₁tsɨn'₅₄ në́₃, tsá₃ jme₁rë₂'me₅; jme₁lë́₄ caun₂ 'mɨ'₂ con'₂ lë́₅ ca₂ta₃ dsa₂, ta₁caun₂.
\p 
\v 24 Jaun₂ ca₂juá'₂ 'lióg₂ ca₂tsɨ́'₃ rɨin'₅₄:
\p ―Co₂ŋei'₅₄ tió'₅ tsá₃ guéi₃. Në₃ i₁cáu₂ co₂ŋei'₅₄ dsí₂ suerte, o₁ne₄ 'ein₂ tɨn₅₄.
\p Jaun₂ le₂në₅ ca₂rë₃ti₃ jág₁ a₂rë₂ton₅ ne₄ Si₂ a₂juá'₂:
\q1 Qui₂ca₂dsión'₂ dsa₂ tsɨ́n'₅ jniá₂ quiain'₅₄ rɨin'₅₄,
\q2 ca₂co₃ ca₂dsi₂ suerte o₁ne₄ 'ein₂ tɨn₅₄.\f + \fr 19:24 \ft Salmo 22:18.\f*
\m Le₂në₅ bá₄ ca₂jmo₃ 'lióg₂ 'éi₂ tioin'₅₄.
\p 
\v 25 La₁ chog₅₄ Jesús në́₃, jaun₂ bá₄ jme₁chéin'₄ cau₅ cróg₄, lia'₂ jma₃quian'₅₄ 'io₅₄ rɨin'₅₄, quiain'₅₄ María quián₅ Cleofas, quian'₅₄ María chan₂ Magdala në́₃.
\v 26 Jme₁ca₂jɨ́n₂ Jesús chog₅₄, quiain'₅₄ chi'₂ dsɨ₂guia₃-tɨ́n₂ i₂ŋɨ́₄ lë₃ jme₁'nioi₃ 'éi₂, chéin'₅ cau₅, jaun₂ ca₂juá'₂ ca₂tsɨ́'₃ chog₅₄:
\p ―'Io₅₄, në₅ chén'₅ ja₂ŋí'₂.
\p 
\v 27 Jaun₂ guë́₄ ca₂juá'₂ ca₂tsɨ́'₃ dsɨ₂guia₃-tɨ́n₂ 'éi₂:
\p ―Në₅ chén'₅ chog'₂.
\p Ca₂le₃ jmɨg₄ jaun₂, ca₂guei₃ chi'₂ dsɨ₂guia₃-tɨ́n₂ 'éi₂ ca₂guein₃ María dsi₂néi₂ quió'₅.
\s1 Ca₂jon₃ Jesús
\r (Mateo 27:45-56; Marcos 15:33-41; Lucas 23:44-49)
\p 
\v 28 Cang₂ guë́₄ jaun₂ në́₃, ia₁ jme₁ma₂ŋi₅ bá₄ Jesús a₂ma₂ca₂rë₃'ŋia₅ ca₂le₃jë́₃, ia₁jaun₂ le₃ti₃ jág₁ tio'₅₄ ne₄ Si₂, ca₂juá'₂:
\p ―Jmɨg₂ i₁guɨ'₁ jniá₂.
\p 
\v 29 Jë₄ jaun₂ jme₁chí'₄ caun₂ nɨ₁dsɨg₁ a₂'a₄ jmɨg₂ dsi'₃, jaun₂ ca₂tiá₂ dsa₂ caun₂ nɨ₁jau₂ 'ŋió'₃, ca₂guioin₃ quian'₅₄ jmɨg₂ dsi'₃ jaun₂. Jaun₂ ca₂chi₃dsí₂ dsa₂ nei'₅₄ caun₂ nɨ₁'ma₂ hisopo jaun₂ ca₂chóg'₃ dsa₂ të₂ mɨ₂'o₄ Jesús.
\v 30 Jme₁ma₂në₂'én'₂ jmɨg₂ dsi'₃ jaun₂, jaun₂ ca₂juá'₂:
\p ―Ma₂ca₂lë₃.
\p Jaun₂ në́₃ ca₂sióg₂ mɨ₂dsi₅₄, ca₂jáng'₃ jme₂dsí₂ quió'₅.
\s1 Ca₂'ág'₂ 'lióg₂ ŋi₁chen'₂ quió'₅ mɨ₂dsɨ₂con₂ Jesús
\p 
\v 31 Jme₁lë́₄ jmɨg₄ a₂jmo₅ dsa₂ co₂jŋia₅₄ Jmɨg₄ Të₂'ɨn₅₄, jaun₂ tsá₃ 'nio₃ dsa₂ judíos jua'₅₄ lia'₂ ma₂le₁ton₅ jaun₂ nɨ₁ŋɨ₁₂ dso'₂ cróg₄ jmɨg₄ sa₅₄, ia₁ jmɨg₄ juë'₂ lɨn₃ bá₄ sa₅₄ jaun₂. 'Uɨg₅₄ jaun₂ në́₃ ca₂mɨ₃ ne₄ Pilato a₂chein₃ 'lióg₂ a₂qui₂dsɨ₃jio₅₄ dsɨ₂tag₄ 'éi₂, jaun₂ guë́₄ të₂.
\v 32 Jaun₂ në́₃ ca₂i₁len₅₄ 'lióg₂ ca₂i₁jio₂ dsɨ₂tag₄ i₂le₂'uɨg₅₄; ján₃ bá₄ le₂jaun₂ ca₂jmo₃ quian'₅₄ i₂jan₂ i₂chi₁ton₅ cróg₄ con₂ Jesús.
\v 33 La₁ jme₁ca₂jme₃quiáin₃ con₂ Jesús, ca₂jág₃ jme₁ma₂join₂₃ bá₄; 'uɨg₅₄ jaun₂ në́₃ tsá₃ ma₂ca₂jió₃ dsɨ₂tag₄ 'éi₂.
\v 34 La₁ ca₂'ág'₂ jan₂ 'lióg₂ mɨ₂dsɨ₁con₂ Jesús quian'₅₄ ŋi₁chen'₂ quió'₅, jaun₂ dsɨ₂juɨ₅ le₂jaun₂ ca₂'io₂ jmɨ₂ quian'₅₄ jmɨg₂.
\v 35 Jan₂ dsa₂ i₂ca₂të́₂ ne₄ i₂jáng'₅ jág₁ dsau₅ la₂; ton'₂ tí₅ bá₄ jág₁ dsau₅ a₂jáng'₅. Ján₃ bá₄ ŋi₅ dsa₂ 'éi₂ a₂juá'₂ jág₁ tí₅ të₃dsón'₂, ia₁jaun₂ le₃'én'₂ 'nia'₂ ján₃.
\v 36 Ia₁ a₂ca₂lë₃ la₂, ca₂lë₃ ia₁jaun₂ le₃ti₃ jág₁ a₂rë₂ton₅ ne₄ Si₂ a₂juá'₂: “Lia'₂ 'i₁caun₂ mu₄ 'éi₂ tsá₃ qui₃jio₃ dsa₂.”\f + \fr 19:36 \ft Éxodo 12:46; Números 9:12; Salmo 34:20.\f*
\v 37 Le₂jaun₂ guë'₂ táng₃ juá'₂ ne₄ Si₂ ja₁siá'₂: “Jág₂ dsa₂ jɨ́in₂ 'éi₂ i₂ca₂'ág'₂ dsa₂ quió'₅.”\f + \fr 19:37 \ft Zacarías 12:10.\f*
\s1 Ca₂'on₃ Jesús
\r (Mateo 27:57-61; Marcos 15:42-47; Lucas 23:50-56)
\p 
\v 38 Cang₂ guë́₄ jaun₂ në́₃, ca₂mɨ₃ jan₂ dsa₂ i₂chen₂ José, i₂chan₂ juɨg₂ Arimatea, i₂jme₁lɨ́n₄ jan₂ dsa₂ i₂quián₅ Jesús, la₁ia₁ jme₁'éin₂ con'₂ të₃co'₅₄ bá₄, ia₁ a₂gain₃ dsa₂ judíos; ca₂mɨ₃ Së́₄ 'éi₂ ne₄ Dsi₄má'₂ Pilato a₂con₂ nɨ₁ŋɨ₁ 'lag₄ Jesús. Ca₂cuë₃ bá₄ Pilato jmɨg₄, jaun₂ ŋe₄ Së́₄ ca₂i₁sioin₅ 'lag₄, jaun₂ ca₂tág₃.
\v 39 Ján₃ bá₄ ca₂dsióg₃ Nicodemo i₂jme₁ca₂i₁dsia₂ jág₁ le₂jŋiá₅ quian'₅₄ Jesús a₂'uë₂. Jme₁quian₅ 'éi₂ con'₂ guióg₂-guiá₂ kilos mirra quian'₅₄ áloes a₂ma₂rë₂güɨ́n'₅.
\v 40 Jaun₂ ca₂tág₃ Së́₄ quiain'₅₄ Nicodemo ca₂tág₃ 'lag₄ ca₂lio₃ quian'₅₄ tsɨ₁'mɨ'₂ tióg₃ lia'₂ jma₃quian'₅₄ mɨ₂ro₂ jaun₂, lia'₂ jme₁lë́₄ tag₄ chí'₅ quió'₅ dsa₂ judíos a₂jme₁'óin₂ 'lag₄.
\v 41 Cau₅ ja₁ca₂tion₃ dsa₂ cróg₄ Jesús, jme₁lë́₄ caun₂ ja₁cha₂ nɨ₁'ma₂ a₂'ag₅ mɨ́g₂. Jaun₂ jë₄ jaun₂ jme₁dsi₅₄ caun₂ tau₂ 'ŋio₅ 'mɨ́₂ ja₁tsá₃ 'ein₂ jme₁ma₂ton'₂ dsa₂ 'i₁jan₂ 'lag₄.
\v 42 Jaun₂ 'uɨg₅₄ ia₁ a₂jme₁lë́₄ jmɨg₄ a₂jmo₃ dsa₂ judíos co₂jŋia₅₄ quió'₅, ton'₂ 'uɨg₅₄ ia₁ a₂jme₁lë́₄ ma₂quián₅ jaun₂ tau₂ 'ŋio₅, jaun₂ ja₁jaun₂ ca₂quio₅ Së́₄ quian'₅₄ Nicodemo ca₂quioin₂₃ Jesús.
\c 20
\s1 Ca₂jen'₅₄ Jesús
\r (Mateo 28:1-10; Marcos 16:1-8; Lucas 24:1-12)
\p 
\v 1 Jë₁le₂'uɨg₅₄ jmɨg₄ semana, ŋe₄ María chan₂ Magdala ja₁dsi₅₄ tau₂ 'ŋio₅, të₂ o₃'iog₂ të₃ qui₁né'₃ guë́₄ le₂jaun₂. Jaun₂ ca₂jág₃, jme₁ma₂rë₃jŋia'₅₄ bá₄ nɨ₁cang₁ 'o₄ tau₂ 'ŋio₅ jme₁dsióg₃.
\v 2 Jaun₂ në́₃ ca₂ŋái'₃ co₂chi'₅₄ ja₁jme₁'en₅₄ Si₂mu₅₄ Pe₄ quiain'₅ chi'₂ dsɨ₂guia₃-tɨ́n₂ jan₂ i₂ŋɨ́₄ lë₃ jme₁'nio₃ Jesús 'éi₂, jaun₂ ca₂juá'₂:
\p ―Ma₂në₂dsen₅ dsa₂ Te₁gui'₅₄ dsi₂néi₂ tau₂ 'ŋio₅ ja₁jme₁roin₂₃, jaun₂ tsá₃ ne₄ a₂já'₄ në₂quio₅ dsa₂.
\p 
\v 3 Jaun₂ në́₃ Pe₄ quian'₅₄ chi'₂ dsɨ₂guia₃-tɨ́n₂ jan₂ 'éi₂ ca₂'uɨin₂ jaun₂ i₃léin₂ ja₁dsi₅₄ tau₂ 'ŋio₅.
\v 4 Le₃oin₃ bá₄ i₃léin₂ co₂lë₅ co₂'ei₅; la₁ i₂jan₂ 'éi₂ ca₂ŋɨ₃ guë́₄ co₂chi'₅₄ con'₂ guë́₄ Pe₄, jaun₂ jŋiái₅ bá₄ ca₂dsióg₃ ja₁dsi₅₄ tau₂ 'ŋio₅.
\v 5 Jaun₂ ca₂jmo₃ i₁jɨ́in₂ ca₂ŋéi₃ ne₅₄, jaun₂ ca₂jág₃, jaun₂ bá₄ jme₁niog₅ tsɨ₁'mɨ'₂ tióg₃, la₁ia₁ tsá₃ ca₂'í₃ dsi₂néi₂.
\v 6 Jaun₂ guë́₄ ca₂dsióg₃ Si₂mu₅₄ Pe₄ chi₁co'₅₄ quió'₅, jaun₂ ca₂'í₃ dsi₂néi₂ tau₂ 'ŋio₅. Jaun₂ ca₂jág₃ 'éi₂ tsɨ₁'mɨ'₂ tióg₃: jaun₂ bá₄ jme₁niog₅ ja₁jaun₂;
\v 7 ján₃ bá₄ ca₂jág₃ pe₁guí₄ a₂ca₂lio₃ mɨ₂dsi₄ Jesús. La₁ tsá₃ jme₁ron₅ co₂lë₅ quian'₅₄ tsɨ₁'mɨ'₂ tióg₃ jaun₂; cau₅ bá₄ jme₁ron₅ jme₁rë₂jon'₅.
\v 8 Jaun₂ bá₄ ca₂'í₃ chi'₂ dsɨ₂guia₃-tɨ́n₂ jan₂ 'éi₂, i₂dsióg₃ le₂'uɨg₅₄; ca₂të́₂ ne₅₄, jaun₂ ca₂rë₃'éin₂.
\v 9 (Ia₁ tsá₃ jme₁ma₂ŋɨ́'₂ guë́₄ dsɨ́₅ jág₁ a₂chi₁ton₅ ne₄ Si₂, a₂tion₅₄ niog₅ jen'₅₄ Jesús jɨn₄ 'lag₄.)
\p 
\v 10 Jaun₂ në́₃, i₂len₃ bá₄ táng₃ chi'₂ dsɨ₂guia₃-tɨ́n₂ 'éi₂ quió'₅.
\s1 Ca₂jme₃jnia₅ Jesús ne₄ María chan₂ Magdala
\r (Marcos 16:9-11)
\p 
\v 11 La₁ jaun₂ bá₄ jme₁chén'₄ María ca₁'né₄ tau₂ 'ŋio₅, 'o₂₃. Të₁lia'₂ 'o₂₃ jaun₂, ca₂jmo₃ i₁jɨ́in₂ a₂ca₂jág₃ të₂le₃ 'ŋió'₃ tau₂ 'ŋio₅,
\v 12 jaun₂ ca₂jɨ́in₂ on₃ ángeles i₂le₁qui'₂ 'mɨ'₂ tiog₂, tiáin'₅ jë₄ jme₁ron₅ nɨ₁ŋɨ₁ Jesús; jan₂ jme₁guá₄ të₂le₃ ja₁lë́₄ chi₁gui'₂, i₂jan₂ guë'₂ ja₁jme₁lë́₄ a₃tag₅.
\p 
\v 13 Jaun₂ ca₂ŋag₃ ángeles ca₂ŋɨ́i'₃ María:
\p ―'Io₅₄, ¿'e₂ lë₃ 'au'₂?
\p Jaun₂ ca₂ŋag₃:
\p ―Ia₁ ma₂në₂te₃ bá₄ dsa₂ Te₁gui'₅₄ quiáng₃, jaun₂ tsá₃ guion₄ jniá₂ a₂já'₄ në₂quio₅ dsa₂.
\p 
\v 14 Jë₂ bá₄ ca₂'ŋiai₂ jág₁ në₅, jme₁ca₂jéin'₃, jaun₂ ca₂jɨ́in₂ Jesús jme₁chéin'₄; la₁ tsá₃ jaun₂ jme₁ŋi₅, Jesús bá₄ 'éi₂.
\p 
\v 15 Jaun₂ në́₃ ca₂ŋag₃ Jesús:
\p ―'Io₅₄, ¿'e₂ lë₃ 'au'₂ 'ne₂? ¿I₂'ein₂ 'nag'₂?
\p Jaun₂, ia₁ a₂lɨ́n₂ María a₂lɨ́n₅ 'éi₂ dsa₂ i₂jmo₅ 'í₁ 'uë₃ jaun₂, jaun₂ ca₂juá'₂:
\p ―Gui'₅₄, chi₂jua'₂ 'ne₂ ne₂te'₅₄, jua'₅₄ a₂já'₄ në₂quioin'₂, ia₁jaun₂ të₅₄ jniá₂.
\p 
\v 16 Jaun₂ ca₂juá'₂ Jesús:
\p ―¡María!
\p Jaun₂ ca₂jén'₃ María jaun₂ ca₂juá'₂ quian'₅₄ jág₁ jmei₅ hebreo:
\p ―¡Raboni! ―co₂'nió'₄ a₂juá'₂: Të₅ quiáng₃.
\p 
\v 17 Jaun₂ ca₂juá'₂ Jesús:
\p ―Tsá₃ lë₁jmá'₂ quió₃, ia₁ tsá₃ ma₂uɨ́g₂ guë́₄ jniá₂ ja₁con₂ Ŋe'₃. La₁ guan'₂ o₂chei'₅₄ rɨ́n'₃ jniá₂, a₂uɨ́g₂ jniá₂ ja₁con₂ Ŋe'₃, ja₁con₂ Ŋéi'₅ 'nia'₂ në́₃, ja₁con₂ Diú₄ quiáng₃, ja₁con₂ Diú₄ quián'₂ 'nia'₂ në́₃.
\p 
\v 18 Jaun₂ bá₄ ŋó₃ María chan₂ Magdala 'éi₂ ca₂i₁chi'₄ chi'₂ dsɨ₂guia₃-tɨ́n₂ a₂jme₁ma₂në₂jɨ́in₂ Te₁gui'₅₄, a₂jme₁ma₂në₂juá'₂ 'éi₂ jág₁ jaun₂.
\s1 Ca₂jme₃jnia₅ Jesús ne₄ chi'₂ dsɨ₂guia₃-tɨ́n₂
\r (Mateo 28:16-20; Marcos 16:14-18; Lucas 24:36-49)
\p 
\v 19 Jme₁ca₂nei₂ jë₁le₂'uɨg₅₄ jmɨg₄ semana jaun₂ në́₃, jme₁tion'₅₄ chi'₂ dsɨ₂guia₃-tɨ́n₂ le₁ŋɨi'₂, qui₂le₁jnág₅ 'né₅ ja₁tioin'₅₄, ia₁ a₂gain₃ dsa₂ judíos. Jaun₂ ca₂'í₃ Jesús, jaun₂ ca₂nau₂ dsi₂jo₂ quió'₅ 'éi₂, jaun₂ ca₂juá'₂:
\p ―Juɨ₁'ei₅ tei₄ 'au'₂ 'nia'₂.
\p 
\v 20 Jme₁ma₂ca₂juá'₂ le₂në₅, ca₂'ë₃ mɨ₂gu₂ quian'₅₄ mɨ₂dsɨ₁coin₂. Jaun₂ ca₂jmo₃ 'io'₂ chi'₂ dsɨ₂guia₃-tɨ́n₂ jme₁ca₂jɨ́in₂ Te₁gui'₅₄.
\p 
\v 21 Jaun₂ ca₂juá'₂ táng₃ Jesús:
\p ―Juɨ₁'ei₅ tei₄ 'au'₂ 'nia'₂. Juɨ₁lia'₂ ca₂chei₃ Ŋe'₃ jniá₂, ján₃ bá₄ le₂jaun₂ tsɨn₅₄ jniá₂ 'nia'₂.\f + \fr 20:21 \ft 'Nio'₂ ja₁ton₅ Juan 17:18.\f*
\p 
\v 22 Jaun₂ në́₃ ca₂jéi₂ dsí₂ ne₄ quió'₅ dsa₂ 'éi₂, jaun₂ ca₂juá'₂:
\p ―Guen'₅₄ 'nia'₂ Jme₂dsí₂ Jŋió₅.
\v 23 Chi₂jua'₂ 'ein₂ i₂ca₂'én'₃ 'nia'₂ dsáu₁, ma₂qui₂ca₂i₃'én₂ bá₄ dsáu₁ 'éi₂; chi₂jua'₂ 'ein₂ tsá₃ ca₂'én'₃ 'nia'₂ dsáu₁, të₃'ŋiá₄ dsáu₁ ja₁coin₂.
\s1 Jág₅ To₁má₄ jɨ́in₂ Te₁gui'₅₄ a₂ma₂ca₂jein'₅₄
\p 
\v 24 La₁ To₁má₄ në́₃, jan₂ chi'₂ dsɨ₂guia₃-tɨ́n₂ i₂të́'₂ dsa₂ Dsa₂ Tsɨn'₅₄, tsá₃ jme₁'ein₅₄ jë₄ quió'₅ rɨin'₅₄ lia'₂ con'₂ jme₁dsióg₃ Jesús.
\v 25 Jaun₂ lë₃, jme₁ca₂juá'₂ chi'₂ dsɨ₂guia₃-tɨ́n₂ rɨin'₅₄:
\p ―Ma₂në₂jɨn₄ jnia'₅₄ Te₁gui'₅₄.
\p La₁ To₁má₄ në́₃ ca₂juá'₂:
\p ―Në₁jua'₂ tsá₃ ca₂jág₃ jniá₂ léi₄ mɨ₂gu₂ ja₁ca₂i₃ba₅₄ mɨ₂ŋí₁, ca₂lia'₂ ca₂tiá₃ chi₁gu₃ tau₂ a₂ca₂lë₃ quian'₅₄ mɨ₂ŋí₁, ca₂lia'₂ ca₂tiá₃ mɨ₂gu₃ mɨ₂dsɨ₁coin₂, tsá₃ le₃'éng₂.
\p 
\v 26 Jŋia₃ jmɨg₄ cang₂ guë́₄ jaun₂, jme₁le₁ŋɨ'₂ táng₃ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅ caun₂ dsi₂néi₂, le₂jaun₂ guë́₄ në́₃ jme₁'en₅₄ To₁má₄ jë₄ quió'₅ 'éi₂. Jaun₂ në́₃, o₁jŋia'₅₄ qui₂le₁jnág₅ 'né₅ ja₁tioin'₅₄, ca₂'í₃ Jesús, ca₂nau₂ dsi₂jo₂ quió'₅ 'éi₂, jaun₂ ca₂juá'₂:
\p ―Juɨ₁'ei₅ tei₄ 'au'₂ 'nia'₂.
\p 
\v 27 Jaun₂ në́₃ ca₂juá'₂ ca₂tsɨ́'₃ To₁má₄:
\p ―'Ŋia₅ i₂tio'₂ chi₁gog'₂ ja₁lá₃, jag₄ mɨ₂gu₃; i₂tio'₂ gog'₂ mɨ₂dsɨ₁cong₂. Tsá₃ lë₁jmo₂ a₂tsá₃ 'éng'₂, juɨ₁le₂'éng'₂ bá₄.
\p 
\v 28 Jaun₂ në́₃ ca₂ŋag₃ To₁má₄:
\p ―¡Te₁gui'₅₄ quiáng₃, Diú₄ quiáng₃ në́₃!
\p 
\v 29 Jaun₂ ca₂juá'₂ Jesús:
\p ―Në₃ guë́₄ 'éng'₂ 'uɨg₅₄ ia₁ a₂në₂jag'₅₄ jniá₂. 'E₂ guë́₄ dsen₃ juɨ₁lia'₂ dsa₂ i₂tsá₃ ca₂jág₂, la₁ 'éin₂ bá₄.
\s1 Ta₁ a₂quí'₅ si₂ la₂
\p 
\v 30 Jaun₂ në́₃, 'lióng₂ bá₄ léi₄ juë'₂ siá'₂ ca₂jmo₃ Jesús ne₄ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅ a₂tsá₃ tio'₅₄ ne₄ si₂ la₂.
\v 31 La₁ia₁ qui₂rë₂ton₅ a₂la₂, ia₁jaun₂ le₃'én'₂ 'nia'₂ a₂lɨ́n₅ Jesús I₂rë₂'ɨ́n₁ quián₅ Diú₄, ton'₂ lɨ́in₅ Ja₁ŋi'₅₄ Diú₄, ia₁jaun₂ jë₁ma₂qui₂ca₂rë₃'én'₂ 'nia'₂, le₃chan'₂ bá₄ 'nia'₂ co₂tan₅₄ le₃quió'₅ 'éi₂.
\c 21
\s1 Ca₂jme₃jnia₅ Jesús ne₄ guion₃ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅
\p 
\v 1 Cang₂ guë́₄ jaun₂, ca₂jme₃jnia₅ táng₃ Jesús ne₄ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅ chei'₅₄ Jmɨ₁ŋí'₄ Tiberias.\f + \fr 21:1 \ft o₃, Jmɨ₁ŋí'₄ Galilea.\f* Le₂la₂ bá₄ ca₂lë₃:
\p 
\v 2 Jme₁tion'₅₄ co₂lë₅ Si₂mu₅₄ Pe₄; To₁má₄, i₂të́'₂ dsa₂ Dsa₂ Tsɨn'₅₄; Natanael i₂chan₂ juɨg₂ Caná ja₁tén₄ 'uë₃ Galilea; le₃on₃ ja₁ŋi'₅₄ Zebedeo në́₃; quiain'₅₄ on₃ guë́₄ chi'₂ dsɨ₂guia₃-tɨ́n₂ sián'₂ quián₅ Jesús.
\v 3 Jaun₂ ca₂juá'₂ Si₂mu₅₄ Pe₄:
\p ―Nei₅₄ i₁cháng'₃ ju₄.
\p Jaun₂ ca₂ŋag₃ 'éi₂:
\p ―Ján₃ bá₄ dsau₅₄ jnia'₅₄ quian'₅₄ 'ne₂.
\p Jaun₂ i₃léin₂, ca₂uɨ́g₂ 'ŋió'₃ caun₂ tsɨ₁mu₅, la₁ a₂'uë₂ jaun₂ tsá₃ ju₄ ca₂join₃ 'i₁jan₂.
\p 
\v 4 Jme₁ca₂jnia₃ táng₃ jaun₂, jaun₂ jme₁chén'₄ Jesús chei'₅₄ jmɨ₁ŋí'₄, la₁ tsá₃ jaun₂ ŋi₅ chi'₂ dsɨ₂guia₃-tɨ́n₂ jŋia'₅₄ Jesús bá₄ 'éi₂.
\v 5 Jaun₂ në́₃ ca₂juá'₂ Jesús:
\p ―'Nia'₂ chi'₂, ¿tsa₁ ju₄ chan₂ quián'₂ 'nia'₂?
\p Jaun₂ ca₂ŋag₃ 'éi₂:
\p ―Lia'₂ 'i₁jan₂.
\p 
\v 6 Jaun₂ në́₃ ca₂juá'₂ Jesús:
\p ―Tiong₂ 'nia'₂ 'má₅ quiáng'₂ të₂le₃ gu₂ ne₁ tsɨ₁mu₅, jaun₂ join'₅₄ 'nia'₂.
\p Jaun₂ le₂jaun₂ bá₄ ca₂jmo₃. Jme₁co₂lág₂ jaun₂ tioin'₅₄ tsá₃ lé₂ dsí₃ tsɨ₁'má₅ dsi₂jmɨg₂, ia₁ a₂ŋɨ́₄ lë₃ juɨn₅ i₁ju₁ jme₁tion'₅₄ 'ŋió'₃.
\p 
\v 7 Jaun₂ në́₃ ca₂juá'₂ chi'₂ dsɨ₂guia₃-tɨ́n₂ i₂jme₁'nio₃ Jesús guë́₄ lɨn₃, ca₂tsɨ́'₃ Pe₄:
\p ―¡Te₁gui'₅₄ bá₄ ó₃!
\p Jë₂ bá₄ con'₂ ca₂nág₂ Si₂mu₅₄ Pe₄, Te₁gui'₅₄ bá₄ 'éi₂, ca₂quɨ́'₂ tsɨn'₅₄ jang₄ le₃co'₅₄ (ia₁ jme₁ma₂në₂jŋiá'₂ a₂jme₁jmo₃ ta₁) jaun₂ ca₂tiáin₂ dsi₂jmɨg₂.
\v 8 Chi'₂ dsɨ₂guia₃-tɨ́n₂ rɨin'₅₄ guë'₂ në́₃, ca₂dsi₃lein₃ bá₄ të₂ chei'₅₄ jmɨ₁ŋí'₄ quian'₅₄ tsɨ₁mu₅ qui₂tsɨ₂cuɨ́n'₅ tsɨ₁'má₅, ca₂lia'₂ rë₂can'₂ ju₄. Ia₁ tsá₃ uɨ́ng₂ jme₁tioin'₅₄ ja₁lë́₄ chei'₅₄ jmɨ₁ŋí'₄: con'₂ caun₂ 'ŋiá₂-láu₂ metros bá₄ jme₁tí₄.
\v 9 Jme₁ca₂sióin₃ 'uë₃ në́₃, ca₂jág₃ a₂ma₂niog₅ si₂ tá'₃, ján₃ bá₄ jme₁ma₂dsɨ́n₂ jan₂ ju₄ ne₄ si₂; ján₃ bá₄ jme₁te₁'i₁ i₁ŋí'₄ në́₃.
\p 
\v 10 Jaun₂ ca₂juá'₂ Jesús:
\p ―Jŋia₅ jan₂-on₃ ju₄ i₂lia'₂ në₂chan'₂ 'nia'₂.
\p 
\v 11 Jaun₂ ca₂uɨ́g₂ Si₂mu₅₄ Pe₄ guei'₅₄ tsɨ₁mu₅. Jaun₂ ca₂tsë́'₃ tsɨ₁'má₅ ca₂të₂ chei'₅₄ jmɨg₂ lia'₂ rë₂can'₂ tion'₅₄ ju₄ ca₁can'₅₄. Con'₂ caun₂ 'ŋiá₂-lón₂ rë₂dsɨ́₂ të₂láu₃-guia₃-ún₂ (153) ju₄ jme₁tion'₅₄. La₁ o₁jŋia'₅₄ la₂ juɨn₅ ju₄ jme₁tion'₅₄, tsá₃ ca₂gag₂ bá₄ guë́₄ tsɨ₁'má₅.
\v 12 Jaun₂ ca₂juá'₂ Jesús ca₂tsɨ́'₃ chi'₂ dsɨ₂guia₃-tɨ́n₂:
\p ―I₂nó'₅ 'nia'₂ i₂qué'₂ má₃ të₂ o₃'iog₂.
\p Jaun₂ lia'₂ 'i₁jan₂ chi'₂ dsɨ₂guia₃-tɨ́n₂ tsá₃ tiá₂ dsɨ́₅ ŋag₃ i₂'ein₂ 'éi₂, ia₁ ŋi₅ bá₄ jaun₂ Te₁gui'₅₄ bá₄ 'éi₂.
\v 13 Jaun₂ në́₃ ca₂jme₃quián₃ Jesús, ca₂can₃ i₁ŋí'₄, jaun₂ ca₂cuë́'₃ chi'₂ dsɨ₂guia₃-tɨ́n₂. Ján₃ bá₄ le₂jaun₂ ca₂jmo₃ quian'₅₄ ju₄.
\v 14 A₂në₅ jë₁ca₂të́₂ 'nag'₂ ráun₂ a₂ca₂jme₃jnia₅ Jesús ne₄ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅ cang₂ jme₁ca₂jein'₅₄ ja₁jme₁rë₂'lɨin₅₄.
\s1 Dsia₅ Jesús jág₁ quian'₅₄ Si₂mu₅₄ Pe₄
\p 
\v 15 Cang₂ jme₁ca₂lë₃ guë́'₅ má₃ të₂ o₃'iog₂, ca₂ŋag₃ Jesús ca₂ŋɨ́i'₃ Si₂mu₅₄ Pe₄:
\p ―Si₂mu₅₄, ja₁ŋi'₅₄ Juan₅₄,\f + \fr 21:15 \ft o₃, ja₁ŋi'₅₄ Jonás.\f* ¿dsau₅ 'nióg'₃ jniá₂ lia'₂ con'₂ guë́₄ dsa₂ tión₂ la₂?
\p Jaun₂ ca₂ŋag₃ Pe₄:
\p ―Ján₅, Te₁gui'₅₄. Ŋi'₅₄ bá₄ 'ne₂ jaun₂, a₂'nió₃ jniá₂ 'ne₂.
\p Jaun₂ ca₂juá'₂ Jesús:
\p ―Jme₁tan₅₄ guein₂ já'₂ cha'₂ quiáng₃ jaun₂.
\p 
\v 16 Jaun₂ ca₂ŋag₃ táng₃ Jesús jë₁ca₂të́₂ táng₃ ráun₂:
\p ―Si₂mu₅₄, ja₁ŋi'₅₄ Juan₅₄, ¿'nióg'₃\f + \fr 21:16 \ft griego: W0Iagapeo (juɨ₁lia'₂ 'a₂ lia'₂ 'nio₃ Diú₄ dsa₂ mɨ₂güɨ́g₃).\f* jniá₂?
\p Jaun₂ ca₂ŋag₃ Pe₄:
\p ―Ján₅, Te₁gui'₅₄. Ŋi'₅₄ bá₄ 'ne₂ jaun₂ a₂'nió₃ jniá₂ 'ne₂.
\p Jaun₂ ca₂juá'₂ Jesús:
\p ―Jmo₄ 'í₁ já'₂ cha'₂ bë'₅₄ quiáng₃ jaun₂.
\p 
\v 17 Jaun₂ ca₂ŋag₃ táng₃ Jesús jë₁ca₂të́₂ 'nag'₂ ráun₂:
\p ―Si₂mu₅₄, ja₁ŋi'₅₄ Juan₅₄, ¿'nióg'₃ jniá₂?
\p Jaun₂ ca₂'í₃ quɨ'₂ dsɨ́₅ Pe₄ ia₁ ca₂ŋag₃ Jesús jë₁ca₂të́₂ 'nag'₂ ráun₂, “¿'nióg'₃ jniá₂?.” Jaun₂ ca₂juá'₂:
\p ―Te₁gui'₅₄, ca₂le₃jë́₃ bá₄ ŋi'₅₄ 'ne₂. Ŋi'₅₄ bá₄ 'ne₂ jaun₂ a₂'nió₃\f + \fr 21:17 \ft griego: W0Ifileo (juɨ₁lia'₂ 'a₂ lia'₂ 'nio₃ dsa₂ mɨ₂güɨ́g₃ rɨn'₅₄ a₂mei₅₄ quiáin₅).\f* jniá₂ 'ne₂.
\p Jaun₂ ca₂juá'₂ Jesús:
\p ―Jme₁tan₅₄ já'₂ cha'₂ bë'₅₄ quiáng₃ jaun₂.
\v 18 A₂dsɨ₂jó'₃ juá'₅ jniá₂, lia'₂ con'₂ jme₁lɨ́ng'₄ guë́₄ dsa₂ chi'₂, jme₁tɨng'₂ jme₁quɨ́'₂ tsɨ́ng'₂, jaun₂ jme₁góg'₂ a₂já'₄ 'niog'₂ gog'₅₄; la₁ia₁ jë₁ma₂lɨ́ng'₅ jan₂ dsa₂ ma₂guen'₂, jaun₂ nei'₅₄ gog'₂, jaun₂ i₂sián'₂ bá₄ quei'₃ tsɨ́ng'₂, jaun₂ dsɨ₃jiog₃ ja₁tsá₃ 'niog'₂ gog'₅₄.
\p 
\v 19 Jme₁ca₂juá'₂ Jesús le₂në₅, ca₂jmo₃ jág₁ a₂'ë₂₃ 'e₂ ne₅₄ 'mú₃ a₂'i₄ 'éi'₃ dsɨ₃ŋɨ́₂ Pe₄, a₂jme₃jniai₂₃ a₂jlán'₁ Diú₄. Jaun₂ ca₂juá'₂ táng₃ ca₂tsɨ́'₃ Pe₄:
\p ―¡'Éin₃ jniá₂!
\s1 Chi'₂ dsɨ₂guia₃-tɨ́n₂ i₂'nió₄ guë́₄ quián₅ Jesús
\p 
\v 20 Jme₁ca₂jén'₃ Pe₄ le₃ca'₃, ca₂jág₃ já₅ chi₁co'₅₄ quió'₅, chi'₂ dsɨ₂guia₃-tɨ́n₂ i₂'nio₃ Jesús guë́₄ lɨn₃; chi'₂ dsɨ₂guia₃-tɨ́n₂ 'éi₂ i₂jme₁guá₄ cau₅ le₃jén'₃ quió'₅ Jesús ja₁ca₂guë́'₃ má₃ të₂le₃ ca₂nei₂, ján₃ bá₄ 'éi₂ i₂ca₂ŋag₃ ca₂ŋɨ́i'₃ Jesús, jme₁ca₂juá'₂: “Te₁gui'₅₄, ¿i₂'ein₂ 'éi₂ i₂jáng'₂ quiáng'₂?”
\v 21 Jaun₂ jme₁ca₂jág₃ Pe₄ ca₂jɨ́in₂ 'éi₂, ca₂ŋag₃ ca₂ŋɨ́i'₃ Jesús:
\p ―Te₁gui'₅₄, i₂la₂ guë'₂: ¿'e₂ jén'₄?
\p 
\v 22 Jaun₂ ca₂ŋag₃ Jesús:
\p ―Chi₂jua'₂ 'nio₃ jniá₂ a₂chan₂ i₂në₅ ca₂lia'₂ jë₁ma₂guión'₃ táng₃ jniá₂, ¿'e₂ bá₄ 'uɨg₅₄ 'ne₂ 'ɨ₅ 'au'₂? La₁ia₁ 'ne₂ 'éin₃ jniá₂.
\p 
\v 23 Jaun₂ në́₃ ca₂i₃'ag₅₄ jág₁ në₅ jɨn₄ rɨin'₅₄ a₂tsá₃ jón₂ chi'₂ dsɨ₂guia₃-tɨ́n₂ 'éi₂. La₁ia₁ on₃jua'₅₄ jaun₂ ca₂juá'₂ Jesús a₂tsá₃ jón₂ 'éi₂; a₂jaun₂ bá₄ ca₂juá'₂: “Chi₂jua'₂ 'nio₃ jniá₂ a₂chan₂ i₂në₅ ca₂lia'₂ jë₁ma₂guión'₃ jniá₂ táng₃, ¿'e₂ bá₄ 'uɨg₅₄ 'ne₂ 'ɨ́₅ 'au'₂?”
\p 
\v 24 Chi'₂ dsɨ₂guia₃-tɨ́n₂ 'éi₂ bá₄ la₂, i₂jáng'₅ jág₁ dsau₅ 'a₂ lia'₂ ca₂lë₃, i₂ca₂tó'₂ jág₁ la₂ ne₄ si₂ në́₃. Jaun₂ ne₄ bá₄ jniog₄, a₂tí₅ bá₄ jág₁ dsau₅ a₂jáng'₅ 'éi₂.
\p 
\v 25 Ján₃ bá₄ cha₂ 'lióng₂ a₂siá'₂ a₂ca₂jmo₃ Jesús; jua'₅₄ mei'₂ guë́₃ dsɨ₃to'₅₄ ne₄ si₂ le₂caun₂ le₂caun₂, ca₂lia'₂ jŋia'₅₄ ta₁caun₂ mɨ₂güɨ́g₃ bá₄ tsá₃ jme₁'éi'₄ si₂ jua'₅₄ ca₂'uë́'₃ dsa₂, lɨ́n₂ jniá₂.\f + \fr 21:25 \ft A₂lɨn₅₄ chog₅₄ si₂ juá'₂ ján₃: “A₂méi₃.” \f*
\p Co₂në₅.
