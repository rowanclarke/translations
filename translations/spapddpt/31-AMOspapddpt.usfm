\v 1 \w Vi|strong="H7200"\w* \w a|strong="H3068"\w* \nd ʼAdonay\nd* \w en|strong="H5921"\w* pie \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w altar|strong="H4196"\w*, \w y|strong="H5921"\w* dijo: \wj Golpea \+w los|strong="H5921"\+w* capiteles \+w para|strong="H5921"\+w* \+w que|strong="H3808"\+w* \+w se|strong="H5921"\+w* estremezcan \+w las|strong="H5921"\+w* columnas. Destrózalos \+w sobre|strong="H5921"\+w* \+w las|strong="H5921"\+w* \+w cabezas|strong="H7218"\+w* \+w de|strong="H5921"\+w* \+w todos|strong="H3605"\+w*. \+w Mataré|strong="H2026"\+w* \+w a|strong="H3068"\+w* \+w espada|strong="H2719"\+w* \+w hasta|strong="H5921"\+w* \+w el|strong="H5921"\+w* último \+w de|strong="H5921"\+w* \+w ellos|strong="H5921"\+w*. \+w No|strong="H3808"\+w* habrá \+w quien|strong="H3605"\+w* huya \+w o|strong="H3068"\+w* \+w escape|strong="H4422"\+w*.\wj*  
