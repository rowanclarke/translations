\p
\v 22 \w Todos|strong="H3605"\w* \w estos|strong="H1992"\w*, \w escogidos|strong="H1305"\w* para vigilar \w las|strong="H1992"\w* puertas, eran 212 cuando \w fueron|strong="H1732"\w* contados según \w el|strong="H3605"\w* orden de \w sus|strong="H1992"\w* familias en \w sus|strong="H1992"\w* \w aldeas|strong="H2691"\w*, \w a|strong="H3068"\w* quienes \w David|strong="H1732"\w* y \w el|strong="H3605"\w* \w vidente|strong="H7200"\w* \w Samuel|strong="H8050"\w* constituyeron en \w su|strong="H1992"\w* oficio.  
\v 23 \w Así|strong="H1992"\w* \w ellos|strong="H1992"\w* \w y|strong="H5921"\w* \w sus|strong="H1992"\w* \w hijos|strong="H1121"\w* eran porteros \w por|strong="H5921"\w* \w turnos|strong="H4931"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w Casa|strong="H1004"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, es decir, \w la|strong="H5921"\w* \w Casa|strong="H1004"\w* \w del|strong="H5921"\w* Tabernáculo.  
\v 24 \w Estaban|strong="H1961"\w* \w los|strong="H1961"\w* \w porteros|strong="H7778"\w* en \w los|strong="H1961"\w* cuatro puntos: \w hacia|strong="H5045"\w* el \w oriente|strong="H4217"\w*, el occidente, el \w norte|strong="H6828"\w* y el sur.  
\v 25 Sus hermanos \w que|strong="H3117"\w* vivían \w en|strong="H5973"\w* las \w aldeas|strong="H2691"\w* llegaban \w cada|strong="H3117"\w* \w siete|strong="H7651"\w* \w días|strong="H3117"\w* \w para|strong="H5973"\w* estar \w con|strong="H5973"\w* ellos según su turno,  
\v 26 \w porque|strong="H3588"\w* \w los|strong="H1992"\w* cuatro \w porteros|strong="H7778"\w* \w principales|strong="H1368"\w*, \w que|strong="H3588"\w* \w eran|strong="H1961"\w* \w levitas|strong="H3881"\w*, \w estaban|strong="H1961"\w* \w en|strong="H5921"\w* servicio permanente \w a|strong="H3068"\w* cargo \w de|strong="H5921"\w* \w las|strong="H1992"\w* \w cámaras|strong="H3957"\w* \w y|strong="H3588"\w* \w de|strong="H5921"\w* \w los|strong="H1992"\w* tesoros \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w Casa|strong="H1004"\w* \w de|strong="H5921"\w* \nd ʼElohim\nd*.  
