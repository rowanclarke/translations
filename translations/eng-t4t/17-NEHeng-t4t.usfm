\p \w They|strong="H5921"\w* \w immediately|strong="H6965"\w* replied, “\w Let|strong="H5046"\w*’s \w start|strong="H2388"\w* \w rebuilding|strong="H1129"\w*!” \w So|strong="H6965"\w* \w they|strong="H5921"\w* \w started|strong="H6965"\w* \w to|strong="H5921"\w* \w do|strong="H3027"\w* \w this|strong="H1931"\w* \w good|strong="H2896"\w* \w work|strong="H1697"\w*.   
\p
\v 19 \w But|strong="H8085"\w* \w when|strong="H8085"\w* \w Sanballat|strong="H5571"\w*, \w Tobiah|strong="H2900"\w*, \w and|strong="H4428"\w* Gershom \w the|strong="H5921"\w* \w Arab|strong="H6163"\w* \add king of the Kedar region\add* \w heard|strong="H8085"\w* \w about|strong="H5921"\w* \w what|strong="H4100"\w* \w we|strong="H3068"\w* planned \w to|strong="H6213"\w* \w do|strong="H6213"\w*, \w they|strong="H5921"\w* \w made|strong="H6213"\w* fun \w of|strong="H4428"\w* \w us|strong="H5921"\w* \w and|strong="H4428"\w* ridiculed \w us|strong="H5921"\w*. \w They|strong="H5921"\w* \w said|strong="H1697"\w*, “\w What|strong="H4100"\w* \w is|strong="H2088"\w* \w this|strong="H2088"\w* \w work|strong="H6213"\w* \w that|strong="H8085"\w* \w you|strong="H5921"\w* \w are|strong="H1697"\w* \w doing|strong="H6213"\w*? \w Are|strong="H1697"\w* \w you|strong="H5921"\w* \w rebelling|strong="H4775"\w* \w against|strong="H5921"\w* \w the|strong="H5921"\w* \w king|strong="H4428"\w* \add again\add*?” [RHQ]   
\p
\v 20 \w But|strong="H7725"\w* \w I|strong="H1697"\w* replied, “\w Our|strong="H5650"\w* \w God|strong="H8064"\w* \add who is/rules\add* \w in|strong="H5650"\w* \w heaven|strong="H8064"\w* \w will|strong="H5650"\w* \w help|strong="H6965"\w* \w our|strong="H5650"\w* plans \w to|strong="H7725"\w* \w succeed|strong="H6743"\w*. \w But|strong="H7725"\w* \w as|strong="H1697"\w* \w for|strong="H3389"\w* \w you|strong="H7725"\w*, \w you|strong="H7725"\w* \w have|strong="H5650"\w* \w no|strong="H6965"\w* \w right|strong="H6666"\w* \w to|strong="H7725"\w* decide \w anything|strong="H1697"\w* \w about|strong="H1697"\w* \w this|strong="H1931"\w* \w city|strong="H1931"\w*, \w because|strong="H1697"\w* \w you|strong="H7725"\w* \w have|strong="H5650"\w* \w not|strong="H7725"\w* participated \w in|strong="H5650"\w* \w what|strong="H1697"\w* \w has|strong="H5650"\w* \w happened|strong="H1697"\w* \w in|strong="H5650"\w* \w this|strong="H1931"\w* \w city|strong="H1931"\w* \w in|strong="H5650"\w* previous years.”   
\c 3  
\s1 They rebuilt the wall around Jerusalem  
\p
\v 1  \add ◄This is a list/These are the names► of the people who helped to rebuild the wall around Jerusalem\add*. Eliashib \w the|strong="H1129"\w* Supreme \w Priest|strong="H3548"\w* \w and|strong="H6965"\w* \w the|strong="H1129"\w* other \w priests|strong="H3548"\w* began \w to|strong="H5704"\w* \w rebuild|strong="H1129"\w* \w it|strong="H5704"\w* \w at|strong="H5975"\w* \w the|strong="H1129"\w* \w Sheep|strong="H6629"\w* \w Gate|strong="H8179"\w*. \w They|strong="H1992"\w* \w also|strong="H1992"\w* put \w the|strong="H1129"\w* \w gates|strong="H8179"\w* \w in|strong="H5975"\w* \w their|strong="H1992"\w* \w places|strong="H6942"\w*. \w They|strong="H1992"\w* \w built|strong="H1129"\w* \w the|strong="H1129"\w* wall \w as|strong="H5704"\w* \w far|strong="H5704"\w* \w as|strong="H5704"\w* \w the|strong="H1129"\w* \w Tower|strong="H4026"\w* \w of|strong="H8179"\w* 100 Soldiers \w and|strong="H6965"\w* \add further north\add* \w to|strong="H5704"\w* \w the|strong="H1129"\w* \w Tower|strong="H4026"\w* \w of|strong="H8179"\w* \w Hananel|strong="H2606"\w*, \w and|strong="H6965"\w* \w they|strong="H1992"\w* \w dedicated|strong="H6942"\w* \w it|strong="H5704"\w* \w to|strong="H5704"\w* God.  
\v 2 \w Next|strong="H5921"\w* \w to|strong="H5921"\w* \w them|strong="H5921"\w*, \add beyond the Tower of Hananel,\add* \w men|strong="H1121"\w* \w from|strong="H5921"\w* \w Jericho|strong="H3405"\w* \w built|strong="H1129"\w* \add part of the wall\add*. \w Next|strong="H5921"\w* \w to|strong="H5921"\w* \w them|strong="H5921"\w*, \w Zaccur|strong="H2139"\w*, \w the|strong="H5921"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* Imri, \w built|strong="H1129"\w* \add part of the wall\add*.   
\p
\v 3 \w The|strong="H1129"\w* \w sons|strong="H1121"\w* \w of|strong="H1121"\w* \w Hassenaah|strong="H5570"\w* \w built|strong="H1129"\w* \w the|strong="H1129"\w* \w Fish|strong="H1709"\w* \w Gate|strong="H8179"\w*. \w The|strong="H1129"\w* put \w in|strong="H1121"\w* \w their|strong="H1992"\w* \w places|strong="H1992"\w* \w the|strong="H1129"\w* wooden \w beams|strong="H7136"\w* above \w the|strong="H1129"\w* \w gates|strong="H8179"\w*, \w and|strong="H1121"\w* \w also|strong="H1121"\w* \w the|strong="H1129"\w* \w doors|strong="H1817"\w*, \w the|strong="H1129"\w* \w bolts|strong="H4514"\w*, \w and|strong="H1121"\w* \w the|strong="H1129"\w* \w bars|strong="H1280"\w* \add for locking the gate\add*.  
