\id OBA
\h عَننَبِ عَبَدِيَسِ
\toc1 عَلَ شَ مَسٍنيِ عَننَبِ عَبَدِيَسِ بّ
\toc2 عَننَبِ عَبَدِيَسِ
\toc3 عَبَ
\mt1 عَلَ شَ مَسٍنيِ عَننَبِ عَبَدِيَسِ بّ
\imt1 مَسٍنيِ ندٍ يِ كِتَابُي شَ قٍ رَ
\ip يِ كِتَابُي كُي، عَننَبِ عَبَدِيَسِ عَ عَلَ شَ كَلَمُي مَسٍنمَ عٍدٌن بْنسْي شَ قٍ رَ. عَ نْندِ نَشَن قَلَ عَ قِندِ نْندِ هَفِفّ نَن نَ عِبُنَدَ مَ بِرِن بّ. عَ مَسٍنيِ قَنيِ تِمَ نفَشَكٍرٍنيَ شَ قٍ رَ. عَ لَنمَ وٌن شَ وٌن تُلِ مَتِ نَ سّرِيّ رَ.
\ip عٍدٌن بٍنبَ سِنفٍ قِندِشِ عٍسَيُ نَن نَ، عِسِيَفَ شَ دِ سِنفٍ رٍبٍكَ نَشَن بَرِشِ عَ بّ. عَ فُلِ بٌورٍ قِندِشِ يَشُبَ نَن نَ. نَ دِ قِرِنيِيٍ تٌ نُ نَ عٍ نفَ تّيفّ، عَلَ نَشَ عَ مَسٍن رٍبٍكَ بّ عَ عٍ قِندِ مَ سِ قِرِن نَن نَ نَشٍيٍ قَمَ عٍ بٌرٍ فٍرٍدٍ قٍ قْلْ قْلّ ٢٥‏؛٢٣. عَ نَشّ نَ دِ سِنفٍ لُمَ عَ شَنبِرَتٌي شَ نْي بُن مَ. نَ كُي عَلَ نَشَ بَرَكّ سَ عِسِيَفَ شَ دِ يَشُبَ مَ، عَ قِندِ بٍنبَ رَ عَ شَ حَمَ عِسِرَيِلَ بّ. عٍسَيُ تَن قِندِ عٍدٌنكَيٍ بٍنبَ سِنفٍ نَن نَ. عٍ شَ بْشِ نُ نَ عِسِرَيِلَ نُن يُدَيَ بْشِ نَن قُفٍ رَ.
\ip حّ وُيَشِ دَنفِ شَنبِ، عِسِرَيِلَ نُن يُدَيَ نَشَ عٍ كٌبٍ رَ سٌ عَلَتَلَ رَ، عَ قَ عٍ شَنِن كٌنيِيَ كُي بَبِلْن بْشِ مَ. عَلَ شَ حَمَ نُ نَ نَ تْورّ كُي تّمُي نَشّ، عٍ نفَشَكٍرٍنيِ نَشٍيٍ قِندِشِ عٍدٌنكَيٍ رَ، عٍ مُ تِن عٍ مَلِدٍ قٍقٍ مَ، عٍ حَن نَشَ ندٍ سَ عٍ شَ تْورّ شُن. هَلِ عَلَ تٌ نُ وَ مَ يُدَيَ حَشَنكَتَقٍ عٍ شَ يُنُبِيٍ شَ قٍ رَ، نَ مَرَحَاشُي شَ قٍ رَ عٍدٌنكَيٍ نَشَن نَمِنِشِ عَلَ شَ حَمَ مَ، نَ مُ عَ كّنّن. نفَشَكٍرٍنيَ قَنيِ مُ نُ نَ نَ رَ.
\ip يِ مَسٍنيِ شْرْشْي عٍسَيُ بْنسْي بّ عَ قَتَنشِ نَ يُنُبِ مْولِ نَن نَ. عَلَ شَ وٌن مَلِ نفَشَكٍرٍنيَ بِنيَدٍ عَلْ عَلَ وَ مَ عَ شْن مَ كِ نَشّ. عَمِنَ.
\mt1 عَلَ شَ مَسٍنيِ عَننَبِ عَبَدِيَسِ بّ
\c 1
\s1 عَلَتَلَ شَ مَسٍنيِ عٍدٌن حَمَ بّ
\q1 
\v 1 عَننَبِ عَبَدِيَسِ شَ لَامَتُنيِ نَن يَ.
\q1 مَرِفِ عَلَتَلَ شَ مَسٍنيِ عٍدٌن حَمَ شَ قٍ رَ.
\q1 مُشُ بَرَ شِبَارُ ندٍ مّ كٍلِقٍ عَلَتَلَ مَ.
\q1 مِشِ ندٍ شّيشِ حَمَنّيٍ مَ يِ يَامَرِ رَ؛
\q1 «وٌ كٍلِ! وٌن شَ سِفَ عٍدٌن فٍرٍدٍ!»
\b
\q1 
\v 2 «ﭑ عِ مَفٌرٌ مَ نّ سِيٍ تَفِ، عِ قَ لُ يَافِ كُي.
\q1 
\v 3 عِ شَ يّتّ عِفبٌيَ بَرَ عِ مَدَشُ،
\q1 عِ تَن نَشَن سَبَتِشِ قْنمّيٍ رَ فٍيَيٍ كْن نَ.
\q1 عِ عَ قَلَمَ، ‹ندٍ نْمَ ﭑ نَفٌرٌدٍ لَنبَنيِ؟›
\q1 
\v 4 هَلِ عِ تٍ كٌورٍ مَ عَلْ سّفّ،
\q1 عِ سَ عِ تّي سَ تُنبُييٍ يَ مَ،
\q1 ﭑ تَن عِ رَفٌرٌ مَ نّ هَن بْشِ.»
\q1 عَلَتَلَ شَ مَسٍنيِ نَن نَ كِ.
\b
\q1 
\v 5 «شَ مُحّتِيٍ سٌمَ عِ شْنيِ كْي رَ،
\q1 عٍ مُ عٍ وَشْنسٍ تٌنفٌمَ شّ عٍ هَيِ نَ نَشَن مَ؟
\q1 شَ سَنسِ شَبّيٍ قَمَ عِ شْنيِ،
\q1 عٍ مُ تْنسْي ندٍيٍ لُمَ شّ نَا؟
\q1 
\v 6 كْنْ عٍسَيُ بْنسْي تَن، عٍ هَرِفٍ بِرِن بَمَ نّ عٍ يِ،
\q1 عٍ شَ نَاقُلِ نْشُنشِ تٌنفٌمَ نّ.
\q1 
\v 7 وٌ سَاتَ تٌنفٌ بٌورٍيٍ وٌ كٍرِ مَ نّ وٌ شَ بْشِ مَ.
\q1 وٌ مَلِ بٌورٍيٍ وٌ يَنقَمَ نّ،
\q1 وٌ نُن نَشٍيٍ نُ وٌ دّفٍمَ لٍنفٍ كٍرٍن كُي،
\q1 نٍيٍ فَنتَنيِ تٍمَ نّ وٌ يَ رَ.»
\b
\q1 
\v 8 عَلَتَلَ شَ مَسٍنيِ نَن يَ؛
\q1 «ﭑ لْننِلَيٍ سْنتْمَ نّ عٍدٌن بْشِ مَ نَ لْشْي،
\q1 ﭑ شَشِلِمَيٍ قَشَمَ نّ عٍدٌن بٍنبَ عٍسَيُ شَ فٍيَيٍ قَرِ.
\q1 
\v 9 عٍ بٍنبَ تٍمَن شَ سْورِيٍ فَاشُمَ نّ،
\q1 عٍ بِرِن قَ سْنتْ عٍسَيُ شَ فٍيَ لٌنفٌرِ.
\q1 
\v 10 وٌ نَ فبَلٌي سْتْمَ نّ وٌ شَ قٍ حَاشِ مَ
\q1 وٌ نَشَن نَبَشِ وٌ نفَشَكٍرٍنيِ يَشُبَ بْنسْي رَ.
\q1 يَافِ دُ سُمَ نّ وٌ شُن نَ، وٌ قَ حْن عَبَدَن.
\q1 
\v 11 نَ لْشْي عٍ يَشُييٍ تٌ عٍ شَ بَننَيَ شَنِن،
\q1 عٍ نَ رَبَ نّ وٌ يَ شْرِ.
\q1 عٍ تٌ سٌ عٍ شَ تَا كُي، عٍ شَ دَرِ سَلَمُ قِندِ عٍ فبٍ رَ،
\q1 وٌ نُ سَشِ عٍ يَشُييٍ دّ رَ.
\q1 
\v 12 وٌ مُ لَن وٌ شَ حّلّشِن وٌ نفَشَكٍرٍنيِيٍ شَ تْورّ رَ.
\q1 وٌ مُ لَن وٌ شَ سّيوَ يُدَ بْنسْي شَ فبَلٌي رَ.
\q1 وٌ مُ لَن وٌ شَ وٌ يّتّ عِفبٌ عٍ شَ تْورّ كُي.
\q1 
\v 13 وٌ مُ لَن وٌ شَ سٌ ﭑ مَ حَمَ شَ تَا كُي عَ كَسَرّ لْشْي.
\q1 وٌ مُ لَن وٌ شَ يٌ عٍ مَ عٍ كَسَرّ لْشْي.
\q1 وٌ مُ لَن وٌ شَ عٍ هَرِفٍ بَ عٍ يِ عٍ كَسَرّ لْشْي.
\q1 
\v 14 وٌ مُ لَن وٌ شَ وٌ نْشُن كِرَ دّ رَ عٍ شَ مِشِيٍ قَشَقٍ رَ
\q1 نَشٍيٍ عٍ فِشِ فٍرٍ مَ.
\q1 وٌ مُ لَن وٌ شَ عٍ سَ عٍ يَشُييٍ سَفٌي عٍ شَ كَسَرّ لْشْي.»
\b
\q1 
\v 15 «عَلَتَلَ شَ كِيتِ لْشْي نَ قَقٍ سِ بِرِن بّ.
\q1 عِ نَشَن نَبَ، نَ نَن نَبَمَ عِ قَن نَ.
\q1 عِ شَ وَلِ سَرٍ فبِلٍنمَ نّ عِ مَ.
\q1 
\v 16 وٌ ﭑ مَ شْنّ نَشَن سْتْشِ ﭑ مَ فٍيَ سّنِيّنشِ قَرِ،
\q1 سِيٍ قَن قَمَ نّ نَ مْولِ سْتْدٍ هَن عٍ بْنسْي حْن.
\q1 
\v 17 كْنْ مِشِ قَمَ كِسِ سْتْدٍ سِيٌنِ فٍيَ قَرِ.
\q1 مّننِ قِندِ مَ يِرٍ سّنِيّنشِ نَن نَ.
\q1 يَشُبَ بْنسْي قَمَ نّ عَ كّ مَسْتْدٍ.
\q1 
\v 18 يَشُبَ بْنسْي نُن يُسُقُ بْنسْي لُمَ نّ عَلْ تّ،
\q1 نَشَن عٍسَيُ بْنسْي فَنمَ عَلْ سّشّ.
\q1 مِشِ يٌ مُ كِسِمَ عٍسَيُ بْنسْي يَ مَ.»
\q1 عَلَتَلَ شَ مَسٍنيِ نَن نَ كِ.
\b
\q1 
\v 19 «نٍفٍوِكَيٍ عٍسَيُ شَ فٍيَيٍ سُشُمَ نّ،
\q1 سٍقٍلَكَيٍ قِلِسِتَكَيٍ شَ بْشِ تٌنفٌمَ نّ،
\q1 عَ نُن عٍقِرَ مِ نُن سَمَرِ بْشِيٍ.
\q1 بُنيَمِن بْنسْي قَن فَلَدِ بْشِ سْتْمَ نّ.
\q1 
\v 20 يِ عِسِرَيِلَكَ نَشٍيٍ فبِلٍن عٍ قَمَ نّ نْدٍ كَنَان بْشِ رَ هَن سَرٍثٍتَ.
\q1 دَرِ سَلَمُكَيٍ نَشٍيٍ فبِلٍن سٍقَرَدَ،
\q1 نٍيٍ قَمَ نّ نٍفٍوِ تَايٍ سُشُدٍ.
\q1 
\v 21 مِشِ نَشٍيٍ فٍينِمَ نُ قَمَ نّ تٍدٍ سِيٌنِ فٍيَ قَرِ،
\q1 عٍ شَ عٍسَيُ شَ فٍيَيٍ يَمَرِ.
\q1 مَنفّيَ لُمَ عَلَتَلَ نَن بّ.»
