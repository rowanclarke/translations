\id SNG Song of Songs in Boko, Ross Jones 2/08
\h Salomↄↄ lɛ
\toc1 Salomↄↄ lɛ
\toc2 Salomↄↄ lɛ
\toc3 Sal
\mt1 SALOMƆƆ LƐ
\imt1 Yã́ pↄ́ kú láɛ bee guuↄ
\ip Salomↄↄ lɛá báasɛ̃ lɛɛ. We ↄ̃ gbɛ̃ↄn plaↄ lɛ́ ń báasɛ̃ ↄlↄukↄ̃ɛ n yã́ nana oakↄ̃ɛo widɛsai. Yã́pi ì di Bibeli kyokɛnaↄwa maamaaɛ. Bee yã́i za asĩnizĩ wà lɛpi dìlɛ Lua yea a gbɛ̃́ↄzi yãtaa ũ. Ń beeo gↄ̃ɛ ń nↄɛo báasɛ̃ ì bↄ Lua kĩ́iɛ, Lua gbaɛ. Ayãmɛto lápi kua Bibeli guu zɛvĩ.
\ip Bↄ̃̀nↄblenapiↄ lɛ́ báasɛ̃ yã́ lɛɛũ ń buapↄ́ↄ. Gↄ̃ɛ ń nↄɛo yã'oa ń kↄ̃opi guu, zĩeↄ aaì kↄ̃ wɛɛlɛ aaì kↄ̃ e, zĩeↄ aaì kuakↄ̃wa ↄ̃ aaì ɛa wàↄ kↄ̃ wɛɛlɛ lↄ. Zĩeↄ gbɛ̃pãleↄ ì mↄ dúsakũkpanɛ́, sãdãnaↄ (ɛ̀waaso gbɛ̃naↄ) ge wɛ̃ndiapi da ge aà dãↄ ge aà gbɛ̃naↄ. Aaìↄ wɛɛlɛ wà lɛda gbɛ̃́piↄ yã́u, ãma báasɛ̃pi i bↄ ń kĩ́i no, Lua mɛ́ tò an nisĩna yekↄ̃i.
\c 1
\p 
\v 1 Lɛↄ mide pↄ́ Salomↄↄ dà.\f + \fr 1.1 \ft 1Kia 5.12\f*
\sp Nↄɛ
\q1 
\v 2 Lɛ́pɛ ma lɛ́wa,
\q1 asa n yeamazi na dɛmɛɛ vɛ̃ɛa.
\q1 
\v 3 N tulaleↄ gĩ na.
\q1 N tↄ́ na lán tulale lɛ́kulɛa gĩwa.
\q1 Bee yã́ mɛ́ tò wɛ̃́ndiaↄ yenzi.
\q1 
\v 4 Ma sɛ wà ta kpakpa.
\q1 Kí, gɛ̃manↄ n kpɛ́u.
\sp Yelusalɛũ nɛnↄnaↄ
\q1 Kí, wálɛ pↄnakɛ n yã́ musu,
\q1 wálɛ yasenapa,
\q1 wá n yeańzi na bo dɛ vɛ̃ɛa.
\sp Nↄɛ
\q1 Aaìↄ yenzi a zɛ́wa.
\q1 
\v 5 Yelusalɛũ nɛnↄnaↄ,
\q1 má sia mɛ́ má kɛfɛũ.
\q1 Má sia lán Kedaa zwã̀akpɛↄwa,
\q1 má kɛfɛũ lán Salomↄↄ kpɛ́ zwãaↄwa.
\q1 
\v 6 Ásu àↄ ma gwa ma siakɛ yã́io,
\q1 ĩatɛ̃ mɛ́ ma lɛ.
\q1 Ma dãↄↄ pↄ pàmaziɛ,
\q1 ↄ̃ aa ma da vɛ̃ɛbugwaa zĩu.
\q1 Mi e ma azĩa pↄ́ kɛ̀kɛo.
\q1 
\v 7 N gbɛ̃́ pↄ́ ma nisĩna yenzi,
\q1 ǹ n sãↄ dã́dãkɛkĩi omɛɛ.
\q1 Mákĩi ni to aa ĩatɛ̃ dɛui?
\q1 Bↄ́yãi máↄ ku n gbɛ̃́ↄ sã waiↄ saɛ sã́sãai?
\sp Kía
\q1 
\v 8 N gbɛ̃́ pↄ́ n nↄankɛ dɛ nↄɛↄla píi,
\q1 tó ń gupi dↄ̃o, tɛ sãↄ iai,
\q1 ní n blenɛↄ dã sãdãnaↄ bòo saɛ.
\q1 
\v 9 Ma gbɛ̃na, ń kɛfɛũmɛɛ
\q1 lán Falaↄ̃ↄ sↄ̃da pↄ́ ì godↄnɛ́ↄ dowa.
\q1 
\v 10 N gɛɛↄ maa, n swã́liↄ n sɛ,
\q1 n ↄ̃nɛɛↄ kↄ̃sì ń n nↄɛo.
\q1 
\v 11 Wá swã́liↄ pinɛ ń vuao,
\q1 wí ã́nusu pɛ́lɛpɛlɛu.
\sp Nↄɛ
\q1 
\v 12 Gↄↄ pↄ́ kía gɛngɛsɛkɛa,
\q1 ma tulale gĩ dↄ.
\q1 
\v 13 Ma yenzide dɛmɛɛ
\q1 lí'ↄ gĩnana pↄ́ looa ma yↄ̃́ taau ũ.
\q1 
\v 14 Ma yenzide dɛmɛɛ ãyã ligↄ̃n vude
\q1 pↄ́ wà bↄ̀ò Ɛ̃ngɛdi vɛ̃ɛbua ũɛ.
\sp Kía
\q1 
\v 15 Ma gbɛ̃na, ń kɛfɛũ fá!
\q1 N wɛ́ kɛfɛũ lán felen wɛ́wa.
\sp Nↄɛ
\q1 
\v 16 Ma yenzide, ń kɛfɛũ fá!
\q1 N zɛa maa!
\q1 Wá wúlɛkĩiá sɛ̃̀bↄlↄɛ,
\q1 
\v 17 wá kpɛ́ zaↄá sɛdɛ líↄnɛ,
\q1 wá kpɛ́ bala líↄá pɛ̃liↄnɛ.
\c 2
\p 
\v 1 Má dɛ lán Salↄna nàalɛvuwa,
\q1 lán guzulɛ sũmaavuwa.
\sp Kía
\q1 
\v 2 Lá lávu kɛfɛna dɛ lɛↄ guu,
\q1 màa ma gbɛ̃na dɛ wɛ̃́ndiaↄ guu.
\sp Nↄɛ
\q1 
\v 3 Lá mao lí dɛ líkpɛu,
\q1 màa ma yenzide dɛ ɛ̀waasoↄ guu.
\q1 Zↄ̃lɛa a uenai ì kamagu,
\q1 a bɛ blea ì kɛmɛɛ na.
\q1 
\v 4 À gɛ̃̀manↄ a pↄnablɛblekpɛu,
\q1 aà dàlapoo pooamala báasɛ̃ ũ.
\q1 
\v 5 À vɛ̃ɛbɛ gii kpaa kɛ́ mà yɛ̃̀ɛɛ e,
\q1 à ma gba mao kɛ́ ma mɛ su,
\q1 asa aà báasɛ̃ lɛ́ ma gyãkɛɛ.
\q1 
\v 6 Aà ↄzɛɛ ku ma mi zíɛ,
\q1 aà ↄplaa liaamazi.
\q1 
\v 7 Yelusalɛũ nɛnↄnaↄ,
\q1 ma naɛ́ tueↄ ń zↄ̃́tɛ̃naↄzi,
\q1 ásu dúsakũkpawɛ̃ɛo,
\q1 ásu wá báasɛ̃ gbooo e a lɛ́ ká.
\sp Nↄɛ
\q1 
\v 8 Ma yenzide kĩ́i ma, àlɛ mↄ́,
\q1 à vĩ̀ lɛ́ pɛ́lɛpɛlɛ gbɛ̀sĩsĩↄwa,
\q1 àlɛ bàalɛ sĩ̀sĩ musu, àlɛ vĩvĩ.
\q1 
\v 9 Ma yenzide dɛmɛɛ
\q1 lán tue ge bùasanawa.
\q1 À aà gwa zɛ wá kpɛ́ kpɛ.
\q1 Àlɛ wɛ́kpalɛ fɛnɛntiu,
\q1 àlɛ gugwagwa a mↄↄ zãnguo.
\q1 
\v 10 Ma yenzide yã'òmɛɛ à mɛ̀:
\sp Kía
\q1 Ma gbɛ̃na kɛfɛna, fɛlɛ wà gɛ́,
\q1 
\v 11 asa lou làa, buziɛ gɛ̃̀zɛa.
\q1 
\v 12 Pↄ́pii lɛ́ vukɛ tↄↄlɛwa,
\q1 lɛsigↄↄ kà,
\q1 felenkↄpunaↄ ↄ́ lìgua wá bùsuu.
\q1 
\v 13 Kaadↄɛnliↄ nɛ́ sɛ̃́ia dàalɛ,
\q1 vɛ̃ɛliↄ vukɛ̀, a gĩ lòo.
\q1 Ma gbɛ̃na kɛfɛna, fɛlɛ wà gɛ́.
\q1 
\v 14 Ma felena,
\q1 ń pɛ gbɛ̀sↄↄu n ulɛkĩi.
\q1 To ma n wɛgwa, to ma n lↄↄ ma,
\q1 asa n lↄↄ na, mɛ́ n oa kɛfɛũ kɛ̀ zài.
\q1 
\v 15 À gbɛ̃gbonaↄ kṹkũwɛ̃ɛ,
\q1 gbɛ̃gbon kelepiↄ,
\q1 aalɛ wá vɛ̃ɛbuↄ ásookɛɛ,
\q1 wá vɛ̃ɛ pↄ́ lɛ́ vukɛpiↄ.
\sp Nↄɛ
\q1 
\v 16 Ma yenzideá ma pↄ́ɛ,
\q1 mɛ́ aà pↄ́n ma ũ,
\q1 àlɛ pↄble sũmaavuↄ guu.
\q1 
\v 17 Ma yenzide, e gu àↄ gɛ́ dↄi,
\q1 e guwɛ àↄ gɛ́ kɛ̃́i,
\q1 ɛa ǹ kɛ lá tue ge bùasan bↄlↄna
\q1 ì kɛ gbɛ̀sĩsĩↄwawa.
\c 3
\p 
\v 1 Ma wɛ́ dↄ ma yenzidezi gwãasĩna ma wúlɛkĩi,
\q1 ma aà wɛ̀ɛlɛ, mi aà eo.
\q1 
\v 2 Má fɛlɛ gɛ́ zɛaↄ kɛɛlɛi saɛ,
\q1 mí gbɛ̃́ pↄ́ ma nisĩna yeipi wɛɛlɛ gãaɛↄ.
\q1 Ɔ̃ ma aà wɛ̀ɛlɛ, mi aà eo.
\q1 
\v 3 Gudↄ̃anaↄ bↄ̀a, kɛ́ aalɛ bɛbɛ wɛ̃́lɛu,
\q1 ↄ̃ ma mɛ̀:
\q1 A gbɛ̃́ pↄ́ ma nisĩna yei è lae?
\q1 
\v 4 Kɛ́ ma gɛ̃má gↄ̃̀ↄ,
\q1 ma bↄ gbɛ̃́ pↄ́ ma nisĩna yeipiwa.
\q1 Ma aà kũ̀, mi we ma aà gbàɛ lↄo
\q1 e ma gɛ gɛ̃aànↄ ma dakpɛu
\q1 e kpɛa pↄ́ à ma nↄsìu.
\q1 
\v 5 Yelusalɛũ nɛnↄnaↄ,
\q1 ma naɛ́ tueↄ ń zↄ̃́tɛ̃naↄzi,
\q1 ásu dúsakũkpawɛ̃ɛo,
\q1 ásu wá báasɛ̃ gbooo e a lɛ́ ká.
\sp Nↄɛ
\q1 
\v 6 Démɛ bↄ̀ gbáau,
\q1 àlɛ mↄ́ lán tɛluwa keei?
\q1 À lí'ↄ gĩnana tulaletikàtɛa
\q1 ń laatanaↄ pↄ́ gĩnanaↄ píi.
\q1 
\v 7 Salomↄↄ mákɛlɛ gwa kɛ,
\q1 gↄ̃saↄ liaai gbɛ̃ↄn bàaↄ̃
\q1 Isaili nɛgↄ̃naↄnɛ.
\q1 
\v 8 Aa fɛ̃ndaↄ kũa ḿpii,
\q1 zĩ̀kan saↄnɛ!
\q1 An baade fɛ̃nda looa gwãasĩn yã́ↄ yã́i.
\q1 
\v 9 Kí Salomↄↄ a sɛbↄpi kɛ̀
\q1 ń Libã bùsu líoɛ.
\q1 
\v 10 A lipɛlɛↄá ã́nusuɛ,
\q1 a kpɛnakĩiá vuaɛ.
\q1 Zwã̀a gàalulade kpa a zↄ̃lɛkĩia,
\q1 a guuá Yelusalɛũ nɛnↄnaↄ yeanzi ↄgbɛɛ.
\q1 
\v 11 Siↄna nɛnↄnaↄ,
\q1 à bↄlɛ à mↄ́ kí Salomↄↄ gwa,
\q1 a a kíakɛfua kpaa.
\q1 Aà da mɛ́ kpàɛ̀ aà nↄsɛzĩ,
\q1 gↄↄ pↄ́ aà nↄ̀sɛ lɛ́ yáalↄ.
\c 4
\sp Kía
\p 
\v 1 Ń kɛfɛũ ma gbɛ̃na, ń kɛfɛũ fá!
\q1 N wɛ́ dɛ lán felen wɛ́wa n sálana fòou,
\q1 n mikã dɛ lán blè wiilaↄ pilaa Galada sĩ̀sĩwawa.
\q1 
\v 2 N swaa pua lán sã pↄ́ wà ń kãkɛ̃̀ɛlɛ
\q1 aa bↄ̀ zu'okĩi aalɛ suↄwa.
\q1 Aa kↄ̃sɛ̀ plapla píi,
\q1 a kee i pↄsɛ bↄo.
\q1 
\v 3 N lɛ́baa dɛ lán wↄ̃ↄtɛ̃n nian dowa,
\q1 n lɛ́ kɛfɛũ.
\q1 N gɛɛ dɛ lán gbɛafu pɛɛwa n sálana fòou.
\q1 
\v 4 N nↄɛ dɛ lán Davidi kalangawa.
\q1 Sɛngbao mɛ̀n ↄ̀aa sↄo looawà,
\q1 nɛgↄ̃naↄ gↄ̃kɛbↄɛ píi.
\q1 
\v 5 N yↄ̃́ dɛ lán tue nɛ́ sìa pↄ́ aalɛ pↄble sũmaavuↄ guuwa.
\q1 
\v 6 E gu àↄ gɛ́ dↄi,
\q1 e guwɛ àↄ gɛ́ kɛ̃́i,
\q1 má gɛ́ gbɛ̀sĩsĩ lí'ↄ gĩnanade musu,
\q1 má dɛdɛ sĩ̀sĩ tulaletidewa.
\q1 
\v 7 Ma gbɛ̃na, n gupii kɛfɛũ,
\q1 n gue sãa vĩo.
\q1 
\v 8 Ma nↄkpama,
\q1 to wà pila Libã gusĩsĩdewa
\q1 za Amana misonawa
\q1 ń Senii gbɛ̀ misonao ń Ɛɛmↄ gbɛ̀ misonao,
\q1 za nↄ̀ↄmusuↄ tòopiu,
\q1 za gbɛaantɛ̃naↄ gusĩsĩdepiu.
\q1 
\v 9 N yã́ ma sↄ̃ blè ma nↄkpama, ma báasɛ̃de,
\q1 wɛ́ pↄ́ n ma gwaò ma sↄ̃ blè
\q1 ń n ↄ̃nɛɛ pↄ́ mɛ̀ndoeo.
\q1 
\v 10 Ma nↄkpama, ma báasɛ̃de,
\q1 n yeamazi kɛ̀ zài,
\q1 n yeamazi namɛɛ dɛ vɛ̃ɛa,
\q1 n nísi gĩ namɛɛ dɛ pↄ́ gĩnanaↄla píi.
\q1 
\v 11 N lɛ́baa mↄ̀sɛ dɛmɛɛ lán zↄsapunawa.
\q1 Ma nↄkpama,
\q1 zↄ́ ń vĩo mɛ́ kú n lɛ́na zíɛ,
\q1 n pↄkasaↄ gĩ dɛ
\q1 lán Libã bùsu líkpɛ gĩwa.
\q1 
\v 12 Ń dɛ lán kaa pↄ́ wà a zɛtà
\q1 wà kilidàuwa.
\q1 Ma báasɛ̃de, ma nↄkpama,
\q1 ń dɛ lán bia pↄ́ wà kaa dàiwa,
\q1 lán nibↄna pↄ́ wà zɛtàɛ̀wa.
\q1 
\v 13 N lu pↄ́ↄá gbɛafuɛ
\q1 ń libɛ maaↄ ń ãyãlio ń naadilio
\q1 
\v 14 ń sũmaao ń fee bui gĩnanao
\q1 ń sinamↄ lío ń lí'ↄ gĩnanaↄ píi.
\q1 Zↄ̃go lí'ↄ ń aloe lí'ↄo ku we
\q1 ń pↄ́ pↄ́ a gĩ na dɛńlaↄ píi.
\q1 
\v 15 Kaa lↄ̀ↄn n ũ,
\q1 nibↄna í wɛ̃nide pↄ́ lɛ́ bↄ za Libã gusĩsĩdeu ũ.
\sp Nↄɛ
\q1 
\v 16 Gugbãntoo ĩ́ana, fɛlɛ!
\q1 Gɛↄmidↄkĩi ĩ́ana,
\q1 káka su ma kaawa,
\q1 a pↄ́ↄ gĩ na i ligua,
\q1 ma yenzide i gɛ̃u,
\q1 i a libɛ nanaↄ ble.
\c 5
\sp Kía
\p 
\v 1 Ma gɛ̃ ma kaau, ma nↄkpama báasɛ̃de,
\q1 ma a zↄ̃go lí'ↄ gò ń pↄ́ gĩnanaↄ,
\q1 ma a zↄsapuna blè ń a ío,
\q1 ma a vɛ̃ɛ mì ń ma vĩo.
\sp Yelusalɛũ nɛnↄnaↄ
\q1 À pↄble gbɛ̃́ↄ,
\q1 à imi à kã́ á bↄ̃̀nↄblenaↄ.
\sp Nↄɛ
\q1 
\v 2 Málɛ i'o, ãma ma làasoo bɛ̃́ɛ,
\q1 ma yenzide ma, àlɛ gbalɛ.
\sp Kía
\q1 Gba wɛ̃mɛɛ ma gbɛ̃na báasɛ̃de,
\q1 ma felen sãasaide!
\q1 Fíi kpà ma miwa,
\q1 gwãasĩna mↄ̀sɛ ma mikã nìni.
\sp Nↄɛ
\q1 
\v 3 Ma a ula bↄ̀, mí ɛa mà da lↄa?
\q1 Ma gbá pìpi, i ɛa gbãsĩkpa lↄa?
\q1 
\v 4 Ma yenzide ↄgɛ̃̀ gbà fòou,
\q1 ↄ̃ ma mɛ lɛ́ kɛ fèfe.
\q1 
\v 5 Ma fɛlɛ gɛ gbawɛ̃i ma yenzideɛ,
\q1 ma ↄ lɛ́ yↄyↄ ń zↄ̃go lí'ↄ tulaleo,
\q1 zↄ̃go lípi nísi lɛ́ bàalɛ ma ↄnɛↄwa,
\q1 à fĩ̀ gbatabↄwa.
\q1 
\v 6 Ma gbawɛ̃̀ ma yenzideɛ,
\q1 ãma à gɛ̃̀zɛa à tà kↄ̀.
\q1 Kɛ́ àlɛ yã'o, aà ni ma kũ.
\q1 Ma aà wɛ̀ɛlɛ, mi aà eo,
\q1 ma lɛzùzuaàzi, i weao.
\q1 
\v 7 Gudↄ̃anaↄ bↄ̀a,
\q1 kɛ́ aalɛ bɛbɛ wɛ̃́lɛ guu.
\q1 Aa ma gbɛ̃ aa ma wiwi,
\q1 bĩ́idↄ̃anapiↄ ma pↄlↄgãu wòlomala.
\q1 
\v 8 Yelusalɛũ nɛnↄnaↄ,
\q1 tó a ma yenzide è,
\q1 á oɛ̀ kpelewa ni?
\q1 Ma naɛ́ Luazi à oɛ̀mɛɛ,
\q1 ma yeaaàzi ma mɛ bùsa.
\sp Yelusalɛũ nɛnↄnaↄ
\q1 
\v 9 Bↄ́ n yenzide dɛò dãↄlai?
\q1 N gbɛ̃́ pↄ́ ń kɛfɛũ dɛ nↄɛↄla píi,
\q1 bↄ́ n yenzide dɛò dãↄla
\q1 ↄ̃ n gbasa n nawɛ̃ɛ Luazi màai?
\sp Nↄɛ
\q1 
\v 10 Ma yenzide tɛ̃a pípia,
\q1 gbɛ̃ↄn ↄ̀aasↄsↄo lɛɛ kwiↄ guu ↄ̃mɛ vua ũ.
\q1 
\v 11 Aà miá vua tɛ̃ɛtɛ̃ɛɛ,
\q1 aà mikã dɛ sí plɛ̀ɛɛ
\q1 lán gbagbaa kã́wa.
\q1 
\v 12 Aà wɛ́ dɛ lán felen pɛ́lɛa íuwa,
\q1 aà wɛ́pi pípia ń vĩo, mɛ́ a sàlala.
\q1 
\v 13 Aà gɛɛ dɛ lán pↄ́ gĩnanaↄ buawa,
\q1 a gĩdↄ nanannↄ.
\q1 Aà lɛ́baa dɛ lán lávuwa,
\q1 àlɛ yↄyↄ ń zↄ̃go lí nísio.
\q1 
\v 14 Aà ↄ dɛ lán vua lipↄ̃ↄↄ pↄ́ diamaa dadauwa,
\q1 aà gbɛɛ dɛ lán wesa swaa yↄↄa pↄ́ wà safii gbɛ pɛ̀pɛwawa.
\q1 
\v 15 Aà gbáↄ dɛ lán gbɛ̀pɛlɛ bɛɛɛde
\q1 pↄ́ wà a zɛbↄ pì ń vuaowa.
\q1 À bↄ̀ lán Libã bùsuwa,
\q1 aà zɛa maa lán sɛdɛ líwa.
\q1 
\v 16 Aà lɛ́á zↄ́ɛ,
\q1 aà gupii kɛfɛũ.
\q1 Yelusalɛũ nɛnↄnaↄ,
\q1 lá ma gbɛ̃na yenzide dɛn we.
\c 6
\sp Yelusalɛũ nɛnↄnaↄ
\p 
\v 1 N gbɛ̃́ pↄ́ ń kɛfɛũ dɛ nↄɛↄla píi,
\q1 n yenzide gɛ̀ má ni?
\q1 N yenzide mi dì má oiɛ
\q1 kɛ́ wà e wà aà wɛɛlɛnnↄi?
\sp Nↄɛ
\q1 
\v 2 Ma yenzide gɛ̀ a pↄ́ gĩnana buaɛ,
\q1 à gɛ̀ pↄblei a kaauɛ,
\q1 i lávuↄ wɛ.
\q1 
\v 3 Ma yenzideá ma pↄ́ɛ,
\q1 mɛ́ aà pↄ́n ma ũ,
\q1 àlɛ pↄble sũmaavuↄ guuɛ.
\sp Kía
\q1 
\v 4 Ma gbɛ̃na, ń kɛfɛũ lán Tiizawa,
\q1 ń maa lán Yelusalɛũwa.
\q1 N yã́ ì dimá
\q1 lán zĩgↄ̃ pↄ́ dàlapoo kũaↄwa.
\q1 
\v 5 Wɛgoa, asa málɛ liɛ.
\q1 N mikã dɛ lán blè wiilaↄ pilaa Galada sĩ̀sĩwawa.
\q1 
\v 6 N swaa pua lán sã pↄ́ aa bↄ̀lɛ zu'okĩi aalɛ suↄwa.
\q1 Aa kↄ̃sɛ̀ plapla píi,
\q1 an kee i pↄsɛ bↄo.
\q1 
\v 7 N gɛɛ dɛ lán gbɛafu pɛɛwa
\q1 n sálana fòou.
\q1 
\v 8 Ma naↄ kà bàaↄ̃,
\q1 a pↄ́ mi mɛ́sɛdilɛnɛ́oↄ basiiↄ̃,
\q1 a lɛ́soↄ lɛ́ vĩo,
\q1 
\v 9 ãma ma felen sãasai adoaɛ,
\q1 aà da nɛ́ mɛ̀ndonan we,
\q1 aà da'iapi pↄ dↄwàɛ.
\q1 Tó nɛnↄnaↄ aà è, aaì aà sáaukpaɛ,
\q1 ma nↄpiↄ ì aà tↄbↄ ḿpii.
\q1 
\v 10 Démɛ bↄ̀ lɛ́ mↄ́ kee lán gudↄawai?
\q1 A kɛfɛũ lán mↄvuawa,
\q1 a pípia lán ĩatɛ̃wa.
\q1 Aà yã́ ì dimá
\q1 lán zĩgↄ̃ pↄ́ dàlapoo kũaↄwa.
\q1 
\v 11 Ma gɛ lí pↄ́ wì a wɛ́na só kaau,
\q1 ma pila swa'ɛu pↄ́ↄ lá taa gwaiɛ.
\q1 Ma gɛ gwai tó vɛ̃ɛↄ bↄlↄbↄ̀,
\q1 tó gbɛafuↄ vukɛ̀.
\q1 
\v 12 Mi dↄ̃ kɛ́ ma nisĩna ma sɛ
\q1 gɛ̀manↄ ma kía deeↄ sↄ̃́goↄ guuo.
\c 7
\sp Yelusalɛũ nɛnↄnaↄ
\p 
\v 1 Ɛa su, ɛa su Sulami nↄɛ!
\q1 Ɛa su, ɛa su wà wɛfĩma!
\sp Kía
\q1 Bↄ́yãi á ye wɛfĩ Sulami nↄɛwa
\q1 lán zã̀ lɛɛ pla ↄ̃gwaawai?
\q1 
\v 2 Kía bui nↄɛ,
\q1 n gbála maa n kyaleu,
\q1 n gbala ú dɛ bũunnↄ,
\q1 a dɛ lán gↄ̃ide ↄzĩwaɛ.
\q1 
\v 3 Kɛɛona pↄ́ vɛ̃ɛli láa a guuo ku we,
\q1 pↄ́wɛn zɛ pↄ́ sũmaavuↄ liaai ku we.
\q1 
\v 4 N yↄ̃́ dɛ lán bua nɛ́ mɛ̀n plaↄwa,
\q1 lán tue nɛ́ sìaↄwa.
\q1 
\v 5 N nↄɛ dɛ lán kalanga pↄ́ wa bò ń wesa swaaowa.
\q1 N wɛ́ dɛ lán Ɛsɛbↄ̃ íkalɛkĩi pↄ́ kú Balabiũ bĩ́ibↄlɛ saɛwa.
\q1 N ní dɛ lán Libã bùsu kalanga pↄ́ bↄaa ń Damasiowa.
\q1 
\v 6 N mi maa lán Kaamɛli gbɛ̀sĩsĩwa.
\q1 N mikã dɛ lán zwã̀a gàaluladewa,
\q1 a dɛ plɛ̀ɛɛ, ì ma laai sia.
\q1 
\v 7 Ń kɛfɛũ fá, ni kamagu,
\q1 wá yeakↄ̃i gɛ̃agɛ̃̀.
\q1 
\v 8 N zɛa maa lán daminaliwa,
\q1 n yↄ̃́ dɛ lá a kↄ́wa.
\q1 
\v 9 Ma mɛ̀ má dɛdɛ lípiwa,
\q1 mí a bɛ kṹ.
\q1 N yↄ̃́ dɛmɛɛ lán vɛ̃ɛ kↄ́wa,
\q1 n lɛ́'ĩana dɛ lán mao gĩwa.
\q1 
\v 10 N lɛ́'i na
\q1 lán vɛ̃ɛ pↄ́ a na dɛńlawa.
\sp Nↄɛ
\q1 Vɛ̃ɛpi lɛ́ gɛ̃ ma yenzide lɛ́u sàaa,
\q1 àlɛ táa'o aà lɛ́baa ń aà swaaowa yↄlↄlↄ.
\q1 
\v 11 Má dɛ ma yenzide pↄ́ ũ,
\q1 ma ni kuwà.
\q1 
\v 12 Ma yenzide, mↄ wà gɛ́ sɛ̃u,
\q1 wí gɛ́ ii zↄ̃ɛwiaↄu.
\q1 
\v 13 Gufɛ̃nɛ wí gɛ́ vɛ̃ɛbua,
\q1 wà gwa tó vɛ̃ɛↄ bↄlↄbↄ̀,
\q1 wà e tó gbɛafuↄ vú pìa.
\q1 We má yeanzi ↄlↄunɛ.
\q1 
\v 14 Sɛ́ɛ lávu gĩ dàgua,
\q1 libɛ nana bui píi kú wá kpɛɛlɛ.
\q1 Ma a zi ń a dafuo kàlɛnɛ,
\q1 ma yenzide.
\c 8
\p 
\v 1 Tó ma dãↄn n ũ
\q1 wa yↄ̃́ mì wá kpàkↄ̃wa yãaɛ lé!
\q1 Tó ma kpaaũnnↄ bàasi,
\q1 dↄ̃ má lɛ́pɛma, wa sakamaguo.
\q1 
\v 2 Dↄ̃ ma gɛnnↄ ma da'ia kpɛ́u,
\q1 mí vɛ̃ɛ gĩ na kpama ǹ mi
\q1 ń gbɛafu í nanao.
\q1 
\v 3 Aà ↄzɛɛ ku ma mi zíɛ,
\q1 aà ↄplaa liaamazi.
\q1 
\v 4 Yelusalɛũ nɛnↄnaↄ, ma naɛ́ Luazi,
\q1 ásu dúsakũkpawɛ̃ɛo,
\q1 ásu wá báasɛ̃ gbooo e a lɛ́ ká.
\sp Yelusalɛũ nɛnↄnaↄ
\q1 
\v 5 Démɛ bↄ̀ gbáau, àlɛ mↄ́,
\q1 àlɛ gbãa'e a yenzidewa keei?
\sp Nↄɛ
\q1 Ma n vu mao lí gbáu,
\q1 wekĩi n da n nↄsìu,
\q1 wekĩi nↄwãwã mↄ̀uwà ↄ̃ à n i.
\q1 
\v 6 Ma na n sↄ̃wa lán seelakɛbↄ pↄ́ wì da ń nↄɛ ge ń ↄwawa,
\q1 asa yeagↄ̃ɛi ì mↄ́má lán gawaɛ,
\q1 báasɛ̃pi pãsĩ lán mia'ɛwaɛ.
\q1 Ì namá lán tɛ́waɛ,
\q1 ì kṹmá lán tɛ́ sà zↄ̃ↄwaɛ.
\q1 
\v 7 Baa ísi a fↄ̃ báasɛ̃ tɛdɛo,
\q1 baa swada í a fↄ̃ daao.
\q1 Tó gbɛ̃́ a bɛ àizɛɛↄ kpà píi
\q1 báasɛ̃ lua yã́i,
\q1 wa sakaaàgu búubuuɛ.
\sp Yelusalɛũ nɛnↄnaↄ
\q1 
\v 8 Wá dãuna vĩ, i yↄ̃́ bↄbↄo.
\q1 Kpelewa wá kɛ
\q1 tó gbɛ̃e ye gɛ̃ aà yã́ui?
\q1 
\v 9 Tó a dɛ bĩ́i ũɛ,
\q1 wá gulɛsĩↄ bowà ń ã́nusuoɛ.
\q1 Tó a dɛ bĩ́ibↄlɛ ũɛ,
\q1 wá káka ń sɛdɛ líoɛ.
\sp Nↄɛ
\q1 
\v 10 Bĩ́in ma ũ,
\q1 ma yↄ̃́ mɛ́ a gulɛsĩↄ ũ,
\q1 ↄ̃ má dɛ ma yenzideɛ
\q1 gbɛ̃́ pↄ́ ì aafia iɛ̀ ũ.
\q1 
\v 11 Salomↄↄ vɛ̃ɛbu vĩ Baalamↄ,
\q1 à búpi nà gbɛ̀winaↄnɛ ń ↄzĩ.
\q1 An baade líↄ fĩabo ã́nusu ↄwatɛ̃ ↄ̀aasↄsↄo.
\q1 
\v 12 Salomↄↄ, má azĩa vɛ̃ɛbu vĩɛ,
\q1 má ã́nusu ↄwatɛ̃ ↄ̀aa sↄo kpama,
\q1 mí a ↄ̀aa do kpa vɛ̃ɛbu zĩkɛnaↄwa.
\sp Kía
\q1 
\v 13 N gbɛ̃́ pↄ́ niↄ ku kaaↄ guu,
\q1 wì swãdↄnzi,
\q1 to mà n lↄↄ ma.
\sp Nↄɛ
\q1 
\v 14 Ma yenzide, mↄ kpakpa,
\q1 ní kɛ lá tue ge bùasan bↄlↄna
\q1 ì kɛ sĩ̀sĩ pↄgĩnadeↄ musuwa.
