\id PSA 19PSANSBP.PTX Ngaanyatjarra, Psalms Chs 1, 23, 46, 51, 63, 91, 100, 119.97-112, 126, 136, 146, July 2007, Amee Glass Australia 
\h Turlku 
\toc1 Turlku 
\toc2 Turlku 
\toc3 Turlku Pirninya 
\mt1 Turlku Pirninya  
\c 1  
\s1 Mama Kuurrku Wangka Kuliranytjalu Warta Purlkurnpirinypa Nyinama  
\q1
\v 1-2 Yuwa, yarnangu palyamunuku wangka-ya kulira nyinanytjamaaltu wantima.  
\q1 Palunyalu-ya palyamunu pirningka yarangka wanarayintjamaaltu wantima.  
\q1 Palunyalu-ya lurrtjurringkula nyinarranytjamaaltu wantima  
\q2 Mama Kuurrnga-ya panypuratjarralu watjaranyangka.  
\q1 Wiya, Mama Kuurrku wangka mukulyanytjulu-ya  
\q2 karlarla mungangka pukurltu kulinma.  
\q1 Yuwa, palunyapirinypa-yan tirtu nyinarranyangka  
\q2 Mama Kuurrtu-tjananyanta walykumunura kanyinma.   
\q1
\v 3 Yuwa, palunyapirinypa-yan nyinarranytjalu warta purlkurnpirinypa nyinama.  
\q2 Tjiinyakurlu warta kapingkartu pakala mirrka purlkanya kanyinma, palunyapirinypa.  
\q1 Palunyalu-yan kutjupa-kutjupa walykumunura palyanma.   
\q1
\v 4 Nyangka-ya yarnangu palyamunu tjanmarta minyarrapirinypa nyinama.  
\q2 Tjiinyakurlu tjanmarta rurrmupungama. Nyangka pirriyalu minyarra katima, palunyapirinypa.   
\q1
\v 5 Tjiinya yarnangu palyamunu pirnilu-ya purtu kulilku  
\q2 tjiinya Mama Kuurrtu yarnangu pirninya tjarraranyangka.  
\q1 Tjiinya-tjananya yarnangu palyamunu pirninya tjarralku.  
\q2 Palunyangka-ya purtu kulilku Mama Kuurrku yungarrapirtingka nyinakitjalu.   
\q1
\v 6 Nyangka-ya yarnangu nyarra yiwarra tjurrkurlwana mapitjalayirni,  
\q2 palunyanya-tjananya Mama Kuurrtu miranykanyira kanyinma.  
\q1 Nyangka yarnangu palyamunu pirninya-ya  
\q2 mirrikutu mapitjalayirni yiwarra palyamunuwana.   
\c 23  
\s1 Puurr, Nyuntulu-rnin Miranykanyira Kanyilpayi  
\q1
\v 1 Yuwa Puurr, nyuntulu-rnin miranykanyira kanyilpayi.  
\q2 Tjiinyakurlu watilu tjiipu miranykanyinma.  
\q2 Palunyapirinytju-rnin miranykanyira kanyilpayi.  
\q1 Nyangka-rna pirnipurlka kanyira  
\q2 nyuntulu-tjun nintiranyangka.   
\q1
\v 2 Patalypa-rna nyinarranyangka nyuntulu-rnin nyinatjunkupayi  
\q2 yukiri walykumunungka.  
\q1 Palunyalu-rnin walara katipayi  
\q2 kapi warla walykumunukutu.   
\q1
\v 3 Kurltjirr-kurltjirrpa-rna nyinarranyangka  
\q2 nyuntulu-rnin kurrurnpa yipilymara kanyilpayi.  
\q1 Puru-rnin yiwarra tjukarurruwanalu walara katipayi,  
\q2 tjiinyamarntu-rnin kalkurnu wantinytjatjanulu.   
\q1
\v 4 Kamu-rna ngurlurriku mirrirrikitja.  
\q2 Tjiinyamarntu-lin lurrtjurtu yankulayirni.  
\q1 Nyuntulu-rnin wartatjarralu paalytjura kanyilpayi.  
\q1 Tjiinyakurlu tjiipu miranykanyilpayilu warta kanyinma  
\q2 papa nganyirri purlkanya pungkukitjalu.  
\q1 Palunyapirinytju-rnin walara katirrayilpayi.  
\q2 Nyangka-rnanta kurrurnpa rapalu wanarayirni.   
\q1
\v 5 Nyuntulu-tjun mirrka kutjupa-kutjupa pirni palyara tjunkupayi,  
\q2 yanyan-yanyanpa pirnilu-rniya nyakulanyangka.  
\q1 Palunyalu-rnin pukurltu yarltipayi pitjala-rna mirrka ngalkulatjaku.  
\q2 Puru-tjun panikinta tjutira mulyawiilymankula tjunkupayi purlkanya-rna tjikiltjaku.   
\q1
\v 6 Yuwa, nyuntulu-rnin ngarltunytjulu tirtu kanyinma.  
\q2 Nyangka-rna nyuntuku ngurrangka tirtu nyinaku nyinama.   
\c 46  
\s1 Mama Kuurrtu-lanya Yangatjura Kanyilpayi  
\q1
\v 1 Mama Kuurrtu-lanya yangatjura kanyilpayi.  
\q2 Nyangka-lan kurrurnpa rapa nyinarra.  
\q1 Tjiinya-lanya tirtu yirringkara kanyilpayi  
\q2 kutjupa-kutjupa ngaralanyangka.   
\q1
\v 2 Palunyangka-lan ngurlumaalpa nyinama.  
\q1 Nyangka mantatarrartu yurrirranyangka  
\q2 purli wararra kartakatirra yuru purlkanyangka  
\q2 punka-punkara tjarrparranyangka-lan  
\q2 ngurlumaalpa nyinama.   
\q1
\v 3 Tjinguru kapi warnanpa purlkanya wirtatjarra  
\q2 rurrku kukurrmanku.  
\q2 Wiya, ngurlumaalpa-lan nyinama.  
\q1 Tjiinya yapu wararratarrartu tiltirr-tiltirrmaranyangka,  
\q2 ngurlumaalpa-lan nyinama.   
\q1
\v 4 Yuwa, kapi warla walykumunulu  
\q2 yarnangu Tjurutjamanyamartatji pirninya pukurlmara kanyilpayi.  
\q1 Yiwarla nyarra Mama Kuurrnga-ya lurrtjurringkula marninypungkupayi, palunyangka.   
\q1
\v 5 Mama Kuurrnga yiwarla palunyangka tirtu nyinama.  
\q2 Nyangka-ya pungkula wiyalkitjalu purtulinku wantiku.  
\q2 Tjiinyamarntu Mama Kuurrtu waarrpungkulalpi yangatjunku kanyinma.   
\q1
\v 6 Yuwa, ngurra kutjupa-kutjupangkatjalu-yanku  
\q2 pika pungkulanyangka  
\q1 Mama Kuurrnga tuturapirinypa wangkama.  
\q2 Nyangka-ya manta lipingkatjalu kuliralpi ngurluny-ngurlunyarriku.   
\q1
\v 7 Yuwa, Mama Kuurrtu Yayirninytjulu Palyalpayilu-lanya miranykanyira kanyira.  
\q1 Mama Kuurrnga, tjiinya Tjayikapalu pupakatirra marninypungkupayi,  
\q2 palunyalu-lanya yangatjura kanyilpayi.   
\q1
\v 8 Pitjalalpi-yan nyaku kata paarnarralku  
\q2 Mama Kuurrtu manta lipiwanalu  
\q2 kutjupa-kutjupa palyarnu wantinyangka.   
\q1
\v 9 Tjiinya Mama Kuurrtu marrkulpayi  
\q2 yarnangu pirnilu-yanku warrmarlara  
\q2 manta lipiwanalu pika pungkulanyangka.  
\q1 Palunyalu kurlarta, kupulu pirninya kartarntankupayi,  
\q2 puru tjara pirninya tilira tjarrpatjunkupayi.   
\q1
\v 10 Mama Kuurrtu watjarnu, “Wiya, tjurlpilyarrinytjamaalpa-ya  
\q2 kurrurnpa yipilyarri.  
\q1 Palunyalu-rniya ngayunya ruukulila  
\q2 tjiinya-tjanamparnanku puurrpa purlkanya nyinarranyangka.  
\q1 Nyangka yarnangu ngurra kutjupa-kutjupangkatjalu-rniya  
\q2 manta lipingkatjalurtu marninypungama.”   
\q1
\v 11 Yuwa, Mama Kuurrtu Yayirninytjulu Palyalpayilu-lanya miranykanyira kanyira.  
\q1 Mama Kuurrnga, tjiinya Tjayikapalu pupakatirra marninypungkupayi,  
\q2 palunyalu-lanya yangatjura kanyilpayi.   
\c 51  
\d Wati yini Tayipirrnga kampangkartu ngarringu wati kutjupaku kurringka. Nyangka wati yini Nayitjintu tjiinya Mama Kuurrku wangka kulira tjakultjunkupayilu pitjangu Tayipirrnga-lu punturnu watjarnu tjiinya wati kutjupaku kurri pampunnyangka. Nyangka palunyalanguru Tayipirrtu turlku ngaanya walkatjunu.  
\s1 Tayipirrtu tjapirnu Mama Kuurrnga-ra kalyparritjaku  
\q1
\v 1 Yuwa Mama, ngarlturriwa-tju ngayuku.  
\q2 Tjiinya-rnin mukulyanytjulu miranykanyira kanyilpayi.  
\q1 Yuwa, nyuntulun walkatjunu wantingu palyamunu-rna palyaranyangka.  
\q2 Nyangka-munta-tjun ruwarrpungku wiyalku?  
\q2 Tjiinyamarntun ngarltunytju purlkanya nyinarra.   
\q1
\v 2 Parltjila-rni walykumunula  
\q2 palyamunu-rna palyarnu palunyangka.   
\b  
\q1
\v 3 Tjiinya-rna nintilu kulira palyamunu palyantjatjanulu.  
\q2 Palunyalu-rna purtu watarrkurringkula.  
\q1 Tirtu-rna kulira palyamunu palyantjatjanulu.   
\q1
\v 4 Nyuntuku wangka-rna tungun-tunguntu wantingu.  
\q1 Nyuntula mirangka-rna palyamunu palyarnu.  
\q1 Nyangka-rnin tjurrkurltu watjara palyamunu-rna palyannyangka.   
\q1
\v 5 Yuwa, pilyirrngurulpi-rna palyamunu tirtu palyaranytja.   
\b  
\q1
\v 6 Yuwa Mama, nyuntulun mukurringkula  
\q2 tjiinya-rna mayuranytjamaalpa tjukarurru nyinarratjaku.  
\q1 Palunyanguru-rni nyuntuku wangka pinangka tjarrpatjurra.   
\q1
\v 7 Parltjila-rni. Nyangka-rna walykumunu nyinama.   
\q1
\v 8 Mama, watjala-rni kalyparringkutjatjanulu.  
\q2 Nyangka-rna pukurlarri nyinama.  
\q1 Nyuntulu-rnin kurltjirr-kurltjirrmanu.  
\q2 Kuwarrinya-rni kurrurnpa pukurlmara kanyinma.   
\q1
\v 9 Tirtu-kurlun kulinma  
\q2 palyamunu-rna palyarnu palunyangka. Wanti.  
\q1 Yuwa Mama, nyuntuku walkangka ngarala.  
\q2 Nyangka-tju ruwarrpuwa wiyala.   
\b  
\q1
\v 10 Wiya Mama, kurrurnpa-rni parltjila walykumunula.  
\q1 Palunyalu-rni wuyurrpa tjurrkurlmara kanyinma.   
\q1
\v 11 Wiya Mama, wituntjamaaltu-rni ngamulu kanyinma.  
\q1 Nyuntuku Kuurti Walykumununya katinytjamaaltu wanti.  
\q2 Nyangka-rni ngayula nyinama.   
\q1
\v 12 Pukurlmara-rni kanyinma,  
\q2 nyarra wankarunkulalpi-rnin pukurlpa kanyiranytja,  
\q2 palunyapirinypa.  
\q1 Palunyalu-rni wuyurrmarra nyuntuku wangka wangarnarralu kulira palyaratjaku.   
\q1
\v 13 Nyangka-rnayi nyuntuku wangka nintipungama  
\q2 yarnangu nyarra palyamunu pirningka.  
\q1 Nyangka-yayi pinkurraara marlaku pitja nyuntulakutu.   
\b  
\q1
\v 14 Mama, nyuntulu-rnin kutjulu wankarunku.  
\q1 Nyangka-kurlu-rnin ngaparrtjika pungku tjunku  
\q2 tjiinya-rna wati nyarranya pungu tjunkunyangka.  
\q1 Palunyangka-rna mirrarra yinkama  
\q2 nyuntulu-rnin wankarunkunyangka.   
\q1
\v 15 Mama, yirringkala-rni wangkarra-rna  
\q2 nyuntunya marninypungkulatjaku.   
\b  
\q1
\v 16 Tjinguru-rnanku mirrka kuka katiku witaralpi nintilku.  
\q2 Wiya, pukurlarrikitjamunu-tjun.   
\q1
\v 17 Tjiinya-rna kurrurnpa tjirturu-tjirturu palyamununguru kurntarringku,  
\q2 palunyangka-tjun pukurlarriku.  
\q1 Palunyalu-rnin wituntjamaaltu ngamuntinku kanyinma.   
\b  
\q1
\v 18 Yuwa Mama, walykumunura-tjananya kanyinma  
\q2 yarnangu pirninya nyarra Tjurutjamala nyinarranytjanya.  
\q2 Palunyalu-tjananya yirringkanama.  
\q2 Nyangka-yayi yaarrpa purlkanya yiwarlawana marlakulu parrapalyanma.   
\q1
\v 19 Palunyalu-latju palyamunu palyaralpi  
\q2 kurntarringkula nyinanytjatjanulu  
\q2 puluka pungku witalku nyuntuku nintilku.  
\q1 Nyangkan pukurlarriku.   
\c 63  
\d Turlku ngaanya Tayipirrtu mayu-mayu nyinarranytjalu walkatjunu wantingu.  
\s1 Tayipirrnga Kurrurnpatarrartu Mama Kuurrku Mukurringkulanytja  
\q1
\v 1 Yuwa Mama, nyuntunya-rnanta pupakatirra marninypungkupayi.  
\q1 Palunyalu-rnanku kurrurnpatarra mukurringkula.  
\q1 Tjiinyakurlu-ya ngurra yayilurrungka pitjalayila  
\q2 purtu mukurringkula pinalukutju kulinma, “Kapipalka ngarrima.  
\q2 Nyangka-rna waarrpungkulalpi tjikila.” Palunyapirinypa.   
\q1
\v 2 Yuwa, mukurringkula-rnanta nyuntunya nyakukitjalu.  
\q1 Puru-rna mukurringkula nyuntuku tili purlkanya nyakukitjalu  
\q2 tjurrtjungka yirrnyaranyangka.   
\q1
\v 3 Walykumunu tjiinya wanka-rna nyinarratjaku.  
\q2 Nyangka palunyangka munkarra ngarala  
\q2 tjiinya-rnin mukulyanytjulu kanyiratjaku.  
\q1 Palunyalangurulta-rnanta marninypungama.   
\q1
\v 4 Yuwa, nyuntunya-rnanta marninypungkulayilku ma-mirrirriku.  
\q1 Puru-rnanta mara katura warlkura tjapinma.   
\q1
\v 5 Yuwa, kurrurnpa-rna pukurlpa nyinama.  
\q2 Tjiinyakurlu kukatjanu parltjarringkulalpi pukurlpa nyinama, palunyapirinypa.  
\q2 Palunyalu-rnanta pukurltu yinkarra marninypungama.   
\b  
\q1
\v 6 Mungangka-rnanta ngarrirra kulilpayi.  
\q2 Wankalu-rnanta kulira tjirnturringkupayi.   
\q1
\v 7 Yuwa, tirtu-rnin yirringkara kanyilpayi.  
\q2 Palunyangka-rnanku turlku pukurltu yinkapayi,  
\q2 tjiinyamarntu-rnin yangatjura kanyiranyangka.  
\q2 Tjiinyakurlu tjurlpulunku kurlunypa pirninya nyarlpilu yangatjura kanyinma.  
\q2 Palunyapirinytju-rnin kanyira.   
\q1
\v 8 Lurrtju-rnanta tirtu nyinama.  
\q2 Nyangka-rnin waku purlkanyalu patjurira kanyinma.   
\b  
\q1
\v 9 Yarnangu nyarra nyinarra-rniya yurakanyira pungkula tjunkukitjalu,   
\q1
\v 10 palunyanya-tjananya warrmarlalu pungku tjunku.  
\q2 Nyangka ngupanulu pitjaku ngalku wiyalku.   
\b  
\q1
\v 11 Yuwa Mama, ngayulu-rnanta puurrpa purlkalu pukurltu marninypungama,  
\q2 tjiinya-rnin yirringkaranyangka.  
\q1 Nyangkanta-ya yarnangu nyarra nyuntunya mularrkuliranytjalu marninypungama.  
\q2 Nyangka-ya mayulpayi pirninya kanmarrarriku nyinama.   
\c 91  
\s1 Mama Kuurrtu-rni Yangatjura Kanyinma  
\q1
\v 1 Ngayulu-tjinguru-rna Mama Kuurrnga tjiinya yayirninytjulu palyalpayingka ngamu nyinama.  
\q2 Nyangka-rni yangatjura kanyinma.   
\q1
\v 2 Nyangkalta-rna Mama Kuurrta watjalku,  
\q2 “Nyuntulu-rnin tjarapirinytju yangatjura kanyilpayi.  
\q1 Nyangka-rnanta nyuntunyakutju pupakatirra marninypungama.  
\q2 Palunyalu-rnanta mula-mularringkula kulinma.”   
\b  
\q1
\v 3 Kulila. Kutjupalu-tjingurunta punkatjingalku.  
\q2 Wiya, Mama Kuurrtunta katulku.  
\q1 Nyangka-tjinguru-ya pirninya pika purlkanyatjarra ngarrima.  
\q2 Nyangkanta Mama Kuurrtu wankarura kanyinma mirrirritjakutarra.   
\q1
\v 4 Yuwa, Mama Kuurrtunta yangatjura kanyinma.  
\q1 Tjiinyakurlu tjurlpulunku kurlunypa pirninya nyarlpilu yangatjura kanyinma, palunyapirinytju.  
\q1 Mama Kuurrtunta watjarnu wantinytjatjanulu kanyinma.  
\q2 Tjiinyanta tjurlpu nyarlpipirinytju yangatjura kanyinma.   
\b  
\q1
\v 5 Wiya, nyaakun ngurlurringkula  
\q2 mamulunta mungangka pitjala pungkutjaku?  
\q1 Wiya, Mama Kuurrtunta miranykanyinma.  
\q1 Nyaakunykan ngurlurringkula  
\q2 karlarla-ya kurlarta warnirranyangka?  
\q1 Wiya, Mama Kuurrtunta yangatjura kanyinma.   
\q1
\v 6 Nyaakun ngurlurringkula mungangka pikatjarrarritjaku?  
\q1 Wiya, Mama Kuurrtunta miranykanyinma.  
\q1 Nyaakun ngurlurringkula  
\q2 kutjupa-kutjupa karlarla yutirringkulanyangka?  
\q1 Wiya, Mama Kuurrtunta yangatjura kanyinma.   
\b  
\q1
\v 7 Tjinguru yarnangu pirninya nyuntula yitingkartu punkalku mirrirriku.  
\q2 Nyangkan kutjuwanka ngarama.   
\q1
\v 8 Palunyalun nyaku  
\q2 Mama Kuurrtu-tjananya palyamunu pirninya ngaparrtjika pungku wiyannyangka.   
\q1
\v 9 Yuwa, kurrurnpa rapalun kulira Mama Kuurrtunta purlkanya nyinarranytjalu yangatjura kanyiratjaku.   
\q1
\v 10 Palunyangka kutjupa-kutjupalu pikanku nintilkitjamunu.  
\q2 Nyangka nyuntuku ngurrangka palyamunu ngarakitjamunu.   
\b  
\q1
\v 11 Nyangka Mama Kuurrtunku palunyaku yayintjulpa pirninya witulku  
\q2 miranykanyiranta-ya kanyiratjaku,  
\q2 tjiinyan ngurra kutjupa-kutjupakutu yankulanyangka.   
\q1
\v 12 Nyangka yayintjulpa pirnilunta-ya maralu katura kanyinma  
\q2 yapulunta tjina pikarntankutjakutarrartu.   
\q1
\v 13 Purun layinpa nganyirri purlkanyawana lirruwanatarrartu parrangarama.  
\q2 Nyangkanta-ya patjalkitjamunu.   
\b  
\q1
\v 14 Yuwa, Mama Kuurrtu watjarnu,  
\q1 “Nyuntulu-tjun mukulyanytju nyinarranyangka  
\q2 ngayulu-rnanta wankarura kanyinma.  
\q1 Ngayulu-rnanta yangatjura kanyinma  
\q2 nyuntulu-rnin puurrpa warlkuranyangka.   
\q1
\v 15 Nyangka-tjingurunku palyamunu yartakarrinyangka  
\q2 ngayula-rni tjapinma.  
\q2 Nyangka kuliralpi-rnanta yampura kanyinma.  
\q1 Palunyalu-rnanta walykumunura kanyinma wanka nyinarratjaku.   
\q1
\v 16 Ngayulu-rnanta wankarura kanyinma.  
\q2 Palunyangkan rawa nyinarrayilku ma-mirrirriku.”   
\c 100  
\s1 Turlku Ngaanya Yinkarra Mama Kuurrnga Marninypungkulatjaku  
\q1
\v 1 Yarnangu pirni, Mama Kuurrnga-ya pukurltu marninypungama.  
\q1 Ngurra kutjupa-kutjupangkatja pirni,  
\q2 turlku-ya yinkarra Mama Kuurrnga marninypungama.   
\q1
\v 2 Yuwa, tjurrtjungka-ya turlku yinkarra tjarrpama.  
\q2 Palunyalu Mama Kuurrnga pukurltu marninypungama.   
\b  
\q1
\v 3 Nintilu-yan kulira  
\q2 Mama Kuurrnga Puurrpa Purlkanya nyinarranyangka.  
\q1 Kutju-palunyalu-lampa tjamupirti lurrtjurnu  
\q2 palunyaku katja yurntalpirti-ya nyinarratjaku.  
\q2 Nyangka ngayulutarrartu-lan palunyaku nyinarra.  
\q1 Ngayulu-lan Mama Kuurrku tjiipupirinypa nyinarra.  
\q2 Nyangka-lanya katja yurntalpirti kurrurnkurlu kanyira.   
\b  
\q1
\v 4 Mapitja-ya tjurrtju kayirrpangka tjarrparralpi watjala,  
\q2 “Mama, walykumunulu-lanyatjun miranykanyira kanyiranytja.”  
\q2 Palunyatjanulu-ya tjurrtjungka ma-tjarrparralpi  
\q2 Mama Kuurrnga marninypungkuma.   
\q1
\v 5 Yuwa, Mama Kuurrnga walykumunu mularrpa.  
\q2 Palunyalu-lanya mukulyanytjulu miranykanyira kanyira.  
\q1 Mama Kuurrtu-lanya tirtu kanyinma watjarnu wantinytjatjanulu.  
\q2 Puru-tjananya katja yurntalpirti  
\q2 marlangkatja-marlangkatjanya pakaranyangka miranykanyira kanyinma.   
\c 119  
\s1 Mama Kuurrku Wangkaku-rna Mukulyanytju Nyinarra  
\q1
\v 97 Yuwa Mama, nyuntuku wangkaku-rna mukulyanytju nyinarra.  
\q2 Wantinytjamaaltu-rna kulira-wanara tjirntu tjarrpatjura.   
\q1
\v 98 Nyuntuku wangka-rna pinangka kanyilpayi.  
\q2 Palunyalanguru-rna nintipukarringu nyinarra,  
\q2 nyarra yanyan-yanyanpa-ya nyinarra, palunyangka munkarra.   
\q1
\v 99 Nyuntuku wangka-rna tirtu kuliranytjatjanu  
\q2 nintipukarringu nyinarra,  
\q2 nyarra ngayunya-rniya nintipungkulanytja,  
\q2 palunyangka munkarra.   
\q1
\v 100 Nyuntuku wangka-rna wangarnarralu kulira palyaranytja.  
\q2 Palunyalanguru-rna nintipukarringu nyinarra,  
\q2 tjiinya nyalpa pirningka munkarra.   
\q1
\v 101 Yiwarra lipinya-rna wantipayi  
\q2 tjiinya nyuntuku wangka wangarnarralu kulira palyalkitjalu.   
\q1
\v 102 Nyuntuku wangka-rna wantikitjamunu.  
\q2 Nyuntulumarntu-rnin nintipungkulanyangka.   
\q1
\v 103 Nyuntuku wangka pukarapirinypa  
\q2 tjiinya yirliltungka munkarra.   
\q1
\v 104 Nyuntuku wangka kuliranytjatjanu-rna  
\q2 nintipukarringu nyinarra.  
\q2 Palunyalanguru-rna yiwarra nyarra lipiku yanyan-yanyanpa nyinarra.   
\s1 Mama Kuurrku Wangka Tilipirinypa  
\q1
\v 105 Yuwa Mama, nyuntuku wangka tilipirinypa  
\q2 tjiinya yiwarra-tju pirntaltjingara kanyilpayi.  
\q1 Nyuntuku wangka pirntal-pirntalpirinypa.  
\q2 Nyangka-rna palunyatjarra tjukarurru mapitjalayilku parrapitjaku.   
\q1
\v 106 Nyuntuku wangka tjukarurru mularrpa ngarala.  
\q1 Nyangka-rnanta watjarnu wantingu wangka palunyanya  
\q2 wangarnarralu kulira palyalkitjalu.   
\q1
\v 107 Wiya, yarnangu pirnilu-rniya parrawanarayirni mirri pungkula tjunkukitjalu.  
\q1 Palunyakutarra-rni wankarura kanyila,  
\q2 tjiinya-rnin watjarnu wantitjalu.   
\q1
\v 108 Yuwa Mama, pukurlarriku-munta-tjun  
\q2 tjiinya-rnanta marninypungkulanyangka?  
\q1 Pukurlarrirralpi-rni nyuntuku wangka tirtu nintipungama.   
\q1
\v 109 Wiya, tirtu-rniya parrawanarayirni pungkula mirri tjunkukitjalu.  
\q2 Nyangka nyuntuku wangkaku-rna watarrkurrikitjamunu.   
\q1
\v 110 Nyangka yarnangu palyamunu pirninya-ya mukurringkula piwarrtjingalkitjalu-rniya.  
\q2 Parturtu-rna nyuntuku wangka wantikitjamunu.   
\q1
\v 111 Yuwa, nyuntulu-rnin wangka walykumunu nintirnu.  
\q2 Nyangka-rnanku tirtu kanyilku kanyinma.  
\q1 Tjiinya-rni wangka palunyalu tirtu pukurlmara kanyira.   
\q1
\v 112 Nyangka-rna wangarnarralu kulira palyarayilku ma-mirrirriku.   
\c 126  
\s1 Pukurlpa-ya Marlaku Pitjangu  
\q1
\v 1 Mama Kuurrtu-lanyatju ngurra nyarra Papulantanguru marlakulu katingu Tjurutjamalakutu.  
\q2 Palunyangka-latju kulirnu tjukurrtjuranytja-latju.   
\q1
\v 2 Yikarringkula-latju pukurlpa mirrarranytja.  
\q2 Nyangka yarnangu kutjupatjarralu-lanyatjuya tjumara watjaranytja,  
\q2 “Mama Kuurrtu-tjanampa yayirninytjulu kutjupa-kutjupa palyarnu.”   
\q1
\v 3 Yuwa mularrpa Mama Kuurrtu-lampatju yayirninytjulu kutjupa-kutjupa yutirnu.  
\q2 Nyangka-latju pukurlpa mularrpa nyinarranytja.   
\b  
\q1
\v 4 Yuwa Mama, yungarrapirti nyarra Papulanta-ya tirtu nyinarra,  
\q2 palunyanya-tjananya marlakulu kati.  
\q2 Nyangka-latjuyi pirni nyinama.  
\q1 Tjiinyakurlu kapi punkannyangka warnanpa kukurrmanama karrungka, palunyapirinypa.   
\q1
\v 5 Yuwa Mama, nyawa-tjananya nyarra-ya yulatawarralu yurninypa pirni makatingu parnangka tjunkulanyangka.  
\q2 Nyangkayi paka-pakannyangka mirrka purlkarriwa.  
\q2 Nyangka-yayi ngula mirrka purlkanya yurraralpi pukurlpa pitjama.   
\q1
\v 6 Yuwa, yarnangu pirni nyarra yulatawarralu-ya yurninypa pirni makatingu mantangka tjunu.  
\q2 Palunyatjinnga-ya nyinarrayilku ngula mirrka purlkanya yutirrinyangka mirratawarralu yurrara pukurltu katima.  
\q2 Pukurl-pukurlpa-ya ngurrakutu pitjama.   
\c 136  
\s1 Yinkarra Mama Kuurrnga Marninypungkulatjaku  
\q1
\v 1 Mama Kuurrnga-la marninypungama,  
\q2 tjiinyamarntu walykumunu mularrpa.  
\q2 Palunyalu-lanya ngarltunytjulu tirtu kanyira.   
\q1
\v 2 Mama Kuurrnga-la marninypungama,  
\q2 tjukurrtatja pirningka munkarra nyinarranyangka.  
\q2 Palunyalu-lanya ngarltunytjulu tirtu kanyira.   
\q1
\v 3 Mama Kuurrnga-la marninypungama,  
\q2 puurrpa pirningka munkarra nyinarranyangka.  
\q2 Palunyalu-lanya ngarltunytjulu tirtu kanyira.   
\q1
\v 4 Kutju-palunyalu yayirninytjulu kutjupa-kutjupa palyalpayi.  
\q2 Palunyalu-lanya ngarltunytjulu tirtu kanyira.   
\q1
\v 5 Mama Kuurrtu ninti purlkanyalu yilkari palyarnu.  
\q2 Palunyalu-lanya ngarltunytjulu tirtu kanyira.   
\q1
\v 6 Palunyalu manta parratjunu kapi yirralawanalu.  
\q2 Palunyalu-lanya ngarltunytjulu tirtu kanyira.   
\q1
\v 7 Palunyalu tjirntu puru kirnara palyarnu.  
\q2 Palunyalu-lanya ngarltunytjulu tirtu kanyira.   
\q1
\v 8 Tjiinya tjirntu palyarnu karlarlara kanyiratjaku.  
\q2 Palunyalu-lanya ngarltunytjulu tirtu kanyira.   
\q1
\v 9 Puru kirnara pirntirritarrartu palyarnu  
\q2 mungangka yutira kanyiratjaku.  
\q2 Palunyalu-lanya ngarltunytjulu tirtu kanyira.   
\q1
\v 10-16 Mama Kuurrtu-tjananya Yitjurayilku tjamupirti  
\q2 yayirninytjulu ngurra nyarra Yiitjipulanguru pakaltjingara katingu.  
\q2 Palunyalu-lanya ngarltunytjulu tirtu kanyira.   
\q1
\v 17-20 Mama Kuurrtu puurrpa warrmarlatjarra pirninya  
\q2 pungkula-wanarayirnu wiyarnu.  
\q2 Palunyalu-lanya ngarltunytjulu tirtu kanyira.   
\q1
\v 21-22 Palunyalu Yitjurayilku tjamupirti-tjananya katingu  
\q2 tjarrpatjunu ngurra kalkurnu wantitjala.  
\q2 Palunyalu-lanya ngarltunytjulu tirtu kanyira.   
\q1
\v 23-24 Nyangka yanyan-yanyanpa nyinapayilu-lanya pika pungkulanyangka  
\q2 Mama Kuurrtu-lanya nyakulalpi paalytjunu kanyirnu.  
\q2 Palunyalu-lanya ngarltunytjulu tirtu kanyira.   
\q1
\v 25 Yuwa, Mama Kuurrtu yarnangu-lanya  
\q2 puru yanamulpa pirninya parltjara kanyilpayi.  
\q2 Palunyalu-lanya ngarltunytjulu tirtu kanyira.   
\q1
\v 26 Marninypungama-la Mama Kuurrnga  
\q2 yilkaringka nyinarranytjanya.  
\q2 Palunyalu-lanya ngarltunytjulu tirtu kanyira.   
\c 146  
\s1 Mama Kuurrnga-la Pukurltu Marninypungama  
\q1
\v 1 Mama Kuurrnga-rna marninypungama.  
\q2 Kurrurntutarrartu-rna Mama Kuurrnga marninypungama.   
\q1
\v 2 Turlku yinkarra-rna Mama Kuurrnga marninypungama.  
\q1 Marninypungkulayilku-rna ma-mirrirriku.   
\b  
\q1
\v 3 Kulilku-kurlu-yan mula-mularriku wati-ya puurrpa nyinarranyangka. Wanti-ya.  
\q2 Tjiinyanta-ya yarnangulu wankalkitjamunu.   
\q1
\v 4 Tjiinya-ya mirrirringkulalpi marlaku mantarriku.  
\q2 Nyangka ngarnmanymara-ya watjaranytjanya yutirrikitjamunu.   
\b  
\q1
\v 5 Mama Kuurrnga tjiinya Tjayikapalu pupakatirra marninypungkulanytja,  
\q2 palunyalu-lanya yirringkankupayi tjiinya-lan mula-mularringkula kuliranyangka.  
\q2 Nyangka palunyalanguru-la walykumunu nyinama.   
\q1
\v 6 Mama Kuurrtu manta yilkari puru kapi purlkanyatarrartu palyarnu,  
\q2 puru kutjupa-kutjupa mantangkatja yilkaringkatja kapingkatjatarrartu nyinarranytjanya.  
\q2 Palunyalu watjarnu wantitjatjanulu tjukarurrulu palyalpayi.   
\q1
\v 7 Mama Kuurrtu-tjananya yarnangu mungutja pirni yirringkankupayi  
\q2 kutjupalu-tjananya kurrara kanyiranyangka.  
\q1 Palunyalu nungkumunu pirniku mirrka nintilpayi.  
\b  
\q1 Mama Kuurrtu tjayilpangka nyinarranytjanya walatjunkupayi.   
\q1
\v 8 Palunyalu kurutjarra pirninya kuru yarlalpayi.  
\q1 Nyangka-tjinguru kutjupanya punkannyangka  
\q2 Mama Kuurrtu katura katirrayilpayi.  
\q1 Palunyalu yarnangu nyarra tjukarurru-ya nyinapayinya  
\q2 mukulyanytjulu kanyilpayi.   
\q1
\v 9 Mama Kuurrtu maliki pirninya miranykanyira kanyilpayi  
\q2 ngurra kutjupanguru-ya pitjangu nyinarranyangka.  
\q1 Puru Mama Kuurrtu-tjananya yirringkara kanyilpayi  
\q2 tjiinya-ya minyma parnaltji puru tjilku wangulyara nyinarranyangka.  
\q1 Palunyalu yarnangu nyarra palyamunu pirninya wiyalpayi.   
\b  
\q1
\v 10 Nyangka Mama Kuurrnga puurrpa purlkanya tirtu nyinaku nyinama.  
\q1 Yarnangu pirni, ngurra ngaa Yitjurayilta-yan nyinarra,  
\q2 kulila-ya.  
\q1 Mama Kuurrnga, tjiinya-yan pupakatirra marninypungkupayinya  
\q2 puurrpa purlkanya tirtu nyinaku nyinama.  
\q1 Nyangka-ya Mama Kuurrnga tirtu marninypungama.  
\b  
\p Yuwa, palunya.   