\id 3JN - Yaouré NT [yre] -Côte d'Ivoire 1999 (web version -2013 bd) 
\h 3 Zan 
\toc1 'Fluba yaagazan nɛn Zan -a crɛn -tɛ 
\toc2 3 Zan 
\toc3 3 Zan 
\mt2 'Fluba yaagazan nɛn 
\mt1 Zan 
\mt2 -a crɛn -tɛ 
\c 1  
\p  
\v 1 'An 'bɔ 'gʋɛ, an ya -leglizi min ceje -tʋ -a, mɛɛn 'fluba 'gʋɛ -a crɛn -tɛ. Maan crɛn -tɛ 'an bee Gai nɛn maan ye "yi 'kpa bɛ -yrɛ. 
\p  
\v 2 'An bee, an Bali trʋ "baa 'nan, 'wɩ pɛɛnɔn 'e drɛ 'yiɛ "yi, 'nan 'i 'kɔn 'i 'belidɩ 'i kɔlɛbo 'ji. Maan -tɔa 'nan, Bali 'lɛ bɛ 'i lei a 'e 'belidɩ.  
\v 3 Kɔɔ -kaa "bʋɩ Zozinɔn -mienun -ta 'gʋ, ɛn zɩ i cɩ 'wɩ tɩglɩ -sru "bɛ, 'lee zɩ i 'ta wʋla "da "bɛ, waa 'vɩ 'mɛn. 'Wɩ zɩɛ yaan 'ci nran 'kpa.  
\v 4 'Wɩ 'pee 'ka "nyian 'an 'ci nranman -e 'bɛ 'mlin -a mandɩ 'nan 'mɛn 'nɛnnun 'ta wʋla 'wɩ tɩglɩ -sru "bɛ -a da dɩ. 
\s1 Zan Gai 'tɔ "yi 'vɩ 
\p  
\v 5 'An bee, i 'wɩ dra 'i 'ci -a -tʋwli 'i "bʋɩ Zozinɔn lɛ. -Te yi'a o tɔa dɩ oo, yia dra -wlɛ "nyian zɩ.  
\v 6 Minnun zɩɛ, o 'yie min yɩdɩ "yi 'vɩ -leglizi -ji 'nɔn lɛ 'gʋ. Mɛin trʋ "baa, -te o "ta -ko fɛ pee -nan bɛ, 'i 'pa o va. -Yɛɛ cɩ Bali ci 'sɔ wɩnun -a.  
\v 7 O 'si 'wee vɛ -nan 'nan -e 'o Zozi Crizi -le 'nyranman 'pa. Wa'a 'wɩlɛ "man -e minnun nɛn wa'a tian -sɔɔnlɛa Zozi -sru "dɩɛ, 'o o lɔ fɛ 'si dɩ.  
\v 8 'Wɩ zɩɛ -yee "wɛan bɛ, -kaa nɛn -kaa -sɔɔnla Zozi -sru "bɛ, -kaa 'pa minnun zɩɛ o va. Zɩ -kaa "paa o va 'wɩ tɩglɩ fuiladɩ -a "man zɩɛ. 
\s1 Zan min -tʋ nɛn waa laabo Diotrɛfu bɛ -yee 'wɩ 'vɩ 
\p  
\v 9 An 'wɩ -mie crɛn -tɛ 'e tɛdɛ, maan 'pa 'sia -leglizi nɛn Diotrɛfu cɩ -ji bɛ, -a -ji 'nɔn lɛ. 'Pian Diotrɛfu 'bɔ nɛn e cɩ "vale 'e dra o tazan -a bɛ, 'wɩ nɛn maan 'vɩ bɛ, ya'a 'silɛa "da "dɩ.  
\v 10 -Yee "wɛan -te an 'bɔla 'nan nun bɛ, 'wɩ 'wlidɩ pɛɛnɔn nɛn yaa dra bɛ, maan ta bɔala. E "we 'kʋ man -wlidɩ, ɛn e 'wlu -sɛan 'kʋ man. 'Pian 'bɛ nɛn zɩɛ 'bɛ 'ka -a ci sɔa dɩ. -Kaa "bʋɩ Zozinɔn nɛn o bɔala "va "bɛ, ya'a 'we "man -e 'o 'fʋ -yee "kɔnnɛn "dɩ. Ɛn -te min nɛn e -kʋ min zɩɛ -a 'yee "kɔnnɛn "bɛ, yaa san -pian -leglizi -ji. 
\p  
\v 11 'An bee, te 'i 'wɩ nɛn e cɩ -wlidɩ "bɛ -a -nan yɩ min lɔ -e 'i drɛ dɩ. 'Pian 'wɩ "yi "nɛn 'i drɛ. Min nɛn e 'wɩ "yi "dra bɛ, te Bali -le 'nɛn nɛn -a san -a. Ɛn min nɛn e 'wɩ 'wlidɩ "dra bɛ, te ya'a Bali tɔa dɩ. 
\s1 Zan min -tʋ nɛn waa laabo Demetri bɛ -yee 'wɩ 'vɩ 
\p  
\v 12 Demetri -le vɛ bɛ, min pɛɛnɔn -yee 'wɩ "yi "ve. Ɛn 'wɩ tɩglɩ nɛn e 'ta wʋla "da "bɛ -yɛɛ 'tɔ "yi bɔala "nyian. 'Kʋ 'bɔ 'gʋ, "kʋ 'tɔ "yi "ve "nyian, ɛn yia -tɔa 'nan 'wɩ nɛn kʋa ve bɛ, 'wɩ 'kpa nɛn. 
\p  
\v 13 'Wɩ "kaga "a 'an 'ji -e 'an vɩ 'yiɛ, 'pian an 'ka "vale 'an crɛn -tɛa "dɩ.  
\v 14 Maan "nrɔnman 'nan tʋ -fʋ "wɛnnɔn -e 'kʋ cin yɩ, -e 'kʋ -sɛɛ "wʋ 'kʋ cin yei. 
\p  
\v 15 'I 'fʋ -trɔɔ! 'I beenun "we 'i 'va, ɛn an "we 'kʋ beenun pɛɛnɔn 'va 'tʋdʋ.