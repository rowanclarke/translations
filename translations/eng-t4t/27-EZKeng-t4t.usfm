\v 19 \w Therefore|strong="H3651"\w*, \w this|strong="H3651"\w* \w is|strong="H3651"\w* \w what|strong="H3541"\w* \add I\add*, \w Yahweh|strong="H3068"\w* \w the|strong="H3605"\w* \w Lord|strong="H3069"\w*, say: \w Because|strong="H3282"\w* \w you|strong="H3605"\w* \w have|strong="H1961"\w* \w all|strong="H3605"\w* \w become|strong="H1961"\w* \add like\add* \w dross|strong="H5509"\w*/\w slag|strong="H5509"\w*, \w I|strong="H2005"\w* \w will|strong="H1961"\w* \w gather|strong="H6908"\w* \w you|strong="H3605"\w* \w in|strong="H8432"\w* \w Jerusalem|strong="H3389"\w*.  
