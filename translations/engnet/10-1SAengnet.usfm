\c 12  
\p
\v 1  \w Samuel|strong="H8050"\w* \w said|strong="H8085"\w* \w to|strong="H3478"\w* \w all|strong="H3605"\w* \w Israel|strong="H3478"\w*, “\w I|strong="H2009"\w* \w have|strong="H3478"\w* \w done|strong="H3478"\w* \w everything|strong="H3605"\w* \w you|strong="H3605"\w* requested. \w I|strong="H2009"\w* \w have|strong="H3478"\w* \w given|strong="H8085"\w* \w you|strong="H3605"\w* \w a|strong="H3068"\w* \w king|strong="H4428"\w*.  
