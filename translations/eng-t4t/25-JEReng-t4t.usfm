\p
\v 1 \w King|strong="H4428"\w* \w Nebuchadnezzar|strong="H5019"\w* \w of|strong="H4428"\w* Babylon \w came|strong="H1961"\w* \w with|strong="H3068"\w* \w the|strong="H3605"\w* \w armies|strong="H2428"\w* \w of|strong="H4428"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w kingdoms|strong="H4467"\w* \w that|strong="H5971"\w* \w he|strong="H3068"\w* \w ruled|strong="H4428"\w*, \w and|strong="H3068"\w* \w they|strong="H3068"\w* \w fought|strong="H3898"\w* \w against|strong="H5921"\w* \w Jerusalem|strong="H3389"\w* \w and|strong="H3068"\w* \w the|strong="H3605"\w* \w other|strong="H3605"\w* \w towns|strong="H5892"\w* \add in Judah\add*. \w At|strong="H5921"\w* \w that|strong="H5971"\w* \w time|strong="H1961"\w*, \w Yahweh|strong="H3068"\w* \w gave|strong="H1961"\w* \w me|strong="H5921"\w* \w this|strong="H1697"\w* \w message|strong="H1697"\w*:  
\v 2 “\w Go|strong="H1980"\w* \w to|strong="H1980"\w* \w Zedekiah|strong="H6667"\w* \w the|strong="H5414"\w* \w King|strong="H4428"\w* \w of|strong="H4428"\w* \w Judah|strong="H3063"\w*, \w and|strong="H1980"\w* \w say|strong="H3478"\w* \w to|strong="H1980"\w* \w him|strong="H5414"\w*, ‘\w This|strong="H2063"\w* \w is|strong="H3068"\w* \w what|strong="H3541"\w* \w Yahweh|strong="H3068"\w*, \w the|strong="H5414"\w* \w God|strong="H3068"\w* whom \w we|strong="H3068"\w* Israelis \add worship\add*, \w says|strong="H3541"\w*: “\w I|strong="H2005"\w* \w am|strong="H3068"\w* \w about|strong="H1980"\w* \w to|strong="H1980"\w* enable \w the|strong="H5414"\w* army \w of|strong="H4428"\w* \w the|strong="H5414"\w* \w King|strong="H4428"\w* \w of|strong="H4428"\w* Babylon \w to|strong="H1980"\w* capture \w this|strong="H2063"\w* \w city|strong="H5892"\w*, \w and|strong="H1980"\w* \w they|strong="H3068"\w* \w will|strong="H3068"\w* \w burn|strong="H8313"\w* \w it|strong="H5414"\w* \w down|strong="H1980"\w*.  
\v 3 \w You|strong="H3588"\w* \w will|strong="H4428"\w* \w not|strong="H3808"\w* \w escape|strong="H4422"\w* \w from|strong="H3027"\w* \w them|strong="H5414"\w*; \w they|strong="H3588"\w* \w will|strong="H4428"\w* \w capture|strong="H8610"\w* \w you|strong="H3588"\w* \w and|strong="H4428"\w* \w take|strong="H8610"\w* \w you|strong="H3588"\w* \w to|strong="H1696"\w* \w the|strong="H7200"\w* \w king|strong="H4428"\w* \w of|strong="H4428"\w* Babylon. \w And|strong="H4428"\w* \add then\add* \w they|strong="H3588"\w* \w will|strong="H4428"\w* \w take|strong="H8610"\w* \w you|strong="H3588"\w* \w to|strong="H1696"\w* Babylon.” ’   
\p
\v 4 \w But|strong="H3808"\w* \w King|strong="H4428"\w* \w Zedekiah|strong="H6667"\w*, \w listen|strong="H8085"\w* \w to|strong="H4191"\w* \w this|strong="H3541"\w* \w that|strong="H8085"\w* \w Yahweh|strong="H3068"\w* \w has|strong="H3068"\w* \w promised|strong="H3068"\w*: ‘\w You|strong="H5921"\w* \w will|strong="H3068"\w* \w not|strong="H3808"\w* \w be|strong="H4191"\w* \w killed|strong="H4191"\w* \w in|strong="H5921"\w* \w a|strong="H3068"\w* battle [MTY];  
\v 5 \w you|strong="H3588"\w* \w will|strong="H3068"\w* \w die|strong="H4191"\w* \w peacefully|strong="H7965"\w*. \add When you die\add*, \w people|strong="H1696"\w* \w will|strong="H3068"\w* \w burn|strong="H8313"\w* incense \w to|strong="H1696"\w* honor/remember \w you|strong="H3588"\w* \w just|strong="H1697"\w* \w as|strong="H1697"\w* \w they|strong="H3588"\w* \w did|strong="H3651"\w* \w for|strong="H3588"\w* \w your|strong="H3068"\w* \w ancestors|strong="H7223"\w* \w who|strong="H3068"\w* \w were|strong="H1961"\w* \w kings|strong="H4428"\w* \w before|strong="H6440"\w* \w you|strong="H3588"\w* \w became|strong="H1961"\w* \w king|strong="H4428"\w*. \w They|strong="H3588"\w* \w will|strong="H3068"\w* \w mourn|strong="H5594"\w* \w for|strong="H3588"\w* \w you|strong="H3588"\w*, \w crying|strong="H4191"\w*, “\w We|strong="H3588"\w* \w are|strong="H1697"\w* \w very|strong="H3651"\w* sad \w that|strong="H3588"\w* \w our|strong="H3068"\w* \w king|strong="H4428"\w* \w is|strong="H3068"\w* \w dead|strong="H4191"\w*!” \w I|strong="H3588"\w*, \w Yahweh|strong="H3068"\w*, \w promise|strong="H1697"\w* \w that|strong="H3588"\w* \w will|strong="H3068"\w* \w happen|strong="H1961"\w*.’ ”   
\p
\v 6  \add So\add* \w I|strong="H1697"\w* \w took|strong="H4428"\w* \w that|strong="H3605"\w* \w message|strong="H1697"\w* \w to|strong="H1696"\w* \w King|strong="H4428"\w* \w Zedekiah|strong="H6667"\w*.  
\v 7 \w At|strong="H5921"\w* \w that|strong="H3588"\w* \w time|strong="H5921"\w* \w the|strong="H3605"\w* \w army|strong="H2428"\w* \w of|strong="H4428"\w* Babylonia \w had|strong="H4428"\w* surrounded \w Jerusalem|strong="H3389"\w* \w and|strong="H3063"\w* \w Lachish|strong="H3923"\w* \w and|strong="H3063"\w* \w Azekah|strong="H5825"\w*. \w Those|strong="H3605"\w* \add three\add* \w cities|strong="H5892"\w* \w were|strong="H3063"\w* \w the|strong="H3605"\w* \w only|strong="H3588"\w* \w cities|strong="H5892"\w* \w in|strong="H5921"\w* \w Judah|strong="H3063"\w* \w that|strong="H3588"\w* \w had|strong="H4428"\w* high walls \w around|strong="H5921"\w* \w them|strong="H5921"\w* \w that|strong="H3588"\w* \w still|strong="H3588"\w* \w had|strong="H4428"\w* \w not|strong="H3588"\w* \w been|strong="H3605"\w* captured.   
\s1 Jeremiah warned them they would be punished for not freeing their slaves  
\p
\v 8 \w King|strong="H4428"\w* \w Zedekiah|strong="H6667"\w* \w had|strong="H3068"\w* decreed \w that|strong="H5971"\w* \w the|strong="H3605"\w* \w people|strong="H5971"\w* must free \w their|strong="H3605"\w* slaves.  
\v 9  \add He decreed that\add* \w the|strong="H5647"\w* people must \w free|strong="H2670"\w* \w their|strong="H5647"\w* \w Hebrew|strong="H5680"\w* \w slaves|strong="H5650"\w*, \add both the\add* \w men|strong="H5650"\w* \w slaves|strong="H5650"\w* \w and|strong="H7971"\w* \w the|strong="H5647"\w* \w women|strong="H5680"\w* \add slaves\add*. \w No|strong="H1115"\w* one \w would|strong="H5650"\w* \w be|strong="H5650"\w* allowed \w to|strong="H7971"\w* force \w a|strong="H3068"\w* fellow \w Jew|strong="H3064"\w* \w to|strong="H7971"\w* \add continue to\add* \w be|strong="H5650"\w* \w his|strong="H7971"\w* \w slave|strong="H5650"\w*.  
\v 10 \w The|strong="H3605"\w* \w officials|strong="H8269"\w* \w and|strong="H7971"\w* \w the|strong="H3605"\w* rest \w of|strong="H8269"\w* \w the|strong="H3605"\w* \w people|strong="H5971"\w* \w had|strong="H5971"\w* \w obeyed|strong="H8085"\w* \add what the king decreed\add*,  
\v 11 \w but|strong="H3651"\w* later \w they|strong="H3651"\w* changed \w their|strong="H7725"\w* minds. \w They|strong="H3651"\w* \w forced|strong="H3533"\w* \w the|strong="H7725"\w* \w men|strong="H5650"\w* \w and|strong="H7971"\w* \w women|strong="H8198"\w* whom \w they|strong="H3651"\w* \w had|strong="H5650"\w* \w freed|strong="H2670"\w* \w to|strong="H7725"\w* \w become|strong="H7725"\w* \w their|strong="H7725"\w* \w slaves|strong="H5650"\w* \w again|strong="H7725"\w*.   
\p
\v 12  \add So\add* \w Yahweh|strong="H3068"\w* \w gave|strong="H1961"\w* \w me|strong="H1697"\w* \w this|strong="H1697"\w* \w message|strong="H1697"\w* \add to tell to them\add*:  
\v 13 “\w I|strong="H3117"\w*, \w Yahweh|strong="H3068"\w*, \w the|strong="H3541"\w* \w God|strong="H3068"\w* whom \w you|strong="H3117"\w* Israelis \add say you belong to\add*, ◄\w made|strong="H3772"\w* \w an|strong="H3772"\w* \w agreement|strong="H1285"\w* \w with|strong="H1004"\w*/\w gave|strong="H3318"\w* \w this|strong="H3541"\w* command \w to|strong="H3318"\w*► \w your|strong="H3068"\w* ancestors \add long ago\add*, \w when|strong="H3117"\w* \w I|strong="H3117"\w* rescued \w them|strong="H3318"\w* \w from|strong="H3318"\w* \w being|strong="H1004"\w* \w slaves|strong="H5650"\w* \w in|strong="H3478"\w* \w Egypt|strong="H4714"\w*.  
\v 14 \w I|strong="H3808"\w* \w told|strong="H8085"\w* \w them|strong="H7971"\w* \w that|strong="H8085"\w* \w they|strong="H3808"\w* \w must|strong="H3808"\w* \w free|strong="H2670"\w* \w all|strong="H7971"\w* \w their|strong="H8085"\w* \w Hebrew|strong="H5680"\w* \w slaves|strong="H5647"\w* \w after|strong="H7093"\w* \w the|strong="H8085"\w* \w slaves|strong="H5647"\w* \w had|strong="H7093"\w* \w worked|strong="H5647"\w* \w for|strong="H7971"\w* \w them|strong="H7971"\w* \w for|strong="H7971"\w* \w six|strong="H8337"\w* \w years|strong="H8141"\w*. \w But|strong="H3808"\w* \w your|strong="H5186"\w* ancestors \w did|strong="H3808"\w* \w not|strong="H3808"\w* \w pay|strong="H5186"\w* \w any|strong="H3808"\w* \w attention|strong="H8085"\w* \w to|strong="H7971"\w* \w what|strong="H8085"\w* \w I|strong="H3808"\w* \w said|strong="H8085"\w*.  
\v 15 \w Recently|strong="H3117"\w*, \w you|strong="H6440"\w* obeyed \w my|strong="H5921"\w* \w command|strong="H5921"\w* \w and|strong="H7725"\w* \w stopped|strong="H7725"\w* \w doing|strong="H6213"\w* \w what|strong="H3477"\w* \w was|strong="H8034"\w* wrong \w and|strong="H7725"\w* \w did|strong="H6213"\w* \w what|strong="H3477"\w* \w was|strong="H8034"\w* \w right|strong="H3477"\w*. \w You|strong="H6440"\w* \w made|strong="H6213"\w* \w a|strong="H3068"\w* solemn \w agreement|strong="H1285"\w* \w at|strong="H5921"\w* \w my|strong="H5921"\w* \w temple|strong="H1004"\w* \add that you would free your slaves\add*, \w and|strong="H7725"\w* \add then\add* \w you|strong="H6440"\w* \w freed|strong="H3772"\w* \w them|strong="H5921"\w*.  
\v 16 \w But|strong="H1961"\w* \w now|strong="H1961"\w* \w you|strong="H7971"\w* \w have|strong="H1961"\w* disregarded what \w you|strong="H7971"\w* solemnly promised, \w and|strong="H7971"\w* \w you|strong="H7971"\w* \w have|strong="H1961"\w* shown \w contempt|strong="H5315"\w* \w for|strong="H8034"\w* what \w I|strong="H5315"\w* [MTY] said \w by|strong="H8034"\w* taking \w back|strong="H7725"\w* \w the|strong="H7725"\w* \w women|strong="H8198"\w* \w and|strong="H7971"\w* \w men|strong="H5650"\w* whom \w you|strong="H7971"\w* \w had|strong="H1961"\w* \w freed|strong="H2670"\w* \w and|strong="H7971"\w* said \w they|strong="H5315"\w* could \w live|strong="H8034"\w* wherever \w they|strong="H5315"\w* wanted \w to|strong="H7725"\w*. \add Now\add* \w you|strong="H7971"\w* \w have|strong="H1961"\w* \w forced|strong="H3533"\w* \w them|strong="H7725"\w* \w to|strong="H7725"\w* \w be|strong="H1961"\w* \w your|strong="H7725"\w* \w slaves|strong="H5650"\w* \w again|strong="H7725"\w*.   
\p
\v 17 \w Therefore|strong="H3651"\w*, \w this|strong="H3651"\w* \w is|strong="H3068"\w* \w what|strong="H3541"\w* \add I\add*, \w Yahweh|strong="H3068"\w*, say: ‘\w Because|strong="H3651"\w* \w you|strong="H5414"\w* \w have|strong="H3068"\w* \w not|strong="H3808"\w* \w obeyed|strong="H8085"\w* \w me|strong="H5414"\w* \w by|strong="H3068"\w* freeing \w your|strong="H3068"\w* \w fellow|strong="H7453"\w* Israelis, \w I|strong="H2005"\w* \w will|strong="H3068"\w* free \w you|strong="H5414"\w* \w to|strong="H3068"\w* \add be destroyed by\add* \w the|strong="H3605"\w* \w swords|strong="H2719"\w* \add of your enemies\add* \w and|strong="H3068"\w* \w by|strong="H3068"\w* famines \w and|strong="H3068"\w* \w diseases|strong="H1698"\w*. \w All|strong="H3605"\w* \w the|strong="H3605"\w* \w nations|strong="H4467"\w* \w of|strong="H3068"\w* \w the|strong="H3605"\w* earth \w will|strong="H3068"\w* \w be|strong="H3808"\w* \w horrified|strong="H2113"\w* \w because|strong="H3651"\w* \w of|strong="H3068"\w* \add what happens to\add* \w you|strong="H5414"\w*.  
\v 18-19 Because you have disregarded what I said in my agreement with you, I will do to you just like you did to the calves that you cut in half to show that you would surely do what you solemnly promised that you would do. I will \add enable your enemies to\add* cut you into pieces, you officials of Judah and you officials of Jerusalem, and you officials in the palace, and you priests and all you common people. I will do that because you have disregarded what you solemnly promised \add about freeing your slaves\add*.  
\v 20 \w I|strong="H5414"\w* \w will|strong="H1961"\w* enable \w your|strong="H5414"\w* \w enemies|strong="H3027"\w* \w to|strong="H1961"\w* capture \w you|strong="H5414"\w*, \w and|strong="H8064"\w* \w they|strong="H5315"\w* \w will|strong="H1961"\w* kill \w you|strong="H5414"\w*. \w And|strong="H8064"\w* \w your|strong="H5414"\w* \w bodies|strong="H5038"\w* \w will|strong="H1961"\w* \w be|strong="H1961"\w* \w food|strong="H3978"\w* \w for|strong="H3027"\w* vultures \w and|strong="H8064"\w* wild \w animals|strong="H1961"\w*.   
\p
\v 21 \w I|strong="H5414"\w* \w will|strong="H4428"\w* enable \w the|strong="H5921"\w* \w army|strong="H2428"\w* \w of|strong="H4428"\w* \w the|strong="H5921"\w* \w king|strong="H4428"\w* \w of|strong="H4428"\w* Babylon \w to|strong="H5927"\w* capture \w King|strong="H4428"\w* \w Zedekiah|strong="H6667"\w* \w and|strong="H3063"\w* \w his|strong="H5414"\w* \w officials|strong="H8269"\w*. \w Although|strong="H5921"\w* \w the|strong="H5921"\w* \w king|strong="H4428"\w* \w of|strong="H4428"\w* Babylon \w and|strong="H3063"\w* \w his|strong="H5414"\w* \w army|strong="H2428"\w* \w have|strong="H3063"\w* \w left|strong="H5414"\w* Jerusalem \add for a short time\add*,  
\v 22 \w I|strong="H2005"\w* \w will|strong="H3068"\w* summon \w them|strong="H5414"\w* \w back|strong="H7725"\w* \w again|strong="H7725"\w*. \add This time\add*, \w they|strong="H3068"\w* \w will|strong="H3068"\w* \w fight|strong="H3898"\w* \w against|strong="H5921"\w* \w this|strong="H2063"\w* \w city|strong="H5892"\w* \w and|strong="H3063"\w* \w capture|strong="H3920"\w* \w it|strong="H5414"\w* \w and|strong="H3063"\w* \w burn|strong="H8313"\w* \w it|strong="H5414"\w* \w down|strong="H3427"\w*. \w I|strong="H2005"\w* \w will|strong="H3068"\w* \w make|strong="H5414"\w* \add sure\add* \w that|strong="H3068"\w* \w all|strong="H5414"\w* \w the|strong="H5002"\w* \w towns|strong="H5892"\w* \w in|strong="H3427"\w* \w Judah|strong="H3063"\w* \w are|strong="H3068"\w* destroyed, \add with the result that\add* \w no|strong="H5414"\w* \w one|strong="H3068"\w* \w will|strong="H3068"\w* \w live|strong="H3427"\w* \w there|strong="H3427"\w* \add any more\add*.’ ”   
\c 35  
\s1 The lesson from the Rechabites  
\p
\v 1  \add Several years earlier,\add* \w when|strong="H1961"\w* \w Jehoiakim|strong="H3079"\w* \w was|strong="H3068"\w* \w the|strong="H3068"\w* \w King|strong="H4428"\w* \w of|strong="H1121"\w* \w Judah|strong="H3063"\w*, \w Yahweh|strong="H3068"\w* \w gave|strong="H1961"\w* \w me|strong="H1961"\w* \w this|strong="H1697"\w* \w message|strong="H1697"\w*:  
\v 2 “\w Go|strong="H1980"\w* \w to|strong="H1696"\w* \w the|strong="H3068"\w* \w place|strong="H1004"\w* \w where|strong="H1004"\w* \w families|strong="H1004"\w* \w of|strong="H1004"\w* \w the|strong="H3068"\w* Rechab clan \w live|strong="H1980"\w*. \w Invite|strong="H1696"\w* \w them|strong="H8248"\w* \w to|strong="H1696"\w* \w my|strong="H3068"\w* \w temple|strong="H1004"\w*. \add When they arrive,\add* \w take|strong="H1980"\w* \w them|strong="H8248"\w* \w into|strong="H1980"\w* \w one|strong="H1004"\w* \w of|strong="H1004"\w* \w the|strong="H3068"\w* \w inside|strong="H1004"\w* \w rooms|strong="H3957"\w* \w and|strong="H1980"\w* offer \w them|strong="H8248"\w* \add some\add* \w wine|strong="H3196"\w*.”   
\p
\v 3 \w So|strong="H3947"\w* \w I|strong="H1121"\w* \w went|strong="H1121"\w* \w to|strong="H1121"\w* see \w Jaazaniah|strong="H2970"\w* \w and|strong="H1121"\w* \w all|strong="H3605"\w* \w his|strong="H3605"\w* \w brothers|strong="H1121"\w* \w and|strong="H1121"\w* \w sons|strong="H1121"\w* \w who|strong="H3605"\w* represented \w the|strong="H3605"\w* Rechab clan. \w Jaazaniah|strong="H2970"\w* \w was|strong="H1004"\w* \w the|strong="H3605"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \add another man named\add* \w Jeremiah|strong="H3414"\w* \w and|strong="H1121"\w* \w grandson|strong="H1121"\w* \w of|strong="H1121"\w* \w Habazziniah|strong="H2262"\w*.  
\v 4 \w I|strong="H1121"\w* took \w them|strong="H1121"\w* \w to|strong="H3068"\w* \w the|strong="H8104"\w* \w temple|strong="H1004"\w*, \add and we went\add* into \w the|strong="H8104"\w* \w room|strong="H1004"\w* \w where|strong="H1004"\w* \w the|strong="H8104"\w* \w sons|strong="H1121"\w* \w of|strong="H1121"\w* \w Igdaliah|strong="H3012"\w*’s \w son|strong="H1121"\w* \w Hanan|strong="H2605"\w*, \w who|strong="H3068"\w* \w was|strong="H3068"\w* \w a|strong="H3068"\w* prophet, stayed. \w That|strong="H3068"\w* \w room|strong="H1004"\w* \w was|strong="H3068"\w* next \w to|strong="H3068"\w* \w the|strong="H8104"\w* \w room|strong="H1004"\w* \w that|strong="H3068"\w* \w was|strong="H3068"\w* used \w by|strong="H3068"\w* \w the|strong="H8104"\w* \w men|strong="H1121"\w* \w who|strong="H3068"\w* \w were|strong="H1121"\w* \w in|strong="H3068"\w* \w charge|strong="H8104"\w* \w of|strong="H1121"\w* \w the|strong="H8104"\w* entrances \w to|strong="H3068"\w* \w the|strong="H8104"\w* \w temple|strong="H1004"\w*. \w It|strong="H8104"\w* \w was|strong="H3068"\w* \w above|strong="H4605"\w* \w the|strong="H8104"\w* \w room|strong="H1004"\w* \w that|strong="H3068"\w* belonged \w to|strong="H3068"\w* \w Maaseiah|strong="H4641"\w*, \w who|strong="H3068"\w* \w was|strong="H3068"\w* \w the|strong="H8104"\w* \w temple|strong="H1004"\w* gatekeeper \w and|strong="H1121"\w* \w the|strong="H8104"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Shallum|strong="H7967"\w*.   
\p
\v 5 \w I|strong="H5414"\w* \w set|strong="H5414"\w* jugs \w of|strong="H1121"\w* \w wine|strong="H3196"\w* \w in|strong="H1004"\w* \w front|strong="H6440"\w* \w of|strong="H1121"\w* \w them|strong="H5414"\w* \w and|strong="H1121"\w* urged \w them|strong="H5414"\w* \w to|strong="H5414"\w* \w drink|strong="H8354"\w* some,  
