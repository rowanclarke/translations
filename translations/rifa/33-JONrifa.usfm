\id JON
\h يُونُوسْ
\toc1 يُونُوسْ
\toc2 يُونُوسْ
\toc3 يُون.
\mt1 يُونُوسْ
\c 1
\s1 ثَاروْڒَا ن يُونُوسْ
\m 
\v 1 أَوَاڒْ ن سِيذِي يُوسَا-د غَارْ يُونُوسْ، مِّيسْ ن أَمِيتَّايْ، إِنَّا:
\v 2 ”كَّارْ، رُوحْ غَارْ ثنْذِينْثْ ن نِينْوَا ثَامقّْرَانْثْ ؤُشَا بَارّحْ ضِيدّْ نّسْ مِينْزِي ثُوعفّْنَا نْسنْ ثْڭعّذْ \add أَمْ إِشْثْ ن أَرِّيحثْ يَارْصُوذنْ\add* أَڒْ ؤُذمْ إِنُو.“ \x ◘ \xo 1:‏2 \xt أَمز. 10‏:‏11، 12؛ يُون. 3‏:‏3\x*
\v 3 \add مَاشَا\add* يُونُوسْ إِكَّارْ حِيمَا أَذْ يَارْوڒْ زڭْ وُوذمْ ن سِيذِي. نتَّا إِهْوَا غَارْ \add ثنْذِينْثْ ن\add* يَافَا ؤُشَا يُوفَا \add ذِينْ\add* إِشْثْ ن ثْغَارَّابُوثْ أَذْ ثْرَاحْ غَارْ \add ثنْذِينْثْ ن\add* ثَارْشِيشْ. نتَّا إِخدْجصْ تَّامَانْ \add ن ؤُسَافَارْ\add* ؤُشَا إِنْيَا ذَايسْ مَاحنْذْ أَذْ إِرَاحْ غَارْ ثَارْشِيشْ، إِخْسْ أَذْ إِڭّْوجْ خْ وُوذمْ ن سِيذِي.
\v 4 \add مَاشَا\add* سِيذِي إِسّكّْ-د أَسمِّيضْ إِجْهذْ خْ ڒبْحَارْ ؤُشَا يَارْنِي إِذْوڒْ ذ ثَاحَارْيَاضْثْ ثَامقّْرَانْثْ خْ ڒبْحَارْ أَڒَامِي عْڒَاحَاڒْ ثِيوضْ أَذْ ثَارْژْ ثْغَارَّابُوثْ.
\v 5 ڭّْوذنْ إِبحْرِييّنْ ؤُشَا كُوڒْ أَرْيَازْ إِسْغُويْ، إِتَّارْ غَارْ أَربِّي نّسْ ؤُشَا نْضَارنْ ڒقْشُوعْ نِّي ذِي ثْغَارَّابُوثْ غَارْ ڒبْحَارْ حِيمَا أَذْ خَاسْ سّْنقْصنْ دّْقڒْ. ثُوغَا إِهْوَا-د يُونُوسْ مَاشَا غَارْ ؤُغزْذِيسْ أَضفَّارْ ن ثْغَارَّابُوثْ، إِزّڒْ ذِينْ ؤُشَا إِطّصْ إِجّْ ن يِيضصْ يُودْجغْ.
\v 6 يُوسَا-د غَارسْ بَابْ ن ثْغَارَّابُوثْ، إِنَّا أَسْ: ”مِينْ ثتّڭّذْ، مَايمِّي ذِينِّي ثطّْصذْ؟ كَّارْ، ڒَاغَا خْ أَربِّي نّشْ، أَذْ ثَاغْ أَربِّي نّشْ أَذْ أَنغْ إِفكَّارْ حِيمَا وَارْ نْغَارّقْ شَا.“
\v 7 نَّانْ يرْيَازنْ إِ وَايَاوْيَا: ”أَسْ-د، أجّْ أَنغْ أَذْ نْضَارْ ثَاقدُّوحْثْ، حِيمَا أَذْ نسّنْ وِي ذ أَنغْ إِڭِّينْ ذِي نّْعِي-يَا.“ نِيثْنِي نْضَارنْ ثَاقدُّوحْثْ ؤُشَا ثُوسَا-د ثْقدُّوحْثْ ذڭْ يُونُوسْ.
\m 
\v 8 \add خنِّي\add* نَّانْ أَسْ: ”إِنِي أَنغْ، مَايمِّي ذ أَنغْ ثحْكمْ نّْعِي-يَا. مِينْ ثعْنَا ڒْخذْمثْ نّشْ؟ مَانِيسْ د-ثُوسِيذْ؟ مِينْ ثعْنَا ثَامُّورْثْ نّشْ ؤُ زِي مَانْ ڒْڭنْسْ إِ غَارْ ثقّْنذْ؟“
\v 9 إِنَّا أَسنْ: ”نشّْ ذ أَعِيبْرَانِي ؤُشَا ڭّْوذغْ زِي سِيذِي، أَربِّي ن إِجنْوَانْ، ونِّي د-إِخڒْقنْ ڒبْحَارْ ذ ڒْبَارْ.“
\v 10 إِرْيَازنْ \add نِّي\add* ڭّْوذنْ أَطَّاسْ، نَّانْ أَسْ: ”مِينْ ثڭِّيذْ؟“ مِينْزِي ثُوغَا سّْننْ، نتَّا يَارْوڒْ-د زڭْ وُوذمْ ن سِيذِي، أَقَا ثُوغَا زعْمَا إِسّْخبَّارْ إِ-ثنْ.
\v 11 ؤُشَا نَّانْ أَسْ: ”مِينْ زَّايكْ إِ غَا نڭّْ، حِيمَا أَذْ خَانغْ إِهدّنْ ڒبْحَارْ؟“ مِينْزِي ڒبْحَارْ ثُوغَا عَاذْ يَارنِّي ذڭْ ؤُهَاجِي.
\v 12 إِنَّا أَسنْ: ”كْسِيمْ أَيِي ؤُ نْضَارمْ أَيِي ذِي ڒبْحَارْ حِيمَا أَذْ خَاومْ إِهدّنْ ڒبْحَارْ، مِينْزِي سّْنغْ أَقَا ثَاحَارْيَاضْثْ-أَ ثَامقّْرَانْثْ إِ خَاومْ د-إِوْضَانْ ذِي سِّيبّثْ إِنُو.“
\v 13 \add مَاشَا\add* إِرْيَازنْ ثُوغَا قدّْفنْ غَارْ ڒْبَارْ، مَاشَا وَارْ ذ أَسْ زمَّارنْ شَا، مِينْزِي ڒبْحَارْ ثُوغَا عَاذْ يَارنِّي خَاسنْ أَطَّاسْ س وَاطَّاسْ ذڭْ ؤُهَاجِي.
\v 14 \add خنِّي\add* ڒَاغَانْ إِ سِيذِي، نَّانْ: ”أَ سِيذِي، وَارْ ذ أَنغْ تّجِّي شَا أَذْ نتّْوَاهلّكْ ذِي سِّيبّثْ ن ڒعْمَارْ ن ورْيَازْ-أَ ؤُشَا وَارْ ذ أَنغْ ثْحسِّيبذْ خْ إِذَامّنْ إِمزْذَاڭنْ، مِينْزِي شكْ، أَ سِيذِي، ثڭِّيذْ مِينْ ذ أَشْ يَارْضَانْ.“
\v 15 \add خَاسْ ؤُشَا\add* طّْفنْ يُونُوسْ، نْضَارنْ ث ذِي ڒبْحَارْ. \add ڒخْذنِّي\add* إِبدّْ ؤُهَاجِي ن ڒبْحَارْ.
\v 16 ڭّْوْذنْ إِرْيَازنْ \add نِّي\add* أَطَّاسْ زِي سِيذِي ؤُشَا غَارْصنْ إِشْثْ ن ثْغَارْصْثْ إِ سِيذِي ؤُشَا وَاعْذنْ لْوُوعُوذْ.
\b
\b
\c 2
\s1 يُونُوسْ ذڭْ وسْڒمْ
\m 
\v 1 إِسّوْجذْ سِيذِي إِجّْ ن وسْڒمْ أَمقّْرَانْ حِيمَا أَذْ إِسّغْرِي يُونُوسْ ؤُشَا يُونُوسْ إِكَّا ثْڒَاثَا ن وُوسَّانْ ذ ثْڒَاثَا نْ دْجِييَاڒِي ذڭْ ؤُعذِّيسْ ن وسْڒمْ. \x ◘ \xo 2:‏1 \xt مت. 12‏:‏40؛ 16‏:‏4؛ لك. 11‏:‏30\x*
\v 2 ؤُشَا إِژُّودْجْ يُونُوسْ إِ سِيذِي، أَربِّي نّسْ، زڭْ ؤُعذِّيسْ ن وسْڒمْ.
\v 3 إِنَّا:
\b
\m \qt “زِي ڒحْصَارثْ إِنُو ڒَاغِيغْ إِ سِيذِي\qt*
\m \qt ؤُ نتَّا يَارَّا-د خَافِي.\qt*
\m \qt زڭْ وحْوِيشْ ن ڒَاخَارْثْ ڒَاغِيغْ\qt*
\m \qt ؤُشَا شكْ ثسْڒِيذْ إِ ثْمِيجَّا إِنُو.\qt* \x ◘ \xo 2:‏3 \xt إِزهد. 120‏:‏1\x*
\m 
\v 4 \qt ثُوغَا ثنْضَارذْ أَيِي ذِي ڒَادْجَاغْ،\qt*
\m \qt ذڭْ وُوڒْ ن ڒبْحُورْ،\qt*
\m \qt ثنّْضنْ أَيِي-د ڒمْوَاجْ.\qt*
\m \qt مَارَّا زّْهِيرْ نّشْ ذ ڒمْوَاجْ نّشْ\qt*
\m \qt كِّينْ-د خَافِي سنّجْ.\qt* \x ◘ \xo 2:‏4 \xt إِزهد. 42‏:‏8\x*
\m 
\v 5 \qt نِّيغْ: ’نشّْ تّْوَاسُّوفّْغغْ\qt*
\m \qt زِي زَّاثْ إِ وُوذمْ نّشْ.\qt*
\m \qt عَاذْ أَذْ ثْوَاڒِيغْ عَاوذْ\qt*
\m \qt زَّاوشْثْ نّشْ ثَامقّْرَانْثْ إِقدّْسنْ.‘\qt* \x ◘ \xo 2:‏5 \xt إِزهد. 31‏:‏23\x*
\m 
\v 6 \qt طّْفنْ أَيِي وَامَانْ\qt*
\m \qt أَڒْ مَانِي إِوْضنْ غَارْ ڒعْمَارْ إِنُو،\qt*
\m \qt \tl أَمَانْ\tl* إِهوْڒنْ نّْضنْ أَيِي-د،\qt*
\m \qt إِڒْصقْ-د أَرْبِيعْ ن ڒبْحَارْ ذڭْ ؤُزدْجِيفْ إِنُو.\qt*
\m 
\v 7 \qt هْوِيغْ غَارْ طّْرُوفَا يُودْجْغنْ قَاعْ ن إِذُورَارْ،\qt*
\m \qt \tl تّْوَابلّْعنْ\tl* زّكْرُونَاثْ ن ثمُّورْثْ خَافِي\qt*
\m \qt سنّجْ إِ ڒبْذَا،\qt*
\m \qt مَاشَا شكْ ثسّْڭعّْذذْ ثُوذَارْثْ إِنُو\qt*
\m \qt زِي ثُورْصُوضِي \tl ذڭْ وَامَانْ\tl*،\qt*
\m \qt \tl أَ\tl* سِيذِي، أَربِّي إِنُو!\qt*
\m 
\v 8 \qt ؤُمِي إِذوّخْ ڒعْمَارْ إِنُو ذَايِي،\qt*
\m \qt فكَّارغْ ذِي سِيذِي،\qt*
\m \qt ؤُ ثَاژَادْجِيثْ إِنُو ثْڭعّذْ غَاركْ،\qt*
\m \qt ذِي زَّاوشْثْ نّشْ ثَامقّْرَانْثْ إِقدّْسنْ.\qt* \f ◼ \fr 2:‏8 \ft \bd ’ذَايِي‘\bd* - س ثْعِيبْرَانِيثْ ’خَافِي‘.\f*
\m 
\v 9 \qt نِيثْنِي طّْفنْ ذِي \tl لْ-أَصْنَامْ\tl* إِبطّْڒنْ ذ إِغشّنْ،\qt*
\m \qt سمْحنْ ذِي ثْمخْسِيوْثْ نْسنْ إِشوَّارنْ.\qt*
\m 
\v 10 \qt \tl مَاشَا\tl* نشّْ أَذْ شكْ حمْذغْ\qt*
\m \qt س يِيشْثْ ن ثْمِيجَّا \tl ثشُّورْ\tl* س ؤُقَاذِي.\qt*
\m \qt مِينْ وَاعْذغْ، أَذْ \tl ث\tl* قفْڒغْ.\qt*
\m \qt أَسنْجمْ زِي سِيذِي.“\qt* \x ◘ \xo 2:‏10 \xt إِزهد. 3‏:‏9؛ 50‏:‏14، 23؛ 116‏:‏17؛ حُوش. 14‏:‏3؛ عبر. 13‏:‏15\x*
\b
\m 
\v 11 إِسِّيوڒْ سِيذِي أَكْ-ذ وسْڒمْ ؤُشَا إِعُوقّْ-د يُونُوسْ ذِي ڒْبَارْ.
\b
\b
\c 3
\s1 تُّوبثْ ن أَيْثْ ن نِينْوَا
\m 
\v 1 يُوسَا-د وَاوَاڒْ ن سِيذِي غَارْ يُونُوسْ إِ ثْوَاڒَا وِيسّْ ثْنَاينْ، إِنَّا:
\v 2 ”كَّارْ، رُوحْ غَارْ ثنْذِينْثْ ن نِينْوَا ثَامقّْرَانْثْ ؤُشَا بَارّحْ أَسنْ ثَابَارّحْثْ نِّي إِ ذ أَشْ غَا إِنِيغْ.“
\v 3 ؤُشَا إِكَّارْ يُونُوسْ، إِرُوحْ غَارْ نِينْوَا عْلَاحْسَابْ أَوَاڒْ ن سِيذِي. ثُوغَا نِينْوَا ذ إِشْثْ ن ثنْذِينْثْ ثَامقّْرَانْثْ س وَاطَّاسْ، أَقَا \add إِتّْخصَّا\add* ثِيشْڒِي ن ثْڒَاثَا ن وُوسَّانْ \add إِ ؤُشُوقِي\add*.
\v 4 يُوذفْ يُونُوسْ ثَانْذِينْثْ ثِيشْڒِي ن إِجّْ ن وَاسّْ ؤُشَا إِبَارّحْ، إِنَّا: ”أَوَارْنِي أَربْعِينْ ن وُوسَّانْ أَذْ ثتّْوَانقْڒبْ \add ثنْذِينْثْ ن\add* نِينْوَا.“
\v 5 إِرْيَازنْ ن نِينْوَا ؤُمْننْ ذِي أَربِّي ؤُشَا بَارّْحنْ س يِيجّْ ن ؤُژُومِّي ؤُشَا أَرْضنْ ثْخُونْشَايْ \add ن وشْضَانْ\add*، زڭْ ؤُمقّْرَانْ أَڒْ أَمژْيَانْ جَارْ أَسنْ. \x ◘ \xo 3:‏5 \xt مت. 12‏:‏41؛ لك. 11‏:‏32\x*
\v 6 يِيوضْ وَاوَاڒْ ؤُڒَا غَارْ ؤُجدْجِيذْ ن نِينْوَا ؤُشَا إِكَّارْ زِي ڒْكُورْسِي ن ڒْعَارْشْ نّسْ، إِكّسْ خَاسْ أَرُّوضْ نّسْ إِڭلّْذنْ، إِسّْذُورِييْ إِخفْ نّسْ س يِيشْثْ ن ثْخَانْشثْ \add ن وشْضَانْ\add* ؤُشَا إِقِّيمْ خْ يِيغّذْ.
\m 
\v 7 خْ ڒُومُورْ ن ؤُجدْجِيذْ \add جْمِيعْ أَكْ-ذ\add* أَيْثْ ن شُّورْفَا ڭِّينْ أَذْ بَارّْحنْ ذِي نِينْوَا، نَّانْ: ”وَارْ تّجِّيمْ بْنَاذمْ ذ ڒْمَاڒْ ذ إِفُونَاسنْ ذ ثْفُونَاسِينْ ذ وُودْجِي أَذْ شّنْ شَا، وَارْ ثنْ تّجِّيمْ أَذْ هْذَانْ ؤُڒَا أَذْ سْونْ. \f ◼ \fr 3:‏7 \ft \bd ’أَيْثْ ن شُّورْفَا‘\bd* - نِيغْ ’أَيْثْ ن ثَاصِيڒثْ‘.\f*
\v 8 جّمْ أَذْ يَارْضْ بْنَاذمْ ذ ڒْمَاڒْ ثِيخُونْشَايْ \add ن وشْضَانْ\add* ؤُشَا جّمْ ثنْ أَذْ سْغُوينْ س جّهْذْ غَارْ أَربِّي ؤُشَا أَذْ إِثُوبْ كُوڒْ  إِجّْ زڭْ وبْرِيذْ نّسْ أَعفَّانْ ؤُ زِي لْعُونْفْ \add إِ يُومْسنْ\add* غَارْ إِفَاسّنْ نّسْ.
\v 9 أَذْ ثَاغْ أَذْ إِنْذمْ أَربِّي ؤُشَا أَذْ إِثُوبْ ؤُشَا أَذْ إِبعّذْ خْ ڒْحَاذُوقْ ن وغْضَابْ نّسْ حِيمَا وَارْ نتّْوَاثْهلِّيكْ شَا.“ \x ◘ \xo 3:‏9 \xt يُووِ. 2‏:‏14\x*
\m 
\v 10 ؤُشَا إِژْرَا أَربِّي مِينْ ڭِّينْ، أَقَا ثُوبنْ خْ وبْرِيذْ نْسنْ أَعفَّانْ ؤُشَا إِنْذمْ أَربِّي خْ ڒْغَارْ نِّي ثُوغَا إِنَّا أَذْ كِيسنْ إِڭّْ ؤُشَا وَارْ ث إِڭِّي شَا.
\b
\b
\c 4
\s1 إِوبّخْ أَربِّي إِ يُونَا
\m 
\v 1 مَانْ أَيَا ثُوغَا ذ \add إِشْثْ ن ثْمسْڒَاشْثْ\add* ثَاعفَّانْثْ أَڒْ طَّارْفْ إِ يُونُوسْ ؤُشَا ثْهَاجْ ثفْقحْثْ نّسْ.
\v 2 إِژُّودْجْ إِ سِيذِي، إِنَّا: ”\add أَ\add* سِيذِي، مَا وَارْ نِّيغْ أَمُّو ؤُمِي ذ أَيِي ثُوغَا ذِي ثمُّورْثْ إِنُو؟ خْ ؤُيَا نْوِيغْ أَذْ ت جّغْ ؤُمِي ڭِّيغْ أَذْ أَروْڒغْ غَارْ ثَارْشِيشْ مِينْزِي نشّْ سّْنغْ بلِّي شكْ ذ إِجّْ ن أَربِّي ذ أَحْنِينْ ذ أَرْحِيمْ، غَاركْ تَّاسِيعْ ن ڒْخَاضَارْ ذ ثْمخْسِيوْثْ إِشوَّارنْ ثَامقّْرَانْثْ ؤُشَا ثْنذْمذْ أَذْ ثڭّذْ ڒْغَارْ. \x ◘ \xo 4:‏2 \xt ؤُف. 34‏:‏6؛ إِزهد. 86‏:‏5؛ يُووِ. 2‏:‏13\x*
\v 3 \add خنِّي\add* ڒخُّو، \add أَ\add* سِيذِي، كّسْ زَّايِي ڒعْمَارْ إِنُو، مِينْزِي إِتّْبَانْ أَيِي بلِّي ڒْموْثْ إِنُو حْسنْ زِي ثُوذَارْثْ إِنُو.“
\v 4 إِنَّا سِيذِي: ”مَا ثشْنَا ؤُمِي ثْخيّْقذْ أَمُّو؟“
\m 
\v 5 إِفّغْ يُونُوسْ زِي ثنْذِينْثْ ؤُشَا إِرُوحْ إِقِّيمْ ذِي جِّيهثْ ن شَّارْقْ ن ثنْذِينْثْ مَانِي إِڭَّا إِ يِيخفْ نّسْ ثَاسقَّافْثْ ن إِفثْوَانْ ؤُشَا إِقِّيمْ سْوَادَّايْ نّسْ ذِي ثِيڒِي مَاحنْذْ أَذْ إِژَارْ مِينْ غَا إِمْسَارنْ إِ ثنْذِينْثْ.
\v 6 ثُوغَا سِيذِي أَربِّي إِسّوْجذْ إِشْثْ ن ثْشجَّارْثْ ن ؤُثبْهثْ ؤُشَا إِجَّا-إِ-ت أَذْ ثيْمَا ثُوعْڒَا خْ يُونُوسْ حِيمَا أَذْ ثِيڒِي ذ ثِيڒِي خْ ؤُزدْجِيفْ نّسْ ؤُ حِيمَا أَذْ إِكّسْ ؤُخيّقْ نّسْ. إِفَارْحْ يُونُوسْ أَطَّاسْ خْ ثْشجَّارْثْ-أَ ن ڒعْجبْ.
\v 7 مَاشَا غَارْ ڒفْجَارْ ن ثْوشَّا ن وَاسّْ إِ د-إِضْفَارنْ إِسّوْجذْ أَربِّي إِشْثْ ن ثْكشَّا نِّي ثسّحْڒشْ ثَاشجَّارْثْ ن ؤُثبْهثْ نِّي أَڒَامِي ثُوژغْ.
\v 8 أَڒَامِي د-ثنْقَارْ ثْفُوشْثْ، إِمْسَارْ بلِّي أَربِّي إِسّكّْ إِجّْ ن ؤُسمِّيضْ ن شَّارْقْ إِحَارّنْ ؤُشَا ثوْثَا ثْفُوشْثْ أَزدْجِيفْ ن يُونُوسْ أَڒَامِي إِذوّخْ ؤُشَا نتَّا يَارْزُو أَذْ إِمّثْ، إِنَّا: ”إِتّْبَانْ أَيِي بلِّي ڒْموْثْ إِنُو حْسنْ زِي ثُوذَارْثْ إِنُو.“
\v 9 \add خنِّي\add* إِنَّا أَسْ أَربِّي إِ يُونُوسْ: ”مَا ثشْنَا ؤُمِي ثْخيّْقذْ أَمُّو خْ ثْشجَّارْثْ-أَ ن ؤُثبْهثْ؟“ إِنَّا: ”أَقَا ذ صّحْ أَقَا خيّْقغْ، أَڒَامِي زمَّارغْ أَذْ مّْثغْ!“
\v 10 إِنَّا \add أَسْ\add* سِيذِي: ”شكْ ثزِّيدْجزْ أَشْ ثْشجَّارْثْ ن ؤُثبْهثْ إِ ؤُمِي وَارْ ثْخذْمذْ ؤُ إِ ؤُمِي وَارْ ثسّيْمذْ، ذ ثنِّي د-يُوسِينْ ذڭْ إِشْثْ ن دْجِيڒثْ ؤُشَا ثتّْوَاهلّكْ ذڭْ إِشْثْ ن دْجِيڒثْ.
\v 11 مَا نشّْ وَارْ ذ أَيِي ثزِّيدْجزْ ثنْذِينْثْ ن نِينْوَا ثَامقّْرَانْثْ ثنِّي إِ ذِي إِدْجَا كْثَارْ زِي مْيَا ؤُ-عِيشْرِينْ-أَڒفْ ن إِوْذَانْ إِنِّي وَارْ إِسِّيننْ \add ڒْْفَارْقْ\add* جَارْ ؤُفُوسْ نْسنْ أَفُوسِي ذ ؤُفُوسْ نْسنْ أَزڒْمَاضْ ؤُ سنّجْ إِ ؤُيَا \add أَقَا ذِينْ\add* أَطَّاسْ ن ڒبْهَايمْ؟“ 
