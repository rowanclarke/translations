\id LAM LAMENTATIONS, Hiri Motu Bible, PNG, 7/88, 5/93 
\h LALOHISIHISI 
\toc1 LALOHISIHISI ANE EDIA BUKA 
\toc2 LALOHISIHISI 
\mt1 LALOHISIHISI ANE EDIA BUKA  
\c 1  
\s1 Ierusalema ena lalohisihisi  
\q1
\v 1 Ierusalema hanua madi ia dika.  
\q1 Gunaguna taunimanima momo be ia lalonai idia noho,  
\q1 to hari ia be anina lasi gabuna.  
\q1 Gunaguna Ierusalema be ia bada,  
\q1 bese idauidau edia huanai,  
\q1 to hari ia be mai lalohisihisi danu,  
\q1 vabu hahine bamona.  
\q1 Guna ia be hanua ibounai edia huanai,  
\q1 hanua namo herea momokani,  
\q1 edia kwini bamona,  
\q1 to hari ia ese hesiai gaukara mai guia danu ia karaia noho.   
\b  
\q1
\v 2 Hanuaboi lalonai ia tai bada noho,  
\q1 iena matana ena ranu be iena vairana dekenai ia diho noho.  
\q1 Guna Ierusalema be mai ena ura henia taudia momo,  
\q1 to hari, idia ibounai edia huanai,  
\q1 tau ta ese Ierusalema durua totona ia mai lasi.  
\q1 Iena turana ibounai ese idia koia vadaeni,  
\q1 bona hari idia ese Ierusalema idia badu henia noho.   
\b  
\q1
\v 3 Iuda taudia ese hesiai gaukara mai guia danu idia karaia noho.  
\q1 Edia gabu korikori dekena amo,  
\q1 bese ta ese idia ia guia, ia abidia lao.  
\q1 Iuda taudia madi be bese idauidau edia huanai idia noho,  
\q1 bona edia laga-ani gabuna ta,  
\q1 be idia davaria diba lasi.  
\q1 Idia hadikaia gwauraia taudia ese idia tuari henidia vadaeni,  
\q1 bona Iuda taudia be heau mauri dalana ta lasi.   
\b  
\q1
\v 4 Siona dekenai idia lao raka daladia,  
\q1 be mai edia lalohisihisi,  
\q1 guna bamona lasi,  
\q1 badina be guriguri aria idia gwauraia neganai, tau ta ia mai lasi.  
\q1 Siona ena magu iduara ibounai,  
\q1 be mai taunimanima lasi.  
\q1 Siona ena hahelagaia taudia idia taitai noho.  
\q1 Siona ena ane abia kekeni,  
\q1 be tau haida ese idia dagedage henidia noho.  
\q1 Siona be ia hisihisi noho momokani.   
\b  
\q1
\v 5 Siona idia hadikaia gwauraia taudia ese idia kwalimu.  
\q1 Idia ese edia siahu henunai,  
\q1 Ierusalema idia atoa vadaeni.  
\q1 Siona ena kara dika momo herea dainai,  
\q1 Lohiabada ese ia hisihisi henia vadaeni.  
\q1 Iena natuna be idau bese taudia ese idia guia vadaeni,  
\q1 bona idia abidia lao gabu daudau dekenai.   
\b  
\q1
\v 6 Ierusalema ena hairai be ia ore vadaeni.  
\q1 Iena gunalaia taudia be uda dia,  
\q1 hitolo dainai idia manoka gaudia bamona.  
\q1 Idia luludia taudia dekena amo idia heau,  
\q1 to edia goada be ia ore lao noho.   
\b  
\q1
\v 7 Iena lalohisihisi lalonai,  
\q1 Ierusalema ese nega gunadia ia laloa noho.  
\q1 Iena kohu namodia momokani,  
\q1 nega gunadia gaudia ia laloa noho.  
\q1 To idau bese tuari taudia ese idia halusia neganai,  
\q1 idia ese Ierusalema idia kirikirilaia,  
\q1 badina ia be mai ena durua taudia ta lasi.   
\b  
\q1
\v 8 Ierusalema ese kara dika bada ia karaia vadaeni,  
\q1 bona unai dainai ia ese sibona ia hamiroa vadaeni.  
\q1 Guna idia hanamoa taudia ese,  
\q1 hari Ierusalema idia hereva dika henia noho,  
\q1 badina idia itaia, ia be kopina kavakava hahine bamona.  
\q1 Io, ia sibona ia tai noho,  
\q1 bona mai hemarai danu,  
\q1 iena doruna ia giroa idia dekenai.   
\b  
\q1
\v 9 Iena kara mirona be ibounai ese idia itaia diba,  
\q1 to do ia davaria dika be ia laloa lasi.  
\q1 Unai dainai iena moru be ia bada herea,  
\q1 bona tau ta ese ia hagoadaia diba lasi.  
\q1 Io, Ierusalema idia tuari henia taudia idia kwalimu vadaeni,  
\q1 bona Ierusalema ese,  
\q1 bogahisihisi totona Lohiabada dekenai ia tai henia noho.   
\b  
\q1
\v 10 Ia idia hadikaia taudia ese,  
\q1 Ierusalema ena kohu namodia ibounai idia henaoa vadaeni.  
\q1 Io, ia sibona ese unai idau bese taudia ia itaia,  
\q1 iena Dubu Helaga idia raka vareai.  
\q1 Momokani oi Lohiabada ese oi taravatudia vadaeni,  
\q1 oi gwau, idau bese taudia do idia vareai lasi,  
\q1 to oiemu gabu helagana lalonai idia vareai kava vadaeni.   
\b  
\q1
\v 11 Ierusalema taudia ibounai ese aniani idia tahua noho,  
\q1 mai taitai danu.  
\q1 Idia ese edia kohu namodia momokani dekena amo,  
\q1 aniani idia hoia noho,  
\q1 do idia mase garina.  
\q1 Ierusalema taudia madi idia guriguri, idia gwau,  
\q1 “Lohiabada e, mani emu kara, ai do oi itaia.  
\q1 Aiemai lalohisihisi do oi itaia.”   
\b  
\q1
\v 12 Raka hanaia taudia ibounai dekenai,  
\q1 Ierusalema ese ia boiboi noho,  
\q1 ia gwau,  
\q1 “Lau do umui itaia,  
\q1 egu hisihisi hegeregerena,  
\q1 be ta ese nega ta ia abia, a?  
\q1 Inai hisihisi be Lohiabada ese egu latanai ia atoa,  
\q1 iena badu siahu bada dinana dekenai.   
\b  
\q1
\v 13 “Ia ese ataiai dekena amo lahi ia siaia diho.  
\q1 Inai lahi be egu turiana edia lalona ia gabua noho.  
\q1 Reke tarapu dekena amo,  
\q1 egu aena ia dogoatao,  
\q1 bona tano dekenai lau ia negea diho.  
\q1 Unai murinai ia ese lau ia rakatania, mai egu gorere danu.  
\q1 Dina ibounai lalonai lau hisihisi noho.   
\b  
\q1
\v 14 “Lohiabada ese egu kara dika ibounai ia kwatua hebou,  
\q1 ikumi gauna metau herea,  
\q1 bona egu aiona dekenai unai ikumi maduna ia atoa kau.  
\q1 Iena metau dainai egu goada be ia maragi lao.  
\q1 Unai neganai Lohiabada ese,  
\q1 lau idia hadikaia gwauraia taudia edia siahu henunai lau ia atoa,  
\q1 bona lau ese lau koudia diba lasi.   
\b  
\q1
\v 15 “Lohiabada ese, egu tuari taudia goadadia ia kirikirilaia.  
\q1 Ia ese tuari orea ta ia siaia,  
\q1 egu eregabe taudia do ia alaia ore totona.  
\q1 Ia ese egu bese taudia ia moidia diho,  
\q1 vain huahua be vain moia gabuna idia moia diho bamona.   
\b  
\q1
\v 16 “Unai dainai lau taitai noho,  
\q1 egu matana ranu ia diho noho,  
\q1 badina tau ta ese,  
\q1 egu lalona ia hanamoa diba lasi,  
\q1 bona ta ese egu lalona ia hagoadaia diba lasi.  
\q1 Lau idia tuari henia taudia ese lau idia halusia,  
\q1 bona egu natuna be mai edia dala namona ta lasi.   
\s1 Siona taudia idia guriguri, bona edia dika idia gwauraia hedinarai  
\q1
\v 17 “Lau Siona ese egu imana lau abia isi,  
\q1 do lau guriguri totona,  
\q1 to tau ta ese lau ia durua lasi.  
\q1 Lohiabada ese Iakobo idia hadikaia gwauraia taudia ia oda henidia,  
\q1 Iakobo besena do idia tuari henia,  
\q1 vadaeni idia laloa Ierusalema be dabua miro herea gauna bamona.   
\b  
\q1
\v 18 “To Lohiabada be maoromaoro,  
\q1 badina be lau Siona ese ia lau kamonai henia lasi.  
\q1 Umui bese idauidau taudia ibounai e,  
\q1 lau dekenai do umui kamonai,  
\q1 bona egu hisihisi do umui itaia.  
\q1 Egu kekeni bona egu uhau ibounai be mai guia danu,  
\q1 tuari taudia ese idia abia lao vadaeni.   
\b  
\q1
\v 19 “Lau idia ura henia taudia dekenai lau boiboi,  
\q1 to idia ese lau idia durua lasi.  
\q1 Egu hahelagaia taudia bona egu tau badadia,  
\q1 be hanua ena ariara edia lalonai idia mase,  
\q1 aniani idia tahua mase,  
\q1 to idia davaria lasi dainai.   
\b  
\q1
\v 20 “Lohiabada e, egu lalohisihisi,  
\q1 bona egu lauma ena hisihisi do oi itaia.  
\q1 Egu kudouna ia makohia vadaeni,  
\q1 badina egu kara dika ese,  
\q1 egu lalona ia hisihisi henia dainai.  
\q1 Ariara edia lalonai taunimanima idia alaia noho,  
\q1 ruma edia lalonai danu mase ia vara noho.   
\b  
\q1
\v 21 “Lohiabada e,  
\q1 egu taitai mani do oi kamonai,  
\q1 badina tau ta ese egu lalona ia hagoadaia diba lasi.  
\q1 Egu mase idia tahua taudia ibounai ese,  
\q1 egu hisihisi ena sivarai idia kamonai,  
\q1 bona idia moale noho,  
\q1 oi ese unai bamona oi karaia vadaeni dainai.  
\q1 Oi ese oi gwauraia badu dinana,  
\q1 be mani do oi havaraia,  
\q1 vadaeni lau idia hadikaia noho taudia ese,  
\q1 hisihisi do idia abia,  
\q1 lau abia noho hegeregerena.   
\b  
\q1
\v 22 “Edia kara dika ibounai,  
\q1 be oiemu vairanai do oi hedinaraia.  
\q1 Unai neganai edia dika davana do oi henia,  
\q1 egu dika davana oi henia hegeregerena.  
\q1 Badina be lau tai bada noho,  
\q1 bona egu kudouna ia manoka lao noho.”   
\c 2  
\s1 Lohiabada ese Ierusalema ena dika davana ia henia  
\q1
\v 1 Lohiabada ese iena badu dekena amo,  
\q1 Siona be dibura lalonai ia koua vadaeni.  
\q1 Siona ena hairaina,  
\q1 be guba dekena amo tano ena kahu dekenai ia negea diho vadaeni.  
\q1 Lohiabada ese iena badu dainai,  
\q1 iena Dubu Helaga danu ia laloa lasi.   
\b  
\q1
\v 2 Lohiabada ese Iuda dekenai noho hanua ibounai ia hadikaia ore,  
\q1 ia bogahisihisi henidia lasi.  
\q1 Iuda ena gabu aukadia,  
\q1 tuari dekena amo gimaia gabudia,  
\q1 be Lohiabada ese ia hamakohia vadaeni.  
\q1 Iuda basileia,  
\q1 mai ena lohia taudia danu,  
\q1 be tano dekenai ia hamorudia,  
\q1 mai edia hemarai bada danu.   
\b  
\q1
\v 3 Israela ena goada ibounai,  
\q1 be Lohiabada ena badu siahuna ese ia haorea vadaeni.  
\q1 Idau bese tuari taudia be tuari totona idia mai neganai,  
\q1 Lohiabada ese Iuda ia durua lasi.  
\q1 Iakobo ena tano,  
\q1 be Lohiabada ese lahi dekena amo ia gabua,  
\q1 bona gau ibounai ia hadikaia.   
\b  
\q1
\v 4 Ia ese tuari tauna bamona,  
\q1 iena peva dekena amo Iuda taudia ia pidia.  
\q1 Ia ese ia moalelaia vadaeni taudia ia alaia mase.  
\q1 Iniseni Siona dekenai noho taudia ese,  
\q1 Lohiabada ena badu ena mamina idia abia, lahi bamona.   
\b  
\q1
\v 5 Lohiabada ese tuari tauna bamona sibona ia halaoa vadaeni,  
\q1 ia ese Israela ia hadikaia ore vadaeni.  
\q1 Israela ena ruma badadia bona gabu aukadia ibounai,  
\q1 be idia dika vadaeni.  
\q1 Iuda taudia edia latanai,  
\q1 Lohiabada ese lalohisihisi ia habadaia momokani.   
\b  
\q1
\v 6 Lohiabada ese iena Dubu Helaga ia hamakohia vadaeni,  
\q1 uma ena au raurau ruma idia hamakohia bamona.  
\q1 Lohiabada ese ia gwauraia guriguri aria ibounai,  
\q1 bona dina helagadia danu,  
\q1 be Siona dekenai ia hadokodia vadaeni.  
\q1 Bona iena badu siahu bada dekena amo,  
\q1 Lohiabada ese,  
\q1 king bona hahelagaia taudia danu ia negea vadaeni.   
\b  
\q1
\v 7 Lohiabada ese iena boubou patana ia negea vadaeni,  
\q1 bona iena Dubu Helaga ia rakatania vadaeni.  
\q1 Siona iena ruma badadia,  
\q1 be idau bese tuari taudia edia imadia dekenai,  
\q1 Lohiabada ese ia henia.  
\q1 Idia ese kwalimu dainai,  
\q1 idia boiboi bada Lohiabada ena Dubu lalonai,  
\q1 guna guriguri aria idia karaia taudia,  
\q1 edia moale ena boiboi bamona.   
\b  
\q1
\v 8 Lohiabada ese iena lalona ia ha-aukaia,  
\q1 Ierusalema ena magu do ia hamakohia momokani.  
\q1 Ia ese tohoa varona dekena amo edia bada ia davaria,  
\q1 do ia hadikadia momokani totona,  
\q1 bona hari magu bona kohoro ibounai be idia dika vadaeni.   
\b  
\q1
\v 9 Ierusalema ena magu iduara ibounai,  
\q1 be tano dekenai idia moru vadaeni.  
\q1 Edia auri ba be idia makohia momokani.  
\q1 Ierusalema ena king,  
\q1 bona iena lohia taudia,  
\q1 be idau bese edia huanai,  
\q1 mai guia danu idia noho.  
\q1 Dirava ena Taravatu be idia hadibaia noho lasi,  
\q1 bona peroveta taudia ese,  
\q1 Lohiabada dekena amo mata hanai idia abia noho lasi.   
\b  
\q1
\v 10 Ierusalema ena tau badadia,  
\q1 be mai regerege lasi tano dekenai idia helai diho,  
\q1 tano kahu be edia kwaradia dekenai idia negea vadaeni,  
\q1 bona puse dabua idia karaia vadaeni.  
\q1 Ierusalema ena kekeni badadia ese,  
\q1 hemarai dainai tano dekenai edia kwaradia idia atoa noho.   
\b  
\q1
\v 11 Egu matana be taitai dainai idia kepulu bamona.  
\q1 Egu kudouna be ia makohia vadaeni.  
\q1 Egu laumana be ia hisihisi bada noho,  
\q1 egu bese idia hadikaia ore dainai.  
\q1 Badina be natuna maragidia,  
\q1 memero bona kekeni,  
\q1 be hanua ena ariara lalonai idia moru noho, manoka dainai.   
\b  
\q1
\v 12 Hitolo bona ranu mase dainai,  
\q1 idia ese edia sinadia dekenai idia tai noho.  
\q1 Ariara lalonai idia moru noho,  
\q1 bero idia davaria bamona,  
\q1 bona edia sinadia edia imadia lalonai idia mase noho.   
\b  
\q1
\v 13 Ierusalema e, egu lalokau hanua e,  
\q1 edena bamona lau ese oi do lau hagoadaia?  
\q1 Daika ena hisihisi be oiemu hisihisi hegeregerena?  
\q1 Badina be oiemu berona be bada,  
\q1 davara ena bada bamona.  
\q1 Daika ese oi ia hanamoa diba?   
\b  
\q1
\v 14 Oiemu peroveta taudia ese,  
\q1 hereva koikoi sibona oi dekenai idia gwauraia.  
\q1 Idia ese oi idia koia,  
\q1 badina be nega ta oiemu kara dika,  
\q1 be oi dekenai idia gwauraia hedinarai lasi.  
\q1 Oi idia sisiba henia lasi dainai,  
\q1 oi ese oiemu lalona oi giroa lasi.  
\q1 Unai dekena amo oi idia hakaua kerere vadaeni.   
\b  
\q1
\v 15 Dala dekenai idia raka hanaia taudia ese Ierusalema idia itaia,  
\q1 mai hevaseha hereva danu.  
\q1 Idia kirikirilaia,  
\q1 bona edia kwaradia idia giroagiroa,  
\q1 idia gwau,  
\q1 “Ia, inai be hairai bada herea hanua,  
\q1 bona, tanobada ibounai hamoalea hanua, a?”   
\b  
\q1
\v 16 Ierusalema e, oi idia ura hadikaia taudia ibounai ese,  
\q1 edia ududia idia kehoa,  
\q1 oi idia hereva dika henia noho.  
\q1 Mai edia badu danu oi idia itaia noho.  
\q1 Edia udu bibinadia idia mogea noho,  
\q1 bona edia isedia idia koria auka masemase, idia gwau,  
\q1 “Ita ese Ierusalema ita hadikaia ore vadaeni.  
\q1 Ita naria dinana be ita davaria vadaeni inai!”   
\b  
\q1
\v 17 Lohiabada ese ia sisiba henia do ia karaia gauna,  
\q1 be ia ese ia karaia vadaeni.  
\q1 Ia ese oi Ierusalema ia hadikaia ore vadaeni,  
\q1 mai ena bogahisihisi lasi.  
\q1 Ia ese oi idia tuari henia taudia dekenai kwalimu ia henia,  
\q1 moale ia henidia, oiemu moru dainai.   
\b  
\q1
\v 18 Ierusalema taudia e, Lohiabada dekenai do umui tai henia.  
\q1 Emui matadia edia ranu do idia diho noho, abata ranu bamona,  
\q1 dina bona hanuaboi danu.  
\q1 Taitai dekena amo do umui laga-ani lasi.  
\q1 Emui matadia ranu danu do idia laga-ani lasi.   
\b  
\q1
\v 19 Do oi toreisi,  
\q1 hanuaboi ena nega ibounai,  
\q1 do oi toreisi lou, toreisi lou,  
\q1 Lohiabada dekenai do oi tai henia totona.  
\q1 Oiemu kudouna ena laloa ibounai,  
\q1 ranu bamona do oi bubua,  
\q1 Lohiabada ena vairana dekenai.  
\q1 Oiemu imana ia dekenai do oi abia isi,  
\q1 oiemu natudia edia mauri dainai,  
\q1 Lohiabada ese do ia bogahisihisi henidia totona.  
\q1 Badina idia be hitolo dainai idia moru diho noho,  
\q1 hanua ena ariara ibounai edia kona dekenai.   
\b  
\q1
\v 20 Lohiabada e, oi ese oi hisihisi henidia noho taudia,  
\q1 mani do oi itaia.  
\q1 Hahine ese edia natudia,  
\q1 idia lalokau henidia maragidia,  
\q1 idia ania noho!  
\q1 Hahelagaia taudia bona peroveta taudia,  
\q1 be Lohiabada ena Dubu lalonai idia aladia noho!   
\b  
\q1
\v 21 Hanua ena ariara ena kahu dekenai,  
\q1 memero bona tau burukadia idia hekure hebou,  
\q1 idia mase vadaeni.  
\q1 Kekeni badadia bona uhau,  
\q1 be tuari kaia dekena amo idia mase.  
\q1 Oiemu badu dinana dekenai oi aladia vadaeni,  
\q1 oi aladia mase vadaeni,  
\q1 oi bogahisihisi henidia lasi.   
\b  
\q1
\v 22 Aria dekenai oi ese taunimanima oi boiridia hebou hegeregerena,  
\q1 oi ese lau idia hagaria gaudia,  
\q1 be kahana ibounai dekena amo oi boiridia mai.  
\q1 Lohiabada ena badu dinana dekenai,  
\q1 tau ta ia heau diba lasi,  
\q1 bona ta ia mauri diba lasi.  
\q1 Lau ese lau havaraia, bona lau naria natudia be,  
\q1 lau dekenai idia tuari henia taudia ese,  
\q1 idia hadikaia ore vadaeni.   
\c 3  
\s1 Dika davana henia, lalona giroa, bona nega namona naria kara  
\q1
\v 1 Lohiabada ese iena badu dainai,  
\q1 taunimanima edia dika davana ia henia,  
\q1 ena mamina be lau diba.   
\q1
\v 2 Ia ese dibura lalonai lau ia lulua vareai,  
\q1 diari lasi gabuna lalonai.   
\q1
\v 3 Momokani,  
\q1 ia ese iena imana ia abia isi,  
\q1 lau hadikaia totona,  
\q1 bona lau ia botaia lou, botaia lou,  
\q1 dina ena hora ibounai.   
\b  
\q1
\v 4 Egu hidiona bona egu kopina ia haorea vadaeni,  
\q1 bona egu turiana haida ia hamakohia vadaeni.   
\q1
\v 5 Ia ese lau ia hagegea,  
\q1 bona lau ia koua vadaeni.  
\q1 Lalohisihisi bona laloa metau momokani ese lau idia abia.   
\q1
\v 6 Dirava ese dibura gabuna lalonai,  
\q1 lau ia doria vareai.  
\q1 Lau be idaunegai lau mase tauna bamona.   
\b  
\q1
\v 7 Ia ese auri seini dekena amo,  
\q1 lau ia guia vadaeni.  
\q1 Lau be magu lalonai,  
\q1 bona lau heau mauri diba lasi.   
\q1
\v 8 Lau boiboi noho,  
\q1 lau tai mai boiboi danu,  
\q1 to Lohiabada ese egu noinoi ia kamonai lasi.   
\q1
\v 9 Ia ese egu dala ia koua vadaeni,  
\q1 ia utua nadi magudia dekena amo,  
\q1 bona egu raka daladia ia hagagevaia vadaeni.   
\b  
\q1
\v 10 Hunia dekenai lau totona ia naria,  
\q1 bea ena kara bamona,  
\q1 bona laiona bamona,  
\q1 lau ia dogoatao totona ia roho mai.   
\q1
\v 11 Ia ese dala dekena amo lau ia veria lao,  
\q1 vadaeni lau ia darea momokani,  
\q1 bona lau ia rakatania.   
\q1
\v 12 Ia ese iena peva ia veria,  
\q1 bona iena diba dekena amo lau ia pidia gwauraia.   
\b  
\q1
\v 13 Iena diba dekena amo egu kudouna ia gwadaia.   
\q1
\v 14 Taunimanima ese lau idia kirikirilaia noho.  
\q1 Edia ane dekena amo,  
\q1 lau dekenai idia hevaseha dina ena hora ibounai.   
\q1
\v 15 Lohiabada ese hisihisi momo lau dekenai ia henia,  
\q1 vadaeni lau hesiku momokani.  
\q1 Inai be,ia ese mamina dika avadia dekena amo,  
\q1 egu bogana ia hahonua bamona.   
\b  
\q1
\v 16 Ia ese nadi maragidia dekena amo,  
\q1 egu isena ia hamakohia,  
\q1 bona tano ena kahu dekenai,  
\q1 lau ia moia diho.   
\q1
\v 17 Lohiabada ese maino bona noho namo,  
\q1 be lau dekena amo ia kokia vadaeni.  
\q1 Moale ena mamina be lau laloaboio.   
\q1
\v 18 Unai dainai lau gwau,  
\q1 “Egu hairaina be ia ore vadaeni,  
\q1 bona Lohiabada dekena amo gau namodia lau laloa noho kara,  
\q1 be ia boio vadaeni.”   
\b  
\q1
\v 19 Egu hisihisi,  
\q1 bona mai egu ruma lasi ena nega,  
\q1 be lau laloa noho.  
\q1 Unai be mamina dika poisini bamona lau dekenai.   
\q1
\v 20 Unai lau laloa noho, laloa noho,  
\q1 bona egu laumana be ia laloa metau noho.   
\q1
\v 21 To egu lalona ia hanamoa noho gauna tamona be inai:   
\b  
\q1
\v 22 Lohiabada ena noho hanaihanai lalokauna,  
\q1 be do ia ore lasi.  
\q1 Iena bogahisihisi karadia be do idia doko lasi,   
\q1
\v 23 daba ibounai idia be matamata.  
\q1 Lohiabada e, oiemu hereva oi badinaia kara be bada momokani.   
\q1
\v 24 Lau gwau, “Egu durua tauna be tamona, Lohiabada sibona,  
\q1 unai dainai ia dekenai egu abidadama lau atoa noho.”   
\b  
\q1
\v 25 Lohiabada idia abidadama henia taudia,  
\q1 be Lohiabada ese ia hanamodia noho.   
\q1
\v 26 Unai dainai Lohiabada ese ita do ia hamauria totona,  
\q1 do ita naria noho be namo,  
\q1 do ita naria mai abidadama danu be namo.   
\q1
\v 27 Tau ta ese ia eregabe neganai,  
\q1 maduna metau do ia huaia,  
\q1 unai be namo.   
\b  
\q1
\v 28 Ia ese sibona do ia helai, regerege lasi, be namo,  
\q1 badina Lohiabada ese unai maduna,  
\q1 be unai mero ena latanai ia atoa vadaeni.   
\q1
\v 29 Ia be Lohiabada ena siahu henunai do ia manau,  
\q1 bona ia ese iena vairana,  
\q1 be tano dekenai do ia atoa,  
\q1 badina gabeai ia ese,  
\q1 namo do ia davaria momokani.   
\q1
\v 30 Iena vairana danu,  
\q1 be do idia botaia taudia dekenai do ia henia be namo,  
\q1 bona edia hereva dika,  
\q1 do ia abia dae danu be namo,   
\b  
\q1
\v 31 badina be Lohiabada ese iena hesiai taudia do ia negea lasi,  
\q1 ela bona bona hanaihanai.   
\q1
\v 32 Momokani Lohiabada ese ita dekenai lalohisihisi ia henia noho,  
\q1 to ia ese ita do ia bogahisihisi henia,  
\q1 badina iena lalokau ita dekenai be momokani,  
\q1 bona mai goada danu.   
\q1
\v 33 Lohiabada ese,  
\q1 ia ura lasi ita dekenai lalohisihisi o hisihisi do ia havaraia.   
\b  
\q1
\v 34 Bema dibura ruma lalonai ita noho neganai,  
\q1 tau haida ese ita idia dagedage henia,  
\q1 bona idia ese ita idia hadikaia neganai,  
\q1 Lohiabada be ia diba.   
\q1
\v 35 Bema Lohiabada ese,  
\q1 ita dekenai gwaumaoro ia henia, kara ta do ita karaia,  
\q1 to tau haida ese unai kara idia koua neganai,  
\q1 Lohiabada be ia diba.   
\q1
\v 36 Bema hereva koikoi dekena amo,  
\q1 kota maoromaoro idia hagagevaia neganai,  
\q1 Lohiabada be ia diba.   
\b  
\q1
\v 37 Badina be nega ibounai,  
\q1 Lohiabada ena ura sibona ia vara noho.  
\q1 Bema Lohiabada ese kara ta ia ura lasi neganai,  
\q1 daika ese unai kara ia karaia diba?   
\q1
\v 38 Lohiabada ena oda dekena amo,  
\q1 namo bona dika be idia vara noho, ani?   
\q1
\v 39 Ita mauri noho taunimanima be,  
\q1 Lohiabada ese iseda dika davana ia henia neganai,  
\q1 dahaka dainai do ita hereva badubadu noho?   
\b  
\q1
\v 40 Namona be iseda dala do ita tohoa,  
\q1 bona iseda kara do ita tahua,  
\q1 bona Lohiabada dekenai do ita giroa lou.   
\q1
\v 41 Namona be iseda kudoudia do ita kehoa,  
\q1 bona iseda imadia do ita abia isi  
\q1 guba dekenai ia noho Dirava dekenai,  
\q1 bona do ita gwau,   
\q1
\v 42 “Ai be ai kerere vadaeni,  
\q1 bona oiemu taravatu ai utua vadaeni,  
\q1 bona oi ese aiemai dika oi gwauatao lasi.   
\b  
\q1
\v 43 Oi ese ai oi lulua lao,  
\q1 bona ai oi alaia mase.  
\q1 Oiemu badu ese oiemu bogahisihisi ia hunia.   
\q1
\v 44 Oi ese ori ta dekena amo oi sibona oi koua,  
\q1 unai dainai aiemai guriguri,  
\q1 be oi dekenai idia ginidae lasi.   
\q1
\v 45 Oi ese miro bona momoru ai oi halaoa vadaeni,  
\q1 bese idauidau edia huanai.   
\b  
\q1
\v 46 Ai idia hadikaia gwauraia taudia ibounai ese,  
\q1 ai idia hereva dika henia,  
\q1 bona ai idia kirikirilaia noho.   
\q1
\v 47 Gari bada bona hekwakwanai be ai dekenai idia vara,  
\q1 vadaeni idia ese emai tano bona emai taunimanima danu,  
\q1 be idia hadikaia ore vadaeni.”   
\q1
\v 48 Egu matana edia ranu ia diho noho,  
\q1 sinavai bamona,  
\q1 egu bese taudia idia hadikaia ore dainai.   
\b  
\q1
\v 49 Egu matana ena ranu do ia diho noho, doko lasi,   
\q1
\v 50 ia lao bona Lohiabada ese,  
\q1 guba dekena amo ai do ia itaia.   
\q1
\v 51 Egu lalona ia hisihisi bada noho,  
\q1 badina lau itaia,  
\q1 egu hanua dekenai noho kekeni badadia,  
\q1 be madi dika idia davaria momokani vadaeni.   
\b  
\q1
\v 52 Nega ta lau hadikaia lasi taudia ese lau idia lulua lao,  
\q1 labana tauna ese manu ta ia tahua noho bamona.   
\q1
\v 53 Idia ese guri badana lalonai lau idia negea diho,  
\q1 bona nadi momo be egu latanai idia negea.   
\q1
\v 54 Ranu lalonai lau diho noho, lau gwau,  
\q1 “Lau be lau mase noho inai.”   
\b  
\q1
\v 55 Lohiabada e,  
\q1 guri dobuna dekena amo,  
\q1 oi dekenai lau boiboi,   
\q1
\v 56 bona oi dekenai lau noinoi neganai,  
\q1 egu taitai oi kamonai henia.   
\q1
\v 57 Oi ese lau dekenai oi haere,  
\q1 bona oi gwau, “Oi gari lasi.”   
\b  
\q1
\v 58 Lohiabada e, oi ese lau oi durua,  
\q1 bona oi ese lau oi hamauria vadaeni.   
\q1
\v 59 Lohiabada e,  
\q1 oi ese oi itaia vadaeni,  
\q1 unai taudia ese lau dekenai idia kara dika.  
\q1 Kota maoromaoro mani lau dekenai do oi henia.   
\q1
\v 60 Unai taudia ese lau idia badu henia noho,  
\q1 bona egu mase dalana idia tahua noho,  
\q1 be oi diba noho.   
\b  
\q1
\v 61 Lohiabada e, edia hereva dika,  
\q1 be oi ese oi kamonai vadaeni,  
\q1 bona lau idia ura hadikaia,  
\q1 inai bamona idia laloa noho gaudia ibounai be oi diba noho.   
\q1
\v 62 Dina ena nega ibounai lalonai,  
\q1 lau idia alaia gwauraia taudia ese lau idia herevalaia noho gaudia,  
\q1 be oi ese oi kamonai noho.   
\q1
\v 63 Daba ia lao bona hanuaboi,  
\q1 be idia ese lau idia hevaseha henia noho.   
\b  
\q1
\v 64 Lohiabada e, oi ese edia dika davana do oi henia.  
\q1 Edia kara hegeregerena,  
\q1 davana do oi henia.   
\q1
\v 65 Oiemu hereva dika idia edia latanai do oi atoa,  
\q1 bona edia kudouna edia laloa do oi koua.   
\q1
\v 66 Oiemu badu dekena amo idia do oi lulua lao,  
\q1 bona guba ena henuna dekena amo,  
\q1 idia ibounai do oi haorea.   
\c 4  
\s1 Ierusalema ia moru murinai ia dika  
\q1
\v 1 Ierusalema ena golo be ia diaridiari lasi,  
\q1 bona Dubu Helaga ena nadi namodia,  
\q1 be hanua ena ariara edia lalonai,  
\q1 idia negedia kava vadaeni.   
\b  
\q1
\v 2 Siona ena uhau taudia namo hereadia,  
\q1 guna edia davana be bada herea ita dekenai,  
\q1 golo namona bona metau herea hegeregerena.  
\q1 To hari idia be raro urodia sibona hegeregerena,  
\q1 uro karaia tauna ena imana dekenai ia karaia gaudia bamona.   
\b  
\q1
\v 3 Uda sisia ena sinana ese iena natuna ia ubudia noho,  
\q1 iena rata ia henidia noho.  
\q1 To egu bese hahine taudia ese,  
\q1 edia natudia idia dagedage henidia noho,  
\q1 uda kokokoko edia kara bamona.   
\b  
\q1
\v 4 Edia maragidia be hitolo,  
\q1 bona ranu mase dainai idia mase noho,  
\q1 to sinadia idia laloa momo lasi.  
\q1 Iseda maragidia ese aniani totona idia noinoi noho,  
\q1 to tau ta ese sisina ia henidia lasi.   
\b  
\q1
\v 5 Guna aniani namodia momokani idia ania taudia,  
\q1 be hari hanua ena ariara lalonai idia mase noho.  
\q1 Guna lohia ena ruma badadia lalonai idia aniani taudia,  
\q1 be hari momoru gabudia dekenai,  
\q1 edia aniani idia tahua noho.   
\b  
\q1
\v 6 Egu bese taudia edia dika davana,  
\q1 ese Sodoma bona Gomora edia dika davana ia hanaia vadaeni,  
\q1 badina Sodoma taudia edia dika,  
\q1 be Dirava ese ia haorea haraga.   
\b  
\q1
\v 7 Guna Ierusalema ena lohia taudia edia toadia be namo herea,  
\q1 idia be goevagoeva, sinou bamona.  
\q1 Edia tauanidia be kakakaka,  
\q1 bona mai goadadia momokani,  
\q1 mai edia hairai danu,  
\q1 sapairo nadidia bamona.   
\b  
\q1
\v 8 To hari idia be hanua ariara dekenai idia hekure noho.  
\q1 Edia vairadia be koremakorema,  
\q1 idia mase vadaeni dainai.  
\q1 Edia kopidia be idia makuku dika,  
\q1 edia turiadia latanai,  
\q1 bona idia kaukau vadaeni, au bamona.   
\b  
\q1
\v 9 Tuari dekenai idia mase taudia edia moale ese,  
\q1 hitolo dekenai idia mase taudia edia moale ia hereaia.  
\q1 Edia tauanidia be metairametaira idia ore lao, idia mase,  
\q1 uma edia anina be lasi dainai.   
\b  
\q1
\v 10 Egu bese idia hadikaia ore dinadia dekenai,  
\q1 hahine ese edia natudia maragidia dekenai idia bogahisihisi,  
\q1 to unai maragidia idia mase neganai,  
\q1 edia tauanidia idia nadua,  
\q1 bona idia ania.   
\b  
\q1
\v 11 Lohiabada ese iena badu ia hasiahua,  
\q1 bona lahi bada dekena amo,  
\q1 Siona ia gabua haorea momokani.   
\b  
\q1
\v 12 Tanobada ena king ibounai,  
\q1 bona tanobada taudia ibounai danu idia laloa,  
\q1 tuari taudia o tuari orea ta,  
\q1 be Ierusalema magu iduaradia do idia raka vareai diba lasi.   
\b  
\q1
\v 13 To inai kara be ia vara momokani,  
\q1 Ierusalema ena peroveta taudia,  
\q1 bona hahelagaia taudia edia kara dika dainai.  
\q1 Idia ese kerere lasi taudia edia mase idia havaraia.   
\b  
\q1
\v 14 Unai Ierusalema ena lohia taudia,  
\q1 be hari ariara dekenai idia loaloa kava,  
\q1 matakepulu taudia bamona.  
\q1 Idia be unai mase taudia edia rara dekena amo idia miro dainai,  
\q1 tau ta ese edia dabua danu,  
\q1 do idia dogoatao diba lasi.   
\b  
\q1
\v 15 Taunimanima ese idia dekenai idia boiboi, idia gwau,  
\q1 “Umui siri. Umui be mai miro danu.  
\q1 Umui siri.  
\q1 Ai dekenai do umui kamokau lasi.”  
\q1 Vadaeni idia heau,  
\q1 bona loaloa kava taudia hegeregerena idia lao.  
\q1 Bese idauidau dekenai idia lao,  
\q1 to unai bese edia huanai taunimanima idia gwau,  
\q1 “Ai dekenai do umui noho lou lasi.”   
\b  
\q1
\v 16 Lohiabada sibona ese ia luludia lao gabu idauidau dekenai.  
\q1 Ia ese unai hahelagaia taudia bona lohia taudia ia matauraia lasi.  
\q1 Taunimanima danu ese edia dagi idia laloa lasi.   
\b  
\q1
\v 17 Aiemai matadia ai negea,  
\q1 durua do ai abia totona,  
\q1 to ai naria kava.  
\q1 Ai ese bese ta ena durua ai naria,  
\q1 to unai bese ese ai ia durua diba lasi.   
\b  
\q1
\v 18 Ai idia tuari henia noho taudia ese ai idia tahua noho,  
\q1 unai dainai ariara dekenai ai raka diba lasi.  
\q1 Aiemai mauri dinadia be kahirakahira idia ore.  
\q1 Aiemai dokona be ia ginidae vadaeni.   
\b  
\q1
\v 19 Ai idia lulua lao taudia edia heau ese,  
\q1 guba ugava manu edia roho ia hereaia.  
\q1 Ororo dekenai ai idia lulua,  
\q1 bona tano kaukau gabudia dekenai,  
\q1 ai hadikaia totona idia naria,  
\q1 hunia dekenai.   
\b  
\q1
\v 20 Lohiabada ese ia abia hidi tauna,  
\q1 aiemai king,  
\q1 be ai hadikaia gwauraia taudia ese idia abia mauri.  
\q1 To ai ese guna ia ai herevalaia vadaeni, ai gwau:  
\q1 “Ia ese ai do ia naria,  
\q1 bona bese ibounai edia tuari taudia dekena amo,  
\q1 ia ese ai do ia gimaia momokani.”   
\b  
\q1
\v 21 Edoma taudia e,  
\q1 Usu tano dekenai umui noho,  
\q1 do umui kiri mai moale bada danu!  
\q1 To Lohiabada ena badu be uaina kapusi bamona,  
\q1 bona ia ese unai kapusi be umui dekenai do ia henia,  
\q1 do umui kekero.  
\q1 Unai neganai umui ese emui dabua do umui kokia,  
\q1 bona hemarai bada do umui abia.   
\b  
\q1
\v 22 Siona ese iena dika davana ia karaia haorea vadaeni.  
\q1 Lohiabada ese Siona taudia edia hesiai mai guia danu,  
\q1 be do ia hadokoa.  
\q1 To Edoma taudia e,  
\q1 Lohiabada ese umui emui dika davana do ia henia,  
\q1 emui kerere do ia hedinaraia.   
\c 5  
\s1 Ierusalema taudia ese Lohiabada idia noia, do ia bogahisihisi henidia  
\q1
\v 1 Lohiabada e,  
\q1 ai dekenai idia vara gaudia,  
\q1 mani do oi laloatao.  
\q1 Ai do oi itaia,  
\q1 aiemai hemarai mani do oi itaia.   
\q1
\v 2 Aiemai tano be idau taudia dekenai idia henia vadaeni.  
\q1 Aiemai ruma be idau bese taudia dekenai idia henia vadaeni.   
\b  
\q1
\v 3 Aiemai tamadia be tuari taudia ese idia alaia,  
\q1 bona aiemai sinadia be vabu vadaeni.   
\q1
\v 4 Aiemai inua ranu be ai hoia noho,  
\q1 bona aiemai lahi audia danu be mai davana.   
\q1
\v 5 Ai idia tuari henia taudia ese ai idia lulua lao,  
\q1 bona ai dekenai idia mai kahirakahira noho.  
\q1 Aiemai goada ia ore momokani,  
\q1 to ai laga-ani diba lasi.   
\q1
\v 6 Aniani do ai abia totona,  
\q1 ai ese Aigupito bona Asuria dekenai ai noinoi.   
\b  
\q1
\v 7 Aiemai tamadia idia kara dika,  
\q1 bona idia mase vadaeni,  
\q1 bona hari ai ese edia dika davana ai huaia noho.   
\q1
\v 8 Guna aiemai hesiai gaukara idia karaia taudia ese,  
\q1 ai idia biagua noho,  
\q1 bona tau ta ese edia siahu dekena amo ai ia hamauria diba lasi.   
\q1
\v 9 Taunimanima alaia taudia be,  
\q1 tano ena kahana ibounai dekenai idia loaloa noho.  
\q1 Unai dainai ai ese,  
\q1 aniani ai tahua noho,  
\q1 mai gari bada danu.   
\q1
\v 10 Aiemai kopina be mai siahu bada, amu bamona,  
\q1 badina be hitolo ese ai ia hadikaia noho.   
\q1
\v 11 Aiemai adavadia be Siona dekenai,  
\q1 tuari taudia ese idia hadikaia.  
\q1 Aiemai natudia kekeni,  
\q1 be Iuda hanua ibounai lalonai,  
\q1 tuari taudia ese idia hadikaia.   
\q1
\v 12 Idia ese aiemai lohia taudia,  
\q1 be edia imadia dekena amo idia taua dae vadaeni,  
\q1 bona idia ese hanua tau badadia idia matauraia lasi.   
\q1
\v 13 Aiemai eregabe taudia ese,  
\q1 uiti moia gabudia dekenai idia gaukara auka noho,  
\q1 bona memero be au metaudia henunai,  
\q1 idia hekwakwanai noho.   
\q1
\v 14 Tau burukadia,  
\q1 be hanua ena magu iduara badinai idia helai lou lasi.  
\q1 Uhau taudia ese,  
\q1 gita gadaralaia kara idia rakatania vadaeni.   
\q1
\v 15 Aiemai moale ibounai be ia ore vadaeni,  
\q1 bona aiemai mavaru ena gabu dekenai,  
\q1 taitai ia vara noho.   
\q1
\v 16 Aiemai kwalimu toana, korona,  
\q1 be aiemai kwaradia dekena amo idia moru vadaeni.  
\q1 Madi, ai be dika vadaeni inai,  
\q1 kara dika ai karaia dainai.   
\b  
\q1
\v 17 Inai dainai aiemai kudoudia idia manoka momokani vadaeni,  
\q1 bona aiemai matadia edia ranu dainai,  
\q1 ai itaia namonamo diba lasi.   
\q1
\v 18 Badina Siona Ororo be anina lasi vadaeni,  
\q1 uda sisia idia loaloa gabuna sibona ia lao vadaeni.   
\b  
\q1
\v 19 To oi, Lohiabada e,  
\q1 oi be king ela bona hanaihanai.  
\q1 Oiemu King siahuna be do ia noho nega ibounai, doko lasi.   
\q1
\v 20 Badina dahaka oi ese nega ibounai ai oi laloaboio noho?  
\q1 Badina dahaka nega daudau ai oi rakatania vadaeni?   
\q1
\v 21 Lohiabada e,  
\q1 ai ura oi dekena do ai giroa lou.  
\q1 Mani emu kara, ai do oi abia dae lou.  
\q1 Aiemai mauri do oi hamatamataia lou,  
\q1 dina gunadia hegeregere.   
\q1
\v 22 O sedira, oi ese ai oi negea momokani vadaeni, a?  
\q1 Oi ese ai oi badu henia momokani, a?   