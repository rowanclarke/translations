\c 2  
\s1 What Nebuchadnezzar dreamed  
\p
\v 1  \add One night\add* \w during|strong="H1961"\w* \w the|strong="H5921"\w* \w second|strong="H8147"\w* \w year|strong="H8141"\w* \w that|strong="H8141"\w* \w Nebuchadnezzar|strong="H5019"\w* ruled, \w he|strong="H8147"\w* \w had|strong="H1961"\w* \w a|strong="H3068"\w* \w dream|strong="H2472"\w*. \w The|strong="H5921"\w* \w dream|strong="H2472"\w* worried \w him|strong="H5921"\w* very \w much|strong="H5921"\w*; \w and|strong="H8141"\w* \add as a result\add* \w he|strong="H8147"\w* could \w not|strong="H1961"\w* \w sleep|strong="H8142"\w*.  
\v 2  \add The next morning \add* \w he|strong="H7121"\w* \w summoned|strong="H7121"\w* \w his|strong="H7121"\w* \w men|strong="H7121"\w* \w who|strong="H4428"\w* worked magic, fortune-tellers, those \w who|strong="H4428"\w* worked \w sorcery|strong="H3784"\w*, \w and|strong="H4428"\w* those \w who|strong="H4428"\w* studied \w the|strong="H6440"\w* stars. \add Because he had forgotten what he had dreamed,\add* \w he|strong="H7121"\w* insisted \w that|strong="H4428"\w* \w they|strong="H6440"\w* \w tell|strong="H5046"\w* \w him|strong="H6440"\w* what \w he|strong="H7121"\w* \w had|strong="H4428"\w* dreamed. \w As|strong="H6440"\w* \w they|strong="H6440"\w* \w stood|strong="H5975"\w* \w there|strong="H5975"\w* \w in|strong="H4428"\w* \w front|strong="H6440"\w* \w of|strong="H4428"\w* \w the|strong="H6440"\w* \w king|strong="H4428"\w*,  
\v 3 \w he|strong="H4428"\w* said, “\w I|strong="H3045"\w* \w had|strong="H4428"\w* \w a|strong="H3068"\w* \w dream|strong="H2472"\w* \add last night \add* \w that|strong="H3045"\w* worries \w me|strong="H3045"\w*. \add Tell me what I dreamed, because\add* \w I|strong="H3045"\w* want \w to|strong="H4428"\w* \w know|strong="H3045"\w* \w what|strong="H3045"\w* \w the|strong="H3045"\w* \w dream|strong="H2472"\w* \add means\add*.”   
\p
\v 4 \w The|strong="H1696"\w* men \w who|strong="H4428"\w* studied \w the|strong="H1696"\w* stars \w replied|strong="H1696"\w* \w to|strong="H1696"\w* \w the|strong="H1696"\w* \w king|strong="H4428"\w*, \w speaking|strong="H1696"\w* \w in|strong="H4428"\w* \w the|strong="H1696"\w* Aramaic \add language\add*. \w They|strong="H1696"\w* \w said|strong="H1696"\w*, “\w King|strong="H4428"\w* \w Nebuchadnezzar|strong="H4430"\w*, \w we|strong="H3068"\w* hope \w that|strong="H4428"\w* \w you|strong="H1696"\w* \w will|strong="H4428"\w* \w live|strong="H2418"\w* \w a|strong="H3068"\w* \w long|strong="H5957"\w* time! \w Tell|strong="H1696"\w* \w us|strong="H5649"\w* \w what|strong="H1696"\w* \w you|strong="H1696"\w* dreamed, \w and|strong="H4428"\w* \add then\add* \w we|strong="H3068"\w* \w will|strong="H4428"\w* \w tell|strong="H1696"\w* \w you|strong="H1696"\w* \w what|strong="H1696"\w* \w it|strong="H1696"\w* means!”   
\p
\v 5 \w But|strong="H4481"\w* \w the|strong="H4481"\w* \w king|strong="H4430"\w* \w replied|strong="H6032"\w*, “\w I|strong="H4481"\w* \w have|strong="H4430"\w* firmly decided \w that|strong="H3046"\w* \w you|strong="H2006"\w* must tell \w me|strong="H4481"\w* \w the|strong="H4481"\w* \w dream|strong="H2493"\w*, \w and|strong="H6032"\w* \add also tell me\add* \w what|strong="H4406"\w* \w it|strong="H2006"\w* means. \w If|strong="H2006"\w* \w you|strong="H2006"\w* \w do|strong="H5648"\w* \w not|strong="H3809"\w* \w do|strong="H5648"\w* \w that|strong="H3046"\w*, \w I|strong="H4481"\w* \w will|strong="H4430"\w* \add order my soldiers to\add* \w cut|strong="H5648"\w* \w you|strong="H2006"\w* into \w pieces|strong="H1917"\w*, \w and|strong="H6032"\w* \w to|strong="H3046"\w* cause your \w houses|strong="H1005"\w* \w to|strong="H3046"\w* become only piles \w of|strong="H4481"\w* stones!  
