\id JOL Joel in Boko, Ross Jones 2/08 
\h Yoɛli 
\toc1 Yoɛli 
\toc2 Yoɛli 
\toc3 Yoɛ 
\mt1 YOƐLI 
\imt1 Yã́ pↄ́ kú láɛ bee guuↄ 
\ip Ãnabi Yoɛli yã́ ì gbɛ̃́ↄ gba gbãa gↄↄpii. Yã́ gbia pↄ́ Yↄɛli ò a lá guu mɛ́ Dii a gbãa ↄlↄa buiↄnɛ ń aà yã́kpalɛkɛańnↄo ũ. A yã́kpalɛkɛ ń Isailiↄ a ↄtondↄkĩi gwasai yã́ musu, mɛ́ a yã́kpalɛkɛ ń buipãleↄ an zaa Isailiↄgu yã́i. Músi yã́ↄ dↄaa yã́kpalɛkɛgↄↄpiɛ ń gu daa yàaao ń pↄ́kɛ̃sãmao. Kwaↄ lɛ́lɛamá ń iminakaao ń pↄ́ↄ tɛ́kũao ń zĩgↄ̃ↄ lɛ́lɛamáo lɛ́ kaalɛgↄↄpi yã́ bↄↄlɛkɛ (1.2-12, 15-18, 2.1-11). A dɛ lá ãnabipi lɛ́ yã'o azĩa gↄↄ yã́ musuwa ń yã́ pↄ́ a su mↄↄ píi. 
\ip Gɛa sua yã́ pↄ́ àlɛ yá a waasokɛa guu wɛbↄa: Isailiↄ gↄ̃̀ gii, aai e Lua kpɛ́ zĩkɛ̀ lↄo, ↄ̃ àlɛ onɛ́ aa ɛa su Luawa aa wabikɛwà (1.13-14, 19-20, 2.12-17). Sema aa gↄ̃ gii gĩa, yã́ i gbasa bↄńnↄ na sa. Pↄdinzi pↄ́ Lua a lɛgbɛ̃̀nɛ́ (2.18-27, 3.1-5, 4.17, 18-21) yã́ i kↄ̃sɛ ń pↄkɛ̃sãma pↄ́ dɛ aà pↄkũmabↄbɛamá ũoo. Yã́ a zↄ̃lɛ buipãleↄwa (4.1-16), Isailiↄ i dↄ̃ sa lá Lua kua ń guu dɛ. Yoɛli ãnabikɛkɛa lɛ́ ↄlↄwɛ̃ɛ kɛ́ zĩewa Lua aↄ kú ń bui píio, asa Lua a a Nisĩna pisimá (3.1-2). Lua lɛgbɛ̃api pàpa Yesude káauↄ gↄↄ Pãteko dikpɛgↄↄzĩ (Zĩn 2.16-21). 
\c 1  
\s1 Kaalɛgↄↄ pↄ́ Dii dìlɛ 
\p  
\v 1 Dii yã'oa Petuɛ nɛ́ Yoɛliɛn kɛ. 
\q1  
\v 2 Mae zↄ̃ↄↄ, à yã́ɛ bee ma! 
\q1 Gbɛ̃́ pↄ́ kú bùsuu laↄ píi, à swã́kpa! 
\q1 Yã́ɛ bee taa kɛ̀ á gↄↄ 
\q1 ge á deziↄ gↄↄe? 
\q1  
\v 3 À dau siu á nɛ́ↄnɛ, 
\q1 aai o ń nɛ́ↄnɛ, 
\q1 an nɛ́ↄ i o ń nɛ́ↄnɛ lↄ. 
\q1  
\v 4 Pↄ́ pↄ́ kwasutɛ̃ↄ tò 
\q1 sɛ̃sɛwɛkwaↄ sò. 
\q1 Pↄ́ pↄ́ sɛ̃sɛwɛkwaↄ tò 
\q1 kwa búunaↄ sò. 
\q1 Pↄ́ pↄ́ kwa búunaↄ tò 
\q1 kwa keleↄ sò. 
\q1  
\v 5 À vu iu idɛnaↄ, í ↄ́ↄlↄ! 
\q1 À búbuapɛ vɛ̃ɛminaↄ ápii 
\q1 vɛ̃ɛ dafu yã́ musu, 
\q1 asa wa wò á lɛ́waɛ. 
\q1  
\v 6 Buie lɛ̀lɛ ma bùsuwa, 
\q1 aa gbãa mɛ́ an dasi lɛ́ vĩo, 
\q1 an swaa dɛ lán nↄ̀ↄmusu swaawa,\f + \fr 1.6 \ft Zia 9.8\f* 
\q1 an kãnkãnaↄ dɛ lán nↄ̀ↄkusi kãnkãnawa. 
\q1  
\v 7 Aa ma vɛ̃ɛliↄ ↄ̃̀ↄkpà, 
\q1 aa ma kaadↄɛnliↄ kɛ̀ kɛ́lɛkɛlɛ. 
\q1 Aa a tɛɛ wòlo kↄ̀lɛ, 
\q1 a gↄ̃na gↄ̃̀ kpá púuu. 
\q1  
\v 8 À búbuapɛ lán wɛ̃́ndia pↄ́ lɛ́ a gↄ̃kpama gaa ↄ́ↄlↄ 
\q1 à zwã̀nkasa kàkaalawa. 
\q1  
\v 9 Pↄ́wɛna ń vɛ̃ɛ gbao zↄ̃̀ɛ Lua kpɛ́u, 
\q1 sa'on Dii gbàgbanaↄ lɛ́ ↄ́ↄlↄ. 
\q1  
\v 10 Bua músikɛ̀, 
\q1 tↄↄlɛ gↄ̃̀ wɛ̃nannↄ, 
\q1 pↄ́wɛna ásookɛ̀, 
\q1 vɛ̃ɛbɛ í vĩo, 
\q1 ku i bↄo. 
\q1  
\v 11 Zↄ̃ɛↄ, à ↄku á wɛ́wa, 
\q1 vɛ̃ɛbudeↄ, à búbuapɛ. 
\q1 À ↄ́ↄlↄ mase ń éseo yã́ musu, 
\q1 asa bua pↄkɛkɛa i zɛkɛo. 
\q1  
\v 12 Vɛ̃ɛliↄ i'ò, 
\q1 kaadↄɛnliↄ lá dↄ̀ńzi 
\q1 ń gbɛafuↄ ń daminaↄ ń maoↄ. 
\q1 Sɛ̃̀a líↄ giigàga píi, 
\q1 pↄna làa gbɛ̃nazĩnaↄwa. 
\q1  
\v 13 Sa'onaↄ, à zwã̀nkasa kákaála 
\q1 à bala bↄ sↄu, 
\q1 Lua gbagbakĩi zĩkɛnaↄ, 
\q1 à búbuapɛ. 
\q1 Ma Lua gbàgbanaↄ, 
\q1 à mↄ i la ń zwã̀nkasaↄ daa, 
\q1 asa pↄ́wɛna ń vɛ̃ɛ gbao lɛ́ gɛ́ á Lua kpɛ́u lↄo. 
\q1  
\v 14 À lɛye dilɛ Lua pↄ́ ũ, 
\q1 à gbɛ̃́ↄ kãaa, 
\q1 à maezↄ̃ↄↄ sísi 
\q1 ń á bùsudeↄ píi 
\q1 aa mↄ wiilɛ Dii á Luawa a kpɛ́u. 
\q1  
\v 15 Agya! Asa Dii gↄↄ kãikũ̀, 
\q1 kaalɛgↄↄ pↄ́ Gbãapiide dìlɛ lɛ́ mↄ́.\f + \fr 1.15 \ft Isa 13.6\f* 
\q1  
\v 16 Pↄblea i láa wá wáao lé? 
\q1 Pↄna ń yaalↄo mìdɛ wá Lua kpɛ́u. 
\q1  
\v 17 Pↄ́wɛna gↄ̃̀ koosiinnↄ bùsukↄ̃ↄtɛ̃u, 
\q1 dↄ̃ↄ gↄ̃̀ yáiyai, gbaↄ gbòo, 
\q1 asa pↄ́wɛna gìɛ. 
\q1  
\v 18 Zuↄ wii gↄ̃̀ dↄ, asa sɛ̃ kuo, 
\q1 kpàsaↄ bílikɛ̀ gɛ́kĩiwa. 
\q1 Baa pↄtuo nɛ́naↄ lɛ́ ĩamaɛ. 
\q1  
\v 19 Dii, málɛ lɛzunzi, 
\q1 asa dã́dãkɛkĩiↄ tɛkũ̀ɛ, 
\q1 tɛ́lɛpiↄ sɛ̃sao líↄ sã̀sã píi. 
\q1  
\v 20 Baa sɛ̃̀anↄbↄↄ, n ni lɛ́ ń dɛ, 
\q1 asa swadↄↄↄ gↄ̃̀ gii píiɛ, 
\q1 mɛ́ an pↄblekĩiↄ tɛkũ̀. 
\c 2  
\s1 Zĩgↄ̃ↄ lɛɛũa ń kwaↄ 
\q1  
\v 1 À kuupɛ Siↄna, 
\q1 à zĩ̀gãalɛ Dii gbɛ̀sĩsĩ musu. 
\q1 Bùsudeↄ píi, à gilikɛ, 
\q1 asa Dii gↄↄ lɛ́ mↄ́, à kãikũ̀. 
\q1  
\v 2 Gubeebeegↄↄɛ, gu a siakũ. 
\q1 Lou guduuduu gↄↄɛ. 
\q1 Zĩgↄ̃ dasiↄ lɛ́ li gbɛ̀sĩsĩↄla 
\q1 lán gudↄawa. 
\q1 An gbãa taa sáa i bↄ yãao 
\q1 mɛ́ a bↄ bau lↄo. 
\q1  
\v 3 Tɛ́ lɛ́ kṹ ń aɛ, tɛ́lɛpiↄ dↄ ń kpɛ. 
\q1 Bùsu kálɛ ń aɛ lán Edɛni swaluwa, 
\q1 à gↄ̃̀ ń iau lán gbáa wáiwaiwa, 
\q1 pↄe i e pìlimáo. 
\q1  
\v 4 An aɛ bↄ̀ lán sↄ̃́wa, 
\q1 aalɛ bàalɛ lán zĩkasↄ̃ wàiↄwa. 
\q1  
\v 5 An kↄ̃fĩ dↄ lán zĩkasↄ̃goↄwa, 
\q1 aalɛ sòo zↄ̃ gbɛ̀sĩsĩ misonaa. 
\q1 An kĩ́i dↄ lán tɛ́ kũa sɛ̃saowawa 
\q1 lán zĩgↄ̃ dasi pↄ́ aalɛ zĩ'ↄpooↄwa.\f + \fr 2.5 \ft Zia 9.7-9\f* 
\q1  
\v 6 Kɛ́ buiↄ wɛsìńlɛ, 
\q1 aa olo'olobò aa oosìsi. 
\q1  
\v 7 Aalɛ siu ń bao lán gↄ̃saↄwa, 
\q1 aalɛ vĩ gĩa lán zĩgↄ̃ↄwa. 
\q1 Baade lɛ́ táa'o a aɛdↄawaɛ, 
\q1 an gbɛ̃e i zã a ↄwao. 
\q1  
\v 8 Aalɛ gã̀sazↄ̃kↄ̃ɛo, 
\q1 aa mipɛ̀ ń aɛ, 
\q1 aalɛ kuadi ń ibɛɛↄwa, 
\q1 an zĩkabↄↄ lɛ́ kpánɛ́o. 
\q1  
\v 9 Aalɛ si wɛ̃́lɛ guu, 
\q1 aalɛ bàalɛ bĩ́i musu, 
\q1 aalɛ dɛdɛ kpɛ́ↄwa, 
\q1 aalɛ gɛ̃ fɛnɛntiↄ guu lán kpã́iↄwa. 
\q1  
\v 10 Tↄↄlɛ lɛ́ lualua ń aɛ, 
\q1 musupↄↄ lɛ́ deedee, 
\q1 ĩatɛ̃ ń mↄvuao lɛ́ siakũ, 
\q1 saanaↄ lɛ́ gↄ̃ tɛkɛsai.\f + \fr 2.10 \ft Zia 8.12\f* 
\q1  
\v 11 Dii dↄaa a zĩgↄ̃ↄnɛ ń lↄↄ gbãao. 
\q1 Aà ìwaↄ dasi maamaaɛ, 
\q1 gbɛ̃́ pↄ́ lɛ́ zĩkɛ aà yã́wapiↄ gbãa. 
\q1 Dii gↄↄpi zↄ̃ↄ, a to vĩa ń kṹ. 
\q1 Démɛ a e bↄui?\f + \fr 2.11 \ft Mal 3.2, Zia 6.17\f* 
\q1  
\v 12 Dii mɛ̀: Baa tia kɛ́wa, 
\q1 à su ma kĩ́i ń nↄ̀sɛmɛndoo 
\q1 ń lɛyeo ń ↄↄlↄo ń búbuapɛao. 
\b  
\q1  
\v 13 À nↄ̀sɛlilɛ, 
\q1 i kɛ á pↄkasaↄ no. 
\q1 À su Dii á Lua kĩ́i, 
\q1 asa a sùuu ń sósobio vĩ, 
\q1 aà pↄ lí pa kpaao. 
\q1 A gbɛ̃kɛ vĩ zↄ̃ↄ, 
\q1 ì ĩa pↄ́ a dìlɛ à damá bↄ a nↄ̀sɛɛɛ. 
\q1  
\v 14 Wìliↄ dↄ̃o tó a wɛ̃nadↄ̃wɛ̃ɛ, 
\q1 i wá tó ń báaao, 
\q1 wí gbadaɛ̀ ń pↄ́wɛnao ń vɛ̃ɛo. 
\q1  
\v 15 À kuupɛ Siↄna, 
\q1 à gbɛ̃́ↄ sísi, 
\q1 í lɛye dilɛ Lua pↄ́ ũ. 
\q1  
\v 16 À gbɛ̃́ↄ kãaa à gbãbↄnɛ́. 
\q1 À maezↄ̃ↄↄ naaa à nɛ́ↄ kãaa, 
\q1 baa a yↄ̃minaↄ. 
\q1 O nↄsɛnaɛ aà bↄ a kpɛ́u, 
\q1 aà nↄ dafu i bↄ kpɛa. 
\q1  
\v 17 To sa'ona pↄ́ lɛ́ Dii gbagbaↄ ↄ́ↄlↄ 
\q1 aà kpɛ́ kpɛɛlɛ ń aà gbagbakĩio zãnguo. 
\q1 Aa mɛ: Dii, ǹ n gbɛ̃́ↄ wɛgwa, 
\q1 ńsu to n bui gↄ̃ láanipↄ ũo, 
\q1 ńsu to buipãleↄ yãadańnↄo. 
\q1 Bↄ́yãi buiↄ mɛ wá Lua kú má niɛi? 
\s1 Dii zɛa ń a gbɛ̃́ↄ 
\q1  
\v 18 Dii nↄ̀sɛ a fɛlɛ a bùsu yã́ musu, 
\q1 i a gbɛ̃́ↄ wɛ̃nagwa. 
\q1  
\v 19 A wemá à mɛ: 
\q1 Málɛ pↄ́wɛna ń vɛ̃ɛo ń nísio kpã́sãɛ́, 
\q1 íↄ kãa pã́upãu. 
\q1 Má á kɛ láanipↄ ũ buiↄnɛ bau lↄo. 
\q1  
\v 20 Má gugbãntoodeↄ yáɛ́ zã̀zã, 
\q1 má ↄzↄ̃ńzi mà ń kpá gbáa wáiwai guuɛ. 
\q1 Má ń dↄaanaↄ zu Ísida Wisideu, 
\q1 mí ń gbɛzãdeↄ zu bɛ'aɛ ísiau. 
\q1 Aa yaikɛ, an gĩ iↄ dↄ we, 
\q1 yã́ pↄ́ aa kɛ̀ɛ́ píi yã́i. 
\b  
\q1  
\v 21 Tↄↄlɛ, ńsu vĩakɛo! 
\q1 Pↄnakɛ! Yáalↄ! 
\q1 Asa ma Dii ma yãzↄ̃ↄkɛ̀. 
\q1  
\v 22 Sɛ̃̀a nↄ̀bↄↄ, ásu vĩakɛo, 
\q1 asa sɛ̃ lɛ́ kùsi kpálɛ. 
\q1 Líↄ lɛ́ nɛ'i, 
\q1 kaadↄɛna ń vɛ̃ɛo lɛ́ ń asea kɛ. 
\q1  
\v 23 Siↄnadeↄ, à pↄnakɛ, 
\q1 à yáalↄ Dii á Luawa. 
\q1 Àlɛ á gba zuↄ lou kã́fĩa yã́iɛ, 
\q1 àlɛ lou maɛ́ lán yãawaɛ. 
\q1 A daalɛ a gↄↄwa, i bↄlɛi. 
\q1  
\v 24 Pↄ́wɛna a nↄnↄaa a gbɛ̃zɛↄu, 
\q1 vɛ̃ɛ ń nísio kákĩiↄ pa yɛlɛlɛ. 
\b  
\q1  
\v 25 Pↄ́ pↄ́ kwaↄ blè wɛ̃ ń wɛ̃o, 
\q1 sɛ̃sɛwɛkwaↄ ń kwasutɛ̃ↄ 
\q1 ń kwa búunaↄ ń kwa keleↄ, 
\q1 ma zĩgↄ̃ dasi pↄ́ ma gbaɛwápiↄ, 
\q1 má a fĩaboɛ́. 
\q1  
\v 26 Á pↄble lá á yeiwa à kã́, 
\q1 í ma Dii á Lua táasilɛ, 
\q1 asa ma yãbↄnsaɛkɛ̀ɛ́ɛ. 
\q1 Wí a ma gbɛ̃́ↄ kũ bau lↄo. 
\q1  
\v 27 Á Isailiↄ íↄ dↄ̃ sa 
\q1 kɛ́ ma Dii á Lua má kú á guu, 
\q1 mɛ́ dii pãle kuo. 
\q1 Wí a ma gbɛ̃́ↄ kũ bau lↄo. 
\c 3  
\s1 Dii a Nisĩna pisia a gbɛ̃́ↄwa 
\q1  
\v 1 Gↄↄ bee gbɛa má a Nisĩna pisi bui píiɛ, 
\q1 á nɛgↄ̃ɛↄ ń á nɛnↄɛↄ i ãnabikɛkɛ, 
\q1 á maezↄ̃ↄↄ i yã́ↄ e iu, 
\q1 á ɛ̀waasoↄ i wɛ́pungu'e. 
\q1  
\v 2 Gↄↄbeezĩ má a Nisĩna pisimá, 
\q1 baa ma zↄ̀blenaↄ, gↄ̃ɛↄ ń nↄɛↄ. 
\q1  
\v 3 Má yãbↄnsaɛↄ kɛ musu ń zĩ́lɛo, 
\q1 au ń tɛ́o ń tɛluo aↄ ku. 
\q1  
\v 4 Ĩatɛ̃ a siakũ, 
\q1 mↄvua a tã lán auwa 
\q1 e Dii mↄgↄↄ zↄ̃ↄ pↄ́ a to vĩa ń kṹ àↄ ká.\f + \fr 3.4 \ft Mat 24.29, Maa 13.24-25, Luk 21.25, Zia 6.12-13\f* 
\q1  
\v 5 Dii sìsinaↄ bↄ píi,\f + \fr 3.5 \ft Zĩn 2.17-21, Lom 10.13\f* 
\q1 asa suabaa aↄ ku Yelusalɛũ 
\q1 Siↄna gbɛ̀sĩsĩ musu lá Dii òwaɛ. 
\q1 Gbɛ̃́ pↄ́ bↄ̀piↄ aaↄ dɛ 
\q1 gbɛ̃́ pↄ́ Dii ń sisiↄ ũɛ. 
\c 4  
\s1 Dii yã́kpalɛkɛa ń buiↄ 
\q1  
\v 1 Gwa! Gↄↄ bee, zĩbeezĩ, 
\q1 tó ma Yelusalɛũdeↄ ń Yudaↄ píi dìlɛ ń pá ziu, 
\q1  
\v 2 má buiↄ kãaa píi 
\q1 mà pilańnↄ yã́kpalɛkɛguzulɛu. 
\q1 We má yã́kpalɛkɛuńnↄ 
\q1 ma gbɛ̃́ Isailiↄ ń ma bùsuo yã́ musu, 
\q1 asa aa ma gbɛ̃́ↄ fã̀aa dṹniau, 
\q1 aa ma bùsupi kpaalɛ̀kↄ̃ɛɛ. 
\q1  
\v 3 Aa tɛ́lɛpà aa ma gbɛ̃́ↄ kpaalɛ̀okↄ̃ɛ, 
\q1 aa ma nɛgↄ̃ɛↄ ń ma nɛnↄɛↄ yìa, 
\q1 aa káaluakà aa vɛ̃ɛmì ń a ↄ̃ao. 
\q1  
\v 4 Tiideↄ ń Sidↄ̃deↄ\f + \fr 4.4 \ft Isa 23.1-18, Mat 11.21-22\f* 
\q1 ń Filitɛ̃ bùsu zↄ̃lɛdeↄ píi, 
\q1 á ye sɛmanↄ kpelewa ni? 
\q1 Álɛ yã́ pↄ́ má kɛ̀ɛ́ fĩabomɛɛ yã̀? 
\q1 Tó álɛ a fĩabomɛɛ, 
\q1 má tó a wi á musu kã́ndo gↄ̃̀ↄɛ. 
\q1  
\v 5 Asa a ma ã́nusu ń ma vuao sɛ̀lɛ, 
\q1 a ma pↄmaa bɛɛɛdeↄ sɛ̀lɛ a taò 
\q1 á kàlɛ á tã́akpɛↄ guuɛ. 
\q1  
\v 6 A Yelusalɛũdeↄ ń Yudaↄ píi yìa Gɛlɛkiↄwa, 
\q1 kɛ́ à ń kɛ̃́ ń bùsuwa zã̀ yã́i. 
\q1  
\v 7 Gwa! Má ń vu iu, 
\q1 aai fɛlɛ gu pↄ́ a ń yiau, 
\q1 mí yã́ pↄ́ á kɛ̀nɛ́pi wíɛ́ á musu. 
\q1  
\v 8 Má á nɛgↄ̃ɛↄ ń á nɛnↄɛↄ yía Yudaↄwa, 
\q1 aai ń yía Seba pↄ́ kú zã̀ↄwa. 
\q1 Ma Dii mámɛ má ò. 
\q1  
\v 9 Yã́ɛ bee kpàwakɛ buiↄnɛ: 
\q1 À zĩ̀ sↄukɛ à nɛgↄ̃naↄ vu iu, 
\q1 í tó zĩgↄ̃ↄ fɛlɛ sↄ̃ kãi ḿpii. 
\q1  
\v 10 À á soonaↄpi fɛ̃ndaↄ ũ, 
\q1 à á máaso limibobↄↄ lilɛ sↄ̃naↄ ũ.\f + \fr 4.10 \ft Isa 2.4\f* 
\q1 Gbãasaide o gↄ̃san a ũ. 
\q1  
\v 11 Bui píi, à bↄ gupiiu, 
\q1 à mↄ kãaa we kpakpa. 
\q1 Dii, pilamá ń n nɛgↄ̃naↄ! 
\q1  
\v 12 Buiↄ vu iu, 
\q1 aai gɛ́ yã́kpalɛkɛguzulɛu, 
\q1 asa we má zↄ̃lɛu 
\q1 mà yã́kpalɛkɛ ń gupii buiↄ. 
\q1  
\v 13 An vãikɛa kɛ̀ zài! 
\q1 Kↄma ká pↄ́i ǹ kɛ̃́, 
\q1 asa à mà à kà kɛkɛaɛ.\f + \fr 4.13 \ft Zia 14.15\f* 
\q1 À mↄ ↄ̃zↄ̃ vɛ̃ɛwa a fɛ̃kĩiu, 
\q1 asa à pàɛ,\f + \fr 4.13 \ft Zia 14.20, 19.15\f* vɛ̃ɛkakĩiↄ pà yɛlɛlɛ. 
\q1  
\v 14 Wa ku we dasidasi yã́kpalɛ midɛguzulɛu, 
\q1 asa Dii yã́kpalɛkɛgↄↄ kãikũ̀ 
\q1 yã́kpalɛ midɛguzulɛuɛ. 
\q1  
\v 15 Ĩatɛ̃ ń mↄvuao a siakũ, 
\q1 saanaↄ tɛkɛ lↄo. 
\q1  
\v 16 Dii a bↄ Siↄna ń kãaao, 
\q1 a bↄ Yelusalɛũ ń lↄↄ gbãao. 
\q1 Musu ń zĩ́lɛo a lualua, 
\q1 ãma Dii aↄ dɛ ulɛkĩi ũ a gbɛ̃́ↄnɛɛ, 
\q1 aↄ dɛ aafia'ekĩi ũ Isailiↄnɛ. 
\q1  
\v 17 Íↄ dↄ̃ sa kɛ́ ma Dii á Lua, 
\q1 má kú Siↄna musu, ma gbɛ pↄ́ a kua adoapi. 
\q1 Yelusalɛũá ma pↄ́ɛ, 
\q1 buipãleↄ si wɛ̃́lɛpiu bau lↄo. 
\q1  
\v 18 Gↄↄ bee gbɛ̀sĩsĩↄ vɛ̃ɛbɛ a kwɛ́, 
\q1 mɛ́ sĩ̀sĩↄ pↄtuoↄ vĩ aↄ diɛ. 
\q1 Yuda bùsu swadↄↄe í a zↄ̃ɛo. 
\q1 Nibↄna a bↄ Dii kpɛ́u à bàalɛ, 
\q1 i mↄ̀sɛpisi lɛpusia guzulɛu. 
\q1  
\v 19 Egipi a gↄ̃ gbáa gii ũ, 
\q1 Ɛdↄũ a gↄ̃ guwaiwai ũ 
\q1 yãpãsĩ pↄ́ aa kɛ̀ Yudaↄnɛ yã́i, 
\q1 asa aa yãesaidepiↄ dɛ̀dɛ ń bùsuuɛ. 
\q1  
\v 20 Yuda bùsu aↄ kálɛa gↄↄpiiɛ, 
\q1 wiↄ ku Yelusalɛũ wɛ̃ ń wɛ̃o. 
\q1  
\v 21 Tↄ pↄ́ mi sínɛ́ yãao ↄ̃ má sínɛ́ sa. 
\q1 Ma Dii, míↄ ku Siↄna.