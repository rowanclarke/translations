\p 
\v 1 Écoutez ceci, \w vous|strong="H1121"\w* \w tous|strong="H1121"\w* \w les|strong="H1121"\w* \w peuples|strong="H1121"\w*; prêtez l'oreille, \w vous|strong="H1121"\w* \w tous|strong="H1121"\w* \w les|strong="H1121"\w* habitants \w du|strong="H1121"\w* monde!
