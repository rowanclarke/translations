\v 25 Te \w phoeiah|strong="H9999"\w* \w David|strong="H1732"\w* loh \w BOEIPA|strong="H3068"\w* \w ham|strong="H9997"\w* \w hmueihtuk|strong="H4196"\w* \w pahoi|strong="H8033"\w* a \w suem|strong="H1129"\w* \w tih|strong="H9999"\w* \w hmueihhlutnah|strong="H5930"\w* \w neh|strong="H9999"\w* \w rhoepnah|strong="H8002"\w* hmueih te a \w khuen|strong="H5927"\w*. Te \w daengah|strong="H9999"\w* te \w khohmuen|strong="H0776"\w* \w ham|strong="H9997"\w* \w BOEIPA|strong="H3068"\w* taengah \w thangthui|strong="H6279"\w* \w tih|strong="H9999"\w* \w Israel|strong="H3478"\w* \w sokah|strong="H5921"\w* \w lucik|strong="H4046"\w* te khaw \w cing|strong="H6113"\w* van. 
