\id TDX - Sa'a UTF-8 
\h MO DOLOSINGE 
\toc1 Mo tatala ienini kire sai pe'i'o huni aalamie mo dolosinge i'oe. 
\toc2 MO DOLOSINGE 
\mt2 Mo tatala ienini kire sai pe'i'o  
\mt2 huni aalamie mo dolosinge i'oe.  
\c 1  s ?A tei ni a God? ?Tolahana God e uri taa? 
\pi3 \bd Mak\bd* 10:27, 12:29-30; \bd Luk\bd* 1:37, 6:35-36; \bd Jon\bd* 4:23-24; \bd Palonga\bd* 14:14-17, 17:22-31; \bd Rom\bd* 1:18-23, 11:33-36; \bd 1 Korinit\bd* 8:4-6; \bd 2 Korinit\bd* 1:3; \bd 1 Timoti\bd* 1:17, 6:15-16; \bd Hibru\bd* 4:13, 10:30-31; \bd Jemes\bd* 1:17; \bd 1 Pita\bd* 1:14-17; \bd 1 Jon\bd* 1:5, 4:7-12, 4:16; \bd Jiud\bd* 1:24-25; \bd Haata'inge\bd* 4:8-11, 15:3-4. s ?A tei nge e asuie walumalau na ahutana mo ola i laona?  
\pi3 \bd Matiu\bd* 6:25-34, 10:29-31, 19:4; \bd Jon\bd* 1:3; \bd Palonga\bd* 14:15-17, 17:24-26; \bd Rom\bd* 8:28, 11:36; \bd 1 Korinit\bd* 8:6; \bd Kolose\bd* 1:15-17; \bd Hibru\bd* 1:2-3, 11:3; \bd Jemes\bd* 4:13-16; \bd Haata'inge\bd* 4:11. s ?A tei ni a Jisas? ?Tolahana Jisas e uri taa?  
\pi2 A Jisas Kalena God.  
\pi3 \bd Matiu\bd* 11:27-30, 16:13-17; \bd Luk\bd* 1:35; \bd Jon\bd* 1:1-18, 5:19-29, 6:35-40, 8:58, 11:25-27, 14:5-11, 17:1-5, 20:26-31; \bd Palonga\bd* 3:13-16, 4:10-12; \bd Rom\bd* 1:3-4; \bd 1 Korinit\bd* 3:11; \bd 2 Korinit\bd* 4:4-6, 5:21; \bd Kalesia\bd* 4:4-5; \bd Pilipae\bd* 2:5-11; \bd Kolose\bd* 1:15-20, 2:9-10; \bd Hibru\bd* 1:1-14, 7:26-28; \bd 1 Jon\bd* 2:1-2, 5:20; \bd Haata'inge\bd* 1:12-18, 19:11-16.  
\pi2 E ne'i iinoni aana e hute aana iinoni.  
\pi3 \bd Matiu\bd* 1:18-25, 2:1-23; \bd Luk\bd* 1:26-38, 2:1-20; \bd Jon\bd* 1:14; \bd Kalesia\bd* 4:4-5; \bd Pilipae\bd* 2:6-7; \bd Hibru\bd* 2:14-18.  
\pi2 E ha'a-uusulie mwala, e ha'a-uurie mo mae-maea'a, na e asuie mo hu'i-hu'ite hunge hai aaopa'i.  
\pi3 \bd Matiu\bd* 4:23-25, 7:28-29, 8:1-4, 8:5-13, 8:14-15, 8:23-27, 8:28-33, 9:1-7, 9:18-36, 11:1-6, 12:9-14, 12:22, 14:15-21, 14:22-32, 15:22-28, 15:32-38, 17:14-18, 20:29-34, 21:18-22; \bd Mak\bd* 1:21-28, 7:32-37, 8:22-25; \bd Luk\bd* 4:14-44, 5:4-8, 7:11-15, 13:10-13, 14:1-4, 17:12-14, 22:50-51; \bd Jon\bd* 2:1-11, 4:46-54, 5:5-9, 9:1-7, 11:11-44, 20:30-31, 21:4-6; \bd Palonga\bd* 2:22, 10:36-38. s ?A tei ni Li'oa Maa'i? ?Tolahana Li'oa Maa'i e uri taa?  
\pi3 \bd Matiu\bd* 28:19; \bd Mak\bd* 1:9-11, 3:28-30; \bd Luk\bd* 1:35, 3:16, 4:1, 11:13, 12:12; \bd Jon\bd* 1:32-34, 3:5-8, 7:37-39, 14:15-17, 14:26, 15:26, 16:7-15, 20:19-23; \bd Palonga\bd* 1:4-5, 1:8, 2:1-18, 2:38-39, 4:31, 5:3-5, 8:14-17, 10:44-48, 13:2-4, 15:28, 16:7-10, 19:1-7; \bd Rom\bd* 5:5, 7:6, 8:9-16, 8:26-27; \bd 1 Korinit\bd* 2:4, 2:9-16, 3:16, 6:11, 6:19, 12:1-13; \bd 2 Korinit\bd* 1:21-22, 5:5, 13:14; \bd Kalesia\bd* 3:2-5, 4:6, 5:16-18, 5:22-25; \bd Epesas\bd* 1:13-14, 1:17, 3:16, 4:3-4, 4:30. s ?Nga taa e rau aana Jisas?  
\pi2 Kire leie hunie maenga.  
\pi3 \bd Matiu\bd* 26:47-68, 27:1-2, 27:11-31; \bd Mak\bd* 14:43-65, 15:1-20; \bd Luk\bd* 22:47-53, 22:63-71, 23:1-25; \bd Jon\bd* 18:1-14, 18:19-24, 18:28—19:16.  
\pi2 Kire horo maesie i lengine po'u-po'u.  
\pi3 \bd Matiu\bd* 27:32-56; \bd Mak\bd* 15:21-41; \bd Luk\bd* 23:26-49; \bd Jon\bd* 19:17-37.  
\pi2 Kire haitolinge'inie.  
\pi3 \bd Matiu\bd* 27:57-66; \bd Mak\bd* 15:42-47; \bd Luk\bd* 23:50-56; \bd Jon\bd* 19:38-42.  
\pi2 E mauri eeliho'i na mwala oto hunge kire leesie.  
\pi3 \bd Matiu\bd* 28:1-20; \bd Mak\bd* 16:1-8; \bd Luk\bd* 24:1-49; \bd Jon\bd* 20:1—21:14; \bd Palonga\bd* 1:3-8, 2:24-32, 3:15, 4:10, 4:33, 10:39-43, 13:29-39, 17:2-3, 17:30-31; \bd Rom\bd* 1:4, 4:24-25; \bd 1 Korinit\bd* 15:3-8, 15:12-21; \bd Haata'inge\bd* 1:18.  
\pi2 E tahela'i lo'u i Lengi.  
\pi3 \bd Luk\bd* 24:50-51; \bd Palonga\bd* 1:9-11, 2:32-36, 5:30-31; \bd Rom\bd* 8:34; \bd Epesas\bd* 1:20-23; \bd Pilipae\bd* 2:9-11; \bd Hibru\bd* 1:3-11, 2:9, 4:14-16, 7:25-26, 10:12-14; \bd 1 Pita\bd* 3:22. s ?Aena nga taa nge a Jisas e mae?  
\pi3 \bd Mak\bd* 10:45; \bd Jon\bd* 3:16; \bd Rom\bd* 4:25, 5:8; \bd 1 Korinit\bd* 15:3-4; \bd 2 Korinit\bd* 5:19-21; \bd Kalesia\bd* 3:13; \bd 1 Timoti\bd* 2:5-6; \bd Hibru\bd* 2:9, 9:28; \bd 1 Pita\bd* 1:18-20, 2:24-25, 3:18; \bd 1 Jon\bd* 2:2; \bd Haata'inge\bd* 5:8-10. s ?Nga taa ni lo'onga'inge aana ha'a-uuringe?  
\pi2 Apune a Jisas e ta'aasie mo ooraha'aa ikie.  
\pi3 \bd Matiu\bd* 26:26-29; \bd Rom\bd* 3:25, 5:9-10; \bd Epesas\bd* 1:7; \bd Hibru\bd* 9:11-14; \bd 1 Jon\bd* 1:6-7; \bd Haata'inge\bd* 7:14-17.  
\pi2 A God e sae'aasie mo ooraha'aa ikie.  
\pi3 \bd Palonga\bd* 5:31, 10:43, 26:18; \bd Epesas\bd* 1:7, 4:32; \bd Kolose\bd* 1:13-14, 2:13-14; \bd Hibru\bd* 10:17-18; \bd 1 Jon\bd* 1:8-10. s ?Iinoni ha'a-uurilana e lae, e aaopa uri taa?  
\pi2 E oodota'i i maana God  
\pi3 \bd Palonga\bd* 13:38-39; \bd Rom\bd* 1:16-17, 3:21-26, 5:1, 5:18-19; \bd Kalesia\bd* 2:16, 3:6-9; \bd Taetas\bd* 3:7.  
\pi2 E to'o aana mei meu-meuringe haalu.  
\pi3 \bd Jon\bd* 3:1-16, 5:19-29, 10:10, 11:25-26, 14:6, 17:2-3, 20:31; \bd Rom\bd* 5:21, 6:5-14, 8:10-17; \bd 2 Korinit\bd* 5:17; \bd Kalesia\bd* 2:20; \bd Epesas\bd* 2:1-6; \bd Kolose\bd* 2:13, 3:1-4; \bd 2 Timoti\bd* 1:10; \bd Taetas\bd* 3:4-7; \bd 1 Pita\bd* 1:23; \bd 1 Jon\bd* 5:11-13.  
\pi2 E ne'ie oto mwela a God.  
\pi3 \bd Jon\bd* 1:12-13; \bd Rom\bd* 8:14-17; \bd Kalesia\bd* 4:6-7; \bd Hibru\bd* 12:5-11; \bd 1 Jon\bd* 3:1-3. s Ineu iinoni diana. ?Oto ha'a-uurileku ke lae huni taa?  
\pi2 Ahutana iinoni kire ooraha'aa mango.  
\pi3 \bd Jon\bd* 8:7-9; \bd Rom\bd* 3:9-20, 3:23, 5:12; \bd Kalesia\bd* 3:22; \bd 1 Jon\bd* 1:8-10.  
\pi2 Tolahana kira ooraha'aala e uuri.  
\pi3 \bd Rom\bd* 1:18-32, 8:5-8; \bd Kalesia\bd* 5:19-21; \bd Epesas\bd* 2:1-3, 5:3-5; \bd Kolose\bd* 3:5-10; \bd Jemes\bd* 4:17; \bd 1 Pita\bd* 4:3; \bd 1 Jon\bd* 3:4-5.  
\pi2 A God kei leie ahutana mo iinoni haahie ooraha'aa ikire.  
\pi3 \bd Matiu\bd* 10:28, 13:41-42; \bd Jon\bd* 3:18-20, 3:36; \bd Palonga\bd* 17:30-31; \bd Rom\bd* 1:18-19, 6:23; \bd Kalesia\bd* 6:7-8; \bd Kolose\bd* 3:5-6; \bd 2 Tesalonaeka\bd* 1:7-9; \bd Hibru\bd* 9:27, 10:26-31; \bd 1 Pita\bd* 1:17, 4:3-5; \bd Jiud\bd* 1:7; \bd Haata'inge\bd* 20:11-15. s A God e paine na e tohungei nanama, ta'e ineu nou mwai-mwei na nou ka'a roro'a ike. ?Oto a God ko lio i sulieu taane wa ha'ike?  
\pi3 \bd Jon\bd* 3:16; \bd Rom\bd* 5:8; \bd 1 Timoti\bd* 2:3-6; \bd 2 Pita\bd* 3:9; \bd 1 Jon\bd* 4:9-10. s Ineu iinoni aaela oto liutaa. ?Uri a God e sai sae'aasie taane ahutana mo ooraha'aa ineu?  
\pi3 \bd Palonga\bd* 5:31, 10:43, 26:18; \bd Epesas\bd* 1:7; \bd Kolose\bd* 1:13-14, 2:13-14; \bd 1 Timoti\bd* 1:15-16; \bd Hibru\bd* 10:17-18; \bd 1 Jon\bd* 1:8-10. s ?Oto nga taa nge ne kei esuie hunie ha'a-uurileku ke lae?  
\pi2 Ne ke oonisae mwaanie ooraha'aa, na ne ke toli'aasie oto tolahai ola ni ooraha'aa.  
\pi3 \bd Matiu\bd* 4:17; \bd Mak\bd* 6:12; \bd Luk\bd* 13:1-5, 15:1-31, 24:45-47; \bd Palonga\bd* 2:37-40, 3:19-20, 17:29-31, 20:21, 26:19-20; \bd 2 Korinit\bd* 7:8-11; \bd 2 Pita\bd* 3:9; \bd Haata'inge\bd* 9:20-21.  
\pi2 Ne ke noruto'o mola aana Jisas hunie ke ha'a-uurieu.  
\pi3 \bd Jon\bd* 1:12, 3:15-18, 3:36, 6:47, 14:6, 20:31; \bd Palonga\bd* 4:12, 16:30-31; \bd Rom\bd* 3:20-22, 10:9-10; \bd Kalesia\bd* 2:16; \bd Epesas\bd* 2:8-9. s ?Ne kei sai diana aana uri ha'a-uurileku e lae uri taa?  
\pi3 \bd Jon\bd* 3:1-16, 5:19-29, 11:25-26, 14:6, 17:2-3, 20:31; \bd Rom\bd* 8:10-17; \bd 2 Korinit\bd* 5:17; \bd Epesas\bd* 2:1-6; \bd Kolose\bd* 2:13; \bd Taetas\bd* 3:4-7; \bd 1 Jon\bd* 5:11-13. s ?Aana nou si ne'ie iinoni hiiwalaimoli, nge mo tolahai ola haalu uri taa ne ke hele i suli'i?  
\pi2 Ne ke toli'aasie mo tolahai ola aaela hunie ne ke hele susule'i aana mo tolahai ola diana.  
\pi3 \bd Luk\bd* 13:3; \bd Palonga\bd* 26:20; \bd Rom\bd* 12:1-2; \bd Kolose\bd* 3:5-17; \bd 1 Tesalonaeka\bd* 4:7; \bd Epesas\bd* 4:28; \bd 2 Pita\bd* 3:9  
\pi2 Ne ke loto maa'i.  
\pi3 \bd Matiu\bd* 28:18-20; \bd Jon\bd* 3:22, 4:1-2; \bd Palonga\bd* 2:37-42, 8:12, 8:36-38, 10:44-48, 16:14-15, 16:31-33, 19:1-7, 22:12-16; \bd Rom\bd* 6:1-4; \bd Kalesia\bd* 3:26-27; \bd Kolose\bd* 2:12; \bd 1 Pita\bd* 3:20-22.  
\pi2 Ne ke saaie mo Uusu-uusu Maa'i oto tarau hunie ne ke saie walu ola i sulie a God na nga taa e saeto'o aana ne ke asuie.  
\pi3 \bd Matiu\bd* 4:1-4, 5:17-20, 22:29; \bd Jon\bd* 8:31-32, 20:31; \bd Palonga\bd* 20:32; \bd Rom\bd* 15:4, 16:26; \bd Kolose\bd* 3:16; \bd 1 Tesalonaeka\bd* 2:13; \bd 1 Timoti\bd* 4:13; \bd 2 Timoti\bd* 3:14-17; \bd Hibru\bd* 4:12; \bd 1 Pita\bd* 1:22-25; \bd 2 Pita\bd* 1:19-21; \bd 2 Jon\bd* 1:9-10; \bd Haata'inge\bd* 1:3.  
\pi2 Ne ke loko tarau pe'ie ngaeta mo iini kire hiiwalaimoli huni palo-paloa God.  
\pi3 \bd Matiu\bd* 18:19-20; \bd Palonga\bd* 2:41-47; \bd Palonga\bd* 2:41-47; \bd Rom\bd* 12:4-8; \bd Epesas\bd* 1:22-23, 4:11-16; \bd Kolose\bd* 3:15-17; \bd 1 Timoti\bd* 4:13; \bd Hibru\bd* 10:24-25.  
\pi2 Ne ke ngau maa'i tararuru pe'ie ngaeta mo iini kire hiiwalaimoli.  
\pi3 \bd Matiu\bd* 26:26-30; \bd Mak\bd* 14:22-26; \bd Luk\bd* 22:14-20; \bd 1 Korinit\bd* 10:14-22, 11:17-34.  
\pi2 Ne ke aarenga'i hunie a God hunie ne ke ere pe'ie i sulie mau-meuringe ineu.  
\pi3 \bd Matiu\bd* 6:5-13, 7:7-11, 18:19-20; \bd Mak\bd* 1:35, 11:24-25; \bd Luk\bd* 5:16, 6:12, 11:1-13, 18:1-8, 21:36; \bd Jon\bd* 14:13-14, 15:7, 16:23-26; \bd Rom\bd* 8:26-27, 12:12; \bd Epesas\bd* 2:18, 6:18; \bd Pilipae\bd* 4:6-7; \bd Kolose\bd* 4:2; \bd 1 Tesalonaeka\bd* 5:17; \bd 1 Timoti\bd* 2:1-4, 2:8, 4:4-5; \bd Hibru\bd* 4:16, 10:19-22; \bd Jemes\bd* 1:5-8, 4:2-3, 5:13-18; \bd 1 Pita\bd* 4:7; \bd 1 Jon\bd* 3:21-22, 5:14-15. s ?Nga taa ni aarenga'inge? ?Na ne kei aarenga'i uri taa?  
\pi3 \bd Matiu\bd* 6:5-13, 7:7-11, 14:23, 18:19-20; \bd Mak\bd* 1:35, 11:24-25; \bd Luk\bd* 5:16, 6:12, 11:1-13, 18:1-8, 21:36, 22:32-45; \bd Jon\bd* 14:13-14, 15:7, 16:23-26, 17:1-26; \bd Palonga\bd* 4:24-31, 16:25; \bd Rom\bd* 1:9-10, 8:26-27, 10:1-2,12:12, 15:30-33; \bd 2 Korinit\bd* 12:7-10; \bd Epesas\bd* 1:15-20, 2:18, 3:14-21, 6:18-20; \bd Pilipae\bd* 1:3-11, 4:6-7; \bd Kolose\bd* 1:9-12, 4:2-4; \bd 1 Tesalonaeka\bd* 3:9-13, 5:17; \bd 2 Tesalonaeka\bd* 1:11-12, 3:1-2; \bd 1 Timoti\bd* 2:1-4, 2:8, 4:4-5; \bd Hibru\bd* 4:16, 5:7, 7:25, 10:19-22; \bd Jemes\bd* 1:5-8, 4:2-3, 5:13-18; \bd 1 Pita\bd* 4:7; \bd 1 Jon\bd* 3:21-22, 5:14-15. s ?Tolahaku na lo'onga'inge ineu kei hei-oolisi uri taa aana maholo nou ne'ie oto iinoni hiiwalaimoli?  
\pi2 Ne ke manata diana hunie a God.  
\pi3 \bd Matiu\bd* 22:34-40; \bd Mak\bd* 12:28-34; \bd Luk\bd* 10:25-27; \bd 1 Pita\bd* 1:8; \bd 1 Jon\bd* 4:20-21, 5:3.  
\pi2 Ne ke tola i sulie a God na a Jisas aana ingeie oto Aalaha ineu.  
\pi3 \bd Jon\bd* 14:15, 14:21, 14:23-24, 15:10-17; \bd Rom\bd* 13:8-10; \bd 1 Pita\bd* 1:14-16; \bd 1 Jon\bd* 2:3-8, 3:22-24; \bd 2 Jon\bd* 1:5-6.  
\pi2 Tolahaku ke urihana tolahana Jisas.  
\pi3 \bd Jon\bd* 13:34-35, 14:27; \bd Rom\bd* 12:9-13; \bd Kalesia\bd* 5:22-26; \bd Kolose\bd* 3:12-17; \bd 1 Tesalonaeka\bd* 5:16-18.  
\pi2 Ne ke paalahea God tarau haahie walu ha'adiana'anga ingeie hunieu.  
\pi3 \bd Luk\bd* 17:11-19; \bd Jon\bd* 6:11; \bd Rom\bd* 1:21; \bd Epesas\bd* 5:20; \bd Pilipae\bd* 4:4-7; \bd Kolose\bd* 2:7, 3:17, 4:2; \bd 1 Tesalonaeka\bd* 5:18; \bd 1 Timoti\bd* 2:1, 4:4-5  
\pi2 Ne ke manata diana hunie ahutana iinoni.  
\pi3 \bd Matiu\bd* 5:43-48, 22:34-40; \bd Mak\bd* 12:28-34; \bd Luk\bd* 10:25-37; \bd Jon\bd* 13:34-35, 15:12-17; \bd Rom\bd* 12:9-10, 13:8-10; \bd 1 Korinit\bd* 13:1-3, 16:14; \bd Kalesia\bd* 5:13-15; \bd 1 Tesalonaeka\bd* 4:9-10; \bd 1 Pita\bd* 4:8; \bd 1 Jon\bd* 2:7-11, 3:11-18, 4:7-21.  
\pi2 Ne ke pe'i-pe'ie ngaeta mwala.  
\pi3 \bd Matiu\bd* 5:43-48, 6:1-4, 7:12, 22:34-40, 25:31-46; \bd Mak\bd* 12:28-34; \bd Luk\bd* 3:10-11, 6:38, 10:25-37; \bd Jon\bd* 13:34-35, 14:21, 15:12-17; \bd Palonga\bd* 11:27-30; \bd Rom\bd* 12:9-10, 13:8-10; \bd 1 Korinit\bd* 10:24, 13:1-3, 16:14; \bd 2 Korinit\bd* 8:1-15, 9:1-15; \bd Kalesia\bd* 5:13-15, 6:9-10; \bd 1 Tesalonaeka\bd* 4:9-10; \bd Pilipae\bd* 4:14-19; \bd Hibru\bd* 10:24, 13:1-3, 13:16; \bd Jemes\bd* 1:27, 2:15-16; \bd 1 Pita\bd* 1:8, 4:8; \bd 1 Jon\bd* 2:9-11, 3:11-18, 4:7-21.5:3,  
\pi2 Ne ke ha'amwai-mwei'aau.  
\pi3 \bd Matiu\bd* 5:3-12, 18:1-5; \bd Luk\bd* 14:7-11, 18:9-14; \bd Rom\bd* 12:16; \bd 1 Korinit\bd* 4:7; \bd 2 Korinit\bd* 10:17-18; \bd Epesas\bd* 4:2; \bd Pilipae\bd* 2:3-11; \bd Kolose\bd* 3:12-13; \bd Jemes\bd* 4:5-16; \bd 1 Pita\bd* 5:5-7.  
\pi2 Ne ke ha'ama'u aana mo iini nge kire paine haahieu.  
\pi3 \bd Matiu\bd* 22:15-22; \bd Palonga\bd* 5:27-29; \bd Rom\bd* 13:1-7; \bd 1 Timoti\bd* 2:1-4; \bd Hibru\bd* 13:17; \bd Taetas\bd* 3:1; \bd 1 Pita\bd* 2:13-17. s ?Mo ola uri taa ka'a malisine ne ke asui'i?  
\pi2 Ne ke su'uri ne'isae paine aana to'oha na to'o-to'olaku.  
\pi3 \bd Matiu\bd* 6:19-21, 6:24-34; \bd Luk\bd* 12:13-21, 12:32-34; \bd Palonga\bd* 20:35; \bd 1 Timoti\bd* 6:6-10, 6:17-19; \bd Hibru\bd* 13:5-6, \bd Jemes\bd* 2:1-9, 5:1-6.  
\pi2 Ne ke su'uri palo-paloa nga god aaopa wa ne ke noruto'o aana mo aakalo wa mo weuwaka oto i na'o huni pe'ieu.  
\pi3 \bd Matiu\bd* 4:10; \bd Palonga\bd* 17:22-31; \bd 1 Korinit\bd* 5:11, 6:9-11, 8:1-13, 10:1-22; \bd 2 Korinit\bd* 6:14-18; \bd Kalesia\bd* 5:19-21; \bd 1 Tesalonaeka\bd* 1:9-10; \bd 1 Jon\bd* 5:21; \bd Haata'inge\bd* 21:8, 22:15.  
\pi2 Ne ke su'uri sukaa nanamanga mo aakalo huni pe'ieu wa hunie ke waelie ngaeta mo iini.  
\pi3 \bd Matiu\bd* 4:10; \bd Palonga\bd* 17:22-31; \bd 1 Korinit\bd* 5:11, 6:9-11, 8:1-13, 10:1-22; \bd 2 Korinit\bd* 6:14-18; \bd Kalesia\bd* 5:19-21; \bd 1 Tesalonaeka\bd* 1:9-10; \bd 1 Jon\bd* 5:21; \bd Haata'inge\bd* 21:8, 22:15.  
\pi2 Ne ke su'uri uunu ola aana nga ola mauri hunie mo aakalo.  
\pi3 \bd Matiu\bd* 9:13; \bd Mak\bd* 12:33; \bd Rom\bd* 12:1; \bd Hibru\bd* 9:6—10:18.  
\pi2 Ne ke su'uri mehiri aana inulana wai ni pweunge.  
\pi3 \bd Rom\bd* 13:13; \bd 1 Korinit\bd* 5:9-11, 6:9-11; \bd Kalesia\bd* 5:19-21; \bd Epesas\bd* 5:18; \bd 1 Timoti\bd* 3:1-3; \bd Taetas\bd* 1:7; \bd 1 Pita\bd* 4:3-5.  
\pi2 Ne ke su'uri aeni ola.  
\pi3 \bd Matiu\bd* 5:27-30; \bd Jon\bd* 8:2-11; \bd Rom\bd* 13:8-10; \bd 1 Korinit\bd* 5:9-11, 6:9-20; \bd Kalesia\bd* 5:19; \bd Epesas\bd* 5:3; \bd Kolose\bd* 3:5-6; \bd 1 Tesalonaeka\bd* 4:1-8; \bd Hibru\bd* 13:4; \bd Jiud\bd* 1:7.  
\pi2 Ne ke kineta'inieu mwaanie erenga haitapali i sulie ta'ena nga ola.  
\pi3 \bd Matiu\bd* 5:25-26, 5:38-42, 18:15-17; \bd Rom\bd* 12:14-21; \bd 1 Korinit\bd* 6:1-8.  
\pi2 Ne ke su'uri eero. \bd Jon\bd* 8:44,  
\pi3 \bd Epesas\bd* 4:25; \bd Kolose\bd* 3:9; \bd 1 Pita\bd* 3:10; \bd Haata'inge\bd* 21:8, 22:15.  
\pi2 Ne ke su'uri peli.  
\pi3 \bd Matiu\bd* 15:19, 19:18; \bd Luk\bd* 19:8; \bd Rom\bd* 13:9; \bd 1 Korinit\bd* 6:9-10; \bd Epesas\bd* 4:28; \bd Jemes\bd* 5:4; \bd 1 Pita\bd* 4:15; \bd Haata'inge\bd* 9:21.  
\pi2 Ne ke su'uri ere aaela.  
\pi3 \bd Epesas\bd* 4:29, 5:4; \bd Pilipae\bd* 4:8; \bd Kolose\bd* 3:8; \bd 1 Timoti\bd* 4:12; \bd Jemes\bd* 1:26, 3:9-10.  
\pi2 Ne ke su'uri su'ue aaelanga nge nga iini ko esuie hunieu.  
\pi3 \bd Matiu\bd* 6:12-15, 18:21-35; \bd Mak\bd* 11:25; \bd Luk\bd* 17:3-4; \bd Rom\bd* 12:17-21; \bd Epesas\bd* 4:31-32; \bd Kolose\bd* 3:13.  
\pi2 Ne ke manata diana hunie ta'ena nga iini, na ma'alana nou sai saewasulie aaelanga nga iini e asuie, ta'e ne ke manata diana mola hunie iinonine.  
\pi3 \bd Kalesia\bd* 5:22-23; \bd Epesas\bd* 4:26; \bd Kolose\bd* 3:8, 3:13; \bd Jemes\bd* 1:19-20. s ?Ne kei saie nga taa e aaela na nga taa e diana uri taa?  
\pi3 \bd Rom\bd* 1:18-32; \bd 1 Korinit\bd* 6:9-11; \bd Kalesia\bd* 5:19-21; \bd Epesas\bd* 5:3-5; \bd Kolose\bd* 3:5-10; \bd Jemes\bd* 4:17; \bd 1 Pita\bd* 4:3; \bd 1 Jon\bd* 2:15-17, 3:4-5. s ?Nga taa ni soihaada'inge?  
\pi3 \bd Matiu\bd* 16:13-20; \bd Palonga\bd* 2:41-42; \bd Rom\bd* 12:4-8; \bd 1 Korinit\bd* 12:12-30; \bd Epesas\bd* 1:22-23, 2:19-22, 4:1-16; \bd Kolose\bd* 1:18; \bd Hibru\bd* 10:24-25; \bd 1 Pita\bd* 2:4-10; \bd Haata'inge\bd* 19:5-10. s ?Mo iinoni diana aana soihaada'inge tolahada e uri taa?  
\pi3 \bd Matiu\bd* 16:13-20; \bd Palonga\bd* 2:41-42; \bd Rom\bd* 12:4-8; \bd 1 Korinit\bd* 12:12-30; \bd Epesas\bd* 1:22-23, 2:19-22, 4:1-16; \bd Kolose\bd* 1:18; \bd Hibru\bd* 10:24-25; \bd 1 Pita\bd* 2:4-10; \bd Haata'inge\bd* 19:5-10. s ?Mo na'ohai iinoni aana soihaada'inge tolahada e uri taa?  
\pi3 \bd Matiu\bd* 28:18-20; \bd Luk\bd* 22:24-27; \bd Palonga\bd* 6:1-6, 14:23, 20:17-35; \bd 1 Tesalonaeka\bd* 2:1-12; \bd 1 Timoti\bd* 3:1-13, 4:1-16, \bd Taetas\bd* 1:5-9, \bd 1 Pita\bd* 5:1-4. s ?Mo iinoni aana soihaada'inge tolahada kei uri taa hunie mo na'ohai iinoni aana soihaada'inge?  
\pi3 \bd 1 Korinit\bd* 9:14; \bd Kalesia\bd* 6:6; \bd 1 Tesalonaeka\bd* 5:12-13; \bd 1 Timoti\bd* 5:17-22; \bd Hibru\bd* 13:7, 13:17. s ?Tolahana uluhe ni iinoni e hiiwalaimoli aana Jisas e uri taa?  
\pi2 ?Poro nge e hiiwalaimoli aana Jisas tolahana e uri taa?  
\pi3 \bd Matiu\bd* 19:4-6; \bd 1 Korinit\bd* 7:1-16; \bd Epesas\bd* 5:21-33; \bd Kolose\bd* 3:18-19; \bd Taetas\bd* 2:3-5; \bd Hibru\bd* 13:4; \bd 1 Pita\bd* 3:1-7.  
\pi2 ?Hu'e nge e hiiwalaimoli aana Jisas tolahana e uri taa?  
\pi3 \bd Matiu\bd* 19:4-6; \bd 1 Korinit\bd* 7:1-16; \bd Epesas\bd* 5:21-33; \bd Kolose\bd* 3:18-19; \bd Taetas\bd* 2:3-5; \bd Hibru\bd* 13:4; \bd 1 Pita\bd* 3:1-7.  
\pi2 Ineu na hu'e ineu mere ka'a sai ii'o ruru ike. ?Uri nou sai sikaa mola?  
\pi3 \bd Matiu\bd* 5:31-32, 19:3-9; \bd Luk\bd* 16:18; \bd Rom\bd* 7:2-3; \bd 1 Korinit\bd* 7:10-11.  
\pi2 Hu'e ineu e ka'a hiiwalaimoli ike. ?Uri nou sai sikaa mola hunie ne ke to'o aana nga iini e hiiwalaimoli?  
\pi3 \bd 1 Korinit\bd* 7:12-16.  
\pi2 Saeku ne ke tola hu'e, ta'e iini nou saeto'o aana e ka'a hiiwalaimoli ike aana Jisas. ?Uri e diana mola hunie ne ke ha'aruru pe'ie?  
\pi3 \bd 2 Korinit\bd* 6:14-15.  
\pi2 ?Mo mwela nge kire hiiwalaimoli aana Jisas tolahada e uri taa?  
\pi3 \bd Matiu\bd* 15:3-6; \bd Luk\bd* 2:51; \bd Epesas\bd* 6:1-3; \bd Kolose\bd* 3:20; \bd 1 Timoti\bd* 5:4, 5:8; \bd Hibru\bd* 12:7-11.  
\pi2 ?Tolahaku kei uri taa hunie mo mwela ineu?  
\pi3 \bd Epesas\bd* 6:1-4; \bd Kolose\bd* 3:20-21; \bd 1 Timoti\bd* 3:4-5.  
\pi2 ?Tolahaku kei uri taa hunie aamaku na nikeku?  
\pi3 \bd Matiu\bd* 15:3-6; \bd Epesas\bd* 6:1-3; \bd Kolose\bd* 3:20; \bd 1 Timoti\bd* 5:4-8.  
\pi2 ?Tolahaku kei uri taa hunie mo nao na mo rei'inge?  
\pi3 \bd Palonga\bd* 6:1; \bd Rom\bd* 7:2-3; \bd 1 Korinit\bd* 7:39-40; \bd 1 Timoti\bd* 5:3-16; \bd Jemes\bd* 1:27. s ?Uri a God ko kineta'inie mo iini kire hiiwalaimoli mwaanie kire lae oodoie lo'u aasanga?  
\pi3 \bd Rom\bd* 8:18-25, 8:28; \bd 2 Korinit\bd* 1:4, 4:16-18; \bd Jemes\bd* 1:2-4; \bd 1 Pita\bd* 1:6-9, 2:19-21, 5:8-10. s ?Nga taa ni ne kei esuie aana maholo malaahongalaku ko lae huni esuie nga mei ola aaela?  
\pi3 \bd Matiu\bd* 4:1-11, 6:13, 26:41; \bd Luk\bd* 22:31-32; \bd Jon\bd* 17:14-19; \bd Rom\bd* 8:31-39, 12:12, 16:19-20; \bd 1 Korinit\bd* 10:12-13, 16:13; \bd 2 Korinit\bd* 12:7-10; \bd Epesas\bd* 3:20-21, 6:10-18; \bd Pilipae\bd* 4:13; \bd 1 Tesalonaeka\bd* 3:5-8; \bd 2 Tesalonaeka\bd* 3:3; \bd 2 Timoti\bd* 1:7-8; \bd Hibru\bd* 2:18, 4:14-16, 12:1-2; \bd Jemes\bd* 1:12-15, 4:7; \bd 1 Pita\bd* 1:5, 5:8-11; \bd 1 Jon\bd* 4:4, 5:3-5; \bd Haata'inge\bd* 12:7-12. s ?Nga taa ni ne kei esuie maholo a Satan ko sare waelieu?  
\pi3 \bd Matiu\bd* 4:1-11, 6:13, 13:19; \bd Luk\bd* 4:1-13, 22:3-4, 22:31-32; \bd Jon\bd* 8:42-44, 17:14-19; \bd Rom\bd* 16:19-20; \bd 1 Korinit\bd* 16:13; \bd 2 Korinit\bd* 2:10-11, 4:4, 11:13-15, 12:7-10; \bd Epesas\bd* 2:2, 3:20-21, 6:10-18; \bd 1 Tesalonaeka\bd* 3:5-8; \bd 2 Tesalonaeka\bd* 3:3; \bd Jemes\bd* 4:7-8; \bd 1 Pita\bd* 5:8-11; \bd 1 Jon\bd* 4:4; \bd Haata'inge\bd* 12:7-12, 20:1-3, 20:10. s ?Nga taa ni ne kei esuie aana nou teke oto i laona malaahonga na no ko ooraha'aa oto?  
\pi3 \bd Luk\bd* 15:11-24; \bd Rom\bd* 6:1-23; \bd Hibru\bd* 12:1-2; \bd Jemes\bd* 4:7-10; \bd 1 Jon\bd* 1:9—2:2; \bd Haata'inge\bd* 3:19-20. s No ko deu aahonga taane hunie ne ke ne'i iinoni diana, ta'e e aasaieu mola. ?Uri a God kei pe'ieu taane?  
\pi3 \bd Matiu\bd* 18:19-20, 28:19-20; \bd Jon\bd* 14:16-23; \bd Rom\bd* 8:35-39; \bd 2 Korinit\bd* 6:16-18; \bd Epesas\bd* 3:17-19; \bd Pilipae\bd* 4:13; \bd Kolose\bd* 2:6-7; \bd 2 Tesalonaeka\bd* 3:16; \bd Hibru\bd* 13:5-6. s ?Nga taa ni ne kei esuie maholo ineu wa mo iinoni aana uluhe ineu kire ko mata'i?  
\pi3 \bd Matiu\bd* 4:23-25, 9:35, 11:2-5; \bd Palonga\bd* 3:1-6, 8:4-8, 19:11-16, 28:8-9; \bd 1 Korinit\bd* 12:9, 12:29-30; \bd 2 Korinit\bd* 12:7-10; \bd 1 Timoti\bd* 5:23; \bd 2 Timoti\bd* 4:20; \bd Jemes\bd* 5:14-15. s ?Nga taa ni ne kei esuie maholo no ko lae oodoie aasanga?  
\pi3 \bd Rom\bd* 8:18-37, 12:12; \bd 2 Korinit\bd* 1:3-5, 4:16-18; \bd Jemes\bd* 1:2-4; \bd 1 Pita\bd* 1:3-9, 2:19-23, 5:8-10. s ?Nga taa ni ne kei esuie maholo ha'aloileku ko lae wa mwala ko ha'amwasi mola aaku aana no ko lulu i sulie a Jisas?  
\pi3 \bd Matiu\bd* 5:10-12; \bd Mak\bd* 13:9-13; \bd Luk\bd* 12:4-9; \bd Jon\bd* 15:18-21, 16:1-4; \bd Palonga\bd* 5:41; \bd Rom\bd* 8:35-37, 12:12-21; \bd 1 Korinit\bd* 4:11-13; \bd 2 Korinit\bd* 4:8-11, 12:10; \bd Pilipae\bd* 1:28-29; \bd 2 Tesalonaeka\bd* 1:4-8, 3:2-4; \bd 2 Timoti\bd* 3:10-13; \bd Hibru\bd* 10:32-39, 12:3-4; \bd 1 Pita\bd* 3:13-17, 4:12-19; \bd Haata'inge\bd* 2:10. s ?Uri e diana hunie mo iini e hiiwalaimoli aana Jisas ke ma'ute'inie maenga?  
\pi3 \bd Jon\bd* 6:39-40, 11:17-27, 14:1-4; \bd Rom\bd* 8:10-11, 8:38-39, 14:7-9; \bd 1 Korinit\bd* 15:12-58; \bd 2 Korinit\bd* 5:1-10; \bd Pilipae\bd* 1:20-24; \bd 1 Tesalonaeka\bd* 4:13-18; \bd Hibru\bd* 2:14-15; \bd Haata'inge\bd* 14:13, 21:1-4, 22:1-5. s ?Nga taa ni kei reu mei puri?  
\pi2 A Jisas kei ooli lo'u mei welumalau.  
\pi3 \bd Matiu\bd* 24:29-44; \bd Jon\bd* 14:1-3; \bd Palonga\bd* 1:10-11, 3:19-21; \bd Pilipae\bd* 3:20-21; \bd Kolose\bd* 3:4; \bd 1 Tesalonaeka\bd* 1:9-10, 3:13, 4:13—5:11; \bd 2 Tesalonaeka\bd* 1:6-10, 2:1-4; \bd 1 Timoti\bd* 6:13-15; \bd 2 Timoti\bd* 4:8; \bd Hibru\bd* 9:28; \bd 2 Pita\bd* 3:1-18; \bd 1 Jon\bd* 3:1-3; \bd Haata'inge\bd* 1:7, 22:12-13.  
\pi2 Jisas Kraes kei leie ahutana iinoni aana a God e niie nanamanga hunie.  
\pi3 \bd Matiu\bd* 7:21-23, 16:24-27, 25:31-46; \bd Jon\bd* 3:18-21, 5:24-29; \bd Palonga\bd* 17:30-31; \bd Rom\bd* 2:1-11, 14:10-12; \bd 1 Korinit\bd* 3:10-15, 4:5; \bd 2 Korinit\bd* 5:9-10; \bd 2 Tesalonaeka\bd* 1:5-10; \bd Hibru\bd* 9:27-28, 10:26-31; \bd 1 Pita\bd* 1:17, 4:3-5; \bd Haata'inge\bd* 20:11-15.  
\pi2 Mo iini nge ha'a-uurilada e lae kire kei ii'o i Lengi oto huu.  
\pi3 \bd Luk\bd* 12:32-34; \bd Jon\bd* 14:1-3; \bd 2 Korinit\bd* 5:1-8; \bd Pilipae\bd* 1:23; \bd 1 Pita\bd* 1:4-5; \bd Haata'inge\bd* 4.1-11, 21:1-4, 21:22—22:5, 22:14-15.  
\pi2 Mo iini nge ha'a-uurilada e ka'a lae kire kei sapesalu i laona dunge ni ha'amotaahinge oto huu.  
\pi3 \bd Matiu\bd* 10:28, 13:41-42, 47-50, 25:41; \bd Luk\bd* 16:23-26; \bd 2 Tesalonaeka\bd* 1:9; \bd Haata'inge\bd* 20:10-15, 21:8.  