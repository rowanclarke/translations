\v 14 \wj \+w De|strong="H4480"\+w* \+w esta|strong="H1961"\+w* \+w ofrenda|strong="H7133"\+w* \+w se|strong="H1961"\+w* \+w presentará|strong="H7126"\+w* una parte \+w de|strong="H4480"\+w* \+w cada|strong="H3605"\+w* sacrificio \+w como|strong="H1961"\+w* \+w ofrenda|strong="H7133"\+w* alzada \+w a|strong="H3068"\+w* \+nd \+w Yavé|strong="H3068"\+w*\+nd*, y \+w será|strong="H1961"\+w* \+w del|strong="H4480"\+w* \+w sacerdote|strong="H3548"\+w* \+w que|strong="H4480"\+w* roció \+w la|strong="H3605"\+w* \+w sangre|strong="H1818"\+w* \+w del|strong="H4480"\+w* sacrificio \+w de|strong="H4480"\+w* paz.\wj*  
