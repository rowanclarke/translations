\id 3JN Mazatec of Jalapa de Díaz
\h Xu̱ju̱n xi ma jahan xi kits'ínntu nda̱ postru̱ Jua
\toc1 Xu̱ju̱n xi ma jahan xi kits'ínntu nda̱ postru̱ Jua
\toc2 Xu̱ju̱n xi ma jahan xi kits'ínntu nda̱ postru̱ Jua
\toc3 3 Jn.
\mt1 Xu̱ju̱n xi ma jahan xi kits'ínntu nda̱ postru̱ Jua
\c 1
\s1 B'i̱ ts'ín kikjaniñaha̱ Jua Gayo̱
\p 
\v 1 An xi nda̱cháha̱ xu̱ta̱ ni̱nku̱ títs'inkjíhi xu̱ju̱i̱n nda̱ xinkjíán Gayo̱. Tjo kju̱axi̱na ji.
\p 
\v 2 Ji nda̱ nts'ena̱, bankihi̱ Nti̱a̱ná nga xi nkú ts'ín nda tísájin ni xi ts'e̱, b'a̱ ta̱ ts'ín nda kasakú ni̱yáhi ngayjee̱ ni xi n'e̱i̱ ko̱ nga nda ni̱stjin xi tsjáhi nga ku̱i̱nchin.
\v 3 A̱t'aha̱ tsjo ṉkjún kamana nk'ie nga j'aisena k'u̱a̱ já nts'eé nga kitsúyana ni xi kikie, nga tu̱ nkú tje̱nnkiní Nti̱a̱ná ko̱ nga xi nkú ts'ín tisinjñajin ni xi yaha̱ ra̱ ni xi na̱xu̱ tjín.
\v 4 Nga nt'e nga ntína̱ tíi̱nchajin ni xi na̱xu̱ tjín, kui nihi xi 'yún tsjána kju̱a̱tsjo.
\s1 B'i̱ ts'ín kitsúya Jua xi nkú ts'ín Gayo̱ tsasinko̱ xu̱ta̱ ni̱nku̱ xi j'aik'úhu̱n
\p 
\v 5 Ji nda̱ts'ena̱, tín'ei ni xi b'a̱ tjín nk'ie nga tíbisinko̱i̱ já nts'eé ko̱ 'yún ṉkjún sa nda tín'ei nga tíbisinko̱i̱ xi nibáha xin nanki.
\v 6 Nginku̱n xu̱ta̱ ni̱nku̱ kitsúya já nts'eé xu'bi̱ xi nkú ts'ín tjohi. Ko̱ nda n'e̱i̱ tsa ku̱i̱si̱nko̱i̱ nga ts'i̱ínndju̱ú ngáha ni̱yáha̱, a̱t'aha̱ b'a̱ ts'ín tjíhin nga ku̱i̱si̱nka̱á xu̱ta̱ xi ts'ínxát'aha̱ Nti̱a̱ná.
\p 
\v 7 A̱t'aha̱ tjoho̱ Jesucristo̱, kui nga i̱ncha tsitjuhu nankihi̱. Najmi i̱ncha kits'ínkjáíhi̱n ni xi ts'e̱ xu̱ta̱ a̱sunntee̱.
\v 8 Kui b'a̱ maha, tjíhin nga k'u̱a̱i̱ntehe̱ ra̱á ni'yaná já nts'eé xi nkúhu xu'bi̱, tu̱ xi ku̱i̱si̱nko̱honá nga k'u̱éni̱jmí ni xi na̱xu̱ tjín.
\s1 B'i̱ ts'ín kitsúya Jua xi nkú ch'on kits'ín Diotre̱fe̱
\p 
\v 9 Kits'inkjíhi̱ nku xu̱ju̱n xu̱ta̱ ni̱nku̱, tu̱nga máha Diotre̱fe̱, tsjoho̱ nga tu̱ nku kuihí ku̱a̱téxumaha̱ xu̱ta̱ ni̱nku̱. Najmi títs'ínkjáíhi̱n xá xi tjínni̱.
\v 10 Kui kju̱a̱ha, tsa kfíhinna yo̱, ts'innisihi̱ ra̱ ni xi títs'ín. A̱t'aha̱ én tsank'á tíkjesíntje̱nneni̱ ko̱ ch'on ts'ín tínchja̱yaneni̱. Ko̱ najmi tu̱ nku ni xu'bi̱ xi títs'ín. Ta̱ najmi ts'ínkjáíhi̱n já nts'eé xi bichúk'uhu̱n. B'échjaha̱ xi mjehe̱ ts'i̱ínkjáíhi̱n já nts'eé ko̱ m'osje a̱jihi̱n xu̱ta̱ ni̱nku̱.
\p 
\v 11 Ji nda̱ nts'ena̱, najmi tu̱ n'ei ni xi ts'ín já ch'onk'uu̱n. Ni xi ts'ín ní já xi nda ts'ín, kui xi n'e̱i. Xi nda títs'ín, kui xi Nti̱a̱ná ts'e̱he̱. Tu̱nga xi ch'on títs'ín, kui xi najmi kje̱e be Nti̱a̱ná.
\s1 B'i̱ ts'ín kitsúya Jua nga nda títs'ín Demetri̱o̱
\p 
\v 12 Ngayjee̱ xu̱ta̱ tsuya nga nda títs'ín Demetri̱o̱, ko̱ kju̱axi̱ kjáíhin ni xi i̱ncha tsu. Ko̱ ji̱n ta̱ nda chubani̱jmíyaha̱ni̱ nkú nda ts'ín ndo̱. Ji yai nga kju̱axi̱ ni xi chubai̱.
\s1 B'i̱ ts'ín kits'ínkje Jua xu̱ju̱i̱n
\p 
\v 13 Tjín ṉkjún sana ni xi xíhin, tu̱nga najmi mjehéna xu̱ju̱n k'uet'áha,
\v 14 a̱t'aha̱ mjena kfínse xatíhi ko̱ kuinchjani̱jmíko̱ho.
\p 
\v 15 Kas'ehi kju̱a̱jyu. Xi tjoho̱ ji xi tjín e̱i̱ tíi̱ncha ts'ínkjihi kju̱a̱suniña, ko̱ ta̱ tje̱hi̱n i̱chí kju̱a̱suniñani̱ nga nkúnkú xi tjoni̱ xi tjín yo̱.
