\c 4
\m
\v 1 PERO \w Jonás|strong="H3124"\w* se apesadumbró en extremo, y \w enojóse|strong="H2734"\w*.   
\m
\v 2 \w Y|strong="H3068"\w* \w oró|strong="H6419"\w* \w al|strong="H5921"\w* \w SEÑOR|strong="H3068"\w*, \w y|strong="H3588"\w* dijo: Ahora, oh \w SEÑOR|strong="H3068"\w*, ¿\w no|strong="H3808"\w* \w es|strong="H1961"\w* \w esto|strong="H2088"\w* \w lo|strong="H1697"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* decía \w estando|strong="H1961"\w* \w aún|strong="H5704"\w* \w en|strong="H5921"\w* \w mi|strong="H5921"\w* tierra? \w Por|strong="H5921"\w* \w eso|strong="H3651"\w* \w me|strong="H5921"\w* precaví \w huyendo|strong="H1272"\w* \w a|strong="H3068"\w* \w Tarsis|strong="H8659"\w*: \w porque|strong="H3588"\w* \w sabía|strong="H3045"\w* \w yo|strong="H3588"\w* \w que|strong="H3588"\w* tú \w eres|strong="H1961"\w* \w Dios|strong="H3068"\w* \w clemente|strong="H2587"\w* \w y|strong="H3588"\w* piadoso, tardo \w a|strong="H3068"\w* enojarte, \w y|strong="H3588"\w* \w de|strong="H5921"\w* \w grande|strong="H7227"\w* \w misericordia|strong="H2617"\w*, \w y|strong="H3588"\w* \w que|strong="H3588"\w* \w te|strong="H5921"\w* arrepientes \w del|strong="H5921"\w* \w mal|strong="H7451"\w*.   
\m
\v 3 \w Ahora|strong="H6258"\w* \w pues|strong="H3588"\w*, oh \w SEÑOR|strong="H3068"\w*, rué­gote \w que|strong="H3588"\w* \w me|strong="H4480"\w* mates; \w porque|strong="H3588"\w* \w mejor|strong="H2896"\w* \w me|strong="H4480"\w* \w es|strong="H3588"\w* \w la|strong="H3588"\w* \w muerte|strong="H4194"\w* \w que|strong="H3588"\w* \w la|strong="H3588"\w* \w vida|strong="H5315"\w*.   
\m
\v 4 \w Y|strong="H3068"\w* el \w SEÑOR|strong="H3068"\w* le dijo: ¿Haces tú \w bien|strong="H3190"\w* en enojarte tanto?   
\m
\v 5 \w Y|strong="H3068"\w* \w salióse|strong="H3318"\w* \w Jonás|strong="H3124"\w* \w de|strong="H4480"\w* la \w ciudad|strong="H5892"\w*, \w y|strong="H5704"\w* asentó \w hacia|strong="H6213"\w* \w el|strong="H6213"\w* \w oriente|strong="H6924"\w* \w de|strong="H4480"\w* la ciu­dad, \w e|strong="H3068"\w* hízose \w allí|strong="H8033"\w* una choza, \w y|strong="H5704"\w* \w se|strong="H1961"\w* sentó \w debajo|strong="H8478"\w* \w de|strong="H4480"\w* \w ella|strong="H8033"\w* \w a|strong="H3068"\w* la \w sombra|strong="H6738"\w*, \w hasta|strong="H5704"\w* \w ver|strong="H7200"\w* \w qué|strong="H4100"\w* \w sería|strong="H1961"\w* \w de|strong="H4480"\w* la \w ciudad|strong="H5892"\w*.   
