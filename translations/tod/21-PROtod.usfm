\id PRO - Toma Bible
\h Tɛnɛ Faalaaliiti
\toc1 Tɛnɛ Faalaaliiti
\toc2 Tɛnɛ Faalaaliiti
\toc3 TFa
\mt1 Tɛnɛ Faalaaliiti
\imt1 Sɛʋɛi lɔɔzeizuʋɛ ma woo mɔungiti
\ip Tɛnɛ Faalaali zɛʋɛi ɠa ga sɛʋɛi nii ɠima ɓɔɛiti ti su. Nu mɔinmɔin ka kpɔgai su, ti Tɛnɛ Faalaali zɛʋɛi ɓɛtɛ, kɛlɛ masagi Davide ná-doun zunui, masagi Salomɔn ɠa é bɔɔlɔzu zɛʋɛai. Ɛsɛ pɛ ge ɠɛni Salomɔn ɠwɛɛ ná-ɠimalai vaa zu, ta Masagiti Ta-Zɛʋɛ Mɔungi ɠɛ tɛnɛ faalaali waasaʋagɔ (3.000) ɠa é sɛʋɛai (\xt 1Ma 5:12\xt*). Naazu Tɛnɛ Faalaali zɛʋɛi bɔɔlɔzu zɛʋɛʋɛ Salomɔn ná-yeeɠɛɠalai zu, kona untaaʋuugɔ puulɔfelaiti zɔɠɔzuʋɛ ta untaaʋuugɔ puusaʋagɔ maazu ɠilagi (970-931), aisa Yesu Kilista ʋa zɔlɔɔ. Ma zɛʋɛi mɔtai ɠa ɠɛ zɛʋɛni ɓaa gaalɛba, siɛgi zu Ezekiase ɠɛni la ga Zuda masagi, kona undɔfela puugɔ maazu lɔɔlugɔiti zɔɠɔzuʋɛ ta kona undɔzita puulɔsaʋa maazu lɔzitai (715-686), aisa Yesu Kilista ʋa zɔlɔɔ (\xt 25:1\xt*).
\ip Tɛnɛ Faalaaliiti ta ga ɠima ɓɔɛiti bɔɔlɔzu ga gaamai, kɛlɛ zeeɠaaɠwɛɛzu ɠa ti ʋa ta minazeɠegiti ɓaa faawokɛɛyeeluɠɔ ɓɔɛiti. Eɠɛʋelei \xt 22:6\xt* bosu la ga doungoi nii ti kalagai ga pelei maanɛai é ziɛ la, anɛɛ siɛgi zu é wɔlɔzaɠasu da, é la zeɠea ba. Kɛlɛ naama lɛnɛ faalaali la ga minazeɠe ga doungoi nii ti kalagai ga pelei maanɛai é ziɛ la, faa ɲɔu nɔpɛ ge la mɔ zeelia ma nu ma ná-eteai zu. Kɛlɛ tɔun, toɠa ga tɛnɛgi é lo naa ʋa, nii é ga gaama yeeɠɛɠala mɔinmɔin su. Tɛnɛ Faalaali zɛʋɛi ɓɔɠɔgoi ɠa faalaalii naati ma ungi lɛɛzu gaaɠwɛsu mɔungi zu (\xt 1:2-6\xt*). Ma ungi ɠa ga é ɠɛ ga kpɔbai buzeɠe niinɛgiti bɛ, ta niiti ti la faaɠwɛ sɛ ti ɠimalai ta tɛnɛ pagɔi zɔlɔɔ, ta é ta ɓɔ vɔlɔ ɠima nuiti ta-ɠimalai ʋa.
\iot Unsosuʋɛ
\io1 1. Salomɔn ná-tɛnɛ faalaaliiti (\xt 1:1—22:16\xt*).
\io1 2. Ɠima nuiti ta-ɠima ɓɔɛ zɛʋɛ felegɔiti (\xt 22:17—24:34).\xt*
\io1 3. Salomɔn ná-tɛnɛ faalaali zɛʋɛi taɠili, nii masagi Ezekiase ná-botiɠɛ nuiti ti gaalɛɛni ba (\xt 25:1—29:27).\xt*
\io1 4. Aguul ɓɔɛ wooiti (\xt 30:1-33\xt*).
\io1 5. Lemuwɛle ɓɔɛ wooiti (\xt 31:1-9\xt*).
\io1 6. Anzanu zɔɓelamai ziɛ ʋelei (\xt 31:10-31\xt*).
\c 1
\ms1 Sɛʋɛi lɔɔzeigi ta sɛʋɛ ungi
\p 
\v 1 Salomɔn é ɠɛni ga Davide ná-doun zunui, ta Izilayɛle masagi, naa ná-tɛnɛ faalaaliiti:\f + \fr 1:1 \ft Faalaali laaseigi, ta Salomɔn laaseigi ma vaa zu, wɛlɛ sɛʋɛi lɔɔzeizuʋɛ.\f*
\b
\q1 
\v 2 Ti ɠɛ ungi ɠa ga ti nu ɠala ga ɠimalai, ti nu ɠɛʋele ɓɛtɛ,
\q1 é kpɔɛiti gaaɠa, niiti ti woni ga keleɠelegi.
\q1 
\v 3 Ti nui ɠala ga siɛ ʋelei ná-eteai zu, keleɠelegi ʋɔ,
\q1 é lelebo, é zɔle, é zoloo su.
\q1 
\v 4 Ti ɠi pagɔi ve naati zea, niiti ti la dɛ faa mɔinmɔin kwɛni,
\q1 ti faaɠwɛgi ta kidafaawui ve zunu loungoiti zea.
\q1 
\v 5 Ɠima nui woilo, toɠa ta ɓɔ ná-soofaalai ʋa,
\q1 zɔi keleɠelegai, naa ɠa ziɛ ʋele ʋagɔi zɔlɔɔ.
\q1 
\v 6 Ta zoo ti tɛnɛ faalaalii ma lɔɔɠuzu vai tanigaani kwɛɛ,
\q1 ta ɠima nuiti daawooiti ma lɔɔɠuzu vaiti poluʋɛti.
\b
\q1 
\v 7 Ɠɔoɠɔ GALAGI ɠaazuluabai ɠa é ga faaɠwɛgi lɔɔzeizuʋɛ,
\q1 faaɠaaɠalala nui ɠa ɗa ɠimalai ʋɛlɛʋɛlɛ ta kalagi.
\s1 Dama ga zunu loungo ɲɔiti
\q1 
\v 8 Dòun zunu, woilo, è dama ga faaɠwɛgi, è sɔlɔɔsu è-ɠɛɛ ya,
\q1 mina è-lee ná-tɛnɛ gooiti da ɠoba.
\q1 
\v 9 Mazɔlɔɔ ta ɠɛ ga masa bɔɔlɔ pagɔi è unba,
\q1 ta ɠɛ ga kɔbu ani ʋagɔi è ɠɔbu.
\b
\q1 
\v 10 Dòun zunu, ni faa ɲɔu ɠɛ nuiti ta pɔ, ti è ɠaazulɛ,
\q1 mina yeezei bu.
\q1 
\v 11 Ta ɠɛna ma: «Ʋilɛ gi ʋolu!
\q1 Ade li de nuiti teʋesuʋɛ maaɓɔun, de ta ʋaa,
\q1 de laalɛ nui ta wu lein nɔ, anɛɛ ni é la faa ɠaazani.
\q1 
\v 12 De ti-ma vului ɓɔle, eɠɛʋelei gɔvɛalaazu a ɗa kɛ la,
\q1 ti ɲɛɛlɛ ɲɛgɛlɛin ga naati kɛʋele, niiti ti yeizu kabai zu.
\q1 
\v 13 Ade ti-ɠɔli pagɔiti seɠe,
\q1 de da-ʋɛlɛiti buulaave da.
\q1 
\v 14 Ɗa ɗɔnɔ zɔlɔɔsu gi ʋɔ,
\q1 ada ɓɔsu wali ɓɔlɔ ɠilagi ma ade pɛ!»
\q1 
\v 15 Dòun zunu, mina ʋilɛ ti ʋolu, è ʋa ziɛ ga ta-ʋelei,
\q1 maaɠooza ta-ʋelei ʋa.
\q1 
\v 16 Mazɔlɔɔ ti-ɠɔɠɔiti suvilɛʋɛ faa ɲɔu ɠɛɛ vai zu,
\q1 ti zuvilɛʋɛ ɲamai ʋuu zu.
\q1 
\v 17 Mazɔlɔɔ toɠa ga fuun faa,
\q1 wɔnii ɗa tumɔi ɠa, é ɗa zei tuɠɔ.
\q1 
\v 18 Kɛlɛ tiya ɓɔɠɔi ɠa ti yaavai zeizu ɓɔɠɔ luɠɔ,
\q1 tiya ɓɔɠɔi ti-yɛnvui ɠa ti balii laazu tuɠɔ.
\q1 
\v 19 Zekana naati gaaɓelazuʋɛ la,
\q1 niiti ti ta-ɓɛtɛi wosu ga kakama vaiti su,
\q1 tɔnɔ ɲɔi ɠa ɗa sɔlɔɔ nui undaaʋili.
\s1 Ɠimalai ɠa toligi wosu ta tɛnɛgi
\q1 
\v 20 Ɠimalai ɠa kpeei loozu taazuʋɛ peleiti su,
\q1 toɠa wooɠulazu maaɓɔ bosuʋɛti.
\q1 
\v 21 É toligi wo maaɓɔ bosuʋɛ,
\q1 é ná-keela wooi wo taa loaʋɛ, é ɠɛ ma:
\q1 
\v 22 «Ɠimalala nuiti, wa ɠimalala vaiti nɛɛzu ʋɛ, eyɛsu yeelɛ?
\q1 Ɲɛɛɠulasu nuiti, wo-yiimai ɠa ɠɛɛzu ga ɲɛɛɠulasui, eyɛsu yeelɛ?
\q1 Faaɠaaɠalala nuiti, wa yɛsu faaɠwɛgi wɔinzeɠezu, eyɛsu yeelɛ?
\q1 
\v 23 À woilo nà-tɛnɛ gooiti ma!
\q1 Wɛlɛ nà nà-keleɠelegi ve wo ya,
\q1 nà dàawooiti dɛɛ ga woye.
\q1 
\v 24 Tɔɔzei gè wo lolini, wo ɠɛlɛ,
\q1 tɔɔzei gè yeeleteni, nu nɔpɛ ge la ma wɛlɛ woni,
\q1 
\v 25 wo nà-tɛnɛ gooiti kpein pilini ya,
\q1 wo la vaani nà-zelilomaiti bu,
\q1 
\v 26 naa ɠa é ba, nà ɓalaagi, nà wo ɲɛɛ, siɛgi zu maanɔɠɔi ʋaazu wo ʋɔ,
\q1 nà ɲɛɛɠula wo zu, siɛgi zu kidaaʋiligi zeelizu la wo ma,
\q1 
\v 27 siɛgi zu kidaaʋiligi ʋaazu la wo ʋɔ, eɠɛ fiilɛ wolai,
\q1 siɛgi zu maanɔɠɔi zeelizu la wo ma, eɠɛ tɔngɔlɔ fiilɛi,
\q1 siɛgi zu koozuʋiligi ta kidaaʋiligi ʋaazu la wo ʋɔ.
\q1 
\v 28 Naazu, ta wooɠula mà, gè la ti wooɠaaʋotega,
\q1 ta gàiziɛ, ti la kàa.
\q1 
\v 29 Toɠa ɠɛ ɠana, tɔɔzei ti faaɠwɛgi wɔinzeɠeʋɛ,
\q1 ti la yiimazeɠeni ga Ɠɔoɠɔ GALAGI ɠaazuluabai,
\q1 
\v 30 tɔɔzei ti la vaani nà-tɛnɛ gooiti bu,
\q1 ti laaɓɛɛluni ga nà-zelilomaiti,
\q1 
\v 31 ti-ziɛ ʋelei ma lɔnɔgi ɠa a ɠɛ ga ti-ɠɔnɔgi,
\q1 ti ɓɔɠɔ lɛnɛ gooiti ta ɠɛ ga ti-laamianigi, eyɛsu mɔtai yɛ.
\q1 
\v 32 Mazɔlɔɔ ɠimalala nui ná-kakagi ɠa ɗa paa,
\q1 faaɠaaɠalala nui ná-ziizoolɛlalai ga ɓɔɠɔ, naa ɠa a ɗa too ya.
\q1 
\v 33 Kɛlɛ zɔi a woilo gòoi ma, naa ɠa zei gaanɛɛi zu,
\q1 é ná-eteai ziɛ ziilɛigi zu, é la luaa maanɔɠɔi ʋa.»
\c 2
\s1 Ɠimalai ɠa ga ani ɓiigi dɔɔɠuai
\q1 
\v 1 Dòun zunu, ni ɗa dàawooiti sona,
\q1 ni ɗa nà-deveiti makɛna è-yiimaʋɛ,
\q1 
\v 2 ni ɗa woilona ɠimalai ma,
\q1 è è-yii ve keleɠelegi ya,
\q1 
\v 3 ungo, ni ɗa wooɠulana faaɠaaɠai ma,
\q1 ni ɗa keleɠelegi ɠaiziɛna,
\q1 
\v 4 ni ɗa gaiziɛna ga walii ɠɛʋele,
\q1 ni ɗa daana ma kpɛ, è gaiziɛ ga naavolo ɠɛʋele,
\q1 
\v 5 názu ɠa è Ɠɔoɠɔ GALAGI ɠaazuluabai ɠwɛɛsu da,
\q1 ɗa zoo è GALA kwɛɛ.
\q1 
\v 6 Mazɔlɔɔ Ɠɔoɠɔ GALAGI ɠa a ɗa ɠimalai ve,
\q1 daawooi ɠa a ɗa faaɠwɛgi ta keleɠelegi ve.
\q1 
\v 7 Toɠa undaanɛ vai makɛsu sɔle nuiti bɛ.
\q1 Eɠɛ kɔɔɠɔ zɛpɛgi, toɠa naati makɛ, niiti ti ziɛzu telebodai zu.
\q1 
\v 8 Niiti ti ta-eteai ziɛzu ga sɔledai, toɠa ɓɔ naati ba.
\q1 Niiti ti bɛ ga wooɠɛɠila nuiti, toɠa ɓaa naati ta-ʋelei maazu.
\q1 
\v 9 Ɗa zoo è faiti zɔɠɔzuɠa, telebodai, ta nii soloogai tɔgi ma, ta sɔle fai,
\q1 è pele ʋagɔiti kpein kwɛɛ.
\q1 
\v 10 Mazɔlɔɔ ɠimalai ɠa ʋa é zei è-yiimaʋɛ,
\q1 faaɠwɛgi ɠa ɠɛ ga è yiima vaiti.
\q1 
\v 11 Kidafaawui ɠa è makɛ,
\q1 keleɠelegi ɠa ɓaa è maazu,
\q1 
\v 12 ga ti è unmɔɔ, ti è ɠula pele ɲɔiti su,
\q1 ta nu ɲɔiti ta-yaava ɓɔɛiti,
\q1 
\v 13 niiti ti ɠɛlɛzu gaama ʋelei ʋa,
\q1 ti ɗa ziɛ ga pelei suɓidiai.
\q1 
\v 14 Ti-yiimai ga faa ɲɔu ɠɛɛ vai,
\q1 ti ɠoozunɛɛzu ga ti lɔ woya vai zu.
\q1 
\v 15 Ti-ziɛ ʋeleiti maaʋegai,
\q1 ta-ʋeleiti suzeiʋɛ.
\q1 
\v 16 Naazu, ɗa ɠizo wɛɛnziɛ anzanui ná-tɛgai ma,
\q1 é ga koloɠolo anzanui woo nɛɛnɛgiti ti da,
\q1 
\v 17 nii kɛlɛai sinigi ʋa, é ɠɛni zea ma niinɛ yeei,
\q1 é yeema ná-vulu minazeɠegi ma, nii é boni ná-GALAGI laaseigi zu.
\q1 
\v 18 Mazɔlɔɔ maalaaʋɛ na saai ʋɔ pelei, ʋɛ ná ga seizuʋɛ,\f + \fr 2:18 \fq Mazɔlɔɔ maalaaʋɛ na saai ʋɔ pelei, ʋɛ ná ga seizuʋɛ\ft : Tati pelei taɠili ɓalaa ka ga nii: \fqa ná-pɛlɛi maalaaʋɛ na ga saai ʋɔ pelei\f*
\q1 siɛ ʋelei ɠa liizu la gɔvɛalaazu.
\q1 
\v 19 Niiti kpein ti liizu pɔ bɛ, taɠila kpalaa ge la ɠalega ma ʋolu, é ʋa ʋa,
\q1 taɠila kpalaa ge la zɛnvu ʋelei ɠaa.
\q1 
\v 20 Yiimazeɠe ga nu ʋagɔiti siɛ ʋelei,
\q1 ziɛ ga telebo nuiti siɛ ʋelei.
\q1 
\v 21 Mazɔlɔɔ sɔle nuiti ta zei zooi zu,
\q1 gaama nuiti ta yɛ zeini ná.
\q1 
\v 22 Kɛlɛ nu ɲɔiti tɔɔ ɠa ɠula ná,
\q1 woovele nuiti ta ɠula ná ʋa.
\c 3
\s1 Nu ɠito GALA ba
\q1 
\v 1 Dòun zunu, mina yeema nà-kala gooiti ma,
\q1 makɛ nà-deveiti ma è-yiimaʋɛ.
\q1 
\v 2 Mazɔlɔɔ ta ta ʋili ɗa-voloi liegɔiti su, ta è-zii ma ɠonagiti,
\q1 ti undaanɛɛi ve è ʋɛ.
\b
\q1 
\v 3 Mina ʋala wooɠɛɠiladai ma, ta gaamai,
\q1 ti ɠili ɠɔbu, è ti zɛʋɛ è-yiimaʋɛ.
\q1 
\v 4 Naazu, ɗa zaalai zɔlɔɔ GALA ta nuɓusɛiti zea,
\q1 è lɔɠɔ ʋagɔi zɔlɔɔ, è leve ga ɠima nui.
\b
\q1 
\v 5 Ɠaliva Ɠɔoɠɔ GALAGI ma ga è-yiimaʋɛ pɛ,
\q1 mina ʋoluzei è ɓɔɠɔ ɠeleɠelegi ʋa.
\q1 
\v 6 Ziimai ɠaiziɛ è-ɠɛɛ vaiti kpein su,
\q1 toɠa è-ziɛ ʋele ʋagɔiti dɛɛ ga ɗe.
\b
\q1 
\v 7 Mina ɓɔɠɔ zeɠe ga ɠima nu,
\q1 lua Ɠɔoɠɔ GALAGI ʋa, è maaɠooza faa ɲɔi ʋa.
\q1 
\v 8 Toɠa ɠɛ ga kɛdɛyai è-ɓusɛi ʋɛ,
\q1 ta è-ɠaeiti niinɛ vai.
\b
\q1 
\v 9 Ɠɔoɠɔ GALAGI lɛbi ga è-zɔlɔɔ gani ʋagɔiti,
\q1 ta è-zɔlɔɔ ganii ma mɔungiti kpein.
\q1 
\v 10 Naazu, ɗa-molo ɠotaiti daa ɠa ve gola,
\q1 ɗa-lɔɔ liɠiiti daa ɠa ve ga dɔɔ niinɛiti.
\b
\q1 
\v 11 Dòun zunu, mina ɠɛlɛ Ɠɔoɠɔ GALAGI ná-maaɠoloi ʋa,
\q1 mina ná-zelilomai ʋɛlɛʋɛlɛ.
\q1 
\v 12 Mazɔlɔɔ nii Ɠɔoɠɔ GALAGI nɛai ʋɛ, naa ɠa a ɗa zelii lo ma,
\q1 eɠɛʋelei doun kɛɛɠɛi a ɗa kɛ la ná-doun zunui ʋɛ, nii nɛai bɛ.
\s1 Ɠimalai ta undaanɛɛi
\q1 
\v 13 Undaanɛ nu ɠa ga naama zunui, nii é ɠigi zɔlɔɔgai,
\q1 zunui nii é ga kidafaawu nui!
\q1 
\v 14 Mazɔlɔɔ kulanumai é sɔlɔɔsu, naa vizɔgɛ walii nɔnɔi ʋa,
\q1 ná-tɔnɔgi vizɔgɛ zanu kitei ʋa.
\q1 
\v 15 Fizɔgɛ é leʋe kɔtu zɔngɔ ɓaagi pɛ ba,
\q1 è yiima anii tanɔpɛ ge la vizɔga ga tɔun kɛʋele.
\q1 
\v 16 Sii zuɠoozai ɠa ɠimalai yeezai ɠa,
\q1 kɔʋɛi ɠa, naavoloi ta lɛbiyai ɠa é miná.
\q1 
\v 17 Peleiti é nu ʋilɛsu ti ʋa, naati pagɛ,
\q1 ná-peleiti kpein ta ɠomisu undaanɛɛi ʋɔ bɛ.
\q1 
\v 18 Toɠa ga zɛnvu wului naati bɛ, niiti ti sosu kpe,
\q1 niiti ti makɛsu ma, naati undaanɛɛʋɛ.
\b
\q1 
\v 19 Ɠɔoɠɔ GALAGI ná-ɠimalai ɠa é zooi ɓɛtɛni la,
\q1 ná-keleɠelegi ɠa é geeɠɔlɔgi ɓɛtɛni la.
\q1 
\v 20 Ná-ɠimalai ʋɔ, zou wu ɗɛiti kulaʋɛ, ti la zooi ma,
\q1 tonaɓiingiti ti ɗa tonai ʋu.
\b
\q1 
\v 21 Dòun zunu, ɠili keleɠelegi ʋa, ta kidafaawui,
\q1 mina zeɠe ti ʋolu eyɛsu ɠɔ.
\q1 
\v 22 Mazɔlɔɔ ta ɠɛ ga zɛnvu ʋagɔi è ya,
\q1 ɗa ɠɛ naazu ga zaalamai.
\q1 
\v 23 Naazu, è ɠisu ɠa ɠala, è ɗa li ga lii ʋele,
\q1 è-ɠɔɠɔi la ziɠaa.
\q1 
\v 24 Ni ɗa laana, maaɠili la ɠɛa è ma,
\q1 ɗa-ɲiimɛnii ɠaaɠaanɛ.
\q1 
\v 25 È la luaa kulafiliba vaaɓa ba,
\q1 ɓaa faa zuɠoloɠologi nii a zei nu ɲɔiti ma.
\q1 
\v 26 Mazɔlɔɔ Ɠɔoɠɔ GALAGI ɠa ɠɛ ga ɗa-ɠitogi,
\q1 toɠa balii kpein seɠe è luɠɔ.
\b
\q1 
\v 27 Siɛnɔpɛ su zobogi è ʋɛ la,
\q1 mina ɠɛlɛ, è ʋa ɓe ɓɔsu naati ba, niiti ti ɓalaai.
\q1 
\v 28 Mina ɠɛ è-zeiɲɔɠɔi ma:
\q1 «Li è ʋa ʋolu, lina, nà fe!»
\q1 Tama anii è ya, nii ɗa fe zea.
\b
\q1 
\v 29 Mina faa ɲɔu ɓɛtɛ ɠisu, è-zeiɲɔɠɔi laalɔɠɔma,
\q1 nii tɔun ka zeini kpɛ è ɠoba.
\q1 
\v 30 Mina nu nɔpɛ sakpe wafuun,
\q1 ni é la faa ɲɔu nɔpɛ kɛɛni ga ɗe.
\b
\q1 
\v 31 Mina ɠaazuɠula toosu nuiti ba,
\q1 è mina ʋokɔɠɔ ti-ziɛ ʋelei ma.
\q1 
\v 32 Mazɔlɔɔ yaava nuiti maayoseɠeʋɛ Ɠɔoɠɔ GALAGI ʋɛ,
\q1 kɛlɛ toɠa ɗa ɠoozu vai lɛ ga naati niiti ti zɔlegai.
\b
\q1 
\v 33 Ɠɔoɠɔ GALAGI ɠa ɗa nu ɲɔi ná-pɛlɛyeɠei voovo,
\q1 naazu ma, toɠa ɗa tuya loo telebo nuiti seizuʋɛ ʋɛ.
\q1 
\v 34 Toɠa ɗa ɲɛɛɠula ɲɛɛɠulasu nuiti su,
\q1 kɛlɛ toɠa ɗa ɠaazu ʋagɔi lo ɓɔɠɔmaayei nuiti ba.
\q1 
\v 35 Lɛbiyai ɠa a ɠɛ ga ɠima nuiti tɔnɔi,
\q1 kɛlɛ faaɠaaɠalala nuiti tɔnɔi ɠa ɠɛ ga unfegi.
\c 4
\s1 Doun kɛɛɠɛi ná-tɛnɛ gooiti
\q1 
\v 1 Dòun zunuiti, à woilo ɠɛɛɠɛ lɛnɛ gooiti ma,
\q1 à woilo ga pagɔ, wo keleɠelegi ɠwɛɛ.
\q1 
\v 2 Nà kala pagɔ veezu wo ya,
\q1 à mina nà-kala gooiti pili ya.
\q1 
\v 3 Gè ɠɛni kɛ̀ɛ ya, ga doun zunu ɠilagi,
\q1 dèe nɛ̀ɛni ʋɛ gola, eɠɛ doun zunu ɠila kpegi.
\q1 
\v 4 Kɛ̀ɛ ɠɛni kàlasu, é ɗa ɠɛ mà:
\q1 «Dàawooiti so ga è-yii pɛ,
\q1 nà-deveiti so, ɗa zɛnvui wo.
\q1 
\v 5 Ɠimalai ɠaiziɛ, ta keleɠelegi,
\q1 mina yeema dàawooiti ma, mina zeɠe ti ʋa.
\q1 
\v 6 Mina ɠɛlɛ ɠimalai ʋa, toɠa ɓɔ è ʋa,
\q1 nɛɛ ʋɛ, toɠa ɓaa è maazu.
\q1 
\v 7 Wɛlɛ ɠimalai lɔɔzeigi ʋa: Ɠimalai ɠaiziɛ,
\q1 keleɠelegi ɠaiziɛ ga è-zɔlɔɔ ganii kpein.
\q1 
\v 8 Bɔɔlɔ, toɠa è wuzeɠe,
\q1 ni ɗa ɠilina ba, toɠa ɠɛ ga lɛbiya è ʋɛ.
\q1 
\v 9 Toɠa bɔɔlɔ pagɔi lɔ è unba,
\q1 é è maaɠili ga masa bɔɔlɔ maayikiai.»
\b
\q1 
\v 10 Woilo dòun zunu, dàawooiti gaaɠa,
\q1 naazu, ɗa è-zii zuɠooza.
\q1 
\v 11 Gè è ɠalagɛ ga ɠimalai ma ʋelei,
\q1 gè lo è luɠɔ telebo peleiti su.
\q1 
\v 12 Ni ɗa ɠɛna ziaa ɠana, è-ɠɔɠɔ zu la ɠataga,
\q1 ni ɗa ɠɛna ɓizaa, è-ɠɔɠɔi la ziɠaa.
\q1 
\v 13 Ɠili kpaan è maaɠolo vai ʋa, nii è sɔlɔɔgai, mina too ya,
\q1 yɛ ɠilini ba, mazɔlɔɔ naa ɠa è-yɛnvui su.
\q1 
\v 14 Mina ziɛ ga nu ɲɔiti ta-ʋelei,
\q1 mina ʋilɛ naati kɛʋelei ʋolu, niiti ti faa ɲɔi ɠɛɛzu.
\q1 
\v 15 Maaɠooza ta-ʋelei ʋa, mina ziɛ la,
\q1 zeɠe ba, è ziɛ yɛ.
\q1 
\v 16 Mazɔlɔɔ faa ɲɔu ɠɛ nui naati, ti la ɲia, ni ti la faa ɲɔi ɠɛɛni,
\q1 ta ʋala ɲiimɛnii ma, ni ti la nui ta looni.
\q1 
\v 17 Mazɔlɔɔ ti-ɠɔnɔgi ɠa ga faa ɲɔi,
\q1 ta-ɓɔɔle lɔɔi ɠa ga suɲɔulai.
\b
\q1 
\v 18 Telebo nuiti ta-ʋelei ɠɛɛʋɛ eɠɛ, geelaalaosu wozakalagi,
\q1 nii ma wozakalagi ɠaa yɛsu wɔɔlɔzu, eyɛsu foloi tɛ.
\q1 
\v 19 Faa ɲɔu ɠɛ nuiti ta-ʋelei ɠɛɛʋɛ eɠɛ kpidii,
\q1 ti la ti ɠɔɠɔziɠa ani ɠwɛɛ.
\b
\q1 
\v 20 Dòun zunu, woilo dàawooiti ma,
\q1 woilo ga pagɔ kpɔ̀ɛ wooiti ma.
\q1 
\v 21 Mina yeema ti ma,
\q1 kɛlɛ makɛ ti ma è-yiimaʋɛ.
\q1 
\v 22 Mazɔlɔɔ niiti ti yeezeizu ti wu, ta ʋa ga zɛnvui naati pɔ,
\q1 ti kɛdɛyai ve ti-ɓusɛi ya.
\q1 
\v 23 Makɛ è-yii ma, é leʋe anii pɛ ba,
\q1 mazɔlɔɔ toɠa zɛnvui wo fai ma ungi su.
\q1 
\v 24 Mina ɓe è-laaʋɛ ʋa, é ʋa ɗa zɛɛiti bo,
\q1 mina è-lakɔlɔgiti zɛ ná, ti ʋa ɗa yaava ɓɔɛiti bo.
\q1 
\v 25 Ɠaazulo ɠakala ʋelei ʋa,
\q1 wɛlɛ ɠakalaʋɛ ga pagɔ.
\q1 
\v 26 Pelei zuɓɛtɛ, ʋɛ è ziɛzu ná,
\q1 pelei è laai da, ziɛ ga naa.
\q1 
\v 27 È mina zeɠe ba, è ʋa li ga yeezazu ʋelei, ɓaa ɠɔʋɛzu ʋelei,
\q1 ɠɔɠɔɠula faa ɲɔu ɠɛɛ vai zu.
\c 5
\s1 Wɛɛnziɛgi ɠa ɗa nui ʋaa
\q1 
\v 1 Dòun zunu, woilo ga pagɔ nà-ɠimala wooi ma,
\q1 woilo nà-keleɠele gooiti ma,
\q1 
\v 2 naa ɠa a kɛ, è zoo kidafaawui la,
\q1 faaɠwɛgi ɠa ɠɛ è-laawooiti su.
\q1 
\v 3 Mazɔlɔɔ wɛɛnziɛ anzanui laawooiti nɛɛʋɛ eɠɛ kɔin gulɔi,
\q1 ti ʋagɛ eɠɛ siɛma wulɔi.
\q1 
\v 4 Kɛlɛ ná-fai ɠaaɓelazuʋɛ ɠaa ɠa ɗa wana ga nu, eɠɛ siinziin ganigi, nii wanaai,\f + \fr 5:4 \fq siinziin ganigi, nii wanaai\ft : Aɓisɛnte, tufa wanawanagi, é ɠɛni ga faa wanai (\xt TSV 29:17; Zel 9:14; Amɔ 6:12\xt*\ft ) ɓaa kotoi ná-ani ʋili koozui ʋoogi (\xt Gɔl 3:15; Kul 8:10-11\xt*\ft ).\f*
\q1 gaaliʋɛ eɠɛ boɠa zɔkpɔi, nii gaaʋɛ fele.
\q1 
\v 5 Siɛ ʋelei ɠa ɗa li ga nui saai ʋɔ pelei,
\q1 kɔɠɔiti ta ɗa zeeli gɔvɛalaazu.
\q1 
\v 6 É la ɗa ga yiizoolɛ ga, é ziɛ ga zɛnvu ʋelei,
\q1 é la suɠwɛɛ ga toɠa ziɛzu ga kaka peleiti.
\b
\q1 
\v 7 Niizu deɠɛmu, dòun zunu, woilo gòoi ma,
\q1 mina ɠɛlɛ dàawooiti ba,
\q1 
\v 8 Maaɠooza naama anzanui ma zii ʋa,
\q1 mina maaɓuɠa ná-pɛlɛlaʋɛ ʋa,
\q1 
\v 9 naa ɠa a kɛ, è mina è ɠaazu unfegi lɔ zunu ɠili zeezu,
\q1 ɗa-eteai mina lɔ zunu ɲɔu yeezu.
\q1 
\v 10 Ni naa laade, è-mɔɔlɛzuʋɛ ɠa ɠɛ ga wɛɛinti daamiizu,
\q1 ɗa-wotii zulɔnɔgi ɠa ɠɛ ga pɛlɛ ɠili bu ani,
\q1 
\v 11 naa ɠa a kɛ, è mina li ɓalasu, ɗa-eteai ɠaaɓelazuʋɛ,
\q1 siɛgi zu è-ɓusɛi kpein suyɔkɔgai na la,
\q1 
\v 12 è mina ɠɛ ma:
\q1 «Leeni vaa zu gè maaɠoloi wɔinzeɠeni?
\q1 Leeni vaa zu tɛnɛgi la ɠɛni zoni zìi ma?
\q1 
\v 13 Leeni vaa zu gè la ɠɛni woiloni nà-kalamɔinti gooiti ma?
\q1 Gè la woiloni naati gooi ma, niiti ti kàlani?
\q1 
\v 14 Ná tago nɔ, gè ʋa ɠɛ maanɔɠɔi zu,
\q1 nuɓusɛiti ta-maaɓɔgi zaama.»
\s1 È-anzai nɛɛ ʋɛ
\q1 
\v 15 È-anzai ɠɛɛʋɛ eɠɛ zeɠe ɗɛi.
\q1 Ɓɔɔle ga zeɠe ɗɛi naa!\f + \fr 5:15 \ft Naa ɠa ga: «anzanui nii è yiimazeɠeni la, è-ma nu niinɛlai zu» (\xt 5:18\xt*\ft ).\f*
\q1 
\v 16 Mina è yiima vai yɛ ná, é ʋa ɗa yei taazuʋɛ peleiti su, eɠɛ ziɛi,
\q1 é ʋa ɗa vaza maaɓɔ bosu wolaiti.
\q1 
\v 17 È yiima vaiti ti ɠɛ ga ɗa ɠila kpe nɔ ɗɔnɔ!
\q1 Ti mina ɠɛ ga wo ɓɔma wa anzanu ɠiligiti.
\q1 
\v 18 Ɠoozunɛ yeenɔpɛ su, wo eteai ziɛ ʋɔ, wa anzanui naa,
\q1 nii è yiimazeɠeni la, è-ma nu niinɛlai zu.
\q1 
\v 19 È-anzai ná-fai ɠaanɛɛʋɛ, ná-fai ʋagɛ eɠɛ dopai.
\q1 Kpusɛi ɗa-ɠoozunɛɛi laazeeli yeenɔpɛ.
\q1 Ɠoozunɛ siɛnɔpɛ su ná-nɛɛbɛi zu.
\q1 
\v 20 Dòun zunu, leeni vaa zu è ɠaazuɠulazu nu ɠili anza ʋa?
\q1 Leeni vaa zu ɗa ziilɛi gaiziɛ naama anzanui ya, nii é la ga ɗɔnɔ?
\q1 
\v 21 Ɠɔoɠɔ GALAGI ɠa nui kpein siɛ ʋelei zumɔsu.
\q1 Toɠa ɛsɛ kɛɛwotii ʋɛtɛsu.
\q1 
\v 22 Faa ɲɔu ɠɛ nui ɠa ɗa zo, tɔ ɓɔɠɔi ná-faaɠaaza golai nɔ zu,
\q1 toɠa ɗa zo, ga tɔ ɓɔɠɔi ná-kotoi ʋa ɠaluiti nɔ.
\q1 
\v 23 Undaa ɠa ʋili, tɔɔzei é la zooni ɓɔɠɔ zosu,
\q1 ná-ɠimalalai ɠa a ɗa paa.
\c 6
\s1 Zeelaga vai
\q1 
\v 1 Dòun zunu, ni è ɓɔɠɔ ɠɛɛʋɛ ga zeelagai è-wɔɔlai ta maaɠuye vai zu,
\q1 ni è minazeɠeni è-zeiɲɔɠɔi ʋɛ,
\q1 
\v 2 ni è ɓɔɠɔ ɠilia ga è-laawooiti,
\q1 ni è ɓɔɠɔ ɠɛa ga kasoɠa nu ga è-laawooiti maaʋele,
\q1 
\v 3 naa ma, nii ɗa kɛ dòun zunu, ɓɔɠɔ vie,
\q1 tɔɔzei è loa è-zeiɲɔɠɔi yeezaama,
\q1 li è ɓɔɠɔmaayei bɛ, è ɓɔi da ga maanɛɛnɛi.
\q1 
\v 4 Mina va bu, ɲiimɛnii ʋa lɔ è-ɠaazu,
\q1 ɓaa è-ɠaazuɠɔlɔgiti ti ʋa pɛɛ ma mɛɛ.
\q1 
\v 5 Ɓɔɠɔ vie ga dopai ɠɛʋele, é ɠulazu dosoiti zea,
\q1 eɠɛʋelei wɔnii a ɗa kɛ la, é ɠula wɔni zo nui ná-tumɔi zu.
\s1 Ɲaka nui ná-fai
\q1 
\v 6 Ɗɛi è ga ɲaka nui, li lɛɛ pupuiti pɔ bɛ, è ti ʋɛtɛ,
\q1 ti-ziɛ ʋeleiti sumɔ, è ɠigi zɔlɔɔ.
\q1 
\v 7 Ta-wɛlɛma nu la ná,
\q1 ta-ɠalamɔn la ná, ta-ɠundiɠi la ná,
\q1 
\v 8 ta ɗa ti-ɠɔnɔgi ɓɛtɛ, foɠo undaaɠulazuʋɛ,
\q1 ti ti-laamianigi ɠaalɛ ba molo leʋe ziɛgi zu.
\q1 
\v 9 Ɲaka nui, ɗa yɛsu laani, eyɛsu yeelɛ?
\q1 Siɛgi ɓɛgele ɠa è wuzeɠezu la, è ɠula ɗa-ɲiimɛnii zu?
\q1 
\v 10 È lago ɲi nɔ, è lago ɠaazuʋɛɛ ma fɔin nɔ,
\q1 è zaamale, è yeeiti da ɓɔɠɔ ma,
\q1 
\v 11 naama ziɛgi zu, baladai ɠa na ʋa è ʋɔ eɠɛ siɛziɛ nui,
\q1 maanɔɠɔi ɠula è viliba eɠɛ toosu nui.
\s1 Yaava nui ná-fai
\q1 
\v 12 Nu ɲakai ɠa ga telebotala nui,
\q1 toɠa a ɗa li ga zɛɛ ɓɔɛiti boga,
\q1 
\v 13 é ɗa ɠaazuʋɛ loo ma, é ɗa ɠɔɠɔiti gaaloɠa,
\q1 é ɗa poogiti kɛ ga yeeɓeɠaiti,
\q1 
\v 14 yaava ɠisiɛi nɔ ɠa é ziimaʋɛ,
\q1 faa ɲɔi nɔ ɠa a ɗa ɠisiɛ su yeenɔpɛ,
\q1 é ɗa kpɔɛleʋe vai ɠɛ.
\q1 
\v 15 Naa ɠa é ba, koloɠolo fai ɠa ɠɛ ga kulafilibai,
\q1 naa ɠa ba ɠila nɔ, é ɠoloɠolo, ma zale la ná.
\s1 Nii Ɠɔoɠɔ GALAGI wɔinzeɠezu
\q1 
\v 16 Faa lɔzita ɠa ná, nii bɛlɛɠulaai Ɠɔoɠɔ GALAGI ʋɛ,
\q1 toɠa vɔlɔ ga dɔfela, niiti ti ga maaɲɛɛi:
\q1 
\v 17 gaazulɛɛ ɠaazui, zɛɛ wo nɛgi,
\q1 nui sɔ ge la ba, nuiti ti naa ma ɲamai ʋuuzu ga ti-yeeiti,
\q1 
\v 18 nu yii nii é ɠisiɛzu telebotala vaiti su,
\q1 nu ɠɔɠɔiti ti zuvilaai ɓizɛzu faa ɲɔu ɠɛɛzuʋɛ,
\q1 
\v 19 zɛɛ zeelei, é zɛɛ zeele wooi wosu,
\q1 ta zɔi é kpɔɛi leʋezu ɠɛɛɠɛlointi zɔɠɔzu.
\s1 Wɛɛnziɛgi zakpe pelei
\q1 
\v 20 Dòun zunu, ɠizɛ è-ɠɛɛ ná-deveiti su,
\q1 mina è-lee ná-tɛnɛ gooiti too ya!
\q1 
\v 21 Makɛ ti ma yeenɔpɛ è-yiimaʋɛ,
\q1 ti zɛlɛ ɠɔbu.
\q1 
\v 22 Ta lo è luɠɔ ɗa-ziɛi zu,
\q1 ti è makɛ è-laazuʋɛ,
\q1 ti yɛpɛ è ʋɔ, ɗa wuunna.
\q1 
\v 23 Mazɔlɔɔ devei ɠa ga lanboi,
\q1 kalagi ɠɛ ga wozakalagi,
\q1 zelilogi ta maaɠoloi, ta ga pelei é lo zɛnvui ʋa.
\q1 
\v 24 Ta è makɛ wɛɛnziɛ anzanui ziɛ ʋelei ma,
\q1 ta è-zeiɲɔɠɔi anzai ná-kpɔɛ nɛɛnɛgi ma.
\q1 
\v 25 Mina ɠaazuɠula ná-pagi ʋa è-yiimaʋɛ,
\q1 mina ɓɔɠɔ yɛ ná, é ʋa è zeɠe ga gaazuɠɔlɔgiti.
\q1 
\v 26 Mazɔlɔɔ koloɠolo anzanui maaʋele ma, ɗa ʋala ɗa-ɓulu ɓuɠai nɔ ma,
\q1 kɛlɛ anzanui é zini bɛ, ɗa ɠɛ è ʋala è-yɛnvui pɛ ma.
\q1 
\v 27 Nu ɠa zoo nɛi é abui lɔ ná-zuvai zu,
\q1 é la ná-seɠeiti kpein gala ɓaa?
\q1 
\v 28 Nu ɠa zoo nɛi é ziɛ abulekai ɠa,
\q1 é la kɔɠɔiti gala ɓaa?
\q1 
\v 29 Zenɔ ɠana é la, ga naama nui nii é ʋilɛsu seiɲɔɠɔi anzai ʋolu,
\q1 a vɔɔɠuna ba, salalalai la yɛga.
\q1 
\v 30 Nu la unma nui ʋɛlɛʋiliga, nii é unmai wosu ga é kogi zulaave,
\q1 tɔɔzei ani la zea, nii a mi.
\q1 
\v 31 Anɛɛ naa ʋe, ni ta sona, maanɛɛʋɛ é potogi ve ga seizu lɔfela,
\q1 ani ʋagɔi kpein é ná-pɛlɛi wu, toɠa naa pɛ fe.\f + \fr 6:31 \ft Nii ʋoluʋɛ ɠa ga kɛni ma nu potogi ve. Tɔgi ná-devei ɠɛni ga ma nu potogi ve ga ma ʋɛɛda felegɔ, ɓaa naanigɔ, ɓaa ni gola zu ɠa ɓaaɠona, ma nu ma ʋɛɛda lɔɔlugɔi ve (\xt Ɛgz 22:1-16\xt*\ft ).\f*
\q1 
\v 32 Kɛlɛ zɔi é wɛɛnziɛgi ɠɛɛzu anzanui ʋɔ, naa ʋalagɛ faaɠaaɠai ma,
\q1 ɗa naa ɠɛɛna, ɗa ɓɔɠɔ ɠoloɠolosu, ɗa ɓɔɠɔi.
\q1 
\v 33 Toɠa kpɔlɔi zɔlɔɔ ta ɓaaɠulamai,
\q1 ná-unfegi la ɓega eyɛsu ɠɔ.
\q1 
\v 34 Mazɔlɔɔ toloi ɠa ɗa anzazinigi yiiɠula,
\q1 é la maawɔinɠa ɠɛa, yeei é potokulai ɠɛɛzu la.
\q1 
\v 35 É la unmɔɔ gani nɔpɛ soga,
\q1 é la vaa bu ɲɛgɛlɛin, anɛɛ ni ɗa lobɛani mɔinmɔin teʋesu.
\c 7
\s1 Wɛɛnzo anzanui ɠa ɗa zunu loungoi ɠaka
\q1 
\v 1 Dòun zunu, mina yeema dàawooiti ma,
\q1 nà-deveiti makɛ.
\q1 
\v 2 Ni ɗa pɔ è zɛnvui wo, nà-deveiti so,
\q1 è makɛ nà-kala gooiti ma, eɠɛ è-ɠaazuleegi.
\q1 
\v 3 Ti lɔ yeeɓeɠaiti ba, eɠɛ balaɠaegiti,
\q1 ti zɛʋɛ yiimaʋɛ.
\q1 
\v 4 Ɠimalai leve ga è-ʋaazeelai,
\q1 è keleɠelegi leve ga è-wɔɔlai,
\q1 
\v 5 ga ti è ɠizo wɛɛnziɛ anzanui ma,
\q1 ta è-zeiɲɔɠɔi anzai ná-tɛga ɓɔɛ nɛɛnɛgiti ma.
\b
\q1 
\v 6 Foloi ta, gè ɠɛni loni nà-fenɛtɛlɛi laaʋɛ,\f + \fr 7:6 \fq fenɛtɛlɛi laaʋɛ\ft : Fɔɔvɔ zooiti su fenɛtɛlɛiti daalaoga ɠɛni de, kɔlu ansa vɛlɛvɛlɛgiti ti ʋilɛni ti la, é ɗa ta ɠula foloi ma zezeiti da. Nui a ɠɛna pɛlɛi wu, toɠa nu ʋɛtɛ, kɛlɛ nu la yɛga etea ʋelei, é ʋa ma nu ʋɛtɛ.\f*
\q1 gè ɗa wɛlɛ eteaʋɛ.
\q1 
\v 7 Gè buzeɠe niinɛgiti kaani, ti la dɛ faa pɛ poluɠwɛɛ,
\q1 ti zaama, zunu loungoi ta ɠɛni ná, balagai ɠigi ma.
\q1 
\v 8 É ɠɛni ziɛzu taazuʋɛ pelei zu, adaʋɛ tɔna ʋɛ naama anzanui ta ɠɛni loni ná,
\q1 é liini ga naa ná-pɛlɛi ʋɔ pelei.
\q1 
\v 9 É ɠɛni ga fitili pɛɛzuʋɛ, foloi liini niina,
\q1 kpidii tɔɔzeini niina ga ʋɛa.
\q1 
\v 10 Kɛlɛ wɛlɛ, anzanui daaɠomini,
\q1 maaɠiliai eɠɛ koloɠolo anzanu, yaava ɠigi bɛ.
\q1 
\v 11 É ɗa zɔngɔ, su la zoga,
\q1 kɔɠɔiti ti la yɛga loni kpɛ ada ɠila.
\q1 
\v 12 Taa zaamaʋɛ ʋeleiti su, ta ada wolaiti,
\q1 adaʋɛ pɛ ka é ná-balii laazu ná.
\q1 
\v 13 É zunu loungoi zo, é nɛɛnɛ,
\q1 é ɠaazulo gaazuʋɛ ʋa, é ɠɛ ma:
\q1 
\v 14 «Ziilɛi zalaɠaiti ka gè ɠɛa ti ɠulazu,
\q1 za nɔ ɠa gè nà-minazeɠegi laazeeliai la.\f + \fr 7:14 \ft Nui nii ti ná-zalaɠai ɠulazu, naa ɓena zalaɠa zuai ɠilazuʋɛ mi ta ná-pɛlɛyeɠei (\xt Lev 7:12-15\xt*\ft ), folo mɔungi ta felesiɛi (\xt Lev 7:15-16\xt*\ft ). Zunu loungoi nii loligɛ naama laamii wosuʋɛ.\f*
\q1 
\v 15 Wɛlɛ nii ɠa é kɛa gè ɠula, gè ʋa è laaɠomisu,
\q1 gè ɠɛa pɔ gè è ɠa, gè è ɠaa.
\q1 
\v 16 Gè nà-betei ɠaaɓɛtɛa, ga dasuzeɠei suʋuai,
\q1 ta geze zeɠei é ga Ezipete gelei.
\q1 
\v 17 Gè dàazuʋɛ makugi nɛa ga,
\q1 miilegi, ta alɔwɛgi ta kanɛlegi.
\q1 
\v 18 Ʋa de lɔ ziimaɠɛɛi zu, eyɛsu sobui zeeli,
\q1 de lɔ ɓɔɠɔyiimai ma nɛɛbɛi zu.
\q1 
\v 19 Mazɔlɔɔ sìnigi la ʋɛ, pɛlɛi wu,
\q1 diiʋɛ siɛ ɠooza ma.
\q1 
\v 20 É wali mɔinmɔin seɠeʋɛ ya,
\q1 kɛni alugi a zeina gize la, é ʋa ʋa.»
\b
\q1 
\v 21 É vɔnini ma ga ná-keleɠelegi,
\q1 é mɛɛnni ga ná-woo nɛɛnɛgiti.
\q1 
\v 22 Gaamago nɔ, é ʋilɛni anzanui naa ʋolu,
\q1 eɠɛ nikɛi ti liizu la paazuʋɛ,
\q1 eɠɛ ɓoloɠa nui, ti gilizu ga, ti maaɠolo,
\q1 
\v 23 eyɛsu mɛɛin sɔ zii ʋa,
\q1 eɠɛ wɔnii é ɠaazuvilɛzu ga é ʋili tumɔi zu,
\q1 é la inɛinɛsu ga zɛnvui, é faaɓaagi laawu.
\b
\q1 
\v 24 Dòun zunuiti, niizu niina, à woilo gòoi ma!
\q1 À dama ga dàawooiti!
\q1 
\v 25 Wo-yii mina valibo, é ʋa ʋilɛ anzanui niima zii ʋolu!
\q1 À mina ɠaka, wo ʋa ʋilɛ ná-pelei ʋa!
\q1 
\v 26 Mazɔlɔɔ ná-nu maawanaiti mɔinʋɛ, niiti ti zaai,
\q1 ta niiti é ti undaaʋiligai, ti ɠɛni ga zɛbɛsu nu wolaiti.
\q1 
\v 27 Ná-pɛlɛi ɠa é ga gɔvɛalaazu ʋelei,
\q1 nii é yeizu saai zeizuʋɛ.
\c 8
\s1 Ɠimalai ɠa wooɠulazu
\q1 
\v 1 À woilo, ɠimalai ɠa toligi wosu,
\q1 keleɠelegi ɠa wooɠulazu.
\q1 
\v 2 Toɠa loni ada ɠaaɠoozagiti maazuʋɛ pele ɠobaʋɛ,
\q1 pele zaɠalaʋɛti.
\q1 
\v 3 Taa loaʋɛ, siɠi daaʋɛti,
\q1 nu lɛɛzuʋɛ taazuʋɛ, toɠa wooɠulazu:
\q1 
\v 4 «Nuiti, wa ɠa gè wooɠulazu wo ma,
\q1 nuɓusɛiti, wa ɠa gè ɓɔɛzu wo ʋɔ.
\q1 
\v 5 Wɔiti wo la dɛ faa mɔinmɔin kwɛni, à kidafaawui maaɠɔli,
\q1 faaɠaaɠalala nuiti, à ɠɛ ga keleɠele nuiti.
\q1 
\v 6 À woilo dɛɛ, mazɔlɔɔ faa ɓii ka gè bosu wo ma,
\q1 telebo kpɔɛiti ka ti ɠulazu dàaʋɛ.
\q1 
\v 7 Mazɔlɔɔ gaama ɓɔɛiti ka gè ti wosu,
\q1 màaɲɛɛi ɠa ga zɛɛ ɓɔɛiti.
\q1 
\v 8 Dàawooiti kpein sɔlegɛ,
\q1 tanɔpɛ su la zeini, ɓaa é ʋa ɠɛ ga zɛɛ ɓɔɛ, ɓaa yaava ɓɔɛ.
\q1 
\v 9 Ti pɛ gaaɠalagɛ naama nui ʋɛ, nii keleɠelegai,
\q1 ti ɠole naama nui ʋɛ, nii kalagai.
\q1 
\v 10 Nà-kalagi gè bosu ga woye, à naa wɔin ɠɛ, é leʋe walii ʋa,
\q1 faaɠwɛgi vizɔgɛ zanugi ʋa, anɛɛ zanu kitei.
\q1 
\v 11 Mazɔlɔɔ ɠimalai vizɔgɛ kɔbu yɔlɔɠɔ ʋagɔiti ba,
\q1 ani ʋagɔ nɔpɛ ge la zooga ʋokɔɠɔsu tɔun ma.
\b
\q1 
\v 12 «Nɔ̀un nà, nà ga ɠimalai, sèizuʋɛ ɠa ga kidafaawui,
\q1 sòogɛ faaɠwɛgi ta kidafaawui zɔlɔɔsu.
\q1 
\v 13 Ɠɔoɠɔ GALAGI ɠaazuluabai ɠa é ga, è zili ga faa ɲɔi.
\q1 Niiti gè ti wɔinzeɠezu, ta ga,
\q1 gaazulɛɛi, wasogi, faa ɲɔu ʋelei, ta zɛɛ wo daaʋɛ.
\q1 
\v 14 Tɛnɛ goo ʋagɔiti, ta kidafaawui ta ga nɔ̀nɔ,
\q1 nà ɠa gè ga keleɠelegi, zobogi ɠa ga nɔ̀nɔ.
\q1 
\v 15 Masagiti ta masadai ɠɛɛzu nɔ̀un saɓui zu,
\q1 kundiɠiiti ti tɔgiti sei, niiti ti zɔlegai.
\q1 
\v 16 Saɓui zu ɠa kundiɠiiti ti kundiɠilai ɠɛɛzu la,
\q1 ta seizumaanɛgiti ti pɛ ta ga tukpɔɠaaleʋe nuiti ti zɔlegai.
\q1 
\v 17 Nɔ̀un nà, naati kpein nɛɛʋɛ bɛ̀, niiti ti nɛ̀ɛzu ʋɛ,
\q1 niiti ti gàiziɛzu, naati ta pɛ̀tɛ.
\q1 
\v 18 Naavoloi ta lɛbiyai ta ga nɔ̀un nɔnɔ,
\q1 ta undaanɛɛi ta ani ʋagɔiti ti yɛsu ná ɠɔ.
\q1 
\v 19 Nà-tɔnɔgi vizɔgɛ, é leʋe zanugi ʋa, anɛɛ zanu kitei,
\q1 kulanumai gè feezu naa ɓaɠoʋɛ walii ʋa.
\q1 
\v 20 Nà ziɛzu telebo pelei zu,
\q1 pìlɛgɛ sɔle peleiti ba,
\q1 
\v 21 gè ʋa ani ʋagɔi ve naati bɛ, niiti ti nɛ̀ai ʋɛ,
\q1 gè ta-ʋɛlɛiti buulaave ga naavoloi.
\b
\q1 
\v 22 «Gè ɠɛni Ɠɔoɠɔ GALAGI ya,\f + \fr 8:22 \fq Gè ɠɛni Ɠɔoɠɔ GALAGI ya\ft : Tati pelei taɠiligaa ɓalaa ka ga niiti: \fqa Ɠɔoɠɔ GALAGI yiimazeɠeni ga ze\ft ɓaa \fqa Ɠɔoɠɔ GALAGI gèyani\ft ɓaa \fqa Ɠɔoɠɔ GALAGI sɔ̀lɔɔni\ft ɓaa \fqa Ɠɔoɠɔ GALAGI kpɛ̀tɛni\f* kaite ná-botiiti tɔɔzeizuʋɛ,
\q1 aisa ná-boti mɔungiti tanɔpɛ ge ʋa ɠɛ.
\q1 
\v 23 Gè zeini kaite wɔlɔwɔlɔ,
\q1 aisa eteai ʋa ɓɛtɛ.
\q1 
\v 24 Siɛgi zu gè zɔlɔɔni da, kpoloɗɛi la ɠɛni dɛ ná,
\q1 ɓaa ziɛungiti, ziɛiti ti ʋa ɗa ɠula ti zu.
\q1 
\v 25 Gè zɔlɔɔni pɛ, aisa gizeiti ti ʋa ɓɛtɛ,
\q1 aisa gize ɓufɛgiti ti ʋa ɠula,
\q1 
\v 26 GALA ge la ɠɛni dɛ zooi ɓɛtɛni, ta zou yɔɠɔzuʋɛti,
\q1 anɛɛ eteai ma vufili mɔungi.
\q1 
\v 27 Gè ɠɛni ná niina, siɛgi zu é geeɠɔlɔgi zeini su la,
\q1 é kwɛgi la, é tati ziɛ wolai ma.
\q1 
\v 28 Siɛgi zu é tonaɓiingiti seini su la geezuʋɛ,
\q1 é zɛbɛi ve ziɛungiti bɛ, ti ɗa ɠula ga keɠaaɓaai.
\q1 
\v 29 Siɛgi zu é kpoloɗɛi ɠwɛgi laani la, ziɛiti ti mina ɓudɛ maazu,
\q1 siɛgi zu é eteai ma wuulaagi ɠazaʋini da,
\q1 
\v 30 gè ɠɛni koba, eɠɛ ná-botiɠɛ ɠundiɠi,
\q1 gè ɠɛni ziilaazu folo-o-folo,
\q1 gè ɠɛni kuai wosu gaazu yeenɔpɛ,
\q1 
\v 31 gè ɗa kuai wo ná-etea ɓɛtɛai zu,
\q1 gè ɗa nà-ziilaai zɔlɔɔ nuɓusɛiti saama.
\b
\q1 
\v 32 «Niizu dòun zunuiti, à woilo gòoi ma,
\q1 wa ɠɛ ga undaanɛ nuiti, ni wa ziɛna ga nà-peleiti!
\q1 
\v 33 À woilo nà-kala gooiti ma,
\q1 wa ɠɛ ga ɠima nuiti.
\q1 À mina da ɠoba pɛ!
\q1 
\v 34 Undaanɛ nu ɠa ga naati, niiti ti woilosu gòo ma,
\q1 niiti ti losu nà-pɛlɛlaʋɛ folo-o-folo,
\q1 ti ɠaaɓaazu nà-pɛlɛlaʋɛ ma!
\q1 
\v 35 Mazɔlɔɔ zɔi a kà, naa zɛnvui zɔlɔɔga,
\q1 é Ɠɔoɠɔ GALAGI ná-kpɔbai zɔlɔɔga.
\q1 
\v 36 Kɛlɛ zɔi nɔpɛ é la ɠoloni bɛ̀, naa ɠa ɓɔɠɔ ɓɔlɔzu,
\q1 niiti kpein ti wɔ̀inzeɠezu, saai nɛɛʋɛ naati bɛ.»
\c 9
\s1 Ɠimalai ɠa toligi wosu
\q1 
\v 1 Ɠimalai ná-pɛlɛi loni,
\q1 é ma ɓɛdɛ dɔfelaiti saɠani.
\q1 
\v 2 É toganiiti paani, é dɔɔi ɠɛʋele ɓɛtɛ,
\q1 é taɓalii ɠaaɓɛtɛni.
\q1 
\v 3 É ná-botiɠɛ anzanuiti teʋeni toli bosuʋɛ,
\q1 ti lɛɛni adaʋɛti, ɗa ɠɛ ná, è zɛlɛ taai maazu, ti ɗa ɠɛ ma:
\q1 
\v 4 «Wɔiti wo la dɛ faa mɔinmɔin kwɛɛ, à ʋaa lɛɛ ʋɛ.»
\q1 É boni naati ma, niiti ti la ɠeleɠeleni, é ɠɛ ma:
\q1 
\v 5 «À ʋa, à nà-ɓului ta mi,
\q1 à dɔɔi ɓɔle, nii gè supuai.
\q1 
\v 6 À ɠɛlɛ nuiti ta-ziɛpolui ʋa, niiti ti la dɛ faa mɔinmɔin kwɛɛ, wa zɛnvui wo.
\q1 À ziɛ ga keleɠele pelei!»
\b
\q1 
\v 7 Zɔi a zelii lo waso nui ma, naa ɠa ɗa bɛlɛlalai zɔlɔɔ,
\q1 zɔi a nu ɲɔi maaɠolo, naa ɠa ɗa poomugi zɔlɔɔ.
\q1 
\v 8 Mina ɲɛɛɠulasu nui zɔgi wo ma, mazɔlɔɔ toɠa è wɔinzeɠe,
\q1 kɛlɛ ɠima nui zɔgi wo ma, toɠa è nɛɛ ʋɛ.
\q1 
\v 9 Ungo, ɠima nui lɛnɛ, ta ɠa ɓɔ ná-ɠimalai ʋa.
\q1 Telebo nui ɠala, ta ɠa ɓɔ ná-faaɠwɛgi ʋa.
\b
\q1 
\v 10 Ɠɔoɠɔ GALAGI ɠaazuluabai ɠa é ga ɠimalai lɔɔzeizuʋɛ,
\q1 è GALA Ɲadegai ɠwɛɛ,\f + \fr 9:10 \fq è GALA Ɲadegai ɠwɛɛ\ft : Tati pelei taɠili ɓalaa ka ga nii: \fqa nu ɲadegaiti ta-vaaɠwɛgi\f* é ga kidafaawui.
\q1 
\v 11 Mazɔlɔɔ nɔ̀un nà, ɠimalai, sàɓu zu,
\q1 è-zii ma voloiti su ɠa ɠooza,
\q1 è-zii ma ɠonagiti suɠooza.
\q1 
\v 12 Ni ɗa ga ɠima nu, ɗa suɠulanumai zɔlɔɔ,
\q1 ni ɗa ga waso nu, ɗa ɠila kpe ka ɗa sulɔnɔgi zɔlɔɔ.
\s1 Titigi ɠa toligi wosu
\q1 
\v 13 Titigi ɠa ga eɠɛ anzanui é zɔngɔzu,
\q1 é la faa ɠaaɠaazu, é la faa ɠwɛɛ.
\q1 
\v 14 Toɠa zeini ná-pɛlɛlaʋɛ,
\q1 seizuʋɛ ɠa ga adaʋɛti ti zɛlɛgai taai maazu.
\q1 
\v 15 É ɗa teʋe nuiti toli,
\q1 niiti ti liizu ga pele zakpai,
\q1 
\v 16 «Zɔi é la dɛ faa mɔinmɔin kwɛɛ, naa ɠale ma, é ʋa ʋɛ!»
\q1 Zɔi balagai ɠigi ma, é ɠɛ naa ma:
\q1 
\v 17 «Ziɛi unmaai nɛɛ ʋɛ,
\q1 daamianigi é miizu dɔɔɠuzu, naa nɛɛ ʋɛ!»
\q1 
\v 18 Ti la suɠwɛɛ ga ta ta li laazu gɔvɛiti ma,
\q1 niiti anzanui naa ti lolisu, naati ta niina gɔvɛalaazu.
\c 10
\ms1 Tɛnɛ gooi ma ziiti
\p 
\v 1 Salomɔn ná-tɛnɛ faalaaliiti.
\b
\q1 Ɠima loun zunui ɠa ɗa ɠɛ ga kɛɛɠɛ ná-koozunɛɛi,
\q1 faaɠaaɠalala loun zunui ɠɛ ga dee ná-ziizoolɛi.
\q1 
\v 2 Naavoloi sɔlɔɔ pelei ɲɔuɗai, é la faa ʋaa eyɛsu pɛ,
\q1 kɛlɛ nii é ná-eteai ziɛzu telebogi zu, naa ɠa ɗa ɠizo saai ma.
\q1 
\v 3 Ɠɔoɠɔ GALAGI la telebo nui yɛga na, é ʋa ɓɔlɔ ga pului,
\q1 kɛlɛ toɠa ɠɛlɛ nu ɲɔi yiima vaiti ba.
\q1 
\v 4 Zɔi é la yeeʋɛa faa ʋa, naa ɠa ɗa ɠɛ ga bala nu,
\q1 kɛlɛ zeemaleʋebogi ɠa ɗa nu ɓɛtɛ.
\q1 
\v 5 Nii é ani ɠaalɛɛzu ba, foɠo undaaɠulazuʋɛ, naa ɠa ga doun zunui, nii keleɠelegai,
\q1 kɛlɛ zɔi é ɲiizu molo leʋe ziɛgi zu, doun zunui ɠa ga naa, nii ɓaa ɠa ɠula ma.
\q1 
\v 6 Tuyaiti ta ʋuuni telebo nui unmaʋɛ,
\q1 kɛlɛ nu ɲɔi laawooiti ta ɗa tooma vai maalɔɔɠu.
\q1 
\v 7 Telebo nui ná-kizɛsui ɠa ɗa ɠɛ ga tuyai taɠiligaani bɛ,
\q1 kɛlɛ zeemai ɠa ɗa wo nu ɲɔiti daaseigi ma.
\q1 
\v 8 Zɔi ɠigi ma ziimaʋɛ, naa ɠa ɗa deveiti so,
\q1 kɛlɛ nui é kpɔɛzuɠula ɲakaiti bosu, naa ɠa ɗa ɓɔɠɔ loo ya.
\q1 
\v 9 Zɔi é ziɛzu sɔledai zu, naa ɠa ziɛzu ziilɛigi zu,
\q1 kɛlɛ zɔi é ziɛzu ga pele zuzeigiti, naa ʋolu ɠa ɠula.
\q1 
\v 10 Nii é gaamai lɔɔɠuzu bɔɔlaiti ba, naa ɠa ti ɓɔlɔzu,
\q1 kɛlɛ zɔi é zelii losu ti ma gaamai zu, naa ɠa ʋaazu ga ziilɛigi.\f + \fr 10:10 \fq kɛlɛ zɔi é zelii…ziilɛigi\ft : Ʋele ɠana é la Gɛlɛke woo zɛʋɛ wɔlɔmai zu. Puuzu lɔsaʋai ɠaaɓelasuʋɛ ɠa Eɓulu woo zɛʋɛi bogai ʋɛ ʋolu.\f*
\q1 
\v 11 Telebo nui laawooiti ta ga zɛnvu ɗɛungi,
\q1 kɛlɛ nu ɲɔi laawooiti ta ɗa tooma vai maalɔɔɠu.
\q1 
\v 12 Wɔinzeɠemai ɠa ɗa sakpegi ɠaazo,
\q1 kɛlɛ nɛɛbɛi ɠa ɗa faaɠaazagi pɛ suvaayɛ.
\q1 
\v 13 Keleɠele nui laawooi ɠa ɗa ɠɛ ga ɠima ɓɔɛi,
\q1 kɛlɛ faaɠaaɠalala nui ʋoluʋɛ nɔnɔi ɠa ga kpakɔi.
\q1 
\v 14 Ɠima nuiti ta ɗa faaɠwɛgi ɠaalɛ ba,
\q1 kɛlɛ siɛgi zu faaɠaaɠalala nui ɓɔɛzu la, maanɔɠɔi maa la mɔ ɠoozani ba.
\q1 
\v 15 Kpɛtɛ nui yeaɠɔligi ɠa bɛ ga taa wolai siɠigi ma,
\q1 kɛlɛ bala nui ná-maawɔin ɠa ɗa koloɠolo.
\q1 
\v 16 Telebo nui ná-tɔnɔgi ɠa ɗa lo tuɠɔ, é zɛnvui wo,
\q1 kɛlɛ nu ɲɔi zɔlɔɔgi ɠa ɗa ɠɛ ga faa ɲɔu ɠɛ anii.
\q1 
\v 17 Zɔi é woilosu tɛnɛ gooi ma, naa zɛnvu ʋelei zeɠea,
\q1 kɛlɛ zɔi é ɠɛlɛzu zelilomai ʋa, naa ɓɔɠɔ loa ya.
\q1 
\v 18 Wooveledai ɠana, ɗa wɔinzeɠemai lɔɔɠuna,
\q1 zɔi é leʋesu ga tɔɠɔ ɠoloɠologi ɠɛa, naa ɠa ga ɠimalala nui.
\q1 
\v 19 Zɔi é kpɔɛi zuɠulazu gola, é la ɓega tɔ koloɠologi ɠɛɛzu,
\q1 kɛlɛ zɔi a laaʋɛ zo, naa ɠa ga zunui, nii ɠi pagɔi ma.
\q1 
\v 20 Telebo nui laawooiti ta ga walii ɲadegai,
\q1 kɛlɛ tosu la faa ɲɔu ɠɛ nuiti ta-ɠisiɛi ʋa.
\q1 
\v 21 Telebo nui laawooiti ta ɗa ɓɔ nuɓusɛ mɔinmɔin ba,
\q1 kɛlɛ ɠimalala nuiti ta ɗa za, tɔɔzei ti ʋalagɛ faaɠaaɠai ma.
\q1 
\v 22 Ɠɔoɠɔ GALAGI laa luyai ɠa a ɗa kulagaanɛɛzui ve,
\q1 é la koozuʋili faa nɔpɛ pilɛga polu.\f + \fr 10:22 \fq é la koozuʋili faa nɔpɛ pilɛga polu\ft : Tati pelei taɠili ɓalaa ka ga nii: \fqa nuɓusɛi ná-kpɔlɔi la zooga tanɔpɛ kpɔsu ba\f*
\q1 
\v 23 Faa ɲɔi ɠɛɛ vai ɠa ga ɠaɠo faa ɠimalala nui ya,
\q1 eɠɛʋelei ɠimalai ɠɛɛ vai la ga ɠaɠo faa ɠima nui ya.
\q1 
\v 24 Nii nu ɲɔi luazu ba, naa ɠa a ɗa sɔlɔɔ,
\q1 kɛlɛ nii telebo nuiti ta wɔin ɠɛ, naa ɠa ɗa ve ti ya.
\q1 
\v 25 Siɛgi zu tɔngɔlɔ fiilɛi leʋesu da, nu ɲɔi ɠa ɗa ɲɛɛlɛ!
\q1 Kɛlɛ telebo nui ɠa loni ani ma, nii é ná eyɛsu ɠɔ.
\q1 
\v 26 Eɠɛʋelei ani ɓodai a ɗa kɛ la ga nu ɲiigai,
\q1 duului ɓalaa ga ʋuuna nu ɠaazuʋɛ a ɗa kɛ la,
\q1 zekana ɲaka nui la, naati bɛ niiti ti teʋesu.
\q1 
\v 27 Ɠɔoɠɔ GALAGI ɠaazuluabai ɠa ɗa nui ná-eteai zuɠooza,
\q1 kɛlɛ faa ɲɔu ɠɛ nui ná-konagiti su ɠa ɗa ɓuɠa.
\q1 
\v 28 Telebo nui ná-maaɓɔungi ʋolu ɠa ɠɛ ga koozunɛɛi,
\q1 kɛlɛ faa ɲɔu ɠɛ nuiti ta-ɠitogi ɠa ɠoloɠolo.
\q1 
\v 29 Ɠɔoɠɔ GALAGI ná-pelei ɠa ga siɠigi wooɠɛɠila nuiti maaɠoolii zu,
\q1 kɛlɛ toɠa ga naati koloɠolo saɓui, niiti ti faa ɲɔi ɠɛɛzu.
\q1 
\v 30 Telebo nui la ɲiikpiga eyɛsu pɛ,
\q1 kɛlɛ faa ɲɔu ɠɛ nuiti ti la yɛga zooi zu.
\q1 
\v 31 Telebo nui laaʋɛ ɠa ɗa ɠimalai wo,
\q1 kɛlɛ yaava nuiti nɛgi ɠa leʋe ga.
\q1 
\v 32 Telebo nui lakɔlɔgiti ti nuɓɔɠɔlai ɠwɛɛ,
\q1 kɛlɛ faa ɲɔu ɠɛ nuiti daaʋɛ yaavaʋɛ.
\c 11
\q1 
\v 1 Ɠɔoɠɔ GALAGI maaɲɛɛi ɠa ga zɛɛ ɠɔɠɔ bo ganiiti,
\q1 kɛlɛ kiloiti ti laazeeliai, naati nɛɛʋɛ bɛ.
\q1 
\v 2 Wasogi ʋolu anii ɠa é ga wɔinzeɠemai,
\q1 kɛlɛ ɠimalai ɠa loni ɓɔɠɔmaayei nuiti kobaʋɛ.
\q1 
\v 3 Ladalai ɠa loni sɔle nuiti tuɠɔ,
\q1 kɛlɛ yaava nuiti ta-woyai ɠa ɗa lati, é ti ɠoloɠolo.
\q1 
\v 4 Naavoloi la levea ga ani nɔpɛ, tukpɔɠaaleʋe voloi,
\q1 kɛni telebodai ɠɛɛ vai nɔ ɠa a nu ɠizo saai ma.
\q1 
\v 5 Telebo nui ná-ladalai ɠa ɗa ná-eteai zɔle,
\q1 kɛlɛ faa ɲɔu ɠɛ nui ɓɔɠɔ vaa ɲɔi ɠa a ɗa too.
\q1 
\v 6 Telebo nui ná-sɔlegi ɠa ɗa kizo faaɓaagiti ma,
\q1 kɛlɛ woovele nuiti koozu ɠisiɛi ɠa ɗa ɠɛ ga balii, ti ɠɔɔ la.
\q1 
\v 7 Siɛgi zu nu ɲɔi zaazu la, ná-kitogi pɛ ge ɠoloɠologa,
\q1 ná-kitogi é ɠɛni ga naavoloi, naa loa ya.
\q1 
\v 8 Telebo nui ɠa ɠula kidaaʋiligi zu,
\q1 faa ɲɔu ɠɛ nui ʋilɛ potogi zu.
\q1 
\v 9 Nui é ɠɛlɛzu GALA ba, naa ɠa ɗa zɔiti koloɠolo ga daawooiti,
\q1 kɛlɛ telebo nuiti ɠimalai ʋɔ, ta ɠizo.
\q1 
\v 10 Siɛgi zu telebo nuiti undaanɛɛzu la, taai kpein koozu ɠa ɗa nɛ,
\q1 siɛgi zu faa ɲɔu ɠɛ nuiti undaaʋilisu da, nuiti ta ɗa wooɠula ga koozunɛɛi.
\q1 
\v 11 Sɔle nuiti daa luyai ɠa ɗa ʋa ga ɓɔɠɔzɔlɔɔgi ta-laazuʋɛ.
\q1 Kɛlɛ faa ɲɔu ɠɛ nuiti daa ɓɔɛi ɠa ɗa koloɠolo.
\q1 
\v 12 Zɔi é seiɲɔɠɔi ʋɛlɛʋilisu, naa la ga faaɠaaɠaa nu,
\q1 kɛlɛ nui nii é faa ɠaaɠaazu, naa ɠa ɗa maaɠɛ kpɔ.
\q1 
\v 13 Fama wo nui ɠa ɗa dɔɔɠuzu vaiti kula kɛlɛma,
\q1 kɛlɛ sɔɓelama nui ɠa ɗa ti makɛ ɠoozu.
\q1 
\v 14 Siɛgi zu totuɠɔ ʋagɔ la zooi ʋɛ la, nuɓusɛiti ta ɗa loo bu,
\q1 kɛlɛ kizogi ɠa ɗa zɔlɔɔ tɛnɛbo nu mɔinmɔingiti zea.
\q1 
\v 15 Zɔi é yeelaazu wɛɛn maaɠuyei ɠa, toɠa ɓaa ma,
\q1 kɛlɛ zɔi é ɠɛlɛzu zeelaga vai ʋa, naa ɠa ɠɛ ziilɛigi zu.
\q1 
\v 16 Anzanu ʋagɔi ɠa ɗa lɛbiyai zɔlɔɔ,
\q1 suɓaa zunuiti ti naavoloi zɔlɔɔ.
\q1 
\v 17 Zunui é nuɓɔɠɔlai ɠɛɛzu, naa ɠa kɛɛzu ɓɔɠɔ nɔ ʋɛ,
\q1 kɛlɛ suɲɔu zunui ɠa ɓɔɠɔ maanɔɠɔzu.
\q1 
\v 18 Faa ɲɔu ɠɛ nui ɠa ɗa yaava lɔnɔgi ɠaiziɛ,
\q1 kɛlɛ zɔi é telebodai ɠɛɛzu, naa ɠa ɗa zala ɠitei zɔlɔɔ.
\q1 
\v 19 Zekana, telebodai ɠaaɓelazuʋɛ ɠa ga zɛnvui,
\q1 kɛlɛ zɔi é ʋilɛsu faa ɲɔi ʋolu, naa ɠa saai laaɠomisu.
\q1 
\v 20 Ɠɔoɠɔ GALAGI la wɔinni ga naati, niiti ti-yiimaʋɛ laavegai ga yaavai,
\q1 kɛlɛ toɠa losu naati polu, niiti ti ziɛzu ga sɔledai.
\q1 
\v 21 Gaamazu, faa ɲɔu ɠɛ nuiti salalalai la yɛga,
\q1 kɛlɛ telebo nuiti ti-mavofodaiti ta ɠizo.
\q1 
\v 22 Anzanui nii pagai, kɛlɛ balagai ɠigi ma,
\q1 kɛɛʋɛ eɠɛ zanu balaɠaegi piligai boigi zokpai ʋa.
\q1 
\v 23 Telebo nuiti wɔinma vaa ɠila kpegi nɔ ɠa faa ʋagɔi.
\q1 Nii nɔ faa ɲɔu ɠɛ nuiti ta zoo ti ɠito ba, naa ɠa nɔ ga GALA ná-ziiɠaawanai.
\q1 
\v 24 Tanigaa ta ɗa faanɛɛi ɠɛ gola, tama ti ɗa wola ɓɛtɛ.
\q1 Tanigaa ma ti ɗa ɠikpa naavoloi ma gola, tama ti ɗa ʋala.
\q1 
\v 25 Faanɛɛ ɠɛ nui ɠa ɗa sɔlɔɔgi wo gola,
\q1 zɔi a nu ɠɔ ga kpɔɔle ɗɛi, tɔ ɓalaa ka kpɔɔle ɗɛi zɔlɔɔ.
\q1 
\v 26 Nuɓusɛiti ta ɗa molo makɛ nui voovo, zɔi é ɠɛɛzu, é ʋa pɔdi ga daaɓaai,
\q1 kɛlɛ ta ɗa tuya loo naa ʋɛ, nii é liizu la ga é pɔdi.
\q1 
\v 27 Zɔi é faa ʋagɔi ɠɛɛ vai ɠaiziɛzu, naa ɠa ɗa undaanɛɛi zɔlɔɔ,
\q1 kɛlɛ zɔi é faa ɲɔi ɠaiziɛzu, faa ɲɔi ɠa ɗa zeeli naa ma.
\q1 
\v 28 Zɔi a ʋoluzei ná-naavoloi ʋa, naa ɠa loo bu,
\q1 kɛlɛ telebo nuiti gaa ɠa wɔɔlɔ eɠɛ gulu wola, nii gaalaagi mɔinɗai.
\q1 
\v 29 Zɔi a gooɠaavazagi lɔɔna ná-pɛlɛyeɠei wu, toɠa sulɔnɔgi zɔlɔɔ ga fiilɛ wolai,
\q1 faaɠaaɠalala nui ɠa ɠɛ ga ɠima nui ná-duɔi.
\q1 
\v 30 Telebo nui ná-kɛɛwotiiti ta ga zɛnvu wului,
\q1 ɠima nui ɠa ɗa nui taɠiligaa ʋilɛ pele ʋa.
\q1 
\v 31 Ni telebo nui ɠa zalai zɔlɔɔsu gaamanɔ eteai zu,
\q1 koleʋɛ ɓalaa ga, faa ɲɔu ɠɛ nui ta kotoba nui, ta ti-zalai zɔlɔɔ!
\c 12
\q1 
\v 1 Zɔi nɛai bɛ ga maaɠolo, faaɠwɛgi wɔin ɠa naa ma,
\q1 kɛlɛ zɔi zelilomai ɠaawanazu la, naa la ɠeleɠeleni.
\q1 
\v 2 Nu ʋagɔi ɠa ɗa Ɠɔoɠɔ GALAGI ná-undaanɛɛi zɔlɔɔ,
\q1 kɛlɛ Ɠɔoɠɔ GALAGI ɠa ɗa naama nui ʋeelala, nii é kisiɛ ɲɔiti bosu.
\q1 
\v 3 Suɲɔu vai la ɗa ga nui losu ɓɛtɛa,
\q1 kɛlɛ zɔi sɔlegai naa lɔɔ la ɠulaa.
\q1 
\v 4 Ziilɔɔ anzanui ɠa ɗa sinigi nɔungi wuzeɠe,
\q1 kɛlɛ anzanui é unfetala vai ɠɛɛzu, toɠa sinigi ʋa ga kae wana zeeɓɛi.
\q1 
\v 5 Telebo nuiti ta-ɠisiɛiti ta faa zɔle faiti nɔ ʋa,
\q1 kɛlɛ faa ɲɔu ɠɛ nuiti siɛ ʋelei ɠa nɔ ga yaavai.
\q1 
\v 6 Faa ɲɔu ɠɛ nuiti daawooiti ta ga baliiti ti nui ʋaazu,
\q1 kɛlɛ telebo nuiti daawooiti ta ɗa ti ɠizo.
\q1 
\v 7 Faa ɲɔu ɠɛ nuiti ta lokana, ti la mɔ ɠɛa ná!
\q1 Kɛlɛ telebo nuiti ta-ʋɛlɛi ɠa yɛ loni kpaan.
\q1 
\v 8 Nui ɠa ɗa maamusɛi zɔlɔɔ, é zoloo ná-kisiɛ ʋagɔiti ma,
\q1 kɛlɛ zɔi kigi la zɔleni, naa wɔin ɠa zeɠe.
\q1 
\v 9 Fizɔgɛ nu ɠɛ ga nui zobo ge la bɛ, botiɠɛ nu ɠila nɔ ɠɛ è ya,
\q1 è ʋa ɠɛ ga nui tɔɠɔi ɠulaai, kɛlɛ é ʋalasu kɔnɔgi ma.
\q1 
\v 10 Telebo nui ɠa ɗa ɠaaɓa ná-toganiiti ma,
\q1 kɛlɛ faa ɲɔu ɠɛ nuiti koozu vai ɠa ga gaazumaavɔi nɔ.
\q1 
\v 11 Zɔi é ná-tii ɠɛɛzu, naa ɠa daamianigi zɔlɔɔ ga bɔɔlɔa,
\q1 kɛlɛ zɔi é ʋilɛsu gaaʋalaba vaiti polu, naa ʋalagɛ ɠigi ma.
\q1 
\v 12 Nu ɲɔi ɠaazu ɠa ɗa ɠula faa ɲɔu ɠɛ nuiti daamiizuʋɛ ʋa,
\q1 kɛlɛ telebo nuiti ma zapei ɠa a ɗa gwaa wo.
\q1 
\v 13 Faa ɲɔu ɠɛ nui ɠa ɗa ɠɔ ga tɔ ɓɔɠɔi ná-zɛɛiti ma ʋalii,
\q1 kɛlɛ sɔle nui ɠa ɗa ɠula faaɓaagiti kpein su.
\q1 
\v 14 Nui laawooi ʋɔ, toɠa zoo é undaanɛ wola ɠaalɛ ba,
\q1 eɠɛʋelei nu a ɗa ná-botii ma zalai zɔlɔɔ da.
\q1 
\v 15 Ɠimalala nui ná-pelei zɔlegɛ tɔ ɓɔɠɔi ɠaazu,
\q1 kɛlɛ ɠima nui ɠa ɗa woilo zɔiti tɛnɛ gooi ma.
\q1 
\v 16 Ɠimalala nui ɠa ɗa ná-ziiɠaawanai ɠula kɛlɛma gaamago nɔ,
\q1 kɛlɛ ɠima nui ɠa ɗa ná-daazuɠɔli vaiti buuɓɔle.
\q1 
\v 17 Nui é gaamai ɠulazu kɛlɛma, naa ɠa telebo fai lɛɛzu,
\q1 kɛlɛ zɛɛ zeelei ɠa ɗa yaavai ɠɛ.
\q1 
\v 18 Kpɔɛzuɠula ɲakaiti ta ɗa maawanai wo eɠɛ boɠa zɔkpɔi,
\q1 kɛlɛ ɠima nuiti daawooi ɠa ɗa ʋa ga kɛdɛyai.
\q1 
\v 19 Gaama nui ɠa yɛ ná ɠɔ,
\q1 kɛlɛ zɔi é zɛɛi wosu, naa la lɛbiga.
\q1 
\v 20 Niiti ti faa ɲɔiti kpɛtɛzu, naati ziimaʋɛti daavegɛ ga yaava vaiti,
\q1 niiti ti nuiti tɛnɛsu ga faa ʋagɔi, naati ta ɗa koozunɛɛi zɔlɔɔ naa zu.
\q1 
\v 21 Maanɔɠɔ nɔpɛ ge la zeelia telebo nui ma,
\q1 kɛlɛ kpɔlɔi ɠa ɗa ɠɛ faa ɲɔu ɠɛ nuiti unma.
\q1 
\v 22 Ɠɔoɠɔ GALAGI la wɔinni ga zɛɛ wo nuiti,
\q1 kɛlɛ toɠa gaama wo nuiti polu.
\q1 
\v 23 Ɠima nui la ɗa ga ná-faaɠwɛgi zulɛa,
\q1 kɛlɛ ɠimalala nui ɠa ɗa zeze ga ná-faaɠaaɠalalai.
\q1 
\v 24 Niiti ti zoogai yeemaleʋebosu, naati ta ɗa lo faa wolaiti untuɠɔ,
\q1 kɛlɛ ɲaka nuiti ta ɗa lɔ duɔlai zu.
\q1 
\v 25 Ziizoolɛi a ɠɛna nui yiimaʋɛ, toɠa ɗa vɔ,
\q1 kɛlɛ iɲɔdɔɔ ɓɔɛi ɠa ɗa nui ɠoozunɛ.
\q1 
\v 26 Telebo nui ɠa ɗa ɠɛ ga ʋelela ʋagɔ bɔɔlaiti bɛ,
\q1 kɛlɛ faa ɲɔu ɠɛ nuiti siɛ ʋelei ɠa ɗa ti ɠaka.
\q1 
\v 27 Sua ɓɛ nui nii dɔɔʋɛai, naa la sua zɔlɔɔga, é ʋa gee.
\q1 Faa ʋagɔi, nii fizɔgai ti pɛ ba nuɓusɛi ná-faa zu, naa ɠa ga é zoo yeemaleʋebosu.
\q1 
\v 28 Ʋɛ telebodai ɠɛɛzu ná, miná ɠa zɛnvui ná,
\q1 naama ʋelei ɠa nu ɠizosu saai ma.
\c 13
\q1 
\v 1 Ɠima loun zunui ɠa ɗa ɠizɛ maaɠoloi zu, kɛɛɠɛ bogai la,
\q1 kɛlɛ waso doun zunui la ɗa ga woiloga zeliloma ɠila kpalaa ma.
\q1 
\v 2 Ɗa zoo è ani ʋagɔiti sɔlɔɔ ga nu laawooiti maaʋele,
\q1 kɛlɛ faa ɲɔu ɠɛ nuiti ta-etea ziɛi ɠa ga toomai.
\q1 
\v 3 Zɔi a dama ga daawooiti, naa ɠa zɛnvui makɛsu,
\q1 zɔi é kpɔɛi wola zuɠulazu, é la ɠidaazu bu, naa ɠa ɗa ɓɔɠɔ loo ya.
\q1 
\v 4 É la faa ʋaa dɔɔʋɛ nui ma, gaazu ʋa ɠula ani ʋa,
\q1 kɛlɛ zeemaleʋebo nui ɠa ɗa naa zɔlɔɔ, nii wɔin ma.
\q1 
\v 5 Telebo nui ɠa ɗa zɛɛ ɓɔɛiti wɔinzeɠe,
\q1 kɛlɛ nu ɲɔi ɠa ɗa unfe fai ɠɛ, ta tɔɠɔ ɠoloɠolo fai.
\q1 
\v 6 Zɔi é siɛ ʋelei zɔlegai, telebodai ɠa ɗa naa makɛ,
\q1 kɛlɛ faa ɲɔi kotoba nuiti ti kɛɛzu, naa ɠa a ɗa ti undaaʋili.
\q1 
\v 7 Tanigaa ta kɛɛzu eɠɛ ta ɓɛtɛ, tama ani nɔpɛ ge la ti ya,
\q1 tanigaa ti ɓɔɠɔ ɠɛ eɠɛ bala nu, kɛlɛ anii ti ya ga gola.
\q1 
\v 8 Tanisu naavolo nui ɠa ɗa ani zala, é ʋa zɛnvui unmɔɔ,
\q1 kɛlɛ bala nu la woiloga zeliloma ma.
\q1 
\v 9 Telebo nui ɠa volozu, eɠɛ wozakalagi gola volozu,
\q1 kɛlɛ faa ɲɔu ɠɛ nui ɠɛɛʋɛ eɠɛ lanboi, nii é zaazu.
\q1 
\v 10 Sakpegi kpein ka ɠulazu wasogi zu,
\q1 ɠimalai ɠa naati zea, niiti ti woilosu tɛnɛgiti ma.
\q1 
\v 11 Naavoloi nii sɔlɔɔgai ga wuugi, gaa ɠa ɗa ʋala ba,
\q1 kɛlɛ nii sɔlɔɔgai vaa, vaa, naa ɠaa ɠa ɗa wɔɔlɔ.
\q1 
\v 12 Nui ná-kitogi a ɠoloɠolona, toɠa ɗa ziiɓɔlɔ,
\q1 kɛlɛ nui yiima vai a ɠɛɛna, naa ɠɛɛʋɛ eɠɛ zɛnvu wului.
\q1 
\v 13 Zɔi a wooi ʋɛlɛʋilina, naa ɠa suɓoloɠɔmɔ,
\q1 kɛlɛ zɔi a devei zona, naa ɠa ma zalai zɔlɔɔ.
\q1 
\v 14 Ɠima nui ná-kalagi ɠa ga zɛnvu ɗɛungi,
\q1 toɠa ɗa kaka faiti kpudɛ nu maazu, niiti ta ɠɛ ga nu zaa vaa.
\q1 
\v 15 Kɛʋele ʋagɔi ɠa ɗa zaalai la nu ma,
\q1 kɛlɛ gaaɓelazu la yaava nuiti ta-ʋelei ʋa.\f + \fr 13:15 \fq Kɛlɛ gaaɓelazu la yaava nuiti ta-ʋelei ʋa\ft : Tati pelei taɠili ɓalaa ka ga nii: \fqa Kɛlɛ yaava nuiti ta-ʋelei ziɛ la ɓaaʋɛ\f*
\q1 
\v 16 Ɠima nu la faa ɠɛa, ni é la ɠigaiziɛni su,
\q1 kɛlɛ ɠimalala nuiti ta ɗa ta-ɠimalala vaiti sulɛ.
\q1 
\v 17 Keelai ɲɔuɗai, naa ɠa ɗa lɔ maanɔɠɔi zu,
\q1 kɛlɛ gooleʋe nui sɔlegai, naa ɠa ɗa faiti suɓɛtɛ.
\q1 
\v 18 Baladai ta unfegi ɠa naama nui luɠɔ, nii é ɠɛlɛzu maaɠoloi ʋa,
\q1 kɛlɛ zɔi a va tɛnɛ gooiti bu, naa ɠa lɛbiyai zɔlɔɔ.
\q1 
\v 19 Toɠa ga faa ʋagɔ nui wɔinma vai laazeeli,
\q1 kɛlɛ ɠimalala nuiti ti la wɔinni ga ti yeeɠula faa ɲɔi zu.
\q1 
\v 20 Nui é ziɛzu ɠima nuiti polu, toɠa ɗa ɠɛ ga ɠima nu,
\q1 kɛlɛ zɔi é zeizeisu ɠimalala nuiti koba, naa ɠa faaɓaagi zɔlɔɔ.
\q1 
\v 21 Maanɔɠɔi ɠa kotoba nuiti polu,
\q1 undaanɛɛi ɠa ɗa telebo nui zala.
\q1 
\v 22 Zunu ʋagɔi ɠa ɗa poganii yɛ ná mavofodaiti bɛ,
\q1 kɛlɛ kotoba nui ná-sɔlɔɔgiti makɛgɛ ga telebo nuiti tɔnɔ.
\q1 
\v 23 Bala nui ná-woza wogai zu ɠa a ɗa ɠɔnɔgi zɔlɔɔ ná, ga bɔɔlɔa,
\q1 kɛlɛ telebotalai ɠa ɗa ɠɔnɔgi ɠoloɠolo.
\q1 
\v 24 Zɔi é ɠɛlɛzu ná-doun zunui loɠa vai ʋa, naa la nɛɛni bɛ,
\q1 zɔi é nɛɛzu ʋɛ, naa la inɛinɛga maaɠolo vai ʋa.
\q1 
\v 25 Telebo nui ɠa ɗa daami wo, ziila,
\q1 kɛlɛ faa ɲɔu ɠɛ nuiti koozu ɲakai ɠa ɗa yɛ de.
\c 14
\q1 
\v 1 Ɠima anzanui ná-pɛlɛyeɠei loni,
\q1 kɛlɛ ɠimalala gelei nɔnɔi woloni tɔ ɓɔɠɔi.
\q1 
\v 2 Zɔi é ziɛzu telebodai zu, naa ɠa ɗa ziɛ Ɠɔoɠɔ GALAGI ɠaazuluabai zu,
\q1 kɛlɛ zɔi é ziɛzu ga yaava ʋeleiti, naa ɠa ɗa pɛlɛʋɛlɛ.
\q1 
\v 3 Ɠimalala nui ɠa ɗa maaɠoloi zɔlɔɔ ga daawooiti maaʋele,
\q1 ɠima nuiti ti-lakɔlɔgiti ta ɗa ti makɛ.
\q1 
\v 4 Ʋɛ wozawoli nikɛ la ná, daamianigi ɠa daamii ɲakai zu,
\q1 kɛlɛ nikɛ zinɛi zuvikɛi ɠa a ɗa tɔnɔ golai ve.
\q1 
\v 5 Zeelei sɔlegai, é la zɛɛ woga pɛ,
\q1 kɛlɛ zɛɛ zeelei ɠa ɗa zɛɛ ɓɔɛiti bo.
\q1 
\v 6 Anɛɛ ni ɲɛɛɠulasu nui ɠa ɠimalai ɠaiziɛ, é la sɔlɔɔga,
\q1 kɛlɛ kidafaawu nui ɠa ɗa faaɠwɛgi zɔlɔɔ yɔɔɠɛ nɔ.
\q1 
\v 7 Maaɠooza faaɠaaɠalala nui ʋa,
\q1 mazɔlɔɔ é la ɠi gila kpalaa fea è ʋɛ.
\q1 
\v 8 Kidafaawu nui ɠa ɗa siɛ ʋelei ʋɛtɛ, tɔɔzei toɠa ga ɠima nui,\f + \fr 14:8 \fq Kidafaawu nui ɠa ɗa siɛ ʋelei ʋɛtɛ, tɔɔzei toɠa ga ɠima nui\ft : Tati pelei taɠili ɓalaa ka ga nii: \fqa Kidafaawu nui ná-ɠimalai ɠa ɗa ɓɔ ba, é siɛ ʋelei ʋɛtɛ\f*
\q1 faaɠaaɠalala nuiti ta ɗa loo ya ta-ɠimalalai ʋɔ.
\q1 
\v 9 Ɠimalala nuiti ta ɗa ɲɛɛɠula zɔɠɔzuɓɛtɛ vai zu,
\q1 kɛlɛ undaanɛɛi ɠa ɗa ɠɛ sɔle nuiti saama.\f + \fr 14:9 \fq kɛlɛ undaanɛɛi ɠa ɗa ɠɛ sɔle nuiti saama\ft : Tati pelei taɠiligaa ɓalaa ka ga niiti: \fqa kɛlɛ ɠi pagɔi ɠa sɔle nuiti bɛ \ft ɓaa \fqa kɛlɛ sɔle nuiti ta pɔ ti undaanɛɛi zɔlɔɔ\f*
\q1 
\v 10 Ɛsɛ nɔ ɠa é ná-ziizoolɛi ɠwɛɛ, ta ná-koozunɛɛi,
\q1 nu ɠili ge la zooga é ʋa nɔnɔ zɔlɔɔ naa zu.
\q1 
\v 11 Faa ɲɔu ɠɛ nuiti ta-ʋɛlɛi ɠa wolo,
\q1 kɛlɛ sɔle nuiti ta-zeɠe ɠotai ɠaa ɠa wɔɔlɔ.
\q1 
\v 12 Ta ɠa ná, siɛ ʋelei zɔlegai gaazu,
\q1 kɛlɛ gaaɓelazuʋɛ ɠa ga saa ʋelei.
\q1 
\v 13 Ɲɛɛi ɠa zoo é ziizoolɛi ɠaazumaalɔɔɠu,
\q1 koozunɛɛi ɠa zoo é ɠaaɓela ga ziizoolɛi.
\q1 
\v 14 Kɔzɔba nui ɠa ɗa ná-kɛɛwotiiti ma ɠulanumai zɔlɔɔ,
\q1 kɛlɛ nu ʋagɔi ɠa ɠoozunɛ nɔnɔ ma ziɛ ʋeleiti ma ɠulanumai zu.\f + \fr 14:14 \fq kɛlɛ nu ʋagɔi ɠa ɠoozunɛ nɔnɔ ma ziɛ ʋeleiti ma ɠulanumai zu\ft : Tati pelei taɠiligaa ɓalaa ka ga niiti: \fqa kɛlɛ nu ʋagɔi ɠɛʋelei vizɔgɛ nɔnɔi ʋa \ft ɓaa \fqa kɛlɛ nu ʋagɔi ɠɛʋelei ɠaaɠoozaʋɛ nɔnɔi ʋa\f*
\q1 
\v 15 Nui nii é la dɛ faa mɔinmɔin kwɛɛ, toɠa ɗa la naati kpein da, niiti ti wosu ma,
\q1 kɛlɛ kidafaawu nui ɠa ɗa ziɛ ga keleɠele.
\q1 
\v 16 Ɠima nui ɠa ɗa lua faa ɲɔi ʋa, é ʋoluave,
\q1 kɛlɛ ɠimalala nui ɠa ɗa yiiɠaawana, é kɛ, tɔɔzei daave ɓɔɠɔ la.
\q1 
\v 17 Ziiɠula nui ɠa ɗa ɠimalala vaiti kɛ,
\q1 nui kigaiziɛ ɲɔi ziimaʋɛ, toɠa ɗa wɔinzeɠemai maaloli ɓɔɠɔ ma.
\q1 
\v 18 Nuiti ti la dɛ faa mɔinmɔin kwɛɛ, naati ta-ʋoganii ɠa é ga ɠimalalai,
\q1 kɛlɛ kidafaawu nuiti ta-masa bɔɔlɔgi ɠa é ga faaɠwɛgi.
\q1 
\v 19 Nu ɲɔiti ta ɗa unmaayei nu ʋagɔiti bɛ,
\q1 faa ɲɔu ɠɛ nuiti ɓalaa ta ɗa kɛ ɠana nɔ telebo nuiti ta-ʋɛlɛlaʋɛ.
\q1 
\v 20 Bala nui la nɛɛni nu nɔpɛ bɛ, anɛɛ seiɲɔɠɔiti,
\q1 kɛlɛ kpɛtɛ nui wɔɔlaiti mɔinʋɛ gola.
\q1 
\v 21 Zɔi é seiɲɔɠɔi wɔinzeɠezu, naa ɠa koto ɠɛɛzu,
\q1 kɛlɛ undaanɛ nu ɠa ga naa, nii é maanɔɠɔ nuiti maawɔinɠaazu.
\q1 
\v 22 Niiti ti ɠisiɛzu faa ɲɔi zu, naati ta kaka pelei ma,
\q1 kɛlɛ niiti ti ɠisiɛzu faa ʋagɔi zu, naati ta kɛɛzu nuɓɔɠɔlai ta gaamai zu.
\q1 
\v 23 Botii kpein ka kulanumai ba,
\q1 kɛlɛ pului ɠa kpɔɛzuɠula wafuungi ʋolu.
\q1 
\v 24 Ɠima nuiti ta-masa bɔɔlɔgi ɠa é ga ta-naavoloi,
\q1 ɠimalala nuiti ta-vaaɠaaɠalalai ɠa é ga ta-litigi.
\q1 
\v 25 Gaama wo zeelei ɠa ɗa zɛnvuiti kizo,
\q1 kɛlɛ zɛɛ wo zeelei ɠa ga yaava nu.
\q1 
\v 26 Zɔi é luazu Ɠɔoɠɔ GALAGI ʋa, naa ɠa kito gola zɔlɔɔ,
\q1 ná-doun zunuiti ti dɔɔɠuzu zɔlɔɔ pɔ bɛ.
\q1 
\v 27 Ɠɔoɠɔ GALAGI ɠaazuluabai ɠa é ga zɛnvu ɗɛungi,
\q1 toɠa ɗa kaka faiti kpudɛ nu maazu, niiti ta ɠɛ ga nu zaa vaa.
\q1 
\v 28 Nuɓusɛi ná-mɔin ɠa é ga masagi ná-lɛbiyai,
\q1 kɛlɛ nuɓusɛiti maaʋɛlɛ vai ɠa ɗa kundiɠii ɠoloɠolo.
\q1 
\v 29 Zɔi zii la ɠula fala, naa ɠa ná-ɠimala wolai lɛɛzu,
\q1 kɛlɛ ziiɠula nui ɠa ɗa ná-ɠimalalai zulɛ.
\q1 
\v 30 Ziilɛigi ɠa é ga kpusɛi ná-sii zuɠoozagi,
\q1 kɛlɛ toloi ɠa é ga seeɓɛi ma ɠaeiti su.
\q1 
\v 31 Nu a bala nui maanɔɠɔna, é Kpɛtɛ Nui ʋɛlɛʋɛlɛga,
\q1 kɛlɛ nu a maanɔɠɔ nuiti maawɔinɠaana, é ti Ɓɛtɛ nui lɛbia.
\q1 
\v 32 Faa ɲɔu ɠɛ nui ná-yaavai ɠa ɗa toka,
\q1 kɛlɛ kitogi ɠa ɗa ɠɛ telebo nui ya, eyɛsu saai.
\q1 
\v 33 Ɠimalai ɠa ɗa zei keleɠele nui yiimaʋɛ,
\q1 naa ɠwɛɛgɛ ɓalaa ɠimalala nuiti saama.
\q1 
\v 34 Telebodai ɠɛɛ vai ɠa ɗa zooi wɔɔlɔ,
\q1 kɛlɛ kotoi ɠa ga nuɓusɛiti kpein unfe faa.
\q1 
\v 35 Masagi ná-unfemai ɠa ɗa ɠɛ botiɠɛ nui naati bɛ, niiti ti botii ɠɛɛzu bɛ ga ɠimalai,
\q1 kɛlɛ zɔi é unfe fai ɠɛɛzu, ná-ziiɠaawanai ɠa ɗa zeeli naa ma.
\c 15
\q1 
\v 1 Gooɠaaʋote pagɔi ɠa ɗa ziiɠulagi ɠaayei,
\q1 kɛlɛ nu maawana ɓɔɛi ɠa ɗa kpɔɛi zuwɔɔlɔ.
\q1 
\v 2 Zɔi é kalagi wosu ga ɠimalai, toɠa ɗa kala wɔin ɠɛ nu ma,
\q1 kɛlɛ ɠimalala nui ɠa ɗa ɠimalala vaiti nɔ wo.
\q1 
\v 3 Ɠɔoɠɔ GALAGI ɠaazuʋɛ ɠa adaʋɛ pɛ,
\q1 é ɗa nu ɲɔiti ta nu ʋagɔiti sumɔ.
\q1 
\v 4 Nu laawoo ʋagɔiti kɛɛʋɛ eɠɛ zɛnvu wulu wolai,
\q1 kɛlɛ faa ɲɔu ɠɛ nɛgi ɠa ɗa ziiɠoloɠologi ɠɛ.
\q1 
\v 5 Ɠimalala nui ɠa ɗa kɛɛɠɛ ná-tɛnɛ gooiti pɛlɛʋɛlɛ,
\q1 kɛlɛ zɔi é yeezeizu zelilomai wu, naa ɠa ɓɔɠɔ lɛɛzu ga ɠima nu.
\q1 
\v 6 Naavolo mɔinmɔin ka é telebo nui ná-pɛlɛi wu,
\q1 kɛlɛ nii kpein nu ɲɔi sɔlɔɔsu, toɠa ɗa ɠɛ ga ziizoolɛi ma ungi.
\q1 
\v 7 Ɠima nuiti daawooi ɠa ɗa faaɠwɛgi vaza,
\q1 kɛlɛ faaɠaaɠalala nuiti ziimaʋɛ la ɠana.
\q1 
\v 8 Ɠɔoɠɔ GALAGI maaɲɛɛi ɠa ga faa ɲɔu ɠɛ nuiti ta-zalaɠaiti,
\q1 kɛlɛ sɔle nuiti ta-ƓALA maanɛɛnɛ wooiti nɛɛʋɛ bɛ.
\q1 
\v 9 Ɠɔoɠɔ GALAGI maaɲɛɛi ɠa ga faa ɲɔu ɠɛ nui ziɛ ʋelei,
\q1 kɛlɛ naama nui nɛɛʋɛ bɛ, nii é ʋilɛsu telebodai ʋolu.
\q1 
\v 10 Zɔi é zeɠezu faa ʋagɔi ʋolu, faa wola ɠa la ma ga maaɠolo,
\q1 zɔi é zelilomai wɔinzeɠezu, naa undaa ɠa ʋili.
\q1 
\v 11 Ɠɔoɠɔ GALAGI gɔvɛalaazu ta undaaʋili zeɠezaɠai, zu vaiti kpein kwɛɛ,
\q1 nuɓusɛiti zii ɠwɛɛ fai ɠa ga leeni tɔun bɛ!
\q1 
\v 12 Waso nui nɛɛbɛ vaa la ga nu zelii lo ma,
\q1 é la ɗa ga li ɠima nuiti pɔ bɛ.
\q1 
\v 13 Koozunɛɛi ɠa ɗa nu ɠaazuʋɛ volo,
\q1 kɛlɛ ziiɓɔlɔi ɠa ɗa nu ɠaalɛi.
\q1 
\v 14 Keleɠele nui ɠa ɗa ɠaaɓa faa maaɠɔli vai ma yeenɔpɛ,
\q1 kɛlɛ ɠimalala nui ɠɔnɔgi ɠa ɗa ɠɛ ga ɠimalala vaiti nɔ.
\q1 
\v 15 Maanɔɠɔ nui zii ma voloi kpein ɲɔuʋɛ,
\q1 kɛlɛ zɔi undaanɛai, naa ɠa ɗa ɠɛ fɛti ɠula vai laawu nɔ ɠɔ.
\q1 
\v 16 Fizɔgɛ nu ɗa ani go nɔ zɔlɔɔ, è ɠɛ ga Ɠɔoɠɔ GALAGI ɠaazuluaba nu,
\q1 è ʋa li naavolo wola zɔlɔɔsu, nii ziiɓɔlɔi polu.
\q1 
\v 17 Fizɔgɛ nu tufa wuulugi ma laamii wo, kpɛtɛai nɛɛbɛi zu,
\q1 è ʋa li nikɛ wulɔi miizu, ni wɔinzeɠemai ɠa ná.
\q1 
\v 18 Ziiɠula nui ɠa ɗa kpɔɛiti suwɔɔlɔ,
\q1 kɛlɛ zɔi ziiɠaa la wana fala, naa ɠa ɗa sakpegiti gaayei.
\q1 
\v 19 Ɲaka nui ná-pelei ɠɛɛʋɛ eɠɛ ɠain sasai,
\q1 kɛlɛ sɔle nuiti ta-ʋelei ɠaa ɠa sɔli.
\q1 
\v 20 Ɠima loun zunui ɠa ɗa kɛɛɠɛ ɠoozunɛ,
\q1 kɛlɛ faaɠaaɠalala zunui ɠa ɗa dee ʋɛlɛʋili.
\q1 
\v 21 Ɠimalalai ɠa ga koozunɛɛi naama nui ʋɛ, nii balagai faaɠaaɠai ma,
\q1 kɛlɛ zunui keleɠelegai, toɠa ɗa ziɛ sɔledai zu.
\q1 
\v 22 Faa mɔinmɔin ka ɗa ɠazaʋi, ti la zolooga tɔɔzei gaazaɠatalai ʋa,
\q1 kɛlɛ ti zu ɠa ɗa ɓɛtɛ, ni tɛnɛbo nua ta ná.
\q1 
\v 23 Koozunɛ vaa ʋe zunui ʋɛ, siɛgi zu é ɓɔɠɔ wooɠaaʋotegi veezu la,
\q1 ziilɛi faa ʋe, ni kpɔɛi a wona ga bo yeeɠɛɠala!
\q1 
\v 24 Keleɠele nui ɠa ɗa ziɛ ga pelei, nii é lɛɛzu geezuʋɛ zɛnvui ʋɔ bɛ,
\q1 naa ɠa kizosu gɔvɛalaazu ma, nii é buu ʋelei.
\q1 
\v 25 Ɠɔoɠɔ GALAGI ɠa ɗa waso nuiti ta-ʋɛlɛi ɠoloɠolo,
\q1 kɛlɛ toɠa ɗa ɓaa poanzai ɠɔligiti maazu.
\q1 
\v 26 Ɠɔoɠɔ GALAGI maaɲɛɛi ɠa ga kisiɛ ɲɔiti,
\q1 kɛlɛ kpɔɛ ʋagɔiti ka a ɗa va ti wu.
\q1 
\v 27 Zɔi é wɔinni ʋele-o-ʋele, é ɓɛtɛ, toɠa ɗa ná-pɛlɛyeɠei lɔ kpɔlɔi zu,
\q1 kɛlɛ zɔi é lobɛanii wɔinzeɠezu, naa zii zu ɠa ɠooza.
\q1 
\v 28 Telebo nui ɠa ɗa ɠigaiziɛ, aisa é ʋa gooɠaaʋotegi ve,
\q1 kɛlɛ faa ɲɔu ɠɛ nuiti ta ɗa faa ɲɔi vaza ga laaʋɛ.
\q1 
\v 29 Ɠɔoɠɔ GALAGI maaɠoozaʋɛ faa ɲɔu ɠɛ nuiti ba,
\q1 kɛlɛ toɠa ɗa woilo telebo nuiti ta-maanɛɛnɛ wooiti ma.
\q1 
\v 30 Nuɓɔɠɔlai ma ɠaazuʋɛ ɠa ɗa koozunɛɛi ve,
\q1 nui a woo niinɛ ʋagɔi mɛnina, toɠa ɗa iɲɔdɔ, é zeeli ma ɠaeiti ma.
\q1 
\v 31 Zɔi é woilosu tɛnɛ gooiti ma, ta ɓɔ ba etea ziɛi zu,
\q1 naa zeizu ɠa ɠima nuiti saama.
\q1 
\v 32 Zɔi é ɠɛlɛzu ga zelii mina lo ma, naa ɠa ɓɔɠɔ ʋɛlɛʋɛlɛsu,
\q1 kɛlɛ zɔi é woilosu tɛnɛ gooiti ma, naa ɠa ɠi pagɔiti sɔlɔɔ.
\q1 
\v 33 Ɠɔoɠɔ GALAGI ɠaazuluabai ɠa ɗa nu ɠala ga ɠimalai,
\q1 aisa nu ʋa lɛbiya zɔlɔɔ, kɛni è ɓɔɠɔmaayei pɛ.
\c 16
\q1 
\v 1 Nuiti ta ɗa ta-vaiti sei kpasu,
\q1 kɛlɛ Ɠɔoɠɔ GALAGI ɠa woo ɠaaɓelagi zea.
\q1 
\v 2 Ɛsɛ pɛ ka ɗa ɠisiɛ ga nii kpein é kɛɛzu pagɛ,
\q1 kɛlɛ Ɠɔoɠɔ GALAGI ɠa é de-ɠɛɛ vaiti ma ungi ma lukpɔi ɠaaleʋezu.
\q1 
\v 3 Ɗa-vaiti pɛ zɛ Ɠɔoɠɔ GALAGI yeezu,
\q1 ɗa-vaazeikpasuiti su ɠa ɓɛtɛ.
\q1 
\v 4 Ani kpein kpɛtɛ ungi ɠa ná, Ɠɔoɠɔ GALAGI ʋɛ,
\q1 anɛɛ faa ɲɔu ɠɛ nuiti, ta ná maanɔɠɔ voloi ʋɛ.
\q1 
\v 5 Waso nuiti maayo ge la Ɠɔoɠɔ GALAGI ʋɛ,
\q1 koleʋɛ ga ti zalalalai la yɛga.
\q1 
\v 6 Faaɠaaza golai ɠa ɗa gba ga nuɓɔɠɔlai ta gaamai,
\q1 Ɠɔoɠɔ GALAGI ɠaazuluabai ʋɔ, nu ɠa ɗa maaɠooza faa ɲɔi ʋa.
\q1 
\v 7 Nui ziɛ ʋelei a nɛɛna Ɠɔoɠɔ GALAGI ʋɛ,
\q1 toɠa ɗa ti yɔɠɔzuɓɛtɛ ta sili nuiti.
\q1 
\v 8 Fizɔgɛ ani goi nu sɔlɔɔsu, é zɔlɔɔ telebodai zu,
\q1 è ʋa sɔlɔɔ golai wo, yaavai zu.
\q1 
\v 9 Nui ɠa ɗa faazeikpasui ɠɛ,
\q1 kɛlɛ Ɠɔoɠɔ GALAGI ɠa lo kɔɠɔʋolu pɛ.
\q1 
\v 10 Masagi a ɠɛna ɓɔɛa, daawooi ɠa ga GALA gooi,
\q1 a ɠɛna tukpɔi ɠaaleʋea, daaʋɛ mina wooveleda ɠɛ.
\q1 
\v 11 Ɠɔoɠɔ GALAGI wɔinʋɛ ga kiloiti ti laazeeliai,
\q1 toɠa devezu, ʋelei kɔɠɔ ganiiti maanɛai ti ɠɛ la.
\q1 
\v 12 Faa ɲɔu ɠɛɛ vai maayoseɠeʋɛ masagiti bɛ,
\q1 mazɔlɔɔ telebodai ɠɛai ɠa a ɗa ná-zobogi maawui.
\q1 
\v 13 Masagi wɔinʋɛ ga naati, niiti ti-laawooiti sɔlegai,
\q1 naati nɛɛʋɛ bɛ, niiti ti ɓɔɛzu ga gaamai.
\q1 
\v 14 Siɛgi zu masagi yiiɠaawanazu la, ná-ziiɠulagi ɠɛɛʋɛ eɠɛ saa ɠeelai,
\q1 kɛlɛ ɠima nui ɠa zoo é gaaɓɛ.
\q1 
\v 15 Siɛgi zu masagi ɠaazulo pelei ʋasu da, naa ɠa é ga zɛnvui,
\q1 ná-nuɓɔɠɔlai ɠɛɛʋɛ eɠɛ foɠo ɠaaɓelazu lonaɓiingi.
\q1 
\v 16 Ɠimalai zɔlɔɔ fai vizɔgɛ zanu kitei ɠaalɛ ba vai ʋa,
\q1 keleɠelegi maaɓɔgai leʋegɛ walii ʋa!
\q1 
\v 17 Sɔle nuiti ta-ʋelei ɠa é ga, è ʋoluave faa ɲɔi ʋa,
\q1 zɔi é ɠaaɓaazu siɛ ʋelei ma, naa ɠa zɛnvui ɠizosu.
\q1 
\v 18 Wasogi ɠa a ɗa ʋa ga nu ɠoloɠolo fai,
\q1 kibɔɔlɔmai ɠa a ɗa ʋa ga tooi.
\q1 
\v 19 Fizɔgɛ nu ɓɔɠɔmaayei, wa ɓɔɠɔmaayei nuiti,
\q1 wo ʋa li ɓɔsu kɔɔzoganii ma, wa waso nuiti.
\q1 
\v 20 Zɔi é ɠidaazu kala gooiti bu,\f + \fr 16:20 \fq Zɔi é ɠidaazu kala gooiti bu\ft : Tati pelei taɠiligaa ɓalaa ka ga niiti: \fqa zɔi é ga kidafaawu nui \ft ɓaa \fqa zɔi é woilosu GALA daawooi ma\f* naa ɠa undaanɛɛi zɔlɔɔ,
\q1 undaanɛ nu ɠa ga naama nui, nii é ɠitosu Ɠɔoɠɔ GALAGI ʋa.
\q1 
\v 21 Zɔi é ga ɠima nui ziimaʋɛ, naa ɠa ta ɗa ɠɛ ma, keleɠele nui,
\q1 kpɔɛ nɛɛnɛgi ɠa a ɗa pilɛ sɔlɔɔ.
\q1 
\v 22 Ɠimalai ɠa ɗa zɛnvui ve naati zea, niiti ti ziɛzu la,
\q1 ɠimalala nuiti salai ɠa ga ɠimalalai.
\q1 
\v 23 Ni ɠimalai ɠa nui yiimaʋɛ, toɠa ɗa ɓɔɛ ga kidafaawui,
\q1 ná-yɛpɛi é bosu, naa ɠa ɗa faa ʋaa mɛni nuiti ma.
\q1 
\v 24 Kpɔɛ ʋagɔiti kɛɛʋɛ eɠɛ kɔin gulɔi,
\q1 nii nɛai zɛnvui ʋɛ, pagai ga kɛdɛ ganii kpusɛi vaa zu.
\q1 
\v 25 Ta ɠa ná, siɛ ʋelei zɔlegai gaazu,
\q1 kɛlɛ gaaɓelazuʋɛ ɠa ga saa ʋelei.
\q1 
\v 26 Pului ɠa ɗa ɠɛ ga botiɠɛ nui ná-kpɔbai,
\q1 daaʋɛ ɠa ɗa di botiɠɛ vai ma.
\q1 
\v 27 Nu ɲakai ɠa ɗa faa ɲɔi ɠɛʋele ɓɛtɛ,
\q1 daawooiti kɛɛʋɛ eɠɛ abulekai, é galai wosu.
\q1 
\v 28 Yaava nui ɠa ɗa kpɔɛiti teʋe,
\q1 zɔɠɔzuziɛ nui ɠa ɗa bɔɔla nuiti bali ma.
\q1 
\v 29 Suɲɔu nui ɠa ɗa seiɲɔɠɔi yaava,
\q1 é naa ʋilɛ pelei ʋa, nii ɲɔuɗai.
\q1 
\v 30 Zɔi é ɠaazuʋɛɛzu ma ga é ɠisiɛ yaava ɠɛɛ vaiti su,
\q1 é lakɔlɔgiti pu bu, naa ɓega ga faa ɲɔi ɠɛ.
\q1 
\v 31 Undeɠa ɠolegiti ta ga lɛbiya wɔɔlɔgi,
\q1 ta ɗa zɔlɔɔ sɔledai zu.
\q1 
\v 32 Zɔi zii la ɠula fala, naa vizɔgɛ kɔɔɠuluɓai ʋa,
\q1 nui é ɓɔɠɔ zosu, naa vizɔgɛ zɔi ʋa, é taa wolai zosu.
\q1 
\v 33 Ta ɗa kpakutoomai ɠɛ ga, ti ʋelela ʋele vaiti kwɛɛ,
\q1 kɛlɛ Ɠɔoɠɔ GALAGI ɠa a ɗa deve ɠaaɓelagi wo.
\c 17
\q1 
\v 1 Fizɔgɛ ɓulu ɓuɠa vɔɔ goi ɠɛ nu ya, è ɗa mi ziilɛigi zu,
\q1 nu ʋa ɠɛ pɛlɛi naa wu, daamiani pagɔi kpein ge ná, kɛlɛ sakpegi la ɓega ná.
\q1 
\v 2 Botiɠɛ nui é ga ɠima nui, naa ɠa ɗa zei doun zunui unda, nii é ɓaaɠulama vai ɠɛɛzu.
\q1 Toɠa nɔnɔ zɔlɔɔ poganii zu ɠɛɛɠɛleaiti saama.
\q1 
\v 3 Wali ɠaei ta zanugi, ti ɠaa ɠa ɗa wuun ga abui, ma nɔɠɔi ʋa ɠula ba,
\q1 ʋele ɠana Ɠɔoɠɔ GALAGI nuiti zii ʋoluɠulazu la.
\q1 
\v 4 Zɔi é faa ɲɔi ɠɛɛzu, toɠa ɗa woilo faa ɲɔu ɠɛ nuiti goo ma,
\q1 zɛɛ nui ɠa ɗa woilo, woo ɲɔu wo nɛgiti goo ma.
\q1 
\v 5 Ɗa ɲɛɛɠulana bala nui zu, Kpɛtɛ Nui ɠa è unfesu,
\q1 zɔi é ɠoozunɛɛzu seiɲɔɠɔi ná-maanɔɠɔ vai zu, salalalai la yɛga.
\q1 
\v 6 Nu wɔlɔiti ta-lɛbiya wɔɔlɔgi ɠa é ga ti-lounlointi,
\q1 lointi ma zaalai ɠa é ga ti zɔlɔɔ nuiti.
\q1 
\v 7 Nu woozuɠɛzɛi la zolooni faaɠaaɠalala nui ma,
\q1 zekana nɔ, zɛɛi la zolooni la kundiɠii ma.
\q1 
\v 8 Tanigaa ta ɗa ɠisiɛ ga, lobɛanii ɠa ɠɛ ti ʋɛ ga undaanɛɛi,
\q1 naa ɠa ta ɓɔɠɔ zɔlɔɔ su, ta-vai pɛ su.
\q1 
\v 9 Zɔi é pɔ é nɛɛ nuiti bɛ, naa ɠa ɗa tɔ koloɠologiti suvaayɛ, niiti ti ɠɛai la,
\q1 tɔɔzei ɗa ɠɛna suɠulaa kenein, naa ɠa ɗa è-wɔɔlaiti maaɠooza è ʋa.
\q1 
\v 10 Zeliloma ɠilagi ɠa ɗa faa ʋaa keleɠele nui ma,
\q1 é leʋe kpakɔ ɲɛ ungila (100) ba, ta faaɠaaɠalala nui loɠa la.
\q1 
\v 11 Nu ɲɔi ɠa ɗa buzeɠe daalɔɠɔma vai nɔ ɠaiziɛ,
\q1 keelai é la maawɔinɠa ɠɛa, naa ɠa ɗa leʋe daalɔɠɔma.
\q1 
\v 12 Nu ɠomi ga filɛ zua leei, nii ná-ziʋoiti kulaai zea,
\q1 naa vizɔgɛ, è ʋa ɠomi ga faaɠaaɠalala nui é ná-ɠimalalai zu.
\q1 
\v 13 Ni nu a faa ʋagɔi zalana ga faa ɲɔi,
\q1 maanɔɠɔi la zeɠea maala pɛ.
\q1 
\v 14 Sakpegi lɔɔzei, naa ɠa é ga è ziɛi luɠɔlosuʋɛ laavie,
\q1 zeɠe ná, aisa kpɔɛi ʋa leʋe.
\q1 
\v 15 Nii é losu faa ɲɔu ɠɛ nui ʋolu, ta zɔi é telebo nui ʋeelalazu,
\q1 ti felegɔ pɛ ti maayoseɠeʋɛ Ɠɔoɠɔ GALAGI ʋɛ.
\q1 
\v 16 Walii a ɠɛna ɠimalala nui ya, leeni ɠa a kɛ la?
\q1 Toɠa zoo é ɠimalai ɠeya la ɓaa?
\q1 Kɛlɛ ɠi pagɔ la zea.
\q1 
\v 17 Bɔɔla nui ɠa ɗa nɛɛbɛi ɠɛ yeenɔpɛ.
\q1 Ɠɛɛɠɛloin ɠa ɗa kpɔbai ɠɛ, faaɓaagi a ʋaana.\f + \fr 17:17 \fq Ɠɛɛɠɛloin ɠa ɗa kpɔbai ɠɛ, faaɓaagi a ʋaana\ft : Tati pelei taɠili ɓalaa ka ga nii: \fqa Ɠɛɛɠɛloin ta ɠa ɗa zɔlɔɔ faaɓaagi ma voloi vaa zu\f*
\q1 
\v 18 Kɛni nui balagai ɠigi ma, naa ɠa a ɗa minazeɠe,
\q1 é ɓɔɠɔ ɠɛ ga zeelagai, nu ɠiligi ná-kuyei zala vai zu.
\q1 
\v 19 Nui kpɔɛba vai nɛai bɛ, tɔ koloɠologi nɛɛʋɛ bɛ.
\q1 Zɔi kibɔɔlɔmai su, naa wɔinʋɛ ga é ɓɔɠɔ ɠoloɠolo.
\q1 
\v 20 Nui yaavai ziimaʋɛ, é la undaanɛ zɔlɔɔga,
\q1 zɔi é ga nɛ felegi, naa ɠa lɔ nimizai zu.
\q1 
\v 21 Zɔi é faaɠaaɠalala loun zunui zɔlɔɔsu, ziizoolɛi ɠa ɗa ɠɛ ma.
\q1 Ɠimalala loun zunui, kɛɛɠɛ ɠoozu la ga nɛ.
\q1 
\v 22 Ziilaai ɠa ga kɛdɛya zaɓu wola,
\q1 kɛlɛ kiteʋei ɠa ɗa nui zuɲɛgi ɓe.
\q1 
\v 23 Yaava nui ɠa ɗa lobɛanii zo, ti dɔɔɠu seɠei wu,
\q1 nii a kɛ é tukpɔi maaʋe.
\q1 
\v 24 Ɠimalai maaɓuɠaʋɛ keleɠele nui ʋa,
\q1 kɛlɛ ɠimalala nui ɠaazuʋɛ ɠa liizu faiti pɔ, niiti é la zooga é ʋa ti zɔlɔɔ.
\q1 
\v 25 Faaɠaaɠalala loun zunui kɛɛɠɛ ɠa ɗa ɠɛ ziiɓɔlɔi zu,
\q1 é ɠɛ ga ziiɠoloɠologi naa ʋɛ, nii é sɔlɔɔga.
\q1 
\v 26 É la zolooni, nu ʋa fuun gani ɠula sɔbalala nui ya,
\q1 toɠa ga telebotala vaa, è ʋa unfema nui loɠa.
\q1 
\v 27 Nui nii é ziaa faa mɔinmɔin su, naa ɠa ɗa dama, é mina ɓɔɛ ga gola,
\q1 keleɠele nui ɠa ɗa yeeɠɛɠalai zeɠe, é ɗa ɠisiɛ.
\q1 
\v 28 Ɠimalala nui ɓalaa a ɗa leve ga ɠima nu, ni toɠa zoo maaɠɛsu kpɔ.
\q1 Zɔi é laaɠulusu, naa ɠa é ga zunui nii keleɠelegai.
\c 18
\q1 
\v 1 Nui nii kpalai ga ɠakalaʋɛ nɔ, toɠa ɗa maaɠooza zɔiti ba,
\q1 toɠa ɗa yiiɠaawana, ɠima vai kpein daalɔɠɔma.
\q1 
\v 2 Ɠimalala nui yiima vaa la ga faaɠaaɠaa vai,
\q1 kɛni ná-kisiɛiti sulɛ vai.
\q1 
\v 3 Siɛgi zu nu ɲɔi ʋaazu la, wɔinzeɠemai ɠa ɗa ʋilɛ polu, ti ʋa.
\q1 Unfegi ɠa ɗa ʋilɛ ɓaaɠulamai ʋolu.
\q1 
\v 4 Nui ɓɔɛ wooiti ti da, ta ga ziɛi buuzeiɗai gola,
\q1 ɠimalai ma ɗɛungi ɠa ga kɔtuɗɛi, é zulusu.
\q1 
\v 5 Maa la nɛɛni, nu ʋa lo faa ɲɔu ɠɛ nui ʋolu,
\q1 è ʋa telebo nui ʋeelala ná-gaamai zu.
\q1 
\v 6 Ɠimalala nui ná-kpɔɛiti ta ɗa sakpegi loo,
\q1 daawooi ɠa ɗa doɠai maaloli ma.
\q1 
\v 7 Ɠimalala nui a ɠɛna ɓɔɛa, toɠa ɗa ɓɔɠɔ ɠoloɠolo fai ɠɛ,
\q1 kpɔɠɔ wooiti ta ɗa ɠɛ ga baliiti, é ɠɔ ga tiye.
\q1 
\v 8 Zɔɠɔzuziɛ nui ná-kpɔɛiti kɛɛʋɛ eɠɛ ani ɲɛmigiti,
\q1 ta ɗa yei ti zeeli nu ɠoozuʋɛ.
\q1 
\v 9 Zɔi é ná-botiɠɛ vai maaɠonɔɔsu,
\q1 ta ga ani ɠila, ta zɔi é koloɠolosu.
\q1 
\v 10 Ɠɔoɠɔ GALAGI ɠa ga pɛlɛ ɠaaɠoozagi,
\q1 telebo nui ɠa ɗa ɓizɛ, é li ná, é ɠɛ ziilɛigi zu.
\q1 
\v 11 Kpɛtɛ nui yeaɠɔligi ɠa bɛ ga taa wolai siɠigi ma,
\q1 toɠa ɗa ɠigaiziɛ ga toɠa ga siɠigi, nii a zoo tɔun makɛsu.
\q1 
\v 12 Siɛgi zu wasogi nui yiimaʋɛ laavesu da, koloɠolo geei zeelia.
\q1 Aisa è ʋa unfemai zɔlɔɔ, kɛni è zoo ɓɔɠɔmaayeizu.
\q1 
\v 13 Zɔi é gooɠaaʋotegi veezu, aisa é ʋa woilo kpɔɛi ma, é wosu,
\q1 toɠa ná-ɠimalalai ɠula kɛlɛma, é zɔngɔ zɛlɛ ɓɔɠɔ ʋa.
\q1 
\v 14 Kisiɛ ʋagɔi ɠa zobo fe nui ʋɛ, é ziɛ seeɓɛi wu,
\q1 kɛlɛ kisiɛ ʋagɔi a valibona ga iɲɔteʋei, ɓɛ ɠa a pu su ʋolu?
\q1 
\v 15 Keleɠele nui wɔinʋɛ ga é faaɠwɛgi zɔlɔɔ,
\q1 ɠima nui ɠa ɗa ɠaaɓa ga é woilo kpɔɛiti ma, ta nu ɠala.
\q1 
\v 16 Faanɛɛi ɠa ɗa peleiti daalao,
\q1 é nu laazeeli nu wolaiti ma.
\q1 
\v 17 Nu mɔungi é ɓaazaɠazu, toɠa ɗa ɠɛ eɠɛ toɠa gaamai zea,
\q1 eyɛsu tukpɔɲɔɠɔi ʋa é gooiti sakpe.
\q1 
\v 18 Kpakutoomai ɠa ɗa sakpegi ɓe,
\q1 toɠa ɗa ɓalaa nu wolaiti seɠe unga.
\q1 
\v 19 Nu zeeli vai ɓaaʋɛ ɠɛɛɠɛloin ma, nii maawanaai, é leʋe taa wolai ʋa, nii siɠigi ma.
\q1 Kpɔɛi ɠɛɛʋɛ eɠɛ siɠigi laaʋɛ ma zɔɠɔgiti.
\q1 
\v 20 Ɛsɛ ka ɗa daawooiti ma lɔnɔgiti kɔɠɔ, é yiɠo ga tiye,
\q1 toɠa yiɠo ga niiti, dakɔlɔgiti ti ti veai.
\q1 
\v 21 Saai ta zɛnvui ta zoo zɔlɔɔsu nui nɛgi zaɓui zu.
\q1 Zɔi kpɔɛzuɠulai nɛai bɛ, kɛni é va suɓolo ɠɔmɔ fai wu.
\q1 
\v 22 Nui a anzai zɔlɔɔna, é undaanɛɛi zɔlɔɔga,
\q1 faanɛɛ ɠa naa, é sɔlɔɔgai Ɠɔoɠɔ GALAGI ya.
\q1 
\v 23 Bala nui ɠa ɗa ɓɔɛ ga maanɛɛnɛ wooi,
\q1 kpɛtɛ nui gooɠaaʋotegi wo ga zeeɠaaɓaai.
\q1 
\v 24 Nui nii bɔɔlai mɔinɗai, ta polu kpɔlɔ vai ma,
\q1 kɛlɛ nu wɔɔla ɠitei ɠa ɗa ɠili è ʋa, é leʋe è-ɠɛɛloin ʋa.
\c 19
\q1 
\v 1 Fizɔgɛ nu ɠɛ ga bala nu, è eteai ziɛ ladalai zu,
\q1 è ʋa ɠɛ ga faaɠaaɠalala nui, nii zɛai.
\q1 
\v 2 É la vizɔni nu nɔpɛ ma, é ʋa ʋala faaɠwɛgi ma,
\q1 zɔi é ɠɔɠɔzuvilɛzu, toɠa ɗa faaɠaazagi ɠɛ.
\q1 
\v 3 Nui ná-ɠimalalai ɠa ɗa ná-pelei ɠaaʋala ba,
\q1 é ɗa yiiɠaawana Ɠɔoɠɔ GALAGI ma niina.
\q1 
\v 4 Naavoloi ɠa ɗa nui wɔɔlai mɔin gola,
\q1 kɛlɛ bala nui bɔɔlai ɠa ɗa ɠɛlɛ ba.
\q1 
\v 5 Zɛɛ zeelei zalalalai la yɛga,
\q1 doɠai la ʋoolaa naa ʋa, nii é zɛɛi vazasu.
\q1 
\v 6 Nu mɔinmɔin ka ɗa sɔɓelama nui maamusɛ gaazu,
\q1 ɛsɛ ka pɔ é ɠɛ ga naa bɔɔlai, nii é faanɛɛi ɠɛɛzu.
\q1 
\v 7 Bala nui la nɛɛni kɛɛɠɛlointi bɛ,
\q1 ɓaa mu ná-siɛpoluiti, naati ta ɗa maaɠooza ba.
\q1 Siɛgi zu é wɔinni la ga é ɓɔɛ ti ʋɔ, ti la mɔ koba.
\q1 
\v 8 È kigaiziɛi maaɠɔli, ɗa naa ɠɛɛzu ɗa ɓɔɠɔi ɗa-undaanɛɛi vaa ma,
\q1 ɗa ɠilina ɠimalai ʋa, ɗa undaanɛɛi zɔlɔɔ.
\q1 
\v 9 Zɛɛ zeelei zalalalai la yɛga,
\q1 zɔi é zɛɛi vazasu, naa ɠa ɓɔɠɔ loozu ya.
\q1 
\v 10 É la vizɔni ɠimalala nui ma, é ʋa eteai ziɛ gaanɛ zu,
\q1 sɔnaga duɔi ʋa ɠɛ ga kundiɠiiti deve nu.
\q1 
\v 11 Nui ná-ɠimalai ɠa a ɗa vɔni da ná-ziiɠulagi ma,
\q1 toɠa bɛ ga lɛbiya, é ná-faawanamaiti suvaayɛ.
\q1 
\v 12 Masagi ná-ziiɠulagi maayikiʋɛ eɠɛ zalai zikɔ wooi,
\q1 kɛlɛ ná-faanɛɛi ɠɛɛʋɛ eɠɛ nɔɗagi, nii é tufai ɠa.
\q1 
\v 13 Faaɠaaɠalala loun zunui ɠa ga kɛɛɠɛ ná-nimizai.
\q1 Kpɔɛleʋe anzanui ɠɛɛʋɛ eɠɛ ziɛ goi, nii é ʋilɛsu peinpein maa la leʋezu.
\q1 
\v 14 Nu ɠa zoo è pɛlɛi ta anii kpein sɔlɔɔ ga pogani è-ɠɛɛni zea,
\q1 kɛlɛ Ɠɔoɠɔ GALAGI ɠila kpe nɔ ɠa a zoo, é ɠima anzanui ve nu ya.
\q1 
\v 15 Dɔɔʋɛi ɠa ɗa nui wui ɓɔɠɔ ma,
\q1 zɔi ɲakaai, pului ɠa so.
\q1 
\v 16 Nii é devei zosu, naa ɠa ɓaazu zɛnvui maazu,
\q1 zɔi é la ɠaaɓaazu siɛ ʋelei ma, naa ɠa za.
\q1 
\v 17 Zɔi a bala nui maawɔinɠa, lɔdɔ kana é feezu Ɠɔoɠɔ GALAGI ya,
\q1 naa ɠa naa ve zea, nii maanɛai ga é sɔlɔɔ.
\q1 
\v 18 È-loun zunui maaɠolo gelegele, siɛgi zu kitogi ná la dɛ,\f + \fr 19:18 \fq siɛgi zu kitogi ná la dɛ\ft : Tati pelei taɠili ɓalaa ka ga nii: \fqa mazɔlɔɔ kito ka dɛ ná\f*
\q1 kɛlɛ mina wɔin ga paa vaa.
\q1 
\v 19 Nui ziiɠulazu, kɛni ti ani ɠula zea.
\q1 Ni ti la ani ɠulani zea, ti zobo fea bɛ ga é tɔɔzei ʋolu.\f + \fr 19:19 \fq ti zobo fea bɛ ga é tɔɔzei ʋolu\ft : Tati pelei taɠiligaa ɓalaa ka ga niiti: \fqa ta tɔɔzei ʋolu \ft ɓaa \fqa ta ta ɓɔ baa vai ʋa\f*
\q1 
\v 20 Woilo tɛnɛ gooiti ma, va zelilomai wu,
\q1 gaaɓelasu, ɗa ɠɛ ga ɠima nu.
\q1 
\v 21 Nui ɠa ɗa faa mɔinmɔin kɛʋele ɓɛtɛ ná-kisiɛi zu,
\q1 kɛlɛ Ɠɔoɠɔ GALAGI ná-devei ɠa daa a ɗa zeeli.
\q1 
\v 22 Nii nuɓusɛi pɔ nui ná-fai zu, naa ɠa é ga wooɠɛɠiladai,
\q1 kɛlɛ tama, bala nui vizɔgɛ wooʋalada nui ʋa.
\q1 
\v 23 Ɠɔoɠɔ GALAGI ɠaazuluabai ɠa ɗa ɓɔ nu ʋa, è zɛnvui wo,
\q1 anii pɛ ge ɠɛ è ya, è kpidiiti siɛ, maanɔɠɔ la zeelia è ma.
\q1 
\v 24 Ɲaka nui ɠa ɗa yeelɔ daami aniɲakai zu,
\q1 kɛlɛ dɔɔ vai daaʋɛ, naa ɓaa.
\q1 
\v 25 Siɛgi zu ti waso nui loɠazu la, zɔi é la dɛ faa mɔinmɔin kwɛni, naa ɠa ɗa ɠi sɔlɔɔ,
\q1 zelii lo keleɠele nui ma, toɠa faaɠwɛgi zɔlɔɔ.
\q1 
\v 26 Zɔi é kɛɛɠɛ zopele ɲɔuzu, é dee ɓɛ,
\q1 naa ɠa ga doun zunui é unfe fai ɠɛɛzu, ta ɓaaɠulama vai.
\q1 
\v 27 Dòun zunu, ɗa ɓena woilosu kala gooi ma,
\q1 ɗa ʋoluave faaɠwɛ kpɔɛiti ba.
\q1 
\v 28 Zeele ɲɔi ɠa ɗa tukpɔɠaaleʋe vai ɠaaʋala ba,
\q1 faa ɲɔu ɠɛ nuiti daaʋɛ ɠa ɗa telebotalai mi.
\q1 
\v 29 Tukpɔi ɠɛʋele ɓɛtɛʋɛ ga é loo ɲɛɛɠulasu nuiti ma,
\q1 doɠa ɓakɔi ɠa ga faaɠaaɠalala nuiti polu zaamaʋɛ nɔnɔ.
\c 20
\q1 
\v 1 Dɔɔi ɠa ga ɲɛɛɠulasu anii, kpɔɔle anii é nu ɠaazulatisu, toɠa ga zɔɔlɛma anii,
\q1 nu-o-nu é ɓɔɠɔ loozu ya su, naa la zooga é ʋa ɠɛ ga ɠima nu.
\q1 
\v 2 Masagi a yiiɠaawanana, maa ɠa ɗa yiki eɠɛ zalai zikɔ wooi,
\q1 ɗɛi ɗa masagi ná-ziiɠaawanai ɠaazulɛɛna, è-yɛnvui ɠa faaɓaagi laawu.
\q1 
\v 3 Nu maaɠooza sakpegi ʋa, naa ɠa ga lɛbiya vaa.
\q1 Kɛni ɠimalala nui ɠa a ɗa woizuɓɔlɔ, é lɔ su.
\q1 
\v 4 Dɔɔʋɛ nui la ɠɛ kɛɛni, é ʋa wozai woli ma yeeɠɛɠalai,
\q1 ani la ɠɛa ná, nii a teʋe molo leʋei zu.
\q1 
\v 5 Kisiɛiti ti nuɓusɛi yiimaʋɛ, ta ga ziɛi buuzeiɗai,
\q1 keleɠele nui ɠa soogai ta zaɠazu.
\q1 
\v 6 Nu mɔinmɔin ka ɗa ná-wooɠɛɠiladai zulɛ,
\q1 kɛlɛ mini ɠa sɔɓelama nui a ɠa ná?
\q1 
\v 7 Telebo nui ɠa ziɛzu ná-sɔledai zu,
\q1 undaanɛ vaa wola ɠa naa, ná-dointi bɛ, a zeɠena naa.
\q1 
\v 8 Siɛgi zu masagi zeizu la tukpɔɠaaleʋezuʋɛ,
\q1 toɠa ɗa faa ɲɔi yɔɠɔzuɠa, ga wɛlɛ laa ɠilagi nɔ.
\q1 
\v 9 Ɓɛ ɠa a zoo é ɠɛ ma: «Zìimaʋɛ ɠoleʋɛ na,
\q1 gè ɲadega koto la mɔ bà»?
\q1 
\v 10 Nu kiloi ta kɔɠɔ ganii ma zii felegɔiti seɠe, é ʋa nuiti yaava,
\q1 naa ɠa ga Ɠɔoɠɔ GALAGI maaɲɛɛi ba vaa.
\q1 
\v 11 Zunu loungoi ɠa ɗa ɓɔɠɔ ɠɛʋele lɛ ga ná-kɛɛwotiiti,
\q1 nu ka ni sɔgi ɠa ʋa, é zɔle.
\q1 
\v 12 Nu woiyeɠei é faa mɛnisu, nu ɠaazuʋɛ é wozaɠaazu,
\q1 Ɠɔoɠɔ GALAGI ɠa é ti ɠilagilagi pɛ kpɛtɛa.
\q1 
\v 13 Mina ɲiimɛnii wola nɛɛ ʋɛ, è mina gaaɓela baladai zu.
\q1 Wuzeɠe ga sobuzobui, ɗa daamiani sɔlɔɔ, è ɓɔlɔ ba.
\q1 
\v 14 Ani ɠeya nui ɠa ɗa ɠɛ ma: «É la ʋani! É la ʋani!»
\q1 Kɛlɛ a zeɠena ná, é ɓɔɠɔ maamusɛ ga anii naa zɔlɔɔ fai.
\q1 
\v 15 Zanugi ma vaa la ɓaani, kɔbu ani ʋagɔi mɔinʋɛ,
\q1 kɛlɛ anii nii fizɔgai ti pɛ ba, naa ɠa é ga, nu laawooi é faaɠwɛgi veezu.
\q1 
\v 16 Ni nui ta a ɓɔɠɔ ɠɛna ga zeelaga è ʋɔ bɛ, é ʋilɛ nui ta ná-kuye vaa ʋa, nii è la kwɛɛ,
\q1 ná-seɠei zeɠe ga kpɔunmai, nui naa ná-faa zu, nii è la kwɛɛ.
\q1 
\v 17 Daamianigi unmaai, mɔunpa toɠa ɗa nɛɛ,
\q1 kɛlɛ naa ʋolu, toɠa ɗa ɠɛ ga kɔtui, é nui laaʋɛ laave.
\q1 
\v 18 Faiti ti ɠazaʋisu, ti laa ɠa ɗa zeeli ga tɛnɛ pagɔiti maaʋele.
\q1 Ɗa ɠɛna lia kɔɔmaʋɛ, gaalugi wo, è faiti kpɛtɛ.
\q1 
\v 19 Zɔi é fama ɓɔɛi vazasu, naa ɠa dɔɔɠuzu vaiti kulazu.
\q1 À mina ɓɔ faa ma, wa nuiti ti kpɔɛzuɠula ɲakaiti bosu.
\q1 
\v 20 Zɔi a kɛɛɠɛ voovo ta dee,
\q1 zii ɠa loo, eɠɛ lanboi é zaazu kpidi ɓɔii zu.
\q1 
\v 21 Poganii sɔlɔɔgai ga gaazuvilɛi mɔunpagi zu,
\q1 tuya la ɠɛa ma naa ʋolu.
\q1 
\v 22 Mina ɠɛ ma: «Nà nɔ̀nɔ ʋotokula!»
\q1 Ɠito Ɠɔoɠɔ GALAGI ʋa, toɠa è ɠizo.
\q1 
\v 23 Ɠɔoɠɔ GALAGI maaɲɛɛ ɠa ga kɔɠɔ ganii daa la zeelini,
\q1 é la vaa zɛɛ ɠiloi wu.
\q1 
\v 24 Ɠɔoɠɔ GALAGI ɠa é losu nui luɠɔ ná-eteai zu.
\q1 Nuɓusɛi ɠa zoo ɠale é pelei ɠwɛɛ, nii é ziɛzu la?
\q1 
\v 25 Polu la ʋani nui ma, è ʋa ani ve Ɠɔoɠɔ GALAGI ʋɛ ga gaazuvilɛi,
\q1 ɓaa è minazeɠe pɛ, è ʋa leɠa ɠigaiziɛ su.
\q1 
\v 26 Ɠima masagi ɠa ɗa faa ɲɔu ɠɛ nuiti so,
\q1 é faa la ti ma, maawɔinɠa la su.
\q1 
\v 27 Nui ná-faaɠaaɠaa ɠigi ɠa ga lanboi, nii Ɠɔoɠɔ GALAGI feai,
\q1 tɔ ɠa é nui yiimaʋɛ vaiti pɛ fɛɠɛlɛfɛɠɛlɛsu.
\q1 
\v 28 Nuɓɔɠɔlai ta wooɠɛɠiladai ɠa a ɗa masagi makɛ,
\q1 ná-nuɓɔɠɔlai ɠa é ná-masa kpɔkpɔgi zei ʋele ɓɛtɛzu la.
\q1 
\v 29 Zɛbɛi ɠa é ga buzeɠe niinɛgiti ta-ʋadai,
\q1 kɛwola wɔlɔiti ta-unfemai ɠa é ga undeɠa ɠolegi.
\q1 
\v 30 Maawana ʋalai ɠa ga faa ɲɔi ɠɛdɛ salei,
\q1 zekana é la, doɠai ɠa ɗa zeeli kisiɛiti ma, niiti ti lɔɔɠuai.
\c 21
\q1 
\v 1 Masagi yii ɠa Ɠɔoɠɔ GALAGI yeezu, eɠɛ ziɛi é yeizu,
\q1 é ɗa lii la, ʋɛ nɔpɛ ná nɛai bɛ.
\q1 
\v 2 Ɛsɛ ka ɗa ɠisiɛ, ga nii kpein é kɛɛzu pagɛ,
\q1 kɛlɛ Ɠɔoɠɔ GALAGI ɠa é de-ɠɛɛ vaiti ma ungi ma lukpɔi ɠaaleʋezu.
\q1 
\v 3 Nui a telebo fai ta sɔle fai ɠɛɛna,
\q1 naa ɠa fizɔgai Ɠɔoɠɔ GALAGI ɠaazu, é leʋe zalaɠaiti ba.
\q1 
\v 4 Gaazulɛɛi ta waso zɛnvui,
\q1 faa ɲɔu ɠɛ nuiti ta-eteai kpein ka ga kotoi.
\q1 
\v 5 Zɔi é yeemaleʋebosu, é faazeikpasuiti kɛ, naa zɔlɔɔgi zu ɠa wɔɔlɔ,
\q1 kɛlɛ zɔi é faiti kɛɛzu ga gaazuɓadii, naa ɠa li é lɔ pului zu.
\q1 
\v 6 Niiti ti ta-ɓɛtɛi zɔlɔɔsu zɛɛi zu,
\q1 ta ga faaɠaaɠalala nuiti ti ɓizɛzu, ti lɔ saai zu.
\q1 
\v 7 Faa ɲɔu ɠɛ nuiti ta-zuɲɔi ɠa ɗa li ga tiye,
\q1 mazɔlɔɔ ti la vaani bu, ti ʋa ladalai ɠɛ.
\q1 
\v 8 Ɲamaba nuiti ta ɗa ʋilɛ pele ɠɔɔngugi ʋolu,
\q1 kɛlɛ lada nuiti siɛ ʋelei zɔlegɛ.
\q1 
\v 9 Fizɔgɛ nu zei fiilɛ zosuʋɛ sokogi zu pɛlɛ ɠɔmaʋɛ,
\q1 wo ʋa li ɓɔsu zeizu ma, wa kpɔɛleʋe anzanui.
\q1 
\v 10 Faa ɲɔu ɠɛ nui yiimai ɠa ga faa ɲɔu ɠɛɛ vai,
\q1 anɛɛ bɔɔlai ɓɔɠɔi, é la loga maazu.
\q1 
\v 11 Maaɠolo ɓakɔi a zeelina waso nui ma, zɔi é la dɛ faa mɔinmɔin kwɛɛ, naa ɓalaa ɠa ɗa ɠi sɔlɔɔ,
\q1 ɗa ɠima nui ɠalana, toɠa ɗa faaɠwɛgi zɔlɔɔ.
\q1 
\v 12 Telebo nui\f + \fr 21:12 \fq telebo nui\ft : Tati pelei taɠili ɓalaa ka ga nii: \fqa telebo GALAGI\f* ɠa ɗa ɠida naa kpein bu, nii é ɠɛɛzu faa ɲɔu ɠɛ nuiti ta-ʋɛlɛi wu,
\q1 siɛgi zu ti lɔɔzu la maanɔɠɔi zu.
\q1 
\v 13 Nui nii é la woilosu maawɔin nui ná-kpee wooi ma,
\q1 tɔ ɓɔɠɔi ɠa kpeei loo, é la gooɠaaʋote sɔlɔɔga.
\q1 
\v 14 Faanɛɛi é ɠɛɛzu dɔɔɠuzu, naa ɠa ɗa ziiɠaawanai ɠaayei.
\q1 Lobɛanii é leʋesu dɔɔɠuzu, naa ɠa ɗa ziiɠula golai ɠaayei.
\q1 
\v 15 Toɠa ga koozunɛ vaa telebo nui ʋɛ, sɔle fai a ɠɛna ɠɛa,
\q1 kɛlɛ naa ɠa ga nimiza vai faa ɲɔu ɠɛ nui ʋɛ.
\q1 
\v 16 Nui nii é zeɠezu ɠi pagɔi ma ʋelei ʋa,
\q1 ná-dooɠo bosuʋɛ ɠa ɠɛɛzu ga gɔvɛiti ta-maaɓɔgi zu.
\q1 
\v 17 Zɔi ɓɔɠɔyiimai nɛai bɛ, toɠa kpalai ɠwɛɛ,
\q1 zɔi é ɓɔɠɔ veai dɔɔi ya, ta etea ɠaazuɠulapɔi, é la ɓɛtɛa eyɛsu pɛ.
\q1 
\v 18 Faa ɲɔu ɠɛ nui ɠa é ga telebo nui unmɔɔ ganii,
\q1 yaava nui ɠɛ ga sɔle nuiti tɔnɔi.
\q1 
\v 19 Fizɔgɛ nu zei zooi ta zu naa vɔai,
\q1 è mina zei kpɔɛleʋe anzanui ɠoba, ziiɠaawanaai.
\q1 
\v 20 Ɠima nui zeizuʋɛ, nu ɠa ɗa ani naavolo ʋagɔiti ka ná, ta gulɔ makɛgaiti,
\q1 faaɠaaɠalala nui ɠa ɗa naati suvaza, niiti ti zea.
\q1 
\v 21 Zɔi é ɠaaɓaazu, é ɠɛ ga telebo nu, ta wooɠɛɠila nu, sii zu ɠa ɠooza,
\q1 toɠa leve ga telebo nu, é unfemai zɔlɔɔ.
\q1 
\v 22 Ɠima nui ɠa laalɛɛna taa wolai wu, nii salaʋusu ɠɛzɛɠɛzɛgiti ti maaɓɛɛzu,
\q1 é siɠigi loka, nii taai ɠitogai ba.
\q1 
\v 23 Zɔi é ɓaazu daaʋɛ maazu ta nɛgi,
\q1 naa ɠa ɓɔɠɔ ɠizo kidaaʋili faa mɔinmɔin ma.
\q1 
\v 24 Ɲɛɛɠulasu nui ɠa ga waso nui, ta gaazulɛɛ nui,
\q1 nii waso dateʋegai diizu faiti kɛɛ vai ma.
\q1 
\v 25 Ɲaka nui ɠa ɗa za, tɔɔzei ziima vaiti daa la zeelizu,
\q1 mazɔlɔɔ é la pɔ é ʋa yeeʋɛɛ faa nɔpɛ ba.
\q1 
\v 26 Yeenɔpɛ, toɠa gaazuɠulapɔi laawu,
\q1 kɛlɛ telebo nui ɠa ɗa ti pɛ kwɛɛ, é la ta makɛga ɓɔɠɔ ʋɛ.
\q1 
\v 27 Faa ɲɔu ɠɛ nuiti ta-zalaɠai ɠa ga ziimaziɛ ganii,
\q1 sɔnaga ta ʋaana kulazu ga kisiɛ ɲɔi.
\q1 
\v 28 Zɛɛ zeelei undaa ɠa ʋili,
\q1 kɛlɛ zɔi é gaamai wosu, nii é mɛnini, zobo ka naa ʋɛ siɛnɔpɛ su é ɓɔɛ.
\q1 
\v 29 Faa ɲɔu ɠɛ nui ɠa ɗa ɓɔɠɔ ɠula ga lada nu,
\q1 kɛlɛ sɔle nui ɠa ɗa ɠaaɓa siɛ ʋelei ma.
\q1 
\v 30 Nuɓusɛi ná-ɠimalai, ta ná-keleɠelegi ta ná-faazeikpasui,
\q1 naati tanɔpɛ ge la zooga, é ʋa li Ɠɔoɠɔ GALAGI yiimai laalɔɠɔma.
\q1 
\v 31 Ta ɗa sooiti maaɠili kɔɔɠɔ voloi laalɔɠɔma,
\q1 kɛlɛ pilɛ sɔlɔɔ fai ɠa Ɠɔoɠɔ GALAGI yeezu.
\c 22
\q1 
\v 1 Tɔɠɔɠulagi vizɔgɛ naavolo wolaiti ba,
\q1 è unfe zɔiti ma, naa vizɔgɛ, é leʋe walii ʋa ta zanugi.
\q1 
\v 2 Kpɛtɛ nui ta bala nui ti ɓɔgɛ faa ɠila ma:
\q1 Ɠɔoɠɔ GALAGI ɠa é ti felegɔ pɛ kpɛtɛa.
\q1 
\v 3 Ɠima nui ɠa ɗa maanɔɠɔi ɠa é ʋaazu, é lɛkpɛ tuɠɔ,
\q1 kɛlɛ nui é la dɛ faa mɔinmɔin kwɛɛ, naa ɠa ɗa ziɛ ná ɠobaʋɛ, é ma ɓɔlɔi zɔlɔɔ.
\q1 
\v 4 Ɓɔɠɔmaayeii ta Ɠɔoɠɔ GALAGI ɠaazuluabai ma ɠulanumai ɠa ga,
\q1 kulagaanɛɛzui, ta unfemai, ta sii zuɠoozai.
\q1 
\v 5 Yaava ʋelei, ɠaingiti ka ti su, ta baliiti, maanɛai nu maaɠooza ba,
\q1 ni è-yɛnvui wɔin ɠa è ma.
\q1 
\v 6 Doungoi ɠala ga pelei maanɛai é ziɛ la,\f + \fr 22:6 \fq Doungoi ɠala ga pelei maanɛai é ziɛ la\ft : Tati pelei taɠiligaa ɓalaa ka ga niiti: \fqa doungoi maaɠolo ga siɛ ʋelei \ft ɓaa \fqa doungoi maaɠolo ná-eteai lɔɔzei ziɛgi zu\f*
\q1 anɛɛ siɛgi zu é wɔlɔzaɠasu da, é la zeɠea ba.
\q1 
\v 7 Kpɛtɛ nui ɠa ɗa zei, bala nui unda.
\q1 Kuye zeɠe nui ɠa ga duɔi, kuye ʋɛɛ nui ya.
\q1 
\v 8 Zɔi a telebotalai vaza, toɠa teʋe ga maanɔɠɔi,
\q1 ná-zobogi ɠa ɠoloɠolo, nii é toomai ɠɛɛzu la.
\q1 
\v 9 Nui é nuɓɔɠɔlai ɠɛɛzu seiɲɔɠɔiti bɛ, toɠa tuyai zɔlɔɔ,
\q1 tɔɔzei ta ɓɔsu ná-daamianigi ma ta bala nui.
\q1 
\v 10 Ɲɛɛɠulasu nui ɓɛ, kpɔɛi ɠa ɓe,
\q1 goomaaɠaaliiti ta poomugiti ta ɓe.
\q1 
\v 11 Ni nu wɔinʋɛ é ɠɛ ga masagi nɛɛɲɔɠɔi,
\q1 kɛni kisiɛ ʋagɔiti ti nɛɛ bɛ, ta nɛɛnɛ kpɔɛiti.
\q1 
\v 12 Ɠɔoɠɔ GALAGI ɠa wɛlɛzu faaɠwɛgi ma,
\q1 kɛlɛ toɠa ɗa yaava nui ná-kisiɛiti supu.
\q1 
\v 13 Ɲaka nui ɠa ɗa ɠɛ ma: «Zalai ɠa loni eteaʋɛ,
\q1 é mina lia bàlizu ga pelei zu taa zaamaʋɛ!»
\q1 
\v 14 Wɛɛnziɛ anzanuiti daaʋɛ ɠa ga zeɠezaɠai suɠoozaai,
\q1 nui Ɠɔoɠɔ GALAGI yiiɠaawanazu ma, naa ɠa loo su.
\q1 
\v 15 Ɠimalalai ɠiliʋɛ doungoi yii ʋa,
\q1 maaɠolo ɓakɔi ɠa maaɠooza ba.
\q1 
\v 16 Zɔi é bala nui laazuɠɔlizu, é ʋa tɔnɔ sɔlɔɔ ba,
\q1 ta zɔi é vebɛaniiti feezu kpɛtɛ nui ʋɛ, naati gaaɓelazuʋɛ ɠa ɠɛ ga baladai.
\ms1 Ɠima nuiti daawooiti
\q1 
\v 17 Dama, è woilo ga pagɔ ɠima nuiti gooi ma,
\q1 yiilaalao faaɠwɛgi luɠɔ, gè feezu è ya.
\q1 
\v 18 Mazɔlɔɔ fizɔgɛ è ti makɛ ɠisu,
\q1 è ɠɛʋele ɓɛtɛ yeenɔpɛ, è ɗa ti zuɠula.
\q1 
\v 19 Wɔ̀inʋɛ ga è ɠito Ɠɔoɠɔ GALAGI ʋa,
\q1 naa ɠa é ba, za, nà è ɠalasu, ɗa ɓalaagi.
\q1 
\v 20 Gè la tɛnɛ gooiti ta kidafaawu vaiti sɛʋɛni è ma,
\q1 ná zeizu ʋa ɠɛ ga puusaʋagɔ (30),\f + \fr 22:20 \fq ná zeizu ʋa ɠɛ ga puusaʋagɔ\ft : Nii wola la ɠoleni Eɓulu wooi zu. Tati pelei taɠiligaa ɓalaa ka ga niiti: \fqa mɔunpa \ft ɓaa \fqa niiti ti wola ʋagai\f* ɓaa?
\q1 
\v 21 Naati ta kala kitei ve è ya, soloogai kitogi ma.
\q1 Ni nui ta a è leʋena, gaamai ɠaiziɛzu,
\q1 ɗa zoo è faa gaamaiti bo ma, kisuɠala.
\b
\q1 
\v 22 Mina lo bala nui ná-zobotalai ma, è ʋa maavo,
\q1 mina maawɔin nui maanɔɠɔ tukpɔɠaaleʋezuʋɛ.
\q1 
\v 23 Tɔɔzei Ɠɔoɠɔ GALAGI ɠa ti maalobo,
\q1 toɠa naama nuiti zɛnvui ɠula ti ya, niiti ti zɔiti zeaɠɔligiti kulazu ti ya.
\b
\q1 
\v 24 Mina ziiɠaawanawana nu zeizei,
\q1 mina ziiɠula nu ɠɛ ga ziɛpoluɲɔɠɔ,
\q1 
\v 25 è ʋa li ɓɔɠɔ maaɠolozu ga siɛ ʋelei,
\q1 è ʋa bali la ɓɔɠɔ luɠɔ ɗa-eteai zu.
\b
\q1 
\v 26 Mina ɠɛ naati saama, niiti ta ɠɛ ga zeelagaiti,
\q1 ziingao faa zu, ta kuye zeɠe vaa zu.
\q1 
\v 27 Mazɔlɔɔ ni ani la è ya, è ʋa sala,
\q1 ta è ɓɔɠɔ ʋetei ɠula è ya, è laazu ga.
\b
\q1 
\v 28 Mina kwɛpelema wɔlɔzaɠagi zeɠe daazu,
\q1 nii è-mɛmɛwolani ti daani.
\b
\q1 
\v 29 Ni ɗa zunui ta ɠaana ɠigi ma ná-botii zu,
\q1 toɠa zoo é botii ɠɛ masagiti bɛ,
\q1 é mina yɛ naati saama, niiti ti la ga sɔɓelama nu.
\c 23
\q1 
\v 1 Ni ɗa ɠɛna zeini daami wosuʋɛ taɓali ɠa,
\q1 wa unfema nui ta, dama ga ná-fai.\f + \fr 23:1 \fq dama ga ná-fai\ft : Tati pelei taɠili ɓalaa ka ga nii: \fqa dama ga nii é è-ɠakalaʋɛ\f*
\q1 
\v 2 Ta ɠula ɗa-ʋului la,
\q1 ni è ɠulukpugɛ.
\q1 
\v 3 Mina daamiani pagɔiti nɔ ʋɛtɛ,
\q1 tanisu ta feezu è ya kisiɛ ɲɔi maazu.
\b
\q1 
\v 4 Mina ɓɔɠɔ ɓɔlɔ ga è ɓɛtɛ vai,
\q1 ɠɛlɛ vɔlɔ ma ɠisiɛi ʋa.\f + \fr 23:4 \fq ɠɛlɛ vɔlɔ ma ɠisiɛi ʋa\ft : Tati pelei taɠili ɓalaa ka ga nii: \fqa ɠɛ ga keleɠele nu è kwɛpelezu\f*
\q1 
\v 5 È ɠɛɛzu nɔ, è ɠaazulo naavoloi ʋa, tɔun é ɓega ga ɲɛɛlɛ,
\q1 mazɔlɔɔ toɠa koʋegiti tosu ɓɔɠɔ ʋa, é ɠoʋe, é li ɠoozama, eɠɛ koɠɛi é geezuʋɛ.
\b
\q1 
\v 6 À mina ɓɔ daamiani ma, wa nui é ga ziiʋodɔɠɔ nui,
\q1 è ɠaazu mina ɠula daamiani pagɔiti ba.
\q1 
\v 7 Mazɔlɔɔ nui ʋe kpegai na ga deve, é ɠɛ ma: «Laami, è ɓɔɔle.»
\q1 Kɛlɛ gaamai zu, é la è ʋɔ ziimaʋɛ.
\q1 
\v 8 Ɗa unpili ga ma ɓuɠai è miai,
\q1 woo nɛɛnɛgiti è ti wogai, ti la mɔ faa ʋaa.
\b
\q1 
\v 9 Mina ɓɔɛ faaɠaaɠalala nui ʋɔ,
\q1 toɠa è ɓɔɛ woo ʋagɔiti baaɠula.
\b
\q1 
\v 10 Mina kwɛpelema wɔlɔzaɠagi maavalibo,
\q1 è ʋa wɔin ga è podointi ta-yooi zeɠe.
\q1 
\v 11 Tɔɔzei ti unmɔɔ nu wola ɠa ná,
\q1 GALA ɓɔɠɔi ɠa ti maalobo è laalɔɠɔma.
\b
\q1 
\v 12 Yiilɔɔ maaɠoloi wu, è sɔlɔɔsu,
\q1 è woilo faaɠwɛgi ma ɠalagi ma, é wosu ga ɗe.
\b
\q1 
\v 13 Mina inɛinɛ ga è-loin maaɠolo vai,
\q1 anɛɛ ni ɗa doɠazu ga kpakɔ ɲɛ tiegɔ, é la zaa.
\q1 
\v 14 Naa ɠa zoo é kaka faiti kpudɛ maazu,
\q1 niiti ta la ɠɛ ga undaaʋili faa.
\b
\q1 
\v 15 Dòun zunu, ni ɗa ɠilina ɠimalai ʋa ga è-yii pɛ,
\q1 nà koozunɛ wola zɔlɔɔ naa zu.
\q1 
\v 16 Siɛgi zu è ɓɔɛzu la ga gaamai,
\q1 toɠa bɛ̀ ga koozunɛ wola.
\b
\q1 
\v 17 Mina ɠaazuɠula faa ɲɔu ɠɛ nuiti ba,
\q1 kɛlɛ yeenɔpɛ ɠolo Ɠɔoɠɔ GALAGI ʋɛ.
\q1 
\v 18 Mazɔlɔɔ ɗa ʋelela ʋelei zɔlɔɔ,
\q1 ɗa-ɠitogi la ɠoloɠologa.
\b
\q1 
\v 19 Woilo gòo ma ga pagɔ, dòun zunu, è ɠɛ ga ɠima nu,
\q1 è yiiʋilɛ sɔle pelei ʋa.
\q1 
\v 20 Mina ʋilɛ dɔɔ ɓɔle nuiti polu,
\q1 ɓaa naati niiti ti ɓɔɠɔ veezu daamii nɛɛnɛgiti zea.
\q1 
\v 21 Mazɔlɔɔ dɔɔ ɓɔle nuiti, ta ɠulukpu nuiti, ta ɗa gaaɓela nimizai zu,
\q1 ɲiimɛni wo nuiti ɓalaa, ná tago ʋena, ti ɓɔɠɔ maaɠili ga seɠe zaɠaiti.
\b
\q1 
\v 22 Woilo è-ɠɛɛ wooi ma, nii é è zɔlɔɔga,
\q1 mina è-lee ʋɛlɛʋɛlɛ, siɛgi zu é wɔlɔzaɠasu da.
\q1 
\v 23 Gaamai ɠaiziɛ, ta ɠimalai, ta kalagi, ta faawuuzumɔgi,
\q1 mina ti zuɠoloɠolo.
\q1 
\v 24 Telebo nui kɛɛɠɛ ɠa ɗa ɠɛ koozunɛɛi zu ɠɔ,
\q1 undaanɛ nu ɠa ga naa, nii é ɠima loun zunui zɔlɔɔsu.
\q1 
\v 25 È-ɠɛɛ ta è-lee ti ɠoozunɛ è ma,
\q1 naama undaanɛɛi ɠɛ ga anzanui naa nɔnɔ, nii é è zɔlɔɔga eteai zu.
\b
\q1 
\v 26 Dòun zunu, la nɔ̀un da,
\q1 è sìɛ ʋelei wuuzumɔ.
\q1 
\v 27 Mazɔlɔɔ koloɠolo anzanui ɠa ga zeɠezaɠai suɠoozaai,
\q1 wɛɛnziɛ anzanui ɠa ga kɔlɔyeɠei sulɔiɗai.
\q1 
\v 28 Toɠa ɗa pele ɓɔungi wo, eɠɛ toosu nu,
\q1 toɠa ɗa zunu mɔinmɔin kɛ ga wooʋalada nu.
\b
\q1 
\v 29 Ɓɛ ɠa é kpeei loozu ga: «Ee, dèe, màanɔɠɔa»?
\q1 Ɓɛ ɠa kpɔɛ wafuungiti ti losu ba, maa ɗa wana un ge la ba?
\q1 Ɓɛ ɠa gaazuɠɛzɛiti kpɔiɗai su?
\q1 
\v 30 Naati, niiti ti lɛbisu dɔɔ ɓɔlezuʋɛ,
\q1 tɛi ti dɔɔ zupuiti kpɔlezu.
\q1 
\v 31 Mina wɛlɛ dɔɔi ʋa pelei ʋa,
\q1 é nɛsu, é ɗa volo ʋɛɛlɛi zu, é ɗa yei vaa.
\q1 
\v 32 Toɠa ɗa gaaɓela ga, é nui ɲi eɠɛ kaalii,
\q1 é nu wo eɠɛ kpokpo ganii ma wanai ba.
\q1 
\v 33 È-ɠaazuʋɛ ɠa faa ɠiligiti ka,
\q1 è-ɠigi ta è-laawooiti ta zupu.
\q1 
\v 34 Toɠa ɠɛ è ɠisu, eɠɛ ɗa ɠɛ laani kpoloɗɛi zaamaʋɛ,
\q1 eɠɛ ɓato zu nui, é zɛlɛni ga ma wului, fiilɛ wolai ɗa ɲiikpi.
\q1 
\v 35 È ɗa ɠɛ ma: «Ta dòɠazu, gaa la wanazu ga ze,
\q1 ti poolɛni ga kpakɔi, gè la gaaɠaani!
\q1 Nà wuunsu yeelɛ? Kɛni gè ani zɔlɔɔ, nii nà kpɔle mɔnɔ!»
\b
\c 24
\q1 
\v 1 Mina ɠaazuɠula faa ɲɔu ɠɛ nuiti ba,
\q1 mina wɔin ga ta-ziɛpolui.
\q1 
\v 2 Mazɔlɔɔ ta-ɠisiɛi ɠa nɔ ga ti suɠoloɠolo,
\q1 ti ɗa ɓɔɛ, é ʋilɛ faa ɲɔi ʋa, ti ʋaazu kɛɛzu.
\b
\q1 
\v 3 Pɛlɛi ɠa ɗa lo ga ɠimalai,
\q1 keleɠelegi ɠa a ɗa sapeziɛ.
\q1 
\v 4 Faaɠwɛgi ɠa a ɗa buuʋɛti daave ga
\q1 ani ʋagɔiti ti vizɔgai.
\b
\q1 
\v 5 Zunui ɠigi ma, toɠa ga zunui suzeeliai,
\q1 zɔi faaɠwɛgi zea, ta ɠa ɗa ɓɔ sɛbɛi ʋa.
\q1 
\v 6 Mazɔlɔɔ faazeikpasu ʋagɔi ɠa ɗa zoo è kɔɔi ɠɔ la,
\q1 tɛnɛbo nuiti ta-mɔin ɠa kizogi a ɗa zɔlɔɔ su.
\b
\q1 
\v 7 Ɠimalala nui la zooga é ʋa ɠima vaiti gaaɠa.
\q1 Naa ɠa é ba, kɛni é ɗa maaɠɛ kpɔ, ta ɠɛna taa vaiti devea.
\b
\q1 
\v 8 Zɔi ná-kisiɛi ga é faa ɲɔi ɠɛ,
\q1 naa laa ɠa ɠɛ ga tɔɠɔ ɠoloɠolo kalamɔin.
\q1 
\v 9 Ɠimalala nui ná-kidafaawui ɠa ga kotoi,
\q1 ɲɛɛɠulasu nui maayoseɠeʋɛ nuɓusɛiti bɛ.
\b
\q1 
\v 10 Ɗa iɲɔteʋena kpɔlɔi ma ziɛgi zu,
\q1 è-zɛbɛi maa ɠa ʋɛlɛʋɛlɛ!
\b
\q1 
\v 11 Naati unmɔɔ, niiti ti liizu ga tiye ga ti ti lɔ saai zu,
\q1 naati kizo, niiti ti liizu ga tiye kazemazu, ga ti ti ʋaa.
\q1 
\v 12 Mina ɠɛ ma: «Ee, gè la ɠɛa suɠwɛɛ!»
\q1 GALA nii é fai pɛ kwɛɛ, nii é ɠɛɛzu è-yiimaʋɛ,
\q1 naa la zɔɠɔzuɠwɛɛ ɓaa?
\q1 Ungo, zɔi é è-yɛnvui makɛsu, naa kwɛɛ,
\q1 toɠa ɛsɛ gilagilagi zala, eɠɛʋelei ná-kɛɛwotiiti ti la.
\b
\q1 
\v 13 Dòun zunu, kɔin gulɔi ɠɔmɔ, mazɔlɔɔ kɔin gulɔi ʋagɛ,
\q1 ma ɲɛmigi ɠa nɛɛ è-laaʋɛ.
\q1 
\v 14 Ɠitoo su, ga ɠimalai ʋagɛ ɗa-eteai ma vaa ma.
\q1 Ni ɗa zoona è ziɛ la, ɗa zoo è ɠoozunɛ ʋelela ʋelei,
\q1 ɗa-ɠitogi la ɠoloɠologa.
\b
\q1 
\v 15 Mina woya lɔ telebo nui ná-pɛlɛi ma, ga faa ɲɔu,
\q1 mina seizuʋɛ ɠoloɠolo.
\q1 
\v 16 Mazɔlɔɔ anɛɛ ni telebo nui loo la ɠa ɠɛɛzu lɔfela, toɠa wuzeɠe,
\q1 kɛlɛ faa ɲɔu ɠɛ nuiti su ɠa ɗa ɓezeɠele ga maanɔɠɔi.
\b
\q1 
\v 17 Mina ɠoozunɛ ni è zili nui a loona,
\q1 ni a lɔɔna kpɔlɔi zu, mina kua wo ga koozunɛɛi.
\q1 
\v 18 Ɠɔoɠɔ GALAGI ɠa naa ɠa ga wanama vaa,
\q1 é la mɔ yiiɠaawana ma.
\b
\q1 
\v 19 Mina yiiɠaawana naati ta-vaa zu, niiti ti faa ɲɔi ɠɛɛzu,
\q1 mina ɠaazuɠula faa ɲɔu ɠɛ nuiti ba.
\q1 
\v 20 Mazɔlɔɔ kulanuma la naati tuɠɔ, niiti ti faa ɲɔi ɠɛɛzu,
\q1 ti-yɛnvui ɠa za eɠɛ lanboi.
\b
\q1 
\v 21 Dòun zunu, unfe Ɠɔoɠɔ GALAGI ma ta masagi.
\q1 Mina ʋɔɔkpɔ naati ba, niiti ti pɔ ga ti fai pɛ falibo.\f + \fr 24:21 \fq niiti ti pɔ ga ti fai pɛ falibo\ft : Tati pelei taɠili ɓalaa ka ga nii: \fqa niiti ti ga lɔɠɔ ba nuiti\f*
\q1 
\v 22 Mazɔlɔɔ ti ɠoloɠolo fai ɠa ɠula ti viliba,
\q1 ɓɛ ɠa é kpɔlɔi ɠwɛɛ, nii Ɠɔoɠɔ GALAGI ta masagi, ʋaazu seizu ti ma?
\ms1 Ɠima nuiti ta-lɛnɛgi taɠiligaa
\q1 
\v 23 Wɛlɛ nii ɠa ɠima nuiti ti boga mɔnɔ.
\b
\q1 Topolui ɠa ga faa ɲɔi tukpɔi ɠaaleʋezuʋɛ.
\q1 
\v 24 Ni tukpɔɠaaleʋe nui a ɠɛna faa ɲɔu ɠɛ nui ma:
\q1 «Sɔ ge la è ʋa,»
\q1 nuɓusɛiti ta foovo, ziiti ti yiiɠaawana ma.
\q1 
\v 25 Kɛlɛ tama zɔiti ti faa ɲɔu ɠɛ nui ʋeelalazu,
\q1 naati ta ɠɛ gaanɛ zu, tuya ɠa loo ti ʋɛ, é ɠɛ ga ta-undaanɛɛ.
\b
\q1 
\v 26 Gooɠaaʋotegi é veezu ga gaamai,
\q1 naa ɠa ga bɔɔlalai ma ʋoogi.
\b
\q1 
\v 27 Aisa è ʋa ɗa-ʋɛlɛi lo,
\q1 kɛni è etea ʋele wotiiti kɛ dɛ,
\q1 è ɗa-ɓalagi ɠɛʋele ɓɛtɛ, é zoloo molo leʋei ma.
\b
\q1 
\v 28 Mina zeele woo wo fuun è-zeiɲɔɠɔi laalɔɠɔma,
\q1 mina nu yaava ga è-laawooi.
\q1 
\v 29 Mina ɠɛ ma: «Nà sosu, eɠɛʋelei é sòni da,
\q1 nà seizu zunu tɛi zea, eɠɛʋelei é kɛni la ga ze.»
\b
\q1 
\v 30 Gè leʋeni ɲaka nui ta ná-kpala kpelamaʋɛ,
\q1 ɠimalala nui ná-leezɛn ɓelei laaʋɛ.
\q1 
\v 31 Wɛlɛ, kpolo ɠaingiti ta gui ɲɔiti ti ɠɛni ʋɔnɔsu ná pɛ,
\q1 siɠigi é ɠɛni ma ga sasai, naa woloni.
\q1 
\v 32 Gè naa ɠaai ma, gè tɔɔzeini ga ɠigaiziɛ,
\q1 nii gè pɛtɛni, ɠigi gè sɔlɔɔni naa ma, é ɠɛni ga:
\q1 
\v 33 È lago ɲi nɔ, è lago ɠaazuʋɛɛ ma fɔin nɔ,
\q1 è zaamale, è yeeiti da ɓɔɠɔ ma,
\q1 
\v 34 naama ziɛgi zu, baladai ɠa na ʋa è ʋɔ, eɠɛ nui é ɠulazu è viliba,
\q1 maanɔɠɔi ɠula è viliba eɠɛ toosu nui.
\c 25
\ms1 Salomɔn ná-tɛnɛ faalaalii taɠiligaani
\p 
\v 1 Wɛlɛ Salomɔn ná-tɛnɛ faalaalii tanigaani ba mɔnɔ, niiti Zuda masagi Ezekiase ná-nuiti ti ti ɠaalɛɛni ba.
\b
\q1 
\v 2 Ada GALA dɛbizu tɔɔzei dɔɔɠuzu vaiti ba, é ti ɠɛɛzu,
\q1 ada masagiti dɛbizu siɛgi zu ti ta-wotiiti kulazu la kɛlɛma.
\q1 
\v 3 Ade la kwɛɛ, geei wuzeɠeʋɛ é ɠwɛ mini, ɓaa mini ɠa zooi ɓomaʋɛ ɠwɛgai ná.
\q1 Ade la zooga, de ʋa masagiti ta-ɠisiɛiti kwɛɛ ɓalaa.
\q1 
\v 4 Ni nu a wali ɠaei ma nɔɠɔiti kulana ba,
\q1 ɠain bo nui ɠa kpɛtɛ ga aniɲaka.
\q1 
\v 5 Ni nu a faa ɲɔu ɠɛ nuiti kpɛɛna masagi maaɠoolii zu,
\q1 toɠa ná-zobogi wɔɔlɔ, a ɠɛna telebodai ɠɛa.
\q1 
\v 6 Mina ɓɔɠɔ wɔɔlɔ masagi ɠaazu,
\q1 mina zei nu wolaiti seizuʋɛ.
\q1 
\v 7 Mazɔlɔɔ fizɔgɛ ti ɠɛ ma: «Ʋa è zei unfema zeizuʋɛ,»
\q1 ti ʋa li è unfesu nu wolaiti gaazu.
\q1 
\v 8 Nii ɗa ka, naa mina ɠɛ ga zaɓu, è ʋa suvilɛ ga nu loliga tukpɔɠaaleʋezu.
\q1 Ni nui naa ɓɔɛ ʋelei a è unfena, leeni ɠa ɗa kɛ?
\q1 
\v 9 Ni kpɔɛ a ɠɛna wo yɔɠɔzu wa è-zeiɲɔɠɔi, a gaaɠula ba wa tɔ,
\q1 kɛlɛ mina taɠili ná-dɔɔɠuzu vaa ɠula kɛlɛzu.
\q1 
\v 10 Tɔɔzei a mɛnina, toɠa è ʋoomu,
\q1 è-lɔɠɔi ɠa ɠoloɠolo eyɛsu ɠɔ.\f + \fr 25:10 \fq è-lɔɠɔi ɠa ɠoloɠolo eyɛsu ɠɔ\ft : Tati pelei taɠili ɓalaa ka ga nii: \fqa è la mɔ zooga è ʋa pele leʋe maawɔin wooiti tuɠɔ\f*
\q1 
\v 11 Kpɔɛi maaɓɛtɛai ga pagɔ, naa wola ʋagɛ,
\q1 eɠɛ zanu sɔɔlai, maaɠiliai ga wali ɠaei.
\q1 
\v 12 Zɔi é woilosu ɠima nui ná-tɛnɛ gooi ma ga pagɔ,
\q1 toɠa bɛ ga zanu balaɠaegi ɠɛʋele, ta zanu kitei ma ɠɔbu anigi.
\q1 
\v 13 Molo leʋe voloi ma liegi zu, ziɛ lɛi ɠa ɗa ɠɛ ga nu yiilɛi ganii.
\q1 Zekana, gooɠɛɠila keelai a zeɠena ná-siɛi ma, toɠa ɗa maliɠii yiilɛi.
\q1 
\v 14 Nui é wasosu ga faanɛɛ ɠɛɛ vai, tama é la kɛɛzu,
\q1 kulaʋɛ ga tonai, nii é maaluai, kɛlɛ é la ʋaazu.
\q1 
\v 15 Maaɓɔungi ɠa nu a ɗa vɔni da kundiɠii ma,
\q1 woo nɛɛnɛgi ɓalaa ɠa ɗa nu ɠaei wolo.
\q1 
\v 16 Ɗa kɔin gulɔi ɠaana, kɔmɔ nɔ ga è-ma liegɔi,
\q1 mazɔlɔɔ ni ɗa gola ɠɔmɔna, ɗa unpili da.
\q1 
\v 17 Mina ɗa ga laali è-zeiɲɔɠɔi ma valafala, ni naa laade,
\q1 toɠa ɓɔlɔ ga ɗa-vai, è wɔinzeɠe ma.
\q1 
\v 18 Nui a zɛɛ zeele wooi wona, seiɲɔɠɔi laalɔɠɔma,
\q1 gaawanaʋɛ gulu ɓakɔ wolai ná-doɠai ʋa, ta boɠa zɔkpɔi, ta mɛɛn ɠaazoɓagi.
\q1 
\v 19 È ɠito yaava nui ʋa, kidaaʋili foloi,
\q1 kɛɛʋɛ eɠɛ ɗa ɠɛ daami wosu ga è-ɲiigai, é ɲiikpisu, ɓaa è zizi è-ɠɔɠɔi ma, é ɓalizu.
\q1 
\v 20 È guyei loo nui ʋɛ, nii ziizoolɛzu,
\q1 kɛɛʋɛ eɠɛ ɗa ɠɛ ná-seɠei ɠulazu kɔba kɔɔlɛ voloi, ɓaa è ziɛ ɓodai ʋu sɛɠɛ ɠaei ma.
\q1 
\v 21 Ni pului ɠa è zili nui ma, daamianigi ve zea, é mi,
\q1 ni kpɔɔle wɔin ɠa ma, ziɛi ve zea, é ɓɔɔle.
\q1 
\v 22 Mazɔlɔɔ abulekaiti kana è puuzu unmaʋɛ,
\q1 Ɠɔoɠɔ GALAGI ɠa è ɠɔnɔ fe.
\q1 
\v 23 Lɛkpɛmaʋɛ nu ɠɔʋɛzu ʋele viilɛi ɠa ɗa ʋa ga tonai,
\q1 kpɔɛzuɠula mɔinmɔingi ɠa ɗa ʋa ga zɔiti ta-yiiɠaawanai.
\q1 
\v 24 Fizɔgɛ nu zei fiilɛ zosuʋɛ sokogi zu pɛlɛ ɠɔmaʋɛ,
\q1 wo ʋa li ɓɔsu zeizu ma, wa kpɔɛleʋe anzanui.
\q1 
\v 25 Keela woo ʋagɔi é ʋaazu, é zeɠe ɠoozama,
\q1 naa ɠɛɛʋɛ eɠɛ ziɛ lɛi, nii ɗa fe nui ya, kpɔɔle wɔin ma gola.
\q1 
\v 26 Telebo nui é ɓɔɠɔ yɛsu ná, faa ɲɔu ɠɛ nui ɠaazumaayiki ma,
\q1 naa ɠɛɛʋɛ eɠɛ ziɛungi kpɔlɔai, ɓaa zeiɗɛ goi kɔzɔai.
\q1 
\v 27 É la ʋani ga nu kɔin gulɔi ɠɔmɔ ga gola,
\q1 ɓaa è ʋa lɛbiyai ɠaiziɛ ɓɔɠɔ ʋɛ ga gola.\f + \fr 25:27 \fq ɓaa è ʋa lɛbiyai ɠaiziɛ ɓɔɠɔ ʋɛ ga gola\ft : Tati pelei taɠili ɓalaa ka ga nii: \fqa kɛlɛ nu faa ɓiigiti kala, naa ɠa fizɔgai\f*
\q1 
\v 28 Taa wolai maaɠɔkɔ zobo ge la ná,
\q1 zekana zunui la, nii é la zooga vɔnisu ná-ziiɠaawanai ma.
\c 26
\q1 
\v 1 Lɛbiyai wola la zolooni ɠimalala nui ma,
\q1 eɠɛʋelei kɔɔlɛ vukɔi, naa la zolooni da foɠoi ma, ta tonai nii é ʋaazu molo leʋe ziɛgi zu.\f + \fr 26:1 \ft É zo Ɠainbogi ma, é li Latagi ʋɔ, tona maanɛa la ɗa ga ʋu Izilayɛle yooi zu.\f*
\q1 
\v 2 Foovooi nii un ge la ba, é la faa ʋaa,
\q1 kɛɛʋɛ eɠɛ soologi é ɠoʋesu, ɓaa sɛʋɛzɛʋɛgoi é ɠoʋesu, ti la zeizu.
\q1 
\v 3 Kpakɔi ɓɛtɛʋɛ sooi laalɔɠɔma, kalafei ɠɛ ga soovalegi nɔnɔ,
\q1 kpakɔi ɠɛ ga ɠimalala nui zaamaʋɛ nɔnɔ.
\q1 
\v 4 Mina ɠimalala nui wooɠaaʋote ga ná-ɠimalalai ɠɛʋele,
\q1 è ʋa ɠɛ ga tɔun kɛʋele ɗa ɓɔɠɔi.
\q1 
\v 5 Ɠimalala nui wooɠaaʋote, é zoloo ná-ɠimalalai ma,
\q1 a ʋa ɠisiɛ ga toɠa ga ɠima nu.
\q1 
\v 6 Zɔi é keela woo ɠalivaazu ɠimalala nui ma,
\q1 naa ɠa ɠɔɠɔiti teʋezu ga, ta toɠa gaazuvilɛ vaa mɔinmɔin sei luɠɔ.
\q1 
\v 7 Ʋelei mɛɠɛlɛ nui ɠɔɠɔiti ti zu la yɔɔɠɛ,
\q1 ʋele ɠana zɛbɛ la la faalaalii ya, nii ɠimalala nui bosu.
\q1 
\v 8 Ɠimalala nui maamusɛ vai ɠɛɛʋɛ eɠɛ
\q1 nu a ʋa li kɔtui ɠilizu fɛlɛvɛlɛgi ʋa.
\q1 
\v 9 Ɠaingi é zoni dɔɔzo nui ya,
\q1 ʋele ɠana faalaalii la ɠimalala nui laaʋɛ.
\q1 
\v 10 Ʋelei kpɛɛin ʋili nui la, é nuɓusɛi kpein maawanazu,
\q1 pele ɠana naama nui la, nii é ɠimalala nui zeɠezu botiɠɛ vai ma, ɓaa teʋeteʋe nuiti.
\q1 
\v 11 Eɠɛʋelei gilɛi a ɗa ɠale da ma, ná-unpiligi ma,
\q1 zekana é la ga ɠimalala nui, é ɠalesu ma ná-ɠimalalai ma.
\q1 
\v 12 Ɗa nu ɠaana daai da ga gola ɠeleɠelegɛ,
\q1 ɠimalala nui ná-fai ɠa vizɔ ná-fai ʋa.
\q1 
\v 13 Ɲaka nui ɠa ɗa ɠɛ ma: «Zalai ɠa pelei zu,
\q1 sua ɲɔi ɠa ziɛzu taazuʋɛ pelei zu!»
\q1 
\v 14 Eɠɛʋelei kpogi a ɗa lati da ná-saniɛlɛiti ga,
\q1 zekana ɲaka nui a ɗa lati da ná-betei zu.
\q1 
\v 15 Ɲaka nui ɠa ɗa yeelɔ daami aniɲakai zu,
\q1 kɛlɛ toɠa ɗa ka ga kpɔlɔ vaa wola ʋɛ, é ʋa dɔ laaʋɛ.
\q1 
\v 16 Ɲaka nui laaʋɛ ɓɔɠɔ la ga ɠigi ɠa ma,
\q1 é leʋe zunu lɔfela ʋa, niiti ta zoo ti gooɠaaʋote fe ga keleɠelegi.
\q1 
\v 17 È ɓɔɠɔ ʋili kpɔɛi ɠa, nii é la loni è ʋa,
\q1 kɛɛʋɛ eɠɛ gilɛi a yɛ leʋesu, è so goii ʋa.
\q1 
\v 18 Eɠɛ titi nui é abuleʋegiti pilisu,
\q1 ta mɛɛinti é ɗa nuiti paa ɓɔɠɔ maaɠoolii zu,
\q1 
\v 19 pele ɠana zunui naa la, nii é seiɲɔɠɔi yaavazu,
\q1 naa ʋoluma, é ɠɛ ma: «Soleya vaa nɔ ʋe.»
\q1 
\v 20 Koʋi ʋalagi ɠa ɗa abui za,
\q1 siɛgi zu nɛ fele ge la ná la, kpɔɛi ɠaa ɠa ɗa yei.
\q1 
\v 21 Tiɠii ɠa ɗa abulekai ve, koʋii abui ɠaazo,
\q1 kpɔɛleʋe zunui ɠa ɗa kpɔɛi ɠaazulɛ.
\q1 
\v 22 Zɔɠɔzuziɛ nui ná-kpɔɛiti kɛɛʋɛ eɠɛ ani ɲɛmigiti,
\q1 ta ɗa yei ti zeeli nu ɠoozuʋɛ.
\q1 
\v 23 Wali ɠaei pɛai penɛi maazu,
\q1 ʋele ɠana kpɔɛ nɛɛnɛgiti ti la, ti nui yiimaʋɛ ma vaa ɲɔiti maalɔɔɠuzu.
\q1 
\v 24 Nui wɔinzeɠemai daavegai, toɠa ɗa maalɔɔɠu ga laawooiti,
\q1 é ɗa yaavaiti kpɛtɛ ɠoozu.
\q1 
\v 25 Ni a ɠɛna kpɔɛ ʋagɔiti boga, mina la da,
\q1 mazɔlɔɔ ná-kisiɛiti sulaavegɛ ga faa ɲɔi.
\q1 
\v 26 Keleɠelegɛ gola ná-wɔinzeɠemai lɔɔɠu vai zu,
\q1 kɛlɛ nuɓusɛi pɛ ge ɓega ga ná-suɲɔi ɠwɛɛ.
\q1 
\v 27 Zɔi a zeɠei wɔ, tɔ ɓɔɠɔ ɠa loo su,
\q1 zɔi a kɔtui ɠilikilina, toɠa loo tɔ ɓɔɠɔi nɔ ma ʋolu.
\q1 
\v 28 È nui ta maawana ga zɛɛʋɛɛmai, naa ɠa ga è zili la.
\q1 Wooveledai ma ɓɔɛi wo fai ɠa ɗa ʋa ga faa zuɠoloɠologi.
\c 27
\q1 
\v 1 Mina ɠɔmazei ga nii a ɠɛ lina,
\q1 mazɔlɔɔ è la naa ɠwɛɛ, nii é ɠɛɛzu za.
\q1 
\v 2 È-laaʋɛ mina è maamusɛ, nu ɠiligiti zɛ ná, ti kɛ.
\q1 Nu ɠiligi naa ɠɛ, ɗa ɓɔɠɔi è-laaʋɛ mina kɛ.
\q1 
\v 3 Kɔtui wuiʋɛ, ɲaɠaegi wuɲɛgi wui,
\q1 kɛlɛ ziiɠaawanai ɠimalala nui buzeɠezu, naa wuiʋɛ ti felegɔ pɛ ba.
\q1 
\v 4 Ziiɠaawanai ɲɔuʋɛ, ziiɠulagi ɠeɠaaɓa,
\q1 kɛlɛ ɓɛ ɠa a lo toloi luɠɔ?
\q1 
\v 5 Fizɔgɛ è zelii lo nui ma kɛlɛi zu,
\q1 è ʋa maaɠɛ kpɔ bɔɔla vai ma.
\q1 
\v 6 Nu wɔɔlai ná-zelilomai, ɠa ná-wooɠɛɠiladai lɛɛzu,
\q1 nu zili nui è nɛɛnɛ vai, naa ɠa ga yaava vaa nɔ.
\q1 
\v 7 Ziɠo nui ɠa ɗa ɠɛlɛ kɔin gulɔi ʋa,
\q1 pulu nui ɠa ɗa ani wanai ɠa ga ɲɛmigɛ.
\q1 
\v 8 Siɛziɛ nui maa ɠa ɠoozana seizuʋɛ ʋa,
\q1 kɛɛʋɛ eɠɛ wɔnii maaɠoozaai ná-daɠagi ʋa.
\q1 
\v 9 Gulɔi ta gulɔ maku nɛɛnɛgi, ta ɗa nu yiiɠaanɛ,
\q1 bɔɔla vai ná-gaanɛɛi ɠa ɗa koozunɛɛi ve nu ya, é leʋe ɗa ɓɔɠɔ ɛnɛkɛgi ʋa.
\q1 
\v 10 Mina ɓeteʋe è-wɔɔlaiti ba, ta è-ɠɛɛ bɔɔlaiti.
\q1 Ni ɗa ɠɛna faaɓaagi zu, mina ɓizɛ, è ʋa li è-ɠɛɛloin ʋɔ bɛ,
\q1 mazɔlɔɔ siɛ mɔinmɔin su, è-zeiɲɔɠɔi maaɓuɠaai è ʋa, naa vizɔgɛ é leʋe è-ɠɛɛloin ʋa, maaɠoozaai è ʋa.
\q1 
\v 11 Ziɛ ga ɠimalai dòun zunu, zìimaʋɛ laa ɠa ve ga koozunɛɛi,
\q1 nà zoo gè naati gooɠaaʋote, niiti ti vaazu mà.
\q1 
\v 12 Ɠima nui ɠa ɗa maanɔɠɔi ɠa é ʋaazu, é lɛkpɛ tuɠɔ,
\q1 kɛlɛ nui é la dɛ faa mɔinmɔin kwɛɛ, naa ɠa ɗa ziɛ ná ɠobaʋɛ, é ma ɓɔlɔi zɔlɔɔ.
\q1 
\v 13 Ni nui ta a ɓɔɠɔ ɠɛna ga zeelaga è ʋɔ bɛ, é ʋilɛ nui ta ná-kuye vaa ʋa, nii è la kwɛɛ,
\q1 ná-seɠei zeɠe ga kpɔunmai, nui naa ná-faa zu, nii è la kwɛɛ.
\q1 
\v 14 Ni nui ta a tuya loona seiɲɔɠɔi ʋɛ, é wooɠula la sobuzobui,
\q1 toɠa leve bɛ ga foovooi.
\q1 
\v 15 Kpɔɛleʋe anzanui ɠɛɛʋɛ eɠɛ ziɛi, é ʋilɛsu peinpein,
\q1 maa la leʋezu tonai ʋa voloi.
\q1 
\v 16 Ɗa wɔinna ga è gaaɓɛ, kɛɛʋɛ eɠɛ ɗa ɠɛ fiilɛi zosu ga yeei,
\q1 ɓaa è gulɔi ʋu yeaʋɛ ga è makɛ.
\q1 
\v 17 Kɔlui ɠa ɗa kɔlui ɠaali,
\q1 nui ɠigi ɠaazu ɠa ɗa zeɠe ma, seiɲɔɠɔi ná-siɛpolui ʋɔ.
\q1 
\v 18 Zɔi é wɛlɛzu kooleɠoole gului ma, toɠa ma waai ta mi,
\q1 zɔi é maliɠii makɛsu, toɠa lɛbiya zɔlɔɔ.
\q1 
\v 19 Ʋelei nu ɓɔɠɔ ɠaazuʋɛ ɠaazu la ziɛi wu,
\q1 ʋele ɠana nu ɠigi a ɗa è-ʋaaɠulabai lɛɛ la.
\q1 
\v 20 Gɔvɛalaazu ta undaaʋili zeɠezaɠai ti zulaa la vega,
\q1 zekana é la, nuɓusɛi yiimai laa la zeelia pɛ.
\q1 
\v 21 Wali ɠaei ta zanugi, ti ɠaa ɠa ɗa wuun ga abui, ma nɔɠɔi ʋa ɠula ba,
\q1 kɛlɛ nui lukpɔi ɠaa ɠa leʋezu, é zoloo daaseigi ma.
\q1 
\v 22 Anɛɛ ni ɗa ɠimalala nui ziɠazu kodai zu ga etei, eɠɛʋelei nu a ɗa kpazii ziɠa la,
\q1 è la zooga è ʋa ná-titigi ɠula ba.
\b
\q1 
\v 23 Ɗa-loganiiti gilagilagi ɠɛʋelei ɠwɛɛ ga pagɔ,
\q1 ɠaaɓa gola ɗa-logani ɓulugiti ma.
\q1 
\v 24 Mazɔlɔɔ kpɛtɛi la zeeyɛga ma eyɛsu ɠɔ,
\q1 masa bɔɔlɔgi la yɛga nu unba yeenɔpɛ.
\q1 
\v 25 Siɛgi zu è tufa vɔɔi leʋezu la, tufa wundui ɠa ɗa wuzeɠe,
\q1 gizeiti ma lufaiti gaa ɠa lɛ ba,
\q1 
\v 26 ɗa-ʋaalagiti maaleɠaiti ta ɠɛ ga è maaɠili zɔɔlaiti,
\q1 boliiti ta ɠɛ ga ɗa-ɓalagi ɠeya aniiti,
\q1 
\v 27 boliiti ta-ɲiimiɗɛi maanɛɛʋɛ, é kula ɠɛ ga è-laamianigi,
\q1 wa ɗa-ʋɛlɛyeɠei, ta ɗa-wotiɠɛ anzanuiti maavaiti.
\c 28
\q1 
\v 1 Faa ɲɔu ɠɛ nui ɠa ɗa ɓizɛ, anɛɛ ni nu la kpɛɛzu,
\q1 kitogi ɠa telebo nuiti zea, eɠɛ zala ɓokpagi.
\q1 
\v 2 Siɛgi zu kpakagi la zooi zu, kundiɠila ɠaiziɛ nuiti ta ɗa mɔin.
\q1 Kɛlɛ kundiɠii a zeina, keleɠelegai é ɠala, faiti ta ɗa ziɛ ga pagɔ.
\q1 
\v 3 Zunui é ga bala nui, é maawɔin nuiti maanɔɠɔzu,
\q1 toɠa ga faa zuɠoloɠolo tonai, é pului loozu.
\q1 
\v 4 Niiti ti ɠɛlɛzu GALA ná-tɔgi ʋa, naati ta ɗa faa ɲɔu ɠɛ nuiti maamusɛ,
\q1 kɛlɛ niiti ti ɠolozu tɔgi ʋɛ, naati ta ɗa laalɛ ti wu.
\q1 
\v 5 Niiti ti ɓɔɠɔ veezu faa ɲɔi ya, naati ti la sɔle fai tanɔpɛ gaaɠaazu,
\q1 kɛlɛ niiti ti ɓɔɠɔ ɠilizu Ɠɔoɠɔ GALAGI ʋa, naati ta ɗa faiti pɛ gaaɠa.
\q1 
\v 6 Fizɔgɛ nu ɠɛ ga bala nui, è ɗa ziɛ sɔledai zu,
\q1 è ʋa li ɠɛɛzu ga kpɛtɛ nui, nii siɛ ʋelei ga wooveledai.
\q1 
\v 7 Zɔi é ɠolozu GALA ná-tɔgi ʋɛ, doun zunu ɠana keleɠelegai,
\q1 kɛlɛ zɔi é ʋilɛsu tuʋa ʋele ɲɔu nuiti polu, naa ɠa ɗa ʋa ga unfegi kɛɛɠɛ ʋɔ.
\q1 
\v 8 Zɔi é ná-sɔlɔɔgi maamɔinzu ga talama walii, nii dateʋegai,
\q1 naa ɠa sɔlɔɔgi ɠaalɛɛzu ba naa ʋɛ, nii a maawɔin nuiti maawɔinɠa.
\q1 
\v 9 Ni nu a ʋoluavena, ga é mina woilo GALA ná-tɔ gooi ma,
\q1 ná-GALA falii wɔin ɠa zeɠe GALA ma.
\q1 
\v 10 Zɔi é telebo nuiti kakasu, é ti ʋilɛ pele ɲɔi ma,
\q1 toɠa loo zeɠei zu, nii é bɔai.
\q1 Kɛlɛ niiti ti ziɛzu ga sɔledai, undaanɛɛi ɠa naati tuɠɔ.
\q1 
\v 11 Kpɛtɛ nui ɠeleɠelegɛ ɓɔɠɔ nɔ ɠaazu,
\q1 kɛlɛ bala nui keleɠelegai, naa ɠa zoo é poluɠula.
\q1 
\v 12 Siɛgi zu telebo nuiti ti kundiɠilai zɔlɔɔsu da, lɛbiya ɠa ɗa ɠɛ lee ɛsɛ pɛ bɛ.
\q1 Kɛlɛ siɛgi zu nu ɲɔiti ti wuzeɠezu la, ɛsɛ ka ɗa lɔɔɠu.
\q1 
\v 13 Zɔi é ná-tɔ koloɠologiti dɔɔɠuzu, naa la ɠula ɓɔɠɔ numa,
\q1 kɛlɛ GALA ka ɗa naa zuvaayɛ, zɔi é laazu zɔ ga é ɠɛlɛ ti ʋa.
\q1 
\v 14 Undaanɛ nu ɠa ga naama nui, nii yeenɔpɛ é luazu faa ɲɔi ɠɛɛ vai ʋa,
\q1 kɛlɛ zɔi é ɠikpaazu, é ɗa faa ɲɔi ɠɛ, naa ɠa lɔ maanɔɠɔi zu.
\q1 
\v 15 Ʋelei zalai la, é zikɔzu, ta filɛ zuai pului ma,
\q1 ʋele ɠana faa ɲɔu ɠɛ nui la, nii é masadai ɠɛɛzu nuɓusɛiti unda, ti ʋalagai.
\q1 
\v 16 Kundiɠii a ʋalana ɠigi ma, toɠa ɗa telebotalai wola ɠɛ,
\q1 kɛlɛ zɔi é ɠɛlɛzu kakama ani mii vai ʋa, toɠa ɗa lɛbi kundiɠilai zu.
\q1 
\v 17 Nui nii nu ʋaa vai ziimaʋɛ, toɠa ɗa ɓizɛ ga lia ná-kabayeɠei ʋɔ pelei,
\q1 nu nɔpɛ ge mina pele ɓesa tuɠɔ.
\q1 
\v 18 Nu-o-nu nii siɛ ʋelei zɔlegai, naa ɠa kizogi zɔlɔɔ,
\q1 kɛlɛ sɔletala nui, é pele zuɓili felegɔi ziɛzu, toɠa loo gila su.
\q1 
\v 19 Zɔi é ná-tii ɠɛɛzu, naa ɠa daamianigi zɔlɔɔ ga bɔɔlɔa,
\q1 kɛlɛ zɔi é ʋilɛsu gaaʋalaba vaiti polu, naa ɠɔnɔgi ɠa ɠɛ ga daanɔɠɔwogi.
\q1 
\v 20 Nui é ga lada nui, zee laa ɠa ve ga tuyai,
\q1 kɛlɛ zɔi é wɔinni é ɓɛtɛ ga gaazuvilɛi, maanɔɠɔi la ʋoola ba.
\q1 
\v 21 É la vizɔni ga nu zeelɔzɔɠɔzui ɠɛ nuɓusɛiti zɔɠɔzu,
\q1 anɛɛ naa ʋe, nui ɠa zoosu é faa ɲɔi ɠɛ ɓulu ɓuɠai zɔlɔɔ fai zu.
\q1 
\v 22 Zunui é ga gaazuɠulapɔ nui, toɠa ɗa kpɛtɛi ɠaiziɛ ga gaazuvilɛi,
\q1 toɠa ɗa yeema ga baladai ɠa ʋaazu pɔ.
\q1 
\v 23 Zɔi é zelii losu seiɲɔɠɔi ma, gaaɓelasu naa ɠa ɗa ná-faanɛɛi wuuɠwɛɛ,
\q1 é leʋe zɔi ʋa é maamusɛi wosu ga nɛgi.
\q1 
\v 24 Nu-o-nu é kaazu ga faa ɲɔu laade, ga é kɛɛɠɛ ta dee maavo,
\q1 é la vizɔni toosu nu ʋa.
\q1 
\v 25 Zunui nii sɔlɔɔgi la ziilɛiɗa, toɠa ɗa kpɔɛi wuzeɠe,
\q1 kɛlɛ zɔi é ɓɔɠɔ ɠalivaazu Ɠɔoɠɔ GALAGI ma, toɠa ɠɛ anii pɛ su nɔ yaɠaba.
\q1 
\v 26 Ɗɛi è laazu ɗa-ɠigaiziɛiti nɔ la, ɗa ga ɠimalala nu,
\q1 kɛlɛ zɔi é ziɛzu ga ɠimalai, faaɓaagiti ta ʋoola ba.
\q1 
\v 27 Zɔi é faanɛɛi ɠɛɛzu bala nuiti bɛ, é la yɛga kpala zu,
\q1 kɛlɛ zɔi é ɠaazuʋɛɛzu ma, seiɲɔɠɔi ná-kpɔlɔi luɠɔ, toɠa foovoo mɔinmɔin sɔlɔɔ.
\q1 
\v 28 Siɛgi zu faa ɲɔu ɠɛ nuiti ti zeizu la kundiɠilai zu, ɛsɛ pɛ ka ɗa lɔɔɠu,
\q1 kɛlɛ siɛgi zu ti loozu bu la, telebo nui ma mɔinmɔin ka ɗa ɠula kɛlɛma.
\c 29
\q1 
\v 1 Zunui nii maanɛai ga zelii lo ma, é ɗa ɠɔgi ɓaa ga,
\q1 toɠa ɠoloɠolo ga kulafilibai, sosu la ɠaa.
\q1 
\v 2 Telebo nuiti ta mɔinna, nuɓusɛiti koozu ɠa ɗa nɛ,
\q1 kɛlɛ nu ɲɔiti ta zeina kundiɠilai zu, nuɓusɛiti ta ɗa kpalagi wo.
\q1 
\v 3 Zɔi é pɔ ga é ziɛ ga ɠimalai, naa ɠa ɗa kɛɛɠɛ ɠoozunɛ,
\q1 kɛlɛ zɔi é ʋilɛsu koloɠolo anzanuiti polu, naa ɠa ɗa ná-naavoloiti koloɠolo.
\q1 
\v 4 Masagi ɠa ɗa ná-zooi ɓɛtɛ, siɛgi zu é ziɛzu la ga telebodai,
\q1 kɛlɛ a lobɛanii maalolina, toɠa naa ɠoloɠolo.
\q1 
\v 5 Nui é bɔɔlaiti tɛɛzu su,
\q1 toɠa balii laazu kɔɠɔi wu.
\q1 
\v 6 Faa ɲɔu ɠɛ nuiti ta ɗa ɠɛ ga kasoɠa nui, tiya ɓɔɠɔi ta-lɔ koloɠologiti faa zu,
\q1 sɔle nuiti ta ɗa pilɛ sɔlɔɔ, ti ɠoozunɛ.
\q1 
\v 7 Telebo nui naa ɠwɛɛ, nii maanɛai é ɠɛ bala nuiti bɛ,
\q1 kɛlɛ naama ɠi ge la faa ɲɔu ɠɛ nui ma.
\q1 
\v 8 Ɲɛɛɠulasu nuiti ta ɗa kpɔɛ abui ʋili taa wolai zu,
\q1 kɛlɛ ɠima nuiti ta ɗa ziiɠaawanai ɠaayei.
\q1 
\v 9 Ni ɠima nui ta ɠimalala nui ta ɠɛna tukpɔi ma,
\q1 ɠimalala nui yiiɠaawanaʋa, ɓaa é ɲɛɛi wo, é la ɓɔlɔa.\f + \fr 29:9 \fq ɠimalala nui yiiɠaawanaʋa, ɓaa é ɲɛɛi wo, é la ɓɔlɔa\ft : Tati pelei taɠili ɓalaa ka ga nii: \fqa toɠa la nɔ yiiɠaawana, ɓaa é ɲɛɛ, tama nu la ɓega pɛ\f*
\q1 
\v 10 Ɲama ʋuu nuiti ta ɗa telebo nui wɔinzeɠe,
\q1 kɛlɛ sɔle nuiti ta ɗa ɓaa zɛnvui maazu.
\q1 
\v 11 Ɠimalala nui ɠa ɗa ná-ziiɠaawana vaiti kpein kula kɛlɛma,
\q1 kɛlɛ ɠima nui ɠa ɗa ɓɔɠɔ zo, é la nɔnɔiti kula kɛlɛma.
\q1 
\v 12 Siɛgi zu kundiɠii woilosu da zɛɛ ɓɔɛiti ma,
\q1 niiti ti botii ɠɛɛzu zeewu, naati pɛ ta ɗa ɠɛ ga wooʋalada nuiti.
\q1 
\v 13 Bala nui ta maanɔɠɔ nui, ti ɓɔgɛ faa ɠila ma:
\q1 Ɠɔoɠɔ GALAGI gaazuʋɛ veeʋɛ ti felegɔ pɛ bɛ, ga ti ɗa wɛlɛ la.
\q1 
\v 14 Masagi nii é zobobɛlala nuiti ta-lukpɔi ɠaaleʋezu ga gaamai,
\q1 ná-masadai ɠa ɗa yɛ zea ɠɔ.
\q1 
\v 15 Kpakɔi ta zelilomai, ta ɗa ɠimalai ve,
\q1 kɛlɛ zunu loungoi pilɛgai ɓɔɠɔ yeema, toɠa ɗa dee unfe.
\q1 
\v 16 Siɛgi zu nu ɲɔiti ti mɔinzu la, tɔ koloɠologi zu ɠa ɗa wɔɔlɔ,
\q1 kɛlɛ telebo nuiti ta ɠɛ ga ta-loobui ma zeelei.
\q1 
\v 17 Ni ɗa è-loun zunui maaɠolona, é la è yiizoolɛ vaa ɠɛa,
\q1 kɛlɛ toɠa è yiilɛi ga gola.
\q1 
\v 18 Siɛgi zu GALA ge la kulakɛlɛma wosu da, nuɓusɛiti ta ɗa eteai ziɛ faazupui zu.
\q1 Undaanɛ nu ɠa ga naama nui, nii naazu, é ɠolozu GALA ná-tɔgi ʋɛ.
\q1 
\v 19 Nu la ɗa ga botiɠɛ nui maaɠolo ga kpɔɛzuɠulai,
\q1 mazɔlɔɔ anɛɛ ni toɠa naa ɠaaɠaazu, nii é wosu ma, é la ɠoloa ɲɛgɛlɛin.
\q1 
\v 20 Ɗa nu ɠaana, é ɗa ɓɔɛ, é la ɠigaiziɛzu,
\q1 nu ɠa ɠito ɠimalala nui ʋa, é leʋe tɔun ba.
\q1 
\v 21 Ni nu a botiɠɛ nui laanɛɛna ná-nu niinɛlai zu,
\q1 toɠa gaaɓela ga kololalai.\f + \fr 29:21 \fq toɠa gaaɓela ga kololalai\ft : Tati pelei taɠili ɓalaa ka ga nii: \fqa toɠa gaaɓela ga é ɓɔɠɔ ʋɛtɛ ga pɛlɛ wu loun zunui ɠila\f*
\q1 
\v 22 Ziiɠula nui ɠa ɗa kpɔɛi leʋe,
\q1 zɔi ziiɠulazu valafala, naa ɠa ɗa tɔ koloɠologiti kɛ.
\q1 
\v 23 Wasogi ɠa ɗa nui maayei,
\q1 kɛlɛ ɓɔɠɔmaayeii ɠa ɗa nui wɔɔlɔ.
\q1 
\v 24 Zɔi é yeezeizu unma nui wu, naa ɠa ɗa ɓɔɠɔ nimiza,
\q1 tɔɔzei é foovooi ɠwɛɛ, é naama nui laalɔɠɔma, nii é ɠɛlɛzu ga é mina ʋa, é ʋa zeele wooi wo.
\q1 
\v 25 Ɗa ɠɛna lua nuiti ba, toɠa ga balii,
\q1 kɛlɛ zɔi é ɠalivaazu Ɠɔoɠɔ GALAGI ma, naa yiilɛiʋɛ.
\q1 
\v 26 Ma mɔinmɔin ka ná, ti ɗa kpɔbai ɠaiziɛ ta-ɠundiɠii ya,\f + \fr 29:26 \fq ti ɗa kpɔbai ɠaiziɛ ta-ɠundiɠii ya\ft : Tati pelei taɠiligaa ɓalaa ka ga niiti: \fqa ti pɔ ga totuɠɔi ti-wooi mɛni \ft ɓaa \fqa totuɠɔi yeezei ti wu\f*
\q1 kɛlɛ ɛsɛ maalobo fai ɠa Ɠɔoɠɔ GALAGI ya.
\q1 
\v 27 Telebotala nuiti wɔin ɠa ɗa zeɠe telebo nuiti ma,
\q1 sɔle nuiti maayoseɠeʋɛ faa ɲɔi ɠɛ nuiti bɛ.
\c 30
\ms1 Aguul ná-kpɔɛiti
\p 
\v 1 Yaké ná-doun zunui Aguul ná-kpɔɛiti. Zunui nii ná-deve wooiti ti Itiyɛle ná-faa ma. Itiyɛle ná-faa ma, ta Ukale.
\b
\q1 
\v 2 Gaama ʋe, nà ga ɠimalala nui, gè leʋe nuɓusɛiti kpein ba,
\q1 nuɓusɛ ɠeleɠelegi la zèa.
\q1 
\v 3 Gè la ɠimalai ɠalani,
\q1 gè la GALA Ɲadegai ná-faaɠwɛgi ɠwɛɛ.\f + \fr 30:3 \fq gè la GALA Ɲadegai ná-faaɠwɛgi ɠwɛɛ\ft : Tati pelei taɠiligaa ɓalaa ka ga niiti: \fqa kɛlɛ gè nuiti ta-vaaɠwɛgi ɠwɛɛ \ft ɓaa \fqa tama gè la nu ɲadegaiti ta-vaaɠwɛgi ɠwɛɛ\f*
\q1 
\v 4 Ɓɛ ɠa é lɛɛni geeɠɔlɔgi zu, GALA pɔ bɛ, é zeɠe ná, é yei?
\q1 Ɓɛ ɠa é fiilɛi zoga, é yɛ zea?
\q1 Ɓɛ ɠa é ziɛiti pua ná-seɠei la?
\q1 Ɓɛ ɠa é zooi ɠwɛgiti kpein daa?
\q1 Daasei ka ɓɛ, ná-doun zunui laasei ka ɓɛ?
\q1 Bo dɛɛ, ni è kwɛɛ!
\b
\q1 
\v 5 GALA daawooi ɠilagilagi pɛ ka ga gaamai.
\q1 Toɠa ga kɔɔɠɔ zɛpɛgi naati bɛ, niiti ti lɔɔɠuzu bu.
\q1 
\v 6 Mina tanɔpɛ da daawooiti ma,
\q1 ni naa laade, toɠa è loɠa, è ʋɛtɛ ga zɛɛ nu.
\b
\q1 
\v 7 Ɠɔoɠɔ GALAGI, nà faa felegɔ valizu è ma,
\q1 naati kɛ bɛ̀, aisa nà-eteai ʋa ɓe:
\q1 
\v 8 Màkɛ, gè mina kpɔɛ ɲaka wo, ɓaa zɛɛiti,
\q1 mina kɛ̀ ga bala nu, ɓaa kpɛtɛ nu wola.
\q1 Naa ve zèa nɔ, nii fizɔgai mà, gè eteai ziɛ.
\q1 
\v 9 Mazɔlɔɔ anii pɛ ga ʋooʋana zèa, nà ʋa lia ɠɛlɛzu è ʋa,
\q1 gè ʋa ɠɛ ma: «Ɓɛ ɠa é ga Ɠɔoɠɔ GALAGI?»
\q1 Ɓaa mu, maanɔɠɔi a ɓɔina dà, gè ɓɔɠɔ ɠɛ ga unma nu,
\q1 gè ɓaaɠula nà-GALAGI ma ɠana.
\b
\q1 
\v 10 Mina va botiɠɛ nu ma, maliɠii ɠaazu.
\q1 É mina è voovo, ɗa-vaaɠaazagi ma ɠasɔi ɠa la è unma.
\b
\q1 
\v 11 Nui tanigaa ta ná, ta ɗa ti-ɠɛɛ ɠoto,
\q1 ti la tuya loa ti-lee ʋɛ.
\q1 
\v 12 Nui tanigaa ta ná, ti ɓɔɠɔ ɠaazu ga ti ɲadegɛ,
\q1 tama, ti la gbani, ti ʋa ɠula ta-ɠɔzɔba vaiti su.
\q1 
\v 13 Nui tanigaa ta ná, ti ɠaazulɛai,
\q1 ti ɗa wɛlɛ nui pɛ ba nɔ fawuu.
\q1 
\v 14 Nui tanigaa ta ná, ti-ɲiigaiti ti ga boɠa zɔkpɔiti,
\q1 ti-ɓalɔɠaeiti ti ga boɠaiti, ti ɗa maanɔɠɔ nuiti mi,
\q1 ti ʋa ɲɛɛlɛ, ti ɠula eteai zu,
\q1 ti ʋa bala nuiti suwuɠaaleʋe, ti ɠula nuɓusɛiti saama.
\b
\q1 
\v 15 Moolɛi ná-doun anzanuiti ti fele, ti-laasei ka ga: Fe! Fe!
\q1 Ani saʋagɔ ɠa ná, ti-yii la lɛiɗa eyɛsu pɛ,
\q1 eyɛsu pɛ ti la ɠɛa ma: «É kula ɠɛa.»
\q1 
\v 16 Gɔvɛalaazu, doun zɔlɔɔtala anzanui,
\q1 zooi, nii ziɛ la ga kpɔɔle wɔinzeɠe ma,
\q1 kɛlɛ ti-naanisiɛi ɠa ná ɓalaa, abui, nii é la ɠɛa ma: «É kula ɠɛa.»
\b
\q1 
\v 17 Nui ɠaazuɠɛzɛiti é ɲɛɛɠulazu la kɛɛɠɛ zu, é ɗa woozotalai ɠɛ ga dee,
\q1 kɔtuɗɛi ma ɠalawɔniiti ta ti ɠula su, koɠɛ yiʋoiti ti ti mi.\f + \fr 30:17 \ft Nii ʋoluʋɛ ɠa ga faanɛɛ wuuɠwɛɛtala loun zunui ma ʋoomai la kaba zɔlɔɔga, toɠa yɛ ná filɛ wɔniiti bɛ.\f*
\b
\q1 
\v 18 Faa saʋagɔ ɠa ge la dɛ gaaɠaani,
\q1 kpudɛai màazu:
\q1 
\v 19 koɠɛi ɠoʋe pelei geezuʋɛ,
\q1 kaalii ɓokpo pelei fasai ma,
\q1 ɓatoi ná-pelei kpoloɗɛi zaamaʋɛ.
\q1 Kɛlɛ naanisiɛi ɓalaa ɠa ná:
\q1 zunui ziɛ ʋelei é lo anzalopoi ʋa.
\b
\q1 
\v 20 Wɛlɛ ʋelei wɛɛnzo anzanui a ɗa kɛ la:
\q1 a yiima vaiti kɛɛna ziilɛi, é laamaʋɛ ɓale,
\q1 é ɠɛ ma: «Gè la faa ɲɔu nɔpɛ kɛɛni.»
\b
\q1 
\v 21 Faa saʋagɔ ɠa ná,
\q1 niiti ta ɗa eteai ɲiikpi, é la ziaa bu:
\q1 
\v 22 duɔi a zeina ga masagi,
\q1 ɠimalala nui a zobo sɔlɔɔna, é ɗa ɠɔnɔgi zɔlɔɔ,
\q1 
\v 23 anzanui kɛlɛbai wogai da, naa a zeina zini bɛ.
\q1 Kɛlɛ naanisiɛi ɓalaa ɠa ná:
\q1 duɔ anzanui é zeizu duɔ dee ʋotogi zu.
\b
\q1 
\v 24 Sua naanigɔ ɠa ná eteai zu, ti wola lɔiɗai gola,
\q1 anɛɛ naa ʋe, ti wola ɠigɛ da ge leʋe:
\q1 
\v 25 pupuiti, zɛbɛ nɔpɛ ge la ti ʋa,
\q1 kɛlɛ ta ɗa ti-ɠɔnɔgi ɠɛʋele ɓɛtɛ foɠoi,
\q1 
\v 26 fasa woliiti,\f + \fr 30:26 \fq fasa woliiti\ft : Naati ta ga tufa mi zua goiti, ta ɗa mɔin ʋolu gizeiti ma.\f* zɛbɛ la ti ʋa,
\q1 kɛlɛ ta ɗa ti-ʋuuzuʋɛ ɓɛtɛ fasaiti su,
\q1 
\v 27 kotogiti, masa ge la ti unda,
\q1 ta ɗa ɓɔɠɔ zei su, ti-ma ɓulugi ɗa ɠula,
\q1 
\v 28 kooloiti, niiti nu a ɗa ti zo nɔ ga yeei,
\q1 ta ɗa lɔ masagiti ta-masa pɛlɛiti bu.
\b
\q1 
\v 29 Fuluani saʋagɔ ɠa ná,
\q1 ti-ziɛ ʋelei, ta ti maanɛɛ ʋelei ga pɛtɛ gani:
\q1 
\v 30 zalai, nii ziilɔai é leʋe suaiti pɛ ba,
\q1 é la ɠula ʋolu nu nɔpɛ bɛ,
\q1 
\v 31 tɛɛ zinɛi,\f + \fr 30:31 \fq tɛɛ zinɛi\ft : Tati pelei taɠiligaa ɓalaa ka ga niiti: \fqa sooi \ft ɓaa \fqa zaɓei\f* nii a ɗa ɠaalɔ kɔɠɔʋolu valagiti ga, ɓaa mu boli zinɛi.
\q1 Kɛlɛ naanisiɛi ɓalaa ɠa ná:
\q1 masagi é loni ná-kɔɔʋɛbɛi untuɠɔ, ti ɗa li.
\b
\q1 
\v 32 Ni è ɠɛni ga ɠimalala nui, è ɗa waso,
\q1 ɓaa ni è ɠɛni kigaiziɛ ɲɔiti bosu,\f + \fr 30:32 \fq ni è ɠɛni kigaiziɛ ɲɔiti bosu\ft : Tati pelei taɠili ɓalaa ka ga nii: \fqa ni è tɔɔzeiɗa ga kigaiziɛi woga\f*
\q1 za ʋoluma, ɓɔɠɔ zo.
\q1 
\v 33 Mazɔlɔɔ nɔnɔi loɠaai ɠa nu a ɗa gulɔi zɔlɔɔ da,
\q1 sokpa loɠai ɠa ɲamai a ɗa ɠula su,
\q1 ziiɠaawanai ɠaazulɛai ɠa kpɔɛi a ɗa ɠula su.
\c 31
\ms1 Tɛnɛgi é veeni masagi ya
\p 
\v 1 Masagi Lemuwɛle laawooiti. Kalagiti dee ti woni da.
\b
\q1 
\v 2 Lee ɠa nà bo è ma, dòun zunu?
\q1 Lee ɠa nà bo è ma, kòozu loin?
\q1 Lee ɠa nà bo è ma, dòun zunu, gè minazeɠeni ga gè sɔlɔɔ?
\q1 
\v 3 Mina è-zuvikɛi ve anzanuiti zea,\f + \fr 31:3 \ft Nii ɠa ɓɔɛzu, é ʋilɛ anza ʋɛlɛi wu anzanu mɔinmɔingiti ba masa pɛlɛi wu, niiti ta la zoo ti masagi zeɠe siɛ ʋele ʋa.\f*
\q1 ta ɗa-ʋeleiti, naati zea, niiti ta ɗa masagiti kaka.
\b
\q1 
\v 4 É la zolooni masagiti ma, Lemuwɛle,
\q1 é la zolooni masagiti ma, ga ti ʋa dɔɔi ɓɔle,
\q1 ɓaa naati, niiti ti kundiɠilai ɠɛɛzu, ti ʋa gaazulati gani ɓɔle.
\q1 
\v 5 Mazɔlɔɔ a ti zona, ti mina yeema tɔgi laawooiti ma,
\q1 ta ti mina maawɔin nuiti ta-ɠaamai maavalibo.
\q1 
\v 6 Nu gaazulati kpɔle anii ve naa ya, nii undaa ʋaazu ʋilisu,
\q1 ta dɔɔi ve maawɔin nui ya.
\q1 
\v 7 É kpɔle, é yeema ná-baladai ma,
\q1 é mina ɠitoo ná-maanɔɠɔi zu.
\b
\q1 
\v 8 Laalao è ɓɔɛ, è naati maalobo, niiti ti la zooga ti ʋa ɓɔɛ,
\q1 è naati kpein maalogi wo, niiti kɛlɛbai wogai ga tiye.
\q1 
\v 9 Laalao è ɓɔɛ, è tukpɔi ɠaaleʋe ga telebodai,
\q1 è maanɔɠɔi nui maalobo ta bala nui.
\ms1 Anzanu zɔɓelamai ná-fai
\q1 
\v 10 Undaanɛ nu ɠa ga naa, nii a anzanu zɔɓelamai zɔlɔɔ,
\q1 tosuʋɛ wɔɔlɔʋɛ kɔbu ani ʋagɔiti sɔngɔi ʋa.
\q1 
\v 11 Sinigi laaʋɛ da,
\q1 ani ʋagɔ nɔpɛ ge la ʋalaga ná-pɛlɛi wu.
\q1 
\v 12 É la ɗa ga kazemazu vaa nɔpɛ kɛ ga sinigi,
\q1 kɛni faa ʋagɔi nɔ, sii ma voloiti pɛ su.
\q1 
\v 13 Toɠa ɗa baala deɠai ɠaiziɛ ta gezei,
\q1 é ɗa boti ɠɛ ga zeeiti ga koozunɛɛi.
\q1 
\v 14 Eɠɛ yaaɠo ɓatoi,
\q1 toɠa ɗa zeɠe ga ɠɔnɔgi ɠoozama.
\q1 
\v 15 Toɠa ɗa wuzeɠe ga kpidiɓidigi,
\q1 é daamianigi ve ná-pɛlɛyeɠei ya,
\q1 é ná-deveiti fe ná-botiɠɛ anzanuiti zea.
\q1 
\v 16 É ɠisiɛ kpalagi ta zu, é geya,
\q1 é leezɛn ɓelei leʋe ba, ga ná-botii zulɔnɔgi.
\q1 
\v 17 Toɠa ɗa botii ɠɛ ga suvikɛi pɛ,
\q1 zea la ʋalaga ɠɔ.
\q1 
\v 18 Toɠa pɛtɛsu ga zeavaiti su ɠa ɓɛtɛzu,
\q1 toɠa ɗa ɠaazuɓa, é ɗa botii ɠɛ kpidii, abu zezei ɠa.
\q1 
\v 19 Toɠa ɗa kenagi zo ga yeei, é ɗa gezei ɓali,
\q1 é kena kpakui zo ga yeeɓeɠaiti.
\q1 
\v 20 Zeei maalegɛ maanɔɠɔ nuiti ta-ɓɔba vai ma,
\q1 toɠa ga faanɛɛ ɠɛ nu bala nuiti bɛ.
\q1 
\v 21 É la lua kɔɔlɛ ʋa, é ʋilɛ ná-pɛlɛi ʋa,
\q1 tɔɔzei seɠe ʋagɔiti ta ti pɛ zea.
\q1 
\v 22 Toɠa ɗa dasuzeɠeiti kpɛtɛ tɔ ɓɔɠɔi,
\q1 geze ɓɔi seɠeiti\f + \fr 31:22 \fq geze ɓɔi seɠeiti\ft : Seɠe zɔngɔ ɓaaɓaagiti kɛɛni ga tiye, ti ɠɛni ga zobodai ma ʋoogi.\f* ta zea.
\q1 
\v 23 Sinigi ɠa ga seizumaanɛgi ɛsɛ pɛ ge kwɛɛ, ti ɗa unfe ma,
\q1 tiya ɠa ta ɗa zei taa vaawo bosuʋɛti.
\q1 
\v 24 Toɠa ɗa seɠeiti fɛlɛ, é ɗa ti ʋɔdi,
\q1 é ɗa saamaɠiligiti fe yaaɠoiti zea.
\q1 
\v 25 Zɛbɛi ta unfemai, ta bɛ ga maaɠili zɔɔlai,
\q1 toɠa ɗa ɲɛɛ laa ɠakama, a ɠɛna ɠisiaa ʋelela ʋele vaiti su.
\q1 
\v 26 Toɠa ɗa ɓɔɛ ga ɠimalai,
\q1 soogɛ kalagi wosu ga wooɠɛɠiladai.
\q1 
\v 27 Toɠa ɗa wɛlɛ fai kpein ma, é ziɛzu ná-pɛlɛyeɠei wu,
\q1 é la looɠoga botii ʋa.
\q1 
\v 28 Ná-dointi ta ɗa wuzeɠe, ti ʋa ti ɗa maamusɛ.
\q1 Maamusɛ vai ɠa ɗa ɠɛ ga guyei sinigi la.
\q1 
\v 29 É ɠɛ ma: «Anzanui mɔinʋɛ, ti-losuʋɛti bɔɔlɔai,
\q1 kɛlɛ ɗɔun ɗa, è ɓudɛʋɛ ti pɛ maazu.»
\q1 
\v 30 Zaalai ɠa ga yaava ani, padai ɠa ɗa leʋe,
\q1 kɛlɛ anzanui é luazu Ɠɔoɠɔ GALAGI ʋa, naa ɠa maanɛai ga é maamusɛi zɔlɔɔ.
\q1 
\v 31 À kpɔlɔzuʋɛ ma lɔnɔgi ve zea!
\q1 Wo maamusɛ vaiti bo, taazuʋɛ ɲɛgɛlɛin é ʋilɛ kɛɛwotiiti pɛ ba!
