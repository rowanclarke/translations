\id GAL  
\ide UTF8
\h Galatalani 
\toc1 Pauluni Dakani jaura Galatalani 
\toc2 Galatalani 
\toc3 Gal 
\mt1 Pauluni Dakani jaura Galatalani.  
\c 1  
\p
\v 1 Paululu, Apostel wata kanandru, bakana wata kana kulnujeli, a‐ai, Jesu Christujeli, ja Goda Ngaperali, Nulia ninaia narindru jiritjibana wonti,   
\p
\v 2 Ja ngatata pratjanali, tana ngakangu jela nganai, mili wolaraia Galatiani.   
\p
\v 3 Manjula jurangunto nganaiatimai, ja murla Goda Ngaperandru ja ngaianani Kapara Jesu Christungundru,   
\p
\v 4 Nauja munta jinkiterina wonti ngaianani madlentjandru, Nulia ngaianana kulkananto nunkangupini miljaru madlentjandru Godaia ja ngaiananaia Ngaperaia jertapaterinandru,   
\p
\v 5 Nunkangu pirnala nganaiatimai milingeru ja ngurali. Amen!   
\p
\v 6 Ngani ngaruparai, ngangau jura walto nganai, tanali jurana karkarkanani nunkangundru, Nulia jurana karkana wonti Christuni manjulani, ngantjani jaura pilkia,   
\p
\v 7 Ja wata pilki parai; windri palpa naka nganai, tanali jurana tjautjau ngankai, ja jertapateriai Christuni ngantjani jaura karitjimalkala.   
\p
\v 8 Bakana ngaiani kara, angela kulno pariwilpandru kara, jurangu ngantjani jaura pilki kaukaubanani nunkangu, ninaia ngaiani jurangu matja kaukaubana, nunkangu kalala madlentji pantjiatimai.   
\p
\v 9 Worderu ngaiani ngopera jatana wonti, jeruja bakana ngani karari nakaldra jatai: Kulnujeli jurangu ngantjani jaura pilki kaukaubanani nunkangu, ninaia jura matja manina, nunkangu kalala madlentji pantjiatimai.   
\p
\v 10 Ngato karari kana kara Goda kara ngakangu murlali ngankai? Ngato ngantjai kara, kanani murlali ngamala? Ngato ngantjanani kanani murlali ngamala, ngani wata Christuni mili ngananani.   
\p
\v 11 Ngato jurangu tinkari ngankai, ngatata worajai, naupini ngantjani jaura, ninaia ngato kaukaubala wapaia, wata kana nguja jeribaka nganai.   
\p
\v 12 Ngangau bakana ngato ninaia wata kana kulnundru manina wonti ja kiririna wonti, a‐ai, Jesuni Christuni tinkari ngankanali.   
\p
\v 13 Jura ngarana warai, worderu ngani waru Juda kana ngujangujarani wirarina wonti, worderu ngani Godaia mili wolarani pirna tirikaripaterina wonti, ja tanana piltjaru ngankana wonti,   
\p
\v 14 Ja worderu ngani Juda kana ngujangujarani morla pirnarina wonti ngampu marapuni ngakani marduni, ngangau ngani morla pirna jigleri nganana wonti ngakanaia ngaperaia jirijiribani jaurandru.   
\p
\v 15 Jendranguta Godali ngantjana wonti, Nulia ngana tjirimalkana wonti ngandri palkundru, ja karkana wonti manjulali nunkanali,   
\p
\v 16 Ngakangu Ngatamura nunkani tinkari ngankala, ninaia ngato kana koni kaukaubananto; ja nurujeli ngato wata palkuni ja kumarani jela ngankamalina wonti;   
\p
\v 17 Ngani bakana wata Jerusalemia tarana wonti tanangu, tana ngakangu ngopera Apostel ngananala, a‐ai, ngani Arabiaia palkana wonti, ja nakaldra Damaskuja tikana kurana wonti.   
\p
\v 18 Kilpawoldra parkulani ngadani, ngani Jerusalemia tarana wonti Petrus najila, ja nunkangu jela ngani ditji marapratjana ja mara wora ngamana wonti.   
\p
\v 19 Apostel kulno morla ngato wata najina wonti, windri Jakobus Kaparaia ngatata.   
\p
\v 20 Mina ngato jurangu dakala wapaia, mai, jenia ngani Godaia mudlani jatai, ngani wata jediai.   
\p
\v 21 Ngadani ngani Syria ja Cilicia mitani wokarana wonti.   
\p
\v 22 Judaia mili wolarali Christungu ngana mudla wata najina wonti;   
\p
\v 23 Tanali windri ngarana wonti: Nulupini, nulu ngaianangu ngopera tirikaripaterinala, karari morlalu ngundrani kaukaubai, ninaia nulu ngopera piltjaru ngankanala;   
\p
\v 24 Ja tanali Goda jurakokana wonti ngakangundru.   
\c 2  
\p
\v 1 Kilpawoldra marapratjana ja mandru mandruni ngadani, ngani nakaldra Jerusalemia tarana wonti Barnabas jelalu, ja ngato bakana Titus wapalkana wonti.   
\p
\v 2 Ngani tarana wonti tinkari ngankana kulnundru, ja tanangu ngantjani jaura kurana wonti, ninaia ngato kaukaubai kana koni; pilki ngato ninaia kurana wonti kaparani, ngani wata baku mindriai kara, mindrina warai kara.   
\p
\v 3 Tana bakana wata Titus, nau ngakangunto ngananala, ja Griekala nganai, jupana wonti, karuwalila pantjinanto.   
\p
\v 4 Jenia pantjina wonti jedikantji ngatatandru, tana watawatali wirina wonti, ngaianini kurakani ngulukala, ninaia ngaiani ngamalkai Christungu Jesungu, tanali ngaiania mili ngankananto.   
\p
\v 5 Tanangu ngaiani wata ditji wordu ngadatikana wonti, ngaiani tanangu pankinanto; ngangau ngantjani jauraia morlaluta ngurunguru jurangu parananto.   
\p
\v 6 Tanangundru, tana kapara nganana wonti — mina kana tana nganana wonti jenia ngakangu baku nganai, ngangau Godali wata kana mudla ngundrai — ngakangu tanali kaparali wata ngujangujara pilki jinkina wonti.   
\p
\v 7 A‐ai, tanali matja najina, ngato ngantjani jaurali karuwalila panini manina wonti, worderu Petrulu karuwalilali.   
\p
\v 8 (Ngangau Naupini, Nauja Petrungu ngurunguru nganana wonti Apostel ngamalkijiribanani karuwalilaia, Nauja bakana ngakangu ngurunguru nganana wonti kana koja.)   
\p
\v 9 Ja tanali manjula matja ngujamana, ninaia ngato maninala, Jakobulu ja Kephali ja Johannili, tanana tanali mardapantja ngundrana wonti, ngakangu ja Barnabangu jelarini mara ngunari jinkina wonti, jeruja ngali kana koni, ja tanali karuwalilani wapananto.   
\p
\v 10 Ngali windri wangiwangila ngundrananto, jenia ngani matja jigleri nganana ngankala.   
\p
\v 11 Petrus Antiochiani matja wokaranani, ngato nunkangu mudlani tjakakana wonti, ngangau tana nunkangu ngulkuterkanala.   
\p
\v 12 Ngangau nau morla ngopera, Jakobuni mili wokaranani, nulu kana koni jela tajina wonti; tana matja wokaranani, nau kutingana wonti ja pilkiringana wonti japali tanangundru, tana karuwalilandru.   
\p
\v 13 Ja nunkangu jela bakana Juda kana palpa morla jeljujeljurina wonti, jeruja tanali bakana Barnabas parumana wonti tanani jeljujeljundru,   
\p
\v 14 Ngato matja najina, tana wata palto talkuni wirariai ngantjani jauraia morlalulani, ngani Petrungu pratjanani mudlani jatana wonti: Jidni, jidni Juda kana ngananani, ja kana ko jeribaka ngamanani, ja wata Juda kana jeribaka, minandru jundru kana ko tertabai, Juda kana jeribaka ngamala?   
\p
\v 15 Ngaiani matja Juda kana, ja wata kana madlentji kana kondru,   
\p
\v 16 Ngangau ngaiani milkila, kana wata talku pantjila ngana, jirijiribani jauraia ngankanandru, a ai, windri morlalu ngundranandru Jesungu Christungu, jeruja ngaiani bakana Jesungu Christungu morlalu ngundrana wonti, jeruja ngaiani talku pantjinanto morlalu ngundranali Christungu, ja wata jirijiribani jauraia ngankanandru; ngangau jirijiribani jauraia ngankanandru wata kana kulno talku pantjila nganai.   
\p
\v 17 Ngaiani wontinani Christungu talku pantjila, ja munta kana madlentji ngamanani, jeruja Christus madlentjaia mili nganai, a‐ai.   
\p
\v 18 Ngangau ngato jenia, mina ngato tampuribana warai, nakaldra wotinani, jeruja ngani munta dankaranietja wondrateriai.   
\p
\v 19 Ngani jirijiribani jaurali jirijiribani jaurani palina warai, ngangau ngani Godani tepirinanto; ngani Christungunto kunarkuni katila wapaia.   
\p
\v 20 Ngani tepi nganai, ja wata morla ngani, a‐ai, Christus ngakangu tepi nganai. Mina ngani karari palkuni tepiriai, jenia ngani tepiriai morlalu ngundranali Godaia Ngatamurani, Nulia ngana ngantjana wonti ja munta ngakangu jinkiterina wonti.   
\p
\v 21 Ngato Godaia manjula wata worarai; ngangau talkula jirijiribani jaurali wokaranani, Christus baku palina wonti.   
\c 3  
\p
\v 1 Jura Galatala worajai, warle jurana kunki manina warai, jura morlalutani wata pankinanto? Jurangu milkini ngato Jesus Christus kunarkula kurana wonti.   
\p
\v 2 Ngato ngantjai windri jenia jurangundru ngujamala: Jura Jaola jirijiribani jauraia ngankanandru maninala kara, morlalu ngundranaia kaukaubanandru kara?   
\p
\v 3 Jeruja patipati jura nganai? Jura Jaolali matja wonina, jura palku tunkali mudananto?   
\p
\v 4 Jeruntjaia jura bakujeli ketjaketjana warai? Ja jenia baku ngananani!   
\p
\v 5 Nulupini, Nulia jurangu Jaola jinkiai ja pirnala jurangu ngankai, Nulia jenia ngankai jirijiribani jauraia ngankanandru kara, morlalu ngundranaia kaukaubanandru kara?   
\p
\v 6 Worderu Abrahamali Godani ngundrana wonti, ja Nulia jenia nunkangu talkulani ngokana wonti.   
\p
\v 7 Jeruja ngujamanau, tana morlalu ngundranandru nganai, tana Abrahamani ngatamura nganai.   
\p
\v 8 Ngangau Godaia jaurali jenia ngopera najina wonti, Godali morlalu ngundranali kana ko talku ngankala nganai; jeruja Nulia Abrahamangu talpadakani jaura jinkina wonti: „Jinkanalalani kana ko warupoto murlali pantjila nganai.“   
\p
\v 9 Jeruja tana, tana morlalu ngundranandru nganai, murlali pantjila nganai morlalu ngundranali Abrahamali jela.   
\p
\v 10 Ngangau jeruntja jirijiribani jauraia ngankanandru nganai kalalani ngamai; ngangau dakanala parai: „Kalala madlentji nunkangu, nau wata pratjanani wodatarana ngamai, mina jirijiribanaia dakanilani dakanala parai, jenia ngankala.“   
\p
\v 11 Morlalu nganai: Jirijiribani jaurali wata kulno talku pantjiai Godani; ngangau kana talku morlalu ngundranali tepirila nganai.   
\p
\v 12 Jirijiribani jaura wata morlalu ngundranandru nganai, a‐ai, warle ninaia ngankai, nau jendralia tepirila nganai.   
\p
\v 13 Christulu ngaianina jirijiribani jauraia kalalandru burungankana wonti, ngangau Nauja munta ngaianingu kalala pantjina wonti, ngangau dakanala parai: „Kalala madlentji nunkangu, nau pitani warukai.“   
\p
\v 14 Ngangau kana koni Abrahamanani murlaia poto wokarananto Christungu Jesungu, ngaiani Jaolaia talpadakanala maninanto morlalu ngundranali.   
\lit (Dakani jaura G. D. 13 Trinitatis.)  
\p
\v 15 Ngatata worajai, kana jeribaka ngani jatai: Wata kulnujeli ngurunguru nganai kanaia testamenta dukarala, nau matja dantjamana, minakulno ngokala kara.   
\p
\v 16 Abrahamangu Nulia talpadakani jaura jinkina wonti ja kupani nunkanani. Wata Nauja jatai: Kupa worani, marapuni jeribaka, a‐ai, kulnuni, kupani jinkanani, Naupini Christus nganai.   
\p
\v 17 Jenia ngani jatai: Testamenta kulno, nina Godali ngopera dantjamana wonti Christungu, jirijiribani jaura, nauja kilpawoldra 430 ngadani matja jinkina, wata walto ngankai, talpadakani jaura teribala.   
\p
\v 18 Ngangau maratunka jirijiribani jaurali wokaranani, jeruja wata morla talpadakani jaurali. Godali ninaia Abrahamangu talpadakani jaurali manjulandru jinkina wonti.   
\p
\v 19 Mina jirijiribani jaurali ngankananto? Dankaranandru Nulia ninaia ngokana wonti, ngatamura wokaranantulu, nunkangu talpadakani jaura pantjina wonti, ja angelali ninaia kurana wonti tertietjaia marali.   
\p
\v 20 Tertietja wata kulnuja tertietja nganai; Goda kulno nganai.   
\p
\v 21 Jirijiribani jaura Godaia talpadakani jaurani nganai? Aai. Ngangau jirijiribani jaura kulno jinkinani, nauja ngurunguru nganai tepi ngankala, jeruja talkula morlalu jirijiribani jaurandru wokarala nganai.   
\p
\v 22 Windri Godaia jaurali warupoto madlentjani ngurunguru ngankana wonti, ngangau talpadakani jaura morlalu ngundranali Jesungu Christungu pantjinanto tanangu, tanali morlalu ngundrai.  
\b  
\lit (Dakani jaura kilpawoldra marra ditjini.)  
\p
\v 23 Windrila morlalu ngundrani wokarananto, jirijiribani jaurali ngaianina ngamalkana wonti kanjangarila jeribaka morlalu ngundranaia, nauja tinkari pantjinanto.   
\p
\v 24 Jeruja jirijiribani jaura ngaianini ngankinganietja nganana wonti Christungu; ngangau ngaiani morlalu ngundranali talku pantjinanto.   
\p
\v 25 Morlalu ngundrani matja wokaranani, ngaiani wata morla ngankinganietjani nganai.   
\p
\v 26 Ngangau jura pratjana Godaia kupa nganai morlalu ngundranali Christungu Jesungu.   
\p
\v 27 Ngangau jura pratjana, jura multibanila manina wonti Christungu, jura Christus widmaterina wonti.   
\p
\v 28 Ninkida wata Juda kana ja wata Griekala nganai; wata mili ja wata kurakanila; wata materi ja wata widla; ngangau jura pratjana Kulno nganai Christungu Jesungu.   
\p
\v 29 Jura Christuni ngananani, jeruja jura bakana Abrahamani ngatamura nganai, ja maratunka maninietja talpadakani jaurandru.  
\b  
\c 4  
\lit (Dakani jaura Jesu dankani ditji Godaia ditjini kulno ngadani.)  
\p
\v 1 Ngani jatai: Jeruntja ditji maratunka maninietja kupa nganai, nau milini jeribaka nganai, ja kantji warupotuja kapara nau nganai;   
\p
\v 2 A‐ai, nau najinajibanietjani ja ngamalkanietjani ngamai, nunkangupini ditjielu, nina ngaperali kurana warai.   
\p
\v 3 Jeruja bakana ngaiani, ngaiani kupa ngananani, ngaiani jirijiribani jaurani dupudupu nganana wonti.   
\p
\v 4 Ditji matja wokaranani, Godali Ngatamura nunkani jinpana wonti, Nauja widlandru dankana wonti, ja Nulia ninaia jirijiribani jauraia ngalpani kurana wonti,   
\p
\v 5 Nulia tanana, tana jirijiribani jaurani ngalpani ngamanani, dukarana burungankananto, ngaiani kupalali maninanto.   
\p
\v 6 Ngangau jura ngatamura nganai, Godali Ngatamuraia Jaola ngaianini ngarani jinpana wonti, nulupini karkai: „Abba, Ngaperiai!“   
\p
\v 7 Jeruja jidni wata morla mili nganai, a‐ai, ngatamura. Jidni ngatamura ngananani, jeruja bakana Godaia maratunka maninietja Christungundru.  
\b  
\p
\v 8 Jendranguta, jura Goda wata ngujamana wonti, jura tanangupini Godani wodatarana ngamana wonti, tana jenia wata kantji nganai;   
\p
\v 9 Karari, jura Goda matja ngujamana, morla talku, Godali jurana matja ngujamana, minandru jura nakaldra karitjiai jirijiribani jaura wangiwangini ja waltowaltuni, ja ngantjai tanangu nakaldra wodatarana ngamala?   
\p
\v 10 Jura ditji ja pira ja miljaru ja kilpawoldra ngundrai;   
\p
\v 11 Ngani japali nganai jurangundru, ngato bakujeli jurangu matja ngankana warai kara.   
\p
\v 12 Ngakangu jeribaka pantjianau, ngangau ngani jurangu jeribaka nganai, ngatata worajai, ngani jurangu ngantjai, jura ngana wata ngaurongauro ngankana warai;   
\p
\v 13 Jura milkila, ngato palkuja waltowaltundru jurangu ngopera ngantjani jaura kaukaubana wonti,   
\p
\v 14 Ja jura ngana, wontjanilandru ngakangu, palkuni wata waka ngundrana wonti ja wata ngirkibana wonti, a‐ai, jura ngana Godaia angela jeribaka patana wonti, Christus Jesus jeribaka.   
\p
\v 15 Worderu murlali pirna jura jendranguta nganana wonti. Ngato jurangu morlalu kurai, jenia wata ngandandarinani, jura jendranguta jurani milki dukaraterinala ja ngakangu jinkinala.   
\p
\v 16 Ngani jendrangundruja talpala jurani pantjina warai, ngangau ngani jurangu morlaluta jatana wonti?   
\p
\v 17 Tanali jurangundru wata ngumu manabakapirna ngankai, a‐ai, tanali ngantjai jurana puntibala, jura tanangundru manabakapirna ngankananto.   
\p
\v 18 Manabakapirna ngumu nganai, jenia ngumuni milingeru pantjinani, ja wata windri, ngani jurangu jela ngananani.   
\p
\v 19 Ngakani kupa worajai, tanangundru ngato nakaldra dankani ketjaketjana ketjaketjai, Christus jurangu mudlamalka pantjinantulu.   
\p
\v 20 Ngato ngantjai karari jurangu jela ngamala, ja ngakani ngaiala karitjimalkala; ngangau ngani wurpuru nganai jurangundru.   
\lit (Dakani jaura Lätare ditjini.)  
\p
\v 21 Ngakangu jatanau, jura jirijiribani jauraia ngalpani jertapateriai ngamala, jura jirijiribani jaura wata ngarai?   
\p
\v 22 Ngangau dakanala parai: Abrahamali ngatamura mandru ngamalkana wonti; kulno widlala milila, ja kulno kurakanilali.   
\p
\v 23 Nau widlala milila palkujeli kantji patana wonti; ja nau kurakanilali talpadakani jaurali.   
\p
\v 24 Nulupini minakulno wondrai; ngangau jenia Testamenta mandru nganai. Kulno Sinai mardawonpandru, milieli dankanaia, naupini Hagar nganai.   
\p
\v 25 Ngangau Arabiala Sinai mardawonpa Hagar dikai, ja jeribaka nganai nunkangupini Jerusalem karari, ngangau nau mili nganai nunkani kupanto.   
\p
\v 26 Jerusalem miri kurakanila nganai; ja naupini ngaiananaia pratjanaia ngandri nganai.   
\p
\v 27 Ngangau dakanala parai: Mankiau ngameriai, jundru wata dankai; jurakokau ja karkau, jundru wata mandrantju pantjiai. Ngangau ngameri morla kupa ngamalkai nankangu, nandru noa ngamalkanani.   
\p
\v 28 Jura, ngatata worajai, Isaakani nguja nganai; talpadakani jauraia kupa.   
\p
\v 29 Worderu jendranguta, nau palkujeli dankana wonti, nunkangu, nau jaolali dankana wonti, tirikaripaterina wonti; jeruja bakana karari.   
\p
\v 30 Mina Godaia jaura jatai? „Mili widla nankani ngatananto narrau, ngangau mili widlaia ngatanajeli wata maratunka maninanto kurakanilaia ngatanajeli jela.“   
\p
\v 31 Jeruja, ngatata worajai, ngaiana wata mili widlaia ngatani nganai, a‐ai, kurakanilaia.  
\b  
\c 5  
\p
\v 1 Christulu ngaianana kurakana wonti kurakanilaia. Ngurunguru terkanau, tanali jurana nakaldra mili wokara pitaia pataiati.   
\p
\v 2 Mai, ngani Paulus jurangu jatai; Jura karuwalila pantjinani, Christus jurangu baku ngananani.   
\p
\v 3 Ngato kana pratjanani nakaldra tinkari ngankai, tana karuwalila pantjinani, tana wilpa nganai jirijiribani jaura pratjana ngankala.   
\p
\v 4 Jura Christungundru puntina warai, jura jertapaterinani jirijiribani jaurali talku pantjila; manjulandru jura purina karuwana warai.   
\p
\v 5 Ngaiana Jaolani wolkareli kalkai talkulaia kalkani morlalu ngundranali.   
\p
\v 6 Ngangau Christungu Jesungu karuwalila kara karuwalila pani kara ngurunguru nganai minakulno ngankala, a‐ai, windri morlalu ngundranali, nulia ngantjanali ngankai.   
\p
\v 7 Jura ngumu mindrina wonti. Warle jurana ngandrawalkana warai morlalulani wata pankinanto?   
\p
\v 8 Naupini karkarkana wata nunkangundru nganai, Nulia jurana karkana wonti.   
\p
\v 9 Pulkurutjeribani buka ngaljejeli buka tjanka pratjana pulkurutjeribai.   
\p
\v 10 Ngato Kaparani morlalu ngundrai jurangundru, jura wata pilki ngundrala nganai. Nulia jurana tjautjau ngankana warai, kalala nunkani manila nganai, worananau nganai kara.   
\p
\v 11 Ngatata worajai, ngato bakana karari karuwalila kaukaubanani, minandru tana ngakangu kararielu tirikaripateriai? Jeruja bakana kunarkuja kintjakintjarina mudana warai.   
\p
\v 12 Tana bakana tapatapa ngankaterinanto, tanali jurana patijiritjibai!   
\p
\v 13 Ngangau Nulia jurana karkana wonti kurakanaia, ngatata worajai, windri ngamalkaterianau, jura kurakanali wata palkuni piri jinkinanto, a‐ai, ngantjanali mili ngankijiribamalianimai.   
\p
\v 14 Ngangau jirijiribani jaura pratjana jaura kulnujeli manamiri pantjiai nunkangu: Ngurala jinkani ngantjamai jidni munta jeribaka.   
\p
\v 15 Jura matamalinani ja tajimalinani; ngamalkaterianau jura julkamaliati.   
\lit (Dakani jaura G. D. 14. Trinitatis.)  
\p
\v 16 Ngani jatai: Jaolani wirarianau, jeruja jura palkuja milkirina wata ngankala nganai.   
\p
\v 17 Ngangau palku milkiriai Jaolani, ja Jaola palkuni; ngangau pudla dilpamaliai; jeruja jura wata ngankananto, mina jura jertapateriai.   
\p
\v 18 Jaolali jurana tertabanani, jura wata jirijiribani jaurani ngalpani nganai.   
\p
\v 19 Palkuja ngankana tinkari nganai jenia: Pinta wokaribana, palakantji, murumuru, ninta nguru ngamana,   
\p
\v 20 Muramurani wodatarana ngamana, kunki manina, kalakalarilkijiribamalina, jatamalina, mandrakarua, tiri, mudlawariwari, puntibana, delkina, ngukingukibaterina, nari ngankana,   
\p
\v 21 Parawarala tapana, mirantjatieli tajina, ja jenia morla: tanangu madlentji marapundru ngani jurangu jatai, worderu ngani jurangu ngopera jatana wonti; tanali jenia ngankanani Godaia milila wata maratunka manila nganai.   
\p
\v 22 Jaolaia tandra nganai: Ngantjana, mankina, murla, manju, murlali, ngumula, talku ngundrana, malti, kulikiri ngamana.   
\p
\v 23 Tanangupini wata jirijiribani jaura nganai.   
\p
\v 24 Tanapini Christungu nganai, tanali palku matja kunarkuni katibana warai nunkani madlentjanto ja milkirinani jela.  
\b  
\lit (Dakani jaura G. D. 15. Trinitatis.)  
\p
\v 25 Ngaiana Jaolali tepi ngamanani, ngaiana bakana Jaolani wirarinanto.   
\p
\v 26 Wata ngaiana pirna ngundraterina baku wontinanto junka ngankijiribamalila ja kalakalarilkijiribamalila.   
\c 6  
\p
\v 1 Ngatata worajai! Kana kulno mangapunkujeli tjikatjikarinani, jeruja juranina, ngangau jura Jaolandru nganai, maltieli talku ngankanau; ja jidni munta ngamalkateriau, bakana jidni wontjanilani wiriati.   
\p
\v 2 Juditji waltijiribamalianau, jeruja jura Christuni jirijiribani jaurani pankila nganai.   
\p
\v 3 Kulnujeli ngundranani minakulno nganala, windri nau panila nganai, nau munta jedibateriai.   
\p
\v 4 Kana pilkipilkieli ngankana nunkani winpananto; jeruja nau windri munta pirna ngundraterila nganai, ja wata kulno nguruni.   
\p
\v 5 Ngangau pilki ja pilkieli juditji nunkani mandrala nganai.   
\p
\v 6 Ja warle ngujangujara maniai Godaia jaurali, nulupini ngumula pilki ja pilki jinkinanto nunkangu, nulu nunkangu ngujangujara jinkiai.   
\p
\v 7 Wata jedibaterianau, kanali Goda wata ngirkibala nganai; ngangau mina kanali jaupai, jenia nulu bakana kampala nganai.   
\p
\v 8 Warlenulu nunkani palkuni jaupai, nulu palkundru tintaterina kampala nganai; ja warlenulu Jaolani jaupai, nulu Jaolandru tepi ngurali kampala nganai.   
\p
\v 9 Ngaiana wata walturinanto ngumu ngankala, ngangau ditji talkuni ngaiana kampala nganai, ngaiana wata walturinani.   
\p
\v 10 Jendrangundruja karari, ngangau ngaiana ditji ngamalkai, ngaiana ngumu ngankananto warupotuni, ja morla pirna morlalu ngundranaia pungalani.  
\b  
\p
\v 11 Najianau! Dakani malka pirnali ngato jurangu dakana warai marali ngakanali.   
\p
\v 12 Jeruntjaiali ngantjai ngumu wondraterila palkuni, tanali jurana jupai karuwalila pantjila, tanali tanangu Christuni kunarkundru wata tiri karipaterinanto.   
\p
\v 13 Bakana karuwalila wata jirijiribani jaurani pankiai, a‐ai, tanali windri ngantjai, jura karuwalila pantjinanto, tana jurani palkundru jurakokaterinanto.   
\p
\v 14 Ngakangu worita nganaiatimai jurakokaterila, windri ngaiananaia Kaparaia Jesuni Christuni kunarkundru, nunkangundru ngakangu mita warupoto ja ngani mitani kunarkuni katiai.   
\p
\v 15 Ngangau Christungu Jesungu karuwalila kara karuwalila pani kara minakulno nganai, a‐ai, pantjimani kana marra:   
\p
\v 16 Ja jeruntjaia nunkangupini malkani wirarinani, tanangu murla ja kalumiltjamiltjarina nganaiatimai Godaia Israelani.   
\p
\v 17 Kararindru wata kulnujeli ngana jupaiatimai, ngangau ngato Jesuni tjinpiri ngakangu palkuni mandrai.   
\p
\v 18 Ngaiananaia Kaparaia Jesuni Christuni manjula jurangu jaolani nganaiatimai, ngatata worajai! Amen.   