\p
\v 13 \w Y|strong="H3068"\w* le dio \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, Quien \w hablaba|strong="H1696"\w* \w con|strong="H3588"\w* ella, \w este|strong="H1988"\w* \w nombre|strong="H8034"\w*: Tú eres \w el|strong="H3588"\w* \nd \+w ʼEL|strong="H3588"\+w*\nd*-que-me-ve, \w porque|strong="H3588"\w* \w dijo|strong="H1696"\w*: ¿\w No|strong="H3588"\w* \w vi|strong="H7200"\w* \w aquí|strong="H1988"\w* \w yo|strong="H3588"\w* \w la|strong="H1571"\w* espalda \w de|strong="H3588"\w* Aquél \w que|strong="H3588"\w* \w me|strong="H3588"\w* \w ve|strong="H7200"\w*?  
\v 14 \w Por|strong="H5921"\w* \w eso|strong="H3651"\w* \w llamó|strong="H7121"\w* \w al|strong="H5921"\w* pozo: Pozo \w del|strong="H5921"\w* Viviente-que-me-ve. Ahí \w está|strong="H3651"\w* \w entre|strong="H5921"\w* \w Cades|strong="H6946"\w* \w y|strong="H5921"\w* \w Bered|strong="H1260"\w*.   
\p
\v 15 \w Agar|strong="H1904"\w* dio \w a|strong="H3068"\w* luz un \w hijo|strong="H1121"\w* \w a|strong="H3068"\w* Abram, y Abram \w llamó|strong="H7121"\w* \w Ismael|strong="H3458"\w* al \w hijo|strong="H1121"\w* \w que|strong="H1121"\w* \w Agar|strong="H1904"\w* le dio \w a|strong="H3068"\w* luz.  
\v 16 Abram tenía 86 \w años|strong="H8141"\w* cuando \w Agar|strong="H1904"\w* le dio \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* \w Ismael|strong="H3458"\w*.   
\c 17  
\s1 La señal del Pacto  
\p
\v 1 Abram \w tenía|strong="H1961"\w* 99 \w años|strong="H8141"\w* \w cuando|strong="H1961"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w se|strong="H1961"\w* le \w apareció|strong="H7200"\w*, y le dijo: \wj Yo \+w soy|strong="H1961"\+w* \+nd ʼEL-Shadday\+nd*. \+w Anda|strong="H1980"\+w* \+w delante|strong="H6440"\+w* \+w de|strong="H6440"\+w* \+w Mí|strong="H1961"\+w* y \+w sé|strong="H1961"\+w* \+w perfecto|strong="H8549"\+w*.\wj*  
\v 2 \wj Estableceré mi \+w Pacto|strong="H1285"\+w* entre Yo y tú, y te \+w multiplicaré|strong="H7235"\+w* muchísimo.\wj*   
\p
\v 3 Entonces Abram \w se|strong="H5921"\w* postró \w sobre|strong="H5921"\w* su \w rostro|strong="H6440"\w*. \nd ʼElohim\nd* \w le|strong="H5921"\w* \w habló|strong="H1696"\w*:  
\v 4 \wj \+w Mira|strong="H2009"\+w*, establezco \+w mi|strong="H2009"\+w* \+w Pacto|strong="H1285"\+w* contigo: \+w Serás|strong="H1961"\+w* padre de una \+w multitud|strong="H1995"\+w* de \+w pueblos|strong="H1471"\+w*.\wj*  
\v 5 \wj Tu \+w nombre|strong="H8034"\+w* ya \+w no|strong="H3808"\+w* \+w será|strong="H1961"\+w* Abram, \+w sino|strong="H3588"\+w* Abraham, \+w porque|strong="H3588"\+w* \+w te|strong="H3588"\+w* constituí padre \+w de|strong="H3588"\+w* una \+w multitud|strong="H1995"\+w* \+w de|strong="H3588"\+w* \+w pueblos|strong="H1471"\+w*. \wj*   
\p
\v 6 \wj \+w Te|strong="H4480"\+w* \+w haré|strong="H5414"\+w* \+w muy|strong="H3966"\+w* fecundo. \+w Haré|strong="H5414"\+w* \+w naciones|strong="H1471"\+w* \+w de|strong="H4480"\+w* \+w ti|strong="H4480"\+w*, y \+w de|strong="H4480"\+w* \+w ti|strong="H4480"\+w* \+w saldrán|strong="H3318"\+w* \+w reyes|strong="H4428"\+w*.\wj*   
\p
\v 7 \wj Yo establezco \+w mi|strong="H1961"\+w* \+w Pacto|strong="H1285"\+w* entre Yo y tú, y \+w después|strong="H1961"\+w* de ti con tu \+w descendencia|strong="H2233"\+w* en sus \+w generaciones|strong="H1755"\+w* \+w como|strong="H1961"\+w* \+w alianza|strong="H1285"\+w* \+w perpetua|strong="H5769"\+w*, \+w para|strong="H1961"\+w* ser el \+nd ʼElohim\+nd* tuyo y \+w a|strong="H3068"\+w* tu \+w descendencia|strong="H2233"\+w*.\wj*  
\v 8 \wj Te \+w daré|strong="H5414"\+w* \+w por|strong="H5769"\+w* posesión \+w perpetua|strong="H5769"\+w* \+w la|strong="H3605"\+w* tierra \+w de|strong="H5414"\+w* tus peregrinaciones, \+w toda|strong="H3605"\+w* \+w la|strong="H3605"\+w* tierra \+w de|strong="H5414"\+w* \+w Canaán|strong="H3667"\+w*, y \+w a|strong="H3068"\+w* tu \+w descendencia|strong="H2233"\+w*. \+w Y|strong="H3068"\+w* \+w seré|strong="H1961"\+w* su \+nd ʼElohim\+nd*.\wj*   
\p
\v 9 Además \nd ʼElohim\nd* dijo \w a|strong="H3068"\w* Abraham: \wj Tú \+w guardarás|strong="H8104"\+w* mi \+w Pacto|strong="H1285"\+w*, tú y tu \+w descendencia|strong="H2233"\+w* en sus \+w generaciones|strong="H1755"\+w*.\wj*  
\v 10 \wj \+w Éste|strong="H2063"\+w* \+w es|strong="H2063"\+w* mi \+w Pacto|strong="H1285"\+w* entre Yo y ustedes, \+w el|strong="H3605"\+w* cual \+w guardarán|strong="H8104"\+w* tú y tu \+w descendencia|strong="H2233"\+w*: \+w Que|strong="H3605"\+w* \+w todo|strong="H3605"\+w* \+w varón|strong="H2145"\+w* entre ustedes sea \+w circuncidado|strong="H4135"\+w*.\wj*   
\p
\v 11 \wj Circuncidarán sus \+w prepucios|strong="H6190"\+w*, y \+w esta|strong="H1961"\+w* \+w será|strong="H1961"\+w* la señal del \+w Pacto|strong="H1285"\+w* entre Yo y ustedes.\wj*  
\v 12 \wj \+w Todo|strong="H3605"\+w* \+w varón|strong="H2145"\+w* \+w entre|strong="H3808"\+w* ustedes en \+w todas|strong="H3605"\+w* \+w sus|strong="H1931"\+w* \+w generaciones|strong="H1755"\+w* \+w será|strong="H1931"\+w* \+w circuncidado|strong="H4135"\+w* \+w a|strong="H3068"\+w* \+w los|strong="H1121"\+w* \+w ocho|strong="H8083"\+w* \+w días|strong="H3117"\+w* \+w de|strong="H1121"\+w* \+w nacido|strong="H3211"\+w*, tanto \+w el|strong="H1931"\+w* \+w nacido|strong="H3211"\+w* en \+w casa|strong="H1004"\+w*, \+w como|strong="H1931"\+w* \+w el|strong="H1931"\+w* \+w comprado|strong="H4736"\+w* con \+w dinero|strong="H3701"\+w* \+w a|strong="H3068"\+w* \+w cualquier|strong="H3605"\+w* \+w extranjero|strong="H5236"\+w* \+w que|strong="H1931"\+w* \+w no|strong="H3808"\+w* sea \+w de|strong="H1121"\+w* tu \+w descendencia|strong="H2233"\+w*.\wj*  
\v 13 \wj Ciertamente \+w será|strong="H1961"\+w* \+w circuncidado|strong="H4135"\+w* el \+w nacido|strong="H3211"\+w* en tu \+w casa|strong="H1004"\+w* y el \+w comprado|strong="H4736"\+w* con tu \+w dinero|strong="H3701"\+w*. \+w Mi|strong="H1961"\+w* \+w Pacto|strong="H1285"\+w* \+w estará|strong="H1961"\+w* en su cuerpo \+w como|strong="H1961"\+w* \+w Pacto|strong="H1285"\+w* \+w eterno|strong="H5769"\+w*.\wj*  
\v 14 \wj Pero \+w el|strong="H1931"\+w* \+w varón|strong="H2145"\+w* \+w incircunciso|strong="H6189"\+w*, \+w que|strong="H1931"\+w* \+w no|strong="H3808"\+w* haya \+w circuncidado|strong="H4135"\+w* \+w su|strong="H1931"\+w* \+w prepucio|strong="H6190"\+w*, \+w será|strong="H1931"\+w* \+w cortado|strong="H3772"\+w* \+w de|strong="H5971"\+w* \+w su|strong="H1931"\+w* \+w pueblo|strong="H5971"\+w*. Quebrantó \+w mi|strong="H5315"\+w* \+w Pacto|strong="H1285"\+w*.\wj*   
\s1 Promesa con respecto a Isaac  
\p
\v 15 También \nd ʼElohim\nd* dijo \w a|strong="H3068"\w* Abraham: \wj \+w A|strong="H3068"\+w* tu esposa Saray \+w no|strong="H3808"\+w* \+w la|strong="H3588"\+w* \+w llamarás|strong="H7121"\+w* Saray, \+w sino|strong="H3588"\+w* \+w su|strong="H3588"\+w* \+w nombre|strong="H8034"\+w* \+w será|strong="H3808"\+w* \+w Sara|strong="H8283"\+w*.\wj*  
\v 16 \wj \+w La|strong="H1571"\+w* \+w bendeciré|strong="H1288"\+w* \+w y|strong="H1571"\+w* \+w también|strong="H1571"\+w* \+w te|strong="H4480"\+w* \+w daré|strong="H5414"\+w* un \+w hijo|strong="H1121"\+w* \+w por|strong="H4480"\+w* medio \+w de|strong="H4480"\+w* \+w ella|strong="H4480"\+w*. \+w Sí|strong="H1571"\+w*, \+w la|strong="H1571"\+w* \+w bendeciré|strong="H1288"\+w*. \+w Ella|strong="H4480"\+w* \+add será madre de\+add* \+w naciones|strong="H1471"\+w*. \+w Reyes|strong="H4428"\+w* \+w de|strong="H4480"\+w* \+w pueblos|strong="H5971"\+w* procederán \+w de|strong="H4480"\+w* \+w ella|strong="H4480"\+w*.\wj*   
