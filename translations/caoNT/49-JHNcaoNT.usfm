\id JHN - Chácobo NT -Bolivia 2010 (DBL -2013)
\h San Juan
\toc1 El Santo Evangelio Según San Juan
\toc2 Juan
\toc3 Jn
\mt2 El Santo Evangelio Según
\mt1 San Juan
\c 1
\s1 Bësomatí Chani
\p 
\v 1 Jariapari tsi Cristo, naa Chani icanai ca iniquë. Toatiyá tsi yama mai iniquë. Jabi Dios ya ja iniquë. Jasca, Dios ja iniquë ra, naa Chani inish cato.
\v 2 Jariapari tsi Dios ya ja iniquë.
\v 3 Jatiroha ca ja nëhohuayoniquë ra. Jasca, yama tsi toa ja ayamanina.
\v 4 Jatiroha ca ja bësomaniquë ra, Bësomati Ibo-iboria ja nori quëshpi na. Jasca, jatiroha ca nohiria qui huahuahi quiha jahuë Chani, jabija ca jismahi na.
\v 5 Tsëmó ca nohiria bo jabija ca Chani jismahai ca Huëa ca tsi xo naa ra. Jabi naa Huëa nocahuayama-pistiariaxëhi quiha tsëmo ra.
\s1 Dios Chani chitahënina
\p 
\v 6 Jatsi jahuë Chani bëhai ca Diós raaniquë, naa Juan icanai cato.
\v 7 Jesucristo, naa Huëa inish ca yoati tsi nohiria bo yoahi quiha Juan joniquë. Joxo tsi quiha Dios Chani ja yoaniquë, Huëa inish ca qui nohiria chitimino iquish na.
\v 8 Jabi Huëa inish ca Juan iyamaniquë. Jama, Huëa inish ca yoati chanihi quiha ja joniquë.
\v 9 Jabija ca Huëa-huëaria ca tsi xo toa mai qui jonish cato. Joxo tsi quiha jatiroha cabo qui jabija ca huahuahi quiha, nohiria bá Dios cahëno iquish na.
\p 
\v 10 Noba maí tsi quiha Chani icanai ca racaniquë; naa noba mai nëhohuanish cato. Jama, tsohuë ja iqui ca nohiria bá cahëyamaniquë rë.
\v 11 Jasca, jahuë maí ca nohiria bo, naa jodiobo qui ja joniquë. Ja joquë tsi quiha jahuë jimibá biyamaniquë pë. Jato qui yoi ja ini quiha.
\v 12 Jama, nohiria bá Chani icanai ca biquë tsi jato qui chama ja aniquë Dios baquë bo manëti. Jahuë baquë bo manëcani quiha Xabahamati Ibo ja nori ca ja chahahuacaquë no.
\v 13 Jatsi cotëquëhi quiha chahahuahi na. Jamëri tsi xo naa cohaina ra. Noba jahëhuá comahai ca jascaria ma xo ra. Nohiria jaha quëëhaina, bënë bá saihuacatsaina, nëca tsi quiha Dios baquë bo manëyamacani quiha. Jama, Dios tsi xo toa jato Comati Ibo-iboria.
\s1 Joni Jesu manënina
\p 
\v 14 Jabi joni naa Chani icanai ca manëniquë. Joni manëhax noqui xërëquë tsi quiha ja racaniquë. Jatsi jahuë oquë no jisniquë, naa ja qui jahuë Jahëpá acacanish ca oquë jiaxëni cato. Jasca, Dios baquë huësti ca ja iqui iqui tsi anomaria jahuë oquë ini quiha ra. Ja quëshpi tsi nohiria bo noiti cahëxëni ja ini quiha. Jasca, jabija ca chaniti cahëxëni ca ja ini quiha.
\v 15 Jabi Cristo yoati tsi Juan nëcaniquë:
\p —E cho joxëhi quiha ëa oquë cato. E conox pari no tsi ja iniquë. Jasca, mato qui ë yoani ca joni tsi xo naa —i Juan niquë Jesu yoati na.
\p 
\v 16 Anomaria tsi xo noqui Cristó noihaina ra. Ja noihai iqui tsi no shomahuariahacaniquë ra, naa noqui tëquëta.
\v 17 Jabi jariapari tsi quiha noqui jodiobo qui Moisés yamabá yoba aniquë. Noqui quësohi quiha toa yoba rë. Jama, mai qui Jesucristo joni iqui tsi Diós noqui noihaina, jahuë jabija ca Chani, tihi cabo cahëyoiqui noa ra.
\v 18 Yama tsi xo toa Dios jisnish cato. Jabi Dios noqui cahëmanish ca tsi xo toa jahuë Baquë yoi roha, naa Dios tahë cato.
\s1 Cristo yoati Juan chaninina
\r Mateo 3.11-12; Marcos 1.7-8; Lucas 3.15-17
\p 
\v 19 Jabi arati ibo bo, jato mëbicanaibo, tihi cabo quiha Jerusalén ca jodioba chama bá raaniquë Juan qui. Jato ja raacaniquë Xabahamati Ibo ja iqui ca nicati. Jatsi Juan ja nicacaquë tsi quiha,
\p 
\v 20 —Cristo, naa jaha ma pasohai ca Xabahamati Ibo ma xo ëa ra —i jato qui Juan niquë.
\p 
\v 21 Jatsi quiha,
\p —¿Tsohuë cara ni mia sa? ¿Elías ma ni mia ra? —i ja qui jaca niquë.
\p Jatsi quiha Juán quëbiniquë:
\p —Elías ma xo ëa —iquiina.
\p Jatsi,
\p —¿Diós raahai ca chani yoati Ibo-iboria ni mia sa? —i jaca niquë.
\p —Toa ma xo ëa ra —i Juan niquë.
\p 
\v 22 Jatsi quiha,
\p —¿Tsohuë cara ni mia ra? Noqui yoahuë, noqui raahax cabo no quëbino iquish na. ¿Japa mia ti? ¿Jënihai ra? —i quiha Juan qui jaca niquë.
\p 
\v 23 Jatsi Juán quëbiniquë:
\p —Xabachá ca quënahai ca ëa xo naa. Shomahuahacacahuë, Ibo johai ca bax na iquia ra. Jabi siri tsi quiha ëa yoati tsi Isaías yamabo, naa Dios Chani yoanish ca chaniniquë, naa ë conox pari no —nëa tsi Juan nëcaniquë.
\p 
\v 24 Jatsi quiha fariseobá raahacanish cabá nicatëquëniquë:
\p 
\v 25 —Johai ca Xabahamati Ibo, Elías, Dios Chani yoati Ibo-iboria, tihi cabo iyamapiquí tsi ¿jëniriaxo tsi nohiria bo ashimahai pa? —i ja qui jaca niquë.
\p 
\v 26 Jatsi quiha Juán jato quëbiniquë:
\p —Jënë́ tsi mato ashimaquia. Jama, mato xërëquë tsi bësohi quiha mato bëroma cato ra.
\v 27 E cho joxëhi quiha ëa oquëria cato. ¿Jënahuariahax raca ja bax ë yonocona rë, iriama ca ë nori quëshpi na? —nëa tsi bëcanish cabo qui Juan nëcaniquë.
\p 
\v 28 Jabi ani Jordán rabëquëxë, naa Betania mai icanish cató tsi quiha ja qui raahacanish cabo Juán quëbiniquë. Toa xo tsi quiha nohiria bo ashimahi ja iniquë.
\s1 Jesú jahuë yonoco chitahëhuanina
\p 
\v 29 Huëaquë tsi quiha ja qui Jesu johai ca Juán jisniquë.
\p —Tsayacapa. Dios oveja tsi xo naa ra. Nohiria jocha bixëhi quiha.
\v 30 Jabi mato qui ë yoani ca joni tsi xo naa, “E cho joxëhi quiha ëa oquë cato” i ë quë no. “E conox pari no tsi bëso ja iniquë” i ë ni quiha.
\v 31 Toatiyá tsi Xabahamati Ibo ja iqui ca ë cahëyamaniquë rë. Jama, jënë́ tsi ashimahi ë joniquë, Israél cabo qui mato Cristo jismaxëna —nëa tsi quiha nohiria bo qui Juan nëcaniquë.
\p 
\v 32 Jatsi quiha Juán yoani ca tsi xo naa:
\p —Espíritu Santo ë jisniquë ra, nai ax boto botëhai jascaria. Botëhax jahá tsi ja chitëniquë.
\v 33 Jari jaha no pasohai ca Xabahamati Ibo ja iqui ca ë cahëyamaniquë rë. Jama, ë qui chaniniquë Dios, naa nohiria bo ashimati ëa raanish cato. “Espíritu Santo botëhai ca jisxëqui mia” i ë qui Dios ni quiha. “Botëhax tsohuëcara ó chitëxëhi quiha. Espíritu Santó tsi nohiria ashimahai ca tsi xo toa” i ë qui Dios ni quiha.
\v 34 Jatsi Jesu qui Espíritu Santo botëhai ca ë jisniquë. Ja tsi xo toa Dios Baquë ra iquia —nëa tsi quiha jato qui Juan nëcaniquë.
\s1 Jesu jariapari ca banahuacanaibo
\p 
\v 35 Huëaquë tsi quiha dos ca jahuë rabëti bo ya Juan nii iniquë.
\v 36 Niixo tsi quiha Jesu tarabihai ca ja tsaya-tsayaniquë.
\p —Tsayacapa. Dios oveja tsi xo toa ra —i quiha jato qui Juan niquë.
\p 
\v 37 Jatsi Jesu quiha Juan rabë ca rabëti bá banahuaniquë ra ja yoani ca nicaxo na.
\v 38 Bopinaxo tsi quiha ja cho banahuacanaibo Jesú jisniquë. Jisi tsi,
\p —¿Jahuë mëracanai? —i jato qui ja niquë.
\p 
\v 39 Jatsi quiha,
\p —¿Jahuënia tsi racahai, Maestró? —i jaca niquë Jesu qui.
\p Jatsi,
\p —Jisi bëcahuë —i jato qui Jesu niquë.
\p Jatsi quiha ja bëta ja bocaniquë. Boxo tsi quiha Jesu racahai ca iti ja jiscaniquë. Jisi tsi ja bëta ja chitëcaniquë, yata ja ini iqui na.
\p 
\v 40 Jabi Jesu ya canish ca Andrés ini quiha, naa Juan chani nicanish cato. Simón Pedro noma quiha.
\v 41 Jasca, jisbaya tsi quiha jahuë rëquëmë Simón pari Andrés bichi caniquë.
\p —Xabahamati Ibo no jisquë ra —i quiha Simón qui ja niquë.
\p 
\v 42 Jatsi quiha Jesu qui jahuë rëquëmë ja bëniquë. Ja bëquë tsi quiha Jesú tsayaniquë.
\p —Juan baquë Simón xo mia. Jaboqui janë paxa ca mi qui axëquia. Pedro mi quënahacaxëti xo —i quiha ja qui Jesu niquë. Jabi noba joí tsi “Maxaxa” Pedro janëhacani quiha.
\s1 Felipe, Natanael, tihi cabo Jesú quënanina
\p 
\v 43 Jatsi huëaquë tsi quiha Galilea mai qui Jesu cacasniquë. Caxo tsi Felipe ja jisniquë. Jatsi,
\p —E bëta johuë —i quiha ja qui Jesu niquë.
\p 
\v 44 Jabi Betsaida yaca quima Felipe joni quiha. Toa yacatá tsi racani quiha Andrés, Pedro ri.
\v 45 Jatsi quiha Natanael Felipé bichi caniquë.
\p —Noqui Xabahamati Ibo ë jisquë ra. Jabi naa joni yoati tsi no yoahacani quiha Moisés quënëni cato ó no. Jasca, ja yoati tsi quënëni quiha Dios Chani yoanish cabo ri. Jahuë janë tsi xo Jesu, naa José baquë quiha. Nazaret quima ax johi quiha —nëa tsi quiha Natanael qui Felipe nëcaniquë.
\p 
\v 46 Jatsi quiha,
\p —¿Jënahuariahax raca Nazaret quima ax jia ca jona? —i Natanael niquë.
\p Jatsi,
\p —Jisi jopa —i ja qui Felipe niquë.
\p 
\v 47 Jatsi ja bëcano tsi quiha Natanael Jesú jisniquë.
\p —Nëá tsi johi quiha Israél ca joni shinajiaxëni cato ra. Quiatimaxëni ca joni tsi xo naa —i quiha Jesu niquë.
\p 
\v 48 Jatsi quiha,
\p —¿Jënahuariaxo ëa mi cahëha pa? —i Natanael niquë.
\p Jatsi,
\p —Felipé mia quënanox pari no tsi tosa jihui namá mi tsahohai ca ë jisquë ra —i ja qui Jesu niquë.
\p 
\v 49 Jatsi Natanaél quëbiniquë:
\p —Dios Baquë xo mia ra, Maestró. Israél caba chama-chamaria xo mia ra —iquiina.
\p 
\v 50 Jatsi,
\p —“Tosa jihui namá mia ë jisquë” i ë a iqui tsi ëa chahahuaqui mia pë.
\v 51 Mia parayamaquia. Naa jisti oquë cabo jisxëqui mia ra. Nai japëquëhai ca jisxëqui mia. Jasca, Nohiria Baquë quima ax Dios ángel bo tëronohaina, ja qui ja botëcanaina, tihi cabo tsi jisxëqui mia ra —i quiha Natanael qui Jesu niquë.
\c 2
\s1 Jënëria Jesú jënëpaxa manëmanina
\p 
\v 1 Dos bari quirëquë quiha Galilea maí ca Caná icanish ca yaca xo tsi ahui yahi quiha joni iniquë. Toá tsi quiha Jesu jahëhua iniquë jaa ri.
\v 2 Jatsi quiha jahuë rabëti bo ya Jesu caniquë jaa ri. Ja qui joi amahacani quiha.
\v 3 Jabi nohiria bo oriquino tsi quiha oriquiti ibobá jënëria binianiquë rë. Jato jënë ja paisacaquë tsi quiha,
\p —Yama xo jato jënë rë —i quiha Jesu qui jahuë jahëhua niquë.
\p 
\v 4 Jatsi Jesú quëbiniquë:
\p —Huënayamahuë, caí. Jamëri tsi xo toa mi shinahaina pë. Jari tsëquëyamahi quiha noho yonocoti xabaca ra —i quiha jahuë jahëhua qui Jesu niquë.
\p 
\v 5 Jama, toá ca yonati bo qui jahuë jahëhua chaniniquë:
\p —Mato ja yoahai ca acahuë —iquiina.
\p 
\v 6 Jabi toá tsi quiha seis maxax ca chomo bo nii ini quiha; naa Jodiobá chocohati jabi quëshpi na. Jabi pistiama naa chomo bo icani quiha.
\v 7 Jatsi,
\p —Chomo bo tsi jënëpaxa rëatsacana —i yonati bo qui Jesu niquë.
\p Jatsi quiha ja rëacaniquë jahuë quëbichí no. \fig Jënëria Jesú jënëpaxa manëmanina|src="cn01667b.tif" size="span" copy="©1978 David C. Cook Publishing Company" ref="JHN 2.7"\fig*
\v 8 Rëajahuacaquë tsi quiha,
\p —Huëtacahuë. Oriquiti ibo qui bocahuë —i jato qui Jesu niquë.
\p Huëtaxo tsi quiha jënëria ibo qui yonati bá boniquë.
\v 9 Ja bocaquë tsi quiha jënëria rarinamahacanish ca jënëpaxa ibobá tananiquë. Anomaria ja ini quiha. Tanaxo tsi quiha ahui yahax ca joni ja quënaniquë. Jabi jahuënia ca naa jënëria joha ca ja cahëyamani quiha. Cahëniquë taanish ca yonati bo roha.
\p 
\v 10 Jatsi,
\p —Anomaria tsi xo naa jënëria ra —i ibo niquë—. Jënëria jiaxëni ca pari taahi quiha jatiroha cabo ra. Noba jabi quiha. Jaquirëquë, nohiria bo sëyaquë tsi quiha jënëria yoi ca taacani quiha pë. Jama, ja cho naa jënëria jiaxëni ca mi taaquë pa —i ja ni quiha ahui yahax ca qui.
\p 
\v 11 Jabi naa jisti quiha Jesú aniquë Galileá ca Caná yacata xo na. Jahuë jariapari ca jisti quiha. Naa jistí tsi quiha jahuë oquë jiaxëni ca Jesú jismaniquë. Ja iqui tsi jahuë rabëti bá chahahuaniquë.
\p 
\v 12 Jaquirëquë jahuë jahëhua, jahuë noma bo, jahuë rabëti bo, tihi cabo ya Jesu caniquë Capernaum mai qui. Toá tsi quiha ichariama ca bari no tsi ja chitëcaniquë.
\s1 Arati xobo qui Jesu jiconina
\r Mateo 21.12-13; Marcos 11.15-18; Lucas 19.45-46
\p 
\v 13 Tsëquëpaimaria jodiobá pascua fiesta ini quiha. Ja quëshpi tsi Jerusalén qui Jesu caniquë.
\v 14 Arati xobo qui jicoxo tsi huëyë bo, oveja bo, boto bo, tihi cabo iniacanaibo ja jisniquë. Jasca, toá tsi quiha parata rarinamacanaibo tsaho iniquë pë.
\v 15 Jaha tsi quiha huacapi Jesú quëconiquë. Quëcoxo tsi quiha arati xobo quima jato tëquë ja raaniquë. Jato oveja bo, jato huëyë bo, tihi cabo ja raaniquë cacha. Raaxo tsi quiha parata rarinamacanaiba parata ja pacanamaniquë. Jasca, jato mesa bo ja narabaniquë.
\p 
\v 16 Jatsi,
\p —Mato boto bo cacha tsëcacata. Noho Jahëpa xobo tienda jabitihuayamaxëqui mato ra —i quiha boto iniacanaibo qui ja niquë.
\p 
\v 17 Jatsi quiha Dios libro ó ca quënëhacanish ca jahuë bo jahuë rabëti bá shinaniquë, “Mi arati xobo noiquia, Diós. Anomaria tsi xo toa mi xobo ë noihaina ra” i ja nina.
\p 
\v 18 Jatsi arati xobo quima jato Jesú raaquë tsi quiha jodiobá nicaniquë:
\p —¿Cacha jato raati chama ya ni mia sa? ¿Jahuë jisti ati mëtsa ni mia, noqui mi chama jismati? —iquiina.
\p 
\v 19 Jatsi Jesú quëbiniquë:
\p —Naa arati xobo potasyocahuë. Tres barí tsi noho chamá tsi niitëquëmaxëquia —i jato qui ja niquë.
\p 
\v 20 Jatsi,
\p —Cuarenta y seis año no tsi ja yonococaniquë, naa arati xobo jatihuaxëna. ¿Jënahuariaxo raca tres barí tsi naa xobo mi nimatëquëna? —i jaca niquë, quëbihi na.
\p 
\v 21 Jama, jahuë yora yoati tsi Jesu chanihi ini quiha, jato arati xobo yoati nomari.
\v 22 Jasca, Jesu bësotëquëquë tsi quiha jodiobo qui ja nëcani ca jahuë rabëti bá shinani quiha. Jaha tsi Quënëhacanish cabo, Jesú yoanina, tihi cabo jahuë rabëti bá chahahuayoini quiha.
\s1 Nohiriá shinahai ca cahëhi quiha Jesu
\p 
\v 23 Pascua fiesta no tsi quiha Jerusalén tsi Jesu iniquë. Toá ja no tsi quiha huëstima cabá chahahuaniquë, ja ani ca jistiria cabo jisish na.
\v 24 Jama, jato bëta Jesu rabënabëquiyamaniquë, jatiroha ca joni bá shinahai ca ja cahëni quëshpi na. ¿Mahitsa ja chahahuayamayamacani?
\v 25 Jabi nohiria bá shinahai ca tëquë ja cahëyoini quiha.
\c 3
\s1 Jesu qui Nicodemo jonina
\p 
\v 1 Tobi jodioba chama iniquë, naa Nicodemo icanai cato. Fariseobo, naa jodioba chama ja ini quiha.
\v 2 Jabi baquichá tsi quiha Jesu qui ja joniquë chaninaxëna. Johax,
\p —Dios raahacanish ca maestro xo mia, Taitá. Dios mi bëtayamarohapino tsi mi acai ca jisti bo mi ayamaquë aquë ra —i quiha Jesu qui ja niquë.
\p 
\v 3 Jatsi,
\p —Mia parayamaquia. Cotëquëyamapihi tsi Diós otohai ca qui jicotimaxëni xo joni ra —i quiha ja qui Jesu niquë.
\p 
\v 4 Jatsi,
\p —¿Jënahuariahax joni siri ca cotëquëna ra? ¿Jahuë jahëhua xama qui jicoxëti ni, cotëquëti pa? —i Nicodemo niquë.
\p 
\v 5 Jatsi quiha Jesú quëbiniquë:
\p —Mia parayamaquia. Jënë, Espíritu Santo, tihi cabá tsi cotëquëyamapihi tsi Diós otohai ca qui jicotimaxëni xo joni ra.
\v 6 Jabi nohiria comahi quiha nohiria. Jama, Dios baquë bo jabitiqui noa, Espíritu Santó tsi no cotëquëquë no.
\v 7 “Mi cotëquëpaima xo” i ë no tsi ratëyamana.
\v 8 Xotohi quiha yoshini jaha ja quëëhai cató no. Xotojano tsi jahuë joi nicaqui noa. Jama, jahuënia ax ja johaina, jahuënia ja cahaina, tihi cabo tsi cahëyoiyamaqui noa. Jabi toca tsi yonocohi quiha Espíritu Santo ri, no cotëquëquë no. Jisnoma xo Espíritu Santo yonocohaina —i Jesu niquë.
\p 
\v 9 Jatsi,
\p —¿Jënahuariahi ni sa? —i Nicodemo niquë.
\p 
\v 10 Jatsi Jesú quëbiniquë:
\p —¿Israél ca nohiria maestro ma ni mia ra? ¿Naa ë chaniha ca cahëyamahai pa?
\v 11 Jabi no cahëhai ca jahuë bo, no jisi ca jahuë bo, tihi roha cabo yoati tsi chaniqui noa ra. Jama, noba chani biyamacani quiha nohiria pë.
\v 12 Naa maí ca jahuë bo yoati ë chanihai ca chahahuayamapiquí tsi ¿jënahuariaxo tsi ëa mi chahahuana, naa Dios naipá ca jahuë bo yoati ë chanixëquë no?
\p 
\v 13 ‘Jabi ëa roha ca tsi xo toa Dios naipá ca jahuë bo jismati mëtsa cato. Yama tsi xo toa nai qui canish ca huëtsa ra. Jaroha ca nai ax jonish ca ëa xo naa, naa Nohiria Baquë cato.
\v 14 Jabi jihuí tsi Moisés yamabá metal rono tëroni quiha nohiria bo rësoyamano iquish na. Jascaria, jihuí tsi tërohacaxëti xo Nohiria Baquë ri, nohiria bo rësoyamano iquish na. Ea namëxëti ca xo.
\v 15 Jabi bëso-bësopaoxëhi quiha ë qui chitimicanaibo tëquë ra —nëa tsi quiha Nicodemo qui Jesu nëcaniquë.
\s1 Maí ca nohiria noihi quiha Dios
\p 
\v 16 Jabi jatiroha ca maí ca nohiria Diós noiniquë. Noixo tsi quiha jahuë jahuësti baquë ja aniquë no bax na. Jahuë baquë chahahuahi tsi rëso-rësoyamahi quiha noa. Jama, bëso-bësopaoxëqui noa.
\v 17 Jabi Diós jahuë Baquë mai qui raayamaniquë jato jocha quëshpi nohiria copixëna. Jama, jahuë Baquë ja raaniquë noqui xabahamaxëna jahá no.
\p 
\v 18 Jabi tënëtia qui jahuë Baquë qui chitimicanaibo raayamaxëhi quiha Dios. Jama, chitimiyamacanai ca tsi xo toa Dios copi bixëhaina ra, jahuë jahuësti Baquë qui ja chitimiyamacanai quëshpi na.
\v 19 Jabi Diós yoani ca tsi xo naa: Mai qui joniquë Huëa nori cato. Jama, tsëmo ó quëëcani quiha joni bo rë, yoi ca ja acanai iqui na.
\v 20 Jabi yoi ca acanaibo qui anoma tsi xo Huëa cato. Jasca, Huëa ca qui bëyamacani quiha pë, jato yoi ca acanai ca jahuë bo bërohuahacamitsa iqui na.
\v 21 Jama, Huëa ca qui bëcani quiha jabija ca banahuacanaibo. Bërohuahacahi quiha Diós toa nohiria mëbihaina.
\s1 Jesu yoati Juan chaninina
\p 
\v 22 Jaquirëquë quiha jodioba mai qui Jesu caniquë jahuë rabëti bo ya. Cahax jato bëta ja chitëniquë. Toa xo tsi quiha nohiria bo Jesú ashimaniquë.
\v 23 Jabi Enón icanai ca ani xo tsi quiha nohiria bo ashimahi Juan iniquë jaa ri. Salim yaca basima ja ini quiha. Toá tsi quiha huëstima ca jënë ini quiha. Jasca, ja qui nohiria bo cariahi ini quiha ashimahacati.
\v 24 Jabi toatiyá tsi quiha jari preso qui nanëhama Juan ini quiha.
\p 
\v 25 Jabi ashimati jabi tahëxo tsi quiha joi mërati Juan rabëti bá chitahëhuaniquë jodiobo yaxo na.
\v 26 Joi mërahax Juan qui ja bocaniquë.
\p —Jisa, maestró. Joquë Jesu, naa ani Jordán rabëquëx ca mi bëta inish cato pa. Jia tsi toa joni yoati mi chaniniquë. Tsayahuë. Jaboqui nëa xo tsi nohiria bo ashimahi quiha pë. Ja qui bocani quiha nohiria tëquë rë —i quiha Juan qui jaca niquë.
\p 
\v 27 Jatsi quiha Juán jato quëbiniquë:
\p —Jia tsi xo Jesu qui nohiria bocanaina iquia. Ja qui jahuë yonoco Diós ani quiha.
\v 28 Jabi toa joni yoati ë yoani ca ma nicaniquë ra. “Dios raahacanish ca Xabahamati Ibo ma xo ëa” ¿iyama ë ni? “E raahacaquë Cristo bëbo cati” i ë ni quiha. Jabi noho yonoco tsi xo toa jahuë quinia shomahuahaina.
\v 29 Ratëyamacana. Jënima tsi xo oquë ca joni qui nohiria bocanaina, naa fiesta ibo ya nohiria bocanai jascaria. ¿Jabi fiesta ibo mëbiyamayamahi ni jahuë rabëti bo? Jabi Iboba rabëti xo ëa ra. Japi Ibo Jesu qui nohiria bocano tsi raniquia ra.
\v 30 Jabi oquënaxëti xo Jesu iquia. Anixëti xo jahuë yonoco ra. Jama, iriama ca ëa xo naa. Namahi quiha noho yonoco —nëa tsi quiha jato qui Juan nëcaniquë.
\s1 Mana ax jonish cato
\p 
\v 31 Jatsi,
\p —Nai ax jonish ca tsi xo naa joni ra. Jatiroha cabo oquë xo. Maí conish ca roha xo ëa ra. Iriama tsi xo noho tiisimati chama. Jama, noqui oquë tsi xo naa nai ax johax cato ra.
\v 32 Ja jisni ca jahuë bo, ja nicani ca jahuë bo, tihi cabo yoahi quiha. Jama, jahuë chani jia ca biyamacani quiha nohiria pë.
\v 33 Jama, “Jabija ca xo Dios” iti mëtsa xo tsohuëcara ca naa joni chani bichish cato.
\v 34 Jabi Dios Chani yoahi quiha Jesu, ja qui Espíritu Santo Diós ani quëshpi na. Dios shina jayaria xo ra.
\v 35 Jasca, jahuë Baquë noihi quiha Jahëpa Dios. Jahuë Baquë qui chama ja aniquë jatiroha ca ja yonano.
\v 36 Jabi bëso-bësopaoxëhi quiha jahuë Baquë chahahuahai cato. Jama, nai qui jicoyamaxëhi quiha jahuë Baquë chahahuayamahai cato. Ja qui caxa-caxapaoxëhi quiha Dios ra —nëa tsi quiha nohiria bo qui Juan nëcaniquë ra.
\c 4
\s1 Samariá ca yoxa
\p 
\v 1 Jodioba chama bo, naa fariseobo icanai cabo qui chani cahëniquë Jesu yoati na. “Huëstima ca nohiria bëbohi quiha Jesu ra. Huëstima ca ashimahi quiha pa; naa Juan huino quiha” i jato qui nohiria bo niquë.
\v 2 Jama, jahuë rabëti bá nohiria bo ashimani quiha, Jesu ja nomari.
\v 3 Jabi ja acai ca jodioba chama bá nicaquë tsi quiha toa jodioba mai Jesú jisbayaniquë. Jisbaya tsi quiha Galilea qui jahari catsijaniquë.
\p 
\v 4 Jabi samaria mai nacoti nori ja ini quiha, jahuë mai qui cahëti.
\v 5-6 Nacopama tsi quiha matoroco barí tsi yaca Sicar icanai ca qui ja cahëniquë. Cahëhax Jacob yamabá ani ca quini, naa jënëpaxa jaya ca quini tapaí Jesu tsahoniquë. Ja joicasni quiha. Basi ja coni quiha. Caquë bari. Jabi José yamaba maí tsi toa jënëpaxa ini quiha, naa jahuë jahëpa Jacob quima ja binina.
\v 7 Tsahojano tsi quiha Samariá ca yoxa joniquë jënëpaxa bichi na. Jodiobo qui yoiria Samaria cabo ini quiha. Jabi ja joquë tsi quiha,
\p —E qui jënëpaxa ahuë —i yoxa qui Jesu niquë.
\p 
\v 8 Jabi jamëpistia Jesu ini quiha. Yaca qui jahuë rabëti bo jiconi quiha piti copiti.
\v 9 Jatsi yoxa ratëniquë ja qui Jesu chanini nori iqui na.
\p —¿Samariá ca yoxa qui chanihi ni mia pa? ¿Jodioba jabi pasomaha ma ni? “E qui jënëpaxa ahuë” ¿i mi a pa? —i quiha Jesu qui ja niquë.
\p 
\v 10 Jatsi Jesú quëbiniquë:
\p —Diós mi qui acatsaina, mi qui chanihai cato, tihi cabo cahërohapiquí tsi ë quima bësomati jënë mi baaquë aquë iquia. Jatsi toa jënë mi qui ë aquë aquë ra —nëa tsi quiha yoxa qui Jesu nëcaniquë.
\p 
\v 11 —Yama tsi xo mi jënëpaxa biti cato, Taitá —i yoxa niquë—. Nëmi xo quini ra. ¿Jahuëniaxo raca bësomati jënë mi bina?
\v 12 Naa maiquiní ca jënëpaxa jiaxëni ca noba Jacob yamabá aniquë. Jasca, naa jënë aniquë jahuë baquë bo. Aniquë jahuë vaca bo ri. ¿Jënahuariaxo raca jënë oquë ca ë qui mi ana? ¿Noba rëquëyamabo Jacob oquë ni mia pa? —nëa tsi quiha yoxa nëcaniquë.
\p 
\v 13 Jatsi Jesú quëbiniquë:
\p —Tëshinatëquëhi quiha naa maiquiní ca jënë acai cato.
\v 14 Jama, tëshinatëquëpistia-yamariaxëhi quiha ë acai ca jënë acai cato ra. Noho jënë ja aapino tsi rëamë ihipaoxëhi quiha jahuë shinana. Naama-naamapaoxëhai ca jënë xo naa ra —i quiha yoxa qui Jesu niquë. \fig Samariá ca yoxa Jesu qui chitiminina|src="cn01674b.tif" size="span" copy="©1978 David C. Cook Publishing Company" ref="JHN 4.14"\fig*
\p 
\v 15 Jatsi,
\p —Toa jënë ë qui ri ahuë, Taitá. E qui mi aapino tsi tëshinatëquëyamaxëquia ra. Jaha tsi naa maiquiní ca jënë bichi joyamaxëquia ra —i ja qui yoxa niquë.
\p 
\v 16 Jatsi Jesú quëbiniquë:
\p —Mi bënë bichi cata —iquiina.
\p 
\v 17 Jatsi,
\p —Bënë yama ca ëa xo naa ra —i ja niquë.
\p Jatsi,
\p —Jabija tsi xo toa mi yoahaina.
\v 18 Cinco ca bënë bo mi jayani quiha. Jasca, mi bënë ma xo toa mi bëta racahai cato. Jabija ca mi yoaquë ra —i quiha ja qui Jesu niquë.
\p 
\v 19 Jatsi yoxá quëbiniquë:
\p —Tonia Dios Chani yoahai ca xo mia ra.
\v 20 Nëá tsi, naa macaná tsi noba rëquëyamabo arapaoni quiha Dios qui. Jama, “Jerusalén tsi araxëti quiha nohiria tëquëta” ii quiha mato jodiobo pë —i Jesu qui ja niquë.
\p 
\v 21 Jatsi Jesú quëbiniquë:
\p —Ea chahahuahuë, caí. Johi quiha bari huëtsa ra. Toatiyá tsi naa macana, Jerusalén, tihi cabá tsi Jahëpa Dios qui arayamacaxëcani quiha nohiria.
\v 22 Jabi ma arahai ca cahëyoiyamaqui mato samariacabo. Jama, no arahai ca cahëqui noa, naa noqui jodiobo. Jabi jodiobo quima johi quiha Diós nohiria bo xabahamahaina.
\v 23 Jasca, joxëhi quiha xaba huëtsa. Toa xaba tsëquëno tsi quinia huëtsá tsi Dios qui aracaxëcani quiha nohiria tëquëta, naa Dios noicanaibo. Jato shinaná tsi Dios qui aracaxëcani quiha ra. Mahitsa iyamaxëhi quiha ja aracanaina ra. Jabi jaboqui rohari tsi naa Dios qui aratí quinia paxa ca chitahëhuahi quiha huësti huësti ca aracanaibo yoi bo ra. Nëca ca aracanaibo jiscatsi quiha Dios. Ja qui jia quiha.
\v 24 Shina xo Dios. Jisnoma quiha. Jascaria, jisnoma xo naa jabija ca arahai paxa cato. Noba shinaná tsi ja qui no araxëti xo —nëa tsi quiha Jesu nëcaniquë.
\p 
\v 25 Jatsi yoxá quëbiniquë:
\p —Xabahamati Ibo raaxëhi quiha Dios ra. Joxëhi quiha Cristo icanai cato. Joquí tsi jahuë bo tëquë yoaxëhi quiha —iquiina.
\p 
\v 26 Jatsi,
\p —Dios raahacanish ca ëa xo naa, naa mi qui chanihai cato —i quiha ja qui Jesu niquë.
\p 
\v 27 Jatsi Jesu rabëti bo bacaniquë. Samariá ca yoxa ya tsi Jesu chanihai ca jisi tsi ja ratëcaniquë. Jesu ja nicacascani quiha yoxa yoati na. Jama,
\p —¿Jënihax tsi naa yoxa ya tsi chanihai pa? ¿Jahuë ó quëëhi ni sa? —iyama jaca ni quiha, bërabihi na.
\v 28 Jatsi yoxa jahari caniquë jahuë yaca qui. Jahuë chomo ja jisbërianiquë maiquini tapaí.
\v 29 Jahuë yaca qui cahëhax,
\p —Naa joni jisi bëcapa. Jatiroha ca ë ani ca ëa ja yoaquë pa. ¿Tonia Diós raahai ca Xabahamati Ibo ma ni? —i quiha nohiria bo qui ja niquë.
\p 
\v 30 Jaha tsi yacatá ca nohiria tëquë jisbayaniquë. Jisbaya tsi quiha Jesu jisi ja bocaniquë.
\s1 Dios yonoco acaina
\p 
\v 31 Jabi jahuë yaca qui yoxa bacaquë tsi quiha,
\p —Pihuë —i Jesu qui jahuë rabëti bo niquë.
\p 
\v 32 Jatsi Jesú quëbiniquë:
\p —Piti huëtsa jaya xo ëa ra, naa ma cahëyamahaina —iquiina.
\p 
\v 33 Jatsi jato xërëquë tsi quiha chaninatsi jahuë rabëti bo niquë:
\p —¿Tsohuëcaracá ja qui piti bëha pa? —iquiina.
\p 
\v 34 Jatsi jahuë rabëti bo qui Jesu chaniniquë:
\p —Ea raanish ca quima johi quiha noho piti. Jahuë shina acaina, jahuë yonoco jatihuahaina, tihi cabo tsi xo toa noho piti ra.
\v 35 “Cuatro oxë tsi bimi tësaxëqui noa” ii quiha mato ra. Jama, johai ca nohiria tirixëni ca tsayacapa. Tësati bimi jascaria ca xo. Dios chahahua-paimaria ca xo. Dios bax ja tësahacapaimaria ca xo iquia.
\v 36 Jasca, nohiria tësacanaibo qui copi jia ca axëhi quiha Dios. Bëso-bësopaocaxëcani quiha toa ja tësacanaina. Jaha tsi nohiria tësacanaibo ya ranixëhi quiha Dios Chani sayacanaibo ri.
\v 37 Jabi “Huësti ca joni tsi xo sayahaina. Ja sayaha ca tësahi quiha joni huëtsa” ii quiha nohiria bo. Jabija tsi xo toa ja chanicanaina.
\v 38 Jatsi mato raaquia ma sayahama ca tësati. ¿Tsayayamacanai? Dios bax yonoconiquë huëtsa bo, Dios Chani sayahaina. Jaboqui jato yonoco tësaxëqui mato ra —nëa tsi quiha jahuë rabëti bo qui Jesu nëcaniquë.
\s1 Samariá cabá chahahuanina
\p 
\v 39 Jabi huëstima ca yacatá ca samariabá chahahuaniquë,
\p —Jatiroha ca ë ani ca ëa naa joní yoaquë pa —i jato qui yoxa quë no.
\p 
\v 40 Jatsi Jesu qui caxo tsi quiha samariabá bënarianiquë:
\p —No bëta mi chitëno ra —iquiina.
\p Jatsi dos bari no tsi jato bëta Jesu chitëniquë.
\v 41 Jaha tsi nohiria huëtsa bo chitiminiquë jato ri Jesu chani nicahax na. Huëstima ja icani quiha.
\p 
\v 42 —Jia tsi xo noqui mi yoahitahana. Jama, jaboqui chahahuariaqui noa, naa joni no nicaha quëshpi na. Nohiria bo Xabahamati Ibo yoi ja nori ca cahëqui noa ra —i yoxa qui jaca niquë.
\s1 Soldado ba capitán baquë
\p 
\v 43 Dos ca bari huinocaquë tsi quiha samariabo Jesú jisbayaniquë. Jisbaya tsi quiha jahuë mai qui, naa Galilea qui ja caniquë.
\v 44 Capama tsi quiha,
\p —Dios Chani yoahai ca nicayamahi quiha jahuë maí ca nohiria bo rë —i Jesu niquë.
\p 
\v 45 Jama, jahuë mai, naa Galilea qui Jesu cahëquë tsi quiha nohiria bá joihuaniquë pa. Jatiroha ca Jesú ani ca ja jiscani quiha Jerusalén qui shishoquí na. Jabi Jerusalén ca pascua fiesta qui ja bocani quiha jato ri.
\p 
\v 46 Jahuë mai qui cahëhax Caná icanai ca yaca qui Jesu caniquë, jënëpaxa quima jënëria ja ani cato. Toá tsi quiha gobierno chama iniquë. Iquihi jahuë baquë ini quiha. Jasca, basi, naa Capernaum yacatá tsi racahi ja ini quiha.
\v 47 Jodioba mai ax Galilea qui Jesu joni nori ca ja nicaniquë. Nicahax Caná yaca qui ja caniquë jahuë baquë iqui na. Jatsi,
\p —Noho xobo qui johuë. Rësopaimaria xo noho baquë rë. Noho baquë mi jënimahuano ra —i quiha Jesu qui ja niquë.
\p 
\v 48 Jatsi capitán Jesú quëbiniquë:
\p —¿Jëniriahax ë qui chitimiyamacanai? E qui chitiminox pari tsi jisti jiscatsi quiha mato rë —iquiina.
\p 
\v 49 Jama,
\p —Johuë, Taitá, noho baquë rësonox pari no —i Jesu qui capitán niquë.
\p 
\v 50 Jatsi,
\p —Cata. Rësoyamaxëqui mi baquë ra —i capitán qui Jesu niquë.
\p Jatsi jahari jahuë xobo qui capitán caniquë. Jesú yoani ca qui ja chitimini quiha jahuë baquë yoati na.
\v 51 Jahari capama tsi quiha jahuë yonati bo ja bëchaniquë bahi xo na.
\p —Jënima xo mi baquë ra. Bëso xo —i quiha ja qui jaca niquë.
\p 
\v 52 Jatsi,
\p —¿Jahuë hora jënimati ja tahëha? —i capitán niquë.
\p —Matoroco bari quiha ja chamahitaquë. A la una quiha —i jaca niquë.
\p 
\v 53 Jatsi jasca ca hora ja ini ca ja cahëniquë, naa “Jënima xo mi baquë” i Jesu quë no. Japi Jesu qui ja chitimiyoiniquë. Chitiminiquë jatiroha ca jahuë xobó cabo ri.
\p 
\v 54 Jabi segunda jisti tsi xo naa Jesú anina, jodioba mai ax Galilea qui johax na.
\c 5
\s1 Tapiyamahai ca joni Jesú jënimahuanina
\p 
\v 1 Jaquirëquë Jerusalén tsi quiha jodioba fiesta iniquë. Jatsi caniquë Jesu ri.
\v 2 Jabi Jerusalén tsi ashimati jënëquini ini quiha, naa Betsaida icanai cato. Oveja jicoti caiti basima quiha. Jabi cinco ca pórticos, naa caiti jisiria cabo, naa ashimati iti jayani quiha.
\v 3-4 Jabi jahuë pórtico namá tsi quiha noitiria cabo racahi ipaoni quiha. Toá tsi quiha bëco cabo, coyamacanaibo, yora choni jaya cabo, tihi cabo iniquë.
\v 5 Toá tsi iniquë cotimaxëni cato. Treinta y ocho año no tsi ja coyamani quiha. Naama quiha.
\v 6 Jabi Jerusalén qui jicopama tsi toa joni raca ca Jesú jisniquë. Naama toca tsi ja ini ca Jesú cahëniquë. Jatsi,
\p —¿Jënimacatsai? —i joni qui Jesu niquë.
\p 
\v 7 Jatsi noitiria ca joní quëbiniquë:
\p —Yama tsi xo ashimati jënëquini qui ëa jicomahai cato rë. Angél jënëpaxa roihano tsi mëri tsi jënë qui canoma xo ëa rë. E jicocasno tsi jariapari jënë qui jicohi quiha huëtsa rë —i Jesu qui ja ni quiha.
\p 
\v 8 Jatsi Jesu ja qui chaniniquë:
\p —Niihuë. Mi oxati bihuë. Cohuë —iquiina.
\p 
\v 9 Jatsi chamatapiniquë joni. Chamaxo tsi quiha jahuë oxati ja biniquë. Bixo ja jisbayaniquë. Jabi joiti barí tsi quiha naa joni jënimahuahacaniquë.
\v 10 Ja quëshpi tsi jodiobá jënimahuahacanish ca joni raahaniquë pë.
\p —Joiti bari tsi xo naa ra. Anoma tsi xo naa mi oxati bëhaina ra —i ja qui jaca niquë.
\p 
\v 11 Jatsi joní quëbiniquë:
\p —“Mi oxati bihuë. Cohuë” i ë qui ëa jënimahuahax ca quë ra —iquiina.
\p 
\v 12 Jatsi jodiobá nicaniquë:
\p —¿Tsohuë ni naa joni ra, naa “Mi oxati bihuë. Cohuë” i mi qui ax cato? —i jaca niquë ja qui.
\p 
\v 13 Tsohuëcara ja ini joní cahëyamani quiha. Caquë Jesu. Nohiria misco ca qui ja jiconi quiha.
\v 14 Jatsi yata tsi quiha jodioba arati xobo xo tsi Jesú toa joni bëchaniquë. Bëchahax tsi,
\p —Tsayapa. Jaboqui jënima xo mia. Jochatëquëyamahuë, jahuëcara oquë ca isihai ca mi bimitsa iqui na —i ja qui Jesu niquë.
\p 
\v 15 Jatsi jodioba chama bo mërahi joni caniquë, Jesu jistëquëxo na.
\p —Jesu tsi xo toa joni, naa ëa jënimahuahax cato ra —i jato qui ja niquë.
\p 
\v 16 Jaha tsi Jesu tënëmati jodioba chama bá chitahëhuaniquë rë, joiti barí tsi nohiria ja jënimahuani iqui na.
\v 17 Jatsi quiha Jesú jato quëbiniquë:
\p —Jatiroha barí tsi jia ca aqui quiha noho Jahëpa ra. Jabi toca xo ëa ri —iquiina.
\p 
\v 18 Jaha tsi Jesu pi jodiobá ariacasniquë, jato joiti bari jabi bo ja janayamani iqui na. Jasca, “Noho Jahëpa xo Dios” i jato qui Jesu ni quiha. Jabi nëca tsi Dios quësca jamë ja ani iqui tsi Jesu jodiobá acasniquë.
\s1 Dios Baquë chama
\p 
\v 19 Jatsi quiha jodiobo Jesú quëbiniquë:
\p —Jabija ca mato yoaquia ra. Yama tsi xo toa jamëpistia xo ë acaina ra, naa Dios Baquë ë nori cato. Jasca, jaha ë quëëhai ca ayamaquia. Noho jahëpá acai ca ë jisi ca roha ca aquia ra. Jatsi noho Jahëpá acai ca jascaria aquia ëa ri.
\v 20 Jasca, ëa, naa jahuë Baquë noihi quiha Jahëpa. Jatiroha ca ja acai ca ëa jismahi quiha. Jaboqui naa joni jënimahuahacaquë. Jama, naa ë aca ca oquë ca axëquia. Jatsi ratëyoxëqui mato ra.
\v 21 Jasca, noho Jahëpá bësoyama cabo bësomahai jascaria tsi ë qui jia cabo bësomaxëquia ëa ri.
\v 22 Jasca, jato jocha quëshpi bo tsi nohiria copixëquia, nohiria bo copiti chama ë qui noho Jahëpá ani quëshpi na. Nohiria bo copiyamaxëhi quiha Jahëpa.
\v 23 Jabi ë qui chama acacaniquë, ëa nohiria bá oquëhuano, naa noho Jahëpa nohiria bá oquëhuahai jascaria. Jabi ëa oquëhuayamapiquí tsi Jahëpa Dios, naa ëa raanish ca oquëhuayamahi quiha mato ra.
\p 
\v 24 ‘Mato parayamaquia. Bëso-bësopaoxëhi quiha noho chani nicahai cato, ëa raanish ca Dios chahahuahai cato. Jahuë jocha quëshpi tsi tënëtiya qui ja raahacayamati xo. Jaboqui bësoyoixëhi quiha ra. Rësonoma quiha.
\v 25 Mato parayamaquia. Dios Baquë joi nicaxëhi quiha bësoyama cabo ra, toa xaba tsëquëquë no. Jabi jaboqui ëa chahahuati chitahëhuahi quiha huësti huësti cabo ra. Jabi bëso-bësoxëhi quiha ëa nicacanaibo tëquë.
\v 26 Nicacapa. E qui nohiria bo bësomati chama noho Jahëpá ani quiha, Bësomati Ibo-iboria ja nori quëshpi na.
\v 27 Jasca, nohiria bo copiti chama ë qui ja ani quiha, joni ë manëni iqui na.
\v 28 Jabi ë yoahai ca qui ratëyamacana. Tsëquëxëhi quiha bari, naa maihuahacanish cabo tëquë noho joi nicaquë no.
\v 29 Toa barí tsi tërohacaxëhi quiha jia ca acanaibo. Jasca, tërohacaxëhi quiha yoi ca acanaibo. Bëso-bësopaoxëhi quiha jia ca acanaibo. Jama, copihacaxëti xo toa yoi ca acanaibo jato jocha quëshpi na.
\s1 Jesu chama yoati tsi ja chanicanina
\p 
\v 30 ‘Yama tsi xo toa ëmëpistia xo ë acaina ra. Nohiria copiquí tsi Diós ëa yoahai ca roha aquia. Jaha tsi mëstë tsi xo nohiria ë copihaina. Jaha ë quëëhai ca ayamaquia; jama, jaha noho Jahëpa quëëhai ca nori.
\v 31 Jabi ëmë yoati tsi ë chanipino tsi noho chani chahahuayamahi quiha nohiria bo.
\v 32 Jama, tobi ëa yoati chanihai ca huëtsa cato ra. Jia tsi chanihi quiha. Jabija tsi xo toa ëa yoati ja chanihaina iquia ra.
\v 33 Jabi ashimati ibo Juan qui joni bo ma raaniquë, ëa yoati nicamati. Jabija tsi xo toa ëa yoati Juan chaninina ra.
\v 34 Jabija ca ja yoani quiha. Jama, tobi quiha Juan chanihai ca oquë cato ra. Mato bax nëcatsiquia, ëa ma chahahuano xabahamahacati.
\v 35 Jabi huëa jascaria Juan ini quiha. Nohiria bo qui jahuë chani huahuapaoni quiha. Tanaroha pistia no tsi mato qui jia quiha jahuë huëahai ca chani iniquë ra.
\v 36 Jama, tobi quiha ëa yoati Juan oquë ca chanihai cato. Ea yoati chani-chaniriahai ca tsi xo toa ë acai ca jisti bo ra. Noho Jahëpá ë qui ani ca chamá tsi toa jisti bo aquia ra. Toa jisti bo aquia, Jahëpa Diós ëa raani ca ma cahëno iquish na.
\v 37 Jasca, ë bax chanihi quiha ëa raanish ca Jahëpa ri. Jabi jahuë joi ma nicapistia-yamariani quiha. Jahuë bëmana ma jisyamani quiha.
\v 38 Jasca, mato shina qui jicoyamahi quiha jahuë chani rë, ëa, naa Jahëpá raani ca ma chahahuayamahai iqui na.
\v 39 Jama, Quënëhacanish cabo tsaya-tsayariaqui mato ra, mato ja bëso-bësopaomacaxëcanai quëscahuaquí na. Mahitsa tsi xo toa ma tsayahaina rë. Jabi ëa yoati chanihai ca tsi xo toa Quënëhacanish cabo ra.
\v 40 Jama, ëa yoati Quënëhacanish cabo chaniquë ri tsi jari ë qui jocasyama xo mato rë, xabahamahacaxëna.
\p 
\v 41 ‘Jabi ë qui iriama tsi xo toa ëa ma nicacasyamahaina.
\v 42 Jama, mato cahëriaquia ra. Yama tsi xo toa mato ó ca Dios noicanaibo iquia.
\v 43 Jasca, noho Jahëpa chamá tsi johai ca ëa xo naa. Jama, ëa, noho chani, tihi cabo bicasyama xo mato rë. Jama, jahuë chama yoí tsi joni huëtsa joopino tsi toa joni joihuaqui mato pë.
\v 44 Jatsi, ¿jënahuariahax raca ë qui ma chitimina, nohiriá mato qui acai ca oquë ó quëëpiquí na? Mato qui Diós acatsai ca oquë ó quëëyamaqui mato rë.
\v 45 Nicacapa, Jahëpa Dios bësojo ax tsi mato qui quësoyamaxëquia. Mato qui quësoxëhai ca tsi xo Moisés ra, naa ja qui ma chitimihai cato.
\v 46 Jabi ëa yoati tsi Moisés yamabá quënëni quiha. Moisés quënëni ca chahahuarohapihax tsi ë qui ma chitimiquë aquë ra.
\v 47 Jatsi, ¿jënahuariaxo noho chani ma chahahuana, Moisés quënëni ca ma chahahuayamaquë no? —nëa tsi jodioba chama bo qui Jesu nëcaniquë.
\c 6
\s1 Cinco mil ca nohiria Jesú pimanina
\r Mateo 14.13-21; Marcos 6.30-44; Lucas 9.10-17
\p 
\v 1 Jaquirëquë quiha ia Galilea Jesu shitaniquë.
\v 2-3 Shitahax maca qui ja tëmahinaniquë. Tëmahinahax ja tsahoniquë jahuë rabëti bo ya. Jasca, huëstima ca nohiria bá Jesu banahuaniquë, noitiria cabo ja jënimahuahai jiscatsi na.
\v 4 Basima quiha jodioba fiesta ini quiha, naa jato pascua fiesta.
\v 5 Tsahopama tsi quiha ja qui bëcanai ca nohiria huëstima ca Jesú jisniquë. Jisi tsi Felipe qui ja chaniniquë:
\p —¿Jahuëniá ca mapari copixëhi ni noa naa nohiria bo pimaxëna? —iquiina.
\p 
\v 6 Jabi ja nëcaniquë Felipe tanamaxëna, ja ati nori ca ja cahëni quëshpi na.
\v 7 Jatsi Felipé quëbiniquë:
\p —Doscientos ca paratá tsi mapari copixo tsi ¿jënahuariaxo raca jato no sëyamana? Narisxëqui noa ra —i Jesu qui ja niquë.
\p 
\v 8 Jatsi Jesu qui chanitsi Andrés, naa Simón Pedro rëquëmë niquë.
\p 
\v 9 —Tobi quiha huësti ca baquë nëá no ra. Cinco ca mapari, dos ca sanino, tihi cabo jaya xo ra. ¿Tihi roha cató tsi naa tihiria ca nohiria raca pimahi ni noa pa? —i Jesu qui ja niquë. \fig Jesu qui jahuë tapeque baquë́ anina|src="cn01716b.tif" size="span" copy="©1978 David C. Cook Publishing Company" ref="JHN 6.9"\fig*
\p 
\v 10 Jatsi,
\p —Nohiria tsahomacahuë —i Jesu niquë.
\p Jabi jia toa iti ini quiha, huasi ya. Jatsi, tsahoniquë nohiria. Toá tsi cinco mil ca joni bo ini quiha. Tihiria ca racana quiha.
\v 11 Tsahomajahuacaquë tsi quiha baquë mapari Jesú biniquë. Jatsi Dios qui “Gracias” ixo tsi tsahonish cabo qui ja mëaniquë. Mëaxo tsi quiha sani nohiria bo qui ja mëaniquë. Jatsi nohiria bá piniquë. Ja sëyacaniquë.
\v 12 Sëyajacaquë tsi quiha,
\p —Pihama ca quësi bo catiacahuë, oriquiti yoshihuahacayamano —i jahuë rabëti bo qui Jesu niquë.
\p 
\v 13 Jatsi mapari quësi bo, sani quësi bo, tihi cabo ja catiacaniquë. Catiaxo tsi quiha doce ca caca ja rëacaniquë pa, naa pihama cato.
\v 14 Jatsi nohiria bo ratëniquë. Ja ani ca jisti jisi tsi,
\p —Jabija. Dios Chani yoahai ca, naa jaha no pasohai ca tsi xo naa ra —i nohiria bo niquë.
\p 
\v 15 Japi nohiria bá Jesu bicasniquë, jato rey, naa chama-chamaria manëmaxëna. Ja acascanai ca cahëxo tsi quiha jato ja jisbayaniquë. Jatsi maca bo qui jamëpistia tsi ja paxaniquë.
\s1 Jënë́ tsi Jesu conina
\r Mateo 14.22-27; Marcos 6.45-52
\p 
\v 16 Bari caquë tsi quiha ia qui jahuë rabëti bo botëniquë Jesu manaxëna.
\v 17 Joyamaniquë Jesu. Caquë bari. Jarohari tsi quiha noti qui ja jicocaniquë, ia Capernaum shitaxëna.
\v 18 Shitajacano tsi quiha xotoriatsi yoshi niquë rë. Anomaria choca ini quiha.
\v 19 Pabasi huaaxaxo tsi quiha ianë́ ca tsi Jesu cohai ja jiscaniquë. Jato noti qui basimahi ja ini quiha. Jatsi quiha ja raquëcaniquë.
\v 20 Jatsi jato qui Jesu chaniniquë:
\p —Raquëyamacana. Ea yoi xo naa —iquiina.
\p 
\v 21 Japi jato noti qui ja jicomacascani quiha. Jicomajahuacaquë tsi quiha mai qui, naa ja rërëcatsai ca iti qui ja cahëtapicaniquë.
\s1 Nohiria bá Jesu jiscasnina
\p 
\v 22-24 Huëaquë tsi quiha ia rabëquëx ca chitënish ca nohiria bá Jesu yopaniquë. Jahuë rabëti bo ya notí tsi Jesu cayamani ca ja cahëcani quiha. Jabi Jesu yama tsi jahuë rabëti bá ia shitashinani ca ja shinacani quiha. Jatsi Jesu, jahuë rabëti bo, tihi cabo yopaxo tsi ia ja shitacascani quiha jato ri. Yama ca noti bo ini quiha. Jatsi toá tsi quiha, naa Ibo Jesú mapari jato pimani ca qui Tiberiá ca noti bo rërëniquë. Jatsi toa noti bo qui nohiria jicocaniquë Capernaum qui shitaxëna, toa xo tsi Jesu mëracatsi na.
\v 25 Ia shitaxo tsi quiha Jesu ja jiscaniquë. Jisi tsi,
\p —¿Jënino tsi mi joha pa, Maestró? —i jaca niquë.
\p 
\v 26 Jatsi Jesú jato quëbiniquë:
\p —E bëta bëyocascaqui mato, mato ë pimahitaha iqui na pë. Mato qui iriama tsi xo toa ë acai ca jisti bo rë.
\v 27 Nicacapa. Iriama tsi xo piti ra. Naamayamahi quiha. Jatsi naamayamahai ca ó quëëyamacana. Jama, mana ca piti ó quëëcana. Mato qui toa piti acasquia, naa Nohiria Baquë ë nori cato. Mato bëso-bësopasomaxëhi quiha toa ë acai ca piti ra. Jabi noho Jahëpa Diós ëa raaniquë, mana ca piti nohiria bo qui ati —nëa tsi nohiria bo qui Jesu nëcaniquë.
\p 
\v 28 Jaha tsi nohiria bo chaniniquë:
\p —¿Jënahuaxëhi ni noa Dios ranihuaxëna ra? —iquiina.
\p 
\v 29 Jatsi Jesú quëbiniquë:
\p —Ranixëhi quiha Dios, ja raani ca ma chahahuaquë no —iquiina.
\p 
\v 30 Jatsi,
\p —¿Jahuë jisti ati mëtsa ni mia? —i Jesu qui jaca niquë—. Noqui jismahuë, mi qui no chitimino. ¿Jahuë acai ra?
\v 31 Jabi xabacá tsi racapama tsi naipá ca mapari noba rëquëbo yamabá pini quiha. Jabi “Naipá ca mapari jato qui Moisés yamabá ani quiha piti” ii quiha Quënëhacanish cabo. Moisés ani ca oquë ca jisti mi ano ra, Diós pi mia raani ca no cahëyoino iquish na —nëa tsi Jesu qui ja nëcacaniquë.
\p 
\v 32 Jatsi Jesú quëbiniquë:
\p —Mato qui naipá ca mapari Moisés yamabá ayamani quiha ra, noho Jahëpá tsi nori. Jasca, jaboqui naipá ca mapari yoi ca mato qui acatsi quiha.
\v 33 Jabi Diós acai ca mapari tsi xo toa nai ax botënish cato. Maí ca nohiria bësomahi quiha —i jato qui Jesu niquë.
\p 
\v 34 Jatsi,
\p —Jatiroha barí tsi naa mapari noqui ahuë, taitá —i nohiria bo niquë.
\p 
\v 35 Jatsi,
\p —Bësomati Mapari ca ëa xo naa ra —i jato qui Jesu niquë—. Paxnayamaxëhi quiha ë qui johai cato. Tëshinayamaxëhi quiha ë qui chitimihai cato.
\v 36 Jama, mahitsa ëa, noho jisti bo, tihi cabo ma jisquë pë. Jisi tsi jari ë qui chitimicasyamaxo mato iquia.
\v 37 Jama, ë qui chitimixëhi quiha huësti huësti cabo, naa jatiroha ca ë qui noho Jahëpá acaina. Tsohuëcara ë qui johai ca niayama-xëquia ra.
\v 38 Jabi nai ax ë botëniquë, noho Jahëpa, naa ëa raanish cato shina axëna. Noho shina ayamahai ca ëa xo naa.
\v 39 Ea raanish cato shina tsi xo naa ë qui ja ani cabo ë bënoyamahaina. Jato bësomaxëquia jaroha ca barí no. Ea raanish ca qui jia tsi xo toa.
\v 40 Ea, naa jahuë Baquë cahëcanaibo, ë qui chitimicanaibo, tihi cabo bësomacatsi quiha. Noho Jahëpa qui jia tsi xo toa jaroha ca barí tsi jato ë bësomaxëhaina —nëa tsi nohiria bo qui Jesu nëcaniquë.
\p 
\v 41 Jatsi pë Jesu qui yosanatsi jodiobo niquë, “Nai ax johax ca Mapari xo ëa” i ja ni iqui na.
\v 42 Jatsi Jesu pasomaha chanitsijacaniquë pë.
\p —Jesu roha tsi xo naa ra. José baquë quiha. Jahuë jahëpa, jahuë jahëhua, tihi cabo cahëqui noa ra. ¿Jënahuariahax “Nai ax ë botëquë” i ja na? —nëa tsi nohiria bo nëcaniquë.
\p 
\v 43 —Toca tsi chaniyamacana. Anoma quiha —i jato qui Jesu niquë—.
\v 44 Yama tsi xo toa ë qui jamëpistia joti mëtsa cato. Ea raanish ca Jahëpa tsi xo toa jato ë qui mëpiti Ibo ra. Jatsi ë qui mëpihacahax cabo bësomaxëquia jaroha ca barí no.
\v 45 Jabi “Jatiroha cabo tiisimaxëhi quiha Dios” ii quiha Dios Chani yoanish cabo ja quënëcani cabo ó no. Japi noho Jahëpa nicacanaibo, naa jabija ca tiisimahacahax cabo, tihi cabo tsi xo toa ë qui bëcaxëcanaina.
\p 
\v 46 ‘Jasca, yama tsi xo toa noho Jahëpa jisish ca ri. Huësti roha ca tsi xo toa noho Jahëpa jisish cato. Jisniquë toa Dios quima ax jonish ca roha.
\v 47 Mato parayamaquia. Bëso-bësopaoxëhi quiha ë qui chitimicanaibo iquia.
\v 48 Jasca, Bësomati Mapari ca ëa xo naa.
\v 49 Jabi nai ax paquënish ca mapari mato rëquëbo yamabá pini quiha xaba xo na. Pihax ja rësoyocaniquë ra. Jato bëso-bësopaomayamani quiha toa mapari ra.
\v 50 Jama, tobi quiha nai ax johax ca Mapari huëtsa ra. Rësoyamaxëhi quiha tsohuëcara ca naa Mapari pihai cato.
\v 51 Mato parayamaquia. Nai ax botënish ca Bësomati Mapari ca ëa xo naa ra. Bëso-bësopaoxëhi quiha tsohuëcara ca naa Mapari pihai cato. Jabi naa Mapari tsi xo noho yora ra. Ja acacani quiha maí ca nohiria bo xabahamati —nëa tsi nohiria bo qui Jesu nëcaniquë.
\p 
\v 52 Jatsi jato xërëquë tsi joi mëranatsi jodiobá huaniquë.
\p —¿Jënahuariaxo raca noqui jahuë yora ja ana? Pinoma quiha —i jaca niquë.
\p 
\v 53 Jatsi Jesú quëbiniquë:
\p —Mato parayamaquia. Pihacati xo Nohiria Baquë. Acacati xo jahuë jimi ra. Jabi xabahamahacatimaxëni tsi xo toa Dios baquë biyamahaina.
\v 54 Jama, bëso-bësopaoxëhi quiha noho yora pihai cato, noho jimi acai cato. Jaroha ca barí tsi quiha toa bësomaxëquia.
\v 55 Piti-pitiria tsi xo noho yora ra. Ati-atiria tsi xo noho jimi ra.
\v 56 E nohó bësoxëhi quiha noho yora pihai cato, noho jimi acai cato. Jasca, jahá tsi bësoxëquia ëa ri.
\v 57 Jabi ëa raanish cato chamá tsi bësoyoiquia ra. Jascaria, noho chamá tsi bësoyoihi quiha ëa pihai cato.
\v 58 Jabi naa nai ax botënish ca Mapari ca ëa xo naa ra. Mato naboyamabá pini ca mapari jascariama xo. Pihax ja rësoyocaniquë. Jama, bëso-bësopaoxëhi quiha tsohuëcara ca Mapari-maparia pihai cato
\v 59 —nëa tsi quiha nohiria bo qui Jesu nëcaniquë, Capernaum ca catiti xobo xo tsi tiisimaquí na.
\s1 Bësomati Chani
\p 
\v 60 Jahuë chani nicahax,
\p —Noqui bëronoma xo ja yoahaina rë. ¿Jënahuariaxo raca no cahëna ra? —i Jesu rabëti bo rabë roha niquë.
\p 
\v 61 Jato qui yosa jahuë chani ini quiha. Jatsi ja shinacanai ca cahëhax,
\p —¿Mato ratiahi ni ë yoahana pa? —i jato qui Jesu niquë—.
\v 62 Mana, naa naipá tsi ë i-ipaoni quiha. ¿Jahari nai qui cati nori ë irohapino tsi jahuë ma shinaquë ana?
\v 63 Jabi nohiria bësomahai ca tsi xo noho Shinana. Nohiria bësomayoiyamahi quiha noho yora ra. Pinoma xo toa ra. Jama, noho chani pi chahahuahi tsi bësoxëqui mato ra. Dios quima tsi xo naa mato qui ë yoahana. Jama, tobi quiha mato ó ca chahahuayamacanaibo rë —nëa tsi jato qui Jesu nëcaniquë.
\p 
\v 64 Jabi rëquë rohari tsi ja qui chitimiyoi-canaibo, ja pasomaha cabo, tihi cabo Jesú cahëni quiha.
\p 
\v 65 Jatsi Jesu chanitëquëniquë:
\p —Yama tsi xo toa ë qui jamëpistia joti mëtsa cato itëquëquia ra. E qui noho Jahëpá mëpiti xo —iquiina.
\p 
\v 66 Jatsi pë huëstima ca banahuacanaibá Jesu jisbërianiquë jahuë chani nicaxo na. Jato jabi siri bo qui ja bacacaniquë pë. Jesu ya ja bocasyamacani quiha jahuë chani iqui na.
\v 67 Jisbëriajahuacaquë tsi quiha,
\p —¿Ea jisbëriacascanai mato ri rë? —i jahuë doce ca rabëti bo qui Jesu niquë.
\p 
\v 68 Jatsi,
\p —¿Tsohuëcara qui no cana, Ibobá? —i Pedro niquë—. Mia roha tsi xo toa bësomati chani jaya cato ra.
\v 69 Jaboqui mi qui chitimiqui noa. Dios quima ax mëstëxëni ca mi nori ca cahëyoiqui noa ra —i Jesu qui ja niquë.
\p 
\v 70 Jatsi Jesú quëbiniquë:
\p —Mato tëquë ë biniquë. Doce ca xo mato. Jama, mato ó ca huësti ca tsi xo toa ëa pasomaha cato rë —iquiina.
\p 
\v 71 Jabi Judas Iscariote yoati chanihi Jesu ini quiha. Jabi soldado bo qui Jesu mëaxëti ca ja ini quiha; naa Jesu doce ó ca huësti cato pa.
\c 7
\s1 Jerusalén qui Jesu canina
\p 
\v 1 Jaquirëquë quiha Galileá tsi Jesu chitëniquë. Jodioba mai qui jiconoma ja ini quiha, jodiobá acasni iqui na.
\v 2 Jabi tsëquëpaimaria jodioba fiesta ini quiha, naa tapás racatiyá no.
\v 3 Toatiyá tsi quiha Jesu qui jahuë noma bo chaniniquë:
\p —Jodioba mai qui jahari cata. Mi acai ca jisti bo mia banahuacanaibá jisno ra. Naa mai jisbayahuë ra.
\v 4 ¿Jënahuariaxo nohiria bá mia cahëna, jonë tsi mi chitëquë no? Jisti bo aapiquí tsi nohiria bo qui mi acai ca jahuë bo jismata —i Jesu qui jahuë noma bo niquë.
\p 
\v 5 Jabi Jesu qui chitimiyoiyamani quiha jahuë noma bo ri rë.
\v 6 Jatsi Jesú jato quëbiniquë:
\p —Canoma xo ëa ra. Jari noho xaba ma xo toa ëmë nohiria bo jismati. Jama, mato qui jia tsi xo jaboqui fiesta qui cahaina.
\v 7 Mato qui caxayama xo nohiria bo. Mato ayamacaxëcani quiha. Jama, ë qui caxariacani quiha, jato yoi ca ja acanai ca pasomaha ë chanihai iqui na.
\v 8 Fiesta qui bocata. Jari fiesta qui cayamaquia. Jari noho cati xaba ma xo ra —i jahuë noma bo qui Jesu niquë.
\p 
\v 9 Jahuë noma bo qui chanihax Galileá tsi ja chitëniquë.
\v 10 Jariapari quiha jahuë noma bo Jerusalén qui bocaniquë fiesta qui. Ja bocaquë tsi quiha jonë tsi Jesu caniquë jaa ri. Bëro tsi ja cayamani quiha.
\s1 Tapas fiestá tsi Jesu inina
\p 
\v 11 Jabi fiesta no tsi quiha jodiobá Jesu mërahi iniquë. Mërahax,
\p —¿Jahuënia cara ca Jesu tia? —i jaca niquë.
\p 
\v 12 Jabi nohiria xërëquë tsi quiha huëstima ca ranimis-hai ca iniquë Jesu yoati na.
\p —Joni shina jiaxëni ca tsi xo naa ra —i jato rabë roha bo niquë, chaninahi na.
\p Jama,
\p —Jia yama xo Jesu ra. Nohiria bo parahi quiha pë —i huëtsa bo niquë.
\p 
\v 13 Jabi bëro tsi quiha Jesu yoati tsi ja chaniyamacani quiha, jato jodioba chama bo qui raquëhi na.
\v 14 Jatsi fiesta naamano tsi quiha jodioba arati xobo qui Jesu caniquë jaa ri. Caxo tsi quiha nohiria bo tiisimati ja chitahëhuaniquë.
\v 15 Jatsi jodioba chama bo ratëniquë ja tiisimahai ca nicahax na.
\p —Tiisi jaya xo naa joni pa. ¿Jahuëniá ca tiisi ja bini pa? Noba escuela bo xo tsi ja tiisimahacayamani quiha ra —i chama bo niquë.
\p 
\v 16 Jaha tsi Jesú jato quëbiniquë:
\p —Nohó-na ma xo naa ë tiisimahaina ra. Dios, naa ëa raanish ca quima johi quiha ë tiisimahaina.
\v 17 Dios shina aapicasquí tsi jahuënia ca ë tiisimahai ca joha ca cahëxëhi quiha Dios banahuacatsai cato tia. “¿Dios quima ni? ¿Joni quima ni?” ixëhi quiha, cahëcatsi na.
\v 18 Jama, jamë oquëhuacatsi quiha jahuë chani roha yoacatsai cato. Jama, jahuë raati ibo oquëhuacatsai ca tsi xo toa jabija ca chanihai cato. Parayamahi quiha.
\v 19 ¿Jabi mato qui yoba Moisés ayamayamani? ¿Jënahuariaxo jahuë yoba nicayamacanai? ¿Jënixo tsi ëa pi acascanai pë? —i jato qui Jesu niquë.
\p 
\v 20 Jatsi nohiria bá quëbiniquë:
\p —Yoyoxëni xo mia ra. ¿Tsohuëcaracá mia acatsana? —i jaca niquë.
\p 
\v 21 Jatsi Jesú jato quëbiniquë:
\p —Joiti barí tsi joni ë jënimahuaquë tsi ma shina-risiquihitaquë pa. ¿Mato qui yoi ni joiti barí tsi joni ë jënimahuahaina sa?
\v 22 Tsayacahuë. Joiti barí tsi yonocoqui mato ri, Moisés ani ca jibirishati jabi ma aquë no ra. Jabi noba rëquëbo yamabo qui naa jabi acacani quiha Moisés qui nomari ra.
\v 23 Jabi mato qui jënima tsi xo joiti barí tsi mato baquë bo jibirishahaina, Moisés yoba jatihuati. Jama, joiti barí tsi joni ë jënimahuano tsi ë qui caxaqui mato pë. ¿Jëni ni sa?
\v 24 Moisés yoba pasomaha joiti barí tsi ë acai nori ca jascahuaqui mato pë. Jaxcamënaqui mato ra. Shinahaxma tsi ë qui quësoyamacana ra —nëa tsi nohiria bo qui Jesu nëcaniquë.
\s1 —¿Dios raahacanish ca ma ni? —i nohiria bo nina.
\p 
\v 25 Jatsi Jesu yoati tsi chaninatsi Jerusalén ca nohiria bo niquë:
\p —¿Ja acascanai ca joni ma ni naa pa?
\v 26 Tsayacapa. Bëro tsi nohiria bo qui chanihi quiha ra. ¿Jëniriahax ja qui chaniyamahi ni noba chama bo pa? ¿Tonia Xabahamati Ibo ja nori ca cahëcahi ni sa? —i huësti huësti ca niquë.
\p 
\v 27 Jama,
\p —Oca ma xo tia. Naa joni coni yaca cahëqui noa, naa noqui tëquëta ra. Jama, Xabahamati Ibo jisiquino tsi jahuënia ja johai ca cahëyamaxëqui noa ra —nëa tsi nohiria huëtsa bo nëcaniquë.
\p 
\v 28 Jatsi arati xobó tsi Jesu nëcaniquë nohiria bo tiisimahi na:
\p —¿Ea cahëyoicanai? ¿Jahuënia ax ë joni ca cahëyoicanai? E joyamaniquë ë jocasni iqui na. Jama, ë raahacaniquë. Jabija ca tsi xo toa ëa raanish cato. Toa cahëyamaqui mato ra.
\v 29 Jama, toa cahëquia ja quima ë joni iqui na. Ea ja raaniquë ra —i nohiria bo qui Jesu niquë.
\p 
\v 30 Jatsi jodioba chama bo Jesu qui tsamicasniquë pë. Binoma quiha, jari jahuë rësoti xaba tsëquëyamani quëshpi na.
\v 31 Jama, toá ca nohiria huëstima cabo Jesu qui chitiminiquë ra.
\p —Anomaria tsi xo naa joní jisti bo acaina ra. ¿Jënahuariaxo naa oquë ca jisti bo jaha no pasohai ca Xabahamati Ibobá ana? Ja tsi xo naa ra —i jaca niquë, ja qui chitimihi na.
\s1 Soldado bo raahacanina Jesu qui tsamiti
\p 
\v 32 Nëca tsi Jesu yoati tsi nohiria bo baxëxëquë tsi quiha jodioba chama bá ja chanicanai ca nicaniquë rë. Jaha tsi pë soldado bo ja raacaniquë Jesu qui tsamiti.
\v 33 Japi Jesu nëcaniquë:
\p —Tana roha pistia no tsi mato bëtaxëquia. Jaquirëquë ëa raanish ca qui jahari caxëquia.
\v 34 E cano tsi ëa mëraxëqui mato; mahitsa. Jasca, ë cahai ca qui canoma ixëqui mato ra —i jato qui Jesu niquë.
\p 
\v 35 Jatsi chaninabëquitsi jodiobo niquë:
\p —¿Jahuënia cacatsi ni naa joni sa? “Mahitsa ëa mëraxëqui mato” ii quiha pa. ¿Tonia pais huëtsa ca jodiobo qui cayamaxëhi ni? ¿Nohiria huëtsa bo tiisimacatsi ni?
\v 36 ¿Jënihi ni ja yoahana sa, “Ea mëraxëqui mato; mahitsa. E cahai ca qui canoma ixëqui mato” i ja quë no? ¿Jënihi ni sa? —i jaca niquë.
\s1 Bësomati Jënë iquish cato
\p 
\v 37 Jabi jaroha ca fiesta bari ja ini quiha. Jodiobo qui oquë toa bari ini quiha. Toa barí tsi quiha Jesu niiniquë nohiria bo qui chanixëna. Pistiama ca jahuë joi quiha.
\p —E qui jopaima xo tsohuëcara tëshinahaina. Bësomati jënë ja qui axëquia ra.
\v 38 “Tsohuëcara ë qui chitimino tsi jahuë shina quima huahuaxëhi quiha bësomati jënë” ii quiha Quënëhacanish cabo —nëa tsi Jesu nëcaniquë nohiria bo qui.
\p 
\v 39 Jabi Espíritu Santo yoati tsi chanihi Jesu ini quiha, naa chahahuacanaibo qui acacati cato.
\p 
\v 40 —Tonia Dios Chani bëhai ca tsi xo naa joni ra —i huëstima cabo niquë, Jesu chani nicahax na.
\p Jasca,
\p —Nohiria Xabahamati Ibo tsi xo naa ra —i nohiria huëtsa bo niquë.
\p 
\v 41 Jama,
\p —Nohiria Xabahamati Ibo ma xo tia. Galilea mai ax joyamahi quiha jaha no pasohai ca Xabahamati Ibo ra.
\v 42 Tsayacahuë. Belén, naa noba David yamabo racani cató tsi coxëhi quiha jaha no pasohai ca Xabahamati Ibo ra. David yamaba chahitaxocobo ixëhi quiha ra —nëa tsi quiha huëtsa bo nëcaniquë.
\p 
\v 43 Ja iqui tsi jamëri jamëri ini quiha nohiria bá shinahaina Jesu yoati na. Huëstima cabo qui jia ja ini quiha, huëtsa cabo qui yoi ja nori.
\v 44 Jasca, huësti huësti ca Jesu qui tsamicasniquë. Jama, jari ja qui ja tsamiyamacaniquë raquëhi na.
\s1 Jodioba chama bá chahahuanina
\p 
\v 45 Jatsi raahacanish ca soldado bo jahari bocaniquë jato jodioba chama bo qui. Jesu yama ja bëcani quiha.
\p Jatsi,
\p —¿Jënixo tsi Jesu ma bëyamacana pë? —i soldado bo qui chama bo niquë.
\p 
\v 46 Jatsi,
\p —Yama tsi xo nëca ca chanihai cato ra. Jiaria tsi xo naa joní yoahaina ra —i soldado bo niquë quëbihi na.
\p 
\v 47 Jaha tsi jodioba chama bá jato raahaniquë:
\p —¿Mato ri ja paraha pa?
\v 48 ¿Japa noqui? ¿Toa joni chahahuahi ni noa, naa noqui fariseobo, noqui chama bo? Ayamaqui noa; ¿tsayacanai?
\v 49 Jama xo nohiria bo pë. Dios Chani cahëtimaxëni ca xo ra. Yoshihuahacanish cabo tsi xo naa nohiria bo ra —i soldado bo qui chama bo niquë.
\p 
\v 50 Jatsi Nicodemo, naa baquichá tsi Jesu qui canish ca chaniniquë chama bo qui. Jabi chama Nicodemo ini quiha jaa ri.
\p 
\v 51 —Naa joni nicahaxma tsi ja qui quësoqui noa pë. ¿Noba yoba pasomaha ma ni naa no acaina? Jariapari ja acai ca no cahëxëti xo —i Nicodemo niquë.
\p 
\v 52-53 Jatsi chama bá Nicodemo ri raahaniquë pë:
\p —¿Yoiria ca galileabo ma ni mia ra? Quënëhacanish cabo tsayahuë. Yama tsi xo Galilea ax johai ca Dios Chani bëhai cato ra —iquiina.
\c 8
\s1 Jochanish ca yoxa tsamihacanina
\p 
\v 1 Fiesta quirëquë jato xobo qui nohiria boyocaniquë. Jama, Maca Olivo Ya qui Jesu caniquë.
\v 2 Jatsi huëaquë tsi baquishmari tsi quiha jahari arati xobo qui ja bacaniquë. Jatsi ja qui nohiria tëquë bëcani quiha. Jatsi tsahoxo tsi quiha tiisimati Jesú chitahëhuaniquë.
\v 3 Tiisimajahuano tsi quiha Dios yoba cahëxëni cabo, fariseobo, tihi cabá jochahuaxëni ca yoxa bëniquë Jesu qui; naa joni huëtsa ya inish cato; naa bënë ma ca ya tsamihacanish ca yoxa quiha. Bëxo tsi quiha nohiria bësojó tsi yoxa ja nimacaniquë.
\p 
\v 4 Jatsi Jesu qui ja chanicaniquë:
\p —Joni huëtsa, naa jahuë bënë ma ya quiha naa yoxa iquë pë. No jisquë ra.
\v 5 “Ja qui nohiria bá maxax niano. Namëhacati xo tocacanaibo” ii quiha Moisés yamabo jahuë yoba ó no. ¿Japa mia ti? ¿Jënihai naa yoxa yoati na? —i jaca niquë Jesu qui.
\p 
\v 6 Ja nëcacani quiha Jesu tanamaxëna. Jahuëcara ca ja pasomaha ca ja mëracascani quiha pë, ja qui quësocasquí na. Jatsi Jesu tëtohaca tsi mai tsi huishatsijahuaniquë jahuë mëtsisí no. Quëbiyamaniquë Jesu.
\p 
\v 7 Jatsi,
\p —¿Japa naa yoxa? ¿Jënihai? —iriatsi jaca niquë pë.
\p Jaha tsi Jesu niiniquë chanixëna. Chanipama tsi,
\p —Jariapari ja qui maxax niati xo tsohuëcara ca jochayama cato ra —i jato qui ja niquë.
\p 
\v 8 Jatsi ja tëtotëquëhaca tsi mai tsi ja huishatëquëniquë.
\v 9 Jahuë chani nicapama tsi quiha huësti huësti tsi yoxa qui quësocanaibá jisbërianiquë. Jariapari bocaniquë yosibo. Jaquirëquë shinapaya bo bocaniquë. Jatsi jamëpistia tsi Jesu iniquë niihai ca yoxa ya.
\v 10 Jatsi Jesu niitëquëniquë.
\p —¿Jahuënia ni mi qui quësocanaibo, yoxa? Yama tsi xo toa mi qui quësocatsai ca huësti cato pa —i yoxa qui ja niquë.
\p 
\v 11 —Yama a. Boyocaquë pa, Ibobá —i yoxá niquë.
\p Jatsi,
\p —Mi qui quësoyamaquia ëa ri. Cata. Jaboqui rohari tsi jochayamahuë —i ja qui Jesu niquë.
\s1 Jodiobo qui Jesú joi mëranina
\p 
\v 12 Jatsi arati xobó ca nohiria bo qui Jesu chanitëquëniquë:
\p —Maí ca nohiria Huëa ca ëa xo naa. Ea pi banahuahi tsi tsëmó tsi coyamaxëhi quiha mato. Mato quinia bërohuaxëquia, naa Huëa ë nori cato. Nohiria Bësomati Ibo ca ëa xo naa —nëa tsi ja nëcaniquë.
\p 
\v 13 Jatsi jodioba chama bá quëbiniquë:
\p —Mimë yoati tsi chaniqui mia pë. Mahitsa tsi xo toa mi yoahaina ra —iquiina.
\p 
\v 14 Jatsi,
\p —Emë yoati tsi ë chanipino tsi jari jabija xo noho chani ra, jahuënia ax ë joni ca ë cahëhai quëshpi na. Jasca, ë caxëhai ca cahëquia. Jama, jahuënia ax ë jonina, jahuënia tsi ë caxëhaina, tihi cabo cahëyamaqui mato ra.
\v 15 Ea ma cahëhai ca quëscahuaqui mato, nohiria quiniá tsi ma shinahai quëshpi na. Ja tsi xo toa ë pasomaha tsi xo mato chani. Toca tsi nohiria qui quësoyamaquia.
\v 16 Quësohë-pino tsi jabija tsi xo toa ë quësohaina, ëmëpistia ax tsi ë quësoyamahai quëshpi na. Ea, ëa raanish cato, tihi caba tsi xo toa nohiria qui quësohaina.
\v 17 Iriama tsi xo toa huësti roha ca joni jabija ca chanihaina. Oquë tsi xo dos. “Dos ca joni bo iti quiha” ¿iyamayamani mato yoba ra? “Jabija tsi xo dos ca joni ba chani, jasca ca ja chanicaquë no” ii quiha.
\v 18 Jabi ëa yoati chanihai ca huësti ca ëa xo naa. Ea yoati chanihai ca huëtsa tsi xo naa ëa raanish ca Jahëpa —nëa tsi jodioba chama bo qui Jesu nëcaniquë.
\p 
\v 19 Jatsi Jesu ja nicacaniquë:
\p —¿Jahuënia ni mi ipa ra? —iquiina.
\p Jatsi,
\p —Ea cahëyamaqui mato ra. Jasca, noho Jahëpa cahëyamaqui mato. Ea pi cahërohaquí tsi noho Jahëpa ma cahëquë aquë ra —i jato qui Jesu niquë.
\p 
\v 20 Arati xobó tsi Jesu nëcani quiha nohiria bo tiisimahi na. Nohiria parata biti caja tahë tsi nii ja ini quiha. Jasca, Jesu qui ja tsamiyamacani quiha, jari jahuë rësoti xaba tsëquëyamani quëshpi na.
\s1 “E caxëhai ca qui canoma xo mato” i Jesu nina
\p 
\v 21 Jatsi nohiria bo qui Jesu chanitëquëniquë:
\p —Caxëquia. E cano tsi ëa mëraxëqui mato; mahitsa. Jatsi mato jocha ó tsi rësoxëqui mato rë. Jabi ë cahai ca qui canoma xo mato —i ja niquë.
\p 
\v 22 Jatsi,
\p —¿Jahuë chanihi ni sa? ¿Jamë ixëhi ni sa? ¿Jëniriahax “E cahai ca qui canoma xo mato” i ja a sa? —i jodiobo niquë.
\p 
\v 23 Jatsi Jesú jato quëbiniquë:
\p —Maí ca nohiria bo xo mato. Jama, mana ax jonish ca ëa xo naa. Nëá racaqui mato. Nëá racayamahai ca ëa xo naa.
\v 24 Jabija tsi xo toa “Mato jocha ó tsi rësoxëqui mato” i ë ana. Xabahamati Ibo ë nori ca chahahuayamapihi tsi mato jocha ó tsi rësoxëqui mato ri —i jato qui Jesu niquë.
\p 
\v 25 Jatsi,
\p —¿Tsohuëcara ni mia ra? —i nohiria bo niquë.
\p Jatsi,
\p —¿Jënahuariahax “Tsohuëcara ni mia” icanai pë? Rëquë rohari tsi mato ë yoani quiha.
\v 26 Jari huëstima tsi xo toa mato yoati tsi ë yoahama cato, naa yoi ca ma acaina. Jama, ëa raanish cató ëa yoahai ca roha chaniquia. Emë yoati chaniyamaquia ra. Jabija tsi xo toa ëa raanish cato chani ra —i jato qui Jesu niquë.
\p 
\v 27 Jabi jahuë Jahëpa Dios yoati tsi chanihi ja ini nori jodioba chama bá cahëyamani quiha.
\p 
\v 28 Jaha tsi,
\p —Jihui ó tsi ëa, naa Nohiria Baquë namëxëqui mato ra. Namëxo tsi jaha ma pasohai ca Xabahamati Ibo ë nori ca cahëxëqui mato ra. Toatiyá tsi ëmë ax tsi ë yonocoyamahai ca cahëxëqui mato, Jahëpá ëa tiisimani ca jahuë bo roha ë yoahai quëshpi na.
\v 29 E bëtá xo ëa raanish cato ra. Ea jisbëriayamaxëhi quiha, ja qui jia ca ë aroha-arohahai quëshpi na —i ja niquë.
\p 
\v 30 Nëcajano tsi quiha huëstima cabo Jesu qui chitiminiquë.
\s1 Paquëmahacahax cabo, yonati bo
\p 
\v 31 Jatsi ja qui chitimihai ca jodiobo qui Jesu chaniniquë:
\p —E tiisimahai ca nicapihi tsi noho rabëtiria bo ixëqui mato ra.
\v 32 Jabija ca cahëxëqui mato. Jocha quima mato paquëmaxëhi quiha jabija ca Chani —i ja niquë jodiobo qui.
\p 
\v 33 Jatsi,
\p —Abraham yamaba chahitaxocobo xo noa ra. Yama tsi xo toa noqui yonahaina. ¿Jënahuariahax “Paquëmahacaxëqui mato” i mi na? —i Jesu qui jaca niquë.
\p 
\v 34 Jatsi Jesú quëbiniquë:
\p —Mato parayamaquia. Jocha yonati tsi xo toa jatiroha ca jochacanaibo.
\v 35 Jabi noitiria tsi xo yonati. Jahuë chama xobó tsi chitëroha-chitërohayamahi quiha, chama huëtsa qui ja iniahacamitsa iqui na. Jama, jamëri tsi xo chama baquë. Jahuë jahëpa xobó tsi chitëroha-chitërohahi quiha. Chama huëtsa qui iniahacatimaxëni quiha.
\v 36 Jasca, jocha quima Dios Baquë́ mato tsëcarohapino tsi shoma-shomaria ixëqui mato, naa chama baquë jascaria iquiina.
\v 37 Jabija. Abraham yamaba chahitaxocobo xo mato iquia ëa ri. Jama, jari mato qui yoi xo noho chani rë. Noho chani bicasyamaquí tsi ëa acasqui mato pë.
\v 38 Jatsi nicaparicana. Noho Jahëpá ëa jismani ca jahuë bo yoati chaniquia ra. Jama, toa chani nicacasyama xo mato pë, mato jahëpá yoba nicacasquí na —nëa tsi jodiobo qui Jesu nëcaniquë.
\p 
\v 39 Jatsi,
\p —Noho Jahëpa yoi tsi xo Abraham yamabo ra —i jaca niquë.
\p Jatsi,
\p —Abraham chahitaxocobo yoi bo irohapiquí tsi jia ca ma aquë aquë ra, naa ja ani jascaria.
\v 40 Jama, jaboqui ëa acasqui mato pë, jabija ca mato qui ë chaniquë no. Toca tsi Abraham yamabá ayamani quiha.
\v 41 Jabi mato jahëpa yoí acai ca jascaria ca aqui mato ra —i jato qui Jesu niquë.
\p Jatsi jodiobá quëbiniquë:
\p —Jia tsi no coniquë ra. Yoma bo ma xo noa. Noba Jahëpa yoi tsi xo Dios ra —iquiina.
\p 
\v 42 Jato Jesú quëbiniquë:
\p —Dios pi mato jahëpa iirohano tsi ëa ma noiquë aquë ra. Dios quima ax ë joniquë ra. Emëpistia tsi ë joyamani quiha. Jama, Diós ëa raaniquë.
\v 43 ¿Jënahuariaxo ë yoahai ca jahuë bo cahëyamacanai pë? Noho chani nicacasyama xo mato iquia.
\v 44 ¿Tsayacanai? Yoshi-yoshiria tsi xo toa mato jahëpa yoi ra. Mato jahëpa jaha quëëhai ca acasqui mato. Rëquë rohari tsi ati ibo ja ini quiha. Quiamisxëniria quiha. Jabija ca chanitimaxëni quiha. Jahuë jabi tsi xo quiamis-haina ra. Quiati ibo-iboria tsi xo toa ra.
\v 45 Ja tsi xo toa jaboqui tsi jabija ca ë chanino tsi ëa chahahuayamaqui mato pë.
\v 46 ¿Jënahuariahax tsi ë qui ma quësona? Jocha yama ca ëa xo naa. Jabija ca ë yoano tsi ¿jënihax tsi ë qui chitimiyamacanai?
\v 47 ¿Tsayayamacanai? Dios Chani nicahi quiha Diós-na bo. Tocama xo mato rë. Dios baquë bo ma xo mato ra. Ja tsi xo toa Dios Chani nicayamaqui mato iquia —nëa tsi quiha jodiobo qui Jesu nëcaniquë.
\s1 Jesu quirëquë Abraham inina
\p 
\v 48 Jatsi jodiobá quëbiniquë caxaquí na:
\p —Dios cahëtimaxëni ca carayana xo mia ra. Mia ri tsi xo toa yoshi jaya cato ra. ¿Jabija ma ni naa no yoahaina mia yoati na? —i Jesu qui jaca niquë.
\p 
\v 49 Jatsi,
\p —Yoshi yama ca ëa xo naa ra. Chanipama tsi Noho Jahëpa oquëhuaquia ra. Jama, mato tsi xo toa ëa ocahuahaina pë.
\v 50 Emë oquë bicasyama xo ëa; jama tobi quiha huëtsá ëa oquëhuacatsaina. Ea mëbicatsai ca tsi xo toa.
\v 51 Nicaparicana. Mato parayamaquia ra. Rësopistiayamariaxëhi quiha noho chani nicacanaibo —nëa tsi jato qui Jesu nëcaniquë.
\p 
\v 52 Jatsi jodiobá quëbiniquë:
\p —Jabija. Mia ri tsi xo yoshi jaya. Rësoniquë Abraham ra. Rësoyoniquë Dios Chani yoanish cabo ri. Jama, “Rësoyamapistiariaxëhi quiha noho chani nicahai cato” ¿i mi a pa?
\v 53 ¿Abraham yamabo oquë ni mia pa? Ja rësoniquë ra. Rësoyoniquë jaquirëquë ca Dios Chani yoanish cabo ri. ¿Jënahuaria raca jato oquë ca mi ina? —i jaca niquë.
\p 
\v 54 Jatsi Jesú jato quëbiniquë:
\p —Emë ë oquëhuapino tsi iriama tsi xo noho oquë ra. Jama, noho Jahëpa tsi xo toa ëa oquëhuahai cato, naa noba Jahëpa ma quënahai ca jascaria cato.
\v 55 Dios cahëyamaqui mato rë. Jama, Dios cahëhai ca ëa xo naa. “Dios cahëyamaquia” irohapihi tsi quiaxëni ca ë iquë aquë pë, naa quiaxëni cabo ma nori jascaria.
\v 56 Jasca, ë johai ca xaba mato jahëpa Abraham yamabá jiscasni quiha. Jasca, ë noho ja pasoni quiha. E noho pasohi tsi ja rani-ranini quiha —nëa tsi jato qui Jesu nëcaniquë.
\p 
\v 57 Jatsi jodiobá quëbitëquëniquë:
\p —Jari cincuenta años ma xo mia ra. ¿Jënahuariaxo raca Abraham mi jisni? —i Jesu qui jaca niquë.
\p 
\v 58 Jatsi,
\p —Mato parayamaquia. Abraham conox pari no tsi ë iniquë ra —i Jesu niquë.
\p 
\v 59 Jatsi jodiobá maxax bo topiniquë Jesu axëna. Jama, jato quima Jesu paxaniquë. Paxaxo tsi quiha jato arati xobo ja jisbayaniquë.
\c 9
\s1 Bëco ca joni Jesú jënimahuanina
\p 
\v 1 Copama tsi quiha bëco ca joni Jesú jisniquë. Jahuë coni ca bari rohari tsi quiha bëco ja iniquë.
\p 
\v 2 Jatsi,
\p —¿Jënihax tsi bëco tsi ja coni? ¿Tsohuë jochani? ¿Naa joni ni? ¿Jahuë nabo ni? —i jaca niquë Jesu nicahi na.
\p 
\v 3 Jatsi Jesú quëbiniquë:
\p —Jochayamaniquë naa joni. Jasca, jochayamaniquë jahuë nabo ri. Bëco tsi ja coniquë ra, ja jënimahuahacahai cató tsi Diós jahuë chama jismano iquish na.
\v 4 Jatsi ëa raanish cato yonoco ë ati xo. Dios bax yonocoti xaba tsi xo naa ra. Joxëhi quiha baquicha. Ja jono tsi yama tsi xo toa Dios bax ë yonocoxëhaina.
\v 5 Jama, maí ca nohiria bo yahi tsi maí ca nohiria ba Huëa ca ëa xo naa —nëa tsi quiha Jesu nëcaniquë.
\p 
\v 6 Chanihax mai tsi Jesú coshohaniquë. Coshohaxo tsi quiha jahuë quëyonó tsi matsa ja biqui-biquihaniquë. Jatsi matsacá tsi joni bëro ja sinoniquë.
\v 7 Sinohax,
\p —Siloé icanai cato ca jënë́ tsi bëchocota —i bëco ca joni qui Jesu niquë.
\p Jatsi joni caniquë. Bëchocohax tsi quiha ja taistëquëniquë. Jënima jahari ja joni quiha.
\v 8 Ja joquë tsi quiha ja tahë́ ca racacanaibo, toa joni cahëxëni cabo, tihi cabo ratëniquë.
\p —¿Parata bënaxëni ca tsahonish ca joni ma ni naa pa? —i jaca niquë.
\p 
\v 9 —¿Oca ma ni? —i jato rabë roha niquë.
\p Jatsi,
\p —Jama xo toa. Ja jisiria quiha —i nohiria huëtsa niquë.
\p Jatsi,
\p —Toa joni xo ëa ra —i parata bënaxëni ca niquë.
\p 
\v 10 Jatsi,
\p —¿Jënahuariaxo raca mi bëro jënimahuahacaha pa? —i ja qui nohiria bo niquë.
\p 
\v 11 Jatsi joní quëbiniquë:
\p —Tsohuëcara ca, naa Jesu icanai cató matsa biqui-biquihaquë. Jatsi noho bëro ja sinoquë pa. Sinohax, “Siloé ca jënë́ tsi bëchocota” i ë qui ja quë. Jatsi jënë qui ë caquë. Bëchocohax ë taisquë ra —i jato qui joni niquë.
\p 
\v 12 Jatsi,
\p —¿Jahuënia ni naa joni ra? —i nohiria bo niquë nicahi na.
\p —¿Jahuënia cara ca tia? Cahëyamaquia rë —i joni niquë.
\p 
\v 13 Jatsi bëco inish ca joni nohiria bá boniquë jodioba chama bo qui.
\v 14 Jabi joiti bari ja ini quiha, naa matsacá tsi Jesú joni bëro taismaquë no.
\v 15 Jatsi fariseobá, naa jodioba chama bá toa joni nicaniquë jato ri:
\p —¿Jënahuariahax mi taismahacaha sa? —iquiina.
\p Jatsi joní quëbiniquë:
\p —Noho bëró tsi matsa naa joní janaquë tsi ë bëchocoquë. Jaboqui taisquia ra —iquiina.
\p 
\v 16 Jatsi,
\p —Dios cahëyamahi quiha naa joni ra. Joiti barí tsi yonocohi quiha pë —i jato rabë roha niquë.
\p Jama,
\p —Jistiria naa joní aquë ra. ¿Jënahuariaxo raca jochahuaxëni ca joní nëca ca jisti ana? Tonia Dios cahëhi quiha —i fariseobo huëtsa bo ni quiha.
\p 
\v 17 Jatsi bëco inish ca joni qui chama bo chanitëquëniquë:
\p —¿Japa mia ti? ¿Jënihai mia ri naa joni yoati na? ¿Tsohuë ni naa joni, naa mia taismahax cato? —i jaca niquë.
\p Jatsi taismahacanish cató quëbiniquë:
\p —Dios Chani yoati ibo tsi xo naa joni iquia —iquiina.
\p 
\v 18 Jabi bëco ja iqui ca jodioba chama bá chahahuayamani quiha pë. Jaha tsi jahuë jahëpa, jahuë jahëhua, tihi cabo ja bënacaniquë jato nicaxëna.
\p 
\v 19 —¿Mato baquë ni naa? ¿Bëco tsi ja coni? ¿Jënahuahax tsi jaboqui taisti mëtsa ja iqui? —i jahuë nabo qui jaca niquë.
\p 
\v 20 Jatsi jahuë nabá quëbiniquë:
\p —Noba baquë yoi xo naa. Jabija, bëco tsi ja coni quiha.
\v 21 ¿Jënahuariahax ja taismahacaha sa? ¿Tsohuëcaracá taisamaha sa? Cahëyamaqui noa ra. Nicacana, shina coshi xo. Jamë xo mato ja yoano —i jahuë jahëpa niquë.
\p 
\v 22 Nëca tsi jahuë nabo chanini quiha, jodioba chama bo qui raquëhi na. Jodioba catiti xobo quima ja niahacacasyamacani quiha. Jabi “Niahacati quiha tsohuëcara ca ‘Jaha no pasohai ca Xabahamati Ibo xo naa joni’ icanaina” i jodiobo ni quiha.
\v 23 Jabi ja tsi xo toa “Shina coshi xo noba baquë. Nicacana” i jato qui jahuë nabo ni quiha. Jasca, arati xobo quima ja niahacacasyamacani quiha.
\v 24 Jatsi jodioba chama bá bëco inish ca bënatëquëniquë:
\p —Quiayamahuë. Jochahuaxëni ca Jesu nori ca cahëqui noa ra —i ja qui chama bo niquë.
\p 
\v 25 Jatsi,
\p —¿Oca ma ni? Cahëyamaquia. Jabi bëco ca joni ë iquë; jaboqui taisquia ra —i bëco inish ca niquë.
\p 
\v 26 Jatsi,
\p —¿Jënahua mi bax jahuaha? ¿Jënahuaxo tsi mia ja taismaha? —i tëquë chama bo niquë.
\p 
\v 27 Jatsi bëco inish cató jato quëbitëquëniquë:
\p —Ja aca mato ë yoaquë ra. ¿Ea ma nicayamacana? ¿Tonia jahuë rabëti bo manëcascanai pa? —iquiina.
\p 
\v 28 Jatsi toa joni ja raahacaniquë pë:
\p —Jesu rabëti xo mia pë. Jama, Moisés yamabo banahuacanaibo xo noa.
\v 29 Moisés yamabo qui Dios chanini ca cahëqui noa. Naa Jesu cahëyamaqui noa. Tsohuëcara quima jahuë chama ja bini cahëyamaqui noa —i ja qui jaca niquë.
\p 
\v 30 Jatsi joní jato quëbiniquë:
\p —Anomaria tsi xo toa naa joní acana. Noho bëro ja jiahuaquë ra. Jama, ¿jahuënia ax ja joni ca cahëyamacanai pa?
\v 31 Jochacanaibo nicayamahi quiha Dios ra. Jama, ja qui aracanaibo, jahuë yoba bo nicacanaibo, tihi cabo nicahi quiha.
\v 32 Mai nëhohuahacanitiya rohari tsi bëco conish ca jënimahuahacahai ca nicahama ini quiha.
\v 33 Dios quima joyamarohapihi tsi ati mëtsama naa joni iquë aquë ra —nëa tsi bëco inish ca nëcaniquë jodiobo chama bo qui.
\p 
\v 34 Jatsi,
\p —Jochahuaxëni mi coniquë ra. ¿Noqui tiisimahi ni mia pa? —i jaca niquë.
\p Jatsi quiha jato arati xobo quima toa joni ja niacaniquë pë.
\s1 Bëco cabo jascaria xo jochacanaibo
\p 
\v 35 Jabi jato arati xobo quima ja niahacani ca Jesú nicaniquë. Nicaxo tsi quiha joni mërahi ja caniquë. Bichi tsi quiha,
\p —¿Nohiria Baquë qui chitimihai? —i ja qui Jesu niquë.
\p 
\v 36 Jatsi joní quëbiniquë:
\p —¿Tsohuë ni toa, Taitá? Toa joni qui chitimicasquia ra —iquiina.
\p 
\v 37 Jatsi,
\p —Mi jisquë ra. Ja tsi xo toa mi bëta chanihai cato —i Jesu niquë.
\p 
\v 38 —Chitimiquia, Ibobá —i joni niquë.
\p Jatsi Jesu bësojó tsi quiha ja mëniniquë.
\p 
\v 39 Jatsi Jesu chaniniquë:
\p —Naa mai qui ë joniquë nohiria ba jocha bërohuaxëna. Bëco cabo, naa jochacanaibo mëbicasquia ra, xabahamati quinia ja jiscano. Jama, ëa iqui tsi bëconayoicani quiha “Bëco yama xo noa” icanaibo. Jato jocha jisyamacani quiha rë —nëa tsi Jesu nëcaniquë.
\p 
\v 40 Jatsi,
\p —¿Bëco ni noa pa? —i toa ca chama rabë roha bo niquë, ja yoani ca nicahax na.
\p 
\v 41 Jatsi Jesú quëbiniquë:
\p —Jabija ca cahëyamarohapihi tsi quësohacatima ma iquë aquë. Jama, tobi mato jocha rë, “Bëco yama xo noa” ma iquii iqui na —nëa tsi quiha Jesu nëcaniquë jato qui chanihi na.
\c 10
\s1 Oveja panë chani
\p 
\v 1 —Mato parayamaquia —i Jesu niquë—. Oveja yomaxëni ca tsi xo toa oveja panë caiti qui jicoyamahai cato. Iti huëtsá tsi matarahi quiha pë.
\v 2 Jama, panë caiti qui jicohi quiha oveja ototi ibo.
\v 3 Ja jono tsi quiha ja bax caiti japëcahi quiha panë obëso cato. Jicoxo tsi jato janë́ tsi jahuë oveja bo quënahi quiha. Jabi iboba joi cahëhi quiha oveja bo. Quënaxo tsi cacha jato rëquëninihi quiha.
\v 4 Paquëmahax jato bëbo cahi quiha ibo. Jatsi, banahuacani quiha jahuë oveja, jahuë joi cahëquí na.
\v 5 Joni huëtsa banahuayamacani quiha. Ja quima jabacaxëcani quiha jahuë joi cahëyamahi na —nëa tsi Jesu nëcaniquë.
\p 
\v 6 Naa chani pistia Jesú yoaniquë nohiria bo mëbixëna. Jama, ja yoani ca nohiria bá cahëyamani quiha.
\s1 Ototi Ibo jiaxëni cato
\p 
\v 7 Jatsi quiha jahuë chani Jesú bërohuaniquë ja cahëyoicano. Ja nëcani quiha:
\p —Mato parayamaquia. Oveja panë Caiti ca ëa xo naa ra.
\v 8 Yomaxëni cabo jascaria tsi xo ëa bëbo bëcanish cabo, naa mahitsa ca tiisimacanaibo. Jato qui nicayamahi quiha noho oveja yoi bo.
\v 9 Jabi Caiti xo ëa ra. Xabahamahacaxëti xo toa tsohuëcara ë noho jicoti cato. Jahá bësoxëquia. Toa shomahuaxëhi quiha Dios. Yamaxëhi quiha toa ja naris-haina iquia.
\p 
\v 10 ‘Jama, oveja yomahi johi quiha yomaxëni cato. Joxo tsi oveja namëhi quiha. Quëyohi johi quiha rë. Jabi tocahi quiha mahitsa ca tiisimacanaibo pë. Jama, ëa ti tsi xo toa nohiria bësomahi johaina, oquë tsi ja bësocano iquish na.
\v 11 Jabi oveja ototi ibo jiaxëni ca ëa xo naa. Emë aapiquia oveja bax nati.
\v 12 Jama, oveja jisbëriahi quiha yonati, johai ca cama jisi na. Jishopë, jato obëso ca ma xo toa. Oveja ibo ma quiha. Ja jabano tsi oveja pihi quiha camano. Jatsi jato pacanamahi quiha rë.
\v 13 Jasca, parata quëshpi roha yonocohi quiha yonati. Oveja noiyamahi quiha rë. Jabi ja tsi xo toa jabahi quiha yonati, cama joquë no.
\v 14-15 Jama, oveja ó bësoti jiaxëni ca ëa xo naa. Noho oveja cahëquia, naa ëa noho Jahëpá cahëhai jascaria. Jascaria, ëa cahëcani quiha noho oveja, naa noho Jahëpa ë cahëhai jascaria. Oveja bax ëmë aapiquia nati.
\v 16 Jasca, oveja huëtsa bo jaya xo ëa ra. Carayana ca nohiria bo ca xo. Jato ri rëquëninixëquia. Noho joi qui nicacaxëcani quiha jato ri. Jatsi huësti ca nohiria maxo icaxëcani quiha jodiobo, carayanabo tëquë. Huësti ca ototi ibo jayacaxëcani quiha.
\p 
\v 17 ‘Jabi ëa noihi quiha noho Jahëpa, oveja bax nati ëmë ë acai iqui na. Rësohax bësotëquëxëquia.
\v 18 Jabi yama tsi xo toa jahuë chamá tsi ëa namëti mëtsa cato. Jama, caxacanaibo qui ëmë aquia nati. Noho chamá tsi ëmë aquia nati. Jasca, noho chamá tsi bësotëquëxëquia. Jabi noho Jahëpá ëa raaniquë nohiria bo bax nati —nëa tsi quiha nohiria bo qui Jesu nëcaniquë.
\p 
\v 19 Jatsi Jesú yoani ca iqui tsi jodiobo mapëxënaniquë. Rabë ca shinahai ca ja jayacani quiha Jesu tahëxo na. Jatsi,
\p 
\v 20 —Yoshi jaya xo naa joni ra. Yoyoxëni quiha. ¿Jëniriaxo raca ja qui nicacanai pë? —i jodio huëstima cabo niquë.
\p 
\v 21 Jama,
\p —Nëca tsi chaniti mëtsama xo yoshi jaya cato ra. ¿Jënahuariaxo raca yoyoxëni cató joni bo taismana? —i jodiobo tëxë bo niquë ja yoati na.
\s1 Jodiobá Jesu chahahuayamanina
\p 
\v 22 Jabi Jerusalén tsi quiha jodiobo mani iniquë. Dios qui jamë aquëquëti fiesta ja ini quiha. Jatiroha ca xënipá tsi quiha naa fiesta ja i-ipaocani quiha, matsitiyá no.
\v 23 Toatiyá tsi quiha arati xobó tsi co-cohi Jesu iniquë, naa Salomón Portal icanai cató no.
\v 24 Co-cojano tsi quiha jodioba chama bo ja qui quëtsoniquë ja qui chanicatsi na.
\p —¿Jaha no pasohai ca Xabahamati Ibo ni mia sa? Bëro tsi noqui yoahuë. Yosanaqui noa ra. ¿Jënino noqui yoahai sa? —i Jesu qui jaca niquë.
\p 
\v 25 Jatsi Jesú jato quëbiniquë:
\p —Mato ë yoahitaquë ra. E yoaquë tsi ëa chahahuayamahitaquë mato pë. Ea yoati tsi jabija ca chanihi quiha ë acai ca jisti bo. Jabi naa jisti bo aquia noho Jahëpa chamá no.
\v 26 Jama, ëa chahahuayamaqui mato rë, noho oveja ma nomari iqui na.
\v 27 Noho joi nicahi quiha noho oveja yoi bo. Jasca, noho oveja bo cahëquia. Ea banahuacani quiha.
\v 28 Jasca, jato bëso-bësopaomaxëquia. Bënotimaxëni ca xo. Jabi yama tsi xo toa ë quima jato tsëcati mëtsa cato ra.
\v 29 Jabi ë qui jato noho Jahëpá aniquë, jato ó ë bësono. Jatiroha cabo oquë tsi xo noho Jahëpa ra. Jabi yama tsi xo toa noho Jahëpa quima jato tsëcati mëtsa cato iquia.
\v 30 Jasca, ëa, noho Jahëpa, tihi ca tsi xo huësti roha cato —nëa tsi Jesu nëcaniquë.
\p 
\v 31 Jatsi pë jodiobá maxax bo topitëquëniquë axëna.
\p 
\v 32 Jatsi Jesú jato quëbiniquë:
\p —Jisti huëstima cabo ë aquë mato bax na jisti. Ja acacaniquë noho Jahëpa chamá no. ¿Jëni ca jisti jiaxëni ca quëshpi tsi ëa acascanai pë? —iquiina.
\p 
\v 33 Jatsi quiha jodiobá quëbiniquë:
\p —Mi acai ca yonoco jia ca quëshpi tsi mia acasyamaxo noa; jama Dios mi ocahuahai quëshpi ja nori. Yoi tsi xo toa mi chanihaina ra. Jasca, Dios manëcasqui mia pë, joni roha mi nori —i jaca niquë.
\p 
\v 34 Jatsi Jesú quëbiniquë:
\p —Yoi ma xo ë chanihana ra. Quënëhacanish cabo ó tsi “dios bo” mato rëquëyamabo quënahacani quiha, “Dios bo xo mato” i jato qui Dios quë no.
\v 35 Quiayamahi quiha Dios Chani ra. “Dios bo” ja quënahacani quiha, naa Dios Chani bicanish cabo. Dios bo xo nohiria tëquë; jahuë jabi ja jayacanai iqui na.
\v 36 Japi “Dios baquë xo ëa” iti mëtsa xo ëa ri ra. Jabi noho Jahëpa Diós ëa biha ca tsi mai qui ëa ja raaniquë. Jatsi, ¿jënahuariahax raca “Dios ocahuaqui mia pë” i ë qui ma na, “Dios Baquë xo ëa” i ë quë no?
\v 37 Noho Jahëpa yonoco pi ë ayamano tsi ëa chahahuayamacana.
\v 38 Jama, jahuë yonoco pi ë ano tsi ë acai ca jisti bo chahahuacana, ë qui ma chitimiquë mari. Noho jisti bo chahahuapiquí tsi ë nohó Jahëpa iquiina, jahá ë iquiina, tihi cabo cahëxëqui mato tia —nëa tsi Jesu nëcaniquë.
\p 
\v 39 Jatsi Jesu qui ja tsamitëquëcascaniquë namëxëna. Jama, jato quima ja paxaniquë ra.
\v 40 Paxahax tsi quiha ani Jordán Jesú shitaniquë. Shitahax toa tsi quiha, naa jariapari ca Juán nohiria bo ashimani cató tsi ja chitëniquë.
\v 41 Toatiyá tsi quiha Jesu qui huëstima cabo bëcaniquë.
\p —Jisti bo Juán ayamaniquë. Jama xo naa joni ra. Ariahi quiha ra. Naa joni yoati tsi jabija ca Juán yoani quiha —i nohiria bo niquë.
\p 
\v 42 Toá tsi quiha huëstima cabo ja qui chitiminiquë.
\c 11
\s1 Lázaro rësonina
\p 
\v 1 Jabi iquihi quiha Lázaro iniquë rë. Betania yacatá tsi ja racani quiha jahuë yoxacabo ya; naa María, Marta, tihi cabo ya.
\v 2 Jabi Iboba tahë qui perojomë japanish ca María tsi xo naa. Jasca, jahuë boó tsi María Jesu tahë masani quiha. Toatiyá tsi iquihi jahuë jonica ini quiha.
\v 3 Jaha tsi quiha Jesu qui jahuë yoxacabá chani raaniquë:
\p —Iquihi quiha mi rabëtiria rë, Ibobá —iquiina.
\p 
\v 4 Jato chani nicahax,
\p —Iquihi quiha Lázaro rë —i Jesu niquë jahuë rabëti bo qui—. Jama, rësoyamaxëhi quiha. Iquihi quiha, jia tsi Dios yoati tsi nohiria bo chanino iquish na. Dios Baquë oquë jismahacati xo jahá no —i ja niquë.
\p 
\v 5 Jabi Marta, jahuë noma María, Lázaro, tihi cabo Jesú noini quiha.
\v 6 Jabi Lázaro iquihai ca yoati tsi nicahax jato xobo qui Jesu cayamatapiniquë pa. Jari dos bari no tsi quiha ja chitëniquë ja ini cató no.
\m 
\v 7 Jaquirëquë quiha,
\p —¿Jahari jodioba mai qui canomani, naa Lázaro racahai ca qui? —i jahuë rabëti bo qui Jesu niquë.
\p 
\v 8 Jatsi jahuë rabëti bá quëbiniquë:
\p —Mia manacani quiha pë jodioba chama bo. Maxaxá tsi mia acascani quiha pë. ¿Jahari catëquëhai pa? —iquiina.
\p 
\v 9 Jatsi Jesú jato quëbiniquë:
\p —Jabi Diós ëa raaniquë jahuë yonoco ati. Jari jatihuahama xo noho yonocoti xabaca ra. Jasca, yama tsi xo toa ëa ati mëtsa cato jaboqui. Jari jatihuahama quiha noho yonocoti xabaca iquia.
\v 10 Jama, Dios bax noho yonocoti xaba jatiquë tsi ë qui tsamixëhi quiha ë qui caxacanaibo —nëa tsi Jesu nëcaniquë.
\p 
\v 11 Jatsi,
\p —Oxa xo Lázaro rë. Jaha bësomahi caquia ra —i jato qui ja niquë.
\p 
\v 12 Jatsi,
\p —Oxapihi tsi chamaxëhi quiha tia, Ibobá —i jaca niquë nicahax na.
\p 
\v 13 Jama ja rësohitaha yoati tsi Jesu chanihi ini quiha. Jama, Lázaro oxahai ca ja quëscahuacani quiha; oxajano mari.
\v 14 Jatsi bëroria tsi jato qui Jesu chaniniquë:
\p —Nahitaquë Lázaro rë.
\v 15 E qui jia tsi xo ja bëta ë yamahitahana ja rësoquë no. Ja iqui tsi oquëxëhi quiha ë qui ma chitimihaina ra. ¿Jisi canomani? —i jato qui ja niquë.
\p 
\v 16 Jatsi,
\p —¿Jesu ya canomani, ja bëta rësoti? —i Tomás niquë jahuë rabëti bo qui.
\s1 Nohiria Bësomati Ibo
\p 
\v 17 Betania qui cahëxo tsi quiha naama, cuatro bari no tsi ja maihuahacani nori ca Jesú nicaniquë.
\v 18 Jabi Betania basima Jerusalén ini quiha. Cariama quiha; una hora nama.
\v 19 Jaha tsi Jerusalén ax huëstima ca jodiobo bëcaniquë, Marta, María, tihi cabo bëpasimaxëna, jato jonica rësohitaha iqui na.
\v 20 Jatsi Jesu johai ca Martá nicaniquë. Nicaxo tsi quiha Jesu bëchahi ja caniquë. Cayamaniquë María. Xobó tsi ja chitëni quiha.
\v 21 Jesu bëchahax,
\p —Nëá pi mi rohano tsi noho jonica rësoyamaquë aquitaquë rë, Ibobá.
\v 22 Jabi jaboqui jahuëcara ca Dios mi bënahai ca mi qui axëhi quiha tia —i Jesu qui Marta niquë.
\p 
\v 23 Jatsi,
\p —Bësotëquëxëhi quiha mi jonicato ra —i Jesu niquë.
\p 
\v 24 —Jabija; toca xo tia. Jaroha ca barí tsi bësotëquëxëhi quiha, naa jatiroha cabo bësotëquëxëquë no —i Marta niquë.
\p 
\v 25 Jatsi Jesú quëbiniquë:
\p —Rësonish cabo Bësomati Ibo ca ëa xo naa ra. Jabi bësotëquëxëhi quiha ë qui chitimihai ca bësoyama cato.
\v 26 Bëso-bësopaoxëhi quiha tsohuëcara ca ë qui chitimihai cato. Dios quima aquëquëmahacatimaxëni ixëhi quiha. ¿Jabija ma ni, Martá? —i ja qui Jesu niquë.
\p 
\v 27 Jatsi,
\p —Jabija xo ra, Ibobá. Dios Baquë, naa nohiria bo jaha pasohai ca Xabahamati Ibo ca mia xo naa —i Marta niquë.
\s1 Jesu aranina
\p 
\v 28 Chanihax jahuë noma bënahi Marta caniquë. Cahax,
\p —Joquë Maestro ra. Mia jiscatsi quiha —i ja qui Marta niquë, baxëxhi na.
\p 
\v 29 Nicahax joitapi María niquë Jesu qui caxëna.
\v 30 Jari yaca cacha Jesu ini quiha, naa Marta ja bëchani cató no.
\v 31 Jabi María jisbayahai ca jisi tsi toá ca jodiobá banahuaniquë jato ri, naa xobó ca María bëpasimacanaibo. Ja banahuacani quiha, Lázaro maí tsi ja aracatsai quëscahuaquí na.
\v 32 Jatsi Jesu qui María cahëniquë. Cahëhax jatahë tsi quiha ja mëniniquë. Jatsi,
\p —Nëá pi mi rohano tsi noho jonica rësoyamaquë aquitaquë rë, Ibobá —i María niquë.
\p 
\v 33 Araconaniquë María rë. Ara-araniquë ja bëta bëcanish ca jodiobo ri. Jaha tsi Jesu cohuërianiquë.
\p 
\v 34 Jatsi,
\p —¿Jahuënia ni jahuë mai? —i Jesu niquë.
\p —Jisi jopa —i jaca niquë.
\p 
\v 35 Jatsi aratsi Jesu niquë jaa ri.
\v 36 Jatsi,
\p —Tsayacapa. Lázaro ja noini quiha —i jodiobo niquë.
\p 
\v 37 Jatsi,
\p —¿Bëco cabo ja taismayamayamani? ¿Tonia rësohai quima Lázaro jënëmati mëtsa ja iyamayamahitaha? —i huësti huësti ca niquë.
\s1 Lázaro bësotëquëmahacanina
\p 
\v 38 Cohuëriahax Lázaro mai qui Jesu caniquë. Jabi macaná ca quiní tsi ja maihuahacani quiha. Jasca, jahuë maiquini qui maxax chahitaxëni tarahacani quiha japati.
\v 39 Jatsi,
\p —Tori maxax taracana —i nohiria bo qui Jesu niquë.
\p Jatsi,
\p —Pisi quiha, Ibobá. Ja rësohitaquë. Cuatro bari tsi quiha —i ja qui Marta niquë, naa rësohitahax cato yoxacato.
\p 
\v 40 Jatsi Jesú quëbiniquë:
\p —“E qui chitimipiquí tsi Dios chama jisxëqui mia ra” ¿iyama mi qui ë a? —iquiina.
\p 
\v 41 Jatsi nohiria bá bahama maxax taraniquë. Jatsi nai qui Jesú tsayahaca tsi jahuë Jahëpa qui ja chaniniquë:
\p —Ea nicaqui mia, noho Jahëpá. Ja quëshpi tsi “Gracias” iquia.
\v 42 Ea mi nicarohahai ca cahëquia. Jama, naa nëá ca niicanai ca nohiria bax bëro tsi ë chaniquë, ëa mi raani ca ja cahëcano —nëa tsi jahuë Jahëpa qui Jesu nëcaniquë.
\p 
\v 43 Jatsi Jesú quënaniquë:
\p —Huajahuë, Lazaró —iquiina.
\p 
\v 44 Jatsi rësonish ca Lázaro huajaniquë. Raití tsi jahuë tahë bo, jahuë mëquë bo, tihi cabo yabohacani quiha. Jasca, jahuë mapo ri yabohacani quiha raití no. Jatsi,
\p —Yaboco ca mëristsacana. Ja cano ra —i jato qui Jesu niquë. \fig “Huajahuë, Lazaró” i Jesu nina|src="cn01769b.tif" size="span" copy="©1978 David C. Cook Publishing Company" ref="JHN 11.44"\fig*
\s1 Jodioba chama bá Jesu acasnina
\r Mateo 26.1-5; Marcos 14.1-2; Lucas 22.1-2
\p 
\v 45 Jabi Jesú ani ca huëstima ca jodiobá, naa María jisi bëcanish cabá jisniquë. Jisi tsi quiha ja qui ja chitimicaniquë.
\v 46 Jama, jato huësti huësti cabo bocaniquë Jesú ani ca yoati tsi fariseobo qui yoaxëna.
\v 47 Jatsi arati ibo ba chama bo, fariseobo, tihi cabo jato jodioba chama bá quënaniquë, jato bëta chaninaxëna.
\p —¿Jënahuariaxëhi ni noa rë? Jisti yoi bo aqui quiha naa joni ra.
\v 48 Naa joni pi no jënëyamano tsi chahahuaxëhi quiha nohiria tëquë pë. Naa Jesu pi ja chahahuacano tsi joxëhi quiha romanoba soldado bo tonia, noba arati xobo potasxëna. Jatsi noqui quëyocaxëcani quiha ra tonia —nëa tsi chama bo nëcaniquë.
\p 
\v 49 Jatsi chanitsi jato huësti ca niquë, naa Caifas icanai cato. Jabi toa xëni no tsi quiha jato arati ibo-iboria ja ini quiha. Jatsi,
\p —¿Jënahuariacascanai pë?
\v 50 Oquë tsi xo huësti ca joni nohiria bo bax rësohaina iquia. ¿Jesu tahëhax tsi quëyohacaxëti ni noba maí ca nohiria bo ra? Ja rësono iquia —nëa tsi jato qui Caifás nëcaniquë.
\p 
\v 51 Jabi jamë yoi tsi chama Caifás chaniyamani quiha. Jama, toa xëni no tsi quiha arati ibo ba chama ja ini iqui tsi Dios quima jahuë chani joni quiha. Ocapixëti ca jahuë bo ja chanini quiha. “Noqui jodiobo ratixëhi quiha naa joni ra nati” i ja ni quiha.
\v 52 Jasca, “Dios xocobo, naa pacanamahacanish ca carayanabo ri catiaxëhi quiha, huësti ca nabo amaxëna” i ja ni quiha.
\v 53 Jaha tsi toa bari rohari tsi jodioba chama bá Jesu acasni quiha pë.
\p 
\v 54 Japi nohiria xërëquë tsi quiha bëro tsi Jesu coyamani quiha. Toa chama bo iqui tsi quiha jodioba mai ja jisbayani quiha. Jisbaya tsi xaba basima ca qui ja cani quiha chitëxëna. Toá tsi quiha Efraín icanai ca yacatá tsi ja chitëniquë jahuë rabëti bo ya.
\s1 Pascua fiesta chitahënina
\p 
\v 55 Jabi basima jodioba pascua fiesta ini quiha. Jabi fiesta chitahënox pari no tsi huëstima ca nohiria Jerusalén qui bocaniquë jianati jabi axëna.
\v 56 Arati xobó tsi catihax Jesu yoati tsi ja chaninabëquicaniquë. Jesu mërahi ja icani quiha. Nicahi tsi,
\p —¿Japa? ¿Pascua fiesta qui joyamahi ni Jesu? —i nohiria bo niquë jiscascanina.
\p 
\v 57 Jabi jodioba chama bá Jesu bicasniquë pë ja qui tsamicasquí na. Jaha tsi,
\p —Jesu jono tsi noqui yoacaxëcahuë —i nohiria bo qui jaca niquë.
\c 12
\s1 Perojomé tsi Jesu tahë ashimahacanina
\r Mateo 26.6-13; Marcos 14.3-9
\p 
\v 1 Toatiyá tsi quiha pascua fiesta tsëquëti basima iniquë. Seis bari tsi chitahëpaima ja ini quiha. Jatsi Betania qui Jesu caniquë, naa Lázaro xobo qui, naa Jesú bësotëquëmani ca joni xobo qui.
\v 2 Toa ax tsi quiha Jesu bax oriquiti shomahuahacaniquë. Jato taahi María ini quiha. Jasca, Jesu ya oriquihi Lázaro ini quiha jaa ri.
\v 3 Jatsi nardo icanai ca perojome copixëni cató tsi quiha Mariá Jesu tahë ashimaniquë. Ashimaxo tsi quiha jahuë boó tsi jahuë tahë ja masaniquë. Jatsi xobó tsi jahuë chopish rëamëni quiha.
\v 4 Jatsi Judas Iscariote, naa Jesu rabëti chaniniquë. Jabi jodioba chama bo qui Jesu mëanish ca ja ini quiha. Jatsi,
\p 
\v 5 —¿Jënixo tsi naa perojome iniayamahacaha pa? Copixëni quiha. Ja iniahacarohapino tsi huëstima ca parata no biquë aquë rë, noitiria cabo ati ra —i ja niquë.
\p 
\v 6 Jabi nëca tsi Judas chanini quiha, parata yomaxëni ca ja ini quëshpi na. Noitiria cabo ja noiyoiyamani quiha. Jasca, Jesu rabëti ba parata obëso ca ja ini quiha pë. Jaha bësoquí tsi quiha ja yomapaoni quiha.
\p 
\v 7 Jatsi Jesu chaniniquë:
\p —Jënëmayamacana. Noho maihuati xaba bax yoxá ano.
\v 8 Mato bëtarohaxëhi quiha noitiria cabo. Jama, mato bëtayamarohahai ca ëa xo naa ra —i ja niquë.
\p 
\v 9 Jatsi Betaniá ca Jesu ini ca Jerusalén ca nohiria bá nicaniquë. Nicahax toa tsi quiha ja bocaniquë Jesu jisi na. Nohiria tirixëni quiha. Jasca, Lázaro ri, naa bësotëquëmahacanish ca ja jiscascani quiha.
\v 10 Jaha tsi Lázaro ri arati ibo ba chama bá acasniquë.
\v 11 Jabi Lázaro bësotëquëmahacani iqui tsi huëstima ca jodiobá jato rëquëniniti ibo bo jisbëriani quiha Jesu banahuaxëna. Jisbëria tsi quiha Jesu qui chitimitsijaca-niquë.
\s1 Jerusalén qui Jesu jiconina
\r Mateo 21.1-11; Marcos 11.1-11; Lucas 19.28-40
\p 
\v 12 Huëaquë tsi quiha Jerusalén qui Jesu johai ca nohiria bá nicaniquë, naa pascua fiesta bëcanish cabo.
\v 13 Nicaxo tsi quiha xëbini pëhi jascaria cabo ja bicaniquë bahi poohati. Bichi tsi quiha Jesu bëchahi ja bocaniquë. Jatsi quënatsi nohiria bá huaniquë:
\p —Jia xo Dios. Shomahuahaca ca tsi xo naa Iboba janë́ tsi johai cato ra. Noqui Israél caba chama-chamaria Diós shomahuano ra —i jaca niquë.
\p 
\v 14 Jatsi quiha Jesú burro biniquë. Bichi tsi jacacha ja tsahoni quiha, Quënëhacanish cabá yoani jascaria.
\v 15 “Mato chama-chamaria qui raquëyamacana, Israél ca nohiria bá. Burró tsaho joxëhi quiha pa” i Quënëhacanish cabo ni quiha.
\v 16 Jabi toatiyá tsi toa quënëni ca Jesu rabëti bá cahëyamani quiha, naa toca tsi Jerusalén qui ja jicohai yoati na. Jama, nai qui ja tërohacaquë tsi Jesu yoati ja quënëhacani ca ja shinatapicani quiha. Jabi Quënëhacanish cabo jatihuahacani quiha toca tsi Jerusalén qui ja jicoquë no.
\p 
\v 17 Jasca, Jesu ya huëstima ca nohiria bo ini quiha maiquini quima Lázaro ja quënaquë no. Toa xo tsi quiha Lázaro ja bësotëquëmani ca ja tsayacani quiha. Tsayaxo tsi quiha Jerusalén ca nohiria bo ja yoacani quiha.
\v 18 Jabi ja tsi xo toa huëstima ca nohiria bëchahi bocaniquë, Jerusalén qui Jesu jicoquë no.
\v 19 Jatsi chaninabëquitsi quiha jodioba chama bo niquë:
\p —¿Jënahuariaxëhi ni noa pë? ¿Tsayacanai? Ja qui jabacani quiha nohiria tëquë pë —iquiina.
\s1 Carayanabo Jesu qui jonina
\p 
\v 20 Jabi Jerusalén qui bëcaniquë carayanabo. Rabë roha quiha. Pascua fiesta ati ja bëcaniquë jato ri.
\v 21 Felipe qui basimahax,
\p —Jesu jiscasqui noa, Señór —i quiha jaca niquë ja qui.
\p 
\v 22 Jatsi Andrés yoahi Felipe caniquë. Jatsi Jesu qui ja bobëquicaniquë yoaxëna. Jatsi carayana bëcanai ca ja yoacaquë tsi quiha
\v 23 Jesú quëbiniquë:
\p —Joquë hora ra, naa Nohiria Baquë oquënaxëquë no.
\v 24 Mato parayamaquia. Saihuayamaxëhi quiha trigo bëro, maí tsi ma banayamaquë no. Jascaria, Dios xocobo paxa bo sainox pari no tsi rësoparixëti xo Nohiria Baquë. E namëhacaxëti quiha.
\v 25 Parayamaquia. Quëyohacaxëti xo jahuë shina noixëni cato. Jama, xabahamahacaxëti xo toa jahuë shina noiyamahai cato. Bëso-bësopaoxëhi quiha toa.
\v 26 Ea banahuaxëti xo tsohuëcara ë bax yonococatsaina iquia. Jatsi nai qui ë tërohacano tsi ë bëtaxëhi quiha noho yonoco acai ca ri. Tsohuëcara pi ë bax yonocono tsi toa oquëhuaxëhi quiha noho Jahëpa ra —nëa tsi Jesu nëcaniquë.
\s1 Ja rësohai ca yoati tsi Jesu chaninina
\p 
\v 27 —Jaboqui shina-huëjënaquia rë. ¿Jënixëhi ni ëa rë noho Jahëpa qui? “Naa tënëti xaba quima ëa tsëcahuë ra, noho Jahëpá” ¿ixëhi ni ëa sa? Iyamaxëquia. E tënëxëti xo rë. Ja tsi xo toa ë joni quiha mai qui.
\v 28 E tënëhai cató tsi mi oquë jismahuë, noho Jahëpá, jia tsi nohiria bá mia oquëhuano iquish na —nëa tsi Jesu nëcaniquë.
\p Jatsi naipá ca joi chaniniquë:
\p —Noho oquë ë jismaquë. Noho oquë jismatëquëxëquia mi rësoquë no —i naipá ca joi niquë.
\p 
\v 29 Jabi naipá ca joi toá ca nohiria bá nicaniquë. Nicahax,
\p —Tërëjaquë pa —i jaca niquë.
\p Jama,
\p —Ja qui ángel chaniquë pa —i huëtsa bo niquë.
\p 
\v 30 Jatsi Jesu jato qui chaniniquë:
\p —Chaniyamaquë toa joi ë nicati quëshpi na. Jama, mato bax ja chaniquë ra.
\v 31 Jaboqui quësohacaxëti xo chahahuayamacanaibo. Jasca, jaboqui bëbohacaxëti xo maí ca nohiria yonamisxëni ca Satanás.
\v 32 Jabi cruzó tsi namëhacaquí tsi nohiria tëquë ë qui bëxëquia —i Jesu niquë.
\p 
\v 33 Jabi nëca tsi Jesu chaniniquë ja rësohai ca quinia jismaxëna.
\v 34 Jatsi nohiria bá quëbiniquë:
\p —Jaha no pasohai ca Xabahamati Ibo yoati tsi chanihi quiha Quënëhacanish cabo; “Bëso-bësopaoxëhi quiha Cristo” iquiina. Jatsi, ¿jënahuariahax raca “Namëhacaxëti xo Nohiria Baquë” i mi na? ¿Tsohuë ni naa “Nohiria Baquë” i mi aina? ¿Xabahamati Ibo jascaria ni? —i jaca niquë.
\p 
\v 35 Jatsi quiha Jesú quëbiniquë:
\p —Huëa ca ëa xo naa. Mato bëta naamayama-xëquia. Jaboqui tsi xo toa noho chani chahahuati xabaca ra. Jaboqui chahahuacana, jocha tsëmó mato bëbomitsa iqui na. Jabi jahuë quinia cahëyamahi quiha tsëmo ó cohai cato.
\v 36 Huëa ca jayaquí tsi chahahuacana, jahuë xocobo manëxëna —nëa tsi Jesu nëcaniquë.
\p Jaquirëquë jato Jesú jisbayaniquë. Jisbaya tsi ja jonëniquë.
\s1 Jodioba chama bá chahahuayamanina
\p 
\v 37 Jabi huëstima ca jisti bo Jesú aniquë nohiria bo bësojo xo na. Mahitsa quiha. Jisxo tsi quiha jari Jesu ja chahahuacasyamacani quiha.
\v 38 Jasca, jatihuahacati Isaiás quënëni ca ini quiha, naa,
\q1 “Yama tsi xo toa no yoahai ca chani chahahuahai cato, Ibobá.
\q1 Mahitsa jato qui Dios chama jismahacaquë rë”
\m i ja quënëni ca nina.
\p 
\v 39 Jabija, chahahuatimaxëni ja icani quiha rë, Diós jato bëro bëcohuani iqui na. Jabi toca tsi Isaías yamabá quënëni quiha.
\q1 
\v 40 “Diós jato bëcohuani quiha.
\q1 Jato shina ja quëstohuariajahuani quiha, jabija ca ja jisyamacano, jato shinaná tsi ja cahëyamacano.
\q1 Jasca, Dios quiri ja bësoyamacano, jato jocha ja masano iquish na”
\m i ja ni quiha.
\p 
\v 41 Jabi toca tsi Isaías yamabo chaniniquë ra toatiyá tsi Jesu oquë ja jisni iqui na. Jesu yoati tsi ja chanini quiha.
\p 
\v 42 Jama, jari huëstima ca jodiobá Jesu chahuaniquë. Jama, chahahuahax ja pasicaniquë pë, fariseobo, naa jato rëquëniniti ibo bo qui raquëhi na. ¿Jato catiti xobo quima ax ja niahacacasyamacani ma ni?
\v 43 Jishopë. Nohiria bá jato oquëhuahai ca ja noicani quiha. Jato qui iriama Diós acai ca oquë ca ini quiha.
\s1 Jato pasomaha Jesu chaninina
\p 
\v 44 Jatsi joi pistiamá tsi quiha nohiria bo qui Jesu chaniniquë:
\p —Ea chahahuaquí tsi noho Jahëpa ri, naa ëa raanish ca chahahuayoiqui mato ra.
\v 45 Jasca, ëa tsayaquí tsi ëa raanish ca jisqui mato.
\v 46 Jasca, maí ca nohiria Huëa ca ëa xo naa. Mai qui ë joni quiha, tsëmo ó tsi ë qui chitimihai ca chitëyamano iquish na.
\v 47 Jabi noho chani nicacasyamacanaibo qui jaboqui quësoyamaxëquia. Jaboqui nohiria bo xabahamahi ë joniquë, tënëtiya qui jato raahi mari.
\v 48 Jama, jaroha ca barí tsi quiha noho chaní tsi quësohacaxëti xo toa noho chani nicayamacanaibo, ëa biyamacanaibo.
\v 49 Jasca, jaboqui ë chanino tsi ë quima joyamahi quiha ë yoahaina. Noho Jahëpa quima quiha. Noho Jahëpá yoani ca mato qui ë yoaquë ra. Noho chani ma xo.
\v 50 Jasca, nohiria bëso-bësopaomaxëhi quiha noho Jahëpa yoba bo ra. E chanihai ca tsi xo toa ë qui noho Jahëpá yoahana ra —nëa tsi nohiria bo qui Jesu nëcaniquë.
\c 13
\s1 Jesú jahuë rabëti ba tahë ashimanina
\p 
\v 1 Huëaquë tsi chitahëti nori quiha pascua fiesta iniquë. Toatiyá tsi noba mai jisbëriati xaba tsëquëha ca Jesú cahëni quiha. Jahëpa qui bacati xaba ja ini quiha. Jabi jahuë maí ca rabëti bo ja noiriani quiha ra. Jasca, jato ja noiriahai ca jato ja jismani quiha.
\p 
\v 2 Jabi jahuë rabëti bo ya oriquihi Jesu iniquë. Naama tsi quiha Judas Iscariote, naa Simón baquë Yoshiní bini quiha yoi ca shinamaxëna. Ja tsi xo toa jodioba chama bo qui mëatsi quiha Judás huaniquë.
\v 3 Jabi jatiroha ca Jesú cahëni quiha. Ja qui chama Jahëpá anina, Dios quima ja jonina, Dios qui jahari ja cahaina, tihi cabo ja cahëni quiha.
\v 4 Jatsi oriquihax mesa quima Jesu joiniquë. Joixo tsi quiha jahuë sacoria ja tsoboniquë. Tsoboxo tsi quiha toalla ja bihaca tsi ja chinëxëniquë.
\v 5 Jatsi pitëxti, naa lavamanos icanai ca qui jënëpaxa ja japaniquë. Japaxo tsi quiha jahuë rabëti ba tahë chocohatsijahua-niquë. Chocohaxo ja shinahuaniquë.
\p 
\v 6 Jatsi Simón Pedro qui ja joniquë.
\p —¿Noho tahë chocohahi ni mia pa, noho Ibobá? —i ja qui Pedro niquë. \fig Pedro tahë Jesú ashimanina|src="cn01799b.tif" size="span" copy="©1978 David C. Cook Publishing Company" ref="JHN 13.6"\fig*
\p 
\v 7 Jatsi Jesú quëbiniquë:
\p —Jaboqui tsi ë acai ca cahëyoiyamaqui mia. Jama, bari huëtsa cahëxëqui mia tia —iquiina.
\p 
\v 8 Jatsi,
\p —Noho tahë ashimayamapistiariaxëqui mia ra —i Jesu qui Pedro niquë.
\p Jatsi Jesú quëbiniquë:
\p —Mi tahë pi ë ashimayamano tsi ¿jënahuariaxo raca noho yonoco mi ana? —iquiina.
\p 
\v 9 Jatsi,
\p —Noho tahë ashimahuë, Ibobá. Jasca, noho mëquënë, noho mapo, tihi cabo ri ashimahuë ra —i Pedro niquë.
\p 
\v 10 Jatsi nëca tsi quiha Jesú quëbiniquë:
\p —Ashitëquëyamahi quiha bahuëhacanish cato ra. Ashimahacaxëti xo jahuë tahë roha, ja chëquënaquë no. Jascaria, jënima tsi xo masahacanish ca shina jaya cato. Masahacaxëti xo ja abëna ca jocha roha, ja jochaquë no. Bahuëhaca ca xo mato tëquëta. Jama, nëá xo huësti ca shina masahama ca jaya cato rë —i Jesu niquë.
\p 
\v 11 Jodioba chama bo qui ja mëacasni ca Jesú cahëni quiha. Ja tsi xo toa,
\p —Nëá xo huësti ca shina masahama ca jaya cato rë —i ja nina.
\p 
\v 12 Jato tahë ashimaxo tsi quiha jahuë sacoria Jesú sahuëtëquëniquë. Jatsi mesa tahë ja tsahotëquëniquë. Tsahohax,
\p —¿Jënixo tsi mato tahë ë ashimaha? ¿Cahëcanai? —i jato qui Jesu niquë—.
\v 13 Maestro, Ibo, tihi cabo ëa quënaqui mato. Jabija tsi xo toa ma chanihaina, mato Ibo ë nori quëshpi na.
\v 14 Jama, ¿jahuë yonati tahë ashimahi ni chama pa? ¿Tsayacanai? Mato tahë yoi ë chocohaquë ra, naa mato Ibo, mato Maestro ra. Toca tsi ma ati xo mato ri.
\v 15 Mato tahë ë chocohaquë ra, ototi quinia mato jismaxëna. Mato bax ë aca ca jascaria tsi huëtsa bo bax ma ano mato ri.
\v 16 Mato parayamaquia. Yama tsi xo toa jahuë chama oquë ca yonati. Jasca, raanish ca oquë ma xo raahacanish cato, naa jahuë ibo chani bëhai cato.
\v 17 Jabi naa yoba nicaquë mato. E yoaha ca yoba jabipihi tsi raniriaxëqui mato ra.
\p 
\v 18 ‘Mato tëquë yoati tsi chaniyamaquia. E bini cabo cahëriaquia ra. Jama, jatihuahacaxëti xo Quënëhacanish cabo, naa “Mia pasomaha tsi xo toa mi bëta xo pihai cato” iquiina.
\v 19 Nicaparicana. Jodiobo chama bo qui ëa pi ja mëanox pari no tsi mato yoaquia, Xabahamati Ibo ë nori ca ma cahëno iquish na.
\v 20 Mato parayamaquia. Mato raaxëquia, noho chani nohiria bo qui boti. Ea yoi bixëhi quiha mato chani bichi cato. Jasca, ëa raanish ca Jahëpa ri bichi quiha ëa bichi cato —i jato qui Jesu niquë.
\s1 “Jodioba chama bo qui ëa aqui mato ó ca huësti cato” i Jesu nina
\r Mateo 26.20-25; Marcos 14.17-21; Lucas 22.21-23
\p 
\v 21 Chanihax cohuëtsi Jesu niquë.
\p —Mato parayamaquia. Jodioba chama bo qui ëa mëaxëhi quiha mato ó ca huësti cato rë —i ja niquë.
\p 
\v 22 Jatsi bëisnabëquitsi jahuë rabëti bo niquë,
\p —¿Tsohuë cara ni sa? —i jaca niquë.
\p 
\v 23 Jabi Jesu tapaí tsaho Juan ini quiha naa Jesu rabëti-rabëtiria.
\v 24 Jatsi ja qui Simón Pedró jahuë mëquë bëë-bëëhaniquë,
\p —¿Tsohuë yoati ni toa ja chanihaina? Nicahuë, no cahëno ra —iquiina.
\p 
\v 25 Jatsi Jesu qui Juan xëquëniquë nicaxëna,
\p —¿Tsohuë ni toa mia pasomaha cato rë? —iquiina.
\p 
\v 26 Jatsi Jesú quëbiniquë:
\p —Pitëxti qui naa mapari nacomaquia moosaxëna. Nacomaxo tsi toa joni qui axëquia. Jabi ëa pasomaha ca tsi xo toa naa mapari bichi cato ra —i ja niquë.
\p Jatsi quiha mapari Jesú nacomaniquë pitëxti qui. Nacomaxo tsi quiha Judas Iscariote qui ja aniquë.
\v 27 Jatsi mapari ja biquë tsi quiha jahuë shina qui Satanás jicotapiniquë pë.
\p Jatsi,
\p —Mi acatsai ca ahuë. Bamayamahuë —i ja qui Jesu niquë.
\p 
\v 28 Jabi Judas qui Jesú yoaha ca toá ca tsaho cabá cahëyamani quiha nicaxo na.
\v 29 Jahuëcara ca oriquiti copiti, noitiria cabo qui parata ati ma ni, tihi cabo ati ja raahacani ca ja quëscahuajahuacani quiha. Toca tsi ja shinacani quiha, jato parata obëso ca Judas ini iqui na.
\v 30 Jatsi quiha Jesú ja qui ani ca mapari Judás biniquë. Bichi tsi quiha cacha ja caniquë. Baquicha ja ini quiha.
\s1 Yoba paxa cato
\p 
\v 31 Judas jisbayaquë tsi,
\p —Tsëquëquë Nohiria Baquë rësoti xabaca ra —i Jesu niquë—. Jaboqui noho oquë jismahacaxëti xo. E rësohai cató tsi jismahacaxëti xo Dios oquë ri.
\v 32 Jabi ëa iqui tsi Dios oquë jismahacano tsi ë qui jahuë naipá ca oquë axëhi quiha Dios. E qui apaimaria xo ra.
\v 33 Tanaroha pistia no tsi mato bëtaxëquia rë, noho xocobá. Jasca, ë caquë tsi quiha ëa mëraxëqui mato. Jama, ë cahai ca qui canoma xo mato iquia ra, naa jodiobo ë yoahitaha jascaria.
\v 34 Jaboqui yoba paxa ca mato qui aquia: Noinacana iquia, mato ë noihai jascaria.
\v 35 Ma noinapino tsi noho rabëti bo ma nori ca cahëcaxëcani quiha jatiroha cabo —nëa tsi jahuë rabëti bo qui Jesu nëcaniquë.
\s1 “Ea pasomaha chanixëqui mia” i Pedro qui Jesu nina
\r Mateo 26.31-35; Marcos 14.27-31; Lucas 22.31-34
\p 
\v 36 Jatsi,
\p —¿Jahuënia tsi cahai, Ibobá? —i Simón Pedro niquë ja qui.
\p Jatsi,
\p —Jaboqui ë cahai ca qui canoma xo mia. Jama, bari huëtsa ëa banahuaxëqui mia ra —i ja qui Jesu niquë.
\p 
\v 37 Jatsi Pedró quëbiniquë:
\p —Jaboqui tsi mi bëta cacasquia, Ibobá. Mi bax ëmë axëquia nati —iquiina.
\p 
\v 38 Jatsi Jesú quëbiniquë:
\p —¿E bax rësoxëhi ni mia pa? Patiari bënë quëonox pari no tsi tres tsi ëa pasomaha chanixëqui mia rë —i ja qui Jesu niquë.
\c 14
\s1 Jahëpa Dios quinia
\p 
\v 1 Shina-motsiquiyamacana. Dios qui chitimicana. Jasca, ë qui ri chitimicana —i jahuë rabëti bo qui Jesu niquë—.
\v 2-3 Noho Jahëpa racahai cató tsi xo huëstima ca xobo bo ra. Jabi mato xobo bo rohahuahi caquia. Rohahuahax jotëquëxëquia mato bixëna, ë noho ma no. Tocayamarohapino tsi bëro tsi mato ë yoaquë aquë. Quiayamaquia.
\v 4 Jabi ë cahai ca quinia cahëqui mato —nëa tsi Jesu nëcaniquë jahuë rabëti bo qui.
\p 
\v 5 Jatsi Tomás chaniniquë:
\p —¿Jahuënia tsi cahai, Ibobá? Cahëyamaqui noa rë. ¿Jënahuariaxo raca mi cahai ca quinia no cahëna? —i Jesu qui ja niquë.
\p 
\v 6 Jatsi Jesú quëbiniquë:
\p —Dios qui quinia xo ëa ra. Jabija ca xo ëa ra. Bësomati Ibo xo ëa ra. Yama tsi xo Jahëpa Dios qui jamëpistia cahai cato. Jasca, ëa roha tsi xo toa ja qui mëpihai cato.
\v 7 Jasca, ëa cahëpiquí tsi noho Jahëpa ri cahëxëqui mato. Jaboqui Jahëpa yoi cahëyoiqui mato. Jahëpa ma jisquë ra —i ja qui Jesu niquë.
\p 
\v 8 Jatsi Felipe chaniniquë:
\p —Mi Ipa noqui jismahuë, Ibobá. Jispihi tsi ranixëqui noa ra —iquiina.
\p 
\v 9 Jatsi Jesú quëbiniquë:
\p —Mato bëta ë naamaquë, Felipé. ¿Jënahuariaxo jari ëa cahëyamahai rë? Jahëpa Dios yoi jisqui ëa jisish cabo ra. Jënihax, “Jahëpa noqui jismahuë” ¿i mi a pa?
\v 10 ¿Jahëpa Dios ó ë iquiina, ë nohó Jahëpa Dios iquiina, tihi cabo chahahuayamahai, Felipé? E quima joyamahi quiha noho chani, naa mato ë yoahaina. Jahëpa quima quiha. Jabi naa yonoco ati ibo tsi xo Jahëpa ra, naa ë nohó bësohai cato.
\v 11 Jasca, Jahëpa ó ë iquiina, ë nohó Jahëpa iquiina, tihi cabo chahahuana. Noho chani chahahuacasyamaquí tsi ë acai ca jisti bo quëshpi tsi ëa chahahuana.
\v 12 Mato parayamaquia. Ea chahahuapiquí tsi ë acai ca jisti bo axëqui mia ri ra. Naa ë acai ca jisti bo oquë ca axëqui mia, Jahëpa qui ë cahai quëshpi na.
\v 13 Caxo tsi noho janë́ tsi jahuëcara ca ma bënahai ca mato bax axëquia. Toca tsi axëquia ra, ë acai cató tsi Jahëpa oquë jisiquino iquish na.
\v 14 Jahuëcara pi noho janë́ tsi ma bënano tsi mato bax axëquia —nëa tsi Felipe qui Jesu nëcaniquë.
\s1 Espíritu Santo yoati tsi Jesu chaninina
\p 
\v 15 —Ea pi noiquí tsi noho yoba nicaxëqui mato.
\v 16-17 Jasca, noho Jahëpa nicaxëquia, Mëbiti Ibo huëtsa ca mato qui ati. Espíritu Santo quiha, naa mato bëta chitë-chitëpaoxëhai ca tsi xo naa ra. Jabija ca qui mato mëpixëhi quiha. Jabi Espíritu Santo biyamahi quiha Dios cahëyamacanaibo. Jato qui bëroma quiha. Cahëyamacani quiha rë. Jama, mato ti tsi xo toa Espíritu Santo cahëcanaina, mato ó ja nori iqui na.
\p 
\v 18 ‘Yoma bo iyamaxëqui mato. Toca tsi mato jisbëriayamaxëquia. Jahari mato qui joxëquia.
\v 19 Tanaroha pistia no tsi ëa jisyamaxëhi quiha nohiria bo. Jama, ë caquë tsi jari ëa jistëquëxëqui mato. Bëso ë nori quëshpi tsi bësoyoixëqui mato ri.
\v 20 Jasca, toa barí tsi quiha Jahëpa ó ë iquiina, ë nohó ma iquiina, mato ó ë iquiina, tihi cabo cahëxëqui mato ra, ë bësotëquëquë no.
\p 
\v 21 ‘Tsohuëcara ca noho yoba bo nicahai ca tsi xo toa ëa noihaina ra. Jasca, ëa noihai ca noixëhi quiha noho Jahëpa. Toa noixëquia ëa ri. Noixo tsi ja qui ëmë jismaxëquia —nëa tsi jahuë rabëti bo qui Jesu nëcaniquë.
\p 
\v 22 Jatsi quiha Judas huëtsa chaniniquë, naa Judas Iscariote ma cato:
\p —¿Noqui roha mimë yoi jismaxëhi ni mia pa, Ibobá? ¿Jënixo tsi chahahuayamacanaibo qui mimë jismayamaxëhai, mia ja cahëyoicano? —i Jesu qui ja niquë.
\p 
\v 23 Jatsi Jesú quëbiniquë:
\p —Noho chani nicaxëhi quiha ëa noihai cato. Toa noixëhi quiha noho Jahëpa ra. Ja qui joxëqui noa, naa ëa, noho Jahëpa. Johax jahá bësoxëqui noa ra.
\v 24 Jama, noho chani nicayamaxëhi quiha ëa noiyamahai cato rë. Jasca, noho chani ma xo naa ma nicahaina, noho Jahëpa chani nori. Ea raanish cato chani tsi xo naa ma nicahana iquia.
\p 
\v 25 ‘Jabi nëca tsi chaniquia mato bëtahi na.
\v 26 Jama, Espíritu Santo mato qui noho Jahëpá raano tsi mato tiisimaxëhi quiha. Mato Mëbiti Ibo ixëhi quiha. Joxo tsi ëa yoati tsi mato tiisimaxëhi quiha. Mato ë yoaha ca tëquë mato shinamaxëhi quiha ë jisbayaquë no.
\p 
\v 27 ‘Mato bëpasimaquia. Jia tsi xo toa mato ë bëpasimahaina; Dios cahëyamacanaibá bëpasimahai ca jamëri nori quiha. Shina-huëjënayamacana. Jasca, raquëyamacana.
\v 28 ¿Jabi mato ë yoaha ca ma nicayamayamaha? “Mato jisbëriayamaxëquia” i ë quë ra. Jasca, “Mato qui jahari joxëquia” i mato qui ë quë ra. Jatsi ëa pi noihi tsi rani-ranixëqui mato ra, jahari noho Jahëpa qui ë cahai tahëhax na. Ea oquëria xo noho Jahëpa ra.
\v 29 Jaboqui tihi ca tsi mato yoaquia, ja ocanox pari no. Jatsi ocapijaquë tsi ë qui chitimiyoixëqui mato ra.
\v 30 Jabi ichariama bari tsi xo toa mato bëta ë chanihaina rë. Capaima xo ëa ra. Jasca, johi quiha Satanás rë, naa chahahuayamacanaibo yonati ibo-iboria. E axëhai ca yonoco quëtiayamaxëhi quiha ra. Ea yonati mëtsama xo ra.
\v 31 Jama, Jahëpa Dios ë noihai ca nohiria bá cahëno. Noiquí tsi jatiroha ca noho Jahëpá yoahai ca aquia ra. Iquë tia. Bëcahuë. ¿Canomani? —nëa tsi Jesu nëcaniquë jahuë rabëti bo qui.
\c 15
\s1 Bimi nishi, jahuë mëshi bo
\p 
\v 1 —Bimi saihuahai ca nishi jascaria ca ëa xo naa —i Jesu niquë—. Bimi nishi ototi ibo tsi xo noho Jahëpa ra.
\v 2 E nohó ca mëshí pi bimi saihuayamano tsi toa mëshi mëris-hi quiha noho Jahëpa. Jasca, saihuahai ca mëshi bo rohahuahi quiha, oquë tsi ja saihuacano iquish na.
\v 3 Jabi mato ë yoani ca chaní tsi ma bahuëhacaniquë, naa mëshi rohahuahacahai jascaria.
\v 4 E nohó bësocana, naa mato ó ë bësohai jascaria. Jabi nishi quima mëris-hacapiquí tsi ¿jënahuariaxo raca toa mëshí saihuana? Jascaria, ë nohó bësoyamapiquí tsi saihuati mëtsama ixëqui mato ri.
\p 
\v 5 ‘Nishi xo ëa ra. Mato tsi xo mëshi bo. Jabi huëstima ca bimi saihuahi quiha ë nohó bësohai cato. Dios yonoco ariaxëhi quiha, jaha ë bësohai iqui na. Yama ca axëqui mato ë bëtaxoma.
\v 6 Jabi niahacaxëti xo tsohuëcara ë nohó bësoyamahai cato, naa niahacanish ca mëshi yoi ca jascaria. Bëso-bësopaoyamaxëhi quiha toa rë. Jabi nëca ca mëshi yoi bo catiahi quiha bimi ibo. Catiaxo tsi chihi qui niahi quiha. Toá tsi mëshocaxëcani quiha.
\v 7 Jama, ë nohó pi ma bësono tsi, mato ó pi noho chani chitëno tsi jaha ma quëëhai ca baati mëtsa ixëqui mato. Baaxo tsi bixëqui mato ra.
\v 8 Jabi huëstima ca bimi saihuahi quiha noho rabëti yoi bo ra. Toca tsi Dios jabi jia ca jismacani quiha ra. Jasca, toca tsi noho rabëti bo ma nori ca cahëxëhi quiha nohiria bo.
\v 9 Mato noiquia ra, naa ëa noho Jahëpá noihai jascaria. E noihai cato ó tsi chitëcana.
\v 10 Noho yoba pi aqui tsi ë nohai cato ó tsi chitëxëqui mato. Jabi noho Jahëpa yoba bo aquia. Jaha tsi ja noihai cato ó tsi chitëxëquia ra.
\p 
\v 11 ‘Nëcaquia ë ranihai ca ma oquëxnano. Ma rani-raniriano ra.
\v 12 Noho yoba tsi xo naa: Noinabëquicana, mato ë noihai jascaria.
\v 13 Tsohuëcara pi jahuë rabëti bax rësono tsi anomaria tsi xo toa ja noihaina. Yama tsi xo toa oquë ca noihaina.
\v 14 Jasca, noho rabëti bo xo mato, noho yoba ahi na.
\v 15 Jaboqui yonati bo mato quënayamaquia. Jahuë chamá shinahai ca cahëyoiyamacani quiha toa bo rë. Jama, noho rabëti bo mato quënaquia ra. Ja tsi xo toa noho Jahëpa quima ë nicaha ca tëquë mato yoaquia ra.
\v 16 Ea ma biyamaniquë. Jama, mato ë biniquë. Bixo tsi mato raaquia, huëstima ca huinocayamahai ca bimi saihuahi ma bocano. Jasca, noho janë́ tsi ma baaha ca jahuëcara ca mato qui axëhi quiha noho Jahëpa.
\v 17 Jabi noho yoba tsi xo naa: Noinabëquicana. Iquë.
\s1 Noqui caxahi quiha maí ca nohiria bo
\p 
\v 18 ‘Ratëyamacana. Mato qui pi Dios cahëyamacanaibo caxano tsi ë qui pari ja caxacani quiha.
\v 19 Jabi jato maí ca jabi yoi ca pi ma noino tsi mato noicaxëcani quiha Dios cahëyamacanaibo, jató-na ja noicanai jascaria. Jama, maí ca nohiria bo quima mato ë tsëcaniquë ra. Jató-na ma xo mato. Ja tsi xo toa mato qui caxahi quiha maí ca nohiria bo.
\v 20 Jabi ë yoaha ca shina-bënoyamacana: “Jahuë ibo oquë ma xo yonati” i ë quë ra. Jabi ëa tënëmacaxëcani quiha maí ca nohiria bo. Jasca, mato ri tënëmacaxëcani quiha, noho rabëti bo ma nori iqui na. Jasca, noho chani nicarohapixo tsi mato chani ri ja nicaquë acaquë ra.
\v 21 Jasca, ëa raanish ca cahëyamahi quiha maí ca nohiria bo rë. Jaha tsi ëa iqui tsi mato tënëmacaxëcani quiha rë.
\v 22 Jato qui pi chanihi ë joyamarohano tsi ja quësoyamahacaquë acaquë. Jama, jaboqui jocha jayaca xo rë. “Noho shina ri ma xo” iti mëtsama ca xo ra, noho chani ja nicacana quëshpi na.
\v 23 Noho Jahëpa qui caxahi quiha tsohuëcara ca ë qui caxahai cato rë.
\v 24 Jasca, jato xërëquë xo pi jistiria bo ë ayamarohano tsi ja quësoyamahacaquë acaquë. Jama, ë ani ca jistiria bo ja jiscani quiha. Jisi tsi ëa, noho Jahëpa, tihi cabo qui jari caxacani quiha pë.
\v 25 Jabi jatihuahacati xo Quënëhacanish cabo ra, ja acanai cató no, naa,
\q1 “Mahitsa ë qui caxacaxëcani quiha rë” iquiina.
\p 
\v 26 ‘Joxëhi quiha Espíritu Santo, naa mato Mëbiti Ibo ra. Noho Jahëpa ax joxëhi quiha. Jabija ca yoahai ca tsi xo naa. Jabi mato qui Espíritu Santo raaxëquia. Joxo tsi jatiroha ca ëa yoati mato yoaxëhi quiha.
\v 27 Jascaria, ëa yoati chanixëqui mato ri, rëquë rohari tsi ë bëta ma ini quëshpi na.
\c 16
\s1 Tënëxëhi quiha Jesu rabëti bo
\p 
\v 1 ‘Jabi mato qui caxacaxëcani quiha maí ca nohiria bo. Toa mato yoaquia, jabija ca quima ma casoyamano iquish na.
\v 2 Jato catiti xobo quima mato niacaxëcani quiha rë. Toa xaba tsëquëno tsi mato acaxëcani quiha ra. Axo tsi Dios yonoco ja acanai ca quëscahuacaxëcani quiha rë.
\v 3 Jasca, ëa, Jahëpa, tihi cabo cahëyamacani quiha rë. Ja tsi xo toa mato acaxëcani quiha pë.
\v 4 Jaboqui mato yobaquia, noho chani ma shinaparino toa xaba tsëquëquë no.
\s1 Espíritu Santo yonoco
\p ‘Jariapari tsi ë caxëhai ca ë yoayamaniquë, jari mato bëta ë ini quëshpi na.
\v 5 Jama, jaboqui ëa raanish ca qui capaima xo ëa. Jama, “¿Jahuënia tsi cahai?” iyamaqui mato rë.
\v 6 Jabija ca mato ë yoaha iqui tsi cohuëria xo mato.
\v 7 Jasca, mato qui jia tsi xo ë caxëhaina iquia. E cayamapino tsi mato qui joyamaxëhi quiha Espíritu Santo, naa mato Mëbiti Ibo. Jama, mato qui Espíritu Santo raaxëquia nai qui caquí na.
\v 8 Jato jocha nohiria bo qui bërohuaxëhi quiha joxo na. Jasca, noho mëstë ca jabi, Diós nohiria bo copixëhaina, tihi cabo tsi bërohuaxëhi quiha.
\v 9 Jasca, jato jocha bërohuaxëhi quiha Espíritu Santo, ë qui ja chitimiyamacanai quëshpi na.
\v 10 Jasca, noho mëstë ca jabi bërohuaxëhi quiha, Jahëpa Dios qui ë caxëhai iqui na. Jabi mëstë ca ë nori iqui tsi Jahëpa qui cati mëtsa xo ëa. Jasca, ë caquë tsi ëa jisyamaxëqui mato.
\v 11 Jasca, Diós nohiria bo copixëhai ca bërohuaxëhi quiha Espíritu Santo, Satanás, naa maí ca nohiria yonati ibo copihacani quëshpi na.
\p 
\v 12 ‘Jari huëstima ca tsi xo toa mato qui ë yoacatsaina. Jaboqui cahënoma xo mato rë. Jaha tsi yoayamaquia.
\v 13 Jama, joxëhi quiha Espíritu Santo. Joxo tsi jatiroha ca jahuë bo tiisimaxëhi quiha. Jabija ca yoahai ca tsi xo naa. Quiayamahi quiha. Jahuë chamá tsi chaniyamaxëhi quiha. Jama, chaniquí tsi ja nicahai ca jahuë bo roha mato qui yoaxëhi quiha.
\v 14 Jasca, ëa oquëhuaxëhi quiha. Oquëhuaxo tsi ë noho ca chani bixëhi quiha. Bixo tsi mato cahëmaxëhi quiha ra.
\v 15 Jabi noho Jahëpa oquë, jahuë chani, tihi cabo tëquë jaya xo ëa ra. Ja tsi xo toa “Ja qui ë acai ca jahuë bo bixëhi quiha Espíritu Santo. Bixo tsi mato cahëmaxëhi quiha ra” i ë quë.
\s1 Ja rësohai yoati tsi Jesu chaninina
\p 
\v 16 ‘Tanaroha pistia no tsi ëa jisyamaxëqui mato. Jaquirëquë, ichariama bari huinocaquë tsi ëa jistëquëxëqui mato —nëa tsi jahuë rabëti bo qui Jesu nëcaniquë.
\p 
\v 17 Jatsi quiha chaninabëquitsi jahuë rabëti bo niquë:
\p —¿Jënijaha sa? “Tanaroha pistia no tsi ëa jisyamaxëqui mato; jaquirëquë, ichariama ca bari tsi ëa jistëquëxëqui mato” i ja quë pa. Jasca, “Noho Jahëpa qui caquia” i ja quë pa.
\v 18 ¿Jahuëcara chanihi ni naa sa, “Tanaroha pistia no” i ja quë no? Ja chanihai ca cahëyamaqui noa rë —nëa tsi quiha jahuë rabëti bo nëcaniquë.
\p 
\v 19 Jabi jahuë rabëti bá nicacascani ca Jesú cahëniquë. Ja quëshpi tsi jato qui ja chanitëquëniquë:
\p —“Tanaroha pistia no tsi ëa jisyamaxëqui mato. Jaquirëquë, ichariama ca bari tsi ëa jistëquëxëqui mato” i ë quë. ¿Jabija ma ni naa ma nicacatsaina?
\v 20 Mato parayamaquia. E caquë tsi araxëqui mato. Jama, ranixëhi quiha maí ca nohiria. Cohuënaxëqui mato. Jama, ranixëqui mato, ëa ma jistëquëquë no.
\v 21 Jabi pahë ya xo yoxa, jahuë baquë coquë no. Jama, jahuë baquë coquë tsi jahuë comahai ca pahë shina-bënohi quiha. Ranihi quiha, jahuë baquë coha quëshpi na.
\v 22 Jascaria tsi jaboqui cohuë xo mato ri. Jama, ranixëqui mato, mato ë jistëquëquë no. Mato quima mëbitimaxëni ixëhi quiha ma ranixëhaina ra.
\p 
\v 23 ‘Toatiyá tsi ëa nicayamaxëqui mato, jahuëcara bixëna. Jama, Jahëpa Dios nicaxëqui mato ra. Jahuëcara ma nicahai ca mato qui axëhi quiha, noho rabëti bo ma nori quëshpi na.
\v 24 Jaboqui jari noho janë́ tsi nicayamahi quiha mato, bëhoxquí na. Jama, toatiyá tsi noho janë́ tsi nicatsacana. Nicaxo tsi bixëqui mato. Toca tsi raniriaxëqui mato ra —nëa tsi Jesu nëcaniquë.
\s1 Maí ca jabi bëbohi quiha Jesu
\p 
\v 25 —Jaboqui mato joma quiha mato ë yoahaina rë. Jama, joxëhi quiha xaba huëtsa. Toatiyá tsi bëroria tsi Jahëpa Dios yoati tsi chanixëquia —i jahuë rabëti bo qui Jesu niquë—.
\v 26 Toatiyá tsi noho janë́ tsi Jahëpa Dios nicaxëqui mato. Noho janë́ tsi ma bëhoxno tsi mato bax nicayamaxëquia, noho Jahëpá mato nicaxëhai quëshpi na.
\v 27 Mato noiriahi quiha Jahëpa Dios yoi, ëa ma noihai iqui na. Jasca, Dios quima ax ë joni ca chahahuaqui mato. Ja quëshpi tsi mato noiriahi quiha Jahëpa.
\v 28 Jahëpa Dios ë jisbërianiquë mai qui joxëna. Jaboqui naa mai jisbëriaquia jahari noho Jahëpa Dios qui caxëna —nëa tsi Jesu nëcaniquë jahuë rabëti bo qui.
\p 
\v 29 Jatsi jahuë rabëti bá quëbiniquë:
\p —Jaboqui bëro xo mi chanihaina. Jonë ma xo ra.
\v 30 Jaboqui jatiroha ca cahëhai ca mi nori ca cahëqui noa. Mia pi no nicacasno tsi no shinahai ca cahëqui mia pa. Ja tsi xo toa Dios quima ax mi joni ca cahëqui noa ra —i Jesu qui jaca niquë.
\p 
\v 31 Jatsi quiha Jesú quëbiniquë:
\p —¿Jaboqui chahahuacanai pa?
\v 32 Jabi basima tsi xo toa hora ra, naa ma pacanamahaca-xëquë no. Jabi joquë toa hora. Toatiyá tsi mato xobo qui jabaxëqui mato pë. Ea jisbëriaxëqui mato rë. Jama, ëmëpistia iyamaxëquia ë bëta Jahëpa nori quëshpi na.
\v 33 Nëca tsi mato qui chaniquia ma bëpasino, ma raquëyamano iquish na. Nicacana. Mato yosicaxëcani quiha maí ca nohiria. Jama, ranitsicana maí ca yoi ca jahuë bo, maí ca nohiria bo, tihi cabo ë boboni quëshpi na —nëa tsi quiha jahuë rabëti bo qui Jesu nëcaniquë.
\c 17
\s1 Jahuë rabëti bo bax Jesu bëhoxnina
\p 
\v 1 Jatsi quiha nai Jesú tsayaniquë bëhoxhi na. Tsayahax,
\p —Tsëquëquë ë rësoti xabaca rë, Jahëpá —i Jahëpa Dios qui ja niquë—. Mi Baquë xo ëa ra. Noho oquë jismahuë, mi oquë ë jismano ëa ri.
\v 2 Jasca, ë qui nohiria yonati chama mi aniquë, ë qui mi ani ca nohiria bo tëquë ë bëso-bësopaomano iquish na.
\v 3 Jabi bëso-bësopaoti quinia tsi xo naa ra: Mia, ëa, tihi cabo ja cahëyoiti ca xo ra. Mia tsi xo toa jaroha ca Dios yoi. Jasca, ëa ti tsi xo toa mi raani ca baquë yoi.
\v 4 Jabi naa mai xo tsi mi oquë ë jismaquë ra. Jasca, ë qui mi ani ca yonoco ë jatihuaquë ra. Jaboqui yama tsi xo.
\v 5 Jatsi jaboqui noho oquë mi jismati xo, Jahëpá, naa mi bëta ë jayapaoni ca oquë. Jabi mai mi nëhohuanox pari no tsi anomaria ini quiha noho oquë ra.
\p 
\v 6 ‘Jasca, ë qui mi ani ca maí ca nohiria bo qui tsohuë mi nori ca ë jismaquë ra. Jabi jato qui mi oquë ë jismaquë. Jariapari tsi mi-na bo ja icapaoniquë. Jatsi ë qui jato mi aniquë jato ó bësoti. Jaboqui mi chani nicacani quiha ra.
\v 7 Jasca, jaboqui ëa yoi cahëriacani quiha. Noho chani, noho tiisi, noho chama, tihi cabo ë qui mi ani ca cahëcani quiha.
\v 8 E qui mi ani ca chani jato qui ë aniquë. Mi chani ja bicaniquë ra. Bixo tsi mi quima ax ë joni ca cahëriacani quiha ra. Ea mi raani ca chahahuayoicani quiha iquia.
\p 
\v 9 ‘Jasca, noho rabëti bo bax bëhoxquia. Chahahuayamacanaibo bax bëhoxyamaquia. Jama, ë qui mi ani cabo bax bëhoxquia mi-na bo jaca nori quëshpi na.
\v 10 Jabi jatiroha ca nohó-na bo xo mi-na bo ri. Jasca, jatiroha ca mi-na bo xo nohó-na bo ri. Jaboqui ja acanai cató tsi jismahacahi quiha noho oquë.
\v 11 Ea ti tsi xo jisbayahaina. Jama, nëá tsi chitëcahi quiha nohó-na bo. Jisbaya tsi mi qui caquia. Ja quëshpi tsi jia tsi ë qui mi ani cabo ó bësohuë, noho Jahëpa jiaxëni cató. Tocahuë, huësti ca ja icano, huësti ca no nori jascaria.
\v 12 Jato bëtapama tsi jato ë oto-otoniquë, ë qui mi ani ca chamá no. Jënima ca xo. Huësti roha tsi xo toa bënohacahax cato, naa tënëtiyá ca baquë rë. Tocapijaquë, Quënëhacanish cabo jatihuahacano iquish na. Iquë.
\v 13 Jaboqui mi qui caquia. Jato bëtapama tsi naa jahuë bo jato ë yoaniquë, ë ranihai ca ja xatënacano iquish na.
\v 14 Jasca, mi chani jato qui ë aquë. Ja iqui tsi jato qui caxahi quiha maí ca nohiria bo, jato maí ca jabi yoi bo ja niacani iqui na. Maí ca nohiria bo quirima ca xo, ëa jascaria jaca nori.
\v 15 Mai quima jato tsëcahuë iyamatsiquia. Jama, jato ó bësohuë, Satanás jato yoshihuayamano.
\v 16 Jaboqui maí ca nohiria ma ca xo. Jató-na ma ca xo, ëa jascaria jaca nori.
\v 17 Jasca, jabija ca Espíritu Santó tsi jato aquëquëmahuë, mi yonoco ati. Jabija tsi xo mi chani ra.
\v 18 Jabi maí ca nohiria bo qui ëa mi raani jascaria tsi maí ca nohiria bo qui jato ë raaquë ëa ri.
\v 19 Jato bax ëmë mi qui aquia namëhacati, Espíritu Santó tsi ja aquëquëmahacacano iquish na.
\p 
\v 20 ‘Jabi noho rabëti bo, jato chani iqui tsi ë qui chitimicaxëcanaibo, tihi cabo bax bëhoxquia ra.
\v 21 Bëhoxquia ja huëstinabëquicano. No nohó ja huëstinabëquicano, Jahëpá, naa ë nohó mi nori jascaria. Ja huëstinabëquicano ra, maí ca nohiria bá ëa mi raani ca chahahuano iquish na.
\v 22 Jabi ë qui mi ani ca oquë jato qui ë aniquë, ja huëstinabëquicano iquish na, naa huësti ca no nori jascaria.
\v 23 Jabi jato ó xo ëa. Jasca, ë nohó xo mia ri. Ja iqui tsi ja huëstina-bëquinayoicano ra. Tocapijacano tsi ëa mi raanina, jato ë noi-noihaina, tihi cabo cahëcaxëcani quiha maí ca nohiria bo.
\p 
\v 24 ‘Jabi ëa mi noiniquë mai nëhohuahacanox pari no. Toatiyá tsi oquë ë qui mi aniquë. Toa oquë ja jiscano ra. Ja tsi xo toa ë nori cató tsi noho rabëti bo icano jato ri, noho oquë ja jiscano.
\v 25 Jishopë, mëstëxëni ca Jahëpá. Mia cahëyamahi quiha maí ca nohiria bo rë. Jama, mia cahëhai ca ëa xo naa. Jasca, ëa mi raani ca cahëhi quiha noho rabëti bo ri.
\v 26 Mi jabi yoi jato ë cahëmaniquë. Jasca, jari mi jabi yoi jato cahëmaxëquia, noiti ja tiisicano, ëa mi noihai jascaria. Jabi jato shina ó tsi bësoxëquia —nëa tsi Jesu nëcaniquë bëhoxhi na.
\c 18
\s1 Jesu tsamihacanina
\r Mateo 26.47-56; Marcos 14.43-50; Lucas 22.47-53
\p 
\v 1 Bëhoxhax tsi quiha pao Cedrón Jesú shitaniquë. Jahuë rabëti bo ri ja boni quiha. Shitahax huerto qui ja jicocaniquë.
\v 2 Jabi toa iti Judás cahëni quiha jaa ri, naa Jesu pasomaha inish cato. Huëstima tsi toa huerto qui Jesu ca-capaoni quiha jahuë rabëti bo ya.
\v 3 Jaha tsi quiha huerto qui Judás caniquë jaa ri, Jesu mërahi na. Huëstima ca soldado bo, jodioba chama bá raani ca policía bo, tihi cabo ja boniquë. Jotati bo, lamparina bo, saipi bo, tihi cabo ja jayacani quiha.
\v 4 Huerto qui ja cahëcaquë tsi quiha jato bëchahi Jesu caniquë, ja acascanai ca ja cahëni quëshpi na. Bëchahax,
\p —¿Tsohuë mëracanai? —i jato qui Jesu niquë.
\p 
\v 5 Jatsi,
\p —Nazarét ca Jesu mëraqui noa ra —i jaca niquë.
\p Jatsi quiha,
\p —Ja xo ëa ra —i Jesu niquë.
\p Jabi toá tsi quiha soldado bo ya Judas nii iniquë, naa Jesu pasomaha inish cato.
\v 6 “Ja xo ëa ra” i Jesu quë tsi quiha ja chishtëquiri-caniquë. Mai qui ja paquëcaniquë ratëhi na.
\v 7 Jatsi quiha Jesú jato nicatëquëniquë:
\p —¿Tsohuë mëracanai ra? —iquiina.
\p Jatsi quiha,
\p —Nazarét ca Jesu ra —itëquë jaca niquë.
\p 
\v 8 Jatsi Jesú quëbiniquë:
\p —“Ja xo ëa ra” i ë quë. Ea pi ma mërano tsi noho rabëti bo ma paquëmano iquia —iquiina.
\p 
\v 9 Jabi toca tsi ja yoaha ca Jesú jatihuani quiha naa “E qui mi ani cabo bënoyamaxëquia” i ja quë no.
\v 10 Jatsi quiha Simón Pedró jahuë saipi tsëcaniquë. Tsëcaxo tsi quiha Malco, naa arati ibo-iboria yonati ja paxtianiquë. Jahuë mënëcayá ca pahoqui quiha.
\v 11 Paxtia-jahuaquë tsi quiha,
\p —Mi huaina qui jahari mi saipi nanëhuë. ¿E qui noho Jahëpá ani ca yonoco ayamayamaxëhi ni ëa ra? Aquia ra —i Pedro qui Jesu niquë.
\s1 Jodioba chama bo bësojó Jesu niinina
\p 
\v 12 Jatsi pë soldado bo, jato capitán, jodiobá policía bo, tihi cabo Jesu qui tsaminiquë. Tsamixo tsi quiha ja nëxacaniquë pë.
\v 13 Nëxaxo tsi Anás xobo qui pari Jesu ja bocaniquë. Caifás raisi ja ini quiha. Jabi toa año no tsi arati ibo ba chama Caifás ini quiha.
\v 14 Jabi jodiobo yobanish ca Anás tsi xo naa, “Oquë tsi xo nohiria bo bax huësti ca joni rësohaina” inish cato.
\s1 Pedró Jesu ocahuanina
\r Mateo 26.69-70; Marcos 14.66-68; Lucas 22.55-57
\p 
\v 15 Jabi Jesu cho Pedro caniquë. Ja cho ë caniquë ëa ri, naa Jesu rabëti huëtsa. Jabi ëa Anás cahëni quiha, naa arati ibo-iboria iqui cato. Ja quëshpi tsi Jesu ya arati ibo-iboria xobo huënënë́ ca mai qui jicoti mëtsa ë iniquë.
\v 16 Jiconoma Pedro ini quiha. Caiti cacha nii quiha. Jatsi cacha ë caniquë, caiti obëso ca xotaco qui chanixëna, huënë qui Pedro jicomacatsi na. Jatsi Pedro ë jicomaniquë ra.
\v 17 Jatsi ë bëta jicojano tsi
\p —Tonia Jesu rabëti xo mia ra —i caití quëmëpi ca xotaco niquë Pedro qui.
\p Jatsi quiha,
\p —Jahuë rabëti ma xo ëa ra —i Pedro niquë rë.
\p 
\v 18 Jabi matsi iqui tsi toá ca policía bo, yonati bo, tihi cabá chihi maponiquë. Mapohax toá tsi quiha ja yohocaniquë. Jato bëta niiniquë Pedro ri, yohohi na.
\s1 Anás Jesu nicanina
\r Mateo 26.59-66; Marcos 14.55-64; Lucas 22.66-71
\p 
\v 19 Jatsi quiha jahuë rabëti bo, ja tiisimahaina, tihi cabo yoati tsi arati ibo ba chamá Jesu nicaniquë.
\v 20 Jatsi Jesú quëbiniquë:
\p —Bëroria tsi nohiria bo qui ë chaniniquë ra. Mato catiti xobo bo, arati xobo, tihi cabo xo tsi ë tiisimapaoniquë, naa jodiobo tëquë catihai cato xo na. Jonë tsi ë chaniyamaniquë ra.
\v 21 Ja quëshpi tsi, ¿jëniriaxo tsi ëa nicahai? Noho chani nicanish cabo nicahuë ra. E yoani ca cahëcani quiha ra —i jato chama qui Jesu niquë.
\p 
\v 22 Jatsi pë toá ca nii ca soldadó Jesu bëpaishaniquë pë.
\p —¿Toca tsi arati ibo ba chama quëbihi ni mia pa? —i ja qui soldado niquë.
\p 
\v 23 Jatsi quiha Jesú quëbiniquë:
\p —Anoma ca pi ë chanirohano tsi ëa nicamahuë. ¿Jëniriaxo tsi ëa mi bëpaishaha pa, jabija ca ë chaniquë no? —iquiina.
\p 
\v 24 Jatsi arati ibo-iboria Caifás qui Anás Jesu raaniquë. Jari nëxë Jesu ini quiha.
\s1 Pedró Jesu ocahuatëquënina
\r Mateo 26.71-75; Marcos 14.69-72; Lucas 22.58-62
\p 
\v 25 Jabi chihi tahë tsi quiha jari nii quiha Pedro iniquë, yohohi na. Yohojano tsi quiha ja qui chanitsi toá ca joni bo niquë:
\p —¿Jesu rabëti ma ni mia ra? —i ja qui jaca niquë.
\p Jatsi quiha,
\p —Jahuë rabëti ma xo ëa ra —i Pedro niquë rë.
\p 
\v 26 Jatsi quiha Pedro qui ibo-iboria yonati chaniniquë, naa paxtiahacanish cato jimibo:
\p —¿Huerto xo tsi Jesu ya mia ë jisyama-yamaha? —iquiina.
\p 
\v 27 Jatsi quiha,
\p —Ea ma xo ra —i Pedro niquë rë.
\p Ja quiaquë tsi quiha patiari bënë quëotapiniquë.
\s1 Pilato bësojó Jesu niinina
\r Mateo 27.1-2, 11-14; Marcos 15.1-5; Lucas 23.1-5
\p 
\v 28 Jaquirëquë Caifás xobo jisbaya tsi quiha romanoba chama xoboria qui Jesu ja bocaniquë. Baquishmari ja ini quiha. Jahuë xoboria qui cahëhax tsi quiha ja jicoyama-caniquë. Carayanaba xobo qui jicohai jodiobo qui yoi ini quiha, jato jabi pasomaha ja ini quëshpi na. Jato qui roa quiha. Jicorohapihi tsi jato pascua fiesta oriquiti mëtsama ja iquë acani quiha.
\v 29 Jatsi quiha cacha Pilato caniquë jato qui.
\p —¿Jahuë naa joni qui quësocanai? —i jato qui ja niquë.
\p 
\v 30 Jatsi quiha,
\p —Anoma ca pi ja ayamarohano tsi mi qui no bëyamaquë aquë ra —i jaca niquë.
\p 
\v 31 Jatsi quiha Pilató jato quëbiniquë:
\p —Bicahuë. Mato yobá tsi copihuë —iquiina.
\p Jatsi quiha,
\p —Naa joni namëcasqui noa ra. Romanoba yoba pasomaha tsi xo toa joni no namëhaina rë —i jaca niquë.
\p 
\v 32 Nëca tsi Jesú yoani ca jatihuahacani quiha, naa ja rësohai ca quinia yoati ja yoaniquë no.
\v 33 Jatsi jahuë xoboria qui jahari Pilato cahaca tsi Jesu ja bënaniquë. Bënahax,
\p —¿Jodioba chama-chamaria ni mia? —i Jesu qui ja niquë.
\p 
\v 34 Jatsi quiha Jesú quëbiniquë:
\p —¿Mi quima johi ni mi nicahana? ¿Tonia ëa yoati huëtsa bá mia yoayamayamaha? —iquiina.
\p 
\v 35 Jatsi,
\p —¿Jodio ë nori ca shinahai? Mi jimibo, jato arati ibo bo, tihi cabo tsi xo toa ë qui mia mëahax cabo ra. Jatsi, ¿jahuë anoma ca mi aca sa? —nëa tsi Jesu qui Pilato nëcaniquë.
\p 
\v 36 Jatsi quiha Jesú quëbiniquë:
\p —Maí ca nohiria chama ma xo ëa ra. Nëa xo tsi yonayamaquia. Jasca, nëa xo tsi ë yonarohapino tsi noho yonati bo nianaquë aquë, jodioba chama bo qui ë mëahacayamano. Mai xoma xo ë yonahaina ra —nëa tsi Jesu nëcaniquë.
\p 
\v 37 Jatsi quiha,
\p —¿Chama ni mia pa? —i Pilato niquë.
\p —Jabija. Chama xo ëa ra. Ja tsi xo toa ë conina. Mai qui ë joniquë jabija ca yoaxëna. Jabi noho rabëti bo tsi xo toa jabija ca nicacanaibo tëquë —i Pilato qui Jesu niquë.
\p 
\v 38 Jatsi quiha,
\p —¿Jahuë ni toa jabija ca sa? —i Pilato niquë.
\p Chanihax cacha jodiobo qui Pilato catëquëniquë. Cahax,
\p —Yama tsi xo naa joní anoma ca acana iquia —i jato qui ja niquë—.
\v 39 Mato pascua fiesta no tsi presó ca achiquinish ca huësti ca ë paquëmapaoniquë. Noba jabi quiha. ¿Japa jaboqui mato jodiobo chama-chamaria mato bax paquëmaxëhi ni ëa? —i jodiobo qui Pilato niquë, Jesu paquëmacatsi na.
\p 
\v 40 Jatsi quiha jato joi jodiobá choshaniquë. Jato qui yoi ini quiha ja yoanina. Jaha tsi,
\p —Naa joni paquëmayamahuë ra. Barrabás paquëmahuë ra —i jaca niquë pë.
\p Jabi yomaxëni ca joni naa Barrabás ini quiha.
\c 19
\s1 Jesu ja namëcanina
\r Mateo 27.15-31; Marcos 15.6-20; Lucas 23.13-25
\p 
\v 1 Jatsi Pilató Jesu biniquë. Bixo tsi quiha ja rashamaniquë rispichí no.
\v 2 Jaquirëquë moxa chaha soldado bá quëconiquë. Quëcoxo tsi quiha ja machëquërëxacaniquë pë. Jatsi quiha raiti shini ja sahuëmacaniquë; naa chama-chamaria sahuëti.
\v 3 Sahuëmahax ja qui soldado bo bocaniquë joihuaxëna.
\p —¡Viva! ¡Viva, jodioba chama-chamariá! —i jaca niquë pë.
\p Joihuaxo tsi quiha ja bëpaishacaniquë pë.
\p 
\v 4 Jaquirëquë cacha Pilato catëquëniquë jodiobo qui.
\p —Cacha mato qui Jesu boquia. Yama tsi xo toa anoma ca ja acana iquia. Ja bësoxëti xo ra —i jato qui ja niquë.
\p 
\v 5 Jatsi xobo cacha Jesu caniquë. Moxa chaha, raiti shini, tihi cabo sahuë ja ini quiha. Jatsi,
\p —Nëá xo mato joni ra —i jato qui Pilato niquë.
\p 
\v 6 Jatsi quiha arati ibo bo, jato yonati bo, tihi cabá Jesu jisniquë. Jisi tsi,
\p —Cruzó tsi tooxahuë. Cruzó tsi tooxahuë —i jaca niquë pë.
\p Jatsi quiha,
\p —Bocahuë. Acasyamaxo ëa ra. Mamëxo tsi cruzó tsi tooxacahuë pë. Yama tsi xo anoma ca ja acana iquia ra —i jato qui Pilato niquë.
\p 
\v 7 Jatsi jodiobá quëbiniquë:
\p —“Ja namëhacati xo” ii quiha noba yoba ra, “Dios Baquë xo ëa” i ja ni quëshpi na —i jaca niquë. \fig “Nëá xo mato chama ra” i Pilato nina|src="cn01828b.tif" size="span" copy="©1978 David C. Cook Publishing Company" ref="JHN 19.7"\fig*
\p 
\v 8 Nicahax raquëriatsi Pilato niquë.
\v 9 Raquëhi tsi jahuë xoboria qui ja jicotëquëniquë Jesu qui chanitëquëhi na.
\p —¿Jahuënia ax mi joni? —i ja qui Pilato niquë.
\p Quëbiyamaniquë Jesu; pasi quiha.
\p 
\v 10 —¿Ea quëbiyamahai pa? ¿Noho chama cahëyamahai? Mia paquëmati chama, mia cruzó tsi tooxamati chama, tihi cabo jaya xo ëa ra —i Jesu qui ja niquë.
\p 
\v 11 Jatsi Jesú quëbiniquë:
\p —Mana quima mi qui chama ayamahacarohapino tsi ëa namëti chama mi jayamaquë aquë ra. Jaha tsi mi jocha oquë tsi xo toa mi qui ëa mëahax cato jocha ra —nëa tsi quiha Pilato qui Jesu nëcaniquë.
\p 
\v 12 Jatsi quiha Pilató Jesu paquëmacasniquë nicaxo na. Jama, jahari jodiobá quënaniquë:
\p —Paquëmapihi tsi romanoba chama-chamaria rabëti ma xo mia pë. Romanoba chama pasomaha tsi xo toa “Chama-chamaria xo ëa” iquii cato. Tocahi quiha naa Jesu ra —i jaca niquë.
\p 
\v 13 Jesu qui ja quësocanai ca nicaxo tsi quiha Pilató Jesu boniquë, cacha xo copixëna pë. Bohax tsi quiha jahuë copiti tsahotí ja tsahoniquë ja qui quësoxëna. Tsahohax,
\p 
\v 14 —Nëá xo mato chama-chamaria Jesu ra —i jodiobo qui ja niquë.
\p Jabi pascua fiesta chiho ca bari ja ini quiha. Matoroco bari quiha.
\v 15 Jatsi quënatsi quiha nohiria bá huaniquë:
\p —Ahuë ra. Ahuë ra. Cruzó tsi tooxahuë ra —i jaca niquë.
\p Jatsi quiha,
\p —¿Mato chama-chamaria tooxaxëhi ni ëa pa? —i jato qui ja niquë.
\p 
\v 16 Chanixo tsi jato qui Pilató Jesu mëaniquë cruzó tsi tooxahacati.
\s1 Cruzó tsi Jesu ja tooxacanina
\r Mateo 27.32-44; Marcos 15.21-32; Lucas 23.26-43
\p 
\v 17 Jatsi jodiobá Jesu biniquë. Yaca cacha ja mëpihacani quiha jahuë cruz iahaina. Mapo Xao Ya icanai ca maca qui tsi quiha ja bocaniquë, naa jodioba joí tsi “Gólgata” quënahacanish cato.
\v 18 Toa xo tsi Jesu soldado bá tooxaniquë cruzó no. Jasca, ja bëta dos ca joni huëtsa bo ja tooxacaniquë, huësti ca jahuë mënëcayá no, huëtsa jahuë mëxojó no. Nëpax tsi quiha Jesu cruz iniquë.
\v 19 Jatsi quiha papi ó tsi Pilató quënëniquë cruzó tsi janahacati chani.
\p “Nazarét ca Jesu. Jodioba chama-chamaria” i ja quënëni ca niquë.
\p 
\v 20 Jabi Jerusalén basima tsi Jesu tooxahacani quiha. Ja quëshpi tsi huëstima ca jodiobá Pilató quënëni ca jisniquë. Tres ca joi bá tsi jahuë chani quënëhacani quiha, naa jodioba joi, griego joi, romanoba joi.
\v 21 Jabi arati ibo bo qui anoma ini quiha Pilató quënënina. Jatsi quiha Pilato qui ja chanicaniquë:
\p —Mi quënëha ca rarinamahuë. “Jodioba chama-chamaria” quënëyamana rë. Jama, “‘Jodioba chama-chamaria xo ëa’ ii quiha naa joni” quënëhuë —nëa tsi quiha Pilato qui jaca niquë.
\p 
\v 22 Jatsi quiha,
\p —E quënëha ca rarinamayamaquia ra —i Pilato niquë.
\p 
\v 23 Jatsi cruzó tsi Jesu tooxaxo tsi quiha jahuë raiti soldado bá biniquë. Bixo tsi cuatro ca maa ca ja oquëxhuacaniquë jamë bax na. Jabi cuatro ca soldado bo ja icani quiha, naa jahuë raiti ó quëënish cabo. Jatsi quiha jahuë camisaria jiaxëni ca ja bicaniquë, naa quëshëquë yama cato.
\v 24 Bichi tsi soldado bo nëcaniquë:
\p —Jahuë camisaria no jaxcayamano ra. Suerte bo no niaparino. Toca tsi jahuë camisaria biti ca cahëxëqui noa ra —i jaca niquë.
\p Toca tsi ja acanai cató tsi Quënëhacanish cabo jatihuahacani quiha. Jabi Quënëhacanish cabá yoani ca tsi xo naa:
\q1 “Jato xërëquë xo tsi noho sahuëti bo ja oquëxhuacaniquë.
\q1 Noho camisaria quëshpi tsi suerte bo ja niacaquë” iquiina.
\m Jabi toca tsi soldado bá aniquë ra.
\p 
\v 25 Jabi cruz tapaí quiha Jesu jahëhua María, jahuë jahëhua noma, Cleofas ahuini María, María Magdalena, tihi cabo iniquë.
\v 26 Jasca, jahuë jahëhua tapaí nii ë iniquë, ëa ri. Jatsi noqui, naa ëa, jahuë jahëhua María, tihi cabo Jesú jisniquë. Jisi tsi,
\p —Jaboqui mi baquë tsi xo toa, caí —i jahëhua qui ja niquë.
\p 
\v 27 Jatsi ë qui ja chaniniquë:
\p —Noho jahëhua mi otono, mi ihua ó mi bësohai jascaria —iquiina.
\p Japi noho xobo qui Jesu jahëhua ë boniquë racati.
\s1 Jesu nanina
\r Mateo 27.45-56; Marcos 15.33-41; Lucas 23.44-49
\p 
\v 28 Jaquirëquë jahuë maí ca yonoco jatihuahacani ca Jesú cahëniquë. Jatsi,
\p —Tëshinaquia —i ja niquë, Quënëhacanish cabá yoani ca jatihuaxëna.
\p 
\v 29 Jabi toá tsi nii quiha chomo iniquë. Nopi ca jënë jayani quiha. Jatsi toa jënëria qui tatë ja moosacaniquë. Moosaxo tsi quiha tahuá tsi tatë ja rëbiquiriahacaniquë. Jatsi jahuë jana qui ja tërocaniquë nopi ca jënë amaxëna.
\v 30 Jënëria acax tsi,
\p —Jatiquë noho yonoco ra —i Jesu niquë.
\p Jatsi ja tëpiniquë. Tëpihax ja naniquë.
\s1 Jesu xao bo tëcahacayamanina
\p 
\v 31 Jabi chitahëpaimaria quiha jodioba joiti bari iniquë. Ja quëshpi tsi Pilato qui jodiobo chaniniquë:
\p —Cruzó tsi tooxahacanish caba huico bo tëcaritsacahuë, ja rësohuënicano. Jato yora bo botëmahacaxëti xo —iquiina.
\p Jabi jodiobo qui anoma ini quiha cruzó tsi yora rotamëhaina, naa jato joiti barí no. Bari-bariria jato jodioba joiti bari ini quiha. Jato qui roa quiha.
\v 32 Jaha tsi quiha soldado bo bocaniquë jato huico bo tëcaxëna. Jatsi Jesu ya ca tooxahacanish ca joni ba huico pari ja tëcacaniquë, mëri tsi ja rësocano.
\v 33 Tëcahax Jesu qui ja bocaniquë. Ja qui cahëxo tsi quiha bësoyama ja iqui ca ja jiscaniquë. Ja quëshpi tsi jahuë huico bo ja tëcayamacaniquë.
\v 34 Jama, soldado huëstitá Jesu yora quëpë tsacaniquë jahuë saipí no. Jatsi jimi, jënëpaxa, tihi cabo xapaquëniquë.
\v 35 Jasca, ja rësohai ca ë jisniquë ëa ri. Jabija tsi xo naa ë quënëhaina. Quiayamaquia. Parayamaquia, ja qui ma chitimicano mato ri.
\v 36 Jabi nëca tsi Jesu naniquë Quënëhacanish cabo jatihuahacano iquish na, naa “Jahuë xao bo tëcayamacaxëcani quiha” ini cato ó no.
\v 37 Jasca, “Ja tsacani ca qui tsayaxëhi quiha nohiria bo” ii quiha Quënëhacanish caba iti huëtsa ó no.
\s1 Jesu maihuahacanina
\r Mateo 27.57-61; Marcos 15.42-47; Lucas 23.50-56
\p 
\v 38 Jaquirëquë quiha raquëhax tsi Arimatiá ca racanish ca José caniquë Pilato qui. Caxo tsi quiha Jesu yora ja bënaniquë maihuaxëna.
\p Jatsi quiha,
\p —Bihuë —i ja qui Pilato niquë.
\p Jatsi quiha Jesu yora bichi ja caniquë. Jabi Jesu rabëti ja iqui ca ja yoayamaniquë jodioba chama bo qui raquëhi na.
\v 39 Jasca, ja bëta Nicodemo caniquë jaa ri, naa baquichá Jesu qui canish cato. Yora maihuati shomahuati perojome, naa mirra, áloes roihacani ca chëxëti ja bëcaniquë. Ihuë ini quiha ja bëcani ca chëxëti.
\v 40 Jatsi Jesu yora ja bicaniquë. Bixo tsi quiha ja yabocaniquë, chëxëtí tsi cohohuahaina.
\v 41 Jabi cruzó tsi Jesu tooxahacani ca basima huerto ini quiha. Toá tsi maiquini paxa ca ini quiha, naa maihuahama cato.
\v 42 Ja bamayamacaniquë, jato jodioba joiti bari chitahëpaimaria ini quëshpi na. Jaha tsi toa maiquini qui mëri tsi Jesu ja maihuacaniquë, cruz basima ja ini quëshpi na.
\c 20
\s1 Jesu bësotëquënina
\r Mateo 28.1-8; Marcos 16.1-8; Lucas 24.1-12
\p 
\v 1 Domingo baquishmari, jari mitsëmono tsi quiha maiquini qui María Magdalena caniquë. Caxo tsi quini quëbëti maxax chahitaxëni ja yopaniquë. Bahama ja tarahacani quiha.
\v 2 Yopahax jahari ja jabaniquë Simón Pedro, ëa, tihi cabo yoaxëna. Jabahax,
\p —Maiquini quima noba Iboba yora ja tsëcacahitaquë rë. ¿Jahuënia cara jahuë yora ja janacahitaha sa? Cahëyamaqui noa rë —i ja niquë.
\p 
\v 3 Jatsi quiha Pedro, ëa, tihi cabo jahuë maiquini qui bocaniquë jisxëna.
\v 4 No jabanabëquiniquë. Jatsi Pedro ë xononiquë. Jariapari jahuë maiquini qui ë cahëniquë.
\v 5 Cahëxo tsi ë naisniquë. Jahá ca jahuë yora yabohacanish ca raiti ë jisniquë caiti xo na. Jari quini qui ë jicoyamaniquë.
\v 6 Jatsi ë cho Pedro joniquë. Johax quini qui ja jiconiquë jisxëna. Yabohacanish ca raiti ja jisniquë jaa ri.
\v 7 Jatsi Jesu bëmana yabohacaha ca raiti pistia ja jisniquë. Iti huëtsá tsi ja ini quiha pa; yabohaca roha. Raiti tëxë basi jahuë mapo raiti ini quiha.
\v 8 Jatsi maiquini qui ë jiconiquë ëa ri. Jicoxo tsi niabëriahacanish ca raiti pistia ë jisniquë ëa ri. Jisi tsi Jesu bëso iqui ca ë cahëniquë ra.
\v 9 Toatiyá tsi jari Jesu yoati Quënëhacanish cabo no cahëyamariani quiha, naa “Rësonish cabo quima ja tërohacati xo” iquii cato.
\v 10 Tsayahax jahari noba xobo qui no caniquë.
\s1 María Magdalena qui Jesu jisiquinina
\r Marcos 16.9-11
\p 
\v 11 Jabi jahari quiha jahuë maiquini qui María Magdalena caniquë. Toá tsi arahi ja iniquë, quini quëmëpi nii iquiina. Arapama tsi quiha ja rëniniquë naisxëna.
\v 12 Naisxo tsi quiha dos ca ángel bo ja jisniquë. Raiti joxo sahuë ja icani quiha. Jasca, Jesu janahacani cató tsi tsaho ja icani quiha; huësti ca jahuë matoró no, huësti ca jahuë tahë rësó no.
\p 
\v 13 Jatsi quiha,
\p —¿Jënihax tsi arahai, caí? —i ja qui ángel bo niquë.
\p —Noho Iboba yora ja bocahitaquë rë. Ja janacana ca iti cahëyamaquia rë —i María niquë.
\p 
\v 14 Chanipama tsi quiha ja bopinaniquë. Jatsi Jesu ja jisniquë pa. Jama, Jesu ja iqui ca ja cahëyamani quiha.
\p 
\v 15 Jatsi quiha,
\p —¿Jënihax tsi arahai, caí? ¿Tsohuë mërahai? —i ja qui Jesu niquë.
\p Jabi toa mai obëso ca ja iqui ca María jascahuani quiha. Ja quëshpi tsi ja qui chanitsi María niquë:
\p —¿Jahuë yora mi bichi? ¿Jahuënia tsi mi janaha? Ea yoahuë; ë bichi cano —i ja qui María niquë.
\p 
\v 16 Jatsi quiha,
\p —Mariá —i ja qui Jesu niquë.
\p Ja qui bësohax tsi,
\p —Maestro pa —i María niquë. \fig María Jesú joihuanina|src="cn01857b.tif" size="span" copy="©1978 David C. Cook Publishing Company" ref="JHN 20.16"\fig*
\p 
\v 17 —Ea achariayamahuë. Jari noho Jahëpa qui ë tëronoyamaquë ra —i ja qui Jesu niquë—. Dios, naa noho Jahëpa qui caquia. Jabi mato Dios, mato Jahëpa xo noho Jahëpa ri. Ja qui ë cahai ca yoati tsi ëbë xatë bo yoata —nëa tsi María Magdalena qui Jesu nëcaniquë.
\p 
\v 18 Jatsi quiha Jesu rabëti bo qui María caniquë yoacatsi na.
\p —Ibo Jesu ë jisquë ra —i jato qui ja niquë.
\p Jatsi ja qui Jesú yoaha ca jato qui ja yoaniquë.
\s1 Jahuë rabëti bo qui Jesu jisiquinina
\r Mateo 28.16-20; Marcos 16.14-18; Lucas 24.36-49
\p 
\v 19 Jabi domingó tsi quiha manihi Jesu rabëti bo iniquë. Caquë quiha bari. Mitsëmono quiha. Jasca, xobo caiti quëbëhacani quiha, jato jimibo qui ja raquëcani iqui na. Ja manicano tsi quiha jato xërëquë tsi Jesu niitapiniquë pa.
\p —Joquë ëa ra. Raquëyamacana —i jato qui ja niquë.
\p 
\v 20 Chanixo tsi quiha jahuë mëquë bo, jahuë taquëpë, tihi cabo jato ja jismaniquë. Jatsi quiha jahuë rabëti bo ranirianiquë jato Ibo jisi na.
\v 21 Jatsi jato qui Jesu chanitëquëniquë:
\p —Raquëyamacana. Mato raaquia noho chani yoati, naa ëa noho Jahëpá raani jascaria —i jato qui ja niquë.
\p 
\v 22 Jatsi quiha jato ja xoohaniquë. Xoohacax tsi,
\p —Espíritu Santo bicahuë —i jato qui ja niquë—.
\v 23 Masahacati xo toa nohiria jocha ma shina-bënohaina. Jama, jato jocha pi ma shina-bënoyamano tsi masahacayamaxëqui mato —nëa tsi quiha jahuë rabëti bo qui Jesu nëcaniquë.
\s1 Tomás Jesu jisnina
\p 
\v 24 Jabi jato bëta Tomás, naa Gemelo icanai ca iyamani quiha, naa jato qui Jesu jisiquiquë no. Jabi doce ca rabëti bo ó ca huësti ca ja ini quiha.
\v 25 Ja quëshpi tsi,
\p —Ibo no jisquë ra —i Tomás qui jaca niquë.
\p —¿Ocama ni? —i Tomás niquë—. Chahahuanox pari tsi jahuë mëquë tsayacasquia ra. Jasca, clavó tsacahitaha ca iti jiscasquia. Jahuë clavo quiní tsi noho mëtsis ë raaparino ra —nëa tsi quiha jato qui ja nëcaniquë.
\p 
\v 26 Jatsi huësti semana huinocaniquë. Naquëtë tsi manihi quiha ja itëquëcaniquë. Toatiyá tsi jato bëtá Tomás iniquë jaa ri. Jasca, quëbëhacani quiha xobo caiti. Ja manicano tsi quiha naquëtë tsi jato xërëquë tsi Jesu jisiquitapiniquë. Nii quiha. Jatsi,
\p —Joquë ëa ra. Raquëyamacana —i jato qui Jesu niquë.
\p 
\v 27 Jatsi quiha Tomás qui Jesu chaniniquë:
\p —Nëá mi mëtsis raahuë. Noho mëquë tsayahuë. Nëa mi mëquënë́ tsi noho taquëpë mamëpa. ¿Jari chahahuayamacatsai pa? Ea chahahuahuë —i ja qui Jesu niquë.
\p 
\v 28 Jatsi quiha,
\p —Noho Ibobá, noho Diós —i Tomás niquë quëbihi na.
\p 
\v 29 Jatsi quiha,
\p —Chahahuaqui mia, ëa mi jisi iqui na. Jama, shoma tsi xo toa ëa jis-haxma tsi ë qui chitimicanaibo ra —i ja qui Jesu niquë.
\s1 Jesú anina
\p 
\v 30 Jabi huëstima ca jisti huëtsa bo Jesú aniquë jahuë rabëti bo bësojo xo na. Naa libro ó tsi tihi ca jahuë bo quënëyamaxëquia; huëstima quiha.
\v 31 Jama, naa jisti bo quënëhacaquë jaha no pasohai ca Xabahamati Ibo Jesu nori ca ma cahëno. Jasca, Dios Baquë ja nori ca ma cahëno. Jabi bëso-bësopaoxëhi quiha ja qui chitimicanaibo.
\c 21
\p 
\v 1 Jaquirëquë noqui, naa jahuë rabëti bo qui Jesu jisiquitëquëniquë ia Tiberias quëmapó no. Jabi nëca tsi noqui ja jisiquiniquë.
\v 2 Simón Pedro, Tomás, Natanael, naa Galileá ca yacatá racanish cato, Zebedeo baquë bo, Jesu dos ca rabëti bo, tihi cabo no iniquë ia quëmapó no.
\v 3 Jatsi,
\p —Sani ai caquia ra —i noqui Pedro niquë.
\p Jatsi,
\p —Mi bëta caqui noa noqui ri —i no niquë.
\p Jatsi noti qui no jiconiquë noqui tëquëta. Jicoxo tsi mahitsa no tana-tanashinaniquë rë. Yama quiha.
\v 4 Huëaquë tsi quëmapó ca joni nii ca no jisniquë. Jesu ja iqui ca no cahëyamani quiha.
\p 
\v 5 Jatsi,
\p —¿Japa? ¿Mëquë ya ni mato, joni bá? —i noqui ja niquë.
\p —Yamaha rë —i no niquë.
\p 
\v 6 Jatsi,
\p —Noti mënëcayá tsi mato nishi niatsacana. Toá ca bixëqui mato ra —i noqui ja niquë.
\p Jatsi mënëcaya ó tsi noba nishi no nianiquë. Anomaria sani ini quiha. Jahari nishi xërëtimaxëni no iniquë rë, tihiria ca sani ini quëshpi na.
\p 
\v 7 Jatsi Pedro qui ë chaniniquë:
\p —Tonia Ibo tsi xo toa ra —iquiina.
\p Jatsi Pedró jahuë sahuëti sahuëniquë. Tsoboco ja ini quiha. Sahuëhax jënë qui ja biisiniquë Jesu qui caxëna.
\v 8 Notí tsi noqui tëxë chitëniquë, sani rëamë ca nishi xërëhi na. Quëmapo basima no ini quiha, cien metros roha.
\v 9 Rërëxo tsi chihi rëxquë no jisniquë. Jahá ca sani imahi ja ini quiha. Toá tsi mapari ini quiha jaa ri.
\p 
\v 10 Jatsi noqui Jesu chaniniquë:
\p —Ma bichi ca sani tihi roha ca nëri bëcana —i noqui ja niquë.
\p 
\v 11 Jatsi noti qui Pedro jiconiquë sani bixëna. Quëmapo qui nishi ja xërëniquë. Rëamë tsi nishi ini quiha; ciento cincuenta y tres sani quiha. Tësëyamaniquë nishi pa, huëstima ja iquë ri.
\v 12 Jatsi,
\p —Nëri bëcahuë. ¿Sani piyamacanai? —i noqui Jesu niquë.
\p Jabi Ibo Jesu yoi ja iqui ca no cahëniquë. Ja tsi xo toa “¿Ibo yoi ni mia?” iyamanoniquë.
\p 
\v 13 Jatsi mapari bichi Jesu caniquë. Bixo tsi noqui ja mëaniquë. Sani noqui ja aniquë piti.
\p 
\v 14 Jabi tres tsi ja iniquë, naa noqui Jesu jisiquihaina bësotëquëhax na.
\s1 Simón Pedro ya Jesu chaninina
\p 
\v 15 No oriquiquë tsi quiha Simón Pedro Jesú nicaniquë:
\p —¿Tëxë bo oquë tsi ëa noihai, Jonás baquë Pedró? —iquiina.
\p Jatsi,
\p —Jaahuë, Ibobá. Mia noiquia. Toa cahëqui mia ra —i Pedro niquë.
\p Jatsi Jesú quëbiniquë:
\p —Noho oveja bo, naa ëa chahahuacanaibo tiisimana —i ja qui ja niquë.
\p 
\v 16 Jatsi Jesú Pedro nicatëquëniquë:
\p —¿Ea noiyoihai? —iquiina.
\p —Jaahuë, Ibobá. Mia noiquia. Toa cahëqui mia ra —i Pedro niquë.
\p Jatsi,
\p —Noho oveja bo obëso mi ino ra —i ja qui Jesu niquë.
\p 
\v 17 Jatsi quiha Jesú Pedro nicatëquëniquë pa:
\p —¿Ea noiyoihai, Jonás baquë Pedró? —iquiina.
\p Jatsi Pedro cohuëniquë, tres tsi “¿Ea noihai?” i Jesu ni iqui na.
\p —Jatiroha ca cahëqui mia, noho Ibobá. Mia noiyoiquia. Toa cahëqui mia ra —i Jesu qui Pedro niquë.
\p Jatsi quiha,
\p —Noho oveja bo tiisimana —i ja qui Jesu niquë—.
\v 18 Jabi jaha mi quëëhai ca mi a-apaoniquë, shinapayo mi iquë no. Jama, mi sirinaquë tsi mia nëxacaxëcani quiha nohiria bo. Mi cacasyamahai ca qui mia mëpicaxëcani quiha mia namëxëna —nëa tsi quiha Pedro qui Jesu nëcaniquë.
\p 
\v 19 Jabi Pedro rësohai quinia Jesú jismani quiha nëca tsi ja chaniquë no. Jabi Pedro rësohai cató tsi Dios oquë jismahacaxëti ini quiha. Jatsi,
\p —Ea banahuahuë —i ja qui Jesu niquë.
\s1 Jesu rabëti huëtsa
\p 
\v 20 Jatsi bopinaxo tsi ëa yoi Pedró jisniquë. Jato cho banahuahi ë ini quiha. Jabi Jesu rabëtiria ë ini quiha ëa ri. Jabi no oriquino tsi Jesu tapai tsahonish ca ëa xo naa, naa “¿Tsohuë ni toa mia pasomaha cato, Ibobá?” iquish cato.
\v 21 Jatsi ëa jisi tsi,
\p —¿Japa toa joni, Ibobá? ¿Jënahuariahax rësoxëhi ni? —i Pedro niquë ëa yoati na.
\p 
\v 22 Jatsi quiha Jesú Pedro quëbiniquë:
\p —Toa joni shinayamahuë. Mi shina ma xo ja rësohaina. Ja bësopino tsi jahari ë joxëquë rohari noho shina tsi xo toa. Ea mi banahuati xo iquia —iquiina.
\p 
\v 23 Jatsi pë “Rësoyamaxëhi quiha Juan” itsi nohiria bo niquë. Jabi toa mahitsa ca chani rëtsamani quiha chahahuacanaibo xërëquë no rë. Jabi “Rësoyamaxëqui Juan” iyamaniquë Jesu. Jama, “Mi shina ma xo ja rësohaina. Ja bësopino tsi jahari ë joxëquë rohari noho shina tsi xo toa. Ea mi banahuati xo iquia” i Pedro qui ja ni quiha.
\s1 Jatihaina
\p 
\v 24 Jabi Juan xo ëa, naa carta quënëhai cato. Jabija tsi xo naa ë quënëhaina ra. Jabija ca ë quënëhai ca nori ca cahëqui mato ri.
\v 25 Jabi huëstimaria tsi xo toa Jesú anina ra. ¿Jënahuariaxo raca ja ani ca tëquë no quënëna? Jatiroha ca ë quënërohapino tsi xëa narisquë aquë janati ra.
