\p
\v 35 \w In|strong="H3068"\w* \w addition|strong="H1571"\w* \w to|strong="H3068"\w* \w the|strong="H3068"\w* \w all|strong="H7230"\w* \w the|strong="H3068"\w* \w offerings|strong="H8002"\w* \w that|strong="H2459"\w* \w were|strong="H1571"\w* completely burned \add on the altar\add*, \w the|strong="H3068"\w* priests \w also|strong="H1571"\w* burned \w the|strong="H3068"\w* \w fat|strong="H2459"\w* \w of|strong="H1004"\w* \w the|strong="H3068"\w* other animals \w that|strong="H2459"\w* \w were|strong="H1571"\w* sacrificed \w to|strong="H3068"\w* \w maintain|strong="H3559"\w* good fellowship \w with|strong="H1004"\w* \w Yahweh|strong="H3068"\w*, \w and|strong="H3068"\w* \w the|strong="H3068"\w* usual wine \w offerings|strong="H8002"\w*.  
\p \w So|strong="H1571"\w* \w the|strong="H3068"\w* worship \w at|strong="H3068"\w* \w the|strong="H3068"\w* \w temple|strong="H1004"\w* began \w again|strong="H1571"\w*.  
\v 36 \w And|strong="H5971"\w* \w Hezekiah|strong="H2396"\w* \w and|strong="H5971"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w other|strong="H3605"\w* \w people|strong="H5971"\w* \w of|strong="H1697"\w* Judah \w celebrated|strong="H8055"\w*, \w because|strong="H3588"\w* God \w had|strong="H1961"\w* enabled \w them|strong="H5921"\w* \w to|strong="H1961"\w* \w do|strong="H3605"\w* \w all|strong="H3605"\w* \w those|strong="H3605"\w* \w things|strong="H1697"\w* \w very|strong="H8055"\w* quickly.   
\c 30  
\s1 Preparations to celebrate the Passover Festival  
\p
\v 1-3 The king and his officials and all the other people who had gathered in Jerusalem wanted to celebrate the Passover Festival. But they were not able to celebrate it at the usual time, because many of the priests had still not performed the rituals to purify themselves; therefore they were not allowed to do serve in the festival. Also, everyone had still not come to Jerusalem \add to celebrate the Passover\add*. So they decided to celebrate it one month later than usual.  
\v 4 \w The|strong="H3605"\w* \w king|strong="H4428"\w* \w and|strong="H4428"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w other|strong="H3605"\w* \w people|strong="H5869"\w* \w who|strong="H3605"\w* \w had|strong="H4428"\w* \w gathered|strong="H6951"\w* \w thought|strong="H5869"\w* \w that|strong="H3605"\w* \w was|strong="H1697"\w* \w a|strong="H3068"\w* \w good|strong="H3474"\w* \w plan|strong="H1697"\w*.  
\v 5 \w So|strong="H6213"\w* \w they|strong="H3588"\w* decided \w to|strong="H5704"\w* \w send|strong="H5674"\w* \w messages|strong="H1697"\w* \w to|strong="H5704"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* towns \w in|strong="H3478"\w* Judah \w and|strong="H3478"\w* \w in|strong="H3478"\w* \w Israel|strong="H3478"\w*, \w from|strong="H3478"\w* Beersheba \add in the far south\add* \w to|strong="H5704"\w* \w Dan|strong="H1835"\w* \add in the far north\add*, \w including|strong="H5704"\w* towns \w in|strong="H3478"\w* \w the|strong="H3605"\w* \w tribes|strong="H5975"\w* \w of|strong="H3068"\w* Ephraim \w and|strong="H3478"\w* Manasseh, \w to|strong="H5704"\w* invite \w people|strong="H3808"\w* \w to|strong="H5704"\w* \w come|strong="H5674"\w* \w to|strong="H5704"\w* \w the|strong="H3605"\w* temple \w in|strong="H3478"\w* \w Jerusalem|strong="H3389"\w* \w to|strong="H5704"\w* \w celebrate|strong="H6213"\w* \w the|strong="H3605"\w* \w Passover|strong="H6453"\w* \add Festival\add* \w to|strong="H5704"\w* \add honor\add* \w Yahweh|strong="H3068"\w*, \w the|strong="H3605"\w* \w God|strong="H3068"\w* \w whom|strong="H3588"\w* \w the|strong="H3605"\w* Israeli \w people|strong="H3808"\w* \add worshiped/belonged to\add*. \w Many|strong="H7230"\w* \w of|strong="H3068"\w* \w the|strong="H3605"\w* \w people|strong="H3808"\w* \w had|strong="H3068"\w* \w not|strong="H3808"\w* \w previously|strong="H3808"\w* \w celebrated|strong="H6213"\w* \w that|strong="H3588"\w* festival, \w even|strong="H5704"\w* \w though|strong="H3588"\w* \w it|strong="H6213"\w* \w had|strong="H3068"\w* \w been|strong="H5674"\w* \w written|strong="H3789"\w* \add in the laws of Moses that they should do that\add*.   
\p
\v 6 Obeying \w what|strong="H4687"\w* \w the|strong="H3605"\w* \w king|strong="H4428"\w* \w commanded|strong="H4687"\w*, \w messengers|strong="H7323"\w* \w went|strong="H3212"\w* \w throughout|strong="H3605"\w* \w Judah|strong="H3063"\w* \w and|strong="H1121"\w* \w Israel|strong="H3478"\w*, taking messages \w that|strong="H3605"\w* \w had|strong="H3068"\w* \w been|strong="H3605"\w* written \w by|strong="H3027"\w* \w the|strong="H3605"\w* \w king|strong="H4428"\w* \w and|strong="H1121"\w* \w his|strong="H3605"\w* \w officials|strong="H8269"\w*. \w This|strong="H3068"\w* \w is|strong="H3068"\w* \w what|strong="H4687"\w* \w they|strong="H3068"\w* wrote:  
\pi1 “\w You|strong="H3605"\w* Israeli \w people|strong="H1121"\w*, \w you|strong="H3605"\w* \w who|strong="H3605"\w* \w survived|strong="H7604"\w* after \w being|strong="H1121"\w* \w slaves|strong="H1121"\w* \w of|strong="H1121"\w* \w the|strong="H3605"\w* \w kings|strong="H4428"\w* \w of|strong="H1121"\w* Assyria, \w return|strong="H7725"\w* \w to|strong="H7725"\w* \w Yahweh|strong="H3068"\w*, \w the|strong="H3605"\w* \w God|strong="H3068"\w* whom \add our great ancestors\add* Abraham, \w Isaac|strong="H3327"\w*, \w and|strong="H1121"\w* Jacob \add worshiped/belonged to\add*, \w in|strong="H3478"\w* \w order|strong="H3027"\w* \w that|strong="H3605"\w* \w he|strong="H3068"\w* \w may|strong="H3068"\w* \w return|strong="H7725"\w* \w to|strong="H7725"\w* \w you|strong="H3605"\w*. \w Your|strong="H3068"\w* fathers \w and|strong="H1121"\w* \w brothers|strong="H1121"\w* \w did|strong="H3478"\w* \w not|strong="H7725"\w* faithfully obey \w Yahweh|strong="H3068"\w*, \w the|strong="H3605"\w* \w God|strong="H3068"\w* whom \w our|strong="H3068"\w* ancestors \add worshiped\add*.  
\v 7 \w Do|strong="H3068"\w* \w not|strong="H5414"\w* \w act|strong="H4603"\w* \w like|strong="H1961"\w* \w they|strong="H3068"\w* \w did|strong="H3068"\w*, \w because|strong="H3068"\w* \w what|strong="H7200"\w* \w they|strong="H3068"\w* \w did|strong="H3068"\w* \w caused|strong="H5414"\w* other \w people|strong="H7200"\w* \w to|strong="H3068"\w* \w become|strong="H1961"\w* disgusted \w with|strong="H3068"\w* \w them|strong="H5414"\w*.  
\v 8 \w Do|strong="H5647"\w* \w not|strong="H5414"\w* \w be|strong="H3027"\w* \w stubborn|strong="H7185"\w* \w as|strong="H3068"\w* \w our|strong="H3068"\w* ancestors \w were|strong="H3027"\w*. \w Do|strong="H5647"\w* what \w Yahweh|strong="H3068"\w* desires. \w Come|strong="H7725"\w* \add to Jerusalem\add* \w to|strong="H7725"\w* \w the|strong="H5414"\w* \w temple|strong="H4720"\w*, \w which|strong="H3068"\w* \w he|strong="H3068"\w* \w has|strong="H3068"\w* \w set|strong="H5414"\w* \w apart|strong="H6942"\w* \w forever|strong="H5769"\w*. \w Do|strong="H5647"\w* what pleases \w Yahweh|strong="H3068"\w* \w our|strong="H3068"\w* \w God|strong="H3068"\w*, \w in|strong="H3068"\w* \w order|strong="H3027"\w* \w that|strong="H3068"\w* \w he|strong="H3068"\w* \w will|strong="H3068"\w* \w no|strong="H4480"\w* \w longer|strong="H5769"\w* \w be|strong="H3027"\w* angry \w with|strong="H3068"\w* \w you|strong="H5414"\w*.  
\v 9 \w If|strong="H3588"\w* \w you|strong="H3588"\w* \w return|strong="H7725"\w* \w to|strong="H7725"\w* \w Yahweh|strong="H3068"\w*, \w the|strong="H6440"\w* \w people|strong="H1121"\w* \w who|strong="H3068"\w* \w have|strong="H3068"\w* \w captured|strong="H7617"\w* \w our|strong="H3068"\w* \w brothers|strong="H1121"\w* \add and sisters\add* \w and|strong="H1121"\w* \w our|strong="H3068"\w* \w children|strong="H1121"\w* \w will|strong="H3068"\w* \w be|strong="H3808"\w* kind \w to|strong="H7725"\w* \w them|strong="H5921"\w*, \w and|strong="H1121"\w* allow \w them|strong="H5921"\w* \w to|strong="H7725"\w* \w return|strong="H7725"\w* \w to|strong="H7725"\w* \w this|strong="H2063"\w* \w land|strong="H6440"\w*. \w Do|strong="H3068"\w* \w not|strong="H3808"\w* forget \w that|strong="H3588"\w* \w Yahweh|strong="H3068"\w* \w our|strong="H3068"\w* \w God|strong="H3068"\w* \w is|strong="H3068"\w* kind \w and|strong="H1121"\w* \w merciful|strong="H7349"\w*. \w If|strong="H3588"\w* \w you|strong="H3588"\w* \w return|strong="H7725"\w* \w to|strong="H7725"\w* \w him|strong="H6440"\w*, \w he|strong="H3588"\w* \w will|strong="H3068"\w* \w no|strong="H3808"\w* \w longer|strong="H3808"\w* \w reject|strong="H5493"\w* \w you|strong="H3588"\w*.”   
\p
\v 10 \w The|strong="H5921"\w* \w messengers|strong="H7323"\w* \w went|strong="H5674"\w* \w to|strong="H5704"\w* \w all|strong="H5704"\w* \w the|strong="H5921"\w* \w towns|strong="H5892"\w* \w in|strong="H5921"\w* \w the|strong="H5921"\w* tribes \w of|strong="H5892"\w* Ephraim \w and|strong="H5892"\w* \w Manasseh|strong="H4519"\w*, \w as|strong="H5704"\w* \w far|strong="H5704"\w* \add north\add* \w as|strong="H5704"\w* \w the|strong="H5921"\w* tribe \w of|strong="H5892"\w* \w Zebulun|strong="H2074"\w*, \add and gave them this message,\add* \w but|strong="H1961"\w* most \w of|strong="H5892"\w* \w the|strong="H5921"\w* people \w there|strong="H1961"\w* scorned \w them|strong="H5921"\w* \w and|strong="H5892"\w* ridiculed \w them|strong="H5921"\w*.  
\v 11 But some \w of|strong="H3389"\w* \w the|strong="H4519"\w* people \w of|strong="H3389"\w* \add the tribes of\add* Asher, \w Manasseh|strong="H4519"\w*, \w and|strong="H3389"\w* \w Zebulun|strong="H2074"\w* \w humbled|strong="H3665"\w* \w themselves|strong="H3665"\w* \w and|strong="H3389"\w* went \w to|strong="H3389"\w* \w Jerusalem|strong="H3389"\w*.  
\v 12 \w Also|strong="H1571"\w* \w in|strong="H3068"\w* \w Judah|strong="H3063"\w* \w God|strong="H3068"\w* motivated \w the|strong="H5414"\w* \w people|strong="H1571"\w* \w to|strong="H3068"\w* \w be|strong="H1961"\w* united \w in|strong="H3068"\w* wanting \w to|strong="H3068"\w* \w do|strong="H6213"\w* \w what|strong="H1697"\w* \w Yahweh|strong="H3068"\w* wanted \w them|strong="H5414"\w* \w to|strong="H3068"\w* \w do|strong="H6213"\w*, \w which|strong="H3068"\w* \w is|strong="H3068"\w* \w what|strong="H1697"\w* \w the|strong="H5414"\w* \w king|strong="H4428"\w* \w and|strong="H3063"\w* \w his|strong="H5414"\w* \w officials|strong="H8269"\w* \w had|strong="H3068"\w* \w told|strong="H1697"\w* \w them|strong="H5414"\w* \w to|strong="H3068"\w* \w do|strong="H6213"\w* \w in|strong="H3068"\w* \w the|strong="H5414"\w* \w message|strong="H1697"\w* \w that|strong="H3068"\w* \w they|strong="H3068"\w* \w sent|strong="H5414"\w*.   
\s1 They celebrated the Passover Festival  
\p
\v 13 \w So|strong="H6213"\w* \w a|strong="H3068"\w* \w huge|strong="H7227"\w* \w crowd|strong="H6951"\w* \w of|strong="H6951"\w* \w people|strong="H5971"\w* \w gathered|strong="H6213"\w* \w in|strong="H6213"\w* \w Jerusalem|strong="H3389"\w* \w in|strong="H6213"\w* \w May|strong="H5971"\w*, \w to|strong="H6213"\w* \w celebrate|strong="H6213"\w* \w the|strong="H6213"\w* \w Festival|strong="H2282"\w* \w of|strong="H6951"\w* Eating \w Unleavened|strong="H4682"\w* \w Bread|strong="H4682"\w*.  
\v 14 \w They|strong="H3605"\w* \w removed|strong="H5493"\w* \w the|strong="H3605"\w* \w altars|strong="H4196"\w* \add of Baal\add* \w in|strong="H5493"\w* \w Jerusalem|strong="H3389"\w* \w and|strong="H6965"\w* \w took|strong="H5493"\w* \w away|strong="H5493"\w* \w the|strong="H3605"\w* \w altars|strong="H4196"\w* \w for|strong="H4196"\w* \w burning|strong="H6999"\w* \w incense|strong="H6999"\w* \add to honor other gods, and burned them\add* \w in|strong="H5493"\w* \w Kidron|strong="H6939"\w* \w Valley|strong="H5158"\w*.   
\p
\v 15 \w They|strong="H3068"\w* \w slaughtered|strong="H7819"\w* \w the|strong="H3068"\w* \w Passover|strong="H6453"\w* lambs \w on|strong="H3068"\w* \w the|strong="H3068"\w* \w fourteenth|strong="H6240"\w* \w day|strong="H2320"\w* \w of|strong="H1004"\w* \w that|strong="H3068"\w* \w month|strong="H2320"\w*. Some \w of|strong="H1004"\w* \w the|strong="H3068"\w* \w priests|strong="H3548"\w* \w and|strong="H3068"\w* \w the|strong="H3068"\w* \w other|strong="H8145"\w* descendants \w of|strong="H1004"\w* \w Levi|strong="H3881"\w* \w were|strong="H3881"\w* \w ashamed|strong="H3637"\w* \add because they had not performed the rituals to cause them to be acceptable to work for Yahweh\add*. \w So|strong="H6942"\w* \w they|strong="H3068"\w* performed those rituals, \w and|strong="H3068"\w* \w brought|strong="H3548"\w* \w to|strong="H3068"\w* \w the|strong="H3068"\w* \w temple|strong="H1004"\w* animals \w to|strong="H3068"\w* \w be|strong="H3068"\w* completely burned \add on the altar\add*.   
\p
\v 16 \w Then|strong="H4872"\w* \w they|strong="H5921"\w* \w stood|strong="H5975"\w* \w at|strong="H5921"\w* \w the|strong="H5921"\w* \w places|strong="H3027"\w* \w where|strong="H5921"\w* \w Moses|strong="H4872"\w* \w had|strong="H4872"\w* written \w in|strong="H5921"\w* \w his|strong="H5921"\w* \w laws|strong="H8451"\w* \w that|strong="H3548"\w* \w they|strong="H5921"\w* \w should|strong="H3548"\w* \w stand|strong="H5975"\w*. \w Then|strong="H4872"\w* \w the|strong="H5921"\w* descendants \w of|strong="H3027"\w* \w Levi|strong="H3881"\w* \w gave|strong="H4872"\w* \w to|strong="H5921"\w* \w the|strong="H5921"\w* \w priests|strong="H3548"\w* \add bowls containing blood of the animals that were being sacrificed\add*, \w and|strong="H4872"\w* \w the|strong="H5921"\w* \w priests|strong="H3548"\w* \w sprinkled|strong="H2236"\w* \add the altar\add* \w with|strong="H5921"\w* \w some|strong="H3027"\w* \w of|strong="H3027"\w* \w the|strong="H5921"\w* \w blood|strong="H1818"\w*.  
