\v 13 Te \w dongah|strong="H9999"\w* \w Samson|strong="H8123"\w* \w te|strong="H0413"\w* \w Delilah|strong="H1807"\w* loh, “\w Tahae|strong="H2008"\w* \w duela|strong="H5704"\w* \w kai|strong="H9901"\w* \w taengah|strong="H9996"\w* na \w omsaa|strong="H2048"\w* \w tih|strong="H9999"\w* \w kai|strong="H9901"\w* \w taengah|strong="H0413"\w* \w laithae|strong="H3577"\w* na \w thui|strong="H1696"\w*, \w kai|strong="H9901"\w* \w taengah|strong="H9997"\w* \w thui|strong="H5046"\w* laeh, \w ba|strong="H4100"\w* \w nen|strong="H9996"\w* lae ng'\w khih|strong="H0631"\w* eh?,” a \w ti|strong="H0559"\w* nah.  
\p Te \w vaengah|strong="H9999"\w*, “\w Ka|strong="H9901"\w* \w lu|strong="H7218"\w* kah \w samtum|strong="H4253"\w* \w parhih|strong="H7651"\w* \w he|strong="H0853"\w* \w hnitah|strong="H4545"\w* \w dongah|strong="H5973"\w* na \w tah|strong="H0707"\w* \w atah|strong="H0518"\w*,” a \w ti|strong="H0559"\w* nah.   
\p
\v 14 Te \w dongah|strong="H9999"\w* a sam te \w ciphuem|strong="H3489"\w* \w neh|strong="H9996"\w* khak a \w hen|strong="H8628"\w* pah \w tih|strong="H9999"\w*, “\w Samson|strong="H8123"\w* \w na|strong="H9905"\w* pum \w dongkah|strong="H5921"\w* \w Philisti|strong="H6430"\w* rhoek te,” a \w ti|strong="H0559"\w* nah.  
\p Te \w vaengah|strong="H9999"\w* \w a|strong="H9909"\w* \w ih|strong="H8142"\w* kung \w lamkah|strong="H4480"\w* \w haenghang|strong="H3364"\w* \w tih|strong="H9999"\w* \w ciphuem|strong="H3489"\w* \w te|strong="H0853"\w* \w tampai|strong="H0708"\w* \w neh|strong="H9999"\w* \w hnitah|strong="H4545"\w* neh rhen a \w dueng|strong="H5265"\w*.   
\p
\v 15 Te \w phoeiah|strong="H9999"\w*, “\w Nang|strong="H9903"\w* loh, 'Kan \w lungnah|strong="H0157"\w*,’ tila \w metlamlae|strong="H0349"\w* na \w thui|strong="H0559"\w* thai, \w na|strong="H9905"\w* \w lungbuei|strong="H3820"\w* te \w kai|strong="H9901"\w* \w taengah|strong="H0854"\w* a om \w pawt|strong="H0369"\w* dongah \w kai|strong="H9901"\w* \w taengah|strong="H9996"\w* \w voei|strong="H6471"\w* \w thum|strong="H7969"\w* na \w omsaa|strong="H2048"\w* \w tih|strong="H9999"\w*, \w me|strong="H4100"\w* \w tla|strong="H9996"\w* \w na|strong="H9905"\w* \w thadueng|strong="H3581"\w* a \w len|strong="H1419"\w* khaw \w kai|strong="H9901"\w* \w taengah|strong="H9997"\w* na \w thui|strong="H5046"\w* \w moenih|strong="H3808"\w*,” a \w ti|strong="H0559"\w* nah.   
\p
\v 16 \w Tedae|strong="H9999"\w* \w Samson|strong="H9909"\w* \w te|strong="H9997"\w* \w hnin|strong="H3117"\w* \w takuem|strong="H3605"\w* ah \w a|strong="H9907"\w* \w ol|strong="H1697"\w* \w neh|strong="H9996"\w* a \w kilh|strong="H6693"\w* \w tih|strong="H9999"\w* a toeh a \w oeih|strong="H0509"\w* \w dongah|strong="H9999"\w* \w duek|strong="H4191"\w* \w ham|strong="H9997"\w* ni \w a|strong="H9909"\w* \w hinglu|strong="H5315"\w* long a \w hnuenah|strong="H7114"\w* coeng.  
\v 17 Te \w dongah|strong="H9999"\w* \w a|strong="H9909"\w* \w lungbuei|strong="H3820"\w* kah \w boeih|strong="H3605"\w* \w te|strong="H0853"\w* \w Delilah|strong="H9907"\w* \w taengah|strong="H9997"\w* a \w thui|strong="H5046"\w* pah. Te \w vaengah|strong="H9999"\w*, “\w Kai|strong="H0589"\w* he \w a|strong="H9901"\w* \w nu|strong="H0517"\w* \w bung|strong="H0990"\w* khui \w lamloh|strong="H4480"\w* \w Pathen|strong="H0430"\w* kah \w hlangcoelh|strong="H5139"\w* la ka om \w dongah|strong="H3588"\w* \w thiha|strong="H4177"\w* loh \w ka|strong="H9901"\w* \w lu|strong="H7218"\w* a \w ben|strong="H5927"\w* \w moenih|strong="H3808"\w*. \w Vo|strong="H1548"\w* \w koinih|strong="H0518"\w* \w ka|strong="H9901"\w* \w thadueng|strong="H3581"\w* he \w kai|strong="H9901"\w* \w lamloh|strong="H4480"\w* \w nong|strong="H5493"\w* \w vetih|strong="H9999"\w* ka \w tlo|strong="H2470"\w* ni. Te \w vaengah|strong="H9999"\w* \w hlang|strong="H0120"\w* \w boeih|strong="H3605"\w* \w banglam|strong="H9995"\w* ni ka \w om|strong="H1961"\w* eh?,” a \w ti|strong="H0559"\w* nah.   
\p
\v 18 \w A|strong="H9909"\w* \w lungbuei|strong="H3820"\w* kah aka om \w boeih|strong="H3605"\w* \w te|strong="H0853"\w* a \w thui|strong="H5046"\w* coeng \w tila|strong="H3588"\w* \w Delilah|strong="H1807"\w* loh a \w hmuh|strong="H7200"\w*. Te \w dongah|strong="H9999"\w* tah \w Philisti|strong="H6430"\w* \w boei|strong="H5633"\w* rhoek \w te|strong="H9997"\w* a \w tah|strong="H7971"\w* \w tih|strong="H9999"\w* a \w khue|strong="H7121"\w* vaengah, “\w Anih|strong="H9907"\w* long \w he|strong="H9997"\w* \w kamah|strong="H9901"\w* \w taengah|strong="H9997"\w* \w a|strong="H9909"\w* \w lungbuei|strong="H3820"\w* kah \w boeih|strong="H3605"\w* \w te|strong="H0853"\w* a \w phoe|strong="H5046"\w* coeng \w dongah|strong="H3588"\w* \w vai|strong="H6471"\w* ah \w halo|strong="H5927"\w* uh saeh,” a \w ti|strong="H0559"\w* nah.  
\p Te \w dongah|strong="H9999"\w* \w Philisti|strong="H6430"\w* \w boei|strong="H5633"\w* rhoek loh \w Delilah|strong="H9907"\w* \w taengla|strong="H0413"\w* \w halo|strong="H5927"\w* uh \w tih|strong="H9999"\w* \w a|strong="H9908"\w* \w kut|strong="H3027"\w* \w dongah|strong="H9996"\w* \w tangka|strong="H3701"\w* hang \w khuen|strong="H5927"\w* uh.   
