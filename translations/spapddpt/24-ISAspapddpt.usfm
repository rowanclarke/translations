\v 9 \w Porque|strong="H3588"\w* \w este|strong="H1931"\w* \w pueblo|strong="H5971"\w* \w es|strong="H1931"\w* \w rebelde|strong="H4805"\w*, \w hijos|strong="H1121"\w* \w mentirosos|strong="H3586"\w*, \w hijos|strong="H1121"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* quieren \w escuchar|strong="H8085"\w* \w la|strong="H1931"\w* \w Ley|strong="H8451"\w* \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd*,
