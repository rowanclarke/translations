\id SNG - Dawuro Full Bible Latin Version
\h Siik'uwaa Sabaa
\toc1 Siik'uwaa Sabbiyaa Mas'aafaa
\toc2 Siik'uwaa Sabaa
\toc3 Sik'.
\mt1 Siik'uwaa Sabbiyaa Mas'aafaa
\imt1 Geluwaa
\ip «Siik'uwaa Sabbiyaa Mas'aafay» siik'uwaa timirttiyaa k'oriide shiishsheeddawaa. Ha gins's'atuwaappe dariyaa baggatuu mazimuriyaa malan s'aafetteeddino; unttunttu attumawe mac'c'aaniw, mac'c'awunna k'ay attumawoo s'aafeeddawantta. Ha mas'aafay itti itti biletsatuwaan «Siik'uwaa Sabaa» woy «Mazamuriyaa Ubbaappe Aad'd'iyaa Mazimuriyaa» geetettiide erettee. Hara biletsatuwaan k'ay «Solomona Mazimuriyaa» geetettiide erettee. Ayaw gooppe, Ibrayiss's'e k'aalan s'aafetteedda mas'aafay Solomon s'aafeedda giide odiyaa diraassa.
\ip Ha mazamurii Kiristtoosappenne woosa golliyaappenne gidduwaan de'iyaa gakkettussaa bessiyaa leemisatwaa oyk'k'eeddawaa. Shin Ayihudatuu, «S'oossaappenne Israa'eeliyaa asaappe gidduwaan de'iyaa gakkettussaa bessiyaa leemisatwaa oyk'k'iyaa mas'aafaa» giino.
\iot Shemppatuwaa Ubbatoo Imetteedda K'antsa K'ofatuwaa
\io1 Siik'uu Woynniyaa Eesaappe aad'd'ee \ior 1:1—2:7\ior*
\io1 Siik'uu Ubbaa Yewuwaa Loytsee \ior 2:8—3:5\ior*
\io1 Soyzzuwaabaa \ior 3:6—4:5\ior*
\io1 Soyzzuwaa Ittippetetsaa \ior 4:6—5:16\ior*
\io1 Siik'uu Ubbaappe Dooretee \ior 6:1—7:6\ior*
\io1 Taaninne Neeninne S'alalay \ior 7:7—8:4\ior*
\io1 Siik'uwaa Sabaa \ior 8:5-14\ior*
\c 1
\s1 Siik'uu Woynniyaa Eesaappe Aad'd'ee
\r (1:1—2:7)
\q1 
\v 1 Mazamuriyaa ubbaappe aad'd'iyaa Solomona mazamurii hawaa.
\sp Wodoratta:
\q1 
\v 2 «Ne siik'uu woyniyaa eessaappe aad'd'i nashechchiyaa diraw,
\q2 ne mettershshan zaara zaaraadekka taana yera.
\q1 
\v 3 Ne okettiyaa shittuu wooti sawii!
\q2 Ne suntsay s'eesettiyaa wodekka ayaa nashechchii!
\q2 Geelayotuu neena siik'iyaawe hewaassa.
\q1 
\v 4 Taana neenana akkaade ba. Haaya, ane laa"uu ittippe wos's'oytte!
\q2 Ta kaatiyaw, taana ne siiris'aa gelissa» yaagaaddu.
\sp Yerusaalame mac'c'a asatuu:
\q1 Aban nuuni ay keeshshaa nashetteeddo!
\q2 Nuuni Aa siik'uwaa woyniyaa eessaappekka aatsiide nashetto.
\q2 Tumukka mac'c'a Asay ubbay neena siik'anaw bessee yaageeddino.
\s1 Wodoratta:
\q1 
\v 5 Hinttenoo, Yerusaalame mac'c'a asatoo, sisite,
\q2 taani karetsa; gidooppenne, malanchcha.
\q2 Ta karetsatetsay K'eedaare dunkkaaniyaa mala;
\q2 shin ta malay Solomona kaatiyaa golliyaa gaariddotuwaa mala.
\q1 
\v 6 Ta malaa kares'isseeddawe s'uuggiyaa aawaa;
\q2 taani karetsa gideedda diraw, taana kad'oppa.
\q2 Ta ishatuu, ta aatti naanatuu taananna walak'ettiide,
\q2 taana woyniyaa turaa naaganchcha ootseeddino;
\q2 yaatina, taani taana naagabeykke.
\q1 
\v 7 Ta siik'ow, ane taw oda;
\q2 ne dorssaa wudiyaa neeni heemmiyaawe hak'anee?
\q2 Gallassi awaappe ne unttuntta shemppisiyaawe hak'anee?
\q2 Neena demmanaw ne laggetuwaa wudiyaa kaalaade,
\q2 ayaw yuushshanchcha mac'c'a asaa gidoo? yaagaaddu.
\sp Yerusaalame mac'c'a asatuu:
\q1 
\v 8 Hanne, mac'c'a asaa ubbaappe aad'd'a lo"iyaa malanchchatee!
\q2 Sa'aa erana d'ayooppe, dorssay beedda sa'aa kaalaade ba;
\q2 ne deeshsha maratuwaakka hentsanchchatuwaa dunkkaaniyaa matan heemma.
\sp Woddallay
\q1 
\v 9 Ta siik'k'atee!
\q2 Gibs'e kaatiyaa paraa gaariyaa goochchiyaa paratuwaa giddon de'iyaa maggaayatiidan lo"aasa.
\q1 
\v 10 Abeet, ne haytsaan goolakkattiyaa alleek'k'uwaana shiik'iide,
\q2 ne gac'uu ayaa lo"ii! Ne ziizziikka ink'k'uwaan alleek'k'etteedawaa.
\q1 
\v 11 Nuuni new biran alleek'k'etteedda,
\q2 work'k'aa alleek'k'uwaa oosissana yaageeddino.
\sp Wodoratta:
\q1 
\v 12 Kaatii maaddan utti de'ishshin,
\q2 ta shittuwaa sawuu golliyaa giddo ubbaan toshukku geedda.
\q1 
\v 13 Ta siik'uu ta d'antsatuwaappe gidduwaan shemppiyaa wode,
\q2 Aa peenuu k'arc'c'iitiyaana de'iyaa kawaraadan sawee.
\q1 
\v 14 Ta siik'uu Enggaade geetettiyaa woyniyaa sa'aan doleedda,
\q2 bazzuwaa c'iishshaa mala yaagaaddu.
\sp Wodallay:
\q1 
\v 15 Ta siik'k'atee, neeni waata lo"ay! Neeni waata lo"ay!
\q2 Ne ayifetuu harap'p'iyaa ayfiyaadan lo"iino yaageedda.
\sp Wodoratta:
\q1 
\v 16 Ta siik'ow, neeni ayaa lo"ay! Ayaa nashechchay;
\q2 nu arssayikka aac'eedda maataadan nashechchiyaawaa.
\q1 
\v 17 Nu golliyaa zaaruu zigaa; kaaraykka s'iidan dadetteeddawaa yaagaaddu.
\c 2
\sp Wodoratta:
\q1 
\v 1 Taani, «Saaroona giyaa sa'aan doliyaa c'iishshaanne,
\q2 wombban doliyaa lo"o c'iishshaa mala» yaagaaddu.
\sp Wodallay:
\q1 
\v 2 Ee ta siik'k'atta mac'c'a asaa giddon s'eelliyaa wode,
\q2 aguntsaa giddon beettiyaa lo"o c'iishshaa malataw yaageedda.
\sp Wodoratta:
\q1 
\v 3 Ta siik'uu hara wodallatuwaa giddon s'eelliyaa wode,
\q2 woran de'iyaa appiliyaa giyaa mitsaa malatee;
\q2 taana loytsi nashechchina, Aa kuwaa giddon uttaad;
\q2 Aa ayifii miina, taana loytsi mal"ee.
\q1 
\v 4 I taana k'umaa miyaa aakko wuyggiyaa gelisseedda;
\q2 bare siik'uwaa banddiraadan ta bolla d'ok'k'u d'ok'k'u ootseedda.
\q1 
\v 5 Taani Aa siik'uwaan okettaade harggeedda diraw,
\q2 zabiibiyaa ayifiyaa taana miziide ministe;
\q2 appiliyaa taana miziide, ta wolk'k'aa kuntsite.
\q1 
\v 6 Bare haddirssa kushiyaa taana borkkotisseedda;
\q2 bare ushechcha kushiyan taana k'oommeedda.
\q1 
\v 7 Hinttenoo Yerusaalame yalaga mac'c'a asaw,
\q2 siik'uu barew dosiide denddana gakkanaw,
\q2 Aa hintte beegotsena mala,
\q2 taani hinttena gen"etuwaaninne bazzuwaa dogetuwaan c'allay.
\s1 Siik'uu Ubbaa Yewuwaa Loytsee
\r (2:8—3:5)
\q1 
\v 8 Sisite, hewe ta siik'uwaa kooshshaa! Be'ite deriyaana piriidde,
\q2 zoozetuwaa bollaanna s'onggettiidde gakkeedda!
\q1 
\v 9 Ta siik'uu wushaa mala; woy gen"iyaa maraa malatee.
\q2 Be'ite, I nu golliyaa dirssaa matan ek'k'eedda;
\q2 maskkootiyaanna golle s'eellee;
\q2 gaaridduwaa garssaanakka luus's'ay s'eellee.
\q1 
\v 10 Ta siik'uu taana hawaadan yaagee; Ta siik'k'atee, dendda!
\q2 Ta malanchchatee, haaya! Ittippe ane boytte.
\q1 
\v 11 Be'a, balgguu aad'd'eeda; iraykka ek'k'eedda.
\q1 
\v 12 Biittan c'iishshay c'iisheedda; yetsaa yes's'iyaa aginayikka gakkeedda;
\q2 harap'p'iyaa yetsay nu biittan sisettee.
\q1 
\v 13 Balasii ayifiyaa doommeedda; woynnii c'iisheedda;
\q2 Aa c'iishshaa sawuu biittan toshukku gee.
\q2 Hewaa diraw, ta siik'k'atee, dendda; ta malanchchatee, haaya;
\q2 ane ittippe boytte yaagee yaagaaddu.
\sp Wodallay:
\q1 
\v 14 Neeni aafuwaa doonaa zaallaa za'an k'osetteedda harap'p'atti mala;
\q2 ane itti gede taana ne som"uwaa bessa; ne kooshshaakka sisa.
\q2 Ayaw gooppe, ne kooshshay taana k'aretsee;
\q2 ne som"uukka daro lo"ee yaageedda.
\sp Yerusaalame Wodorotuu:
\q1 
\v 15 Nu woynnii c'iisheedda; hewaa diraw,
\q2 nu woyniyaa gidduwaa bayzziyaa worakanatuwaa,
\q2 he k'eeri worakanatuwaa p'iriyaa wotsiide oyk'k'ite yaageeddino.
\sp Wodoratta:
\q1 
\v 16 Ta siik'uu tawaa; taanikka aano;
\q2 c'iishshaa giddon I bare wudiyaa heemmee.
\q1 
\v 17 K'amma d'umay k'aarettanaw, wontta c'arkkuu c'arkkanaw,
\q2 ta siik'ow, gen"iyaadan woy yalaga doggiyaadan,
\q2 aafotiya deriyaana wos's'aade haa simma yaagaaddu.
\c 3
\sp Wodoratta:
\q1 
\v 1 K'amma kumentsaa ta hiis'an gisaade,
\q2 ta siik'uwaa demmanaw amottaad; minisaade koyaad;
\q2 shin demmanaw danddayabeykke.
\q1 
\v 2 Katamaa giddon de'iyaa aakonne s'untsa ogetuwaa ubbaan yuuyyaad;
\q2 ta siik'uwaa demmanaw koyaad; minisaade koyaad;
\q2 shin demmanaw danddayabeykke.
\q1 
\v 3 Katamaa yuuyyi naagiyaawanttu taana demmeeddino;
\q2 taanikka, Ta siik'uwaa be'eeditee? yaagaade unttuntta oochchaad.
\q1 
\v 4 Unttunttuppe yaa aad'anne ta siik'uwaa demma aggaad.
\q2 I taappe kessi akkenaadan, minisaade oyk'k'aad;
\q2 ta daayi golle akka afaad; ta yeletteedda kifiliyaa gelissaad.
\q1 
\v 5 Hinttenoo Yerusaalame yalaga mac'c'a asaw,
\q2 siik'uu barew dosiide denddana gakkanaw,
\q2 Aa hintte beegotsena mala,
\q2 taani hinttena gen"etuwaaninne bazzuwaa dogetuwaan c'allay yaagaaddu.
\s1 Soyzzuwaabaa
\r (3:6—4:5)
\sp Yerusaalame Wodorotuu:
\q1 
\v 6 Hawe bazzuwaana yiyaawe, c'uwaa tuussaa malatiyaawe,
\q2 peenuukka zal"anchchaa is'aanaadaaninne kawaraadan,
\q2 sawiyaawe I oonee?
\q1 
\v 7 Hewaa be'ite, Solomona paraa gaarii yee;
\q2 he paraa gaarii Israa'eeliyaappe dooretteedda wolk'k'aamatuu,
\q2 usuppun tammu tooranchchatuu ajabeedino.
\q1 
\v 8 Unttunttu ubbaykka mashshaa oyk'k'etsaa meezeteeddawanttanne,
\q2 olankka paac'etteeddawantta.
\q2 K'amman gakkana metuwaa ek'ettanaw,
\q2 unttunttu ittuu ittuu mashshaa gis's'iide giigeeddawantta.
\q1 
\v 9 Kaatiyaa Solomon paraa gaariyaa giddon,
\q2 barew uttiyaa kawutetsaa araataa giigisseedda.
\q2 I araataa Liibaanoosa asaappe aheedda mitsaappe oosisseedda.
\q1 
\v 10 Araataa tuussatuu biran sheeshetteeddino;
\q2 gedii work'k'aan alleek'k'etteedda;
\q2 uttiyaasay Yerusaalame wodoratuu ochchaa teeraa malatiyaa k'ac'inan,
\q2 siik'uwaan daddeedda afilaan kameteedda yaageeddino.
\sp Wodoratta:
\q1 
\v 11 Hinttenoo, S'iyoone wodoratoo, Kaatiyaa Solomona be'anaw haayite!
\q2 I loytsi nashetteedda, Aa bullachchaa gallassi Aa aata Aa huup'iyaan,
\q2 wotseedda kallachchaa wotsiide utteedda yaagaaddu.
\c 4
\sp Wodallay:
\q1 
\v 1 Ta siik'k'atee, neeni ayaa malanchchatii! Neeni woota lo"ay!
\q2 Ne ayifetuu ne som"uwaa kammiyaa sharbbe gidduwaana be'iyaa wode,
\q2 harap'p'iyaadan lo"iino.
\q2 Ne binnaanay Gala'aade Deriyaappe wod'd'iyaa deeshshaa wudiyaa mala.
\q1 
\v 2 Ne achchay meedettiide, haatsaan meec'etteedda ubbaykka manttiyaa yeliyaa,
\q2 unttunttu giddon maynii bayinna dorssaa wudiyaa mala.
\q1 
\v 3 Ne mettershshatuu zo'o k'ac'inaa mala;
\q2 ne haasayiyaa wode daro nashechchiino.
\q2 Ne laa"u gac'otuwaa sharbbiyaa gidduwaana s'eelliyaa wode,
\q2 itti roomaaniyaa laa"u kessi p'alk'k'eeddawaa malatiino.
\q1 
\v 4 Ne k'ood'ii olaa miishshaa kak'k'anaw gimbbeedda,
\q2 Daawita adussa gimbbiyaa malatee;
\q2 he gimbbii sha"u mino olanchchatuwaa gonddallii kak'ettina,
\q2 alleek'k'etti utteedda.
\q1 
\v 5 Ne d'antsatuu manttiyaa yeletteedda,
\q2 wora c'iishshaa giddon miyaa gen"iyaa maratuwaa malatiino.
\s1 Soyzzuwaa Ittipetetsaa
\r (4:6—5:16)
\q1 
\v 6 K'ammay wonttanaw, kuway kichchanaw,
\q2 karbbiyaa deriyaanne is'aanaa zooziyaa baade shemppashshana.
\q1 
\v 7 Ta siik'k'atee, ne asatetsay ubbaykka malanchcha;
\q2 neenan wotsiyaawe ayaynne baawa.
\b
\q1 
\v 8 Ta mushurattee, Liibaanoosa Deriyaappe wod'd'a.
\q2 Gaammuunne maahii geessuu Amaana Deriyaappe,
\q2 Saniira Deriyaappenne Hermmoone kiikiyaappe wod'd'a.
\q1 
\v 9 Ta siik'uwaa michchato gidiyaa ta siik'attee!
\q2 Ne ayifiyaa s'eeluunne ne k'ood'iyaa alleek'k'uu,
\q2 ta wozanaa nashshechchan gooshsheedda.
\q1 
\v 10 Ta siik'uwaa michchato gidiyaa ta mushurate!
\q2 Ne siik'uu taana ayaa nashechchii!
\q2 Ne siik'uu woyniyaa eessaappe aad'd'i nashechchee;
\q2 ne shittuu ubbabaappekka aad'd'iide sawee.
\q1 
\v 11 Ta mushurattee, ne mettershshaanna eessaa ililuu s'okee.
\q2 Ne doonaappe eessaynne maatsay pulttee;
\q2 ne mayuu Liibaanoosa s'iidday sawiyaawaadan sawee.
\q1 
\v 12 Ta siik'uwaa michchato gidiyaa ta mushurati yuushshuu,
\q2 direttiide naagettiyaa ataakilttiyaa sa'aa mala.
\q2 Yuushshuu gimbbetteedda pulttuwaa,
\q2 maatafay attametteedda goggiyaa haatsaa mala.
\q1 
\v 13 Ne ataakilttetuwaa giddon: roomaanii,
\q2 dooretteedda ataakilttiyaa ayifetuu,
\q2 heenayinne narddoosiyaa giyaawanttu de'iino.
\q1 
\v 14 Hewaadankka k'ay narddoosii,
\q2 laadii, sawuwaa maataynne k'arafay,
\q2 hewaadankka is'aanaadan sawiyaabatuu de'iino;
\q2 hewaadankka k'ay karbbii,
\q2 godare uutsaa c'iishshaynne dumma dumma k'imaamiyaa ataakilttetuu mokkiino.
\q1 
\v 15 Neeni ataakilttiyaa sa'aa aliyaa pulttuwaa mala;
\q2 de'uwaa haatsay beettiyaa ollaa mala;
\q2 Liibaanoosa Deriyaappe goggiyaa shaafaa mala yaageedda.
\sp Wodoratta:
\q1 
\v 16 Huup'issa bagga c'arkkoo, dendda!
\q2 Gedissa bagga c'arkkoo, haaya!
\q2 Ta ataakilttiyaa bolla c'arkka! Aa sawuu hewan toshukku go.
\q2 Ta siik'uu bare ataakilttiyaa giddo yo.
\q2 Daro mal"iyaa teeratuwaa mo yaagaaddu.
\c 5
\sp Wodallay:
\q1 
\v 1 Ta siik'o michchatto gidiyaa ta mishiratte,
\q2 be'a; taani ta ataakilttiyaa giddo gelaad.
\q2 Ta karbbiyaanne ta shittuwaa c'iishshaa k'oray.
\q2 Eessaa ukitsaa yolttayaade may.
\q2 Ta woyniyaa eessaanne ta maatsaa ushay yaageedda.
\sp Yerusaalame Wodoratuu:
\q1 Hinttenoo, Aa laggetoo, siik'uwaa alana gakkanaw ushite yaageeddino.
\sp Wodoratta:
\q1 
\v 2 Taani k'amma gem"ishaad; shin ta wozanay beegotti utteedda.
\q2 Ta akumuwaan ta siik'uu hawaadan yaagiidde,
\q2 penggiyaa k'os's'iina sisaad; Ta mushurattee, ta siik'k'atee,
\q2 neenan wotsiyaawe bayinna ta harap'p'atte, taw kariyaa dooyaa;
\q2 ta huup'ii ketterssaan ka"eedda.
\q2 Ta binnaanaykka k'amma puusiyaan narkkakkeedda yaagee.
\q1 
\v 3 Taani, Ta mayuwaa k'aara diggaad; zaara mayyooyye?
\q2 Ta gediyaa meec'etta kichchaad; zaaraadde urk'k'ayooyye? yaagaad.
\q1 
\v 4 Ta siik'uu ifitsaa s'oo'iyaanna bare kushiyaa golle yeddeedda;
\q2 ta wozanay Aa diraw poddi poddee.
\q1 
\v 5 Yaatina, ta siik'oo kariyaa dooyanaw denddaad.
\q2 Kariyaa dooyiyaa kulbbuwaa taani oyk'k'iyaa wode,
\q2 ta kushiyaappe karbbii, ta birad'd'iyaappe shittuu s'okee.
\q1 
\v 6 Ta siik'oo kariyaa dooyaad; shin dooyiyaa wode I baawa bi kichcheedda.
\q2 Aa kooshshaa sisanaw loytsi amottaad.
\q2 Mintsaade Aa koyaad; shin demmanaw danddayabeykke.
\q2 S'eegaad; shin taw koyibeenna.
\q1 
\v 7 Yuuyyiide katamaa naagiyaawanttu taana demmiide,
\q2 wad'd'eeddinonne madutseeddino;
\q2 katamaa dirssaa naagiyaawanttu ta k'umayuwaa k'aari akkeeddino.
\q1 
\v 8 Hinttenoo Yerusaalame geelayotoo, ta siik'uwaa demmooppe,
\q2 taani Aa siik'uwaappe denddeeddawaan harggiyaawaa,
\q2 hadaraa, aw odite yaagaaddu.
\sp Yerusaalame Wodoratuu:
\q1 
\v 9 Neenoo, mac'c'a asaa ubbaappe aad'd'eeda malanchchatee!
\q2 Ne siik'uu tumu haratuwaappe waan dummatii?
\q2 Neeni hawaa keeshshaa nuuna c'alliyaawe,
\q2 I haratuwaappe dummatiyaawe ayaanee? yaageeddino.
\sp Wodoratta:
\q1 
\v 10 Ta siik'uu daro lo"iyaawaanne mina;
\q2 tammu sha"u attuma asaa giddon Aa mali baawa.
\q1 
\v 11 Aa huup'ii work'k'aa luliyaa malatee;
\q2 Aa binnaanaykka lo"anne k'uuruwaa mala karetsa.
\q1 
\v 12 Aa ayifii shaafaa lank'k'iyaan ek'k'eeddanne,
\q2 maatsan meec'etteeddawaa malatiyaa harap'p'etuwaa malatee.
\q1 
\v 13 Aa gac'otuukka sawuwaa maataynne,
\q2 k'imaamii toketteedda atakilttiyaadan lo"iino;
\q2 Aa mettershshatuu karbbiyaa shittuu s'okiyaa wora c'iishshaadan lo"iino.
\q1 
\v 14 Aa kushetuu ink'k'uwaan alleek'k'etteedda work'k'aa s'am"aadan lo"iino;
\q2 Aa asatetsay samppeeriyaa giyaa ink'k'uwaan alleek'k'etteedda,
\q2 danggarssaa achchaa mala.
\q1 
\v 15 Aa gedetuu work'k'aa baasuwaan toketteedda,
\q2 ibinabaradiyaa tuussaa malatiino;
\q2 Aa malay zigan alleek'k'etteedda Liibaanoosa asaa mala.
\q1 
\v 16 Aa doonay eessaadan mal"ee. I ubbaannakka lo"iyaawaa.
\q2 Hinttenoo Yerusaalame wodoratoo,
\q2 ta siik'uunne ta laggii hawaa malatee yaagaaddu.
\c 6
\ms1 Siik'uu Ubbaappe Doorettee
\mr (6:1—7:6)
\sp Yerusaalame Wodorotuwaa:
\q1 
\v 1 Mac'c'a asaa ubbaappe malanchchatee!
\q2 Ne laggii hak'a beedee? Nuunikka neenana ittippe koyanaw,
\q2 I beedda sa'aa nuw oda yaageeddino.
\sp Wodoratta:
\q1 
\v 2 Ta siik'uu dorssaa wudiyaa heemmanawunne,
\q2 lo"iyaa c'iishshaa shiishshanaw,
\q2 shittuwaa sawuwaa maatay de'iyaa ataakilttiyaa giddo wod'd'eedda.
\q1 
\v 3 Taani ta siik'uwaanno; ta siik'uukka tawaa.
\q2 I c'iishshaa giddon wudiyaa heemmee yaagaaddu.
\sp Wodallay:
\q1 
\v 4 Ta siik'k'atee! Neeni Tirs's'a katamay lo"iyaawaadan lo"aasa;
\q2 Yerusaalamedan daro lo"aasa; banddiraa oyk'k'iide,
\q2 salppiyaan biyaa olanchchay yashshiyaawaadan yashshaasa.
\q1 
\v 5 Hayyanaa ne ayifiyaa taappe wora zaaraarikkii,
\q2 ayaw gooppe, unttunttu taana waayissiino.
\q2 Ne binnaanay Gala'aade Deriyaappe wod'd'iyaa deeshshaa wudiyaa malatee.
\q1 
\v 6 Ne achchay meec'ettiide kesiyaa, ubbaykka manttiyaa yeliyaa,
\q2 unttunttu giddon maynii bayinna dorssaa wudiyaa mala.
\q1 
\v 7 Ne laa"u gac'otuwaa sharbbiyaa gidduwaana s'eelliyaa wode,
\q2 laa"u kesseedda roomaaniyaa teeraa malatiino.
\q1 
\v 8 Usuppun tammu mac'c'a kaatetuunne usuppun tammu baakkotuu,
\q2 k'ay payduu bayinna wodorotuu taw de'iino.
\q1 
\v 9 Shin ta harap'p'atta, ta tooshii bayinnaana, Aa taw dumma.
\q2 Aa bare aatissikka mes's'i ittinno;
\q2 izo yeleedda aatakka ayaappenne aatsaade izo siik'aw.
\q2 Wodorotuukka izo s'eelliide, Hanna anjjetteedaano yaagiino.
\q2 Mac'c'a kaatetuukka baakkotuukka izo sabbiino.
\sp Yerusaalame Wodoratuwaa
\q1 
\v 10 Hanna wontta s'alk'k'iyaadan doliyaana, aginaadan poo'iyaanna,
\q2 awaadan c'addiyaana, banddiraa oyk'k'iide salppiyaan biyaa olanchchaadan,
\q2 yashshiyaanna iza oonee? yaagiino.
\sp Wodallay
\q1 
\v 11 Taani wombban toketteedda mitsatuu lic'uwaa be'anaw,
\q2 woyniyaa turay aac'eedenttonne k'ay roomaaniikka c'iisheeddenttonne s'eellanaw,
\q2 duge ataakilttiyaa sa'aa wod'd'ay.
\q1 
\v 12 Taani akeekenan de'ishiina, ta amuu taana afiide,
\q2 ta kaatiyaa matan, paraa gaariyan taana utisseedda yaageedda.
\sp Yerusaalame Wodorotuwaa:
\q1 
\v 13 Neenoo Shulaame biittaappe yeeddawunne, haaya;
\q2 haa simma! Neena nu loytsiide s'eelana; haa simma! yaageeddino.
\sp Wodoratta:
\q1 Daro asaa sintsan yes's'iyaa asaadan, taakko ayaw s'eelliitee? yaagaaddu.
\c 7
\sp Wodallay:
\q1 
\v 1 Kaatiyaa naattidan lo"iyaanee!
\q2 Ne gedetuu neeni nas'alaa c'aammaa wotsi de'ishshin be'iyaa wode,
\q2 ayaa lo"iino! Ne sheechchii eranchcha wogaac'ii k'os's'iide,
\q2 loytsi alleek'k'isseeda ink'k'uwaa malatee.
\q1 
\v 2 Ne gul"ay woyniyaa eessay kumeedda birilliyaa malatee;
\q2 ne s'eessaa yuushshuu c'iishshan k'ashetteedda zarggaa mirk'k'iyaa malatee.
\q1 
\v 3 Ne d'antsatuu manttiyaa yeletteedda, gen"ati maratuwaa malatiino.
\q1 
\v 4 Ne k'ood'ii danggarssaa zaaliyaan alleek'k'etteedda adussa gimbbiyaa mala.
\q2 Ne ayifii wolk'k'aama Haseboona katamaa penggiyaa matan de'iyaa,
\q2 zeeruwaa haatsaa malatee.
\q2 Ne siid'ii Damask'k'o s'eelissiide gimbbeedda Liibaanoosa gimbbiyaa malatee.
\q1 
\v 5 Ne huup'ii K'armmeloosa asaa malatee;
\q2 ne olassa binnaanay k'ac'inaa s'aatsaa malatee;
\q2 kaatiyaakka ne huup'iyaa datsay nashechcheedda.
\q1 
\v 6 Ta siik'k'atee, ne ayaa lo"ay! Ne ayaa malanchchatii!
\q2 Ne siik'uu taana ayaa nashechchii!
\s1 Taaninne Neeninne S'alalay
\r (7:7—8:4)
\q1 
\v 7 Ne geesay zambbaa geesaa malatee.
\q2 Ne d'antsay zambbaa ayifiyaa wurc'c'uwaa malatee.
\q1 
\v 8 Taani, Ha zambbaa gi"ana; Aa maratuwaa oyk'k'ana yaagaad.
\q2 Ne d'antsay woyniyaa teeraa wurc'c'uwaa mala;
\q2 k'ay ne siid'iyaanna kesiyaa peenuu appiliyaa ayifiyaadan sawee.
\q1 
\v 9 Ne yeruu mettershshatuwaappenne achchaappe gidduwaana,
\q2 walalattiidde geliyaa woyniyaa mala.
\sp Wodoratta:
\q1 Ubbaappe aad'd'iide mal"iyaa
\q2 woyniyaa eessaa mala yaageedda.
\q1 
\v 10 Taani ta al"o siik'uwaanno; ikka taana amottee.
\q2 
\v 11 Ta siik'ow, haaya; laa"uu katamaappe kesiide biide,
\q2 gas'ariyan ak'oytte; k'ammaa laa"uu hewan aatsana.
\q1 
\v 12 Wontta guuran ane woyniyaa turaa giddo boytte;
\q2 woyniyaa turay c'iisheeddentto, c'iishshiide ayifiyaa dors's'os's'eedenttonne,
\q2 k'ay roomaaniikka ayifeeddentto ane be'oytte.
\q2 Taani ta siik'uwaa neena hewan bessana.
\q1 
\v 13 Inkkoyiyaa ayifiyaa sawuunne hara nashechchiyaa ataakilttiyaa ayifii,
\q2 nu karen besseedda; ta siik'oo!
\q2 Ha ayifetuwaappe teereeddawanttanne ooratsa mas'eeddawantta,
\q2 new ashsha wotsaad.
\c 8
\q1 
\v 1 Ne taw allaga gidennaan ta daayi d'antsaa d'ammeedda ta ishaa gidaarikkiishsha!
\q2 Yaatintto taani neena ogiyaan demmaade shiishsha akka yerina,
\q2 taana ooninne borennashin.
\q1 
\v 2 Taana tamaarisseedda ta daay golle taani neena kaaletsaade,
\q2 ta daayi k'ol"o gelissa aginaa,
\q2 hewan taana ne siik'uwaabaa tamaarisseeddawaa gidaarikkii;
\q2 roomaaniyaa gum"eedda mal"iyaawaa,
\q2 lo"iyaa woyniyaa eessaa taani neena hewan ushshaarikkitaa.
\q1 
\v 3 Taana hewan ne haddirssa k'eesiyaa borkkotissaade,
\q2 ne ushechcha kushiyan taana k'oommeeddawaa gidaarikkii.
\q1 
\v 4 Hinttenoo Yerusaalame wodoratoo,
\q2 Siik'uu bare wodiyaan denddanaw, k'aasetsi dentsetsennaadan,
\q2 ta hinttew hadaraa gay yaagaaddu.
\s1 Siik'uwaa Sabaa
\r (8:5-14)
\sp Yerusaalame Wodorotuu:
\q1 
\v 5 Bare siik'uwaa hashiyaan zemppaade,
\q2 bazzuwaappe yiyaana hanna oonee? yaageeddino.
\sp Wodoratta:
\q1 Beni ne aata neena bannikka yeleedda,
\q2 appiliyaa lank'k'iyaan ne gisa de'ishshin,
\q2 neena ta k'aaseretsaade dentsaad.
\q1 
\v 6 Med'inaa siik'uwaan taana ne wozanaa bolla attama;
\q2 ne k'esiyankka maatafaadan, ta s'alalaa oyk'k'a.
\q2 Ayaw gooppe, siik'uu hayk'k'uwaa mala mina;
\q2 mishuukka duufuwaa mala mek'etsaa iita;
\q2 Aa lac'uukka S'oossaa tamaa lac'uwaa mala.
\q1 
\v 7 Haatsaa daruu siik'uwaa tamaa toyissanaw danddayenna;
\q2 di'uukka meec'c'iide afanaw danddayenna.
\q2 Asay siik'uwaa shammanaw barew de'iyaa ak'uwaa ubbaa immooppekka,
\q2 siik'uu shaluwaan shamettenna diraw,
\q2 asay hewaa kad'ee yaagaaddu.
\sp Wodoratti Ishatuu:
\q1 
\v 8 Nuw tiraan d'antsay uttibeenna michchata de'aw;
\q2 asinay izo oochchooppe, nuuni iw ootsanawe ayee?
\q1 
\v 9 Iza gimbbiyaa dirssaa gidintto, nuuni I bolla wochchiyaa adussa,
\q2 biraa gimbbiyaa gimbbana; Aa dirssaa pengge gidintto,
\q2 zigaa sank'k'aan izo doodissana yaageeddino.
\sp Wodoratta:
\q1 
\v 10 Hekko taani dirssaa gimbbiyaa;
\q2 ta d'antsaykka gimbbiyaa bolla gimbbetteedda wochchiyaa saa;
\q2 hewaa diraw, taani ta siik'uwaanna de'iyaa wode, I taanan nashettee.
\q1 
\v 11 Solomonew Ba'aali-Hamoonan woynnii toketteedda shoyk'ay de'ee;
\q2 he woyniyaa gidduwaa ootsiyaawanttoo keraa immeedda.
\q2 Keraa akkeedawanttu teeran go'etteeddawaa diraw,
\q2 huup'iyaan huup'iyaan sha"u biraa aw ahiino.
\q1 
\v 12 Shin taw ta buzo woynnii toketteedda shoyk'ay de'ee;
\q2 Solomona, neeni sha"u biraa akka;
\q2 ataakilttiyaa ootsiyaawanttu laa"u s'eetu biraa akkino yaagaaddu.
\sp Wodallay:
\q1 
\v 13 Neenoo, ataakilttiyaa giddon de'iyaa ta siik'k'atee,
\q2 ne kooshshaa laggetuwaa sissanaw koyiino;
\q2 ne kooshshaa taana sisa yaageedda.
\sp Wodoratta:
\q1 
\v 14 Ta siik'ow, taakko ellekka haaya!
\q2 Sawiyaa maatay mokkiyaa deretuwaa bollaanna,
\q2 guppiyaa gen"iyaa woy doggiyaa maratuwaa malataade yaagaaddu.
