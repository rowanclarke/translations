\v 8 \w You|strong="H3045"\w* cause \w me|strong="H2451"\w* \w to|strong="H3045"\w* hear joy \w and|strong="H2451"\w* gladness, || \w You|strong="H3045"\w* \w make|strong="H3045"\w* bones \w You|strong="H3045"\w* \w have|strong="H3045"\w* bruised joyful.
