\mi1 Jonam, naio be Eliakim kenerinio
\mi1 
\v 31 Eliakim, naio be Melea kenerinio
\mi1 Melea, naio be Mena kenerinio
\mi1 Mena, naio be M̃atata kenerinio
\mi1 M̃atata, naio be Netan kenerinio
\mi1 Netan, naio be Teviti kenerinio
\mi1 
\v 32 Teviti, naio be Jese kenerinio
\mi1 Jese, naio be Ovete kenerinio
\mi1 Ovete, naio be Boasa kenerinio
\mi1 Boasa, naio be Sala kenerinio
\mi1 Sala, naio be Nesono kenerinio
\mi1 
\v 33 Nesono, naio be Aminatapo kenerinio
\mi1 Aminatapo, naio be Atmin kenerinio
\mi1 Atmin, naio be Ani kenerinio
\mi1 Ani, naio be Esrono kenerinio
\mi1 Esrono, naio be Peres kenerinio
\mi1 Peres, naio be Yuta kenerinio
\mi1 
\v 34 Yuta, naio be Yakovo kenerinio
\mi1 Yakovo, naio be Aisak kenerinio
\mi1 Aisak, naio be Epraamo kenerinio
\mi1 Epraamo, naio be Tera kenerinio
\mi1 Tera, naio be Nao kenerinio
