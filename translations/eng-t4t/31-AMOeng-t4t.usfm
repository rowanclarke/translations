\v 8 \w Yahweh|strong="H3068"\w* \w the|strong="H5002"\w* \w Lord|strong="H3068"\w* \w has|strong="H3068"\w* \w solemnly|strong="H7650"\w* \w declared|strong="H5002"\w* \w this|strong="H3068"\w*:
\q1 “\w I|strong="H5315"\w* \w hate|strong="H8130"\w* \w the|strong="H5002"\w* \w people|strong="H5315"\w* \w of|strong="H3068"\w* Israel \w because|strong="H3068"\w* \w they|strong="H3068"\w* \w are|strong="H3068"\w* very \w proud|strong="H1347"\w*;
\q2 \w I|strong="H5315"\w* \w detest|strong="H8130"\w* \w their|strong="H3068"\w* fortresses.
\q1 \w I|strong="H5315"\w* \w will|strong="H3068"\w* enable \add their enemies\add* \w to|strong="H3068"\w* capture \w their|strong="H3068"\w* \add capital\add* \w city|strong="H5892"\w*
\q2 \w and|strong="H3068"\w* everything \w in|strong="H3068"\w* \w it|strong="H4393"\w*.”
\p 
\v 9 \add When that happens,\add* \w if|strong="H1961"\w* \w there|strong="H1961"\w* \w are|strong="H1004"\w* \w ten|strong="H6235"\w* people \w in|strong="H1004"\w* \w one|strong="H1961"\w* \w house|strong="H1004"\w*, they \w will|strong="H1961"\w* \w all|strong="H4191"\w* \w die|strong="H4191"\w*.
\v 10 \w If|strong="H3588"\w* \w a|strong="H3068"\w* relative \w who|strong="H3068"\w* ◄\w has|strong="H3068"\w* \w the|strong="H3588"\w* task \w of|strong="H1004"\w*/\w is|strong="H3068"\w* \w responsible|strong="H4480"\w* \w for|strong="H3588"\w*► burning \w their|strong="H3068"\w* \w corpses|strong="H4480"\w* \w comes|strong="H3318"\w* \w to|strong="H3318"\w* \w the|strong="H3588"\w* \w house|strong="H1004"\w* \w and|strong="H3068"\w* inquires \w of|strong="H1004"\w* \w anyone|strong="H3588"\w* \w who|strong="H3068"\w* \w is|strong="H3068"\w* \w still|strong="H5750"\w* hiding \w there|strong="H4480"\w*, “\w Is|strong="H3068"\w* \w there|strong="H4480"\w* \w anyone|strong="H3588"\w* \w here|strong="H3318"\w* \w with|strong="H5973"\w* \w you|strong="H3588"\w*?”, \w and|strong="H3068"\w* \w that|strong="H3588"\w* person replies “\w No|strong="H3808"\w*,” \add the one who inquired\add* \w will|strong="H3068"\w* say, “\w Be|strong="H5750"\w* \w quiet|strong="H2013"\w*! \w We|strong="H3588"\w* \w must|strong="H5375"\w* \w not|strong="H3808"\w* \w mention|strong="H2142"\w* \w the|strong="H3588"\w* \w name|strong="H8034"\w* \w of|strong="H1004"\w* \w Yahweh|strong="H3068"\w*, \add lest he cause us also to be killed\add*!”
\b
\q1 
\v 11 \add Terrible things like that will happen\add* \w because|strong="H3588"\w* \w Yahweh|strong="H3068"\w* \w has|strong="H3068"\w* \w commanded|strong="H6680"\w* \w that|strong="H3588"\w* \w large|strong="H1419"\w* \w houses|strong="H1004"\w* \add in Israel\add* must \w be|strong="H3068"\w* \w smashed|strong="H5221"\w* into \w pieces|strong="H7447"\w*,
\q2 \w and|strong="H3068"\w* \w small|strong="H6996"\w* \w houses|strong="H1004"\w* must \w be|strong="H3068"\w* \w smashed|strong="H5221"\w* into tiny bits.
\b
\q1 
\v 12 \w Horses|strong="H5483"\w* \w certainly|strong="H3588"\w* \w do|strong="H2790"\w* \w not|strong="H3588"\w* [RHQ] \w run|strong="H7323"\w* \w on|strong="H7323"\w* big \w rocks|strong="H5553"\w*,
\q2 \w and|strong="H4941"\w* \w certainly|strong="H3588"\w* people \w do|strong="H2790"\w* \w not|strong="H3588"\w* [RHQ] \w plow|strong="H2790"\w* \w the|strong="H3588"\w* sea \w with|strong="H4941"\w* \w oxen|strong="H1241"\w*.
\q1 \w But|strong="H3588"\w* \w you|strong="H3588"\w* \w have|strong="H3588"\w* \add done things that no one should do\add*:
\q1 \w You|strong="H3588"\w* \w have|strong="H3588"\w* distorted \w what|strong="H4941"\w* \w is|strong="H4941"\w* fair/\w right|strong="H4941"\w* \w and|strong="H4941"\w* caused \w it|strong="H3588"\w* \w to|strong="H7323"\w* \w be|strong="H1241"\w* considered \w like|strong="H7323"\w* \w poison|strong="H7219"\w* [MET];
\q2 \w you|strong="H3588"\w* \w have|strong="H3588"\w* \w changed|strong="H2015"\w* \w what|strong="H4941"\w* \w is|strong="H4941"\w* \w right|strong="H4941"\w* \w and|strong="H4941"\w* consider \w it|strong="H3588"\w* \w to|strong="H7323"\w* \w be|strong="H1241"\w* \w like|strong="H7323"\w* things \w that|strong="H3588"\w* \w are|strong="H5483"\w* bitter.
\q1 
\v 13 \w You|strong="H3947"\w* \w are|strong="H1697"\w* proud \w because|strong="H1697"\w* \w you|strong="H3947"\w* \w have|strong="H1697"\w* \w captured|strong="H3947"\w* Lo-Debar \add town\add*,
\q2 \w and|strong="H1697"\w* \w you|strong="H3947"\w* \w have|strong="H1697"\w* \w said|strong="H1697"\w*, “\w We|strong="H1697"\w* \w captured|strong="H3947"\w* Karnaim \w by|strong="H3808"\w* \w our|strong="H3947"\w* own \w power|strong="H2392"\w*!”
\b
\q1 
\v 14 \w But|strong="H3588"\w* \w the|strong="H5002"\w* Commander \w of|strong="H1004"\w* \w the|strong="H5002"\w* \w armies|strong="H6635"\w* \w of|strong="H1004"\w* angels \w declares|strong="H5002"\w*,
\q2 “\w I|strong="H3588"\w* \w will|strong="H3068"\w* cause another \w nation|strong="H1471"\w* \w to|strong="H5704"\w* \w attack|strong="H6965"\w* \w you|strong="H3588"\w* \w people|strong="H1471"\w* [MTY] \w of|strong="H1004"\w* \w Israel|strong="H3478"\w*;
\q1 \w they|strong="H3588"\w* \w will|strong="H3068"\w* ◄\w oppress|strong="H3905"\w* \w you|strong="H3588"\w*/cause \w you|strong="H3588"\w* \w to|strong="H5704"\w* \w suffer|strong="H1004"\w*► \w all|strong="H5704"\w* \w the|strong="H5002"\w* \w way|strong="H5704"\w* \w from|strong="H5921"\w* \w Hamath|strong="H2574"\w* \w Pass|strong="H6965"\w* \add in the northwest\add*
\q2 \w to|strong="H5704"\w* \w the|strong="H5002"\w* Dead Sea \add in the southeast\add*.”
\c 7
\s1 Visions that Yahweh gave to Joel
\p 
\v 1 \w Yahweh|strong="H3068"\w* \w our|strong="H7200"\w* \w God|strong="H3069"\w* \w showed|strong="H7200"\w* \w me|strong="H7200"\w* \add in a vision\add* \w that|strong="H7200"\w* \w he|strong="H3541"\w* \w was|strong="H4428"\w* \w going|strong="H5927"\w* \w to|strong="H5927"\w* \w send|strong="H5927"\w* \w locusts|strong="H1462"\w* \add to destroy our crops\add*. \w It|strong="H7200"\w* \w was|strong="H4428"\w* \w going|strong="H5927"\w* \w to|strong="H5927"\w* happen \w right|strong="H2009"\w* \w after|strong="H5927"\w* \w the|strong="H7200"\w* \w king|strong="H4428"\w*’s share \w of|strong="H4428"\w* \w the|strong="H7200"\w* hay \w had|strong="H4428"\w* \w been|strong="H5927"\w* harvested/cut \w and|strong="H4428"\w* \w before|strong="H7200"\w* \w the|strong="H7200"\w* rest \w of|strong="H4428"\w* \w the|strong="H7200"\w* hay \w was|strong="H4428"\w* ready \w to|strong="H5927"\w* \w be|strong="H4428"\w* harvested.
\v 2 \add And in the vision I saw\add* \w those|strong="H1931"\w* locusts \w come|strong="H1961"\w*, \w and|strong="H6965"\w* \w they|strong="H3588"\w* ate everything \w that|strong="H3588"\w* \w was|strong="H1961"\w* green. \w Then|strong="H1961"\w* \w I|strong="H3588"\w* cried \w out|strong="H6965"\w*, “\w Yahweh|strong="H3068"\w* \w our|strong="H1961"\w* \w Lord|strong="H3069"\w*, \w please|strong="H4994"\w* \w forgive|strong="H5545"\w* \w us|strong="H4994"\w*! \w We|strong="H3588"\w* Israeli \w people|strong="H1931"\w* \w are|strong="H4310"\w* very helpless; ◄\w how|strong="H3588"\w* \w will|strong="H4310"\w* \w we|strong="H3068"\w* \w be|strong="H1961"\w* able \w to|strong="H1961"\w* \w survive|strong="H6965"\w* [RHQ]?/\w we|strong="H3068"\w* \w will|strong="H4310"\w* \w not|strong="H1961"\w* \w be|strong="H1961"\w* able \w to|strong="H1961"\w* \w survive|strong="H6965"\w*!►”
\p 
\v 3 \w So|strong="H1961"\w* \w Yahweh|strong="H3068"\w* \w changed|strong="H5162"\w* \w his|strong="H3068"\w* \w mind|strong="H5162"\w* \w and|strong="H3068"\w* said, “\w That|strong="H3068"\w* \w will|strong="H3068"\w* \w not|strong="H3808"\w* \w happen|strong="H1961"\w*.”
\p 
\v 4 \w Then|strong="H2009"\w* \w this|strong="H3541"\w* \w is|strong="H2009"\w* \w what|strong="H3541"\w* \w Yahweh|strong="H3068"\w* \w our|strong="H7200"\w* \w Lord|strong="H3069"\w* \w showed|strong="H7200"\w* \w me|strong="H7200"\w* \add in another vision\add*: \w He|strong="H7121"\w* \w was|strong="H7227"\w* \w calling|strong="H7121"\w* \w to|strong="H7200"\w* \w a|strong="H3068"\w* fire \w to|strong="H7200"\w* \add come and\add* punish \add his people\add*. \add In the vision I saw that\add* \w the|strong="H7200"\w* fire dried \w up|strong="H7200"\w* \w the|strong="H7200"\w* \w ocean|strong="H8415"\w* \w and|strong="H7200"\w* \w also|strong="H3541"\w* burned \add everything on\add* \w the|strong="H7200"\w* \w land|strong="H2506"\w*.
\v 5 \w Then|strong="H6965"\w* \w I|strong="H3588"\w* cried \w out|strong="H2308"\w* \w again|strong="H6965"\w*, “\w Yahweh|strong="H3068"\w* \w our|strong="H3588"\w* \w Lord|strong="H3069"\w*, \w I|strong="H3588"\w* plead \w with|strong="H6965"\w* \w you|strong="H3588"\w*, \w please|strong="H4994"\w* \w stop|strong="H2308"\w* \w this|strong="H1931"\w*! \w We|strong="H3588"\w* Israeli \w people|strong="H1931"\w* \w are|strong="H4310"\w* very helpless; \w how|strong="H3588"\w* \w will|strong="H4310"\w* \w we|strong="H3068"\w* \w be|strong="H4994"\w* able \w to|strong="H6965"\w* \w survive|strong="H6965"\w* [RHQ]?”
\p 
\v 6 \w So|strong="H1961"\w* \w Yahweh|strong="H3068"\w* \w changed|strong="H5162"\w* \w his|strong="H3068"\w* \w mind|strong="H5162"\w* \w again|strong="H1961"\w*, \w and|strong="H3068"\w* said, “\w That|strong="H1931"\w* \w also|strong="H1571"\w* \w will|strong="H3068"\w* \w not|strong="H3808"\w* \w happen|strong="H1961"\w*.”
\b
\p 
\v 7 \w Then|strong="H2009"\w* \w Yahweh|strong="H3068"\w* \w showed|strong="H7200"\w* \w me|strong="H7200"\w* \add another vision\add*. \w I|strong="H3541"\w* \w saw|strong="H7200"\w* \w him|strong="H5921"\w* \w standing|strong="H5324"\w* \w beside|strong="H5921"\w* \w a|strong="H3068"\w* \w wall|strong="H2346"\w*. \add It was very straight because\add* \w it|strong="H5921"\w* \w had|strong="H3027"\w* been built using \w a|strong="H3068"\w* ◄plumb line/cord \w with|strong="H5921"\w* \w a|strong="H3068"\w* weight \w on|strong="H5921"\w* \w one|strong="H7200"\w* end \w to|strong="H5921"\w* \w determine|strong="H7200"\w* \w if|strong="H2009"\w* \w walls|strong="H2346"\w* \w are|strong="H3027"\w* vertically straight►. \w Yahweh|strong="H3068"\w* \w had|strong="H3027"\w* \w the|strong="H5921"\w* plumb line \w in|strong="H5921"\w* \w his|strong="H5921"\w* \w hand|strong="H3027"\w*.
\v 8 \w Yahweh|strong="H3068"\w* \w asked|strong="H4100"\w* \w me|strong="H7200"\w*, “\w Amos|strong="H5986"\w*, \w what|strong="H4100"\w* \w do|strong="H3068"\w* \w you|strong="H7760"\w* \w see|strong="H7200"\w*?”
\p \w I|strong="H2005"\w* replied, “\w A|strong="H3068"\w* plumb line.”
\p \w Then|strong="H3254"\w* \w Yahweh|strong="H3068"\w* said, “\w Look|strong="H7200"\w*, \w I|strong="H2005"\w* \w am|strong="H3068"\w* \w going|strong="H5674"\w* \w to|strong="H3478"\w* \w use|strong="H5674"\w* \w a|strong="H3068"\w* plumb line \w among|strong="H7130"\w* \w my|strong="H3068"\w* Israeli \w people|strong="H5971"\w*, \add to show that they are like a wall that is not straight\add*. \w I|strong="H2005"\w* \w will|strong="H3068"\w* \w not|strong="H3808"\w* \w change|strong="H7760"\w* \w my|strong="H3068"\w* \w mind|strong="H3808"\w* \w again|strong="H5750"\w* \w about|strong="H5971"\w* punishing \w them|strong="H7760"\w*.
\q1 
\v 9 \w The|strong="H5921"\w* \w places|strong="H1116"\w* \w on|strong="H5921"\w* hills \w where|strong="H5921"\w* \add the descendants of\add* [MTY] \w Isaac|strong="H3446"\w* \w worship|strong="H3478"\w* \add idols\add* \w will|strong="H3478"\w* \w be|strong="H3478"\w* \w destroyed|strong="H2717"\w*.
\q2 \w And|strong="H6965"\w* \w the|strong="H5921"\w* other important \w shrines|strong="H1004"\w* \w in|strong="H5921"\w* \w Israel|strong="H3478"\w* \w will|strong="H3478"\w* \w also|strong="H3478"\w* \w be|strong="H3478"\w* \w destroyed|strong="H2717"\w*.
\q1 \w And|strong="H6965"\w* \w I|strong="H5921"\w* \w will|strong="H3478"\w* enable \add your enemies\add* \w to|strong="H3478"\w* \w attack|strong="H6965"\w* \w your|strong="H5921"\w* people \w with|strong="H1004"\w* \w swords|strong="H2719"\w*
\q2 \w and|strong="H6965"\w* \w they|strong="H5921"\w* \w will|strong="H3478"\w* \w get|strong="H6965"\w* rid \w of|strong="H1004"\w* \add King\add* \w Jeroboam|strong="H3379"\w* \w and|strong="H6965"\w* \w all|strong="H5921"\w* \w his|strong="H5921"\w* descendants.”
\s1 Amaziah criticized Amos
\p 
\v 10 \w Then|strong="H7971"\w* Amaziah, \w the|strong="H3605"\w* \w priest|strong="H3548"\w* \w at|strong="H5921"\w* \w Bethel|strong="H1008"\w*, \w sent|strong="H7971"\w* \add a message\add* \w to|strong="H3478"\w* \w Jeroboam|strong="H3379"\w*, \w the|strong="H3605"\w* \w King|strong="H4428"\w* \w of|strong="H4428"\w* \w Israel|strong="H3478"\w*. \w In|strong="H5921"\w* \w the|strong="H3605"\w* \w message|strong="H1697"\w* \w he|strong="H3605"\w* \w said|strong="H1697"\w*, “\w Amos|strong="H5986"\w* \w is|strong="H1697"\w* plotting \w against|strong="H5921"\w* \w you|strong="H3605"\w* \w among|strong="H7130"\w* \w the|strong="H3605"\w* Israeli \w people|strong="H3808"\w* [MTY]. \add I am worried that\add* \w the|strong="H3605"\w* \w people|strong="H3808"\w* \w of|strong="H4428"\w* \w this|strong="H1697"\w* country \w will|strong="H4428"\w* \w not|strong="H3808"\w* \w be|strong="H3808"\w* \w able|strong="H3201"\w* \w to|strong="H3478"\w* refute \w his|strong="H3605"\w* \w words|strong="H1697"\w*.
\v 11 \w This|strong="H3541"\w* \w is|strong="H3478"\w* \w what|strong="H3541"\w* \w he|strong="H3588"\w* \w is|strong="H3478"\w* saying:
\q1 ‘\w Jeroboam|strong="H3379"\w* \w will|strong="H3478"\w* \w soon|strong="H3588"\w* \w be|strong="H4191"\w* \w killed|strong="H4191"\w* \w by|strong="H5921"\w* \add someone using\add* \w a|strong="H3068"\w* \w sword|strong="H2719"\w*,
\q2 \w and|strong="H3478"\w* \w the|strong="H5921"\w* people \w of|strong="H5921"\w* \w Israel|strong="H3478"\w* \w will|strong="H3478"\w* \w be|strong="H4191"\w* ◄\w exiled|strong="H1540"\w*/forced \w to|strong="H3478"\w* leave \w their|strong="H5921"\w* land \w and|strong="H3478"\w* \w go|strong="H1540"\w* \w to|strong="H3478"\w* another country►.’”
\b
\p 
\v 12 \w Then|strong="H3063"\w* Amaziah \add came to me and\add* said, “\w You|strong="H3212"\w* \w prophet|strong="H2374"\w*, \w get|strong="H3212"\w* \w out|strong="H3212"\w* \w of|strong="H3899"\w* \w here|strong="H8033"\w*! \w Go|strong="H3212"\w* \w back|strong="H3212"\w* \w to|strong="H3212"\w* \w the|strong="H8033"\w* country \w of|strong="H3899"\w* \w Judah|strong="H3063"\w*! Earn money \w to|strong="H3212"\w* \add buy food to be able\add* \w to|strong="H3212"\w* live \w there|strong="H8033"\w*, \w and|strong="H3063"\w* \w do|strong="H3063"\w* \w your|strong="H8033"\w* \w prophesying|strong="H5012"\w* \w there|strong="H8033"\w*!
\v 13 \w Do|strong="H3254"\w* \w not|strong="H3808"\w* \w prophesy|strong="H5012"\w* \w any|strong="H5750"\w* \w more|strong="H3254"\w* here \w at|strong="H1004"\w* \w Bethel|strong="H1008"\w*, \w because|strong="H3588"\w* \w this|strong="H1931"\w* \w is|strong="H1931"\w* \w where|strong="H1004"\w* \w the|strong="H3588"\w* national \w temple|strong="H1004"\w*, \w the|strong="H3588"\w* \w king|strong="H4428"\w*’s \w temple|strong="H1004"\w*, \w is|strong="H1931"\w*!”
\p 
\v 14 \w I|strong="H3588"\w* \w replied|strong="H6030"\w* \w to|strong="H1121"\w* Amaziah, “\w I|strong="H3588"\w* \w was|strong="H1121"\w* \add previously\add* \w not|strong="H3808"\w* \w a|strong="H3068"\w* \w prophet|strong="H5030"\w*, \w and|strong="H1121"\w* \w my|strong="H3588"\w* \w father|strong="H1121"\w* \w was|strong="H1121"\w* \w not|strong="H3808"\w* \w a|strong="H3068"\w* \w prophet|strong="H5030"\w*; \w I|strong="H3588"\w* \w was|strong="H1121"\w* \w a|strong="H3068"\w* shepherd. \w I|strong="H3588"\w* \w also|strong="H1121"\w* \w took|strong="H5030"\w* care \w of|strong="H1121"\w* sycamore-fig \w trees|strong="H8256"\w*.
\v 15 \w But|strong="H3947"\w* \w Yahweh|strong="H3068"\w* \w took|strong="H3947"\w* \w me|strong="H3947"\w* \w away|strong="H3947"\w* \w from|strong="H3478"\w* \w taking|strong="H3947"\w* care \w of|strong="H3068"\w* \w my|strong="H3068"\w* \w sheep|strong="H6629"\w*, \w and|strong="H3478"\w* \w he|strong="H3068"\w* said \w to|strong="H3478"\w* \w me|strong="H3947"\w*, ‘\w Go|strong="H3212"\w* \w to|strong="H3478"\w* \w Israel|strong="H3478"\w* \w and|strong="H3478"\w* \w prophesy|strong="H5012"\w* \w to|strong="H3478"\w* \w my|strong="H3068"\w* \w people|strong="H5971"\w* \w there|strong="H3068"\w*!’
\q1 
\v 16 \w You|strong="H5921"\w* \w said|strong="H1697"\w* \w to|strong="H3478"\w* \w me|strong="H5921"\w*, ‘\w Do|strong="H3068"\w* \w not|strong="H3808"\w* prophecy \w saying|strong="H1697"\w* terrible \w things|strong="H1697"\w* \w will|strong="H3068"\w* \w happen|strong="H1697"\w* \w to|strong="H3478"\w* \add the people of\add* \w Israel|strong="H3478"\w*;
\q2 \w stop|strong="H3808"\w* \w saying|strong="H1697"\w* \w those|strong="H8085"\w* \w things|strong="H1697"\w*!’
\p 
\v 17 \w Therefore|strong="H3651"\w* listen \w to|strong="H3478"\w* \w what|strong="H3541"\w* \w Yahweh|strong="H3068"\w* \w says|strong="H3541"\w* \w about|strong="H5921"\w* \w you|strong="H5921"\w*:
\q1 ‘\w Your|strong="H3068"\w* wife \w will|strong="H3068"\w* \w become|strong="H2181"\w* \w a|strong="H3068"\w* \w prostitute|strong="H2181"\w* \w in|strong="H5921"\w* \w this|strong="H3651"\w* \w city|strong="H5892"\w*,
\q2 \w and|strong="H1121"\w* \w your|strong="H3068"\w* \w sons|strong="H1121"\w* \w and|strong="H1121"\w* \w daughters|strong="H1323"\w* \w will|strong="H3068"\w* \w be|strong="H4191"\w* \w killed|strong="H4191"\w* \w by|strong="H5921"\w* \add your enemies’\add* \w swords|strong="H2719"\w*.
