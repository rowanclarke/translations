\p
\v 33 Jacob looked \w at|strong="H1121"\w* \w the|strong="H1121"\w* \w coat|strong="H3801"\w*, \w and|strong="H1121"\w* \w he|strong="H3130"\w* \w knew|strong="H5234"\w* \w that|strong="H2416"\w* \w it|strong="H5234"\w* belonged \w to|strong="H1121"\w* \w Joseph|strong="H3130"\w*. So \w he|strong="H3130"\w* said, “Yes, \w that|strong="H2416"\w* \w is|strong="H7451"\w* \w my|strong="H2963"\w* \w son|strong="H1121"\w*’s \w coat|strong="H3801"\w*.” \w And|strong="H1121"\w* Jacob saw \w the|strong="H1121"\w* blood \w on|strong="H7451"\w* \w that|strong="H2416"\w* \w coat|strong="H3801"\w*, so \w he|strong="H3130"\w* said, “\w I|strong="H1121"\w* \w know|strong="H5234"\w* \w what|strong="H7451"\w* happened. \w A|strong="H3068"\w* \w wild|strong="H7451"\w* \w animal|strong="H2416"\w* ate \w Joseph|strong="H3130"\w*. Yes, \w that|strong="H2416"\w* \w animal|strong="H2416"\w* \w tore|strong="H2963"\w* \w him|strong="H5234"\w* \w into|strong="H3130"\w* little bits.”\fig Jacob thought Joseph died, so he was really sad|src="ai jo 6 a jacob sad.jpg" size="col" copy="Maryanne Cameron. (I need to check if this is copyright Bible Society Australia.)" ref="37:33" \fig*   
\p
\v 34 \w So|strong="H7760"\w* \w Jacob|strong="H3290"\w* \w was|strong="H3117"\w* \w really|strong="H7760"\w* sad, \w because|strong="H5921"\w* \w he|strong="H3117"\w* \w thought|strong="H7760"\w* \w that|strong="H3117"\w* Joseph \w was|strong="H3117"\w* \w dead|strong="H7227"\w*. \w He|strong="H3117"\w* \w was|strong="H3117"\w* \w so|strong="H7760"\w* sad \w that|strong="H3117"\w* \w he|strong="H3117"\w* \w tore|strong="H7167"\w* \w his|strong="H7760"\w* \w clothes|strong="H8071"\w*. \w Then|strong="H7760"\w* \w he|strong="H3117"\w* \w put|strong="H7760"\w* \w on|strong="H5921"\w* \w some|strong="H7227"\w* \w clothes|strong="H8071"\w* \w made|strong="H7760"\w* \w out|strong="H5921"\w* \w of|strong="H1121"\w* \w a|strong="H3068"\w* rough \w cloth|strong="H8071"\w*, \w called|strong="H7760"\w* sack-cloth, \w and|strong="H1121"\w* \w he|strong="H3117"\w* cried. \w You|strong="H5921"\w* see, \w in|strong="H5921"\w* \w that|strong="H3117"\w* culture, \w people|strong="H1121"\w* sometimes \w tore|strong="H7167"\w* \w their|strong="H7760"\w* \w clothes|strong="H8071"\w* \w and|strong="H1121"\w* \w wore|strong="H5921"\w* sack-cloth \w to|strong="H5921"\w* \w show|strong="H7760"\w* \w that|strong="H3117"\w* \w they|strong="H3117"\w* \w were|strong="H1121"\w* sad.  
\p \w Jacob|strong="H3290"\w* cried \w like|strong="H1121"\w* \w that|strong="H3117"\w* \w for|strong="H5921"\w* lots \w of|strong="H1121"\w* \w days|strong="H3117"\w*.  
\v 35 \w All|strong="H3605"\w* \w of|strong="H1121"\w* Jacob’s \w sons|strong="H1121"\w* \w and|strong="H1121"\w* \w daughters|strong="H1323"\w*, \w they|strong="H3588"\w* talked \w to|strong="H3381"\w* Jacob, \w and|strong="H1121"\w* \w they|strong="H3588"\w* tried \w to|strong="H3381"\w* \w help|strong="H1323"\w* \w him|strong="H3381"\w* feel happy \w again|strong="H6965"\w*. \w But|strong="H3588"\w* Jacob said, “\w No|strong="H3605"\w*, \w I|strong="H3588"\w* \w can|strong="H1121"\w*’t \w be|strong="H1121"\w* happy \w again|strong="H6965"\w*. \w I|strong="H3588"\w* \w will|strong="H1121"\w* keep \w on|strong="H3381"\w* \w crying|strong="H1058"\w* \w for|strong="H3588"\w* \w my|strong="H3605"\w* \w son|strong="H1121"\w*, \w until|strong="H3588"\w* \w I|strong="H3588"\w* \w die|strong="H1121"\w* \w and|strong="H1121"\w* \w go|strong="H3381"\w* \w to|strong="H3381"\w* \w join|strong="H3381"\w* \w him|strong="H3381"\w*.” \w And|strong="H1121"\w* Jacob \w cried|strong="H1058"\w* \w a|strong="H3068"\w* lot \w for|strong="H3588"\w* Joseph.   
\p
\v 36 But Joseph wasn’t really dead. \w That|strong="H6547"\w* Midian mob, they \w took|strong="H2876"\w* Joseph \w to|strong="H4714"\w* \w Egypt|strong="H4714"\w* country, \w and|strong="H4714"\w* they \w sold|strong="H4376"\w* him \w to|strong="H4714"\w* \w a|strong="H3068"\w* man called Potifar. \w That|strong="H6547"\w* man Potifar, he worked \w for|strong="H4714"\w* \w the|strong="H4376"\w* big boss \w of|strong="H8269"\w* \w Egypt|strong="H4714"\w*, called \w Pharaoh|strong="H6547"\w*. Potifar \w was|strong="H6547"\w* \w in|strong="H4714"\w* \w charge|strong="H8269"\w* \w of|strong="H8269"\w* \w all|strong="H4376"\w* \w the|strong="H4376"\w* soldiers \w that|strong="H6547"\w* guarded \w Pharaoh|strong="H6547"\w*’s house.   
\c 38  
\s1 The story about Judah’s sons  
\p
\v 1 \w This|strong="H1931"\w* story \w is|strong="H1931"\w* \w about|strong="H1961"\w* something \w that|strong="H1931"\w* Jacob’s son \w Judah|strong="H3063"\w* \w did|strong="H3063"\w*.  
\p \w Judah|strong="H3063"\w* \w left|strong="H1961"\w* \w his|strong="H5186"\w* brothers, \w and|strong="H3063"\w* \w he|strong="H1931"\w* \w went|strong="H3381"\w* \w to|strong="H5704"\w* stay \w with|strong="H3381"\w* \w a|strong="H3068"\w* man \w from|strong="H3381"\w* \w the|strong="H5704"\w* town \w called|strong="H8034"\w* Adullam. \w That|strong="H1931"\w* man’s \w name|strong="H8034"\w* \w was|strong="H8034"\w* \w Hirah|strong="H2437"\w*.  
\v 2 \w While|strong="H7200"\w* \w Judah|strong="H3063"\w* \w was|strong="H8034"\w* \w staying|strong="H8033"\w* \w in|strong="H8034"\w* \w that|strong="H7200"\w* \w place|strong="H8033"\w*, \w he|strong="H8033"\w* \w saw|strong="H7200"\w* \w a|strong="H3068"\w* young \w woman|strong="H1323"\w*. \w That|strong="H7200"\w* \w woman|strong="H1323"\w*’s father \w was|strong="H8034"\w* \w called|strong="H8034"\w* \w Shua|strong="H7770"\w*, \w and|strong="H3063"\w* \w he|strong="H8033"\w* \w was|strong="H8034"\w* \w from|strong="H3947"\w* \w the|strong="H7200"\w* \w Canaan|strong="H3669"\w* tribe. \w Judah|strong="H3063"\w* \w married|strong="H3947"\w* \w that|strong="H7200"\w* young \w woman|strong="H1323"\w*, \w and|strong="H3063"\w* \w he|strong="H8033"\w* slept \w with|strong="H3947"\w* \w her|strong="H3947"\w*.  
\v 3 \w Then|strong="H7121"\w* \w that|strong="H7121"\w* \w woman|strong="H3205"\w* \w had|strong="H3205"\w* \w a|strong="H3068"\w* \w baby|strong="H1121"\w* boy, \w and|strong="H1121"\w* Judah \w named|strong="H7121"\w* \w him|strong="H3205"\w* \em Er\em*.  
\v 4 Later, \w that|strong="H7121"\w* \w woman|strong="H3205"\w* \w had|strong="H3205"\w* \w another|strong="H5750"\w* \w baby|strong="H1121"\w* boy, \w and|strong="H1121"\w* \w she|strong="H7121"\w* \w named|strong="H7121"\w* \w him|strong="H3205"\w* \em Onan\em*.  
\v 5 \w And|strong="H1121"\w* \w later|strong="H1961"\w*, \w she|strong="H7121"\w* \w had|strong="H1961"\w* \w another|strong="H5750"\w* \w baby|strong="H1121"\w* boy \w too|strong="H5750"\w*. \w She|strong="H7121"\w* \w named|strong="H7121"\w* \w that|strong="H7121"\w* \w baby|strong="H1121"\w* \em Shelah\em*. \w At|strong="H1961"\w* \w that|strong="H7121"\w* \w time|strong="H5750"\w*, Judah \w was|strong="H8034"\w* staying \w in|strong="H1121"\w* \w the|strong="H3205"\w* town \w called|strong="H7121"\w* Kezib.   
\p
