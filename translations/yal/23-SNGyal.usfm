\id SNG
\h Marafanna Falane Sora
\toc1 Muluku Sulemani Fala Ɲaxumɛn Naxanye Sɛbɛ
\toc2 Marafanna Falane
\mt1 Marafanna Falane
\mt2 Muluku Sulemani Fala Ɲaxumɛn Naxanye Sɛbɛ
\ip Xɛmɛn nun a ɲaxanla e bode xanuma kii naxan yi, Ala nan na feen nagidixi adamadiine ma. Na feen sɛbɛxi Dunuɲa Fɔlɔn sora 2.23-25 kui. Xanuntenya sigine nun fala ɲaxumɛne nan sɛbɛxi Kitabun yireni ito yi lan xɛmɛn nun a ɲaxanla marafanna fe ma. Yanyina nde, Muluku Sulemani nun a ɲaxanla nan falani itoe sɛbɛxi e bode ma.
\ip Kitabun yireni ito kui, xɛmɛn nun ɲaxanla marafanna falane nan tima e bode tagi. Yirena ndee, e bode fenma, e yi e bode to, e lɔ ayi e bode ma, e lu e bode fenɲɛ fala ɲaxumɛne yi. Muxu gbɛtɛne falane fan sɛbɛxi alogo falan xa ɲaxun.
\ip Muxuna ndee bata Kitabun yireni ito xaran misaala ra, wundo falan naxan xanuntenyana fe yɛbama lan Ala nun a yamaan tagin ma.
\c 1
\p 
\v 1 Sulemani a sigi fisamantenna.
\s1 Xanuntenyana
\sp Ɲaxanla falana a xɛmɛn xa:
\q1 
\v 2 N sunbu marafan sunbuni!
\q1 Amasɔtɔ i ya xanuntenyaan ɲaxun dangu manpaan na.
\q1 
\v 3 I ya latikɔnɔnna xirin ɲaxun.
\q1 I xinla luxi nɛn
\q1 alo latikɔnɔnna naxan xiri sigama ayi.
\q1 Nanara, i rafan sungutunne ma.
\q1 
\v 4 N suxu n yiin ma!
\q1 En na en gi!
\q1 Mangan bata n xali a konni.
\q1 Nxu ɲaxanma,
\q1 nxu sɛwa i ya fe ra,
\q1 nxu i ya xanuntenyaan matɔxɔma nɛn dangu manpaan na.
\q1 Yoon sungutunne xa,
\q1 i rafan e ma!
\q1 
\v 5 Yerusalɛn sungutunne,
\q1 n fatin nan gbeelixi,
\q1 koni n nayabu
\q1 alo Kedari kaane bubu fɔrɛne,
\q1 alo Sulemani a dugin naxanye singanxi a banxini.
\q1 
\v 6 Koni, i nama n mato,
\q1 n to gbeelixi.
\q1 Sogen nan n fatin gbeelixi.
\q1 Ngaa dii xɛmɛne nan xɔlɔxi n ma,
\q1 e yi n findi manpa bili nakɔ kantanna ra.
\q1 Koni n mi n yengi luxi n yɛtɛna nakɔɔn xɔn.
\q1 
\v 7 A fala n xa,
\q1 i tan naxan nafan n ma n bɔɲɛni,
\q1 i fa i ya xuruse kurun nabama dɛnaxan yi,
\q1 hanma i e luma dɛnaxan yi yanyi tagini
\q1 alogo n nama lu i fenɲɛ na xun xɔn
\q1 alo ɲaxalan kobina
\q1 i xɔyine xuruse kurune dɛnaxan yi.
\b
\sp Xɔyine falana:
\q1 
\v 8 Xa i mi na kolon,
\q1 i tan naxan tofan ɲaxanle birin xa,
\q1 siga i ya sii diine rabɛ yɛxɛɛ kurune funfun xɔn,
\q1 xuruse kantanne bubune dɛxɔn.
\b
\sp Xɛmɛna falana a ɲaxanla xa:
\q1 
\v 9 N nafan ɲaxanla,
\q1 i luxi nɛn n yɛɛ ra yi
\q1 alo soo gilɛ faɲin naxanye Misiran mangana yɛngɛ so wontoron bandunma.
\q1 
\v 10 I xadene rayabu tunlasone longonna ra,
\q1 i kɔɛɛn nayabu ɲɛrɛni.
\q1 
\v 11 En tunlaso xɛma daxine rafalama nɛn i xa,
\q1 naxanye rayabuxi gbeti wuredine ra.
\b
\sp Ɲaxanla falana a xɛmɛn xa:
\q1 
\v 12 Mangan yi a dɛgema waxatin naxan yi,
\q1 n ma latikɔnɔnna xiri faɲin yi sigama a ma.
\q1 
\v 13 N nafan muxun luxi nɛn n xa
\q1 alo mirihi latikɔnɔnna se sa seen kui
\q1 naxan singanxi n xiɲɛ longonna ra.
\q1 
\v 14 N nafan muxun luxi n xa nɛn
\q1 alo se fuge faɲine
\q1 keli manpa bili nakɔne yi En-Gedi yamanani.
\b
\sp Xɛmɛna falana a ɲaxanla xa:
\q1 
\v 15 I rayabu, n nafan ɲaxanla,
\q1 i rayabu han!
\q1 I yɛɛne rayabu alo ganbane.
\b
\sp Ɲaxanla falana a xɛmɛn xa:
\q1 
\v 16 N xanuntenna, i tofan,
\q1 i rayabu han!
\q1 En saden findixi sɛxɛ xindene nan na.
\q1 
\v 17 Suman yiine nan en xunna soon na,
\q1 fɔfɔ binle yi findi banxi kankene ra en xa.
\c 2
\s1 Xɛmɛn nun ɲaxanla tofanna
\sp Ɲaxanla falana a xɛmɛn xa:
\q1 
\v 1 N luxi nɛn
\q1 alo se fuge faɲin naxanye Sarɔn yamanani,
\q1 gabala fugene mɛrɛmɛrɛne yi.
\b
\sp Xɛmɛna falana a ɲaxanla xa:
\q1 
\v 2 N nafan ɲaxanla luxi sungutunne tagi nɛn
\q1 alo gabala fugen sɛxɛ ɲali kanne tagi.
\b
\sp Ɲaxanla falana a xɛmɛn xa:
\q1 
\v 3 N nafan xɛmɛn luxi banxulanne tagi nɛn
\q1 alo mangon binla fɔtɔn yi wudine tagi.
\q1 A rafan n ma n dɔxɔ a nininna ra,
\q1 a rafan n ma
\q1 alo wudi bogi ɲaxumɛna n dɛ.
\q1 
\v 4 A bata n xali sumun yireni.
\q1 A xanuntenyaan luxi nɛn n xa
\q1 alo taxamasenna.
\q1 
\v 5 Ɛ n sɛnbɛ so se bogine ra,
\q1 ɛ yi n bɔɲɛn maxunbeli mangon bogine ra,
\q1 bayo xanuntenyaan furena n ma.
\q1 
\v 6 A kɔmɛn ma yiina n xunna bun,
\q1 a yi a yiifanna rabilin n ma.
\q1 
\v 7 Yerusalɛn sungutunne,
\q1 n bata ɛ rakɔlɔ bolene nun burunna xɛnle yi,
\q1 ɛ nama xanuntenyaan nakeli,
\q1 ɛ nama a raxulun,
\q1 benun a waxatin xa a li.
\q1 
\v 8 N bata n xanuntenna xuiin mɛ!
\q1 A fama tuganɲɛ ayi geyane xun tagi,
\q1 a a gima yire matexine xun tagi.
\q1 
\v 9 N xanuntenna a gima
\q1 alo bolena hanma xɛli sɛnbɛmana.
\q1 A mato,
\q1 a tixi en konna sansanna xanbi ra.
\q1 A yɛɛn nasoma banxin foyesoden na,
\q1 a yɛɛ masama wure sansanna yinle ra.
\q1 
\v 10 N xanuntenna falan tima n xa, a naxa,
\q1 “Keli, n xanunten tofaɲina, fa en siga!
\q1 
\v 11 Bayo ɲɛmɛn ɲanmatɔɔn ni i ra,
\q1 tulen bata ɲan, a bata siga.
\q1 
\v 12 Se fuge faɲine bata wara ayi bɔxɔni,
\q1 sigi sa waxatin bata a li,
\q1 kolokondene xuiin minima burunna ra.
\q1 
\v 13 Xɔdɛ binla bata a bogi singene ramini fɔlɔ,
\q1 manpa binle\f + \fr 2.13 \ft Wudi binla nde na yi, mɛn kaane naxanye sima, e yi naxanye bogi yitɔnma alo manpana e gbee kiini.\f* bata fuga,
\q1 e xiri faɲin naminima.
\q1 N xanuntenna, keli, fa en siga.”
\b
\sp Xɛmɛna falana a ɲaxanla xa:
\q1 
\v 14 N ma ɲaxanla,
\q1 i nama i luxun
\q1 alo ganbana gɛmɛ yinle ra geyaan kanke.
\q1 I yɛtagin yita n na,
\q1 i xuiin namini n xa a mɛ,
\q1 amasɔtɔ i xuiin ɲaxun, i tofan.
\b
\sp Xɛmɛna falana a muxune xa
\q1 
\v 15 Ɛ xulumaseene suxu nxu xa,
\q1 xulumase xurin naxanye nxɔ manpa bili fugaxine kalama.
\b
\sp Ɲaxanla falana a xɛmɛn xa:
\q1 
\v 16 N gbeen nan n xanuntenna ra,
\q1 a fan gbeen nan n na,
\q1 a nɛma a xuruseene rabama sansi fugaxine tagi.
\q1 
\v 17 N xanuntenna,
\q1 benun kuye xa yiba,
\q1 dimin yi siga, xɛtɛ,
\q1 i i gi alo bolena
\q1 alo xɛli sɛnbɛmaan gɛmɛ geyane fari.
\c 3
\s1 Ɲaxanla xiye sana a xɛmɛn fen feen na
\q1 
\v 1 N nɛma saxi n ma saden ma kɔɛɛn na,
\q1 n kataxi n xanuntenna to feen na,
\q1 n na a fenma, koni n mi a toma.
\q1 
\v 2 Nayi, n kelima nɛn,
\q1 n yi taan nabilin,
\q1 n yi siga taan yama malandene nun kirane xɔn,
\q1 n yi n bɔɲɛn nafan muxun fen.
\q1 N na a fenma, koni n mi a toma.
\q1 
\v 3 Taan kantan muxune yi fa n li,
\q1 n yi e maxɔdin, n naxa,
\q1 “Ɛ mi n bɔɲɛn nafan muxun toxi ba?”
\q1 
\v 4 N dangu e ra nɛn tun,
\q1 n yi n bɔɲɛn nafan muxun to,
\q1 n yi a suxu,
\q1 n mi fa a beɲin sɔnɔn,
\q1 han n yi sa a raso ngaa banxini,
\q1 nga fudi tongo n na dɛnaxan yi.
\q1 
\v 5 Yerusalɛn sungutunne,
\q1 n bata ɛ rakɔlɔ bolene nun burunna xɛnle yi,
\q1 ɛ nama xanuntenyaan nakeli,
\q1 ɛ nama a raxulun,
\q1 benun a waxatin xa a li.
\q1 
\v 6 Nde ito ra naxan kelima tonbonni,
\q1 naxan tema alo tutina,
\q1 alo mirihi nun wusulanna xirina,
\q1 e nun latikɔnɔnna xiri ɲaxumɛn sifan birin?
\q1 
\v 7 Sulemani maxali saden nan a ra,
\q1 sofa tonge sennin a rabilinxi,
\q1 Isirayila sofa kɛndɛne nan e birin na.
\q1 
\v 8 Silanfanna e birin yii\f + \fr 3.8\fk Silanfanna:\ft Sofane yɛngɛso dɛgɛmana.\f*
\q1 e birin darixi yɛngɛn na.
\q1 Silanfanna xidixi e birin tagi,
\q1 alogo e xa makantanna ti kɔɛɛn na.
\q1 
\v 9 Manga Sulemani a saden nafalaxi Liban yamanan wudine nan na.
\q1 
\v 10 A bun tiine rafalaxi wure gbetin nan na,
\q1 xɛmaan nan a bundɔxɔn na.
\q1 Yerusalɛn sungutunne a dɔxɔ seen nafalaxi
\q1 dugi mamiloxin nan na xanuntenyani.
\q1 
\v 11 Ɛ mini, Siyon taan sungutunne,
\q1 ɛ Manga Sulemani nun a manga kɔmɔtin mato
\q1 a nga naxan soxi a xun na a ɲaxalandin mati lɔxɔni,
\q1 a bɔɲɛn sɛwa lɔxɔna.
\c 4
\s1 Xɛmɛna ɲaxanla luxi nɛn alo a nakɔ yirena
\sp Xɛmɛna falana a ɲaxanla xa:
\q1 
\v 1 I rayabu,
\q1 n nafan ɲaxanla, i rayabu.
\q1 I yɛɛne rayabu alo ganbane
\q1 hali dugin soxi i yɛtagin xun na.
\q1 I xun sɛxɛn saxi a ma
\q1 alo sii kurun nɛma godɛ Galadi geyaan ma.
\q1 
\v 2 I ɲinne fixa alo yɛxɛɛ kurun
\q1 naxan xabe baxi maxabadeni
\q1 naxanye kelima e maxadeni.\f + \fr 4.2\ft Mɛn kaane yɛxɛɛne \fk xaben\ft gbo nɛn han! A nɔɛ findɛ dugin na.\f*
\q1 E lanxi e boden ma firin firin yɛɛn ma
\q1 alo gulunne, e keden pe mi baxi.
\q1 
\v 3 I dɛ kidine luxi alo luti gbeela,
\q1 i dɛɛn tofan han!
\q1 I xaden nayabu
\q1 alo girenada wudi bogini xabaxina a tagi
\q1 hali dugin bata so i yɛtagin xun na.
\q1 
\v 4 I kɔɛɛn maxidixi
\q1 alo Dawudaa sangansona,
\q1 sofane yɛngɛ so wure lefa wuli kedenna singanxi naxan na
\q1 alo ɲɛrɛna i kɔɛ ra.
\q1 
\v 5 I xiɲɛ firinne rayabu
\q1 alo bolen dii gulun firinne,
\q1 naxanye e dɛgema sansi fugaxine tagi.
\q1 
\v 6 N sigama nɛn na mirihi latikɔnɔnna nun wusulanna yireni
\q1 han kuye yiba, dimin yi siga.
\q1 
\v 7 N xanuntenna, i rayabu,
\q1 fɛ yo mi i ra.
\q1 
\v 8 N ma ɲaxalandi masuxina,
\q1 fa n fɔxɔ ra
\q1 keli Liban yamanani Amana geyaan xuntagi,
\q1 Xerimon geyaan nun Seniri geyaan xuntagi,
\q1 yatane xiin dɛnaxan yi,
\q1 burunna ɲarine geyane.
\q1 
\v 9 I n bɔɲɛn nadinma,
\q1 i tan sungutunna,
\q1 n ma ɲaxalan masuxina,
\q1 i na i yɛɛn ti n na keden pe
\q1 i n bɔɲɛn nadinma nɛn.
\q1 Hali i ya ɲɛrɛn xɔri keden pe,
\q1 a na ligɛ n na.
\q1 
\v 10 I ya xanuntenyaan ɲaxun,
\q1 i tan sungutunna,
\q1 n ma ɲaxalan masuxina,
\q1 i ya xanuntenyaan ɲaxun
\q1 dangu manpa faɲin na,
\q1 i ya latikɔnɔnna xirin ɲaxun
\q1 dangu se xiri ɲaxumɛne birin na.
\q1 
\v 11 N ma ɲaxalan masuxina,
\q1 i dɛɛn ɲaxun alo kumina,
\q1 nɔnɔn nun kumin nan i lɛnna bun,
\q1 i ya dugine xirin luxi nɛn
\q1 alo Liban wudi xiri ɲaxumɛne.
\q1 
\v 12 I tan sungutunna,
\q1 n ma ɲaxalan masuxina,
\q1 i luxi nɛn alo n ma nakɔ masansanxina,
\q1 n ma tigina,
\q1 n ma ige miniden naxan namaraxi n keden peen xa.
\q1 
\v 13 I fan
\q1 alo sansi faɲin sixi nakɔɔn naxan yi,
\q1 alo girenada binla
\q1 naxanye bogi faɲine raminima,
\q1 e nun henna binle
\q1 nun naradi sansi xiri faɲina,
\q1 
\v 14 naradin nun sansi fuge nɛri fuɲiramaan
\q1 nun gbala xiri ɲaxumɛne
\q1 nun sinamon wudi xiri ɲaxumɛne,
\q1 e nun wusulanna kelixi wudin naxanye birin ma
\q1 e nun mirihi latikɔnɔnna nun wudi ige xiri ɲaxumɛne
\q1 nun sansi xiri ɲaxumɛ faɲine birin.
\q1 
\v 15 I luxi nɛn alo nakɔ yi tigina,
\q1 alo xude xunna naxan godoma
\q1 keli Liban geyane ma.
\b
\sp Ɲaxanla falana a xɛmɛn xa:
\q1 
\v 16 Foye faɲin xa fa
\q1 sa keli kɔmɛnna nun yiifanna ma,
\q1 e yi n ma nakɔɔn xiri faɲin nasiga ayi
\q1 alogo n nafan muxun xa fa so a nakɔni,
\q1 a yi a bogise faɲine don!
\c 5
\s1 Xɛmɛna tofanna
\sp Xɛmɛna falana a ɲaxanla xa:
\q1 
\v 1 N fama n ma nakɔni,
\q1 i tan sungutunna,
\q1 n ma ɲaxalan masuxina,
\q1 n xa sa n ma mirihi latikɔnɔnna nun wusulanna ba,
\q1 n yi n ma kumi dɛngbɛn nun kumin don,
\q1 n yi n ma manpaan nun n ma nɔnɔn min.
\b
\sp Xɔyine falana:
\q1 Nxu xɔyine, ɛ min,
\q1 ɛ xunne xa magi a ra xanuntenyani.
\b
\sp Ɲaxanla xiyen naxan saxi lan a xɛmɛn ma:
\q1 
\v 2 N bata yi xi,
\q1 koni n bɔɲɛn mi yi xima.
\q1 N yi n xanuntenna xuiin nan mɛma dɛɛn na.
\b
\sp Xɛmɛna falana a ɲaxanla xa:
\q1 Dɛɛn nabi n xa, i tan sungutunna,
\q1 n ma ɲaxalandi masuxina,
\q1 n ma ganbadina,
\q1 fɛ mi ɲaxanla naxan na.
\q1 Xiila bata n xunni kun
\q1 n xun sɛxɛn bata yikun kɔɛ ra kundaan bun.
\b
\sp Ɲaxanla falana a xɛmɛn xa:
\q1 
\v 3 N bata n ma domaan ba n ma,
\q1 n fa a ragodoma n ma di?
\q1 N baxi n sanne maxadeni nɛn,
\q1 n fa e malɔxɔma di?
\q1 
\v 4 N xanuntenna bata a yiin naso dɛɛn yalenna ra,
\q1 n fatin yi xuruxurun.
\q1 
\v 5 N to keli
\q1 n xa dɛɛn nabi n xanuntenna xa,
\q1 mirihi latikɔnɔnna yi n yiine nun yii sonle ra,
\q1 han a lu dindinɲɛ bɔxɔni
\q1 e nun dɛɛn balan seen ma.
\q1 
\v 6 N yi dɛɛn nabi n xanuntenna xa,
\q1 koni n xanuntenna bata yi a xun xanbi so,
\q1 a dangu.
\q1 A fala xuiin yi godoma n niini,
\q1 n yi a fen, n mi a to,
\q1 n yi a xili han,
\q1 koni a mi n yabi.
\q1 
\v 7 Kantan tiin naxanye taan nabilinma,
\q1 ne yi fa n li,
\q1 e yi n bɔnbɔ,
\q1 e yi n maxɔlɔ,
\q1 e yi n ma xunbeli domaan ba n ma,
\q1 e tan naxanye taan nabilinna yinna kantanma.
\q1 
\v 8 Yerusalɛn sungutunne,
\q1 ɛ kɔlɔ n xa.
\q1 Xa ɛ n xanuntenna to,
\q1 ɛ nanse falama a xa?
\q1 Ɛ a fala a xa, fa fala
\q1 a fe xanuntenyaan furena n ma.
\b
\sp Xɔyine falana:
\q1 
\v 9 I tan ɲaxanla
\q1 naxan tofan ɲaxanle birin xa
\q1 i xanuntenna fan e birin xa di?
\q1 I xanuntenna fisa gbɛtɛye xa kiin mundun yi,
\q1 naxan a ligaxi i nxu rakɔlɔma na kiini?
\b
\sp Ɲaxanla falan lan a xɛmɛn ma:
\q1 
\v 10 N xanuntenna fatin fixa,
\q1 a gbeeli,
\q1 a rayabu muxu wuli fuun yɛ.
\q1 
\v 11 A xunna luxi alo xɛma kɛndɛna,
\q1 a xunsɛxɛne saxi a ma,
\q1 e fɔrɔ alo xaxaan xabena.
\q1 
\v 12 A yɛɛne rayabu
\q1 alo ganbane xuden dɛ.
\q1 E fixa alo nɔnɔna,
\q1 e mayilenma alo dayimuna.
\q1 
\v 13 A xadene luxi
\q1 alo sansi xiri ɲaxumɛ nakɔna,
\q1 naxanye xiri ɲaxumɛn tema.
\q1 A dɛ kidine luxi alo gabala fugene
\q1 mirihi latikɔnɔnna minima dɛnaxan yi.
\q1 
\v 14 A yiine rayabu
\q1 alo yiiraso xɛma daxin
\q1 naxanye rayabuxi kirisoliti gɛmɛ faɲine ra.
\q1 A fatin luxi alo sama ɲin xuruxina
\q1 safiri gɛmɛ faɲin saxin naxan ma.
\q1 
\v 15 A sanne luxi nɛn
\q1 alo sɛnbɛtɛn gɛmɛ fixɛ daxin
\q1 naxanye tixi xɛma faɲin fari.
\q1 A tofan alo Liban yamanana,
\q1 a tixi alo sumanna.
\q1 
\v 16 Ɲaxunna nan tun a dɛ,
\q1 a fatin birin nayabu.
\q1 N xanuntenna na kii nin,
\q1 n fɔxɔrabiran na kii nin,
\q1 ɛ tan Yerusalɛn sungutunne.
\c 6
\s1 Ɲaxanla tofanna
\sp Xɔyine falana:
\q1 
\v 1 I tan ɲaxanla
\q1 naxan tofan birin xa,
\q1 i xanuntenna sigaxi minɛn?
\q1 I xanuntenna a xun tixi minɛn na,
\q1 alogo nxu fan xa sa a fen i xa?
\b
\sp Ɲaxanla falana:
\q1 
\v 2 N xanuntenna bata siga a nakɔni,
\q1 sansi xiri ɲaxumɛ yireni
\q1 alogo a xa a xuruseene raba mɛnni,
\q1 a yi sansi fugaxina ndee malan.
\q1 
\v 3 N xanuntenna gbeen nan n na,
\q1 n fan gbeen nan a ra,
\q1 a nɛma a xuruseene rabama sansi fugaxine tagi.
\b
\sp Xɛmɛna falana a ɲaxanla xa:
\q1 
\v 4 N nafan ɲaxanla,
\q1 i rayabu alo Tirisa taana,
\q1 i rayabu alo Yerusalɛn taana,
\q1 koni i magaxu alo sofa ganla.
\q1 
\v 5 I yɛɛn ba n na
\q1 alogo e nama n xaxinli fu.
\q1 I xunsɛxɛn saxi a ma
\q1 alo sii kurun nɛma godɛ Galadi geyaan na.
\q1 
\v 6 I ɲinne fixa
\q1 alo yɛxɛɛ kurun naxanye kelima e maxadeni.
\q1 E lanxi e boden ma
\q1 firin firin yɛɛn ma alo gulunne.
\q1 E keden pe mi baxi e bode ma.
\q1 
\v 7 I xaden nayabu
\q1 alo girenada wudi bogini xabaxina a tagi
\q1 hali dugin bata so i yɛtagin xun na.
\q1 
\v 8 Mangan nɔɛ ɲaxalan manga tonge sennin sɔtɛ nɛn,
\q1 e nun konyi ɲaxalan tonge solomasɛxɛ,
\q1 e nun sungutun wuyaxi
\q1 naxanye xasabi mi nɔɛ kolonɲɛ,
\q1 
\v 9 koni n tan ɲaxalan keden peen nan kolon.
\q1 N ma ganbadin na a ra,
\q1 fɛ mi ɲaxanla naxan na.
\q1 A keden peen nan a nga yii dii tɛmɛn na.
\q1 A nga a tan nan nafisaxi a diine birin xa.
\q1 Sungutunne to a to,
\q1 e a sɛwana fe fala nɛn,
\q1 mangana ɲaxanle nun mangana konyi ɲaxanle fan yi a matɔxɔ.
\q1 
\v 10 E naxa, “Nde ito ra
\q1 naxan fama alo subaxana,
\q1 a rayabu alo kikena,
\q1 a mayilenma alo sogena,
\q1 koni a magaxu alo sofa ganla?”
\b
\q1 
\v 11 N bata siga nakɔni kantin yireni,
\q1 alogo n xa sa se solixine mato xuden dɛ,
\q1 alogo n xa a to xa manpa binle maɲingima,
\q1 xa girenada wudine bata fuga.
\q1 
\v 12 Anu n mi a kolon naxan a ligaxi,
\q1 n fa n yɛtɛ rasoxi yamaan kuntigine yɛngɛ so wontorone tagi.
\c 7
\s1 Ɲaxanla nun xɛmɛna xanuntenyana
\sp Xɔyine falana:
\q1 
\v 1 I xun xɛtɛ, i xun xɛtɛ,
\q1 i tan Sulami kaana!
\q1 I xun xɛtɛ, i xun xɛtɛ
\q1 alogo nxu xa i mato.
\q1 Nanfera i Sulami kaan matoma
\q1 alo gali firinna nɛma e bodonma?
\b
\sp Xɛmɛna falana a ɲaxanla xa:
\q1 
\v 2 I sanne rayabu
\q1 i ya sankidine kui,
\q1 i tan xɔrɔ ɲaxanla!
\q1 I danbane rayabu
\q1 alo yiirafalan ɲɛrɛn naxan nafalaxi.
\q1 
\v 3 I xuli fundin luxi nɛn
\q1 alo lenge radigilinxina,
\q1 minse xiri ɲaxumɛn mi ɲanma dɛnaxan yi.
\q1 I kuiin luxi nɛn
\q1 alo murutu malanxina
\q1 naxan nabilinxi gabala fugene ra.
\q1 
\v 4 I xiɲɛ firinne luxi nɛn
\q1 alo bolen dii gulun firinne.
\q1 
\v 5 I kɔɛɛn mɛrɛndɛnxi nɛn
\q1 alo sanganso sama ɲin daxina.
\q1 I yɛɛne mayilenma
\q1 alo Xɛsibɔn dara igena,
\q1 Bati-Rabimi so dɛɛn dɛxɔn.
\q1 I ɲɔɛɛn fan alo Liban sangansoon
\q1 naxan tixi Damasi taan binni.
\q1 
\v 6 I xunna ratinxinxi i gbindin dɛ
\q1 alo Karemele geyana,
\q1 i xun sɛxɛne mayilenma
\q1 alo mangane dugi mamiloxine.
\q1 Mangan mi nɔɛ a yɛɛn bɛ e ra.
\q1 
\v 7 I rayabu, i tofan han,
\q1 n xanuntenna, n ma sɛwa xunna.
\q1 
\v 8 I kuya alo tugu binla,
\q1 i xiɲɛne luxi alo tugu bogi tɔnsɔnne.
\q1 
\v 9 Nanara, n na a falama, n naxa,
\q1 “N tema nɛn tugu binla kɔɛ ra,
\q1 n yi a bogine suxu.”
\q1 I xiɲɛne luxi nɛn
\q1 alo ɲaxundan tɔnsɔnne,
\q1 i dɛ foyen xirin luxi nɛn
\q1 alo mangon mɔɛɛn xirina.
\q1 
\v 10 I dɛɛn xirin luxi nɛn
\q1 alo manpa xiri ɲaxumɛna.
\b
\sp Ɲaxanla falana a xɛmɛn xa:
\q1 Na manpaan xa lu n xanuntenna nan xa,
\q1 a godo a dɛ kidine nun a ɲinne ma.
\q1 
\v 11 N xanuntenna nan gbee n na
\q1 a waxi n tan nan xɔn.
\q1 
\v 12 N xanuntenna,
\q1 fa en siga burunna ra,
\q1 en kɔɛne radangu banxidɛne ra.
\q1 
\v 13 Xɔtɔnni en kurun sigɛ manpa bili nakɔne yi,
\q1 en sa a mato
\q1 xa e solima, xa e fugama,
\q1 xa girenada binle fugama.
\q1 Mɛnni, n sa n ma xanuntenyaan yita i ra.
\q1 
\v 14 Marafan bogi binle e xiri faɲine raminima,
\q1 bogise faɲine birin en dɛxɔn.
\q1 N xanuntenna,
\q1 n fe faɲine birin namaraxi i tan nan xa
\q1 a fonne nun a nɛnɛne.
\c 8
\s1 Xanuntenyaan sɛnbɛn gbo
\sp Ɲaxanla falana a xɛmɛn xa:
\q1 
\v 1 Xa ngaxakeden xɛmɛmaan nan yi i ra nun,
\q1 naxan nga xiɲɛn minxi,
\q1 n yi sa i ralanma nɛn nun,
\q1 n yi i sunbu tanden ma,
\q1 muxu yo mi n naɲaxu.
\q1 
\v 2 N yi i xalima nɛn nun,
\q1 n sa i raso ngaa banxini.
\q1 I yi n xaran xanuntenyaan ma.
\q1 I yi n ma manpa xiri ɲaxumɛn min,
\q1 n ma girenada bogine igene.
\q1 
\v 3 A kɔmɛn ma yiina n xunna bun,
\q1 a yi a yiifanna rabilin n ma.
\q1 
\v 4 Yerusalɛn sungutunne,
\q1 n bata ɛ rakɔlɔ,
\q1 ɛ nama xanuntenyaan nakeli,
\q1 ɛ nama a raxulun,
\q1 benun a waxatin xa a li.
\b
\sp Xɔyine falana:
\q1 
\v 5 Ɲaxanla mundun fama ito ra
\q1 sa keli tonbonni,
\q1 a singanxi a xanuntenna ra?
\b
\sp Ɲaxanla falana a xɛmɛn xa:
\q1 N bata i raxulun mangon binla bun,
\q1 i bari ngana i fudi tongoxi dɛnaxan yɛtɛni.
\q1 
\v 6 N ma fe sa i bɔɲɛni
\q1 alo taxamasenna i yiin na,
\q1 bayo xanuntenyaan sɛnbɛn gbo
\q1 alo sayana.
\q1 Xɔxɔlɔnna ɲaxu alo laxira,
\q1 a dɛgɛn xɔlɔ
\q1 alo habadan tɛɛ dɛgɛna.
\q1 
\v 7 Ige gbeene mi nɔɛ xanuntenyaan ɲanɲɛ.
\q1 Baa igene mi nɔɛ a xalɛ.
\q1 Xa muxuna nde yi katɛ a banxin kui seene birin masarɛ xanuntenyaan na,
\q1 muxe mi yi tinɲɛ a rasuxɛ.
\b
\sp Xɔyine falana:
\q1 
\v 8 Nxu xunyɛ ɲaxalanmana nde na,
\q1 naxan xiɲɛye munma te singen.
\q1 En nanse ligama en xunyɛ ɲaxalanmaan xa,
\q1 en na a futu feen fala lɔxɔn naxan yi?
\q1 
\v 9 Xa a luxi
\q1 alo taan nabilinna yinna
\q1 naxan mi rabima,
\q1 nxu a binyama nɛn gbeti gbeen na.
\q1 Koni xa a luxi
\q1 alo dɛɛn naxan nabima keden na,
\q1 nxu a balanma suman farinne nan na.
\b
\sp Ɲaxanla falana a xɛmɛn xa:
\q1 
\v 10 N tan luxi nɛn
\q1 alo taan makantan yinna,
\q1 n xiɲɛne luxi alo sangansona.
\q1 N luxi nɛn n ma xɛmɛn yɛɛ ra yi
\q1 alo ɲaxanla naxan fama bɔɲɛ xunbenla ra a xa.
\q1 
\v 11 Manpa bili nakɔna nde yi Sulemani yii Baali-Hamon yi,
\q1 a yi a taxu muxuna ndee ra.
\q1 E birin yi fama gbeti gbanan wuli keden nan na a bogine saren na.
\q1 
\v 12 N ma nakɔna n tan nan xa.
\q1 A n yii.
\q1 Na gbeti gbanan wuli kedenna i tan nan xa Sulemani,
\q1 i yi kɛmɛ firin so a kantan muxune yii.
\b
\sp Xɛmɛna falana a ɲaxanla xa:
\q1 
\v 13 I tan naxan dɔxi nakɔni,
\q1 n lanfane tuli matixi i ra.
\q1 I xuiin namini n xa a mɛ.
\b
\sp Ɲaxanla falana a xɛmɛn xa:
\q1 
\v 14 N xanuntenna, i gi,
\q1 alo bolena hanma xɛli sɛnbɛmaan geyane fari
\q1 sansi xiri ɲaxumɛne dɛnaxan yi.
