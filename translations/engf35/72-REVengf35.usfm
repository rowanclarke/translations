\v 1 \w And|strong="G2532"\w* \w I|strong="G2532"\w* \w saw|strong="G3708"\w* \w an|strong="G2192"\w* \w angel|strong="G2597"\w* \w coming|strong="G2597"\w* \w down|strong="G2597"\w* \w from|strong="G1537"\w* \w heaven|strong="G3772"\w*, \w having|strong="G2192"\w* \w the|strong="G2532"\w* \w key|strong="G2807"\w* \w of|strong="G1537"\w* \w the|strong="G2532"\w* Abyss \w and|strong="G2532"\w* \w a|strong="G2192"\w* \w huge|strong="G3173"\w* chain \w on|strong="G1909"\w* \w his|strong="G1909"\w* \w hand|strong="G5495"\w*.  
