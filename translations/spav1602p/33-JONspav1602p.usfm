\v 13 \w Y|strong="H3068"\w* aquellos hombres \w trabajaron|strong="H2864"\w* \w por|strong="H5921"\w* \w tornar|strong="H7725"\w* \w la|strong="H5921"\w* nave \w a|strong="H3068"\w* \w tierra|strong="H3004"\w*; \w mas|strong="H3588"\w* \w no|strong="H3808"\w* \w pudieron|strong="H3201"\w*, \w porque|strong="H3588"\w* \w el|strong="H5921"\w* \w mar|strong="H3220"\w* \w iba|strong="H1980"\w* \add a más\add*, \w y|strong="H3588"\w* \w se|strong="H5921"\w* embravecía \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w*.   
