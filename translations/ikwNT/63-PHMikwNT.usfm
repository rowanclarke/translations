\id PHM - Ikwerre
\h Filemọni
\toc1 Ọkwukwo izi Pọlu gbaznennu Filemọni
\toc2 Filemọni
\toc3 Filem
\mt2 Ọkwukwo izi
\mt2 Pọlu gbaznennu
\mt1 Filemọni
\imt1 Nhne gbasịri ọkwukwo izi ka
\im Filemọni bụ otu nye zị mkpa n'ọgbako Chiokike ke zị nụ Kọlosi, nye nwe ọhi ke rẹwhna a bụ Ọnesimosi. Ọhi ka hiri n'ọro nye nwe a gbawhu. Kpa ọ kpawhuru, ya nụ Pọlu nye zị n'ikelu whnụtaru. Hite n'aka Pọlu, Ọnesimosi ghọ nye Karaịsi. Pọlu gbaznennu Filemọni ọkwukwu izi ka naarịasno a, ọ kwubnahnarnụ ọhi a, nye Pọlu neezihnahienu a. Pọlu naarịasno a, ọ naabnarnụ a lele nnwọ nda nụ rime Karaịsi, ọ bụ́o lele ọhi.
\iot Nhne zị n'ọkwukwo izi ka
\io1 Ọpanizo \ior (1-3) \ior*
\io1 Ọwhnun'anya Filemọni nụ ọkwnata ovu a \ior (4-7) \ior*
\io1 Ọriasno nụ risi Ọnesimosi \ior (8-22)\ior*
\io1 Okwukwo \ior (23-25) \ior*
\c 1
\p 
\v 1 Mawa, Pọlu, nye ikelu kwnornu Karaịsi Jizọsi, nụ nwene aị rukna Timoti, naagbaznenu enyi aị nụ nye ẹrnu ibne aị, Filemọni, ọkwukwo izi.
\v 2 A naagbaznenu masịnu nwene aị rinya Afịa nụ nye ọgwnu ibne aị Akịposi nụ ọgbako ke zị n'ọro ị.
\v 3 Oru nụ udno ke Chiokike Nda aị nụ Nyenwe aị Jizọsi Karaịsi dazịnu anụ.
\s1 Pọlu nọotunu Chiokike // mmamma
\p 
\v 4 M nọotunu Chiokike mmamma ige ọbula me neechenwanya ị n'okpukpe m,
\v 5 kwnornu nụ m nọonu nhne gbasịri ọwhnun'anya i hne kpakara rụmu Chiokike zị nụ ọkwnata ovu i nụ Nyenwe aị Jizọsi Karaịsi.
\v 6 M neekpe ma ọkwnata ovu i nọornusi ẹrnu rikne n'esilawụru rụmu nda ma ị mahịa kpakara nhne ọma ke a nwernu a ji nọornu ẹrnu nụ rime Karaịsi.
\v 7 Ọwhnun'anya i nyernu m mkpọma ọso n'ọnu k'agịda sụ nwene m rukna, bụ ke mernu ovu ele nsọ zịri bụdnu ikne, gbata kwno m inwe.
\s1 Pọlu rịasnornu // nụ risi Ọnesimosi
\p 
\v 8 M nwernu m anya rikne nụ rime Karaịsi ọ kanụ ị mee nhne ke kwesiri.
\v 9 Kọvu ọwhnun'anya mernu me rịasno i, lele ọkpa badnụ me bụ, Pọlu nye okno badnụ, kọvu kịtna, nye ikelu kwnornu Jizọsi Karaịsi.
\v 10 M nọorio ị kwnornu Ọnesimosi nnwọ m rukna nụ rime Karaịsi, nye ghọru nnwọ m kpa me zị n'ikelu.
\v 11 Nụ mbọm, ọ bnáge nụ nhne ọbula nyee i, kọvu kịtna ọ bnarnụ iru nyee i, ma mawa masị.
\p 
\v 12 M neeziyanu ị ya hite n'ovu m, lele nye zị m okne mkpa.
\v 13 O znernu amasị m ọ bịta a hna me zị ma o yinu m aka n'ọnodi ị kpa me zị n'ikelu kwnornu izi ọma.
\v 14 Kọvu m jéeme nhne ovu i kwéle, kpa nhne ọma ọbula i jeeme jeehi n'ovu i whụya, ọ bụ́o nhne be kwnagidnernu i mee.
\v 15 Ọ jọobu nụ Ọnesimosi whọgaru ige matị, ma i kwubnanya a n'ẹhni ị ọkwnukokwnu.
\v 16 Ọ bụ́ma lele ọhi, o kakwo ọhi, kọvu lele nnwọ nda be whnụrnu n'anya. Ọ zị m mkpa k'ezi, kọvu ọ zị ị mkpa kakwo lele badnụ nụ lele nnwọ nda nụ rime Nyenwe aị.
\p 
\v 17 Ọ bụru nụ i kwuru m nye ẹrnu ibne i, kwubnanya a lele kpa i jeegweru m.
\v 18 Ọ bụru nụ o nwernu nhne ọjo ọbula mọbu ọgwo ke o ji i, gwnụsi a nụ risi m.
\v 19 Mawa Pọlu, ji aka m naagba nhne ka, m jọokwu ị be. Ị magwụ nụ jị n'iwhuru i jigwu m ọgwo bụdnu i.
\v 20 Bikno, nwene m rukna, menu m nhne ka kwnornu nụ Nyenwe aị, mee ovu sọ m n'ọnu lele nwene rukna nụ Karaịsi.
\v 21 M tụkwasiri m mkpọma nụ ị joobno nsnị kpa me naagba ọkwukwo ka nụ i jeeme kakwo nhne me nọorio ị.
\p 
\v 22 Kpam masị, bịtanu m otu ọnu ọro, kwnornu m neele anya nụ Chiokike jaaza kpakara okpukpe anụ mee m hiehnakwnusi anụ berere.
\s1 Obekwu ikwu ipne-aznụ
\p 
\v 23 Epafarasị nye me nụ a zị n'ikelu kwnornu Karaịsi Jizọsi neebekwu i,
\v 24 ma ele ẹrnu ibne m Makị, Arịsitakosi, Demasị nụ Lukwu.
\v 25 Oru ke Nyenwe aị Jizọsi Karaịsi dazịnu enine anụ.
