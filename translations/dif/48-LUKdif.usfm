\id LUK  
\ide UTF8
\h Lucas 
\toc1 Ngantjani‐Jaura Lucangundru 
\toc2 Lucangundru 
\toc3 Luc 
\mt1 Ngantjani‐Jaura Lucangundru.  
\c 1  
\p
\v 1 Ngangau marapujeli wontjana wonti kaukaubani jaura dakala nunkangundru, mina ngaianangu terti pantjina wonti, ja ngaiani morlalu milkila,   
\p
\v 2 Jeruja worderu tanali ngaianangu kaukaubana wonti, tana ngoperandru milkieli najina wonti ja jaura jinkinietja pantjina wonti.   
\p
\v 3 Jeruja bakana ngato ngundrana warai, ngato ngoperandru pratjana jiglerali matja jakalkana warai, jenia jinkangu talku dakala, Theophilai ngantjalu.   
\p
\v 4 Ngangau jundru talku ngujamananto tananapini jaura, tanangu jundru ngujangujara matja manina.   
\p
\v 5 Herodes Judaia mitaia kaparaia ditjini Priesta kulno nganana wonti, tala nunkani Zacharias, Abiaia mardundru, ja noa nunkani Aaroni ngatamura widlandru, tala nankani Elisabeth.   
\p
\v 6 Pudla talku nganana wonti Godani, ja Kaparaia jirijiribani jaura pratjanani ja talkulani ngumu wodatarana ngamana wonti.   
\p
\v 7 Pudlali wata kupa ngamalkana wonti, ngangau Elisabeth ngameri nganana wonti, ja pudla kilpawoldra marapuni wiringana wonti.   
\p
\v 8 Ja jendranguta nulu Priestaia mangini ngamalkana wonti marduwittani nunkanani Godani.   
\p
\v 9 Ja Priestaia wondrani malkali nina patana wonti kuli ngumu tarala, nau Godaia Kaparaia pungani wirina wonti.   
\p
\v 10 Ja kana wolara palarani terkana wonti ngatjila kuli ngumuja ditjini.   
\p
\v 11 Ja Kaparaia angela kulno nunkangu wondraterina wonti, nau turutupu Altaraia ngunarani terkana wonti.   
\p
\v 12 Ja Zachariali nina najina, nau ngarrana wonti ja japali pantjina wonti.   
\p
\v 13 Angela nunkangu jatana wonti: „Wata japali nganau Zachariajai, ngangau ngatjina jinkani ngarana warai, ja noajeli jinkanali jinkangu kanku dankala nganai, ja jundru tala nunkani dikala nganai: Johannes.   
\p
\v 14 Ja jundru mankina ja murla ngamalkala nganai, ja marapu mankila nganai nunkani dankanandru,   
\p
\v 15 Ngangau nau pirna nganala nganai Kaparani; ja waina ja tapana ngurunguru nulu wata tapala nganai, ja Jaolali kulikirieli nau manamiri pantjila nganai nunkani ngandri mandrandru.   
\p
\v 16 Ja nulu Israelaia ngatamura marapu karitjimalkala nganai Kaparani Godani tananani.   
\p
\v 17 Ja nau nunkangu ngopera wapala nganai Eliaia jaolali ja ngurungurulali, ngaperi woraia ngara kupa worani, ja delkinietja talkulaia kirilani karitjimalkala, Kaparani kana wolara talku ngankingala.“   
\p
\v 18 Ja Zacharias angelani jatana wonti: „Worderu ngato jenia ngujamananto? Ngangau ngani pinaru, ja noa ngakani nankani ditji marapuni wiringana warai.“   
\p
\v 19 Ja angelali kalabana wonti ja nunkangu jatana wonti: „Ngani Gabrieli nganai, nauja Godani terkai, ja Nulia ngana jinpana warai, jinkangu ngankamalinanto, ja ninapini ngantjani jaura jinkangu kaukaubananto.   
\p
\v 20 Ja mai, jidni ngapurila nganai ja ngandandarila nganai jatala nunkangupini ditjielu, nunkangupini jenia morlalu pantjila nganai; ngangau jundru jaurani ngakanani wata morlalu ngundrana warai, tanaia morlalu pantjila nganai ditjini tananani.“   
\p
\v 21 Ja kana wolarali kalkana wonti Zachariangu, to tana ngaruparana wonti, ngangau nau juri ngamana wonti Godaia pungani.   
\p
\v 22 Nau matja dunkana kurana, nau ngandandarina wonti tanangu ngankamalila, ja tanali ngujamana wonti, nulu mudla Godaia pungani najina warai, ja nau tanangu marali wondraterina wonti ja ngapu nganana wonti.   
\p
\v 23 Ja jendranguta ngankana ditji nunkani matja mudana, nau tikana wonti pungaia nunkanaia.   
\p
\v 24 Tanangupini ditjini ngadani, Elisabeth noa nunkani mandrantjurina wonti; ja nani kurukuru ngamalkaterina wonti pira mara wora, ja jatana wonti:   
\p
\v 25 „Jeruja Kaparali tanangupini ditjini ngakangu ngankana paraia, tanangu Nulia ngana najina, ninta ngakani kanandru manila.“   
\lit (Ngantjani‐jaura Mariananka talpadakani ditjini.)  
\p
\v 26 Pirani mara wora ja kulnuni Godali angela Gabriel jinpana wonti ngura kulnuja Galilaiaia, tala nunkani Nazaret.   
\p
\v 27 Mankara kulnuni, nandru talpadakana wonti materi kulnuni, tala nunkani Joseph, Davidani pungandru; ja mankaraia tala Maria nganana wonti.   
\p
\v 28 Ja angela nankangu wirina wonti ja jatana wonti: „Murlali nganamai murlamaninietjajai; Kapara jinkangunto, jidni murlali pirna nganai widlani!“   
\p
\v 29 Nandru nina najina, nani ngaruparana wonti nunkani jaurandru, ja ngundraterina wonti, mina mandurini jaura jenia nganai.   
\p
\v 30 Ja angela nankangu jatana wonti: „Wata japali nganau Mariajai; ngangau jundru manjula mankamankana warai Godani.   
\b  
\p
\v 31 Ja mai, jidni mandrantjurila nganai, ja kanku kulno dankala nganai, ja tala nunkani dikala nganai: «JESUS.»   
\p
\v 32 Naupini pirna nganala nganai, ja tanali nina Kapara pirnaia Ngatamura dikala nganai, ja Goda Kaparali nunkangu jinkila nganai ngaperaia nunkanaia Davidani pirnalaia piri.   
\p
\v 33 Ja Nau Kapara nganala nganai Jakobani pungani ngurali, ja milila nunkani wata mudala nganai.“   
\p
\v 34 Maria angelani jatana wonti: „Worderu jenia nganala nganai, ngangau ngato noa wata ngujamai?“   
\p
\v 35 Ja angelali kalabana wonti ja jatana wonti: „Jaola kulikiri jinkangu ngarila nganai, ja Kapara pirnaia ngurulali jidna walpala nganai; ngangau bakana nina Kulikirila, nina jundru dankala nganai, tanali Godaia Ngatamura dikala nganai.   
\p
\v 36 Ja mai, Elisabeth kamaneli jinkani bakana mandrantju nganai kankunto, ja naupini pira mara wora ja kulno nganai nankangu, nana tanali ngameri dikai.   
\p
\v 37 Ngarla Godata wata ngandandarila nganai jaura pratjanani.“   
\p
\v 38 Maria jatana wonti: „Mai, ngani Kaparaia mili nganai, ngakangu pantjiatimai worderu jidni jatana warai!“ Ja angela nankangundru kutingana wonti.   
\lit (Ngantjani jaura Mariananka mandurini ditjini)  
\p
\v 39 Maria terkakana wonti tanangupini ditjini, ja palkana wonti mardawonpaia ngura kulnuja Judaiaia.   
\p
\v 40 Ja Zachariani pungani wirina wonti ja Elisabethangu mandurini jaura jinkina wonti.   
\p
\v 41 Ja jendranguta Elisabethandru Mariani mandurini jaura ngarana wonti, kupa nankani mandrani kulkungana wonti; ja Elisabeth manamiri pantjina wonti Jaolali kulikirieli.   
\p
\v 42 Ja nani ngaiala pirnali maritjina wonti ja jatana wonti: „Murlali pirna jidni nganai widlani, ja murlali pirna jinkani mandraia tandra nganai!   
\p
\v 43 Ja wodajerindru jenia ngakangu, Kaparaia ngakanaia ngandri ngakangu wokarananto?   
\p
\v 44 Ngangau mai, matja mandurini jaura jinkani ngakangu talpani wirina, kupa mandrani ngakanani mankina kulkungana warai.   
\p
\v 45 Ja murlali pirna nandru morlalu ngundrana paraia, ngangau morlalu jenia pantjila nganai, mina nankangu Kapara jatana paraia.“   
\p
\v 46 Ja Maria jatana wonti: „Mungarali ngakanali Kapara jurakokala wapaia,   
\p
\v 47 Ja jaolali ngakanali Goda Kulkanipirnandru ngakanani mankila wapaia,   
\p
\v 48 Ngangau Nulia najina wonti nunkani mili waka. Ngangau mai, kararindru ngana jurakokala nganai kana nguja warupotujeli.   
\p
\v 49 Ngangau ngakangu pirnala ngankana paraia Nauja ngurunguru, ja kulikiri tala nunkani nganai.   
\p
\v 50 Ja kalumiltjamiltjarina nunkani ngujandru ngujani nganai tanangu, tana nunkangundru japali nganai.   
\p
\v 51 Nulia ngurungurula ngankana wonti ngunarali nunkanali; Nulia piltjaru ngankana wonti tanana ngara ngundranani tananani pirna ngundrateriai;   
\p
\v 52 Nulia kapara worana worarana wonti pirnalaia pirindru ja wakawaka miri ngankana wonti.   
\p
\v 53 Tana maua nganana, Nulia potujeli manamiri ngankana wonti; ja tana poto pirnanto Nulia kala jinpana wonti.   
\p
\v 54 Nulia Israeli milini nunkanani marangokana wonti kalumiltjamiltjarina nunkani ngundrala.   
\p
\v 55 Worderu Nauja jatana wonti ngaianani ngaperi worani, Abrahamangu ja ngatamurani nunkanani ngurali.“   
\p
\v 56 Maria nankangu jela pira parkulu ngamana wonti, ja ngadani pungaia nankanaia tikana wonti.   
\b  
\lit (Ngantjani‐jaura Johannes multibanietjaia ditjini.)  
\p
\v 57 Elisabethananka ditji matja wokarana, nandru dankananto, ja nandru kupa ngatani dankana wonti.   
\p
\v 58 Ja jenimalinietjali ja kamanelieli nankanali ngarana wonti worderu Kapara kalumiltjamiltjarina nunkani nankangu pirna ngankala wiri; ja tana nankangunto mankina wonti.   
\p
\v 59 Ja jendranguta ditji mara wora ja parkulani tana wokarana wonti nina kanku karuwali ngankala, ja tanali nina ngaperi nunkani jeri „Zacharias“ dikana wonti.   
\p
\v 60 Ja ngandrieli nunkanali kalabana wonti ja jatana wonti: „A‐ai, Johannes tala nunkani nganala nganai.“   
\p
\v 61 Ja tana nankangu jatana wonti: „Wata kamaneli kulno jinkani nganai, nina tanali ninapini tala dikai.“   
\p
\v 62 Tanali ngaperi nunkani marali jekibana wonti, worderu nulu ngantjai ninaia dikala.   
\p
\v 63 Ja nau ngatjina wonti marda pirrapirrani ja dakana wonti ja jatana wonti: „Johannes tala nunkani nganai.“ Ja tana pratjana ngaruparana wonti.   
\p
\v 64 Nurujeli mana nunkani piririna wonti, ja tali nunkani walturina wonti, ja nau jatana wonti ja Goda jurakokana wonti.   
\p
\v 65 Ja jenimalinietja pratjana japali pantjina wonti, ja Judaia mardawonpa worani tana ngankamalina wonti jenia jaura pratjanandru.   
\p
\v 66 Ja pratjana, tanali jenia ngarana wonti, jenia ngarali patana wonti ja jatana wonti: „Mina naupini kupa pantjila nganai?“ Ngangau Kaparaia mara nunkangunto nganana wonti.   
\p
\v 67 Ja Zacharias, ngaperi nunkani, Jaolali kulikirieli manamiri pantjina wonti, ja nulu talpadakana wonti ja jatana wonti:   
\p
\v 68 „Jurakokana nganaiatimai Kaparani, Israelaia Godani, ngangau Nulia najina wonti ja kulkana ngankingana wonti kana wolarani nunkanani,   
\p
\v 69 Ja Nulia murlaia jurietjali ngaianangu jiritjibana wonti Davidani milini nunkanani pungani,   
\p
\v 70 Worderu Nauja jatana wonti nunkani Prophetaia kulikiria manali, tana ngopera nganana wonti.   
\p
\v 71 Nulia ngaianana kulkananto ngaianani talpalandru, ja mara pratjanandru tana ngaianangu kalakalariai,   
\p
\v 72 Kalumiltjamiltjarina ngankala ngaianani ngaperi worani, ja ngundrala nunkani Testamenta kulikiri;   
\p
\v 73 Jaura morlalu, nina Nulia talpadakana wonti Abrahamangu ngaperi ngaiananani, ngaianangu jinkila.   
\p
\v 74 Ngangau ngaiana japanguru, Nulia ngaiananana tulaia marani matja kulkana, mili nunkani nganananto.   
\p
\v 75 Kulikirilani ja talkulani nunkani mudlani ditjini warupotuni ngaiananani.   
\p
\v 76 Ja bakana jidna, kupajai, tanali Kapara pirnaia Propheta dikala nganai, ngangau jidni ngopera wapala nganai Kaparaia mudlani, palto nunkani ngankingala.   
\p
\v 77 Murlaia ngujamani jinkila kana wolarani nunkanani, madlentji tanani kalingala.   
\p
\v 78 Godaia ngaiananaia ngarali kalumiltjamiltjarinandru, nunkangundru ngaianangu mirindru praitji dunkana warai,   
\p
\v 79 Tanangu mintjila, tana ngalpurani ja naria pungalani ngamanani, ngaianani tidna murlaia paltuni wirilkala.“   
\p
\v 80 Kupa pirnarina wonti ja ngurungururina wonti Jaolali; ja nau pitarani nganana wonti nunkangupini ditjielu, nau Juda kanani wondraterina wonti.   
\b  
\c 2  
\lit (Ngantjani jaura Jesuja dankani ditjini.)  
\p
\v 1 Jendranguta tanangupini ditjini mitaia kaparali Augustulu jirijiribana wonti, mita warupoto windamala.   
\p
\v 2 Naupini windamani ngoperala nganana wonti, jendranguta Kyrenius kapakapara Syria mitani nganana wonti.   
\p
\v 3 Ja kana pratjana wapana wonti tanali tanana windamananto, kana pilki ja pilki nguraia tananaia.   
\p
\v 4 Jendranguta bakana Joseph tarana wonti Galilaiandru Nazaret ngurandru Judaia mitaia Davidani nguraia, tala nunkani Bethlehem, ngangau nau Davidani pungandru ja mardundru nganana wonti.   
\p
\v 5 Tanali nina windamananto Mariangunto, talpadakani noanto nunkani, nani mandrantju nganana wonti.   
\p
\v 6 Jendranguta, pudla jerra matja ngamana, ditji nankani wokarana wonti, nandru dankananto.   
\p
\v 7 Ja nandru kupa kanku panturu dankana wonti, ja nina katieli karana wonti ja nganti pirrani kurana wonti, ngangau pudlangu piri pani nganana wonti ngurani.   
\p
\v 8 Ja ngamalkanietja nunkangupini mitani palarani nganana wonti, tanali tinkani ngami tanani ngamalkana wonti.   
\p
\v 9 Ja mai, Kaparaia angela kulno tanangu wondraterina wonti, ja Kaparaia pirnala tanangu mintjina wonti, ja tana japali pirna ngamana wonti.   
\p
\v 10 Ja angela tanangu jatana wonti: „Wata japali ngananau; mai, mankini pirna ngato jurangu kaukaubala wapaia, nauja kanani warupotuni nganala nganai.   
\p
\v 11 Ngangau Kulkanipirna jurangu karari dankana warai, Naupini Christus Kapara nganai, Davidani ngurani.   
\p
\v 12 Ja naupini jurangu malka nganananto, jura kupa karaterinani mankamankala nganai, ja nganti pirrani paranani.“   
\p
\v 13 Ja nurujeli angela kulnuni angela wolara wora pariwilpandru wokarana wonti, tanali Goda jurakokana wonti ja jatana wonti:   
\p
\v 14 „Pirnala Godani miri, ja murla mitani, ja Godali kana ngantjai.“  
\b  
\lit (Ngantjani‐jaura Jesuja dankana ditjini mandruni.)  
\p
\v 15 Jendranguta angela wolara wora tanangundru matja pariwilpani tikana tarana, ngamalkanietja ngankamalina wonti: „Ngaiana Bethlehemia wapananto jenia jaurandru, tana Kaparali ngaianangu wondrana warai, najila, mina pantjina warai.“   
\p
\v 16 Ja nurujeli tana wapana wonti, ja Joseph ja Maria mankamankana wonti, ja bakana kupa nganti pirrani paranani.   
\p
\v 17 Tanali nina matja najina, tanali jenia jaura piltjaru ngankana wonti, tanangu matja kaukaubana nunkangupini kupandru.   
\p
\v 18 Ja pratjanali, tanali jenia ngarana, ngaruparana wonti nunkangundru, mina ngamalkanietjali tanangu kaukaubana warai.   
\p
\v 19 Ja Mariandru tananapini jaura pratjana ngamalkana wonti, ja ngarali nankanali ngundrana wonti.   
\p
\v 20 Ja ngamalkanietja tikana wonti ja Goda pirna ngundrana wonti ja jurakokana wonti pratjanandru, mina tanali ngarana ja najina warai, worderu tanangu matja kaukaubana.  
\b  
\lit (Ngantjani jaura kilpawoldra marra ditjini.)  
\p
\v 21 Ja ditji mara wora ja mandru matja mudana, tanali nina kupa karuwali ngankana wonti; ja tanali nunkangu bakana tala jinkina wonti „JESUS,“ worderu angelali nina morla ngopera dikana wonti, Nau mandrani kantjirina warai.  
\b  
\lit (Ngantjani jaura Mariananka kulirkani ditjini.)  
\p
\v 22 Ja kulirkani ditji nankani matja mudana Mosini jirijiribani jaurandru, pudlali nina Jerusalemia taralkana wonti, nina Kaparani wondralkala.   
\p
\v 23 Worderu Kaparaia jirijiribani jaurani parai: „Kanku pratjana ngandrindru ngopera dankana, Kaparani kulikiri nganala nganai.“   
\p
\v 24 Ja poto ngumu jinkila, worderu Kaparaia jirijiribani jaura jatai: „Mulapara mandru kara, waparu wolka mandru kara.“   
\p
\v 25 Ja mai, kana kulno Jerusalemani nganana wonti, tala nunkani Simeon, ja naupini kana talku ja Godandru japali nganana wonti ja Israelaia ngankalkanani wolkareli kalkana wonti; ja Jaola kulikiri nunkangunto nganana wonti.   
\p
\v 26 Ja nunkangu tinkari nganana wonti Jaola kulikirindru, nulu nari wata najinanto, a‐ai, nulu ngopera Kaparaia Christus najinanto.   
\p
\v 27 Ja nau Jaolali Godaia pungani wirina wonti. Ja pudlali Jesus kupa wirilkanani nunkangu ngankala, worderu tanali jirijiribani jaurandru milingeru ngankana wonti.   
\p
\v 28 Bakana nulu nina ngunali nunkanali munamana wonti ja Goda jurakokana wonti ja jatana wonti:   
\p
\v 29 „Kaparajai, karari jundru milini jinkanani manuni kurala wapai wapananto, worderu jundru ngakangu talpadakanala.   
\p
\v 30 Ngangau ngato milkieli Kulkanipirna jinkani najila wapaia.   
\p
\v 31 Ninapini jundru ngankingana wonti kana mudla warupotuja.   
\p
\v 32 Praitji kulno kana koni mintjila, ja pirnala Israel kana wolarani jinkanani.“  
\b  
\lit (Ngantjani‐jaura Jesu dankani ditji Godaia ditjini kulno ngadani.)  
\p
\v 33 Ja ngaperi nunkani ja ngandri nunkani ngaruparana wonti jenia jaurandru, mina nau nunkangundru jatana warai.   
\p
\v 34 Ja Simeonali tanana ngurungutana wonti, ja Mariangu ngandrini nunkanani jatana wonti: „Mai, Naupini parai marapu Israelani nunkangu purinanto ja jiritjinanto, ja malka nganala, nunkangu tanali tjakakala nganai.   
\p
\v 35 Ja kalti tiri bakana jinkangu mungarani palkingala nganai, kana marapuja ngarali ngundrani wondraterinanto.“   
\p
\v 36 Ja Propheta widla Hanna naka nganana wonti, Phanuelani ngatamura, Asserani mardundru; nani ditji marapuni wiringana wonti, nani noanto kilpawoldra mara wora ja mandru matja tepi ngamana.   
\p
\v 37 Ja nani mangawaru nganana wonti tidna ja mara pratjana ja kulno pota mandru ja mandru; nanipini milingeru Godaia pungani ngamana wonti ja milja ngamana wonti ja ngatjina wonti, ja ditjini ja tinkani mili ngamana wonti.   
\p
\v 38 Nanipini bakana nunkangupini ditjini karakara wokarana wonti, ja nandru Goda jurakokana wonti ja pratjanani nunkangundru kaukaubana wonti, tanali Jerusalemani Kulkanipirnani kalkana wonti.   
\p
\v 39 Ja pudlali pratjana Kaparaia jirijiribani jaurandru matja mudana, pudla tikana kurana wonti Galilaia mitaia Nazaret nguraia tananaia.   
\p
\v 40 Ja kupa pirnarina wonti ja ngurungururina wonti ja manamiri nganana wonti milkilali, ja Godaia manjula nunkangunto nganana wonti.  
\b  
\lit (Ngantjani jaura G. D. 1. Epiphanias.)  
\p
\v 41 Ja ngaperi ja ngandri nunkani milingeru kilpawoldrani pota kulno Jerusalemia palkana wonti wiringani ditji pirnani.   
\p
\v 42 Ja Nau matja kilpawoldra marapratjana ja mandru nganana, pudla tarana wonti Jerusalemia, worderu milingeru ditji pirnani.   
\p
\v 43 Ja ditji pirna matja mudana, pudla tikana kurana wonti; ja Nau kanku Jesus Jerusalemini ngamantina wonti, ja Joseph ja ngandri nunkani ko nganana wonti.   
\p
\v 44 Pudlali ngundrana wonti, Nau kamanelini jela nganai, ja ditji kulno matja palkana, pudlali nina wontina wonti kamanelini ja nguralani.   
\p
\v 45 Ja pudlali nina wata mankamankana, pudla nakaldra tikana wonti Jerusalemia nina wontila.   
\p
\v 46 Ja jendranguta ditji parkulani pudlali nina mankamankana wonti Godaia pungani, worderu Nau jaura jinkinietjani terti ngamanani tanana ngarala ja jakalkala.   
\p
\v 47 Ja pratjanali nina matja ngarana, pirna ngaruparana wonti nunkani tjuru ngumundru ja kalabanandru.   
\p
\v 48 Ja pudlali nina matja najina, pudla pirna ngaruparana wonti, ja ngandri nunkani nunkangu jatana wonti: „Ngataniai, minandru jundru jenia ngankala wiri ngalingu? mai, ngaurongaurojeli ngaperali jinkanali ngali jidna wontina warai.“   
\p
\v 49 Ja Nau pudlangu jatana wonti: „Minandrn judla ngana wontina warai? Wata judla ngujamai, ngani nganananto ngakani Ngaperaia pungani?“   
\p
\v 50 Ja pudlali jaura nunkani bulu ngujamana wonti, tanana Nau pudlangu jatana wonti.   
\p
\v 51 Ja Nau pudlangu jela tikana wonti Nazaret nguraia, ja pudlangu wodatarana ngamana wonti. Ja ngandrieli nunkanali tananapini jaura pratjana ngamalkana wonti ngarali nankanali.   
\p
\v 52 Ja Jesus morla milkila pantjina wonti ja pirnarina wonti ja Godali ja kanali nina morla ngantjana wonti.  
\b  
\c 3  
\p
\v 1 Tiberius kilpawoldra marapratjana ja mara wora mitaia kapara matja ngamana, Pontius Pilatus najinajibanietja Judaiani, ja Herodes kapakapara Galilaiani, ja Philippus neji nunkani kapakapara Ituraiani ja Trachonitis mitani, ja Lysanias kapakapara Abyleneni,   
\p
\v 2 Ja Hannas ja Kaiphas Priesta pirna nganana wonti. Jendranguta Johanningu Zachariani ngatamurani Godaia jaura pantjina wonti pitarani.   
\p
\v 3 Ja nau mitani Jorda kaiarani karakara wokarana wonti ja madlentjandru karitjimalkani multibani jaura kaukaubana wonti madlentji kalingala.   
\p
\v 4 Worderu Jesaiani Prophetaia jaurani parai, jeruja jatanani: „Karkanietjaia ngaiala pitarani parai: Kaparaia palto ngankinganimai ja tidna palto nunkani talku ngankanimai.   
\p
\v 5 Wipawipa pratjana palparu pantjila nganai, ja mardawonpa ja dako pratjana waka pantjila nganai; ja kuntikunti talku, ja palto diladila palara pantjila nganai.   
\p
\v 6 Ja kana warupotujeli Godaia Kulkanipirna najila nganai.“   
\p
\v 7 Nulu kana wolarani, tana nunkangu dunkana wonti nunkangundru multibanila manila, jatana wonti: „Wiparaia kuparu worajai! Warlenulu jurangu wondrana wonti japa mindrinanto tirini, nau wokarala nganai?   
\p
\v 8 Madlentjandru karitjinaia tandra talku punkibanau, ja wata wonianau jataterila: «Ngaiana Abraham ngaperi ngaianani ngamalkai;» ngangau ngani jurangu jatai, Goda ngurunguru nganai tanangupini mardandru kupa jiritjibala Abrahamangu.   
\p
\v 9 Kalara matja pita kaparani parai; pita pratjana, wata tandra ngumu punkibanani wokaribala nganai ja turuni worala nganai.“   
\p
\v 10 Ja kana wolarali nina jekibana wonti ja jatana wonti: „Mina ngaiani ngankananto?“   
\p
\v 11 Nulu kalabana wonti ja tanangu jatana wonti: „Warle kati mandru ngamalkai, nulia nunkangu jinkiatimai, nulia wata ngamalkai; ja warle buka ngamalkai, ngankaiatimai bakana jeruja.“   
\p
\v 12 Ja bakana mardatandrakampanietja wokarana wonti multibanila manila, ja nunkangu jatana wonti: „Ngujangujara jinkinietjajai, mina ngaiani ngankananto?“   
\p
\v 13 Nau tanangu jatana wonti: „Kampanimai mina jurangu parai kampananto, wata morla!“   
\p
\v 14 Bakana kalti ja kirraetjali nina jekibana wonti ja jatana wonti: „Ja ngaiani, mina ngaiani ngankananto?“ Ja nau tanangu jatana wonti: „Wata kulno jupanau, ja wata kaukau wapanau, ja murlali ngananau kalalani juranani!“   
\p
\v 15 Kana wolara kalkaterina wonti, ja pratjana ngarali tananali ngundrana wonti Johanningundru, nauja munta Christus nganai kara.   
\p
\v 16 Johannili kalabana wonti ja jatana wonti pratjanani: „Ngato jurana ngapali multibai, ngakangu ngadani kulno wokarala nganai, Nau morla ngurunguru nganai ngakangu; nunkangu ngani wata talku nganai nunkani jinka tidnaputandru dukarala. Nulu jurana multibala nganai Jaolali kulikirieli ja turujeli.   
\p
\v 17 Marani nunkanani pirra nunkani parai, ja Nulu jiraua nunkani darpala nganai, ja buka tandra nunkani kampani pungaia mapala nganai, ja ngurdi Nulu japila nganai turujeli, nau wata paliai.“   
\p
\v 18 Ja morla marapu nulu kurukurubana wonti ja ngantjani jaura kana wolarani kaukaubana wonti.   
\p
\v 19 Herodili kapakaparali, ninapini nulu kurukurubana wonti Herodias nunkanaia nejia noandru, ja madlentji pratjanandru, mina Herodili ngankana wonti,   
\p
\v 20 Pratjanani bakana jenia ngokana wonti, ja Johannes kanjangari pungani widmana wonti.   
\p
\v 21 Jendranguta kana pratjanali multibanila manina wonti, ja bakana Jesujeli multibanila manina wonti, ja Nau ngatjinani pariwilpa piririna wonti.   
\p
\v 22 Ja Jaolali kulikirieli nunkangu ngarina wonti kantji mulapara jeribaka, ja ngaiala kulno pariwilpandru pantjina wonti ja jatana wonti: „Jidni Ngatamura ngantjalu ngankani nganai, jinkangu ngani murlali nganai.“   
\p
\v 23 Ja Jesus matja kilpawoldra pota parkulu marapratjana nganana, Nulu woninani; ja Nau, worderu kanali ngundrana wonti, Ngatamura nganana wonti Josephani, nau Elini.   
\p
\v 24 Nau Matthatani, nau Levini, nau Melchini, nau Janani, nau Josephani.   
\p
\v 25 Nau Mattathiani, nau Amonani, nau Nahumani, nau Eslini, nau Naggaiani.   
\p
\v 26 Nau Maathani, nau Mattathiani, nau Semeiani, nau Josephani, nau Judani.   
\p
\v 27 Nau Joananani, nau Rhesani, nau Zorababelani, nau Salathielani, nau Neriani.   
\p
\v 28 Nau Melchiani, nau Addiani, nau Kosamani, nau Elmodamani, nau Erani.   
\p
\v 29 Nau Joseani, nau Elieserani, nau Jorimani, nau Matthatani, nau Levini,   
\p
\v 30 Nau Simeonani, nau Judani, nau Josephani, nau Jonasani, nau Eliakimani.   
\p
\v 31 Nau Meleani, nau Menani, nau Mattathani, nau Nathanani, nau Davidani.   
\p
\v 32 Nau Jesseni, nau Obedani, nau Boasani, nau Salmonani, nau Nahessonani.   
\p
\v 33 Nau Aminadabani, nau Aramani, nau Esromani, nau Pharesani, nau Judani.   
\p
\v 34 Nau Jakobani, nau Isaakani, nau Abrahamani, nau Tharani, nau Nachorani.   
\p
\v 35 Nau Sarungani, nau Raguani, nau Phalekani, nau Eberani, nau Salahani.   
\p
\v 36 Nau Kainani, nau Arphachsadani, nau Semini, nau Noahni, nau Lamechani.   
\p
\v 37 Nau Methusalahani, nau Enochani, nau Jaredani, nau Mahaleelani, nau Kainani.   
\p
\v 38 Nau Enosani, nau Sethani, nau Adamani, nau Godaia.   
\c 4  
\p
\v 1 Jesus Jaola kulikirieli manamiri Jordan kaiarandru tikana wonti; ja Jaolali nina pitarani wirilkana wonti,   
\p
\v 2 Kutjieli nina pira mara kulno ja ditji marapratjana wontjananto. Ja Nulu tanangupini ditjini panila tajina wonti; ja tana matja mudana, Nau mauali nganana wonti.   
\p
\v 3 Ja kutji nunkangu jatana wonti: „Jidni Godaia Ngatamura ngananani, nunkangupini mardani jatamai, nau bukarinanto.“   
\p
\v 4 Jesujeli kalabana wonti ja nunkangu jatana wonti: „Dakanala parai: Wata windri bukandru kana tepiriai, a‐ai, Godaia jaura pratjanandru.“   
\p
\v 5 Ja kutjieli nina mardawonpa miria taralkana wonti, ja nunkangu nurujeli mitaia kaparaia warupotuja milila wondrana wonti.   
\p
\v 6 Ja kutji nunkangu jatana wonti: „Jinkangu ngato tananapini ngurula pratjana ja tanani pirnala jinkila nganai; ngangau ngakangu naupini matja jinkina, ja nunkangu ngani jertapateriai jinkila, ngato ninaia jinkila nganai.   
\p
\v 7 Jidni ngakangu pantjaterkana ngarinani, jenia pratjana jinkani nganala nganai.“   
\p
\v 8 Ja Jesujeli kalabana wonti ja nunkangu jatana wonti: „Ngakangu ngadaia nganamai, Satanajai! Ngangau dakanala parai: Jidni Godani Kaparani jinkanani ngatjiamai, ja windri nunkangu wodatarana jidni ngamamai.“   
\p
\v 9 Ja nulu nina Jerusalemia wapalkana wonti ja Godaia punga wutjuni terkibana wonti ja nunkangu jatana wonti: „Jidni Godaia Ngatamura ngananani, ninkidandru ngarinalu kulkungamai!   
\p
\v 10 Ngangau dakanala parai: Nulu angelani nunkanani jinkangundru jirijiribala nganai jidnana ngumu ngamalkala;   
\p
\v 11 Ja tanali jidna marali ngamalkala nganai, wata jidni tidna mardali dakaterinanto.“   
\p
\v 12 Ja Jesujeli kalabana wonti ja nunkangu jatana wonti: „Jaura jatai: Goda, Kapara jinkani wata wontjamai!“   
\p
\v 13 Ja kutjieli wontjana pratjana matja mudana, nau nunkangundru kutingana wonti miljaru pilkielu.   
\p
\v 14 Ja Jesus Jaolali ngurungurujeli tikana wonti Galilaiaia, ja pinti nunkangundru karitjinawontiwontikana wonti mita marapuni karakara.   
\p
\v 15 Ja Nulu ngujangujara jinkina wonti jaura pungani tananani, ja tanali pratjanali nina jurakokana wonti.   
\p
\v 16 Ja Nau Nazaretani wokarana wonti, woderi Nau pirnarinala; ja Nau Godaia ditjini jaura pungani wirina wonti worderu milingeru, ja terkakana wonti warapala.   
\p
\v 17 Ja tanali nunkangu Jesaiani jaura jinkina wonti, ja Nulu nina matja pirakana, Nulu mankamankana wonti nina piri, woderi dakanala paranani:   
\p
\v 18 „Kaparaia Jaola ngakangu nganai, jendrania Nulia ngana wiribana wonti ngantjani jaura wangiwangini kaukaubala; ja Nulia ngana jinpana wonti ngara ngaurongauro murlali ngankala ja kanjangarini kurakana kaukaubala, ja butjuni nakaldra najina ngankala; ja tanana tapanto kurakana dadala,   
\p
\v 19 Kaparaia kilpawoldra murlali kaukaubala.“   
\p
\v 20 Ja Nulu jaura matja punmana, ja milini nakaldra jinkina, Nau ngamana ngarina wonti; ja pratjana, jaura pungani ngamana, nina ngurutalpana najina wonti.   
\p
\v 21 Nau wonina wonti tanangu jatala: „Karari jenia jaura jurangu talpani morlalu pantjina warai.“   
\p
\v 22 Ja tanali pratjanali nunkangundru tinkari ngankana wonti ja ngaruparana wonti murlaia jaurandru, jenia nunkani manandru dunkana wonti, ja jatana wonti: „Wata naupini Josephani ngatamura nganai?“   
\p
\v 23 Ja Nau tanangu jatana wonti: „Morlalu jura ngakangu jenia jeribaka jaura jatala nganai: «Kunkiai, munta tepi ngankateriau! Pirnala marapu ngaiani ngarana warai Kapernaum ngurani matja pantjina, ngankau jenia bakana ninkida jinkani ngaperaia ngurani!»“   
\p
\v 24 Nau jatana wonti: „Morlalu ngani jurangu jatai: Wata Propheta kulno kamaneli nganai ngaperaia ngurani.   
\p
\v 25 Morlalu ngani jurangu jatai: Mangawaru marapu nganana wonti Eliani ditjini Israelani, jendranguta pariwilpa ngurunguru nganana wonti kilpawoldra parkulu ja pira mara wora ja kulno, ja mita marapuni maua pirna nganana wonti;   
\p
\v 26 Ja wata tanangundru kulnuja Elias jinpanala, a‐ai, windri mangawaru kulnuja Sidon mitaia Sarepta nguraia.   
\p
\v 27 Ja kana gambanto marapu Israelani nganana wonti Propheta Elisani ditjini, ja wata kulno tanangundru nulu kulirkana wonti, windri Naeman Syriala.“   
\p
\v 28 Ja jaura pungalali pratjanali jenia matja ngarana, tana tiri pirna pantjina wonti.   
\p
\v 29 Ja tana terkakana wonti, ja nina ngurandru tertubana wonti, ja nina marda tuluraia taralkana wonti nunkangupini kalikalini tanani ngura matja wotina, nina tertubana ngarila.   
\p
\v 30 Ja Nau tanangu terti palkingana wonti ja wapana wonti.   
\p
\v 31 Ja Nau Kapernaum nguraia ngarina wonti Galilaia ngura kulnuni, ja Nulu tanangu ngujangujara jinkina wonti Sabbat ditjini.   
\p
\v 32 Ja tana ngaruparana wonti nunkani ngujangujarandru, ngangau jaura nunkani ngurunguru nganana wonti.   
\p
\v 33 Ja jaura pungani kana kulno nganana wonti, nulu kutji murumuru ngamalkana wonti, ja nau ngaiala pirnali maritjina wonti,   
\p
\v 34 Ja jatana wonti: „Burru! Mina ngaianingu ja jinkangu, Jesujai Nazarenalajai! jidni wokarana warai ngaianina teribala? Ngato jidna ngujamai worana jidni nganai, Godaia kulikiri.“   
\p
\v 35 Ja Jesujeli nina daudauana wonti ja jatana wonti: „Ngapuriau ja nunkangundru dunkau!“ Ja kutjieli nina terti worana wonti ja nunkangundru dunkana wonti, ja nina wata patibana wonti.   
\p
\v 36 Ja pratjana japali ngaruparana wonti ja ngankamalina wonti ja jatana wonti: „Mina jaura naupini nganai? ngangau ngurungurujeli ja pirnalali Nulia kutjini murumuruni jirijiribai, ja tana dunkai.“   
\p
\v 37 Ja pinti nunkangundru karitjinawontiwontikana wonti ngura marapuni karakara.   
\p
\v 38 Nau jaura pungandru terkakana wonti ja Simonani pungani wirina wonti; ja Simoni paiara muntja turuturu pirna nganana wonti, ja tana nunkangu ngatjina wonti nankangundru.   
\p
\v 39 Ja Nau nankangu buruna ngarina wonti, ja Nulu muntja turuturuni dikidikibana wonti, ja nau nankangundru puntina wonti; ja nurujeli nani jiritjina wonti ja tanangu mili nganana wonti.   
\p
\v 40 Ja ditji wirinani, pratjana tanali kana muntja muntja nguja pilkipilki marapu ngananani, nunkangu wapalkana wonti. Ja Nau tanangu pratjanani mara kuraterina wonti ja tanana tepi ngankana wonti.   
\p
\v 41 Ja bakana kutji wora marapundru dunkana wonti, tana maritjina wonti ja jatana wonti: „Jidni Christus, Godaia Ngatamura nganai!“ Ja Nulu tanana daudauana wonti ja tanangu wata manuni kurana wonti jatananto, ngangau tana milkila nganana wonti, Nauja Christus nganai.   
\p
\v 42 Ja matja ditjirina, Nau puntina wonti ja palkana wonti pitaraia; ja kana wolarali nina wontina wonti ja nunkangu wokarana wonti, ja tanali ngantjana wonti nina patala, Nau tanangundru puntiati.   
\p
\v 43 Nau tanangu jatana wonti: „Bakana ngura nguruni ngato ngantjani jaura Godaia mililandru kaukaubananto; ngangau jendrania Nulia ngana jinpanala.“   
\p
\v 44 Ja Nulu ngujangujara jinkina wonti Galilaia jaura punga worani.   
\c 5  
\lit (Ngantjani‐jaura G. D. 5. Trinitatis.)  
\p
\v 1 Jendranguta kana wolarali nina jenijenina wonti Godaia jaura ngarala, ja Nau Genezaret pantuni terkana wonti.   
\p
\v 2 Ja Nulu bota mandru panto dirkalani paranani najina wonti; ja parumaninietja dunkana kurana wonti jama kulirkala.   
\p
\v 3 Nau botani kulnuni wirina wonti, Simonanani nunkanani, ja nunkangu ngatjina wonti, nulu ninaia ngalje ngapani tirimalkana ngarinanto; ja Nau ngamana ngarina wonti ja kana wolarani ngujangujara jinkina wonti botandru.   
\p
\v 4 Nulu matja mudana jaura jatana, Nau Simoningu jatana wonti: „Ngapa mandraia bota ngarilkamai, ja jama jurani woranau paru patala!“   
\p
\v 5 Ja Simonali kalabana wonti ja jatana wonti nunkangu: „Kaparajai, ngaiani tinkawirdi jiglerali ngankana warai ja panila patana warai; ja jinkani jaurani ngato jama worala nganai.“   
\p
\v 6 Ja tanali jenia ngankana, tanali paru marapu patana wonti, ja jama tanani puraterina wonti.   
\p
\v 7 Ja tanali kamaneli tanani bota nguruni marali karkana wonti tana wokarananto marangokala; ja tana wokarana wonti ja bota wulana manamiri ngankana wonti ngampu kunakutinanto.   
\p
\v 8 Simon Petrulu jenia najina, nau Jesungu pantjani woraterina wonti ja jatana wonti: „Kaparajai, ngakangundru dunkau, ngangau ngani kana madlentji nganai!“   
\p
\v 9 Ngangau nau japali ngaruparana wonti, ja pratjana nunkangunto, jenia paru marapundru, tanali jelali patana warai.   
\p
\v 10 Jeruja bakana Jakobus ja Johannes Zebedäuni ngatamura wulu Simonani kamaneli. Ja Jesus Simoningu jatana wonti: „Wata japali nganau; ngangau kararindru jidni kana maninietja nganala nganai!“   
\p
\v 11 Ja tanali bota wulana dirkalani tirimalkana wonti ja pratjana worarana wonti ja nunkangu karipaterina wonti.  
\b  
\p
\v 12 Ja jendranguta Nau ngura kulnuni nganana wonti, ja mai, kana kulno gambanto, nulu Jesus najina, nau mudlani woraterina wonti ja nunkangu ngatjina wonti ja jatana wonti: „Kaparajai, jidni jertapaterinani, jidni ngurunguru nganai ngana kulikiri ngankala.“   
\p
\v 13 Ja Nau mara warpina wonti ja nina karakarana wonti ja jatana wonti: „Ngani jertapateriai, kulikiri nganamai!“ ja nurujeli gamba nunkangundru kutingana wonti.   
\p
\v 14 Ja Nulu nunkangu jirijiribana wonti wata kulnuni jenia kaukaubala, a‐ai, wapau, ja Priestani wondrateriau, ja jinkani kulirkanandru jenia poto jinkiau, worderu Mosili jirijiribana wonti, tanangu malka nganananto.   
\p
\v 15 Ja jaura nunkangundru kanani marurina wonti, ja kana wolara nunkangu jurborina wonti nina ngarala, ja tanani muntjandru nunkangundru tepi manila.   
\p
\v 16 Nau kurukurumalkaterina wonti pitarani ja ngatjina wonti.   
\p
\v 17 Ja jendranguta ditji kulnuni Nulu ngujangujara jinkina wonti; ja jerra Pharisaia ja jirijiribani jaura jinkinietja ngamana wonti, tana Galilaia ja Judaia ngura pratjanandru ja Jerusalemingundru wokarana wonti; ja Kaparaia ngurula nganana wonti tanana tepi ngankala.   
\p
\v 18 Ja mai, materali kana kulno wokaralkana wonti turarani pirini paranani, nau tjunduru nganana wonti; ja tanali wontina wonti nina wirilkala ja nunkangu terkibala.   
\p
\v 19 Ja tanali kana wolarandru wata mankamankana wonti, worderu tanali nina wirilkananto, tana punga mangatandrani tarana wonti, ja nina turarani pirieli punga mangatandrandru ngarilkana wonti, tanangu terti Jesungu.   
\p
\v 20 Ja Nulu tanani morlalu ngundrana matja najina, Nau nunkangu jatana wonti: „Kanajai, madlentji jinkani matja worana warai!“   
\p
\v 21 Ja jaura jinkinietjali ja Pharisaiali wonina wonti ngundrala ja jatana wonti: „Worana Naupini nganai, Nulu ngirkibani jaura jatai Godani? Worana ngurunguru nganai madlentji kalingala, kalitakali Goda kulnulu?“   
\p
\v 22 Jesulu tanani ngundrana matja talku ngujamana, Nulu kalabana wonti ja tanangu jatana wonti: „Mina jura ngarali juranali ngundrai?   
\p
\v 23 Mina morla ngaua nganai jatala kara: Madlentji jinkani matja worana, jatala kara: Terkakamai ja wirariau?“   
\p
\v 24 Ngangau jura ngujamananto Kanaia Ngatamurajeli ngurula ngamalkai mitani madlentji worala, Nau tjundurani jatana wonti: „Ngani jinkangu jatai: Terkakamai, turarani piri jinkani patau, ja pungaia jinkanaia tikau!“   
\p
\v 25 Ja nurujeli nau tanangu milkini terkakana wonti, ja nulu turarani piri, nunkangu nau parana, patana wonti, ja pungaia nunkanaia tikana wonti ja Goda jurakokana wonti.   
\p
\v 26 Ja pratjana pirna ngaruparana wonti, ja tanali Goda jurakokana wonti ja japali pirna pantjina wonti ja jatana wonti: „Ngaiani nguja tula karari najina warai.“   
\p
\v 27 Ja ngadani Nau wapana wonti, ja Nulu mardatandrakampanietja najina wonti, tala nunkani Levi, kampani pungani ngamanani, ja Nau nunkangu jatana wonti: „Ngakangu karipateriau!“   
\p
\v 28 Ja nulu pratjana worarana wonti, ja nau terkakana wonti ja nunkangu karipaterina wonti.   
\p
\v 29 Ja Levili nunkangu buka pirna ngankingana wonti pungani nunkanani, ja naka mardatandrakampanietja marapu ja kana nguru nganana wonti, tana tanangunto kurlini ngamana wonti.   
\p
\v 30 Ja jaura jinkinietja ja Pharisaia milini nunkanani kuterina wonti ja jatana wonti: „Minandru jura mardatandrakampanietjani ja kana madlentjani jela tajiai ja tapai?“   
\p
\v 31 Ja Jesujeli kalabana wonti ja tanangu jatana wonti: „Tepieli wata kunki ngundrai, a‐ai, windri muntjali.   
\p
\v 32 Ngani wata wokarana warai kana talku karkala, a‐ai, windri kana madlentji madlentjandru karitjinanto.“   
\p
\v 33 Tana nunkangu jatana wonti: „Minandru Johannini milieli jiglerali milja ngamai ja ngatjiai, jeruja bakana Pharisaiani mili, ja milieli jinkanali tajiai ja tapai?“   
\p
\v 34 Nau tanangu jatana wonti: „Jura ngandandariai noangantjanipirnaia kamaneli milja ngankala, noangantjanipirna tanangu jela ngananani?   
\p
\v 35 Ditji wokarala nganai, tanali noangantjanipirna tanangundru manila nganai, ngadani tanaia milja ngamala nganai tanangupini ditjini.“   
\p
\v 36 Nau tanangu bakana jeribaka jaura jatana wonti: „Wata kulnujeli kati buru tjela kati marrandru kati womalani karpai, a‐ai, jenia wata windri kati marra purateriai, nau kati tjela marra bakana kati womalani wata talku nganai.   
\p
\v 37 Ja bakana wata kulnujeli waina marra junga womalani kurarai, a‐ai, waina marrali junga wakaribaiati, ja wata windri waina baku ngakala nganai, bakana junga tintaterila nganai;   
\p
\v 38 A‐ai, tanali waina marra junga marrani kurarananto, ja pudlana jela kulkananto.   
\p
\v 39 Ja wata kulnujeli, nulu waina warula matja tapana, marra ngantjai; ngangau nau jatai: Nauja warula morla ngumu nganai.“   
\c 6  
\p
\v 1 Jendranguta Nau Sabbat ditji pirna mandrulani buka maruni palkingana wonti; ja milieli nunkanali bukatandra mangatandra wokaribana wonti, ja marali turbana tajina wonti.   
\p
\v 2 Pharisaia palpa jatana wonti tanangu: „Minandru jura jenia ngankai, mina wata talku nganai Sabbat ditjini?“   
\p
\v 3 Jesujeli tanangu kalabana wonti ja jatana wonti: „Jura wata jenia warapanala mina Davidali ngankana wonti, jendranguta nau munta mauali nganana wonti ja tana nunkangunto?   
\p
\v 4 Worderu nau Godaia pungani wirina wonti ja wondrani buka manina wonti ja tajina wonti, ja bakana tanangu nunkangunto jinkina wonti? tanana tajila wata kulnuni manuni kuranala, a‐ai, windri Priestani.“   
\p
\v 5 Ja Nau tanangu jatana wonti: „Kanaia Ngatamura bakana Sabbat ditjia Kapara nganai.“   
\p
\v 6 Jendranguta Sabbat ditji nguruni Nau jaura pungani wokarana wirina wonti ja ngujangujara jinkina wonti; ja naka kana kulno nganana wonti, nau mara ngunari muja nganana wonti.   
\p
\v 7 Jaura jinkinietjali ja Pharisaiali nina kurukuru najinajibana wonti, Nulu Sabbat ditjini tepi ngankala nganai kara; ngangau tanali mankamankananto nunkangundru ngulkuterkala.   
\p
\v 8 Nulu ngundrana tanani ngujamana wonti, ja nunkangu kanani nau mara muja ngananani jatana wonti: „Jiritjiau ja terti terkakamai!“ Nau jiritjina wonti ja terkana wonti.   
\p
\v 9 Jesus tanangu jatana wonti: „Ngato jurana minakulno jakalkai: «Jenia talku nganai Sabbat ditjini, ngumu ngankala kara, madlentji ngankala kara? Mungara kulkala kara, nari ngankala kara?»“   
\p
\v 10 Ja Nulu tanana pratjana najina karitjina wonti ja nunkangu jatana wonti: „Mara ngutateriau!“ Nulu jeruja ngankana wonti, ja nau mara nakaldra tepi nganana wonti mara nguru jeribaka.   
\p
\v 11 Tana tiri pirna pantjina wonti ja ngankamalina wonti, mina tanali Jesungu ngankananto.   
\p
\v 12 Jendranguta tanangupini ditjini Nau mardawonpaia tarana wonti ngatjila; ja Nau tinkawirdi Godani ngatjina wonti.   
\p
\v 13 Ja matja ditjirina, Nulu mili nunkani karkana wonti nunkangu. Ja Nulu tanangundru mili marapratjana ja mandru kalkalkana wonti, tanana Nulu bakana Apostel dikana wonti:   
\p
\v 14 Simon, nina Nulu bakana Petrus dikana wonti, ja Andreas ngatata nunkani, ja Jakobus, ja Johannes, ja Philippus, ja Bartholomäus,   
\p
\v 15 Ja Matthäus, ja Thomas, ja Jakobus Alphäuni ngatamura, ja Simon, nina tanali dikai Zelotes,   
\p
\v 16 Ja Judas Jokobuni ngatamura, ja Judas Ischariot, nau wontawontanietja pantjina wonti.   
\p
\v 17 Ja Nau tanangunto ngarina wonti ja terkana wonti mita palarani, ja nunkani mili wolara, ja kana wolara Judaiandru, ja Jerusalemingundru, ja Tyrus ja Sidon pantudirkala ngurandru, tana wokarana wonti nina ngarala ja tepi manila tanani muntjandru.   
\p
\v 18 Bakana jenipara kana, tanana kutji murumurujeli jupana, tepi pantjina wonti.   
\p
\v 19 Ja kana pratjanali wontina wonti nina karakarala, ngangau ngurula nunkangundru dunkana wonti ja pratjana tepi pantjina wonti.   
\p
\v 20 Ja Nau milki tjenmana wonti milini nunkanani ja jatana wonti: „Murlali pirna jura wangiwangi, ngangau jurangu Godaia milila nganai.   
\p
\v 21 Murlali pirna jura karari mauali ngananani, ngangau jura jerto pantjila nganai; murlali pirna jura karari jindranani, ngangau jura kinkala nganai.   
\p
\v 22 Murlali pirna jura nganai, kana jurangu kalakalarinani, ja jurana pilki ngankanani, ja ngirkibanani, ja jurani tala madlentji jeribaka woranani Kanaia Ngatamurandru.   
\p
\v 23 Nunkangupini ditjini mankianimai ja kulkunganimai; ngangau mai, kalala jurani pirna nganai pariwilpani; ngangau jeruja ngaperali tananali Prophetani ngankana wonti.   
\p
\v 24 Jakajai jurangu poto pirnanto, ngangau jura ngankalkana jurani matja manina.   
\p
\v 25 Jakajai jurangu, jura jerto pirna ngananani, ngangau jura maua ngamala nganai; jakajai jurangu, jura karari kinkanani, ngangau jura ngaurongauro ngamala nganai ja jindrala nganai.   
\p
\v 26 Jakajai jurangu, kana pratjanali jurangundru ngumu jatanani, ngangau jeruja ngaperali tananali jedikantji Prophetani bakana ngankana wonti.   
\p
\v 27 Ngani jurangu, tanalia ngaranani, jatai: Talpala jurani ngantjanimai; ngumu ngankanimai tanangu, tana jurangu kalakalarinani.   
\p
\v 28 Tanali jurangu kalala madlentji kuranani, tanangu kalala ngumu kuranau, ja ngatjianau tanangundru, tanali jurana ngirkibanani.   
\p
\v 29 Warlenulu jidnana ngadla kulno nandrai, nunkangu bakana ngadla kulno jinkiteriau; ja warlenulu jinkani kati pirna maniai, nunkangu bakana kati waka wata ngandrawalkau.   
\p
\v 30 Worananau jinkangu ngatjiai, nunkangu jinkiau; ja nunkangundru, nulu poto jinkani maniai, ninaia wata mamana tikau.   
\p
\v 31 Ja worderu jura ngantjai kanali jurangu ngankananto, jeruja kakana jura tanangu ngankanimai!   
\p
\v 32 Ja jura tanana ngantjanani, tanali jurana ngantjai, mina kalala jura ngamalkai? Ngangau bakana madlentjali tanani ngantjanipirna ngantjai.   
\p
\v 33 Ja jura tanangu ngumu ngankanani, tanali jurangu ngumu ngankai, mina kalala jura ngamalkai? Ngangau bakana madlentjali jenildramata.   
\p
\v 34 Ja jura tanangu woljaia jinkinani, tanangundru jura ngundrai nakaldra manila, mina kalala jura ngamalkai? Ngangau bakana madlentjali kana madlentjani woljaia jinkiai, nakaldra jenia jeribaka manila.   
\p
\v 35 Talpala jurani ngantjanimai, ja ngumu ngankanimai, ja woljaia jinkianimai, ja wata ngundranimai jenia matja tintana; ja kalala jurani pirna nganala nganai, ja jura Kapara pirnaia ngatamura nganala nganai; ngangau Nauja ngumu nganai tanangu jurakokani panini ja kana madlentjani.   
\lit (Ngantjani jaura G. D. 4 Trinitatis.)  
\p
\v 36 Ngangau kalumiltjamiltjarianau, worderu bakana ngaperi jurani kalumiltjamiltjariai!   
\p
\v 37 Wata kalala kuranau, jeruja tanali jurangu wata kalala kurala nganai; wata dikidikibanau, jeruja tanali jurangu wata dikidikibala nganai; madlentji woranau, jeruja tanali jurani madlentji worarala nganai.   
\p
\v 38 Jinkianimai, jeruja jura manila nganai; koko ngumu, matja nankana ngarina, ja wijawijabana, ja manimiri nangaterinanilu tanali jurangu ngalpani jinkila nganai; ngangau mina kokujeli jura jinkiai, jenia jura nakaldra manina tikala nganai.   
\p
\v 39 Ja Nau tanangu jeribaka jaura jatana wonti: Butju ngandandariai butjuni palto wondrala? Wata pudla jela kutuni purila nganai?   
\p
\v 40 Mili wata kaparani nunkanani wiringai; nau matja kiririna, nau kaparani nunkanani jeribaka nganala nganai.   
\p
\v 41 Ja minandru jundru tiwitiwi ngatatani jinkanani milkini najiai, ja pita wondra milkini jinkanani jundra wata najiai?   
\p
\v 42 Worderu jidni ngatatani jinkanani jatananto: ngatatajai, ngato pita tiwitiwi jinkani milkindru giltarananto, ja jundru muntali pita wondra milkini jinkanani wata najiai? Jidni kana jeljujelju, ngopera pita wondra jinkani milkindru giltaramai, ja ngadani jundru ngumu najinanto pita tiwitiwi ngatatani jinkanani milkindru giltarala.   
\b  
\p
\v 43 Ngangau wata pita nindri ngumujeli tandra madlentji punkibai, ja wata pita nindri madlentjali tandra ngumu punkibai.   
\p
\v 44 Ngangau tanali pita pratjana ngujamai tanani tandrandru; ngangau tanali dilkandru wata manawara kampai, ja dilka nindrindru wata waina tandra wokaribai.   
\p
\v 45 Kana ngumujeli nunkani ngara ngumundru ngumula dunkalkai, ja kana madlentjali nunkani ngara madlentjandru madlentji dunkalkai; ngangau ngara mananirindru nunkani mana jatai.   
\p
\v 46 Minandru jura ngana dikai: «Kaparajai, Kaparajai!» ja wata ngankai mina ngani jatai?   
\p
\v 47 Worana ngakangu wokarai, ja jaura ngakani ngarai, ja tanana ngankai; ngato jurangu wondrala nganai worangu jeribaka nauja nganai.   
\p
\v 48 Nau kana kulnuni jeribaka, nulu punga wotinala, nulu mikari bakunala, ja nulu marda kapara marda tulurani kuranala. Ja ngapa kumari matja wokarana, kaiarali nunkangupini pungani tertabanala ja ngandandarinala nina tamburibala, ngangau marda tulurani matja wotinala.   
\p
\v 49 Warle matja ngarana, ja wata ngankana, nau kana kulnuni jeribaka nganai, nulu punga mita ngalarani wotinala marda kapara pani; ja kaiarali nina tertabana, ja nurujeli nau tamburinala, ja nunkanipini pungaia tamburini pirna ngananala.“   
\c 7  
\p
\v 1 Nulu jaura nunkani pratjana kana wolaraia talpani matja mudana, Nau Kapernaum ngurani wirina wonti.   
\p
\v 2 Juljaia kapara kulnuja mili, nina nulu ngantjana wonti, muntja nganana wonti nari kupiri.   
\p
\v 3 Nulu Jesungundru ngarana wonti, ja nulu Judaia kapara nunkangu jinpana wonti, ja nunkangu ngatjina wonti, Nau wokarananto milini nunkanani marangokala.   
\p
\v 4 Tana Jesungu matja wokarana, tana nunkangu parparali ngatjina wonti ja jatana wonti: „Nau talku nganai, jundru nunkangu jenia ngankananto.   
\p
\v 5 Ngangau nulu ngaianana kana wolara ngantjai, ja jaura punga ngaianani nulu wotinala.“   
\p
\v 6 Jesus tanangunto wapana wonti. Ja Nau wata morla worita pungandru nganana, juljaia kaparali kamaeli nunkangu jinpana wonti tana nunkangu jatananto: „Kaparajai, wata ngara patau, ngangau ngani wata talku nganai jidni ngakangu pungani wirinanto.   
\p
\v 7 Jendrania ngani munta waka ngundraterina warai jinkangu wokarala; windri jaura kulno jatamai, ja mili ngakani tepirila nganai.   
\p
\v 8 Ngangau bakana ngani kana nganai ja kaparani wodatarana ngamai, ja ngato mili wolara ngamalkai; ngani nunkangupini jatanani: Wapau, ja nau wapai; ja kulnuni: Kaparau, ja nau wokarai; ja milini ngakanani: Jenia ngankau, ja nulu jenia ngankai.“   
\p
\v 9 Jesujeli jenia ngarana, Nau nunkangundru pirna ngaruparana wonti; ja Nulu najina karitjina wonti kana wolarani, nunkangu karipaterinani, ja jatana wonti: „Ngani jurangu jatai: Wata Israelani ngato jenipara morlalu ngundrana mankamankanala.“   
\p
\v 10 Ja tanali, tanana nulu jinpana, terpina tikana wonti, ja mili muntja tepi mankamankana wonti.   
\lit (Ngantjani jaura G. D. 16. Trinitatis.)  
\p
\v 11 Ja ditji kulnuni Nau ngura kulnuja palkana wonti, Nain tala nunkani; ja mili nunkani marapu, ja kana wolara nunkangunto wapana wonti.   
\p
\v 12 Nau ngura manani karakara wokarana, mai, tanali nari kulno padakana tarana wonti, nunkani ngandria ngatani kunakulno, ja nani mangawaru nganana wonti; ja kana wolara ngurandru nankangunto nganana wonti.   
\p
\v 13 Kaparali nana najina, Nau nankangu kalumiltjamiltjarina wonti ja nankangu jatana wonti: „Wata jindrau!“   
\p
\v 14 Ja Nau karakararina wonti, ja naria pirra patana wonti; ja wilimanietja banbana wonti. Ja Nau jatana wonti: „Teriai, ngani jinkangu jatai, terkakamai!“   
\p
\v 15 Ja narila ngamana tarana wonti, ja wonina wonti jatala. Ja Nulu nina ngandrini nunkanani jinkina tikana wonti.   
\p
\v 16 Ja tana pratjana japali pantjina wonti ja Goda jurakokana wonti ja jatana wonti: „Propheta pirna ngaianangu terti jiritjina warai, ja Goda nunkani kana wolarani wokarana warai.“   
\p
\v 17 Ja nunkani pintipinti karitjinawontiwontikana wonti Judaia mitani paruparu, ja mita pratjanani karakara.  
\b  
\p
\v 18 Ja Johanningu milieli nunkanali jenia pratjana kaukaubana wonti.   
\p
\v 19 Ja Johannili mili nunkani mandru karkana wonti ja pudlana Jesungu jinpana wonti ja jatana wonti: „Naumata jidni, Nau wokarananto kara, kulnuni ngaiani kalkananto?“   
\p
\v 20 Pudla materi nunkangu wokarana wonti ja jatana wonti: „Johannes multibanietjali ngalina jinkangu jinpana warai ja jatana warai: Naumata jidni, Nau wokarananto kara, kulnunni gaiani kalkananto?“   
\p
\v 21 Nunkangupini ditjini Nulu marapu tepi ngankana wonti muntjandru ja jupanandru ja kutji murumurundru, ja butju marapuni Nulu jinkina wonti najinanto.   
\p
\v 22 Ja Jesujeli kalabana wonti ja pudlangu jatana wonti: „Tikalumai ja Johanningu kaukaubalumai, mina judla najila wapaia ja ngarala wapaia: Butjulali najiai, tjundurula wapai, gambala kulikiri pantjiai, talpakurulali ngarai, narila tepi terkakai, wangiwangieli ngantjani jaura ngarai.   
\p
\v 23 Ja murlali pirna naupini nganai, nau ngakangu wata buljubuljuriai.“   
\p
\v 24 Johannini mili matja tikana, Nulu wonina wonti kana wolarani jatala Johanningundru: „Mina najila jura pitaraia palkana paraia? Kalanka kulno watarali wijawijabanani?   
\p
\v 25 Mina najila jura palkana paraia? Kana kulno kati tjankanto? Mai, tana kati tjankani ja pankipankinani, mitaia Kaparaia pungani ngamai.   
\p
\v 26 Mina najila jura palkana paraia? Propheta kulno? Morlalu ngani jurangu jatai: Nau morla pirna nganai Prophetani.   
\p
\v 27 Naupini nau nganai, nunkangundru dakanala parai: Mai, ngato angela ngakani jinkangu mudlani ngopera jinpai, nulu palto jinkani jinkangu ngopera ngankingala nganai.   
\p
\v 28 Ngangau ngani jurangu jatai: Propheta morla pirna tanangundru, widlandru dankanala, Johanningu multibanietjani wata kulno nganai; worananau waka nganai Godaia mililani, nau morla pirna nganai nunkangu.“   
\p
\v 29 Ja kana wolarali, tanali matja ngarana, ja mardatandrakampanietjali Goda talku ngundrana wonti, ja multibanila manina wonti Johannini multibanilali.   
\p
\v 30 Pharisaiali ja jirijiribani jaura ngujangujara jinkinietjali Godaia jertapaterina tanangundru worarana wonti; ngangau tanali wata multibanila manina wonti nunkangundru.   
\p
\v 31 Kapara jatana wonti: „Worangu ngato ninapini kana nguja jeribaka kurananto? Ja worangu tanaia jeribaka nganai?   
\p
\v 32 Tanaia kupa wakani jeribaka nganai, tana jinkimalini pirini ngamai ja karkamaliai ja jatai: Ngaiani jurangu wilpina warai, ja jura wata kilina warai; ngaiani jurangu juajuangana warai, ja jura wata jindrana warai.   
\p
\v 33 Johannes multibanietja wokarana warai, nulu wata buka tajina ja wata waina tapana, ja jura jatai: Nulu kutji ngamalkai.   
\p
\v 34 Kanaia Ngatamura wokarana warai, Nulia tajai ja tapai; ja jura jatai: Najiau! Nauja mirantjatieli tajinietja ja waina tapanietja, mardatandrakampanietjaia ja madlentji ngankanietjaia kamaneli!“   
\p
\v 35 Ja kirilali kalala maniai nunkani kupa pratjanandru.   
\lit (Ngantjani jaura Maria Magdalenaia ditjini.)  
\p
\v 36 Pharisaia kulno nunkangu ngatjina wonti, Nulu nunkangunto tajinanto; ja Nau Pharisaia pungani matja wirina, Nau kurlini ngamana ngarina wonti.   
\p
\v 37 Ja mai, widla kulno ngurani, nani madlentji ngankanietja nganana wonti, nandru morlalu ngujamana wonti, Nau Pharisaia pungani kurlini ngamanani, nandru Alabaster koko kulno gildinto padakana wonti.   
\p
\v 38 Ja nani nunkangu tokuni terkana wonti ja jindranali wonina wonti milkigildieli nankanali tidna nunkani turibala, ja parali nankanali pudlana muja ngankala; ja nandru tidna nunkani manatapana wonti ja gildieli wiribana wonti.   
\p
\v 39 Nulupini Pharisaiali, nulu nina matja karkana, jenia najina, nulu muntali ngundrana wonti ja jatana wonti: „Naupini Propheta ngananani, Nulia ngujamananto worana ja mina widla nania nganai, nandruja ninaia matja karakarana; ngangau nania madlentji ngankanietja nganai.“   
\p
\v 40 Ja Jesujeli nunkangu kalabana wonti ja jatana wonti: „Simoniai! Ngani jinkangu minakulno jatananto.“ Nau jatana wonti: „Ngujangujara jinkinietjajai, jatau!“   
\p
\v 41 Mardatandra jinkinietja kulnuni kana mandru poto wilpanto nganana wonti. Kulno nunkangu 500 mardatandra waka wilpa nganana wonti, ja kulno 50.   
\p
\v 42 Ngangau pndlali wata ngamalkana wonti woljaia jinkila, nulu jenia pudlangu bakujeli jinkina wonti. Jatau, warle pudlangundru nina morla ngantjala nganai?   
\p
\v 43 Simonali kalabana wonti ja jatana wonti: „Ngato ngundrai nulu, nunkangupini nulu morla bakujeli jinkina warai.“ Nau nunkangu jatana wonti: „Jidni talku jatana warai.“   
\p
\v 44 Ja Nulu widla karitjina najina wonti ja Simoningu jatana wonti: „Jundru najiai nanapini widla? Ngani jinkangu pungani wirina warai; jundru ngakangu wata ngapa tidnaia jinkina warai; nandru milkigildieli nankanali tidna ngakani wiribana warai ja parali nankanali muja ngankana warai.   
\p
\v 45 Jundru ngana wata manatapana warai; nani matja wirina, jigleri nganana warai, tidna ngakani tapala.   
\p
\v 46 Gildieli jundru wata ngana mangatandra wiribana warai, nandruja gildieli tidna ngakani wiribana warai.   
\p
\v 47 Jendrangundruja ngani jinkangu jatai: Madlentji nankani marapu matja kalingana, ngangau nandruja pirna ngantjana warai; worangu ngalje matja kalingana, nulu ngalje ngantjai.“   
\p
\v 48 Nau nankangu jatana wonti: „Madlentji jinkani matja kalingana.“   
\p
\v 49 Ja bukaia kamanelieli wonina wonti ngankamalila: „Worana Naupini nganai, Nulia bakana madlentji kalingai?“   
\p
\v 50 Nau widlani jatana wonti: „Morlalu ngundranali jinkanali jidnana kulkana warai; murlali wapamai!“  
\b  
\c 8  
\p
\v 1 Ja jendranguta ditji ngadani Nau wirarina wonti ngura pirnani ja wakani ngujangujara jinkila ja ngantjani jaura Godaia mililandru kaukaubala, ja nunkangunto marapratjana ja mandru.   
\p
\v 2 Ja widla palpa tana tepi pantjinala kutji murumurundru ja muntjandru, Maria, nana tanali dikai Magdalena, nankangundru kutji mara wora ja mandru dunkanala.   
\p
\v 3 Ja Johanna, Chuzani, Herodini kapakaparaia noa, ja Susanna, ja widla palpa morla, tana mili nunkani nganana wonti tanani potundru.   
\lit (Ngantjani jaura G. D. Sexagesimä.)  
\p
\v 4 Kana wolara marapu nunkangu jurborinani ja ngura marapundru nunkangu wokaranani, Nau jeribaka jaurali jatana wonti:   
\p
\v 5 „Jaupanietja wapana wonti paua nunkani jaupala; ja nulu jaupanani, palpa paltuni purina wonti, ja kanali nina nankanankana wonti, ja paiali ngaranalali nina tajina wonti.   
\p
\v 6 Ja palpa marda paltirani purina wonti, ja matja kuririna, mujarina wonti; ngangau tjanka pani nganana wonti.   
\p
\v 7 Ja palpa dilkani terti purina wonti, ja dilkali jela punkana wonti, ja nina ngandrawalkana wonti.   
\p
\v 8 Ja palpa mita ngumuni purina wonti ja punkana wonti ja tandra punkibana wonti 100 potajeli. Nau jenia matja jatana, Nulu karkana wonti: Warle talpa ngamalkai ngarala, nulu ngaraiatimai!“   
\p
\v 9 Ja milieli nunkananli nina jakalkana wonti ja jatana wonti: „Mina jeribaka jaura naupini?“   
\p
\v 10 Nau jatana wonti: „Jurangu matja jinkina warai, jaura kurukuru Godaia mililandru ngujamananto; ja kana nguruni jeribaka jaurali, tanali najinani wata najinanto, ja ngaranani wata ngarananto.   
\p
\v 11 Jenia jeribaka jaurali wondrai: Paua Godaia jaura nganai.   
\p
\v 12 Tana paltuni tanapini nganai, tanali ngarai; ngadani kutji wokarai, ja nulu jaura tanani ngarandru maniai, tanali morlalu ngundraiati ja tepi pantjiati.   
\p
\v 13 Tana paltirani tanapini nganai, tanali matja ngarana, jaura mankinali patai, ta tana kapara pani nganai; ditji palpa tanali morlalu ngundrai, ja wontjanilaia ditjini tana walturiai.   
\p
\v 14 Ja tana dilkani matja purina tanapini nganai, tanali matja ngarana, ja mitaia manujeli ngundranali ja poto pirnali ja pankipankinali wirarina nina ngandrawalkai ja wata tandra punkibai.   
\p
\v 15 Ja tana mita ngumuni tanapini nganai, tanali jaura ngarai ja ngamalkai ngara kulikirieli ja ngumujeli ja wonkieli; ja wonkieli tandra punkibai.  
\b  
\p
\v 16 Wata kulnujeli, nulu praitji matja miribana, nina kokujeli walpadakai, turarani pirini ngarinalu kurai kara, a‐ai, nulu nina praitji potuni kurai, ngangau tanali wirinani praitji najinanto.   
\p
\v 17 Ngangau panila kurukuru nganai, jenia wata tinkari pantjila nganai; bakana panila ngalpurani nganai, tanali jenia wata ngujamala nganai ja tinkari pantjila nganai.   
\p
\v 18 Najianau worderu jura ngarai, ngangau warle ngamalkai, nunkangu Nulia jinkila nganai; ja warle wata ngamalkai, bakana jenia, nulu ngundrai ngamalkala, Nulia nunkangundru manila nganai.“   
\p
\v 19 Ngandri nunkani ja ngatata nunkani nunkangu wokarana wonti, ja tana ngandandarina wonti nunkangu wokarala kana wolarani.   
\p
\v 20 Ja tanali nunkangu kaukaubana wonti ja jatana wonti: „Ngandri jinkani ja ngatata jinkani palarani terkala wapaia ja jertapaterila wapaia jidna najila.“   
\p
\v 21 Nulu kalabana wonti ja tanangu jatana wonti: „Ngandri ngakani ja ngatata ngakani tanapini nganai, tanali Godaia jaura ngarai ja ngankai.“   
\p
\v 22 Ja jendranguta ditji kulnuni Nau ja mili nunkani botani wirina wonti; ja Nau tanangu jatana wonti: „Ngaiana pantuni jerankari dirkalaia pararananto;“ ja tana dirkalandru wapana wonti.   
\p
\v 23 Tana botali matja wapana, Nau mukaturarana wonti. Ja watara wondru wokarana wonti, ja bota manamiririna wonti, ja tana japali pantjina wonti.   
\p
\v 24 Tana karakara wokarana wonti nina jiritjibala ja jatana wonti: „Kaparajai, Kaparajai, ngaiana tintateriati!“ Nau matja jiritjina, Nulu watara ja mandikila dikidikibana wonti, ja tana ngapurina wonti, ja dalpura pirna pantjina wonti.   
\p
\v 25 Nau tanangu jatana wonti: „Woderi jurani morlalu ngundrana nganai?“ Tana japali pirna ngaruparana wonti ja ngankamalina wonti: „Worana Naupini nganai, Nulu bakana watarani ja ngapani daudauai, ja tana nunkangu pankiai?“   
\p
\v 26 Ja tana Gadarena mitani pararana wonti Galilaiankari.   
\p
\v 27 Nau mitaia matja dunkana tarana, nunkangu kana kulno ngurandru mandurina wonti, nulu ditji marapu kutji murumuru ngamalkana wonti, ja nau wata kati widmaterina wonti ja wata pungani ngamana wonti, a‐ai, narikutuni.   
\p
\v 28 Nulu Jesus najina, Nau maritjina wonti ja nunkangu woraterina wonti ja ngaiala pirnali jatana wonti: „Mina ngakangu ja jinkangu, Jesu, Goda Kapara pirnaia Ngatamurajai? Ngani jinkangu ngatjiai, ngana wata jupau!“   
\p
\v 29 Ngangau Nulu kutji murumuruni jirijiribana wonti kanandru dunkananto; ngangau ditji marapu nulu nina nunkangunto wapalkana paraia, ja tanali nina kanjangarieli dupudupu ngankana paraia, ja bakana tanali nina workamantrana paraia; ja nulu jenia ngurula matja wokaribana, kutjieli nina pitaraia wirilkana wonti.   
\p
\v 30 Jesulu nina jakalkana wonti ja jatana wonti: „Mina tala jundru ngamalkai?“ Nau jatana wonti: „Legiona:“ ngangau kutji marapu nunkangu wirinala.   
\p
\v 31 Ja nau nunkangu ngatjina wonti, Nulu tanangu wata jirijiribananto ngarinaluja ngarila.   
\p
\v 32 Naka piki ngami pirna nganana wonti, tana mardawonpa kalikalini marakana wonti. Ja tana nunkangu ngatjina wonti, Nulu tanangu manuni kurananto, tanangupini wirinanto. Ja Nulu tanangu jenia manuni kurana wonti.   
\p
\v 33 Ja tana kutji murumuru kanandru matja dunkana, tana pikini wirina wonti; ja piki ngami mardawonpa kalikalini ngapani kalikalibakana wonti, ja ngapali palipalina wonti.   
\p
\v 34 Piki ngamalkanietjali jenia najina, mina pantjina warai, tana japa mindrina wonti ja ngura pirnani ja wakani jenia kaukaubana wonti.   
\p
\v 35 Tana dunkana wonti najila mina pantjina warai; ja tana Jesungu wokarana wonti, ja nina kana Jesuja tidnani ngamanani mankamankana wonti, nunkangundru kutji wora dunkana warai, nau kati matja widmaterina ja tjuru ngumu ngamalkana; ja tana japali pantjina wonti.   
\p
\v 36 Tanali jenia najina wonti tanangu kaukaubana wonti, worderu nau kutjila tepi pantjina warai.   
\p
\v 37 Ja kana wolarali Gadarenaia wondirani nunkangu ngatjina wonti, Nau tanangundru puntinanto, ngangau tana japali pirna pantjina wonti; ja Nau botani wirina wonti ja nakaldra karitjina tikana wonti.   
\p
\v 38 Nulupini kanali, nunkangundru kutji wora dunkana warai, nunkangu ngatjina wonti, nunkangu jela ngamala. Ja Jesujeli nina jinpana wonti ja jatana wonti:   
\p
\v 39 „Pungaia jinkanaia tikamai, ja kaukaubamai, mina pirnala Godali jinkangu ngankana warai.“ Ja nau wapana wonti ja ngurani paruparu parparali kaukaubana wonti, mina pirnala Jesujeli nunkangu ngankana warai.   
\p
\v 40 Jendranguta Jesus tikana wonti, ja kana wolarali nina patana wonti, ngangau pratjanali nunkangu kalkana wonti.   
\p
\v 41 Ja mai, kana kulno wokarana wonti, tala nunkani Jairus, nau jaura pungaia kapara nganana wonti, ja nau Jesungu tidnani woraterina wonti ja nunkangu ngatjina wonti, Nau nunkangu pungani wirinanto.   
\p
\v 42 Ngangau nulu mankara ngatamura kulno ngamalkana wonti, nani kilpawoldra marapratjana ja mandru tepi, ja parana wonti ngara wordu. Nau wapanani kana wolarali nina jenina wonti.   
\p
\v 43 Ja widla kulnujeli kumaranto kilpawoldra marapratjana ja mandru nganana wonti, ja nandru poto nankani pratjana kunkini kalala jinkina wonti, ja wata kulnujeli nana tepi ngankana wonti.   
\p
\v 44 Nani nunkangu tokuni wokarana wonti, ja kati jelpi nunkani karakarana wonti; ta nurujeli kumari tjiri nankani mudana wonti.   
\p
\v 45 Ja Jesus jatana wonti: „Warle ngana karakarana warai?“ Pratjana pani pataterinani, Petrus ja tana nunkangunto jatana wonti: „Kaparajai, kana wolarali jidna jeniai ja nankai, ja jidni jatai: Warle ngana karakarana warai?“   
\p
\v 46 Jesus jatana wanti: „Kulnujeli ngana karakarana warai, ngangau ngato ngujamai ngurula ngakangundru dunkana warai.“   
\p
\v 47 Widlali matja najina, nani wata kurukuru nganai, nani ngarranali wokarana wonti ja woraterina wonti ja kana wolarani nunkangu kaukaubaterina wonti, minandru nandru nina karakarana warai, ja worderu nani nurujeli tepi pantjina warai.   
\p
\v 48 Nau nankangu jatana wonti: „Murlali nganamai ngatamurajai, morlalu ngundranali jinkanali jidna tepi ngankana warai, murlali wapau!“   
\p
\v 49 Nau jenia jatana, jaura pungaia kapara mili kulno wokarana wonti ja nunkangu jatana wonti: „Ngatamura mankara jinkani matja nari, ngujangujara jinkinietja wata ngarapatipatibau!“   
\p
\v 50 Jesujeli jenia ngarana, Nulu nunkangu kalabana wonti ja jatana wonti: „Wata japali nganau, windri morlalu ngundrau, ja nani tepirila nganai.“   
\p
\v 51 Nau pungani wirina, Nulu wata kulnuni manuni kurana wonti wirinanto, windri Petrungu ja Johanningu ja Jakobungu ja kupaia ngaperani ja ngandrini.   
\p
\v 52 Pratjana jindrana wonti ja nankangundru ngaurongauro nganana wonti. Nau jatana wonti: „Wata jindranau! Nania wata nari, a‐ai, nania windri mukaturarai.“   
\p
\v 53 Ja tana nunkangu kinkana wonti, ngangau tana ngujamana wonti nani nari.   
\p
\v 54 Nulu tanana pratjana narrana wonti, ja Nulu nana mara patana wonti ja karkana wonti ja jatana wonti: „Kupajai, terkakamai!“   
\p
\v 55 Ja mungara nankani tikana wonti, ja nani nurujeli jiritjina wonti. Ja Nulu jirijiribana wonti nana buka jinkinanto.   
\p
\v 56 Ja ngaperi ja ngandri nankani pirna ngaruparana wonti. Ja Nulu tanangu jirijiribana wonti wata kulkuni jenia kaukaubananto mina pantjina warai.   
\c 9  
\p
\v 1 Nulu mili marapratjana ja mandru nunkani karkana wonti, ja tanangu pirnala ja ngurula jinkina wonti kutji murumuru pratjanaia, ja muntjandru tepi ngankala.   
\p
\v 2 Ja Nulu tanana jinpana wonti Godaia mililandru ngujangujara jinkila, ja kana muntja tepi ngankala.   
\p
\v 3 Ja Nau tanangu jatana wonti: „Panila paltuni manianimai; wata wonapita, wata billi, wata buka, wata mardatandra; jura bakana wata kati mandru ngamalkananto.   
\p
\v 4 Ja mina pungani jura matja wirina, naka ngamanimai, ja nakandru wirarianimai.   
\p
\v 5 Ja worderuntjali jurana wata patala nganai, nunkangupini ngurandru dunkanimai, ja bakana puturu jurani tidnandru kantikantianimai malka nganala tanangu.“   
\p
\v 6 Tana wapana kurana wonti, ja ngura kulno ja kulnuni palkingana wonti, paruparu ngantjani jaura kaukaubala ja tepi ngankala.   
\p
\v 7 Herodili mitaia kapakaparali pratjana ngarana, mina nunkangundru pantjinani, nau japali nganana wonti, ngangau palpa jatana wonti: „Johannes narindru matja jiritjina.“   
\p
\v 8 Palpa: „Elias wondraterina warai;“ palpa: „Propheta kulno warula narindru matja jiritjina.“   
\p
\v 9 Ja Herodes jatana wonti: „Nina Johannes mangatandra ngato wokaribana paraia: ja worana Naupini nganai, nunkangundru ngato jenia ngarai?“ Ja nulu ngantjana wonti nina najila.   
\p
\v 10 Ja Apostela matja tikana, tanali nunkangu kaukaubana wonti, mina pirnala tanali ngankanala; ja Nulu tanana tjirimalkana wonti, ja ngura kulnuja, tala nunkani Bethsaida, kutingana wonti.   
\p
\v 11 Kana wolarali jenia ngujamana, tana nunkangu karipaterina wonti; ja Nulu tanana patana wonti, ja tanangu Godaia mililandru kaukaubana wonti, ja kana muntja Nulu tepi ngankana wonti.   
\p
\v 12 Ditji kunarkuni mili marapratjana ja mandru nunkangu wokarana wonti ja jatana wonti: „Kana wolara jinpau, ngangau tanaia ngura pirnani ja wakani wirinanto bukaia; ngangau ngaiana ninkida pitarani nganai.“   
\p
\v 13 Nau tanangu jatana wonti: „Jura tanangu jinkianau tajinanto!“ Tana jatana wonti: „Ngaiani ninkida windri buka ngunku mara wora ja paru mandru ngamalkai; ngaiani kara wapananto, ja tanangupini kana wolarani buka burungankananto?“   
\p
\v 14 Ngangau tana kana 5000 nganana wonti. Nau milini nunkanani jatana wonti: „Tanaia ngamana ngarinanto witta kulno ja kulno, milingeru marapratjana pota mara wora.“   
\p
\v 15 Ja tanali jeruja ngankana wonti, ja pratjana ngamana ngarina wonti.   
\p
\v 16 Nulu buka ngunku mara wora ja paru mandru patana wonti ja pariwilpani najina tarana wonti, ja tanana ngurungutana wonti, ja tanana wokaribana wonti, ja milini nunkanani jinkina wonti, tana kana wolarani jinkinanto.   
\p
\v 17 Ja tanali tajina wonti ja jerturina wonti, ja tanali buka worduwordu kampana wonti billi marapratjana ja mandru manamiri.   
\p
\v 18 Ja jendranguta Nau kulnulu ngatjinani, mili nunkangu jurborina wonti; ja Nulu tanana jekibana wonti ja jatana wonti: „Mina kana jatai, worana ngani?“   
\p
\v 19 Tanali kalabana wonti ja jatana wonti: „Johannes multibanietja; palpa Elias; palpa jatai Propheta kulno warula matja jiritjina.“   
\p
\v 20 Nau tanangu jatana wonti: „Mina jura jatai, worana ngani nganai?“ Petrulu kalabana wonti ja jatana wonti: „Godaia Christus.“   
\p
\v 21 Nulu tanana daudauana wonti, ja tanangu jirijiribana wonti, wata kulnuni jenia kaukaubala.   
\p
\v 22 Nau jatana wonti: „Kanaia Ngatamura pirna ketjaketjananto, ja pinaru worali ja Priesta pirnali ja jaura jinkinietjali ninaia worala nganai ja nari ngankala nganai, ja ditjini parkulani Nau jiritjila nganai.“   
\p
\v 23 Nau pratjanani jatana wonti: „Warle ngantjai ngakangu karipaterila, nau munta panila ngundrateriatimai, ja nulu kunarku nunkani ditji pratjanani maniatimai, ja ngakangu karipateriatimai.   
\p
\v 24 Ngangau warle tepi nunkani ngantjai kulkala, nulu nina tintala nganai; ja warle tepi nunkani tinkai ngakangundru, nulu nina kulkala nganai.   
\p
\v 25 Ngangau jenia kanani ngumu nganai kara, nulu mita maru maninani, ja munta tintaterinani kara, nandraterinani kara?   
\p
\v 26 Ngangau worananau ngakangundru ja ngakani jaurandru nintali nganai, nunkangundru bakana Kanaia Ngatamura nintali nganala nganai, Nau nunkanani, ja ngaperaia, ja angela kulikiria pirnalani wokarala nganai.   
\p
\v 27 Morlalu ngani jurangu jatai: Tanangundru palpa, ninkida terkala wapaia, tanalipini nari wata wontjala nganai, tanali Godaia milila najinantulu.“   
\p
\v 28 Jendranguta Nulu tanapini jaura matja mudana, ditji mara wora ja parkulani, Nulu Petrus ja Johannes ja Jakobus patana wonti, ja mardawonpaia tarana wonti ngatjila.   
\p
\v 29 Ja Nau ngatjinani, mudla nunkani njeranjerarina wonti, ja kati nunkani bulurina wonti ja kintjalkururina wonti.   
\p
\v 30 Ja mai, kana mandru nunkangu ngankamalina wonti, pudla Moses ja Elias nganana wonti.   
\p
\v 31 Pudla pirnalali wondraterina wonti, ja mudana nunkani kaukaubana wonti, nina Nulu morlalu ngankananto Jerusalemini.   
\p
\v 32 Petrus ja pudla nunkangunto jindina wonti; ngangau tanali matja tepi ngamana, tanali pirnala nunkani najina wonti, ja kana mandru nunkangunto terkanani.   
\p
\v 33 Ja jendranguta pudla nunkangundru kutinganani, Petrus Jesungu jatana wonti: „Kaparajai, ninkida ngaianangu ngumu nganai; ngaiani punga parkulu wotila nganai, jinkani kulno, Mosini kulno, ja Eliani kulno;“ ja nau ko nganana wonti, mina nau jatai.   
\p
\v 34 Nau jenia jatana, talara palku wokarana wonti ja tanana walpadakana wonti; ja tana japali pirna pantjina wonti, pudla talara palkuni wirinani.   
\p
\v 35 Ja ngaiala kulno talara palkundru pantjina wonti ja jatana wonti: „Naupini Ngatamura ngantjalu ngakani nganai; ninaia ngaraiatinimai!“   
\p
\v 36 Ja nau ngaiala pantjinani, tanali Jesus kulnulu mankamankana wonti. Ja tana ngapu nganana wonti, ja wata kulnuni tanangupini ditjini kaukaubana wonti nunkangundru, mina tanali matja najina.   
\p
\v 37 Jendranguta ditji kulnuni, tana mardawonpandru matja ngarina, kana wolara nunkangu jurborina wonti.   
\p
\v 38 Ja mai, kana kulno kana wolarandru maritjina wonti ja jatana wonti: „Ngujangujara jinkinietjajai, ngani jinkangu ngatjiai, ngatamura kunakulno ngakani najiau.   
\p
\v 39 Ja mai, kutjieli nina patai, ja nurujeli nau maritjiai, ja nulu nina diadialkai, jeruja nau ngaltja wiltjiwiltjiriai, ja mankali nau nunkangundru kutingai ja nandrai.   
\p
\v 40 Ja ngani milini jinkanani ngatjina warai, tanali nina dunkalkananto, ja tanaia ngandandarina warai.“   
\p
\v 41 Jesujeli kalabana wonti ja jatana wonti: „Jidni nguja gilbarinietja ja tjautjau, wintaranaia ngani jurangu jela nganai? Wintaranaia ngato jurana ngamalkala nganai? Ngatamura jinkani ninkidani padakanimai!“   
\p
\v 42 Nau karakara wokaranani, kutjieli nina patana wonti, ja nina matala ngankana wonti; ja Jesujeli kutji murumuru dikidikibana wonti, ja nina kanku tepi ngankana wonti, ja nina ngaperani nunkanani nakaldra jinkina tikana wonti.   
\p
\v 43 Pratjana Godaia pirnalandru ngaruparana wonti. Tana pratjana ngaruparanani pratjanandru, mina Jesujeli matja ngankana, Nau milini nunkanani jatana wonti:   
\p
\v 44 „Tananapini jaura talpali patanimai; ngangau tanali Kanaia Ngatamura kana marani ngulkujeli jinkila nganai.“   
\p
\v 45 Tanali ninapini jaura wata ngujamana wonti, ja jenia tanangu kurukuru nganana wonti, tanali jenia wata patananto; ja tana japali nganana wonti, nina jenia jaurandru jakalkala.   
\p
\v 46 Ja tanali ngundrana wonti, worana morla pirna nganai tanangundru.   
\p
\v 47 Jesujeli tanani ngarali ngundranani ngujamana, Nulu kupa waka kulno patana wonti, ja nina nunkangu karakara terkibana wonti.   
\p
\v 48 Ja tanangu jatana wonti: „Warle ninapini kupa patai ngakani talandru, nulia ngana patai; ja warle ngana patai, nulia ninapini patai, Nulia ngana jinpanala. Ngangau worana jurangundru pratjanani waka nganai, nauja pirna nganala nganai.“   
\p
\v 49 Johannili kalabana wonti ja jatana wonti: „Kaparajai, ngaiani kulno najina paraia, nulu talani jinkanani kutji dunkalkanani, ja ngaiani nina daudauana paraia, ngangau nau wata ngaianingunto wapai.“   
\p
\v 50 Ja Jesus nunkangu jatana wonti: „Wata daudauanau; ngangau worana wata tula ngaianani nganai, nau kamaneli ngaianani.“   
\p
\v 51 Jendranguta, ditji nunkani miririnani, nau puntina wonti, ja Nulu mudlamudla kurana wonti Jerusalemia palkala.   
\p
\v 52 Ja Nulu mili jinpana wonti manununkaninkari, ja tana palkana wonti Samarita ngura wakaia, nunkani ngankingala.   
\p
\v 53 Ja tanali nina wata patana wonti, ngangau Nulu mudlamudla kurana wonti Jerusalemia palkala.   
\p
\v 54 Ja milieli nunkanali Jokabus ja Johannes jenia najina, pudla jatana wonti: „Kaparajai, jidni jertapaterinani, ngali jirijiribananto turu pariwilpandru godananto, tanana julkananto, worderu Eliali ngankana wonti?“   
\p
\v 55 Jesujeli najina karitjina wonti ja pudlana daudauana wonti ja jatana wonti: „Judla wata milkila, mina Jaolaia kupa judla nganai.   
\p
\v 56 Ngangau Kanaia Ngatamura wata wokarana warai kanaia tepi teribala, a‐ai, kulkala.“ Ja tana ngura kulnuja palkana wonti.   
\p
\v 57 Jendranguta tana paltuni wapanani, kulno nunkangu jatana wonti: „Ngani jinkangu karipaterila nganai, woderi jidni paruparu wapanani, Kaparajai.“   
\p
\v 58 Ja Jesus nunkangu jatana wonti: „Kintala jampali minka ngamalkai, ja paiali ngaranani kunjila ngamalkai, ja Kanaia Ngatamurajeli piri pani ngamalkai, wodajeri kukadi terkala.“   
\p
\v 59 Nau kulnuni jatana wonti: „Ngakangu karipateriau!“ Nau jatana wonti: „Kaparajai, ngakangu manuni kurau, ngani ngopera wopananto ngaperi ngakani todila.“   
\p
\v 60 Jesus nunkangu jatana wonti: „Narieli muntali nari tanani todinanto, jidni wapau, ja Godaia mililandru kaukaubau.“   
\p
\v 61 Bakana kulno jatana wonti: „Ngani jinkangu karipaterila nganai, Kaparajai, ngopera ngakangu manuni kurau, ngani ngakani nguralandru daninanto, tana ngakani pungani ngamai.“   
\p
\v 62 Jesus nunkangu jatana wonti: „Wata kulno, nulu mara nunkani mita bakuni potuni kurai, ja worakalina tikana najiai, talku nganai Godaia mililani.“   
\c 10  
\p
\v 1 Ngadani Kaparali mili marapratjana pota mara wora ja mandru kalkalkana wonti, ja tanana mandru ja mandru nunkangu ngopera jinpana wonti ngura pirnaia ja wakaia, woderi Nau jertapaterina wonti munta wokarala.   
\p
\v 2 Nau tanangu jatana wonti: „Kampananto marapu parai, ja ngankanietja windri ngalje; jendrania Kampani Kaparani ngatjianau, Nulia ngankanietja worana jinpananto nunkani kampanaia.   
\p
\v 3 Wapanau! mai, ngato jurana jinpai tjipi kuparu jeribaka pandipandi mandrani.   
\p
\v 4 Wata billi, wata pailtji, ja wata tidnaputa mandranau; ja bakana wata kulnuni mandurini jaura jinkianau.   
\p
\v 5 Mina pungani jura wirila nganai, ngopera jatanau: «Murla nunkangupini pungani nganaiatimai!»   
\p
\v 6 Ja naka murlaia kupa ngananani, jurani mura nunkangu wokarala nganai; ja pani, nau jurangu tikala nganai.   
\p
\v 7 Nunkangupini pungani ngamanimai; tajianimai ja tapanimai mina tanali ngamalkai; ngangau ngankanietjani talku nganai nunkani kalala; wata punga kulnundru punga nguruja wapanau.   
\p
\v 8 Ja mina ngurani jura wirila nganai, ja tanali jurana patanani, naka tajianimai mina tanali jurangu kurai.   
\p
\v 9 Ja nunkangupini ngurani kana muntja tepi ngankanau, ja tanangu jatanau: Godaia milila jurangu karakara wokarala wapaia.   
\p
\v 10 Mina ngurani jura wirila nganai, ja tanali jurana wata patanani, tanani paltuni dunkanimai ja jatanimai:   
\p
\v 11 Bakana nina puturu, nau jurani ngurandru ngaianangu tidnani parai, ngaiani jurangu kantikantiai; windri jenia ngujamanau, jurangu Godaia milila karakara wokarala wapaia.   
\p
\v 12 Ngani jurangu jatai: Sodom mitalali kalala morla waka manila nganai kalala ditjini nunkangupini ngurani.   
\p
\v 13 Jakajai jinkangu Choraziniai! Jakajai jinkangu Bethsaidajai! Ngangau Tyrus ja Sidon ngurani jenia pirnala pantjinani, judlangu pantjinala, pudla nurujeli kati murumurunto ja turuputani madlentjandru karitjinanto.   
\p
\v 14 Tyrus ja Sidon mitalali kalala morla waka manila nganai kalala ditjini, judlangu.   
\p
\v 15 Ja jidni Kapernaum, jidni miririna pariwilpaia, turujelu jidni ngarila nganai!   
\p
\v 16 Warle jurana ngarai, nulu ngana ngarai; ja warle jurana worarai, nulu ngana worarai; ja warle ngana worarai, nulu ninaia worarai, Nulia ngana jinpanala.“   
\p
\v 17 Tana marapratjana pota mara wora ja mandru mankinali tikana wonti ja jatana wonti: „Kaparajai, bakana kutji wora ngaianingu jinkani talani wodatarana ngamana warai.“   
\p
\v 18 Nau tanangu jatana wonti: „Ngato Satan talara praitji jeribaka pariwilpandru ngarinani najina warai.   
\p
\v 19 Mai, ngato jurangu ngurula jinkiai tjutjuni ja katninuntini nankana wirarinanto, ja talpalaia ngurulani pratjanani, ja tanali jurana wata jupala nganai.   
\p
\v 20 Wata jendrangundruja mankianimai, jurangu kutji wora wadatarana ngamai, a‐ai, jendrania mankianimai, ngangau tala jurani pariwilpani matja dakana parai.“   
\p
\v 21 Nunkangupini ditjini Jesus Jaolali mankina wonti ja jatana wonti: „Ngato Jidnana Ngaperiai, Kapara pariwilpaia ja mitaia, jurakokala wapaia; ngangau Jundru jenia kana kirini ja ngujamanietjani kutibana warai ja kupani tinkari ngankana warai; kau Ngaperiai, jeruja jinkangu manju nganana wonti.   
\p
\v 22 Ngaperali ngakanali ngakangu warupoto jinkina wonti; ja wata kulnujeli ngujamai, worana Ngatamura nganai, windri Ngapili, ja worana Ngili nganai, windri Ngatamurajeli, ja worangu Ngatamurajeli ngantjai jenia tinkari ngankala.“   
\lit (Ngantjani‐jaura G. D. 13. Trinitatis.)  
\p
\v 23 Ja Nulu mili mudlakalkana wonti ja jatana wonti: „Murlali pirna tana milki, tanali najiai mina jura najiai!   
\p
\v 24 Ngangau ngani jurangu jatai: Propheta ja mitaia kapara marapujeli wolkareli nganana wonti jenia najila mina jura najiai, ja wata najina wonti; ja jenia ngarala mina jura ngarai, ja wata ngarana wonti.“   
\p
\v 25 Ja mai, jirijiribani jauraia ngujangujara jinkinietja terkakana wonti ja jatana wonti: „Ngujangujara jinkinietjajai, mina ngato ngankananto tepi ngurali maratunka ngamalkala?“   
\p
\v 26 Nau nunkangu jatana wonti: „Mina jirijiribani jaurani dakanala parai? Worderu jundru warapai?“   
\p
\v 27 Nulu kalabana wonti ja jatana wonti: „Jundru Goda Kapara jinkani ngantjamai ngarali jinkanali, mungarali jinkanali, ja manujeli jinkanali; ja ngurala jinkani jidna munta jeribaka.“   
\p
\v 28 Nau nunkangu jatana wonti: „Jundru talku kalabana warai; jenia ngankau, ja jidni tepi ngamala nganai!“   
\p
\v 29 Nau jertapaterina wonti talku ngankaterila ja Jesungu jatana wonti: „Worana ngurala ngakani nganai?“   
\p
\v 30 Jesujeli kalabana wonti ja jatana wonti: „Kana kulno Jerusalemingundru Jerichoja ngarina wonti, ja watawatali maninietjali kati nunkani dukarana wonti ja nina nandrana wonti ja kutingana wonti, ja nina ngampu nari worarana wonti.   
\p
\v 31 Priesta kulno nunkangupini paltuni manubaku ngarina wonti; ja nulu nina najina, nau wiringana wonti.   
\p
\v 32 Jeruja bakana Levita kulno nunkangupini pirini wokarana wonti, ja nina najina wonti ja wiringana wonti.   
\p
\v 33 Ja Samarita kana palkana wonti ja nina dankana wonti, ja nulu nina najina, nau kalumiltjamiltjarina wonti.   
\p
\v 34 Ja nau karakararina wonti, ja nulu nina tapa karana wonti, ja gildi ja waina nangana wonti; ja nulu nina ngantini nunkanani kurana tarana wonti ja wapalkana wonti nguraia, ja nina ngamalkana wonti.   
\p
\v 35 Ja nguramaranani nulu mardatandra mandru dukarana wonti ja punga ngamalkanietjani jinkina kurana wonti ja jatana wonti: «Ninaia ngamalkau, ja jundru morla tintanani, ngato jinkila tikala nganai ngani tikana.»   
\p
\v 36 Mina jundru ngundrai, worana tanangu parkulani ngurala nganana wonti nunkangu, nau watawatali maninietjani matja purina?“   
\p
\v 37 Nau jatana wonti: „Naupini kalumiltjamiltjarinala nunkangu.“ Ja Jesus nunkangu jatana wonti: „Wapau, ja nunkangupini jeribaka ngankamai!“   
\b  
\p
\v 38 Jendranguta tana palkana, Nau ngura kulnuni wokara wonti; ja widla kulnujeli, tala nankani Martha, nina pungani nankanani patana wonti.   
\p
\v 39 Ja nandru kaku kulno ngamalkana wonti, tala nankani Maria, nani bakana ngamana ngarina wonti Jesungu tidnani jaura nunkani ngarila.   
\p
\v 40 Marthandru jiglerali ngankana wonti nunkangu mili nganala. Nani wokarana wonti ja jatana wonti: „Kaparajai, jenia jinkangu baku nganai, kakujeli ngakanali ngana kulnulu worarai mili nganala? Jatamai nankangu, nandruja ngakangu marangokananto!“   
\p
\v 41 Jesujeli kalabana wonti ja jatana wonti: „Marthajai, Marthajai, jundru marapuni manujeli ngundrai ja ngankai.   
\p
\v 42 Kulno jundru ngamalkananto. Mariandru poto ngumu kalkalkana warai, jenia wata kulnujeli nankangundru manila nganai.“   
\c 11  
\p
\v 1 Ja jendranguta Nau piri kulnuni nganana wonti ja ngatjina wonti, ja Nau matja mudana, mili nunkani kulno nunkangu jatana wonti: „Kaparajai, ngaianina kiri ngankau ngatjinanto, worderu bakana Johannili mili nunkani kiri ngankanala.“   
\p
\v 2 Nau tanangu jatana wonti: „Jura ngatjinani jeruja jatanimai: Ngaperi ngaianini jidni pariwilpani ngamala wapaia, tala jinkani kulikiri pantjiatimai, milila jinkani wokaraiatimai, jertapaterina jinkani pantjiatimai, worderu pariwilpani jeruja bakana mitani.   
\p
\v 3 Buka ngaianini ngaianingu karari jinkiamai.   
\p
\v 4 Madlentji ngaianini woramai, ngangau bakana ngaiani muntali nunkangu worai, nulu ngaianingu madlentji ngankanani, ja wata ngaianina wontjanilani wirilkamai, a‐ai, madlentjani ngaianina kulkamai.“   
\p
\v 5 Nau tanangu jatana wonti: „Warle jurangundru kamaneli kulno ngamalkai, ja nunkangu tinka terti wapala nganai, ja nunkangu jatala nganai: Kamaneliai, buka ngunku parkulu ngakangn woljaia jinkiamai.   
\p
\v 6 Ngangau kamaneli kulno ngakani paltundru ngakangu wirina warai, ja ngato panila ngamalkai nunkangu kurala.“   
\p
\v 7 Ja nulu mandrani nunkangu kalabanani ja jatanani: „Wata ngana jupau; mana matja nguru nganai, ja kupa ngakani ngakangunto turarani pirini turarai; ngani ngandandariai jiritjila ja jinkangu jinkila.“   
\p
\v 8 Ngani jurangu jatai: „Nau bakana wata jiritjinani ja nunkangu jinkinani, ngangau nau kamaneli nunkani nganai, nau nunkani kaukau wapanandru jiritjila nganai, ja nunkangu jinkila nganai worderuntjali nulu ngamalkananto.“   
\p
\v 9 Ja ngani jurangu jatai: „Ngatjianimai, ja Nulia jurangu jinkila nganai; wontianimai, ja jura mankamankala nganai; nandranandranimai, ja mana jurangu wilpa pantjila nganai.   
\p
\v 10 Ngangau worana ngatjiai, nulu manila nganai; ja warle wontiai, nulu mankamankala nganai; ja warle nandranandrai, nunkangu mana wilpa pantjila nganai.   
\p
\v 11 Worangu ngaperani jurangundru ngatamura bukaia ngatjila nganai, nnlu nunkangu marda jinkila nganai kara? Bakana parundru kara, nulu nunkangu parundru tjutju jinkila nganai kara?   
\p
\v 12 Nau nunkangu kapini ngatjinani kara, nulu nunkangu katninunti jinkila nganai?   
\p
\v 13 Jura, madlentji ngananani, ngujamai, kupani juranani poto ngumu jinkila; worderu morla Ngaperali pariwilpani Jaola kulikiri jinkila nganai tanangu, tana nunkangu ngatjinani!“   
\lit (Ngantjani‐jaura G. D. Oculi.)  
\p
\v 14 Ja Nulu kutji dunkalkana wonti, nau ngapu nganana wonti. Ja jendranguta kutji matja dunkana, nau ngapula jatana wonti, ja kana wolara ngaruparana wonti.   
\p
\v 15 Palpa tanangundru jatana wonti: „Beelsebub kutjia kaparali Nulia kutji worana dunkalkai.“   
\p
\v 16 Palpali nina wontjana wonti ja malka kulno pariwilpandru nunkangu ngatjina wonti.   
\p
\v 17 Ngangau Nulu tanani ngundrana matja ngujamana, Nau tanangu jatana wonti: „Milila pratjana, munta piltjaru ngankaterinani, pitaru jeribaka pantjila nganai, ja punga kulno punga kulnuni tamburiai.   
\p
\v 18 Satanas munta piltjaru ngankaterinani, worderu milila nunkani terkananto? Ngangau jura jatai: Beelsebubieli ngato kutji worana dunkalkai.   
\p
\v 19 Ja ngato Beelsebubieli kutji dunkalkanani, waninali ngatamurajeli juranali tanana dunkalkai? Jendrania tana kalala kuranietja jurani nganala nganai.   
\p
\v 20 Ngato Godaia mara wutjujeli kutji dunkalkanani, jeruja morlalu Godaia milila jurangu wokarana warai.   
\p
\v 21 Kana ngurujeli kaltieli punga nunkani kulkanani, poto nunkani murlali parala nganai.   
\p
\v 22 Kana morla nguru nunkangu wokaranani ja nina kalalu ngankanani, ngadani nulu tirimalini poto nunkani maniai, tanangu nulu manujeli ngundrai, ja poto nunkani nulu piltjaru ngankai.   
\p
\v 23 Worana wata ngakangunto nganai, nau tula ngakani nganai; ja warle wata ngakangunto kampai, nulu piltjaru ngankai.   
\p
\v 24 Kutji murumuru kanandru matja dunkana, nau pitarani palkingai, ngara ngamala wontina, ja nulu nina wata mankamankanani, nau jatai: Ngani tikala nganai pungaia ngakanaia, woderundru ngani matja dunkana.   
\p
\v 25 Ja nau matja wokarana, nulu nina mankamankai matja darpana ja tjirkatjirkana.   
\p
\v 26 Ngadani nau palkai, ja nulu wapalkai kutji mara wora ja mandru, morla madlentji nunkangu; ja tana wiriai naka ngamala; ja ngadani naupini kana morla madlentji pantjila nganai ngoperalani.“   
\p
\v 27 Jendranguta, Nulu jenia kaukaubanani, widla kulno kana wolarandru ngaiala pirnali nunkangu jatana wonti: „Murlali pirna naupini palku, nulu jidna mandranala, ja ngama jundru tapanala!“   
\p
\v 28 Nau jatana wonti: „Kauna, ja morla murlali pirna tana nganai, tanali Godaia jaura ngarai ja ngumu ngamalkai.“   
\b  
\p
\v 29 Kana wolara jenimalinani, Nulu wonina wonti jatala: „Naupini nguja madlentji nganai; malka tanalia wontiai, ja tanalia wata malka manila nganai windri Prophetaia Jonani malka.   
\p
\v 30 Ngangau worderu Jonas Ninivilani malka nganana wonti, jeruja bakana Kanaia Ngatamura nunkangupini ngujani malka nganala nganai.   
\p
\v 31 Mitaia Kaparaia widla kunankarindru terkakala nganai kalala ditjini, nunkangupini nguja kanani jela, ja tanangu ngulkuterkala nganai, ngangau nani mitaia wondirandru wokarana wonti, Salomoni kiri ngarala; ja mai, ninkida morla pirna nganai Salomongu.   
\p
\v 32 Ninive kana terkakala nganai kalala ditjini, nunkangupini ngujani jela, ja tanangu ngulkuterkala nganai, ngangau tana madlentjandru karitjina wonti Jonani ngujangujarandru; ja mai, ninkida morla pirna nganai Jonangu.   
\p
\v 33 Wata kulnujeli, nulu praitji miribai, nina kurukuruni kara, kokuni ngarinala kara widmai, a‐ai, praitji potuni, ngangau tana wirinani mintjina nunkani najinanto.   
\p
\v 34 Palkuja praitji milki nganai. Jidni milki manju ngananani, jidni palku buru pratjana praitji ngananani; jidni milki madlentji ngananani, jidni palku buru pratjana ngalpuru ngananani.   
\p
\v 35 Ngamalkateriau, nau praitji jinkangu ngananani ngalpuru nganaiati.   
\p
\v 36 Jinkani palku pratjana praitji ngananani, ja wata buru kulno ngalpuru ngananani, nau paruparu praitji nganala nganai, jeruja, worderu praitjieli mintjinali nunkanali jinkangu mintjinani.“   
\p
\v 37 Nau jenia jatana, Pharisaia kulno nunkangu ngatjina wonti, Nulu nunkangunto tajinanto. Nau matja wirina, Nau kurluni ngamana ngarina wonti.   
\p
\v 38 Pharisaiali najina wonti ja ngaruparana wonti, ngangau Nau tajinani ngopera wata kulirkaterina wonti.   
\p
\v 39 Kapara nunkangu jatana wonti: „Jura Pharisaiali koko ja piri tokuni kulikiri ngankai; jurani mandrani watawatali ja madlentji manamiri nganai.   
\p
\v 40 Jura kana patipati! Nulupini, Nulia toku pantjimana wonti, wata bakana mandra pantjimana wonti?   
\p
\v 41 Mina mandrani nganai wangiwangini jinkiau; ja mai, pratjana jurangu kulikiri nganai.   
\p
\v 42 Jakajai jurangu, jura Pharisaia, ngangau jura manjura ja kalumba ja kanta pilki pratjana puntipai, ja buru kulno marapratjanandru Godani jinkiai, ja kalala ja Godaia ngantjana jura worarai; tananapini jura ngankananto, ja jenia wata worarananto.   
\p
\v 43 Jakajai jurangu, jura Pharisaia, ngangau jura ngantjai piri ngopera jaura pungani, ja mandurini jaura jinkimalini pirini.   
\p
\v 44 Jakajai jurangu, jura jaura jinkinietja ja Pharisaia, jura kana jeljujelju, ngangau jura nariwonpa warula jeri, ja kana tanangu miri wirariai ja jenia wata ngujamai.“   
\p
\v 45 Jirijiribani jauraia ngujangujara jinkinietja kulnujeli kalabana wonti ja nunkangu wonti: „Ngujangujara jinkinietjajai, jenia jaurali jundru bakana ngaianina ngirkibai.“   
\p
\v 46 Nau jatana wonti: „Jakajai bakana jurangu, jura jirijiribani jauraia ngujangujara jinkinietja, ngangau jura kanani bururu mati pirna kurarai, ja muntali jura nina bururu wata mara ngalkieli patai.   
\p
\v 47 Jakajai jurangu, ngangau jura Prophetaia nariwonpa ngankijiribai, ja ngaperali juranali tanana nari ngankana wonti.   
\p
\v 48 Jeruja jura muntali morlalu kurai ngaperaia juranaia ngankanani; ngangau tanali tanana nari ngankana wonti, ja jura nariwonpa tananina ngankijiribai.   
\p
\v 49 Jendrania bakana Godaia kirila jatana wonti: «Ngato tanangu Apostel ja Propheta worana jinpala nganai, ja tanangundru palpa tanali nari ngankala nganai ja tanangu tirikaripaterila nganai.»   
\p
\v 50 Ngangau tanalipini ngujali kalala maninanto Propheta pratjanaia kumarandru jenia nanganani mita pantjimanandru;   
\p
\v 51 Abelani kumarandru Zachariani kumaranilu, nau palina wonti Tarani Altarani ja Godaia pungani terti. Kau, ngani jurangu jatai: Tanalipini ngujali kalala manila nganai jendrangundruja.   
\p
\v 52 Jakajai jurangu, jura jirijiribani jauraia ngujangujara jinkinietja, ngangau jura ngujamani mana ngamalkai; jura munta wata wiriai, ja tanana, tanali ngantjai wirila, jura ngandrawalkai.“   
\p
\v 53 Nau tanangu jenia jatana, jaura jinkinietjali ja Pharisaiali wonina wonti nina jaura winpala, ja palpandru nina jakalkala,   
\p
\v 54 Tanali nina kurukuru najinajibana wonti ja wontina wonti nunkani manandru palpa patala, nunkangundru ngulkuterkananto.   
\c 12  
\p
\v 1 Jendranguta kana wolara mapaterina wonti 1000 marapu jelalu, jeruja tana tidnali dakamalina wonti. Ja Nulu wonina wonti milini nunkanani jatala: „Ngopera Pharisaiaia pulkurutjeribani bukandru ngamalkaterianau, jenipara jeljujelju.   
\p
\v 2 Ngangau panila kuripi nganai, nau wata tinkari pantjila nganai; ja panila kurukuru nganai, nina tanali wata ngujamala nganai.   
\p
\v 3 Jendrania, mina jura ngalpurani jatana warai, jenia tanali praitjani ngarala nganai! ja mina jura talpani punga bitini kaukaubana warai, jenia tanali punga mangatandrani kaukaubala nganai.   
\p
\v 4 Ngani jurangu, kamanelini ngakanani, jatai: Wata tanangundru japali ngananau, tanali palku nari ngankai, ja ngadani tana ngandandariai morla ngankala.   
\p
\v 5 Ngato jurangu wondrala nganai, worangundru jura japali nganananto; nunkangundru japali ngananau, Nulia matja nari ngankana, bakana ngurula ngamalkai turuja teribala; kau, ngani jurangu jatai, nunkangundru japali ngananau.   
\p
\v 6 Tanali wata tiwilitja mara worali mardatandra waka mandrundru jinkimaliai? ja Goda wata kulno tanangundru kuritarana warai.   
\p
\v 7 Bakana para pratjana jurani mangatandrani matja windamana. Wata japali ngananau; ngangau jura morla pirna nganai tiwilitja marapuni.   
\p
\v 8 Ngani jurangu jatai: Warle ngana dikala nganai kanani, nina bakana Kanaia Ngatamurajeli dikala nganai Godaia angelani.   
\p
\v 9 Warle ngana kutikutibala nganai kanani, nina ngato kutikutibala nganai Godaia angelani.   
\p
\v 10 Ja warle jaura madlentji jatanani Kanaia Ngatamurani, nunkangu Nulia kalingala nganai; ja warle Jaola kulikiri ngirkibai, nunkangu Nulia wata kalingala nganai.   
\p
\v 11 Tanali jurana jaura pungani ja mitaia kaparani ja ngurulani wapalkanani, wata manujeli ngundranau worderu kara, mina kara jura kalabananto kara jatananto kara.   
\p
\v 12 Ngangau Jaolali kulikirieli jurana nunkangupini ditjini kiri ngankala nganai, mina jura jatananto.“   
\p
\v 13 Kana wolarandru kulno nunkangu jatana wonti: „Ngujangujara jinkinietjajai, nejini ugakanani jatamai, nulungali poto maratunka puntibananto.“   
\p
\v 14 Nau nunkangu jatana wonti: „Kanajai, warlenulu ngana talku jatanietja kara, poto maratunka puntibijiribanietja jurangu kurana warai?“   
\p
\v 15 Nau tanangu jatana wonti: „Najinajibaterianau ja ngamalkaterianau poto manujeli ngundranadru; ngangau kana kulno wata tepiriai, nulu poto marapu ngamalkanani.“   
\p
\v 16 Nulu tanangu jeribaka jaura kaukaubana wonti ja jatana wonti: „Kana poto pirnaia mitali marapu mandrana wonti.   
\p
\v 17 Ja nulu muntali ngundrana wonti ja jatana wonti: «Mina ngato ngankala nganai, ngangau ngato wata piri ngamalkai, woderi ngato tandra ngakani kurananto?»   
\p
\v 18 Ja Nau jatana wonti: Jenia ngato ngankala nganai; Ngato kampani punga ngakani wokaribala nganai ja morla pirna wotila nganai, ja jerra ngato pratjana kurala nganai, mina ngakangu matja punkana, ja poto ngakani.   
\p
\v 19 Ja ngani mungarani ngakanani jatala nganai: «Mungarajai, jundru poto marapu ngamalkai kilpawoldra marapuja; ngara ngamamai, tajiau, tapau, tepiriau!»   
\p
\v 20 Goda nunkangu jatana wonti: «Jidni kana patipatiai! nunkangupini tinkani Nulia mungara jinkani karkala nganai; wanini jenia nganala nganai, mina jundru matja ngankingana?»   
\p
\v 21 Jeruja nau nganai, nulu nunkangu muntali poto kampai, ja wata poto pirna nganai Godani.“   
\p
\v 22 Nau milini nunkanani jatana wonti: „Jendrania ngani jurangu jatai: Wata manujeli ngundranau tepini juranani, mina jura tajila nganai, bakana wata palkuni juranani, mina jura widmaterila nganai.   
\p
\v 23 Tepi morla pirna nganai bukani, ja palku morla pirna katini.   
\p
\v 24 Kawalka najianau; ngangau tanalia wata jaupai ja wata kampai, ja wata tajina pnnga ja kampani punga ngamalkai, ja Godali tananaia jerto ngankai; worderu morla pirna jura nganai paiani?   
\p
\v 25 Worana jurangundru ngurunguru nganai, tepini nunkanani tintipidi kulno juri ngankala manujeli ngundraterinali?   
\p
\v 26 Jura ngandandarinani wakawakani, minandru jura manujeli ngundrai pilkilani?   
\p
\v 27 Ngunandula najianau, worderu tanaia punkai; tanalia wata ngankai ja wata turpai; ngani jurangu jatai: Bakana Salomo pirnalani nunkanani pratjanani wata widmaterina wonti tanangundru kulnuni jeribaka.   
\p
\v 28 Godali kanta jeruja widmanani, nauja karari maruni terkai, ja tankubana tanali ninaia turupirini worai; worderu morla jurangu, jura wuldrungundranietja worajai!   
\p
\v 29 Bakana jura wata manujeli ngundranau, mina jura tajila nganai kara, mina jura tapala nganai kara, ja wata milkirianau!   
\p
\v 30 Jenia pratjana mitaia kanali wontiai; Ngaperi jurani milkila, jura jenia pratjana ngamalkananto.   
\p
\v 31 Wontianau Godaia milila, ja jenia pratjana Nulia jurangu jinkila nganai.   
\p
\v 32 Wata japali ngangau, ngangau jidni ngami wakawaka; ngangau Ngaperi jurani jertapaterina wonti jurangu milila jinkila.   
\p
\v 33 Buru ngankanau mina jura ngamalkai, ja wangiwangini bakujeli jinkianau. Jurangu billi ngankanau, tana wata womala pantjiai; poto pariwilpani nau wata mudai, woderi kurikantji wata karakara wokarai, ja bakana wata kakatjieli tajiai.   
\p
\v 34 Ngangau woderi ngantjani poto jurani parai, naka bakana jurani ngara nganai.   
\p
\v 35 Jura kapa ngampianau, ja praitji jurani mintjianau.   
\p
\v 36 Jenipara kanani jeribaka ngananau, tanali kaparani tananani kalkai, nunkangu nurujeli mana walto ngankala, nau noapatamalini ditjindru wokarala tikanani ja nandranandranani.   
\p
\v 37 Murlali pirna tanapara mili, tanana kaparali tananali, nau wokarana tikanani, tepi mankamankala nganai. Morlalu ngani jurangu jatai: «Nau ngampipaterila nganai, ja tanangu manuni kurala nganai kurlini ngamana ngarinanto, ja nau wapala nganai tanangu mili nganala.»   
\p
\v 38 Ja nau tinka terti kara, nguramaranaia woljaia kara wokaranani, ja tanana jeruja mankamankanani: Murlali pirna tanapini mili!   
\p
\v 39 Jenia ngujamanau, punga ngamalkanietja milkila ngananani, mina ditji tinkani kurikantji wokarai, nau tepi ngamala nganai ja ngandrawalkala nganai, nau wata pungani nunkanani wirinanto.   
\p
\v 40 Bakana jura ngankingaterianau! ngangau ditji kulnuni, nina jura wata ngundrai, Kanaia Ngatamura wokarala nganai.“   
\p
\v 41 Petrus nunkangu jatana wonti: „Kaparajai, jidni ninapini jeribaka jaura ngaianingu jatai kara marapuni kara.“   
\p
\v 42 Kapara jatana wonti: „Worana punga ngamalkanietja talku ja kiri nganai, nina kaparali najinajibanietja milini nunkanani kurala nganai, nulu tanangu buka ditji talkuni jinkinanto.   
\p
\v 43 Murlali pirna jenipara mili, nina kaparali nunkanali, nau wokarana tikanani, jeruja ngankanani mankamankala nganai.   
\p
\v 44 Morlalu ngani jurangu jatai: Nulu nina kapara kurala nganai nunkani poto pratjanani.   
\p
\v 45 Naupara mili ngarali nunkanali jatanani: Kapara ngakani kalkai wokarala, ja nau woninani mili materi ja mili widla nandrala, tajila ja tapala ja parawarala.   
\p
\v 46 Jenipara milia kapara wokarala nganai miljaru kulnuni, nina nulu wata ngundrai, ja ditji kulnuni, nina nulu wata ngujamai, ja nina terti tjelapalkala nganai, ja nunkangu kalala nunkani kana tjikatjikani jeribaka kurala nganai.   
\p
\v 47 Jenipara milieli, nulu kaparaia nunkanaia jertapaterina ngujamai, ja wata ngankingana warai, ja bakana jertapaterinani nunkanani wata pankina warai, nandrana marapu manila nganai.   
\p
\v 48 Warle nina wata ngujamana warai, ja jenia ngankana warai, minandru nulu nandrana maninanto, nulu nandrana ngalje manila nganai. Nunkangundru, nunkangu marapu matja jinkina, Nulia marapu wontila nganai; ja worangu Nulia marapu jinkina warai, morla marapu Nulia nunkangundru karkala nganai.   
\p
\v 49 Ngani wokarana wonti turu mitani worala, ja ngato ngantjai, nau matja jerkinanto!   
\p
\v 50 Multibanila kulno ngato maninanto, ja worderu japali ngani nganai nau mudanantulu!   
\p
\v 51 Wata ngundranau, ngani wokarana warai murla jinkila mitani, a‐ai, windri puntibala.   
\p
\v 52 Ngangau kararindru mara wora punga kulnuni puntibijiribamalila nganai; parkulu mandruni ja mandru parkulani.   
\p
\v 53 Ngaperali puntibala nganai ngatamurani ja ngatamurajeli ngaperani; ngandrieli ngatani mankarani ja ngatani mankarali ngandrini; paiarali kalarani nankanani, ja kalarali paiarani nankanani.“   
\p
\v 54 Nau bakana kana wolarani jatana wonti: „Jura talara palku kulno kalkaura jendakarani dunkanani najinani, jura nurujeli jatai: Kunditji wokarai, ja jeruja morlalu pantjiai.   
\p
\v 55 Ja jura kunankari watara ngakanani najinani, jura jatai: «Woldra pirna pantjila nganai, ja jeruja morlalu pantjiai.»   
\p
\v 56 Jura kana jeljujelju! mitaia ja pariwilpaia mudla jura ngujamai wontjala; minandru jura ninapini miljaru wata wontjai?   
\p
\v 57 Minandru jura wata muntali tjurujeli ngundrai mina talku nganai?   
\p
\v 58 Ngangau jidni talpalani jinkanani jelalu mitaia kaparani wapanani, paltuni jigleri ngankau nunkangu kulnukulnuni nganala; ngangau nulu jidnana kalala kuranietjani wapal‐kaiati, ja kalala kuranietjali jidnana milini jinkiati, ja milieli jidnana kanjangari pungani widmaiati.   
\p
\v 59 Morlalu ngani jinkangu jatai: «Jidni wata morla nakandru dunkala nganai, jundru ngopera mudani marda jinkinantulu.»“   
\c 13  
\p
\v 1 Tanangupini ditjini palpa naka nganana wonti, tanali nunkangu Galilaialandru kaukaubana wonti, tanani kumari Pilatulu tanani poto ngumuni duldruwanala.   
\p
\v 2 Ja Jesujeli kalabana wonti ja tanangu jatana wonti: „Jura ngundrai, tana Galilaiala morla madlentji ngananala Galilaiala worangu, ngangau tanali jenia ketjaketjanala?“   
\p
\v 3 A‐ai, ngani jurangu jatai: „Jura wata madlentjandru karitjinani, jura pratjana tanangu jeribaka palila nganai.   
\p
\v 4 Tana marapratjana ja mara wora ja parkulu kara, tanangupini Siloa punga wutju purina wonti, ja tanana nari ngankana wonti; jura ngundrai, tana morla madlentji nganana wonti kana pratjanani Jerusalem ngurani ngamanani?   
\p
\v 5 A‐ai, ngani jurangu jatai; jura wata madlentjandru karitjinani, jura tanangu jeribaka palila nganai.“   
\p
\v 6 Nau ninapini jeribaka jaura jatana wonti: „Kulnujeli tandraia nindri maruni nunkanani kurana wonti; ja nau wokarana wonti nunkangu tandra wontila ja panila mankamankana wonti.   
\p
\v 7 Nau maru ngamalkanietjani jatana wonti: «Mai, kilpawoldra parkulu ngani wokarai nunkangupini tandra nindrindru tandra wontila, ja panila mankamankai; ninaia wokaribamai, minandru nulia mita ngandrawalkai?»   
\p
\v 8 Nulu kalabana wonti ja nunkangu jatana wonti: «Kaparajai, nunkangupini kilpawoldrani ninaia worani patamai, ngato nunkangu bakuna karitjinantulu ja kudna kuranantulu.   
\p
\v 9 Nulia kara ngadani tandra punkibananto; pani kara, ngadani jundru ninaia wokaribananto.»“   
\p
\v 10 Ja Nulu jaura punga kulnuni Sabbat ditjini ngujangujara jinkina wonti.   
\p
\v 11 Ja mai, widla kulno naka nganana wonti, nandru waltowaltuja kutji kilpawoldra marapratjana ja mara wora ja parkulu ngamalkana wonti, ja nani tjunduru nganana wonti ja ngandandarina wonti talku terkala.   
\p
\v 12 Jesujeli nana najina, Nulu nana karkana wonti ja nankangu jatana wonti: „Widlajai, dukarateriau jinkani waltowaltundru!“   
\p
\v 13 Ja Nulu nankangu mara kuraterina wonti, ja nurujeli nani talku terkana wonti ja Goda jurakokana wonti.   
\p
\v 14 Jaura pungaia kaparali junkarina wonti, ngangau Jesujeli Sabbat ditjini tepi ngankana warai, ja nulu kalabana wonti ja kana wolarani jatana wonti: „Ditji mara wora ja kulno nganai, tanangu jura ngankananto, tanangupini wokaranau Nulia jurana tepi ngankananto, ja wata Sabbat ditjini!“   
\p
\v 15 Kaparali nunkangu kalabana wonti ja jatana wonti: „Jidni kana jeljujelju! wata jura pratjanali jurani nganti kara, donki kara, pirrandru dukarai, ja tanana wapalkai ngapaia, Sabbat ditjini?   
\p
\v 16 Nanipini bakana Abrahamani ngatamura, nana kutjieli kilpawoldra marapratjana ja mara wora ja parkulu matja dupudupu ngankana, ngato nana wata kurakananto nanapini dupudupundru Sabbat ditjini?“   
\p
\v 17 Ja Nau jenia jatanani, talpala nunkani pratjana nintali pantjina wonti; ja kana wolara mankina wonti pirnala pratjanandru, jenia nunkangundru pantjinala.   
\p
\v 18 Nau jatana wonti: „Worangu jeribaka Godaia milila nganai, ja worangu jeribaka ngato nina kurala nganai?   
\p
\v 19 Nau paua wakawakani jeribaka nganai, ninapini kana kulnujeli manina wonti, ja maruni nunkanani jaupana wonti; ja nau punkana wonti, ja pita pirna pantjina wonti, ja paia ngaranani ngunani nunkanani kunjila wontina wonti.“   
\p
\v 20 Ja nakaldra Nau jatana wonti: „Worangu jeribaka ngato Godaia milila kurala nganai?   
\p
\v 21 Nau pulkurutjeribani buka jeribaka nganai, nina widla kulnujeli manina wonti ja kurukurumalkana wonti koko pirna parkulu buka turarani, nau pulkurutjeranantulu.“   
\p
\v 22 Ja Nau ngura pirnani ja wakani palkingana wonti ngujangujara jinkila, ja Nau Jerusalemia palkana wonti.   
\p
\v 23 Kulno nunkangu jatana wonti: „Kaparajai! tana ngalje nganai kara, tanali tepi manila nganai?“ Nau tanangu jatana wonti:   
\p
\v 24 „Jiglerali ngankanau mana wuldruni wirila; ngangau marapujeli, ngani jurangu jatai, wontiai wirila, ja ngandandarila nganai.   
\p
\v 25 Jendranguka ditjindru, punga ngamalkanietja matja terkakana ja mana matja nguru ngankana, jura wonila nganai palarani terkala ja mana nandranandrala ja jatala: «Kaparajai, Kaparajai, ngaianingu walto ngankamai!» ja Nulu kalabala nganai ja jatala nganai: Ngato jurana wata ngujamai wodajerindru jura nganai.   
\p
\v 26 Ngadani jura wonila nganai jatala: «Ngaiani jinkangu milkini tajinala ja tapanala, ja paltuni ngaianinani jundru ngujangujara jinkinala.»   
\p
\v 27 Ja Nau jatala nganai: Ngani jurangu jatai, ngato jurana wata ngujamai wodajerindru jura nganai; wapanau ngakangundru pratjana jura tjikatjika ngankanietja!   
\p
\v 28 Naka ngirikidana ja mana katakatangana nganala nganai, jura najinani Abraham ja Isaak ja Jakob ja Propheta pratjana Godaia mililani, ja jurana nunkangundru matja teribana.   
\p
\v 29 Ja tana tiriwandru ja jendakarandru ja tidnankarandru ja kunankarindru wokarala nganai, ja Godaia mililaia kurlini ngamana ngarila nganai.   
\p
\v 30 Ja mai, ngadalata nganai, tana ngopera nganala nganai, ja ngoperalata nganai, tana ngadaia nganala nganai.“   
\p
\v 31 Nunkangupini ditjini Pharisaia palpa nunkangu wokarana wonti ja nunkangu jatana wonti: „Puntiau, ja ninkidandru palkau, ngangau Herodili jertapateriai jidna nari ngankala.“   
\p
\v 32 Ja Nau tanangu jatana wonti: „Wapanau ja nunkangupini kintala jampani jatanau: Mai, ngato kutji worana dunkalkai ja tepi ngankai karari ja dankubana, ja ditjini parkulani ngato mudala nganai.   
\p
\v 33 Jendrania ngani karari ja dankubana ja tankubana kulnuni palkananto; ngangau jenia wata pantjinanto, Propheta kulno wata Jerusalemingu palinanto.   
\p
\v 34 Jerusalemiai, Jerusalemiai! jundru Propheta worana nandrai, ja mardali dakai, tanana jinkangu jinpanala; worderuntja pota ngato kupa jinkani jertapaterina wonti mapala, worderu warugati ngandrieli nankani wolka nankani ngaruni mapai, ja jura wata ngantjana wonti.   
\p
\v 35 Mai, punga jurani ngurawalpa parala nganai. Morlalu ngani jurangu jatai: Jura ngana wata morla najila nganai jura jatanantulu: Ngaiani jurakokai ninaia, Nauja wokarai Kaparaia talani!“   
\c 14  
\lit (Ngantjani‐jaura G. D. 17. Trinitatis.)  
\p
\v 1 Jendranguta Nau Sabbat ditjini Pharisaia kaparaia pungaia wirina wonti buka tajila, ja tanali nina najinajibana wonti.   
\p
\v 2 Ja mai, kana kulno nunkangu kantjini nganana wonti ngapali muntja.   
\p
\v 3 Ja Jesujeli kalabana wonti ja jirijiribani jauraia nguja ngujara jinkinietjani ja Pharisaiani jatana wonti: „Jenia talku nganai, Sabbat ditjini tepi ngankala kara, pani kara?“   
\p
\v 4 Tana ngapurina wonti. Ja Nulu nina patana wonti ja tepi ngankana wonti ja nina jinpana wonti.   
\p
\v 5 Ja Nulu kalabana wonti ja tanangu jatana wonti: „Warle jurangundru, ngatamura nunkani kara nganti kara ngapa kutuni purinani, nulu nina wata nurujeli dukarala nganai Sabbat ditjini?“   
\p
\v 6 Ja tana ngandandarina wonti nina jendrangundruja kalabala.   
\p
\v 7 Nau jeribaka jaura jatana wonti kurlia kamanelini, ngangau Nulu najina wonti, worderu tanali piri ngopera kalkalkanani, ja tanangu jatana wonti:   
\p
\v 8 „Kana kulnujeli jidna karkanani noa patamalini bukaia, wata piri ngoperani ngamana ngariau, nulu kara kulno morla pirna jinkangu karkana warai;   
\p
\v 9 Ja nau wokaranani, nulu jidna ja nina matja karkana, nau jinkangu jatala nganai: Jerrariau; ja jidni wonila nganai mudani pirini ngamala.   
\p
\v 10 A‐ai, kulnujeli jidna karkanani, wapau ja mudani pirini ngamana ngariau; ngangau nau wokaranani, nulu jidna matja karkana, nau jinkangu jatala nganai: Kamaneliai, jera tarau! ngadani jundru pirnala ngamalkala nganai tanangundru, tana jinkangu jela kurlini ngamai.   
\p
\v 11 Ngangau warle pirna ngankateriai, nau waka pantjila nganai; ja warle waka ngankateriai, nau pirna pantjila nganai.“   
\b  
\p
\v 12 Nau nunkangu, nulu nina matja karkana, jatana wonti: „Jundru manamuka kara, buka pirna kara ngankinganani, wata kana kamaneli jinkani karkau, bakana wata neji worana jinkani, bakana wata kamaneli jinkani, bakana wata jenimalinietjaia kana poto pirna; ngangau tanali jidnana nakaldra karkaiati ja jinkangu kalala pantjiati.   
\p
\v 13 A‐ai, jundru buka pirna ngankinganani, jeruja karkau kana wangiwangi, dupudupu, tjunduru, butju.   
\p
\v 14 Ja murlali pirna jidni nganala nganai, ngangau tanali wata ngamalkai jinkangu kalala jinkila; ngangau jundru kalala manila nganai kana talkuja jiritjini ditjini.“   
\p
\v 15 Kurlaia kamaneli kulnujeli jenia ngaranani, nau nunkangu jatana wonti: „Murlali pirna, warlenulu buka tajila nganai Godaia mililani.“   
\lit (Ngantjani‐jaura G. D. 2. Trinitatis.)  
\p
\v 16 Nau nunkangu jatana wonti: „Kana kulnujeli buka pirna ngankingana wonti ja marapuni jatingana wonti.   
\p
\v 17 Ja nulu mili nunkani jinpana wonti bukaia ditjini, tanangu matja karkana, jatala: «Kaparanau, ngangau pratjana matja ngankingana warai.»   
\p
\v 18 Ja tanali pratjanali wonina wonti kulnukulnuni delkila. Ngoperala nunkangu jatana wonti: «Ngato mita kulno burungankana warai, ja ngani morlalu wapananto nina najinajibala; ngani jinkangu ngatjiai, manju jatamai ngakangundru.»   
\p
\v 19 Ja kulno jatana wonti: «Ngato nganti marapratjana burungankana warai, ja ngani wapai tanana wontjala; ngani jinkangu ngatjiai, manju jatamai ngakangundru.»   
\p
\v 20 Ja kulno jatana wonti: «Ngato noa patana warai, jendralia ngani ngandandariai wokarala.»   
\p
\v 21 Ja mili tikana wonti ja jenia kaparani nunkanani kaukaubana wonti. Jendranguta pungaia kapara tiri pantjina wonti ja milini nunkanani jatana wonti: «Nurujeli wapamai nguraia palto pirnani ja wakani, ja wangiwangi, ja dupudupu, ja tjunduru, ja butju wirilkamai.»   
\p
\v 22 Ja mili jatana wonti: «Kaparajai, jenia matja pantjina, worderu jundru jirijiribana warai, ja morla piri parai.»   
\p
\v 23 Ja Kapara milini jatana wonti: «Wapamai paltuni ja wondirani, ja tanana mararibamai wirinanto; ngangau punga ngakani manamiri pantjinanto.»   
\p
\v 24 Ngangau ngani jurangu jatai: Wata kana kulnujeli tanangundru, ngani matja jatingana, buka ngakani wontjala nganai.“   
\b  
\p
\v 25 Kana wolara marapu nunkangunto wapana wonti; ja Nau karitjina wonti ja tanangu jatana wonti:   
\p
\v 26 „Kulno ngakangu wokaranani ja wata kalakalarinani ngaperani nunkanani ja ngandrini ja noani ja kupani ja neji marani ja kakuni, ja bakana mungarani nunkanani; nau ngandandariai mili ngakani nganala.   
\p
\v 27 Ja warlenulu wata kunarku nunkani mandrai ja ngakangu karipateriai, nau ngandandariai mili ngakani nganala.   
\p
\v 28 Ngangau warlenulu jurangundru ngantjai pungu wutju wotila, nauja wata ngopera ngamana ngarinani wintamala, nulia pratjana ngamalkai nina mudala?   
\p
\v 29 Ngangau, nulia marda kapara matja kurana kara, ja ngandandarinani nina mudala, pratjanali nina najinani, woniati ninaia ngirkibala,   
\p
\v 30 Ja jatala: «Nulupini kanali wonina warai wotila, ja ngandandarina warai mudala.»   
\p
\v 31 Worana mitaia kapara nganai kara, nau palkanani mitaia kapara kulnuni tirimalila, nau wata ngopera ngamana ngarinani ja munta warawarabanani, nau ngurunguru nganai kara 10,000 kananto nunkangu mandurila, nau nunkangu manduriai 20,000 kananto?   
\p
\v 32 Pani kara, nulu mili nunkani jinpala nganai, nau worita ngananani, nunkangundru murla ngatjila.   
\p
\v 33 Jeruja bakana pratjana jurangundru, warlenulu wata pratjana, mina nulu ngamalkai, worarai, ngandandariai mili ngakani nganala.   
\p
\v 34 Kaldri ngumu nganai; kaldri dunkarinani, minali tanali kaldri ngankananto?   
\p
\v 35 Wata mitani kara wata tunkani kara nau ngumu nganai, a‐ai, tanali nina palarani worarai. Warle talpa ngamalkai ngarala, nulu ngaraiatimai!“   
\c 15  
\lit (Ngantjani‐jaura G. D. 3. Trinitatis.)  
\p
\v 1 Mardatandra kampanietja ja kana madlentji marapu nunkangu karakarana wonti nina ngarala.   
\p
\v 2 Ja Pharisaiali ja jaura jinkinietjali kuterilkana wonti ja jatana wonti: „Nulupini kana madlentji patai, ja tanali jelali tajiai.“   
\p
\v 3 Nulu tanangu ninapini jeribaka jaura kaukaubana wonti ja jatana wonti:   
\p
\v 4 „Warlenulu kanali jurangundru, nulu 100 tjipi ngamalkanani, ja kulno tanangundru tintanani, wata nulu 99 wolja woraranani pitarani ja wapantinani nunkangu, nau matja tintaterina, nulu nina mankamankalalu?   
\p
\v 5 Ja nulu nina matja mankamankana, nulu mankina nina pilperani kurana tarai.   
\p
\v 6 Ja nau pungani matja tikana, nulu kamaneli ja jenimalinietja karkai ja tanangu jatai: «Ngakangunto mankianimai, ngangu tintani tjipi ngakani ngato mankamankana warai.»   
\p
\v 7 Ngani jurangu jatai: Jeruja bakana pariwilpani mankina nganala nganai kana madlentji kulnundru, nau madlentjandrn karitjinani, morla 99 talkuni, tana wata madlentjandru karitjinanto.   
\p
\v 8 Widla kulnujeli kara mardatandra marapratjana ngamalkanani, ja nandru mardatandra kulno tintanani, wata praitji miribai, ja punga darbai, ja jiglerali wontiai, nina mankamankalalu?   
\p
\v 9 Ja nandru nina matja mankamankana, nandru kamaneli ja jenimalinietja karkai ja jatai: «Ngakangunto mankianimai, ngangau nina mardatandra ngato mankamankana warai, nina ngato tintana warai.»   
\p
\v 10 Jeruja bakana ngani jurangu jatai: Godaia angela mankila nganai kana madlentji kulnundru, nau madlentjandru karitjinani.“   
\b  
\p
\v 11 Nau jatana wonti: „Kana kulnujeli ngatamura mandru ngamalkana wonti.   
\p
\v 12 Ja wakaia kupali ngaperani jatana wonti: «Ngaperiai, jinkiau ngakangu jenia poto ngakani pilki nganai.» Ja nulu pudlangu poto puntibana wonti.   
\p
\v 13 Ja ditji palpani ngadani wakaia kupali pratjana ngokana wonti ja mita woritaia palkana wonti; ja jelaua nulu poto nunkani tintana wonti tepi madlentjali.   
\p
\v 14 Nulu pratjana matja tintana, nunkangupini mitani maua pirna pantjina wonti; ja nulu wonina wonti maua ngamala.   
\p
\v 15 Ja nau wapana wonti ja nunkangupini mitani kana kulnuja mili pantjina wonti; ja nulu nina mitani nunkanani jinpana wonti nganti ngamalkananto.   
\p
\v 16 Ja nau ngalkujeli nganana wonti mandra nunkani tandra talali jerturila, tanana ngantieli tajina wonti, ja wata kulnujeli nunkangu jinkina wonti.   
\p
\v 17 Nau burkali pantjina wonti ja jatana wonti: «Worderuntja mili ngaperali ngakanali ngamalkai, tanali buka marapu ngamalkai, ja ngani mauali paliai.   
\p
\v 18 Ngani jiritjila nganai, ja ngapinangu tikala nganai, ja nunkangu jatala nganai: ‚Ngaperiai, ngato madlentji ngankanala pariwilpani ja jinkangu,   
\p
\v 19 Ngani wata morla talku nganai jundru ngana ngatamura jinkani dikananto; ngana mili jinkani ngankamai.‘ »   
\p
\v 20 Ja nau jiritjina wonti, ja ngaperani nunkanani wokarana wonti. Nau matja worita nganana, ngaperali nunkanali nina najina wonti, ja nau nunkangu kalumiltjamiltjarina wonti ja mindrina wonti, ja nina munkana wonti ja manatapana wonti.   
\p
\v 21 Ngatamura nunkangu jatana wonti: «Ngaperiai, ngato madlentji ngankanala pariwilpani ja jinkangu; ngani wata morla talku nganai, jundru ngana ngatamura jinkani dikananto.»   
\p
\v 22 Ngaperi milini nunkanani jatana wonti: «Nurujeli kati ngumu pirna dukaranau ja nunkangu widmanau, ja marani nunkanani marapirapira kuranau, ja tidnaputa tidnani nunkanani,   
\p
\v 23 Ja nina nganti kuparu manipirna manianau ja nandranau; ja ngaiana tajinanto ja mankinanto;   
\p
\v 24 Ngangau naupini ngatamura ngakani nari nganana warai, ja nakaldra tepirina warai, nau tintaterina warai, ja nina matja mankamankana.» Ja tanali wonina wonti mankila.   
\p
\v 25 Neji nunkani maruni nganana wonti: ja nau tikanani ja pungani matja karakara, nulu wima ja dultrinani ngarana wonti.   
\p
\v 26 Ja nulu mili kulno karkana wonti, ja nina jakalkana wonti mina jenia wondrai.   
\p
\v 27 Nau nunkangu jatana wonti: «Ngatata jinkani matja tikana, ja ngaperali jinkanali nina nganti kuparu manipirna nandrana warai, ngangau nulu nina nakaldra tepi ngamalkai.»   
\p
\v 28 Nau tiri pantjina wonti, ja wata ngantjana wonti wirila. Ngaperi nunkani dunkana wonti, ja nina kurukurubana wonti.   
\p
\v 29 Nulu kalabana wonti ja ngaperani nunkanani jatana wonti: «Mai, jeruntjaia kilpawoldra ngani jinkangu pankiai, ja wata pota kulno ngato jirijiribani jaura jinkani dankarana warai; ja ngakangu jundru wata pota kulno kuparu waka jinkina warai, ngani ngakani kamanelinto mankinanto.   
\p
\v 30 Naupini ngatamura jinkani matja tikana warai, nulu poto nunkani pirangurujeli julkana warai, jundru nunkangu nina nganti kuparu manipirna nandrana warai.»   
\p
\v 31 Nau nunkangu jatana wonti: Kupajai, jidni milingeru ngakangu jela nganai, ja pratjana mina ngakani, jinkani nganai.   
\p
\v 32 Jidni murlali nganananto ja mankinanto, ngangau naupini ngatata jinkani nari nganana warai ja tepirina warai, ja nau tintaterina warai ja nina matja mankamankana.“   
\c 16  
\lit (Ngantjani‐jaura G. D. 9. Trinitatis.)  
\p
\v 1 Nau bakana milini nunkanani jatana wonti: „Kana kulno poto pirna nganana wonti, nulu ngamalkiribanietja ngamalkana wonti; ja nina tanali nunkangu ngulkuterkana wonti, ngangau nulu poto nunkani duljaduljamanala.“   
\p
\v 2 Ja nulu nina karkana wonti ja nunkangu jatana wonti: „Mina ngato jinkangundru ngarai? Ngamalkijiribanandru windamau, ngangau jidni ngandandariai morla ngankijiribala.“   
\p
\v 3 Ngamalkiribanietja warawarapaterina wonti: „Mina ngato ngankananto? Ngangau kaparali ngakanali ngamalkijiribanila ngakangundru maniai. Ngani ngandandariai bakula, ja ngani nintali nganai tjambatjambala,   
\p
\v 4 Ngani milkila, mina ngato ngankala nganai, nulu ngamalkijiribanila ngakangundru mamanani, tanali ngana patananto pungaia tananaia.“   
\p
\v 5 Ja nulu kaparaia nunkanaia kana poto wilpanto kulno ja kulno karkana wonti ja ngoperalani jatana wonti: „Worderuntja jundru kaparani ngakanani poto wilpanto nganai?“   
\p
\v 6 Nau jatana wonti: „100 koko gildi;“ ja nau nunkangu jatana wonti: „Talpadakani dakani jinkani patamai, ngamana ngariau, ja nurujeli dakamai 50.“   
\p
\v 7 Ngadani nau kulnuni jatana wonti: „Ja jundru, worderuntja jundru poto wilpanto nganai?“ Nau jatana wonti: „100 billi buka tandra.“ Ja nau nunkangu jatana wonti: „Talpadakani dakani jinkani patau, ja dakamai 80.“   
\p
\v 8 Ja kaparali ngamalkiribanietja tjikatjika jurakokana wonti, ngangau nulu kiri ngankana wonti; ngangau nunkanipini mitaia kupa morla kiri nganai praitjaia kupani ngujani tananani.   
\p
\v 9 Ja ngani jurangu jatai: „Jura jurangu muntali kamaneli ngankanimai mamon wata talkuni; ngangau nau mudanani, tanali jurana patala nganai punga nguralia.   
\b  
\p
\v 10 Worana talku nganai wakawakani, nau bakana pirnani talku nganai; ja worana wata talku nganai wakawakani, nau bakana pirnani wata talku nganai.   
\p
\v 11 Jura mamon wata talkuni wata talkurinani, warle jurangu morlalulali jinkila nganai?   
\p
\v 12 Ja jura tulani wata talkurinani, warle jurangu juranani jinkila nganai?   
\p
\v 13 Pungaia mili kulno ngandandariai kapara mandruni mili ngamala; nau kulnuni kalakalarila nganai, ja kulno nulu ngantjala nganai kara, kulnuni nau wodatarana ngamala nganai, ja kulnuni gilbarila nganai kara. Jura ngandandariai Godani ja Mamonani mili ngamala.“   
\p
\v 14 Jenia pratjana Pharisaiali ngarana wonti, tanali mardatandra manujeli ngundrana wonti; ja tanali nina ngirkibana wonti.   
\p
\v 15 Nau tanangu jatana wonti: „Jura jenipara nganai, tana munta talku wondrateriai kanani, ja Godali ngara jurani ngujamai. Ngangau jenia, mina kanani pirna nganai, Godani tjikatjika nganai.   
\p
\v 16 Jirijiribani jaura ja Propheta Johaningulu; nunkangupini ditjindru tanali ngantjani jaura Godaia mililandru kaukaubai, ja kana pratjanali ngurujeli nunkangu jeniai.   
\p
\v 17 Morla ngaua nganai pariwilpa ja mita mudanani, tjilpi waka kulno jirijiribani jaurandru purinani.   
\p
\v 18 Warlenulu noa nunkani worarai, ja kulno nguru patai, nulu pinta wokaribai; ja warlenulu jenipara, materali matja worarana, patai, bakana pinta wokaribai.   
\lit (Ngantjani‐jaura G. D. 1. Trinitatis.)  
\p
\v 19 Kana kulno poto pirna nganana wonti, nau kati tjanka waru ja maralje widmaterina wonti, ja ditjini warupotuni tepi ngumu ngankaterina wonti, ja mankina wonti.   
\p
\v 20 Ja kana wangiwangi nganana wonti, tala nunkani Lazarus, naupini punga manani nunkanani parana wonti gambanto.   
\p
\v 21 Ja nau ngalkujeli nganana wonti buka murujeli jerturila, tana kana poto pirnaia kurlindru purinani; ja kintala wokarana wonti ja nina tapa talieli tapana wonti.   
\p
\v 22 Jendranguta kana wangiwangi palina wonti, ja angelali nina taralkana wonti Abrahamangu ngalpaia. Ja kana poto pirna bakana palina wonti, ja tanali nina todina wonti.   
\p
\v 23 Ja turuni nau milki tjenmana tarana wonti, ngangau nau ketjaketjanani nganana wonti; ja nulu Abraham woritandra najina wonti, ja Lazarus nunkangu ngalpani.   
\p
\v 24 Ja nau karkana wonti ja jatana wonti: «Ngaperiai Abraham, kalumiltjamiltjariau ngakangu, ja Lazarus jinpamai, nau maramoku ngapani multibaterinanto ngana tali malti ngankala; ngangau ngani pirna ketjaketjai nunkanguja turu jaolani.»   
\p
\v 25 Abraham jatana wonti: «Ngundrau ngatamurajai, ngumula jinkani jundru manina wonti tepiwirdi, ja Lazarulu madlentji manina wonti; ja karari nulu ninkida ngankalkana maniai, ja jundru ketjaketjana.   
\p
\v 26 Ja bakana dulkuru pirna parai ngaianingu ja jurangu terti, jeruja tana ninkidandru jertapaterinani jerra pararala, jenia ngandandariai, ja bakana tana ninkindrupara ngandandariai ngaianingu pararala.»   
\p
\v 27 Nau jatana wonti: «Ngani jinkangu ngatjiai, ngaperiai, jundru ninapara jinpananto ngakani ngaperaia pungaia.   
\p
\v 28 Ngangau ngatata mara wora ngato ngamalkai: tanangu nulupara morlalu kurananto, tana nunkangupini ketjaketjani pirini wokaraiati.»   
\p
\v 29 Abraham nunkangu jatana wonti: «Tanali Mose ja Propheta worana ngamalkai, tanali tananaka ngaraiatinimai.»   
\p
\v 30 Nau jatana wonti: «A‐ai, ngaperiai Abraham, narila kulno wokaranani, jeruja tana madlentjandru karitjila nganai.»   
\p
\v 31 Nau nunkangu jatana wonti: «Tanali Mose ja Propheta worana bulu ngaranani, tanali bakana wata morlalu ngundrala nganai narila terkakanani.»“   
\b  
\c 17  
\p
\v 1 Nau milini nunkanani jatana wonti: „Jenia ngandandariai wata karkarkana wokarananto; jakajai nunkangu, nunkangundru jenia wokarai.   
\p
\v 2 Nunkangu morla ngumu nganai, marda wati nunkangu jerkalani kurananto, ja nina panto pirnani jikananto, nulu wata tanangupini wakawaka kulno karkarkananto.   
\p
\v 3 Ngamalkaterianau! Ngatatajeli jinkanali jinkangu madlentji ngankanani, nina kurukurubau; ja nau burkali ngananani, madlentji nunkani worau.   
\p
\v 4 Ja nulu ditji kulnuni pota mara wora ja mandru jinkangu madlentji ngankanani, ja ditji kulnuni pota mara wora ja mandru jinkangu karitjinani ja jatanani: «Ngani burkali nganai;» jundru madlentji nunkani worananto.“   
\p
\v 5 Ja Apostel wora Kaparani jatana wonti: „Ngaianingu morlalu ngundrana morla jinkiau!“   
\p
\v 6 Kapara jatana wonti: „Jura morlalu ngundrana ngamalkanani paua wakani jeribaka, jura nunkangupini tandra pitani jatala nganai: Dukarateriau, ja panto pirnani terkibateriau, ja nauja jurangu pankila nganai.   
\p
\v 7 Warlenulu jurangundru mili kulno ngamalkanani, nulu mita bakunani kara nganti ngamalkanani kara, nau marundru tikana warai, nunkangu jatanani: Nurujeli wokarau ja kurlini ngamana ngariau?   
\p
\v 8 Nau wata nunkangu jatala nganai: Ngakangu buka ngankinganimai, ja ngampipateriau, ja mili ngakani ngamamai, ngato matja tajina warai ja tapana warai; ja ngadani bakana jundru tajinanto ja tapananto?   
\p
\v 9 Nulu nina mili jurakokala nganai, nau jirijiribani jaurani nunkanani pankina warai? A‐ai, ngato ngundrai.   
\p
\v 10 Jeruja bakana jura, jura pratjana ngankana warai, mina jurangu matja jirijiribana, jatanau: Ngaiani mili baku nganai, ngangau mina ngaiani wilpanto nganai ngankala, ngaiani ngankana warai.“   
\lit (Ngantjani‐jaura G. D. 14. Trinitatis.)  
\p
\v 11 Jendranguta Nau Jerusalemia palkana wonti ja Samaria ja Galilaia mitani palkingana wonti.   
\p
\v 12 Ja Nau ngura kulnuni wirinani, nunkangu materi marapratjana gambanto mandurina wonti, tana worita terkana wonti.   
\p
\v 13 Ja tana ngaiala pirnali karkana wonti: „Jesujai, Ngujangujara jinkinietjajai, ngaianingu kalumiltjamiltjariau!“   
\p
\v 14 Ja Nulu tanana najina, Nau tanangu jatana wonti: „Wapanimai, ja Priesta worangu wondraterianau!“ Ja jendranguta tana wapana, tana kulikiririgana wonti.   
\p
\v 15 Kulno tanangundru najiterina, nau matja tepirina, nau tarpina tikana wonti, ja Goda ngaiala pirnali jurakokana wonti.   
\p
\v 16 Ja nau mudlani woraterina wonti nunkangu tidnani, ja nina jurakokana wonti; ja nau Samaritala nganana wonti.   
\p
\v 17 Ja Jesujeli kalabana wonti ja jatana wonti: „Wata marapratjana kulikiri pantjina warai? Woderi mara wora ja mandru mandru?   
\p
\v 18 Wata tanana mankamankana, tanana karitjina tikananto Goda jurakokala, windri nulupini kana tulali?“   
\p
\v 19 Ja Nau nunkangu jatana wonti: „Terkakamai ja wapau; morlalu ngundranali jinkanali jidna tepi ngankana warai.“   
\b  
\p
\v 20 Pharisaiali nina jakalkana wonti: „Winta Godaia milila wokarai?“ Nulu tanangu kalabana wonti ja jatana wonti: „Godaia milila wata jeruja wokarai, tanali nina ngujamanani.   
\p
\v 21 Tana bakana wata jatala nganai: Najiau ninkida, najiau jerra; ngangau mai, Godaia milila jurangu terti nganai.“   
\p
\v 22 Nau milini nunkanani jatana wonti: „Ditji wokarala nganai, tanangupini jura jertapaterila nganai Kanaia Ngatamuraia ditji kulno najila, ja jura nina wata najila nganai.   
\p
\v 23 Ja tana jurangu jatala nganai: Najiau ninkida, najiau jerra; wata wapanau, bakana wata karipaterianau.   
\p
\v 24 Ngangau worderu talara praitji, nau mintjiai pariwilpaia wondiri kulnundru pariwilpaia wondiri kulnujelu, jeruja bakana Kanaia Ngatamura nganala nganai ditjini nunkanani.   
\p
\v 25 Ngopera Nau pirna ketjaketjananto, ja tanalipini kana ngujali nina worananto.   
\p
\v 26 Ja worderu Noahni ditjini pantjina wonti, jeruja bakana Kanaia Ngatamuraia ditjini nganala nganai.   
\p
\v 27 Tanali tajina wonti, tapana wonti, noa patana wonti, noa pantjina wonti, jenia ditjielu, Noah bota pirnani wirina wonti; ja kunditji wokarana wonti, ja pratjana nandrana wonti.   
\p
\v 28 Bakana jeruja, worderu Lotani ditjini pantjina wonti: tanali tajina wonti, tapana wonti, burungankana wonti, jinkimalina wonti, kurana wonti, wotina wonti.   
\p
\v 29 Nunkangupini ditjini, Lot Sodom ngurandru dunkana kurana, turu ja turukandri pariwilpandru godana wonti, ja pratjana nandrana wonti.   
\p
\v 30 Jeruja nunkangupini ditjini nganala nganai, nunkangu Kanaia Ngatamura wondraterila nganai.   
\p
\v 31 Worana nunkangupini ditjini punga mangatandrani nganai, ja poto nunkani pungani parai, wata ngarina tikaiatimai tanana manila; ja worana maruni nganai, bakana wata karitjina tikaiatimai nunkangu, mina nunkangu ngadani nganai.   
\p
\v 32 Ngundranimai Lothani noa!   
\p
\v 33 Warlenulu wontiai tepi nunkani kulkala, nulu nina tintala nganai; ja warlenulu nina tintai, nulu nina tepi ngamalkala nganai.   
\p
\v 34 Ngani jurangu jatai: Nunkangupini tinkani mandru turarani piri kulnuni parala nganai; kulno Nulia patala nganai, ja kulno Nulia worarala nganai.   
\p
\v 35 Mandrujeli jelali turara ngankala nganai; nana kulno Nulia patala nganai, ja nana kulno Nulia worarala nganai.   
\p
\v 36 Mandru maruni nganala nganai; kulno Nulia patala nganai, ja kulno Nulia worarala nganai.“   
\p
\v 37 Ja tanali kalabana wonti ja nunkangu jatana wonti: „Woderi Kaparajai!“ Nau tanangu jatana wonti: „Woderi pundupundu nganai, naka kirki jurborila nganai.“   
\c 18  
\p
\v 1 Nau bakana tanangu jeribaka jaura jatana wonti, jendrangundruja tana milingeru ngatjinanto ja wata walturinanto.   
\p
\v 2 Ja jatana wonti: „Ngura kulnuni kalala kuranietja kulno nganana wonti, nau Godandru wata japala nganana wonti, ja kanandru wata manngarina wonti.   
\p
\v 3 Mangawaru kulno nunkangupini ngurani nganana wonti, ja nani nunkangu wokarana wonti ja jatana wonti: «Ngana kulkamai ngakani talpalandru.»   
\p
\v 4 Ja nulu juri wata ngantjana wonti. Ngadani nau warawarapaterina wonti: «Ngani bakana Godandru wata japali ngananani, ja wata kana kulnundru manngarinani.   
\p
\v 5 Ngangau nandrupini mangawarujeli ngana jupai, ngato nana kulkala nganai; ngangau nania ngadani wokaraiati ja ngana nandraiati.»“   
\p
\v 6 Kapara jatana wonti: „Ngaranau, mina kalala kuranietja tjikatjika jatai!   
\p
\v 7 Godali kana kalkalkana nunkani wata kulkala nganai, tanali ditjini ja tinkani nunkangu karkai, ja tanangu manju kalumiltjamiltjarila nganai?   
\p
\v 8 Ngani jurangu jatai: Nulu tana nurujeli kulkala nganai. Kanaia Ngatamura wokaranani, Nulu bakana morlalu ngundrana mankamankala nganai?“   
\lit (Ngantjani‐jaura G. D. 11. Trinitatis.)  
\p
\v 9 Nau nina jeribaka jaura palpani jatana wonti, tana munta talku ngundraterina wonti ja kana nguruni gilbarina wonti:   
\p
\v 10 „Kana mandru tarana wonti Godaia pungani ngatjila; kulno Pharisaia nganana wonti, ja kulno mardatandra kampanietja.   
\p
\v 11 Pharisaia terkana wonti ja ngatjina wonti jeruja: «Godajai, ngato jidna jurakokai, ngangau ngani wata kana pilki jeribaka, watawatali maninietja, kana tjikatjika, pinta wokaribanietja, ja bakana wata naupini mardatandra kampanietja jeribaka.   
\p
\v 12 Pota mandru ngani milja ngamai ditji mara wora ja mandruni, ja marapratjanandru ngato buru kulno jinkiai pratjanandru ngato ngamalkai.»   
\p
\v 13 Ja mardatandra kampanietja worita terkana wonti, nau wata jertapaterina wonti milki tjenmala tarala pariwilpaia, a‐ai, nau munambiri nandraterina wonti ja jatana wonti: «Godajai, ngakangu kanani madlentjani kalumiltjamiltjariau!»   
\p
\v 14 Ngani jurangu jatai: Naupini morla talku ngarina tikana wonti pungaia nunkanaia nunkangu. Ngangau warle pirna ngankateriai, nau waka pantjila nganai, ja warle waka ngankateriai, nau pirna pantjila nganai.“   
\b  
\p
\v 15 Tanali bakana kupa waka nunkangu wokaralkana wonti, nulu tanana karakarananto; ja milieli jenia najina, tanali tauaua daudauana wonti.   
\p
\v 16 Jesujeli tanana karkana wonti ja jatana wonti: „Kupa waka worani patanau ngakangu wokarananto, ja tananaia wata daudauanau; ngangau tanangu Godaia milila nganai.   
\p
\v 17 Morlalu ngani jurangu jatai: Warle Godaia milila wata patai kupa wakali jeribaka, nau nunkangu wata wirila nganai.“   
\p
\v 18 Ja kana kaparali nina jakalkana wonti ja jatana wonti: „Ngujangujara jinkinietja ngumujai, mina ngato ngankananto tepi ngurali maratunka manila?“   
\p
\v 19 Jesus nunkangu jatana wonti: „Minandru jundru ngana ngumu dikai? Wata kulno ngumu nganai, windri Goda kulnulu.   
\p
\v 20 Jirijiribani jaura jidni milkila: Wata pinta wokaribamai, wata narielu nandramai, wata kurieli maniamai, wata jedi jaura morlalu jatamai, ngaperi jinkani ja ngandri jinkani pirna ngundramai.“   
\p
\v 21 Nau jatana wonti: „Jenia pratjana ngato ngamalkai kupandru.“   
\p
\v 22 Jesujeli jenia ngarana, Nau nunkangu jatana wonti: „Windri kulno jundru wata ngamalkai: Pratjana mina jundru ngamalkai jinkau kalalaia, ja wangiwangini bakujeli jinkiau, ja jundru poto pirna pariwilpani ngamalkala nganai; ja tikau, ja ngakangu karipateriau!“   
\p
\v 23 Nulu jenia ngarana, nau ngaurongaurorina wonti, ngangau nau poto pirna nganana wonti.   
\p
\v 24 Jesujeli najina, nau ngaurongaurorinani, Nau jatana wonti: „Worderu mati tana kana poto pirna Godaia mililani wirila nganai!   
\p
\v 25 Morla ngaua nganai, Camuli kulno kuri pikiri wilpani palkingananto kana poto pirnani, nau Godaia mililani wirinanto.“   
\p
\v 26 Tanali jenia ngarana jatana wonti: „Warlengarla tepita manila nganai?“   
\p
\v 27 Nau jatana wonti: „Mina kanani ngandandariai, ngarla Godata wata ngandandariai.“   
\p
\v 28 Petrus jatana wonti: „Mai, ngaiani pratjana woraranala ja jinkangu karipaterinala.“   
\p
\v 29 Nau tanangu jatana wonti: „Morlalu ngani jurangu jatai: Wata kulno nganai, nulu matja worarana punga kara, ngaperi ja ngandri kara, neji ngatata kara, noa kara, kupa kara, Godaia mililandru,   
\p
\v 30 Nulu wata pota marapu morla manila nganai nunkangupini miljarani, ja miljarani nau wokarala nganai tepi ngurali.“   
\lit (Ngantjani‐jaura G. D. Quinquagesimä.)  
\p
\v 31 Ja Nulu mili marapratjana patana wonti ja tanangu jatana wonti: „Mai, ngaiana Jerusalemia tarala nganai, ja jenia pratjana morlalu pantjila nganai, mina Propheta worali dakana wonti Kanaia Ngatamurandru.   
\p
\v 32 Ngangau tanali nina kana koni ngulkujeli jinkila nganai, ja tanali nina ngirkibala nganai ja nunkangu madlentji jatala nganai ja ngaltja worala nganai,   
\p
\v 33 Ja tanali nina wirieli nandrala nganai ja nari ngankala nganai; ja ditjini parkulani Nau jiritjila nganai.“   
\p
\v 34 Ja tanali jenia bulu ngujamana wonti, ja naupini jaura tanangu purru nganana wonti, ja tanali bulu patana wonti mina tanangu matja jatana.   
\p
\v 35 Jendranguta Nau Jericho karakara wokarana wonti, ja kana butju paltuni ngamana wonti potuni ngatjila.   
\p
\v 36 Nulu matja ngarana, kana wolara wiri nganani, nulu jakalkana wonti mina jenia nganai.   
\p
\v 37 Tanali nunkangu kaukaubana wonti: „Jesus Nazaretala wiringala wapaia.“   
\p
\v 38 Ja nau maritjina wonti ja jatana wonti: „Jesujai, Davidani ngatamurajai, ngakangu kalumiltjamiltjariau!“   
\p
\v 39 Tana ngopera wiringana nina daudauana wonti nau ngapurinanto; ja nau morla parparali maritjina wonti: „Davidani ngatamurajai, ngakangu kalumiltjamiltjariau!“   
\p
\v 40 Ja Jesus banbana wonti ja jirijiribana wonti nina nunkangu padakananto. Nau nunkangu matja karakara, Nulu nina jakalkana wonti   
\p
\v 41 Ja jatana wonti: „Mina jidni ngantjai, ngato jinkangu ngankananto?“ Nau jatana wonti: „Kaparajai, ngato najinanto.“   
\p
\v 42 Ja Jesus nunkangu jatana wonti: „Najiamai! morlalu ngundranali jinkanali jidna kulkana warai.“   
\p
\v 43 Ja nurujeli nulu nakaldra najina wonti ja nunkangu karipaterina wonti ja Goda jurakokana wonti. Ja kana wolarali pratjanali jenia najina, Goda jurakokana wonti.   
\b  
\c 19  
\lit (Ngantjani‐jaura Godaia punga kulikiri ngankani ditjini.)  
\p
\v 1 Ja Nau wirina wonti, ja Jericho ngurani palkingana wonti.   
\p
\v 2 Ja mai, kana kulno tala nunkani Zachäus, nau mardatandra kampanietjaia kapara nganana wonti, ja kana poto pirna.   
\p
\v 3 Ja nulu wontina wonti Jesus najila worana nau nganai, ja nau ngandandarina wonti kana wolarandru; ngangau nau kana wordu waka nganana wonti.   
\p
\v 4 Ja nau ngopera mindrina wonti ja tandra pitani katina wonti nina najila; ngangau naka Nau palkingananto.   
\p
\v 5 Ja Nau nunkangupini pirini wokarana, Jesujeli nina najina tarana wonti ja nunkangu jatana wonti: „Zachäusajai, nurujeli ngariau, ngangau ngani karari jinkani pungani ngamananto.“   
\p
\v 6 Ja nau nurujeli ngarina wonti, ja murlali pirna nina patana wonti.   
\p
\v 7 Ja pratjanali tanali jenia najina, buljubuljurina wonti ja jatana wonti: „Nauja kana madlentji kulnuni wirina warai jerra ngamala.“   
\p
\v 8 Zachäus karakararina wonti ja Kaparani jatana wonti: „Mai, Kaparajai, poto jura ngakani ngato wangiwangini jinkiai; ja ngani kana kulnundru palpa ngukingukipaterina warai, ngato nunkangu pota mandru mandru morla jinkina tikai.“   
\p
\v 9 Jesus nunkangu jatana wonti: „Karari nunkangupini pungani murla pantjina warai, ngangau nauja bakana Abrahamani ngatamura nganai.   
\p
\v 10 Ngangau Kanaia Ngatamura wokarana wonti wontila ja kulkala, mina tintaterina warai.“   
\b  
\p
\v 11 Tanali jenia ngarana, Nau jeribaka jaura kulno morla jatana wonti, ngangau Nau Jerusalemingu karakara nganana wonti, ja ngangau tanali ngundrana wonti Godaia milila nurujeli wondraterinanto.   
\p
\v 12 Nau jatana wonti: „Kana pirna mita woritaia palkana wonti nunkangu milila manila ja nakaldra tikala.   
\p
\v 13 Nulu mili nunkani marapratjana karkana wonti, ja nulu tanangu mardatandra pirna marapratjana jinkina wonti ja tanangu jatana wonti: «Jinkimalianimai ngani wokaranantulu.»   
\p
\v 14 Kana wolara nunkani nunkangu kalakalarina wonti, ja nunkangu ngadani mili palpa jinpana wonti ja jatana wonti: «Ngaiani wata ngantjai, naupini ngaianingu kapara nganananto.»   
\p
\v 15 Ja jendranguta nau matja tikana ja milila matja manina, nulu jirijiribana wonti tananapini mili nunkangu karkala, tanangu nulu mardatandra matja jinkina; ngangau nulu ngujamananto warle palpa jinkimalinala.   
\p
\v 16 Ngoperala terkana wonti ja jatana wonti: «Kaparajai, mardatandra pirnali jinkanali mardatandra pirna marapratjana morla ngokana warai.»   
\p
\v 17 Ja nau nunkangu jatana wonti: «Matja, jidni mili ngumu, ngangau jidni talku nganana warai wakawakani, ngurula ngamalkau ngura marapratjanani.»   
\p
\v 18 Mili mandrula wokarana wonti ja jatana wonti: «Kaparajai, mardatandra pirnali jinkanali mardatandra pirna mara wora morla ngokana warai.»   
\p
\v 19 Nau bakana nunkangu jatana wonti: «Bakana jidni kapara nganananto ngura mara worani.»   
\p
\v 20 Ja kulno morla wokarana wonti ja jatana wonti: «Kaparajai, najiau mardatandra pirna jinkani, ninapini ngato katieli karana ngamalkana warai;   
\p
\v 21 Ngangau ngani jinkangundru japali nganana warai, ngangau jidni kana ngurunguru nganai; jundru maniai, mina jundru wata kuranala, ja kampai, mina jundru wata jaupanala.»   
\p
\v 22 Nau nunkangu jatana wonti: «Jinkani manandru ngani jinkangu kalala jatai, jidni mili madlentji! Jidni milkila nganana warai ngani kana ngurunguru nganai, ngato maniai, mina ngato wata kuranala, ja kampai, mina ngato wata jaupanala.   
\p
\v 23 Ja minandru jundru mardatandra ngakani wata mardatandrajinkimalinietjani jinkina warai? Ngangau ngato wokaranani nina kalalanto maninanto.»   
\p
\v 24 Ja tanangu naka terkanani Nau jatana wonti: «Nunkangundru ninaia mardatandra pirna manianau, ja ninaia nunkangu jinkianau, nulia mardatandra pirna marapratjana ngamalkai!»   
\p
\v 25 Ja tana nunkangu jatana wonti: «Kaparajai, nulia mardatandra pirna marapratjana ngamalkai!»   
\p
\v 26 Ngangau ngani jurangu jatai: «Nunkangu, nulu ngamalkai, tanali jinkila nganai; nunkangundru, nulu wata ngamalkai, tanali bakana jenia manila nganai, mina nulu ngamalkai.   
\p
\v 27 Tanapini talpala ngakani, tanali wata ngantjana warai, ngani tanangu kapara nganananto, ninkida wokaralkanimai, ja ngakangu milkini nandranimai!»“   
\p
\v 28 Ja Nau jenia matja jatana, Nau ngopera Jerusalemia taringana wonti.   
\p
\v 29 Jendranguta Nau Bethphage ja Bathania ngurani wokarana, nunkangu mardawonpani, nina tanali dikai maninindri mardawonpa, nulu mili mandru nunkani jinpana wonti,   
\p
\v 30 Ja jatana wonti: „Wapalumai nunkangu ngura wakankari, ja judla jerra wirina, judla donki kuparu workamantraterinani mankamankala nganai, nunkangu wata kana kulno dukaterinala; nina dukaralumai ja tikalkalumai!   
\p
\v 31 Ja kulnujeli judlana jakalkanani: «Minandru judla ninaia dukarai?» Jeruja judla nunkangu jatala nganai: «Kaparali ninaia ngamalkananto».“   
\p
\v 32 Pudla mili wulu wapana wonti, ja jeruja mankamankana wonti, worderu Nau pudlangu jatana warai.   
\p
\v 33 Pudlali nina kuparu dukarana, kapara wora nunkani pudlangu jatana wonti: „Minandru judla ninaia kuparu dukarai?“   
\p
\v 34 Pudla jatana wonti: „Kaparali ninaia ngamalkananto.“   
\p
\v 35 Ja pudlali nina Jesungu tikalkana wonti, ja tanali kati tanani nunkangu kuparani kurana wonti, ja Jesus nankangu kurana tarana wonti.   
\p
\v 36 Nau palkanani, tanali kati tanani paltuni jaupana wonti.   
\p
\v 37 Nau maninindri mardawonpaia kalikalini karakara wokarana, mili wolarali wonina wonti mankina Goda ngaiala pirnali jurakokala pirnala pratjanandru, tanali matja najina.   
\p
\v 38 Ja tana jatana wonti: „Ngaiani Kapara jurakokai, Nauja wokarai Kaparaia talani! Murla pariwilpani, ja pirnala mirini!“   
\p
\v 39 Ja Pharisaia palpa kana wolarandru nunkangu jatana wonti: „Ngujangujara jinkinietjajai; milini jinkanani daudauamai!“   
\p
\v 40 Ja Nulu kalabana wonti ja jatana wonti: „Ngani jurangu jatai: Tanapini ngapu ngananani, marda maritjila nganai.“   
\lit (Ngantjani‐jaura G. D. 10. Trinitatis.)  
\p
\v 41 Ja Nau matja karakara wokarana, Nulu ngura najina wonti ja jindrana wonti nunkangundru,   
\p
\v 42 Ja jatana wonti: „Jundru jenia ngujamanani nunkangupini ditjini jinkanani, mina murlani jinkanani nganananto! Ja jenipara jinkangu milkini kurukuru nganala wapaia.   
\p
\v 43 Ngangau ditji wokarala nganai jinkangu, ja talpalali jinkanali wondiri wotina karitjila nganai ja jidna kapikapila nganai, ja paruparu tanali jidna jupala nganai;   
\p
\v 44 Ja tanali jidna ja kupa jinkani dakangandrala nganai, ja tanali wata marda kulno kulnuni parananto worarala nganai; ngangau jundru ngantjani ditji jinkani wata ngujamanala.“   
\p
\v 45 Ja Nau Godaia pungani wirina wonti, ja Nulu wonina wonti tanana narrala, tana nunkangu jinkimalina wonti ja tanali burungankana wonti,   
\p
\v 46 Ja Nau tanangu jatana wonti: „Dakanala parai: Punga ngakani ngatjini punga nganai, ja jura ninaia watawatali maninietjaia minka ngankanala.“   
\p
\v 47 Ja Nulu ditji pratjanani ngujangujara jinkina wonti Godaia pungani. Ja Priesta pirnali ja jaura jinkinietjali ja pinarali wontina wonti nina nandrala,   
\p
\v 48 Ja tanali wata mankamankana wonti mina tanali ngankananto; ngangau kana wolarali nina ngantjana wonti ja nina ngarana wonti.   
\b  
\c 20  
\p
\v 1 Jendranguta ditji kulnuni, Nulu kana wolarani Godaia pungani ngujangujara jinkinani ja ngantjani jaura kaukaubanani, Priesta pirna ja jaura jinkinietja pinarani jela terkakana wonti ja nunkangu jatana wonti:   
\p
\v 2 „Ngaianingu jatamai, mina ngurulali jundru jenia ngankai, ja warle jinkangu ninapini ngurula jinkina warai?“   
\p
\v 3 Nulu kalabana wonti ja tanangu jatana wonti: „Bakana ngato jurana jaura kulno jakalkala nganai, ja jura ngakangu jatananto:   
\p
\v 4 Johannini multibanila, pariwilpandru kara kanandru kara nganana wonti.“   
\p
\v 5 Tana warawarabijiribamalina wonti ja jatana wonti: „Ngaiani jatanani: «Pariwilpandru,» Nauja jatala nganai: Minandru jura nunkangu wata morlalu ngundrana wonti?   
\p
\v 6 Ngaiani jatanani: «Kanandru,» kana wolarali ngaianina mardali diaiati, ngangau tanalia morlalu ngundrai, Johannes Prophata nganana wonti.   
\p
\v 7 Ja tanali kalabana wonti: Ngaiani ko wodajerindru.“   
\p
\v 8 Ja Jesus tanangu jatana wonti: „Bakana ngani jurangu wata jatai, mina ngurulali ngato jenia ngankai.“   
\p
\v 9 Nulu wonina wonti kana wolarani ninapini jeribaka jaura jatala: „Kana kulnujeli wain maru kurana wonti ja nina marunajinajibanietja worangu worarana wonti ja palkana wonti ditji marapu.   
\p
\v 10 Ditji talkuni nulu marunajinajibanietja worangu mili kulno jinpana wonti, tanali nunkangu wain maruja tandra jinkinanto; ja marunajinajibanietja worali nina nandrana wonti, ja nina kala jinpana wonti.   
\p
\v 11 Ja nakaldra nulu mili kulno jinpana wonti; bakana ninapini tanali nandrana wonti, ja nina ngirkibana wonti, ja nina kala jinpana wonti.   
\p
\v 12 Ja nulu mili kulno morla jinpana wonti; tanali bakana nunkangu tapa jinkina wonti, ja nina palarani worarana wonti.   
\p
\v 13 Wain maruja kapara jatana wonti: «Mina ngato ngankananto? Ngato ngatamura ngantjalu ngakani jinpala nganai; tanali nina najinani, tana nintali warawararila nganai kara.»   
\p
\v 14 Wain maru najinajibanietja worali nina najina wonti, tana ngankamalina wonti ja jatana wonti: «Naupini maratunkaia; ngaiani nina nari nandrananto maratunka ngaianani nganananto.»   
\p
\v 15 Ja tanali nina wain marundru palarani worarana wonti, ja nina nari ngankana wonti. Mina wain maruja kaparali tanangu ngankala nganai?   
\p
\v 16 Nau wokarala nganai, ja tananapini marunajinajibanietja worana nandrala nganai.“ Tanali jenia ngarana, tana tatakana wonti: „A‐ai.“   
\p
\v 17 Nulu tanana nguru talpana najina wonti ja jatana wonti: „Mina jenia nganai, matja dakanala parai: Naupini marda, nina wotinietjali worana wonti, nau marda buru pantjina wonti?   
\p
\v 18 Worana nunkangupini mardani puriai, nina nulu nankanankala nganai; worangu nau marda purila nganai, ninapini nulu turara ngankala nganai.“   
\p
\v 19 Ja Priesta pirnali ja jaura jinkinietjali wontina wonti nunkangupini ditjini mara nunkangu kurala, windri tana kana wolarandru japali nganana wonti; ngangau tanali ngujamana wonti, Nau tanangu ninapini jeribaka jaura jatana warai.   
\p
\v 20 Ja tanali nina matja najinajibana, tanali kurukuru najinajibanietja jinpana wonti, tanali jeljujeljujeli talku wondraterina wonti, tanali nina jaurali patananto, ja nina kana kaparani ja najinajibanietjaia ngurulani ngulkujeli jinkinanto.   
\p
\v 21 Ja tanali nina jekibana wonti ja jatana wonti: „Ngujangujara jinkinietjajai, ngaiani milkila, jundru talku kaukaubai, ja ngujangujara jinkiai, ja manubaku nganai, ja morlalu Godaia paltundru ngujangujara jinkiai;   
\p
\v 22 Ngaianingu talku nganai, ngaiani mitaia kaparani kalala jinkinani kara, pani kara?“   
\p
\v 23 Nulu tanani jeljujelju ngujamana wonti, ja Nau tanangu jatana wonti: „Minandru jura ngana wontjai?   
\p
\v 24 Ngakangu kalalaia mardatandra kulno wondralkamai. Waninunkani mudla ja jaura dirkalani nulia ngamalkai?“ Tanali kalabana wonti ja jatana wonti: „Mitaia kaparaia.“   
\p
\v 25 Nau tanangu jatana wonti: „Jinkianau kaparaia poto kaparani ja Godaia poto Godani!“   
\p
\v 26 Ja tanali ngandandarina wonti nina jaura kulnujeli patala kana wolarandru; ja nunkani kalabani jaurandru tana ngaruparana wonti ja ngapurina wonti.   
\p
\v 27 Sadducaia palpa nunkangu karakararina wonti, tana jatai: „Narila wata morla jiritjila nganai,“ ja nina jakalkana wonti ja jatana wonti:   
\p
\v 28 „Ngujangujara jinkinietjajai, Mosili ngaianingu dakana wonti, kana kulnuja nejieli, nulu noa ngamalkana warai, kupa pani palinani, ngatatajeli nunkanali nana widla patananto ja nejini nunkanani ngatamura jiritjibananto.   
\p
\v 29 Neji mara mara wora ja mandru nganana wonti; ja ngoperalali noa patana wonti ja kupa pani palina wonti;   
\p
\v 30 Ja mandrulali nana widla noa patana wonti, nau bakana kupa pani palina wonti.   
\p
\v 31 Ja parkulali nana patana monti, nunkangu jeribaka bakana tanali mara wora ja mandrujeli, ja tanali wata kupa worarana wonti ja palina wonti.   
\p
\v 32 Pratjanani ngadani bakana widla palina wonti.   
\p
\v 33 Terkakani ditjini, waninunkani noa tanangundru nani nganala nganai? ngangau mara wora ja mandrujeli nana noa ngamalkana wonti.“   
\p
\v 34 Ja Jesujeli kalabana wonti ja tanangu jatana wonti: „Nunkanipini mitaia kupali noa patai ja noa pantjiai;   
\p
\v 35 Tana talku nganai jenipara milila ja narindru jiritjina manila, tanali wata noa patai ja noa pantjiai.   
\p
\v 36 Tana ngandandarila nganai palila, ngangau tana angelani jeribaka nganai ja Godaia kupa, ngangau tana narindru jiritjini kupa nganai.   
\p
\v 37 Narila jiritjila nganai, jenia bakana Mosili dilka nindrini wondrana wonti, worderu nulu Kaparani dikai: «Goda Abrahamani ja Goda Isaakani ja Goda Jakobani.»   
\p
\v 38 Goda wata naria Goda nganai, a‐ai, tepia; ngangau nunkangu tana pratjana tepi.“   
\p
\v 39 Jaura jinkinietja palpali kalabana wonti ja jatana wonti: „Ngujangujara jinkinietjajai, jundru ngumu kaukaubana warai.“   
\p
\v 40 Tanali wata morla wontjana wonti nina minakulno jakalkala.   
\p
\v 41 Nau tanangu jatana wonti: „Worderu tana jatai, Christus Davidani ngatamura nganai?   
\p
\v 42 Ja David munta wina jaurani jatai: «Kapara jatanala Kaparani ngakanani: Ngakangu ngunarani ngamana ngariau,   
\p
\v 43 Ngato talpala jinkani jinkangu tidnani kuranantulu, tidnaparani piri jeribaka.»   
\p
\v 44 Davidali nina Kapara dikanani, worderu Nau ngatamura nunkani nganai?“   
\p
\v 45 Kana wolarali jenia ngaranani, Nau milini nunkanani jatana wonti:   
\p
\v 46 „Ngamalkaterianau jaura jinkinietjandru, tanali ngantjai kati wirdieli wirarila, ja jaura murlali jinkimalini pirini, ja ngamani piri ngopera jaura pungani, ja ngamani piri ngopera buka pirnani;   
\p
\v 47 Tanali mangawaruja punga tajiai ja ngatjina wirdieli wondralkateriai. Tanalipini kalala morla pirna manila nganai.“   
\c 21  
\p
\v 1 Nulu najina tarana wonti, ja kana poto pirna najina wonti, worderu tanali poto tanani mardatandra kokuni kurana wonti.   
\p
\v 2 Nulu bakana mangawuru wangiwangi kulno najina wonti, nandru mardatandra wakawaka mandru kurana wonti   
\p
\v 3 Ja jatana wonti: „Morlalu ngani jurangu jatai, nandruja mangawaru wangiwangieli morla kurana wonti pratjanani.   
\p
\v 4 Ngangau tanalipini pratjanali tanani poto manamirindru Godaia potuni kurana warai; nandruja nankani ngaljengaljendru pratjana, mina nandruja ngamalkana warai, nankani poto pratjana, kurana warai.“   
\p
\v 5 Ja palpa Godaia pungandru jatanani, worderu nauja marda ngumujeli ja poto ngumujeli tjirkatjirkaraterina, Nau jatana wonti:   
\p
\v 6 „Jenia mina jura najiai — ditji wokarala nganai, tanangupini wata marda kulno kulnuni parala nganai, ninaia tanali wata dukarala nganai.“   
\p
\v 7 Tanali nina jakalkana wonti ja jatana wonti: „Ngujangujara jinkinietjajai, winta jenia pantjila nganai? Ja mina nauja malka nganai jenia pantjinanto?“   
\p
\v 8 Nau jatana wonti: „Ngamalkaterianau, tanali jurana karkarkaiati; ngangau marapu talani ngakanani wokarala nganai ja jatala nganai: Ngani Naujamata; ja: Miljaru matja karakararina warai. Tanangu wata wapantianau!   
\p
\v 9 Jura tirimalinandru ja tiripatijiritjinandru ngaranani, wata japali ngananau, ngangau jenia ngopera pantjinanto; ju mudani wata nurujeli wokarai.   
\p
\v 10 Ngadani Nau tanangu jatana wonti: Kana wolara tiriterkakala nganai kana wolarani, ja mitaia kaparaia milila mitaia kaparaia mililani,   
\p
\v 11 Ja mita wiltjiwiltjina pirna nganala nganai mankamanka, ja maua pirna ja muntja pirna pilki ja pilki paruparu nganala nganai, ja japa pirna ja malka pirna pariwilpandru pantjila nganai.   
\p
\v 12 Tanangupini pratjanani ngopera tanali jurangu mara kurala nganai ja jurangu tirikaripaterila nganai; tanali jurana jaura pungani ja kanjangarini ngulkujeli jinkila nganai, ja mitaia kaparani ja najinajibanietjani wapalkala nganai ngakani talandru.   
\p
\v 13 Jenia tanali jurangu ngankala nganai malka nganananto.   
\p
\v 14 Jurani ngarali jenia patanau, jura wata manujeli ngundrananto mina jura kalabananto.   
\p
\v 15 Ngangau ngato jurangu mana ja kirila jinkila nganai, nunkangu jurani talpalali pratjanali wata tjakakala nganai, ja wata ngandrawalkala nganai.   
\p
\v 16 Jurana ngaperali ja ngandrieli ja neji marali ja kana kamanelieli ja kamanelieli jurana ngulkujeli jinkila nganai, ja palpa jurangundru tanali nari ngankala nganai.   
\p
\v 17 Ja pratjana jurana kalakalarila ngunai ngakani talandru.   
\p
\v 18 Ja para kulno jurani mangatandrani jura wata tintala nganai.   
\p
\v 19 Jura ngurunguru ngananani, jura mungara jurani kulkala nganai.   
\p
\v 20 Jura najinani tirimalinaia kana wolarali Jerusalem matja kapikapina, ngadani ngujamanau, ngurawalpa nunkani wokarana warai.   
\p
\v 21 Ngadani tana Judaia mitani ngananani mardawonpaia japa mindrinanto, ja tana ngura pirnani terti ngananani puntinanto, ja tana ngura wakani ngananani wata nunkangu wirinanto.   
\p
\v 22 Ngangau kalala ditji tanapini nganai, pratjana morlalu pantjinanto mina dakanala parai.   
\p
\v 23 Jakajai tanangu mandrantjuni ja ngama jinkinietjani tanangupini ditjtni! ngangau ketjaketjana pirna mitani nganala nganai ja tiri tanangupini kana wolarani.   
\p
\v 24 Ja tana kalti tirieli palila nganai, ja tanali tanana dupudupu kana wolara pratjanani wapalkala nganai; ja kana ko wolarali Jerusalem tidnali dakala nganai kana koja ditji mudanantulu.   
\lit (Ngantjani‐jaura G. D. 2. Advent.)  
\p
\v 25 Ja malka pantjila nganai ditji pirnani ja pirani ja ditji wakawakani; ja mitani kana japali nganala nganai ja tana japali ngarrala nganai panto pirna mandikila tutunganani;   
\p
\v 26 Ja kana japandru waltowalto pirna pantjila nganai, ngangau tana japali kalkai mina wolja mita maruni wokarananto; ngangau bakana pariwilpaia ngurula wiltjiwiltjila nganai.   
\p
\v 27 Ja ngadani tanali Kanaia Ngatamura najila nganai talara palkujeli wokaranani ngurunguru ja pirna.   
\p
\v 28 Ja jenia woninani, terkakanau ja mangatandra miririanau, ngangau kulkani jurani karakara wokarai.   
\p
\v 29 Ja Nau jeribaka jaura tanangu jatana wonti: Najianau tandra nindri ja nindri warupoto.   
\p
\v 30 Tana matja kuljakuljarina, jura najiai ja muntali ngujamai, woldrakanja karakara nganai.   
\p
\v 31 Jeruja bakana jura najinani jenia matja pantjina, ngujamanau: Godaia milila karakara nganai.   
\p
\v 32 Morlalu ngani jurangu jatai: Naupini nguja wata mudala nganai jenia pratjana pantjinantulu.   
\p
\v 33 Pariwilpa ja mita maru mudala nganai, ja jaura ngakani wata mudala nganai.   
\p
\v 34 Ngamalkaterianau, jura wata ngara nankaterinanto mirantjatieli tajina ja parawarala tapana ja tepindru manujeli ngundraterina, ja naupini ditji jurangu nurujeli wokaraiati.   
\p
\v 35 Ngangau minti jeribaka nau wokarala nganai kanani warupotuni, tana mita maruni ngamai.   
\p
\v 36 Ngangau milingeru tepi ngamanau, ja ditjini pratjanani ngatjianimai, jura ngurunguru pantjinanto nunkangundru pratjanandru, mina pantjila nganai, japa mindrila, ja Kanaia Ngatamurani terkala.“  
\b  
\p
\v 37 Ditjini Nulu Godaia pungani ngujangujara jinkina wonti, jr tinkani Nau dunkana wonti mukaturarala nunkangu marda wonpani, nina tanali dikai maninindri mardawonpa.   
\p
\v 38 Ja kana wolara dankudankubana nunkangu wokarana wonti Godaia pungani, nina ngarala.   
\c 22  
\p
\v 1 Pulkurutjeribani ditji pirna, nina tanali dikai Passa, karakararina wonti.   
\p
\v 2 Priesta pirnali ja jaura jinkinietjali wontina wonti, worderu tanali nina nari ngankananto, ngangau tana kana wolarandru japali nganana wonti.   
\p
\v 3 Satan wirina wonti Judangu, nau tala Ischariot, nau marapratjana ja mandrundru kulno nganana wonti.   
\p
\v 4 Ja nau wapana wonti ja Priesta pirnani ja jirijiribanietjani ngankamalina wonti, worderu nulu nina tanangu wontawontananto.   
\p
\v 5 Ja tana mankina wonti; ja tana kulnukulnuni nganana wonti nunkangu mardatandra jinkila.   
\p
\v 6 Ja nulu jenia talpadakana wonti, ja ditji talku wontina wonti, nina tanangu kana wolara panini ngulkujeli jinkila.   
\p
\v 7 Pulkurutjeribani ditji pirna kantji wokarana wonti, nunkangupini tanali Passa kuparu nandrananto.   
\p
\v 8 Ja Nulu Petrus ja Johannes jinpana wonti ja jatana wonti: „Wapalumai ja Passa kupara ngaianani ngankingalumai, ngaiana nina tajinanto.“   
\p
\v 9 Pudla nunkangu jatana wonti: „Wodaninkinaia jidni jertapateriai ngali nina ngankingananto.“   
\p
\v 10 Nau pudlangu jatana wonti: „Mai, judla ngurani wirinani, kana kulno judlangu mandurila nganai, nulu ngapakoko mandrai; nunkangu karipaterialumai pungaia, woderi nau wiriai,   
\p
\v 11 Ja punga ngamalkanietjani jatalumai: Ngujangujara jinkinietja jinkangu jatai: Woderi tajini piri nganai, nunkangu ngato Passa kuparu ngakani milintali tajinanto?   
\p
\v 12 Ja nulu judlangu tajini piri pirna, matja ngankingana, wondrala nganai, naka nina ngankingalumai.“   
\p
\v 13 Pudla matja wapana, pudlali jeruja mankamankana wonti, worderu Nau pudlangu jatana warai: ja pudlali Passa kuparu ngankingana wonti.   
\p
\v 14 Ja ditji matja wokarana, Nau ngamana ngarina wonti, ja Apostel marapratjana ja mandru nunkangunto.   
\p
\v 15 Ja Nau tanangu jatana wonti: „Ngani wolkareli ja ngalkujeli nganana warai ninapini Passa kuparu jurangu jelali tajila ngakani ketjaketjanani ngopera.   
\p
\v 16 Ngangau ngani jurangu jatai: Ngato ninaia wata morla tajila nganai, jenia Godaia mililani morlalu pantjinantulu.“   
\p
\v 17 Ja Nulu koko patana wonti ja jurakokana wonti ja Nau jatana wonti: „Ninapini patanau ja jura muntali puntibijiribamalianau.   
\p
\v 18 Ngangau ngani jurangu jatai: Ngato wata morla waina nindri tandrandru tapala nganai Godaia milila wokaranantulu.“   
\p
\v 19 Ja Nulu buka patana wonti ja jurakokana wonti ja nina wokaribana wonti ja tanangu jinkina wonti ja jatana wonti: „Naupini ngani palku nganai, ninaia ngani jurangu jinkiteriai; jeruja ngankanimai ngakangu ngundrala!“   
\p
\v 20 Jeruja bakana koko tajinani ngadani, ja jatana wonti: „Naupini koko Testamenta marra nganai ngakani kumarani, ninaia ngani jurangu nangateriai.“   
\p
\v 21 Ja mai, ngakani wontawontanietjaia mara ngakangunto kurlini nganai.   
\p
\v 22 Ja Kanaia Ngatamura wapai worderu morlalu kurana wonti; ja jakajai nunkangupara kanani, nulia ninaia wontawontala nganai.   
\p
\v 23 Ja tanali wonina wonti jakalkijiribamalila, warlenulu tanangundru nganai, nulia jenia ngankala nganai.   
\lit (Ngantjani‐jaura Bartholomäuni ditjini.)  
\p
\v 24 Tana bakana jatamalina wonti jendrangundruja, worananau morla pirna nganai tanangundru.   
\p
\v 25 Nau tanangu jatana wonti: „Kana wolaraia kaparali tanangu jirijiribai, ja ngurula ngamalkanietja tanani tanali dikai: «kapara ngumu.»   
\p
\v 26 Jura wata jeruja, a‐ai, worananau morla pirna jurangundru nganai, wakani jeribaka pantjinanto; ja kapara milini jeribaka.   
\p
\v 27 Ngangau worananau morla pirna nganai, nau kurlini ngamai kara, nau mili nganai kara? Wata jeruja nganai, nau kurlini ngamai? Ngani jurangu terti nganai mili jeribaka.   
\p
\v 28 Jura tanaia nganai, tanaia ngakangunto wonki nganana warai ngakani wontjanani;   
\p
\v 29 Ja ngato jurangu milila jinkiai, worderu Ngaperali ngakanali matja jinkina; ngangau jura tajinanto ja tapananto ngakani kurlini mililani ngakanani.   
\p
\v 30 Ja jura kaparaia pirini ngamala nganai Israelani kapara marapratjana ja mandruni kalala kurala.“   
\b  
\p
\v 31 Kapara jatana wonti: „Simoniai, Simoniai, mai, Satanali wontjana warai jurana buka tandra jeribaka tarauala.   
\p
\v 32 Ngani jinkangundru ngatjina warai, morlalu ngundrana jinkani wata mudananto; ja jidni ngadani matja madlentjandru karitjina, ngatata jinkani ngurunguru ngankau!“   
\p
\v 33 Nau nunkangu jatana wonti: „Kaparajai, ngani matja ngankaterina, jinkangunto bakana kanjangaria ja naria wapala.“   
\p
\v 34 Nau jatana wonti: „Ngani jinkangu jatai Petrujai: Karari paia ngaperi wata jatala nganai, windrila jundru ngana pota parkulu jedieli worarala nganai ngana ngujamala.“   
\p
\v 35 Ja Nau tanangu jatana wonti: „Ngato jurana marakala jinpanala, billi ja pailtji ja tidnaputa pani, jura palpa wata ngamalkanala?“ Tana jatana wonti: „Pani.“   
\p
\v 36 Nau tanangu jatana wonti: „Karari, warle billi ngamalkai, ninaia maniatimai, jeruja bakana pailtji; ja warlenulu wata ngamalkai, kati nunkani kalalaia jinkiatimai ja mardakirra burungankaiatimai.   
\p
\v 37 Ngangau ngani jurangu jatai: Bakana jenia, mina ngakagundru morla dakanala parai, morlalu pantjinanto; jenia: Tanali nina madlentji ngankanietjani terti kurana wonti; ngangau mina ngakangundru dakanala parai, matja mudana.“   
\p
\v 38 Tana jatana wonti: „Kaparajai, najiau ninkida mardakirra mandru parai!“ Nau tanangu jatana wonti: „Matja.“   
\p
\v 39 Ja Nau dunkana wonti ja maninindri mardawonpaia wapana wonti, worderu Nulu milingeru ngankana wonti; ja nunkangu bakana mili nunkani karipaterina wonti.   
\p
\v 40 Nau pirini matja wokarana, Nau tanangu jatana wonti: „Ngatjianimai jura wontjanilani wiriati.“   
\p
\v 41 Ja Nau tanangundru kulnulu tjiringana wonti, diani marda worita jeribaka, ja pantjaterkana ngarina wonti ja ngatjina wonti ja jatana wonti:   
\p
\v 42 „Ngaperiai, jidni jertapaterinani ninapini koko ngakangu wirilkingala; wata jertapaterina ngakani, a‐ai, jinkani pantjinanto.“   
\p
\v 43 Angela kulno pariwilpandru nunkangu wondraterina wonti nina ngurunguru ngankala.   
\p
\v 44 Ja Nau naritirimalini wirinani, Nau morla parparali ngatjina wonti; ja kangu nunkani kumari jeribaka ngakana wonti.   
\p
\v 45 Ja Nau ngatjinandru matja terkana tarana, Nau milini nunkanani wokarana wonti, ja Nulu tanana ngaurongaurojeli mukaturaranani mankamankana wonti,   
\p
\v 46 Ja tanangu jatana wonti: „Minandru jura mukaturarai? Terkakanau ja ngatjianau, jura wontjanilani wiriati.“   
\p
\v 47 Nau jenia jatanani, mai, kana wolara, ja Judas marapratjana ja mandrundru kulno, tanangu ngopera wapana wonti, ja Jesungu karakararina wonti nina manatapala.   
\p
\v 48 Jesus nunkangu jatana wonti: „Judajai, manatapanali jundru Kanaia Ngatamura wontawontai?“   
\p
\v 49 Tanali nunkangunto matja najina, mina pantjiati, tana nunkangu jatana wonti: „Kaparajai, ngaiani mardakirrali nandrananto?“   
\p
\v 50 Ja kulnujelit anangundru Priesta pirnaia mili nandrana wonti, ja nina talpa ngunari wokaribana wonti.   
\p
\v 51 Jesujeli kalabana wonti ja jatana wonti: „Karari mudau!“ Ja Nulu nina talpa karakarana wonti ja nina tepi ngankana wonti.   
\p
\v 52 Jesus jatana wonti Priesta pirnani ja Godaia pungaia kaparani ja pinarani, tana nunkangu matja wokarana: „Watawatali maninietjani jeribaka jura dunkana warai mardakirrali ja pitali?   
\p
\v 53 Ngani jurangunto Godaia pungani nganana warai, jura mara jurani wata ngakangu ngutana warai. Ja naupini jurani ditji nganai ja ngalpuruja ngurula.“   
\p
\v 54 Tanali nina patana wonti ja nina wapalkana wonti ja nina Priesta pirnaia pungani wirilkana wonti. Ja Petrus woritandru wapantina wonti.   
\p
\v 55 Tanali pirini terti matja turu miribana ja ngamana ngarina, bakana Petrus tanangu terti ngamana ngarina wonti.   
\p
\v 56 Widla milieli nina turuni ngamanani najina, ja nina ngurutalpana najina, nani jatana wonti: „Bakana naupini nunkangunto nganana warai!“   
\p
\v 57 Nau jedina wonti ja jatana wonti: „Widlajai, ngato nina wata ngujamai.“   
\p
\v 58 Ja wolja nina kulnujeli najina wonti ja jatana wonti: „Bakana jidni tanangundru kulno nganai!“ Petrus jatana wonti: „Wata ngani.“   
\p
\v 59 Ja ditji kulno matja mudana, kulnujeli morlalu kurana wonti ja jatana wonti: „Morlalu, bakana naupara nunkangunto nganana warai, ngangau nauja Galilaiala nganai!“   
\p
\v 60 Petrus jatana wonti: „Kanajai! Ngani ko mina jidni jatai.“ Ja nurujeli, nau jeruja jatanani, paia ngaperi jatana wonti.   
\p
\v 61 Ja Kaparali najina karitjina wonti ja Petrus najina pararana wonti. Ja Petrulu Kaparaia jaura ngundrana wonti, worderu Nau nunkangu jatala wiri: „Morla ngopera, windrila paia ngaperi jatananto, jundru ngana pota parkulu jedieli worarala nganai.“   
\p
\v 62 Ja Petrus palaraia dunkana wonti ja burkali pirna jindrana wonti.   
\p
\v 63 Ja kanali, tanali Jesus patana wonti, nina ngirkibana wonti ja nandrana wonti.   
\p
\v 64 Ja tanali nina matja walpadakana, tanali nina mudla nandrana wonti ja nina jakalkana wonti ja jatana wonti: „Ngaianingu morlalu jatamai, warlenulu jidna nandrana warai?“   
\p
\v 65 Ja ngirkibani jaura marapu morla tana nunkangu jatana wonti.   
\p
\v 66 Ja matja ditjirina, kana wolaraia pinaru pratjana ja Priesta pirna ja bakana jaura jinkinietja jurborina wonti, ja tanali nina kaparani tananani wapalkana wonti,   
\p
\v 67 Ja jatana wonti: „Jidni Christus nganai? Ngaianingu jatau!“ Nau tanangu jatana wonti: „Ngani jurangu jatanani, jura wata morlalu ngundranani;   
\p
\v 68 Ngato jurana jakalkanani, jura ngakangu wata kalabanani, ngana kurakanani kara.   
\p
\v 69 Kararindru Kanaia Ngatamura Godaia ngurulaia ngunarani ngamala nganai.“   
\p
\v 70 Tana pratjana jatana wonti: „Ngarla jidni Godaia Ngatamura?“ Nau tanangu jatana wonti: „Jura jenia jatai, ngangau ngani Nauja.“   
\p
\v 71 Tana jatana wonti: „Mina jaura morlalu ngaiana morla ngamalkananto? Ngangau ngaiana muntali jenia nunkani manandru ngarana warai.“   
\c 23  
\p
\v 1 Ja kana wolara tanani terkakana wonti ja nina Pilatungu wapalkana wonti.   
\p
\v 2 Tanali wonina wonti nunkangu ngulkuterkala ja jatana wonti: „Ninapini ngaiani mankamankana warai, Nulia kana wolara ngaianini tjautjau ngankai ja daudauai mitaia kaparani kalala jinkila ja jatai, Nauja Christus Kapara nganai.“   
\p
\v 3 Pilatulu nina jakalkana wonti ja jatana wonti: „Jidni Juda kanaia Kapara nganai?“ Nulu nunkangu kalabana wonti ja jatana wonti: „Jidni matja jatai.“   
\p
\v 4 Pilatus Priesta pirnani ja kana wolarani jatana wonti: „Ngato madlentji pani nunkangupini kanani mankamankai.“   
\p
\v 5 Ja tana jadijadibana wonti ja jatana wonti: „Nulia kana wolara patijiritjibai ja Judaia mitani pratjanani ngujangujara jinkiai, ja Nulia Galilaiandru wonina wonti ninkidanilu.“   
\p
\v 6 Pilatulu Galilaia ngarana, nulu jakalkana wonti: „Nauja kana Galilaiala?“   
\p
\v 7 Ja nulu matja ngujamana, Nau Herodini ngurulandru nganai, nulu nina Herodingu jinpana wonti, naupini nunkangupini ditjini bakana Jerusalemingu nganana wonti.   
\p
\v 8 Herodilu Jesus najina, nau pirna mankina wonti; ngangau nau ditji marapuni wolkareli nganana wonti nina najila, ngangau nulu marapu nunkangundru ngarana wonti, ja nau kalkaterina wonti malka kulno nunkangundru najila.   
\p
\v 9 Nulu nina jaura marapujeli jakalkana wonti, ja Nulu nunkangu panila kalabana wonti.   
\p
\v 10 Priesta pirna ja jaura jinkinietja naka terkana wonti, tana nunkangu pirna ngulkuterkana wonti.   
\p
\v 11 Herodili ja milieli nunkanali nina tilpana wonti ja ngirkibana wonti, ja nulu nina kati waru widmana wonti, ja nina nakaldra Pilatungu jinpana tikana wonti.   
\p
\v 12 Pilatus ja Herodes nunkangupini ditjini kamaneli pantjina wonti; ngangau pudla ngopera kalakalarilkijiribamalina wonti.   
\p
\v 13 Pilatulu Priesta pirna ja kana kapara ja kana wolara matja mapana, nau tanangu jatana wonti:   
\p
\v 14 „Jura ninapini kana ngakangu wapalkana warai kulnuni jeribaka, nulu kana wolara karkarkai; ja mai, ngato jurangu mudlani ninaia wontjana warai, ja ngato nunkangupini kanani madlentji pani mankamankana warai, pratjanani jura nunkangundru ngulkuterkai.   
\p
\v 15 Bakana Herodili pani; ngangau ngato jurana nunkangu jinpana warai, ja mai, wata madlentji Nulia ngankana warai, jendrali Nauja palinanto.   
\p
\v 16 Ngato ninaia nandrala nganai ja kurakala nganai.“   
\p
\v 17 Ngangau nulu tanangu ditji pirnani kulno kurakananto.   
\p
\v 18 Tana pratjana maritjina wonti ja jatana wonti: „Ninapini worau, ja ngaianingu Barabbas kurakau!“   
\p
\v 19 Naupini tiripatijiritjinandru ngurani matja pantjina, ja nari nandranandru kanjangarini ngamana wonti.   
\p
\v 20 Nakaldra Pilatulu tanangu jaura kaukaubana wonti, ngangau nau jertapaterina wonti Jesus kurakala.   
\p
\v 21 Tana maritjina wonti ja jatana wonti: „Kunarkuni katibamai, kunarkuni ninaia katibamai!“   
\p
\v 22 Nau pota parkulula tanangu jatana wonti: „Mina madlentji Nulupini ngankanala? Ngato wata madlentji nunkangu mankamankana warai jendrali Nauja palinanto; ngato ninaia nandrala nganai ja kurakala nganai.“   
\p
\v 23 Tanali nina ngaiala pirnali winpana wonti ja ngatjina wonti, Nauja kunarkuni parananto. Ja tanani ja Priesta pirnaia ngaialali kalalu ngankana wonti.   
\p
\v 24 Pilatulu morlalu kurana wonti tanani ngatjina pantjinanto.   
\p
\v 25 Nulu tanangu ninapini kurakana wonti, nau tiripatijiritjinandru ja nari ngankanandru kanjangarini ngamana wonti. Ja nulu Jesus tanani jertapaterinani jinkina wonti.   
\p
\v 26 Ja tanali nina wapalkana, tanali Simon, Kyrenala kulno, watawatali patana wonti, nau marundru tikanani, ja nunkangu kunarku kurana wonti, nulu nina Jesungu ngadani waltananto.   
\p
\v 27 Bakana kana wolara ja widla marapu nunkangu karipaterina wonti, tana nunkangundru ngaurongauro nganana wonti ja jindrana wonti.   
\p
\v 28 Jesus tanangu jatana karitjina wonti: „Jura Jerusalemini ngatamura worai, wata ngakangundru jindranau, a‐ai, jurangundru munta ja jurani kupandru jindranau!   
\p
\v 29 Ngangau mai, ditji wokarala nganai, tanangupini tana jatala nganai: Murlali pirna tana ngameri, ja tana palku wata kantjirina warai, ja tana ngama, tanali wata tapananto jinkina warai!   
\p
\v 30 Ngadani tanali wonila nganai mardawonpani jatala: Ngaianingu woraterianau! ja wonpani: Ngaianina walpadakanau;   
\p
\v 31 Ngangau tanali jenia pita tjankani ngankanani, mina mujani pantjinanto?“   
\p
\v 32 Tanali bakana madlentji ngankanietja mandru morla wapalkana wonti, pudlana nunkangunto nari ngankala.   
\p
\v 33 Ja tana nunkangupini pirini, tala nunkani „mangatandra piri“ matja wokarana, tanali nina naka kunarkuni katibana wonti, ja madlentji ngankanietja kulno ngunarani ja kulno worangantjuni.   
\p
\v 34 Jesus jatana wonti: „Ngaperiai, tanangu woramai, ngangau tanali mangapunkujeli jenia ngankai.“ Tanali kati nunkani puntibana wonti wontjani malkali.   
\p
\v 35 Ja kana wolara terkana wonti najila. Tanangunto bakana kana kaparali ngirkibana wonti ja jatana wonti: „Nguru Nulia kulkanala; Nauja munta kulkateriatimai, Nauja Christus, Godaia kalkalkani ngananani!“   
\p
\v 36 Nina bakana mitaia kaparaia milieli ngirkibana wonti, tana karakararina wonti ja nunkangu kaldri pilki jinkina wonti,   
\p
\v 37 Ja jatana wonti: „Jidni Juda kanaia Kapara ngananani, munta kulkateriamai!“   
\p
\v 38 Bakana nunkangu miri jaura dakani parana wonti Griekaia ja Romaia ja Juda kanaia jaurali: „NAUPINI JUDA KANAIA KAPARA NGANAI.“   
\p
\v 39 Madlentji ngankanietja kulnujeli, kunarkuni warukana, nina ngirkibana wonti ja jatana wonti: „Jidni Christus ngananani, munta kulkateriamai ja ngalina.“   
\p
\v 40 Nulu kulnujeli kalabana wonti ja nina daudauana wonti ja jatana wonti: „Jidni bakana wata Godandru japali nganai, ngangau jundru bakana ninapini kalala ngamalkai?   
\p
\v 41 Ja talku ngaldrangu, ngangau ngaldra maniai, mina ngaldra ngankanala;“ nulupini wata madlentji ngankana warai.   
\p
\v 42 Ja nau Jesungu jatana wonti: „Kaparajai, ngana ngundramai, jidni mililani jinkanani wokaranani!“   
\p
\v 43 Jesus nunkangu jatana wonti: „Morlalu ngani jinkangu jatai: Karari jidni ngakangunto Paradiesini nganala nganai.“   
\p
\v 44 Ja toda ngalpuru pirna pantjina wonti mita maruni ditji kunarkujelu.   
\p
\v 45 Ja ditji pirna ngalpuru pantjina wonti, ja Godaia pungaia kati pirna terti puraterina wonti.   
\p
\v 46 Ja Jesus ngaiala pirnali karkana wonti ja jatana wonti: „Ngaperiai! marani jinkanani ngato Jaola ngakani kurai.“ Ja Nau jenia matja jatana, Nau palina wonti.   
\p
\v 47 Juljaia kaparali jenia najina, mina pantjina, nulu Goda jurakokana wonti ja jatana wonti: „Morlalu, Naupini kana talku nganana warai.“   
\p
\v 48 Ja kana wolara pratjanali tana wokarana warai najila, tanali matja najina mina pantjinani, tana munampiri nandraterina wonti ja tikana karitjina wonti.   
\p
\v 49 Worita terkana wonti kamaneli nunkani pratjana, ja tana widla nunkangu Galilaiandru karipaterina warai, ja tanali jenia najina wonti.   
\p
\v 50 Ja mai, kana kulno tala nunkani Joseph, kana kapara, kana ngumu ja talku.   
\p
\v 51 Naupini ngankamalinani tananani ja ngankanani tananani manukulkaterina wonti — nau Arimathia Juda kana ngura kulnundru, nulu bakana Godaia mililani kalkana wonti.   
\p
\v 52 Nau Pilatungu wapana wonti ja Jesu palkuni ngatjina wonti.   
\p
\v 53 Ja nulu nina matja ngarilkana, nulu nina katieli karana wonti ja narikutuni, mardani matja bakuna, kurana wonti, nunkangu wata kulno parana wonti.   
\p
\v 54 Ja ngankingani ditji nganana wonti, ja Sabbat ditjini kupiri nganana wonti.   
\p
\v 55 Bakana widla, nunkangu matja karipaterina, tana nunkangunto Galilaiandru wokarala wiri, nina narikutu najina wonti, worderu palku nunkani paranani.   
\p
\v 56 Tana matja tikana, tanali kuli ngumu ja gildi pilki ngankingana wonti; ja Sabbat ditjini tana ngapu nganana wonti jirijiribani jaurandru.   
\c 24  
\p
\v 1 Godaia ditji nguramaranani tana nariwonpani wokarana wonti, ja kuli ngumu, nina tanali matja ngankingana, padakana wonti, ja palpa tanangunto.   
\p
\v 2 Tanali marda nari kutundru matja tiringana mankamankana wonti.   
\p
\v 3 Ja tana matja wirina, tanali Jesu Kaparaia palku wata mankamankana wonti.   
\p
\v 4 Ja jendranguta tana jendrangundruja mangapunkujeli nganana wonti, ja mai, materi mandru tanangu wokarana wonti mintjini katieli.   
\p
\v 5 Tana japali pantjinani ja mudla tanani mitani buruna ngarinani, pudla tanangu jatana wonti: „Minandru jura Tepita narini wontiai?   
\p
\v 6 Nau wata ninkida nganai, a‐ai, Nau jiritjina warai. Ngundranau worderu Nulu jurangu kaukaubana paraia, Nau Galilaiani matja nganana,   
\p
\v 7 Ja jatana paraia: Tanali Kanaia Ngatamura kana madlentjia marani jinkinanto ja kunarkuni katibananto, ja ditjini parkulani Nau jiritjinanto.“   
\p
\v 8 Ja tanali jaura nunkani ngundrana wonti.   
\p
\v 9 Ja tana narikutundru karitjina tikana wonti ja jenia pratjana marapratjana ja kulnuni ja tanangu pratjanani kaukaubana wonti.   
\p
\v 10 Maria Magdalala ja Johanna ja Maria Jokobuni, ja tana widla palpa, tanangunto nganana wonti, tana jenia Apostelani jatana wonti.   
\p
\v 11 Ja tanani kaukaubani jaura tanangu jaura baku jeribaka nganana wonti, ja tanali tanangu wata morlalu ngundrana wonti.   
\p
\v 12 Petrus terkakana wonti ja nari kutuja mindrina wonti; ja nulu matja buruna ngulukana, nulu windri kati paranani najina wonti; ja nau pungani tikana wonti ja pirna ngaruparana wonti jendrangundruja, mina pantjina warai.   
\lit (Ngantjani‐jaura Jesu tepi terkakani ditji mandrulani.)  
\p
\v 13 Ja mai, mandru tanangundru nunkangupini ditjini ngura kulno wakaia wapana wonti, tala nunkani Emaus, nau Jerusalemingundru 60 Statia worita nganana wonti.   
\p
\v 14 Ja pudla ngankamalina wonti jenia pratjanandru, mina pantjina warai.   
\p
\v 15 Ja jendranguta pudla ngankamalinani ja jakalkijiribamalinani, bakana Jesus munta karakara wokarana wonti, ja pudlangunto wapana wonti.   
\p
\v 16 Pudlani milki njurlunjurlurina wonti nina wata ngujamala.   
\p
\v 17 Nau pudlangu jatana wonti: „Mina jaura judla ngankamaliai paltuni, ja minandru judla ngaurongauro nganai?“   
\p
\v 18 Kulnujeli, tala nunkani Kleophas, kalabana wonti ja nunkangu jatana wonti: „Jidni kulnulu tidnapalara Jerusalemingu nganai, nulupini wata ngarana warai, mina naka tanangupini ditjini matja pantjina?“   
\p
\v 19 Ja Nau pudlangu jatana wonti: „Mina?“ Pudla nunkangu jatana wonti: „Jenia Jesus Nazarenalandru, Naupini Propheta talku nganana wonti, ngankanali ja jaurali ngurunguru Godani ja kana wolarani.   
\p
\v 20 Ja worderu Priesta pirnali ja kana kaparali ngaianinali nina naria ngulkujeli jinkila wiri, ja nina kunarkuni katibala wiri.   
\p
\v 21 Ngaiani kalkanala, Nulu Israel kulkananto. Ja karari ditji parkulu nganai, jenia pratjana pantjila wiri.   
\p
\v 22 Ja bakana widla palpali ngaianingundru ngaianina ngaruparibana warai, tana nguramarani nariwonpani wokarana warai.   
\p
\v 23 Ja tanali palku nunkani wata mankamankana warai ja tikana warai ja jatana warai, tanali angela mudla matja najina, tana jatai, Nau tepi nganai.   
\p
\v 24 Ja palpa ngaianingundru narikutuni wokarana warai, ja jeruja mankamankana warai, worderu widla likaukaubana warai; windri nina tanali wata najina warai.“   
\p
\v 25 Ja Nau pudlangu jatana wonti: „Judla kana patipati ja ngara ngurunguru jenia pratjana morlalu ngundrala, mina Prophetali kaukaubana wonti.   
\p
\v 26 Wata jenia Christulu ketjaketjananto ja pirnalani nunkanani wirinanto?“   
\p
\v 27 Ja Nulu wonina wonti pudlangu Mosingundru ja Propheta pratjanandru jenia mildiri ngankala, mina tanali jaurani tananani pratjanani jatana wonti.   
\p
\v 28 Ja tana nunkangupini nguraia karakara wokarana wonti wodajeri pudla wapananto; ja Nulu malka wondrana wonti, Nau wiringananto.   
\p
\v 29 Ja pudlali nina parparali ngankana wonti ja jatana wonti: „Ngalingu ngamamai, ngangau matja kalkaurariai ja ditji panila.“ Ja Nau wirina wonti pudlangu jela ngamala.   
\p
\v 30 Ja jendranguta Nau pudlangunto matja ngamana ngarina, Nulu buka patana wonti ja nina ngurungutana wonti ja wokaribana wonti ja pudlangu jinkina wonti.   
\p
\v 31 Pudla milki piririna wonti, ja pudlali nina ngujamana wonti; ja Nau pudlangundru kutingana wonti.   
\p
\v 32 Ja pudla ngankamalina wonti: „Wata ngaldra ngara jerkina warai, worderu Nulu paltuni ngaldrangu kaukaubana warai, ja worderu Nulu ngaldrangu jaura worana mildiri ngankana warai?“   
\p
\v 33 Ja pudla nunkangupini ditjini jiritjina wonti ja Jerusalemia tikana karitjina wonti; ja pudlali marapratjana ja kulno ja tanana tanangunto matja jurborina, mankamankana wonti.   
\p
\v 34 Ja tana jatana wonti: „Kapara morlalu jiritjina warai ja Simoningu wondraterina warai!“   
\p
\v 35 Ja pudlali kaukaubana wonti mina paltuni matja pantjina, ja worderu pudlali nina ngujamana warai buka wokaribanani.   
\b  
\lit (Ngantjani‐jaura Jesu tepi terkakani ditji parkulani.)  
\p
\v 36 Tana jenia kaukaubijiribamalinani Jesus munta tanangu terti terkana wonti ja tanangu jatana wonti: „Murla jurangunto nganaiatimai!“   
\p
\v 37 Tana ngarrana wonti ja japali pirna pantjina wonti, ja tanali ngundrana wonti, tanali jaola najiai.   
\p
\v 38 Ja Nau tanangu jatana wonti: „Minandru jura japali pirna nganai; ja minandru ngarali juranali mangangankana jiritjiai?   
\p
\v 39 Ngana mara ja ngana tidna najianau, ngani munta Nauja nganai; ngana karakaranau ja najianau, ngangau jaolali wata palku ja moku ngamalkai, worderu jura najiai ngato ngamalkanani.“   
\p
\v 40 Ja Nau jenia matja jatana, Nau mara ja tidna tanangu wondraterina wonti.   
\p
\v 41 Ngangau tanali mankinandru wata morlalu ngundrana wonti ja ngaruparana wonti, Nau tanangu jatana wonti: „Jura ninkida palpa ngamalkai tajinanto?“   
\p
\v 42 Tanali nunkangu paru buru kulno, matja wajina, ja pitjambu jinkina wonti.   
\p
\v 43 Ja Nulu nina patana wonti ja tanangu milkini tajina wonti.   
\p
\v 44 Nau tanangu jatana wonti: „Tanapini jaura ngakani nganai, tananaia ngato jurangu kaukaubanala ngani jurangunto nganana, ngangau pratjana morlalu pantjinanto mina Mosini jirijiribani jaurani ja Prophetani ja wima jaurani ngakangundru dakanala parai.“   
\p
\v 45 Ngadani Nulu tjuru tanani piri ngankana wonti jaura worana ngujamananto.   
\p
\v 46 Ja Nau tanangu jatana wonti: „Jeruja dakanala parai, ja jeruja Christus ketjaketjananto, ja ditjini parkulani jiritjinanto.   
\p
\v 47 Ngangau tanali talani nunkanani madlentjandru karitjina ja madlentji kalingana kanani warupotuni kaukaubananto ja Jerusalemingu woninanto.   
\b  
\p
\v 48 Jura jenia pratjanandru morlalu kuranietja nganai.   
\p
\v 49 Ja mai, ngato jurangu Ngaperaia ngakanaia talpada‐kanila jinpala nganai; Jerusalem ngurani ngamanau, jura ngurula mirindru widmaterilalu.“   
\p
\v 50 Ngadani Nulu tanana Bethaniaia dunkalkana wonti, ja Nau mara ngutaterina wonti, ja Nulu tanana ngurungutana wonti.   
\p
\v 51 Ja jendranguta Nulu tanana matja ngurungutana, Nau tanangundru danina wonti ja pariwilpaia tarana wonti.   
\p
\v 52 Ja tanali nunkangu matja pantjaterkana ngatjina, tana Jerusalemia tikana kurana wonti mankinali.   
\p
\v 53 Ja tana milingeru Godaia pungani ngamana wonti, ja Goda jurakokana wonti ja ngatjina wonti.   