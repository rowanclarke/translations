\v 11 \w Y|strong="H3068"\w* \w vino|strong="H1961"\w* \w Palabra|strong="H1697"\w* \w de|strong="H1697"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w a|strong="H3068"\w* \w Salomón|strong="H8010"\w*:
\v 12 \wj \w En|strong="H3212"\w* cuanto \w a|strong="H3068"\w* \w esta|strong="H2088"\w* \w Casa|strong="H1004"\w* \w que|strong="H1697"\w* \w tú|strong="H6213"\w* \w edificas|strong="H1129"\w*, si andas \w en|strong="H3212"\w* mis \w Estatutos|strong="H2708"\w*, ejecutas mis \w Ordenanzas|strong="H4941"\w* y \w guardas|strong="H8104"\w* \w todos|strong="H3605"\w* mis \w Mandamientos|strong="H4687"\w* al \w andar|strong="H3212"\w* \w en|strong="H3212"\w* \w ellos|strong="H2708"\w*, entonces \w Yo|strong="H6213"\w* cumpliré mi \w Palabra|strong="H1697"\w* \w que|strong="H1697"\w* \w hablé|strong="H1696"\w* \w a|strong="H3068"\w* \w tu|strong="H6213"\w* padre \w David|strong="H1732"\w*: \wj*
\v 13 \wj Moraré \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* y \w no|strong="H3808"\w* \w abandonaré|strong="H5800"\w* \w a|strong="H3068"\w* mi \w pueblo|strong="H5971"\w* \w Israel|strong="H3478"\w*.\wj*
