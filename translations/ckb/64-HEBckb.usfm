\id HEB - Biblica® Open Kurdi Sorani Standard Version 
\h عیبرانییەکان 
\toc1 نامە بۆ عیبرانییەکان 
\toc2 عیبرانییەکان 
\toc3 عیبرانییەکان 
\mt1 نامە بۆ عیبرانییەکان 
\c 1  
\s1 پایەبەرزی عیسای مەسیح 
\p  
\v 1 لە سەردەمانی کۆنەوە خودا زۆر جار و بە ڕێگای جۆراوجۆر بەهۆی پێغەمبەرانەوە لەگەڵ باوباپیراندا دواوە،  
\v 2 بەڵام لەم ڕۆژانەی کۆتاییدا بەهۆی کوڕەکەیەوە لەگەڵمان دوا، ئەوەی دەستنیشانی کردووە وەک میراتگری هەموو شتێک و لە ڕێگەی ئەویشەوە گەردوونی دروستکردووە.  
\v 3 کوڕەکە تیشکی شکۆی خودایە و بە تەواوی وێنەی کڕۆکیەتی\f + \fr 1:3 \ft وێنەی کڕۆکیەتی: مەبەستی لەوەیە کە مەسیح دەربڕینێکی ڕاستەقینەی ناخی خودایە.‏\f*، هەڵگری هەموو شتێکە بە هێزی فەرمایشتی خۆی، لەدوای ئەوەی هەموو گوناهەکانی پاک کردەوە، لە دەستەڕاستی خودای مەزن لە ئاسمان دانیشت.  
\v 4 بەم شێوەیە کوڕەکە لە فریشتەکان پایەبەرزتر بوو، بەو ئەندازەیەی ناوێکی بە میرات بۆ مایەوە زۆر لەوان شکۆدارتر. 
\p  
\v 5 ئیتر چ جارێک خودا بە کام لە فریشتەکانی فەرمووە: 
\q1 ﴿تۆ کوڕی منی، 
\q2 من ئەمڕۆ بوومە باوکت﴾\f + \fr 1:5 \ft \xt زەبوورەکان 2‏:7.‏\ft ‏\f*؟ 
\m هەروەها: 
\q1 ﴿من دەبمە باوکی ئەو و 
\q2 ئەویش دەبێتە کوڕی من﴾\f + \fr 1:5 \ft \xt دووەم ساموئێل 7‏:14 و یەکەم پوختەی مێژوو 17‏:13.‏\ft ‏\f*؟ 
\m  
\v 6 دیسان کاتێک خودا نۆبەرەکەی دەهێنێتە جیهانەوە، دەفەرموێت: 
\q1 ﴿با هەموو فریشتەی خودا کڕنۆشی بۆ ببەن.﴾\f + \fr 1:6 \ft لە وەرگێڕانی یۆنانی بۆ پەیمانی کۆن، \xt دواوتار 32‏:43‏\ft .‏\f* 
\m  
\v 7 لەبارەی فریشتەش دەفەرموێ: 
\q1 ﴿خودا وا لە فریشتەکانی دەکات وەک با بن، 
\q2 خزمەتکارەکانیشی وەک بڵێسەی ئاگر.﴾\f + \fr 1:7 \ft \xt زەبوورەکان 104‏:4.‏\ft ‏\f* 
\m  
\v 8 بەڵام لەبارەی کوڕەکەوە دەفەرموێت: 
\q1 ﴿ئەی خودایە، تەختی تۆ بۆ هەتاهەتاییە، 
\q2 داردەستی شانشینیت داردەستی دادپەروەرییە. 
\q1  
\v 9 تۆ حەزت لە ڕاستودروستی کردووە و ڕقت لە خراپە بووەوە، 
\q2 بۆیە خودا، خودای خۆت لە سەرووی هاوەڵەکانتەوە داینای، 
\q2 بە ڕۆنی شادی دەستنیشانی\f + \fr 1:9 \ft لە پەیمانی کۆن داود لەلایەن ساموئێلەوە چەورکرا کە هەڵبژاردەی خودایە، ئەم چەورکردنەش وەک نەریتێک بەردەوام بوو بۆ ڕزگاریی خودا.‏\f* کردیت.﴾\f + \fr 1:9 \ft \xt زەبوورەکان 45‏:6‏،7‏\ft ‏.‏\f* 
\m  
\v 10 هەروەها: 
\q1 ﴿تۆ یەزدان، لە سەرەتاوە بناغەی زەویت دانا، 
\q2 ئاسمانیش دەستکردی تۆیە. 
\q1  
\v 11 ئەوان لەناودەچن، بەڵام تۆ دەمێنیت، 
\q2 هەموو وەک کراس کۆن دەبن. 
\q1  
\v 12 وەک کەوا دەیپێچیتەوە، 
\q2 وەک بەرگی کۆن دەگۆڕدرێن، 
\q1 بەڵام تۆ هەروەک خۆتی، 
\q2 ساڵانی تۆ کۆتایی نایەت.﴾\f + \fr 1:12 \ft \xt زەبوورەکان 102‏:25‏-27.‏\ft ‏\f* 
\m  
\v 13 ئایا خودا چ جارێک بە کام لە فریشتەکانی فەرمووە: 
\q1 ﴿لە دەستەڕاستم دابنیشە 
\q2 هەتا دوژمنانت دەکەمە تەختەپێ\f + \fr 1:13 \ft بەهۆی ئەوەی پاشا کورسییەکەی بەرز بووە، تەختەیەک لەژێر پێی دانراوە کە وێنەی دوژمنەکانی لەسەر کێشراوە، وەک هێمایەک بۆ خستنە ژێر پێیان.‏\f* بۆ پێیەکانت﴾\f + \fr 1:13 \ft \xt زەبوورەکان 110‏:1.‏\ft ‏\f*؟ 
\m  
\v 14 ئایا هەموویان ڕۆحی خزمەتکارانە نین کە نێردراون بۆ خزمەتی ئەوانەی لە داهاتوو ڕزگاری بە میرات دەگرن؟ 
\c 2  
\s1 پشتگوێ نەخستنی ڕزگاری 
\p  
\v 1 لەبەر ئەمە دەبێ وریاتر بین لەوەی بیستمان، نەوەک لێی لابدەین،  
\v 2 چونکە ئەگەر پابەندبوون بەو پەیامەی کە لە ڕێگەی فریشتەکانەوە گوترا، کە هەموو دەستدرێژی و سەرپێچییەک سزای دادپەروەرانەی وەرگرتووە،  
\v 3 ئەوا ئێمە چۆن دەتوانین لەو سزایە هەڵبێین، کە ڕزگارییەکی ئەوەندە گەورەی وەک ئەمە پشتگوێ بخەین؟ ئەوەی یەکەم جار بەهۆی مەسیحی خاوەن شکۆوە گوترا و لەلایەن ئەوانەی بیستیان بۆمان پشتڕاست کرایەوە،  
\v 4 خوداش بە نیشانە و کاری مەزن و پەرجووی جۆراوجۆر شایەتی بۆ ئەم ڕزگارییە دا، هەروەها بەو بەهرانەی ڕۆحی پیرۆز کە بەگوێرەی خواستی خۆی دابەشی کردوون. 
\s1 عیسا وەک براکانیەتی 
\p  
\v 5 ئەو جیهانەی کە دێت و باسی دەکەین، ملکەچی فریشتەکانی نەکردووە.  
\v 6 بەڵام لە شوێنێکدا کەسێک شایەتی داوە: 
\q1 ﴿مرۆڤ چییە تاکو بیری لێ بکەیتەوە؟ 
\q2 کوڕی مرۆڤ چییە تاکو بایەخی پێبدەیت؟ 
\q1  
\v 7 بۆ ماوەیەکی کەم ئەوت لە فریشتەکانت بە کەمتر دانا و 
\q2 تاجی شکۆ و ڕێزت خستە سەری، 
\q2  
\v 8 تۆ هەموو شتێکت خستووەتە ژێر پێی ئەو.﴾\f + \fr 2:8 \ft \xt زەبوورەکان 8‏:4‏-6.‏\ft ‏\f* 
\m کاتێک خودا هەموو شتێکی ملکەچ کردووە، هیچ شتێکی نەهێشتەوە ملکەچی نەکات. هەرچەندە ئێستا نابینین هەموو شتێک ملکەچی کرابێت.  
\v 9 بەڵام عیسا دەبینین، ئەوەی بۆ ماوەیەکی کورت لە فریشتەکان کەمتر دانرا، لەبەر ئازاری مردن تاجی شکۆ و ڕێزی خراوەتە سەر، تاکو بە نیعمەتی خودا لە جیاتی هەموو کەسێک مردن بچێژێ. 
\p  
\v 10 لە خودا دەوەشایەوە، ئەوەی هەموو شتێک بۆ ئەو و بەهۆی ئەوەوەیە، کاتێک دەیویست ڕۆڵەی زۆر بهێنێتە نێو شکۆمەندییەکەی، دەبووایە عیسا کە پێشەنگی ڕزگارکردنیانە، لە ڕێگەی ئازارەوە بکاتە ڕزگارکەرێکی تەواو.  
\v 11 عیسا کە خەڵک پیرۆز دەکات و ئەو خەڵکەی پیرۆز کراون هەردووکیان سەر بە یەک خێزانن، لەبەر ئەم هۆیەش عیسا شەرم ناکات بە خوشک یان برا ناویان ببات.  
\v 12 دەفەرموێ: 
\q1 ﴿ناوی تۆ بە براکانم ڕادەگەیەنم، 
\q2 لەناو کۆمەڵدا\f + \fr 2:12 \ft یۆنانی: کڵێسا.‏\f* ستایشت دەکەم.﴾\f + \fr 2:12 \ft \xt زەبوورەکان 22‏:22.‏\ft ‏\f* 
\m  
\v 13 هەروەها: 
\q1 ﴿من پشت بەو دەبەستم.﴾\f + \fr 2:13 \ft \xt ئیشایا 8‏:17.‏\ft ‏\f* 
\m دیسان: 
\q1 ﴿ئەوەتا خۆم و ئەو منداڵانەی کە خودا پێیداوم.﴾\f + \fr 2:13 \ft \xt ئیشایا 8‏:18.‏\ft ‏\f* 
\p  
\v 14 بۆیە کە منداڵەکان لە گۆشت و خوێن بەشدارن، ئەویش بە هەمان شێوە بەشداری لە سروشتی مرۆڤایەتییان کرد، تاکو بەهۆی مردنی خۆیەوە شەیتان لەناوببات کە هێزی مردنی هەیە،  
\v 15 ئەوانەش ئازاد بکات کە بە درێژایی ژیانیان لە ترسی مردن ملکەچی کۆیلایەتی بوون.  
\v 16 بە ڕاستی ئەوە بۆ یارمەتیدانی فریشتە نییە، بەڵکو بۆ یارمەتیدانی نەوەی ئیبراهیمە.  
\v 17 لەبەر ئەوە پێویست بوو لە هەموو ڕووێکەوە لە خوشکان و برایانی بچێت تاکو ببێتە سەرۆک کاهینێکی بە بەزەیی و دڵسۆز لە خزمەتکردنی خودا، هەروەها ببێتە کەفارەت\f + \fr 2:17 \ft ئەو قوربانییەی کە تووڕەیی خودا لادەدات.‏\f* لە پێناوی گوناهەکانی خەڵک.  
\v 18 لەبەر ئەوەی خۆی ئازاری چێژتووە و تاقی کراوەتەوە، دەتوانێت یارمەتیی ئەوانەش بدات کە تاقی دەکرێنەوە. 
\c 3  
\s1 عیسا پایەبەرزترە لە موسا 
\p  
\v 1 کەواتە ئەی خوشک و برایانی پیرۆز، ئێوە کە لە بانگەوازی ئاسمانی بەشدارن، سەیری عیسا بکەن کە نێردراو و سەرۆکی کاهینانی دانپێدانانمانە.  
\v 2 ئەو دڵسۆز بوو بەرامبەر ئەو خودایەی کە دەستنیشانی کرد، هەروەک موسا لە هەموو ماڵی خودا دڵسۆز بوو.  
\v 3 عیسا بۆی دانرا شایانی شکۆیەکی زیاتر بێت لە موسا، وەک چۆن دروستکەری خانووێک ڕێزی لە خودی خانووەکە زیاترە.  
\v 4 لەبەر ئەوەی هەموو خانووێک کەسێک دروستی کردووە، بەڵام ئەوەی هەموو شتێکی دروستکردووە خودایە.  
\v 5 موسا وەک خزمەتکارێکی دڵسۆز لە هەموو ماڵی خودا بوو و شایەتی بۆ ئەو فەرمایشتانە دەدا کە لە داهاتوودا خودا دەیفەرموو.  
\v 6 بەڵام مەسیح وەک کوڕەکە لەسەر ماڵی خودا\f + \fr 3:6 \ft ماڵی خودا: مەبەست لەو پیرۆزگایەیە کە لە ئاسماندا هەیە. بڕوانە \xt زەبوورەکان 20‏:6.‏\ft ‏\f* دڵسۆزە، ئەو ماڵەش ئێمەین، ئەگەر دەستبگرین بەو متمانە و هیوایەی کە شانازی پێوە دەکەین. 
\s1 ئاگادارکردنەوە لە دژی بێباوەڕی 
\p  
\v 7 لەبەر ئەوە، وەک ڕۆحی پیرۆز دەفەرموێ: 
\q1 ﴿ئەمڕۆ، کاتێک گوێتان لە فەرمایشتی ئەو دەبێت، 
\q2  
\v 8 دڵی خۆتان ڕەق مەکەن وەک لە یاخیبوونەکە ڕوویدا، 
\q2 لە ڕۆژانی تاقیکردنەوە لە بیابان. 
\q1  
\v 9 لەوێ باوباپیرانتان ئەزموونیان کردم و تاقییان کردمەوە\f + \fr 3:9 \ft بڕوانە \xt یاقوب 1‏:13‏،14‏.‏\ft ‏\f*، 
\q2 هەرچەندە بۆ ماوەی چل ساڵ کردارەکانی منیان بینی. 
\q1  
\v 10 لەبەر ئەوە لەو نەوەیە تووڕە بووم، 
\q2 فەرمووم: «دڵیان هەر بەرەو گومڕایی دەڕوات و 
\q2 ڕێگای منیان نەناسی.» 
\q1  
\v 11 بۆیە لە تووڕەییمدا سوێندم خوارد: 
\q2 «نایەنە ناو حەسانەوەی من.»﴾\f + \fr 3:11 \ft \xt زەبوورەکان 95‏:7‏-11‏.‏\ft ‏\f* 
\p  
\v 12 خوشکان، برایان، ئاگاداری خۆتان بن، نەوەک یەکێکتان دڵێکی خراپ و بێباوەڕی هەبێت کە لە خودای زیندوو هەڵبگەڕێتەوە.  
\v 13 بەڵکو هەموو ڕۆژێک یەکتری هانبدەن، ئەوەندەی پێی دەگوترێ ﴿ئەمڕۆ،﴾\f + \fr 3:13 \ft \xt زەبوورەکان 95‏:7.‏\ft ‏\f* تاکو کەستان بە فێڵی گوناه دڵی ڕەق نەبێت.  
\v 14 بووینەتە هاوبەشی مەسیح، ئەگەر هەتا کۆتایی دەستبگرین بەو متمانەیەی لە سەرەتاوە هەمانە.  
\v 15 وەک چۆن گوتراوە: 
\q1 ﴿ئەمڕۆ، کاتێک گوێتان لە فەرمایشتی ئەو دەبێت، 
\q2 دڵی خۆتان ڕەق مەکەن وەک لە یاخیبوونەکە ڕوویدا.﴾\f + \fr 3:15 \ft \xt زەبوورەکان 95‏:7‏،8‏.‏\ft ‏\f* 
\p  
\v 16 جا کێن ئەوانەی بیستیان و یاخیبوون؟ ئایا هەموو ئەوانە نەبوون کە لە میسر بە ڕابەرایەتی موسا هاتنە دەرەوە؟  
\v 17 خودا بۆ ماوەی چل ساڵ لە کێ تووڕە بوو؟ ئایا لەوانە نەبوو کە گوناهیان کرد و لە بیاباندا تەرمەکانیان کەوت؟  
\v 18 خودا سوێندی لە کێ خوارد کە ناچێتە حەسانەوەکەی؟ ئایا لەوانە نەبوو کە یاخیبوون؟  
\v 19 هەر بۆیە دەبینین لەبەر بێباوەڕییان نەیانتوانی بچنە شوێنی حەسانەوەکەی. 
\c 4  
\s1 بەڵێنی حەسانەوەی خودایی 
\p  
\v 1 بۆیە کە بەڵێنی چوونە ناو شوێنی حەسانەوەی خودا هەر ماوە، دەبێ بترسین نەوەک یەکێکتان ئەو بەڵێنەی لەدەست بچێت.  
\v 2 هەرچەندە ئێمەش وەک ئەوان مزگێنیمان درایێ، بەڵام ئەو پەیامەی ئەوان بیستوویانە سوودی بۆیان نەبوو، چونکە ئەوانەی ئەو پەیامەیان بیست لە دڵیانەوە بە باوەڕ وەریان نەگرت.  
\v 3 ئێمەی باوەڕدار دەچینە ناو حەسانەوەی خودا، هەروەک خۆی فەرموویەتی: 
\q1 ﴿بۆیە لە تووڕەییمدا سوێندم خوارد: 
\q2 «نایەنە ناو حەسانەوەی من.»﴾\f + \fr 4:3 \ft \xt زەبوورەکان 95‏:11،‏\ft ‏ هەروەها لە ئایەتی 5.‏\f* 
\m هەرچەندە کارەکان لە دامەزراندنی جیهانەوە تەواو بوون.  
\v 4 لە شوێنێکدا دەربارەی ڕۆژی حەوتەمی هەفتە فەرموویەتی: ﴿ئیتر خودا لە ڕۆژی حەوتەم لە هەموو کارەکانی پشووی دا.﴾\f + \fr 4:4 \ft \xt پەیدابوون 2‏:2.‏\ft ‏\f* 
\v 5 دیسان لەو دەقەدا دەفەرموێت: ﴿نایەنە ناو حەسانەوەی من.﴾ 
\p  
\v 6 ئەوانەی پێشتر مزگێنییان درایێ نەیانتوانی بچنە شوێنی حەسانەوەی خودا، چونکە یاخیبوون. ئیتر شتێکی ڕوونە کە شوێنی حەسانەوەی خودا چاوەڕێی کەسانی دیکە دەکات.  
\v 7 دیسان خودا ڕۆژێکی دیاری کرد، ناوی ئەو ڕۆژەشی نا «ئەمڕۆ»، کاتێک لەدوای ماوەیەکی زۆر لە ڕێگەی داودی پێغەمبەرەوە قسەی کرد، هەروەک پێشتر باسمان کرد: 
\q1 ﴿ئەمڕۆ، کاتێک گوێتان لە فەرمایشتی ئەو دەبێت، 
\q2 دڵی خۆتان ڕەق مەکەن.﴾\f + \fr 4:7 \ft \xt زەبوورەکان 95‏:7‏،8‏\ft ‏.‏\f* 
\m  
\v 8 لەبەر ئەوەی ئەگەر یەشوع ئەوانی بحەساندبایەوە، ئەوا پاش ئەوە خودا باسی ڕۆژێکی دیکەی نەدەکرد.  
\v 9 کەواتە حەسانەوەی ڕۆژی حەوتەم بۆ گەلی خودا ماوە،  
\v 10 چونکە ئەوەی بچێتە ناو حەسانەوەی خودا لە کارەکانیشی پشوو دەدات، وەک خوداش لە کارەکانی پشووی دا.  
\v 11 بۆیە با تێبکۆشین تاکو بچینە ناو ئەو حەسانەوەیە، بۆ ئەوەی هیچ کەسێک دیسان دوای هەمان پەندی یاخیبوون نەکەوێت و لەناونەچێت. 
\p  
\v 12 چونکە پەیامی خودا زیندووە، کاریگەرە، لە هەموو شمشێرێکی دوودەم تیژترە، نێوانی دەروون و ڕۆح و جومگە و مۆخی ئێسک دەبڕێت، نیاز و بیری دڵ جیا دەکاتەوە.  
\v 13 بەدیهێنراو نییە لەبەرچاوی خودا شاردراوە بێت، بەڵکو هەموو شتێک ڕووت و ئاشکرایە لەبەرچاوی خودا کە هەر یەکێک لە ئێمە دەبێت حیسابی خۆی بخاتە بەردەستی. 
\s1 عیسا سەرۆک کاهینی پایەبەرزە 
\p  
\v 14 لەبەر ئەوەی ئەو سەرۆکی کاهینانە پایەبەرزەمان هەیە کە بە ئاسماندا تێپەڕی، عیسای کوڕی خودا، با دەستبگرین بەو باوەڕەی کە دانمان پێدا ناوە،  
\v 15 چونکە سەرۆک کاهینێکمان نییە کە نەتوانێت هاوخەمی لاوازییەکانمان بێت، بەڵکو سەرۆک کاهینێکمان هەیە کە وەکو ئێمە لە هەموو شتێک تاقی کراوەتەوە، بەڵام بێ گوناه دەرچوو.  
\v 16 بۆیە با بە متمانەوە لە تەختی نیعمەت\f + \fr 4:16 \ft نیعمەت بەخشینێکی خودایە بە مرۆڤ بەبێ شایستەبوونی پێی دەبەخشێت.\f* بچینە پێش، بۆ ئەوەی بەزەیی وەربگرین و نیعمەت بدۆزینەوە تاکو لە کاتی پێویستدا یارمەتیمان بدات. 
\c 5  
\p  
\v 1 هەر سەرۆک کاهینێک لەنێو خەڵک هەڵبژێردراوە، وەک نوێنەری خەڵک لە کاروباری خودا دەستنیشان کراوە، تاکو دیاری و قوربانییەکانی گوناه پێشکەش بکات.  
\v 2 دەتوانێ لەگەڵ نەزان و چەواشە کراوان دڵنەرم بێت، چونکە خۆشی وەک ئەوان گرفتاری لاوازییە.  
\v 3 لەبەر ئەوە پێویستە لە پێناوی گوناهەکانی خۆی قوربانی بکات، هەروەک لە پێناوی گوناهەکانی کەسانی دیکە دەیکات.  
\v 4 کەس ئەم ڕێزە بۆ خۆی وەرناگرێت، بەڵکو دەبێت خودا بانگی بکات، هەروەک چۆن خودا هارونی بانگکرد. 
\p  
\v 5 بە هەمان شێوە، مەسیح خۆی شکۆدار نەکرد تاکو ببێتە سەرۆکی کاهینان، بەڵکو خودا پێی فەرموو: 
\q1 ﴿تۆ کوڕی منی، 
\q2 من ئەمڕۆ بوومە باوکت.﴾\f + \fr 5:5 \ft \xt زەبوورەکان 2‏:7‏\ft ‏\f* 
\m  
\v 6 وەک لە شوێنێکی دیکەش دەفەرموێ: 
\q1 ﴿هەتاهەتایە تۆ کاهینیت، 
\q2 لە پلەی مەلکیسادق\f + \fr 5:6 \ft بڕوانە \xt عیبرانییەکان 7‏:1‏-10.‏\ft ‏\f*‏.﴾\f + \fr 5:6 \ft \xt زەبوورەکان 110‏:4‏\ft ‏\f* 
\p  
\v 7 عیسا لە ماوەی ژیانی لەسەر زەوی، بە هاواری توند و فرمێسکەوە نوێژ و پاڕانەوەی پێشکەش بە خودا کرد، ئەوەی توانای ڕزگارکردنیی هەبوو لە مردن، ئیتر لەبەر لەخواترسییەکەی گوێی لێ گیرا.  
\v 8 هەرچەندە عیسا کوڕی خودا بوو، بەڵام بەو ئازارانەی کە چێژتی فێری گوێڕایەڵی بوو و  
\v 9 لە ڕێی ئازارەکانیەوە بووە مرۆڤێکی پڕ و تەواو، بەم ڕێگایە بووە سەرچاوەی ڕزگاریی هەتاهەتایی بۆ هەموو ئەوانەی گوێڕایەڵی دەبن.  
\v 10 ئیتر لەلای خوداشەوە بە سەرۆکی کاهینان ناونرا، لە پلەی مەلکیسادق. 
\p  
\v 11 لەم بارەیەوە قسەمان زۆرە بیکەین، بەڵام ڕوونکردنەوەی زەحمەتە، چونکە گوێتان گران بووە.  
\v 12 هەرچەندە دەبووایە ئێوە ئێستا مامۆستا بوونایە، پێویستتان بە کەسێکە دیسان بنەما سەرەکییەکانی وشەی خوداتان فێر بکات. واتان لێ هاتووە پێویستتان بە شیر بێت نەک خۆراکی بەهێز.  
\v 13 هەر یەکێک شیرەخۆرە بێت ئەوا لە فێرکردنی ڕاستودروستی ڕانەهاتووە، چونکە ساوایە.  
\v 14 بەڵام خۆراکی بەهێز بۆ ئەوانەیە کە پێگەیشتوون، ئەوانەی کە بە بەردەوامی مەشقیان کردووە بۆ ئەوەی بتوانن چاکە و خراپە جیا بکەنەوە. 
\c 6  
\s1 پاشگەزبوونەوە لە باوەڕ 
\p  
\v 1 بۆیە کە وازمان لە فێرکردنی سەرەتایی لەبارەی مەسیح هێنا، با بەرەو پێگەیشتن بڕۆین، دیسان بناغەڕێژی ناکەین بۆ تۆبەکردن لەو کارانەی کە دەبنە هۆی مردن و باوەڕهێنان بە خودا،  
\v 2 فێرکردن دەربارەی لەئاوهەڵکێشان و دەست لەسەر دانان و هەستانەوەی مردووان و لێپرسینەوەی هەتاهەتایی.  
\v 3 ئەگەر خودا ڕێگا بدات، ئەمەش دەکەین. 
\p  
\v 4 ناکرێ ئەوانەی جارێک ڕووناک کراونەتەوە و تامی بەهرەی ئاسمانییان کردووە و بەشدار بوونە لە ڕۆحی پیرۆز،  
\v 5 هەروەها تامی باشی وشەی خودا و هێزەکانی جیهانی داهاتوویان کردووە،  
\v 6 ئەگەر هەڵگەڕانەوە\f + \fr 6:6 \ft یۆنانی: کەوتن.‏\f*، بۆ تۆبەکردن نوێ بکرێنەوە، چونکە بۆ خۆیان کوڕی خودا لە خاچ دەدەنەوە و ڕیسوای دەکەن. 
\p  
\v 7 لەبەر ئەوەی زەوی لەو بارانە دەخواتەوە کە چەندین جار دێتە سەری، ڕووەکێکی بە سوود دەدات بۆ ئەوانەی بۆیان کێڵدراوە، لە خوداشەوە بەرەکەتدار دەبێت.  
\v 8 بەڵام ئەگەر دڕک و داڵی\f + \fr 6:8 \ft بڕوانە \xt پەیدابوون 3‏:18‏\ft ‏.‏\f* بەرهەم هێنا، ئەوا پووچە و نزیکە لە نەفرەت، کۆتاییەکەشی سووتانە. 
\p  
\v 9 خۆشەویستان، هەرچەندە ئاوا قسە دەکەین، دڵنیا بووین لەبارەی ئێوەوە ڕەوشێکی باشتر هەیە کە تایبەتە بە ڕزگاری.  
\v 10 خودا زۆردار نییە کاری ئێوە لەبیر بکات، هەروەها ئەو خۆشەویستییەتان لەبیر ناکات کە بۆ خودا لە خزمەتکردنی گەلی پیرۆزی خۆی دەرتانبڕی و هەتا ئێستا بەردەوامن.  
\v 11 ئێمەش خوازیارین هەر یەکێکتان هەمان دڵگەرمی دەربخات بۆ دڵنیایی تەواوی هیوا هەتا کۆتایی،  
\v 12 بۆ ئەوەی تەمبەڵ نەبن، بەڵکو لاسایی ئەوانە بکەنەوە کە بە باوەڕ و ئارامگرتن میراتگری بەڵێنەکانن. 
\s1 خودا بەڵێنی خۆی دەباتەسەر 
\p  
\v 13 کاتێک خودا بەڵێنی بە ئیبراهیم دا، سوێندی بەخۆی خوارد، چونکە کەسی پایەبەرزتری نەبوو سوێندی پێ بخوات،  
\v 14 فەرمووی: ﴿بێگومان بەرەکەتدارت دەکەم و نەوەکەت زۆر دەکەم.﴾\f + \fr 6:14 \ft \xt پەیدابوون 22‏:17‏\ft ‏.‏\f* 
\v 15 بەم شێوەیە ئیبراهیم ئارامی گرت هەتا بەڵێنەکەی بەدەستهێنا. 
\p  
\v 16 خەڵک سوێند بە گەورەتر دەخۆن، کۆتایی هەموو دەمەقاڵەیەک بۆ چەسپاندن سوێندە.  
\v 17 خودا سوێندی خوارد، چونکە ویستی خواستی نەگۆڕی خۆی بە میراتگری بەڵێن پیشان بدات.  
\v 18 خودا ئەمەی کرد تاکو لە ڕێگەی دوو شتی نەگۆڕەوە\f + \fr 6:18 \ft بەڵێن و سوێند.‏\f* کە مەحاڵە خودا تێیاندا درۆ بکات، دەیەوێت ئێمە زۆر هانبدرێین، کە پەنامان بۆ ئەو بردووە بۆ ئەوەی دەستبگرین بەو هیوایەی کە پێمان دراوە.  
\v 19 ئەم هیوایەمان هەیە کە وەک لەنگەرە بۆ دەروونمان، چەسپاو و ڕاگرە. دەچێتە ناو شوێنی هەرەپیرۆز لە پشت پەردەکە،  
\v 20 لەوێدا عیسا پێشتر و لەبری ئێمە چووە ناوی، هەتاهەتایە بووە سەرۆکی کاهینان، لە پلەی مەلکیسادق. 
\c 7  
\s1 مەلکیسادقی کاهین 
\p  
\v 1 ئەم مەلکیسادقە پاشای شالیم بوو، هەروەها کاهینی خودای هەرەبەرز بوو، کاتێک ئیبراهیم لە بەزاندنی پاشاکان گەڕایەوە، تووشی بوو و داوای بەرەکەتی بۆ کرد،\f + \fr 7:1 \ft بڕوانە \xt پەیدابوون 14‏:17‏-20.‏\ft ‏\f* 
\v 2 ئەوەی ئیبراهیم دەیەکی هەموو شتێکی بۆ جیا کردەوە. یەکەم جار ناوی بە واتای «پاشای ڕاستودروستی» دێت، دواتر «پاشای شالیم» واتا «پاشای ئاشتی».  
\v 3 بێ دایک و باوک، بێ ڕەچەڵەکە، بێ سەرەتای ڕۆژان و کۆتایی ژیان، بەڵکو وەک کوڕی خودا وایە، هەتاهەتایە وەک کاهین دەمێنێتەوە. 
\p  
\v 4 سەرنج بدەن چەند کەسێکی گەورە بووە، تەنانەت ئیبراهیمی بابەگەورە دەیەکی دەستکەوتی داوەتێ.  
\v 5 بەڵام ئەوانەی لە نەوەی لێڤین و کاهینیێتییان وەرگرتووە، ڕاسپاردەیان هەیە کە بەگوێرەی تەورات دەیەک لە خەڵک وەربگرن، واتا لە براکانیان، هەرچەندە لە پشتی ئیبراهیمن.  
\v 6 ئەوەی لە ڕەچەڵەکی ئەوانیش نییە، دەیەکی لە ئیبراهیم وەرگرت و ئەوەی بەڵێنەکانی هەیە بەرەکەتداری کرد.  
\v 7 بێگومان بچووکترین لەلایەن گەورەترینەوە بەرەکەتدار دەکرێت.  
\v 8 لێرەش خەڵکی کە دەمرن دەیەک وەردەگرن، بەڵام لەوێ شایەتی بۆ دەدرێت کە زیندووە.  
\v 9 ئاوا قسەیەک دەکرێت: تەنانەت لێڤی\f + \fr 7:9 \ft لێڤی کوڕی یاقوب بووە سەرهۆزی کاهینەکان لەناو گەلی جولەکە.‏\f* کە دەیەک وەردەگرێ، خۆی لە ڕێگەی ئیبراهیمەوە دەیەکی داوە،  
\v 10 چونکە کاتێک مەلکیسادق تووشی ئیبراهیم بوو، هێشتا لێڤی لە پشتی باوکیدا بوو. 
\s1 عیسا وەک مەلکیسادقە 
\p  
\v 11 ئێستا ئەگەر بە ڕێگەی کاهینیێتی لێڤی تەواوەتی\f + \fr 7:11 \ft تەواوی لە پیرۆزی و ڕاستودروستی خودا.‏\f* بەدەستبهاتبایە، کە گەلیش لەسەر ئەمە تەوراتی وەرگرت، ئایا پێویستە کاهینێکی دیکە لە پلەی مەلکیسادق و نەک لە پلەی هارون دابنرێت؟  
\v 12 چونکە ئەگەر کاهینیێتی بگۆڕدرێت، ئەوا پێویستە شەریعەتیش بگۆڕدرێت.  
\v 13 ئەوەی ئەم باسەی لەسەر دەکرێ، سەر بە هۆزێکی جیاوازە، کەسیش لەم هۆزە خزمەتی قوربانگای\f + \fr 7:13 \ft مەبەست تەنها لەو قوربانگایەیە کە لە چادری پەیمان لە سەردەمی موسا و دوایی لە پەرستگای ئۆرشەلیم بوو.‏\f* نەکردووە.  
\v 14 ئاشکرایە کە مەسیحی خاوەن شکۆمان سەر بە هۆزی یەهودایە، موساش لەبارەی کاهینیێتی باسی ئەم هۆزەی نەکردووە.  
\v 15 زۆر ڕوونتریشە، ئەگەر لە شێوەی مەلکیسادق کاهینێکی دیکە دەربکەوێت،  
\v 16 کە ئەو بەپێی تەورات بە کاهین دانەنراوە کە لە ڕێگەی ڕەچەڵەکەوەیە، بەڵکو بەپێی هێزی ئەو ژیانەی کە لەناوناچێت،  
\v 17 چونکە شایەتی دەدات: 
\q1 ﴿هەتاهەتایە تۆ کاهینیت، 
\q2 لە پلەی مەلکیسادق.﴾\f + \fr 7:17 \ft \xt زەبوورەکان 110‏:4‏\ft ‏\f* 
\p  
\v 18 ئیتر ڕاسپاردەی پێشوو لابردرا، لەبەر ئەوەی لاواز و بێ سوود بوو،  
\v 19 چونکە تەورات هیچ شتێکی تەواو نەکرد، بەڵکو هیوایەکی چاکتر هاتە کایەوە کە بەهۆیەوە لە خودا نزیک دەبینەوە. 
\p  
\v 20 ئەمەش بێ سوێند نەبوو. ئەوانەی دیکە بێ سوێند بوون بە کاهین،  
\v 21 بەڵام ئەمە بە سوێندەوە بوو، لەوەی پێی فەرموو: 
\q1 ﴿یەزدان سوێندی خواردووە و 
\q2 بڕیاری ناگۆڕێت: 
\q2 «هەتاهەتایە تۆ کاهینیت.»﴾\f + \fr 7:21 \ft \xt زەبوورەکان 110‏:4‏\ft ‏\f* 
\m  
\v 22 بەگوێرەی ئەم سوێندەش عیسا بووە دەستەبەری پەیمانێکی باشتر. 
\p  
\v 23 کاهینەکان زۆربوون، چونکە مەرگ بووە کۆسپ لەوەی بەردەوام بن.  
\v 24 بەڵام لەبەر ئەوەی عیسا هەتاهەتایە دەمینێتەوە، کاهینیێتییەکی نەگۆڕی هەیە.  
\v 25 بەو هۆیەوە دەتوانێ ئەوانە بە تەواوی ڕزگار بکات کە لە ڕێگەی ئەوەوە دەچنە لای خودا، ئەو هەمیشە دەژیێت تاکو داکۆکییان لێ بکات. 
\p  
\v 26 لەڕاستیدا ئەو جۆرە سەرۆکی کاهینانە هەموو پێویستییەکانمان دابین دەکات، ئەو پیرۆز و بێ گلەیی و بێگەردە، لە گوناهباران جیا کرایەوە و لە ئاسمان بەرزتر کرا.  
\v 27 ئەو پێویستی بەوە نییە وەک سەرۆکی کاهینانی دیکە ڕۆژانە قوربانی بکات، یەکەم بۆ گوناهەکانی خۆی و دوایی بۆ گوناهەکانی گەلەکەی، چونکە یەک جار خۆی کرد بە قوربانی بۆ هەمووان.  
\v 28 تەورات کەسانێک لە پێگەی سەرۆکی کاهینان دادەنێت کە لاوازییان هەیە، بەڵام وشەی سوێند کە دوای تەوراتە، کوڕەکە\f + \fr 7:28 \ft مەسیح‏\f* دادەنێت کە بۆ هەتاهەتایە کامڵ و تەواو کراوە. 
\c 8  
\s1 سەرۆک کاهینی پەیمانی نوێ 
\p  
\v 1 گرنگترین خاڵ لەوەی گوترا ئەمەیە: ئێمە سەرۆک کاهینێکی ئاوامان هەیە کە لە ئاسماندا لە دەستەڕاستی تەختی خودای پایەبەرز دانیشت،  
\v 2 خزمەتکاری پیرۆزگا\f + \fr 8:2 \ft شوێنە پیرۆزەکانی ئاسمان.‏\f* و چادری پەرستنی ڕاستەقینەیە، ئەوەی پەروەردگار دایناوە نەک مرۆڤ. 
\p  
\v 3 لەبەر ئەوەی هەر سەرۆک کاهینێک بۆ پێشکەشکردنی بەخشین و قوربانی دانراوە، هەر بۆیە پێویست بوو ئەویش شتێکی هەبێت کە پێشکەشی بکات.  
\v 4 ئەگەر لەسەر زەوی بووایە، نەدەبووە کاهین، چونکە کەسانێکی هەیە بەگوێرەی تەورات قوربانی بکات.  
\v 5 ئەوانەی خزمەتی وێنە و سێبەری شتە ئاسمانییەکان دەکەن، کە موساش بەتەمابوو چادری پەرستن دروستبکات، ئاگادار کرایەوە: ﴿بڕوانە کە هەموو شتێک لەسەر ئەو نموونەیە دروستبکەی کە لەسەر کێوەکە پیشانت دراوە.﴾\f + \fr 8:5 \ft \xt دەرچوون 25‏:40.‏\ft ‏\f* 
\v 6 بەڵام لەڕاستیدا ئەو خزمەتەی کە عیسا وەریگرت لە خزمەتی ئەوان زۆر نایابترە، بەو ئاستەی کە خۆی پەیوەندی ڕێکخەرە بۆ پەیمانێکی باشتر، چونکە پەیمانە نوێیەکەی لەسەر بەڵێنی باشتر بنیاد نراوە. 
\p  
\v 7 لەبەر ئەوەی ئەگەر پەیمانی یەکەم بێ کەموکوڕی بووایە، ئیتر شوێن بۆ دووەم داوا نەدەکرا.  
\v 8 بەڵام خودا کەموکوڕی لە گەلەکەی دۆزییەوە، بۆیە پێیان دەفەرموێ: 
\q1 ﴿یەزدان دەفەرموێ: ئەوەتا سەردەمێک دێت، 
\q2 پەیمانێکی نوێ لەگەڵ بنەماڵەی ئیسرائیل و بنەماڵەی یەهودا دەبەستم. 
\q1  
\v 9 وەک ئەو پەیمانە نابێت کە لەگەڵ باوباپیرانیاندا بەستم 
\q2 ئەو ڕۆژەی دەستی ئەوانم گرت بۆ ئەوەی لە خاکی میسر دەریانبهێنم، 
\q1 چونکە لەسەر پەیمانەکەم نەڕۆیشتن، 
\q2 ئیتر منیش پشتگوێم خستن، 
\q4 ئەوە فەرمایشتی یەزدانە. 
\q1  
\v 10 یەزدان دەفەرموێت: ئەمە ئەو پەیمانەیە کە لەدوای ئەو ڕۆژانە لەگەڵ بنەماڵەی ئیسرائیلدا دەیبەستم، 
\q1 فێرکردنەکانم دەخەمە ناو مێشکیان و 
\q2 لەسەر دڵیان دەینووسم، 
\q1 من دەبم بە خودای ئەوان و 
\q2 ئەوانیش دەبن بە گەلی من. 
\q1  
\v 11 لەمەودوا کەس هاوڕێکەی خۆی یان 
\q2 براکەی خۆی فێرناکات و بڵێت، «یەزدان بناسە،» 
\q1 چونکە هەموویان دەمناسن، 
\q2 لە بچووکیانەوە هەتا گەورەیان، 
\q1  
\v 12 چونکە لە تاوانەکانیان خۆشدەبم، چیتر 
\q2 گوناهەکانیان بەبیری خۆم ناهێنمەوە.﴾\f + \fr 8:12 \ft \xt یەرمیا 31‏:31‏-34‏\ft ‏\f* 
\p  
\v 13 کاتێک باسی ئەم پەیمانە دەکات و دەفەرموێ: «نوێ»، پەیمانی یەکەم کۆن دەکات. شتێکیش کە کۆن و پیر بوو، ئەوا لە نەمان نزیکە. 
\c 9  
\s1 شێوازی پەرستن لە پەیمانی کۆن 
\p  
\v 1 ڕاستە کە پەیمانەکەی یەکەم ڕێوڕەسمی خزمەت و پیرۆزگای زەمینییە.  
\v 2 چادری پەرستن هەڵدرا، لە ژووری یەکەم چرادان و مێز و نانی تەرخانکراوی تێدابوو کە پێی دەگوترا شوێنی پیرۆز.  
\v 3 پشتی پەردەی دووەم، ژوورێک هەبوو پێی دەگوترا شوێنی هەرەپیرۆز،  
\v 4 بخووردانێکی زێڕین و سندوقی پەیمانی تێدابوو کە لە هەموو لایەکانی بە زێڕ ڕووپۆش کرابوو. لەناو ئەمەش گۆزەیەکی زێڕین هەبوو مەنی\f + \fr 9:4 \ft گەلی خودا کاتێک لە بیابان بوون، خودا مەن و سوێسکەی بۆ ناردن هەتا بیخۆن، گۆزەیەک لەو مەنەیان هەڵگرتبوو بۆ یادکردنەوەی ئەو ڕۆژانە. بڕوانە دەرچوون 16.‏\f* تێدابوو، لەگەڵ گۆچانەکەی هارون کە گەڵای سەوزی کردبوو، هەروەها دوو تەختە بەردەکەی پەیمان.  
\v 5 لەسەریشی کەڕوبەکانی\f + \fr 9:5 \ft جووتێک پەیکەری بوونەوەرێکی ئاسمانی باڵدارە لە شێوەی ئاژەڵ و مرۆڤ بۆ پارێزگاریکردن لە سندوقی پەیمان دانرابوو، بڕوانە \xt دەرچوون 25‏:18‏\ft ‏.‏\f* شکۆ سێبەریان کردبووە سەر قەپاغی کەفارەت\f + \fr 9:5 \ft بە واتای شوێنی لێخۆشبوونی گوناه. قەپاغێکە بۆ داپۆشینی سندوقی پەیمان، لە ڕۆژی کەفارەت خوێنی قوربانی لەسەر ڕژاوە بۆ لێخوشبوونی گوناه. بڕوانە \xt دەرچوون 25‏:17‏\ft ‏.‏\f*. لێرەدا بە وردی ناتوانین باسی ئەمانە بکەین. 
\p  
\v 6 کاتێک شتەکان ئاوا ڕێکخرابوون، کاهینان هەموو کاتێک دەچوونە ژووری یەکەم بۆ جێبەجێکردنی خزمەت.  
\v 7 بەڵام بۆ ژووری دووەم تەنها سەرۆکی کاهینان ساڵی جارێک دەچوو، ئەویش بێ خوێن نەدەبوو. خوێنەکەی لە پێناوی خۆی و گوناهەکانی گەل پێشکەش دەکرد کە بە نەزانی کردوویانە.  
\v 8 بەمەش ڕۆحی پیرۆز ئاماژەی دەکرد کە هەتا چادری پەرستن لەسەر زەوی بێت، ڕێگای شوێنی هەرەپیرۆز لە ئاسمان ئاشکرا ناکرێت.  
\v 9 ئەوەش هێما بوو بۆ ئەم سەردەمە، کە تێیدا دیاری و قوربانی پێشکەش دەکرێت، ناتوانێت ئاسوودەیی بە ویژدانی ئەوانە ببەخشێت کە خودا دەپەرستن.  
\v 10 ئەوانە تەنها ڕێوڕەسمی ڕواڵەتین کە چڕدەبێتەوە لەسەر خواردن و خواردنەوە و شێوازەکانی شوشتن، هەتا کاتی داڕشتنەوەی نوێ. 
\s1 خوێنی مەسیح 
\p  
\v 11 بەڵام کاتێک مەسیح وەک سەرۆکی کاهینان هات بۆ ئەو شتە باشانەی ئێستا هەن، چووە ناو ئەو چادرەی کە گەورەتر و تەواوترە و هەروەها دەستکرد نییە، واتا هی بەدیهێنراو نییە.  
\v 12 بە خوێنی بزن و گوێرەکە نەچوو، بەڵکو بە خوێنی خۆی یەک جار چووە ناو شوێنی هەرەپیرۆز و کڕینەوەی هەتاهەتایی دەستکەوت،  
\v 13 چونکە ئەگەر خوێنی بزن و گا و خۆڵەمێشی گوێرەکە کە بەسەر گڵاوەکاندا دەپرژێنرێت،\f + \fr 9:13 \ft بڕوانە \xt دەرچوون 24‏:6‏\ft ‏.‏\f* پیرۆز بکات بۆ پاککردنەوەی جەستە،  
\v 14 ئیتر خوێنی مەسیح چەند زیاترە، ئەوەی بە ڕۆحی پیرۆزی هەتاهەتایی بێ کەموکوڕی خۆی پێشکەشی خودا کرد، ئەوەی ویژدانمان لەو کارانە پاک دەکاتەوە کە دەبنە هۆی مردن، تاکو خزمەتی خودای زیندوو بکەین. 
\p  
\v 15 لەبەر ئەمە مەسیح ڕێکخەری پەیمانی نوێیە، تاکو بانگکراوان بەڵێنی میراتی هەتاهەتایی وەربگرن، چونکە مردنەکە بەهای خوێنە بۆ ئازادکردن لەو گوناهانەی کە لە پەیمانی یەکەمدا کردوویانە. 
\p  
\v 16 ئەگەر وەسیەتنامە\f + \fr 9:16 \ft یۆنانی: هەمان وشەی پەیمان.‏\f* هەبێ، پێویستە مردنی وەسیەتکار بسەلمێنرێ،  
\v 17 چونکە وەسیەتنامە کاتێک کاری پێ دەکرێ کە خاوەنەکەی مردبێت، بەڵام ئەگەر زیندوو بێت هیچ کاری پێ ناکرێت.  
\v 18 بۆیە پەیمانەکەی یەکەمیش بێ خوێن بەجێنەگەیەنرا،  
\v 19 چونکە موسا، دوای ئەوەی هەموو ڕاسپاردەکانی بەگوێرەی تەورات بە هەموو گەل ڕاگەیاند، خوێنی گوێرەکەی هێنا لەگەڵ ئاو و خوریی سوور و زوفا، بەسەر تەورات و هەموو گەلدا پرژاندی.  
\v 20 فەرمووی: ﴿ئەمە خوێنی ئەو پەیمانەیە کە خودا فەرمانی پێ کردن.﴾\f + \fr 9:20 \ft \xt دەرچوون 24‏:8‏\ft ‏\f* 
\v 21 هەروەها خوێنەکەی پرژاندە سەر چادری پەرستن و هەموو کەلوپەلەکانی خزمەتکردن.  
\v 22 بەگوێرەی تەورات نزیکەی هەموو شتێک بە خوێن پاک دەبێتەوە، لێخۆشبوونی گوناهیش بێ خوێنڕشتن نابێت. 
\s1 مەسیح گەورەترین قوربانییە 
\p  
\v 23 پاککردنەوەی وێنەی شتە ئاسمانییەکان دەبووایە ئاوا بکرێت، بەڵام خودی شتە ئاسمانییەکان بە قوربانی باشتر لەمانە پاک دەبنەوە،  
\v 24 چونکە مەسیح نەچووە پیرۆزگای دەستکرد کە لەبەرگیراوەی شتە ڕاستەقینەکەیە، بەڵکو خودی ئاسمان، ئێستاش لەوێ لەبەردەم خودا بۆ ئێمە دەردەکەوێت.  
\v 25 هەروەها بۆ ئەوە نەچووە ئاسمان کە چەند جارێک خۆی پێشکەش بکات، وەک سەرۆکی کاهینان ساڵی جارێک بە خوێنێک کە هی خۆی نییە دەچێتە شوێنی هەرەپیرۆز.  
\v 26 ئەگینا دەبووایە مەسیح لە دامەزراندنی جیهانەوە چەندین جار ئازاری بچێژتبووایە. بەڵام ئێستا لە کۆتایی زەمان تەنها جارێک دەرکەوت تاکو گوناه بسڕێتەوە، بەوەی خۆی کردە قوربانی.  
\v 27 وەک بۆ مرۆڤ دانراوە جارێک بمرێت، دواتر لێپرسینەوەیە،  
\v 28 ‏مەسیحیش، جارێک خۆی کرد بە‏ قوربانی تاکو گوناهی خەڵکێکی زۆر لاببات. بەڵام هاتنەوەی عیسا بۆ جاری دووەم بۆ لابردنی گوناه نییە، بەڵکو بۆ ڕزگارکردنی ئەوانەیە کە بە پەرۆشەوە چاوەڕێی دەکەن. 
\c 10  
\s1 قوربانی مەسیح جارێک و بۆ هەمووان 
\p  
\v 1 تەورات تەنها سێبەری شتە باشەکانی داهاتووە، نەک وێنەی تەواوی ڕاستییەکان. لەبەر ئەوە بەردەوام بە هەمان قوربانییەکانی ساڵ لەدوای ساڵ پێشکەش دەکرێتەوە، هەرگیز ناتوانێ ئەوانە کامڵ و تەواو بکات کە بۆ پەرستن نزیک دەبنەوە.  
\v 2 ئەگینا، ئایا لە پێشکەشکردن نەدەوەستان؟ لەبەر ئەوەی ئەگەر خواپەرستان تەنها جارێک پاک بوونەتەوە، بۆیە چیتر لە ویژدانیاندا هەست بە گوناه ناکەن.  
\v 3 بەڵام لەو قوربانییانەدا ساڵانە یادەوەری گوناه دەکرێتەوە،  
\v 4 چونکە مەحاڵە خوێنی گا و بزن گوناه لاببات. 
\p  
\v 5 لەبەر ئەوە کاتێک مەسیح هاتە ناو جیهان فەرمووی: 
\q1 ﴿بە قوربانی و پێشکەشکراو ڕازی نەبوویت، 
\q2 بەڵکو جەستەیەکت بۆ دابین کردم. 
\q1  
\v 6 بە قوربانی سووتاندن و قوربانی گوناه دڵخۆش نەبووی. 
\q1  
\v 7 ئینجا گوتم: «ئەوەتا هاتم، هەروەک لە تۆمارەکەدا لەسەرم نووسراوە، 
\q2 تاکو خواستی تۆ بەجێبهێنم، ئەی خودا.»﴾\f + \fr 10:7 \ft \xt زەبوورەکان 40‏:6‏-8.‏\ft ‏\f* 
\m  
\v 8 لە سەرەوە فەرمووی: ﴿تۆ قوربانی و پێشکەشکراو و قوربانی سووتاندن و قوربانی گوناهت نەویست و پێی دڵخۆش نەبووی،﴾ ئەوەی بەگوێرەی تەورات دەکرێت،  
\v 9 ئینجا مەسیح فەرمووی: ﴿ئەوەتا هاتم تاکو خواستی تۆ بەجێبهێنم.﴾ یەکەم لادەبات، تاکو دووەم دابنێ\f + \fr 10:9 \ft مەبەست لە پەیمانەکانی یەکەم و دووەمە، بڕوانە \xt 9‏:1‏\ft .‏\f*.  
\v 10 بەم خواستەی خودا بە یەک جار بەهۆی پێشکەشکردنی جەستەی عیسای مەسیحەوە پیرۆز بووین. 
\p  
\v 11 هەر کاهینێک هەموو ڕۆژێک ڕادەوەستێت و خزمەت دەکات بەردەوام هەمان قوربانی دەکاتەوە، کە هەرگیز ناتوانێت گوناه لاببات.  
\v 12 بەڵام کاتێک مەسیحی کاهین لە جیاتی گوناه یەک قوربانی بۆ هەموو کاتێک پێشکەش کرد، لە دەستەڕاستی خوداوە دانیشت،  
\v 13 لەو کاتەوە چاوەڕوانە، تاکو خودا هەموو دوژمنانی بکاتە تەختەپێی،  
\v 14 چونکە ئەو بە یەک قوربانی بۆ هەمیشە ئەوانەی تەواو کرد کە ئەو پیرۆزیان دەکات. 
\p  
\v 15 ڕۆحی پیرۆزیش شایەتیمان بۆ دەدات، چونکە دوای ئەوەی فەرمووی: 
\q1  
\v 16 ﴿یەزدان دەفەرموێ، ئەمە ئەو پەیمانەیە کە 
\q2 لەدوای ئەو ڕۆژانە لەگەڵیان دەیبەستم، 
\q1 «فێرکردنەکانم\f + \fr 10:16 \ft تەورات.‏\f* دەخەمە ناو دڵیان و 
\q2 لەناو مێشکیان دەینووسم.»﴾\f + \fr 10:16 \ft \xt یەرمیا 31‏:33.‏\ft ‏\f* 
\m  
\v 17 پاشان دەفەرموێت: 
\q1 ﴿لەمەودوا گوناه و تاوانەکانیان بەبیری خۆم ناهێنمەوە.﴾\f + \fr 10:17 \ft \xt یەرمیا 31‏:34.‏\ft ‏\f* 
\m  
\v 18 لەکوێ لێخۆشبوونی ئەم گوناهانە هەبێت، ئیتر پێویست ناکات قوربانی بۆ گوناه بکرێت. 
\s1 بانگەوازێک بۆ خۆڕاگریی لە باوەڕ 
\p  
\v 19 بۆیە ئەی خوشک و برایانی باوەڕدار، لەبەر ئەوەی متمانەمان هەیە بۆ چوونە ناو شوێنی هەرەپیرۆز بەهۆی خوێنی عیساوە،  
\v 20 بەو ڕێگا زیندوو و تازەیەی کە بەهۆی بەخشینی جەستەی خۆی بەناو پەردەدا بۆی کردینەوە،  
\v 21 لەبەر ئەوەی کاهینێکی بەرزمان هەیە سەرپەرشتی ماڵی خودا\f + \fr 10:21 \ft ماڵی خودا: مەبەست لەو پیرۆزگایەیە کە لە ئاسماندا هەیە. بڕوانە \xt زەبوورەکان 20‏:6.‏\ft ‏\f* دەکات،  
\v 22 هەروەها لەبەر ئەوەی خوێنی مەسیح بەسەر دڵماندا پرژێنرا\f + \fr 10:22 \ft مەبەست لە خوێنی مەسیحە بۆ لێخۆشبوونی گوناه، بڕوانە \xt دەرچوون 24‏:8‏\ft ‏.‏\f* تاکو لە ویژدانی خراپ پاکمان بکاتەوە، جەستەشمان بە ئاوێکی پاک شوشتراوە، با بە دڵێکی ڕاست و بە متمانەی تەواوی باوەڕ بچینە بەردەم خودا.  
\v 23 با بێ ڕاڕایی دەستبگرین بە دانپێدانانی هیوامان، چونکە ئەوەی بەڵێنی پێمان داوە جێی متمانەیە.  
\v 24 هەروەها با ئاگاداری یەکتری بین بۆ هاندان لەسەر خۆشەویستی و کاری چاک.  
\v 25 با واز لە کۆبوونەوەکانمان نەهێنین، وەک هەندێک لەسەری ڕاهاتوون، بەڵکو یەکتری هانبدەین، بە تایبەتی کە دەبینن ڕۆژی هاتنەوەی مەسیح نزیک دەبێتەوە. 
\p  
\v 26 ئەگەر لەدوای ئەوەی کە ڕاستیمان ناسی، بەردەوام بین لەوەی بە ئەنقەست گوناه بکەین، ئەوا هیچ قوربانییەک نییە بۆ ئەوەی گوناهەکانمان پاک بکاتەوە،  
\v 27 بەڵکو تەنها چاوەڕێکردنی حوکمدانی ترسناک و ئاگری بڵێسەدار کە خەریکە دوژمنەکانی خودا دەخوات.  
\v 28 ئەوەی سەرپێچی تەوراتی موسای دەکرد، بێ بەزەییانە بە شایەتی دوو یان سێ شایەت حوکمی مردنی بەسەردا دەدرا.  
\v 29 بە ڕای ئێوە شایانی سزای چەند خراپترە ئەوەی سووکایەتی بە کوڕی خودا کردووە و خوێنی پەیمان بە پیس دادەنێت کە پیرۆزی کردووە، سووکایەتیش بە ڕۆحی پیرۆز دەکات کە نیعمەتی لێ وەرگرتووە؟  
\v 30 لەبەر ئەوەی ئەو خودایە دەناسین کە ئەمەی فەرمووە: ﴿تۆڵەسەندنەوە هی منە، منم سزا دەدەم.﴾\f + \fr 10:30 \ft \xt دواوتار 32‏:35‏\ft .‏\f* هەروەها: ﴿یەزدان حوکم بەسەر گەلی خۆیدا دەدات.﴾\f + \fr 10:30 \ft دواوتار 32‏:36، \xt زەبوورەکان 135‏:14‏\ft ‏\f* 
\v 31 کەوتنە ناو دەستی خودای زیندوو ترسناکە. 
\p  
\v 32 ڕۆژانی ڕابردووتان بە یاد بێتەوە کە ڕووناک کرانەوە و بەرگەی ململانێیەکی سەختی پڕ لە ئازارتان گرت.  
\v 33 هەندێک جار تووشی جنێو و چەوسانەوەی ئاشکرا هاتوون، هەندێک جار بەشداری ناخۆشی ئەوانەتان کردووە کە بە هەمان شێوەی ئێوە هەڵسوکەوتیان لەگەڵ کراوە.  
\v 34 هاوسۆزی بەندکراوانتان کرد، کاتێک سامانتان تاڵان کرا بە خۆشییەوە قبوڵتان کرد، چونکە دەزانن لە ئاسماندا سامانی باشترتان هەیە و دەمێنێتەوە. 
\p  
\v 35 کەواتە متمانەتان فڕێمەدەن کە پاداشتی گەورەی هەیە،  
\v 36 چونکە پێویستیتان بە دانبەخۆداگرتن هەیە، تاکو لەدوای ئەوەی بە خواستی خوداتان کرد، بەڵێنەکە بەدەستبهێنن،  
\v 37 چونکە دوای ماوەیەکی زۆر کورت، 
\q1 ﴿ئەوەی دێت، بێگومان دێت و دواناکەوێت. 
\q2  
\v 38 ئەوەی ڕاستودروستە و هی خۆمە بە باوەڕ دەژیێت، 
\q1 هەروەها ئەگەر هەڵگەڕایەوە، 
\q2 ئەوە جێی ڕەزامەندی من نابێت.﴾\f + \fr 10:38 \ft حەبەقوق 2‏:3، 4‏\f* 
\m  
\v 39 جا ئێمە سەر بەوانە نین کە هەڵدەگەڕێنەوە و لەناودەچن، بەڵکو سەر بە ئەوانەین کە باوەڕیان هەیە و ڕزگار دەکرێن. 
\c 11  
\s1 باوەڕی باپیرانمان 
\p  
\v 1 باوەڕ دڵنیاییە بەوەی هیوامان پێیەتی، بێگومانییە لەوەی نایبینین،  
\v 2 چونکە بەم باوەڕە پێشینان پەسەند کراون. 
\p  
\v 3 بە باوەڕ تێدەگەین کە گەردوون بە فەرمایشتی خودا بەدیهێنراوە، تەنانەت ئەوەی دەیبینین لەو شتانەی کە بینراوە نەهاتووەتە کایەوە. 
\p  
\v 4 بە باوەڕ هابیل قوربانییەکی باشتری لەوەی قایین پێشکەشی خودا کرد\f + \fr 11:4 \ft بڕوانە \xt پەیدابوون 4‏:4‏\ft ‏.‏\f*. بە باوەڕ شایەتی بۆ درا کە ڕاستودروستە کاتێک خودا شایەتی بۆ قوربانییەکەی دا. هەرچەندە هابیل مرد بەڵام هێشتا بە باوەڕ قسە دەکات. 
\p  
\v 5 بە باوەڕ حەنۆخ بەرزکرایەوە لای خودا تاکو مردن نەبینێ، ئیتر لەسەر زەوی نەما، چونکە خودا بردی بۆ لای خۆی\f + \fr 11:5 \ft بڕوانە \xt پەیدابوون 5‏:21‏-24.‏\ft ‏\f*. پێش بردنیشی شایەتی وەرگرت کە خودای ڕازی کردووە.  
\v 6 بەبێ باوەڕ مەحاڵە ڕەزامەندی خودا بەدەستبهێنرێت، چونکە ئەوەی لەو نزیک بێتەوە، دەبێ باوەڕی بە بوونی ئەو هەبێت و پاداشتی ئەوانەش دەداتەوە کە بە پەرۆشەوە ڕوویان لەو دەکەن. 
\p  
\v 7 بە باوەڕ نوح کاتێک لەلایەن خوداوە سەبارەت بەوەی کە هێشتا نەبینرابوو ئاگادار کرایەوە، ترسی خودای کەوتە دڵ و کەشتییەکی بنیاد نا بۆ ڕزگارکردنی خاووخێزانەکەی.\f + \fr 11:7 \ft بڕوانە \xt پەیدابوون 6‏:13‏-22.‏\ft ‏\f* بەم شێوەیە، بە باوەڕ جیهانی حوکم دا و بوو بە میراتگری ئەو ڕاستودروستییەی کە بەگوێرەی باوەڕ بوو. 
\p  
\v 8 بە باوەڕ کاتێک ئیبراهیم\f + \fr 11:8 \ft بڕوانە پەیدابوون 12‏–22.‏\f* بانگکرا بچێتە ئەو شوێنەی خەریک بوو بە میرات وەریبگرێت، گوێڕایەڵ بوو و ڕۆیشت، هەرچەندە نەیدەزانی بۆ کوێ دەچێت.  
\v 9 بە باوەڕ وەک بێگانە لە خاکی بەڵێندراو نامۆ بوو، لە چادردا ژیا، وەک ئیسحاق و یاقوب کە ئەوانیش میراتگری هەمان بەڵێن بوون،  
\v 10 چونکە ئیبراهیم چاوەڕێی ئەو شارەی دەکرد کە بناغەیەکی چەسپاوی هەیە، ئەوەی خودا ئەندازیار و دروستکەرەکەیەتی. 
\p  
\v 11 بە باوەڕ سارا توانای سکوزای پێدرا، هەرچەندە نەزۆک بوو و تەمەنی سکوزاشی بەسەرچوو بوو، چونکە دڵنیا بوو ئەوەی بەڵێنی داوە دڵسۆزە.  
\v 12 بۆیە لە پیاوێک کە هەر وەک مردوو وابوو، نەوەیەک دروست بوو کە وەک ئەستێرەی ئاسمان و لمی سەر کەناری دەریا لە ژمارە نەدەهات\f + \fr 11:12 \ft بڕوانە \xt پەیدابوون 22‏:17‏\ft ‏\f*. 
\p  
\v 13 هەموو ئەوانە لە باوەڕدا مردن و بەڵێنەکانیان وەرنەگرت، بەڵکو لە دوورەوە بینییان و پێشوازییان لێکرد، دانیان پێدا نا کە ئەوان لەسەر زەویدا نامۆ و بێگانەن.  
\v 14 ئەوانەی ئەو شتانە دەڵێن، دەریدەخەن کە داوای نیشتیمان دەکەن.  
\v 15 ئەگەر ئەوان بیریان لەو نیشتیمانە بکردایەوە کە بەجێیان هێشتبوو، ئەوا هەلی گەڕانەوەیان بۆی دەبوو.  
\v 16 بەڵام ئێستا ئارەزووی نیشتیمانێکی باشتر دەکەن، کە ئاسمانییەکەیە. بۆیە خودا شەرمی پێیان نییە بە خودای ئەوان ناوببردرێت، چونکە شارێکی بۆ ئامادەکردن. 
\p  
\v 17 بە باوەڕ ئیبراهیم ئیسحاقی کوڕی وەک قوربانی پێشکەش کرد، کاتێک خودا ئیبراهیمی تاقی کردەوە. ئەوەی بە بەڵێن لە خودا وەریگرت ئامادە بوو کوڕە تاقانەکەی بکاتە قوربانی،  
\v 18 هەرچەندە خودا سەبارەت بەو فەرمووبووی: ﴿لە ڕێگەی ئیسحاقەوە نەوەی تۆ ناودەبردرێت.﴾\f + \fr 11:18 \ft \xt پەیدابوون 21‏:12‏\ft ‏\f* 
\v 19 ئیبراهیم دڵنیابوو لەوەی کە خودا دەتوانێت ئیسحاق لەدوای مردنی زیندوو بکاتەوە. بە واتایەکی دیکە، خودا ئەوی بە شێوەیەکی نموونەیی لەنێو مردووان هەستاندەوە. 
\p  
\v 20 بە باوەڕ ئیسحاق\f + \fr 11:20 \ft بڕوانە \xt پەیدابوون 27‏:27‏-39.‏\ft ‏\f* داوای بەرەکەتی خودای بۆ داهاتووی یاقوب و عیسۆ کرد. 
\p  
\v 21 بە باوەڕ یاقوب لە سەرەمەرگیدا داوای بەرەکەتی بۆ هەریەکە لە کوڕەکانی یوسف کرد و خۆی بەسەر دەسکی گۆچانەکەیدا دا و ستایشی خودای کرد\f + \fr 11:21 \ft بڕوانە پەیدابوون 48‏\f*. 
\p  
\v 22 بە باوەڕ یوسف لە سەرەمەرگیدا باسی چوونەدەرەوەی نەوەی ئیسرائیلی لە میسر کرد و لەبارەی گواستنەوەی ڕوفاتەکەی وەسیەتی بۆ کردن\f + \fr 11:22 \ft یوسف وەسیەتی کرد لەدوای مردنی تەرمەکەی بهێننەوە خاکی بەڵێندراو، بڕوانە \xt پەیدابوون 50‏:24‏،25‏\ft ‏.‏\f*. 
\p  
\v 23 بە باوەڕ کاتێک موسا\f + \fr 11:23 \ft بڕوانە دەرچوون 2‏–14.‏\f* لەدایک بوو، سێ مانگ دایک و باوکی شاردییانەوە، چونکە بینییان منداڵەکە جوانە، لە فەرمانی پاشا نەترسان. 
\p  
\v 24 بە باوەڕ کاتێک موسا گەورە بوو، نەیویست بە کچەزای فیرعەون بناسرێت.  
\v 25 بەلایەوە باشتر بوو لەگەڵ گەلی خودا سووکایەتیی پێ بکرێت، لەوەی لەزەتێکی کاتیی لە گوناهدا هەبێت.  
\v 26 موسا ئەو ڕیسواییەی لە پێناوی مەسیحدا چێژتی بە سامانێکی گەورەتری دانا لە گەنجینەی میسر، چونکە چاوی لەوە بوو کە خودا پاداشتی بداتەوە.  
\v 27 بە باوەڕ میسری بەجێهێشت و لە تووڕەیی پاشا نەترسا. دانی بەخۆیدا گرت چونکە ئەوەی بینی کە نەبینراوە.  
\v 28 بە باوەڕ پەسخەی کرد و خوێنەکەی پرژاند، نەوەک لەناوبەری نۆبەرە\f + \fr 11:28 \ft بڕوانە \xt دەرچوون 12‏:12‏،13‏\ft ‏.‏\f* دەستیان لێ بدات. 
\p  
\v 29 بە باوەڕ بە دەریای سووردا پەڕینەوە وەک بە وشکانیدا بڕۆن، بەڵام کاتێک میسرییەکان ویستیان بپەڕنەوە نوقوم بوون. 
\p  
\v 30 بە باوەڕ شووراکانی ئەریحا ڕووخان\f + \fr 11:30 \ft بڕوانە یەشوع بەشی 6.‏\f*، دوای ئەوەی حەوت ڕۆژ بە دەوریدا سووڕانەوە. 
\p  
\v 31 بە باوەڕ ڕاحابی لەشفرۆش لەگەڵ یاخیبووان لەناونەچوو، چونکە پێشوازییەکی ئاشتییانەی لە سیخوڕەکان کرد. 
\p  
\v 32 چی دیکەش بڵێم؟ کاتم نییە باسی گدعۆن و باراک و شەمشون و یەفتاح و داود و ساموئێل و پێغەمبەران بکەم،  
\v 33 کە بە باوەڕ پاشایەتییەکانیان بەزاند، دادپەروەرییان هێنایە کایەوە، بەڵێنەکانیان بۆ هاتە دی، دەمی شێریان داخست،  
\v 34 هێزی ئاگریان کوژاندەوە، لە تیخی شمشێر دەرباز بوون، لە لاوازیدا بەهێزبوون، لە شەڕدا توند بوون، لەشکری بێگانەیان گەڕاندەوە.  
\v 35 هەندێک ژن مردووەکانیان بە هەستانەوە وەرگرتەوە. بەڵام خەڵکی دیکە ئەشکەنجە دران و ڕزگارییان نەویست، تاکو هەستانەوەیەکی باشتریان دەستبکەوێت.  
\v 36 هەندێکی دیکە ڕووبەڕووی سووکایەتی و قامچی و کۆت و زیندان بوونەوە.  
\v 37 بەردباران کران، بە مشار لەت لەت کران، بە شمشێر کوژران. هەندێکیش بە پێستی مەڕ و بزن خۆیان داپۆشی، تووشی نەبوونی و چەوسانەوە و زەلیلی بوون.  
\v 38 جیهان شایانی ئەمان نەبوو. دەربەدەری بیابان و شاخ و ئەشکەوت و کون و کەلەبەری زەوی بوون. 
\p  
\v 39 هەموو ئەمانەش بەهۆی باوەڕیانەوە شایەتییان بۆ درا، بەڵام بەڵێنی خودایان دەست نەکەوت،  
\v 40 چونکە خودا پێشتر شتێکی باشتری بۆمان بینی، تاکو بێ ئێمە تەواو نەبن. 
\c 12  
\s1 تەمبێکردن لە خودای باوکەوە 
\p  
\v 1 کەواتە لەبەر ئەوەی ئێمە بە هەورێکی شایەتیدەری ئاوا گەورە دەورە دراوین، با هەموو بارگرانییەک و ئەو گوناهانەی کە بە ئاسانی لێمان دەئاڵێت لە خۆمانی دوور بخەینەوە و بە دانبەخۆداگرتنەوە لەو پێشبڕکێیە ڕابکەین کە لەپێشمان دانراوە.  
\v 2 با سەرنجمان بخەینە سەر عیسا، پێشڕەو و تەواوکاری باوەڕمان، ئەوەی لە پێناوی ئەو خۆشییەی لەپێشی دانرابوو، بەرگەی خاچی گرت و شەرمەزاری بە سووک وەرگرت، جا لە دەستەڕاستی تەختی خودا دانیشت.  
\v 3 با بیر بکەنەوە لەوەی کە دانی بەخۆیدا گرت بەرامبەر ئەو دژایەتییەی کە گوناهباران لەگەڵیان کرد، تاکو شەکەت نەبن و ورە بەرنەدەن. 
\p  
\v 4 لە خەباتی ئێوە لە دژی گوناه هەتا ئاستی خوێنڕشتن بەرگریتان نەکردووە.  
\v 5 ئایا ئێوە بە تەواوی ئەو پەیامەی هاندانتان لەبیر چووەوە کە وەک ڕۆڵە لەگەڵتان دەدوێت؟ پەیامەکە دەڵێت: 
\q1 ﴿ڕۆڵەکەم، بە سووکی تەماشای تەمبێکردنی\f + \fr 12:5 \fq تەمبێکردن: \ft تەمبێکردن بۆ مەبەستی ڕاستەڕێکردنە لە گوناه و کاری هەڵە کەوا خودا بەرامبەر بە مرۆڤ دەیگرێتە بەر.\f* یەزدان مەکە، 
\q2 هەروەها کاتێک سەرزەنشتت دەکات ورە بەرمەدە، 
\q1  
\v 6 چونکە ئەوەی یەزدان خۆشیبوێ تەمبێی دەکات، 
\q2 هەروەها هەر یەکێک وەک ڕۆڵەی خۆی وەریبگرێت، بە گۆچان لێی دەدات.﴾\f + \fr 12:6 \ft \xt پەندەکان 3‏:11‏،12‏\ft ‏.‏\f* 
\p  
\v 7 کەواتە بەرگەی تەمبێکردن بگرن، خوداش وەک ڕۆڵەی خۆی لەگەڵتان دەجوڵێتەوە. چ ڕۆڵەیەک هەیە باوکی تەمبێی نەکات؟  
\v 8 ئەگەر بێتو خودا تەمبێتان نەکات وەک هەموو منداڵەکانی دیکەی، ئەمە ئەوە دەگەیەنێ ئێوە زۆڵن و منداڵی ئەو نین.  
\v 9 سەرەڕای ئەمە، باوکی مرۆڤانەمان هەیە کە تەمبێی کردووین و ڕێزی ئەومان گرتووە. ئەی چەند زیاتر ملکەچی باوکی ڕۆحیمان بین، بۆ ئەوەی ژیانی هەتاهەتایی بەدەستبهێنین؟  
\v 10 باوکانمان بۆ ماوەیەک ئەوەندەی بە باشیان زانیوە تەمبێیان کردووین، بەڵام خودا بۆ سوودی ئێمەیە تەمبێمان دەکات، تاکو بەشداری پیرۆزییەکەی بکەین.  
\v 11 هەموو تەمبێکردنێک لە کاتی خۆیدا وا دەردەکەوێت کە ئازاربەخشە و خۆش نییە، بەڵام دواتر بەروبوومی ئاشتییانەی ڕاستودروستی دەگرێت بۆ ئەوانەی پێی ڕاهێنراون. 
\p  
\v 12 کەواتە دەستە لاوازبووەکان و ئەژنۆ لەرزۆکەکان بەهێز بکەن،  
\v 13 ﴿ڕێڕەوی بەرپێت خۆش بکە،﴾\f + \fr 12:13 \ft \xt پەندەکان 4‏:26‏\ft ‏\f* تاکو شەل پێی لەجێ نەچێت، بەڵکو چاک بێتەوە. 
\s1 ئاگاداری لە ڕەتکردنەوەی خودا 
\p  
\v 14 کۆشش بکەن تاوەکو لەگەڵ هەموو کەسێک بە ئاشتی بژین، هەروەها پیرۆز بن. بێ پیرۆزی کەس مەسیحی خاوەن شکۆ نابینێت.  
\v 15 ئاگاداری ئەوە بن، کەس خۆی لە نیعمەتی خودا بێبەش نەکات، نەوەک ڕەگی تاڵی لەناوتاندا گەشە بکات و پەشێوی دروستبکات، بەهۆی ئەمەشەوە زۆر کەس گڵاو ببێت.  
\v 16 ئاگاداربن نەوەک یەکێک داوێنپیس بێت یان وەک عیسۆ بەڕەڵا بێت، ئەوەی مافی نۆبەرایەتی خۆی بە ژەمێک خواردن فرۆشت\f + \fr 12:16 \ft بڕوانە \xt پەیدابوون 25‏:32‏-33.‏\ft ‏\f*.  
\v 17 دواتر وەک ئاگادارن، ویستی ئەم بەرەکەتە بە میرات وەربگرێت، بەڵام ڕەتکرایەوە. هەرچەندە بە فرمێسکەوەش داوای بەرەکەتەکەی کرد، بەڵام دەرفەتی تۆبەکردنی بۆ نەمابووەوە. 
\p  
\v 18 ئێوە نەهاتوونەتە لای شاخێک\f + \fr 12:18 \ft مەبەستی شاخی سینایە لە کاتی پێدانی تەورات بە موسا، بڕوانە \xt دەرچوون 19‏\ft ‏ و 20.‏\f* دەستی لێ بدرێت، لای ئاگرێکی بەتین، لای تاریکی، لای تەم، لای گەردەلوول،  
\v 19 لای دەنگی کەڕەنا، لای دەنگی قسەکردنێک وا لە گوێگران بکات بپاڕێنەوە ئیتر ئەم قسانەیان بۆ نەکرێت،  
\v 20 لەبەر ئەوەی نەیانتوانی بەرگەی فەرمانەکانی خودا بگرن: ﴿تەنانەت ئەگەر ئاژەڵیش دەستی بەر ئەو کێوە بکەوێ، دەبێ بەردباران بکرێت.﴾\f + \fr 12:20 \ft \xt دەرچوون 19‏:12‏،13‏.‏\ft ‏\f* 
\v 21 دیمەنەکە ئەوەندە ترسناک بوو، موسا گوتی: ﴿من لە ترسان دەلەرزم.﴾\f + \fr 12:21 \ft \xt دواوتار 9‏:19‏\ft ‏\f* 
\p  
\v 22 بەڵکو ئێوە هاتوونەتە کێوی سییۆن، بۆ شاری خودای زیندوو، ئۆرشەلیمی ئاسمانی، بۆ ئاهەنگێک کە فریشتەیەکی بێشوماری کۆکردووەتەوە،  
\v 23 بۆ کڵێسای نۆبەرە تۆمارکراوەکان لە ئاسماندا، بۆ لای خودا کە دادوەری هەمووانە، بۆ لای ڕۆحی ڕاستودروستان کە تەواوکراون،  
\v 24 بۆ لای عیسا، کە ڕێکخەری پەیمانی نوێیە، بۆ خوێنێکی پرژێنراو کە لە خوێنی هابیل باشتر دەدوێت. 
\p  
\v 25 ئاگاداربن قسەکەرەکە ڕەت مەکەنەوە، چونکە ئەگەر ئەوانەی قسەکەری سەر زەوییان ڕەتکردەوە دەرباز نەبووبن، ئایا ئێمە چۆن دەرباز دەبین ئەگەر لە قسەکەری ئاسمان هەڵبگەڕێینەوە؟  
\v 26 ئەوسا دەنگی خودا زەوی هەژاند، بەڵام ئێستا بەڵێنی داوە و دەفەرموێ: ﴿جارێکی دیکە نەک تەنها زەوی دەهەژێنم، بەڵکو ئاسمانیش.﴾\f + \fr 12:26 \ft \xt حەگەی 2‏:6‏\ft ‏\f* 
\v 27 وشەی «جارێکی دیکە» ئاماژەیە بۆ سڕینەوەی ئەو شتانەی کە دەهەژێن، واتا شتە دروستکراوەکان، تاکو ئەو شتانەی کە ناهەژێن بمێننەوە. 
\p  
\v 28 لەبەر ئەوە با سوپاسگوزار بین، چونکە شانشینێک وەردەگرین کە ناهەژێت، بەهۆیەوە بە شێوازێکی پەسەند بە ترس و ڕێزەوە خودا بپەرستین،  
\v 29 چونکە ﴿خودامان ئاگرێکی بەتینە.﴾\f + \fr 12:29 \ft \xt دواوتار 4‏:24‏\ft ‏\f* 
\c 13  
\s1 وتەی هاندان 
\p  
\v 1 بەردەوام بن لەسەر خۆشەویستیتان بۆ یەکتر وەک خوشک و برا.  
\v 2 میوانداری نامۆکان لەیاد مەکەن، چونکە بەمە کەسانێک بێ ئەوەی بزانن میوانداری فریشتەکانیان کردووە.  
\v 3 یادی بەندکراوان بکەنەوە هەروەک ئەوەی لەگەڵیان بەند کرابن، هەروەها زۆرلێکراوانیش وەک ئەوەی خۆتان لەگەڵ ئەواندا زۆرلێکراو بن. 
\p  
\v 4 با لەلای هەمووان هاوسەرایەتی ڕێزی هەبێت، نوێنی هاوسەرایەتیش پاک بێت، چونکە خودا بەڕەڵا و داوێنپیس تاوانبار دەکات.  
\v 5 با ژیانتان بێ خۆشویستنی پارە بێت و ڕازی بن بەوەی هەتانە، چونکە خودا فەرموویەتی: 
\q1 ﴿هەرگیز پشتگوێت ناخەم، 
\q2 هەرگیز وازت لێ ناهێنم.﴾\f + \fr 13:5 \ft \xt دواوتار 31‏:6‏\ft ‏\f* 
\m  
\v 6 کەواتە بە متمانەوە دەڵێین: 
\q1 ﴿یەزدان یارمەتیدەری منە، ناترسم. 
\q2 مرۆڤ دەتوانێت چیم لێ بکات؟﴾\f + \fr 13:6 \ft \xt زەبوورەکان 118‏:6‏،7‏.‏\ft ‏\f* 
\p  
\v 7 ڕابەرەکانتان لەیاد بێت، ئەوانەی باسی وشەی خوداتان بۆ دەکەن، تەماشای سەربوردەیان بکەن و لاسایی باوەڕیان بکەنەوە.  
\v 8 عیسای مەسیح وەک خۆیەتی، دوێنێ و ئەمڕۆ و هەتاهەتایە. 
\p  
\v 9 مەهێڵن فێرکردنی جۆراوجۆر و نامۆ بەڕێوەتان ببات\f + \fr 13:9 \ft بە بۆچوونی جیاواز گومڕا مەبن.‏\f*، چونکە باشە دڵ بە نیعمەت بەهێز بکرێت، نەک بە یاساکانی خۆراک کە سوودی نەبوو بۆ ئەوانەی پێی دەژین.  
\v 10 ئێمە قوربانگایەکمان هەیە کە ئەوانەی خزمەتی چادری پەرستن دەکەن بۆیان نییە لێی بخۆن.\f + \fr 13:10 \ft واتا کاهینانی پەیمانی کۆن بۆیان نییە لە بەرهەمی خاچی مەسیح سوود وەربگرن، بڕوانە ئایەتی 15.‏\f* 
\p  
\v 11 سەرۆکی کاهینان خوێنی ئاژەڵان وەک قوربانی گوناه دەهێنێتە ناو شوێنی هەرەپیرۆز، بەڵام کەلاکەکانیان لە دەرەوەی ئۆردوگا دەسووتێنرێن\f + \fr 13:11 \ft بڕوانە \xt دەرچوون 29‏:14‏\ft ‏.‏\f*.  
\v 12 لەبەر ئەوە عیساش لە دەرەوەی دەرگای شار ئازاری چێژت، تاکو بە خوێنی خۆی گەل پیرۆز بکات.  
\v 13 کەواتە با بچینە دەرەوەی ئۆردوگا\f + \fr 13:13 \ft مەبەستی دەوروبەری شوورای ئۆرشەلیمە.‏\f* بۆ لای عیسا، ڕیسواییەکەی هەڵبگرین.  
\v 14 لەبەر ئەوەی لێرەدا هیچ شارێکمان بۆ نامێنێتەوە، بەڵام داوای ئەو شارە دەکەین کە لە داهاتوودا دێت. 
\p  
\v 15 لەبەر ئەوە، با بەردەوام لە ڕێگەی مەسیحەوە بە لێوەکانمان ستایشی خودا بکەین، کە قوربانیی ئێمەیە بۆ خودا.  
\v 16 هەروەها چاکەکاری و یارمەتیدانی خەڵک پشتگوێ مەخەن، چونکە ئەو جۆرە قوربانییانە خودا دڵشاد دەکات. 
\p  
\v 17 گوێڕایەڵی ڕابەرەکانتان بن و ملکەچیان بن، چونکە ئێشکتان بۆ دەگرن، وەک بڵێی حیسابیان پێشکەشی خودا دەکەن، تاکو بە شادییەوە ئەمە بکەن نەک بە بێزاری، چونکە ئەمە زیانی بۆتان دەبێت. 
\p  
\v 18 نوێژمان بۆ بکەن، چونکە دڵنیاین ویژدانێکی باشمان هەیە، حەز دەکەین لە هەموو شتێکدا هەڵسوکەوتمان چاک بێت.  
\v 19 زیاتر لێتان دەپاڕێمەوە ئەمە بکەن، تاکو بە خێرایی بگەڕێمەوە لاتان. 
\p  
\v 20 با خودای ئاشتی کە بە خوێنی پەیمانی هەتاهەتایی عیسای خاوەن شکۆمانی لەنێو مردووان هەستاندەوە، شوانە پایەبەرزەکەی مەڕەکان،  
\v 21 بە هەموو شتێکی باش ئامادەتان بکات تاکو بە خواستی ئەو هەڵسوکەوت بکەن، لە ئێمەشدا بەپێی ڕەزامەندی خۆی کار بکات بەهۆی عیسای مەسیحەوە کە هەتاهەتایە شکۆمەندی بۆ ئەوە. ئامین. 
\s1 سڵاوی کۆتایی 
\p  
\v 22 خوشکان، برایان، لێتان دەپاڕێمەوە، بە سنگفراوانییەوە ئەم وتەی هاندانە وەربگرن، چونکە تەنها نامەیەکی کورتم بۆ نووسیون. 
\b  
\p  
\v 23 بزانن تیمۆساوسی برامان ئازاد کراوە. ئەگەر زوو هات، بەیەکەوە دیدەنیتان دەکەین. 
\b  
\p  
\v 24 سڵاو لە هەموو ڕابەران و تەواوی باوەڕداران بکەن. 
\p باوەڕدارانی ئیتالیا سڵاوتان لێدەکەن. 
\b  
\p  
\v 25 با نیعمەتی خودا لەگەڵ هەمووتان بێت.