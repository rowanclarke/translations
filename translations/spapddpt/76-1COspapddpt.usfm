\p
\v 9 ¿\w No|strong="G3756"\w* \w saben|strong="G1492"\w* \w que|strong="G3754"\w* \add los\add* injustos \w no|strong="G3756"\w* \w heredarán|strong="G2816"\w* \add el\add* reino \w de|strong="G3754"\w* \w Dios|strong="G2316"\w*? \w No|strong="G3756"\w* \w se|strong="G1492"\w* engañen: \w Ni|strong="G3777"\w* inmorales sexuales, \w ni|strong="G3777"\w* \w idólatras|strong="G1496"\w*, \w ni|strong="G3777"\w* \w adúlteros|strong="G3432"\w*, \w ni|strong="G3777"\w* afeminados, \w ni|strong="G3777"\w* homosexuales,  
