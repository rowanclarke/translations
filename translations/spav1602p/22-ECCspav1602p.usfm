\v 9 \w Alégrate|strong="H8055"\w*, mancebo, \w en|strong="H5921"\w* tu mocedad, \w y|strong="H3588"\w* tome placer tu cora­zón \w en|strong="H5921"\w* \w los|strong="H5921"\w* \w días|strong="H3117"\w* \w de|strong="H5921"\w* tu juventud; \w y|strong="H3588"\w* \w anda|strong="H1980"\w* \w en|strong="H5921"\w* \w los|strong="H5921"\w* \w caminos|strong="H1870"\w* \w de|strong="H5921"\w* tu cora­zón, \w y|strong="H3588"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w vista|strong="H4758"\w* \w de|strong="H5921"\w* tus \w ojos|strong="H5869"\w*: \w mas|strong="H3588"\w* \w sabe|strong="H3045"\w*, \w que|strong="H3588"\w* \w sobre|strong="H5921"\w* \w todas|strong="H3605"\w* estas \w cosas|strong="H3045"\w* \w te|strong="H5869"\w* traerá Dios \w a|strong="H3068"\w* \w juicio|strong="H4941"\w*.
