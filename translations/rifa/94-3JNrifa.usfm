\id 3JN
\h 3 يُوحَانَّا
\toc1 3 يُوحَانَّا
\toc2 3 يُوحَانَّا
\toc3 3 يُوح.
\mt1 3 يُوحَانَّا
\c 1
\m 
\v 1 \bd أَمْغَارْ، إِ خَايُوسْ إِعِيزّنْ\bd*، ونِّي تّخْسغْ ذِي ثِيذتّْ.
\b
\m 
\v 2 \bd \bdit أَ\bdit* أَمْعِيزّْ نّغْ\bd*، سِّيثِيمغْ أَذْ ثِيڒِيذْ مْلِيحْ ذِي مَارَّا ؤُ أَذْ ثِيڒِي ؤُڒَا ذ صّحّثْ نّشْ مْلِيحْ، أَمْ مَامّشْ إِتِّيڒِي ڒعْمَارْ نّشْ ذ لمْلِيحْ.
\v 3 مِينْزِي فَارْحغْ أَطَّاسْ، ڒَامِي د-ؤُسِينْ وَاوْمَاثنْ، شهْذنْ خْ ڒَامَانْ إِ ذَايكْ، مَامّشْ ثڭُّورذْ ذِي ثِيذتّْ.
\v 4 وَارْ غَارِي ڒفْرَاحثْ ثمْغَارْ خْ ثَا: أَقَا سْڒِيغْ ثَارْوَا إِنُو ڭُّورنْ ذِي ثِيذتّْ.
\b
\m 
\v 5 \bd \bdit أَ\bdit* أَمْعِيزّْ نّغْ\bd*، مَارَّا مِينْ ثتّڭّذْ إِ وَاوْمَاثنْ، ثتّڭّذْ ث س لْ-إِيمَانْ، ذ أَمزْوَارُو إِ إِبَارَّانِييّنْ،
\v 6 إِنِّي إِشهْذنْ خْ ثَايْرِي نّشْ قِيبَاتْشْ إِ ثْمسْمُونْثْ مَارَّا. ثڭِّيذْ مْلِيحْ ؤُمِي ذ أَسنْ ثوْشِيذْ أَفُوسْ ذِي مِينْ هْذَاجنْ نِيثْنِي، أَمْ مَامّشْ يَارْضَا أَربِّي،
\v 7 مِينْزِي نِيثْنِي فّْغنْ خْ سِّيبّثْ ن يِيسمْ نّسْ، أَمْ وَارْ كْسِينْ وَالُو زِي ڒڭْنُوسْ.
\v 8 س ؤُينِّي إِتّْخصَّا أَذْ نقْبڒْ \add إِوْذَانْ\add* أَمْ نِيثْنِي، حِيمَا أَذْ نِيڒِي ذ إِمْسخَّارنْ أَكِيذْسنْ إِ ثِيذتّْ.
\b
\m 
\v 9 نشّْ ثُوغَا خْسغْ أَذْ أَرِيغْ إِ ثْمسْمُونْثْ، مَاشَا ذِييُوثْرِيفُو، ونِّي إِتّخْسنْ أَذْ يِيڒِي ذ أَمزْوَارُو جَارْ أَسنْ، وَارْ ذ أَنغْ إِقْبِيڒْ شَا.
\v 10 س ؤُينِّي خْمِي د غَا يَاسغْ، أَذْ ث سّْعقْڒغْ ذِي ڒخْذَايمْ إِ إِتّڭّْ، ؤُمِي خَانغْ إِتّْحَارّضْ ڒهْرُوذْ ثِيعفَّانِينْ. ؤُ ڒَامِي وَارْ ذ أَسْ إِعْجِيبْ ڒْحَارْ عَاذْ، وَارْ إِقْبِيڒْ أَوْمَاثنْ، ؤُ إِنِّي ثنْ قبْڒنْ، إِمّْعَاڒَا أَكِيذْسنْ، إِسُّوفّغْ إِ-ثنْ زِي ثْمسْمُونْثْ.
\b
\m 
\v 11 \bd \bdit أَ\bdit* أَمْعِيزّْ\bd*، وَارْ ضفَّارْ شَا ثُوعفّْنَا مَاشَا ثْشُونِي! ونِّي إِتّڭّنْ ثْشُونِي، نتَّا زِي أَربِّي. ونِّي إِتّڭّنْ ثُوعفّْنَا، وَارْ إِژْرِي شَا أَربِّي. \x ◘ \xo 1:‏11 \xt إِزهد. 37‏:‏27؛ إِشا. 1‏:‏16؛ 1 بُط. 3‏:‏11؛ 1 يُوح. 3‏:‏6. \x*
\v 12 مَارَّا شهْذنْ مْلِيحْ خْ ذِيمِيثْرِييُو ڒَا ذ ثْمسْمُونْثْ ؤُڒَا ذ ثِيذتّْ سِيمَانْثْ نّسْ. ؤُڒَا ذ نشِّينْ نْشهّذْ \add خَاسْ\add* مْلِيحْ ؤُشَا ثسّْنمْ بلِّي شّْهَاذثْ نّغْ ذ ثِيذتّْ.
\b
\m 
\v 13 أَقَا غَارِي أَطَّاسْ إِ ذ أَشْ د غَا أَرِيغْ، مَاشَا وَارْ خْسغْ شَا أَذْ أَشْ د-أَرِيغْ س سّْمخْ ذ ڒقْڒمْ، \x ◘ \xo 1:‏13 \xt 2 يُوح. 12. \x*
\v 14 مَاشَا سِّيثِيمغْ أَذْ شكْ ژَترغْ ذغْيَا، \add خنِّي\add* أَذْ نسِّيوڒْ زڭْ وُوذمْ غَارْ وُوذمْ.
\v 15 ڒهْنَا أَذْ يِيڒِي أَكِيذكْ. إِمدُّوكَّاڒْ تّْسدْجَامنْ خَاكْ س ڒهْنَا. سدْجمْ خْ إِمدُّوكَّاڒْ س إِسْمَاونْ نْسنْ. 
