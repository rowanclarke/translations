\v 13 \wj \w este|strong="H2088"\w* \w pecado|strong="H5771"\w* les \w será|strong="H1961"\w* \w como|strong="H1961"\w* brecha \w que|strong="H1961"\w* amenaza ruina y \w se|strong="H1961"\w* extiende desde \w lo|strong="H2088"\w* \w alto|strong="H7682"\w* del \w muro|strong="H2346"\w* \w hasta|strong="H2088"\w* \w que|strong="H1961"\w* \w se|strong="H1961"\w* desploma \w súbita|strong="H6597"\w* y \w repentinamente|strong="H6597"\w*.\wj*
\v 14 \wj Esta \w quebradura|strong="H7667"\w* \w será|strong="H7665"\w* como \w se|strong="H3808"\w* quiebra un vaso \w de|strong="H4325"\w* alfarero, \w que|strong="H3808"\w* \w lo|strong="H3808"\w* hace trizas \w sin|strong="H3808"\w* compasión, hasta \w no|strong="H3808"\w* quedar \w entre|strong="H3808"\w* sus pedazos, \w ni|strong="H3808"\w* un \w tiesto|strong="H2789"\w* con el cual llevar fuego del horno \w o|strong="H3068"\w* para sacar \w agua|strong="H4325"\w* del pozo.\wj*
\p 
\v 15 \w Porque|strong="H3588"\w* \nd ʼAdonay \w Yavé|strong="H3068"\w*\nd*, \w el|strong="H3588"\w* \w Santo|strong="H6918"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*, dice: \wj \w En|strong="H3588"\w* regresar \w a|strong="H3068"\w* \w Mí|strong="H1961"\w* \w y|strong="H3588"\w* \w tener|strong="H1961"\w* calma, \w serán|strong="H1961"\w* salvos. \w En|strong="H3588"\w* quietud \w y|strong="H3588"\w* confianza \w está|strong="H1961"\w* \w su|strong="H3588"\w* \w fortaleza|strong="H1369"\w*. \wj* \w Pero|strong="H3588"\w* \w no|strong="H3808"\w* quisieron.
\v 16 \w Sino|strong="H3588"\w* dijeron: \w No|strong="H3808"\w*, huiremos \w a|strong="H3068"\w* \w caballo|strong="H5483"\w*. \w Por|strong="H5921"\w* \w eso|strong="H3651"\w* \w ciertamente|strong="H3588"\w* huirán. Dijeron: \w En|strong="H5921"\w* veloces corceles \w cabalgaremos|strong="H7392"\w*. \w Por|strong="H5921"\w* \w eso|strong="H3651"\w* \w más|strong="H3588"\w* veloces serán sus \w perseguidores|strong="H7291"\w*.
\v 17 Un millar \w huirán|strong="H5251"\w* \w por|strong="H5921"\w* \w la|strong="H5921"\w* amenaza \w de|strong="H5921"\w* uno. \w Por|strong="H5921"\w* \w la|strong="H5921"\w* amenaza \w de|strong="H5921"\w* \w cinco|strong="H2568"\w* \w huirán|strong="H5251"\w* todos ustedes, \w hasta|strong="H5704"\w* \w que|strong="H5921"\w* queden \w como|strong="H5921"\w* mástil \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w cumbre|strong="H7218"\w* \w de|strong="H5921"\w* una montaña \w y|strong="H5921"\w* \w como|strong="H5921"\w* \w bandera|strong="H5251"\w* \w sobre|strong="H5921"\w* una colina.
\p 
