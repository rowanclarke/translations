\p 
\v 15 \nd \w Yahweh|strong="H03068"\w*\nd* \w des|strong="H03068"\w* \w armées|strong="H06635"\w* \w les|strong="H03068"\w* \w protégera|strong="H01598"\w* ; \w Ils|strong="H01992"\w* \w dévoreront|strong="H00398"\w*\f + \fr 9:15 \ft \it Ils dévoreront… ils boitant… pris de vin\it*. Texte difficile. — La coupe pleine du sang des victimes, dont on aspergeait les quatre cornes ou angles saillants de l’autel des holocaustes.\f*, \w ils|strong="H01992"\w* fouleront \w aux|strong="H03068"\w* \w pieds|strong="H03533"\w* \w les|strong="H03068"\w* \w pierres|strong="H00068"\w* \w de|strong="H04390"\w* \w fronde|strong="H07050"\w* ; \w Ils|strong="H01992"\w* \w boiront|strong="H08354"\w*, \w ils|strong="H01992"\w* \w se|strong="H03068"\w* démèneront \w comme|strong="H03644"\w* \w pris|strong="H03947"\w* \w de|strong="H04390"\w* \w vin|strong="H03196"\w*, \w et|strong="H03068"\w* \w ils|strong="H01992"\w* \w seront|strong="H04196"\w* \w remplis|strong="H04390"\w* \w comme|strong="H03644"\w* \w la|strong="H04390"\w* \w coupe|strong="H04219"\w* \w des|strong="H03068"\w* \w sacrifices|strong="H02077"\w*, \w comme|strong="H03644"\w* \w les|strong="H03068"\w* \w cornes|strong="H07161"\w* \w de|strong="H04390"\w* l’\w autel|strong="H04196"\w*.
\v 16 \nd \w Yahweh|strong="H03068"\w*\nd* \w leur|strong="H03068"\w* \w Dieu|strong="H03068"\w* \w sera|strong="H03068"\w* \w leur|strong="H03068"\w* \w salut|strong="H03467"\w* \w en|strong="H03117"\w* \w ce|strong="H01931"\w* \w jour-là|strong="H01931"\w*, \w le|strong="H03068"\w* \w salut|strong="H03467"\w* \w du|strong="H03117"\w* \w troupeau|strong="H06629"\w* \w qui|strong="H05971"\w* \w est|strong="H03068"\w* \w son|strong="H03117"\w* \w peuple|strong="H05971"\w* ; \w ils|strong="H05971"\w* \w seront|strong="H03117"\w* \w comme|strong="H03117"\w* \w des|strong="H03068"\w* \w pierres|strong="H00068"\w* \w de|strong="H03117"\w* \w diadème|strong="H05145"\w*, \w qui|strong="H05971"\w* \w brilleront|strong="H05264"\w* \w dans|strong="H03117"\w* \w son|strong="H03117"\w* \w pays|strong="H00776"\w*.\f + \fr 9:16 \ft Autre verset difficile. — \it Comme des pierres de diadème\it*, comme les pierres précieuses qui ornent un diadème royal.\f*
\p 
