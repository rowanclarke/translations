\c 5  
\s1 La circuncisión y la Pascua  
\p
\v 1 \w Sucedió|strong="H1961"\w* \w que|strong="H3808"\w* \w cuando|strong="H5704"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w reyes|strong="H4428"\w* amorreos \w que|strong="H3808"\w* \w estaban|strong="H1961"\w* \w al|strong="H5921"\w* occidente, \w al|strong="H5921"\w* \w otro|strong="H5750"\w* \w lado|strong="H5676"\w* \w del|strong="H5921"\w* \w Jordán|strong="H3383"\w*, \w y|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w reyes|strong="H4428"\w* \w cananeos|strong="H3669"\w* \w que|strong="H3808"\w* \w estaban|strong="H1961"\w* frente \w al|strong="H5921"\w* \w mar|strong="H3220"\w*, \w oyeron|strong="H8085"\w* \w cómo|strong="H1961"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w secó|strong="H3001"\w* \w las|strong="H5921"\w* \w aguas|strong="H4325"\w* \w del|strong="H5921"\w* \w Jordán|strong="H3383"\w* \w ante|strong="H6440"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w hasta|strong="H5704"\w* \w que|strong="H3808"\w* cruzamos, desfalleció su \w corazón|strong="H3824"\w* \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w hubo|strong="H1961"\w* \w en|strong="H5921"\w* \w ellos|strong="H5921"\w* \w más|strong="H5750"\w* aliento \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.   
