\id HAG
\h حَاڭَّايْ
\toc1 حَاڭَّايْ
\toc2 حَاڭَّايْ
\toc3 حَاڭ.
\mt1 حَاڭَّايْ
\c 1
\s1 أَشجّعْ إِ ؤُعَاوذْ ن ڒبْنِي ن زَّاوشْثْ ثَامقّْرَانْثْ
\m 
\v 1 ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثْنَاينْ ن ؤُجدْجِيذْ ذَارِييُوسْ، ذڭْ ؤُيُورْ وِيسّْ ستَّا، ذڭْ وَاسّْ أَمزْوَارُو ن ؤُيُورْ، يُوسَا-د وَاوَاڒْ ن سِيذِي، س ؤُفُوسْ ن حَاڭَّايْ، أَنَابِي، غَارْ زَارُوبَّابِيلْ، مِّيسْ ن شَأَلْتِيئِيلْ، لْوَالِي ن يَاهُوذَا، ؤُ غَارْ يَاهُوشَاعْ مِّيسْ ن يَاهُوصَاذَاقْ، أَرَّايْسْ ن إِكهَّاننْ، إِنَّا:
\v 2 ”أَمُّو إِ إِسَّاوَاڒْ سِيذِي ن ڒْعسْكَارْ، إِقَّارْ: ڒْڭنْسْ-أَ إِقَّارْ: ’عَاذْ وَارْ د-يِيوِيضْ ڒْحَاڒْ، ڒْحَاڒْ مَاحنْذْ أَذْ ثتّْوَابْنَا ثَادَّارْثْ ن سِيذِي عَاوذْ.‘ “
\m 
\v 3 \add خنِّي\add* يُوسَا-د وَاوَاڒْ ن سِيذِي س ؤُفُوسْ ن ؤُنَابِي حَاڭَّايْ، إِنَّا:
\v 4 ”مَا يِيوذْ-د ڒْحَاڒْ حِيمَا كنِّيوْ أَذْ ثْزذْغمْ ذِي ثُوذْرِينْ نْومْ إِتّْوَاسقّْفنْ، \add أَمْ\add* ثَادَّارْثْ-أَ ذ ڒْخَارْبثْ؟
\v 5 ڒخُّو \add مَاشَا\add* إِنَّا سِيذِي ن ڒْعسْكَارَاثْ: حْضَامْ مْلِيحْ إِبْرِيذنْ نْومْ \add ذڭْ\add* وُوڒَاونْ نْومْ ...
\v 6 كنِّيوْ ثْزَارّْعمْ أَطَّاسْ، ثْمجَّارمْ ذْرُوسْ. كنِّيوْ ثتّتّمْ، وَارْ ثتّْجِّيوِينمْ، كنِّيوْ ثْسسّمْ، \add مَاشَا\add* وَارْ إِدْجِي أَڒَامِي إِ غَا ثسْشَارمْ، كنِّيوْ ثْيَارْضمْ أَرُّوضْ، \add مَاشَا\add* وَارْ إِسّْحمِّي، ؤُ ونِّي ذ غَا إِطّْفنْ ڒْمُونثْ، أَذْ إِطّفْ ڒْمُونثْ ذڭْ إِشْثْ ن ثْكمُّوسْثْ ثنُّوقّبْ. \x ◘ \xo 1:‏6 \xt أَعَوذ. 28‏:‏38؛ مِيخَا 6‏:‏14، 15\x*
\v 7 أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارْ: حْضَامْ مْلِيحْ إِبْرِيذنْ نْومْ \add ذڭْ\add* وُوڒَاونْ نْومْ.
\v 8 ڭعّْذمْ أَذْرَارْ، أَوْيمْ-د أَكشُّوضْ ؤُ بْنَامْ ثَادَّارْثْ-أَ ؤُ نشّْ أَذْ خَاسْ أَرْضِيغْ ؤُ أَذْ زَّايسْ تّْوَاسّْعُودْجغْ، إِنَّا سِيذِي.
\v 9 كنِّيوْ ثَارِّيمْ ثَايْنِيثْ إِ وَاطَّاسْ \add ن ڒْغِيدْجثْ\add*، \add مَاشَا\add* خْزَارمْ، \add أَقَا-ث\add* مْغِيرْ ذْرُوسْ ؤُ خْمِي ث-إِ-د-ثتَّاوْيمْ غَارْ ثَادَّارْثْ، نشّْ تّْسُوضغْ خَاسْ. مَايمِّي؟ \add أَمُّو إِ\add* إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ. زِي سِّيبّثْ ن ثَادَّارْثْ إِنُو ثنِّي \add إِذوْڒنْ\add* ذ ڒْخَارْبثْ، \add أَمْ\add* كُوڒْ إِجّنْ \add زَّايْومْ\add* إِتَّازّڒْ خْ ثَادَّارْثْ \add ن يِيخفْ\add* نّسْ.
\v 10 خْ ؤُيَا منّْعنْ خَاومْ إِجنْوَانْ نّْذَا ؤُ ثَامُّورْثْ ثْمنّعْ \add خَاومْ\add* ڒْغِيدْجثْ نّسْ. \x ◘ \xo 1:‏10 \xt أَعَوذ. 28‏:‏23\x*
\v 11 نشّْ ڒَاغِيغْ-د خْ ڒكْحضْ إِ ثمُّورْثْ، خْ إِذُورَارْ، خْ إِمنْذِي، خْ بِينُو، خْ زّشْثْ، ؤُ خْ مَارَّا مِينْ إِ د-ثتَّاوِي ثمُّورْثْ، ؤُڒَا خْ إِوْذَانْ ؤُ خْ ڒْمَاڒْ ؤُ خْ وَارْبرْ ن إِفَاسّنْ.“
\m 
\v 12 \add خنِّي\add* إِسْڒَا زَارُوبَّابِيلْ، مِّيسْ ن شَأَلْتِيئِيلْ، ؤُ \add أَكِيذسْ\add* يَاهُوشَاعْ، مِّيسْ ن يَاهُوصَاذَاقْ، أَرَّايْسْ ن إِكهَّاننْ، ؤُ مَارَّا مِينْ إِقِّيمنْ ن ڒْڭنْسْ، غَارْ ثْمِيجَّا ن سِيذِي، أَربِّي نْسنْ، ؤُ غَارْ وَاوَاڒنْ ن ؤُنَابِي حَاڭَّايْ، أَمْ مَامّشْ إِ ث إِسّكّْ سِيذِي، أَربِّي نْسنْ. ؤُ نِيثْنِي، ڒْڭنْسْ، ڭّْوذنْ زَّاثْ إِ وُوذمْ ن سِيذِي.
\v 13 إِبَارّحْ حَاڭَّايْ، أَمْسخَّارْ ن سِيذِي، إِ ڒْڭنْسْ، إِنَّا: ”نشّْ أَقَا أَيِي أَكِيذْومْ!“ إِقَّارْ سِيذِي.
\v 14 ؤُشَا إِسّكَّارْ سِيذِي بُوحْبڒْ ن زَارُوبَّابِيلْ، مِّيسْ ن شَأَلْتِيئِيلْ، لْوَالِي ن يَاهُوذَا، ؤُڒَا ذ بُوحْبڒْ ن يَاهُوشَاعْ، مِّيسْ ن يَاهُوصَاذَاقْ، أَرَّايْسْ ن إِكهَّاننْ، ؤُڒَا ذ بُوحْبڒْ ن مَارَّا مِينْ إِقِّيمنْ زِي ڒْڭنْسْ ؤُ نِيثْنِي ؤُسِينْ-د ؤُ ڭِّينْ ڒْخذْمثْ ذِي ثَادَّارْثْ ن سِيذِي ن ڒْعسْكَارَاثْ، أَربِّي نْسنْ.
\v 15 ذڭْ وَاسّْ وِيسّْ أَربْعَا ؤُ-عِيشْرِينْ ن ؤُيُورْ، ذڭْ ؤُيُورْ وِيسّْ ستَّا، ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثْنَاينْ ن ؤُجدْجِيذْ ذَارِييُوسْ.
\b
\b
\c 2
\s1 أَعُودْجِي ن زَّاوشْثْ ثَامقّْرَانْثْ ن جْذِيذْ
\m 
\v 1 ذڭْ ؤُيُورْ وِيسّْ سبْعَا، ذڭْ وَاسّْ وِيسّْ وَاحِيثْ ؤُ-عِيشْرِينْ ن ؤُيُورْ، يُوسَا-د وَاوَاڒْ ن سِيذِي س ؤُفُوسْ ن حَاڭَّايْ، إِنَّا:
\v 2 ”سِيوڒْ خنِّي غَارْ زَارُوبَّابِيلْ، مِّيسْ ن شَاعَالْثِييِيلْ، لْوَالِي ن يَاهُوذَا، ؤُ غَارْ يَاهُوشَاعْ، مِّيسْ ن يَاهُوصَاذَاقْ، أَرَّايْسْ ن إِكهَّاننْ، ؤُ غَارْ مِينْ إِقِّيمنْ زِي ڒْڭنْسْ، إِنِي:
\v 3 وِي زَّايْومْ إِقِّيمنْ زڭْ إِنِّي إِژْرِينْ \add عَاذْ\add* ثَادَّارْثْ-أَ س ؤُعُودْجِي نّسْ أَمزْوَارُو؟ ذ مَامّشْ إِ ت ثتّْوَاڒَامْ ڒخُّو؟ مَا وَارْ ثدْجِي جَارْ ثِيطَّاوِينْ نْومْ أَمْ وَالُو؟
\v 4 مَاشَا ڒخُّو، مْحضْ، \add أَ\add* زَارُوبَّابِيلْ، إِقَّارْ سِيذِي، مْحضْ، \add أَ\add* يَاهُوشَاعْ، مِّيسْ ن يَاهُوصَاذَاقْ، أَرَّايْسْ ن إِكهَّاننْ، محْضمْ \add كنِّيوْ\add* مَارَّا إِمزْذَاغْ ن ثمُّورْثْ، إِقَّارْ سِيذِي. كَّارمْ غَارْ ڒْخذْمثْ، مَاغَارْ نشّْ أَقَا أَيِي أَكِيذْومْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ.
\v 5 أَوَاڒْ إِ زِي ڭِّيغْ إِجّْ ن ڒْعَاهْذْ أَكِيذْومْ، ڒَامِي د-ثفّْغمْ زِي مِيصْرَا، ؤُ أَرُّوحْ إِنُو، أَقَا أَثنْ \add س ثْنَاينْ إِذْسنْ\add* بدّنْ ذِي ڒْوسْطْ نْومْ. وَارْ تّڭّْوذمْ شَا!
\v 6 مَاغَارْ أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ: عَاذْ إِشْثْ ن ثْوَاڒَا، \add مْغِيرْ\add* ذْرُوسْ ن ڒْحَاڒْ، نشّْ أَذْ سّنْهزّغْ إِجنْوَانْ ذ ثمُّورْثْ، ڒبْحَارْ ذ ڒْبَارّْ. \x ◘ \xo 2:‏6 \xt عبر. 12‏:‏26، 27\x*
\m 
\v 7 نشّْ أَذْ جّغْ مَارَّا ڒڭْنُوسْ أَذْ أَرْجِيجنْ ؤُ أَذْ د-أَسنْ \add س\add* مِينْ إِغْڒَانْ أَطَّاسْ زِي مَارَّا ڒڭْنُوسْ ؤُ نشّْ أَذْ شُّورغْ ثَادَّارْثْ-أَ \add س\add* ؤُعُودْجِي!، \add أَمُّو إِ\add* إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ.
\v 8 إِنُو نُّوقَارْثْ ؤُ إِنُو وُورغْ، إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ.
\v 9 أَعُودْجِي ن ثَادَّارْثْ-أَ ثَانڭَّارُوثْ أَذْ يِيڒِي ذ أَمقّْرَانْ خْ ونِّي ن \add ثَادَّارْثْ\add* ثَامزْوَارُوثْ، إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ، ؤُ نشّْ أَذْ وْشغْ ڒهْنَا ذڭْ ومْشَانْ-أَ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ.“
\b
\s1 إِجّْ ن ڒْڭنْسْ إِخْمجْ أَذْ إِطّفْ لْبَارَاكَا
\m 
\v 10 ذڭْ وَاسّْ وِيسّْ أَربْعَا ؤُ-عِيشْرِينْ ن ؤُيُورْ وِيسّْ ثسْعَا، ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثْنَاينْ ن ذَارِييُوسْ، يُوسَا-د وَاوَاڒْ ن سِيذِي س ؤُفُوسْ ن حَاڭَّايْ، إِنَّا:
\v 11 ”أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ: سقْسَامْ خنِّي إِكهَّاننْ \add خْ\add* شَّارِيعَا، إِنِي:
\v 12 خْزَارْ، إِجّنْ إِكْسِي أَيْسُومْ إِقدّْسنْ ذڭْ ؤُبحْرُورْ ن وَارُّوضْ نّسْ ؤُ س ؤُبحْرُورْ نّسْ إِحَاذَا أَغْرُومْ نِيغْ مِينْ إِونَّانْ نِيغْ بِينُو نِيغْ زّشْثْ نِيغْ مِينْ مَا إِتّمْوَاشَّانْ، مَا مَانْ أَيَا أَذْ إِذْوڒْ إِقدّسْ؟“ ؤُشَا أَرِّينْ-د إِكهَّاننْ، نَّانْ ”لَّ!“
\v 13 ؤُشَا إِنَّا حَاڭَّايْ: ”مَاڒَا إِجّْ إِذْوڒْ إِخْمجْ زڭْ إِشْثْ ن ڒْخشْبثْ، ؤُشَا خنِّي إِحَاذَا شَا زِي مَارَّا مَانْ أَيَا، مَا مَانْ أَيَا أَذْ إِذْوڒْ \add خنِّي\add* إِخْمجْ؟“ أَرِّينْ-د \add خَاسْ\add* إِكهَّاننْ، نَّانْ: ”أَذْ إِذْوڒْ إِخْمجْ!“ \x ◘ \xo 2:‏13 \xt ڒخْڒ. 5‏:‏2؛ 9‏:‏6‏-‏7، 10\x*
\v 14 \add ڒخْذنِّي\add* يَارَّا-د حَاڭَّايْ، إِنَّا: ”أَمُّو إِ يدْجَا ڒْڭنْسْ-أَ ؤُ أَمُّو إِ يدْجَا ڒْڭنْسْ-أَ زَّاثْ إِ وُوذمْ إِنُو، إِقَّارْ سِيذِي، ؤُ أَمُّو إِ ثدْجَا مَارَّا ڒْخذْمثْ ن إِفَاسّنْ نْسنْ ؤُ مِينْ قدّْمنْ ذ دّْبِيحثْ، أَقَا-ت إِخْمجْ.
\v 15 \add مَاشَا\add* ڒخُّو، زڭْ وَاسّْ-أَ ذ ثْسَاونْثْ ڭّمْ ؤُڒَاونْ نْومْ \add خْ مَانْ أَيَا\add*: قْبڒْ مَا إِتّْوَاسَّارْسْ وژْڒُو خْ وژْرُو ذِي زَّاوشْثْ ثَامقّْرَانْثْ ن سِيذِي،
\v 16 قْبڒْ مَا أَذْ إِمْسَارْ ؤُيَا، يُوسَا-د يِيجّنْ غَارْ يِيجّْ ن ؤُعُورِّيشْ ن إِمنْذِي ن عِيشْرِينْ ن ڒقْيَاسْ، أَمُّو إِ ثُوغَا \add ذِينْ\add* مْغِيرْعشْرَا، \add ؤُ\add* يُوسَا-د يِيجّْ غَارْ يِيشْثْ ن ثْسِيرْثْ \add ن ؤُضِيڒْ\add*، حِيمَا أَذْ يَايمْ خمْسِينْ ن إِبَارْمِيڒنْ، أَمُّو ثُوغَا \add ذِينْ\add* مْغِيرْ عِيشْرِينْ.
\v 17 نشّْ وْثِيغْ كنِّيوْ س \add إِمنْذِي\add* إِتّْوَاسّْشمْضنْ \add زڭْ ؤُسمِّيضْ\add*، س جّْرِيحشْثْ ن وفْسُو ؤُ س ثبْرُورِّي، \add وْثِيغْ\add* مَارَّا ڒْخذْمثْ ن إِفَاسّنْ نْومْ، \add مَاشَا\add* كنِّيوْ وَارْ د غَارِي ثذْوِيڒمْ شَا، \add أَمُّو إِ\add* إِقَّارْ سِيذِي. \x ◘ \xo 2:‏17 \xt Ḥag. 1‏:‏11\x*
\m 
\v 18 زڭْ وَاسّْ-أَ ذ ثْسَاونْثْ ڭّمْ ؤُڒَاونْ نْومْ خْ مَانْ أَيَا، زڭْ وَاسّْ وِيسّْ أَربْعَا ؤُ-عِيشْرِينْ ن ؤُيُورْ وِيسّْ ثسْعَا، زڭْ وَاسّْ نِّي ذِي إِتّْوَاسَّارْسْ ذْسَاسْ ن زَّاوشْثْ ثَامقّْرَانْثْ ن سِيذِي، ڭّمْ ؤُڒَاونْ نْومْ \add خْ مَانْ أَيَا\add*،
\v 19 مَا أَقَا ذِينْ زَّارِّيعثْ ذِي ثسْرَافْثْ؟ ثَازَايَارْثْ ذ وَارْثُو ن ثَازَارْثْ ذ ثْشجَّارْثْ ن أَرمَّانْ ذ ثْشجَّارْثْ ن زِّيثُونْ وَارْ د-إِوْينْ \add عَاذْ\add* ڒْغِيدْجثْ! زڭْ وَاسّْ-أَ نشّْ أَذْ بَارْكغْ!“
\b
\s1 لْوَاعْذْ إِ زَارُوبَّابِيلْ
\m 
\v 20 ذڭْ وَاسّْ وِيسّْ أَربْعَا ؤُ-عِيشْرِينْ يُوسَا-د وَاوَاڒْ ن سِيذِي إِ حَاڭَّايْ إِ ثْوَاڒَا وِيسّْ ثْنَاينْ، إِنَّا:
\v 21 ”سِيوڒْ غَارْ زَارُوبَّابِيلْ، لْوَالِي ن يَاهُوذَا، إِنِي: نشّْ أَذْ سّنّْهزّغْ إِجنْوَانْ ذ ثمُّورْثْ،
\v 22 ؤُ نشّْ أَذْ سّنْقڒْبغْ ڒْعَارْشْ ن ثْڭلْذِينْ ذ ثْزمَّارْ ن ثْڭلْذِينْ نْ ڒڭْنُوسْ، نشّْ أَذْ سّنْقڒْبغْ إِكَارُّوثنْ \add ن ؤُمنْغِي\add* س يِينِّي إِ ثنْ إِندّْهنْ ؤُڒَا ذ يِييْسَانْ أَكْ-ذ إِمْنَاينْ نْسنْ أَذْ تّْوَاغضْڒنْ، كُوڒْ إِجّْ ذِي سِّيفْ ن ونّغْنِي. \f ◼ \fr 2:‏22 \ft \bd ’ن ونّغْنِي‘\bd* - س ثْعِيبْرَانِيثْ ’س ؤُمَاسْ‘.\f*
\v 23 \bd ذڭْ وَاسّْ نِّي\bd*، إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ، نشّْ أَذْ شكْ كْسِيغْ، زَارُوبَّابِيلْ، مِّيسْ ن شَأَلْتِيئِيلْ، أَمْسخَّارْ إِنُو، إِقَّارْ سِيذِي، ؤُ نشّْ أَذْ شكْ أَرّغْ ذ ثْخَاذنْثْ ن ؤُشمّعْ، مَاغَارْ نشّْ إِخْضَارغْ شكْ!، \add أَمُّو إِ\add* إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ.“ 
