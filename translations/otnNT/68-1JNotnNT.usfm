\id 1JN
\h 1 ra̱ Xuua
\toc1 Ja ua rá̱ mʉdi ra̱ carta bi 'yo'tra̱ Xuua.
\toc2 1 ra̱ Xuua
\toc3 1 Jn.
\mt1 1 ra̱ Xuua
\mt2 Ja ua rá̱ mʉdi ra̱ carta bi 'yo'tra̱ Xuua.
\c 1
\p 
\v 1 Nu̱na̱ ra̱ Jesucristo di u̱nna̱ 'da'yo te, da̱di cuat'a̱hʉ ua ja ra̱ carta te'o na̱. Guehna̱ ya mi̱ 'bʉi hangu̱ ra̱ pa na̱, hante ngue di̱ nhohyø cosa i ja. Dá̱ øhme te bi̱ ma̱mp'ʉ ha bi̱ nya̱. Di 'bähme p'ʉ di hɛ̱the. Ma̱jua̱ni̱ dá̱ nu̱he, 'nɛ̱ dá̱ thädi conma̱ 'yɛhe.
\v 2 Nu̱na̱ di u̱nna̱ 'da'yo te, bi 'yøt'e ngue da̱ fa̱di̱ te'o na̱. Dá̱ nu̱he, ja̱na̱ngue nu̱ya da̱di jahe ma̱jua̱ni̱ ngue dá̱ nu̱he. Nu̱yá, dí xi'a̱hʉ ngue nu̱na̱ di u̱nna̱ 'da'yo te, hi̱n'yʉ ha bá̱ fʉdi 'nɛ̱ hi̱nha rá̱ nzɛgui ngue 'bʉi. Nu̱na̱, ma̱mbi̱ 'bʉp'ʉ bí 'bʉhrá̱ Papá, pɛ bi zøcua ngue dá̱ nnu̱he.
\v 3 Dí xi'a̱hʉ ngue dá̱ nu̱gähe na̱, 'nɛ̱ dá̱ øsɛhe te bi̱ ma̱, n'namhma̱ ngue 'nɛ̱'a̱hʉ 'da gdá̱ n'amigohʉ na̱ Oja̱ ma̱ Papáhʉ, conna̱ Jesucristo rá̱ Ts'ʉnt'ʉ Oja̱.
\v 4 Nu̱ya dí ot'a̱hʉ ya yø hya̱ jaua, n'namhma̱ ngue ma̱n'na ma̱thoguitho gui johyahʉ.
\s1 ---------
\p 
\v 5 Nu̱na̱ ra̱ hya̱ bi xännga̱he ra̱ Jesucristo, guehna̱ dí xi'a̱hʉ na̱ya, ngue nu̱na̱ Oja̱ xa̱ndønho, hi̱n tema̱ hya̱ da̱di̱ nɛ̱qui̱ ngue hi̱nga̱ njua̱ni̱.
\v 6 Nu̱'mø dí ɛ̱na̱ ngue da̱di̱ n'amigohʉ Oja̱, 'nɛ̱ hi̱nga̱ njua̱ni̱ te dí øthʉ, ya di̱ nɛ̱qui̱ ngue hi̱mma̱ jua̱ni̱ te dí̱ mma̱mhmʉ. 'Nɛ̱ hi̱mma̱ jua̱ni̱ ngue dí pa̱di̱ ga̱ øthʉ ra̱ nho.
\v 7 A nu̱'mø dí 'yo ma̱nhohʉ tengu̱tho Oja̱ ngue gä ra̱ nho øt'e, ma̱jua̱ni̱ ngue da̱di̱ n'amigo n'na ngu̱ n'najʉ 'mø. 'Nɛ̱ di̱ nhogui gätho ma̱ ts'oquihʉ conná̱ nguehrá̱ ji bi̱ männa̱ Jesucristo.
\p 
\v 8 A nu̱'mø ga̱ ɛ̱na̱ ngue hi̱n'yʉ ma̱ ts'oquihʉ, da̱di̱ nhyäsɛhʉ 'mø, hi̱mma̱ jua̱ni̱ te dí̱ mma̱mhmʉ.
\v 9 Pɛ nu̱'mø ga̱ xihmʉ Oja̱ ngue ja ma̱ ts'oquihʉ, di pu̱nnga̱ ma̱ ts'oquihʉ, di hoga̱hʉ'a̱ te gäma̱ nts'ohʉ i ja. Porque Oja̱ da̱ 'yøt'a̱ te ni̱ 'yu̱p'ʉ, di pu̱nnga̱hʉ tengu̱tho bi̱ ma̱.
\v 10 Pɛ nu̱'mø ga̱ ɛ̱na̱ ngue hi̱n tema̱ ts'oqui xtá̱ øthʉ, nu̱'mø ya dí̱ nnu̱ bɛtha̱ni̱hʉ Oja̱ 'mø. Nu̱na̱ rá̱ hya̱ Oja̱ p'ʉya, ya hi̱nga̱ ɛdi ɛ̱c'ɛ̱i̱hʉ.
\s1 ---------
\c 2
\p 
\v 1 Ague ma̱ ba̱si̱'a̱hʉ, dí ot'a̱hʉ ya yø hya̱ jaua n'namhma̱ ngue hi̱ngui̱ 'yøthʉ ra̱ ts'oqui. Pɛ nu̱'mø to bi 'yøtra̱ ts'oqui, i 'bʉ'a̱ ma̱ hojpa̱tehʉ p'ʉ bí 'bʉhma̱ Papáhʉ. Nu̱na̱ guehna̱ ra̱ Jesucristo na̱, 'nɛ̱ guehna̱ hi̱n'yʉ rá̱ ts'oqui na̱.
\v 2 Nu̱na̱ ra̱ Jesucristo bi du̱ ngue bi hoga̱ ma̱ ts'oquihʉ, 'nɛ̱ hi̱nga̱ høngtho ga̱hʉ, sinoque bi du̱ ngue di hojpa̱bi̱ yø ts'oqui gätho yø ja̱'i̱ 'bʉ'a̱ nxi̱mhäi.
\p 
\v 3 Nu̱'mø dí øthʉ te di̱ ma̱nda Oja̱, ya dí ha̱xhʉ njua̱ni̱ ngue dí pa̱hmʉ Oja̱ 'mø.
\v 4 Pɛ nu̱ te'o ngue ɛ̱na̱: “Nu̱gä dí pa̱cä Oja̱”, i ɛ̱na̱, pɛ hi̱ngui̱ øt'e te di̱ ma̱nda Oja̱, nu̱ná̱, guehna̱ ra̱ ja̱'i̱ fɛhni̱ na̱, hi̱mma̱ jua̱ni̱ ngue rá̱ mpa̱di̱ui Oja̱.
\v 5 Nu̱ ra̱ ja̱'i̱ ngue øt'e te di̱ ma̱nda Oja̱, guehna̱ ma̱jua̱ni̱ ngue pa̱di̱ xa̱nho ha di ma̱ Oja̱ na̱. Gue'a̱ gui̱ nɛ̱qui̱ ngue n'youi Oja̱ ra̱ ja̱'i̱'a̱.
\v 6 A nu̱ ra̱ ja̱'i̱ ɛ̱na̱ ngue n'youi Oja̱, i ja ngue di̱ n'yo tengu̱tho i̱ n'yo ra̱ Jesucristo 'mø mi̱ m'mʉcua.
\s1 ---------
\p 
\v 7 Ague ma̱ zi cu̱'a̱hʉ, nu̱na̱ ra̱ hya̱ dá̱ ot'ä ua ja ra̱ carta da̱di 'bɛp'a̱hʉ gui 'yøthʉ ya, hi̱mma̱ 'da'yo na̱. Guehna̱ ra̱ hya̱ bi̱ m'mɛp'i gui 'yøthʉ 'mø ga̱mba̱ ɛ̱c'ɛ̱i̱hʉ ra̱ hoga̱ 'da'yo hya̱ ma̱ m'mɛt'o na̱.
\v 8 A nu̱yá, ɛ̱ntho ma̱'da'yo na̱ ra̱ hya̱ da̱di 'bɛp'i gui 'yøthʉ ya, porque ma̱jua̱ni̱ ngue nu̱na̱ ra̱ hya̱ na̱, ja di 'uecra̱ 'bɛxu̱i̱ yu̱cua ja ra̱ xi̱mhäi na̱. A nu̱ya ngue ndap'ʉ bi zä ma̱'yoni̱ ra̱ hya̱ ya, ɛ̱ntho di da̱yot'a̱ n'na ra̱ nyot'i p'ʉ ni̱ ma ra̱ hya̱. Nu̱na̱ ra̱ Jesucristo, nu̱ te gä mma̱nna̱ ra̱ hya̱ jaua, gä bi 'yøt'e. A nu̱yá, xquet'a̱ 'nɛ̱'a̱hʉ guí øthʉ'a̱ te mma̱nna̱ ra̱ hya̱ na̱ya̱.
\p 
\v 9 Nu̱ ra̱ ja̱'i̱ ɛ̱na̱ ngue ya xa̱nho te ga̱ 'yo, pɛ nnu̱ ma̱n'ʉ drá̱ cu̱, guehna̱ ra̱ ja̱'i̱ di siguetho ngue xa̱nts'o ga̱ 'yo na̱.
\v 10 Nu̱ ra̱ ja̱'i̱ di̱ ma̱hrá̱ cu̱, ya xa̱nho te ga̱ 'yo. Hi̱n'yʉ p'ʉ di t'ɛ̱mbi̱ ngue go rá̱ ts'oqui p'ʉ øtra̱ ts'oqui mi̱'da yø ja̱'i̱.
\v 11 Pɛ nu̱ ra̱ ja̱'i̱ ngue nnu̱ ma̱n'ʉ drá̱ cu̱, ɛmma̱ 'bʉi, pɛ ra̱ nts'o ga̱ 'yo. Hi̱ngui̱ pa̱di̱ te da̱ n'yo, porque nu̱'a̱ ra̱ nts'o ja rá̱ mmʉi, gue'a̱ corpa̱ rá̱ n'yomfɛ̱ni̱'a̱.
\p 
\v 12 Ague ma̱ ba̱si̱'a̱hʉ, ngu̱na̱ ra̱ hya̱ dí ot'a̱hʉ ua ja ra̱ carta jaua, porque ya bi pu̱nnga̱ ma̱ ts'oquihʉ Oja̱ ngue bi du̱ ra̱ Jesucristo conná̱ nguecjʉ.
\v 13 A nu̱ yø da̱ja̱'i̱, ngu̱na̱ ra̱ hya̱ dí ot'a̱hʉ ua ja ra̱ carta, porque bi zøni̱ gá̱ pa̱hmʉ te'o na̱ ya mi̱ 'bʉi hante ngue di̱ nhohyø cosa i ja. A nu̱ yø ts'ʉnt'ʉ, ngu̱na̱ ra̱ hya̱ dí ot'a̱hʉ ua ja ra̱ carta, porque ya gá̱ ta̱phʉ ra̱ zithu̱.
\p Ague ma̱ ba̱si̱'a̱hʉ, ngu̱na̱ ra̱ hya̱ dí ot'a̱hʉ ua ja ra̱ carta, porque bi zøni̱ gá̱ pa̱hmʉ Oja̱ ma̱ Papáhʉ.
\v 14 A nu̱ yø da̱ja̱'i̱, ngu̱na̱ ra̱ hya̱ dí ot'a̱hʉ ua ja ra̱ carta, porque bi zøni̱ gá̱ pa̱hmʉ te'o na̱ ya mi̱ 'bʉi hante ngue di̱ nhohyø cosa i ja. A nu̱ yø ts'ʉnt'ʉ, ngu̱na̱ ra̱ hya̱ dí ot'a̱hʉ ua ja ra̱ carta, porque guí dʉhʉ ngue gá̱ 'yɛ̱c'ɛ̱i̱hʉ rá̱ hya̱ Oja̱ p'ʉ ja ni̱ mmʉihʉ. Ya gá̱ ta̱phʉ ra̱ zithu̱.
\p 
\v 15 'Yo ga̱di hohʉ ra̱ nts'o jaua ja ra̱ xi̱mhäi. Nu̱ to di ho ra̱ nts'o jaua ja ra̱ xi̱mhäi, guehna̱ ra̱ ja̱'i̱ hi̱ngui̱ pa̱di̱ di̱ ma̱'a̱ ma̱ Papáhʉ na̱.
\v 16 Porque nu̱'a̱ te gä ra̱ nts'o jaua ja ra̱ xi̱mhäi, hi̱ngrá̱ ts'änni̱ Oja̱, sinoque rá̱ ts'änni̱sɛ yø ja̱'i̱. Nu̱ yø ja̱'i̱ øt'a̱ te yø pähäsɛ. Nu̱ te gä hɛ̱ti̱, gä nne ngue dyø mmɛti, di 'yɛ̱ts'i̱ ngue'a̱ te ga̱ 'bʉi.
\v 17 Pɛ yø ja̱'i̱ da̱ thogui, da̱ gue'a̱ te yø pähä yø ja̱'i̱ da̱ thogui. Pɛ nu̱ ra̱ ja̱'i̱ ørpa̱bi̱ rá̱ pähä Oja̱ i 'bʉi para za̱ntho.
\s1 ---------
\p 
\v 18 Ague ma̱ ba̱si̱'a̱hʉ, ya ni̱ ma da̱ ga̱xra̱ pa ya. Nu̱'a̱hʉ, ya xcá̱ 'yøhmʉ ngue rá̱ nsʉiui ra̱ Cristo i ja ngue di̱ m'mʉi. A nu̱yá, ya 'bʉi xa̱ngu̱ yø ja̱'i̱ sʉ'a̱ ra̱ Cristo ya. Ja̱na̱ngue dí pa̱hmʉ ngue ya ni̱ ma da̱ ga̱xra̱ pa.
\v 19 Nu̱ ra̱ ja̱'i̱ ngue rá̱ nsʉiui ra̱ Cristo, guehna̱ hi̱mma̱ jua̱ni̱ ngue ma̱ mmi̱'yɛ̱c'ɛ̱i̱hʉ na̱, ja̱na̱ngue 'uegue. A nu̱'mø nma̱jua̱ni̱ ngue ma̱ mmi̱'yɛ̱c'ɛ̱i̱hʉ, 'daua gdi̱ n'yohʉ 'mø. Pɛ i 'uegue para ngue di̱ nɛ̱qui̱ xa̱nho ngue hi̱mma̱ jua̱ni̱ ma̱ mmi̱'yɛ̱c'ɛ̱i̱hʉ.
\p 
\v 20 Pɛ nu̱'a̱hʉ, ya bá̱ pɛn'na̱hʉ ra̱ Espíritu Santo ra̱ Cristo. Guehna̱ ra̱ Espíritu Santo øt'e ngue guí pa̱hmʉ ndana̱ ra̱ hya̱ ma̱jua̱ni̱, ndana̱ hi̱mma̱ jua̱ni̱.
\v 21 Hi̱ndá̱ ot'ä ua ja ra̱ carta 'da yø hya̱ hi̱nguí̱ pa̱hmʉ, sinoque ya guí pa̱hmʉ ngue ma̱jua̱ni̱ ya yø hya̱ dí xi'a̱hʉ. 'Nɛ̱ guí pa̱hmʉ ngue nu̱na̱ ra̱ hya̱ ma̱jua̱ni̱, hi̱n tema̱ fɛhni̱ n'youi.
\p 
\v 22 Ma ga̱ pa̱hmʉ ndana̱ ra̱ ja̱'i̱ fɛhni̱ ya. Nu̱na̱ ra̱ fɛhni̱ ya, guehna̱ ra̱ ja̱'i̱ i̱ mma̱ ngue ra̱ Jesús hi̱nga̱ guehna̱ ra̱ Cristo bá̱ ɛ̱x Oja̱ ngue di̱ nda̱st'abi na̱. Nu̱na̱ p'ʉya, guehna̱ rá̱ nsʉiui ra̱ Cristo na̱, porque cøn'a̱ ra̱ Papá, 'nɛ̱ cønnba̱bi̱ rá̱ Ts'ʉnt'ʉ Oja̱.
\v 23 Nu̱ ra̱ ja̱'i̱ ɛ̱mbi̱ ngue hi̱nga̱ guehna̱ ra̱ Jesús rá̱ Ts'ʉnt'ʉ Oja̱, guehna̱ hi̱ngui̱ n'youi ra̱ Papá na̱. Pɛ nu̱ ra̱ ja̱'i̱ i̱ mma̱ ngue ra̱ Jesucristo, guehna̱ rá̱ Ts'ʉnt'ʉ Oja̱ na̱, guehna̱ ra̱ ja̱'i̱ n'youi ra̱ Papá na̱.
\p 
\v 24 Ja̱na̱ngue da̱mi̱ 'yɛ̱t'a̱mmʉihʉ na̱ ra̱ hya̱ rá̱ mʉdi gá̱ 'yøhmʉ. Nu̱'mø ngue guí ɛ̱t'a̱mmʉihʉ na̱ ra̱ hya̱ rá̱ mʉdi gá̱ 'yøhmʉ, ya guí̱ n'yohʉ rá̱ Ts'ʉnt'ʉ Oja̱ 'mø, xquet'a̱ 'nɛ̱'a̱ ra̱ Papá guí̱ n'yohʉ p'ʉya.
\v 25 'Nɛ̱ xquet'a̱ ra̱ Jesucristo bi ya̱t'i̱ ngue di 'dacjʉ ra̱ 'da'yo te para za̱ntho.
\p 
\v 26 Dí ot'a̱hʉ na̱ ra̱ hya̱ na̱, n'namhma̱ guí pa̱hmʉ ngue 'yop'ʉ 'da ngue nne da̱ hyä'a̱hʉ.
\v 27 Ra̱ Jesucristo bá̱ pɛnhna̱ Espíritu Santo da̱ mä'a̱hʉ. Ja̱na̱ngue nu̱yá, ya hi̱mma̱ hyoni̱ ngue to da̱ xän'na̱hʉ te'o ya yø fɛhni̱ dí xi'a̱hʉ ya. Porque guesɛ'a̱ ra̱ Espíritu Santo da̱ xän'na̱hʉ gätho, ndana̱ ma̱jua̱ni̱, ndana̱ hi̱mma̱ jua̱ni̱. A nu̱'a̱ te da̱ xän'na̱hʉ na̱ ra̱ Espíritu Santo, gä gue'a̱ ma̱jua̱ni̱, hi̱ngra̱ fɛhni̱. Ja̱na̱ngue nu̱yá, hønt'a̱ ra̱ Cristo da̱ 'yo ni̱ mmʉihʉ ya, porque gue'a̱ xän'na̱hʉ ra̱ Espíritu Santo'a̱.
\p 
\v 28 Ague ma̱ ba̱si̱'a̱hʉ, hønt'a̱ ra̱ Cristo da̱ 'yo ma̱ mmʉihʉ ya, n'namhma̱ ga̱ ha̱hʉ nzammʉi 'mø dá̱ nu̱hʉ'a̱, ya hi̱nga̱ pɛs'ma̱ sähʉ 'mø bá̱ ɛ̱hɛ̱.
\v 29 Ya guí pa̱hmʉ ngue ra̱ Jesucristo, gä ra̱ nho i̱ n'yo'a̱. Xquet'a̱ jatho ngue guí pa̱hmʉ ya ngue nu̱ to gä 'yo ma̱nho, gue'ʉ yø ba̱si̱ Oja̱'ʉ.
\s1 ---------
\c 3
\p 
\v 1 Ma ga̱ pa̱hmʉ ya ngue ma̱jua̱ni̱ di̱ ma̱cjʉ na̱ Oja̱ ma̱ Papáhʉ, porque nu̱yá, ya yø ba̱si̱ ga̱hʉ Oja̱ ya. 'Nɛ̱ ma̱jua̱ni̱ ngue guecjʉ yø ba̱si̱ ga̱hʉ Oja̱. Pɛ mi̱'da yø ja̱'i̱, hi̱ngui̱ pa̱di̱ ngue yø ba̱si̱ ga̱hʉ Oja̱'ʉ, porque yø ja̱'i̱ hi̱ngui̱ pa̱ Oja̱.
\v 2 Ague ma̱ zi cu̱'a̱hʉ, ya yø ba̱si̱ ga̱hʉ Oja̱ ya, 'nɛ̱ tobe hi̱ndí̱ pa̱hmʉ xa̱nho tengu̱ ga̱ cohmʉ 'mø rá̱ nzɛgui. Pɛ dí pa̱hmʉ ngue nu̱'mø bá̱ ɛ̱hra̱ Jesucristo, ya ga̱ cohmʉ tengu̱tho'a̱, porque ya ga̱ nnu̱rpa̱hʉ rá̱ hmi̱ tengu̱.
\v 3 Nu̱ te'o gä tø'mi̱ ngue da̱ gohi tengu̱tho ra̱ Jesucristo, ya hɛp'ʉ ra̱ nts'o, i̱ nne di̱ n'yo xa̱nho ra̱ ja̱'i̱ tengu̱tho i̱ n'yo ra̱ Jesucristo.
\p 
\v 4 Nu̱ to gä øtra̱ ts'oqui, guehya nui̱spa̱bi̱ rá̱ ley Oja̱ ya. Porque ra̱ ts'oqui, gue'a̱ ngue nhui̱ts'i̱ ra̱ ley'a̱.
\v 5 Ya guí pa̱hmʉ ngue ra̱ Jesucristo bá̱ ɛ̱cua ja ra̱ xi̱mhäi ngue di hoga̱ ma̱ ts'oquihʉ. Pɛ nu̱ná̱, hi̱n tema̱ ts'oqui bi 'yø'na̱.
\v 6 Nu̱ to gätho n'youi ra̱ Jesucristo, ya hi̱ndi̱ siguetho øtra̱ ts'oqui. Pɛ nu̱ to gä øtra̱ ts'oqui, guehya hi̱ngui̱ ti̱mp'ʉ ja yø mmʉi hanja na̱ ra̱ Jesucristo ya, 'nɛ̱ hi̱ngui̱ pa̱di̱ te'o na̱ ra̱ Cristo.
\p 
\v 7 Ague ma̱ ba̱si̱'a̱hʉ, 'yo to di hä'a̱hʉ ngue gui 'yøthʉ ra̱ ts'oqui. Nu̱ ra̱ ja̱'i̱ 'yo ma̱nho, ya xa̱nho tengu̱tho ra̱ Jesucristo xa̱nho'a̱.
\v 8 Pɛ nu̱'ʉ ga̱ 'yot'a̱ ngue ra̱ ts'oqui øt'e, ra̱ zithu̱ n'youi'ʉ. Porque ra̱ zithu̱ di siguetho øtra̱ ts'oqui'a̱, asta̱ gue'mø ma̱mbi̱ dʉ'mi̱ bá̱ øtra̱ ts'oqui. Ja̱na̱ngue bá̱ ɛ̱cua rá̱ Ts'ʉnt'ʉ Oja̱ ngue di ts'onnba̱ rá̱ 'bɛfi ra̱ zithu̱.
\p 
\v 9 Nu̱'ʉ yø ba̱si̱ Oja̱, ya hi̱ngui̱ øtra̱ ts'oqui, porque ya bi̱ nthɛui ra̱ 'da'yo te di u̱n'Oja̱. Ya hi̱ngui̱ nne di sigue da̱ 'yøtra̱ ts'oqui, porque ya yø ba̱si̱ Oja̱.
\v 10 Ja di̱ nɛ̱qui̱ ua ya, ndana̱ gue'a̱ yø ba̱si̱ Oja̱, ndana̱ gue'a̱ yø ba̱si̱ ra̱ zithu̱. Nu̱ to gä hi̱ngui̱ nne da̱ 'yøtra̱ nho, ogue hi̱ngui̱ nne di̱ ma̱hrá̱ mmi̱c'ɛ̱i̱ui, guehya hi̱ngyø ba̱si̱ Oja̱ ya.
\s1 ---------
\p 
\v 11 Nu̱na̱ ra̱ hya̱ rá̱ mʉdi gá̱ 'yøhmʉ, guehna̱ mma̱nna̱ ngue n'na ngu̱ n'najʉ, jatho ga̱ ma̱di̱ gätho ma̱ mmi̱'yɛ̱c'ɛ̱i̱hʉ.
\v 12 Hi̱nga̱ øthʉ tengu̱tho ra̱ Caín ngue ma̱rá̱ n'youi ra̱ zithu̱, ja̱na̱ngue bi hyo rá̱ n'yohʉ. ¿Ha bi̱ nja ngue bi hyo? Bi hyo, porque ra̱ Caín xa̱nts'o te mi̱ øt'e, ja̱na̱ngue bi sɛyabi rá̱ n'yohʉ nu̱na̱ mi̱ øtra̱ nho.
\p 
\v 13 Ague ma̱ zi cu̱'a̱hʉ, nu̱'mø bi̱ nu̱ ma̱n'ʉ'a̱hʉ yø ja̱'i̱ ua ja ra̱ xi̱mhäi, 'yo ga̱di̱ 'yøthohʉ hanja.
\v 14 Porque ma̱m'mɛt'o ɛmma̱ dí 'bʉhmʉ, pɛ ɛ̱ntho ya xtá̱da̱ tu̱hʉ. A nu̱yá, ya dá̱ nthɛhʉ ra̱ 'da'yo te ya. Dí pa̱hmʉ ngue dá̱ nthɛhʉ ra̱ 'da'yo te, porque da̱di̱ ma̱hma̱ cu̱hʉ. Nu̱ to hi̱ndi̱ ma̱hyø cu̱, ɛmma̱ 'bʉi, pɛ ɛ̱ntho ya xa̱ ndu̱.
\v 15 Nu̱ to gä nnu̱ ma̱n'ʉ rá̱ cu̱, sʉtho ngue ra̱ hyote. 'Nɛ̱ guí pa̱hmʉ ngue nu̱'a̱ ya ga̱ 'bʉ'a̱ ngue ra̱ hyote, hi̱nga̱ n'na di̱ nthɛui ra̱ 'da'yo te.
\v 16 Ra̱ Cristo bi 'yu̱rca̱hʉ te ga̱ mbøn'a̱ ngue di̱ ma̱hrá̱ mmi̱c'ɛ̱i̱ui n'na, ngue bi̱ n'u̱ni̱ bi du̱ conná̱ nguecjʉ. Xquet'a̱ ga̱ njathʉ p'ʉya, nu̱'mø ja ngue da̱ thojʉ conná̱ nguehma̱ cu̱hʉ, ya da̱ zä.
\v 17 Xi n'na ra̱ ja̱'i̱ ngue xa̱ngu̱ te pɛts'i, 'nɛ̱ da̱ nu̱ rá̱ cu̱ ngue hi̱n'yʉ te da̱ hyoni̱, nu̱'mø hi̱ndi̱ huɛ̱qui̱ ngue di u̱nni̱ te honi̱, ¿hague da̱ nzä da̱ 'yɛ̱na̱ ngue di̱ ma̱ Oja̱ p'ʉ ja rá̱ mmʉi 'mø?
\v 18 Ague ma̱ ba̱si̱'a̱hʉ, hi̱nga̱ høntho da̱ bømma̱ nehʉ ngue da̱di̱ ma̱hma̱ mmi̱c'ɛ̱i̱hʉ, sinoque di̱ nɛ̱qui̱ ngue ma̱jua̱ni̱ da̱di̱ ma̱hmʉ, ma ga̱ fäxhʉ ma̱ mmi̱c'ɛ̱i̱hʉ.
\s1 ---------
\p 
\v 19 Nu̱'mø ma̱jua̱ni̱ da̱di̱ ma̱hma̱ mmi̱c'ɛ̱i̱hʉ, ya dí pa̱hmʉ njua̱ni̱ ngue dí øthʉ'a̱ te mma̱nná̱ hya̱ Oja̱ 'mø. Ya ma̱jua̱ni̱ ngue hu̱ ma̱ mmʉihʉ ngue ya hi̱nda̱ zʉcjʉ Oja̱ p'ʉya.
\v 20 Xi'mø ngue su̱ ma̱ mmʉihʉ ngue hi̱ndí̱ øthʉ xa̱nho'a̱ te mma̱nna̱ hya̱, pɛ nu̱'a̱ go da̱ ma̱n'Oja̱, gue'a̱ di̱ nja'a̱, hi̱nga̱ nu̱'a̱ go ga̱ mma̱mhmʉ. Porque pa̱sɛ Oja̱ te øt'e.
\v 21 A nu̱ya ma̱ zi cu̱'a̱hʉ, nu̱'mø ya hi̱ngui̱ su̱ ma̱ mmʉihʉ ya, ya säp'ʉ ga̱ ha̱hʉ ra̱ ts'ɛdi ga̱ nzohmʉ Oja̱ 'mø.
\v 22 Nu̱'mø te gäma̱ cosa ga̱ äphʉ Oja̱, di 'dacjʉ Oja̱ te dí̱ nnehʉ, porque nu̱ya yø hya̱ di̱ ma̱nda, dí ɛ̱c'ɛ̱i̱hʉ, nu̱ te nnu̱ ma̱nho Oja̱, gue'a̱ dí øthʉ'a̱.
\v 23 Nu̱na̱ ra̱ hya̱ di̱ ma̱nda Oja̱, guehna̱ ngue ga̱ ɛ̱c'ɛ̱i̱hʉ ra̱ Jesucristo rá̱ Ts'ʉnt'ʉ. 'Nɛ̱ ga̱ øthʉ te di̱ ma̱nda na̱ p'ʉya ngue n'na ngu̱ n'najʉ ga̱ ma̱di̱ gätho ma̱ mmi̱'yɛ̱c'ɛ̱i̱hʉ.
\v 24 Nu̱ to gä øt'a̱ te ra̱ hya̱ di̱ ma̱nda Oja̱, ya yø n'youi Oja̱. Nu̱'a̱ nná̱ pa̱hmʉ ngue dí̱ n'yohʉ Oja̱, ngue bá̱ pɛnnga̱hʉ ra̱ Espíritu Santo.
\s1 ---------
\c 4
\p 
\v 1 Ague ma̱ zi cu̱'a̱hʉ, nu̱ to bi zä ma̱ ja̱'i̱ da̱ 'yɛ̱na̱ ngue ra̱ Espíritu Santo di bɛ̱nnba̱bi̱ ra̱ hya̱ da̱ ma̱, 'yo sä 'bexque'a̱ guí ɛ̱c'ɛ̱i̱hʉ te mma̱. 'Be da̱mi̱ hya̱cjʉ ra̱ güɛnda xa̱ndønho te ra̱ hya̱ mma̱, n'namhma̱ guí pa̱hmʉ ngue'mø ma̱jua̱ni̱ rá̱ hya̱ Oja̱ mma̱, ogue hi̱n'na̱. Porque xa̱ngu̱ yø fɛhni̱ pønga̱hya̱ ya 'yo ndap'ʉ bi zä.
\v 2 Nu̱yá, ga̱ xi'a̱hʉ ha gdí pa̱hmʉ ngue'mø ma̱jua̱ni̱ ra̱ Espíritu Santo di bɛ̱nnba̱ ra̱ hya̱ mma̱nna̱ ja̱'i̱ ogue hi̱n'na̱. Nu̱ to gätho mma̱nya ngue ra̱ Jesucristo ma̱jua̱ni̱ bi̱ nja̱'i̱, guehna̱ rá̱ hya̱ Oja̱ mma̱nna̱.
\v 3 Pɛ nu̱ to gätho mma̱nya ngue hi̱mbi̱ nja̱'i̱ ra̱ Jesucristo, guehna̱ hi̱ngui̱ n'youi ra̱ Espíritu Santo na̱, sinoque guehna̱ ra̱ hya̱ ngue rá̱ nsʉiui ra̱ Cristo na̱. Pɛ ya xcá̱ 'yøhmʉ ngue ja ngue di̱ n'yo ua ja ra̱ xi̱mhäi'a̱ ra̱ hya̱ ngue ra̱ fɛhni̱. 'Nɛ̱ ya 'yo'a̱ ra̱ hya̱'a̱ ya.
\p 
\v 4 Ague ma̱ ba̱si̱'a̱hʉ, ya yø ja̱'i̱'a̱hʉ Oja̱ ya. Ja̱na̱ngue ya gá̱ ta̱phʉ'ʉ yø fɛhni̱ pønga̱hya̱. Porque nu̱na̱ ra̱ Espíritu Santo guí̱ n'yohʉ, ma̱n'na xa̱nzaqui na̱ ngue'a̱ ra̱ zithu̱ n'youi yø ja̱'i̱ ua ja ra̱ xi̱mhäi.
\v 5 Nu̱'ʉ yø fɛhni̱ pønga̱hya̱, yø n'yohʉ yø ja̱'i̱ 'bʉcua ja ra̱ xi̱mhäi'ʉ, ja̱na̱ngue mma̱n'a̱ te ja ua ja ra̱ xi̱mhäi. Yø ja̱'i̱ 'bʉcua ja ra̱ xi̱mhäi p'ʉya, nnu̱ ma̱nho ra̱ hya̱ mma̱nya yø fɛhni̱.
\v 6 Pɛ nu̱jʉ, ya yø ja̱'i̱ga̱hʉ Oja̱. Nu̱ te'o ya rá̱ mpa̱di̱ui Oja̱ ya, di ho da̱ 'yøhya yø hya̱ dí xännba̱he yø ja̱'i̱. Pɛ nu̱ to hi̱ngrá̱ mpa̱di̱ui Oja̱, hi̱ngui̱ nne da̱ 'yøhya yø hya̱ dí xännba̱he yø ja̱'i̱. Guehna̱ gdá̱ pa̱hmʉ na̱ya ndana̱ ra̱ ja̱'i̱ ma̱jua̱ni̱ ra̱ hya̱ mma̱, ndana̱ ra̱ ja̱'i̱ hi̱mma̱ jua̱ni̱ te mma̱.
\s1 ---------
\p 
\v 7 Ague ma̱ zi cu̱'a̱hʉ, nu̱'ʉ ma̱ mmi̱'yɛ̱c'ɛ̱i̱hʉ ya, jatho ngue ga̱ mma̱hmʉ n'na ngu̱ n'najʉ'ʉ ya. Porque nu̱'a̱ di̱ ma̱hrá̱ mmi̱c'ɛ̱i̱ui, guehna̱ øt'a̱ te rá̱ ts'änni̱ Oja̱ na̱. Nu̱'a̱ di̱ ma̱hrá̱ mmi̱c'ɛ̱i̱ui, gue'a̱ rá̱ ba̱si̱ Oja̱'a̱. Gue'a̱ rá̱ mpa̱di̱ui Oja̱'a̱.
\v 8 A nu̱'a̱ hi̱ndi̱ ma̱hrá̱ mmi̱c'ɛ̱i̱ui, hi̱ngrá̱ mpa̱di̱ui Oja̱'a̱, porque Oja̱ di̱ ma̱di̱ gätho yø ja̱'i̱.
\v 9 Ja di̱ nɛ̱qui̱ p'ʉya ngue di̱ ma̱cjʉ Oja̱, porque bá̱ pɛnhná̱ 'dants'ʉnt'ʉ ua ja ra̱ xi̱mhäi, para ngue da̱ zäp'ʉ ga̱ nthɛhʉ ra̱ 'da'yo te conná̱ ngue'a̱.
\v 10 Xi̱nda̱ hangu̱ ga̱di̱ ma̱hmʉ Oja̱, pɛ hi̱nja̱m'mø da̱ zä ga̱ ørpa̱hʉ tengu̱tho gui̱ ma̱cjʉ. Pɛ bi 'yu̱rca̱hʉ Oja̱ ha gui̱ ma̱cjʉ, ngue bá̱ pɛnhua rá̱ Ts'ʉnt'ʉ ngue da̱ du̱ ngue di hoga̱ ma̱ ts'oquihʉ.
\p 
\v 11 Ague ma̱ zi cu̱'a̱hʉ, nu̱'mø ngu̱'a̱ bi 'yøt'Oja̱ ngue i̱ ma̱cjʉ, nu̱'ʉ ma̱ mmi̱'yɛ̱c'ɛ̱i̱hʉ, jatho ngue ga̱ mma̱hmʉ n'na ngu̱ n'najʉ'ʉ ya.
\v 12 Nu̱na̱ Oja̱, hi̱nja̱m'mø to di̱ nnu̱ na̱. Pɛ nu̱'mø da̱di̱ mma̱di̱ n'na ngu̱ n'najʉ, ya dí̱ n'yohʉ Oja̱ 'mø. 'Nɛ̱ ma̱jua̱ni̱ da̱di̱ ma̱hmʉ Oja̱ 'mø.
\p 
\v 13 Nu̱na̱ Oja̱ bá̱ pɛnnga̱hʉ ra̱ Espíritu Santo, guehna̱ øt'e ngue ga̱ pa̱hmʉ ngue dí̱ n'yohʉ Oja̱.
\v 14 Nu̱na̱ rá̱ Tsʉnt'ʉ Oja̱, dá̱ nu̱sɛgähe na̱, ja̱na̱ngue da̱di jahe ma̱jua̱ni̱ ngue ra̱ Papá bá̱ pɛnhná̱ Ts'ʉnt'ʉ ua ja ra̱ xi̱mhäi ngue da̱ ya̱nyø ja̱'i̱.
\v 15 Nu̱ ra̱ ja̱'i̱ mma̱ ngue ɛ̱c'ɛ̱i̱ ngue rá̱ Ts'ʉnt'ʉ Oja̱ na̱ ra̱ Jesús, guehna̱ ra̱ ja̱'i̱ rá̱ n'youi Oja̱ na̱, ngu̱ Oja̱, ngu̱ ra̱ ja̱'i̱ hi̱nha gui̱ nhyɛgui.
\v 16 Ya dí pa̱hmʉ ngue di̱ ma̱cjʉ Oja̱, nu̱'a̱ dí ɛ̱c'ɛ̱i̱hʉ ngue ma̱jua̱ni̱'a̱.
\p Nu̱na̱ Oja̱ di̱ ma̱di̱ gätho yø ja̱'i̱. Ja̱na̱ngue nu̱ ra̱ ja̱'i̱ di̱ ma̱hrá̱ mmi̱c'ɛ̱i̱ui, ya rá̱ n'youi Oja̱ ra̱ ja̱'i̱, n'na ngu̱ n'na hi̱nha gui̱ nhyɛgui.
\v 17 Jatho ga̱ ma̱hmʉ Oja̱ co gätho ma̱ mmʉihʉ, n'namhma̱ ngue ya hi̱nte ga̱ su̱hʉ 'mø ra̱ pa da̱ni̱ hya̱xra̱ güɛnda. A nu̱ua ja ra̱ xi̱mhäi ya, nu̱na̱ Oja̱ rá̱ Papá na̱ ra̱ Jesucristo, guehna̱ ma̱ Papáhʉ na̱.
\v 18 Nu̱ ra̱ ja̱'i̱ ngue rá̱ mmʉi gui̱ ma̱ Oja̱ ya, ya hi̱ngui̱ su̱ da̱ zʉ Oja̱ ra̱ ja̱'i̱. ¿Teni̱ mantho da̱ zu̱ ra̱ ja̱'i̱ 'mø ya rá̱ mmʉi gui̱ ma̱di̱? Su̱ ra̱ ja̱'i̱ da̱ zʉ Oja̱, pɛ gue'mø hi̱ngrá̱ mmʉi gui̱ ma̱di̱.
\p 
\v 19 A nu̱jʉ da̱di̱ ma̱hmʉ Oja̱ ya, porque bi di̱mma̱ mmʉihʉ ngue rá̱ mʉdi go bi̱ ma̱cjʉ Oja̱.
\v 20 A nu̱ ra̱ ja̱'i̱ da̱ 'yɛ̱na̱ ngue di̱ ma̱ Oja̱, pɛ nnu̱ ma̱n'ʉ drá̱ cu̱, guehna̱ ra̱ ja̱'i̱ fɛhni̱ na̱. Porque ra̱ ja̱'i̱ hi̱ndi̱ ma̱hrá̱ cu̱ nu̱na̱ i̱ nnu̱, ¿hague da̱ nzä di̱ ma̱ Oja̱ nu̱na̱ hi̱ngui̱ nnu̱ 'mø?
\v 21 Guehna̱ ra̱ hya̱ di̱ ma̱nda Oja̱ na̱ya ngue nu̱ ra̱ ja̱'i̱ ɛ̱na̱ ngue di̱ ma̱ Oja̱, jatho di̱ ma̱hrá̱ cu̱.
\s1 ---------
\c 5
\p 
\v 1 Nu̱ to gätho ɛ̱c'ɛ̱i̱ ngue ra̱ Jesús guehna̱ ra̱ Cristo na̱, guehna̱ ra̱ ja̱'i̱ rá̱ ba̱si̱ Oja̱ na̱. A nu̱yá, nu̱ ra̱ ja̱'i̱ di̱ ma̱hrá̱ mmi̱n'yohʉui, co 'nɛ̱'ʉ yø ba̱si̱ na̱ ra̱ n'yohʉ ma̱ ma̱di̱ jatho ngue da̱ ma ma̱ ma̱di̱bi̱.
\v 2 Ja̱na̱ngue nu̱'mø da̱di̱ ma̱hmʉ Oja̱, 'nɛ̱ dí øthʉ'a̱ ra̱ hya̱ di̱ ma̱nda, ya dí pa̱hmʉ ngue nu̱'ʉ yø ba̱si̱ Oja̱ jatho da̱ ma ma̱ ma̱di̱.
\v 3 Porque ra̱ ja̱'i̱ di̱ ma̱ Oja̱, gue'a̱ øt'e te di̱ ma̱nda Oja̱'a̱. Nu̱'a̱ te gä di̱ ma̱nda Oja̱, gä øt'e, hi̱ngui̱ nnu̱ ma̱nhɛ̱nni̱tho da̱ 'yøt'e.
\v 4 Porque nu̱ to gätho ya 'bʉi ngue rá̱ ba̱si̱ Oja̱, ya hɛp'ʉ ra̱ nts'o jaua ja ra̱ xi̱mhäi. Nu̱na̱ ma̱ nt'ɛ̱c'ɛ̱i̱hʉ i ja, guehna̱ ga̱ tha̱pra̱ nts'o jaua ja ra̱ xi̱mhäi na̱.
\v 5 Hi̱njongui̱ sä da̱ hyɛp'ʉ ra̱ nts'o jaua ja ra̱ xi̱mhäi, høndya yø ja̱'i̱ ɛ̱c'ɛ̱i̱ ngue rá̱ Ts'ʉnt'ʉ Oja̱ na̱ ra̱ Jesús, guehya yø ja̱'i̱ hɛp'ʉ ra̱ nts'o ya.
\s1 ---------
\p 
\v 6 Ma̱mbá̱ ɛ̱cua ra̱ Jesucristo, bi fa̱di̱ ngue rá̱ Ts'ʉnt'ʉ Oja̱ 'mø mi̱ nxixya̱ p'ʉ ja ra̱ dehe 'nɛ̱'mø mi̱ männá̱ ji p'ʉ bi du̱. Pɛ hi̱nga̱ høntho bi̱ nxixya̱, sinoque bi̱ nxixya̱ 'nɛ̱ bi tho. Guesɛ ra̱ Espíritu Santo di ja ma̱jua̱ni̱ te'o na̱ ra̱ Jesucristo. A nu̱na̱ ra̱ Espíritu Santo gä ma̱jua̱ni̱ te mma̱.
\v 7 Pɛ nu̱ya hyu̱ ya, ba̱di̱ ja ma̱jua̱ni̱ p'ʉ ma̱hɛ̱ts'i̱ ngue ra̱ Jesucristo guehna̱ rá̱ Ts'ʉnt'ʉ Oja̱ na̱. Nu̱'a̱ rá̱ mʉdi, gue'a̱ rá̱ Papá. Rá̱ yoho, gue'a̱ rá̱ Ts'ʉnt'ʉ Oja̱, nu̱na̱ øt'e ngue fa̱di̱ hanja Oja̱. Rá̱ hyu̱ p'ʉya, gue'a̱ ra̱ Espíritu Santo. Nu̱ya hyu̱ ya, 'da'igu̱ mma̱.
\v 8 'Nɛ̱cua ja ra̱ xi̱mhäi, guehya di ja ma̱jua̱ni̱ ya hyu̱ yø hya̱ ya, ja dí ha̱xhʉ p'ʉ njua̱ni̱ ngue rá̱ Ts'ʉnt'ʉ Oja̱ na̱ ra̱ Jesucristo. Nu̱'a̱ rá̱ mʉdi, ra̱ Espíritu Santo øt'e ngue ti̱mma̱ mmʉihʉ hanja ra̱ hya̱. A nu̱'a̱ rá̱ yoho, bi̱ nɛ̱qui̱ xa̱nho 'mø mi̱ nja ra̱ nxixya̱. A nu̱'a̱ rá̱ hyu̱, bi fa̱di̱ xa̱nho 'mø mi̱ tho ra̱ Jesucristo. Gätho ya hyu̱ ya, 'da'igu̱ mma̱ ngue guehna̱ rá̱ Ts'ʉnt'ʉ Oja̱ na̱.
\v 9 Xi'mø bi̱ ma̱n'a̱ n'na ra̱ hya̱ yø ja̱'i̱ 'nɛ̱ dá̱ ɛ̱c'ɛ̱i̱hʉ te bi̱ ma̱, goma̱ gue Oja̱ hi̱nga̱ ɛ̱c'ɛ̱i̱hʉ te mma̱mp'ʉya. A nu̱na̱ Oja̱, guehna̱ di jasɛ ma̱jua̱ni̱ te'o na̱ rá̱ Ts'ʉnt'ʉ na̱.
\v 10 Nu̱'a̱ ɛ̱c'ɛ̱i̱bi̱ rá̱ Ts'ʉnt'ʉ Oja̱, pa̱sɛ p'ʉ ja rá̱ mmʉi ra̱ ja̱'i̱ ngue ma̱jua̱ni̱ te ɛ̱c'ɛ̱i̱. Nu̱'a̱ hi̱ngui̱ ɛ̱c'ɛ̱i̱'a̱ te mma̱n'Oja̱, guehna̱ ra̱ ja̱'i̱ nnu̱ bɛthani̱ Oja̱ na̱, porque hi̱ngui̱ ɛ̱c'ɛ̱i̱'a̱ ra̱ hya̱ bi̱ ma̱n'Oja̱ ngue te'o na̱ rá̱ Ts'ʉnt'ʉ.
\v 11 Guesɛ Oja̱ di jacjʉ ma̱jua̱ni̱ ngue di 'dacjʉ ra̱ 'da'yo te para za̱ntho. 'Nɛ̱ nu̱na̱ ra̱ 'da'yo te na̱, di̱ n'nacjʉ 'mø ga̱ ɛ̱c'ɛ̱i̱hʉ rá̱ Ts'ʉnt'ʉ Oja̱.
\v 12 Nu̱'a̱ to n'youi rá̱ Ts'ʉnt'ʉ Oja̱, ya ja ra̱ 'da'yo te. Pɛ nu̱ to hi̱ngui̱ n'youi rá̱ Ts'ʉnt'ʉ Oja̱, ya hi̱n'yʉ ra̱ 'da'yo te.
\s1 ---------
\p 
\v 13 Nu̱ya to ɛ̱c'ɛ̱i̱bi̱ rá̱ Ts'ʉnt'ʉ Oja̱, dá̱ cuarpa̱bi̱ ra̱ carta ya yø hya̱ jaua, dí̱ nnepe da̱ ba̱di̱ ngue ja ra̱ 'da'yo te para za̱ntho.
\v 14 Nu̱'mø dá̱ mat'Oja̱hʉ, di ha̱hʉ nzammʉi, porque dí ha̱xʉ njua̱ni̱ ngue nu̱'mø dí äphʉ Oja̱ n'na ra̱ cosa nu̱'a̱ da̱ ne di 'dacjʉ, nu̱na̱ Oja̱ ørpa̱ ma̱su̱ te dí xihmʉ.
\v 15 Nu̱'mø dí pa̱hmʉ ngue ørca̱hʉ ma̱su̱ Oja̱ 'mø tema̱ cosa dí äphʉ, nu̱'mø dá̱ mat'Oja̱hʉ p'ʉya, dí pa̱hmʉ ngue di 'dacjʉ Oja̱ te dí äphʉ.
\p 
\v 16 Nu̱'mø to pa̱di̱ ngue bi 'yøt'a̱ n'na ra̱ ts'oqui rá̱ cu̱, 'nɛ̱ da̱ zä di̱ mpu̱nnbi̱, da̱ marpa̱bi̱ Oja̱. Oja̱ p'ʉya di u̱nna̱ 'da'yo te 'mø ngue sä di̱ mpu̱nnba̱bi̱ rá̱ ts'oqui. Porque ja ra̱ ts'oqui ngue hi̱n'yʉ rá̱ pu̱nnbi̱, ya ra̱ castigotho tø'mra̱ ja̱'i̱. Nu̱na̱ ra̱ ts'oqui na̱, hi̱nte dí xi'a̱hʉ ngue da̱ zä gui̱ marpa̱hʉ Oja̱ ra̱ ja̱'i̱ ngue di̱ mpu̱nnbi̱.
\v 17 Nu̱'a̱ te xa̱nts'o, gä ra̱ ts'oqui'a̱. Pɛ ja ra̱ ts'oqui ngue sä di̱ mpu̱nnba̱bi̱ ra̱ ja̱'i̱.
\v 18 Dí pa̱hmʉ ngue ra̱ ja̱'i̱ nnøpa̱ Papá Oja̱, ya hi̱nga̱ 'yot'a̱ ngue ra̱ ts'oqui da̱ 'yøt'e. Porque rá̱ Ts'ʉnt'ʉ Oja̱ fähra̱ ja̱'i̱ ha ni̱ ma, ya hi̱mma̱ japi ra̱ zithu̱ di ts'onnba̱ rá̱ mmʉi ra̱ ja̱'i̱.
\p 
\v 19 A nu̱yá, dí pa̱hmʉ ngue yø ba̱si̱ga̱hʉ Oja̱ ya. A nu̱ya gätho mi̱'da yø ja̱'i̱ 'bʉi rá̱ ngʉni̱ nxi̱mhäi, gä o rá̱ 'yɛ ra̱ zithu̱.
\p 
\v 20 A nu̱yá, ya dí pa̱hmʉ ngue rá̱ Ts'ʉnt'ʉ Oja̱ bá̱ ɛ̱cua, 'nɛ̱ ya bi xoga̱ ma̱ n'yomfɛ̱ni̱hʉ ngue dá̱ pa̱hmʉ ndana̱ gue'a̱ ma̱jua̱ni̱ Oja̱. A nu̱yá, ya dí̱ n'yohʉ'a̱ ma̱jua̱ni̱ Oja̱ ya, guehna̱ ra̱ Jesucristo rá̱ Ts'ʉnt'ʉ Oja̱ na̱. Guehna̱ ma̱jua̱ni̱ ngue Oja̱ na̱, 'nɛ̱ di u̱nna̱ 'da'yo te para za̱ntho.
\p 
\v 21 Ague ma̱ ba̱si̱'a̱hʉ, 'yo gui tha̱nnehʉ yø da̱hmʉ. Da ngu̱t'a̱tho.
