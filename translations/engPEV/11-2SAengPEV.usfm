\v 18 \w After|strong="H1961"\w* 7 \w days|strong="H3117"\w* \w the|strong="H8085"\w* baby \w died|strong="H4191"\w*. \w David|strong="H1732"\w*’s \w working|strong="H6213"\w* \w men|strong="H3206"\w* \w were|strong="H1961"\w* \w afraid|strong="H3372"\w* \w to|strong="H1696"\w* \w tell|strong="H5046"\w* \w him|strong="H5046"\w* \w the|strong="H8085"\w* \w bad|strong="H7451"\w* \w news|strong="H6963"\w*. \w They|strong="H3588"\w* \w said|strong="H1696"\w* \w to|strong="H1696"\w* \w each|strong="H3117"\w* other, “\w While|strong="H1961"\w* \w the|strong="H8085"\w* baby \w was|strong="H1961"\w* \w alive|strong="H2416"\w*, \w we|strong="H3068"\w* \w tried|strong="H6213"\w* \w to|strong="H1696"\w* \w talk|strong="H1696"\w* \w to|strong="H1696"\w* \w him|strong="H5046"\w*, \w but|strong="H3588"\w* \w he|strong="H3588"\w* didn’t \w listen|strong="H8085"\w* \w to|strong="H1696"\w* \w us|strong="H5046"\w*. \w We|strong="H3588"\w* \w can|strong="H5650"\w*’t \w tell|strong="H5046"\w* \w him|strong="H5046"\w* \w this|strong="H6213"\w* \w bad|strong="H7451"\w* \w news|strong="H6963"\w*, \w or|strong="H3808"\w* \w he|strong="H3588"\w* \w might|strong="H2416"\w* \w hurt|strong="H7451"\w* \w himself|strong="H6213"\w*.”
\p 
\v 19 \w But|strong="H3588"\w* \w David|strong="H1732"\w* \w saw|strong="H7200"\w* \w that|strong="H3588"\w* \w his|strong="H1732"\w* working \w men|strong="H3206"\w* talked quietly \w to|strong="H4191"\w* each other \w like|strong="H4191"\w* \w that|strong="H3588"\w*. \w He|strong="H3588"\w* worked \w out|strong="H7200"\w* \w that|strong="H3588"\w* \w the|strong="H7200"\w* baby \w died|strong="H4191"\w*. \w So|strong="H4191"\w* \w he|strong="H3588"\w* asked \w them|strong="H7200"\w*, “\w Is|strong="H5650"\w* \w the|strong="H7200"\w* baby \w dead|strong="H4191"\w*?”
\p \w They|strong="H3588"\w* answered, “\w Yes|strong="H3588"\w*.”
\p 
\v 20 \w Then|strong="H6965"\w* \w David|strong="H1732"\w* \w got|strong="H6965"\w* \w up|strong="H6965"\w* \w from|strong="H6965"\w* \w the|strong="H3068"\w* floor \w and|strong="H6965"\w* \w washed|strong="H7364"\w* \w himself|strong="H7812"\w*, \w and|strong="H6965"\w* \w he|strong="H3068"\w* rubbed \w himself|strong="H7812"\w* \w with|strong="H1004"\w* \w perfume|strong="H1004"\w*. \w Then|strong="H6965"\w* \w he|strong="H3068"\w* \w put|strong="H7760"\w* \w on|strong="H7760"\w* some clean \w clothes|strong="H8071"\w*. \w He|strong="H3068"\w* \w went|strong="H1732"\w* \w into|strong="H7760"\w* \w God|strong="H3068"\w*’s ceremony \w house|strong="H1004"\w* \w and|strong="H6965"\w* \w got|strong="H6965"\w* \w down|strong="H7812"\w* \w on|strong="H7760"\w* \w his|strong="H3068"\w* knees \w to|strong="H3068"\w* \w show|strong="H7760"\w* \w respect|strong="H7760"\w* \w to|strong="H3068"\w* \w God|strong="H3068"\w*, \w and|strong="H6965"\w* \w to|strong="H3068"\w* \w pray|strong="H7592"\w*. \w Then|strong="H6965"\w* \w he|strong="H3068"\w* \w went|strong="H1732"\w* \w back|strong="H1004"\w* \w to|strong="H3068"\w* \w his|strong="H3068"\w* own \w house|strong="H1004"\w* \w and|strong="H6965"\w* \w told|strong="H7760"\w* \w his|strong="H3068"\w* working men \w to|strong="H3068"\w* \w bring|strong="H7760"\w* \w him|strong="H7760"\w* some \w food|strong="H3899"\w* \w to|strong="H3068"\w* \w eat|strong="H3899"\w*.
\p 
