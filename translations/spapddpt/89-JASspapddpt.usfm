\mt1 Santiago  
\c 1  
\s1 Saludo  
\p
\v 1 Santiago, \w un|strong="G3588"\w* esclavo \w de|strong="G1722"\w* \w Dios|strong="G2316"\w* \w y|strong="G2532"\w* \w del|strong="G3588"\w* \w Señor|strong="G2962"\w* \w Jesucristo|strong="G2424"\w*, \w a|strong="G1722"\w* \w las|strong="G3588"\w* 12 \w tribus|strong="G5443"\w* \w que|strong="G3588"\w* están \w en|strong="G1722"\w* \w la|strong="G3588"\w* dispersión. Saludos.   
\s1 La prueba de la fe  
\p
\v 2 Hermanos míos, gócense profundamente \w cuando|strong="G3752"\w* pasen por \w diversas|strong="G4164"\w* pruebas,  
\v 3 y \w sepan|strong="G1097"\w* \w que|strong="G3754"\w* \w la|strong="G3588"\w* \w prueba|strong="G1383"\w* \w de|strong="G3588"\w* \w su|strong="G3588"\w* \w fe|strong="G4102"\w* \w produce|strong="G2716"\w* \w paciencia|strong="G5281"\w*.  
\v 4 \w Pero|strong="G1161"\w* obtenga \w la|strong="G3588"\w* \w paciencia|strong="G5281"\w* \w su|strong="G3588"\w* resultado \w perfecto|strong="G5046"\w* \w para|strong="G2443"\w* \w que|strong="G3588"\w* sean \w perfectos|strong="G5046"\w* \w y|strong="G2532"\w* \w cabales|strong="G3648"\w*, \w sin|strong="G3367"\w* deficiencia.   
\p
\v 5 \w Si|strong="G1487"\w* \w alguno|strong="G5100"\w* \w de|strong="G3844"\w* ustedes carece \w de|strong="G3844"\w* \w sabiduría|strong="G4678"\w*, pídala \w a|strong="G3844"\w* \w Dios|strong="G2316"\w*, \w Quien|strong="G3588"\w* \w da|strong="G1325"\w* \w a|strong="G3844"\w* \w todos|strong="G3956"\w* generosamente \w y|strong="G2532"\w* \w sin|strong="G3361"\w* reproche, \w y|strong="G2532"\w* \w se|strong="G2532"\w* le \w dará|strong="G1325"\w*.  
\v 6 \w Pero|strong="G1161"\w* pida \w con|strong="G1722"\w* \w fe|strong="G4102"\w* \w sin|strong="G3367"\w* \w dudar|strong="G1252"\w*, \w porque|strong="G1063"\w* \w el|strong="G3588"\w* \w que|strong="G3588"\w* duda es \w semejante|strong="G1722"\w* \w a|strong="G1722"\w* \w la|strong="G3588"\w* onda \w del|strong="G3588"\w* \w mar|strong="G2281"\w* \w que|strong="G3588"\w* \w el|strong="G3588"\w* viento arrastra \w y|strong="G2532"\w* lanza.  
\v 7 \w Por|strong="G3754"\w* tanto \w no|strong="G3361"\w* suponga \w aquel|strong="G3588"\w* hombre \w que|strong="G3754"\w* \w recibirá|strong="G2983"\w* \w alguna|strong="G5100"\w* \w cosa|strong="G5100"\w* \w del|strong="G3588"\w* \w Señor|strong="G2962"\w*.  
\v 8 \w Un|strong="G3588"\w* hombre \w de|strong="G1722"\w* doble ánimo es inestable \w en|strong="G1722"\w* \w todos|strong="G3956"\w* \w sus|strong="G3588"\w* \w caminos|strong="G3598"\w*.   
\p
\v 9 \w El|strong="G3588"\w* hermano \w de|strong="G1722"\w* \w humilde|strong="G5011"\w* condición, enaltézcase \w en|strong="G1722"\w* \w su|strong="G3588"\w* alta posición,  
\v 10 \w pero|strong="G1161"\w* \w el|strong="G3588"\w* \w rico|strong="G4145"\w*, \w en|strong="G1722"\w* \w su|strong="G3588"\w* \w humillación|strong="G5014"\w*, \w pues|strong="G1161"\w* \w pasará|strong="G3928"\w* \w como|strong="G5613"\w* \w la|strong="G3588"\w* flor \w de|strong="G1722"\w* \w la|strong="G3588"\w* \w hierba|strong="G5528"\w*.  
\v 11 \w Porque|strong="G1063"\w* \w el|strong="G3588"\w* \w sol|strong="G2246"\w* sale \w con|strong="G1722"\w* \w calor|strong="G2742"\w* abrasador, \w seca|strong="G3583"\w* \add la\add* \w hierba|strong="G5528"\w*, \w su|strong="G3588"\w* flor cae \w y|strong="G2532"\w* perece \w la|strong="G3588"\w* belleza \w de|strong="G1722"\w* \w su|strong="G3588"\w* \w apariencia|strong="G4383"\w*. \w Así|strong="G3779"\w* \w también|strong="G2532"\w* \w el|strong="G3588"\w* \w rico|strong="G4145"\w* \w se|strong="G3779"\w* marchitará \w en|strong="G1722"\w* todos \w sus|strong="G3588"\w* \w negocios|strong="G3588"\w*.   
\s1 Prueba y tentación  
\p
\v 12 Inmensamente feliz \add el\add* varón \w que|strong="G3754"\w* soporta \add la\add* prueba, \w porque|strong="G3754"\w* \w al|strong="G3588"\w* \w ser|strong="G1096"\w* \w aprobado|strong="G1384"\w*, ganará \w la|strong="G3588"\w* \w corona|strong="G4735"\w* \w de|strong="G3588"\w* \w la|strong="G3588"\w* \w vida|strong="G2222"\w* \w que|strong="G3754"\w* \add Dios\add* \w prometió|strong="G1861"\w* a \w los|strong="G3588"\w* \w que|strong="G3754"\w* \w lo|strong="G3588"\w* aman.   
\p
\v 13 \w Ninguno|strong="G3762"\w* \w que|strong="G3754"\w* es \w tentado|strong="G3985"\w*, diga: \w Soy|strong="G1510"\w* \w tentado|strong="G3985"\w* \w por|strong="G3754"\w* \w Dios|strong="G2316"\w*. \w Porque|strong="G1063"\w* \w Dios|strong="G2316"\w* \w no|strong="G3367"\w* puede ser \w tentado|strong="G3985"\w* \w por|strong="G3754"\w* \add los \add*\w malos|strong="G2556"\w*, \w y|strong="G1161"\w* \w Él|strong="G3588"\w* mismo \w no|strong="G3367"\w* \w tienta|strong="G3985"\w* \w a|strong="G1161"\w* \w nadie|strong="G3762"\w*.  
\v 14 \w Cada|strong="G1538"\w* \w uno|strong="G1538"\w* es \w tentado|strong="G3985"\w*, atraído \w y|strong="G2532"\w* seducido \w por|strong="G5259"\w* \w su|strong="G3588"\w* \w propio|strong="G2398"\w* \w deseo|strong="G1939"\w* ardiente.  
\v 15 \w Entonces|strong="G1161"\w*, \w después|strong="G1534"\w* \w de|strong="G3588"\w* concebir \w el|strong="G3588"\w* \w deseo|strong="G1939"\w* ardiente, da \w a|strong="G1161"\w* luz \add el\add* pecado. \w Luego|strong="G1534"\w* \w de|strong="G3588"\w* consumarse \w el|strong="G3588"\w* pecado, da \w a|strong="G1161"\w* luz \add la\add* \w muerte|strong="G2288"\w*.  
\v 16 Amados hermanos míos, \w no|strong="G3361"\w* se engañen.   
\p
\v 17 \w Toda|strong="G3956"\w* buena \w dádiva|strong="G1394"\w* \w y|strong="G2532"\w* \w todo|strong="G3956"\w* \w don|strong="G1434"\w* \w perfecto|strong="G5046"\w* \w desciende|strong="G2597"\w* \w de|strong="G3844"\w* arriba, \w del|strong="G3588"\w* \w Padre|strong="G3962"\w* \w de|strong="G3844"\w* \w las|strong="G3588"\w* \w luces|strong="G5457"\w*, \w en|strong="G3844"\w* \w Quien|strong="G3739"\w* \w no|strong="G3756"\w* \w hay|strong="G1762"\w* cambio \w ni|strong="G2532"\w* sombra \w de|strong="G3844"\w* variación.  
\v 18 \w Por|strong="G1519"\w* \w su|strong="G3588"\w* voluntad, nos dio \w a|strong="G1519"\w* luz \w por|strong="G1519"\w* \w la|strong="G3588"\w* \w Palabra|strong="G3056"\w* \w de|strong="G1519"\w* verdad \w para|strong="G1519"\w* \w que|strong="G3588"\w* seamos primicias \w de|strong="G1519"\w* \w sus|strong="G3588"\w* \w criaturas|strong="G2938"\w*.   
\s1 Hacedores  
\p
\v 19 Sepan, mis amados hermanos: \w Todo|strong="G3956"\w* ser humano \w sea|strong="G3588"\w* \w pronto|strong="G5036"\w* \w para|strong="G1519"\w* escuchar, tardo \w para|strong="G1519"\w* \w hablar|strong="G2980"\w*, tardo \w para|strong="G1519"\w* \w airarse|strong="G3709"\w*,  
\v 20 \w porque|strong="G1063"\w* \add la \add*\w ira|strong="G3709"\w* del hombre \w no|strong="G3756"\w* efectúa \add la\add* \w justicia|strong="G1343"\w* de \w Dios|strong="G2316"\w*.  
\v 21 \w Por|strong="G1722"\w* tanto desechen \w toda|strong="G3956"\w* impureza \w y|strong="G2532"\w* \w abundancia|strong="G4050"\w* \w de|strong="G1722"\w* \w maldad|strong="G2549"\w* \w y|strong="G2532"\w* \w reciban|strong="G1209"\w* \w con|strong="G1722"\w* humildad \w la|strong="G3588"\w* \w Palabra|strong="G3056"\w* sembrada \w que|strong="G3588"\w* \w puede|strong="G1410"\w* \w salvar|strong="G4982"\w* \w sus|strong="G3588"\w* \w almas|strong="G5590"\w*.   
\p
\v 22 \w Así|strong="G2532"\w* \w que|strong="G2532"\w* \w no|strong="G3361"\w* \w se|strong="G1438"\w* engañen ustedes mismos. \w Sean|strong="G1096"\w* \w hacedores|strong="G4163"\w* \w de|strong="G1161"\w* \add la\add* \w Palabra|strong="G3056"\w* \w y|strong="G2532"\w* \w no|strong="G3361"\w* \w solo|strong="G3441"\w* oidores.  
\v 23 \w Porque|strong="G3754"\w* \w si|strong="G1487"\w* \w alguno|strong="G5100"\w* \w es|strong="G1487"\w* oidor \w de|strong="G1722"\w* \add la\add* \w Palabra|strong="G3056"\w*, \w y|strong="G2532"\w* \w no|strong="G3756"\w* \w hacedor|strong="G4163"\w*, \w es|strong="G1487"\w* \w como|strong="G2532"\w* \w un|strong="G5100"\w* hombre \w que|strong="G3754"\w* mira \w su|strong="G3588"\w* \w rostro|strong="G4383"\w* \w en|strong="G1722"\w* \w un|strong="G5100"\w* \w espejo|strong="G2072"\w*:  
\v 24 \w se|strong="G1438"\w* mira \w y|strong="G2532"\w* sale, \w e|strong="G2532"\w* inmediatamente \w se|strong="G1438"\w* olvida \w cómo|strong="G2532"\w* \w era|strong="G1510"\w*.  
\v 25 \w Pero|strong="G1161"\w* \w el|strong="G3588"\w* \w que|strong="G3588"\w* mira atentamente \w en|strong="G1722"\w* \add la\add* \w ley|strong="G3551"\w* \w perfecta|strong="G5046"\w*, \w la|strong="G3588"\w* \w de|strong="G1722"\w* \w la|strong="G3588"\w* \w libertad|strong="G1657"\w*, permanece \w en|strong="G1722"\w* \w ella|strong="G3588"\w* \w y|strong="G2532"\w* \w no|strong="G3756"\w* \w es|strong="G1096"\w* oidor \w olvidadizo|strong="G1953"\w*, \w sino|strong="G1161"\w* practicante, \w será|strong="G1096"\w* inmensamente feliz \w en|strong="G1722"\w* \w lo|strong="G3588"\w* \w que|strong="G3588"\w* \w hace|strong="G2041"\w*.   
\p
\v 26 \w Si|strong="G1487"\w* \w alguno|strong="G5100"\w* supone ser \w religioso|strong="G2357"\w* \w y|strong="G1510"\w* \w no|strong="G3361"\w* \w refrena|strong="G5468"\w* \w su|strong="G3588"\w* \w lengua|strong="G1100"\w*, \w sino|strong="G1487"\w* engaña \w su|strong="G3588"\w* \w corazón|strong="G2588"\w*, \w su|strong="G3588"\w* \w religión|strong="G2356"\w* \w no|strong="G3361"\w* tiene valor.  
\v 27 \add La\add* \w religión|strong="G2356"\w* \w pura|strong="G2513"\w* \w y|strong="G2532"\w* \w sin|strong="G2532"\w* mancha \w delante|strong="G3844"\w* \w del|strong="G3588"\w* \w Dios|strong="G2316"\w* \w y|strong="G2532"\w* \w Padre|strong="G3962"\w* \w es|strong="G3778"\w* \w ésta|strong="G3778"\w*: Atender \w a|strong="G1722"\w* \add los\add* \w huérfanos|strong="G3737"\w* \w y|strong="G2532"\w* \w a|strong="G1722"\w* \w las|strong="G3588"\w* \w viudas|strong="G5503"\w* \w en|strong="G1722"\w* \w su|strong="G3588"\w* \w aflicción|strong="G2347"\w* \w y|strong="G2532"\w* guardarse \w sin|strong="G2532"\w* mancha \w del|strong="G3588"\w* \w mundo|strong="G2889"\w*.   
\c 2  
\s1 Contra la acepción de personas  
\p
\v 1 Hermanos míos, \w no|strong="G3361"\w* practiquen \w la|strong="G3588"\w* \w fe|strong="G4102"\w* \w de|strong="G1722"\w* \w nuestro|strong="G2249"\w* \w glorioso|strong="G1391"\w* \w Señor|strong="G2962"\w* \w Jesucristo|strong="G2424"\w* \w con|strong="G1722"\w* \w acepción|strong="G4382"\w* \w de|strong="G1722"\w* personas.   
\p
\v 2 \w Porque|strong="G1063"\w* \w si|strong="G1437"\w* \w en|strong="G1722"\w* la \w congregación|strong="G4864"\w* judía \w de|strong="G1722"\w* ustedes alguien \w entra|strong="G1525"\w* \w con|strong="G1722"\w* anillo \w de|strong="G1722"\w* oro \w y|strong="G2532"\w* \w ropa|strong="G2066"\w* espléndida, \w y|strong="G2532"\w* \w también|strong="G2532"\w* \w entra|strong="G1525"\w* \w un|strong="G1722"\w* \w pobre|strong="G4434"\w* \w con|strong="G1722"\w* \w ropa|strong="G2066"\w* rota,  
\v 3 \w y|strong="G2532"\w* miran \w con|strong="G1909"\w* agrado \w al|strong="G3588"\w* \w que|strong="G3588"\w* usa \w la|strong="G3588"\w* \w ropa|strong="G2066"\w* espléndida, \w y|strong="G2532"\w* \add le\add* \w dicen|strong="G3004"\w*: \w Siéntate|strong="G2521"\w* \w aquí|strong="G5602"\w* \w en|strong="G1909"\w* \w un|strong="G3588"\w* buen puesto, \w y|strong="G2532"\w* \w dicen|strong="G3004"\w* \w al|strong="G3588"\w* \w pobre|strong="G4434"\w*: Quédate \w tú|strong="G4771"\w* \w ahí|strong="G1563"\w* \w en|strong="G1909"\w* \w pie|strong="G2476"\w*, \w o|strong="G2228"\w* \w siéntate|strong="G2521"\w* \w aquí|strong="G5602"\w* \w a|strong="G1909"\w* mis pies,  
\v 4 ¿\w no|strong="G3756"\w* \w se|strong="G1438"\w* convierten \w en|strong="G1722"\w* \w jueces|strong="G2923"\w* \w de|strong="G1722"\w* decisiones corruptas \w entre|strong="G1722"\w* ustedes mismos?   
\p
\v 5 Amados hermanos míos: ¿\w No|strong="G3756"\w* \w escogió|strong="G1586"\w* \w Dios|strong="G2316"\w* \w a|strong="G1722"\w* \w los|strong="G3588"\w* \w pobres|strong="G4434"\w* según \w el|strong="G3588"\w* \w mundo|strong="G2889"\w*, \w ricos|strong="G4145"\w* \w en|strong="G1722"\w* \w fe|strong="G4102"\w* \w y|strong="G2532"\w* \w herederos|strong="G2818"\w* \w del|strong="G3588"\w* reino \w que|strong="G3588"\w* \w prometió|strong="G1861"\w* \w a|strong="G1722"\w* \w los|strong="G3588"\w* \w que|strong="G3588"\w* \w lo|strong="G3588"\w* aman?  
\v 6 \w Pero|strong="G1161"\w* ustedes trataron \w con|strong="G2532"\w* desprecio \w al|strong="G3588"\w* \w pobre|strong="G4434"\w*.  
\p ¿\w No|strong="G3756"\w* \w los|strong="G3588"\w* \w oprimen|strong="G2616"\w* \w los|strong="G3588"\w* \w ricos|strong="G4145"\w*, \w y|strong="G2532"\w* \w ellos|strong="G3588"\w* mismos \w los|strong="G3588"\w* \w arrastran|strong="G1670"\w* \w a|strong="G1519"\w* \add los \add*tribunales?  
\v 7 ¿\w No|strong="G3756"\w* blasfeman \w ellos|strong="G3588"\w* \w el|strong="G3588"\w* \w Nombre|strong="G3686"\w* \w por|strong="G1909"\w* \w el|strong="G3588"\w* \w cual|strong="G3588"\w* fueron llamados?   
\p
\v 8 \w Si|strong="G1487"\w* ciertamente cumplen \add la\add* \w Ley|strong="G3551"\w* real \w según|strong="G2596"\w* \w la|strong="G3588"\w* \w Escritura|strong="G1124"\w*:  
\m \wj Amarás \+w a|strong="G2596"\+w* \+w tu|strong="G4771"\+w* \+w prójimo|strong="G4139"\+w* \+w como|strong="G5613"\+w* \+w a|strong="G2596"\+w* \+w ti|strong="G4572"\+w* mismo,\wj* \w hacen|strong="G4160"\w* \w bien|strong="G2573"\w*.   
\p
\v 9 \w Pero|strong="G1161"\w* \w si|strong="G1487"\w* hacen acepción \w de|strong="G5259"\w* personas, cometen pecado \w y|strong="G1161"\w* \w son|strong="G1487"\w* convictos \w por|strong="G5259"\w* \w la|strong="G3588"\w* \w Ley|strong="G3551"\w* \w como|strong="G5613"\w* \w transgresores|strong="G3848"\w*.  
\v 10 \w Porque|strong="G1063"\w* \w cualquiera|strong="G3956"\w* \w que|strong="G3588"\w* \w guarde|strong="G5083"\w* \w toda|strong="G3956"\w* \w la|strong="G3588"\w* \w Ley|strong="G3551"\w*, \w pero|strong="G1161"\w* tropieza \w en|strong="G1722"\w* \w un|strong="G1520"\w* \add punto\add* \w es|strong="G1096"\w* culpable \w de|strong="G1722"\w* \w todos|strong="G3956"\w*.  
\v 11 \w Porque|strong="G1063"\w* \w el|strong="G3588"\w* \w que|strong="G3588"\w* \w dijo|strong="G3004"\w*: \wj \+w No|strong="G3756"\+w* \+w adulteres|strong="G3431"\+w*\wj*, \w también|strong="G2532"\w* \w dijo|strong="G3004"\w*: \wj \+w No|strong="G3756"\+w* asesines\wj*. \w Y|strong="G2532"\w* \w si|strong="G1487"\w* \w no|strong="G3756"\w* \w adulteras|strong="G3431"\w*, \w pero|strong="G1161"\w* asesinas, eres \w transgresor|strong="G3848"\w* \w de|strong="G3588"\w* \add la\add* \w Ley|strong="G3551"\w*.   
\p
\v 12 \w Así|strong="G3779"\w* \w hablen|strong="G2980"\w*, \w y|strong="G2532"\w* \w así|strong="G3779"\w* procedan, \w como|strong="G5613"\w* \w los|strong="G2532"\w* \w que|strong="G2532"\w* van \w a|strong="G5613"\w* ser juzgados \w por|strong="G1223"\w* \w medio|strong="G1223"\w* \w de|strong="G1223"\w* \add la \add*\w ley|strong="G3551"\w* \w de|strong="G1223"\w* \add la\add* \w libertad|strong="G1657"\w*.  
\v 13 \w Porque|strong="G1063"\w* \w el|strong="G3588"\w* \w juicio|strong="G2920"\w* será \w sin|strong="G3361"\w* \w misericordia|strong="G1656"\w* \w para|strong="G3361"\w* \w el|strong="G3588"\w* \w que|strong="G3588"\w* \w no|strong="G3361"\w* tiene \w misericordia|strong="G1656"\w*. \add La \add*\w misericordia|strong="G1656"\w* triunfa sobre \add el \add*\w juicio|strong="G2920"\w*.   
\s1 Fe y obras  
\p
\v 14 ¿\w De|strong="G3588"\w* \w qué|strong="G3588"\w* vale, hermanos míos, \w cuando|strong="G1437"\w* \w alguno|strong="G5100"\w* diga \w que|strong="G3588"\w* \w tiene|strong="G2192"\w* \w fe|strong="G4102"\w* \w y|strong="G1161"\w* \w no|strong="G3361"\w* \w tiene|strong="G2192"\w* \w obras|strong="G2041"\w*? ¿Esa \w fe|strong="G4102"\w* \w puede|strong="G1410"\w* salvarlo?  
\v 15 \w Cuando|strong="G1437"\w* \w un|strong="G3588"\w* hermano \w o|strong="G2228"\w* \w una|strong="G3588"\w* hermana \w no|strong="G1437"\w* tiene ropa \w y|strong="G2532"\w* carece \w de|strong="G3588"\w* sustento diario,  
