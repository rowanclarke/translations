\id JOL - Kuna, San Blas - Bible -Panama 2014 (DBL -2014) 
\h Joel 
\toc1 Joel-Garda 
\toc2 Joel 
\toc3 Jl 
\mt1 JOEL-GARDA 
\mt2 JOEL 
\imt2 GEBE-SOGLENAID 
\imt1 Garda-nug 
\ip \it Joel-Garda.\it* Joel, Bab-Dummad-gayaburba-barsogdii gusad. We-dulede, Petuel-machid. \it Bab-Dummad, Jehováʼye,\it* Joel-nug obarileged. 
\is1 Joel-Gardagi weyob sunmaklenaid 
\ip Anmar dakdele, reymar-garda-sogbogwadgi ibmar-soglenaid-balillasaar anmarga Joel e-gardagi sunmaknaid (2 Reyes 25:1-26). Bur bule Joel Jerusalén-neggweburgi sunmakdii gusad. We-ibagangine, Jerusalén-neggwebur Judá-yargi-neggweburmar-e-sailaga siid. Joel, Judá-dulemarga Bab-Dummad-ibagan-danikoedgi sunmaksabalid. 
\ip We-gardagine, weyob ilemakar sunmaklenaid: 
\io1 1. Yoedse sesmarse neg ibitogoed, degi, Bab-Jehová-E-Iba-Danikid (1:1–2:2a). 
\io1 2. Bab-Jehová-E-Iba-Danikidgi gannar sunmaklenaid (2:2b-11). 
\io1 3. Bab-Jehová-dule-wiledaked (2:12-27). 
\io1 4. Bab-Dummad-e-Burba-Isligwaled aidenonikoed (2:28-32). 
\io1 5. Dule-yar-baid-baidgi-bukmalad sabsur-odurdaklemaloed (3:1-15). 
\io1 6. Judá-dulemar-bendaklenonikoed (3:16-21). 
\ip Be itogua. 
\c 1  
\ms1 1. YOEDSE SESMARSE NEG IBITOGOED, DEGI, BAB-JEHOVÁ-E-IBA-DANIKID 
\mr (1:1–2:2a) 
\p  
\v 1 Bab-Jehová Petuel-machi-Joelʼga gayaburba sognonikid. 
\s1 Sesmar neg-oitosad 
\p Joel, Israel-dulemarga weyob sogded: 
\q1  
\v 2-4 “Bemar, sapin-dummagan-gumalad, nue itomalo. 
\q2 Bela we-yargi-gudidimalad, nue itomalo. 
\q1 Ses-danagwen-gudimalad-ibmar-guchagusad-obesadi, 
\q2 sorba ses-dummagan-gudidimalad gunnonimalad. 
\q1 Geb ses-dummagan-gudidimalad-ibmar-guchagusad-obesadi, 
\q2 sorba ses-sapingana gunnonimarmogad. 
\q1 Geb ses-sapingana-ibmar-guchagusad-obesadi, 
\q2 sorba ses-burwigana gunnonimarmogad. 
\q1 Be-dadgan-ibagangi, ¿ar weyobi neg-gusa? 
\q2 Bemar-emi-dulagudimaladgi, ¿ar bemar weyob neg-dakdimala? 
\q1 Emi, be-mimmigangala, be we-ibmar sogmala, 
\q2 adi, be-mimmigan na e-mimmiganga sogmarmogaga, 
\q2 deginmoga, a-mimmigan na e-wagan-danimaloedga sogmarmogoed.\fig Sesmar gagan-gunnanaid. (Joel 1:2-4) |src="HK00059B.TIF" size="col" ref="Joel 1:2-4" \fig* 
\b  
\q1  
\v 5 ”¡Mummugan, atakmala, be bomala! 
\q2 Bela-gadi-vino-gobmalad be nunmak itomala, 
\q1 ar ade, vino-binid bemar-annik sulesad. 
\q2  
\v 6 Ar dule-yar-baidgi-bukmalad-gandikmalad-bukidar, an-yargine ubononikid. 
\q1 E-nugarmar, achumigur-nugarmaryobi nikamalad. 
\q2 E-nugar-suigan, achumigur-e-ome-nugaryobi nikamalad. 
\q1  
\v 7 An-uva-dubmar-digar-naid obelosmalad. 
\q2 An-higuera-sapimar daas-daas-imaksad. 
\q1 Bela e-uka yaas-yaas-imaksamalad, 
\q2 e-anagan swanga imaksamalad. 
\q2 Bela omukusmalad. 
\b  
\q1  
\v 8 ”An-dulemar, yagwa wile-itoged-mor-yoi na machered-abesiid-ei-burgwisadba-boedyobi, bomalad. 
\q2  
\v 9 Bab-Jehováʼse-goled-neggi ibmar-gwag-orosgi-dakleged-ukleged bar uklesulid, 
\q2 degi, vinoʼmar bar uklesurbalid. 
\q1 Dule-irwa-Bab-Dummadse-gormalad Bab-Jehováʼga-arbamaladi, bomarmogad. 
\q2  
\v 10 Nainumar bela swanga nanaid, 
\q2 e-napamar bela dinna naded. 
\q1 Bela ibmar-gwag-orosgi-dakleged bergusad, 
\q2 vinoʼmar bela dinguded, 
\q2 olivoʼmar bela berguded. 
\b  
\q1  
\v 11 ”Bemar, sapurgi-arbamalad, bemar uva-dubgi-arbamalad, ibmar-gwag-trigoʼye-nugad-bela-dingusadba, 
\q2 ibmar-gwag-cebadaʼye-nugad-bela-dingusadba, be bomala. 
\q1 Ar bela ibmar-gwagmar-welesadi oitolesad. 
\q1  
\v 12 Uva-dubmar bela dinguded, 
\q2 sapi-higueraʼye-nugad, bela burgwided. 
\q1 Sapi-granadoʼye-nugad bela dingudmogad, 
\q2 ogobgi-dakleged, manzana-sapimar, dingudmalad. 
\q1 Bela sapimar-gwigwichid dingudmalad. 
\q2 Dulemar-e-yeer-itodiidse-bakale, e-ibe bergunonikid.” 
\s1 Isgued-barsogmarye gorlenaid 
\q1  
\v 13 Dule-irwa-Bab-Dummadse-gormalad, be wile-itomar, 
\q2 wile-itoged-mor be yomar. 
\q1 Bab-Jehováʼga-ibmar-ukleged-ailagi-arbamalad, 
\q2 naibid-dummad be itomar. 
\q1 An-Bab-Dummadga-arbadimalad, be dagmala, 
\q2 wile-itoged-mor-yoi, be oibomar, 
\q1 ar ibmar-gwagmar, degi, vinoʼmar 
\q2 Bab-Dummadse-goled-neggi bar uklesulid. 
\q1  
\v 14 Bela dulemarse gormala, 
\q2 mer-bar-mas-gulleged-iba be nasikmalo. 
\q1 Be-Bab-Dummad-Jehováʼse-goled-neggi, girmar-dummagan be onmakmala, 
\q2 bela dulemar-we-yargi-gudidimalad be onmakmala, 
\q1 agi Bab-Jehováʼse ise-gollar imakmala. 
\b  
\q1  
\v 15 ¡Iba-buledi danikid! 
\q2 ¡Bab-Jehová-e-iba bato warmakdanikid! 
\q1 Bab-Dummad-Bela-Gangued-Nika-Maid-e-iba, 
\q2 ibmar-bergued-iba guoed. 
\b  
\q1  
\v 16 Anmar-masgulleged, ¿anmar-wagab anmar-ibe sulenai gussursi? 
\q2 Anmar-Bab-Dummadse-goled-neggi anmar-wergued, anmar-yeer-itoged, 
\q2 ¿anmar-ibe osulolessursi? 
\q1  
\v 17 Ibmar-gwag diglesa-inigwele, degite, bela nungusad. 
\q2 Ibmar-saboleged-neg isgus-sii. 
\q1 Ibmar-gwag-saboleged-negmar bela bibichisad. 
\q2 Ar ibmar-gwagmar bela dingusmalad. 
\q1  
\v 18 Ibiyobi molimar masbina gornanai. 
\q2 Moli-bebe-nikamalad masgunned satedbali oes gaamakdidimalad. 
\q1 Sibad-wawaadmar deyobi gudidimarmogad. 
\b  
\q1  
\v 19 Bab-Jehováʼye, an bese ise-wilegar goled, 
\q2 ar ade, nainumargi gagan-nanaid soo ogumaksad, 
\q2 bela sapimar-gwigwichid ogumaksad. 
\q1  
\v 20 Bab-Jehová, amba ibmar-durganse-bakale, bela-bela be-amimalad, 
\q2 ar ade, bela diwarmar-mamaidi dingusad, 
\q2 nainumargi gagan-nanaid soo ogumaksad. 
\c 2  
\q1  
\v 1 Sión-yargine gar-trompeta ogormar, 
\q2 an-yar-islidikidgi neg-owisoleged-gar be ogormar. 
\q1 Bela dulemar-we-yargi-gudimalad wawanmakmar, 
\q2 ar ade, Bab-Jehová-danikid-e-iba mosad, 
\q2 ar bato nue-warmaksad. 
\q1  
\v 2 A-ibagi, negasichid nagunonikoed, 
\q2 neg gudure sigoed. 
\q1 Mogirmar-gudureged nagunonikoed, 
\q2 neg daas sigoed. 
\ms1 2. BAB-JEHOVÁ-E-IBA-DANIKIDGI GANNAR SUNMAKLENAID 
\mr (2:2b-11) 
\q1 Igi neg-oibodanikile, bela yarmargi neg-mee imakdanidae, 
\q2 deyobi, dule-bukidar dule-bulegana danimaloed. 
\q1 Epenne we-dulemaryobid dulemar gwen dakledisulid, 
\q2 deginbali, yoedsega dulemar-deyobid gwen daklegosurbalid. 
\q1  
\v 3 We-dulemar sooyobi gumalad, 
\q2 bela ese ibmar gummaked. 
\q1 We-dulemar-nonikoed-iduale, soo bela ibmar-ogumaked, 
\q2 we-dulemar-nasad-sorbali, soo bela ibmar-obeloged. 
\q1 We-dulemar, amba yoo dagegua, 
\q2 we-yar-naidi, Edén-nainuyobi daklegenad. 
\q1 We-dulemar, we-yargi-nasmargua, 
\q2 e-sorbali, yar, nega-dulesulidganyob nagusad. 
\q2 E-ganguedgi ibmarmar geg wakinned. 
\q1  
\v 4 E-gangued, moliyob gangumalad. 
\q2 Dulemar-moli-birgi-abarmakmaidyob abarmakmalad. 
\q1  
\v 5 Yar-birgi ichomakdemalale, bila-onomalad-ur-napagined-gollomakedyob, oimakmalad. 
\q2 Igi-gagan-dinnagana soose-gummakdele, gormamaidae, 
\q2 deyobi gollomakmalad. 
\q1 Igi-bila-onomalad-bulegan, bila-onogega guagwar bukmala, 
\q2 deyobi gumalad. 
\b  
\q1  
\v 6 We-dulemar-asabin bela dulemar-we-napneggi-bukmalad gwakidmalad, 
\q2 bela e-niga argwatemalad. 
\q1  
\v 7 Bila-onomalad-buleganyobi urwemalad, 
\q2 bila-onomaladyobi galumar-birgi nakwe-nakwe imakmalad. 
\q1 Bela ilekwaa na e-igarba namaloed 
\q2 gwen igar-baid-baidsik-nadapi gumalosulid. 
\q1  
\v 8 Na muchub-muchub-yolenanai gumalosulid, 
\q2 na ilemakar nadapmaloed. 
\q1 Sigu-egi-milemamaid-abinni, 
\q2 amba ilekwaa nadapi gumaloed. 
\q1  
\v 9 We-dulemar neggweburgi sabsur ubononimaloed, 
\q2 galumar-matusulid-mamaid-birgi abarmakdimaloed. 
\q1 Negmargi nakwe-nakwe imaknonimaloed, 
\q2 dule-atursamaladyobi, yawagak-seniganaba dognonimaloed. 
\b  
\q1  
\v 10 We-dulemar-bila-onomalad-abin napneg wawanmakdoed, 
\q2 nibneg giglimakdoed. 
\q1 We-dulemar-abin dada, degi, nii sichii nadoed, 
\q2 bela niisgwamala bar gaosulid. 
\q1  
\v 11 Bab-Jehová, e-sordamar-idu-nadapi, 
\q2 maryob e-gaya-goled itogega imakoed. 
\q1 Bab-Jehová-e-sordamala bukidarad, 
\q2 e-igar-uksadba-ibsamaladi, gege ebisleged. 
\q1 Bab-Jehová-danikid-e-iba gwayed-dummadid, dobed-dummadid. 
\q2 ¿Doa abin-gwisguoe? 
\ms1 3. BAB-JEHOVÁ-DULE-WILEDAKED 
\mr (2:12-27) 
\s1 Isgued na be barsogmarsun 
\p  
\v 12 Bab-Jehová weyob soged: 
\q1 “Emigindi, bela-bela be-gwage-ulubgine be an-amimala, 
\q2 mas-gunsuli be gudii gumar, 
\q2 be bomar, degi, be naibi itomar.” 
\b  
\q1  
\v 13 Wile-itogedbali, mer mor-esirmakedgi be binsamar. 
\q2 Unnila gwagegi nunmaked-dummad-itonai be gumar. 
\q1 Be-Bab-Dummad-Jehová be gannar amimar, 
\q2 ar ade, Bab-Dummad, dule-nuedid, dule-wiledakedid, 
\q1 Gwae-gwae urwesulid, bela-bela emar-sabgumaid, 
\q2 sabsur-odurdakoye-sogda-inigwele, igi-barsaye sogdedaed. 
\q1  
\v 14 Abakale, Bab-Dummad binsaed gwakalile, igi-barsaye sokalile, 
\q2 deyobi, anmargi ise-nued binsaoed. 
\q1 Ibmar-gwag-ukleged, degi, vinoʼmar, 
\q2 Bab-Dummad-Jehováʼgadga guoed. 
\b  
\q1  
\v 15 Sión-yar-birgi gar-trompeta ogormalo, 
\q2 dulemar-onmakega ese gormalo, 
\q2 masgullesulid-iba nasikmalo. 
\q1  
\v 16 Bela dulemar-bukwad-onmakega imakmalo, 
\q2 bela dulemar swilidik ambikumalo. 
\q1 Sapin-dummagan bela onmakmalo, 
\q2 burwigana onmakmalo, 
\q2 goemarse-bakale, onmakmalo. 
\q1 Emisgwa-ome-nikusad e-gabedneggi nodage, 
\q2 emisgwa-sui-nikusad e-gabedneggi-maidgi nodamoga. 
\q1  
\v 17 Bab-Dummad-neg-yawagak-siid, 
\q2 degi, ibmar-ukleged-aila-siid, 
\q1 amar-imbagi, dule-irwa-Babse-gormalad Bab-Jehováʼga-arbamaladi, be bomala. 
\q2 Weyob sognanai be gumala: 
\q1 “Bab-Jehováʼye, be wile be-dulamar dake. 
\q2 Mer be-dulamar-nug-oichogega be imake, 
\q2 mer dulemar-yar-baid-baidgi-bukmalad be-dulamargi dodogega be imake. 
\q1 Ibiga dulemar-yar-baid-baidgi-bukmalad sogmaloe: 
\q2 ‘¿Ar bia e-Bab-Dummad nadsunna?’ ” 
\b  
\q1  
\v 18 Geb degine, Bab-Jehová na e-sabgued e-yarga oyosad, 
\q2 e-dulamar egi-isgussuliyobi daksad. 
\s1 Bab-Jehová e-dulamar-ese-wilenaid-abin-imaksad 
\p  
\v 19 Bab-Jehová e-dulamarga weyob sogded: 
\q1 “An bemarga ibmar-gwag ukoed, 
\q2 vinoʼmar, degi, olivo-gwallu ukbaloed. 
\q1 Bemar we-ibmarmargi immelemaloed. 
\q2 Dulemar-yar-baid-baidgi-bukmalad bemargi dodomalaga bar an imakosulid. 
\b  
\q1  
\v 20 ”Dule-dad-nakwed-argan-sapiledsik-danikid an bemargi-banguega imakoed, 
\q2 a-dule, dule-buksurmaladsik, dule-negasulidganba an balimetoed. 
\q1 E-sordamar-idu-danimalad, dad-nakwedsik-demar-naidgi, didulegega an imakoed. 
\q2 E-sordamar-sorba-danimaladdi, dad-argwanedsik-demar-naidgi, didulegega an imakoed. 
\q1 E-muimar nunguega an imakoed, 
\q2 sunnasuli-yapannega an imakoed.” 
\q1 Bab-Jehová ibmar-dummagan imakoed. 
\b  
\q1  
\v 21 An-yargi-bukmalad mer-dobgumala, 
\q2 bur weligwar itomala, wergumala. 
\q2 Ar Bab-Jehová ibmar-dummagan imakoed. 
\q1  
\v 22 Ibdula-sapurbarmalad, mer dobgumala, 
\q2 ar gaganmar aramakdagoed. 
\q1 Sapimar bela sanmakdagoed, 
\q2 sapi-higueraʼye-nugadi, degi, uva-dubmar yeer sanmakdagoed. 
\q1  
\v 23 Sión-dulemar weligwar-itomar, 
\q2 be-Bab-Dummad-Jehováʼba be wergumarsun. 
\q1 Ar be-Bab-Jehová e-iba-sogedba bega dii owioed. 
\q2 Ar igi epenneunni, ibmar-digleged-idu dii owidae, 
\q1 degi, ibmar-gwag-weleged-idu dii owidae, 
\q2 deyobi bemarga dii-wied-ibagan nasikoed. 
\q1  
\v 24 Ibmar-gwag-saboged-negmar ibmar-gwag ena sigoed. 
\q2 Ibmar-gwagmar-egured-negmar vino ena sigoed. 
\q2 Olivo-gwallu ena sigbaloed. 
\p  
\v 25 Bab-Jehová soged: 
\q1 “Ses-danagwen-gudimalad, ses-dummagan, 
\q2 ses-sapingana, ses-burwigan, 
\q1 birga-nasmaladgine bemar-ibe bela ibmar-gwag guchagusad, 
\q2 gannar bemar a-ibmarmar-nikuega an be-imakoed. 
\q1  
\v 26 Bemar obinebaka, nue-immelegedse gunmaloed, 
\q2 geb be-Bab-Dummad-Jehová-nug be odummomaloed. 
\q1 Ar ani be-Bab-Dummad-Jehová, bemarga ibmar-gegerdakleged imakoed. 
\q2 An-dulamar bar bipisaale, bingeguosurmalad. 
\q1  
\v 27 Geb degine, wisgumaloed, 
\q2 ani an Israel-dulemar-abargi gudiiye. 
\q2 Ani an e-Bab-Dummad-Jehová gued. 
\q1 Anyobid dule-baid sated. 
\q2 An-dulamar bar bipisaale, bingeguosurmalad.” 
\ms1 4. BAB-DUMMAD-E-BURBA-ISLIGWALED AIDENONIKOED 
\mr (2:28-32) 
\p  
\v 28 Bab-Jehová sogdebalid: 
\q1 “We-ibmar-gusad-sorbali, An-Burba bela-dulemargi an odenonikoed. 
\q2 Be-masmala, degi, be-bunamala, an-gayaburbagi sunmakdemaloed. 
\q1 Selebagusmalad gabdakdemaloed, 
\q2 sapingana negburgan dakdemaloed. 
\q1  
\v 29 A-ibagangi, An-Burba, mai-machergangi, mai-omegangi, an odenonibaloed. 
\q2  
\v 30 Ibmar-gegerdakleged nibneggine, napneggine, an oyogoed. 
\q1 Ablisbi neg-nagunonikoed, 
\q2 soo-dummad oyolegoed, 
\q2 degi, waa-bupurmagwichi neg gudoed.” 
\q1  
\v 31 Bab-Jehová-e-iba-dobegwar-itoleged-danikoed-idu, 
\q2 e-iba-gwayed-dummad-danikoed-idu, 
\q1 dad-ibegwar-ganaidi negasichidga gudoed, 
\q2 nii-ganaidi ablisgi-oglesayobi ginnitibi daklenonikoed. 
\q1  
\v 32 Bela dulemar e-Bab-Dummadga Bab-Jehová-imakmaladi, abonolemaloed. 
\q2 Ar igi Bab-Jehová sogsagusa, 
\q2 deyobi, Sión-yargi, Jerusalén-neggweburgi, abonoleged nikaoed. 
\q1 Bab-Jehová na dulemar-susagusadi, 
\q2 dulemar-dula-bemaloed-abargi gudii imakoed. 
\c 3  
\ms1 5. DULE-YAR-BAID-BAIDGI-BUKMALAD SABSUR-ODURDAKLEMALOED 
\mr (3:1-15) 
\p  
\v 1 Bab-Jehová weyob soged: 
\q1 “A-iba-nonikile, Judá-yarginmalad, degi, Jerusalén-dulemar, 
\q2 yar-baid-baidse-gales-selesgusmaladi, an gannar e-yarse senonikoed. 
\q1  
\v 2 Bela dulemar-yar-baid-baidgi-bukmalad an onmakoed, 
\q2 Josafat-Nebase-ambikuega an imakoed. 
\q1 Agine, an-Israel-dulamar-sabed-nukad, 
\q2 an we-dulemala sabsur-odurdakoed. 
\q1 Ar we-dulemar, an-dulamar yar-baid-baidse-oaisakiega imaksamalad, 
\q2 an-yar-naid mimismalad. 
\q1  
\v 3 We-dulemar ibmargi-wilubdakar an-dulamar-mimismalad. 
\q2 Omegan-gamba-imaked-muchub, burwigana uksamalad. 
\q1 We-dulemar na mumgumalaga, 
\q2 vino-muchub, bunamala manigi uksamalad. 
\p  
\v 4 ”Sidón-neggwebur, Tiro-neggwebur, degi, bela Filistea-yarginmalad, ¿ibiga bemar angi yolenanai? ¿Ar bemar bugedmai an-imakbimala? Ar deyob be an-imakbimalale, bemar-bugedmai-an-imakbimalad, bemargi emiskwaa aibinega an imakoed.  
\v 5 Ar bemar an-ibe or, mani atursasmalad. Deginbali, bemar an-ibmar-nuegan be-bab-dummadgan-negse be sesmarbalid.  
\v 6 E-yargi-dikasur-banguega bemar Grecia-dulemarga Judá-dulemar, degi, Jerusalén-dulemar uksamalad. 
\p  
\v 7 ”Emigindi, bemar wisgubi an abedo, bemar doa-dulemarga Israel-dulemar-uksamala, amar a-yargi-bukwadgi an onogoed. Ar igi bemar an-dulamar-imaksamala, deyobi an bemar-imakmarmogoed.  
\v 8 Judá-dulemarga be-masmala, be-bunamala, an manigi ukoed. Geb Judá-dulemar, Sabá-dulemarga ukmarmogoed. We-Sabá-dulemar dikasur yar-baidgi bukmalad.” 
\p Bab-Jehová weyob sogsad: 
\q1  
\v 9 “Dulemar-yar-baid-baidgi-bukwamaladga, be weyob sogmala: 
\q2 ‘Bila-onogega guakwaa ambikumala, 
\q1 Sordamar bila-onogega be barmide, 
\q2 Bela dule-bila-onomalad-bulegan urwega be guagwar bukumala. 
\q1  
\v 10 Napa-imumaladgi es-suigan be sobmala, 
\q2 es-doperegwadgi eswar be sobmala.’ 
\q1 Dule-gegegwad soge: 
\q2 ‘¡An dule-gandikidye!’ 
\q1  
\v 11 Dulemar-anmar-yar-dikarba-bukwamalad, gwae be dagmala, 
\q2 Josafat-Nebase be ambikudamala.” 
\b  
\q1 Bab-Jehová, be-dule-gandikmalad be odedage. 
\b  
\q1  
\v 12 “Dulemar-yar-baidgi-bukwamalad, be dagmala, 
\q2 Josafat-Nebase be dagmala. 
\q1 A-nebagine, dulemar-yar-baidgi-bukwamaladga igar-nabogega an signonikoed. 
\q2  
\v 13 Orosgi-dakleged-trigo goresale, igi es-doperegwadgi weledae, 
\q2 ayobi, an we-dulemar-imakoed. 
\q1 Uva-goresale e-nis-eguregala igi birgi gwirlege, 
\q2 ayobi, an we-dulemar-imakoed. 
\q1 Igi vino e-sigedgi engusadba dikarba aryomaidae, 
\q2 ayobi, we-dulemar-e-isgusad doggus wilub-obichad.” 
\b  
\q1  
\v 14 Neba-Decisiónʼye-nugadgine, 
\q2 dulemar-bukidara onmakdanikid. 
\q1 Neba-Decisiónʼye-nugadgine 
\q2 Bab-Jehová-e-iba warmakdanikid. 
\q1  
\v 15 Dad-ibeler-ganaid, degi, nii-ganaid bar gaosulid. 
\q2 Niisgwamar bar gaosurbalid. 
\ms1 6. JUDÁ-DULEMAR-BENDAKLENONIKOED 
\mr (3:16-21) 
\q1  
\v 16 Bab-Jehová Sión-yar-akale, achumigur-nono-wawaadyobi binnasuli gordagoed. 
\q2 Jerusalén-neggwebur-akale, mar-goleyobi binnasuli sunmakdagoed. 
\q2 Bela napneg-naid, nibneg-naid, giglimakdoed. 
\q1 Ar Bab-Jehováʼdi e-dulamarga dukued-negga gunonikoed, 
\q2 Israel-dulemarga ganguedga gunonikoed. 
\s1 Bab-Jehová e-dulamargi ise-nued-binsamaid 
\p  
\v 17 Bab-Jehová e-dulamarga sogded: 
\q1 “Geb degine, bemar wisgunonikoed, ani an be-Bab-Dummad-Jehová, 
\q2 an-yar-Sión-islidikidgi an maid. 
\q1 Jerusalén-neggwebur islidikidga gunonikoed. 
\q2 Sordamar-yar-baidginmalad gandikidba bar egi ubogosurmalad. 
\b  
\q1  
\v 18 ”A-ibagi, yarmargine, vino-osidikid aryonai gudoed, 
\q2 yar-seniganagine, moli-nunismar aryomai gudoed, 
\q2 Judá-dianmargine, diimar aryomai gudoed. 
\q1 Anse-goled-neggine, dii aryodagoed, 
\q2 we-dii, neba-Sitimʼye-nugad-ognai gudoed. 
\q1  
\v 19 Egipto-yar-naidi, sabsur-Judá-dulemar-imaksamalad-nukad, bela ibitogoed. 
\q2 Edom-yar-naidi, sabsur-Judá-dulemar-imaksamalad-nukad, nega-dulesulidganga binyoed. 
\q1 Ar wemar, Judá-yargine dulemar-gwen-ibmar-oakalossurmalad-ibe ablis eos gusmalad. 
\q2  
\v 20 Judá-yargi, degi, Jerusalén-neggweburgi, degisadegu dulemar bukwa gudoed. 
\q1  
\v 21 Dulemar-ibe-ablis-eosmalad, ¿baisur an dakoe? 
\q2 Suli, baisur geg an daked. An buged-mai imakedsegad.” 
\q1 Bab-Jehová, Sión-yargi megnonikoed.