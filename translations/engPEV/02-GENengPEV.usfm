\p
\v 7 \w Jacob|strong="H3290"\w* thought, “Maybe \w Esau|strong="H6215"\w* \w and|strong="H3967"\w* \w his|strong="H7725"\w* \w men|strong="H1980"\w* \w are|strong="H1571"\w* \w coming|strong="H1980"\w* \w to|strong="H1980"\w* attack \w my|strong="H7725"\w* camp.” \w Jacob|strong="H3290"\w* \w was|strong="H3290"\w* \w really|strong="H7725"\w* frightened \w and|strong="H3967"\w* worried. \w So|strong="H1980"\w* \w he|strong="H1980"\w* split \w up|strong="H7725"\w* \w all|strong="H7725"\w* \w the|strong="H7725"\w* \w people|strong="H1571"\w* \w that|strong="H4397"\w* \w were|strong="H3290"\w* \w with|strong="H5973"\w* \w him|strong="H7725"\w* \w into|strong="H1980"\w* 2 camps. \w And|strong="H3967"\w* \w he|strong="H1980"\w* split \w up|strong="H7725"\w* \w all|strong="H7725"\w* \w his|strong="H7725"\w* sheep \w and|strong="H3967"\w* goats, \w and|strong="H3967"\w* \w his|strong="H7725"\w* cows, \w and|strong="H3967"\w* \w his|strong="H7725"\w* bulls, \w and|strong="H3967"\w* \w his|strong="H7725"\w* camels. \w He|strong="H1980"\w* split \w up|strong="H7725"\w* \w all|strong="H7725"\w* \w those|strong="H1980"\w* animals \w into|strong="H1980"\w* 2 groups, \w and|strong="H3967"\w* \w he|strong="H1980"\w* \w put|strong="H7725"\w* \w one|strong="H1571"\w* group \w in|strong="H1980"\w* \w one|strong="H1571"\w* camp \w and|strong="H3967"\w* \w the|strong="H7725"\w* other group \w in|strong="H1980"\w* \w the|strong="H7725"\w* other camp.  
