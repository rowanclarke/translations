\id ROM stc-46ROM-Nat.sfm, Romans, Natqgu (Santa Cruz) STC, Daniel Boerger, 11/07/2007
\ide UTF-8
\h Rom
\toc3 Rom
\toc1 Nzryr-krbz Pol Mz Lr Rom
\toc2 Rom
\mt1 Nzryr-krbz Pol Mz Lr Rom
\imt1 Natq Ngr Nzaplxtqngr Mz Nzryr-krbz Pol Mz Lr Rom
\ip Aposol Pol yrbzle letz lc mz lrmakxtr mrkc mzteadau Rom, mzli kc tqmnc-ngrde mz taon kxetu Korint. \x + \xo 1:0 \xt Rom 15:26; 16:1-2\x* Mz drtwr kxnzakrlzng mz Nzryrngrkxtr, yrle mz mzlir yiz 57—58 AD mz nibr nzrmcngr mz Jiszs. Mzli lc ycpwz pipz nzayrkrpx-krde nzvzpx-krde kratq.
\ip Lr Jiu x kxtrngiulrJiu kxnzrlxngiting nzmncng Rom. Pol troklatipeleu nidr, a' xlrle nqmq krdr. Ayrkrpxpele nzryapwxtipx-krde Nrpakxmrlz mrkc Provins kcng Masedonia x Esia, x suti kz drtwrde nzvz-krde Spen mz nzryapwx-krde elr. Mz drtwrde, Rom nangi nou nzwz-mou-krde x lr Rom kxnzrlxngiting naokatrlr nide mz nzvzpx-krde. Mz nzmu-krde lcde, mrlzbz bade nzyokaetipx-zpwx-krbzle badr Nrpakxmrlz kc tqyapwxtipxle, murde nakrlz-angidrlr da kcng tqalvztr-ngrde, murde tralvztrleu lr Rom mzli kc.
\ip Mz letz lc, Pol pipx-zpwxle kxnamu leplz nztubq-krdr mz nzobqkr Gct. X kxmu nzarlapx-krde nidr. Mc Rom 1:16-17 x 3:21-25.
\iot Mrkcng Mz Letz Lc
\io1 Pol pibzle badr nike yrle mz letz lc. \ior [1:1-17]\ior*
\io1 Mz nzobqkr Gct leplz amrlx takitrde nzprtr-krdr mz Hxl. \ior [1:18—3:20]\ior*
\io1 Jiszs nide lrpzki r Gct mz nzarlapx-krde leplz. \ior [3:21-31]\ior*
\io1 Be ngr Ebraam aelwapx-ngrde kx Gct atubqtile leplz kcng tzbrti drtwrdr nide. \ior [dckrlzde 4]\ior*
\io1 Nztubq-krgu mz nzobqkr Gct okatrle nigu. \ior [5:1-11]\ior*
\io1 Leplz amrlx nzaleng alwx, a' Jiszs aovxiole alwx x nzbzngr. \ior [5:12-21]\ior*
\io1 Zmrlz ngr Gct kxmyalz trmailzleu leplz mz nzale-krdr alwx. \ior [dckrlzde 6]\ior*
\io1 Loukxtr tr-rngiscu zmatq ngr nzaprtr-krde kxnzrlxngiting mz Hxl, murde nzbzpeng badr Kraes mz nzaxvctr-krbzlr bade. \ior [7:1-13]\ior*
\io1 Zmatq ngr alwx nzotablrng badr drtwr kxmrlz mz nabz kxnzrlxngiting. \ior [7:14-25]\ior*
\io1 Mqngrkxtr wz zvz mz nabz kxnzrlxngiting x nivz lr Gct etu. \ior [dckrlzde 8]\ior*
\io1 Kxmule-esz' Gct okatrle kxnzlxngitilr Jiszs mz zmrlz ngrde kxmyalz, a' vz zvz nzatutr-kz-krde da kcng tqesalz-ngrbzle mz lr Israel. \ior [9—11]\ior*
\io1 Leplz neng Gct navz-nqblq-zvzlr natqde lcng. \ior [12—15]\ior*
\io1 Pol rpibzle kx, “Nimu la,” mz kzdung lr Rom. \ior [dckrlzde 16]\ior*
\c 1
\p 
\v 1 Ninge Pol, wztrpo mz Mevalu Jiszs, x ryrbo bamu, nimu kxnzrlxngiting mz mzteadau Rom. Gct kqlele ninge mz nzngini-krnge aposol, x mcpxle ninge mz nzryapwxtipx-krbo Nrpakxmrlz.
\v 2 Mzli kc bqnc Nrpakxmrlz lc pipx-pnzbz Gct mz profet nedeng mz nzesalz-krbzle kx sa na-atutrle kalr. X nzyrolr mz Nzryrngrkxtr.
\v 3-4 Nrpakxmrlz lc ycmnetr-ngrde Mrlxde, Kxetu rgu Jiszs Kxnzmcpx. Mz nzngini-krde leplz, nzmikapx mz nqvi lr King Devet. Kxmule-esz' nide leplz, a' Gct aelwapx-zpwx-ngrde mz zmatq ngrde kx xplr kx Jiszs ni-kzde Mrlxde kc tqtr-esz'ngr. X alele da lc mz nzatulz-krmle nide mz nzbzngr.
\v 5 Gct ka-ngrmle bange nzwzkr aposol, mz nzvz-nqblq-krde da kc tqalem Kraes bange mz zmrlz ngrde kxmyalz, murde namailzx leplz amrlx kxtrngiulrJiu mz nzbrtikr drtwrdr nide x mz nzvz-nqblq-krdr natqde. Murde sa nabatrpzle mz leplz kxkqlu nzamatq-krdr Kraes.
\p 
\v 6 X prtrpe-kzpzmu mz leplz kcng tqkqle Gct mz nzngini-krdr leplz neng Jiszs Kxnzmcpx.
\v 7 Mz nzmu-krde lcde, tqryr-ngrbo bamu, nimu amrlx kcng tzmncng Rom, tqmrlzti Gct nimu x tqkqlele nimu mz nzngini-krmu leplz kxnztr nedeng. X krka'-ngrne kx Gct Trtegu badr Kxetu rgu Jiszs Kxnzmcpx naokatrlr nimu x na-amnc-zpwxlr nimu.
\s1 Pol Suti Drtwrde Nzyapwxtipx-krbzle Nrpakxmrlz Mz Lr Rom
\p 
\v 8 Mz nzyzutrkr letz lc, napi-kaipo bamu kx awi-ngrbo mz Gct nimu amrlx, murde nrpa ngr nzbrtikr drtwrmu Jiszs Kxnzmcpx krlzpele mrkang kqlu mz nrlc tulvzo.
\v 9 Wztrpo mz Gct mz mqngrnge atwrnrngr, mz nzpipx-krnge Nrpa ngr Mrlxde. X Gct krlzle kx trmrbrtru mz drtwrnge nimu mz nzkrka'-krnge.
\v 10 Rlxti-zvzbo bade narlr-ngrmle bange nzoklati-krbo nimu.
\v 11 Murde sutitx zlwz drtwrnge nzvz-krbo bamu, murde na-amrlzx nimu mz nzokatrkr Mqngrkxtr x nzrlxngiti-krmu naxplrnepx.
\v 12 Drtwr ngr nzycmne-krbo lc kx sa naokatr-lzbqku, murde nzrlxngiti-krmu sa na-apqtrple drtwrnge x nzrlxngiti-krnge sa na-apqtrpzle drtwrmu.
\v 13 Mzlengeng x inwengeng, suti drtwrnge kx nakrlzamu kx nzwrde kqlupe aotingr drtwrnge nzvz-krbo bamu. A' vzm krlzmle mzli ka sc tqrblxtxbe. Suti drtwrnge nzvz-krbo murde naokatrpo nimu lr Rom mz nzrlxngitingr, da kc tqwaisrpe-ngrne mztea nyz kzdung kz leplz.
\v 14 Murde Gct kapxle natq kx nayapwxtipxbo Nrpakxmrlz mz leplz amrlx mz nrlc tulvzo, myapxbz kxtrngiulrJiu, kxmule-esz' nqmq krdr blepxbz o trtingr, x kxmule-esz' kxnzsiklung o kxtrnzsikluung.
\v 15 Delc tqsutitx-zlwzngr drtwrnge nzpipx-kz-krbo Nrpakxmrlz bamu, nimu lr Rom.
\s1 Zmatq Ngr Nrpakxmrlz
\p 
\v 16 Glqpx-lzbq-ngrne Nrpakxmrlz, murde angidatile me pnz drtwrnge. Nrpakxmrlz lc tqngi nou zmatq ngr Gct mz nzarlapx-krde leplz amrlx kcng tzbrti zvz drtwrdr Jiszs mz nzlxngiti-krdr Nrpa lc. Lrpzki r nzarlapxngr lc navzki leplz amrlx, abzo mz lr Jiu x kxtrngiulrJiu kc ate.
\v 17 Murde Nrpakxmrlz lc aelwapx-ngrde lrpzki kc tqyrlqbz Gct mz leplz mz nzatubqti-krbzle nidr mz nzobq-krde. Nztubqngr lc yzutr mz nzbrkr drtwr x yrkrpx mz nzbrkr drtwr. Da kc tqwai nzrpikr Nzryrngrkxtr kx, \qt “Nzlukr kxnztubqng tutr mz nzbrtikr drtwrdr Gct.”\qt* \x + \xo 1:17 \xt Habakuk 2:4\x* \f + \fr 1:17 \ft Drtwr ngrde li, murde ycmnetr-ngrde nzlungr mz nrlc ka x nzlungr kxboi Heven. Leplz neng Gct sa namnc-zpwxng mz nrlc ka mzli kznike nzlu-krdr vz-nqblq-ngrde nzbrtikr drtwrdr nide. X nzlungr kxboi Heven vzpxm mz nzabrtr-krbzlr drtwrdr mz Jiszs. Mc kz Galesia 3:11 x Hibru 10:38. \f*
\s1 Takitrde Gct Nzayrplapx-krde Leplz Kxnzaleng Alwx
\p 
\v 18 Gct kc tqmncom Heven, ngyati drtwrde leplz x ayrplapxle nidr amrlx mz alwx ngrdrng. Murde nzpxtxpx-ngrdr nzalvztrngr angidrng, a' vz zvz nzvz-nqblq-krdr nqmq ngr alwx.
\v 19 Nzalelr da lc, kxmule-esz' adcpx-lzbqbz badr mz nabzdr x da angidr opx-zpwxbz badr.
\v 20 Yzuo mzli kc Gct tqwz-ngrde nrlc, da lcng amrlx tqwz-ngrde nzaelwapx-ngrbzlr nide mz leplz, kxmule-esz' trnzmclru nide. Nakrlzlr kx nide Gct angidr kc tqwz-ngrde nrlc x rngisc zmatq kx yctx alo. Mz nzmu-krde lcde, trpnzngr me ngi noude mz nzrpi-krdr kx trnzkrlzlru nide.
\v 21 Kxmule-esz' nzkrlzlr kx nide Gct, a' nzpxtxpx-ngrdr nzangio-krdr nide x nzawi-krbzlr bade. Trnzlxngitilru da angidr, a' vz-rbr mz nzyrlq-krdr drtwrdr esz'-krdr mz nqmq kr Gct. Mz nzmu-krde lcde, drtwrdr mrbrtrpz x nzrlxngiti-rbrng.
\v 22 Kxmule-esz' nzrpilr nzyrplapxng, a' nzngqngutx-zlwzng.
\v 23 Murde nztekqtrlr nzangio-krdr Gct angidr kc tqlu alo, tqtr, x tqmyalz, mz nzangio-alzu-krdr mqngr da kxnzlz kxnzapulr ncblo, utc, animol x da kx nzngrlaneng. \x + \xo 1:23 \xt Lou Kcpwz 4:16-18; Sam 106:20\x*
\p 
\v 24 Mz nzmu-krde lcde, Gct ayrplapxle nidr mz nzrlr-krbzle badr nzmnclz-krbzlr mz zmatq ngr drtwr kxtrka kcng tqyclzm mz nabzdr. Delc tzale-etr-ngrdr da kx mya-zlwzngr drtq.
\v 25 Nztekqtrlr nzlxngiti-krdr nzalvztrngr angidr, mz nzlxngiti-alzu-krdr natq ngr nzpokiangr. Nzangiolr da kcng tqwzngr Kxrpalz, a' trnzangiolru nide kc tqtakitrde nzglqpx-zvz-krgule tqyc tqyc. Eu, angida.
\p 
\v 26 Mz nzmu-krde lcde, Gct sc tqaprcpebzle badr nzmnclz-krbzlr mz zmatq ngr drtwr kxtrka kx mya-zlwzngr drtq. Dekc olvz tztekqtrlr nzrmwimi-krdr ncblo, mz da kx vz-rbr-zlwzbz mz nzobqkr Gct, krlc nzrmwimi-alzu-krdr olvz kztedrng.
\v 27 Mz nqmq lcpwz, ncblo drtwrdr bao mz nzrmwimi-krdr olvz x pqtr alzu mz drtwrdr nzrmwimi-krdr ncblo kztedrng. Ncblo lcng nzrtrngzbzng badr ncblo mou da kx mya-zlwzngr drtq. X da kx prpxm elr nztwz-krdr nzayrplapxngr mz nrkrdrtqdr kx takitrde nzvz-rbr-zlwz-krdr lc.
\p 
\v 28 Zbz Gct sc tqaprcpebzle badr mz zmatq ngr drtwr kxtrka mz nzrtrngzti-zvz-krbzlr da kx trtakitrpleu nzalekr leplz le. Murde aoti drtwrdr kx trtakitrpedeu nzlxngiti-krdr nide.
\v 29 Nabzdr yrbulzm mz da kxtrka, da kxdrka'ngr, x da kx nzvz-rbr-zlwzng kang kqlu, mz nzngini-krdr kxnztrkibrng, kxnzrkcmnz-ngrng, x kxnzdobu-zlwzng, x kx drtwrdr trkabz mz leplz, kxnzrnibqng, kxnzota-zvzng, kxnzesabrng, kxnzabrtzlvzlr nzaetq-krdr drtq leplz, x kxnzrpikiting leplz.
\v 30 X nzpibqti-kzlr nidr. Nzpxtxpx-zlwz-ngrdr Gct. Nzxpqbrlr-ngrdr leplz. X nzglqpx-lzbqng. Suti drtwrdr nzale-krdr namrlzu r alwx kang kqlu. X trnzamatqlru trtedrng badr lxedrng.
\v 31 Nzngqngung murde trnzlxngitilru kx nzvz-rbrng. X trnzyrlqlru natqdr. Trpnzngr nivz mz nabzdr murde tryc-ngru drtwrdr leplz, a' vz zvz nzaetq-krdr drtqdr.
\v 32 Vz zvz nzale-krdr da lcng, kxmule-esz' nzkrlzpelr mz nabzdr kx Gct rpile kx leplz kxnzmulr lcng takitrde nzbztx-krpwzlr. A' da kx trka zlwz, nzabrtzlvz-kzlr kzdu-kzng leplz kcng tzrtrngz-kzpzng da lcng tqtrka.
\c 2
\s1 Gct Sa Na-ayzlu-ngrbzle Da Mz Leplz Amrlx Mz Nzvz-nqblq-krde Da Kx Nzalelr
\p 
\v 1 Doa kx rpile kx takitrde leplz nzayrplapx-katongr mz alwx ngrdrng vz-rbr! Trmrlzu nzpibqti-krm nidr mz drtwrm. Murde vz-rbrq mz nzobqkr Gct, mz nzale-kz-krm alwx lcng. \x + \xo 2:1 \xt Matiu 7:1-2\x*
\v 2 Napipx Gct kx leplz nzvz-rbrng o trtingr. X krlzku kx da kxpipxle tubq zvz.
\v 3 Bzkq rpiq kx narlapxq kalr mz nzayrplapxkr Gct nim, murde vz-rbr-kzq da kc tzwai leplz kcng tqatubqtiq.
\v 4 X bzkq obqszoq nzmyalzkr zmrlz ngr Gct, x nzaenzli-zpwx-krde. Mwx trkrlzwq kx zmrlz ngrde kxmyalz drtwr ngrde kx trayrplapxleu nim mzli ka, murde narnginyzm mzli r nzyzlu-krm drtwrm x nztekqtr-krm nqmq nr drtwrm.
\p 
\v 5 A' narm mqngi zlwz murde pxtxpx-ngrn nztekqtr-krm nqmq nr drtwrm. Mz nzmu-krde lcde, aetunepx-zlwzq nzayrplapxkr Gct nim. Mz Mzli Kxmatq kc navzm, Gct sa napipxle kxnzvz-rbrng o trtingr, mz nzvz-nqblq-krde nztubq-esz'ngr-krde. X sa na-ayrplapx-zlwzle kxnzaleng alwx mz zngya ngr drtwrde.
\v 6 Murde sa na-ayzlubz Gct mz doa kxesz' mz nzvz-nqblq-krde da kx alele mz nrlc ka. \x + \xo 2:6 \xt Sam 62:12; Nzyrplapxngr 24:12\x*
\v 7 Sa nakabzle nzlungr kxboi mz leplz kcng tzvz zvz nzale-krdr da kxtubq, mz nzaenzli-krdr nzamatqkr Gct nidr x nzprtr-krdr mz nzlungr kc tqyc zvz.
\v 8 A' sa na-ayrplapx-zlwzle mz zngya ngr drtwrde leplz kxdrka'-ngrng kcng tzpxtxpx-ngrdr natqde mz nzrpi-krbzle badr da kxtubq x da kx vz-rbr. Murde nzvz-nqblq-zvzlr me pnz drtwrdr esz'-krdr.
\v 9 Gct sa nabatrpzle nzkxpungr x nzetqkr drtq mz leplz amrlx kcng tzalelr da kxtrka. Sa na-ale-kaipzle mz lr Jiu mz nzngini-krdr leplz kcng tqmcpx-kaileng, x kxtrngiulrJiu kcng ate.
\v 10 A' sa nabatrpzle nzmrluengr kxetu x nzmnc-zpwxngr mz leplz amrlx kcng tzalelr da kxmrlz. Sa na-ale-kaipzle mz lr Jiu, x kxtrngiulrJiu kcng ate.
\v 11 Murde mz nzobqkr Gct leplz amrlx nzesz'ting, x kxmu nzayzlu-krbzle da badr tubq zvz.
\p 
\v 12 Sa na-adwatr Gct mz Hxl kxtrngiulrJiu kcng tzaleng alwx, kxmule-esz' trnzkrlzlru Loukxtr scde. X sa na-ayrplapxle lr Jiu kcng tzxpqbrlr-ngrdr Loukxtr, mz nzkrlz-zpwx-krdrle.
\v 13 Murde nztubqkr leplz mz nzobqkr Gct, trtutxtrpwzu mz nzxlr-krdr o nzkrlz-krdr Loukxtr, a' vzpxm mz nzvz-nqblq-zpwx-krdrle.
\s1 Gct Sa Na-ayzlu-ngrbzle Da Mz KxtrngiulrJiu Mz Nzvz-nqblq-krde Da Kx Nzalelr
\p 
\v 14 Krlzamu kx kzdung kxtrngiulrJiu nzvz-nqblqlr natq kc tqkabz Loukxtr, murde nzkrlzlr kx da lcng mrlz, kxmule-esz' trnzxlrlru Lou lc.
\v 15 Krlc aelwapx-ngrde kx kzdung natq mz Loukxtr ycpxpe-kaip mz nabzdr. X mz nabzdr nzkrlzlr mzli kznike nzale-ngrdr da kxmrlz o da kx vz-rbr.
\v 16 Da lcng amrlx sa naprtzng mzli kc Gct naobqtr-ngrde mz nqmq kr leplz amrlx x mz drtwrdr kcng tqyc-kapq. X sa nayrlqle Mevalu Jiszs mz nzpipx-krde kx nqmq kr leplz mrlz o trtingr. Krlc Nrpa kc tqyapwxtipxx.
\s1 Gct Sa Na-ayzlu-ngrbzle Da Mz Lr Jiu Mz Kxmu Nzvz-nqblq-krdr Loukxtr
\p 
\v 17 Nimu lr Jiu, lalztqmamu bange. Kzdung nimu nzrpilr kx nimu doa neng Gct murde krlzamu Loukxtr. X glqpx-lzbqamu kx tubqamu mz nzobq-krde.
\v 18 Krlzamu me pnz drtwr Gct x krlz-kzamu da kxmrlz x da kxtrka, murde nzalvztrpz bamu Loukxtr.
\v 19 Mz drtwrmu rpiamu kx namailzbzmu leplz kcng tzmnc-mrbrng mz Gct, mz nzalvztr-krbzmu da angidr.
\v 20 Rpi-kzamu kx krlzamu nzalvztrngr leplz kcng tzapulr doa kxnztopwzng, x krkcng trpnzngr da kx pnz drtwrdr. Murde krlzamu Loukxtr mrkc tqyclz-ngrm da amrlx kx takitrde nzalvztrngr angidr x da kx suti drtwr Gct nakrlzku.
\p 
\v 21 Alvztramu leplz, a' trvz-nqblqwamuu nzalvztr-krmu lcng. Yapwxtipxbzmu badr leplz kx bzkq nzpnang da, a' nimu ke ye tqpnaamu da.
\v 22 Rpibzmu badr kx nayrlq-angidrlr nzesalz-krdr mz nzyrlzngr, a' trvz-nqblqwamuu natqmu esz'-krmu. Pxtxpx-ngrnamu nzangio-krmu mqngr drka'ng kxnzlz, a' nimu ke ye tqatrkati-lzbqamu mz nzmale-krmu da kx pnatipxmamu mz ma ngr nzangiongr nidr.
\v 23 Glqpx-lzbq-ngrnamu nzmnclz-krbzmu mz Loukxtr, a' rnzlvzoamu Gct mz nzobqkr kxtrngiulrJiu kcng trnzrlxngitiung mz nzxpqbrlr-krmu natqde.
\v 24 X atutramu natq Gct mz Nzryrngrkxtr kc tqrpile kx, \qt “Leplz kcng trngiulrJiu nzpibqtilr Gct murde da kx nzale lr Jiu, mz nzngini-krdr leplz nedeng.”\qt* \x + \xo 2:24 \xt Asaea 52:5; Esikel 36:20-21\x*
\p 
\v 25 Nzrpakrngr ngi rkx mz nrkrdrtqmu, nimu lr Jiu, kx nimu doa neng Gct. X drtwr ngrde ycbz mz nzvz-nqblq-krmu Lou scde. A' nzmu naxpqbrlr-ngrnamu Loukxtr apuamu leplz kxnzmnc-mrbrng kcng trnzpakru.
\v 26 X leplz kcng trngiulrJiu kx trpnzngr scdr rkx ngr nzrpakrngr mz nrkrdrtqdr, nzngini-krdr doa neng Gct tuo mz nzvz-nqblq-krdr Loukxtr, da kc tqwaile mz lr Jiu.
\v 27 Nimu lr Jiu twzamu rkx ngr Gct lc. Krlzamu x rlwxamu Loukxtr. A' kzdung nimu trnzvz-nqblqlru. A' kzdung kxtrngiulrJiu nzvz-nqblq-angidrlr Loukxtr, kxmule-esz' trnztwzlru rkx ngr Gct mz nrkrdrtqdr. Mz nzmu-krde lcde, mz nzobqkr Gct nqmq lcng li, sa napibzle kx nqmq krmu vz-rbr, a' nqmq krdr tubq.
\p 
\v 28 Nznginingr doa ne Gct trtuou mz lxede x trtede nzngini-krdr lr Jiu o mz nzrpakrngr nrkrdrtqde. Murde tr-rblxu nzatrkatingr rkx lcng mz trnzrvz-nqblq-ngru Loukxtr.
\v 29 A' doa kx ngi lr Jiu angidr mrlztile x vz-nqblqle Gct mz nabzde. X rkx angidr alepxm Mqngrkxtr mz nabzde. Nzrpakrngr angidr ngi da kx trnzmcu mz nabz leplz, a' trngi-txpwzu rkx mz nrkrdrtq ncblo. Kxmule-esz' leplz trnzglqlzlru doa lc tqtwzle rkx lc mz nabzde, a' Gct sa naglqlz-zpwxle nide.
\c 3
\p 
\v 1 ?Nzmu doa trtubqu mz nzobqkr Gct mz nzngini-krde lr Jiu, myx kxmule, lr Jiu nzmyaszpxlr kxtrngiulrJiu o trtingr? ?X mrlz nzrpakrngr nidr o trtingr?
\v 2 Lr Jiu nzmyaszpxlr kxtrngiulrJiu mz da kxkqlu. X krlc kc tqmyapxbz, Gct yrlqle nidr mz nzaclve-krdr natqde kcng mz Nzryrngrkxtr, mrkc tzyrongr da kcng tqesalz-ngrbzle badr.
\v 3 Da zpwxtx kx kzdung nidr trnzyrlq-angidrlru natqdr mz nzvz-nqblq-krdr Gct. ?A' myx kxmule, drtwr ngrde kx Gct trnayrlq-angidr-kzleu natqde x trna-atutrleu da kx esalz-ngrbzle badr mz Nzryrngrkxtr?
\v 4 Bzkqtx pnz! Murde Gct sa nayrlq-angidrle natqde, kxmule-esz' leplz amrlx nztaong mz da kx nzpilr. Murde King Devet yrle kx, \qt “Tubqq mz nzrpi-krme bange kx vz-rbrx, x mz nzyrlq-krm nzayrplapxngr ninge.”\qt* \x + \xo 3:4 \xt Sam 51:4\x*
\v 5 Mwx kzdung leplz narpilr kx, “?Nzmu alwx rgrng nzaopx-angidrlr nztubqkr Gct x nztr-krde, e nike, vz-rbr mz nzayrplapx-krde nigr Gct mz zngya ngr drtwrde?”
\v 6 Bzkqtx pnz! Murde Gct natubqpwz mz nzpipx-angidr-krde nztubqkr lr nrlc o nzvz-rbr-krdr.
\v 7 A' mwx, kzdq kxdrka'ngr lc narpi-moule kx, “A' nzmu nzpokia-krnge aopx-angidrle kx Gct atutr-zvzle natqde, x batrpzle leplz nzglqpx-krdr nide, drtwr ngrde kx okatrx nide. ?A' nike tqayrplapx-ngrbele ninge?”
\v 8 A' drtwr lc vz-rbr, murde batrple bagu nzrpi-krgu kx mrlz nzale-krgu alwx, murde batrpzle mz leplz nzglqpx-krdr Gct. X kzdung leplz nzpibqtilr ninge mz nzrpi-krdr kx sc tqyapwxtipxx da lc! A' takitrde Gct nzayrplapx-krde nidr mz natq lc.
\s1 Trpnzngr Leplz Kxtubq Mz Nzobqkr Gct
\p 
\v 9 Pipeku kx lr Jiu nzmyaszpxlr kxtrngiulrJiu o trtingr. A' mz nzobqkr Gct, lr Jiu trnzmyaszpxlru kxtrngiulrJiu, murde leplz amrlx nzmnclzbzng mz zmatq ngr alwx.
\v 10 Da kc tqwai nzpikr Nzryrngrkxtr le kx,
\pm \qt “Trpnzngr leplz kxesz' kxtubq.\qt*
\v 11 \qt Trpnzngr kx yrplapx. Trpnzngr kx rtangrtile Gct.\qt*
\v 12 \qt A' nzesablqtilr Gct amrlx ngrdr, x drtwrdr esz'ti mz nzale-krdr da kxtrka. Trpnzngr leplz kxesz' kx ale da kxmrlz.\qt*
\v 13 \qt X mz nzycmne-krdr nzmailzlr leplz mz nzbatr-krbzlr nzbz-krdr esz'-krdr. Natqdr nzlvati apule nipna kr ningidoe kc tqrtq.\qt*
\v 14 \qt Natqdrng amrlx ngi dalr nzrpikitingr, nzrpibqtingr, x nzrpilzngr.\qt*
\v 15 \qt Nzoliq-zvzng mz nzrnibqngr.\qt*
\v 16 \qt X nzodang x nzaetqbzlr drtq leplz mz nzvzne-krdr.\qt*
\v 17 \qt X trnzkrlzlru nzmnc-krdr badr leplz mz nrwx.\qt*
\v 18 \qt X trnzamrluelru Gct.”\qt* \x + \xo 3:18 \xt Sam 14:1-3; 53:1-3; Kxalvztr 7:20; Sam 5:9; 140:3; 10:7; Asaea 59:7-8; Nzyrplapxngr 1:16; Sam 36:1\x*
\p 
\v 19 Krlzpeku kx nike pipx Loukxtr pibzle mz lr Jiu kcng tzmnclzbzng mz zmatq ngrde. Loukxtr pile natqdeng murde naopx kx mz nzobqkr Gct leplz amrlx nzvz-rbrng, kxmule-esz' lr Jiu o kxtrngiulrJiu, x takitrde Gct nzayrplapx-krde nidr. Dekc trpnzngr leplz kx narpile kx tubq mz nzobqkr Gct.
\v 20 Mz nzmu-krde lcde, trpnzngr leplz kx natubq mz nzobqkr Gct mz nzvz-nqblq-krde natqdeng amrlx, murde rblxbz mz leplz amrlx nzale-zvz-krdrle. Loukxtr trngiu dalr nzatubqtingr leplz mz nzobq-krde, a' ngi dalr nzaelwapxngr kx leplz kcng trnzyatrpwzung mz nzvz-nqblq-krdrle takitrde nzayrplapxngr nidr murde nzaleng alwx. \x + \xo 3:20 \xt Sam 143:2\x*
\s1 Lrpzki R Gct Mz Nzatubqti-krde Leplz Mz Nzobq-krde
\p 
\v 21 X mzli ka mz nzvz-krm Kraes, Gct aopx-zpwxbzle lrpzki rde kx natubq-ngrbz leplz mz nzobq-krde. Lrpzki lc trngiu Lou sc Mosis, a' ngi lrpzki kx Gct esalz-ngrbzle mz Lou sc Mosis x mz natq profet kcng bqnc.
\v 22 X lrpzki lc nide sele: Gct aotipe drtwrde kx leplz natubqbzng mz nzobq-krde mz nzbrtikr drtwrdr Jiszs Kxnzmcpx mz nzrkatx-krde alwx ngrdrng. Murde Jiszs atutr-zpwxpele me pnz drtwr Gct x Lou scdeng amrlx. Kxmule-esz' doa kznike, a' krlc lrpzki r leplz nztubq-krbzlr mz nzobqkr Gct. \x + \xo 3:22 \xt Galesia 2:16\x*
\v 23 Murde leplz amrlx nztaong mz alwx x trnzyatrpwzu nzvz-nqblq-krdr nqmq kxmrlz kxtr kc tqyrlqbz Gct badr.
\v 24 A' Gct naka-nrbalqbzle nzrlapxngr lc mz leplz amrlx, vzpxm mz zmrlz ngrde kxmyalz. Murde Mevalu Jiszs xpepxpele alwx ngr leplz amrlx mz nztekqtr-krde nidr mzli kc tqbz-ngrde nidr mz kros.
\v 25-26 Gct tubq-esz'ngr mzli kc x mzli ka. X nztubq-krde drtwr ngrde kx na-ayrplapxle kxnzaleng alwx, murde trpnzngr da kxtrka kx namcle. Gct aenzli-zpwxle nzvz-krm Mevalu Kraes mz nzayrplapx-krde leplz kcng pnz mz alwx ngrdrng. Murde yrlqle Mevalu mz nzngini-krde blz kx naxpepxle alwx amrlx ngr leplz amrlx kcng pnz, krkcng mzli ka x mzli kc navzm. X mz nzngini-krde blz kc, Jiszs katxde alwx ngr leplz kcng tzbrti drtwrdr mepyr ngrde mz nzbz-krde nidr, murde nakatx-kzle nzngyatikr drtwr Gct nidr. Dekc tqatubqti-ngrde nidr mz nzobqkr Gct. Gct tubq-esz'ngr murde ayrplapx-zpwxle alwx amrlx. X atubqtibzle mz nzobq-krde leplz kcng tzlxngitilr Jiszs. Delc Gct tqngi nou nztubqngr amrlx. \x + \xo 3:25-26 \xt Nou 22:8; 1 Timoti 2:6; 4:10; Livae 17:11\x*
\p 
\v 27-28 Mz nzmu-krde lcde, trpnzngr doa kx takitrde nzglqpx-lzbq-krde. Murde trpnzngr kx vz-nqblq-zvzle Loukxtr. X nztubqkr doa tuo mz nzrlxngitingr. Mz nzmu-krde lcde, nztubq-krde vztxpxpq mz nzlxngiti-krde Jiszs, a' trngiu mz nzvz-nqblq-krde Loukxtr.
\v 29-30 Nimu lr Jiu, bzkq rpiamu kx Gct lc nide Gct rmu txpwz, x trngiu Gct r krkcng trngiulrJiu. Murde Gct esz'txu kc tqaclvele leplz amrlx. X atubqtibzle lr Jiu mz nzlxngiti-krdr Jiszs x atubqti-kzpzle kxtrngiulrJiu mz nzrlxngitingr kcpwz. \x + \xo 3:29-30 \xt Galesia 3:20\x*
\v 31 A' mwx kzdung leplz napilr kx nzatubqtikr Gct leplz mz nzrlxngiti-krdr ayrkrpxle Loukxtr. A' bzkqtx pnz! Murde pipxle da kcpwz tqpipx Mosis mz Lou lc.
\c 4
\s1 Nztubqkr Ebraam Mz Nzobqkr Gct // Tuo Mz Nzbrtikr Drtwrde Gct
\p 
\v 1 Mrlz. Na-aoti drtwrgu Ebraam, kc tqngi melrmqgr, nigr lr Jiu. ?Nike rmctile mz nztubqkr doa mz nzobqkr Gct?
\v 2 Nzmu Gct na-atubqtile nide mz da kx aleleng, tr-rblxu nzglqpx-lzbq-krde. A' mz nzobqkr Gct trpnzngr da kx takitrde nzglqpx-lzbq-krde.
\v 3 Murde Nzryrngrkxtr rpile kx, \qt “Ebraam tubq mz nzobqkr Gct, murde brti drtwrde nide.”\qt* \x + \xo 4:3 \xt Nou 15:6; Galesia 3:6; Hibru 11:8-12; Jemes 2:23\x*
\p 
\v 4 Trau kc tztwz leplz mz nzwz-krdr trngiu da kx nzrka-nrbalqngr, murde nzmabztilr trau lc.
\v 5 A' rblxbz mz leplz nzrwztingr nztubqngr lc. Murde ka-nrbalqbz Gct nztubqngr lc mz doa kx brti drtwrde nide kc tqatubqtile kxdrka'-ngrng.
\v 6 Devet pi-kzle da lc mzli kc tqycmnepx-ngrde nzabrtz-zlwzkr ncblo kc tqtubq mz nzobqkr Gct kxmule-esz' trwztileu.
\v 7 Murde rpile kx, \qt “Doa kx nzipq mz alwx ngrde, drtwrde elalz-zlwzm.\qt*
\v 8 \qt Murde mz nzobqkr Yawe trvz-rbrpeu.”\qt* \x + \xo 4:8 \xt Sam 32:1-2\x*
\s1 Ebraam Tubq Mz Nzobqkr Gct Mzli Kc Trtwzka-ngrde Rkx Ngr Gct
\p 
\v 9 Mrlz. ?Myx kxmule, zmrlz ngr Gct lc vzbz mz lr Jiu txpwz, mz nzrpakr-krdr mz rkx ngr Gct? Trtingr! A' vz-kzpz mz kxtrngiulrJiu kcng trnzrtwzu rkx lc. Krlzpeku mrkc tqrpile mz Nzryrngrkxtr kx, \qt “Ebraam tubq mz nzobqkr Gct, murde brti drtwrde nide.”\qt* \x + \xo 4:9 \xt Nou 15:6; Rom 4:3\x*
\v 10 ?Myx kxmule, Ebraam tubq mz nzobqkr Gct mzli kc trnzpakrka-ngrde mz rkx ngr Gct o mz nibrdepe? Mzli kc trnzpakrka-ngrde!
\v 11 Murde mz nibrde Gct kabzle natq mz Ebraam kx napakr \x + \xo 4:11 \xt Nou 17:9-14\x* mz nzngini-krde rkx ngr nzlxngiti-krde nzesalzkr Gct x nztubq-krde mz nzobq-krde. Mzli lc trnzpakrka-ngrde, Ebraam trngiulrJiu, a' tubq mz nzobqkr Gct. Mz nzmu-krde lcde, Ebraam apule trte leplz amrlx kcng tzbrti drtwrdr Gct, kxmule-esz' trnzpakrung, murde navz-nqblqlr nide mz nzbrti drtwrdr Gct. Delc nztubq-krdr mz nzobqkr Gct vzpxm mz nzbrtikr drtwrdr nide.
\v 12 X Ebraam ni-kzde trte lr Jiu kcng tzpakrng, mzli kznike nzvz-nqblq-ngrdr nide mz nzbrkr drtwr kcpwz tqvz-nqblqle mzli kc trnzpakrka-ngrde.
\s1 Nzrtwzngr Da Kcng Tqesalz-ngrbz Gct Vzpxm Mz Nzrlxngitingr Natqde \f + \fr 4:13 \ft Gct esalz-ngrbzle mz Ebraam da tq mz Buk Ngr Nou. 1) Ebraam nanginede dq doa ncblo x nqvi lrde sa navz zvz. Da lc ngida mzli kc tzmcngr mz Aesak, x nqvi lrde dekc tqngi neidu lrdr lr Israel, x mz nibrde lr Jiu. 2) Doa kx nzvzpxmqng bade nakqlu-zlwzng x narblx nzrlwxngr. X nanginide trte leplz kxkqlu mz nrlc tulvzo. Da lc ngida murde kxnzrlxngiting amrlx nidr doa nedeng. 3) Sa nakabz Gct nrlc atwrnrngr bade x doa nedeng. Sa na-atutrle da lc mzli kc nayzlu-ngrm Jiszs mz nzaclve-krde kxnzrlxngiting amrlx mz nrlc kxmrna. Mzli lc kxtrnzrlxngitiung amrlx sa namncng mz Hxl. \f*
\p 
\v 13-15 Esalz-ngrbz Gct mz Ebraam kx sa nakabzle nrlc atwrnrngr bade x doa nedeng mz nzrnginyz-krdrle. Nzmu Gct na-atutr-txpwzle nzesalz-krdeng mz leplz kx nzvz-nqblq-zvzlr Lou scdeng, drtwr ngrde kx mane nzbrtikr drtwrgu nide. X mane kz da kx esalz-ngrbzle murde rblx nzvz-nqblq-zvzngr Lou scdeng. A' Gct tresalz-ngrpwzleu da lc murde Ebraam vz-nqblq-zvzle Lou scdeng, a' murde nztubq-krde mz nzobq-krde vzpxm mz nzbrtikr drtwrde nide. Gct esalz-kai-ngrbzle da lc mz Ebraam, x sc tqka-atebzle Loukxtr mz Mosis. Delc rblx nztubqkr Ebraam nzvzpx-krmle mz nzvz-nqblq-krde Lou sc Mosis. \x + \xo 4:13-15 \xt Nou 12:3; 13:14-17; 15:4-5; 17:2-8, 16, 19; 22:15-18; Galesia 3:17, 29\x*
\p 
\v 16 Mz nzmu-krde lcde, Gct atutr-txpwzle nzesalz-krdeng mz leplz kx nzbrti drtwrdr kx sa nakabzleleng badr. Murde naka-nrbalqbzle mz kxnzrlxngiting nztubqngr lc. X mz nzrlxngiti-krgu, nakrlzku kx natwzku da kc tqesalz-ngrmle bagu, kxmule-esz' vz-nqblqku Lou sc Mosis o trtingr. Murde Ebraam apu-zpwxle trte leplz amrlx kcng tzlxngitilr Gct, da kc tqwaile.
\v 17 Krlc drtwr ngr Nzryrngrkxtr mz nzrpi-krde kx, \qt “Mcpxpex nim nzngini-krm trte leplz ngr nou x nqvi kxkqlu.”\qt* \x + \xo 4:17 \xt Nou 17:5\x* Da lc ngida murde mz drtwr Gct Ebraam nide melrmqgu nigu amrlx. X Gct lc rngisc zmatq ngr nzatulz-krde kxnzbzng x mz nzrwzngr da mz nzycmne-krde txpwz.
\p 
\v 18 Kxmule-esz' rblx, a' Ebraam obqtipxle mz nzrlxngitingr x nipede trte leplz ngr nou x nqvi kxkqlu, da kc tqwai nzpi-krbz Gct bade kx, \qt “Nzkqlukr doa nemqng sa na-apule vri ngr bongavz.”\qt* \x + \xo 4:18 \xt Nou 15:5\x*
\v 19 Nzbrkr drtwrde trycngrlru, kxmule-esz' krlz-zpwxle kx trtakitrpeleu nide nzngini-krde trte doa, murde yiz ngrde krlzpebzle nzpnu-rpwxmz-nrade-rpwxmz (99), x Sera nipede blang x vz-nrbalq.
\v 20 X drtwrde trlitrpwzu mz nzatutrkr Gct natqde kalr. A' nzrlxngiti-krde xplrnepx, x glqlz-zvzle Gct mz da kx esalz-ngrbzle bade.
\v 21 Murde brti zvz drtwrde kx sa na-alele da lc.
\v 22 Mz nzmu-krde lcde, \qt “Ebraam tubq mz nzobqkr Gct.”\qt* \x + \xo 4:22 \xt Nou 15:6\x*
\v 23 Natq lc tzrpibz kx, \qt “Nide tubq mz nzobqkr Gct, murde brti drtwrde nide,”\qt* trnzyrou mz nzokatr-krde Ebraam esz'-krde.
\v 24 A' nzyro kz mz nzokatr-krde nigu, murde nakrlzku kx tubqku mz nzobq-krde mz nzabrtr-krbzku drtwrgu mz Gct kc tqatulz-mople Kxetu rgu Jiszs mz nzbz-krde.
\v 25 Gct rlrpx-ngrde Jiszs nzayrplapxngr nide mz alwx ngrgung mz nzbz-krde. X atulz-mople nide mz nzbzngr murde natubqku mz nzobqkr Gct mz nzxpepxkr Jiszs alwx lcng.
\c 5
\s1 Kxnzrlxngiting Nzmnc-lxblr-moung Badr Gct Mz Nrwx
\p 
\v 1 Mz nzmu-krde lcde, tqtubq-ngrgu mz nzobqkr Gct, murde lxngitiku Kxetu rgu Jiszs Kxnzmcpx x brti drtwrgu nzbz-krde mz nzarlapx-krde nigu. Mz nzmu-krde lcde, navz zvz nzmnc-lxblr-krgu badr Gct mz nrwx.
\v 2 Mz nzlxngiti-krgu Kraes, dekc tqmnc-aepztr-ngrbzku mz Gct. X okatr-zvzle nigu murde nzaxvctrpebzku mz Kraes. X abrtzlvzku nzobqtipx-krgu nzyzlu-krm Kraes, murde mzli lc sa naprtr-kzku mz nzmyalz-krde.
\v 3 X abrtzlvz-kzku nzkxpungr mz nrlc ka, murde alvztrple bagu kx natu-amqngilzbzku bade mz nzrlxngitingr.
\v 4 X nztu-amqngilz-krbzku mz nzkxpungr alvztrple bagu kx drtwrgu natubq. X nztubqkr drtwrgu alvztrple bagu kx naobqtipxku Gct mz nzangidati-krde natqde.
\v 5 X krlzku nzbrtikr drtwrgu Gct nzangidati-krde nzobqtipx-krgu, murde xngibzku nivz lrde mz nabzgu mz nzwzkr Mqngrkxtr kc tqkamle bagu.
\p 
\v 6 Na-aoti drtwrmu da lc. Rblxm bagu, nigu leplz, nzarlapx-lzbq-krgu. Kxmule-esz', a' mzli kc tqkrlzpe-ngrbzle mzli kc tqyrlq Gct, Kraes bz mz nzarlapx-krde nigu kxnzaleng alwx.
\v 7 Leplz kxpipz kx nzrlrpx-lzbq-ngrdr mz nzbz-krdr nzarlapxngr doa kzble, kxmule-esz' doa lc tqmrlz. A' mwx kzdq leplz narlrpx-lzbqngr mz nzbz-krde mz nzarlapx-krde doa kx mrlz-esz'ngr.
\v 8 A' mzli kc tqalebe-ngrgu alwx, Gct aelwapx-ngrde nzmrlzti-zlwzkr nivz lrde nigu, mz nzbzkr Kraes nigu.
\v 9 Naopx angidr kx Kraes sa na-arlapxbzle nigu mz zngya ngr drtwr Gct. Murde tubqpeku mz nzobqkr Gct mz nzbzkr Kraes nigu.
\v 10 X naopx angidr kz kx mz nztulz-mou-krmle mz nzbzngr, Kraes sa na-arlapxbzle nigu mz nzayrplapxkr Gct nigu kalr. Murde Gct amnc-lxblrtrpele nigu badr mz nrwx mz nzbzkr Mrlxde mzli kc tqnginibe-ngrgu enqmi rdeng.
\v 11 X mou, mzli ka abrtzlvz-zvzku Gct mz nzmnc-lxblr-krgu badr mz nrwx, mz nzwzkr Kxetu rgu Jiszs Kxnzmcpx.
\s1 Adzm Twzmle Nzbzngr, A' Kraes Twzmle Nzlungr
\p 
\v 12 Mzli kc Adzm tqtao-ngrde mz alwx, alwx lc nzaxvctr-kzpz mz nqvi lrde. X alwx lc twz-kzple nzbzngr. X nzbzngr lc prtzbz mz leplz amrlx murde nztao-kzng mz alwx mz nzngini-krdr nqvi lr Adzm. \x + \xo 5:12 \xt Nou 2:17\x*
\v 13 Nzvz-rbr-krdr lcng ngi alwx, kxmule-esz' Gct tr-rkakapz Loukxtr. A' rblx nzrpingr kx leplz nzaleng alwx mzli kc trgalr lou kx na-alvztr-ngrde nidr mz alwx.
\v 14 Kxmule-esz', a' opx angidr kx nzaleng alwx murde nzbzng. Abzo mz mzli nyz Adzm krlzmle mzli nyz Mosis, leplz amrlx nztaong mz alwx x nzbzng, kxmule-esz' trnzxpqbrlr-ngrdru natq angidr lc tqkabz Gct, da kc tqwai Adzm.
\p Mrlz nzkrlz-krgu kx Adzm ngi rkx kc tqplzpx-kaile Kraes kc navzm, mz nzbatr-krbzlr da mz leplz kxkqlu.
\v 15 A' alwx ngr Adzm blepx-zlwzbz mz nzipqkr Gct leplz. Murde Adzm batrpzle nzbzkr leplz kxkqlu mz alwx ngrde. A' Jiszs Kxnzmcpx batrpzle nzipqngr leplz kxkqlu mz zmrlz ngr Gct kc tqka-nrbalqbzle badr.
\v 16 Mz nqmq lcpwz, alwx ngr Adzm batrpzle nzayrplapxngr leplz kxkqlu mz nzbzngr. A' da kc tqka-nrbalqbz Gct batrpzle nzrkapxngr alwx ngr leplz kxkqlu x atubqtile nidr mz nzobq-krde.
\v 17 Da zpwx kx alwx ngr Adzm amnclzbzle leplz mz zmatq ngr nzbzngr. A' nzwzkr Jiszs Kxnzmcpx myaszpx-zlwzle da lc. Murde leplz amrlx sa na-aovxio-zpwxlr zmatq ngr alwx x nzbzngr mz nzprtr-krdr mz nztubqngr kc tqka-nrbalqbz Gct badr.
\p 
\v 18 Mz nzmu-krde lcde, alwx kc esz' tqale Adzm drtwr ngrde kx takitrde Gct nzayrplapx-krde leplz amrlx. Mz nqmq lcpwz, da kc esz' tqale Kraes mz nzvz-nqblq-krde me pnz drtwr Gct mz nzbzngr, drtwr ngrde kx leplz amrlx kcng tzrlxngiting nzkrlzlr nzprtr-krdr mz nztubq-krde x mz nzlungr kxboi.
\v 19 Leplz kxnzkqlu nzaleng alwx, murde Adzm trvz-nqblqleu natq Gct. X mz nqmq lcpwz, leplz kxnzkqlung sa natubqng mz nzobqkr Gct murde Jiszs vz-nqblq-zvzle natqde. \fig Adzm trvz-nqblqleu natq Gct.|alt="100 Adam eating fruit" src="100-Gen3.1.tif" size="COL" loc="ROM 5:19" copy="LLL Language Recording" ref="5:19"\fig*
\v 20 Gct kao-ngrmle Loukxtr murde leplz nakrlz-zpwxlr kx nzvz-rbr-zvzng. A' mz nzetunepxkr nzmc-krgu kx alwx ngrgung trka zlwz, zmrlz ngr Gct kc tqmyalz sc tqetunepx kz, mz nzipq-krde nigu leplz.
\v 21 Mz nzmu-krde lcde, mzli kc leplz amrlx nzmnclz-ngrbzlr mz zmatq ngr alwx x nzbzngr. A' mzli ka mz nzvz-krm Kraes, mnclzpebzku mz zmatq ngr nzokatrkr Gct nigu, x tubqku mz nzobq-krde. Delc sa naprtrku mz nzlungr kxboi, murde nzwzkr Kxetu rgu Jiszs Kxnzmcpx.
\c 6
\s1 Kxnzrlxngiting Trnzmnclzpepwzung Mz Zmatq Ngr Alwx, A' Nzmnclzbzng Mz Gct
\p 
\v 1 Mwx kzdq doa napile kx mrlz nzale-zvz-krgu alwx, murde nabatrpzle nzetunepx-zvzkr zmrlz ngr Gct kc tqmyalz.
\v 2 Bzkqtx pnz! Murde mz nzobqkr Gct bzpeku badr Kraes x trmnclzpekuu mz zmatq ngr alwx. Doa kx bzpe rblxbz bade nztao-krde mz nzatalzngr. X mz nqmq lcpwz, mz nzmnc-krgu mzli ka, na-apusr-lzbqku kx nrkrdrtqgu bzpe, murde bzkq vz-nqblqpeku alwx x trpengr nzmetx-krbzku bade.
\v 3 Nadcpx mz drtwrmu kx nzaxvctrpebzku mz Mevalu Jiszs mz nzwrkxtr-krgu, x mz nzobqkr Gct bzpeku badr mz kros.
\v 4 Bzpeku badr x nzyrtzmqpe-kzku badr mz nzwrkxtr-krgu, murde natwz-kzku nzlungr kxmrna kxtr, da kc tqwai Kraes mzli kc tqatulz-ngr-mop Gct Trtegu nide mz nzbzngr, mz zmatq ngrde kx myalz-esz'ngr.
\p 
\v 5 X mz nzaxvctr-krbzku bade mz nzbzngr mzli ka, sa na-axvctr-zpwx-kzpzku bade Heven, mzli kc na-atulz-kzngr Gct nigu mz nzbzngr, da kc tqwaisrpe-ngrde Kraes.
\v 6 Murde krlzpeku kx nqmq ngr alwx kx vzo la mz nabzgu nztqlvzmitrpe Kraes mz nzodatitxpx-krbz Gct zmatq ngr alwx nzaclve-krde nigu. Delc mzli ka trmnclzpepwzkuu mz zmatq ngr alwx.
\v 7 Murde leplz kznike bzpe, drtqde opxpe mz nzvz-nqblq-krde kc ena zmatq ngr alwx.
\v 8 X mz nzbzpe-krgu lc badr Kraes, lxngitiku kx sa nalu-kzku badr.
\v 9 Krlzku kx mz nztulz-krm Kraes mz nzbzngr, trpengr nzbz-mou-krde, murde trmnclzpepwzu mz zmatq ngr nzbzngr.
\v 10 Mzli kc tqbz-ngrde, nzbz-krde nzwrde esz'txu, a' nzaovxio-krde zmatq ngr alwx lc tqyc tqyc. X mzli ka mz nzlupe-krde lc, mnclz-zvzpebz mz Gct.
\v 11 Mz nzmu-krde lcde, nalxngitiamu kx nimu leplz kxnzbzpeng, kcng rblxbz badr nzmetx-mou-krbzlr mz alwx. X nalxngiti-kzamu kx Mevalu Jiszs mncpxpem bamu mz nzokatr-krde nimu mz nzvz-nqblq-zpwx-krmu nqmq krde mz nzwztr-krbzmu mz Gct.
\p 
\v 12 A' bzkq rlr-lzbqpe-ngrbzmu mz nzmnclz-krbzmu mz zmatq ngr alwx, murde ma tqvz-nqblqamu. \f + \fr 6:12 \ft Drtwr ngrde kx nigu kxnzrlxngiting, rngiscgu zmatq ngr nzvz-nqblq-krgu Gct x nzesablqti-krgu nqmq ngr alwx. \f*
\m 
\v 13 Bzkq pnz rlr-ngrbzmu kzdq nrlc mz nrkrdrtqmu mz alwx, nangi dalr nzalengr da kxtrka. A' rlr-lzbq-ngrbzmu mz Gct, murde kapebzle bamu nzlungr kxmrna. X rlr-lzbq-ngrbzmu bade mz nrkrdrtqmu atwrnrngr, nangi dalr nzalengr da kxtubq.
\v 14 Murde kxmule-esz' trmnclzpepwzmuu mz zmatq ngr Lou mz nzpipx-krde kx vz-rbramu, a' suti drtwr Gct kx bzkq taoamu mz alwx. A' namnc-nqblqamu nide murde twzpeamu zmrlz ngrde kxmyalz mz nzokatr-krde nimu mz nzvz-nqblq-krmu me pnz drtwrde.
\s1 Nawztrpzku Mz Gct
\p 
\v 15 Mrlz. A' mwx kzdq doa napi-moule kx mrlz nzale-krgu alwx murde trmnclzpepwzkuu mz zmatq ngr Lou mz nzayrplapx-krde nigu, a' mnclzbzku mz zmatq ngr Gct mz nzokatr-krde nigu. A' bzkqtx pnz!
\v 16 Murde nakrlzamu kx mzli kc tqrlr-lzbq-ngrbzmu mz kzdq ncblo mz nzwztr-krbzmu bade, drtwr ngrde kx nide kxetu rmu x mnclzbzmu mz zmatq ngrde. Namcpx-zpwxamu da kx nangi kxetu rmu. Nangi alwx o me pnz drtwr Gct. Nzmu namcpxamu alwx, me natutr-ngrde nzbz-alongr. A' nzmu namcpxamu me pnz drtwr Gct, me natutr-ngrde nztubq-krmu mz nzobq-krde.
\v 17 Mzli kc ena wztrpzmu mz alwx mz nzmnclz-krbzmu mz zmatq ngrde. A' awi-ngrbo mz Gct kx mzli ka mcpxpeamu mz nabzmu atwrnrngr mz nzmnclz-krbzmu me pnz drtwrde x da kcng tzalvztr-ngrmu mzli kc kai tqlxngiti-ngrnamu Jiszs.
\v 18 Mz nzlungr kxmrna lc, Gct aopxpebzle drtqmu mz zmatq ngr alwx, x mzli ka mcpxpeamu nzmnclz-krbzmu mz zmatq ngrde mz nzale-krmu da kxtubq.
\v 19 Krkc tqkxmu nzycmne-dalitipx-krbo da lc bamu, murde narmu nayrplatrpz mz nzrlxngiti-krmu kc tqpobe. Mzli kc ena rlr-ngrbzmu nrkrdrtqmu atwrnrngr mz zmatq ngr da kx trtakitrdeu x da kxdrka'ngr, mz nzale-zvz-krmu da kxtrka zlwz. A' mzli ka na-aotipe drtwrmu mz nzrlr-krbzmu nrkrdrtqmu mz Gct mz nzmncngr kxtubq, murde nztrkr nzmnc-krmu naetunepx zvz.
\p 
\v 20 Mzli kc ena tqmnclz-ngrbepzmu mz zmatq ngr alwx, traotiu drtwrmu nzale-krmu da kxtubq.
\v 21 ?X nike mabztiamu mz nzmncngr lc tqmyapengr drtqmu? Murde trpnzngr da kxmrlz kx vzpxm elr. A' natutr-ngrde mz nzbz-alongr.
\v 22 A' mzli ka drtqmu opxpe mz zmatq ngr alwx, x mnclzpebzmu mz zmatq ngr Gct. X natutr-ngrde mz nzmncngr kxtr x nzlungr kxboi.
\v 23 Nzrmabztitrngr alwx, natutr-ngrde mz nzbzngr. A' Gct ka-nrbalqbzle nzlungr kxboi mz leplz kcng tzaxvctrpzng mz Kxetu rgu Mevalu Jiszs.
\c 7
\s1 Kxnzrlxngiting Trnzmnclzpepwzung Mz Zmatq Ngr Lou Sc Mosis
\p 
\v 1 Mzlengeng x inwengeng, ryrbo bamu mz nzngini-krmu leplz kcng tzkrlz-angidrlr Lou sc Gct. A' nadcpx mz drtwrmu kx doa mnclzbz mz zmatq ngr Lou mzli kc tqlu-ngrde.
\v 2 Na-aoti drtwrmu nzyrlzngr. Murde olvz kxyrlz namncbz mz ncblo ngrde mzli kc tqlungr ncblo ngrde. A' nzmu ncblo ngrde nabzle, olvz lc trmnclzpepwzu mz lou ngr nzyrlzngr.
\v 3 X trxpqbrlr-ngrdeu lou ngr nzyrlzngr mz nzyrlzti-mou-krde ncblo kzble. A' nzmu nayrlzti-moule dq ncblo kzble mzli kc tqlubengr ncblo ngrde kc kai, olvz lc xpqbrlr-ngrde lou ngr nzyrlzngr.
\v 4 Mz nqmq lcpwz, kx mzlengeng x inwengeng, bzpeamu badr Kraes mz nzaxvctr-krbzmu bade, x trmnclzpepwzmuu mz zmatq ngr Loukxtr. Mzli ka nepede nimu Kraes kc tqatulz-mop Gct mz nzbzngr, murde nrade naycbz mz nzwztr-krbzmu mz Gct. \f + \fr 7:4 \ft Nigu kxnzrlxngiting trmnclzpepwzkuu mz zmatq ngr Loukxtr mz da lcde seng tq: 1) Rblxbz mz Loukxtr nzatalz-krde nigu, murde trmnclzpepwzkuu mz zmatq ngr alwx. 2) Rblxbz mz Loukxtr nzbatr-krmle nzxngi-krbzku nzmnc-rlru-krm Gct, murde krlzku kx Gct ipqpele nigu mz nzplzpx-krgu alwx ngrgung. 3) Rblxbz mz Loukxtr nzyrlq-krmle nzayrplapx-krdeng bagu, murde Gct yrlqlzpebzle nzayrplapxngr amrlx mz Kraes. \f*
\m 
\v 5 Mzli kc tqvz-nqblqbe-ngrgu drtwrgu esz'-krgu mz nzale-krgu alwx, nzkrlz-krgu Loukxtr aetunepx zvz nzatalzngr. X nzwz-krgung amrlx tutr mz da kxdrka'ngr x yrkrpx mz nzbzngr.
\v 6 Mzli lcde, mnclzbzku mz lou kx nzyrong. A' mzli ka drtqgu opxpe mz nzmnclz-krbzku mz zmatq ngr Loukxtr, murde bzpeku badr Kraes. X krlzku nzwztr-krbzku mz Gct mz nzvz-nqblq-krgu Mqngrkxtr, kc tqmncpxm mz nabzgu x okatrle nigu mz nzlungr kxmrna.
\s1 Loukxtr Aelwapx-zpwx-ngrde Alwx
\p 
\v 7 Bzkq rpiamu kx natqnge lc drtwr ngrde kx Loukxtr ngi da kxdrka'ngr. Bzkqtx pnz! Murde rblxm bagi nzmc-krgi kx aleki alwx, nzmu Loukxtr trna-aelwapx-ngrpleu bagi kx vz-rbrki. Nzmu lou trnarpileu kx, \qt “Bzkq kcmnz-ngrbzme dztu leplz kc-kzng,”\qt* nzmu trkrlzkiu kx nzrkcmnzngr ngi alwx. \x + \xo 7:7 \xt Nzrlaszngr 20:17; Lou Kcpwz 5:21\x*
\v 8 A' mz nzxlr-krgi natq lc tqkapx Gct, zmatq ngr alwx atalz-ngrde nigi nzrkcmnznr-krgi da kxkqlu. A' rblx nzrpingr kx leplz nzaleng alwx mzli kc trpnzngr lou mz nzpi-krbzle badr da kx ngi alwx. \x + \xo 7:8 \xt Rom 5:13, 20\x*
\v 9 Mzli kc ena trkrlzkiu da kx alvztrngr Loukxtr mz alwx. A' mzli kc tqmcpe-ngrgi natq lc tqkapx Gct mz nzrkcmnzngr, sc tqkrlz-ateki kx aleki alwx x mnc-rlrubzki mz Gct.
\v 10-11 Mzli lcde, mz nztwz-kai-krgi natq kcng tqkapx Gct, zmatq ngr alwx mz nabzgi esabrtile nigi. X rpimle bagi kx sa nalu-aloki mz nzvz-nqblq-zvz-krgi natq lcng. A' zmatq ngrde xplr x atalzle nigi, x sc tqtaopeki mz alwx. A' mz nibrde, sc tqkrlz-ateki kx natq kcng tqkapx Gct trngiu lrpzki r nzlungr kxboi, murde nzaelwapx-ngrmlr bagi kx takitrde nzayrplapxngr nigi mz nzamnc-rlru-ngrbz nigi mz Gct, mz nzbz-alongr.
\p 
\v 12-13 ?Nike, drtwr ngrde kx natq Gct batrple nzmnc-rlru-krbzki bade? Bzkqtx pnz! Na-aoti drtwrgi dxlrbi. Kzdung mzli mz nzobq-krgi otxpx. A' mzli kc tqayabeti-ngrgile mz dapunc, aelwapx-ngrde kx lue lc ngangrtx zlwz. Trngiu dapunc kc tqblqki, a' lue esz'-krde. Natq kc tqkapx Gct apule dapunc lc mz nzaelwapx-krde alwx kc tqyc-kapq mz nabzgi mzli kc zmatq ngr alwx lc tqatao-ngrde nigi mz alwx. Trngiu natq Gct kc tqtrka, a' alwx kcng tqtrka zlwz mz nzobq-krde. Delc Lou sc Gct tr x natq amrlx kcng tqkapx Gct nztrng, nztubqng, x nzmrlzvxing.
\s1 Nike Kxnzrlxngiting Tztao-ngrdr Mou Mz Alwx
\p 
\v 14 Kxmule-esz' krlzki kx Lou sc Gct mrlz murde vzpxm mz Mqngrde, a' mzli ka mncbeki mz nrkrdrtqgi, mnclzbepzki mz lrpzki kc pnz tqikztiki mz nzale-zvz-krgi alwx. Murde nrkrdrtqgi x nargi tr-rblxpwzu badr nztwz-ani-mou-krdr alwx lcng tqale-zvzki mzli kc.
\v 15 X mzli kang kqlu aleki da, a' trkrlzkiu nike tqaletiking. Mz drtwrgi mrlzm bagi nzalengr da kxmrlz, a' ale-alzuki alwx kc tqpxtxpx-ngrgi.
\v 16 Glxki kx aleki alwx. X drtwrgi kc tqxpepxpe Jiszs esz'ti mz nike pi Lou sc Gct kx krlc alwx. Da lc aelwapx-ngrde kx lxngitiki nzmrlzkr Loukxtr.
\p 
\v 17 Mz nzmu-krde lcde, nzale-krgi alwx trvzpxpuu mz nike pnz drtwrgi mz nigi esz'-krgi, a' vzpxm mz nzvz-nqblqbe-krgi lrpzki kc pnz tqikztiki mz nzale-zvz-krgi alwx mzli kc.
\v 18 X drtwrgi esz'timi drtwr Gct kx alwx lcng nzvzpxmqng mz lrpzki lc tqikzti-pnzki ngi da kxdrka'ngr. Murde suti zlwz drtwrgi nzale-krgi da kxtubq, a' rblxm bagi nzale-krgileng mz nzxplr-krgi esz'-krgi.
\v 19 Mzli kc nasutingr drtwrgi nzalengr da kxmrlz, trale-zvzkiung. Murde kxmule-esz' suti drtwrgi nztu-amqngi-krgi, a' kzdung mzli sc tqtaobeki mz nzatalzngr.
\v 20 Mz nzmu-krde lcde, nou alwx ngrgi lcng tqpxtxpx-ngrgi trngiu drtwrgi kc tqxpepxpe Jiszs, a' nzvzpxbepqng mz lrpzki lc tqikzti-pnzki.
\p 
\v 21 Mzli ka krlzpeki nqmq lc. Mzli lcpwz tqsutingr drtwrgi nzalengr da kxmrlz, lrpzki kc pnz tqikztiki mz nzale-zvz-krgi alwx apumle bagi zmyo rgi kx vz-nqblq-zvzle nigi drlve ke vzkiki. X rpile na-ataole nigi mz alwx.
\v 22 Kxmule-esz', a' yclzm mz nabzgi, abrtzlvzki Loukxtr.
\v 23 X mzli lcpwz krlz-kzki kx nqmq kxdrka'ngr wzbep mz nrkrdrtqgi x nargi mz nzatrkati-krde da kxmrlz kx suti drtwrgi na-aleki. X krlz-kzki kx mnclzbepzki mz nqmq ngr alwx mz lrpzki lc tqikzti-pnzki.
\v 24 Delc tqtrka-zlwzpe-ngrgi! ?Rkrlz dq kx na-arlapxle nigi mz zmatq lc tqtrka tqvzmile nigi mz nzbzngr?
\v 25 Eu! X awi-ngrbzki mz Gct kx Kxetu rgi Jiszs Kxnzmcpx sc tqarlapxpele nigi murde nakrlzki nzesablqti-krgi nqmq ngr alwx lc tqycbep mz nrkrdrtqgi x nargi!
\p Mz nzmu-krde lcde, mzli kcpwz tqmnclz-ngrbzki mz Gct mz nabzgi x drtwrgi, mnclz-kzpzki mz lrpzki r alwx kc tqikzti-pnzki.
\c 8
\s1 Doa Neng Gct Nzvz-nqblqlr Mqngrkxtr
\p 
\v 1 Mz da kcng amrlx tqpipebo, nakrlzamu kx mzli ka trpengr nztwz-krgu nzayrplapxkr Gct nigu mz nzvz-rbr-krgung, murde sc tzaxvctrpebzku mz Mevalu Jiszs.
\v 2 X mz nzaxvctrpe-krbzku bade, zmatq ngr Mqngrkxtr alule mqngrgu x arlapxle nigu murde trmnclzpepwzkuu mz zmatq ngr alwx x nzbzngr.
\v 3 Murde trpnzngr scgu zmatq ngr nzarlapx-lzbq-krgu mz nzvz-nqblq-zvz-krgu Loukxtr, murde mzli kc mnclzbzku mz zmatq ngr alwx. Mz nzmu-krde lcde, Gct esz'-krde sc tqarlapxpele nigu, mz nzatwzlr-krmle Mrlxde angidr mz nzngini-krde leplz da kc tqwaiku. Murde nangi blz kx takitrde nzxpepxngr alwx ngrgu, nigu leplz. Dekc Gct tqarlapx-ngrde nigu leplz murde trmnclzpepwzkuu mz zmatq ngr alwx.
\v 4 Arlapxpele nigu murde ma tqvz-nqblqbeku nqmq ngr alwx lc, a' navz-nqblq-alzuku Mqngrkxtr kc tqokatrle nigu mz nzvz-nqblq-krgu natq Gct mz nzmncngr kxtubq.
\p 
\v 5 Kxtrnzrlxngitiung kcng tzvz-nqblqlr nqmq ngr alwx kc tqycpxm mz nabzdr, nzaoti zvz drtwrdr nzalengr alwx lcng. A' kxnzrlxngiting kcng tzvz-nqblqlr Mqngrkxtr, nzvqti drtqdr da kx na-abrtzlvz-ngrde nidr.
\v 6 Nzmu nzaokr drtwr leplz nayclzbzlr mz nqmq ngr alwx, sa navz-nqblqlr lrpzki kc tqtutr mz nzbz-alongr. A' nzmu nzaokr drtwr leplz navz-nqblq-zvzlr me pnz drtwr Mqngrkxtr, sa narmctilr nzlungr kxboi x namncng badr Gct mz nrwx.
\v 7 X leplz kcng nzao-krdr drtwrdr tqyctrpz mz nqmq ngr alwx, nidr enqmi r Gct, murde nzpxtxpx-ngrdr nzvz-nqblq-krdr Loukxtr, x mou rblx-zlwzbz badr nzale-krdrle.
\v 8 X leplz lcng tzmnclzbzng mz zmatq ngr alwx, rblx-kzpz badr nzabrtzlvzkr Gct nidr.
\p 
\v 9 A' nzao-krmu drtwrmu tryctrpepwzu mz zmatq ngr alwx, murde Mqngrkxtr mncpxm mz nabzmu, x mnclzbzmu bade. A' krkcng nabzdr trmncpx-ngrpqu Mqngrkxtr kc tqkabz Kraes, trnginidru leplz nedeng.
\v 10 A' nimu, leplz nedeng. Murde kxmule-esz' nrkrdrtqmu nabzng kalr murde alwx ngrmung, a' mqngrmu nzlupeng x nztubqpeng mz nzobqkr Gct murde Kraes mncpxm bamu mz Mqngrkxtr.
\v 11 A' Gct kc tqatulzmle Jiszs mz nzbzngr, mz nqmq lcpwz sa na-alu-mople nrkrdrtqmu mz zmatq ngr Mqngrkxtr kc tqkabzle mz nzmncpx-krmle bamu.
\p 
\v 12 Mzlengeng x inwengeng, da kxmrlzting kcng tzvzpxmqng mz Mqngrkxtr drtwr ngrde kx navz zvz nzvz-nqblq-krgu da kx pimle bagu. X trpnzngr da kx batrple bagu nzvz-nqblq-krgu lrpzki kc pnz tqikztiku mz nzale-zvz-krgu alwx.
\v 13 Murde krkc tqvz-nqblq-zvzle lrpzki lc, sa nabz alo. A' mz nzrlr-krbzmu zmatq ngr Mqngrkxtr nzokatr-krde nimu, krlzamu nzesablqti-krmu lrpzki lc tqmrlz-zlwzbz mz nrkrdrtqmu x narmu. X mz nzale-krmu da lc, sa naprtramu mz nzlungr kxboi.
\v 14 Murde leplz amrlx kcng tzvz-nqblqlr Mqngrkxtr kc tqkabz Gct, nidr doa nedeng.
\v 15 X Mqngrkxtr kc tqkamle bagu, trapusr-ngrdeu nigu kxnzawz-nrbalqng kcng tzmwxlr-ngrdr nide mz nzayrplapx-krde nidr. A' mz nzka-krmle bagu Mqngrkxtr, nginipegu doa nedeng, x Mqngrkxtr pi-zvzmle bagu kx Gct suti zlwz drtwrde nzrpi-krbzku bade kx, “Trte.”
\p 
\v 16 X Mqngrkxtr aopx-angidrmle bagu mz mqngrgung x nabzgung kx nigu doa neng Gct.
\v 17 Delc, mz nznginipe-krgu lc doa nedeng, sa naprtrku mz dztudeng amrlx. X sa naprtr-kzku mz da amrlx kcng tqkabz Gct mz Mrlxde Kraes. Murde nzmu na-axvctrpzku bade mz nzetqkr drtqde, sa naprtr-kzpzku bade mz nzmyalz-krde.
\s1 Nzprtr-krgu Mz Nzmyalzkr Gct X Nzamatqngr Nide Heven
\p 
\v 18 Mz drtwrnge, nzetukr da amrlx kcng tqmrlz tqluli tqkqlu nakam Gct bagu Heven kalr nzmyaszpx-zlwzlr nztopwzkr nzetqkr drtqgu kxpipz mzli kxmrbcne tqmncku mz nrlc ka.
\v 19 Da amrlx kcng tqwzngr Gct nzobqtipxlr mzli kc Gct na-aelwapx-ngrde nzmrluekr leplz nedeng.
\v 20 Murde Gct yrlqlzbzle dalr nrlc atwrnrngr mz zmatq ngr zmibi x nzbzngr vzpxm mz alwx kc tqale Adzm.
\v 21 A' pnzpe kai drtwrde kx mz Mzli Kxmatq kc nayzlu-ngrm Jiszs, sa na-arlapxle doa nedeng x nakabzle badr nzmnc-zpwxngr. X mzli lcpwz, sa na-arlapx-kzle dalr nrlc atwrnrngr kcng tzyclzbzng mz zmatq ngr zmibi x nzbzngr, murde nayc-zpwx-kzng.
\p 
\v 22 Mz nzmu-krde lcde, krlzpeku kx abzo mzli kc tqalengr Adzm alwx krlzmle mzli ka, dalr nrlc amrlx sc tqvzbe nzmibi-krdr x nzbz-krdr. X nzetqkr drtqdr apule zvetq ngr drtq olvz kx narmika.
\v 23 A' nigu kz, apuku olvz lc, kxmule-esz' Mqngrkxtr mncpxm mz nabzgu mz nzngini-krde da ayrnrngr mz da kcng amrlx nakam Gct bagu. Murde nabzgu yrnibu kz mz nzaenzli-krgu Gct nzarlapx-krde nigu mz nzetqkr drtqgu x nzota-krgu badr zmatq ngr alwx mz nrlc ka. Aenzliku Gct nzka-krmle bagu nrkrdrtqgu kxmrna x nzvzmi-krde nigu Heven mz nzngini-zpwx-krgu doa nedeng.
\v 24 Abzo mzli kc Gct tqarlapx-ngrde nigu, obqtipx-zvzku nztwz-krgu da lcng. Murde nzmu natwzpeku da lcng, e trna-aenzlipekuu. Trpnzngr kx obqtipxle da kx twzpele.
\v 25 A' obqtipxku da kcng trtwzkaku. X aenzliku mz drtwrgu kx br kx sa natwzkung kalr.
\s1 Mqngrkxtr Okatrle Nigu Mz Nzkrka'-krgu
\p 
\v 26 X Mqngrkxtr okatr-kzle nigu mz nzaenzli-krgu mzli ka mz nzngrgokr nabzgu. X krka'-zvz-ngrde nigu. Murde trkrlzkuu da kx takitrde nzkrka'ti-krgule, x rblx nzrmcti-krgu natq mz nzpipx-krbzku da kx yclzm mz nabzgu.
\v 27 A' Gct Trte kc tqobqplxle nabzgu x drtwrgu, krlz-kzle drtwr ngr nzkrka'kr Mqngrkxtr nigu, murde Mqngrkxtr vz-nqblq-txpwzle me pnz drtwr Trte mz nzkrka'-krde leplz nedeng.
\s1 Da Kx Suti Drtwr Gct Nartrngztimle Bagu
\p 
\v 28 Gct kqlele nigu mz nzngini-krgu leplz nedeng, mz nzvz-nqblq-krde drtwr kx yrlq-pnzle. Delc kxmule-esz' da kx prtzm bagu, nakrlzku kx Gct yrlqle drtwr lc mz nzamrlz-krde nigu kcng tzmrlztilr nide.
\v 29 X mcpx pnz kz Gct nigu, x sc tqwz-ate-ngrde nrlc. Murde krlz-pnz-kaile kx sa nalxngitiku Mrlxde. X yrlqle drtwr kx na-apupwzku Mrlxde mz nqmq krgung, murde Mrlxde nangi doa kc kai x nanginigu doa kxnztopwzbzng bade. \x + \xo 8:29 \xt Aposol 26:23; 1 Korint 15:20; Kolosia 1:18; Hibru 1:6\x*
\v 30 X nigu lcng na-apuku Mrlxde, kqle-kzle nigu mz nzngini-krgu doa nedeng. X nigu lcng tqkqleleng, atubqti-kzle nigu mz nzobq-krde. X nigu lcng tqatubqtipeleng, sa tqbatrple nzaxvctr-krbzku mz nzmyalzkr Mrlxde.
\s1 Gct Tu Mz Nibrgu X Nivz Lrde Tu-ngalelvzle Nigu
\p 
\v 31 Mz nzmc-krgu da amrlx lcng tqalem Gct bagu, nakrlz-kzku kx trpnzngr kx na-aovxiole nigu murde tu-zvzle mz nibrgu.
\v 32 X krlz-angidrku kx sa naka-kzple bagu da amrlx kcng tqpimle, murde trlolvzleu Mrlxde kc esz'txu, a' atwzlr-ngrmle nide mz nztekqtr-krde nigu amrlx mz nzbzngr.
\v 33 X trpnzngr kx narpibzle mz Gct kx kzdq nigu leplz kcng tqmcpxle vz-rbrpe, murde nide esz'-krde kc tqatubqtipele nigu mz nzobq-krde. \f + \fr 8:33 \ft Kzdung mzli mz nzaotikr drtwrgu alwx rgung, nabzgu talvzo murde mwx mz drtwrgu rblxbz mz Gct nzmrlzti-krde nigu. A' drtwr lc ngi nzwzkr Setzn mz nzatrkati-krde nzrlxngiti-krgu. Mz nzplzpxpe-krbzku alwx rgung mz Gct x mz nztekqtrpe-krgu nqmq nr drtwrgu murde navz-nqblq-mouku nide, nakrlz-zpwxku kx ipqpe Gct nigu x tubqpe-mouku mz nzobq-krde. \xt 1 Jon 1:9 \xt*\ft Mzli kznike nabzgu talvzo-ngrde, naglqlzku Gct x na-awi-ngrbzku bade nivz lrde mz nzyckr drtwrde nigu. Murde nzrglqlzngr Gct krlzle nzaovxio-krde nzwzkr Setzn. \xt Sam 8:2\xt*\f*
\m 
\v 34 Mz nzmu-krde lcde, trpnzngr kx narpile kx takitrde nzayrplapxngr nigu mz alwx rgung. Murde Jiszs Kxnzmcpx bzpe-ngrde nzxpepx-krde nigu mz alwx lcng. X da kx myapxbz, Gct Trtede atulz-mople nide mz nzbzngr x awxbule nide me matq-esz'ngr Heven, mrkc tqpi-ngrbzle mz Trtede kx nede nigu.
\v 35-36 A' kzdung mzli da prtzm bagu, da kc tqwai nzrlwx-krgule mz Nzryrngrkxtr, mz nzrpikr kzdq Sam kx, \qt “Gct, mz nzngini-krgr doa nemqng, vz zvz nznibqti-krdr nigr, mz nzapusr-krdr nigr sip kcng tzmnc-nabung mz nzrnibqngr nidr.”\qt* \x + \xo 8:35-36 \xt Sam 44:22\x* A' nakrlzku kx trtxpnzngr da kx narpwa'-ngrde nivz lr Kraes mz nzkrlz-krmle nigu. Trngiu nzkxpungr, x zmwxlr, x nzetqkr drtq, x dzbi, x trnzrngisc-ngru da, x nzatrkatingr, x nzotangr, x kxmu-kzle-esz' nzbzngr. Trtxpnzngr kz.
\v 37 Kxmule-esz' da lcng amrlx nzprtzmqng bagu, a' sa na-aovxio-zvzkung mz nzokatrkr Kraes kc tqmrlztile nigu.
\v 38-39 Murde lxngiti-angidrx kx trpnzngr doa x da kx na-aovxiole nivz lrde. Kxmule-esz' nzlungr o nzbzngr, a' xngi-zvzpebzku nivz lrde. Kxmule-esz' kxnzmncng mzlilxlr kxnzxplrng x kxnzmatqng, a' trnzkrlzlru nzodati-krdr nivz lc. Kxmule-esz' da kx prtz mzli ka o mzli lc navzm, a' nivz lrde tqyc tqyc. Kxmule-esz' lr Heven, o lr Hxl, o doa x da kznikeng kz wzngr Gct, a' nivz lrde talvzpxle da amrlx. Trtxpnzngr doa o da kx na-aovxiole nivz lr Gct kc tqrmctiku mz Kxetu rgu, Mevalu Jiszs.
\c 9
\s1 Lr Jiu Kx Nzpxtxpx-ngrdr Jiszs
\p 
\v 1-2 Mzli kang kqlu drtqnge etq zlwz x drtwrnge vztx-ngrde kxnginingeng, lr Jiu, mz nzpxtxpx-krdr Kraes. Pibo da lc bamu x krlzamu kx ngi da angidr murde nede ninge Kraes. X Mqngrkxtr ncdr nzao-krnge drtwrnge, nzpimlr mz nabznge kx trpokiawxu.
\v 3 Lr Jiu kxkqlu trnzlxngitilru Jiszs nzngini-krde Mevalu Kxnzmcpx. A' suti zlwz drtwrnge nzokatr-krnge nidr mz nztekqtr-krdr nqmq nr drtwrdr, murde nidr kxnginingeng x nqvi kr bangeng. Kxmule-esz' rblx, a' da kx aoti txpwz drtwrnge nide sele—nzayrplapxkr Gct ninge x nalakitxpxmle ninge mz Kraes, nzmu da lc kx tqkrlzle nzokatr-krde lr Jiu lcng mz nzesotr-krbzlr mou mz Gct. A' trtingr.
\v 4 Sc tqmcpx-pnzng Gct lr Israel mz nzngini-krdr doa nedeng. Mrkc lzke nzmclr rkx ngr nzmyalz-krde x yrlqbzle Nzesz'tikr Drtwrdr badr, x kabzle Loukxtr badr mz Newz Saenae. Alvztr-ngrde nidr kxnamu nzangio-angidr-krdr nide x esalz-ngrbzle badr da kcng tqmyapxbz mz nzvz-krm Kxnzmcpx. \x + \xo 9:4 \xt Nou 9:8-9; 17:2; Nzrlaszngr 24:8; Josua 8:33; 2 Samwel 23:5\x* \fig Kabzle Loukxtr badr mz Newz Saenae.|alt="101 Mt Sinai, 10 commandments" src="101-Ex19.1.tif" size="COL" loc="ROM 9:4" copy="LLL Language Recording" ref="9:4"\fig*
\v 5 Melrmqdrng nidr ncblo kxnzetu neng Gct kcng bqnc, x Kraes nzmika kz apule leplz mz nqvi lr ncblo lcdeng. A' nide kc tqmyaszpxle doa x da amrlx. Naglqlz-zvz-ngrgu Gct! Angida!
\p 
\v 6 Bzkq rpiamu kx Gct tratutrleu nzesalz-krbzle badr. Murde trngiu leplz amrlx kcng nzmika mz nqvi lr Israel kcng tqmcpx Gct.
\v 7 X trngiu leplz amrlz mz nqvi lr Ebraam kx nznginidr leplz neng Gct. Murde rpibz Gct mz Ebraam kx, \qt “Nqvi lr ncblo nem angidr nayzuo mz mrlxm Aesak.”\qt* \x + \xo 9:7 \xt Nou 21:12\x*
\v 8 Drtwr ngrde nznginikr leplz doa neng Gct trvzpxpuu mz nzngini-krdr nqvi lr Ebraam. Murde leplz amrlx kcng tzlxngitilr Gct, da kc tqwai Ebraam, nidr angidr doa ngr nqvi lrde.
\v 9 Natq lcng tqesalz-ngrbz Gct mz Ebraam kx, \qt “Mzli kapwz, mz yiz lc navzm, sa nabatrpo mz Sera nzkrlz-krde nzmika-krde mrlxde.”\qt* \x + \xo 9:9 \xt Nou 18:10, 14\x*
\v 10 Kxmu-kzle lc mz Rebeka kc mrlxde tzlipxmqng, trtedr esz', krlc melrmqgu Aesak.
\v 11-12 Kxmule-esz' mztr trnzmcka x trnzalekalr da kxmrlz o da kxtrka, a' rpibz Gct mz Rebeka kx, \qt “Mrlxm kxetu sa nawztrpz mz mzlede kxtopwz.”\qt* \x + \xo 9:11-12 \xt Nou 25:23\x* Gct pile da lc mz nzaelwapx-krde kx nzmcpx-krde leplz trtuou mz da kx nzalelr, a' tuo mz drtwr kx yrlq-pnzle.
\v 13 Da kc tqwai nzpikr Gct le mz Nzryrngrkxtr kx, \qt “Mrlztix Jekop, a' pxtxpx-ngrne Isc.”\qt* \x + \xo 9:13 \xt Malakai 1:2-3\x*
\p 
\v 14 ?Nike, napiku kx Gct vz-rbr mz nzale-krde da lc? Bzkqtx pnz! Murde Gct tubq zvz.
\v 15 X rpibzle mz Mosis kx, \qt “Sa naycngr drtwrnge doa kx pnz drtwrnge. X sa naokatrx doa kx pnz drtwrnge.”\qt* \x + \xo 9:15 \xt Nzrlaszngr 33:19\x*
\v 16 Mz nzmu-krde lcde, Gct sa namcpxle krkcng natwzlr da kx esalz-ngrde. X nzmcpx-krde leplz tryctru mz nzrsutikr drtwrdr o mz nzale-krdr da, a' mz nzryckr drtwrde nidr.
\v 17 Na-aoti kz drtwrgu King r Ijipt. Murde Nzryrngrkxtr alvztr-ngrde kx Gct rpibzle bade kx, \qt “Yrlqx nim mz nzngini-krm king, murde na-aovxiox nim mz zmatq rnge x nrpa rnge natalvzole nrlc.”\qt* \x + \xo 9:17 \xt Nzrlaszngr 9:16\x*
\v 18 Mz nzmu-krde lcde, opx angidr kx Gct ycngr drtwrde kzdung leplz, mz nzvz-nqblq-krde me pnz drtwrde. X batr-kzpzle nzmqngikr nar kzdu-kzng leplz, vz-nqblq-kzle me pnz drtwrde. \f + \fr 9:18 \ft \em 9:7\em* Kzdung doa neng Ebraam nzvzpx-kzpqng mz mrlxde Ismael, mrlx Haga. A' doa lcng trnzatutrlru da kc tqesalz-ngrbz Gct mz Ebraam, x trnginidru leplz kcng tqmcpxle. [Nou dckrlzdeng 15—18, 21] \em 9:13\em* Isc x Jekop nzlipxmqng, x Isc nide kc nzmika kai. \em 9:17\em* Mzli kang kqlu King r Ijipt, narde mqngi. [Nzrlaszngr 7:22; 8:15, 32] Zbz sc tqbatrpebz Gct nzmqngi-zvzkr narde. [Nzrlaszngr 9:12, 35; 10:27; 11:10] \f*
\p 
\v 19 Mwx kzdung leplz sa narpimlr bange kx, “Leplz lcng nzale-txpwzlr da kc tqbatrpz Gct badr nzale-krdr le. X rblxbz badr nzvecpx-lzbq-krmlr mz zmatq ngr me pnz drtwrde. ?A' nike Gct tqayrplapx-ngrde leplz kcng trnzlalztqpwzung bade?”
\v 20 A' sa na-ayzlu-ngrbo natqdr kx, “Bzkq kxmu nzvea-krmu lc.” Murde nimu leplz, x trtakitrdeu leplz nzycmnetitr-krdr Kxrpalz kc tqwz-ngrde nidr. Murde ma nyz ncblo tr-rpipwzleu mz ncblo kc tqwz-ngrde nide kx, “?Nike tqmu nzwz-krm ninge lc?”
\v 21 Murde ncblo kx rwzngr ma, takitrde nzvz-nqblq-krde me pnz drtwrde esz'-krde. Krlzle nzwzngr ma kx li, kzdq kxnzmwingr, x kzdq kxnzasungr dakxnzng.
\p 
\v 22-23 Kxmu-kzle lc mz Gct. Murde kxmule-esz' takitrde nzayrplapx-krde kxnzaleng alwx mz zngya ngr drtwrde, a' rlr-ngrbzle badr nzmncbengr mz nrlc mzli ka x trayrkrpx-anileu nrlc. Murde na-aelwapx-kai-ngrbzle nzyckr drtwrde x rkx ngr nzmyalz-krde mz leplz kcng mztr trnzmcka, tqmcpx-pnzleng, x sc tqayrplapx-atele kxnzaleng alwx.
\v 24 Alemle da lc bagu, nigu kcng tqkqleleng, kxmule-esz' nigu lr Jiu o kxtrngiulrJiu.
\v 25 Da kc tqwai nzpikr profet Hosia le mz Nzryrngrkxtr kx, \qt “Leplz kcng trngiu leplz nengeng mzli kc, sa narpibo badr mzli ka leplz nengeng. X leplz kcng trnzprtr-pnzung mz nivz lrnge mzli kc, sa narpibo badr mzli ka kx mrlzti-zlwzpexng nidr.”\qt* \x + \xo 9:25 \xt Hosia 2:23; 1 Pita 2:10\x*
\v 26 \qt “X mrkc tqrpi-ngrbo badr kx, ‘Trnginipwxmuu leplz nengeng,’ mrlcdepwz dekc narpi-ngr-mopwc' badr kx, ‘Nimu doa neng Mevalu Gct.’”\qt* \x + \xo 9:26 \xt Hosia 1:10\x*
\v 27 A' profet Asaea ycmnetr-ngrde Israel, rpile kx, \qt “Kxmule-esz' leplz ngr Israel nzkqlu-krdr apule drta' ngr prla, a' kxpipz txpwz delang narlapxng.\qt*
\v 28 \qt Murde ycpwz pipz Yawe sa na-atutrle nzayrplapx-krde leplz amrlx mrka mz nrlc.”\qt* \x + \xo 9:28 \xt Asaea 10:22-23\x*
\v 29 X Asaea ycmnetr-mou-ngrde da lc, rpile kx, \qt “Nzmu Yawe trnarlrpx-ngrdeu bagu kzdung doa negung kxnzpipzng, e nigu lr Israel milxtxopeleng, da kc tqwaisr-ngrde lr Sodom x lr Gomora.”\qt* \x + \xo 9:29 \xt Asaea 1:9; Nou 19\x*
\s1 Lr Jiu Trnzrlxngitiung
\p 
\v 30 Drtwr ngr da lcng tqpibo bamu kxmule se. Leplz kcng trngiulrJiu nztubqng mz nzobqkr Gct murde nzbrti drtwrdr Kraes, kxmule-esz' mzli kc trnzabzlru nzvz-nqblq-krdr Loukxtr.
\v 31 A' lr Israel kcng tzabz-zlwzlr nzrvz-nqblqngr Loukxtr murde natubqbzng mz nzobqkr Gct, trnzyatrpwzung mz nzkrlz-krbzlr bz lc.
\v 32 ?Nike trnzyatr-ngrpwzlru? Trnzyatr-ngrpwzlru murde trnzabzlru nzkrlz-krbzlr bz mz nzbrtikr drtwrdr da kc tqesalz-ngrbz Gct badr. A' nzabz-alzulr nzkrlz-krbzlr bz mz nzvz-nqblq-krdr natq amrlx kcng tzyrong mz Loukxtr mz nzxplr-krdr esz'-krdr. X mz nzpxtxpx-krdr lrpzki r nzarlapxngr kc tqyrlq Gct, nztaong mz nou rplz kc tzyrputrngr leplz. \f + \fr 9:32 \ft Mz drtwr lr Jiu, rblx nzbzkr Mevalu Kxnzmcpx. Mzli kc tzxlr-ngrdr kx Kraes bz-ngrde nidr, nzpxtxpx-ngrdr drtwr lc. X mz nzmu-krde lcde, nztaong mz nou rplz, kc tqngi Kraes esz'-krde. \f*
\m 
\v 33 Da kc tqwai nzpikr Gct le mz Nzryrngrkxtr kx, \qt “Obqmamu! Murde yrlqpex kc doa mrkc Jerusalem kx apule rplz kx nayrputrngr leplz, mz nzobqszo-krdr nide. X nide nou rplz kc tzpxtxpx-ngrdr. Kxmule-esz', a' doa kx lxngitile nide drtqde trnamyau mz nzbrtikr drtwrde nide.”\qt* \x + \xo 9:33 \xt Asaea 8:14; 28:16; 1 Pita 2:7-8\x*
\c 10
\p 
\v 1 Mzlengeng x inwengeng, krka'-ngrbo mz Gct kx lr Jiu amrlx narlapxng, murde ngi da kx pqtx zlwz mz drtwrnge.
\v 2 Krlz-angidrx kx nzabz-zlwzlr nzvz-nqblq-krdr Gct, a' trnzkrlzlru kxnamu nzvz-nqblq-krdr le.
\v 3 Trnzkrlzlru kxmu nzatubqtikr Gct leplz mz nzobq-krde. A' mz drtwrdr, nztubq-krdr navzpxm mz da kx nzyrlqlr esz'-krdr, mz nzvz-nqblq-krdr Loukxtr. X nzpxtxpx-ngrdr nzmnclz-krbzlr mz lrpzki r Gct mz nzatubqti-krde leplz kcng tzlxngitilr Kraes.
\v 4 Kc tqatutrpele bz ngr Loukxtr. X mz nztubq-krde mz nzvz-nqblq-angidr-krdele, leplz amrlx kcng tzlxngitilr nide nzkrlzlr nzprtr-kz-krdr mz nztubq-krde mz nzobqkr Gct.
\p 
\v 5 Mosis yrole kxmu leplz natubq-ngrdr mz nzobqkr Gct mz nzvz-nqblq-krdr Loukxtr. Rpile kx, \qt “Doa kx vz-nqblq-zvzle Loukxtr amrlx, sa nalu zvz.”\qt* \x + \xo 10:5 \xt Livae 18:5\x*
\v 6 X mou, Nzryrngrkxtr alvztr-kzple mz nzatubqtikr Gct leplz mz nzlxngiti-krdr Kraes, mz nzrpi-krde kx, \qt “Bzkq rpi drtwrm kx navzdzq Heven,”\qt* (mz nzvzmio-krme Kraes mz nztwz-krmle nrpa ngr nzrlapxngr).
\v 7 \qt “X bzkq rpi kz drtwrm kx navzoq la,”\qt* (mz nzatulz-krme Kraes mz nzbzngr, mz nztwz-krmle Nrpakxmrlz).
\v 8 \qt “Murde nrpa lc krlzpebzle nim. X ycpxpem mz nabzm x pipxpeq mz naom.”\qt* \x + \xo 10:8 \xt Lou Kcpwz 30:11-14\x* Krlc nrpa kc tqyapwxtipxkr, kx leplz narlapxng mz nzlxngiti-krdr Kraes. X tr-rblxu nzrlapx-krdr murde Gct esz'-krde kx atwzlro-ngrmle Jiszs bagu x atulz-mople nide mz nzbzngr.
\v 9 Murde doa kx naplzpxle mz naode kx, “Jiszs nide Kxetu Kxmyalz-esz'ngr,” x lxngiti-angidr-kzle mz nabzde kx Gct atulz-mople Jiszs mz nzbzngr, doa la sa na-arlapx.
\v 10 Murde mz nzplzpx-krgu nzlxngiti-angidr-krgu Kraes, tubqku mz nzobqkr Gct x sa na-arlapxle nigu.
\v 11 Murde Nzryrngrkxtr ycmnetr-ngrde Mevalu mz nzrpi-krde kx, \qt “Doa kx lxngitile nide drtqde trnamyau mz nzbrtikr drtwrde nide.”\qt* \x + \xo 10:11 \xt Asaea 28:16\x*
\v 12 Kxmule-esz' lr Jiu o kxtrngiulrJiu, a' kxnzrlxngiting amrlx nzmnclzbzng mz Kxetu kcpwz, tqamrlz-zlwzle leplz amrlx kcng tzrlxtibzlr nzokatr-krde nidr.
\v 13 Da kc tqwai nzpikr profet Joel le kx, \qt “Krkcng nzrlxtibzlr mz Kxetu nzokatr-krde nidr, sa narlapxng.”\qt* \x + \xo 10:13 \xt Joel 2:32\x*
\p 
\v 14 ?A' myx kxnamu nzrlx-krbzlr bade nzokatrngr, nzmu kx trnzlxngitikalr nide? ?X myx kxnamu nzlxngiti-krdr nide, nzmu kx trnzxlrkalr nrpa ngrde? ?X myx kxnamu nzxlr-krdr Nrpakxmrlz lc, nzmu kx trpnzngr leplz kx narpipxbz badr?
\v 15 ?X myx kxnamu nzrpipxkr leplz nrpa, nzmu kx trpnzngr doa kx na-atwzlrpx-ngrng? Da kc tqwai nzpikr Nzryrngrkxtr le kx, \qt “Mrlz-esz'ngr nzvz-krm leplz kcng tzrtwzmqng nrpa kxmrlz.”\qt* \x + \xo 10:15 \xt Asaea 52:7\x*
\p 
\v 16 A' lr Jiu amrlx trtwzlru Nrpakxmrlz lc. Murde profet Asaea rpile kx, \qt “Yawe, trpnzngr kx lxngitile natqnge.”\qt* \x + \xo 10:16 \xt Asaea 53:1; Jon 12:38\x*
\v 17 Mz nzmu-krde lcde, leplz nzrlxngiting mz nzyrplatitrkr nardr Nrpakxmrlz, x nardr nzyrplatitrlr Nrpakxmrlz mz nzryapwxtipx-ngrbz badr Nrpa ngr Kraes.
\p 
\v 18 ?A' lr Jiu nzxlrpe-kzlr Nrpakxmrlz? Eu, nzxlrpelr, da kc tqwai nzpikr Nzryrngrkxtr le kx, \qt “A' nrpa scdr vzpx x krlzbzle leplz amrlx mz nrlc tulvzo.”\qt* \x + \xo 10:18 \xt Sam 19:4\x*
\v 19 ?A' lr Jiu nzyrplatitr nardr nrpa lc? Eu, murde Mosis alvztrpzle da kc tqpi-kaipz Gct mz lr Israel, mz nzrpi-krde kx, \qt “Sa na-adobu-ngrbo nimu leplz kxnzmaneng kcng trngiu lr Israel. X sa na-angyati-ngrbo drtwrmu nzamrlz-krnge leplz kcng trnzkrlzlru ninge.”\qt* \x + \xo 10:19 \xt Lou Kcpwz 32:21\x*
\v 20 X mz nelzde kxbr Asaea alvztrpzle natq Gct mz nzrpi-krde kx, \qt “Leplz kcng trnzrtangrtilru ninge, sc tzrmctipelr ninge. X aelwapx-lzbqpe-ngrbo mz krkcng trnzrlxtilru nzvz-krbo badr.\qt*
\v 21 \qt A' mz zbq kalvz kqle-ngrne leplz nengeng kx nayzlu-mopqng bange. A' vz zvz nzxpqbrlr-krdr ninge murde nardr mqngi.”\qt* \x + \xo 10:21 \xt Asaea 65:1-2\x*
\c 11
\s1 Gct Trlakitxpx-atwrnrleu Lr Israel
\p 
\v 1 ?Myx kxmule, Gct pxtxpx-ngrde leplz nedeng kcng tqngi lr Jiu? Bzkqtx pnz! Murde ninge dq kz lr Jiu. X mzke' nzmc mz nqvi lr ncblo kc mz Benjamin, tqvzpxm mz Ebraam. A' Gct trpxtxpx-ngrdeu ninge.
\v 2 X trpxtxpx-kz-ngrdeu leplz nedeng kcng tqmcpx-pnz-kaile, x nrlc kc tqwz-ate-ngrde. X krlzpeamu nike ycmnetrngr Nzryrngrkxtr mz da lc. Murde profet Elaeja drtwrde lctrpz mz lr Israel mz nzrpi-krde kx,
\v 3 \qt “Yawe, nznibqtipelr profet nemqng amrlx, x nzawxtxopebzlr olta nyzmqng. Ninge kc tqmnctxpxpepwz, x sa tzrpilr nanibq-kzlr ninge.”\qt* \x + \xo 11:3 \xt 1 King 19:10, 14\x*
\v 4 A' ayzlu-ngrbz Gct nzkrka'-krde kx, \qt “Amnc-bekapxpex leplz ngr Israel siu-rlimz (7,000) kx trnzangiolru gct Baal, murde leplz lcng nangi nengeng.”\qt* \x + \xo 11:4 \xt 1 King 19:18\x*
\v 5 Kxmu-kzle lc mzli ka. Murde kzdu lang kz leplz kxpipz kxnzamnc-bekapxpeng kcng tqmcpxpeng Gct mz nzarlapx-krde nidr mz zmrlz ngrde kxmyalz.
\v 6 Nzmcpx-krde nidr tuo mz zmrlz ngrde kxmyalz x trtuou mz nike nzalelr. Murde nzmu namcpxle nidr mz nike nzalelr, zmrlz ngrde lc trngiu da kx ka-nrbalqle.
\p 
\v 7 Krlc drtwr ngrde kx lr Israel nzabz-zlwzlr nztubq-krbzlr mz nzobqkr Gct, a' nzkqlung kx trnzyatrpwzung. A' ngi txpwz krkcng tqmcpxle kx nayatrpzng. A' batrpzle nzmqngikr nar leplz kxkqlu.
\v 8 Da kc tqwai nzrpikr Nzryrngrkxtr le kx, \qt “Gct aprcbzle badr kxmnc mzlilxlr kx akamrbr-ngrbzle nzrkrlz-krdr, vzm vzm krlzmle mzli ka, rblxbz badr nzrmcngr x nzxlrngr nzalvztrngr angidr.”\qt* \x + \xo 11:8 \xt Lou Kcpwz 29:4; Asaea 6:9-10; 29:10\x*
\v 9-10 X rpi kz Devet kx, \qt “Yawe, kxmu nzmukr leplz lcng badr kztedrng Mangr-nzangiongr trtubqu mz nzobq-krm. Delc, nzrtxlvzlz-mou-ngrdr alwx ngrdrng x takitrde nzodati-krm nidr. Akcbz mztr, x ayangrnga-zvzbz nrkrdrtqdr.”\qt* \x + \xo 11:9-10 \xt Sam 69:22-23\x*
\p 
\v 11 ?Myx kxmule, mzli kc tztaongr lr Jiu mz nzpxtxpx-krdr Kraes, drtwr ngrde kx nzlakitxpxkr Gct nidr tqyc tqyc? Bzkqtx pnz! A' arlapxle leplz kcng trngiulrJiu, mz nzlxngiti-krdr Jiszs, murde nabatrpzle nzdobuti-zlwzkr lr Israel nidr.
\v 12 Lr Jiu nzpxtxpx-krdr Kraes, batrpzle mz Gct nzka-alzu-krbzle da kxmrlzting mz kxtrngiulrJiu. Mz nzmu-krde lcde, mz nibr lr Jiu amrlx kcng tqmcpx Gct narlapxng, sa na-amrlz mou Gct leplz amrlx mz nrlc namyaszpxle mzli ka. Murde da kxmrlzting amrlx kcng tqkaom Gct bagu, nzvzpxmqng mz nzkao-kai-krbzleng mz lr Jiu.
\p 
\v 13 Pibo da lcng amrlx bamu, myapxbz nimu kcng trngiulrJiu. Gct mcpxle ninge mz nzngini-krnge aposol mz nzalvztr-krnge kxtrngiulrJiu. X nzwz-krnge lc matq zlwz mz drtwrnge.
\v 14 Murde mwx, sa nadobutingr lr mrnyzngeng nzarlapxkr Gct nimu, x nzwz-krnge lc sa nabatrpzle mz kzdung nidr nzrlapx-krdr kz.
\v 15 Mzli kc lr Jiu tzpxtxpx-ngrdr Jiszs nzngini-krde Mevalu rdr, Gct rlrpx-ngrde nzrlapxkr lr mrkzbleng amrlx mz nrlc. ?A' nike naprtz mzli kc na-abrtzlvz-ngrde nidr mzli kc nalxngitilr Jiszs kalr? Kxnzbzng sa nalu-moung. \f + \fr 11:15 \ft Mz drtwr kzdung kxnzetung, natq lc ‘kxnzbzng sa nalu-moung,’ drtwr ngrde kx lr Jiu kxnzkqlung sa nalxngitilr Jiszs, x sc tqyzlu-atem. \f*
\s1 Lr Jiu Nznginibedr Kxnzmcpxng Ne Gct
\p 
\v 16 Na-aoti drtwrmu dalr nrlanc x dzbr nc. Murde dalr nrlanc kc tzamrlz tzka-kaipz mz Gct batrpzle nztrkr dalr nrlanc amrlx. X nzmu dzbr nc natrlr, e nrladeng amrlx nztr-kzng. Mz nqmq lcpwz, lr Jiu sa nangineng Gct murde melrmqdrng nidr leplz nedeng.
\p 
\v 17 Naycmne-ebzpxbo nc olivi. Lr Jiu nzapulr nc olivi kc tqpeti Gct mz nrlanc nyzde. X lr Jiu kcng trnzrlxngitiung nzapulr nrla nounc kcng tqlakitxpx Gct. X nimu kxtrngiulrJiu apuamu nrla nc olivi kx tutrp mz nrlarde kx yz mz nrlanc nyz Gct. A' mzli ka mz nzrlxngiti-krmu, Gct twzpele nrlade kcng tqnginimu x sc tqaxvctrpebzle nimu mz nc olivi nyzde, murde nanginimu kz leplz nedeng. X mzli ka prtrpe-kzamu mz da amrlx kcng tqesalz-ngrbzle mz leplz nedeng.
\v 18 Mz nzmu-krde lcde, bzkq obqszo-ngrnamu leplz kcng tzapulr nrla nounc kx lakitxpxle. Murde dzbr nc nide kc tqalule nrla nounc, a' trngiu nrladeng kcng tzalulr dzbrdr.
\v 19 Mwx kzdung nimu naglqpx-lzbqamu mz nzrpi-krmu kx, “A' Gct lakitxpxle nrla nc olivi angidr, murde na-axvctrpzle nigr mrkcng tzyzprpx-ngrmlr.”
\v 20 Da zpwxtx. A' nrlade kcng tzlakitxpxng murde trnzrlxngitiung, x nimu kx ngipe nrla nc olivi lc murde rlxngitiamu. Mrlzvxitx, a' bzkq glqpx-lzbqamu, a' aclvetio-lzbqamu mz zmwxlr, murde ma tzlakitxpx kz nimu.
\v 21 Murde nzmu Gct kx tqlakitxpxle lr Jiu kcng tqngi angidr nrla nc olivi mz trnzrlxngiti-krdru, e sa nalakipx-kzle nimu, nzmu trnavz-zvzu nzrlxngiti-krmu.
\p 
\v 22 Nakrlz-angidramu kx Gct okatrle leplz o ayrplapxle nidr. Murde sc tqayrplapxpele krkcng trnzrlxngitiung. X okatrle nimu mz zmrlz ngrde, nzmu navz zvz nzbrtikr drtwrmu zmrlz lc. A' nzmu navecpx-lzbqamu mz nzrlxngitingr, sa nalakitxpx-kzle nimu mz nc olivi.
\v 23 X mz nqmq lcpwz, nzmu lr Jiu natekqtrlr nqmq nr drtwrdr mz nzlxngiti-krdr Mrlx Gct, sa na-axvctr-moule nidr mrkc tzyzprkipxmlr. Murde Gct rngisc zmatq ngr nzaxvctr-moungr nidr.
\v 24 Murde axvctrpzle nimu mz nc olivi kc tqpetile, kxmule-esz' nginimu nrla nc olivi kzble. Mz nzmu-krde lcde, trnarblxpwzu bade kalr nzaxvctr-mou-krde lr Jiu kcng tznginidr nrla nc olivi angidr.
\s1 Lr Jiu Sa Nayzlubzng Mz Gct Mz Nzlxngiti-krdr Kraes Kalr
\p 
\v 25 Mzlengeng x inwengeng, suti drtwrnge nzkrlz-krmu da angidr kc tqyc-kapq mzli kc, murde ma tqglqpx-lzbqamu. Nzmqngikr nar lr Jiu sa navz nakrlzmle mzli kc narlapxngr kxtrngiulrJiu kxnzkqlung kcng tqmcpxng Gct. \f + \fr 11:25 \ft Mwx ‘kxtrngiulrJiu kxnzkqlung’ drtwr ngrde leplz kcng na-atutr-ngrdr natq kc tqplzpx Jon mz Nzaelwapxngr 5:9-10 x 7:9. Kzdung leplz kcng tzprpxmqng mz nou, natq, leplz, drtqbr, x neidu amrlx mz nrlc sa nalxngiti-kailr Kraes, x lr Jiu kxnzkqlung kc ate. Mz nibrde kzdung leplz mou sa nalxngiti-kzlr Kraes. \f*
\m 
\v 26 Zbz lr Jiu kxnzkqlung kcng mzli lc sa narlxngiting x narlapxng. Da kc tqwai nzrpikr Nzryrngrkxtr le kx, \qt “Mevalu sa naprpxm Jerusalem, x sa nakatxde nqmq kxtrka amrlx mz leplz kcng tzvzpxmqng mz nqvi lr Jekop.\qt*
\v 27 \qt X sa nayrlqkr Nzesz'tikr Drtwrdr badr, mzli kc naipqpx-ngrbo alwx ngrdr.”\qt* \x + \xo 11:27 \xt Asaea 59:20-21; 27:9; Jeremaea 31:33-34\x*
\v 28 Lr Jiu kxnzkqlung nzpxtxpx-ngrdr Nrpakxmrlz. X krlc okatrle nimu, murde Gct sc tqka-zvzbzle bamu da kxmrlzting. Kxmule-esz', a' lr Jiu sc tznginibedr leplz nedeng kc tqmcpxleng. X mrlzti-zlwzle nidr murde da kcng tqesalz-ngrbzle mz melrmqdrng.
\v 29 X trtekqtrleu drtwrde mz leplz kcng tqkqleleng tqamrlzleng.
\v 30 Mzli kc, nimu kcng trngiulrJiu xpqbrlr-ngrnamu Gct. A' mzli kc lr Jiu trnzrlr-ngrpwzlru mz Gct nzokatr-krde nidr x nzyckr drtwrde nidr, okatr-alzule nimu x yc mz drtwrde nimu.
\v 31 X mzli ka lr Jiu nzxpqbrlr-ngrdr Gct. X krlc Gct naokatr-kzle nidr x naycngr drtwrde nidr, da kc tqwaisr-ngrde nimu.
\v 32 Murde amnclzbzle leplz amrlx mz zmatq ngr nzxpqbrlrngr mz nzapu-krdr kxnzmncng mz presin. Mz nzmu-krde lcde, krlzle nzokatr-krde nidr x nzyckr mz drtwrde nidr amrlx.
\s1 Nabz Ngr Nzrglqlzngr Gct
\q1 
\v 33 Kctitxpx-zlwzx nzetukr
\q1 Nzyrplapxkr Gct x nzrkrlz-krde.
\q1 Trpnzngr kx narde nayrplatrpz
\q1 Mz da kc tqaolvzle x nqmq krdeng.
\b
\q1 
\v 34 Natq Gct rpile kx, \qt “Trpnzngr\qt*
\q1 \qt Kx rkrlz me pnz drtwr Yawe,\qt*
\q1 \qt O kx rkrlz nzokatr-krde Gct\qt*
\q1 \qt Mz da kznike kx pibzle bade.”\qt* \x + \xo 11:34 \xt Asaea 40:13-14\x*
\b
\q1 
\v 35-36 \qt “Trpnzngr kx rkabz da mz Gct\qt*
\q1 \qt Murde na-ayzlu-mopwz Gct bade.”\qt* \x + \xo 11:35-36 \xt Job 35:7; 41:11\x*
\q1 Murde wz-ngrde nrlc atwrnrngr,
\q1 Mz nzvz-nqblq-krde me pnz drtwrde.
\b
\q1 X da amrlx lolvz lxblr zvz
\q1 Zmatq ngrde kx xplr-esz'ngr. \x + \xo 11:35-36 \xt Kolosia 1:17\x*
\q1 Naglqlzku x na-amrlue-zvzku
\q1 Gct tqyc tqyc. Eu, angida.
\c 12
\s1 Rlr-lzbq-ngrbzmu Mz Gct
\p 
\v 1 Mzlengeng x inwengeng, mz nzkrlz-krmu kx Gct ycngr drtwrde leplz amrlx, lc-apqbzx nimu nzrlr-lzbq-krbzmu mz nzwztr-krbzmu bade, mz nzapu-krmu blz kxtr kxlu. Murde krlc nzangiongr angidr x aelalzmle drtwrde. \x + \xo 12:1 \xt Jon 4:23-24\x*
\v 2 Bzkq rlr-lzbq-ngrbzmu mz nzvz-nqblq-krmu nqmq kr lr nrlc, x bzkq drtwrmu esz'ti badr. A' rlr-ngrbzmu mz Gct nztekqtr-krbzle nqmq nr drtwrmu, murde navz-nqblq-alzuamu me pnz drtwrde. X mz nzale-krmu da lc, nakrlz-zvzamu me pnz drtwrde. Krlc da kx mrlzbz bade, aelalz-ngrmle drtwrde, x tubq mz nzobq-krde. \f + \fr 12:2 \ft Gct krlzle nztekqtr-krde nqmq nr drtwrgu mz nzrlwx-krgu Nzryrngrkxtr x mz nzvz-nqblq-krgu le mz nzmnc-krgu. \f*
\p 
\v 3 Mz nzngini-krnge aposol, rngidrlvz-ngrbo mz doa kxesz' mz nimu, kx bzkq glqpx-lzbqm. A' na-avzo-lzbqm mz nzkrlz-angidr-krm zmatq kx myapxbz kc tqkabz Gct bam mz nzwztr-krbzme bade. Murde zmatq lc vzpxm mz nzlxngiti-krm Kraes.
\v 4 Murde nrkrdrtqm esz', a' dalr nrkrdrtq kqlu. X mrlcdeng nzwz-krdr bletipx-lxblrng.
\v 5 Mz nqmq lcpwz, kxmule-esz' kqluku, a' mz nzaxvctr-krbzku mz Kraes nigu nrkrdrtq kxesz'. Doa kxesz' mz nigu apule dalr nrkrdrtqde, kx nzmwitr-lxblrbz bade.
\v 6 Gct kamle bagu zmatq kxmyapxbz kx bletipx-lxblrng mz nzwztr-krbzku bade. X zmatq lcng nzvzpxmqng mz Mqngrkxtr. Doa kxesz' mz nigu nawz zvz mz zmatq kc tqkabz Gct bade. Nzmu kx tqkabzle bam zmatq ngr nzrplzpxngr nrpa kc tqkabzle bam, plzpx nrpa lc navz-nqblqle nzetukr nzrlxngiti-krm, mzli kc tqpi-ngrbz Mqngrkxtr nzplzpx-krmle.
\v 7 Nzmu kx tqkabzle bam zmatq ngr nzwztr-ngrbz mz leplz, wztrpz badr. Nzmu kx tqngi nzalvztrngr natq Gct le, alvztr leplz.
\v 8 Nzmu kx tqngi dalr nzapqtr-ngrbz drtwr leplz le, apqtrpz drtwrdr. Nzmu kx tqngi zmatq ngr nzrka-ngrbz da mz leplz le, rka-nrbalqbz badr, a' bzkq pnz drtwrm nzayzlu-krbzlr le. Nzmu kx tqngi zmatq ngr nzrmailzngr le, mailz angidr leplz. X nzmu kx tqngi zmatq ngr nzrycngr drtwr leplz le, okatr nidr.
\p 
\v 9 Nivz lrm, nangi nivz angidr. Lolvz-amqngi da kxmrlzbz mz Gct, x pxtxpxngr da kxtrka.
\v 10 Mrlzti leplz da kc tqwaisr-ngrn doa lr ma nyzm. X amrlue kztemqng namyaszpxle nim esz'-krm.
\v 11 Nzpq-zlwzkr drtwrm mz nzwztr-krbzme mz Kxetu, naglq-zvzle nabzm.
\v 12 Naelalz-zvz-ngrm drtwrm nzobqtipx-krm da amrlx kcng tqesalz-ngrbz Gct bam. Tu-amqngi mz nzrlxngiti-krm mz mzli r nzkxpungr. Bzkq nzkrka'-krm esaki.
\v 13 Akiamu dztumu badr leplz ne Gct kcng takitrde nzokatrngr. X abrtzlvz nzadwatr-krbz leplz ma nyzm mz nzvz-krdr mrkzbleng.
\p 
\v 14 Rlxtibz mz Gct nzamrlz-krde krkcng tzatrkatilr nim. Amrlz nidr, x bzkq pibqtiq nidr.
\v 15 Prtr mz nzabrtzkr kxnzabrtzng, x mz nzvzkr drtwrdr kxnzyrning.
\v 16 Mnc-zpwx-lxblramu. Bzkq aetu-lzbqm, a' mnc-lxblramu badr leplz x wz-lxblramu badr. X bzkq rpiq nim kxrkrlz da.
\p 
\v 17 Bzkq ayzlubzme da kxtrka kx nzalebz leplz bam. A' ale txpwz da kxtubq mz drtwr leplz amrlx.
\v 18 Kxmule-esz' nike nzale leplz, a' ale zvz da kx namnc-ngrnamu badr mz nrwx.
\v 19 Nimu kztengeng, x doa kxesz' mz nimu bzkq ayzlubzme da kxtrka kx nzalebz leplz bam. A' rlr-ngrbz mz Gct nzayrplapx-krde nidr mz zngya ngr drtwrde. Murde mz Nzryrngrkxtr rpi Yawe kx, \qt “Ninge kx na-ayrplapxle leplz. X ninge kx na-ayzlu-mopwz badr da kx nzalelr.”\qt* \x + \xo 12:19 \xt Lou Kcpwz 32:35\x*
\v 20 A' nim vz-nqblq alzu nike pi Nzryrngrkxtr kx, \qt “Nzmu doa kx mwati drtwrde nim kx tqbrtalele, rkabz nade dakxnzng. X nzmu drtwrde kc tqbrlxkzle, rkabz mqde lue. Mz nzale-krbzme da lc, sa namyangr drtqde da kc tqalebzle bam.”\qt* \x + \xo 12:20 \xt Nzyrplapxngr 25:21-22\x*
\v 21 Bzkq rlr-ngrbzme mz da kxtrka kx nzalebz bam nzaovxio-krde nim, murde ma tqbatrpzle bam nzayzlu-krbzmele badr. A' aovxio nzao-krm drtwrm kxtrka mz nzale-krbzme da kxmrlz badr.
\c 13
\s1 Vz-nqblqamu Gzpman
\p 
\v 1 Doa kxesz' mz nigu kxnzrlxngiting namnclzbz mz zmatq ngr gzpman. Murde zmatq ngr gzpman amrlx vzom mz Gct, x yrlqle kxnzetung ngr gzpman mr nyzdrng.
\v 2 Mz nzmu-krde lcde, krkcng tzxpqbrlr-ngrdr gzpman nzxpqbrlr-ngrdr Gct kc tqyrlqle gzpman lc, x sa na-ayrplapxng.
\v 3 Krkcng tzaleng da kxtubq trnzmwxlrtilru gzpman. A' nzmwxlrti krkcng tzaleng da kxtrka. Nzmu kx trsutiu drtwrmu nzmwxlrtingr gzpman, e ale-txpwzmu da kxtubq, murde naglqlz-ngrdr nimu.
\v 4 Murde kxnzetung mz gzpman, nidr kxnzawz neng Gct kcng tqyrlqleng mz nzokatr-krdr nimu. A' nzmu kx tqaleamu da kxtrka, e mwxlrtiamu gzpman lc, murde Gct kabzle badr zmatq ngr nzayrplapxngr kxnzaleng da kxtrka, kxmule-esz' nznibqlr nidr.
\v 5 Mz nzmu-krde lcde, namnclzbzmu mz zmatq ngr gzpman murde ma tzayrplapx nimu, x mou murde tubq nzmnclz-krbzmu bade.
\p 
\v 6 Delc tqxpe-ngrnamu kz takes, murde kxnzetu lcng nidr kxnzawz neng Gct mz nzale-krdr nzwzngr kc tqkabzle badr.
\v 7 Mz nzmu-krde lcde, xpebzmu mz leplz nike takitrde nzxpe-krmu. X xpeamu takes kcng tqpi lou ngr gzpman kx naxpe. Mz nqmq lcpwz amatqamu krkcng tqtakitrde nzamatq-krmu nidr x amrlueamu krkcng tqtakitrde nzamrlue-krmu nidr.
\s1 Nzmncngr Kxtubq Mzli Ka, X Jiszs Sc Tqyzlu-atem
\p 
\v 8 Eu. Mrlz nzxpe-krbzmu mz leplz da amrlx kcng tqrlxtibzmu badr. A' nakrlz-zpwxamu kx rblx nzxpe-krbzmu da mz Gct mz nzayzlu-krbzmu nivz lrde. Delc navz zvz nzmrlzti-lzbq-krmu. Murde nzale-krmu da lc atutrle natq amrlx kcng tqkapx Loukxtr. \x + \xo 13:8 \xt Matiu 22:40\x*
\v 9 Natq lcng nzrpilr kx, \qt “Bzkq rmwimiq doa kx trngiu krnalzm. Bzkq rnibqq leplz. Bzkq pnaq da. Bzkq rkcmnz-ngrn,”\qt* x kzdung kz da mou. \x + \xo 13:9 \xt Nzrlaszngr 20:13-17; Lou Kcpwz 5:17-21\x* A' natq lcng amrlx nzaxvctr-lxblrbzng mz natq kc esz' tqrpile kx, \qt “Namrlztiq kztemqng da kc tqwaiq nzmrlzti-lzbq-krm.”\qt* \x + \xo 13:9 \xt Livae 19:18; Matiu 19:19; 22:39; Mak 12:31; Luk 10:27; Galesia 5:14\x*
\v 10 Nzmrlzti-krmu leplz drtwr ngrde kx bzkq aleamu da kx na-atrkatile nidr. Mz nzmu-krde lcde, nivz ngi lrpzki nzvz-nqblqngr Loukxtr amrlx.
\p 
\v 11-12 Nzmnc-krmu natubq, mz nzkrlz-krmu kx ycpe pipz nzyzlu-krm Jiszs mz nzvzmi-krde nigu Heven. Mz nzmu-krde lcde, bzkq amaamu, a' nawz-katopeamu mz nzwzngr kc tqkabz Kxetu bamu mzli ka tqyc-ngrbepz mzli. X bzkq vz-nqblq-zvzamu da kxtrka, a' vz-nqblq-alzuamu nzalvztrngr angidr.
\v 13 Mz nqmq lcpwz kx tr-rblxu nzmc-krgu da ngrlx, tr-rblx-kzpwzu mz leplz nzmc-krdr kx nqmq krmu tubq. Bzkq prtrpzmu mz kxnzrmnq-zvzng, kxnzyrlwr-lxblrng mz nzale-krdr alwx, kxnzrmwimi-abeaneng, kxnzaleng da kx myangr drtq, kxnzota-zvzng, x kxnzdobung, a' kapx-lzbqmamu badr.
\v 14 A' mz nzaxvctr-krbzmu mz Kxetu rgu Jiszs Kxnzmcpx, navz-nqblq-kzamu nqmq krde, murde leplz namclr nide mz nzmc-krdr nqmq krmu. X bzkq aoti drtwrmu nzvz-nqblq-krmu zmatq ngr alwx kc tqycpxbep mz nrkrdrtqmu. \x + \xo 13:14 \xt Rom 7:23\x*
\c 14
\s1 Bzkq Pikitiq Leplz Kcng Nzrlxngiti-krdr Tqngrgo
\p 
\v 1 Mnc-zpwxamu badr leplz kcng drtwrdr tqlitrpz mz da, murde trnzkrlzlru kx da kx nzalelr tubqbz mz nzobqkr Gct o trtingr. X bzkq otablramu badr mz drtwr kx blepxngr mz nzao-krmu drtwrmu.
\v 2 Murde kzdung leplz nzlxngitilr kx takitrde nzmu-krdr dakxnzng amrlx. A' kzdu-kzng leplz trnzmuu ncvr animol, murde mz drtwrdr rpwa'ngr Gct x nzrlxngiti-krdr ngrgo mz nzmu-krdrle. \f + \fr 14:2 \ft \em 14:1\em* Bzkq otablrku mz da kx tryctru mz Nzryrngrkxtr. X mou, bzkq otablrku mz dalr Nzryrngrkxtr kx tropxu, x drtwr lrmakxtr tresz'titru elr, da kc tqwai mz nzwrkxtrngr. A' takitrde nzatubqti-krgu leplz kcng tzaleng alwx x tzxpqbrlr-ngrdr natq Gct. \em 14:2\em* Lou sc Mosis rpwa'-ngrde nzmungr kzdung dakxnzng. A' mzli kc lr Jiu tzlxngitipe-ngrdr Jiszs, nardr tryrplatrpwzu kx mzli ka takitrpede nzmu-krdr dakxnzng angidr amrlx. \f*
\m 
\v 3 Mrlx kx krlzle nzmungr dakxnzng amrlx bzkq obqszo-ngrde ncblo kc trmuu ncvr. X doa kx trkrlzleu nzmungr ncvr, bzkq pikitile ncblo kc tqmu dakxnzng amrlx, murde tr-rpwa'-ngru Gct.
\v 4 ?Nim neke kc tqkxmu nzycmne-krde lc? Murde trtakitrdeu nzpikiti-krm kxnzawz neng Gct! Trnzwztrpwzu bam! A' Kxetu sa napibzle mz kxnzawz nedeng kx nzale-krdr da kxtubq o trtingr. Kxnzrlxngiting amrlx nidr leplz nedeng, murde okatrle nidr amrlx, kxmule-esz' nzrlxngiti-krdr mqngi o ngrgo.
\v 5 Mz nqmq lcpwz, kzdq ncblo mz drtwrde kzdq zbq kxesz' myapxbz mz zbq amrlx. X kzdq kz ncblo mz drtwrde zbq amrlx kxmu-txpwzle esz'. Doa kxesz' mz nimu nakrlz-angidrle nike lxngitile, x navz-nqblqle mz nzmnc-krde.
\v 6 Murde mrlx kx rpi drtwrde kzdq zbq kxesz' myapxbz mz zbq amrlx, alebzle mz Kxetu. X krkcng tzmung dakxnzng amrlx, nzalebzlr mz Kxetu, murde nzawi-ngrbzlr bade. X leplz kx trnzmuung ncvr, nzale-kzpzlr mz Kxetu mz nzawi-krbzlr bade. Nzabrtzlvzkr Gct nidr vzpxm mz nzale-krbzlr da bade.
\v 7 Mz nzao-krgu drtwrgu nigu kxnzrlxngiting, da kxmyapxbz trngiu nzamatqkr leplz nigu mzli ka mz nzlu-krgu o mzli kc nabz-ngrgu.
\v 8 A' da kxmyapxbz nzamatqkr leplz Gct mz nzmc-krdr nqmq krgu mzli ka x mzli kc nabz-ngrgu. Mz nzmu-krde lcde, kxmule-esz' luku o bzku nede nigu Kxetu rgu.
\v 9 X nakrlzamu kx Kraes bz x lu-mop murde nanginide Kxetu r kxnzlubeng x kxnzbzpeng.
\v 10 Mz nzmu-krde lcde, bzkq pikitiq x obqszoq kztemqng. Murde mzli kc nayzlu-ngrm Jiszs, sa natutrpzku amrlx ngrgu mz mz Gct, mz nzpi-krmle bagu kx vz-rbrku o trtingr.
\v 11 Murde mz Nzryrngrkxtr Kxetu rgu rpile kx, \qt “Da kc tqpibo bamu sa natutr angidr, murde ninge Yawe Gct kc tqlu alo. Leplz amrlx sa na-atuobzng zpr bange. x naplzpxlr natq ngr nzrglqpxngr ninge.”\qt* \x + \xo 14:11 \xt Asaea 45:23; Filipae 2:10-11\x*
\v 12 Mz nzmu-krde lcde, nigu leplz amrlx sa napipxbzku mz Gct nqmq krgung x da kx alekung amrlx mz nrlc ka.
\p 
\v 13 Mz nzmu-krde lcde, bzkq vz zvz nzpikiti-lzbq-krmu. A' na-aoti drtwrmu kx bzkq aleamu da kx na-atrkatile nzrlxngitikr kztemung o na-ataole nidr mz alwx.
\v 14 Mz nzaxvctr-krbo lc mz Kxetu rgu Jiszs, lxngiti-angidrx kx trpnzngr dakxnzng kx trtakitrdeu nzmungr mz nzobq-krde. A' nzmu mzlenge rpi drtwrde kx kzdung dakxnzng trtakitrdeu mz nzobqkr Gct, trtakitrdeu nzngq-krdeleng. X bzkq atrkati-ngrbo nzrlxngiti-krde.
\v 15 Nzmu nzmu-krm ncvr atrkatile nzrlxngitikr kztem x ataole nide mz alwx, e bzkq ngqnle. Murde Kraes bz-ngrde nzarlapx-krde nide. X da kx atrkatile nzrlxngitikr kztem, trvzpxpuu mz nivz.
\v 16 Mz nzmu-krde lcde, bzkq ale-zvzq da kx mrlzbz bam esz'-krm, murde ma tqataole kztem mz alwx x sc tzpibqtipengr leplz nim.
\v 17 Murde mz nznginikr Gct king rmu, da kx myapxbz trngiu nzmungr x nzrmnqngr. A' da kcng tqmyapxbz da lcde seleng tq: nztubqkr nzmnc-krmu mz nzobqkr Gct, nzmnc-zpwx-krmu badr kztemung kxnzrlxngiting, x nzprtr-krmu mz nzabrtzngr kx vzpxm mz Mqngrkxtr.
\v 18 Murde krkcng nawztrpzng mz Kraes mz nzvz-nqblq-krdr da lcdeng, sa na-abrtzlvz Gct nidr x na-amatq kz leplz nidr.
\p 
\v 19 Dekc na-ale-ngrgu da kx na-amnc-zpwxle nigu x na-amqngile nzrlxngiti-krgu.
\v 20 Nzmu nzngq-krmu dakxnzng na-atrkatile da kx na-alebz Gct mz kztemung, bzkq ngqamu dakxnzng lcng. Murde dakxnzng amrlx takitrde nzmungr mz nzobq-krde. A' trtakitrdeu nzngq-krmu dakxnzng kx nabatrpzle mz kztemung nztao-krdr mz alwx.
\v 21 Bzkq aleamu da kx krlzle nzbatr-krbzle mz kztemung nztao-krdr mz alwx, kxmule-esz' da kx ngqnamu o da kx mnqamu.
\v 22 Doa kxesz' mz nimu, bzkq alvztrpzme nike lxngitiq mz da lcng mz kztemqng, murde navz-nqblq-kzlr me pnz drtwrm. A' pi txpwz nzrlxngiti-krm mz Gct. X mz nzvz-nqblq-krmle, Gct trnapipwzleu bam kx vz-rbrq, a' sa na-abrtzlvzle nim.
\v 23 A' doa kx drtwrde litrpz mz dakxnzng kx ngqde, alepele da kx vz-rbr. Murde trvz-nqblqleu da kxtubq mz nzobqkr Gct mz nzrlxngiti-krde. Mzli kznike doa ale-ngrde da kx atrkatile nzrlxngiti-krde sc tqalepele alwx mz nzobqkr Gct.
\c 15
\p 
\v 1 Nigu kcng nzrlxngiti-krgu tqmqngi, na-aoti drtwrgu kztegung kcng nzrlxngiti-krdr tqngrgo, mz dakxnzng x zbq kxtr lcng. X bzkq ale-txpwzku da kx na-abrtz-ngrgu esz'-krgu.
\v 2 A' mzli kc tqmnc-ngrgu badr, na-aleku da kxmrlzbz badr mz nzokatr-krgu nidr mz nzamqngingr nzrlxngiti-krdr.
\v 3 Murde Kraes traleleu da kx na-abrtz-ngrde esz'-krde, a' da kx abrtzngr Gct, da kc tqwai nzpikr Nzryrngrkxtr le kx, \qt “Natq kcng tzpikiti-ngrdr nim, yrplatr-kzpqng bange.”\qt* \x + \xo 15:3 \xt Sam 69:9\x*
\v 4 Da amrlx kcng tqyclzm mz Nzryrngrkxtr, nzyro-ngrdr na-alvztrlr nigu, murde nabzgu napqtr zvz x natu-amqngi-zvzku mz nzobqtipx-krgu da kcng tqesalz-ngrm Gct bagu.
\v 5 Krka'-ngrbo mz Gct kc tqapqtrple nabzgu x okatrle nigu mz nztu-amqngi-krgu mz nzrlxngiti-krgu, kx sa naokatrle nimu mz nzesz'tikr drtwrmu, mz nzvz-nqblq-krmu nabzlvz r nanyc Mevalu Jiszs.
\v 6 Murde naodutr-lxblramu mz nabz kxesz' mz nzangio-krmu Gct, kc tqngi Trte Kxetu rgu Jiszs Kxnzmcpx. Eu, angida.
\p 
\v 7 Mz nzmu-krde lcde, na-aodu-lzbqamu, da kc tqwai Kraes nzaodu-krde nimu, murde nzesz'tikr drtwrmu lc nabatrpzle mz leplz nzglqlz-krdr Gct.
\v 8 Nadcpx mz drtwrmu kx Kraes vzm mz nzokatr-krde nigr lr Jiu. Suti drtwrde kx na-aelwapx-ngrde kx Gct takitrde nzbrtikr drtwr leplz le. Murde angidatile da kcng tqesalz-ngrbzle mz melrmqgrng, mz da kc tqalepele Mevalu kc Tzmcpx.
\v 9 X Kxnzmcpx vz-kzp murde kxtrngiulrJiu naglqlz-kzlr Gct mz nzyckr drtwrde nidr x nzokatr-krde nidr. Da lc atutrle da kc tqpi Devet mz Nzryrngrkxtr kx, \qt “Gct, sa naglqlzx nim mz mzlir lr drtqbrng amrlx, mz nzangrlvz-krnge nim.”\qt* \x + \xo 15:9 \xt Sam 18:49; 2 Samwel 22:50\x*
\v 10 Rpi mou Nzryrngrkxtr kx, \qt “Nimu kcng trngiulrJiu, abrtz-lxblramu badr leplz neng Gct.”\qt* \x + \xo 15:10 \xt Lou Kcpwz 32:43\x*
\v 11 X rpi-moule kx, \qt “Glqpxamu Yawe nimu lr drtqbrng amrlx. X leplz mz nrlc tulvzo naglqlz-kzlr nide.”\qt* \x + \xo 15:11 \xt Sam 117:1\x*
\v 12 X rpi kz profet Asaea kx, \qt “King kxmrna sa naprpxm mz nqvi lr Jesi. X na-aclvele kxtrngiulrJiu. X sa na-abrtrpzlr drtwrdr bade.”\qt* \x + \xo 15:12 \xt Asaea 11:10\x* \f + \fr 15:12 \ft Jesi nide trte King Devet, x Jiszs Kxnzmcpx nide King kx prpxm mz nqvi lrdr. \f*
\p 
\v 13 Gct nide nou nzobqtipx-krgu da kcng sa na-alele kalr. X krka'-ngrne kx sa nakabzle bamu nzabrtzngr x nzmnc-zpwxng kcng tzvzpxmqng mz nzbrtikr drtwrmu nide, murde nzrlxngiti-krmu naetunepx zvz mz zmatq ngr Mqngrkxtr.
\p 
\v 14 Mzlengeng x inwengeng, krlz-angidrx kx amrlz-zvzamu leplz, x krlzpeamu da amrlx kx suti drtwr Gct nakrlzamu, x krlz-kzamu nzalvztr-lzbq-krmu.
\v 15 A' mz nzryr-krbo lc letz, rngidrlvz-ngrbo kzdung da bamu, kx nadcpxngr drtwrmu da kxmyapxbz. X alex da lc murde mz nzvz-nqblq-krde zmrlz ngrde kxmyalz, Gct atwzlr-ngrmle ninge
\v 16 mz nzokatr-krnge nimu kxtrngiulrJiu mz nzwztr-krbo mz Mevalu Jiszs. Apux pris kc tqvectrple leplz mz Gct, mz nzyapwxtipx-krbo Nrpakxmrlz mz kxtrngiulrJiu, murde nalxngiti-kzlr Kraes x natubqng mz nzobqkr Gct, mz nzapu-krdr blz kc tqatr Mqngrkxtr.
\p 
\v 17 X mz nzaxvctr-krbo mz Mevalu Jiszs, glqpx-lzbq-ngrne nzwztr-krbo mz Gct.
\v 18-19 A' sa naycmnetxtrpo mz nike ale Kraes mz nzaxvctr-krbo bade, mz nzmailz-krde leplz kcng trngiulrJiu mz nzvz-nqblq-krdr natq Gct. Murde batrpz Gct nzrlxngiti-krdr mz zmatq ngr Mqngrkxtr kc tqaelwapxpele mz nzryapwxtipx-krnge x mz nzale-krnge rkx x da kxnzkctipxng. Dekc tqyapwxtipx-zpwxbo Nrpa ngr Kraes, abzo Jerusalem vz vz krlzbzle Provins kc Ilirikzm.
\v 20 Zvz drtwrnge pq mz nzpipx-krbo Nrpakxmrlz mz lr mztea kcng trnzkrlzkalr Kraes. A' trsutiu drtwrnge nzalvztr-krnge lr mztea kcng tzxlrpelr Nrpa ngr Kraes.
\v 21 A' nzwz-krnge na-atutrle Nzryrngrkxtr kc tqycmnetr-ngrde Kraes mz nzrpi-krde kx, \qt “Leplz kcng trnzpi-kaipwzu badr nide, sa nakrlzlr nzalvztrngr angidr. X leplz kcng trnzxlr-kailru nrpa ngrde, nardr sa nayrplatrpz mz nrpa lc.”\qt* \x + \xo 15:21 \xt Asaea 52:15\x*
\v 22 X nzwrde kqlupe kx rpi-ngrne kx naoklati-ngrbo nimu. A' nzale-krnge nzwzngr lc rpwa'-ngrmle bange.
\s1 Pol Aoti Drtwrde Nzoklati-krde Lr Rom Kxnzrlxngiting
\p 
\v 23 A' mzli ka nzwz-krnge yrkrpxpe mz mztea lcdeng, murde trpengr mrka me nayapwxtingr mou Nrpakxmrlz. Delc, tqaotipengr drtwrnge nzoklati-krbo nimu, murde yiz kqlupe kx sutingr drtwrnge nzvz-krbo bamu.
\v 24 Sa naoklatibo nimu mzli kc navz-ngrne Spen. X sa naodutr-lxblrku mz kzdung mzli. X mz nibrde, suti drtwrnge naokatramu ninge mz nzvz-krnge Spen.
\v 25 A' mzli ka navz-kaix Jerusalem mz nzrtwz-krbo kzdung trau kx naokatrle lrmakxtr kx nzmncng elr.
\v 26 Murde dzbe lrmakxtr ngr provins kcng Masedonia x Akaia nzabrtz-ngrdr nzrkapx-krdr trau kx naokatrngr nra-nzlungr lrmakxtr kcng Jerusalem, mz nzodutr-lxblr-krdr badr.
\v 27 Eu. Nzabrtz-ngrdr nzrkapx-krdr, murde rblxbz mz kxtrngiulrJiu nzayzlu-krbzlr mz lr Jiu da kxnzmrlzting amrlx kcng tqkabz Gct badr mz nzaxvctr-krbzlr mz Mevalu kc tqesalz-ngrbzle mz lr Jiu. Delc takitrde kxtrngiulrJiu nzrka-krbzlr kzdung dztudrng mz nrlc ka mz nzokatr-krdr lr Jiu.
\v 28 Mz nibr nzrtwz-krnge trau kcng tzatakqtilr Jerusalem, ninge kc tqvz-atex Spen. X mz nzvz-krnge lc Spen, dekc naoklati-ngrbo nimu.
\v 29 Krlzx kx mzli kc navz-ngrmc bamu, Kraes sa na-amrlz-zlwzle nigu mz da kxkqlu.
\p 
\v 30-31 Mzlengeng x inwengeng, nigu dzbede kxesz' mz nzaxvctr-krbzku mz Kxetu rgu Jiszs Kxnzmcpx, x mz nzaodukr Mqngrkxtr nigu. Mz nzmu-krde lcde, drtwrgu naesz'ti kz mz nzkrka'-zvz-krgu ninge mz nzvz-krnge Jerusalem. Murde Gct na-arlapxle ninge mz provins kc Judiz, murde ma tzatrkatilr ninge lr Jiu kcng trnzlxngitilru Jiszs. X nakrka'-kz-ngrnamu kx leplz kxnztrng ne Gct kcng Jerusalem, na-abrtzlvzlr trau kc natwzbo badr.
\v 32 Nzmu kx tqsuti drtwr Gct le, sa naelalz-ngrm drtwrnge nzvz-krbo bamu, x sa na-apqtrpamu drtwrnge x na-amqngiamu nzrlxngiti-krnge mzli kc namnc-ngrgu.
\v 33 Krka'-ngrne kx Gct kc tqngi nou nzmnc-zpwxngr, namncbz bamu amrlx ngrmu. Eu, angida.
\c 16
\s1 Rpibz Pol “Nimu la,” Mz Kzdung Lr Rom
\p 
\v 1 Fibi kc tqrtwzbz letz lc bamu, nide inwegu kc tqwztrpz mz lrmakxtr kc mz taon Kenkrae, mz nzngini-krde kzdq kxaclvele dalr makxtr. Abrtzlvzx nide murde nide olvz kxmrlz-esz'ngr.
\v 2 Rlxtibo bamu nzaodu-krmu nide naesz' mz nzngini-krmu leplz neng Gct, murde wztrpz mz Kxetu. Okatramu nide mz nikeng suti drtwrde, murde okatr-zlwzle ninge x leplz kxnzkqlu.
\li1 
\v 3-4 Rpibzmu kx, “Nimu la,” mz kztengeng amrlx mrla, myapxbz Prisila x Akwila, nidr kx wztrpzkr badr mz Jiszs Kxnzmcpx, badr lrmakxtr kcng tzangio-lxblrng ma nyzdr. Ycpwz pipz nzbz-krdr mz nzarlapx-krdr ninge. X nigr badr lrmakxtr amrlx kcng trngiulrJiu awitx-zlwz-ngrbzkr mz Gct nidr.
\li1 
\v 5 X kztenge Epenetzs. Nide kx lxngiti-kaile Kraes mz provins kc Esia.
\li1 
\v 6 Mxri kc tqwz zlwz mz nzokatr-krde nimu.
\li1 
\v 7 Adronikzs x Junia, ni-kzdr lr Jiu. Mrlx lcng nzling mncpxmgr badr mz presin, x nidr aposol kxnzamatqng. Nidr rlilrdr kx nzlxngiti-kailr Kraes x ninge kc ate. \f + \fr 16:7 \ft Nzrpilr kx Junia ngi drtq olvz, kc tqngi kx aposol. \f*
\li1 
\v 8 X Ampliatzs, nide mzlenge kx mrlzvxi mz Kxetu.
\li1 
\v 9 Urbanzs, nide ncblo kx wzku badr mz nrlarde nyz Kraes. X mrlx kztenge Stakis.
\li1 
\v 10 Apelis kc tqaelwapx-ngrde nzpqkr nzlxngiti-krde Kraes, mz nztu-amqngi-krde mz mzlir nzkxpungr.
\li1 X lr ma nyz Aristobulzs.
\li1 
\v 11 X Herodion, ni-kzde lr Jiu.
\li1 X kxnzrlxngiting kcng tzmncng ma nyz Narsiszs.
\li1 
\v 12 Trifaena ncdr Trifosa, olvz kx nzwz-zlwzng mz nrlarde nyz Kxetu.
\li1 X inwegu Persis kxnzmrlzti. Nide kzdq kz olvz kx wz kato mz nrlarde nyz Kxetu.
\li1 
\v 13 X Rufzs, ncblo kxmyapxbz, x lxede kz kc tqapusr-ngrde ninge mrlxde.
\li1 
\v 14 Asinkritzs, Flegon, Hermes, Patrobas, Hermas x lrmakxtr amrlx kcng tzangio-lxblrng badr.
\li1 
\v 15 X Filologzs, Julia, Olimpas x Nerezs ncdr inwede, x leplz neng Gct amrlx kcng tzangio-lxblrng badr.
\li1 
\v 16 Eu, x rpi-etramu, “Nim la,” x male-lxblramu mqmu mz nivz. Lrmakxtr amrlx kcng tzmncng mrka nzrpibzlr bamu kx, “Nimu la.”
\s1 Natq Ngr Nzarlr-lzbqngr
\p 
\v 17 Mzlengeng x inwengeng, xplrmibz natqnge bamu, kx aclvetioamu leplz kcng tzakipxlr kxnzrlxngiting. Murde nzatrkatilr nzrlxngiti-krmu mz nzrpi-krbzlr da kx blepxngr mz nzalvztrngr kc tqkrlz-kaiamu. Kapx-lzbqmamu badr.
\v 18 Murde leplz kxnzmulr lcng trnzwztrpwzung mz Kraes, Kxetu rgu. A' nzvz-nqblq-txpwzlr alwx kznikeng nzaoti drtwrdr kx namrlzbz badr. Nztamiti-krdr leplz mz natq x nzalvztr-krbzlr badr da kxmrlz mz nzxlr-ngrbz, a' nzkrlzlr nzesabrtingr leplz kx trnzaclvetio-lzbqung mz nzalvztr-rbr-krdr lc.
\v 19 Leplz kxkqlu nzxlrpelr kx vz-nqblqpeamu Nrpakxmrlz. X mz nzmu-krde lcde, abrtztx-zlwz-ngrne nimu. A' suti drtwrnge nakrlz-angidramu da kxmrlz, x bzkq aoti drtwrmu da kxtrka.
\v 20 Murde ycpe pipz Gct kc tqngi nou nzmnc-zpwxngr, nzodati-krde zmatq ngr Setzn, mz nzokatr-krde nzaovxio-krmu leplz kcng tzrpilr na-akipxlr nimu. Krka'-ngrne kx Kxetu rgu Jiszs Kxnzmcpx naokatr-zvzle nimu mz zmrlz ngrde kxmyalz. Eu, angida.
\p 
\v 21 Kzdung lrmakxtr kcng mrka nzrpi-kzpzlr bamu, “Nimu la.” Kzdung nidr seleng, Timoti kc tqwzkr ncdr. X Lusias, Jeszn x Sospata, mrlx lcng nigr badr lr Jiu.
\v 22 X Tertizs kc tqyrbzle natqnge lcng.
\v 23 Gaizs kc tqmnckr ncdr ma nyzde, x kc tqrlr-ngrbzle mz lrmakxtr nzangio-krdr mrka. X wai-kzle Erastzs kc tqaclvele trau ngr taon ka, x mzlegu Kwartzs. \f + \fr 16:23 \ft Ngalrde kc 24 yclzm mz kzdung nzryrngr kcng pnz. X mule narsakrlrmi ngalrde kc 20, mz nzrpi-krde kx, \em “Eu, krka'-zvz-ngrne kx Kxetu rgu Jiszs Kxnzmcpx naokatrle nimu amrlx ngrmu mz zmrlz ngrde kxmyalz. Eu, angida.”\em* \f*
\s1 Nzrglqlzkr Pol Gct
\q1 
\v 25-26 Naglqlzku Gct kc tqkrlzle
\q1 Nzatu-amqngingr nimu amrlx
\q1 Mz nzlxngiti-krmu nrpa ngr
\q1 Jiszs Kxnzmcpx kc tqyapwxtipxx.
\b
\q1 Nrpakxmrlz lcde yc-kapq pnz
\q1 Mzli kc nrlc trnzwzka-ngrde.
\q1 A' mzli ka sc tqaelwapxpengr Gct
\q1 Kx suti drtwrde leplz amrlx.
\b
\q1 Na-arlapxle kxnzlxngitilr Kraes,
\q1 Kxmule-esz' nidr lr Jiu o trtingr.
\q1 Gct kc tqlu zvz kapxle natq
\q1 Kx natqde kcng pnz na-atutrpeng.
\b
\q1 Da kcng tzyro-pnzlr profet mz
\q1 Nzryrngrkxtr na-atutrng mzli ka.
\q1 Murde leplz mz nrlc tulvzo
\q1 Nalxngitilr Kraes mz nzmnc-krdr.
\b
\q1 
\v 27 Gct nide txpwz Gct kxyrplapx.
\q1 X nigu kcng tzaxvctrpzng mz Kraes
\q1 Jiszs Kxnzmcpx naglqlzku
\q1 Gct tqyc, tqyc. Eu, angida.
\b
\cls Delape. Ninge \sig Pol. \sig* 
