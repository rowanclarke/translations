\v 9 \w Le|strong="H7760"\w* jour où \w je|strong="H3808"\w* crierai \w à|strong="H7760"\w* \w toi|strong="H3808"\w*, \w mes|strong="H7760"\w* ennemis \w seront|strong="H3808"\w* repoussés \w en|strong="H7760"\w* arrière; \w je|strong="H3808"\w* sais \w que|strong="H3808"\w* \w Dieu|strong="H3808"\w* est \w pour|strong="H7760"\w* \w moi|strong="H3808"\w*.
\v 10 \w Je|strong="H3068"\w* louerai \w Dieu|strong="H3588"\w* \w et|strong="H3117"\w* \w sa|strong="H7725"\w* promesse; \w je|strong="H3588"\w* louerai l'Éternel \w et|strong="H3117"\w* \w sa|strong="H7725"\w* promesse.
\v 11 \w Je|strong="H3068"\w* m'assure \w en|strong="H3068"\w* \w Dieu|strong="H3068"\w*; \w je|strong="H3068"\w* \w ne|strong="H3068"\w* crains \w rien|strong="H1697"\w*; \w que|strong="H1697"\w* \w me|strong="H3068"\w* \w ferait|strong="H3068"\w* l'\w homme|strong="H3068"\w*?
\v 12 \w O|strong="H3068"\w* \w Dieu|strong="H6213"\w*, j'\w accomplirai|strong="H6213"\w* \w les|strong="H6213"\w* vœux \w que|strong="H3808"\w* \w je|strong="H3808"\w* t'\w ai|strong="H6213"\w* \w faits|strong="H6213"\w*; \w je|strong="H3808"\w* \w te|strong="H3808"\w* rendrai \w des|strong="H6213"\w* actions \w de|strong="H6213"\w* grâces.
\v 13 Car \w tu|strong="H5921"\w* as délivré \w mon|strong="H5921"\w* âme \w de|strong="H5921"\w* \w la|strong="H5921"\w* mort \w et|strong="H5921"\w* \w mes|strong="H7999"\w* pieds \w de|strong="H5921"\w* chute, afin \w que|strong="H5921"\w* \w je|strong="H5921"\w* marche devant \w Dieu|strong="H7999"\w*, \w dans|strong="H5921"\w* \w la|strong="H5921"\w* \w lumière|strong="H5921"\w* \w des|strong="H5921"\w* vivants.
\c 57
\p 
\v 1 \w Aie|strong="H6440"\w* pitié, ô \w Dieu|strong="H6440"\w*, \w aie|strong="H6440"\w* pitié \w de|strong="H6440"\w* \w moi|strong="H6440"\w*! \w Car|strong="H6440"\w* \w mon|strong="H6440"\w* âme \w se|strong="H1732"\w* retire \w vers|strong="H6440"\w* \w toi|strong="H6440"\w*; \w je|strong="H6440"\w* \w me|strong="H6440"\w* réfugie sous \w l|strong="H6440"\w*'ombre \w de|strong="H6440"\w* \w tes|strong="H6440"\w* ailes, jusqu'\w à|strong="H6440"\w* \w ce|strong="H6440"\w* \w que|strong="H6440"\w* \w les|strong="H6440"\w* calamités soient passées.
\v 2 \w Je|strong="H3068"\w* crie \w au|strong="H5704"\w* \w Dieu|strong="H3588"\w* Très-Haut, \w à|strong="H5704"\w* \w Dieu|strong="H3588"\w* \w qui|strong="H5315"\w* accomplit \w son|strong="H3588"\w* œuvre \w pour|strong="H5704"\w* \w moi|strong="H5315"\w*.
\v 3 \w Il|strong="H5921"\w* enverra \w des|strong="H5921"\w* cieux \w et|strong="H5921"\w* me sauvera. \w Il|strong="H5921"\w* rendra honteux \w celui|strong="H7121"\w* \w qui|strong="H7121"\w* me poursuit (Sélah); \w Dieu|strong="H5921"\w* enverra \w sa|strong="H5921"\w* bonté \w et|strong="H5921"\w* \w sa|strong="H5921"\w* vérité.
\v 4 \w Mon|strong="H7971"\w* âme \w est|strong="H2617"\w* \w au|strong="H7971"\w* milieu \w des|strong="H7971"\w* \w lions|strong="H7971"\w*; j'habite \w parmi|strong="H7971"\w* \w des|strong="H7971"\w* \w gens|strong="H7971"\w* \w qui|strong="H3467"\w* soufflent \w des|strong="H7971"\w* flammes, \w des|strong="H7971"\w* \w hommes|strong="H7971"\w* dont \w les|strong="H7971"\w* dents \w sont|strong="H8064"\w* \w des|strong="H7971"\w* \w lances|strong="H7971"\w* \w et|strong="H7971"\w* \w des|strong="H7971"\w* flèches, dont \w la|strong="H7971"\w* langue \w est|strong="H2617"\w* \w une|strong="H7971"\w* épée aiguë.
\v 5 \w O|strong="H3068"\w* \w Dieu|strong="H1121"\w*, élève-toi \w sur|strong="H5315"\w* \w les|strong="H1121"\w* cieux! \w Que|strong="H1121"\w* \w ta|strong="H1121"\w* gloire \w soit|strong="H5315"\w* \w sur|strong="H5315"\w* toute \w la|strong="H1121"\w* \w terre|strong="H8127"\w*!
\v 6 \w Ils|strong="H5921"\w* avaient tendu \w un|strong="H5921"\w* piège \w à|strong="H7311"\w* \w mes|strong="H5921"\w* pas; \w mon|strong="H7311"\w* \w âme|strong="H3519"\w* chancelait; \w ils|strong="H5921"\w* avaient creusé \w une|strong="H5921"\w* \w fosse|strong="H5921"\w* devant \w moi|strong="H5921"\w*; \w ils|strong="H5921"\w* y \w sont|strong="H8064"\w* tombés. (Sélah.)
\v 7 \w Mon|strong="H6440"\w* \w cœur|strong="H5315"\w* \w est|strong="H5315"\w* \w disposé|strong="H3559"\w*, ô \w Dieu|strong="H6440"\w*! \w mon|strong="H6440"\w* \w cœur|strong="H5315"\w* \w est|strong="H5315"\w* \w disposé|strong="H3559"\w*; \w je|strong="H5315"\w* chanterai, \w je|strong="H5315"\w* psalmodierai.
\v 8 Éveille-toi, ma gloire; éveillez-vous, \w mon|strong="H3820"\w* luth \w et|strong="H3820"\w* ma harpe! \w Je|strong="H3068"\w* préviendrai l'aurore.
\v 9 Seigneur, je \w te|strong="H3519"\w* louerai \w parmi|strong="H3519"\w* \w les|strong="H5782"\w* peuples; je \w te|strong="H3519"\w* célébrerai \w parmi|strong="H3519"\w* \w les|strong="H5782"\w* nations.
\v 10 Car \w ta|strong="H5971"\w* bonté atteint jusqu'\w aux|strong="H5971"\w* cieux, \w et|strong="H5971"\w* \w ta|strong="H5971"\w* fidélité jusqu'\w aux|strong="H5971"\w* nues.
\v 11 \w O|strong="H3068"\w* \w Dieu|strong="H3588"\w*, élève-toi \w sur|strong="H3588"\w* \w les|strong="H2617"\w* \w cieux|strong="H8064"\w*! \w Que|strong="H3588"\w* \w ta|strong="H3588"\w* gloire \w soit|strong="H3588"\w* \w sur|strong="H3588"\w* toute \w la|strong="H3588"\w* \w terre|strong="H5704"\w*!
\c 58
\p 
\v 1 Est-ce que vous prononcez vraiment \w selon|strong="H1732"\w* \w la|strong="H1732"\w* justice? \w Fils|strong="H1732"\w* \w des|strong="H1732"\w* \w hommes|strong="H1732"\w*, jugez-vous avec droiture?
\v 2 Loin \w de|strong="H1121"\w* \w là|strong="H1121"\w*; \w dans|strong="H1121"\w* \w votre|strong="H1696"\w* cœur \w vous|strong="H1121"\w* commettez \w des|strong="H1121"\w* iniquités, \w vous|strong="H1121"\w* ordonnez \w sur|strong="H1696"\w* \w la|strong="H1121"\w* \w terre|strong="H1696"\w* \w la|strong="H1121"\w* violence \w de|strong="H1121"\w* \w vos|strong="H1121"\w* mains.
\v 3 \w Les|strong="H3027"\w* \w méchants|strong="H5766"\w* \w se|strong="H3820"\w* \w sont|strong="H3027"\w* détournés \w dès|strong="H3027"\w* \w le|strong="H3027"\w* \w sein|strong="H3820"\w* maternel; \w les|strong="H3027"\w* menteurs \w se|strong="H3820"\w* \w sont|strong="H3027"\w* égarés \w dès|strong="H3027"\w* \w leur|strong="H3027"\w* naissance.
\v 4 Ils ont \w un|strong="H1696"\w* venin semblable \w au|strong="H1696"\w* venin \w du|strong="H1696"\w* serpent; ils \w sont|strong="H7563"\w* \w comme|strong="H1696"\w* l'aspic sourd, \w qui|strong="H7563"\w* ferme \w son|strong="H1696"\w* oreille;
\v 5 \w Qui|strong="H2795"\w* n'écoute point la voix \w des|strong="H2534"\w* enchanteurs, la voix \w du|strong="H2534"\w* charmeur expert \w en|strong="H3644"\w* charmes.
\v 6 \w O|strong="H3068"\w* \w Dieu|strong="H8085"\w*, brise-leur \w les|strong="H8085"\w* dents \w dans|strong="H6963"\w* \w la|strong="H8085"\w* \w bouche|strong="H8085"\w*! Éternel, romps \w les|strong="H8085"\w* mâchoires \w des|strong="H6963"\w* lionceaux!
\v 7 Qu'\w ils|strong="H6310"\w* s'écoulent \w comme|strong="H3068"\w* l'eau, \w et|strong="H3068"\w* qu'\w ils|strong="H6310"\w* \w se|strong="H3068"\w* dissipent! \w Quand|strong="H6310"\w* \w ils|strong="H6310"\w* bandent \w leur|strong="H3068"\w* arc, \w que|strong="H6310"\w* \w leurs|strong="H6310"\w* \w flèches|strong="H3068"\w* \w soient|strong="H3068"\w* rompues!
\v 8 Qu'\w ils|strong="H3644"\w* s'\w en|strong="H1980"\w* aillent \w comme|strong="H3644"\w* \w le|strong="H1980"\w* limaçon \w qui|strong="H4325"\w* \w se|strong="H4325"\w* fond; \w sans|strong="H1980"\w* voir \w le|strong="H1980"\w* soleil, \w comme|strong="H3644"\w* l'avorton d'\w une|strong="H3644"\w* femme!
\v 9 Avant que \w vos|strong="H1980"\w* chaudières aient senti \w le|strong="H1980"\w* feu \w des|strong="H1980"\w* épines, vertes ou enflammées, \w le|strong="H1980"\w* vent \w les|strong="H1980"\w* emportera.
\v 10 \w Le|strong="H2416"\w* juste \w se|strong="H2416"\w* réjouira lorsqu'\w il|strong="H2416"\w* aura vu \w la|strong="H2416"\w* vengeance; \w il|strong="H2416"\w* baignera ses pieds \w dans|strong="H2416"\w* \w le|strong="H2416"\w* sang \w du|strong="H2416"\w* méchant.
\v 11 \w Et|strong="H6662"\w* l'\w on|strong="H3588"\w* dira: Oui, \w il|strong="H7563"\w* \w y|strong="H6662"\w* \w a|strong="H3068"\w* \w du|strong="H1818"\w* fruit \w pour|strong="H3588"\w* \w le|strong="H3588"\w* \w juste|strong="H6662"\w*; oui, \w il|strong="H7563"\w* \w y|strong="H6662"\w* \w a|strong="H3068"\w* \w un|strong="H3588"\w* \w Dieu|strong="H3588"\w* \w qui|strong="H7563"\w* \w fait|strong="H7563"\w* \w justice|strong="H6662"\w* \w sur|strong="H3588"\w* \w la|strong="H3588"\w* \w terre|strong="H3588"\w*.
\c 59
\p 
\v 1 \w Mon|strong="H7971"\w* \w Dieu|strong="H1004"\w*, délivre-moi \w de|strong="H1004"\w* \w mes|strong="H8104"\w* ennemis; garantis-moi \w de|strong="H1004"\w* \w ceux|strong="H1004"\w* \w qui|strong="H4191"\w* s'élèvent \w contre|strong="H7971"\w* \w moi|strong="H1004"\w*!
\v 2 \w Délivre-moi|strong="H6965"\w* \w des|strong="H6965"\w* ouvriers d'iniquité, \w et|strong="H6965"\w* sauve-moi \w des|strong="H6965"\w* hommes sanguinaires!
\v 3 Car \w voilà|strong="H6466"\w*, ils sont aux aguets pour m'\w ôter|strong="H5337"\w* \w la|strong="H3467"\w* vie; \w des|strong="H1818"\w* \w hommes|strong="H6466"\w* puissants s'assemblent contre moi; sans qu'il y ait \w en|strong="H1818"\w* moi d'offense, \w ni|strong="H5337"\w* \w de|strong="H1818"\w* transgression, ô Éternel.
\v 4 \w Sans|strong="H3808"\w* \w qu|strong="H3588"\w*'\w il|strong="H3068"\w* \w y|strong="H3068"\w* \w ait|strong="H3068"\w* d'iniquité \w en|strong="H3068"\w* \w moi|strong="H5315"\w*, \w ils|strong="H5315"\w* accourent, \w ils|strong="H5315"\w* \w se|strong="H3068"\w* préparent; réveille-toi \w pour|strong="H3068"\w* \w venir|strong="H3068"\w* \w à|strong="H3068"\w* \w moi|strong="H5315"\w*, \w et|strong="H3068"\w* regarde!
\v 5 \w Toi|strong="H7323"\w* \w donc|strong="H7323"\w*, Éternel, \w Dieu|strong="H7200"\w* \w des|strong="H7200"\w* armées, \w Dieu|strong="H7200"\w* d'Israël, réveille-toi, visite \w toutes|strong="H7200"\w* \w les|strong="H7200"\w* nations; \w ne|strong="H7200"\w* \w fais|strong="H7200"\w* grâce \w à|strong="H7200"\w* aucun \w de|strong="H7200"\w* \w ces|strong="H7200"\w* \w hommes|strong="H7200"\w* perfides \w et|strong="H7200"\w* méchants. Sélah (pause).
\v 6 \w Ils|strong="H3068"\w* reviennent \w le|strong="H3068"\w* soir; hurlant \w comme|strong="H3068"\w* \w des|strong="H3068"\w* chiens, \w ils|strong="H3068"\w* parcourent \w la|strong="H3068"\w* ville.
\v 7 Voilà, \w ils|strong="H7725"\w* vomissent \w l|strong="H5892"\w*'injure \w de|strong="H5892"\w* \w leur|strong="H7725"\w* bouche; \w des|strong="H5892"\w* épées \w sont|strong="H5892"\w* \w sur|strong="H7725"\w* \w leurs|strong="H7725"\w* lèvres; car, disent-ils, \w qui|strong="H5892"\w* \w nous|strong="H5892"\w* entend?
\v 8 \w Mais|strong="H3588"\w* \w toi|strong="H3588"\w*, Éternel, \w tu|strong="H3588"\w* \w te|strong="H3588"\w* riras d'\w eux|strong="H2009"\w*; \w tu|strong="H3588"\w* \w te|strong="H3588"\w* moqueras \w de|strong="H6310"\w* \w toutes|strong="H8085"\w* \w les|strong="H8085"\w* nations.
\v 9 \w A|strong="H3068"\w* \w cause|strong="H3068"\w* \w de|strong="H3068"\w* \w leur|strong="H3068"\w* force, c'\w est|strong="H3068"\w* \w à|strong="H3068"\w* \w toi|strong="H3068"\w* \w que|strong="H1471"\w* \w je|strong="H3068"\w* regarde; car \w Dieu|strong="H3068"\w* \w est|strong="H3068"\w* \w ma|strong="H3068"\w* \w haute|strong="H3068"\w* retraite.
\v 10 \w Mon|strong="H3588"\w* \w Dieu|strong="H3588"\w*, dans \w sa|strong="H8104"\w* bonté, \w me|strong="H3588"\w* préviendra; \w Dieu|strong="H3588"\w* \w me|strong="H3588"\w* \w fera|strong="H3588"\w* contempler \w avec|strong="H8104"\w* joie \w mes|strong="H8104"\w* ennemis.
\v 11 \w Ne|strong="H7200"\w* \w les|strong="H7200"\w* tue \w pas|strong="H7200"\w*, \w de|strong="H7200"\w* peur \w que|strong="H7200"\w* \w mon|strong="H7200"\w* peuple \w ne|strong="H7200"\w* l'oublie; agite-les \w par|strong="H7200"\w* \w ta|strong="H7200"\w* \w puissance|strong="H7200"\w*, \w et|strong="H7200"\w* précipite-les, \w Seigneur|strong="H7200"\w*, \w notre|strong="H7200"\w* bouclier!
\v 12 Chaque parole \w de|strong="H5971"\w* \w leurs|strong="H2026"\w* lèvres \w est|strong="H5971"\w* \w un|strong="H5971"\w* péché \w de|strong="H5971"\w* \w leur|strong="H3381"\w* bouche; qu'\w ils|strong="H5971"\w* soient donc \w pris|strong="H5971"\w* \w dans|strong="H2428"\w* \w leur|strong="H3381"\w* \w orgueil|strong="H2026"\w*, \w à|strong="H5971"\w* cause \w des|strong="H5971"\w* imprécations \w et|strong="H5971"\w* \w des|strong="H5971"\w* mensonges qu'\w ils|strong="H5971"\w* profèrent!
\v 13 Consume-les \w avec|strong="H1697"\w* fureur, consume-les \w et|strong="H6310"\w* \w qu|strong="H1697"\w*'\w ils|strong="H6310"\w* \w ne|strong="H1697"\w* \w soient|strong="H1697"\w* \w plus|strong="H6310"\w*; \w et|strong="H6310"\w* \w qu|strong="H1697"\w*'\w on|strong="H6310"\w* sache \w que|strong="H1697"\w* \w Dieu|strong="H1697"\w* règne \w en|strong="H1697"\w* Jacob \w et|strong="H6310"\w* jusqu'\w aux|strong="H1697"\w* extrémités \w de|strong="H1697"\w* \w la|strong="H1697"\w* \w terre|strong="H1697"\w*. (Sélah. )
\v 14 \w Qu|strong="H3588"\w*'\w ils|strong="H3588"\w* reviennent \w le|strong="H3045"\w* soir, hurlant \w comme|strong="H3045"\w* \w des|strong="H3045"\w* chiens, \w et|strong="H3045"\w* parcourant \w la|strong="H3045"\w* ville;
\v 15 Qu'\w ils|strong="H7725"\w* aillent çà \w et|strong="H7725"\w* \w là|strong="H7725"\w*, cherchant \w à|strong="H7725"\w* manger, \w et|strong="H7725"\w* qu'\w ils|strong="H7725"\w* passent \w la|strong="H7725"\w* \w nuit|strong="H7725"\w* \w sans|strong="H5892"\w* être rassasiés!
\v 16 Mais \w moi|strong="H3808"\w*, \w je|strong="H3808"\w* chanterai \w ta|strong="H3808"\w* force; \w je|strong="H3808"\w* célébrerai \w dès|strong="H3808"\w* \w le|strong="H3808"\w* matin \w ta|strong="H3808"\w* bonté; car \w tu|strong="H3808"\w* as \w été|strong="H3808"\w* \w ma|strong="H3808"\w* haute retraite \w et|strong="H3808"\w* \w mon|strong="H3808"\w* refuge \w au|strong="H3885"\w* jour \w de|strong="H7646"\w* \w la|strong="H5128"\w* détresse.
\v 17 \w Toi|strong="H3117"\w*, \w ma|strong="H3117"\w* \w force|strong="H5797"\w*, \w je|strong="H3588"\w* \w te|strong="H3588"\w* psalmodierai. \w Car|strong="H3588"\w* \w Dieu|strong="H3588"\w* \w est|strong="H3117"\w* \w ma|strong="H3117"\w* \w haute|strong="H5797"\w* \w retraite|strong="H4869"\w* \w et|strong="H3117"\w* \w le|strong="H3117"\w* \w Dieu|strong="H3588"\w* \w qui|strong="H3117"\w* \w me|strong="H3588"\w* \w fait|strong="H1961"\w* voir \w sa|strong="H3117"\w* \w bonté|strong="H2617"\w*.
\c 60
\p 
\v 1 Lorsqu'\w il|strong="H1732"\w* \w fit|strong="H1732"\w* \w la|strong="H5921"\w* guerre avec \w les|strong="H1732"\w* Syriens \w de|strong="H5921"\w* Mésopotamie \w et|strong="H5921"\w* avec \w les|strong="H1732"\w* Syriens \w de|strong="H5921"\w* Tsoba, \w et|strong="H5921"\w* \w que|strong="H5921"\w* Joab revint \w et|strong="H5921"\w* défit douze mille Édomites \w dans|strong="H5921"\w* \w la|strong="H5921"\w* vallée \w du|strong="H5921"\w* Sel.
\v 2 \w O|strong="H3068"\w* \w Dieu|strong="H7725"\w*, \w tu|strong="H7725"\w* \w nous|strong="H7725"\w* \w as|strong="H7725"\w* rejetés, \w tu|strong="H7725"\w* \w nous|strong="H7725"\w* \w as|strong="H7725"\w* \w dispersés|strong="H7725"\w*, \w tu|strong="H7725"\w* t'\w es|strong="H7725"\w* irrité; rétablis-nous!
\v 3 \w Tu|strong="H7725"\w* \w as|strong="H7725"\w* \w fait|strong="H7725"\w* trembler \w la|strong="H7725"\w* \w terre|strong="H7725"\w*, \w tu|strong="H7725"\w* l'\w as|strong="H7725"\w* déchirée; répare \w ses|strong="H7725"\w* \w brèches|strong="H6555"\w*, car \w elle|strong="H7725"\w* est ébranlée.
\v 4 \w Tu|strong="H3588"\w* \w as|strong="H3588"\w* fait voir \w à|strong="H3588"\w* \w ton|strong="H3588"\w* peuple des choses dures; \w tu|strong="H3588"\w* \w nous|strong="H3588"\w* \w as|strong="H3588"\w* abreuvés d'\w un|strong="H3588"\w* vin d'étourdissement.
\v 5 Mais \w tu|strong="H7200"\w* \w as|strong="H7200"\w* donné \w à|strong="H7200"\w* \w ceux|strong="H5971"\w* \w qui|strong="H5971"\w* \w te|strong="H5971"\w* craignent \w un|strong="H7200"\w* étendard
\v 6 Afin \w que|strong="H6440"\w* \w tes|strong="H5414"\w* \w bien-aimés|strong="H5414"\w* soient délivrés; sauve-nous \w par|strong="H6440"\w* \w ta|strong="H5414"\w* droite, \w et|strong="H6440"\w* \w nous|strong="H6440"\w* \w exauce|strong="H5414"\w*!
\v 7 Dieu \w a|strong="H3068"\w* parlé dans \w son|strong="H2502"\w* sanctuaire; \w je|strong="H4616"\w* \w me|strong="H3225"\w* réjouirai; \w je|strong="H4616"\w* partagerai Sichem, \w et|strong="H6032"\w* \w je|strong="H4616"\w* mesurerai \w la|strong="H3467"\w* vallée \w de|strong="H3225"\w* Succoth:
\v 8 Galaad \w est|strong="H1696"\w* \w à|strong="H1696"\w* \w moi|strong="H1696"\w*; \w à|strong="H1696"\w* \w moi|strong="H1696"\w* Manassé; Éphraïm \w est|strong="H1696"\w* \w le|strong="H1696"\w* \w rempart|strong="H1696"\w* \w de|strong="H1696"\w* \w ma|strong="H6944"\w* tête; Juda \w mon|strong="H1696"\w* législateur;
\v 9 Moab \w est|strong="H7218"\w* \w le|strong="H7218"\w* bassin \w où|strong="H7218"\w* \w je|strong="H3063"\w* \w me|strong="H7218"\w* lave; \w je|strong="H3063"\w* jette mon soulier \w sur|strong="H7218"\w* Édom; terre \w des|strong="H7218"\w* Philistins, pousse \w des|strong="H7218"\w* acclamations \w à|strong="H3063"\w* mon honneur!
\v 10 Qui me conduira \w vers|strong="H7321"\w* \w la|strong="H5921"\w* ville forte? Qui me mènera jusqu'\w en|strong="H5921"\w* Édom?
\v 11 N'\w est-ce|strong="H4310"\w* \w pas|strong="H5704"\w* \w toi|strong="H5892"\w*, ô \w Dieu|strong="H5704"\w*, \w qui|strong="H4310"\w* \w nous|strong="H5892"\w* avais rejetés, \w qui|strong="H4310"\w* \w ne|strong="H5892"\w* sortais \w plus|strong="H5892"\w*, ô \w Dieu|strong="H5704"\w*, \w avec|strong="H5892"\w* \w nos|strong="H5892"\w* armées?
\v 12 Donne-nous \w du|strong="H3318"\w* secours \w pour|strong="H3318"\w* \w sortir|strong="H3318"\w* \w de|strong="H3318"\w* détresse; car
\v 13 \w En|strong="H8668"\w* Dieu nous combattrons avec vaillance, \w et|strong="H7723"\w* c'\w est|strong="H8668"\w* \w lui|strong="H6862"\w* \w qui|strong="H5833"\w* foulera \w nos|strong="H6862"\w* \w adversaires|strong="H6862"\w*.
\c 61
\p 
\v 1 \w O|strong="H3068"\w* \w Dieu|strong="H5921"\w*, écoute \w mon|strong="H5921"\w* cri, sois attentif \w à|strong="H1732"\w* \w ma|strong="H5921"\w* prière!
\v 2 \w Du|strong="H8085"\w* bout \w de|strong="H8085"\w* \w la|strong="H8085"\w* \w terre|strong="H8085"\w*, \w je|strong="H8085"\w* crie \w à|strong="H8085"\w* toi, \w quand|strong="H8085"\w* \w le|strong="H8085"\w* cœur me manque; conduis-moi sur \w ce|strong="H8085"\w* rocher, \w qui|strong="H8085"\w* \w est|strong="H8605"\w* trop élevé \w pour|strong="H8085"\w* moi.
\v 3 Car \w tu|strong="H4480"\w* \w as|strong="H7121"\w* \w été|strong="H7121"\w* \w mon|strong="H7121"\w* refuge, \w ma|strong="H7311"\w* forte tour \w devant|strong="H4480"\w* l'\w ennemi|strong="H7121"\w*.
\v 4 \w Je|strong="H3068"\w* séjournerai \w dans|strong="H6440"\w* \w ta|strong="H6440"\w* \w tente|strong="H6440"\w* \w à|strong="H6440"\w* jamais; \w je|strong="H3588"\w* \w me|strong="H6440"\w* retirerai sous \w l|strong="H6440"\w*'\w abri|strong="H4268"\w* \w de|strong="H6440"\w* \w tes|strong="H6440"\w* ailes. (Sélah.)
\v 5 Car tu as, ô \w Dieu|strong="H5769"\w*, exaucé mes vœux; tu m'as donné l'héritage \w de|strong="H5769"\w* ceux qui craignent \w ton|strong="H5769"\w* nom.
\v 6 \w Ajoute|strong="H5414"\w* \w des|strong="H5414"\w* \w jours|strong="H5414"\w* \w aux|strong="H5414"\w* \w jours|strong="H5414"\w* \w du|strong="H5414"\w* roi, \w et|strong="H8085"\w* \w que|strong="H3588"\w* \w ses|strong="H5414"\w* années \w soient|strong="H3588"\w* d'âge \w en|strong="H5414"\w* âge!
\v 7 Qu'\w il|strong="H4428"\w* siège \w à|strong="H8141"\w* \w toujours|strong="H3117"\w* \w devant|strong="H4428"\w* \w Dieu|strong="H4428"\w*! \w Donne-lui|strong="H3117"\w* \w pour|strong="H5921"\w* garde \w ta|strong="H5921"\w* bonté, \w ta|strong="H5921"\w* fidélité.
\v 8 \w Alors|strong="H3427"\w* \w je|strong="H6440"\w* chanterai \w ton|strong="H6440"\w* \w nom|strong="H3427"\w* \w à|strong="H3427"\w* \w jamais|strong="H5769"\w*, \w et|strong="H6440"\w* j'accomplirai \w mes|strong="H6440"\w* vœux \w chaque|strong="H6440"\w* \w jour|strong="H3427"\w*.
\c 62
\p 
\v 1 \w Mon|strong="H5921"\w* âme \w se|strong="H1732"\w* repose \w en|strong="H5921"\w* \w Dieu|strong="H5921"\w* seul; c'est \w de|strong="H5921"\w* \w lui|strong="H1732"\w* \w que|strong="H5921"\w* vient \w mon|strong="H5921"\w* salut.
\v 2 \w Lui|strong="H5315"\w* \w seul|strong="H5315"\w* \w est|strong="H5315"\w* \w mon|strong="H5315"\w* rocher, \w ma|strong="H5315"\w* \w délivrance|strong="H3444"\w*, \w ma|strong="H5315"\w* haute retraite; \w je|strong="H5315"\w* \w ne|strong="H3444"\w* serai pas beaucoup ébranlé.
\v 3 Jusques \w à|strong="H3808"\w* \w quand|strong="H3808"\w* \w vous|strong="H3808"\w* jetterez-vous sur \w un|strong="H3808"\w* \w homme|strong="H1931"\w*, \w pour|strong="H7227"\w* \w le|strong="H1931"\w* détruire tous ensemble, \w comme|strong="H3808"\w* \w un|strong="H3808"\w* mur \w qui|strong="H1931"\w* penche, \w comme|strong="H3808"\w* \w une|strong="H3808"\w* clôture \w ébranlée|strong="H4131"\w*?
\v 4 \w Ils|strong="H5921"\w* ne font \w que|strong="H5704"\w* consulter \w pour|strong="H5704"\w* \w le|strong="H5921"\w* \w faire|strong="H5921"\w* \w tomber|strong="H1760"\w* \w de|strong="H5921"\w* \w son|strong="H5186"\w* élévation; \w ils|strong="H5921"\w* \w se|strong="H7523"\w* plaisent \w au|strong="H5704"\w* mensonge; \w de|strong="H5921"\w* \w leur|strong="H5921"\w* bouche \w ils|strong="H5921"\w* bénissent, mais \w dans|strong="H5921"\w* \w leur|strong="H5921"\w* cœur \w ils|strong="H5921"\w* maudissent. (Sélah.)
\v 5 \w Mon|strong="H1288"\w* \w âme|strong="H1288"\w*, repose-toi sur \w Dieu|strong="H1288"\w* seul, car \w mon|strong="H1288"\w* attente \w est|strong="H6310"\w* \w en|strong="H7130"\w* \w lui|strong="H7130"\w*.
\v 6 \w Lui|strong="H5315"\w* \w seul|strong="H5315"\w* \w est|strong="H5315"\w* \w mon|strong="H3588"\w* rocher, \w ma|strong="H5315"\w* délivrance \w et|strong="H5315"\w* \w ma|strong="H5315"\w* haute retraite; \w je|strong="H3588"\w* \w ne|strong="H8615"\w* \w serai|strong="H3588"\w* \w point|strong="H3588"\w* ébranlé.
\v 7 \w En|strong="H3808"\w* \w Dieu|strong="H3808"\w* \w est|strong="H1931"\w* \w mon|strong="H1931"\w* \w salut|strong="H3444"\w* \w et|strong="H3808"\w* \w ma|strong="H3808"\w* gloire; \w mon|strong="H1931"\w* fort \w rocher|strong="H6697"\w*, \w mon|strong="H1931"\w* \w refuge|strong="H4869"\w* \w est|strong="H1931"\w* \w en|strong="H3808"\w* \w Dieu|strong="H3808"\w*.
\v 8 Peuples, confiez-vous \w en|strong="H5921"\w* \w lui|strong="H5921"\w* \w en|strong="H5921"\w* \w tout|strong="H5921"\w* temps; répandez \w votre|strong="H5921"\w* \w cœur|strong="H3519"\w* devant \w lui|strong="H5921"\w*; \w Dieu|strong="H5921"\w* \w est|strong="H3519"\w* \w notre|strong="H5921"\w* \w retraite|strong="H4268"\w*. (Sélah.)
\v 9 \w Les|strong="H6440"\w* \w petits|strong="H6440"\w* \w ne|strong="H5971"\w* \w sont|strong="H6440"\w* \w que|strong="H6440"\w* néant; \w les|strong="H6440"\w* grands \w ne|strong="H5971"\w* \w sont|strong="H6440"\w* \w que|strong="H6440"\w* mensonge; placés \w dans|strong="H6440"\w* \w la|strong="H6440"\w* balance, \w ils|strong="H5971"\w* \w seraient|strong="H6440"\w* \w tous|strong="H3605"\w* \w ensemble|strong="H5971"\w* \w plus|strong="H5971"\w* légers \w que|strong="H6440"\w* \w le|strong="H6440"\w* néant \w même|strong="H6440"\w*.
\v 10 \w Ne|strong="H1121"\w* \w vous|strong="H1121"\w* confiez \w pas|strong="H5927"\w* \w dans|strong="H1121"\w* \w la|strong="H1121"\w* violence, \w et|strong="H1121"\w* \w ne|strong="H1121"\w* \w soyez|strong="H1121"\w* \w pas|strong="H5927"\w* séduits \w par|strong="H5927"\w* \w la|strong="H1121"\w* rapine; \w si|strong="H1121"\w* \w les|strong="H1121"\w* richesses abondent, n'\w y|strong="H1121"\w* \w mettez|strong="H1121"\w* \w pas|strong="H5927"\w* \w votre|strong="H1121"\w* \w cœur|strong="H3162"\w*.
\v 11 \w Dieu|strong="H3588"\w* \w a|strong="H3068"\w* parlé \w une|strong="H7896"\w* fois, \w et|strong="H3820"\w* \w je|strong="H3588"\w* l'ai entendu \w deux|strong="H2428"\w* fois: c'\w est|strong="H3820"\w* \w que|strong="H3588"\w* \w la|strong="H3588"\w* \w force|strong="H2428"\w* appartient \w à|strong="H3588"\w* \w Dieu|strong="H3588"\w*.
\v 12 \w A|strong="H3068"\w* \w toi|strong="H3588"\w* \w aussi|strong="H1696"\w*, \w Seigneur|strong="H8085"\w*, \w la|strong="H8085"\w* miséricorde! \w Oui|strong="H8085"\w*, \w tu|strong="H3588"\w* rendras \w à|strong="H1696"\w* \w chacun|strong="H3588"\w* \w selon|strong="H1696"\w* \w son|strong="H3588"\w* œuvre.
\c 63
\p 
\v 1 \w O|strong="H3068"\w* \w Dieu|strong="H1961"\w*, \w tu|strong="H3063"\w* es \w mon|strong="H1961"\w* \w Dieu|strong="H1961"\w*, \w je|strong="H3063"\w* \w te|strong="H1732"\w* cherche \w au|strong="H1732"\w* point \w du|strong="H4057"\w* jour; \w mon|strong="H1961"\w* âme \w a|strong="H3068"\w* soif \w de|strong="H4057"\w* \w toi|strong="H1961"\w*, \w ma|strong="H4210"\w* chair \w te|strong="H1732"\w* souhaite, \w dans|strong="H1732"\w* \w cette|strong="H1732"\w* \w terre|strong="H4057"\w* aride, desséchée, \w sans|strong="H1961"\w* eau,
\v 2 \w Pour|strong="H5315"\w* voir ta force \w et|strong="H5315"\w* ta gloire, \w comme|strong="H5315"\w* \w je|strong="H5315"\w* t'ai contemplé \w dans|strong="H4325"\w* \w le|strong="H5315"\w* sanctuaire.
\v 3 \w Car|strong="H3651"\w* \w ta|strong="H7200"\w* bonté \w est|strong="H3519"\w* meilleure \w que|strong="H7200"\w* \w la|strong="H7200"\w* vie; \w mes|strong="H7200"\w* lèvres chanteront \w ta|strong="H7200"\w* louange.
\v 4 Ainsi \w je|strong="H3588"\w* \w te|strong="H3588"\w* bénirai pendant \w ma|strong="H3588"\w* \w vie|strong="H2416"\w*; j'élèverai \w mes|strong="H3588"\w* mains \w en|strong="H3588"\w* \w ton|strong="H2416"\w* nom.
\v 5 \w Mon|strong="H5375"\w* \w âme|strong="H1288"\w* \w est|strong="H8034"\w* rassasiée comme \w de|strong="H8034"\w* mœlle \w et|strong="H8034"\w* \w de|strong="H8034"\w* graisse; \w ma|strong="H5375"\w* bouche \w te|strong="H8034"\w* loue \w avec|strong="H8034"\w* \w des|strong="H2416"\w* cris \w de|strong="H8034"\w* réjouissance;
\v 6 \w Quand|strong="H6310"\w* \w je|strong="H5315"\w* \w me|strong="H5315"\w* souviens \w de|strong="H6310"\w* \w toi|strong="H5315"\w* \w sur|strong="H5315"\w* \w mon|strong="H5315"\w* lit, \w et|strong="H5315"\w* \w que|strong="H5315"\w* \w je|strong="H5315"\w* médite \w sur|strong="H5315"\w* \w toi|strong="H5315"\w* pendant \w les|strong="H5315"\w* veilles \w de|strong="H6310"\w* \w la|strong="H6310"\w* nuit.
\v 7 Car \w tu|strong="H5921"\w* as été \w mon|strong="H2142"\w* secours; aussi \w je|strong="H5921"\w* me réjouirai sous l'ombre \w de|strong="H5921"\w* \w tes|strong="H5921"\w* ailes.
\v 8 \w Mon|strong="H3588"\w* âme s'\w est|strong="H1961"\w* attachée \w à|strong="H1961"\w* \w toi|strong="H3588"\w* \w pour|strong="H3588"\w* \w te|strong="H3588"\w* suivre, \w et|strong="H1961"\w* \w ta|strong="H7442"\w* droite \w me|strong="H3588"\w* soutient.
\v 9 Mais \w ceux|strong="H5315"\w* \w qui|strong="H5315"\w* cherchent \w ma|strong="H5315"\w* \w vie|strong="H5315"\w* \w pour|strong="H5315"\w* \w la|strong="H5315"\w* détruire, descendront \w dans|strong="H5315"\w* \w les|strong="H5315"\w* profondeurs \w de|strong="H5315"\w* \w la|strong="H5315"\w* terre.
\v 10 \w Ils|strong="H1992"\w* \w seront|strong="H5315"\w* livrés \w au|strong="H5315"\w* tranchant \w de|strong="H5315"\w* l'épée; \w ils|strong="H1992"\w* \w seront|strong="H5315"\w* \w la|strong="H1245"\w* proie \w des|strong="H5315"\w* renards.
\v 11 Mais \w le|strong="H3027"\w* roi \w se|strong="H3027"\w* réjouira \w en|strong="H5921"\w* \w Dieu|strong="H3027"\w*, \w et|strong="H3027"\w* \w quiconque|strong="H3027"\w* \w jure|strong="H3027"\w* \w par|strong="H3027"\w* \w lui|strong="H3027"\w*, s'\w en|strong="H5921"\w* glorifiera; car \w la|strong="H5921"\w* bouche \w de|strong="H3027"\w* \w ceux|strong="H3027"\w* \w qui|strong="H3027"\w* parlent faussement \w sera|strong="H1961"\w* fermée.
\c 64
\p 
\v 1 \w O|strong="H3068"\w* \w Dieu|strong="H1732"\w*, écoute \w ma|strong="H4210"\w* voix quand je parle; garantis \w ma|strong="H4210"\w* vie contre \w l|strong="H1732"\w*'ennemi \w qui|strong="H1732"\w* m'épouvante!
\v 2 Mets-moi \w à|strong="H8085"\w* couvert \w du|strong="H6963"\w* complot \w des|strong="H2416"\w* méchants, \w du|strong="H6963"\w* \w tumulte|strong="H6963"\w* \w des|strong="H2416"\w* ouvriers d'iniquité;
\v 3 \w Qui|strong="H5475"\w* aiguisent leur langue \w comme|strong="H7489"\w* une épée, \w qui|strong="H5475"\w* ajustent \w comme|strong="H7489"\w* une flèche leur parole amère,
\v 4 \w Pour|strong="H1697"\w* tirer \w en|strong="H1697"\w* secret sur l'innocent; \w ils|strong="H2719"\w* tirent soudain contre \w lui|strong="H1697"\w*, \w et|strong="H1697"\w* n'\w ont|strong="H1697"\w* point \w de|strong="H1697"\w* crainte.
\v 5 \w Ils|strong="H3808"\w* s'affermissent \w dans|strong="H3808"\w* \w un|strong="H3808"\w* \w mauvais|strong="H3808"\w* dessein; \w ils|strong="H3808"\w* \w ne|strong="H3808"\w* parlent \w que|strong="H3808"\w* \w de|strong="H3372"\w* cacher \w des|strong="H3808"\w* pièges; \w ils|strong="H3808"\w* \w disent|strong="H3808"\w*: \w Qui|strong="H3808"\w* \w le|strong="H3372"\w* \w verra|strong="H3808"\w*?
\v 6 \w Ils|strong="H7451"\w* inventent \w des|strong="H1697"\w* fraudes: \w Nous|strong="H7200"\w* \w voilà|strong="H1697"\w* prêts; \w le|strong="H7200"\w* plan \w est|strong="H1697"\w* formé! \w Et|strong="H7200"\w* \w leur|strong="H7200"\w* pensée secrète, \w le|strong="H7200"\w* cœur \w de|strong="H1697"\w* \w chacun|strong="H1697"\w* \w est|strong="H1697"\w* \w un|strong="H7200"\w* abîme.
\v 7 Mais \w Dieu|strong="H3820"\w* \w leur|strong="H7130"\w* lance \w une|strong="H3820"\w* flèche; soudain \w les|strong="H3820"\w* voilà frappés.
\v 8 \w Ceux|strong="H1961"\w* \w que|strong="H1961"\w* \w leur|strong="H1961"\w* langue attaquait, \w les|strong="H1961"\w* \w ont|strong="H1961"\w* renversés; tous \w ceux|strong="H1961"\w* \w qui|strong="H2671"\w* \w les|strong="H1961"\w* voient hochent \w la|strong="H1961"\w* tête.
\v 9 \w Les|strong="H7200"\w* \w hommes|strong="H7200"\w* \w sont|strong="H7200"\w* \w tous|strong="H3605"\w* saisis \w de|strong="H5921"\w* crainte; \w ils|strong="H5921"\w* racontent l'œuvre \w de|strong="H5921"\w* \w Dieu|strong="H7200"\w*, \w et|strong="H7200"\w* considèrent \w ce|strong="H3605"\w* qu'\w il|strong="H5921"\w* \w a|strong="H3068"\w* \w fait|strong="H3956"\w*.
\v 10 \w Le|strong="H5046"\w* juste \w se|strong="H6467"\w* réjouira \w en|strong="H4639"\w* l'Éternel, \w et|strong="H5046"\w* \w se|strong="H6467"\w* retirera vers \w lui|strong="H3372"\w*; \w tous|strong="H3605"\w* \w ceux|strong="H3605"\w* \w qui|strong="H3605"\w* ont \w le|strong="H5046"\w* \w cœur|strong="H5046"\w* droit s'\w en|strong="H4639"\w* glorifieront.
\c 65
\p 
\v 1 \w O|strong="H3068"\w* \w Dieu|strong="H1732"\w*, \w la|strong="H1732"\w* louange t'attend \w dans|strong="H1732"\w* Sion; \w là|strong="H1732"\w* seront rendus \w les|strong="H1732"\w* vœux qu'on t'\w a|strong="H3068"\w* faits.
\v 2 \w O|strong="H3068"\w* toi qui entends \w la|strong="H7999"\w* prière, toute créature viendra jusqu'\w à|strong="H7999"\w* toi.
\v 3 \w Les|strong="H8085"\w* iniquités avaient prévalu \w sur|strong="H5704"\w* \w moi|strong="H5704"\w*; mais \w toi|strong="H5704"\w*, \w tu|strong="H8085"\w* expieras \w nos|strong="H3605"\w* transgressions.
\v 4 Heureux \w celui|strong="H1697"\w* \w que|strong="H1697"\w* \w tu|strong="H1697"\w* choisis, \w et|strong="H1697"\w* \w que|strong="H1697"\w* \w tu|strong="H1697"\w* fais habiter \w dans|strong="H1697"\w* \w tes|strong="H1697"\w* parvis! \w Nous|strong="H5771"\w* serons rassasiés \w des|strong="H1697"\w* biens \w de|strong="H1697"\w* \w ta|strong="H4480"\w* \w maison|strong="H1697"\w*, \w de|strong="H1697"\w* \w la|strong="H4480"\w* sainteté \w de|strong="H1697"\w* \w ton|strong="H1697"\w* palais.
\v 5 \w Tu|strong="H1004"\w* \w nous|strong="H1004"\w* répondras \w par|strong="H7126"\w* \w des|strong="H1004"\w* œuvres redoutables, \w selon|strong="H1004"\w* \w ta|strong="H1004"\w* justice, ô \w Dieu|strong="H1004"\w* \w de|strong="H1004"\w* \w notre|strong="H1004"\w* salut, l'espoir \w des|strong="H1004"\w* extrémités lointaines \w de|strong="H1004"\w* \w la|strong="H1004"\w* \w terre|strong="H1004"\w* \w et|strong="H1004"\w* \w de|strong="H1004"\w* \w la|strong="H1004"\w* mer!
\v 6 \w Il|strong="H7350"\w* tient ferme \w les|strong="H3605"\w* montagnes \w par|strong="H6030"\w* \w sa|strong="H3372"\w* force; \w il|strong="H7350"\w* \w est|strong="H3220"\w* ceint \w de|strong="H3372"\w* puissance.
\v 7 \w Il|strong="H3581"\w* apaise \w le|strong="H3559"\w* bruit \w des|strong="H2022"\w* mers, \w le|strong="H3559"\w* bruit \w de|strong="H2022"\w* \w leurs|strong="H2022"\w* flots \w et|strong="H2022"\w* \w la|strong="H3559"\w* rumeur \w des|strong="H2022"\w* peuples.
\v 8 \w Et|strong="H3220"\w* ceux qui habitent aux bouts \w de|strong="H3220"\w* \w la|strong="H7623"\w* terre, craignent \w à|strong="H3220"\w* \w la|strong="H7623"\w* vue \w de|strong="H3220"\w* \w tes|strong="H7623"\w* prodiges; tu fais chanter \w de|strong="H3220"\w* joie \w et|strong="H3220"\w* \w le|strong="H3220"\w* Levant \w et|strong="H3220"\w* \w le|strong="H3220"\w* Couchant.
\v 9 \w Tu|strong="H1242"\w* visites \w la|strong="H3427"\w* \w terre|strong="H3427"\w*, \w tu|strong="H1242"\w* l'arroses, \w tu|strong="H1242"\w* l'enrichis abondamment; \w les|strong="H3427"\w* ruisseaux \w de|strong="H3427"\w* \w Dieu|strong="H3427"\w* \w sont|strong="H3427"\w* pleins d'eau; \w tu|strong="H1242"\w* prépares \w leur|strong="H3427"\w* froment, après \w que|strong="H1242"\w* \w tu|strong="H1242"\w* as ainsi préparé \w la|strong="H3427"\w* \w terre|strong="H3427"\w*.
\v 10 \w Tu|strong="H3588"\w* abreuves \w ses|strong="H6485"\w* sillons; \w tu|strong="H3588"\w* aplanis \w ses|strong="H6485"\w* mottes; \w tu|strong="H3588"\w* l'amollis \w par|strong="H3559"\w* \w la|strong="H4390"\w* \w pluie|strong="H4325"\w* menue; \w tu|strong="H3588"\w* bénis \w son|strong="H3588"\w* germe.
\v 11 Tu couronnes l'année \w de|strong="H1288"\w* \w tes|strong="H1288"\w* biens, \w et|strong="H1288"\w* \w les|strong="H1288"\w* roues \w de|strong="H1288"\w* \w ton|strong="H1288"\w* char distillent l'abondance.
\v 12 Elles \w la|strong="H8141"\w* \w répandent|strong="H7491"\w* \w sur|strong="H8141"\w* \w les|strong="H2896"\w* pâturages \w du|strong="H8141"\w* désert, \w et|strong="H2896"\w* \w les|strong="H2896"\w* coteaux \w sont|strong="H2896"\w* parés \w de|strong="H8141"\w* \w joie|strong="H2896"\w*.
\v 13 \w Les|strong="H4057"\w* campagnes \w sont|strong="H4057"\w* revêtues \w de|strong="H4057"\w* troupeaux, et \w les|strong="H4057"\w* vallées \w sont|strong="H4057"\w* couvertes \w de|strong="H4057"\w* froment; elles \w en|strong="H4057"\w* triomphent, et elles \w en|strong="H4057"\w* chantent.
\c 66
\p 
\v 1 Chantez la gloire \w de|strong="H4210"\w* \w son|strong="H3605"\w* nom; louez-le, et lui rendez gloire!
\v 2 Dites \w à|strong="H7760"\w* \w Dieu|strong="H7760"\w*: \w Que|strong="H8034"\w* \w tes|strong="H7760"\w* œuvres \w sont|strong="H8034"\w* redoutables! \w A|strong="H3068"\w* cause \w de|strong="H8034"\w* \w la|strong="H7760"\w* grandeur \w de|strong="H8034"\w* \w ta|strong="H7760"\w* force, \w tes|strong="H7760"\w* ennemis viendront \w se|strong="H8034"\w* soumettre \w à|strong="H7760"\w* \w toi|strong="H8034"\w*.
\v 3 \w Toute|strong="H7230"\w* \w la|strong="H7230"\w* terre se prosternera \w devant|strong="H3584"\w* toi; elle chantera \w en|strong="H4639"\w* \w ton|strong="H3372"\w* \w honneur|strong="H5797"\w*, elle chantera \w ton|strong="H3372"\w* nom. (Sélah.)
\v 4 Venez, \w et|strong="H8034"\w* voyez \w les|strong="H3605"\w* œuvres \w de|strong="H8034"\w* \w Dieu|strong="H8034"\w*; \w il|strong="H3605"\w* \w est|strong="H8034"\w* redoutable \w dans|strong="H8034"\w* \w ce|strong="H3605"\w* qu'\w il|strong="H3605"\w* fait envers \w les|strong="H3605"\w* \w fils|strong="H8034"\w* \w des|strong="H8034"\w* hommes.
\v 5 \w Il|strong="H1121"\w* \w a|strong="H3068"\w* changé \w la|strong="H7200"\w* \w mer|strong="H5921"\w* \w en|strong="H3212"\w* \w terre|strong="H5921"\w* sèche; \w on|strong="H1121"\w* passait \w à|strong="H1121"\w* pied \w dans|strong="H5921"\w* \w le|strong="H7200"\w* fleuve; \w là|strong="H7200"\w* \w nous|strong="H3212"\w* \w nous|strong="H3212"\w* sommes réjouis \w en|strong="H3212"\w* \w lui|strong="H5921"\w*.
\v 6 \w Il|strong="H5674"\w* domine éternellement \w par|strong="H5674"\w* \w sa|strong="H5674"\w* puissance; \w ses|strong="H5674"\w* \w yeux|strong="H7272"\w* observent \w les|strong="H5674"\w* nations, \w pour|strong="H3220"\w* \w que|strong="H8033"\w* \w les|strong="H5674"\w* rebelles \w ne|strong="H7272"\w* s'\w élèvent|strong="H5674"\w* \w pas|strong="H7272"\w*. (Sélah.)
\v 7 \w Peuples|strong="H1471"\w*, bénissez \w notre|strong="H7311"\w* \w Dieu|strong="H5769"\w*, \w et|strong="H5869"\w* faites entendre \w la|strong="H7311"\w* voix \w de|strong="H5869"\w* \w sa|strong="H1471"\w* \w louange|strong="H7311"\w*!
\v 8 \w Lui|strong="H5971"\w* \w qui|strong="H5971"\w* \w a|strong="H3068"\w* conservé \w la|strong="H8085"\w* vie \w à|strong="H5971"\w* \w notre|strong="H8085"\w* \w âme|strong="H1288"\w*, \w et|strong="H8085"\w* \w qui|strong="H5971"\w* n'\w a|strong="H3068"\w* \w pas|strong="H8085"\w* permis \w que|strong="H8085"\w* \w nos|strong="H8085"\w* pieds bronchassent.
\v 9 Car \w tu|strong="H5414"\w* \w nous|strong="H3808"\w* \w as|strong="H5414"\w* éprouvés, ô \w Dieu|strong="H5414"\w*; \w tu|strong="H5414"\w* \w nous|strong="H3808"\w* \w as|strong="H5414"\w* \w fait|strong="H5414"\w* \w passer|strong="H3808"\w* \w au|strong="H5414"\w* creuset \w comme|strong="H5414"\w* l'\w argent|strong="H3808"\w*.
\v 10 \w Tu|strong="H3588"\w* \w nous|strong="H3588"\w* \w avais|strong="H3588"\w* amenés \w dans|strong="H3701"\w* \w le|strong="H3588"\w* filet; \w tu|strong="H3588"\w* \w avais|strong="H3588"\w* mis \w sur|strong="H3588"\w* nos reins \w un|strong="H3588"\w* pesant fardeau;
\v 11 \w Tu|strong="H7760"\w* avais \w fait|strong="H7760"\w* monter \w les|strong="H7760"\w* \w hommes|strong="H7760"\w* \w sur|strong="H7760"\w* \w nos|strong="H7760"\w* têtes; \w nous|strong="H7760"\w* étions entrés \w dans|strong="H7760"\w* \w le|strong="H7760"\w* \w feu|strong="H7760"\w* \w et|strong="H7760"\w* \w dans|strong="H7760"\w* l'eau; mais \w tu|strong="H7760"\w* \w nous|strong="H7760"\w* as \w mis|strong="H7760"\w* \w au|strong="H7760"\w* large \w et|strong="H7760"\w* \w dans|strong="H7760"\w* l'abondance.
\v 12 \w J|strong="H3068"\w*'entrerai \w dans|strong="H3318"\w* \w ta|strong="H3318"\w* \w maison|strong="H7218"\w* \w avec|strong="H3318"\w* \w des|strong="H7218"\w* holocaustes; \w et|strong="H3318"\w* \w je|strong="H3318"\w* \w te|strong="H4325"\w* rendrai \w mes|strong="H3318"\w* vœux,
\v 13 \w Que|strong="H1004"\w* \w mes|strong="H7999"\w* lèvres ont proférés \w et|strong="H1004"\w* \w que|strong="H1004"\w* \w ma|strong="H1004"\w* bouche \w a|strong="H3068"\w* prononcés \w dans|strong="H1004"\w* \w ma|strong="H1004"\w* détresse.
\v 14 \w Je|strong="H3068"\w* t'offrirai \w des|strong="H1696"\w* brebis grasses \w en|strong="H1696"\w* holocauste, \w avec|strong="H1696"\w* \w les|strong="H1696"\w* béliers fumant \w sur|strong="H1696"\w* l'autel; \w je|strong="H6310"\w* sacrifierai \w des|strong="H1696"\w* taureaux \w avec|strong="H1696"\w* \w des|strong="H1696"\w* boucs. (Sélah.)
\v 15 \w Vous|strong="H6213"\w* \w tous|strong="H6213"\w* \w qui|strong="H1241"\w* craignez \w Dieu|strong="H6213"\w*, venez, écoutez, \w et|strong="H5927"\w* \w je|strong="H5927"\w* raconterai \w ce|strong="H6213"\w* qu'\w il|strong="H6213"\w* \w a|strong="H3068"\w* \w fait|strong="H6213"\w* \w à|strong="H6213"\w* \w mon|strong="H6213"\w* âme.
\v 16 \w Je|strong="H3068"\w* l'\w ai|strong="H6213"\w* invoqué \w de|strong="H6213"\w* \w ma|strong="H8085"\w* \w bouche|strong="H5315"\w*; \w aussi|strong="H6213"\w* \w ma|strong="H8085"\w* langue l'exaltera.
\v 17 Si j'eusse pensé quelque iniquité \w dans|strong="H6310"\w* \w mon|strong="H7121"\w* cœur, \w le|strong="H7121"\w* \w Seigneur|strong="H7121"\w* \w ne|strong="H3956"\w* m'eût \w point|strong="H7121"\w* écouté.
\v 18 Mais \w certainement|strong="H3808"\w* \w Dieu|strong="H7200"\w* m'\w a|strong="H3068"\w* \w écouté|strong="H8085"\w*; \w il|strong="H3820"\w* \w a|strong="H3068"\w* prêté l'\w oreille|strong="H8085"\w* \w à|strong="H7200"\w* \w la|strong="H8085"\w* \w voix|strong="H8085"\w* \w de|strong="H3820"\w* \w ma|strong="H8085"\w* prière.
\v 19 Béni \w soit|strong="H6963"\w* \w Dieu|strong="H8085"\w* \w qui|strong="H6963"\w* n'\w a|strong="H3068"\w* \w point|strong="H8085"\w* rejeté \w ma|strong="H8085"\w* \w prière|strong="H8605"\w*, \w ni|strong="H6963"\w* retiré \w de|strong="H6963"\w* \w moi|strong="H6963"\w* \w sa|strong="H8085"\w* bonté!
\c 67
\p 
\v 1 Que Dieu ait pitié \w de|strong="H4210"\w* nous et nous bénisse; qu'il fasse luire sa face sur nous! (Sélah.)
\v 2 Afin \w que|strong="H6440"\w* \w ta|strong="H6440"\w* voie \w soit|strong="H1288"\w* connue \w sur|strong="H6440"\w* \w la|strong="H6440"\w* \w terre|strong="H6440"\w*, \w et|strong="H6440"\w* \w ton|strong="H6440"\w* salut \w parmi|strong="H6440"\w* \w toutes|strong="H6440"\w* \w les|strong="H6440"\w* nations.
\v 3 \w Les|strong="H3605"\w* \w peuples|strong="H1471"\w* \w te|strong="H1870"\w* célébreront, ô \w Dieu|strong="H3045"\w*; \w tous|strong="H3605"\w* \w les|strong="H3605"\w* \w peuples|strong="H1471"\w* \w te|strong="H1870"\w* célébreront.
\v 4 \w Les|strong="H3605"\w* nations \w se|strong="H5971"\w* réjouiront \w et|strong="H5971"\w* chanteront \w de|strong="H5971"\w* joie; car \w tu|strong="H5971"\w* jugeras \w les|strong="H3605"\w* \w peuples|strong="H5971"\w* \w avec|strong="H5971"\w* droiture, \w et|strong="H5971"\w* \w tu|strong="H5971"\w* conduiras \w les|strong="H3605"\w* nations sur \w la|strong="H5971"\w* \w terre|strong="H5971"\w*.
\v 5 \w Les|strong="H5971"\w* \w peuples|strong="H5971"\w* \w te|strong="H5971"\w* célébreront, ô \w Dieu|strong="H3588"\w*; \w tous|strong="H5971"\w* \w les|strong="H5971"\w* \w peuples|strong="H5971"\w* \w te|strong="H5971"\w* célébreront.
\v 6 \w La|strong="H5971"\w* \w terre|strong="H5971"\w* \w a|strong="H3068"\w* donné \w son|strong="H3034"\w* \w fruit|strong="H3605"\w*; \w Dieu|strong="H5971"\w*, \w notre|strong="H3605"\w* \w Dieu|strong="H5971"\w*, \w nous|strong="H5971"\w* bénira.
\v 7 \w Dieu|strong="H5414"\w* \w nous|strong="H5414"\w* \w bénira|strong="H1288"\w*, \w et|strong="H5414"\w* \w toutes|strong="H5414"\w* \w les|strong="H5414"\w* \w extrémités|strong="H5414"\w* \w de|strong="H5414"\w* \w la|strong="H5414"\w* \w terre|strong="H5414"\w* \w le|strong="H5414"\w* craindront.
\c 68
\p 
\v 1 Que \w Dieu|strong="H1732"\w* \w se|strong="H1732"\w* lève, \w et|strong="H1732"\w* ses ennemis seront dispersés, \w et|strong="H1732"\w* ceux \w qui|strong="H1732"\w* \w le|strong="H1732"\w* haïssent s'enfuiront devant \w lui|strong="H1732"\w*.
\v 2 \w Tu|strong="H6440"\w* \w les|strong="H6440"\w* dissiperas \w comme|strong="H6965"\w* \w la|strong="H6440"\w* fumée \w se|strong="H6440"\w* dissipe; \w comme|strong="H6965"\w* \w la|strong="H6440"\w* cire \w se|strong="H6440"\w* fond \w au|strong="H6440"\w* \w feu|strong="H6440"\w*, \w ainsi|strong="H6965"\w* périront \w les|strong="H6440"\w* méchants \w devant|strong="H6440"\w* \w Dieu|strong="H6440"\w*.
\v 3 Mais \w les|strong="H6440"\w* justes \w se|strong="H6440"\w* réjouiront, \w ils|strong="H6440"\w* triompheront \w devant|strong="H6440"\w* \w Dieu|strong="H6440"\w*, \w et|strong="H6440"\w* tressailleront \w de|strong="H6440"\w* joie.
\v 4 Chantez \w à|strong="H6440"\w* \w Dieu|strong="H6440"\w*, célébrez \w son|strong="H6440"\w* \w nom|strong="H6440"\w*, préparez \w le|strong="H6440"\w* chemin \w à|strong="H6440"\w* \w celui|strong="H6440"\w* \w qui|strong="H6662"\w* s'\w avance|strong="H6440"\w* \w dans|strong="H6440"\w* \w les|strong="H6440"\w* plaines! \w L|strong="H3068"\w*'Éternel \w est|strong="H6440"\w* \w son|strong="H6440"\w* \w nom|strong="H6440"\w*; réjouissez-vous \w devant|strong="H6440"\w* \w lui|strong="H6440"\w*!
\v 5 \w Le|strong="H6440"\w* \w père|strong="H6440"\w* \w des|strong="H6440"\w* orphelins \w et|strong="H6440"\w* \w le|strong="H6440"\w* défenseur \w des|strong="H6440"\w* veuves, c'\w est|strong="H8034"\w* \w Dieu|strong="H6440"\w*, \w dans|strong="H6440"\w* \w sa|strong="H6440"\w* demeure sainte.
\v 6 Dieu fait habiter en famille ceux qui \w étaient|strong="H3490"\w* seuls; \w il|strong="H6944"\w* délivre \w les|strong="H6944"\w* captifs, \w et|strong="H6944"\w* \w les|strong="H6944"\w* met au large; mais \w les|strong="H6944"\w* rebelles demeurent \w dans|strong="H6944"\w* \w des|strong="H6944"\w* lieux arides.
\v 7 \w O|strong="H3068"\w* \w Dieu|strong="H1004"\w*, quand \w tu|strong="H1004"\w* \w sortis|strong="H3318"\w* \w devant|strong="H1004"\w* \w ton|strong="H3318"\w* \w peuple|strong="H3318"\w*, quand \w tu|strong="H1004"\w* marchas \w dans|strong="H3427"\w* \w le|strong="H3318"\w* \w désert|strong="H3318"\w*, \w -|strong="H1004"\w* Sélah (pause), \w -|strong="H1004"\w*
\v 8 \w La|strong="H6440"\w* \w terre|strong="H6440"\w* trembla, \w les|strong="H6440"\w* cieux \w mêmes|strong="H6440"\w* \w se|strong="H5971"\w* fondirent \w en|strong="H5971"\w* eau \w devant|strong="H6440"\w* \w Dieu|strong="H6440"\w*; \w le|strong="H6440"\w* Sinaï \w même|strong="H6440"\w* trembla \w devant|strong="H6440"\w* \w Dieu|strong="H6440"\w*, \w le|strong="H6440"\w* \w Dieu|strong="H6440"\w* \w d|strong="H6440"\w*'Israël.
\v 9 \w Tu|strong="H3478"\w* répandis \w une|strong="H6440"\w* pluie bienfaisante, ô \w Dieu|strong="H6440"\w*; \w tu|strong="H3478"\w* rendis \w la|strong="H6440"\w* force \w à|strong="H3478"\w* \w ton|strong="H6440"\w* héritage épuisé.
\v 10 \w Ton|strong="H3559"\w* troupeau habita \w dans|strong="H3559"\w* cette terre \w que|strong="H5159"\w* \w ta|strong="H3559"\w* bonté, ô Dieu, avait \w préparée|strong="H3559"\w* \w pour|strong="H3559"\w* l'affligé.
\v 11 \w Le|strong="H3427"\w* \w Seigneur|strong="H3427"\w* \w fait|strong="H2896"\w* entendre \w sa|strong="H3559"\w* parole, \w et|strong="H3427"\w* \w les|strong="H3427"\w* messagères \w de|strong="H3427"\w* \w bonnes|strong="H2896"\w* nouvelles \w sont|strong="H3427"\w* \w une|strong="H3559"\w* \w grande|strong="H2896"\w* armée.
\v 12 \w Les|strong="H5414"\w* rois \w des|strong="H5414"\w* \w armées|strong="H6635"\w* s'enfuient; \w ils|strong="H5414"\w* s'enfuient, \w et|strong="H5414"\w* celle \w qui|strong="H7227"\w* \w reste|strong="H5414"\w* \w à|strong="H5414"\w* \w la|strong="H5414"\w* \w maison|strong="H5414"\w* partage \w le|strong="H5414"\w* butin.
\v 13 \w Vous|strong="H1004"\w* \w qui|strong="H4428"\w* restez couchés \w au|strong="H1004"\w* \w milieu|strong="H1004"\w* \w des|strong="H4428"\w* parcs, \w vous|strong="H1004"\w* recevez \w les|strong="H1004"\w* ailes argentées \w de|strong="H4428"\w* \w la|strong="H4428"\w* colombe, \w et|strong="H4428"\w* \w son|strong="H4428"\w* plumage d'\w un|strong="H1004"\w* jaune d'or.
\v 14 Quand \w le|strong="H3671"\w* Tout-Puissant dispersa \w les|strong="H7901"\w* rois, \w la|strong="H3701"\w* terre devint blanche \w comme|strong="H3671"\w* \w la|strong="H3701"\w* neige \w de|strong="H3701"\w* Tsalmon.
\v 15 Montagne \w de|strong="H4428"\w* \w Dieu|strong="H4428"\w*, mont \w de|strong="H4428"\w* Bassan, montagne \w aux|strong="H4428"\w* cimes nombreuses, mont \w de|strong="H4428"\w* Bassan,
\v 16 Pourquoi vous élevez-vous, monts \w aux|strong="H2022"\w* \w cimes|strong="H1386"\w* nombreuses, contre \w la|strong="H2022"\w* \w montagne|strong="H2022"\w* \w que|strong="H2022"\w* \w Dieu|strong="H2022"\w* \w a|strong="H3068"\w* choisie \w pour|strong="H2022"\w* \w sa|strong="H2022"\w* demeure? \w L|strong="H3068"\w*'Éternel y habitera \w pour|strong="H2022"\w* jamais.
\v 17 \w Les|strong="H3068"\w* chars \w de|strong="H2022"\w* \w Dieu|strong="H3068"\w* \w se|strong="H3068"\w* comptent \w par|strong="H3068"\w* vingt mille, \w par|strong="H3068"\w* milliers redoublés; \w le|strong="H3068"\w* \w Seigneur|strong="H3068"\w* \w est|strong="H3068"\w* \w au|strong="H3068"\w* \w milieu|strong="H3427"\w* d'\w eux|strong="H3068"\w*; Sinaï \w est|strong="H3068"\w* \w dans|strong="H3427"\w* \w le|strong="H3068"\w* sanctuaire.
\v 18 \w Tu|strong="H6944"\w* es monté \w en|strong="H7393"\w* haut, \w tu|strong="H6944"\w* as emmené \w des|strong="H6944"\w* captifs; \w tu|strong="H6944"\w* as reçu \w des|strong="H6944"\w* dons parmi \w les|strong="H6944"\w* hommes, \w pour|strong="H6944"\w* avoir \w ta|strong="H6944"\w* demeure \w même|strong="H6944"\w* chez \w les|strong="H6944"\w* rebelles, ô Éternel Dieu!
\v 19 Béni soit \w le|strong="H3947"\w* \w Seigneur|strong="H3947"\w* \w chaque|strong="H5927"\w* jour! Quand \w on|strong="H3947"\w* \w nous|strong="H7617"\w* accable, \w Dieu|strong="H5927"\w* \w est|strong="H7931"\w* \w notre|strong="H3947"\w* délivrance. (Sélah.)
\v 20 \w Dieu|strong="H3117"\w* \w est|strong="H3117"\w* \w pour|strong="H3117"\w* \w nous|strong="H3117"\w* \w le|strong="H3117"\w* \w Dieu|strong="H3117"\w* \w des|strong="H3117"\w* \w délivrances|strong="H3444"\w*; c'\w est|strong="H3117"\w* l'Éternel \w notre|strong="H3117"\w* \w Dieu|strong="H3117"\w* \w qui|strong="H3117"\w* retire \w de|strong="H3117"\w* \w la|strong="H3117"\w* \w mort|strong="H3117"\w*.
\v 21 Certainement Dieu écrasera \w la|strong="H4194"\w* tête \w de|strong="H4194"\w* ses ennemis, le crâne chevelu \w de|strong="H4194"\w* celui \w qui|strong="H4194"\w* marche dans ses forfaits.
