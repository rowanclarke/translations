\q1 Jesús Eliezer hiewaa; 
\q1 Eliezer Jorim hiewaa; 
\q1 Jorim Matat hiewaa; 
\q1  
\v 30 Matat Leví hiewaa; 
\q1 Leví Simeón hiewaa; 
\q1 Simeón Judá hiewaa; 
\q1 Judá José hiewaa; 
\q1 José Jonam hiewaa; 
\q1 Jonam Eliaquim hiewaa; 
\q1  
\v 31 Eliaquim Melea hiewaa; 
\q1 Melea Mena hiewaa; 
\q1 Mena Matata hiewaa; 
