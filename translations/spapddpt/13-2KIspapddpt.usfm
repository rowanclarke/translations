\p \w No|strong="H3808"\w* \w escuchen|strong="H8085"\w* \w a|strong="H3068"\w* Ezequías, quien \w los|strong="H3588"\w* persuade: \nd \w Yavé|strong="H3068"\w*\nd* nos \w librará|strong="H5337"\w*.
\v 33 ¿Alguno de los \tl ʼelohim\tl* de las \w naciones|strong="H1471"\w* ha \w librado|strong="H5337"\w* su tierra de la \w mano|strong="H3027"\w* del \w rey|strong="H4428"\w* de Asiria?
\v 34 ¿Dónde están \w los|strong="H3588"\w* \tl ʼelohim\tl* \w de|strong="H3588"\w* Hamat \w y|strong="H3588"\w* Arfad? ¿Dónde están \w los|strong="H3588"\w* \tl ʼelohim\tl* \w de|strong="H3588"\w* Sefarvaim, \w de|strong="H3588"\w* Hena \w y|strong="H3588"\w* \w de|strong="H3588"\w* Iva? ¿Pudieron \w librar|strong="H5337"\w* \w a|strong="H3068"\w* \w Samaria|strong="H8111"\w* \w de|strong="H3588"\w* mi \w mano|strong="H3027"\w*?
\v 35 ¿Cuáles \w de|strong="H3588"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \tl ʼelohim\tl* \w de|strong="H3588"\w* estas naciones \w libraron|strong="H5337"\w* sus tierras \w de|strong="H3588"\w* \w mi|strong="H3389"\w* \w mano|strong="H3027"\w*, \w para|strong="H3588"\w* \add confiar\add* \w que|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w libre|strong="H5337"\w* \w a|strong="H3068"\w* Jerusalén \w de|strong="H3588"\w* \w mi|strong="H3389"\w* \w mano|strong="H3027"\w*?
\p 
\v 36 \w Pero|strong="H3588"\w* \w el|strong="H1931"\w* \w pueblo|strong="H5971"\w* \w calló|strong="H2790"\w* \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w le|strong="H1931"\w* \w respondió|strong="H6030"\w* alguna \w palabra|strong="H1697"\w*, \w pues|strong="H3588"\w* \w había|strong="H3588"\w* una consigna del \w rey|strong="H4428"\w*: \w No|strong="H3808"\w* \w le|strong="H1931"\w* respondan.
\p 
\v 37 Eliaquim, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Hilcías|strong="H2518"\w*, administrador \w del|strong="H5921"\w* palacio, \w el|strong="H5921"\w* \w escriba|strong="H5608"\w* \w Sebna|strong="H7644"\w* \w y|strong="H5921"\w* \w el|strong="H5921"\w* cronista Joa, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Asaf, fueron \w a|strong="H3068"\w* Ezequías \w con|strong="H5921"\w* sus ropas rasgadas \w y|strong="H5921"\w* \w le|strong="H5921"\w* \w declararon|strong="H5046"\w* \w las|strong="H5921"\w* \w palabras|strong="H1697"\w* \w del|strong="H5921"\w* \tl \w Rabsaces|strong="H7262"\w*. \tl*
\c 19
\s1 Oración de Ezequías
\p 
\v 1 \w Aconteció|strong="H1961"\w* \w que|strong="H1961"\w* \w cuando|strong="H1961"\w* el \w rey|strong="H4428"\w* Ezequías lo \w oyó|strong="H8085"\w*, \w rasgó|strong="H7167"\w* sus ropas, \w se|strong="H1961"\w* \w cubrió|strong="H3680"\w* de tela áspera y \w fue|strong="H1961"\w* \w a|strong="H3068"\w* la \w Casa|strong="H1004"\w* de \nd \w Yavé|strong="H3068"\w*\nd*.
\p 
\v 2 \w Envió|strong="H7971"\w* \w al|strong="H5921"\w* administrador Eliaquim, \w al|strong="H5921"\w* \w escriba|strong="H5608"\w* \w Sebna|strong="H7644"\w* \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w ancianos|strong="H2205"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w sacerdotes|strong="H3548"\w*, \w cubiertos|strong="H3680"\w* \w de|strong="H5921"\w* tela áspera, \w al|strong="H5921"\w* \w profeta|strong="H5030"\w* \w Isaías|strong="H3470"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Amoz,
\v 3 \w y|strong="H3588"\w* le dijeron: Ezequías dijo: ¡\w Hoy|strong="H3117"\w* \w es|strong="H2088"\w* \w día|strong="H3117"\w* \w de|strong="H3588"\w* \w angustia|strong="H6869"\w*, castigo \w y|strong="H3588"\w* blasfemia! ¡\w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w están|strong="H2088"\w* \w por|strong="H3588"\w* salir del vientre, \w pero|strong="H3588"\w* \w no|strong="H3588"\w* hay \w fuerzas|strong="H3581"\w* \w para|strong="H5704"\w* darlos \w a|strong="H3068"\w* luz!
\v 4 Quizás \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* haya escuchado \w todas|strong="H3605"\w* las \w palabras|strong="H1697"\w* del \tl \w Rabsaces|strong="H7262"\w*\tl*, \w a|strong="H3068"\w* \w quien|strong="H3605"\w* \w el|strong="H3605"\w* \w rey|strong="H4428"\w* \w de|strong="H1697"\w* Asiria, su \tl ʼadón\tl*, \w envió|strong="H7971"\w* para vituperar \w al|strong="H4428"\w* \nd ʼElohim\nd* \w viviente|strong="H2416"\w* y \w reprenda|strong="H3198"\w* las \w palabras|strong="H1697"\w* \w que|strong="H1697"\w* \w Él|strong="H3605"\w* \w oyó|strong="H8085"\w*. \w Por|strong="H1157"\w* tanto, \w eleva|strong="H5375"\w* \w una|strong="H4672"\w* \w oración|strong="H8605"\w* \w a|strong="H3068"\w* favor del remanente \w que|strong="H1697"\w* aún nos queda.
\p 
\v 5 Los esclavos del \w rey|strong="H4428"\w* Ezequías se presentaron ante \w Isaías|strong="H3470"\w*.
\v 6 \w Isaías|strong="H3470"\w* les respondió: Digan \w a|strong="H3068"\w* su \tl ʼadon:\tl* \nd \w Yavé|strong="H3068"\w*\nd* \w dice|strong="H1697"\w*: \wj \w No|strong="H6440"\w* \w temas|strong="H3372"\w* las \w palabras|strong="H1697"\w* \w que|strong="H1697"\w* \w oíste|strong="H8085"\w*, con las cuales los esclavos del \w rey|strong="H4428"\w* \w de|strong="H6440"\w* Asiria \w me|strong="H3541"\w* blasfemaron.\wj*
\v 7 \wj \w Ciertamente|strong="H2005"\w* \w pondré|strong="H5414"\w* un \w espíritu|strong="H7307"\w* sobre \w él|strong="H5307"\w*, y \w oirá|strong="H8085"\w* un \w rumor|strong="H8052"\w*. Se \w volverá|strong="H7725"\w* \w a|strong="H3068"\w* su tierra y \w caerá|strong="H5307"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w* en su propia tierra.\wj*
\p 
\v 8 \w Cuando|strong="H3588"\w* \w el|strong="H5921"\w* \tl \w Rabsaces|strong="H7262"\w*\tl* \w oyó|strong="H8085"\w* \w que|strong="H3588"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Asiria salió \w de|strong="H5921"\w* Laquis, regresó \w y|strong="H3588"\w* \w halló|strong="H4672"\w* \w que|strong="H3588"\w* combatía \w contra|strong="H5921"\w* \w Libna|strong="H3841"\w*.
\p 
\v 9 Pero cuando \w oyó|strong="H8085"\w* \w decir|strong="H8085"\w* que Tirhaca, \w rey|strong="H4428"\w* \w de|strong="H3898"\w* \w Etiopía|strong="H3568"\w*, \w salió|strong="H3318"\w* \w a|strong="H3068"\w* luchar contra él, \w envió|strong="H7971"\w* otra vez \w mensajeros|strong="H4397"\w* \w a|strong="H3068"\w* Ezequías para decirle:
\v 10 Digan \w a|strong="H3068"\w* Ezequías, \w rey|strong="H4428"\w* \w de|strong="H5414"\w* \w Judá|strong="H3063"\w*: \w No|strong="H3808"\w* te \w engañe|strong="H5377"\w* tu \nd ʼElohim\nd*, en el cual confías, \w y|strong="H3541"\w* dices: Jerusalén \w no|strong="H3808"\w* \w será|strong="H3808"\w* \w entregada|strong="H5414"\w* en \w mano|strong="H3027"\w* del \w rey|strong="H4428"\w* \w de|strong="H5414"\w* Asiria.
\v 11 \w Ciertamente|strong="H2009"\w* \w tú|strong="H6213"\w* \w oíste|strong="H8085"\w* \w lo|strong="H6213"\w* \w que|strong="H3605"\w* \w los|strong="H3605"\w* \w reyes|strong="H4428"\w* de Asiria \w hicieron|strong="H6213"\w* \w a|strong="H3068"\w* \w todas|strong="H3605"\w* las tierras y las \w destruyeron|strong="H2763"\w*. ¿\w Y|strong="H3068"\w* \w tú|strong="H6213"\w* te \w librarás|strong="H5337"\w*?
\v 12 ¿\w Los|strong="H1121"\w* \tl ʼelohim\tl* \w de|strong="H1121"\w* las \w naciones|strong="H1471"\w* \w que|strong="H1121"\w* mis antepasados \w destruyeron|strong="H7843"\w* las pudieron \w librar|strong="H5337"\w* \w de|strong="H1121"\w* la destrucción, esto es, \w a|strong="H3068"\w* \w Gozán|strong="H1470"\w*, \w Harán|strong="H2771"\w*, Resef y \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Edén \w que|strong="H1121"\w* estaban en Telasar?
\v 13 ¿Dónde está el \w rey|strong="H4428"\w* de Hamat, \w o|strong="H3068"\w* Arfad, \w o|strong="H3068"\w* de la \w ciudad|strong="H5892"\w* de Sefarvaim, \w o|strong="H3068"\w* de Hena, \w o|strong="H3068"\w* de Iva?
\p 
\v 14 Ezequías \w recibió|strong="H3947"\w* la \w carta|strong="H5612"\w* \w de|strong="H6440"\w* \w mano|strong="H3027"\w* \w de|strong="H6440"\w* los \w mensajeros|strong="H4397"\w* y la \w leyó|strong="H7121"\w*. \w Subió|strong="H5927"\w* \w a|strong="H3068"\w* la \w Casa|strong="H1004"\w* \w de|strong="H6440"\w* \nd \w Yavé|strong="H3068"\w*\nd*, y la desplegó \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\s1 Oración del rey Ezequías
\p 
\v 15 Ezequías \w oró|strong="H6419"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*: ¡Oh \nd \w Yavé|strong="H3068"\w* ʼElohim\nd* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*, \w que|strong="H1931"\w* tienes \w tu|strong="H6213"\w* trono entre \w los|strong="H3427"\w* \w querubines|strong="H3742"\w*! ¡\w Solo|strong="H1931"\w* \w Tú|strong="H6213"\w* \w eres|strong="H1931"\w* \w el|strong="H1931"\w* \nd ʼElohim\nd* \w de|strong="H6440"\w* \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w reinos|strong="H4467"\w* \w de|strong="H6440"\w* \w la|strong="H1931"\w* tierra! \w Tú|strong="H6213"\w* \w hiciste|strong="H6213"\w* \w el|strong="H1931"\w* \w cielo|strong="H8064"\w* y \w la|strong="H1931"\w* tierra.
\v 16 \w Inclina|strong="H5186"\w* tu \w oído|strong="H8085"\w*, oh \nd \w Yavé|strong="H3068"\w*\nd*, y \w escucha|strong="H8085"\w*. \w Abre|strong="H6491"\w* tus \w ojos|strong="H5869"\w*, oh \nd \w Yavé|strong="H3068"\w*\nd*, y observa. \w Escucha|strong="H8085"\w* las \w palabras|strong="H1697"\w* \w que|strong="H1697"\w* Senaquerib \w envió|strong="H7971"\w* para vituperar al \nd ʼElohim\nd* \w viviente|strong="H2416"\w*.
\p 
\v 17 Cierto es, oh \nd \w Yavé|strong="H3068"\w*\nd*, que los \w reyes|strong="H4428"\w* de Asiria asolaron los \w pueblos|strong="H1471"\w* y sus tierras,
\v 18 \w y|strong="H3588"\w* echaron \w sus|strong="H1992"\w* \tl ʼelohim\tl* al fuego. \w Porque|strong="H3588"\w* \w ellos|strong="H1992"\w* \w no|strong="H3808"\w* \w son|strong="H3588"\w* \nd ʼElohim\nd*, \w sino|strong="H3588"\w* \w obra|strong="H4639"\w* \w de|strong="H3588"\w* \w madera|strong="H6086"\w* \w y|strong="H3588"\w* piedra hechas \w por|strong="H3588"\w* \w el|strong="H3588"\w* hombres. \w Por|strong="H3588"\w* eso \w los|strong="H1992"\w* destruyeron.
\p 
\v 19 \w Ahora|strong="H6258"\w* \w pues|strong="H3588"\w*, oh \nd \w Yavé|strong="H3068"\w* ʼElohim\nd* nuestro, \w te|strong="H3588"\w* \w ruego|strong="H4994"\w* \w que|strong="H3588"\w* nos \w salves|strong="H3467"\w* \w de|strong="H3588"\w* \w su|strong="H3588"\w* \w mano|strong="H3027"\w*, \w y|strong="H3588"\w* \w que|strong="H3588"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w reinos|strong="H4467"\w* \w de|strong="H3588"\w* \w la|strong="H3605"\w* tierra \w sepan|strong="H3045"\w* \w que|strong="H3588"\w* solo Tú, oh \nd \w Yavé|strong="H3068"\w*\nd*, eres \nd ʼElohim.\nd*
\p 
\v 20 Entonces \w Isaías|strong="H3470"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Amoz, \w envió|strong="H7971"\w* \w a|strong="H3068"\w* \w decir|strong="H8085"\w* \w a|strong="H3068"\w* Ezequías: \nd \w Yavé|strong="H3068"\w* ʼElohim\nd* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* dice: \wj \w Escuché|strong="H8085"\w* lo \w que|strong="H1121"\w* \w me|strong="H3541"\w* \w rogaste|strong="H6419"\w* acerca \w de|strong="H1121"\w* Senaquerib, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* Asiria.\wj*
\p 
\v 21 \wj \w Esta|strong="H2088"\w* \w es|strong="H2088"\w* \w la|strong="H5921"\w* \w Palabra|strong="H1697"\w* \w que|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w dice|strong="H1696"\w* \w acerca|strong="H5921"\w* \w de|strong="H5921"\w* \w él|strong="H5921"\w*: \w Te|strong="H5921"\w* menosprecia, \w se|strong="H5921"\w* burla \w de|strong="H5921"\w* \w ti|strong="H5921"\w* \w la|strong="H5921"\w* \w virgen|strong="H1330"\w*, \w hija|strong="H1323"\w* \w de|strong="H5921"\w* \w Sion|strong="H6726"\w*. Menea despectivamente \w la|strong="H5921"\w* \w cabeza|strong="H7218"\w* tras \w ti|strong="H5921"\w*, \w la|strong="H5921"\w* \w hija|strong="H1323"\w* \w de|strong="H5921"\w* Jerusalén.\wj*
\v 22 \wj ¿\w A|strong="H3068"\w* \w quién|strong="H4310"\w* vituperaste \w y|strong="H5921"\w* \w blasfemaste|strong="H1442"\w*? ¿\w Contra|strong="H5921"\w* \w quién|strong="H4310"\w* levantaste tu \w voz|strong="H6963"\w* \w y|strong="H5921"\w* elevaste tus \w ojos|strong="H5869"\w* \w con|strong="H5921"\w* \w altivez|strong="H7311"\w*? \w Contra|strong="H5921"\w* \w el|strong="H5921"\w* \w Santo|strong="H6918"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.\wj*
\p 
\v 23 \wj \w Por|strong="H3027"\w* \w medio|strong="H3027"\w* de tus \w mensajeros|strong="H4397"\w* afrentaste \w a|strong="H3068"\w* \nd ʼAdonay\nd* y dijiste: Con la multitud de mis carruajes yo escalé la cima de las montañas, lo más inaccesible del \w Líbano|strong="H3844"\w*. Corté sus más altos cedros y lo mejor de sus cipreses, y entré en su más remoto refugio, en su \w bosque|strong="H3293"\w* más frondoso.\wj*
\v 24 \wj \w Cavé|strong="H6979"\w* pozos, \w bebí|strong="H8354"\w* \w aguas|strong="H4325"\w* extranjeras y sequé \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w ríos|strong="H2975"\w* \w de|strong="H4325"\w* Egipto con las plantas \w de|strong="H4325"\w* mis \w pies|strong="H6471"\w*.\wj*
\p 
\v 25 \wj ¿\w No|strong="H3808"\w* \w oíste|strong="H8085"\w* \w que|strong="H3808"\w* \w hace|strong="H6213"\w* mucho \w tiempo|strong="H3117"\w* \w lo|strong="H3808"\w* determiné, y desde \w tiempos|strong="H3117"\w* \w antiguos|strong="H6924"\w* \w lo|strong="H3808"\w* dispuse? \w Ahora|strong="H6258"\w* \w lo|strong="H3808"\w* \w ejecuto|strong="H6213"\w* \w para|strong="H1961"\w* reducir \w ciudades|strong="H5892"\w* \w fortificadas|strong="H1219"\w* \w a|strong="H3068"\w* montones de escombros.\wj*
\v 26 \wj Sus \w habitantes|strong="H3427"\w*, carentes \w de|strong="H6440"\w* fuerza, \w fueron|strong="H1961"\w* acobardados y avergonzados \w como|strong="H1961"\w* la vegetación del \w campo|strong="H7704"\w*, la \w hierba|strong="H6212"\w* \w verde|strong="H3419"\w*, \w el|strong="H3427"\w* verdor del pasto, \w como|strong="H1961"\w* la \w hierba|strong="H6212"\w* \w de|strong="H6440"\w* las azoteas \w que|strong="H1961"\w* \w se|strong="H1961"\w* marchita \w antes|strong="H6440"\w* \w de|strong="H6440"\w* madurar.\wj*
\p 
\v 27 \wj Pero \w conozco|strong="H3045"\w* tu situación, cómo \w sales|strong="H3318"\w* y entras, y te enfureces contra Mí.\wj*
\v 28 \wj \w A|strong="H3068"\w* causa de tu furia contra Mí y \w porque|strong="H3282"\w* tu soberbia \w subió|strong="H5927"\w* hasta mis oídos, \w pondré|strong="H7760"\w* mi argolla en tu nariz y mi freno en tu hocico. Te \w haré|strong="H7760"\w* \w volver|strong="H7725"\w* \w por|strong="H3282"\w* el \w camino|strong="H1870"\w* \w por|strong="H3282"\w* donde viniste.\wj*
\s1 Señal para el rey Ezequías
\p 
\v 29 \wj \w Ésta|strong="H2088"\w* será la señal para ti: \w Este|strong="H2088"\w* \w año|strong="H8141"\w* comerás \w lo|strong="H2088"\w* \w que|strong="H2088"\w* brote del grano caído, y el \w segundo|strong="H8145"\w* \w año|strong="H8141"\w*, \w lo|strong="H2088"\w* \w que|strong="H2088"\w* brote sin sembrar. El tercer \w año|strong="H8141"\w* \w sembrarás|strong="H2232"\w* y cosecharás, \w plantarás|strong="H5193"\w* \w viñas|strong="H3754"\w* y comerás su \w fruto|strong="H6529"\w*.\wj*
\v 30 \wj \w El|strong="H6213"\w* remanente que \w quede|strong="H7604"\w* de la \w casa|strong="H1004"\w* de \w Judá|strong="H3063"\w* echará nuevamente \w raíces|strong="H8328"\w* \w hacia|strong="H6213"\w* \w abajo|strong="H4295"\w*, y llevará \w fruto|strong="H6529"\w* \w hacia|strong="H6213"\w* \w arriba|strong="H4605"\w*.\wj*
\v 31 \wj \w Porque|strong="H3588"\w* \w saldrá|strong="H3318"\w* un remanente \w de|strong="H3588"\w* Jerusalén, \w y|strong="H3588"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* montaña \w Sion|strong="H6726"\w* \add saldrán\add* \w los|strong="H3588"\w* \w que|strong="H3588"\w* se salven. ¡\w El|strong="H3588"\w* \w celo|strong="H7068"\w* \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w de|strong="H3588"\w* las huestes \w hará|strong="H6213"\w* \w esto|strong="H2063"\w*!\wj*
\s1 Profecía de Isaías contra Senaquerib
\p 
\v 32 \w Por|strong="H5921"\w* \w tanto|strong="H3651"\w*, \nd \w Yavé|strong="H3068"\w*\nd* dijo \w con|strong="H5921"\w* respecto \w al|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Asiria: \wj \w No|strong="H3808"\w* entrará \w en|strong="H5921"\w* \w esta|strong="H2063"\w* \w ciudad|strong="H5892"\w*, \w ni|strong="H3808"\w* disparará \w en|strong="H5921"\w* \w ella|strong="H8033"\w* \w ni|strong="H3808"\w* una sola flecha, \w ni|strong="H3808"\w* vendrá \w delante|strong="H5921"\w* \w de|strong="H5921"\w* \w ella|strong="H8033"\w* \w con|strong="H5921"\w* \w escudo|strong="H4043"\w*, \w ni|strong="H3808"\w* levantará \w contra|strong="H5921"\w* \w ella|strong="H8033"\w* terraplén.\wj*
\v 33 \wj \w Se|strong="H3808"\w* devolverá \w por|strong="H1870"\w* el mismo \w camino|strong="H1870"\w* \w por|strong="H1870"\w* el cual \w vino|strong="H1870"\w*. \w Nunca|strong="H3808"\w* entrará en \w esta|strong="H2063"\w* \w ciudad|strong="H5892"\w*, Palabra de \nd \w Yavé|strong="H3068"\w*\nd*,\wj*
\v 34 \wj \w por|strong="H4616"\w* cuanto Yo defenderé \w esta|strong="H2063"\w* \w ciudad|strong="H5892"\w* \w para|strong="H4616"\w* salvarla \w a|strong="H3068"\w* causa de Mí y de mi esclavo \w David|strong="H1732"\w*.\wj*
\s1 Golpe de \nd Yavé\nd* contra el rey de Asiria
\p 
\v 35 \w Aconteció|strong="H1961"\w* \w que|strong="H1931"\w* \w aquella|strong="H1931"\w* \w noche|strong="H3915"\w* \w el|strong="H1931"\w* \w Ángel|strong="H4397"\w* \w de|strong="H2568"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w salió|strong="H3318"\w* \w e|strong="H3068"\w* \w hirió|strong="H5221"\w* \w a|strong="H3068"\w* 185.000 \w en|strong="H3318"\w* \w el|strong="H1931"\w* \w campamento|strong="H4264"\w* \w de|strong="H2568"\w* \w los|strong="H3605"\w* asirios. \w Cuando|strong="H1961"\w* \add los demás\add* \w se|strong="H1961"\w* levantaron \w de|strong="H2568"\w* madrugada, \w ciertamente|strong="H4191"\w* \w todos|strong="H3605"\w* \w eran|strong="H1961"\w* cadáveres.
\v 36 \w Entonces|strong="H7725"\w* Senaquerib, \w rey|strong="H4428"\w* de Asiria se retiró \w a|strong="H3068"\w* \w Nínive|strong="H5210"\w*.
\v 37 \w Aconteció|strong="H1961"\w* \w que|strong="H1931"\w* mientras \w adoraba|strong="H7812"\w* \w en|strong="H8478"\w* \w el|strong="H1931"\w* \w templo|strong="H1004"\w* \w de|strong="H8478"\w* \w su|strong="H1931"\w* \nd ʼelohim,\nd* Nisroc, Adramelec y Sarezer \w lo|strong="H1931"\w* \w mataron|strong="H5221"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w*. \w Ellos|strong="H1992"\w* \w escaparon|strong="H4422"\w* \w a|strong="H3068"\w* \w la|strong="H1931"\w* tierra \w de|strong="H8478"\w* Ararat. \w Su|strong="H1931"\w* \w hijo|strong="H1121"\w* Esar-hadón \w reinó|strong="H4427"\w* \w en|strong="H8478"\w* \w su|strong="H1931"\w* \w lugar|strong="H8478"\w*.
\c 20
\s1 Enfermedad de Ezequías
\p 
\v 1 \w En|strong="H3588"\w* \w aquellos|strong="H1992"\w* \w días|strong="H3117"\w* Ezequías cayó \w enfermo|strong="H2470"\w* \w de|strong="H3588"\w* \w muerte|strong="H4191"\w*. \w El|strong="H3588"\w* \w profeta|strong="H5030"\w* \w Isaías|strong="H3470"\w*, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* Amoz, \w fue|strong="H3808"\w* \w a|strong="H3068"\w* \w él|strong="H3588"\w* \w y|strong="H3588"\w* le dijo: \nd \w Yavé|strong="H3068"\w*\nd* dice: \wj \w Ordena|strong="H6680"\w* tu \w casa|strong="H1004"\w*, \w porque|strong="H3588"\w* \w morirás|strong="H4191"\w* \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w vivirás|strong="H2421"\w*.\wj*
\p 
\v 2 \w Y|strong="H3068"\w* él volvió su \w rostro|strong="H6440"\w* \w hacia|strong="H6440"\w* la \w pared|strong="H7023"\w* y \w oró|strong="H6419"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*:
\v 3 \w Te|strong="H5869"\w* \w ruego|strong="H4994"\w*, oh \nd \w Yavé|strong="H3068"\w*\nd*, \w que|strong="H4994"\w* \w recuerdes|strong="H2142"\w* \w que|strong="H4994"\w* he \w andado|strong="H1980"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Ti con verdad y un \w corazón|strong="H3824"\w* \w íntegro|strong="H8003"\w*, y \w que|strong="H4994"\w* \w hice|strong="H6213"\w* \w lo|strong="H6213"\w* \w bueno|strong="H2896"\w* \w ante|strong="H6440"\w* Ti. Ezequías \w lloraba|strong="H1058"\w* \w amargamente|strong="H1058"\w*.
\p 
\v 4 \w Aconteció|strong="H1961"\w* \w que|strong="H3808"\w* antes \w que|strong="H3808"\w* \w Isaías|strong="H3470"\w* \w saliera|strong="H3318"\w* del patio central, le \w vino|strong="H1961"\w* \w Palabra|strong="H1697"\w* \w de|strong="H1697"\w* \nd \w Yavé|strong="H3068"\w*\nd*:
\v 5 \wj \w Vuelve|strong="H7725"\w* \w y|strong="H3541"\w* dí \w a|strong="H3068"\w* Ezequías, líder \w de|strong="H5971"\w* mi \w pueblo|strong="H5971"\w*: \nd \w Yavé|strong="H3068"\w*\nd*, el \nd ʼElohim\nd* \w de|strong="H5971"\w* \w David|strong="H1732"\w* tu antepasado, dice: \w Escuché|strong="H8085"\w* tu \w oración|strong="H8605"\w* \w y|strong="H3541"\w* \w vi|strong="H7200"\w* tus \w lágrimas|strong="H1832"\w*. \w Mira|strong="H7200"\w*, Yo te \w sano|strong="H7495"\w*. Al tercer \w día|strong="H3117"\w* irás al \w Templo|strong="H1004"\w* \w de|strong="H5971"\w* \nd \w Yavé|strong="H3068"\w*\nd*.\wj*
