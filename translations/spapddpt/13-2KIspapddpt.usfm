\c 1
\s1 Ministerio de Elías para el rey Ocozías
\p 
\v 1 Después de la \w muerte|strong="H4194"\w* de Acab, \w Moab|strong="H4124"\w* se rebeló \w contra|strong="H3478"\w* \w Israel|strong="H3478"\w*.
\v 2 Ocozías \w cayó|strong="H5307"\w* \w por|strong="H1157"\w* la ventana de la sala \w en|strong="H3212"\w* \w el|strong="H5307"\w* nivel superior de su casa \w en|strong="H3212"\w* \w Samaria|strong="H8111"\w*. Cuando estaba \w enfermo|strong="H2470"\w* \w envió|strong="H7971"\w* \w mensajeros|strong="H4397"\w* y les dijo: \w Vayan|strong="H3212"\w* y consulten \w a|strong="H3068"\w* Baal-zebub, \tl ʼelohim\tl* de \w Ecrón|strong="H6138"\w*, \w si|strong="H1157"\w* sanaré de \w esta|strong="H2088"\w* \w enfermedad|strong="H2483"\w*.
\p 
\v 3 Entonces el \w Ángel|strong="H4397"\w* de \nd \w Yavé|strong="H3068"\w*\nd* \w dijo|strong="H1696"\w* \w a|strong="H3068"\w* Elías tisbita: \wj \w Levántate|strong="H6965"\w*, \w sube|strong="H5927"\w* \w a|strong="H3068"\w* encontrar \w a|strong="H3068"\w* los \w mensajeros|strong="H4397"\w* del \w rey|strong="H4428"\w* de \w Samaria|strong="H8111"\w* y \w diles|strong="H1696"\w*: ¿\w Porque|strong="H4428"\w* \w no|strong="H1097"\w* hay \nd ʼElohim\nd* en \w Israel|strong="H3478"\w*, \w van|strong="H1980"\w* \w a|strong="H3068"\w* consultar \w a|strong="H3068"\w* Baal-zebub, el \tl ʼelohim\tl* de \w Ecrón|strong="H6138"\w*?\wj*
\v 4 \wj \w Por|strong="H3588"\w* \w tanto|strong="H3651"\w*, \nd \w Yavé|strong="H3068"\w*\nd* dice: \w No|strong="H3808"\w* bajarás \w del|strong="H4480"\w* lecho \w al|strong="H4480"\w* \w que|strong="H3588"\w* \w subiste|strong="H5927"\w*. \w Ciertamente|strong="H3588"\w* \w morirás|strong="H4191"\w*.\wj* \w Y|strong="H3068"\w* Elías \w se|strong="H4480"\w* \w fue|strong="H3212"\w*.
\p 
\v 5 \w Cuando|strong="H4100"\w* los \w mensajeros|strong="H4397"\w* \w volvieron|strong="H7725"\w* \w a|strong="H3068"\w* él, les preguntó: ¿\w Por|strong="H2088"\w* \w qué|strong="H4100"\w* regresaron?
\p 
\v 6 \w Y|strong="H3068"\w* \w respondieron|strong="H1696"\w*: \w Salió|strong="H5927"\w* un hombre \w a|strong="H3068"\w* encontrarse \w con|strong="H4480"\w* nosotros, \w y|strong="H3588"\w* \w nos|strong="H4480"\w* \w dijo|strong="H1696"\w*: \w Vayan|strong="H3212"\w*, \w vuelvan|strong="H7725"\w* \w al|strong="H4480"\w* \w rey|strong="H4428"\w* \w que|strong="H3588"\w* \w los|strong="H3588"\w* \w envió|strong="H7971"\w* \w y|strong="H3588"\w* díganle: \nd \w Yavé|strong="H3068"\w*\nd* \w dice|strong="H1696"\w*: \wj ¿\w Porque|strong="H3588"\w* \w no|strong="H3808"\w* hay \nd ʼElohim\nd* \w en|strong="H4480"\w* \w Israel|strong="H3478"\w*, tú mandas \w a|strong="H3068"\w* consultar \w a|strong="H3068"\w* Baal-zebub, \tl ʼelohim\tl* \w de|strong="H4480"\w* \w Ecrón|strong="H6138"\w*? \w Por|strong="H3588"\w* \w tanto|strong="H3651"\w*, \w no|strong="H3808"\w* bajarás \w del|strong="H4480"\w* lecho \w al|strong="H4480"\w* \w que|strong="H3588"\w* \w subiste|strong="H5927"\w*, \w pues|strong="H3588"\w* \w ciertamente|strong="H3588"\w* \w morirás|strong="H4191"\w*.\wj*
\p 
\v 7 Entonces él les preguntó: ¿\w Cómo|strong="H4100"\w* era aquel hombre \w que|strong="H4100"\w* \w salió|strong="H5927"\w* \w a|strong="H3068"\w* encontrarlos y \w dijo|strong="H1696"\w* estas \w palabras|strong="H1697"\w*?
\p 
\v 8 \w Y|strong="H3068"\w* \w le|strong="H1931"\w* respondieron: \w Es|strong="H1931"\w* un hombre velludo, con un cinturón de cuero atado \w a|strong="H3068"\w* \w su|strong="H1931"\w* cintura.
\p \w Y|strong="H3068"\w* \w él|strong="H1931"\w* dijo: \w Es|strong="H1931"\w* Elías tisbita.
\p 
\v 9 Entonces \w le|strong="H5921"\w* \w envió|strong="H7971"\w* un \w jefe|strong="H7218"\w* \w de|strong="H5921"\w* 50 \w con|strong="H5921"\w* sus 50, quien \w subió|strong="H5927"\w* \w a|strong="H3068"\w* \add Elías\add*, \w porque|strong="H5921"\w* \w estaba|strong="H3427"\w* \w sentado|strong="H3427"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w cumbre|strong="H7218"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* montaña, \w y|strong="H5921"\w* \w le|strong="H5921"\w* \w dijo|strong="H1696"\w*: ¡Varón \w de|strong="H5921"\w* \nd ʼElohim\nd*, \w el|strong="H5921"\w* \w rey|strong="H4428"\w* ordenó quen bajes!
\p 
\v 10 Elías \w respondió|strong="H6030"\w* \w al|strong="H4480"\w* \w jefe|strong="H8269"\w* \w de|strong="H4480"\w* 50: Si \w yo|strong="H4480"\w* soy varón \w de|strong="H4480"\w* \nd ʼElohim\nd*, ¡\w que|strong="H4480"\w* baje fuego \w del|strong="H4480"\w* \w cielo|strong="H8064"\w* y \w te|strong="H4480"\w* consuma, \w a|strong="H3068"\w* \w ti|strong="H4480"\w* y \w a|strong="H3068"\w* tus 50! \w Y|strong="H3068"\w* bajó fuego \w del|strong="H4480"\w* \w cielo|strong="H8064"\w* y los consumió \w a|strong="H3068"\w* todos.
\p 
\v 11 \w Y|strong="H3068"\w* \w volvió|strong="H7725"\w* \w a|strong="H3068"\w* enviarle otro \w jefe|strong="H8269"\w* \w de|strong="H8269"\w* 50 con sus 50, quien le \w dijo|strong="H1696"\w*: Varón \w de|strong="H8269"\w* \nd ʼElohim\nd*, el \w rey|strong="H4428"\w* \w dijo|strong="H1696"\w*: ¡Apresúrate \w y|strong="H3541"\w* \w baja|strong="H3381"\w*!
\p 
\v 12 \w Y|strong="H3068"\w* Elías \w respondió|strong="H6030"\w*: Si \w yo|strong="H4480"\w* soy varón \w de|strong="H4480"\w* \nd ʼElohim\nd*, ¡\w que|strong="H4480"\w* baje fuego \w del|strong="H4480"\w* \w cielo|strong="H8064"\w* y \w te|strong="H4480"\w* consuma, \w a|strong="H3068"\w* \w ti|strong="H4480"\w* y \w a|strong="H3068"\w* tus 50! \w Y|strong="H3068"\w* bajó fuego \w de|strong="H4480"\w* \nd ʼElohim\nd* y los consumió \w a|strong="H3068"\w* todos.
\p 
\v 13 \w Volvió|strong="H7725"\w* \w a|strong="H3068"\w* enviar un tercer \w jefe|strong="H8269"\w* \w de|strong="H5921"\w* 50 \w con|strong="H5921"\w* sus 50. Pero \w el|strong="H5921"\w* tercer \w jefe|strong="H8269"\w* \w de|strong="H5921"\w* 50 \w subió|strong="H5927"\w*, \w se|strong="H5921"\w* postró \w de|strong="H5921"\w* \w rodillas|strong="H1290"\w* \w delante|strong="H5048"\w* \w de|strong="H5921"\w* Elías \w y|strong="H5921"\w* \w le|strong="H5921"\w* suplicó: Varón \w de|strong="H5921"\w* \nd ʼElohim\nd*, \w te|strong="H5869"\w* \w ruego|strong="H4994"\w* \w que|strong="H4994"\w* \w mi|strong="H5921"\w* \w vida|strong="H5315"\w* \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w vida|strong="H5315"\w* \w de|strong="H5921"\w* estos 50 esclavos tuyos sea valiosa ante \w ti|strong="H5921"\w*.
\v 14 \w Ciertamente|strong="H2009"\w*, fuego \w del|strong="H4480"\w* \w cielo|strong="H8064"\w* bajó y consumió \w a|strong="H3068"\w* los \w dos|strong="H8147"\w* anteriores \w jefes|strong="H8269"\w* \w de|strong="H4480"\w* 50 \w con|strong="H4480"\w* sus 50. ¡\w Ahora|strong="H6258"\w* \w pues|strong="H6258"\w*, \w te|strong="H5869"\w* ruego \w que|strong="H4480"\w* \w mi|strong="H2009"\w* \w vida|strong="H5315"\w* sea valiosa ante \w ti|strong="H4480"\w*!
\p 
\v 15 Entonces el \w Ángel|strong="H4397"\w* \w de|strong="H6440"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w dijo|strong="H1696"\w* \w a|strong="H3068"\w* Elías: \wj \w Baja|strong="H3381"\w* con él. \w No|strong="H6440"\w* le \w temas|strong="H3372"\w*.\wj* \w Y|strong="H3068"\w* se \w levantó|strong="H6965"\w* y bajó con él \w al|strong="H4428"\w* \w rey|strong="H4428"\w* \add Ocozías\add*.
\p 
\v 16 \w Y|strong="H3068"\w* le \w dijo|strong="H1696"\w*: \nd \w Yavé|strong="H3068"\w*\nd* \w dice|strong="H1696"\w*: \wj \w Por|strong="H3588"\w* \w cuanto|strong="H3588"\w* \w enviaste|strong="H7971"\w* \w mensajeros|strong="H4397"\w* \w a|strong="H3068"\w* consultar \w con|strong="H4480"\w* Baal-zebub, \w el|strong="H3588"\w* \tl ʼelohim\tl* \w de|strong="H4480"\w* \w Ecrón|strong="H6138"\w*, \w como|strong="H3588"\w* \w si|strong="H3588"\w* \w no|strong="H3808"\w* hubiera \nd ʼElohim\nd* \w en|strong="H4480"\w* \w Israel|strong="H3478"\w* \w para|strong="H3588"\w* consultar \w su|strong="H3588"\w* \w Palabra|strong="H1697"\w*, \w no|strong="H3808"\w* bajarás \w del|strong="H4480"\w* lecho \w al|strong="H4480"\w* \w que|strong="H3588"\w* \w subiste|strong="H5927"\w*. \w Ciertamente|strong="H3588"\w* \w morirás|strong="H4191"\w*.\wj*
\p 
\v 17 \add Ocozías\add* \w murió|strong="H4191"\w* según \w la|strong="H3588"\w* \w Palabra|strong="H1697"\w* \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w que|strong="H3588"\w* Elías \w dijo|strong="H1696"\w*.
\p \w Joram|strong="H3088"\w* \w reinó|strong="H4427"\w* \w en|strong="H3588"\w* \w su|strong="H3588"\w* \w lugar|strong="H8478"\w* \w el|strong="H3588"\w* \w año|strong="H8141"\w* \w segundo|strong="H8147"\w* \w de|strong="H3588"\w* \w Joram|strong="H3088"\w*, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* Josafat, \w rey|strong="H4428"\w* \w de|strong="H3588"\w* \w Judá|strong="H3063"\w*, \w porque|strong="H3588"\w* Ocozías \w no|strong="H3808"\w* \w tuvo|strong="H1961"\w* \w hijo|strong="H1121"\w*.
\v 18 \w Los|strong="H1992"\w* demás \w hechos|strong="H1697"\w* \w de|strong="H5921"\w* Ocozías, ¿\w no|strong="H3808"\w* están \w escritos|strong="H3789"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* rollo \w de|strong="H5921"\w* \w las|strong="H1992"\w* Crónicas \w de|strong="H5921"\w* \w los|strong="H1992"\w* \w reyes|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*?
\c 2
\s1 Arrebatamiento de Elías al cielo en presencia de Eliseo
\p 
\v 1 \w Aconteció|strong="H1961"\w* \w que|strong="H4480"\w* \w cuando|strong="H1961"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w iba|strong="H3212"\w* \w a|strong="H3068"\w* \w alzar|strong="H5927"\w* \w a|strong="H3068"\w* Elías \w en|strong="H4480"\w* un remolino \w de|strong="H4480"\w* viento \w al|strong="H4480"\w* \w cielo|strong="H8064"\w*, Elías \w iba|strong="H3212"\w* \w de|strong="H4480"\w* \w Gilgal|strong="H1537"\w* \w con|strong="H4480"\w* Eliseo.
\p 
\v 2 Elías dijo \w a|strong="H3068"\w* Eliseo: \w Quédate|strong="H3427"\w* \w aquí|strong="H6311"\w*, \w porque|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w me|strong="H3588"\w* \w envió|strong="H7971"\w* \w a|strong="H3068"\w* Bet-ʼEl.
\p \w Y|strong="H3068"\w* Eliseo respondió: ¡\w Vive|strong="H2416"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w y|strong="H3588"\w* \w vive|strong="H2416"\w* tu \w alma|strong="H5315"\w* \w que|strong="H3588"\w* \w no|strong="H3588"\w* \w te|strong="H3588"\w* \w dejaré|strong="H7971"\w*! \w Entonces|strong="H3588"\w* \w bajaron|strong="H3381"\w* \w a|strong="H3068"\w* Bet-ʼEl.
\p 
\v 3 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w profetas|strong="H5030"\w* \w que|strong="H3588"\w* \w estaban|strong="H7218"\w* \w en|strong="H5921"\w* Bet-ʼEl \w salieron|strong="H3318"\w* \w a|strong="H3068"\w* encontrar \w a|strong="H3068"\w* Eliseo \w y|strong="H1571"\w* \w le|strong="H5921"\w* preguntaron: ¿\w Sabes|strong="H3045"\w* \w que|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* arrebata \w hoy|strong="H3117"\w* \w a|strong="H3068"\w* tu \tl ʼadón\tl* \w de|strong="H5921"\w* \w encima|strong="H5921"\w* \w de|strong="H5921"\w* tu \w cabeza|strong="H7218"\w*? \w Y|strong="H3068"\w* \w él|strong="H5921"\w* respondió: \w Sí|strong="H3588"\w*, \w lo|strong="H5921"\w* \w sé|strong="H3045"\w*, callen.
\p 
\v 4 Elías le dijo: Eliseo, \w quédate|strong="H3427"\w* \w aquí|strong="H6311"\w*, \w porque|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w me|strong="H3588"\w* \w envió|strong="H7971"\w* \w a|strong="H3068"\w* \w Jericó|strong="H3405"\w*.
\p \w Y|strong="H3068"\w* \w él|strong="H3588"\w* dijo: ¡\w Vive|strong="H2416"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w y|strong="H3588"\w* \w vive|strong="H2416"\w* tu \w alma|strong="H5315"\w* \w que|strong="H3588"\w* \w no|strong="H3588"\w* \w te|strong="H3588"\w* \w dejaré|strong="H7971"\w*! \w Y|strong="H3068"\w* fueron \w a|strong="H3068"\w* \w Jericó|strong="H3405"\w*.
\p 
\v 5 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w profetas|strong="H5030"\w* \w que|strong="H3588"\w* \w estaban|strong="H7218"\w* \w en|strong="H5921"\w* \w Jericó|strong="H3405"\w* \w llegaron|strong="H5066"\w* \w a|strong="H3068"\w* Eliseo \w y|strong="H1571"\w* \w le|strong="H5921"\w* preguntaron: ¿\w Sabes|strong="H3045"\w* \w que|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w quitará|strong="H3947"\w* \w hoy|strong="H3117"\w* \w a|strong="H3068"\w* tu \tl ʼadón\tl* \w de|strong="H5921"\w* \w encima|strong="H5921"\w* \w de|strong="H5921"\w* tu \w cabeza|strong="H7218"\w*?
\p \w Y|strong="H3068"\w* \w él|strong="H5921"\w* dijo: \w Sí|strong="H3588"\w*, \w lo|strong="H5921"\w* \w sé|strong="H3045"\w*, callen.
\p 
\v 6 Elías le dijo: \w Quédate|strong="H3427"\w* \w aquí|strong="H6311"\w*, \w porque|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w me|strong="H3588"\w* \w envió|strong="H7971"\w* al \w Jordán|strong="H3383"\w*.
\p \w Y|strong="H3068"\w* \w él|strong="H3588"\w* dijo: ¡\w Vive|strong="H2416"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w y|strong="H3588"\w* \w vive|strong="H2416"\w* tu \w alma|strong="H5315"\w*, \w que|strong="H3588"\w* \w no|strong="H3588"\w* \w te|strong="H3588"\w* \w dejaré|strong="H7971"\w*!
\p \w Y|strong="H3068"\w* \w ambos|strong="H8147"\w* \w fueron|strong="H3212"\w*.
\p 
\v 7 50 \w hombres|strong="H1121"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w profetas|strong="H5030"\w* \w fueron|strong="H1980"\w* \w y|strong="H5921"\w* \w se|strong="H5921"\w* detuvieron \w a|strong="H3068"\w* \w lo|strong="H5921"\w* \w lejos|strong="H7350"\w* \w frente|strong="H5048"\w* \w a|strong="H3068"\w* \w ellos|strong="H5921"\w*. También \w ellos|strong="H5921"\w* \w dos|strong="H8147"\w* \w se|strong="H5921"\w* detuvieron \w junto|strong="H5921"\w* \w al|strong="H5921"\w* \w Jordán|strong="H3383"\w*.
\v 8 Entonces Elías \w tomó|strong="H3947"\w* su manto y lo dobló. Golpeó las \w aguas|strong="H4325"\w*, y se separaron \w a|strong="H3068"\w* uno y otro lado. \w Ambos|strong="H8147"\w* cruzaron por tierra seca.
\p 
\v 9 \w Sucedió|strong="H1961"\w* \w que|strong="H4100"\w* \w cuando|strong="H4100"\w* cruzaban, Elías dijo \w a|strong="H3068"\w* Eliseo: \w Pide|strong="H7592"\w* \w lo|strong="H4100"\w* \w que|strong="H4100"\w* quieras \w que|strong="H4100"\w* \w haga|strong="H6213"\w* \w por|strong="H4100"\w* \w ti|strong="H5973"\w* \w antes|strong="H2962"\w* \w que|strong="H4100"\w* \w sea|strong="H1961"\w* arrebatado \w de|strong="H5973"\w* \w tu|strong="H6213"\w* \w lado|strong="H7307"\w*.
\p \w Y|strong="H3068"\w* Eliseo respondió: ¡\w Te|strong="H5973"\w* \w ruego|strong="H4994"\w* \w que|strong="H4100"\w* una doble porción \w de|strong="H5973"\w* \w tu|strong="H6213"\w* \w espíritu|strong="H7307"\w* pose \w sobre|strong="H1961"\w* \w mí|strong="H1961"\w*!
\p 
\v 10 \w Y|strong="H3068"\w* él le dijo: Cosa difícil \w pediste|strong="H7592"\w*. \w Si|strong="H3808"\w* me \w ves|strong="H7200"\w* \w cuando|strong="H1961"\w* \w sea|strong="H1961"\w* arrebatado de tu lado, te \w será|strong="H1961"\w* concedida. \w Si|strong="H3808"\w* \w no|strong="H3808"\w* me \w ves|strong="H7200"\w*, \w no|strong="H3808"\w*.
\p 
\v 11 Mientras \w ellos|strong="H1992"\w* caminaban y \w hablaban|strong="H1696"\w*, \w ciertamente|strong="H2009"\w* una carroza de fuego con \w caballos|strong="H5483"\w* de fuego \w apartó|strong="H6504"\w* \w a|strong="H3068"\w* \w los|strong="H1992"\w* \w dos|strong="H8147"\w*. Elías \w subió|strong="H5927"\w* al \w cielo|strong="H8064"\w* por medio de un remolino de viento.
\v 12 Al verlo Eliseo \w clamaba|strong="H6817"\w*: ¡Padre mío, padre mío! ¡Carroza y jinete \w de|strong="H5750"\w* \w Israel|strong="H3478"\w*! \w Y|strong="H3068"\w* \w no|strong="H3808"\w* \w lo|strong="H1931"\w* \w vio|strong="H7200"\w* \w más|strong="H5750"\w*. Entonces tomó \w sus|strong="H1931"\w* ropas y las \w rasgó|strong="H7167"\w* \w en|strong="H5750"\w* \w dos|strong="H8147"\w* \w pedazos|strong="H7167"\w*.
\p 
\v 13 Recogió \w el|strong="H5921"\w* manto \w de|strong="H5921"\w* Elías \w que|strong="H5921"\w* \w se|strong="H5921"\w* \w le|strong="H5921"\w* \w cayó|strong="H5307"\w*. Regresó \w y|strong="H5921"\w* \w se|strong="H5921"\w* detuvo \w a|strong="H3068"\w* \w la|strong="H5921"\w* orilla \w del|strong="H5921"\w* \w Jordán|strong="H3383"\w*.
\v 14 \w Al|strong="H5921"\w* \w tomar|strong="H3947"\w* \w el|strong="H1931"\w* manto \w de|strong="H5921"\w* Elías \w que|strong="H1931"\w* \w se|strong="H1931"\w* \w le|strong="H1931"\w* \w cayó|strong="H5307"\w*, golpeó \w las|strong="H5921"\w* \w aguas|strong="H4325"\w* \w y|strong="H5921"\w* dijo: ¿\w Dónde|strong="H2008"\w* \w está|strong="H1931"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w el|strong="H1931"\w* \nd ʼElohim\nd* \w de|strong="H5921"\w* Elías? Cuando \add Eliseo\add* golpeó \w las|strong="H5921"\w* \w aguas|strong="H4325"\w*, también \w se|strong="H1931"\w* dividieron \w a|strong="H3068"\w* uno \w y|strong="H5921"\w* otro lado, \w y|strong="H5921"\w* Eliseo cruzó.
\p 
\v 15 Cuando \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w profetas|strong="H5030"\w* \w que|strong="H5921"\w* estaban \w al|strong="H5921"\w* otro \w lado|strong="H7307"\w* \w en|strong="H5921"\w* \w Jericó|strong="H3405"\w* \w lo|strong="H5921"\w* \w vieron|strong="H7200"\w*, dijeron: \w El|strong="H5921"\w* \w espíritu|strong="H7307"\w* \w de|strong="H5921"\w* Elías \w reposó|strong="H5117"\w* \w sobre|strong="H5921"\w* Eliseo.
\p Luego fueron \w a|strong="H3068"\w* encontrarlo, \w se|strong="H5921"\w* postraron \w en|strong="H5921"\w* tierra ante \w él|strong="H5921"\w*
\v 16 y le dijeron: \w Mira|strong="H2009"\w*, \w ahora|strong="H4994"\w* \w hay|strong="H3426"\w* 50 \w hombres|strong="H1121"\w* \w fuertes|strong="H2428"\w* con tus esclavos. \w Que|strong="H3808"\w* ellos \w vayan|strong="H3212"\w* y \w busquen|strong="H1245"\w* \w a|strong="H3068"\w* \w tu|strong="H3426"\w* \tl ʼadón\tl*, \w no|strong="H3808"\w* \w sea|strong="H6435"\w* \w que|strong="H3808"\w* \w el|strong="H1121"\w* \w Espíritu|strong="H7307"\w* \w de|strong="H1121"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w lo|strong="H3808"\w* \w haya|strong="H3426"\w* levantado y \w lo|strong="H3808"\w* \w haya|strong="H3426"\w* colocado \w en|strong="H3212"\w* alguna montaña \w o|strong="H3068"\w* \w valle|strong="H1516"\w*. Pero \w él|strong="H1121"\w* respondió: \w No|strong="H3808"\w* \w los|strong="H1121"\w* envíen.
\p 
\v 17 Pero ellos le insistieron tanto \w que|strong="H3808"\w* él \w se|strong="H3808"\w* avergonzó \w y|strong="H5704"\w* dijo: ¡Envíen! \w Y|strong="H3068"\w* \w enviaron|strong="H7971"\w* 50 hombres \w que|strong="H3808"\w* \w buscaron|strong="H1245"\w* \w tres|strong="H7969"\w* \w días|strong="H3117"\w* \w y|strong="H5704"\w* \w no|strong="H3808"\w* \w lo|strong="H3808"\w* \w hallaron|strong="H4672"\w*.
\v 18 \w Volvieron|strong="H7725"\w* cuando \w él|strong="H1931"\w* \w estaba|strong="H3427"\w* \w en|strong="H3212"\w* \w Jericó|strong="H3405"\w*. \w Entonces|strong="H7725"\w* les preguntó: ¿\w No|strong="H3808"\w* les dije: \w No|strong="H3808"\w* \w vayan|strong="H3212"\w*?
\p 
\v 19 \w Luego|strong="H4994"\w* los hombres \w de|strong="H4325"\w* la \w ciudad|strong="H5892"\w* dijeron \w a|strong="H3068"\w* Eliseo: \w Ciertamente|strong="H2009"\w* el sitio \w de|strong="H4325"\w* esta \w ciudad|strong="H5892"\w* es \w bueno|strong="H2896"\w*, como \w ve|strong="H7200"\w* \w mi|strong="H2009"\w* \tl ʼadón\tl*, pero las \w aguas|strong="H4325"\w* son \w malas|strong="H7451"\w* y la tierra es estéril.
\p 
\v 20 Entonces él dijo: Tráiganme una vasija \w nueva|strong="H2319"\w* y \w pongan|strong="H7760"\w* \w allí|strong="H8033"\w* \w sal|strong="H4417"\w*. \w Y|strong="H3068"\w* se la \w llevaron|strong="H3947"\w*.
\p 
\v 21 \w Salió|strong="H3318"\w* al manantial, \w echó|strong="H7993"\w* \w allí|strong="H8033"\w* la \w sal|strong="H3318"\w* \w y|strong="H3541"\w* dijo: \nd \w Yavé|strong="H3068"\w*\nd* dice: \wj Yo sané estas \w aguas|strong="H4325"\w*. \w No|strong="H3808"\w* \w habrá|strong="H1961"\w* \w más|strong="H5750"\w* \w muerte|strong="H4194"\w* \w ni|strong="H3808"\w* esterilidad \w por|strong="H5750"\w* causa \w de|strong="H5750"\w* ellas.\wj*
\v 22 \w Y|strong="H3068"\w* las \w aguas|strong="H4325"\w* fueron sanadas \w hasta|strong="H5704"\w* \w hoy|strong="H3117"\w*, según la \w Palabra|strong="H1697"\w* \w que|strong="H5704"\w* Eliseo \w habló|strong="H1696"\w*.
\p 
\v 23 \w De|strong="H4480"\w* \w allí|strong="H8033"\w* \w subió|strong="H5927"\w* \w a|strong="H3068"\w* Bet-ʼEl.
\p Mientras iba \w por|strong="H4480"\w* \w el|strong="H1931"\w* \w camino|strong="H1870"\w*, \w salieron|strong="H3318"\w* unos muchachos \w de|strong="H4480"\w* \w la|strong="H1931"\w* \w ciudad|strong="H5892"\w* \w que|strong="H4480"\w* \w se|strong="H1931"\w* burlaban \w de|strong="H4480"\w* \w él|strong="H1931"\w* y \w le|strong="H1931"\w* decían: ¡\w Sube|strong="H5927"\w*, \w calvo|strong="H7142"\w*! ¡\w Sube|strong="H5927"\w*, \w calvo|strong="H7142"\w*!
\v 24 \w Él|strong="H1992"\w* \w se|strong="H4480"\w* \w volvió|strong="H6437"\w* \w para|strong="H4480"\w* verlos. \w Los|strong="H1992"\w* \w miró|strong="H7200"\w* y \w los|strong="H1992"\w* \w maldijo|strong="H7043"\w* \w en|strong="H4480"\w* \w el|strong="H1992"\w* \w Nombre|strong="H8034"\w* \w de|strong="H4480"\w* \nd \w Yavé|strong="H3068"\w*\nd*. \w Y|strong="H3068"\w* \w salieron|strong="H3318"\w* \w del|strong="H4480"\w* \w bosque|strong="H3293"\w* \w dos|strong="H8147"\w* osas \w que|strong="H4480"\w* destrozaron \w a|strong="H3068"\w* 42 \w de|strong="H4480"\w* \w aquellos|strong="H1992"\w* \w muchachos|strong="H3206"\w*.
\p 
\v 25 De \w allí|strong="H8033"\w* \w fue|strong="H3212"\w* \w a|strong="H3068"\w* la montaña Carmelo, y desde \w allí|strong="H8033"\w* \w volvió|strong="H7725"\w* \w a|strong="H3068"\w* \w Samaria|strong="H8111"\w*.
\c 3
\s1 Joram, rey de Israel
\p 
\v 1 \w El|strong="H5921"\w* \w año|strong="H8141"\w* 18 \w de|strong="H5921"\w* Josafat, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*, \w Joram|strong="H3088"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Acab, \w fue|strong="H3063"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w en|strong="H5921"\w* \w Samaria|strong="H8111"\w*, \w y|strong="H5921"\w* \w reinó|strong="H4427"\w* 12 \w años|strong="H8141"\w*.
\v 2 \w Hizo|strong="H6213"\w* \w lo|strong="H3808"\w* \w malo|strong="H7451"\w* ante \nd \w Yavé|strong="H3068"\w*\nd*, \w aunque|strong="H7535"\w* \w no|strong="H3808"\w* tanto como su padre y su madre, pues \w quitó|strong="H5493"\w* la imagen \w de|strong="H5869"\w* \w baal|strong="H1168"\w* \w que|strong="H3808"\w* erigió su padre.
\v 3 \w Sin|strong="H3808"\w* embargo, persistió \w en|strong="H4480"\w* \w los|strong="H1121"\w* \w pecados|strong="H2403"\w* \w de|strong="H4480"\w* \w Jeroboam|strong="H3379"\w*, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* \w Nabat|strong="H5028"\w*, \w con|strong="H4480"\w* \w los|strong="H1121"\w* cuales estimuló \w a|strong="H3068"\w* \w pecar|strong="H2398"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w*. \w No|strong="H3808"\w* \w se|strong="H4480"\w* apartó \w de|strong="H4480"\w* \w ellos|strong="H4480"\w*.
\s1 Guerra contra Moab
\p 
\v 4 \w Entonces|strong="H7725"\w* Mesa, \w rey|strong="H4428"\w* de \w Moab|strong="H4124"\w*, \w era|strong="H1961"\w* criador de ovejas y tributaba \w al|strong="H4428"\w* \w rey|strong="H4428"\w* de \w Israel|strong="H3478"\w* 100.000 \w corderos|strong="H3733"\w*, y la \w lana|strong="H6785"\w* de 100.000 carneros.
\v 5 Pero \w cuando|strong="H1961"\w* Acab murió, \w sucedió|strong="H1961"\w* \w que|strong="H1961"\w* el \w rey|strong="H4428"\w* de \w Moab|strong="H4124"\w* \w se|strong="H1961"\w* rebeló \w contra|strong="H1961"\w* el \w rey|strong="H4428"\w* de \w Israel|strong="H3478"\w*.
\p 
\v 6 \w Aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w el|strong="H1931"\w* \w rey|strong="H4428"\w* \w Joram|strong="H3088"\w* \w salió|strong="H3318"\w* de \w Samaria|strong="H8111"\w* y pasó revista \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w*.
\p 
\v 7 También \w envió|strong="H7971"\w* \w a|strong="H3068"\w* decir \w a|strong="H3068"\w* Josafat, \w rey|strong="H4428"\w* \w de|strong="H5971"\w* \w Judá|strong="H3063"\w*: El \w rey|strong="H4428"\w* \w de|strong="H5971"\w* \w Moab|strong="H4124"\w* \w se|strong="H5971"\w* rebeló contra mí. ¿\w Vas|strong="H3212"\w* conmigo \w a|strong="H3068"\w* la \w guerra|strong="H4421"\w* contra \w Moab|strong="H4124"\w*? \w Y|strong="H3068"\w* él respondió: Sí, voy. Yo soy \w como|strong="H3644"\w* tú, mi \w pueblo|strong="H5971"\w* \w como|strong="H3644"\w* tu \w pueblo|strong="H5971"\w* y mis \w caballos|strong="H5483"\w* \w como|strong="H3644"\w* los tuyos.
\p 
\v 8 \w Y|strong="H3068"\w* añadió: ¿\w Por|strong="H1870"\w* cuál \w camino|strong="H1870"\w* \w iremos|strong="H5927"\w*?
\p \w Y|strong="H3068"\w* \add Joram\add* respondió: \w Por|strong="H1870"\w* el \w camino|strong="H1870"\w* del \w desierto|strong="H4057"\w* de Edom.
\p 
\v 9 \w El|strong="H4264"\w* \w rey|strong="H4428"\w* \w de|strong="H4325"\w* \w Israel|strong="H3478"\w*, \w el|strong="H4264"\w* \w rey|strong="H4428"\w* \w de|strong="H4325"\w* \w Judá|strong="H3063"\w*, y \w el|strong="H4264"\w* \w rey|strong="H4428"\w* \w de|strong="H4325"\w* Edom salieron. Rodearon y \w anduvieron|strong="H3212"\w* \w por|strong="H1870"\w* \w el|strong="H4264"\w* desierto \w siete|strong="H7651"\w* \w días|strong="H3117"\w*, \w hasta|strong="H3117"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w hubo|strong="H1961"\w* \w agua|strong="H4325"\w* \w para|strong="H1961"\w* \w el|strong="H4264"\w* \w campamento|strong="H4264"\w* \w ni|strong="H3808"\w* \w para|strong="H1961"\w* las bestias \w que|strong="H3808"\w* \w los|strong="H1961"\w* \w seguían|strong="H1961"\w*.
\p 
\v 10 \w Entonces|strong="H3588"\w* \w el|strong="H3588"\w* \w rey|strong="H4428"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* dijo: ¡Ay! ¡\nd \w Yavé|strong="H3068"\w*\nd* trajo \w a|strong="H3068"\w* estos \w tres|strong="H7969"\w* \w reyes|strong="H4428"\w* \w para|strong="H3588"\w* entregarlos \w en|strong="H3588"\w* \w manos|strong="H3027"\w* \w de|strong="H3588"\w* \w Moab|strong="H4124"\w*!
\p 
\v 11 Pero Josafat preguntó: ¿\w No|strong="H5921"\w* hay \w aquí|strong="H6311"\w* un \w profeta|strong="H5030"\w* \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w para|strong="H5921"\w* \w que|strong="H5921"\w* \w consultemos|strong="H1875"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w por|strong="H5921"\w* \w medio|strong="H3027"\w* \w de|strong="H5921"\w* \w él|strong="H5921"\w*?
\p Entonces uno \w de|strong="H5921"\w* \w los|strong="H1121"\w* esclavos \w del|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w respondió|strong="H6030"\w*: \w Aquí|strong="H6311"\w* \w está|strong="H5921"\w* Eliseo, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Safat, quien vertía \w agua|strong="H4325"\w* \w en|strong="H5921"\w* \w las|strong="H5921"\w* \w manos|strong="H3027"\w* \w de|strong="H5921"\w* Elías.
\v 12 \w Y|strong="H3068"\w* Josafat dijo: La \w Palabra|strong="H1697"\w* \w de|strong="H1697"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w está|strong="H3426"\w* con él. \w Y|strong="H3068"\w* el \w rey|strong="H4428"\w* \w de|strong="H1697"\w* \w Israel|strong="H3478"\w*, el \w rey|strong="H4428"\w* \w de|strong="H1697"\w* Edom y Josafat fueron \w a|strong="H3068"\w* él.
\p 
\v 13 Eliseo preguntó \w al|strong="H4428"\w* \w rey|strong="H4428"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*: ¿\w Qué|strong="H3588"\w* tengo \w yo|strong="H3588"\w* contigo? \w Vete|strong="H3212"\w* \w a|strong="H3068"\w* \w los|strong="H3588"\w* \w profetas|strong="H5030"\w* \w de|strong="H3588"\w* tu padre \w y|strong="H3588"\w* tu madre.
\p \w Pero|strong="H3588"\w* \w el|strong="H3588"\w* \w rey|strong="H4428"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* le respondió: \w No|strong="H3588"\w*, \w porque|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* reunió \w a|strong="H3068"\w* estos \w tres|strong="H7969"\w* \w reyes|strong="H4428"\w* \w para|strong="H3588"\w* entregarlos \w en|strong="H3588"\w* \w manos|strong="H3027"\w* \w de|strong="H3588"\w* \w Moab|strong="H4124"\w*.
\p 
\v 14 \w Entonces|strong="H3588"\w* Eliseo dijo: ¡\w Vive|strong="H2416"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w de|strong="H3588"\w* las huestes, \w ante|strong="H6440"\w* Quien \w estoy|strong="H5975"\w*, \w que|strong="H3588"\w* \w si|strong="H3588"\w* \w no|strong="H3884"\w* fuera \w por|strong="H3588"\w* respeto \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w presencia|strong="H6440"\w* \w de|strong="H3588"\w* Josafat, \w rey|strong="H4428"\w* \w de|strong="H3588"\w* \w Judá|strong="H3063"\w*, \w no|strong="H3884"\w* \w te|strong="H3588"\w* haría caso ni \w te|strong="H3588"\w* miraría!
\v 15 Pero, tráiganme \w ahora|strong="H6258"\w* un tañedor.
\p \w Sucedió|strong="H1961"\w* \w que|strong="H6258"\w* mientras \w el|strong="H5921"\w* tañedor \w tañía|strong="H5059"\w*, \w la|strong="H5921"\w* \w mano|strong="H3027"\w* \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w vino|strong="H1961"\w* \w sobre|strong="H5921"\w* Eliseo
\v 16 \w y|strong="H3541"\w* dijo: \wj \nd \w Yavé|strong="H3068"\w*\nd* dice: \w Hagan|strong="H6213"\w* en \w este|strong="H2088"\w* valle muchas zanjas,\wj*
\v 17 \wj \w porque|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* dice: \w No|strong="H3808"\w* \w verán|strong="H7200"\w* \w viento|strong="H7307"\w* \w ni|strong="H3808"\w* \w lluvia|strong="H1653"\w*, \w pero|strong="H3588"\w* \w este|strong="H1931"\w* valle \w se|strong="H1931"\w* \w llenará|strong="H4390"\w* \w de|strong="H3588"\w* \w agua|strong="H4325"\w*, \w y|strong="H3588"\w* \w beberán|strong="H8354"\w* ustedes, \w sus|strong="H1931"\w* \w bestias|strong="H4735"\w* \w y|strong="H3588"\w* \w ganado|strong="H4735"\w*.\wj*
\v 18 \wj Si \w esto|strong="H2063"\w* \w es|strong="H3027"\w* \w poco|strong="H7043"\w* ante \nd \w Yavé|strong="H3068"\w*\nd*, Él también \w entregará|strong="H5414"\w* \w a|strong="H3068"\w* los moabitas en \w manos|strong="H3027"\w* \w de|strong="H5414"\w* ustedes.\wj*
\v 19 \wj Destruirán \w toda|strong="H3605"\w* \w ciudad|strong="H5892"\w* fortificada y \w todo|strong="H3605"\w* pueblo importante, talarán \w todo|strong="H3605"\w* \w árbol|strong="H6086"\w* \w bueno|strong="H2896"\w*, cerrarán \w toda|strong="H3605"\w* \w fuente|strong="H4599"\w* \w de|strong="H4325"\w* \w agua|strong="H4325"\w* y arruinarán con piedras \w toda|strong="H3605"\w* \w tierra|strong="H2513"\w* \w fértil|strong="H2896"\w*.\wj*
\p 
\v 20 \w Sucedió|strong="H1961"\w* \w que|strong="H4325"\w* \w a|strong="H3068"\w* la hora \w de|strong="H4325"\w* ofrecer el sacrificio \w de|strong="H4325"\w* la \w mañana|strong="H1242"\w*, \w ciertamente|strong="H2009"\w* \w llegó|strong="H5927"\w* \w agua|strong="H4325"\w* \w por|strong="H1870"\w* el \w camino|strong="H1870"\w* \w de|strong="H4325"\w* Edom, y la tierra \w se|strong="H1961"\w* \w llenó|strong="H4390"\w* \w de|strong="H4325"\w* \w agua|strong="H4325"\w*.
\p 
\v 21 \w Cuando|strong="H3588"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w de|strong="H5921"\w* \w Moab|strong="H4124"\w* \w oyeron|strong="H8085"\w* \w que|strong="H3588"\w* \w los|strong="H5921"\w* \w reyes|strong="H4428"\w* iban \w a|strong="H3068"\w* luchar \w contra|strong="H5921"\w* \w ellos|strong="H5921"\w*, convocaron \w a|strong="H3068"\w* \w todos|strong="H3605"\w*, \w desde|strong="H5921"\w* \w los|strong="H5921"\w* \w que|strong="H3588"\w* apenas \w se|strong="H5921"\w* ataban \w las|strong="H5921"\w* armas \w en|strong="H5921"\w* adelante, \w y|strong="H3588"\w* tomaron posición \w en|strong="H5921"\w* \w la|strong="H5921"\w* frontera.
\v 22 Cuando \w se|strong="H5921"\w* levantaron \w por|strong="H5921"\w* \w la|strong="H5921"\w* \w mañana|strong="H1242"\w*, \w el|strong="H5921"\w* \w sol|strong="H8121"\w* brillaba \w sobre|strong="H5921"\w* \w las|strong="H5921"\w* \w aguas|strong="H4325"\w*. \w Los|strong="H5921"\w* \w de|strong="H5921"\w* \w Moab|strong="H4124"\w* \w vieron|strong="H7200"\w* \w desde|strong="H5921"\w* lejos \w las|strong="H5921"\w* \w aguas|strong="H4325"\w* rojas \w como|strong="H5921"\w* \w sangre|strong="H1818"\w*
\v 23 y dijeron: ¡\w Es|strong="H2088"\w* \w sangre|strong="H1818"\w*! \w Ciertamente|strong="H5221"\w* los \w reyes|strong="H4428"\w* se atacaron el uno \w al|strong="H4428"\w* \w otro|strong="H2088"\w* y se \w mataron|strong="H5221"\w* unos con otros. \w Ahora|strong="H6258"\w* \w pues|strong="H6258"\w*, \w Moab|strong="H4124"\w*: ¡\w Al|strong="H4428"\w* botín!
\p 
\v 24 Pero cuando llegaron al \w campamento|strong="H4264"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*, se \w levantaron|strong="H6965"\w* los israelitas y atacaron \w a|strong="H3068"\w* los \w de|strong="H6440"\w* \w Moab|strong="H4124"\w*, quienes \w huyeron|strong="H5127"\w* \w de|strong="H6440"\w* ellos. Pero los persiguieron y \w mataron|strong="H5221"\w* \w a|strong="H3068"\w* los moabitas.
\v 25 Asolaron las \w ciudades|strong="H5892"\w*. \w En|strong="H5704"\w* \w todas|strong="H3605"\w* las tierras \w fértiles|strong="H2896"\w* \w cada|strong="H3605"\w* uno \w echó|strong="H7993"\w* su piedra \w y|strong="H5704"\w* \w la|strong="H3605"\w* \w llenaron|strong="H4390"\w*. Cerraron \w toda|strong="H3605"\w* \w fuente|strong="H4599"\w* \w de|strong="H5704"\w* \w agua|strong="H4325"\w*. Talaron \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w árboles|strong="H6086"\w* \w buenos|strong="H2896"\w*. Incluso \w a|strong="H3068"\w* Kir-herés solo le \w quedaron|strong="H7604"\w* piedras, \w después|strong="H5704"\w* \w que|strong="H5704"\w* \w los|strong="H3605"\w* honderos \w la|strong="H3605"\w* cercaron \w y|strong="H5704"\w* \w la|strong="H3605"\w* destruyeron.
\p 
\v 26 \w Cuando|strong="H3588"\w* \w el|strong="H3588"\w* \w rey|strong="H4428"\w* \w de|strong="H4480"\w* \w Moab|strong="H4124"\w* \w vio|strong="H7200"\w* \w que|strong="H3588"\w* \w la|strong="H3588"\w* \w batalla|strong="H4421"\w* arreciaba \w contra|strong="H4480"\w* \w él|strong="H3588"\w*, \w tomó|strong="H3947"\w* consigo 700 hombres \w que|strong="H3588"\w* \w sacaban|strong="H8025"\w* \w espada|strong="H2719"\w*, \w para|strong="H3588"\w* atacar \w al|strong="H4480"\w* \w rey|strong="H4428"\w* \w de|strong="H4480"\w* Edom, \w pero|strong="H3588"\w* \w no|strong="H3808"\w* \w pudieron|strong="H3201"\w*.
\v 27 \w Entonces|strong="H7725"\w* \w tomó|strong="H3947"\w* \w a|strong="H3068"\w* su \w hijo|strong="H1121"\w* \w primogénito|strong="H1060"\w* \w que|strong="H5921"\w* iba \w a|strong="H3068"\w* reinar \w en|strong="H5921"\w* su \w lugar|strong="H8478"\w* \w y|strong="H5921"\w* \w lo|strong="H5921"\w* \w ofreció|strong="H5927"\w* \w en|strong="H5921"\w* \w holocausto|strong="H5930"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w muro|strong="H2346"\w*. \w Hubo|strong="H1961"\w* una \w gran|strong="H1419"\w* \w ira|strong="H7110"\w* \w contra|strong="H5921"\w* \w Israel|strong="H3478"\w*. \w Ellos|strong="H5921"\w* \w salieron|strong="H5265"\w* \w de|strong="H5921"\w* allí \w y|strong="H5921"\w* \w volvieron|strong="H7725"\w* \w a|strong="H3068"\w* su tierra.
\c 4
\s1 Hechos de Eliseo
\s1 Provisión de aceite para una viuda
\p 
\v 1 Cierta viuda, \w de|strong="H3588"\w* las esposas \w de|strong="H3588"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w los|strong="H1121"\w* \w profetas|strong="H5030"\w*, \w clamó|strong="H6817"\w* \w a|strong="H3068"\w* Eliseo: Tu esclavo, \w mi|strong="H1961"\w* esposo, \w murió|strong="H4191"\w*. Tú \w sabes|strong="H3045"\w* \w que|strong="H3588"\w* tu esclavo \w era|strong="H1961"\w* \w temeroso|strong="H3372"\w* \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd*. Ahora un acreedor \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w tomar|strong="H3947"\w* \w a|strong="H3068"\w* mis \w dos|strong="H8147"\w* \w hijos|strong="H1121"\w* \w como|strong="H3588"\w* esclavos suyos.
\p 
\v 2 Eliseo le preguntó: ¿\w Qué|strong="H3588"\w* puedo \w hacer|strong="H6213"\w* \w por|strong="H3588"\w* ti? Dime \w qué|strong="H3588"\w* \w tienes|strong="H3426"\w* \w en|strong="H3588"\w* \w casa|strong="H1004"\w*.
\p \w Y|strong="H3068"\w* \w ella|strong="H3605"\w* respondió: \w Tu|strong="H6213"\w* esclava \w no|strong="H6213"\w* \w tiene|strong="H3426"\w* \w alguna|strong="H3605"\w* \w cosa|strong="H3605"\w* \w en|strong="H3588"\w* \w su|strong="H3588"\w* \w casa|strong="H1004"\w*, \w sino|strong="H3588"\w* una vasija \w de|strong="H3588"\w* \w aceite|strong="H8081"\w*.
\p 
\v 3 \w Y|strong="H3068"\w* le dijo: \w Vé|strong="H3212"\w* \w a|strong="H3068"\w* pedir \w vasijas|strong="H3605"\w* \w a|strong="H3068"\w* \w todas|strong="H3605"\w* tus vecinas, \w vasijas|strong="H3605"\w* vacías, no pocas.
\v 4 Luego entra \w y|strong="H5921"\w* enciérrate \w con|strong="H5921"\w* tus \w hijos|strong="H1121"\w*, \w y|strong="H5921"\w* echa aceite \w en|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w vasijas|strong="H3605"\w*. Pon \w aparte|strong="H5265"\w* \w las|strong="H5921"\w* \w que|strong="H5921"\w* estén \w llenas|strong="H4392"\w*.
\p 
\v 5 \w Ella|strong="H1931"\w* \w se|strong="H1931"\w* alejó \w de|strong="H1121"\w* \w él|strong="H1931"\w* y \w se|strong="H1931"\w* encerró con \w sus|strong="H1931"\w* \w hijos|strong="H1121"\w*. \w Ellos|strong="H1992"\w* \w le|strong="H1931"\w* llevaban \w las|strong="H1992"\w* vasijas, y \w ella|strong="H1931"\w* vertía \w el|strong="H1931"\w* aceite.
\v 6 \w Sucedió|strong="H1961"\w* \w que|strong="H1121"\w* \w cuando|strong="H1961"\w* las vasijas \w estaban|strong="H1961"\w* \w llenas|strong="H4390"\w*, dijo \w a|strong="H3068"\w* un \w hijo|strong="H1121"\w* suyo: \w Tráeme|strong="H5066"\w* \w otra|strong="H5750"\w* \w vasija|strong="H3627"\w*.
\p \w Y|strong="H3068"\w* \w él|strong="H1121"\w* respondió: \w No|strong="H1961"\w* \w hay|strong="H1961"\w* \w más|strong="H5750"\w* vasijas. Entonces cesó \w el|strong="H1121"\w* \w aceite|strong="H8081"\w*.
\p 
\v 7 Ella \w fue|strong="H3212"\w* y se lo \w dijo|strong="H5046"\w* al varón \w de|strong="H1121"\w* \nd ʼElohim\nd*. \w Y|strong="H3068"\w* \w él|strong="H1121"\w* \w dijo|strong="H5046"\w*: \w Vé|strong="H3212"\w*, \w vende|strong="H4376"\w* \w el|strong="H1121"\w* \w aceite|strong="H8081"\w* y \w paga|strong="H7999"\w* tu deuda. \w Vive|strong="H2421"\w* con tus \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* lo \w que|strong="H1121"\w* quede.
\s1 Cuidados de una sunamita para Eliseo
\p 
\v 8 También \w aconteció|strong="H1961"\w* un \w día|strong="H3117"\w*, \w que|strong="H3117"\w* Eliseo \w pasaba|strong="H5674"\w* por \w Sunem|strong="H7766"\w*. \w Había|strong="H1961"\w* \w allí|strong="H8033"\w* una mujer distinguida, la cual lo invitaba con insistencia \w a|strong="H3068"\w* comer. \w Sucedió|strong="H1961"\w* \w que|strong="H3117"\w* \w siempre|strong="H3899"\w* \w que|strong="H3117"\w* \w pasaba|strong="H5674"\w* por \w allí|strong="H8033"\w*, \w él|strong="H5674"\w* entraba \w a|strong="H3068"\w* comer.
\v 9 \w Y|strong="H3068"\w* \w ella|strong="H1931"\w* dijo \w a|strong="H3068"\w* \w su|strong="H1931"\w* esposo: \w Mira|strong="H2009"\w*, \w ahora|strong="H4994"\w* \w sé|strong="H3045"\w* \w que|strong="H3588"\w* \w el|strong="H1931"\w* hombre \w que|strong="H3588"\w* \w siempre|strong="H8548"\w* \w pasa|strong="H5674"\w* \w por|strong="H5921"\w* nuestra casa \w es|strong="H1931"\w* un \w santo|strong="H6918"\w* varón \w de|strong="H5921"\w* \nd ʼElohim\nd*.
\v 10 Te \w ruego|strong="H4994"\w* \w que|strong="H4994"\w* \w hagamos|strong="H6213"\w* un \w pequeño|strong="H6996"\w* aposento de paredes \w en|strong="H5493"\w* la azotea. \w Pongamos|strong="H7760"\w* \w allí|strong="H8033"\w* una \w cama|strong="H4296"\w*, una \w mesa|strong="H7979"\w*, una silla y un candelero, \w para|strong="H1961"\w* \w que|strong="H4994"\w* \w cuando|strong="H1961"\w* \w venga|strong="H1961"\w* \w entre|strong="H6996"\w* \w allí|strong="H8033"\w*.
\p 
\v 11 \w Sucedió|strong="H1961"\w* \w que|strong="H3117"\w* un \w día|strong="H3117"\w* \w fue|strong="H1961"\w* \w allí|strong="H8033"\w*. \w Se|strong="H1961"\w* \w quedó|strong="H1961"\w* \w en|strong="H5493"\w* aquel aposento y \w allí|strong="H8033"\w* \w durmió|strong="H7901"\w*.
\v 12 Luego dijo \w a|strong="H3068"\w* su esclavo \w Giezi|strong="H1522"\w*: \w Llama|strong="H7121"\w* \w a|strong="H3068"\w* \w esta|strong="H2063"\w* \w sunamita|strong="H7767"\w*. Cuando \w la|strong="H2063"\w* \w llamó|strong="H7121"\w*, ella se presentó \w ante|strong="H6440"\w* él.
\p 
\v 13 \w Y|strong="H3068"\w* le \w dijo|strong="H1696"\w* \w a|strong="H3068"\w* Giezi: Dile: \w Mira|strong="H2009"\w*, estuviste solícita \w por|strong="H4100"\w* \w nosotros|strong="H3605"\w* con \w todo|strong="H3605"\w* \w este|strong="H2063"\w* esmero. ¿\w Qué|strong="H4100"\w* quieres \w que|strong="H4100"\w* \w haga|strong="H6213"\w* \w por|strong="H4100"\w* ti? ¿Quieres \w que|strong="H4100"\w* \w hable|strong="H1696"\w* \w por|strong="H4100"\w* ti \w al|strong="H4428"\w* \w rey|strong="H4428"\w* \w o|strong="H3068"\w* \w al|strong="H4428"\w* \w jefe|strong="H8269"\w* del \w ejército|strong="H6635"\w*? Pero \w ella|strong="H3605"\w* respondió: \w Yo|strong="H2009"\w* vivo \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H5971"\w* \w mi|strong="H2009"\w* \w pueblo|strong="H5971"\w*.
\p 
\v 14 \w Y|strong="H3068"\w* \w él|strong="H1121"\w* dijo \w a|strong="H3068"\w* \w Giezi|strong="H1522"\w*: ¿\w Qué|strong="H4100"\w* \w haremos|strong="H6213"\w* \w por|strong="H4100"\w* ella?
\p \w Y|strong="H3068"\w* respondió \w Giezi|strong="H1522"\w*: En verdad ella \w no|strong="H6213"\w* tiene \w hijos|strong="H1121"\w*, y su esposo es anciano.
\s1 Profecía con respecto a un hijo para la sunamita
\p 
\v 15 \w Y|strong="H3068"\w* él dijo: \w Llámala|strong="H7121"\w*. Así que la \w llamó|strong="H7121"\w* y ella se detuvo \w en|strong="H5975"\w* la \w puerta|strong="H6607"\w*.
\v 16 \w Y|strong="H3068"\w* \w él|strong="H1121"\w* dijo: \w El|strong="H1121"\w* año \w que|strong="H1121"\w* viene, \w por|strong="H2088"\w* \w este|strong="H2088"\w* \w tiempo|strong="H6256"\w*, \w abrazarás|strong="H2263"\w* \w a|strong="H3068"\w* un \w hijo|strong="H1121"\w*.
\p Pero ella respondió: ¡No, \tl ʼadón\tl* mío, varón \w de|strong="H1121"\w* \nd ʼElohim\nd*, no engañes \w a|strong="H3068"\w* tu esclava!
\p 
\v 17 Pero la mujer \w concibió|strong="H2029"\w* y dio \w a|strong="H3068"\w* luz un \w hijo|strong="H1121"\w* en \w el|strong="H1121"\w* \w tiempo|strong="H6256"\w* \w que|strong="H1121"\w* Eliseo le \w dijo|strong="H1696"\w*.
\s1 Muerte del hijo de la sunamita
\p 
\v 18 El niño \w creció|strong="H1431"\w*. Pero \w sucedió|strong="H1961"\w* \w que|strong="H3117"\w* un \w día|strong="H3117"\w*, \w cuando|strong="H3117"\w* \w salió|strong="H3318"\w* con su padre y con \w los|strong="H1961"\w* cosechadores,
\v 19 dijo \w a|strong="H3068"\w* su padre: ¡Ay, \w mi|strong="H5375"\w* \w cabeza|strong="H7218"\w*, \w mi|strong="H5375"\w* \w cabeza|strong="H7218"\w*!
\p \w Y|strong="H3068"\w* él dijo al esclavo: \w Llévalo|strong="H5375"\w* \w a|strong="H3068"\w* su madre.
\v 20 \w Cuando|strong="H5704"\w* \w lo|strong="H5921"\w* \w llevó|strong="H5375"\w* \w a|strong="H3068"\w* su madre, \w se|strong="H5921"\w* sentó \w en|strong="H5921"\w* sus \w rodillas|strong="H1290"\w* \w hasta|strong="H5704"\w* \w el|strong="H5921"\w* mediodía, \w y|strong="H5921"\w* \w luego|strong="H5704"\w* \w murió|strong="H4191"\w*.
\v 21 \w Ella|strong="H5921"\w* \w subió|strong="H5927"\w* \w y|strong="H5921"\w* \w lo|strong="H5921"\w* acostó \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w cama|strong="H4296"\w* \w del|strong="H5921"\w* varón \w de|strong="H5921"\w* \nd ʼElohim\nd*, \w cerró|strong="H5462"\w* \w la|strong="H5921"\w* puerta \w y|strong="H5921"\w* \w salió|strong="H3318"\w*.
\p 
\v 22 \w Luego|strong="H4994"\w* \w llamó|strong="H7121"\w* \w a|strong="H3068"\w* su esposo \w y|strong="H5704"\w* le dijo: Mándame \w ahora|strong="H4994"\w* \w a|strong="H3068"\w* uno \w de|strong="H4480"\w* los esclavos \w y|strong="H5704"\w* una \w de|strong="H4480"\w* las asnas, \w para|strong="H5704"\w* \w que|strong="H4480"\w* \w yo|strong="H4480"\w* vaya rápido \w a|strong="H3068"\w* hablar \w al|strong="H4480"\w* varón \w de|strong="H4480"\w* \nd ʼElohim\nd* \w y|strong="H5704"\w* \w vuelva|strong="H7725"\w*.
\p 
\v 23 Pero él preguntó: ¿\w Por|strong="H4069"\w* \w qué|strong="H3808"\w* tienes \w que|strong="H3808"\w* \w ir|strong="H1980"\w* \w a|strong="H3068"\w* hablar con él \w hoy|strong="H3117"\w*? \w No|strong="H3808"\w* es luna nueva, \w ni|strong="H3808"\w* \w sábado|strong="H7676"\w*.
\p Ella respondió: \w Paz|strong="H7965"\w*.
\v 24 Aparejó \w el|strong="H3588"\w* asna \w y|strong="H3588"\w* dijo al esclavo: Arrea \w y|strong="H3588"\w* \w anda|strong="H3212"\w* sin detenerte, \w a|strong="H3068"\w* \w menos|strong="H3588"\w* \w que|strong="H3588"\w* \w te|strong="H3588"\w* lo diga.
\p 
\v 25 \w Fue|strong="H1961"\w* y \w llegó|strong="H3212"\w* al varón \w de|strong="H5048"\w* \nd ʼElohim\nd* \w en|strong="H3212"\w* la montaña Carmelo.
\p \w Y|strong="H3068"\w* \w sucedió|strong="H1961"\w* \w que|strong="H1961"\w* \w cuando|strong="H1961"\w* el varón \w de|strong="H5048"\w* \nd ʼElohim\nd* la \w vio|strong="H7200"\w* \w de|strong="H5048"\w* lejos, dijo \w a|strong="H3068"\w* su esclavo \w Giezi|strong="H1522"\w*: \w Aquí|strong="H2009"\w* \w está|strong="H1961"\w* la \w sunamita|strong="H7767"\w*.
\v 26 \w Corre|strong="H7323"\w* \w ahora|strong="H6258"\w* \w a|strong="H3068"\w* encontrarla y pregúntale: ¿Te \w va|strong="H3068"\w* \w bien|strong="H7965"\w*? ¿Están \w bien|strong="H7965"\w* tu esposo y tu hijo?
\p Ella respondió: \w Bien|strong="H7965"\w*.
\p 
\v 27 \w Pero|strong="H3588"\w* \w al|strong="H4480"\w* llegar \w a|strong="H3068"\w* \w la|strong="H3588"\w* montaña, ante \w el|strong="H3588"\w* varón \w de|strong="H4480"\w* \nd ʼElohim\nd*, \w ella|strong="H4480"\w* \w se|strong="H4480"\w* aferró \w a|strong="H3068"\w* sus \w pies|strong="H7272"\w*. \w Giezi|strong="H1522"\w* \w se|strong="H4480"\w* \w acercó|strong="H5066"\w* \w para|strong="H3588"\w* apartarla, \w pero|strong="H3588"\w* \w el|strong="H3588"\w* varón \w de|strong="H4480"\w* \nd ʼElohim\nd* \w dijo|strong="H5046"\w*: \w Déjala|strong="H7503"\w*, \w porque|strong="H3588"\w* \w su|strong="H3588"\w* \w alma|strong="H5315"\w* está \w en|strong="H4480"\w* \w amargura|strong="H4843"\w*. \nd \w Yavé|strong="H3068"\w*\nd* \w me|strong="H4480"\w* ocultó \w el|strong="H3588"\w* asunto, \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w me|strong="H4480"\w* \w lo|strong="H3808"\w* \w declaró|strong="H5046"\w*.
\p 
\v 28 Entonces ella dijo: ¿\w Pedí|strong="H7592"\w* yo un \w hijo|strong="H1121"\w* \w a|strong="H3068"\w* mi \tl ʼadon\tl*? ¿\w No|strong="H3808"\w* te dije \w que|strong="H3808"\w* \w no|strong="H3808"\w* me engañaras?
\p 
\v 29 \w Entonces|strong="H3588"\w* \w él|strong="H5921"\w* dijo \w a|strong="H3068"\w* \w Giezi|strong="H1522"\w*: Ata tu cintura, \w toma|strong="H3947"\w* \w mi|strong="H5921"\w* bastón \w en|strong="H5921"\w* tu \w mano|strong="H3027"\w* \w y|strong="H3588"\w* \w vete|strong="H3212"\w*. \w Si|strong="H3588"\w* alguno \w te|strong="H5921"\w* encuentra, \w no|strong="H3808"\w* \w lo|strong="H3808"\w* saludes, \w y|strong="H3588"\w* \w si|strong="H3588"\w* alguien \w te|strong="H5921"\w* saluda, \w no|strong="H3808"\w* \w respondas|strong="H6030"\w*. \w Pon|strong="H7760"\w* \w mi|strong="H5921"\w* bastón \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w cara|strong="H6440"\w* \w del|strong="H5921"\w* \w niño|strong="H5288"\w*.
\p 
\v 30 \w Y|strong="H3068"\w* la madre del \w niño|strong="H5288"\w* dijo: \w Vive|strong="H2416"\w* \nd \w Yavé|strong="H3068"\w*\nd* y \w vive|strong="H2416"\w* tu \w alma|strong="H5315"\w* que no \w te|strong="H5315"\w* \w dejaré|strong="H5800"\w*. \w Y|strong="H3068"\w* él se \w levantó|strong="H6965"\w* y la \w siguió|strong="H3212"\w*.
\p 
\v 31 \w Giezi|strong="H1522"\w* \w se|strong="H5921"\w* adelantó \w a|strong="H3068"\w* \w ellos|strong="H5921"\w* \w y|strong="H5921"\w* \w puso|strong="H7760"\w* \w el|strong="H5921"\w* bastón \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w cara|strong="H6440"\w* \w del|strong="H5921"\w* \w niño|strong="H5288"\w*, pero \w no|strong="H3808"\w* hubo \w voz|strong="H6963"\w* \w ni|strong="H3808"\w* reacción. Así \w que|strong="H3808"\w* regresó \w a|strong="H3068"\w* encontrase \w con|strong="H5921"\w* Eliseo \w y|strong="H5921"\w* \w le|strong="H5921"\w* \w declaró|strong="H5046"\w*: \w El|strong="H5921"\w* \w niño|strong="H5288"\w* \w no|strong="H3808"\w* \w despierta|strong="H6974"\w*.
\p 
\v 32 Cuando Eliseo llegó \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w*, ahí \w estaba|strong="H1004"\w* \w el|strong="H5921"\w* niñito \w muerto|strong="H4191"\w*, tendido \w sobre|strong="H5921"\w* su \w cama|strong="H4296"\w*.
\v 33 Entonces entró, se encerraron los \w dos|strong="H8147"\w* y \w oró|strong="H6419"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\v 34 \w Después|strong="H5921"\w* \w subió|strong="H5927"\w* \w y|strong="H5921"\w* \w se|strong="H5921"\w* echó \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* niño. \w Puso|strong="H7760"\w* su \w boca|strong="H6310"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w de|strong="H5921"\w* \w él|strong="H5921"\w*, sus \w ojos|strong="H5869"\w* \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* \w de|strong="H5921"\w* \w él|strong="H5921"\w*, \w y|strong="H5921"\w* sus \w manos|strong="H3709"\w* \w sobre|strong="H5921"\w* \w las|strong="H5921"\w* \w de|strong="H5921"\w* \w él|strong="H5921"\w*. \w Se|strong="H5921"\w* tendió \w sobre|strong="H5921"\w* \w él|strong="H5921"\w*, \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w carne|strong="H1320"\w* \w del|strong="H5921"\w* niño \w se|strong="H5921"\w* calentó.
\v 35 \w Luego|strong="H5927"\w* \w volvió|strong="H7725"\w*, \w y|strong="H5921"\w* caminó \w de|strong="H5921"\w* un lado \w a|strong="H3068"\w* otro \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w*. \w Después|strong="H5921"\w* \w subió|strong="H5927"\w*, \w se|strong="H5921"\w* tendió \w sobre|strong="H5921"\w* \w él|strong="H5921"\w*, \w y|strong="H5921"\w* \w el|strong="H5921"\w* niñito estornudó \w siete|strong="H7651"\w* \w veces|strong="H6471"\w* \w y|strong="H5921"\w* \w abrió|strong="H6491"\w* sus \w ojos|strong="H5869"\w*.
\p 
\v 36 Entonces \w llamó|strong="H7121"\w* \w a|strong="H3068"\w* \w Giezi|strong="H1522"\w*: \w Llama|strong="H7121"\w* \w a|strong="H3068"\w* \w esta|strong="H2063"\w* \w sunamita|strong="H7767"\w*. \w La|strong="H2063"\w* \w llamó|strong="H7121"\w*. Cuando ella llegó, \w él|strong="H1121"\w* le dijo: ¡\w Alza|strong="H5375"\w* \w a|strong="H3068"\w* tu \w hijo|strong="H1121"\w*!
\v 37 \w Ella|strong="H5921"\w* entonces entró \w y|strong="H5921"\w* \w cayó|strong="H5307"\w* \w a|strong="H3068"\w* sus \w pies|strong="H7272"\w* postrada \w en|strong="H5921"\w* tierra. \w Después|strong="H5921"\w* \w alzó|strong="H5375"\w* \w a|strong="H3068"\w* su \w hijo|strong="H1121"\w* \w y|strong="H5921"\w* \w salió|strong="H3318"\w*.
\s1 La muerte en la olla
\p 
\v 38 Eliseo \w volvió|strong="H7725"\w* \w a|strong="H3068"\w* \w Gilgal|strong="H1537"\w*. Había \w entonces|strong="H7725"\w* una hambruna en la tierra. \w Los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w los|strong="H3427"\w* \w profetas|strong="H5030"\w* se \w sentaron|strong="H3427"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w él|strong="H1121"\w*, y \w él|strong="H1121"\w* dijo \w a|strong="H3068"\w* su esclavo: Prepara la \w olla|strong="H5518"\w* \w grande|strong="H1419"\w* y prepara un guiso para \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w los|strong="H3427"\w* \w profetas|strong="H5030"\w*.
\p 
\v 39 Uno \w de|strong="H4480"\w* \w ellos|strong="H4480"\w* \w salió|strong="H3318"\w* \w al|strong="H4480"\w* \w campo|strong="H7704"\w* \w a|strong="H3068"\w* recoger hierbas. Encontró \w una|strong="H4672"\w* \w vid|strong="H1612"\w* silvestre \w y|strong="H3588"\w* \w recogió|strong="H3950"\w* \w de|strong="H4480"\w* \w ella|strong="H4480"\w* \w calabazas|strong="H6498"\w* \w silvestres|strong="H7704"\w* hasta llenar \w su|strong="H3588"\w* faldón. Regresó \w y|strong="H3588"\w* las echó \w en|strong="H4480"\w* \w la|strong="H3588"\w* \w olla|strong="H5518"\w* \w del|strong="H4480"\w* guiso, \w aunque|strong="H3588"\w* \w no|strong="H3808"\w* \w sabían|strong="H3045"\w* \w qué|strong="H3588"\w* \w eran|strong="H3808"\w*.
\v 40 Luego sirvieron \w a|strong="H3068"\w* \w los|strong="H1992"\w* hombres \w para|strong="H1961"\w* \w que|strong="H3808"\w* comieran. Pero \w sucedió|strong="H1961"\w* \w que|strong="H3808"\w* \w cuando|strong="H1961"\w* comían \w el|strong="H1992"\w* guiso, gritaron: ¡Varón de \nd ʼElohim\nd*, \w hay|strong="H1961"\w* \w muerte|strong="H4194"\w* en la \w olla|strong="H5518"\w*! \w Y|strong="H3068"\w* \w no|strong="H3808"\w* \w pudieron|strong="H3201"\w* comer.
\p 
\v 41 Entonces él dijo: Tráiganme \w harina|strong="H7058"\w*. \w Y|strong="H3068"\w* la \w echó|strong="H7993"\w* en la \w olla|strong="H5518"\w* y dijo: Sirve \w a|strong="H3068"\w* la \w gente|strong="H5971"\w* \w para|strong="H1961"\w* \w que|strong="H3808"\w* coma. \w Y|strong="H3068"\w* \w nada|strong="H3808"\w* \w malo|strong="H7451"\w* \w hubo|strong="H1961"\w* en la \w olla|strong="H5518"\w*.
\s1 Multiplicación de panes
\p 
\v 42 Entonces llegó un hombre \w de|strong="H5971"\w* Baal-salisa, y llevó \w para|strong="H5414"\w* el varón \w de|strong="H5971"\w* \nd ʼElohim\nd* \w pan|strong="H3899"\w* \w de|strong="H5971"\w* las primicias: 20 \w panes|strong="H3899"\w* \w de|strong="H5971"\w* \w cebada|strong="H8184"\w* con espigas \w de|strong="H5971"\w* trigo nuevo. \w Y|strong="H3068"\w* Eliseo dijo: Dalo \w a|strong="H3068"\w* la \w gente|strong="H5971"\w* \w para|strong="H5414"\w* \w que|strong="H5971"\w* coma.
\p 
\v 43 \w Pero|strong="H3588"\w* \w su|strong="H3588"\w* esclavo preguntó: ¿\w Cómo|strong="H4100"\w* serviré \w esto|strong="H2088"\w* \w a|strong="H3068"\w* 100 hombres?
\p \w Y|strong="H3068"\w* \w él|strong="H3588"\w* respondió: Dalo \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w gente|strong="H5971"\w* \w para|strong="H3588"\w* \w que|strong="H3588"\w* coma, \w porque|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* dice: \wj Comerán, \w y|strong="H3588"\w* sobrará.\wj*
\v 44 \w Y|strong="H3068"\w* \w lo|strong="H1697"\w* sirvió. Comieron y les sobró, según la \w Palabra|strong="H1697"\w* \w de|strong="H6440"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\c 5
\s1 Aventuras del general Naamán
\p 
\v 1 \w Naamán|strong="H5283"\w*, \w general|strong="H8269"\w* del \w ejército|strong="H2428"\w* del \w rey|strong="H4428"\w* \w de|strong="H3588"\w* Siria, \w era|strong="H1961"\w* un \w hombre|strong="H1368"\w* muy estimado \w por|strong="H3588"\w* \w su|strong="H3588"\w* \tl ʼadón\tl* \w porque|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w dio|strong="H5414"\w* victoria \w a|strong="H3068"\w* Siria \w por|strong="H3588"\w* medio \w de|strong="H3588"\w* \w él|strong="H3588"\w*. \w Era|strong="H1961"\w* \w además|strong="H3588"\w* muy \w valiente|strong="H1368"\w*, \w pero|strong="H3588"\w* \w leproso|strong="H6879"\w*.
\p 
\v 2 \w Los|strong="H1961"\w* sirios \w salieron|strong="H3318"\w* \w en|strong="H3318"\w* incursiones, y llevaron cautiva \w a|strong="H3068"\w* una muchacha \w de|strong="H6440"\w* la tierra \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*, la cual \w servía|strong="H1961"\w* \w a|strong="H3068"\w* la esposa \w de|strong="H6440"\w* \w Naamán|strong="H5283"\w*.
\v 3 \w Y|strong="H3068"\w* ella dijo \w a|strong="H3068"\w* su \tl ʼadón\tl*: ¡Deseo que mi \tl ʼadón\tl* vaya al \w profeta|strong="H5030"\w* que está en \w Samaria|strong="H8111"\w*! \w Él|strong="H5030"\w* lo sanaría \w de|strong="H6440"\w* su \w lepra|strong="H6883"\w*.
\p 
\v 4 Naamán fue \w e|strong="H3068"\w* informó \w a|strong="H3068"\w* su \tl ʼadón\tl*: \w Así|strong="H2063"\w* y \w así|strong="H2063"\w* \w dijo|strong="H1696"\w* \w la|strong="H2063"\w* muchacha que \w es|strong="H2063"\w* de \w la|strong="H2063"\w* tierra de \w Israel|strong="H3478"\w*.
\v 5 \w Y|strong="H3068"\w* el \w rey|strong="H4428"\w* de Siria dijo: \w Vé|strong="H3212"\w* allí con una \w carta|strong="H5612"\w* para el \w rey|strong="H4428"\w* de \w Israel|strong="H3478"\w*. \w Salió|strong="H3212"\w* y llevaba consigo 330 kilogramos de \w plata|strong="H3701"\w*, 7.000 piezas de \w oro|strong="H2091"\w* y \w diez|strong="H6235"\w* \w mudas|strong="H2487"\w* de ropa.
\v 6 Llevó la \w carta|strong="H5612"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w* de \w Israel|strong="H3478"\w*, la cual decía: \w Ahora|strong="H6258"\w* \w pues|strong="H6258"\w*, \w cuando|strong="H5650"\w* \w esta|strong="H2088"\w* \w carta|strong="H5612"\w* llegue \w a|strong="H3068"\w* ti, \w ciertamente|strong="H2009"\w* te \w envío|strong="H7971"\w* \w a|strong="H3068"\w* \w mi|strong="H2009"\w* esclavo \w Naamán|strong="H5283"\w*, \w para|strong="H6258"\w* \w que|strong="H6258"\w* \w lo|strong="H2088"\w* sanes de su \w lepra|strong="H6883"\w*.
\p 
\v 7 \w Sucedió|strong="H1961"\w* \w que|strong="H3588"\w* \w al|strong="H4428"\w* \w leer|strong="H5612"\w* \w la|strong="H1931"\w* \w carta|strong="H5612"\w*, \w el|strong="H1931"\w* \w rey|strong="H4428"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* \w rasgó|strong="H7167"\w* \w sus|strong="H1931"\w* ropas \w y|strong="H3588"\w* dijo: ¿\w Soy|strong="H1961"\w* \w yo|strong="H3588"\w* \nd ʼElohim\nd* \w que|strong="H3588"\w* \w mata|strong="H4191"\w* \w o|strong="H3068"\w* da \w vida|strong="H2421"\w*, \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w éste|strong="H2088"\w* \w me|strong="H3588"\w* \w envíe|strong="H7971"\w* \w a|strong="H3068"\w* un hombre \w y|strong="H3588"\w* espere \w que|strong="H3588"\w* \w yo|strong="H3588"\w* \w lo|strong="H1931"\w* sane \w de|strong="H3588"\w* \w su|strong="H1931"\w* \w lepra|strong="H6883"\w*? Consideren \w ahora|strong="H4994"\w*, \w y|strong="H3588"\w* \w vean|strong="H7200"\w* \w cómo|strong="H3588"\w* busca ocasión \w contra|strong="H3478"\w* \w mí|strong="H1961"\w*.
\p 
\v 8 \w Pero|strong="H3588"\w* \w aconteció|strong="H1961"\w* \w que|strong="H3588"\w* \w al|strong="H4428"\w* \w oír|strong="H8085"\w* Eliseo, \w el|strong="H3588"\w* varón \w de|strong="H3588"\w* \nd ʼElohim\nd*, \w que|strong="H3588"\w* \w el|strong="H3588"\w* \w rey|strong="H4428"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* \w rasgó|strong="H7167"\w* sus ropas, \w envió|strong="H7971"\w* \w a|strong="H3068"\w* \w decir|strong="H8085"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w*: ¿\w Por|strong="H3588"\w* \w qué|strong="H3588"\w* rasgaste tus ropas? \w Que|strong="H3588"\w* \w venga|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w* \w y|strong="H3588"\w* \w sabrá|strong="H3045"\w* \w que|strong="H3588"\w* \w hay|strong="H3426"\w* \w profeta|strong="H5030"\w* \w en|strong="H3588"\w* \w Israel|strong="H3478"\w*.
\v 9 Entonces \w Naamán|strong="H5283"\w* fue con sus \w caballos|strong="H5483"\w* y sus carruajes, y se detuvo \w en|strong="H5975"\w* la \w puerta|strong="H6607"\w* de la \w casa|strong="H1004"\w* de Eliseo.
\v 10 Eliseo le \w envió|strong="H7971"\w* un \w mensajero|strong="H4397"\w*, quien le dijo: \w Vé|strong="H1980"\w* y \w lávate|strong="H7364"\w* \w siete|strong="H7651"\w* \w veces|strong="H6471"\w* en el \w Jordán|strong="H3383"\w*. Tu \w carne|strong="H1320"\w* te será restaurada y será \w limpia|strong="H2891"\w*.
\p 
\v 11 \w Naamán|strong="H5283"\w* \w salió|strong="H3318"\w* airado y dijo: \w Ciertamente|strong="H2009"\w* \w yo|strong="H2009"\w* pensaba: Él \w saldrá|strong="H3318"\w* \w luego|strong="H3318"\w*, \w en|strong="H3318"\w* \w pie|strong="H5975"\w* \w invocará|strong="H7121"\w* el \w Nombre|strong="H8034"\w* de \nd \w Yavé|strong="H3068"\w*\nd* su \nd ʼElohim\nd*, moverá su \w mano|strong="H3027"\w* \w por|strong="H3027"\w* encima del \w lugar|strong="H4725"\w* y sanará la lepra.
\v 12 ¿Abana y Farfar, ríos \w de|strong="H4325"\w* \w Damasco|strong="H1834"\w*, \w no|strong="H3808"\w* \w son|strong="H3808"\w* \w mejores|strong="H2896"\w* \w que|strong="H3808"\w* \w todas|strong="H3605"\w* las \w aguas|strong="H4325"\w* \w de|strong="H4325"\w* \w Israel|strong="H3478"\w*? ¿\w No|strong="H3808"\w* puedo yo lavarme \w en|strong="H3212"\w* \w ellos|strong="H3605"\w* y ser \w limpio|strong="H2891"\w*? \w Y|strong="H3068"\w* dio \w la|strong="H3605"\w* vuelta y \w salió|strong="H3212"\w* airado.
\p 
\v 13 \w Pero|strong="H3588"\w* sus esclavos \w se|strong="H3808"\w* le acercaron \w y|strong="H3588"\w* le \w dijeron|strong="H1697"\w*: Padre mío, \w si|strong="H3588"\w* \w el|strong="H3588"\w* \w profeta|strong="H5030"\w* \w te|strong="H3588"\w* \w mandara|strong="H1696"\w* alguna \w cosa|strong="H1697"\w* \w grande|strong="H1419"\w*, ¿\w no|strong="H3808"\w* \w la|strong="H3588"\w* harías? ¿\w Cuánto|strong="H3588"\w* \w más|strong="H3588"\w* \w cuando|strong="H3588"\w* \w te|strong="H3588"\w* \w dice|strong="H1696"\w*: \w Lávate|strong="H7364"\w* \w y|strong="H3588"\w* serás \w limpio|strong="H2891"\w*?
\v 14 \w Entonces|strong="H7725"\w* bajó y se sumergió \w siete|strong="H7651"\w* \w veces|strong="H6471"\w* en el \w Jordán|strong="H3383"\w*, según la \w palabra|strong="H1697"\w* del varón \w de|strong="H1697"\w* \nd ʼElohim\nd*. \w Y|strong="H3068"\w* su cuerpo se \w volvió|strong="H7725"\w* como el cuerpo \w de|strong="H1697"\w* un \w niño|strong="H5288"\w* y quedó limpiado.
\p 
\v 15 Enseguida \w volvió|strong="H7725"\w* al varón \w de|strong="H3588"\w* \nd ʼElohim\nd* \w con|strong="H3588"\w* \w toda|strong="H3605"\w* \w su|strong="H1931"\w* comitiva. \w Se|strong="H3045"\w* presentó \w ante|strong="H6440"\w* \w él|strong="H1931"\w* \w y|strong="H3588"\w* dijo: \w Mira|strong="H2009"\w*, \w ahora|strong="H6258"\w* \w reconozco|strong="H3045"\w* \w que|strong="H3588"\w* \w no|strong="H3588"\w* hay \nd ʼElohim\nd* \w en|strong="H3588"\w* \w toda|strong="H3605"\w* \w la|strong="H1931"\w* tierra, \w sino|strong="H3588"\w* \w en|strong="H3588"\w* \w Israel|strong="H3478"\w*. ¡\w Te|strong="H3588"\w* \w ruego|strong="H4994"\w* \w que|strong="H3588"\w* \w recibas|strong="H3947"\w* algún \w presente|strong="H1293"\w* \w de|strong="H3588"\w* tu esclavo!
\p 
\v 16 Pero él respondió: ¡\w Vive|strong="H2416"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Quien \w estoy|strong="H5975"\w*, que \w no|strong="H3985"\w* lo \w tomaré|strong="H3947"\w*! \w E|strong="H3068"\w* insistió que aceptara alguna cosa, pero él \w no|strong="H3985"\w* quiso.
\p 
\v 17 \w Naamán|strong="H5283"\w* dijo: \w Pues|strong="H3588"\w* \w entonces|strong="H3588"\w*, \w te|strong="H3588"\w* \w ruego|strong="H4994"\w* \w que|strong="H3588"\w* sea \w dada|strong="H5414"\w* \w a|strong="H3068"\w* \w tu|strong="H6213"\w* esclavo \w la|strong="H3588"\w* \w carga|strong="H4853"\w* \w de|strong="H3588"\w* tierra \w para|strong="H3588"\w* un \w par|strong="H6776"\w* \w de|strong="H3588"\w* mulas, \w pues|strong="H3588"\w* \w tu|strong="H6213"\w* esclavo \w ya|strong="H4994"\w* \w no|strong="H3808"\w* \w ofrecerá|strong="H6213"\w* \w holocausto|strong="H5930"\w* \w ni|strong="H3808"\w* \w sacrificio|strong="H2077"\w* \w a|strong="H3068"\w* \w otros|strong="H5750"\w* \tl ʼelohim\tl*, \w sino|strong="H3588"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\v 18 \w En|strong="H5921"\w* \w esto|strong="H2088"\w* \w perdone|strong="H5545"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w a|strong="H3068"\w* tu esclavo: \w cuando|strong="H5650"\w* \w mi|strong="H5921"\w* \tl ʼadón\tl* \w entre|strong="H5921"\w* \w al|strong="H5921"\w* \w templo|strong="H1004"\w* \w de|strong="H5921"\w* Rimón \w para|strong="H5921"\w* postrarse \w allí|strong="H8033"\w* \w y|strong="H5921"\w* \w se|strong="H1931"\w* apoye \w en|strong="H5921"\w* \w mi|strong="H5921"\w* \w mano|strong="H3027"\w*, \w y|strong="H5921"\w* \w yo|strong="H4994"\w* \w me|strong="H5921"\w* incline \w en|strong="H5921"\w* \w el|strong="H1931"\w* \w templo|strong="H1004"\w* \w de|strong="H5921"\w* Rimón \w cuando|strong="H5650"\w* \w yo|strong="H4994"\w* tenga \w que|strong="H1931"\w* hacerlo, \w perdone|strong="H5545"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w a|strong="H3068"\w* tu esclavo \w en|strong="H5921"\w* \w esto|strong="H2088"\w*.
\p 
\v 19 \w Y|strong="H3068"\w* él le dijo: \w Vé|strong="H3212"\w* \w en|strong="H3212"\w* \w paz|strong="H7965"\w*.
\p Se había alejado de él cierta distancia,
\v 20 \w cuando|strong="H3588"\w* \w Giezi|strong="H1522"\w*, esclavo \w de|strong="H3588"\w* Eliseo, varón \w de|strong="H3588"\w* \nd ʼElohim\nd*, pensó: \w Ciertamente|strong="H3588"\w* \w mi|strong="H2009"\w* \tl ʼadón\tl* se inclinó \w a|strong="H3068"\w* perdonar \w a|strong="H3068"\w* \w este|strong="H2088"\w* sirio \w Naamán|strong="H5283"\w* al \w no|strong="H3588"\w* \w recibir|strong="H3947"\w* \w de|strong="H3588"\w* \w su|strong="H3588"\w* \w mano|strong="H3027"\w* \w lo|strong="H2088"\w* \w que|strong="H3588"\w* traía. \w Pero|strong="H3588"\w*, ¡\w vive|strong="H2416"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w que|strong="H3588"\w* \w de|strong="H3588"\w* seguro \w correré|strong="H7323"\w* tras \w él|strong="H3588"\w* \w para|strong="H3588"\w* \w tomar|strong="H3947"\w* \w algo|strong="H3972"\w* \w de|strong="H3588"\w* \w él|strong="H3588"\w*!
\p 
