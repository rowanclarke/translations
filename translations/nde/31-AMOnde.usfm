\id AMO - Biblica® Open Ndebele Contemporary Bible 
\h U-Amosi 
\toc1 U-Amosi 
\toc2 U-Amosi 
\toc3 Ams 
\mt1 U-Amosi 
\c 1  
\p  
\v 1 La ngamazwi ka-Amosi, omunye wabelusi baseThekhowa, lokho akubonayo mayelana lo-Israyeli eminyakeni emibili ngaphambi kokuzamazama komhlaba, ngezinsuku u-Uziya eyinkosi yakoJuda loJerobhowamu indodana kaJowashi eyinkosi yako-Israyeli. 
\b  
\b  
\p  
\v 2 Wathi: 
\q1 “\nd UThixo\nd* uyavungama eseZiyoni, 
\q2 idume iJerusalema; 
\q1 amadlelo abelusi ayoma 
\q2 lengqongo yeKhameli iyabuna.” 
\s1 Ukwahlulelwa Kwabakhelene Lo-Israyeli 
\p  
\v 3 Nanku okutshiwo \nd nguThixo\nd*: 
\q1 “Ngenxa yezono ezintathu zeDamaseko, 
\q2 loba ngenxa yezine, 
\q2 kangiyikulunqanda ulaka lwami. 
\q1 Ngenxa yokuthi yatshaya iGiliyadi 
\q2 ngemibhulo elamazinyo ensimbi, 
\q1  
\v 4 ngizathumela umlilo endlini kaHazayeli 
\q2 ozalobisa izinqaba zikaBheni-Hadadi. 
\q1  
\v 5 Ngizabhidliza isango laseDamaseko; 
\q2 ngizachitha inkosi ephakathi kweSigodi sase-Aveni 
\q1 lalowo ophethe intonga yobukhosi eBhethi Edeni. 
\q2 Abantu base-Aramu bazathunjwa 
\q2 basiwe eKhiri,” 
\q2 kutsho \nd uThixo\nd*. 
\p  
\v 6 Nanku okutshiwo \nd nguThixo\nd*: 
\q1 “Ngenxa yezono ezintathu zeGaza 
\q2 loba ngenxa yezine, 
\q2 kangiyikulunqanda ulaka lwami 
\q1 ngenxa yokuthi yathumba abantu bezigaba zonke 
\q2 yabathengisa e-Edomi, 
\q1  
\v 7 ngizathumela umlilo emidulini yaseGaza 
\q2 ozalobisa izinqaba zayo. 
\q1  
\v 8 Ngizayichitha inkosi yase-Ashidodi 
\q2 kanye lalowo ophatha intonga yobukhosi e-Ashikheloni. 
\q1 Ngizaphendulela isandla sami ekuhlaseleni i-Ekroni 
\q2 kuze kufe umFilistiya wokucina,” 
\q2 kutsho \nd uThixo\nd* Wobukhosi. 
\p  
\v 9 Nanku okutshiwo \nd nguThixo\nd*: 
\q1 “Ngenxa yezono ezintathu zaseThire 
\q2 loba ngenxa yezine, kangiyikulunqanda ulaka lwami. 
\q1 Ngenxa yokuthi yabathengisela e-Edomi 
\q2 bonke abantu bezigaba zonke ezathunjwayo 
\q2 inganaki isivumelwano sobuzalwane, 
\q1  
\v 10 ngizathumela umlilo emidulini yaseThire 
\q2 ozalobisa izinqaba zayo.” 
\p  
\v 11 Nanku okutshiwo \nd nguThixo\nd*: 
\q1 “Ngenxa yezono ezintathu zase-Edomi 
\q2 loba ngenxa yezine, kangiyikulunqanda ulaka lwami. 
\q1 Ngenxa yokuthi waxotshana lomfowabo ngenkemba, 
\q2 enqabela isihawu sonke, 
\q1 ngoba ulaka lwakhe lwavutha kokuphela 
\q2 lentukuthelo yakhe yabhebha ingelakuthitshwa, 
\q1  
\v 12 ngizathumela umlilo eThemani 
\q2 ozalobisa izinqaba zaseBhozira.” 
\p  
\v 13 Nanku okutshiwo \nd nguThixo\nd*: 
\q1 “Ngenxa yezono ezintathu zase-Amoni, loba langenxa yezine, 
\q2 kangiyikulunqanda ulaka lwami. 
\q1 Ngenxa yokuthi waqhaqha abesifazane abazithweleyo baseGiliyadi 
\q2 ukuze aqhelise ilizwe lakhe, 
\q1  
\v 14 ngizathungela imiduli yaseRaba ngomlilo 
\q2 ozalobisa izinqaba zayo 
\q1 kumenyezelwa izitsho zempi ngosuku lokulwa 
\q2 kulomoya olamandla ngosuku lwesiphepho. 
\q1  
\v 15 Inkosi yalo izathunjwa, 
\q2 yona kanye lezikhulu zayo,” 
\q2 kutsho \nd uThixo\nd*. 
\c 2  
\p  
\v 1 Nanku okutshiwo \nd nguThixo\nd*: 
\q1 “Ngenxa yezono ezintathu zaseMowabi 
\q2 loba ngenxa yezine, kangiyikulunqanda ulaka lwami, 
\q1 ngoba utshise amathambo enkosi yase-Edomi 
\q2 aze afana lekalaga, 
\q1  
\v 2 ngizathumela umlilo kuMowabi 
\q2 ozalobisa izinqaba zaseKheriyothi. 
\q1 UMowabi uzachitheka kulokuxokozela okukhulu 
\q2 lokumenyezelwa kwezitsho zempi lokukhala kwecilongo. 
\q1  
\v 3 Ngizaqothula ababusi bakhe 
\q2 ngibulale zonke izikhulu zakhe kanye laye,” 
\q2 kutsho \nd uThixo\nd*. 
\p  
\v 4 Nanku okutshiwo \nd nguThixo\nd*: 
\q1 “Ngenxa yezono ezintathu zikaJuda 
\q2 loba ngenxa yezine, kangiyikulunqanda ulaka lwami, 
\q1 ngoba bawalile umthetho \nd kaThixo\nd* 
\q2 kabaze bagcina lezimiso zakhe, 
\q1 ngoba badukiswe ngonkulunkulu bamanga, 
\q2 onkulunkulu abalandelwa ngokhokho babo. 
\q1  
\v 5 Ngizathumela umlilo koJuda 
\q2 ozalobisa izinqaba zaseJerusalema.” 
\s1 Ukwahlulelwa Kuka-Israyeli 
\p  
\v 6 Nanku okutshiwo \nd nguThixo\nd*: 
\q1 “Ngenxa yezono ezintathu zika-Israyeli 
\q2 loba ngenxa yezine, kangiyikulunqanda ulaka lwami 
\q1 ngoba bathengisa abalungileyo ngesiliva, 
\q2 labaswelayo ngamanyathelo. 
\q1  
\v 7 Banyathela phezu kwamakhanda abayanga 
\q2 njengaphezu kothuli lomhlabathi 
\q2 banqabele imfanelo yabancindezelweyo. 
\q1 Uyise lendodana bembatha lentombi yinye 
\q2 kanjalo bangcolise ibizo lami elingcwele. 
\q1  
\v 8 Bacambalala phansi emaceleni ama-alithare wonke, 
\q2 phezu kwezembatho ezithethwe ziyizibambiso. 
\q1 Endlini kankulunkulu wabo 
\q2 banatha iwayini elithethwe njengenhlawulo. 
\b  
\q1  
\v 9 Ngachitha umʼAmori phambi kwabo, 
\q2 lanxa wayemude njengemisedari 
\q2 njalo eqine njengomʼokhi. 
\q1 Ngachitha izithelo zakhe phezulu 
\q2 kanye lempande zakhe ngaphansi. 
\q1  
\v 10 Ngalikhupha eGibhithe 
\q2 ngalikhokhela iminyaka engamatshumi amane enkangala 
\q2 ukuba ngilinike ilizwe lama-Amori. 
\b  
\q1  
\v 11 Ngakhupha labaphrofethi bephuma phakathi kwamadodana enu, 
\q2 kanye lamaNaziri ephuma phakathi kwezinsizwa zenu. 
\q1 Lokhu akuqotho na, bantu bako-Israyeli?” 
\q2 kutsho \nd uThixo\nd*. 
\q1  
\v 12 “Kodwa lanathisa amaNaziri iwayini, 
\q2 lalaya abaphrofethi ukuba bangaphrofethi. 
\b  
\q1  
\v 13 Khathesi-ke mina ngizalichoboza 
\q2 njengokuchoboza kwenqola ithwele amabele. 
\q1  
\v 14 Olejubane kayikubaleka, 
\q2 oqinileyo uzawaswela amandla akhe, 
\q2 lebutho kaliyikusindisa impilo yalo. 
\q1  
\v 15 Umtshoki akayikugxila, 
\q2 ibutho elilejubane kaliyikuphunyuka 
\q2 lomgadi webhiza kayikusindisa impilo yakhe. 
\q1  
\v 16 Lebutho elilesibindi kakhulu, 
\q2 ngalolosuku lizabaleka linqunu,” 
\q2 kutsho \nd uThixo\nd*. 
\c 3  
\s1 Ofakazi Bokumelana Lo-Israyeli 
\p  
\v 1 Zwanini ilizwi elikhulunywe \nd nguThixo\nd* ngani lina bantu bako-Israyeli Lomndeni wonke engawukhupha eGibhithe: 
\q1  
\v 2 “Yini kuphela engalikhethayo 
\q2 kuyo yonke imideni yasemhlabeni; 
\q1 ngakho ngizalijezisela 
\q2 zonke izono zenu.” 
\b  
\q1  
\v 3 Ababili bayahamba bendawonye 
\q2 ngaphandle kokuba bevumelene ukwenzanjalo na? 
\q1  
\v 4 Isilwane siyabhonga ehlathini 
\q2 kungelalutho esingalubamba na? 
\q1 Siyabhonga esikhundleni saso 
\q2 singabambanga lutho na? 
\q1  
\v 5 Inyoni iyabanjwa emhlabathini 
\q2 okungelamjibila othiywe khona na? 
\q1 Umjibila uyathanca usuke emhlabathini 
\q2 kungelalutho olubambayo na? 
\q1  
\v 6 Lapho icilongo likhala edolobheni 
\q2 abantu kabethuki na? 
\q1 Lapho incithakalo isehlela idolobho 
\q2 kayenziwanga \nd nguThixo\nd* na? 
\b  
\q1  
\v 7 Impela \nd uThixo\nd* Wobukhosi kenzi lutho 
\q2 engavezanga icebo 
\q2 lakhe ezincekwini zakhe abaphrofethi. 
\b  
\q1  
\v 8 Isilwane sibhongile, 
\q2 ngubani ongayikwesaba na? 
\q1 \nd UThixo\nd* Wobukhosi usekhulumile 
\q2 ngubani ongayekela ukuphrofitha na? 
\b  
\q1  
\v 9 Memezelani ezinqabeni zase-Ashidodi 
\q2 lasezinqabeni zaseGibhithe lithi: 
\q1 “Buthanani phezu kwezintaba zaseSamariya; 
\q2 libone isiyaluyalu esikhulu phakathi kwayo 
\q2 lokuncindezela phakathi kwabantu bayo.” 
\b  
\q1  
\v 10 “Kabakwazi ukwenza okulungileyo,” kutsho \nd uThixo\nd*, 
\q2 “bona ababuthelela impango 
\q2 baphange lasezinqabeni zabo.” 
\p  
\v 11 Ngakho \nd uThixo\nd* Wobukhosi uthi: 
\q1 “Isitha sizachitha ilizwe; 
\q2 sizadiliza izinqaba zenu, 
\q2 siphange izinqaba zenu.” 
\p  
\v 12 Nanku okutshiwo \nd nguThixo\nd*: 
\q1 “Njengomelusi ehlenga emlonyeni wesilwane 
\q2 amathambo amabili kuphela omlenze loba isiqa sendlebe, 
\q1 bazahlengwa kanjalo abako-Israyeli abahlala eSamariya 
\q2 bethithibele ekucineni kwemibheda yabo, 
\q2 kanye laseDamaseko phezu kwemibheda yabo yokuphumulela.” 
\p  
\v 13 “Zwanini lokhu lifakaze ngendlu kaJakhobe,” kutsho iNkosi, \nd uThixo\nd* uNkulunkulu uSomandla. 
\q1  
\v 14 “Ngosuku engizajezisela u-Israyeli izono zakhe 
\q2 ngizabhidliza ama-alithare aseBhetheli; 
\q1 impondo ze-alithare zizaqunywa 
\q2 ziwele emhlabathini. 
\q1  
\v 15 Ngizadiliza indlu yebusika kanye 
\q2 lendlu yehlobo, 
\q1 izindlu eziceciswe ngempondo zendlovu zizadilizwa 
\q2 lezindlu ezinkulu zizabhidlizwa,” 
\q2 kutsho \nd uThixo\nd*. 
\c 4  
\s1 U-Israyeli Kakabuyeli KuNkulunkulu 
\q1  
\v 1 Zwanini ilizwi leli lina mankomokazi aseBhashani phezu kweNtaba iSamariya, 
\q2 lina besifazane elincindezela abayanga lichoboze abaswelayo 
\q2 beselisithi kubomkenu, “Siletheleni okunathwayo!” 
\q1  
\v 2 \nd UThixo\nd* Wobukhosi usefunge ngobungcwele bakhe wathi: 
\q2 “Isikhathi sizafika impela 
\q1 lapho elizathathwa khona ngewuka, 
\q2 owokucina wenu ngewuka yenhlanzi. 
\q1  
\v 3 Lizaphuma ngamunye 
\q2 ngezikhala emdulini liqonde nta phandle, 
\q1 njalo lizalahlelwa ngaphandle ngokuya eHamoni,” 
\q2 kutsho \nd uThixo\nd*. 
\q1  
\v 4 “Hambani eBhetheli liyekwenza isono; 
\q2 hambani eGiligali liyekwenza isono ngokudlulayo. 
\q1 Lethani imihlatshelo yenu nsuku zonke ekuseni 
\q2 lokwetshumi kwenu minyaka yonke emithathu. 
\q1  
\v 5 Tshisani isinkwa esilemvubelo njengomnikelo wokubonga 
\q2 lintele ngeminikelo yenu yokuzithandela 
\q1 lizikhukhumeze ngayo, lina bako-Israyeli, 
\q2 ngoba lokhu yikho elithanda ukukwenza,” 
\q2 kutsho \nd uThixo\nd* Wobukhosi. 
\b  
\q1  
\v 6 “Ngalilethela indlala emadolobheni wonke 
\q2 lokusweleka kokudla emadolobheni wonke, 
\q1 kodwa kalibuyelanga kimi,” 
\q2 kutsho \nd uThixo\nd*. 
\b  
\q1  
\v 7 “Ngagodla izulu futhi 
\q2 kusasele inyanga ezintathu ukuba kuvunwe. 
\q1 Izulu ngalinisa kwelinye idolobho 
\q2 kodwa ngaligodla kwelinye. 
\q1 Enye insimu yaba lezulu, 
\q2 enye kayaze yaba lalo njalo yoma qha. 
\q1  
\v 8 Abantu babhadazela besuka kwelinye idolobho besiya kwelinye befuna amanzi 
\q2 kodwa kabawatholanga anele ukuba bakholwe, 
\q1 ikanti kalibuyelanga kimi,” 
\q2 kutsho \nd uThixo\nd*. 
\b  
\q1  
\v 9 “Ezikhathini ezinengi ngahlasela izivande zenu lezivini zenu, 
\q2 ngizihlasela ngesona langengumane. 
\q1 Izintethe zadla imikhiwa yenu lezihlahla zenu zama-oliva, 
\q2 kodwa kalibuyelanga kimi,” 
\q2 kutsho \nd uThixo\nd*. 
\b  
\q1  
\v 10 “Ngathumela izifo phakathi kwenu 
\q2 njengengakwenza kweleGibhithe. 
\q1 Ngabulala izinsizwa zenu ngenkemba 
\q2 ndawonye lamabhiza enu athunjwayo. 
\q1 Ngavimbanisa amakhala enu ngomnuko wezihonqo zenu, 
\q2 kodwa kalibuyelanga kimi,” 
\q2 kutsho \nd uThixo\nd*. 
\b  
\q1  
\v 11 “Ngachitha abanye benu 
\q2 njengalokhu ngachitha iSodoma leGomora. 
\q1 Lalinjengesikhuni esitshayo esihluthunwe emlilweni, 
\q2 kodwa kalibuyelanga kimi,” 
\q2 kutsho \nd uThixo\nd*. 
\b  
\q1  
\v 12 “Ngakho-ke engizakwenza kuwe Israyeli yilokhu, 
\q2 njalo njengoba lokhu ngizakwenza kuwe, 
\q2 zilungisele ukuhlangana loNkulunkulu wakho, wena Israyeli.” 
\b  
\q1  
\v 13 Yena obumba izintaba, 
\q2 udala umoya, 
\q2 aveze lemicabango yakhe ebantwini, 
\q1 yena oguqula ukusa kube ngumnyama, 
\q2 anyathele lezindawo eziphakemeyo zomhlaba, 
\q2 \nd uThixo\nd* uNkulunkulu uSomandla yilo ibizo lakhe. 
\c 5  
\s1 Isililo Lesimemezelo Sokuphenduka 
\p  
\v 1 Zwana ilizwi leli, wena ndlu ka-Israyeli, isililo lesi engisenzayo ngani: 
\q1  
\v 2 “Iwile iNtombi u-Israyeli, 
\q2 kayiphindi ivuke futhi, 
\q1 ideliwe elizweni layo, 
\q2 kungekho ongayiphakamisela phezulu.” 
\p  
\v 3 Nanku okutshiwo \nd nguThixo\nd* Wobukhosi: 
\q1 “Idolobho lenu elikhupha inkulungwane eziqinileyo 
\q2 lizasala labalikhulu kuphela; 
\q1 idolobho elikhupha abalikhulu abaqinileyo lizasala 
\q2 labalitshumi kuphela.” 
\p  
\v 4 Nanku okutshiwo \nd nguThixo\nd* endlini ka-Israyeli: 
\q1 “Dingani mina, liphile; 
\q2  
\v 5 lingadingi iBhetheli, 
\q1 lingayi eGiligali, 
\q2 lingayi eBherishebha. 
\q1 Ngoba impela iGiligali izakuya ekuthunjweni, 
\q2 leBhetheli izadliwa iphele nya.” 
\q1  
\v 6 Dingani \nd uThixo\nd* liphile 
\q2 hlezi adabule phakathi kwendlu kaJosefa njengomlilo; 
\q1 uzatshisa uqothule, 
\q2 njalo iBhetheli kayiyikuba lomuntu ozawucitsha. 
\b  
\q1  
\v 7 Lina eliguqula ukulunga kube yibuhlungu, 
\q2 lilahlele ubuqotho emhlabathini. 
\b  
\q1  
\v 8 Yena owenza iSilimela loMthala, 
\q2 oguqula umnyama ube yikusa 
\q2 enze imini ibe yibusuku obumnyama, 
\q1 yena obiza amanzi olwandle, 
\q2 awathele phezu kobuso belizwe, 
\q2 \nd uThixo\nd* yilo ibizo lakhe, 
\q1  
\v 9 wehlisela incithakalo phezu kwenqaba atshabalalise 
\q2 idolobho elivikelweyo. 
\b  
\q1  
\v 10 Liyamzonda okhuzayo emthethwandaba limeyise 
\q2 lalowo okhuluma iqiniso. 
\b  
\q1  
\v 11 Linyathezela umyanga limncindezele 
\q2 ukuba aliphe amabele. 
\q1 Ngakho-ke, lanxa lakhe izindlu ezinkulukazi zamatshe 
\q2 kaliyikuhlala kuzo; 
\q1 lanxa lihlanyele izivini ezinhle, 
\q2 iwayini lazo kaliyikulinatha. 
\q1  
\v 12 Ngoba iziphambeko zenu ngiyazazi ukuthi zingaki 
\q2 kanye lokuthi izono zenu zinkulu okunganani. 
\b  
\q1 Lincindezela abalungileyo lamukele isivalamlomo, 
\q2 njalo emithethwandaba linqabela abayanga imfanelo. 
\q1  
\v 13 Ngakho ezikhathini ezinjalo umuntu ohlakaniphileyo uyazithulela, 
\q2 ngoba izikhathi zimbi. 
\b  
\q1  
\v 14 Dingani okuhle, hatshi okubi, 
\q2 ukuze liphile. 
\q1 Lapho-ke \nd uThixo\nd* uNkulunkulu uSomandla uzakuba lani 
\q2 njengoba lisithi ulani. 
\q1  
\v 15 Zondani okubi lithande okuhle; 
\q2 qinisani ukulunga emithethwandaba. 
\q1 Mhlawumbe \nd uThixo\nd* uNkulunkulu uSomandla uzakuba lomusa 
\q2 kuzinsalela zakoJosefa. 
\p  
\v 16 Ngakho nanku okutshiwo yiNkosi, \nd uThixo\nd*, uNkulunkulu uSomandla, 
\q1 “Kuzakuba lokulila emigwaqweni yonke 
\q2 lokukhala kabuhlungu ezinkundleni zonke zikazulu. 
\q1 Abalimi bazabizwa ukuba bakhale, 
\q2 labakhalayo ukuba balile. 
\q1  
\v 17 Kuzakuba lokulila ezivinini zonke, 
\q2 ngoba ngizadlula phakathi kwenu,” 
\q2 kutsho \nd uThixo\nd*. 
\s1 Usuku \nd LukaThixo\nd* 
\q1  
\v 18 Maye kini lina elilangazelela 
\q2 usuku \nd lukaThixo\nd*! 
\q1 Kungani lilangazelela lolosuku \nd lukaThixo\nd* na? 
\q2 Lolosuku luzakuba ngumnyama, hatshi ukukhanya. 
\q1  
\v 19 Kuzafana lokuthi umuntu ubalekele isilwane 
\q2 wahlangana lebhele, 
\q1 njengangathi ungene endlini yakhe 
\q2 wabambelela emdulini ngesandla 
\q2 waselunywa yinyoka. 
\q1  
\v 20 Usuku \nd lukaThixo\nd* kaluyikuba ngumnyama na, 
\q2 hatshi ukukhanya, 
\q2 lumnyama bhuqe, kungekho nhlansi yokukhanya? 
\b  
\q1  
\v 21 “Ngiyayizonda, ngiyayeyisa imikhosi yokholo lwenu; 
\q2 angingeke ngiyimele imbuthano yenu. 
\q1  
\v 22 Lanxa lingangilethela iminikelo yokutshiswa leminikelo 
\q2 yamabele kangiyikuyamukela. 
\q1 Lanxa liletha iminikelo emihle kakhulu yobuzalwane, 
\q2 lokunonisiweyo kangiyikuyinanza. 
\q1  
\v 23 Sukani lomsindo wezingoma zenu! 
\q2 Kangiyikuwulalela umculo wamachacho enu. 
\q1  
\v 24 Kodwa ukulunga kakugeleze njengamanzi, 
\q2 lobuqotho njengesifula esingatshiyo! 
\b  
\q1  
\v 25 Kanje wake wangilethela imihlatshelo leminikelo 
\q2 eminyakeni engamatshumi amane enkangala, 
\q2 wena ndlu ka-Israyeli na? 
\q1  
\v 26 Seliphakamise indawo yokukhonzela izithombe zenu, 
\q2 isenabelo senkosi unkulunkulu wenu uSakhuthi, 
\q2 lenkanyezi kankulunkulu wenu uKhayiwani, 
\q2 elazenzela khona lina ngokwenu. 
\q1  
\v 27 Ngakho ngizalisa ekuthunjweni ngale kweDamaseko,” 
\q2 kutsho \nd uThixo\nd* obizo lakhe nguNkulunkulu uSomandla. 
\c 6  
\s1 Maye Kulabo Abangakhathaliyo 
\q1  
\v 1 Maye kini lina elingakhathaliyo eZiyoni, 
\q2 lakini elizizwa livikelekile eNtabeni iSamariya, 
\q1 lina madoda adumileyo esizwe sokuqala, 
\q2 abantu bako-Israyeli abaya kuso! 
\q1  
\v 2 Yanini eKhaline liyikhangele; 
\q2 lisuka lapho yanini eHamathi enkulu, 
\q2 beselisehlela eGathi eseFilistiya. 
\q1 Bangcono kulemibuso yenu emibili na? 
\q2 Ilizwe labo likhulu kulelenu na? 
\q1  
\v 3 Lisusa usuku olubi 
\q2 lisondeze eduze ukubusa ngodlakela. 
\q1  
\v 4 Lilala emibhedeni eyenziwa ngempondo zendlovu 
\q2 licambalale phezu kwemibheda yenu yokuphumulela. 
\q1 Lidla inyama yezimvu zekhethelo 
\q2 leyamathole anonisiweyo. 
\q1  
\v 5 Lihweba amachacho njengoDavida 
\q2 kodwa engamachacho ezaba. 
\q1  
\v 6 Linatha iwayini ligcwele inqayi, 
\q2 ligcobe ngamagcobo amahle, 
\q2 kodwa kalikhathazeki ngokuchitheka kukaJosefa. 
\q1  
\v 7 Ngakho-ke lizakuba ngabanye bakuqala ekuthunjweni; 
\q2 ukuzitika kwenu lokuhleka kuzaphela. 
\s1 Inkosi Iyakwenyanya Ukuzigqaja Kuka-Israyeli 
\p  
\v 8 \nd UThixo\nd* Wobukhosi uzifungele yena ngokwakhe, \nd uThixo\nd* uNkulunkulu uSomandla uthi: 
\q1 “Ngiyakwenyanya ukuzigqaja kukaJakhobe 
\q2 njalo ngiyazizonda izinqaba zakhe; 
\q1 ngizalinikela idolobho lakho 
\q2 konke okukulo.” 
\p  
\v 9 Nxa amadoda alitshumi esele endlini eyodwa, lawo azakufa.  
\v 10 Njalo nxa isihlobo okumele sitshise izidumbu zifika ukuba sizisuse kuleyondlu besesibuza loba ngubani oyabe elokhu ecatshile khonapho, sithi, “Kulomunye olawe na?” Yena athi, “Hatshi,” lapho-ke uzakuthi, “Thula! Akumelanga sithinte ibizo \nd likaThixo\nd*.” 
\q1  
\v 11 Ngoba \nd uThixo\nd* usekhuphe umlayo, 
\q2 njalo uzaphahlaza indlukazi ibe yizihlephu 
\q2 kuthi indlu encinyane ibe yizicucu. 
\b  
\q1  
\v 12 Amabhiza ayagijima emadwaleni angamawa na? 
\q2 Umuntu uyalima khonapho ngenkabi na? 
\q1 Kodwa lina liphendule ukulunga kwaba yitshefu 
\q2 lesithelo sokulunga saba yibuhlungu, 
\q1  
\v 13 lina elithokoziswa yikunqotshwa kweLo-Debhari 
\q2 beselisithi, “IKharinayimi kasiyithumbanga ngamandla ethu na?” 
\b  
\q1  
\v 14 Ngoba \nd uThixo\nd* uNkulunkulu uSomandla uthi, 
\q2 “Ngizakuvusela isizwe, wena ndlu ka-Israyeli, 
\q1 esizakuncindezela indawo yonke 
\q2 kusukela eLebho Hamathi kusiyafika esigodini sase-Arabha.” 
\c 7  
\s1 Intethe, Lomlilo Lentambo Yokuqondisa 
\p  
\v 1 Nanku engakutshengiswa \nd nguThixo\nd* Wobukhosi: Wayelungisa imitshitshi yezintethe emva kokuvunwa kwesabelo senkosi khonapho amabele esibili esakhula.  
\v 2 Kwathi lapho ilizwe seziliphundlile, ngamemeza ngathi, “\nd Thixo\nd* Wobukhosi, thethelela! UJakhobe angaphepha kanjani? Mncinyane kakhulu!” 
\p  
\v 3 Ngakho \nd uthixo\nd* waxola. 
\p “Akusoze kwenzakale” watsho \nd uthixo\nd*. 
\p  
\v 4 Nanku engakutshengiswa \nd nguThixo\nd* Wobukhosi: \nd uThixo\nd* Wobukhosi wayememezela ukwehlulela ngomlilo; womisa ulwandle waqothula lelizwe.  
\v 5 Ngakho ngamemeza ngathi “\nd Thixo\nd* Wobukhosi, ngiyakuncenga, ake ume! UJakhobe angaphepha kanjani na? Mncinyane kakhulu!” 
\p  
\v 6 Ngakho \nd uThixo\nd* waxola. 
\p “Lokhu lakho akuyikwenzakala,” kwatsho \nd uThixo\nd* Wobukhosi. 
\b  
\p  
\v 7 Nanku angitshengisa khona: uThixo wayemi phansi komduli owawakhiwe waqonda nta ephethe intambo yokuqondisa ngesandla sakhe  
\v 8 \nd UThixo\nd* wasengibuza esithi, “Kuyini okubonayo, Amosi?” 
\p Ngaphendula ngathi, “Yintambo yokuqondisa.” 
\p UThixo wasesithi, “Khangela, ngibeka intambo yokuqondisa phakathi kwabantu bami bako-Israyeli; kangisayikubaxolela futhi. 
\q1  
\v 9 Izindawo eziphakemeyo zika-Isaka zizadilizwa 
\q2 lezindawo ezingcwele zako-Israyeli zizachithwa; 
\q2 indlu kaJerobhowamu ngizayihlasela ngenkemba yami.” 
\s1 U-Amosi Lo-Amaziya 
\p  
\v 10 U-Amaziya umphristi waseBhetheli wathumela ilizwi kuJerobhowamu inkosi yako-Israyeli, wathi, “U-Amosi uceba okubi ngawe khona kanye phakathi kwako-Israyeli. Ilizwe lingeke limelane lawo wonke amazwi akhe.  
\v 11 Ngoba u-Amosi uthi: 
\q1 ‘UJerobhowamu uzakufa ngenkemba, 
\q2 njalo impela u-Israyeli uzathunjwa, 
\q2 asiwe khatshana kwelizwe lakibo.’ ” 
\p  
\v 12 U-Amaziya wasesithi ku-Amosi, “Phuma, wena mboni! Buyela elizweni lakoJuda, usebenzele ukudla kwakho khonale wenze lokuphrofetha kwakho khonale.  
\v 13 Ungaphrofithi futhi eBhetheli, ngoba le yindawo yenkosi kanye lethempeli lombuso.” 
\p  
\v 14 U-Amosi waphendula u-Amaziya wathi, “Mina ngangingasuye mphrofethi kumbe indodana yomphrofethi, kodwa ngangingumelusi, njalo ngigcina izihlahla zomkhiwa wesikhamore.  
\v 15 Kodwa \nd uThixo\nd* wangithatha ekweluseni imihlambi yezimvu wathi kimi, ‘Hamba uyephrofetha ebantwini bami bako-Israyeli.’  
\v 16 Ngakho-ke khathesi zwana ilizwi \nd likaThixo\nd*. Wena uthi: 
\q1 ‘Ungaphrofethi kubi ngo-Israyeli, 
\q2 njalo yekela ukutshumayela kubi ngendlela ka-Isaka.’ 
\p  
\v 17 Ngakho-ke nanku okutshiwo \nd nguThixo\nd*: 
\q1 ‘Umkakho uzakuba yisifebe edolobheni, 
\q2 amadoda lamadodakazi akho azakufa ngenkemba. 
\q1 Ilizwe lakho lizalinganiswa labiwe, 
\q2 njalo wena ngokwakho uzafela elizweni lamaqaba. 
\q1 Njalo impela u-Israyeli uzathunjwa 
\q2 asiwe khatshana kwelizwe lakhe.’ ” 
\c 8  
\s1 Isitsha Sezithelo Ezivuthiweyo 
\p  
\v 1 Nanku engakutshengiswa \nd nguThixo\nd* Wobukhosi: isitsha esilezithelo ezivuthiweyo.  
\v 2 Wangibuza wathi, “Kuyini okubonayo, Amosi?” 
\p Mina ngaphendula ngathi, “Yisitsha esilezithelo ezivuthiweyo.” 
\p \nd UThixo\nd* wasesithi kimi, “Isikhathi sabantu bami bako-Israyeli sesifikile; kangisabaxoleli futhi. 
\p  
\v 3 Ngalolosuku, izingoma zethempelini zizaphenduka zibe yikulila. Izidumbu ezinengi kakhulu zidaklazelwe indawo yonke! Thulani!” Kutsho \nd uThixo\nd* Wobukhosi. 
\q1  
\v 4 Zwanini lokhu, lina elincindezela abaswelayo njalo 
\q2 lichitha labayanga elizweni, 
\m  
\v 5 lisithi, 
\q1 “Ukuthwasa kweNyanga Entsha kuzaphela nini 
\q2 ukuze sithengise amabele, 
\q1 leSabatha lidlule 
\q2 ukuze sithengise ingqoloyi na?” 
\q1 Sinciphise isilinganiso, 
\q2 sikhweze intengo 
\q2 siqilibezele ngezilinganiso zenkohliso, 
\q1  
\v 6 sithenge abayanga ngesiliva, 
\q2 abaswelayo sibathenge ngamanyathelo, 
\q2 sithengise lamakhoba ngengqoloyi. 
\p  
\v 7 \nd UThixo\nd* ufungile ngokuziQhenya kukaJakhobe wathi, “Angisoze ngakhohliswa loba yini abayenzileyo. 
\q1  
\v 8 Ilizwe kaliyikuthuthumela ngalokhu yini 
\q2 labo bonke abahlala kulo kabayikulila na? 
\q1 Ilizwe lonke lizaqubuka njengeNayili; 
\q2 lizadungeka beselitshona phansi 
\q2 njengomfula waseGibhithe. 
\p  
\v 9 Ngalolosuku,” kutsho \nd uThixo\nd* Wobukhosi, 
\q1 “ngizakwenza ilanga litshone emini, 
\q2 ngenze emhlabeni kube mnyama emini ekhanyayo. 
\q1  
\v 10 Ngizaphendula imikhosi yenu yokukhonza ibe yikulila 
\q2 lokuhlabelela kwenu konke kube yikukhala. 
\q1 Lonke ngizalenza ligqoke amasaka, 
\q2 njalo liphuce amakhanda enu. 
\q1 Lesosikhathi ngizasenza sifane lokulilela indodana eyiyo yodwa 
\q2 lokuphela kwaso kube njengosuku olubuhlungu. 
\b  
\q1  
\v 11 Insuku ziyeza, kutsho \nd uThixo\nd* Wobukhosi, 
\q2 lapho engizathumela khona indlala elizweni 
\q1 hatshi indlala yokudla kumbe ukomela amanzi, 
\q2 kodwa indlala yokuzwa amazwi \nd kaThixo\nd*. 
\q1  
\v 12 Abantu bazaphamazela besuka elwandle besiya elwandle, 
\q2 njalo bazule kusukela enyakatho kusiya empumalanga, 
\q1 bedinga ilizwi \nd likaThixo\nd*, 
\q2 kodwa kabayikulithola. 
\p  
\v 13 Ngalolosuku 
\q1 izintombi ezinhle lezinsizwa eziqinileyo 
\q2 zizaqaleka ngenxa yokoma. 
\q1  
\v 14 Bona labo abafunga ngesono seSamariya, 
\q2 loba bathi, ‘Ngeqiniso 
\q2 njengoba unkulunkulu wakho ephila, wena Dani,’ 
\q1 loba bathi, ‘Ngeqiniso 
\q2 njengoba unkulunkulu waseBherishebha ephila,’ 
\q2 bazakuwa, bangaphindi bavuke futhi.” 
\c 9  
\s1 U-Israyeli Uzachithwa 
\p  
\v 1 Ngabona uThixo emi phansi kwe-alithari, wasesithi: 
\q1 “Tshaya izihloko zensika 
\q2 ukuze imibundu inyikinyeke. 
\q1 Ziwisele phansi phezu kwamakhanda abantu bonke; 
\q2 labo abazasala ngizababulala ngenkemba. 
\q1 Kakho lamunye ozaphunyuka, 
\q2 kakho ozabaleka. 
\q1  
\v 2 Loba besimba baze bafike ekudepheni kwengcwaba, 
\q2 isandla sami sizabathatha khonapho. 
\q1 Loba bekhwela baye phezulu emazulwini, 
\q2 bekhonapho ngizabehlisela phansi. 
\q1  
\v 3 Loba becatsha engqongweni yeKhameli, 
\q2 khonapho ngizabadinga ngibabambe. 
\q1 Loba bengicatshela enzikini yolwandle, 
\q2 khonapho ngizalaya inyoka ukuba ibalume. 
\q1  
\v 4 Loba izitha zabo zingabasa ekuthunjweni, 
\q2 khonale ngizalaya inkemba ukuba ibabulale. 
\b  
\q1 Ngizagxilisa amehlo ami kubo 
\q2 ngenxa yobubi hatshi ngobuhle.” 
\b  
\q1  
\v 5 INkosi, \nd uThixo\nd* uSomandla, 
\q1 yena othinta umhlaba uncibilike, 
\q2 kuthi bonke abahlezi kuwo bakhale, 
\q1 ilizwe lonke liyaphakama njengoNayili 
\q2 liphinde litshone phansi njengomfula waseGibhithe, 
\q1  
\v 6 yena owakha indlu yakhe yobukhosi ephakemeyo emazulwini 
\q2 njalo ubeka isisekelo sakhe phezu komhlaba, 
\q1 ebiza amanzi olwandle 
\q2 awathele phezu kobuso bomhlaba, 
\q2 \nd uThixo\nd* yilo ibizo lakhe. 
\b  
\q1  
\v 7 “Lina ma-Israyeli, 
\q2 kimi kalinjengamaKhushi na?” 
\q2 kutsho \nd uThixo\nd*. 
\q1 “U-Israyeli kangimkhuphanga eGibhithe, 
\q2 lamaFilistiya eKhafithori, 
\q2 kanye lama-Aramu eKhiri na? 
\b  
\q1  
\v 8 Impela amehlo \nd kaThixo\nd* Wobukhosi 
\q2 aphezu kombuso olesono. 
\q1 Ngizawukhucula ebusweni bomhlaba 
\q2 ikanti indlu kaJakhobe 
\q1 angiyikuyichitha ngokupheleleyo,” 
\q2 kutsho \nd uThixo\nd*. 
\q1  
\v 9 “Ngoba ngizakupha umlayo, 
\q2 njalo ngizahlungula indlu ka-Israyeli 
\q2 phakathi kwezizwe zonke 
\q1 njengokuhlungulwa kwamabele ekhomaneni 
\q2 njalo akukho hlamvu oluzawela phansi. 
\q1  
\v 10 Izoni zonke phakathi kwabantu bami 
\q2 zizakufa ngenkemba, 
\q1 bonke labo abathi, 
\q2 ‘Umonakalo kawuyikusifica loba usihlangabeze.’ ” 
\s1 Ukubuyiswa Kuka-Israyeli 
\p  
\v 11 “Ngalolosuku 
\q1 ngizavusa ithente likaDavida elawayo. 
\q2 Ngizavala izikhala zalo, 
\q2 ngivuselele okwadilikayo kwalo, 
\q2 ngilakhe njengelaliyikho khona, 
\q1  
\v 12 ukuze bathathe insalela ye-Edomi 
\q2 kanye lezizwe zonke ezizabizwa ngebizo lami,” 
\q2 kutsho \nd uThixo\nd*, ozazenza lezizinto. 
\p  
\v 13 \nd UThixo\nd* uthi, “Zinsuku ziyeza, 
\q1 lapho ovunayo ezaficwa ngolimayo, 
\q2 lohlanyelayo aficwe ngokhama amavini. 
\q1 Iwayini elitsha lizagobhoza ezintabeni, 
\q2 njalo ligeleze emaqaqeni wonke. 
\q1  
\v 14 Ngizababuyisela abantu bami 
\q2 bako-Israyeli abathunjwayo. 
\b  
\q1 Bazawakha kutsha amadolobho adilikayo bahlale kuwo. 
\q2 Bazahlanyela izivini banathe iwayini lazo; 
\q2 bazakwenza izivande badle izithelo zazo. 
\q1  
\v 15 Ngizagxumeka u-Israyeli elizweni lakhe 
\q2 angaphindi asitshunwe futhi 
\q2 elizweni engimnike lona,” 
\m kutsho \nd uThixo\nd* uNkulunkulu wenu.