\p 
\v 26 \w Then|strong="H2009"\w* \w the|strong="H7200"\w* \w watchman|strong="H6822"\w* \w saw|strong="H7200"\w* \w another|strong="H2088"\w* \w man|strong="H7200"\w* \w running|strong="H7323"\w*. \w So|strong="H7121"\w* \w he|strong="H7121"\w* \w called|strong="H7121"\w* \w down|strong="H7323"\w* \w to|strong="H4428"\w* \w the|strong="H7200"\w* \w gatekeeper|strong="H7778"\w*, “\w Look|strong="H7200"\w*! \w There|strong="H2009"\w* \w is|strong="H2088"\w* \w another|strong="H2088"\w* \w man|strong="H7200"\w* \w running|strong="H7323"\w*!” \w And|strong="H4428"\w* \w the|strong="H7200"\w* \w king|strong="H4428"\w* \w said|strong="H7121"\w*, “\w He|strong="H7121"\w* \w also|strong="H1571"\w* \w is|strong="H2088"\w* \w bringing|strong="H1319"\w* \add some good\add* \w news|strong="H1319"\w*.”
\p 
\v 27 \w The|strong="H7200"\w* \w watchman|strong="H6822"\w* said, “\w I|strong="H7200"\w* \w think|strong="H7200"\w* \w the|strong="H7200"\w* \w first|strong="H7223"\w* \w man|strong="H1121"\w* \add must be Ahimaaz, because he\add* \w is|strong="H2088"\w* \w running|strong="H4794"\w* \w like|strong="H2896"\w* Ahimaaz runs.” \w The|strong="H7200"\w* \w king|strong="H4428"\w* said, “\w He|strong="H4428"\w* \w is|strong="H2088"\w* \w a|strong="H3068"\w* \w good|strong="H2896"\w* \w man|strong="H1121"\w*, \w and|strong="H1121"\w* \add I am sure\add* \w he|strong="H4428"\w* \w is|strong="H2088"\w* coming \w with|strong="H4428"\w* \w good|strong="H2896"\w* \w news|strong="H1309"\w*.”
\p 
\v 28 \add When\add* Ahimaaz \add reached the king, he\add* \w called|strong="H7121"\w* \w out|strong="H3027"\w* “\w I|strong="H3027"\w* hope/\w desire|strong="H5375"\w* \w that|strong="H3068"\w* things \w will|strong="H3068"\w* \w go|strong="H3068"\w* \w well|strong="H7965"\w* \w with|strong="H3068"\w* \w you|strong="H1288"\w*!” \w Then|strong="H5375"\w* \w he|strong="H3068"\w* \w prostrated|strong="H7812"\w* \w himself|strong="H7812"\w* \w on|strong="H3027"\w* \w the|strong="H5375"\w* ground \w in|strong="H3068"\w* front \w of|strong="H4428"\w* \w the|strong="H5375"\w* \w king|strong="H4428"\w* \w and|strong="H3068"\w* \w said|strong="H7121"\w*, “\w Your|strong="H3068"\w* Majesty, \w praise|strong="H1288"\w* \w Yahweh|strong="H3068"\w* \w our|strong="H3068"\w* \w God|strong="H3068"\w*, \w who|strong="H3068"\w* \w has|strong="H3068"\w* rescued \w you|strong="H1288"\w* \w from|strong="H3027"\w* \w the|strong="H5375"\w* \w men|strong="H7121"\w* \w who|strong="H3068"\w* \w were|strong="H3027"\w* rebelling \w against|strong="H3027"\w* \w you|strong="H1288"\w*!”
\p 
\v 29 \w The|strong="H7200"\w* \w king|strong="H4428"\w* said, “\w Is|strong="H4100"\w* \w the|strong="H7200"\w* \w young|strong="H5288"\w* \w man|strong="H5288"\w* Absalom \w safe|strong="H7965"\w*/\w all|strong="H7200"\w* \w right|strong="H3045"\w*?” Ahimaaz \add did not want to answer that question, so he\add* replied, “\w When|strong="H7200"\w* \w Joab|strong="H3097"\w* \w sent|strong="H7971"\w* \w me|strong="H7971"\w*, \w I|strong="H3045"\w* \w saw|strong="H7200"\w* \w that|strong="H3045"\w* \w there|strong="H7965"\w* \w was|strong="H4428"\w* \w a|strong="H3068"\w* lot \w of|strong="H4428"\w* confusion, \w but|strong="H3808"\w* \w I|strong="H3045"\w* \w do|strong="H4100"\w* \w not|strong="H3808"\w* \w know|strong="H3045"\w* \w what|strong="H4100"\w* \w it|strong="H7200"\w* \w was|strong="H4428"\w* \w about|strong="H3045"\w*.”
\p 
\v 30 \w Then|strong="H4428"\w* \w the|strong="H3541"\w* \w king|strong="H4428"\w* said, “\w Stand|strong="H5975"\w* \w aside|strong="H5437"\w*.” \w So|strong="H3541"\w* Ahimaaz stepped \w aside|strong="H5437"\w* \w and|strong="H4428"\w* \w stood|strong="H5975"\w* \w there|strong="H5975"\w*.
