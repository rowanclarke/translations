\q2 \w from|strong="G1537"\w* \w the|strong="G1537"\w* \w tribe|strong="G5443"\w* \w of|strong="G1537"\w* \w Manasseh|strong="G3128"\w* \w twelve|strong="G1427"\w* \w thousand|strong="G5505"\w*,   
