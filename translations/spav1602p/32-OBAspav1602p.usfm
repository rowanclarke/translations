\v 1 \w VISIÓN|strong="H2377"\w* \w de|strong="H5921"\w* \w Abdías|strong="H5662"\w*. \w Así|strong="H3541"\w* dice \w el|strong="H5921"\w* \w Señor|strong="H3068"\w* \w DIOS|strong="H3069"\w* \w cuanto|strong="H5921"\w* \w a|strong="H3068"\w* Edom: \w Oído|strong="H8085"\w* hemos \w el|strong="H5921"\w* pregón \w del|strong="H5921"\w* \w SEÑOR|strong="H3068"\w*, \w y|strong="H5921"\w* \w mensajero|strong="H6735"\w* \w es|strong="H3541"\w* \w enviado|strong="H7971"\w* \w a|strong="H3068"\w* \w las|strong="H5921"\w* \w gentes|strong="H1471"\w*. \w Levantaos|strong="H6965"\w*, \w y|strong="H5921"\w* \w levantémonos|strong="H6965"\w* \w contra|strong="H5921"\w* \w ella|strong="H5921"\w* \w en|strong="H5921"\w* \w batalla|strong="H4421"\w*.   
\m
\v 2 He \w aquí|strong="H2009"\w*, \w pequeño|strong="H6996"\w* te he hecho \w entre|strong="H6996"\w* las \w gentes|strong="H1471"\w*; abatido eres tú en \w gran|strong="H3966"\w* \w manera|strong="H3966"\w*.   
\m
\v 3 La soberbia de tu \w corazón|strong="H3820"\w* te ha engañado, tú \w que|strong="H4310"\w* moras en las hendiduras de las peñas, en tu altísima morada; \w que|strong="H4310"\w* dices en tu \w corazón|strong="H3820"\w*; ¿\w Quién|strong="H4310"\w* \w me|strong="H4310"\w* derribará \w a|strong="H3068"\w* tierra?   
\m
\v 4 \w Aunque|strong="H8033"\w* te enaltecieres como el águila, y \w aunque|strong="H8033"\w* \w entre|strong="H8033"\w* las \w estrellas|strong="H3556"\w* \w pusieres|strong="H7760"\w* tu \w nido|strong="H7064"\w*, de \w ahí|strong="H8033"\w* te derribaré, \w dice|strong="H5002"\w* el \w SEÑOR|strong="H3068"\w*.   
\m
\v 5 \w Si|strong="H3808"\w* \w ladrones|strong="H1590"\w* vinieran \w a|strong="H3068"\w* ti, \w o|strong="H3068"\w* \w robadores|strong="H7703"\w* de \w noche|strong="H3915"\w* (¡cómo has sido \w destruído|strong="H7703"\w*!) ¿\w no|strong="H3808"\w* hurtarían \w lo|strong="H3808"\w* \w que|strong="H3808"\w* les bastase? Pues \w si|strong="H3808"\w* entraran \w a|strong="H3068"\w* ti \w vendimiadores|strong="H1219"\w*, ¿\w No|strong="H3808"\w* dejarían algún rebusco?   
\m
\v 6 ¡Cómo fueron escudriñadas \add las cosas de\add* \w Esaú|strong="H6215"\w*! sus cosas escon­didas fueron buscadas.   
\m
\v 7 \w Hasta|strong="H5704"\w* \w el|strong="H3605"\w* \w término|strong="H1366"\w* te \w hicieron|strong="H7760"\w* llegar \w todos|strong="H3605"\w* tus aliados; te han engañado tus pacíficos, prevale­cieron contra ti; \add los que comían\add* tu \w pan|strong="H3899"\w*, \w pusieron|strong="H7760"\w* \w el|strong="H3605"\w* lazo \w debajo|strong="H8478"\w* \w de|strong="H8478"\w* ti: no hay \w en|strong="H5704"\w* \w él|strong="H3605"\w* \w entendimiento|strong="H8394"\w*.   
\m
\v 8 ¿\w No|strong="H3808"\w* haré \w que|strong="H1931"\w* perezcan en \w aquel|strong="H1931"\w* \w día|strong="H3117"\w*, \w dice|strong="H5002"\w* \w el|strong="H1931"\w* \w SEÑOR|strong="H3068"\w*, \w los|strong="H2450"\w* \w sabios|strong="H2450"\w* de Edom, y \w la|strong="H1931"\w* prudencia del \w monte|strong="H2022"\w* de \w Esaú|strong="H6215"\w*?   
\m
\v 9 \w Y|strong="H3068"\w* tus \w valientes|strong="H1368"\w*, oh \w Temán|strong="H8487"\w*, serán \w quebrantados|strong="H2865"\w*; \w porque|strong="H4616"\w* todo \w hombre|strong="H1368"\w* será talado del \w monte|strong="H2022"\w* de \w Esaú|strong="H6215"\w* \w por|strong="H4616"\w* el estrago.   
\m
\v 10 \w Por|strong="H5769"\w* la injuria de tu hermano \w Jacob|strong="H3290"\w* te \w cubrirá|strong="H3680"\w* vergüenza, y serás talado para \w siempre|strong="H5769"\w*.   
\m
\v 11 \w El|strong="H5921"\w* \w día|strong="H3117"\w* \w que|strong="H5921"\w* \w estando|strong="H5975"\w* tú \w delante|strong="H5048"\w*, llevaban extraños \w cautivo|strong="H7617"\w* \w su|strong="H1992"\w* \w ejército|strong="H2428"\w*, \w y|strong="H1571"\w* \w los|strong="H1992"\w* extraños entraban \w por|strong="H5921"\w* \w sus|strong="H1992"\w* \w puertas|strong="H8179"\w*, \w y|strong="H1571"\w* echaban suer­tes \w sobre|strong="H5921"\w* \w Jerusalem|strong="H3389"\w*, tú \w también|strong="H1571"\w* eras \w como|strong="H1571"\w* uno \w de|strong="H5921"\w* \w ellos|strong="H1992"\w*.   
\m
\v 12 \w Pues|strong="H7200"\w* no debiste tú estar mirando en \w el|strong="H1121"\w* \w día|strong="H3117"\w* \w de|strong="H1121"\w* tu hermano, \w el|strong="H1121"\w* \w día|strong="H3117"\w* en \w que|strong="H3117"\w* \w fue|strong="H3063"\w* extrañado: no te habías \w de|strong="H1121"\w* haber alegrado \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w* en \w el|strong="H1121"\w* \w día|strong="H3117"\w* \w que|strong="H3117"\w* se per­dieron, ni habías \w de|strong="H1121"\w* ensanchar tu \w boca|strong="H6310"\w* en \w el|strong="H1121"\w* \w día|strong="H3117"\w* \w de|strong="H1121"\w* la \w angustia|strong="H6869"\w*:   
\m
\v 13 No habías \w de|strong="H5971"\w* haber entrado por \w la|strong="H1571"\w* \w puerta|strong="H8179"\w* \w de|strong="H5971"\w* mi \w pueblo|strong="H5971"\w* en \w el|strong="H1571"\w* \w día|strong="H3117"\w* \w de|strong="H5971"\w* su calamidad; no, no habías tú \w de|strong="H5971"\w* haber mirado su aflicción en \w el|strong="H1571"\w* \w día|strong="H3117"\w* \w de|strong="H5971"\w* su calamidad, \w ni|strong="H1571"\w* haber \w echado|strong="H7971"\w* \add mano\add* \w a|strong="H3068"\w* su sustancia en \w el|strong="H1571"\w* \w día|strong="H3117"\w* \w de|strong="H5971"\w* su calamidad.   
\m
\v 14 Tampoco habías \w de|strong="H5921"\w* haberte parado \w en|strong="H5921"\w* \w las|strong="H5921"\w* encrucijadas, \w para|strong="H5921"\w* matar \w los|strong="H5921"\w* \w que|strong="H5921"\w* \w de|strong="H5921"\w* \w ellos|strong="H5921"\w* escapasen; ni habías tú \w de|strong="H5921"\w* haber \w entregado|strong="H5462"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* quedaban \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w día|strong="H3117"\w* \w de|strong="H5921"\w* \w angustia|strong="H6869"\w*.   
