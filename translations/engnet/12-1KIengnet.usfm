\p
\v 10  Ben Hadad \w sent|strong="H7971"\w* \w another|strong="H3254"\w* message \w to|strong="H7971"\w* \w him|strong="H7971"\w*, “\w May|strong="H5971"\w* \w the|strong="H3605"\w* gods \w judge|strong="H6213"\w* \w me|strong="H7971"\w* severely if \w there|strong="H3541"\w* \w is|strong="H3605"\w* \w enough|strong="H3605"\w* \w dirt|strong="H6083"\w* \w left|strong="H7971"\w* \w in|strong="H6213"\w* \w Samaria|strong="H8111"\w* \w for|strong="H6213"\w* \w my|strong="H3605"\w* \w soldiers|strong="H5971"\w* \w to|strong="H7971"\w* scoop \w up|strong="H7971"\w* \w in|strong="H6213"\w* \w their|strong="H3605"\w* hands.”  
