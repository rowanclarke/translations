\v 30 (\w Now|strong="G1161"\w* \w Jesus|strong="G2424"\w* \w had|strong="G2424"\w* \w not|strong="G1510"\w* \w yet|strong="G2089"\w* \w entered|strong="G2064"\w* \w the|strong="G1722"\w* \w village|strong="G2968"\w*, \w but|strong="G1161"\w* \w was|strong="G1510"\w* \w in|strong="G1722"\w* \w the|strong="G1722"\w* \w place|strong="G5117"\w* \w where|strong="G3699"\w* \w Martha|strong="G3136"\w* \w met|strong="G5221"\w* \w Him|strong="G3588"\w*.
