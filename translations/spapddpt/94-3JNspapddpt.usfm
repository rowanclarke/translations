\mt1 3 Juan
\c 1
\s1 Saludo
\p 
\v 1 \w El|strong="G3588"\w* \w anciano|strong="G4245"\w* \w al|strong="G3588"\w* amado \w Gayo|strong="G1050"\w*, \w a|strong="G1722"\w* \w quien|strong="G3739"\w* \w yo|strong="G1473"\w* amo \w en|strong="G1722"\w* verdad.
\p 
\v 2 Amado, hablo \w con|strong="G2532"\w* Dios \w para|strong="G4012"\w* \w que|strong="G3588"\w* \w así|strong="G2532"\w* \w como|strong="G2531"\w* prospera \w tu|strong="G4771"\w* \w alma|strong="G5590"\w* seas prosperado \w en|strong="G4012"\w* \w todas|strong="G3956"\w* \w las|strong="G3588"\w* cosas \w y|strong="G2532"\w* \w que|strong="G3588"\w* tengas buena salud.
\v 3 \w Pues|strong="G1063"\w* \w en|strong="G1722"\w* gran manera \w me|strong="G1722"\w* regocijé \w cuando|strong="G1722"\w* \w vinieron|strong="G2064"\w* \w unos|strong="G3588"\w* hermanos \w y|strong="G2532"\w* dieron \w testimonio|strong="G3140"\w* \w de|strong="G1722"\w* \w tu|strong="G4771"\w* verdad, \w de|strong="G1722"\w* \w cómo|strong="G2531"\w* \w tú|strong="G4771"\w* vives \w en|strong="G1722"\w* verdad.
\v 4 \w No|strong="G3756"\w* \w tengo|strong="G2192"\w* \w más|strong="G3756"\w* \w grande|strong="G3173"\w* \w gozo|strong="G5479"\w* \w que|strong="G3588"\w* \w éste|strong="G3778"\w*: \w que|strong="G3588"\w* oiga \w que|strong="G3588"\w* \w mis|strong="G1699"\w* \w hijos|strong="G5043"\w* viven \w en|strong="G1722"\w* \w la|strong="G3588"\w* verdad.
\s1 Cooperación con la verdad
\p 
\v 5 Amado, \w fielmente|strong="G4103"\w* procedes \w en|strong="G1519"\w* \w lo|strong="G3588"\w* \w que|strong="G3588"\w* \w haces|strong="G4160"\w* \w para|strong="G1519"\w* \w los|strong="G3588"\w* hermanos, \w y|strong="G2532"\w* especialmente \w a|strong="G1519"\w* extraños,
\v 6 \w quienes|strong="G3739"\w* dieron \w testimonio|strong="G3140"\w* ante \add la \add*\w iglesia|strong="G1577"\w* \w de|strong="G3588"\w* \w tu|strong="G4771"\w* amor. \w Harás|strong="G4160"\w* \w bien|strong="G2573"\w* \w al|strong="G3588"\w* proveerles para \w su|strong="G3588"\w* viaje \w de|strong="G3588"\w* \w una|strong="G3588"\w* manera digna \w de|strong="G3588"\w* \w Dios|strong="G2316"\w*.
\v 7 \w Porque|strong="G1063"\w* \w salieron|strong="G1831"\w* \w por|strong="G5228"\w* amor \w al|strong="G3588"\w* \w Nombre|strong="G3686"\w*, \w sin|strong="G3367"\w* \w recibir|strong="G2983"\w* algo \w de|strong="G5228"\w* \w los|strong="G3588"\w* gentiles.
\v 8 \w Nosotros|strong="G2249"\w*, \w pues|strong="G3767"\w*, tenemos \w que|strong="G3588"\w* recibirlos \w para|strong="G2443"\w* \w que|strong="G3588"\w* \w seamos|strong="G1096"\w* colaboradores \w con|strong="G3588"\w* \w la|strong="G3588"\w* verdad.
\s1 Oposición de Diótrefes
\p 
\v 9 \w Escribí|strong="G1125"\w* \w algo|strong="G5100"\w* a \w la|strong="G3588"\w* \w iglesia|strong="G1577"\w*, pero \w Diótrefes|strong="G1361"\w*, \w quien|strong="G3588"\w* desea ser \w el|strong="G3588"\w* primero \w de|strong="G3588"\w* ustedes, \w no|strong="G3756"\w* nos \w recibe|strong="G1926"\w*.
\p 
\v 10 \w Por|strong="G1223"\w* \w esto|strong="G3778"\w*, \w cuando|strong="G1909"\w* \w yo|strong="G1473"\w* \w vaya|strong="G2064"\w* \w le|strong="G1909"\w* \w recordaré|strong="G5279"\w* \w las|strong="G3588"\w* \w obras|strong="G2041"\w* \w que|strong="G3588"\w* \w hace|strong="G4160"\w* \w al|strong="G3588"\w* acusarnos \w con|strong="G1223"\w* \w palabras|strong="G3056"\w* perversas. \w Y|strong="G2532"\w* \w no|strong="G3361"\w* satisfecho \w con|strong="G1223"\w* \w éstas|strong="G3778"\w* \add palabras\add*, \w no|strong="G3361"\w* solo \w no|strong="G3361"\w* \w recibe|strong="G1926"\w* \w a|strong="G1909"\w* \w los|strong="G3588"\w* hermanos, \w sino|strong="G3361"\w* \w impide|strong="G2967"\w* \w y|strong="G2532"\w* expulsa \w de|strong="G1909"\w* \w la|strong="G3588"\w* \w iglesia|strong="G1577"\w* \w a|strong="G1909"\w* \w los|strong="G3588"\w* \w que|strong="G3588"\w* quieren \add recibirlos\add*.
\s1 Recomendación a Demetrio
\p 
\v 11 Amado, \w no|strong="G3756"\w* te fijes \w en|strong="G1537"\w* \w lo|strong="G3588"\w* \w malo|strong="G2556"\w*, \w sino|strong="G3361"\w* \w en|strong="G1537"\w* \w lo|strong="G3588"\w* bueno. \w El|strong="G3588"\w* \w que|strong="G3588"\w* hace \w lo|strong="G3588"\w* bueno \w es|strong="G3756"\w* \w de|strong="G1537"\w* \w Dios|strong="G2316"\w*. \w El|strong="G3588"\w* \w que|strong="G3588"\w* hace \w lo|strong="G3588"\w* \w malo|strong="G2556"\w*, \w no|strong="G3756"\w* ha visto \w a|strong="G1537"\w* \w Dios|strong="G2316"\w*.
\p 
\v 12 \w Todos|strong="G3956"\w* dieron buen \w testimonio|strong="G3141"\w* \w de|strong="G5259"\w* \w Demetrio|strong="G1216"\w* \w y|strong="G2532"\w* \w de|strong="G5259"\w* \w la|strong="G3588"\w* \w misma|strong="G5259"\w* verdad. \w También|strong="G2532"\w* \w nosotros|strong="G2249"\w* damos \w testimonio|strong="G3141"\w*, \w y|strong="G2532"\w* \w sabes|strong="G1492"\w* \w que|strong="G3754"\w* \w nuestro|strong="G2249"\w* \w testimonio|strong="G3141"\w* es verdadero.
\s1 Epílogo
\p 
\v 13 \w Muchas|strong="G4183"\w* cosas \w tenía|strong="G2192"\w* \w que|strong="G2532"\w* \w escribirte|strong="G1125"\w*, \w pero|strong="G2532"\w* \w no|strong="G3756"\w* \w quiero|strong="G2309"\w* \w escribir|strong="G1125"\w* \w por|strong="G1223"\w* \w medio|strong="G1223"\w* \w de|strong="G1223"\w* \w tinta|strong="G3188"\w* \w y|strong="G2532"\w* \w pluma|strong="G2563"\w*,
\v 14 \w pues|strong="G1161"\w* \w espero|strong="G1679"\w* verte \w en|strong="G4314"\w* breve, \w y|strong="G2532"\w* \w hablaremos|strong="G2980"\w* cara \w a|strong="G4314"\w* cara.
\p 
\v 15 \w Paz|strong="G1515"\w* \w a|strong="G2596"\w* ti. \w Los|strong="G3588"\w* \w amigos|strong="G5384"\w* \w te|strong="G4771"\w* saludan. Saluda \w a|strong="G2596"\w* \w los|strong="G3588"\w* \w amigos|strong="G5384"\w*, \w a|strong="G2596"\w* \w cada|strong="G2596"\w* \w uno|strong="G3588"\w* \w por|strong="G2596"\w* \w nombre|strong="G3686"\w*. 
