\p Entonces \w la|strong="H1931"\w* tierra tuvo \w reposo|strong="H8252"\w* \w de|strong="H6440"\w* \w la|strong="H1931"\w* \w guerra|strong="H4421"\w*.   
\c 15  
\s1 Territorio de Judá  
\p
\v 1 \w La|strong="H1366"\w* parte \w que|strong="H1121"\w* le tocó en \w suerte|strong="H1486"\w* \w a|strong="H3068"\w* \w la|strong="H1366"\w* \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*, según sus \w familias|strong="H4940"\w*, iba \w hacia|strong="H5045"\w* \w el|strong="H1121"\w* \w límite|strong="H7097"\w* \w de|strong="H1121"\w* Edom, \w hacia|strong="H5045"\w* \w el|strong="H1121"\w* \w desierto|strong="H4057"\w* \w de|strong="H1121"\w* Zin al \w extremo|strong="H7097"\w* sur.  
\v 2 \w Su|strong="H1992"\w* \w límite|strong="H7097"\w* \w por|strong="H4480"\w* \w el|strong="H1992"\w* lado sur iba \w desde|strong="H4480"\w* \w la|strong="H1366"\w* costa \w del|strong="H4480"\w* \w mar|strong="H3220"\w* \w Salado|strong="H4417"\w*, \w desde|strong="H4480"\w* \w la|strong="H1366"\w* bahía \w que|strong="H4480"\w* \w mira|strong="H6437"\w* \w hacia|strong="H1366"\w* \w el|strong="H1992"\w* sur,  
\v 3 y seguía por \w el|strong="H5674"\w* sur \w hacia|strong="H5045"\w* la subida de Acrabim, \w pasaba|strong="H5674"\w* hasta Zin, \w subía|strong="H5927"\w* por \w el|strong="H5674"\w* sur de Cades Barnea y \w pasaba|strong="H5674"\w* por Hebrón, y después de \w subir|strong="H5927"\w* por Adar, volvía \w a|strong="H3068"\w* Carca.  
\v 4 De allí \w pasaba|strong="H5674"\w* \w a|strong="H3068"\w* Asmón y \w seguía|strong="H1961"\w* \w hasta|strong="H2088"\w* \w el|strong="H5674"\w* \w arroyo|strong="H5158"\w* de \w Egipto|strong="H4714"\w*, y terminaba \w en|strong="H3318"\w* \w el|strong="H5674"\w* \w mar|strong="H3220"\w*. \w Éste|strong="H2088"\w* les \w será|strong="H1961"\w* \w el|strong="H5674"\w* límite del sur.   
