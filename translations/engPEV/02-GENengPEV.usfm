\p
\v 18 \w Hamor|strong="H2544"\w* \w and|strong="H1121"\w* \w his|strong="H7927"\w* \w son|strong="H1121"\w* Shekem, \w they|strong="H1697"\w* \w liked|strong="H5869"\w* \w that|strong="H1697"\w* \w idea|strong="H1697"\w*, \w and|strong="H1121"\w* \w they|strong="H1697"\w* agreed \w to|strong="H1121"\w* \w do|strong="H3190"\w* \w what|strong="H1697"\w* Jacob’s \w sons|strong="H1121"\w* \w said|strong="H1697"\w*.  
\v 19 Shekem really loved \w Dinah|strong="H3513"\w*, \w and|strong="H1004"\w* \w he|strong="H1931"\w* really \w wanted|strong="H2654"\w* \w to|strong="H6213"\w* marry \w her|strong="H3605"\w* \w soon|strong="H3588"\w*, \w so|strong="H6213"\w* \w he|strong="H1931"\w* \w went|strong="H3290"\w* quickly \w to|strong="H6213"\w* \w do|strong="H6213"\w* \w those|strong="H3605"\w* \w things|strong="H1697"\w*. Shekem \w was|strong="H1931"\w* \w the|strong="H3605"\w* most important person \w in|strong="H1004"\w* \w his|strong="H3605"\w* father’s \w family|strong="H1004"\w*.  
\v 20 \w Hamor|strong="H2544"\w* \w and|strong="H1121"\w* \w his|strong="H1696"\w* \w son|strong="H1121"\w* Shekem, \w they|strong="H8179"\w* \w went|strong="H5892"\w* \w to|strong="H1696"\w* \w the|strong="H1696"\w* \w town|strong="H5892"\w* \w gate|strong="H8179"\w*, \w and|strong="H1121"\w* \w they|strong="H8179"\w* \w had|strong="H1121"\w* \w a|strong="H3068"\w* meeting \w with|strong="H1696"\w* \w the|strong="H1696"\w* other \w men|strong="H1121"\w* \w that|strong="H5892"\w* lived \w in|strong="H5892"\w* \w that|strong="H5892"\w* \w town|strong="H5892"\w*. \w Hamor|strong="H2544"\w* \w and|strong="H1121"\w* Shekem \w said|strong="H1696"\w* \w to|strong="H1696"\w* \w those|strong="H1121"\w* \w men|strong="H1121"\w*,  
\v 21 “\w You|strong="H5414"\w* know, \w that|strong="H5414"\w* \w man|strong="H7342"\w* Jacob \w and|strong="H3027"\w* \w his|strong="H5414"\w* sons, \w they|strong="H1992"\w* \w are|strong="H1992"\w* \w friendly|strong="H8003"\w* \w to|strong="H5414"\w* \w us|strong="H5414"\w*. \w So|strong="H3947"\w* \w let|strong="H5414"\w* \w them|strong="H5414"\w* \w live|strong="H3427"\w* \w here|strong="H2009"\w* \w in|strong="H3427"\w* \w our|strong="H5414"\w* \w land|strong="H6440"\w*, \w and|strong="H3027"\w* \w let|strong="H5414"\w* \w them|strong="H5414"\w* \w buy|strong="H3947"\w* \w things|strong="H1992"\w* \w and|strong="H3027"\w* \w sell|strong="H5414"\w* \w things|strong="H1992"\w* \w here|strong="H2009"\w*. \w Our|strong="H5414"\w* \w land|strong="H6440"\w* \w is|strong="H3027"\w* big, \w and|strong="H3027"\w* \w there|strong="H2009"\w* \w is|strong="H3027"\w* plenty \w of|strong="H1323"\w* room \w for|strong="H6440"\w* \w them|strong="H5414"\w*. \w Our|strong="H5414"\w* \w men|strong="H1992"\w* \w can|strong="H3947"\w* \w marry|strong="H3947"\w* \w their|strong="H5414"\w* \w women|strong="H1323"\w*, \w and|strong="H3027"\w* \w their|strong="H5414"\w* \w men|strong="H1992"\w* \w can|strong="H3947"\w* \w marry|strong="H3947"\w* \w our|strong="H5414"\w* \w women|strong="H1323"\w*.  
\v 22 \w But|strong="H1961"\w* first, \w there|strong="H1961"\w* \w is|strong="H3605"\w* \w one|strong="H3605"\w* \w thing|strong="H2063"\w* \w that|strong="H5971"\w* \w we|strong="H3068"\w* \w have|strong="H1961"\w* \w to|strong="H1961"\w* \w do|strong="H3605"\w*. \w All|strong="H3605"\w* \w of|strong="H3427"\w* \w us|strong="H1961"\w* \w men|strong="H2145"\w* \w and|strong="H5971"\w* boys \w in|strong="H3427"\w* \w our|strong="H3605"\w* mob, \w we|strong="H3068"\w* \w have|strong="H1961"\w* \w to|strong="H1961"\w* \w have|strong="H1961"\w* \w a|strong="H3068"\w* young \w man|strong="H2145"\w* operation, \w just|strong="H3605"\w* \w like|strong="H1961"\w* Jacob \w and|strong="H5971"\w* \w his|strong="H3605"\w* family. \w If|strong="H1961"\w* \w we|strong="H3068"\w* \w do|strong="H3605"\w* \w that|strong="H5971"\w*, \w then|strong="H1961"\w* Jacob \w and|strong="H5971"\w* \w his|strong="H3605"\w* sons \w will|strong="H1961"\w* agree \w to|strong="H1961"\w* \w live|strong="H3427"\w* \w with|strong="H3427"\w* \w us|strong="H1961"\w*, \w and|strong="H5971"\w* \w their|strong="H3605"\w* mob \w will|strong="H1961"\w* \w join|strong="H3427"\w* \w together|strong="H5971"\w* \w with|strong="H3427"\w* \w our|strong="H3605"\w* mob, \w and|strong="H5971"\w* \w we|strong="H3068"\w* \w will|strong="H1961"\w* \w become|strong="H1961"\w* \w one|strong="H3605"\w* tribe.  
