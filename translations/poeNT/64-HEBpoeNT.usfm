\id HEB  
\h HEBREOS 
\toc1 Tí xroon kꞌuáyéhe̱ tí sín Hebreos 
\toc2 HEBREOS 
\toc3 He. 
\mt1 Tí xroon kꞌuáyéhe̱ tí sín Hebreos 
\c 1  
\s1 Dios nixja̱xi̱n chꞌán tí Xje̱en chꞌán 
\p  
\v 1 A̱ ntá tí imá ósé Dios mé nixje̱he̱ tí sín tsíkꞌaxrjeníxinni nchónhya veces kíxin nchónhya nkexrí chrókienxín sín, nixja̱xi̱n chꞌán tí sín kꞌuéchrónka tí itén chꞌán.  
\v 2 A̱ ntá jie tió tsjixixín Dios nixja̱xi̱n chꞌán tí Xje̱en chꞌán, na mé Dios kjuíchꞌéna chꞌán kaín xín nkehe siín kíxin kjua̱cha̱xién tí Xje̱en chꞌán, mé tí nkexro kꞌuáyéhe̱ kaín xín nkehe.  
\v 3 Jehe chꞌán mé tꞌinkaséyanxín chꞌán tí kjuachaxin kuènte Dios, la ko jehe chꞌán mé kja̱xin éxí tsjehe Dios xi̱kaha tsjehe tí jehe chꞌán. Jehe chꞌán tꞌaykonhen chꞌán kaín xín nkehe siín kíxin tí kjuachaxin jié chónta tí tan nixja chꞌán. A̱ ntá kjuixin kjuínchetjóá chꞌán tí jie̱ chóntani, ntá sákjui̱ chꞌán kjuákꞌetja̱xi̱n chꞌán tí tja chjina Itꞌé chꞌán tí tjen chꞌán tꞌe̱to̱an chꞌán nkaya nka̱jní. 
\s1 Tí Xje̱en Dios imá tꞌe̱to̱an, a̱ ntá tí sín ángel la kénhyó 
\p  
\v 4 Tí Xje̱en Dios kꞌuáyéhe̱ chꞌán kjuachaxin tsꞌe̱tue̱nhen tí sín ángel, kíxin tsíkꞌáyéhe̱ chꞌán tí kjuachaxin kuènte Itꞌé chꞌán, a̱ ntá imá tꞌe̱to̱an chꞌán, a̱ ntá tí jehe sín la náhí.  
\v 5 Méxra̱ Dios ntáchehya nijnko ángel kíxin: 
\q1 Jaha mé Xja̱nna, 
\q1 janhan mé kjui̱tꞌána tí jaha ijie. 
\m la ko kja̱xin ntáchrohya Dios kuènte nijnko ángel kíxin: 
\q1 Janhan mé chrókꞌóna Itꞌé chꞌán, 
\q1 la ko jehe chꞌán mé chrókꞌóna xja̱nna.\f + \fr 1:5 \ft Salmo 2.7; 2 Samuel 7.14; 1 Crónicas 17.13\f* 
\m  
\v 6 A̱ ntá tió kui tí jnkoko̱á Xje̱en Dios chjasintajni, ntá ntáchro Dios kíxin: 
\q1 Kaín tí sín ángel kuènte Dios chrókjuikosáyehe tí jehe chꞌán.\f + \fr 1:6 \ft Deuteronomio 32.43\f* 
\m  
\v 7 A̱ ntá ntáchro Dios kuènte tí sín ángel kíxin: 
\q1 Tí sín ángel chꞌéna chꞌán éxí xri̱nto̱ kíxin ncha̱kuen sín ó, 
\q1 la ko tí sín chꞌehe chꞌán xra̱ la chꞌéna chꞌán éxí xrohinene.\f + \fr 1:7 \ft Salmo 104.4\f* 
\m  
\v 8 A̱ ntá ntáche chꞌán tí Xje̱en chꞌán kíxin: 
\q1 Tí trono kuèntá itjen jnkochríxín, jaha Dios, 
\q1 la mé jaha mé ijnko nkexro tꞌe̱to̱an jína. 
\q1  
\v 9 Jaha tóxrjínhan tí nkehe jína, a̱ ntá ninkákonhén tí nkehe jínahya. 
\q1 Mé xi̱kaha tí Dios tsíkjeyá jaha, la Dios kuèntá kjuíntacháha má, 
\q1 a̱ ntá tí í so sín kꞌuájikoa la kánhyó.\f + \fr 1:9 \ft 1.8-9 Salmo 45.6-7\f* 
\m  
\v 10 Kja̱xin ntáchro kíxin: 
\q1 Jaha Ìnchéni, tí xrankíxixín kjui̱chꞌéna chjasintajni, 
\q1 la ko jaha kjui̱chꞌéna nka̱jní. 
\q1  
\v 11 Táha mé tsꞌitjáyan, a̱ ntá jaha la tsjakꞌe jnkochríxín. 
\q1 Kaín tíha tsontaxín éxí iké chojni, 
\q1  
\v 12 éxí ijnko iké chojni xi̱kaha tsoxrátꞌo̱, 
\q1 tsꞌixinkí éxí ijnko iké chojni. 
\q1 A̱ ntá jaha la tsꞌixitóxinhya jnkochríxín tsjakꞌe, 
\q1 a̱ ntá tí kjuachón chonta jaha la nunca tsjeje̱hya.\f + \fr 1:12 \ft 1.10–12 Salmo 102.25–27\f* 
\m  
\v 13 Dios la ntáchehya nijnko tí sín ángel kuènte chꞌán kíxin chrókꞌuejó sín tja chꞌán chjina ntahó chrókꞌue̱to̱an sín, tsjixinjian kaín xín tí sín nínkakonhen sín la chrókjuachahya sín chrókꞌue̱to̱an sín.\f + \fr 1:13 \ft Salmo 110.1\f* 
\v 14 Kaín tí sín ángel mé ncha̱kuen sín ó mé chꞌehe Dios xra̱ mé kꞌuítuenhen sín tsjinki̱tsa tí sín tsꞌáyéhe̱ kjuachaxin tsaá sín. 
\c 2  
\s1 Chrókjo̱nie̱hyani tí nkehe tsaáxinni 
\p  
\v 1 Mé xi̱kaha chrókjuenka̱yáxinni jína tí nkehe ó kuínhinni kíxin chrókuíto̱ehyani tí nti̱a ó kuákjani.  
\v 2 A̱ ntá tí tan tsíchrónka tí sín ángel ósé la mé tsíkónoxín kíxin chaxín tíha. A̱ ntá tí sín kuítekakonhya sín tí tan jína kuínhin sín la kjuasin sín jie̱, na mé kjuasóte sín la táhó mé kjuacha sín.  
\v 3 ¿Xá nkexrí chrókuaáni tí chrókuahyani kuentá tí nkehe jié chrókuaáxinni? Jehe Ìnchéni tsíchrónka chꞌán sa̱oxín nkexrí chrókuaáxinni, a̱ ntá chrꞌéxi̱n tí sín tsíkinhin mé kjua̱ko̱he̱ sín tí jeheni.  
\v 4 Méxra̱ Dios kjua̱ko̱xi̱n chꞌán kjuaxroan jié la ko kjuachaxin jié kíxin chaxín tíha, la ko noexínni kaín tí kjua̱cha̱xién Ncha̱kuen chꞌán tsíkꞌáyéhe̱ni éxí tjinkaon chꞌán tsjanjon chꞌán. 
\s1 Jesucristo kꞌóna chꞌán chojni 
\p  
\v 5 Dios la tsíchjéhya tí sín ángel kjuachaxin kíxin chrókꞌue̱to̱an chjasintajni chrꞌéxi̱n éxí tí jie tjejónixjani.  
\v 6 Náhí. Éxí nixja xroon itén Dios chronkaxín kíxin: 
\q1 ¿Xá nkexéhe tí chojni a, jaha Itꞌéni Dios, kíxin imá xráxinkávan tí jehe chꞌán? 
\q1 ¿Xá nkexro tíha kíxin imá tóxakonhan kíxin tí jehe chꞌán? 
\q1  
\v 7 Jaha tsíkji̱chꞌéna chꞌán éxí ijnko chojni tꞌe̱tu̱anhya kjánchó kánhyó isé, a̱ ntá tí sín ángel a̱ntsí má kꞌuéchónta sín kjuachaxin, 
\q1 a̱ ntá jie la imá kjuíkosáyehé chꞌán; 
\q1  
\v 8 la jaha tsíchje̱hé chꞌán kjuachaxin kíxin kaín nkehe tsꞌe̱tue̱nhen chꞌán.\f + \fr 2:8 \ft 2.6–8 Salmo 8.4–6\f* 
\m Mé xi̱kaha ntáchro tíha kíxin tsíchjéhe Dios tí chojni kjuachaxin kíxin chrókꞌue̱tue̱nhen chꞌán kaín xín nkehe, ntá Dios kuíto̱ehya ninkehó nkehe chrókuitekakuenhya chꞌán. Kjánchó na̱xa̱ tꞌikonhyani kíxin á kaín nkehe titekakonhen chꞌán.  
\v 9 Kjánchó ó noheni kíxin Jesús la tsíkjichꞌéna Dios éxí chojni tꞌeto̱anhya kjánchó kánhyó isé, a̱ ntá tí sín ángel a̱ntsí má kꞌuéchónta sín kjuachaxin. Dios mé tjuèhe kaín xín chojni ntá tjinkaon chꞌán kíxin chꞌín Jesús chrókꞌuenyákonhe̱n kaín chojni. A̱ ntá jie tsíkꞌáyéhe̱ chꞌán kjuachaxin náxrjón la ko Dios tjikosáyehe tí jehe chꞌán kíxin tí kjuasóte chꞌán, ikꞌuén chꞌán. 
\p  
\v 10 Kaín nkehe siín la kuènte Dios la ko tjejó kíxin tí kjuachaxin kuènte tí jehe chꞌán. A̱ ntá Dios tjinkaon chꞌán kíxin kaín xín tí xje̱en chꞌán chrókꞌuejó sín tí tjen chꞌán tí tꞌinkaséyan. Méxra̱ Dios kjuanjon Ìnchéni Jesucristo kíxin tsjasóte chꞌán kíxin ntá jína kjua̱ko̱xi̱n chꞌán kíxin ntá jehe chꞌán tsaáxinni chꞌán.  
\v 11 Kaín tí sín tsíkótjóá la ko tí nkexro kjuínchetjóá na mé chónta jnkoko̱á Itꞌé. Méxra̱ tí Xje̱en Dios tósuèhya chꞌán tsontáchro chꞌán kíxin kíchó chꞌán tí jehe sín.  
\v 12 Éxí ntáchro tí xroon itén Dios kíxin: 
\q1 Tsochénkani tí sín kíchó ni kíxin nkexro tí jaha, 
\q1 tsjikosáyahani tsotsjeni himno tí tójnkotsékoni tí sín kíchó ni.\f + \fr 2:12 \ft Salmo 22.22\f* 
\m  
\v 13 Kja̱xin ntáchro kíxin: 
\q1 Janhan títeka̱van Dios.\f + \fr 2:13 \ft Isaías 8.17,18\f* 
\m La ko kja̱xin ntáchro ínaá kíxin: 
\q1 Ntihi tjékian tí xje̱en Dios tsíkjanjon chꞌán tsíkꞌayáha̱.\f + \fr 2:13 \ft Isaías 8.17,18\f* 
\p  
\v 14 A̱ ntá tí xje̱en chojni mé jnkoko̱á kíchó la kꞌóna nto la ko ijni̱; la kja̱xin chꞌín Jesús xi̱kaha tsíkꞌóna chꞌán nto la ko ijni̱ kíxin jína itsꞌen chꞌán kíxin jína sinchekꞌitjáyan chꞌán tí nkexro chónta kjuachaxin tꞌóyán chojni, na mé tꞌaxrjexín kíxin diablo tíha,  
\v 15 mé xi̱kaha chrókjuinchekaá chꞌán kaín tí sín chrako̱nhe̱n sín tí kjuachꞌen, tjejó sín éxí tꞌítuenhen sín kaín ya̱on tjejó sín.  
\v 16 Kja̱xin kuihya chꞌán kíxin chrókjuinki̱tsa chꞌán tí sín ángel. Náhí. Ikui chꞌán kíxin tsjinki̱tsa chꞌán tí sín tsíkꞌaxrjeníxin chꞌín Abraham.  
\v 17 A̱ ntá tꞌichjánxi̱n chrókóyóhe̱ chꞌán éxí tí sín kíchó chꞌán kíxin jína chrókꞌóna chꞌán ncha̱tꞌá tꞌe̱to̱an kuènte Dios la chrókui̱konóe̱he̱ni chꞌán, ntá jína tsja̱tse̱n chꞌán iji̱é kaín chojni kíxin kꞌuenyákonhe̱nni chꞌán.  
\v 18 Kíxin jehe chꞌán kjuasóte chꞌán la ko tí Jínahya tjinkaon chrókjuachroe chꞌán la kjuachahya, a̱ ntá jie la jína tsjinki̱tsa chꞌán tí sín chrókjuachroe tí Jínahya kíxin chrókjuasinhya sín jie̱. 
\c 3  
\s1 A̱ntsí tjetoan chꞌín Jesús, a̱ ntá chꞌín Moisés la kánhyó 
\p  
\v 1 A̱ ntá kíchó ni, jahará la tsíkótjóárá, la mé Dios tsíkꞌíyahará chꞌán kíxin tsꞌónará xje̱en chꞌán, a̱ ntá chróxraxinkáonrá jína Cristo Jesús na mé jehe chꞌán mé tí apóstol la ko tí ncha̱tꞌá tꞌe̱to̱an kuènte tí nkehe tinkáchónkini.  
\v 2 Tí chꞌín Jesús jína kuítekakonhen chꞌán Dios, mé tí nkexro tsíkjeyá chꞌán sichꞌehe chꞌán xra̱, éxí kja̱xin chꞌín Moisés jína kjuíchꞌe chꞌán xra̱ kꞌuáyakonhen chꞌán nto̱e Dios.  
\v 3 Dios a̱ntsí kjuikosáyehe tí chꞌín Jesús, a̱ ntá chꞌín Moisés la kénhyó, éxí a̱ntsí tjikosáyehe sín tí nkexro kjuíchꞌéna ijnko nchia, a̱ ntá tí nchia la kénhyó tjikosáyehe sín.  
\v 4 Jnkojnko nchia kꞌóna kíxin siín nkexro kjuíchꞌéna, kjánchó Dios mé kjuíchꞌéna kaín nkehe siín.  
\v 5 Chꞌín Moisés jína kjuíchꞌe chꞌán xra̱ kꞌuáyakonhen chꞌán tí nchia kuènte Dios. Tí xra̱ kjuíchꞌe chꞌán mé kꞌuénixja chꞌán kuènte tí nkehe tsontáchro Dios chrꞌéxi̱n.  
\v 6 A̱ ntá Cristo la mé Xje̱en Dios tí jehe chꞌán, ntá kjuínchexiteyá chꞌán jína la tꞌayakonhen chꞌán tí nchia kuènte Dios, la tíha mé jeheni, kíxin tí tsíto̱ehyani chꞌán la na̱xa̱ tsinkáchónkini chꞌán ntá tso̱chéhe̱ni kíxin tí nkehe tjejóchónhenni. 
\s1 Tsꞌo̱kꞌéheni tí tjen Dios 
\p  
\v 7 Mé xi̱kaha éxí ntáchro Ncha̱kuen Dios nixja xroon itén Dios kíxin: 
\q1 A̱ ntá jie tí chrókuinhínrá tí nkehe ntáchro Dios, 
\q1  
\v 8 chrókjui̱chꞌehyará éxí kjuíchꞌe tí sín ósé kuítekakonhya sín Dios 
\q1 tí ya̱on kjuíchꞌehe sín prueba Dios tí nte̱je̱. 
\q1  
\v 9 A̱ ntá ntaha tí sín tsíkꞌaxrjeníxinrá ósé kjuíchꞌèna sín prueba, 
\q1 kjónté cuarenta nánó kꞌuíkon sín tí xra̱ kjui̱tꞌa. 
\q1  
\v 10 Méxra̱ kónínka̱konha̱n tí chojni a, 
\q1 ntáxrja̱n kíxin: “Xráxín xrichoe a̱sén sín, 
\q1 tjinkakonhya sín tsochóxin sín nti̱aná.” 
\q1  
\v 11 Méxra̱ kónínka̱konha̱n tí jehe sín, ntátjan sín 
\q1 kíxin chaxín tsoxiteyá kíxin tsꞌixenhya sín tsꞌo̱kꞌéhe sín tí tjén janhan.\f + \fr 3:11 \ft 3.7–11 Salmo 95.7–11\f* 
\p  
\v 12 Kíchóni, chrókóxakonhanrá kíxin chrókókohya nijnko tí jahará chróchontará a̱sánrá jínahya chrókui̱to̱hérá Dios tjechón chrókuítekákuenhyará tí jehe chꞌán.  
\v 13 Chrókjui̱nchechéhérá kíchuárá jnkojnko ya̱on na̱xa̱ tjen tiempo kíxin nijnko tí jahará chrókjuenka̱yáxinrá kíxin na̱xa̱ chrókjuásinrá jie̱, í chróntáchrohya a̱sánrá kíxin na̱xa̱ chrókójia̱hará.  
\v 14 A̱ ntá tí chrókꞌuejóni jnkojína hasta tsjixixín éxí kuinkáchónkini tí xrankíxixín, ntá siín kjuachaxin tsꞌejókoni Cristo. 
\p  
\v 15 Mé xi̱kaha ntáchro kíxin: 
\q1 A̱ ntá jie tí chrókuinhínrá jahará tí nkehe ntáchro Dios, 
\q1 chrókjui̱chꞌehyará éxí kjuíchꞌe tí sín ósé kuítekakonhya sín Dios.\f + \fr 3:15 \ft Salmo 95.7-8\f* 
\m  
\v 16 ¿A̱ ntá nkexro tí sín kuínhin itén Dios, a̱ ntá tí chrꞌéxi̱n kuítekakonhya sín? ¿Á jehya kaín tí sín tsíkakitsjexín chꞌín Moisés tí nación Egipto?  
\v 17 ¿A̱ ntá nkexro tí kónínkakonhen Dios tí cuarenta nánó? ¿Á jehya tí sín kjuasin jie̱ kꞌuénxin nte̱je̱?  
\v 18 ¿A̱ ntá nkexro ntáche Dios kíxin chaxín tsoxiteyá kíxin tsꞌixenhya sín tsꞌo̱kꞌéhe sín tí tjen tí jehe chꞌán? ¿Á jehya tí sín kuítekakonhya?  
\v 19 A̱ ntá ó noheni kíxin kjuachahya sín kꞌuíxenhen sín kíxin kuítekakonhya sín. 
\c 4  
\p  
\v 1 Méxra̱, tsíntáchro Dios kíxin tsjanjon chꞌán kjuachaxin tsꞌixenhenni tsꞌo̱kꞌéheni tí tjen chꞌán, a̱ ntá tóxakonhenni kíxin áchꞌe jnkojín tí jahará chrókjuachahyará chrókꞌuixe̱nhenrá ntiha.  
\v 2 Kíxin kja̱xin jeheni kuínhinni itén chꞌán tsaáxinni éxí kuínhin tí jehe sín, kjánchó tí jehe sín la ninkehó kjuínki̱tsahya sín tí tan jína kuínhin sín, kíxin kjónté kuínhin sín tí tan na kuítekakonhya sín.  
\v 3 A̱ ntá jeheni kuítekaonni, ntá tsꞌixenhenni tsꞌo̱kꞌéheni ntaha, éxí tsíntáchro Dios kíxin: 
\q1 Méxra̱ kóninka̱konha̱n sín tí jehe sín ntátjan sín kíxin chaxín tsoxiteyá 
\q1 kíxin tsꞌixenhya sín tsꞌo̱kꞌéhe sín tí tjén janhan.\f + \fr 4:3 \ft Salmo 95.11\f* 
\m Kíxin Dios la tió kjuixinhin chꞌán xra̱ kjuíchꞌéna chꞌán chjasintajni ntá kjuákꞌe chꞌán kꞌo̱kꞌéhe chꞌán.  
\v 4 Mé xi̱kaha í jnko nketí nixja tí xroon itén Dios chrónka kuènte tí ya̱on ya̱to̱xi̱n ntáchro kíxin: 
\q1 Kjuixinhin Dios kaín xra̱ ntá kjuákꞌe chꞌán kꞌo̱kꞌéhe chꞌán tí ya̱on ya̱to̱xi̱n.\f + \fr 4:4 \ft Génesis 2.2\f* 
\m  
\v 5 A̱ ntá ínaá ntáchro tí xroon itén Dios kíxin: 
\q1 Tsꞌixenhya sín tsꞌo̱kꞌéhe sín tí tjén janhan.\f + \fr 4:5 \ft Salmo 95.11\f* 
\m  
\v 6 Kjánchó na̱xa̱ tꞌitjáyan jnkojín chojni chrókꞌuixenhen sín chrókꞌo̱kꞌéhe sín. A̱ ntá tí sín sa̱oxín kuínhin tí tan chrókuaáxin sín la kꞌuíxenhya sín kíxin kuítekakonhya sín tí tan a.  
\v 7 Méxra̱ Dios tsíkjeyá chꞌán í jnko ya̱on, mé tí ya̱on jie, a̱ ntá chrꞌéxi̱n nixja̱xi̱n chꞌán tí nkehe tsíchrónka chꞌín David éxí ntáchro tí xroon itén Dios kíxin: 
\q1 A̱ ntá jie tí tsinhínrá tí nkehe ntáchro Dios, chrókjui̱nchexiteyárá.\f + \fr 4:7 \ft Salmo 95.7-8\f* 
\m  
\v 8 Kíxin tí chrókjuanjon chꞌín Josué kjuachaxin kíxin chrókꞌo̱kꞌéhe tí sín israelita,\f + \fr 4:8 \ft Josué 22.4\f* ntá Dios la í chrónixjahya chꞌán kuènte í jnko ya̱on.  
\v 9 A̱ ntá na̱xa̱ tjechónhen tí tsꞌo̱kꞌéhe tí sín tinkáchónki Dios;  
\v 10 kíxin tí nkexro tsꞌixenhen tsꞌo̱kꞌéhe tí tjen Dios tsíkjixinhin chꞌán tí xra̱ kuènte chꞌán éxí yóhe̱ kja̱xin Dios kjuixinhin chꞌán tí xra̱ kuènte chꞌán ntá kjuákꞌe chꞌán kꞌo̱kꞌéhe chꞌán.  
\v 11 Tꞌichjánxi̱n kíxin kaín a̱sénni chrókjueyáni nkexrí chrókꞌuixenhenni chrókꞌo̱kꞌéheni, kíxin chrókóyóe̱hyani éxí tí sín kuítekakonhya. 
\p  
\v 12 Kíxin tí itén Dios la mé tjechón la ko chónta kjuachaxin. Tíha la imá taté, a̱ ntá kánhyó taté tí chica espada yánjín taté, la tíha mé tꞌixenhen tí ni̱nka a̱sén chojni la ko ncha̱kuen chojni hasta tí nkaya a̱sén chojni. Tíha mé nchexraxinkaon chojni kaín nkehe tjenka̱yáxin sín la ko kaín nkehe ntáchro a̱sén sín.  
\v 13 Kohya ninkehó nkehe tsíkjichꞌéna Dios tsjacha chrókꞌuejóméhe tí jehe chꞌán kíxin kaín nkehe la noxín siín tꞌikon tí nkexro tsꞌáyéhe̱ kuentá. 
\s1 Jesús mé tí ncha̱tꞌá imá tjetoan 
\p  
\v 14 Jesús tí Xje̱en Dios mé tí ncha̱tꞌá tjetoan kuènténi mé kꞌuíxenhen tí tjen Dios la méxra̱ chrókuíto̱ehyani tí tinkáchónkini tí jehe chꞌán.  
\v 15 Méxra̱ jehe chꞌán mé tí ncha̱tꞌá tjetoan kuènténi mé tsjinki̱tsa chꞌán tí jeheni kíxin fuérte̱hyani kíxin kja̱xin tí Jínahya chrókjuachroe tí jehe chꞌán éxí sítónhen tí jeheni, kjánchó jehe chꞌán la ninkehó jie̱ kjuasinhya chꞌán kjónté xi̱kaha kónhen chꞌán.  
\v 16 Méxra̱ kaín a̱sénni chrókóchjineheni Dios tí tjen chꞌán tꞌe̱to̱an chꞌán kíxin chrókui̱konóe̱he̱ni chꞌán la ko chrókjuinki̱tsa chꞌán tí jeheni tí nkehe chrókꞌuichjánxi̱nhinni. 
\c 5  
\p  
\v 1 Kaín ncha̱tꞌá tꞌe̱to̱an tsíkónoxín la chojni ó, tsíkꞌáyéhe̱ xra̱ tsonixayákonhe̱n chojni nkayakon Dios, la ko tsjanjon nkehe la ko iko itsꞌen kíxin tsꞌitjáyanxín tí jie̱ kuènte chojni.  
\v 2 Kja̱xin tí ncha̱tꞌá a la fuérte̱hya kíxin chojni ó, a̱ ntá chrókóninkakuenhya chꞌán tí sín noehya la ko tí sín tsíkjichroe.  
\v 3 Kja̱xin jehe chꞌán, kíxin fuérte̱hya chꞌán tꞌichjánxi̱n tsjanjon chꞌán iko itsꞌen kíxin tí jie̱ chónta chꞌán jehe chꞌán éxí tjanjon chꞌán nkehe kuènte tí í so chojni chónta jie̱. 
\p  
\v 4 Ninkexró xitjahya jehó sichꞌéna a̱sén ncha̱tꞌá tꞌe̱to̱an. Náhí. Jehó tí sín tsíkjeyá Dios tsíkꞌáyéhe̱ tí xra̱ éxí tsíkꞌáyéhe̱ chꞌín Aarón.  
\v 5 Mé xi̱kaha Cristo, kjuíchꞌénahya chꞌán jehó chꞌán a̱sén chꞌán ncha̱tꞌá tꞌe̱to̱an. Náhí. Dios mé kjuikosáyehe chꞌán mé tsíkjanjon tí xra̱ éxí tsíntáchro kíxin: 
\q1 Jaha mé xja̱nna; 
\q1 Janhan mé kjui̱tꞌána ijie.\f + \fr 5:5 \ft Salmo 2.7\f* 
\m  
\v 6 Kja̱xin í jnko nketí nixja xroon itén Dios ntáchro kíxin: 
\q1 Jaha mé ijnko ncha̱tꞌá tsjakꞌe jnkochríxín, 
\q1 éxí yóhe̱ kꞌuékjakꞌe chꞌín Melquisedec.\f + \fr 5:6 \ft Salmo 110.4\f* 
\m  
\v 7 Tió kjuákꞌe Cristo ntihi chjasintajni imá tsjánka chꞌán la ko itsen chrónóe̱he̱ chꞌán Dios, kíxin Dios chónta kjuachaxin chrókjuinchekaá chꞌán kíxin chrókꞌuenhya chꞌán; la Dios la kuínhin kíxin xi̱kaha kuítekaon chꞌán.  
\v 8 Méxra̱ Cristo, kjónté Xje̱en Dios, la kuítekaon chꞌán kjuínchexiteyá chꞌán kjónté tí kjuasote chꞌán.  
\v 9 Mé kjuínchexiteyá chꞌán, ntá kjuacha chꞌán kꞌóna chꞌán tí nkexro sinchekaá jnkochríxín kaín tí chojni sinchexiteyéhe̱ tí jehe chꞌán.  
\v 10 A̱ ntá Dios mé tsíkjichꞌéna chꞌán ncha̱tꞌá tꞌe̱to̱an éxí yóhe̱ kjuákꞌe chꞌín Melquisedec. 
\s1 Jehya jína chrókuíto̱heni tí tinkáchónkini Ìnchéni 
\p  
\v 11 Chóntani nchónhya nkehe chróchrónkani kuènte tíha, kjánchó imá xra̱ chróchrónkaxínni tíha kíxin tiénxinhyará jahará.  
\v 12 Ntá kꞌuátsínka nchónhya tiempo, a̱ ntá ó jína chrókꞌónará maestro, ntá náhí kíxin na̱xa̱ tꞌichjánxi̱nhanrá nkexro chrókjua̱ko̱ha̱rá ínaá tí nkehe xra̱hya kuènte itén Dios. Éxí xíkꞌónará lo̱nti̱rá, tꞌichjánxi̱n chrókꞌuirá tsjen ínaá kíxin xitjahya sinterá nkehe cha.  
\v 13 A̱ ntá tí sín itꞌi tsjen ó, na mé yóhe̱ chánjan takí tsjachahya sín tsjeyá sín nkexrí chrókꞌuejó sín jína.  
\v 14 Á ntá tí nkehe cha mé ine tí chojni nte̱to kíxin ó nohe sín ti nkehe jína la ko tí nkehe jínahya. 
\c 6  
\p  
\v 1 Na̱xa̱ chrókjueyáni kíxin jína chrókjuenka̱yáxinni éxí chojni nte̱to. Chróchenkahyani tí jahará ijie tí nkehe kánhyó xra̱ tsíxrakohará tí xrankíxixín kuènte Cristo. Náhí. Tꞌichjánxi̱nhya na̱xa̱ chrókjua̱ko̱ha̱ráni kíxin chrókui̱to̱hérá tí jie̱ kꞌuékjásinrá chrókꞌuénxinrá, la ko nkexrí chrókuinkachónkirá Dios,  
\v 2 la ko nkexrí chrókuikite chojni, la ko nkexrí tsꞌejotja tjárá chrítaón tí sín tinkáchónki Cristo, la ko nkexrí tsoxechón chojni tsíkꞌen, la ko nkexrí chrókuito̱exín iji̱é chojni.  
\v 3 A̱ ntá tí Dios chrókjuanjon kjuachaxin la chrókjuakoni í so nkehe. 
\p  
\v 4 A̱ ntá tí sín ó tsíkꞌáyéhe̱ sín tí xrohi, la ko ó tsjexín sín tí nkehe kjuanjon Dios, la ko tsíkꞌáyéhe̱ sín tí Ncha̱kuen Dios,  
\v 5 la ko kóxrjínhi̱n sín tí nkehe jína kuènte itén Dios, la ko kónohe sín nkexrí tí kjuachaxin tsochónta tí chjasintajni chrꞌéxi̱n,  
\v 6 a̱ ntá tí chrókuíto̱he sín Dios, í chrókuinkáchónkihya sín, ntá xitjahya tsokjan sín ínaá, kíxin tí xi̱kaha la éxí chrókjua̱kꞌe̱nka̱ni sín ntacruz tí Xje̱en Dios ínaá la ko chrókjuanoá sín chꞌán nkayakon nchónhya chojni.  
\v 7 Éxí nonte jnkojnko vez tꞌaniá chrin la tsjátan la tsꞌóna jína, a̱ ntá kjuacha tí sín kjuíchꞌe xra̱ kíxin Dios kjuíncheyaon ntiha.  
\v 8 A̱ ntá tí tꞌóna ntachꞌi̱ la ko kachꞌi̱ la ninkehó sínkíhya la tso̱nínkakonhen Dios, la tí tsjixixín mé tsoche. 
\s1 Tí nkehe tjejóchónhenni mé tjinki̱tsa kíxin jína tsꞌejóni 
\p  
\v 9 Kjónté nixjani xi̱kaha, kíchó ni, ó noheni kíxin chaxín jína tjejorá kꞌuitjará tí nti̱a tsaáxinrá.  
\v 10 Kíxin Dios la jína, la tsꞌitjáyenhya chꞌán tí xra̱ jína tjejochꞌerá kíxin tjuèherá kíchuárá, mé xi̱kaha kjuáko̱xi̱nrá kíxin kjuínki̱tsará tí kíchuárá tinkáchónki Cristo la na̱xa̱ tjejótjinki̱tsará sín xi̱kaha.  
\v 11 Tjinkaonni kíxin jnkojnkorá chrókjuáko̱xi̱nrá hasta tsjixixín kíxin chontará kjuachéhe̱ chrókjuínki̱tsará kíchuárá kíxin chaxín tsꞌayéhérá tí nkehe tjejochonhénrá.  
\v 12 Tjinkakonhyani kíxin chrókjanrá chrókósáhará. Náhí. Tjinkaonni kíxin chrókjuáko̱xi̱nrá éxí tí sín chaxín tinkáchónki Ìnchéni tjejóchónhen sín tsꞌáyéhe̱ sín tí nkehe tsíntáchro Dios kíxin tsjanjon chꞌán. 
\p  
\v 13 A̱ ntá Dios, tió tsíntáchro chꞌán kíxin tsjanjon chꞌán nkehe tsꞌáyéhe̱ tí chꞌín Abraham la jehó Dios kꞌuákjenxi̱n a̱sén kíxin kohya nkexro a̱ntsí tjetoan chrókꞌuákjenxi̱n chꞌán.  
\v 14 Ntáchro chꞌán kíxin chaxín sincheyaon chꞌán tí chꞌín Abraham la ko nchónhya chojni tsꞌaxrjeníxin tí jehe chꞌán.\f + \fr 6:14 \ft Génesis 22.16-17\f* 
\v 15 Chꞌín Abraham kjuákꞌechónhen chꞌán isé kíxin tsꞌáyéhe̱ chꞌán tí nkehe tsíntáchro Dios.  
\v 16 A̱ ntá tió tꞌákjenxi̱n chojni ijnko nkexro la mé tꞌákjenxi̱n sín ijnko nkexro a̱ntsí tjetoan, a̱ ntá jehó sín la náhí. A̱ ntá tsꞌákjenxi̱n sín tí xi̱kaha kíxin ijnko nkehe tsoxiteyá, a̱ ntá kohya nkexro tsontáchro ninkehó.  
\v 17 Méxra̱ Dios kꞌuákjenxi̱n chꞌán a̱sén chꞌán tsíntáchro chꞌán kíxin chaxín tsoxiteyá, kíxin tjinkaon chꞌán chrókjua̱ko̱xi̱n chꞌán noxín kíxin chrókónohe tí sín tsꞌáyéhe̱ tí nkehe tsjanjon chꞌán kíxin sinchexiteyá chꞌán tí nkehe tsíntáchro chꞌán la í tsjitóxi̱enhya chꞌán ninkehó tíha.  
\v 18 Mé xi̱kaha siín yaá nkehe xitjahya tsꞌixitóxi̱n, kíxin Dios la xitjahya sichꞌia; kíxin tíha Dios nchenoexínni kíxin chaxín tsoxiteyá, la mé jeheni kjuancheheni chꞌán kíxin chrókꞌuayakonhenni chꞌán la ko tjejóchónhenni tí nkehe tsjanjon chꞌán.  
\v 19 Tí tjejóchónhenni xi̱kaha la jína tsꞌejó a̱sénni éxí yóhe̱ tí ntabárco̱ chónta gancho tjechruéxin kíxin kohya nketí sátsji. Méxra̱ xi̱kaha kja̱xin tí nkehe tjejóchónhenni la sátsíkji̱ hasta nóton tí ka cortina tjen nkaxenhen ni̱nko tjen nkaya nka̱jní,  
\v 20 tí senó kꞌuíxenhen Jesús kuakitje̱he̱ chꞌán ijnko nti̱a tsꞌixenxínni. Mé xi̱kaha jehe chꞌán kꞌóna chꞌán ncha̱tꞌá tꞌe̱to̱an jnkochríxín éxí yóhe̱ kjuákꞌe tí chꞌín Melquisedec. 
\c 7  
\s1 Chꞌín Jesús mé ncha̱tꞌá éxí yóhe̱ kꞌuékjakꞌe chꞌín Melquisedec 
\p  
\v 1 Tí chꞌín Melquisedec mé kꞌué rey kuènte chjasin Salem la ko ncha̱tꞌá kuènte Dios tjen nkaya nka̱jní. A̱ ntá tió chꞌín Abraham kja̱nxi̱n chꞌán tí tsíkjikjanjo̱nko chꞌán tí í so sín rey, kjuacha chꞌán, ntá chꞌín Melquisedec kjuíxinhin chꞌán nti̱a ikui chꞌín Abraham, ntá jehe chꞌín Melquisedec kjuíncheyaon chꞌán tí chꞌín Abraham.  
\v 2 A̱ ntá tí chꞌín Abraham chjéhe chꞌán tí chꞌín Melquisedec diezmo kaín xín nkehe tsíkjacha chꞌán tí tsíkjikjanjo̱nko chꞌán tí sín rey.\f + \fr 7:2 \ft 7.1-2 Génesis 14.17-20\f* A̱ ntá ihni̱é chꞌín Melquisedec mé tꞌaxrjexín sa̱oxín kíxin “ijnko rey jína”; a̱ ntá jehe chꞌán kꞌué rey kuènte chjasin Salem, tíha mé tꞌaxrjexín kíxin “kjuaxróxin”, la mé xi̱kaha jehe chꞌán mé “ijnko rey tjanjon kjuaxróxin”.  
\v 3 A̱ ntá chꞌín Melquisedec la noehya sín nkexro itꞌé chꞌán la ko nkexro ìné chꞌán la ko nkexro tsíkꞌaxrjeníxin chꞌán; la ko noehya sin nkesá tsíkokjíhi chꞌán la ko nkesá tsíkꞌen chꞌán. Mé xi̱kaha tóyóhe̱ tí Xje̱en Dios kíxin jehe chꞌán mé ijnko ncha̱tꞌá jnkochríxín. 
\p  
\v 4 A̱ ntá jie, tsjehérá kíxin imá tꞌe̱to̱an tí chꞌín Melquisedec kíxin tí chꞌín Abraham kꞌuaxrjeníxinni, la tsíchjéhe chꞌán tí chꞌín Melquisedec diezmo tí nkehe tsíkjacha chꞌán tí tsíkjanjo̱nko chꞌan tí sín rey.  
\v 5 Éxí nixja ley tsíkꞌe̱to̱an chꞌín Moisés, kíxin tí sín ncha̱tꞌá tsíkꞌaxrjeníxin tí chꞌín Leví chónta sín kjuachaxin tsjanchehe sín kaín xín chojni diezmo kjónté na̱xa̱ kjéhya sín, tsíkꞌaxrjeníxin sín tí chꞌín Abraham éxí tí jehe sín.  
\v 6 A̱ ntá chꞌín Melquisedec, kjónté tsíkꞌaxrjeníxinhya chꞌán tí chꞌín Leví, na mé kjuíchꞌehe chꞌán cobra tí chꞌín Abraham, mé tí chꞌín tsíkꞌáyéhe̱ tí nkehe tsíntáchro Dios. Mé xi̱kaha tí chꞌín Melquisedec tsíkjincheyaon chꞌán tí chꞌín Abraham.  
\v 7 Kohya nkexro tsontáchro kíxin chaxínhya kíxin tí nkexro ncheyaon la a̱ntsí má tꞌe̱to̱an, a̱ ntá tí nkexro tsíkóyaon la tꞌe̱to̱anhya. Náhí.  
\v 8 A̱ ntá tí tjejóni, tí sín tꞌáyéhe̱ tí diezmo la mé chojni tsꞌen ó. Kjánchó ntáchro tí xroon itén Dios kíxin tí chꞌín Melquisedec mé ijnko chojni na̱xa̱ tsíkꞌenhya, la na̱xa̱ tjechón.  
\v 9 Mé tꞌaxrjexín kíxin chꞌín Leví la ko kaín xín tí sín ncha̱tꞌá tsíkꞌaxrjeníxin chꞌán, mé tí sín tꞌáyéhe̱ sín diezmo jie, la mé kja̱xin jehe sín tsíkje̱nke̱he sin diezmo tí chꞌín Melquisedec tió tsíkje̱nka̱ chꞌín Abraham,  
\v 10 kíxin na̱xa̱ tjiko cuerpo kuènte chꞌán tí sín tsꞌaxrjeníxin chꞌán, na̱xa̱ kokjíehya sín tió xeta chꞌán tí chꞌín Melquisedec. 
\p  
\v 11 Tí sín nación Israel tsíkꞌáyéhe̱ sín tí ley kíxin tí sín ncha̱tꞌá levita, mé tsíkꞌaxrjeníxin sín tí chꞌín Aarón. A̱ ntá jie tí chaxín chrókjuacha sín chrókjuentoá sín tí sín tinkáchónki tí ley, la í tꞌichjánxi̱nhya na̱xa̱ chrókónoxín í jnko ncha̱tꞌá í chrókóyóe̱hya éxí tí chꞌín Aarón. A̱ ntá kjuachahya sín xi̱kaha ntá tꞌichjánxi̱n chrókónoxín ijnko ncha̱tꞌá chrókóyóhe̱ éxí tí chꞌín Melquisedec.  
\v 12 A̱ ntá tí chrókꞌuixinkí tí ncha̱tꞌá la kja̱xin chrókꞌuixinkí tí ley.  
\v 13 A̱ ntá tí xroon itén Dios chrónka tíhi kuènte Ìnchéni. A̱ ntá jehe chꞌán la tsíkꞌaxrjeníxin chꞌán í jnko nkexro kuènte Israel la kohya ninkexró tsíkꞌóna ncha̱tꞌá tsíkꞌaxrjeníxin tí sín a.  
\v 14 Kíxin ó noxín kíxin Ìnchéni tsíkꞌaxrjeníxin chꞌán tí chꞌín Judá, a̱ ntá chꞌín Moisés la chrónkahya chꞌán ninkehó kuènte tí sín tsꞌaxrjeníxin tí chꞌín a tió nixja chꞌán kuènte tí sín ncha̱tꞌá. 
\p  
\v 15 A̱ ntá tíhi la a̱ntsí má kónoxín kíxin tí ncha̱tꞌá ni̱xin la tóyóhe̱ éxí chꞌín Melquisedec  
\v 16 kíxin tió kꞌóna chꞌán ncha̱tꞌá la jehya kíxin xi̱kaha chrókꞌue̱to̱an ijnko ley kíxin nkexro chrókꞌuaxrjeníxin chꞌán. Náhí. Ó jehí kꞌóna chꞌán ncha̱tꞌá kíxin tí kjuachaxin chónta chꞌán la xitjahya tsꞌitjáyan.  
\v 17 Kíxin nixja Dios kíxin nkexrí tjen tí jehe chꞌán, ntáchro kíxin: 
\q1 Jaha mé ijnko ncha̱tꞌá tsjakꞌe jnkochríxín, 
\q1 éxí yóhe̱ kꞌuékjakꞌe chꞌín Melquisedec.\f + \fr 7:17 \ft Salmo 110.4\f* 
\m  
\v 18 Méxra̱ tí nkehe kꞌuékꞌe̱to̱an senó mé chꞌehya xra̱ jie kíxin kánhyó kjuachaxin kꞌuéchónta la ko kjuachahya,  
\v 19 kíxin tí nkehe kꞌue̱to̱an chꞌín Moisés kjuachahya kjuínchetjóá ninkehó nkehe. A̱ ntá jie chóntani ijnko nkehe a̱ntsi jína tjejóchónhenni kíxin tíha mé a̱ntsí jína tso̱chjinexínni Dios. 
\p  
\v 20 A̱ ntá tió ntáchro Dios tíha la tsíkꞌákjenxi̱n chꞌán a̱sén chꞌán jehó chꞌán.  
\v 21 La ntá tí í so ncha̱tꞌá, tió tsíkónoxín sín, tsíkꞌákjenxi̱nhya Dios a̱sén chꞌán. A̱ ntá tió tsíkónoxín tí ncha̱tꞌá i la Dios tsíkꞌákjenxi̱n chꞌán a̱sén chꞌán. A̱ ntá ntáchro xroon itén Dios kíxin: 
\q1 Ìnchéni tsíkꞌákjenxi̱n a̱sén chꞌán 
\q1 a̱ ntá tsꞌixitóxi̱nhya tí nkehe tsíntáchro chꞌán: 
\q1 “Jaha mé ijnko ncha̱tꞌá tsjakꞌe jnkochríxín 
\q1 éxí yóhe̱ kꞌuékjakꞌe chꞌín Melquisedec.”\f + \fr 7:21 \ft Salmo 110.4\f* 
\m  
\v 22 Méxra̱ chꞌín Jesús ntáchro kíxin tí pacto tꞌe̱to̱an chꞌán la a̱ntsí má jína, a̱ ntá tí pacto senó la náhí.  
\v 23 Ntá kꞌuíxin nchónhya sín ncha̱tꞌá, kjánchó nkákꞌen sín, ntá xitjahya na̱xa̱ chrókjuichꞌe sín tí xra̱ a.  
\v 24 A̱ ntá chꞌín Jesús la tsꞌenhya chꞌán la tꞌichjánxi̱nhya kíxin í jnko nkexro chrókuakja tí xra̱ kuènte chꞌán chrókꞌóna ncha̱tꞌá.  
\v 25 Méxra̱ jehe chꞌán tsjacha sinchekaá chꞌán jnkochríxín tí sín tso̱chjinehe Dios kíxin tinkáchónki sín tí jehe chꞌán kíxin itjen chꞌán jnkochríxín chrónóe̱he̱ chꞌán Dios kíxin chrókjuinchekaáni chꞌán. 
\p  
\v 26 Mé xi̱kaha Jesús mé tí ncha̱tꞌá tꞌe̱to̱an tꞌichjánxi̱nhinni; jehe chꞌán mé ijnko nkexro tjóá, chóntahya ninkehó jie̱, la ko tjenkákjanhya chꞌán tí sín tjasin jie̱, a̱ ntá sákjui̱ chꞌán nkaya nka̱jní.  
\v 27 Ntá tóyóe̱hya tí í so ncha̱tꞌá tꞌe̱to̱an, kíxin tꞌichjánxi̱n tsꞌóyán sín iko tsjanjon sín tsochjéhe sín Dios kaín ya̱on, sa̱oxín kíxin tí jie̱ kuènte sín, a̱ ntá chrꞌéxi̱n kíxin tí jie̱ chónta tí í so chojni. A̱ ntá chꞌín Jesús jnkoko̱axón vez kjuanjon a̱sén chꞌán ikꞌuén chꞌán.  
\v 28 Tí ley kꞌuékꞌe̱to̱an chꞌín Moisés tꞌe̱to̱an kíxin chojni na̱xa̱ chónta jie̱ chrókꞌóna ncha̱tꞌá, a̱ ntá Dios tsíkꞌákjenxi̱n a̱sén chꞌán tió kjuixin kꞌóna tí ley, ntáchro chꞌán kíxin tí Xje̱en chꞌán mé tsꞌóna ncha̱tꞌá tꞌe̱to̱an kíxin jína kjuínchexiteyá chꞌán jnkochríxín. 
\c 8  
\s1 Chꞌín Jesús nixja̱xi̱n chꞌán ijnko pacto ni̱xin 
\p  
\v 1 Tí nkehe a̱ntsí má tjetoan chrónkani la mé tíhi kíxin tí ncha̱tꞌá kuènteni mé tꞌe̱to̱an chꞌán, la ko tjetja̱xi̱n chꞌán nkaya nka̱jní, nó chjina tí trono tꞌe̱to̱anxín Dios,  
\v 2 kꞌóna chꞌán ncha̱tꞌá tí ni̱nko chaxín tsíkjichꞌéna Ìnchéni, la jehya chojni tsíkjichꞌéna tíha.  
\v 3 Kaín ncha̱tꞌá tꞌe̱to̱an tsíkꞌáyéhe̱ xra̱ kíxin tsjanjon nkehe la ko iko itsꞌen. Méxra̱ Jesucristo tꞌichjánxi̱n kíxin tsjanjon chꞌán ichrén nkehe.  
\v 4 Tí chrókjuakꞌe chꞌán chjasintajni, chrókꞌónahya chꞌán ncha̱tꞌá kíxin na̱xa̱ siín ncha̱tꞌá tjanjon nkehe kꞌue̱to̱an tí ley tsíkꞌáyéhe̱ chꞌín Moisés.  
\v 5 A̱ ntá tí sín ncha̱tꞌá kꞌuékjanjon nkehe tóyóhó tí nkehe siín nkaya nka̱jní. Noheni kíxin tóyóhó kíxin tió chꞌín Moisés chrókjuichꞌéna chꞌán ni̱nko la ntáche Dios tí jehe chꞌán kíxin: “Tjenka̱yáxian jína, a̱ ntá si̱chꞌéna jaha éxí tí nkehe kjuákuáxian chrítaón jna̱.”\f + \fr 8:5 \ft Éxodo 25.40\f* 
\v 6 A̱ ntá tí ncha̱tꞌá tꞌe̱to̱an kuènteni tjechꞌe chꞌán xra̱ a̱ntsí jína kíxin jehe chꞌán mé tí nkexro nixja̱xi̱n tí pacto ni̱xin tsíntáchro Dios chrónka tí nkehe jína tso̱nhen chrꞌéxi̱n. 
\p  
\v 7 A̱ ntá tí pacto tsíkꞌe̱to̱an sa̱oxín la tí chróxiteyá jína, la tꞌichjánxi̱nhya chrókꞌóna yóxin pacto.  
\v 8 A̱ ntá Dios kꞌuíkon kíxin kjuínchexiteyáhya tí sín a, éxí ntáchro xroon itén Dios kíxin: 
\q1 Ntáchro Ìnchéni kíxin: Itsi ijnko ya̱on 
\q1 mé tsjánjuan ijnko pacto ni̱xin tsochónta tí sín nación Israel la ko tí sín chjasin Judá. 
\q1  
\v 9 Jehya xi̱kaha tí pacto kuétua̱nha̱n tí sín tsíkꞌaxrjeníxinrá ósé, 
\q1 tí ya̱on kjuínki̱tsa sín kꞌuaxrjexín sín tí nación Egipto; 
\q1 kjánchó kjuínchexiteyáhya sín tí pacto kuétua̱nha̱n sín, 
\q1 méxra̱ kui̱to̱ha̱ sín, ichro Ìnchéni. 
\q1  
\v 10 Tí pacto tsétua̱nha̱n tí sín chjasin Israel tió tsꞌatsínka tí ya̱on a, mé xi̱kaha tíhi, ichro Ìnchéni: 
\q1 Si̱ntaxráxinka̱van a̱sén sín tí ley tséto̱an, 
\q1 a̱ ntá tí kjuaxrexinkaon kuènte sín tsokjian tí nkehe tsétua̱nha̱n sín. 
\q1 A̱ ntá janhan tsꞌóna Dios kuènte sín, 
\q1 a̱ ntá jehe sín mé tsꞌóna chjasin kuènta̱na. 
\q1  
\v 11 Tsꞌichjánxi̱nhya na̱xa̱ tsja̱ko̱he̱ kíchó sín 
\q1 kíxin chróchóxin sín Ìnchéni, 
\q1 kíxin kaín sín tsochóxinna sín, 
\q1 kjónté chojni imá ntsíntsí la ko chojni imá hyé. 
\q1  
\v 12 Si̱ntakꞌitjáyan tí nkehe jínahya kjuíchꞌe sín 
\q1 la ko í tsoxráxinka̱konhya ínaá tí jie̱ chónta sín.\f + \fr 8:12 \ft 8.8–12 Jeremías 31.31–34\f* 
\m  
\v 13 Xi̱kaha nixja Dios kuènte tí pacto ni̱xin tsꞌe̱to̱an chꞌán kíxin tsíkóntaxin tí pacto sa̱oxín kꞌue̱to̱an chꞌán, tíha mé tinkákóntaxin la ko tinkákjeje̱, na í séhya tsꞌitjáyan. 
\c 9  
\s1 Tí ni̱nko chjasintajni la ko tí ni̱nko nkaya nka̱jní 
\p  
\v 1 A̱ ntá tí pacto sa̱oxín tꞌe̱to̱an nkexrí chróxraxinkaonni Dios, kíxin tí ni̱nko ntihyó chjasintajni.  
\v 2 A̱ ntá tí ni̱nko kꞌuékjakꞌe mé tí cuarto sa̱oxín kꞌuekjinchekꞌin sín tí Cuarto Tjóá, tí kjuákꞌe tí candelero la ko tí mesa tjejókjen tí nio̱tja̱ kꞌuéxraxinkakonxín sín Dios.  
\v 3 Nóton tí yóxin ka cortina kjuákꞌe tí cuarto kꞌuékjinchekꞌin sín tí Cuarto A̱ntsí Tjóá.  
\v 4 Ntiha kꞌuékjakꞌe tí altar tsíkꞌóna chica oro kꞌuékjakaxín sín tí chji̱nco̱ la ko kꞌuékjakꞌe tí ntacajón chrꞌísimá chica oro tjenkáya tí pacto. Nkaxenhen tí ntacajón kꞌuékjakꞌe ijnko nchésen tsíkꞌóna chica oro kꞌuékꞌinka maná kꞌóna nio̱tja̱, la ko kja̱xin kꞌuékjakꞌe tí nta kꞌuékjixín chꞌín Aarón kjuankíxin kꞌuayan nta ntahnte̱, la ko kja̱xin ntiha kjuákꞌe tí xro̱ chónta tí tan kꞌue̱to̱an Dios.  
\v 5 Chrítaón tí ntacajón kꞌuékꞌejó yaá ángel tsíkjano̱ya tsíkjentoá ka̱ne̱ne̱e chrítaón tí kjuákꞌe tí kjuachaxin kuènte Dios; ntaha kꞌuékjìinxín tí jie̱ kꞌuéchónta chojni. A̱ ntá ijie la tꞌichjánxi̱nhya na̱xa̱ tsonixjani kuènte tíha. 
\p  
\v 6 A̱ ntá xi̱kaha kꞌuéjó tí nkehe a, a̱ ntá tí sín ncha̱tꞌá jnkoya̱xón tꞌixenhen sín tí cuarto sa̱oxín kuènte ni̱nko kíxin tí xra̱ chꞌe sín kuènte ni̱nko.  
\v 7 A̱ ntá tí yóxin cuarto jehó tí ncha̱tꞌá tꞌe̱to̱an tꞌixenhen chꞌán jnkoko̱á vez jnkojnko nánó; a̱ ntá tí tꞌixenhen chꞌán tꞌichjánxi̱n tsꞌixenko chꞌán ijni̱é iko tsochjéhe chꞌán Dios tso̱tjuáxin iji̱é chꞌán la ko iji̱é tí i so chojni.  
\v 8 A̱ ntá tí Ncha̱kuen Dios nchenoexínni tíhi kíxin nachrohe kꞌuékjichꞌe xra̱ tí cuarto sa̱oxín la na̱xa̱ tjexrankehya kíxin chrókꞌuixenhenni tí Cuarto A̱ntsí Tjóá.  
\v 9 Kaín tíha tja̱ko̱xi̱n ijnko nkehe chrókónoheni jie, kjánchó tí nkehe chjéhe sín Dios la ko tí ko tꞌóyán sín xitjahya nchenoexín sín kíxin á chaxín kótjóá tí jie̱ kꞌuéchónta sín kíxin xi̱kaha kꞌuéxraxinkaon sín Dios.  
\v 10 A̱ ntá tíha jehó tꞌe̱to̱an kuènte tí nkehe chrókjóne sín la ko tí nkehe chrókꞌui sín la ko tí chrókꞌónti sín kíxin chrókótjuáxin iji̱é sín, kaín tíha mé kꞌuítuenhen sín kuènte cuerpo ó la jehó kꞌuéchónta kjuachaxin tí na̱xa̱ kjuinkíhya Dios nkexrí chróxraxinkaon sín chꞌán. 
\p  
\v 11 A̱ ntá ó kui Cristo, jehe chꞌán mé ncha̱tꞌá tꞌe̱to̱an kuènte tí nkehe a̱ntsí jína itsi. A̱ ntá tí ni̱nko chꞌe chꞌán xra̱ la a̱ntsí jína la ko a̱ntsí ntoá, la jehya chojni tsíkjichꞌéna tíha kíxin jehya chjasintajni ntihi tjen.  
\v 12 Tió kꞌuíxenhen Cristo tí Cuarto Tjóá, la jehya kíxin chrókjuanjon chꞌán ijni̱é kotèntso̱ la ko ijni̱é koxintáxjan. Náhí. Ijni̱é chꞌán kjuanjon chꞌán; mé xi̱kaha kꞌuíxenhen chꞌán jnkoko̱á vez ntiha mé xi̱kaha kjue̱nka̱ chꞌán kíxin chrókuaáxinni jnkochríxín.  
\v 13 A̱ ntá tí ijni̱é koxinta la ko ijni̱é kotèntso̱ la ko tí nteso kuènte tí koxintáxjan tsíchexín tí altar tikitexín tí sín tjuáhya la mé tíha chónta kjuachaxin tso̱tjuáxin tí chrítaón ó.  
\v 14 A̱ ntá tí xi̱kaha, la kjá a̱ntsí má chónta kjuachaxin tí ijni̱é Cristo. Kíxin tí kjuachaxin Ncha̱kuen Dios tjen jnkochríxín, la Cristo kjuanjon a̱sén chꞌán ikꞌuén chꞌán kꞌuáyéhe̱ Dios, la jehe chꞌán la ninkehó jie̱ chóntahya chꞌán. A̱ ntá ijni̱é chꞌán nchetjóá tí nkehe kjuíchꞌeni senó chrókꞌuenxínni kíxin ntá jie la jína chrókjuichꞌeheni xra̱ Dios tjechón. 
\p  
\v 15 Méxra̱ Jesucristo nixja̱xi̱n chꞌán tí pacto ni̱xin kꞌue̱to̱an Dios. Kíxin kꞌuenyákonhe̱nni Cristo ntá tso̱tjuáxin tí jie̱ kjuasinni kjuínchexiteyáhyani tí pacto kꞌuítuenhenni senó; kíxin tí sín kꞌuíye̱he̱ Dios la jína chrókꞌuáyéhe̱ sín tí nkehe tsjeje̱hya kíxin jehe chꞌán xi̱kaha tsíntáchro chꞌán tsjanjon chꞌán.  
\v 16 A̱ ntá tí siín ijnko nkehe tsíntáchro ijnko chojni kjuákꞌe na ntá ikꞌuén la tꞌichjánxi̱n tso̱noxín kíxin chaxín tsíkꞌen tí nkexro tsíkjichꞌéna.  
\v 17 A̱ ntá tí nkehe tsíntáchro chꞌán la sínkíhya tí na̱xa̱ tjechón tí nkexro tsíkjichꞌéna; jehó tió chrókꞌuen chꞌán mé sínkí.  
\v 18 Méxra̱ tí pacto xrankíxixín tsíkꞌe̱to̱an Dios kjuankíxin kjuíchꞌe xra̱ kíxin kꞌuítji ijni̱.  
\v 19 Chꞌín Moisés tsíchrónka chꞌán kaín nkehe tsíkꞌe̱to̱an tí ley kuínhin kaín tí chojni; a̱ ntá chrꞌéxi̱n kuákja chꞌán ichjo̱én kolélo kjátse la koí ntarama hisopo, ntá kjuínchekjatjaxín chꞌán ijni̱é koxintáxjan la ko ijni̱é kotèntso̱ tsíkjiko ìnta̱, ntá kui̱kja̱nji̱n chꞌán tí libro chónta ley la ko kui̱kja̱nji̱n chꞌán kain tí chojni.  
\v 20 A̱ ntá ntáchro chꞌán kíxin: “Tí jni̱ i tsoxiteyáxin tí pacto kꞌue̱to̱an Dios chrókjuinchexiteyéhérá jahará.”\f + \fr 9:20 \ft 9.19–20 Éxodo 24.6–8\f* 
\v 21 Tí chꞌín Moisés kja̱xin kui̱kja̱nji̱n chꞌán jni̱ tí ni̱nko la ko kaín nkehe tꞌichjánxi̱n tí nkaxenhen ni̱nko.  
\v 22 Kíxin xi̱kaha ntáchro tí ley kíxin kaín nkehe la chrókótjuáxin tí jni̱; a̱ ntá xitjahya chrókótjóá tí jie̱ tí chrókꞌuixikja̱nji̱nhya jni̱. 
\s1 Tí ikꞌuén Cristo mé tsjìinxín iji̱éni 
\p  
\v 23 Méxra̱ tꞌichjánxi̱n kíxin ikꞌuén iko kótjuáxin tí nkehe a, táha mé tóyóhó tí nkehe siín nkaya nka̱jní; a̱ ntá tí nkehe chaxín kuènte nkaya nka̱jní tꞌichjánxi̱n ijnko nkehe a̱ntsí jína chrókꞌuen.  
\v 24 A̱ ntá Cristo kꞌuíxenhya tí ni̱nko tsíkjichꞌénaxín chojni tja, táha mé ijnko nkehe tóyóhó tí ni̱nko chaxín. Náhí. Jehe chꞌán mé kꞌuíxenhen chꞌán tí nkaya nka̱jní, a̱ ntá jie mé tjen chꞌán tí tjen Dios nixja̱xi̱n chꞌán kaín ni.  
\v 25 A̱ ntá jehe chꞌán la jehya jnkoya̱xón kꞌuíxenhen chꞌán ntiha kꞌuenyákonhe̱nni chꞌán. Náhí. A̱ ntá tí ncha̱tꞌá tꞌe̱to̱an tꞌixenhen tí Cuarto Tjóá jnkojnko nánó kíxin tsjanjon chꞌán ijni̱é ko ó.  
\v 26 A̱ ntá tí xi̱kaha chrókónhen Cristo la tꞌichjánxi̱n kíxin jnkoya̱xón chrókꞌóyán sín chꞌán desde tí kꞌóna tí chjasintajni. A̱ ntá jie la ó chjina, tsjixraká tsjeje̱ chjasintajni, a̱ ntá kónoxín Cristo la ikꞌuén chꞌán jnkoko̱á vez kíxin tsjìinxín iji̱éni.  
\v 27 Mé xi̱kaha kaín ni itsꞌenni jnkoko̱á vez, a̱ ntá chrꞌéxi̱n tsito̱exín iji̱éni.  
\v 28 Mé xi̱kaha kja̱xin Cristo jnkoko̱á vez ikꞌuén chꞌán kíxin tsjìinxín iji̱é nchónhya chojni. A̱ ntá chrꞌéxi̱n itsi chꞌán ínaá, jehya kíxin na̱xa̱ tsja̱tse̱n chꞌán iji̱é chojni. Náhí. Sinchekaá chꞌán tí chojni ó tsíkótjóá tjejóchónhen itsi chꞌán. 
\c 10  
\p  
\v 1 A̱ ntá tí ley kꞌue̱to̱anxín chꞌín Moisés la tóyóhó tí nkehe jína tsi la jehya tí nkehe chrókuaáxinni. Méxra̱ tí ley kjuachahya kjuínchetjóá tí sín kóchjinehe Dios kjuanjon sín iko itsꞌen jnkojnko nánó.  
\v 2 A̱ ntá tí chrókjuacha tí ley chrókjuinchetjóá iji̱é sín, ntá chrókjuenka̱yáxinhya sín kíxin na̱xa̱ chróchónta sín jie̱, la chrókuíto̱he sín, í chrókjuanjonhya sín iko itsꞌen.  
\v 3 A̱ ntá xi̱kaha ichꞌe sín tꞌóyán sín ko, la jnkojnko nánó xraxinkakonxín sín tí jie̱ tsíkjasin sín  
\v 4 kíxin ijni̱é koxinta la ko ijni̱é kotèntso̱ xitjahya tsjìinxín iji̱é chojni. 
\p  
\v 5 A̱ ntá tió Cristo kui chjasintajni ntáche chꞌán Dios kíxin: 
\q1 Tjinkákonhya jaha iko itsꞌen la ko tjinkákonhya jaha ninkehó nkehe chrókꞌuayéhé. Náhí. 
\q1 Jaha tsíkji̱chꞌéna ijnko cuerpo kíxin tsochonta janhan. 
\q1  
\v 6 Jaha tóxrjíanhya iko tsíchján la ko tí í so nkehe chrókjuanjonni chrókjuakjìinxian ijie̱. 
\q1  
\v 7 A̱ ntá ntátja̱n chꞌán kíxin: “A̱ ntá ijie la ntihi tjén janhan kíxin si̱ntaxiteyá tí nkehe tóxrjínhan jaha Dios, 
\q1 éxí nixja xroon chrónka nkexrí chrókjui̱tꞌa.”\f + \fr 10:7 \ft 10.5–7 Salmo 40.6–8\f* 
\m  
\v 8 Senó ntáchro kíxin Dios tjinkakonhya la ko tóxrjíe̱nhya chꞌán iko itsꞌen chrókjuanjonni la ko ninkehó nkehe chrókjuanjonni chrókjuìinxín iji̱éni kjónté tí ley kꞌue̱to̱an kíxin xi̱kaha chrókónhen.  
\v 9 A̱ ntá chrꞌéxi̱n tsíntáchro kíxin: “A̱ ntá kꞌuinka janhan kíxin si̱ntaxiteyá tí nkehe tóxrjínhan jaha Dios,” ichro chꞌán. Mé xi̱kaha kjua̱tse̱n chꞌán tí ko kꞌuékꞌóyán sín ósé, a̱ ntá jehe chꞌán kjuanjon chꞌán ijnko nkehe ni̱xin.  
\v 10 Dios kjuínchetjuáxinni kíxin Jesucristo kjuínchexiteyá éxí tóxrjínhi̱n Dios kíxin tí cuerpo kuènte chꞌán kjuanjon chꞌán ikꞌuén chꞌán jnkoko̱áxón vez para jnkochríxín. 
\p  
\v 11 A̱ ntá kaín ncha̱tꞌá judío tí xra̱ chꞌe sín jnkojnko ya̱on la jnkokón nkehe itsꞌen tjanjon sín kjánchó tíha la xitjahya tsjìinxín iji̱é chojni.  
\v 12 A̱ ntá Jesucristo mé jnkoko̱á vez kꞌuenyákonhe̱nni chꞌán kíxin tso̱tjuáxin iji̱éni la tíha mé sichꞌe xra̱ jnkochríxín. A̱ ntá kjuixin ntá sákjui̱ chꞌán kjuákꞌetja̱xi̱n chꞌán nó tí tja chjina kuènte Dios.  
\v 13 A̱ ntá ntiha tjechónhen chꞌán tsjixinjian kaín tí sín nínkakonhen chꞌán tsjachahya sín tsꞌe̱to̱an sín.  
\v 14 Mé xi̱kaha jnkoko̱á nkehe kjuíchꞌe chꞌán chjéhe chꞌán Dios, kíxin jína tsꞌejó tí sín ó tsíkótjóá.  
\v 15 A̱ ntá tí Ncha̱kuen Dios nchenoheni tíhi kíxin senó tsíntáchro kíxin: 
\q1  
\v 16 Tí pacto tsotja̱ha̱ tí jehe sín tió tsꞌatsínka tí ya̱on a, ichro Ìnchéni; 
\q1 Si̱ntaxráxinka̱van a̱sén sín tí ley tséto̱an, 
\q1 a̱ ntá tí kjuaxrexinkaon kuènte sín tsokjian tí nkehe tjínka̱van.\f + \fr 10:16 \ft 10.16-17 Jeremías 31.33-34\f* 
\m  
\v 17 Kja̱xin ntáchro kíxin: 
\q1 Í tsoxráxinka̱konhya ínaá tí iji̱é sín la ko tí nkehe jínahya kjuíchꞌe sín.\f + \fr 10:17 \ft 10.16-17 Jeremías 31.33-34\f* 
\m  
\v 18 Mé xi̱kaha tí ó kótjóá iji̱éni la tꞌichjánxi̱nhya í so nkehe chrókjuanjonni chrókótjuáxin tí iji̱éni. 
\s1 Méxra̱ tꞌichjánxi̱n tso̱chjineheni Dios 
\p  
\v 19 Kíchóni, a̱ ntá la í kohya kjuachrakon tsꞌixenhenni tí Cuarto A̱ntsí Tjóá tí tjen Dios kíxin kjua̱cha̱xi̱én ijni̱é Jesucristo,  
\v 20 chréhe̱ni tí nti̱a ni̱xin mé tí nti̱a tjechón kuakitje̱he̱ chꞌán nóton tí ka cortina, tíha mé tí cuerpo kuènte chꞌán.  
\v 21 Jesús mé tí ncha̱tꞌá tjetoan kuènteni tꞌe̱to̱an tí nto̱e Dios.  
\v 22 Méxra̱ xi̱kaha chrókóchjineheni Dios kaín a̱sénni chrókuinkáchónkini chꞌán chaxín kíxin jehe chꞌán tsíkjinchetjóá chꞌán a̱sénni kíxin chrókjuenka̱yáxinhyani kíxin na̱xa̱ chóntani jie̱ kíxin tí cuerpo kuènteni kótjuáxin tí nta̱ jehó.\f + \fr 10:22 \ft Ezequiel 36.25\f* 
\v 23 Chrókuíto̱ehyani chrókꞌuejóchónhenni tí nkehe tinkáchónkini kíxin Dios la chaxín sinchexiteyá chꞌán tí nkehe tsíntáchro chꞌán.  
\v 24 Chrókjueyáni nkexrí chrókjuinki̱tsani kíchó ni kíxin chrótjuèheni kíchó ni la chrókjuichꞌeni tí nkehe jína.  
\v 25 Chrókuíto̱ehyani chrókójnkotséni, chrókóyóe̱hyani éxí tí sín í tójnkotséhya sín. Náhí. Chrókjuinchechéhe̱ni kíchó ni a̱ntsí má jie kíxin ó noheni kíxin í séhya tsokjan Ìnchéni. 
\p  
\v 26 A̱ ntá tí na̱xa̱ chrókjuenka̱yáxinni chrókjuasinni jie̱ tí ó noheni tí nkehe chaxín, la kohya í jnko nkexro chrókꞌuenyákonhe̱nni chrókótjuáxin tí jie̱ chóntani.  
\v 27 A̱ ntá jehó itjen tí kjuachrakon jié tsito̱exín jie̱ la ko tí xrohi tjeche tsꞌitjáyanxín tí sín nínkakonhen Dios.  
\v 28 A̱ ntá tí tjen jnkojín nkexro titekakonhya tí ley kꞌue̱to̱anxín chꞌín Moisés, la tso̱noxín yaá o̱ yꞌá tí sín tsíkꞌikon tí jie̱ tsíkjasin sín, tíha mé tsꞌenxín sín la kohya nkexro tsi̱konóe̱he̱ tí jehe sín.  
\v 29 ¿Á tjenka̱yáxinhyará kíxin a̱ntsí má chrókjuasóte tí sín kuítekakuenhya tí Xje̱en Dios la ko chóntehya sín kjuasáya tí ijni̱é chꞌán la ko tꞌántaxínhi̱n sín tí Ncha̱kuen Dios tjuèheni? Kíxin tí jni̱ chrónkaxín kíxin tsꞌe̱to̱anxín tí pacto la ko tí jni̱ kꞌuíjmáxinni.  
\v 30 Noheni kíxin tsíntáchro Ìnchéni kíxin: “Janhan mé tóna tocar si̱ntakito̱axián iji̱é chojni la ko janhan tsjénka̱ha̱ sín.”\f + \fr 10:30 \ft Deuteronomio 32.35-36\f* Kja̱xin tsíntáchro kíxin: “Ìnchéni sinchekito̱exín iji̱é tí sín tinkáchónki chꞌán.”\f + \fr 10:30 \ft Deuteronomio 32.35-36\f* 
\v 31 Méxra̱ kjuachrakon jié chrókꞌuanótjenyáni tí tja Dios tjechón. 
\p  
\v 32 A̱ ntá chróxráxinkáonrá jahará tí nkehe tsíkónhen ósé kíxin tió jahará na̱ntá tsíkꞌayéhérá tí nkehe tꞌinkaséyan, a̱ ntá kjuachará kjónté tí nchónhya nkehe tsíkónhanrá.  
\v 33 A̱ ntá jnkojín tí jahará kꞌuántaxínhanrá sín la ko kjuatiará sín nkayakon nchónhya chojni, a̱ ntá í so sín la kjuínki̱tsa tí sín tsíkꞌekon.  
\v 34 A̱ ntá jahará kui̱konóe̱hérá tí sín tjejóchjina nto̱echiso, a̱ ntá jahará kóninkákonhyará kjónté kꞌuaxrjahará kaín nkehe chontará, kíxin ó nohará kíxin nkaya nka̱jní chontará nkehe a̱ntsí jína chónhya tsjeje̱.  
\v 35 Chrókui̱to̱éhyará tí nkehe tinkachónkirá kíxin ó nohará kíxin tíha mé tsꞌayéxinrá nkehe chrꞌéxi̱n.  
\v 36 Kja̱xin jahará tꞌichjánxi̱n chrókꞌuejochonhénrá chrókóninkákonhyará kjónté ichrén nkehe chrókónhanrá, kíxin si̱chꞌerá tí nkehe tjinkaon Dios, kíxin xi̱kaha chrókꞌuayéhérá tí nkehe tsíntáchro tí jehe chꞌán.  
\v 37 Kíxin xi̱kaha ntáchro xroon itén Dios kíxin: 
\q1 Kánhyó sé 
\q1 itsi tí nkexro tsi, í sinchexrjenhya. 
\q1  
\v 38 Tí sín kótjóá a̱sén mé tjejóchónxin sín kíxin tinkáchónki sín Dios; 
\q1 a̱ ntá tí sín tsíto̱he tí janhan la í tso̱chànahya tí xi̱kaha chꞌe sín.\f + \fr 10:38 \ft 10.37-38 Habacuc 2.3-4\f* 
\m  
\v 39 Kjánchó jeheni jehya xi̱kaha chrókuíto̱heni chrókuinkáchónkihyani tí jehe chꞌán kíxin ntá chrókjuasinni jie̱ chrókꞌuitjáyanxínni. Náhí. Tinkáchónkini chꞌán la tíha chrókuaáxinni. 
\c 11  
\s1 Tí fe 
\p  
\v 1 Tí fe chóntani la mé noexínni chaxín kíxin tsoxiteyá tsꞌáyéhe̱ni tí nkehe tjejóchónhenni, la ko noexínni chaxín kíxin kjónté ijnko nkehe tꞌikonhyani la chaxín tjen.  
\v 2 Tí sín tsíkꞌaxrjeníxinni ósé la kóxrjínhi̱n Dios kíxin kꞌuéchónta sín fe. 
\p  
\v 3 Tí fe mé noexínni kíxin Dios tsíkjichꞌéna kaín nkehe tí kjuachaxin tí nixja chꞌán la ko noexínni kíxin tí nkehe tꞌikonni mé tsíkꞌóna tí nkehe tꞌikonhyani. 
\p  
\v 4 A̱ ntá tí fe kꞌuéchónta chꞌín Abel mé kꞌóyán chꞌán ijnko kolélo chjéhe chꞌán Dios. Tíha ijnko nkehe a̱ntsí jína kjuanjon chꞌán, a̱ ntá tí nkehe tsíkjanjon chꞌín Caín la náhí. Méxra̱ Dios kóxrjínhi̱n tí nkehe kjuanjon chꞌín Abel ntá ntáchro Dios kíxin jína tí chꞌín a. Kjónté ó tsíkꞌen chꞌín Abel la tí nkehe tsíkjichꞌe chꞌán na̱xa̱ tja̱ko̱xi̱n kíxin jína tí fe kꞌuéchónta chꞌán.\f + \fr 11:4 \ft Génesis 4.3–10\f* 
\p  
\v 5 A̱ ntá tí fe kꞌuéchónta chꞌín Enoc la Dios sátsíkji̱ko tí jehe chꞌán la kꞌuénhya chꞌán, a̱ ntá kꞌuitjahya sín chꞌán kíxin Dios sátsíkji̱ko. Na̱xa̱ sákjui̱hya chꞌán la xráxín kóxrjínhi̱n Dios nkexrí kꞌuékjakꞌe chꞌán.\f + \fr 11:5 \ft Génesis 5.21–24\f* 
\v 6 A̱ ntá tí chróchóntahyani fe la xitjahya chrókjuinchechéhe̱ni Dios, kíxin tꞌichjánxi̱n kíxin tí sín chrókóchjinehe sín Dios chrókuitekaon sín kíxin chaxín itjen chꞌán la ko jehe chꞌán tsje̱nke̱he chꞌán tí sín xritjeyá sín tí jehe chꞌán. 
\p  
\v 7 A̱ ntá tí fe kꞌuéchónta chꞌín Noé tí Dios chénka tí jehe chꞌán tí nkehe na̱xa̱ kꞌuíkonhya chꞌán tso̱nhen, la kuítekaon chꞌán kjuíchꞌéna chꞌán ntabárco̱ kíxin tsaáxin chꞌán la ko tí sín na̱xa̱ kjéhya chꞌán. Tí fe kꞌuéchónta chꞌán kjua̱ko̱xi̱n kíxin tí í so chojni chjasintajni la jínahya sín tsjasóte sín. A̱ ntá kóxrjínhi̱n Dios tí jehe chꞌán kíxin kuítekaon chꞌán la tí xra̱ kjuíchꞌe chꞌán mé kuaáxin chꞌán.\f + \fr 11:7 \ft Génesis 6.13–22\f* 
\p  
\v 8 A̱ ntá tí fe kꞌuéchónta chꞌín Abraham tí kꞌuíye̱he̱ Dios tí jehe chꞌán la kuítekaon chꞌán sákjui chꞌán tí nonte tsjanjon Dios tsꞌáyéhe̱ chꞌán, ntá kꞌuaxrjexín chꞌán chjasén chꞌán kjónté noehya chꞌán nketí nó sátsji chꞌán.\f + \fr 11:8 \ft Génesis 12.1–5\f* 
\v 9 A̱ ntá tí fe kꞌuéchónta chꞌán kꞌuékjakꞌe chꞌán tí nonte chrókjuanjon Dios, éxí jehya no̱nte̱e chꞌán tíha. Kjuákꞌe chꞌán nchia tsíkꞌóna ka, la ko kja̱xin xi̱kaha kꞌuéchónta chꞌín Isaac la ko chꞌín Jacob la ko kja̱xin jehe sín tsíkꞌáyéhe̱ sín tí nkehe tsíntáchro Dios.\f + \fr 11:9 \ft Génesis 35.27\f* 
\v 10 A̱ ntá chꞌín Abraham kꞌuékjakꞌechónhen chꞌán tí chjasin tsíkjichꞌéna Dios tsꞌitjáyanhya. 
\p  
\v 11 A̱ ntá tí fe kꞌuéchónta tjan Sara kjónté ó nána tjan, kꞌuáyéhe̱ tjan kjuachaxin sichꞌéna tjan ijnko xjan; a̱ ntá kjuíchꞌéna tjan ijnko xjan kíxin kuítekaon tjan kíxin Dios sinchexiteyá tí nkehe tsíntáchro chꞌán.\f + \fr 11:11 \ft Génesis 18.11–14; 21.2\f* 
\v 12 Kja̱xin xi̱kaha chꞌín Abraham, kjónté ó mero chrókꞌuen chꞌán kíxin ó táda chꞌán, la kꞌuaxrjeníxin chꞌán nchónhya chojni éxí konotsé siín nka̱jní o̱ éxí nchesen siín chrínta nta̱yaon, xitjahya tsꞌekini.\f + \fr 11:12 \ft Génesis 22.17\f* 
\p  
\v 13 A̱ ntá kaín tí chojni a ikꞌuén sín kꞌuáyèhya sín tí nkehe tsíntáchro Dios kíxin chrókꞌuáyéhe̱ sín, a̱ ntá kꞌuéchónta sín fe, la kjónté ikjín kꞌuíkon sín la ko kuítekaon sín kóchéhe̱ sín. Mé xi̱kaha kꞌuéchrónka sín kíxin tí chjasintajni jehya chjasén sín.  
\v 14 Mé xi̱kaha kꞌuénixja sín la tienxínni jína kíxin na̱xa̱ xritjeyá sín nketí chrókꞌóna chjasén sín.  
\v 15 A̱ ntá tí chróxraxinkaon sín tí chjasin tsíkꞌaxrjexín sín ntá jína chrókjan sín ntiha ínaá.  
\v 16 Kjánchó tjinkaon sín ijnko chjasin a̱ntsí má jína, tíha mé chjasin nkaya nka̱jní. Méxra̱ Dios la tósuèhya chꞌán kíxin chrókjuinchekꞌin sín chꞌán tí Dios kuènte tí jehe sín, kíxin ó tjechónhen tí chjasin tsꞌáyéhe̱ tí jehe sín. 
\p  
\v 17 A̱ ntá fe kꞌuéchónta chꞌín Abraham kíxin Dios kjuíchꞌe prueba tí jehe chꞌán kjuanchia tí xje̱en chꞌán Isaac, a̱ ntá kjui̱ka̱o chꞌán chrókꞌóyán chꞌán, chrókjuanjon chꞌán. Tjechónhen chꞌán chrókjuanjon chꞌán kjónté jnkoko̱áxón xje̱en chꞌán tsíkjanjon Dios\f + \fr 11:17 \ft Génesis 22.1–14\f* tsíntáchro kíxin:  
\v 18 “Tí chꞌín Isaac tsꞌaxrjeníxin nchónhya xjan.”\f + \fr 11:18 \ft Génesis 21.12\f* 
\v 19 A̱ ntá chꞌín Abraham kjuátso̱an chꞌán kíxin Dios imá chónta kjuachaxin, la kjónté chojni tsíkꞌen na nchexechón chꞌán, la éxí yóhe̱ chrókꞌuen tí xje̱en chꞌín Abraham ntá chrókꞌuáyéhe̱ chꞌán ínaá. 
\p  
\v 20 A̱ ntá tí fe kꞌuéchónta chꞌín Isaac kjuíncheyaon chꞌán tí xje̱en chꞌán chꞌín Jacob la ko Esaú, kíxin jína tsꞌejó sín.\f + \fr 11:20 \ft Génesis 27.27―29,39–40\f* 
\v 21 A̱ ntá tí fe kꞌuéchónta chꞌín Jacob tió chjina itsꞌen chꞌán kjuíncheyaon chꞌán jnkojnko tí xje̱en chꞌín José, a̱ ntá tí nta tjixin chꞌán kjuisóji̱xi̱n chꞌán nixje̱he̱ chꞌán Dios.\f + \fr 11:21 \ft Génesis 47.31—48.20\f* 
\v 22 A̱ ntá tí fe kꞌuéchónta chꞌín José tió chjina itsꞌen chꞌán tsíntáchro chꞌán kíxin tí sín israelita la chrꞌéxi̱n tsꞌaxrjexín sín chjasin Egipto, tsíkꞌe̱to̱an chꞌán kíxin tió sátsji̱ sín la sátsji̱ko sín tí hueso̱é chꞌán.\f + \fr 11:22 \ft Génesis 50.24–25\f* 
\p  
\v 23 A̱ ntá tí fe kꞌuéchónta itꞌé la ko ìné chꞌín Moisés tió kokjíhi chꞌán kjua̱kꞌe̱ma̱ sín chꞌán iní nitjó kíxin tsíkꞌikon sín kíxin ijnko xjan ntoa náxrjón tsjehe chꞌán, la ko chrakuenhya sin tí nkehe tsíkꞌe̱to̱an tí chꞌín rey kíxin chrókꞌóyán sín xjan.\f + \fr 11:23 \ft Éxodo 1.2; 2.2\f* 
\v 24 A̱ ntá tí fe kꞌuéchónta chꞌín Moisés tió kónte̱to chꞌán la chrohya chꞌán itsꞌin chꞌán xje̱en tí tjan xje̱en chꞌín rey Egipto.\f + \fr 11:24 \ft Éxodo 2.10–12\f* 
\v 25 Náhí. Kjueyá chꞌán kíxin kjónté chrókjuasóteko chꞌán tí sín tinkáchónki Dios, la kóxrjíe̱nhya chꞌán kíxin séhya náxrjón chrókjuakꞌe chꞌán chrókjuasin chꞌán jie̱. Náhí.  
\v 26 Kjuenka̱yáxin chꞌán kíxin a̱ntsí tjetoan chrókjuasótexín chꞌán tí tinkáchónki chꞌán tí Cristo itsi chrꞌéxi̱n, a̱ ntá kánhyó tjetoan chróchónta chꞌán kaín nkehe tjete siín chjasin Egipto. Kjuenka̱yáxin chꞌán kíxin chrókꞌuáyéhe̱ chꞌán tí nkehe chrókjuanjon Dios.  
\v 27 A̱ ntá tí fe kꞌuéchónta chꞌín Moisés sákjui̱xin sín tí chjasin Egipto,\f + \fr 11:27 \ft Éxodo 2.15\f* chrakonhya chꞌán kjónté kónínkaon tí chꞌín rey, a̱ ntá kuíto̱ehya chꞌán tí tinkáchónki chꞌán Dios kíxin éxí tꞌikon chꞌán tí Dios ninkexró tꞌikonhya. 
\p  
\v 28 A̱ ntá tí fe kꞌuéchónta chꞌín Moisés kjuasin chꞌán tí kia pascua, kꞌue̱to̱an chꞌán kixin chrókuikja̱nji̱n sín jni̱ tí puerta, kíxin tí ángel tꞌóyán chojni chrókjuincheníehya nijnko tí xjan sa̱o kuènte tí sín Israel.\f + \fr 11:28 \ft Éxodo 12.21–30\f* 
\v 29 A̱ ntá tí fe kꞌuéchónta tí sín israelita kꞌuátòye̱ sín tí Nta̱yaon Kjátse kíxin kꞌóna nche xámá, a̱ ntá tió tí sín Egipto tjinkaon sín chróchréhe̱ sín xi̱kaha la kjánchó kjuínhin sín tí nta̱ a.\f + \fr 11:29 \ft Éxodo 14.21–31\f* 
\p  
\v 30 A̱ ntá tí fe kꞌuéchonta tí sín israelita la xítjen tí tja̱tꞌo̱ tꞌinkákuènxín tí chjasin Jericó, tió kjuixin kꞌuántatjen sín yato ya̱on tí chjasin a.\f + \fr 11:30 \ft Josué 6.12–21\f* 
\v 31 A̱ ntá tí fe kꞌuéchónta tí tjan Rahab, na mé ijnko tjan kꞌuéchónta nchónhya chojni ntoa, ntá kꞌuénkohya tjan kaín tí sín jie̱he kuítekakonhya, kíxin tsíkjanjon tjan kjuachaxin kíxin kjuaxróxin tsíkito̱he nto̱e tjan tí sín israelita kjuíjitsàya sín tí chjasin Jericó.\f + \fr 11:31 \ft Josué 2.1–21\f* 
\p  
\v 32 ¿Nkehe na̱xa̱ chróntáxrja̱n? Si̱ntakꞌitjáyan tiempo na̱xa̱ chrónixja̱ kuènte chꞌín Gedeón, la ko chꞌín Barac, la ko chꞌín Sansón, la ko chꞌín Jefté, la ko chꞌín David, la ko chꞌín Samuel, la ko tí sín profeta.  
\v 33 Kíxin tí fe kꞌuéchónta tí jehe sín kjuacha sín kꞌue̱to̱an sín jína ókjé chjasin, la ko jína kjuínchekito̱exín sín iji̱é chojni, la ko kꞌuáyéhe̱ sín tí nkehe tsíntáchro Dios kíxin tsjanjon chꞌán, la ko kꞌuikjehe̱ sín irꞌva koxra̱,  
\v 34 la ko kꞌuanka tí xrohi chróchexín sín, la ko kjuachahya tí espada chrókꞌuenxín sín. A̱ ntá tí sín chrakon la kófuérte̱ sín, kꞌóna sín chojni tse̱he̱ kjuacha sín kjuánjo̱nko sín tí sín soldado tsíkji̱xi̱n ókjé.  
\v 35 Kja̱xin kꞌuékꞌixin chojni chjin kꞌuáyéhe̱ ínaá tí chojni tsíkꞌen kuènte sín tsíxechón ínaá. 
\p A̱ ntá í so sín la kjuasote sín kꞌuénxin sín kíxin kjuínchemáhya sín kíxin kuinkáchónki sín Dios kíxin ó nohe sín kíxin tsoxechón sín a̱ntsí jína ínaá.  
\v 36 A̱ ntá í so sín kjuasóte sín la nchónhya chojni kjuanoá tí jehe sín, la ko tsíkꞌekon sín la ko kja̱xin cadena chróntetoxín sín kꞌuejóchjina sín.  
\v 37 Í so sín la ixro̱ kꞌuénxin sín, la í so sín cierra chrítꞌo̱xin sín, la í so sín la nchónhya nkehe kjuasótexín sín, la í so sín kꞌuénxin sín espada, la í so sín kꞌuékꞌaji sín tsíkꞌinkáya sín tjo̱e kolélo la ko tjo̱e kotèntso̱, nòa sín, kjuasóte sín, kjuaxróxinhya la náxrjónhya kꞌuéjó sín.  
\v 38 A̱ ntá tí sín chjasin ntiha kjuikosáyehya tí sín a la ntá kꞌuínkíté sín, la tí sín a la chóntahya chjasén sín la sákjui̱ sín nte̱je̱, la ko jna̱, la ko tjo síxrja la ko tòye̱.  
\v 39 Kaín tí sín a kónhen sín prueba kíxin á chaxín chónta sín fe la kjónté xi̱kaha kꞌuáyèhya sín tí nkehe tsíntáchro Dios kíxin tsjanjon chꞌán  
\v 40 kíxin Dios kjuenka̱yáxin chꞌán ijnko nkehe a̱ntsí jína kíxin jehó jnkoko̱á chrókꞌuáyèkoni sín tí nkehe tsjanjon chꞌán. 
\c 12  
\s1 Jehó Cristo chrókuinkáchónkini 
\p  
\v 1 Méxra̱ tí jeheni la tsíkꞌantátjenni nchónhya chojni tsíkja̱ko̱xi̱n sín tí fe kꞌuéchónta sín, la ntá chrókuíto̱heni ntáha kaín tí nkehe tꞌinkákonhe̱n, la ko tí jie̱ chrókjuachroeni, a̱ ntá chrókjuichꞌeni jína tí xra̱ chóntani la ntá chrókjuachani a̱ntsí má chrókónoheni.  
\v 2 Jehó Jesús chrókuinkáchónkini kíxin jehe chꞌán kjuanjon tí fe chóntani kíxin jína kjua̱ko̱xi̱n chꞌán kjuínchexiteyá chꞌán, la kjuasótexín chꞌán tí ntacruz, la kuáhya chꞌán kuentá kósuèhya chꞌán tí nkehe kónhen chꞌán ikꞌuén chꞌán, kíxin nohe chꞌán kíxin tsjixin tsjasóte chꞌán ntá náxrjón tsjakꞌe chꞌán la ko tso̱chéhe̱ chꞌán kíxin tsjakꞌetja̱xi̱n chꞌán tí tja chjina tí trono kuènte Dios. 
\p  
\v 3 Méxra̱ chrókjuenka̱yáxinrá jahará nkexrí kjua̱ko̱xi̱n chꞌín Jesús. Tí sín chónta jie̱ imá kjuínchekjasóte tí jehe chꞌán la kjónté jahará xi̱kaha chrókjuasóterá la chrókóxrjéhyará chrókuinkachónkirá chꞌán.  
\v 4 A̱ ntá jahará na̱xa̱ kꞌuénxinhyará tí tjanjo̱nkoará tí jie̱.  
\v 5 ¿Á kꞌuitjáyanhanrá tí jahará tí nkehe ntaxraxinkaonrá Dios kíxin éxí xje̱en chꞌán tꞌikon chꞌán tí jahará? Éxí ntáchro xroon itén Dios kíxin: 
\q1 Xje̱enni, tóninkákonhya tí nkehe tjentuáha Ìnchéni, chrókꞌuaváhya tí chrókjuentuáha chꞌán. 
\q1  
\v 6 Kíxin Ìnchéni mé tjentuéhe tí sín tjuèhe chꞌán la ko nchekjasóte kaín tí sín tsꞌáyéhe̱ chꞌán tsꞌóna xje̱en chꞌán.\f + \fr 12:6 \ft Job 5.17; Provérbios 3.11–12\f* 
\m  
\v 7 Chrókuítekáonrá tí nkehe tꞌe̱to̱an Dios kíxin Dios tꞌikon kíxin éxí xje̱en chꞌán tí jahará. ¿Á siín ijnko itꞌé xjan chrokjuentuéhya tí xje̱en?  
\v 8 A̱ ntá tí chrókjuentuáhyará Dios tí jahará éxí tjentuéhe chꞌán kaín tí xje̱en chꞌán, ntá jahará kjá jehya xje̱en chꞌán chaxín.  
\v 9 A̱ ntá tí na̱xa̱ kꞌuéchánjanni, na mé itꞌéni ntihi chjasintajni kjuentuéhe tí jeheni, la jeheni kjuikosáyeheni sín. A̱ ntá xi̱kaha a̱ntsí chrókjuinchexiteyéhe̱ni Itꞌéni tjen nkaya nka̱jní kíxin chróchóntaxínni kjuachón.  
\v 10 Itꞌéni ntihi chjasintajni kjuentuéheni chꞌán kjónté kánhyó sé éxí nkexrí kóxrjínhi̱n chꞌán; a̱ ntá Itꞌéni Dios tjentuéheni chꞌán kíxin jnkojína chrókꞌuejóni, kíxin chrókꞌónani tjóá kíxin jehe chꞌán la tjóá chꞌán.  
\v 11 Chaxín ninkehó xi̱kaha chrókjuinchekjasóte Dios tí jeheni chrókóxrjínhi̱nni tí na̱ntá chrókónhenni kíxin tí kjuatjoté. A̱ ntá xi̱kaha tsꞌitjaxínni tí kjuaxróxin éxí ijnko nkehe náxrjón kjuachani. 
\s1 Tí sín tjanoá tí kjuasáyé Dios 
\p  
\v 12 Méxra̱ tjisójirá tí tjárá tsíkóxrjé la ko tóchꞌinrá chóntahya fuerza,  
\v 13 la ko chrókjuéyárá tí nti̱a ntoá. A̱ ntá tí to̱tárá níhi xitjahya tjixinrá chrókuito̱he jína la ko chrókóníehya ínaá. 
\p  
\v 14 Chrókóxakonhanrá kíxin kjuaxróxin chrókꞌuejorá kaín rá, jnkojína tjóá chrókꞌuejorá. A̱ ntá tí tjuáhya chrókꞌuejorá la xitjahya tsꞌikonrá Ìnchéni.  
\v 15 Chrókóxakonhanrá kíxin nijnkorá chrókui̱to̱éhyará tí kjuasáyé Dios la ko nijnkorá chrókꞌónahyará éxí ijnko nuèe ka tsjá chónta veneno chrókóníexín tí í so chojni.  
\v 16 Nijnko tí jahará chrókjuásinkoará jie̱ ijnko chojni chjin ókjé, la ko chrókjo̱niéhyará tí nkehe tjóá éxí kjuíchꞌe chꞌín Esaú, kíxin jnkoko̱á comida kjuínchekjixin chꞌán tí nkehe chróchónta chꞌán kíxin xjan sa̱o jehe chꞌán.\f + \fr 12:16 \ft Génesis 25.29–34\f* 
\v 17 Jahará ó nohará kíxin chrꞌéxi̱n, tió tjinkaon chꞌán kíxin chrókjuincheyaon itꞌé chꞌán tí jehe chꞌán la í xitjahya tso̱yaon chꞌán kíxin kohya nkexrí chrókꞌuixitóxi̱n tí nkehe tsikjichꞌe chꞌán kjónté imá chrótsjánka chꞌán.\f + \fr 12:17 \ft Génesis 27.30–40\f* 
\p  
\v 18 A̱ ntá jahará la jehya kóchjinará éxí kóchjina tí sín israelita tí jna̱ jína chrótsé sín tí síchrꞌákjen xrohi, tí tjen tí sítié tꞌinkaséyanhya la ko tí chjéhe xri̱nto̱.  
\v 19 Na ni tsíkíenhyará tí tsíntáchro trompeta, la ko tí itén Dios nixja. A̱ ntá tí sín tsíkinhin tí tan a na mé chronòa sín kíxin í chrónixjahya chꞌán ínaá,\f + \fr 12:19 \ft Éxodo 19.16–22, 20.18–21\f* 
\v 20 mé xi̱kaha ichro sín kíxin tsjachahya sín sinchexiteyá sín tí nkehe kꞌue̱to̱an chꞌán kíxin “Tí nkexro tsinkátja tí jna̱ mé itsꞌen, la ixro̱ la o̱ chica lanza chrókꞌóyánxin sín, la kjónté ijnko ko tsinkátja va tí jna̱ la chrókꞌuen.”\f + \fr 12:20 \ft Éxodo 19.12–13\f* 
\v 21 Ijnko kjuachrakon jié tí nkehe kꞌuíkon sín la kjónté chꞌín Moisés tsíntáchro chꞌán kíxin: “Kja̱xin síxrànka̱na chrakonna.”\f + \fr 12:21 \ft Deuteronomio 9.19\f* 
\p  
\v 22 A̱ ntá jahará tsíkóchjineherá tí jna̱ Sión, tí chjasén Dios tjechón, mé tí Jerusalén itjen nkaya nka̱jní, la ko nchónhya miles ángel  
\v 23 tsíkójnkotsé sín kíxin tsochjéhe sín kjuasáyá Dios, la ko tí sín tsíkójnkotsé sín tsíkꞌóna sín xje̱en Dios sa̱oxín tsꞌínixín ihni̱é sín nkaya nka̱jní. Jahará tsíkóchjineherá Dios, jehe chꞌán mé Juez sinchekito̱exín chꞌán iji̱é kaín chojni, la ko tsikóchjineherá tí ncha̱kuen chojni jína ó tsíkjinchetjóá Dios,  
\v 24 la ko tsíkóchjineherá chꞌín Jesús, jehe chꞌán mé nixja̱xi̱n chꞌán tí pacto ni̱xin kíxin tí ijni̱é chꞌán kꞌuítji kjuínchetjuáxinni chꞌán. A̱ ntá a̱ntsí jína chrónkaxín tí ijni̱é chꞌán, a̱ ntá kánhyó tí ijni̱é chꞌín Abel. 
\p  
\v 25 Chrókóxakonhanrá chrókuítekákonhénrá tí nkexro tjenixja. Kíxin tí sín kjuanoá Dios tió kjuínchexraxinkaon chꞌán tí jehe sín ntihi chjasintajni ó la kuaáhya sín; a̱ ntá a̱ntsí má xitjahya chrókuaáni tí chrókuitekakuenhyani tí nkexro nchexraxinkaonni kui̱xi̱n nkaya nka̱jní.  
\v 26 A̱ ntá tí itén Dios tí ya̱on a kjuínchekinkí nonte. A̱ ntá jie tsíntáchro chꞌán kíxin: “A̱ ntá ínaá jehya nonte ó si̱ntakinkiá. Náhí. Kja̱xin nka̱jní si̱ntakinkiá”,\f + \fr 12:26 \ft Hageo 2.6\f* 
\v 27 A̱ ntá tí tsíntáchro chꞌán kíxin “ínaá” mé tꞌaxrjexín kíxin tsjakjìin chꞌán tí nkehe jína tsinkí, a̱ ntá tsíto̱he chꞌán tí nkehe xitjahya tsinkí.  
\v 28 A̱ ntá tí tsꞌáyéhe̱ni tí kjuachaxin kjuanjon Dios la xitjahya tsꞌixinkí tíha. Méxra̱ chróchjéheni Dios kjuasáya chróxraxinkaonni chꞌán chróchrako̱nhe̱nni chꞌán  
\v 29 kíxin tí Dios kuènteni mé éxí ijnko xrohi tsjacha sinchekꞌitjáyan kaín nkehe.\f + \fr 12:29 \ft Deuteronomio 4.24\f* 
\c 13  
\s1 Nkexrí chrókꞌuejóni kíxin chrókóchéhe̱ Dios 
\p  
\v 1 Méxra̱ chrókui̱to̱éhyará chrótjuèherá kíchuárá.  
\v 2 Chrókꞌuitjáyanhyará chrókjuánjonrá kjuachaxin chrókuito̱he nto̱ará tí sín tsíkji̱xi̱n kjín. Mé xi̱kaha kjuíchꞌe iso sín la kjónté ángel tsíkꞌáyéhe̱ sín la kónoehya sín.\f + \fr 13:2 \ft Génesis 18.1–8, 19.1–3\f* 
\p  
\v 3 Xráxinkáonrá tí sín tjejóchjina éxí kja̱xinrá chrókꞌuejochjinakoará tí jehe sín. Xráxinkáonrá tí sín tsíkꞌekon éxí kja̱xin tí jahará xi̱kaha chrókonhanrá kja̱xin. 
\p  
\v 4 Kaínrá chróchonteherá kjuasáya tí kóte̱he chojni. A̱ ntá jahará tsíkóta̱hará la jína chrókꞌuejokoará kíchuárá chrótjuèhérá kíchuárá. A̱ ntá tí sín tjinkaon tsochónta chojni chjin ókjé la Dios sinchekjasóte sín kíxin xi̱kaha ichꞌe sín. 
\p  
\v 5 Kénhyó má chrókóxrjínhanrá itsjé chichaon. Chrókócháhará kjónté tí kánhyó tsjé chontará; kíxin tsíntáchro Dios kíxin: “Janhan na tsi̱to̱a̱hya tí jahará la ko tsꞌitjáyannahya tí jahará.”\f + \fr 13:5 \ft Deuteronomio 31.6\f* 
\v 6 Mé xi̱kaha chrakonhyani tsontáchroni kíxin: 
\q1 Ìnchéni mé tjinki̱tsani, 
\q1 méxra̱ chróchrakonhyani kjónté ichrén nkehe chrókjuichꞌeheni chojni.\f + \fr 13:6 \ft Salmo 118.6\f* 
\p  
\v 7 Chróxráxinkáonrá tí sín kjuínki̱tsa tí jahará kjua̱ko̱ha̱rá sín itén Dios, chrókjuenka̱yáxinrá nkexrí kꞌuejó sín ntá xi̱kaha chrókóyóha̱rá sín éxí tí fe kꞌuéchónta sín. 
\p  
\v 8 Jesucristo mé itjen chꞌán ijna la ko ijie la ko jnkochríxín.  
\v 9 Chrókui̱to̱éhyará chrókjua̱ko̱ha̱rá chojni ijnko nkehe ókjé chrókuinkachónkirá. Íchá jína tí a̱sánrá chrókꞌuáyéhe̱ fuerza kíxin Dios tjuahará la jehya tjetoan chrókjuinchexiteyéhe̱ni tí nkehe tꞌe̱to̱an nkehe sineni. Mé xi̱kaha tí sín kjuíchꞌe xi̱kaha kjuínchexiteyá tí nkehe kꞌuítuenhen sín nkexrí chrókjóne sín la ninkehó kjuínki̱tsahya tíha. 
\p  
\v 10 A̱ ntá jeheni chóntani í jnko altar kíxin kꞌuenyákonhe̱nni Cristo la ntiha kohya kjuachaxin chrókjónexín tí ncha̱tꞌá kjuíchꞌe xra̱ nkaxenhen ni̱nko ósé.  
\v 11 A̱ ntá tí ncha̱tꞌá tꞌe̱to̱an judío kjuíko sín tí ijni̱é ko nkaxenhen tí Cuarto A̱ntsí Tjóá kíxin tí nkehe la tsja̱tse̱n tí iji̱é sín. A̱ ntá tí cuérpo̱é tí ko kjuakaxín sín ikon tí chjasin kꞌuejó sín.  
\v 12 Kja̱xin Ìnchéni Jesús kjuasóte chꞌán kꞌuénxin chꞌán ikon chjasin kíxin tso̱tjuáxin kaín iji̱é chojni tí ijni̱é chꞌán.  
\v 13 Tsochréhe̱ni Ìnchéni Jesús éxí kꞌuénxin chꞌán ikon chjasin kjónté tsjasóteni éxí kjuasóte tí jehe chꞌán kjuikosáyehya sín tí jehe chꞌán.  
\v 14 A̱ ntá ntihi chjasintajni chóntahyani nijnko chjasénni chrókꞌuitjáyanhya; a̱ ntá xritjeyáni tí chjasin itsi chrꞌéxi̱n.  
\v 15 Méxra̱ chrókuíto̱ehyani chrókjuikosáyeheni Dios kíxin Jesucristo kꞌuenyákonhe̱nni chꞌán. Tí xraxinkaonni chꞌán la yóhe̱ tí ko tsíkꞌen tsíchjéhe sín Dios. Yóhe̱ xi̱kaha chrókjuanjonni kíxin irꞌvani ó chrókjuikosáyexínni chꞌán.  
\v 16 Chrókꞌuitjáyanhyará chrókjui̱chꞌerá xra̱ jína la ko chrókjuínki̱tsará kíchuárá. Tí xi̱kaha chrókjui̱chꞌerá la imá tóxrjínhi̱n Dios. 
\p  
\v 17 Chrókuítekákonhénrá tí sín tja̱ko̱ha̱rá chrókjui̱nchexiteyéhérá tí jehe sín. Jehe sín mé tꞌayakonhen sín a̱sánrá kíxin jehe sín la ó nohe sín kíxin tsjanjon sín kuentá tí tjen Dios. Tsjínki̱tsará sín kíxin tso̱chéhe̱ sín sichꞌe sín xra̱ la tso̱nínkakonhya sín. A̱ ntá tí chrókjui̱nchekꞌávárá sín, ntá ninkehó tsjachahya sín tsjinki̱tsa sín tí jahará. 
\p  
\v 18 Nixje̱hérá Dios kíxin tí jeheni kaín ni, kíxin chaxín jína kjuenka̱yáxinni la ko tjinkaonni kíxin jína chrókꞌuejóni.  
\v 19 Tjánchíá xra̱ ó kíxin chrónixje̱hérá Dios kíxin chrókjuanjon chꞌán kjuachaxin kíxin tjoka chrókjan janhan chrókꞌuejóni. 
\s1 Tjanchia chꞌán kíxin chrókóyaon sín 
\p  
\v 20 Tí Dios tjanjon kjuaxróxin, mé tí nkexro kjuínchexechón Ìnchéni Jesucristo kjónté tsíkꞌen chꞌán, jehe Jesucristo mé tí Pastor tjetoan tꞌayakonhen tí kolélo, la tí ijni̱é chꞌán mé tsoxiteyáxin tí pacto sichꞌe xra̱ jnkochríxín,  
\v 21 jehe Dios mé tsjinki̱tsa tí jahará kíxin jína chrókꞌuejorá la ko kaín xra̱ jína chrókjui̱chꞌerá kixin xi̱kaha tjinkaon chꞌán; kíxin jehe chꞌán tꞌe̱tue̱nhenni chꞌán kaín nkehe nkexrí tjinkaon chꞌán kíxin tí kjuachaxin chónta Jesucristo. Mé xi̱kaha chjéheni Cristo kjuasáya jnkochríxín. Amén. 
\p  
\v 22 Kíchóni, xrja̱nóa̱hará kíxin tóninkákonhyará kíxin tí palabra xrja̱nka si̱ntaxraxinkáonrá. Méxra̱ ikjian tí xroon kjónté kánhyó tsjé nixja tsꞌayéhérá.  
\v 23 Chrókónohará kíxin kíchó ni Timoteo la í tjechjinahya chꞌán jie. Tí tjoka tsi chꞌán la tsjasánkian chꞌán tí tsjasántsjahárá tí jahará. 
\p  
\v 24 Nixje̱hérá jnkojína kaín tí sín tjítaón nti̱a tjako la ko kaín tí sín kíchó ni tinkáchónki Dios. Tí sín tinkáchónki Ìnchéni tjejó Italia mé nixjahará sín. 
\p  
\v 25 Dios sintayaonrá chꞌán kaín rá. Amén. Ó tjen.