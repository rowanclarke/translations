\s1 The silver trumpets
\p 
\v 1 \w Yahweh|strong="H3068"\w* \w also|strong="H3068"\w* \w told|strong="H1696"\w* \w Moses|strong="H4872"\w*/\w me|strong="H1696"\w*,
