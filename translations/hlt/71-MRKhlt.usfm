\p
\v 33 \w Tedae|strong="G2532"\w* \w amih|strong="G0846"\w* te a \w doo|strong="G0611"\w* tih, \wj “ \+w Kai|strong="G3450"\+w* \+w manu|strong="G3384"\+w* \+w neh|strong="G2532"\+w* \+w kai|strong="G3450"\+w* \+w manuca|strong="G0080"\+w* rhoek \+w te|strong="G3588"\+w* \+w unim|strong="G5101,G2076"\+w*? unim manuca rhoek la aka om?”\wj* a \w ti|strong="G3004"\w* nah.   
\p
\v 34 Te \w phoeiah|strong="G2532"\w* \w a|strong="G0846"\w* \w taengvai|strong="G2945"\w* \w ah|strong="G4012"\w* \w aka \w*\w ngol|strong="G2521"\w* rhoek \w te|strong="G3588"\w* a \w sawt|strong="G4017"\w* tih, \wj “ \+w Ka|strong="G3450"\+w* \+w manu|strong="G3384"\+w* \+w neh|strong="G2532"\+w* \+w ka|strong="G3450"\+w* \+w manuca|strong="G0080"\+w* \+w rhoek|strong="G3588"\+w* la \+w he|strong="G2396"\+w*\wj*,  
