\id LUK - Biblica® Open Kurdi Sorani Standard Version
\h لۆقا
\toc1 مزگێنی بەپێی نووسینی لۆقا
\toc2 لۆقا
\toc3 لۆقا
\mt1 مزگێنی بەپێی نووسینی لۆقا
\c 1
\s1 مەبەستی ئەم نووسینە
\p 
\v 1 ئەی ساوفیلۆسی\f + \fr 1:1 \ft ناوێکی یۆنانییە، واتا ئەوەی خودای خۆشدەوێت.‏\f* پایەبەرز، زۆر کەس هەستان بە داڕشتنی چیرۆکی ئەو شتانەی\f + \fr 1:1 \ft مەبەست لە هاتنەدی هەموو پێشبینییەکانی پێغەمبەرانە سەبارەت بە مەسیح.‏\f* لەلای ئێمە هاتنە دی،
\v 2 وەک ئەوەی لەلایەن ئەوانەوە پێمان گەیشت کە لە سەرەتاوە شایەتحاڵ و خزمەتکاری پەیامەکە\f + \fr 1:2 \ft یۆنانی: وشەکە: مەبەست لە پەیامی مەسیحە.‏\f* بوون.
\v 3 لەدوای ئەوەی من لە سەرەتاوە پشکنینێکی وردم بۆ هەموو شتێک کرد، ئێستاش بە باشم زانی بە ڕیزبەندی بۆت بنووسم،
\v 4 تاکو لە ڕاستی ئەو قسانە دڵنیابی کە فێرکراوی.
\s1 پێشبینیی لەدایکبوونی حەزرەتی یەحیا
\p 
\v 5 لەو سەردەمەی هێرۆدسی باوک پاشای یەهودیا بوو، کاهینێک\f + \fr 1:5 \ft کاهین: پیاوێکی ئایینی جولەکەیە کە هەڵدەستێ بە ئەرکی قوربانی کردن لەناو پەرستگا و فێرکردنی خەڵک.‏\f* لە نۆرەی نەوەی ئەبیا\f + \fr 1:5 \ft گروپێکی کاهینان بوون لە نەوەی ئەبیا.‏\f* هەبوو کە ناوی زەکەریا بوو، ئەلیساباتی ژنیشی لە نەوەی هارون بوو.
\v 6 هەردووکیان لەبەرچاوی خودا ڕاستودروست بوون، بێ گلەیی بوون لە پەیڕەوکردنی هەموو ڕاسپاردە و حوکمەکانی\f + \fr 1:6 \ft تەورات.‏\f* یەزدان.
\v 7 بەڵام منداڵیان نەدەبوو، چونکە ئەلیسابات نەزۆک بوو، هەردووکیشیان بە ساڵدا چووبوون.
\p 
\v 8 کاتێک زەکەریا لە نۆرەی کۆمەڵەکەی خۆیدا کاروباری کاهینیێتی جێبەجێ دەکرد لەبەردەم خودا،
\v 9 بەگوێرەی نەریتی کاهینیێتی\f + \fr 1:9 \ft یەکێک لە کاهینان هەڵدەستا بە دانانی بخوور لەناو قوربانگا.‏\f*، تیروپشکی کەوتە سەر تاکو بچێتە ناو پەرستگای یەزدان و بخوور بسووتێنێت.
\v 10 لە کاتی سووتانی بخوورەکەدا، خەڵکی هەموو لە دەرەوە نوێژیان دەکرد.
\p 
\v 11 لەوێ فریشتەیەکی یەزدانی بۆ دەرکەوت، لەلای ڕاستی قوربانگای بخوور ڕاوەستابوو.
\v 12 کاتێک زەکەریا فریشتەکەی بینی، پەشۆکا و ترسی لێ نیشت.
\v 13 بەڵام فریشتەکە پێی گوت: «زەکەریا مەترسە، چونکە پاڕانەوەکەت بیسترا، ئەلیساباتی ژنیشت کوڕێکی بۆت دەبێت و ناوی لێ دەنێیت یەحیا\f + \fr 1:13 \ft یەحیا: عیبری: یۆخەننەن، واتا خودا میهرەبانە، لەلای هەندێک بە یۆحەنا ناسراوە.‏\f*.
\v 14 ئەو دەبێتە مایەی خۆشی و شادی بۆ تۆ، زۆر کەس بە لەدایکبوونی دڵخۆش دەبن،
\v 15 چونکە ئەو لەبەرچاوی یەزدان دەبێتە کەسێکی مەزن و پایەبەرز. هەرگیز شەراب و مەی ناخواتەوە. لە سکی دایکییەوە پڕدەبێت لە ڕۆحی پیرۆز و
\v 16 زۆر لە ڕۆڵەکانی ئیسرائیل بۆ لای یەزدانی پەروەردگاری خۆیان دەگەڕێنێتەوە.
\v 17 بە ڕۆح و توانای ئەلیاسەوە پێش یەزدان دەکەوێت\f + \fr 1:17 \ft خودا پێش هاتنی مەسیح یەحیای نارد.‏\f*، تاکو دڵی باوکان بۆ لای منداڵەکان ڕابکێشێت و یاخیبووانیش بۆ لای دانایی ڕاستودروستان بگەڕێنێتەوە، بۆ ئەوەی گەلێکی ئامادە بۆ یەزدان پێکبهێنێت.»
\p 
\v 18 زەکەریاش بە فریشتەکەی گوت: «چۆن لەمە دڵنیا بم، چونکە خۆم پیرم و ژنەکەشم بە ساڵدا چووە؟»
\p 
\v 19 فریشتەکە وەڵامی دایەوە: «من جبرائیلم\f + \fr 1:19 \ft جبرائیل: یەکێکە لەو دوو فریشتەیەی کە لە کتێبی پیرۆزدا ناویان هاتووە، بڕوانە \xt دانیال 8‏:16‏\xt*\ft ‏.‏\f* لەبەردەم خودا ڕادەوەستم، نێردراوم تاکو لەگەڵت بدوێم و ئەم مژدەیەت بدەمێ.
\v 20 ئەوەتا لە ئێستاوە تۆ لاڵ دەبیت و توانای قسەکردنت نامێنێت هەتا ئەو ڕۆژەی ئەم شتانە ڕوودەدەن، چونکە باوەڕت بە قسەکەم نەکرد، ئەوەی لە کاتی خۆیدا دێتە دی.»
\p 
\v 21 خەڵکەکە چاوەڕوانی زەکەریایان دەکرد و سەرسام ببوون لە دواکەوتنی لەناو پەرستگادا.
\v 22 کاتێک هاتە دەرەوە نەیتوانی لەگەڵیان بدوێت، جا زانییان کە لە پەرستگادا بینینێکی بۆ ئاشکرا کراوە، چونکە بە ئیشارەت لەگەڵیان دەدوا و بە لاڵی مایەوە.
\p 
\v 23 کاتێک ڕۆژانی خزمەتکردنەکەی تەواوبوو، گەڕایەوە ماڵ.
\v 24 دوای ئەو ڕۆژانە، ئەلیساباتی ژنی سکی پڕبوو، پێنج مانگ خۆی شاردەوە و دەیگوت:
\v 25 «یەزدان ئەمەی بۆ کردم، لەم ڕۆژانەدا چاکەی خۆی نیشان دا و ئابڕووی منی لەنێو خەڵکدا کڕییەوە.»
\s1 مژدەی لەدایکبوونی عیسا
\p 
\v 26 کاتێک ئەلیسابات سکی شەش مانگ‏‏ بوو، خودا جبرائیلی فریشتەی نارد بۆ شارێک لە ناوچەی جەلیل کە ناوی ناسیرە بوو،
\v 27 بۆ لای پاکیزەیەک کە دەستگیرانی پیاوێک بوو لە بنەماڵەی داود بە ناوی یوسف، ناوی پاکیزەکەش مریەم بوو.
\v 28 جبرائیل هاتە لای مریەم و گوتی: «سڵاو، ئەی ئەو کەسەی نیعمەتی خودات بەسەردا ڕژاوە، یەزدانت لەگەڵە.»
\p 
\v 29 بەڵام ئەو بە پەیامەکە زۆر شێوا و بیری کردەوە دەبێت ئەمە چ جۆرە سڵاوێک بێت.
\v 30 فریشتەکە پێی گوت: «مەترسە مریەم، چونکە لەلای خودا ڕەزامەندیت بەدەستهێنا.
\v 31 ئەوەتا سکت دەبێت و کوڕێکت دەبێت ناوی لێ دەنێیت عیسا.
\v 32 پایەبەرز دەبێت و بە کوڕی خودای هەرەبەرز ناودەبردرێت، خودای پەروەردگاریش تەختی داودی باوکی پێدەداتەوە.
\v 33 هەتاهەتایە حوکمڕانی نەوەی یاقوب دەکات، شانشینەکەشی کۆتایی نایەت.»
\p 
\v 34 بەڵام مریەم بە فریشتەکەی گوت: «ئەمە چۆن دەبێت، کە من هێشتا پاکیزەم؟»
\p 
\v 35 فریشتەکە وەڵامی دایەوە: «ڕۆحی پیرۆز دێتە سەرت و هێزی خودای هەرەبەرز دەبێتە سایەی سەرت. لەبەر ئەوە ئەو پیرۆزەی لێت دەبێت بە کوڕی خودا ناودەبردرێت.
\v 36 ئەوەتا ئەلیساباتی خزمیشت بەو پیرییە سکی پڕە بە کوڕێک. ئەوەی پێیان دەگوت نەزۆک سکی شەش مانگە،
\v 37 چونکە هیچ شتێک لەلای خودا مەحاڵ نییە.»
\p 
\v 38 مریەم گوتی: «ئەوەتا من کارەکەری یەزدانم. ئەوەی تۆ دەیفەرموویت با بێتە دی.» فریشتەکەش بەجێی هێشت.
\s1 دیدەنی مریەم و ئەلیسابات
\p 
\v 39 لەو ڕۆژانەدا، مریەم هەستا و خێرا بۆ شارۆچکەیەک چوو لە ناوچە شاخاوییەکانی هەرێمی یەهودیا.
\v 40 چووە ماڵی زەکەریا و سڵاوی لە ئەلیسابات کرد.
\v 41 کاتێک ئەلیسابات گوێی لە سڵاوەکەی مریەم بوو، منداڵەکە لە سکیدا کەوتە جوڵەجوڵ و ئەلیسابات پڕبوو لە ڕۆحی پیرۆز.
\v 42 ئەلیسابات بە دەنگێکی بەرز هاواری کرد: «لەنێو ژناندا بەرەکەتداریت، بەرهەمی سکت بەرەکەتدار دەبێت!
\v 43 بۆ من کێم تاکو دایکی گەورەکەم بێت بۆ لام؟
\v 44 چونکە هەرکە دەنگی سڵاوەکەت بەر گوێم کەوت، منداڵەکە لە خۆشیدا لە سکمدا هەڵبەزییەوە.
\v 45 خۆزگە دەخوازرێت بەوەی\f + \fr 1:45 \ft بەوەی: لێرەدا دەگەڕێتەوە بۆ کەسی سێیەمی تاکی مێ، کە مەبەستی لە مریەمە.‏\f* باوەڕی هێناوە کە لە یەزدانەوە چی پێ گوتراوە دێتە دی.»
\s1 ستایشی مریەم
\p 
\v 46 مریەمیش گوتی:
\q1 «گیانم ستایشی یەزدان دەکات،
\q2 
\v 47 ڕۆحم بە خودای ڕزگارکەرم دڵشادە،
\q1 
\v 48 چونکە سەیری بێفیزی کارەکەرەکەی کرد.
\q1 ئەوەتا لە ئێستاوە هەموو نەوەکان خۆزگە بە من دەخوازن،
\q2 
\v 49 چونکە توانادار کاری گەورەی بۆ من ئەنجام دا،
\q2 پیرۆزە ناوی ئەو.
\q1 
\v 50 بەزەییەکەی بۆ ئەوانەیە کە لێی دەترسن،
\q2 نەوە دوای نەوە.
\q1 
\v 51 بە بازووی کاری بەهێزی ئەنجام دا،
\q2 ئەوانەی بە بۆچوونەکانی دڵیان لووتبەرز بوون، پەرتوبڵاوی کردنەوە.
\q1 
\v 52 تەختی توانادارەکانی سەرەوژێر کردووە و
\q2 بێفیزەکانی بڵند کردەوە.
\q1 
\v 53 برسییەکانی لە خێروبێر تێر کرد،
\q2 دەوڵەمەندانی بە دەستی بەتاڵ ڕەوانە کردەوە.
\q1 
\v 54 بە یارمەتیدانی گەلی ئیسرائیلی بەندەی خۆی
\q2 هەتاهەتایە بەزەییەکەی بەبیر هێنایەوە
\q1 
\v 55 لەگەڵ ئیبراهیم و نەوەکەی،
\q2 هەروەک بەڵێنی بە باوباپیرانمان دا.»
\p 
\v 56 مریەم لەلای ئەلیسابات نزیکەی سێ مانگ مایەوە، پاشان گەڕایەوە بۆ ماڵەکەی خۆی.
\s1 لەدایکبوونی حەزرەتی یەحیا
\p 
\v 57 ئەلیسابات کاتی منداڵبوونی هات و کوڕێکی بوو.
\v 58 جا دراوسێ و خزمانی بیستیان یەزدان دەرگای بەزەیی فراوانی خۆی بۆ کردووەتەوە، لەگەڵی شادمان بوون.
\p 
\v 59 لە ڕۆژی هەشتەمدا بۆ خەتەنەکردنی منداڵەکە هاتن، لەسەر ناوی باوکی ناویان لێنا زەکەریا.
\v 60 بەڵام دایکی گوتی: «نەخێر، ناوی دەنرێت یەحیا\f + \fr 1:60 \ft بڕوانە \xt 1‏:13‏\xt*\ft .‏\f*.»
\p 
\v 61 پێیان گوت: «کەس لە خزمانت بەم ناوە ناونەنراوە.»
\p 
\v 62 ئینجا ئاماژەیان بۆ باوکی کرد، دەیەوێت چ ناوێکی لێ بنێت.
\v 63 تەختەیەکی داوا کرد و لەسەری نووسی: «ناوی یەحیایە.» هەموو سەرسام بوون.
\v 64 دەستبەجێ دەم و زمانی زەکەریا کرایەوە، دەستی کرد بە قسەکردن و ستایشی خودا.
\v 65 هەموو دراوسێکانیان ترسیان لێ نیشت و لە سەراپای ناوچە شاخاوییەکانی یەهودیا هەموو ئەم شتانە بوون بە قسە و باسی سەر زاری خەڵکی.
\v 66 هەموو ئەوانەی ئەم باسەیان بیست لە دڵی خۆیاندا گوتیان: «ئایا ئەم منداڵە دەبێتە چی؟» چونکە دەستی یەزدانی لەگەڵ بوو.
\s1 ستایشی زەکەریا
\p 
\v 67 زەکەریای باوکیشی پڕبوو لە ڕۆحی پیرۆز و پێشبینی کرد و گوتی:
\q1 
\v 68 «ستایش بۆ یەزدانی پەروەردگاری ئیسرائیل،
\q2 چونکە گەلەکەی بەسەرکردەوە و کڕییەوە\f + \fr 1:68 \ft بە واتای ڕزگاری کرد.‏\f*.
\q1 
\v 69 هێزی ڕزگاریمانی هەستاندەوە،
\q2 لە بنەماڵەی داودی بەندەی،
\q1 
\v 70 وەک چۆن لە کۆنەوە لە ڕێگەی پێغەمبەرە پیرۆزەکانییەوە دواوە،
\q1 
\v 71 بۆ ڕزگاربوون لە دەست دوژمنان و
\q2 هەموو ناحەزانمان،
\q1 
\v 72 هەروەها بۆ بەخشینی بەزەیی بە باوباپیرانمان و
\q2 پەیوەستبوون بە پەیمانە پیرۆزەکەی،
\q2 
\v 73 واتا ئەو سوێندەی کە بۆ ئیبراهیمی باپیرە گەورەمانی خوارد:
\q1 
\v 74 کە ئێمە لە دەست دوژمن ڕزگارمان بێت و
\q2 بێ ترس ئەو بپەرستین،
\q2 
\v 75 هەموو ڕۆژانی ژیانمان بە پیرۆزی و ڕاستودروستی\f + \fr 1:75 \ft لەبەرچاوی خودا ڕاست و دادپەروەرانە بین.‏\f* لەبەردەمیدا بین.
\b
\q1 
\v 76 «تۆش ئەی منداڵ، بە پێغەمبەری خودای هەرەبەرز ناودەبردرێیت،
\q2 چونکە پێش یەزدان دەکەویت، تاکو ڕێگای بۆ ئامادە بکەیت،
\q1 
\v 77 تاکو بە گەلەکەی ڕابگەیەنیت
\q2 بە لێخۆشبوونی گوناهەکانیان ڕزگاریان دەبێت،
\q1 
\v 78 بەهۆی بەزەییە بەسۆزەکەی خودامانەوە،
\q2 کە بەهۆیەوە ڕووناکی لە بەرزاییەوە بەسەرماندا دەدرەوشێتەوە،
\q1 
\v 79 تاکو بەسەر ئەوانەی لە تاریکی و لە سێبەری مەرگدا دانیشتوون بدرەوشێتەوە،
\q2 بۆ ئەوەی پێیەکانمان بە ڕێگای ئاشتیدا ببات.»
\p 
\v 80 منداڵەکەش گەشەی دەکرد و لە ڕۆحدا بەهێز دەبوو، لە‏ چۆڵەوانی مایەوە هەتا ئەو ڕۆژەی کە خۆی بۆ گەلی ئیسرائیل دەرخست.
\c 2
\s1 لەدایکبوونی عیسا
\p 
\v 1 لەو ڕۆژانەدا لە ئۆگستۆس قەیسەرەوە فەرمانێک دەرچوو، کە هەموو دانیشتووانی ئیمپراتۆریەتیەکەی\f + \fr 2:1 \ft مەبەست لە سنووری ئیمپراتۆریەتی ڕۆمانییە.‏\f* ناونووس بکرێت.
\v 2 ئەمە یەکەم ناونووسین بوو، کاتێک کیرینیۆس فەرمانڕەوای سوریا بوو.
\v 3 ئیتر هەرکەس بۆ ناونووسین دەچووە شاری خۆی.
\p 
\v 4 یوسفیش لە جەلیل لە شاری ناسیرەوە بەرەو یەهودیا سەرکەوت بۆ شارەکەی داود کە پێی دەگوترێ بێت‌لەحم، چونکە لە بنەماڵە و تیرەی داود بوو،
\v 5 تاکو لەگەڵ مریەم ناونووس بکرێن کە دەستگیرانی بوو و سکی هەبوو.
\v 6 کە لەوێ بوون، کاتی منداڵبوونی هات.
\v 7 جا کوڕە نۆبەرەکەی بوو، قۆنداغی کرد و لە ئاخوڕێکدا داینا، چونکە هیچ ژوورێکیان بۆ نوستن دەست نەکەوت.
\s1 شوانەکان و فریشتەکان
\p 
\v 8 لەو ناوچەیە شوان هەبوون لە دەشت دەمانەوە و شەوان ئێشکیان لە مێگەلەکەیان دەگرت.
\v 9 فریشتەیەکی یەزدان بۆیان دەرکەوت و شکۆمەندی یەزدان لە دەوریان درەوشایەوە، بەمە ترسێکی زۆریان لێ نیشت.
\v 10 فریشتەکە پێی گوتن: «مەترسن، ئەوا مژدەی خۆشییەکی گەورەتان دەدەمێ کە بۆ هەموو گەلە.
\v 11 ئەمڕۆ لە شاری داود ڕزگارکەرێکتان بۆ لەدایک بوو، ئەویش مەسیحی\f + \fr 2:11 \ft بە زمانی عیبری پێی دەگوترێ \tl مەشیخ‏\tl* یان \tl مەشیح‏\tl*. بە زمانی یۆنانی دەبێتە \tl کریستۆس‏\tl*، کە بە واتای (دەستنیشانکراو) لەلای خودا دێت کە ڕزگارکەری گەلەکەیەتی. بڕوانە یەکەم ساموئێل 16.‏\f* خاوەن شکۆیە.
\v 12 ئەمەش نیشانەیە بۆتان، مەلۆتکەیەک دەبینن لەناو ئاخوڕێک دانراوە.»
\p 
\v 13 لەناکاو لەگەڵ فریشتەکە لەشکرێکی گەورەی ئاسمانی دەرکەوت و ستایشی خودایان دەکرد و دەیانگوت:
\q1 
\v 14 «شکۆ بۆ خودا لە ئاسمان،
\q2 لەسەر زەویش ئاشتی بۆ ئەوانەی جێی ڕەزامەندی ئەون.»
\p 
\v 15 کاتێک فریشتەکان بەرەو ئاسمان بەجێیان هێشتن، شوانەکان بە یەکتریان گوت: «دەی با بڕۆینە بێت‌لەحم و ئەم شتەی ڕوویداوە بیبینین کە یەزدان پێی ڕاگەیاندین.»
\p 
\v 16 خێرا هاتن و مریەم و یوسف و ئەو مەلۆتکەیەی لە ئاخوڕەکەدا دانرابوو دۆزییانەوە.
\v 17 کاتێک بینییان، ئەو قسەیەیان بڵاو کردەوە کە دەربارەی ئەم منداڵە پێیان گوترابوو.
\v 18 هەموو ئەوانەی گوێیان لێبوو، سەریان سوڕمابوو لەوەی شوانەکان پێیان دەگوتن.
\v 19 بەڵام مریەم هەموو ئەم شتانەی لە دڵی خۆیدا هەڵدەگرت و لێکی دەدایەوە.
\v 20 شوانەکان گەڕانەوە و خودایان شکۆدار کرد و ستایشیان کرد لە پێناوی هەموو ئەوەی بیستیان و بینییان، بەو شێوەیەی پێیان گوترابوو.
\s1 خەتەنەکردنی عیسا
\p 
\v 21 لە ڕۆژی هەشتەم کاتی خەتەنەکردنی منداڵەکە هات،\f + \fr 2:21 \ft بڕوانە \xt لێڤییەکان 12‏:3‏\xt*\ft .‏\f* هەر ئەو کاتەش ناوی لێنرا عیسا، بەو شێوەیەی فریشتەکە ناوی لێنا، پێش ئەوەی مریەم سکی پڕبێت.
\p 
\v 22 پاشان یوسف و مریەم لەدوای تەواوبوونی ڕۆژانی پاکبوونەوە\f + \fr 2:22 \ft پاکبوونەوەی مریەم لە زەیستانی، بەگوێرەی نەریتی تەورات ئافرەت لەم ماوەیەدا گڵاوە. بڕوانە \xt لێڤییەکان 12‏:1‏-7.‏\xt*\ft ‏\f* عیسایان بردە ئۆرشەلیم تاکو پێشکەشی یەزدانی بکەن، بەگوێرەی تەوراتی موسا،
\v 23 کە تەوراتی یەزدانە، هەروەک تێیدا نووسراوە: ﴿هەر نێرینەیەکی نۆبەرە بۆ یەزدان تەرخان دەکرێت‏.﴾\f + \fr 2:23 \ft \xt دەرچوون 13‏:2‏،12‏\xt*\ft ‏.‏\f*
\v 24 بۆ پێشکەشکردنی قوربانییەکیش، بەگوێرەی ئەوەی لە تەوراتی یەزدان گوتراوە: ﴿دوو کوکوختی یان دوو بێچووە کۆتر‏.﴾\f + \fr 2:24 \ft \xt لێڤییەکان 12‏:8.‏\xt*\ft ‏\f*
\p 
\v 25 پیاوێکی چاک و لەخواترس بە ناوی شیمۆن لە ئۆرشەلیم هەبوو، چاوەڕێی هاتنی دڵنەواییکەری\f + \fr 2:25 \ft هاتنی مەسیح، بۆ ڕزگارکردنی گەل لەژێر بارگرانی گوناه.‏\f* ئیسرائیل بوو، ڕۆحی پیرۆزی لەسەر بوو.
\v 26 بە ڕۆحی پیرۆز بۆی ئاشکرا کرابوو کە نامرێت هەتا مەسیحی یەزدان نەبینێت.
\v 27 بەهۆی ڕۆحی پیرۆزەوە هاتە حەوشەکانی پەرستگا. کاتێک دایک و باوکەکە عیسای منداڵیان هێنایە ژوورەوە، تاکو بەگوێرەی نەریتی تەوراتی بۆ بکەن،
\v 28 شیمۆن عیسای لە باوەشی گرت و ستایشی خودای کرد:
\q1 
\v 29 «ئەی یەزدانی باڵادەست، ئێستا بەگوێرەی قسەکەت
\q2 بەندەی خۆت بە ئاشتی بەڕێبکە.
\q1 
\v 30 ئەوا چاوم ڕزگاریی\f + \fr 2:30 \ft مەبەستی لە عیسای ڕزگارکەرە.‏\f* تۆی بینی،
\q2 
\v 31 ئەوەی لەبەردەم هەموو گەلان ئامادەت کردووە،
\q1 
\v 32 هەتا ببێتە ڕووناکی بۆ ئاشکراکردنی سروشی تۆ بۆ نەتەوەکان و
\q2 ببێتە مایەی شکۆمەندی بۆ ئیسرائیلی گەلەکەت.»
\p 
\v 33 دایک و باوکی\f + \fr 2:33 \ft لە باری کۆمەڵایەتییەوە یوسف وەک باوکی عیسا ناسراوە، بەهۆی ئەوەی مێردی مریەم بووە لە منداڵییەوە ئەو عیسای بەخێو کردووە.‏\f* سەرسام بوون لەوەی دەربارەی گوترا.
\v 34 شیمۆن داوای بەرەکەتی بۆ کردن و بە مریەمی دایکی گوت: «ئا ئەم منداڵە دەبێتە هۆی کەوتن و هەستانەوەی کەسانێکی زۆر لە ئیسرائیل، هەروەها دەبێتە نیشانەیەک دژایەتی دەکرێت،
\v 35 هەتا نیازی دڵی زۆر‏ کەس ئاشکرابێت. تۆش شمشێرێک جەرگت دەبڕێت.»
\p 
\v 36 پێغەمبەرێکی ژن هەبوو بە ناوی ئانای کچی پەنوئێل لە هۆزی ئاشێر. زۆر بە ساڵدا چوو بوو، لەدوای شووکردنی تەنها حەوت ساڵ لەگەڵ مێردەکەی ژیابوو،
\v 37 پاشان بە بێوەژنی مابووەوە و تەمەنی گەیشتبووە هەشتا و چوار ساڵ. پەرستگای بەجێ نەدەهێشت، شەو و ڕۆژ بە نوێژ و ڕۆژوو خودای دەپەرست.
\v 38 هەر لەو کاتەدا هات بۆ لای ئەوان و ستایشی خودای کرد، باسی منداڵەکەی بۆ هەموو ئەوانە کرد کە چاوەڕوانی ڕزگاریی\f + \fr 2:38 \ft لە یۆنانی وشەیەک بەکارهاتووە بە واتای کڕینەوە دێت، کە مەبەستی لە کڕینەوەی مرۆڤە بە مەبەستی ڕزگارکردنی. بڕوانە دەرچوون 14، \xt عیبرانییەکان 9‏:12.‏\xt*\ft ‏\f* ئۆرشەلیم بوون.
\p 
\v 39 کە هەموو شتێکیان بەگوێرەی تەوراتی یەزدان تەواو کرد، هاتنەوە بۆ ناسیرەی شارەکەی خۆیان لە ناوچەی جەلیل.
\v 40 منداڵەکەش گەشەی دەکرد و بەهێز دەبوو، پڕبوو لە دانایی و نیعمەتی خوداشی\f + \fr 2:40 \ft نیعمەتی خودا لێرەدا مەبەست لەو بەخشینە خوداییە کە دەبێتە مایەی گەشەکردنی ڕۆحی و هزری. بڕوانە \xt 2‏:42‏\xt*\ft .‏\f* لەسەر بوو.
\s1 عیسا لە پەرستگادا
\p 
\v 41 دایک و باوکی هەموو ساڵێک لە جەژنی پەسخە دەچوونە ئۆرشەلیم.
\v 42 کاتێک عیسا بووە دوازدە ساڵ، وەک نەریتی جەژن بەرەو ئۆرشەلیم سەرکەوتن.
\v 43 دوای تەواوبوونی جەژن و لە گەڕانەوەیاندا، بەبێ ئەوەی دایک و باوکی بزانن، عیسای مێردمنداڵ لە ئۆرشەلیم مایەوە.
\v 44 لەبەر ئەوەی پێیان وابوو لەنێو کاروانەکەیە، ڕۆژە ڕێیەک ڕۆیشتن. دوای ئەوە لەناو خزم و ناسیاوەکاندا بەدوایدا گەڕان.
\v 45 کاتێک نەیاندۆزییەوە، گەڕانەوە بۆ ئۆرشەلیم بۆ ئەوەی بەدوایدا بگەڕێن.
\v 46 دوای سێ ڕۆژ لە حەوشەکانی پەرستگادا دۆزیانەوە، بینییان لەناو مامۆستایان دانیشتووە، گوێیان لێ دەگرێت و پرسیاریان لێدەکات.
\v 47 هەموو ئەوانەی گوێیان لێی ڕاگرتبوو، لە تێگەیشتن و وەڵامەکانی سەرسام بوون.
\v 48 کاتێک بینییان واقیان وڕما، ئینجا دایکی پێی گوت: «کوڕم، بۆ وات لێکردین؟ من و باوکت نیگەرانت بووین و بەدواتدا دەگەڕاین.»
\p 
\v 49 وەڵامی دانەوە: «بۆچی بەدوامدا دەگەڕان؟ نەتاندەزانی پێویستە لە ماڵی باوکمدا بم؟»
\v 50 بەڵام لەو قسەیە تێنەگەیشتن کە پێی فەرموون.
\p 
\v 51 ئینجا لەگەڵیان گەڕایەوە و هاتەوە ناسیرە و گوێڕایەڵیان بوو. مریەمی دایکی ئەمانەی هەموو دەخستە دڵییەوە.
\v 52 عیساش لە دانایی و باڵا گەشەی دەکرد، جێی ڕەزامەندی خودا و خەڵکی بوو.
\c 3
\s1 یەحیای لەئاوهەڵکێش
\p 
\v 1 لە ساڵی پازدەمینی\f + \fr 3:1 \ft نزیکەی 25‏–26ی زایینی.‏\f* حوکمڕانی تێباریۆس قەیسەر، کاتێک پیلاتۆسی پۆنتی فەرمانڕەوای یەهودیا بوو، هێرۆدسی ئەنتیپاس\f + \fr 3:1 \ft یۆنانی: هێرۆدس: هێرۆدسی ئەنتیپاس کوڕی شا هێرۆدسی مەزن بوو، کە لە \xt لۆقا 1‏:5‏\xt*\ft ‏ باسکراوە.‏\f* فەرمانڕەوای\f + \fr 3:1 \ft یۆنانی: \tl تیترارک‏\tl*: فەرمانڕەوا لەسەر چواریەکی هەرێمێک لەژێر دەسەڵاتی ڕۆمانی.‏\f* جەلیل بوو، فیلیپۆسی براشی فەرمانڕەوای ئیتۆریە و تەراخۆنیتس بوو، لیسانیۆس فەرمانڕەوای ئەبیلینە بوو،
\v 2 لە سەردەمی سەرۆک کاهینیێتی حەنا و قەیافا، لە دەشتودەر پەیامی خودا بۆ یەحیای کوڕی زەکەریا هات.
\v 3 ئیتر بە هەموو ناوچەکانی دەوروبەری ڕووباری ئوردوندا دەگەڕا، جاڕی لەئاوهەڵکێشانی\f + \fr 3:3 \ft یۆنانی: \tl باپتسمە‏\tl*، بە واتای شوشتن دێت بۆ پاکبوونەوە لە گوناه، وەک (بسمیلکردن).‏\f* تۆبەکردنی دەدا بۆ گوناه بەخشین.
\v 4 وەک لە پێشبینییەکانی پەڕتووکی ئیشایای پێغەمبەردا نووسراوە:
\q1 ﴿کەسێک لە چۆڵەوانی هاوار دەکات و دەڵێت:
\q1 «ڕێگا بۆ هاتنی یەزدان ئامادە بکەن،
\q2 ڕێچکەکانی بۆ ڕێکبخەن.»
\q1 
\v 5 هەموو دۆڵێک پڕ دەبێتەوە و
\q2 هەموو چیا و گردێک ڕۆدەچێت،
\q1 ڕێگا خواروخێچەکان ڕاست دەبنەوە و
\q2 سەختەکانیش ئاسان دەبن،
\q1 
\v 6 هەموو مرۆڤایەتی ڕزگاریی خودا دەبینن!﴾\f + \fr 3:6 \ft \xt ئیشایا 40‏:3‏-5.‏\xt*\ft ‏\f*
\p 
\v 7 یەحیا بەو خەڵکانەی دەگوت کە دەهاتن تاکو لە ئاویان هەڵکێشێت: «ئەی بێچووە ماران، کێ ئاگاداری کردوونەتەوە لە دەست تووڕەیی داهاتوو هەڵبێن؟
\v 8 با بەرهەمێکتان هەبێت لە تۆبەکردن بوەشێتەوە. بە خۆتان مەڵێن: ”ئیبراهیم باوکمانە.“ پێتان دەڵێم، خودا دەتوانێت لەم بەردانە نەوە بۆ ئیبراهیم دروستبکات.
\v 9 ئەوەتا تەور خراوەتە سەر ڕەگی دار، هەر دارێک بەرهەمی باش نەدات، دەبڕدرێتەوە و فڕێدەدرێتە ناو ئاگرەوە.»
\p 
\v 10 خەڵکەکە پرسیاریان لێکرد: «کەواتە چی بکەین؟»
\p 
\v 11 وەڵامی دانەوە: «ئەوەی دوو کراسی هەیە، با یەکێکیان بداتە ئەوەی کە نییەتی، ئەوەش کە نانی هەیە، با هەمان شت بکات.»
\p 
\v 12 باجگرانیش بۆ لەئاوهەڵکێشان هاتن، لێیان پرسی: «مامۆستا، ئێمە چی بکەین؟»
\p 
\v 13 پێی گوتن: «لەوەی بۆتان دانراوە زیاتر وەرمەگرن.»
\p 
\v 14 سەربازانیش پرسیاریان لێکرد: «ئەی ئێمە چی بکەین؟»
\p یەحیاش وەڵامی دانەوە: «خاوە لە کەس وەرمەگرن و بوختان مەکەن، بە مووچەکانتان ڕازی بن.»
\p 
\v 15 گەل لە چاوەڕوانیدا بوون، هەموو لە دڵی خۆیاندا دەربارەی یەحیا لێکیان دەدایەوە کە لەوانەیە یەحیا خۆی مەسیح بێت.
\v 16 یەحیا وەڵامی هەمووانی دایەوە: «من لە ئاوتان هەڵدەکێشم، بەڵام یەکێک دێت لە من بەتواناترە، ئەوەی من شایانی ئەوە نیم کە قەیتانی پێڵاوەکانی بکەمەوە. ئەو لە ڕۆحی پیرۆز و لە ئاگرتان هەڵدەکێشێت\f + \fr 3:16 \ft واتا پاکبوونەوە لە گوناه بەهۆی ڕۆحی پیرۆزەوە.‏\f*.
\v 17 شەنی بەدەستەوەیە بۆ پاککردنەوەی جۆخینەکەی\f + \fr 3:17 \ft جۆخین یان سەرخەرمان ئەو زەوییە تەرخانکراوەیە کە لەلایەن وەرزێر و جوتیارەوە بەکارهێنراوە بۆ کوتانی دانەوێڵە لەسەری لەدوای کۆکردنەوەی لە کێڵگە.‏\f*، گەنمەکە لە ئەمباردا کۆدەکاتەوە و قەسەڵەکەش\f + \fr 3:17 \ft قەسەڵ: قەسەر.‏\f* بە ئاگرێکی نەکوژاوە دەسووتێنێت.»
\v 18 بە زۆر شتی دیکەش ئامۆژگاری گەلی دەکرد و مژدەی دەدانێ.
\p 
\v 19 بەڵام کاتێک یەحیا سەرزەنشتی هێرۆدسی ئەنتیپاسی فەرمانڕەوای جەلیلی کردبوو لەبەر ئەوەی کە هێرۆدیای براژنی خۆی هێنابوو و هەروەها لەبەر هەموو ئەو خراپانەی کردبووی،
\v 20 ئەم خراپەیەشی خستە پاڵ هەموو ئەوانە، یەحیای لە زیندان بەندکرد.
\s1 لەئاوهەڵکێشانی عیسا
\p 
\v 21 کاتێک گەل هەموو لە ئاو هەڵکێشران، عیساش لە ئاو هەڵکێشرا. کاتێک کە عیسا نوێژی دەکرد ئاسمان کرایەوە و
\v 22 ڕۆحی پیرۆز لە شێوەی جەستەی کۆترێک لەسەری نیشتەوە و دەنگێک لە ئاسمانەوە هات: «تۆ کوڕی خۆشەویستمی، بە تۆ زۆر دڵشادم.»
\s1 بنەچەی عیسا
\p 
\v 23 کاتێک عیسا دەستی بە خزمەتەکەی کرد تەمەنی نزیکەی سی ساڵ بوو. وا دەزانرا کە کوڕی یوسفی،
\b
\li1 کوڕی هەلی،
