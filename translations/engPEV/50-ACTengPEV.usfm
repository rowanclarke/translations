\p 
\v 26 \w That|strong="G3588"\w* boss soldier heard \w what|strong="G5101"\w* \w Paul|strong="G1510"\w* \w said|strong="G3004"\w*, \w then|strong="G1161"\w* \w he|strong="G1161"\w* \w went|strong="G4334"\w* \w to|strong="G3004"\w* \w the|strong="G1161"\w* big boss soldier \w and|strong="G1161"\w* \w told|strong="G3004"\w* \w him|strong="G3588"\w* \w about|strong="G3195"\w* \w Paul|strong="G1510"\w*. \w He|strong="G1161"\w* \w said|strong="G3004"\w*, “\w This|strong="G3778"\w* \w man|strong="G3778"\w* \w is|strong="G1510"\w* \w not|strong="G1510"\w* \w just|strong="G3588"\w* \w a|strong="G1510"\w* Jew, \w he|strong="G1161"\w* \w is|strong="G1510"\w* \w a|strong="G1510"\w* \w Roman|strong="G4514"\w* too. \w Do|strong="G4160"\w* \w you|strong="G3004"\w* really want \w us|strong="G3004"\w* \w to|strong="G3004"\w* whip \w him|strong="G3588"\w*?”
