\id 2JN  
\h SEGUNDA JUAN 
\toc1 Si₂ carta jë₁ca₂të́₂ tɨn₃ a₂ca₂jmo₃ SAN JUAN 
\toc2 SEGUNDA JUAN 
\toc3 2 Jn. 
\mt2 Si₂ carta jë₁ca₂të́₂ tɨn₃ a₂ca₂jmo₃ 
\mt1 SAN JUAN 
\c 1  
\s1 Jág₁ dsau₅, quian'₅₄ 'a₂ lia'₂ 'nió'₅ jme₃'nio₃ dsa₂ rɨin'₅₄ 
\p  
\v 1 Jniá₂ i₂lɨ́ng₅ gui'₅₄ juɨn'₂ quián₅ guá'₅ jmo₂₃ si₂ la₂ tsɨ́ng₂ ne'₅₄ 'ne₂ 'io₅₄\f + \fr 1:1 \ft I₂lɨn₅₄ të₅sí₃ ŋɨ́'₂ dsɨ́₅ juɨ₁lia'₂ jág₁ në₅, co₂'nió'₄ të́'₂ guá'₅ në₂jag₄ bá₄ jan₂ 'io₅₄; chi'₂ quiáin₅ guë'₂ në́₃, co₂'nió'₄ dsa₂ i₂tén₅ guá'₅.\f* rɨn'₅₄ jniog₄ i₂ma₂quion'₅₄ quián₅ Diú₄, quian'₅₄ chi'₂ quiáng'₂ i₂'nióg₃ guë́₄ lɨn₃. On₃jua'₅₄ jmá'₃ jniá₂ 'nióg₃ 'nia'₂, ján₃ bá₄ 'nio₃ ca₂le₃jɨ́n₃ i₂ma₂le₁ŋi₅ jág₁ tí₅.  
\v 2 O₄quió'₄ jág₁ dsau₅ bá₄ 'nióg₃ 'nia'₂, jág₁ a₂ma₂të₁'ŋiá₄ të₂dsɨ₅ jniog₄, ton'₂ jiog₅ co₂tan₅₄ ja₁con₂ jniog₄.  
\v 3 Diú₄ Jmei₂ quian'₅₄ Te₁gui'₅₄ Jesucristo Ja₁ŋi'₅₄, juɨ₁jme₂gu'₅₄, dsia₃ ŋéi'₂ dsɨ́₅, jmo₃ 'ag₃ tei₄ 'au'₂ 'nia'₂, ia₁ a₂dsón'₂ bá₄ 'nioi₃ 'nia'₂. 
\p  
\v 4 'Ŋio₅ të₅ dsɨ₃ ia₁ ma₂jɨng₅₄ i₂lɨn₅₄ chi'₂ quiáng'₂ tiáin'₅ bá₄ lia'₂ con'₂ lë́₅ jág₁ tí₅, lia'₂ con'₂ lë́₅ juá'₂ Diú₄ Jmei₂ jniog₄, 'éi'₃ a₂ma₂cuë₃.  
\v 5 Në₃ në́₃ 'io₅₄ rɨn'₅₄ jniog₄, mɨ₅ jniá₂ juɨ́g₂ 'ne₂, a₂jme₁'nió₄ jniog₄ rɨn'₅₄ le₂jau₂ le₂jau₂. A₂juá'₅ jniá₂ ne₄ si₂ la₂, on₃jua'₅₄ 'éi'₃ 'mɨ́₂ la₂, 'éi'₃ jaun₂ bá₄ la₂ juɨ₁lia'₂ 'éi'₃ a₂jme₁ma₂ron₅ quián₂ jniog₄ le₂'uɨg₅₄.  
\v 6 Le₂në₅ bá₄ jme₁'nió₄ jniog₄ rɨn'₅₄: a₂i₂nio₄ jniog₄ lia'₂ con'₂ lë́₅ 'éi'₃ quió'₅ Diú₄. 'Éi'₃ a₂ma₂nei'₂ 'nia'₂ le₂'uɨg₅₄ bá₄ jaun₂, a₂le₃chang'₂ jme₁'nióg'₄ rɨ́ng'₂. 
\s1 Juɨ₁lia'₂ dsa₂ i₂jme₂gau₅ 
\p  
\v 7 Le₂con₂ mɨ₂güɨ́g₃ bá₄ i₂nio₄ juɨn₅ dsa₂ i₂jme₂gau₅, tsá₃ jág₁ jmo₂₃ jua'₅₄ a₂juá'₂ a₂ca₂guan₃ Te₁gui'₅₄ chi₁dsáin₃. Dsa₂ le₂'éi₂ bá₄ lɨ́n₅ i₂jme₂gau₅, i₂'ŋia₅₄ Cristo në́₃.  
\v 8 Jmo₄ 'nia'₂ 'í₁ ia₁jaun₂ tsá₃ lë₁dsɨ₃'én₂ ta₁ quián'₂ 'nia'₂ a₂jmo'₂ ia₁ 'éng'₂, jaun₂ bá₄ tɨn'₃ 'nia'₂ lia'₂ 'ŋia₅ 'liang'₅₄ cuë₃ Diú₄. 
\p  
\v 9 Ia₁ juɨ₁'ein₂ guë́₃ i₂dsɨ₂jŋiá₄ jmo₂₃ ŋag₅₄ guë́₄ jme₂tag₂₃ con'₂ jág₁ a₂ma₂ca₂jme₃tag₅ Cristo, tsá₃ Diú₄ quian'₅₄ dsa₂ 'éi₂. La₁ juɨ₁lia'₂ i₂juá'₂ jme₂tag₂₃ con'₂ lë́₅ ca₂jme₃tag₅ Cristo, chan₂ Diú₄ Jmei₂ ja₁coin₂, ján₃ guë'₂ quiain'₅₄ bá₄ Ja₁ŋi'₅₄ Diú₄ në́₃.  
\v 10 Në₁jua'₂ chan₂ i₂ca₂dsióg₃ ja₁con'₂ 'nia'₂, la₁ në₁jua'₂ tsá₃ jme₂tag₂₃ lia'₂ con'₂ lë́₅ jág₁ në₅, tsá₃ lë₁guéin₅ 'nia'₂ dsi₂néi₂ quiáng'₂, ca₂lia'₂ jŋia'₅₄ Diú₄ tsá₃ 'nió'₅ cuɨ́in'₄ 'nia'₂.  
\v 11 Ia₁ në₁jua'₂ chan₂ i₂ca₂cuɨn₃ Diú₄ dsa₂ le₂'éi₂, co₂'nió'₄ quein'₅₄ 'e₂ a₂'lɨg'₅₄ a₂jmo₅-dsáu₅ 'éi₂. 
\s1 Jág₁ jë₁ca₂tó'₂ 
\p  
\v 12 'Lióng₂ bá₄ jág₁ a₂'nio₃ jniá₂ juɨg₅₄ 'nia'₂, la₁ tsá₃ 'nio₃ jniá₂ jua'₅₄ a₂juá'₄ të₂le₃ quian'₅₄ si₂, on₃ guë'₂ quian'₅₄ jmɨ₁jné₂. Ia₁ 'ɨ́n₂ dsɨ₃ jniá₂ dsióg₄ bá₄ 'ŋió₃ ia₁jaun₂ dsiá₁ jniog₄ jág₁ dsi₁ne₁, ia₁jaun₂ le₃'ŋia₅ a₂'io'₂ jein₂ jniog₄. 
\p  
\v 13 Chi'₂ quián₅ 'io₅₄ rɨ́ng'₂ i₂ma₂quion'₅₄ quián₅ Diú₄, dsiáin'₂ jág₁ a₂cuɨin₂₃ Diú₄ 'nia'₂. 
\p Co₂në₅.