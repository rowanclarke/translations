\b  
\m
\v 4 \w The|strong="H5414"\w* \w pasturelands|strong="H4054"\w* \w around|strong="H5439"\w* \w the|strong="H5414"\w* \w cities|strong="H5892"\w* \w you|strong="H5414"\w* \w are|strong="H5892"\w* \w to|strong="H5414"\w* \w give|strong="H5414"\w* \w the|strong="H5414"\w* \w Levites|strong="H3881"\w* \w will|strong="H5892"\w* extend \w a|strong="H3068"\w* thousand cubits \f + \fr 35:4 \ft 1,000 cubits is approximately 1,500 feet or 457.2 meters.\f* \w from|strong="H3881"\w* \w the|strong="H5414"\w* \w wall|strong="H7023"\w* \w on|strong="H5892"\w* \w every|strong="H5439"\w* \w side|strong="H5439"\w*.  
\v 5 \w You|strong="H8432"\w* \w are|strong="H5892"\w* \w also|strong="H2088"\w* \w to|strong="H1961"\w* \w measure|strong="H4058"\w* \w two|strong="H6285"\w* thousand cubits \f + \fr 35:5 \ft 2,000 cubits is approximately 3,000 feet or 914.4 meters.\f* \w outside|strong="H2351"\w* \w the|strong="H8432"\w* \w city|strong="H5892"\w* \w on|strong="H1961"\w* \w the|strong="H8432"\w* \w east|strong="H6924"\w*, \w two|strong="H6285"\w* thousand \w on|strong="H1961"\w* \w the|strong="H8432"\w* \w south|strong="H5045"\w*, \w two|strong="H6285"\w* thousand \w on|strong="H1961"\w* \w the|strong="H8432"\w* \w west|strong="H3220"\w*, \w and|strong="H5892"\w* \w two|strong="H6285"\w* thousand \w on|strong="H1961"\w* \w the|strong="H8432"\w* \w north|strong="H6828"\w*, \w with|strong="H5892"\w* \w the|strong="H8432"\w* \w city|strong="H5892"\w* \w in|strong="H8432"\w* \w the|strong="H8432"\w* \w center|strong="H8432"\w*. \w These|strong="H2088"\w* \w areas|strong="H4054"\w* \w will|strong="H1961"\w* \w serve|strong="H1961"\w* \w as|strong="H1961"\w* larger \w pasturelands|strong="H4054"\w* \w for|strong="H5892"\w* \w the|strong="H8432"\w* \w cities|strong="H5892"\w*.   
\b  
