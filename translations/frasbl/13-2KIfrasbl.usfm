\v 3 Mais l'\w ange|strong="H4397"\w* \w du|strong="H5927"\w* \w SEIGNEUR|strong="H4428"\w*\f + \fr 1.3 \ft Lorsqu'il est écrit en MAJUSCULES, « SEIGNEUR » ou « DIEU » est la traduction du nom propre de Dieu (en hébreu « \wh יהוה\wh* », généralement prononcé Yahvé).\f* \w dit|strong="H1696"\w* \w à|strong="H3068"\w* \w Élie|strong="H5927"\w* \w le|strong="H3068"\w* \w Thischbite|strong="H8664"\w* : « \w Lève-toi|strong="H6965"\w*, \w monte|strong="H5927"\w* \w à|strong="H3068"\w* \w la|strong="H3068"\w* \w rencontre|strong="H7125"\w* \w des|strong="H3068"\w* \w messagers|strong="H4397"\w* \w du|strong="H5927"\w* \w roi|strong="H4428"\w* \w de|strong="H4428"\w* \w Samarie|strong="H8111"\w*, \w et|strong="H3068"\w* \w dis-leur|strong="H6965"\w* : « Est-ce parce qu'\w il|strong="H3068"\w* n'\w y|strong="H3068"\w* \w a|strong="H3068"\w* \w point|strong="H3068"\w* \w de|strong="H4428"\w* \w Dieu|strong="H3068"\w*\f + \fr 1.3 \ft Le mot hébreu rendu par « Dieu » est « \wh אֱלֹהִ֑ים\wh* » (Elohim).\f* \w en|strong="H3068"\w* \w Israël|strong="H3478"\w* \w que|strong="H4428"\w* \w vous|strong="H3068"\w* \w allez|strong="H1980"\w* \w consulter|strong="H1875"\w* Baal-Zébub, \w le|strong="H3068"\w* \w dieu|strong="H3068"\w* d'\w Ékron|strong="H6138"\w* ?
\v 4 C'\w est|strong="H3068"\w* \w pourquoi|strong="H3651"\w* \w ainsi|strong="H3541"\w* \w parle|strong="H3541"\w* \w le|strong="H3068"\w* \w SEIGNEUR|strong="H3068"\w* : \w Tu|strong="H3588"\w* \w ne|strong="H3808"\w* \w descendras|strong="H3381"\w* \w pas|strong="H3808"\w* \w du|strong="H5927"\w* \w lit|strong="H4296"\w* \w sur|strong="H3068"\w* \w lequel|strong="H3068"\w* \w tu|strong="H3588"\w* \w es|strong="H3588"\w* \w monté|strong="H5927"\w*, \w mais|strong="H3588"\w* \w tu|strong="H3588"\w* \w mourras|strong="H4191"\w* \w assurément|strong="H3651"\w*. » » \w Puis|strong="H3808"\w* \w Élie|strong="H5927"\w* s'\w en|strong="H3068"\w* \w alla|strong="H3212"\w*.
\p 
