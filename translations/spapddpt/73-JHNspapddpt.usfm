\v 7 \w Entonces|strong="G2532"\w* \w el|strong="G3588"\w* \w discípulo|strong="G3101"\w* \w a|strong="G1519"\w* \w quien|strong="G3739"\w* \w Jesús|strong="G2424"\w* amaba, \w dijo|strong="G3004"\w* \w a|strong="G1519"\w* \w Pedro|strong="G1565"\w*: ¡\w Es|strong="G3739"\w* \w el|strong="G3588"\w* \w Señor|strong="G2962"\w*!  
\p Cuando \w Simón|strong="G4613"\w* \w Pedro|strong="G1565"\w* oyó: \w Es|strong="G3739"\w* \w el|strong="G3588"\w* \w Señor|strong="G2962"\w*, \w se|strong="G1438"\w* ató \w el|strong="G3588"\w* manto externo, \w pues|strong="G3767"\w* \w se|strong="G1438"\w* había despojado \w de|strong="G1519"\w* \w él|strong="G3588"\w*, \w y|strong="G2532"\w* \w se|strong="G1438"\w* lanzó \w al|strong="G3588"\w* \w mar|strong="G2281"\w*.   
\p
