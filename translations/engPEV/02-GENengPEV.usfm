\p
\v 10 \w Then|strong="H1961"\w* Jacob said, “\w One|strong="H1961"\w* \w time|strong="H6256"\w*, \w I|strong="H2009"\w* \w had|strong="H1961"\w* \w a|strong="H3068"\w* \w dream|strong="H2472"\w*. \w It|strong="H5921"\w* \w was|strong="H1961"\w* \w the|strong="H5921"\w* month \w when|strong="H1961"\w* \w the|strong="H5921"\w* \w male|strong="H6260"\w* \w and|strong="H5869"\w* female \w animals|strong="H1961"\w* join \w together|strong="H5921"\w* \w to|strong="H5927"\w* \w make|strong="H7200"\w* babies. \w In|strong="H5921"\w* \w that|strong="H7200"\w* \w dream|strong="H2472"\w*, \w I|strong="H2009"\w* \w saw|strong="H7200"\w* \w male|strong="H6260"\w* \w and|strong="H5869"\w* female \w goats|strong="H6260"\w* joining \w together|strong="H5921"\w*, \w and|strong="H5869"\w* \w all|strong="H7200"\w* \w the|strong="H5921"\w* \w male|strong="H6260"\w* \w goats|strong="H6260"\w* \w had|strong="H1961"\w* black \w and|strong="H5869"\w* white spots \w and|strong="H5869"\w* stripes \w on|strong="H5921"\w* \w their|strong="H5375"\w* wool.  
