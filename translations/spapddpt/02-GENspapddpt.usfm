\v 9 \w También|strong="H1571"\w* \w subieron|strong="H5927"\w* \w con|strong="H5973"\w* \w él|strong="H5973"\w* carrozas \w y|strong="H1571"\w* \w jinetes|strong="H6571"\w*, \w y|strong="H1571"\w* \w se|strong="H1961"\w* formó un cortejo \w muy|strong="H3966"\w* \w grande|strong="H3515"\w*.   
\p
\v 10 \w Cuando|strong="H3117"\w* llegaron \w a|strong="H3068"\w* la era \w de|strong="H5704"\w* Atad \w que|strong="H5704"\w* \w está|strong="H8033"\w* \w al|strong="H5704"\w* otro \w lado|strong="H5676"\w* del \w Jordán|strong="H3383"\w*, \w hicieron|strong="H6213"\w* una lamentación \w muy|strong="H3966"\w* \w grande|strong="H1419"\w* \w y|strong="H5704"\w* solemne. José \w hizo|strong="H6213"\w* duelo \w por|strong="H5704"\w* su padre \w siete|strong="H7651"\w* \w días|strong="H3117"\w*.  
\v 11 Cuando \w los|strong="H3427"\w* \w cananeos|strong="H3669"\w*, \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* \w de|strong="H5921"\w* \w aquella|strong="H5921"\w* tierra, \w vieron|strong="H7200"\w* \w el|strong="H5921"\w* duelo \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w era|strong="H2088"\w* \w de|strong="H5921"\w* Atad, dijeron: \w Este|strong="H2088"\w* \w es|strong="H2088"\w* un profundo duelo \w de|strong="H5921"\w* \w los|strong="H3427"\w* \w egipcios|strong="H4713"\w*. \w Por|strong="H5921"\w* \w tanto|strong="H3651"\w*, \w aquel|strong="H2088"\w* lugar fue \w llamado|strong="H8034"\w* Duelo \w de|strong="H5921"\w* \w los|strong="H3427"\w* \w Egipcios|strong="H4713"\w*, \w el|strong="H5921"\w* cual \w está|strong="H2088"\w* \w al|strong="H5921"\w* \w otro|strong="H2088"\w* \w lado|strong="H5676"\w* \w del|strong="H5921"\w* \w Jordán|strong="H3383"\w*.   
\p
\v 12 Sus \w hijos|strong="H1121"\w* \w hicieron|strong="H6213"\w* \w como|strong="H3651"\w* Israel \w les|strong="H6680"\w* \w ordenó|strong="H6680"\w*.  
\v 13 \w Lo|strong="H5921"\w* \w llevaron|strong="H5375"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w Canaán|strong="H3667"\w* \w y|strong="H5921"\w* \w lo|strong="H5921"\w* \w sepultaron|strong="H6912"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w cueva|strong="H4631"\w* \w del|strong="H5921"\w* \w campo|strong="H7704"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* Macpela, \w campo|strong="H7704"\w* \w que|strong="H5921"\w* Abraham \w compró|strong="H7069"\w* \w a|strong="H3068"\w* Efrón heteo, \w como|strong="H5921"\w* propiedad \w para|strong="H5921"\w* \w sepultura|strong="H6913"\w*, \w en|strong="H5921"\w* frente \w de|strong="H5921"\w* \w Mamre|strong="H4471"\w*.   
