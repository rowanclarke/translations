\p
\v 11 \w Aka\w* \w khawn|strong="G3885"\w* \w te|strong="G3588"\w*, “\wj \+w Namah|strong="G4671"\+w*taengah kan \+w thui|strong="G3004"\+w*, \+w thoo|strong="G1453"\+w*, \+w na|strong="G4675"\+w* \+w phakdoeng|strong="G2895"\+w* \+w te|strong="G3588"\+w* \+w kawt|strong="G0142"\+w* \+w lamtah|strong="G2532"\+w* \+w namah|strong="G4675"\+w* \+w im|strong="G3624"\+w* \+w la|strong="G1519"\+w* \+w cet|strong="G5217"\+w* laeh,” \wj* \w a \w*\w ti \w*\w nah\w*.   
\p
\v 12 Te \w vaengah|strong="G2532"\w* \w thoo|strong="G1453"\w* \w tih|strong="G2532"\w* hlang \w boeih|strong="G3956"\w* \w hmaiah|strong="G1715"\w* \w phakdoeng|strong="G2895"\w* \w te|strong="G3588"\w* \w pahoi|strong="G2117"\w* a \w loh|strong="G0142"\w* tih \w cet|strong="G1831"\w*. Te \w dongah|strong="G5620"\w* \w boeih|strong="G3956"\w* \w limlum|strong="G1839"\w* uh \w tih|strong="G2532"\w* \w Pathen|strong="G2316"\w* \w te|strong="G3588"\w* \w thangpom|strong="G1392"\w* ham, “\w He|strong="G3779"\w* tlam he m'\w hmuh|strong="G3708"\w* noek \w moenih|strong="G3763"\w*,” a \w ti|strong="G3004"\w* uh.   
\s1 Mathai A Khue  
\p
\v 13 \w Tuili|strong="G2281"\w* \w kaengah|strong="G3844"\w* \w koep|strong="G3825"\w* a \w caeh|strong="G1831"\w* \w vaengah|strong="G2532"\w* \w hlangping|strong="G3793"\w* \w loh|strong="G3588"\w* \w a|strong="G0846"\w* \w taengla|strong="G4314"\w* \w boeih|strong="G3956"\w* ha \w pawh|strong="G2064"\w* uh \w tih|strong="G2532"\w* \w amih|strong="G0848"\w* te a \w thuituen|strong="G1321"\w*.  
\v 14 A \w khum|strong="G3855"\w* phai \w vaengah|strong="G2532"\w*, mangmu \w doenah|strong="G5058"\w* \w ah|strong="G1909"\w* aka \w ngol|strong="G2521"\w* \w Alphaeus|strong="G0256"\w* capa \w Levi|strong="G3017"\w* te a \w hmuh|strong="G3708"\w* \w tih|strong="G2532"\w*, \wj “ \+w Kai|strong="G3427"\+w* \+w m'vai|strong="G0190"\+w* lah,” \wj* a \w ti|strong="G3004"\w* nah.  
\p Te \w dongah|strong="G2532"\w* \w thoo|strong="G0450"\w* tih \w Jesuh|strong="G2424"\w* hnuk a \w vai|strong="G0190"\w*.  
\v 15   
\s1 Hlangtholh taengah Buhvaelnah  
\p \w Levi|strong="G3017"\w* \w im|strong="G3614"\w* \w ah|strong="G1722"\w* \w om|strong="G1096"\w* tih buh \w a|strong="G0846"\w* \w vael|strong="G2621"\w*. Te \w vaengah|strong="G2532"\w* \w mangmucoi|strong="G5057"\w* rhoek \w neh|strong="G2532"\w* \w hlangtholh|strong="G0268"\w* rhoek tah \w Jesuh|strong="G2424"\w* \w neh|strong="G2532"\w* \w a|strong="G0846"\w* \w hnukbang|strong="G3101"\w* rhoek \w taengah|strong="G3588"\w* \w muep|strong="G4183"\w* \w ngol|strong="G4873"\w* uh. Te phoeiah \w anih|strong="G0846"\w* aka \w vai|strong="G0190"\w* rhoek \w khaw|strong="G2532"\w* \w muep|strong="G4183"\w* \w om|strong="G2258"\w* uh.  
\v 16 \w hlangtholh|strong="G0268"\w* rhoek \w neh|strong="G2532"\w* \w mangmucoi|strong="G5057"\w* rhoek \w taengah|strong="G3326"\w* a \w caak|strong="G2068"\w* \w te|strong="G3754"\w* \w Pharisee|strong="G5330"\w* rhoek \w kah|strong="G3588"\w* \w cadaek|strong="G1122"\w* rhoek \w loh|strong="G3588"\w* a \w hmuh|strong="G3708"\w* uh \w vaengah|strong="G2532"\w* \w a|strong="G0846"\w* \w hnukbang|strong="G3101"\w* rhoek \w taengah|strong="G3588"\w*, “\w Mangmucoi|strong="G5057"\w* rhoek \w neh|strong="G2532"\w* \w hlangtholh|strong="G0268"\w* rhoek \w taengah|strong="G3326"\w* khaw a \w caak|strong="G2068"\w* mai \w ke|strong="G3574"\w*,” a \w ti|strong="G3004"\w* na uh.   
\p
\v 17 \w Jesuh|strong="G2424"\w* \w loh|strong="G3588"\w* a \w yaak|strong="G0191"\w* \w vaengah|strong="G2532"\w* \w amih|strong="G0846"\w* te, \wj “ \+w Sading|strong="G2480"\+w* \+w loh|strong="G3588"\+w* \+w siboei|strong="G2395"\+w* \+w ngoe|strong="G5532,G2192"\+w* \+w pawt|strong="G3756"\+w* \+w tih|strong="G0235"\+w*, \+w tloh|strong="G2560"\+w* aka \+w khueh|strong="G2192"\+w* \+w long|strong="G3588"\+w* ni a ngoe. Aka \+w dueng|strong="G1342"\+w* rhoek \+w khue|strong="G2564"\+w* ham \+w pawt|strong="G3756"\+w* tih \+w hlangtholh|strong="G0268"\+w* rhoek ham ni ka \+w pawk|strong="G2064"\+w*,” \wj* a \w ti|strong="G3004"\w* nah.   
\s1 Tuitang neh Misurtui  
\p
\v 18 \w Johan|strong="G2491"\w* kah \w hnukbang|strong="G3101"\w* rhoek \w neh|strong="G2532"\w* caak aka \w yaeh|strong="G3522"\w* \w Pharisee|strong="G5330"\w* rhoek \w tah|strong="G3588"\w* ha \w pawk|strong="G2258"\w* uh. Te \w vaengah|strong="G2532"\w* \w cet|strong="G2064"\w* uh \w tih|strong="G2532"\w* \w Jesuh|strong="G2424"\w* taengah, “\w Balae|strong="G5101"\w* \w tih|strong="G1223"\w* \w Johan|strong="G2491"\w* kah \w hnukbang|strong="G3101"\w* rhoek \w neh|strong="G2532"\w* \w Pharisee|strong="G5330"\w* rhoek \w kah|strong="G3588"\w* \w hnukbang|strong="G3101"\w* rhoek \w tah|strong="G3588"\w* a \w yaeh|strong="G3522"\w* uh \w tih|strong="G1161"\w* \w na|strong="G4674"\w* \w hnukbang|strong="G3101"\w* rhoek \w tah|strong="G3588"\w* a \w yaeh|strong="G3522"\w* uh \w pawh|strong="G3756"\w*,” a \w ti|strong="G3004"\w* uh.   
\p
\v 19 \w Jesuh|strong="G2424"\w* \w loh|strong="G3588"\w* \w amih|strong="G0846"\w* te, \wj “ \+w Yulueihmuen|strong="G3567"\+w* \+w kah|strong="G3588"\+w* \+w paca boeina|strong="G5207"\+w* \+w a om vaengah|strong="G1722"\+w* tah \+w coeng|strong="G1410"\+w* \+w mahpawh|strong="G3361"\+w*. \+w Yulokung|strong="G3566"\+w* \+w loh|strong="G3588"\+w* \+w amih|strong="G0846"\+w* \+w taengah|strong="G3326"\+w* a \+w om|strong="G2076"\+w* \+w vaengah|strong="G3739"\+w* a \+w yaeh|strong="G3522"\+w* aya? \+w Amih|strong="G0846"\+w* \+w te|strong="G3326"\+w* \+w yulokung|strong="G3566"\+w* neh a \+w om|strong="G2192"\+w* uh \+w tue|strong="G5550"\+w* \+w khuiah|strong="G3745"\+w* \+w yaeh|strong="G3522"\+w* uh \+w thai|strong="G1410"\+w* \+w mahpawh|strong="G3756"\+w*\wj*.  
\v 20 \wj \+w Tedae|strong="G1161"\+w* \+w khohnin|strong="G2250"\+w* a \+w pai|strong="G2064"\+w* \+w vaengah|strong="G3752"\+w* \+w yulokung|strong="G3566"\+w* \+w tah|strong="G3588"\+w* \+w amih|strong="G0846"\+w* taeng \+w lamkah|strong="G0575"\+w* loh a \+w khue|strong="G0522"\+w* \+w vetih|strong="G2532"\+w* \+w te|strong="G1565"\+w* vaeng \+w khohnin|strong="G2250"\+w* \+w ah|strong="G1722"\+w* a \+w yaeh|strong="G3522"\+w* uh bitni\wj*.   
\s1 Himbai Rhuem neh Himbai Thai  
\p
\v 21 \wj \+w Hni|strong="G4470"\+w* \+w pen|strong="G1915"\+w* a \+w cuemsok|strong="G0046"\+w* te \+w himbai|strong="G2440"\+w* \+w rhuem|strong="G3820"\+w* \+w soah|strong="G1909"\+w* a \+w hui|strong="G1976"\+w* \+w moenih|strong="G3762"\+w*. \+w Te|strong="G1161"\+w* \+w pawt|strong="G3361"\+w* \+w koinih|strong="G1487"\+w* a \+w bonah|strong="G4138"\+w* \+w rhuem|strong="G3820"\+w* \+w te|strong="G3588"\+w* a \+w thai|strong="G2537"\+w* \+w loh|strong="G3588"\+w* a \+w sol|strong="G0142"\+w* \+w tih|strong="G2532"\+w* a \+w pawnnah|strong="G4978"\+w* te a \+w thae|strong="G5501"\+w* \+w om|strong="G1096"\+w*\wj*.   
\s1 Misurtui Noe neh Rhuem  
\p
\v 22 \wj Te \+w phoeiah|strong="G2532"\+w* \+w misurtui|strong="G3631"\+w* \+w noe|strong="G3501"\+w* te \+w tuitang|strong="G0779"\+w* \+w rhuem|strong="G3820"\+w* \+w khuiah|strong="G1519"\+w* a \+w than|strong="G0906"\+w* uh \+w moenih|strong="G3762"\+w*. \+w Te|strong="G1161"\+w* \+w pawt|strong="G3361"\+w* \+w koinih|strong="G1487"\+w* \+w misurtui|strong="G3631"\+w* \+w loh|strong="G3588"\+w* \+w tuitang|strong="G0779"\+w* \+w te|strong="G3588"\+w* a \+w va|strong="G4486"\+w* \+w vetih|strong="G2532"\+w*, \+w misurtui|strong="G3631"\+w* khaw, \+w tuitang|strong="G0779"\+w* \+w khaw|strong="G2532"\+w* \+w poci|strong="G0622"\+w* ni. Te \+w dongah|strong="G0235"\+w* \+w misurtui|strong="G3631"\+w* \+w noe|strong="G3501"\+w* te \+w tuitang|strong="G0779"\+w* a \+w thai|strong="G2537"\+w* \+w khuiah|strong="G1519"\+w* ni a khueh,” \wj* a \w ti|strong="G2036"\w* nah.   
\s1 Sabbath Boeipa  
\p
