\pb
\mt2 Naves galevis lotovoi hǝn datb̃inau gat gail
\tr 
\tc1 \k Mat 5.3-11\k*
\tc2 Navoian siGot van hǝn nǝvanuan gail
\tr 
\tc1 \k Mat 5.16\k*
\tc2 Nǝvanuan gail leris navoian sam̃ ale sal suh aGot
\tr 
\tc1 \k Mat 5.43-45\k*
\tc2 Lǝmas bun aenemi sam̃ gail
\tr 
\tc1 \k Mat 11.28-30\k*
\tc2 Gǝm hǝn aYesu hǝn gǝb̃ikad nǝŋavŋavan
\tr 
\tc1 \k Mat 20.26-28\k*
\tc2 Nǝvanuan totibau tegǝm vi slev sinǝvanuan gail
\tr 
\tc1 \k Mat 25.40\k*
\tc2 Nǝsa gotogole van hǝn nǝbathudud, gugole van hǝn ginau
\tr 
\tc1 \k Mat 28.19-20\k*
\tc2 Mitivan hǝn nǝvanuan gail lǝb̃egǝm vi hai susur sagw gail
\tr 
\tc1 \k Mak 11.25\k*
\tc2 Mǝterub̃at nǝsaan dan avan ideh togol tosa hǝn gaiug
\tr 
\tc1 \k Luk 6.31\k*
\tc2 Gigol nǝsa gotolǝŋoni ke nǝvanuan gail ligole van hǝn gaiug
\tr 
\tc1 \k Luk 11.2-4\k*
\tc2 Na-sor-tuṽ-an
\tr 
\tc1 \k Luk 14.26-27\k*
\tc2 Na-husur-aKristo-an
