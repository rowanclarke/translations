\c 1
\p
\v 1 \w Le|strong="H3068"\w* \w huitième|strong="H8066"\w* \w mois|strong="H2320"\w*, \w la|strong="H3068"\w* \w deuxième|strong="H8147"\w* \w année|strong="H8141"\w* \w de|strong="H1121"\w* \w Darius|strong="H1867"\w*, \w la|strong="H3068"\w* \w parole|strong="H1697"\w* \w du|strong="H1121"\w* \w SEIGNEUR|strong="H3068"\w*\f + \fr 1.1 \ft Lorsqu'il est écrit en MAJUSCULES, « SEIGNEUR » ou « DIEU » est la traduction du nom propre de Dieu (en hébreu « \+wh יהוה\+wh* », généralement prononcé Yahvé).\f* \w fut|strong="H3068"\w* \w adressée|strong="H1697"\w* \w au|strong="H3068"\w* \w prophète|strong="H5030"\w* \w Zacharie|strong="H2148"\w*, \w fils|strong="H1121"\w* \w de|strong="H1121"\w* \w Bérékia|strong="H1296"\w*, \w fils|strong="H1121"\w* d'\w Iddo|strong="H5714"\w* :  
\v 2 « \w Le|strong="H3068"\w* \w SEIGNEUR|strong="H3068"\w* s'\w est|strong="H3068"\w* fortement \w irrité|strong="H7107"\w* \w contre|strong="H3068"\w* \w vos|strong="H3068"\w* \w pères|strong="H3068"\w*.  
\v 3 Dis-leur \w donc|strong="H3068"\w* : \w Ainsi|strong="H3541"\w* \w parle|strong="H3541"\w* \w le|strong="H3068"\w* \w SEIGNEUR|strong="H3068"\w* \w des|strong="H3068"\w* \w armées|strong="H6635"\w* : \w Revenez|strong="H7725"\w* \w à|strong="H3068"\w* \w moi|strong="H3068"\w*, \w dit|strong="H5002"\w* \w le|strong="H3068"\w* \w SEIGNEUR|strong="H3068"\w* \w des|strong="H3068"\w* \w armées|strong="H6635"\w*, \w et|strong="H3068"\w* \w je|strong="H7725"\w* \w reviendrai|strong="H7725"\w* \w à|strong="H3068"\w* \w vous|strong="H3068"\w*, \w dit|strong="H5002"\w* \w le|strong="H3068"\w* \w SEIGNEUR|strong="H3068"\w* \w des|strong="H3068"\w* \w armées|strong="H6635"\w*.  
\v 4 \w Ne|strong="H3808"\w* \w soyez|strong="H1961"\w* \w pas|strong="H3808"\w* \w comme|strong="H3068"\w* \w vos|strong="H8085"\w* \w pères|strong="H3068"\w*, auxquels \w les|strong="H3068"\w* \w premiers|strong="H7223"\w* \w prophètes|strong="H5030"\w* proclamaient : \w Ainsi|strong="H3541"\w* \w parle|strong="H3541"\w* \w le|strong="H3068"\w* \w SEIGNEUR|strong="H8085"\w* \w des|strong="H3068"\w* \w armées|strong="H6635"\w* : “\w Détournez-vous|strong="H3068"\w* \w donc|strong="H7121"\w* \w de|strong="H1870"\w* \w vos|strong="H8085"\w* \w mauvaises|strong="H7451"\w* \w voies|strong="H1870"\w* \w et|strong="H3068"\w* \w de|strong="H1870"\w* \w vos|strong="H8085"\w* \w mauvaises|strong="H7451"\w* \w actions|strong="H4611"\w*” ; mais \w ils|strong="H1961"\w* n'\w ont|strong="H3068"\w* \w pas|strong="H3808"\w* \w écouté|strong="H8085"\w*, \w ils|strong="H1961"\w* n'\w ont|strong="H3068"\w* \w pas|strong="H3808"\w* \w fait|strong="H3068"\w* \w attention|strong="H7181"\w* \w à|strong="H3068"\w* \w moi|strong="H3068"\w*, \w dit|strong="H5002"\w* \w le|strong="H3068"\w* \w SEIGNEUR|strong="H8085"\w*.  
\v 5 \w Vos|strong="H5769"\w* pères, où sont-ils ? \w Et|strong="H5030"\w* \w les|strong="H2421"\w* \w prophètes|strong="H5030"\w*, vivent-ils \w éternellement|strong="H5769"\w* ?  
\v 6 \w Cependant|strong="H3651"\w* \w mes|strong="H6213"\w* \w paroles|strong="H1697"\w* \w et|strong="H3068"\w* \w mes|strong="H6213"\w* décrets, \w que|strong="H1697"\w* \w j|strong="H3068"\w*'\w avais|strong="H6213"\w* \w prescrits|strong="H6680"\w* \w à|strong="H3068"\w* \w mes|strong="H6213"\w* \w serviteurs|strong="H5650"\w* \w les|strong="H3068"\w* \w prophètes|strong="H5030"\w*, n'\w ont-ils|strong="H5650"\w* \w pas|strong="H3808"\w* \w atteint|strong="H5381"\w* \w vos|strong="H6213"\w* \w pères|strong="H3068"\w* ?  
\p \w Ils|strong="H7725"\w* \w se|strong="H3068"\w* \w sont|strong="H3068"\w* \w alors|strong="H3651"\w* repentis \w et|strong="H3068"\w* \w ont|strong="H5650"\w* \w dit|strong="H1697"\w* : “\w Le|strong="H3068"\w* \w SEIGNEUR|strong="H3068"\w* \w des|strong="H3068"\w* \w armées|strong="H6635"\w* \w nous|strong="H3068"\w* \w a|strong="H3068"\w* \w traités|strong="H6213"\w* \w comme|strong="H3068"\w* \w il|strong="H3068"\w* \w avait|strong="H3068"\w* \w résolu|strong="H2161"\w* \w de|strong="H1697"\w* \w le|strong="H3068"\w* \w faire|strong="H6213"\w*, \w selon|strong="H6213"\w* \w nos|strong="H5650"\w* \w voies|strong="H1870"\w* \w et|strong="H3068"\w* \w selon|strong="H6213"\w* \w nos|strong="H5650"\w* \w actions|strong="H1697"\w*.” »   
\p
\v 7 \w Le|strong="H3068"\w* \w vingt-quatrième|strong="H3068"\w* \w jour|strong="H3117"\w* \w du|strong="H3117"\w* \w onzième|strong="H6249"\w* \w mois|strong="H2320"\w*, \w qui|strong="H3068"\w* \w est|strong="H3068"\w* \w le|strong="H3068"\w* \w mois|strong="H2320"\w* \w de|strong="H1121"\w* Shebat, \w la|strong="H3068"\w* \w deuxième|strong="H8147"\w* \w année|strong="H8141"\w* \w de|strong="H1121"\w* \w Darius|strong="H1867"\w*, \w la|strong="H3068"\w* \w parole|strong="H1697"\w* \w du|strong="H3117"\w* \w SEIGNEUR|strong="H3068"\w* \w fut|strong="H3068"\w* \w adressée|strong="H1697"\w* \w au|strong="H3068"\w* \w prophète|strong="H5030"\w* \w Zacharie|strong="H2148"\w*, \w fils|strong="H1121"\w* \w de|strong="H1121"\w* \w Bérékia|strong="H1296"\w*, \w fils|strong="H1121"\w* d'\w Iddo|strong="H5714"\w* :  
\v 8 \w J|strong="H3068"\w*'\w eus|strong="H7200"\w* \w une|strong="H7200"\w* \w vision|strong="H7200"\w* \w pendant|strong="H7200"\w* \w la|strong="H7200"\w* \w nuit|strong="H3915"\w* : \w voici|strong="H2009"\w*,\f + \fr 1.8 \ft « Voici », de l'hébreu « \+wh הִנֵּה\+wh* », signifie regarder, prêter attention, observer, voir ou contempler. Il est souvent utilisé comme interjection.\f* \w un|strong="H7200"\w* \w homme|strong="H1931"\w* \w monté|strong="H7392"\w* \w sur|strong="H5921"\w* \w un|strong="H7200"\w* \w cheval|strong="H5483"\w* roux \w se|strong="H7200"\w* \w tenait|strong="H5975"\w* \w parmi|strong="H7200"\w* \w les|strong="H7200"\w* \w myrtes|strong="H1918"\w* \w dans|strong="H5921"\w* \w un|strong="H7200"\w* ravin ; \w et|strong="H7200"\w* \w derrière|strong="H5975"\w* \w lui|strong="H1931"\w*, \w il|strong="H1931"\w* \w y|strong="H2009"\w* \w avait|strong="H7200"\w* \w des|strong="H5921"\w* \w chevaux|strong="H5483"\w* roux, \w fauves|strong="H8320"\w* \w et|strong="H7200"\w* \w blancs|strong="H3836"\w*.  
\v 9 \w Je|strong="H3068"\w* demandai : « \w Mon|strong="H7200"\w* \w seigneur|strong="H7200"\w*, \w que|strong="H7200"\w* \w sont|strong="H1992"\w* ceux-ci ? »  
\p \w L|strong="H3068"\w*'\w ange|strong="H4397"\w* \w qui|strong="H1992"\w* \w me|strong="H1992"\w* \w parlait|strong="H1696"\w* \w me|strong="H1992"\w* \w répondit|strong="H1696"\w* : « \w Je|strong="H3068"\w* \w te|strong="H4100"\w* \w ferai|strong="H4100"\w* \w voir|strong="H7200"\w* \w ce|strong="H1992"\w* \w qu|strong="H4100"\w*'\w ils|strong="H1992"\w* \w sont|strong="H1992"\w*. »   
\p
\v 10 \w L|strong="H3068"\w*'\w homme|strong="H3068"\w* \w qui|strong="H3068"\w* \w se|strong="H3068"\w* \w tenait|strong="H5975"\w* \w parmi|strong="H3068"\w* \w les|strong="H3068"\w* \w myrtes|strong="H1918"\w* \w prit|strong="H3068"\w* \w la|strong="H3068"\w* \w parole|strong="H6030"\w* \w et|strong="H3068"\w* \w dit|strong="H6030"\w* : « \w Ce|strong="H7971"\w* \w sont|strong="H3068"\w* \w ceux|strong="H3068"\w* \w que|strong="H3068"\w* \w le|strong="H3068"\w* \w SEIGNEUR|strong="H7971"\w* \w a|strong="H3068"\w* \w envoyés|strong="H7971"\w* \w pour|strong="H7971"\w* \w parcourir|strong="H1980"\w* \w la|strong="H3068"\w* \w terre|strong="H3068"\w*. »   
\p
\v 11 \w Ils|strong="H3068"\w* \w firent|strong="H3068"\w* rapport \w à|strong="H3068"\w* l'\w ange|strong="H4397"\w* \w du|strong="H3427"\w* \w SEIGNEUR|strong="H3068"\w* \w qui|strong="H3068"\w* \w se|strong="H3068"\w* \w tenait|strong="H5975"\w* \w parmi|strong="H3068"\w* \w les|strong="H3068"\w* \w myrtes|strong="H1918"\w*, \w et|strong="H3068"\w* \w dirent|strong="H3068"\w* : « \w Nous|strong="H3068"\w* \w avons|strong="H3068"\w* \w parcouru|strong="H1980"\w* \w la|strong="H3068"\w* \w terre|strong="H3068"\w*, \w et|strong="H3068"\w* \w voici|strong="H2009"\w*, \w toute|strong="H3605"\w* \w la|strong="H3068"\w* \w terre|strong="H3068"\w* \w est|strong="H3068"\w* \w en|strong="H3068"\w* \w repos|strong="H8252"\w* \w et|strong="H3068"\w* \w tranquille|strong="H8252"\w*. »   
\p
\v 12 \w Alors|strong="H3808"\w* \w l|strong="H8141"\w*'\w ange|strong="H4397"\w* \w du|strong="H8141"\w* \w SEIGNEUR|strong="H3068"\w* \w reprit|strong="H6030"\w* : « Ô \w SEIGNEUR|strong="H3068"\w* \w des|strong="H3068"\w* \w armées|strong="H6635"\w*, jusques \w à|strong="H3068"\w* \w quand|strong="H3808"\w* \w seras-tu|strong="H5704"\w* \w sans|strong="H3808"\w* \w miséricorde|strong="H7355"\w* \w pour|strong="H5704"\w* \w Jérusalem|strong="H3389"\w* \w et|strong="H3068"\w* \w pour|strong="H5704"\w* \w les|strong="H3068"\w* \w villes|strong="H5892"\w* \w de|strong="H5892"\w* \w Juda|strong="H3063"\w*, \w contre|strong="H3068"\w* \w lesquelles|strong="H3068"\w* \w tu|strong="H8141"\w* \w es|strong="H8141"\w* indigné \w depuis|strong="H3068"\w* \w soixante-dix|strong="H8141"\w* \w ans|strong="H8141"\w* ? »   
\p
\v 13 \w Le|strong="H3068"\w* \w SEIGNEUR|strong="H1696"\w* \w répondit|strong="H6030"\w* \w à|strong="H3068"\w* l'\w ange|strong="H4397"\w* \w qui|strong="H3068"\w* \w me|strong="H3068"\w* \w parlait|strong="H1696"\w* \w par|strong="H3068"\w* \w de|strong="H1697"\w* \w bonnes|strong="H2896"\w* \w paroles|strong="H1697"\w*, \w des|strong="H3068"\w* \w paroles|strong="H1697"\w* \w de|strong="H1697"\w* \w consolation|strong="H5150"\w*.  
\v 14 \w L|strong="H3068"\w*'\w ange|strong="H4397"\w* \w qui|strong="H3068"\w* \w me|strong="H3068"\w* \w parlait|strong="H1696"\w* \w me|strong="H3068"\w* \w dit|strong="H1696"\w* \w alors|strong="H3068"\w* : « \w Proclame|strong="H1696"\w* \w ce|strong="H7121"\w* message : \w Ainsi|strong="H3541"\w* \w parle|strong="H1696"\w* \w le|strong="H3068"\w* \w SEIGNEUR|strong="H1696"\w* \w des|strong="H3068"\w* \w armées|strong="H6635"\w* : “\w J|strong="H3068"\w*'\w éprouve|strong="H3068"\w* \w pour|strong="H3068"\w* \w Jérusalem|strong="H3389"\w* \w et|strong="H3068"\w* \w pour|strong="H3068"\w* \w Sion|strong="H6726"\w* \w une|strong="H3068"\w* \w grande|strong="H1419"\w* \w jalousie|strong="H7068"\w*.  
\v 15 \w Je|strong="H3068"\w* suis saisi \w d|strong="H1992"\w*'\w une|strong="H5921"\w* \w grande|strong="H1419"\w* \w colère|strong="H7110"\w* \w contre|strong="H5921"\w* \w les|strong="H5921"\w* \w nations|strong="H1471"\w* \w qui|strong="H7451"\w* vivent \w dans|strong="H5921"\w* l'insouciance ; car \w je|strong="H4592"\w* n'étais qu'\w un|strong="H5921"\w* \w peu|strong="H4592"\w* \w irrité|strong="H7107"\w*, mais \w elles|strong="H5921"\w* \w ont|strong="H1471"\w* aggravé \w le|strong="H5921"\w* \w malheur|strong="H7451"\w*.”  
\v 16 C'\w est|strong="H3068"\w* \w pourquoi|strong="H3651"\w*, \w ainsi|strong="H3541"\w* \w parle|strong="H3541"\w* \w le|strong="H3068"\w* \w SEIGNEUR|strong="H3068"\w* : “\w Je|strong="H3068"\w* \w reviens|strong="H7725"\w* \w à|strong="H3068"\w* \w Jérusalem|strong="H3389"\w* \w avec|strong="H3068"\w* \w miséricorde|strong="H7356"\w*. \w Ma|strong="H7725"\w* \w maison|strong="H1004"\w* \w y|strong="H3068"\w* \w sera|strong="H3068"\w* \w rebâtie|strong="H1129"\w*, \w dit|strong="H5002"\w* \w le|strong="H3068"\w* \w SEIGNEUR|strong="H3068"\w* \w des|strong="H3068"\w* \w armées|strong="H6635"\w*, \w et|strong="H3068"\w* \w le|strong="H3068"\w* \w cordeau|strong="H5002"\w* \w sera|strong="H3068"\w* \w tendu|strong="H5186"\w* \w sur|strong="H5921"\w* \w Jérusalem|strong="H3389"\w*.”   
\p
\v 17 \w Proclame|strong="H7121"\w* \w encore|strong="H5750"\w* \w ceci|strong="H3068"\w* : \w Ainsi|strong="H3541"\w* \w parle|strong="H3541"\w* \w le|strong="H3068"\w* \w SEIGNEUR|strong="H3068"\w* \w des|strong="H3068"\w* \w armées|strong="H6635"\w* : “\w Mes|strong="H7121"\w* \w villes|strong="H5892"\w* regorgeront \w encore|strong="H5750"\w* \w de|strong="H5892"\w* \w prospérité|strong="H2896"\w*, \w le|strong="H3068"\w* \w SEIGNEUR|strong="H3068"\w* \w consolera|strong="H5162"\w* \w encore|strong="H5750"\w* \w Sion|strong="H6726"\w*, \w et|strong="H3068"\w* \w il|strong="H3068"\w* \w choisira|strong="H3068"\w* \w encore|strong="H5750"\w* \w Jérusalem|strong="H3389"\w*.” »   
\p
\v 18 \w Je|strong="H3068"\w* levai les yeux et je regardai, et voici, il y avait quatre cornes.  
\v 19 \w Je|strong="H3068"\w* demandai à l'ange qui me parlait : « Que sont ces cornes ? »  
\p Il me répondit : « Ce sont les cornes qui ont dispersé Juda, Israël et Jérusalem. »   
\p
\v 20 Le SEIGNEUR me fit voir quatre forgerons.  
\v 21 \w Je|strong="H3068"\w* demandai alors : « Que viennent faire ceux-ci ? »  
\p Il dit : « Celles-là sont les cornes qui ont dispersé Juda, au point que personne ne levait la tête ; mais ces forgerons sont venus pour les effrayer, pour abattre les cornes des nations qui ont levé la corne contre le pays de Juda afin de le disperser. »   
\c 2
\p
\v 1 \w Je|strong="H3068"\w* \w levai|strong="H5375"\w* \w les|strong="H5375"\w* \w yeux|strong="H5869"\w* \w et|strong="H7200"\w* \w je|strong="H7200"\w* \w regardai|strong="H7200"\w*, \w et|strong="H7200"\w* \w voici|strong="H2009"\w*, \w il|strong="H2009"\w* \w y|strong="H2009"\w* \w avait|strong="H7200"\w* \w un|strong="H7200"\w* \w homme|strong="H7200"\w* \w qui|strong="H5869"\w* tenait \w à|strong="H5869"\w* \w la|strong="H7200"\w* \w main|strong="H7200"\w* \w un|strong="H7200"\w* \w cordeau|strong="H7200"\w* \w à|strong="H5869"\w* mesurer.  
\v 2 \w Je|strong="H3068"\w* demandai : « \w Où|strong="H3478"\w* vas-tu ? »  
\p \w Il|strong="H3389"\w* \w me|strong="H3478"\w* \w répondit|strong="H1696"\w* : « \w Je|strong="H3068"\w* vais mesurer \w Jérusalem|strong="H3389"\w*, \w pour|strong="H3478"\w* \w voir|strong="H4397"\w* \w quelle|strong="H4100"\w* \w est|strong="H3478"\w* \w sa|strong="H3478"\w* \w largeur|strong="H4100"\w* \w et|strong="H3478"\w* \w quelle|strong="H4100"\w* \w est|strong="H3478"\w* \w sa|strong="H3478"\w* longueur. »   
\p
\v 3 \w Voici|strong="H7200"\w*, l'ange \w qui|strong="H3068"\w* \w me|strong="H3068"\w* \w parlait|strong="H3068"\w* s'avança, \w et|strong="H3068"\w* \w un|strong="H3068"\w* \w autre|strong="H3068"\w* ange \w vint|strong="H3068"\w* \w à|strong="H3068"\w* \w sa|strong="H3068"\w* \w rencontre|strong="H7200"\w*,  
\v 4 \w et|strong="H3063"\w* \w il|strong="H6213"\w* \w lui|strong="H6213"\w* \w dit|strong="H3063"\w* : « Cours, parle \w à|strong="H6213"\w* \w ce|strong="H6213"\w* \w jeune|strong="H6213"\w* \w homme|strong="H6213"\w*, \w et|strong="H3063"\w* dis-lui : « Jérusalem \w sera|strong="H6213"\w* habitée \w comme|strong="H6213"\w* \w des|strong="H6213"\w* villages \w sans|strong="H3808"\w* murailles, \w à|strong="H6213"\w* \w cause|strong="H6213"\w* \w de|strong="H6213"\w* \w la|strong="H6213"\w* multitude d'\w hommes|strong="H6213"\w* \w et|strong="H3063"\w* \w de|strong="H6213"\w* \w bêtes|strong="H7218"\w* \w qui|strong="H1471"\w* \w seront|strong="H1471"\w* \w au|strong="H6213"\w* \w milieu|strong="H6213"\w* d'\w elle|strong="H3063"\w*.  
\v 5 Car \w moi|strong="H3027"\w*, \w dit|strong="H2009"\w* \w le|strong="H7200"\w* \w SEIGNEUR|strong="H7200"\w*, \w je|strong="H3027"\w* \w serai|strong="H3027"\w* \w pour|strong="H3027"\w* \w elle|strong="H3027"\w* \w une|strong="H7200"\w* \w muraille|strong="H5375"\w* \w de|strong="H3027"\w* \w feu|strong="H7200"\w* \w tout|strong="H7200"\w* \w autour|strong="H2256"\w*, \w et|strong="H3027"\w* \w je|strong="H3027"\w* \w serai|strong="H3027"\w* \w la|strong="H7200"\w* \w gloire|strong="H7200"\w* \w au|strong="H3027"\w* \w milieu|strong="H7200"\w* d'\w elle|strong="H3027"\w*. »   
\p
\v 6 Allons ! Allons ! Fuyez \w le|strong="H7200"\w* \w pays|strong="H7200"\w* \w du|strong="H7200"\w* nord, \w dit|strong="H3389"\w* \w le|strong="H7200"\w* \w SEIGNEUR|strong="H7200"\w* ; \w car|strong="H4100"\w* \w je|strong="H7200"\w* \w vous|strong="H7200"\w* \w ai|strong="H7200"\w* dispersés \w aux|strong="H7200"\w* \w quatre|strong="H1980"\w* \w vents|strong="H1980"\w* \w du|strong="H7200"\w* ciel, \w dit|strong="H3389"\w* \w le|strong="H7200"\w* \w SEIGNEUR|strong="H7200"\w*.  
\v 7 Allons, Sion ! Sauve-toi, \w toi|strong="H3318"\w* \w qui|strong="H4397"\w* demeures \w avec|strong="H1696"\w* \w la|strong="H3318"\w* \w fille|strong="H3318"\w* \w de|strong="H3318"\w* \w Babylone|strong="H3318"\w* !  
\v 8 Car \w ainsi|strong="H1696"\w* \w parle|strong="H1696"\w* \w le|strong="H3427"\w* \w SEIGNEUR|strong="H1696"\w* \w des|strong="H8432"\w* armées : \w Pour|strong="H3427"\w* \w la|strong="H1696"\w* gloire, \w il|strong="H3389"\w* m'\w a|strong="H3068"\w* envoyé \w vers|strong="H7323"\w* \w les|strong="H3427"\w* \w nations|strong="H3427"\w* \w qui|strong="H5288"\w* \w vous|strong="H8432"\w* \w ont|strong="H5288"\w* dépouillés ; car \w celui|strong="H1696"\w* \w qui|strong="H5288"\w* \w vous|strong="H8432"\w* touche, touche \w à|strong="H1696"\w* \w la|strong="H1696"\w* \w prunelle|strong="H1696"\w* \w de|strong="H3427"\w* \w son|strong="H3427"\w* œil.  
