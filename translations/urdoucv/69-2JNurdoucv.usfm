\id 2JN - Biblica® Open Urdu Contemporary Version 
\h 2 یُوحنّا 
\toc1 یُوحنّا کا دُوسرا خط 
\toc2 2 یُوحنّا 
\toc3 2 یُوح 
\mt1 یُوحنّا 
\mt2 کا دُوسرا خط 
\c 1  
\po  
\v 1 بُزرگ\f + \fr 1‏:1 \fq بُزرگ \ft پہلی صَدی میں بُزرگ کا لقب صِرف اُنہیں حاصل تھا جو خُداوؔند یِسوعؔ المسیح کے چشم دید گواہ تھے۔‏\f* حضرت یُوحنّا کی جانِب سے، 
\po اُس برگُزیدہ خاتُون\f + \fr 1‏:1 \fq برگُزیدہ خاتُون \ft یعنی جماعت جسے یہ خط لِکھّا گیا تھا۔‏\f* اَور اُس کے فرزندوں کے نام خط جِن سے میں سچّی مَحَبّت رکھتا ہوں اَور نہ صِرف میں بَلکہ وہ سَب مُومِنین کو بھی جو حق سے واقف ہیں۔  
\v 2 اَور یہ مَحَبّت اُس سچّائی کے سبب سے ہے جو ہمارے اَندر رہتاہے اَور ہمیشہ تک ہمارے ساتھ رہے گا۔ 
\po  
\v 3 خُدا باپ اَور خُدا کے بیٹے یِسوعؔ المسیح کی طرف سے فضل، رحم اَور اِطمینان، سچّائی اَور مَحَبّت میں ہمارے ساتھ قائِم رہے گی۔ 
\b  
\p  
\v 4 مُجھے بڑی خُوشی ہُوئی، جَب مُجھے پتا چلا کہ تیرے کچھ فرزند اُس حُکم کے مُطابق سچّائی پر عَمل کر رہے ہیں جو ہمیں باپ کی طرف سے مِلا ہے۔  
\v 5 اَور اَب اَے عزیزہ خاتُون! مَیں تُجھے کویٔی نیا حُکم نہیں بَلکہ صِرف وُہی جو شروع سے ہی ہمارے پاس ہے، لِکھ رہا ہُوں اَور تُم سے مِنّت کرتا ہُوں کہ ہم ایک دُوسرے سے مَحَبّت رکھیں۔  
\v 6 اَور مَحَبّت اِس میں ہے کہ ہم خُدا کے حُکموں پر فرمانبرداری سے چلیں۔ یہ وُہی حُکم ہے جو تُم نے شروع سے سُنا ہے کہ تُم مَحَبّت سے زندگی بسر کرو۔ 
\p  
\v 7 کیونکہ بہت سے اَیسے گُمراہ کرنے والے دُنیا میں نکل چُکے ہیں جو یہ نہیں مانتے ہیں کہ یِسوعؔ المسیح مُجسّم ہوکر آئے ہیں، اَیسا ہر شخص گُمراہ کرنے والا اَور مُخالف المسیح یعنی دَجّال ہے۔  
\v 8 خبردار رہو کہ جو محنت ہم نے کی ہے وہ تمہارے سبب سے ضائع نہ ہو جائے بَلکہ تُمہیں اُس کا مُکمّل اجر ملے۔  
\v 9 جو کویٔی بھٹک کر آگے بڑھ جاتا ہے اَور المسیح کی تعلیم پر قائِم نہیں رہتاہے، اُس میں خُدا نہیں ہے۔ اَورجو اُس کی تعلیم پر قائِم رہتاہے تو اُس کے پاس باپ اَور بیٹا دونوں ہیں۔  
\v 10 اگر کویٔی تمہارے پاس آئے مگر یہ تعلیم نہ دے تو اُسے گھر میں داخل مت ہونے دینا اَور نہ ہی اُسے سلام کرنا۔  
\v 11 کیونکہ جو کویٔی اَیسے شخص کا خیرمقدم کرتا ہے وہ اُن کے بُرے کاموں میں شریک ہوتاہے۔ 
\b  
\b  
\p  
\v 12 مُجھے بہت سِی باتیں تُم کو لِکھنا ہیں، مگر میں اُنہیں کاغذ\f + \fr 1‏:12 \ft کاغذ اصل میں پیپرس کی چادر کا حوالہ دیتاہے۔‏\f* پر روشنائی سے لِکھنا نہیں چاہتا؛ بَلکہ اُمّید رکھتا ہُوں کہ تمہارے پاس آکر رُوبرو مُلاقات اَور گُفتگو کروں تاکہ ہماری خُوشی مُکمّل ہو جائے۔ 
\b  
\p  
\v 13 تیری برگُزیدہ بہن کے فرزند یعنی جماعت کے مُومِنین تُجھے سلام کہتے ہیں۔