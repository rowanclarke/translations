\v 21 \w So|strong="H4480"\w* \w King|strong="H4428"\w* \w Zedekiah|strong="H6667"\w* \w commanded|strong="H6680"\w* \w that|strong="H3605"\w* \add I not be sent back to the prison cell. Instead,\add* \w I|strong="H3117"\w* \w was|strong="H5892"\w* \w allowed|strong="H5414"\w* \w to|strong="H5704"\w* \w be|strong="H3117"\w* watched \w by|strong="H3117"\w* \w the|strong="H3605"\w* guards \w in|strong="H3427"\w* \w the|strong="H3605"\w* \w courtyard|strong="H2691"\w* \add of the palace\add*. \add The king\add* \w also|strong="H4428"\w* \add commanded that they should\add* \w bring|strong="H5414"\w* \w me|strong="H5414"\w* \w a|strong="H3068"\w* \w loaf|strong="H3603"\w* \w of|strong="H4428"\w* fresh \w bread|strong="H3899"\w* \w every|strong="H3605"\w* \w day|strong="H3117"\w*, \w until|strong="H5704"\w* \w there|strong="H3427"\w* \w was|strong="H5892"\w* \w no|strong="H4480"\w* \w bread|strong="H3899"\w* \w left|strong="H5414"\w* \w in|strong="H3427"\w* \w the|strong="H3605"\w* \w city|strong="H5892"\w*. \w So|strong="H4480"\w* \add they put me\add* \w in|strong="H3427"\w* \w that|strong="H3605"\w* \w courtyard|strong="H2691"\w* \w and|strong="H4428"\w* \w I|strong="H3117"\w* \w remained|strong="H3427"\w* \w there|strong="H3427"\w*.   
