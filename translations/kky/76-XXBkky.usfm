\b
\q1 (5)
\q2 Ngayu nambure batchil kakawe
\q2 Wungga nanu milkan name,
\q2 Nundu ngadongu batchega
\q2 Gura bamangu wurgai yokuwe.
\b
\q1 (6)
\q2 Ngayu birninu, wauu dawinu
\q2 Tjiri nanumego wanggar.
\q2 Ani mande nundu mangar,
\q2 Murga tjiringu kana birninu.
\b
\q1 (7)
\q2 Garko ngamburgo ngayu yandanu,
\q2 Dodi dabar, banggar nila
\q2 Wauu ngadomego woa.
\q2 Yerba nanugo yandal ngamburgo.
\b
\q1 (8)
\q2 Yendu ngambadir ninggal warradir
\q2 Nina wudurbego yiwar —
\q2 Nundu nayun gari dambar
\q2 Garko wauudir ninggal nanuntchir. 
