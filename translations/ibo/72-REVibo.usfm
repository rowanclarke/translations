\id REV - Biblica® Open Igbo Contemporary Bible 2020
\h Mkpughe
\toc1 Mkpughe
\toc2 Mkpughe
\toc3 Mkp
\mt1 Mkpughe
\c 1
\s1 Ihe e dere nʼakwụkwọ a
\p 
\v 1 Mkpughe banyere Jisọs Kraịst, nke Chineke nyere ya igosi ndị ohu ya, ime ka ha mata ihe ndị ahụ na-aga ime nʼoge na-adịghị anya. O mere ka amata nke a site na izite mmụọ ozi ya ka ọ bịakwute ohu ya Jọn,
\v 2 onye a gbara ama banyere ihe niile ọ hụrụ, okwu Chineke, na ọgbụgba ama Jisọs Kraịst.
\v 3 Ngọzị na-adịrị onye ahụ na-agụpụta okwu ndị a dị nʼamụma a. Ngọzị na-adịkwara ndị na-anụ ya, ma nabata ihe e dere nʼime ya nʼobi ha. Nʼihi na oge mmezu ha dị nso.
\b
\s1 Ekele na otuto
\p 
\v 4 Ọ bụ m Jọn na-ede akwụkwọ a,
\b
\p Na-edere ya nzukọ asaa dị na mpaghara Eshịa:
\b
\p Ka amara na udo nke sitere na Onye ahụ na-adị, Onye ahụ dịkwaarị, na Onye ahụ na-aga ịbịa dịrị unu, sitekwa nʼebe Mmụọ asaa\f + \fr 1:4 \ft Nʼakwụkwọ Nsọ, asaa dị ka ọnụọgụgụ na-egosipụta izuoke.\f* ahụ na-eguzo nʼihu ocheeze ya,
\v 5 sitekwa nʼaka Jisọs Kraịst, onye bụ onyeama kwesiri ntụkwasị obi, na onye mbụ sitere na ndị nwụrụ anwụ bilie, nakwa onye na-achị ndị eze niile nke ụwa.
\b
\b
\p Nye onye ahụ hụrụ anyị nʼanya ma meekwa ka anyị site nʼọbara ya nwere onwe anyị pụọ na mmehie.
\v 6 O mere ka anyị bụrụ alaeze, ndị nchụaja nye Nna ya bụ Chineke. Ọ bụ ya ka otuto niile na ike niile dịịrị ruo mgbe niile ebighị ebi. Amen.
\q1 
\v 7 “Lee, ọ na-abịa ya na igwe ojii.\f + \fr 1:7 \ft \xt Dan 7:13\xt*\f*
\q2 Anya niile ga-ahụkwa ya,
\q1 ọ bụladị ndị ahụ niile mapuru ya ahụ, ha ga-ahụ ya.”\f + \fr 1:7 \ft \xt Zek 12:10\xt*\f*
\q2 Mmadụ niile nọ nʼụwa “ga-erukwa ụjụ nʼihi ya.”
\qc Otu a ka ọ ga-adị! Amen.
\p 
\v 8 Otu a ka Onyenwe anyị Chineke kwuru, “Abụ m Alfa na Omega, onye na-adị, onye ahụ dịkwaarị, na onye ahụ na-aga ịbịa, bụ onye pụrụ ime ihe niile.”
\b
\s1 Ọhụ Jọn hụrụ banyere Kraịst
\p 
\v 9 Mụ onwe m, Jọn, nwanne unu nwoke, onye unu na ya na-enwekọ ahụhụ na nʼalaeze, na ntachiobi nke bụ oke anyị nʼime Jisọs. Anọ m nʼogbe ala ntakịrị mmiri gbara gburugburu a na-akpọ Patmọs nʼihi okwu Chineke na-agba ama banyere Kraịst.
\v 10 Nʼụbọchị Onyenwe anyị, anọ m nʼime Mmụọ ma nụ otu oke olu dara ụda dị ka opi ike nʼazụ m,
\v 11 na-ekwu, \wj “Dee ihe ị na-ahụ ugbu a nʼakwụkwọ zigara ya nzukọ asaa dị nʼEfesọs na Smyrna na Pegamọm na Tiatira na Sardis, na Filadelfia na Laodisia.”\wj*
\p 
\v 12 Mgbe m chigharịrị, lee anya ịhụ onye na-agwa m okwu, ahụrụ m ihe ịdọba oriọna asaa e ji ọlaedo kpụọ.
\v 13 Nʼetiti ihe ịdọba oriọna ndị a, ahụrụ m otu onye yiri nwa nke mmadụ,\f + \fr 1:13 \ft \xt Dan 7:13\xt*\f* ka o guzo. O yikwasịrị onwe ya uwe mwụda. Ma o nwere ihe okike na-acha ọlaedo e ji kee gburugburu obi ya.
\v 14 Isi ya na agịrị isi ya na-acha vaa dịka ogho ọcha, dịka akụmmiri igwe.\f + \fr 1:14 \ft Nke a ka ndị ọcha na-akpọ snoo.\f* Anya ya abụọ yiri ire ọkụ na-enwusi ike.
\v 15 Ụkwụ ya abụọ dị ka bronz a nụchasịrị nnọọ nke ọma hichapụkwa ya. Olu okwu ya na-ada dị ka ụzụ mmiri na-achị achị.
\v 16 O jidere kpakpando asaa nʼaka nri ya, mma agha dị nkọ nwere ihu abụọ sikwa nʼọnụ ya na-apụta. Ihu ya na-egbu maramara dịka anyanwụ na-acha nʼike ya niile.
\p 
\v 17 Mgbe m hụrụ ya, adara m nʼala nʼụkwụ ya dịka onye nwụrụ anwụ. Ma o weere aka nri ya metụ m nʼahụ na-ekwu sị, \wj “Atụla egwu. Abụ m Mmalite na Ọgwụgwụ.\wj*
\v 18 \wj Abụ m onye ahụ na-adị ndụ. Anwụrụ m anwụ, ma lee, ana m adị ndụ ruo mgbe niile ebighị ebi. Ọ bụkwa m ji ọtụghe igodo nke ọnwụ na nke ọkụ ala mmụọ.\wj*
\p 
\v 19 \wj “Ya mere, detuo ihe niile ị hụrụla, ihe dị ugbu a na ihe gaje ime na mgbe na adịghị anya.\wj*
\v 20 \wj Nke a bụ ihe omimi nke kpakpando asaa ahụ ị hụrụ nʼaka nri m, na ihe ịdọba oriọna asaa ndị ahụ pụtara. Kpakpando asaa ahụ bụ ndị mmụọ ozi ụlọ nzukọ asaa ahụ. Osisi oriọna asaa ahụ bụ ụlọ nzukọ ndị ahụ nʼonwe ha.\wj*
\c 2
\s1 Nzukọ dị nʼEfesọs
\p 
\v 1 \wj “Dee akwụkwọ nye mmụọ ozi ụlọ nzukọ dị nʼEfesọs, sị ya:\wj*
\b
\pi1 \wj Ihe ndị a bụ okwu si nʼọnụ onye ahụ na-ejide kpakpando asaa nʼaka ya, ma na-ejegharịkwa nʼetiti ihe ịdọba oriọna ọlaedo asaa ndị ahụ.\wj*
\b
\pi1 
\v 2 \wj Amaara m ihe niile banyere ọrụ gị niile. Ahụkwala m ịrụsị ọrụ ike gị na ntachiobi gị. Amaara m na ị dịghị anagide ndị ajọ omume, na ị nwaleela ndị ahụ niile na-akpọ onwe ha ndị ozi, ma ha abụghị ndị ozi nʼezie, chọpụtakwa na ha bụ ndị ụgha.\wj*
\v 3 \wj I jirila ntachiobi nagide nhụju anya nʼihi aha m, ma ike agwụghị gị.\wj*
\pi1 
\v 4 \wj Ma enwere m ihe ndị a megide gị. Ị hapụla ịhụnanya mbụ ahụ i nwere.\wj*
\v 5 \wj Cheta ọnọdụ i si na ya daa. Chegharịa, mekwa ihe ndị ahụ ị na-eme na mbụ. Ọ bụrụ na i meghị otu a, aga m abịa wepụ ihe ịdọba oriọna gị site nʼọnọdụ ya.\wj*
\v 6 \wj Ọ bụladị otu a, o nwere ihe ụfọdụ dị mma banyere gị. Ị kpọrọ ọrụ ọjọọ nke ndị Nikolaitan asị, dịka mụ onwe m si kpọọ ya asị.\wj*
\pi1 
\v 7 \wj Onye ọbụla nwere ntị, ya nụrụ ihe Mmụọ Nsọ na-agwa nzukọ. Onye ahụ na-emeri emeri ka m ga-enye ike iri mkpụrụ sitere nʼosisi ndụ ahụ nke dị na paradaịs nke Chineke.\wj*
\s1 Nzukọ dị na Smyrna
\p 
\v 8 \wj “Dee akwụkwọ nye mmụọ ozi ụlọ nzukọ dị na Smyrna, sị ya:\wj*
\b
\pi1 \wj Ihe ndị a bụ okwu ahụ bụ Mmalite na Ọgwụgwụ ihe niile. Onye nwụrụ anwụ ma dịkwa ndụ ọzọ.\wj*
\b
\pi1 
\v 9 \wj Amaara m mkpagbu gị niile na ịda ogbenye gị. Ma nʼezie, ị bụ ọgaranya. Amaara m ihe banyere nkwutọ niile ndị ahụ na-akpọ onwe ha ndị Juu na-ekwutọ gị, ma ha abụghị ndị Juu, nʼezie ha bụ ụlọ nzukọ ekwensu.\wj*
\v 10 \wj Atụkwala egwu nʼihi ihe ahụ gaje ịbịakwasị gị. Nʼihi na ekwensu nʼonwe ya gaje ime ka a tụba ụfọdụ nʼime ndị gị nʼụlọ mkpọrọ, ka o jiri ya nwalee gị. A ga-akpagbu unu abalị iri. Ma gosi onwe gị onye kwesiri ntụkwasị obi, ọ bụladị ruo mgbe ọnwụ ga-abịakwasị gị. Emesịa, a ga m enye gị okpueze ahụ, bụ ndụ.\wj*
\pi1 
\v 11 \wj Onye ọbụla nwere ntị ya nụrụ ihe Mmụọ Nsọ na-agwa nzukọ niile. Onye ọbụla na-emeri emeri, ọnwụ nke ugboro abụọ agaghị emekpa ya ahụ.\wj*
\s1 Nzukọ dị nʼobodo Pegamọm
\p 
\v 12 \wj “Dee akwụkwọ nye mmụọ ozi ụlọ nzukọ dị Pegamọm, sị ya:\wj*
\b
\pi1 \wj Ndị a bụ okwu si nʼọnụ onye ahụ ji mma agha ahụ dị nkọ nke nwere ihu abụọ nʼaka ya.\wj*
\b
\pi1 
\v 13 \wj Amaara m ebe i bi, bụ obodo ebe ekwensu nwere ocheeze ya. Ma ị na-anọgidesi ike nʼaha m. Ị jụrụ ịgọnarị okwukwe gị nʼime m, ọ bụladị nʼoge Antipas onyeama m kwesiri ntụkwasị obi, bụ onye e gburu nʼobodo unu, ebe ekwensu bi.\wj*
\pi1 
\v 14 \wj Ma enwere m ihe ole ma ole megide gị. I nwere ụfọdụ mmadụ ebe ahụ, ndị jidesiri nkuzi Belam ike, bụ onye kuziiri Balak ka o raa ụmụ Izrel ụra nke mere ka ha mehie, rie ihe a chụrụ nʼaja nye arụsị, kwaakwa iko.\wj*\f + \fr 2:14 \ft Ọ bụ Belam kuziri Balak ụzọ ọ ga-esi rara ndị Izrel nye na nnupu isi megide iwu Chineke nyere ha banyere ife arụsị, nʼakwụkwọ \xt Ọnụ 31:15-16\xt*\ft , ịkwa iko na ịlụ di maọbụ nwunye site na mba ọzọ. Iwu ndị a dị nʼakwụkwọ \xt Dit 7:3-11\xt*\ft .\f*
\v 15 \wj Nʼotu aka ahụ, i nwekwara ụfọdụ mmadụ ndị jidesiri nkuzi Nikolaitan ike.\wj*
\v 16 \wj Ya mere, chegharịa! Ma ọ bụghị otu a, aga m abịakwute gị ọsịịsọ jiri mma agha dị m nʼọnụ buso ha agha.\wj*
\pi1 
\v 17 \wj Onye ọbụla nwere ntị, ya nụrụ ihe Mmụọ Nsọ na-agwa nzukọ niile. Ọ bụ naanị onye na-emeri emeri ka m ga-enye ụfọdụ nʼime achịcha mánà ahụ e zoro ezo. Aga m enyekwa onye ahụ ezi nkume ọcha ahụ, nke edekwasịrị aha ọhụrụ nʼelu ya, nke onye ọbụla ọzọ na-agaghị amata, karịa onye ahụ natara ya.\wj*
\s1 Nzukọ dị nʼobodo Tiatira
\p 
\v 18 \wj “Dee akwụkwọ nye mmụọ ozi ụlọ nzukọ dị na Tiatira, sị ya:\wj*
\b
\pi1 \wj Ndị a bụ okwu sitere nʼaka Ọkpara Chineke, onye anya ya na-enwuba nʼebe niile dị ka ire ọkụ. Ụkwụ ya kwa na-egbu maramara dị ka bronz a nụchara nke ọma.\wj*
\b
\pi1 
\v 19 \wj Amaara m ọrụ gị niile, na ịhụnanya gị, na okwukwe gị. Amakwaara m ije ozi gị na ntachiobi gị, na-ahụkwa na ị na-arụ ọrụ ugbu a karịa ka i mere na mbụ.\wj*
\pi1 
\v 20 \wj Ma enwere m ihe ndị a megide gị. Ị na-anabata nwanyị ahụ a na-akpọ Jezebel, onye na-ekwupụta na ya bụ onye amụma nwanyị\wj*\f + \fr 2:20 \fq Onye amụma nwanyị \ft Ọ bụ onye amụma ụgha nʼihi na ihe ọ na-akụzi megidere iwu Chineke.\f*\wj nye ya ohere ka o were nkuzi asị na-eduhie ndị ohu m ụzọ, ka ha kwaa iko, riekwa ihe e ji chụọrọ arụsị aja.\wj*
\v 21 \wj Enyela m ya ohere ka o si na mmehie ya chegharịa, ma ọ jụrụ ichegharị site na ndụ ịkwa iko.\wj*
\v 22 \wj Lee, aga m etinye ya nʼute ahụhụ, meekwa ka ndị ya na ha na-akwa iko taa ahụhụ dị ukwuu. Ọ bụ naanị ma ha chegharịrị ka ihe ndị a na-agaghị abịakwasị ha.\wj*
\v 23 \wj Ma nʼebe ụmụ ya nọ, aga m etigbu ha ka ha nwụọ. Nzukọ niile ga-amata na abụ m onye na-enyocha mmụọ na mkpụrụobi niile. Aga m akwụghachikwa onye ọbụla nʼime unu ụgwọ ọrụ kwesiri ọrụ ya.\wj*
\pi1 
\v 24 \wj Ugbu a, ana m agwa unu ndị fọdụrụ na Tiatira, unu ndị na-agbasoghị ozizi ya, ndị na-amụtabekwaghị ihe ndị ahụ ekwensu kpọrọ ihe nzuzo dị omimi,\wj*\f + \fr 2:24 \fq Ihe nzuzo dị omimi \ft E nwere ọdị iche nʼetiti ihe omimi Mmụọ Nsọ na-ekpughe dị ka e dere nʼakwụkwọ \xt 1Kọ 2:10,\xt*\ft site nʼihe omimi ndị ọzọ. Ya mere, o ji dị mkpa na mmadụ ga-akpachapụ anya mgbe ọbụla onye dị otu na-achọ ịmata ụfọdụ ihe omimi, ka ọ rịọ inyeaka mmụọ nsọ.\f*\wj ‘O nweghị ibu arọ ọzọ m ga-ebokwasị unu,\wj*
\v 25 \wj ma ọ bụghị, unu jidesienụ ihe unu nwere aka ike tutu ruo mgbe m ga-abịa.’\wj*
\pi1 
\v 26 \wj Ma onye ọbụla na-emeri emeri, na-anọgidekwa na-eme uche m ruo ọgwụgwụ ihe niile, ka m ga-enye ikike nʼebe mba niile nọ.\wj*
\v 27 \wj Onye ahụ, ‘ga-eji mkpara igwe chịa ha, dịka mgbe a kụwachara ite aja na mpekele na mpekele.’\wj*\f + \fr 2:27 \ft \xt Abụ 2:9\xt*\f*\wj Ọ bụladị ka Nna m si nye m ike,\wj*
\v 28 \wj a ga-enye onye nke meririnụ kpakpando ụtụtụ.\wj*
\v 29 \wj Onye ọbụla nwere ntị, ya nụrụ ihe Mmụọ Nsọ na-agwa nzukọ niile.\wj*
\c 3
\s1 Nzukọ dị nʼobodo Sardis
\p 
\v 1 \wj “Dee akwụkwọ nye mmụọ ozi ụlọ nzukọ dị na Sardis, sị ya:\wj*
\b
\pi1 \wj Ndị a bụ okwu onye ahụ nwere mmụọ asaa nke Chineke na kpakpando asaa.\wj*
\b
\pi1 \wj Amaara m ọrụ gị niile, ị nwere aha dịka onye dị ndụ ma ị bụ onye nwụrụ anwụ.\wj*
\v 2 \wj Ugbu a, sị nʼụra bilite. Mee ka ihe ntakịrị ahụ fọdụrụ na-achọ ịnwụ anwụ dịrị ike. Nʼihi na ọ dịghị ọrụ gị m hụrụ dị ka ihe zuruoke nʼanya Chineke m.\wj*
\v 3 \wj Ya mere, cheta ihe ndị ahụ ị natara na nke ị nụrụ; rube isi nye ya, chegharịakwa. Ma ọ bụrụ na i tetaghị, aga m abịakwute gị dị ka onye ohi, ị gaghị amatakwa oge m ji bịakwute gị.\wj*
\pi1 
\v 4 \wj Otu ọ dị, i nwere ụfọdụ mmadụ na Sardis ndị na-emerụbeghị uwe ha. Ha ga-eyiri uwe ọcha ma soro m jee ije nʼihi na ha bụ ndị kwesiri ekwesi.\wj*
\v 5 \wj Onye ọbụla na-emeri emeri, ka a ga-eyikwasị uwe mwụda ọcha dịka ha. Agaghị m ehichapụ aha ya site nʼakwụkwọ nke ndụ ahụ, kama aga m ekwupụtakwa aha ahụ nʼihu Nna m na nʼihu ndị mmụọ ozi niile.\wj*
\v 6 \wj Onye ọbụla nwere ntị, ya nụrụ ihe Mmụọ nsọ na-agwa nzukọ niile.\wj*
\s1 Nzukọ dị nʼobodo Filadelfia
\p 
\v 7 \wj “Dee akwụkwọ nye mmụọ ozi ụlọ nzukọ dị na Filadelfia, sị ya:\wj*
\b
\pi1 \wj Ndị a bụ okwu onye dị nsọ na onye eziokwu, onye ahụ ji ọtụghe igodo Devid, nke o ji emeghepụ ihe onye ọbụla na-apụghị imechi, na nke o ji emechi ihe onye ọbụla na-apụghị imeghe.\wj*
\b
\pi1 
\v 8 \wj Amaara m ọrụ gị niile. Lee, edebela m nʼihu gị ọnụ ụzọ nke e meghere emeghe, nke onye ọbụla na-apụghị imechi. Amaara m na i nwere ike dị ntakịrị, ma i debere okwu m, ị gọnarịkwaghị aha m.\wj*
\v 9 \wj Aga m eme ka ndị ahụ so na nzukọ ekwensu, bụ ndị na-asị na ha bụ ndị Juu ma ha abụghị, kama ha bụ ndị ụgha, aga m eme ka ha bịa kpọọ isiala nye gị, si otu a ghọta na ahụrụ m gị nʼanya.\wj*
\v 10 \wj Ebe i sitere na ntachiobi sọpụrụ okwu m niile, aga m ekpuchi gị site nʼoke mkpagbu ahụ, nke ga-abịakwasị ụwa mgbe a ga-anwale ndị niile bi nʼime ya.\wj*
\pi1 
\v 11 \wj Ana m abịa ọsịịsọ. Jidesienụ ihe unu nwere aka ike, ka onye ọbụla ghara ịnapụ gị okpueze gị.\wj*
\v 12 \wj Ma onye ọbụla na-emeri emeri, ka m ga-eme ka ọ bụrụ ogidi nʼime ụlọnsọ Chineke m. Ọ gaghị esikwa nʼebe ahụ pụọ apụọ. Aga m edekwasịkwa aha Chineke m nʼahụ, na aha obodo nsọ Chineke, nke bụ Jerusalem ọhụrụ ahụ si nʼeluigwe, ebe Chineke nọ na-arịdata. Aha ọhụrụ m ka a ga-edekwasịkwa nʼihu ya.\wj*
\v 13 \wj Onye ọbụla nwere ntị, ya nụrụ ihe Mmụọ Nsọ na-agwa nzukọ niile.\wj*
\s1 Nzukọ dị nʼobodo Laodisia
\p 
\v 14 \wj “Dee akwụkwọ nye mmụọ ozi ụlọ nzukọ dị na Laodisia, sị ya:\wj*
\b
\pi1 \wj Ndị a bụ okwu Amen, onye kwesiri ntụkwasị obi, na onye bụ ezi onyeama, bụrụkwa isi mmalite ihe niile Chineke kere.\wj*
\b
\pi1 
\v 15 \wj Amaara m ọrụ gị niile, na ị jụghị oyi, i kpoghịkwa ọkụ. Ọ gaara adị nnọọ mma ma asị na ị na-ajụ oyi ma ọ bụkwanụ na-ekpo ọkụ.\wj*
\v 16 \wj Nʼihi nke a, ebe ị na-ajụghị oyi, i kpoghịkwa ọkụ, ihe ị dị bụ ṅaraṅara. Nʼihi ya, aga m esi nʼọnụ m gbụpụ gị.\wj*
\v 17 \wj Nʼihi na ị na-asị, ‘abụ m ọgaranya, nwezuo ihe niile. Mkpa ihe ọbụla akpakwaghị m.’ Ma ị ghọtaghị na onye gba aka ka ị bụ. Ị bụ onye e kwesiri imere ebere. Ị bụkwa ogbenye na onye kpuru ìsì na onye gba ọtọ.\wj*
\v 18 \wj Ana m adụ gị ọdụ ka ịzụta ezigbo ọlaedo nʼaka m, bụ ọlaedo a nụchara anụcha nʼime ọkụ. Mgbe ahụ, ị ga-abụkwa ọgaranya nʼezie. Ị gaara esitekwa nʼaka m zụta akwa ọcha na-enweghị ntụpọ ka ị ghara ịgba ọtọ, ka ihere gharakwa ime gị. Ka ị zụrụkwa ezigbo ọgwụ ọrịa anya tee, ka ibido ịhụ ụzọ nke ọma.\wj*
\pi1 
\v 19 \wj Ndị m hụrụ nʼanya ka m na-abara mba na-enyekwa ha ahụhụ. Ya mere, nwee ịnụ ọkụ nʼobi, chegharịakwa.\wj*
\v 20 \wj Lee, ana m eguzo nʼọnụ ụzọ na-akụ aka. Ọ bụrụ na onye ọbụla anụ olu m ma meghee ụzọ, aga m abata soro ya rikọọ ihe, ya onwe ya ga-esokwa m rie ihe.\wj*
\pi1 
\v 21 \wj Onye ọbụla na-emeri emeri, ka mụ ga-enye ikike ka o soro m nọdụ nʼocheeze m. Ọ bụladị dịka m meriri sorokwa Nna m nọdụ nʼocheeze ya.\wj*
\v 22 \wj Onye nwere ntị, ya nụrụ ihe Mmụọ Nsọ na-agwa nzukọ niile.”\wj*
\c 4
\s1 Ocheeze dị nʼeluigwe
\p 
\v 1 Mgbe ihe ndị a gasịrị, eleliri m anya m hụ ọnụ ụzọ dị nʼeluigwe ka e meghere ya. Ụda olu ahụ m nụrụ na mmalite dara ọzọ, dị ka ụda opi ike sị m, \wj “Bịa, gbagota nʼebe a, ka m gosi gị ihe ga-emezuriri mgbe ihe ndị a gasịrị.”\wj*
\v 2 Nʼotu oge ahụ, e mere ka m nọọ nʼime mmụọ, ma lee, ahụrụ m onwe m nʼeluigwe, hụkwa ka e debere otu ocheeze nke otu onye na-anọkwasị nʼelu ya.
\v 3 Ụdịdị onye nọkwasịrị nʼocheeze ahụ na-egbu nweghenweghe dịka nkume dị oke ọnụahịa a na-akpọ jaspa na kanelian. Eke na egwurugwu dịka nkume oke ọnụahịa. Emeralụdụ gbara ocheeze ahụ gburugburu.
\v 4 Iri ocheeze abụọ na anọ ọzọ, gbara ocheeze ukwu ahụ gburugburu. Ndị nọkwasịrị nʼocheeze ndị a bụ iri ndị okenye abụọ na anọ, ndị yi uwe ọcha. Ha kpukwa okpueze e ji ọlaedo kpụọ nʼisi ha.
\v 5 Mgbe ahụ, ụda dịka ụda egbe eluigwe, ya na amụma na-egbuke sitere nʼocheeze ukwu ahụ na-ada na-achapụtakwa. Nʼihu ocheeze ukwu ahụ, e nwere oriọna asaa na-enwu ọkụ. Oriọna ndị a bụ mmụọ asaa nke Chineke.
\v 6 Nʼihu ocheeze ahụ e nwere ihe dịka oke osimiri e ji enyo mee, nke na-enwu dịka kristal.
\p Nʼetiti ihu ocheeze ahụ na gburugburu ya, e nwere anụ anọ dị ndụ nwere anya nʼakụkụ ahụ ha niile, ihu na azụ.
\v 7 Nke mbụ nʼime anụ ndị ahụ dị ndụ nwere oyiyi dịka ọdụm. Nke abụọ dịka ehi. Nke atọ nwere ihu yiri nke mmadụ. Nke anọ dịka ugo gbasapụrụ nku ya na-efe efe.
\v 8 Nke ọbụla nʼime ihe anọ ndị a dị ndụ nwere nku isii. Anya jupụtara nʼahụ ha niile na nʼime ha, ọ bụladị nʼokpuru nku ha. Ehihie na abalị niile, ọrụ ha bụ iti mkpu na-asị,
\qc “ ‘Nsọ, Nsọ, Nsọ
\qc ka Onyenwe anyị Chineke, Onye pụrụ ime ihe niile dị,’\f + \fr 4:8 \ft \xt Aịz 6:3\xt*\f*
\qc bụ onye ahụ dịkwaarị, onye ahụ na-adị, na onye ahụ na-aga ịbịa.”
\m 
\v 9 Mgbe ọbụla anụ ndị ahụ dị ndụ na-enye onye ahụ na-anọkwasị nʼelu ocheeze ahụ na-adị ndụ ruo mgbe niile ebighị ebi otuto na nsọpụrụ na ekele,
\v 10 iri ndị okenye abụọ na anọ ahụ na-adakwa nʼala nʼihu onye ahụ nọ nʼocheeze na-efe ya ofufe, bụ onye ahụ na-adị ndụ ruo mgbe niile ebighị ebi. Ha niile nʼotu nʼotu na-atụda okpueze ha nʼihu ya na-abụ abụ na-asị,
\q1 
\v 11 “Gị, Onyenwe anyị na Chineke anyị,
\q2 kwesiri ịnara otuto, na nsọpụrụ, na ike.
\q1 Nʼihi na gị onwe gị kere ihe niile,
\q2 ọ bụkwa site nʼọchịchọ gị ka e ji kee ha,
\q2 ma meekwa ka ha dịrị ndụ.”
\c 5
\s1 Akwụkwọ kọwara ihe na-aga ime
\p 
\v 1 Mgbe ahụ, ahụrụ m akwụkwọ e dere ihe ihu na azụ, nke a fụkọrọ afụkọ, kakwasịkwa ya akara asaa, ka ọ dị nʼaka nri onye ahụ nọkwasịrị nʼelu ocheeze ahụ.
\v 2 Ahụkwara m otu mmụọ ozi dị ukwuu, ka ọ na-ekwusa okwu nʼoke olu na-asị, “Ọ bụ onye kwesiri ịnyakapụ akara ndị a ma saghee akwụkwọ ahụ a fụkọrọ afụkọ?”
\v 3 Ma ọ dịghị onye ọbụla pụrụ ịsaghe akwụkwọ ahụ maọbụ ilenye ya anya a hụrụ nʼeluigwe, maọbụ nʼụwa, maọbụ nʼokpuru ụwa.
\v 4 Akwara m akwa nʼobi ilu nʼihi na ọ dịghị onye ọbụla a hụrụ tozuru oke ịsaghe akwụkwọ ahụ maọbụ ileba anya nʼime ya.
\v 5 Mgbe ahụ, otu onye nʼime ndị okenye ahụ gwara m sị, “Akwala akwa. Lee, Ọdụm ebo Juda, bụ mgbọrọgwụ Devid, emeriela. Ọ pụrụ ịnyakapụ akara asaa ahụ ma saghekwaa akwụkwọ ahụ.”
\p 
\v 6 Mgbe ahụ, ahụrụ m Nwa Atụrụ na-eguzo nʼetiti ocheeze ahụ dịka e gburu ya egbu. Anụ anọ ahụ dị ndụ na ndị okenye ahụ gbara ya gburugburu. O nwekwara mpi asaa na anya asaa, nke bụ mmụọ asaa nke Chineke, ndị e zipụrụ nʼime ụwa niile.
\v 7 Ọ gara nʼihu were akwụkwọ ahụ site nʼaka nri onye ahụ na-anọkwasị nʼelu ocheeze ahụ.
\v 8 Mgbe ọ weere ya, anụ anọ ahụ dị ndụ na iri ndị okenye abụọ na anọ ndị ahụ dara nʼala nʼihu Nwa Atụrụ ahụ. Ha niile nʼotu nʼotu jikwa ụbọ akwara na efere e ji ọlaedo mee, nke ihe jupụtara nʼime ha bụ ụda na-esi isi ụtọ, bụ ekpere ndị nsọ.
\v 9 Ha na-abụ abụ ọhụrụ na-asị,
\q1 “I kwesiri ịnara akwụkwọ ahụ
\q2 na ịnyakapụ akara ya,
\q1 nʼihi na e gburu gị,
\q2 ma site nʼọbara gị, ị gbataara Chineke ndị mmadụ,
\q2 ndị si nʼebo niile, na asụsụ niile, na ndị niile, na mba niile.
\q1 
\v 10 Ị chịkọtaala ha, mee ha otu alaeze na ndị nchụaja na-ejere Chineke anyị ozi.
\q2 Ha ga-achịkwa achị nʼụwa.”
\p 
\v 11 Mgbe ahụ, elere m anya, hụ ma nụkwa olu nke ọtụtụ ndị mmụọ ozi, nke ọnụọgụgụ ha ruru puku kwụrụ puku, na nde kwụrụ nde. Ha gbara ocheeze ahụ gburugburu, na anụ anọ ahụ dị ndụ na ndị okenye ahụ.
\v 12 Ha na-abụ abụ nʼoke olu na-asị,
\q1 “O kwesiri bụ Nwa Atụrụ ahụ e gburu egbu
\q2 ịnara ike na akụnụba na amamihe na ike
\q2 na nsọpụrụ na otuto na ngọzị.”
\p 
\v 13 Mgbe ahụ, anụrụ m ka ihe niile nọ nʼeluigwe na ndị nọ nʼụwa na ndị nọ nʼokpuru ụwa, na ndị nọ nʼokpuru oke osimiri na-eti mkpu abụ na-asị,
\q1 “Ka ngọzị, na nsọpụrụ niile, na otuto niile, na ike niile
\q2 dịrị onye ahụ na-anọkwasị nʼocheeze ahụ, na Nwa Atụrụ ahụ
\qc ruo mgbe niile ebighị ebi!”
\m 
\v 14 Anụ anọ ahụ dị ndụ zakwara sị, “Amen!” Ndị okenye ahụ dakwara nʼala nʼihu ya kpọọ isiala nye ya.
\c 6
\s1 Akara mechiri akwụkwọ ahụ
\p 
\v 1 Ahụrụ m mgbe Nwa atụrụ ahụ meghere otu nʼime akara asaa ahụ. Otu nʼime anụ anọ ahụ dị ndụ tiri mkpu dịka a ga-asị na ọ bụ egbe eluigwe sị, “Bịa!”
\v 2 Mgbe m lere anya, ahụrụ m ịnyịnya dị ọcha. Onye na-anọkwasị nʼelu ya ji ụta nʼaka ya. A tụkwasịkwara okpueze nʼisi ya dịka onye agha na-emeri emeri mgbe niile.
\p 
\v 3 Mgbe o meghere akara nke abụọ, ngwangwa, anụrụ m ka anụ nke abụọ ahụ nʼime anụ anọ ndị ahụ dị ndụ tiri mkpu sị, “Bịa!”
\v 4 Mgbe ahụ, ịnyịnya ọzọ na-acha ọbara ọbara pụtara. E nyere onye nọkwasịrị nʼelu ya ike iwepụ udo nʼụwa nakwa ime ka ụmụ mmadụ na-egburita ibe ha. E nyekwara ya mma agha dị ukwuu.
\p 
\v 5 Ma mgbe o meghere akara nke atọ, anụrụ m ka anụ nke atọ ahụ dị ndụ kwuru, “Bịa!” Ahụrụ m ịnyịnya dị ojii. Onye na-anọkwasị nʼelu ya ji ihe ọtụtụ abụọ nʼaka ya.
\v 6 Anụkwara m ihe dị ka olu nke sitere nʼetiti anụ anọ ahụ dị ndụ na-adapụta sị, “Otu ihe ọtụtụ kilo\f + \fr 6:6 \ft Ihe ọtụtụ nta dị otu kilo\f* nke ọka wiiti bụ ụgwọ ọrụ otu ụbọchị,\f + \fr 6:6 \ft Ya bụ, otu denarị\f* ihe ọtụtụ kilo atọ\f + \fr 6:6 \ft Ihe ọtụtụ dị kilo atọ\f* nke ọka balị bụkwa ụgwọ ọrụ otu ụbọchị. Ya mere, unu emebikwala mmanụ oliv na mmanya.”
\p 
\v 7 Mgbe o meghere akara nke anọ, anụrụ m ka anụ nke anọ dị ndụ sịrị, “Bịa!”
\v 8 Elere m anya ma hụ ịnyịnya na-acha ntụntụ nʼihu m. Aha onye nọkwasịrị nʼelu ya bụ Ọnwụ na Ọkụ ala mmụọ na-esokwa ya nʼazụ. E nyere ha ike nʼebe otu ụzọ nʼụzọ anọ nke ụwa dị ka ha jiri mma agha na ụnwụ, na ọrịa ọjọọ na anụ ọhịa gbuchapụ ndị bi nʼime ha.
\p 
\v 9 Ma mgbe ọ meghere akara nke ise, ahụrụ m nʼokpuru ebe ịchụ aja mkpụrụobi ndị niile e gburu egbu nʼihi okwu Chineke na nʼihi ịgba ama nke ha jidesiri ike.
\v 10 Ha ji oke olu tie mkpu na-asị, “Gị, Onye kachasị ihe niile elu, bụ Onyenwe anyị, onye dị nsọ na onye eziokwu, ruo olee mgbe ka ị na-eche ikpe ụwa na ndị bi nʼime ya ikpe ma bọọkwa ọbọ nʼisi ha maka ọbara anyị ha wufuru?”
\v 11 E nyere ha nʼotu nʼotu uwe ọcha, a gwakwara ha ka ha zuru ike nwa oge nta, tutu ruo mgbe ọnụọgụgụ ndị ozi ibe ha na ụmụnna ha a ga-egbu dịka e gburu ha ga-ezu.
\p 
\v 12 Anọkwa m na-ele anya mgbe o meghere akara nke isii ahụ. Nke a mere ka oke ala ọma jijiji dịrị. Anyanwụ gbara ọchịchịrị dị ka akwa mkpe e jiri ajị mee. E mekwara ka ọnwa chaa uhie uhie dịka ọbara.
\v 13 Mgbe ahụ, kpakpando dị na mbara eluigwe malitere ịdapụ nʼala dịka mkpụrụ osisi fiig na-achaghị acha si adapụ mgbe oke ifufe na-efegharị ya.
\v 14 Mbara eluigwe gabigara, dịka akwụkwọ mgbe a na-apịakọta ya. Ugwu niile na agwa etiti niile ka e wepụkwara site nʼọnọdụ ha.
\p 
\v 15 Ndị eze niile nke ụwa na ndị nọ nʼọchịchị dị iche iche, na ndị ọgaranya, na ndị nọ nʼọnọdụ dị elu, na ndị ọchịagha, na ndị mmadụ niile dị iche iche, ndị ukwu ma ndị nta, ndị ohu na ndị nwe onwe ha, ha niile gara zoo onwe ha nʼime ọgba nkume na nʼokpuru ugwu,
\v 16 ha na-eti mkpu na-arịọ ugwu ndị ahụ na-asị, “Dakwasịnụ anyị zoo anyị ka onye ahụ nọkwasịrị nʼelu ocheeze ahụ hapụ ịhụ anyị, ka oke iwe nke Nwa Atụrụ ahụ hapụ ịbịakwasị anyị.
\v 17 Nʼihi na, lee oke ụbọchị iwe ha abịala, onye pụrụ ịgbanarị ya?”
\c 7
\s1 Ndị ozi Chineke a kara akara
\p 
\v 1 Mgbe ihe ndị a gasịrị, ahụrụ m ndị mmụọ ozi anọ ka ha guzo nʼakụkụ anọ nke ụwa. Ha na-egbochikwa ka ifufe ọbụla ghara ife nʼelu ala, na nʼelu osimiri, na nʼelu osisi.
\v 2 Mgbe ahụ, ahụkwara m mmụọ ozi ọzọ ka o si nʼọwụwa anyanwụ na-apụta, akara Chineke dị ndụ dịkwa nʼaka ya. O tikuru ndị mmụọ ozi anọ ahụ mkpu, bụ ndị ahụ e nyere ike imekpa ụwa ahụ, ya na oke osimiri,
\v 3 na-asị, “Unu emebila ụwa maọbụ oke osimiri maọbụ osisi ọbụla tutu ruo mgbe anyị kachara ndị ohu niile nke Chineke anyị akara nʼegedege ihu ha.”
\v 4 Mgbe ahụ anụrụ m ọnụọgụgụ ndị a kara akara ahụ, ha dị narị puku mmadụ, na iri puku mmadụ anọ na anọ, bụ ndị sitere nʼebo niile nke Izrel.
\b
\li1 
\v 5 Ndị a kara akara site nʼebo Juda dị puku mmadụ iri na abụọ (12,000).
\li1 Ndị si nʼebo Ruben dịkwa puku mmadụ iri na abụọ (12,000).
\li1 Ndị si nʼebo Gad dị puku mmadụ iri na abụọ (12,000).
\li1 
\v 6 E sitere nʼebo Asha họpụta puku mmadụ iri na abụọ (12,000).
\li1 Ndị sitekwara nʼebo Naftalị dị puku mmadụ iri na abụọ (12,000).
\li1 E sitere nʼebo Manase\f + \fr 7:6 \ft Nʼebe a Manase nwa Josef, weere ọnọdụ Dan.\f* họpụta puku mmadụ iri na abụọ (12,000).
\li1 
\v 7 Ndị si nʼebo Simiọn dị puku mmadụ iri na abụọ (12,000).
\li1 Ndị sitere nʼebo Livayị dị puku mmadụ iri na abụọ (12,000).
\li1 Ndị si nʼebo Isaka dị puku mmadụ iri na abụọ (12,000).
\li1 
\v 8 E sitere nʼebo Zebụlọn họpụta puku mmadụ iri na abụọ (12,000).
\li1 Ndị si nʼebo Josef dị puku mmadụ iri na abụọ (12,000).
\li1 Ndị sikwa nʼebo Benjamin dị puku mmadụ iri na abụọ (12,000).
\s1 Oke igwe ndị yi uwe ọcha
\p 
\v 9 Mgbe ihe ndị a gasịrị, ahụrụ m oke igwe mmadụ, ndị dị ọtụtụ nʼọnụọgụgụ nke onye ọbụla na-apụghị ịgụta ọnụ. Ha sitere na mba dị iche iche na ebo dị iche iche na ndị niile na asụsụ dị iche iche, na-eguzo nʼihu ocheeze ahụ na nʼihu Nwa Atụrụ ahụ. Ha yikwasịrị onwe ha uwe ọcha, jirikwa igu nkwụ nʼaka ha.
\v 10 Ma ha ji oke olu na-eti mkpu na-asị,
\q1 “Nzọpụta dịrị Chineke anyị,
\q1 onye na-anọkwasị nʼocheeze ahụ,
\q1 dịkwara Nwa atụrụ ahụ.”
\m 
\v 11 Ndị mmụọ ozi niile ahụ guzoro ocheeze ahụ gburugburu, ha na ndị okenye ahụ na anụ anọ ahụ dị ndụ. Ha dara, kpuo ihu ha nʼala nʼihu ocheeze ahụ feekwa Chineke ofufe,
\v 12 na-asị,
\q1 “Amen!
\q1 Ngọzị niile na otuto niile,
\q1 na amamihe niile na ekele niile na nsọpụrụ niile
\q1 na ike niile na ume niile,
\q1 dịrị Chineke anyị ruo mgbe niile ebighị ebi.
\q1 Amen.”
\p 
\v 13 Mgbe ahụ, otu nʼime ndị okenye ahụ zara m sị, “Ị maara ndị ahụ, ndị a e gbokwasịrị uwe ọcha ahụ, ebee ka ha siri pụta?”
\p 
\v 14 Asịrị m, “Onyenwe m, ọ bụ gị maara.”
\p Ọ sịrị m, “Ndị a bụ ndị sitere nʼime oke mkpagbu ahụ pụta. Ha bụ ndị sachara uwe ha, mee ha ka ha dịrị ọcha site nʼọbara Nwa Atụrụ ahụ.
\v 15 Ọ bụ nke a mere,
\q1 “ha ji guzoro nʼihu ocheeze Chineke
\q2 na-efe ya ofufe ehihie na abalị nʼime ụlọnsọ ya.
\q1 Onye ahụ na-anọkwasị nʼelu ocheeze ahụ
\q2 ga-ekpuchikwa ha.
\q1 
\v 16 ‘Agụụ agaghị agụkwa ha ọzọ.
\q2 Akpịrị agaghị akpọkwa ha nkụ mgbe ọbụla.
\q1 Anyanwụ agaghị achakwa ha ọzọ,’\f + \fr 7:16 \ft \xt Aịz 49:10\xt*\f*
\q2 okpomọkụ ọbụla agaghị erute ebe ha nọ.
\q1 
\v 17 Nʼihi na Nwa Atụrụ ahụ nke nọ nʼetiti ocheeze ahụ
\q2 ga-abụ onye ọzụzụ atụrụ ha;
\q1 ‘ọ ga-edurukwa ha jee nʼisi mmiri nke ndụ ahụ.’\f + \fr 7:17 \ft \xt Aịz 49:10\xt*\f*
\q2 ‘Chineke ga-ehichapụkwa anya mmiri ọbụla site nʼanya ha.’\f + \fr 7:17 \ft \xt Aịz 25:8\xt*\f*”
\c 8
\s1 Nyakapụ akara nke asaa
\p 
\v 1 Mgbe o meghere akara nke asaa, akụkụ niile nke eluigwe dara jụụ ruo ihe dị ka iri nkeji atọ.
\p 
\v 2 Ahụrụ m ndị mmụọ ozi asaa, ndị na-eguzo nʼihu Chineke. E nyere ha opi ike nʼotu nʼotu.
\p 
\v 3 Mmụọ ozi ọzọ nke ji ite igwe ntakịrị e ji ọlaedo kpụọ bịara guzo nʼihu ebe ịchụ aja. E nyere ya ọtụtụ ụda na-esi isi ụtọ ka o jiri chụọ aja, ya na ekpere ndị nsọ niile, nʼebe ịchụ aja e jiri ọlaedo wuo, nʼihu ocheeze ahụ.
\v 4 Anwụrụ ọkụ nke ihe ahụ na-esi isi ụtọ, ya na ekpere ndị nsọ sitere nʼaka mmụọ ozi ahụ rigoo elu nʼihu Chineke.
\v 5 Mgbe ahụ kwa, mmụọ ozi ahụ weere ọkụ sitere nʼebe ịchụ aja ahụ tinye ya nʼime ite igwe ntakịrị ahụ, tụda ya, ka ọ danye nʼime ụwa. Mgbe o mere nke a, ụzụ egbe eluigwe dara, amụma gbukwara nʼụzọ dị oke egwu. Ala ọma jijiji dakwasịkwara ebe niile nʼụwa.
\s1 Ndị mmụọ ozi afụọ opi ike
\p 
\v 6 Mgbe ahụ, ndị mmụọ ozi asaa ahụ ndị ji opi asaa ahụ jikeere onwe ha ịfụ opi ike ahụ.
\p 
\v 7 Mgbe mmụọ ozi nke mbụ fụrụ opi ike ya, a tụdara mkpụrụ mmiri na ọkụ a gwakọtara ya na ọbara nʼime ụwa. Nke a mere ka otu ụzọ nʼime ụzọ atọ nke osisi rechapụrụ ọkụ, e rechapụkwara ahịhịa ndụ niile ọkụ.
\p 
\v 8 Mgbe mmụọ ozi nke abụọ fụkwara opi ike ya, a tụdara ihe yiri ugwu dị ukwuu na-enwu ọkụ nʼime osimiri. Nke a mere ka otu ụzọ nʼime ụzọ atọ e kere osimiri niile chagharịa ghọọ ọbara.
\v 9 Otu ụzọ nʼime ụzọ atọ nke ihe niile dị ndụ dị nʼime osimiri nwụrụ. Otu ụzọ nʼime ụzọ atọ e kere ụgbọ mmiri niile dị nʼelu osimiri lara nʼiyi.
\p 
\v 10 Mgbe mmụọ ozi nke atọ fụrụ opi ike ya, otu kpakpando dịkarịsịrị ukwuu nke na-enwu dị ka ọwaọkụ sitere na mbara eluigwe danye nʼime otu ụzọ nʼime ụzọ atọ e kere iyi niile na isi iyi niile.
\v 11 Aha kpakpando ahụ bụ Ilu ilu. Otu ụzọ nʼime ụzọ atọ nke mmiri malitere ilu ilu, ọtụtụ mmadụ nwụrụ nʼihi mmiri a na-elu ilu.
\p 
\v 12 Mgbe mmụọ ozi nke anọ fụrụ opi ike ya, e mere ka otu akụkụ nʼime akụkụ atọ e kere anyanwụ gbaa ọchịchịrị. Otu a kwa, otu akụkụ nʼime akụkụ atọ e kere ọnwa gbara ọchịchịrị. Ya na otu akụkụ nʼime atọ e kere kpakpando niile. Nke a mere ka anyanwụ hapụ inyekwa ìhè ya nʼuju dịka o si eme na mbụ. Otu ụzọ nʼime ụzọ atọ e kere ehihie ghọkwara oke ọchịchịrị, ọ dịkwa otu a nʼoge anyasị.\f + \fr 8:12 \ft Opi ike anọ mbụ dara metụtara ikpe Chineke nʼebe ihe e kere eke dị. Ihe a bụ ala, na osimiri, na iyi, na ihe ndị dị na mbara nʼelu, dị ka kpakpando, na anyanwụ na ọnwa.\f*
\p 
\v 13 Elere m anya, hụ ma nụkwa otu ugo ka ọ na-efegharị nʼetiti mbara eluigwe na-eti mkpu nʼolu ike na-asị, “Ahụhụ! Ahụhụ! Ahụhụ dịrị mmadụ niile bi nʼụwa nʼihi ụda opi ike nke ndị mmụọ ozi atọ ndị a ga-afụ.”
\c 9
\s1 Opi ike nke ise
\p 
\v 1 Mgbe mmụọ ozi nke ise ahụ fụrụ opi ike ya, ahụrụ m otu kpakpando si nʼeluigwe daa nʼala. E nyere ya ihe ọtụghe igodo nke e ji atụghe olulu nke Abis\f + \fr 9:1 \ft E mere ka anyị mata na ọ bụ olulu na-enweghị nsọtụ.\f* ahụ.
\v 2 Mgbe o meghere olulu Abis ahụ, anwụrụ ọkụ dị ukwu sitere nʼime ya pụta dịka anwụrụ ọkụ si nʼọkụ icheku ọkụ ya dị ukwuu, mee ka oke ọchịchịrị kpuchie ihu anyanwụ na mbara eluigwe.
\v 3 Igurube sitere nʼanwụrụ ọkụ ahụ pụta fedakwasa ụwa. E nyekwara ha ike ịta mmadụ ọbụla dịka akpị si agba mmadụ.
\v 4 E nyere ha iwu si ha emebila ahịhịa ndụ ọbụla, maọbụ osisi na ihe ọbụla a kụrụ nʼala. Kama ọrụ ha bụ ịbịakwasị mmadụ ọbụla na-enweghị akara Chineke nʼegedege ihu ya.
\v 5 Iwu e nyere ha abụghị ka ha gbuo ndị a, kama ọ bụ ka ha mekpaa ha ahụ ọnwa ise. Mmekpa ahụ ha dịka ahụ ụfụ na nhụju anya nke akpị mgbe ọ gbara mmadụ.
\v 6 Nʼime ụbọchị ndị ahụ, ọtụtụ mmadụ ga-achọ iji aka ha gbuo onwe ha ma ha agaghị enwe ike mee ya. Agụụ ịnwụ ọnwụ ga-agụ ha, ma ọnwụ ga-esi nʼebe ha nọ wezuga onwe ya.
\p 
\v 7 Igurube ndị a nwere oyiyi dị ka ịnyịnya a kwadebere maka ibu agha. Ha nwere ihe yiri okpueze e ji ọlaedo kpụọ nʼisi ha. Ihu ha dịkwa ka ihu mmadụ.
\v 8 Agịrị isi ha dịka agịrị isi ụmụ nwanyị. Eze ha dịkwa ka eze ọdụm.
\v 9 Ha yikwasịrị onwe ha ihe ikpuchi obi dịka nke e ji igwe kpụọ. Nku ha na-eme mkpọtụ dị ka ụda nzọ ụkwụ ọtụtụ ịnyịnya nke ụgbọ agha na-esekpu na-abanye nʼọgbọ agha.
\v 10 Ha nwere ọdụdụ dịka akpị. Ma ike niile e nyere ha bụ imerụ ndị mmadụ ahụ ọnwa ise site nʼike dị nʼọdụdụ ha.
\v 11 Ha nwere mmụọ ozi nke Abis,\f + \fr 9:11 \ft Olulu nke omimi ya na-enweghị nsọtụ.\f* onye na-achịkọta ha dịka eze. Aha ya nʼasụsụ Hibru bụ Abadọn, ma nʼasụsụ Griik ọ bụ Apolion.\f + \fr 9:11 \ft Ya bụ Onye Mbibi\f*
\p 
\v 12 Ahụhụ nke mbụ agafeela, ebe ahụhụ abụọ ọzọ na-abịa nʼihu.
\s1 Opi ike nke isii
\p 
\v 13 Mgbe mmụọ ozi nke isii fụrụ opi ike ya, anụrụ m olu sitere na mpi anọ ahụ dị nʼebe ịchụ aja ahụ e jiri ọlaedo wuo, nke dị nʼihu ocheeze Chineke,
\v 14 na-agwa mmụọ ozi nke isii ahụ, nke ji opi ike okwu, “Tọpụ mmụọ ozi anọ ndị ahụ e kere agbụ nʼebe osimiri Yufretis dị.”
\v 15 A tọhapụrụ ndị mmụọ ozi anọ ahụ, ndị e jibu eji na njikere maka oge awa ahụ, na ụbọchị ahụ, na ọnwa ahụ, na afọ ahụ, iji gbuo otu ụzọ nʼime ụzọ atọ nke mmadụ.
\v 16 Ndị agha ahụ, ọnụọgụgụ ha bụ narị nde abụọ. Anụrụ m mgbe e kwuru ole ha dị.
\p 
\v 17 Nʼime ọhụ m, ahụrụ m ịnyịnya ha, hụkwa ndị nọkwasịrị ha nʼelu. Ndị nọ nʼelu ịnyịnya ndị a yi ihe ikpuchi obi nke ụfọdụ nʼime ha na-acha ọbara ọbara. Ụfọdụ na-acha dịka akpụkpọ eluigwe, ụfọdụ na-acha odo odo. Ụfọdụ na-acha dịka anwụrụ ọkụ. Isi ịnyịnya ha dịka isi ọdụm, anwụrụ ọkụ na ọkụ na nkume ọkụ sị ha nʼọnụ na-apụta.
\v 18 E sitere nʼihe mmekpa ahụ ndị a, ire ọkụ, anwụrụ ọkụ na nkume ọkụ na-adịghị anyụ anyụ, ka ha ji gbuo otu ụzọ nʼime ụzọ atọ nke mmadụ niile bi nʼụwa.
\v 19 Ike ịnyịnya ndị a dị nʼọnụ ha, na ọdụdụ ha. Ọdụdụ ha dị ka agwọ, nwee isi agwọ nke ha ji emerụ mmadụ ahụ.
\p 
\v 20 Ma ndị fọdụrụ nʼetiti mmadụ, bụ ndị a na-egbughị site nʼihe ntaramahụhụ ọrịa ndị a, echegharịghị site nʼọrụ aka ha maọbụ ịkwụsị ife mmụọ ọjọọ ofufe. Ha jụkwara ịkwụsị ife arụsị ha niile nke ha ji ọlaedo na ọlaọcha na bronz na igwe na nkume na osisi kpụọ. Chi ndị na-apụghị ịhụ ụzọ, maọbụ ịnụ ihe, maọbụ ije ije.
\v 21 Ha echegharịghị site nʼigbu mmadụ ha, maọbụ ụzọ mgbaasị ha, maọbụ ndụ ịkwa iko ha, na izu ohi ha pụta.
\c 10
\s1 Mmụọ ozi ji akwụkwọ ntakịrị
\p 
\v 1 Ahụrụ m mmụọ ozi ọzọ dị oke egwu ka o si nʼeluigwe na-arịdata. Igwe ojii gbara ya gburugburu. Eke na egwurugwu dịkwa ya nʼisi. Ihu ya na-egbukwa maramara dịka anyanwụ. Ụkwụ ya na-acha dịka ogidi na-enwu ọkụ.
\v 2 O ji akwụkwọ ntakịrị a fụkọtara afụkọta nʼaka ya. Otu ụkwụ ya, nke aka nri ya, ka ọ zọnyere nʼime osimiri, ma ụkwụ nke aka ekpe ya ka ọ zọkwasịrị nʼelu ala.
\v 3 O ji oke olu, nke dara ụda dịka ịgbọ ụja ọdụm, tie mkpu, egbe eluigwe asaa gbara otu mgbe ahụ.
\v 4 Mgbe m chọrọ idetu ihe egbe eluigwe ndị a kwuru, anụrụ m otu olu si nʼeluigwe na-ekwu, “Edela ihe ahụ nʼakwụkwọ, nʼihi na-achọghị ka ndị ọzọ mata okwu ahụ egbe eluigwe ndị ahụ kwuru.”
\p 
\v 5 Mgbe ahụ, mmụọ ozi ahụ nke m hụrụ zọkwasịrị ụkwụ ya nʼelu osimiri, na nʼala akọrọ ahụ, chịlịri aka ya abụọ elu,
\v 6 were onye ahụ na-adị ndụ mgbe niile ebighị ebi ṅụọ iyi. Ya bụ onye ahụ kere eluigwe na ụwa, na ihe niile dị nʼime ha, na oke osimiri, na ndị niile bi nʼime ha, sị na oge ezuola. Na o kwesikwaghị ka a tufuo oge ọbụla.
\v 7 Nʼụbọchị ahụ, mgbe ndị mmụọ ozi asaa ahụ ga-afụ opi ike ha, ihe omimi niile nke Chineke ga-emezu, dịka ọ gwara ndị ohu ya bụ ndị amụma.
\p 
\v 8 Olu nke ahụ m nụrụ mbụ sitere nʼeluigwe gwa m okwu ọzọ, na-asị, “Gaa nara mmụọ ozi ahụ guzo nʼelu oke osimiri na ala akọrọ, akwụkwọ ahụ aseghere aseghe nke o ji nʼaka ya.”
\p 
\v 9 Ejekwuru m mmụọ ozi ahụ gwa ya ka o nye m akwụkwọ nta ahụ. Ọ sịrị m, “Nara ya, taa ya. Ọ ga-eme ka afọ gị luo ilu, ma ‘nʼọnụ gị, ọ ga-atọ gị ụtọ dịka mmanụ aṅụ.’\f + \fr 10:9 \ft \xt Izk 3:3\xt*\f*”
\v 10 Ya mere, anaara m ya akwụkwọ nta ahụ site nʼaka mmụọ ozi ahụ taa ya. Ọ tọrọ ụtọ dịka mmanụ aṅụ nʼọnụ m, ma mgbe m lodara ya, afọ m bidoro ilu ilu.
\v 11 Mgbe ahụ ha sịrị m, “Ị ghaghị ibu amụma ọzọ banyere ọtụtụ mmadụ, na ọtụtụ mba, na ọtụtụ asụsụ na ọtụtụ ndị eze.”
\c 11
\s1 Ndị ama abụọ
\p 
\v 1 Enyere m ihe ọtụtụ osisi achara e ji atụ ihe. Agwara m sị m, “Gaa tụọ ụlọnsọ ukwu Chineke, ma tụọkwa ebe ịchụ aja dị nʼụlọnsọ ahụ, gụọ ọnụọgụgụ ndị niile na-akpọ isiala nʼebe ahụ.
\v 2 Ma atụkwala ogige nke dị na mpụta ụlọnsọ ahụ, nʼihi na ewerela ya nye ndị mba ọzọ. Ha ga-azọtọkwa obodo nsọ ahụ ụkwụ iri ọnwa anọ na abụọ.
\v 3 Aga m enye mmadụ abụọ ndị ga-agbara m ama ike ka ha buo amụma otu puku ụbọchị na narị ụbọchị abụọ na iri ụbọchị isii (1,260), ha ga-eyi akwa mkpe.”
\v 4 Ndị a bụ osisi oliv abụọ ahụ na ihe ịdọba oriọna abụọ ahụ, ndị na-eguzo nʼihu Onye nwe ụwa.\f + \fr 11:4 \ft \xt Abụ 52:8; Zek 4:3,11,14\xt*\f*
\v 5 Ọ bụrụ na onye ọbụla achọọ imerụ ha ahụ, ọkụ ga-esi ha nʼọnụ pụta rechapụ ndị iro ha. Ọ bụrụ na onye ọbụla achọọ imerụ ha ahụ, a ga-egbu ya nʼụzọ dị otu a.
\v 6 A ga-enyekwa ha ike imechi eluigwe ime ka mmiri ozuzo ọbụla ghara izo nʼụwa nʼime afọ atọ na ọkara ahụ ha ga-ebu amụma ha. A ga-enyekwa ha ike ime ka osimiri na mmiri nta niile ghọọ ọbara. Ha ga-enwekwa ike ime ka ụdị ọrịa dị iche iche bịakwasị ụwa niile nʼoge ọbụla ha chepụtara nʼobi ha.
\p 
\v 7 Mgbe ha gbazuru ama ha, anụ ọhịa ahụ,\f + \fr 11:7 \ft Anụ ọhịa a bụ onye na-emegide Kraịst.\f* nke na-esite nʼime olulu Abis ahụ ga-ebuso ha agha merie ha, gbukwaa ha.
\v 8 Mgbe ha nwụchara, ozu ha ga-atọgbọrọ nʼokporoụzọ nke obodo ukwu ahụ nke a na-akpọ na mmụọ Sọdọm na Ijipt, ebe a kpọgburu Onyenwe ha nʼobe.
\v 9 A gaghị ekwenyekwa ka onye ọbụla lie ozu ha. Ma ndị niile dị iche iche nʼụwa, nʼebo niile, na asụsụ niile, na mba niile ga-agba ozu ha gburugburu ụbọchị atọ na ọkara nʼebe a tọgbọrọ ha na-ele ha anya.
\v 10 Ndị niile bi nʼụwa ga-aṅụrị ọṅụ, nyerịta ibe ha onyinye dị iche iche, kpọọ oriri dị iche iche iji ṅụrịa ọṅụ nʼihi ogbugbu e gburu ndị amụma abụọ ahụ, ndị wetaara ha oke nhụju anya.
\p 
\v 11 Ma mgbe ụbọchị atọ na ọkara gafesịrị, Chineke ga-eme ka Mmụọ ya na-enye ndụ banyekwa nʼime ha, ha bilitere ọtọ, oke egwu jidere ndị niile hụrụ ha.
\v 12 Ha nụrụ oke olu si nʼeluigwe daa na-asị, “rigotanụ nʼelu.” Ha siri nʼigwe ojii, rigoro nʼeluigwe ebe ndị iro ha ga-anọ na-ele ha anya.
\p 
\v 13 Ma nʼotu oge ahụ, nʼotu awa ahụ, ala ọma jijiji dịkarịsịrị oke egwu mara nke mere ka otu akụkụ nʼime akụkụ iri nke obodo ahụ niile daa. Ndị nwụrụ nʼoge ala ọma jijiji a dịkwa puku mmadụ asaa. Ma ndị niile fọdụrụ sitere nʼoke egwu nye Chineke nke eluigwe otuto.
\p 
\v 14 Ugbu a ahụhụ nke abụọ ahụ agafeela. Ma mgbe na-adịghị anya, ahụhụ nke atọ na-abịa.
\s1 Opi nke asaa
\p 
\v 15 Ka mmụọ ozi nke asaa fụrụ opi ike ya, oke olu dị iche iche dara ike ike nʼeluigwe, na-asị,
\q1 “Alaeze niile nke ụwa
\q2 abụrụla alaeze Onyenwe anyị, na nke Kraịst ya.
\q2 Ya onwe ya ga-achịkwa ruo mgbe niile ebighị ebi.”
\m 
\v 16 Mgbe ahụ, iri ndị okenye abụọ na anọ ahụ nọ nʼocheeze ndị ahụ dị nʼihu ocheeze Chineke dara nʼala kpọọ isiala nye Chineke,
\v 17 na-asị,
\q1 “Anyị na-enye gị otuto, gị Onyenwe anyị Chineke, Onye pụrụ ime ihe niile.
\q2 Onye na-adị, na onye dịkwaarị,
\q1 nʼihi na i werela oke ike gị niile nʼaka gị
\q2 malitekwa ịchị ọchịchị.
\q1 
\v 18 Mba niile were oke iwe megide gị,
\q2 ma ugbu a bụ oge gị iweso ha iwe dị ọkụ.
\q1 Ugbu a bụ oge ikpe ndị nwụrụ anwụ ikpe
\q2 na ịkwụghachi ndị ohu gị bụ ndị amụma ụgwọ ọrụ ha,
\q1 na ndị nsọ na ndị gị niile, bụ ndị na-atụ egwu aha gị,
\q2 bụ ndị dị nta na ndị dị ukwuu.
\q1 Oge eruokwala mgbe ịla nʼiyi ndị na-emebi ụwa ga-adị.”
\p 
\v 19 Mgbe ahụ kwa, e meghere ụlọnsọ Chineke nke dị nʼeluigwe. A hụkwara igbe ọgbụgba ndụ nʼime ya. Nʼotu oge ahụ kwa, egbe eluigwe malitere ịgba, amụma gbukwara. Oke ifufe bidokwara ife. Oke ala ọma jijiji na akụmmiri igwe mere mkpọtụ nke ukwuu.
\c 12
\s1 Nwanyị na agwọ ochie ahụ
\p 
\v 1 Oke ihe ịrịbama pụtara ihe nʼeluigwe, otu nwanyị e yikwasịrị anyanwụ dịka uwe. Ọnwa dịkwa nʼokpuru ụkwụ ya abụọ. Okpueze nwee kpakpando iri na abụọ dịkwa ya nʼisi.
\v 2 Ọ dị ime, na-etikwa mkpu nʼihi ahụhụ na ihe ụfụ nke ọmụmụ nwa.
\v 3 Mgbe ahụ, ihe ama ọzọ pụtara ihe nʼeluigwe, agwọ ochie nke dị ukwuu na-acha uhie uhie a na-akpọ dragọn, nke nwere isi asaa na mpi iri. O kpukwasịkwara okpueze asaa nʼisi ya.
\v 4 O nwere ọdụdụ nke o ji dọkpụrụ otu ụzọ nʼime ụzọ atọ nke kpakpando niile dị nʼeluigwe, tụda ha nʼala. Ọ bịara guzo nʼihu nwanyị ahụ na-achọ ịmụpụta nwa ahụ ọ dị ime ya, nọọ na njikere iri nwantakịrị ahụ ma a mụpụta ya.
\v 5 Ọ mụpụtara nwantakịrị nwoke, “onye ga-ejikwa mkpara ọchịchị chịa mba niile ọchịchị.”\f + \fr 12:5 \ft \xt Abụ 2:9\xt*\f* Nʼotu oge ahụ kwa, e si nʼebe ahụ wepụ nwata ahụ were ya gaa nʼebe Chineke nọ nʼeluigwe nʼocheeze ya.
\v 6 Ma nwanyị ahụ si nʼebe ahụ gbapụ gbalaa nʼọzara ebe Chineke kwadebere na ọ ga-anọ. Ebe ahụ ka a ga-elekọta ya anya nke ọma otu puku ụbọchị na narị ụbọchị abụọ na iri ụbọchị isii (1,260).
\s1 Agha a lụrụ nʼeluigwe
\p 
\v 7 Mgbe ahụ, agha dapụtara nʼeluigwe. Maikel na ndị mmụọ ozi ya buru agha megide agwọ ochie ahụ (a na-akpọ dragọn). Dragọn ahụ na ndị mmụọ ozi ya bukwara agha nke ha,
\v 8 ma e meriri ha, ha enwekwaghị ọnọdụ ọbụla nʼeluigwe.
\v 9 Dragọn ukwu ahụ, bụ agwọ ochie ahụ a na-akpọ ekwensu maọbụ Setan, nke na-eduhie ndị niile bi nʼụwa. A tụdara ya nʼụwa, ya na ndị mmụọ ozi ya niile.
\p 
\v 10 Mgbe ahụ, anụrụ m oke olu si nʼeluigwe na-ada sị,
\q1 “O mezuola nʼikpeazụ, bụ nzọpụta Chineke na ike
\q2 na alaeze Chineke anyị, na ikike ịchị isi Kraịst ya,
\q2 ha abụrụla ihe dị ire.
\q1 Nʼihi na e sitela nʼeluigwe chụtuo
\q2 onye ahụ na-ebo ụmụnna anyị ebubo.
\q2 Ọ na-ebo ha ebubo ehihie na abalị nʼihu Chineke.
\q1 
\v 11 Ha lụgburu ya nʼagha
\q2 site nʼọbara Nwa atụrụ ahụ
\q2 na site nʼama nke okwu ọnụ ha,
\q1 nʼihi na ha ahụghị ndụ ha nʼanya karịa,
\q2 kama ha jikere inye ndụ ha ọbụladị ruo nʼọnwụ.
\q1 
\v 12 Ya mere, ṅụrịanụ ọṅụ eluigwe
\q2 ma unu ndị niile bi nʼime ya.
\q1 Ma ahụhụ dịrị unu ndị bi nʼụwa na osimiri
\q2 nʼihi na ekwensu abịakwutela unu.
\q1 O jirila oke ọnụma bịakwute unu.
\q2 Ọ makwaara na oge a o nwere ehighị nne.”
\p 
\v 13 Mgbe agwọ ochie ahụ chọpụtara na a chụdala ya nʼụwa, ọ chụsoro nwanyị ahụ mụrụ nwa nwoke ahụ ọsọ.
\v 14 Ma e nyere nwanyị ahụ nku abụọ, nke dịka nku oke ugo, ka o jiri gbanarị agwọ ochie ahụ feba nʼime ọzara, ebe a kwadooro ya, na ebe a ga-anọ lezie ya anya afọ atọ na ọnwa isii.
\v 15 Ma agwọ ahụ meghere ọnụ ya mee ka mmiri si nʼọnụ ya sọpụta dịka iyi nke ga-ebufu nwanyị ahụ.
\v 16 Ma ala nyeere nwanyị ahụ aka. O meghere ọnụ ya loda idee mmiri a nke si nʼọnụ agwọ ahụ sọpụta.
\v 17 Mgbe ahụ, agwọ ochie ahụ wesara nwanyị ahụ iwe, pụọ ịga buo agha megide ụmụ ya bụ ndị niile fọdụrụ, bụ ndị niile na-edebe iwu Chineke na ndị na-ekwupụta na ha bụ ndị ama nke Jisọs.
\c 13
\s1 Anụ si nʼosimiri pụta
\p 
\v 1 Agwọ ochie ahụ guzoro nʼakụkụ nʼọnụ oke osimiri ahụ. Ma ahụrụ m otu anụ ọhịa ka o si nʼime oke osimiri na-arịpụta. Anụ ọhịa a nwere isi asaa na mpi iri. Okpueze iri dịkwa nʼelu mpi ndị a. Aha e dekwasịrị nʼisi asaa ahụ nʼotu nʼotu bụ ikwutọ na ikwuhie Chineke.
\v 2 Anụ ọhịa a m hụrụ dị ka agụ, ma ụkwụ ya dịka ụkwụ anụ ọhịa bịa. Ọnụ ya dịkwa ka nke ọdụm. Agwọ ochie ahụ nyere ya ike ya, na ocheeze ya na ikike dị ukwuu.
\v 3 Otu nʼime isi ya nwere ọnya buru ibu, nke pụrụ iwetara ya ọnwụ, e mere ka ọnya ahụ laa. Ụwa niile sobere anụ ọhịa ahụ nʼazụ nʼịtụnanya.
\v 4 Ha kpọrọ isiala nye agwọ ochie ahụ nʼihi na o nyere anụ ọhịa ahụ ikike dị otu a. Ha bidokwara ịkpọ isiala nye anụ ọhịa ahụ, na-asị, “Ebee ka onye ahụ nọ, nke dị ukwuu karịa ya, onye pụkwara ibu agha megide ya?”
\p 
\v 5 E nyekwara anụ ọhịa ahụ ọnụ na ike ikwu okwu mpako na ikike ikwulu ekwulu ọnwa iri anọ na abụọ.
\v 6 O meghere ọnụ ya malite ikwulu Chineke, na aha ya na ebe obibi ya, na ndụ ahụ bụ ndị bi nʼeluigwe.
\v 7 E nyere ya ike ibuso ndị nsọ agha na imeri ha. E nyekwara ya ikike ịchị agbụrụ niile, na ebo niile, na ndị niile, na mba niile na asụsụ niile.
\v 8 Ndị niile bi nʼelu ụwa ga-akpọkwa isiala nye ya, bụ onye ọbụla a na-edeghị aha ya nʼime akwụkwọ nke ndụ nke Nwa atụrụ ahụ e gbururị, site nʼoge e kere ụwa.
\p 
\v 9 Onye nwere ntị ya nụrụ.
\q1 
\v 10 “Ọ bụrụ na ọ dị onye ọbụla a ga-adọta nʼagha,
\q2 ọ bụ ha ka a ga-adọtakwa nʼagha.
\q1 Ọ bụrụ na ọ dị onye ọbụla ga-anwụ site na mma agha,
\q2 aghaghị iji mma agha gbuo ha.”\f + \fr 13:10 \ft \xt Jer 15:2\xt*\f*
\m Ka nke a bụrụ ihe ịgbaume na iguzosikwa ike nʼokwukwe nke ndị Chineke.
\s1 Anụ ọjọọ si nʼime ala pụta
\p 
\v 11 Mgbe ahụ kwa, ahụrụ m anụ ọhịa ọzọ dị iche ka o si nʼala na-arịpụta. O nwere mpi nta abụọ dịka mpi Nwa atụrụ, kama ọ na-ekwu okwu dịka agwọ ochie ahụ.
\v 12 Ọ na-achị isi nʼọnọdụ anụ ọhịa nke mbụ. Ọ bụkwa ike a ka o ji kwagide ụwa na ndị niile bi nʼime ya ka ha kpọọ isiala nye anụ ọhịa mbụ ahụ nke a gwọrọ ọnya ya na-eweta ọnwụ.
\v 13 Ọ na-emekwa ọtụtụ oke ihe ịrịbama dị iche iche. O mere ọbụladị ka ọkụ si na mbara eluigwe daa nʼụwa nʼihu mmadụ niile.
\v 14 O duhiekwara ndị mmadụ bi nʼụwa site nʼọrụ ịrịbama ya niile nke e nyere ya ike ịrụ nʼọnọdụ anụ ọhịa ahụ. Ọ gwakwara ndị niile bi nʼụwa ka ha kpụọ ihe oyiyi nke anụ ọhịa ahụ nke e jiri mma agha merụchaa ahụ, ma mechaa dị ndụ.
\v 15 E nyere ya ike ikunye ume ndụ nʼime oyiyi nke anụ ọhịa mbụ ahụ, ime ka ihe a kpụrụ akpụ kwuo okwu mekwa ka e gbuo ndị niile na-akpọghị isiala nye ya.
\v 16 O nyere iwu ka onye ọbụla, onye ukwu na onye nta, ọgaranya na ogbenye, ohu na onye nwe onwe ya, nata akara nʼaka nri maọbụ nʼegedege ihu ha.
\v 17 Ya mere, ọ dịghị onye ọbụla nwere ike ịzụ ahịa maọbụ ree ahịa ma ọ bụrụ na onye ahụ enweghị akara a, nke bụ aha anụ ọhịa ahụ, maọbụ ihe e ji mara ya, maọbụ ọnụọgụgụ nọchiri aha ya.
\p 
\v 18 Nke a ka chọrọ amamihe maka ịghọta ya. Ka onye ọbụla nwere ọgụgụisi, gụọ ọnụọgụgụ nke anụ ọhịa ahụ, nʼihi na ọ bụ ọnụọgụgụ mmadụ.\f + \fr 13:18 \ft Nke a bụ akara ọnụọgụgụ mmadụ e kere eke.\f* Ọnụọgụgụ ahụ bụkwa narị isi na iri isi na isii, ya bụ 666.
\c 14
\s1 Nwa atụrụ ahụ na ndị a gbapụtara
\p 
\v 1 Elere m anya hụ Nwa Atụrụ ahụ ka o guzo nʼugwu Zayọn. Ya na narị puku mmadụ na iri puku mmadụ anọ na anọ ahụ, bụ ndị e dekwasịrị aha ya na aha Nna ya nʼegedege ihu ha.
\v 2 Anụkwara m olu si nʼeluigwe na-ada dịka ụda mmiri si nʼime nkume na-asọpụta, maọbụ dịka ụda nke oke egbe eluigwe. Olu m nụrụ dịka olu ndị na-abụ abụ, ndị ji ụbọ akwara na-abụ abụ.
\v 3 Narị puku mmadụ na iri puku mmadụ anọ na anọ ndị ahụ guzo, chee ocheeze ahụ, anụ anọ ahụ dị ndụ, na ndị okenye ahụ ihu, na-abụ abụ, ha na-abụ abụ ọhụrụ. Nke naanị ha bụ ndị a gbapụtara nʼụwa pụrụ ịmụta.
\v 4 Ndị a bụkwa ndị na-emerụghị onwe ha nʼebe ụmụ nwanyị dị, nʼihi na ha dị ọcha ka ụmụ agbọghọ na-amaghị nwoke. Ha na-eso Nwa Atụrụ ahụ ebe ọbụla ọ na-aga. Ha bụ ndị a gbapụtara nʼetiti mmadụ ịbụrụ Chineke na Nwa Atụrụ ahụ dịka mkpụrụ mbụ.
\v 5 Ọ dịkwaghị okwu ụgha ọbụla a hụrụ nʼọnụ ha. Ha bụkwa ndị na-enweghị ịta ụta.
\s1 Ndị mmụọ ozi atọ
\p 
\v 6 Ahụkwara m mmụọ ozi ọzọ ka ọ na-efegharị nʼetiti mbara eluigwe. O ji oziọma nke ebighị ebi ahụ nʼaka, nke ọ na-aga ikwusara mba niile, na ebo niile, na asụsụ niile na mmadụ niile nọ nʼụwa.
\v 7 O jiri oke olu kwuo sị, “Tụọnụ egwu Chineke, nyekwanụ ya otuto, nʼihi na oge ikpe ya eruola. Kpọọkwanụ isiala nye ya, bụ onye kere eluigwe na ala, na oke osimiri na isi iyi mmiri niile.”
\p 
\v 8 Mgbe ahụ mmụọ ozi nke abụọ bịara soro ya, na-efegharị na-asị, “ ‘Ọ daala! Ọ daala, bụ Babilọn obodo ukwu ahụ,’\f + \fr 14:8 \ft \xt Aịz 21:9\xt*\f* bụ nke mere ka mba niile ṅụọ mmanya ọnụma nke ịkwa iko ya.”
\p 
\v 9 Mgbe ahụ, mmụọ ozi nke atọ bịakwara soro ha na-eti mkpu na-asị, “Onye ọbụla na-akpọ isiala nye anụ ọhịa ahụ si nʼime mmiri rịpụta, na oyiyi ya ahụ a kpụrụ akpụ, na onye na-anarakwa akara ahụ nʼegedege ihu maọbụ nʼaka ya,
\v 10 ha onwe ha, aghaghị isoro ṅụọ mmanya nke oke iwe Chineke, bụ nke a na-agwaghị agwa\f + \fr 14:10 \ft Nke a na-etinyeghị mmiri\f* gbanye nʼime iko ọnụma ya. A ga-ejikwa ọkụ na nkume ọkụ\f + \fr 14:10 \ft Maọbụ, \fqa sọlfọ\f* mekpaa ha ahụ nʼihu ndị mmụọ ozi dị nsọ na nʼihu Nwa Atụrụ ahụ.
\v 11 Anwụrụ ọkụ si nʼebe a na-emekpa ha ahụ apụta na-arịgo elu ruo mgbe niile ebighị ebi. Izuike agaghị adịrị ha ehihie na abalị bụ ndị ahụ kpọrọ isiala nye anụ ọhịa ahụ na oyiyi ya a kpụrụ akpụ, kwerekwa ka a kakwasị ha akara nke aha ya.
\v 12 Ka nke a bụrụ ihe ịgbaume nye ndị nsọ ya, bụ ndị nke Chineke na-erubere iwu ya isi, na-eguzosikwa ike nʼokwukwe ha nʼime Jisọs.”
\p 
\v 13 Anụkwara m olu nke si nʼeluigwe daa na-asị, dee ihe a nʼakwụkwọ, “Ndị a gọziri agọzi ka ha bụ, bụ ndị nwụrụ nʼime Onyenwe anyị site ugbu a gaa nʼihu.”
\p “E, ha ga-ezu ike site na ndọgbu niile nke ha dọgburu onwe ha, nʼihi na ọrụ ha rụrụ ga-eso ha,” ka Mmụọ Nsọ na-ekwu.
\s1 Oge iwe ihe ubi
\p 
\v 14 Elere m anya hụ otu igwe ọcha, nke onye nọdụrụ na ya dịka nwa nke mmadụ.\f + \fr 14:14 \ft \xt Dan 7:13\xt*\f* O kpu okpueze e jiri naanị ọlaedo mee, jirikwa mma iwe ihe ubi dị nkọ, nʼaka ya.
\v 15 Mgbe ahụ, otu mmụọ ozi sitere nʼụlọnsọ ukwu pụta, tikuo onye ahụ nọkwasịrị nʼigwe ọcha sị, “Ngwa, bido iji mma iwe ihe ubi gị rụọ ọrụ, nʼihi na oge owuwe ihe ubi eruola. Ihe a ga-aghọ aghọ nʼụwa achaala nke ọma.”
\v 16 Ya mere, onye ahụ nọkwasịrị nʼigwe ọcha ahụ rụnyere mma owuwe ihe ubi ya nʼime ụwa, ghọta ihe dị nʼụwa dịka ihe ubi.
\p 
\v 17 Mmụọ ozi ọzọ sitekwara nʼụlọnsọ ukwu dị nʼeluigwe pụta. Ya onwe ya jikwa mma owuwe ihe ubi dị nkọ.
\v 18 Mmụọ ozi ọzọ, nke na-elekọta ọkụ sitekwara nʼebe ịchụ aja ahụ pụta, were olu ike gwa mmụọ ozi ahụ ji mma dị nkọ sị, “Were mma owuwe ihe ubi gị dị nkọ bipụ osisi ụyọkọ mkpụrụ grepu site na vaịnị niile dị nʼụwa, nʼihi na ha niile achaala.”
\v 19 Ya mere, mmụọ ozi ahụ rụnyere mma owuwe ihe ubi ya nʼụwa, bipụsịa ụyọkọ mkpụrụ vaịnị ahụ chịkọta ha, kpojupụta ha ebe Chineke ga-eji iwe zọchaa ha.
\v 20 A zọchakwara mkpụrụ vaịnị ahụ nʼebe a na-azọcha mkpụrụ vaịnị nke dị nʼazụ obodo. Ọbara si nʼebe ahụ gbapụta dị elu ruo ihe dịka eriri e ji ekegide ịnyịnya nʼisi ime ka ọ gaa ebe achọrọ, ọ bụ ihe ruru narị kilomita atọ nʼogologo.\f + \fr 14:20 \ft Ihe ruru narị maịlụ na iri asatọ.\f*
\c 15
\s1 Ndị mmụọ ozi asaa ji ihe ntaramahụhụ asaa
\p 
\v 1 Ahụkwara m ihe ịrịbama ọzọ nʼeluigwe. Ọ dị ebube dịkwa oke egwu. Ndị mmụọ ozi asaa ji ụzọ ahụhụ asaa. Ha bụ ahụhụ nke ikpeazụ ndị ga-eweta iwe Chineke na ngwụcha.
\s1 Abụ ndị a gbapụtara bụrụ
\p 
\v 2 Ahụrụ m ihe dịka oke osimiri enyo a gwakọtara ya na ọkụ, na ndị ahụ nweterala mmeri nʼebe anụ ọhịa ahụ na oyiyi ya, na ọnụọgụgụ aha ya. Ha guzo nʼakụkụ oke osimiri enyo ahụ, jidekwa ụbọ akwara nke Chineke nʼaka ha.
\v 3 Ha na-abụ abụ Mosis ohu Chineke, na abụ Nwa atụrụ ahụ.
\q1 “Ọrụ gị niile dị ukwuu dịkwa ebube,
\q2 Onyenwe anyị Chineke, Onye pụrụ ime ihe niile.
\q1 Ụzọ gị niile ziri ezi, bụrụkwa eziokwu,
\q2 Gị, Eze nke mba niile.
\q1 
\v 4 Onye ga-aghara ịtụ gị egwu, Onyenwe anyị,
\q2 onye ga-agharakwa ito aha gị?
\q1 Nʼihi na ọ bụ naanị gị dị nsọ.
\q1 Mba niile ga-abịakwa
\q2 ịkpọ isiala nʼihu gị,
\q1 nʼihi na emeela ka ọrụ ezi omume gị pụta ìhè.”
\p 
\v 5 Mgbe nke a gasịrị, elere m anya hụ, na e meghere, ụlọnsọ ukwu dị nʼeluigwe, ya bụ, ụlọ ikwu nke iwu ọgbụgba ndụ ahụ.
\v 6 Mmụọ ozi asaa ndị ahụ ji ihe ntaramahụhụ asaa sị nʼụlọnsọ ahụ pụta. Ha yi uwe ogho ọcha, akwa ọcha na-enwu ezigbo ọcha. E kekwasịrị ihe okike ọlaedo gburugburu obi ha.
\v 7 Otu nʼime anụ anọ ndị ahụ dị ndụ bunyere mmụọ ozi asaa ndị ahụ efere ọlaedo asaa a gbajuru ọnụma Chineke, bụ onye ahụ na-adị ndụ mgbe niile ebighị ebi.
\v 8 Mgbe ahụ ụlọnsọ ahụ jupụtara nʼanwụrụ ọkụ si nʼebube na ike Chineke na-apụta. O nweghị onye ọbụla nwere ike ịba nʼụlọnsọ ahụ tutu ruo mgbe ntaramahụhụ asaa nke ndị mmụọ ozi asaa ahụ gwụchara.
\c 16
\s1 Efere asaa nke ọnụma Chineke
\p 
\v 1 Mgbe ahụ, anụrụ m oke olu si nʼụlọnsọ ahụ na-ada na-agwa ndị mmụọ ozi asaa ahụ okwu, “Ngwanụ, gaanụ wụsa ihe dị nʼefere ọnụma asaa Chineke ahụ nʼelu ụwa.”
\p 
\v 2 Mmụọ ozi nke mbụ pụrụ gaa wụsa ihe dị nʼefere nke ya nʼelu ụwa, ọnya ọjọọ na-egbu oke mgbu bịakwasịrị mmadụ niile nwere akara anụ ọhịa ahụ, na ndị na-akpọrọ oyiyi ya isiala.
\p 
\v 3 Mmụọ ozi nke abụọ wụsara ihe dị nʼime efere nke ya nʼelu osimiri niile. Otu mgbe ahụ, osimiri niile chagharịrị ghọọ ọbara dịka nke onye nwụrụ anwụ. Nke a mere ka ihe niile dị ndụ nʼime osimiri ahụ nwụọ.
\p 
\v 4 Mmụọ ozi nke atọ pụrụ gaa wụsa ihe dị nʼefere nke ya nʼelu iyi na nʼelu isi iyi niile. Nke a mere ka ha niile ghọọ ọbara.
\v 5 Anụrụ m ka mmụọ ozi ahụ mmiri niile dị nʼaka ya kwuru okwu sị,
\q1 “I kpere ikpe ziri ezi, Gị, Onye dị Nsọ,
\q2 na onye na-adị site na mmalite, na onye na-adịkwa ugbu a.
\q1 
\v 6 Nʼihi na ha wụsara ọbara ndị nsọ gị na ndị amụma gị.
\q2 Ma ugbu a, i nyela ha ọbara ka ha ṅụọ. Nke a bụkwa ezi ụgwọ ọrụ ha kwesiri ịnata.”
\m 
\v 7 Mgbe ahụ kwa, anụrụ m ka mmụọ ozi ahụ na-anọ nʼebe ịchụ aja sịrị,
\q1 “E, Onyenwe anyị Chineke, Onye pụrụ ime ihe niile,
\q2 ikpe gị niile bụ nke ziri ezi, bụrụkwa eziokwu.”
\p 
\v 8 Mmụọ ozi nke anọ pụrụ wụsa ihe dị nʼefere nke ya nʼelu anyanwụ si otu a mee ka anwụ were okpomọkụ ya chagbuo ndị mmadụ.
\v 9 Okpomọkụ ahụ si nʼanyanwụ bịa rere onye ọbụla ọkụ nʼahụ. Nke a mere ka ndị mmadụ bido ịkọcha aha Chineke, onye nwere ike ịchị ihe otiti ndị a, ma ha jụrụ ichegharị nye ya otuto.
\p 
\v 10 Mmụọ ozi nke ise pụrụ wụkwasị ihe dị nʼefere nke ya nʼelu ocheeze anụ ọhịa ahụ, mee ka alaeze ya jupụta nʼọchịchịrị. Ndị mmadụ tabiri ire ha nʼihi oke ahụ ụfụ.
\v 11 Ha kọchara Chineke nke eluigwe nʼihi ihe ụfụ na ọnya bịakwasịrị ha. Ma ha jụrụ ichegharị site nʼajọ ọrụ ha niile.
\p 
\v 12 Mmụọ ozi nke isii pụkwara wụkwasị ihe dị nʼefere ya nʼelu mmiri ukwu ahụ bụ Yufretis si otu a mee ka mmiri dị nʼime ya taa. Nke a mere ka ọ dịrị ndị eze ahụ si nʼọwụwa anyanwụ mfe.
\v 13 Ahụrụ mmụọ atọ rụrụ arụ ndị pụtara ihe nʼụdịdị awọ, ha si nʼọnụ agwọ ochie ahụ na nʼọnụ anụ ọhịa ahụ nwere ike ịrụ ọrụ ịtụnanya pụta, na nʼọnụ onye amụma ụgha ahụ.
\v 14 Ha bụ mmụọ nke ajọ mmụọ ndị ahụ na-arụ ọrụ ịrịbama. Ọ bụ ha na-ejekwuru ndị eze ụwa niile ịchịkọta ha maka ibu agha nʼụbọchị ukwu ahụ bụ ụbọchị Chineke Onye pụrụ ime ihe niile.
\b
\mi1 
\v 15 \wj “Lee! Ana m abịa dịka onye ohi. Ngọzị na-adịrị onye ahụ nọ na-eche nche, ndị yi uwe ha na njikere, ka ọ ghara ijegharị nʼọnọdụ ịgba ọtọ, bụrụ onye ọnọdụ ya na-eweta ihere.”\wj*
\b
\m 
\v 16 Ha kpọkọrọ ndị eze ahụ nʼotu ebe a na-akpọ Amagidọn nʼasụsụ Hibru.
\p 
\v 17 Mmụọ ozi nke asaa wụpụrụ ihe dị nʼefere nke ya nʼikuku, otu olu sitere nʼocheeze dị nʼụlọnsọ ukwu ahụ daa ụda sị, “Emezuola ya!”
\v 18 Mgbe ahụ egbe eluigwe bidoro na-agba na-eme mkpọtụ, amụma bidokwara na-egbu, oke ala ọma jijiji dịkwara nʼụwa, ụdị nke na-adịbeghị site na mgbe e kere ụwa. Ọ bụ ala ọma jijiji kachasị ala ọma jijiji ndị ọzọ njọ.
\v 19 Obodo ukwu ahụ kewara ụzọ atọ. Obodo niile dị na mba niile dakwara. Chineke chetara obodo ukwu ahụ bụ Babilọn. O nyere ya iko jupụtara na mmanya nke nʼoke iwe nke ọnụma ya.
\v 20 Mgbe ahụ, agwa etiti niile mikpuru, ugwu niile ghọrọ ala dị larịị.
\v 21 Mkpụrụ mmiri nke ịdị arọ otu nʼime ha ruru kilogram iri anọ na ọkara, sitere nʼeluigwe na-adakwasị ndị mmadụ. Nke a mekwara ka ha kọchaa Chineke nʼihi ihe ntaramahụhụ nke mkpụrụ mmiri ahụ, nʼihi na ihe ntaramahụhụ ahụ dị nnọọ njọ nke ukwuu.
\c 17
\s1 Nwanyị akwụna na anụ ọjọọ ahụ
\p 
\v 1 Otu nʼime ndị mmụọ ozi asaa ndị ahụ ji efere bịara sị m, “Bịa, aga m egosi gị ahụhụ ga-abịakwasị onye ahụ ụwa niile maara dịka akwụna, onye ahụ na-anọkwasị nʼelu ọtụtụ mmiri nke ụwa.
\v 2 Ndị eze ụwa esorola ya kwaa iko nʼotu ihe ndina, emeekwara ka ndị niile bi nʼụwa bụrụ ndị mmanya ịkwa iko ya na-egbu.”
\p 
\v 3 O duuru m nʼime mmụọ baa nʼọzara. Nʼebe ahụ ka m nọ hụ otu nwanyị nọkwasịrị nʼelu otu anụ ọhịa na-acha ọbara ọbara. Anụ ọhịa ahụ nwere isi asaa na mpi iri. Aha ndị e dere anụ ọhịa ahụ nʼahụ bụ naanị okwu ikwulu Chineke.
\v 4 Nwanyị ahụ yi akwa na-acha odo odo na nke na-achakwa ọbara ọbara, gbarakwa ihe ịchọ mma e ji ọlaedo, nkume dị oke ọnụahịa na pieal kpụọ. O jikwa iko ọlaedo nʼaka ya nke jupụtara nʼihe arụ na ihe ure niile o ji na-akwa iko ya.
\v 5 Aha e dekwasịrị ya nʼegedege ihu bụ ihe omimi:
\pc Obodo ukwu ahụ bụ Babilọn,
\pc nne ndị na-akwa iko
\pc na nke ihe arụ niile nke ụwa.
\m 
\v 6 Ejikwa m anya m hụ na nwanyị ahụ aṅụjuola ọbara ndị nsọ afọ, ya na ọbara ndị ama Jisọs.
\p Mgbe m hụrụ ya, ọ gbagwojuru m anya.
\v 7 Ma mmụọ ozi ahụ sịrị m, “Gịnị mere ihe ị hụrụ ji ju gị anya? Aga m akọwara gị ihe omimi banyere nwanyị a na anụ ọhịa ahụ nke na-ebugharị ya, bụ nke nwere isi asaa na mpi iri.
\v 8 Anụ ọhịa ahụ ị hụrụ, nwere mgbe ọ dịịrị, ma ugbu a, ọ dịkwaghị. Ma ọ ga-esi nʼolulu Abis ahụ pụta banye na mbibi. Ma nlọghachi ya ga-eju ndị ahụ a na-edeghị aha ha nʼime akwụkwọ ndụ ahụ site nʼoge e kere ụwa anya. Nʼihi na e nwere mgbe ọ dịịrị, ma ugbu a, ọ dịkwaghị, ma ọ ga-emesi bịa.
\p 
\v 9 “Nke a chọrọ uche nke nwere amamihe. Isi asaa ahụ nọchiri anya ugwu asaa ahụ nke nwanyị ahụ na-anọdụ nʼelu ha. Ha na-anọchikwa anya ndị eze asaa.
\v 10 Ise nʼime ha adaala, otu ka nọ, nke ọzọ abịabeghị. Mgbe ọ bịara, ọ ga-anọ nwantakịrị oge.
\v 11 Anụ ọhịa ahụ nke dịrịị ma ọ dịkwaghị, bụ onye nke asatọ, ọ bụ onye otu ndị eze asaa ahụ ma a lakwara ya nʼiyi.
\p 
\v 12 “Mpi iri ahụ ị hụrụ nọchiri anya ndị eze iri na-anatabeghị alaeze. Ha na anụ ọhịa ahụ ga-anata ike ọchịchị dịka eze sọọsọ otu awa.
\v 13 Ha ji otu obi na-enye anụ ọhịa ahụ ike ha na ịchị isi ha.
\v 14 Ha ga-ebu agha megide Nwa Atụrụ ahụ, ma Nwa Atụrụ ahụ ga-emeri ha nʼihi na ọ bụ Onyenwe kachasị ndị nwenụ niile nakwa Eze kachasị ndị eze niile. Ndị so ya bụkwa ndị a kpọrọ, na ndị a họpụtara, ndị ya kwesikwara ntụkwasị obi.”
\p 
\v 15 Mgbe ahụ ọ sịrị m, “Mmiri ndị ahụ ị hụrụ, ebe nwanyị akwụna ahụ nọ, bụ ndị mmadụ dị iche iche, igwe mmadụ, na mba dị iche iche na nʼasụsụ dị iche iche.
\v 16 Anụ ọhịa ahụ na mpi iri ahụ ị hụrụ ga-akpọ nwanyị akwụna ahụ asị. Ha ga-agba ya ọtọ, laakwa ya nʼiyi, ha ga-eri anụ ya, werekwa ọkụ rechapụ ya.
\v 17 Chineke etinyela ya nʼobi ha imejupụta nzube ya site nʼinwe otu obi nakwa inyefe anụ ọhịa ahụ ikike ọchịchị alaeze ha, tutu ruo mgbe a ga-emezu okwu Chineke.
\v 18 Ma nwanyị a ị hụrụ bụ obodo ukwu ahụ na-achị ndị eze niile nke ụwa.”
\c 18
\s1 Nkwatu obodo Babilọn
\p 
\v 1 Mgbe ihe ndị a niile gasịrị, ahụrụ m mmụọ ozi ọzọ ka o si nʼeluigwe na-arịdata. E nyere ya ikike dị ukwuu, ebube ya mekwara ka ihe jupụta nʼụwa.
\v 2 O ji olu dị ike tie mkpu,
\q1 “ ‘Ọ daala! Ọ daala! Babilọn Obodo Ukwu ahụ adaala!’\f + \fr 18:2 \ft \xt Aịz 21:9\xt*\f*
\q2 Ọ ghọọkwala ọgba obibi ndị mmụọ ọjọọ
\q1 nʼebe nzukọ mmụọ ndị ahụ na-adịghị ọcha,
\q2 nʼebe nzukọ ụmụ nnụnụ rụrụ arụ
\q2 nʼebe nzukọ ụmụ anụmanụ niile na-adịghị ọcha na ndị rụrụ arụ.
\q1 
\v 3 Nʼihi na mba niile aṅụọla
\q2 site na mmanya ọnụma nke ịkwa iko ya.
\q1 Ndị eze nke ụwa sokwaara ya kwaa iko,
\q2 ndị na-azụ ahịa nʼụwa aghọkwaala ndị ọgaranya site nʼoke ịba ụba nke ya.”
\s1 Ịdọ aka na ntị
\p 
\v 4 Mgbe ahụ, anụkwara m olu ọzọ si nʼeluigwe na-akpọ oku na-asị,
\q1 “ ‘Ndị m, sinụ nʼime ya pụta,’\f + \fr 18:4 \ft \xt Jer 51:45\xt*\f*
\q2 ka unu ghara iketa oke na mmehie ya,
\q2 ka unu gharakwa iketa oke ahụhụ ya.
\q1 
\v 5 Nʼihi na mmehie ya amụbaala ruo eluigwe.
\q2 Chineke echetakwala ajọ omume ya niile.
\q1 
\v 6 Mesonụ ya mmeso dịka o si meso unu.
\q2 Kwụghachinụ ya ụgwọ mmaji abụọ maka ihe o mere.
\q2 Gwakọọrọnụ ya mmaji abụọ nʼime iko mmanya ahụ nke ọ gwakọọrọ ndị ọzọ.
\q1 
\v 7 Nye ya ọtụtụ mmekpa ahụ na obi ilu
\q2 dịka ndụ otuto, nʼime onwe ya obi ụtọ nke o nyere onwe ya.
\q1 Ọ na-ekwu nʼobi ya na-asị,
\q2 ‘Abụ m eze nwanyị nọ nʼelu ocheeze m.
\q1 Abụghị m nwanyị di ya nwụrụ,
\q2 iru ụjụ ọbụla adịghị nye m.’\f + \fr 18:7 \ft \xt Aịz 47:7,8\xt*\f*
\q1 
\v 8 Nʼihi nke a, ihe ntaramahụhụ ya ga-abịakwasị ya nʼotu ụbọchị,
\q2 ọnwụ na iru ụjụ nke ọnwụ na-eweta, na ụnwụ.
\q1 A ga-eji ọkụ rechapụ ya,
\q2 nʼihi na Onyenwe anyị Chineke onye na-ekpe ya ikpe, dị ike.
\s1 Ahụhụ atọ bịakwasịrị obodo Babilọn
\p 
\v 9 “Ndị eze nke ụwa, ndị soro ya kwaa iko, ma bie ndụ ọchịchọ ọjọọ ya, ga-akwa akwa, ruo ụjụ nʼihi ya, mgbe ha ga-ahụ anwụrụ ọkụ nke ịkpọ ọkụ ya.
\v 10 Ha ga-eji oke egwu guzo nʼebe dị anya, kwaa akwa nʼihi ntaramahụhụ ya sị,
\q1 “ ‘Ahụhụ, Ahụhụ dịrị gị, Babilọn, Obodo ukwu a maara aha ya
\q2 gị Babilọn, obodo e ji ịdị ike maara.
\q1 Nʼotu ntabi anya, ikpe nke gị na-abịa.’
\p 
\v 11 “Ndị ahịa nke ụwa ga-akwa akwa ruokwa ụjụ nʼihi ya, nʼihi na ọ dịkwaghị onye na-azụ ihe ahịa ha ọzọ.
\v 12 Ngwa ahịa ọlaedo gị, na ọlaọcha, na ọla e ji achọ mma na nkume oke ọnụahịa, ezi akwa ọcha, na akwa uhie uhie, na akwa lọrịlọrị, na akwa odo odo, osisi niile na-esi isi ọma, ihe niile e ji ọdụ enyi mee, ngwa ahịa niile e ji osisi niile dị oke ọnụahịa mee, bronz, igwe na nkume mabụl.
\v 13 Ha na ụda sinamọn na mmanụ otite nke ọkpụrụkpụ eso osisi na-esi isi ụtọ, máá na frankisens, mmanya na mmanụ oliv, ụtụ ọka na wiiti, ehi na atụrụ, ịnyịnya na ụgbọala agha, na ndị na-ere mmadụ ibe ha dịka ohu, na ahụ mmadụ na mkpụrụobi mmadụ.
\p 
\v 14 “Ha ga-asị, ‘Mkpụrụ ndị ahụ niile nke na-agụ mkpụrụobi agụ e sitela nʼebe ị nọ gabiga. Ihe ọma niile i ji ebi ndụ, na ihe oke ọnụahịa niile i ji azụ afọ gị, efunarịla gị. Apụghị ịchọtakwa ha ọzọ mgbe ọbụla.’
\v 15 Ndị ahịa ahụ bara ọgaranya site nʼaka ya, ga-anọ nʼebe dị anya, nʼihi oke egwu nke ntaramahụhụ ya, na-eru ụjụ, na-ebesikwa akwa ike.
\q1 
\v 16 “ ‘Ahụhụ, Ahụhụ dịrị gị, obodo ukwu ahụ,
\q2 nke e yikwasịrị ezi akwa ọcha, nke na-acha odo odo na ọbara ọbara
\q2 nke nya ihe ịchọ mma nke ọlaedo, nkume dị oke ọnụahịa dị iche iche na nkume pieal dị iche iche.
\q1 
\v 17 Nʼotu awa a ka a lara oke akụ niile ndị a nʼiyi.’
\p “Ndị niile nwee ụgbọ na-aga nʼoke osimiri, na ndị na-akwọ ụgbọ ndị ahịa nʼoke osimiri, na ndị niile na-eso ụgbọ mmiri ga-anọ nʼebe tere anya,
\v 18 na-eti mkpu mgbe ha ga na-ele anya na-ahụ anwụrụ ọkụ na-ala elu site nʼire ọkụ ya na-asị, ‘Olee obodo ọzọ dịka obodo ukwuu a?’
\v 19 Ha ga-ekpokwasị aja nʼisi igosi obi ọjọọ ha na-eti mkpu akwa na-asị,
\q1 “ ‘Ahụhụ, Ahụhụ dịrị gị, obodo ukwu a maara aha ya
\q2 ebe ndị niile nwere ụgbọ mmiri na-aga nʼosimiri
\q2 ghọrọ ndị ọgaranya site nʼakụ dị nʼime ya.
\q1 Ma ugbu a, nʼotu ntabi anya, ihe niile dị nʼime ya bụ ihe a laara nʼiyi.’
\b
\q1 
\v 20 “Ma gị eluigwe, ṅụrịa ọṅụ nʼihi ihe a dakwasịrị ya,
\q2 unu ndị nsọ, ṅụrịakwanụ ọnụ,
\q2 unu ndị amụma na ndị ozi, ṅụrịakwanụ ọnụ.
\q1 Nʼihi na Chineke ekpeela ya ikpe
\q2 nʼihi mmeso ya megide unu.”
\s1 Ụbọchị mkpebi ikpe Babilọn
\p 
\v 21 Mgbe ahụ, otu mmụọ ozi dị ukwuu tụtụlitere otu nkume nke dịka nkume igwe nri, tụba ya nʼime oke osimiri, na-asị,
\q1 “Otu a ka a ga-esi tufuo
\q2 Babilọn obodo ukwu ahụ,
\q2 agaghị ahụkwa ya ọzọ.
\q1 
\v 22 Ọ dịghị mgbe ọzọ ụzụ egwu ga-adị nʼebe ahụ.
\q2 Agaghị anụkwa olu ọja na une na ụbọ akwara na nke ndị na-afụ opi ike nʼime gị ọzọ.
\q1 Aghaghị ahụ onye ọrụ ǹka ọbụla
\q2 nʼime gị ọzọ.
\q1 Agaghị anụkwa ụzụ nkume igwe nri
\q2 nʼime gị ọzọ.
\q1 
\v 23 Ìhè nke sitere nʼoriọna
\q2 agaghị acha nʼime gị ọzọ.
\q1 Olu obi ụtọ nke nwoke na nwanyị
\q2 na-alụ di na nwunye agaghị adịkwa.
\q1 Ndị mgbereahịa gị bụ ndị a ma ama nʼelu ụwa,
\q2 ọ bụkwa mgbaasị gị ka e ji duhie mba niile nke ụwa.
\q1 
\v 24 Nʼime ya ka a hụrụ ọbara ndị amụma niile, na nke ndị nsọ niile,
\q2 na nke ndị ọzọ ahụ niile e gburu nʼụwa.”
\c 19
\s1 Otuto dịrị Onyenwe anyị
\p 
\v 1 Mgbe ihe ndị a gasịrị, anụrụ m ụzụ nke ọtụtụ igwe mmadụ nʼeluigwe. Ha niile na-eti mkpu na-asị,
\q1 “Haleluya!
\q1 Nzọpụta, na ebube na ike niile dịrị Chineke anyị.
\q2 
\v 2 Nʼihi na ikpe ikpe ya niile ziri ezi, bụrụkwa eziokwu.
\q1 Ọ kpeela nwanyị ahụ na-akwa iko ikpe,
\q2 onye ji ịkwa iko ya merụọ ụwa.
\q1 Ọ bọọlara ọbọ ọbara ndị ohu ya nʼisi ya.”
\p 
\v 3 Ọzọkwa, ha tiri mkpu,
\q1 “Haleluya!
\q1 Anwụrụ ọkụ si nʼime ya na-arịgo elu ruo mgbe ebighị ebi.”
\p 
\v 4 Mgbe ahụ, iri ndị okenye abụọ na anọ ahụ, ha na anụ anọ ahụ dị ndụ dara nʼala nʼihu Chineke onye nọkwasịrị nʼelu ocheeze ukwu ahụ, fee ya ofufe na-asị,
\q1 “Amen, Haleluya!”
\p 
\v 5 Otu olu sitekwara nʼocheeze ahụ na-asị,
\q1 “Toonu Chineke anyị,
\q2 unu ndị ohu ya niile,
\q1 ndị ukwu na ndị nta,
\q2 unu ndị na-atụ egwu ya.”
\p 
\v 6 Mgbe ahụ, anụkwara m olu dara ka olu igwe mmadụ dịkwa ka ụzụ mmiri na-ekwo ekwo, dịkwa ka ụda egbe eluigwe dasiri ike na-asị,
\q1 “Haleluya!
\q2 Nʼihi na Onyenwe anyị Chineke, Onye pụrụ ime ihe niile na-achị.
\q1 
\v 7 Ka anyị ṅụrịanụ ọṅụ, ka obi tọkwaa anyị ụtọ.
\q2 Ka anyị nye ya otuto.
\q1 Nʼihi na ọlụlụ di na nwunye nke Nwa Atụrụ ahụ eruola,
\q2 nwunye ya edoziekwala onwe ya.
\q1 
\v 8 E nyela ya ezi akwa ọcha nke na-enweghị ntụpọ ọbụla,
\q2 na nke dị nnọọ ezi ọcha ka o yikwasị onwe ya.”
\m (Ezi akwa ọcha ahụ nọchiri anya ọrụ ezi omume nke ndị nsọ rụrụ.)
\b
\p 
\v 9 Mmụọ ozi ahụ gwara m sị, “Dee nke a: Ngọzị dịrị ndị ahụ a kpọrọ ka ha bịa soro nʼoriri ọlụlụ nwunye Nwa Atụrụ ahụ.” Ọ gwakwara m sị, “Nʼeziokwu, ndị a bụ okwu nke Chineke.”
\p 
\v 10 Adara m nʼala nʼụkwụ ya ịkpọ isiala nye ya, ma ọ gwara m sị, “O kwesighị ka ị kpọọ isiala nye m nʼihi na abụ m naanị onyeozi ibe gị, na dịka ọtụtụ ụmụnna gị ndị na-agba ama banyere Jisọs. Ọ bụ naanị Chineke ka i kwesiri ịkpọ isiala nye. Nʼihi na ọ bụ Mmụọ nke amụma na-agba ama ihe banyere Jisọs.”
\s1 Onye nọkwasịrị nʼelu ịnyịnya ọcha
\p 
\v 11 Mgbe ahụ kwa, elere m anya hụ ka eluigwe meghere. Ahụkwara m otu ịnyịnya dị ọcha. Onye nọkwasịrị nʼelu ya bụ onye a na-akpọ Onye kwesiri ntụkwasị obi na Onye eziokwu. Ọ bụ onye na-ekpe ikpe nʼụzọ ziri ezi na-ebukwa agha.
\v 12 Anya ya na-acha dịka ire ọkụ. Ọtụtụ okpueze dịkwa ya nʼisi. Otu aha nke naanị ya maara omimi ya ka e dekwasịrị ya nʼegedege ihu.
\v 13 E gbokwasịrị ya uwe mwụda e denyere nʼọbara. Aha a na-akpọ ya bụ Okwu Chineke.
\v 14 Usuu ndị agha nke eluigwe, ndị yi uwe ezi akwa ọcha, na-enweghị ntụpọ, nọ nʼelu ịnyịnya ọcha na-eso ya.
\v 15 Ọ kpụ mma agha dị nkọ nʼọnụ ya, nke o ji egbutu mba niile. “Ọ ga-eji mkpara igwe achị ha.”\f + \fr 19:15 \ft \xt Abụ 2:9\xt*\f* Ọ na-azọchakwa mkpụrụ vaịnị nʼebe ịnara mmanya nke iwe ọkụ nke Chineke Onye pụrụ ime ihe niile.
\v 16 Otu aha ka e dere nʼelu uwe ya na nʼelu apata ya:
\pc Eze kachasị ndị eze niile, na Onyenwe kachasị ndị nwenụ niile.
\p 
\v 17 Mgbe ahụ, ahụrụ m otu mmụọ ozi ka o guzo nʼime anyanwụ na-eti mkpu nʼoke olu, na-akpọku ụmụ nnụnụ niile na-efe nʼetiti mbara eluigwe, “Bịanụ! Zukọọnụ maka oke oriri nke Chineke.
\v 18 Bịanụ soro rie anụ ahụ ndị eze, na ndị ọchịagha, na ndịisi agha. Sorokwanụ rie anụ ahụ ịnyịnya na anụ ahụ ndị nọkwasịrị nʼelu ha. Riekwanụ anụ ahụ ndị mmadụ, ndị ukwu na ndị nta, ndị ohu na ndị nweere onwe ha.”
\p 
\v 19 Mgbe ahụ, ahụrụ m anụ ọhịa ọjọọ ahụ ya na ndị eze niile dị nʼụwa, na ndị agha ha, ka ha zukọtara ibu agha megide onye ahụ nọkwasịrị nʼelu ịnyịnya ahụ na ndị agha ya.
\v 20 Ma e jidere anụ ọhịa ahụ, ya na onye amụma ụgha ahụ onye nke nọọrọ nʼihu ya gosi ihe ịrịbama nke o jiri duhie ndị niile natara akara nke anụ ọhịa ahụ, ya na ndị kpọọrọ ihe oyiyi ya isiala. A tụnyere anụ ọhịa ahụ na onye amụma ụgha ya na ndụ nʼime ọdọ ọkụ e ji nkume na-enwu ọkụ kwanye.
\v 21 Ndị agha ha fọdụrụnụ ka e jikwa mma agha dị nkọ, nke dị nʼọnụ onye ahụ nọ nʼelu ịnyịnya ọcha ahụ gbuo. Ụmụ anụ ufe niile nke eluigwe rikwara ozu ha.
\c 20
\s1 Puku afọ ahụ
\p 
\v 1 Mgbe ahụ kwa, ahụrụ m otu mmụọ ozi ka o si nʼeluigwe na-arịdata, o ji mkpisi igodo e ji atụghe olulu Abis ahụ. O jikwa eriri igwe dị ukwuu nʼaka ya.
\v 2 O jidere agwọ ochie ahụ, bụ agwọ ochie ahụ, onye bụ Ekwensu na Setan, kee ya agbụ otu puku afọ.
\v 3 Emesịa, a tụnyere ya nʼime olulu Abis ahụ, tụchie ụzọ ya. Ọ kakwara akara nʼelu ya ka agwọ ochie ahụ hapụ inwekwa ike iduhie mba niile dị nʼụwa ọzọ tutu ruo mgbe puku afọ gasịrị. Mgbe afọ ndị a zuru, a ga-atọghepụ ya ka ọ gagharịa nwantịntị oge.
\s1 Mbilite nʼọnwụ nke mbụ
\p 
\v 4 Mgbe ahụ, ahụkwara m ocheeze, hụkwa ndị nọ nʼelu ya. Ha bụ ndị e nyere ike ikpe ikpe. Ahụkwara m mkpụrụobi ndị ahụ e bepụrụ isi nʼihi na ha gbaara Jisọs akaebe, kwusakwa okwu Chineke. Ha akpọbeghị isiala nye anụ ọhịa ahụ maọbụ ihe oyiyi ya. Ha enweghị akara anụ ọhịa ahụ nʼegedege ihu ha, maọbụ nʼaka ha. Ha dịkwa ndụ ọzọ, sorokwa Kraịst chịa otu puku afọ.
\v 5 Nke a bụ mbilite nʼọnwụ nke mbụ. Ndị fọdụrụ nʼetiti ndị nwụrụ anwụ esoghị bilite nʼọnwụ tutu ruo mgbe puku afọ gafesịrị.
\v 6 Ndị a gọziri agọzi na ndị dị nsọ bụ ndị ahụ ketara oke na mbilite nʼọnwụ nke mbụ ahụ. Ọnwụ nke abụọ enweghị ike nʼebe ha nọ, nʼihi na ha ga-abụ ndị nchụaja Chineke na nke Kraịst, sorokwa ya chịa ọchịchị puku afọ.
\s1 Ikpe e kpere Setan
\p 
\v 7 Mgbe puku afọ ahụ gafesịrị, a ga-emekwa ka ekwensu si nʼụlọ mkpọrọ ya pụta.
\v 8 Ọ ga-apụkwa jegharịa iduhie mba niile nọ nʼakụkụ anọ nke ụwa, ya bụ Gog na Magog, ọ ga-akpọkọta ha maka agha. Ọnụọgụgụ ha dịka aja dị nʼikpere osimiri.
\v 9 Ha biliri agha guzo nʼụwa niile, gbaa ụlọ ikwu nke ndị nsọ Chineke hụrụ nʼanya gburugburu. Ma ọkụ sitere nʼeluigwe gbadata repịa ha.
\v 10 Mgbe ahụ, ekwensu ahụ dufuru ha ka a ga-atụnye nʼọdọ ọkụ e ji nkume na-enwu ọkụ kwanye. Ebe ahụ ka ọ ga-anọ, ya na anụ ọhịa ọjọọ ahụ, na onye amụma ụgha ya. Ha ga-anọkwa nʼọnọdụ ahụ mgbu ehihie na abalị ruo mgbe ebighị ebi.
\s1 Ikpe Ikpeazụ
\p 
\v 11 Ahụkwara m otu ocheeze ọcha buru ibu, na onye nọkwasịrị nʼelu ya. Ụwa na mbara eluigwe si nʼihu ya gbapụ, ahụkwaghị ebe ọbụla nye ha.
\v 12 Ahụrụ m ndị niile nwụrụ anwụ, ndị ukwu na ndị nta, ka ha guzo nʼihu ocheeze ahụ. E meghere akwụkwọ dị iche iche, meghekwa akwụkwọ ọzọ, nke bụ akwụkwọ nke ndụ. E sitekwara nʼihe niile e dere nʼakwụkwọ ahụ kpee ndị a niile nwụrụ anwụ ikpe dịka ọrụ ha rụrụ si dị.
\v 13 Oke osimiri niile nyeghachiri ndị niile nwụrụ nọ nʼime ha. Otu a kwa, ọnwụ na ala mmụọ nyeghachikwara ndị nwụrụ anwụ dị nʼime ha. E kpekwara onye ọbụla ikpe dịka ọrụ ya si dị.
\v 14 Emesịa, a tụnyere ọnwụ na ọkụ ala mmụọ nʼime ọdọ ọkụ ahụ. Nke a bụ ọnwụ nke ugboro abụọ nke bụ ọdọ ọkụ.
\v 15 Onye ọbụla a na-achọtaghị ebe e dere aha ya nʼakwụkwọ nke ndụ ahụ, ka a tụnyere nʼime ọdọ ọkụ ahụ.
\c 21
\s1 Eluigwe ọhụrụ na ụwa ọhụrụ
\p 
\v 1 Mgbe ahụ, ahụrụ m eluigwe ọhụrụ na ụwa ọhụrụ.\f + \fr 21:1 \ft \xt Aịz 65:17\xt*\f* Eluigwe nke mbụ na ụwa nke mbụ agabigala, osimiri adịghịkwa.
\v 2 Ahụkwara obodo nsọ ahụ bụ Jerusalem ọhụrụ ka o si nʼeluigwe ebe Chineke nọ na-arịdata. Ọ mara mma dịka nwaagbọghọ ejikwara nke ọma maka ịgakwuru di ya.
\v 3 Anụkwara m oke olu si nʼocheeze ahụ kwuo okwu sị, “Leenụ! Ebe obibi Chineke adịla ugbu a nʼetiti ụmụ mmadụ. Ọ ga-ebinyere ha. Ha ga-abụkwa ndị ya, nʼezie, Chineke nʼonwe ya ga-anọkwa nʼetiti ha bụrụkwa Chineke ha.
\v 4 Ọ ga-ehichapụ anya mmiri niile dị nʼanya ha. Ọnwụ agaghị adịkwa ọzọ.\f + \fr 21:4 \ft \xt Aịz 25:8\xt*\f* Ọ bụladị iru ụjụ na ịkwa akwa na ahụhụ agaghị adịkwa. Ihe ndị ochie niile agabigala.”
\p 
\v 5 Onye ahụ nọ nʼocheeze ahụ kwuru sị, “Lee, ana m eme ka ihe niile dị ọhụrụ.” Mgbe ahụ, ọ sịkwara, “Detuo ihe ndị a, nʼihi na okwu ndị a bụ ihe e kwesiri ịtụkwasị obi, bụrụkwa eziokwu.”
\p 
\v 6 Ọ sịrị m, “E mezuola ihe niile. Abụ m Alfa na Omega, Mmalite na Ọgwụgwụ. Aga m enye onye akpịrị na-akpọ nkụ mmiri nke si nʼisi iyi mmiri nke ndụ dịka ihe onyinye.
\v 7 Ndị ọbụla na-emeri emeri ga-enweta ihe nketa ndị a. Aga m abụkwa Chineke ha, ha onwe ha ga-abụ ụmụ m.
\v 8 Ma ndị na-atụ ụjọ, ndị na-ekweghị ekwe, na ndị na-emetọ onwe ha, na ndị ogbu mmadụ, na ndị na-akwa iko, na ndị ha na mmụọ ọjọọ na-akparịta ụka, na ndị na-ekpere arụsị, na ndị ụgha niile, ihe ha ga-eketa bụ ikpe ọmụma nke ịbanye nʼime olulu ahụ e ji nkume na-enwu ọkụ kwanye ọkụ. Nke bụ ọnwụ nke ugboro abụọ.”
\s1 Jerusalem ọhụrụ
\p 
\v 9 Otu nʼime ndị mmụọ ozi asaa ahụ, nke ji efere asaa ahụ nke ihe ntaramahụhụ dị nʼime ya bịakwutere m sị m, “Soro m, ka m gosi gị nwaagbọghọ ahụ bụ nwunye Nwa Atụrụ ahụ.”
\v 10 O buuru m nʼime Mmụọ buga m nʼotu ugwu buru ibu nke ịdị elu ya dịkwa ukwuu. O gosiri m obodo nsọ ahụ bụ Jerusalem ka o si na mbara eluigwe ebe Chineke nọ na-arịdata.
\v 11 O jupụtara nʼebube Chineke, na-enwu ma na-achakwa dịka nkume dịkarịsịrị oke ọnụahịa, dịka nkume jaspa, na-enwu dịka kristal.
\v 12 Mgbidi ya niile dị obosara dịkwa elu. O nwekwara ọnụ ụzọ iri na abụọ. Ọ bụkwa ndị mmụọ ozi iri na abụọ na-eche ọnụ ụzọ ndị a nche. E dekwara aha ebo iri na abụọ nke ụmụ Izrel nʼọnụ ụzọ ama ndị a nʼotu nʼotu.
\v 13 Ọnụ ụzọ ama atọ dị nʼakụkụ ọwụwa anyanwụ, atọ dị nʼakụkụ ugwu, atọ dị nʼakụkụ ndịda, ebe atọ dị nʼakụkụ ọdịda anyanwụ.
\v 14 Mgbidi ahụ nwere nkume iri na abụọ e ji tọọ ntọala ya. Nʼelu nkume ndị a nʼotu nʼotu ka e dere aha ndị ozi iri na abụọ nke Nwa Atụrụ ahụ.
\p 
\v 15 Onye ahụ na-agwa m okwu ji osisi e ji atụ ihe, nke e ji ọlaedo mee, nʼaka ya. O ji ya tụọ obodo ahụ na ọnụ ụzọ ama ya, na mgbidi ya.
\v 16 Nʼobodo ahụ, enweghị otu akụkụ nʼime akụkụ anọ nke mgbidi ya karịrị ibe ya. Ogologo ya na obodobo ya ha otu. O ji ihe ọtụtụ tụọ ya, ogologo ya na obodobo nakwa ịdị elu ya ha, ọtụtụ ya dị puku kilomita abụọ na narị kilomita abụọ.\f + \fr 21:16 \ft Ya bụ otu puku na narị maịlụ anọ.\f*
\v 17 Ọ tụkwara ịdị igbidi nke mgbidi ahụ chọpụta na ọ dị narị nzọ ụkwụ atọ, dịka ihe ọtụtụ nke mmụọ ozi ahụ si gụpụta.
\s1 Ịma mma nke obodo ahụ
\p 
\v 18 Ihe e ji rụọ mgbidi ya bụ nkume dị oke ọnụahịa a na-akpọ jaspa, jiri ezi ọlaedo a nụchara anụcha, nke na-enwu dịka enyo dị ọcha rụọ obodo ahụ.
\v 19 E ji nkume niile dị oke ọnụahịa chọọ ntọala mgbidi obodo ahụ mma. Ntọala nke mbụ, bụ nkume a na-akpọ jaspa, ntọala nke abụọ, nkume a na-akpọ safaia, ntọala nke atọ, nkume a na-akpọ kaldoni, nke anọ, nkume a na-akpọ emeralụdụ,
\v 20 nke ise, nkume a na-akpọ ọniks, nke isii, nkume a na-akpọ kanelian, nke asaa, nkume a na-akpọ krisolaịt, nke asatọ, nkume a na-akpọ beril, nke itoolu, nkume a na-akpọ topaazi, nke iri, nkume a na-akpọ krisoprez, nke iri na otu, nkume a na-akpọ jasint, nke iri na abụọ, nkume a na-akpọ ametisiti.
\v 21 Ọnụ ụzọ ama iri na abụọ ahụ bụ pieal iri na abụọ, ọnụ ụzọ ama ọbụla ka e ji otu nkume pieal rụọ nʼotu nʼotu. Ihe e ji rụọ okporoụzọ dị nʼobodo ahụ bụ naanị ọlaedo a nụchara anụcha ọbụla, nke dị ọcha dịka enyo e hichaziri nke ọma.
\p 
\v 22 O nweghị ụlọnsọ ukwu ọbụla m hụrụ nʼime obodo ahụ nʼihi na Onyenwe anyị Chineke, Onye pụrụ ime ihe niile na Nwa Atụrụ ahụ bụ ụlọnsọ ukwu obodo ahụ nwere.
\v 23 Ọ dịkwaghị mkpa ọ dịrị obodo ahụ ka anwụ maọbụ ọnwa mụkwasị ya, nʼihi na ebube nke Chineke bụ ìhè ya, oriọna ya bụkwa Nwa atụrụ ahụ.
\v 24 Mba niile ga-eji ìhè ya jegharịa. Ndị eze ụwa niile ga-abịakwa webata ebube ha nʼime ya.
\v 25 A naghị emechi ọnụ ụzọ ama obodo ahụ emechi. Ha na-eghe oghe ụbọchị niile nʼihi abalị ọbụla adịghịkwa nʼebe ahụ.
\v 26 Ebube na nsọpụrụ nke mba niile ka a ga-ewebata nʼime ya.
\v 27 Ọ dịkwaghị ihe ọbụla rụrụ arụ ga-abata nʼime ya. Otu a kwa, ọ dịkwaghị onye na-eme ihe arụ, maọbụ onye ụgha ga-abata nʼime ya, kama ọ bụ naanị ndị ahụ e dere aha ha nʼakwụkwọ nke ndụ Nwa Atụrụ ahụ.
\c 22
\s1 Mmiri na-enye ndụ
\p 
\v 1 Mmụọ ozi ahụ gosiri m iyi ahụ e si ekute mmiri nke na-enye ndụ nke na-enwu dịka kristal. O sikwa nʼokpuru ocheeze Chineke na Nwa atụrụ ahụ na-asọpụta,
\v 2 nʼetiti okporoụzọ ahụ dị nʼobodo ahụ. Nʼakụkụ aka nri na aka ekpe iyi ahụ, a ga-ahụ osisi ahụ na-enye ndụ. Osisi ndị a na-amị ụzọ mkpụrụ iri na abụọ dị iche iche. Ha na-amịpụta mkpụrụ ọhụrụ kwa ọnwa ọbụla. Akwụkwọ osisi ahụ wapụtara bụ ọgwụ e ji agwọ mba niile.
\v 3 A gaghị ahụ ihe ọbụla a bụrụ ọnụ nʼime obodo ahụ. Ocheeze Chineke na nke Nwa atụrụ ahụ ga-adị nʼobodo ahụ. Ndị ohu ya ga-efekwa ya ofufe.
\v 4 Ha ga-ahụkwa ihu ya, a ga-edekwa aha ya nʼegedege ihu ha.
\v 5 Abalị agaghị adịkwa ọzọ, ịmụnye oriọna agaghị adịkwa mkpa. Mkpa ìhè anwụ na-enye agaghị adịkwa nʼihi na Onyenwe anyị Chineke ga-abụ ìhè ha, ha ga-achịkwa achị dịka eze ruo mgbe ebighị ebi.
\s1 Ọbịbịa Jisọs
\p 
\v 6 Mmụọ ozi ahụ gwara m, “Okwu ndị a bụ ihe e kwesiri ịtụkwasị obi, bụrụkwa eziokwu. Onyenwe anyị, bụ Chineke, onye na-enye ndị amụma Mmụọ ya ezitela mmụọ ozi ya igosi ụmụodibo ya ihe ndị ahụ ga-emezu nʼoge na-adịghị anya.
\b
\p 
\v 7 \wj “Lee, ana m abịa ọsịịsọ. Ngọzị na-adịrị onye ahụ na-edebe okwu amụma ndị a dị nʼakwụkwọ a.”\wj*
\b
\p 
\v 8 Mụ onwe m bụ Jọn, hụrụ ihe ndị a niile, nụkwa ha. Mgbe m hụrụ ma nụchaa ihe ndị a niile, adara m nʼụkwụ mmụọ ozi a gosiri m ha ịkpọ isiala nye ya.
\v 9 Ma ọ sịrị m, “Emela ihe dị otu ahụ! Mụ onwe m bụkwa odibo Jisọs dịka gị onwe gị, na dịka ụmụnna gị ndị amụma, na dịka ndị ahụ niile na-edebe okwu niile e dere nʼakwụkwọ a. Kpọọrọ Chineke isiala.”
\p 
\v 10 Ma ọ sịrị, “Akachila okwu amụma ndị a dị nʼakwụkwọ akara, nʼihi na oge adịla nso.
\v 11 Ka ndị niile na-eme ajọ omume gaa nʼihu na-eme ajọ omume, ka ndị na-adịghị ọcha gaa nʼihu bụrụ ndị na-adịghị ọcha, ka ndị na-eme ezi ihe gaa nʼihu na-eme ezi ihe, ka ndị dị nsọ gaa nʼihu bụrụ ndị dị nsọ.”
\b
\s1 Ịdọ aka na ntị nakwa ọkpụkpọ oku
\p 
\v 12 \wj “Lee, ana m abịa ọsịịsọ! Ụgwọ ọrụ m ga-enye onye ọbụla dịka ọrụ ọ rụrụ si dị dịkwa m nʼaka.\wj*
\v 13 \wj Abụ m Alfa na Omega. Onye mbụ na Onye ikpeazụ, Mmalite na Ọgwụgwụ.\wj*
\b
\p 
\v 14 \wj “Ngọzị na-adịrị ndị ahụ sara uwe ha mmiri, ka ha si otu a bụrụ ndị na-enweta oke na mkpụrụ si nʼosisi ahụ na-enye ndụ, ndị ga-enwe ike isite nʼọnụ ụzọ ama ahụ baa nʼime obodo ahụ.\wj*
\v 15 \wj Nʼazụ obodo ka ndị ahụ bụ nkịta nọ, ha na ndị niile na-agba afa, na ndị niile na-akwa iko, na ndị niile na-egbu mmadụ, na ndị niile na-ekpere arụsị, na ndị niile hụrụ ụgha nʼanya ma na-emekwa ya.\wj*
\b
\p 
\v 16 \wj “Mụ onwe m, bụ Jisọs ezitela mmụọ ozi m ka ọ gbara unu ama a nye nzukọ m niile. Ọ bụ m bụ Mgbọrọgwụ na Mkpụrụ Devid. Abụkwa m Kpakpando ụtụtụ ahụ na-enwu enwu.”\wj*
\b
\p 
\v 17 Mmụọ Nsọ na nwanyị ahụ a na-alụ ọhụrụ na-asị, “Bịa!” Ka onye ọbụla nụrụ okwu a kwuo sị, “Bịa!” Onye akpịrị na-akpọ nkụ ya bịa, onye ọbụla chọrọ ya bịa ṅụrụ mmiri na-enye ndụ na-akwụghị ụgwọ ọbụla.
\b
\p 
\v 18 Ana m adọ onye ọbụla nụrụ okwu amụma dị nʼakwụkwọ a aka na ntị, sị, ọ bụrụ na onye ọbụla atụkwasị ihe ọbụla nʼelu ha, Chineke ga-atụkwasịrị onye ahụ ihe ntaramahụhụ ahụ niile e kwuru maka ha nʼakwụkwọ a.
\v 19 Ọ bụrụkwa na onye ọbụla ewepụ okwu ọbụla nʼakwụkwọ amụma a, Chineke ga-ewepụ oke o nwere nʼosisi ahụ na-enye ndụ, na oke o nwere nʼobodo nsọ ahụ, nke e kwuru okwu ha nʼakwụkwọ a.
\b
\p 
\v 20 Onye ahụ gbara ama ihe ndị a niile na-asị, \wj “Nʼezie, ana m abịa ọsịịsọ.”\wj*
\p Amen. Bịa, Onyenwe anyị Jisọs.
\b
\p 
\v 21 Ka amara Onyenwe anyị Jisọs dịnyere ndị nsọ niile. Amen.
