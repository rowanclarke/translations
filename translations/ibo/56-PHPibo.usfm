\id PHP - Biblica® Open Igbo Contemporary Bible 2020
\h Ndị Filipai
\toc1 Ndị Filipai
\toc2 Ndị Filipai
\toc3 Fil
\mt1 Ndị Filipai
\c 1
\p 
\v 1 Pọl na Timoti, ndị bụ ohu Kraịst Jisọs,
\b
\p Na-edegara unu ndị ụkọchukwu, ndị okenye\f + \fr 1:1 \fq Ndị okenye \ft ndị a na-ekwu nʼebe bụ ndị ahọpụtara ka ha na-eje ozi nʼokpuru ụkọchukwu maọbụ onye nlekọta nzukọ.\f* na ndị nsọ niile nọ nʼụlọ nzukọ Kraịst Jisọs dị nʼobodo Filipai.
\b
\p 
\v 2 Ka amara na udo nke sitere na Chineke Nna anyị, na Onyenwe anyị Jisọs Kraịst dịrị unu.
\b
\s1 Inye ekele na ekpere
\p 
\v 3 Ana m ekele Chineke m ekele mgbe ọbụla m chetara unu.
\v 4 Nʼime arịrịọ niile m na-arịọ ya mgbe niile nʼekpere m nʼihi unu, obi m na-ejupụta nʼọṅụ.
\v 5 Nʼihi inyeaka niile unu na-enye, ime ka izisa oziọma na-aga nʼihu ọ bụladị ruo ugbu a.
\v 6 Amaara m nʼezie, na onye ahụ malitere ọrụ ọma nʼime unu, ga-aga nʼihu ịrụzu ya ruo ụbọchị Kraịst Jisọs.
\p 
\v 7 Ọ bụ ihe ziri ezi nʼebe m nọ iche ụdị echiche dị otu a banyere unu niile, nʼihi na unu dị m nʼobi. Ma m nọ nʼagbụ maọbụ na m na-echekwa oziọma, na mgbe m na-eme ka o guzosie ike, unu niile esorola m keta oke nʼamara ahụ.
\v 8 Chineke bụ onye akaebe m, otu agụụ unu niile si agụsi m ike site nʼịhụnanya nke Kraịst Jisọs.
\p 
\v 9 Nke a bụkwa ekpere m, ka ịhụnanya unu na-ahụrịta onwe unu na-ababiga ụba oke. Ka unu nwee ike ito eto, ruo nʼinwe mmazu na nghọta ihe niile.
\v 10 Ka unu nwee ike nwapụta ihe nke kachasị mma. Mgbe ahụ, unu ga-adị ọcha nʼenweghị ịta ụta ọbụla maka ụbọchị nke Kraịst.
\v 11 Ebe e mejupụtara unu na mkpụrụ nke ezi omume nke sitere na Jisọs Kraịst iji bulie Chineke elu ma nyekwa ya otuto.
\s1 Ịdị ndụ bụ Kraịst
\p 
\v 12 Ugbu a ụmụnna m, nke a bụ ihe m chọrọ ime ka unu ghọta, na nsogbu niile dakwasịrị m emeela ka ọrụ ikwusa oziọma na-aga nʼihu.
\v 13 Nʼihi na ọ pụtala ihe nye ndị nche nke ụlọeze ahụ na onye ọbụla ọzọ, na ọ bụ naanị nʼihi na m bụ onye na-eso Kraịst ka e ji tụọ m mkpọrọ.
\v 14 Site na mkpọrọ a a tụrụ m, e meela ka ọtụtụ ụmụnna anyị bụrụ ndị nwere ezi ntụkwasị obi nʼime Onyenwe anyị, nwekwa oke nkwuwa okwu, izisa oziọma ahụ na-atụghị egwu ọbụla.
\p 
\v 15 Ọ bụ eziokwu na ụfọdụ ji ekworo na anya ụfụ na-ekwusa Kraịst, ma ụfọdụ kwa na-ezisa ya site nʼọchịchọ obi ziri ezi.
\v 16 Ndị ahụ ji ọchịchọ obi ziri ezi na-eme nke a nʼịhụnanya ebe ha matara na e tinyere m ebe a nʼihi izisa oziọma.
\v 17 Ndị mbụ ahụ na-ekwusa Kraịst site nʼọchịchọ obi nke onwe ha, ọ bụghị site nʼezi obi, ebe ha na-eche na ha ga-akpalị nsogbu nye m nʼime mkpọrọ.
\v 18 Gịnịkwa ka ogbochiri? Otu ọ dị, maọbụ nʼụzọ aghụghọ maọbụ nʼeziokwu, ihe dị mkpa bụ nʼụzọ ọbụla a na-ekwusa oziọma Kraịst, nʼihi nke a ka m na-aṅụrị ọṅụ.
\p E, m ga-aṅụrịkwa ọṅụ mgbe niile.
\v 19 Nʼihi na-amaara m na site nʼekpere unu, ya na ịgbaume nke Mmụọ Jisọs Kraịst ihe ndị a niile dakwasịrị m ga-emesi ghọọrọ m nzọpụta.
\v 20 Nʼihi na olileanya m na ntụkwasị obi m bụ na ihere agaghị eme m nʼụzọ ọbụla, kama, aga m enwe ezi agbamume nke ga-eme ka e bulie Kraịst elu nʼahụ m, ma ugbu a ma mgbe niile, maọbụ na ndụ, ma ọ bụkwanụ nʼọnwụ.
\v 21 Nʼihi na nʼebe m nọ, ịdị ndụ bụ Kraịst, ịnwụ ọnwụ bụkwa uru.
\v 22 Ma ọ bụrụ na ịdị ndụ nʼanụ ahụ, nke a buuru m ịrụpụta ọrụ bara uru, enweghị m ike ikwu nke m ga-ahọrọ.
\v 23 Ụzọ ihe abụọ a na-eche m ihu: Ma ọchịchọ obi m bụ ịlakwuru Kraịst, nʼihi na ọ bụ nke kachasị mma.
\v 24 Ma ọ pụtara ihe na ọ dị mkpa nye unu ma ọ bụrụ na m adịrị ndụ nʼanụ ahụ.
\v 25 Ebe nke a doro m anya, amara m na mụ na unu niile ga-aga nʼihu ịnọ maka ọganihu na ọṅụ nke unu nʼime okwukwe.
\v 26 Ka mgbe m ga-abịakwute unu ọzọ, unu ga-enwebiga ọṅụ oke nʼime Kraịst Jisọs nʼihi m.
\s1 Ibi ndụ nʼụzọ kwesiri oziọma
\p 
\v 27 Ma nʼọnọdụ ọbụla, na-ebinụ ndụ kwesiri oziọma nke Kraịst, ma abịara m leta unu maọbụ na abịaghị m, ka a mata na unu guzosiri ike nʼotu mmụọ, werekwa otu obi na-agba mgba nʼokwukwe nke ikwusa oziọma,
\v 28 na-atụghị ụjọ ihe ndị na-emegide unu ga-eme. Iguzosi ike unu ga-agbara ha ezi ama banyere ịla nʼiyi nke ga-abịakwasị ha. Ma nʼebe unu nọ, ọ ga-abụrụ unu nzọpụta pụtara ihe nke sikwa nʼebe Chineke nọ bịa.
\v 29 Nʼihi na ohere ahụ e nyere unu, abụghị naanị ikwere na Kraịst, kama ọ bụkwa ịhụ ahụhụ nʼihi ya.
\v 30 Unu nọ na-agabiga ụdị ibu agha ahụ unu hụrụ na m gabigara, nke unu na-anụkwa na m ka nọ nʼime ya ugbu a.
\c 2
\s1 Ịṅomi ịdị umeala nke Kraịst
\p 
\v 1 Ya mere, ọ bụrụ na e nwere nkasiobi ọbụla dịrị anyị nʼihi njikọta e jikọtara anyị na Kraịst, ọ bụrụkwa na e nwere inyeaka ọbụla site nʼịhụnanya ya, ọ bụrụkwa na ọ dị nnwekọ ọbụla anyị na Mmụọ na-enwekọ, ọ bụrụ na unu nwere obi nro na ọmịiko,
\v 2 meenụ ka ọṅụ m zuo oke, site nʼinwe nkwekọta nʼihe ọbụla, site nʼịhụrịta onwe unu nʼanya, sitekwa nʼinwekọ otu mmụọ, na otu uche.
\v 3 Emela ihe ọbụla nʼihi naanị ọdịmma nke gị, maọbụ bie ndụ nʼụzọ ịdọtara onwe gị otuto efu. Kama bụrụ onye wedara onwe ya ala, onye na-ahụ ndị ọzọ dị ka ndị ka ya mma.
\v 4 Echela echiche banyere naanị ihe metụtara gị, kama, na-eleba anya nʼihe banyere ndị ọzọ.
\p 
\v 5 Na mmekọrịta unu na ibe unu, nweenụ ụdị uche ahụ nke dị nʼime Jisọs Kraịst:
\q1 
\v 6 Onye ọ bụ ezie na o nwere ụdịdị Chineke site na mmalite
\q2 ma ọ gụghị ụdịdị ya dị ka Chineke dị ka ihe ọ ga-ejidesi aka ike.
\q1 
\v 7 Kama, ọ gụrụ onwe ya dị ka ihe efu,
\q2 site na ịnara ụdịdị nke onye bụ ohu,
\q2 onye nke a mụrụ dị ka mmadụ.
\q1 
\v 8 Ebe ahụrụ ya ka ọ dịka mmadụ nʼoyiyi,
\q2 o wedakwara onwe ya ala,
\q2 site nʼirube isi ruo ọnwụ,
\q3 bụ ọnwụ nke obe.
\b
\q1 
\v 9 Ọ bụ nʼihi nke a ka Chineke ji bulie ya elu nʼebe kachasị elu,
\q2 nyekwa ya aha kachasị aha niile elu.
\q1 
\v 10 Ka ọ ga-abụ mgbe ọbụla a kpọrọ aha Jisọs ka ikpere niile ọbụla gbuo nʼala,
\q2 ihe niile dị nʼeluigwe, ndị niile bi nʼụwa, na ndị bi nʼokpuru ụwa.
\q1 
\v 11 Ka ire niile ọbụla kwupụta na Jisọs Kraịst bụ Onyenwe anyị,
\q2 maka inye Chineke bụ Nna, otuto.
\s1 Wezuganụ ntamu nʼịrụ ọrụ unu
\p 
\v 12 Ya mere, ezi ndị enyi m, dị ka unu na-erube isi mgbe niile, ọ bụghị naanị mgbe m nọ, ma karịsịa ugbu a m na-anọghị unu nso, gaanụ nʼihu ịrụpụta nzọpụta unu site nʼịtụ egwu na ịma jijiji.
\v 13 Nʼihi na ọ bụ Chineke nʼonwe ya na-arụ ọrụ nʼime unu, inyere unu aka ịchọ ime ihe ọ chọrọ ka unu mee, na inyere unu aka ime ihe ahụ ọ chọrọ.
\p 
\v 14 Nʼihe ọbụla unu na-eme, wezuganụ ntamu na ịrụ ụka nʼetiti unu.
\v 15 Bienụ ndụ unu dị ka ụmụ Chineke, ndị a na-apụghị ịta ụta, ndị dị ọcha na ndị a na-apụghị ibo ebubo nʼime ụwa ọjọọ a, nʼetiti ọgbọ gbagọrọ agbagọ,\f + \fr 2:15 \ft \xt Dit 32:5\xt*\f* na nʼetiti ndị nwere obi nʼazụ. Mgbe ahụ, unu ga-enwupụta nʼetiti ha dị ka kpakpando nʼime ụwa!
\v 16 Na-echekwanụ nʼihu ha okwu ahụ na-enye ndụ. Ka ọ bụrụ na mgbe Kraịst bịara ọzọ, aga m aṅụrị ọṅụ, nʼihi na ọrụ m rụrụ nʼetiti unu abụghị ihe efu.
\v 17 Nʼezie, ọ bụrụ na-awụpụ m dị ka aja ihe ọṅụṅụ nʼelu aja nʼife ofufe nke sitere na Chineke nʼihi okwukwe unu. E, a si na e gbuo m nʼihi unu, aga m aṅụrị ọṅụ na-esorokwa unu niile nwe obi ụtọ
\v 18 otu aka ahụ, unu onwe unu kwesiri inwe obi ụtọ ma sorokwa m ṅụrịa ọṅụ.
\s1 Timoti na Epafroditọs
\p 
\v 19 Enwere m olileanya nʼime Onyenwe anyị Jisọs na m ga-ezitere unu Timoti nʼoge na-adịghị anya site ugbu a, ka m site nʼozi ọ ga-anata banyere unu nwee obi ụtọ.
\v 20 Enweghị m onye ọzọ dị ka ya, onye ga-eche ezi echiche maka ọdịmma unu.
\v 21 Nʼihi na ndị ọzọ na-echegbu onwe ha maka ọdịmma nke ha, ma ọ bụghị maka ọdịmma Jisọs Kraịst.
\v 22 Ma unu niile maara otu Timoti si dị oke mkpa. Ọ dị nnọọ dị ka nwa m, site nʼinyeaka ọ na-enyere m nʼọrụ izisa oziọma.
\v 23 Enwere m olileanya nʼezie izitere unu ya. M ga-emekwa nke a ma ọ bụrụ na m chọpụta ihe ọnọdụ m nʼebe a ga-abụ.
\v 24 Nʼezie, enwere m olileanya na site nʼinyeaka Onyenwe anyị, mụ onwe m ga-abịakwutekwa unu na mgbe na-adịghị anya.
\p 
\v 25 Otu ọ dị, echere m na ọ dị mkpa ugbu a izighachiri unu Epafroditọs, nwanna m na onye mụ na ya na-arụkọ ọrụ, onye mụ na ya na-ebukọ agha, onyeozi nke unu zitere ka ọ bịa nyere m aka nʼọnọdụ mkpa m.
\v 26 Ugbu a, ana m eziteghachiri unu ya, nʼihi na ọ na-agụsị ya agụụ ike ịhụ unu anya. O wutekwara ya nke ukwuu, na e mere ka unu mara na ọ dara ọrịa nʼoge gara aga.
\v 27 Nʼezie, ọ fọdụrụ nnọọ ntakịrị ka o site nʼọrịa ahụ daa nʼụra ọnwụ. Ma Chineke meere ya ebere. Ọ bụghị naanị ya, kama o mekwaara m ebere, nʼihi na o kweghị ka a tụkwasịrị m ihe mwute nʼelu ihe mwute.
\v 28 Nʼihi nke a, ọ na-anụ m ọkụ nʼobi izite ya nʼebe unu nọ. Nʼihi na amaara m na ọbịbịa ọ ga-abịakwute unu ga-eme ka unu ṅụrịa ọṅụ. Ọ ga-emekwa ka ọnọdụ nchegbu m dị mfe.
\v 29 Ya mere, arịọ m unu, werenụ ọṅụ nabata ya nke ọma nʼime Onyenwe anyị, na-asọpụkwaranụ ndị dị ka ya.
\v 30 Nʼihi na ọ fọdụrụ nwantịị ka o nwụọ, nʼihi ọrụ nke Kraịst, tinye ndụ ya nʼihe egwu iji mezuo ọrụ unu nʼebe m nọ.
\c 3
\s1 Atụkwasịla obi nʼanụ ahụ
\p 
\v 1 Na nchịkọta okwu ndị a niile, ụmụnna m, na-aṅụrịnụ ọṅụ nʼime Onyenwe anyị. Ike adịghị agwụ m ịgwa unu ihe ndị a. Ọ bakwaara unu uru ịnụ ụdị okwu a mgbe niile.
\v 2 Kpachapụrụnụ onwe unu anya nʼebe ndị mmadụ ọjọọ ahụ yiri nkịta nọ. Ndị ahụ na-eyiwasị ahụ ha.
\v 3 Nʼihi na ọ bụ anyị bụ ndị ezi obibi ugwu ahụ, ọ bụghị ha, nʼihi na anyị bụ ndị na-efe Chineke site na Mmụọ ya. Anyị na-aṅụrị ọṅụ nʼime Kraịst Jisọs. Anyị adịghị atụkwasị obi nʼihe e mere nʼanụ ahụ.
\v 4 Mụ onwe m nwere ike nwee ntụkwasị obi nʼihe ndị a.
\p Nʼihi na e nwee onye chere na ọ pụrụ ịtụkwasị obi ya nʼanụ ahụ, mụ onwe m nwere ụdị ntụkwasị obi ahụ karịa onye ahụ:
\v 5 e biri m ugwu nʼabalị nke asatọ site na mgbe a mụrụ m, abụ m onye Izrel, sitere nʼagbụrụ Benjamin; abụ m onye Hibru a mụrụ nʼetiti ndị Hibru; dị ka o si metụta iwu abụ m onye Farisii;
\v 6 igosi ịnụ ọkụ nʼobi m, akpagburu m chọọchị, nʼụzọ ezi omume nʼokpuru iwu, abụ m onye zuruoke.
\p 
\v 7 Ma ihe ndị a niile m gụrụ dịka ihe bara uru nʼoge gara aga, bụụrụ m ugbu a, ihe na-abaghị uru nʼihi Kraịst.
\v 8 E, karịa nke a, akpọọla m ihe ndị a niile ihe efu, nʼihi na a pụghị iji ha tụnyere ịdị oke ọnụahịa nke ịmata Kraịst Jisọs, Onyenwe m. Nʼihi ya, etufuola m ihe ndị a niile, gụọ ha dị ka ihe na-abaghị uru, ka m nwee ike rite Kraịst nʼuru.
\v 9 Ka e nwee ike hụ m nʼime ya. Enweghị m ezi omume nke aka m, nke dabere nʼiwu, kama ọ bụ nke sitere nʼokwukwe na Kraịst, ezi omume si na Chineke nke dabeere nʼokwukwe.
\v 10 Naanị ihe m chọrọ bụ ịmara Kraịst na ike dị na mbilite nʼọnwụ ya, na nnwekọ nke isoro ya keta oke nʼahụhụ ya, nakwa ka m yie ya nʼọnwụ.
\v 11 Ka m si otu a, ruo nʼogo nke inweta mbilite site nʼọnwụ.
\s1 Eleghị anya nʼazụ
\p 
\v 12 Anaghị m ekwu na m etozuola oke, maọbụ nwezuo ihe niile. Ma a na m agbalịsi ike ka m jide ihe ahụ nke Kraịst Jisọs jidere m nʼihi ya.
\v 13 Ụmụnna m, nʼezie, abụbeghị m ihe ahụ m kwesiri ịbụ. Ma ihe m ji ike m niile na-eme bụ ichefu ihe niile ndị gara aga, na ilekwasị anya nʼihe ahụ m na-agbaso bụ nke dị m nʼihu.
\v 14 Ana m agbasi ọsọ ike iji gbaruo nʼisi, maka irite ihe ahụ a na-agbata nʼọsọ, bụ ọkpụkpọ ịbanye na ndụ eluigwe ahụ nke Chineke kpọrọ m site na Jisọs Kraịst.
\s1 Ịṅomi ụzọ Pọl
\p 
\v 15 Ka anyị niile, bụ ndị tozuru oke nʼime mmụọ nwee uche dị otu a. Ọ bụrụkwa na ụfọdụ nʼime unu nwere uche ọzọ dị iche, Chineke ga-ekpughere unu nke a.
\v 16 Ka anyị jidesienụ aka ike naanị nʼihe ahụ anyị nweterela.
\p 
\v 17 Ụmụnna m, na-agbasonu ụdị ndụ m na-ebi, chọpụtakwanụ ndị ọzọ na-adị ndụ dị ka anyị si adị, mee ha ihe ilere anya unu.
\v 18 Nʼihi na agwala m unu nke a ọtụtụ mgbe, na-achọkwa ịgwa unu ya ọzọ ugbu a. Lee, anya mmiri dị m nʼanya ugbu a m na-ekwu ya sị na e nwere ọtụtụ ndị na-ebi ndụ ha dị ka ha bụ ndị iro obe Kraịst nʼezie.
\v 19 Ọgwụgwụ ndị dị otu a ga-abụ ịla nʼiyi. Afọ ha bụ chi ha, ndị otuto ha dịkwa nʼihere ha. Ha na-atụkwasị uche naanị nʼihe nke ụwa.
\v 20 Ma ebe obibi anyị dị nʼeluigwe, ebe anyị na-atụsi anya ike na Onye nzọpụta bụ Onyenwe anyị Jisọs Kraịst ga-esi bịa.
\v 21 Onye ga-agbanwe ahụ anyị dị ala ka ọ dị ka nke ya dị ebube, site nʼike nke mere ka o debe ihe niile nʼokpuru ya.
\c 4
\s1 Arịrịọ mmechi maka ịdị nʼotu nakwa ịnọgidesi ike
\p 
\v 1 Ya mere, ụmụnna m, ndị m hụrụ nʼanya, na ndị ihe ha na-agụsị m agụụ ike, unu ndị na-enye m ọṅụ, na ndị bụ okpueze m nʼihi ọrụ m na-arụ, bikonu, guzosienụ ike nʼime Onyenwe anyị.
\p 
\v 2 Arịrịọ m na-arịọ Yodia na Sintiki bụ, ha biko, nwe otu uche nʼime Onyenwe anyị.
\v 3 E, ana m arịọkwa gị, ezi onye mụ na ya na-arụkọ ọrụ, biko, nyere ụmụ nwanyị ndị a aka nʼihi na ha abụọ bụ ndị so m rụọ ọrụ ikwusa oziọma nye ndị ọzọ. Ha sokwa Klement rụọkwa ọrụ, bụ ndị ahụ e dere aha ha nʼakwụkwọ nke ndụ ahụ.
\s1 Ndụmọdụ ikpeazụ
\p 
\v 4 Na-aṅụrịnụ ọṅụ mgbe niile nʼime Onyenwe anyị. Ka m kwuokwa ya ọzọ, ṅụrịanụ ọṅụ!
\v 5 Meenụ ka mmadụ niile jiri anya ha hụ na unu bụ ndị obiọma nʼihe niile unu na-eme. Chetanụ na ọbịbịa Onyenwe anyị dị nso.
\v 6 Unu echegbula onwe unu banyere ihe ọbụla. Kama nʼihe niile, sitenụ nʼekpere na arịrịọ, ya na ekele, chee ihe niile na-akpa unu nʼihu Chineke.
\v 7 Udo Chineke, nke dị ukwuu karịa ihe ọbụla mmadụ nwere ike ịghọta, ga-eche echiche uche unu na obi unu nche nʼime Kraịst Jisọs.
\p 
\v 8 Nʼikpeazụ, ụmụnna m, na-echenụ echiche mgbe niile banyere ihe bụ eziokwu, na ihe dị mma, na ihe ziri ezi. Na-echekwanụ echiche banyere ihe dị ọcha, ihe ọbụla mabigara mma oke, ihe ọbụla dị mma na ndụ onye ọbụla nke e kwesiri ịṅomi, na nke e kwesiri inwe otuto nʼihi ya.
\v 9 Na-emenụ ihe ọbụla unu si nʼaka m mụta, maọbụ ihe unu nụrụ, ma ọ bụkwanụ ihe unu hụrụ m ka m na-eme. Chineke onye na-enye udo ga-anọnyekwara unu.
\s1 Ekele nʼihi Onyinye ha
\p 
\v 10 Ana m aṅụrị ọṅụ dị ukwuu nʼime Onyenwe anyị nʼihi na unu mechara malite iche echiche ọzọ banyere m. Unu bu m nʼobi nʼeziokwu ma unu enwetaghị ohere izipụta ya.
\v 11 Ọ bụghị na m nọ nʼọnọdụ oke mkpa na ụkọ. Nʼihi na amụtala m otu m ga-esi jiri ọṅụ nọrọ nʼọnọdụ ọbụla.
\v 12 Amụtala m otu m ga-esi nọrọ mgbe ihe siri ike na mgbe ihe bara ụba. Amụtakwala m otu m ga-esi nwee afọ ojuju nʼọnọdụ ọbụla, maọbụ mgbe m na-anọ agụụ, maọbụ mgbe m rijuru afọ, maọbụ mgbe m nwere ihe dị ukwuu maọbụ nʼoge ụkọ.
\v 13 Nʼihi na apụrụ m ime ihe niile site nʼinyeaka onye na-enye m ike.
\p 
\v 14 Ma unu mere nnọọ nke ọma inyere m aka nʼọnọdụ nsogbu nke m nọ nʼime ya.
\v 15 Unu onwe unu ndị Filipai maara na mbido nke oziọma a, mgbe m hapụrụ Masidonia, na o nweghị nzukọ ọzọ nyere m aka nʼinye maọbụ ịnabata onyinye, ma e wezuga unu.
\v 16 Ọ bụladị mgbe m nọ na Tesalonaịka, unu ziteere m onyinye ihe karịrị otu ugbo, inyere m aka na mkpa m.
\v 17 Ọ bụghịkwa na m chọrọ onyinye unu, kama ana m achọ ka mkpụrụ unu ga-amịta baa ụba, bara unu uru.
\v 18 Ugbu a, enweela m ihe niile na-akpa m mkpa, nʼezie, enweela m karịa ihe na-akpa m. Onyinye unu nyere m, nke Epafroditọs wetara, egboola mkpa m niile. Onyinye ndị a dị ka aja na-esi isi ụtọ a chụụrụ Chineke, nke ọ na-anabatakwa nke ọma.
\v 19 Ọ bụ Chineke m ga-egboro unu mkpa unu niile, site nʼụlọakụ ebube ya nke eluigwe, nʼihi Kraịst Jisọs.
\p 
\v 20 Ka otuto dịrị Chineke anyị, bụ Nna anyị, ruo mgbe niile ebighị ebi. Amen.
\b
\s1 Ekele ikpeazụ
\p 
\v 21 Keleere m ndị nsọ niile nʼime Kraịst Jisọs.
\p Ụmụnna ndị mụ na ha nọ na-ekelekwa unu.
\p 
\v 22 Ndị nsọ niile nọ nʼebe a na-ekele unu, karịsịa ndị nọ nʼụlọ Siza.
\b
\p 
\v 23 Ka amara Onyenwe anyị Jisọs Kraịst dịnyere mmụọ unu. Amen.
