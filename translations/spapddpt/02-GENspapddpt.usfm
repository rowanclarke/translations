\v 17 \w Cuando|strong="H1961"\w* \w los|strong="H5921"\w* \w sacaron|strong="H3318"\w* \w les|strong="H5921"\w* dijeron: ¡Huye \w por|strong="H5921"\w* tu \w vida|strong="H5315"\w*! \w No|strong="H6435"\w* \w mires|strong="H5027"\w* atrás, \w ni|strong="H6435"\w* \w te|strong="H5921"\w* detengas \w en|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* llanura. ¡\w Escapa|strong="H4422"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* montaña, \w no|strong="H6435"\w* \w sea|strong="H1961"\w* \w que|strong="H5921"\w* \w perezcas|strong="H5595"\w*!   
\p
\v 18 \w Lot|strong="H3876"\w* les contestó: ¡No, les \w ruego|strong="H4994"\w*, mis \nd ʼAdonay\nd*!  
\v 19 Miren, les \w ruego|strong="H4994"\w*, \w ya|strong="H4994"\w* \w que|strong="H3808"\w* su esclavo \w halló|strong="H4672"\w* \w gracia|strong="H2580"\w* ante sus \w ojos|strong="H5869"\w*, y engrandecieron la \w misericordia|strong="H2617"\w* para \w conmigo|strong="H6213"\w* y preservaron \w mi|strong="H2009"\w* \w vida|strong="H5315"\w*. Pero \w no|strong="H3808"\w* \w puedo|strong="H3201"\w* \w escapar|strong="H4422"\w* hasta la montaña, \w pues|strong="H4994"\w* \w el|strong="H6213"\w* desmayo me \w alcanzará|strong="H4672"\w*, y \w moriré|strong="H4191"\w*.  
\v 20 Oigan, les \w ruego|strong="H4994"\w*, \w esa|strong="H1931"\w* \w ciudad|strong="H5892"\w* \w está|strong="H2063"\w* \w cerca|strong="H7138"\w* para huir \w allá|strong="H8033"\w* y \w es|strong="H1931"\w* \w pequeña|strong="H4705"\w*. ¿\w No|strong="H3808"\w* \w es|strong="H1931"\w* insignificante? Permítanme \w que|strong="H1931"\w* huya \w allá|strong="H8033"\w* y conserve \w mi|strong="H2009"\w* \w vida|strong="H5315"\w*.   
\p
\v 21 \add Un ángel\add* le respondió: \w Ciertamente|strong="H1571"\w*, \w también|strong="H1571"\w* sobre \w esto|strong="H2088"\w* acepto tu ruego. \w No|strong="H1115"\w* destruiremos \w la|strong="H1571"\w* \w ciudad|strong="H5892"\w* \w de|strong="H6440"\w* \w la|strong="H1571"\w* cual \w hablaste|strong="H1696"\w*.  
\v 22 ¡Apresúrate! \w Escapa|strong="H4422"\w* \w hacia|strong="H6213"\w* \w allá|strong="H8033"\w*, \w pues|strong="H3588"\w* \w no|strong="H3808"\w* \w podré|strong="H3201"\w* \w hacer|strong="H6213"\w* alguna \w cosa|strong="H1697"\w* \w hasta|strong="H5704"\w* \w que|strong="H3588"\w* llegues \w allá|strong="H8033"\w*. \w Por|strong="H5921"\w* \w eso|strong="H3651"\w* \w llamó|strong="H7121"\w* \w Zoar|strong="H6820"\w* \w el|strong="H5921"\w* \w nombre|strong="H8034"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w*.   
\p
\v 23 \w Salía|strong="H3318"\w* \w el|strong="H5921"\w* \w sol|strong="H8121"\w* \w sobre|strong="H5921"\w* \w aquella|strong="H5921"\w* tierra cuando \w Lot|strong="H3876"\w* entraba \w en|strong="H5921"\w* \w Zoar|strong="H6820"\w*.  
\v 24 Entonces \nd \+w Yavé|strong="H3068"\+w*\nd* ordenó \w que|strong="H4480"\w* lloviera \w azufre|strong="H1614"\w* \w y|strong="H5921"\w* fuego \w desde|strong="H4480"\w* \w el|strong="H5921"\w* \w cielo|strong="H8064"\w* \w sobre|strong="H5921"\w* \w Sodoma|strong="H5467"\w* \w y|strong="H5921"\w* \w Gomorra|strong="H6017"\w* \w de|strong="H4480"\w* parte \w de|strong="H4480"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*,  
\v 25 y destruyó estas \w ciudades|strong="H5892"\w* y \w toda|strong="H3605"\w* aquella llanura, con \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* de las \w ciudades|strong="H5892"\w* y las plantas de \w la|strong="H3605"\w* tierra.  
\v 26 Pero la esposa de Lot \w miró|strong="H5027"\w* hacia atrás y \w se|strong="H1961"\w* convirtió en \w estatua|strong="H5333"\w* de \w sal|strong="H4417"\w*.   
\p
\v 27 Abraham, al madrugar, se dirigió al \w lugar|strong="H4725"\w* \w donde|strong="H8033"\w* \w estuvo|strong="H5975"\w* \w en|strong="H5975"\w* la \w Presencia|strong="H6440"\w* \w de|strong="H6440"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.  
\v 28 \w Miró|strong="H7200"\w* \w hacia|strong="H5921"\w* \w Sodoma|strong="H5467"\w*, \w Gomorra|strong="H6017"\w* \w y|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* región \w de|strong="H5921"\w* \w la|strong="H5921"\w* llanura. \w Ciertamente|strong="H2009"\w* \w vio|strong="H7200"\w* \w que|strong="H5921"\w* un humo \w subía|strong="H5927"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra, \w como|strong="H5921"\w* \w la|strong="H5921"\w* humareda \w de|strong="H5921"\w* un horno.   
\p
\v 29 Así ocurrió \w que|strong="H1961"\w* \w cuando|strong="H1961"\w* \nd ʼElohim\nd* \w destruyó|strong="H7843"\w* las \w ciudades|strong="H5892"\w* de la llanura, \nd ʼElohim\nd* \w se|strong="H1961"\w* acordó de Abraham. Por eso sacó \w a|strong="H3068"\w* \w Lot|strong="H3876"\w* de \w en|strong="H8432"\w* \w medio|strong="H8432"\w* de la destrucción de las \w ciudades|strong="H5892"\w* \w en|strong="H8432"\w* las cuales \w Lot|strong="H3876"\w* \w se|strong="H1961"\w* estableció.   
\s1 Descendencia de Lot  
\p
\v 30 \w Luego|strong="H1931"\w* \w Lot|strong="H3876"\w* \w subió|strong="H5927"\w* desde \w Zoar|strong="H6820"\w* \w y|strong="H3588"\w* vivió \w en|strong="H5973"\w* \w la|strong="H1931"\w* montaña \w con|strong="H5973"\w* \w sus|strong="H1931"\w* \w dos|strong="H8147"\w* \w hijas|strong="H1323"\w*, \w pues|strong="H3588"\w* \w temía|strong="H3372"\w* permanecer \w en|strong="H5973"\w* \w Zoar|strong="H6820"\w*. \w Habitó|strong="H3427"\w*, \w pues|strong="H3588"\w*, \w en|strong="H5973"\w* una caverna \w junto|strong="H5973"\w* \w con|strong="H5973"\w* \w sus|strong="H1931"\w* \w dos|strong="H8147"\w* \w hijas|strong="H1323"\w*.  
\v 31 Dijo \w la|strong="H5921"\w* primogénita \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w más|strong="H5921"\w* joven: Nuestro padre es anciano, \w y|strong="H5921"\w* \w no|strong="H5921"\w* hay \w en|strong="H5921"\w* \w esta|strong="H5921"\w* tierra ni un varón \w que|strong="H5921"\w* \w se|strong="H5921"\w* una \w a|strong="H3068"\w* nosotras \w según|strong="H5921"\w* \w la|strong="H5921"\w* costumbre \w de|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* tierra.  
\v 32 ¡\w Ven|strong="H3212"\w*! Hagamos \w beber|strong="H8248"\w* \w vino|strong="H3196"\w* \w a|strong="H3068"\w* nuestro padre, y unámonos \w con|strong="H5973"\w* \w él|strong="H5973"\w*. \w Así|strong="H5973"\w* preservaremos \w descendencia|strong="H2233"\w* \w de|strong="H5973"\w* nuestro padre.  
\v 33 \w Y|strong="H3068"\w* dieron \w a|strong="H3068"\w* \w beber|strong="H8248"\w* \w vino|strong="H3196"\w* \w a|strong="H3068"\w* \w su|strong="H1931"\w* padre \w aquella|strong="H1931"\w* \w noche|strong="H3915"\w*. Entró \w la|strong="H1931"\w* primogénita y \w se|strong="H3045"\w* unió \w a|strong="H3068"\w* \w su|strong="H1931"\w* padre, pero \w él|strong="H1931"\w* \w no|strong="H3808"\w* \w supo|strong="H3045"\w* cuándo \w ella|strong="H1931"\w* \w se|strong="H3045"\w* unió \w ni|strong="H3808"\w* cuándo \w se|strong="H3045"\w* \w levantó|strong="H6965"\w*.   
\p
\v 34 \w Sucedió|strong="H1961"\w* al día \w siguiente|strong="H4283"\w* \w que|strong="H1571"\w* \w la|strong="H1571"\w* primogénita dijo \w a|strong="H3068"\w* \w la|strong="H1571"\w* \w más|strong="H1571"\w* joven: \w Mira|strong="H2005"\w*, anoche \w me|strong="H5973"\w* uní \w con|strong="H5973"\w* \w mi|strong="H1961"\w* padre. Hagámosle \w beber|strong="H8248"\w* \w vino|strong="H3196"\w* \w también|strong="H1571"\w* \w esta|strong="H1961"\w* \w noche|strong="H3915"\w* \w y|strong="H1571"\w* \w vé|strong="H3068"\w*, únete \w con|strong="H5973"\w* \w él|strong="H5973"\w* \w y|strong="H1571"\w* preservemos \w descendencia|strong="H2233"\w* \w de|strong="H5973"\w* nuestro padre.  
\v 35 \w También|strong="H1571"\w* hicieron \w beber|strong="H8248"\w* \w vino|strong="H3196"\w* \w a|strong="H3068"\w* \w su|strong="H1931"\w* padre \w aquella|strong="H1931"\w* \w noche|strong="H3915"\w*. \w Se|strong="H3045"\w* \w levantó|strong="H6965"\w* \w la|strong="H1931"\w* \w más|strong="H1571"\w* joven \w y|strong="H1571"\w* \w se|strong="H3045"\w* unió \w con|strong="H5973"\w* \w él|strong="H1931"\w*. \w Sin|strong="H3808"\w* embargo, \w él|strong="H1931"\w* \w no|strong="H3808"\w* \w supo|strong="H3045"\w* \w cuándo|strong="H1571"\w* \w ella|strong="H1931"\w* \w se|strong="H3045"\w* unió, \w ni|strong="H3808"\w* \w cuándo|strong="H1571"\w* \w se|strong="H3045"\w* \w levantó|strong="H6965"\w*.   
\p
\v 36 Las \w dos|strong="H8147"\w* \w hijas|strong="H1323"\w* de \w Lot|strong="H3876"\w* \w concibieron|strong="H2029"\w* de su padre.  
\v 37 \w La|strong="H1931"\w* primogénita dio \w a|strong="H3068"\w* luz un \w hijo|strong="H1121"\w*, \w y|strong="H5704"\w* \w lo|strong="H1931"\w* \w llamó|strong="H7121"\w* \w Moab|strong="H4124"\w*, \w el|strong="H1931"\w* \w cual|strong="H1931"\w* \w es|strong="H1931"\w* padre \w de|strong="H5704"\w* \w los|strong="H1121"\w* moabitas \w hasta|strong="H5704"\w* \w hoy|strong="H3117"\w*.  
\v 38 \w También|strong="H1571"\w* \w la|strong="H1931"\w* \w más|strong="H1571"\w* joven dio \w a|strong="H3068"\w* luz un \w hijo|strong="H1121"\w*, \w y|strong="H1571"\w* \w lo|strong="H1931"\w* \w llamó|strong="H7121"\w* \w Ben-ammí|strong="H1931"\w*, \w el|strong="H1931"\w* \w cual|strong="H1931"\w* \w es|strong="H1931"\w* padre \w de|strong="H5704"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5704"\w* Amón \w hasta|strong="H5704"\w* \w hoy|strong="H3117"\w*.   
\c 20  
\s1 Abraham y Sara en Gerar  
\p
\v 1 Desde \w allí|strong="H8033"\w* Abraham viajó \w hacia|strong="H8033"\w* la tierra del Neguev. Acampó \w entre|strong="H8033"\w* \w Cades|strong="H6946"\w* y \w Shur|strong="H7793"\w*, y vivió temporalmente en \w Gerar|strong="H1642"\w*.  
\v 2 \w Y|strong="H3068"\w* Abraham decía con respecto \w a|strong="H3068"\w* \w Sara|strong="H8283"\w*, \w su|strong="H1931"\w* esposa: \w Es|strong="H1931"\w* mi hermana. \w Así|strong="H1931"\w* \w que|strong="H1931"\w* Abimelec, \w rey|strong="H4428"\w* de \w Gerar|strong="H1642"\w*, \w envió|strong="H7971"\w* y \w tomó|strong="H3947"\w* \w a|strong="H3068"\w* \w Sara|strong="H8283"\w*.   
\p
\v 3 Pero \nd ʼElohim\nd* vino \w a|strong="H3068"\w* Abimelec \w en|strong="H5921"\w* un \w sueño|strong="H2472"\w* \w aquella|strong="H1931"\w* \w noche|strong="H3915"\w* \w y|strong="H5921"\w* \w le|strong="H1931"\w* dijo: \wj \+w Mira|strong="H2009"\+w*, \+w eres|strong="H1931"\+w* hombre \+w muerto|strong="H4191"\+w* \+w a|strong="H3068"\+w* causa \+w de|strong="H5921"\+w* \+w la|strong="H1931"\+w* mujer \+w que|strong="H1931"\+w* \+w tomaste|strong="H3947"\+w*, \+w pues|strong="H1931"\+w* \+w ella|strong="H1931"\+w* \+w está|strong="H1931"\+w* \+w casada|strong="H1167"\+w* \+w y|strong="H5921"\+w* \+w tiene|strong="H1931"\+w* esposo.\wj*   
\p
\v 4 Pero Abimelec, quien \w no|strong="H3808"\w* \w se|strong="H3808"\w* había unido \w a|strong="H3068"\w* ella, dijo: \nd ʼAdonay\nd*, ¿\w matarás|strong="H2026"\w* \w a|strong="H3068"\w* \w gente|strong="H1471"\w* inocente?  
\v 5 ¿\w No|strong="H3808"\w* me dijo \w él|strong="H1931"\w*: \w Ella|strong="H1931"\w* \w es|strong="H1931"\w* mi hermana? \w Y|strong="H3068"\w* \w ella|strong="H1931"\w* \w también|strong="H1571"\w* dijo: \w Es|strong="H1931"\w* mi hermano. \w Con|strong="H1571"\w* \w integridad|strong="H8537"\w* de \w corazón|strong="H3824"\w* \w y|strong="H1571"\w* limpieza de \w manos|strong="H3709"\w* \w hice|strong="H6213"\w* \w esto|strong="H2063"\w*.   
\p
\v 6 \nd ʼElohim\nd* \w le|strong="H5921"\w* dijo \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w sueño|strong="H2472"\w*: \wj \+w También|strong="H1571"\+w* \+w Yo|strong="H3588"\+w* \+w sé|strong="H3045"\+w* \+w que|strong="H3588"\+w* \+w con|strong="H5921"\+w* \+w integridad|strong="H8537"\+w* \+w de|strong="H5921"\+w* \+w tu|strong="H6213"\+w* \+w corazón|strong="H3824"\+w* \+w hiciste|strong="H6213"\+w* \+w esto|strong="H2063"\+w*, \+w y|strong="H1571"\+w* \+w Yo|strong="H3588"\+w* \+w también|strong="H1571"\+w* \+w te|strong="H5921"\+w* retuve \+w de|strong="H5921"\+w* \+w pecar|strong="H2398"\+w* \+w contra|strong="H5921"\+w* \+w Mí|strong="H5921"\+w*. \+w Por|strong="H5921"\+w* \+w eso|strong="H3651"\+w* \+w no|strong="H3808"\+w* \+w te|strong="H5921"\+w* permití tocarla.\wj*  
\v 7 \wj Devuelve \+w ahora|strong="H6258"\+w* \+w a|strong="H3068"\+w* \+w la|strong="H1931"\+w* esposa \+w de|strong="H3588"\+w* \+w ese|strong="H1931"\+w* hombre, \+w porque|strong="H3588"\+w* \+w es|strong="H1931"\+w* \+w profeta|strong="H5030"\+w*. \+w Él|strong="H1931"\+w* conversará \+w con|strong="H3588"\+w* Dios \+w por|strong="H3588"\+w* ti, \+w y|strong="H3588"\+w* \+w vivirás|strong="H2421"\+w*. \+w Pero|strong="H3588"\+w* \+w si|strong="H3588"\+w* \+w no|strong="H3588"\+w* \+w la|strong="H1931"\+w* devuelves, \+w sabes|strong="H3045"\+w* \+w que|strong="H3588"\+w* \+w de|strong="H3588"\+w* \+w cierto|strong="H3588"\+w* \+w morirás|strong="H4191"\+w*, tú \+w y|strong="H3588"\+w* \+w todos|strong="H3605"\+w* \+w los|strong="H3605"\+w* tuyos.\wj*   
\p
\v 8 Entonces Abimelec se levantó temprano \w por|strong="H1697"\w* \w la|strong="H3605"\w* \w mañana|strong="H1242"\w*. \w Llamó|strong="H7121"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* sus esclavos y les \w habló|strong="H1696"\w* \w todas|strong="H3605"\w* estas \w cosas|strong="H1697"\w* en privado, y \w aquellos|strong="H3605"\w* hombres sintieron un \w gran|strong="H3966"\w* \w temor|strong="H3372"\w*.   
\p
\v 9 Luego Abimelec \w llamó|strong="H7121"\w* \w a|strong="H3068"\w* Abraham \w y|strong="H3588"\w* \w le|strong="H5921"\w* dijo: ¿\w Qué|strong="H3588"\w* \w nos|strong="H5921"\w* \w hiciste|strong="H6213"\w*? ¿\w En|strong="H5921"\w* \w qué|strong="H3588"\w* \w te|strong="H5921"\w* ofendí \w para|strong="H5921"\w* \w que|strong="H3588"\w* trajeras tan \w gran|strong="H1419"\w* \w pecado|strong="H2401"\w* \w contra|strong="H5921"\w* \w mí|strong="H5921"\w* \w y|strong="H3588"\w* \w contra|strong="H5921"\w* \w mi|strong="H5921"\w* \w reino|strong="H4467"\w*? ¡\w Hiciste|strong="H6213"\w* \w conmigo|strong="H6213"\w* cosas \w que|strong="H3588"\w* \w no|strong="H3808"\w* debiste \w hacer|strong="H6213"\w*!  
\v 10 \w Además|strong="H3588"\w* Abimelec preguntó \w a|strong="H3068"\w* Abraham: ¿\w Qué|strong="H3588"\w* encontraste \w que|strong="H3588"\w* \w te|strong="H3588"\w* persuadió \w a|strong="H3068"\w* \w hacer|strong="H6213"\w* \w esto|strong="H2088"\w*?   
\p
\v 11 Abraham respondió: \w Porque|strong="H3588"\w* \w me|strong="H5921"\w* dije: \w Ciertamente|strong="H3588"\w* \w no|strong="H3588"\w* hay \w temor|strong="H3374"\w* \w a|strong="H3068"\w* \nd ʼElohim\nd* \w en|strong="H5921"\w* \w este|strong="H2088"\w* \w lugar|strong="H4725"\w*, \w y|strong="H3588"\w* \w me|strong="H5921"\w* \w matarán|strong="H2026"\w* \w por|strong="H5921"\w* \w causa|strong="H1697"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* esposa.  
\v 12 \w Aunque|strong="H1571"\w*, en efecto, \w ella|strong="H1931"\w* \w es|strong="H1931"\w* \w mi|strong="H1961"\w* hermana, \w hija|strong="H1323"\w* de \w mi|strong="H1961"\w* padre, pero \w no|strong="H3808"\w* \w hija|strong="H1323"\w* de \w mi|strong="H1961"\w* madre. \w Así|strong="H1571"\w* llegó \w a|strong="H3068"\w* ser \w mi|strong="H1961"\w* esposa.  
\v 13 \w Sucedió|strong="H1961"\w* \w que|strong="H1931"\w* \w cuando|strong="H1961"\w* \nd ʼElohim\nd* me \w hizo|strong="H6213"\w* salir errante de \w casa|strong="H1004"\w* de \w mi|strong="H1961"\w* padre, \w yo|strong="H6213"\w* \w le|strong="H1931"\w* dije \w a|strong="H3068"\w* \w ella|strong="H1931"\w*: \w Tú|strong="H6213"\w* me \w harás|strong="H6213"\w* \w este|strong="H2088"\w* favor. \w A|strong="H3068"\w* \w todo|strong="H3605"\w* \w lugar|strong="H4725"\w* \w a|strong="H3068"\w* \w donde|strong="H8033"\w* lleguemos, dirás de \w mí|strong="H1961"\w*: \w Él|strong="H1931"\w* \w es|strong="H1931"\w* \w mi|strong="H1961"\w* hermano.   
\p
\v 14 \w Entonces|strong="H7725"\w* Abimelec \w tomó|strong="H3947"\w* un \w rebaño|strong="H6629"\w* \w y|strong="H1241"\w* una manada \w de|strong="H5414"\w* \w ganado|strong="H6629"\w* \w vacuno|strong="H1241"\w*, esclavos \w y|strong="H1241"\w* esclavas, se los \w dio|strong="H5414"\w* \w a|strong="H3068"\w* Abraham \w y|strong="H1241"\w* le devolvió \w a|strong="H3068"\w* su esposa \w Sara|strong="H8283"\w*.   
\p
\v 15 Luego Abimelec \w le|strong="H5869"\w* dijo: \w Mira|strong="H2009"\w*, \w mi|strong="H2009"\w* tierra \w está|strong="H3427"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ti. Establécete donde \w te|strong="H5869"\w* parezca \w bien|strong="H2896"\w*.   
\p
\v 16 \w Y|strong="H3068"\w* dijo \w a|strong="H3068"\w* \w Sara|strong="H8283"\w*: \w Mira|strong="H2009"\w*, \w doy|strong="H5414"\w* \w a|strong="H3068"\w* tu hermano 1.000 piezas \w de|strong="H5414"\w* \w plata|strong="H3701"\w*. \w Ciertamente|strong="H2009"\w*, \w esto|strong="H1931"\w* \w será|strong="H1931"\w* \w para|strong="H5414"\w* ti \w como|strong="H1931"\w* un velo ante \w los|strong="H3605"\w* \w ojos|strong="H5869"\w* \w de|strong="H5414"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w que|strong="H1931"\w* \w están|strong="H2009"\w* contigo. \w Así|strong="H1931"\w* quedas vindicada ante \w todos|strong="H3605"\w*.   
\p
\v 17 Abraham \w oró|strong="H6419"\w* \w a|strong="H3068"\w* \nd ʼElohim\nd*, y \nd ʼElohim\nd* \w sanó|strong="H7495"\w* \w a|strong="H3068"\w* Abimelec, \w a|strong="H3068"\w* su esposa y \w a|strong="H3068"\w* sus esclavas, las cuales tuvieron hijos,  
\v 18 \w pues|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w había|strong="H3588"\w* \w cerrado|strong="H6113"\w* \w por|strong="H5921"\w* completo \w toda|strong="H3605"\w* \w matriz|strong="H7358"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* Abimelec \w por|strong="H5921"\w* \w causa|strong="H1697"\w* \w de|strong="H5921"\w* \w Sara|strong="H8283"\w*, esposa \w de|strong="H5921"\w* Abraham.   
\c 21  
\s1 Nacimiento de Isaac  
\p
\v 1 \nd \+w Yavé|strong="H3068"\+w*\nd* \w visitó|strong="H6485"\w* \w a|strong="H3068"\w* \w Sara|strong="H8283"\w* como \w dijo|strong="H1696"\w*, y \nd \+w Yavé|strong="H3068"\+w*\nd* procedió con \w Sara|strong="H8283"\w* según \w lo|strong="H6213"\w* prometido.  
\v 2 Entonces \w Sara|strong="H8283"\w* \w concibió|strong="H2029"\w*, y según \w el|strong="H1121"\w* \w tiempo|strong="H4150"\w* \w señalado|strong="H4150"\w* \w que|strong="H1121"\w* \nd ʼElohim\nd* le indicó, dio \w a|strong="H3068"\w* luz un \w hijo|strong="H1121"\w* \w a|strong="H3068"\w* Abraham en su vejez.  
\v 3 Abraham \w llamó|strong="H7121"\w* \w Isaac|strong="H3327"\w* al \w hijo|strong="H1121"\w* \w que|strong="H1121"\w* le \w nació|strong="H3205"\w*, \w que|strong="H1121"\w* \w Sara|strong="H8283"\w* le dio \w a|strong="H3068"\w* luz.  
\v 4 \w Cuando|strong="H3117"\w* tenía \w ocho|strong="H8083"\w* \w días|strong="H3117"\w*, Abraham circuncidó \w a|strong="H3068"\w* su \w hijo|strong="H1121"\w* \w Isaac|strong="H3327"\w*, como \nd ʼElohim\nd* le \w ordenó|strong="H6680"\w*.  
\v 5 Abraham tenía 100 \w años|strong="H8141"\w* cuando le \w nació|strong="H3205"\w* su \w hijo|strong="H1121"\w* \w Isaac|strong="H3327"\w*.   
\p
\v 6 Entonces \w Sara|strong="H8283"\w* dijo: \nd ʼElohim\nd* me \w hizo|strong="H6213"\w* reír. \w Todo|strong="H3605"\w* \w el|strong="H3605"\w* \w que|strong="H3605"\w* \w lo|strong="H6213"\w* \w oiga|strong="H8085"\w*, reirá \w conmigo|strong="H6213"\w*.  
\v 7 Añadió: ¿\w Quién|strong="H4310"\w* \w le|strong="H4310"\w* hubiera dicho \w a|strong="H3068"\w* Abraham \w que|strong="H3588"\w* \w Sara|strong="H8283"\w* amamantaría \w hijos|strong="H1121"\w*? \w Pues|strong="H3588"\w* \w le|strong="H4310"\w* di \w a|strong="H3068"\w* luz un \w hijo|strong="H1121"\w* \w en|strong="H3588"\w* \w su|strong="H3588"\w* vejez.   
\p
\v 8 \w Creció|strong="H1431"\w* \w el|strong="H6213"\w* niño, y fue destetado. \w Entonces|strong="H3117"\w* Abraham \w hizo|strong="H6213"\w* un \w gran|strong="H1419"\w* \w banquete|strong="H4960"\w* \w el|strong="H6213"\w* \w día|strong="H3117"\w* \w cuando|strong="H3117"\w* \w Isaac|strong="H3327"\w* fue destetado.   
\s1 Expulsión de Agar  
\p
\v 9 Pero \w Sara|strong="H8283"\w* \w vio|strong="H7200"\w* \w que|strong="H1121"\w* \w el|strong="H1121"\w* \w hijo|strong="H1121"\w* \w que|strong="H1121"\w* Abraham tuvo con \w Agar|strong="H1904"\w* la \w egipcia|strong="H4713"\w* se burlaba.  
\v 10 \w Por|strong="H3588"\w* \w eso|strong="H2063"\w* \w le|strong="H5973"\w* dijo \w a|strong="H3068"\w* Abraham: Expulsa \w a|strong="H3068"\w* esa esclava \w y|strong="H3588"\w* \w a|strong="H3068"\w* \w su|strong="H3588"\w* \w hijo|strong="H1121"\w*, \w porque|strong="H3588"\w* \w no|strong="H3808"\w* \w heredará|strong="H3423"\w* \w el|strong="H5973"\w* \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* esa esclava \w con|strong="H5973"\w* mi \w hijo|strong="H1121"\w* \w Isaac|strong="H3327"\w*.   
\p
\v 11 Pero \w el|strong="H5921"\w* \w asunto|strong="H1697"\w* \w pareció|strong="H7489"\w* \w muy|strong="H3966"\w* grave \w a|strong="H3068"\w* Abraham \w por|strong="H5921"\w* \w cuanto|strong="H5921"\w* \w era|strong="H1121"\w* su \w hijo|strong="H1121"\w*.  
\v 12 \w Entonces|strong="H3588"\w* \nd ʼElohim\nd* dijo \w a|strong="H3068"\w* Abraham: \wj \+w No|strong="H3588"\+w* \+w te|strong="H5869"\+w* parezca grave \+w lo|strong="H5921"\+w* \+w del|strong="H5921"\+w* \+w muchacho|strong="H5288"\+w* \+w y|strong="H3588"\+w* tu esclava. \+w Escucha|strong="H8085"\+w* \+w la|strong="H5921"\+w* \+w voz|strong="H6963"\+w* \+w de|strong="H5921"\+w* \+w Sara|strong="H8283"\+w* \+w en|strong="H5921"\+w* \+w todo|strong="H3605"\+w* \+w lo|strong="H5921"\+w* \+w que|strong="H3588"\+w* \+w te|strong="H5869"\+w* dice, \+w porque|strong="H3588"\+w* \+w en|strong="H5921"\+w* \+w Isaac|strong="H3327"\+w* \+w te|strong="H5869"\+w* será llamada \+w descendencia|strong="H2233"\+w*, \wj*  
\v 13 \wj \+w aunque|strong="H3588"\+w* \+w también|strong="H1571"\+w* \+w haré|strong="H7760"\+w* una \+w nación|strong="H1471"\+w* del \+w hijo|strong="H1121"\+w* \+w de|strong="H3588"\+w* \+w la|strong="H1931"\+w* esclava, \+w pues|strong="H3588"\+w* \+w él|strong="H1931"\+w* \+w es|strong="H1931"\+w* descendiente tuyo. \wj*   
\p
\v 14 Entonces Abraham \w se|strong="H5921"\w* levantó temprano \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w mañana|strong="H1242"\w*, \w tomó|strong="H3947"\w* \w pan|strong="H3899"\w* \w y|strong="H5921"\w* un \w odre|strong="H2573"\w* \w con|strong="H5921"\w* \w agua|strong="H4325"\w* \w y|strong="H5921"\w* \w lo|strong="H5921"\w* \w dio|strong="H5414"\w* \w a|strong="H3068"\w* \w Agar|strong="H1904"\w*. Colocó también \w sobre|strong="H5921"\w* su espalda \w al|strong="H5921"\w* niño \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w despidió|strong="H7971"\w*. \w Ella|strong="H5921"\w* \w salió|strong="H3212"\w* \w y|strong="H5921"\w* \w anduvo|strong="H3212"\w* errante \w por|strong="H5921"\w* \w el|strong="H5921"\w* \w desierto|strong="H4057"\w* \w de|strong="H5921"\w* Beerseba.   
\p
\v 15 Cuando \w se|strong="H4480"\w* \w acabó|strong="H3615"\w* el \w agua|strong="H4325"\w* \w del|strong="H4480"\w* \w odre|strong="H2573"\w* colocó \w al|strong="H4480"\w* muchacho \w bajo|strong="H8478"\w* uno \w de|strong="H4480"\w* los arbustos.  
\v 16 Luego \w fue|strong="H3212"\w* \w y|strong="H3588"\w* se sentó \w enfrente|strong="H5048"\w*, \w a|strong="H3068"\w* distancia \w como|strong="H3588"\w* \w de|strong="H3588"\w* un tiro \w de|strong="H3588"\w* \w arco|strong="H7198"\w*, \w pues|strong="H3588"\w* se dijo: \w Así|strong="H3588"\w* \w no|strong="H3588"\w* \w veré|strong="H7200"\w* \w cuando|strong="H3588"\w* \w el|strong="H3588"\w* muchacho muera. Se sentó \w enfrente|strong="H5048"\w*, \w alzó|strong="H5375"\w* \w su|strong="H3588"\w* \w voz|strong="H6963"\w* \w y|strong="H3588"\w* \w lloró|strong="H1058"\w*.   
\p
\v 17 \w Pero|strong="H3588"\w* \nd ʼElohim\nd* \w oyó|strong="H8085"\w* \w la|strong="H1931"\w* \w voz|strong="H6963"\w* \w del|strong="H4480"\w* \w muchacho|strong="H5288"\w*. \w El|strong="H1931"\w* \w Ángel|strong="H4397"\w* \w de|strong="H4480"\w* \nd ʼElohim\nd* \w llamó|strong="H7121"\w* \w a|strong="H3068"\w* \w Agar|strong="H1904"\w* \w desde|strong="H4480"\w* \w el|strong="H1931"\w* \w cielo|strong="H8064"\w* \w y|strong="H3588"\w* \w le|strong="H1931"\w* dijo: \wj ¿\+w Qué|strong="H3588"\+w* \+w tienes|strong="H4480"\+w*, \+w Agar|strong="H1904"\+w*? \+w No|strong="H3588"\+w* \+w temas|strong="H3372"\+w*, \+w porque|strong="H3588"\+w* \+nd ʼElohim\+nd* \+w oyó|strong="H8085"\+w* \+w la|strong="H1931"\+w* \+w voz|strong="H6963"\+w* \+w del|strong="H4480"\+w* \+w muchacho|strong="H5288"\+w* \+w en|strong="H4480"\+w* \+w donde|strong="H8033"\+w* \+w está|strong="H1931"\+w*. \wj*  
\v 18 \wj ¡\+w Levántate|strong="H6965"\+w*! \+w Alza|strong="H5375"\+w* al \+w muchacho|strong="H5288"\+w* \+w y|strong="H3588"\+w* sostenlo \+w con|strong="H3588"\+w* tu \+w mano|strong="H3027"\+w*, \+w porque|strong="H3588"\+w* \+w haré|strong="H7760"\+w* \+w de|strong="H3588"\+w* \+w él|strong="H3588"\+w* una \+w gran|strong="H1419"\+w* \+w nación|strong="H1471"\+w*. \wj*   
\p
\v 19 \nd ʼElohim\nd* \w le|strong="H5869"\w* \w abrió|strong="H6491"\w* los \w ojos|strong="H5869"\w* y \w vio|strong="H7200"\w* un pozo \w de|strong="H4325"\w* \w agua|strong="H4325"\w*. \w Y|strong="H3068"\w* \w fue|strong="H3212"\w*, \w llenó|strong="H4390"\w* el \w odre|strong="H2573"\w* \w de|strong="H4325"\w* \w agua|strong="H4325"\w* y dio \w de|strong="H4325"\w* \w beber|strong="H8248"\w* al \w muchacho|strong="H5288"\w*.   
\p
\v 20 \nd ʼElohim\nd* \w estuvo|strong="H1961"\w* con \w el|strong="H3427"\w* \w muchacho|strong="H5288"\w*, \w el|strong="H3427"\w* cual \w creció|strong="H1431"\w* y \w habitó|strong="H3427"\w* en \w el|strong="H3427"\w* \w desierto|strong="H4057"\w* y \w fue|strong="H1961"\w* tirador de arco.  
\v 21 \w Habitó|strong="H3427"\w* en \w el|strong="H3427"\w* \w desierto|strong="H4057"\w* de \w Parán|strong="H6290"\w*, y su madre \w tomó|strong="H3947"\w* para \w él|strong="H3427"\w* una esposa de la tierra de \w Egipto|strong="H4714"\w*.   
\s1 Pacto de Abraham con Abimelec  
\p
\v 22 \w Sucedió|strong="H1961"\w* \w en|strong="H5973"\w* \w aquel|strong="H1931"\w* \w tiempo|strong="H6256"\w* \w que|strong="H1931"\w* Abimelec y Ficol, \w capitán|strong="H8269"\w* \w de|strong="H5973"\w* \w su|strong="H1931"\w* \w ejército|strong="H6635"\w*, \w se|strong="H1961"\w* dirigieron \w a|strong="H3068"\w* Abraham y dijeron: \nd ʼElohim\nd* \w está|strong="H1931"\w* \w contigo|strong="H5973"\w* \w en|strong="H5973"\w* \w todo|strong="H3605"\w* \w lo|strong="H1931"\w* \w que|strong="H1931"\w* \w tú|strong="H6213"\w* \w haces|strong="H6213"\w*.  
\v 23 \w Ahora|strong="H6258"\w*, \w pues|strong="H6258"\w*, \w júrame|strong="H7650"\w* \w aquí|strong="H2008"\w* por \nd ʼElohim\nd*, \w que|strong="H6258"\w* \w no|strong="H6213"\w* \w me|strong="H5973"\w* engañarás, \w ni|strong="H5973"\w* \w a|strong="H3068"\w* mí, \w ni|strong="H5973"\w* \w a|strong="H3068"\w* mi \w hijo|strong="H5209"\w*, \w ni|strong="H5973"\w* \w a|strong="H3068"\w* mis futuras generaciones. Conforme \w a|strong="H3068"\w* la benevolencia \w con|strong="H5973"\w* la \w cual|strong="H5973"\w* he obrado \w contigo|strong="H5973"\w*, \w haz|strong="H6213"\w* \w conmigo|strong="H5973"\w* y \w con|strong="H5973"\w* la tierra \w en|strong="H5973"\w* la \w cual|strong="H5973"\w* \w te|strong="H5973"\w* hospedaste.   
\p
\v 24 \w Y|strong="H3068"\w* Abraham contestó: Yo \w juro|strong="H7650"\w*.   
\p
\v 25 Pero Abraham \w se|strong="H5921"\w* quejó ante Abimelec \w por|strong="H5921"\w* causa \w de|strong="H5921"\w* un pozo \w de|strong="H5921"\w* \w agua|strong="H4325"\w* \w del|strong="H5921"\w* cual \w se|strong="H5921"\w* apoderaron \w los|strong="H5921"\w* esclavos \w de|strong="H5921"\w* Abimelec.   
\p
\v 26 \w Y|strong="H3068"\w* Abimelec \w dijo|strong="H5046"\w*: \w No|strong="H3808"\w* \w sé|strong="H3045"\w* \w quién|strong="H4310"\w* \w hizo|strong="H6213"\w* \w tal|strong="H2088"\w* \w cosa|strong="H1697"\w*, \w y|strong="H1571"\w* \w además|strong="H1571"\w*, \w tú|strong="H6213"\w* \w no|strong="H3808"\w* \w me|strong="H4310"\w* informaste \w ni|strong="H3808"\w* \w yo|strong="H6213"\w* \w lo|strong="H1697"\w* \w supe|strong="H3045"\w* \w hasta|strong="H3117"\w* \w hoy|strong="H3117"\w*.   
\p
\v 27 Entonces Abraham \w tomó|strong="H3947"\w* un \w rebaño|strong="H6629"\w* \w y|strong="H1241"\w* una manada \w de|strong="H5414"\w* \w ganado|strong="H6629"\w* \w vacuno|strong="H1241"\w* \w y|strong="H1241"\w* se las \w dio|strong="H5414"\w* \w a|strong="H3068"\w* Abimelec. \w Ambos|strong="H8147"\w* concertaron un \w pacto|strong="H1285"\w*.  
\v 28 Abraham separó \w siete|strong="H7651"\w* \w corderas|strong="H3535"\w* del \w rebaño|strong="H6629"\w*,  
\v 29 y Abimelec preguntó \w a|strong="H3068"\w* Abraham: ¿\w Qué|strong="H4100"\w* significan \w estas|strong="H2007"\w* \w siete|strong="H7651"\w* \w corderas|strong="H3535"\w* \w que|strong="H4100"\w* colocaste aparte?   
\p
\v 30 \w Y|strong="H3068"\w* respondió: \w Que|strong="H3588"\w* \w tomarás|strong="H3947"\w* \w de|strong="H3588"\w* \w mi|strong="H1961"\w* \w mano|strong="H3027"\w* \w estas|strong="H2063"\w* \w siete|strong="H7651"\w* \w corderas|strong="H3535"\w* \w a|strong="H3068"\w* fin \w de|strong="H3588"\w* \w que|strong="H3588"\w* \w me|strong="H3588"\w* \w seas|strong="H1961"\w* \w testigo|strong="H5713"\w* \w de|strong="H3588"\w* \w que|strong="H3588"\w* cavé \w este|strong="H2063"\w* pozo.   
\p
\v 31 \w Por|strong="H5921"\w* \w tanto|strong="H3651"\w* \w aquel|strong="H1931"\w* \w lugar|strong="H4725"\w* \w se|strong="H1931"\w* \w llamó|strong="H7121"\w* Beerseba, \w pues|strong="H3588"\w* \w ambos|strong="H8147"\w* \w se|strong="H1931"\w* juramentaron \w allí|strong="H8033"\w*.   
\p
\v 32 Pactaron, pues, en Beerseba, y se \w levantaron|strong="H6965"\w* Abimelec y Ficol, \w capitán|strong="H8269"\w* \w de|strong="H8269"\w* su \w ejército|strong="H6635"\w*, y regresaron \w a|strong="H3068"\w* tierra \w de|strong="H8269"\w* los \w filisteos|strong="H6430"\w*.   
\p
\v 33 \add Abraham\add* \w plantó|strong="H5193"\w* un tamarisco en Beerseba \w e|strong="H3068"\w* invocó \w allí|strong="H8033"\w* el \w Nombre|strong="H8034"\w* de \nd \+w Yavé|strong="H3068"\+w* ʼEl-Olam. \nd*  
\v 34 Abraham \w peregrinó|strong="H1481"\w* \w muchos|strong="H7227"\w* \w días|strong="H3117"\w* en tierra de los \w filisteos|strong="H6430"\w*.   
\c 22  
\s1 El sacrificio  
\p
\v 1 \w Después|strong="H1961"\w* \w de|strong="H1697"\w* \w esto|strong="H1697"\w* \w aconteció|strong="H1961"\w* \w que|strong="H1697"\w* \nd ʼElohim\nd* \w probó|strong="H5254"\w* \w a|strong="H3068"\w* Abraham, y le dijo: \wj ¡Abraham! \wj*  
\p Él respondió: \w Aquí|strong="H2009"\w* \w estoy|strong="H1961"\w*.   
\p
\v 2 \add ʼElohim\add* \w le|strong="H5921"\w* dijo: \wj \+w Toma|strong="H3947"\+w* \+w ahora|strong="H4994"\+w* \+w a|strong="H3068"\+w* tu \+w único|strong="H3173"\+w* \+w hijo|strong="H1121"\+w* \+w Isaac|strong="H3327"\+w* \+w y|strong="H5921"\+w* \+w vé|strong="H3068"\+w* \+w a|strong="H3068"\+w* \+w la|strong="H5921"\+w* tierra \+w de|strong="H5921"\+w* Moriah. \+w Y|strong="H3068"\+w* tú mismo \+w sacrifícalo|strong="H5927"\+w* \+w allí|strong="H8033"\+w* \+w en|strong="H5921"\+w* \+w holocausto|strong="H5930"\+w* \+w sobre|strong="H5921"\+w* una \+w de|strong="H5921"\+w* \+w las|strong="H5921"\+w* montañas \+w que|strong="H4994"\+w* \+w Yo|strong="H4994"\+w* \+w te|strong="H5921"\+w* diré.\wj*   
\p
\v 3 Abraham se \w levantó|strong="H6965"\w* temprano por la \w mañana|strong="H1242"\w*, \w enalbardó|strong="H2280"\w* su \w asno|strong="H2543"\w* y \w tomó|strong="H3947"\w* consigo \w a|strong="H3068"\w* \w dos|strong="H8147"\w* \w de|strong="H1121"\w* sus esclavos jóvenes y \w a|strong="H3068"\w* su \w hijo|strong="H1121"\w* \w Isaac|strong="H3327"\w*. Luego \w cortó|strong="H1234"\w* \w leña|strong="H6086"\w* para \w el|strong="H1121"\w* \w holocausto|strong="H5930"\w*, se \w levantó|strong="H6965"\w*, y \w fue|strong="H3212"\w* \w al|strong="H5930"\w* \w lugar|strong="H4725"\w* \w que|strong="H1121"\w* \nd ʼElohim\nd* \w le|strong="H1242"\w* dijo.   
\p
\v 4 Al tercer \w día|strong="H3117"\w* Abraham \w levantó|strong="H5375"\w* sus \w ojos|strong="H5869"\w* y divisó el \w lugar|strong="H4725"\w* desde \w lejos|strong="H7350"\w*.  
\v 5 \w Y|strong="H3068"\w* Abraham dijo \w a|strong="H3068"\w* sus esclavos jóvenes: Permanezcan \w aquí|strong="H6311"\w* \w con|strong="H5973"\w* \w el|strong="H5973"\w* \w asno|strong="H2543"\w*. Yo \w y|strong="H5704"\w* \w el|strong="H5973"\w* \w muchacho|strong="H5288"\w* \w iremos|strong="H3212"\w* \w hasta|strong="H5704"\w* allá \w y|strong="H5704"\w* nos postraremos. \w Después|strong="H3427"\w* regresaremos \w a|strong="H3068"\w* ustedes.   
\p
\v 6 Entonces Abraham \w tomó|strong="H3947"\w* \w la|strong="H5921"\w* \w leña|strong="H6086"\w* \w para|strong="H5921"\w* \w el|strong="H5921"\w* \w holocausto|strong="H5930"\w* \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w cargó|strong="H3027"\w* \w sobre|strong="H5921"\w* su \w hijo|strong="H1121"\w* \w Isaac|strong="H3327"\w*. Luego \w tomó|strong="H3947"\w* \w en|strong="H5921"\w* su \w mano|strong="H3027"\w* \w el|strong="H5921"\w* fuego \w y|strong="H5921"\w* \w el|strong="H5921"\w* cuchillo, \w y|strong="H5921"\w* \w ambos|strong="H8147"\w* caminaban \w juntos|strong="H3162"\w*.   
\p
\v 7 \w Isaac|strong="H3327"\w* habló \w a|strong="H3068"\w* su padre Abraham: Padre mío.  
\p \w Y|strong="H3068"\w* \w él|strong="H1121"\w* respondió: \w Aquí|strong="H2009"\w* estoy, \w hijo|strong="H1121"\w* mío.  
\p \w Y|strong="H3068"\w* le dijo: \w Mira|strong="H2009"\w*, está \w el|strong="H1121"\w* fuego y la \w leña|strong="H6086"\w*, pero ¿dónde está \w el|strong="H1121"\w* \w cordero|strong="H7716"\w* para \w el|strong="H1121"\w* \w holocausto|strong="H5930"\w*?   
\p
\v 8 Abraham respondió: \nd ʼElohim\nd* se \w proveerá|strong="H7200"\w* \w el|strong="H1121"\w* \w cordero|strong="H7716"\w* para \w el|strong="H1121"\w* \w holocausto|strong="H5930"\w*, \w hijo|strong="H1121"\w* mío. \w Y|strong="H3068"\w* \w ambos|strong="H8147"\w* caminaban \w juntos|strong="H3162"\w*.   
\p
\v 9 Cuando llegaron \w al|strong="H5921"\w* \w lugar|strong="H4725"\w* \w que|strong="H5921"\w* \nd ʼElohim\nd* \w le|strong="H5921"\w* dijo, Abraham construyó \w allí|strong="H8033"\w* \w el|strong="H5921"\w* \w altar|strong="H4196"\w* \w y|strong="H5921"\w* preparó \w la|strong="H5921"\w* \w leña|strong="H6086"\w*. Luego ató \w a|strong="H3068"\w* su \w hijo|strong="H1121"\w* \w Isaac|strong="H3327"\w* \w y|strong="H5921"\w* \w lo|strong="H5921"\w* \w puso|strong="H7760"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w altar|strong="H4196"\w*, \w encima|strong="H4605"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w leña|strong="H6086"\w*.  
\v 10 \w Extendió|strong="H7971"\w* Abraham su \w mano|strong="H3027"\w* y \w tomó|strong="H3947"\w* \w el|strong="H1121"\w* cuchillo para degollar \w a|strong="H3068"\w* su \w hijo|strong="H1121"\w*.   
\p
\v 11 Pero el \w Ángel|strong="H4397"\w* \w de|strong="H4480"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* lo \w llamó|strong="H7121"\w* \w desde|strong="H4480"\w* el \w cielo|strong="H8064"\w*: \wj ¡Abraham! ¡Abraham!\wj*  
\p \w Y|strong="H3068"\w* él respondió: ¡\w Aquí|strong="H2009"\w* estoy!   
\p
\v 12 \w El|strong="H3588"\w* Ángel le dijo: \wj \+w No|strong="H3808"\+w* \+w extiendas|strong="H7971"\+w* \+w tu|strong="H6213"\+w* \+w mano|strong="H3027"\+w* \+w sobre|strong="H4480"\+w* \+w el|strong="H3588"\+w* \+w muchacho|strong="H5288"\+w*. \+w Nada|strong="H3808"\+w* le \+w hagas|strong="H6213"\+w*, \+w pues|strong="H3588"\+w* \+w ya|strong="H6258"\+w* entiendo \+w que|strong="H3588"\+w* eres \+w temeroso|strong="H3373"\+w* \+w de|strong="H4480"\+w* \+nd ʼElohim\+nd* \+w por|strong="H3588"\+w* \+w cuanto|strong="H3588"\+w* \+w no|strong="H3808"\+w* \+w me|strong="H4480"\+w* \+w rehusaste|strong="H2820"\+w* \+w a|strong="H3068"\+w* \+w tu|strong="H6213"\+w* \+w único|strong="H3173"\+w* \+w hijo|strong="H1121"\+w*.\wj*   
\p
\v 13 Entonces Abraham \w levantó|strong="H5375"\w* \w los|strong="H1121"\w* \w ojos|strong="H5869"\w*, y ahí mismo detrás, \w vio|strong="H7200"\w* \w en|strong="H8478"\w* \w el|strong="H1121"\w* zarzal un carnero trabado \w por|strong="H8478"\w* \w los|strong="H1121"\w* \w cuernos|strong="H7161"\w*. Abraham \w fue|strong="H3212"\w* y \w tomó|strong="H3947"\w* \w el|strong="H1121"\w* carnero, y lo \w sacrificó|strong="H5927"\w* \w en|strong="H8478"\w* \w holocausto|strong="H5930"\w* \w en|strong="H8478"\w* \w lugar|strong="H8478"\w* \w de|strong="H8478"\w* su \w hijo|strong="H1121"\w*.  
\v 14 Abraham \w llamó|strong="H7121"\w* \w a|strong="H3068"\w* \w aquel|strong="H1931"\w* \w lugar|strong="H4725"\w* \nd \+w Yavé|strong="H3068"\+w* Yireh\nd*. Por \w eso|strong="H1931"\w* \w se|strong="H1931"\w* dice \w hoy|strong="H3117"\w*: En \w la|strong="H1931"\w* Montaña de \nd \+w Yavé|strong="H3068"\+w*\nd* \w será|strong="H1931"\w* provisto.   
\p
\v 15 El \w Ángel|strong="H4397"\w* \w de|strong="H4480"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w llamó|strong="H7121"\w* \w a|strong="H3068"\w* Abraham \w por|strong="H4480"\w* \w segunda|strong="H8145"\w* vez \w desde|strong="H4480"\w* el \w cielo|strong="H8064"\w*  
\v 16 \w y|strong="H3588"\w* le \w habló|strong="H1697"\w*: \nd \+w Yavé|strong="H3068"\+w*\nd* \w dice|strong="H5002"\w*: \wj \+w Por|strong="H3588"\+w* Mí mismo \+w juré|strong="H7650"\+w* \+w que|strong="H3588"\+w* \+w porque|strong="H3588"\+w* \+w hiciste|strong="H6213"\+w* \+w esto|strong="H2088"\+w* \+w y|strong="H3588"\+w* \+w no|strong="H3808"\+w* \+w me|strong="H3588"\+w* \+w rehusaste|strong="H2820"\+w* \+w a|strong="H3068"\+w* \+w tu|strong="H6213"\+w* \+w único|strong="H3173"\+w* \+w hijo|strong="H1121"\+w*,\wj*  
\v 17 \wj \+w ciertamente|strong="H3588"\+w* \+w te|strong="H5921"\+w* \+w bendeciré|strong="H1288"\+w*. \+w Multiplicaré|strong="H7235"\+w* muchísimo tu \+w descendencia|strong="H2233"\+w*, \+w como|strong="H3588"\+w* \+w las|strong="H5921"\+w* \+w estrellas|strong="H3556"\+w* \+w del|strong="H5921"\+w* \+w cielo|strong="H8064"\+w* \+w y|strong="H3588"\+w* \+w como|strong="H3588"\+w* \+w la|strong="H5921"\+w* arena \+w que|strong="H3588"\+w* \+w está|strong="H5921"\+w* \+w en|strong="H5921"\+w* \+w la|strong="H5921"\+w* orilla \+w del|strong="H5921"\+w* \+w mar|strong="H3220"\+w*. Tu \+w descendencia|strong="H2233"\+w* \+w poseerá|strong="H3423"\+w* \+w la|strong="H5921"\+w* \+w puerta|strong="H8179"\+w* \+w de|strong="H5921"\+w* sus enemigos,\wj*  
\v 18 \wj y en tu \+w descendencia|strong="H2233"\+w* serán bendecidas \+w todas|strong="H3605"\+w* las \+w naciones|strong="H1471"\+w* de \+w la|strong="H3605"\+w* tierra, \+w por|strong="H6118"\+w* cuanto \+w obedeciste|strong="H8085"\+w* mi \+w voz|strong="H6963"\+w*.\wj*   
\p
\v 19 Abraham regresó \w a|strong="H3068"\w* sus jóvenes esclavos. \w Luego|strong="H7725"\w* se \w levantaron|strong="H6965"\w* y \w fueron|strong="H3212"\w* \w juntos|strong="H3162"\w* hacia Beerseba. \w Y|strong="H3068"\w* vivió Abraham \w en|strong="H3212"\w* Beerseba.   
\s1 Familia de Nacor  
\p
\v 20 \w Después|strong="H1961"\w* \w de|strong="H1121"\w* estas \w cosas|strong="H1697"\w* ocurrió \w que|strong="H1931"\w* \w se|strong="H1961"\w* informó \w a|strong="H3068"\w* Abraham: \w Mira|strong="H2009"\w*, \w también|strong="H1571"\w* \w Milca|strong="H4435"\w* ha dado \w hijos|strong="H1121"\w* \w a|strong="H3068"\w* Nacor tu hermano:  
\v 21 \w a|strong="H3068"\w* \w Uz|strong="H5780"\w* su \w primogénito|strong="H1060"\w*, \w a|strong="H3068"\w* Buz, hermano de éste, \w a|strong="H3068"\w* Kemuel, padre de Aram,  
\v 22 y \w a|strong="H3068"\w* Quesed, \w a|strong="H3068"\w* Hazo, \w a|strong="H3068"\w* Pildas, \w a|strong="H3068"\w* Jidlaf y \w a|strong="H3068"\w* Betuel.  
\v 23 Betuel \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Rebeca|strong="H7259"\w*. \w Milca|strong="H4435"\w* dio \w a|strong="H3068"\w* luz estos \w ocho|strong="H8083"\w* \w a|strong="H3068"\w* Nacor, hermano de Abraham.  
\v 24 \w Su|strong="H1931"\w* \w concubina|strong="H6370"\w*, \w cuyo|strong="H1931"\w* \w nombre|strong="H8034"\w* \w era|strong="H1931"\w* \w Reúma|strong="H7208"\w*, \w también|strong="H1571"\w* dio \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* Tebah, \w a|strong="H3068"\w* Gaham, \w a|strong="H3068"\w* Tahas \w y|strong="H1571"\w* \w a|strong="H3068"\w* Maaca.   
\c 23  
\s1 Muerte de Sara  
\p
\v 1 \w Sara|strong="H8283"\w* vivió 127 \w años|strong="H8141"\w*. Tantos \w fueron|strong="H1961"\w* \w los|strong="H1961"\w* \w años|strong="H8141"\w* de la \w vida|strong="H2416"\w* de \w Sara|strong="H8283"\w*.  
\v 2 \w Sara|strong="H8283"\w* \w murió|strong="H4191"\w* en Quiriat-arba, \w que|strong="H1931"\w* \w es|strong="H1931"\w* \w Hebrón|strong="H2275"\w*, en tierra de \w Canaán|strong="H3667"\w*. Abraham acudió para hacer duelo por \w Sara|strong="H8283"\w* y llorar por \w ella|strong="H1931"\w*.   
\p
\v 3 Abraham \w se|strong="H5921"\w* \w levantó|strong="H6965"\w* \w de|strong="H5921"\w* \w junto|strong="H5921"\w* \w a|strong="H3068"\w* su difunta \w y|strong="H5921"\w* \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* Het:  
\v 4 Yo soy forastero y \w extranjero|strong="H1616"\w* \w entre|strong="H5973"\w* ustedes. Denme propiedad \w de|strong="H6440"\w* \w sepultura|strong="H6913"\w* \w entre|strong="H5973"\w* ustedes y sepultaré \w a|strong="H3068"\w* mi difunta fuera \w de|strong="H6440"\w* mi \w presencia|strong="H6440"\w*.   
\p
\v 5 \w Y|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Het \w respondieron|strong="H6030"\w* \w a|strong="H3068"\w* Abraham:  
\v 6 Escúchenos, \tl ʼadón\tl* nuestro, tú eres \w en|strong="H4480"\w* \w medio|strong="H8432"\w* \w de|strong="H4480"\w* nosotros un \w príncipe|strong="H5387"\w* \w de|strong="H4480"\w* \nd ʼElohim\nd*. \w Sepulta|strong="H6912"\w* \w a|strong="H3068"\w* tu difunta \w en|strong="H4480"\w* \w lo|strong="H3808"\w* \w más|strong="H4480"\w* escogido \w de|strong="H4480"\w* nuestros \w sepulcros|strong="H6913"\w*. \w Ninguno|strong="H3808"\w* \w de|strong="H4480"\w* nosotros \w te|strong="H4480"\w* negará su \w sepulcro|strong="H6913"\w* \w para|strong="H4480"\w* sepultar \w a|strong="H3068"\w* tu difunta.   
\p
\v 7 Pero Abraham \w se|strong="H5971"\w* \w levantó|strong="H6965"\w* y \w se|strong="H5971"\w* inclinó ante \w el|strong="H1121"\w* \w pueblo|strong="H5971"\w* \w de|strong="H1121"\w* aquella tierra, ante \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Het,  
\v 8 y les \w habló|strong="H1696"\w*: \w Si|strong="H6440"\w* \w es|strong="H3426"\w* su \w voluntad|strong="H5315"\w* \w que|strong="H1121"\w* \w yo|strong="H5315"\w* sepulte \w a|strong="H3068"\w* \w mi|strong="H5315"\w* difunta lejos \w de|strong="H6440"\w* \w mi|strong="H5315"\w* \w presencia|strong="H6440"\w*, escúchenme. Intercedan \w por|strong="H6440"\w* \w mí|strong="H5315"\w* \w ante|strong="H6440"\w* Efrón, \w hijo|strong="H1121"\w* \w de|strong="H6440"\w* Zoar,  
\v 9 \w para|strong="H5414"\w* que me venda la \w cueva|strong="H4631"\w* \w de|strong="H5414"\w* la Macpela, que está \w en|strong="H8432"\w* el \w extremo|strong="H7097"\w* \w de|strong="H5414"\w* su \w campo|strong="H7704"\w*, que \w por|strong="H5414"\w* su \w justo|strong="H4392"\w* \w precio|strong="H3701"\w* me la \w dé|strong="H5414"\w* como propiedad \w para|strong="H5414"\w* \w sepultura|strong="H6913"\w* \w entre|strong="H8432"\w* ustedes.   
\s1 La cueva de la Macpela  
\p
\v 10 Efrón \w habitaba|strong="H3427"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H1121"\w* \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Het. \w Y|strong="H3068"\w* Efrón heteo \w respondió|strong="H6030"\w* \w a|strong="H3068"\w* Abraham, \w a|strong="H3068"\w* oídos \w de|strong="H1121"\w* \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Het y \w de|strong="H1121"\w* \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w que|strong="H1121"\w* entraban por \w la|strong="H3605"\w* \w puerta|strong="H8179"\w* \w de|strong="H1121"\w* su \w ciudad|strong="H5892"\w*:  
\v 11 \w No|strong="H3808"\w*, mi \tl ʼadón\tl*, \w escúchame|strong="H8085"\w*. \w Te|strong="H5869"\w* \w doy|strong="H5414"\w* \w el|strong="H1121"\w* \w campo|strong="H7704"\w* y la \w cueva|strong="H4631"\w* \w que|strong="H3808"\w* está \w en|strong="H6912"\w* \w él|strong="H1121"\w*. \w Te|strong="H5869"\w* la \w doy|strong="H5414"\w* \w en|strong="H6912"\w* presencia \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* mi \w pueblo|strong="H5971"\w*. \w Sepulta|strong="H6912"\w* tu difunta.   
\p
\v 12 Pero Abraham \w se|strong="H5971"\w* inclinó \w ante|strong="H6440"\w* el \w pueblo|strong="H5971"\w* \w de|strong="H6440"\w* aquella tierra,  
\v 13 \w habló|strong="H1696"\w* \w a|strong="H3068"\w* Efrón ante el \w pueblo|strong="H5971"\w* y \w dijo|strong="H1696"\w*: \w Más|strong="H4480"\w* bien, \w si|strong="H3863"\w* \w te|strong="H4480"\w* place, \w te|strong="H4480"\w* ruego \w que|strong="H4480"\w* \w me|strong="H4480"\w* escuches. \w Te|strong="H4480"\w* \w doy|strong="H5414"\w* el valor \w del|strong="H4480"\w* \w campo|strong="H7704"\w*. Acéptamelo y sepultaré mi difunta \w allí|strong="H8033"\w*.   
\p
\v 14 Efrón \w respondió|strong="H6030"\w* \w a|strong="H3068"\w* Abraham:  
\v 15 Mi \tl ʼadón\tl*, \w escúchame|strong="H8085"\w*: ¿\w Qué|strong="H4100"\w* \w es|strong="H1931"\w* entre tú y yo una parcela de 4,4 kilogramos de \w plata|strong="H3701"\w*? \w Sepulta|strong="H6912"\w*, \w pues|strong="H1931"\w*, \w a|strong="H3068"\w* tu difunta.   
\p
\v 16 Abraham \w atendió|strong="H8085"\w* \w a|strong="H3068"\w* Efrón. \w Y|strong="H3068"\w* Abraham le pesó \w a|strong="H3068"\w* Efrón la \w plata|strong="H3701"\w* \w que|strong="H1121"\w* \w dijo|strong="H1696"\w* \w a|strong="H3068"\w* \w oídos|strong="H8085"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Het, 4,4 kilogramos \w de|strong="H1121"\w* \w plata|strong="H3701"\w* \w de|strong="H1121"\w* curso entre comerciantes.   
\p
\v 17 Así quedó \w el|strong="H3605"\w* \w campo|strong="H7704"\w* \w de|strong="H6440"\w* Efrón \w que|strong="H3605"\w* \w está|strong="H6965"\w* en \w la|strong="H3605"\w* Macpela, al frente \w de|strong="H6440"\w* \w Mamre|strong="H4471"\w*: \w El|strong="H3605"\w* \w campo|strong="H7704"\w*, \w la|strong="H3605"\w* \w cueva|strong="H4631"\w* \w que|strong="H3605"\w* estaba en \w él|strong="H3605"\w* y \w toda|strong="H3605"\w* \w la|strong="H3605"\w* arboleda \w que|strong="H3605"\w* \w está|strong="H6965"\w* \w alrededor|strong="H5439"\w* del \w campo|strong="H7704"\w* en \w todo|strong="H3605"\w* su límite  
\v 18 quedaron en posesión \w de|strong="H1121"\w* Abraham \w a|strong="H3068"\w* \w la|strong="H3605"\w* vista \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Het y \w de|strong="H1121"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w que|strong="H1121"\w* entraban por \w la|strong="H3605"\w* \w puerta|strong="H8179"\w* \w de|strong="H1121"\w* su \w ciudad|strong="H5892"\w*.  
\v 19 \w Después|strong="H5921"\w* \w de|strong="H5921"\w* \w esto|strong="H3651"\w* Abraham \w sepultó|strong="H6912"\w* \w a|strong="H3068"\w* \w su|strong="H1931"\w* esposa \w Sara|strong="H8283"\w* \w en|strong="H5921"\w* \w la|strong="H1931"\w* \w cueva|strong="H4631"\w* \w del|strong="H5921"\w* \w campo|strong="H7704"\w* \w de|strong="H5921"\w* \w la|strong="H1931"\w* Macpela, \w al|strong="H5921"\w* frente \w de|strong="H5921"\w* \w Mamre|strong="H4471"\w*, \w que|strong="H1931"\w* \w es|strong="H1931"\w* \w Hebrón|strong="H2275"\w*, \w en|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w Canaán|strong="H3667"\w*.  
\v 20 \w El|strong="H1121"\w* \w campo|strong="H7704"\w* y la \w cueva|strong="H4631"\w* \w que|strong="H1121"\w* estaba en \w él|strong="H1121"\w* quedaron en posesión \w de|strong="H1121"\w* Abraham como propiedad para \w sepultura|strong="H6913"\w*, procedente \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Het.   
\c 24  
\s1 El esclavo y Rebeca  
\p
\v 1 Abraham era anciano, entrado en \w días|strong="H3117"\w*, y \nd \+w Yavé|strong="H3068"\+w*\nd* \w lo|strong="H3605"\w* había bendecido en \w todo|strong="H3605"\w*.  
\v 2 \w Y|strong="H3068"\w* Abraham dijo \w al|strong="H8478"\w* esclavo más antiguo \w de|strong="H8478"\w* su \w casa|strong="H1004"\w*, \w el|strong="H3605"\w* cual administraba \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w que|strong="H4994"\w* \w aquél|strong="H3605"\w* tenía: Coloca \w ahora|strong="H4994"\w* tu \w mano|strong="H3027"\w* \w debajo|strong="H8478"\w* \w de|strong="H8478"\w* \w mi|strong="H4994"\w* \w muslo|strong="H3409"\w*  
\v 3 y \w jurarás|strong="H7650"\w* por \nd \+w Yavé|strong="H3068"\+w*, ʼElohim\nd* \w de|strong="H1121"\w* \w los|strong="H3427"\w* \w cielos|strong="H8064"\w* y \w de|strong="H1121"\w* la tierra, \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w tomarás|strong="H3947"\w* para mi \w hijo|strong="H1121"\w* esposa \w de|strong="H1121"\w* las \w hijas|strong="H1323"\w* \w de|strong="H1121"\w* \w los|strong="H3427"\w* \w cananeos|strong="H3669"\w* en \w medio|strong="H7130"\w* \w de|strong="H1121"\w* \w los|strong="H3427"\w* cuales yo vivo,  
\v 4 \w sino|strong="H3588"\w* \w que|strong="H3588"\w* \w irás|strong="H3212"\w* \w a|strong="H3068"\w* mi tierra \w y|strong="H3588"\w* \w a|strong="H3068"\w* mi \w parentela|strong="H4138"\w* \w y|strong="H3588"\w* \w tomarás|strong="H3947"\w* esposa \w para|strong="H3588"\w* mi \w hijo|strong="H1121"\w* \w Isaac|strong="H3327"\w*.   
\p
\v 5 \w Y|strong="H3068"\w* \w el|strong="H1121"\w* esclavo le \w respondió|strong="H7725"\w*: Quizás \w la|strong="H2063"\w* mujer \w no|strong="H3808"\w* consienta \w en|strong="H3318"\w* \w venir|strong="H3212"\w* conmigo \w a|strong="H3068"\w* \w esta|strong="H2063"\w* tierra. ¿Llevaré \w a|strong="H3068"\w* tu \w hijo|strong="H1121"\w* \w a|strong="H3068"\w* \w la|strong="H2063"\w* tierra \w de|strong="H1121"\w* \w donde|strong="H8033"\w* \w saliste|strong="H3318"\w*?   
\p
\v 6 \w Entonces|strong="H7725"\w* Abraham le contestó: \w Guárdate|strong="H8104"\w* \w de|strong="H1121"\w* \w no|strong="H6435"\w* llevar \w a|strong="H3068"\w* mi \w hijo|strong="H1121"\w* \w allá|strong="H8033"\w*.  
