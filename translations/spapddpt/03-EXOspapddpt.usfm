\v 31 \w El|strong="H3588"\w* \w pueblo|strong="H5971"\w* creyó, \w y|strong="H3588"\w* al \w oír|strong="H8085"\w* \w que|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w visitó|strong="H6485"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* \w y|strong="H3588"\w* \w vio|strong="H7200"\w* \w su|strong="H3588"\w* \w aflicción|strong="H6040"\w*, \w se|strong="H5971"\w* postraron \w y|strong="H3588"\w* \w adoraron|strong="H7812"\w*.   
\c 5  
\ms1 Ante Faraón  
\s1 La primera solicitud  
\p
\v 1 Después \w Moisés|strong="H4872"\w* \w y|strong="H3541"\w* Aarón fueron \w a|strong="H3068"\w* \w Faraón|strong="H6547"\w* \w y|strong="H3541"\w* le dijeron: \nd \+w Yavé|strong="H3068"\+w*\nd* el \nd ʼElohim\nd* \w de|strong="H5971"\w* \w Israel|strong="H3478"\w* dice: \wj \+w Deja|strong="H7971"\+w* \+w ir|strong="H7971"\+w* \+w a|strong="H3068"\+w* mi \+w pueblo|strong="H5971"\+w* \+w para|strong="H5971"\+w* \+w que|strong="H5971"\+w* \+w me|strong="H3541"\+w* celebre una fiesta en el \+w desierto|strong="H4057"\+w*.\wj*   
\p
\v 2 Pero \w Faraón|strong="H6547"\w* respondió: ¿\w Quién|strong="H4310"\w* es \nd \+w Yavé|strong="H3068"\+w*\nd* para \w que|strong="H4310"\w* yo obedezca su \w voz|strong="H6963"\w* \w y|strong="H1571"\w* \w deje|strong="H7971"\w* \w ir|strong="H7971"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w*? ¡\w No|strong="H3808"\w* \w conozco|strong="H3045"\w* \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w ni|strong="H3808"\w* \w dejaré|strong="H7971"\w* \w ir|strong="H7971"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w*!   
\p
\v 3 \w Ellos|strong="H5921"\w* dijeron: \w El|strong="H5921"\w* \nd ʼElohim\nd* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w hebreos|strong="H5680"\w* \w se|strong="H5921"\w* encontró \w con|strong="H5921"\w* \w nosotros|strong="H5921"\w*. \w Te|strong="H5921"\w* rogamos \w que|strong="H4994"\w* \w nos|strong="H5921"\w* permitas \w ir|strong="H3212"\w* un \w camino|strong="H1870"\w* \w de|strong="H5921"\w* \w tres|strong="H7969"\w* \w jornadas|strong="H3117"\w* \w por|strong="H5921"\w* \w el|strong="H5921"\w* \w desierto|strong="H4057"\w* \w para|strong="H5921"\w* \w que|strong="H4994"\w* ofrezcamos sacrificio \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* nuestro \nd ʼElohim\nd*, \w no|strong="H6435"\w* \w sea|strong="H6435"\w* \w que|strong="H4994"\w* \w Él|strong="H5921"\w* \w nos|strong="H5921"\w* ataque \w con|strong="H5921"\w* \w pestilencia|strong="H1698"\w* \w o|strong="H3068"\w* \w con|strong="H5921"\w* \w la|strong="H5921"\w* \w espada|strong="H2719"\w*.   
\p
\v 4 Entonces el \w rey|strong="H4428"\w* \w de|strong="H5971"\w* \w Egipto|strong="H4714"\w* les dijo \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w* y Aarón: ¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* distraen \w al|strong="H4428"\w* \w pueblo|strong="H5971"\w* \w de|strong="H5971"\w* su trabajo? ¡Dedíquense \w a|strong="H3068"\w* sus tareas!   
\p
\v 5 También \w Faraón|strong="H6547"\w* dijo: Miren, las gentes \w de|strong="H5971"\w* la tierra son \w ahora|strong="H6258"\w* \w muchas|strong="H7227"\w*, y ustedes los están haciendo cesar en sus tareas.   
\p
\v 6 \w Aquel|strong="H1931"\w* \w mismo|strong="H1931"\w* \w día|strong="H3117"\w* \w Faraón|strong="H6547"\w* \w mandó|strong="H6680"\w* \w a|strong="H3068"\w* \w los|strong="H1931"\w* capataces del \w pueblo|strong="H5971"\w* y \w a|strong="H3068"\w* \w sus|strong="H1931"\w* caporales:  
\v 7 \w No|strong="H3808"\w* continúen la provisión \w de|strong="H5971"\w* pasto seco al \w pueblo|strong="H5971"\w* \w para|strong="H5414"\w* fabricar adobes como \w en|strong="H3212"\w* días pasados. ¡\w Que|strong="H3808"\w* \w ellos|strong="H1992"\w* \w mismos|strong="H1992"\w* \w vayan|strong="H3212"\w* y recojan \w el|strong="H1992"\w* pasto seco!  
\v 8 \w Les|strong="H1992"\w* exigirán \w la|strong="H5921"\w* misma cantidad \w de|strong="H4480"\w* adobes \w que|strong="H3588"\w* \w hacían|strong="H6213"\w* \w en|strong="H5921"\w* días pasados, \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w la|strong="H5921"\w* rebajarán, \w porque|strong="H3588"\w* \w son|strong="H3588"\w* perezosos. \w Por|strong="H5921"\w* \w eso|strong="H3651"\w* \w claman|strong="H6817"\w* \w y|strong="H3588"\w* dicen: Deseamos \w ir|strong="H3212"\w* \w a|strong="H3068"\w* \w hacer|strong="H6213"\w* \w sacrificios|strong="H2076"\w* \w para|strong="H5921"\w* nuestro \nd ʼElohim\nd*.  
\v 9 ¡\w Que|strong="H5921"\w* \w se|strong="H5921"\w* agrave \w la|strong="H5921"\w* \w servidumbre|strong="H5656"\w* \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w*, \w que|strong="H5921"\w* \w se|strong="H5921"\w* ocupen \w en|strong="H5921"\w* \w ella|strong="H5921"\w* \w y|strong="H5921"\w* \w no|strong="H6213"\w* \w atiendan|strong="H8159"\w* \w a|strong="H3068"\w* \w palabras|strong="H1697"\w* falsas!   
\p
\v 10 Entonces al \w salir|strong="H3318"\w* los capataces \w y|strong="H3541"\w* los caporales, hablaron al \w pueblo|strong="H5971"\w*: \w Faraón|strong="H6547"\w* dijo: ¡\w Ya|strong="H3068"\w* no les \w doy|strong="H5414"\w* más pasto seco!  
\v 11 \w Vayan|strong="H3212"\w*, recojan ustedes mismos pasto seco donde \w lo|strong="H1697"\w* encuentren, \w aunque|strong="H3588"\w* \w nada|strong="H1697"\w* se \w disminuirá|strong="H1639"\w* \w de|strong="H3588"\w* \w su|strong="H3588"\w* \w tarea|strong="H5656"\w*.   
\p
\v 12 Entonces \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* \w se|strong="H5971"\w* esparció por \w toda|strong="H3605"\w* \w la|strong="H3605"\w* tierra \w de|strong="H5971"\w* \w Egipto|strong="H4714"\w* \w para|strong="H5971"\w* recoger \w rastrojo|strong="H7179"\w*\f + \fr 5:12 \ft Rastrojo. Residuo de espigas que queda tras la cosecha de trigo y otros granos.\f* \w que|strong="H5971"\w* sirviera como pasto seco.  
\v 13 Entre tanto \w los|strong="H1961"\w* capataces \w los|strong="H1961"\w* apremiaban y decían: \w Acaben|strong="H3615"\w* sus tareas, la tarea \w de|strong="H1697"\w* \w cada|strong="H1697"\w* \w día|strong="H3117"\w* en su \w día|strong="H3117"\w*, \w como|strong="H1961"\w* \w cuando|strong="H3117"\w* \w había|strong="H1961"\w* pasto seco.  
\v 14 \w También|strong="H1571"\w* \w los|strong="H1121"\w* caporales \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w a|strong="H3068"\w* quienes \w los|strong="H1121"\w* capataces \w de|strong="H5921"\w* \w Faraón|strong="H6547"\w* \w les|strong="H5921"\w* \w dieron|strong="H5221"\w* autoridad \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w*, \w eran|strong="H3808"\w* azotados, \w y|strong="H1571"\w* \w les|strong="H5921"\w* decían: ¿\w Por|strong="H5921"\w* \w qué|strong="H3808"\w* \w no|strong="H3808"\w* cumplieron \w ayer|strong="H8543"\w* \w ni|strong="H3808"\w* \w hoy|strong="H3117"\w* su cuota \w de|strong="H5921"\w* adobes \w como|strong="H1571"\w* \w antes|strong="H8543"\w*?   
\p
\v 15 Entonces \w los|strong="H1121"\w* caporales \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* fueron \w a|strong="H3068"\w* \w Faraón|strong="H6547"\w* \w y|strong="H3541"\w* \w se|strong="H4100"\w* quejaron ante \w él|strong="H1121"\w*: ¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* tratas \w así|strong="H3541"\w* \w a|strong="H3068"\w* tus esclavos?  
\v 16 \w No|strong="H6213"\w* \w se|strong="H5971"\w* \w da|strong="H5414"\w* pasto seco \w a|strong="H3068"\w* tus esclavos, pero nos dicen: ¡\w Hagan|strong="H6213"\w* adobes! \w Mira|strong="H2009"\w*, tus esclavos son azotados, como \w si|strong="H2009"\w* \w tu|strong="H6213"\w* \w pueblo|strong="H5971"\w* fuera \w el|strong="H6213"\w* culpable.   
\p
\v 17 Pero \w él|strong="H5921"\w* respondió: Son perezosos, muy perezosos, \w y|strong="H5921"\w* \w por|strong="H5921"\w* \w eso|strong="H3651"\w* ustedes dicen: \w Vamos|strong="H3212"\w* \w a|strong="H3068"\w* ofrecer sacrificio \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.  
\v 18 \w Vayan|strong="H3212"\w* \w ahora|strong="H6258"\w* y trabajen. \w No|strong="H3808"\w* \w se|strong="H3808"\w* les \w dará|strong="H5414"\w* pasto seco, y deberán entregar la misma cantidad \w de|strong="H5414"\w* adobes.   
\p
\v 19 \w Y|strong="H3068"\w* \w los|strong="H1121"\w* caporales \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w se|strong="H3808"\w* \w vieron|strong="H7200"\w* en apuros \w porque|strong="H3808"\w* \w se|strong="H3808"\w* les dijo: \w Nada|strong="H3808"\w* \w de|strong="H1121"\w* su cuota \w de|strong="H1121"\w* adobes \w se|strong="H3808"\w* reducirá. La tarea \w de|strong="H1121"\w* \w cada|strong="H1697"\w* jornada en su \w día|strong="H3117"\w*.   
\p
\v 20 Al \w salir|strong="H3318"\w* de la presencia de \w Faraón|strong="H6547"\w*, se encontraron con \w Moisés|strong="H4872"\w* y Aarón, quienes los esperaban,  
\v 21 \w y|strong="H5921"\w* \w les|strong="H5921"\w* dijeron: \w Que|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w los|strong="H5921"\w* \w mire|strong="H7200"\w* \w y|strong="H5921"\w* \w juzgue|strong="H8199"\w*, \w pues|strong="H7200"\w* \w nos|strong="H5921"\w* \w hicieron|strong="H5414"\w* odiosos ante \w Faraón|strong="H6547"\w* \w y|strong="H5921"\w* ante sus esclavos \w al|strong="H5921"\w* \w poner|strong="H5414"\w* \w en|strong="H5921"\w* su \w mano|strong="H3027"\w* una \w espada|strong="H2719"\w* \w para|strong="H5921"\w* \w que|strong="H5921"\w* \w se|strong="H5921"\w* \w nos|strong="H5921"\w* \w mate|strong="H2026"\w*.   
\p
\v 22 \w Entonces|strong="H7725"\w* \w Moisés|strong="H4872"\w* \w se|strong="H4100"\w* \w volvió|strong="H7725"\w* hacia \nd \+w Yavé|strong="H3068"\+w*\nd* y le dijo: \w Oh|strong="H4100"\w* \nd ʼAdonay\nd*, ¿\w por|strong="H2088"\w* \w qué|strong="H4100"\w* \w afliges|strong="H7489"\w* \w a|strong="H3068"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w*? ¿\w Por|strong="H2088"\w* \w qué|strong="H4100"\w* me \w enviaste|strong="H7971"\w*?  
\v 23 \w Porque|strong="H3808"\w* desde cuando \w fui|strong="H3808"\w* \w a|strong="H3068"\w* \w Faraón|strong="H6547"\w* \w para|strong="H5971"\w* \w hablar|strong="H1696"\w* en tu \w Nombre|strong="H8034"\w*, él afligió \w a|strong="H3068"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w*, y Tú \w no|strong="H3808"\w* has \w librado|strong="H5337"\w* \w a|strong="H3068"\w* tu \w pueblo|strong="H5971"\w* \w de|strong="H5971"\w* \w ningún|strong="H3808"\w* modo.   
\c 6  
\s1 La respuesta divina  
\p
\v 1 \nd \+w Yavé|strong="H3068"\+w*\nd* dijo \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: \wj \+w Ahora|strong="H6258"\+w* \+w verás|strong="H7200"\+w* \+w lo|strong="H6213"\+w* \+w que|strong="H3588"\+w* \+w Yo|strong="H3588"\+w* \+w haré|strong="H6213"\+w* \+w a|strong="H3068"\+w* \+w Faraón|strong="H6547"\+w*, \+w porque|strong="H3588"\+w* \+w por|strong="H3588"\+w* \+w mano|strong="H3027"\+w* \+w fuerte|strong="H2389"\+w* \+w los|strong="H3588"\+w* dejará \+w ir|strong="H7971"\+w*, \+w y|strong="H3588"\+w* \+w por|strong="H3588"\+w* \+w mano|strong="H3027"\+w* \+w fuerte|strong="H2389"\+w* \+w los|strong="H3588"\+w* expulsará \+w de|strong="H3588"\+w* \+w su|strong="H3588"\+w* tierra. \wj*   
\p
\v 2 \w Y|strong="H3068"\w* \nd ʼElohim\nd* \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: \wj Yo soy \+nd \+w Yavé|strong="H3068"\+w*\+nd*.\wj*  
\v 3 \wj Yo me aparecí \+w a|strong="H3068"\+w* Abraham, \+w a|strong="H3068"\+w* \+w Isaac|strong="H3327"\+w* y \+w a|strong="H3068"\+w* \+w Jacob|strong="H3290"\+w* como \+nd ʼEL-Shadday\+nd*, pero \+w no|strong="H3808"\+w* me dí \+w a|strong="H3068"\+w* conocer \+w a|strong="H3068"\+w* ellos con mi \+w Nombre|strong="H8034"\+w* \+nd \+w Yavé|strong="H3068"\+w*\+nd*. \wj*  
\v 4 \wj \+w También|strong="H1571"\+w* \+w establecí|strong="H6965"\+w* mi \+w Pacto|strong="H1285"\+w* \+w con|strong="H1571"\+w* \+w ellos|strong="H1571"\+w* \+w para|strong="H5414"\+w* darles \+w la|strong="H1571"\+w* tierra \+w de|strong="H5414"\+w* \+w Canaán|strong="H3667"\+w*, tierra \+w de|strong="H5414"\+w* sus peregrinaciones en \+w la|strong="H1571"\+w* cual vivieron. \wj*  
\v 5 \wj \+w Además|strong="H1571"\+w* Yo \+w escuché|strong="H8085"\+w* \+w el|strong="H1121"\+w* gemido \+w de|strong="H1121"\+w* \+w los|strong="H1121"\+w* \+w hijos|strong="H1121"\+w* \+w de|strong="H1121"\+w* \+w Israel|strong="H3478"\+w*, porque \+w los|strong="H1121"\+w* \+w egipcios|strong="H4714"\+w* \+w los|strong="H1121"\+w* mantienen en esclavitud, \+w y|strong="H1571"\+w* recordé mi \+w Pacto|strong="H1285"\+w*. \wj*   
\p
\v 6 \wj \+w Por|strong="H8478"\+w* \+w tanto|strong="H3651"\+w*, dí \+w a|strong="H3068"\+w* \+w los|strong="H1121"\+w* \+w hijos|strong="H1121"\+w* \+w de|strong="H8478"\+w* \+w Israel|strong="H3478"\+w*: Yo soy \+nd \+w Yavé|strong="H3068"\+w*\+nd*. \+w Los|strong="H1121"\+w* sacaré \+w de|strong="H8478"\+w* \+w debajo|strong="H8478"\+w* \+w de|strong="H8478"\+w* las cargas \+w de|strong="H8478"\+w* \+w los|strong="H1121"\+w* \+w egipcios|strong="H4714"\+w* y \+w los|strong="H1121"\+w* \+w libraré|strong="H5337"\+w* \+w de|strong="H8478"\+w* su esclavitud. \+w También|strong="H3651"\+w* \+w los|strong="H1121"\+w* \+w redimiré|strong="H1350"\+w* con \+w brazo|strong="H2220"\+w* \+w extendido|strong="H5186"\+w* y con \+w grandes|strong="H1419"\+w* \+w juicios|strong="H8201"\+w*. \wj*   
\p
\v 7 \wj \+w Entonces|strong="H3588"\+w* \+w los|strong="H1961"\+w* \+w tomaré|strong="H3947"\+w* \+w para|strong="H3588"\+w* \+w Mí|strong="H1961"\+w* \+w como|strong="H3588"\+w* \+w mi|strong="H1961"\+w* \+w pueblo|strong="H5971"\+w* \+w y|strong="H3588"\+w* \+w seré|strong="H1961"\+w* \+w para|strong="H3588"\+w* ustedes \+w su|strong="H3588"\+w* \+nd ʼElohim\+nd*. \+w Y|strong="H3068"\+w* \+w sabrán|strong="H3045"\+w* \+w que|strong="H3588"\+w* \+w Yo|strong="H3588"\+w* \+w soy|strong="H1961"\+w* \+nd \+w Yavé|strong="H3068"\+w*\+nd* \+w su|strong="H3588"\+w* \+nd ʼElohim\+nd*, Quien \+w los|strong="H1961"\+w* \+w sacó|strong="H3318"\+w* \+w de|strong="H3588"\+w* \+w debajo|strong="H8478"\+w* \+w de|strong="H3588"\+w* las cargas \+w de|strong="H3588"\+w* \+w los|strong="H1961"\+w* \+w egipcios|strong="H4714"\+w*. \wj*  
\v 8 \wj Los \+w llevaré|strong="H5375"\+w* \+w a|strong="H3068"\+w* la tierra \+w que|strong="H3027"\+w* juré \+w dar|strong="H5414"\+w* \+w a|strong="H3068"\+w* Abraham, \+w a|strong="H3068"\+w* \+w Isaac|strong="H3327"\+w* y \+w a|strong="H3068"\+w* \+w Jacob|strong="H3290"\+w*, y se la \+w daré|strong="H5414"\+w* en \+w posesión|strong="H4181"\+w*. Yo, \+nd \+w Yavé|strong="H3068"\+w*\+nd*.\wj*   
\p
\v 9 \w Moisés|strong="H4872"\w* \w habló|strong="H1696"\w* \w así|strong="H3651"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, pero ellos \w no|strong="H3808"\w* \w escucharon|strong="H8085"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w* \w a|strong="H3068"\w* causa \w de|strong="H1121"\w* la impaciencia \w de|strong="H1121"\w* \w espíritu|strong="H7307"\w* y la cruel esclavitud.   
\p
\v 10 Entonces \nd \+w Yavé|strong="H3068"\+w*\nd* \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*:  
\v 11 \wj Entra, dile \+w a|strong="H3068"\+w* \+w Faraón|strong="H6547"\+w*, \+w rey|strong="H4428"\+w* \+w de|strong="H1121"\+w* \+w Egipto|strong="H4714"\+w*, \+w que|strong="H1121"\+w* \+w deje|strong="H7971"\+w* salir \+w de|strong="H1121"\+w* su tierra \+w a|strong="H3068"\+w* \+w los|strong="H1121"\+w* \+w hijos|strong="H1121"\+w* \+w de|strong="H1121"\+w* \+w Israel|strong="H3478"\+w*.\wj*   
\p
\v 12 \w Y|strong="H3068"\w* \w Moisés|strong="H4872"\w* \w habló|strong="H1696"\w* \w ante|strong="H6440"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*: \w Mira|strong="H2005"\w*, \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w* \w no|strong="H3808"\w* me \w escuchan|strong="H8085"\w*. ¿Cómo me \w escuchará|strong="H8085"\w* \w Faraón|strong="H6547"\w*? \w Porque|strong="H3808"\w* yo soy \w de|strong="H6440"\w* \w labios|strong="H8193"\w* \w incircuncisos|strong="H6189"\w*.   
\p
\v 13 Entonces \nd \+w Yavé|strong="H3068"\+w*\nd* \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w* y \w a|strong="H3068"\w* Aarón y \w les|strong="H6680"\w* dio instrucciones para \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* y para \w Faraón|strong="H6547"\w*, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w Egipto|strong="H4714"\w*, \w a|strong="H3068"\w* fin \w de|strong="H1121"\w* sacar \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w de|strong="H1121"\w* la tierra \w de|strong="H1121"\w* \w Egipto|strong="H4714"\w*.   
\s1 Las familias de Rubén, Simeón y Leví  
\p
\v 14 Estos son \w los|strong="H1121"\w* \w jefes|strong="H7218"\w* \w de|strong="H1121"\w* las \w familias|strong="H4940"\w* paternas: \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Rubén|strong="H7205"\w*, \w el|strong="H1121"\w* \w primogénito|strong="H1060"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*: Hanoc, Falú, \w Hezrón|strong="H2696"\w* y \w Carmi|strong="H3756"\w*. Estas son las \w familias|strong="H4940"\w* \w de|strong="H1121"\w* \w Rubén|strong="H7205"\w*.   
\p
\v 15 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Simeón|strong="H8095"\w*: \w Jemuel|strong="H3223"\w*, \w Jamín|strong="H3226"\w*, Ohad, Jaquín, Zoar y \w Saúl|strong="H7586"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* una \w cananea|strong="H3669"\w*. Estas son las \w familias|strong="H4940"\w* \w de|strong="H1121"\w* \w Simeón|strong="H8095"\w*.   
\p
\v 16 Estos son \w los|strong="H1121"\w* \w nombres|strong="H8034"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Leví|strong="H3878"\w* por sus linajes: \w Gersón|strong="H1648"\w*, Coat y \w Merari|strong="H4847"\w*. \w Y|strong="H3068"\w* \w los|strong="H1121"\w* \w años|strong="H8141"\w* \w de|strong="H1121"\w* la \w vida|strong="H2416"\w* \w de|strong="H1121"\w* \w Leví|strong="H3878"\w* fueron 137 \w años|strong="H8141"\w*.   
\p
\v 17 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Gersón|strong="H1648"\w*: \w Libni|strong="H3845"\w* y Simei, por sus \w familias|strong="H4940"\w*.   
\p
\v 18 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Coat: \w Amram|strong="H6019"\w*, Izar, \w Hebrón|strong="H2275"\w* y Uziel. \w Y|strong="H3068"\w* la duración \w de|strong="H1121"\w* la \w vida|strong="H2416"\w* \w de|strong="H1121"\w* Coat fue 133 \w años|strong="H8141"\w*.   
\p
\v 19 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Merari|strong="H4847"\w*: Mahli y Musi. Estas son las \w familias|strong="H4940"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* levitas según sus generaciones.   
\p
\v 20 \w Amram|strong="H6019"\w* \w tomó|strong="H3947"\w* como esposa \w a|strong="H3068"\w* su tía Jocabed, la cual le dio \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* Aarón y \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*. \w Y|strong="H3068"\w* los \w años|strong="H8141"\w* de la \w vida|strong="H2416"\w* de \w Amram|strong="H6019"\w* fueron 137 \w años|strong="H8141"\w*.   
\p
\v 21 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Izar: \w Cora|strong="H7141"\w*, Nefeg y Zicri.   
\p
\v 22 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Uziel: \w Misael|strong="H4332"\w*, Elzafán y Sitri.   
\p
\v 23 Aarón \w tomó|strong="H3947"\w* como esposa \w a|strong="H3068"\w* Elizabet \w hija|strong="H1323"\w* de \w Aminadab|strong="H5992"\w*, hermana de \w Naasón|strong="H5177"\w*, la cual le dio \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* \w Nadab|strong="H5070"\w*, Abiú, Eleazar \w e|strong="H3068"\w* Itamar.   
\p
\v 24 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Coré|strong="H7141"\w*: Asir, Elcana y Abiasaf. Estas son las \w familias|strong="H4940"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* coreítas.   
\p
\v 25 Eleazar, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Aarón, \w tomó|strong="H3947"\w* para \w él|strong="H1121"\w* una esposa \w de|strong="H1121"\w* las \w hijas|strong="H1323"\w* \w de|strong="H1121"\w* Futiel, la cual le dio \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* Finees. Estos son \w los|strong="H1121"\w* \w jefes|strong="H7218"\w* paternos \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w levitas|strong="H3881"\w* según sus \w familias|strong="H4940"\w*.   
\p
\v 26 \w Éstos|strong="H1931"\w* fueron \w aquel|strong="H1931"\w* Aarón \w y|strong="H5921"\w* \w aquel|strong="H1931"\w* \w Moisés|strong="H4872"\w* \w a|strong="H3068"\w* quienes \nd \+w Yavé|strong="H3068"\+w*\nd* dijo: \wj Saquen \+w a|strong="H3068"\+w* \+w los|strong="H1121"\+w* \+w hijos|strong="H1121"\+w* \+w de|strong="H5921"\+w* \+w Israel|strong="H3478"\+w* \+w de|strong="H5921"\+w* \+w la|strong="H1931"\+w* tierra \+w de|strong="H5921"\+w* \+w Egipto|strong="H4714"\+w* organizados \+w como|strong="H5921"\+w* escuadrones.\wj*  
\v 27 \w Ellos|strong="H1992"\w* fueron \w los|strong="H1992"\w* \w que|strong="H1931"\w* \w hablaron|strong="H1696"\w* \w a|strong="H3068"\w* \w Faraón|strong="H6547"\w* para sacar \w de|strong="H1121"\w* \w Egipto|strong="H4714"\w* \w a|strong="H3068"\w* \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*. \w Estos|strong="H1992"\w* fueron \w Moisés|strong="H4872"\w* y Aarón.   
\p
\v 28 \w Ahora|strong="H3117"\w* bien, \w sucedió|strong="H1961"\w* \w que|strong="H3117"\w* el \w día|strong="H3117"\w* \w cuando|strong="H3117"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w* en la tierra de \w Egipto|strong="H4714"\w*,  
\v 29 \nd \+w Yavé|strong="H3068"\+w*\nd* se dirigió \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: \wj Yo soy \+nd \+w Yavé|strong="H3068"\+w*\+nd*. \+w Habla|strong="H1696"\+w* \+w a|strong="H3068"\+w* \+w Faraón|strong="H6547"\+w*, \+w rey|strong="H4428"\+w* de \+w Egipto|strong="H4714"\+w*, \+w todas|strong="H3605"\+w* las cosas \+w que|strong="H3605"\+w* te digo. \wj*   
\p
\v 30 Pero \w Moisés|strong="H4872"\w* respondió \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*: \w Mira|strong="H2005"\w*, yo soy \w incircunciso|strong="H6189"\w* \w de|strong="H6440"\w* \w labios|strong="H8193"\w*. ¿Cómo, pues, me \w escuchará|strong="H8085"\w* \w Faraón|strong="H6547"\w*?   
\c 7  
\s1 Confirmación del llamamiento  
\p
\v 1 Entonces \nd \+w Yavé|strong="H3068"\+w*\nd* dijo \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: \wj \+w Mira|strong="H7200"\+w*, te designé \+w como|strong="H1961"\+w* \+tl ʼelohim\+tl* ante \+w Faraón|strong="H6547"\+w*, y tu hermano Aarón \+w será|strong="H1961"\+w* tu \+w profeta|strong="H5030"\+w*.\wj*  
\v 2 \wj Tú \+w hablarás|strong="H1696"\+w* cuanto \+w Yo|strong="H6680"\+w* te \+w ordene|strong="H6680"\+w*, y tu hermano Aarón \+w hablará|strong="H1696"\+w* \+w a|strong="H3068"\+w* \+w Faraón|strong="H6547"\+w* para \+w que|strong="H1121"\+w* \+w deje|strong="H7971"\+w* salir \+w de|strong="H1121"\+w* su tierra \+w a|strong="H3068"\+w* \+w los|strong="H1121"\+w* \+w hijos|strong="H1121"\+w* \+w de|strong="H1121"\+w* \+w Israel|strong="H3478"\+w*.\wj*   
\p
\v 3 \wj Sin embargo, Yo \+w endureceré|strong="H7185"\+w* el \+w corazón|strong="H3820"\+w* de \+w Faraón|strong="H6547"\+w*, y aunque multiplique mis señales y mis \+w prodigios|strong="H4159"\+w* en la tierra de \+w Egipto|strong="H4714"\+w*,\wj*  
\v 4 \wj cuando \+w Faraón|strong="H6547"\+w* \+w no|strong="H3808"\+w* \+w los|strong="H1121"\+w* \+w escuche|strong="H8085"\+w*, entonces Yo asentaré mi \+w mano|strong="H3027"\+w* sobre \+w Egipto|strong="H4714"\+w*, y con \+w grandes|strong="H1419"\+w* \+w juicios|strong="H8201"\+w* sacaré \+w de|strong="H1121"\+w* la tierra \+w de|strong="H1121"\+w* \+w Egipto|strong="H4714"\+w* \+w a|strong="H3068"\+w* \+w mis|strong="H5414"\+w* escuadrones, mi \+w pueblo|strong="H5971"\+w*, \+w los|strong="H1121"\+w* \+w hijos|strong="H1121"\+w* \+w de|strong="H1121"\+w* \+w Israel|strong="H3478"\+w*.\wj*   
\p
\v 5 \wj \+w Y|strong="H3068"\+w* \+w los|strong="H1121"\+w* \+w egipcios|strong="H4713"\+w* \+w sabrán|strong="H3045"\+w* \+w que|strong="H3588"\+w* \+w Yo|strong="H3588"\+w* soy \+nd \+w Yavé|strong="H3068"\+w*\+nd* \+w cuando|strong="H3588"\+w* extienda \+w mi|strong="H5921"\+w* \+w mano|strong="H3027"\+w* \+w sobre|strong="H5921"\+w* \+w Egipto|strong="H4714"\+w* \+w y|strong="H3588"\+w* \+w saque|strong="H3318"\+w* \+w a|strong="H3068"\+w* \+w los|strong="H1121"\+w* \+w hijos|strong="H1121"\+w* \+w de|strong="H5921"\+w* \+w Israel|strong="H3478"\+w* \+w de|strong="H5921"\+w* \+w en|strong="H5921"\+w* \+w medio|strong="H8432"\+w* \+w de|strong="H5921"\+w* \+w ellos|strong="H3027"\+w*.\wj*   
\p
\v 6 \w Moisés|strong="H4872"\w* y Aarón \w hicieron|strong="H6213"\w* \w como|strong="H3651"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w les|strong="H6680"\w* \w ordenó|strong="H6680"\w*. \w Así|strong="H3651"\w* \w hicieron|strong="H6213"\w*.   
\p
\v 7 \w Moisés|strong="H4872"\w* tenía 80 \w años|strong="H8141"\w* y Aarón 83 cuando \w hablaron|strong="H1696"\w* \w a|strong="H3068"\w* \w Faraón|strong="H6547"\w*.   
\p
\v 8 \nd \+w Yavé|strong="H3068"\+w*\nd* habló \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w* y \w a|strong="H3068"\w* Aarón:  
\v 9 \wj \+w Cuando|strong="H3588"\+w* \+w Faraón|strong="H6547"\+w* les \+w hable|strong="H1696"\+w*: Hagan un prodigio, \+w entonces|strong="H3588"\+w* \+w dirás|strong="H1696"\+w* \+w a|strong="H3068"\+w* Aarón: \+w Toma|strong="H3947"\+w* tu \+w vara|strong="H4294"\+w* \+w y|strong="H3588"\+w* échala \+w delante|strong="H6440"\+w* \+w de|strong="H3588"\+w* \+w Faraón|strong="H6547"\+w* \+w para|strong="H3588"\+w* \+w que|strong="H3588"\+w* \+w se|strong="H1961"\+w* convierta \+w en|strong="H3588"\+w* una serpiente.\wj*   
\p
\v 10 \w Moisés|strong="H4872"\w* y Aarón \w fueron|strong="H1961"\w* \w a|strong="H3068"\w* \w Faraón|strong="H6547"\w* \w e|strong="H3068"\w* \w hicieron|strong="H6213"\w* \w como|strong="H1961"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w ordenó|strong="H6680"\w*. Aarón \w echó|strong="H7993"\w* su \w vara|strong="H4294"\w* \w ante|strong="H6440"\w* \w Faraón|strong="H6547"\w* y sus esclavos, y \w se|strong="H1961"\w* convirtió en serpiente.   
\p
\v 11 \w Faraón|strong="H6547"\w* \w también|strong="H1571"\w* \w llamó|strong="H7121"\w* \w sabios|strong="H2450"\w* \w y|strong="H1571"\w* hechiceros. \w Los|strong="H1992"\w* hechiceros de \w Egipto|strong="H4714"\w* \w también|strong="H1571"\w* \w hicieron|strong="H6213"\w* \w lo|strong="H6213"\w* \w mismo|strong="H1571"\w* \w con|strong="H1571"\w* \w sus|strong="H1992"\w* \w encantamientos|strong="H3858"\w*,  
\v 12 \w pues|strong="H1961"\w* cada uno \w echó|strong="H7993"\w* su \w vara|strong="H4294"\w* y \w se|strong="H1961"\w* convirtieron en serpientes. Sin embargo, la \w vara|strong="H4294"\w* de Aarón \w devoró|strong="H1104"\w* las \w varas|strong="H4294"\w* de ellos.   
\p
\v 13 \w Y|strong="H3068"\w* tal como \nd \+w Yavé|strong="H3068"\+w*\nd* \w dijo|strong="H1696"\w*, el \w corazón|strong="H3820"\w* de \w Faraón|strong="H6547"\w* \w se|strong="H3808"\w* \w endureció|strong="H2388"\w* y \w no|strong="H3808"\w* los \w escuchó|strong="H8085"\w*.   
\s1 Comienzo de plagas  
\p
\v 14 Entonces \nd \+w Yavé|strong="H3068"\+w*\nd* dijo \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: \wj El \+w corazón|strong="H3820"\+w* \+w de|strong="H5971"\+w* \+w Faraón|strong="H6547"\+w* \+w se|strong="H5971"\+w* endureció y \+w no|strong="H3985"\+w* \+w quiere|strong="H3985"\+w* dejar \+w que|strong="H5971"\+w* el \+w pueblo|strong="H5971"\+w* \+w se|strong="H5971"\+w* vaya.\wj*  
\v 15 \wj \+w Vé|strong="H3212"\+w* \+w a|strong="H3068"\+w* \+w Faraón|strong="H6547"\+w* \+w por|strong="H5921"\+w* \+w la|strong="H5921"\+w* \+w mañana|strong="H1242"\+w* cuando \+w él|strong="H5921"\+w* \+w sale|strong="H3318"\+w* \+w al|strong="H5921"\+w* \+w agua|strong="H4325"\+w*, \+w y|strong="H5921"\+w* ubícate \+w en|strong="H5921"\+w* \+w la|strong="H5921"\+w* orilla \+w del|strong="H5921"\+w* Nilo. \+w Lleva|strong="H3212"\+w* \+w en|strong="H5921"\+w* tu \+w mano|strong="H3027"\+w* \+w la|strong="H5921"\+w* \+w vara|strong="H4294"\+w* \+w que|strong="H5921"\+w* \+w se|strong="H5921"\+w* convirtió \+w en|strong="H5921"\+w* \+w serpiente|strong="H5175"\+w*\wj*  
\v 16 \wj \+w y|strong="H5704"\+w* dile: \+nd \+w Yavé|strong="H3068"\+w*\+nd*, el \+nd ʼElohim\+nd* \+w de|strong="H5704"\+w* los \+w hebreos|strong="H5680"\+w*, \+w me|strong="H3541"\+w* \+w envió|strong="H7971"\+w* \+w a|strong="H3068"\+w* ti \+w para|strong="H5704"\+w* decirte: \+w Deja|strong="H7971"\+w* salir \+w a|strong="H3068"\+w* \+w mi|strong="H2009"\+w* \+w pueblo|strong="H5971"\+w* \+w para|strong="H5704"\+w* \+w que|strong="H3808"\+w* \+w me|strong="H3541"\+w* \+w sirva|strong="H5647"\+w* \+w en|strong="H5704"\+w* el \+w desierto|strong="H4057"\+w*. Pero \+w en|strong="H5704"\+w* verdad \+w no|strong="H3808"\+w* has obedecido \+w hasta|strong="H5704"\+w* \+w ahora|strong="H3541"\+w*.\wj*   
\p
\v 17 \nd \+w Yavé|strong="H3068"\+w*\nd* dice: \wj \+w Por|strong="H5921"\+w* \+w esto|strong="H2063"\+w* \+w sabrás|strong="H3045"\+w* \+w que|strong="H3588"\+w* \+w Yo|strong="H3588"\+w* soy \+nd \+w Yavé|strong="H3068"\+w*\+nd*. \+w Mira|strong="H2009"\+w*, golpearé \+w el|strong="H5921"\+w* \+w agua|strong="H4325"\+w* \+w del|strong="H5921"\+w* Nilo \+w con|strong="H5921"\+w* \+w la|strong="H5921"\+w* \+w vara|strong="H4294"\+w* \+w que|strong="H3588"\+w* \+w tengo|strong="H5921"\+w* \+w en|strong="H5921"\+w* \+w mi|strong="H5921"\+w* \+w mano|strong="H3027"\+w*, \+w y|strong="H3588"\+w* \+w se|strong="H3045"\+w* convertirá \+w en|strong="H5921"\+w* \+w sangre|strong="H1818"\+w*.\wj*  
\v 18 \wj Los \+w peces|strong="H1710"\+w* \+w que|strong="H4480"\+w* están \+w en|strong="H4480"\+w* \+w el|strong="H2975"\+w* Nilo \+w morirán|strong="H4191"\+w*, \+w el|strong="H2975"\+w* \+w río|strong="H2975"\+w* hederá, y los \+w egipcios|strong="H4713"\+w* tendrán asco \+w de|strong="H4480"\+w* \+w beber|strong="H8354"\+w* \+w agua|strong="H4325"\+w* \+w del|strong="H4480"\+w* Nilo.\wj*   
\p
\v 19 \nd \+w Yavé|strong="H3068"\+w*\nd* dijo \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: \wj Dí \+w a|strong="H3068"\+w* Aarón: \+w Toma|strong="H3947"\+w* tu \+w vara|strong="H4294"\+w* \+w y|strong="H5921"\+w* \+w extiende|strong="H5186"\+w* tu \+w mano|strong="H3027"\+w* \+w sobre|strong="H5921"\+w* \+w las|strong="H5921"\+w* \+w aguas|strong="H4325"\+w* \+w de|strong="H5921"\+w* \+w Egipto|strong="H4714"\+w*, sus \+w ríos|strong="H2975"\+w*, sus \+w arroyos|strong="H2975"\+w*, sus pozos, sus estanques \+w y|strong="H5921"\+w* \+w todos|strong="H3605"\+w* sus depósitos \+w de|strong="H5921"\+w* \+w agua|strong="H4325"\+w* \+w para|strong="H5921"\+w* \+w que|strong="H5921"\+w* \+w se|strong="H1961"\+w* conviertan \+w en|strong="H5921"\+w* \+w sangre|strong="H1818"\+w*. \+w Haya|strong="H1961"\+w* \+w sangre|strong="H1818"\+w* \+w por|strong="H5921"\+w* \+w toda|strong="H3605"\+w* \+w la|strong="H5921"\+w* tierra \+w de|strong="H5921"\+w* \+w Egipto|strong="H4714"\+w* \+w tanto|strong="H5921"\+w* \+w en|strong="H5921"\+w* \+w las|strong="H5921"\+w* \+w vasijas|strong="H3605"\+w* \+w de|strong="H5921"\+w* \+w madera|strong="H6086"\+w* \+w como|strong="H1961"\+w* \+w en|strong="H5921"\+w* \+w las|strong="H5921"\+w* \+w de|strong="H5921"\+w* piedra.\wj*   
\p
\v 20 \w Moisés|strong="H4872"\w* y Aarón \w hicieron|strong="H6213"\w* \w lo|strong="H6213"\w* \w que|strong="H4325"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w ordenó|strong="H6680"\w*. \w Él|strong="H3605"\w* \w alzó|strong="H7311"\w* \w la|strong="H3605"\w* \w vara|strong="H4294"\w* y golpeó las \w aguas|strong="H4325"\w* \w que|strong="H4325"\w* \w estaban|strong="H4325"\w* \w en|strong="H5221"\w* \w el|strong="H3605"\w* Nilo \w delante|strong="H5869"\w* \w de|strong="H1818"\w* \w Faraón|strong="H6547"\w* y \w de|strong="H1818"\w* sus esclavos. \w Y|strong="H3068"\w* \w todas|strong="H3605"\w* las \w aguas|strong="H4325"\w* del Nilo \w se|strong="H3651"\w* convirtieron \w en|strong="H5221"\w* \w sangre|strong="H1818"\w*.  
\v 21 \w Los|strong="H3605"\w* \w peces|strong="H1710"\w* \w que|strong="H4480"\w* \w estaban|strong="H1961"\w* \w en|strong="H4480"\w* \w el|strong="H3605"\w* Nilo \w murieron|strong="H4191"\w* y \w el|strong="H3605"\w* \w río|strong="H2975"\w* hedió. \w Los|strong="H3605"\w* \w egipcios|strong="H4713"\w* \w no|strong="H3808"\w* \w pudieron|strong="H3201"\w* \w beber|strong="H8354"\w* \w el|strong="H3605"\w* \w agua|strong="H4325"\w* \w del|strong="H4480"\w* Nilo. \w Hubo|strong="H1961"\w* \w sangre|strong="H1818"\w* \w por|strong="H4480"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* tierra \w de|strong="H4480"\w* \w Egipto|strong="H4714"\w*.   
\p
\v 22 Pero los hechiceros de \w Egipto|strong="H4714"\w* \w hicieron|strong="H6213"\w* \w lo|strong="H3808"\w* mismo con sus encantamientos. \w Tal|strong="H3651"\w* \w como|strong="H3651"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w lo|strong="H3808"\w* predijo, \w el|strong="H6213"\w* \w corazón|strong="H3820"\w* de \w Faraón|strong="H6547"\w* \w se|strong="H3808"\w* \w endureció|strong="H2388"\w*, y \w no|strong="H3808"\w* los \w escuchó|strong="H8085"\w*.   
\p
\v 23 \w Faraón|strong="H6547"\w* regresó \w a|strong="H3068"\w* su palacio \w sin|strong="H3808"\w* alguna preocupación sobre \w esto|strong="H2063"\w*.  
\v 24 \w Todos|strong="H3605"\w* \w los|strong="H3605"\w* \w egipcios|strong="H4713"\w* excavaron pozos \w alrededor|strong="H5439"\w* \w del|strong="H8354"\w* Nilo \w para|strong="H3588"\w* \w beber|strong="H8354"\w* \w agua|strong="H4325"\w*, \w porque|strong="H3588"\w* \w no|strong="H3808"\w* \w podían|strong="H3201"\w* \w beber|strong="H8354"\w* \w agua|strong="H4325"\w* \w del|strong="H8354"\w* Nilo.   
\p
\v 25 \w Siete|strong="H7651"\w* \w días|strong="H3117"\w* transcurrieron después \w que|strong="H3117"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* golpeó \w el|strong="H2975"\w* Nilo.   
\c 8  
\s1 Segunda, tercera y cuarta plagas  
\p
\v 1 Entonces \nd \+w Yavé|strong="H3068"\+w*\nd* dijo \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: \wj Entra \+w a|strong="H3068"\+w* Faraón \+w y|strong="H5921"\+w* dile: \+nd \+w Yavé|strong="H3068"\+w*\+nd* dice Deja salir \+w a|strong="H3068"\+w* \+w mi|strong="H5921"\+w* pueblo \+w para|strong="H5921"\+w* \+w que|strong="H5921"\+w* \+w me|strong="H5921"\+w* sirva.\wj*  
\v 2 \wj \+w Si|strong="H5921"\+w* \+w te|strong="H5921"\+w* niegas \+w a|strong="H3068"\+w* dejarlo ir, ciertamente Yo castigaré todo tu territorio \+w con|strong="H5921"\+w* una plaga \+w de|strong="H5921"\+w* \+w ranas|strong="H6854"\+w*.\wj*  
\v 3 \wj \+w El|strong="H5921"\+w* Nilo bullirá \+w de|strong="H5921"\+w* \+w ranas|strong="H6854"\+w*, \+w las|strong="H5921"\+w* cuales \+w subirán|strong="H5927"\+w* \+w y|strong="H5921"\+w* penetrarán \+w en|strong="H5921"\+w* \+w tu|strong="H6213"\+w* palacio, \+w en|strong="H5921"\+w* \+w tu|strong="H6213"\+w* dormitorio \+w y|strong="H5921"\+w* \+w sobre|strong="H5921"\+w* \+w tu|strong="H6213"\+w* propio lecho, \+w así|strong="H3651"\+w* \+w como|strong="H5921"\+w* \+w en|strong="H5921"\+w* \+w las|strong="H5921"\+w* casas \+w de|strong="H5921"\+w* tus esclavos, \+w entre|strong="H5921"\+w* \+w tu|strong="H6213"\+w* pueblo, \+w en|strong="H5921"\+w* tus hornos \+w y|strong="H5921"\+w* \+w en|strong="H5921"\+w* tus artesas \+w de|strong="H5921"\+w* amasar. \wj*  
\v 4 \wj Las \+w ranas|strong="H6854"\+w* subirán \+w sobre|strong="H4480"\+w* \+w ti|strong="H4480"\+w*, tu \+w pueblo|strong="H5971"\+w* y todos tus esclavos. \wj*   
\p
\v 5 \nd \+w Yavé|strong="H3068"\+w*\nd* dijo \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: \wj Dí \+w a|strong="H3068"\+w* Aarón: Extiende tu mano \+w con|strong="H5921"\+w* tu vara \+w sobre|strong="H5921"\+w* \+w los|strong="H5921"\+w* \+w ríos|strong="H2975"\+w*, \+w los|strong="H5921"\+w* \+w arroyos|strong="H2975"\+w* \+w y|strong="H5921"\+w* \+w los|strong="H5921"\+w* estanques. \+w Haz|strong="H3772"\+w* \+w que|strong="H4480"\+w* suban \+w ranas|strong="H6854"\+w* \+w sobre|strong="H5921"\+w* \+w la|strong="H5921"\+w* tierra \+w de|strong="H4480"\+w* Egipto. \wj*   
\p
\v 6 Aarón extendió \w su|strong="H3588"\w* mano sobre las aguas \w de|strong="H3588"\w* Egipto, \w y|strong="H3588"\w* subieron las ranas \w que|strong="H3588"\w* cubrieron \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* Egipto.  
\v 7 Los hechiceros hicieron lo mismo \w con|strong="H4480"\w* sus encantamientos, \w e|strong="H3068"\w* hicieron subir \w ranas|strong="H6854"\w* \w sobre|strong="H4480"\w* la tierra \w de|strong="H4480"\w* Egipto.   
\p
\v 8 Entonces \w Faraón|strong="H6547"\w* llamó \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w* \w y|strong="H5921"\w* \w a|strong="H3068"\w* Aarón \w y|strong="H5921"\w* \w les|strong="H5973"\w* dijo: Supliquen \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w que|strong="H5921"\w* quite \w las|strong="H5921"\w* \w ranas|strong="H6854"\w* \w de|strong="H5921"\w* \w mí|strong="H5921"\w* \w y|strong="H5921"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w pueblo|strong="H5973"\w*, \w y|strong="H5921"\w* dejaré ir \w al|strong="H5921"\w* \w pueblo|strong="H5973"\w* \w para|strong="H5921"\w* \w que|strong="H5921"\w* ofrezca sacrificio \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.   
\p
\v 9 \w Moisés|strong="H4872"\w* dijo \w a|strong="H3068"\w* Faraón: Dígnate indicarme cuándo debo suplicar \w por|strong="H4480"\w* \w ti|strong="H4480"\w*, \w por|strong="H4480"\w* tus esclavos y \w por|strong="H4480"\w* \w tu|strong="H6213"\w* pueblo, \w para|strong="H4480"\w* \w que|strong="H4480"\w* las \w ranas|strong="H6854"\w* sean quitadas \w de|strong="H4480"\w* \w ti|strong="H4480"\w* y \w de|strong="H4480"\w* tus \w casas|strong="H1004"\w*, y sean dejadas solo \w en|strong="H4480"\w* \w el|strong="H6213"\w* Nilo.   
\p
\v 10 \w Y|strong="H3068"\w* él dijo: Mañana.  
\p \w Y|strong="H3068"\w* Moisés respondió: Se hará conforme \w a|strong="H3068"\w* tu palabra, para que entiendas que no hay como \nd \+w Yavé|strong="H3068"\+w*\nd* nuestro \nd ʼElohim\nd*.  
\v 11 \w Se|strong="H1961"\w* retirarán las ranas \w de|strong="H3588"\w* ti, \w de|strong="H3588"\w* tus casas, \w de|strong="H3588"\w* tus esclavos \w y|strong="H3588"\w* \w de|strong="H3588"\w* tu pueblo. Solo \w serán|strong="H1961"\w* dejadas \w en|strong="H3588"\w* \w el|strong="H3588"\w* Nilo.   
\p
\v 12 \w Moisés|strong="H4872"\w* y Aarón salieron de \w la|strong="H3605"\w* presencia de Faraón. \w Moisés|strong="H4872"\w* clamó \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* por \w el|strong="H3605"\w* asunto de las ranas \w que|strong="H1961"\w* \w Él|strong="H3605"\w* envió \w sobre|strong="H1961"\w* Faraón.  
\v 13 \nd \+w Yavé|strong="H3068"\+w*\nd* \w hizo|strong="H6213"\w* conforme \w a|strong="H3068"\w* \w la|strong="H3605"\w* súplica de Moisés, y murieron las ranas de las casas, de \w los|strong="H3605"\w* patios y de \w los|strong="H3605"\w* campos.  
\v 14 Las \w pusieron|strong="H6213"\w* \w en|strong="H3318"\w* grandes montones, y \w el|strong="H6213"\w* país hedía.  
\v 15 Pero cuando \w Faraón|strong="H6547"\w* vio \w que|strong="H1931"\w* había un alivio, \w endureció|strong="H2388"\w* \w su|strong="H1931"\w* \w corazón|strong="H3820"\w* y \w no|strong="H3808"\w* \w los|strong="H1931"\w* \w escuchó|strong="H8085"\w*, \w como|strong="H1931"\w* \w dijo|strong="H1696"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.   
\p
\v 16 Entonces \nd \+w Yavé|strong="H3068"\+w*\nd* dijo \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: \wj Dí \+w a|strong="H3068"\+w* Aarón: \+w Extiende|strong="H7971"\+w* tu vara \+w y|strong="H3541"\+w* golpea el polvo \+w de|strong="H6440"\+w* la tierra \+w para|strong="H3320"\+w* \+w que|strong="H5971"\+w* haya piojos \+w en|strong="H3318"\+w* toda la tierra \+w de|strong="H6440"\+w* Egipto. \wj*   
\p
\v 17 \w Y|strong="H3068"\w* \w ellos|strong="H1992"\w* \w lo|strong="H5921"\w* hicieron \w así|strong="H1571"\w*. Aarón \w extendió|strong="H7971"\w* \w su|strong="H1992"\w* mano \w con|strong="H5921"\w* \w su|strong="H1992"\w* vara, \w y|strong="H1571"\w* golpeó \w el|strong="H5921"\w* polvo \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra. Hubo piojos \w sobre|strong="H5921"\w* hombres \w y|strong="H1571"\w* bestias. ¡Todo \w el|strong="H5921"\w* polvo \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w se|strong="H5921"\w* convirtió \w en|strong="H5921"\w* piojos \w en|strong="H5921"\w* todo \w el|strong="H5921"\w* país \w de|strong="H5921"\w* Egipto!  
\v 18 \w Los|strong="H5921"\w* hechiceros intentaron sacar \w los|strong="H5921"\w* piojos \w con|strong="H5921"\w* \w sus|strong="H1931"\w* encantamientos, \w pero|strong="H3588"\w* \w no|strong="H3588"\w* pudieron.  
\p \w Así|strong="H3588"\w* \w que|strong="H3588"\w* \w hubo|strong="H1961"\w* piojos \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* hombres \w y|strong="H3588"\w* \w las|strong="H5921"\w* bestias.   
\p
\v 19 Entonces \w los|strong="H1961"\w* hechiceros dijeron \w a|strong="H3068"\w* Faraón: ¡\w Esto|strong="H2088"\w* \w es|strong="H1961"\w* el dedo \w de|strong="H5971"\w* \nd ʼElohim\nd*! Pero el corazón \w de|strong="H5971"\w* Faraón \w se|strong="H1961"\w* endureció, y \w no|strong="H1961"\w* \w los|strong="H1961"\w* escuchó, \w como|strong="H1961"\w* dijo \nd \+w Yavé|strong="H3068"\+w*\nd*.   
\p
\v 20 \nd \+w Yavé|strong="H3068"\+w*\nd* dijo \w a|strong="H3068"\w* Moisés: \wj Levántate temprano \+w por|strong="H6440"\+w* \+w la|strong="H3605"\+w* mañana, preséntate \+w ante|strong="H6440"\+w* \+w Faraón|strong="H6547"\+w* \+w cuando|strong="H5650"\+w* sale al agua y dile: \+nd \+w Yavé|strong="H3068"\+w*\+nd* dice: Deja salir \+w a|strong="H3068"\+w* mi pueblo para \+w que|strong="H3605"\+w* me sirva. \wj*  
\v 21 \wj Porque si no dejas salir \+w a|strong="H3068"\+w* mi pueblo, ciertamente enviaré una multitud de moscas sobre ti, tus esclavos, tu pueblo y tus casas. Las casas de los egipcios estarán llenas de podredumbre de moscas y también la tierra sobre la cual están. \wj*   
\p
\v 22 \wj \+w Sin|strong="H3808"\+w* embargo, \+w el|strong="H3588"\+w* mismo día excluiré \+w la|strong="H3588"\+w* tierra \+w de|strong="H3588"\+w* Gosén \+w en|strong="H3588"\+w* \+w la|strong="H3588"\+w* \+w cual|strong="H3588"\+w* vive mi pueblo \+w para|strong="H3588"\+w* \+w que|strong="H3588"\+w* \+w no|strong="H3808"\+w* haya multitud \+w de|strong="H3588"\+w* moscas \+w en|strong="H3588"\+w* ella, \+w y|strong="H3588"\+w* \+w así|strong="H3651"\+w* entenderás \+w que|strong="H3588"\+w* \+w Yo|strong="H3588"\+w*, \+nd \+w Yavé|strong="H3068"\+w*\+nd*, estoy \+w en|strong="H3588"\+w* medio \+w de|strong="H3588"\+w* \+w esta|strong="H3651"\+w* tierra. \wj*  
\v 23 \wj Yo haré división entre mi pueblo y tu pueblo. Mañana ocurrirá esta señal.\wj*   
\p
\v 24 Así \nd \+w Yavé|strong="H3068"\+w*\nd* \w lo|strong="H3808"\w* hizo. \w Llegó|strong="H3212"\w* una gran multitud de moscas \w a|strong="H3068"\w* la casa de \w Faraón|strong="H6547"\w* y \w a|strong="H3068"\w* las casas de sus esclavos. \w En|strong="H3212"\w* todo el país de Egipto la tierra \w se|strong="H3808"\w* corrompió \w por|strong="H1157"\w* causa de la multitud de moscas.   
\p
\v 25 \w Entonces|strong="H5493"\w* \w Faraón|strong="H6547"\w* llamó \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w* y \w a|strong="H3068"\w* Aarón y \w les|strong="H5973"\w* dijo: Vayan, ofrezcan sacrificio \w a|strong="H3068"\w* su \nd ʼElohim\nd* dentro \w del|strong="H5973"\w* país.   
\p
\v 26 Pero \w Moisés|strong="H4872"\w* respondió: No es correcto hacerlo \w así|strong="H5973"\w*, porque ofreceríamos sacrificio \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* nuestro \nd ʼElohim,\nd* lo \w cual|strong="H5973"\w* es repugnancia \w para|strong="H5973"\w* \w los|strong="H5973"\w* egipcios. Si sacrificamos lo que es una repugnancia \w para|strong="H5973"\w* \w los|strong="H5973"\w* egipcios \w delante|strong="H5973"\w* \w de|strong="H5973"\w* ellos, ¿no nos apedrearían?  
\v 27 Tenemos \w que|strong="H3808"\w* \w hacer|strong="H6213"\w* una jornada \w de|strong="H5971"\w* tres días \w por|strong="H1697"\w* \w el|strong="H6213"\w* desierto y ofreceremos sacrificio \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* nuestro \nd ʼElohim\nd*, según \w lo|strong="H1697"\w* \w que|strong="H3808"\w* \w Él|strong="H6213"\w* nos manda.   
\p
\v 28 \w Faraón|strong="H6547"\w* respondió: Los \w dejaré|strong="H7971"\w* salir \w para|strong="H5971"\w* \w que|strong="H3808"\w* ofrezcan sacrificio \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* su \nd ʼElohim\nd* en \w el|strong="H1571"\w* desierto, \w con|strong="H1571"\w* \w tal|strong="H2063"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* vayan \w más|strong="H1571"\w* lejos. ¡Supliquen por mí!   
\p
\v 29 Entonces Moisés dijo: Ciertamente voy \w a|strong="H3068"\w* salir de tu presencia y suplicaré \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* que la multitud de moscas se aparte mañana de Faraón, de sus esclavos y de su pueblo, con tal que Faraón no siga engañándome al impedir al pueblo que salga \w a|strong="H3068"\w* ofrecer sacrificios \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.   
\p
\v 30 Moisés salió de la presencia de Faraón y suplicó \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.  
\v 31 \nd \+w Yavé|strong="H3068"\+w*\nd* hizo conforme \w a|strong="H3068"\w* la palabra de Moisés y apartó las moscas de Faraón, de sus esclavos y de su pueblo. No quedó ni una.  
\v 32 Sin embargo Faraón endureció su corazón también esta vez, y no dejó salir al pueblo.   
\c 9  
\s1 Quinta, sexta y séptima plagas  
\p
\v 1 Entonces \nd \+w Yavé|strong="H3068"\+w*\nd* \w dijo|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: \wj Vé \+w a|strong="H3068"\+w* \+w Faraón|strong="H6547"\+w* \+w y|strong="H3541"\+w* dile: \+nd \+w Yavé|strong="H3068"\+w*\+nd* el \+nd ʼElohim\+nd* \+w de|strong="H5971"\+w* los \+w hebreos|strong="H5680"\+w* \+w dice|strong="H1696"\+w*: \+w Deja|strong="H7971"\+w* \+w ir|strong="H7971"\+w* \+w a|strong="H3068"\+w* mi \+w pueblo|strong="H5971"\+w* \+w para|strong="H5971"\+w* \+w que|strong="H5971"\+w* \+w me|strong="H3541"\+w* \+w sirva|strong="H5647"\+w*,\wj*  
\v 2 \wj \+w porque|strong="H3588"\+w* \+w si|strong="H3588"\+w* tú rehúsas dejarlos \+w ir|strong="H7971"\+w* \+w y|strong="H3588"\+w* continúas \+w la|strong="H3588"\+w* retención \+w de|strong="H3588"\+w* ellos,\wj*  
\v 3 \wj \+w ciertamente|strong="H2009"\+w* la \+w mano|strong="H3027"\+w* de \+nd \+w Yavé|strong="H3068"\+w*\+nd* \+w vendrá|strong="H1961"\+w* con una peste \+w muy|strong="H3966"\+w* severa \+w sobre|strong="H3515"\+w* tus \+w ganados|strong="H4735"\+w* \+w que|strong="H1961"\+w* \+w están|strong="H1961"\+w* en el \+w campo|strong="H7704"\+w*, \+w los|strong="H1961"\+w* \+w caballos|strong="H5483"\+w*, \+w los|strong="H1961"\+w* \+w asnos|strong="H2543"\+w*, \+w los|strong="H1961"\+w* \+w camellos|strong="H1581"\+w*, la manada de \+w ganado|strong="H4735"\+w* \+w vacuno|strong="H1241"\+w* \+w y|strong="H1241"\+w* \+w los|strong="H1961"\+w* rebaños.\wj*  
\v 4 \wj Pero \+nd \+w Yavé|strong="H3068"\+w*\+nd* hará distinción \+w entre|strong="H3808"\+w* \+w los|strong="H1121"\+w* \+w ganados|strong="H4735"\+w* \+w de|strong="H1121"\+w* \+w Israel|strong="H3478"\+w* y \+w los|strong="H1121"\+w* \+w ganados|strong="H4735"\+w* \+w de|strong="H1121"\+w* \+w Egipto|strong="H4714"\+w*, y \+w nada|strong="H3808"\+w* \+w morirá|strong="H4191"\+w* \+w de|strong="H1121"\+w* \+w todo|strong="H3605"\+w* \+w lo|strong="H1697"\+w* \+w que|strong="H3808"\+w* pertenece \+w a|strong="H3068"\+w* \+w los|strong="H1121"\+w* \+w hijos|strong="H1121"\+w* \+w de|strong="H1121"\+w* \+w Israel|strong="H3478"\+w*.\wj*   
\p
\v 5 \nd \+w Yavé|strong="H3068"\+w*\nd* fijó plazo y dijo: \wj \+w Mañana|strong="H4279"\+w* \+nd \+w Yavé|strong="H3068"\+w*\+nd* \+w hará|strong="H6213"\+w* \+w esto|strong="H2088"\+w* en la tierra.\wj*   
\p
\v 6 Al \w día|strong="H1121"\w* \w siguiente|strong="H4283"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w hizo|strong="H6213"\w* \w esto|strong="H2088"\w*, y \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w ganado|strong="H4735"\w* \w de|strong="H1121"\w* Egipto \w murió|strong="H4191"\w*, pero del \w ganado|strong="H4735"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w ni|strong="H3808"\w* uno \w murió|strong="H4191"\w*.   
\p
\v 7 \w Faraón|strong="H6547"\w* \w envió|strong="H7971"\w* \add observadores\add*, \w y|strong="H5704"\w* \w ciertamente|strong="H4191"\w* del \w ganado|strong="H4735"\w* \w de|strong="H5704"\w* los hijos \w de|strong="H5704"\w* \w Israel|strong="H3478"\w* \w no|strong="H3808"\w* pereció \w ni|strong="H3808"\w* uno. Pero el \w corazón|strong="H3820"\w* \w de|strong="H5704"\w* \w Faraón|strong="H6547"\w* \w se|strong="H3808"\w* endureció \w y|strong="H5704"\w* \w no|strong="H3808"\w* \w dejó|strong="H7971"\w* salir \w al|strong="H5704"\w* \w pueblo|strong="H5971"\w*.   
\p
\v 8 Entonces \nd \+w Yavé|strong="H3068"\+w*\nd* dijo \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w* y \w a|strong="H3068"\w* Aarón: \wj \+w Tomen|strong="H3947"\+w* \+w puñados|strong="H2651"\+w* \+w de|strong="H5869"\+w* ceniza \+w de|strong="H5869"\+w* un horno, y que \+w Moisés|strong="H4872"\+w* la lance hacia el \+w cielo|strong="H8064"\+w* en la presencia \+w de|strong="H5869"\+w* \+w Faraón|strong="H6547"\+w*.\wj*  
\v 9 \wj \+w Se|strong="H1961"\+w* convertirá \+w en|strong="H5921"\+w* un polvo fino \+w sobre|strong="H5921"\+w* \+w toda|strong="H3605"\+w* \+w la|strong="H5921"\+w* tierra \+w de|strong="H5921"\+w* \+w Egipto|strong="H4714"\+w*, \+w el|strong="H5921"\+w* cual ocasionará un \+w sarpullido|strong="H7822"\+w* \+w que|strong="H5921"\+w* producirá úlceras \+w en|strong="H5921"\+w* hombres \+w y|strong="H5921"\+w* bestias \+w en|strong="H5921"\+w* \+w toda|strong="H3605"\+w* \+w la|strong="H5921"\+w* tierra \+w de|strong="H5921"\+w* \+w Egipto|strong="H4714"\+w*.\wj*   
\p
\v 10 Entonces \w tomaron|strong="H3947"\w* la ceniza \w de|strong="H6440"\w* un horno y \w se|strong="H1961"\w* presentaron \w ante|strong="H6440"\w* \w Faraón|strong="H6547"\w*. \w Moisés|strong="H4872"\w* la lanzó \w hacia|strong="H6440"\w* el \w cielo|strong="H8064"\w* y \w se|strong="H1961"\w* formó un \w sarpullido|strong="H7822"\w* \w que|strong="H1961"\w* produjo úlceras \w en|strong="H5975"\w* \w los|strong="H1961"\w* hombres y \w en|strong="H5975"\w* las bestias.  
\v 11 \w Los|strong="H3605"\w* hechiceros \w no|strong="H3808"\w* \w pudieron|strong="H3201"\w* permanecer \w en|strong="H3588"\w* \w la|strong="H3588"\w* \w presencia|strong="H6440"\w* \w de|strong="H3588"\w* \w Moisés|strong="H4872"\w* \w a|strong="H3068"\w* \w causa|strong="H6440"\w* \w de|strong="H3588"\w* las úlceras, \w pues|strong="H3588"\w* \w había|strong="H1961"\w* úlceras \w en|strong="H3588"\w* \w los|strong="H3605"\w* hechiceros \w y|strong="H3588"\w* \w en|strong="H3588"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w egipcios|strong="H4713"\w*.   
\p
\v 12 Pero \nd \+w Yavé|strong="H3068"\+w*\nd* \w endureció|strong="H2388"\w* el \w corazón|strong="H3820"\w* de \w Faraón|strong="H6547"\w*, y \w no|strong="H3808"\w* los \w escuchó|strong="H8085"\w*, según \nd \+w Yavé|strong="H3068"\+w*\nd* predijo \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*.   
\p
\v 13 Entonces \nd \+w Yavé|strong="H3068"\+w*\nd* dijo \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: \wj \+w Levántate|strong="H7925"\+w* \+w de|strong="H6440"\+w* \+w mañana|strong="H1242"\+w* \+w y|strong="H3541"\+w* preséntate \+w a|strong="H3068"\+w* \+w Faraón|strong="H6547"\+w* \+w y|strong="H3541"\+w* dile: \+nd \+w Yavé|strong="H3068"\+w*\+nd* el \+nd ʼElohim\+nd* \+w de|strong="H6440"\+w* los \+w hebreos|strong="H5680"\+w* dice: \+w Deja|strong="H7971"\+w* \+w ir|strong="H7971"\+w* \+w a|strong="H3068"\+w* mi \+w pueblo|strong="H5971"\+w* \+w para|strong="H3320"\+w* \+w que|strong="H5971"\+w* \+w me|strong="H3541"\+w* \+w sirva|strong="H5647"\+w*,\wj*  
\v 14 \wj \+w pues|strong="H3588"\+w* \+w esta|strong="H2063"\+w* \+w vez|strong="H6471"\+w* \+w Yo|strong="H3588"\+w* \+w enviaré|strong="H7971"\+w* \+w todas|strong="H3605"\+w* mis \+w plagas|strong="H4046"\+w* sobre ti, tus esclavos \+w y|strong="H3588"\+w* tu \+w pueblo|strong="H5971"\+w*, \+w para|strong="H3588"\+w* \+w que|strong="H3588"\+w* entiendas \+w que|strong="H3588"\+w* \+w no|strong="H3588"\+w* hay otro \+w como|strong="H3588"\+w* \+w Yo|strong="H3588"\+w* \+w en|strong="H3588"\+w* \+w toda|strong="H3605"\+w* \+w la|strong="H3588"\+w* tierra.\wj*   
\p
\v 15 \wj \+w Porque|strong="H3588"\+w* \+w ahora|strong="H6258"\+w* \+w Yo|strong="H4480"\+w* hubiera podido \+w extender|strong="H7971"\+w* mi \+w mano|strong="H3027"\+w* \+w para|strong="H3588"\+w* herirte \+w con|strong="H4480"\+w* \+w pestilencia|strong="H1698"\+w*, \+w a|strong="H3068"\+w* \+w ti|strong="H4480"\+w* \+w y|strong="H3588"\+w* \+w a|strong="H3068"\+w* tu \+w pueblo|strong="H5971"\+w*, \+w y|strong="H3588"\+w* serías exterminado \+w de|strong="H4480"\+w* \+w la|strong="H3588"\+w* tierra.\wj*  
\v 16 \wj Pero \+w en|strong="H5975"\+w* verdad, \+w por|strong="H4616"\+w* \+w esto|strong="H2063"\+w* te permití permanecer, \+w para|strong="H4616"\+w* mostrarte mi \+w poder|strong="H3581"\+w* y \+w para|strong="H4616"\+w* proclamar mi \+w Nombre|strong="H8034"\+w* \+w en|strong="H5975"\+w* \+w toda|strong="H3605"\+w* \+w la|strong="H2063"\+w* tierra.\wj*  
\v 17 \wj ¿\+w Aun|strong="H5750"\+w* te exaltas contra \+w mi|strong="H1115"\+w* \+w pueblo|strong="H5971"\+w* \+w para|strong="H5971"\+w* \+w no|strong="H1115"\+w* dejarlos salir?\wj*   
