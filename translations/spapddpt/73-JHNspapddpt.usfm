\c 21  
\s1 Una gran pesca  
\p
\v 1 \w Después|strong="G3326"\w* \w de|strong="G1909"\w* \w esto|strong="G3778"\w*, \w Jesús|strong="G2424"\w* \w apareció|strong="G5319"\w* \w otra|strong="G3825"\w* vez \w a|strong="G1909"\w* \w los|strong="G3588"\w* \w discípulos|strong="G3101"\w* junto \w al|strong="G3588"\w* \w mar|strong="G2281"\w* \w de|strong="G1909"\w* \w Tiberias|strong="G5085"\w*.  
\p \w Apareció|strong="G5319"\w* \w de|strong="G1909"\w* \w esta|strong="G3778"\w* \w manera|strong="G3779"\w*:  
\v 2 Estaban \w juntos|strong="G3674"\w* \w Simón|strong="G4613"\w* \w Pedro|strong="G4074"\w*, \w Tomás|strong="G2381"\w* \w el|strong="G3588"\w* Dídimo, \w Natanael|strong="G3482"\w* \w el|strong="G3588"\w* \w de|strong="G1537"\w* \w Caná|strong="G2580"\w* \w de|strong="G1537"\w* \w Galilea|strong="G1056"\w*, \w los|strong="G3588"\w* \add hijos\add* \w de|strong="G1537"\w* \w Zebedeo|strong="G2199"\w* \w y|strong="G2532"\w* \w otros|strong="G3588"\w* \w dos|strong="G1417"\w* \w de|strong="G1537"\w* \w sus|strong="G3588"\w* \w discípulos|strong="G3101"\w*.   
