\q2 agali ko uruni homai helabe.   
\q1
\v 9 Agalime ira emene karu dibu waharadagua  
\q2 Ngode Datagaliwabehanda agali ko uruni abale bo wahai holebira.  
\q1 Ti homa nabi kaore  
\q2 Ngode Datagaliwabehanda tihondo keba timbuni halu  
\q2 durumbu hilo waharadagua bulebira.   
\b  
\q1
\v 10 Ngode Datagaliwabehanda ko biaga karu bo waharangi  
\q2 mini tigabi karume turu timbuniore ho holebira.  
\q1 Turu howa tigua ko biaga uruninaga daramame  
\q2 tininaga ge wayawaya bulebira.   
\q1
\v 11 Wali agali bu karume lalu,\x + \xo 58.11 \xt Iba 67.4, 92.7\x*  
\q1 Heneneore Ngode Datagaliwabehanda  
