\v 1 \w Ce|strong="H01697"\w* \w qui|strong="H00376"\w* \w suit|strong="H01980"\w* \w est|strong="H03068"\w* \w la|strong="H08085"\w* \w copie|strong="H06572"\w* \w de|strong="H01121"\w* \w cette|strong="H01836"\w* \w lettre|strong="H05612"\w* :  
\p « \w Assuérus|strong="H00325"\w*, \w le|strong="H00559"\w* \w grand|strong="H01419"\w* \w roi|strong="H04428"\w*, \w aux|strong="H00559"\w* \w satrapes|strong="H00324"\w* \w et|strong="H04872"\w* \w aux|strong="H00559"\w* \w chefs|strong="H08269"\w* \w des|strong="H03068"\w* \w cent|strong="H03967"\w* vingt-sept \w provinces|strong="H04082"\w*, \w de|strong="H01121"\w* l’Inde \w à|strong="H00559"\w* l’Ethiopie, \w et|strong="H04872"\w* \w à|strong="H00559"\w* \w ceux|strong="H00582"\w* \w qui|strong="H00376"\w* \w ont|strong="H00001"\w* \w à|strong="H00559"\w* cœur \w nos|strong="H00947"\w* intérêts, \w salut|strong="H03444"\w* !   
