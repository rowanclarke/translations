\v 7 \w When|strong="H3068"\w* \w they|strong="H3068"\w* burn \w each|strong="H3532"\w* \w lamb|strong="H3532"\w*, \w they|strong="H3068"\w* must \w also|strong="H3068"\w* \w pour|strong="H5258"\w* \w on|strong="H3068"\w* \w the|strong="H3068"\w* \w sacred|strong="H6944"\w* altar \w one|strong="H3532"\w* quart/liter \w of|strong="H3068"\w* \w wine|strong="H7941"\w*.
