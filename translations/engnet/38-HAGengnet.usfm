\s1 The Indifference of the People  
\p
\v 2  \w The|strong="H3541"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w who|strong="H5971"\w* rules \w over|strong="H3068"\w* \w all|strong="H3068"\w* \w says|strong="H3541"\w* \w this|strong="H2088"\w*: “\w These|strong="H2088"\w* \w people|strong="H5971"\w* \w have|strong="H3068"\w* said, ‘\w The|strong="H3541"\w* \w time|strong="H6256"\w* \w for|strong="H3068"\w* \w rebuilding|strong="H1129"\w* \w the|strong="H3541"\w* \nd \+w Lord|strong="H3068"\+w*\nd*’s \w temple|strong="H1004"\w* \w has|strong="H3068"\w* \w not|strong="H3808"\w* \w yet|strong="H3068"\w* \w come|strong="H6635"\w*.’”  
\v 3  \w So|strong="H1961"\w* \w the|strong="H3068"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w spoke|strong="H1697"\w* \w through|strong="H3027"\w* \w the|strong="H3068"\w* \w prophet|strong="H5030"\w* \w Haggai|strong="H2292"\w* \w as|strong="H1697"\w* follows:  
\v 4 “\w Is|strong="H2088"\w* \w it|strong="H6256"\w* right \w for|strong="H3427"\w* \w you|strong="H2088"\w* \w to|strong="H6256"\w* \w live|strong="H3427"\w* \w in|strong="H3427"\w* richly \w paneled|strong="H5603"\w* \w houses|strong="H1004"\w* \w while|strong="H2088"\w* \w my|strong="H2088"\w* \w temple|strong="H1004"\w* \w is|strong="H2088"\w* \w in|strong="H3427"\w* ruins?  
\v 5  \w Here|strong="H3541"\w* \w then|strong="H6258"\w* \w is|strong="H3068"\w* \w what|strong="H3541"\w* \w the|strong="H5921"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w who|strong="H3068"\w* rules \w over|strong="H5921"\w* \w all|strong="H5921"\w* \w says|strong="H3541"\w*: ‘\w Think|strong="H3824"\w* \w carefully|strong="H3824"\w* \w about|strong="H5921"\w* \w what|strong="H3541"\w* \w you|strong="H5921"\w* \w are|strong="H3068"\w* \w doing|strong="H1870"\w*.  
\v 6  \w You|strong="H7235"\w* \w have|strong="H4592"\w* \w planted|strong="H2232"\w* \w much|strong="H7235"\w*, but \w have|strong="H4592"\w* harvested \w little|strong="H4592"\w*. \w You|strong="H7235"\w* eat, but are never \w filled|strong="H7654"\w*. \w You|strong="H7235"\w* \w drink|strong="H8354"\w*, but are still \w thirsty|strong="H7937"\w*. \w You|strong="H7235"\w* \w put|strong="H3847"\w* \w on|strong="H3847"\w* \w clothes|strong="H3847"\w*, but are \w not|strong="H8354"\w* \w warm|strong="H2527"\w*. Those \w who|strong="H8354"\w* earn \w wages|strong="H7936"\w* end \w up|strong="H8354"\w* \w with|strong="H3847"\w* \w holes|strong="H5344"\w* \w in|strong="H3847"\w* \w their|strong="H8354"\w* money bags.’”   
\s1 The Instruction of the People  
\p
\v 7 “\w Moreover|strong="H3541"\w*, \w the|strong="H5921"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w who|strong="H3068"\w* rules \w over|strong="H5921"\w* \w all|strong="H5921"\w* \w says|strong="H3541"\w*: ‘\w Pay|strong="H7760"\w* \w close|strong="H3824"\w* \w attention|strong="H7760"\w* \w to|strong="H3068"\w* \w these|strong="H7760"\w* things \w also|strong="H3068"\w*.  
\v 8  \w Go|strong="H5927"\w* \w up|strong="H5927"\w* \w to|strong="H3068"\w* \w the|strong="H3068"\w* \w hill|strong="H2022"\w* \w country|strong="H2022"\w* \w and|strong="H3068"\w* \w bring|strong="H5927"\w* \w back|strong="H5927"\w* \w timber|strong="H6086"\w* \w to|strong="H3068"\w* \w build|strong="H1129"\w* \w the|strong="H3068"\w* \w temple|strong="H1004"\w*. \w Then|strong="H5927"\w* \w I|strong="H3068"\w* \w will|strong="H3068"\w* \w be|strong="H3068"\w* \w pleased|strong="H7521"\w* \w and|strong="H3068"\w* \w honored|strong="H3513"\w*,’ says \w the|strong="H3068"\w* \nd \+w Lord|strong="H3068"\+w*\nd*.  
\v 9 ‘\w You|strong="H4100"\w* expected \w a|strong="H3068"\w* \w large|strong="H7235"\w* harvest, \w but|strong="H2009"\w* \w instead|strong="H2009"\w* \w there|strong="H2009"\w* \w was|strong="H3068"\w* \w little|strong="H4592"\w*, \w and|strong="H3068"\w* \w when|strong="H3068"\w* \w you|strong="H4100"\w* \w brought|strong="H3068"\w* \w it|strong="H1931"\w* \w home|strong="H1004"\w* \w it|strong="H1931"\w* disappeared \w right|strong="H3068"\w* \w away|strong="H6437"\w*. \w Why|strong="H4100"\w*?’ \w asks|strong="H5002"\w* \w the|strong="H5002"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w who|strong="H1931"\w* rules \w over|strong="H3068"\w* \w all|strong="H2009"\w*. ‘\w Because|strong="H3282"\w* \w my|strong="H3068"\w* \w temple|strong="H1004"\w* remains \w in|strong="H3068"\w* ruins, thanks \w to|strong="H3068"\w* each \w of|strong="H1004"\w* \w you|strong="H4100"\w* \w favoring|strong="H7323"\w* \w his|strong="H3068"\w* own \w house|strong="H1004"\w*!  
\v 10  \w This|strong="H3651"\w* \w is|strong="H3651"\w* \w why|strong="H5921"\w* \w the|strong="H5921"\w* \w sky|strong="H8064"\w* \w has|strong="H8064"\w* held \w back|strong="H3607"\w* \w its|strong="H5921"\w* \w dew|strong="H2919"\w* \w and|strong="H8064"\w* \w the|strong="H5921"\w* \w earth|strong="H8064"\w* \w its|strong="H5921"\w* \w produce|strong="H2981"\w*.  
\v 11  Moreover, \w I|strong="H5921"\w* \w have|strong="H3605"\w* \w called|strong="H7121"\w* \w for|strong="H5921"\w* \w a|strong="H3068"\w* \w drought|strong="H2721"\w* \w that|strong="H3605"\w* \w will|strong="H2022"\w* affect \w the|strong="H3605"\w* fields, \w the|strong="H3605"\w* \w hill|strong="H2022"\w* \w country|strong="H2022"\w*, \w the|strong="H3605"\w* \w grain|strong="H1715"\w*, \w new|strong="H8492"\w* \w wine|strong="H8492"\w*, \w fresh|strong="H3323"\w* olive \w oil|strong="H3323"\w*, \w and|strong="H2022"\w* \w everything|strong="H3605"\w* \w that|strong="H3605"\w* \w grows|strong="H3318"\w* \w from|strong="H3318"\w* \w the|strong="H3605"\w* ground; \w it|strong="H7121"\w* \w also|strong="H3318"\w* \w will|strong="H2022"\w* harm \w people|strong="H3709"\w*, animals, \w and|strong="H2022"\w* \w everything|strong="H3605"\w* \w they|strong="H5921"\w* \w produce|strong="H3018"\w*.’”   
\s1 The Response of the People  
\p
\v 12  \w Then|strong="H7971"\w* \w Zerubbabel|strong="H2216"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Shealtiel|strong="H7597"\w* \w and|strong="H1121"\w* \w the|strong="H3605"\w* \w high|strong="H1419"\w* \w priest|strong="H3548"\w* \w Joshua|strong="H3091"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Jehozadak|strong="H3087"\w*, \w along|strong="H5921"\w* \w with|strong="H3068"\w* \w the|strong="H3605"\w* \w whole|strong="H3605"\w* \w remnant|strong="H7611"\w* \w of|strong="H1121"\w* \w the|strong="H3605"\w* \w people|strong="H5971"\w*, \w obeyed|strong="H8085"\w* \w the|strong="H3605"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w their|strong="H3605"\w* \w God|strong="H3068"\w*. \w They|strong="H3068"\w* \w responded|strong="H8085"\w* \w favorably|strong="H6963"\w* \w to|strong="H3068"\w* \w the|strong="H3605"\w* \w message|strong="H1697"\w* \w of|strong="H1121"\w* \w the|strong="H3605"\w* \w prophet|strong="H5030"\w* \w Haggai|strong="H2292"\w*, \w who|strong="H3605"\w* \w spoke|strong="H1697"\w* \w just|strong="H1697"\w* \w as|strong="H1697"\w* \w the|strong="H3605"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w their|strong="H3605"\w* \w God|strong="H3068"\w* \w had|strong="H3068"\w* \w instructed|strong="H1697"\w* \w him|strong="H6440"\w*, \w and|strong="H1121"\w* \w the|strong="H3605"\w* \w people|strong="H5971"\w* began \w to|strong="H3068"\w* \w respect|strong="H5921"\w* \w the|strong="H3605"\w* \nd \+w Lord|strong="H3068"\+w*\nd*.  
\v 13  \w Then|strong="H3068"\w* \w Haggai|strong="H2292"\w*, \w the|strong="H5002"\w* \nd \+w Lord|strong="H3068"\+w*\nd*’s \w messenger|strong="H4397"\w*, spoke \w the|strong="H5002"\w* \nd \+w Lord|strong="H3068"\+w*\nd*’s \w word|strong="H4400"\w* \w to|strong="H3068"\w* \w the|strong="H5002"\w* \w people|strong="H5971"\w*: “\w I|strong="H3068"\w* \w am|strong="H3068"\w* \w with|strong="H3068"\w* \w you|strong="H5971"\w*!” \w says|strong="H5002"\w* \w the|strong="H5002"\w* \nd \+w Lord|strong="H3068"\+w*\nd*.  
\v 14  \w So|strong="H6213"\w* \w the|strong="H3605"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w energized|strong="H7307"\w* \w and|strong="H1121"\w* encouraged \w Zerubbabel|strong="H2216"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Shealtiel|strong="H7597"\w*, \w governor|strong="H6346"\w* \w of|strong="H1121"\w* \w Judah|strong="H3063"\w*, \w the|strong="H3605"\w* \w high|strong="H1419"\w* \w priest|strong="H3548"\w* \w Joshua|strong="H3091"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Jehozadak|strong="H3087"\w*, \w and|strong="H1121"\w* \w the|strong="H3605"\w* \w whole|strong="H3605"\w* \w remnant|strong="H7611"\w* \w of|strong="H1121"\w* \w the|strong="H3605"\w* \w people|strong="H5971"\w*. \w They|strong="H3068"\w* \w came|strong="H3068"\w* \w and|strong="H1121"\w* \w worked|strong="H6213"\w* \w on|strong="H3068"\w* \w the|strong="H3605"\w* \w temple|strong="H1004"\w* \w of|strong="H1121"\w* \w their|strong="H3605"\w* \w God|strong="H3068"\w*, \w the|strong="H3605"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w who|strong="H3605"\w* rules \w over|strong="H4399"\w* \w all|strong="H3605"\w*.  
\v 15  \w This|strong="H3117"\w* \w took|strong="H4428"\w* place \w on|strong="H3117"\w* \w the|strong="H3117"\w* \w twenty-fourth|strong="H6242"\w* \w day|strong="H3117"\w* \w of|strong="H4428"\w* \w the|strong="H3117"\w* \w sixth|strong="H8345"\w* \w month|strong="H2320"\w* \w of|strong="H4428"\w* \w King|strong="H4428"\w* \w Darius|strong="H1867"\w*’ \w second|strong="H8147"\w* \w year|strong="H8141"\w*.   
\c 2  
\p
\v 1  \w On|strong="H3027"\w* \w the|strong="H3068"\w* \w twenty-first|strong="H6242"\w* \w day|strong="H2320"\w* \w of|strong="H3068"\w* \w the|strong="H3068"\w* \w seventh|strong="H7637"\w* \w month|strong="H2320"\w*, \w the|strong="H3068"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w spoke|strong="H1697"\w* \w again|strong="H1961"\w* \w through|strong="H3027"\w* \w the|strong="H3068"\w* \w prophet|strong="H5030"\w* \w Haggai|strong="H2292"\w*:  
\v 2 “Ask \w the|strong="H3091"\w* following questions \w to|strong="H1121"\w* \w Zerubbabel|strong="H2216"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Shealtiel|strong="H7597"\w*, \w governor|strong="H6346"\w* \w of|strong="H1121"\w* \w Judah|strong="H3063"\w*, \w the|strong="H3091"\w* \w high|strong="H1419"\w* \w priest|strong="H3548"\w* \w Joshua|strong="H3091"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Jehozadak|strong="H3087"\w*, \w and|strong="H1121"\w* \w the|strong="H3091"\w* \w remnant|strong="H7611"\w* \w of|strong="H1121"\w* \w the|strong="H3091"\w* \w people|strong="H5971"\w*:  
\v 3 ‘\w Who|strong="H4310"\w* \w among|strong="H4310"\w* \w you|strong="H3808"\w* \w survivors|strong="H7604"\w* \w saw|strong="H7200"\w* \w the|strong="H7200"\w* \w former|strong="H7223"\w* \w splendor|strong="H3519"\w* \w of|strong="H1004"\w* \w this|strong="H2088"\w* \w temple|strong="H1004"\w*? \w How|strong="H4100"\w* \w does|strong="H4100"\w* \w it|strong="H7200"\w* \w look|strong="H7200"\w* \w to|strong="H1004"\w* \w you|strong="H3808"\w* \w now|strong="H6258"\w*? Isn’t \w it|strong="H7200"\w* \w nothing|strong="H3808"\w* \w by|strong="H3808"\w* \w comparison|strong="H3644"\w*?  
\v 4  \w Even|strong="H3588"\w* \w so|strong="H6213"\w*, \w take|strong="H2388"\w* heart, \w Zerubbabel|strong="H2216"\w*,’ \w says|strong="H5002"\w* \w the|strong="H3605"\w* \nd \+w Lord|strong="H3068"\+w*\nd*. ‘\w Take|strong="H2388"\w* heart, \w Joshua|strong="H3091"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Jehozadak|strong="H3087"\w*, \w the|strong="H3605"\w* \w high|strong="H1419"\w* \w priest|strong="H3548"\w*, \w and|strong="H1121"\w* \w all|strong="H3605"\w* \w you|strong="H3588"\w* \w citizens|strong="H5971"\w* \w of|strong="H1121"\w* \w the|strong="H3605"\w* land,’ \w says|strong="H5002"\w* \w the|strong="H3605"\w* \nd \+w Lord|strong="H3068"\+w*\nd*, ‘\w and|strong="H1121"\w* begin \w to|strong="H3068"\w* \w work|strong="H6213"\w*. \w For|strong="H3588"\w* \w I|strong="H3588"\w* \w am|strong="H3068"\w* \w with|strong="H3068"\w* \w you|strong="H3588"\w*,’ \w says|strong="H5002"\w* \w the|strong="H3605"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w who|strong="H3605"\w* rules \w over|strong="H2388"\w* \w all|strong="H3605"\w*.  
\v 5 ‘\w Do|strong="H3318"\w* \w not|strong="H3318"\w* \w fear|strong="H3372"\w*, \w because|strong="H1697"\w* \w I|strong="H1697"\w* \w made|strong="H3772"\w* \w a|strong="H3068"\w* \w promise|strong="H1697"\w* \w to|strong="H3318"\w* \w your|strong="H3772"\w* ancestors \w when|strong="H3318"\w* \w they|strong="H1697"\w* \w left|strong="H3318"\w* \w Egypt|strong="H4714"\w*, \w and|strong="H4714"\w* \w my|strong="H3318"\w* \w spirit|strong="H7307"\w* \w even|strong="H4714"\w* \w now|strong="H4714"\w* testifies \w to|strong="H3318"\w* \w you|strong="H8432"\w*.’  
\v 6  \w Moreover|strong="H3541"\w*, \w the|strong="H3588"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w who|strong="H1931"\w* rules \w over|strong="H3220"\w* \w all|strong="H3068"\w* \w says|strong="H3541"\w*: ‘\w In|strong="H3068"\w* just \w a|strong="H3068"\w* \w little|strong="H4592"\w* \w while|strong="H5750"\w* \w I|strong="H3588"\w* \w will|strong="H3068"\w* \w once|strong="H5750"\w* \w again|strong="H5750"\w* \w shake|strong="H7493"\w* \w the|strong="H3588"\w* \w sky|strong="H8064"\w* \w and|strong="H3068"\w* \w the|strong="H3588"\w* \w earth|strong="H8064"\w*, \w the|strong="H3588"\w* \w sea|strong="H3220"\w* \w and|strong="H3068"\w* \w the|strong="H3588"\w* \w dry|strong="H2724"\w* \w ground|strong="H2724"\w*.  
\v 7  \w I|strong="H2088"\w* \w will|strong="H3068"\w* \w also|strong="H3068"\w* \w shake|strong="H7493"\w* \w up|strong="H3605"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w nations|strong="H1471"\w*, \w and|strong="H3068"\w* \w they|strong="H3068"\w* \w will|strong="H3068"\w* offer \w their|strong="H3605"\w* treasures; \w then|strong="H2088"\w* \w I|strong="H2088"\w* \w will|strong="H3068"\w* \w fill|strong="H4390"\w* \w this|strong="H2088"\w* \w temple|strong="H1004"\w* \w with|strong="H4390"\w* \w glory|strong="H3519"\w*,’ says \w the|strong="H3605"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w who|strong="H3605"\w* rules \w over|strong="H3068"\w* \w all|strong="H3605"\w*.  
\v 8 ‘\w The|strong="H5002"\w* \w silver|strong="H3701"\w* \w and|strong="H3068"\w* \w gold|strong="H2091"\w* \w will|strong="H3068"\w* \w be|strong="H3068"\w* mine,’ \w says|strong="H5002"\w* \w the|strong="H5002"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w who|strong="H3068"\w* rules \w over|strong="H3068"\w* \w all|strong="H3068"\w*.  
\v 9 ‘\w The|strong="H5002"\w* future \w splendor|strong="H3519"\w* \w of|strong="H1004"\w* \w this|strong="H2088"\w* \w temple|strong="H1004"\w* \w will|strong="H3068"\w* \w be|strong="H1961"\w* \w greater|strong="H1419"\w* \w than|strong="H4480"\w* \w that|strong="H3068"\w* \w of|strong="H1004"\w* \w former|strong="H7223"\w* times,’ \w the|strong="H5002"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w who|strong="H3068"\w* rules \w over|strong="H5414"\w* \w all|strong="H1419"\w* \w declares|strong="H5002"\w*, ‘\w and|strong="H3068"\w* \w in|strong="H3068"\w* \w this|strong="H2088"\w* \w place|strong="H4725"\w* \w I|strong="H5414"\w* \w will|strong="H3068"\w* \w give|strong="H5414"\w* \w peace|strong="H7965"\w*.’”   
\s1 The Promised Blessing  
\p
\v 10  \w On|strong="H3068"\w* \w the|strong="H3068"\w* \w twenty-fourth|strong="H6242"\w* day \w of|strong="H3068"\w* \w the|strong="H3068"\w* \w ninth|strong="H8671"\w* month \w of|strong="H3068"\w* \w Darius|strong="H1867"\w*’ \w second|strong="H8147"\w* \w year|strong="H8141"\w*, \w the|strong="H3068"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w spoke|strong="H1697"\w* \w again|strong="H1961"\w* \w to|strong="H3068"\w* \w the|strong="H3068"\w* \w prophet|strong="H5030"\w* \w Haggai|strong="H2292"\w*:  
\v 11 “\w The|strong="H3541"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w who|strong="H3548"\w* rules \w over|strong="H3068"\w* \w all|strong="H3068"\w* \w says|strong="H3541"\w*, ‘\w Ask|strong="H7592"\w* \w the|strong="H3541"\w* \w priests|strong="H3548"\w* \w about|strong="H3541"\w* \w the|strong="H3541"\w* \w law|strong="H8451"\w*.  
