\id LUK - Biblica® Open Igbo Contemporary Bible 2020 
\h Luk 
\toc1 Oziọma Luk 
\toc2 Luk 
\toc3 Luk 
\mt1 Oziọma Luk 
\c 1  
\s1 Mmalite 
\p  
\v 1 Ebe ọ bụ nʼọtụtụ mmadụ agbalịala otu ha nwere ike i detu nʼusoro ihe niile mezuru nʼetiti anyị.  
\v 2 Dị ka e nyefere ha nʼaka anyị idebe bụ ndị ahụ sitere na malite jiri anya ha hụ ihe niile, ndị jikwa okwu a eje ozi.  
\v 3 Ekpebikwara m, ebe mụ onwe m nyocharala ihe niile nke ọma site na mmalite, ka m dere gị ihe niile nʼusoro, Tiofilọs, gị onye dị elu a na-asọpụrụ.  
\v 4 Nke a ga-eme ka ị mata nke bụ eziokwu banyere ihe ndị ahụ e ziri gị. 
\s1 Ozi banyere ọmụmụ Jọn omee baptizim 
\p  
\v 5 Nʼoge Herọd bụ eze Judịa, ọ dị otu onyeisi nchụaja aha ya bụ Zekaraya, onye si nʼotu ndị nchụaja nke Abija. Elizabet bụ nwunye ya, site nʼagbụrụ Erọn.  
\v 6 Ha abụọ bụ ndị ezi omume nʼihu Chineke. Ha debere iwu na ụkpụrụ niile Onyenwe anyị nyere na-enweghị ntụpọ ọbụla.  
\v 7 Mana ha amụtaghị nwa, nʼihi na Elizabet bụ nwanyị agaa, ha abụọ emeela nnọọ agadi. 
\p  
\v 8 O ruru mgbe ọ bụ ndị otu Zekaraya ga-eje ozi, ọ nọ dịka onye nchụaja na-eje ozi nʼihu Chineke.  
\v 9 A họpụtara ya site nʼife nza dị ka omenaala ndị nchụaja si dị ka ọ bụrụ ya ga-abanye nʼime ime ụlọnsọ Onyenwe anyị ịchụ aja nsure ọkụ nke e ji ụda na-esi isi ụtọ achụ.  
\v 10 Mgbe oge ịchụ aja ụda na-esi isi ụtọ ruru, igwe ndị mmadụ bịara nọ nʼezi na-ekpe ekpere. 
\p  
\v 11 Mgbe ahụ, mmụọ ozi Onyenwe anyị, onye guzo nʼaka nri nke ebe ịchụ aja nke ihe na-esi isi ụtọ mere ka ọ hụ ya anya.  
\v 12 Mgbe Zekaraya hụrụ ya, obi fepụrụ ya, ọ tụkwara oke egwu.  
\v 13 Ma mmụọ ozi ahụ gwara ya sị, “Zekaraya atụla egwu, Chineke anụla ekpere gị. Elizabet nwunye gị ga-atụrụ ime mụtara gị nwa nwoke. Ị ga-akpọkwa aha ya Jọn.  
\v 14 Ọ ga-abụrụ gị ihe oke ọṅụ na obi ụtọ, ọtụtụ mmadụ ga-aṅụrịkwa ọṅụ nʼihi ọmụmụ ya.  
\v 15 Nʼihi na ọ ga-abụ onye dị ukwuu nʼanya Onyenwe anyị. Ọ gaghị aṅụkwa mmanya ọbụla, maọbụ ihe ọṅụṅụ ọbụla na-egbu egbu nʼihi na site nʼafọ nne ya ọ ga-abụ onye emejupụtara na Mmụọ Nsọ.  
\v 16 Ọ ga-akpọghachite ọtụtụ ụmụ Izrel nye Onyenwe ha bụ Chineke ha.  
\v 17 Ma ọ ga-aga nʼihu Onyenwe anyị nʼike mmụọ na ike nke Ịlaịja, tụgharịa obi ndị bụ nna nʼebe ụmụ ha nọ. Meekwa ka ndị isiike tụgharịa obi, lekwasị anya nʼamamihe nke ndị ezi omume, na ijikere ụmụ mmadụ nʼihi Onyenwe anyị.” 
\p  
\v 18 Zekaraya sịrị mmụọ ozi ahụ, “Olee otu m ga-esi mata na nke a ga-adị otu a? Abụrụla m agadi. Nwunye m akakwaala nka.” 
\p  
\v 19 Mmụọ ozi zara ya sị, “Abụ m Gebrel.\f + \fr 1:19 \ft Mmụọ ozi nke na-eweta oziọma.\f* Ana m eguzo nʼihu Chineke. Ezitere m ka m bịa gwa gị okwu ma wetara gị oziọma a.  
\v 20 Ma lee, ị ga-ada ogbi, ị gaghị ekwukwa okwu ọbụla, tutu ruo mgbe ihe ndị a ga-emezu nʼihi na i kwenyeghị nʼokwu m, nke ga-emezu mgbe oge ya ruru.” 
\p  
\v 21 Mgbe ihe ndị a niile na-eme, mmadụ ndị ahụ nọkwa na-eche Zekaraya ka ọ pụta. O juru ha anya na ọ nọọla ọdụ nʼime ime ụlọnsọ ukwu ahụ.  
\v 22 Mgbe o mesịrị pụta, o nwekwaghị ike ikwuru ha okwu. Ha ghọtara na ọ hụrụ ọhụ nʼime ụlọnsọ ahụ nʼihi na ọ bụ aka ka o ji gwa ha okwu. 
\p  
\v 23 Mgbe oge ịrụ ọrụ ya gwụsịrị, ọ laghachiri nʼụlọ ya.  
\v 24 Mgbe ụbọchị ndị ahụ gasịrị, Elizabet bụ nwunye ya tụụrụ ime. O zoro onwe ya nʼime ụlọ ọnwa ise.  
\v 25 Ọ sịrị, “Onyenwe anyị emeerela m nke a. O gosila m ihuọma ya nʼụbọchị ndị a, ma wepụkwara m ihere nʼetiti ndị nke m.” 
\s1 Ozi banyere ọmụmụ Jisọs 
\p  
\v 26 Ma nʼọnwa isii ya, Chineke zigara mmụọ ozi ya, bụ Gebrel, ka ọ gaa nʼobodo Nazaret nke dị nʼime Galili.  
\v 27 Ka o jekwuru otu nwaagbọghọ na-amaghị nwoke bụ onye otu nwoke aha ya bụ Josef, onye sitere nʼagbụrụ Devid, kwere nkwa ịlụ. Aha nwaagbọghọ a bụ Meri.  
\v 28 O jekwuru ya sị ya, “Ekele! Gị onye ihuọma dịkwasịrị. Onyenwe anyị nọnyekwara gị.” 
\p  
\v 29 Ma obi lọrọ ya mmiri nke ukwuu nʼihi okwu ya. O bidokwara ịtụgharị nʼuche ya ihe ekele a pụtara.  
\v 30 Ma mmụọ ozi ahụ sịrị ya, “Atụla egwu Meri, nʼihi na i chọtala ihuọma nʼebe Chineke nọ.  
\v 31 Ma lee ị ga-atụrụ ime, mụọ nwa nwoke. Ị ga-akpọkwa aha ya Jisọs.  
\v 32 Ọ ga-abụ nnukwu mmadụ onye a ga-akpọ Ọkpara Onye kachasị ihe niile elu. Onyenwe anyị Chineke ga-enye ya ocheeze nna ya Devid.  
\v 33 Ọ ga-achị ụlọ Jekọb ruo ebighị ebi, alaeze ya agaghị enwekwa ọgwụgwụ.” 
\p  
\v 34 Meri sịrị mmụọ ozi ahụ, “Olee otu nke a ga-esi mee ebe m bụ nwaagbọghọ na-amaghị nwoke?” 
\p  
\v 35 Mmụọ ozi ahụ sịrị ya, “Mmụọ Nsọ ga-abịakwasị gị, ike nke Onye kachasị ihe niile elu ga-ekpuchikwa gị. Ya mere onye nsọ ahụ a ga-amụ, a ga-akpọ ya Ọkpara Chineke.  
\v 36 Lekwa Elizabet onye ikwu gị atụrụla ime nwa nwoke nʼagadi ya. Nke a bụ ọnwa isii ya, bụ onye ahụ ha na-akpọ nwanyị aga.  
\v 37 Nʼihi na ọ dịghị okwu sitere na Chineke nke na-agaghị ere.” 
\p  
\v 38 Meri zaghachiri sị, “Abụ m ohu Onyenwe anyị, ka ọ dịrị m dị ka i kwuru.” Mgbe ahụ mmụọ ozi ahụ hapụrụ ya laa. 
\s1 Meri agaa ileta Elizabet 
\p  
\v 39 Nʼoge ahụ, Meri biliri gaa ọsịịsọ nʼotu obodo dị nʼugwu Juda.  
\v 40 Nʼebe ahụ, ọ banyere nʼụlọ Zekaraya, kelee Elizabet.  
\v 41 Mgbe Elizabet nụrụ ekele Meri, nwa nọ ya nʼafọ megharịrị ahụ. E mere ka Elizabet jupụta na Mmụọ nsọ.  
\v 42 O tiri mkpu nʼoke olu sị, “Onye a gọziri agọzi ka ị bụ nʼetiti ụmụ nwanyị niile. Onye a gọziri agọzi ka nwa ahụ ị bu nʼafọ bụkwa.  
\v 43 Onye kwanụ ka m bụ na ihuọma dị otu a kpọrọ m na nne Onyenwe m ga-abịa ileta m?  
\v 44 Ngwangwa m nụrụ olu ekele gị, nwa nọ m nʼafọ wuliri elu nʼọṅụ.  
\v 45 Ngọzị ga-adịrị onye ahụ kwere na Onyenwe anyị ga-emezu ihe o kweere ya na nkwa ime.” 
\s1 Abụ Meri bụrụ 
\p  
\v 46 Ma Meri sịrị, 
\q1 “Mkpụrụobi m na-ebuli Onyenwe anyị elu 
\q2  
\v 47 mmụọ m na-aṅụrị ọṅụ nʼime Chineke bụ Onye nzọpụta m, 
\q1  
\v 48 nʼihi na o ledatala anya, lekwasị m, 
\q2 bụ odibo ya dị ala. 
\q1 Site ugbu a gaa nʼihu, ọgbọ niile ga-akpọ m onye a gọziri agọzi. 
\q2  
\v 49 Nʼihi na Onye dị ike emeelara m ihe dị ukwuu. 
\q2 Aha ya dịkwa nsọ. 
\q1  
\v 50 Ebere ya na-erute ndị niile na-atụ egwu ya 
\q2 site nʼọgbọ ruo nʼọgbọ. 
\q1  
\v 51 O gosila ike aka ya; 
\q2 ọ chụsasịala ndị dị mpako nʼime echiche obi ha. 
\q1  
\v 52 O sitela nʼocheeze ndị eze dị ike kwatuo ha, 
\q2 buliekwa ndị dị umeala nʼobi elu. 
\q1  
\v 53 O jirila ihe dị mma nyejuo ndị agụụ na-agụ afọ 
\q2 ma ndị ọgaranya ka o zipụrụ nʼaka efu. 
\q1  
\v 54 O nyerela odibo ya bụ Izrel aka, 
\q2 ọ na-echetakwa imere ya ebere. 
\q1  
\v 55 Dị ka ọ gwara nna nna anyị ha, 
\q2 nye Ebraham na ụmụ ụmụ ya ruo mgbe ebighị ebi.” 
\p  
\v 56 Meri nọnyeere ya ihe dịka ọnwa atọ ma mesie laghachi nʼụlọ ya. 
\s1 Ọmụmụ Jọn omee baptizim 
\p  
\v 57 Mgbe oge zuru ka Elizabet mụọ nwa, ọ mụrụ nwa nwoke.  
\v 58 Ndị agbataobi ya na ndị ikwu ya, ndị nụrụ otu Chineke si gosi ya ebere dị ukwuu, bịara soro ya ṅụrịa ọṅụ. 
\p  
\v 59 Nʼabalị nke asatọ ha bịara ibi nwata ahụ ugwu na ịgụ ya aha. Ha na-achọ ịgụ ya Zekaraya bụ aha nna ya,  
\v 60 ma Nne ya sịrị, “Mba, a ga-agụ ya Jọn.” 
\p  
\v 61 Ha sịrị ya, “Ọ dịghị onye ọbụla nʼetiti ndị ikwu gị na-aza aha ahụ.” 
\p  
\v 62 Ya mere, ha jiri ife aka jụọ nna ya, ihe ọ chọrọ ka akpọ nwata ahụ.  
\v 63 Ọ rịọrọ ka e nye ya mbadamba ihe e ji ede ihe, o deere “Aha ya bụ Jọn.” Nke a jukwara mmadụ niile anya.  
\v 64 Ngwangwa, ọnụ ya meghere, atọpụkwara ire ya. Ya ebido ikwu okwu ma na-etokwa Chineke.  
\v 65 Ibubo wụrụ ndị agbataobi ha niile nʼahụ, ndị mmadụ kọkwara akụkọ banyere ihe ndị a niile ruo obodo niile dị nʼakụkụ ugwu Judịa.  
\v 66 Ndị niile nụrụ akụkọ a chere nʼobi ha na-ajụ sị, “Gịnịkwa ka nwa nke a gaje ịbụ?” Nʼihi na aka Onyenwe anyị dịnyeere ya. 
\s1 Abụ Zekaraya 
\p  
\v 67 E mere ka Zekaraya bụ nna ya jupụta na Mmụọ Nsọ. O buru amụma sị, 
\q1  
\v 68 “Ngọzị dịrị Onyenwe anyị bụ Chineke nke Izrel, 
\q2 nʼihi na ọ bịala leta ma gbapụtakwa ndị nke ya. 
\q1  
\v 69 O welielara anyị Onye nzọpụta 
\q2 site nʼụlọ odibo ya bụ Devid. 
\q1  
\v 70 (Dị ka o kwuru na mgbe ochie, site nʼọnụ ndị amụma ya dị nsọ). 
\q1  
\v 71 Na ọ ga-azọpụta anyị site nʼaka ndị iro anyị 
\q2 na sitekwa nʼaka ndị niile kpọrọ anyị asị. 
\q1  
\v 72 O meere ndị nna nna anyị ha ebere 
\q2 site nʼicheta ọgbụgba ndụ ya dị nsọ. 
\q2  
\v 73 Iyi nke ọ ṅụụrụ nna anyị bụ Ebraham, kwekwa nkwa: 
\q1  
\v 74 Na ọ ga-anapụta anyị site nʼaka ndị iro anyị, 
\q2 nyekwa anyị ike ife ya ofufe na-atụghị egwu. 
\q2  
\v 75 Nʼịdị nsọ na ezi omume nʼihu ya ụbọchị niile nke ndụ anyị. 
\b  
\b  
\q1  
\v 76 “Ma gị nwa m, a ga-akpọ gị onye amụma nke Onye kachasị ihe niile elu; 
\q2 nʼihi na ị ga-aga nʼihu Onyenwe anyị kwadoro ya ụzọ. 
\q1  
\v 77 Ime ka ndị nke ya nwee amamihe nke nzọpụta 
\q2 site na ịgbaghara mmehie ha. 
\q1  
\v 78 Nʼihi oke obi ebere Chineke anyị, 
\q2 nke ọwụwa anyanwụ ga-ewetara anyị site nʼigwe. 
\q1  
\v 79 Ka ọ chakwasị ndị bi nʼọchịchịrị 
\q2 na nʼonyinyo nke ọnwụ, 
\q1 na iduzi ụkwụ anyị nʼụzọ nke udo.” 
\p  
\v 80 Nwata ahụ toro, bụrụ onye dị ike nʼime mmụọ. O biri nʼime ọzara tutu ruo mgbe oge zuru igosi ụmụ Izrel onwe ya. 
\c 2  
\s1 Ọmụmụ Jisọs 
\p  
\v 1 Nʼoge ahụ, Siza Ọgọstọs nyere iwu ka a gụọ ọnụ, detuo aha mmadụ niile bi nʼụwa dum.\f + \fr 2:1 \fq Ụwa dum \ft na-ekwu maka Rom mgbe ochie maọbụ mba niile ndị Rom na-achị.\f* 
\v 2 (Nke a bụ ịgụ ọnụ na ide aha nke mbụ e mere mgbe Kwirinus bụ onye na-achị Siria.)  
\v 3 Onye ọbụla gara nʼobodo ya, ka e denye aha ya nʼakwụkwọ. 
\p  
\v 4 Ya mere Josef hapụrụ Nazaret nke dị na Galili, gaa Betlehem nke dị na Judịa, nke bụkwa obodo Devid, nʼihi na o si nʼụlọ na agbụrụ Devid pụta.  
\v 5 Ya na Meri, nwaagbọghọ o kwere nkwa ịlụ, nke dịkwa ime, soro gaa ka o denye aha ha.  
\v 6 Mgbe ha nọ ebe ahụ, oge ọ ga-eji mụọ nwa ya zuru.  
\v 7 Ọ mụrụ nwa nwoke mbụ ya. O ji akwa kee ya, nibe ya nʼime ebe a na-enye anụ ụlọ nri, nʼihi na ha enwetaghị ebe ndina nʼụlọ ndị ije. 
\s1 Ndị ọzụzụ atụrụ na ndị Mmụọ Ozi 
\p  
\v 8 Ma e nwere ndị ọzụzụ atụrụ\f + \fr 2:8 \fq Ndị ọzụzụ atụrụ \ft Maọbụ, \fqa ndị na-elekọta atụrụ.\f* bi nʼọhịa nʼakụkụ ebe ahụ, ndị na-eche igwe atụrụ ha nche nʼabalị.  
\v 9 Mmụọ ozi nke Onyenwe anyị pụtara ihe nye ha. Ebube Onyenwe anyị mụwara gburugburu ha, oke egwu tụrụ ha.  
\v 10 Ma mmụọ ozi ahụ sịrị ha, “Unu atụla egwu. Ana m ewetara unu oziọma nke oke ọṅụ nke ga-adịrị mmadụ niile.  
\v 11 Nʼihi na taa, nʼobodo Devid ka a mụrụ Onye nzọpụta nye unu; ọ bụ Kraịst, Onyenwe anyị.  
\v 12 Nke a ga-abụrụ unu ihe ịrịbama, unu ga-ahụ nwata ọhụrụ e kechiri nʼakwa, dina nʼime ebe a na-enye anụ ụlọ nri.” 
\p  
\v 13 Na mberede, igwe ndị mmụọ ozi nke eluigwe pụtara soro mmụọ ozi a, bido na-eto Chineke na-asị, 
\q1  
\v 14 “Otuto dịrị Chineke nʼebe kachasị elu nke eluigwe. 
\q2 Udo nʼelu ụwa nye ndị niile ihe ha dị Chineke ezi mma.” 
\p  
\v 15 Mgbe ndị mmụọ ozi ahụ hapụrụ ha, laghachi nʼeluigwe, ndị ọzụzụ atụrụ ahụ sịrịtara onwe ha, “Bịanụ ka anyị jeruo Betlehem, ka anyị jiri anya anyị hụ ihe ndị a merenụ, nke Onyenwe anyị mere ka anyị mara.” 
\p  
\v 16 Ha gara ọsịịsọ hụ Meri na Josef, na nwata ahụ ka o dina nʼime ebe a na-enye anụ ụlọ nri.  
\v 17 Mgbe ha hụrụ nke a, ha mere ka a mata ihe niile a gwara ha banyere nwantakịrị a.  
\v 18 Ihe ndị ọzụzụ atụrụ a kwuru juru ndị niile nụrụ ya anya.  
\v 19 Ma Meri debere ihe ndị a niile nʼobi ya, na-atụgharị ihe banyere ha nʼobi ya.  
\v 20 Ndị ọzụzụ atụrụ ahụ laghachiri, na-eto Chineke na-ebulikwa aha ya elu nʼihi ihe niile ha nụrụ ma hụkwa, nke dịkwa ka a gwara ha. 
\p  
\v 21 Mgbe ụbọchị asatọ gasịrị, mgbe oge ruru ibi nwata ahụ ugwu, ha gụkwara ya aha. Aha ha nyere ya bụ Jisọs, aha ahụ mmụọ ozi nyere tupu a dị ime ya. 
\s1 I kubata Jisọs nʼime ụlọnsọ 
\p  
\v 22 Mgbe oge zuru maka mmemme nke ịdị ọcha dị ka iwu Mosis siri dị, ha kutere ya na Jerusalem iche ya nʼihu Onyenwe anyị  
\v 23 (dịka e dere ya nʼiwu nke Onyenwe anyị, “Nwa mbụ ọbụla nke bụ nwoke ka a ga-edo nsọ nye Onyenwe anyị”\f + \fr 2:23 \ft \xt Ọpụ 13:2,12\f*),  
\v 24 ha chụrụ aja dị ka e nyere nʼiwu Onyenwe anyị: “Ụmụ kpalakwukwu abụọ maọbụ ụmụ nduru abụọ.”\f + \fr 2:24 \ft \xt Lev 12:8\f* 
\p  
\v 25 Ma lee, e nwere otu nwoke bi na Jerusalem aha ya bụ Simiọn, onye jupụtara na Mmụọ Nsọ. Ọ bụ onye ezi omume bụrụkwa onye ji obi ya niile na-efe Chineke. Ọ bụkwa onye na-ele anya maka nkasiobi nke ndị Izrel.  
\v 26 Ma Mmụọ Nsọ Chineke mere ka ọ mata na ọ gaghị anwụ ruo mgbe ọ hụrụ Kraịst nke Onyenwe anyị.  
\v 27 Site nʼodudu nke Mmụọ Nsọ, ọ batara nʼụlọnsọ ukwu, ma mgbe nne na nna nwata ahụ bụ Jisọs kubatara ya dị ka omenaala iwu si dị,  
\v 28 Simiọn kuuru ya nʼaka, kelee Chineke sị, 
\q1  
\v 29 “Gị, Onye kachasị ihe niile elu, bụ Onyenwe dị ka i kwere na nkwa, 
\q2 ugbu a zilaga nwaodibo gị nʼudo. 
\q1  
\v 30 Nʼihi na anya m ahụla nzọpụta gị, 
\q2  
\v 31 nke i kwadoro nʼihu mba niile. 
\q1  
\v 32 Ìhè nke ga-egosi ndị mba ọzọ ụzọ, 
\q2 na ebube nke ndị gị Izrel.” 
\p  
\v 33 O juru nne na nna nwantakịrị ahụ anya ịnụ ihe ndị a e kwuru banyere ya.  
\v 34 Mgbe ahụ, Simiọn gọziri ha, sịkwa Meri nne ya, Lee, “Nwatakịrị a bụ onye e zitere ka ọ bụrụ ọdịda na mbili nye ọtụtụ mmadụ nʼIzrel, ọ ga-abụkwa ihe ama nke ọtụtụ ga-ekwujọ.  
\v 35 Ọ bụkwa site nʼụzọ dị otu a ka a ga-ekpughe echiche nke dị ọtụtụ nʼobi. Mma agha ga-adụwakwa mkpụrụobi nke gị onwe gị.” 
\p  
\v 36 O nwekwara onye amụma nwanyị, aha ya bụ Ana, ada Fanuel nke si nʼebo Asha. Ọ bụ ezigbo agadi nwanyị na-enweghị di, nʼihi na di ya nwụrụ mgbe ha biri naanị afọ asaa.  
\v 37 Ọ nọọla dị ka nwanyị na-enweghị dị iri afọ asatọ na anọ. Ọ hapụghị ụlọnsọ, kama ọ nọgidere nʼefe ofufe ehihie na abalị, na-ibu ọnụ na-ekpe ekpere.  
\v 38 Nʼoge ahụ ọ bịarutere nʼebe ha nọ, nye Chineke ekele, kwuo okwu banyere nwantakịrị ahụ nye ndị niile na-ele anya maka mgbapụta Jerusalem. 
\p  
\v 39 Mgbe ha mesịrị ihe niile otu ọ dị nʼiwu Onyenwe anyị, ha laghachiri obodo ha bụ Nazaret nke dị nʼime Galili.  
\v 40 Ma nwata ahụ toro bụrụ onye dị ike; o jupụtara nʼamamihe, amara Chineke dịnyekwaara ya. 
\s1 Jisọs agaa nʼụlọnsọ ukwuu 
\p  
\v 41 Nʼafọ niile, ndị mụrụ ya na-aga Jerusalem nʼihi Mmemme Ngabiga.  
\v 42 Mgbe o ruru afọ iri na abụọ, ha gara maka mmemme dị ka omenaala si dị.\f + \fr 2:42 \ft Ọ bụ naanị Luk dere banyere Jisọs isonyere ndị mụrụ ya gaa maka mmemme a.\f* 
\v 43 Mgbe e mesịrị mmemme ahụ, ka ndị mụrụ ya na-alaghachi, nwata ahụ bụ Jisọs nọdụrụ na Jerusalem. Ndị ha amataghị na o soghị ha na-alọta.  
\v 44 Ha chere na o sonyere nʼetiti njem. Ha gara ije otu ụbọchị tupu ha a malite ịchọ ya nʼetiti ndị ikwu na ibe, na ndị enyi ha.  
\v 45 Ma mgbe ha na-ahụghị ya, ha laghachiri Jerusalem na-achọkwa ya.  
\v 46 Ka ụbọchị atọ gasịrị, ha hụrụ ya nʼụlọnsọ ukwu ebe ọ nọdụrụ nʼetiti ndị ode akwụkwọ, na-ege ha ntị na-ajụkwa ha ajụjụ.  
\v 47 Nghọta na ọsịsa ya juru ndị niile nụrụ okwu ya anya.  
\v 48 Mgbe ndị mụrụ ya hụrụ ya, ọ tụrụ ha nʼanya, ma nne ya sịrị ya, “Nwa m, gịnị mere i ji mesoo anyị mmeso dị otu a? Mụ na nna gị nọ na-achọgharị gị?” 
\p  
\v 49 Ọ jụrụ ha sị, \wj “Gịnị mere unu ji na-achọ m? Unu amaghị na aghaghị m ịnọ nʼụlọ Nna m?”\wj* 
\v 50 Ma ha aghọtaghị ihe ọ gwara ha. 
\p  
\v 51 Mgbe ahụ, o sooro ha laghachi Nazaret ma na-erubekwara ha isi. Ma nne ya dobere ihe ndị a niile nʼobi ya.  
\v 52 Jisọs na-aga nʼihu nʼamamihe na ogologo, ya na ihuọma nʼebe Chineke na nke mmadụ nọ. 
\c 3  
\s1 Nkwusa nke Jọn omee baptizim 
\p  
\v 1 Nʼafọ nke iri na ise nke ọchịchị Tiberiọs Siza, mgbe Pọntiọs Pailet bụ onye na-achị Judịa, ebe Herọd bụkwa onye na-achị akụkụ Galili, ma nwanne ya nwoke bụ Filip na-achị akụkụ Iturịa na Trakona, Laisania bụkwa onye na-achị akụkụ Abilin,  
\v 2 mgbe ahụ Anas na Kaịfas bụ ndịisi nchụaja, okwu Chineke bịakwutere Jọn nwa Zekaraya nʼime ọzara.  
\v 3 Ọ gara nʼime obodo niile gbara Jọdan gburugburu na-ekwusa banyere baptizim nke nchegharị maka mgbaghara mmehie.  
\v 4 Dịka e dere ya nʼakwụkwọ Aịzaya onye amụma sị, 
\q1 “Otu onye na-eti mkpu nʼọzara na-asị, 
\q1 ‘Dozienụ ụzọ maka Onyenwe anyị, 
\q2 meenụ ka okporoụzọ ya guzozie. 
\q1  
\v 5 A ga-ekpoju ndagwurugwu ọbụla, 
\q2 ugwu ọbụla na ugwu nta ọbụla ka a ga-emekwa ka ọ dị ala. 
\q1 Ụzọ gbagọrọ agbagọ ka a ga-eme ka o guzozie nke ọma, 
\q2 meekwa ka ụzọ ọjọọ niile dị larịị. 
\q1  
\v 6 Mmadụ niile ga-ahụkwa nzọpụta Chineke.’ ”\f + \fr 3:6 \ft \xt Aịz 40:3-5\f* 
\p  
\v 7 Jọn sịrị igwe mmadụ ndị na-apụta ka o mee ha baptizim sị, “Unu ụmụ ajụala! Onye dọrọ unu aka na ntị sị unu gbanarị ọnụma nke na-abịa?  
\v 8 Mịanụ mkpụrụ na-egosipụta nchegharị unu. Unu amalitekwala na-asị onwe unu, ‘Anyị nwere Ebraham dịka nna.’ Nʼihi na agwa m unu na Chineke pụrụ isite na nkume ndị a mepụtara Ebraham ụmụ.  
\v 9 Ọ bụladị ugbu a, atụkwasịla anyụike na mgbọrọgwụ osisi, osisi ọbụla nke na-adịghị amị ezi mkpụrụ ka a ga-egbutu tụba ya nʼime ọkụ.” 
\p  
\v 10 Ma igwe mmadụ ahụ jụrụ ya sị, “Gịnị ka anyị kwesiri ime?” 
\p  
\v 11 Ọ zara ha sị, “Onye ọbụla nwere uwe abụọ, ya nye onye ọ na-adịghị nke o nwere otu. Onye nwere nri ya meekwa otu ahụ.” 
\p  
\v 12 Ọ bụladị ndị ọna ụtụ bịakwara ka e mee ha baptizim. Ha sịrị ya, “Onye ozizi, gịnị ka anyị kwesiri ime?” 
\p  
\v 13 Ọ sịrị ha, “Unu anatala karịa otu unu kwesiri ịnata.” 
\p  
\v 14 Ndị agha bịakwara jụọ ya sị, “Gịnịkwa ka anyị kwesiri ime?” 
\p Ọ sịrị ha, “Unu ejikwala ike apụnara ndị mmadụ ego ha; unu ebokwala ndị mmadụ ebubo ụgha, ka afọ ju unu nʼụgwọ a na-akwụ unu.” 
\p  
\v 15 Ndị mmadụ ji olileanya na-eche na-atulekwa nʼobi ha ma Jọn ọ bụ Kraịst ahụ.  
\v 16 Ma Jọn zara sị ha, “Eji m mmiri na-eme unu baptizim, ma otu onye dị ike karịa m ga-abịa, onye m na-erughị ịtọpụ eriri akpụkpọụkwụ ya. Ọ ga-eji Mmụọ Nsọ na ọkụ mee unu baptizim.  
\v 17 Ihe ịfụcha ọka ya dị nʼaka ya, iji zachaa ebe ịzọcha ọka ya nke ọma, ka e kponye ezi mkpụrụ ọka wiiti nʼime ọba, ma kpoba igbugbo ọka nʼime ọkụ nke a na-apụghị imenyụ emenyụ.”  
\v 18 O ji ọtụtụ okwu ọzọ dị iche iche dụọ ha ọdụ ma kwusaakwara ha oziọma. 
\p  
\v 19 Ma Eze Herọd, onye ọ tara ụta maka Herodịas nwunye nwanne ya nwoke, nakwa maka ihe ọjọọ dị iche iche ndị o mere,  
\v 20 tụkwasịkwara ihe nʼelu ihe ndị a niile, site na ịtụnye Jọn nʼụlọ mkpọrọ. 
\s1 Baptizim na usoro ndị agbụrụ Jisọs 
\p  
\v 21 Mgbe e mechara ndị niile baptizim, ma mechakwa Jisọs baptizim, mgbe ọ na-ekpe ekpere, eluigwe meghere.  
\v 22 Mmụọ Nsọ sikwa nʼelu rịdata dị ka nduru, bekwasị ya, mgbe ahụ, otu olu sitere nʼeluigwe daa sị, “Ị bụ Ọkpara m, onye m hụrụ nʼanya, ihe gị dị m ezi mma.” 
\p  
\v 23 Jisọs agbaala ihe dị ka iri afọ atọ mgbe o bidoro ọrụ ya. Ọ bụ nwa (dịka ndị mmadụ chere) Josef, 
\b  
\li1 onye bụ nwa Heli;  
\v 24 Heli abụrụ nwa Matat, 
\li1 nwa Livayị, nwa Meliki, 
\li1 nwa Janayi, nwa Josef; 
\li1  
\v 25 nwa Matatiyas, nwa Emọs, 
\li1 nwa Nehum, nwa Esili, 
\li1 nwa Nagayị;  
\v 26 nwa Maat, 
\li1 nwa Matatiyas, nwa Semein, 
\li1 nwa Josek, nwa Joda; 
\li1  
\v 27 nwa Joanan, nwa Resa, 
\li1 nwa Zerubabel, nwa Shealtiel, 
\li1 nwa Neri;  
\v 28 nwa Meliki, 
\li1 nwa Adi, nwa Kosam, 
\li1 nwa Elmadam, nwa Er, 
\li1  
\v 29 nwa Joshua, nwa Elieza, 
\li1 nwa Jorim, nwa Matat, 
\li1 nwa Livayị;  
\v 30 nwa Simiọn, 
\li1 nwa Juda, nwa Josef, 
\li1 nwa Jonam, nwa Eliakịm; 
\li1  
\v 31 nwa Melea, nwa Mena, 
\li1 nwa Matata, nwa Netan, 
\li1 nwa Devid;  
\v 32 nwa Jesi, 
\li1 nwa Obed, nwa Boaz, 
\li1 nwa Salmọn, nwa Nashọn; 
\li1  
\v 33 nwa Aminadab, nwa Ram,\f + \fr 3:33 \ft Nʼakwụkwọ ụfọdụ i nwere ike ihu nwa Admin, nwa Anai.\f* 
\li1 nwa Hezrọn, nwa Perez, 
\li1 nwa Juda;  
\v 34 nwa Jekọb, 
\li1 nwa Aịzik, nwa Ebraham, 
\li1 nwa Tera, nwa Nahọ; 
\li1  
\v 35 nwa Serug, nwa Reu, 
\li1 nwa Peleg, nwa Eba, 
\li1 nwa Shela;  
\v 36 nwa Kenan, 
\li1 nwa Aafaksad, nwa Shem, 
\li1 nwa Noa, nwa Lamek; 
\li1  
\v 37 nwa Metusela, nwa Enọk, 
\li1 nwa Jared, nwa Mahalalel, 
\li1 nwa Kenan;  
\v 38 nwa Enọsh, 
\li1 nwa Set, nwa Adam, 
\li1 nwa Chineke. 
\c 4  
\s1 Ọnwụnwa Jisọs 
\p  
\v 1 Jisọs, onye jupụtara na Mmụọ Nsọ, sitere na Jọdan lọta. Mmụọ nsọ duuru ya baa nʼọzara.  
\v 2 Ebe ahụ ka ekwensu nwara ya ọnwụnwa iri ụbọchị anọ. Nʼụbọchị ndị ahụ niile o righị nri ọbụla. Nʼikpeazụ agụụ gụrụ ya. 
\p  
\v 3 Ekwensu sịrị ya, “Ọ bụrụ na ị bụ Ọkpara Chineke, gwa nkume a ka ọ ghọọ achịcha.” 
\p  
\v 4 Jisọs zara ya sị, \wj “E dere ya, ‘Ọ bụghị naanị site na achịcha ka mmadụ ga-eji dị ndụ.’\wj*\f + \fr 4:4 \ft \xt Dit 8:3\f* \wj ”\wj* 
\p  
\v 5 Ekwensu duuru ya rigoo nʼebe dị elu, gosi ya alaeze niile nke ụwa, nʼotu ntabi anya.  
\v 6 Ọ gwara ya sị, “M ga-enye gị ikike niile ndị a na ebube ha. Ọ bụ m ka e nyere ha, e nwere m ike inye ha onye ọbụla m chọrọ inye ha.  
\v 7 Ya mere, ọ bụrụ na ị kpọọ isiala nye m, ha ga-abụ nke gị.” 
\p  
\v 8 Jisọs zara ya sị, \wj “E deela ya: ‘Ị ga-akpọ isiala nye Onyenwe anyị Chineke gị, naanị ya ka ị ga-efekwa.’\wj*\f + \fr 4:8 \ft \xt Dit 6:13\f* \wj ”\wj* 
\p  
\v 9 Ekwensu duuru ya gaa Jerusalem, mee ka o guzo nʼebe dịkarịsịrị elu nke ụlọnsọ ukwu ahụ. Ọ sịrị ya, “Ọ bụrụ na ị bụ Ọkpara Chineke, si nʼebe a tụda onwe gị nʼala.  
\v 10 Nʼihi na e dere ya, 
\q1 “ ‘Ọ ga-enye ndị mmụọ ozi ya iwu banyere gị, 
\q2 ichekwa gị nke ọma; 
\q1  
\v 11 ha ga-ebuli gị elu nʼaka ha, 
\q2 ka ị ghara ịkpọbi ụkwụ gị na nkume.’\f + \fr 4:11 \ft \xt Abụ 91:11,12\f*” 
\p  
\v 12 Jisọs zara ya sị, \wj “E kwuola ya, Anwala Onyenwe anyị Chineke gị ọnwụnwa.\wj*\f + \fr 4:12 \ft \xt Dit 6:16\f* \wj ”\wj* 
\p  
\v 13 Mgbe ekwensu nwasịrị ya ọnwụnwa ndị a niile, ọ hapụrụ ya ruo mgbe ohere ọzọ dapụtara. 
\s1 Jisọs agaa Nazaret 
\p  
\v 14 Jisọs lọghachiri na Galili nʼike nke Mmụọ Nsọ. Akụkọ banyere ya gbasara ruo akụkụ obodo niile.  
\v 15 O ziri ihe nʼọtụtụ ụlọ ekpere ha, mmadụ niile na-etokwa ya. 
\p  
\v 16 Mgbe o rutere Nazaret ebe ọ nọrọ too, nʼụbọchị izuike, ọ gara nʼụlọ ekpere dị ka ọ dị mbụ eme. O guzoro ọtọ ịgụ akwụkwọ nsọ.  
\v 17 E nyere ya akwụkwọ nke onye amụma Aịzaya dere. O meghere ya chọta ebe e dere sị, 
\q1  
\v 18 \wj “Mmụọ nke Onyenwe anyị dị nʼahụ m,\wj* 
\q2 \wj nʼihi na o teela m mmanụ\wj* 
\q2 \wj ka m kwusaa oziọma nye ndị ogbenye.\wj* 
\q1 \wj O zitela m ikwupụta inwere onwe nye ndị mkpọrọ,\wj* 
\q2 \wj ya na ịhụ ụzọ nye ndị kpuru ìsì,\wj* 
\q1 \wj ime ka ndị a na-emegbu emegbu nwere onwe ha.\wj* 
\q2  
\v 19 \wj Ikwupụta afọ Onyenwe anyị ga-eme amara.”\wj*\f + \fr 4:19 \ft \xt Aịz 61:1,2\f* 
\p  
\v 20 O mechiri akwụkwọ ahụ nyeghachi ya onye ahụ na-eje ozi, nọdụ ala. Ndị mmadụ niile nọ nʼụlọ nzukọ ahụ legidere ya nnọọ anya.  
\v 21 Ma o bidoro ịgwa ha sị, \wj “Taa ka ihe ndị a e dere nʼakwụkwọ nsọ a mezuru na ntị unu.”\wj* 
\p  
\v 22 Mmadụ niile kwuru okwu ọma banyere ya nʼihi okwu amara niile si ya nʼọnụ pụta nke mere na ha jụrịtara onwe ha sị, “Onye a, ọ bụghị nwa nwoke Josef?” 
\p  
\v 23 Ọ sịrị ha, \wj “Nʼezie, amaara m na unu ga-atụrụ m ilu a: ‘Dibịa, gwọọ onwe gị!’ Sikwa m, ‘Ihe ndị ahụ niile anyị nụrụ ị na-eme na Kapanọm mee ha nʼebe a bụ obodo gị.’ ”\wj*  
\p  
\v 24 Ọ gara nʼihu sị, \wj “Ma ị gwa unu eziokwu, o nweghị onye amụma ọbụla a na-anabata nke ọma nʼobodo a mụrụ ya.\wj* 
\v 25 \wj Nʼezie, chetakwanụ na e nwere ọtụtụ ụmụ nwanyị di ha nwụrụ anwụ nʼoge Ịlaịja onye amụma. Nʼoge oke ụnwụ dara nʼala ahụ dum, mgbe e mechiri eluigwe na mmiri ezoghị nʼala Izrel afọ atọ na ọnwa isii.\wj* 
\v 26 \wj Ma e zigaghị Ịlaịja ka o jekwuru onye ọbụla nʼime ha karịakwa nwanyị di ya nwụrụ anwụ nʼobodo Zarefat nʼakụkụ Saịdọn.\wj* 
\v 27 \wj Nʼoge Ịlaisha onye amụma, e nwere ọtụtụ ndị ekpenta nʼala Izrel, ma o nweghị onye e mere ka ọ dị ọcha nʼetiti ha karịakwa Neeman onye Siria.”\wj* 
\p  
\v 28 Mgbe ndị nọ nʼụlọ ekpere ahụ nụrụ nke a, iwe were ha nke ukwuu.  
\v 29 Ha biliri, kwapụ ya site nʼobodo ahụ, dọkpụrụ ya gaa nʼelu ugwu nke e wukwasịrị obodo ahụ ka ha nwee ike tụpụ ya site nʼugwu ahụ.  
\v 30 Ma o sitere nʼetiti igwe mmadụ ahụ pụọ, gawara onwe ya. 
\s1 Jisọs achụpụ mmụọ ọjọọ 
\p  
\v 31 O sitere nʼebe ahụ gaa Kapanọm, obodo dịkwa na Galili. Nʼụbọchị izuike, o bidoro izi ha ihe.  
\v 32 Ozizi ya juru ha anya, nʼihi na okwu ya nwere ikike. 
\p  
\v 33 Otu nwoke nọ nʼime ụlọ ekpere ahụ, onye mmụọ na-adịghị ọcha bi nʼime ya. O tiri mkpu nʼoke olu,  
\v 34 “Hapụ anyị! Gịnị ka ị na-achọ nʼebe anyị nọ, gị, Jisọs onye Nazaret? Ị bịara ka ị laa anyị nʼiyi? Ama m onye ị bụ, Onye Nsọ nke Chineke!” 
\p  
\v 35 Jisọs baara ya mba sị, \wj “Nọrọ jii! Si nʼime ya pụta.”\wj* Mgbe ahụ mmụọ ọjọọ ahụ tụdara ya nʼala nʼihu ha niile, o sikwa nʼime ya pụọ ma o merụghị ya ahụ. 
\p  
\v 36 Ihe ndị a juru ha niile anya, ha jụrịtara ibe ha sị, “Gịnị bụ ozizi nke a? O ji ịchị isi na ike na-enye mmụọ na-adịghị ọcha ndị a iwu, ha na-apụtakwa!”  
\v 37 Akụkọ banyere ya gbasara jeruo obodo niile dị ebe ahụ gburugburu. 
\s1 Jisọs agwọọ ọtụtụ ndị ọrịa 
\p  
\v 38 Mgbe ọ hapụrụ ụlọ ekpere ahụ gaa nʼụlọ Saimọn. Nne nwunye Saimọn nwere ahụ ọkụ, ha rịọrọ ya ka o nyere ya aka.  
\v 39 O guzoro nʼihu ya, ma baara ahụ ọkụ ahụ mba, ọ hapụrụ ya nʼotu ntabi anya ahụ. O bilikwara lee ha ọbịa. 
\p  
\v 40 Mgbe anyanwụ na-ada, ọtụtụ ndị nwere ndị na-arịa ọrịa dị iche iche kpọọrọ ha bịakwute Jisọs. O bikwasịrị ha niile aka nʼotu nʼotu, gwọọ ha.  
\v 41 Mmụọ ọjọọ dị iche iche si nʼime ọtụtụ mmadụ pụta na-eti mkpu na-asị, “Ị bụ Ọkpara Chineke.” Ma ọ baara ha mba, o kweghị ka ha kwuo okwu, nʼihi na ha matara na ọ bụ Kraịst. 
\p  
\v 42 Mgbe chi bọrọ, ọ pụrụ gaa ebe naanị ya nọ. Ndị mmadụ nọ na-achọgharị ya; mgbe ha bịaruru ebe ọ nọ, ha gbalịsịrị ike ime ka ọ ghara ịhapụ ha.  
\v 43 Ma ọ sịrị ha, \wj “Aghaghị m ikwusa oziọma alaeze Chineke nʼobodo ndị ọzọ, nʼihi na ọ bụ nʼihi ya ka e zitere m.”\wj* 
\v 44 Ọ gara nʼihu na-ekwusa oziọma nʼụlọ ekpere niile dị na Judịa. 
\c 5  
\s1 Ọkpụkpọ ndị mbụ na-eso ụzọ ya 
\p  
\v 1 Otu oge, ka Jisọs guzo nʼakụkụ ọdọ mmiri Genesaret.\f + \fr 5:1 \ft Maọbụ, \fqa osimiri Galili\f* Igwe mmadụ gbara ya gburugburu ka ha nụrụ okwu Chineke.  
\v 2 Ọ hụrụ nʼọnụ mmiri ahụ, ụgbọ mmiri abụọ nke ndị ọkụ azụ nwe ha hapụrụ gaa ịsa ụgbụ ha ji egbu azụ.  
\v 3 Ọ banyere nʼime otu ụgbọ mmiri ndị ahụ, nke bụ nke Saimọn, ọ rịọrọ ya ka ọ kwọrọ ya banyetụ ntakịrị nʼime mmiri. Ọ nọdụrụ ala nʼime ya bido na-ezi igwe mmadụ ihe. 
\p  
\v 4 Mgbe o kwusiri okwu, ọ gwara Saimọn sị, \wj “Banyetụkwuo nʼime mmiri, tụnye ụgbụ gị ka i gbute azụ.”\wj* 
\p  
\v 5 Saimọn zara sị, “Nna anyị ukwuu, anyị rụsịrị ọrụ ike abalị niile na-egbutaghị ihe ọbụla, ma otu i sịrị kwuo, aga m awụnye ụgbụ azụ niile.” 
\p  
\v 6 Mgbe ha mere nke a, ha gbutere ọtụtụ azụ nke mere na ụgbụ azụ ha malitere ịdọkasị.  
\v 7 Ha kpọrọ ndị ọkụ azụ ibe ha nọ nʼụgbọ mmiri ọzọ ka ha bịa nyere ha aka. Ha bịara kpojuo azụ nʼụgbọ mmiri abụọ ahụ nke malitere imikpu. 
\p  
\v 8 Ma mgbe Saimọn Pita hụrụ nke a, ọ dara nʼukwu Jisọs sị, “Si nʼebe m nọ pụọ, Onyenwe m, nʼihi na abụ m onye mmehie.”  
\v 9 Nʼihi na o juru ya na ndị ya na ha so anya ịhụ ọtụtụ azụ ndị a ha gbutere.  
\v 10 Ọ bụladị Jemis na Jọn ụmụ Zebedi, ndị ha na Saimọn na-arụkọ ọrụ, ka ihe a jukwara anya. 
\p Mgbe ahụ Jisọs gwara Saimọn sị, \wj “Atụla egwu, nʼihi na site ugbu a gaa nʼihu, ị ga na-akụta mmadụ.”\wj* 
\v 11 Mgbe ha kwọpụtara ụgbọ mmiri ha nʼelu ala, ha hapụrụ ihe niile soro ya. 
\s1 Nwoke onye ekpenta 
\p  
\v 12 Mgbe Jisọs nọ nʼotu obodo, otu nwoke onye ekpenta juru ahụ, bịara daa, kpudo ihu ya nʼala mgbe ọ hụrụ ya, rịọ ya sị, “Onyenwe m, ọ bụrụ na ị chọrọ, ị pụrụ ime ka m dị ọcha.” 
\p  
\v 13 Jisọs setịpụrụ aka ya metụ ya sị, \wj “Achọrọ m, bụrụ onye dị ọcha!”\wj* Ngwangwa ekpenta ahụ hapụrụ ya. 
\p  
\v 14 O nyere ya iwu, \wj “A gwakwala onye ọbụla, kama gaa gosi onye nchụaja onwe gị, chụọkwa aja dị ka Mosis nyere nʼiwu maka ime ka ị dị ọcha, ka ọ bụrụ ihe ama nye ha.”\wj* 
\p  
\v 15 Ma akụkọ banyere ya gbasara karịa, nke mere na igwe mmadụ bịara ịnụrụ ihe ọ na-ekwu, na ka a gwọọkwa ha nrịa nrịa.  
\v 16 Ma site nʼoge ruo nʼoge, Jisọs na-ewezuga onwe ya gaa nʼebe ọ ga-anọ naanị ya ikpe ekpere. 
\s1 Ọgwụgwọ onye akụkụ ahụ ya kpọnwụrụ akpọnwụ 
\p  
\v 17 Otu ụbọchị, mgbe ọ nọ na-ezi ndị mmadụ ihe, ndị Farisii na ndị ozizi iwu (sitere nʼobodo nta niile dị na Galili na Judịa na Jerusalem bịa nọdụkwa ebe) ahụ. Ike Chineke dịnyekwaara ya ịgwọ ndị ọrịa.  
\v 18 Nʼoge ahụ ndị ikom ụfọdụ bu otu nwoke akụkụ ahụ ya kpọnwụrụ akpọnwụ nʼihe ndina ya, bịara gbalịa isite nʼọnụ ụzọ ụlọ ahụ bubata ya tọgbọ ya nʼụkwụ ya.  
\v 19 Mgbe ha na-enweghị ike ime nke a nʼihi igwe mmadụ, ha rigooro nʼelu ụlọ, site nʼoghere wetuo nwoke ahụ nʼute ya nʼetiti igwe mmadụ nʼihu Jisọs. 
\p  
\v 20 Mgbe Jisọs hụrụ okwukwe ha, ọ sịrị, \wj “Enyi m, a gbagharala gị mmehie gị.”\wj* 
\p  
\v 21 Ndị Farisii na ndị ozizi iwu malitere iche nʼime obi ha sị, “Onye bụ onye a na-ekwulu Chineke? Onye pụrụ ịgbaghara mmadụ mmehie, ma ọ bụghị naanị Chineke?” 
\p  
\v 22 Mgbe Jisọs matara ihe ha na-ajụ, ọ zara ha sị, \wj “Gịnị mere unu ji na-eche ihe ndị a nʼobi unu?\wj* 
\v 23 \wj Olee nke ka mfe ikwu: Ọ bụ a gbagharala gị mmehie gị niile, ka ọ bụ ị sị, Bilie jee ije?\wj* 
\v 24 \wj Ma ka unu mata na Nwa nke Mmadụ nwere ikike nʼụwa ịgbaghara mmehie.”\wj* Ọ sịrị onye ahụ akụkụ ahụ ya kpọnwụrụ akpọnwụ, \wj “Asị m gị, bilie, chịrị ute gị laa nʼụlọ gị!”\wj* 
\v 25 Ngwangwa, o biliri ọtọ nʼihu mmadụ niile, chịrị ihe ndina ya bido na-eto Chineke na-ala nʼụlọ ya.  
\v 26 Ihe ndị a juru onye ọbụla anya, ha tokwara Chineke. Oke egwu jupụtakwara ha nʼahụ, ha sịrị, “Anyị ahụla ihe ebube taa.” 
\s1 Ọkpụkpọ Livayị 
\p  
\v 27 Mgbe nke a gasịrị, ọ pụrụ hụ otu onye ọna ụtụ aha ya bụ Livayị, ka ọ nọdụrụ ala nʼụlọ ịnakọta ụtụ ya. Ọ sịrị ya, \wj “Soro m.”\wj* 
\v 28 Ngwangwa, o biliri, hapụ ihe niile soro ya. 
\p  
\v 29 Emesịa, Livayị kwadooro Jisọs oke oriri nʼụlọ ya, ọtụtụ igwe ndị ọna ụtụ na ndị ọzọ soo ha nʼoriri ahụ.  
\v 30 Ma ndị Farisii na ndị ozizi iwu tamuru ntamu na-ajụ ndị na-eso ụzọ ya sị, “Gịnị mere unu ji soro ndị ọna ụtụ na ndị mmehie na-erikọ nri na-aṅụkọkwa ihe ọṅụṅụ?” 
\p  
\v 31 Jisọs zara sị, \wj “Mkpa dibịa adịghị akpa ndị ahụ dị ike, kama ọ bụ ndị ahụ na-esighị ike.\wj* 
\v 32 \wj Abịaghị m ịkpọ ndị ezi omume, kama abịara m ịkpọ ndị mmehie ka ha chegharịa.”\wj* 
\s1 Ajụjụ banyere ibu ọnụ 
\p  
\v 33 Ha sịrị, “Ndị na-eso ụzọ Jọn na ndị na-eso ụzọ ndị Farisii na-ebu ọnụ, na-ekpe ekpere oge niile, ma ndị na-eso ụzọ gị na-eri, na-aṅụkwa.” 
\p  
\v 34 Jisọs sịrị ha, \wj “Ndị a kpọrọ oriri nʼọlụlụ di na nwunye, ha ga-ebu ọnụ mgbe ha na onye na-alụ nwunye ọhụrụ nọ?\wj* 
\v 35 \wj Ma oge na-abịa mgbe a ga-ewepụ onye na-alụ nwunye nʼetiti ha, mgbe ahụ ka ha ga-ebu ọnụ.”\wj* 
\p  
\v 36 Ọ tụụrụ ha ilu a, \wj “O nweghị onye na-adọkara akwa ọhụrụ were ya kwachie akwa ochie. Ọ bụrụ na e mee nke a, ọ pụtara na a dọwaala akwa ọhụrụ ahụ nʼihi na nke ahụ eji kwachie ya agaghị adaba.\wj* 
\v 37 \wj Nʼụzọ dị otu a kwa, mmadụ adịghị agbanye mmanya ọhụrụ dị ike nʼime karama akpụkpọ ochie. Nʼihi na ike si na mmanya ọhụrụ ahụ ga-eme ka karama ahụ gbawaa. Mmanya ahụ ga-awụfukwa, karama ahụ a laa nʼiyi.\wj* 
\v 38 \wj Ma ọ dị mma ịgbanye mmanya ọhụrụ nʼime karama akpụkpọ ọhụrụ.\wj* 
\v 39 \wj O nweghị onye ṅụsịrị mmanya ochie ga-achọ ịṅụ mmanya ọhụrụ, nʼihi na ọ ga-asị, ‘Nke ochie ahụ ka mma.’ ”\wj* 
\c 6  
\s1 Onyenwe Ụbọchị Izuike 
\p  
\v 1 Nʼotu ụbọchị izuike, mgbe Jisọs na-agafe nʼubi a kụrụ ọka. Ndị na-eso ụzọ ya malitere ịghọrọ ụfọdụ nʼime ogbe ọka ndị ahụ, na-amazu ha nʼaka, ma na-ata ha.  
\v 2 Ụfọdụ ndị Farisii sịrị, “Gịnị mere unu ji na-eme ihe megidere iwu nʼụbọchị izuike?” 
\p  
\v 3 Jisọs zara ha sị, \wj “Ọ bụ na unu agụtaghị ihe Devid mere mgbe agụụ gụrụ ya na ndị so ya?\wj* 
\v 4 \wj Otu o si banye nʼụlọ Chineke, were achịcha a na-eche nʼihu ya, nyetụkwa ndị ya na ha so, achịcha nke onye ọbụla na-ekwesighị ịta ma ọ bụghị naanị ndị nchụaja.”\wj* 
\v 5 Mgbe ahụ ọ gwara ha sị, \wj “Nwa nke Mmadụ bụ Onyenwe Ụbọchị Izuike.”\wj* 
\p  
\v 6 Nʼụbọchị izuike ọzọ, ọ banyere nʼụlọ ekpere na-ezi ihe. Otu nwoke nọkwa nʼebe ahụ onye aka nri ya kpọnwụrụ akpọnwụ.  
\v 7 Ndị Farisii na ndị ode akwụkwọ na-achọ ụzọ ha ga-esi boo ya ebubo, ya mere ha lekwasịrị ya anya ịhụ ma ọ ga-agwọ ọrịa nʼụbọchị izuike.  
\v 8 Ma ebe ọ maara ihe ha na-ezube nʼobi ha, ọ kpọrọ nwoke ahụ nke aka ya kpọnwụrụ akpọnwụ sị ya, \wj “Bilie bịa guzoro nʼetiti ebe a.”\wj* Nwoke ahụ pụtara bịa guzoro ebe ahụ. 
\p  
\v 9 Mgbe ahụ Jisọs sịrị ha, \wj “Ka m jụọ unu, gịnị ziri ezi nʼiwu ime nʼụbọchị izuike; ọ bụ ime ihe ọma ka ọ bụ ime ihe ọjọọ; ịzọpụta ndụ ka ọ bụ ịla ndụ nʼiyi?”\wj* 
\p  
\v 10 Mgbe o lesiri ha niile anya gburugburu, ọ sịrị ya, \wj “Setịpụ aka gị.”\wj* O mere nke a, aka ya dịkwara mma ọzọ.  
\v 11 Ha were iwe nke ukwuu ma malite na-ekwurịtara nʼetiti onwe ha ihe ha nwere ike ime Jisọs. 
\s1 Ndị ozi iri na abụọ 
\p  
\v 12 Nʼụbọchị ndị ahụ, ọ gara rigoro nʼelu ugwu ikpe ekpere. Ọ nọrọ abalị ahụ niile na-ekpe ekpere nye Chineke.  
\v 13 Mgbe chi bọrọ, ọ kpọrọ ndị niile na-eso ụzọ ya, site nʼime ha họrọ mmadụ iri na abụọ ndị ọ kpọrọ ndị ozi ya.\f + \fr 6:13 \ft Mgbe ọbụla ị na-achọ inwe mkpebi banyere ihe dị mkpa, wepụta oge kpee ekpere dịka Jisọs mere nʼamaokwu iri na abụọ ruo nke iri na atọ.\f* 
\b  
\li1  
\v 14 Saimọn (onye ọ kpọrọ Pita) na Andru nwanne ya, 
\li1 Jemis 
\li1 Jọn, 
\li1 Filip 
\li1 Batalomi. 
\li1  
\v 15 Matiu 
\li1 Tọmọs, 
\li1 Jemis nwa Alfiọs, 
\li1 Saimọn onye a na-akpọ Zilọt. 
\li1  
\v 16 Judas nwa Jemis 
\li1 na Judas Iskarịọt onye raara ya nye. 
\s1 Ngọzị na ọbụbụ ọnụ 
\p  
\v 17 Ya na ha rịdatara ga nʼebe ala dị larịị. Igwe ndị na-eso ụzọ ya na oke igwe mmadụ sitere na Judịa, na Jerusalem nakwa obodo dị na nsọtụ mmiri nke Taịa na Saịdọn.  
\v 18 Ndị bịara ịnụrụ okwu ya na ka a gwọọ ha ọrịa ha. A gwọkwara ọtụtụ ndị mmụọ na-adịghị ọcha na-esogbu.  
\v 19 Igwe mmadụ ahụ gbalịrị ịmetụ ya aka, nʼihi na ike dị ukwuu si ya nʼahụ na-apụ na-agwọ ha niile. 
\p  
\v 20 O weliri anya lee ndị na-eso ụzọ ya, sị ha, 
\q1 \wj “Ngọzị na-adịrị unu bụ ndị ogbenye,\wj* 
\q2 \wj nʼihi na alaeze Chineke bụ nke unu.\wj* 
\q1  
\v 21 \wj Ngọzị na-adịrị unu ndị agụụ na-agụ ugbu a,\wj* 
\q2 \wj nʼihi na afọ ga-eju unu.\wj* 
\q1 \wj Ngọzị na-adịrị unu ndị na-ebe akwa ugbu a,\wj* 
\q2 \wj nʼihi na unu ga-achị ọchị.\wj* 
\q1  
\v 22 \wj Ngọzị na-adịrị unu mgbe ndị mmadụ na-akpọ unu asị,\wj* 
\q2 \wj mgbe ha na-achụpụ unu, na-akparị unu,\wj* 
\q2 \wj na-ajụ aha unu,\wj* 
\q3 \wj nʼihi Nwa nke Mmadụ.\wj* 
\p  
\v 23 \wj “Ṅụrịanụ ọṅụ ma wuliekwanụ elu nʼihi ọṅụ nʼụbọchị ahụ, nʼihi na ụgwọ ọrụ unu dị ukwuu nʼeluigwe. Nʼihi na otu a ka ndị nna nna ha mesoro ndị amụma.\wj* 
\q1  
\v 24 \wj “Ma ahụhụ na-adịrị unu ndị ọgaranya,\wj* 
\q2 \wj nʼihi na unu eketala nkasiobi unu.\wj* 
\q1  
\v 25 \wj Ahụhụ na-adịrị ndị afọ juru ugbu a,\wj* 
\q2 \wj nʼihi na agụ ga-agụkwa unu.\wj* 
\q1 \wj Ahụhụ na-adịrị ndị na-achị ọchị ugbu a,\wj* 
\q2 \wj nʼihi na unu ga-eru ụjụ, bee akwa.\wj* 
\q1  
\v 26 \wj Ahụhụ na-adịrị unu mgbe ndị mmadụ niile na-ekwu okwu ọma gbasara unu,\wj* 
\q2 \wj nʼihi na otu a ka ndị bụ nna ha mesoro ndị amụma ụgha.”\wj* 
\s1 Ịhụ ndị iro nʼanya 
\p  
\v 27 \wj “Ma a na m agwa unu ndị na-ege m ntị: hụnụ ndị iro unu nʼanya, mekwaaranụ ndị kpọrọ unu asị ihe ọma.\wj* 
\v 28 \wj Gọzienụ ndị na-abụ unu ọnụ, ma kpekwaaranụ ndị na-akparị unu ekpere.\wj* 
\v 29 \wj Ọ bụrụ na onye ọbụla a maa gị ụra nʼotu ntị, tụgharịara ya ntị gị nke ọzọ. Ọ bụrụkwa na onye ọbụla anara gị uwe ahụ gị, nyekwa ya uwe ime ahụ gị.\wj* 
\v 30 \wj Nye onye ọbụla rịọrọ gị ihe. Ọ bụrụkwa na mmadụ ewere ihe bụ nke gị, agala ịnapụta ya.\wj* 
\v 31 \wj Dịka unu si chọọ ka ndị mmadụ mesoo unu, sitekwanụ otu a na-emeso ha.\wj* 
\p  
\v 32 \wj “Ọ bụrụ naanị ndị hụrụ unu nʼanya ka unu na-ahụ nʼanya, gịnị ga-abụ uru unu? Nʼihi na ọbụladị ndị mmehie, ọ bụ ndị hụrụ ha nʼanya ka ha na-ahụkwa nʼanya.\wj* 
\v 33 \wj Ọ bụrụkwa naanị ndị na-emere unu ihe ọma ka unu na-emere ihe ọma, gịnị ga-abụ uru unu? Nʼihi na ndị mmehie na-enyekwara ndị na-enyere ha aka aka.\wj* 
\v 34 \wj Ọ bụrụkwa na unu agbazinye naanị ndị nwere ike ịkwụghachi unu ihe, gịnị ga-abụ uru unu? Nʼihi na ndị mmehie na-agbazinyekwa ndị mmehie ibe ha na-atụ anya ka a kwụghachikwa ha nʼozuzu oke.\wj* 
\v 35 \wj Hụnụ ndị iro unu nʼanya, na-emekwa ezi ihe nye ha, gbazinyenụ ndị nọ na mkpa ihe ha chọrọ, na-eleghị anya na ha ga-akwụghachi unu. Mgbe ahụ, ụgwọ ọrụ unu ga-adị ukwuu, unu ga-egosikwa na unu bụ ụmụ nke Onye kachasị ihe niile elu, nʼihi na ebere ya na-adịrị ndị ajọ omume na ndị na-enweghị mmụọ ekele nʼime ha.\wj* 
\v 36 \wj Nweenu obi ebere dị ka Nna unu si nwee obi ebere.\wj* 
\s1 Ikpe ndị ọzọ ikpe 
\p  
\v 37 \wj “Unu ekpela ndị ọzọ ikpe, ka a ghara ikpekwa unu ikpe. Unu amala ndị ọzọ ikpe ka a ghara ịma unu ikpe. Gbagharanụ ndị ọzọ, a ga-agbagharakwa unu.\wj* 
\v 38 \wj Nyenụ, nʼihi na a ga-enyekwa unu. Onyinye unu ga-anata ga-abụ nke juru eju, nke a bịadara nke ọma, yọkọtakwa ayọkọta nke na-ejubiga oke ka a ga-adọkwasị gị nʼahụ; nʼihi na ọ bụ ihe i na-eji atụ ihe ka a ga-eji tụọrọ gị.”\wj* 
\p  
\v 39 Ọ tụkwaara ha ilu a, \wj “Onye ìsì ọ pụrụ idu onye ìsì ibe ya? Ha abụọ ọ gaghị adaba nʼime olulu?\wj* 
\v 40 \wj Onye na-eso ụzọ onye ozizi anaghị akarị onye nkuzi ya, kama mgbe ọ mụtasịrị ọ ga-amata ihe dị ka onye nkuzi ya.\wj* 
\p  
\v 41 \wj “Gịnị mere i ji elee ntakịrị ahịhịa dị nwanna gị nʼanya, ma ị dịghị ahụta obodobo osisi dị gị onwe gị nʼanya?\wj* 
\v 42 \wj Ị ga-esi aṅaa sị nwanna gị, ‘Nwanna a, ka m wepụ gị ntakịrị ahịhịa dị gị nʼanya,’ mgbe gị onwe gị na-ahụghị obodobo osisi dị gị nʼanya? Gị onye ihu abụọ, buru ụzọ wepụ obodobo osisi dị gị nʼanya ka i nwee ike ịhụzi ụzọ nke ọma wepụ ntakịrị ahịhịa dị nwanna gị nʼanya.\wj* 
\s1 Osisi na mkpụrụ ya 
\p  
\v 43 \wj “Ezi osisi adịghị amị mkpụrụ ọjọọ. Ọ dịkwaghị osisi ọjọọ na-amị mkpụrụ ọma.\wj* 
\v 44 \wj Ọ bụ mkpụrụ osisi mịrị ka e ji ama ụdị osisi ọ bụ. Ndị mmadụ adịghị aghọta fiig site nʼosisi ogwu, otu a kwa o nweghị onye na-aghọta mkpụrụ grepu nʼobi ogwu.\wj* 
\v 45 \wj Ezi mmadụ na-esite nʼakụ ọma juru ya obi na-arụpụta ezi ọrụ, otu a kwa, ajọ mmadụ na-esite nʼobi ọjọọ ya na-arụpụta ajọ ọrụ. Nʼihi na ihe ọbụla dị mmadụ nʼobi bụ ihe na-apụta nʼọnụ ya.\wj* 
\s1 Onye amamihe na onye nzuzu wuru ụlọ 
\p  
\v 46 \wj “Gịnị mere unu ji na-akpọ m, ‘Onyenwe anyị, Onyenwe anyị,’ ma unu adịghị eme ihe m kwuru?\wj* 
\v 47 \wj Achọrọ m igosi unu ihe onye ọbụla na-abịakwute m nke na-anụ okwu m, ma na-ejikwa ihe ọ na-anụ akpọrọ ihe, yiri.\wj* 
\v 48 \wj Onye ahụ yiri nwoke wuru ụlọ, onye gwumiri ala, doo ntọala ụlọ ahụ nʼelu oke nkume. Mgbe idee mmiri bịara were ike ya tie nʼụlọ ahụ, o nweghị ike ime ka ọ maa jijiji nʼihi na e wusiri ya ike.\wj* 
\v 49 \wj Ma onye ahụ nụrụ okwu m, nke na-ejighị ihe ọ nụrụ mee ihe, dị ka nwoke wukwasịrị ụlọ ya nʼelu ala, nke na-enweghị ntọala ọbụla. Mgbe idee mmiri bịara were ike ya tie nʼụlọ ahụ, ụlọ ahụ dara daruo ala, ọdịda ya dị ukwuu.”\wj* 
\c 7  
\s1 Okwukwe onye ọchịagha 
\p  
\v 1 Mgbe o kwusiri okwu ndị a nye ndị na-ege ya ntị, ọ banyere na Kapanọm.  
\v 2 Ma e nwere otu ọchịagha\f + \fr 7:2 \ft Ọ bụ onye Rom.\f* nke nwere otu ohu nwoke ọ hụrụ nʼanya. Onye nọ nʼọrịa na nʼọnụ ọnwụ.  
\v 3 Mgbe ọ nụrụ ihe banyere Jisọs, o zipụrụ ụfọdụ ndị okenye ndị Juu ka ha gaa rịọrọ ya ka ọ bịa gwọọ ohu ya.  
\v 4 Mgbe ha bịakwutere Jisọs, ha rịọsiri ya arịrịọ ike sị, “O kwesiri ka i mere ya ihe a.  
\v 5 Nʼihi na ọ hụrụ obodo anyị nʼanya. O wukwaara anyị ụlọ ekpere.”  
\v 6 Jisọs sooro ha gawa. 
\p Ma mgbe ọ nọ nso nʼụlọ ya, onye ọchịagha ahụ zipụrụ ndị enyi ya ka ha ga sị ya, “Onyenwe anyị, esogbukwala onwe gị, nʼihi na etorughị m ka ị bata nʼokpuru ụlọ m.  
\v 7 Ọ bụ ya mere na-echeghị m na m toruru ịpụta bịa zute gị. Ma kwuo okwu, ọ ga-agwọkwa odibo m.  
\v 8 Nʼihi na mụ onwe m bụkwa onye nọ nʼokpuru ikike ọchịchị, nwee ndị agha nọ nʼokpuru m. Ana m asị onye nke a ‘gaa,’ ọ gaa, sịkwa onye nke ọzọ ‘bịa,’ Ọ bịa. Ana m asị ohu m, ‘mee nke a,’ ọ na-emekwa ya.” 
\p  
\v 9 Mgbe Jisọs nụrụ okwu niile a, o juru ya anya nke ukwuu. Ọ tụgharịrị gwa igwe mmadụ ndị na-eso ya sị, \wj “Asị m unu, ahụbeghị m okwukwe dị otu a ọ bụladị nʼIzrel.”\wj* 
\v 10 Mgbe ndị ozi ahụ laghachiri nʼụlọ, ha chọpụtara na ahụ adịla ohu ahụ mma. 
\s1 Jisọs akpọlite nwa nwoke nwanyị di ya nwụrụ 
\p  
\v 11 O ruo mgbe nwa oge gasịrị, ọ gara nʼobodo a na-akpọ Nain. Ndị na-eso ụzọ ya na ọtụtụ igwe mmadụ ndị ọzọ sooro ya gaa.  
\v 12 Mgbe ọ na-abịaru nso nʼọnụ ụzọ e si abata nʼobodo ahụ, o nwere otu nwoke nwụrụ anwụ nke a na-ebupụ, otu nwa nke nne ya mụrụ. Nne ya ahụ bụ nwanyị di ya nwụrụ, oke igwe mmadụ si nʼobodo ahụ sonyekwara ya.  
\v 13 Mgbe Onyenwe anyị hụrụ ya, o meere ya obi ebere ma sị ya, \wj “Ebela akwa.”\wj* 
\p  
\v 14 Mgbe ahụ ọ gara nso metụ igbe ozu ahụ aka, ndị bu ya kwụsịrị. Ọ sịrị, \wj “Nwokorobịa, asị m gị bilie!”\wj* 
\v 15 Nwoke ahụ nwụrụ anwụ biliri, nọdụ ala, bido ikwu okwu, ọ kpọnyere ya nne ya. 
\p  
\v 16 Egwu tụrụ ha niile, ha tokwara Chineke sị, “Onye amụma dị ukwuu apụtala nʼetiti anyị, Chineke abịala inyere ndị ya aka!”  
\v 17 Akụkọ a banyere ya ruru Judịa niile na obodo nta niile gbara ya gburugburu. 
\s1 Jisọs na Jọn omee baptizim 
\p  
\v 18 Ndị na-eso ụzọ Jọn kọọrọ ya maka ihe ndị a niile. Jọn kpọrọ mmadụ abụọ nʼime ndị na-eso ụzọ ya,  
\v 19 zie ha ka ha jekwuru Onyenwe anyị jụọ ya ajụjụ sị, “Ọ bụ gị bụ onye ahụ ga-abịa. Ka anyị ga-ele anya ọbịbịa onye ọzọ?” 
\p  
\v 20 Mgbe ụmụ nwoke ahụ bịakwutere ya, ha sịrị, “Jọn omee baptizim ziri anyị ka anyị jụọ gị sị, ‘Ọ bụ gị bụ onye ahụ ga-abịa ka anyị ga-ele anya ọbịbịa onye ọzọ?’ ” 
\p  
\v 21 Mgbe ahụ ọ gwọrọ ọtụtụ ndị nwere ọrịa, na nrịa nrịa dị iche iche, na mmụọ ọjọọ. O mekwara ka ọtụtụ ndị kpuru ìsì hụ ụzọ ọzọ.  
\v 22 Ọ zaghachiri ndị ozi ahụ sị, \wj “Laghachinụ azụ gaa kọrọ Jọn ihe unu hụrụ na nke unu nụrụ; ndị kpuru ìsì na-ahụ ụzọ, ndị ngwụrọ na-aga ije, ndị ekpenta ka a na-eme ka ha dị ọcha, ndị ntị chiri na-anụ ihe, a na-eme ka ndị nwụrụ anwụ si nʼọnwụ bilie, a na-ezisara ndị ogbenye oziọma.\wj* 
\v 23 \wj Ngọzị na-adịrị onye ahụ na-enweghị ihe mkpasu iwe nʼihi m.”\wj* 
\p  
\v 24 Mgbe ndị na-eso ụzọ Jọn pụrụ, Jisọs bidoro ịgwa igwe mmadụ ahụ okwu banyere Jọn sị, \wj “Gịnị ka unu gara nʼọzara ịhụ? Ọ bụ ahịhịa achara nke ikuku na-ebugharị?\wj* 
\v 25 \wj Ma gịnị ka unu pụrụ ịga ịhụ? Ọ bụ nwoke yi uwe mara mma? E e, ndị na-eyi uwe dị oke ọnụahịa, ndị na-ebikwa nʼoke oriri na oke ọṅụṅụ bi nʼụlọeze.\wj* 
\v 26 \wj Ma gịnị ka unu pụrụ ka unu ga-ahụ? Ọ bụ onye amụma? E, ana m a gwa unu, unu hụrụ onye karịrị onye amụma.\wj* 
\v 27 \wj Ọ bụ onye a bụ onye ahụ e dere ihe banyere ya sị,\wj* 
\q1 \wj “ ‘Aga m ezipu onyeozi m nʼihu gị,\wj* 
\q2 \wj onye ga-edozi ụzọ gị nʼihu gị.’\wj*\f + \fr 7:27 \ft \xt Mal 3:1\f* 
\m  
\v 28 \wj Agwa m unu, nʼetiti ndị nwanyị mụrụ, ọ dịghị onye dị ukwuu karịa Jọn, ma onye dịkarịsịrị nta nʼalaeze Chineke dị ukwuu karịa ya.”\wj* 
\p  
\v 29 (Ndị mmadụ niile nụrụ nke a, tinyekwara ndị ọna ụtụ, nabatara nʼụzọ Chineke bụ nke ziri ezi, nʼihi na Jọn emela ha baptizim.  
\v 30 Ma ndị Farisii na ndị ozizi iwu jụrụ imezu ebumnobi Chineke nye ha onwe ha, nʼihi na ha anabataghị ka Jọn mee ha baptizim.) 
\p  
\v 31 Ọ gara nʼihu sị ha, \wj “Ma gịnị ka m ga-eji tụnyere ndị bi nʼọgbọ a? Gịnị ka ha yiri?\wj* 
\v 32 \wj Ha dị ka ụmụntakịrị nọ nʼọma ahịa na-akpọ ibe ha oku na-asị,\wj* 
\q1 \wj “ ‘Anyị gburu unu ọja,\wj* 
\q2 \wj ma unu adịghị ete egwu.\wj* 
\q1 \wj Anyị bụrụ abụ ịkwa ozu,\wj* 
\q2 \wj ma unu ebeghị akwa.’\wj* 
\m  
\v 33 \wj Nʼihi na Jọn omee baptizim bịara na-erighị achịcha maọbụ ṅụọ ihe ọṅụṅụ ma unu sịrị, ‘Mmụọ ọjọọ bi nʼime ya.’\wj* 
\v 34 \wj Nwa nke Mmadụ bịara na-eri ihe oriri na-aṅụkwa ihe ọṅụṅụ, ma unu sịrị, ‘Lee, onye oke oriri na onye oke aṅụmaṅụ, enyi ndị ọna ụtụ na ndị mmehie.’\wj* 
\v 35 \wj Ma e sitela nʼụmụ ya niile nwapụta amamihe nʼonye ziri ezi.”\wj* 
\s1 Nwanyị onye mmehie etee Jisọs mmanụ 
\p  
\v 36 Otu onye nʼime ndị Farisii kpọrọ ya oriri. Ọ gara nʼụlọ onye Farisii ahụ, ma nọdụ ala nʼoche nri.  
\v 37 Ma otu nwanyị nke bi nʼobodo ahụ, onye birila ndụ mmehie, mgbe ọ matara na ọ nọ nʼụlọ onye Farisii ahụ na-eri nri, o jiri otu karama alabasta mmanụ otite bata nʼụlọ ahụ.  
\v 38 Ka o guzoro nʼazụ ụkwụ ya na-ebe akwa, ọ malitere iji anya mmiri ya na-awụsa nʼụkwụ ya. O jiri agịrị isi ya hichaa anya mmiri ahụ, sutu ụkwụ ya ọnụ, ma wụsa mmanụ otite isi ụtọ ahụ na ha. 
\p  
\v 39 Mgbe onye Farisii ahụ kpọrọ ya oriri hụrụ ihe nke a, o kwuru nʼobi ya sị, “A sị na nwoke a bụ onye amụma, ọ gaara amata ụdị mmadụ nwanyị a na-emetụ ya aka bụ, na ọ bụ onye mmehie.” 
\p  
\v 40 Jisọs zara ya sị, \wj “Saimọn, e nwere m ihe m chọrọ ịgwa gị.”\wj* 
\p Ọ sịrị ya, “Onye ozizi gwa m ya.” 
\p  
\v 41 \wj “Ndị ikom abụọ ji onye na-ebinye ndị mmadụ ego nʼọmụrụnwa ụgwọ. Otu onye ji ya narị ego ise, onye nke ọzọ ji ya iri ego ise.\wj* 
\v 42 \wj Mgbe ha na-enweghị ike ịkwụghachi ụgwọ ha ji ya, ọ gbaghara ha ụgwọ ahụ. Ugbu a, onye nʼime ha ga-ahụ ya nʼanya karịa?”\wj* 
\p  
\v 43 Saimọn zara sị, “Ọ dị m ka ọ bụ onye nke ọ gbaghara ụgwọ dị ukwuu.” 
\p Ọ sịrị ya, \wj “Ị kpeziri.”\wj* 
\p  
\v 44 Mgbe ahụ ọ tụgharịrị nʼebe nwanyị ahụ nọ gwa Saimọn sị, \wj “Ị hụrụ nwanyị a? A batara nʼụlọ gị, i kunyeghị m mmiri ka m saa ụkwụ m, ma nwanyị a ejirila anya mmiri ya sachaa ụkwụ m, jirikwa agịrị isi ya hichaa ha.\wj* 
\v 45 \wj Ị sutughị m ọnụ, ma kemgbe m batara nʼụlọ a, o zubeghị ike isutu ụkwụ m ọnụ.\wj* 
\v 46 \wj Ị teghị m mmanụ ọbụla nʼisi, ma lee, o werela mmanụ otite isi ụtọ wụkwasị m nʼụkwụ.\wj* 
\v 47 \wj Ya mere, ana m agwa gị sị, a gbagharala ya mmehie ya niile o mehiere, nʼihi na ọ nwere ịhụnanya dị ukwuu. Ma onye nwetara mgbaghara dị nta, na-enwe ịhụnanya dị nta.”\wj* 
\p  
\v 48 Mgbe ahụ ọ gwara ya sị, \wj “A gbagharala gị mmehie gị.”\wj* 
\p  
\v 49 Ma ndị ọzọ soro ya nọdụ na-eri nri bidoro ikwu nʼetiti onwe ha na-asị, “Onye bụ onye a nwere ike ọ bụladị ịgbaghara mmehie?” 
\p  
\v 50 Ọ sịrị nwanyị ahụ, \wj “Okwukwe gị azọpụtala gị, laa nʼudo.”\wj* 
\c 8  
\s1 Akụkọ ọgha mkpụrụ 
\p  
\v 1 Mgbe ihe ndị a gasịrị, ọ gara nʼobodo ukwu niile na nʼobodo nta niile na-ekwusa ma na-ewetakwara ndị mmadụ oziọma nke alaeze Chineke. Ndị ozi iri na abụọ ahụ sokwa ya,  
\v 2 na ụmụ nwanyị ụfọdụ ndị a chụpụrụ mmụọ ọjọọ site nʼime ha, gwọkwa ha nrịa nrịa: Meri Magdalin onye e sitere nʼime ya chụpụ mmụọ ọjọọ asaa,  
\v 3 na Joana nwunye Chuza onye na-elekọta ụlọeze Herọd na akụ ya niile, na Suzana, na ọtụtụ ndị ọzọ ndị ji akụ ha na-enyere ha aka. 
\p  
\v 4 Mgbe oke igwe mmadụ gbakọrọ ha na ndị mmadụ si nʼobodo dị iche iche bịakwute ya. Ọ tụụrụ ha ilu a sị,  
\v 5 \wj “Ọgha mkpụrụ pụrụ ịkụ mkpụrụ ya, mgbe ọ nọ na-agha mkpụrụ ndị a, ụfọdụ nʼime mkpụrụ ahụ dara nʼakụkụ ụzọ ebe ndị mmadụ zọrọ ha ụkwụ, ụmụ nnụnụ bịakwara tụrịa ha loo.\wj* 
\v 6 \wj Ụfọdụ nʼime ha dakwasịrị nʼelu nkume. Mgbe ha puputara chọọ ito, ha kpọnwụrụ nʼihi na mgbọrọgwụ ha enweghị ike ịmịta mmiri mkpụrụ ahụ ga-eji dị ndụ.\wj* 
\v 7 \wj Ụfọdụ dara nʼetiti ogwu, ogwu ndị a sooro ha puo ma kpagbuo ha.\wj* 
\v 8 \wj Ụfọdụ nʼime mkpụrụ dara nʼezi ala. Ha puputara, too, mịa mkpụrụ dị otu narị nʼọnụọgụgụ.”\wj* 
\p Mgbe o kwusiri nke a, ọ sịrị ha, \wj “Onye ọbụla nwere ntị ịnụ ihe, ya nụrụ.”\wj* 
\p  
\v 9 Ndị na-eso ụzọ ya jụrụ ya ihe ilu a pụtara.  
\v 10 Ọ sịrị, \wj “Ọ bụ unu ka e nyere ịmata ihe omimi niile nke alaeze Chineke, ma ndị ọzọ ga-anụ ya naanị nʼilu. Site nʼụzọ dị otu a,\wj* 
\q1 \wj “ ‘ha ga na-ele anya, ma ha agaghị ahụ ihe ọbụla.\wj* 
\q2 \wj Ha ga na-anụ ntị ma ha agaghị aghọta ihe ọbụla.’\wj*\f + \fr 8:10 \ft \xt Aịz 6:9\f* 
\p  
\v 11 \wj “Nke a bụ nkọwa ilu ahụ. Mkpụrụ ahụ bụ okwu Chineke.\wj* 
\v 12 \wj Mkpụrụ dara nʼakụkụ ụzọ nọchiri anya ndị nụrụ okwu Chineke, ma ekwensu bịara napụ ha okwu ahụ nʼobi ha, ka ha ghara ikwere ma nwetakwa nzọpụta.\wj* 
\v 13 \wj Mkpụrụ ndị ahụ dara nʼelu nkume nọchiri anya ndị nụrụ okwu Chineke jiri ọṅụ nabata ya, ma ha enweghị mgbọrọgwụ nʼime ha. Ha na-ekwere naanị nwa oge nta, ma mgbe ọnwụnwa bịara ha na-adachapụ.\wj* 
\v 14 \wj Mkpụrụ nke dara nʼetiti ogwu nọchiri anya ndị nụrụ okwu Chineke, ma mgbe ha na-aga nʼụzọ ha, echiche banyere akụ na ihe ụtọ nke ụwa na-akpagbu okwu ahụ, mee ka ha ghara ịmị mkpụrụ.\wj* 
\v 15 \wj Ma mkpụrụ ndị ahụ dara nʼezi ala nọchiri anya ndị jiri obi ghere oghe na mmụọ ziri ezi nabata okwu ahụ ma werekwa ndidi mịpụta mkpụrụ.\wj* 
\s1 Iheọkụ dị nʼelu ihe ndọkwasị 
\p  
\v 16 \wj “Ọ dịghị onye ọbụla, nke na-amụnye oriọna zoo ya nʼime igbe maọbụ dọnye ya nʼokpuru ihe ndina. Kama, ọ na-adọkwasị ya nʼelu ihe ịdọba ọkụ ka ndị ọbụla na-abata nʼụlọ ahụ jiri ya hụ ụzọ.\wj* 
\v 17 \wj Ọ dịghị ihe ọbụla zoro ezo nke na-agaghị emesịa pụta ìhè, ọ dịkwaghị ihe ọbụla dị nzuzo nke a na-aghaghị eme ka ọ pụta ìhè.\wj* 
\v 18 \wj Ya mere, kpacharanụ anya otu unu si ege ntị. Nʼihi na ọ bụ onye ahụ nwere ihe ka a ga-enye karịa, ma onye ahụ na-enweghị, ọ bụladị nke o nwere, ka a ga-anapụ ya.”\wj* 
\s1 Nne Jisọs na ụmụnne ya nwoke 
\p  
\v 19 Nʼoge a, nne ya na ụmụnne ya nwoke bịakwutere ya. Ma ha enweghị ike ịbịaru ya nso nʼihi igwe mmadụ.  
\v 20 Otu onye gwara ya sị, “Nne gị na ụmụnne gị ndị nwoke guzo nʼezi, ha chọrọ ịhụ gị.” 
\p  
\v 21 Ọ zara sị, \wj “Nne m na ụmụnne m ndị nwoke bụ ndị ahụ na-anụ okwu Chineke ma jiri ya mere ihe.”\wj* 
\s1 Jisọs emee ka ebili mmiri dajụọ 
\p  
\v 22 Otu ụbọchị, ya na ndị na-eso ụzọ ya banyere nʼụgbọ mmiri, ọ sịrị ha, \wj “Ka anyị gafee nʼofe nke ọzọ nke osimiri.”\wj* Nke a mere ha ji nụpụ ụgbọ,  
\v 23 ma mgbe ha na-aga, ọ rahụrụ ụra. Oke ifufe malitere ife nʼelu ọdọ mmiri ahụ, nke mere na mmiri na-awụbanye nʼime ụgbọ ha, mee ka ha nọrọ nʼoke nsogbu. 
\p  
\v 24 Ha gara kpọtee ya na-eti mkpu, “Nna anyị ukwu! Nna anyị ukwu! Lee na anyị nʼala nʼiyi!” 
\p O biliri, baara ifufe na ebili mmiri ahụ mba. Ha dara jụụ, ebe niile dekwara jii.  
\v 25 Ọ sịrị ha, \wj “Ebee ka okwukwe unu dị?”\wj* 
\p Ha ji oke egwu na oke iju anya jụrịta onwe ha sị, “Onye bụ onye a? Ọ na-enye ọ bụladị ifufe na ebili mmiri iwu, ha na-aṅakwa ya ntị.” 
\s1 Ọgwụgwọ nwoke mmụọ ọjọọ ji 
\p  
\v 26 Ha kwọrọ ụgbọ mmiri rute nʼala Gerazin,\f + \fr 8:26 \ft Nʼakwụkwọ ochie ụfọdụ, ị nwere ike hụ Gadarin.\f* nke dị nʼofe mmiri Galili.  
\v 27 Mgbe o si nʼụgbọ mmiri rịpụta nʼelu ala, otu nwoke obodo ahụ onye mmụọ ọjọọ bi nʼime ya zutere ya. Nwoke a ebighị nʼụlọ maọbụ yie uwe ogologo oge, ma ebe obibi ya bụ ebe a na-eli ozu.  
\v 28 Mgbe ọ hụrụ Jisọs, ọ bịara daa nʼihu ya, tie mkpu nʼoke olu sị, “Gịnị ka mụ na gị nwekọrọ Jisọs, Ọkpara Chineke Onye kachasị ihe niile elu? Biko arịọ m gị, atala m ahụhụ.”  
\v 29 Nʼihi na o nyela mmụọ ahụ na-adịghị ọcha iwu ka o site nʼime ya pụta. Ọtụtụ oge, mmụọ ọjọọ a na-ejidesi ya ike, nʼagbanyeghị na eji ụdọ igwe kee ya aka na ụkwụ, debe ebe a na-eche ya nche, ọ na-adọbisi ụdọ igwe e ji kee ya, mmụọ ọjọọ a na-eduru ya gaa nʼime ọzara. 
\p  
\v 30 Jisọs jụrụ ya sị, \wj “Gịnị bụ aha gị?”\wj* 
\p Ọ zara sị, “Lijiọn,” nʼihi na igwe mmụọ ọjọọ bi nʼime ya.  
\v 31 Ha rịọsiri ya arịrịọ ike ka ọ ghara inye ha iwu ka ha banye nʼAbis. 
\p  
\v 32 Igwe ezi nọ nʼakụkụ ugwu dị ebe ahụ nso na-akpa nri. Mmụọ ọjọọ ndị a rịọrọ Jisọs ka o nye ha ike ka ha banye nʼime ha. Jisọs nyere ha ike.  
\v 33 Mmụọ ọjọọ ndị ahụ sitere nʼime nwoke a pụọ banye nʼime ezi ndị ahụ, igwe ezi ahụ niile sitere na mkputamkpu ala ọnụ mmiri ahụ gbara ọsọ dabanyechaa nʼime mmiri ebe osimiri riri ha. 
\p  
\v 34 Mgbe ndị na-elekọta ezi ahụ hụrụ ihe mere, ha gbara ọsọ gaa nʼime obodo na nʼobodo nta niile dị gburugburu ebe ahụ kọsaa ihe mere.  
\v 35 Ndị mmadụ pụtara ịhụ ihe mere. Mgbe ha rutere ebe Jisọs nọ, ha hụrụ nwoke ahụ e si nʼime ya chụpụ mmụọ ọjọọ ndị ahụ, ebe ọ nọdụrụ ala yiri uwe ma nọrọkwa nʼezi uche ya. Egwu tụrụ ha.  
\v 36 Ndị hụrụ ka ihe a si mee kọọrọ ha ka e siri gwọọ onye ahụ mmụọ ọjọọ na-esogbu.  
\v 37 Mgbe ahụ, ndị niile bi na Gerazin na nʼobodo gbara ebe ahụ gburugburu rịọrọ Jisọs ka ọ hapụrụ ha obodo ha, nʼihi na egwu dị ukwuu tụrụ ha. Ọ banyekwara nʼime ụgbọ mmiri ahụ laghachi. 
\p  
\v 38 Nwoke a e sitere nʼime ya chụpụ mmụọ ọjọọ rịọrọ ya ka o soro ya ma o zilagara ya, sị ya,  
\v 39 \wj “Laghachi nʼezinaụlọ gị kọọrọ ha ihe niile Chineke meere gị.”\wj* Nwoke ahụ lara, gbasaa akụkọ ihe Jisọs meere ya nʼobodo ahụ niile. 
\s1 Nwa agbọghọ nwụrụ anwụ na nwanyị onye ọrịa 
\p  
\v 40 Mgbe Jisọs lọghachiri, igwe mmadụ nabatara ya nʼihi na ha niile na-eche ya.  
\v 41 Mgbe ahụ otu nwoke nke aha ya bụ Jairọs, onye bụ onyeisi nʼụlọ ekpere, bịara daa nʼala nʼụkwụ Jisọs na-arịọ ya ka ọ bịa nʼụlọ ya.  
\v 42 Nʼihi na otu nwata nwanyị ọ mụtara naanị ya, nke gbara afọ iri na abụọ nọ nʼọnụ ọnwụ. 
\p Mgbe ọ na-aga, igwe mmadụ ahụ na-akpagbu ya.  
\v 43 Ọ dị otu nwanyị nʼetiti ha nke nọrịị na-arịa ọrịa oruru ọbara afọ iri na abụọ, onye mefuru ihe niile o ji nʼaka ndị dibịa, ma ọ dịghị onye nwere ike ịgwọ ya.  
\v 44 O sitere nʼazụ ya metụ ọnụ uwe ya aka. Ngwangwa, ọrịa oruru ọbara ahụ kwụsịkwara. 
\p  
\v 45 Jisọs sịrị, \wj “Onye metụrụ m aka?”\wj* 
\p Mgbe ọ na-enweghị onye pụtara kwuo sị na ọ bụ ya. Pita gwara ya sị, “Nna anyị ukwu, igwe mmadụ gbara gị gburugburu na-adakwasịkwa gị.” 
\p  
\v 46 Ma Jisọs sịrị, \wj “Otu onye metụrụ m aka; amatara m na ike esitela nʼime m pụọ.”\wj* 
\p  
\v 47 Mgbe nwanyị ahụ hụrụ na ọ dịkwaghị ihe o nwere ike ime iji zoo onwe ya, o ji ịma jijiji bịa daa nʼụkwụ ya. Nʼihu mmadụ niile, ọ kọrọ ihe mere o ji metụ ya aka na otu e sị gwọọ ya nʼotu ntabi anya.  
\v 48 Ọ gwara ya sị, \wj “Ada m nwanyị, okwukwe gị agwọọla gị. Laa nʼudo.”\wj* 
\p  
\v 49 Mgbe ọ ka nọ na-ekwu okwu, otu onye si nʼụlọ Jairọs bụ onyeisi ụlọ ekpere, bịara sị, “Ada gị nwanyị anwụọla, enyekwala onye ozizi nsogbu ọzọ.” 
\p  
\v 50 Ma mgbe Jisọs nụrụ ozi a, ọ zara ya sị, \wj “Atụla egwu, naanị kwere, a ga-agwọkwa ya.”\wj* 
\p  
\v 51 Mgbe o rutere nʼụlọ Jairọs, o kweghị ka onye ọbụla soro ya baa nʼime ụlọ ahụ ma ọ bụghị naanị Pita, Jọn, Jemis, nne na nna nwata ahụ.  
\v 52 Nʼoge ahụ, ha niile nọ na-ebe akwa na-eru ụjụ maka nwata ahụ. Ọ sịrị ha, \wj “Unu ebezila akwa, nʼihi na ọ nwụghị anwụ kama ọ nọ nʼụra.”\wj* 
\p  
\v 53 Ha chịrị ya ọchị, nʼihi na ha matara na ọ nwụrụ anwụ.  
\v 54 Ma o jidere ya nʼaka, sị, \wj “Nwa m, bilie!”\wj* 
\v 55 Mmụọ ya lọghachiri, o bilitekwara mgbe ahụ. Ọ gwakwara ha ka ha chọọrọ ya nri ka o rie.  
\v 56 Ihe a gbara ndị mụrụ ya gharịị ma ọ nyere ha iwu ka ha ghara ịkọrọ onye ọbụla ihe mere. 
\c 9  
\s1 Jisọs ezipu ndị ozi iri na abụọ 
\p  
\v 1 Mgbe ọ kpọkọtara ndị ozi iri na abụọ ahụ, o nyere ha ike na ịchị isi nʼebe mmụọ ọjọọ niile nọ na ịgwọ ọrịa dị iche iche.  
\v 2 O nyere ha ikike, zipụ ha ikwusa alaeze Chineke na ịgwọ ndị nrịa nrịa.  
\v 3 Ọ gwara ha sị, \wj “Unu ewerekwala ihe ọbụla maka njem a, maọbụ mkpanaka maọbụ akpa, maọbụ achịcha maọbụ ego maọbụ uwe abụọ.\wj* 
\v 4 \wj Ụlọ ọbụla unu banyere, nọgidenụ nʼebe ahụ ruo mgbe unu hapụrụ obodo ahụ.\wj* 
\v 5 \wj Ma ebe ọbụla a na-anabataghị unu, kụchapụnụ aja dị nʼụkwụ unu mgbe unu na-apụ nʼobodo ahụ, ka ọ bụrụ ihe ama megide ha.”\wj* 
\v 6 Ha gara nʼobodo nta niile na-ekwusa oziọma na-agwọkwa ndị ọrịa nʼebe niile. 
\p  
\v 7 Mgbe Herọd onye ọchịchị nụrụ akụkọ banyere ihe niile merenụ, ọ gbagwojuru ya anya nʼihi na ụfọdụ mmadụ na-asị, na Jọn omee baptizim esitela na ndị nwụrụ anwụ bilie.  
\v 8 Ndị ọzọ na-asị na Ịlaịja apụtala, ebe ndị ọzọ na-asị na otu nʼime ndị amụma ochie apụtakwala ndụ ọzọ.  
\v 9 Ma Herọd sịrị, “Mụ onwe bipụrụ isi Jọn. Onye bụkwa onye a nke m na-anụ ihe banyere ya?” Ọ gụrụ ya agụụ ịhụ ya. 
\s1 Jisọs enye puku mmadụ ise nri 
\p  
\v 10 Mgbe ndị ozi a lọtara, ha kọọrọ ya ihe niile ha mere. Ọ kpọọrọ ha gaa nʼobodo a na-akpọ Betsaida ebe ha ga-anọ naanị ha.  
\v 11 Ma mgbe igwe mmadụ matara nke a, ha sooro ya. Ọ nabatara ha ma gwakwa ha okwu maka alaeze Chineke. Ọ gwọkwara ndị niile ọ dị mkpa na-emere ka ahụ dị ha mma. 
\p  
\v 12 Mgbe anwụ bidoro ịda, ndị na-eso ụzọ ya iri na abụọ bịakwutere ya sị ya, “Zilaga igwe mmadụ a ka ha gaa nʼime obodo na nʼobodo nta ndị gbara ebe a gburugburu, ka ha chọtara onwe ha nri na ebe ndina nʼihi na ebe a anyị nọ bụ ọzara.” 
\p  
\v 13 Ọ zara ha sị, \wj “Unu nye ha nri ka ha rie.”\wj* 
\p Ha zaghachiri ya sị, “Anyị nwere naanị ogbe achịcha ise na azụ abụọ. Ma ọ bụghị na anyị ga aga zụọra mmadụ ndị a niile nri.”  
\v 14 Ndị nọ nʼebe ahụ ruru puku ndị nwoke ise. 
\p Ọ gwara ndị na-eso ụzọ ya sị, \wj “Meenụ ka ha nọdụ ala nʼigwe nʼigwe, iri mmadụ ise, iri mmadụ ise.”\wj* 
\v 15 Ha mere otu ahụ, mee ka ha niile nọdụ ala.  
\v 16 O weere ogbe achịcha ise na azụ abụọ ndị ahụ, lelie anya nʼeluigwe, gọzie ma nyawaa ha, nye ndị na-eso ụzọ ya ka ha keere igwe mmadụ ahụ.  
\v 17 Ha niile riri rijuokwa afọ, a tụtụkọtara ihe fọdụrụ, tụtụjuo nkata iri na abụọ nʼiberibe achịcha fọdụrụ. 
\s1 Ọgbụgba ama Pita 
\p  
\v 18 Otu ụbọchị mgbe ọ nọ naanị ya na-ekpe ekpere, ndị na-eso ụzọ ya bịakwutere ya. Ọ jụrụ ha sị, \wj “Onye ka igwe mmadụ na-asị na m bụ?”\wj* 
\p  
\v 19 Ha zara sị, “Ụfọdụ na-asị na ị bụ Jọn omee baptizim, ndị ọzọ sị na ị bụ Ịlaịja, ndị ọzọkwa, sị na ị bụ otu nʼime ndị amụma ochie ahụ si nʼọnwụ bilie.” 
\p  
\v 20 Ma ọ jụrụ ha, \wj “Unu onwe unu, ọ bụ onye ka unu na-asị na m bụ?”\wj* 
\p Pita zara sị, “Ị bụ Kraịst nke Chineke.” 
\s1 Jisọs ekwuo ihe banyere ọnwụ ya 
\p  
\v 21 Ma ọ dọrọ ha aka na ntị, nyesiekwa ha iwu ike ka ha ghara ịgwa onye ọbụla nke a,  
\v 22 na-asị, \wj “Nwa nke Mmadụ aghaghị ịhụ ọtụtụ ahụhụ dị iche iche. Ndị okenye na ndịisi nchụaja, na ndị ozizi iwu ga-ajụ ya. Aghaghị igbu ya, ma nʼụbọchị nke atọ, a ga-eme ka o site nʼọnwụ bilie.”\wj* 
\p  
\v 23 Mgbe ahụ ọ sịkwara ha, \wj “Ọ bụrụ na onye ọbụla achọọ iso m nʼazụ, ọ ghaghị ịjụ onwe ya ma buru obe ya kwa ụbọchị na-eso m.\wj* 
\v 24 \wj Nʼihi na onye ọbụla chọrọ ịzọpụta ndụ ya ga-atụfu ya. Ma onye ọbụla nke tufuru ndụ ya nʼihi m, ga-azọpụta ya.\wj* 
\v 25 \wj Uru gịnị ka mmadụ nwere ma ọ bụrụ na o ritechaa ụwa niile nʼuru ma tufuo ndụ ya, maọbụ bụrụ onye a napụrụ ndụ ya?\wj* 
\v 26 \wj Onye ọbụla ihere m na ihere okwu m na-eme, ka ihere ya ga-emekwa Nwa nke Mmadụ mgbe ọ ga-abịa nʼebube ya, na nʼebube nke Nna ya, ya na ndị mmụọ ozi dị nsọ.\wj* 
\p  
\v 27 \wj “Nʼezie asị m unu, ụfọdụ nʼime ndị guzo nʼebe a agaghị edetụ ọnwụ ire tupu ha ahụ alaeze Chineke.”\wj* 
\s1 Nnwogha Jisọs 
\p  
\v 28 Mgbe ụbọchị asatọ gasịrị, ọ kpọọrọ Pita na Jọn na Jemis gaa nʼelu ugwu ikpe ekpere.  
\v 29 Mgbe ọ nọ na-ekpe ekpere, ụdịdị ihu ya gbanwere. Uwe ya bidoro ịchaa ọcha nke ukwuu.  
\v 30 Nʼotu ntabi anya, ha hụrụ ndị ikom abụọ ka ha na ya na-ekwu okwu. Ha bụ Mosis na Ịlaịja.  
\v 31 Ha pụtara nʼebube eluigwe dị ukwu na-ekwu banyere nlaghachi ya, nke ọ na-aga imezu na Jerusalem.  
\v 32 Pita na ndị ya na ha nọ na-arahụ ụra. Mgbe ha tetara, ha hụrụ ebube ya na ndị ikom abụọ ya na ha nọ na-ekwurịta okwu.  
\v 33 Mgbe ha na-ahapụ ya, Pita sịrị Jisọs, “Nna anyị ukwu, ọ ga-adị mma ka anyị nọrọ ebe a ka anyị wuo ụlọ ikwu atọ, otu ga-abụ nke gị, otu ga-abụ nke Mosis, otu ga-abụkwa nke Ịlaịja.” Ọ mataghị ihe ọ na-ekwu. 
\p  
\v 34 Mgbe ọ ka kpụ okwu nʼọnụ, igwe ojii pụtara kpuchie ha. Egwu tụkwara ha dị ka ha na-aba nʼigwe ojii ahụ.  
\v 35 Olu sitere nʼigwe ojii ahụ daa sị, “Onye a bụ Ọkpara m, onye m họpụtara; geenụ ya ntị.”  
\v 36 Mgbe olu ahụ kwusiri okwu, ha chọpụtara na Jisọs nọ naanị ya. Ndị na-eso ụzọ ya kpuchiri ọnụ ha, debe ihe niile nʼobi ha, ọ dịkwaghị onye ọbụla ha gwara ihe ha hụrụ. 
\s1 Ọgwụgwọ nwa nwoke mmụọ ọjọọ bi nʼime ya 
\p  
\v 37 Nʼechi ya, mgbe ha si nʼugwu ahụ rịdata, oke igwe mmadụ bịara zute ya.  
\v 38 Otu nwoke si nʼetiti igwe mmadụ ahụ jiri oke olu tie mkpu sị, “Onye ozizi, arịọ m gị ka i lee nwa m nwoke anya, nʼihi na naanị ya bụ nwa m nwere.  
\v 39 Mmụọ ọjọọ na-ejide ya mee ka ọ na-eti mkpu. Ọ na-atụda ya nʼala, na-ese ya ese, na-adọkwa ya adọ mee ka ọ na-agbọ ụfụfụ nʼọnụ. Ọ dịghị mgbe ọ na-ahapụ ya kama ọ na-echihịasị ya ahụ.  
\v 40 Arịọrọ m ndị na-eso ụzọ gị ka ha chụpụ ya, ma ha enweghị ike.” 
\p  
\v 41 Jisọs zara sị, \wj “Leenụ ọgbọ rụrụ arụ, nke na-enweghị okwukwe! Ruo olee mgbe ka mụ na unu ga-anọ, ruokwa olee mgbe ka m ga-anagide ekweghị ekwe unu? Kpọtara m nwa gị nwoke ahụ nʼebe a!”\wj* 
\p  
\v 42 Mgbe ọ na-abịa, mmụọ ọjọọ ahụ kwadara ya nʼala sesie ya ike, ma Jisọs baara mmụọ ọjọọ ahụ mba. Ọ gwọrọ nwata ahụ kpọnyekwa ya nna ya.  
\v 43 Ebube ukwu nke Chineke tụrụ ha nʼanya. 
\s1 Jisọs ekwuo ihe banyere ọnwụ ya ọzọ 
\p Ma mgbe onye ọbụla nọ na mgbagwoju anya nʼihi ọrụ ọ rụrụ, ọ sịrị ndị na-eso ụzọ ya,  
\v 44 \wj “Geenụ ntị nke ọma banyere ihe m chọrọ ịgwa unu. A ga-arara Nwa nke Mmadụ nye nʼaka ụmụ mmadụ.”\wj* 
\v 45 Ma ha aghọtaghị okwu a. E zonarịrị ya nʼebe ha nọ ka ha ghara ịghọta ya. Egwu tụkwara ha ịjụ ya ihe ọ pụtara. 
\s1 Onye karịrị ibe ya ukwuu? 
\p  
\v 46 Ịrụ ụka dapụtara nʼetiti ha banyere onye karịrị ibe ya ukwuu.  
\v 47 Ebe Jisọs ma ihe ha na-eche, ọ kpọtara otu nwantakịrị mee ka o guzo nʼakụkụ ya.  
\v 48 Ọ gwara ha sị, \wj “Onye ọbụla nabatara nwata a nʼaha m, nabatara m. Onye ọ bụlakwa nabatara m, nabatara onye zitere m. Ọ bụkwa onye dịkarịsịrị nta nʼetiti unu bụ onye kachasị ukwuu.”\wj* 
\p  
\v 49 Jọn a zaa sị, “Nna anyị ukwu, anyị hụrụ otu onye ka o ji aha gị na-achụpụ mmụọ ọjọọ. Ebe ọ na-esoghị anyị, anyị gbochiri ya.” 
\p  
\v 50 Jisọs sịrị ya, \wj “Unu egbochila ya. Nʼihi na onye ọbụla na-adịghị emegide unu dịnyeere unu.”\wj* 
\s1 Nguzogide site nʼaka ndị Sameria 
\p  
\v 51 Mgbe oge o ji alaghachi na-abịaru nso, o chere ihu ya ịga Jerusalem.  
\v 52 O zipụrụ ndị ozi, ka ha buru ya ụzọ gawa. Ka ha na-aga ha batara nʼotu obodo nta nke ndị Sameria\f + \fr 9:52 \ft Ha na ndị Izrel enweghị ezi mmekọrịta.\f* ịkwado ihe niile tupu ọ bịa;  
\v 53 ma ha jụrụ ịnabata ya nʼihi na o chere ihu ịga Jerusalem.  
\v 54 Mgbe Jemis na Jọn ndị na-eso ụzọ ya hụrụ nke a, ha sịrị ya, “Onyenwe anyị, ị chọrọ ka anyị nye iwu ka ọkụ site nʼeluigwe bịa laa ha nʼiyi?”  
\v 55 Ọ tụgharịrị bara ha mba.  
\v 56 Ma ha pụrụ banye nʼobodo nta ọzọ. 
\s1 Ihe ọ ga-efu iso Jisọs 
\p  
\v 57 Mgbe ha nọ na-aga ije a, otu nwoke sịrị ya, “Aga m eso gị gaa ebe ọbụla ị na-aga.” 
\p  
\v 58 Jisọs zara, sị, \wj “Nkịta ọhịa nwere ọnụ ebe ha na-edina, ụmụ nnụnụ nke igwe nwekwara akwụ, ma Nwa nke Mmadụ enweghị ebe ọ na-atụkwasị isi.”\wj* 
\p  
\v 59 Ọ gwara onye ọzọ sị, \wj “Soro m.”\wj* 
\p Ma ọ sịrị ya. Onyenwe anyị, “Biko, nye m ohere ka m gaa buru ụzọ lie nna m.” 
\p  
\v 60 Ma ọ sịrị ya, \wj “Hapụ ndị nwụrụ anwụ ka ha lie ndị nwụrụ anwụ ibe ha. Ma gị gaa kwusaa alaeze nke Chineke.”\wj* 
\p  
\v 61 Ma onye ọzọkwa, sịrị ya, “Aga m eso gị, Onyenwe m, ma kwere ka m buru ụzọ gaa sị ndị ezinaụlọ m nọdụnụ nke ọma.” 
\p  
\v 62 Jisọs sịrị ya, \wj “Onye ọbụla jidere aka nʼọgụ anụ ụlọ na-adọkpụ ma na-ele anya nʼazụ ekwesighị alaeze Chineke.”\wj* 
\c 10  
\s1 Jisọs ezipu iri mmadụ asaa na abụọ 
\p  
\v 1 Mgbe nke a gasịrị, Onyenwe anyị họpụtara iri mmadụ asaa na abụọ ndị ọzọ, zipụ ha mmadụ abụọ abụọ ka ha buru ya ụzọ gaa nʼobodo niile nakwa ebe niile ọ na-achọ ịga.\f + \fr 10:1 \ft Ọ bụ naanị Luk dere banyere nzipụ ezipụrụ ndị ozi iri asaa na abụọ ndị a.\f* 
\v 2 Ọ sịrị ha, \wj “Owuwe ihe ubi dị ukwuu ma ndị ọrụ dị naanị ole na ole. Ya mere, rịọọnụ Onyenwe owuwe ihe ubi ka o zite ndị ọrụ nʼowuwe ihe ubi ya.\wj* 
\v 3 \wj Gaanụ! Ma lee, ana m ezipu unu dị ka ụmụ atụrụ nʼetiti agụ.\wj* 
\v 4 \wj Unu ewerekwala ego maọbụ akpa maọbụ akpụkpọụkwụ. Unu ekelekwala onye ọbụla nʼụzọ.\wj* 
\p  
\v 5 \wj “Mgbe unu banyere nʼụlọ ọbụla, burunu ụzọ sị, ‘Udo dịrị nʼụlọ a.’\wj* 
\v 6 \wj Ọ bụrụ na mmadụ udo bi nʼụlọ ahụ, udo unu ga-adịnyekwara ya. Ọ bụrụkwanụ na onye bi nʼụlọ ahụ abụghị onye udo, udo unu ji bịa ga-alọghachitekwara unu.\wj* 
\v 7 \wj Nọgidenụ nʼebe ahụ, na-erinụ ma na-aṅụkwanụ ihe ọbụla ha nyere unu, nʼihi na onye ọrụ kwesiri ịnata ụgwọ ọrụ ya. Unu esitela nʼotu ụlọ gaa nʼụlọ ọzọ.\wj* 
\p  
\v 8 \wj “Ọ bụrụ na ndị bi nʼobodo unu batara anabata unu, rienụ ihe ọbụla ha nyere unu.\wj* 
\v 9 \wj Gwọọnụ ndị ọrịa nọ nʼebe ahụ, gwakwanụ ha sị, ‘Alaeze Chineke adịla unu nso.’\wj* 
\v 10 \wj Ma mgbe unu banyere nʼobodo ọbụla ha jụ ịnabata unu, pụọnụ gaa nʼokporoụzọ ya kwuo sị,\wj* 
\v 11 \wj ‘Ọ bụladị aja si nʼobodo a nke nyapagidere nʼụkwụ anyị, anyị na-ehichapụ ya ka ọ bụrụ ihe ịdọ aka ntị nye gị. Otu ọ dị, matakwanụ nke a, na alaeze Chineke dị nso.’\wj* 
\v 12 \wj Ana m agwa unu na nʼụbọchị ahụ, ga-akara Sọdọm mma karịa obodo ahụ.\wj* 
\p  
\v 13 \wj “Ahụhụ ga-adịrị gị Korazin. Ahụhụ ga-adịrị gị Betsaida. Nʼihi na ọ bụrụ na ọrụ ebube a rụrụ nʼime unu ka a rụrụ na Taịa na Saịdọn ha gaara echegharị ogologo oge, nọdụ nʼakwa mkpe na ntụ.\wj* 
\v 14 \wj Ọ ga-akara Taịa na Saịdọn mma nʼụbọchị ikpe karịa unu.\wj* 
\v 15 \wj Ma gị Kapanọm! Ị na-eche na a ga-ebuli gị elu ruo eluigwe? Mba! Ị ga-arịda nʼala mmụọ!\wj*\f + \fr 10:15 \ft Maọbụ, \fqa Hadis\f* 
\p  
\v 16 \wj “Onye ọbụla gere unu ntị, ọ bụ mụ ka o gere ntị. Onye ọbụla jụrụ ịnabata unu, ọ bụ mụ ka ọ jụrụ ịnabata. Onye ọbụla jụrụ ịnabata m jụrụ ịnabata onye zitere m.”\wj* 
\p  
\v 17 Iri mmadụ asaa na abụọ ahụ jiri ọṅụ lọta sị, “Onyenwe anyị, nʼaha gị, ọ bụladị ndị mmụọ ọjọọ rubeere anyị isi.” 
\p  
\v 18 Ọ sịrị ha, \wj “Ahụrụ m ekwensu ka o si nʼeluigwe daa dị ka amụma.\wj* 
\v 19 \wj Lee! Enyela m unu ikike ịzọkwasị agwọ na akpị ụkwụ, na imegide ike niile nke onye iro; ọ dịghị ihe ọbụla ga-emerụ unu ahụ.\wj* 
\v 20 \wj Otu ọ dị, unu aṅụrịla ọṅụ nʼihi na mmụọ ọjọọ rubere unu isi, kama ṅụrịanụ ọṅụ nʼihi na e deela aha unu nʼeluigwe.”\wj* 
\p  
\v 21 Nʼotu oge ahụ, o jupụtara nʼọṅụ nke Mmụọ Nsọ kwuo sị, \wj “Nna, Onyenwe eluigwe na ụwa, ana m ekele gị nʼihi na ị zonarịrị ihe ndị a nʼebe ndị ọkachamara na ndị nwere amamihe nọ, ma ị kpughere ihe ndị a niile nye ụmụntakịrị. E, Nna, otu a ka o si masị uche gị ime ya.\wj* 
\p  
\v 22 \wj “Nna m enyefeela m ihe niile nʼaka. Ọ dịghị onye maara onye Ọkpara ahụ bụ, karịa Nna ahụ. Ọ dịkwaghị onye maara Nna ahụ karịa Ọkpara na ndị ahụ Ọkpara chọrọ igosi onye Nna ya bụ.”\wj* 
\p  
\v 23 Mgbe ahụ ọ tụgharịrị gwa ndị na-eso ụzọ ya na nzuzo sị, \wj “Ngọzị na-adịrị anya nke na-ahụ ihe unu na-ahụ ugbu a.\wj* 
\v 24 \wj Ana m asị unu, na ọtụtụ ndị amụma na ndị eze ka ọ gụrụ agụụ ịhụ ihe unu na-ahụ ma ha ahụghị ya, na ịnụ ihe unu na-anụ, ma ha anụghị ya.”\wj* 
\s1 Ilu banyere ezi onye agbataobi 
\p  
\v 25 Otu ụbọchị, otu onye ozizi iwu biliri ịnwale ya. Ọ jụrụ ya, “Onye ozizi, gịnị ka m kwesiri ime ka m keta ndụ ebighị ebi?” 
\p  
\v 26 Ọ sịrị ya, \wj “Gịnị ka e dere nʼiwu? Gịnị ka ị gụtara nʼime ya?”\wj* 
\p  
\v 27 Ọ zara sị, “ ‘Ị ga-eji obi gị niile, na mkpụrụobi gị niile, na ike gị niile, na uche gị niile, hụ Onyenwe anyị bụ Chineke gị nʼanya’; ma ‘hụkwa onye agbataobi gị nʼanya dị ka onwe gị.’\f + \fr 10:27 \ft \xt Dit 6:5; Lev 19:18\f*” 
\p  
\v 28 Ọ sịrị ya, \wj “Ị zara nke ọma. Gaa mee nke a ị ga-adị ndụ.”\wj* 
\p  
\v 29 Ma iji gosi na ya bụ onye na-eme ihe ziri ezi, ọ sịrị Jisọs, “Onye kwanụ bụ onye agbataobi m?” 
\p  
\v 30 Jisọs sịrị ya, \wj “Otu nwoke sitere Jerusalem na-aga Jeriko, ọ dabara nʼaka ndị ohi, ndị gbara ya ọtọ, tiekwa ya ihe, hapụ ya nʼọnọdụ ọdịndụ-ọnwụkamma laa.\wj* 
\v 31 \wj Ma dị ka ihe si eme, otu onye nchụaja sitere ụzọ ahụ na-agafe. Mgbe ọ hụrụ ya, o sitere nʼakụkụ ụzọ nke ọzọ gafee.\wj* 
\v 32 \wj Otu a kwa, otu onye Livayị bịarutekwara nʼebe ahụ, hụ ya, ma o sitere nʼakụkụ ụzọ nke ọzọ gafeekwa.\wj* 
\v 33 \wj Ma otu onye Sameria na-aga njem, mgbe ọ bịarutere nso nʼebe ahụ; hụ ya, o nwere ọmịiko nʼahụ ya.\wj* 
\v 34 \wj Ọ gara nso nʼebe ọ nọ, jiri mmanya na mmanụ wụsa nʼọnya ya, were akwa kechie ya. Ọ tụkwasịrị ya nʼelu ịnyịnya ibu ya, buba ya nʼụlọ ndị ije ebe o lekọtara ya anya nke ọma.\wj* 
\v 35 \wj Nʼechi ya, o wepụtara mkpụrụ ego ọlaọcha abụọ nye onye na-elekọta ụlọ ndị ije ahụ sị ya, ‘Lezie ya anya nke ọma. M lọta aga m akwụghachi gị ihe ọbụla ọzọ i mefuru.’\wj* 
\p  
\v 36 \wj “Onye nʼime mmadụ atọ ndị a ka i chere bụ onye gosiri onwe ya dị ka onye agbataobi nye nwoke ahụ nke dabara nʼaka ndị ohi?”\wj* 
\p  
\v 37 Ọ sịrị, “Ọ bụ onye ahụ meere ya ebere.” 
\p Jisọs sịrị ya, \wj “Laa, gaa mee otu ahụ.”\wj* 
\s1 Nʼụlọ Mata na Meri 
\p  
\v 38 Mgbe ha na-aga nʼụzọ, ọ banyere nʼotu obodo nta ebe nwanyị a na-akpọ Mata nabatara ya nʼụlọ ya.  
\v 39 O nwere nwanne nwanyị a na-akpọ Meri nke nọdụrụ ala nʼụkwụ Onyenwe anyị na-ege ntị nʼihe ọ na-ekwu.  
\v 40 Ma uche Mata gbasasịrị agbasa ebe ọ na-akwado maka ile ọbịa. Ọ bịakwutere ya sị ya, “Onyenwe anyị, ọ bụ na o metụghị gị nʼobi na nwanne m nwanyị hapụrụ naanị m ije ozi niile? Gwa ya ka ọ bịa nyere m aka.” 
\p  
\v 41 Ma Onyenwe anyị zara ya sị, \wj “Mata, Mata, ị na-echegbu onwe gị ma na-adọgbukwa onwe gị banyere ọtụtụ ihe,\wj* 
\v 42 \wj maọbụ naanị otu ihe dị mkpa, Meri ahọrọla nke ka mma, nke a na-agaghị anapụkwa ya.”\wj* 
\c 11  
\s1 Ekpere Onyenwe anyị 
\p  
\v 1 Ọ nọ nʼotu ebe na-ekpe ekpere, mgbe o kpesịrị ekpere, otu nʼime ndị na-eso ụzọ ya sịrị ya, “Onyenwe anyị, kuziere anyị ikpe ekpere, dị ka Jọn kuziri ndị na-eso ụzọ ya.” 
\p  
\v 2 Ọ sịrị ha, \wj “Mgbe unu na-ekpe ekpere, sịnụ:\wj* 
\q1 \wj “ ‘Nna,\wj* 
\q1 \wj ka e doo aha gị nsọ\wj* 
\q1 \wj ka alaeze gị bịa.\wj* 
\q1  
\v 3 \wj Nye anyị taa nri nke ụbọchị anyị.\wj* 
\q1  
\v 4 \wj Gbaghara anyị mmehie anyị,\wj* 
\q2 \wj nʼihi na anyị na-agbaghara onye ọbụla mehiere megide anyị.\wj* 
\q1 \wj Ekwela ka anyị daba nʼime ọnwụnwa.’ ”\wj* 
\p  
\v 5 Ọ sịrị ha, \wj “Onye nʼime unu nwere enyi, ga-agakwuru ya nʼetiti abalị sị ya, ‘Enyi m, biko gbazinye m ogbe achịcha atọ,\wj* 
\v 6 \wj nʼihi na otu enyi m bịara nʼụlọ m, ma enweghị m nri ọbụla nʼụlọ m nke m ga-enye ya.’\wj* 
\v 7 \wj Ma ọ ga-esi nʼime ụlọ zaghachi sị, ‘Enyela m nsogbu, emechiela m ụzọ, mụ na ụmụ m alakpuola, enweghị m ike ibili ugbu a inye gị ihe ọbụla.’\wj* 
\v 8 \wj Agwa m unu, ọ bụ ezie na ọ gaghị ebili nye ya ihe ọbụla nʼihi na ọ bụ enyi ya, kama nʼihi nsogbu ya, ọ ga-ebili nye ya ihe ọbụla dị ya mkpa.\wj* 
\p  
\v 9 \wj “Ya mere, agwa m unu, rịọọnụ, unu ga-arịọta, chọọnụ, unu ga-achọta, kụọkwanụ aka, a ga-emeghekwara unu ụzọ.\wj* 
\v 10 \wj Nʼihi na onye na-arịọ na-arịọta, onye na-achọ na-achọta, onye na-akụ aka nʼụzọ ka a ga-emeghekwara ụzọ.\wj* 
\p  
\v 11 \wj “Onye nʼime unu bụ nna, ka nwa ya ga-arịọ ya azụ, o nye ya agwọ?\wj* 
\v 12 \wj Maọbụ rịọọ ya akwa, ọ ga-enye ya akpị?\wj* 
\v 13 \wj Ọ bụrụ na unu bụ ndị ọjọọ, maara otu esi enye ụmụ unu onyinye dị mma, karịa nke a, Nna unu nke bi nʼeluigwe aghaghị inye ha Mmụọ Nsọ bụ ndị niile na-arịọ ya.”\wj* 
\s1 Jisọs na mmụọ ọjọọ 
\p  
\v 14 Otu mgbe, ọ na-achụpụ mmụọ ọjọọ nke dara ogbi, mgbe mmụọ ọjọọ ahụ pụrụ, onye ogbi ahụ kwuru okwu. Nke a juru igwe mmadụ ahụ anya.  
\v 15 Ma ụfọdụ nʼime ha sịrị, “Ọ bụ site nʼike Belzebub eze ndị mmụọ ọjọọ ka o ji achụpụ mmụọ ọjọọ.”  
\v 16 Ndị ọzọ, iji nwalee ya, sị ya gosi ha ihe ịrịbama nke si nʼeluigwe. 
\p  
\v 17 Ma ebe ọ bụ na ọ maara ihe ha na-eche, ọ sịrị ha, \wj “Alaeze ọbụla kewaranụ megide ibe ya, ga-atọgbọrọ nʼefu, ezinaụlọ ọbụla nke kewakwara megide ibe ya ga-adakpọ.\wj* 
\v 18 \wj Ọ bụrụ na ekwensu ekewa megide onwe ya, alaeze ya ọ ga-esi aṅaa guzosie ike? Unu na-asị na m na-achụpụ mmụọ ọjọọ site nʼike Belzebub.\wj* 
\v 19 \wj Ugbu a, ọ bụrụ na m sitere nʼike Belzebub na-achụpụ mmụọ ọjọọ, ọ bụ site nʼike onye ka ụmụ unu ji na-achụpụ ha? Ya mere, ha ga-abụ ndị ikpe unu.\wj* 
\v 20 \wj Ma ọ bụrụ na m ji ike mkpịsịaka Chineke na-achụpụ mmụọ ọjọọ, mgbe ahụ alaeze Chineke abịarutela nʼebe unu nọ.\wj* 
\p  
\v 21 \wj “Mgbe nwoke siri ike ji ngwa agha chekwa obi ya, ihe o nwere ga-adịgidere ya nʼudo.\wj* 
\v 22 \wj Ma ọ bụrụ na onye ọzọ ka ya ike alụso ya ọgụ merie ya, ọ ga-anara ya ngwa agha niile bụ ihe ntụkwasị obi ya, kesakwaa ihe ọ kwatara nʼụlọ dike ahụ.\wj* 
\p  
\v 23 \wj “Onye ọbụla na-adịnyeghịrị m na-emegide m. Onye ọ bụlakwa na-adịghị eso m ekpokọta, na-ekposa ekposa.\wj* 
\p  
\v 24 \wj “Mgbe ọbụla mmụọ na-adịghị ọcha sị nʼime mmadụ pụọ, ọ na-ejegharị nʼala kpọrọ nkụ na-achọgharị ebe izuike. Ọ bụrụ na ọ chọtaghị ya, mgbe ahụ, ọ ga-asị, ‘Aga m alaghachi nʼụlọ m hapụrụ.’\wj* 
\v 25 \wj Mgbe ọ lọghachiri, ọ ga-achọpụta na a zachaala ya dozie ya nke ọma.\wj* 
\v 26 \wj Mgbe ahụ, ọ ga-apụ ga chọta mmụọ ọjọọ asaa ọzọ ndị dị njọ karịa ya. Ha niile na-abata biri nʼime onye ahụ, mee ka ọnọdụ ya dị njọ karịa ka ọ dị na mbụ.”\wj* 
\p  
\v 27 Mgbe ọ kpụ okwu a nʼọnụ, otu nwanyị sitere nʼime igwe mmadụ ahụ tie mkpu sị, “Ngọzị na-adịrị afọ mụrụ gị na ara nke e jiri zụọ gị.” 
\p  
\v 28 Ma ọ sịrị, kama, \wj “Ngọzị na-adịrị ndị na-anụ okwu Chineke, na-emekwa ha.”\wj* 
\s1 Ihe ama nke Jona 
\p  
\v 29 Dị ka igwe mmadụ ahụ na-amụba, o bidoro na-ekwu sị, \wj “Ọgbọ a bụ ọgbọ ọjọọ. Ọ na-achọ ihe ịrịbama ma ọ dịghị ihe ịrịbama a ga-ezi ya karịa ihe ịrịbama Jona.\wj* 
\v 30 \wj Nʼihi na dị ka Jona si bụrụ ihe ịrịbama nye ndị Ninive, otu a ka Nwa nke Mmadụ ga-esi bụrụkwa ihe ama nye ọgbọ a.\wj* 
\v 31 \wj Nʼụbọchị ahụ, eze nwanyị ndị ndịda ga-ebili soro ndị ọgbọ a guzo nʼikpe, maa ha ikpe, nʼihi na o sitere na nsọtụ nke ụwa bịa nụrụ okwu amamihe Solomọn, ma lee, onye karịrị Solomọn nọ nʼebe a.\wj* 
\v 32 \wj Ndị ikom Ninive ga-eso ọgbọ a bilie nʼụbọchị ikpe maa ya ikpe, nʼihi na ha chegharịrị mgbe ha nụrụ nkwusa Jona, ma lee, onye karịrị Jona ukwuu nọ nʼebe a.”\wj* 
\s1 Iheọkụ nke anụ ahụ 
\p  
\v 33 \wj “Ọ dịghị onye na-amụnye oriọna dọnye ya nʼebe zoro ezo maọbụ nʼokpuru efere, kama, ọ na-adọkwasị ya nʼelu ihe ịdọba ọkụ ka ndị na-abata nʼụlọ ahụ jiri ya hụ ụzọ.\wj* 
\v 34 \wj Anya bụ oriọna nke anụ ahụ. Ọ bụrụ na anya gị dị mma, ahụ gị niile ga-ejupụta nʼìhè. Ọ bụrụkwanụ na anya gị dị njọ, ị ga-anọ nʼọchịchịrị.\wj* 
\v 35 \wj Ya mere, lezie anya ka ị mara ka ìhè dị nʼime gị, ọ bụghị ọchịchịrị.\wj* 
\v 36 \wj Nʼihi nke a, ọ bụrụ na ahụ gị niile ejupụta nʼìhè, ọ bụrụkwa na akụkụ ọbụla agbaghị ọchịchịrị, mgbe ahụ, ahụ gị niile ga-ejupụta nʼìhè dị ka mgbe ìhè oriọna na-achakwasị gị nʼahụ.”\wj* 
\s1 Ahụhụ na-adịrị ndị Farisii na ndị ọka nʼiwu 
\p  
\v 37 Mgbe ọ na-ekwu okwu, otu onye Farisii kpọrọ ya ka ọ bịa soro ya rie nri. Ọ banyere nọrọ nʼoche nri.  
\v 38 O juru onye Farisii ahụ anya na mgbe ọ bidoro iri nri ọ kwọghị aka ya tupu ya ebido. 
\p  
\v 39 Ma Onyenwe anyị sịrị ya, \wj “Unu ndị Farisii na-asacha azụ iko mmiri na efere, mee ka ọ dị ọcha, ma ime unu jupụtara nʼanya ukwu na nʼihe ọjọọ dị iche iche.\wj* 
\v 40 \wj Ndị nzuzu! Ọ bụ na ọ bụghị onye ahụ mere azụ iko mekwara ime ya?\wj* 
\v 41 \wj Kama werenụ ihe ndị ahụ dị nʼime rụọ ọrụ ebere, ihe niile ga-adịkwara unu ọcha.\wj* 
\p  
\v 42 \wj “Ahụhụ ga-adịrị unu ndị Farisii, nʼihi na unu na-enye otu ụzọ nʼụzọ iri nʼihi mint, na mkpa akwụkwọ na-esi isi ụtọ\wj*\f + \fr 11:42 \ft Nke a na-akpọ roo\f*\wj na mkpa akwụkwọ niile dị iche iche nke ubi, ma leghara ikpe ziri ezi na ịhụnanya nke Chineke anya. Ihe niile ndị a ka unu kwesiri ime nʼelegharaghị ihe ndị ọzọ anya.\wj* 
\p  
\v 43 \wj “Ahụhụ ga-adịrị unu ndị Farisii! Nʼihi na unu na-ahụ ịnọ nʼisi oche niile nʼụlọ ekpere na ekele pụrụ iche a na-ekele unu nʼọma ahịa nʼanya.\wj* 
\p  
\v 44 \wj “Ahụhụ ga-adịrị unu, nʼihi na unu dị ka ili na-apụtaghị ihe\wj*\f + \fr 11:44 \ft Apụtaghị ihe \fqa ya bụ nke zoro ezo.\f*\wj , nke ndị mmadụ na-agafe nʼelu ha nʼihi na ha amaghị na ọ bụ ili.”\wj* 
\p  
\v 45 Nʼotu oge, otu onye ozizi iwu sịrị ya, “Onye ozizi, mgbe ị na-ekwu ihe ndị a, anyị sokwa na ndị ị na-akọcha.” 
\p  
\v 46 Ma ọ sịrị, \wj “Ahụhụ ga-adịrị unu bụ ndị ozizi iwu. Nʼihi na unu na-ebo ndị mmadụ ibu ha na-enweghị ike ibuli, ma unu onwe unu adịghị eweli ọ bụladị otu mkpịsịaka unu, ịmetụ ibu ahụ aka.\wj* 
\p  
\v 47 \wj “Ahụhụ ga-adịrị unu nʼihi na unu na-ewu ili ndị amụma bụ ndị nna nna unu ha gburu.\wj* 
\v 48 \wj Ya mere, unu bụ ndị akaebe ma kwenyekwa nʼihe ndị nna nna unu ha mere, nʼihi ha gburu ha, ma unu e wuo ili ha.\wj* 
\v 49 \wj Ọ bụ nʼihi nke a ka Chineke nʼamamihe ya ji kwuo sị, Aga m ezigara ha ndị amụma na ndị ozi, ụfọdụ ka ha ga-egbu ma ndị ọzọkwa ka ha ga-akpagbu.\wj* 
\v 50 \wj Nʼihi nke a, ọgbọ a ga-aza ajụjụ banyere ọbara ndị amụma niile a wufuru, site na mmalite nke ụwa,\wj* 
\v 51 \wj site nʼọbara Ebel ruo na nke Zekaraya, onye e gburu nʼetiti ebe ịchụ aja na ebe nsọ. E, agwa m unu, a ga-ajụ ihe banyere ha nʼaka ọgbọ a.\wj* 
\p  
\v 52 \wj “Ahụhụ ga-adịrị unu bụ ndị ozizi iwu, nʼihi na unu wepụrụ ọtụghe igodo nke amamihe. Unu onwe unu abanyeghị, ma unu gbochikwara ndị na-abata ịbata.”\wj* 
\p  
\v 53 Mgbe o si nʼebe ahụ pụọ, ndị ode akwụkwọ na ndị Farisii bidoro isogbu ya, na ịkpasu ya ikwu ọtụtụ okwu,  
\v 54 na-esiri ya ọnya, ka ha mara ma ọ ga-ekwuhie ọnụ, ka ha hụ ihe ha ga-eji jide ya. 
\c 12  
\s1 Ịdọ aka na ntị na ịgbaume 
\p  
\v 1 Nʼoge ahụ, mgbe ọtụtụ puku ndị mmadụ gbakọtara, nke mere ka ha na-azọ ibe ha ụkwụ. O buuru ụzọ bido ịgwa ndị na-eso ụzọ ya sị, \wj “Kpacharanụ anya unu banyere ihe na-eko achịcha ndị Farisii, nke bụ ihu abụọ ha.\wj* 
\v 2 \wj Nʼihi na ọ dịghị ihe ọbụla zoro ezo nke na-agaghị apụta ìhè, ọ dịkwaghị ihe e kpuchiri ekpuchi nke a na-agaghị ekpughe.\wj* 
\v 3 \wj Ihe ọbụla unu kwuru nʼọchịchịrị, a ga-anụ ya nʼihe, ihe ọbụla unu gbara nʼizu nʼime ụlọ ka a ga-ekwusa nʼelu ụlọ.\wj* 
\p  
\v 4 \wj “Ana m agwa unu, ndị enyi m, unu atụla egwu maka ndị na-egbu anụ ahụ ma e mesịa, ha apụghị ime ihe ọzọ.\wj* 
\v 5 \wj Ma aga m ezi unu onye unu ga-atụ egwu. Tụọnụ egwu Onye ahụ nwere ikike igbu anụ ahụ ma tụbakwa ya nʼọkụ ala mmụọ. E, asị m unu tụọnụ ya egwu.\wj* 
\v 6 \wj Ọ bụghị mkpụrụ ego abụọ ka a na-ere ụmụ nza ise? Ma o nweghị nke ọbụla nʼime ha Chineke chefuru.\wj* 
\v 7 \wj Nʼezie a gụrụ ọ bụladị agịrị isi dị nʼisi unu ọnụ. Unu atụla egwu, nʼihi na unu dị oke ọnụ karịa ọtụtụ ụmụ nza.\wj* 
\p  
\v 8 \wj “Ma asị m unu, na onye ọbụla kwupụtara m nʼihu ụmụ mmadụ, onye ahụ ka Nwa nke Mmadụ ga-ekwupụta nʼihu ndị mmụọ ozi nke Chineke.\wj* 
\v 9 \wj Onye ọbụla na-agọnarị m nʼihu ndị mmadụ, a ga-agọnarịkwa ya nʼihu ndị mmụọ ozi nke Chineke.\wj* 
\v 10 \wj Onye ọbụla nke ga-ekwu okwu megide Nwa nke Mmadụ, a ga-agbaghara ya, ma onye ọbụla na-ekwulu Mmụọ Nsọ, agaghị agbaghara ya.\wj* 
\p  
\v 11 \wj “Mgbe ha ga-akpọbata unu nʼihu ụlọ nzukọ, ndị ọchịchị na ndịisi, unu echegbula onwe unu otu unu ga-esi zaghachi, maọbụ ihe unu ga-aza, maọbụ ihe unu ga-ekwu.\wj* 
\v 12 \wj Nʼihi na Mmụọ Nsọ ga-ezi unu nʼoge awa ahụ, ihe unu kwesiri ikwu.”\wj* 
\s1 Ilu banyere ọgaranya dị nzuzu 
\p  
\v 13 Otu onye nʼime igwe mmadụ ahụ sịrị ya, “Onye ozizi, gwa nwanne m nwoke ka o kenye m oke nʼihe nketa anyị.” 
\p  
\v 14 Ọ sịrị ya, \wj “Nwoke, onye mere m onye ikpe maọbụ onye ndozi okwu nʼetiti unu?”\wj* 
\v 15 Ma ọ sịrị ha, \wj “Kpachapụnụ anya! Nọrọnụ na nche banyere oke ọchịchọ niile, nʼihi na ndụ mmadụ adabereghị nʼọtụtụ ihe o nwere.”\wj* 
\p  
\v 16 Ọ tụụrụ ha ilu a sị, \wj “Otu ọgaranya nwere ala mịrị nnọọ mkpụrụ dị ukwuu.\wj* 
\v 17 \wj O chere nʼime onwe ya sị, ‘Gịnị ka m ga-eme nʼihi na enweghị m ebe m ga-echekwa mkpụrụ m?’\wj* 
\p  
\v 18 \wj “Ya mere ọ sịrị, ‘Ihe m ga-eme bụ nke a, aga m akwatu ọba m, wuo nke ka ya ukwuu, bụ ebe m ga-echekwa mkpụrụ m na ihe ndị ọzọ.\wj* 
\v 19 \wj Ya mere aga m agwa mkpụrụobi m, “I nwere ọtụtụ ezi ihe ga-ezuru gị ọtụtụ afọ, nʼihi ya zuru ike, rie, ṅụọ ma nweekwa obi ụtọ.” ’\wj* 
\p  
\v 20 \wj “Ma Chineke gwara ya sị, ‘Onye nzuzu, nʼabalị a ka a ga-achọ mkpụrụobi gị nʼaka gị. Ihe niile ị kpakọtara nke onye ka ha ga-abụ?’\wj* 
\p  
\v 21 \wj “Otu a ka ọ ga-adịrị onye ọbụla na-akpadoro naanị onwe ya akụ, ma ọ baghị ụba nʼebe Chineke nọ.”\wj* 
\s1 Echegbula onwe gị 
\p  
\v 22 Ọ gwara ndị na-eso ụzọ ya, \wj “Ya mere, asị m unu, unu echegbula onwe unu banyere ndụ unu, ihe unu ga-eri, maọbụ banyere ahụ unu, ihe unu ga-eyi.\wj* 
\v 23 \wj Nʼihi na ndụ dị mkpa karịa ihe oriri, anụ ahụ dịkwa mkpa karịa uwe.\wj* 
\v 24 \wj Tuleenụ ugolọma. Ha adịghị akụ maọbụ ghọrọ mkpụrụ ọbụla. Ha enweghị ụlọakụ maọbụ ọba, ma Chineke na-azụ ha nri. Unu ọ dịghị oke ọnụahịa karịa anụ ufe ndị a.\wj* 
\v 25 \wj Onye nʼime unu pụrụ itinye otu nkeji nʼogologo ụbọchị nke ndụ ya site nʼichegbu onwe ya?\wj* 
\v 26 \wj Ebe unu na-apụghị ime ihe nta dị otu a, gịnị mere unu ji echegbu onwe unu banyere ihe ndị ọzọ?\wj* 
\p  
\v 27 \wj “Tuleenụ otu okoko ọhịa lili si eto. Ha adịghị arụ ọrụ ọbụla maọbụ tụọ ogho. Ma asị m unu, ọ bụladị Solomọn nʼebube nke ịbụ eze ya niile, eyighị uwe ọbụla mara mma dị ka otu nʼime okoko osisi nke ọhịa ndị a.\wj* 
\v 28 \wj Ma ọ bụrụ na Chineke si otu a chọọ ahịhịa efu nke ubi mma, nke pụrụ ịdị ndụ taa ma echi atụba ha nʼite ọkụ, ọ bụ na ọ pụghị i si otu a chọọ unu mma karịa? Unu ndị okwukwe nta.\wj* 
\v 29 \wj Ya mere, unu adọgbula onwe unu maka ihe unu ga-eri maọbụ ihe unu ga-aṅụ. Unu echegbukwala onwe unu.\wj* 
\v 30 \wj Nʼihi na ọ bụ ihe ndị a ka ndị mba nke ụwa na-achụso, ma Nna unu makwara na ha dị unu mkpa.\wj* 
\v 31 \wj Kama chọọnụ alaeze ya, a ga-atụkwasịkwara unu ihe ndị a niile.\wj* 
\p  
\v 32 \wj “Unu atụla egwu, igwe atụrụ nta, nʼihi na ọ tọrọ Nna unu ụtọ inye unu alaeze ahụ.\wj* 
\v 33 \wj Reenụ ihe unu nwere nyekwanụ ndị ogbenye. Meerenụ onwe unu akpa na-agaghị aka nka, nʼọba akụ nʼeluigwe, ebe onye ohi na-adịghị abịa nso, nla adịghị erichapụkwa ya.\wj* 
\v 34 \wj Nʼihi na ebe ọbụla akụ unu dị ka obi unu ga-adịkwa.”\wj* 
\s1 Ịnọ na nche 
\p  
\v 35 \wj “Keenụ ajị nʼume, meenụ ka oriọna unu na-enwu enwu.\wj* 
\v 36 \wj Dịnụ ka ndị ohu na-echere nlọghachi nke nna ha ukwu, onye gara oriri agbamakwụkwọ, bụ onye ha ga-emeghere ụzọ ngwangwa mgbe ọ lọtara kụọ aka.\wj* 
\v 37 \wj Ndị ohu ahụ ga-abụ ndị a gọziri agọzi, bụ ndị onyenwe ha ga-ahụ na ha nọ na nche mgbe ọ ga-alọghachi. Nʼezie asị m unu na ọ ga-eke belịt ya nʼukwu ya, mekwa ka ha nọdụ ala na tebul iri ihe, ọ ga-abịakwa jere ha ozi.\wj* 
\v 38 \wj Ngọzị ga-adịrị ndị ohu ahụ onye nwe ha ga-ahụ ka ha nọ na njikere, ọ bụladị ma ọ lọghachiri nʼetiti abalị, maọbụ nʼezigbo isi ụtụtụ.\wj* 
\v 39 \wj Maranụ nke a: ọ bụrụ na onyenwe ụlọ maara oge awa onye ohi ga-eji abịa nʼụlọ ya, ọ gaghị ekwe ka onye ohi ahụ tiwaa ụlọ ya.\wj* 
\v 40 \wj Unu kwesiri ịnọ na njikere nʼihi na Nwa nke Mmadụ ga-abịa nʼoge awa unu na-atụghị anya ya.”\wj* 
\p  
\v 41 Pita sịrị ya, “Onyenwe anyị, ị tụrụ ilu a nʼihi anyị, ka ọ bụ maka onye ọbụla?” 
\p  
\v 42 Ma Onyenwe anyị sịrị, \wj “Onye bụ ohu ahụ nke kwesiri ntụkwasị obi ma nwekwa uche, nke onyenwe ya mere onyeisi ụmụodibo ya niile, ka ọ na-enye ha nri mgbe o kwesiri?\wj* 
\v 43 \wj Ngọzị na-adịrị ohu ahụ nke onyenwe ya ga-ahụ ka ọ na-arụ ọrụ ahụ mgbe ọ ga-alọghachi.\wj* 
\v 44 \wj Nʼezie asị m unu, ọ ga-eme onye nke ahụ onyeisi nke ihe niile o nwere.\wj* 
\v 45 \wj Ma ọ bụrụ na ohu ahụ asị nʼobi ya, ‘Onyenwe m na-anọ ọdụ ịlọta,’ ọ bụrụkwa na ọ malite itigbu ụmụodibo ndị ọzọ, bụ ndị ikom na ndị inyom na-eje ozi, na iri ihe oriri, na ịṅụkwa ihe ọṅụṅụ na ịṅụbiga mmanya oke.\wj* 
\v 46 \wj Nna ukwu ohu ahụ ga-alọta nʼụbọchị ọ na-atụghị anya, nʼoge awa ọ na-amakwaghị. Ọ ga-egburisikwa ya, nye ya ọnọdụ nʼetiti ndị na-ekweghị ekwe.\wj* 
\p  
\v 47 \wj “Ohu ahụ maara ihe nna ya ukwu chọrọ ma hapụ ịnọ na njikere, maọbụ ime ya, ka a ga-apịasi ụtarị ike.\wj* 
\v 48 \wj Ma onye na-amaghị ama ma mee ihe kwesiri ka a pịa ya ụtarị, a ga-apịa ya ụtarị ole na ole. Nʼihi na ọ bụ onye e nyere ihe hiri nne ka a ga-ele anya ịnata ihe hiri nne nʼaka. Onye e nyekwara ihe ukwu nʼaka idebe, nʼaka ya ka a ga-achọ ihe nke kachasịnụ.\wj* 
\s1 Ọ bụghị udo kama nkewa 
\p  
\v 49 \wj “A bịara m iwebata ọkụ nʼelu ụwa, ọ gaara adịrị m nọ mma ma ọ bụrụ na ọ malitelarị inwu!\wj* 
\v 50 \wj Enwere m baptizim nke m na-aghaghị ime, ma aga m anọgide nʼoke ihe mgbu tutu e mezuo ya\wj* 
\v 51 \wj Unu chere na m bịara iweta udo nʼụwa? Asị m unu mbaa, kama nkewa.\wj* 
\v 52 \wj Site ugbu a gawa, mmadụ ise si nʼotu ezinaụlọ ga-ekewa megide onwe ha, atọ megide abụọ, abụọ megide atọ.\wj* 
\v 53 \wj Ha ga-ekewa; nna megide nwa ya nwoke, nwa nwoke ga-emegidekwa nna ya, nne megide nwa ya nwanyị, nwa nwanyị megidekwa nne ya, nne di megide nwunye nwa ya, nwunye nwa megide nne di ya.”\wj* 
\s1 Ịkọwa oge 
\p  
\v 54 Ọ gwakwara igwe mmadụ ahụ sị, \wj “Mgbe unu hụrụ urukpu ojii ka ọ na-ebili nʼọdịda anyanwụ, unu na-eme ngwangwa sị, ‘Mmiri ga-ezo,’ ọ na-ezokwa.\wj* 
\v 55 \wj Mgbe unu hụrụ na ifufe na-esite na ndịda na-efe, unu na-asị, Oke okpomọkụ ga-adị, ọ na-emekwa otu ahụ.\wj* 
\v 56 \wj Ndị ihu abụọ! Unu matara ịkọwa ihu ala na mbara eluigwe. Gịnị mere unu apụghị ịkọwa oge dị ugbu a?\wj* 
\p  
\v 57 \wj “Gịnị mere unu adịghị ekpebiri onwe unu ihe ziri ezi?\wj* 
\v 58 \wj Ọ bụrụ na gị na onye na-ebo gị ebubo esoro na-aga nʼihu ọkaikpe, gbalịsie ike ka gị na ya kpezie nʼụzọ, ma ọ bụghị otu a, ọ ga-akpọpụ gị nʼihu onye ọkaikpe, ma eleghị anya ọkaikpe ahụ ga-arara gị nye nʼaka ọkaikpe ukwu, ọkaikpe ukwu ga-ararakwa gị nye nʼaka onye na-eje ozi nʼụlọikpe, bụ onye ga-etinye gị nʼụlọ mkpọrọ.\wj* 
\v 59 \wj Asị m gị, ị gaghị e si nʼebe ahụ pụta ruo mgbe ị kwụghachiri ọ bụladị otu kobo nke ikpeazụ.”\wj* 
\c 13  
\s1 Chegharịa maọbụ laa nʼiyi 
\p  
\v 1 Mgbe ahụ, ụfọdụ ndị nọ nʼebe ahụ gwara ya banyere ndị Galili ahụ Pailet jiri ọbara ha gwakọta nʼaja ha chụrụ.  
\v 2 Ọ zara sị ha, \wj “Unu chere na ndị Galili a tara ụdị ahụhụ a bụ ndị mmehie karịa ndị Galili niile?\wj* 
\v 3 \wj Mba! Asị m unu, ọ bụrụ na unu echegharịghị, unu niile ga-esi otu ahụ laa nʼiyi.\wj* 
\v 4 \wj Ka unu chere na mmadụ iri na asatọ ahụ, ndị mgbidi aja ụlọ elu Sailọm dagburu bụ ndị ikpe mmehie mara karịa ndị niile bi na Jerusalem?\wj* 
\v 5 \wj Mba! Asị m unu, ọ bụrụ na unu echegharịghị, unu niile ga-ala nʼiyi dị ka ha.”\wj* 
\p  
\v 6 Ya mere, ọ tụụrụ ha ilu a sị, \wj “Otu nwoke kụrụ osisi fiig nʼubi vaịnị ya, ma mgbe ọ bịara chọọ nʼelu ya, ma ọ hụghị mkpụrụ ọbụla.\wj* 
\v 7 \wj Ya mere, ọ gwara onye ọrụ ubi ya sị, ‘Nʼime afọ atọ ndị a ka m bịara ka m ghọrọ mkpụrụ site nʼosisi fiig a, ma ahụghị m mkpụrụ ọbụla. Gbutuo ya! Gịnị mere ọ ga-eji na-erikọ nri dị nʼala ubi a?’\wj* 
\p  
\v 8 \wj “Ọ zara sị ya, ‘Nna m ukwu, hapụkwa ya nʼafọ a, ka m gwuo ala gburugburu, hinye ya aja nri ala nʼukwu.\wj* 
\v 9 \wj Ọ bụrụ na ọ mịa mkpụrụ nʼafọ ọzọ, ọ dị mma, ọ bụrụkwa na ọ mịghị, i nwere ike gbutuo ya. ’ ”\wj* 
\s1 Ọgwụgwọ onye ọrịa nʼụbọchị izuike 
\p  
\v 10 Nʼụbọchị izuike ndị Juu, ọ banyere nʼime otu ụlọ ekpere na-ezi ihe.  
\v 11 Otu nwanyị nọkwa nʼebe ahụ, onye mmụọ nrịa nrịa mere ka ahụ ghara ị dị ya ike afọ iri na asatọ. Ọ na-ehu ehu, o nwekwaghị ike iguzo ọtọ kwem.  
\v 12 Mgbe Jisọs hụrụ ya, ọ kpọrọ ya sị ya, \wj “Nwanyị emeela ka i nwere onwe gị site nʼọrịa gị.”\wj* 
\v 13 Mgbe o bikwasịrị ya aka, ngwangwa, o guzooro kwem malite na-eto Chineke. 
\p  
\v 14 Ma onyendu ụlọ ekpere ahụ were iwe nke ukwuu nʼihi na Jisọs gwọrọ ọrịa nʼụbọchị izuike. Ọ gwara igwe mmadụ ahụ okwu sị, “E nwere ụbọchị isii nʼime izu ụka mgbe mmadụ kwesiri ịrụ ọrụ. Ya mere, bịanụ ka a gwọọ unu nʼụbọchị ndị a, ọ bụghị nʼụbọchị izuike.” 
\p  
\v 15 Ma Onyenwe anyị zara ya sị, \wj “Unu ndị ihu abụọ! Ọ dị onye nʼime unu na-adịghị atọpụ oke ehi ya maọbụ ịnyịnya ibu ya, site nʼụlọ anụmanụ, kpụpụ ya ebe ọ ga-aṅụ mmiri nʼụbọchị izuike?\wj* 
\v 16 \wj O kwesighị ka a tọpụ nwanyị a bụ ada Ebraham nʼagbụ ekwensu kere ya ogologo afọ iri na asatọ, nʼụbọchị izuike, mee ka o nwere onwe ya?”\wj* 
\p  
\v 17 Mgbe o kwuru nke a, ihere mere ndị iro ya niile, ma ndị mmadụ nọ nʼebe ahụ ṅụrịrị ọṅụ nʼihi ọrụ ebube niile ọ na-arụ. 
\s1 Ilu mkpụrụ mọstaadị na ihe na-eko achịcha 
\p  
\v 18 Ya mere, ọ na-ekwu sị, \wj “Gịnị ka alaeze Chineke yiri? Gịnịkwa ka m ga-eji tụnyere ya?\wj* 
\v 19 \wj O yiri mkpụrụ mọstaadị nke mmadụ kụrụ nʼubi ya a gbara ogige. O toro ghọọ osisi, nke ụmụ nnụnụ na-ezukwa ike nʼalaka ya.”\wj* 
\p  
\v 20 Ọzọ, ọ sịrị, \wj “Gịnị ka m ga-eji tụnyere alaeze Chineke?\wj* 
\v 21 \wj Ọ dị ka ihe na-eko achịcha\wj*\f + \fr 13:21 \ft Maọbụ, \fqa yiist\f*\wj nke nwanyị gwakọtara na ọtụtụ atọ nke ụtụ ọka, tutu ruo mgbe o koro ụtụ ọka ahụ niile.”\wj* 
\s1 Ụzọ dị warawara 
\p  
\v 22 O jegharịrị nʼobodo ukwu na nʼobodo nta niile na-ezi ihe, ka ọ na-aga Jerusalem.  
\v 23 Otu onye sịrị ya, “Onyenwe m, ndị a ga-azọpụta ha ga-adị ole na ole?” 
\p Ọ sịrị ha,  
\v 24 \wj “Gbalịsienụ ike banye site nʼọnụ ụzọ dị warawara, nʼihi na ana m a gwa unu na ọtụtụ ga-achọ ịbanye ma ha agaghị enwe ike.\wj* 
\v 25 \wj Ọ bụrụ na nna nwe ụlọ ebilie mechie ọnụ ụzọ, unu ga-eguzo na-ezi na-akụ aka nʼụzọ na-asị, ‘Onyenwe anyị meghere anyị ụzọ.’\wj* 
\p \wj “Na nzaghachi, ọ ga-asị, ‘Amaghị m ebe unu si bịa.’\wj* 
\p  
\v 26 \wj “Nʼoge ahụ, unu ga-asị, ‘Anyị na gị rikọrọ, ṅụkọkwaa, ị kuzikwara nkuzi nʼogbe anyị.’\wj* 
\p  
\v 27 \wj “Ma ọ ga-asị, ‘Amaghị m ebe unu siri bịa. Pụọnụ nʼihu m, unu ndị ajọ omume.’\wj* 
\p  
\v 28 \wj “Ịkwa akwa na ịta ikikere eze ga-adịkwa mgbe unu ga-ahụ Ebraham, na Aịzik na Jekọb na ndị amụma niile ka ha nọ nʼalaeze Chineke; ma unu onwe unu abụrụ ndị a chụpụrụ nʼezi.\wj* 
\v 29 \wj Ndị mmadụ ga-esite nʼọwụwa anyanwụ, nakwa ọdịda anyanwụ, na nʼugwu na ndịda nke ụwa bịa nọdụ nʼoriri nʼime alaeze Chineke.\wj* 
\v 30 \wj Ma lee, ndị bu ụzọ ga-aghọ ndị ikpeazụ, ma ndị ikpeazụ ga-aghọ ndị bu ụzọ.”\wj* 
\s1 Mwute Jisọs nwere nʼihi Jerusalem 
\p  
\v 31 Nʼoge awa ahụ, ụfọdụ ndị Farisii bịakwutere ya sị ya, “Si nʼebe a pụọ, nʼihi na Herọd na-achọ igbu gị.” 
\p  
\v 32 Ọ sịrị ha, \wj “Gaa gwaranụ m nkịta ọhịa ahụ, lee, ana m achụpụ mmụọ ọjọọ, gwọọkwa ndị ọrịa taa na echi, ma nʼụbọchị nke atọ ka m ga-arụcha ọrụ m.\wj* 
\v 33 \wj Ma otu ọ dị, aga m aga nʼihu nʼụzọ m taa, na echi na nwanne echi, nʼihi na nʼezie, ọ dịghị onye amụma ga-anwụ nʼebe ọzọ na-abụghị na Jerusalem.\wj* 
\p  
\v 34 \wj “O Jerusalem! Jerusalem! Gị onye na-egbu ndị amụma ma na-ejikwa nkume atụgbu ndị e ziteere gị. Ọtụtụ mgbe ka m gbalịrị ịchịkọta ụmụ gị dị ka nne ọkụkụ sị achịkọta ụmụ ya nʼokpuru nku ya, ma unu ekweghị.\wj* 
\v 35 \wj Lee, a hapụrụla unu ụlọ unu. Ma agwa m unu, unu agaghị ahụ m anya ọzọ ruo mgbe oge ahụ ga-abịa, mgbe unu ga-asị, ‘Onye a gọziri agọzi ka onye ahụ bụ nke na-abịa nʼaha Onyenwe anyị.’\wj*\f + \fr 13:35 \ft \xt Abụ 118:26\f* \wj ”\wj* 
\c 14  
\s1 Jisọs agaa nʼụlọ onye Farisii 
\p  
\v 1 Otu ụbọchị izuike, mgbe ọ gara iri ihe nʼụlọ otu onyendu ndị Farisii, ha nọ na-ele ya anya nke ọma.  
\v 2 Ma lee, otu nwoke ahụ ya zara aza nọkwa nʼihu ya ebe ahụ.  
\v 3 Jisọs jụrụ ndị Farisii na ndị ozizi iwu sị, \wj “O ziri ezi nʼiwu ịgwọ ọrịa nʼụbọchị izuike ka ọ bụ na o zighị?”\wj* 
\v 4 Ma ha e kwughị okwu ọbụla. Ya mere ọ kpọrọ ya, gwọọ ya ma sị ya laa. 
\p  
\v 5 Ọ sịrị ha, \wj “Ọ bụrụ na otu nʼime unu nwere nwa nwoke maọbụ oke ehi nke dabara nʼime olulu mmiri nʼụbọchị izuike, ọ bụ na ọ gaghị eme ngwangwa dọpụta ya?”\wj* 
\v 6 Ma ha enweghị ike ịza ajụjụ a. 
\p  
\v 7 Mgbe ọ hụrụ otu ndị a kpọrọ oriri si họrọ naanị oche ndị a na-asọpụrụ, oche ndị a na-asọpụrụ, ọ tụrụ ha ilu sị,  
\v 8 \wj “Mgbe mmadụ ọbụla kpọrọ gị oriri nʼọlụlụ di na nwunye, abatala nọdụ nʼoche ndị a na-asọpụrụ, nʼihi na eleghị anya, onye kpọrọ gị oriri kpọkwara onye ka gị nwe nsọpụrụ.\wj* 
\v 9 \wj Nʼihi na onye ahụ kpọrọ unu oriri nwere ike bịakwute gị sị gị, nye nwoke a ọnọdụ gị. Mgbe ahụ, ị ga-ebili nʼanya ihere gaa nọdụ nʼoche dịkarịsịrị ala.\wj* 
\v 10 \wj Ma mgbe a kpọrọ gị, nọdụ nʼoche dị ala, ka ọ ga-abụ na onye kpọrọ gị oriri bịa, ọ ga-asị gị ‘Enyi m, rigota nʼebe a ka elu.’ Mgbe ahụ, ị ga-enwekwa ugwu nʼanya ndị niile a kpọrọ gị na ha oriri.\wj* 
\v 11 \wj Nʼihi na onye ọbụla ga-ebuli onwe ya elu ka a ga-eweda nʼala, ma onye ọbụla na-eweda onwe ya ala ka a ga-ebuli elu.”\wj* 
\p  
\v 12 Ọ gwara onye ahụ kpọrọ ya oriri sị, \wj “Mgbe ị na-akpọ oriri nke nri ehihie maọbụ nke nri anyasị, akpọla naanị ndị enyi gị maọbụ ụmụnne gị ndị nwoke maọbụ ndị ikwu na ibe gị, maọbụ ndị agbataobi gị bara ọgaranya, nʼihi ma eleghị anya, ha pụrụ ịkpọkwa gị na mgbe nke ha, sị otu a kwụghachi gị ụgwọ.\wj* 
\v 13 \wj Kama mgbe ị na-akpọ oriri, kpọọ ndị ogbenye na ndị ọlụsị na ndị ngwụrọ na ndị ìsì.\wj* 
\v 14 \wj A ga-agọzikwa gị, nʼihi na ha enweghị ike ịkwụghachi gị, a ga-akwụghachikwa gị mgbe ndị ezi omume ga-ebili nʼọnwụ.”\wj* 
\s1 Ilu banyere oke oriri 
\p  
\v 15 Mgbe otu nʼime ndị a kpọrọ oriri nụrụ nke a, ọ sịrị ya, “Ngọzị ga-adịrị onye ga-eso rie oriri nʼalaeze Chineke.” 
\p  
\v 16 Ma ọ sịrị ya, \wj “Otu onye na-akwado oke oriri kpọkwa ọtụtụ mmadụ oku.\wj* 
\v 17 \wj Mgbe oge oriri ahụ ruru, o zipụrụ ohu ya ka ọ ga gwa ndị ahụ ọ kpọrọ sị, ‘Bịanụ, nʼihi na e dozichaala ihe niile.’\wj* 
\p  
\v 18 \wj “Ma ha niile nʼotu nʼotu malitere inye ọsịsa. Onye nke mbụ sịrị, ‘Azụrụ m iberibe ala ọhụrụ, ọ dịkwa mkpa na m ga-eje hụ ya, biko gbaghara m, agaghị m abịa.’\wj* 
\p  
\v 19 \wj “Onye nke ọzọ sịrị, ‘Azụrụ m ehi e ji arụ ọrụ ubi, iri e jikọrọ abụọ abụọ. Ana m aga ugbu a ka m nwalee ha, biko gbaghara m, agaghị m abịa.’\wj* 
\p  
\v 20 \wj “Ma onye ọzọ sịkwara, ‘Alụrụ m nwunye ọhụrụ, nʼihi nke a agaghị m abịa.’\wj* 
\p  
\v 21 \wj “Ohu ahụ lọtara, kọọrọ nna ya ukwu ihe ndị ahụ a kpọrọ oriri kwuru. Mgbe ahụ, iwe dị ukwuu were nna ya ukwu, nke a mere ka o zipụ ohu ya sị ya, ‘Gaa ngwangwa nʼokporoụzọ ukwu na nʼokporoụzọ nta dị nʼobodo a, kpọbata ndị ogbenye, na ndị ụkwụ rụrụ, na ndị ìsì na ndị ngwụrọ.’\wj* 
\p  
\v 22 \wj “Ohu ahụ sịrị, ‘Nna m ukwu, emeela m ihe i kwuru, ma ohere ka fọdụrụ.’\wj* 
\p  
\v 23 \wj “Nna ukwu ahụ sịrị ohu ahụ, ‘Gaakwa nʼokporoụzọ ukwu na okporoụzọ nta, mee ka ndị mmadụ bata nʼụlọ m, ka ụlọ m jupụta na mmadụ.\wj* 
\v 24 \wj Nʼihi na agwa m unu, ọ dịghị otu onye nʼime ndị ahụ a kpọrọ oriri ga-edetụ nri m ọnụ.’ ”\wj* 
\s1 Ihe ọ na-efu iso Jisọs 
\p  
\v 25 Ugbu a, oke igwe mmadụ na-eso ya ma ọ tụgharịrị sị ha:  
\v 26 \wj “Onye ọbụla chọrọ iso m, ma o bụghị ụzọ kpọ nne na nna ya, na nwunye ya, na ụmụ ya, na ụmụnne ya ndị nwoke na ndị nwanyị tinyekwara ndụ nke ya onwe ya asị, apụghị ịbụ onye na-eso ụzọ m.\wj* 
\v 27 \wj Onye ọbụla na-eburughị obe ya soro m, enweghị ike ịbụ onye na-eso ụzọ m.\wj* 
\p  
\v 28 \wj “Ọ dị onye ọbụla nʼime unu chọrọ iwu ụlọ elu, na-agaghị ebu ụzọ nọdụ ala, gbakọọ ihe ọ ga-efu ya, iji chọpụta ma o nwekwara ego ga-ezu iwucha ya?\wj* 
\v 29 \wj Nʼihi na ọ bụrụ na ọ tọọ ntọala ma o nwekwaghị ike wuchaa ya, onye ọbụla hụrụ ya ga-achị ya ọchị,\wj* 
\v 30 \wj na-asị, ‘Nwoke a malitere iwu ụlọ, ma o nweghị ike wuchaa ya.’\wj* 
\p  
\v 31 \wj “Maọbụ olee eze chọrọ ịlụso eze ibe ya ọgụ, ọ gaghị ebu ụzọ nọdụ ala tulee ma puku ndị agha iri ya ọ ga-ezuru ya iji lụso onye ji iri puku ndị agha abụọ abịakwute ya ọgụ?\wj* 
\v 32 \wj Ọ bụrụ na o nweghị ike, ọ ga-ezipụ ozi rịọ ka e kpee udo mgbe onye nke ọzọ ka nọ nʼebe dị anya.\wj* 
\v 33 \wj Nʼụzọ dị otu a, onye ọbụla na-ajụghị ihe niile o nwere, apụghị ịbụ onye na-eso ụzọ m.\wj* 
\p  
\v 34 \wj “Nnu dị mma, ma ọ bụrụ na ọ dịghị atọkwa ụtọ, a ga-eji gịnị mee ka ọ tọọ ụtọ ọzọ?\wj* 
\v 35 \wj Ọ bakwaghị uru nye ala maọbụ iji mee nri ala. Kama ọ bụ itufu ya.\wj* 
\p \wj “Onye ọbụla nwere ntị ịnụ ihe, ya nụrụ.”\wj* 
\c 15  
\s1 Ilu maka atụrụ furu efu 
\p  
\v 1 Ugbu a, ndị ọna ụtụ na ndị mmehie na-abịa ya nso ịnụta ihe ọ na-ekwu.  
\v 2 Ndị Farisii na ndị ozizi iwu tamuru ntamu na-asị, “Nwoke a na-anabata ndị mmehie sorokwa ha na-eri nri.” 
\p  
\v 3 Ya mere, ọ tụrụ ha ilu a sị,  
\v 4 \wj “Ọ bụrụ na otu onye nʼime unu enwee narị atụrụ ma otu nʼime ha akpafuo. Ọ bụ na ọ gaghị ahapụ iri atụrụ itoolu na itoolu ahụ fọdụrụ nʼọzara, pụọ ịchọgharị otu ahụ kpafuru ruo mgbe ọ chọtara ya?\wj* 
\v 5 \wj Mgbe ọ chọtara ya, ọ ga-eji ọṅụ tụkwasị ya nʼubu ya.\wj* 
\v 6 \wj Mgbe ọ lọtara nʼụlọ ya, ọ ga-akpọkọta ndị enyi ya na ndị agbataobi ya sị ha, ‘Soronụ m ṅụrịa ọṅụ nʼihi na achọtala m atụrụ m furu efu.’\wj* 
\v 7 \wj Asị m unu, nʼụzọ dị otu a, ọṅụ dị ukwu ga-adị nʼeluigwe nʼihi otu onye mmehie nke chegharịrị, karịa iri itoolu na itoolu ndị ezi omume bụ ndị nchegharị na-adịghị mkpa.\wj* 
\s1 Ilu maka mkpụrụ ego furu efu 
\p  
\v 8 \wj “Maọbụ olee nwanyị nke nwere mkpụrụ ọlaọcha iri, ọ bụrụ nʼotu nʼime ha adafuo. Ọ gaghị amụnye oriọna, zaa ime ụlọ ya ịchọ otu mkpụrụ ego ahụ tutu ọ chọta ya?\wj* 
\v 9 \wj Mgbe ọ chọtara otu mkpụrụ ego ahụ, ọ ga-akpọ ndị enyi ya na ndị agbataobi ya sị ha, ‘Soronụ m ṅụrịa ọṅụ nʼihi na achọtala m ego m furu efu.’\wj* 
\v 10 \wj Nʼụzọ dị otu a, asị m unu, ọṅụ ga-adị nʼihu ndị mmụọ ozi Chineke nʼihi otu onye mmehie nke chegharịrị.”\wj* 
\s1 Ilu maka nwa mmefu 
\p  
\v 11 O kwukwaara sị, \wj “Otu nwoke mụtara ụmụ nwoke abụọ.\wj* 
\v 12 \wj Nwa ya nke nta sịrị nna ya, ‘Nna, kenye m oke ruuru m nʼihe niile i nwere.’ Ya mere, o kenyere ya oke nke ya site nʼihe o nwere.\wj* 
\p  
\v 13 \wj “Mgbe ụbọchị ole na ole gasịrị, nwokorobịa ahụ kwakọtara ihe niile o nwere gaa biri nʼotu obodo dị anya. Nʼebe ahụ, o mefuchara ihe niile o nwere nʼibi ndụ ọjọọ.\wj* 
\v 14 \wj Mgbe o mefuchara ihe niile o nwere, oke ụnwụ dara nʼala ahụ. Ọ malitere ịnọ nʼụkọ.\wj* 
\v 15 \wj Nʼihi nke a, ọ gara binyere otu onye obodo ahụ nyere ya ọrụ ilekọta ezi ya na inye ha nri.\wj* 
\v 16 \wj Ma ọ na-agụ ya ka o site na nri ọ na-enye ezi rijuo afọ, ma ọ dịghị onye nyere ya ụdị nri ahụ.\wj* 
\p  
\v 17 \wj “Mgbe ọ ghọtara onwe ya, ọ sịrị, ‘Mmadụ ole bụ ndị ọrụ e goro ego nna m nwere, ndị nri na-ezuru ma mapụtakwa, ma agụụ na-egbu m nʼebe a.\wj* 
\v 18 \wj Aga m ebili lakwuru nna m, sị ya, Nna, emehiela m megide eluigwe na gị onwe gị.\wj* 
\v 19 \wj Ekwesikwaghị m ka a kpọọ m nwa gị ọzọ, were m dị ka otu nʼime ndị i goro ọrụ.’\wj* 
\v 20 \wj Ya mere, o biliri laghachikwuru nna ya.\wj* 
\p \wj “Ma mgbe ọ nọrịị nʼebe dị anya, nna ya hụrụ ya, nwee ọmịiko nʼahụ ya, gbaara ọsọ ga makụọ ya, sutukwa ya ọnụ.\wj* 
\p  
\v 21 \wj “Nwa ya nwoke ahụ sịrị ya, ‘Nna, emehiela m megide eluigwe na gị onwe gị. Ekwesighị m ka a kpọọ m nwa gị ọzọ.’\wj* 
\p  
\v 22 \wj “Ma nna ya gwara ndị ohu ya sị, ‘Meenụ ngwangwa weta uwe kachasị mma yikwasị ya. Gbanye ya ọlaaka nʼaka, yinyekwanụ ya akpụkpọụkwụ nʼụkwụ.\wj* 
\v 23 \wj Gaanụ kpụpụta nwa ehi gbara abụba, gbuo ya, ka anyị rie ma ṅụrịakwa.\wj* 
\v 24 \wj Nʼihi na nwa m a, nwụrụ anwụ ma ọ dịla ndụ ọzọ. O fukwara efu ma a chọtala ya.’ Ha bidoro na-eri, na-aṅụ na-aṅụrịkwa ọṅụ.\wj* 
\p  
\v 25 \wj “Ọ dịghị anya, nwa ya nke okenye, onye jere ịrụ ọrụ nʼubi, mgbe ọ na-abịaru ụlọ nso, ọ nụrụ ụda egwu na ịgba egwu.\wj* 
\v 26 \wj Ọ kpọrọ otu nʼime ndị ohu jụọ ya ihe na-eme.\wj* 
\v 27 \wj Ọ sịrị ya, ‘Nwanne gị nwoke alọtala. Nna gị egbuola nwa ehi gbara abụba nʼihi na ọ lọtara nʼudo na ahụ ike.’\wj* 
\p  
\v 28 \wj “Iwe were ya, ọ jụrụ ịbata nʼime ụlọ. Nna ya pụtara nʼezi rịọ ya arịrịọ.\wj* 
\v 29 \wj Ma ọ zara nna ya sị, ‘Lee ọtụtụ afọ niile ndị a ka m nọọ na-ejere gị ozi, enupukwaghị m isi nʼiwu gị nʼụzọ ọbụla. Ma o nweghị oge i nyere m ọ bụladị nwa ewu sị mụ na ndị enyi m jiri ya mee oriri.\wj* 
\v 30 \wj Ma ugbu a, nwa gị a, onye ya na ndị akwụna mefuru akụ gị alọtala, ya ka i gburu nwa ehi gbara abụba.’\wj* 
\p  
\v 31 \wj “Ma ọ sịrị ya, ‘Nwa m, mụ na gị nọ mgbe niile, ihe niile m nwere bụkwa nke gị.\wj* 
\v 32 \wj Ma anyị kwesiri ịṅụrị ọṅụ, kpọọkwa oriri, nʼihi na nwanne gị nwoke a nwụrụ anwụ ma ọ dịla ndụ ọzọ. O fukwara efu ma a chọtala ya. ’ ”\wj* 
\c 16  
\s1 Ilu maka onyeisi ọrụ nwere uche 
\p  
\v 1 Ọ gwara ndị na-eso ụzọ ya sị, \wj “Otu ọgaranya nwere otu onyeisi ọrụ nke e boro ebubo na ọ na-ala akụ ya nʼiyi.\wj* 
\v 2 \wj Ya mere ọ kpọrọ ya sị ya, ‘Gịnị bụ ihe a m na-anụ banyere gị? Gbakọọrọ m otu i si na-elekọta akụ m, nʼihi na achọkwaghị m ka ị bụrụ onyeisi ọrụ ọzọ.’\wj* 
\p  
\v 3 \wj “Onyeisi ọrụ ahụ sịrị onwe ya, ‘Gịnị ka m ga-eme ugbu a nna m ukwu na-achọ ịkwụsị m ọrụ? Ike igwu ala adịghị m, ihere agakwaghị ekwe m ịrịọ arịrịọ.\wj* 
\v 4 \wj Amatala m ihe m ga-eme, nke a ga-enyere m aka ma ọ bụrụ na a chụpụ m nʼọrụ nʼebe a, aga m enweta ndị ga-anabata m nʼụlọ ha.’\wj* 
\p  
\v 5 \wj “Ya mere ọ kpọrọ ndị niile ji nna ya ukwu ụgwọ nʼotu nʼotu. Ọ jụrụ onye nke mbụ sị, ‘Ego ole bụ ụgwọ i ji nna m ukwu?’\wj* 
\p  
\v 6 \wj “Ọ sịrị ya, ‘Ọ bụ puku karama mmanụ oliv ka m ji ụgwọ ya.’\wj* 
\p \wj “Onyeisi ọrụ ahụ gwara ya sị, ‘Ngwangwa, were akwụkwọ degharịa ya narị karama ise.’\wj* 
\p  
\v 7 \wj “Mgbe ahụ, ọ jụrụ onye nke abụọ sị, ‘Ego ole bụ ụgwọ i ji?’\wj* 
\p \wj “Ọ sịrị ya, ‘Ọ bụ narị akpa ọka wiiti.’\wj* 
\p \wj “Ọ sịrị ya, ‘Ngwangwa degharịa ya iri akpa ọka wiiti asatọ.’\wj* 
\p  
\v 8 \wj “Nna ya ukwu toro onyeisi ọrụ ahụ na-ekwesighị ntụkwasị obi nʼihi na ọ kpara agwa dị ka onye nwere uche. Nʼihi na ụmụ, nke ọgbọ a, ji akọnuche na-eso ndị ọgbọ ha karịa ụmụ nke ìhè.\wj* 
\v 9 \wj Agwa m unu, jirinụ akụnụba nke ajọ omume metara onwe unu ndị enyi, ka ọ ga-abụ na mgbe ọ na-adịghịkwa akụ unu nwere, ha ga-anabata unu nʼụlọ obibi ha ebighị ebi.\wj* 
\p  
\v 10 \wj “Onye ọbụla kwesiri ntụkwasị obi nʼihe dị ntakịrị, ga-ekwesikwa ntụkwasị obi nʼihe dị ukwuu. Onye na-ekwesikwaghị ntụkwasị obi nʼihe dị ntakịrị, agaghịkwa ekwesi ntụkwasị obi nʼihe dị ukwuu.\wj* 
\v 11 \wj Ọ bụrụ na unu abụghị ndị kwesiri ntụkwasị obi nʼakụ mmehie nke ụwa, onye ga-enyekwa ezi akụ nʼaka unu na ntụkwasị obi idebe?\wj* 
\v 12 \wj Ọ bụrụkwa na unu abụghị ndị kwesiri ntụkwasị obi nʼakụ onye ọzọ, onye ga-enye unu ihe nke bụ nke unu?\wj* 
\p  
\v 13 \wj “Ọ dịghị onye ọbụla pụrụ ife nna ukwu abụọ, nʼihi na ọ ga-achọ ịhụ otu nʼime ha nʼanya, kpọkwa nke ọzọ asị, maọbụ, sọpụrụ otu ma lelịa nke ọzọ anya. Otu a kwa i nweghị ike ife Chineke na akụ otu mgbe ahụ.”\wj* 
\p  
\v 14 Mgbe ndị Farisii, bụ ndị hụrụ ego nʼanya nụrụ ihe ndị a, ha jiri ya mee ihe ọchị.  
\v 15 Ọ sịrị ha, \wj “Unu na-egosi onwe unu dị ka ndị ezi omume nʼihu ndị mmadụ ma Chineke maara obi unu. Nʼihi na ihe ndị mmadụ na-akpọ ihe dị oke mkpa bụ ihe rụrụ arụ nʼanya Chineke.\wj* 
\s1 Ozizi ndị ọzọ 
\p  
\v 16 \wj “Iwu na ndị amụma nọ na-achị ruo oge Jọn bịara. Site nʼoge ahụ, a na-ekwusa oziọma nke alaeze Chineke, onye ọbụla na-ejikwa ike na-abanye nʼime ya.\wj* 
\v 17 \wj Ọ dị mfe ka eluigwe na ụwa gabiga karịa na a ga-ewepụ otu kpọm, site nʼihe niile dị nʼiwu.\wj* 
\p  
\v 18 \wj “Onye ọbụla gbara nwunye ya alụkwaghị m ma lụrụ nwanyị ọzọ na-eme mmehie ịkwa iko. Onye ọ bụlakwa lụrụ nwanyị di ya jụrụ na-eme mmehie ịkwa iko.\wj* 
\s1 Onye ọgaranya na Lazarọs 
\p  
\v 19 \wj “Ọ dị otu ọgaranya na-eyi uwe odo odo na ezi akwa ọcha, na-erikwa nri dị mma ụbọchị niile.\wj* 
\v 20 \wj Nʼọnụ ụzọ ụlọ ya, otu nwoke onye ogbenye nke ọnya juru ahụ ya na-edina nʼebe ahụ. Aha ya bụ Lazarọs\wj*.  
\v 21 \wj Ọ na-agụsị ya agụụ ike iri iberibe nri si na tebul ọgaranya ahụ daa nʼala. Ọ bụladị ụmụ nkịta na-abịa na-aracha ọnya dị ya nʼahụ.\wj* 
\p  
\v 22 \wj “Mgbe onye ogbenye ahụ nwụrụ, ndị mmụọ ozi bịara buru ya gaa nʼebe Ebraham nọ. Onye ọgaranya ahụ nwụkwara, e lie ya.\wj* 
\v 23 \wj Nʼọkụ ala mmụọ ebe onye ọgaranya ahụ nọ nʼoke ihe mgbu, ọ hụrụ Ebraham ka ọ nọ nʼebe dị anya, hụkwa Lazarọs nʼakụkụ ya.\wj* 
\v 24 \wj Ọ kpọkuru Ebraham sị ya, ‘Nna m Ebraham, meere m ebere nʼihi na anọ m nʼoke ihe mgbu nʼime ọkụ a. Biko zienụ Lazarọs ka ọ denye mkpịsịaka ntakịrị ya na mmiri bịa mejụọ ire m.’\wj* 
\p  
\v 25 \wj “Ma Ebraham sịrị ya, ‘Nwa m, chetakwa na ị nara ezi ihe gị mgbe ị dị ndụ, ebe Lazarọs nara ihe ọjọọ. Ma ugbu a, a na-akasị ya obi nʼebe a ma gị onwe gị nọkwa nʼahụhụ.\wj* 
\v 26 \wj A sịkwarị na anyị achọọ inyere gị aka, ọ gaghị ekwe mee nʼihi na e nwere olulu dị ukwuu kewara anyị na unu. Mmadụ ọbụla enwekwaghị ike isite nʼebe a bịa nʼebe unu nọ, ọ dịkwaghị onye nwere ike isite nʼebe ahụ unu nọ bịa nʼebe a.’\wj* 
\p  
\v 27 \wj “Ọ sịrị, ‘Ya mere, arịọ m gị nna, ziganụ ya nʼụlọ nna m,\wj* 
\v 28 \wj nʼihi na enwere m ụmụnne nwoke ise. Ka ọ dọọ ha aka na ntị ka ha ghara ịbịa nʼebe a mmekpa ahụ dị.’\wj* 
\p  
\v 29 \wj “Ebraham sịrị, ‘Ha nwere Mosis na ndị amụma, ha gee ha ntị.’\wj* 
\p  
\v 30 \wj “Ma o kwuru, ‘Nna Ebraham, nke ahụ agaghị ezu! A sị na otu onye ga-esi nʼala ndị nwụrụ anwụ gakwuru ha, ha ga-echegharị.’\wj* 
\p  
\v 31 \wj “Ọ sịrị ya, ‘Ọ bụrụ na ha egeghị Mosis na ndị amụma ntị, ha agaghị ekwenye ma a sịkwarị na mmadụ esi nʼọnwụ bilie.’ ”\wj* 
\c 17  
\s1 Mmehie na okwukwe na ije ozi 
\p  
\v 1 Ọ sịrị ndị na-eso ụzọ ya, \wj “Ihe ndị nke na-eme ka mmadụ jehie aghaghị ịdị, ma ahụhụ ga-adịrị onye ọbụla ọnọdụ ndị a ga-esi nʼaka ya bịa.\wj* 
\v 2 \wj Ọ ga-akara gị mma ka e kenye gị nkume igwe nri nʼolu, tụnye gị nʼime oke osimiri, karịa na ị ga-eduhie otu nʼime ụmụntakịrị ndị a ụzọ.\wj* 
\v 3 \wj Kpachapụrụnụ onwe unu anya!\wj* 
\p \wj “Ọ bụrụ na nwanna gị e mejọọ gị, baara ya mba. Ọ bụrụ na o chegharịa, gbaghara ya.\wj* 
\v 4 \wj Ọ bụrụkwa na o mejọọ gị ugboro asaa nʼotu ụbọchị, rịọkwa gị ugboro asaa sị, ‘E chegharịala m,’ ị ghaghị ịgbaghara ya.”\wj* 
\p  
\v 5 Ndị ozi ya sịrị ya, “Onyenwe anyị, mee ka okwukwe anyị dị ukwuu!” 
\p  
\v 6 Onyenwe anyị zara, \wj “Ọ bụrụ na unu nwere okwukwe nke ha ka mkpụrụ mọstaadị, unu nwere ike ị sị osisi ukwu a, Ka e site na mgbọrọgwụ hopu gị ma kụọkwa gị nʼime oke osimiri, ọ ga-erubere unu isi.\wj* 
\p  
\v 7 \wj “Ọ bụ onye nʼime unu nke nwere ohu onye si ebe ọ gara rụọ ọrụ maọbụ ịzụ atụrụ lọbata, ga-asị ya, ‘Mee ngwangwa nọdụ ala rie nri’?\wj* 
\v 8 \wj Ọ gaghị asị ya, ‘Siere m nri ọsịịsọ, kwadoo onwe gị jere m ozi ka m na-eri na aṅụkwa ihe ọṅụṅụ; emesịa ị ga-eri nri ma ṅụọ ihe ọṅụṅụ nke gị’?\wj* 
\v 9 \wj Ọ ga-ekele ohu ahụ nʼihi na ọ rụrụ ọrụ o kwesiri ịrụ?\wj* 
\v 10 \wj Nʼotu aka ahụ, mgbe unu rụchara ọrụ niile unu kwesiri ịrụ, ihe unu ga-ekwu bụ, ‘Anyị bụ ụmụ ohu na-ekwesighị ekwesi, anyị emeela ihe anyị kwesiri ime.’ ”\wj* 
\s1 Ọgwụgwọ ndị ekpenta iri 
\p  
\v 11 Ka ọ na-aga Jerusalem, o sitere nʼụzọ dị nʼagbata Sameria na Galili.  
\v 12 Mgbe ọ banyere nʼotu obodo nta, ndị ekpenta iri sitere nʼebe dị anya zute ya.  
\v 13 Ha tiri mkpu nʼoke olu sị, “Jisọs nna anyị ukwuu, mere anyị ebere.” 
\p  
\v 14 Mgbe ọ hụrụ ha, ọ sịrị ha, \wj “Gaanụ gosi ndị nchụaja onwe unu.”\wj* Dị ka ha na-aga, e mere ka ha dị ọcha. 
\p  
\v 15 Mgbe otu nʼime ha chọpụtara na a gwọọla ya, ọ laghachiri azụ, jiri oke olu na-eto Chineke.  
\v 16 Ọ dara nʼala nʼụkwụ ya, kelee ya. Ọ bụ onye Sameria. 
\p  
\v 17 Jisọs jụrụ sị, \wj “Ọ bụghị mmadụ iri ka e mere ka ha dị ọcha, ebeekwanụ ka itoolu ndị ọzọ nọ?\wj* 
\v 18 \wj Ọ bu naanị onye mba ọzọ a lọghachiri inye Chineke otuto?”\wj* 
\v 19 Mgbe ahụ, ọ sịrị ya, \wj “Bilie, laa, okwukwe gị agwọọla gị.”\wj* 
\s1 Ọbịbịa nke alaeze Chineke 
\p  
\v 20 Ma mgbe ndị Farisii jụrụ ya sị, Olee mgbe alaeze Chineke ga-abịa? O kwuru, \wj “Ọbịbịa alaeze Chineke agaghị a bụ nʼụzọ a ga-eji anya efu hụ ya.\wj* 
\v 21 \wj Ha agaghịkwa asị, ‘Lee, ọ nọ nʼebe a,’ maọbụ, ‘nʼebe ahụ,’ nʼihi nʼezie, alaeze Chineke nọ nʼetiti unu. ”\wj* 
\p  
\v 22 Mgbe ahụ, ọ gwara ndị na-eso ụzọ ya, \wj “Oge na-abịa mgbe ọ ga-agụsi unu agụụ ike ịhụ otu nʼime ụbọchị nke Nwa nke Mmadụ, ma unu agaghị ahụ ya.\wj* 
\v 23 \wj Ha ga-asị unu, ‘Lee, nʼebe ahụ,’ maọbụ, ‘Lee, nʼebe a,’ unu agala, unu esokwala ha.\wj* 
\v 24 \wj Nʼihi na Nwa nke Mmadụ nʼụbọchị ya ga-adị ka amụma nke eluigwe nke na-enye ìhè na mbara eluigwe site nʼotu ebe ruo nʼebe nke ọzọ.\wj* 
\v 25 \wj Ma ọ ghaghị ibu ụzọ hụọ ọtụtụ ahụhụ, ọgbọ a ga-ajụkwa ya.\wj* 
\p  
\v 26 \wj “Dị ka ọ dị nʼụbọchị Noa, otu a ka ọ ga-adịkwa nʼụbọchị Nwa nke Mmadụ.\wj* 
\v 27 \wj Ha nọ na-eri na-aṅụ, na-alụ nwunye na-ekekwa ụmụ ha di, ruo mgbe Noa banyere nʼụgbọ mmiri. Oke iju mmiri ahụ bịakwara laa ha nʼiyi.\wj* 
\p  
\v 28 \wj “Otu a ka ọ dịkwa nʼoge Lọt. Ha nọ na-eri, na-aṅụ, na-azụrịtakwa ahịa, na-akụ mkpụrụ, na-arụkwa ụlọ.\wj* 
\v 29 \wj Ma nʼụbọchị ahụ Lọt si nʼobodo Sọdọm pụta, ọkụ na nkume dị ọkụ sitere nʼeluigwe zoo ka mmiri, laa ha niile nʼiyi.\wj* 
\p  
\v 30 \wj “Otu a ka ọ ga-adịkwa nʼụbọchị a ga-eme ka Nwa nke Mmadụ pụta ìhè.\wj* 
\v 31 \wj Nʼụbọchị ahụ, onye ọbụla nọ nʼelu ụlọ, ma ihe ya dị nʼime ụlọ, arịtukwala ịba nʼime ụlọ iburu ngwongwo ndị ahụ. Nʼotu aka ahụ, onye ọbụla nọ nʼubi, ya ghara ịlọghachita.\wj* 
\v 32 \wj Chetakwanụ nwunye Lọt.\wj* 
\v 33 \wj Onye ọbụla chọrọ iche ndụ ya nche ka ọ ga-efunarị, ma onye ọbụla na-atụfu ndụ ya ga-echebe ya.\wj* 
\v 34 \wj Asị m unu, nʼanyasị ahụ mmadụ abụọ ga-edina nʼotu akwa, a ga-ewepụ otu nʼime ha hapụ onye nke ọzọ.\wj* 
\v 35 \wj Ụmụ nwanyị abụọ ga na-akwọ ọka nʼotu ebe, a ga-ewere otu ma hapụ nke ọzọ.”\wj* 
\v 36 \wj Ụmụ nwoke abụọ ga-anọ nʼubi, a ga-ewere otu onye hapụ nke ọzọ.\wj*\f + \fr 17:36 \ft Ụfọdụ akwụkwọ na-edebanye okwu ndị a dịka ọ dị nʼakwụkwọ \xt Mat 24:40\ft .\f* 
\p  
\v 37 Ha jụrụ ya sị, “Olee ebe, Onyenwe anyị?” 
\p Ọ sịrị ha, \wj “Ebe ọbụla ozu dị, ka udele na-ezukọta.”\wj* 
\c 18  
\s1 Ilu banyere ịnọgidesi ike 
\p  
\v 1 Mgbe ahụ ọ tụụrụ ha ilu a iji gosi ha mkpa ọ dị ikpe ekpere na-esepụghị aka,  
\v 2 ọ sịrị, \wj “O nwere otu ọkaikpe bi nʼotu obodo ma ọ naghị atụ egwu Chineke. Ọ naghị asọpụkwara mmadụ.\wj* 
\v 3 \wj Nʼobodo ahụkwa, e nwere otu nwanyị di ya nwụrụ anwụ nke na-abịakwute ya, na-asị ya, ‘Kpepụta m nʼaka ndị na-emegide m.’\wj* 
\p  
\v 4 \wj “Na mmalite, ọ chọghị, ma nʼikpeazụ, ọ gwara onwe ya sị, ‘Ọ bụ eziokwu na anaghị m atụ egwu Chineke maọbụ sọpụrụ mmadụ.\wj* 
\v 5 \wj Ma nʼihi na nwanyị a di ya nwụrụ anwụ nọgidere na-enye m nsogbu, aga m ahụ na o nwetara ikpe ziri ezi, ka ọ kwụsị inye m nsogbu site na ọbịbịa ọ na-abịa.’ ”\wj* 
\p  
\v 6 Ya mere Onyenwe anyị sịrị, \wj “Gerenụ ihe ọkaikpe nke na-eme ajọ omume na-ekwu.\wj* 
\v 7 \wj Ọ bụ na Chineke agaghị ekpepụta ndị ahụ ọ họpụtara, bụ ndị na-akpọku ya ehihie na abalị? Ọ ga-anọ tee anya nʼinyere ha aka?\wj* 
\v 8 \wj Asị m unu, ọ ga-eme ngwangwa hụ na ha nwetara ikpe ziri ezi. Ma otu ọ dị, mgbe Nwa nke Mmadụ ga-abịa, ọ ga-ahụkwa ndị nwere okwukwe nʼime ụwa?”\wj* 
\s1 Ilu banyere onye Farisii na onye ọna ụtụ 
\p  
\v 9 Ọ tụkwara ilu a nʼihi ndị tụkwasịrị obi nʼonwe ha na ha bụ ndị ezi omume ma na-eleda ndị ọzọ anya.  
\v 10 \wj “Ụmụ nwoke abụọ rigoro nʼụlọnsọ ukwu ikpe ekpere, otu onye nʼime ha bụ onye Farisii, onye nke ọzọ bụ onye ọna ụtụ.\wj* 
\v 11 \wj Onye Farisii ahụ guzoro ọtọ kpee ekpere banyere onwe ya sị, ‘Chineke nna m, ana m ekele gị nʼihi na adịghị m ka mmadụ ndị ọzọ ndị na-apụnara mmadụ ihe ya nʼike, maọbụ ndị ajọ omume, maọbụ ndị na-akwa iko, ma ọ bụkwanụ dị ka onye ọna ụtụ a.\wj* 
\v 12 \wj Ana m ebu ọnụ ugboro abụọ nʼizu ụka ọbụla. Ana m akwụkwa otu ụzọ nʼụzọ iri nke ihe niile m nwetara.’\wj* 
\p  
\v 13 \wj “Ma onye ọna ụtụ ahụ guzo nʼebe dị anya, o nwekwaghị ike iweli ihu ya elu lee anya nʼeluigwe. Kama, ọ na-eti aka nʼobi ya na mwute na-asị, ‘Chineke, biko mere m ebere nʼihi na abụ m onye mmehie.’\wj* 
\p  
\v 14 \wj “Asị m unu, na nwoke a lara nʼụlọ ya bụrụ onye a gụrụ nʼonye ezi omume nʼihu Chineke karịa onye nke ọzọ. Nʼihi na onye ọbụla ga-ebuli onwe ya elu ka a ga-eweda, ma onye ọbụla na-eweda onwe ya ala ka a ga-ebuli elu.”\wj* 
\s1 Jisọs na ụmụntakịrị 
\p  
\v 15 Ndị mmadụ na-ekutere ya ụmụntakịrị ka o bikwasị ha aka. Mgbe ndị na-eso ụzọ ya hụrụ nke a, ha baara ha mba.  
\v 16 Ma Jisọs kpọrọ ha ka ha bịakwute ya, sị, \wj “Kweenụ ka ha bịakwute m, unu egbochikwala ha, nʼihi na alaeze Chineke bụ nke ndị dị ka ha.\wj* 
\v 17 \wj Nʼezie, agwa m unu, onye ọbụla na-agaghị anara alaeze Chineke dị ka nwantakịrị agaghị aba nʼime ya.”\wj* 
\s1 Onye ọchịchị bara ọgaranya 
\p  
\v 18 Otu onye ọchịchị jụrụ ya sị, “Ezi onye ozizi, ọ bụ gịnị ka m ga-eme keta ndụ ebighị ebi.” 
\p  
\v 19 Jisọs sịrị ya, \wj “Gịnị mere i ji akpọ m ezi mmadụ? Ọ dịghị onye ọbụla bụ ezi mmadụ ma ọ bụghị naanị Chineke.\wj* 
\v 20 \wj Ị maara ihe niile enyere nʼiwu, akwala iko, egbula mmadụ, ezula ohi, agbala ama ụgha, sọpụrụ nne na nna gị.\wj*\f + \fr 18:20 \ft \xt Ọpụ 20:12-16; Dit 5:16-20\f*\wj ”\wj* 
\p  
\v 21 Ọ sịrị, “Edebezuchaala m iwu ndị a niile site na mgbe m bụ nwata.” 
\p  
\v 22 Mgbe Jisọs nụrụ nke a, ọ sịrị ya, \wj “Otu ihe fọdụrụ ka ime: ree ihe niile i nwere, kesara ụmụ ogbenye ego ya. Ị ga-enwe akụ nʼeluigwe, bịazie soro m.”\wj* 
\p  
\v 23 Mgbe ọ nụrụ nke a, o wutere ya nke ukwuu, nʼihi na ọ bụ onye nwere ọtụtụ akụ.  
\v 24 Jisọs lere ya anya sị, \wj “Lee ka o si bụrụ ihe siri ike bụ ndị ọgaranya ịba nʼalaeze Chineke.\wj* 
\v 25 \wj Nʼezie, ọ dịrị ịnyịnya kamel mfe isite nʼanya agịga gafee karịa ọgaranya ịbanye nʼalaeze Chineke.”\wj* 
\p  
\v 26 Ndị nụrụ ya sịrị, “Onye kwanụ ka a ga-azọpụta?” 
\p  
\v 27 Ọ sịrị, \wj “Ihe mmadụ na-apụghị ime, bụ ihe Chineke pụrụ ime.”\wj* 
\p  
\v 28 Mgbe ahụ Pita sịrị, “Lee, anyị ahapụla ihe niile anyị nwere soro gị!”\f + \fr 18:28 \ft Ihe niile gbasara ezinaụlọ anyị\f* 
\p  
\v 29 Ọ sịrị ha, \wj “Nʼezie, agwa m unu, o nweghị onye ọbụla hapụrụ ụlọ ya, maọbụ nwunye, maọbụ ụmụnne, maọbụ ndị mụrụ ya, maọbụ ụmụntakịrị ya, nʼihi alaeze Chineke\wj* 
\v 30 \wj nke na-agaghị anata ihe ndị a nʼọgbọ a, nwekwa ndụ ebighị ebi nʼọgbọ nke na-abịa.”\wj* 
\s1 Jisọs ekwuo okwu banyere ọnwụ ya ọzọ 
\p  
\v 31 Jisọs kpọpụrụ mmadụ iri na abụọ ahụ na-eso ụzọ ya nʼakụkụ, gwa ha sị, \wj “Anyị na-aga Jerusalem, ihe niile ndị amụma dere banyere Nwa nke Mmadụ ga-emezu\wj*.  
\v 32 \wj A ga-arara ya nyefee ya nʼaka ndị mba ọzọ. Ha ga-akwa ya emo, mee ya ihe ihere, bụkwaa ya ọnụ mmiri asụ.\wj* 
\v 33 \wj Ha ga-apịa ya ihe, gbukwaa ya; ma nʼụbọchị nke atọ, ọ ga-esite nʼọnwụ bilie ọzọ.”\wj* 
\p  
\v 34 Ma ha aghọtaghị ihe ọbụla nʼokwu ndị a. E mere ka nkọwa okwu ndị a bụrụ ihe e zoro ezo nʼebe ha nọ, ha aghọtakwaghị ihe o kwuru. 
\s1 Onye ìsì ahụ ụzọ 
\p  
\v 35 O ruo ka ọ bịaruru Jeriko nso, otu nwoke kpuru ìsì nọ nʼakụkụ ụzọ na-arịọ arịrịọ.  
\v 36 Mgbe ọ nụrụ uzu igwe mmadụ ka ha na-agafe, ọ jụrụ ihe na-eme.  
\v 37 Ha gwara ya, “Jisọs onye Nazaret na-agafe.” 
\p  
\v 38 O tiri mkpu sị, “Jisọs nwa Devid, meere m ebere!” 
\p  
\v 39 Ndị bu ụzọ baara ya mba ka o mechie ọnụ. Ma o tisiri mkpu ike sị, “Nwa Devid, meere m ebere!” 
\p  
\v 40 Jisọs kwụsịrị, nye iwu ka a kpọtara ya nwoke ahụ. Mgbe o rutere nso, ọ jụrụ ya,  
\v 41 \wj “Gịnị ka ị chọrọ ka m meere gị?”\wj* 
\p Ọ sịrị, “Onyenwe anyị, ka e mee ka m hụ ụzọ ọzọ.” 
\p  
\v 42 Jisọs sịrị ya, \wj “Hụ ụzọ, okwukwe gị agwọọla gị.”\wj* 
\v 43 Ngwangwa, o bidoro ịhụ ụzọ ma soro Jisọs, na-etokwa Chineke. Ndị mmadụ niile, mgbe ha hụrụ ya tokwara Chineke. 
\c 19  
\s1 Zakịọs ezute Jisọs 
\p  
\v 1 Ọ banyere Jeriko mgbe ọ na-agafe.  
\v 2 Otu nwoke nọ ebe ahụ, aha ya bụ Zakịọs; ọ bụ onyeisi ndị ọna ụtụ bụrụkwa ọgaranya.  
\v 3 Ọ chọrọ ịhụ onye Jisọs bụ ma ebe ọ bụ onye mkpụmkpụ, ọ dịrịghị ya mfe nʼihi igwe mmadụ.  
\v 4 Ya mere, ọ gbaara ọsọ gaa nʼihu rigoro nʼotu osisi sikamọ, ka o nwee ike ịhụ ya dị ka ọ na-agafe nʼụzọ ahụ. 
\p  
\v 5 Mgbe Jisọs rutere nʼebe ahụ, o lere anya nʼelu sị ya, \wj “Zakịọs, rịdata ngwangwa. Aga m abụ ọbịa nʼụlọ gị taa.”\wj* 
\v 6 Ọ rịdatara nʼotu mgbe ahụ jirikwa obi ụtọ nabata ya. 
\p  
\v 7 Mmadụ niile hụrụ nke a, ma bido na-atamu sị, “Ọ gaala ịbụ ọbịa onye mmehie.” 
\p  
\v 8 Ma Zakịọs biliri ọtọ gwa Onyenwe anyị, “Lee, Onyenwe anyị, aga m enye ndị ogbenye ọkara ihe niile m nwere. Ọ bụrụkwa na o nwere onye m ghọgburu nara ya ihe ọbụla, aga m akwụghachi ya okpukpu anọ.” 
\p  
\v 9 Jisọs gwara ya, \wj “Taa nzọpụta abịala nʼụlọ a, nʼihi na onye a bụkwa nwa Ebraham.\wj* 
\v 10 \wj Nʼihi na Nwa nke Mmadụ bịara ịchọ na ịzọpụta ndị furu efu.”\wj* 
\s1 Ilu banyere mkpụrụ ego iri 
\p  
\v 11 Dị ka ha na-ege ya ntị nʼokwu a, ọ gara nʼihu tụọrọ ha ilu, nʼihi na ọ nọ Jerusalem nso, ha chekwara na o ruola mgbe alaeze Chineke ga-apụta ihe.  
\v 12 Ọ sịrị, \wj “Otu nwoke a mụrụ nʼọnọdụ dị elu gara obodo dị anya ka echie ya eze, ka ọ lọtakwa ma e mesịa.\wj* 
\v 13 \wj Ya mere, ọ kpọrọ ndị ohu ya iri nye ha mkpụrụ ego iri sị ha, ‘Werenụ ego ndị a zụọ ahịa ruo mgbe m ga-alọta.’\wj* 
\p  
\v 14 \wj “Ma ndị ọ na-achị kpọrọ ya asị, ha zipụkwara ndị ụkwụ ozi nʼazụ ya na-asị, ‘Anyị achọkwaghị ka onye a chịa anyị.’\wj* 
\p  
\v 15 \wj “Mgbe ọ natachara ikike ịbụ eze, ọ lọghachiri, kpọọ ndị ohu ya ahụ o nyere ego mgbe ọ na-apụ, ka ha bịa pịaziere ya ego ole ha ritere nʼuru.\wj* 
\p  
\v 16 \wj “Onye nke mbụ bịara sị, ‘Onyenwe m e jiri m mkpụrụ ego ị nyere m rite uru mkpụrụ ego iri ọzọ.’\wj* 
\p  
\v 17 \wj “Nna ya ukwu sịrị ya, ‘I mere nke ọma, ezi odibo. Nʼihi na i gosiri onwe gị onye kwesiri ntụkwasị obi nʼihe dịkarịsịrị nta, ị ga-achị mba iri.’\wj* 
\p  
\v 18 \wj “Onye nke abụọ bịara sịkwa, ‘Onyenwe m, otu mkpụrụ ego gị amụtala mkpụrụ ego ise ọzọ.’\wj* 
\p  
\v 19 \wj “Ọ sịrị ya, ‘Ị ga-achị obodo ise.’\wj* 
\p  
\v 20 \wj “Onye nke ọzọ bịakwara sị, ‘Onyenwe m, lee mkpụrụ ego gị. Ekechiri m ya nʼakwa, zoo ya.\wj* 
\v 21 \wj Atụrụ m egwu gị, nʼihi na ị bụ onye afọ tara mmiri, bụrụkwa onye na-ewe ihe na-abụghị nke gị, na-aghọrọkwa mkpụrụ ị na-akụghị.’\wj* 
\p  
\v 22 \wj “Ọ sịrị ya, ‘Ọ bụ okwu si gị nʼọnụ ka m ga-eji kpee gị ikpe, gị bụ ohu ọjọọ! I maara na afọ tara m mmiri, matakwa na m na-ewe ihe na-abụghị nke m, na-aghọrọkwa mkpụrụ m na-akụghị?\wj* 
\v 23 \wj Gịnị mere na i wereghị ego m tinye nʼụlọakụ? Nke ọ ga-abụ mgbe m lọtara, m ga-anara ya na ọmụrụnwa ya.’\wj* 
\p  
\v 24 \wj “Mgbe ahụ, ọ gwara ndị guzo nʼebe ahụ, ‘Napụtanụ ya mkpụrụ ego ahụ, were ya nye onye ji mkpụrụ ego iri.’\wj* 
\p  
\v 25 \wj “Ha sịrị ya, ‘Nna anyị ukwu, o nwelarị mkpụrụ ego iri.’\wj* 
\p  
\v 26 \wj “Ọ zara, ‘Asị m unu, onye ọbụla nwere ihe ka a ga-enyekwa ihe ọzọ, ma onye na-enweghị ihe ka a ga-anapụ ọ bụladị ihe ahụ o nwere.\wj* 
\v 27 \wj Ma ndị iro m ahụ, ndị na-achọghị ka m bụrụ eze ha, kpụpụtanụ ha nʼebe a, gbukwaanụ ha nʼihu m.’ ”\wj* 
\s1 Jisọs abata Jerusalem 
\p  
\v 28 Mgbe ọ kwusiri nke a, ọ gakwara nʼihu nʼije ya ịga Jerusalem.  
\v 29 Mgbe ọ na-abịaru Betfeji na Betani nso, nʼUgwu a na-akpọ Oliv, Jisọs zipụrụ mmadụ abụọ nʼime ndị na-eso ụzọ ya,  
\v 30 sị, \wj “Gaanụ nʼime obodo nta ahụ dị nʼihu unu. Mgbe unu na-abanye nʼime ya, unu ga-ahụ nwa ịnyịnya e kenyere nʼebe ahụ nke onye ọbụla na-anọkwasịbeghi nʼelu ya, tọpụnụ ya, kpụtara m ya.\wj* 
\v 31 \wj Ọ bụrụ na onye ọbụla ajụọ unu, ‘Gịnị mere unu ji atọpụ ya?’ Gwanụ onye ahụ sị, ‘Ọ dị Onyenwe anyị mkpa.’ ”\wj* 
\p  
\v 32 Ndị ahụ o zipụrụ gara hụ ya dị ka ọ gwara ha.  
\v 33 Mgbe ha bidoro ịtọpụ ya, ndị nwe ya jụrụ ha sị, “Gịnị mere unu ji atọpụ nwa ịnyịnya ahụ?” 
\p  
\v 34 Ha sịrị, “Ọ dị Onyenwe anyị mkpa.” 
\p  
\v 35 Ha kpụtaara Jisọs nwa ịnyịnya ahụ, wụkwasịkwa uwe ha nʼelu ya, nyere Jisọs aka ka ọ rigoro nʼelu ya.  
\v 36 Dị ka ọ na-aga, ndị mmadụ tụsara uwe ha nʼokporoụzọ. 
\p  
\v 37 Mgbe o rutere nʼụzọ e si arịgo Ugwu Oliv, igwe mmadụ ndị ahụ na-eso ụzọ ya malite iji ọṅụ na-eto Chineke nʼoke olu nʼihi ọrụ ebube niile ha hụrụ,  
\v 38 na-asị, 
\q1 “Onye a gọziri agọzi ka eze ahụ bụ nke na-abịa nʼaha Onyenwe anyị.”\f + \fr 19:38 \ft \xt Abụ 118:26\f* 
\b  
\q1 “Udo nʼeluigwe, ebube dịkwa nʼebe kachasị elu.” 
\p  
\v 39 Ụfọdụ nʼime ndị Farisii so igwe mmadụ ahụ gwara ya, “Onye ozizi, gwa ndị na-eso ụzọ gị ka ha mechie ọnụ!” 
\p  
\v 40 Ọ zara sị, \wj “Ka m gwa unu, ọ bụrụ na ha agbaa nkịtị, nkume ndị a ga-eti mkpu.”\wj* 
\p  
\v 41 Mgbe ọ rutere Jerusalem nso, ebe ọ nọ hụzie obodo ahụ anya nke ọma. Ọ bere akwa nʼihi ya,  
\v 42 sị, \wj “Ọ bụrụ na ị maara taa, ọ bụladị gị onwe gị, ihe ndị na-eweta udo! Ma ugbu a, ezofuola ha nʼanya gị.\wj* 
\v 43 \wj Oge na-abịa mgbe ndị iro gị ga-agba gị gburugburu, mechie ụzọ mgbapụ niile, sitekwa nʼụzọ niile dị iche iche bịakwasị gị.\wj* 
\v 44 \wj Ha ga-egwepịa gị nʼala, gị na ụmụ gị nọ nʼime mgbidi a, ọ dịkwaghị nkume ọbụla ha ga-ahapụ nʼelu ibe ya, nʼihi na ị mataghị oge nleta Chineke nye gị.”\wj* 
\s1 Jisọs nʼime ụlọnsọ ukwu Chineke 
\p  
\v 45 Mgbe ahụ, ọ banyere nʼime ụlọnsọ ukwu bido ịchụpụ ndị nọ ebe ahụ na-ere ahịa.  
\v 46 Ọ sị ha, \wj “E dere ya nʼakwụkwọ nsọ ‘na a ga-akpọ ụlọ m ụlọ ekpere’; ma unu emeela ya ‘ọgba ndị na-apụnara mmadụ ihe nʼike.’\wj*\f + \fr 19:46 \ft \xt Aịz 56:7; Jer 7:11\f* \wj ”\wj* 
\p  
\v 47 Ụbọchị niile, ọ na-anọ na-akụzi ihe nʼụlọnsọ ukwu ahụ. Ma ndịisi nchụaja na ndị ozizi iwu na ndị ndu nʼetiti ndị mmadụ, nọ na-achọ ụzọ ha ga-esi gbuo ya.  
\v 48 Ma ha achọtaghị ụzọ ọbụla ime ya, nʼihi na mmadụ niile sogidere ya kwenyekwara nʼokwu ya. 
\c 20  
\s1 Ajụjụ banyere ike Jisọs nwere 
\p  
\v 1 Otu ụbọchị, ka ọ nọ nʼụlọnsọ ukwu na-ezi ndị mmadụ ihe na-ekwusakwa oziọma. Ndịisi nchụaja, na ndị ozizi iwu na ndị okenye bịakwutere ya.  
\v 2 Ha sịrị ya, “Gwa anyị, olee ikike i ji na-eme ihe ndị a niile? Onye nyekwara gị ikike a?” 
\p  
\v 3 Ọ zara ha sị, \wj “Aga m ajụkwa unu otu ajụjụ. Gwanụ m,\wj* 
\v 4 \wj baptizim nke Jọn, o si nʼeluigwe ka o si nʼaka mmadụ?”\wj* 
\p  
\v 5 Ha kparịtara ụka nʼetiti onwe ha ma sị, “Ọ bụrụ na anyị asị na o sitere nʼeluigwe, ọ ga-asị, ‘Gịnị mere unu na-ejighị kwenye na ya?’  
\v 6 Ọ bụrụkwanụ na anyị asị na, ‘o sitere nʼaka mmadụ,’ ndị mmadụ ga-atụ anyị nkume, nʼihi na ha niile kweere na Jọn bụ onye amụma.” 
\p  
\v 7 Ya mere, ha zara, “Anyị amaghị ebe o si bịa.” 
\p  
\v 8 Jisọs sịrị ha, \wj “Enwekwaghị m ike ịgwa unu ikike m ji na-eme ihe ndị a.”\wj* 
\s1 Ilu maka ndị ọrụ ubi 
\p  
\v 9 Ọ gara nʼihu tụọrọ ndị mmadụ ilu a sị, \wj “Otu nwoke nwere ubi vaịnị, nke o nyefere nʼaka ndị ga-elekọta ya anya ma pụọ gaa njem nʼala ọzọ ebe ọ nọrọ ogologo oge.\wj* 
\v 10 \wj Mgbe oge iwe ihe ubi ruru, o zigara otu nʼime ndị ohu ya ka ọ bịakwute ndị ahụ na-elekọtara ya ubi, ka ha nyekwa ya ụfọdụ nʼime mkpụrụ ubi vaịnị ahụ. Ma ndị na-elekọtara ya ubi jidere ya, tie ya ihe, zilaga ya nʼaka efu.\wj* 
\v 11 \wj O zigakwara ohu ya ọzọ. Ma ha tikwara ya ihe mee ya ihe ihere, zilakwaa ya nʼaka efu.\wj* 
\v 12 \wj O zigakwara onye nke atọ, ma ha merụrụ ya ahụ, chụlaa ya.\wj* 
\p  
\v 13 \wj “Mgbe ahụ, onyenwe ubi vaịnị ahụ sịrị, ‘Gịnị ka m ga-eme? Aga m ezigara ha ọkpara m, nke m hụrụ nʼanya, ma eleghị anya ha ga-asọpụrụ ya.’\wj* 
\p  
\v 14 \wj “Ma mgbe ndị na-elekọta ubi ahụ hụrụ ya, ha kwurịtara nʼetiti onwe ha, sị, ‘Onye a bụ onye nketa ihe niile a, ka anyị gbuo ya, ka ihe nketa a bụrụzia nke anyị.’\wj* 
\v 15 \wj Ya mere, ha kpụfere ya nʼazụ ubi vaịnị ahụ, gbuo ya.\wj* 
\p \wj “Gịnị ka onye nwe ubi ahụ ga-eme ha?\wj* 
\v 16 \wj Ọ ga-abịa, laa ndị ahụ na-elekọta ubi ahụ nʼiyi, were ubi vaịnị ahụ nye ndị ọzọ.”\wj* 
\p Mgbe ndị ahụ nụrụ nke a, ha sịrị, “Chineke ekwela.” 
\p  
\v 17 O legidere ha anya sị, \wj “Gịnịkwa ka unu chere na ihe e dere nʼakwụkwọ nsọ pụtara,\wj* 
\q1 \wj “ ‘Nkume ahụ ndị na-ewu ụlọ jụrụ\wj* 
\q2 \wj aghọọla nkume nke isi ntọala ụlọ’\wj*\f + \fr 20:17 \ft \xt Abụ 118:22\f*\wj ?\wj* 
\m  
\v 18 \wj Onye ọbụla nke dakwasịrị nʼelu nkume ahụ, ka a ga-etiwasị, ma onye ọbụla ọ dakwasịrị, ka ọ ga-egwepịa.”\wj* 
\p  
\v 19 Ndị ozizi iwu na ndịisi nchụaja chọrọ ụzọ ha ga-esi jide ya nʼotu oge ahụ nʼihi na ha matara na ọ bụ ha ka o bu nʼobi tụọ ilu ahụ, ma ha tụrụ egwu ndị mmadụ. 
\s1 Ilu banyere ụtụ isi nye Siza 
\p  
\v 20 Ya mere, ha chere ya nche nke ọma, ma zipụ ndị nnyopụta, ndị mere onwe ha dịka ndị ezi omume, ka ha chọpụta ma o nwere ụzọ ha ga-esi jide ya site nʼihe ọ ga-ekwu, ka ha site na nke a nyefee ya nʼaka ọchịchị na ike onyeisi ala.  
\v 21 Ya mere ndị nnyopụta ahụ jụrụ ya sị, “Onye ozizi, anyị mara na i na-ekwu ma na-ezikwa ihe ziri ezi, matakwa na i dịghị ele mmadụ anya nʼihu, kama ị na-ezi ụzọ Chineke dị ka eziokwu si dị.  
\v 22 O ziri ezi nʼiwu ka anyị tụọ ụtụ isi nye Siza, ka ọ bụ na o zighị ezi?” 
\p  
\v 23 Ma ọ matara na nke a bụ ajụjụ aghụghọ, ya mere ọ sịrị ha,  
\v 24 \wj “Gosinụ m otu mkpụrụ ego denarị. Isi onye ka e sere nʼelu ya, aha onye ka e dekwasịkwara ya?”\wj* 
\p Ha sịrị, “Ọ bụ nke Siza.” 
\p  
\v 25 Ọ sịrị ha, \wj “Ya mere, nyenụ Siza ihe bụ nke Siza, nyekwanụ Chineke ihe bụ nke Chineke.”\wj* 
\p  
\v 26 Ha enweghị ike ijide ya nʼihi ihe o kwuru nʼebe ahụ, nʼihu ọha mmadụ. Ọsịsa ya juru ha anya, ha mechikwara ọnụ. 
\s1 Mbilite nʼọnwụ na ọlụlụ di na nwunye 
\p  
\v 27 Ụfọdụ ndị Sadusii, ndị sị na mbilite nʼọnwụ adịghị, bịakwutere ya  
\v 28 ma jụọ ya sị, “Onye ozizi, Mosis deere anyị na ọ bụrụ na nwanne nwoke mmadụ anwụọ hapụ nwunye ya na-amụtaghị nwa, na nwoke dị otu a ga-alụrụ nwunye nwanne ya nwoke ahụ, sị otu a, mụtara nwanne ya ụmụ.  
\v 29 Ugbu a, e nwere ụmụnne nwoke asaa, onye nke mbụ lụrụ nwanyị, nwụọ na-amụtaghị nwa.  
\v 30 Nke abụọ kwa  
\v 31 na onye nke atọ lụrụkwara ya. Nʼotu aka ahụ ha asaa lụchara ya ma nwụọ na-amụtaghị nwa.  
\v 32 Nʼikpeazụ nwanyị ahụ nʼonwe ya nwụkwara.  
\v 33 Ya mere, nʼoge mbilite nʼọnwụ nwunye onye ka ọ ga-abụ? Nʼihi na ha asaa lụchara ya?” 
\p  
\v 34 Jisọs gwara ha, \wj “Ndị nke ọgbọ a na-alụ nwunye, ma na-enyekwa ụmụ ha ka a lụrụ ha.\wj* 
\v 35 \wj Ma ndị ahụ a gụrụ dị ka ndị kwesiri isoro keta oke nʼọgbọ ahụ, nakwa na mbilite nʼọnwụ agaghị alụ di na nwunye.\wj* 
\v 36 \wj Nʼezie, ha apụghịkwa ịnwụ ọzọ, nʼihi na ha dị ka ndị mmụọ ozi. Ha bụ ụmụ Chineke, nʼihi na ha bụ ụmụ nke mbilite nʼọnwụ.\wj* 
\v 37 \wj Ọ bụladị Mosis nʼonwe ya zipụtara na mbilite nʼọnwụ dị, nʼakụkọ banyere ọhịa ahụ na-ere ọkụ, mgbe ọ na-akpọ Onyenwe anyị ‘Chineke nke Ebraham, Chineke nke Aịzik na Chineke nke Jekọb.’\wj*\f + \fr 20:37 \ft \xt Ọpụ 3:6\f* 
\v 38 \wj Ọ bụghị Chineke nke ndị nwụrụ anwụ, kama ọ bụ nke ndị dị ndụ, nʼihi nʼebe ọ nọ mmadụ niile dị ndụ.”\wj* 
\p  
\v 39 Ụfọdụ ndị ozizi iwu zara ya sị, “Onye ozizi, ị kwuru nke ọma.”  
\v 40 O nwekwaghị onye ọbụla jụrụ ya ajụjụ ọzọ. 
\s1 Nwa onye ka Kraịst bụ? 
\p  
\v 41 Ma ọ sịrị ha, \wj “Olee otu ha si kwuo na Kraịst ahụ bụ nwa Devid?\wj* 
\v 42 \wj Devid nʼonwe ya kwupụtara nʼakwụkwọ Abụ Ọma, sị:\wj* 
\q1 \wj “ ‘Onyenwe anyị gwara Onyenwe m,\wj* 
\q2 \wj “Nọdụ ala nʼaka nri m\wj* 
\q1  
\v 43 \wj ruo mgbe m ga-eme ndị iro gị\wj* 
\q2 \wj ihe mgbakwasị ụkwụ nye ụkwụ gị.” ’\wj*\f + \fr 20:43 \ft \xt Abụ 110:1\f* 
\m  
\v 44 \wj Devid nʼonwe ya kpọrọ ya ‘Onyenwe anyị.’ Oleekwanụ otu o si bụrụ nwa ya?”\wj* 
\s1 Ịdọ aka na ntị banyere ndị ozizi iwu 
\p  
\v 45 Mgbe ndị mmadụ na-ege ntị, ọ sịrị ndị na-eso ụzọ ya,  
\v 46 \wj “Kpacharanụ anya nʼebe ndị ozizi iwu nọ. Ndị iyi uwe mwụda na-ejegharị ebe niile na-amasị, ndị hụrụ ekele pụrụ iche bụ nke a na-ekele ha nʼọma ahịa nʼanya. Ndị ọ na-amasịkwa ịnọkwasị nʼoche kachasị elu nʼụlọ ekpere nakwa nʼoche pụrụ iche na mmemme oriri ọbụla.\wj* 
\v 47 \wj Ha na-eripịa ihe niile dị nʼụlọ ndị inyom ndị di ha nwụrụ anwụ, nʼekpe ogologo ekpere ka a hụta ha. Ndị dị otu a ka a ga-ata ahụhụ dị ukwuu.”\wj* 
\c 21  
\s1 Onyinye nwanyị dị ya nwụrụ 
\p  
\v 1 Ọ leliri anya elu hụ ka ndị ọgaranya si etinye onyinye ha nʼime igbe onyinye.  
\v 2 Ọ hụkwara otu nwanyị di ya nwụrụ anwụ ka ọ bịara tinye naanị mkpụrụ ego kọpa abụọ.  
\v 3 Ọ sịrị, \wj “Nʼezie, agwa m unu, nwanyị ogbenye a di ya nwụrụ etinyela ego karịa ndị ọzọ niile.\wj* 
\v 4 \wj Nʼihi na ndị ọzọ niile nyere onyinye ha site nʼego mapụtaara ha nʼakụnụba ha, ma ya onwe ya sitere nʼogbenye ya tinye ihe niile o ji biri.”\wj* 
\s1 Akara na-egosi ọgwụgwụ oge 
\p  
\v 5 Mgbe ụfọdụ na-ekwu okwu banyere otu e si were nkume mara mma na onyinye e chere nʼihu Chineke, chọọ ụlọnsọ ukwu ahụ mma, ọ sịrị,  
\v 6 \wj “Ma banyere ihe ndị a, oge na-abịa mgbe ihe ndị a niile unu na-ahụ na-agaghị adịkwa. Ọ dịghị otu nkume a ga-ahapụ nʼelu ibe ya, a ga-akwatusị ha niile.”\wj* 
\p  
\v 7 Ha jụrụ ya sị, “Onye ozizi, olee mgbe ihe ndị a ga-emezu? Gịnị ga-abụkwa ihe ịrịbama ga-egosi na ha na-aga imezu?” 
\p  
\v 8 Ọ sịrị, \wj “Lezienụ anya ka a ghara iduhie unu nʼihi na ọtụtụ ga-abịa nʼaha m sị, ‘Abụ m ya,’ na-asịkwa na ‘Oge ahụ dị nso.’ Unu esokwala ha.\wj* 
\v 9 \wj Mgbe ọbụla unu nụrụ akụkọ agha dị iche iche na ọgbaaghara, ka ụjọ ghara ịtụ unu, ihe ndị a aghaghị ibu ụzọ mezuo, ma ọgwụgwụ oge erubeghị.”\wj* 
\p  
\v 10 Mgbe ahụ, ọ sịrị ha, \wj “Mba ga-ebili megide mba, alaeze ga-ebilikwa megide alaeze.\wj* 
\v 11 \wj A ga-enwe ala ọma jijiji dị ukwuu. Ụnwụ na ọrịa ọjọọ dị iche iche ga-adịkwa nʼebe dị iche iche. A ga-ahụ ihe dị egwu na ihe ịrịbama dị ukwuu site na mbara eluigwe.\wj* 
\p  
\v 12 \wj “Ma tupu ihe ndị a niile emezuo, ha ga-ejide unu, kpagbukwaa unu. Ha ga-enyefe unu nʼaka ọtụtụ ụlọ ekpere. Ha ga-atụkwa unu mkpọrọ. Ha ga-akpọpụkwa unu nʼihu ndị eze na ndị ọchịchị nʼihi aha m.\wj* 
\v 13 \wj Nke a ga-abụrụ unu ohere iji gbaa akaebe.\wj* 
\v 14 \wj Ma burunu ụzọ kpebie nʼobi unu na unu agaghị echegbu onwe unu maka ihe unu ga-aza.\wj* 
\v 15 \wj Nʼihi na aga m enye unu ụdị okwu na amamihe nke ndị na-ebo unu ebubo na-enweghị ike iguzogide maọbụ kwuo okwu megide.\wj* 
\v 16 \wj Ọ bụladị ndị mụrụ unu, ụmụnne unu ndị nwoke na ndị nwanyị, ndị ikwu unu na ndị enyi unu, ha ga-arara unu nye nʼaka ndị ọchịchị, ndị ga-egbukwa ụfọdụ nʼime unu.\wj* 
\v 17 \wj Mmadụ niile ga-akpọ unu asị nʼihi m.\wj* 
\v 18 \wj Ma otu agịrị isi dị nʼisi unu agaghị ala nʼiyi.\wj* 
\v 19 \wj Unu ga-azọpụta ndụ unu site na ntachiobi unu.\wj* 
\p  
\v 20 \wj “Mgbe unu hụrụ ka ndị agha gbara Jerusalem gburugburu, matanụ na oge e ji ala ya nʼiyi eruola.\wj* 
\v 21 \wj Nʼoge ahụ ka ndị nọ na Judịa gbalaga nʼugwu, ka ndị nọ nʼime obodo si na ya pụta, ka ndị na-anọghị nʼobodo gharakwa ịba nʼime ya.\wj* 
\v 22 \wj Nʼihi na oge a ga-abụ oge ịbọ ọbọ ka e mezuo ihe niile akwụkwọ nsọ kwuru.\wj* 
\v 23 \wj Ma ahụhụ ga-adịrị ndị dị ime, na ndị na-enye ụmụaka ara, nʼụbọchị ahụ! A ga-enwe oke ihe mgbu nʼala a, iwe ga-adakwasịkwa ụmụ mmadụ.\wj* 
\v 24 \wj Mma agha ga-egbu ha, mba niile ga-adọrọkwa ha nʼagha. Ndị mba ọzọ ga na-azọtọsị Jerusalem nʼụkwụ ruo mgbe oge nke ndị mba ọzọ ahụ zuru.\wj* 
\p  
\v 25 \wj “A ga-enwe ihe ịrịbama nʼanyanwụ, nʼọnwa, na kpakpando. Nʼelu ụwa, mba niile ga-anọ nʼoke ahụhụ na mgbagwoju anya dị ka oke osimiri na-eme mkpọtụ, ebili mmiri ga na-ebilikwa.\wj* 
\v 26 \wj Ndị mmadụ ga-adakwa mba nʼobi nʼihi ụjọ mgbe ha ghọtara ihe gaje ịbịakwasị ụwa, nʼihi na a ga-eme ka ike niile nke dị nʼeluigwe maa jijiji.\wj* 
\v 27 \wj Nʼoge ahụ, a ga-ahụ Nwa nke Mmadụ ka ọ na-abịa nʼike na ebube nʼigwe ojii.\wj* 
\v 28 \wj Mgbe ihe ndị a malitere ime, guzoronụ ọtọ welie isi unu elu, nʼihi na oge mgbapụta unu dị nso.”\wj* 
\p  
\v 29 Ọ tụụrụ ha ilu a, \wj “Leenụ osisi fiig na osisi ndị ọzọ niile anya.\wj* 
\v 30 \wj Mgbe ha bidoro ipupụta ahịhịa ọhụrụ, unu na-amata na ọkọchị adịla nso.\wj* 
\v 31 \wj Nʼụzọ dị otu a kwa, mgbe unu hụrụ ihe ndị a niile ka ha na-eme, matanụ na alaeze Chineke adịla nso.\wj* 
\p  
\v 32 \wj “Nʼezie agwa m unu, ọgbọ a agaghị agabiga tupu ihe ndị a niile emezuo.\wj* 
\v 33 \wj Eluigwe na ụwa ga-agabiga, ma okwu m enweghị ike ịgabiga.\wj* 
\p  
\v 34 \wj “Kpachapụkwanụ anya, unu ekwela ka e bogbuo obi unu site nʼoke oriri na ọṅụṅụ na nchekasị nke ndụ a, site otu a mee ka ụbọchị ahụ bịakwasị unu na mberede, dị ka ọnya.\wj* 
\v 35 \wj Nʼihi na ọ ga-abịakwasị ndị niile bi nʼelu ụwa.\wj* 
\v 36 \wj Nọrọnụ na nche oge niile ma na-ekpekwanụ ekpere ka unu nwee ike ịgbanarị ihe niile gaje ịbịa, ka unu nweekwa ike iguzo nʼihu Nwa nke Mmadụ.”\wj* 
\p  
\v 37 Kwa ụbọchị, ọ na-ezi ihe nʼụlọnsọ ukwu ahụ, ma nʼuhuruchi, ọ na-arịgoro nʼelu Ugwu Oliv ị ga nọọ ọnọdụ abalị.  
\v 38 Ndị mmadụ niile na-abịakwute ya nʼisi ụtụtụ niile nʼụlọnsọ ukwu ịnụrụ okwu ya. 
\c 22  
\s1 Judas agbaa Jisọs mgba okpuru 
\p  
\v 1 Nʼoge a, Mmemme Achịcha na-ekoghị eko nke a na-akpọ Ngabiga na-eru nso.  
\v 2 Ndịisi nchụaja na ndị ozizi iwu nọkwa na-achọ ụzọ ha ga-esi gbuo ya, nʼihi na ha na-atụ egwu ndị mmadụ.  
\v 3 Mgbe ahụ, ekwensu banyere nʼime Judas, onye a na-akpọ Iskarịọt, otu nʼime mmadụ iri na abụọ na-eso ụzọ ya.  
\v 4 Ọ gakwuru ndịisi nchụaja, na ndịisi ndị nlekọta nke ụlọnsọ ukwu ahụ, ya na ha akparịta ụka otu ọ ga-esi rara ya nyefee ya nʼaka ha.  
\v 5 Ha ṅụrịrị ọṅụ ma kwekwa nkwa inye ya ego.  
\v 6 O kwenyere, na-achọkwa ohere ga-adị mma ọ ga-eji nyefee ya nʼaka ha mgbe igwe mmadụ na-agaghị anọ. 
\s1 Nri anyasị nke ikpeazụ 
\p  
\v 7 O ruo nʼụbọchị Mmemme Achịcha na-ekoghị eko ahụ bụ ụbọchị a na-eji atụrụ Ngabiga achụ aja.  
\v 8 O zipụrụ Pita na Jọn sị, \wj “Gaanụ kwadoo maka oriri Ngabiga nke anyị ga-eri.”\wj* 
\p  
\v 9 Ha sịrị ya, “Ebee ka ị chọrọ ka anyị gaa kwadoo maka ya?” 
\p  
\v 10 Ọ sịrị ha, \wj “Lee, ka unu na-abata nʼobodo, otu nwoke bu ite mmiri ga-ezute unu, soronụ ya baa nʼụlọ ọbụla ọ banyere.\wj* 
\v 11 \wj Sịnụ onyenwe ụlọ ahụ, ‘Onye ozizi sịrị, Olee ụlọ ndị ọbịa ebe mụ na ndị na-eso ụzọ m ga-anọ rie oriri Ngabiga?’\wj* 
\v 12 \wj Ọ ga-egosi unu otu ọnụụlọ buru ibu dị nʼelu ụlọ nke e dozicharala ihe niile, kwadoonụ nri anyị nʼebe ahụ.”\wj* 
\p  
\v 13 Ha gara chọpụta ihe niile dị ka ọ gwara ha. Ha kwadokwara nri Ngabiga ahụ. 
\p  
\v 14 Mgbe oge awa ahụ ruru, ya na ndị na-eso ụzọ ya gara ebe ahụ nọdụ ala iri ihe.  
\v 15 Ọ sịrị ha, \wj “Ọ gụrụ m nnọọ agụụ ka mụ na unu rie nri Ngabiga a tupu mụ ataa ahụhụ.\wj* 
\v 16 \wj Nʼihi na asị m unu, agaghị m erikwa ya ọzọ tutu ruo mgbe a ga-emezu ya nʼalaeze Chineke.”\wj* 
\p  
\v 17 O buru iko, mgbe o nyechara ekele ọ sịrị, \wj “Burunu nke a kesaa nʼetiti unu.\wj* 
\v 18 \wj Nʼihi na asị m unu, site ugbu a ga nʼihu, agaghị m aṅụ mmanya sitere na mkpụrụ vaịnị ọzọ, ruo mgbe alaeze Chineke ga-abịa.”\wj* 
\p  
\v 19 O werekwara otu ogbe achịcha, mgbe o nyechara ekele, ọ nyawaa ya nye ha sị, \wj “Nke a bụ ahụ m nke e nyere nʼihi unu. Na-emenụ nke a iji na-echeta m.”\wj* 
\p  
\v 20 Nʼotu ụzọ ahụ, mgbe ha risiri nri anyasị o buuru iko sị, \wj “Iko a bụ iko nke ọgbụgba ndụ ọhụrụ nʼọbara m, nke a na-awụpụ nʼihi unu.\wj* 
\v 21 \wj Ma lee, onye ahụ nke ga-arara m nye nọnyeere m, o sokwa m na-eri nri.\wj* 
\v 22 \wj Nwa nke Mmadụ na-aga ịnwụ dị ka e kpebiri ya, ma ahụhụ ga-adịrị nwoke ahụ a ga-esi nʼaka ya rara ya nye.”\wj* 
\v 23 Ha bidoro ịjụrịta onwe ha onye ọ bụ nʼetiti ha ga-eme nke a. 
\p  
\v 24 Ịrụ ụka malitere nʼetiti ha banyere onye nʼime ha ka a na-agụ na ọ dị ukwuu karịa ibe ya.  
\v 25 Ma ọ sịrị ha, \wj “Ndị eze ndị mba ọzọ na-eji aka ike na-achị ndị nọ nʼokpuru ha. Otu aka ahụkwa, a na-akpọ ndị na-achị achị enyi ndị mmadụ.\wj* 
\v 26 \wj Ma unu onwe unu agaghị adị otu a. Kama onye kachasị ibe ya ịdị elu dịrị ka onye dịkarịsịrị nta. Ka onyeisi dịrị ka onye na-eje ozi.\wj* 
\v 27 \wj Onye dị elu karịa ibe ya? Ọ bụ onye nọdụrụ ala rie nri na tebul ka ọ bụ onye siri nri dozie ya na tebul? Ọ bụghị onye nọdụrụ ala rie nri na tebul? Ma adị m ka onye na-eje ozi nʼetiti unu.\wj* 
\v 28 \wj Ọ bụ unu onwe unu bụ ndị nọnyere m nʼoge ọnwụnwa m niile.\wj* 
\v 29 \wj Ana m enye unu alaeze dị ka Nna m nyere m ya.\wj* 
\v 30 \wj Ka unu nwe ike isoro m rie ma ṅụọkwa nʼalaeze m. Sorokwa m nọdụ nʼocheeze na-ekpe ebo iri na abụọ nke Izrel ikpe.\wj* 
\p  
\v 31 \wj “Saimọn, Saimọn, lee ekwensu arịọla ike ịyọcha unu dị ka ọka wiiti.\wj* 
\v 32 \wj Ma ekpeelara m gị ekpere ka okwukwe gị ghara ịda. Mgbe ị kwudosiri ike, gbaakwa ụmụnna gị ume.”\wj* 
\p  
\v 33 Ma ọ sịrị ya, “Onyenwe anyị, ejikeere m isoro gị gaa mkpọrọ, ma sorokwa gị nwụọ.” 
\p  
\v 34 Jisọs zara, \wj “Agwa m gị Pita, tupu oke ọkụkụ akwaa akwa taa, ị ga-agọnarị m ugboro atọ, si na ị maghị onye m bụ.”\wj* 
\p  
\v 35 Ọ gwara ha, \wj “Mgbe m zipụrụ unu na mbụ sị unu ewerekwala ego, maọbụ akpa maọbụ akpụkpọụkwụ, o nwere ihe kọrọ unu?”\wj* 
\p Ha sịrị, “O nweghị ihe kọrọ anyị.” 
\p  
\v 36 Ọ sịrị ha, \wj “Ugbu a, ọ bụrụ na i nwere akpa ego, were ya, ma werekwa akpa ije. Ọ bụrụkwa na i nweghị mma agha ree uwe mgbokwasị gị zụtara onwe gị otu.\wj* 
\v 37 \wj Nʼihi na agwa m unu, na a ga-emejupụta ihe ndị a e dere nʼakwụkwọ nsọ nʼime m, A gụkọtara ya na ndị na-emebi iwu.\wj*\f + \fr 22:37 \ft \xt Aịz 53:12\f*\wj Nʼezie, ihe e dere banyere m eruwela mgbe ọ ga-emezu.”\wj* 
\p  
\v 38 Ha sịrị, “Onyenwe anyị, lee mma agha abụọ dị ebe a.” 
\p Ọ sịrị ha, \wj “Nke ahụ ezuola.”\wj* 
\s1 Ekpere Jisọs kpere nʼUgwu Oliv 
\p  
\v 39 Jisọs pụrụ gaa nʼUgwu Oliv dị ka ọ na-eme mgbe dum, ndị na-eso ụzọ ya sokwa ya gaa.  
\v 40 Mgbe o ruru nʼebe ahụ, ọ sịrị ha, \wj “Kpeenụ ekpere ka unu ghara ịdaba nʼọnwụnwa.”\wj* 
\v 41 Ọ hapụrụ ha gaa ihe ha ka nzọ ụkwụ ole na ole nọrọ nʼebe ahụ gbuo ikpere nʼala kpee ekpere, sị,  
\v 42 \wj “Nna ọ bụrụ na ị chọrọ, nara m iko a, ma otu ọ dị, ọ bụghị ka e mee uche m, kama ka e mezuo uche gị.”\wj* 
\v 43 Otu mmụọ ozi si nʼeluigwe bịakwutere ya, gbaakwa ya ume.  
\v 44 Site nʼoke ihe mgbu, o kpere ekpere kpesie ike, nke mere na ọsụsọ si ya nʼahụ na-adapụ nʼala dị ka ọkpụrụkpụ ọbara. 
\p  
\v 45 Mgbe o kpechara ekpere bilie, ọ bịakwutere ndị na-eso ụzọ ya hụ ha ka ha na-arahụ ụra nʼihi ihe mwute nke obi.  
\v 46 Ọ sịrị ha, \wj “Gịnị mere unu ji na-arahụ ụra? Bilienụ kpee ekpere ka unu ghara ịdaba nʼọnwụnwa.”\wj* 
\s1 Njide e jidere Jisọs 
\p  
\v 47 Mgbe ọ ka kpụ okwu nʼọnụ, igwe mmadụ bịara, onye du ha bụ onye a na-akpọ Judas, bụ otu nʼime mmadụ iri na abụọ ahụ na-eso ụzọ ya. Ọ bịaruru Jisọs nso, isutu ya ọnụ.  
\v 48 Ma Jisọs sịrị ya, \wj “Judas, ọ bụ site nʼisutu ọnụ ka i ji arara Nwa nke Mmadụ nye?”\wj* 
\p  
\v 49 Mgbe ndị nọ ya gburugburu hụrụ ihe gaje ime, ha sịrị, “Onyenwe anyị, ọ bụ anyị were mma agha gbuo?”  
\v 50 Otu nʼime ha ji mma gbuo ohu onyeisi nchụaja, gbupụ ntị aka nri ya. 
\p  
\v 51 Ma Jisọs sịrị, \wj “O zuola!”\wj* O metụkwara ntị nwoke ahụ aka gwọọ ya. 
\p  
\v 52 Mgbe ahụ, Jisọs sịrị ndịisi nchụaja, na ndị nlekọta nke ụlọnsọ ukwu na ndị okenye, \wj “Gịnị mere unu ji chịrị mma agha na mkpọ bịa ijide m, dị ka a ga-asị na m bụ onye ohi o ji egbe ezu?\wj* 
\v 53 \wj Mgbe mụ na unu na-anọ kwa ụbọchị nʼime ụlọnsọ ukwu ahụ, ma unu emetụghị m aka. Ma ugbu a bụ oge awa unu bụrụkwa mgbe ike ọchịchịrị na-achị achị.”\wj* 
\s1 Pita agọnarị Jisọs 
\p  
\v 54 Mgbe ahụ ha jidere ya duru ya pụọ, gaa nʼụlọ onyeisi nchụaja. Pita sokwara ha nʼazụ kama ọ nọ nʼebe dị anya.  
\v 55 Mgbe ha kwanyere ọkụ nʼetiti mbara ezi obi ahụ, ma nọdụ ala gba ọkụ ahụ gburugburu, Pita sokwara ha nọdụ ala.  
\v 56 Ka ọ na-anya ọkụ ahụ, otu nwaagbọghọ na-eje ozi hụrụ ya, o leruru ya anya nke ọma, sị, “Onye a na Jisọs nọkọrọ.” 
\p  
\v 57 Ma ọ gọrọ agọ sị, “Nwanyị, amaghị m onye ọ bụ.” 
\p  
\v 58 Mgbe oge nta gasịrị, onye ọzọ hụkwara ya kwukwaa sị, “Gị onwe gị bụkwa otu onye nʼime ha.” 
\p Ma Pita kwuru sị, “Nwoke m, abụghị m.” 
\p  
\v 59 Mgbe ihe dị ka otu awa gafere, onye ọzọ bịakwara kwusie okwu ike, “Nʼezie, nwoke a so ya nʼihi na ọ bụ onye Galili.” 
\p  
\v 60 Pita sịrị, “Nwoke m, amaghị m ihe ị na-ekwu maka ya?” Dị ka ọ kpụ okwu ahụ nʼọnụ, oke ọkpa kwara akwa.  
\v 61 Mgbe ahụ, Onyenwe anyị tụgharịrị lee Pita anya. Pita chetakwara okwu Onyenwe anyị gwara ya nke bụ, \wj “Tupu oke ọkpa akwa akwa taa, ị ga-agọnarị m ugboro atọ.”\wj* 
\v 62 Ma ọ pụrụ nʼezi gaa bee akwa na mwute. 
\s1 Ndị nche kwara Jisọs emo 
\p  
\v 63 Ndị ahụ na-eche ya nche bidoro na-akwa ya emo na-etikwa ya ihe.  
\v 64 Ha jiri akwa kechie ya anya, sị ya, “Buo amụma, onye tiri gị ihe?”  
\v 65 Ha kwukwara ọtụtụ okwu ọjọọ na nke mkparị megide ya. 
\s1 Jisọs nʼihu Pailet na Herọd 
\p  
\v 66 Mgbe chi bọrọ, nzukọ ndị okenye na ndịisi nchụaja, na ndị ozizi iwu zukọtara, a kpọtakwara Jisọs nʼihu ha.  
\v 67 Ha na-ekwu, “Ọ bụrụ na ị bụ Kraịst, gwa anyị.” 
\p Ọ sịrị ha, \wj “Ọ bụrụ na m agwa unu, unu agaghị ekwe.\wj* 
\v 68 \wj Ọ bụrụkwa na m ajụọ unu ajụjụ, unu agaghị aza m.\wj* 
\v 69 \wj Ma site ugbu a gawa, Nwa nke Mmadụ ga-anọdụ ala nʼaka nri nke ike Chineke.”\wj* 
\p  
\v 70 Ha niile sịrị, “Gị onwe gị, ị bụ Ọkpara Chineke?” 
\p Ọ sịrị ha, \wj “Unu kwuru na Abụ m.”\wj* 
\p  
\v 71 Mgbe ahụ ha sịrị, “Gịnị mere anyị ji na-achọ onye akaebe ọzọ? Anyị ejirila ntị anyị nụrụ ya site nʼọnụ ya.” 
\c 23  
\s1 Jisọs nʼihu Pailet 
\p  
\v 1 Mgbe ahụ, ọha mmadụ ahụ niile biliri duru ya gakwuru Pailet.  
\v 2 Ha malitere ibo ya ebubo na-asị, “Anyị chọpụtara na nwoke a na-eduhie ndị obodo anyị niile, na-egbochikwa ha ịtụ ụtụ isi nye Siza, ma na-ekwukwa na ya bụ Kraịst, Eze.” 
\p  
\v 3 Ya mere Pailet jụrụ ya sị, “Ị bụ eze ndị Juu?” 
\p Ọ zara ya sị, \wj “Gị onwe gị kwuru otu a.”\wj* 
\p  
\v 4 Mgbe ahụ Pailet gwara ndịisi nchụaja na igwe mmadụ ahụ, “O nweghị ihe ọjọọ ọbụla m chọpụtara nwoke a mere.” 
\p  
\v 5 Ma ha gara nʼihu na-asị, “Ọ na-akpasu ọgbaaghara nʼala ndị Judịa niile site nʼozizi ya. Ọ malitere na Galili, ọ bịakwala ebe a ugbu a.” 
\s1 Jisọs nʼihu Herọd 
\p  
\v 6 Mgbe Pailet nụrụ nke a, ọ jụrụ ma nwoke a ọ bụ onye Galili?  
\v 7 Mgbe ọ matara na o si nʼebe Herọd na-achị, o nyere iwu ka e dugara ya Herọd, onye nọkwa na Jerusalem mgbe ahụ. 
\p  
\v 8 Obi tọrọ Herọd ụtọ nke ukwuu, mgbe ọ hụrụ Jisọs nʼihi na ọ nọ na-achọ ịhụ ya anya nʼoge dị anya gara aga. Sitekwa nʼakụkọ ọ nụrụ banyere ya, o lere anya na ọ ga-arụ ọrụ ebube ụfọdụ.  
\v 9 Ya mere ọ jụrụ ya ọtụtụ ajụjụ, ma ọ zaghị ya ihe ọbụla.  
\v 10 Ndịisi nchụaja na ndị ozizi iwu guzo nʼebe ahụ gara nʼihu bosie ya ebubo ike.  
\v 11 Emesịa, Herọd na ndị agha ya jiri ya mee ihe ọchị, ma kwaakwa ya emo. Ha yikwasịrị ya uwe mwụda mara mma ma zighachikwara ya Pailet.  
\v 12 Nʼụbọchị ahụ ka Herọd na Pailet ghọrọ enyi, maka nʼoge gara aga ha bụ ndị iro. 
\p  
\v 13 Pailet kpọkọtara ndịisi nchụaja, na ndị ndu, na ndị mmadụ ndị ọzọ  
\v 14 sị ha, “Unu kpọtaara m nwoke a dị ka otu onye nʼime ndị na-akpali ndị mmadụ inupu isi. Ajụọla m ya ajụjụ nʼihu unu ma achọpụtaghị m ihe ọbụla nke unu kwesiri iji boo ya ebubo.  
\v 15 Ọ bụladị Herọd achọpụtaghị ihe ọjọọ ọbụla nʼaka ya, nke a mere o jiri kpụghachitere anyị ya. Leenụ, o nweghị ihe ọbụla o mere e kwesiri iji maa ya ikpe ọnwụ.  
\v 16 Ya mere aga m apịa ya ihe hapụ ya ka ọ laa.”  
\v 17 Ma ọ dị mkpa na a ga-ahapụ otu onye mkpọrọ nʼoge mmemme.\f + \fr 23:17 \ft Ụfọdụ akwụkwọ na-edebanye okwu ndị a dịka ọ dị nʼakwụkwọ \xt Mat 27:15\ft  na \xt Mak 15:6\ft .\f* 
\p  
\v 18 Ma igwe mmadụ ahụ tiri mkpu nʼotu olu sị, “Gbuo nwoke a, hapụrụ anyị Barabas.”  
\v 19 (Onye a tụbara nʼụlọ mkpọrọ nʼihi ọgbaaghara dapụtara nʼobodo ahụ, nakwa nʼihi igbu mmadụ.) 
\p  
\v 20 Dị ka ọ gbalịsịrị ike ịhapụ Jisọs, Pailet gwakwara ha okwu ọzọ.  
\v 21 Ma ha niile tiri mkpu sị, “Kpọgide ya nʼobe! Kpọgide ya nʼobe!” 
\p  
\v 22 Ọ sịrị ha na nke ugboro atọ, “Ọ bụ nʼihi gịnị? Olee ihe ọjọọ nwoke a mere? O nweghị ihe ọbụla m chọpụtara nʼaka ya kwesiri iwetara ya ọnwụ. Ya mere aga m ata ya ahụhụ, hapụ ya.” 
\p  
\v 23 Ma ha nọgidere na-eti mkpu nʼoke olu ka a kpọgide ya nʼobe, nʼikpeazụ olu iti mkpu ha karịrị.  
\v 24 Ya mere Pailet kpebiri imere ha ihe ha chọrọ.  
\v 25 Ọ hapụrụ nwoke ahụ ha chọrọ nke a tụbara nʼụlọ mkpọrọ nʼihi ọgbaaghara na igbu mmadụ, ma nyefee ha Jisọs nʼaka. 
\s1 Mkpọgide Jisọs nʼobe 
\p  
\v 26 Dị ka ha duu ya na-aga, ha jidere Saimọn onye Sirini bụ onye si nʼime otu obodo nta na-alọbata; ha boro ya obe ahụ, manye ya ka o buru ya na-eso Jisọs na-azụ.  
\v 27 Igwe mmadụ dị ukwuu soro ya tinyekwara ụmụ nwanyị bụ ndị tiri mkpu akwa ma ruokwara ya ụjụ.  
\v 28 Ma Jisọs tụgharịrị sị ha, \wj “Ụmụada Jerusalem, unu eberela m akwa, kama beerenụ onwe unu na ụmụ unu.\wj* 
\v 29 \wj Nʼihi na oge na-abịa mgbe unu ga-asị, ‘Ngọzị na-adịrị ụmụ nwanyị aga, akpanwa ndị na-amụghị nwa, na ara ndị na-enweghị onye ṅụrụ ha.’\wj* 
\v 30 \wj Mgbe ahụ,\wj* 
\q1 \wj “ ‘ha ga-asị, ugwu ukwu niile, “Dakwasị anyị!”\wj*\f + \fr 23:30 \ft \xt Hos 10:8\f* 
\q2 \wj Sịkwa, ugwu nta, “Kpuchite anyị!” ’\wj*  
\m  
\v 31 \wj Ya mere, ọ bụrụ na ha mee ọhịa otu a mgbe ahịhịa dị ndụ dị na ya, gịnị ga-emekwanụ mgbe ọ kpọrọ nkụ?”\wj* 
\p  
\v 32 Ha dukwaara mmadụ abụọ bụ ndị ohi gaa igbu ha na ya.  
\v 33 Mgbe ha bịarutere nʼebe a na-akpọ Okpokoro Isi, ebe ahụ ka ha kpọgidere ya nʼobe ya na ndị ohi abụọ ahụ. Otu nʼaka nri ya nke ọzọ nʼaka ekpe ya.  
\v 34 Jisọs sịrị, \wj “Nna gbaghara ha nʼihi na ha amataghị ihe ha na-eme.”\wj* Ha ji ife nza kee uwe ya nʼetiti onwe ha. 
\p  
\v 35 Ndị mmadụ guzoro ebe ahụ na-ele anya, ka ndị ọchịchị ji ya na-eme ihe ọchị, na-asị, “Ọ zọpụtara ndị ọzọ, ya zọpụtanụ onwe ya, ma ọ bụrụ na ọ bụ Kraịst nke Chineke, bụ Onye a họpụtara.” 
\p  
\v 36 Ndị agha bịakwara chịa ya ọchị. Ha nyere ya mmanya gbara ụka,\f + \fr 23:36 \ft \xt Mat 27:48\f* 
\v 37 ma na-asị, “Ọ bụrụ na ị bụ eze ndị Juu, zọpụtanụ onwe gị.” 
\p  
\v 38 Ihe e dere nʼelu isi obe ahụ bụ: 
\pc Onye a bụ Eze ndị Juu. 
\p  
\v 39 Otu onye nʼime ndị ohi ahụ a kpọgidekwara nʼobe nʼebe ahụ kparịkwara ya sị, “Ọ bụghị gị bụ Kraịst? Zọpụtanụ onwe gị ma zọpụtakwa anyị.” 
\p  
\v 40 Ma onye nke ọzọ a makwara ikpe ọnwụ baara ya mba sị, “Ị naghị atụ Chineke egwu, ị hụghị na a mara gị ikpe dị ka e si maa ya.  
\v 41 Anyị na-ata ahụhụ kwesiri anyị, nʼihi na a na-ata anyị ahụhụ nʼihi ihe anyị mere, ma nwoke a emeghị ihe ọjọọ ọbụla.” 
\p  
\v 42 Mgbe ahụ ọ sịrị, “Jisọs, chetakwa m mgbe ị bara nʼalaeze gị.” 
\p  
\v 43 Ọ sịrị ya, \wj “Nʼezie a agwa m gị, taa, ị ga-anọnyere m na paradaịs.”\wj* 
\s1 Ọnwụ Jisọs 
\p  
\v 44 Mgbe ọ na-eru ihe dị ka elekere iri na abụọ nke ehihie, ọchịchịrị gbachikọtara nʼala ahụ niile ruo elekere atọ nke ehihie.  
\v 45 Nʼihi na anyanwụ kwụsịrị inye ihe ya. Akwa mgbochi dị nʼụlọnsọ ukwu sitere nʼelu gbawaa abụọ.  
\v 46 Jisọs tiri mkpu nʼoke olu sị, \wj “Nna, nʼaka gị ka m na-enyefe mmụọ m.”\wj* Mgbe o kwusiri nke a, o kubiri ume. 
\p  
\v 47 Mgbe ọchịagha na-achị otu narị ndị agha hụrụ ihe merenụ, o nyere Chineke otuto ma kwuokwa sị, “Nʼezie nwoke a bụ onye ezi omume.”\f + \fr 23:47 \ft Maọbụ, \fqa onye aka ya dị ọcha\f* 
\v 48 Mgbe igwe mmadụ niile gbakọtara ilere anya hụrụ ihe mere, ha laghachiri nʼụlọ ha na-eti aka nʼobi.  
\v 49 Ma ndị niile maara onye ọ bụ, tinyekwara ụmụ nwanyị ndị soro ya si Galili bịa, guzokwara nʼebe dị anya na-ele ihe ndị a. 
\s1 Olili Jisọs 
\p  
\v 50 O nwere otu nwoke aha ya bụ Josef, onye so nʼotu ndịisi ụlọ nzukọ. Ọ bụ ezigbo mmadụ na onye aka ya kwụ ọtọ.  
\v 51 Ọ kwadoghị mkpebi ha na omume ha. Onye sitere Arimatia, nʼotu obodo ndị Juu, onye na-echere ọbịbịa nke alaeze Chineke.  
\v 52 Nwoke a gakwuru Pailet rịọọ ka e bunye ya ahụ Jisọs.\f + \fr 23:52 \ft Jọn onye Arimatia bụ onye na-eso Jisọs na nzuzo \xt Jọn 19:38\ft .\f* 
\v 53 Ya mere, o budatara ya fụchie ya nʼakwa ọcha linin, tinye ya nʼili e gwuru nʼọgba nkume, nke a na-etinyebeghị mmadụ na mbụ.  
\v 54 Ọ bụ Ụbọchị Nkwadebe maka ụbọchị izuike nke na-abịa nso.\f + \fr 23:54 \ft Ndị na-edebe ụbọchị izuike nʼala anyị, na-akwadobe ihe ha niile nke ọma nʼụbọchị fụraịdee, nʼihi na ụbọchị izuike na-ebido nʼoge ọdịda anyanwụ nʼụbọchị ahụ.\f* 
\p  
\v 55 Ndị nwanyị ahụ sitere Galili soro ya hụrụ ili ahụ, hụkwa otu e si nibe ahụ ya nʼime ya.  
\v 56 Emesịa ha laghachiri ga kwadoo mmanụ otite nke e tinyere ọtụtụ ụda. Nʼụbọchị izuike ha zukwara ike dịka ọ dị nʼiwu.\f + \fr 23:56 \ft \xt Ọpụ 35:2\ft  na \xt Lev 23:3\ft  nakwa \xt Dit 5:14\f* 
\c 24  
\s1 Mbilite nʼọnwụ 
\p  
\v 1 Nʼụbọchị mbụ nke izu ụka, nʼezigbo isi ụtụtụ, ha weere mmanụ otite ahụ ha tinyere ọtụtụ ụda nke ha kwadoro gawa nʼili ahụ.  
\v 2 Ha chọpụtara na e nupụla nkume e ji dochie nʼọnụ ili ahụ.  
\v 3 Ma mgbe ha banyere nʼime ya, ha ahụghị ahụ Onyenwe anyị Jisọs.  
\v 4 Dị ka ha nọ na mgbagwoju anya banyere nke a, nʼotu ntabi anya, ha hụrụ mmadụ abụọ yi uwe na-egbu ka amụma guzo ha nso.  
\v 5 Ha kpudoro ihu ha nʼala nʼihi oke egwu, ma mmadụ abụọ ahụ gwara ha, “Gịnị mere unu ji na-achọ onye dị ndụ nʼetiti ndị nwụrụ anwụ?  
\v 6 Ọ nọkwaghị nʼebe a, o biliela nʼọnwụ, chetakwanụ ihe ọ gwara unu mgbe unu na ya nọ na Galili sị,  
\v 7 \wj ‘A ghaghị inyefe Nwa nke Mmadụ nʼaka ndị mmehie, a ga-akpọgidekwa ya nʼobe ma nʼụbọchị nke atọ ọ ga-esi nʼọnwụ bilie.’ ”\wj* 
\v 8 Mgbe ahụ ha chetara okwu ya. 
\p  
\v 9 Mgbe ha sitere nʼili ahụ lọghachi, ha kọọrọ mmadụ iri na otu ahụ na ndị ọzọ niile ihe ndị a.  
\v 10 Ọ bụ Meri Magdalin, na Joana, na Meri nne Jemis na ụmụ nwanyị ndị ọzọ so ha kọọrọ ndị na-eso ụzọ ya ihe a.  
\v 11 Ma ha ekweghị ihe ha gwara ha, nʼihi na okwu ha dị ha ka ọ bụ ihe efu.  
\v 12 Ma otu ọ dị, Pita gbaara ọsọ ruo nʼili ahụ, hulata ala hụ ka akwa ozu ndị ahụ tọgbọọrọ onwe ha; ọ lara na-atụgharị uche nʼime onwe ya ihe ihe ndị a pụtara. 
\s1 Nʼụzọ Emaus 
\p  
\v 13 Nʼotu ụbọchị ahụ, mmadụ abụọ nʼime ha gaje nʼobodo nta a na-akpọ Emaus, nke dị ihe ruru kilomita iri na abụọ site na Jerusalem.  
\v 14 Ha na-ekwurịta nʼetiti onwe ha banyere ihe niile mere.  
\v 15 Dị ka ha na-ekwu na-akparịta ụka banyere ihe ndị a, Jisọs nʼonwe ya bịara soro ha na-aga ije.  
\v 16 Ma e mechiri anya ha ịmata na ọ bụ ya. 
\p  
\v 17 Ọ sịrị ha, \wj “Gịnị ka unu na-ekwurịta nʼetiti onwe unu dị ka unu na-aga nʼụzọ.”\wj* 
\p Ha kwụsịrị ebe ahụ, gbarụọ ihu ha.  
\v 18 Otu onye nʼime ha a na-akpọ Kleopas, sịrị ya, “Ị bụ onye ọbịa na Jerusalem nke mere na ị maghị ihe mere nʼime ya nʼụbọchị ndị a?” 
\p  
\v 19 Ọ sịrị ha, \wj “Gịnị bụ ihe mere?”\wj* 
\p Ha sịrị ya, “Banyere Jisọs onye Nazaret! Ọ bụ onye amụma bụrụkwa onye dị ike, ma nʼokwu ma nʼomume nʼihu Chineke na mmadụ niile.  
\v 20 Na otu ndịisi nchụaja na ndị ọchịchị anyị nyefere ya ka a maa ya ikpe ọnwụ, ma kpọgbukwaa ya nʼobe.  
\v 21 Anyị nwererịị olileanya na ọ bụ ya ga-agbapụta Izrel. Nke ka nke, taa mere ya abalị atọ kemgbe ihe ndị a mere.  
\v 22 Tụkwasị ihe ndị a, ụfọdụ ụmụ nwanyị anyị mere ka anyị nwee ihe ịtụnanya. Ha gara nʼili ahụ nʼisi ụtụtụ a.  
\v 23 Ma ha ahụghị ahụ ya. Ha bịara kọrọ anyị na ha hụrụ ọhụ nke ndị mmụọ ozi, bụ ndị gwara ha na ọ dị ndụ.  
\v 24 Ya mere ụfọdụ nʼime ndị otu anyị gara nʼili ahụ chọpụta na ihe niile ụmụ nwanyị a kwuru mere otu ahụ ha siri kwuo ya. Ma ha ahụkwaghị ya.” 
\p  
\v 25 Ọ sịrị ha, \wj “Unu bụ nnọọ ndị nzuzu!\wj*\f + \fr 24:25 \ft Ya bụ, ndị na-enweghị uche\f*\wj Leenụ ka o si siere unu ike ikwere ihe niile ndị amụma kwuru.\wj* 
\v 26 \wj Ọ bụ na o kwesighị ka Kraịst taa ahụhụ ndị a tupu ọ banye nʼebube ya?”\wj* 
\v 27 Ya mere, ọ kọwaara ha ihe e dere nʼakwụkwọ nsọ banyere ya onwe ya malite na nke Mosis ruo na ndị amụma niile. 
\p  
\v 28 Mgbe ha na-eru obodo nta ahụ ha na-aga, o mere dị ka ọ na-aga nʼihu na njem ya.  
\v 29 Ma ha rịọ ya nʼebe ọ dị ukwuu sị, “Nọnyerenụ anyị nʼihi na chi ebidola iji, ụbọchị agamiekwala ugbu a.” Nʼihi ya ọ banyere ịga nọnyere ha. 
\p  
\v 30 Mgbe ya na ha nọdụrụ na tebul iri nri, o were achịcha, kelee Chineke ekele, nyawaa ya were ya nye ha.  
\v 31 Mgbe ahụ, e meghere anya ha, ha amata onye ọ bụ, ha ahụkwaghị ya anya ọzọ.  
\v 32 Mgbe ahụ, ha gwara onwe ha sị, “Ọ bụ na ọ dịghị ka ọkụ ọ na-enwu nʼobi anyị mgbe anyị na ya nọ nʼụzọ, ya na-ekpughere anyị akwụkwọ nsọ?” 
\p  
\v 33 Ha biliri ngwangwa laghachi Jerusalem. Ebe ahụ, ha hụrụ mmadụ iri na otu ahụ na ndị so ha ka ha nọkọtara nʼotu ebe,  
\v 34 na-asị, “Ọ bụ eziokwu, Onyenwe anyị ebiliela, o gosila Saimọn onwe ya.”  
\v 35 Mgbe ahụ, ha kọọrọ ha ihe mere nʼụzọ, ya na otu ha siri mata ya mgbe ọ nyawara achịcha. 
\s1 Jisọs egosi ndị na-eso ụzọ ya onwe ya 
\p  
\v 36 Mgbe ha ka na-ekwu banyere nke a, ya onwe ya guzooro nʼetiti ha sị ha, \wj “Udo dịrị unu.”\wj* 
\p  
\v 37 Oke egwu tụrụ ha, obi lọkwara ha mmiri nʼihi na ha chere na ha ahụla mmụọ.  
\v 38 Ma ọ sịrị ha, \wj “Gịnị mere ụjọ ji atụ unu, gịnị mere unu ji nwee obi abụọ?\wj* 
\v 39 \wj Leenụ m anya nʼaka na nʼụkwụ. Ọ bụ mụ onwe m! Metụnụ m aka ka unu hụrụ, nʼihi na mmụọ adịghị enwe anụ ahụ na ọkpụkpụ dị ka unu hụrụ m nwere.”\wj* 
\p  
\v 40 Mgbe o kwuchara nke a, o gosiri ha aka ya na ụkwụ ya.  
\v 41 Ma dị ka o siiri ha ike ikwere nʼihi ọṅụ na oke mgbagwoju anya, ọ sịrị ha, \wj “Ọ dị ihe oriri unu nwere ebe a?”\wj* 
\v 42 Ha nyere ya otu ntakịrị azụ a mịkpọrọ amịkpọ.  
\v 43 Ma ọ naara ya rie ya nʼihu ha. 
\p  
\v 44 Mgbe ahụ, ọ sịrị ha, \wj “Okwu ndị a ka m gwara unu mgbe mụ na unu nọ, na ihe niile e dere nʼiwu Mosis na ndị Amụma na nʼAbụ Ọma banyere m ga-emezucha.”\wj* 
\p  
\v 45 Mgbe ahụ, o meghere akọnuche ha ka ha ghọta akwụkwọ nsọ.  
\v 46 Ọ sịrị ha, \wj “Nke a bụ ihe e dere na, Kraịst ahụ ga-ahụ ahụhụ ma sitekwa nʼọnwụ bilie\wj*\f + \fr 24:46 \ft Mbilite nʼọnwụ Kraịst bụ ihe e mere ka ọ dị ire site nʼike Chineke \xt Ọrụ 2:45; Rom 8:11\ft  Ọ bụkwa mbilite nʼọnwụ ya nyere ọha mmadụ napụta site nʼikpe ọmụma nke mmehie na-eweta, \xt Rom 4:25; 8:34\ft .\f*\wj nʼụbọchị nke atọ.\wj* 
\v 47 \wj Na a ga-ekwusa nchegharị na mgbaghara mmehie site nʼaha ya nye mba niile, malite na Jerusalem.\wj* 
\v 48 \wj Unu bụ ndị akaebe nke ihe ndị a.\wj* 
\v 49 \wj Ma lee, agaje m izitere unu ihe ahụ Nna m kwere na nkwa. Ya mere, nọrọnụ nʼime obodo ruo mgbe a ga-eyikwasị unu ike nke si nʼelu.”\wj* 
\s1 Jisọs agbagoro nʼeluigwe 
\p  
\v 50 O duuru ha garuo na Betani, chilie aka ya abụọ elu gọzie ha.  
\v 51 Dị ka ọ na-agọzi ha, ọ sitere nʼebe ha nọ pụọ, e weliri ya elu, baa nʼeluigwe.  
\v 52 Mgbe ahụ, ha fere ya ofufe jiri oke ọṅụ laghachi na Jerusalem.  
\v 53 Ha nọgidere nʼụlọnsọ ukwu ahụ na-eto Chineke oge niile.