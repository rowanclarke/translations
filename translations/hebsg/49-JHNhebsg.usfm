\id JHN
\h ג'ון
\toc1 הבְּשׂוֹרָה הַקְּדוֹשָׁה עַל־פִּי יוֹחָנָן
\toc2 ג'ון
\toc3 ג'ון
\mt1 הבְּשׂוֹרָה הַקְּדוֹשָׁה עַל־פִּי יוֹחָנָן
\c 1
\cp א
\cl פרק א
\p 
\v 1 \vp א\vp* בְּרֵאשִׁית הָיָה הַדָּבָר וְהַדָּבָר הָיָה אֶת־הָאֱלֹהִים וְהוּא הַדָּבָר הָיָה אֱלֹהִים׃
\v 2 \vp ב\vp* הוּא הָיָה מֵרֹאשׁ אֶת־הָאֱלֹהִים׃
\v 3 \vp ג\vp* כָּל־הַמַּעֲשִׂים נִהְיוּ עַל־יָדוֹ וְאֵין דָּבָר אֲשֶׁר נַעֲשָׂה מִבַּלְעָדָיו׃
\v 4 \vp ד\vp* בּוֹ נִמְצָא חַיִּים וְהַחַיִּים הֵם אוֹר הָאָדָם׃
\v 5 \vp ה\vp* וְהָאוֹר זֹרֵחַ בַּחֹשֶׁךְ וְהַחֹשֶׁךְ לֹא יְכִילֶנּוּ׃
\v 6 \vp ו\vp* אִישׁ הָיָה בָאָרֶץ יוֹחָנָן שְׁמוֹ אֲשֶׁר שְׁלָחוֹ אֱלֹהִים׃
\v 7 \vp ז\vp* הוּא בָא לְעֵדוּת לְהָעִיד עַל־הָאוֹר לְמַעַן יַאֲמִינוּ כֻלָּם עַל־יָדוֹ׃
\v 8 \vp ח\vp* וְלֹא הוּא הָיָה הָאוֹר כִּי אִם־בָּא לְהָעִיד עַל־הָאוֹר הַהוּא׃
\v 9 \vp ט\vp* הוּא אוֹר אֱמֶת אֲשֶׁר בָּא לָעוֹלָם לְהָאִיר לְכָל־אָדָם׃
\v 10 \vp י\vp* הוּא הָיָה בָעוֹלָם וְהָעוֹלָם נִהְיָה עַל־יָדוֹ וְהָעוֹלָם אֹתוֹ לֹא יָדָע׃
\v 11 \vp יא\vp* הוּא בָא אֶל־עַמּוֹ שֶׁלּוֹ וְעַמּוֹ שֶׁלּוֹ לֹא הֶחֱזִיקוּ־בוֹ׃
\v 12 \vp יב\vp* וְאֵלֶּה אֲשֶׁר הֶחֱזִיקוּ־בוֹ נָתַן־כֹּחַ בְּיָדָם לִהְיוֹת בָּנִים לֵאלֹהִים הֲלֹא הֵם הַמַּאֲמִינִים בִּשְׁמוֹ׃
\v 13 \vp יג\vp* אֲשֶׁר לֵדָתָם לֹא מִדָּם וְלֹא מִתַּאֲוַת בָּשָׂר וְלֹא מֵרוּחַ גָּבֶר כִּי אִם־מֵאֱלֹהִים׃
\v 14 \vp יד\vp* וְהַדָּבָר לָבַשׁ בָּשָׂר וַיִּשְׁכֹּן בְּתוֹכֵנוּ וְאֶת־כְּבוֹדוֹ רָאִינוּ כִּכְבוֹד בֵּן יָחִיד לְאָבִיו מָלֵא חֶסֶד וֶאֱמֶת׃
\v 15 \vp טו\vp* וְיוֹחָנָן הֵעִיד עָלָיו וַיִּקְרָא לֵאמֹר זֶה הוּא אֲשֶׁר אָמַרְתִּי עָלָיו כִּי הוּא בָא אַחֲרַי וְהִנֵּה הוּא לְפָנָי כִּי רִאשׁוֹן־לִי הָיָה׃
\v 16 \vp טז\vp* כִּי מִמְּלֹאוֹ נָשָׂאנוּ כֻלָּנוּ חֶסֶד עַל־חָסֶד׃
\v 17 \vp יז\vp* כִּי הַתּוֹרָה נְתוּנָה בְּיַד־מֹשֶׁה וְחֶסֶד וֶאֱמֶת מִמְּקוֹר יֵשׁוּעַ הַמָּשִׁיח יָצָאוּ׃
\v 18 \vp יח\vp* אֵת הָאֱלֹהִים לֹא־רָאָה אָדָם מֵעוֹלָם וְהַבֵּן הַיָּחִיד בְּחֵיק הָאָב הוּא הִגִּיד תְּכוּנָתוֹ׃
\v 19 \vp יט\vp* וְזֹאת עֵדוּת יוֹחָנָן בִּשְׁלֹחַ הַיְּהוּדִים כֹּהֲנִים וּלְוִיִּם מִירוּשָׁלַיִם לִשְׁאֹל אֹתוֹ מִי הוּא׃
\v 20 \vp כ\vp* וְהוּא הוֹדָה וְלֹא כִחֵד כִּי הִגִּיד לֵאמֹר אָנֹכִי אֵינֶנִּי הַמָּשִׁיחַ׃
\v 21 \vp כא\vp* וַיִּשְׁאֲלוּ אֹתוֹ מִי אֵפוֹא אָתָּה הַאַתָּה אֵלִיָּהוּ וַיֹּאמֶר אֵינֶנִּי אֵלִיָּהוּ הַאִם הַנָּבִיא אַתָּה וַיַּעַן לֹא׃
\v 22 \vp כב\vp* וַיֹּאמְרוּ אֵלָיו וּמִי אֵפוֹא אָתָּה כִּי עָלֵינוּ לְהָשִׁיב דָּבָר אֶת־שֹׁלְחֵינוּ מָה־תֹּאמַר עַל־נַפְשֶׁךָ׃
\v 23 \vp כג\vp* וַיֹּאמַר אָנֹכִי קוֹל קוֹרֵא בַּמִּדְבָּר פַּנּוּ דֶּרֶךְ יְהוָֹה כַּאֲשֶׁר דִּבֶּר יְשַׁעְיָהוּ הַנָּבִיא׃
\v 24 \vp כד\vp* וְהַשְּׁלוּחִים הָאֵלֶּה הָיוּ מִן־הַפְּרוּשִׁים׃
\v 25 \vp כה\vp* וַיִּשְׁאֲלוּ וַיֹּאמְרוּ אֵלָיו אִם־אֵינְךָ הַמָּשִׁיחַ וְלֹא אֵלִיָּהוּ וְלֹא הַנָּבִיא לָמָּה־זֶּה מְטַבֵּל הִנֶּךָ׃
\v 26 \vp כו\vp* וַיַּעַן אֹתָם יוֹחָנָן וַיֹּאמַר אָנֹכִי מְטַבֵּל בַּמָּיִם אַךְ אִישׁ עֹמֵד בְּתוֹכְכֶם אֲשֶׁר לֹא יְדַעְתֶּם אֹתוֹ׃
\v 27 \vp כז\vp* זֶה הַבָּא אַחֲרָי אֲשֶׁר הָיָה לְפָנָי וַאֲנִי קַלֹּתִי מֵהַתֶּר־לוֹ שְׂרוֹךְ נְעָלָיו׃
\v 28 \vp כח\vp* זֹאת הָיְתָה בְּבֵית הָעֲרָבָה מֵעֵבֶר לַיַּרְדֵּן אֲשֶׁר יוֹחָנָן הָיָה מְטַבֵּל שָׁמָּה׃
\v 29 \vp כט\vp* וַיְהִי מִמָּחֳרָת וַיַּרְא אֶת־יֵשׁוּעַ בָּא אֵלָיו וַיֹּאמַר הִנֵּה שֵׂה הָאֱלֹהִים הַנֹּשֵׂא אֶת־חַטַּאת הָעוֹלָם׃
\v 30 \vp ל\vp* וְהוּא אֲשֶׁר אָמַרְתִּי עָלָיו הִנֵּה אִישׁ בָּא אַחֲרַי וְהִנֵּה הוּא לְפָנָי כִּי רִאשׁוֹן־לִי הָיָה׃
\v 31 \vp לא\vp* וַאֲנִי לֹא יָדַעְתִּי אֹתוֹ אַךְ לְמַעַן יִגָּלֶה לְיִשְׂרָאֵל בָּאתִי אֲנִי לְטַבֵּל בַּמָּיִם׃
\v 32 \vp לב\vp* וַיָּעַד יוֹחָנָן לֵאמֹר רָאִיתִי אֶת־הָרוּחַ כְּיוֹנָה יֹרֶדֶת מִן־הַשָּׁמַיִם וַתָּנַח עָלָיו׃
\v 33 \vp לג\vp* וַאֲנִי לֹא יָדַעְתִּי אֹתוֹ אַךְ הַשֹּׁלֵחַ אֹתִי לְטַבֵּל בַּמַּיִם אָמַר אֵלָי אֶת־הַלָּז אֲשֶׁר תִּרְאֶה הָרוּחַ יֹרֶדֶת וְתָנוּחַ עָלָיו זֶה הוּא הַמְטַבֵּל בְּרוּחַ הַקֹּדֶשׁ׃
\v 34 \vp לד\vp* וַאֲנִי רָאִיתִי וָאָעִיד כִּי־זֶה הוּא בֶּן־הָאֱלֹהִים׃
\v 35 \vp לה\vp* וַיְהִי מִמָּחֳרָת וַיַּעֲמֹד יוֹחָנָן עוֹד עִם־שְׁנַיִם מִתַּלְמִידָיו׃
\v 36 \vp לו\vp* וַיַּרְא אֶת־יֵשׁוּעַ מִתְהַלֵּךְ וַיֹּאמַר הִנֵּה שֵׂה הָאֱלֹהִים׃
\v 37 \vp לז\vp* וַיִּשְׁמְעוּ שְׁנֵי תַלְמִידָיו אֶת־אֲשֶׁר דִּבֵּר וַיֵּלְכוּ אַחֲרֵי יֵשׁוּעַ׃
\v 38 \vp לח\vp* וַיִּפֶן יֵשׁוּעַ וַיִּרְאֵם הֹלְכִים אַחֲרָיו וַיֹּאמֶר אֲלֵיהֶם מַה־תְּבַקֵּשׁוּן וַיֹּאמְרוּ אֵלָיו רַבִּי אֲשֶׁר יֵאָמֵר מוֹרִי אַיֵּה מְקוֹם מוֹשָׁבֶךָ׃
\v 39 \vp לט\vp* וַיֹּאמֶר אֲלֵיהֶם בֹּאוּ וּרְאוּ וַיָּבֹאוּ וַיִּרְאוּ אֶת־מְקוֹם מוֹשָׁבוֹ וַיֵּשְׁבוּ אִתּוֹ בַּיּוֹם הַהוּא וְהָעֵת הָיְתָה כַּשָּׁעָה הָעֲשִׂירִית׃
\v 40 \vp מ\vp* וְאֶחָד מִן־הַשְּׁנַיִם אֲשֶׁר שָׁמְעוּ מֵאֵת יוֹחָנָן וְהָלְכוּ אַחֲרָיו הָיָה אַנְדְּרַי אֲחִי שִׁמְעוֹן פֶּטְרוֹס׃
\v 41 \vp מא\vp* הוּא מָצָא אֶת־אָחִיו אֶת־שִׁמְעוֹן וַיֹּאמֶר אֵלָיו מָצָאנוּ אֶת־הַמָּשִׁיחַ אֲשֶׁר בִּלְשׁוֹן יָוָן כְּרִיסְטוֹס׃
\v 42 \vp מב\vp* וַיְבִיאֵהוּ אֶל־יֵשׁוּעַ וַיִּרְאֵהוּ יֵשׁוּעַ וַיֹּאמַר אַתָּה שִׁמְעוֹן בַּר־יוֹנָה לְךָ יִקָּרֵא כֵיפָא וּבִלְשׁוֹן יָוָן פֶּטְרוֹס׃
\v 43 \vp מג\vp* וַיְהִי מִמָּחֳרָת וַיּוֹאֶל לָלֶכֶת הַגָּלִילָה וַיִּמְצָא אֶת־פִּילִפּוֹס וַיֹּאמֶר אֵלָיו יֵשׁוּעַ לֵךְ אַחֲרָי׃
\v 44 \vp מד\vp* וּפִילִפּוֹס הָיה מִבֵּית־צָיְדָה עִיר אַנְדְּרַי וּפֶטְרוֹס׃
\v 45 \vp מה\vp* וַיִּמְצָא פִּילִפּוֹס אֶת־נְתַנְאֵל וַיֹּאמֶר אֵלָיו מָצָאנוּ אֹתוֹ אֲשֶׁר כָּתַב עָלָיו מֹשֶׁה בַּתּוֹרָה וְהַנְּבִיאִים אֶת־יֵשׁוּעַ בֶּן־יוֹסֵף מִנְּצָרֶת׃
\v 46 \vp מו\vp* וַיֹּאמֶר אֵלָיו נְתַנְאֵל הֲכִי מִנְּצֶרֶת יָבֹא טוֹב וַיֹּאמֶר אֵלָיו פִּילִפּוֹס בֹּא וּרְאֵה׃
\v 47 \vp מז\vp* וַיַּרְא יֵשׁוּעַ אֶת־נְתַנְאֵל בָּא לִקְרָאתוֹ וַיֹּאמֶר עָלָיו אוּלָם זֶה הוּא יִשְׂרְאֵלִי אֲשֶׁר אֵין־בּוֹ רְמִיָּה׃
\v 48 \vp מח\vp* וַיֹּאמֶר אֵלָיו נְתַנְאֵל מֵאַיִן יָדַעְתָּ אֹתִי וַיַּעַן יֵשׁוּעַ וַיֹּאמֶר אֵלָיו טֶרֶם קָרָא לְךָ פִּילִפּוֹס בִּהְיוֹתְךָ תַּחַת הַתְּאֵנָה רְאִיתִיךָ׃
\v 49 \vp מט\vp* וַיַּעַן אֹתוֹ נְתַנְאֵל רַבִּי אַתָּה הוּא בֶּן־הָאֱלֹהִים אַתָּה הוּא מֶלֶךְ יִשְׂרָאֵל׃
\v 50 \vp נ\vp* וַיַּעַן יֵשׁוּעַ וַיֹּאמֶר אֵלָיו יַעַן אֲשֶׁר הֶאֱמַנְתָּ בִּי בַּעֲבוּר אָמְרִי לְךָ תַּחַת הַתְּאֵנָה רְאִיתִיךָ לָכֵן גְּדֹלוֹת מֵאֵלֶּה תִּרְאֶה׃
\v 51 \vp נא\vp* וַיֹּאמֶר אֵלָיו אָמֵן אָמֵן אֲנִי אֹמֵר לָכֶם כִּי תִרְאוּ אֶת־הַשָּׁמַיִם פְּתוּחִים וּמַלְאֲכֵי אֱלֹהִים עֹלִים וְיֹרְדִים עַל בֶּן־הָאָדָם׃
\c 2
\cp ב
\cl פרק ב
\p 
\v 1 \vp א\vp* וּבַיּוֹם הַשְּׁלִישִׁי הָיְתָה חֲתֻנָּה בְּקָנָה אֲשֶׁר לַגָּלִיל וְאֵם יֵשׁוּעַ הָיְתָה שָּׁמָּה׃
\v 2 \vp ב\vp* וְגַם־יֵשׁוּעַ וְתַלְמִידָיו הָיוּ מִן־קְרוּאֵי הַחֲתֻנָּה׃
\v 3 \vp ג\vp* וְאַחֲרֵי אֲשֶׁר תַּם הַיָּיִן אָמְרָה אֵם יֵשׁוּעַ אֵלָיו הִנֵּה אֵין לָהֶם יָיִן׃
\v 4 \vp ד\vp* וַיֹּאמֶר אֵלֶיהָ יֵשׁוּעַ מַה־לִּי וָלָךְ אִשָּׁה עוֹד לֹא־בָאָה עִתִּי׃
\v 5 \vp ה\vp* וַתֹּאמֶר אִמּוֹ אֶל־הַמְשָׁרְתִים אֶת־אֲשֶׁר יֹאמַר לָכֶם תַּעֲשׂוּ׃
\v 6 \vp ו\vp* וְשָׁם נִמְצְאוּ שֵׁשׁ כַּדֵּי־אֶבֶן עֲרֻכוֹת לְטַהֵר אֶת־אֲשֶׁר לֹא טָהוֹר בֵּין הַיְּהוּדִים כַּמִּשְׁפָּט שְׁתַּיִם אוֹ־שָׁלֹשׁ בַּתִּים תָּכִיל כָּל־כָּד׃
\v 7 \vp ז\vp* וַיֹּאמֶר אֲלֵיהֶם יֵשׁוּעַ מַלְאוּ אֶת־הַכַּדִּים מָיִם וַיְמַלְאוּן עַד־הַשָּׂפָה׃
\v 8 \vp ח\vp* וַיֹּאמֶר שַׁאֲבוּ־נָא עַתָּה וְהָבִיאוּ אֶל־פְּקִיד הַמִּשְׁתֶּה וַיָּבִיאוּ׃
\v 9 \vp ט\vp* וַיִּטְעַם פְּקִיד הַמִּשְׁתֶּה אֶת־הַמַּיִם אֲשֶׁר נֶהֶפְכוּ לְיַיִן מִבְּלִי דַעַת מֵאַיִן בָּא רַק הַמְשָׁרְתִים אֲשֶׁר־שָׁאֲבוּ אֶת־הַמַּיִם יָדָעוּ וַיִּקְרָא רַב בֵּית הַמִּשְׁתֶּה אֶל־הֶחָתָן׃
\v 10 \vp י\vp* וַיֹּאמֶר אֵלָיו כָּל־אִישׁ יָשִׂים יַיִן טוֹב רִאשׁוֹנָה וְאַחֲרֵי שָׁתוּ הַקְּרֻאִים לָרְוָיָה יָשִׂים יַיִן שְׁפַל־עֶרֶךְ לִפְנֵיהֶם וְאַתָּה צָפַנְתָּ אֶת־הַיַּיִן הַטּוֹב עַד־לָאַחֲרֹנָה׃
\v 11 \vp יא\vp* זֹאת רֵאשִׁית הָאֹתוֹת אֲשֶׁר עָשָׂה יֵשׁוּעַ בְּקָנָה אֲשֶׁר לַגָּלִיל וְשָׁם גִּלָּה כְבוֹדוֹ וַיַּאֲמִינוּ בוֹ תַּלְמִידָיו׃
\v 12 \vp יב\vp* וְאַחֲרֵי־כֵן יָרַד אֶל־כְּפַר נַחוּם הוּא וְאִמּוֹ וְאֶחָיו וְתַלְמִידָיו וַיֵּשְׁבוּ שָׁם יָמִים לֹא רַבִּים׃
\v 13 \vp יג\vp* וַיִּקְרַב חַג־הַפֶּסַח לַיְּהוּדִים וַיַּעַל יֵשׁוּעַ יְרוּשָׁלָיְמָה׃
\v 14 \vp יד\vp* וַיִּמְצָא אֲנָשִׁים ישְׁבִים בַּהֵיכָל מֹכְרִים בָּקָר וָצֹאן וְיוֹנִים וּמְחַלְּפֵי כָסֶף׃
\v 15 \vp טו\vp* וַיִּקַּח חֲבָלִים וְיְשָׂרֵג אֹתָם לְמַלְקָה בְּיָדוֹ וַיְגָרֶשׁ אֶת־כֻּלָּם אֶל־מִחוּץ לַהֵיכָל גַּם אֶת־הַצֹּאן גַּם אֶת־הַבָּקָר וַיַּשְׁלֵךְ אֶת־כֶּסֶף הַמְחַלְּפִים אַרְצָה וְאֶת־שֻׁלְחֲנֹתֵיהֶם הָפָךְ׃
\v 16 \vp טז\vp* וְאֶל־מֹכְרֵי הַיּוֹנִים אָמָר הוֹצִיאוּ אֶת־אֵלֶּה מִזֶּה וְלֹא תַעֲשׂוּ אֶת־בֵּית אָבִי לְבֵית מִקָּח וּמִמְכָּר׃
\v 17 \vp יז\vp* אָז זָכְרוּ תַלְמִידָיו אֵת אֲשֶׁר־כָּתוּב קִנְאַת בֵּיתְךָ אֲכָלָתְנִי׃
\v 18 \vp יח\vp* וַיַּעֲנוּ הַיְּהוּדִים וַיֹּאמְרוּ אֵלָיו מָה אוֹת הֶרְאֵיתָ לָּנוּ כִּי תַעֲשֶׂה כָּזֹאת׃
\v 19 \vp יט\vp* וַיַּעַן יֵשׁוּעַ וַיֹּאמֶר אֲלֵיהֶם הִרְסוּ אֶת־הַהֵיכָל הַזֶּה וַאֲנִי בִּשְׁלֹשֶׁת יָמִים אֲקִימֶנּוּ׃
\v 20 \vp כ\vp* וַיֹּאמְרוּ הַיְּהוּדִים אַרְבָּעִים שָׁנָה וְשֵׁשׁ שָׁנִים נִבְנָה הַהֵיכָל הַזֶּה וְאַתָּה תְקִימֶנּוּ בִּשְׁלֹשֶׁת יָמִים׃
\v 21 \vp כא\vp* וְהוּא דִבֶּר דְּבָרוֹ עַל־הֵיכַל גְּוִיָּתוֹ׃
\v 22 \vp כב\vp* עַל־כֵּן אַחֲרֵי תְקוּמָתוֹ מִן־הַמֵּתִים זָכְרוּ תַלְמִידָיו כִּי־כֹה אָמָר לָהֶם וַיַּאֲמִינוּ בַכָּתוּב וּבִדְבַר יֵשׁוּעַ אֲשֶׁר דִּבֵּר׃
\v 23 \vp כג\vp* וַיְהִי בִּהְיוֹתוֹ בִירוּשָׁלַיִם בְּחַג־הַפֶּסַח וַיַּאֲמִינוּ רַבִּים בִּשְׁמוֹ כִּי רָאוּ אֶת־הָאֹתוֹת אֲשֶׁר עָשָׂה לְעֵינֵיהֶם׃
\v 24 \vp כד\vp* וְיֵשׁוּעַ לֹא הֶאֱמִין לָהֶם יַעַן יָדַע אֶת־יֵצֶר כֻּלָּם׃
\v 25 \vp כה\vp* וּבְיַעַן לֹא בִקֵּשׁ עֵדוּת אִישׁ בְּאִישׁ כִּי אֶת־מַחְשְׁבוֹת אָדָם הוּא הָיָה מֵבִין׃
\c 3
\cp ג
\cl פרק ג
\p 
\v 1 \vp א\vp* וַיְהִי אִישׁ מִן־הַפְּרוּשִׁים וּשְׁמוֹ נַקְדִּימוֹן קְצִין הַיְּהוּדִים׃
\v 2 \vp ב\vp* הוּא בָא אֶל־יֵשׁוּעַ לַיְלָה וַיֹּאמֶר אֵלָיו רַבִּי יָדַעְנוּ כִּי מֵאֵת אֱלֹהִים בָּאתָ לְמוֹרֶה לָנוּ כִּי אֵין לְאֵל יַד־אִישׁ לַעֲשׂוֹת אֶת־הָאֹתוֹת אֲשֶׁר אַתָּה עֹשֶׂה בִּלְתִּי אִם־אֱלֹהִים עִמּוֹ׃
\v 3 \vp ג\vp* וַיַּעַן יֵשׁוּעַ וַיֹּאמֶר אֵלָיו אָמֵן אָמֵן אֲנִי אֹמֵר לָךְ אִם־לֹא יִוָּלֵד אִישׁ מִמְּקוֹר עָל לֹא־יוּכַל לִרְאוֹת אֶת־מַלְכוּת הָאֱלֹהִים׃
\v 4 \vp ד\vp* וַיֹּאמֶר אֵלָיו נַקְדִּימוֹן אֵיכָה יוּכַל אִישׁ לְהִוָּלֵד וְהוּא זָקֵן הֲכִי יוּכַל לָשׁוּב לְרֶחֶם אִמּוֹ וּלְהִוָּלֵד שֵׁנִית׃
\v 5 \vp ה\vp* וַיַּעַן יֵשׁוּעַ אָמֵן אָמֵן אֲנִי אֹמֵר לָךְ אִם־לֹא יִוָּלֵד אִישׁ מִן־הַמַּיִם וּמִן־הָרוּחַ לֹא־יוּכַל לָבֹא אֶל־מַלְכוּת הָאֱלֹהִים׃
\v 6 \vp ו\vp* הַנּוֹלָד מִן־הַבָּשָׂר בָּשָׂר הוּא וְהַנּוֹלָד מִן־הָרוּחַ רוּחַ הוּא׃
\v 7 \vp ז\vp* אַל־תִּתְמַהּ עַל־אֲשֶׁר אָמַרְתִּי לָךְ כִּי נָכוֹן לָכֶם לְהִוָּלֵד מִמְּקוֹר עָל׃
\v 8 \vp ח\vp* הָרוּחַ נֹשֶׁבֶת אֶל־אֲשֶׁר תַּחְפֹּץ וְאַתָּה שֹׁמֵעַ אֶת־קוֹלָהּ וְלֹא תֵדַע מֵאַיִן בָּאָה וְאָן הִיא הֹלֶכֶת כְּמוֹ כֵן כָּל־הַנּוֹלָד מִן־הָרוּחַ׃
\v 9 \vp ט\vp* וַיַּעַן נַקְדִּימוֹן וַיֹּאמֶר אֵלָיו אֵיכָה תִקְרֶינָה כָּאֵלֶּה׃
\v 10 \vp י\vp* וַיַּעַן יֵשׁוּעַ וַיֹּאמֶר אֵלָיו הִנְּךָ מוֹרֶה בְיִשְׂרָאֵל וְאֶת־אֵלֶּה לֹא יָדָעְתָּ׃
\v 11 \vp יא\vp* אָמֵן אָמֵן אֲנִי אֹמֵר לָךְ כִּי אֵת אֲשֶׁר־יָדַעְנוּ נְדַבֵּר וְאֵת אֲשֶׁר־רָאִינוּ נָעִיד וְאַתֶּם לֹא תִשְׁמְעוּ לְעֵדוּתֵנוּ׃
\v 12 \vp יב\vp* אִם בִּדְבָרִים שְׁפָלִים לֹא הֶאֱמַנְתֶּם לִי אֵיךְ תַּאֲמִינוּ לִי כִּי אַגִּיד רָאמוֹת׃
\v 13 \vp יג\vp* וְאִישׁ לֹא־עָלָה לַמָּרוֹם בִּלְתִּי הוּא אֲשֶׁר־יָרַד מִמָּרוֹם הֲלֹא הוּא בֶּן־הָאָדָם אֲשֶׁר בַּשָּׁמָיִם׃
\v 14 \vp יד\vp* וְכַאֲשֶׁר נִשָּׂא משֶׁה בַּמִּדְבָּר אֶת־הַנָּחָשׁ עַל־הַנֵּס כֵּן יִנָּשֵׂא בֶּן־הָאָדָם׃
\v 15 \vp טו\vp* לְמַעַן אֲשֶׁר לֹא יֹאבַד כָּל־הַמַּאֲמִין בּוֹ כִּי אִם יִמְצָא בוֹ חַיֵּי עוֹלָם׃
\v 16 \vp טז\vp* כִּי־כֵן אֹהֵב אֱלֹהִים אֶת־הָעוֹלָם עַד־אֲשֶׁר נָתַן בַּעֲדוֹ אֶת־בְּנוֹ אֶת־יְחִידוֹ וְכָל־הַמַּאֲמִין בּוֹ לֹא־יֹאבַד כִּי בוֹ יִמְצָא חַיֵּי עוֹלָם׃
\v 17 \vp יז\vp* כִּי לֹא־שָׁלַח אֱלֹהִים אֶת־בְּנוֹ אֶל־הָעוֹלָם לְהַרְשִׁיעוֹ בְּהִשָּׁפְטוֹ כִּי אִם־לְמַעַן יִוָּשַׁע בּוֹ הָעוֹלָם׃
\v 18 \vp יח\vp* הַמַּאֲמִין בּוֹ לֹא יֶאְשַׁם וַאֲשֶׁר לֹא־יַאֲמִין בּוֹ אַשְׁמָתוֹ עָלָיו מִנִּי אָז כִּי לֹא־הֶאֱמִין בְּשֵׁם הַבֵּן הַיָּחִיד לֵאלֹהִים׃
\v 19 \vp יט\vp* וְזֶה הוּא הַמִּשְׁפָּט כִּי הָאוֹר בָּא אֶל־הָעוֹלָם וּבְנֵי הָאָדָם אָהֲבוּ אֶת־הַחשֶׁךְ מִן־הָאוֹר כִּי רָעִים מַעֲשֵׂיהֶם׃
\v 20 \vp כ\vp* כִּי כָל־פֹּעֵל אָוֶן שׁנֵא הוּא אֶת־הָאוֹר וְלֹא יָבֹא אֶל־הָאוֹר לִבְלִי יִבָּחֲנוּ מַעֲשָׂיו׃
\v 21 \vp כא\vp* אֲבָל פֹּעֵל אֱמֶת יָבֹא אֶל־הָאוֹר לְמַעַן יִוָּדְעוּ מַעֲשָׂיו אֲשֶׁר עָשָׂה לִפְנֵי הָאֱלֹהִים׃
\v 22 \vp כב\vp* אַחַר הַדְּבָרִים הָאֵלֶּה הָלַךְ יֵשׁוּעַ וְתַלְמִידָיו אֶל־אֶרֶץ יְהוּדָה וַיֵּשֶׁב עִמָּהֶם וַיְטַבֵּל שָׁם׃
\v 23 \vp כג\vp* וְגַם־יוֹחָנָן הָיָה מְטַבֵּל בָּעֵת הַהִיא בְּעֵנוֹן בֹּאֲכָה שָׁלֵם כִּי מַיִם רַבִּים נִמְצְאוּ שָׁם וְהַבָּאִים נִטְבָּלוּ׃
\v 24 \vp כד\vp* כִּי עוֹד לֹא־נִתַּן יוֹחָנָן אֶל־בֵּית הַכֶּלֶא׃
\v 25 \vp כה\vp* וַיְהִי־רִיב בֵּין תַּלְמִידֵי יוֹחָנָן וּבֵין אַחַד הַיְּהוּדִים עַל־דְּבַר הַטָּהֳרָה׃
\v 26 \vp כו\vp* וַיָּבֹאוּ אֶל־יוֹחָנָן וַיֹּאמְרוּ אֵלָיו רַבֵּנוּ הָאִישׁ אֲשֶׁר הָיָה עִמְּךָ בְּעֵבֶר הַיַּרְדֵּן אֲשֶׁר הַעִידֹתָ לּוֹ הִנֵּה הוּא מְטַבֵּל וְכֻלָּם בָּאִים אֵלָיו׃
\v 27 \vp כז\vp* וַיַּעַן יוֹחָנָן וַיֹּאמַר לֹא־יוּכַל אִישׁ לָקַחַת דָּבָר אִם לֹא נִתַּן־לוֹ מִמָּרוֹם׃
\v 28 \vp כח\vp* אַתֶּם עֵדַי אֲשֶׁר הִגַּדְתִּי כִּי לֹא־אָנֹכִי הַמָּשִׁיחַ כִּי אִם־שָׁלוּחַ לְפָנָיו׃
\v 29 \vp כט\vp* מִי אֲשֶׁר־לוֹ הַכַּלָּה הוּא הֶחָתָן וְאֹהֵב הֶחָתָן בְּעָמְדוֹ וּכְשָׁמְעוֹ אֹתוֹ שׂוֹשׂ יָשִׂישׂ לְקוֹל הֶחָתָן עַל־כֵּן מָלְאָה שִׂמְחָתִי׃
\v 30 \vp ל\vp* הוּא יֵלֵךְ הָלוֹךְ וָרָב וַאֲנִי אֵלֵךְ הָלוֹךְ וְחָסוֹר׃
\v 31 \vp לא\vp* הַבָּא מִמָּרוֹם רָם הוּא מִכָּל וְהַבָּא מֵאֶרֶץ מֵעָפָר הוּא וְעַל־עָפָר יְדַבֵּר הַבָּא מִשָּׁמַיִם רָם הוּא עַל־כֹּל׃
\v 32 \vp לב\vp* וְכַאֲשֶׁר רָאָה וְשָׁמַע כֵּן יִתֵּן עֵדוּתוֹ וּלְעֵדוּתוֹ אֵין שֹׁמֵעַ׃
\v 33 \vp לג\vp* וְהַשֹּׁמֵעַ לְעֵדוּתוֹ יַחְתֹּם בְּחוֹתַם יָדוֹ כִּי הָאֱלֹהִים אֱמֶת׃
\v 34 \vp לד\vp* כִּי הוּא אֲשֶׁר שְׁלָחוֹ אֱלֹהִים דִּבְרֵי אֱלֹהִים הוּא מְדַבֵּר כִּי־לֹא בִמְשׂוּרה נָתַן אֶת־רוּחוֹ׃
\v 35 \vp לה\vp* הָאָב אֹהֵב אֶת־הַבֵּן וְאֶת־כָּל נָתַן בְּיָדוֹ׃
\v 36 \vp לו\vp* מִי אֲשֶׁר יַאֲמִין בַּבֵּן יֶשׁ־לוֹ חַיֵּי עוֹלָם וּמִי אֲשֶׁר לֹא יַאֲמִין בַּבֵּן לֹא יִרְאֶה חַיִּים כִּי אִם־חֲרוֹן אַף אֱלֹהִים עָלָיו יָחוּל׃
\c 4
\cp ד
\cl פרק ד
\p 
\v 1 \vp א\vp* וְכַאֲשֶׁר נוֹדַע לָאָדוֹן כִּי הַפְּרוּשִׁים שָׁמְעוּ לֵאמֹר יֵשׁוּעַ הֶעֱמִיד וְטִבֵּל תַּלְמִידִים רַבִּים מִיּוֹחָנָן׃
\v 2 \vp ב\vp* אַף כִּי־יֵשׁוּעַ לֹא טִבֵּל אֹתָם רַק תַּלְמִידָיו׃
\v 3 \vp ג\vp* וַיַּעֲזֹב אֶת־יְהוּדָה וַיָּשָׁב וַיִּסַּע הַגָּלִילָה׃
\v 4 \vp ד\vp* וְהָיָה נָכוֹן לוֹ לַעֲבֹר דֶּרֶךְ שֹׁמְרוֹן׃
\v 5 \vp ה\vp* וַיָּבֹא אֶל־עִיר בְּאֶרֶץ שֹׁמְרוֹן וּשְׁמָהּ סוּכַר מִמּוּל חֶלְקַת הַשָּׂדֶה אֲשֶׁר־נָתַן יַעֲקֹב לִבְנוֹ לְיוֹסֵף׃
\v 6 \vp ו\vp* וְשָׁם בְּאֵר יַעֲקֹב וְיֵשׁוּעַ עָיְפָה נַפְשׁוֹ בַדֶּרֶךְ וַיֵּשֶׁב־לוֹ עַל־הַבְּאֵר כְּשָׁעָה הַשִּׁשִּׁית׃
\v 7 \vp ז\vp* וְהִנֵּה אִשָּׁה שֹׁמְרֹנִית בָּאָה לִשְׁאָב־מָיִם וַיֹּאמֶר אֵלֶיהָ יֵשׁוּעַ תְּנִי־נָא לִי לִשְׁתּוֹת׃
\v 8 \vp ח\vp* כִּי תַלְמִידָיו הָלְכוּ הָעִירָה לִשְׁבֹּר לָהֶם אֹכֶל׃
\v 9 \vp ט\vp* וַתֹּאמֶר אֵלָיו הָאִשָּׁה הַשֹּׁמְרֹנִית הֲלֹא יְהוּדִי אַתָּה וְאֵיךְ תִּשְׁאַל מִמֶּנִּי לִשְׁתּוֹת וַאֲנִי אִשָּׁה שֹׁמְרֹנִית כִּי־אֵין דָּבָר לַיְּהוּדִים עִם־הַשֹּׁמְרֹנִים׃
\v 10 \vp י\vp* וַיַּעַן יֵשׁוּעַ וַיֹּאמֶר אֵלֶיהָ לוּ יָדַעַתְּ אֶת־מַתַּת אֱלֹהִים וּמִי הָאֹמֵר לָךְ תְּנִי לִי לִשְׁתּוֹת אָז שָׁאַלְתְּ אַתְּ מִמֶּנּוּ וְנָתַן לָךְ מַיִם חַיִּים׃
\v 11 \vp יא\vp* וַתֹּאמֶר אֵלָיו הָאִשָּׁה אֲדֹנִי הֵן אֵין־לְךָ בַּמֶּה לִשְׁאֹב וְהַבְּאֵר עֲמֻקָּה וּמֵאַיִן לְךָ אֵפוֹא מַיִם חַיִּים׃
\v 12 \vp יב\vp* הֲגָדוֹל אַתָּה מִיַעֲקֹב אָבִינוּ אֲשֶׁר נָתַן־לָנוּ הַבְּאֵר הַזֹּאת אֲשֶׁר מִמֶּנָּה שָׁתָה הוּא וּבָנָיו וּבְעִירוֹ׃
\v 13 \vp יג\vp* וַיַּעַן יֵשׁוּעַ וַיֹּאמֶר אֵלֶיהָ כָּל־הַשֹּׁתֶה מִן־הַמַּיִם הָאֵלֶּה יִצְמָא עוֹד׃
\v 14 \vp יד\vp* וְכָל־אֲשֶׁר יִשְׁתֶּה מִן־הַמַּיִם אֲשֶׁר אֲנִי נֹתֵן לוֹ לֹא יִצְמָא לְעוֹלָם כִּי הַמַּיִם אֲשֶׁר אֲנִי נֹתֵן יִהְיוּ בוֹ לִמְקוֹר מַיִם נֹבְעִים לְחַיֵּי עוֹלָם׃
\v 15 \vp טו\vp* וַתֹּאמֶר אֵלָיו הָאִשָּׁה תְּנָה־לִּי אֲדֹנִי אֶת־הַמַּיִם הָהֵם וְלֹא־אֶצְמָא עוֹד וְלֹא אָבֹא הֵנָּה לִשְׁאֹב׃
\v 16 \vp טז\vp* וַיֹּאמֶר אֵלֶיהָ יֵשׁוּעַ לְכִי קִרְאִי לְאִישֵׁךְ וּבֹאִי הֵנָּה׃
\v 17 \vp יז\vp* וַתַּעַן הָאִשָּׁה וַתֹּאמֶר אֵלָיו אֵין־לִי אִישׁ וַיֹּאמֶר אֵלֶיהָ יֵשׁוּעַ כֵּן דִּבַּרְתְּ כִּי אֵין־לָךְ אִישׁ׃
\v 18 \vp יח\vp* חֲמִשָּׁה בְעָלִים הָיוּ לָךְ וְהוּא אֲשֶׁר עִמֵּךְ כַּיּוֹם אֵינֶנּוּ בַעְלֵךְ וּבָזֹאת אֱמֶת דִּבַּרְתְּ׃
\v 19 \vp יט\vp* וַתֹּאמֶר אֵלָיו הָאִשָּׁה אֲדֹנִי רֹאָה אָנֹכִי כִּי נָבִיא אָתָּה׃
\v 20 \vp כ\vp* אֲבֹתֵינוּ הִשְׁתַּחֲווּ בָּהָר הַזֶּה וְאַתֶּם אֹמְרִים כִּי יְרוּשָׁלַיִם הַמָּקוֹם לְהִשְׁתַּחֲוֹת׃
\v 21 \vp כא\vp* וַיֹּאמֶר אֵלֶיהָ יֵשׁוּעַ הַאֲמִינִי לִי אִשָּׁה כִּי תָבֹא עֵת אֲשֶׁר לֹא־בָּהָר הַזֶּה וְלֹא בִירוּשָׁלַיִם תִּשְׁתַּחֲווּ לָאָב׃
\v 22 \vp כב\vp* אַתֶּם מִשְׁתַּחֲוִים אֶל־אֲשֶׁר לֹא תֵדְעוּן וַאֲנַחְנוּ מִשְׁתַּחֲוִים אֶל־אֲשֶׁר נֵדָע כִּי הַיְשׁוּעָה בָאָה מִמְּקוֹר הַיְּהוּדִים׃
\v 23 \vp כג\vp* אַךְ תָּבֹא עֵת וְגַם־הִיא בָאָה וְהַמִּשְׁתַּחֲוִים הַנֶּאֶמָנִים יִשְׁתַּחֲווּ לָאָב בָּרוּחַ וּבָאֶמֶת כִּי בְּמִשְׁתַּחֲוִים כָּאֵלֶה חָפֵץ הָאָב׃
\v 24 \vp כד\vp* הָאֱלֹהִים הוּא רוּחַ וְהַמִּשְׁתַּחֲוִים לוֹ עֲלֵיהֶם לְהִשְׁתַּחֲוֹת בְּרוּחַ וּבֶאֱמֶת׃
\v 25 \vp כה\vp* וַתֹּאמֶר אֵלָיו הָאִשָּׁה יָדַעְתִּי כִּי־יָבֹא מָשִׁיחַ עהַנִּקְרָא כְרִיסְטוֹסא וְכַאֲשֶׁר יָבֹא יַגִּיד לָנוּ אֶת־כֹּל׃
\v 26 \vp כו\vp* וַיֹּאמֶר אֵלֶיהָ יֵשׁוּעַ אֲנִי הוּא הַמְדַבֵּר אֵלָיִךְ׃
\v 27 \vp כז\vp* עוֹד דְּבָרוֹ בְּפִיו וְתַלְמִידָיו בָּאוּ וַיִּתְמְהוּ עַל־דַּבְּרוֹ עִם־אִשָּׁה אַךְ אִישׁ לֹא אָמַר מַה־תְּבַקֵּשׁ אוֹ לָמָּה תְדַּבֵּר אֵלֶיהָ׃
\v 28 \vp כח\vp* וְהָאִשָּׁה עָזְבָה אֶת־כַּדָּהּ וַתֵּלֶךְ הָעִירָה וַתֹּאמֶר אֶל־הָעָם׃
\v 29 \vp כט\vp* בֹּאוּ וּרְאוּ אִישׁ אֲשֶׁר הִגִּיד לִי כָּל־אֲשֶׁר עָשִׂיתִי הַאֵין זֶה הוּא הַמָּשִׁיחַ׃
\v 30 \vp ל\vp* וַיֵּצְאוּ מִן־הָעִיר לָבֹא אֵלָיו׃
\v 31 \vp לא\vp* וַיְהִי עַד־כֹּה וְעַד כֹּה וַיֹּאמְרוּ אֵלָיו תַּלְמִידָיו רַבִּי אֱכֹל׃
\v 32 \vp לב\vp* וַיֹּאמֶר אֲלֵיהֶם אֲנִי יֶשׁ־לִי לֶאֱכֹל אֹכֶל אֲשֶׁר לֹא יְדַעְתֶּם׃
\v 33 \vp לג\vp* וַיֹּאמְרוּ הַתַּלְמִידִים אִישׁ אֶל־רֵעֵהוּ הַאִם הֵבִיא לוֹ אִישׁ מַאֲכַל לְאָכְלָה׃
\v 34 \vp לד\vp* וַיֹּאמֶר אֲלֵיהֶם יֵשׁוּעַ מַאֲכָלִי הוּא עֲשׂוֹת רְצוֹן שֹׁלְחִי וּלְכַלּוֹת אֶת־פָּעֳלוֹ׃
\v 35 \vp לה\vp* הֵן אַתֶּם אֹמְרִים עוֹד אַרְבָּעָה חֳדָשִׁים טֶרֶם יָבֹא הַקָּצִיר וַאֲנִי אֹמֵר לָכֶם שְׂאוּ אֶת־עֵינֵיכֶם וּרְאוּ אֶל־הַשָּׂדוֹת אֲשֶׁר הִלְבִּינוּ לַקָּצִיר׃
\v 36 \vp לו\vp* הַקּוֹצֵר יִמְצָא שְׂכָרוֹ וּתְבוּאָה יֶאֱסֹף לְחַיֵּי עוֹלָם וְהַזֹּרֵעַ וְהַקּוֹצֵר יִשְׂמְחוּ יַחְדָּו׃
\v 37 \vp לז\vp* לְמַלֹּאת דְּבַר הַמֹּשֵׁל אֶחָד זֹרֵעַ וְאַחֵר קֹצֵר׃
\v 38 \vp לח\vp* אָנֹכִי שָׁלַחְתִּי אֶתְכֶם לִקְצֹר בְּמָקוֹם לֹא עֲמַלְתֶּם שָׁם אֲחֵרִים עָמְלוּ וְאַתֶּם בַּאתֶם עַל־עֲמָלָם׃
\v 39 \vp לט\vp* וְרַבִּים מִן־הַשֹּׁמְרֹנִים בָּעִיר הַהִיא הֶאֱמִינוּ בוֹ בַּעֲבוּר דְּבַר הָאִשָּׁה אֲשֶׁר הֵעִידָה לֵאמֹר הוּא הִגִּיד לִי אֶת־כָּל־אֲשֶׁר עָשִׂיתִי׃
\v 40 \vp מ\vp* וַיָּבֹאוּ אֵלָיו הַשֹּׁמְרֹנִים וַיִּקְרְאוּ לוֹ לָשֶׁבֶת אִתָּם וַיֵּשֶׁב שָׁם יוֹמָיִם׃
\v 41 \vp מא\vp* וְעוֹד רַבִּים מֵהֵמָּה הֶאֱמִינוּ בוֹ בַּעֲבוּר דִּבְרֵי פִיהוּ׃
\v 42 \vp מב\vp* וַיֹּאמְרוּ אֶל־הָאִשָּׁה עַתָּה אֲנַחְנוּ מַאֲמִינִים בּוֹ לֹא־בַעֲבוּר דְּבָרֵךְ כִּי גַּם־אֲנַחְנוּ שָׁמַעְנוּ וַנֵּדַע כִּי־אָמֵן זֶה הוּא הַמָּשִׁיחַ מוֹשִׁיעַ הָעוֹלָם׃
\v 43 \vp מג\vp* וַיְהִי אַחֲרֵי שְׁנַיִם יָמִים וַיִּסַּע לְמַסָּעָיו הַגָּלִילָה׃
\v 44 \vp מד\vp* אַף כִּי הִגִּיד יֵשׁוּעַ כִּי אֵין־כָּבוֹד לְנָבִיא בְּאֶרֶץ מוֹלַדְתּוֹ׃
\v 45 \vp מה\vp* וַיָּבֹא אֶל־הַגָּלִיל וַיַּחֲזִיקוּ־בוֹ הַגָּלִילִים כִּי רָאוּ אֵת כָּל־אֲשֶׁר עָשָׂה בִירוּשָׁלַיִם בִּימֵי הֶחָג כִּי גַּם־הֵם חָגְגוּ שָׁם אֶת־הַחַג הַהוּא׃
\v 46 \vp מו\vp* וַיָּבֹא יֵשׁוּעַ עוֹד הַפַּעַם אֶל־קָנָה בַּגָּלִיל אֲשֶׁר הָפַךְ שָׁם הַמַּיִם לְיָיִן וְאִישׁ הָיָה מֵעַבְדֵי הַמֶּלֶךְ וּבְנוֹ חֹלֶה בִּכְפַר־נַחוּם׃
\v 47 \vp מז\vp* וְכַאֲשֶׁר שָׁמַע כִּי־בָא יֵשׁוּעַ מִיהוּדָה לַגָּלִיל וַיֵּלֶךְ אֵלָיו וַיִּפְצַר־בּוֹ לָרֶדֶת אִתּוֹ וְלִרְפֹּא אֶת־בְּנוֹ אֲשֶׁר נָטָה לָמוּת׃
\v 48 \vp מח\vp* וַיֹּאמֶר אֵלָיו יֵשׁוּעַ אִם־לֹא תִרְאוּ אֹתוֹת וּמֹפְתִים לֹא תַאֲמִינוּ׃
\v 49 \vp מט\vp* וַיֹּאמֶר אֵלָיו הָאִישׁ רְדָה־נָּא אֲדֹנִי בְּטֶרֶם יָמוּת בְּנִי׃
\v 50 \vp נ\vp* וַיֹּאמֶר אֵלָיו יֵשׁוּעַ לֵךְ לְדַרְכְּךָ בִּנְךָ חָי וְהָאִישׁ הֶאֱמִין בַּדָּבָר אֲשֶׁר־דִּבֶּר יֵשׁוּעַ וַיֵּלַךְ׃
\v 51 \vp נא\vp* וַיְהִי בְּלֶכְתּוֹ וַיִּפְגְּעוּ־בוֹ עֲבָדָיו וַיַּגִּידוּ לוֹ לֵאמֹר בִּנְךָ חָי׃
\v 52 \vp נב\vp* וַיִּדְרֹשׁ מֵהֶם אֶת־הַשָּׁעָה אֲשֶׁר הֵחֵל לְהֵרָפֵא מֵחָלְיוֹ וַיֹּאמְרוּ אֵלָיו אֶתְמוֹל בַּשָּׁעָה הַשְּׁבִיעִית סָרָה מִמֶּנּוּ הַקַּדָּחַת׃
\v 53 \vp נג\vp* וַיֵּדַע אָבִיו כִּי הָיָה בַּשָּׁעָה הַהִיא אֲשֶׁר הִגִּיד־לוֹ יֵשׁוּעַ בִּנְךָ חָי וַיַּאֲמֵן הוּא וְכָל־בֵּיתוֹ׃
\v 54 \vp נד\vp* זֶה הוּא הָאוֹת הַשֵּׁנִי אֲשֶׁר עָשָׂה יֵשׁוּעַ בַּגָּלִיל בְּשׁוּבוֹ מִיהוּדָה׃
\c 5
\cp ה
\cl פרק ה
\p 
\v 1 \vp א\vp* וְאַחֲרֵי־כֵן בָּא מוֹעֵד חַג הַיְּהוּדִים וַיַּעַל יֵשׁוּעַ יְרוּשָׁלָיְמָה׃
\v 2 \vp ב\vp* וּבִירוּשָׁלַיִם בְּרֵכַת מַיִם עַל־יַד שַׁעַר הַצֹּאן אֲשֶׁר קָרְאוּ לָהּ בְּלָשׁוֹן עִבְרִית בֵּית־חַסְדָּא וְלָהּ חֲמִשָּׁה אֵלַמּוֹת׃
\v 3 \vp ג\vp* וְשָׁם שָׁכְבוּ רַבִּים חוֹלִים עִוְרִים פִּסְחִים וִיבֵשֵׁי־כֹחַ וְהֵם מְיַחֲלִים שָׁם עַד אֲשֶׁר־יִגּוֹעוּ הַמָּיִם׃
\v 4 \vp ד\vp* כִּי לְעַד מִן־הָעִתִּים יֵרֵד מַלְאָךְ אֶל־הַבְּרֵכָה וְהִרְתִּיחַ אֶת־הַמָּיִם וְהָיָה הָרִאשׁוֹן הַיֹּרֵד שָׁם אַחֲרֵי אֲשֶׁר רֻתְּחוּ הַמָּיִם וְרָפָא לוֹ מִכָּל־מַחֲלָה אֲשֶׁר דָּבְקָה־בּוֹ׃
\v 5 \vp ה\vp* וְאִישׁ הָיָה שָׁם אֲשֶׁר חָלָה אֶת־חָלְיוֹ שְׁמֹנֶה וּשְׁלֹשִׁים שָׁנָה׃
\v 6 \vp ו\vp* וַיַּרְא אֹתוֹ יֵשׁוּעַ שֹׁכֵב עַל־מִשְׁכָּבוֹ וַיֵּדַע כִּי שָׁכַב כֵּן יָמִים רַבִּים וַיֹּאמֶר אֵלָיו הֶחָפֵץ אַתָּה לְהֵרָפֵא׃
\v 7 \vp ז\vp* וַיַּעַן אֹתוֹ הַחוֹלֶה אֲדֹנִי אֵין לִי אִישׁ אֲשֶׁר יוֹרִידֵנִי אֶל־הַבְּרֵכָה לְעֵת רִגְשַׁת הַמַּיִם וַאֲנִי טֶרֶם אֵרֵד וְיָרַד אַחֵר לְפָנָי׃
\v 8 \vp ח\vp* וַיֹּאמֶר אֵלָיו יֵשׁוּעַ קוּם שָׂא אֶת־מִשְׁכָּבְךָ וְהִתְהַלֵּךְ׃
\v 9 \vp ט\vp* וּפִתְאֹם שָׁב הָאִישׁ לְאֵיתָנוֹ וַיִּשָּׂא אֶת־מִשְׁכָּבוֹ וַיֵּלַךְ׃
\v 10 \vp י\vp* וְהַיּוֹם הַהוּא הָיָה יוֹם הַשַּׁבָּת וַיֹּאמְרוּ הַיְּהוּדִים אֶל־הָאִישׁ הַנִּרְפָּא הֲלֹא שַׁבָּת הַיּוֹם וְאֵין לְךָ לָשֵׂאת אֶת־הַמִּשְׁכָּב׃
\v 11 \vp יא\vp* וַיַּעַן אֹתָם לֵאמֹר הָרֹפֵא אֹתִי הוּא אָמַר אֵלַי שָׂא אֶת־מִשְׁכָּבְךָ וְהִתְהַלֵּךְ׃
\v 12 \vp יב\vp* וַיִּשְׁאָלֻהוּ מִי הוּא הָאִישׁ אֲשֶׁר אָמַר אֵלֶיךָ שָׂא אֶת־מִשְׁכָּבְךָ וְהִתְהַלֵּךְ׃
\v 13 \vp יג\vp* וְהַנִּרְפָּא לֹא יָדַע מִי הוּא כִּי יֵשׁוּעַ הָלַךְ־לוֹ בְּהִתְאַסֵּף עַם־רָב בַּמָּקוֹם הַהוּא׃
\v 14 \vp יד\vp* אַחֲרֵי־כֵן מָצָא אֹתוֹ יֵשׁוּעַ בְּבֵית הַמִּקְדָּשׁ וַיֹּאמֶר אֵלָיו רְאֵה כִּי נִרְפֵּאתָ אַל־תּוֹסֶף לַחֲטֹא פֶּן־תְּאֻנֶּה אֵלֶיךָ רָעָה גְּדוֹלָה מִזֹּאת׃
\v 15 \vp טו\vp* וַיֵּלֶךְ הָאִישׁ וַיַּגֵּד לַיְּהוּדִים כִּי־יֵשׁוּעַ הוּא אֲשֶׁר רִפְּאוֹ׃
\v 16 \vp טז\vp* וְעַל־כֵּן רָדְפוּ הַיְּהוּדִים אֶת־יֵשׁוּעַ וַיְבַקְשׁוּ הֲמִיתוֹ עֵקֶב אֲשֶׁר עָשָׂה זֹאת בַּשַּׁבָּת׃
\v 17 \vp יז\vp* וַיַּעַן אֹתָם יֵשׁוּעַ אָבִי פֹּעֵל פְּעֻלָּתוֹ עַד־עָתָּה וְגַם־אֲנִי פֹּעֵל הִנֵּנִי׃
\v 18 \vp יח\vp* וּבַעֲבוּר זֹאת בִּקְשׁוּ הַיְּהוּדִים בְּחֵפֶץ יֶתֶר לְהָרְגוֹ כִּי לֹא רַק אֶת־יוֹם הַשַּׁבָּת חִלֵּל כִּי אִם גַּם־אָמַר עַל־אֱלֹהִים כִּי הוּא אָבִיו וְכִי הוּא דוֹמֶה לֵאלֹהִים׃
\v 19 \vp יט\vp* וַיַּעַן יֵשׁוּעַ וַיֹּאמֶר אֲלֵיהֶם אָמֵן אָמֵן אֲנִי אֹמֵר לָכֶם הַבֵּן לֹא־יוּכַל לַעֲשׂוֹת דָּבָר מִלִּבּוֹ בִּלְתִּי אֵת אֲשֶׁר־רֹאֶה מַה־פֹּעֵל הָאָב כִּי אֶת־אֲשֶׁר הוּא עֹשֶׂה עֹשֶׂה גַּם־הַבֵּן כָּמֹהוּ׃
\v 20 \vp כ\vp* כִּי הָאָב אֹהֵב אֶת־הַבֵּן וּמַרְאֶה אֹתוֹ אֶת־כֹּל אֲשֶׁר הוּא עֹשֶׂה וּגְדֹלוֹת מֵאֵלֶּה יַרְאֶנּוּ לִהְיוֹת לְפֶלֶא בְּעֵינֵיכֶם׃
\v 21 \vp כא\vp* כִּי כַּאֲשֶׁר הָאָב מַעֲלֶה וּמְחַיֶּה אֶת־הַמֵּתִים כֵּן יְחַיֶּה גַּם־הַבֵּן אֶת־אֲשֶׁר חָפֵץ בּוֹ׃
\v 22 \vp כב\vp* וְהָאָב לֹא־יִשְׁפֹּט אִישׁ אַךְ כָּל־מִשְׁפָּטוֹ נָתַן בְּיַד הַבֵּן׃
\v 23 \vp כג\vp* לְמַעַן יְכַבְּדוּ כֻלָּם אֶת־הַבֵּן כַּאֲשֶׁר יְכַבְּדוּ אֶת־הָאָב מִי אֲשֶׁר לֹא־יְכַבֵּד אֶת־הַבֵּן אֵינֶנּוּ מְכַבֵּד אֶת הָאָב אֲשֶׁר שְׁלָחוֹ׃
\v 24 \vp כד\vp* אָמֵן אָמֵן אֲנִי אֹמֵר לָכֶם הַמַּקְשִׁיב לִדְבָרַי וּמַאֲמִין בְּשֹׁלְחִי יֶשׁ־לוֹ חַיֵּי עוֹלָם וְלֹא יָבֹא לְהִשָּׁפֵט כִּי־עָבַר מִמָּוֶת לַחַיִּים׃
\v 25 \vp כה\vp* אָמֵן אָמֵן אֲנִי אֹמֵר לָכֶם כִּי־תָבֹא עֵת וְכִי גַם־בָּאָה וְהַמֵּתִים יִשְׁמְעוּ אֶת־קוֹל בֶּן־הָאֱלֹהִים וְהַשֹּׁמְעִים חָיֹה יִחְיוּ׃
\v 26 \vp כו\vp* כִּי כַּאֲשֶׁר חַיֵּי הָאָב מִמְּקוֹר עַצְמוֹ כֵּן נִתַּן לַבֵּן לִהְיוֹת־לוֹ חַיָּיו מִמְּקוֹר עַצְמוֹ׃
\v 27 \vp כז\vp* וְגַם־כֹּחַ נָתַן בְּיָדוֹ לַעֲשׂוֹת מִשְׁפָּט כִּי בֶן־הָאָדָם הוּא׃
\v 28 \vp כח\vp* עַל־זֹאת אַל־תִּתַּמְּהוּ תָמֹהַּ כִּי הִנֵּה יוֹם בָּא וְכָל־שֹׁכְנֵי קֶבֶר יִשְׁמְעוּ אֶת־קֹלוֹ וְיַעֲלוּ׃
\v 29 \vp כט\vp* הָעֹשִׂים טוֹב יַעַמְדוּ לַחַיִּים וְהָעֹשִׂים רָע יַעַמְדוּ לַמִּשְׁפָּט׃
\v 30 \vp ל\vp* לֹא אוּכַל לַעֲשׂוֹת דָּבָר מִלִּבִּי כַּאֲשֶׁר אֶשְׁמַע כֵּן אֶשְׁפֹּט וּמִשְׁפָּטִי מִשְׁפָּט־צֶדֶק כִּי לֹא רְצוֹנִי אֲנִי מְבַקֵּשׁ כִּי אִם־רְצוֹן הָאָב אֲשֶׁר שֹׁלְחִי׃
\v 31 \vp לא\vp* אִם־אֲנִי לְבַדִּי מֵעִיד עָלָי לֹא נֶאֶמְנָה עֵדוּתִי׃
\v 32 \vp לב\vp* אַךְ יֵשׁ עֵד אַחֵר לִי וְיָדַעְתִּי כִּי עֵדוּתוֹ אֲשֶׁר־הוּא מֵעִיד עָלַי נֶאֱמָנָה׃
\v 33 \vp לג\vp* אַתֶּם שְׁלַחְתֶּם אֶל־יוֹחָנָן וְהוּא הֵעִיד עֵדוּת אֱמֶת׃
\v 34 \vp לד\vp* וַאֲנִי לֹא מֵאָדָם אֶקַּח לִי עֵדוּת אַךְ הַדְּבָרִים הָאֵלֶּה דִּבַּרְתִּי לְמַעַן אַתֶּם תִּוָּשֵׁעוּן׃
\v 35 \vp לה\vp* הוּא הָיָה לַפִּיד בֹּעֵר וּמֵאִיר וּבְאוֹרוֹ הוֹאַלְתֶּם לְהִתְעַלֵּם עַד־אַרְגִּיעָה׃
\v 36 \vp לו\vp* וְלִי עֵדוּת גְּדוֹלָה מֵעֵדוּת יוֹחָנָן כִּי הַמַּעֲשִׂים אֲשֶׁר נָתַן־לִי אָבִי לְכַלּוֹתָם הַמַּעֲשִׂים הָאֵלֶּה אֲנִי עֹשֶׂה וְהֵם מְעִידִים עָלַי כִּי שְׁלָחַנִי הָאָב׃
\v 37 \vp לז\vp* וְהָאָב אֲשֶׁר שְׁלָחַנִי הוּא הֵעִיד עָלָי וְאַתֶּם אֶת־קֹלוֹ לֹא־שְׁמַעְתֶּם מֵעוֹלָם וְאֶת־תָּאֳרוֹ לֹא רְאִיתֶם׃
\v 38 \vp לח\vp* וְאֵין דְּבָרוֹ שֹׁכֵן בְּקִרְבְּכֶם כִּי אֹתוֹ אֲשֶׁר שָׁלַח לֹא תַאֲמִינוּ בוֹ׃
\v 39 \vp לט\vp* אַתֶּם דֹּרְשִׁים מֵעַל־כִּתְבֵי הַקֹּדֶשׁ כִּי בָּהֶם אַתֶּם אֹמְרִים חַיֵּי עוֹלָם לָכֶם וְהֵם הֵמָּה הַמְּעִידִים עָלָי׃
\v 40 \vp מ\vp* וְלֹא אֲבִיתֶם לָבֹא אֵלָי לִהְיוֹת לָכֶם חַיִּים׃
\v 41 \vp מא\vp* כָּבוֹד לֹא־אֶקַּח מִבְּנֵי אָדָם׃
\v 42 \vp מב\vp* וְאֶתְכֶם יָדַעְתִּי כִּי אֵין־אַהֲבַת אֱלֹהִים בְּקִרְבְּכֶם׃
\v 43 \vp מג\vp* אָנֹכִי הִנֵּה בָאתִי בְּשֵׁם אָבִי וְלֹא הֶחֱזַקְתֶּם בִּי וְאִם־יָבֹא אַחֵר בְּשֵׁם עַצְמוֹ בּוֹ תַּחֲזִיקוּן׃
\v 44 \vp מד\vp* אֵיךְ תּוּכְלוּ לְהַאֲמִין אַחֲרֵי אֲשֶׁר תִּרְדְּפוּ כָבוֹד אִישׁ מֵרֵעֵהוּ וְאֶת־הַכָּבוֹד הַבָּא מֵאֵת הָאֱלֹהִים הָאֶחָד לֹא תְבַקֵּשׁוּן׃
\v 45 \vp מה\vp* אַל־תְּחַשְּׁבוּ כִּי אֲנִי אָבִיא שִׂטְנָה עֲלֵיכֶם לִפְנֵי הָאָב יֵשׁ אֶחָד מֵבִיא שִׂטְנָה עֲלֵיכֶם משֶׁה אֲשֶׁר בְּטַחְתֶּם בּוֹ׃
\v 46 \vp מו\vp* כִּי לוּ הֶאֱמַנְתֶּם בְּמשֶׁה הֶאֱמַנְתֶּם גַּם־בִּי כִּי עָלַי הוּא כָתָב׃
\v 47 \vp מז\vp* אַךְ אִם־בִּכְתָבָיו לֹא תַאֲמִינוּ אֵיךְ תַּאֲמִינוּ בִּדְבָרָי׃
\c 6
\cp ו
\cl פרק ו
\p 
\v 1 \vp א\vp* וַיְהִי אַחֲרֵי־כֵן וַיַּעֲבֹר יֵשׁוּעַ אֶל־עֵבֶר יַם־הַגָּלִיל הוּא יַם טִיבַרְיָה׃
\v 2 \vp ב\vp* וַהֲמוֹן עַם־רָב הָלְכוּ אַחֲרָיו כִּי רָאוּ אֶת־הָאֹתוֹת אֲשֶׁר עָשָׂה לְחוֹלִים׃
\v 3 \vp ג\vp* וַיַּעַל יֵשׁוּעַ אֶל־הָהָר וַיֵּשֶׁב־שָׁם עִם־תַּלְמִידָיו׃
\v 4 \vp ד\vp* וּמוֹעֵד הַפֶּסַח חַג הַיְּהוּדִים קָרַב לָבוֹא׃
\v 5 \vp ה\vp* וַיִּשָּׂא יֵשׁוּעַ אֶת־עֵינָיו וַיַּרְא הֲמוֹן עַם־רָב בָּא אֵלָיו וַיֹּאמֶר אֶל־פִּילִפּוֹס מֵאַיִן נִשְׁבֹּר לָהֶם לֶחֶם לֶאֱכֹל׃
\v 6 \vp ו\vp* וְהוּא דִּבֶּר כָּזֹאת לְנַסּוֹתוֹ כִּי הוּא יָדַע אֶת־אֲשֶׁר יַעֲשֶׂה׃
\v 7 \vp ז\vp* וַיַּעַן אֹתוֹ פִּילִפּוֹס מָאתַיִם דִּינַר לֶחֶם לֹא־יִשְׂפֹּק לָהֶם לֶאֱכֹל מִמֶּנּוּ אִישׁ אִישׁ פַּת קְטַנָּה׃
\v 8 \vp ח\vp* וְאֶחָד מִתַּלְמִידָיו אַנְדְּרַי אֲחִי שִׁמְעוֹן פֶּטְרוֹס אָמַר אֵלָיו לֵאמֹר׃
\v 9 \vp ט\vp* יֶשְׁנוֹ פֹּה נַעַר אֶחָד וְלוֹ חֲמִשָּׁה לֶחֶם שְׂעֹרִים וְדָגִים שְׁנָיִם אַךְ מָה אֵלֶּה לְעַם־רָב כָּזֶה׃
\v 10 \vp י\vp* וַיֹּאמֶר יֵשׁוּעַ הוֹשִׁיבוּ אֶת־הָאֲנָשִׁים וַיֵּשְׁבוּ כַּחֲמֵשֶׁת אֲלָפִים אִישׁ לְמִסְפָּרָם בִּנְאוֹת דֶּשֶׁא אֲשֶׁר נִמְצָא שָׁם לְמַכְבִּיר׃
\v 11 \vp יא\vp* וַיִּקַּח יֵשׁוּעַ אֶת־כִּכְּרוֹת הַלֶּחֶם וַיְבָרֶךְ וַיְחַלֵּק לְתַלְמִידָיו וְהַתַּלְמִידִים לְכָל־הַיּשְׁבִים שָׁמָּה וְגַם מִן־הַדָּגִים נָתַן לָהֶם כְּאַוַּת נַפְשָׁם׃
\v 12 \vp יב\vp* וְאַחֲרֵי אֲשֶׁר שָׂבְעוּ אָמַר אֶל־תַּלְמִידָיו אִסְפוּ אֶת־הַפְּתוֹתִים הַנּוֹתָרִים לִבְלִי יֹאבַד מְאוּמָה׃
\v 13 \vp יג\vp* וַיַּאַסְפוּ וַיְמַלְאוּ שְׁנֵים־עָשָׂר סַלִּים פְּתוֹתִים אֲשֶׁר הוֹתִירוּ הָאֹכְלִים מִן־חֲמִשָּׁה לַחְמֵי הַשְּׂעֹרִים׃
\v 14 \vp יד\vp* וַיְהִי כִּרְאוֹת הָעָם אֶת־הָאוֹת הַזֶּה אֲשֶׁר עָשָׂה יֵשׁוּעַ וַיֹּאמְרוּ אָמְנָה זֶה הוּא הַנָּבִיא הַבָּא לְתֵבֵל אָרְצָה׃
\v 15 \vp טו\vp* וַיֵּדַע יֵשׁוּעַ כִּי־יָבֹאוּ וְתָפְשׂוּ־בוֹ לַעֲשׁתוֹ לְמֶלֶךְ עַל־כֵּן חָלַץ מֵהֶם עוֹד הַפַּעַם אֶל־הָהָר לְבַדּוֹ׃
\v 16 \vp טז\vp* וַיְהִי לְעֵת עֶרֶב וַיֵּלְכוּ תַלְמִידָיו אֶל־הַיָּם וַיֵּרְדוּ בָאֳנִיָּה וַיַּעַבְרוּ אֶל־עֵבֶר הַיָּם אֶל־כְּפַר נַחוּם׃
\v 17 \vp יז\vp* וְהִנֵּה חשֶׁךְ בָּא וְיֵשׁוּעַ עוֹד לֹא־בָא אֲלֵיהֶם׃
\v 18 \vp יח\vp* וַיְהִי סַעַר גָּדוֹל עֹבֵר וְהַיָּם הֹלֵךְ וְסֹעֵר׃
\v 19 \vp יט\vp* וַיַּחְתְּרוּ כְּמֶרְחַק עֶשְׂרִים וְחָמֵשׁ אוֹ שְׁלשִׁים מַעֲנוֹת וַיִּרְאוּ אֶת־יֵשׁוּעַ הוֹלֵךְ עַל־פְּנֵי הַיָּם הָלוֹךְ וְקָרֵב אֶל־הָאֳנִיָּה וַיִּירָאוּ׃
\v 20 \vp כ\vp* וַיֹּאמֶר אֲלֵיהֶם אֲנִי הוּא אַל־תִּירָאוּ׃
\v 21 \vp כא\vp* וַיּוֹאִילוּ לָקַחַת אֹתוֹ אֶל־הָאֳנִיָּה וְהִנֵּה פִּתְאֹם הִגִּיעָה הָאֳנִיָּה אֶל־הַיַּבָּשָׁה אֶל־מְחוֹז חֶפְצָם׃
\v 22 \vp כב\vp* וַיְהִי מִמָּחֳרָת וַיַּרְא הֲמוֹן הָעָם הָעֹמֵד מֵעֵבֶר לַיָּם כִּי מִבַּלְעֲדֵי הָאֳנִיָּה לֹא הָיְתָה שָּׁם אֳנִיָּה אַחֶרֶת כִּי אִם־אַחַת אֲשֶׁר יָרְדוּ־בַהּ תָּלְמִידָיו וְכִי לֹא־יָרַד יֵשׁוּעַ בָּהּ עִם־תַּלְמִידָיו כִּי אִם־תַּלְמִידָיו עָבְרוּ לְבַדָּם׃
\v 23 \vp כג\vp* רַק אֳנִיּוֹת אֲחֵרוֹת הִגִּיעוּ מִטִּיבַרְיָה מִקָּרוֹב לַמָּקוֹם אֲשֶׁר אָכְלוּ־שָׁם אֶת־הַלֶּחֶם כַּאֲשֶׁר בֵּרַךְ הָאָדוֹן׃
\v 24 \vp כד\vp* וְעַל־כֵּן בִּרְאוֹת הֲמוֹן הָעָם כִּי יֵשׁוּעַ אֵינֶנּוּ שָׁם וְאַף־לֹא תַלְמִידָיו וַיֵּרְדוּ גַם־הֵמָּה בָּאֳנִיּוֹת הָאֵלֶּה וַיָּבֹאוּ כְּפַר־נַחוּם לְבַקֵּשׁ אֶת־יֵשׁוּעַ׃
\v 25 \vp כה\vp* וַיִּמְצָאֻהוּ מֵעֵבֶר לַיָּם וַיֹּאמְרוּ אֵלָיו רַבֵּנוּ מָתַי בָּאתָ הֵנָּה׃
\v 26 \vp כו\vp* וַיַּעַן אֹתָם יֵשׁוּעַ לֵאמֹר אָמֵן אָמֵן אֲנִי אֹמֵר לָכֶם הֵן לֹא בִקַּשְׁתֶּם אֹתִי יַעַן אֲשֶׁר רְאִיתֶם אֶת־אֹתוֹתַי כִּי אִם־יַעַן מִכִּכְּרוֹת הַלֶּחֶם אֲכַלְתֶּם וּשְׂבַעְתֶּם׃
\v 27 \vp כז\vp* אַל־תַּעַמְלוּ בְּעַד אֹכֶל אֹבֵד כִּי אִם־בְּעַד לֶחֶם עֹמֵד לְחַיֵּי עוֹלָם אֲשֶׁר בֶּן־הָאָדָם יִתֵּן לָכֶם כִּי־עָלָיו חָתַם הָאֱלֹהִים הָאָב אֶת־חֹתָמוֹ׃
\v 28 \vp כח\vp* וַיֹּאמְרוּ אֵלָיו מַה־נַּעֲשֶׂה אֲשֶׁר נִפְעַל פְּעֻלּוֹת אֱלֹהִים׃
\v 29 \vp כט\vp* וַיַּעַן יֵשׁוּעַ וַיֹּאמֶר אֲלֵיהֶם זֹאת פְּעֻלַּת אֱלֹהִים כִּי־תַאֲמִינוּ בָאִישׁ אֲשֶׁר שְׁלָחוֹ אֲלֵיכֶם׃
\v 30 \vp ל\vp* וַיֹּאמְרוּ אֵלָיו וּמֶה־הָאוֹת אֲשֶׁר תַּעֲשֶׂה כִּי נִרְאֶה וְנַאֲמִין בָּךְ מַה־תִּפְעָל׃
\v 31 \vp לא\vp* אֲבוֹתֵינוּ אָכְלוּ אֶת־הַמָּן בַּמִּדְבָּר כַּכָּתוּב לֶחֶם שָׁמַיִם נָתַן־לָמוֹ לֶאֱכֹל׃
\v 32 \vp לב\vp* וַיֹּאמֶר אֲלֵיהֶם יֵשׁוּעַ אָמֵן אָמֵן אֲנִי אֹמֵר לָכֶם משֶׁה לֹא נָתַן לָכֶם לֶחֶם שָׁמָיִם כִּי אִם־אָבִי נֹתֵן לָכֶם לֶחֶם אֱמֶת מִן־הַשָּׁמָיִם׃
\v 33 \vp לג\vp* כִּי־לֶחֶם אֱלֹהִים הוּא הַיֹּרֵד מִן־הַשָּׁמָיִם וְהַנּוֹתֵן חַיִּים לָעוֹלָם׃
\v 34 \vp לד\vp* וַיֹּאמְרוּ אֵלָיו אֲדֹנֵינוּ תְּנָה־לָּנוּ אֶת־הַלֶּחֶם הַזֶּה תָּמִיד׃
\v 35 \vp לה\vp* וַיֹּאמֶר אֲלֵיהֶם יֵשׁוּעַ אָנֹכִי הוּא לֶחֶם הַחַיִּים כָּל־הַבָּא אֵלַי לֹא יִרְעָב וְכָל־הַמַּאֲמִין בִּי לֹא יִצְמָא עוֹד לְעוֹלָם׃
\v 36 \vp לו\vp* וָאֹמַר אֲלֵיכֶם אֲשֶׁר רְאִיתֶם אֹתִי וְלֹא הֶאֱמַנְתֶּם בִּי׃
\v 37 \vp לז\vp* כָּל־אִישׁ אֲשֶׁר אֹתוֹ יִתֶּן־לִי הָאָב יָבֹא אֵלָי וְהַבָּא אֵלַי לֹא אֲגָרְשֶׁנּוּ מִפָּנָי׃
\v 38 \vp לח\vp* כִּי יָרַדְתִּי מִן־הַשָּׁמַיִם לֹא לַעֲשׂוֹת רְצוֹנִי כִּי אִם־רְצוֹן הָאָב אֲשֶׁר שֹׁלְחִי׃
\v 39 \vp לט\vp* וְזֶה רְצוֹן הָאָב אֲשֶׁר שֹׁלְחִי כִּי אֶת־אֲשֶׁר נָתַן לִי לֹא־יֹאבַד לִי אַף אֶחָד כִּי אֲקִימֶנּוּ בַּיּוֹם הָאַחֲרוֹן׃
\v 40 \vp מ\vp* כִּי זֶה רְצוֹן אָבִי מִי אֲשֶׁר רֹאֶה אֶת־הַבֵּן וּמַאֲמִין בּוֹ יִהְיוּ־לוֹ חַיֵּי עוֹלָם וַאֲנִי אֲקִימֶנּוּ בַּיּוֹם הָאַחֲרוֹן׃
\v 41 \vp מא\vp* וַיִּלֹּנוּ עָלָיו הַיְּהוּדִים עַל כִּי־אָמַר אָנֹכִי הוּא לֶחֶם הַיֹּרֵד מִן־הַשָּׁמָיִם׃
\v 42 \vp מב\vp* וַיֹּאמְרוּ הֲלֹא זֶה הוּא יֵשׁוּעַ בֶּן־יוֹסֵף אֲשֶׁר יָדַעְנוּ אֶת־אָבִיו וְאֶת־אִמּוֹ וְאֵיךְ יֹאמַר הוּא מִן־הַשָּׁמַיִם יָרָדְתִּי׃
\v 43 \vp מג\vp* וַיַּעַן יֵשׁוּעַ וַיֹּאמֶר אֲלֵיהֶם אַל־נָא תְהִי תְלוּנָה בֵּינֵיכֶם׃
\v 44 \vp מד\vp* לֹא־יוּכַל אִישׁ לָבֹא אֵלַי בִּלְתִּי אִם־יִמְשְׁכֵהוּ הָאָב אֲשֶׁר שְׁלָחָנִי וַאֲנִי אֲקִימֶנּוּ בַּיּוֹם הָאַחֲרוֹן׃
\v 45 \vp מה\vp* הֲלֹא כָתוּב בַנְּבִיאִים וְכָל־בָּנַיִךְ לִמּוּדֵי יְהוָֹה כָּל־הַשֹּׁמֵעַ מִן־הָאָב וְלֹמֵד מִמֶּנּוּ יָבֹא אֵלָי׃
\v 46 \vp מו\vp* וְלֹא כִּי־רָאָה אָדָם אֶת־הָאָב כִּי רַק זֶה אֲשֶׁר מֵאֵת יְהוָֹה הוּא רָאָה אֶת־הָאָב׃
\v 47 \vp מז\vp* אָמֵן אָמֵן אֲנִי אֹמֵר לָכֶם כָּל־הַמַּאֲמִין בִּי יֶשׁ־לוֹ חַיֵּי עוֹלָם׃
\v 48 \vp מח\vp* אֲנִי הוּא לֶחֶם הַחַיִּים׃
\v 49 \vp מט\vp* אֲבוֹתֵיכֶם אָכְלוּ אֶת־הַמָּן בַּמִּדְבָּר וַיָּמֻתוּ׃
\v 50 \vp נ\vp* וְזֶה הוּא הַלֶּחֶם הַיֹּרֵד מִן־הַשָּׁמָיִם לְבַעֲבוּר יֹאכַל־אָדָם מִמֶּנּוּ וְלֹא יָמוּת׃
\v 51 \vp נא\vp* אָנֹכִי לֶחֶם חַיִּים הַיֹּרֵד מִן־הַשָּׁמַיִם אָדָם כִּי־יֹאכַל מִלֶּחֶם הַזֶּה וָחַי לְעוֹלָם וְהַלֶּחֶם אֲשֶׁר אֲנִי נֹתֵן בְּשָׂרִי הוּא אֲשֶׁר אֶתְּנֶנּוּ בְּעַד חַיֵּי הָעוֹלָם׃
\v 52 \vp נב\vp* וַיֵּרָגְנוּ הַיְּהוּדִים בֵּינֵיהֶם לֵאמֹר אֵיכָה יוּכַל זֶה לָתֶת־לָנוּ אֶת־בְּשָׂרוֹ לֶאֱכֹל׃
\v 53 \vp נג\vp* וַיֹּאמֶר אֲלֵיהֶם יֵשׁוּעַ אָמֵן אָמֵן אֲנִי אֹמֵר לָכֶם אִם־לֹא תֹאכְלוּ מִבְּשַׂר בֶּן־הָאָדָם וּמִדָּמוֹ לֹא תִשְׁתּוּ לֹא יִהְיוּ לָכֶם חַיִּים בְּעַצְמוֹתֵיכֶם׃
\v 54 \vp נד\vp* הָאֹכֵל מִבְּשָׂרִי וְהַשֹּׁתֶה מִדָּמִי יֶשׁ־לוֹ חַיֵּי עוֹלָם וַאֲנִי אֲקִימֶנּוּ בַּיּוֹם הָאַחֲרוֹן׃
\v 55 \vp נה\vp* כִּי בְשָׂרִי הוּא אֹכֶל אֱמֶת וְדָמִי שִׁקּוּי אֱמֶת׃
\v 56 \vp נו\vp* הָאֹכֵל אֶת־בְּשָׂרִי וְהַשֹּׁתֶה אֶת־דָּמִי הוּא יִשְׁכָּן־בִּי וַאֲנִי בוֹ׃
\v 57 \vp נז\vp* כִּי כְּמוֹ הָאָב הַחַי שְׁלָחַנִי וְאָנֹכִי חַי בִּגְלָלוֹ כֵּן הָאֹכֵל אֹתִי גַּם־הוּא יִחְיֶה בִּגְלָלִי׃
\v 58 \vp נח\vp* זֶה הוּא הַלֶּחֶם הַיֹּרֵד מִן־הַשָּׁמָיִם לֹא כַמָּן אֲשֶׁר אָכְלוּ אֲבוֹתֵיכֶם וָמֵתוּ הָאֹכֵל מִן־הַלֶּחֶם הַזֶּה יִחְיֶה לְעוֹלָם׃
\v 59 \vp נט\vp* כַּדְּבָרִים הָאֵלֶּה דִּבֶּר בְּלַמְּדוֹ בְּבֵית הַכְּנֵסֶת בִּכְפַר־נַחוּם׃
\v 60 \vp ס\vp* וְרַבִּים מִתַּלְמִידָיו שָׁמְעוּ וַיֹּאמְרוּ קָשֶׁה הַדָּבָר הַזֶּה מִי יוּכַל לְשָׁמְעוֹ׃
\v 61 \vp סא\vp* וְיֵשׁוּעַ יָדַע בְּנַפְשׁוֹ כִּי תַלְמִידָיו מַלִּינִים עַל־זֶה וַיֹּאמֶר אֲלֵיהֶם הֲזֶה הָיָה לָכֶם לְמוֹקֵשׁ׃
\v 62 \vp סב\vp* וּמַה־יִּהְיֶה כִּי־תִרְאוּ אֶת־בֶּן־הָאָדָם עֹלֶה אֶל־אֲשֶׁר הָיָה־שָׁם לְפָנִים׃
\v 63 \vp סג\vp* הָרוּחַ הוּא הַמְחַיֶּה וְהַבָּשָׂר לֹא־יִצְלַח לַכֹּל הַדְּבָרִים אֲשֶׁר דִּבַּרְתִּי אֲלֵיכֶם רוּחַ הֵם וְחַיִּים׃
\v 64 \vp סד\vp* אַךְ־יֵשׁ אֲנָשִׁים בָּכֶם אֲשֶׁר אֵין אֵמֻן בָּם כִי יֵשׁוּעַ יָדַע מֵרֹאשׁ מִי אֵלֶּה אֲשֶׁר לֹא יַאֲמִינוּ וּמִי הוּא אֲשֶׁר יַסְגִּירֵהוּ׃
\v 65 \vp סה\vp* וַיֹּאמַר בַּעֲבוּר זֶה הִגַּדְתִּי לָכֶם כִּי לֹא־יוּכַל אִישׁ לָבֹא אֵלַי בִּלְתִּי אִם־נָתוּן־לוֹ מֵאֵת הָאָב׃
\v 66 \vp סו\vp* וּבַעֲבוּר הַדָּבָר הַזֶּה שָׁבוּ אָחוֹר רַבִּים מִתַּלְמִידָיו וְלֹא הָלְכוּ עוֹד עִמּוֹ׃
\v 67 \vp סז\vp* וַיֹּאמֶר יֵשׁוּעַ אֶל־שְׁנֵים הֶעָשָׂר הֲיֵשׁ אֶת־לִבְּכֶם לָשׁוּב מֵאַחֲרַי גַּם־אַתֶּם׃
\v 68 \vp סח\vp* וַיַּעַן אֹתוֹ שִׁמְעוֹן פֶּטְרוֹס אֲדֹנִי אֶל־מִי נֵלֵךְ וְדִבְרֵי חַיֵּי עוֹלָם עִמָּךְ׃
\v 69 \vp סט\vp* וַאֲנַחְנוּ הֶאֱמַנּוּ וְגַם־יָדָעְנוּ כִּי אַתָּה הוּא הַמָּשִׁיחַ בֶּן־אֵל חָי׃
\v 70 \vp ע\vp* וַיַּעַן אֹתָם יֵשׁוּעַ הֲלֹא שְׁנֵים עָשָׂר בָּחַרְתִּי בָכֶם וְאֶחָד מִכֶּם שָׂטָן הוּא׃
\v 71 \vp עא\vp* וְזֹאת דִּבֶּר עַל־יְהוּדָה בֶּן־שִׁמְעוֹן אִישׁ־קְרִיּוֹת כִּי זֶה נָכוֹן הָיָה לְהַסְגִּירוֹ וְהוּא אֶחָד מִשְּׁנֵים הֶעָשָׂר׃
\c 7
\cp ז
\cl פרק ז
\p 
\v 1 \vp א\vp* אַחֲרֵי־כֵן נָסַע יֵשׁוּעַ הֵנָּה וָהֵנָּה בַּגָּלִיל כִּי לֹא אָבָה לִנְסֹעַ בִּיהוּדָה אַחֲרֵי־אֲשֶׁר בִּקְשׁוּ הַיְּהוּדִים לְהָרְגוֹ׃
\v 2 \vp ב\vp* וַיִּקְרַב חַג הַיְּהוּדִים חַג הַסֻּכּוֹת׃
\v 3 \vp ג\vp* וַיֹּאמְרוּ אֵלָיו אֶחָיו עֲלֵה מִזֶּה וְלֶךְ־לְךָ אֶל־אֶרֶץ יְהוּדָה לְמַעַן יִרְאוּ תַלְמִידֶיךָ גַּם־שָׁם אֶת־הָעֲלִילֹת אֲשֶׁר־אַתָּה עֹשֶׂה׃
\v 4 \vp ד\vp* כִּי אֵין־אִישׁ עֹשֶׂה דָבָר בַּסֵּתֶר וּמְבַקֵּשׁ הוּא לְהִוָּדַע נֶגֶד הַשָּׁמֶשׁ וְאִם כֵּן אַתָּה עֹשֶׂה קוּם הִוָּדַע בָּאָרֶץ׃
\v 5 \vp ה\vp* כִּי־אֶחָיו גַּם־הֵם לֹא הֶאֱמִינוּ בוֹ׃
\v 6 \vp ו\vp* וַיֹּאמֶר אֲלֵיהֶם יֵשׁוּעַ עוֹד לֹא־בָאָה עִתִּי עַד־הֵנָּה וְעִתְּכֶם הִיא אִתְכֵם תָּמִיד׃
\v 7 \vp ז\vp* הָעוֹלָם לֹא־תוּכַל לִשְׂנֹא אֶתְכֶם וְאֹתִי תִשְׂנָא עֵקֶב עֵדוּתִי בָהּ כִּי רָעִים מַעֲשֶׂיהָ׃
\v 8 \vp ח\vp* עֲלוּ אַתֶּם לְעֵת הֶחָג וַאֲנִי לֹא אֶעֱלֶה לְעֵת הֶחָג עַתָּה כִּי לֹא מָלְאָה עִתִּי עַד־כֹּה׃
\v 9 \vp ט\vp* כַּדְּבָרִים הָאֵלֶּה דִבֵּר וַיִּתְמַהְמַהּ בַּגָּלִיל׃
\v 10 \vp י\vp* וְאַחֲרֵי אֲשֶׁר עָלוּ אֶחָיו לְעֵת הֶחָג עָלָה גַּם־הוּא לֹא בַגָּלוּי כִּי אִם־כְּמִסְתַּתֵּר׃
\v 11 \vp יא\vp* וַיְבַקְשׁוּ אֹתוֹ הַיְּהוּדִים בֶּחָג וַיֹּאמְרוּ אַיֵּה אֵיפֹא הוּא׃
\v 12 \vp יב\vp* וַיְהִי הָעָם נָדוֹן הַרְבֵּה אֵלֶּה אֹמְרִים כִּי־טוֹב הוּא וְאֵלֶּה אֹמְרִים לֹא כִּי־מַתְעֶה הוּא אֶת־הָעָם׃
\v 13 \vp יג\vp* אֶפֶס אֵין־אִישׁ מְדַבֵּר עָלָיו בַּגָּלוּי מִפְּנֵי יִרְאַת הַיְּהוּדִים׃
\v 14 \vp יד\vp* וַיְהִי בְּתוֹךְ יְמֵי הֶחָג וַיַּעַל יֵשׁוּעַ וַיְלַמֵּד בְּבֵית הַמִּקְדָּשׁ׃
\v 15 \vp טו\vp* וְהַיְּהוּדִים תָּמְהוּ לֵאמֹר מֵאַיִן יֹדֵעַ זֶה סֵפֶר וְהוּא לֹא לֻמָּד׃
\v 16 \vp טז\vp* וַיַּעַן אֹתָם יֵשׁוּעַ וַיֹּאמַר לֹא תוֹרָתִי שֶׁלִּי אֲנִי מוֹרֶה כִּי אִם־תּוֹרַת שֹׁלְחִי׃
\v 17 \vp יז\vp* מִי הָאִישׁ הֶחָפֵץ לַעֲשׂוֹת רְצוֹנוֹ הוּא יֵדַע תּוֹרָתִי אִם־מֵאֵת אֱלֹהִים הִיא אוֹ מִלִּבִּי אֲנִי מוֹרֶה׃
\v 18 \vp יח\vp* הַמּוֹרֶה מִלִּבּוֹ אֶת־כְּבוֹדוֹ הוּא מְבַקֵּשׁ וְהַמְבַקֵּשׁ כְּבוֹד שֹׁלְחוֹ נֶאֱמָן הוּא וְלֹא עַוְלָתָה בּוֹ׃
\v 19 \vp יט\vp* הֲלֹא משֶׁה נָתַן לָכֶם אֶת־הַתּוֹרָה וְאֵין־אִישׁ מִכֶּם שֹׁמֵר אֶת־הַתּוֹרָה מַדּוּעַ תְּבַקְשׁוּ לְהָרְגֵנִי׃
\v 20 \vp כ\vp* וַיַּעַן הָעָם וַיֹּאמַר רוּחַ רָעָה בָּךְ מִי אֵיפֹא מְבַקֵּשׁ לְהָרְגֶךָ׃
\v 21 \vp כא\vp* וַיַּעַן יֵשׁוּעַ וַיֹּאמֶר אֲלֵיהֶם פְּעֻלָּה אַחַת פָּעַלְתִּי וְכֻלְּכֶם תִּתַּמָּהוּ׃
\v 22 \vp כב\vp* הֵן משֶׁה נָתַן לָכֶם אֶת־הַמּוּלֹת אַף כִּי־לֹא מִמּשֶׁה הִיא כִּי אִם מִן־הָאָבוֹת וְעַל־כֵּן בַּשַּׁבָּת תָּמוּלוּ בֶּן־זָכָר׃
\v 23 \vp כג\vp* וְעַתָּה אִם־בַּשַּׁבָּת הִמּוֹל יִמּוֹל בֶּן־זָכָר לְבַעֲבוּר לֹא תוּפַר תּוֹרַת משֶׁה לָמָּה־זֶּה תִּתְעַבְּרוּ־בִי עַל כִּי־רִפֵּאתִי אִישׁ כֻּלּוֹ בַּשַּׁבָּת׃
\v 24 \vp כד\vp* אַל־תִּשְׁפְּטוּ לָעֵינָיִם כִּי אִם־מִשְׁפַּט־צֶדֶק שְׁפֹטוּ׃
\v 25 \vp כה\vp* וַיֹּאמְרוּ אֲחָדִים מִיּשְׁבֵי יְרוּשָׁלָיִם הֲלֹא זֶה הוּא אֲשֶׁר הֵם מְבַקְשִׁים לַהֲמִיתוֹ׃
\v 26 \vp כו\vp* וְהִנֵּה הוּא מְדַבֵּר בָּרַבִּים וְהֵם אֵינָם אֹמְרִים לוֹ דָבָר הַאַף אֻמְנָם הִכִּירוּ שָׂרֵינוּ כִּי־בֶּאֱמֶת הוּא הַמָּשִׁיחַ׃
\v 27 \vp כז\vp* אַךְ אֶת־הָאִישׁ הַזֶּה יָדַעְנוּ מֵאַיִן הוּא אֲבָל הַמָּשִׁיחַ בְּבֹאוֹ לֹא־יֵדַע אָדָם מֵאַיִן בָּא׃
\v 28 \vp כח\vp* אָז יְלַמֵּד יֵשׁוּעַ בַּמִּקְדָּשׁ וַיִּקְרָא לֵאמֹר אָכֵן יְדַעְתֶּם אֹתִי גַּם־יְדַעְתֶּם מֵאַיִן אָנֹכִי אַךְ מִלִּבִּי לֹא־בָאתִי כִּי יֵשׁ נֶאֱמָן אֲשֶׁר שְׁלָחַנִי וְאַתֶּם לֹא יְדַעְתֶּם אֹתוֹ׃
\v 29 \vp כט\vp* וַאֲנִי יָדַעְתִּי אֹתוֹ כִּי מֵאִתּוֹ אָנֹכִי וְהוּא שְׁלָחָנִי׃
\v 30 \vp ל\vp* וַיְבַקְשׁוּ לְתָפְשׂוֹ וְאִישׁ לֹא־שָׁלַח בּוֹ יָד כִּי עוֹד לֹא־בָאָה עִתּוֹ׃
\v 31 \vp לא\vp* וְרַבִּים מִן־הָעָם הֶאֱמִינוּ־בוֹ וַיֹּאמְרוּ הֲכִי הַמָּשִׁיחַ בְּבֹאוֹ יַעֲשֶׂה אֹתוֹת רַבִּים מֵאֲשֶׁר הוּא עֹשֶׂה׃
\v 32 \vp לב\vp* וַיִּשְׁמְעוּ הַפְּרוּשִׁים כִּי הָעָם מִתְלַחֲשִׁים כָּזֹאת עַל־אֹדוֹתָיו וַיִּשְׁלְחוּ רָאשֵׁי הַכֹּהֲנִים וְהַפְּרוּשִׁים מְשָׁרְתִים לְתָפְשׂוֹ׃
\v 33 \vp לג\vp* וַיֹּאמֶר אֲלֵיהֶם יֵשׁוּעַ עוֹד מְעַט מִזְעָר אֶהְיֶה עִמָּכֶם וְאֵלֵךְ לִי אֶל־שֹׁלְחִי׃
\v 34 \vp לד\vp* תְּבַקְשֻׁנִי וְלֹא תִמְצָאֻנִי וּבַאֲשֶׁר אֶהְיֶה אֲנִי לֹא תוּכְלוּ אַתֶּם לָבֹא שָׁמָּה׃
\v 35 \vp לה\vp* וַיֹּאמְרוּ הַיְּהוּדִים אִישׁ אֶל־אָחִיו אָנָה יֵלֵךְ זֶה כִּי לֹא נִמְצָא אֹתוֹ הֲיֵלֵךְ אֶל־הַנְּפוֹצִים בְּאֶרֶץ יָוָן וּלְלַמֵּד אֶת־הַיְּוָנִים׃
\v 36 \vp לו\vp* מָה־הַדָּבָר הַזֶּה אֲשֶׁר אָמַר תְּבַקְשֻׁנִי וְלֹא תִמְצָאֻנִי וּבַאֲשֶׁר אֶהְיֶה אֲנִי לֹא תוּכְלוּ אַתֶּם לָבֹא שָׁמָּה׃
\v 37 \vp לז\vp* וַיְהִי בַּיּוֹם הָאַחֲרוֹן הַגָּדוֹל בֶּחָג וַיַּעֲמֹד יֵשׁוּעַ וַיִּקְרָא הוֹי כָּל־צָמֵא לְכוּ אֵלַי וּשְׁתוּ׃
\v 38 \vp לח\vp* הַמַּאֲמִין בִּי כִּדְבַר הַכָּתוּב מִקִּרְבּוֹ יִזְּלוּ נַחֲלֵי מַיִם חַיִּים׃
\v 39 \vp לט\vp* כָּזֹאת דִּבֶּר עַל־הָרוּחַ אֲשֶׁר תָּנַח עַל־הַמַּאֲמִינִים בּוֹ כִּי עוֹד לֹא־נִשְׁפַּךְ רוּחַ הַקֹּדֶשׁ בְּטֶרֶם לֻקַּח יֵשׁוּעַ אַחַר כָבוֹד׃
\v 40 \vp מ\vp* וְיֵשׁ מִן־הָעָם כְּשָׁמְעָם אֶת־הַדְּבָרִים הָאֵלֶּה אָמְרוּ אָכֵן זֶה הוּא הַנָּבִיא׃
\v 41 \vp מא\vp* וְיֵשׁ אֲשֶׁר אָמְרוּ זֶה הוּא הַמָּשִׁיחַ וַאֲחֵרִים אָמְרוּ הֲמִן־הַגָּלִיל יָבֹא הַמָּשִׁיחַ׃
\v 42 \vp מב\vp* הֲלֹא הַכָּתוּב אֹמֵר כִּי מִזֶּרַע דָּוִד מִבֵּית־לֶחֶם הָעִיר חָנָה דָוִד מִשָּׁם יֵצֵא הַמָּשִׁיחַ׃
\v 43 \vp מג\vp* וַיֵּחָלֵק הָעָם בְּהַצֹּתָם עָלָיו׃
\v 44 \vp מד\vp* וְיֵשׁ מֵהֶם אֲשֶׁר רָצוּ לְתָפְשׂוֹ וְאִישׁ לֹא־שָׁלַח בּוֹ יָדוֹ׃
\v 45 \vp מה\vp* וַיָּשׁוּבוּ הַמְשָׁרְתִים אֶל־רָאשֵׁי הַכֹּהֲנִים וְהַפְּרוּשִׁים וְהֵם אָמְרוּ אֲלֵיהֶם מַדּוּעַ לֹא־הֲבֵאתֶם אֹתוֹ׃
\v 46 \vp מו\vp* וַיַּעֲנוּ הַמְשָׁרְתִים לֵאמֹר מֵעוֹלָם לֹא־דִבֶּר אָדָם כָּמֹהוּ׃
\v 47 \vp מז\vp* וַיֹּאמְרוּ אֲלֵיהֶם הַפְּרוּשִׁים הֲכִי נִדַּחְתֶּם גַּם־אַתֶּם׃
\v 48 \vp מח\vp* הֲכִי הֶאֱמִין בּוֹ אַחַד הַשָּׂרִים אוֹ אַחַד הַפְּרוּשִׁים׃
\v 49 \vp מט\vp* לְבַד הֶהָמוֹן הַזֶּה אֲשֶׁר אֵינָם יֹדְעִים אֶת־הַתּוֹרָה אֲרוּרִים הֵמָּה׃
\v 50 \vp נ\vp* וַיֹּאמֶר אֲלֵיהֶם נַקְדִּימוֹן הוּא אֲשֶׁר־בָּא אֵלָיו לְפָנִים וְהוּא אֶחָד מִן־הַפְּרוּשִׁים׃
\v 51 \vp נא\vp* הֲכִי תִשְׁפֹּט תּוֹרָתֵנוּ אֶת־הָאָדָם בְּטֶרֶם יִשָּׁמַע מַה־בְּפִיו וּבְטֶרֶם יִוָּדַע מֶה־עָשָׂה׃
\v 52 \vp נב\vp* וַיַּעֲנוּ וַיֹּאמְרוּ אֵלָיו הֲמִן־הַגָּלִיל גַּם־אַתָּה דְּרֹשׁ וַחֲקֹר כִּי לֹא־קָם נָבִיא מִן־הַגָּלִיל׃
\c 8
\cp ח
\cl פרק ח
\p 
\v 1 \vp א\vp* וַיֵּלְכוּ אִישׁ אִישׁ לְבֵיתוֹ וְיֵשׁוּעַ הָלַךְ אֶל־הַר הַזֵּיתִים׃
\v 2 \vp ב\vp* וַיְהִי בַּבֹּקֶר וַיָּבֹא עוֹד אֶל־הַהֵיכָל וְכָל־הָעָם בָּאוּ אֵלָיו וַיֵּשֶׁב וַיְלַמְּדֵם׃
\v 3 \vp ג\vp* וְהַסּוֹפְרִים וְהַפְּרוּשִׁים הֵבִיאוּ לְפָנָיו אִשָּׁה אֲשֶׁר נִתְפְּשָׂה בְּנַאֲפוּפֶיהָ וַיַּעֲמִדוּהָ בַּתָּוֶךְ׃
\v 4 \vp ד\vp* וַיֹּאמְרוּ אֵלָיו רַבֵּנוּ הָאִשָּׁה הַזֹּאת נִתְפְּשָׂה בְּנַאֲפוּפֶיהָ כְּגַנָּב בַּמַּחְתָּרֶת׃
\v 5 \vp ה\vp* וּבַתּוֹרָה צִוָּה־לָנוּ משֶׁה לִסְקֹל בָּאֲבָנִים אִשָּׁה כָזֹאת וּמַה־תֹּאמַר אָתָּה׃
\v 6 \vp ו\vp* וְכָזֹאת אָמְרוּ לְנַסּוֹתוֹ לִמְצֹא עָלָיו דָּבָר לְשִׂטְנוֹ וַיִּשְׁתּוֹחַח יֵשׁוּעַ וַיְתָו בְּאֶצְבָּעוֹ עַל־הָאָרֶץ׃
\v 7 \vp ז\vp* וְכַאֲשֶׁר הוֹסִיפוּ לִשְׁאֹל אֹתוֹ וַיָּקָם וַיֹּאמֶר אֲלֵיהֶם מִי־בָכֶם נָקִי מֵעָוֹן יַדֶּה־בָּהּ אֶבֶן רִאשׁוֹנָה׃
\v 8 \vp ח\vp* וַיִּשְׁתּוֹחַח שֵׁנִית וַיְתָו עוֹד עַל־הָאָרֶץ׃
\v 9 \vp ט\vp* וְהֵם כְּשָׁמְעָם אֶת־זֹאת וַיַּךְ לִבָּם אֹתָם יָצְאוּ אִישׁ אִישׁ מִזָּקֵן וְעַד־צָעִיר וַיִּוָּתֵר יֵשׁוּעַ לְבַדּוֹ וְהָאִשָּׁה עֹמֶדֶת בַּתָּוֶךְ׃
\v 10 \vp י\vp* וַיָּקָם יֵשׁוּעַ וַיַּרְא כִּי אֵין אִישׁ בִּלְתִּי הָאִשָּׁה לְבַדָּה וַיֹּאמַר אִשָּׁה אַיֵּה הֵם שִּׂטְנַיִךְ הֲכִי לֹא הִרְשִׁיעֵךְ אִישׁ׃
\v 11 \vp יא\vp* וַתֹּאמֶר אֵין גַּם־אֶחָד אֲדֹנִי וַיֹּאמֶר אֵלֶיהָ יֵשׁוּעַ גַּם־אֲנִי לֹא אַרְשִׁיעֵךְ לְכִי לְבֵיתֵךְ וְאַל־תֶּחֶטְאִי עוֹד׃
\v 12 \vp יב\vp* וַיּוֹסֶף יֵשׁוּעַ וַיְדַבֵּר אֲלֵיהֶם לֵאמֹר אָנֹכִי אוֹר הָעוֹלָם הַהֹלֵךְ אַחֲרַי לֹא יֵלֵךְ בַּחֹשֶׁךְ כִּי־לוֹ אוֹר הַחַיִּים׃
\v 13 \vp יג\vp* וַיֹּאמְרוּ אֵלָיו הַפְּרוּשִׁים אַתָּה מֵעִיד עֵדוּת לְנַפְשֶׁךָ עֵדוּתְךָ לֹא נֶאֱמָנָה׃
\v 14 \vp יד\vp* וַיַּעַן יֵשׁוּעַ וַיֹּאמֶר אֲלֵיהֶם אַף אִם־אֲנִי מֵעִיד לְנַפְשִׁי עֵדוּתִי נֶאֱמָנָה כִּי־יָדַעְתִּי מֵאַיִן בָּאתִי וּלאָן אֲנִי הֹלֵךְ וְאַתֶּם אֵינְכֶם יֹדְעִים מֵאַיִן בָּאתִי וּלְאָן אֲנִי הֹלֵךְ׃
\v 15 \vp טו\vp* אַתֶּם דָּנִים לְעֵינֵי בָשָׂר וַאֲנִי אֵינֶנִּי דָן אַף לֹא־לָאֶחָד׃
\v 16 \vp טז\vp* וְאַף לוּ־דָן הָיִיתִי דִּינִי דִּין אֱמֶת כִּי אֵינֶנִּי לְבַדִּי כִּי אִם־אֲנִי וְהָאָב אֲשֶׁר שְׁלָחָנִי׃
\v 17 \vp יז\vp* וְגַם בְּתוֹרַתְכֶם כָּתוּב כִּי עַל־פִּי שְׁנַיִם עֵדִים יָקוּם דָּבָר׃
\v 18 \vp יח\vp* אֲנִי הוּא הַמֵעִיד עֵדוּת לְנַפְשִׁי וְאָבִי אֲשֶׁר שְׁלָחַנִי גַּם־הוּא לִי לְעֵד׃
\v 19 \vp יט\vp* וַיֹּאמְרוּ אֵלָיו אָבִיךָ אַיּוֹ וַיַּעַן יֵשׁוּעַ לֹא יְדַעְתֶּם גַּם־אֹתִי וְגַם־לֹא אֶת־אָבִי לוּ יְדַעְתֶּם אֹתִי אָז יְדַעְתֶּם גַּם אֶת־אָבִי׃
\v 20 \vp כ\vp* כַּדְּבָרִים הָאֵלֶּה דִּבֶּר יֵשׁוּעַ בְּבֵית הָאוֹצָר כַּאֲשֶׁר לִמַּד בַּהֵיכָל וְלֹא־תְפָשׂוֹ אִישׁ כִּי עוֹד לֹא־בָאָה עִתּוֹ׃
\v 21 \vp כא\vp* וַיּוֹסֶף יֵשׁוּעַ וַיֹּאמֶר אֲלֵיהֶם אֲנִי אֵלֶךְ לִי וְאַתֶּם תְּבַקְשֻׁנִי וּבְחַטֹּאתֵיכֶם תָּמוּתוּ וְאֶל־אֲשֶׁר אֲנִי הֹלֵךְ אַתֶּם לֹא־תוּכְלוּ לָבֹא שָׁמָּה׃
\v 22 \vp כב\vp* וַיֹּאמְרוּ הַיְּהוּדִים הַיְאַבֵּד נַפְשׁוֹ בְּיָדָיִם כִּי אֹמֵר אֶל־אֲשֶׁר אֲנִי הֹלֵךְ אַתֶּם לֹא־תוּכְלוּ לָבֹא שָׁמָּה׃
\v 23 \vp כג\vp* וַיֹּאמֶר אֲלֵיהֶם אַתֶּם מִשֹּׁכְנֵי מַטָּה וַאֲנִי מִשֹּׁכְנֵי מָעְלָה אַתֶּם מִן־הָעוֹלָם הַזֶּה וַאֲנִי אֵינֶנִּי מִן־הָעוֹלָם הַזֶּה׃
\v 24 \vp כד\vp* לָכֵן אָמַרְתִּי לָכֶם כִּי תָמוּתוּ בְחַטֹּאתֵיכֶם כִּי אִם־לֹא תַאֲמִינוּ־בִי כִּי־אֲנִי הוּא תָּמוּתוּ בְחַטֹּאתֵיכֶם׃
\v 25 \vp כה\vp* וַיֹּאמְרוּ אֵלָיו וּמִי־זֶה אָתָּה וַיֹּאמֶר אֲלֵיהֶם יֵשׁוּעַ אֲנִי הוּא כַּאֲשֶׁר אָמַרְתִּי אֲלֵיכֶם מֵרֹאשׁ׃
\v 26 \vp כו\vp* יֶשׁ־לִי רַבּוֹת לְדַבֵּר וְלִשְׁפֹּט עֲלֵיכֶם אָכֵן שֹׁלְחִי נֶאֱמָן הוּא וְאֶת־הַדָּבָר אֲשֶׁר אֶשְׁמַע מִמֶּנּוּ אֹתוֹ אֲדַבֵּר אֶל־הָעוֹלָם׃
\v 27 \vp כז\vp* וְהֵם לֹא הֵבִינוּ זֹאת כִּי עַל־הָאָב דִּבֶּר אֲלֵיהֶם׃
\v 28 \vp כח\vp* וַיֹּאמֶר יֵשׁוּעַ כַּאֲשֶׁר תַּגְבִּיהוּ אֶת־בֶּן־הָאָדָם לְמַעְלָה אָז תַּכִּירוּ כִּי־אֲנִי הוּא וְלֹא עָשִׂיתִי מְאוּמָה מִלִּבִּי כִּי אִם־הַדָּבָר אֲשֶׁר הוֹרַנִי הָאָב אֹתוֹ אֲנִי מְדַבֵּר׃
\v 29 \vp כט\vp* וְשֹׁלְחִי עִמָּדִי הוּא לֹא זָנַח אֹתִי גַּלְמוּד כִּי אֶת־הַטּוֹב בְּעֵינָיו אֲנִי עֹשֶׂה תָּמִיד׃
\v 30 \vp ל\vp* וַיְהִי כְּדַבְּרוֹ אֶת־הַדְּבָרִים הָאֵלֶּה וַיַּאֲמִינוּ־בוֹ רַבִּים׃
\v 31 \vp לא\vp* וַיֹּאמֶר יֵשׁוּעַ אֶל־הַיְּהוּדִים הַמַּאֲמִינִים בּוֹ אִם־תַּעַמְדוּ בִּדְבָרַי אָז תִּהְיוּ תַלְמִידַי בֶּאֱמֶת וּבְתָמִים׃
\v 32 \vp לב\vp* כִּי תַשְׂכִּילוּ אֶת־הָאֱמֶת וְהָאֱמֶת תַּעֲשֶׂה אֶתְכֶם חָפְשִׁים׃
\v 33 \vp לג\vp* וַיַּעֲנוּ אֹתוֹ הֵן זֶרַע אַבְרָהָם אֲנַחְנוּ וְלֹא־הָיִינוּ עֲבָדִים לְאָדָם מֵעוֹלָם וְאֵיךְ תֹּאמַר אַתָּה כִּי־חָפְשִׁים תִּהְיוּ׃
\v 34 \vp לד\vp* וַיַּעַן אֹתָם יֵשׁוּעַ אָמֵן אָמֵן אֲנִי אֹמֵר לָכֶם כָּל־אִישׁ אֲשֶׁר יַעֲשֶׂה חֵטְא עֶבֶד לַחֵטְא הוּא׃
\v 35 \vp לה\vp* וְהָעֶבֶד לֹא־יֵשֵׁב בַּבַּיִת עַד־עוֹלָם אַךְ הַבֵּן יֵשֵׁב שָׁם עַד־עוֹלָם׃
\v 36 \vp לו\vp* לָכֵן אִם־הַבֵּן יַעֲשֶׂה אֶתְכֶם חָפְשִׁים חָפְשִׁים תִּהְיוּ אֶל־נָכוֹן׃
\v 37 \vp לז\vp* יָדַעְתִּי כִּי־זֶרַע אַבְרָהָם אַתֶּם וּבְכָל־זֹאת תְּבַקְשׁוּ אֶת־נַפְשִׁי לְקַחְתָּהּ כִּי לִדְבָרַי אֵין מְסִלּוֹת בִּלְבַבְכֶם׃
\v 38 \vp לח\vp* אֲנִי מְדַבֵּר אֵת אֲשֶׁר רָאִיתִי אֵצֶל הָאָב וְאַתֶּם עֹשִׂים אֵת אֲשֶׁר שְׁמַעְתֶּם מֵאֵת אֲבִיכֶם׃
\v 39 \vp לט\vp* וַיַעֲנוּ וַיֹּאמְרוּ אֵלָיו אָבִינוּ הוּא אַבְרָהָם וַיֹּאמֶר אֲלֵיהֶם יֵשׁוּעַ לוּ הֱיִיתֶם בְּנֵי אַבְרָהָם כְּמַעֲשֵׂי אַבְרָהָם עֲשִׂיתֶם׃
\v 40 \vp מ\vp* וְאַתֶּם מְבַקְשִׁים אֶת־נַפְשִׁי לְקַחְתָּהּ בַּאֲשֶׁר אֱמֶת אַגִּיד לָכֶם אֵת אֲשֶׁר שָׁמַעְתִּי מֵאֵת אֱלֹהִים כָּזֹאת לֹא עָשָׂה אַבְרָהָם׃
\v 41 \vp מא\vp* כְּמַעֲשֵׂי אֲבִיכֶם אַתֶּם עֹשִׂים וַיֹּאמְרוּ אֵלָיו לֹא יַלְדֵי זְנוּנִים אֲנָחְנוּ יֶשׁ־לָנוּ אָב אֶחָד אֱלֹהִים׃
\v 42 \vp מב\vp* וַיֹּאמֶר אֲלֵיהֶם יֵשׁוּעַ אִם אֱלֹהִים אֲבִיכֶם תֶּאֱהָבוּנִי כִּי מֵאֵת אֱלֹהִים יָצָאתִי וּמֵאִתּוֹ בָאתִי וְלֹא־מִלִּבִּי כִּי־הוּא שְׁלָחָנִי׃
\v 43 \vp מג\vp* מַדּוּעַ לֹא תָבִינוּ נִיב שְׂפָתָי אֵין זֶה כִּי אִם לֹא־תוּכְלוּן לְהַשְׂכִּיל אֶל־תּוֹרָתִי׃
\v 44 \vp מד\vp* אַתֶּם מֵאֵת אֲבִיכֶם הַשָּׂטָן הִנְּכֶם וַתִּתְמַכְּרוּ לַעֲשׂוֹת כְּתַאֲוַת אֲבִיכֶם הוּא הָיָה רֹצֵחַ נְפָשׁוֹת מֵרֹאשׁ וּבְמוֹ־אֱמֶת לֹא עָמַד כִּי אֱמֶת אֵין־בּוֹ כַּאֲשֶׁר יְדַבֵּר כָּזָב מִלִּבּוֹ הוּא דֹבֵר כִּי־מְשַׁקֵּר הוּא וַאֲבִי כָל־מְשַׁקֵּר׃
\v 45 \vp מה\vp* וַאֲנִי כַּאֲשֶׁר אֱמֶת אֲנִי דֹבֵר לֹא תַאֲמִינוּ לִי׃
\v 46 \vp מו\vp* מִי־מִכֶּם יַכְזִיבֵנִי עַל־שֶׁמֶץ דָּבָר וְאִם דֹּבֵר אֱמֶת אֲנִי מַדּוּעַ לֹא־תַאֲמִינוּ לִי׃
\v 47 \vp מז\vp* מִי אֲשֶׁר מֵאֵת אֱלֹהִים הוּא יִשְׁמַע דִּבְרֵי אֱלֹהִים וְאַתֶּם לֹא תִשְׁמָעוּנִי כִּי לֹא מֵאֵת אֱלֹהִים אַתֶּם׃
\v 48 \vp מח\vp* וַיַּעֲנוּ הַיְּהוּדִים וַיֹּאמְרוּ אֵלָיו הֲלֹא הֵיטֵב דִּבַּרְנוּ כִּי שֹׁמְרוֹנִי אַתָּה וְרוּחַ רָעָה בָּךְ׃
\v 49 \vp מט\vp* וַיַּעַן יֵשׁוּעַ רוּחַ רָעָה אֵין־בִּי כִּי אִם־מְכַבֵּד אֲנִי אֶת־אָבִי וְאַתֶּם תִּבְזֻנִי׃
\v 50 \vp נ\vp* וַאֲנִי לֹא אֶת־כְּבוֹדִי אֲנִי מְבַקֵּשׁ יֵשׁ אֶחָד אֲשֶׁר הוּא מְבַקְשׁוֹ וְגַם־יִשְׁפֹּט׃
\v 51 \vp נא\vp* אָמֵן אָמֵן אֲנִי אֹמֵר לָכֶם אִם יִשְׁמֹר אִישׁ אֶת־דְּבָרִי לֹא יִרְאֶה־מָּוֶת לְעוֹלָם׃
\v 52 \vp נב\vp* וַיֹּאמְרוּ אֵלָיו הַיְּהוּדִים עַתָּה יָדַעְנוּ כִּי־רוּחַ רָעָה בָּךְ גַּם־אַבְרָהָם מֵת גַּם־הַנְּבִיאִים וְאַתָּה אָמַרְתָּ אִם יִשְׁמֹר אִישׁ אֶת־דְּבָרִי לֹא יִטְעַם־מָוֶת לְעוֹלָם׃
\v 53 \vp נג\vp* הֲגָדוֹל אַתָּה מֵאַבְרָהָם אָבִינוּ אֲשֶׁר מֵת וְהַנְּבִיאִים כִּי מֵתוּ מַה תַּעֲשֶׂה בְנַפְשֶׁךָ׃
\v 54 \vp נד\vp* וַיַּעַן יֵשׁוּעַ אִם־אֲנִי אֶתֵּן כָּבוֹד לְנַפְשִׁי כְּבוֹדִי כְאָיִן אַךְ אָבִי הוּא מְכַבְּדֵנִי אֲשֶׁר עָלָיו תֹּאמְרוּן כִּי הוּא אֱלֹהֵיכֶם׃
\v 55 \vp נה\vp* וְאַתֶּם לֹא יְדַעְתֶּם אֹתוֹ אַךְ אֲנִי יֹדֵעַ אֹתוֹ וְכִי־אֹמַר לֹא יְדַעְתִּיו אֶהְיֶה מְכַזֵּב כְּמוֹכֶם אָכֵן יְדַעְתִּיו וְאֶת־דְּבָרוֹ אֲנִי שֹׁמֵר׃
\v 56 \vp נו\vp* אַבְרָהָם אֲבִיכֶם הִתְעַלֵּס לִרְאוֹת אֶת־יוֹמִי וַיַּרְא וַיִּשְׂמַח׃
\v 57 \vp נז\vp* וַיֹּאמְרוּ אֵלָיו הַיְּהוּדִים אֵינְךָ עוֹד בֶּן־חֲמִשִּׁים שָׁנָה וְאֶת־אַבְרָהָם רָאִיתָ׃
\v 58 \vp נח\vp* וַיֹּאמֶר אֲלֵיהֶם יֵשׁוּעַ אָמֵן אָמֵן אֲנִי אֹמֵר לָכֶם אֲנִי הָיִיתִי עוֹד עַד לֹא־הָיָה אַבְרָהָם׃
\v 59 \vp נט\vp* וַיִּשְׂאוּ אֲבָנִים לִרְגֹּם אֹתוֹ אַךְ יֵשׁוּעַ הִסְתַּתֵּר מֵעֵינֵיהֶם וַיֵּצֵא מִן־הַמִּקְדָּשׁ וַיַּעֲבֹר בְּתֹכָם וַיֵּלֶךְ הָלוֹךְ׃
\c 9
\cp ט
\cl פרק ט
\p 
\v 1 \vp א\vp* וַיְהִי בְּעָבְרוֹ וַיַּרְא אִישׁ אֲשֶׁר נוֹלַד עִוֵּר מֵרֶחֶם אִמּוֹ׃
\v 2 \vp ב\vp* וַיִּשְׁאָלֻהוּ תַלְמִידָיו לֵאמֹר רַבֵּנוּ מִי חָטָא הָאִישׁ הַזֶּה אוֹ יֹלְדָיו כִּי נוֹלַד עִוֵּר׃
\v 3 \vp ג\vp* וַיַּעַן יֵשׁוּעַ לֹא הוּא חָטָא וְלֹא יֹלְדָיו אַךְ לְבַעֲבוּר יֵרָאוּ־בוֹ מַעַלְלֵי־אֵל׃
\v 4 \vp ד\vp* עָלַי לְעוֹלֵל עֲלִלוֹת שֹׁלְחִי בְּעוֹד יוֹם כִּי־יָבֹא לַיְלָה וְאָז לֹא־יוּכַל אִישׁ לַעֲשׂוֹת מְאוּמָה׃
\v 5 \vp ה\vp* בְּעוֹד אֲנִי בָעוֹלָם אוֹר הָעוֹלָם הִנֵּנִי׃
\v 6 \vp ו\vp* הַדָּבָר יָצָא מִפִּיו וַיָּרֶק רֹק בַּעֲפַר הָאֲדָמָה וַיִּגְבָּל־חֹמֶר וַיִּמְרַח עַל־עֵינָיו׃
\v 7 \vp ז\vp* וַיֹּאמֶר אֵלָיו הָלֹךְ וְרָחַצְתָּ בִּבְרֵכַת הַשִּׁלֹּחַ אֲשֶׁר יֵאָמֵר שָׁלוּחַ וַיֵּלֶךְ וַיִּרְחַץ וַיָּבֹא בְּעֵינַיִם פְּקֻחוֹת׃
\v 8 \vp ח\vp* וַיֹּאמְרוּ שְׁכֵנָיו הַיֹּדְעִים אֹתוֹ מֵאָז הֲלֹא־זֶה הוּא הַיֹּשֵׁב הַמְבַקֵּשׁ נְדָבוֹת׃
\v 9 \vp ט\vp* אֵלֶּה אָמְרוּ כִּי־זֶה הוּא וְאֵלֶּה לֹא־כֵן רַק דּוֹמֶה־לּוֹ וְהוּא אָמַר אֲנִי הוּא׃
\v 10 \vp י\vp* וַיֹּאמְרוּ אֵלָיו אֵיכָה אֵיפוֹא נִפְקְחוּ עֵינֶיךָ׃
\v 11 \vp יא\vp* וַיַּעַן אִישׁ אֲשֶׁר שְׁמוֹ יֵשׁוּעַ גָּבַל חֹמֶר וַיִּמְרַח עַל־עֵינָי וְכֹה אָמַר אֵלַי הָלֹךְ וְרָחַצְתָּ בִּבְרֵכַת הַשִּׁלֹּחַ וָאֵלֵךְ וָאֶרְחַץ וְעֵינַי נִפְקָחוּ׃
\v 12 \vp יב\vp* וַיֹּאמְרוּ אֵלָיו וְאַיּוֹ וַיֹּאמֶר לֹא יָדָעְתִּי׃
\v 13 \vp יג\vp* וַיָּבִיאוּ אֶת־הָעִוֵּר הָרֹאֶה הַזֶּה אֶל־הַפְּרוּשִׁים׃
\v 14 \vp יד\vp* וְהַיּוֹם אֲשֶׁר לָשׁ יֵשׁוּעַ אֶת־הַטִּיחַ וְאֶת־עֵינָיו פָּקָח הָיָה יוֹם הַשַּׁבָּת׃
\v 15 \vp טו\vp* וַיּוֹסִיפוּ גַם־הַפְּרוּשִׁים לִשְׁאֹל אֹתוֹ אֵיךְ נִתַּן לוֹ אוֹר עֵינָיו וַיַגֵּד לָהֶם כִּי שָׂם טִיחַ עַל־עֵינַי וָאֶרְחַץ וְהִנֵּה עֵינַי רֹאוֹת׃
\v 16 \vp טז\vp* וְיֵשׁ מִן־הַפְּרוּשִׁים אָמְרוּ הָאִישׁ הַזֶּה אֵינֶנּוּ אִישׁ אֱלֹהִים כִּי אֵינֶנּוּ שֹׁמֵר אֶת־הַשַּׁבָּת וְיֵשׁ אָמְרוּ הֲיוּכַל אִישׁ חֹטֵא לַעֲשׂוֹת מוֹפְתִים כָּאֵלֶה וַיְהִי מָדוֹן בֵּינֵיהֶם׃
\v 17 \vp יז\vp* וַיּוֹסִיפוּ וַיֹּאמְרוּ אֶל־הָעִוֵּר וּמַה־תֹּאמַר אַתָּה עָלָיו כִּי פָּקַח אֶת־עֵינֶיךָ וַיֹּאמֶר כִּי נָבִיא הוּא׃
\v 18 \vp יח\vp* וְלֹא־הֶאֱמִינוּ לוֹ הַיְּהוּדִים כִּי עִוֵּר הָיָה וְאוֹר עֵינָיו נִתַּן לוֹ עַד־אֲשֶׁר קָרְאוּ לְיֹלְדֵי הָעִוֵּר הָרֹאֶה׃
\v 19 \vp יט\vp* וַיִּשְׁאֲלוּ אֹתָם לֵאמֹר הֲזֶה בִנְכֶם אֲשֶׁר אֲמַרְתֶּם כִּי נוֹלַד עִוֵּר וְאֵיךְ הוּא רֹאֶה עָתָּה׃
\v 20 \vp כ\vp* וַיַּעֲנוּ אֹתָם יֹלְדָיו וַיֹּאמְרוּ יָדַעְנוּ בְּנֵנוּ הוּא זֶה וְגַם נוֹלַד עִוֵּר׃
\v 21 \vp כא\vp* אֲבָל לֹא יָדַעְנוּ אֵיךְ הוּא רֹאֶה עַתָּה וְלֹא יָדַעְנוּ מִי פָקַח אֶת־עֵינָיו הֲלֹא בָא בַיָּמִים הוּא שַׁאֲלוּ אֹתוֹ וְהוּא בְּפִיו יַגִּיד לָכֶם׃
\v 22 \vp כב\vp* כָּזֹאת דִּבְּרוּ יֹלְדָיו מִיִּרְאָתָם אֶת־הַיְּהוּדִים אֲשֶׁר כְּבָר חָרְצוּ לְנַדּוֹת אֶת־כָּל־אֲשֶׁר יוֹדֶה כִּי הוּא הַמָּשִׁיחַ׃
\v 23 \vp כג\vp* עַל־כֵּן אָמְרוּ יֹלְדָיו כִּי בָא בַשָּׁנִים הוּא שַׁאֲלוּ אֶת־פִּיהוּ׃
\v 24 \vp כד\vp* אָז קָרְאוּ שֵׁנִית לָעִוֵּר הָרֹאֶה וַיֹּאמְרוּ אֵלָיו שִׂים־נָא כָּבוֹד לֵאלֹהִים אֲנַחְנוּ יָדַעְנוּ כִּי־הָאִישׁ הַזֶּה חֹטֵא הוּא׃
\v 25 \vp כה\vp* וַיַּעַן וַיֹּאמֶר אִם־חֹטֵא הוּא לֹא יָדָעְתִּי רַק אַחַת יָדַעְתִּי כִּי עִוֵּר הָיִיתִי וְעַתָּה הִנְנִי רֹאֶה׃
\v 26 \vp כו\vp* וַיֹּאמְרוּ אֵלָיו מֶה־עָשָׂה לָךְ אֵיךְ פָּקַח אֶת־עֵינֶיךָ׃
\v 27 \vp כז\vp* וַיַּעַן אֹתָם הֲלֹא אָמַרְתִּי לָכֶם וְלֹא שְׁמַעְתֶּם וּמַה־לָּכֶם לִשְׁמֹעַ שֵׁנִית הֲגַם אַתֶּם חֲפֵצִים לִהְיוֹת תַּלְמִידָיו׃
\v 28 \vp כח\vp* וַיְגַדְּפוּ אֹתוֹ וַיֹּאמְרוּ אַתָּה הוּא תַלְמִידוֹ וַאֲנַחְנוּ תַּלְמִידֵי משֶׁה אֲנָחְנוּ׃
\v 29 \vp כט\vp* יָדַעְנוּ כִּי אֶל־משֶׁה דִּבֶּר אֱלֹהִים וְזֶה הָאִישׁ לֹא יָדַעְנוּ מֵאַיִן הוּא׃
\v 30 \vp ל\vp* וַיַּעַן הָאִישׁ וַיֹּאמֶר אֲלֵיהֶם דְּבַר פֶּלֶא הוּא אַתֶּם לֹא יְדַעְתֶּם מֵאַיִן הוּא וְהוּא אֶת־עֵינַי פָּקָח׃
\v 31 \vp לא\vp* וַאֲנַחְנוּ יָדַעְנוּ כִּי חַטָּאִים לֹא־יִשְׁמַע אֱלֹהִים כִּי אִם־הַיָּרֵא אֶת־הָאֱלֹהִים וְהָעֹשֶׂה אֶת־רְצוֹנוֹ אֹתוֹ יִשְׁמָע׃
\v 32 \vp לב\vp* מִי שָׁמַע מֵעוֹדוֹ כִּי־פָקַח אִישׁ אֶת־עֵינֵי הַנּוֹלָד עִוֵּר מֵרָחֶם׃
\v 33 \vp לג\vp* לוּלֵא הָיָה זֶה אִישׁ אֱלֹהִים לֹא־יָכֹל עֲשׂוֹת דָּבָר׃
\v 34 \vp לד\vp* וַיַּעֲנוּ וַיֹּאמְרוּ אֵלָיו הֵן בְּעָוֹן חוֹלָלְתָּ וְאַתָּה תְלַמֵּד אֹתָנוּ וַיִּדְחֲפוּ אֹתוֹ מֵעַל־פְּנֵיהֶם׃
\v 35 \vp לה\vp* וְיֵשׁוּעַ שָׁמַע כִּי דָחֲפוּ אֹתוֹ מֵעַל־פְּנֵיהֶם וַיִּפְגְּשֵׁהוּ וַיֹּאמַר הֲתַאֲמִין בְּבֶן־הָאֱלֹהִים׃
\v 36 \vp לו\vp* וַיַּעַן וַיֹּאמַר וּמִי הוּא־זֶה אֲדֹנִי וְאַאֲמִין בּוֹ׃
\v 37 \vp לז\vp* וַיֹּאמֶר אֵלָיו יֵשׁוּעַ הֲלֹא רָאִיתָ אֹתוֹ וְהִנֵּה הוּא הַמְדַבֵּר אֵלֶיךָ זֶה הוּא׃
\v 38 \vp לח\vp* וַיֹּאמַר הִנְנִי מַאֲמִין אֲדֹנִי וַיִּשְׁתַּחוּ לוֹ׃
\v 39 \vp לט\vp* וַיֹּאמֶר יֵשׁוּעַ אֲנִי לָדִין בָּאתִי בָאָרֶץ לְמַעַן הַעִוְרִים יִהְיוּ רֹאִים וְהָרֹאִים יִהְיוּ עִוְרִים׃
\v 40 \vp מ\vp* וּמִן־הַפְּרוּשִׁים אֲשֶׁר הָיוּ עִמּוֹ וְשָׁמְעוּ אֶת־דְּבָרָיו אָמְרוּ הֲגַם אֲנַחְנוּ עִוְרִים׃
\v 41 \vp מא\vp* וַיֹּאמֶר אֲלֵיהֶם יֵשׁוּעַ לוּ עִוְרִים הֱיִיתֶם לֹא־הָיָה בָכֶם עָוֹן אֲבָל אַתֶּם אֹמְרִים כִּי הִנְּכֶם רֹאִים לָכֵן נִמְצָא עָוֹן בָּכֶם׃
\c 10
\cp י
\cl פרק י
\p 
\v 1 \vp א\vp* אָמֵן אָמֵן אֲנִי אֹמֵר לָכֶם אִישׁ אֲשֶׁר לֹא־יַבֹא דֶּרֶךְ הַשַּׁעַר אֶל־מִכְלְאוֹת הַצֹּאן כִּי אִם־יַעֲלֶה בְדֶרֶךְ אַחֵר גַּנָּב הוּא וְשֹׁדֵד׃
\v 2 \vp ב\vp* וְאִישׁ הַבָּא דֶרֶךְ הַשַּׁעַר הוּא רֹעֵה הַצֹּאן׃
\v 3 \vp ג\vp* לוֹ יִפְתַּח הַשֹּׁעֵר וְהַצֹּאן תִּשְׁמַעְנָה בְקֹלוֹ וְהוּא בְּשֵׁמוֹת יִקְרָא אֶל־צֹאנוֹ וְיוֹצִיאֵן׃
\v 4 \vp ד\vp* בְּהוֹצִיאוֹ אֶת־כָּל־צֹאנוֹ יַעֲבֹר לִפְנֵיהֶן וְהָלְכוּ אַחֲרָיו הַצֹּאן כִּי יֹדְעוֹת אֶת־קֹלוֹ׃
\v 5 \vp ה\vp* וְאַחֲרֵי זָר לֹא תֵלַכְנָה כִּי תָנוֹסְנָה מִפָּנָיו יַעַן קוֹל זָרִים לֹא יָדָעוּ׃
\v 6 \vp ו\vp* אֶת־הַמָּשָׁל הַזֶּה נָשָׂא עֲלֵיהֶם יֵשׁוּעַ וְהֵם לֹא הֵבִינוּ מַה־זֶּה אֲשֶׁר דִּבֶּר אֲלֵיהֶם׃
\v 7 \vp ז\vp* וַיּוֹסֶף יֵשׁוּעַ וַיְדַבֵּר אֲלֵיהֶם אָמֵן אָמֵן אֲנִי אֹמֵר לָכֶם אָנֹכִי שַׁעַר הַצֹּאן׃
\v 8 \vp ח\vp* כֹּל אֲשֶׁר בָּאוּ לְפָנַי גַּנָּבִים הֵם וְשֹׁדְדִים וְלֹא־שָׁמְעוּ אֲלֵיהֶם הַצֹּאן׃
\v 9 \vp ט\vp* אָנֹכִי הַשַּׁעַר אִישׁ כִּי־יָבֹא דֶרֶךְ בִּי יְוָּשֵׁעַ וּבָא וְיֵצֵא וּמָצָא מִרְעֶה׃
\v 10 \vp י\vp* הַגַּנָּב לֹא יָבֹא כִּי אִם־לִגְנֹב לִשְׁחֹט וּלְהַשְׁמִיד וַאֲנִי בָאתִי לְמַעַן יִמְצְאוּ חַיִּים וְחַיַּת נַפְשָׁם לָרְוָיָה׃
\v 11 \vp יא\vp* אֲנִי הוּא הָרֹעֶה הַטּוֹב הָרֹעֶה הַטּוֹב יִתֵּן אֶת־נַפְשׁוֹ בְּעַד הַצֹּאן׃
\v 12 \vp יב\vp* וְהַשָּׂכִיר אֲשֶׁר אֵינֶנּוּ רֹעֶה וְלֹא־לוֹ הַצֹּאן יִרְאֶה אֶת־הַזְּאֵב בָּא יַעֲזֹב אֶת־הַצֹּאן וְיָנוּס וְהַזְּאֵב יַחֲטֹף וְיָפִיץ אֶת־הַצֹּאן׃
\v 13 \vp יג\vp* וְהַשָּׂכִיר נָס כִּי שָׂכִיר הוּא וְלֹא יִדְאַג לַצֹּאן׃
\v 14 \vp יד\vp* אֲנִי הוּא הָרֹעֶה הַטּוֹב יָדַעְתִּי אֵת אֲשֶׁר־לִי וְנוֹדַעְתִּי לַאֲשֶׁר לִי׃
\v 15 \vp טו\vp* כַּאֲשֶׁר גַּם־הָאָב יֹדֵעַ אֹתִי וַאֲנִי יֹדֵעַ אֶת־הָאָב וְאֶת־נַפְשִׁי אֶתֵּן בְּעַד הַצֹּאן׃
\v 16 \vp טז\vp* וְעוֹד צֹאן אֲחֵרוֹת יֶשׁ־לִי אֲשֶׁר אֵינָן מִן־הַמִּכְלָה הַזֹּאת וְעָלַי לִנְהַג גַּם־אֹתָן וְהֵנָּה בְּקוֹלִי תִשְׁמַעְנָה וְהָיָה עֵדֶר אֶחָד וְרֹעֶה אֶחָד׃
\v 17 \vp יז\vp* עַל־כֵּן יֶאֱהָבַנִי הָאָב כִּי אֶת־נַפְשִׁי אֶתֵּן וְאָשִׁיב וְאֶקָּחֶיהָ׃
\v 18 \vp יח\vp* אִישׁ לֹא יִקַּח נַפְשִׁי מִמֶּנִּי כִי אִם־אֲנִי אֶתְּנֶנָּה יֶשׁ־לְאֵל יָדִי לְתִתָּהּ וְיֶשׁ־לְאֵל לַהֲשִׁיבָהּ אֵלָי זֹאת הַמִּצְוָה צֻוֵּיתִי מֵאֵת אָבִי׃
\v 19 \vp יט\vp* וַיֵּחָלְקוּ הַיְּהוּדִים עוֹד הַפַּעַם עַל־הַדְּבָרִים הָאֵלֶּה׃
\v 20 \vp כ\vp* רַבִּים מֵהֶם אָמְרוּ רוּחַ רָע בּוֹ וּמְשֻׁגָּע הוּא לָמָּה־זֶּה תִּשְׁמְעוּ אֵלָיו׃
\v 21 \vp כא\vp* וַאֲחֵרִים אָמְרוּ אֵין הַדְּבָרִים הָאֵלֶּה דִּבְרֵי בַעַל רוּחַ רָע הֲיֵשׁ עִם־רוּחַ רָע לִפְקֹחַ עֵינֵי עִוְרִים׃
\v 22 \vp כב\vp* וַיְהִי בִּימֵי הַחֲנֻכָּה בִּימֵי הַחֹרֶף בִּירוּשָׁלָיִם׃
\v 23 \vp כג\vp* וַיִּתְהַלֵּךְ יֵשׁוּעַ בְּבֵית הַמִּקְדָּשׁ בְּאוּלָם שְׁלֹמֹה׃
\v 24 \vp כד\vp* וַיָּסֹבּוּ אֹתוֹ הַיְהוּדִים וַיֹּאמְרוּ עַד־אָנָה תִמְשְׁכֵנוּ בְנַפְשֵׁנוּ אִם־אַתָּה הוּא הַמָּשִׁיחַ הַגֶּד־לָנוּ לְעֵין הַשָּׁמֶשׁ׃
\v 25 \vp כה\vp* וַיַּעַן אֹתָם יֵשׁוּעַ הֵן הִגַּדְתִּי לָכֶם וְלֹא הֶאֱמַנְתֶּם בִּי הַמַּעֲשִׂים אֲשֶׁר־אֲנִי עֹשֶׂה בְּשֵׁם אָבִי הֵם לִי לְעֵדוּת׃
\v 26 \vp כו\vp* רַק אַתֶּם לֹא תַאֲמִינוּ כִּי לֹא מִצֹּאנִי אַתֶּם כַּאֲשֶׁר אָמַרְתִּי לָכֶם׃
\v 27 \vp כז\vp* צֹאנִי שֹׁמְעוֹת אֶת־קֹלִי וַאֲנִי יֹדֵעַ אֹתָן וְהֵנָּה הֹלְכוֹת אַחֲרָי׃
\v 28 \vp כח\vp* וְחַיֵּי עוֹלָם אֶתֵּן לָהֶן לֹא תֹאבַדְנָה לָנֶצַח וְלֹא יַחֲטֹף אֹתָן אִישׁ מִיָּדִי׃
\v 29 \vp כט\vp* אָבִי אֲשֶׁר נְתָנָן לִי אַדִּיר הוּא מִכֹּל וְאֵין אִישׁ אֲשֶׁר־יוּכַל לַחֲטֹף אֶתְהֶן מִיַּד הָאָב׃
\v 30 \vp ל\vp* וַאֲנִי וְהָאָב אֶחָד׃
\v 31 \vp לא\vp* וַיּוֹסִיפוּ הַיְּהוּדִים וַיִּשְׂאוּ אֲבָנִים לְסָקְלוֹ׃
\v 32 \vp לב\vp* וַיַּעַן אֹתָם יֵשׁוּעַ הֵן מַעֲשִׂים רַבִּים טוֹבִים הֶרְאֵיתִי לָכֶם מֵאֵת הָאָב עַל־אֵי־זֶה מִן־הַמַּעֲשִׂים הָאֵלֶּה תִּסְקְלֻנִי׃
\v 33 \vp לג\vp* וַיַּעֲנוּ אֹתוֹ הַיְּהוּדִים לֵאמֹר עַל־מַעֲשֶׂה טוֹב לֹא נִסְקְלֶךָ כִּי אִם־עַל־חִלּוּל הַשֵּׁם בַּאֲשֶׁר כִּי אָדָם אַתָּה וְהִנְּךָ אֹמֵר לְנַפְשְׁךָ אֱלֹהִים אָתָּה׃
\v 34 \vp לד\vp* וַיַּעַן אֹתָם יֵשׁוּעַ הֲלֹא כָתוּב בְּתוֹרַתְכֶם אֲנִי אָמַרְתִּי אֱלֹהִים אַתֶּם׃
\v 35 \vp לה\vp* וְעַתָּה אִם־אֲנָשִׁים נִקְרְאוּ אֱלֹהִים אֲשֶׁר תּוֹרַת הָאֱלֹהִים אִתָּם וּדְבַר הַכָּתוּב אֵין לְהָשִׁיב׃
\v 36 \vp לו\vp* אֵיךְ תֹּאמְרוּן עַל־זֶה אֲשֶׁר קִדְּשׁוֹ הָאָב וַיִּשְׁלָחֵהוּ בָאָרֶץ מְגַדֵּף אָתָּה יַעַן אָמַרְתִּי בֶּן־הָאֱלֹהִים אָנִי׃
\v 37 \vp לז\vp* אִם־לֹא עָשִׂיתִי אֶת־מַעֲשֵׂי אָבִי לֹא תַאֲמִינוּ לִי׃
\v 38 \vp לח\vp* וְאִם־עֲשִׂיתִים אַף כִּי לֹא־אֲבִיתֶם לְהַאֲמִין בִּי הַאֲמִינוּ בְּמַעֲשֵׂי יָדָי לְמַעַן תֵּדְעוּ וְתַאֲמִינוּ כִּי הָאָב בִּי וַאֲנִי בָּאָב׃
\v 39 \vp לט\vp* וַיּוֹסִיפוּ וַיְבַקְשׁוּ לְתָפְשׂוֹ אַךְ הוּא נִמְלַט מִיָּדָם׃
\v 40 \vp מ\vp* וַיֵּצֵא וַיָּשָׁב אֶל־עֵבֶר הַיַּרְדֵּן אֶל־הַמָּקוֹם אֲשֶׁר יוֹחָנָן הָיָה מְטַבֵּל שָׁם בַּתְּחִלָּה וַיֵּשֶׁב שָׁם׃
\v 41 \vp מא\vp* וַיָּבֹאוּ אֵלָיו רַבִּים וַיֹּאמְרוּ הִנֵּה יוֹחָנָן לֹא־נָתַן מוֹפֵת אֲבָל כָּל־אֲשֶׁר דִּבֶּר עַל־הָאִישׁ הַזֶּה אֱמֶת הוּא׃
\v 42 \vp מב\vp* וַיַּאֲמִינוּ־בוֹ רַבִּים בַּמָּקוֹם הַהוּא׃
\c 11
\cp יא
\cl פרק יא
\p 
\v 1 \vp א\vp* וַיְהִי אִישׁ חֹלֶה וּשְׁמוֹ אֶלְעָזָר מִבֵּית־עַנְיָה מְקוֹם מוֹשַׁב מִרְיָם וּמַרְתָא אֲחוֹתָהּ׃
\v 2 \vp ב\vp* הִיא מִרְיָם אֲשֶׁר מָשְׁחָה אֶת־הָאָדוֹן בְּשֶׁמֶן רֹקֵחַ וּבְשַׂעֲרֹתֶיהָ נִגְּבָה אֶת־רַגְלָיו וְאֶלְעָזָר הוּא אָחִיהָ אֲשֶׁר חָלָה׃
\v 3 \vp ג\vp* וַתִּשְׁלַחְנָה הָאֲחָיוֹת אֵלָיו לֵאמֹר אֲדֹנִי הִנֵּה זֶה אֲשֶׁר נַפְשְׁךָ אֲהֵבַתְהוּ חֹלֶה הוּא׃
\v 4 \vp ד\vp* וַיִשְׁמַע יֵשׁוּעַ וַיֹּאמַר הַמַּחֲלָה הַזֹּאת לֹא לַמָּוֶת כִּי אִם־לִכְבוֹד הָאֱלֹהִים לְמַעַן יִכָּבֶד־בָּהּ בֶּן־הָאֱלֹהִים׃
\v 5 \vp ה\vp* וְיֵשׁוּעַ אָהַב אֶת־מַרְתָא וְאֶת־אֲחוֹתָהּ וְאֶת־אֶלְעָזָר׃
\v 6 \vp ו\vp* וַיְהִי בְּשָׁמְעוֹ כִּי חָלָה וַיִּתְמַהְמַהּ וַיֵּשֶׁב יוֹמַיִם בַּמָּקוֹם אֲשֶׁר־הוּא שָׁם׃
\v 7 \vp ז\vp* וְאַחֲרֵי־כֵן אָמַר לְתַלְמִידָיו לְכוּ וְנָשׁוּבָה אֶל־אֶרֶץ יְהוּדָה׃
\v 8 \vp ח\vp* וַיֹּאמְרוּ אֵלָיו תַּלְמִידָיו רַבֵּנוּ הֲלֹא זֶה עַתָּה בִּקְשׁוּ הַיְּהוּדִים לִסְקָלְךָ וְאַתָּה עוֹד תָּשׁוּב שָׁמָּה׃
\v 9 \vp ט\vp* וַיַּעַן יֵשׁוּעַ הֲלֹא שְׁתֵּים־עֶשְׂרֵה שָׁעוֹת בַּיּוֹם אִישׁ הַהֹלֵךְ בַּיּוֹם לֹא יִכָּשֵׁל כִּי יִרְאֶה אוֹר הָעוֹלָם הַזֶּה׃
\v 10 \vp י\vp* אֲבָל הַהֹלֵךְ בַּלַּיְלָה יִכָּשֵׁל כִּי הָאוֹר אֵינֶנּוּ־בוֹ׃
\v 11 \vp יא\vp* וְאַחֲרֵי דַבְּרוֹ כָזֹאת אָמַר אֲלֵיהֶם אֶלְעָזָר יְדִידֵנוּ יָשֵׁן וַאֲנִי הֹלֵךְ לְהָעִיר אֹתוֹ מִשְּׁנָתוֹ׃
\v 12 \vp יב\vp* וַיַּעֲנוּ תַלְמִידָיו אֲדֹנִי אִם־יָשֵׁן הוּא שְׁנָתוֹ תַחֲלִימֵהוּ וָחָי׃
\v 13 \vp יג\vp* וְיֵשׁוּעַ דִּבֶּר כֵּן עַל־מוֹתוֹ וְהֵם חָשְׁבוּ כִּי עַל־מְנוּחָתוֹ בַּשֵּׁנָה הוּא מְדַבֵּר׃
\v 14 \vp יד\vp* אָז אָמַר אֲלֵיהֶם יֵשׁוּעַ בְּשָׂפָה בְרוּרָה אֶלְעָזָר מֵת׃
\v 15 \vp טו\vp* וַאֲנִי שָׂמֵחַ לְמַעַנְכֶם כִּי לֹא־הָיִיתִי שָׁמָּה לְבַעֲבוּר תַּאֲמִינוּ אַךְ נֵלְכָה־נָּא אֵלָיו׃
\v 16 \vp טז\vp* וַיֹּאמֶר תּוֹמָא הַנִּקְרָא דִידוּמוֹס אֶל־חֲבֵרָיו הַתַּלְמִידִים נֵלְכָה־נָּא גַּם־אֲנַחְנוּ וְנָמוּתָה עִמּוֹ׃
\v 17 \vp יז\vp* וַיָּבֹא יֵשׁוּעַ וַיִּמְצָא כִּי זֶה כְבָר אַרְבָּעָה יָמִים שֹׁכֵב בַּקָּבֶר׃
\v 18 \vp יח\vp* וּבֵית־עַנְיָה קְרֹבָה לִירוּשָׁלָיִם כַּחֲמֵשׁ עֶשְׂרֵה מַעֲנוֹת צֶמֶד שָׂדֶה׃
\v 19 \vp יט\vp* וִיהוּדִים רַבִּים בָּאוּ אֶל־מַרְתָא וּמִרְיָם לְנַחֲמָן עַל־אֲחִיהֶן׃
\v 20 \vp כ\vp* וַיְהִי כִּשְׁמֹעַ מַרְתָא כִּי יֵשׁוּעַ בָּא וַתֵּצֵא לִקְרָאתוֹ וּמִרְיָם יֹשֶׁבֶת בַּבָּיִת׃
\v 21 \vp כא\vp* וַתֹּאמֶר מַרְתָא אֶל־יֵשׁוּעַ אֲדֹנִי לוּ הָיִיתָ פֹּה עִמָּנוּ וְלֹא־מֵת אָחִי׃
\v 22 \vp כב\vp* וְגַם־עַתָּה יָדַעְתִּי כִּי כָל־אֲשֶׁר תִּשְׁאַל מֵאֵת הָאֱלֹהִים כֵּן יִתֵּן לְךָ הָאֱלֹהִים׃
\v 23 \vp כג\vp* וַיֹּאמֶר אֵלֶיהָ יֵשׁוּעַ הֲלֹא יָקוּם אָחִיךְ׃
\v 24 \vp כד\vp* וַתֹּאמֶר אֵלָיו מַרְתָא יָדַעְתִּי כִּי יָקוּם בְּיוֹם הַתְּקוּמָה בַּיּוֹם הָאַחֲרוֹן׃
\v 25 \vp כה\vp* וַיֹּאמֶר אֵלֶיהָ יֵשׁוּעַ אֲנֹכִי הַתְּקוּמָה וְהַחַיִּים הַמַּאֲמִין בִּי אַף כִּי־הוּא מֵת יָקוּם וָחָי׃
\v 26 \vp כו\vp* וְכָל־חַי אֲשֶׁר יַאֲמִין־בִּי לֹא יָמוּת לְעוֹלָם הֲתַאֲמִינִי זֹאת אָתְּ׃
\v 27 \vp כז\vp* וַתֹּאמֶר אֵלָיו הֵן אֲדֹנִי הֵן אֲנֹכִי הֶאֱמַנְתִּי כִּי־אַתָּה הוּא הַמָּשִׁיחַ בֶּן־הָאֱלֹהִים הַבָּא אֶל־הָעוֹלָם׃
\v 28 \vp כח\vp* וּבְדַבְּרָהּ כָּזֹאת הָלְכָה וְקָרְאָה לְמִרְיָם אֲחוֹתָהּ בַּסֵּתֶר לֵאמֹר הִנֵּה בָּא הָרַבִּי וְהוּא קֹרֵא לָךְ׃
\v 29 \vp כט\vp* וַתִּשְׁמַע וַתָּקָם כְּרֶגַע וַתָּבֹא אֵלָיו׃
\v 30 \vp ל\vp* וְיֵשׁוּעַ טֶרֶם יָבֹא אֶל־הַכְּפָר כִּי אִם־עוֹדֶנּוּ עֹמֵד בַּמָּקוֹם אֲשֶׁר פָּגְשָׁה־בּוֹ מַרְתָא׃
\v 31 \vp לא\vp* וְהַיְּהוּדִים אֲשֶׁר־הָיוּ אִתָּהּ בַּבַּיִת לְנַחֲמָהּ בִּרְאוֹתָם כִּי־קָמָה מִרְיָם וְיָצְאָה פִתְאֹם הָלְכוּ אַחֲרֶיהָ בְּחָשְׁבָם כִּי־לִבְכּוֹת אֶל־הַקֶּבֶר הִיא הֹלָכֶת׃
\v 32 \vp לב\vp* וּמִרְיָם בָּאָה אֶל־הָמָּקוֹם אֲשֶׁר יֵשׁוּעַ עֹמֵד שָׁם וַתִּרְאֵהוּ וַתִּפֹּל לְרַגְלָיו וַתֹּאמֶר לוֹ אֲדֹנִי לוּ הָיִיתָ פֹּה עִמָּנוּ וְלֹא־מֵת אָחִי׃
\v 33 \vp לג\vp* כִּרְאוֹת יֵשׁוּעַ אֹתָהּ בֹּכִיָּה וְאֶת־הַיְּהוּדִים בֹּכִים עִמָּהּ וַיֵּמַר רוּחוֹ בְּקִרְבּוֹ וַיִּסָּעֵר לִבּוֹ׃
\v 34 \vp לד\vp* וַיֹּאמֶר אָן קְבַרְתֶּם אֹתוֹ וַיֹּאמְרוּ אֵלָיו בֹּא אֲדֹנֵינוּ וּרְאֵה׃
\v 35 \vp לה\vp* וַיֵּבְךְ יֵשׁוּעַ׃
\v 36 \vp לו\vp* וַיֹּאמְרוּ הַיְּהוּדִים רְאוּ מַה־נִּפְלָאָה לּוֹ אַהֲבָתוֹ׃
\v 37 \vp לז\vp* וְיֵשׁ מֵהֶם אָמְוּ הַהוּא אֲשֶׁר פָּקַח עֵינֵי הָעִוֵּר לֹא יָכֹל לַעֲצֹר גַּם אֶת־זֶה מִמָּוֶת׃
\v 38 \vp לח\vp* וְיֵשׁוּעַ בְּמַר נַפְשׁוֹ בָּא אֶל־הַקָּבֶר וְהוּא מְעָרָה וְאֶבֶן שׂוּמָה עַל־פִּיהָ׃
\v 39 \vp לט\vp* וַיֹּאמֶר יֵשׁוּעַ גֹּלּוּ אֶת־הָאָבֶן וַתֹּאמֶר אֵלָיו מַרְתָא אֲחוֹת הַמֵּת אֲדֹנִי הִנֵּה הוּא נִבְאָשׁ כִּי־זֶה לוֹ יָמִים אַרְבָּעָה׃
\v 40 \vp מ\vp* וַיֹּאמֶר אֵלֶיהָ יֵשׁוּעַ הֲלֹא אָמַרְתִּי לָךְ אִם־תַּאֲמִינִי אָז תִּרְאִי אֶת־כְּבוֹד הָאֱלֹהִים׃
\v 41 \vp מא\vp* וַיָּגֹלּוּ אֶת־הָאֶבֶן אֲשֶׁר הַמֵּת הוּשַׂם שָׁם וְיֵשׁוּעַ נָשָׂא אֶת־עֵינָיו לַמָּרוֹם וַיֹּאמַר אוֹדְךָ אָבִי כִּי עֲנִיתָנִי׃
\v 42 \vp מב\vp* וַאֲנִי יָדַעְתִּי כִּי מִדֵּי אֲדַבֵּר אַתָּה תַעֲנֶה אֶפֶס בַּעֲבוּר הָעָם הָעֹמֵד עָלַי דִּבַּרְתִּי כֵן לְבַעֲבוּר יַאֲמִינוּ כִּי אַתָּה שְׁלַחְתָּנִי׃
\v 43 \vp מג\vp* כְּכַלֹּתוֹ לְדַבֵּר כֵּן וַיִּקְרָא בְקוֹל גָּדוֹל אֶלְעָזָר עוּרָה וָצֵאָה׃
\v 44 \vp מד\vp* וַיֵּצֵא הַמֵּת וְיָדָיו וְרַגְלָיו אֲסוּרוֹת בְּתַכְרִיכִין וּפָנָיו קְשׁוּרִים בְּמִטְפָּחַת וַיֹּאמֶר יֵשׁוּעַ אֲלֵיהֶם הַתִּירֻהוּ וּתְנוּ לוֹ לָלָכֶת׃
\v 45 \vp מה\vp* וְרַבִּים מִן־הַיְּהוּדִים אֲשֶׁר בָּאוּ אֶל־מִרְיָם כִּרְאוֹתָם אֶת־אֲשֶׁר עָשָׂה יֵשׁוּעַ וַיַּאֲמִינוּ־בוֹ׃
\v 46 \vp מו\vp* וּמִקְצוֹתָם הָלְכוּ אֶל־הַפְּרוּשִׁים וַיַּגִּידוּ לָהֶם אֶת־אֲשֶׁר עָשָׂה יֵשׁוּעַ׃
\v 47 \vp מז\vp* וַיַּקְהִילוּ רָאשֵׁי הַכֹּהֲנִים וְהַפְּרוּשִׁים אֶת־הַסַּנְהֶדְרִין וַיֹּאמְרוּ מַה־נַּעֲשֶׂה הֲלֹא הָאִישׁ הַזֶּה עֹשֶׂה מוֹפְתִים רַבִּים׃
\v 48 \vp מח\vp* וְאִם־נֶחְדַּל מִמֶּנּוּ כַּיּוֹם הֲלֹא כֻלָּם יַאֲמִינוּ־בוֹ וּבָאוּ הָרוֹמִיִּים וְלָקְחוּ אֶת־מְקוֹמֵנוּ וְאֶת־עַמֵּנוּ׃
\v 49 \vp מט\vp* וְאֶחָד מֵהֶם קַיָּפָא שְׁמוֹ אֲשֶׁר הָיָה כֹהֵן גָּדוֹל בַּשָּׁנָה הַהִיא אָמַר אֲלֵיהֶם אַתֶּם לֹא־תָבִינוּ דָבָר׃
\v 50 \vp נ\vp* וְגַם לֹא־תַשְּׂכִּילוּ כִּי טוֹב לָכֶם אֲשֶׁר יָמוּת אִישׁ אֶחָד בְּעַד הָעָם מֵאָבְדַן הָעָם כֻּלּוֹ׃
\v 51 \vp נא\vp* וְלֹא מִלִּבּוֹ דִּבֶּר כָּזֹאת כִּי אִם־בִּהְיוֹתוֹ כֹּהֵן גָּדוֹל בַּשָּׁנָה הַהִיא נִבָּא בְפִיו כִּי־יֵשׁוּעַ יָמוּת בְּעַד הָעָם׃
\v 52 \vp נב\vp* וְלֹא־לְבַד בְּעַד הָעָם כִּי אִם־גַּם־לְקַבֵּץ אֶת־בְּנֵי הָאֱלֹהִים הַנְּפֹצִים וְהָיוּ לַאֲחָדִים׃
\v 53 \vp נג\vp* וּמִן־הַיּוֹם הַהוּא נוֹעֲצוּ עָלָיו יַחְדָּו לַהֲמִיתוֹ׃
\v 54 \vp נד\vp* וְעַל־כֵּן לֹא־הִתְהַלֵּךְ יֵשׁוּעַ עוֹד בֵּין הַיְּהוּדִים בְּגָלוּי כִּי אִם־נָטָה מִשָּׁם עַד־הַכִּכָּר הַקְּרוֹבָה לַמִּדְבָּר אֶל־עִיר וּשְׁמָהּ אֶפְרָיִם וַיָּגָר־שָׁם עִם־תַּלְמִידָיו׃
\v 55 \vp נה\vp* וַיִּקְרַב חַג־הַפֶּסַח לַיְּהוּדִים וְרַבִּים מִן־הָאָרֶץ עָלוּ יְרוּשָׁלַיְמָה לִפְנֵי הַפֶּסַח לְהִתְקַדֵּשׁ שָׁמָּה׃
\v 56 \vp נו\vp* וַיְבַקְשׁוּ אֶת־יֵשׁוּעַ וַיֹּאמְרוּ אִישׁ אֶל־רֵעֵהוּ הָעֹמְדִים בְּבֵית הַמִּקְדָּשׁ מַה־יֶּהְגֶּה לִבְּכֶם הַאִם לֹא־יָבֹא אֶל־הֶחָג׃
\v 57 \vp נז\vp* וְרָאשֵׁי הַכֹּהֲנִים וְהַפְּרוּשִׁים נָתְנוּ פְקֻדָּה כִּי אִם־יֵדַע אִישׁ אֶת־מְקוֹמוֹ אַיּוֹ יָבֹא וְיַגִּיד לְמַעַן יִתְפְּשֻׂהוּ׃
\c 12
\cp יב
\cl פרק יב
\p 
\v 1 \vp א\vp* וְשֵׁשֶׁת יָמִים לִפְנֵי חַג־הַפֶּסַח בָּא יֵשׁוּעַ אֶל־בֵּית־עַנְיָה וְשָׁם אֶלְעָזָר הַמֵּת אֲשֶׁר הֶחֱיָה מִן־הַמֵּתִים׃
\v 2 \vp ב\vp* וַיַּעֲשׂוּ־לוֹ שָׁם מִשְׁתֶּה בָּעָרֶב וּמַרְתָא מְשָׁרַת אֹתוֹ וְאֶלְעָזָר הָיָה אֶחָד מִן־הַיֹּשְׁבִים אֶל־הַשֻּׁלְחָן׃
\v 3 \vp ג\vp* וַתִּקַּח מִרְיָם מִרְקַחַת נֵרְדְּ זַךְ וִיקַר־עֵרֶךְ מְאֹד לִטְרָא אַחַת מִשְׁקָלָהּ וַתִּמְשַׁח אֶת־רַגְלֵי יֵשׁוּעַ וּבְשַׂעֲרֹתֶיהָ נִגְּבָה אֶת־רַגְלָיו וְהַבַּיִת מָלֵא רֵיחַ הַמִּרְקָחַת׃
\v 4 \vp ד\vp* וְאֶחָד מִתַּלְמִידָיו הוּא יְהוּדָה בֶּן־שִׁמְעוֹן אִישׁ־קְרִיּוֹת אֲשֶׁר אַחֲרֵי־כֵן הִסְגִּירוֹ אָמַר לֵאמֹר׃
\v 5 \vp ה\vp* עַל־מֶה לֹא־תִמָּכֵר הַמִּרְקַחַת הַזֹּאת בִּשְׁלֹשׁ מֵאוֹת דִּינָר לָתֵת לָעֲנִיִּים׃
\v 6 \vp ו\vp* וְהוּא דִּבֶּר כָזֹאת לֹא מִדַּאֲגָתוֹ לָעֲנִיִּים רַק יַעַן כִּי־גַנָּב הָיָה וַאֲרוֹן אוֹצָרָם בְּיָדוֹ וְנָשָׂא מֵאֲשֶׁר נָתוּן בּוֹ׃
\v 7 \vp ז\vp* וַיֹּאמֶר יֵשׁוּעַ הַנַּח־לָהּ לְיוֹם קְבֻרָתִי הֵכִינָה זֹאת׃
\v 8 \vp ח\vp* כִּי אֶת־הָעֲנִיִּים תִּמְצְאוּ לִפְנֵיכֶם תָּמִיד וְאֹתִי לֹא תִמְצְאוּ תָּמִיד לִפְנֵיכֶם׃
\v 9 \vp ט\vp* וְרַבִּים מִן־הַיְּהוּדִים שָׁמְעוּ כִּי הוּא שָׁם וַיָּבֹאוּ לֹא־בַעֲבוּר יֵשׁוּעַ לְבַדּוֹ כִּי אִם־גַּם־לִרְאוֹת אֶת־אֶלְעָזָר אֲשֶׁר הֶחֱיָה מִן־הַמֵּתִים׃
\v 10 \vp י\vp* וַיִּוָּעֲצוּ רָאשֵׁי הַכֹּהֲנִים לַהֲרֹג גַּם אֶת־אֶלְעָזָר׃
\v 11 \vp יא\vp* כִּי בִּגְלָלוֹ אָזְלוּ יְהוּדִים רַבִּים וַיַּאֲמִינוּ בְּיֵשׁוּעַ׃
\v 12 \vp יב\vp* וַיְהִי מִמָּחֳרָת כִּשְׁמֹעַ רַבִּים מִן־הָעָם מִן־עוֹלֵי הָרֶגֶל כִּי יֵשׁוּעַ בָּא יְרוּשָׁלָיְמָה׃
\v 13 \vp יג\vp* וַיִּקְחוּ כַפּוֹת תְּמָרִים בְּיָדָם וַיֵּצְאוּ לִקְרָאתוֹ וַיָּרִיעוּ הוֹשַׁע־נָא בָּרוּךְ הַבָּא בְּשֵׁם יְהוָֹה מֶלֶךְ יִשְׂרָאֵל׃
\v 14 \vp יד\vp* וַיִּמְצָא יֵשׁוּעַ עַיִר וַיִּרְכַּב עָלָיו כַּכָּתוּב׃
\v 15 \vp טו\vp* אַל־תִּירְאִי בַּת־צִיּוֹן הִנֵּה מַלְכֵּךְ יָבוֹא לָךְ רֹכֵב עַל־עַיִר בֶּן־אֲתֹנוֹת׃
\v 16 \vp טז\vp* וְכָל־זֹאת לֹא־הֵבִינוּ תַלְמִידָיו בַּתְּחִילָּה אַךְ כַּאֲשֶׁר לֻקַּח יֵשׁוּעַ אַחַר כָּבוֹד זָכְרוּ אָז כִּי־כֹה כָּתוּב עָלָיו וְכֹה גַם־עֲשׂוּ לוֹ׃
\v 17 \vp יז\vp* וְהָעָם אֲשֶׁר הָיוּ אִתּוֹ הֵעִידוּ בְפִיהֶם כִּי קָרָא אֶת־אֶלְעָזָר מִן־קִבְרוֹ וַיְחַיֵּהוּ מִן־הַמֵּתִים׃
\v 18 \vp יח\vp* וְעַל־כֵּן יָצְאוּ הָעָם לִקְרָאתוֹ אַחֲרֵי שָׁמְעָם כִּי עָשָׂה אֶת־הָאוֹת הַזֶּה׃
\v 19 \vp יט\vp* וְהַפְּרוּשִׁים אָמְרוּ אִישׁ אֶל־אָחִיו הַרְאִיתֶם כִּי יְדֵיכֶם לֹא תַעֲשֶׂינָה תּוּשִׁיָּה וְאַחֲרָיו כָּל־אָדָם יִמְשֹׁךְ׃
\v 20 \vp כ\vp* וּבְתוֹךְ עוֹלֵי הָרֶגֶל לְהִשְׁתַּחֲוֹת נִמְצְאוּ גַּם־יְוָנִים׃
\v 21 \vp כא\vp* וְהֵם בָּאוּ אֶל־פִּילִפּוֹס אִישׁ בֵּית־צַיְדָה מִן־הַגָּלִיל וַיְחַלּוּ אֶת־פָּנָיו לֵאמֹר אֲדֹנֵינוּ חֲפֵצִים אֲנַחְנוּ לִרְאוֹת אֶת־יֵשׁוּעַ׃
\v 22 \vp כב\vp* וַיָּבֹא פִילִפּוֹס וַיַּגֵּד לְאַנְדְּרָי וְאַנְדְּרַי וּפִילִיפּוֹס הִגִּידוּ הַדָּבָר לְיֵשׁוּעַ׃
\v 23 \vp כג\vp* וַיַּעַן אֹתָם יֵשׁוּעַ לֵאמֹר הִנֵּה בָּא הַמּוֹעֵד וּבֶן־הָאָדָם נֶאְדָּר יִהְיֶה בִּכְבוֹדוֹ׃
\v 24 \vp כד\vp* אָמֵן אָמֵן אֲנִי אֹמֵר לָכֶם גַּרְגַּר דָּגָן אִם לֹא־יִפֹּל וָמֵת בְּתוֹךְ הָאָרֶץ יִשָּׁאֵר לְבַדּוֹ וְאִם יָמוּת יוֹצִיא זֶרַע רָב׃
\v 25 \vp כה\vp* הָאֹהֵב אֶת־נַפְשׁוֹ תִּכָּרֶת־לוֹ וְהַשּׂנֵא אֶת־נַפְשׁוֹ בָּעוֹלָם הַזֶּה שְׁמֻרָה תִהְיֶה־לּוֹ לְחַיֵּי עַד׃
\v 26 \vp כו\vp* מִי־הֶחָפֵץ לְשָׁרְתֵנִי יֵלֵךְ בְּעִקְּבוֹתַי וּבַאֲשֶׁר אֶהְיֶה אֲנִי שָׁם יִהְיֶה גַם־מְשָׁרְתִי וְכִי אִישׁ יְשָׁרֵת אֹתִי אֹתוֹ יְכַבֵּד הָאָב׃
\v 27 \vp כז\vp* עַתָּה נִבְהֲלָה נַפְשִׁי וּמָה אֹמַר הַצִּילֵנִי אָבִי מִן־עֵת הַמּוֹעֵד הַזֶּה אַךְ עַל־כֵּן בָּאתִי לַמּוֹעֵד הַזֶּה׃
\v 28 \vp כח\vp* אָבִי גַּדֵּל כְּבוֹד שְׁמֶךָ וְהִנֵּה קוֹל עֹנֶה מִשָּׁמַיִם גִּדַּלְתִּי כְבוֹדוֹ וְגַם־אֲגַדְּלֶנּוּ עוֹד׃
\v 29 \vp כט\vp* וְהָעָם הָעֹמְדִים שָׁם שָׁמְעוּ וְאָמְרוּ קוֹל רַעַם הוּא וְיֵשׁ מֵהֶם אָמְרוּ כִּי מַלְאָךְ דִּבֶּר אֵלָיו׃
\v 30 \vp ל\vp* וַיַּעַן יֵשׁוּעַ וַיֹּאמַר לֹא לְמַעֲנִי הָיָה הַקּוֹל הַזֶּה כִּי אִם־לְמַעַנְכֶם׃
\v 31 \vp לא\vp* עַתָּה נֶחֱרַץ מִשְׁפַּט הָעוֹלָם הַזֶּה וְשַׂר הָעוֹלָם הַזֶּה נִדְחַף לְמַדְחֵפוֹת׃
\v 32 \vp לב\vp* וַאֲנִי כַּאֲשֶׁר אֶנָּשֵׂא מֵעַל־הָאָרֶץ אֶמְשֹׁךְ כָּל־אָדָם אַחֲרָי׃
\v 33 \vp לג\vp* וְהַמִּלִּין הָאֵלֶּה הוֹצִיא כִּי יִרְזְמוּן בְּאֵיזֶה מָוֶת יָמוּת׃
\v 34 \vp לד\vp* וַיַּעֲנוּ אֹתוֹ הָעָם שָׁמַעְנוּ מִפִּי הַתּוֹרָה כִּי הַמָּשִׁיחַ חַי הוּא לְעוֹלָם וְאֵיךְ תֹּאמַר אַתָּה כִּי נָשׂא יִנָּשֵׂא בֶּן־הָאָדָם מִי הוּא זֶה בֶּן־הָאָדָם׃
\v 35 \vp לה\vp* וַיֹּאמֶר אֲלֵיהֶם יֵשׁוּעַ עוֹד מְעַט מִזְעָר יָאִיר הָאוֹר לְעֵינֵיכֶם לְכוּ לְאוֹרוֹ בְּהִמָּצְאוֹ פֶּן־יְכַסֶּה אֶתְכֶם הַחֹשֶׁךְ וְהַהֹלֵךְ בַּחֹשֶׁךְ יֵלֵךְ אֶל־אֲשֶׁר לֹא יֵדָע׃
\v 36 \vp לו\vp* הַאֲמִינוּ בָאוֹר כָּל־עוֹד הוּא זוֹרֵחַ עֲלֵיכֶם לְמַעַן תִּהְיוּ בְנֵי הָאוֹר וְאַחֲרֵי הַדְּבָרִים הָאֵלֶּה הָלַךְ יֵשׁוּעַ וַיִּסָּתֵר מִפְּנֵיהֶם׃
\v 37 \vp לז\vp* וְהֵם לֹא הֶאֱמִינוּ לוֹ אַף כִּי־עָשָׂה אֹתוֹת רַבִּים לִפְנֵיהֶם׃
\v 38 \vp לח\vp* לְמַלֹּאת דְּבַר יְשַׁעְיָהוּ הַנָּבִיא אֲשֶׁר אָמָר יְהוָֹה מִי הֶאֱמִין לִשְׁמֻעָתֵנוּ וּזְרוֹעַ יְהוָֹה עַל־מִי נִגְלָתָה׃
\v 39 \vp לט\vp* וְעַל־כֵּן לְהַאֲמִין לֹא יָכֹלוּ כִּי יְשַׁעְיָהוּ הוֹסִיף לֵאמֹר׃
\v 40 \vp מ\vp* הֵשַׁע עֵינֵיהֶם וְהִשְׁמִין אֶת־לְבָבָם פֶּן־יִרְאוּ בְעֵינֵיהֶם וּלְבָבָם יָבִין וְשָׁבוּ וְרִפֵּאתִי לָהֶם׃
\v 41 \vp מא\vp* הַדְּבָרִים הָאֵלֵּה דִּבֵּר יְשַׁעְיָהוּ בַּחֲזוֹתוֹ אֶת־כְּבוֹדוֹ וַיִּנָּבֵא עָלָיו׃
\v 42 \vp מב\vp* אוּלָם גַּם מִן־הַשָּׂרִים הֶאֱמִינוּ־בוֹ רַבִּים אַךְ בַּעֲבוּר הַפְּרוּשִׁים לֹא הוֹדוּ בְפִיהֶם לְבִלְתִּי יְנֻדּוּ מִתּוֹךְ קְהָלָם׃
\v 43 \vp מג\vp* כִּי כְּבוֹד אֲנָשִׁים יָקָר בְּעֵינֵיהֶם מִכְּבוֹד אֱלֹהִים׃
\v 44 \vp מד\vp* וַיִּקְרָא יֵשׁוּעַ וַיֹּאמַר הַמַּאֲמִין בִּי לֹא־בִי הוּא מַאֲמִין כִּי אִם־בְּשֹׁלְחִי׃
\v 45 \vp מה\vp* וְהָרֹאֶה אֹתִי הוּא רֹאֶה אֶת־שֹׁלְחִי׃
\v 46 \vp מו\vp* וַאֲנִי לְאוֹר בָּאתִי אֶל־הָעוֹלָם אֲשֶׁר כָּל־הַמַּאֲמִין בִּי לֹא יִשְׁכֹּן בַּחֲשֵׁכָה׃
\v 47 \vp מז\vp* וְאִישׁ כִּי יִשְׁמַע אֶת־דְּבָרַי וְלֹא יִשְׁמְרֵם אֲנִי לֹא אֶשְׁפֹּט אֹתוֹ כִּי לֹא־לִשְׁפֹּט אֶת־הָעוֹלָם בָּאתִי כִּי אִם־לְהוֹשִׁיעַ אֶת־הָעוֹלָם׃
\v 48 \vp מח\vp* וְכִי יִמְאַס בִּי אִישׁ וְלֹא יִקַּח אֲמָרַי יֵשׁ שֹׁפֵט אֲשֶׁר־יִשְׁפְּטֶנּוּ הַדָּבָר אֲשֶׁר דִּבַּרְתִּי הוּא יִשְׁפְּטֶנּוּ בַּיּוֹם הָאַחֲרוֹן׃
\v 49 \vp מט\vp* כִּי אֲנִי לֹא מִלִּבִּי דִבַּרְתִּי כִי אִם־הָאָב אֲשֶׁר שְׁלָחַנִי הוּא צִוַּנִי אֶת־אֲשֶׁר אֹמַר וְאֶת־אֲשֶׁר אֲדַבֵּר׃
\v 50 \vp נ\vp* וְיָדַעְתִּי כִּי חַיֵּי עוֹלָם מִצְוָתוֹ וְעַל־כֵּן אֶת־אֲשֶׁר אָמַר אֵלַי הָאָב לְדַבֵּר אֹתוֹ אֶשְׁמֹר לְדַבֵּר׃
\c 13
\cp יג
\cl פרק יג
\p 
\v 1 \vp א\vp* וַיְהִי לִפְנֵי חַג־הַפֶּסַח וַיֵּדַע יֵשׁוּעַ כִּי בָא זְמָנּוֹ לַעֲלוֹת מִן־הָאָרֶץ אֶל־הָאָב וְאֶת־בְּחִירָיו אֲשֶׁר אָהֵב בָּאָרֶץ מֵאָז כֵּן אֲהֵבָם עַד־אַחֲרִית׃
\v 2 \vp ב\vp* אַחֲרֵי סִיוּם סְעוּדַת הַמִּצְוָה וְאַחֲרֵי אֲשֶׁר נָתַן הַשָּׂטָן בְּלֵב יְהוּדָה בֶּן־שִׁמְעוֹן אִישׁ־קְרִיּוֹת לְהַסְגִּיר אֹתוֹ׃
\v 3 \vp ג\vp* וַיֵּדַע יֵשׁוּעַ כִּי הָאָב נָתַן בְּיָדוֹ אֶת־כֹּל וְכִי הוּא מֵאֵת אֱלֹהִים יָצָא וְאֶל־אֱלֹהִים יָשׁוּב׃
\v 4 \vp ד\vp* וַיָּקָם מֵעַל הַשֻּׁלְחָן וַיִּפְשֹׁט אֶת־בְּגָדָיו וַיַּחְגֹּר מִטְפַּחַת עַל־מָתְנָיו׃
\v 5 \vp ה\vp* וְאַחַר יָצַק מַיִם בְּכִיּוֹר וַיָּחֶל לִרְחֹץ רַגְלֵי תַלְמִידָיו וְלִמְחוֹתָן בַּמִּטְפַּחַת אֲשֶׁר־הוּא חָגוּר בָּהּ׃
\v 6 \vp ו\vp* וַיָּבֹא אֶל־שִׁמְעוֹן פֶּטְרוֹס וְהוּא אָמַר אֵלָיו הַאַתָּה אֲדֹנִי תִּרְחַץ אֶת־רַגְלָי׃
\v 7 \vp ז\vp* וַיַּעַן יֵשׁוּעַ וַיֹּאמֶר אֵלָיו אֵת אֲשֶׁר אֲנִי עֹשֶׂה בָזֶה לֹא־תֵדַע עַתָּה אַךְ אַחֲרֵי־כֵן תַּשְׂכִּיל׃
\v 8 \vp ח\vp* וַיֹּאמֶר אֵלָיו פֶּטְרוֹס לֹא־תִרְחַץ רַגְלַי לְעוֹלָם וַיַּעַן אֹתוֹ יֵשׁוּעַ אִם־לֹא אֶרְחָצְךָ אֵין־לְךָ חֵלֶק עִמָּדִי׃
\v 9 \vp ט\vp* וַיֹּאמֶר אֵלָיו שִׁמְעוֹן פֶּטְרוֹס בִּי אֲדֹנִי לֹא לְבַד אֶת־רַגְלַי כִּי אִם־גַּם אֶת־יָדַי וְאֶת־רֹאשִׁי׃
\v 10 \vp י\vp* וַיֹּאמֶר אֵלָיו יֵשׁוּעַ הַמְרֻחָץ אֵין־לוֹ לִרְחֹץ עוֹד זוּלָתִי אֶת־רַגְלָיו כִּי כֻלּוֹ טָהוֹר הוּא וְאַתֶּם הִנְּכֶם טְהוֹרִים אֲבָל לֹא כֻלְּכֶם׃
\v 11 \vp יא\vp* כִּי יָדַע אֹתוֹ אֲשֶׁר יַסְגִּירֶנּוּ עַל־כֵּן אָמַר לֹא כֻלְּכֶם טְהוֹרִים׃
\v 12 \vp יב\vp* וְאַחֲרֵי אֲשֶׁר רָחַץ אֶת־רַגְלֵיהֶם וְלָבַשׁ אֶת־בְּגָדָיו שָׁב וַיֵּשֶׁב וַיֹּאמֶר אֲלֵיהֶם הַיְדַעְתֶּם מַה־זֹּאת עָשִׂיתִי לָכֶם׃
\v 13 \vp יג\vp* אַתֶּם קֹרִאים־לִי רַבִּי וְאָדוֹן וְהֵיטַבְתֶּם לִקְרֹא־לִי כֵן כִּי־אֲנִי הוּא׃
\v 14 \vp יד\vp* וְעַל־כֵּן אִם־אֲנִי הָאָדוֹן וְהָרַבִּי רָחַצְתִּי אֶת־רַגְלֵיכֶם עֲלֵיכֶם גַּם־אַתֶּם לִרְחֹץ אִישׁ אִישׁ אֶת־רַגְלֵי אָחִיו׃
\v 15 \vp טו\vp* כִּי אֲנִי הוּא מוֹפֶתְכֶם לְמַעַן תַּעֲשׂוּן גַּם־אַתֶּם כַּאֲשֶׁר עָשִׂיתִי לָכֶם אָנִי׃
\v 16 \vp טז\vp* אָמֵן אָמֵן אֲנִי אֹמֵר לָכֶם אֵין הָעֶבֶד גָּדוֹל מֵאֲדֹנָיו וְאֵין הַשָּׁלִיחַ רַב מִשֹּׁלְחוֹ׃
\v 17 \vp יז\vp* וְאִם־יְדַעְתֶּם זֹאת אַשְׁרֵיכֶם אִם־כֵּן תַּעֲשׂוּן׃
\v 18 \vp יח\vp* וְלֹא עַל־כֻּלְּכֶם דִּבַּרְתִּי כֵן כִּי יָדַעְתִּי אֶת־אֲשֶׁר בָּחַרְתִּי־בָם אַךְ לְמַעַן יָקוּם הַכָּתוּב אוֹכֵל לַחְמִי הִגְדִּיל עָלַי עֲקֵב׃
\v 19 \vp יט\vp* מֵעַתָּה אֲנִי מַגִּיד לָכֶם דָּבָר טֶרֶם בֹּאוֹ לְמַעַן תַּאֲמִינוּ אַחֲרֵי בֹאוֹ כִּי אֲנִי הוּא׃
\v 20 \vp כ\vp* אָמֵן אָמֵן אֲנִי אֹמֵר לָכֶם הַמְקַבֵּל אֶת־מִי אֲשֶׁר אֶשְׁלַח פָּנַי הוּא מְקַבֵּל וְהַמְקַבֵּל פָּנַי הוּא מְקַבֵּל פְּנֵי שֹׁלְחִי׃
\v 21 \vp כא\vp* וַיְהִי כְּדַבֵּר יֵשׁוּעַ אֶת־הַדְּבָרִים הָאֵלֶּה וַתִּפָּעֶם רוּחוֹ בְקִרְבּוֹ וַיַּגֵּד לָהֶם לֵאמֹר אָמֵן אָמֵן אֲנִי אֹמֵר לָכֶם כִּי אֶחָד מִכֶּם יַסְגִּיר אֹתִי׃
\v 22 \vp כב\vp* וַיִּתְרָאוּ הַתַּלְמִידִים פָּנִים בְּפָנִים כִּי לֹא יָדְעוּ עַל־מִי דִבֵּר׃
\v 23 \vp כג\vp* וְאֶחָד מִתַּלְמִידָיו אֲשֶׁר יֵשׁוּעַ אֲהֵבוֹ נִשְׁעַן עַל־חֵיקוֹ׃
\v 24 \vp כד\vp* וַיִּרְמָז־לוֹ שִׁמְעוֹן פֶּטְרוֹס וַיֹּאמֶר אֵלָיו אֱמָר־נָא מִי־הוּא זֶה אֲשֶׁר דִּבֶּר עָלָיו׃
\v 25 \vp כה\vp* וַיִפֹּל עַל־צַוְּארֵי יֵשׁוּעַ וַיֹּאמֶר אֵלָיו אֲדֹנִי מִי הוּא׃
\v 26 \vp כו\vp* וַיַּעַן יֵשׁוּעַ זֶה הוּא אֲשֶׁר אֶטְבָּל־לוֹ פְרוּסָה וּנְתַתִּיהָ לּוֹ וַיִּטְבֹּל אֶת־הַפְּרוּסָה וַיִּקָחֶהָ וַיִּתְּנֶהָ אֶל־יְהוּדָה בֶּן־שִׁמְעוֹן אִישׁ־קְרִיּוֹת׃
\v 27 \vp כז\vp* וְאַחֲרֵי אָכְלוֹ אֶת־הַפְּרוּסָה בָּא הַשָּׂטָן אֶל־קִרְבּוֹ וַיֹּאמֶר אֵלָיו יֵשׁוּעַ אֵת אֲשֶׁר־תַּעֲשֶׂה מַהֵר וַעֲשֵׂה׃
\v 28 \vp כח\vp* וְלֹא־יָדַע אִישׁ מִן־הַיֹּשְׁבִים שָׁם בַּמְּסִיבָּה עַל־מֶה דִבֶּר אֵלָיו כָּזֹאת׃
\v 29 \vp כט\vp* כִּי יֵשׁ אֲשֶׁר חָשְׁבוּ בִּהְיוֹת צְרוֹר הַכֶּסֶף בְּיַד יְהוּדָה עַל־כֵּן אָמַר אֵלָיו יֵשׁוּעַ קְנֵה־נָא אֶת־אֲשֶׁר יֶחְסַר לָנוּ לֶחָג אוֹ תְּנָא דָבָר לַעֲנִיִּים׃
\v 30 \vp ל\vp* וְהוּא בְּקַחְתּוֹ אֶת־הַפְּרוּסָה אֶל־פִּיו יָצָא פִתְאֹם וַיְהִי לָיְלָה׃
\v 31 \vp לא\vp* וַיְהִי כַּאֲשֶׁר יָצָא וַיֹּאמֶר יֵשׁוּעַ עַתָּה נֶאְדָּר בֶּן־הָאָדָם בְּכָבוֹד וּבוֹ אֱלֹהִים בְּכָבוֹד נֶאְדָּר׃
\v 32 \vp לב\vp* וֵאלֹהִים הוּא יַאְדִּיר אֹתוֹ בִּכְבוֹדוֹ וְגַם־יָחִישׁ לְהַאְדִּירוֹ׃
\v 33 \vp לג\vp* בָּנַי הַיְקָרִים עוֹד־מְעַט מִזְעָר אֵשֵׁב עִמָּכֶם וְאַתֶּם תְּבַקְשׁוּנִי וְכַאֲשֶׁר אָמַרְתִּי אֶל־הַיְּהוּדִים כִּי אֶל־אֲשֶׁר אֲנִי הֹלֵךְ לֹא תוּכְלוּ לָבֹא שָׁמָּה כֵּן אֲנִי אֹמֵר עַתָּה גַּם־אֲלֵיכֶם׃
\v 34 \vp לד\vp* הִנֵּה מִצְוָה חֲדָשָׁה אֲנִי נֹתֵן לָכֶם לְאַהֲבָה אִישׁ אֶת־רֵעֵהוּ כַּאֲשֶׁר אָהַבְתִי אֶתְכֶם כֵּן גַּם־אַתֶּם אִישׁ אֶת־רֵעֵהוּ תֶּאֱהָבוּן׃
\v 35 \vp לה\vp* בָּזֹאת יֵדְעוּ כֻלָּם כִּי תַּלְמִידַי אַתֶּם אִם אַהֲבַת רֵעִים תָּלִין בֵּינֵיכֶם׃
\v 36 \vp לו\vp* וַיֹּאמֶר אֵלָיו שִׁמְעוֹן פֶּטְרוֹס אֲדֹנִי אָנָה אַתָּה הֹלֵךְ וַיַּעַן יֵשׁוּעַ אֶל־אֲשֶׁר אֲנִי הֹלֵךְ לֹא־תוּכַל לָלֶכֶת אַחֲרַי כַּיּוֹם אַךְ הִנֵּה יָמִים בָּאִים וְהָלַכְתָּ אַחֲרָי׃
\v 37 \vp לז\vp* וַיֹּאמֶר אֵלָיו פֶטְרוֹס אֲדֹנִי עַל־מֶה לֹא־אוּכַל לָלֶכֶת אַחֲרֶיךָ כַּיּוֹם הֲלֹא אֶת־נַפְשִׁי אֶתֵּן בַּעֲדֶךָ׃
\v 38 \vp לח\vp* וַיַּעַן יֵשׁוּעַ הֲתִתֵּן אֶת־נַפְשְׁךָ בַּעֲדִי אָמֵן אָמֵן אֲנִי אֹמֵר לָךְ לֹא יִקְרָא הַתַּרְנְגֹל עַד־אֲשֶׁר תְּכַחֶשׁ־בִּי שָׁלֹשׁ פְּעָמִים׃
\c 14
\cp יד
\cl פרק יד
\p 
\v 1 \vp א\vp* אַל־יֵחַת לִבְּכֶם הַאֲמִינוּ בֵאלֹהִים וּכְמוֹ־כֵן הַאֲמִינוּ בִּי׃
\v 2 \vp ב\vp* מְעוֹנוֹת רַבּוֹת נִמְצָאוֹת בְּבֵית אָבִי כִּי לוּלֵא כֵן הָיִיתִי מַגִּיד לָכֶם וַאֲנִי הֹלֵךְ לְהָכִין לָכֶם מָקוֹם׃
\v 3 \vp ג\vp* וְאַחֲרֵי אֲשֶׁר אֵלֵךְ וְאָכִין מָקוֹם לָכֶם שׁוֹב אָשׁוּב וְלָקַחְתִּי אֶתְכֶם אֵלָי לְמַעַן תִּהְיוּ עִמִּי שָׁם בַּאֲשֶׁר אֶהְיֶה׃
\v 4 \vp ד\vp* וְאַתֶּם יְדַעְתֶּם אָנָא אֲנִי הֹלֵךְ וְגַם אֶת־הַדֶּרֶךְ יְדַעְתֶּם׃
\v 5 \vp ה\vp* וַיֹּאמֶר אֵלָיו תּוֹמָא אֲדֹנִי לֹא יָדַעְנוּ אָנָה אַתָּה הֹלֵךְ וְאֵיכָה נֵדַע אֶת־הַדָּרֶךְ׃
\v 6 \vp ו\vp* וַיֹּאמֶר אֵלָיו יֵשׁוּעַ אָנֹכִי הַדֶּרֶךְ וְהָאֱמֶת וְהַחַיִּים וְאִישׁ לֹא־יָבֹא אֶל־הָאָב בִּלְתִּי עַל־יָדִי׃
\v 7 \vp ז\vp* לוּ אֹתִי יְדַעְתֶּם יְדַעְתֶּם גַּם אֶת־אָבִי וּמֵעַתָּה יְדַעְתֶּם אֹתוֹ וְגַם־רְאִיתֶם אֹתוֹ׃
\v 8 \vp ח\vp* וַיֹּאמֶר אֵלָיו פִילִפּוֹס אֲדֹנִי הַרְאֵנוּ נָא אֶת־הָאָב וְרַב לָנוּ׃
\v 9 \vp ט\vp* וַיֹּאמֶר אֵלָיו יֵשׁוּעַ הֲלֹא יָמִים רַבִּים הָיִיתִי עִמָּכֶם הֲטֶרֶם תֵּדַע אֹתִי פִּילִפּוֹס הָרֹאֶה אֹתִי רֹאֶה אֶת־הָאָב וְלָמָּה־זֶּה תֹאמַר הַרְאֵנוּ אֶת־הָאָב׃
\v 10 \vp י\vp* הֲכִי לֹא תַאֲמִין כִּי אֲנִי בָאָב וְהָאָב בִּי הַדְּבָרִים אֲשֶׁר אֲנִי דֹבֵר אֲלֵיכֶם לֹא־מִלִּבִּי אֲנִי דֹבֵר כִּי הָאָב הַשֹּׁכֵן בִּי הוּא פֹעֵל בִּי פְּעֻלּוֹתָיו׃
\v 11 \vp יא\vp* הַאֲמִינוּ לִי כִּי־אֲנִי בָאָב וְהָאָב בִּי וְאִם־לֹא הַאֲמִינוּ לִי בִּגְלַל הַפְּעֻלּוֹת הָאֵלֶּה׃
\v 12 \vp יב\vp* אָמֵן אָמֵן אֲנִי אֹמֵר לָכֶם הַמַּאֲמִין בִּי אֶת־הַמַּעֲשִׂים אֲשֶׁר אֲנִי עֹשֶׂה יַעֲשֶׂה גַם־הוּא וּגְדֹלוֹת מֵאֵלֶּה יַעֲשֶׂה כִּי אֶל־אָבִי אָנֹכִי הֹלֵךְ׃
\v 13 \vp יג\vp* וְכָל־אֲשֶׁר תִּשְׁאֲלוּ בִשְׁמִי אֹתוֹ אֶעֱשֶׂה לְבַעֲבוּר יִגְדַּל כְּבוֹד הָאָב בִּבְנוֹ׃
\v 14 \vp יד\vp* כָּל־דָּבָר אֲשֶׁר תִּשְׁאֲלוּ בִשְׁמִי אֲנִי אֶעֱשֶׂנּוּ׃
\v 15 \vp טו\vp* אִם־אֲהַבְתֶּם אֹתִי אֶת־מְִֹצתַי תִּשְׁמֹרוּ׃
\v 16 \vp טז\vp* וַאֲנִי אֲחַלֶּה פְנֵי הָאָב וְיִתֵּן לָכֶם מֵלִיץ אַחֵר אֲשֶׁר־יִשְׁכֹּן אִתְּכֶם עֲדֵי־עַד׃
\v 17 \vp יז\vp* הֲלֹא הוּא רוּחַ הָאֱמֶת אֲשֶׁר הָעוֹלָם לֹא־יָכֹל לְקַבְּלוֹ בַּאֲשֶׁר לֹא יִרְאֶנּוּ וְלֹא יֵדָעֶנּוּ וְאַתֶּם יְדַעְתֶּם אֹתוֹ כִּי הוּא שֹׁכֵן אִתְּכֶם וְאַף־הָיֹה יִהְיֶה בְּתוֹכְכֶם׃
\v 18 \vp יח\vp* וַאֲנִי לֹא אֶעֱזָבְכֶם יְתוֹמִים כִּי בֹא אָבֹא אֲלֵיכֶם׃
\v 19 \vp יט\vp* עוֹד מְעַט מִזְעָר וְהָעוֹלָם לֹא יוֹסִיף לִרְאוֹת אֹתִי וְאַתֶּם תִּרְאֻנִי כִּי־אֲנִי חַי וְכֵן גַּם־אַתֶּם תִּחְיוּן׃
\v 20 \vp כ\vp* בַּיּוֹם הַהוּא תֵּדְעוּ כִּי־אֲנִי בְאָבִי וְאַתֶּם בִּי וַאֲנִי בָכֶם׃
\v 21 \vp כא\vp* מִי אֲשֶׁר מִצְוֹתַי אִתּוֹ וְשֹׁמֵר לַעֲשׂוֹתָן זֶה הוּא אֲשֶׁר יֶאֱהָבַנִי וְאֹהֲבִי אָהוּב לְאָבִי וַאֲנִי אֹהֲבֵהוּ וְאֵלָיו אֶתְוַדָּע׃
\v 22 \vp כב\vp* וַיֹּאמֶר אֵלָיו יְהוּדָה לֹא אִישׁ־קְרִיּוֹת וְאֵיכָה אֲדֹנִי תִּקְרֶינָה כָאֵלֶּה כִּי תָבֹא לְהִתְוַדַּע אֵלֵינוּ וְלֹא לָעוֹלָם׃
\v 23 \vp כג\vp* וַיַּעַן יֵשׁוּעַ וַיֹּאמֶר אֵלָיו אִישׁ כִּי יֶאֱהָבַנִי יִשְׁמֹר אֶת־דְּבָרַי וְאָבִי יֶאֱהַב אֹתוֹ וְאֵלָיו נָבֹא וְשָׁכַנּוּ אִתּוֹ׃
\v 24 \vp כד\vp* וְאִישׁ אֲשֶׁר לֹא יֶאֱהָבַנִי הוּא לֹא יִשְׁמֹר אֶת־דְּבָרָי וְהַדְּבָרִים אֲשֶׁר שְׁמַעְתֶּם לֹא מִלִּבִּי יָצָאוּ כִּי אִם־מִפִּי הָאָב אֲשֶׁר שְׁלָחָנִי׃
\v 25 \vp כה\vp* אֶת־אֵלֶּה דִּבַּרְתִּי אֲלֵיכֶם בְּעוֹד שִׁבְתִּי עִמָּכֶם׃
\v 26 \vp כו\vp* וְהַמֵּלִיץ הוּא רוּחַ הַקֹּדֶשׁ אֲשֶׁר־יִשְׁלָחֵהוּ הָאָב בִּשְׁמִי יְלַמֶּדְכֶם אֶת־כֹּל וְאָז תִּזְכְּרוּ כֹּל אֲשֶׁר־הִגַּדְתִּי לָכֶם׃
\v 27 \vp כז\vp* וְעַתָּה שָׁלוֹם אֲנִי מַנִּיחַ לָכֶם אֶת־שְׁלוֹמִי אֲנִי נֹתֵן לָכֶם לֹא כַאַשֶׁר יִתֵּן הָעוֹלָם אֲנִי נֹתֵן לָכֶם אַל־יִרְגַּז לִבְּכֶם וְאַל־יֵחָת׃
\v 28 \vp כח\vp* הֲלֹא שְׁמַעְתֶּם אֵת אֲשֶׁר־אָמַרְתִּי אֲלֵיכֶם כִּי אֵלֵךְ מִכֶּם וְעוֹד אֲשׁוּב אֲלֵיכֶם לוּ אֲהַבְתֶּם אֹתִי הֱיִיתֶם שְׂמֵחִים בְּאָמְרִי לָכֶם כִּי־הֹלֵךְ אֲנִי אֶל־הָאָב כִּי הָאָב גָּדוֹל מִמֶּנִּי׃
\v 29 \vp כט\vp* וְעַתָּה הִגַּדְתִּי לָכֶם הַדָּבָר טֶרֶם בֹּאוֹ לְבַעֲבוּר תַּאֲמִינוּ אַחֲרֵי בֹאוֹ׃
\v 30 \vp ל\vp* וַאֲנִי לֹא־אוּכַל עוֹד לְהַרְבּוֹת אֲמָרִים עִמָּכֶם מִפְּנֵי שַׂר־הָעוֹלָם אֲשֶׁר יָבֹא וְהוּא אֵין־לוֹ חֵלֶק בִּי כָּל־מְאוּמָה׃
\v 31 \vp לא\vp* רַק לְבַעֲבוּר יֵדַע הָעוֹלָם כִּי אֲנִי אֹהֵב אֶת־הָאָב וְעֹשֶׂה אֲנִי כְּכֹל אֲשֶׁר צִוַּנִי הָאָב לְכוּ וְנֵלְכָה מִזֶּה׃
\c 15
\cp טו
\cl פרק טו
\p 
\v 1 \vp א\vp* אָנֹכִי הַגֶּפֶן גֶּפֶן אֱמֶת וְאָבִי הַכֹּרֵם׃
\v 2 \vp ב\vp* כָּל־זְמוֹרָה מִמֶּנִּי אֲשֶׁר לֹא תַעֲשֶׂה עֲנָבִים יְכְרְתֶנָּה וַאֲשֶׁר תַּעֲשֶׂה עֲנָבִים יְקַיְמֶנָּה לְהַרְבּוֹת אֶת־פִּרְיָהּ׃
\v 3 \vp ג\vp* וְאַתֶּם זַכִּים הִנְּכֶם כַּיּוֹם עַל־פִּי דְבָרַי אֲשֶׁר דִּבַּרְתִּי אֲלֵיכֶם׃
\v 4 \vp ד\vp* הֱיוּ דְבֵקִים בִּי וַאֲנִי בָכֶם כִּי כַּאֲשֶׁר הַזְּמֹרָה פְּרִי בַל־תַּעֲשֶׂה מֵאֵלֶיהָ אִם־לֹא דָבְקָה בַגָּפֶן כֵּן גַּם־אַתֶּם אִם־לֹא תִדְבְּקוּן בִּי׃
\v 5 \vp ה\vp* אֲנֹכִי הַגֶּפֶן וְאַתֶּם הַזְּמֹרוֹת הַדָּבֵק בִּי וְאֲנִי בוֹ הוּא יְשַׁוֶּה רֹב פֶּרִי כִּי בִּלְעָדַי לֹא תוּכְלוּ עֲשׂוֹת מְאוּמָה׃
\v 6 \vp ו\vp* מִי אֲשֶׁר לֹא יִדְבַּק בִי יַשְׁלִיכֻהוּ כְּנֵצֶר אֲשֶׁר יִיבָשׁ וּמְקֹשֵׁשׁ יְקֹשְׁשֶׁנּוּ וּנְתָנוֹ לָאֵשׁ וְהָיָה לְבָעֵר׃
\v 7 \vp ז\vp* אִם־בִּי אַתֶּם דְּבֵקִים וּדְבָרַי שְׁמֻרִים בָּכֶם תִּשְׁאֲלוּ וְיֵעָשֶׂה לָכֶם כְּכָל־מִשְׁאֲלוֹת לִבְּכֶם׃
\v 8 \vp ח\vp* בְּזֹאת יִגְדַּל כְּבוֹד אָבִי כִּי־תַעֲשׂוּ רֹב פֶּרִי וִהְיִיתֶם לִי לְתַלְמִידִים׃
\v 9 \vp ט\vp* כַּאֲשֶׁר אֲהַב אֹתִי הָאָב כֵּן אָהַבְתִּי אֶתְכֶם חֲסוּ בְאַהֲבָתִי תָּמִיד׃
\v 10 \vp י\vp* אִם אֶת־מִצְוֹתַי תִּשְׁמְרוּ תֶּחֱסוּ בְאַהֲבָתִי תָּמִיד כַּאֲשֶׁר גַּם־אֲנֹכִי מִצְוֹת אָבִי שָׁמַרְתִּי וְאֶחֱסֶה בְאַהֲבָתוֹ תָּמִיד׃
\v 11 \vp יא\vp* אֶת־הַדְּבָרִים הָאֵלֶה דִּבַּרְתִּי אֲלֵיכֶם לְבַעֲבוּר תִּהְיֶה שִׂמְחָתִי עֲלֵיכֶם וְשִׂמְחַתְכֶם תִּמָּלֵא נַפְשֵׁכֶם׃
\v 12 \vp יב\vp* וְזֹאת הִיא מְצְוָתִי לְאַהֲבָה אִישׁ אֶת־אָחִיו כַּאֲשֶׁר אֲנֹכִי אָהַבְתִּי אֶתְכֶם׃
\v 13 \vp יג\vp* אֵין לְאִישׁ אַהֲבָה רַבָּה מֵאֲשֶׁר אִם יִתֵּן אֶת־נַפְשׁוֹ בְּעַד יְדִידָיו׃
\v 14 \vp יד\vp* וְאַתֶּם יְדִידַי הִנְּכֶם רַק אִם־תַּעֲשׂוּ אֵת אֲשֶׁר־אֲנֹכִי מְצַוֶּה אֶתְכֶם׃
\v 15 \vp טו\vp* לֹא עוֹד עֲבָדִים אֶקְרָא לָכֶם כִּי הָעֶבֶד אֵינֶנּוּ יֹדֵעַ אֶת־אֲשֶׁר אֲדֹנָיו עֹשֶׂה אַךְ לָכֶם קָרָאתִי יְדִידַי כִּי הוֹדַעְתִּי אֶתְכֶם כֹּל אֲשֶׁר שָׁמַעְתִּי מִפִּי אָבִי׃
\v 16 \vp טז\vp* לֹא אַתֶּם בְּחַרְתֶּם בִּי רַק־אֲנִי בָּחַרְתִּי בָּכֶם וַאֲנִי מִנִּיתִי אֶתְכֶם לָלֶכֶת וְלַעֲשׂוֹת פֶּרִי וּפֶרְיְכֶם יַעֲמֹד לָעַד וְכָל־דָּבָר אֲשֶׁר תִּשְׁאֲלוּ מֵאֵת הָאָב בִּשְׁמִי אֹתוֹ יִתֵּן לָכֶם׃
\v 17 \vp יז\vp* וְזֹאת הִיא הַמִּצְוָה אֲשֶׁר אֲנִי מְצַוֶּה אֶתְכֶם כִּי אִישׁ אֶת־רֵעֵהוּ תֶּאֱהָבוּן׃
\v 18 \vp יח\vp* אִם־הָעוֹלָם יִשְׂנָא אֶתְכֶם הֲלֹא יְדַעְתֶּם כִּי אֹתִי שָׂנֵא לִפְנֵיכֶם׃
\v 19 \vp יט\vp* לוּ הֱיִיתֶם מִן־הָעוֹלָם הָעוֹלָם יֶאֱהַב אֵת אֲשֶׁר־לוֹ אַךְ יַעַן כִּי־אֵין אַתֶּם מִן־הָעוֹלָם וַאֲנִי בָחַרְתִּי בָכֶם מִן־הָעוֹלָם עַל־כֵּן יִשְׂנָא אֶתְכֶם הָעוֹלָם׃
\v 20 \vp כ\vp* זִכְרוּ אֶת־הַדָּבָר אֲשֶׁר אָמַרְתִּי לָכֶם הָעֶבֶד אֵינֶנּוּ גָדוֹל מֵאֲדֹנָיו אִם־רָדְפוּ אֹתִי גַּם־אֶתְכֶם יִרְדֹּפוּ אִם־שָׁמְרוּ אֶת־דְּבָרַי גַּם אֶת־דִּבְרֵיכֶם יִשְׁמֹרוּ׃
\v 21 \vp כא\vp* אֲבָל כָּל־אֵלֶּה יַעֲשׂוּ לָכֶם בַּעֲבוּר שְׁמִי כִּי אֵינָם יֹדְעִים אֶת־שֹׁלְחִי׃
\v 22 \vp כב\vp* לוּלֵי בָאתִי וְהִגַּדְתִּי לָהֶם לֹא הוּשַׁת עֲלֵיהֶם חֵטְא אֲבָל עַתָּה אֵין מַעֲנֶה בְּפִיהֶם עַל־חַטֹּאתָם׃
\v 23 \vp כג\vp* הַשּׂנֵא אֹתִי הוּא שׂנֵא גַּם־אֶת־אָבִי׃
\v 24 \vp כד\vp* לוּלֵי עָשִׂיתִי לִפְנֵיהֶם הַמַּעֲשִׂים אֲשֶׁר לֹא עֲשָׂה אִישׁ אַחֵר לֹא־הוּשַׁת עֲלֵיהֶם חֵטְא אֲבָל עַתָּה רָאוּ אֶת־מַעֲשַׂי וַיִּשְׂנְאוּ גַם־אֹתִי וְגַם אֶת־אָבִי׃
\v 25 \vp כה\vp* אַךְ לְמַלֹּאת הַדָּבָר הַכָּתוּב בְּתוֹרָתָם וְשִׂינְאַת חִנָּם שְׂנֵאוּנִי׃
\v 26 \vp כו\vp* אַךְ כַּאֲשֶׁר יָבֹא הַמֵּלִיץ אֲשֶׁר אֶשְׁלָחֶנּוּ אֲלֵיכֶם מֵאֵת הָאָב הֲלֹא הוּא רוּחַ הָאֱמֶת הַיֹּצֵא מִמְּקוֹר הָאָב הוּא יָעֶד־לִי׃
\v 27 \vp כז\vp* וְגַם־אַתֶּם תָּעִידוּ לִי כִּי הֱיִיתֶם עִמָּדִי מֵרֹאשׁ׃
\c 16
\cp טז
\cl פרק טז
\p 
\v 1 \vp א\vp* אֶת־אֵלֶּה דִּבַּרְתִּי אֲלֵיכֶם לְמַעַן לֹא תִכָּשֵׁלוּ׃
\v 2 \vp ב\vp* הֵם יְנַדּוּ אֶתְכֶם מִתּוֹךְ הַקָּהָל וְאַף הִגִּיעַ הַזְּמָן אֲשֶׁר כָּל־הֹרֵג אֶתְכֶם יַחֲשֹׁב בְּלִבּוֹ כִּי קָרְבָּן הוּא מַקְרִיב לֵאלֹהִים׃
\v 3 \vp ג\vp* וְאֶת־אֵלֶּה יַעֲשׂוּ לָכֶם כִּי גַּם־אֶת־אָבִי וְגַם־אֹתִי לֹא יָדָעוּ׃
\v 4 \vp ד\vp* וָאַגִּיד לָכֶם אֶת־אֵלֶּה לְמַעַן תִּזְכְּרוּ אֹתָם בְּעִתָּם כִּי אֲנִי הַמְדַבֵּר אֲלֵיכֶם וְלֹא הִקְדַּמְתִּי לְהַגִּיד לָכֶם כָּל־זֶה מֵרֹאשׁ בַּעֲבוּר כִּי הָיִיתִי עִמָּכֶם׃
\v 5 \vp ה\vp* וְעַתָּה הִנְּנִי הֹלֵךְ אֶל־שֹׁלְחִי וְאֵין עוֹד אִישׁ מִכֶּם שֹׁאֵל אֹתִי אָנָה אַתָּה הֹלֵךְ׃
\v 6 \vp ו\vp* רַק לִבְּכֶם מָלֵא עֶצֶב בְּדַבְּרִי אֲלֵיכֶם הַדְּבָרִים הָאֵלֶּה׃
\v 7 \vp ז\vp* אוּלָם אֱמֶת אַגִּיד לָכֶם כִּי טוֹב לָכֶם אֲשֶׁר אֵלֵךְ כִּי אִם־לֹא אֵלֵךְ לֹא־יָבֹא הַמֵּלִיץ אֲלֵיכֶם וְכִי־אֵלֵךְ אֶשְׁלָחֶנּוּ אֲלֵיכֶם׃
\v 8 \vp ח\vp* וְהוּא בְּבֹאוֹ יוֹכַח אֶת־הָעוֹלָם עַל־דְּבַר חֵטְא צְדָקָה וּמִשְׁפָּט׃
\v 9 \vp ט\vp* עַל־חֵטְא עַל־אֲשֶׁר לֹא הֶאֱמִינוּ בִי׃
\v 10 \vp י\vp* עַל־צְדָקָה עַל־כִּי הֹלֵךְ אֲנִי אֶל־אָבִי וְלֹא תִרְאֻנִי עוֹד׃
\v 11 \vp יא\vp* וְעַל־מִשְׁפָּט עַל־כִּי יַרְשִׁיעַ אֶת־שַׂר הָעוֹלָם הַזֶּה בְּהִשָּׁפְטוֹ׃
\v 12 \vp יב\vp* וְעוֹד לִי מִלִּין רַבּוֹת לְהוֹדִיעֲכֶם אַךְ לֹא־תוּכְלוּ שְׂאֵת אוֹתָן כַּיּוֹם׃
\v 13 \vp יג\vp* וְרוּחַ הָאֱמֶת בְּבֹאוֹ יַנְחֶה אֶתְכֶם אֶל־הָאֱמֶת כֻּלָּהּ כִּי לֹא מִלִּבּוֹ יְדַבֵּר כִּי אִם אֶת־אֲשֶׁר יִשְׁמַע יַשְׁמִיעַ וְיַגִּיד אֶת־הָאֹתִיּוֹת לְאָחוֹר׃
\v 14 \vp יד\vp* הוּא יְגַדֵּל כְּבוֹדִי כִּי יִקַּח מִשֶּׁלִּי וְהִגִּיד לָכֶם׃
\v 15 \vp טו\vp* כֹּל אֲשֶׁר לְאָבִי לִי הוּא עַל־כֵּן אָמַרְתִּי מִשֶּׁלִּי יִקַּח וְהִגִּיד לָכֶם׃
\v 16 \vp טז\vp* עוֹד כִּמְעַט רֶגַע וְלֹא תִרְאֻנִי עוֹד וְעוֹד כִּמְעַט רֶגַע וְתִרְאֻנִי כִּי אֲנִי הֹלֵךְ אֶל־אָבִי׃
\v 17 \vp יז\vp* וְיֵשׁ מִתַּלְמִידָיו אֲשֶׁר נִדְבְּרוּ אָז אִישׁ אֶל־רֵעֵהוּ מַה־זֶּה אֲשֶׁר אָמַר אֵלֵינוּ עוֹד כִּמְעַט רֶגַע וְלֹא תִרְאוּנִי וְעוֹד כִּמְעַט רֶגַע וְתִרְאוּנִי וְכִי אֲנִי הֹלֵךְ אֶל־הָאָב׃
\v 18 \vp יח\vp* וַיֹּאמְרוּ מַה־זֶּה כִּמְעַט רֶגַע אֲשֶׁר אָמַר וַאֲנַחְנוּ לֹא נֵדַע מָה הוּא מְדַבֵּר׃
\v 19 \vp יט\vp* וַיַּרְא יֵשׁוּעַ כִּי מְבַקְשִׁים הֵם לִשְׁאֹל אֶת־פִּהוּ וַיֹּאמֶר אֲלֵיהֶם הֲתַחְקְרוּן זֶה אֶת־זֶה עַל כִּי־אָמַרְתִּי עוֹד כִּמְעַט רֶגַע וְלֹא תִרְאֻנִי וְעוֹד כִּמְעַט רֶגַע וְתִרְאֻנִי׃
\v 20 \vp כ\vp* אָמֵן אָמֵן אֲנִי אֹמֵר לָכֶם כִּי אַתֶּם תִּבְכּוּ וְתֵילִילוּ וּבְנֵי הָעוֹלָם יָגִילוּ אַתֶּם תִּתְאַבְּלוּ אַךְ אֶבְלְכֶם יֵהָפֵךְ לְשָׂשׂוֹן׃
\v 21 \vp כא\vp* אִשָּׁה תָּחִיל בַּחֲבָלֶיהָ כִּי בָאָה עִתָּהּ וְאַחֲרֵי אֲשֶׁר הִמְלִיטָה אֶת־הַוָּלָד לֹא־תִזְכֹּר עוֹד חֶבְלָהּ מִשִּׂמְחָתָהּ כִּי־אִישׁ נוֹלַד בָּעוֹלָם׃
\v 22 \vp כב\vp* וְגַם־אַתֶּם מְלֵאִים יָגוֹן כַּיּוֹם אַךְ עוֹד אָשׁוּב אֶרְאֶה אֶתְכֶם וְשָׂשׂ לִבְּכֶם וְשִׂמְחַתְכֶם לֹא־יִקַּח מִכֶּם גָּבֶר׃
\v 23 \vp כג\vp* וּבַיּוֹם הַהוּא לֹא תִשְׁאֲלוּ לִי כָּל־שְׁאֵלָה אָמֵן אָמֵן אֲנִי אֹמֵר לָכֶם אִם תְּבַקְשׁוּ דָבָר מֵאֵת הָאָב יִתֵּן לָכֶם בִּשְׁמִי׃
\v 24 \vp כד\vp* עַד־עַתָּה לֹא־בִקַּשְׁתֶּם דָּבָר בִּשְׁמִי בַּקְּשׁוּ וְתִקְחוּ וְנַפְשְׁכֶם תִּמָּלֵא שִׂמְחָה׃
\v 25 \vp כה\vp* אֶת־אֵלֶּה בִּמְשָׁלִים דִּבַּרְתִּי אֲלֵיכֶם אַךְ הִגִּיעַ הַמּוֹעֵד וְלֹא אֲדַבֵּר אֲלֵיכֶם עוֹד בִּמְשָׁלִים כִּי אִם־בְּמִלִּים בְּרֻרוֹת אַגֵּדְכֶם עַל־דְּבַר הָאָב׃
\v 26 \vp כו\vp* בַּיּוֹם הַהוּא מִשְׁאֲלוֹתֵיכֶם בִּשְׁמִי תִּשְׁאָלוּ וְאֵינֶנִּי אֹמֵר לָכֶם כִּי אֲנִי אַעְתִּיר בַּעַדְכֶם אֶל־הָאָב׃
\v 27 \vp כז\vp* כִּי־הָאָב גַּם־הוּא אֹהֵב אֶתְכֶם עֵקֶב אֲשֶׁר אֲהַבְתֶּם אֹתִי וַתַּאֲמִינוּ כִּי־מֵאֵת הָאָב יָצָאתִי׃
\v 28 \vp כח\vp* יָצָאתִי מֵאֵת הָאָב וּבָאתִי בָעוֹלָם וְעַתָּה אָשׁוּב אֶעֱזֹב אֶת־הָעוֹלָם וְאֵלֶךְ־לִי אֶל־הָאָב׃
\v 29 \vp כט\vp* וַיֹּאמְרוּ תַלְמִידָיו הִנְּךָ מְדַבֵּר עַתָּה בְּמִלִּים בְּרֻרוֹת וְלֹא תַבִּיע מָשָׁל׃
\v 30 \vp ל\vp* עַתָּה יָדַעְנוּ כִּי־אַתָּה יֹדֵעַ כֹּל וְאֵין מַחְסֹר לְךָ אֲשֶׁר יִשְׁאָלְךָ אִישׁ בָּזֹאת נַאֲמִין כִּי מֵאֵת אֱלֹהִים יָצָאתָ׃
\v 31 \vp לא\vp* וַיַּעַן אֹתָם יֵשׁוּעַ הֲכִי תַאֲמִינוּ עָתָּה׃
\v 32 \vp לב\vp* הִנֵּה הַזְּמָן בָּא וּכְבָר הִגִּיעַ כִּי־תָפוּצוּ אִישׁ אִישׁ לִבֵיתוֹ וְאֹתִי תַעַזְבוּ לְבַדִּי אַךְ אֵינֶנִּי לְבַדִּי כִּי אָבִי עִמָּדִי׃
\v 33 \vp לג\vp* וַאֲנִי בַּדְּבָרִים הָאֵלֶּה בָּאתִי לְהַגִּיד לָכֶם כִּי בִי שָׁלוֹם יִהְיֶה־לָכֶם בָּעוֹלָם צָרָה תְּבוֹאַתְכֶם אַךְ־הִתְאַזְּרוּ עֹז אֲנִי נִצַּחְתִּי אֶת־הָעוֹלָם׃
\c 17
\cp יז
\cl פרק יז
\p 
\v 1 \vp א\vp* אֶת־אֵלֶּה דִּבֶּר יֵשׁוּעַ וַיִּשָּׂא עֵינָיו לַמָּרוֹם וַיֹּאמַר אֲבִי גַּדֵּל כְּבוֹד בִּנְךָ כִּי בָא מוֹעֵד וּבִנְךָ יְגַדֵּל כְּבוֹדֶךָ׃
\v 2 \vp ב\vp* כַּאֲשֶׁר אַתָּה תַמְשִׁילֵהוּ בְּכָל־בָשָׂר לָתֵת חַיֵּי עוֹלָם לְכֹל אֲשֶׁר־נָתַתָּה לּוֹ׃
\v 3 \vp ג\vp* וּמַה חַיֵּי עוֹלָם אֲשֶׁר יֵדְעוּ אֹתְךָ כִּי אַתָּה לְבַדְּךָ אֶל־אֱמֶת וְאֶת־יֵשׁוּעַ הַמָּשִׁיחַ אֲשֶׁר שָׁלָחְתָּ׃
\v 4 \vp ד\vp* אֶת־כְּבוֹדְךָ גִּדַּלְתִּי בָאָרֶץ כִּלִּיתִי אֶת־הַמְּלָאכָה אֲשֶׁר נָתַתָּה לִּי לַעֲשׂתָהּ׃
\v 5 \vp ה\vp* וְעַתָּה כַּבְּדֵנִי־נָא עִמְּךָ אָבִי בַּכָּבוֹד אֲשֶׁר הָיָה־לִי עִמְּךָ טֶרֶם נַעֲשׂוּ שָׁמַיִם וָאָרֶץ׃
\v 6 \vp ו\vp* הוֹדַעְתִּי אֶת־שִׁמְךָ לַאֲנָשִׁים אֲשֶׁר אֹתָם נָתַתָּה־לִּי מִן־הָעוֹלָם לְךָ הָיוּ וְאַתָּה נְתַתָּם לִי וְהֵם אִמְרָתְךָ יִנְצֹרוּ׃
\v 7 \vp ז\vp* יֹדְעִים הֵם כַּיּוֹם כִּי־כֻלָּם אֲשֶׁר נָתַתָּה לִּי מֵאִתְּךָ הֵמָּה׃
\v 8 \vp ח\vp* כִּי שַׂמְתִּי לִפְנֵיהֶם אֶת־הַדְּבָרִים אֲשֶׁר שַׂמְתָּ בְּפִי וְהֵם שָׁמְעוּ וַיַּכִּירוּ בֶאֱמֶת כִּי מֵאִתְּךָ יָצָאתִי וַיַּאֲמִינוּ כִּי אַתָּה שְׁלַחְתָּנִי׃
\v 9 \vp ט\vp* וַאֲנִי בַּעֲדָם מַפְגִּיעַ לֹא בְעַד הָעוֹלָם אֶפְגַּע בְּךָ כִּי אִם־בְּעַד אֵלֶּה אֲשֶׁר נָתַתָּה לִּי כִּי־לְךָ הֵמָּה׃
\v 10 \vp י\vp* וְכָל־שֶׁלִּי שֶׁלָּךְ וְשֶׁלָּךְ שֶׁלִּי אֲשֶׁר בָּם אֶתְפָּאָר׃
\v 11 \vp יא\vp* לֹא אֲגוּר עוֹד בָּאָרֶץ וְהֵם גָּרִים בָּאָרֶץ וַאֲנִי בָא אֵלֶיךָ אָבִי קְדֹשִׁי שְׁמֹר בְּשִׁמְךָ אֶת־אֵלֶּה אֲשֶׁר נָתַתָּה לִּי לְמַעַן יִהְיוּ אֶחָד כָּמֹנוּ׃
\v 12 \vp יב\vp* בִּהְיוֹתִי עִמָּהֶם בָּעוֹלָם שָׁמַרְתִּי אֹתָם בִּשְׁמֶךָ כֹּל אֲשֶׁר נָתַתָּה לִּי שָׁמַרְתִּי וְלֹא־אָבַד אֶחָד מֵהֶם זוּלָתִי בֶּן־הָאֲבַדּוֹן לְמַלֹּאת דְּבַר־הַכָּתוּב׃
\v 13 \vp יג\vp* וְעַתָּה הִנְנִי בָא אֵלֶיךָ וְהַדְּבָרִים הָאֵלֶּה דִּבַּרְתִּי בָאָרֶץ לְמַלֹּאת נַפְשָׁם שִׂמְחָתִי׃
\v 14 \vp יד\vp* אֲנִי נָתַתִּי לָהֶם דְּבָרְךָ וְהָעוֹלָם שׂנֵא אֹתָם יַעַן כִּי לֹא מִן־הָעוֹלָם הֵם כַּאֲשֶׁר גַּם־אֲנִי לֹא מִן־הָעוֹלָם אָנִי׃
\v 15 \vp טו\vp* וַאֲנִי אֵינֶנִּי מַפְגִּיעַ בַּעֲדָם כִּי תִקָּחֵם מִן־הָעוֹלָם רַק כִּי אִם־תַּצִּילֵם מִן־הָרָע׃
\v 16 \vp טז\vp* לֹא מִן־הָעוֹלָם הֵם כַּאֲשֶׁר גַּם־אֲנִי לֹא מִן־הָעוֹלָם אָנִי׃
\v 17 \vp יז\vp* קַדֵּשׁ אֹתָם בַּאֲמִתֶּךָ דְּבָרְךָ אֱמֶת׃
\v 18 \vp יח\vp* כַּאֲשֶׁר אַתָּה שְׁלַחְתַּנִי בָעוֹלָם כֵּן אֲנִי שְׁלַחְתִּים בָּעוֹלָם׃
\v 19 \vp יט\vp* וּבַעֲדָם הִקְדַּשְׁתִּי אֶת־נַפְשִׁי וְכֵן גַּם־הֵם אֶת־נַפְשָׁם בֶּאֱמֶת יַקְדִּישׁוּ׃
\v 20 \vp כ\vp* אוּלָם לֹא בְּעַד־אֵלֶּה לְבַדָּם אֲנִי מַעְתִּיר לָךְ כִּי אִם־גַּם־בְּעַד אֵלֶּה אֲשֶׁר יַאֲמִינוּ בִי עַל־פִּי דְבָרָם׃
\v 21 \vp כא\vp* לְמַעַן יִהְיוּ כֻלָּם לְאֶחָד כַּאֲשֶׁר אַתָּה אָבִי בִּי וַאֲנִי בָּךְ כֵּן יִהְיוּ גַם־הֵם בָּנוּ לְבַעֲבוּר יַאֲמִין הָעוֹלָם כִּי אַתָּה שְׁלַחְתָּנִי׃
\v 22 \vp כב\vp* וַאֲנִי נָתַתִּי לָהֶם אֶת־הַכָּבוֹד אֲשֶׁר נָתָתָּה לִּי לְבַעֲבוּר יִהְיוּ לְאֶחָד כַּאֲשֶׁר גַּם אֲנַחְנוּ אֶחָד׃
\v 23 \vp כג\vp* אֲנִי בָּהֶם וְאַתָּה בִּי לְמַעַן יִהְיוּ תַּמִּים בְּאֶחָד וּלְמַעַן יֵדַע הָעוֹלָם כִּי אַתָּה שְׁלַחְתַּנִי וְכִי אָהַבְתָּ אֹתָם כַּאֲשֶׁר אֲהַבְתָּנִי׃
\v 24 \vp כד\vp* וַאֲנִי חָפַצְתִּי אָבִי כִּי אֵלֶּה אֲשֶׁר נָתַתָּה לִּי יִהְיוּ עִמִּי גַּם־הֵם בַּאֲשֶׁר אֶהְיֶה לְמַעַן יִרְאוּ אֶת־כְּבוֹדִי אֲשֶׁר נָתַתָּה לִּי כִּי אָהַבְתָּ אֹתִי טֶרֶם הִוָּסֵד אָרֶץ׃
\v 25 \vp כה\vp* אָבִי הַצַּדִּיק הֵן הָעוֹלָם אֵינֶנּוּ יֹדֵעַ אֹתְךָ וַאֲנִי יְדַעְתִּיךָ וְאֵלֶּה יֹדְעִים כִּי אַתָּה שְׁלַחְתָּנִי׃
\v 26 \vp כו\vp* הוֹדַעְתִּי לָהֶם אֶת־שִׁמְךָ וְכֵן אוֹסִיף לְהוֹדִיעָם לְמַעַן תִּהְיֶה־בָּם הָאַהֲבָה אֲשֶׁר אֲהַבְתָּנִי וְגַם־אֲנִי אֶהְיֶה בְּתוֹכָם׃
\c 18
\cp יח
\cl פרק יח
\p 
\v 1 \vp א\vp* וַיְכַל יֵשׁוּעַ לְדַבֵּר אֶת־הַדְּבָרִים הָאֵלֶּה וַיֵּצֵא עִם־תַּלְמִידָיו אֶל־עֵבֶר לַנַּחַל קִדְרוֹן וַיָּבֹא לַגָּן אֲשֶׁר שָׁם הוּא וְתַלְמִידָיו׃
\v 2 \vp ב\vp* וִיהוּדָה הַמַּסְגִּיר יָדַע אֶת־הַמָּקוֹם הַהוּא כִּי יֵשׁוּעַ וְתַלְמִידָיו פְּעָמִים רַבּוֹת נוֹעֲדוּ שָׁם׃
\v 3 \vp ג\vp* וַיִּקַּח יְהוּדָה אֶת־הַגְּדוּד וְאֶת־הַמְשָׁרְתִים אֲשֶׁר לְרָאשֵׁי הַכֹּהֲנִים וְהַפְּרוּשִׁים וַיָּבֹא שָׁם בְּנֵרוֹת וְלַפִּידִים וּכְלֵי־נָשֶׁק׃
\v 4 \vp ד\vp* וְיֵשׁוּעַ יָדַע אֵת כָּל־אֲשֶׁר יְבֹאֶנּוּ וַיֵּצֵא וַיֹּאמֶר אֲלֵיהֶם אֶת־מִי תְבַקֵּשׁוּן׃
\v 5 \vp ה\vp* וַיַעֲנוּ אֹתוֹ אֶת־יֵשׁוּעַ הַנָּצְרִי וַיֹּאמֶר אֲלֵיהֶם יֵשׁוּעַ אֲנִי הוּא וִיהוּדָה הַמַּסְגִּיר עֹמֵד אֶצְלָם׃
\v 6 \vp ו\vp* וַיְהִי כַּאֲשֶׁר אָמַר אֲלֵיהֶם ישׁוּעַ אֲנִי הוּא וַיִּסֹּגוּ אָחוֹר וַיִּפְּלוּ אָרְצָה׃
\v 7 \vp ז\vp* וַיּוֹסֶף וַיִּשְׁאַל אֹתָם אֶת־מִי תְבַקֵּשׁוּ וַיֹּאמְרוּ אֶת־יֵשׁוּעַ הַנָּצְרִי׃
\v 8 \vp ח\vp* וַיַעַן יֵשׁוּעַ הֲלֹא אָמַרְתִּי לָכֶם כִּי אֲנִי הוּא עַל־כֵּן אִם־אֹתִי תְבַקְשׁוּ הַנִּיחוּ לָאֵלֶּה וְיֵלֵכוּ׃
\v 9 \vp ט\vp* לְהָקִים הַדָּבָר אֲשֶׁר אָמָר מֵאֵלֶּה אֲשֶׁר נָתַתָּה לִּי לֹא־אָבַד לִי אַף־אֶחָד׃
\v 10 \vp י\vp* וְחֶרֶב הָיְתָה בִּידֵי שִׁמְעוֹן פֶּטְרוֹס וַיִּשְׁלֹף אֹתָהּ וַיַּךְ אֶת־עֶבֶד הַכֹּהֵן הַגָּדוֹל וַיְקַצֵּץ אֶת־אָזְנוֹ הַיְמָנִית וְשֵׁם הָעֶבֶד מַלְכוֹס׃
\v 11 \vp יא\vp* וַיֹּאמֶר יֵשׁוּעַ אֶל־פֶּטְרוֹס חָשֵׁב חַרְבְּךָ אֶל־נְדָנָהּ הַאִם אֶת־כּוֹס אֲשֶׁר נָתַן־לִי אָבִי אֲנִי לֹא־אֶשְׁתֶּנָּה׃
\v 12 \vp יב\vp* וְהַגְּדוּד וְשַׂר הָאֶלֶף וּמְשָׁרְתֵי הַיְּהוּדִים תָּפְשׂוּ אָז אֶת־יֵשׁוּעַ וַיַּאַסְרֻהוּ׃
\v 13 \vp יג\vp* וַיֹּלִיכֻהוּ בָרִאשׁוֹנָה אֶל־חָנָן כִּי הוּא הָיָה חֹתֵן קַיָּפָא הַכֹּהֵן הַגָּדוֹל בַּשָּׁנָה הַהִיא׃
\v 14 \vp יד\vp* הוּא קַיָּפָא אֲשֶׁר בַּעֲצָתוֹ לַיְּהוּדִים הִגִּיד כִּי טוֹב אֲשֶׁר יֹאבַד אִישׁ־אֶחָד בְּעַד כָּל־הָעָם׃
\v 15 \vp טו\vp* וְשִׁמְעוֹן פֶּטְרוֹס וְתַלְמִיד אַחֵר הָלְכוּ אַחֲרֵי יֵשׁוּעַ וְהַתַּלְמִיד הַהוּא נוֹדָע הָיָה לַכֹּהֵן הַגָּדוֹל וַיָּבֹא עִם־יֵשׁוּעַ לַחֲצַר הַכֹּהֵן הַגָּדוֹל׃
\v 16 \vp טז\vp* וּפֶטְרוֹס עָמַד מִחוּץ לַשָּׁעַר וַיֵּצֵא הַתַּלְמִיד הָאַחֵר הַנּוֹדָע לַכֹּהֵן הַגָּדוֹל וַיְדַבֵּר אֶל־הַשֹּׁעֶרֶת וַיָּבֵא אֶת־פֶּטָרוֹס הַבָּיְתָה׃
\v 17 \vp יז\vp* וַתֹּאמֶר הָאָמָה הַשֹּׁעֶרֶת אֶל־פֶּטְרוֹס הֲלֹא גַם־אַתָּה מִתַּלְמִידֵי הָאִישׁ הַזֶּה וַיֹּאמֶר לֹא אָנִי׃
\v 18 \vp יח\vp* וְשָׁם עָמְדוּ הָעֲבָדִים וְהַמְשָׁרְתִים וַיְבַעֲרוּ גֶחָלִים לְהִתְחַמֵּם מִפְּנֵי הַקֹּר וַיַּעֲמֹד גַּם־פֶּטְרוֹס עִמָּהֶם וַיִּתְחַמָּם׃
\v 19 \vp יט\vp* וַיִּשְׁאַל הַכֹּהֵן הַגָּדוֹל אֶת־יֵשׁוּעַ עַל־תַּלְמִידָיו וְעַל־תּוֹרָתוֹ׃
\v 20 \vp כ\vp* וַיַּעַן אֹתוֹ יֵשׁוּעַ אֲנֹכִי לְעֵין הַשֶּׁמֶשׁ דִּבַּרְתִּי אֶל־הָעוֹלָם וְתָמִיד לִמַּדְתִּי בְּבֵית־הַכְּנֵסֶת וּבְבֵית הַמִּקְדָּשׁ אֲשֶׁר שָׁם כָּל־הַיְּהוּדִים נִקְהָלִים וְלֹא־דִבַּרְתִּי דָבָר בַּסָּתֶר׃
\v 21 \vp כא\vp* וְלָמָּה־זֶּה תִּשְׁאָלֵנִי שְׁאַל־נָא אֶת־הָאֲנָשִׁים אֲשֶׁר שָׁמְעוּ דְבָרָי הִנָּם יֹדְעִים אֶת־אֲשֶׁר הוֹרֵיתִי׃
\v 22 \vp כב\vp* וַיְהִי כְּדַבְּרוֹ אֶת־הַדְּבָרִים הָאֵלֶּה וַיַּךְ אֶחָד הַמְשָׁרְתִים הָעֹמֵד שָׁם אֶת־יֵשׁוּעַ עַל־הַלְּחִי וַיֹּאמַר הֲכָזֹאת תַּעֲנֶה אֶת־הַכֹּהֵן הַגָּדוֹל׃
\v 23 \vp כג\vp* וַיַּעַן אֹתוֹ יֵשׁוּעַ אִם־רָעָה דִבַּרְתִּי עֲנֵה בִי אֶת־הָרָעָה וְאִם־נְכוֹנָה עַל־מֶה הִכִּיתָנִי׃
\v 24 \vp כד\vp* וְחָנָן שָׁלַח אֹתוֹ אָסוּר אֶל־קַיָּפָא הַכֹּהֵן הַגָּדוֹל׃
\v 25 \vp כה\vp* וְשִׁמְעוֹן פֶּטְרוֹס עֹמֵד וּמִתְחַמֵּם וַיֹּאמְרוּ אֵלָיו הֲלֹא גַם־אַתָּה מִתַּלְמִידָיו וַיְכַחֵשׁ וַיֹּאמֶר לֹא אָנִי׃
\v 26 \vp כו\vp* וְאֶחָד מֵעַבְדֵי הַכֹּהֵן הַגָּדוֹל מוֹדָע לָאִישׁ הַהוּא אֲשֶׁר קִצֵּץ פֶּטְרוֹס אֶת־אָזְנוֹ אָמַר אֵלָיו הֲלֹא אֲנִי רְאִיתִיךָ עִמּוֹ בַּגָּן׃
\v 27 \vp כז\vp* וַיּוֹסֶף פֶּטְרוֹס וַיְכַחֵשׁ וּבְרֶגַע זֶה קָרָא הַתַּרְנְגֹל׃
\v 28 \vp כח\vp* וַיּוֹלִיכוּ אֶת־יֵשׁוּעַ מִבֵּית קַיָּפָא אֶל־בֵּית הַמִּשְׁפָּט כַּעֲלוֹת הַבֹּקֶר וְהֶם לֹא בָאוּ לְתוֹךְ בֵּית הַמִּשְׁפָּט לְבִלְתִּי יִטַּמְּאוּ וְלֹא יוּכְלוּ לֶאֱכֹל אֶת־הַפָּסַח׃
\v 29 \vp כט\vp* וַיֵּצֵא פִילָטוֹס אֲלֵיהֶם וַיֹּאמַר מַה־שִּׂיטְנָה תָבִיאוּ עַל־הָאִישׁ הַזֶּה׃
\v 30 \vp ל\vp* וַיַּעֲנוּ וַיֹּאמְרוּ אֵלָיו לוּלֵא הָיָה זֶה פֹּעֵל־אָוֶן לֹא הִסְגַּרְנוּ אֹתוֹ בְּיָדֶיךָ׃
\v 31 \vp לא\vp* וַיֹּאמֶר אֲלֵיהֶם פִּילָטוֹס קְחוּ אֹתוֹ אַתֶּם וְשִׁיפְטֻהוּ עַל־פִּי תוֹרַתְכֶם וַיֹּאמְרוּ אֵלָיו הַיְּהוּדִים אֵין־לָנוּ כֹחַ לְהָמִית נֶפֶשׁ אָדָם׃
\v 32 \vp לב\vp* לְמַלֹּאת דְּבַר יֵשׁוּעַ אֲשֶׁר הִגִּיד מַה־יִּהְיֶה מוֹתוֹ אֲשֶׁר יוּמָת׃
\v 33 \vp לג\vp* וַיָּשָׁב פִּילָטוֹס אֶל־בֵּית הַמִּשְׁפָּט וַיִּקְרָא אֶל־יֵשׁוּעַ וַיֹּאמֶר אֵלָיו הַאַתָּה הוּא מֶלֶךְ הַיְּהוּדִים׃
\v 34 \vp לד\vp* וַיַּעַן יֵשׁוּעַ הֲמִלִּבְּךָ אַתָּה דֹבֵר כֵּן אוֹ כֵן הִגִּידוּ־לְךָ עָלַי אֲחֵרִים׃
\v 35 \vp לה\vp* וַיַּעַן פִּילָטוֹס הֲכִי יְהוּדִי אֲנֹכִי הֵן עַמְּךָ וְרָאשֵׁי הַכֹּהֲנִים הִסְגִּירוּךָ בְיָדִי מֶה עָשִׂתָה׃
\v 36 \vp לו\vp* וַיַּעַן יֵשׁוּעַ מַלְכוּתִי אֵינֶנָּה מִן־הָעוֹלָם הַזֶּה אִלּוּ מִן־הָעוֹלָם הַזֶּה הָיְתָה מַלְכוּתִי מְשָׁרְתַי יִלָּחֲמוּ לִי לְבִלְתִּי אֶנָּתֵן בִּידֵי הַיְּהוּדִים אַךְ עַתָּה מַלְכוּתִי אֵינֶנָּה מִפֹּה׃
\v 37 \vp לז\vp* וַיֹּאמֶר אֵלָיו פִּילָטוֹס אִם־כֵּן מֶלֶךְ אָתָּה וַיַּעַן יֵשׁוּעַ אַתָּה אָמַרְתָּ כִּי־מֶלֶךְ אָנִי לָזֹאת נוֹלַדְתִּי וְלָזֹאת בָּאתִי בָעוֹלָם לְהָעִיד עַל־הָאֱמֶת מִי אֲשֶׁר לָאֱמֶת יִשְׁמַע אֶת־קוֹלִי׃
\v 38 \vp לח\vp* וַיֹּאמֶר אֵלָיו פִּילָטוֹס מָה הִיא הָאֱמֶת וְאַחֲרֵי דַבְּרוֹ כָזֹאת שָׁב אֶל־הַיְּהוּדִים וַיֹּאמֶר אֲלֵיהֶם אֲנִי לֹא־מָצָאתִי בוֹ עֲוֹן׃
\v 39 \vp לט\vp* וְהִנֵּה זֶה הַחֹק מֵאָז לְשַׁלַּח לָכֶם בַּפֶּסַח אֶחָד מֵהָאֲסִירִים לַחָפְשִׁי וְעַתָּה אִם־טוֹב בְּעֵינֵיכֶם אֲשַׁלַּח לָכֶם אֶת־מֶלֶךְ הַיְּהוּדִים׃
\v 40 \vp מ\vp* וַיּוֹסִיפוּ וַיִּצְעֲקוּ לֵאמֹר לֹא אֶת־זֶה כִּי אִם אֶת־בַּר־אַבָּא וּבַר־אַבָּא הָיָה שׁוֹדֵד׃
\c 19
\cp יט
\cl פרק יט
\p 
\v 1 \vp א\vp* אָז יִקַּח פִּילָטוֹס אֶת־יֵשׁוּעַ וַיְיַסֵּר אֹתוֹ בַּשּׁוֹטִים׃
\v 2 \vp ב\vp* וְאַנְשֵׁי הַצָּבָא שָׂרְגוּ כֶתֶר קוֹצִים וַיָּשִׂימוּ עַל־רֹאשׁוֹ וַיַּלְבִּישֻׁהוּ מְעִיל אַרְגָּמָן׃
\v 3 \vp ג\vp* וַיִּגְשׁוּ אֵלָיו וַיִּקְרְאוּ יְחִי מֶלֶךְ הַיְּהוּדִים וַיַּכֻּהוּ עַל־הַלֶּחִי׃
\v 4 \vp ד\vp* וַיָּשָׁב פִּילָטוֹס וַיֵּצֵא הַחוּצָה וַיֹּאמֶר אֲלֵיהֶם הִנֵּה אוֹצִיאֶנּוּ לִפְנֵיכֶם לְבַעֲבוּר תֵּדְעוּ כִּי לֹא־מָצָאתִי בוֹ עָוֹן׃
\v 5 \vp ה\vp* וַיֵּצֵא יֵשׁוּעַ הַחוּצָה נֹשֵׂא כֶתֶר הַקּוֹצִים וּמְעִיל הָאַרְגָּמָן עָלָיו וַיֹּאמֶר אֲלֵיהֶם פִּילָטוֹס הִנֵּה הַגָּבֶר׃
\v 6 \vp ו\vp* וְרָאשֵׁי הַכֹּהֲנִים וְהַמְשַׁרְתִים כִּרְאוֹתָם אֹתוֹ צָעֲקוּ לֵאמֹר הַצְלֵב הַצְלֵב אֹתוֹ וַיֹּאמֶר אֲלֵיהֶם פִּילָטוֹס קְחוּ אֹתוֹ אַתֶּם וְהַצְלִיבֻהוּ כִּי אֲנִי לֹא־מָצָאתִי בוֹ עָוֹן׃
\v 7 \vp ז\vp* וַיַּעֲנוּ אֹתוֹ הַיְּהוּדִים הִנֵּה יֶשׁ־לָנוּ תּוֹרָה וּלְפִי תוֹרָתֵנוּ מִשְׁפָּט־מָוֶת לוֹ כִּי־מִתְאַמֵּר לֵאמֹר בֶּן־הָאֱלֹהִים הוּא׃
\v 8 \vp ח\vp* כִּשְׁמֹעַ פִּילָטוֹס אֶת־הַדָּבָר הַזֶּה וַיִּירָא יֶתֶר מְאֹד׃
\v 9 \vp ט\vp* וַיָּשָׁב וַיָּבֹא אֶל־בֵּית הַמִּשְׁפָּט וַיֹּאמֶר אֶל־יֵשׁוּעַ אֵי מִזֶּה אָתָּה וְיֵשׁוּעַ לֹא־עָנָה אֹתוֹ מְאוּמָה׃
\v 10 \vp י\vp* וַיֹּאמֶר אֵלָיו פִּילָטוֹס הַאֵלַי לֹא תְדַבֵּר הֲלֹא תֵדַע כִּי יָדִי רַב־לִי לְשַׁלֵּחֲךָ וְרַב־לִי לִצְלָבֶךָ׃
\v 11 \vp יא\vp* וַיַעַן אֹתוֹ יֵשׁוּעַ אֵין־לְךָ כֹחַ עָלַי לוּלֵא נִתַּן־לְךָ מֵעָל עַל־כֵּן עֲוֹן מַסְגִּירַי בְּיָדֶיךָ גָּדוֹל מֵעֲוֹנֶךָ׃
\v 12 \vp יב\vp* וְעַל־זֹאת בִּקֵשׁ פִּילָטוֹס לְשַׁלְּחוֹ וְהַיְּהוּדִים צָעֲקוּ וְאָמְרוּ אִם־תְּשַׁלַּח אֶת־הָאִישׁ הַזֶּה אֵינְךָ אֹהֵב אֶת־הַקֵּיסָר כִּי הַמִּתְקוֹמֵם לִהְיוֹת לְמֶלֶךְ הוּא מִתְקוֹמֵם עַל־הַקֵּיסָר׃
\v 13 \vp יג\vp* כִּשְׁמֹעַ פִּילְטוֹס אֶת־הַדְּבָרִים הָאֵלֶּה הוֹצִיא אֶת־יֵשׁוּעַ הַחוּצָה וַיֵּשֶׁב עַל־כִּסֵּא הַמִּשְׁפָּט בַּמָּקוֹם הַנִּקְרָא מַרְצֶפֶת אֲבָנִים וּבְעִבְרִית גַּבְּתָא׃
\v 14 \vp יד\vp* וַיֹּאמַר ֵֶאל־הַיְּהוּדִים בָּעֶרֶב הַפֶּסַח הַהוּא כַּשָּׁעָה הַשִּׁשִּׁית הִנֵּה מַלְכְּכֶם׃
\v 15 \vp טו\vp* וַיִּצְעֲקוּ הַיְצֵא הַיְצֵא אֹתוֹ צְלֹב אֹתוֹ וַיֹּאמֶר אֲלֵיהֶם פִּילָטוֹס הֲצָלֹב אֶצְלֹב אֶת־מַלְכְּכֶם וַיַּעֲנוּ רָאשֵׁי הַכֹּהֲנִים אֵין־לָנוּ מֶלֶךְ כִּי אִם־הַקֵּיסָר׃
\v 16 \vp טז\vp* אָז נְתָנוֹ בְיָדָם לִצְלֹב אֹתוֹ וַיִּקְחוּ אֶת־יֵשׁוּעַ וַיּוֹלִיכֻהוּ׃
\v 17 \vp יז\vp* וַיַּשִּׂיאוּ אֹתוֹ אֶת־עֵץ צְלָבוֹ וַיְבִיאֻהוּ אֶל־הַמָּקוֹם הַנִּקְרָא מְקוֹם הַגֻּלְגֹּלֶת וּבְעִבְרִית גָּלְגָּלְתָּא׃
\v 18 \vp יח\vp* וַיִּצְלְבוּ אֹתוֹ שָׁם וּשְׁנֵי אֲנָשִׁים אֲחֵרִים עִמּוֹ מֵעֵבֶר מִזֶּה וּמִזֶּה וְיֵשׁוּעַ בֵּין שְׁנֵיהֶם׃
\v 19 \vp יט\vp* וַיִּכְתֹּב פִּילָטוֹס כְּתֹבֶת עַל־לוּחַ וַיִשִׂימֵהוּ עַל־הַצְּלָב יֵשׁוּעַ הַנָּצְרִי מֶלֶךְ הַיְּהוּדִים׃
\v 20 \vp כ\vp* וִיהוּדִים רַבִּים קָרְאוּ אֶת־הַכְּתֹבֶת כִּי הַמָּקוֹם אֲשֶׁר נִצְלַב־שָׁם יֵשׁוּעַ קָרוֹב לָעִיר וְהַכְּתֹבֶת כְּתוּבָה עִבְרִית רוֹמִית וִיוָנִית׃
\v 21 \vp כא\vp* וַיֹּאמְרוּ רָאשֵׁי כֹהֲנֵי הַיְּהוּדִים אֶל־פִּילָטוֹס אַל־תִּכְתֹּב מֶלֶךְ הַיְּהוּדִים רַק כִּי אָמַר אֲנִי מֶלֶךְ הַיְּהוּדִים׃
\v 22 \vp כב\vp* וַיַּעַן פִּילָטוֹס אֶת־אֲשֶׁר כָּתַבְתִּי כָּתַבְתִּי׃
\v 23 \vp כג\vp* וַיְהִי כַּאֲשֶׁר צָלְבוּ אַנְשֵׁי הַצָּבָא אֶת־יֵשׁוּעַ וַיִּקְחוּ אֶת־בְּגָדָיו וַיְחַלְּקוּם אַרְבָּעָה רֹבַע לְאִישׁ אִישׁ וְגַם אֶת־כֻּתַּנְתּוֹ וְהַכְּתֹנֶת לֹא הָיְתָה תְּפוּרָה כִּי אִם־מַעֲשֶׂה אֹרֵג מִשָּׂפָה עַד־הַשָּׂפָה׃
\v 24 \vp כד\vp* וַיֹּאמְרוּ אִישׁ אֶל־רֵעֵהוּ לֹא נִקְרְעָה אֹתָהּ אַךְ נַפִּילָה עָלֶיהָ גּוֹרָל לְמִי תִהְיֶה לְהָקִים דְּבַר הַכָּתוּב יְחַלְּקוּ בְגָדַי לָהֶם וְעַל־לְבוּשִׁי יַפִּילוּ גוֹרָל וַיַּעֲשׂוּ־כֵן אַנְשֵׁי הַצָּבָא׃
\v 25 \vp כה\vp* וְעַל־יַד צְלַב יֵשׁוּעַ עָמְדוּ אִמּוֹ וַאֲחוֹת אִמּוֹ וּמִרְיָם אֵשֶׁת קְלוֹפָס וּמִרְיָם הַמַּגְדָּלִית׃
\v 26 \vp כו\vp* וַיַּרְא יֵשׁוּעַ אֶת־אִמּוֹ וְאֶת־תַּלְמִידוֹ אֲשֶׁר אָהַב עֹמְדִים אֶצְלוֹ וַיֹּאמֶר אֶל־אִמּוֹ אִשָּׁה רְאִי זֶה בְּנֵךְ׃
\v 27 \vp כז\vp* וְאַחַר אָמַר אֶל־תַּלְמִידוֹ רְאֵה זֹאת אִמֶּךָ וַיַּאַסְפָהּ הַתַּלְמִיד אֶל־בֵּיתוֹ מֵהַיּוֹם הַהוּא וָמָעְלָה׃
\v 28 \vp כח\vp* וְיֵשׁוּעַ בְּדַעְתּוֹ אַחֲרֵי־כֵן כִּי נִשְׁלַם כָּל־דָּבָר אַךְ לְמַלֹּאת אֶת־הַכָּתוּב אָמַר צָמֵאתִי׃
\v 29 \vp כט\vp* וְשָׁם עָמַד כְּלִי מָלֵא חֹמֶץ וַיִּטְבְּלוּ סְפוֹג בַּחֹמֶץ וַיָּשִׂימוּ עַל־רֹאשׁ אֵזוֹב וַיַּגִיעוּהוּ אֶל־פִּיו׃
\v 30 \vp ל\vp* וַיִּטְעַם יֵשׁוּעַ מִן־הַחֹמֶץ וַיֹּאמֶר נִשְׁלָם וַיֵּט אֶת־רֹאשׁוֹ וַיַּפְקֵד אֶת־רוּחוֹ׃
\v 31 \vp לא\vp* וְהַיְּהוּדִים חָשׁוּ לְבִלְתִּי הַשְׁאֵר אֶת־הַפְּגָרִים עַל־הָעֵץ בְּיוֹם הַשַּׁבָּת כִּי־עֶרֶב שַׁבָּת הָיָה וְהַשַּׁבָּת הַהוּא גָּדוֹל הוּא עַל־כֵּן שָׁאֲלוּ מִפִּלָטוֹס לְשַׁבֵּר אֶת־שׁוֹקֵיהֶם כִּי יָמוּתוּ וּלְהוֹרִידָם מִן־הָעֵץ׃
\v 32 \vp לב\vp* וַיָּבֹאוּ אַנְשֵׁי הַצָּבָא וַיְשַׁבְּרוּ אֶת־שׁוֹקֵי הָאֶחָד וְאֶת־שׁוֹקֵי הַשֵּׁנִי אֲשֶׁר נִצְלְבוּ עִמּוֹ׃
\v 33 \vp לג\vp* וַיָּבֹאוּ אֶל־יֵשׁוּעַ וַיִּרְאוּ כִּי־כְבָר מֵת וְלֹא שִׁבְּרוּ אֶת־שׁוֹקָיו׃
\v 34 \vp לד\vp* אַךְ אֶחָד מֵאַנְשֵׁי הַצָּבָא דְּקָרוֹ בַחֲנִית בְּצִדּוֹ וַיֵּצֵא דָם וָמָיִם׃
\v 35 \vp לה\vp* וְהַמֵּעִיד עַל־זֶה רָאָה אֶת־הַדָּבָר וְעֵדוּתוֹ נֶאֱמָנָה וְהוּא יֹדֵעַ כִּי אֱמֶת יֶהְגֶּה חִכּוֹ לְבַעֲבוּר תַּאֲמִינוּ גַּם־אַתֶּם׃
\v 36 \vp לו\vp* וְכָל־זֶה הָיָה לְקַיֵּם אֶת־הַכָּתוּב וְעֶצֶם לֹא־תִשְׁבְּרוּ בוֹ׃
\v 37 \vp לז\vp* וְעוֹד כָּתוּב לֵאמֹר וְהִבִּטוּ אֵלָיו אֵת אֲשֶׁר־דָּקָרוּ׃
\v 38 \vp לח\vp* וַיְהִי אַחַר הַדְּבָרִים הָאֵלֶּה יוֹסֵף מִן־הָרָמָתַיִם הוּא אֲשֶׁר הָיָה תַּלְמִיד יֵשׁוּעַ בַּסֵּתֶר מִיִּרְאָתוֹ אֶת־הַיְּהוּדִים וַיִּשְׁאַל מֵאֵת פִּילָטוֹס לָתֶת־לוֹ לָשֵׂאת אֶת־גּוּפַת יֵשׁוּעַ׃
\v 39 \vp לט\vp* וַיִתֶּן־לוֹ פִּילָטוֹס רִשְׁיוֹן וַיָּבֹא וַיִּשָׂא אֶת־גּוּפַת יֵשׁוּעַ וְנַקְדִּימוֹן אֲשֶׁר לְפָנִים בָּא אֶל־יֵשׁוּעַ בַּלַּיְלָה בָּא גַּם־הוּא וְהֵבִיא סַמִּים בְּלוּלִים מֹר־וַאֲהָלוֹת כְּמֵאָה לִיטָרִין׃
\v 40 \vp מ\vp* וַיִּקְחוּ אֶת־גּוּפַת יֵשׁוּעַ וַיַּעֲטוּהָ בְתַכְרִיכִים אֲשֶׁר מִלְאוּ בְשָׂמִים כְּדֶרֶךְ קְבוּרַת הַיְּהוּדִים׃
\v 41 \vp מא\vp* וּבַמָּקוֹם אֲשֶׁר נִצְלַב־שָׁם הָיָה גָן וּבוֹ קֶבֶר חָדָשׁ אֲשֶׁר עוֹד לֹא־נִקְבַּר בּוֹ אִישׁ׃
\v 42 \vp מב\vp* וּבִהְיוֹת הַיּוֹם עֶרֶב שַׁבָּת לַיְּהוּדִים וְהַקֶּבֶר קָרוֹב קָבְרוּ בוֹ אֶת־יֵשׁוּעַ׃
\c 20
\cp כ
\cl פרק כ
\p 
\v 1 \vp א\vp* וַיְהִי בָּאֶחָד בַּשַּׁבָּת וַתָּבֹא מִרְיָם הַמַּגְדָּלִית לִפְנוֹת בֹּקֶר בַּחֲשֵׁכָה אֶל־הַקָּבֶר וַתֵּרֶא אֶת־הָאֶבֶן מְגוֹלָלָה מֵעַל־הַקָּבֶר׃
\v 2 \vp ב\vp* וַתָּרָץ וַתָּבֹא אֶל־שִׁמְעוֹן פֶּטְרוּס וְאֶל־הַתַּלְמִיד הָאַחֵר אֲשֶׁר אָהַב אֹתוֹ יֵשׁוּעַ וַתֹּאמֶר אֲלֵיהֶם הִנֵּה נָשְׂאוּ אֶת־אֲדֹנֵינוּ מִן־הַקֶּבֶר וַאֲנַחְנוּ לֹא נֵדַע אָנָה שָׂמוּ אֹתוֹ׃
\v 3 \vp ג\vp* וַיֵּצֵא פֶטְרוֹס וְהַתַּלְמִיד הָאַחֵר וַיֵּלְכוּ אֶל־הַקָּבֶר׃
\v 4 \vp ד\vp* וּשְׁנֵיהֶם רָצוּ יַחְדָּו וַיְמַהֵר הַתַּלְמִיד הָאַחֵר לָרוּץ וַיַּעֲבֹר אֶת־פֶּטְרוֹס וַיָּבֹא רִאשׁוֹן אֶל־הַקָּבֶר׃
\v 5 \vp ה\vp* וַיִּשַּׁח וַיַּשְׁקֵף אֶל־תּוֹכוֹ וַיַּרְא אֶת־הַתַּכְרִיכִים מֻנָּחִים לְבַדָּם וְלֹא יָרַד פְּנִימָה׃
\v 6 \vp ו\vp* וְגַם־שִׁמְעוֹן פֶּטְרוֹס בָּא אַחֲרָיו וַיֵּרֶד אֶל־הַקָּבֶר וַיַּרְא אֶת־הַתַּכְרִיכִים מֻנָּחִים לְבַדָּם׃
\v 7 \vp ז\vp* וְהַמִּטְפַּחַת אֲשֶׁר הָיְתָה עַל־רֹאשׁוֹ אֵינֶנָּה עִם־הַתַּכְרִיכִים כִּי אִם־צְנוּפָה לְבַדָּהּ בְּמָקוֹם אַחֵר׃
\v 8 \vp ח\vp* וַיֵּרֶד שָׁם גַּם־הַתַּלְמִיד הָאַחֵר אֲשֶׁר־בָּא רִאשׁוֹן אֶל־הַקֶּבֶר וַיַּרְא וַיַּאֲמֵן׃
\v 9 \vp ט\vp* כִּי עַד־עַתָּה לֹא־הֵבִינוּ עוֹד אֶת־הַכְּתוּבִים כִּי נָכוֹן לוֹ לָקוּם מִן־הַמֵּתִים׃
\v 10 \vp י\vp* וַיָּשֻׁבוּ הַתַּלְמִידִים וַיֵּלְכוּ אֶל־בֵּיתָם׃
\v 11 \vp יא\vp* וּמִרְיָם עָמְדָה מִחוּץ לַקֶּבֶר וַתֵּבְ וַיְהִי בִּבְכּוֹתָהּ וַתִּשַּׁח וַתַּשְׁקֵף אֶל־תּוֹךְ הַקָּבֶר׃
\v 12 \vp יב\vp* וַתֵּרֶא שְׁנֵי מַלְאָכִים עֹטִים לְבָנִים וְישְׁבִים בַּמָּקוֹם אֲשֶׁר שָׂמוּ אֶת־גּוּפַת יֵשׁוּעַ אֶחָד מְרַאֲשֹׁתָיו וְאֶחָד מַרְגְּלֹתָיו׃
\v 13 \vp יג\vp* וַיֹּאמְרוּ אֵלֶיהָ אִשָּׁה לָמֶה תִבְכִּי אֲלֵיהֶם כִּי נָשְׂאוּ אֶת־אֲדֹנִי מִזֶּה וְלֹא אֵדַע אָנָה שָׂמֻהוּ׃
\v 14 \vp יד\vp* עוֹד הִיא מְדַבֶּרֶת כָּזֹאת וַתֵּפֶן מֵאַחֲרֶיהָ וַתֵּרֶא אֶת־יֵשׁוּעַ עֹמֵד וְלֹא יָדְעָה כִּי הוּא יֵשׁוּעַ׃
\v 15 \vp טו\vp* וַיֹּאמֶר אֵלֶיהָ יֵשׁוּעַ אִשָּׁה לָמֶה תִבְכִּי אֶת־מִי תְבַקֵּשִׁי וְהִיא חָשְׁבָה כִּי־נֹטֵר הַגָּן הוּא וַתֹּאֶר אֵלָיו אֲדֹנִי אִם־אַתָּה נָשָׂאתָ אֹתוֹ מִזֶּה הַגִּידָה־נָא לִי אֵיפֹא שַׂמְתָּ אֹתוֹ וַאֲנִי אֵלֵךְ וְאֶשָּׂאֶנּוּ׃
\v 16 \vp טז\vp* וַיֹּאמֶר אֵלֶיהָ יֵשׁוּעַ מִרְיָם וַתֵּפֶן וַתֹּאמֶר אֵלָיו עִבְרִית רַבּוּנִי אֲשֶׁר יֵאָמֵר רַבִּי׃
\v 17 \vp יז\vp* וַיֹּאמֵר אֵלֶיהָ יֵשׁוּעַ אַל־תִּגְּעִי בִי כִּי עוֹד לֹא עָלִיתִי אֶל־הָאָב אַךְ לְכִי אֶל־אַחַי וְאִמְרִי אֲלֵיהֶם הִנְנִי עֹלֶה אֶל־אָבִי וַאֲבִיכֶם אֶל־אֱלֹהַי וֵאלֹהֵיכֶם׃
\v 18 \vp יח\vp* וַתָּבֹא מִרְיָם הַמַּגְדָּלִית וַתַּגֵּד לַתַּלְמִידִים כִּי־רָאֲתָה אֶת־הָאָדוֹן וְכִי כָּזֹאת דִּבֶּר אֵלֶיהָ׃
\v 19 \vp יט\vp* וַיְהִי בָּעֶרֶב בַּשַּׁבָּת הַהוּא כַּאֲשֶׁר נִסְגְּרוּ דַלְתוֹת הַבַּיִת אֲשֶׁר נִקְבְּצוּ שָׁם הַתַּלְמִידִים מִיִּרְאָתָם אֶת־הַיְּהוּדִים וַיָּבֹא יֵשׁוּעַ וַיַּעֲמֹד בְּתוֹכָם וַיֹּאמֶר אֲלֵיהֶם שָׁלוֹם עֲלֵיכֶם׃
\v 20 \vp כ\vp* וְאַחֲרֵי דַבְּרוֹ כָזֹאת הֶרְאָם אֶת־יָדָיו וְאֶת־צִדּוֹ וַיִּשְׂמְחוּ הַתַּלְמִידִים בִּרְאוֹתָם אֶת־הָאָדוֹן׃
\v 21 \vp כא\vp* וַיּוֹסֶף יֵשׁוּעַ וַיֹּאמֶר אֲלֵיהֶם שָׁלוֹם לָכֶם כַּאֲשֶׁר שָׁלַח אֹתִי הָאָב כֵּן הִנְנִי שֹׁלֵחַ אֶתְכֶם׃
\v 22 \vp כב\vp* וְאַחֲרֵי דַבְּרוֹ כָזֹאת וַיִּפַּח בָּהֶם וַיֹּאמֶר אֲלֵיהֶם קְחוּ לָכֶם אֶת־רוּחַ הַקֹּדֶשׁ׃
\v 23 \vp כג\vp* אִישׁ אִישׁ אֲשֶׁר תִּסְלְחוּ לוֹ אֶת־חֲטָאָיו וְנִסְלַח לוֹ וְאִם תְּשִׁיתוּם עָלָיו עָלָיו יִהְיוּ׃
\v 24 \vp כד\vp* וְתוֹמָא הַנִּקְרָא דִידוּמוֹס אֶחָד מִשְּׁנֵים הֶעָשָׂר לֹא־הָיָה עִמָּהֶם בְּבֹא יֵשׁוּעַ׃
\v 25 \vp כה\vp* וַיֹּאמְרוּ אֵלָיו יֶתֶר הַתַּלְמִידִים רָאִינוּ אֶת־הָאָדוֹן וַיֹּאמֶר אֲלֵיהֶם אִם־לֹּא אֶרְאֶה אֶת־מַדְקְרוֹת הַמַּסְמְרִים בְּיָדָיו וְלֹא אֶתְקַע אֶת־אֶצְבָּעִי בְּנִקְבֵי הַמַּסְמְרִים הָאֵלֶּה ובְיָדִי לֹא אֶגַּע בְּצִדּוֹ לֹא אַאֲמִינָה׃
\v 26 \vp כו\vp* וּמִקְצֵה שְׁמֹנַת יָמִים נִקְהֲלוּ הַתַּלְמִידִים בַּבַּיִת פְּנִימָה עוֹד הַפַּעַם וְתוֹמָא עִמָּהֶם וַיָּבֹא יֵשׁוּעַ כַּאֲשֶׁר סֻגְּרוּ הַדְּלָתוֹת וַיַּעֲמֹד בְּתוֹכָם וַיֹּאמֶר שָׁלוֹם עֲלֵיכֶם׃
\v 27 \vp כז\vp* וְאַחַר אָמַר אֶל־תּוֹמָא הוֹשֵׁט אֶת־אֶצְבָּעֲךָ הֵנָּה וּרְאֵה אֶת־יָדַי וְהוֹשֵׁט אֶת־יָדְךָ וּמֻשֵּׁנִי בְצִדִּי וְאַל־תְּהִי חֲסַר אֱמוּנָה כִּי אִם־הַאֲמֵן תַּאֲמִין׃
\v 28 \vp כח\vp* וַיַּעַן תּוֹמָא וַיֹּאמֶר אֵלָיו אֲדֹנִי וֵאלֹהָי׃
\v 29 \vp כט\vp* וַיֹּאמֶר אֵלָיו יֵשׁוּעַ יַעַן אֲשֶׁר רְאִיתַנִי הֱאֶמַנְתָּ תּוֹמָא אַשְׁרֵי אֵלֶּה הַמַּאֲמִינִים וְרָאוֹ לֹא רָאוּ׃
\v 30 \vp ל\vp* וְגַם־מוֹפְתִים אֲחֵרִים רַבִּים עָשָׂה יֵשׁוּעַ לְעֵינֵי תַלְמִידָיו אֲשֶׁר לֹא־נִכְתְּבוּ בַּסֵּפֶר הַזֶּה׃
\v 31 \vp לא\vp* אַךְ־אֵלֶּה נִכְתְּבוּ לְבַעֲבוּר תַּאֲמִינוּ כִּי יֵשׁוּעַ הוּא הַמָּשִׁיחַ בֶּן־הָאֱלֹהִים וּלְבַעֲבוּר יִהְיוּ לָכֶם חַיִּים עֵקֶב אֱמוּנַתְכֶם בִּשְׁמוֹ׃
\c 21
\cp כא
\cl פרק כא
\p 
\v 1 \vp א\vp* וַיְהִי אַחֲרֵי־כֵן וַיּוֹסֵף יֵשׁוּעַ לְהֵרָאוֹת אֶל־תַּלְמִידָיו עַל־יַם טְבַרְיָה וְכֹה נִרְאָה אֲלֵיהֶם׃
\v 2 \vp ב\vp* כַּאֲשֶׁר יָשְׁבוּ יַחְדָּו שִׁמְעוֹן פֶּטְרוֹס וְתוֹמָא הַנִּקְרָא דִידוּמוֹס וּנְתַנְאֵל מִקָּנָה אֲשֶׁר בַּגָּלִיל וּבְנֵי זַבְדִּי וּשְׁנַיִם אֲחֵרִים מִתַּלְמִידָיו׃
\v 3 \vp ג\vp* וַיֹּאמֶר אֲלֵיהֶם שִׁמְעוֹן פֶּטְרוֹס הִנְנִי הֹלֵךְ לָדִיג וַיֹּאמְרוּ אֵלָיו עִמָּךְ נֵלֵךְ גַּם־אֲנָחְנוּ וַיֵּצְאוּ מִיָּד וַיֵּרְדוּ אֶל־הָאֳנִיָּה וְלֹא לָכְדוּ מְאוּמָה בַּלַּיְלָה הוּא׃
\v 4 \vp ד\vp* הַבֹּקֶר אוֹר וְהִנֵּה יֵשׁוּעַ עֹמֵד עַל־שְׂפַת הַיָּם וְהַתַּלְמִידִים לֹא יָדְעוּ כִּי יֵשׁוּעַ הוּא׃
\v 5 \vp ה\vp* וַיֹּאמֶר אֲלֵיהֶם יֵשׁוּעַ בָּנַי הֲיֵשׁ־לָכֶם דָּבָר לֶאֱכֹל וַיַּעֲנוּ וַיֹּמְרוּ אָיִן׃
\v 6 \vp ו\vp* וַיֹּאמֶר אֲלֵיהֶם פִּרְשׂוּ אֶת־הַמִּכְמֹרֶת מִימִין לָאֳנִיָּה וּמְצָאתֶם וַיִפְרְשׂוּ וְלֹא־יָכְלוּ עוֹד לְמָשְׁכָהּ מֵרֹב דָּגִים׃
\v 7 \vp ז\vp* וְהַתַּלְמִיד הַהוּא אֲשֶׁר יֵשׁוּעַ אֲהֵבוֹ אָמַר אֶל־פֶּטְרוֹס הָאָדוֹן הוּא וְכִשְׁמֹעַ שִׁמְעוֹן פֶּטְרוֹס כִּי הוּא הָאָדוֹן וַיַּעַט אֶת־מְעִילוֹ כִּי עֵרֹם הָיָה וַיִּתְנַפֵּל אֶל־הַיָּם׃
\v 8 \vp ח\vp* וְיֶתֶר הַתַּלְמִידִים בָּאוּ בָאֳנִיָּתָם כִּי לֹא הִרְחִיקוּ מִן־הַיַּבָּשָׁה כִּי אִם־כְּמָאתַיִם אַמָּה וַיִּמְשְׁכוּ אֶת־הַמִכְמֹרֶת עִם־הַדָּגִים׃
\v 9 \vp ט\vp* וַיֵּצְאוּ אֶל־הַיַּבָּשָׁה וַיִּרְאוּ גַּחֲלֵי־אֵשׁ עֲרוּכִים שָׁם וְדָג עֲלֵיהֶם וְכִכַּר לָחֶם׃
\v 10 \vp י\vp* וַיֹּאמֶר אֲלֵיהֶם יֵשׁוּעַ הָבִיאוּ הֲלֹם מִן־הַדָּגִים אֲשֶׁר לְכַדְתֶּם עָתָּה׃
\v 11 \vp יא\vp* וַיַּעַל שִׁמְעוֹן פֶּטְרוֹס וַיִּמְשֹׁךְ אֶת־הַמִּכְמֹרֶת אֶל־הַיַּבָּשָׁה וְהִיא מְלֵאָה דָגִים גְּדוֹלִים מֵאָה וַחֲמִישִׁים וּשְׁלשָׁה וּבְכָל־זֹאת לֹא נִקְרְעָה הַמִּכְמֹרֶת מֵרֹב הַדָּגִים׃
\v 12 \vp יב\vp* וַיֹּאמֶר אֲלֵיהֶם יֵשׁוּעַ בֹּאוּ אִכְלוּ אֲרֻחַת הַבֹּקֶר וְאֵין גַּם־אֶחָד בַּתַּלְמִידִים אֲשֶׁר מְלָאוֹ לִבּוֹ לִשְׁאֹל מִי אָתָּה כִּי יָדְעוּ אֲשֶׁר הוּא הָאָדוֹן׃
\v 13 \vp יג\vp* וַיָּבֹא יֵשׁוּעַ וַיִּקַּח אֶת־הַלֶּחֶם וַיִּתֵּן לָהֶם וְגַם אֶת־הַדָּגָה׃
\v 14 \vp יד\vp* וְזֹאת הַפַּעַם הַשְּׁלִישִׁית אֲשֶׁר־נִרְאָה יֵשׁוּעַ אֶל־תַּלְמִידָיו אַחֲרֵי קוּמוֹ מִן־הַמֵּתִים׃
\v 15 \vp טו\vp* וַיְהִי אַחֲרֵי אֲרֻחָתָם וַיֹּאמֶר יֵשׁוּעַ אֶל־שִׁמְעוֹן פֶּטְרוֹס שִׁמְעוֹן בַּר־יוֹנָה הַאֹהֵב אַתָּה אֹתִי יֶתֶר מֵאֵלֶּה וַיֹּאמֶר אֵלָיו הֵן אֲדֹנִי אַתָּה יָדַעְתָּ כִּי אֲהַבְתִּיךָ וַיֹּאמֶר אֵלָיו נַהֵל אֶת־עָלוֹתָי׃
\v 16 \vp טז\vp* וַיֹּאמֶר אֵלָיו פַּעַם שֵׁנִית שִׁמְעוֹן בַּר־יוֹנָה הַאֹהֵב אַתָּה אֹתִי וַיֹּאמֶר אֵלָיו הֵן אֲדֹנִי אַתָּה יָדַעְתָּ כִּי אֲהַבְתִּיךָ וַיֹּאמֶר אֵלָיו נְחֵה אֶת־צֹאנִי׃
\v 17 \vp יז\vp* וַיֹּאמֶר אֵלָיו פַּעַם שְׁלִישִׁית שִׁמְעוֹן בַּר־יוֹנָה הַאֹהֵב אַתָּה אֹתִי וַיִּתְעַצֵּב פֶּטְרוֹס אֶל־לִבּוֹ כִּי אָמַר אֵלָיו פַּעַם שְׁלִישִׁית הַאֹהֵב אַתָּה אֹתִי וַיֹּאמֶר אֵלָיו אֲדֹנִי אַתָּה אֶל־כֹּל יָדַעְתָּ אַתָּה יָדַעְתָּ כִּי אֲהַבְתִּיךָ וַיֹּאמֶר אֵלָיו יֵשׁוּעַ רְעֵה אֶת־צֹאנִי׃
\v 18 \vp יח\vp* אָמֵן אָמֵן אֲנִי אֹמֵר לָךְ בְּעוֹד נַעַר הָיִיתָ בְּיָדְךָ חָגַרְתָּ אֶת־מָתְנֶיךָ וַתֵּלֶךְ אֶל־אֲשֶׁר חָפַצְתָּ וְכִי תִזְקַן תִּפְרֹשׂ כַּפֶּיךָ וְאַחֵר יַחְגָּרְךָ וּנְשָׂאֲךָ אֶל־אֲשֶׁר לֹא תַחְפֹּץ׃
\v 19 \vp יט\vp* וְאוּלָם כָּזֹאת הוּא דִבֵּר בְּרָמְזוֹ לוֹ בְּאֵיזֶה מָוֶת הוּא יָמוּת אֲשֶׁר יִגְדַּל בּוֹ כְּבוֹד אֱלֹהִים וְאַחֲרֵי דַבְּרוֹ כָזֹאת אָמַר אֵלָיו לֵךְ אַחֲרָי׃
\v 20 \vp כ\vp* וַיִּפֶן פֶּטְרוֹס וַיַּרְא אֶת־הַתַּלְמִיד אֲשֶׁר יֵשׁוּעַ אֲהֵבוֹ הֹלֵךְ אַחֲרֵיהֶם וְהוּא אֲשֶׁר נָפַל עַל־צַוָּארוֹ בְּמִשְׁתֵּה הָעֶרֶב וְאָמַר אֲדֹנִי מִי הוּא־זֶה אֲשֶׁר יַסְגִּירֶךָ׃
\v 21 \vp כא\vp* וַיְהִי בִּרְאוֹת אֹתוֹ פֶּטְרוֹס וַיֹּאמֶר אֶל־יֵשׁוּעַ אֲדֹנִי וְזֶה מָה אַחֲרִיתוֹ׃
\v 22 \vp כב\vp* וַיֹּאמֶר אֵלָיו יֵשׁוּעַ אִם־חָפַצְתִּי כִּי יִשָּׁאֵר עַד־אֲשֶׁר אָבֹא אַךְ מַה־לָּךְ לֵךְ אַחֲרָי׃
\v 23 \vp כג\vp* עַל־כֵּן יָצָא הַדָּבָר הַזֶּה בֵּין הָאַחִים כִּי הַתַּלְמִיד הַהוּא לֹא יָמוּת וְיֵשׁוּעַ לֹא אָמַר־לוֹ כִּי לֹא־יָמוּת רַק אָמַר אִם־חָפַצְתִּי כִּי־יִשָּׁאֵר עַד־אֲשֶׁר אָבֹא אַךְ מַה־לָּךְ׃
\v 24 \vp כד\vp* זֶה הוּא הַתַּלְמִיד הַנֹּתֵן אֶת־עֵדוּתוֹ לָאֵלֶּה וְהוּא אֲשֶׁר כָּתַב כָּל־אֵלֶּה וְיָדַעְנוּ כִּי עֵדוּתוֹ נֶאֱמָנָה׃
\v 25 \vp כה\vp* וְעוֹד יֵשׁ מַעֲשִׂים רַבִּים אֲחֵרִים אֲשֶׁר עָשָׂה יֵשׁוּעַ אַךְ אִם־יִכָּתְבוּ כֻלָּם אֶחָד אַחַר אֶחָד יַחֲשֹׁב לְבָבִי כִּי לֹא תָכִיל כָּל־הָעוֹלָם אֶת־הַסְּפָרִים אֲשֶׁר יִכָּתֵבוּן אָמֵן׃ 
