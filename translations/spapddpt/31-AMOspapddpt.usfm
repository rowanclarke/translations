\v 16 \nd ʼAdonay \+w Yavé|strong="H3068"\+w*, ʼElohim\nd* de las huestes dice: \wj En \+w todas|strong="H3605"\+w* las \+w plazas|strong="H7339"\+w* habrá \+w llanto|strong="H4553"\+w* \+w y|strong="H3541"\+w* en \+w todas|strong="H3605"\+w* las \+w calles|strong="H7339"\+w* dirán: ¡\+w Ay|strong="H1930"\+w*! ¡\+w Ay|strong="H1930"\+w*! \+w Y|strong="H3068"\+w* \+w llamarán|strong="H7121"\+w* al labrador \+w a|strong="H3068"\+w* duelo \+w y|strong="H3541"\+w* \+w a|strong="H3068"\+w* lamentación \+w a|strong="H3068"\+w* \+w los|strong="H3605"\+w* \+w que|strong="H3045"\+w* \+w saben|strong="H3045"\+w* lamentar.\wj*  
\v 17 \wj \+w En|strong="H3588"\+w* \+w todas|strong="H3605"\+w* las \+w viñas|strong="H3754"\+w* habrá \+w llanto|strong="H4553"\+w*, \+w porque|strong="H3588"\+w* \+w pasaré|strong="H5674"\+w* \+w entre|strong="H7130"\+w* ustedes, \wj*dice \nd \+w Yavé|strong="H3068"\+w*\nd*.   
\p
\v 18 ¡\w Ay|strong="H1945"\w* de \w los|strong="H1931"\w* \w que|strong="H4100"\w* anhelan \w el|strong="H1931"\w* \w día|strong="H3117"\w* de \nd \+w Yavé|strong="H3068"\+w*\nd*! ¿Para \w qué|strong="H4100"\w* desean \w este|strong="H2088"\w* \w día|strong="H3117"\w* de \nd \+w Yavé|strong="H3068"\+w*\nd*? \w Será|strong="H1931"\w* de \w tinieblas|strong="H2822"\w* y \w no|strong="H3808"\w* de luz,  
\v 19 \w como|strong="H5921"\w* cuando uno \w huye|strong="H5127"\w* \w del|strong="H5921"\w* león \w y|strong="H5921"\w* choca \w con|strong="H5921"\w* un \w oso|strong="H1677"\w*. \w O|strong="H3068"\w* \w al|strong="H5921"\w* entrar \w en|strong="H5921"\w* su \w casa|strong="H1004"\w*, apoya \w la|strong="H5921"\w* \w mano|strong="H3027"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w pared|strong="H7023"\w* \w y|strong="H5921"\w* \w lo|strong="H5921"\w* \w muerde|strong="H5391"\w* una \w serpiente|strong="H5175"\w*.  
\v 20 ¿\w No|strong="H3808"\w* \w será|strong="H3808"\w* el \w día|strong="H3117"\w* de \nd \+w Yavé|strong="H3068"\+w*\nd* \w oscuridad|strong="H2822"\w* y \w no|strong="H3808"\w* luz? ¿Muy oscuro, \w sin|strong="H3808"\w* \w resplandor|strong="H5051"\w*?   
\p
\v 21 \wj ¡\+w Aborrezco|strong="H8130"\+w*, repugno sus \+w solemnidades|strong="H2282"\+w*! ¡Sus asambleas \+w no|strong="H3808"\+w* me \+w son|strong="H3808"\+w* olor grato!\wj*  
\v 22 \wj \+w Aunque|strong="H3588"\+w* \+w me|strong="H3588"\+w* ofrezcan \+w holocaustos|strong="H5930"\+w* \+w y|strong="H3588"\+w* ofrendas vegetales, \+w no|strong="H3808"\+w* las aceptaré, \+w ni|strong="H3808"\+w* \+w miraré|strong="H5027"\+w* sus sacrificios \+w de|strong="H3588"\+w* paz \+w con|strong="H3588"\+w* animales engordados.\wj*  
\v 23 \wj Retiren \+w el|strong="H5921"\+w* bullicio \+w de|strong="H5921"\+w* \+w los|strong="H5921"\+w* cánticos \+w de|strong="H5921"\+w* \+w mi|strong="H5921"\+w* Presencia. \+w No|strong="H3808"\+w* quiero \+w escuchar|strong="H8085"\+w* \+w el|strong="H5921"\+w* sonido \+w de|strong="H5921"\+w* tus arpas.\wj*  
\v 24 \wj Pero fluya la \+w justicia|strong="H6666"\+w* como las \+w aguas|strong="H4325"\+w*, y la equidad como \+w arroyo|strong="H5158"\+w* perenne.\wj*   
\p
\v 25 \wj ¿Me ofrecieron \+w sacrificios|strong="H2077"\+w* y ofrendas en \+w el|strong="H5066"\+w* \+w desierto|strong="H4057"\+w* durante 40 \+w años|strong="H8141"\+w*, oh \+w Casa|strong="H1004"\+w* de \+w Israel|strong="H3478"\+w*?\wj*  
\v 26 \wj Más bien, \+w llevaron|strong="H5375"\+w* \+w a|strong="H3068"\+w* Sicut, su \+w rey|strong="H6213"\+w*, y \+w a|strong="H3068"\+w* Quiún, la \+w estrella|strong="H3556"\+w* de sus \+tl ʼelohim\+tl* que \+w hicieron|strong="H6213"\+w* para ustedes.\wj*  
\v 27 \wj Por tanto, promoveré que los deporten más \+w allá|strong="H1973"\+w* de \+w Damasco|strong="H1834"\+w*, \wj*dice \nd \+w Yavé|strong="H3068"\+w*\nd*, \wj cuyo \+w Nombre|strong="H8034"\+w* es \+nd ʼElohim\+nd* de las huestes.\wj*   
\c 6  
\s1 Destrucción para Israel  
\p
\v 1 ¡\w Ay|strong="H1945"\w* de \w los|strong="H1992"\w* \w que|strong="H1992"\w* viven tranquilos en \w Sion|strong="H6726"\w*, de \w los|strong="H1992"\w* \w que|strong="H1992"\w* confían en la montaña de \w Samaria|strong="H8111"\w* y \w los|strong="H1992"\w* notables y \w principales|strong="H7225"\w* entre \w las|strong="H1992"\w* \w naciones|strong="H1471"\w*, \w a|strong="H3068"\w* quienes la \w Casa|strong="H1004"\w* de \w Israel|strong="H3478"\w* acude!  
\v 2 Pasen \w a|strong="H3068"\w* Calne y observen. \w Desde|strong="H4480"\w* \w allí|strong="H8033"\w* \w vayan|strong="H3212"\w* \w a|strong="H3068"\w* \w la|strong="H1366"\w* \w gran|strong="H7227"\w* Hamat, \w luego|strong="H5674"\w* bajen \w a|strong="H3068"\w* Gat \w de|strong="H4480"\w* los \w filisteos|strong="H6430"\w*. ¿Son \w ellos|strong="H4480"\w* \w mejores|strong="H2896"\w* \w que|strong="H4480"\w* estos \w reinos|strong="H4467"\w*? ¿\w O|strong="H3068"\w* es su territorio \w mayor|strong="H7227"\w* \w que|strong="H4480"\w* \w el|strong="H5674"\w* \w de|strong="H4480"\w* ustedes?  
\v 3 ¿Alejan \w el|strong="H5066"\w* \w día|strong="H3117"\w* \w de|strong="H7451"\w* la calamidad y acercan la silla \w de|strong="H7451"\w* la \w violencia|strong="H2555"\w*?  
\v 4 \w Duermen|strong="H7901"\w* \w en|strong="H5921"\w* \w camas|strong="H4296"\w* \w de|strong="H5921"\w* \w marfil|strong="H8127"\w*, reposan \w sobre|strong="H5921"\w* sus \w camas|strong="H4296"\w* \w y|strong="H5921"\w* comen \w los|strong="H5921"\w* \w corderos|strong="H3733"\w* \w del|strong="H5921"\w* \w rebaño|strong="H6629"\w* \w y|strong="H5921"\w* \w los|strong="H5921"\w* \w becerros|strong="H5695"\w* \w del|strong="H5921"\w* establo.  
\v 5 Improvisan \w el|strong="H5921"\w* sonido \w del|strong="H5921"\w* arpa \w y|strong="H5921"\w* componen salmos \w para|strong="H5921"\w* \w ellos|strong="H1992"\w* \w mismos|strong="H1992"\w* \w como|strong="H5921"\w* \w David|strong="H1732"\w*.  
\v 6 \w Beben|strong="H8354"\w* \w vino|strong="H3196"\w* \w en|strong="H5921"\w* grandes copas, \w se|strong="H3808"\w* ungen \w con|strong="H5921"\w* \w los|strong="H5921"\w* mejores \w ungüentos|strong="H8081"\w* \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* afligen \w por|strong="H5921"\w* \w la|strong="H5921"\w* ruina \w de|strong="H5921"\w* \w José|strong="H3130"\w*.  
\v 7 \w Por|strong="H3651"\w* \w tanto|strong="H3651"\w*, \w ahora|strong="H6258"\w* serán llevados \w a|strong="H3068"\w* la \w cabeza|strong="H7218"\w* de los \w cautivos|strong="H1540"\w*, y cesará el banquete de los \w que|strong="H6258"\w* \w se|strong="H3651"\w* reclinan.   
\p
\v 8 \nd ʼAdonay \+w Yavé|strong="H3068"\+w*\nd* \w juró|strong="H7650"\w* por \w sí|strong="H5315"\w* mismo. \nd \+w Yavé|strong="H3068"\+w* ʼElohim\nd* de las huestes \w dijo|strong="H5002"\w*: \wj Repugno el orgullo de \+w Jacob|strong="H3290"\+w* y \+w aborrezco|strong="H8130"\+w* sus palacios. Entregaré la \+w ciudad|strong="H5892"\+w* al enemigo y todo cuanto hay en ella.\wj*   
\p
\v 9 \w Acontecerá|strong="H1961"\w* \w que|strong="H1961"\w* \w si|strong="H1961"\w* quedan \w diez|strong="H6235"\w* hombres en una \w casa|strong="H1004"\w*, \w morirán|strong="H4191"\w*.  
\v 10 Un pariente quemará \w a|strong="H3068"\w* cada uno \w para|strong="H3588"\w* sacar \w los|strong="H5973"\w* \w huesos|strong="H6106"\w* \w de|strong="H4480"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w*. Dirá \w al|strong="H4480"\w* \w que|strong="H3588"\w* está \w en|strong="H4480"\w* \w algún|strong="H5750"\w* rincón \w de|strong="H4480"\w* \w ella|strong="H4480"\w*: ¿Queda \w alguno|strong="H5750"\w* \w contigo|strong="H5973"\w*? \w Y|strong="H3068"\w* responderá: \w Ninguno|strong="H3808"\w*. \w Y|strong="H3068"\w* dirá: ¡Silencio! \w Porque|strong="H3588"\w* \w no|strong="H3808"\w* podemos mencionar \w el|strong="H5973"\w* \w Nombre|strong="H8034"\w* \w de|strong="H4480"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.   
\p
\v 11 \w Porque|strong="H3588"\w* \w ciertamente|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w ordena|strong="H6680"\w* \w que|strong="H3588"\w* \w la|strong="H3588"\w* mansión sea destrozada \w y|strong="H3588"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* reducida \w a|strong="H3068"\w* fragmentos.  
\v 12 ¿Galopan \w los|strong="H3588"\w* \w caballos|strong="H5483"\w* sobre las peñas? ¿Se \w ara|strong="H2790"\w* \w con|strong="H3588"\w* \w bueyes|strong="H1241"\w* \w en|strong="H3588"\w* \w el|strong="H3588"\w* mar? \w Pero|strong="H3588"\w* ustedes convierten \w el|strong="H3588"\w* \w juicio|strong="H4941"\w* \w en|strong="H3588"\w* \w veneno|strong="H7219"\w* \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w fruto|strong="H6529"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w justicia|strong="H6666"\w* \w en|strong="H3588"\w* ajenjo.  
\v 13 Ustedes, los \w que|strong="H3808"\w* \w se|strong="H3808"\w* \w alegran|strong="H8055"\w* con \w nada|strong="H3808"\w*, y dicen: ¿\w No|strong="H3808"\w* adquirimos poder con nuestra fuerza?   
\p
\v 14 \wj \+w Pues|strong="H3588"\+w* \+w mira|strong="H2005"\+w*, oh \+w Casa|strong="H1004"\+w* \+w de|strong="H5921"\+w* \+w Israel|strong="H3478"\+w*. \+w Yo|strong="H3588"\+w* \+w levanto|strong="H6965"\+w* \+w contra|strong="H5921"\+w* ustedes una \+w nación|strong="H1471"\+w* \+w que|strong="H3588"\+w* \+w los|strong="H5921"\+w* oprimirá \+w desde|strong="H5704"\+w* \+w la|strong="H5921"\+w* entrada \+w de|strong="H5921"\+w* Hamat \+w hasta|strong="H5704"\+w* \+w el|strong="H5921"\+w* \+w torrente|strong="H5158"\+w* \+w del|strong="H5921"\+w* Arabá, \wj*\w dice|strong="H5002"\w* \nd \+w Yavé|strong="H3068"\+w*, ʼElohim\nd* \w de|strong="H5921"\w* \w las|strong="H5921"\w* huestes.   
\c 7  
\s1 Langosta, fuego y plomada  
\p
\v 1 \nd ʼAdonay \+w Yavé|strong="H3068"\+w*\nd* \w me|strong="H3541"\w* \w mostró|strong="H7200"\w* \w esto|strong="H3541"\w*: \wj \+w Ciertamente|strong="H2009"\+w* Él formaba un enjambre de langostas cuando comenzaba \+w a|strong="H3068"\+w* brotar el pasto tardío. \+w Y|strong="H3068"\+w* \+w en|strong="H8462"\+w* verdad era el pasto tardío \+w que|strong="H3541"\+w* \+w viene|strong="H5927"\+w* después de la cosecha del \+w rey|strong="H4428"\+w*.\wj*  
\v 2 \w Aconteció|strong="H1961"\w* \w que|strong="H3588"\w* \w cuando|strong="H3588"\w* \w acababan|strong="H6965"\w* \w de|strong="H3588"\w* comer \w la|strong="H1931"\w* \w hierba|strong="H6212"\w* \w de|strong="H3588"\w* \w la|strong="H1931"\w* tierra, \w yo|strong="H3588"\w* dije: ¡\w Oh|strong="H4310"\w* \nd ʼAdonay \+w Yavé|strong="H3068"\+w*\nd*, \w te|strong="H3588"\w* \w ruego|strong="H4994"\w* \w que|strong="H3588"\w* perdones! ¿\w Cómo|strong="H3588"\w* podrá resistir \w Jacob|strong="H3290"\w*, \w que|strong="H3588"\w* \w es|strong="H1931"\w* \w tan|strong="H1931"\w* \w pequeño|strong="H6996"\w*?   
\p
\v 3 \nd \+w Yavé|strong="H3068"\+w*\nd* desistió \w de|strong="H5921"\w* \w esto|strong="H2063"\w*: \wj \+w No|strong="H3808"\+w* \+w será|strong="H1961"\+w*,\wj* dijo \nd \+w Yavé|strong="H3068"\+w*\nd*.   
\p
\v 4 \nd ʼAdonay \+w Yavé|strong="H3068"\+w*\nd* \w me|strong="H3541"\w* \w mostró|strong="H7200"\w*: \w Vi|strong="H7200"\w* \w que|strong="H3541"\w* \nd ʼAdonay \+w Yavé|strong="H3068"\+w*\nd* \w llamaba|strong="H7121"\w* \w a|strong="H3068"\w* \w contender|strong="H7378"\w* con fuego, \w y|strong="H3541"\w* consumió el \w gran|strong="H7227"\w* \w abismo|strong="H8415"\w*, \w y|strong="H3541"\w* devoraba la tierra.  
\v 5 \w Entonces|strong="H3588"\w* dije: ¡\w Oh|strong="H4310"\w* \nd ʼAdonay \+w Yavé|strong="H3068"\+w*\nd*, \w te|strong="H3588"\w* \w ruego|strong="H4994"\w* \w que|strong="H3588"\w* desistas! ¿\w Cómo|strong="H3588"\w* puede resistir \w Jacob|strong="H3290"\w*, \w que|strong="H3588"\w* \w es|strong="H1931"\w* \w tan|strong="H1931"\w* \w pequeño|strong="H6996"\w*?  
\v 6 \nd \+w Yavé|strong="H3068"\+w*\nd* desistió \w de|strong="H5921"\w* \w esto|strong="H2063"\w*: \wj \+w Tampoco|strong="H1571"\+w* \+w será|strong="H1961"\+w* \+w esto|strong="H2063"\+w*, dijo \+nd ʼAdonay \+w Yavé|strong="H3068"\+w*\+nd*.\wj*   
\p
\v 7 \w Me|strong="H5921"\w* \w mostró|strong="H7200"\w* \w esto|strong="H3541"\w*: \w Miré|strong="H7200"\w* \w que|strong="H5921"\w* \nd ʼAdonay\nd* \w estaba|strong="H5324"\w* \w en|strong="H5921"\w* pie \w sobre|strong="H5921"\w* un \w muro|strong="H2346"\w* vertical, \w con|strong="H5921"\w* una plomada \w en|strong="H5921"\w* su \w mano|strong="H3027"\w*.  
\v 8 \nd \+w Yavé|strong="H3068"\+w*\nd* me dijo: \wj ¿\+w Qué|strong="H4100"\+w* \+w ves|strong="H7200"\+w*, \+w Amós|strong="H5986"\+w*?\wj*  
\p \w Y|strong="H3068"\w* respondí: Una plomada.  
\p Entonces \nd ʼAdonay\nd* me dijo: \wj \+w Mira|strong="H7200"\+w*, Yo estoy \+w a|strong="H3068"\+w* punto \+w de|strong="H5750"\+w* aplicar la plomada \+w en|strong="H5750"\+w* \+w medio|strong="H7130"\+w* \+w de|strong="H5750"\+w* mi \+w pueblo|strong="H5971"\+w* \+w Israel|strong="H3478"\+w*. \+w No|strong="H3808"\+w* \+w lo|strong="H4100"\+w* soporto \+w más|strong="H5750"\+w*.\wj*  
\v 9 \wj \+w Los|strong="H5921"\+w* lugares \+w altos|strong="H1116"\+w* \+w de|strong="H5921"\+w* Isaac serán \+w destruidos|strong="H8074"\+w*, \+w las|strong="H5921"\+w* cosas sagradas \+w de|strong="H5921"\+w* \+w Israel|strong="H3478"\+w* serán desoladas, \+w y|strong="H5921"\+w* \+w me|strong="H5921"\+w* \+w levantaré|strong="H6965"\+w* \+w con|strong="H5921"\+w* \+w la|strong="H5921"\+w* \+w espada|strong="H2719"\+w* \+w contra|strong="H5921"\+w* \+w la|strong="H5921"\+w* \+w casa|strong="H1004"\+w* \+w de|strong="H5921"\+w* \+w Jeroboam|strong="H3379"\+w*.\wj*   
\p
\v 10 Entonces Amasías, \w sacerdote|strong="H3548"\w* \w de|strong="H5921"\w* Bet-ʼEl, \w envió|strong="H7971"\w* \w a|strong="H3068"\w* decir \w a|strong="H3068"\w* \w Jeroboam|strong="H3379"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*: \w Amós|strong="H5986"\w* conspira \w contra|strong="H5921"\w* \w ti|strong="H5921"\w* \w en|strong="H5921"\w* \w medio|strong="H7130"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w Casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*: \w la|strong="H5921"\w* tierra \w no|strong="H3808"\w* \w puede|strong="H3201"\w* soportar sus \w palabras|strong="H1697"\w*.  
\v 11 \w Porque|strong="H3588"\w* \w Amós|strong="H5986"\w* dijo: \w Jeroboam|strong="H3379"\w* \w morirá|strong="H4191"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w* \w e|strong="H3068"\w* \w Israel|strong="H3478"\w* \w saldrá|strong="H1540"\w* \w de|strong="H5921"\w* \w su|strong="H3588"\w* tierra \w en|strong="H5921"\w* cautiverio.   
\p
\v 12 \w Y|strong="H3068"\w* Amasías dijo \w a|strong="H3068"\w* \w Amós|strong="H5986"\w*: \w Vidente|strong="H2374"\w*, \w vé|strong="H3068"\w*, huye \w a|strong="H3068"\w* la tierra de \w Judá|strong="H3063"\w*. Come \w allí|strong="H8033"\w* tu \w pan|strong="H3899"\w* y \w profetiza|strong="H5012"\w* \w allí|strong="H8033"\w*,  
\v 13 \w pero|strong="H3588"\w* \w ya|strong="H3254"\w* \w no|strong="H3808"\w* vuelvas \w a|strong="H3068"\w* profetizar \w en|strong="H3588"\w* Bet-ʼEl, \w porque|strong="H3588"\w* \w es|strong="H1931"\w* \w santuario|strong="H4720"\w* del \w rey|strong="H4428"\w* \w y|strong="H3588"\w* capital del \w reino|strong="H4467"\w*.   
\p
\v 14 \w Pero|strong="H3588"\w* \w Amós|strong="H5986"\w* \w respondió|strong="H6030"\w* \w a|strong="H3068"\w* Amasías: \w No|strong="H3808"\w* soy \w profeta|strong="H5030"\w*, \w ni|strong="H3808"\w* \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* \w profeta|strong="H5030"\w*, \w sino|strong="H3588"\w* boyero \w y|strong="H3588"\w* cultivador \w de|strong="H3588"\w* higos silvestres.   
\p
\v 15 Pero \nd \+w Yavé|strong="H3068"\+w*\nd* me \w tomó|strong="H3947"\w* \w de|strong="H5971"\w* detrás del \w rebaño|strong="H6629"\w* y me dijo: \wj \+w Vé|strong="H3212"\+w*, \+w profetiza|strong="H5012"\+w* \+w a|strong="H3068"\+w* mi \+w pueblo|strong="H5971"\+w* \+w Israel|strong="H3478"\+w*.\wj*   
\p
\v 16 \w Ahora|strong="H6258"\w* \w pues|strong="H6258"\w*, \w escucha|strong="H8085"\w* \w la|strong="H5921"\w* \w Palabra|strong="H1697"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*: Tú \w dices|strong="H1697"\w*: \w No|strong="H3808"\w* \w profetices|strong="H5012"\w* \w contra|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w ni|strong="H3808"\w* prediques \w contra|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* Isaac.  
\v 17 \w Por|strong="H5921"\w* \w tanto|strong="H3651"\w*, \nd \+w Yavé|strong="H3068"\+w*\nd* dice: \wj Tu esposa \+w se|strong="H5921"\+w* prostituirá \+w en|strong="H5921"\+w* \+w la|strong="H5921"\+w* \+w ciudad|strong="H5892"\+w*, tus \+w hijos|strong="H1121"\+w* \+w y|strong="H5921"\+w* tus \+w hijas|strong="H1323"\+w* \+w caerán|strong="H5307"\+w* \+w a|strong="H3068"\+w* \+w espada|strong="H2719"\+w*, tu tierra será repartida \+w a|strong="H3068"\+w* cordel \+w y|strong="H5921"\+w* tú \+w morirás|strong="H4191"\+w* \+w en|strong="H5921"\+w* tierra impura. \+w Israel|strong="H3478"\+w* \+w ciertamente|strong="H4191"\+w* irá \+w de|strong="H5921"\+w* su tierra \+w al|strong="H5921"\+w* exilio.\wj*   
\c 8  
\s1 La fruta de verano  
\p
\v 1 \nd ʼAdonay \+w Yavé|strong="H3068"\+w*\nd* \w me|strong="H3541"\w* \w mostró|strong="H7200"\w*: \wj \+w Mira|strong="H7200"\+w* ahí una cesta con frutas de \+w verano|strong="H7019"\+w*.\wj*   
\p
\v 2 \w Y|strong="H3068"\w* dijo: \wj ¿\+w Qué|strong="H4100"\+w* \+w ves|strong="H7200"\+w*, \+w Amós|strong="H5986"\+w*?\wj*  
\p \w Y|strong="H3068"\w* respondí: Una cesta con frutas \w de|strong="H5750"\w* \w verano|strong="H7019"\w*.  
