\id JER
\h Knjiga proroka Jeremije
\toc1 Knjiga proroka Jeremije
\toc2 Jeremija
\toc3 Jer
\mt1 Knjiga proroka Jeremije
\c 1
\s1 Jeremija pozvan za proroka.
\p 
\v 1 Reči Jeremije, sina Helkijinog, između sveštenika koji behu u Anatotu u zemlji Venijaminovoj,
\v 2 kome dođe reč Gospodnja u vreme Josije sina Amonovog, cara Judinog, trinaeste godine carovanja njegovog,
\v 3 i u vreme Joakima sina Josijinog, cara Judinog, do svršetka jedanaeste godine carovanja Sedekije sina Josijinog nad Judom, dok ne bi preseljen Jerusalim, petog meseca.
\b
\p 
\v 4 I dođe mi reč Gospodnja govoreći:
\b
\q1 
\v 5 Pre nego te sazdah u utrobi, znah te;
\q2 i pre nego iziđe iz utrobe, posvetih te;
\q2 za proroka narodima postavih te.
\b
\p 
\v 6 A ja rekoh: Oh, Gospode, Gospode! Evo, ne znam govoriti, jer sam dete.
\v 7 A Gospod mi reče:
\b
\q1 Ne govori: Dete sam;
\q2 nego idi kuda te god pošaljem,
\q2 i govori šta ti god kažem.
\q1 
\v 8 Ne boj ih se,
\q2 jer sam ja s tobom da te izbavljam,
\q2 govori Gospod.
\b
\p 
\v 9 I pruživši Gospod ruku svoju dotače se usta mojih, i reče mi Gospod:
\b
\q1 Eto, metnuh reči svoje u tvoja usta.
\q1 
\v 10 Vidi, postavljam te danas nad narodima i carstvima
\q2 da istrebljuješ i obaraš,
\q1 i da zatireš i raskopavaš,
\q2 i da gradiš i da sadiš.
\b
\p 
\v 11 Posle mi dođe reč Gospodnja govoreći: Šta vidiš, Jeremija? I rekoh: Vidim prut bademov.
\v 12 Tada mi reče Gospod: Dobro si video, jer ću nastati oko reči svoje da je izvršim.
\p 
\v 13 Opet mi dođe reč Gospodnja drugom govoreći: Šta vidiš? I rekoh: Vidim lonac gde vri, i prednja mu je strana prema severu.
\v 14 Tada mi reče Gospod: Sa severa će navaliti zlo na sve stanovnike ove zemlje.
\v 15 Jer, gle, ja ću sazvati sve porodice iz severnih carstava, veli Gospod, te će doći, i svaki će metnuti svoj presto na vratima jerusalimskim i oko svih zidova njegovih i oko svih gradova Judinih.
\v 16 I izreći ću im sud svoj za svu zloću njihovu što me ostaviše, i kadiše drugim bogovima, i klanjaše se delu ruku svojih.
\v 17 Ti dakle opaši se i ustani i govori im sve što ću ti zapovediti; ne boj ih se, da te ne bih satro pred njima.
\v 18 Jer evo ja te postavljam danas kao tvrd grad i kao stup gvozden i kao zidove bronzane svoj ovoj zemlji, carevima Judinim i knezovima njegovim i sveštenicima njegovim i narodu zemaljskom.
\v 19 Oni će udariti na te, ali te neće nadvladati, jer sam ja s tobom, veli Gospod, da te izbavljam.
\c 2
\s1 Izrailjeva nezahvalnost i kazna.
\p 
\v 1 Opet mi dođe reč Gospodnja govoreći:
\v 2 Idi i viči Jerusalimu da čuje i govori: Ovako veli Gospod:
\b
\q1 Opominjem te se po milosti u mladosti tvojoj
\q2 i po ljubavi o veridbi tvojoj,
\q1 kad iđaše za mnom po pustinji,
\q2 i po zemlji gde se ne seje.
\q1 
\v 3 Izrailj beše svetinja Gospodu
\q2 i prvina od rodova Njegovih;
\q1 koji je jeđahu svi behu krivi,
\q2 zlo dolažaše na njih,
\q2 veli Gospod.
\b
\p 
\v 4 Čujte reč Gospodnju, dome Jakovljev i sve porodice doma Izrailjevog.
\v 5 Ovako veli Gospod:
\b
\q1 Kakvu nepravdu nađoše oci vaši u mene,
\q2 te odstupiše od mene,
\q1 i pristaše za ništavilom,
\q2 i postaše ništavi?
\q1 
\v 6 I ne rekoše:
\q1 Gde je Gospod koji nas je izveo iz zemlje misirske,
\q2 koji nas je vodio po pustinji,
\q1 po zemlji pustoj i punoj propasti,
\q2 po zemlji suvoj i gde je sen smrtni,
\q1 po zemlji preko koje niko nije hodio
\q2 i u kojoj niko nije živeo?
\q1 
\v 7 I kad vas dovedoh u zemlju rodnu
\q2 da jedete rod njen i dobra njena,
\q1 došavši oskvrniste zemlju moju
\q2 i od nasledstva mog načiniste gad.
\q1 
\v 8 Sveštenici ne rekoše:
\q2 Gde je Gospod?
\q1 I koji se bave zakonom ne poznaše me,
\q2 i pastiri odustaše me,
\q1 i proroci prorokovaše Valom
\q2 i idoše za stvarima zaludnim.
\b
\q1 
\v 9 Za to ću se još preti s vama, veli Gospod,
\q2 i sa sinovima sinova vaših preću se.
\q1 
\v 10 Jer prođite ostrva kitimska i vidite
\q2 i pošljite u Kidar, i razgledajte dobro,
\q2 i vidite, je li bilo takvo šta:
\q1 
\v 11 Je li koji narod promenio bogove, ako i nisu bogovi?
\q2 A moj narod promeni slavu svoju na stvar zaludnu.
\q1 
\v 12 Čudite se tome, nebesa,
\q2 i zgrozite se i upropastite se!
\q2 Veli Gospod.
\q1 
\v 13 Jer dva zla učini moj narod:
\q2 ostaviše mene, izvor žive vode,
\q2 i iskopaše sebi studence,
\q1 studence isprovaljivane,
\q2 koji ne mogu da drže vode.
\b
\q1 
\v 14 Je li Izrailj rob?
\q2 Je li rob u kući rođen?
\q2 Zašto posta grabež?
\q1 
\v 15 Rikaše na nj lavići i dizaše glas svoj,
\q2 i obratiše zemlju njegovu u pustoš;
\q1 gradovi su mu popaljeni,
\q2 te nema nikoga da živi u njima.
\q1 
\v 16 I sinovi nofski i tafneski opasoše ti teme.
\q1 
\v 17 Nisi li to sam sebi učinio
\q2 ostavivši Gospoda Boga svog kad te vođaše putem?
\q1 
\v 18 A sada šta će ti put misirski da piješ vode siorske?
\q2 Šta li će ti put asirski da piješ vode iz reke?
\q1 
\v 19 Tvoja će te zloća pokarati
\q2 i tvoje će te odmetanje prekoriti.
\q1 Poznaj dakle i vidi
\q2 da je zlo i gorko što si ostavio Gospoda Boga svog
\q1 i što nema straha mog u tebi,
\q2 veli Gospod Gospod nad vojskama.
\b
\q1 
\v 20 Jer davno izlomih jaram tvoj
\q2 i raskidoh sveze tvoje,
\q1 i ti reče: Neću biti sluga;
\q2 a na svaki visoki hum i pod svako zeleno drvo ideš da se kurvaš.
\q1 
\v 21 Ja te posadih, lozu izabranu, sve seme istinito;
\q2 pa kako mi se promeni i izmetnu se odvoda od tuđe loze?
\q1 
\v 22 Da se izmiješ salitrom i uzmeš mnogo sapuna,
\q2 opet će se poznavati bezakonje tvoje preda mnom,
\q1 veli Gospod Gospod.
\q1 
\v 23 Kako možeš reći:
\q1 Nisam se oskvrnio,
\q2 nisam išao za Valima?
\q1 Pogledaj put svoj po dolu;
\q2 poznaj šta si učinila, brza kamilo,
\q2 koja ostavljaš znake na svojim putevima.
\q1 
\v 24 Kao divlja magarica,
\q2 koja je navikla na pustinju
\q2 i po želji duše svoje vuče u se vetar,
\q1 kad navali, ko će je vratiti?
\q2 Koji je traže neće se umoriti,
\q2 naći će je u mesecu njenom.
\q1 
\v 25 Čuvaj nogu svoju, da nije bosa,
\q2 i grlo svoje, da ne žedni.
\q1 Ali ti veliš:
\q2 Od toga nema ništa;
\q2 ne, jer ljubim tuđe, i za njima ću ići.
\b
\q1 
\v 26 Kao što se lupež posrami kad se uhvati,
\q2 tako će se posramiti dom Izrailjev,
\q2 oni, carevi njihovi, knezovi njihovi, i sveštenici njihovi i proroci njihovi,
\q1 
\v 27 Koji govore drvetu: Ti si otac moj;
\q2 i kamenu: Ti si me rodio;
\q1 jer mi okrenuše leđa, a ne lice;
\q2 a kad su u nevolji govore: Ustani i izbavi nas.
\q1 
\v 28 A gde su bogovi tvoji koje si načinio sebi?
\q2 Neka ustanu, ako te mogu izbaviti kad si u nevolji,
\q2 jer imaš, Juda, bogova koliko gradova.
\b
\q1 
\v 29 Zašto hoćete da se pravdate sa mnom?
\q2 Vi ste se svi odmetnuli od mene,
\q2 veli Gospod.
\q1 
\v 30 Uzalud bih sinove vaše, ne primiše nauke;
\q2 mač vaš proždre proroke vaše kao lav koji davi.
\q1 
\v 31 O rode! Vidite reč Gospodnju;
\q2 bejah li pustinja Izrailju ili mračna zemlja?
\q1 Zašto govori moj narod:
\q2 Gospodari smo, nećemo više doći k tebi?
\q1 
\v 32 Zaboravlja li devojka svoj nakit i nevesta ures svoj?
\q2 A narod moj zaboravi me toliko dana da im nema broja.
\b
\q1 
\v 33 Zašto govoriš da je dobar tvoj put tražeći šta ljubiš?
\q2 Pa si i nevaljale žene naučio svojim putevima.
\q1 
\v 34 I još na skutovima tvojim nalazi se krv siromaha pravih;
\q2 ne nalazim kopajući, nego je na svima njima.
\q1 
\v 35 A ti govoriš: Nisam kriv,
\q2 gnev se Njegov odvratio od mene.
\q1 Evo ja ću se preti s tobom
\q2 što govoriš: Nisam zgrešio.
\q1 
\v 36 Zašto trčkaš tako menjajući svoj put?
\q2 Posramićeš se od Misirca kako si se posramio od Asirca.
\q1 
\v 37 Otići ćeš i odatle s rukama nad glavom svojom,
\q2 jer Gospod odbacuje uzdanice tvoje,
\q2 i nećeš biti srećan u njima.
\c 3
\s1 Poziv na pokajanje. Obricanje Božije milosti.
\q1 
\v 1 Govore: Ako ko pusti ženu svoju,
\q2 i ona otišavši od njega uda se za drugog,
\q2 hoće li se onaj vratiti k njoj?
\q1 Ne bi li se sasvim oskvrnila ona zemlja?
\q2 A ti si se kurvala s mnogim milosnicima;
\q2 ali opet vrati se k meni, veli Gospod.
\q1 
\v 2 Podigni oči svoje k visinama,
\q2 i pogledaj gde se nisi kurvala;
\q1 na putevima si sedela čekajući ih kao Arapin u pustinji,
\q2 i oskvrnila si zemlju kurvarstvom svojim i zloćom svojom.
\q1 
\v 3 Zato se ustaviše daždi,
\q2 i ne bi poznog dažda;
\q1 ali u tebe beše čelo žene kurve,
\q2 i ne hte se stideti.
\q1 
\v 4 Hoćeš li odsele vikati k meni:
\q2 Oče moj, Ti si vođ mladosti moje?
\q1 
\v 5 Hoće li se srditi jednako?
\q2 Hoće li se gneviti do veka?
\q1 Eto, govoriš, a činiš zlo koliko god možeš.
\b
\p 
\v 6 Još mi reče Gospod za vremena cara Josije: Jesi li video šta učini odmetnica, Izrailj? Kako odlazi na svako visoko brdo i pod svako zeleno drvo, i kurva se onde.
\v 7 I, pošto učini sve to, rekoh: Vrati se k meni; ali se ne vrati; i to vide nevernica, sestra njena, Juda.
\v 8 I svide mi se za sve to što učini preljubu odmetnica Izrailj da je pustim i dam joj knjigu raspusnu; ali se ne poboja nevernica sestra joj Juda, nego otide, te se i ona prokurva.
\v 9 I sramotnije kurvanjem svojim oskvrni zemlju, jer činjaše preljubu s kamenom i s drvetom.
\v 10 I kod svega toga ne vrati se k meni nevernica sestra joj Juda svim srcem svojim, nego lažno, govori Gospod.
\p 
\v 11 Za to mi reče Gospod: Odmetnica Izrailj opravda se više nego nevernica Juda.
\v 12 Idi i viči ove reči k severu, i reci:
\b
\q1 Vrati se, odmetnice Izrailju,
\q2 veli Gospod,
\q1 i neću pustiti da padne gnev moj na vas,
\q2 jer sam milostiv,
\q1 veli Gospod,
\q2 neću se gneviti do veka.
\q1 
\v 13 Samo poznaj bezakonje svoje,
\q2 da si se odmetnula Gospodu Bogu svom,
\q1 te si tumarala k tuđima pod svako drvo zeleno,
\q2 i niste slušali glas moj,
\q2 veli Gospod.
\q1 
\v 14 Obratite se, sinovi odmetnici,
\q2 veli Gospod,
\q1 jer sam ja muž vaš,
\q2 i uzeću vas, jednog iz grada i dva iz porodice,
\q2 i odvešću vas u Sion.
\b
\p 
\v 15 I daću vam pastire po srcu svom, koji će vas pasti znanjem i razumom.
\v 16 I kad se umnožite i narodite u zemlji, onda se, veli Gospod, neće više govoriti: Kovčeg zaveta Gospodnjeg; niti će im dolaziti na um niti će ga pominjati, niti će hoditi k njemu, niti će ga više opravljati.
\v 17 U to će se vreme Jerusalim zvati presto Gospodnji, i svi će se narodi sabrati u nj, k imenu Gospodnjem u Jerusalimu, i neće više ići po misli srca svog zlog.
\v 18 U to će vreme dom Judin ići s domom Izrailjevim, i doći će zajedno iz zemlje severne u zemlju koju dadoh u nasledstvo ocima vašim.
\b
\q1 
\v 19 Ali ja rekoh:
\q1 Kako bih te postavio među sinove
\q2 i dao ti zemlju željenu,
\q2 krasno nasledstvo mnoštva naroda?
\q1 I rekoh: Ti ćeš me zvati: Oče moj;
\q2 i nećeš se odvratiti od mene.
\q1 
\v 20 Doista kao što žena izneveri druga svog,
\q2 tako izneveriste mene, dome Izrailjev,
\q2 veli Gospod.
\b
\q1 
\v 21 Glas po visokim mestima neka se čuje,
\q2 plač, molbe sinova Izrailjevih,
\q1 jer prevratiše put svoj,
\q2 zaboraviše Gospoda Boga svog.
\q1 
\v 22 Vratite se, sinovi odmetnici,
\q2 i isceliću odmete vaše.
\q1 Evo, mi idemo k Tebi,
\q2 jer si Ti Gospod Bog naš.
\q1 
\v 23 Doista, zaludu su humovi, mnoštvo gora;
\q2 doista, u Gospodu je Bogu našem spasenje Izrailjevo.
\b
\p 
\v 24 Jer ta sramota proždre trud otaca naših od detinjstva našeg, ovce njihove i goveda njihova, sinove njihove i kćeri njihove.
\v 25 Ležimo u sramoti svojoj, i pokriva nas rug naš; jer Gospodu Bogu svom grešismo mi i oci naši od detinjstva svog do danas, i ne slušasmo glas Gospoda Boga svog.
\c 4
\s1 Ponovna beseda radi pokajanja. Proricanje o pustošenju Judejske zemlje. Žalost prorokova.
\q1 
\v 1 Ako ćeš se vratiti, Izrailju, veli Gospod, k meni se vrati,
\q2 i ako ukloniš gadove svoje ispred mene, nećeš se skitati.
\q1 
\v 2 I klećeš se istinito, verno i pravo: Tako da je živ Gospod.
\q2 I narodi će se blagosiljati Njim, i Njim će se hvaliti.
\b
\p 
\v 3 Jer ovako veli Gospod Judejcima i Jerusalimljanima:
\b
\q1 orite sebi krčevinu,
\q2 i ne sejte u trnje.
\q1 
\v 4 Obrežite se Gospodu,
\q2 i skinite okrajak sa srca svog,
\q2 Judejci i Jerusalimljani,
\q1 da ne iziđe jarost moja kao oganj
\q2 i razgori se da ne bude nikoga ko bi ugasio
\q2 za zla dela vaša.
\b
\p 
\v 5 Objavite u Judeji i oglasite u Jerusalimu i recite:
\b
\q1 trubite u trubu po zemlji;
\q2 vičite, sazovite narod i recite:
\q2 Skupite se, i uđimo u tvrde gradove.
\q1 
\v 6 Podignite zastavu prema Sionu, bežite i ne stajte,
\q2 jer ću dovesti zlo od severa i pogibao veliku.
\q1 
\v 7 Izlazi lav iz česte svoje
\q2 i koji zatire narode krenuvši se ide s mesta svog
\q1 da obrati zemlju tvoju u pustoš,
\q2 gradovi tvoji da se raskopaju da ne bude nikoga u njima.
\q1 
\v 8 Za to pripašite kostret, plačite i ridajte,
\q2 jer se žestoki gnev Gospodnji nije odvratio od nas.
\b
\p 
\v 9 I tada će, veli Gospod, nestati srca caru i srca knezovima, i sveštenici će se udiviti i proroci će se začuditi.
\v 10 I rekoh: Ah Gospode Gospode! Baš si prevario ovaj narod i Jerusalim govoreći: Imaćete mir, a mač dođe do duše.
\p 
\v 11 U to će se vreme kazati ovom narodu i Jerusalimu: Vetar vruć s visokih mesta u pustinji duva ka kćeri naroda mog, ne da proveje ni pročisti.
\v 12 Vetar jači od tih doći će mi; i ja ću im sada izreći sud.
\b
\q1 
\v 13 Gle, kao oblak podiže se,
\q2 i kola su mu kao vihor, konji su mu brži od orlova.
\q2 Teško nama! Propadosmo.
\q1 
\v 14 Umij srce svoje od zla, Jerusalime, da bi se izbavio;
\q2 dokle će stajati u tebi misli tvoje ništave?
\q1 
\v 15 Jer glas javlja od Dana,
\q2 i oglašuje zlo od gore Jefremove.
\q1 
\v 16 Kazujte narodima;
\q2 evo oglašujte za Jerusalim
\q1 da idu stražari iz daleke zemlje,
\q2 i puštaju glas svoj na gradove Judine.
\q1 
\v 17 Kao čuvari poljski staće oko njega,
\q2 jer se odmetnu od mene,
\q2 veli Gospod.
\q1 
\v 18 Put tvoj i dela tvoja to ti učiniše;
\q2 to je od zla tvog da je gorko i da ti dopire do srca.
\b
\q1 
\v 19 Jaoh utroba, jaoh utroba!
\q2 Boli me u srcu; srce mi bije;
\q1 ne mogu ćutati;
\q2 jer glas trubni čuješ, dušo moja, viku ubojnu.
\q1 
\v 20 Pogibao na pogibao oglašuje se;
\q2 jer se pustoši sva zemlja,
\q1 najedanput će se opustošiti moji šatori,
\q2 zavesi moji za čas.
\q1 
\v 21 Dokle ću gledati zastavu?
\q2 Slušati glas trubni?
\b
\q1 
\v 22 Jer je narod moj bezuman, ne poznaje me,
\q2 ludi su sinovi i bez razuma,
\q1 mudri su da zlo čine,
\q2 a dobro činiti ne umeju.
\b
\q1 
\v 23 Pogledah na zemlju, a gle bez obličja je i pusta;
\q2 i na nebo, a svetlosti njegove nema.
\q1 
\v 24 Pogledah na gore,
\q2 a gle, tresu se i svi humovi drmaju se.
\q1 
\v 25 Pogledah, a gle, nema čoveka,
\q2 i sve ptice nebeske odletele.
\q1 
\v 26 Pogledah, a gle, Karmil je pustinja
\q2 i svi gradovi njegovi oboreni od Gospoda,
\q2 od žestokog gneva Njegovog.
\b
\p 
\v 27 Jer ovako govori Gospod:
\b
\q1 Sva će zemlja opusteti;
\q2 ali neću sasvim zatrti.
\q1 
\v 28 Zato će tužiti zemlja, i nebo će gore potamneti,
\q2 jer rekoh, namislih, i neću se raskajati, niti ću udariti natrag.
\b
\q1 
\v 29 Od vike konjika i strelaca pobeći će svi gradovi,
\q2 otići će u guste šume i na stene će se popeti;
\q1 svi će gradovi biti ostavljeni
\q2 i niko neće u njima živeti.
\q1 
\v 30 A ti, opustošena, šta ćeš činiti?
\q1 Ako se i oblačiš u skerlet,
\q2 ako se i kitiš nakitom zlatnim,
\q2 i mažeš lice svoje,
\q1 zaludu se krasiš,
\q2 preziru te milosnici, traže dušu tvoju.
\q1 
\v 31 Jer čujem glas kao porodiljin,
\q2 cviljenje kao žene koja se prvi put porađa,
\q1 glas kćeri sionske, koja rida,
\q2 pruža ruke svoje govoreći:
\q1 Teško meni! Jer mi nestaje duša od ubilaca.
\c 5
\s1 Različiti gresi judejskog naroda i pretnja kaznama zbog njih.
\q1 
\v 1 Prođite po ulicama jerusalimskim,
\q2 i vidite sada i razberite i potražite po ulicama njegovim,
\q1 hoćete li naći čoveka, ima li ko da čini što je pravo i da traži istinu,
\q2 pa ću oprostiti.
\q1 
\v 2 Ako i govore: Tako da je živ Gospod!
\q2 Opet se krivo kunu.
\q1 
\v 3 Gospode! Ne gledaju li oči Tvoje na istinu!
\q1 Biješ ih, ali ih ne boli;
\q2 satireš ih, ali neće da prime nauke,
\q1 tvrđe im je lice od kamena, neće da se obrate.
\b
\q1 
\v 4 I ja rekoh: Siromasi su,
\q2 ludo rade, jer ne znaju put Gospodnji, zakon Boga svog.
\q1 
\v 5 Idem k vlasteljima, i njima ću govoriti,
\q2 jer oni znaju put Gospodnji, zakon Boga svog;
\q1 ali i oni izlomiše jaram, pokidaše sveze.
\b
\q1 
\v 6 Za to će ih pobiti lav iz šume,
\q2 vuk će ih večernji potrti,
\q2 ris će vrebati kod gradova njihovih,
\q1 ko god iziđe iz njih biće rastrgnut,
\q2 jer je mnogo greha njihovih
\q2 i silni su odmeti njihovi.
\b
\q1 
\v 7 Kako ću ti oprostiti to?
\q2 Sinovi tvoji ostaviše mene,
\q2 i kunu se onima koji nisu bogovi.
\q1 Kako ih nasitih, stadoše činiti preljubu,
\q2 i u kuću kurvinu stiču se gomilom.
\q1 
\v 8 Jutrom su kad ustaju kao tovni konji,
\q2 svaki rže za ženom bližnjeg svog.
\q1 
\v 9 Za to li neću pohoditi? Veli Gospod,
\q2 i duša moja neće li se osvetiti takvom narodu?
\b
\q1 
\v 10 Izađite mu na zidove i razvalite,
\q2 ali nemojte sasvim zatrti,
\q1 skinite mu prevornice,
\q2 jer nisu Gospodnje.
\q1 
\v 11 Jer me sasvim izneveri dom Izrailjev i dom Judin,
\q2 veli Gospod.
\q1 
\v 12 Udariše u bah Gospodu i rekoše:
\q2 Nije tako, neće nas zlo zadesiti,
\q2 i nećemo videti mača ni gladi.
\q1 
\v 13 A ti proroci otići će u vetar,
\q2 i reči nema u njima,
\q2 njima će biti tako.
\b
\q1 
\v 14 Zato ovako veli Gospod Gospod nad vojskama:
\q1 Kad tako govorite,
\q2 evo ja ću učiniti da reči moje u ustima tvojim budu kao oganj,
\q2 a ovaj narod drva, te će ih spaliti.
\q1 
\v 15 Gle, ja ću dovesti na vas narod iz daleka, dome Izrailjev, veli Gospod,
\q2 narod jak, narod star, narod kome jezika nećeš znati niti ćeš razumeti šta govori;
\q1 
\v 16 Kome je tul kao grob otvoren,
\q2 svi su jaki.
\q1 
\v 17 I poješće letinu tvoju i hleb tvoj,
\q2 što sinovi tvoji i kćeri tvoje hteše jesti,
\q1 poješće ovce tvoje i goveda tvoja,
\q2 poješće vinovu lozu tvoju i smokve tvoje,
\q1 i mačem će zatrti tvrde gradove tvoje u koje se uzdaš.
\b
\p 
\v 18 Ali ni tada, veli Gospod, neću vas sasvim zatrti.
\v 19 Jer kad kažete: Zašto nam čini Gospod Bog naš sve ovo? Tada im reci: Kako ostaviste mene i služiste tuđim bogovima u zemlji svojoj, tako ćete služiti tuđincima u zemlji koja nije vaša.
\b
\q1 
\v 20 Javite ovo u domu Jakovljevom, i oglasite u Judi,
\q2 govoreći:
\q1 
\v 21 Čujte ovo, ludi i bezumni narode,
\q2 koji imate oči, a ne vidite,
\q2 koji imate uši, a ne čujete.
\q1 
\v 22 Mene li se nećete bojati?
\q2 Veli Gospod;
\q1 od mene li nećete drhtati?
\q2 Koji postavih pesak moru za među večnom naredbom,
\q2 i neće preći preko nje;
\q1 ako mu i ustaju vali, neće nadjačati,
\q2 ako i buče, neće je preći.
\q1 
\v 23 Ali je u naroda ovog srce uporno i nepokorno;
\q2 odstupiše i otidoše.
\q1 
\v 24 Niti rekoše u srcu svom:
\q2 Bojmo se Gospoda Boga svog,
\q1 koji nam daje dažd rani i pozni na vreme,
\q2 i čuva nam nedelje određene za žetvu.
\q1 
\v 25 Bezakonja vaša odvraćaju to,
\q2 i gresi vaši odbijaju dobro od vas.
\q1 
\v 26 Jer se nalaze u narodu mom bezbožnici,
\q2 koji vrebaju kao ptičari kad se pritaje,
\q2 meću zamke da hvataju ljude.
\q1 
\v 27 Kao krletka puna ptica tako su kuće njihove pune prevare;
\q2 zato postaše veliki i obogatiše.
\q1 
\v 28 Ugojiše se, sjaju se,
\q2 mimoilaze zlo,
\q1 ne čine pravde ni siročetu, i opet im je dobro,
\q2 i ne daju pravice ubogima.
\q1 
\v 29 Zato li neću pohoditi? Veli Gospod,
\q2 i duša moja neće li se osvetiti takvom narodu?
\b
\q1 
\v 30 Čudo i strahota biva u zemlji.
\q1 
\v 31 Proroci prorokuju lažno,
\q2 i sveštenici gospoduju preko njih,
\q1 i narodu je mom to milo.
\q2 A šta ćete raditi na posledak?
\c 6
\s1 Na narod pouzdan dolaze strašni neprijatelji.
\q1 
\v 1 Skupite se iz Jerusalima, sinovi Venijaminovi,
\q2 i u Tekuji zatrubite u trubu,
\q1 i podignite znak ognjen nad Vet-Akeremom,
\q2 jer se vidi zlo od severa i velika pogibao.
\q1 
\v 2 Učinih kćer sionsku da je kao lepa i nežna devojka.
\q1 
\v 3 K njoj će doći pastiri sa stadima svojim,
\q2 razapeće oko nje šatore,
\q2 svaki će opasti svoje mesto.
\q1 
\v 4 Spremite rat na nju,
\q2 ustanite da udarimo u podne.
\q1 Teško nama,
\q2 jer dan naže, i senke večernje oduljaše.
\q1 
\v 5 Ustanite da udarimo obnoć
\q2 i razvalimo dvorove njene.
\b
\q1 
\v 6 Jer ovako govori Gospod nad vojskama:
\q1 Secite drva, i načinite opkope prema Jerusalimu;
\q2 to je grad koji treba pohoditi;
\q2 koliki je god, nasilje je u njemu.
\q1 
\v 7 Kao što izvor toči vodu svoju, tako on toči zloću svoju;
\q2 nasilje i otimanje čuje se u njemu,
\q2 preda mnom su jednako bolovi i rane.
\q1 
\v 8 Popravi se, Jerusalime,
\q2 da se ne otrgne duša moja od tebe,
\q1 da te ne obratim u pustinju,
\q2 u zemlju gde se ne živi.
\b
\q1 
\v 9 Ovako govori Gospod nad vojskama:
\q1 Ostatak će se Izrailjev pabirčiti kao vinova loza.
\q2 Turaj ruku svoju kao berač u kotarice.
\q1 
\v 10 Kome ću govoriti i svedočiti da čuju?
\q2 Gle, uho im je neobrezano, te ne mogu čuti;
\q2 gle, reč je Gospodnja njima podsmeh, nije im mila.
\q1 
\v 11 Za to sam pun gneva Gospodnjeg;
\q2 iznemogoh ustežući ga;
\q1 prosuću ga na decu po ulicama i na sabrane mladiće,
\q2 i čovek i žena uhvatiće se, i stari i vremeniti.
\q1 
\v 12 I kuće će njihove pripasti drugima, i njive i žene,
\q2 kad mahnem rukom svojom na stanovnike ove zemlje,
\q2 veli Gospod.
\q1 
\v 13 Jer od malog do velikog svi se dadoše na lakomstvo,
\q2 i prorok i sveštenik, svi su varalice.
\q1 
\v 14 I leče rane kćeri naroda mog ovlaš,
\q2 govoreći: Mir, mir;
\q2 a mira nema.
\q1 
\v 15 Eda li se postideše što činiše gad?
\q2 Niti se postideše niti znaju za stid;
\q1 za to će popadati među onima koji padaju;
\q2 kad ih pohodim, popadaće,
\q2 veli Gospod.
\b
\q1 
\v 16 Gospod reče ovako:
\q1 Stanite na putevima i pogledajte,
\q2 i pitajte za stare staze, koji je put dobar,
\q1 pa idite po njemu, i naći ćete mir duši svojoj.
\q2 A oni rekoše: Nećemo da idemo.
\q1 
\v 17 I postavih vam stražare govoreći:
\q1 Pazite na glas trubni.
\q2 A oni rekoše: Nećemo da pazimo.
\q1 
\v 18 Zato čujte, narodi, i poznaj, zbore,
\q2 šta je među njima.
\q1 
\v 19 Čuj, zemljo!
\q1 Evo ja ću pustiti zlo na ovaj narod,
\q2 plod misli njihovih,
\q1 jer ne paze na moje reči,
\q2 i odbaciše zakon moj.
\q1 
\v 20 Šta će mi tamjan, što dolazi iz Save,
\q2 i dobri cimet iz daleke zemlje?
\q1 Žrtve vaše paljenice nisu mi ugodne,
\q2 niti su mi prinosi vaši mili.
\q1 
\v 21 Zato ovako govori Gospod:
\q1 Evo ja ću metnuti ovom narodu smetnje,
\q2 o koje će se spotaći i očevi i sinovi, sused i prijatelj mu,
\q2 i poginuće.
\b
\q1 
\v 22 Ovako govori Gospod:
\q1 Evo narod će doći iz zemlje severne,
\q2 i velik će narod ustati od krajeva zemaljskih.
\q1 
\v 23 Luk i koplje nosiće,
\q2 žestoki će biti i nemilostivi,
\q1 glas će im bučati kao more,
\q2 i jahaće na konjima,
\q1 spremni kao junaci da se biju s tobom,
\q2 kćeri sionska.
\q1 
\v 24 Kad čujemo glas o njemu, klonuće nam ruke,
\q2 tuga će nas spopasti i bolovi kao porodilju.
\q1 
\v 25 Ne izlazite u polje, i putem ne idite,
\q2 jer je mač neprijateljev i strah unaokolo.
\q1 
\v 26 Kćeri naroda mog,
\q2 pripaši kostret i valjaj se u pepelu,
\q1 žali kao za sinom jedincem i ridaj gorko,
\q2 jer će brzo doći na nas zatirač.
\b
\q1 
\v 27 Postavih te da si stražara i grad narodu mom
\q2 da doznaješ i izviđaš put njihov.
\q1 
\v 28 Svi su odmetnici nad odmetnicima, idu te opadaju,
\q2 bronza su i gvožđe, svi su pokvareni.
\q1 
\v 29 Izgoreše mehovi,
\q2 oganj sažeže olovo,
\q1 uzalud se pretapa,
\q2 jer se zla ne mogu odlučiti.
\q1 
\v 30 Oni će se zvati srebro lažno,
\q2 jer ih Gospod odbaci.
\c 7
\s1 Samo spoljašnje služenje Bogu bez kajanja gadno je pred Bogom i ne može podneti sud.
\p 
\v 1 Reč koja dođe Jeremiji od Gospoda govoreći:
\v 2 Stani na vratima doma Gospodnjeg, i oglasi onde ovu reč, i reci: Čujte reč Gospodnju, svi Judejci, koji ulazite na ova vrata da se poklonite Gospodu.
\v 3 Ovako govori Gospod nad vojskama, Bog Izrailjev: Popravite svoje puteve i dela svoja, pa ću učiniti da stanujete na ovom mestu.
\v 4 Ne uzdajte se u lažne reči govoreći: Crkva Gospodnja, crkva Gospodnja, crkva Gospodnja ovo je.
\p 
\v 5 Nego doista popravite svoje puteve i dela svoja, i sudite pravo između čoveka i bližnjeg njegova.
\v 6 Inostrancu, siroti i udovici ne činite krivo, i krv pravu ne prolivajte na ovom mestu, i ne idite za drugim bogovima na svoje zlo.
\v 7 Tada ću učiniti da stanujete od veka do veka na ovom mestu, u zemlji koju sam dao ocima vašim.
\p 
\v 8 Eto, vi se uzdate u reči lažne, koje ne pomažu.
\v 9 Kradete, ubijate i činite preljubu, kunete se krivo, i kadite Valima, i idete za drugim bogovima, kojih ne znate;
\v 10 pa onda dohodite i stajete preda mnom u ovom domu, koji se zove mojim imenom, i govorite: Izbavismo se, da činite sve ove gadove.
\v 11 Je li ovaj dom, koji se zove mojim imenom, u vašim očima pećina hajdučka? Gle, i ja vidim, veli Gospod.
\v 12 Nego idite sada na moje mesto, koje je bilo u Silomu, gde namestih ime svoje ispočetka, i vidite šta sam mu učinio za zloću naroda svog Izrailja.
\v 13 Zato sada, što činite sva ona dela, veli Gospod, i što vam govorim zarana jednako, a vi ne slušate, i kad vas zovem, a vi se ne odazivate,
\v 14 zato ću učiniti tom domu, koji se zove mojim imenom, u koji se vi uzdate, i ovom mestu, koje dadoh vama i ocima vašim, kao što sam učinio Silomu.
\v 15 I odbaciću vas od lica svog, kao što sam odbacio svu braću vašu, sve seme Jefremovo.
\p 
\v 16 Ti se dakle ne moli za taj narod, i ne podiži vike ni molbe za njih, i ne govori mi za njih; jer te neću uslišiti.
\v 17 Zar ne vidiš šta čine po gradovima Judinim i po ulicama jerusalimskim?
\v 18 Sinovi kupe drva, a očevi lože oganj, i žene mese testo, da peku kolače carici nebeskoj, i da liju nalive drugim bogovima, da bi mene dražili.
\v 19 Mene li draže? Govori Gospod; eda li ne sebe, na sramotu licu svom?
\v 20 Zato ovako govori Gospod Gospod: Gle, gnev moj i jarost moja izliće se na ovo mesto, na ljude i na stoku i na drveta poljska i na rod zemaljski, i raspaliće se, i neće se ugasiti.
\p 
\v 21 Ovako veli Gospod nad vojskama Bog Izrailjev: Žrtve svoje paljenice sastavite sa prinosima svojim, i jedite meso.
\v 22 Jer ne govorih ocima vašim, niti im zapovedih, kad ih izvedoh iz zemlje misirske, za žrtve paljenice ni za prinose.
\v 23 Nego im ovo zapovedih govoreći: Slušajte glas moj i biću vam Bog i vi ćete mi biti narod, i idite svim putevima koje vam zapovedih, da bi vam dobro bilo.
\v 24 Ali ne poslušaše, niti uha svog prignuše, nego idoše po savetima i mislima zlog srca svog, i otidoše natrag, a ne napred.
\v 25 Otkad iziđoše oci vaši iz zemlje misirske do danas, slah k vama sve sluge svoje proroke svaki dan zarana i bez prestanka.
\v 26 Ali ne poslušaše me, niti uha svog prignuše, nego behu tvrdovrati i činiše gore nego oci njihovi.
\p 
\v 27 Govorićeš im sve ove reči, ali te neće poslušati; i zvaćeš ih, ali ti se neće odazvati.
\v 28 Zato im reci: Ovo je narod koji ne sluša glas Gospoda Boga svog, niti prima nauke; propade vera i nesta je iz usta njihovih.
\b
\q1 
\v 29 Ostriži kosu svoju i baci je,
\q2 i zaridaj glasno na visokim mestima,
\q1 jer odbaci Gospod i ostavi rod,
\q2 na koji se razgnevi.
\b
\p 
\v 30 Jer sinovi Judini učiniše šta je zlo preda mnom, govori Gospod, metnuše gadove svoje u dom koji se zove mojim imenom, da bi ga oskvrnili.
\v 31 I sagradiše visine Tofetu, koji je u dolini sina Enomovog, da sažižu sinove svoje i kćeri svoje ognjem, što nisam zapovedio niti mi je došlo na um.
\v 32 Zato evo, idu dani, veli Gospod, kad se više neće zvati Tofet ni dolina sina Enomovog, nego dolina krvna, i pogrebavaće se u Tofetu, jer neće biti mesta.
\v 33 I mrtva će telesa naroda ovog biti hrana pticama nebeskim i zverju zemaljskom, i neće biti nikoga da ih plaši.
\v 34 I učiniću, te će iz gradova Judinih i s ulica jerusalimskih nestati glas radostan i glas veseo, glas ženikov i glas nevestin; jer će zemlja opusteti.
\c 8
\s1 Najveća sramota, pustošenje i progonstvo snalazi narod zbog njegovog otpadništva.
\p 
\v 1 U to vreme, govori Gospod, izvadiće se iz grobova kosti careva Judinih i kosti knezova njegovih i kosti svešteničke i kosti proročke, i kosti stanovnika jerusalimskih;
\v 2 i razmetnuće se prema suncu i mesecu i svoj vojsci nebeskoj, koje ljubiše i kojima služiše i za kojima idoše i koje tražiše i kojima se klanjaše; neće se pokupiti ni pogrepsti, nego će biti gnoj po zemlji.
\v 3 I voleće smrt nego život, sav ostatak što ih ostane od ovog roda zlog, što ih ostane po svim mestima kuda ih raselim, govori Gospod nad vojskama.
\b
\q1 
\v 4 Još im reci:
\q1 Ovako veli Gospod:
\q2 Ko padne, ne ustaje li?
\q2 Ko zađe, ne vraća li se?
\q1 
\v 5 Zašto je zašao taj narod jerusalimski za svagda?
\q2 Drže se prevare, neće da se obrate.
\q1 
\v 6 Pazio sam i slušao,
\q2 ne govore pravo,
\q1 nema nikoga da se kaje za zlo svoje,
\q2 da reče: Šta učinih?
\q1 Svaki je okrenuo svojim trkom,
\q2 kao konj kad nagne u boj.
\q1 
\v 7 I roda pod nebom zna svoje vreme,
\q2 grlica i ždral i lasta paze na vreme kad dolaze;
\q1 a narod moj ne zna sud Gospodnji.
\b
\q1 
\v 8 Kako govorite: Mudri smo, i zakon je Gospodnji u nas?
\q2 Doista, gle, laž učini lažljiva pisaljka književnička.
\q1 
\v 9 Mudraci se osramotiše,
\q2 uplašiše se i uhvatiše se;
\q1 eto, odbaciše reč Gospodnju,
\q2 pa kakva im je mudrost?
\q1 
\v 10 Zato ću dati žene njihove drugima,
\q2 njive njihove onima koji će ih naslediti,
\q1 jer od malog do velikog svi se dadoše na lakomstvo,
\q2 i proroci i sveštenici, svi su varalice.
\q1 
\v 11 Jer leče rane kćeri naroda mog ovlaš
\q2 govoreći: Mir, mir;
\q2 a mira nema.
\q1 
\v 12 Eda li se postideše što činiše gad?
\q2 Niti se postideše niti znaju za stid;
\q1 za to će popadati među onima koji padaju;
\q2 kad ih pohodim, popadaće, veli Gospod.
\q1 
\v 13 Sasvim ću ih istrebiti,
\q2 govori Gospod,
\q1 nema grozda na lozi, ni smokve na drvetu, i lišće je opalo;
\q2 i šta sam im dao uzeće im se.
\b
\q1 
\v 14 Što stojimo?
\q2 Skupite se i uđimo u tvrde gradove, i onde ćutimo;
\q1 jer nas je Gospod Bog naš ućutkao napojivši nas žuči,
\q2 jer zgrešismo Gospodu.
\q1 
\v 15 Čekasmo mir, ali nema dobra;
\q2 i vreme da ozdravimo, a gle, strah.
\b
\q1 
\v 16 Od Dana ču se frkanje konja njegovih,
\q2 od rzanja pastuha njegovih sva se zemlja zatrese,
\q1 dođoše i pojedoše zemlju i sve što beše u njoj,
\q2 gradove i koji življahu u njima.
\q1 
\v 17 Jer, evo, ja ću pustiti na vas zmije,
\q2 aspide, od kojih nema bajanja,
\q1 te će vas ujedati,
\q2 govori Gospod.
\b
\q1 
\v 18 Okrepio bih se u žalosti,
\q2 ali je srce u meni iznemoglo.
\q1 
\v 19 Eto vike kćeri naroda mog iz daleke zemlje:
\q2 Zar Gospod nije u Sionu? Car njegov zar nije u njemu?
\q1 Zašto me razgneviše svojim likovima rezanim,
\q2 tuđim taštinama?
\q1 
\v 20 Žetva je prošla, leto minulo,
\q2 a mi se ne izbavismo.
\q1 
\v 21 Satrven sam što je kći naroda mog satrvena,
\q2 u žalosti sam, čudo osvoji me.
\b
\q1 
\v 22 Nema li balsama u Galadu? Nema li onde lekara?
\q2 Zašto se dakle ne isceli kći naroda mog?
\c 9
\s1 Jadikovanje zbog pokvarenosti naroda koji je sa svojim neobrezanim srcem prezreo jedini put spasenja.
\q1 
\v 1 O, da bi glava moja bila voda, a oči moje izvori suzni!
\q2 Da plačem danju i noću za pobijenima kćeri naroda svog.
\q1 
\v 2 O, da mi je u pustinji stanak putnički!
\q2 Da ostavim narod svoj i da otidem od njih,
\q1 jer su svi preljubočinci,
\q2 zbor nevernički;
\q1 
\v 3 I zapinju jezik svoj kao luk da lažu,
\q2 i osiliše na zemlji, ali ne za istinu,
\q1 nego idu iz zla u zlo,
\q2 niti znaju za me,
\q2 govori Gospod.
\b
\q1 
\v 4 Čuvajte se svaki prijatelja svog
\q2 i ni jednom bratu ne verujte;
\q1 jer svaki brat radi da potkine drugog,
\q2 i svaki prijatelj ide te opada.
\q1 
\v 5 I svaki vara prijatelja svog
\q2 i ne govori istine,
\q1 uče jezik svoj da govori laž,
\q2 muče se da čine zlo.
\q1 
\v 6 Stan ti je usred prevare;
\q2 radi prevare neće da znaju za me,
\q2 govori Gospod.
\b
\q1 
\v 7 Zato ovako govori Gospod nad vojskama:
\q1 Gle, pretopiću ih, i okušaću ih;
\q2 jer šta bih činio radi kćeri naroda svog?
\q1 
\v 8 Jezik im je strela smrtna,
\q2 govori prevaru;
\q1 ustima govore o miru s prijateljem svojim,
\q2 a u srcu nameštaju zasedu.
\q1 
\v 9 Zato li ih neću pohoditi? Govori Gospod;
\q2 duša moja neće li se osvetiti takvom narodu?
\b
\q1 
\v 10 Za ovim gorama udariću u plač i u ridanje,
\q2 i za torovima u pustinji u naricanje;
\q1 jer izgoreše da niko ne prolazi niti se čuje glas od stada,
\q2 i ptice nebeske i stoka pobegoše i otidoše.
\q1 
\v 11 I obratiću Jerusalim u gomilu,
\q2 u stan zmajevski;
\q1 i gradove Judine obratiću u pustoš,
\q2 da neće niko onuda živeti.
\b
\p 
\v 12 Ko je mudar da bi razumeo? I kome govoriše usta Gospodnja, da bi objavio zašto zemlja propade i izgore kao pustinja da niko ne prolazi?
\v 13 Jer Gospod reče: Što ostaviše zakon moj, koji metnuh pred njih, i ne slušaše glas moj i ne hodiše za njim,
\v 14 nego hodiše za mislima srca svog i za Valima, čemu ih naučiše oci njihovi,
\v 15 za to ovako veli Gospod nad vojskama, Bog Izrailjev: Evo ja ću nahraniti taj narod pelenom i napojiću ih žuči.
\v 16 I rasejaću ih među narode, kojih ne poznavaše ni oni ni oci njihovi; i puštaću za njima mač dokle ih ne istrebim.
\b
\q1 
\v 17 Ovako veli Gospod nad vojskama:
\q1 Gledajte i zovite narikače neka dođu,
\q2 i pošljite po vešte neka dođu,
\q1 
\v 18 I neka brže nariču za nama,
\q2 da se rone suze od očiju naših,
\q2 i od veđa naših da teče voda.
\q1 
\v 19 Jer se glasno ridanje ču od Siona:
\q2 Kako propadosmo!
\q1 Posramismo se vrlo,
\q2 jer se rastavljamo sa zemljom,
\q2 jer obaraju stanove naše.
\b
\q1 
\v 20 Zato, žene, čujte reč Gospodnju
\q2 i neka primi uho vaše reč usta Njegovih,
\q1 i učite kćeri svoje ridati
\q2 i jedna drugu naricati.
\q1 
\v 21 Jer se pope smrt na prozore naše
\q2 i uđe u dvorove naše
\q1 da istrebi decu s ulica
\q2 i mladiće s puteva.
\q1 
\v 22 Reci: Ovako govori Gospod:
\q1 i mrtva će telesa ljudska ležati kao gnoj po njivi
\q2 i kao rukoveti za žeteocem, kojih niko ne kupi.
\b
\p 
\v 23 Ovako veli Gospod: Mudri da se ne hvali mudrošću svojom, ni jaki da se ne hvali snagom svojom, ni bogati da se ne hvali bogatstvom svojim.
\v 24 Nego ko se hvali, neka se hvali tim što razume i poznaje mene da sam ja Gospod koji činim milost i sud i pravdu na zemlji, jer mi je to milo, govori Gospod.
\p 
\v 25 Eto, idu dani, veli Gospod, kad ću pohoditi sve, obrezane i neobrezane,
\v 26 Misirce i Judejce i Edomce i sinove Amonove i Moavce i sve koji se s kraja strižu, koji žive u pustinji; jer su svi ti narodi neobrezani, i sav je dom Izrailjev neobrezanog srca.
\c 10
\s1 Idole i idolopoklonike živi će Bog upropastiti, a svoj će narod kazniti s merom.
\p 
\v 1 Slušajte reč koju vam govori Gospod, dome Izrailjev.
\v 2 Ovako veli Gospod:
\b
\q1 Ne učite se putu kojim idu narodi,
\q2 i od znaka nebeskih ne plašite se,
\q2 jer se od njih plaše narodi.
\q1 
\v 3 Jer su uredbe u naroda taština,
\q2 jer seku drvo u šumi, delo ruku umetničkih sekirom;
\q1 
\v 4 Srebrom i zlatom ukrašuju ga,
\q2 klinima i čekićima utvrđuju ga da se ne pomiče;
\q1 
\v 5 Stoje pravo kao palme, ne govore;
\q2 treba ih nositi, jer ne mogu ići;
\q1 ne boj ih se,
\q2 jer ne mogu zla učiniti, a ne mogu ni dobra učiniti.
\b
\q1 
\v 6 Niko nije kao Ti, Gospode;
\q2 velik si i veliko je ime Tvoje u sili.
\q1 
\v 7 Ko se ne bi Tebe bojao, care nad narodima!
\q2 Jer Tebi to pripada;
\q1 jer među svim mudracima u naroda i u svim carstvima njihovim
\q2 nema takvog kakav si Ti.
\q1 
\v 8 Nego su svi ludi i bezumni,
\q2 drvo je nauka o taštini.
\q1 
\v 9 Srebro kovano donosi se iz Tarsisa i zlato iz Ufaza,
\q2 delo umetničko i ruku zlatarskih,
\q1 odelo im je od porfire i skerleta,
\q2 sve je delo umetničko.
\q1 
\v 10 A Gospod je pravi Bog,
\q2 Bog živi i car večni,
\q1 od Njegove srdnje trese se zemlja,
\q2 i gnev Njegov ne mogu podneti narodi.
\b
\p 
\v 11 Ovako im recite: Bogovi, koji nisu načinili nebo ni zemlju, nestaće sa zemlje i ispod neba.
\b
\q1 
\v 12 On je načinio zemlju silom svojom,
\q2 utvrdio vasiljenu mudrošću svojom,
\q2 i razumom svojim razastro nebesa;
\q1 
\v 13 On kad pusti glas svoj,
\q2 buče vode na nebesima,
\q1 podiže paru s krajeva zemaljskih,
\q2 pušta munje s daždem,
\q2 i izvodi vetar iz staja njegovih.
\q1 
\v 14 Svaki čovek posta bezuman od znanja,
\q2 svaki se zlatar osramoti likom rezanim,
\q1 jer su laž liveni likovi njegovi,
\q2 i nema duha u njima.
\q1 
\v 15 Taština su, delo prevarno;
\q2 kad ih pohodim, poginuće.
\q1 
\v 16 Nije takav deo Jakovljev,
\q2 jer je Tvorac svemu,
\q1 i Izrailj Mu je nasledstvo,
\q2 ime Mu je Gospod nad vojskama.
\b
\q1 
\v 17 Pokupi iz zemlje trg svoj
\q2 ti, koja sediš u gradu.
\q1 
\v 18 Jer ovako veli Gospod:
\q1 Gle, ja ću izbaciti kao praćom stanovnike ove zemlje,
\q2 i pritesniću ih da osete.
\b
\q1 
\v 19 Teško meni od muke moje, reći će;
\q2 ljuta je rana moja;
\q1 a ja rekoh:
\q2 To je bol, treba da ga podnosim.
\q1 
\v 20 Moj je šator opustošen
\q2 i sva uža moja pokidana,
\q1 sinovi moji otidoše od mene
\q2 i nema ih,
\q1 nema više nikoga da razapne šator moj
\q2 i digne zavese moje.
\q1 
\v 21 Jer pastiri postaše bezumni
\q2 i Gospoda ne tražiše;
\q1 zato ne biše srećni,
\q2 i sve se stado njihovo rasprša.
\b
\q1 
\v 22 Gle, ide glas i vreva velika iz severne zemlje
\q2 da obrati gradove Judine u pustoš,
\q2 u stan zmajevski.
\b
\q1 
\v 23 Znam, Gospode, da put čovečji nije u njegovoj vlasti
\q2 niti je čoveku koji hodi u vlasti da upravlja koracima svojim.
\q1 
\v 24 Karaj me, Gospode, ali s merom,
\q2 ne u gnevu svom, da me ne bi zatro.
\b
\q1 
\v 25 Izlij gnev svoj na narode koji Te ne poznaju,
\q2 i na plemena koja ne prizivaju ime Tvoje,
\q1 jer proždreše Jakova, proždreše ga da ga nema,
\q2 i naselje njegovo opusteše.
\c 11
\s1 Božiji zavet. Neverstvo naroda. Jeremijina životna opasnost.
\p 
\v 1 Reč koja dođe Jeremiji od Gospoda govoreći:
\v 2 Slušajte reči ovog zaveta, i kazujte ljudima Judinim i stanovnicima jerusalimskim.
\v 3 I reci im: Ovako veli Gospod Bog Izrailjev: Proklet da je ko ne posluša reči ovog zaveta,
\v 4 koji zapovedih ocima vašim kad ih izvedoh iz zemlje misirske, iz peći gvozdene, govoreći: Slušajte glas moj i tvorite ovo sve kako vam zapovedam, pa ćete mi biti narod i ja ću vam biti Bog,
\v 5 da bih ispunio zakletvu kojom se zakleh ocima vašim da ću im dati zemlju u kojoj teče mleko i med, kako se vidi danas. A ja odgovorih i rekoh: Amin, Gospode.
\p 
\v 6 Po tom reče mi Gospod: Kazuj sve ove reči po gradovima Judinim i po ulicama jerusalimskim govoreći: Slušajte reči ovog zaveta, i izvršujte ih.
\v 7 Jer tvrdo zasvedočavah ocima vašim od kad ih izvedoh iz zemlje misirske do danas, zarana jednako govoreći: Slušajte glas moj.
\v 8 Ali ne poslušaše i ne prignuše uha svog, nego hodiše svaki za mislima zlog srca svog; za to pustih na njih sve reči ovog zaveta, koji zapovedih da vrše, a oni ne vršiše.
\p 
\v 9 Tada mi reče Gospod: Buna je među ljudima Judinim i stanovnicima jerusalimskim.
\v 10 Vratili su se na bezakonja starih svojih, koji ne hteše slušati moje reči, i idu za drugim bogovima, te im služe; dom Izrailjev i dom Judin pokvariše zavet moj, koji učinih s ocima njihovim.
\v 11 Zato ovako veli Gospod: Evo, ja ću pustiti na njih zlo, iz kog neće moći izaći, i vapiće k meni, ali ih neću uslišiti.
\v 12 Tada će gradovi Judini i stanovnici jerusalimski ići i vapiti k bogovima kojima kade, ali im neće pomoći u nevolji njihovoj.
\v 13 Jer imaš bogova, Juda, koliko gradova, i koliko ima ulica u Jerusalimu, toliko podigoste oltara sramotnih, oltara da kadite Valu.
\p 
\v 14 Ti se dakle ne moli za taj narod, i ne podiži vike ni molbe za njih, jer ih neću uslišiti kad zavape k meni u nevolji svojoj.
\v 15 Šta će mili moj u domu mom, kad čini grdilo s mnogima, i sveto meso otide od tebe, i veseliš se kad zlo činiš?
\v 16 Gospod te nazva maslinom zelenom, lepom radi dobrog roda; ali s hukom velikog vetra raspali oganj oko nje, i grane joj se polomiše.
\v 17 Jer Gospod nad vojskama, koji te je posadio, izreče zlo po te, za zloću doma Izrailjevog i doma Judinog, koju činiše među sobom da bi me razgnevili kadeći Valu.
\b
\q1 
\v 18 Gospod mi objavi, te znam;
\q2 Ti mi pokaza dela njihova.
\q1 
\v 19 A ja bejah kao jagnje i tele koje se vodi na klanje,
\q2 jer ne znah da se dogovaraju na me:
\q1 Oborimo drvo s rodom njegovim,
\q2 i istrebimo ga iz zemlje živih,
\q2 da mu se ime ne spominje više.
\q1 
\v 20 Ali, Gospode nad vojskama,
\q2 Sudijo pravedni,
\q2 koji ispituješ bubrege i srce,
\q1 daj da vidim osvetu Tvoju na njima,
\q2 jer Tebi kazah parbu svoju.
\b
\p 
\v 21 Zato ovako veli Gospod za Anatoćane, koji traže dušu tvoju govoreći: Ne prorokuj u ime Gospodnje, da ne pogineš od naših ruku;
\v 22 zato ovako veli Gospod nad vojskama: Evo, ja ću ih pohoditi; mladići će njihovi izginuti od mača, sinovi njihovi i kćeri njihove izginuće od gladi.
\v 23 I neće biti od njih ostatka; jer ću pustiti zlo na Anatoćane kad ih pohodim.
\c 12
\s1 Teške prilike zemlje zbog grehova njenih stanovnika. Proricanje o susednim narodima.
\q1 
\v 1 Pravedan si, Gospode, ako bih se pravdao s Tobom;
\q2 ali ću progovoriti o sudovima Tvojim.
\q1 Zašto je put bezbožnički srećan?
\q2 Zašto žive u miru svi koji čine neveru?
\q1 
\v 2 Ti ih posadi, i oni se ukoreniše,
\q2 rastu i rod rađaju;
\q1 Ti si im blizu usta
\q2 ali daleko od bubrega.
\q1 
\v 3 Ali Gospode, Ti me poznaješ, razgledaš me
\q2 i okušao si srce moje kako je prema Tebi;
\q1 odvuci ih kao ovce na klanje,
\q2 i pripravi ih za dan kad će se ubiti.
\q1 
\v 4 Dokle će tužiti zemlja, i trava svega polja sahnuti
\q2 sa zloće onih koji žive u njoj?
\q1 Nesta sve stoke i ptica,
\q2 jer govore: Ne vidi kraja našeg.
\b
\q1 
\v 5 Kad si trčao s pešacima pa te umoriše,
\q2 kako ćeš se utrkivati s konjima?
\q1 I kad ti je tako u zemlji mirnoj, u koju se uzdaš,
\q2 šta ćeš činiti kad ustane Jordan?
\q1 
\v 6 Jer i braća tvoja i dom oca tvog, i oni te izneveriše
\q2 i oni viču za tobom glasno.
\q1 Ne veruj im,
\q2 ako bi ti i prijateljski govorili.
\b
\q1 
\v 7 Ostavih dom svoj,
\q2 napustih nasledstvo svoje;
\q1 što beše milo duši mojoj,
\q2 dadoh ga u ruke neprijateljima njegovim.
\q1 
\v 8 Nasledstvo moje posta mi kao lav u šumi,
\q2 pušta glas svoj na mene,
\q2 zato mi omrznu.
\q1 
\v 9 Nasledstvo moje posta mi ptica grabljiva;
\q2 ptice, sletite se na nju,
\q1 skupite se svi zverovi poljski,
\q2 hodite da jedete.
\q1 
\v 10 Pastiri mnogi pokvariće moj vinograd,
\q2 potlačiće deo moj,
\q2 mili deo moj obratiće u golu pustoš.
\q1 
\v 11 Obratiće ga u pustoš,
\q2 opustošen plakaće preda mnom;
\q1 sva će ta zemlja opusteti,
\q2 jer niko ne uzima na um.
\q1 
\v 12 Na sva visoka mesta po pustinji doći će zatirači;
\q1 jer će mač Gospodnji proždirati
\q2 od jednog kraja zemlje do drugog,
\q2 neće biti mira ni jednom telu.
\q1 
\v 13 Sejaće pšenicu, a trnje će žeti;
\q2 mučiće se, a koristi neće imati,
\q1 i stideće se letine svoje,
\q2 sa žestokog gneva Gospodnjeg.
\b
\p 
\v 14 Ovako govori Gospod za sve zle susede moje, koji diraju nasledstvo što dadoh narodu svom Izrailju: evo, ja ću ih počupati iz zemlje njihove, i dom Judin iščupaću isred njih.
\v 15 A kad ih iščupam, opet ću se smilovati na njih, i dovešću opet svakog njih na nasledstvo njegovo i svakog u zemlju njegovu.
\v 16 I ako dobro nauče puteve naroda mog, da se zaklinju mojim imenom: Tako da je živ Gospod! Kao što su oni učili moj narod da se kune Valom, tada će se sazidati usred naroda mog.
\v 17 Ako li ne poslušaju, tada ću iščupati sasvim takav narod i zatrti, govori Gospod.
\c 13
\s1 Kazna Judejaca pretstavljena u dva znaka. Odvođenje u ropstvo.
\p 
\v 1 Ovako mi reče Gospod: Idi i kupi sebi pojas lanen i opaši se njim, a ne meći ga u vodu.
\v 2 Tako kupih pojas po reči Gospodnjoj, i opasah se njim.
\v 3 Potom dođe mi opet reč Gospodnja govoreći:
\v 4 Uzmi taj pojas što si kupio, što je oko tebe, pa se digni i idi na Efrat, i sakrij ga onde u kakvu raselinu kamenu.
\v 5 I otidoh i sakrih ga kod Efrata, kako mi zapovedi Gospod.
\v 6 A posle mnogo vremena reče mi Gospod: Ustani i idi na Efrat, i uzmi pojas koji ti zapovedih da sakriješ onde.
\v 7 I otidoh na Efrat i otkopah i uzeh pojas s mesta gde ga bejah sakrio; a gle, pojas otruhnuo, i ne beše nizašta.
\p 
\v 8 Tada mi dođe reč Gospodnja govoreći:
\v 9 Ovako veli Gospod: Tako ću učiniti da otrune ponos Judin i veliki ponos jerusalimski,
\v 10 tog naroda nevaljalog, što neće da sluša moje reči, što hodi po mislima srca svog i ide za drugim bogovima služeći im i klanjajući im se; i biće kao taj pojas, koji nije nizašta.
\v 11 Jer kako se pojas pripoji oko čoveka, tako bejah pripojio oko sebe sav dom Izrailjev i sav dom Judin, veli Gospod, da bi bili moj narod na slavu i hvalu i diku; ali ne poslušaše.
\b
\p 
\v 12 Zato im reci ovu reč: Ovako veli Gospod Bog Izrailjev: Svi se mehovi pune vina. A oni će reći: Zar ne znamo da se svi mehovi pune vina?
\v 13 Tada im reci: Ovako veli Gospod: Evo ja ću napuniti pijanstva sve stanovnike ove zemlje i careve, koji sede mesto Davida na prestolu njegovom, i sveštenike i proroke i sve stanovnike jerusalimske.
\v 14 I razbiću ih jednog o drugog, i očeve i sinove, veli Gospod; neću požaliti ni poštedeti niti se smilovati, da ih ne potrem.
\b
\q1 
\v 15 Slušajte i čujte,
\q1 nemojte se ponositi,
\q2 jer Gospod govori.
\q1 
\v 16 Dajte slavu Gospodu Bogu svom dok nije spustio mrak,
\q2 dokle se nisu spotakle noge vaše po gorama mračnim,
\q1 da čekate svetlost,
\q2 a On je obrati u sen smrtni i pretvori u tamu.
\q1 
\v 17 Ako li ovo ne poslušate,
\q2 duša će moja plakati tajno radi oholosti vaše
\q1 i roniti suze, suze će teći iz oka mog,
\q2 jer će se zarobiti stado Gospodnje.
\b
\q1 
\v 18 Reci caru i carici:
\q1 Dole sedite,
\q2 jer će se slavni venac vaš skinuti s vaše glave.
\q1 
\v 19 Gradovi južni zatvoriće se
\q2 i neće biti nikoga da ih otvori,
\q1 odvešće se Juda u ropstvo,
\q2 sasvim će se odvesti u ropstvo.
\b
\q1 
\v 20 Podignite oči svoje
\q2 i vidite one što idu od severa.
\q1 Gde je stado što ti je predano,
\q2 stado slave tvoje?
\q1 
\v 21 Šta ćeš reći kad te pohodi?
\q2 Jer si ih ti naučio da budu knezovi nad tobom.
\q2 Neće li te spopasti bolovi kao ženu kad se porađa?
\q1 
\v 22 Ako li kažeš u srcu svom:
\q2 Zašto me to zadesi?
\q1 Za mnoštvo bezakonja tvog
\q2 uzgrnuće se skuti tvoji i obuća ti se skinuti.
\q1 
\v 23 Može li Etiopljanin promeniti kožu svoju ili ris šare svoje?
\q2 Možete li vi činiti dobro naučivši se činiti zlo?
\q1 
\v 24 Zato ću ih razmetnuti
\q2 kao što razmeće plevu vetar iz pustinje.
\q1 
\v 25 To je deo tvoj i obrok tvoj od mene, govori Gospod,
\q2 zato što si me zaboravio i pouzdao se u laž.
\q1 
\v 26 Zato ću ti ja uzgrnuti skute na lice
\q2 da se vidi sramota tvoja.
\q1 
\v 27 Preljube tvoje, rzanje tvoje,
\q2 sramotna kurvarstva tvoja po humovima, po poljima,
\q2 gadove tvoje video sam;
\q1 teško tebi, Jerusalime!
\q2 Zar se nećeš očistiti?
\q2 Dokle još?
\c 14
\s1 Objavljivanje suše i gladi.
\p 
\v 1 Reč Gospodnja koja dođe Jeremiji o suši.
\b
\q1 
\v 2 Juda tuži, i vrata su mu žalosna;
\q2 leže na zemlji u crno zaviti;
\q2 vika iz Jerusalima podiže se.
\q1 
\v 3 Najveći između njih šalju najmanje na vodu;
\q2 došavši na studence ne nalaze vode,
\q1 vraćaju se s praznim sudovima svojim,
\q2 stide se i srame se i pokrivaju glavu svoju.
\q1 
\v 4 Zemlja je ispucala, jer ne beše dažda na zemlji;
\q2 zato se težaci stide i pokrivaju glavu svoju.
\q1 
\v 5 I košuta u polju ostavlja mlade svoje,
\q2 jer nema trave.
\q1 
\v 6 I divlji magarci stojeći na visovima vuku u se vetar kao zmajevi,
\q2 oči im iščileše,
\q2 jer nema trave.
\b
\q1 
\v 7 Kad bezakonja naša svedoče na nas, Gospode,
\q2 učini radi imena svog;
\q1 jer je mnogo odmeta naših,
\q2 Tebi sagrešismo.
\q1 
\v 8 Nado Izrailjeva!
\q2 Spasitelju njegov u nevolji!
\q1 Zašto si kao tuđin u ovoj zemlji
\q2 i kao putnik koji se svrati da prenoći?
\q1 
\v 9 Zašto si kao umoran čovek,
\q2 kao junak, koji ne može izbaviti?
\q1 Ta, Ti si usred nas, Gospode,
\q2 i ime je Tvoje prizvano na nas;
\q2 nemoj nas ostaviti.
\b
\q1 
\v 10 Ovako govori Gospod za narod ovaj:
\q1 Milo im je da se skitaju,
\q2 ne ustavljaju noge svoje,
\q1 zato nisu mili Gospodu;
\q2 sada će se opomenuti bezakonja njihova
\q2 i pohodiće grehe njihove.
\b
\p 
\v 11 Potom reče mi Gospod: Ne moli se za taj narod da bi mu bilo dobro.
\v 12 Ako će i postiti, neću uslišiti vike njihove; i ako će prineti žrtve paljenice i dar, neće mi to ugoditi, nego mačem i glađu i pomorom pomoriću ih.
\b
\p 
\v 13 Tada rekoh: Oh, Gospode Gospode, evo, proroci im govore: Nećete videti mača, i neće biti gladi u vas, nego ću vam dati mir pouzdan na ovom mestu.
\v 14 A Gospod mi reče: Laž prorokuju ti proroci u moje ime, nisam ih poslao, niti sam im zapovedio, niti sam im govorio; lažne utvare i gatanje i ništavilo i prevaru srca svog oni vam prorokuju.
\v 15 Zato ovako veli Gospod za proroke koji prorokuju u moje ime, a ja ih nisam poslao, i govore: Neće biti mača ni gladi u ovoj zemlji: od mača i gladi izginuće ti proroci.
\v 16 A narod ovaj, kome oni prorokuju, biće povaljan po ulicama jerusalimskim od gladi i mača, i neće biti nikoga da ih pogrebe, njih, žene njihove i sinove njihove i kćeri njihove; tako ću izliti na njih zloću njihovu.
\b
\q1 
\v 17 Reci im dakle ovu reč:
\q1 Neka oči moje liju suze danju i noću
\q2 i neka ne prestaju,
\q1 jer devojka, kći mog naroda satre se veoma,
\q2 od udarca preljutog.
\q1 
\v 18 Ako iziđem u polje, eto pobijenih mačem;
\q2 ako uđem u grad, eto iznemoglih od gladi;
\q2 jer i prorok i sveštenik otidoše u zemlju koju ne znaju.
\b
\q1 
\v 19 Eda li si sasvim odbacio Judu?
\q2 Eda li je omrzao duši Tvojoj Sion?
\q1 Zašto si nas udario tako da nam nema leka?
\q2 Čekasmo mir, ali nema dobra;
\q2 i vreme da ozdravimo, a gle, strah.
\q1 
\v 20 Priznajemo, Gospode, zloću svoju,
\q2 bezakonje otaca svojih,
\q2 zgrešili smo Ti.
\q1 
\v 21 Nemoj nas odbaciti radi imena svog;
\q2 nemoj naružiti prestola slave svoje,
\q1 opomeni se zaveta svog s nama,
\q2 nemoj ga ukinuti.
\q1 
\v 22 Ima li među taštinama u naroda koji da daje dažd?
\q2 Ili nebesa, daju li sitan dažd?
\q1 Nisi li Ti to, Gospode Bože naš?
\q2 Zato Tebe čekamo, jer Ti činiš sve to.
\c 15
\s1 Propast je naroda neizbežna, ali će ostatak naći milost. Osobita utešna reč za Jeremiju.
\p 
\v 1 I reče mi Gospod: Da stane Mojsije i Samuilo preda me, ne bi se duša moja obratila k tom narodu; oteraj ih ispred mene, i neka odlaze.
\v 2 I ako ti kažu: Kuda ćemo ići? Tada im reci: Ovako veli Gospod:
\b
\q1 ko je za smrt, na smrt;
\q2 ko je za mač, pod mač;
\q1 ko za glad, na glad;
\q2 ko za ropstvo, u ropstvo.
\b
\p 
\v 3 I pustiću na njih četvoro, govori Gospod: Mač, da ih ubija, i pse, da ih razvlače, i ptice nebeske i zveri zemaljske, da ih jedu i istrebe.
\v 4 I daću ih da se potucaju po svim carstvima zemaljskim radi Manasije sina Jezekijinog cara Judinog za ono što je učinio u Jerusalimu.
\b
\q1 
\v 5 Jer ko bi se smilovao na tebe, Jerusalime?
\q2 Ko li bi te požalio?
\q2 Ko li bi došao da zapita kako ti je?
\q1 
\v 6 Ti si me ostavio, govori Gospod,
\q2 otišao si natrag;
\q1 zato ću mahnuti rukom svojom na te i pogubiću te;
\q2 dosadi mi žaliti.
\q1 
\v 7 Zato ću ih izvijati vijačom na vratima zemaljskim,
\q2 učiniću ih sirotima,
\q1 potrću narod svoj,
\q2 jer se ne vraćaju s puteva svojih.
\q1 
\v 8 Više će mi biti udovica njegovih nego peska morskog,
\q2 dovešću im na majke momačke zatirače u podne,
\q2 i pustiću iznenada na njih smetnju i strahotu.
\q1 
\v 9 Iznemoći će koja je rodila sedmoro
\q2 i ispustiće dušu,
\q1 sunce će joj zaći još za dana,
\q2 sramiće se i stideće se,
\q1 a ostatak ću njihov dati pod mač
\q2 pred neprijateljima njihovim,
\q2 govori Gospod.
\b
\p 
\v 10 Teško meni, majko moja, što si me rodila da se sa mnom prepire i da se sa mnom svađa sva zemlja; ne davah u zajam niti mi davaše u zajam, i opet me svi proklinju.
\v 11 Gospod reče: Doista, ostatku će tvom biti dobro, i braniću te od neprijatelja, kad budeš u nevolji i u teskobi.
\v 12 Eda li će gvožđe slomiti gvožđe severno i bronzu?
\p 
\v 13 Imanje tvoje i blago tvoje daću da se razgrabi bez cene po svim međama tvojim, i to za sve grehe tvoje.
\v 14 I odvešću te s neprijateljima tvojim u zemlju koje ne poznaješ, jer se raspalio oganj od gneva mog, i goreće nad vama.
\b
\q1 
\v 15 Ti znaš, Gospode,
\q2 opomeni me se i pohodi me
\q2 i osveti me od onih koji me gone;
\q1 nemoj me zgrabiti dokle se ustežeš od gneva;
\q2 znaj da podnosim rug tebe radi.
\q1 
\v 16 Kad se nađoše reči Tvoje, pojedoh ih,
\q2 i reč Tvoja bi mi radost i veselje srcu mom,
\q1 jer je ime Tvoje prizvano na me,
\q2 Gospode Bože nad vojskama.
\q1 
\v 17 Ne sedim u veću podsmevačkom
\q2 niti se s njima veselim;
\q1 sedim sam radi ruke Tvoje,
\q2 jer si me napunio srdnje.
\q1 
\v 18 Zašto bol moj jednako traje?
\q1 I zašto je rana moja smrtna,
\q2 te neće da se isceli?
\q1 Hoćeš li mi biti kao varalica,
\q2 kao voda nepostojana?
\b
\q1 
\v 19 Zato ovako veli Gospod:
\q1 Ako se obratiš,
\q2 ja ću te opet postaviti da stojiš preda mnom,
\q1 ako odvojiš što je dragoceno od rđavog,
\q2 bićeš kao usta moja;
\q1 oni neka se obrate k tebi,
\q2 a ti se ne obraćaj k njima.
\q1 
\v 20 I učiniću da budeš tom narodu kao jak zid bronzani,
\q2 i udaraće na te, ali te neće nadvladati;
\q1 jer sam ja s tobom da te čuvam i izbavljam,
\q2 govori Gospod.
\q1 
\v 21 I izbaviću te iz ruku zlih ljudi,
\q2 i iskupiću te iz ruku nasilničkih.
\c 16
\s1 Opustošenje i progonstvo Judino zbog idolopoklonika. Povratak Izrailja iz Vavilona.
\p 
\v 1 Potom dođe mi reč Gospodnja govoreći:
\v 2 Nemoj se ženiti, i da nemaš sinove ni kćeri na tom mestu.
\v 3 Jer ovako govori Gospod za sinove i kćeri što se rode na tom mestu i za matere njihove koje ih rode, i za oce njihove koji ih rode u toj zemlji:
\v 4 Ljutom će smrću pomreti, neće biti oplakani niti će se pogrepsti, biće gnoj po zemlji, i od mača i od gladi izginuće, i mrtva će telesa njihova biti hrana pticama nebeskim i zverima zemaljskim.
\p 
\v 5 Jer ovako govori Gospod: Ne ulazi u kuću u kojoj je žalost, i ne idi da plačeš niti ih žali; jer sam uzeo mir svoj od tog naroda, govori Gospod, milost i žaljenje.
\v 6 Pomreće mali i veliki u ovoj zemlji, neće biti pogrebeni niti će se oplakati, niti će se ko rezati ni glave strići za njima.
\v 7 Neće im se dati hleba u žalosti da se poteše za mrtvim, niti će ih napojiti iz čaše radi utehe za ocem ili za materom.
\v 8 Tako ne ulazi u kuću u kojoj je žalost da sediš s njima da jedeš i piješ.
\v 9 Jer ovako veli Gospod nad vojskama, Bog Izrailjev: Evo, ja ću učiniti da na ovom mestu pred vašim očima i za vaših dana ne bude glasa radosnog ni glasa veselog, glasa ženikovog ni glasa nevestinog.
\p 
\v 10 A kad kažeš tom narodu sve ove reči, ako ti kažu: Zašto izreče Gospod sve to veliko zlo na nas? I kakvo je bezakonje naše ili kakav je greh naš, kojim zgrešismo Gospodu Bogu svom?
\v 11 Tada im reci: Jer oci vaši ostaviše mene, govori Gospod, i idoše za drugim bogovima i služiše im i klanjaše im se, a mene ostaviše i zakon moj ne držaše;
\v 12 a vi još gore činite nego oci vaši, jer eto idete svaki po misli srca svog zlog ne slušajući mene.
\v 13 Zato ću vas izbaciti iz ove zemlje u zemlju koje ne poznaste ni vi ni oci vaši, i onde ćete služiti drugim bogovima dan i noć dokle vam ne učinim milost.
\b
\p 
\v 14 Zato, evo, idu dani, govori Gospod, kad se neće više govoriti: Tako da je živ Gospod koji je izveo sinove Izrailjeve iz zemlje misirske;
\v 15 nego: Tako da je živ Gospod koji je izveo sinove Izrailjeve iz zemlje severne i iz svih zemalja u koje ih beše razagnao! Jer ću ih opet dovesti u zemlju njihovu koju sam dao ocima njihovim.
\p 
\v 16 Gle, ja ću poslati mnoge ribare, govori Gospod, da ih love, i posle ću poslati mnoge lovce da ih love po svakoj gori i po svakom humu i po raselinama kamenim.
\v 17 Jer oči moje paze na sve puteve njihove, nisu sakriveni od mene, niti je bezakonje njihovo zaklonjeno od mojih očiju.
\v 18 I platiću im prvo dvojinom za bezakonje njihovo i za greh njihov, što oskvrniše zemlju moju strvima gadova svojih, i nasledstvo moje napuniše gnusobama svojim.
\b
\q1 
\v 19 Gospode, kreposti moja i grade moj
\q2 i utočište moje u nevolji,
\q1 k Tebi će doći narodi od krajeva zemaljskih,
\q2 i reći će:
\q1 Doista oci naši imaše laž,
\q2 i taštinu i što ni malo ne pomaže.
\q1 
\v 20 Eda li će čovek načiniti sebi bogove,
\q2 koji ipak nisu bogovi?
\b
\p 
\v 21 Zato, evo, ja ću ih naučiti sada, pokazaću im ruku svoju i silu svoju, da poznadu da mi je ime Gospod.
\c 17
\s1 Kazna zbog idolopoklonstva, uzdanja u ljude i prevare. Poziv na praznovanje subote.
\p 
\v 1 Greh je Judin zapisan gvozdenom pisaljkom i vrhom od dijamanta, urezan je na ploči srca njihovog i na rogovima oltara vaših,
\v 2 da se sinovi njihovi sećaju oltara njihovih i lugova njihovih pod zelenim drvetima, na visokim humovima.
\v 3 Goro s poljem, daću imanje tvoje, sve blago tvoje daću da se razgrabi, visine tvoje, za greh po svim međama tvojim.
\v 4 I ti ćeš i koji su s tobom ostaviti nasledstvo svoje, koje sam ti dao, i učiniću da služiš neprijateljima svojim u zemlji koje ne poznaješ; jer ste raspalili oganj gneva mog, koji će goreti do veka.
\b
\q1 
\v 5 Ovako veli Gospod:
\q1 Da je proklet čovek koji se uzda u čoveka
\q2 i koji stavlja telo sebi za mišicu,
\q2 a od Gospoda odstupa srce njegovo.
\q1 
\v 6 Jer će biti kao vres u pustinji,
\q2 koji ne oseća kad dođe dobro,
\q1 nego stoji u pustinji,
\q2 na suvim mestima u zemlji slanoj i u kojoj se ne živi.
\b
\q1 
\v 7 Blago čoveku koji se uzda u Gospoda
\q2 i kome je Gospod uzdanica.
\q1 
\v 8 Jer će biti kao drvo usađeno kraj vode
\q2 i koje niz potok pušta žile svoje,
\q1 koje ne oseća kad dođe pripeka, nego mu se list zeleni,
\q2 i sušne godine ne brine se i ne prestaje rađati rod.
\b
\q1 
\v 9 Srce je prevarno više svega i opako:
\q2 ko će ga poznati?
\q1 
\v 10 Ja Gospod ispitujem srca i iskušavam bubrege,
\q2 da bih dao svakome prema putevima njegovim
\q2 i po plodu dela njegovih.
\b
\q1 
\v 11 Kao što jarebica leži na jajima ali ne izleže,
\q2 tako ko sabira bogatstvo ali s nepravdom,
\q1 u polovini dana svojih ostaviće ga
\q2 i najposle će biti lud.
\b
\q1 
\v 12 Mesto je svetinje naše presto slave,
\q2 visoko mesto od početka.
\q1 
\v 13 Nado Izrailjeva, Gospode!
\q2 Svi koji Te ostavljaju neka se posrame;
\q1 koji odstupaju od mene, neka se zapišu na zemlji,
\q2 jer ostaviše izvor vode žive, Gospoda.
\b
\q1 
\v 14 Isceli me, Gospode, i biću isceljen;
\q2 izbavi me, i biću izbavljen,
\q2 jer si Ti hvala moja.
\q1 
\v 15 Gle, oni mi govore:
\q1 Gde je reč Gospodnja?
\q2 Neka dođe.
\q1 
\v 16 A ja se ne zatezah ići za Tobom kao pastir,
\q2 i dan žalosni ne želeh, Ti znaš;
\q1 šta je god izašlo iz usta mojih,
\q2 pred Tobom je.
\q1 
\v 17 Ne budi mi strah,
\q2 Ti si utočište moje u zlu.
\q1 
\v 18 Neka se posrame koji me gone, a ja ne;
\q2 neka se oni uplaše, a ja ne;
\q1 pusti na njih zli dan,
\q2 i dvostrukim polomom polomi ih.
\b
\p 
\v 19 Ovako mi reče Gospod: Idi, i stani na vrata sinova narodnih, na koja ulaze carevi Judini i na koja izlaze, i na svaka vrata jerusalimska.
\v 20 I reci im: Čujte reč Gospodnju, carevi Judini i svi Judejci i svi Jerusalimljani, koji ulazite na ova vrata.
\v 21 Ovako veli Gospod: Čuvajte se da ne nosite breme u subotu i ne unosite na vrata jerusalimska.
\v 22 I ne iznosite bremena iz kuća svojih u subotu, i nikakav posao ne radite, nego svetite subotu, kao što sam zapovedio ocima vašim.
\v 23 Ali ne poslušaše niti prignuše uha svog, nego otvrdnuše vratom svojim da ne poslušaju i ne prime nauke.
\p 
\v 24 Ako me poslušate, govori Gospod, da ne nosite bremena na vrata ovog grada u subotu, nego svetite subotu ne radeći u nju nikakav posao,
\v 25 tada će ulaziti na vrata grada ovog carevi i knezovi, koji sede na prestolu Davidovom, na kolima i na konjima, oni i knezovi njihovi, Judejci i Jerusalimljani, i stajaće ovaj grad do veka.
\v 26 I dolaziće iz gradova Judinih i iz okoline jerusalimske, i iz zemlje Venijaminove, i iz ravnice i iz gora i s juga, i donosiće žrtve paljenice i prinose s darom i kadom, i žrtve zahvalne donosiće u dom Gospodnji.
\v 27 Ako li me ne poslušate da svetite subotu i ne nosite bremena ulazeći na vrata jerusalimska u subotu, onda ću raspaliti oganj na vratima njegovim, koji će upaliti dvorove jerusalimske i neće se ugasiti.
\c 18
\s1 Kajanje održava, nekajanje upropašćuje. Plač i molitva Jeremijina.
\p 
\v 1 Reč koja dođe Jeremiji od Gospoda govoreći:
\v 2 Ustani, i siđi u kuću lončarevu, i onde ću ti kazati reči svoje.
\v 3 Tada siđoh u kuću lončarevu, i gle, on rađaše posao na svom kolu.
\v 4 I pokvari se u ruci lončaru sud koji građaše od kala, pa načini iznova od njega drugi sud, kako beše volja lončaru da načini.
\p 
\v 5 Tada dođe mi reč Gospodnja govoreći:
\v 6 Ne mogu li činiti od vas kao ovaj lončar, dome Izrailjev? Govori Gospod; gle, šta je kao u ruci lončarevoj, to ste vi u mojoj ruci, dome Izrailjev.
\v 7 Kad bih rekao za narod i za carstvo da ga istrebim i razorim i zatrem;
\v 8 ako se obrati narod oda zla, za koje bih rekao, i meni će biti žao sa zla koje mišljah da mu učinim.
\v 9 A kad bih rekao za narod i za carstva da ga sazidam i nasadim;
\v 10 ako učini šta je zlo preda mnom ne slušajući glas moj, i meni će biti žao dobra koje rekoh da mu učinim.
\v 11 Zato sada reci Judejcima i Jerusalimljanima govoreći: Ovako veli Gospod: Evo spremam na vas zlo, i mislim misli na vas; vratite se, dakle, svaki sa svog puta zlog, i popravite puteve svoje i dela svoja.
\p 
\v 12 A oni rekoše: Nema ništa od toga, nego ćemo ići za svojim mislima i činićemo svaki po misli srca svog zlog.
\b
\q1 
\v 13 Zato ovako govori Gospod:
\q1 Pitajte po narodima je li ko čuo takvo šta?
\q2 Grdilo veliko učini devojka Izrailjeva.
\q1 
\v 14 Ostavlja li sneg livanski sa stene moja polja?
\q2 Ostavljaju li se vode studene, koje teku?
\q1 
\v 15 A narod moj mene zaboravi,
\q2 kadi taštini,
\q1 i spotiču se na svojim putevima,
\q2 na starim stazama,
\q2 da hode stazama puta neporavnjenog,
\q1 
\v 16 Da bih obratio zemlju njihovu u pustoš,
\q2 na večnu sramotu,
\q1 da se čudi ko god prođe preko nje
\q2 i maše glavom svojom.
\q1 
\v 17 Kao ustokom razmetnuću ih pred neprijateljem;
\q2 leđa a ne lice pokazaću im u nevolji njihovoj.
\b
\p 
\v 18 A oni rekoše: Hodite da smislimo šta Jeremiji, jer neće nestati zakona svešteniku ni saveta mudracu ni reči proroku; hodite, ubijmo ga jezikom i ne pazimo na reči njegove.
\b
\q1 
\v 19 Pazi na me, Gospode,
\q2 i čuj glas mojih protivnika.
\q1 
\v 20 Eda li će se zlo vratiti za dobro,
\q2 kad mi kopaju jamu?
\q1 Opomeni se da sam stajao pred Tobom
\q2 govoreći za njihovo dobro,
\q2 da bih odvratio gnev Tvoj od njih.
\q1 
\v 21 Zato predaj sinove njihove gladi
\q2 i učini da izginu od mača,
\q1 i žene njihove da budu sirote i udove,
\q2 i muževi njihovi da se pogube,
\q2 mladiće njihove da pobije mač u boju.
\q1 
\v 22 Neka se čuje vika iz kuća njihovih,
\q2 kad dovedeš na njih vojsku iznenada;
\q1 jer iskopaše jamu da me uhvate,
\q2 i zamke namestiše nogama mojim.
\q1 
\v 23 A Ti, Gospode, znaš sve
\q2 što su naumili meni da me ubiju,
\q1 nemoj im oprostiti bezakonja
\q2 ni greh njihov izbrisati ispred sebe;
\q1 nego neka popadaju pred Tobom,
\q2 u gnevu svom radi suprot njima.
\c 19
\s1 Opustošenje Jerusalima označeno razbijanjem jednog zemljanog krčaga.
\p 
\v 1 Ovako reče Gospod: Idi i kupi krčag zemljan u lončara s nekoliko starešina narodnih i starešina svešteničkih.
\v 2 I otidi u dolinu sina Enomovog što je pred vratima istočnim, i onde proglasi reči koje ću ti kazati.
\v 3 I reci: Čujte reč Gospodnju, carevi Judini i stanovnici jerusalimski; ovako veli Gospod nad vojskama Bog Izrailjev: Evo, ja ću pustiti zlo na to mesto da će zujati uši svakome ko ga čuje.
\v 4 Jer me ostaviše i oskvrniše ovo mesto kadeći na njemu drugim bogovima, kojih ne znaše ni oni ni oci njihovi, ni carevi Judini, i napuniše to mesto krvi prave.
\v 5 I pogradiše visine Valu da sažižu sinove svoje ognjem na žrtve paljenice Valu, čega ne zapovedih niti o tom govorih, niti mi na um dođe.
\v 6 Zato, evo, ide vreme, veli Gospod, kad se ovo mesto neće više zvati Tofet, ni dolina sina Enomovog, nego krvna dolina.
\v 7 Jer ću uništiti savet Judin i jerusalimski na ovom mestu, i učiniću da padnu od mača pred neprijateljima svojim i od ruke onih koji traže dušu njihovu, i mrtva ću telesa njihova dati za hranu pticama nebeskim i zverima zemaljskim.
\v 8 I obratiću taj grad u pustoš i rug: ko god prođe mimo nj, čudiće se i zviždaće za sve muke njegove.
\v 9 I učiniću da jedu meso od svojih sinova i meso od svojih kćeri, i svaki će jesti meso od druga svog u nevolji i teskobi, kojom će im dosađivati neprijatelji njihovi i koji traže dušu njihovu.
\p 
\v 10 Potom razbij krčag pred ljudima koji će ići s tobom.
\v 11 I reci im: Ovako veli Gospod nad vojskama: Tako ću razbiti taj narod i taj grad kao što se razbije sud lončarski, koji se ne može više opraviti, i u Tofetu će se pogrebavati, jer neće biti mesta za pogrebavanje:
\v 12 Tako ću učiniti tome mestu, veli Gospod, i stanovnicima njegovim i učiniću taj grad da bude kao Tofet;
\v 13 i kuće jerusalimske i kuće careva Judinih biće nečiste kao mesto Tofet, sve kuće, gde na krovovima kadiše svoj vojsci nebeskoj i liše nalive drugim bogovima.
\p 
\v 14 Potom se vrati Jeremija iz Tofeta kuda ga beše poslao Gospod da prorokuje, i stade u tremu doma Gospodnjeg, i reče svemu narodu:
\v 15 Ovako veli Gospod nad vojskama, Bog Izrailjev: Evo, ja ću pustiti na taj grad i na sve gradove njegove sve zlo koje izrekoh za nj, jer otvrdnuše vratom svojim da ne slušaju reči moje.
\c 20
\s1 Zlostavljanje od Pashora, Jeremija proriče Vavilonsko ropstvo, i jada se što je postao prorok.
\p 
\v 1 A Pashor sin Imirov, sveštenik, koji beše starešina u domu Gospodnjem, ču Jeremiju gde prorokuje te reči.
\v 2 I udari Pashor proroka Jeremiju, i metnu ga u tamnicu na gornjim vratima Venijaminovim uz dom Gospodnji.
\v 3 A sutradan kad Pashor izvede Jeremiju iz tamnice, reče mu Jeremija: Gospod ti nade ime ne Pashor nego Magor-Misaviv.
\v 4 Jer ovako veli Gospod: Evo, ja ću pustiti na te strah, na tebe i na sve prijatelje tvoje, koji će pasti od mača neprijatelja svojih, i oči će tvoje videti, i svega ću Judu dati u ruke caru vavilonskom, koji će ih odvesti u Vavilon, i pobiće ih mačem.
\v 5 I daću sve bogatstvo tog grada i sav trud njegov i sve što ima dragoceno, i sve blago careva Judinih daću neprijateljima njihovim u ruke, i razgrabiće i uzeti i odneti u Vavilon.
\v 6 I ti, Pashore, i svi koji žive u tvom domu otići ćete u ropstvo; i doći ćeš u Vavilon i onde ćeš umreti i onde ćeš biti pogreben ti i svi prijatelji tvoji, kojima si prorokovao lažno.
\b
\q1 
\v 7 Nagovarao si me, Gospode,
\q2 i dadoh se nagovoriti;
\q1 bio si jači od mene
\q2 i nadvladao si me;
\q1 na podsmeh sam svaki dan,
\q2 svak mi se podsmeva.
\q1 
\v 8 Jer od kad govorim, vapim,
\q2 radi nasilja i pustošenja vičem,
\q1 jer mi je reč Gospodnja na porugu
\q2 i na podsmeh svaki dan.
\q1 
\v 9 I rekoh: Neću Ga više pominjati,
\q2 niti ću više govoriti u ime Njegovo;
\q1 ali bi u srcu mom kao oganj razgoreo,
\q2 zatvoren u kostima mojim,
\q1 i umorih se zadržavajući ga,
\q2 i ne mogoh više.
\q1 
\v 10 Jer čujem poruge od mnogih, strah od svuda:
\q2 Prokažite da prokažemo;
\q1 svi koji behu u miru sa mnom,
\q2 vrebaju da posrnem:
\q1 Da ako se prevari,
\q2 te ćemo ga nadvladati i osvetićemo mu se.
\q1 
\v 11 Ali je Gospod sa mnom
\q2 kao strašan junak;
\q1 zato oni koji me gone spotaknuće se
\q2 i neće nadvladati;
\q1 posramiće se vrlo;
\q2 jer neće biti srećni,
\q2 sramota večna neće se zaboraviti.
\q1 
\v 12 Zato, Gospode nad vojskama,
\q2 koji kušaš pravednika,
\q2 koji vidiš bubrege i srce,
\q1 daj da vidim Tvoju osvetu na njima,
\q2 jer Tebi kazah parbu svoju.
\b
\q1 
\v 13 Pevajte Gospodu, hvalite Gospoda,
\q2 jer izbavi dušu siromahu iz ruke zlikovačke.
\b
\q1 
\v 14 Proklet da je dan u koji se rodih!
\q2 Dan, u koji me rodi mati moja, da nije blagosloven!
\q1 
\v 15 Proklet da je čovek koji javi ocu mom
\q2 i vrlo ga obradova govoreći: Rodi ti se sin.
\q1 
\v 16 I taj čovek da bi bio kao gradovi koje Gospod zatre i ne bi Mu žao!
\q2 Neka sluša viku ujutru i vrisku u podne,
\q1 
\v 17 Što me ne usmrti u utrobi materinoj
\q2 da bi mi mati moja bila grob,
\q2 i utroba njena da bi ostala do veka trudna.
\q1 
\v 18 Zašto iziđoh iz utrobe
\q2 da vidim muku i žalost
\q2 i da se svrše u sramoti dani moji?
\c 21
\s1 Na pitanje cara Sedekije proriče Jeremija razorenje Jerusalima i pokazuje šta je jedini put spasenja.
\p 
\v 1 Reč koja dođe Jeremiji od Gospoda kad posla k njemu car Sedekija Pashora sina Melhijinog i Sofoniju sina Masijinog sveštenika, i poruči:
\v 2 Upitaj Gospoda za nas, jer Navuhodonosor, car vavilonski, zavojšti na nas; eda bi nam učinio Gospod po svim čudesima svojim, da otide od nas.
\p 
\v 3 A Jeremija im reče: Ovako recite Sedekiji:
\v 4 Ovako veli Gospod Bog Izrailjev: Evo, ja ću okrenuti natrag oružje što je u vašim rukama, kojim se bijete s carem vavilonskim i s Haldejcima koji su vas opkolili iza zidova, i skupiću ih usred tog grada.
\v 5 I ja ću vojevati na vas rukom podignutom i mišicom krepkom i gnevom i jarošću i žestinom velikom.
\v 6 I pobiću stanovnike tog grada, i ljude i stoku; od pomora velikog pomreće.
\v 7 A posle, veli Gospod, daću Sedekiju cara Judinog i sluge njihove i narod, one koji ostanu u tom gradu od pomora, od mača i od gladi, u ruke Navuhodonosoru caru vavilonskom i u ruke neprijateljima njihovim i u ruke onima koji traže dušu njihovu, te će ih pobiti mačem, neće ih žaliti ni štedeti niti će se smilovati.
\p 
\v 8 A narodu tom reci: Ovako veli Gospod: Evo ja stavljam pred vas put k životu i put k smrti.
\v 9 Ko ostane u tom gradu, poginuće od mača ili od gladi ili od pomora; a ko izađe i preda se Haldejcima koji su vas opkolili, ostaće živ, i duša će mu biti mesto plena.
\v 10 Jer okretoh lice svoje tome gradu na zlo, a ne na dobro, govori Gospod; u ruke caru vavilonskom biće predan, i on će ga spaliti ognjem.
\b
\p 
\v 11 A za dom cara Judinog čujte reč Gospodnju:
\v 12 Dome Davidov, tako veli Gospod,
\b
\q1 sudite svako jutro,
\q2 i kome se otima
\q2 izbavljajte ga iz ruku nasilnikovih
\q1 da ne iziđe kao oganj gnev moj
\q2 i razgori se da ga niko ne može ugasiti
\q2 za zloću dela vaših.
\q1 
\v 13 Evo me na tebe,
\q2 koji sediš u dolini,
\q2 kao stena u ravnici,
\q1 govori Gospod,
\q1 na vas, koji govorite:
\q2 Ko će doći na nas?
\q2 I ko će ući u stanove naše?
\q1 
\v 14 Jer ću vas pokarati po plodu dela vaših,
\q2 veli Gospod,
\q1 i raspaliću oganj u šumi njegovoj,
\q2 koji će proždreti sve što je oko njega.
\c 22
\s1 Proricanje protiv careva Saluma, Joakima i Jehonije.
\p 
\v 1 Ovako govori Gospod: Siđi u dom cara Judinog, i reci onde ovu reč,
\v 2 i kaži: Slušaj reč Gospodnju, care Judin, koji sediš na prestolu Davidovom, ti i sluge tvoje i narod tvoj, koji ulazite na ova vrata.
\v 3 Ovako veli Gospod: Činite sud i pravdu, i kome se otima izbavljajte ga iz ruku nasilnikovih, i ne činite krivo inostrancu ni siroti ni udovici, i ne činite im silu, i krv pravu ne prolivajte na ovom mestu.
\v 4 Jer ako doista uzradite ovo, ulaziće na vrata ovog doma carevi, koji sede mesto Davida na prestolu njegovom, na kolima i na konjima, oni i sluge njihove i narod njihov.
\v 5 Ako li ne poslušate ove reči, zaklinjem se sobom, veli Gospod, da ću opusteti taj dom.
\v 6 Jer ovako veli Gospod za dom cara Judinog:
\b
\q1 Ti si mi Galad
\q2 i vrh livanski,
\q1 ali ću te obratiti u pustinju,
\q2 u gradove u kojima se ne živi.
\q1 
\v 7 I spremiću na tebe zatirače,
\q2 svakog s oružjem,
\q1 i poseći će tvoje krasne kedre
\q2 i pobacati ih u oganj.
\b
\p 
\v 8 I mnogi će narodi prolaziti mimo taj grad, i govoriće jedan drugom: Zašto učini ovo Gospod od tog grada velikog?
\v 9 I reći će: Jer ostaviše zavet Gospoda Boga svog, i klanjaše se drugim bogovima i služiše im.
\b
\q1 
\v 10 Ne plačite za mrtvim niti ga žalite;
\q2 nego plačite za onim koji odlazi,
\q1 jer se neće više vratiti
\q2 niti će videti svoje postojbine.
\b
\p 
\v 11 Jer ovako govori Gospod o Salumu sinu Josije, cara Judinog, koji carovaše mesto Josije oca svog, koji otide iz ovog mesta: neće se više vratiti.
\v 12 Nego će umreti u mestu kuda ga odvedoše u ropstvo, i neće više videti ove zemlje.
\b
\q1 
\v 13 Teško onom koji gradi svoju kuću ne po pravdi,
\q2 i kleti svoje ne po pravici,
\q1 koji se služi bližnjim svojim nizašta
\q2 i platu za trud njegov ne daje mu;
\q1 
\v 14 Koji govori: Sagradiću sebi veliku kuću
\q2 i prostrane kleti;
\q1 i razvaljuje sebi prozore,
\q2 i oblaže kedrom i maže crvenilom.
\q1 
\v 15 Hoćeš li carovati kad se mešaš s kedrom?
\q2 Otac tvoj nije li jeo i pio?
\q1 Kad činjaše sud i pravdu,
\q2 tada mu beše dobro.
\q1 
\v 16 Davaše pravicu siromahu i ubogome,
\q2 i beše mu dobro;
\q1 nije li to poznavati me?
\q2 Govori Gospod.
\q1 
\v 17 Ali oči tvoje i srce tvoje idu samo za tvojim dobitkom
\q2 i da prolivaš krv pravu
\q2 i da činiš nasilje i krivdu.
\b
\p 
\v 18 Zato ovako veli Gospod za Joakima sina Josije cara Judinog:
\b
\q1 Neće naricati za njim:
\q2 Jaoh brate moj! Ili: Jaoh sestro!
\q1 Neće naricati za njim:
\q2 Jaoh gospodaru! Ili: Jaoh slavo njegova!
\q1 
\v 19 Pogrebom magarećim pogrepšće se,
\q2 izvući će se i baciće se iza vrata jerusalimskih.
\b
\q1 
\v 20 Iziđi na Livan i viči,
\q2 i na Vasanu pusti glas svoj,
\q1 i viči preko brodova,
\q2 jer se satrše svi koji te ljube.
\q1 
\v 21 Govorih ti u sreći tvojoj,
\q2 a ti reče: Neću da slušam;
\q1 to je put tvoj od detinjstva tvog
\q2 da ne slušaš glas moj.
\q1 
\v 22 Sve će pastire tvoje odneti vetar,
\q2 i koji te ljubi otići će u ropstvo;
\q1 tada ćeš se posramiti i postideti
\q2 za svu zloću svoju.
\q1 
\v 23 Ti sediš na Livanu,
\q2 gnezdo viješ na kedrima,
\q1 kako ćeš biti ljupka,
\q2 kad ti dođu muke i bolovi kao porodilji!
\b
\p 
\v 24 Kako sam ja živ, veli Gospod, da bi Honija sin Joakima cara Judinog bio prsten pečatni na desnoj ruci mojoj, i odande ću te otrgnuti.
\v 25 I daću te u ruke onima koji traže dušu tvoju, i u ruke onima kojih se bojiš, u ruke Navuhodonosoru caru vavilonskom i u ruke Haldejcima.
\v 26 I baciću tebe i mater tvoju koja te je rodila u zemlju tuđu, gde se niste rodili, i onde ćete pomreti.
\v 27 A u zemlju u koju ćete želeti da se vratite, nećete se vratiti u nju.
\b
\q1 
\v 28 Je li taj čovek Honija ništav idol izlomljen?
\q2 Je li sud u kome nema miline?
\q1 Zašto biše isterani, on i seme njegovo,
\q2 i bačeni u zemlju, koje ne poznaju?
\q1 
\v 29 O zemljo, zemljo, zemljo!
\q2 Čuj reč Gospodnju.
\q1 
\v 30 Ovako veli Gospod:
\q1 Zapišite da će taj čovek biti bez dece
\q2 i da neće biti srećan do svog veka;
\q1 i niko neće biti srećan od semena njegovog,
\q2 koji bi sedeo na prestolu Davidovom
\q2 i još vladao Judom.
\c 23
\s1 Protiv zlih pastira. Obricanje dobrog pastira i cara iz Davidovog doma. Protiv lažnih proroka.
\p 
\v 1 Teško pastirima koji potiru i razmeću stado paše moje! Govori Gospod.
\v 2 Zato ovako veli Gospod Bog Izrailjev za pastire koji pasu narod moj: Vi razmetnuste ovce moje i razagnaste ih, i ne obilaziste ih; evo, ja ću vas obići za zloću dela vaših, govori Gospod.
\v 3 I ostatak ovaca svojih ja ću skupiti iz svih zemalja u koje ih razagnah, i vratiću ih u torove njihove, gde će se naploditi i umnožiti.
\v 4 I postaviću im pastire, koji će ih pasti, da se ne boje više i ne plaše i da ne pogine ni jedna, govori Gospod.
\p 
\v 5 Gle, idu dani, govori Gospod, u koje ću podignuti Davidu Klicu pravednu, koja će carovati i biti srećna i činiti sud i pravdu na zemlji.
\v 6 U Njegove dane spašće se Juda, i Izrailj će stanovati u miru, i ovo mu je ime kojim će se zvati: Gospod pravda naša.
\p 
\v 7 Zato, evo, idu dani, govori Gospod, u koje se neće više govoriti: Tako da je živ Gospod, koji je izveo sinove Izrailjeve iz zemlje misirske;
\v 8 nego: Tako da je živ Gospod, koji je izveo i doveo seme doma Izrailjevog iz severne zemlje i iz svih zemalja u koje ih bejah razagnao. I oni će sedeti u svojoj zemlji.
\b
\q1 
\v 9 Radi proroka puca srce u meni,
\q2 trepeću sve kosti moje,
\q1 kao pijan sam
\q2 i kao čovek koga je osvojilo vino,
\q1 Gospoda radi
\q2 i Njegovih radi svetih reči.
\q1 
\v 10 Jer je zemlja puna preljubočinaca,
\q2 i s kletava tuži zemlja,
\q1 posušiše se paše u pustinji;
\q2 trk je njihov zao i moć njihova neprava.
\q1 
\v 11 Jer i prorok i sveštenik skvrne je,
\q2 nalazim i u domu svom zloću njihovu,
\q2 govori Gospod.
\q1 
\v 12 Za to će put njihov biti kao klizavica po tami,
\q2 gde će popuznuti i pasti;
\q1 jer ću pustiti na njih zlo,
\q2 godine pohođenja njihovog,
\q2 govori Gospod.
\q1 
\v 13 U proroka samarijskih video sam bezumlje,
\q2 prorokovahu Valom,
\q2 prelašćivahu narod moj Izrailja;
\q1 
\v 14 Ali u proroka jerusalimskih vidim strahotu:
\q2 čine preljubu i hode u laži,
\q1 ukrepljuju ruke zlikovcima
\q2 da se niko ne vrati od svoje zloće;
\q1 svi su mi kao Sodom,
\q2 i stanovnici njegovi kao Gomor.
\q1 
\v 15 Zato ovako veli Gospod nad vojskama o tim prorocima:
\q1 Evo, ja ću ih nahraniti pelenom i napojiću ih žuči;
\q2 jer od proroka jerusalimskih iziđe oskvrnjenje po svoj zemlji.
\b
\p 
\v 16 Ovako veli Gospod nad vojskama: Ne slušajte šta govore proroci koji vam prorokuju; varaju vas, govore utvare svog srca, ne iz usta Gospodnjih.
\v 17 Jednako govore onima koji ne mare za me: Gospod je rekao: Imaćete mir; i svakome koji ide po misli srca svog govore: Neće doći na vas zlo.
\b
\q1 
\v 18 Jer ko je stajao u veću Gospodnjem, i video ili čuo reč Njegovu?
\q2 Ko je pazio na reč Njegovu i čuo?
\q1 
\v 19 Evo, vihor Gospodnji, gnev,
\q2 izići će vihor, koji ne prestaje,
\q2 pašće na glavu bezbožnicima.
\q1 
\v 20 Neće se odvratiti gnev Gospodnji
\q2 dokle ne učini i izvrši šta je u srcu naumio;
\q2 najposle ćete razumeti to sasvim.
\b
\q1 
\v 21 Ne slah tih proroka, a oni trčaše;
\q2 ne govorih im, a oni prorokovaše.
\q1 
\v 22 Da su stajali u mom veću,
\q2 tada bi kazivali moje reči narodu mom,
\q1 i odvraćali bi ih s puta njihovog zlog
\q2 i od zloće dela njihovih.
\b
\p 
\v 23 Jesam li ja Bog iz bliza, govori Gospod, a nisam Bog i iz daleka?
\v 24 Može li se ko sakriti na tajno mesto da ga ja ne vidim? Govori Gospod; ne ispunjam li ja nebo i zemlju? Govori Gospod.
\v 25 Čujem šta govore ti proroci koji u ime moje prorokuju laž govoreći: Snio sam, snio sam.
\v 26 Dokle će to biti u srcu prorocima koji prorokuju laž, i prevaru srca svog prorokuju?
\v 27 Koji misle da će učiniti da narod moj zaboravi ime moje uza sne njihove, koje pripovedaju jedan drugom, kao što zaboraviše oci njihovi ime moje uz Vala.
\v 28 Prorok koji sni, neka pripoveda san; a u koga je reč moja, neka govori reč moju istinito; šta će pleva sa pšenicom? Govori Gospod.
\v 29 Nije li reč moja kao oganj, govori Gospod, i kao malj koji razbija kamen?
\v 30 Za to, evo me na te proroke, govori Gospod, koji kradu moje reči jedan od drugog.
\v 31 Evo me na te proroke, veli Gospod, koji dižu jezik svoj i govore: On veli.
\v 32 Evo me na one koji prorokuju lažne sne, veli Gospod, i pripovedajući ih zavode narod moj lažima svojim i hitrinom svojom; a ja ih nisam poslao niti sam im zapovedio; i neće ništa pomoći tome narodu, govori Gospod.
\p 
\v 33 Ako te zapita ovaj narod ili koji prorok ili sveštenik govoreći: Kako je breme Gospodnje? Tada im reci: Kako breme? Ostaviću vas, govori Gospod.
\v 34 A proroka i sveštenika i narod koji reče: Breme Gospodnje, ja ću pokarati tog čoveka i dom njegov.
\v 35 Nego ovako govorite svaki bližnjemu svom i svaki bratu svom: Šta odgovori Gospod? I: Šta reče Gospod?
\v 36 A bremena Gospodnjeg ne pominjite više, jer će svakome biti breme reč njegova, jer izvrćete reči Boga Živoga, Gospoda nad vojskama, Boga našeg.
\v 37 Ovako reci proroku: Šta ti odgovori Gospod? I šta ti reče Gospod?
\v 38 Ali kad kažete: Breme Gospodnje, zato ovako veli Gospod: Šta govorite tu reč: Breme Gospodnje, a ja slah k vama da vam kažu: Ne govorite: Breme Gospodnje,
\v 39 zato evo me, ja ću vas zaboraviti sasvim i odbaciću od sebe vas i grad koji sam dao vama i ocima vašim.
\v 40 I navaliću na vas porugu večnu i sramotu večnu koja se neće zaboraviti.
\c 24
\s1 Bolji i gori deo Judinog naroda označen u slici dobrim i rđavim smokvama.
\p 
\v 1 Pokaza mi Gospod, i gle, dve kotarice smokava nameštene pred crkvom Gospodnjom, pošto Navuhodonosor, car vavilonski, zarobi Jehoniju sina Joakimovog cara Judinog, i knezove Judine, i drvodelje i kovače iz Jerusalima i odvede ih u Vavilon.
\v 2 U jednoj kotarici behu smokve vrlo dobre, kakve behu rane smokve, a u drugoj kotarici behu vrlo rđave smokve, koje se ne mogahu jesti, tako behu rđave.
\v 3 I reče mi Gospod: Šta vidiš, Jeremija? A ja rekoh: Smokve, jedne dobre smokve, vrlo dobre, a druge rđave, vrlo rđave, koje se ne mogu jesti, tako su rđave.
\p 
\v 4 I dođe mi reč Gospodnja govoreći:
\v 5 Ovako veli Gospod Bog Izrailjev: Kakve su te smokve dobre, tako će mi biti dobra radi roblje Judino, koje odaslah iz ovog mesta u zemlju haldejsku.
\v 6 I obratiću oči svoje na njih dobra radi, i dovešću ih opet u ovu zemlju, i sazidaću ih i neću ih razoriti, i nasadiću ih i neću ih počupati.
\v 7 Jer ću im dati srce da me poznaju da sam ja Gospod, i biće mi narod i ja ću im biti Bog, jer će se obratiti k meni svim srcem svojim.
\p 
\v 8 A kakve su te rđave smokve da se ne mogu jesti, kako su rđave, takvim ću, veli Gospod, učiniti Sedekiju cara Judinog i knezove njegove i ostatak Jerusalimljana koji ostaše u ovoj zemlji i koji žive u zemlji misirskoj.
\v 9 Učiniću da se potucaju po svim carstvima zemaljskim na zlo, da budu sramota i priča i rug i uklin po svim mestima, kuda ih raselim.
\v 10 I poslaću na njih mač, glad i pomor, dokle se ne istrebe sa zemlje, koju sam dao njima i ocima njihovim.
\c 25
\s1 Sedamdesetgodišnje ropstvo Judino. Propast Vavilona. Čaša gneva za sve narode.
\p 
\v 1 Reč koja dođe Jeremiji za sav narod Judin četvrte godine Joakima sina Josijinog cara Judinog, a to je prva godina Navuhodonosora cara vavilonskog,
\v 2 koju reče Jeremija prorok svemu narodu Judinom i svim stanovnicima jerusalimskim, govoreći:
\v 3 Od trinaeste godine Josije sina Amonovog cara Judinog do danas, za ove dvadeset i tri godine, dolazi mi reč Gospodnja i govorih vam zarana jednako, ali ne poslušaste.
\v 4 I sla vam Gospod sve sluge svoje proroke zarana jednako, ali ne poslušaste, niti prignuste uha svog da biste čuli.
\v 5 I govorahu: Vratite se svaki sa svog puta zlog i od zloće dela svojih, pa ćete ostati u zemlji koju dade Gospod vama i ocima vašim od veka do veka.
\v 6 I ne idite za drugim bogovima da im služite i da im se klanjate i ne gnevite me delom ruku svojih, i neću vam učiniti zla.
\v 7 Ali me ne poslušaste, govori Gospod, nego me gneviste delom ruku svojih na svoje zlo.
\p 
\v 8 Za to ovako veli Gospod nad vojskama: Što ne poslušaste moje reči,
\v 9 evo, ja ću poslati po sve narode severne, govori Gospod, i po Navuhodonosora cara vavilonskog slugu svog, i dovešću ih na tu zemlju i na stanovnike njene, i na sve te narode okolne, koje ću zatrti, i učiniću da budu čudo i podsmeh i pustoš večna.
\v 10 I učiniću da nestane među njima glas radostan i glas veseo, glas ženikov i glas nevestin, lupa od žrvanja i svetlost od žiška.
\v 11 I sva će ta zemlja biti pustoš i čudo, i ti će narodi služiti caru vavilonskom sedamdeset godina.
\v 12 A kad se navrši sedamdeset godina, onda ću pohoditi cara vavilonskog i onaj narod, govori Gospod, za bezakonje njihovo, i zemlju haldejsku, i obratiću je u pustoš večnu.
\v 13 I pustiću na tu zemlju sve što sam govorio o njoj, sve što je napisano u ovoj knjizi, što prorokova Jeremija za sve narode.
\v 14 Jer će veliki narodi i silni carevi i njih pokoriti; tada ću im platiti po delima njihovim i po onom što su činili rukama svojim.
\b
\p 
\v 15 Jer ovako mi reče Gospod Bog Izrailjev: Uzmi iz moje ruke čašu vina, ovog gneva, i napoj iz nje sve narode ka kojima te ja pošaljem.
\v 16 Neka piju i smetu se i polude od oštrog mača koji ću ja poslati među njih.
\p 
\v 17 I uzeh čašu iz ruke Gospodu, i napojih sve te narode, ka kojima me posla Gospod:
\v 18 Jerusalim i gradove Judine i careve njegove i knezove njegove, da budu pustoš i čudo i podsmeh i uklin, kao što je danas,
\v 19 Faraona cara misirskog i sluge njegove i knezove njegove i sav narod njegov,
\v 20 i svu mešavinu, i sve careve zemlje Uza, sve careve zemlje filistejske, i Askalon i Gazu i Akaron i ostatak od Azota,
\v 21 Edomce i Moavce i sinove Amonove,
\v 22 i sve careve tirske i sve careve sidonske i careve na ostrvima preko mora,
\v 23 Dedana i Temu i Vuza, i sve koji se s kraja strižu,
\v 24 i sve careve arapske i sve careve od mešavine koji žive u pustinji,
\v 25 i sve careve zimrijske, i sve careve elamske, i sve careve midske,
\v 26 i sve careve severne, koji su blizu i koji su daleko, kako jednog tako drugog, i sva carstva zemaljska što su po zemlji; a car sisaški piće posle njih.
\p 
\v 27 I reci im: Ovako veli Gospod nad vojskama Bog Izrailjev: Pijte i opijte se, i bljujte i padajte, da ne ustanete od mača koji ću pustiti među vas.
\p 
\v 28 Ako li ne bi hteli uzeti čašu iz ruke tvoje da piju, tada im reci: Ovako veli Gospod nad vojskama: Zaista ćete piti.
\v 29 Jer evo počinjem puštati zlo na grad koji se naziva mojim imenom, a vi li ćete ostati bez kara? Nećete ostati bez kara, jer ću dozvati mač na sve stanovnike zemaljske, govori Gospod nad vojskama.
\p 
\v 30 Ti dakle prorokuj im sve ove reči i reci im:
\b
\q1 Gospod će s visine riknuti,
\q2 i iz stana svetinje svoje pustiće glas svoj,
\q1 silno će riknuti iz stana svog,
\q2 kao oni što gaze grožđe podignuće viku na sve stanovnike zemaljske.
\q1 
\v 31 Proći će graja do kraja zemlje,
\q2 jer raspru ima Gospod s narodima,
\q1 sudi se sa svakim telom,
\q2 bezbožnike će dati pod mač,
\q2 govori Gospod.
\b
\q1 
\v 32 Ovako veli Gospod nad vojskama:
\q1 Evo, nevolja će poći od naroda do naroda,
\q2 i velik će se vihor podignuti od krajeva zemaljskih.
\b
\p 
\v 33 I u onaj će dan biti od kraja do kraja zemlje pobijeni od Gospoda, neće biti oplakani, niti će se pokupiti i pogrepsti, biće gnoj po zemlji.
\b
\q1 
\v 34 Ridajte, pastiri, i vičite
\q2 i valjajte se po prahu, glavari stadu,
\q1 jer se navršiše vaši dani da budete poklani,
\q2 i da se razaspete,
\q2 i pašćete kao skupocen sud.
\q1 
\v 35 I neće biti utočišta pastirima,
\q2 ni izbavljenja glavarima od stada.
\q1 
\v 36 Vikaće pastiri i ridaće glavari od stada,
\q2 jer će potrti Gospod pašu njihovu.
\q1 
\v 37 I razvaliće se mirni torovi
\q2 od žestokog gneva Gospodnjeg.
\q1 
\v 38 Kao lavić ostavio je šator svoj,
\q2 jer će zemlja njihova opusteti od žestine nasilnikove
\q2 i od ljutog gneva njegovog.
\c 26
\s1 Jeremijin govor o pokajanju. Optužba i odbrana od strane knezova.
\p 
\v 1 U početku carovanja Joakima, sina Josijinog, cara Judinog, dođe ova reč od Gospoda govoreći:
\v 2 Ovako govori Gospod: Stani u tremu doma Gospodnjeg, i govori svim gradovima Judinim, koji dolaze da se poklone u domu Gospodnjem, sve reči koje ti zapovedam da im kažeš, ne izostavi ni reči,
\v 3 ne bi li poslušali i vratili se svaki sa svog zlog puta, da mi se sažali sa zla koje im mislim učiniti za zloću dela njihovih.
\v 4 Reci im dakle: Ovako veli Gospod: ako me ne poslušate da hodite u mom zakonu koji sam stavio pred vas,
\v 5 da slušate reči sluga mojih proroka, koje vam šaljem, koje slah zarana jednako, ali ih ne poslušaste,
\v 6 učiniću s domom ovim kao sa Silomom, i grad ovaj daću u prokletstvo svim narodima na zemlji.
\p 
\v 7 A sveštenici i proroci i sav narod čuše Jeremiju gde govori te reči u domu Gospodnjem.
\v 8 I kad Jeremija izgovori sve što mu Gospod zapovedi da kaže svemu narodu, uhvatiše ga sveštenici i proroci i sav narod govoreći: Poginućeš.
\v 9 Zašto prorokova u ime Gospodnje govoreći: Ovaj će dom biti kao Silom, i ovaj će grad opusteti da neće u njemu niko živeti? I skupi se sav narod na Jeremiju u dom Gospodnji.
\p 
\v 10 A knezovi Judini čuvši to dođoše iz doma carskog u dom Gospodnji, i sedoše pred nova vrata Gospodnja.
\v 11 I rekoše sveštenici i proroci knezovima i svemu narodu govoreći: Ovaj je čovek zaslužio smrt, jer prorokova protiv ovog grada, kao što čuste svojim ušima.
\p 
\v 12 Tada progovori Jeremija svim knezovima i svemu narodu govoreći: Gospod me posla da prorokujem protiv ovog doma i protiv ovog grada sve što čuste.
\v 13 Zato popravite puteve svoje i dela svoja, i poslušajte reč Gospoda Boga svog, i sažaliće se Gospodu sa zla koje je izrekao za vas.
\v 14 A ja, evo sam u vašim rukama, činite od mene šta mislite da je dobro i pravo.
\v 15 Ali znajte zacelo, ako me ubijete, krv pravu svalićete na se i na ovaj grad i na stanovnike njegove, jer doista Gospod me posla k vama da govorim sve ove reči, da čujete.
\b
\p 
\v 16 Tada rekoše knezovi i sav narod sveštenicima i prorocima: Nije ovaj čovek zaslužio smrt, jer nam je govorio u ime Gospoda Boga našeg.
\v 17 I ustaše neki od starešina zemaljskih, i progovoriše svemu zboru narodnom i rekoše:
\v 18 Mihej Morašćanin prorokova u vreme Jezekije, cara Judinog, i govori svemu narodu Judinom i reče: Ovako veli Gospod nad vojskama:
\b
\q1 Sion će se preorati kao njiva
\q2 i grad će Jerusalim biti gomila kamenja,
\q2 i gora ovog doma visoka šuma.
\b
\p 
\v 19 Je li ga zato ubio Jezekija, car Judin i sav Juda? Nije li se pobojao Gospoda i molio se Gospodu? I Gospodu se sažali radi zla koje beše izrekao na njih; mi dakle činimo veliko zlo dušama svojim.
\p 
\v 20 I još beše jedan koji prorokova u ime Gospodnje, Urija sin Semajin iz Kirijat-Jarima; on prorokova protiv ovog grada i protiv ove zemlje isto onako kao Jeremija.
\v 21 I kad ču car Joakim i sve vojvode njegove i svi knezovi reči njegove, traži ga car da ga ubije; a Urija čuvši poboja se i pobeže i dođe u Misir.
\v 22 A car Joakim posla neke u Misir, Elnatana sina Ahovorovog i druge s njim.
\v 23 I oni izvedoše Uriju iz Misira i dovedoše k caru Joakimu, i ubi ga mačem, i baci telo njegovo u groblje prostog naroda.
\p 
\v 24 Ali ruka Ahikama, sina Safanovog, bi uz Jeremiju, te ga ne predaše u ruke narodu da ga pogube.
\c 27
\s1 Jeremija poziva cara nad Judom i druge careve, da se po Božijoj volji priklone pod jaram Vavilonski.
\p 
\v 1 U početku carovanja Joakima sina Josijinog cara Judinog dođe ova reč Jeremiji od Gospoda govoreći:
\v 2 Ovako mi reče Gospod: Načini sebi sveze i jaram, i metni sebi oko vrata.
\v 3 Po tom pošlji ih caru edomskom i caru moavskom i caru sinova Amonovih i caru tirskom i caru sidonskom, po poslanicima koji će doći u Jerusalim k Sedekiji caru Judinom.
\v 4 I naruči im neka kažu svojim gospodarima: Ovako veli Gospod nad vojskama Bog Izrailjev: ovako recite svojim gospodarima:
\v 5 Ja sam stvorio zemlju i ljude i stoku, što je po zemlji, silom svojom velikom i mišicom svojom podignutom; i dajem je kome mi je drago.
\v 6 I sada ja dadoh sve te zemlje u ruke Navuhodonosoru caru vavilonskom sluzi svom, dadoh mu i zverje poljsko da mu služi.
\v 7 I svi će narodi služiti njemu i sinu njegovom i unuku njegovom dokle dođe vreme i njegovoj zemlji, i veliki narodi i silni carevi pokore ga.
\p 
\v 8 A koji narod ili carstvo ne bi hteo služiti Navuhodonosoru caru vavilonskom, i ne bi hteo saviti vrata svog u jaram cara vavilonskog, takav ću narod pohoditi mačem i glađu i pomorom, govori Gospod, dokle ih ne istrebim rukom njegovom.
\v 9 Ne slušajte dakle proroka svojih ni vrača svojih ni sanjača svojih ni gatara svojih ni bajača svojih, koji vam govore i vele: Nećete služiti caru vavilonskom.
\v 10 Jer vam oni laž prorokuju, kako bih vas daleko odveo iz zemlje vaše i izagnao vas da izginete.
\v 11 A narod koji bi savio vrat svoj pod jaram cara vavilonskog i služio mu, ostaviću ga na zemlji njegovoj, govori Gospod, da je radi i stanuje u njoj.
\p 
\v 12 I Sedekiji caru Judinom rekoh sve ovo govoreći: Savijte vrat svoj pod jaram cara vavilonskog i služite njemu i narodu njegovom, pa ćete ostati živi.
\v 13 Zašto da poginete ti i narod tvoj od mača i od gladi i od pomora, kako reče Gospod za narod koji ne bi služio caru vavilonskom?
\v 14 Ne slušajte, dakle, šta govore proroci koji vam kažu i vele: Nećete služiti caru vavilonskom, jer vam oni prorokuju laž.
\v 15 Jer ih ja nisam poslao, govori Gospod, nego lažno prorokuju u moje ime, kako bih vas prognao da izginete i vi i proroci koji vam prorokuju.
\p 
\v 16 I sveštenicima i svemu narodu govorih i rekoh: Ovako veli Gospod: ne slušajte šta govore vaši proroci koji vam prorokuju govoreći: Evo, posuđe doma Gospodnjeg vratiće se iz Vavilona skoro. Jer vam oni prorokuju laž.
\v 17 Ne slušajte ih; služite caru vavilonskom, i ostaćete živi; zašto taj grad da opusti?
\v 18 Ako li su proroci i ako je reč Gospodnja u njih, neka mole Gospoda nad vojskama da sudovi što su ostali u domu Gospodnjem i u domu cara Judinog i u Jerusalimu ne otidu u Vavilon.
\v 19 Jer ovako veli Gospod nad vojskama za stupove i za more i za podnožja i za druge sudove što su ostali u tom gradu,
\v 20 kojih ne uze Navuhodonosor car vavilonski kad odvede u ropstvo Jehoniju sina Joakimovog, cara Judinog, iz Jerusalima u Vavilon, i sve glavare Judine i jerusalimske;
\v 21 jer ovako veli Gospod nad vojskama, Bog Izrailjev, za sudove što ostaše u domu Gospodnjem i u domu cara Judinog u Jerusalimu:
\v 22 U Vavilon će se odneti i onde će biti do dana kad ću ih pohoditi, veli Gospod, kad ću ih doneti i vratiti na ovo mesto.
\c 28
\s1 Lažan prorok Ananija protivureči Jeremiji, koji mu prorokuje smrt i te je godine umro prorok Ananija.
\p 
\v 1 A iste godine, u početku carovanja Sedekije cara Judinog, četvrte godine, petog meseca, reče mi Ananija sin Azorov, prorok iz Gavaona, u domu Gospodnjem pred sveštenicima i svim narodom govoreći:
\v 2 Ovako veli Gospod nad vojskama Bog Izrailjev: Slomih jaram cara vavilonskog.
\v 3 Do dve godine ja ću vratiti na ovo mesto sve sudove doma Gospodnjeg, koje uze Navuhodonosor car vavilonski odavde i odnese u Vavilon.
\v 4 I Jehoniju sina Joakimovog cara Judinog i sve roblje Judino što ode u Vavilon, ja ću dovesti opet na ovo mesto, govori Gospod, jer ću slomiti jaram cara vavilonskog.
\p 
\v 5 Tada reče Jeremija prorok Ananiji proroku pred sveštenicima i pred svim narodom, koji stajaše u domu Gospodnjem.
\v 6 Reče Jeremija prorok: Amin, da Gospod učini tako, da Gospod ispuni tvoje reči što si prorokovao da bi vratio sudove doma Gospodnjeg i sve roblje iz Vavilona na ovo mesto.
\v 7 Ali čuj ovu reč koju ću ja kazati pred tobom i pred svim narodom:
\v 8 Proroci koji su bili pre mene i pre tebe od starine, oni prorokovaše mnogim zemljama i velikim carstvima rat i nevolju i pomor.
\v 9 Prorok koji proriče mir, kad se zbude reč tog proroka, onda se poznaje taj prorok da ga je zaista poslao Gospod.
\p 
\v 10 Tada Ananija prorok skide jaram s vrata Jeremiji proroku i slomi ga.
\v 11 I reče Ananija pred svim narodom govoreći: Ovako veli Gospod: Ovako ću slomiti jaram Navuhodonosora, cara vavilonskog, do dve godine s vrata svih naroda. I ode prorok Jeremija svojim putem.
\p 
\v 12 Ali dođe reč Gospodnja Jeremiji, pošto slomi Ananija prorok jaram s vrata Jeremiji proroku, i reče:
\v 13 Idi i kaži Ananiji i reci: Ovako veli Gospod: Slomio si jaram drveni, ali načini mesto njega gvozden jaram.
\v 14 Jer ovako veli Gospod nad vojskama Bog Izrailjev: gvozden ću jaram metnuti na vrat svim tim narodima da služe Navuhodonosoru, caru vavilonskom, i služiće mu, dao sam mu i zverje poljsko.
\v 15 Potom reče Jeremija prorok Ananiji proroku: Čuj, Ananija; nije te poslao Gospod, a ti si učinio da se narod ovaj pouzda u laž.
\v 16 Zato ovako veli Gospod: Evo, ja ću te skinuti sa zemlje, ove godine ti ćeš umreti; jer si kazivao odmet od Gospoda.
\p 
\v 17 I umre prorok Ananija te godine sedmog meseca.
\c 29
\s1 Pismo Jeremijino zarobljenim Judejcima u Vavilonu. Semaja će se kazniti.
\p 
\v 1 A ovo su reči u poslanici koju posla prorok Jeremija iz Jerusalima k ostatku starešina zarobljenih i sveštenicima i prorocima i svemu narodu što ga preseli Navuhodonosor iz Jerusalima u Vavilon,
\v 2 pošto otide iz Jerusalima car Jehonija i carica i dvorani i knezovi Judini i jerusalimski, i drvodelje i kovači.
\v 3 Po Elasi, sinu Safanovom, i Gemariji sinu Helkijinom, koje sla Sedekija car Judin u Vavilon k Navuhodonosoru caru vavilonskom; i u knjizi govoraše:
\v 4 Ovako veli Gospod nad vojskama, Bog Izrailjev, svemu roblju koje preselih iz Jerusalima u Vavilon:
\v 5 Gradite kuće i sedite u njima; sadite vrtove i jedite rod njihov;
\v 6 ženite se i rađajte sinove i kćeri; i sinove svoje ženite, i kćeri svoje udajte, neka rađaju sinove i kćeri, i množite se tu i ne umanjujte se.
\v 7 I tražite dobro gradu, u koji vas preselih, i molite se za nj Gospodu, jer u dobru njegovom biće vama dobro.
\v 8 Jer ovako veli Gospod nad vojskama Bog Izrailjev: Nemojte da vas varaju vaši proroci što su među vama i vaši vrači, i ne gledajte na sne svoje što sanjate.
\v 9 Jer vam oni lažno prorokuju u moje ime, ja ih nisam poslao, govori Gospod.
\p 
\v 10 Jer ovako veli Gospod: Kad se navrši u Vavilonu sedamdeset godina, pohodiću vas, i izvršiću vam dobru reč svoju da ću vas vratiti na ovo mesto.
\v 11 Jer ja znam misli koje mislim za vas, govori Gospod, misli dobre a ne zle, da vam dam posledak kakav čekate.
\v 12 Tada ćete me prizivati i ići ćete i molićete mi se, i uslišiću vas.
\v 13 I tražićete me, i naći ćete me, kad me potražite svim srcem svojim.
\v 14 I daću vam se da me nađete, govori Gospod, i vratiću roblje vaše, i sabraću vas iz svih naroda i iz svih mesta u koja sam vas razagnao, govori Gospod, i dovešću vas opet na mesto, odakle sam vas iselio.
\p 
\v 15 Jer rekoste: Gospod nam podiže proroke u Vavilonu.
\v 16 Jer, ovako veli Gospod za cara koji sedi na prestolu Davidovom i za sav narod koji stoji u ovom gradu, za braću vašu što ne otidoše s vama u ropstvo.
\v 17 Ovako veli Gospod nad vojskama: Evo, ja ću pustiti na njih mač, glad i pomor, i učiniću ih da budu kao smokve rđave, koje se ne mogu jesti, kako su rđave.
\v 18 I goniću ih mačem i glađu i pomorom, i učiniću da se potucaju po svim carstvima zemaljskim, da budu uklin i čudo i podsmeh i rug u svih naroda, u koje ih pošaljem.
\v 19 Jer ne poslušaše moje reči, govori Gospod, kad slah k njima sluge svoje proroke zarana jednako; ali ne poslušaste, govori Gospod.
\v 20 Slušajte, dakle, reč Gospodnju vi svi zarobljeni, koje poslah iz Jerusalima u Vavilon.
\v 21 Ovako veli Gospod nad vojskama, Bog Izrailjev, za Ahava sina Kolajinog i za Sedekiju sina Masijinog, koji vam prorokuju u moje ime laž: evo, ja ću ih predati u ruke Navuhodonosoru caru vavilonskom, da ih pobije na vaše oči.
\v 22 I od njih će se uzeti uklin među sve roblje Judino što je u Vavilonu, te će govoriti: Gospod da učini od tebe kao od Sedekije i kao od Ahava, koje ispeče car vavilonski na ognju.
\v 23 Jer učiniše grdilo u Izrailju čineći preljubu sa ženama bližnjih svojih i govoreći laž na moje ime, što im ne zapovedih; ja znam to, i svedok sam, govori Gospod.
\b
\p 
\v 24 I Semaji iz Nelama reci govoreći:
\v 25 Ovako veli Gospod nad vojskama, Bog Izrailjev, govoreći: Što si u svoje ime poslao knjige svemu narodu koji je u Jerusalimu, i Sofoniji sinu Masijinom svešteniku i svim sveštenicima, govoreći:
\v 26 Gospod te postavi sveštenikom na mesto Jodaja sveštenika, da pazite u domu Gospodnjem na svakog čoveka bezumnog i koji se gradi prorok, da ih mećeš u tamnicu i u klade.
\v 27 Zašto, dakle, ne ukori Jeremije Anatoćanina, koji se gradi prorok među vama?
\v 28 Jer posla k nama u Vavilon i poruči: Dugo će trajati; gradite kuće i sedite u njima, i sadite vrtove i jedite rod njihov.
\p 
\v 29 I Sofonija sveštenik pročita tu knjigu pred prorokom Jeremijom.
\v 30 I dođe reč Gospodnja Jeremiji govoreći:
\v 31 Pošalji ka svemu roblju i poruči: Ovako veli Gospod za Semaju iz Nelama; što vam prorokuje Semaja, a ja ga ne poslah, i čini da se uzdate u laž,
\v 32 zato ovako veli Gospod: Evo, ja ću pohoditi Semaju Nelamljanina i seme njegovo, neće od njega niko ostati u ovom narodu niti će videti dobra što ću ja učiniti narodu svom, govori Gospod, jer kaziva odmet od Gospoda.
\c 30
\s1 Proricanje o spasenju Izrailja i Jude, i o budućnosti pomazanika.
\p 
\v 1 Reč koja dođe Jeremiji od Gospoda govoreći:
\v 2 Ovako veli Gospod Bog Izrailjev govoreći: Napiši u knjigu sve reči koje ti govorih.
\v 3 Jer evo idu dani, govori Gospod, kad ću povratiti roblje naroda svog Izrailja i Jude, govori Gospod, i dovešću ih natrag u zemlju koju sam dao ocima njihovim, i držaće je.
\p 
\v 4 I ovo su reči koje reče Gospod za Izrailja i Judu.
\b
\q1 
\v 5 Jer ovako veli Gospod:
\q1 Čusmo viku od prepadanja, straha,
\q2 a mira nema.
\q1 
\v 6 Pitajte i vidite,
\q2 eda li muško rađa?
\q1 Zašto, dakle, vidim gde se svaki čovek drži rukama svojim za bedra svoja kao porodilja
\q2 i u svih se promenila lica i pobledela?
\q1 
\v 7 Jaoh! Jer je velik ovaj dan,
\q2 nije bilo takvog,
\q1 i vreme je muke Jakovljeve,
\q2 ipak će se izbaviti iz nje.
\b
\p 
\v 8 Jer u taj dan, govori Gospod nad vojskama, slomiću jaram njegov s vrata tvog, i sveze tvoje pokidaću; i neće ga više tuđini nagoniti da im služi.
\v 9 Nego će služiti Gospodu Bogu svom i Davidu caru svom, kog ću im podignuti.
\b
\q1 
\v 10 Ti se dakle ne boj, Jakove slugo moj, govori Gospod,
\q2 i ne plaši se, Izrailju;
\q1 jer, evo, ja ću te izbaviti iz daleke zemlje,
\q2 i seme tvoje iz zemlje ropstva tvog,
\q1 i Jakov će se vratiti i počivati, i biće miran,
\q2 i niko ga neće plašiti.
\q1 
\v 11 Jer sam ja s tobom, govori Gospod,
\q2 da te izbavim;
\q1 i učiniću kraj svim narodima,
\q2 među koje sam te rasejao,
\q1 ali tebi neću učiniti kraja,
\q2 nego ću te pokarati s merom,
\q2 a neću te ostaviti sa svim bez kara.
\b
\q1 
\v 12 Jer ovako veli Gospod:
\q1 Smrtan je polom tvoj
\q2 i rana tvoja ljuta.
\q1 
\v 13 Nema nikoga koji bi se primio tvoje stvari da te leči,
\q2 nema leka koji bi ti pomogao.
\q1 
\v 14 Svi koji te ljube zaboraviše te,
\q2 ne traže te,
\q1 jer te udarih udarcem neprijateljskim,
\q2 karom žestokim,
\q1 za mnoštvo bezakonja tvog,
\q2 za silne grehe tvoje.
\q1 
\v 15 Zašto vičeš radi rane svoje,
\q2 smrtnog bola svog?
\q1 Za mnoštvo bezakonja tvog,
\q2 za silne grehe tvoje činim ti to.
\q1 
\v 16 Ali svi koji te proždiru,
\q2 proždreće se,
\q1 i neprijatelji tvoji svikoliki
\q2 otići će u ropstvo,
\q1 i koji te gaze,
\q2 biće pogaženi,
\q1 i sve koji te plene,
\q2 daću ih da se oplene.
\q1 
\v 17 Jer ću te isceliti,
\q2 i rane ću ti izlečiti, govori Gospod,
\q1 jer te zvaše oteranom:
\q2 Sionom, kog niko ne traži.
\b
\q1 
\v 18 Ovako veli Gospod:
\q1 Evo, ja ću povratiti iz ropstva šatore Jakovljeve
\q2 i smilovaću se na stanove njegove;
\q1 i grad će se sazidati na mestu svom,
\q2 i dvor će stajati na svoj način.
\q1 
\v 19 I iz njih će izlaziti hvale
\q2 i glas ljudi veselih,
\q1 jer ću ih umnožiti, i neće se umanjivati,
\q2 i uzvisiću ih, i neće se poniziti.
\q1 
\v 20 I sinovi će njegovi biti kao pre,
\q2 i zbor će njegov biti utvrđen preda mnom,
\q2 i pohodiću sve koji mu čine silu.
\q1 
\v 21 I knez će njihov biti od njih,
\q2 i vladalac će njihov izlaziti isred njih;
\q1 i daću mu da pristupa,
\q2 i pristupaće k meni;
\q1 jer ko je taj koji se usuđuje pristupiti k meni?
\q2 Govori Gospod.
\q1 
\v 22 I bićete mi narod,
\q2 i ja ću vam biti Bog.
\b
\q1 
\v 23 Gle, vihor Gospodnji, gnev,
\q2 izići će, vihor, koji ne prestaje,
\q2 pašće na glavu bezbožnicima.
\q1 
\v 24 Neće se povratiti žestoki gnev Gospodnji
\q2 dokle ne učini i izvrši šta je naumio u srcu svom;
\q2 na posletku ćete razumeti to.
\c 31
\s1 Dalje proricanje o budućem spasenju Izrailja i Jude i o novom zavetu.
\p 
\v 1 U to vreme, govori Gospod, ja ću biti Bog svim porodicama Izrailjevim, i oni će mi biti narod.
\b
\q1 
\v 2 Ovako veli Gospod:
\q1 Narod što osta od mača nađe milost u pustinji,
\q2 kad iđah da dam odmor Izrailju.
\q1 
\v 3 Odavna mi se javljaše Gospod.
\q1 Ljubim te ljubavlju večnom,
\q2 zato ti jednako činim milost.
\q1 
\v 4 Opet ću te sazidati, i bićeš sazidana,
\q2 devojko Izrailjeva,
\q1 opet ćeš se veseliti bubnjevima svojim,
\q2 i izlazićeš sa zborom igračkim.
\q1 
\v 5 Opet ćeš saditi vinograde na brdima samarijskim,
\q2 sadiće vinogradari i ješće rod.
\q1 
\v 6 Jer će doći dan kad će vikati čuvari na gori Jefremovoj:
\q2 Ustanite, da idemo na Sion, ka Gospodu Bogu svom.
\b
\q1 
\v 7 Jer ovako veli Gospod:
\q1 Pevajte veselo radi Jakova,
\q2 i podvikujte radi glave narodima;
\q1 javljajte, hvalite i govorite:
\q2 Spasi, Gospode, narod svoj, ostatak Izrailjev.
\q1 
\v 8 Evo, ja ću ih dovesti iz zemlje severne,
\q2 i sabraću ih s krajeva zemaljskih,
\q1 i slepog i hromog,
\q2 i trudnu i porodilju,
\q1 sve zajedno,
\q2 zbor veliki vratiće se ovamo.
\q1 
\v 9 Ići će plačući,
\q2 i s molitvama ću ih dovesti natrag;
\q1 vodiću ih pokraj potoka pravim putem,
\q2 na kome se neće spoticati;
\q1 jer sam Otac Izrailju,
\q2 i Jefrem je prvenac moj.
\b
\q1 
\v 10 Čujte, narodi, reč Gospodnju,
\q2 i javljajte po dalekim ostrvima i recite:
\q1 Koji raseja Izrailja, skupiće ga,
\q2 i čuvaće ga kao pastir stado svoje.
\q1 
\v 11 Jer iskupi Gospod Jakova,
\q2 i izbavi ga iz ruku jačeg od njega.
\q1 
\v 12 I doći će i pevaće na visini sionskoj,
\q2 i steći će se k dobru Gospodnjem,
\q1 k žitu, k vinu i k ulju,
\q2 k jaganjcima i teocima;
\q1 i duša će im biti kao vrt zaliven,
\q2 i neće više tužiti.
\q1 
\v 13 Tada će se veseliti devojka u kolu,
\q2 i momci i starci zajedno,
\q1 i promeniću žalost njihovu na radost, i utešiću ih,
\q2 i razveseliću ih po žalosti njihovoj.
\q1 
\v 14 I napitaću sveštenicima dušu pretilinom,
\q2 i narod će se moj nasititi dobra mog,
\q2 govori Gospod.
\b
\q1 
\v 15 Ovako veli Gospod:
\q1 Glas u Rami ču se,
\q2 naricanje i plač veliki;
\q1 Rahilja plače za decom svojom,
\q2 neće da se uteši za decom svojom, jer ih nema.
\b
\q1 
\v 16 Ovako veli Gospod:
\q1 Ustavi glas svoj od plača
\q2 i oči svoje od suza,
\q1 jer ima plata delu tvom,
\q2 govori Gospod,
\q1 i oni će se vratiti iz zemlje neprijateljske.
\q1 
\v 17 I imaš nadu za posledak, govori Gospod,
\q2 da će se vratiti sinovi tvoji na međe svoje.
\q1 
\v 18 Čujem doista Jefrema gde tuži:
\q1 Pokarao si me,
\q2 te sam pokaran kao june neuko;
\q1 obrati me da se obratim,
\q2 jer si Ti Gospod Bog moj.
\q1 
\v 19 Jer pošto se obratih,
\q2 pokajah se;
\q1 i pošto se naučih,
\q2 udarih se po bedru;
\q1 jer se posramih
\q2 i stidim se što nosim sramotu mladosti svoje.
\q1 
\v 20 Nije li mi Jefrem mio sin?
\q2 Nije li dete predrago?
\q1 Od kad govorih protiv njega,
\q2 jednako ga se opominjem;
\q1 zato je srce moje ustreptalo njega radi,
\q2 doista ću se smilovati na nj,
\q2 govori Gospod.
\b
\q1 
\v 21 Podigni znake, nanesi gomile kamenja,
\q2 zapamti put kojim si išla;
\q1 vrati se, devojko Izrailjeva,
\q2 vrati se u gradove svoje.
\q1 
\v 22 Dokle ćeš lutati,
\q2 kćeri odmetnice!
\q1 Jer je Gospod učinio nešto novo na zemlji:
\q2 žena će opkoliti čoveka.
\b
\p 
\v 23 Ovako veli Gospod nad vojskama, Bog Izrailjev: Još ću ovu reč govoriti u zemlji Judinoj i u gradovima njegovim kad natrag dovedem roblje njihovo:
\b
\q1 Gospod da te blagoslovi,
\q2 stane pravde, sveta goro!
\b
\p 
\v 24 Jer će se naseliti u njoj Juda, i svi gradovi njegovi, i ratari i koji idu za stadom.
\v 25 Jer ću napojiti umornu dušu, i nasititi svaku klonulu dušu.
\p 
\v 26 U tom se probudih i pogledah, i san mi beše sladak.
\p 
\v 27 Evo idu dani, govori Gospod, kad ću zasejati dom Izrailjev i dom Judin semenom čovečijim i semenom od stoke.
\v 28 I kao što sam pazio na njih da ih istrebljujem i razvaljujem, i kvarim i zatirem i mučim, tako ću paziti na njih da ih sazidam i posadim, govori Gospod.
\v 29 U te dane neće se više govoriti:
\b
\q1 Oci jedoše kiselo grožđe,
\q2 a sinovima trnu zubi.
\b
\p 
\v 30 Nego će svaki za svoje grehe poginuti; ko god jede kiselo grožđe, tome će zubi trnuti.
\b
\p 
\v 31 Evo, idu dani, govori Gospod, kad ću učiniti s domom Izrailjevim i s domom Judinim nov zavet,
\v 32 ne kao onaj zavet, koji učinih s ocima njihovim, kad ih uzeh za ruku da ih izvedem iz zemlje misirske, jer onaj zavet moj oni pokvariše, a ja im bejah muž, govori Gospod.
\v 33 Nego ovo je zavet što ću učiniti s domom Izrailjevim posle ovih dana, govori Gospod: metnuću zavet svoj u njih, i na srcu njihovom napisaću ga, i biću im Bog i oni će mi biti narod.
\v 34 I neće više učiti prijatelj prijatelja ni brat brata govoreći: Poznajte Gospoda; jer će me znati svi od malog do velikog, govori Gospod; jer ću im oprostiti bezakonja njihova, i grehe njihove neću više pominjati.
\b
\q1 
\v 35 Ovako veli Gospod,
\q2 koji daje sunce da svetli danju,
\q2 i uredbe mesecu i zvezdama da svetle noću,
\q1 koji raskida more
\q2 i buče vali njegovi,
\q2 kome je ime Gospod nad vojskama:
\q1 
\v 36 Ako tih uredbi nestane ispred mene, govori Gospod,
\q2 i seme će Izrailjevo prestati biti narod preda mnom na vek.
\b
\q1 
\v 37 Ovako veli Gospod:
\q1 Ako se može izmeriti nebo gore
\q2 i izvideti temelji zemaljski dole,
\q1 tada ću i ja odbaciti sve seme Izrailjevo
\q2 za sve što su učinili,
\q2 veli Gospod.
\b
\p 
\v 38 Evo idu dani, govori Gospod, u koje će se sazidati Gospodu ovaj grad od kule Ananeilove do vrata na uglu.
\v 39 I još će dalje otići uže meračko do huma Gariva i obrnuće se na Goat.
\v 40 I sva dolina od mrtvih telesa i pepela, i sva polja sve do potoka Kedrona, do ugla konjskih vrata k istoku, biće svetinja Gospodu; neće se razvaliti ni potrti doveka.
\c 32
\s1 Jeremija za znak povratka iz Vavilona kupuje jednu njivu, moli se Bogu i dobija ponovo Božije obricanje, da će se Izrailj spasti.
\p 
\v 1 Reč koja dođe Jeremiji od Gospoda desete godine Sedekije cara Judinog, koje je osamnaesta godina Navuhodonosorova;
\v 2 a tada vojska cara vavilonskog beše opkolila Jerusalim, i prorok Jeremija beše zatvoren u tremu od tamnice, koja beše u dvoru cara Judinog.
\v 3 Jer ga zatvori Sedekija, car Judin, govoreći: Zašto da prorokuješ govoreći: Ovako veli Gospod: Evo, ja ću predati taj grad u ruke caru vavilonskom i uzeće ga?
\v 4 I Sedekija car Judin neće uteći iz ruku haldejskih, nego će zacelo biti predan u ruke caru vavilonskom, i usta će ovog govoriti s ustima onog, oči će se ovog videti s očima onog.
\v 5 I odvešće Sedekiju u Vavilon, te će ostati onde dokle ga ne pohodim, govori Gospod; ako se bijete s Haldejcima, nećete biti srećni.
\p 
\v 6 Reče, dakle, Jeremija: Dođe mi reč Gospodnja govoreći:
\v 7 Evo, Anameilo, sin Saluma strica tvog, ide k tebi da ti kaže: Kupi njivu moju što je u Anatotu, jer ti imaš po srodstvu pravo da je kupiš.
\v 8 I dođe k meni Anameilo, sin strica mog, po reči Gospodnjoj u trem od tamnice, i reče mi: Hajde kupi moju njivu što je u Anatotu u zemlji Venijaminovoj, jer tebi pripada po nasledstvu i ti imaš pravo otkupiti je; kupi. I razumeh da je reč Gospodnja.
\p 
\v 9 I kupih od Anameila, sina strica svog tu njivu koja je u Anatotu, i izmerih mu novce, sedamnaest sikala srebra.
\v 10 I napisah knjigu, i zapečatih, i uzeh svedoke izmerivši novce na meru.
\v 11 I uzeh knjigu o kupovini zapečaćenu po zakonu i uredbama, i otvorenu,
\v 12 i dadoh knjigu o kupovini Varuhu, sinu Nirije sina Masijinog, pred Anameilom bratučedom svojim i pred svedocima koji se potpisaše na knjizi o kupovini i pred svim Judejcima koji seđahu u tremu od tamnice.
\v 13 I zapovedih Varuhu pred njima govoreći:
\v 14 Ovako veli Gospod nad vojskama Bog Izrailjev: Uzmi ovu knjigu, knjigu o kupovini, zapečaćenu i ovu knjigu otvorenu, i metni ih u zemljan sud da ostanu dugo vremena.
\v 15 Jer ovako veli Gospod nad vojskama Bog Izrailjev: Još će se kupovati kuće i njive i vinogradi u ovoj zemlji.
\b
\p 
\v 16 I davši knjigu o kupovini Varuhu, sinu Nirijinom, pomolih se Gospodu govoreći:
\v 17 Ah, Gospode Gospode! Eto, Ti si stvorio nebo i zemlju silom svojom velikom i mišicom svojom podignutom; ništa nije Tebi teško.
\v 18 Činiš milost na hiljadama, i vraćaš za bezakonje otačko u nedra sinovima njihovim nakon njih; Bože veliki, silni, kome je ime Gospod nad vojskama;
\v 19 veliki u namerama i silni u delima; jer su oči Tvoje otvorene na sve puteve ljudske da daš svakome prema putevima njegovim i prema plodu dela njegovih;
\v 20 koji si činio znake i čudesa do danas u zemlji misirskoj i u Izrailju i među svim ljudima, i stekao si sebi ime kako je danas;
\v 21 jer si izveo narod svoj Izrailja iz zemlje misirske znacima i čudesima i rukom krepkom i mišicom podignutom i strahotom velikom;
\v 22 i dao si im ovu zemlju, za koju se zakle ocima njihovim da ćeš im je dati, zemlju gde teče mleko i med.
\v 23 Ali ušavši u nju i nasledivši je ne poslušaše glas Tvoj, i po Tvom zakonu ne hodiše, i šta si im god zapovedio da čine, ne činiše, zato si učinio te ih snađe sve ovo zlo.
\v 24 Evo, opkopi dođoše do grada da ga uzmu; i od mača i gladi i pomora grad će se dati u ruke Haldejcima koji ga biju; i šta si god rekao, zbiva se, eto vidiš.
\v 25 A Ti mi veliš, Gospode, Gospode: Kupi tu njivu za novce i uzmi svedoke, a grad se predaje u ruke Haldejcima.
\p 
\v 26 Tada dođe reč Gospodnja Jeremiji govoreći:
\v 27 Gle, ja sam Gospod Bog svakog tela, eda li je meni šta teško?
\v 28 Za to ovako veli Gospod: Evo ja dajem taj grad u ruke Haldejcima i u ruke Navuhodonosoru caru vavilonskom da ga uzme.
\v 29 I Haldejci koji biju taj grad ući će u nj, i upaliće ognjem taj grad i spaliće ga i kuće gde na krovovima kadiše Valu i livaše nalive bogovima drugim da bi me razgnevili.
\v 30 Jer sinovi Izrailjevi i sinovi Judini činiše od detinjstva svog samo šta je zlo preda mnom, i sinovi Izrailjevi samo me gneviše delima ruku svojih, govori Gospod.
\v 31 Jer taj grad beše mi na gnev i na srdnju otkad ga sazidaše do danas da bih ga odbacio ispred sebe,
\v 32 za sve zlo sinova Izrailjevih i sinova Judinih što činiše gneveći me, oni, carevi njihovi, knezovi njihovi, sveštenici njihovi i proroci njihovi, Judejci i Jerusalimljani.
\v 33 I okrenuše mi leđa, a ne lice, i kad ih učah za rana jednako, ne poslušaše da bi primili nauku.
\v 34 Nego metnuše svoje gadove u dom koji se zove mojim imenom i oskvrniše ga.
\v 35 I sagradiše visine Valu što su u dolini sina Enomovog da vode sinove svoje i kćeri svoje Molohu, što im ja ne zapovedih niti mi dođe na um, da bi činili taj gad, i tako Judu navodili na greh.
\b
\p 
\v 36 Ali zato opet ovako veli Gospod Bog Izrailjev za taj grad za koji velite da će se dati u ruke caru vavilonskom od mača i gladi i pomora:
\v 37 Evo, ja ću ih sabrati iz svih zemalja u koje ih razagnah u gnevu svom i u jarosti svojoj i u velikoj ljutini, i dovešću ih opet na ovo mesto i učiniti da nastavaju bez straha.
\v 38 I biće mi narod i ja ću im biti Bog.
\v 39 I daću im jedno srce i jedan put da bi me se bojali uvek na dobro svoje i sinova svojih nakon njih.
\v 40 I učiniću s njima zavet večan, da se neću odvratiti od njih čineći im dobro, i daću im strah svoj u srce da ne odstupe od mene.
\v 41 I radovaću im se čineći im dobro i zasadiću ih u ovoj zemlji tvrdo svim srcem svojim i svom dušom svojom.
\p 
\v 42 Jer ovako veli Gospod: Kao što sam doveo na taj narod sve ovo zlo veliko, tako ću dovesti na njih sve dobro koje im obričem.
\v 43 Tada će se kupovati njive u ovoj zemlji, za koju vi kažete da je pusta i da nema u njoj ni živinčeta i da je dana u ruke Haldejcima.
\v 44 Kupovaće njive za novce, i pisaće knjige i pečatiti i uzimati svedoke u zemlji Venijaminovoj i po okolini jerusalimskoj i u gradovima Judinim i u gradovima po gorama i u gradovima po ravnici i u gradovima južnim, jer ću povratiti roblje njihovo, govori Gospod.
\c 33
\s1 Proricanje o izbavljenju iz Vavilona i o večnom zavetu Božijem.
\p 
\v 1 I dođe reč Gospodnja Jeremiji drugi put dok još beše zatvoren u tremu od tamnice, govoreći:
\v 2 Ovako veli Gospod koji čini to, Gospod koji udešava i potvrđuje to, kome je ime Gospod:
\v 3 Zovi me, i odazvaću ti se, i kazaću ti velike i tajne stvari, za koje ne znaš.
\v 4 Jer ovako veli Gospod Bog Izrailjev za domove ovog grada i za domove careva Judinih koji će se razvaliti opkopima i mačem,
\v 5 i za one koji dođoše da se biju s Haldejcima, ali će ih napuniti mrtvim telesima ljudi koje ću pobiti u gnevu svom i u jarosti svojoj odvrativši lice svoje od toga grada za svu zloću njihovu;
\v 6 evo, ja ću ga isceliti i zdravlje mu dati, isceliću ih i pokazaću im obilje mira, postojanog mira.
\v 7 Jer ću povratiti roblje Judino i roblje Izrailjevo, i sazidaću ih kao pre.
\v 8 I očistiću ih od svakog bezakonja njihova kojim mi sagrešiše, i oprostiću im sva bezakonja njihova, kojima mi sagrešiše i kojima se odmetnuše od mene.
\v 9 I biće mi milo ime i hvala i slava u svih naroda na zemlji koji će čuti za sve dobro što ću im učiniti, i uplašiće se i drhtaće radi svega dobra i radi svega mira što ću im ja dati.
\p 
\v 10 Ovako veli Gospod: Na ovom mestu, za koje vi velite da je pusto i nema u njemu ni čoveka ni živinčeta, u gradovima Judinim i po ulicama jerusalimskim opustelim da nema čoveka ni stanovnika ni živinčeta, opet će se čuti
\v 11 glas radostan i glas veseo, glas ženikov i glas nevestin, glas onih koji će govoriti:
\b
\q1 Slavite Gospoda nad vojskama,
\q2 jer je dobar Gospod,
\q2 jer je do veka milost Njegova;
\b
\p koji će prinositi prinose zahvalne u domu Gospodnjem; jer ću vratiti roblje ove zemlje kao što je bilo pre, govori Gospod.
\p 
\v 12 Ovako veli Gospod nad vojskama: Na ovom mestu pustom, gde nema čoveka ni živinčeta, i u svim gradovima njegovim opet će biti torovi pastirski da počivaju stada.
\v 13 U gradovima po gorama, u gradovima po ravnici i u gradovima južnim i u zemlji Venijaminovoj i oko Jerusalima i po gradovima Judinim opet će prolaziti stada ispod ruku brojačevih, veli Gospod.
\b
\p 
\v 14 Evo, idu dani, govori Gospod, kad ću izvršiti ovu dobru reč koju rekoh za dom Izrailjev i za dom Judin.
\v 15 U te dane i u to vreme učiniću da proklija Davidu klica prava, koja će činiti sud i pravdu na zemlji.
\v 16 U te dane spašće se Juda, i Jerusalim će stajati bez straha, i zvaće se: Gospod pravda naša.
\p 
\v 17 Jer ovako veli Gospod: Neće nestati Davidu čoveka koji bi sedeo na prestolu doma Izrailjevog.
\v 18 Na sveštenicima Levitima neće nestati preda mnom čoveka koji bi prinosio žrtvu paljenicu i palio dar i klao žrtvu do veka.
\p 
\v 19 Po tom dođe reč Gospodnja Jeremiji govoreći:
\v 20 Ovako veli Gospod: Ako možete ukinuti zavet moj za dan i zavet moj za noć da ne bude dana ni noći na vreme,
\v 21 onda će se ukinuti i moj zavet s Davidom, slugom mojim, da nema sina koji bi carovao na prestolu njegovom, i s Levitima sveštenicima slugama mojim.
\v 22 Kao što se ne može izbrojati vojska nebeska ni izmeriti pesak morski, tako ću umnožiti seme Davida sluge svog i Levita sluga svojih.
\p 
\v 23 Opet dođe reč Gospodnja Jeremiji govoreći:
\v 24 Nisi li video šta reče taj narod govoreći: Dve porodice, koje beše izabrao Gospod, odbaci ih? I ruže moj narod kao da već nije narod pred njima.
\v 25 Ovako veli Gospod: Ako nisam postavio zavet svoj za dan i za noć i uredbe nebesima i zemlji,
\v 26 onda ću i seme Jakovljevo i Davida sluge svog odbaciti da ne uzimam od semena njegovog one koji će vladati semenom Avramovim, Isakovim i Jakovljevim; jer ću povratiti roblje njihovo i smilovaću se na njih.
\c 34
\s1 Prorokovanje da će se car Sedekija kazniti zajedno s narodom zbog prestupa zakona o godini oslobođenja.
\p 
\v 1 Reč koja dođe Jeremiji od Gospoda, kad Navuhodonosor car vavilonski i sva vojska njegova, i sva carstva zemaljska koja behu pod njegovom vlašću, i svi narodi vojevahu na Jerusalim i na sve gradove njegove, i reče:
\v 2 Ovako veli Gospod Bog Izrailjev: Idi i kaži Sedekiji, caru Judinom, i reci mu: Ovako veli Gospod: Evo, ja ću predati taj grad u ruke caru vavilonskom, i on će ga spaliti ognjem.
\v 3 A ti nećeš uteći iz njegove ruke, nego ćeš biti uhvaćen i predan u njegove ruke, i oči će se tvoje videti s očima cara vavilonskog i njegova će usta govoriti s tvojim ustima, i otići ćeš u Vavilon.
\v 4 Ali čuj reč Gospodnju, Sedekija care Judin; ovako veli Gospod za te: Nećeš poginuti od mača.
\v 5 Nego ćeš umreti na miru, i kao što pališe ocima tvojim, pređašnjim carevima, koji su bili pre tebe, tako će paliti i tebi, i naricaće za tobom: Jaoh gospodaru! Jer ja rekoh ovo, govori Gospod.
\p 
\v 6 I kaza Jeremija prorok Sedekiji caru Judinom sve ove reči u Jerusalimu.
\v 7 A vojska cara vavilonskog udaraše na Jerusalim i na sve ostale gradove Judine, na Lahis i Aziku, jer ti behu ostali tvrdi gradovi između gradova Judinih.
\p 
\v 8 Reč koja dođe Jeremiji od Gospoda kad car Sedekija učini zavet sa svim narodom koji beše u Jerusalimu da im proglasi slobodu,
\v 9 da svaki otpusti slobodnog roba svog i robinju svoju, Jevrejina i Jevrejku, da ni u koga ne bude rob Judejac, brat njegov.
\v 10 I poslušaše svi knezovi i sav narod, koji prista na zavet, da svaki otpusti slobodnog roba svog i robinju svoju, da im ne budu više robovi, poslušaše i otpustiše.
\v 11 A posle, opet, staše uzimati robove i robinje, koje behu otpustili na volju, i nagoniše ih da im budu robovi i robinje.
\v 12 I dođe reč Gospodnja Jeremiji od Gospoda govoreći:
\v 13 Ovako veli Gospod Bog Izrailjev: Ja učinih zavet s ocima vašim kad vas izvedoh iz zemlje misirske, iz doma ropskog, govoreći:
\v 14 Kad se svršuje sedma godina, otpuštajte svaki brata svog Jevrejina koji ti se bude prodao i služio ti šest godina, otpusti ga slobodnog od sebe. Ali ne poslušaše me oci vaši niti prignuše uha svog.
\v 15 I vi se bejaste sada obratili i učinili što je pravo preda mnom proglasivši slobodu svaki bližnjemu svom, učinivši zavet preda mnom u domu koji se zove mojim imenom.
\v 16 Ali udariste natrag i pogrdiste ime moje uzevši opet svaki roba svog i robinju svoju, koje bejaste otpustili slobodne na njihovu volju, i nateraste ih da vam budu robovi i robinje.
\p 
\v 17 Zato ovako veli Gospod: Vi ne poslušaste mene da proglasite slobodu svaki bratu svom i bližnjemu svom; evo, ja proglašujem slobodu suprot vama, govori Gospod, maču, pomoru i gladi, i predaću vas da se potucate po svim carstvima zemaljskim.
\v 18 I predaću ljude koji prestupiše moj zavet, koji ne izvršiše reči zaveta koji učiniše preda mnom, rasekavši tele na dvoje i prošavši između polovina,
\v 19 knezove Judine i knezove jerusalimske, dvorane i sveštenike i sav narod ove zemlje, koji prođoše između polovina onog teleta,
\v 20 predaću ih u ruke neprijateljima njihovim i u ruke onima koji traže dušu njihovu, i mrtva će tela njihova biti hrana pticama nebeskim i zverima zemaljskim.
\v 21 I Sedekiju, cara Judinog, i knezove njegove predaću u ruke neprijateljima njihovim i u ruke onima koji traže dušu njihovu, u ruke vojsci cara vavilonskog, koja se vratila od vas.
\v 22 Evo, ja ću im zapovediti, veli Gospod, i dovešću ih opet na ovaj grad, i biće ga i uzeće ga i spaliće ga ognjem; i gradove Judine obratiću u pustoš da niko neće stanovati u njima.
\c 35
\s1 Poslušnost sinova Rihavovih prema zapovestima njihovog praoca i neposlušnost Judejskog naroda prema Bogu.
\p 
\v 1 Reč koja dođe Jeremiji od Gospoda u vreme Joakima, sina Josijinog cara Judinog, govoreći:
\v 2 Idi k domu sinova Rihavovih i govori s njima, te ih dovedi u dom Gospodnji, u koju klet, i podaj im vino, neka piju.
\v 3 Tada uzeh Jazaniju, sina Jeremije, sina Hovasijinog i braću njegovu i sve sinove i sav dom sinova Rihavovih.
\v 4 I dovedoh ih u dom Gospodnji, u klet sinova Anana sina Igdalijinog čoveka Božijeg, koja je do kleti knezovske, nad kleću Masije sina Salumovog, vratara.
\v 5 I metnuh pred sinove doma Rihavovog krčage pune vina, i čaše, pa im rekoh: Pijte vino.
\v 6 A oni rekoše: Nećemo piti vino, jer Jonadav, sin Rihavov, otac naš zabranio nam je rekavši: Ne pijte vino, ni vi ni sinovi vaši do veka;
\v 7 i kuće ne gradite, ni semena sejte, ni vinograda sadite niti ga držite, nego u šatorima živite svega veka svog, da biste dugo živeli na zemlji, gde ste došljaci.
\v 8 I poslušasmo glas Jonadava, sina Rihavovog oca svog, u svemu što nam zapovedi da ne pijemo vino svega veka svog, ni mi ni naše žene, ni sinovi naši ni kćeri naše,
\v 9 ni da gradimo kuća da u njima živimo, ni da imamo vinograda ni njive ni useva.
\v 10 Nego živimo u šatorima, i slušamo i činimo sve kako nam je zapovedio Jonadav, otac naš.
\v 11 A kad dođe Navuhodonosor, car vavilonski, u ovu zemlju, rekosmo: Hajde da otidemo u Jerusalim ispred vojske haldejske i vojske sirske; i tako ostasmo u Jerusalimu.
\p 
\v 12 Tada dođe reč Gospodnja Jeremiji govoreći:
\v 13 Ovako veli Gospod nad vojskama Bog Izrailjev: Idi reci Judejcima i Jerusalimljanima: Zar nećete da primite nauke da slušate reči moje? Govori Gospod.
\v 14 Izvršuju se reči Jonadava, sina Rihavovog, koji zabrani sinovima svojim da ne piju vino, i ne piju vino do danas, nego slušaju zapovest oca svog; a ja vam govorih zarana jednako, a vi me ne poslušaste.
\v 15 I slah k vama sve sluge svoje proroke zarana jednako govoreći: Vratite se svaki sa svog puta zlog, i popravite dela svoja i ne idite za drugim bogovima služeći im, pak ćete ostati u zemlji koju sam dao vama i ocima vašim, ali ne prignuste uha svog niti me poslušaste.
\v 16 Da, sinovi Jonadava sina Rihavovog izvršuju zapovest oca svog što im je zapovedio, a taj narod ne sluša mene.
\v 17 Zato ovako veli Gospod Bog nad vojskama, Bog Izrailjev: Evo, ja ću pustiti na Judu i na sve stanovnike jerusalimske sve zlo što izrekoh za njih; jer im govorah, a oni ne poslušaše, i zvah ih a oni se ne odazvaše.
\p 
\v 18 A porodici Rihavovoj reče Jeremija: Ovako veli Gospod nad vojskama Bog Izrailjev: Što slušate zapovest Jonadava oca svog i držite sve zapovesti njegove i činite sve kako vam je zapovedio,
\v 19 zato ovako veli Gospod nad vojskama Bog Izrailjev: Neće nestati Jonadavu, sinu Rihavovom čoveka koji bi stajao preda mnom do veka.
\c 36
\s1 Proročanstva se Jeremijina spaljuju, ali se po zapovesti Gospodnjoj ponovo pišu.
\p 
\v 1 A četvrte godine Joakima, sina Josijinog cara Judinog, dođe ova reč Jeremiji od Gospoda govoreći:
\v 2 Uzmi knjigu i napiši u nju sve reči koje sam ti rekao za Izrailja i Judu i za sve narode, od kada ti počeh govoriti, od vremena Josijinog, do danas;
\v 3 eda bi čuo dom Judin sve zlo koje im mislim učiniti i vratio se svak sa svog zlog puta, da bih im oprostio bezakonje i greh njihov.
\p 
\v 4 Tada Jeremija dozva Varuha, sina Nirijinog, i napisa Varuh u knjigu iz usta Jeremijinih sve reči Gospodnje koje mu govori.
\v 5 Potom zapovedi Jeremija Varuhu govoreći: Meni nije slobodno, te ne mogu otići u dom Gospodnji.
\v 6 Nego idi ti, i pročitaj iz knjige koju si napisao iz mojih usta, reči Gospodnje, narodu u domu Gospodnjem u dan posni, i svim Judejcima koji dođu iz gradova svojih pročitaj;
\v 7 ne bi li, moleći se, pripali ka Gospodu i vratili se svaki sa svog puta zlog, jer je velik gnev i jarost što je Gospod izrekao za taj narod.
\v 8 I učini Varuh, sin Nirijin, sve kako mu zapovedi prorok Jeremija, i pročita iz knjige reči Gospodnje u domu Gospodnjem.
\p 
\v 9 A pete godine Joakima sina Josijinog cara Judinog meseca devetog, oglasiše post pred Gospodom svemu narodu jerusalimskom i svemu narodu koji dođe iz gradova Judinih u Jerusalim.
\v 10 I pročita Varuh iz knjige reči Jeremijine u domu Gospodnjem, u kleti Gemarije, sina Safanovog pisara, u gornjem tremu kod novih vrata doma Gospodnjeg pred svim narodom.
\p 
\v 11 A kad ču Mihej, sin Gemarije, sina Safanovog, sve reči Gospodnje iz knjige,
\v 12 on siđe u dom carev u klet pisarevu, i gle, onde seđahu svi knezovi, Elisama pisar, i Delaja sin Semajin, i Elnatan sin Ahvorov, i Gemarija sin Safanov, i Sedekija sin Ananijin, i svi knezovi.
\v 13 I kaza im Mihej sve reči što ču kad Varuh čitaše knjigu narodu.
\v 14 Tada svi knezovi poslaše k Varuhu Judija, sina Natanije sina Selemije, sina Husijevog, i poručiše mu: Knjigu koju si čitao narodu uzmi u ruku i dođi ovamo. I uze knjigu u ruku Varuh, sin Nirijin, i dođe k njima.
\v 15 I oni mu rekoše: Sedi i čitaj da čujemo. I Varuh im je pročita.
\v 16 A kad čuše sve one reči, svi se uplašiše i rekoše Varuhu: Kazaćemo caru sve te reči.
\v 17 I zapitaše Varuha govoreći: Kaži nam kako si napisao sve te reči iz usta njegovih.
\v 18 A Varuh im reče: Iz usta svojih kaziva mi sve te reči, a ja pisah u knjigu mastilom.
\v 19 Tada rekoše knezovi Varuhu: Idi, sakrij se i ti i Jeremija, da niko na zna gde ste.
\p 
\v 20 Potom otidoše k caru u trem ostavivši knjigu u kleti Elisame pisara, i kazaše caru sve te reči.
\v 21 A car posla Judija da donese knjigu; i donese je iz kleti Elisame pisara, i stade čitati Judije pred carem i pred svim knezovima koji stajahu oko cara.
\v 22 A car seđaše u zimnoj kući devetog meseca, i pred njim beše živo ugljevlje.
\v 23 I kad Judije pročita tri četiri lista, iseče je car nožem pisarskim, i baci u oganj na žeravicu, te izgore sva knjiga ognjem na žeravici.
\v 24 Ali se ne uplašiše, niti razdreše haljine svoje car niti koji od sluga njegovih čuvši sve one reči.
\v 25 I premda Elnatan i Delaja i Gemarija moljahu cara da ne pali knjigu, on ih ne posluša.
\v 26 Nego zapovedi car Jerameilu, sinu carevom i Seraji sinu Azrilovom i Selemiji sinu Avdilovom, da uhvate Varuha pisara i Jeremiju proroka; ali ih sakri Gospod.
\p 
\v 27 I dođe reč Gospodnja Jeremiji, pošto car sažeže knjigu i reči koje napisa Varuh iz usta Jeremijinih, govoreći:
\v 28 Uzmi opet drugu knjigu, i napiši u nju sve pređašnje reči koje behu u prvoj knjizi, koju sažeže Joakim car Judin.
\v 29 A za Joakima cara Judinog reci: Ovako veli Gospod: Ti si sažegao onu knjigu govoreći: Zašto si napisao u njoj i rekao: Doći će car vavilonski i zatrti ovu zemlju i istrebiti iz nje i ljude i stoku?
\v 30 Zato, ovako veli Gospod za Joakima cara Judinog: Neće imati nikoga ko bi sedeo na prestolu Davidovom, i mrtvo će telo njegovo biti bačeno na pripeku obdan i na mraz obnoć.
\v 31 Jer ću pohoditi njega i seme njegovo i sluge njegove za bezakonje njihovo, i pustiću na njih i na stanovnike jerusalimske i na Judejce sve zlo, za koje im govorih ali ne poslušaše.
\p 
\v 32 I uze Jeremija drugu knjigu, i dade je Varuhu sinu Nirijinom pisaru, a on napisa u nju iz usta Jeremijinih sve reči što behu u onoj knjizi, koju sažeže Joakim, car Judin ognjem; i još bi dodano k onim mnogo onakvih reči.
\c 37
\s1 Jeremiju tuku i robe.
\p 
\v 1 Potom carova Sedekija, sin Josijin, mesto Honije, sina Joakimovog, kog postavi carem u zemlji Judinoj Navuhodonosor car vavilonski.
\v 2 Ali ni on ni sluge njegove ni narod zemaljski ne slušahu reči Gospodnje koje govoraše preko Jeremije proroka.
\p 
\v 3 I posla car Sedekija Jeuhala sina Selemijinog, i Sofoniju sina Masijinog sveštenika k Jeremiji proroku, te mu rekoše: Pomoli se za nas Gospodu Bogu našem.
\v 4 I Jeremija iđaše među narod i još ga ne behu metnuli u tamnicu.
\v 5 I vojska Faraonova iziđe iz Misira, a Haldejci koji bijahu Jerusalim čuvši glas o njoj otidoše od Jerusalima.
\p 
\v 6 A reč Gospodnja dođe Jeremiji proroku govoreći:
\v 7 Ovako veli Gospod Bog Izrailjev: Ovako recite caru Judinom, koji vas je poslao k meni da me pitate: Evo vojska Faraonova koja pođe vama u pomoć, vratiće se u svoju zemlju, u Misir.
\v 8 A Haldejci će opet doći i opkoliće taj grad i uzeće ga i spaliće ga ognjem.
\v 9 Ovako veli Gospod: Ne varajte se govoreći: Otići će od nas Haldejci, jer neće otići.
\v 10 I da pobijete svu vojsku haldejsku, koja će se biti s vama, i da ih ostane nekoliko ranjenika, i oni će ustati iz svojih šatora i spaliti taj grad ognjem.
\b
\p 
\v 11 A kad otide vojska haldejska od Jerusalima radi vojske Faraonove,
\v 12 iziđe Jeremija iz Jerusalima da bi otišao u zemlju Venijaminovu i uklonio se odande među narod.
\v 13 Ali, kad beše na vratima Venijaminovim, onde beše starešina stražarski po imenu Jereja, sin Selemije sina Ananijinog, te uhvati Jeremiju proroka govoreći: Ti bežiš ka Haldejcima.
\v 14 A Jeremija reče: Nije istina, ne bežim ka Haldejcima. Ali ga ne hte slušati, nego uhvati Jereja Jeremiju i odvede ka knezovima.
\v 15 A knezovi se razgneviše na Jeremiju, i izbiše ga, i metnuše ga u tamnicu u kući Jonatana pisara, jer od nje behu načinili tamnicu.
\p 
\v 16 A kad Jeremija uđe u jamu, u tamnicu, osta onde dugo vremena.
\v 17 Potom posla car Sedekija, te ga izvadi, i upita ga u svojoj kući nasamo, i reče mu govoreći: Ima li reč od Gospoda? A Jeremija reče: Ima. Još reče: Bićeš predan u ruke caru vavilonskom.
\v 18 Po tom reče Jeremija caru Sedekiji: Šta sam ti skrivio ili slugama tvojim ili tom narodu, te me metnuste u tamnicu?
\v 19 I gde su vaši proroci koji vam prorokuju govoreći: Neće doći car vavilonski na vas ni na ovu zemlju?
\v 20 Sada dakle poslušaj, care gospodaru moj, pusti preda se molbu moju, nemoj me vraćati u kuću Jonatana pisara, da ne umrem onde.
\v 21 Tada zapovedi car Sedekija da zatvore Jeremiju u trem od tamnice i da mu daju svaki dan po hleb s ulice hlebarske, dokle traje hleba u gradu. Tako seđaše Jeremija u tremu od tamnice.
\c 38
\s1 Jeremija bačen u jamu; izvadili su ga po zapovesti carevoj od koga traži da se preda neprijatelju.
\p 
\v 1 A Sefatija, sin Matanov i Godolija sin Pashorov i Juhal sin Selemijin i Pashor sin Malhijin, čuše reči koje govori Jeremija svemu narodu rekavši:
\v 2 Ovako veli Gospod: Ko ostane u tom gradu, poginuće od mača, od gladi ili od pomora; a ko otide ka Haldejcima, ostaće živ, i duša će mu njegova biti mesto plena, i biće živ.
\v 3 Ovako veli Gospod: Doista će taj grad biti predan u ruke vojsci cara vavilonskog, i uzeće ga.
\v 4 I rekoše knezovi caru: Da se pogubi taj čovek, jer on oslabljava ruke vojnicima koji ostaše u ovom gradu, i ruke svemu narodu govoreći im takve reči, jer taj čovek ne traži dobra ovom narodu nego zlo.
\v 5 A car Sedekija reče: Eto, u vašim je rukama; jer car ne može ništa nasuprot vama.
\v 6 Tada uzeše Jeremiju, i baciše ga u jamu Malhije sina Amelehovog, koja beše u tremu od tamnice, i spustiše Jeremiju o užima; a u jami ne beše vode, nego glib, i Jeremija se uvali u glib.
\b
\p 
\v 7 Ali kad ču Avdemeleh Etiopljanin, dvoranin, koji beše u dvoru carevom, da su metnuli Jeremiju u onu jamu, a car seđaše na vratima Venijaminovim,
\v 8 iziđe Avdemeleh iz dvora carevog i reče caru govoreći:
\v 9 Care gospodaru moj, zlo učiniše ti ljudi u svemu što učiniše Jeremiji proroku bacivši ga u jamu, jer bi i onde gde je bio od gladi umro, jer nema više hleba u gradu.
\v 10 Zato car zapovedi Avdemelehu Etiopljaninu govoreći: Uzmi odavde trideset ljudi i izvadi Jeremiju proroka iz jame dok nije umro.
\v 11 Tada uze Avdemeleh ljude, i dođe u dom carev pod riznicu, i uze odande iznošenih haljina i starih rita, i spusti ih Jeremiji u jamu o užima.
\v 12 I reče Avdemeleh Etiopljanin Jeremiji: Podmetni te stare haljine i rite pod pazuha ispod uža. I učini Jeremija tako.
\v 13 I izvukoše Jeremiju na užima i izvadiše ga iz jame; i osta Jeremija u tremu od tamnice.
\b
\p 
\v 14 Potom car Sedekija posla po Jeremiju proroka, te ga dovedoše preda nj u treći ulazak koji beše u domu Gospodnjem; i reče car Jeremiji: Zapitaću te nešto, nemoj mi zatajiti.
\v 15 A Jeremija reče Sedekiji: Da ti kažem, nećeš li me pogubiti? A da te savetujem, nećeš me poslušati.
\v 16 Tada se car Sedekija zakle Jeremiji nasamo govoreći: Tako da je živ Gospod, koji nam je stvorio ovu dušu, neću te pogubiti niti ću te dati u ruke ljudima koji traže dušu tvoju.
\p 
\v 17 Tada Jeremija reče Sedekiji: Ovako veli Gospod Bog nad vojskama, Bog Izrailjev: Ako otideš ka knezovima cara vavilonskog, živa će ostati duša tvoja, i grad ovaj neće izgoreti ognjem, i tako ćeš ostati u životu ti i dom tvoj.
\v 18 Ako li ne otideš ka knezovima cara vavilonskog, ovaj će grad biti predan u ruke Haldejcima, koji će ga spaliti ognjem, i ti nećeš pobeći iz ruku njihovih.
\v 19 A car Sedekija reče Jeremiji: Ja se bojim Judejaca koji su prebegli ka Haldejcima, da me ne predaju u njihove ruke, te će mi se narugati.
\v 20 A Jeremija reče: Neće te predati; poslušaj glas Gospodnji, koji ti ja govorim, i dobro će ti biti i živa će biti tvoja duša.
\v 21 Ako li nećeš da iziđeš, ovo je šta mi pokaza Gospod:
\v 22 Gle, sve žene koje su ostale u domu cara Judinog, odvešće se ka knezovima cara vavilonskog, i one će reći:
\b
\q1 Nagovoriše te i prevariše te prijatelji tvoji;
\q2 noge ti se uvališe u glib, a oni se povukoše natrag.
\b
\p 
\v 23 Sve žene tvoje i sinovi tvoji odvešće se Haldejcima, i ti nećeš uteći iz ruku njihovih; nego ćeš dopasti u ruke caru vavilonskom, i ovaj će grad izgoreti ognjem.
\p 
\v 24 Tada reče Sedekija Jeremiji: Niko da ne dozna za te reči, da ne pogineš.
\v 25 Ako li knezovi, čuvši da sam govorio s tobom, dođu k tebi i kažu ti: Kaži nam šta si govorio caru, nemoj tajiti od nas, pa te nećemo pogubiti, i šta je car tebi govorio?
\v 26 Reci im: Ja pripadoh k caru moleći se da me ne pošalje natrag u dom Jonatanov da umrem onde.
\v 27 I dođoše svi knezovi k Jeremiji i pitaše ga; a on im odgovori sasvim kako mu zapovedi car. I okaniše ga se, jer ne doznaše ništa od toga.
\v 28 A Jeremija osta u tremu od tamnice do dana kad uzeše Jerusalim; i on beše onde kad uzeše Jerusalim.
\c 39
\s1 Jerusalim osvojen. Sedekija s iskopanim očima odveden u Vavilon. Jeremija zaštićen od Navuhodonosora prorokuje Avdemelehu da će se izbaviti.
\p 
\v 1 Devete godine Sedekije, cara Judinog, meseca desetog dođe Navuhodonosor, car vavilonski, sa svom vojskom svojom na Jerusalim i stade ga biti.
\v 2 Jedanaeste godine Sedekijine, meseca četvrtog, devetog dana tog meseca provališe u grad.
\v 3 I uđoše svi knezovi cara vavilonskog, i stadoše kod srednjih vrata Nergal-sareser, Samgar-nevon, Sarsehim, starešina nad dvoranima, Nergal-sareser, starešina nad vračima, i svi drugi knezovi cara vavilonskog.
\v 4 A kad ih vide Sedekija car Judin i svi vojnici, pobegoše i iziđoše noću iz grada pokraj vrta carskog, na vrata među dva zida; i iđahu preko polja.
\v 5 A vojska haldejska gonjaše ih, i stiže Sedekiju u polju jerihonskom, i uhvativši ga dovedoše ga k Navuhodonosoru caru vavilonskom u Rivlu, u zemlji ematskoj, te mu sudi.
\v 6 I zakla car vavilonski sinove Sedekijine u Rivli na njegove oči, i sve znatne ljude od Jude pokla car vavilonski.
\v 7 Iza toga Sedekiji iskopa oči, i sveza ga u dvoje verige bronzane, da ga odvede u Vavilon.
\v 8 A dom carev i domove narodne popališe Haldejci ognjem, i zidove jerusalimske raskopaše.
\v 9 A ostatak naroda što osta u gradu i prebege koji prebegoše k njemu, ostatak naroda što beše ostao, odvede Nevuzardan zapovednik stražarski u Vavilon.
\v 10 Samo najsiromašnije iz naroda, koji ništa nemahu, ostavi Nevuzardan zapovednik stražarski u zemlji Judinoj, i dade im tada vinograde i njive.
\b
\p 
\v 11 A Navuhodonosor, car vavilonski, zapovedi za Jeremiju Nevuzardanu zapovedniku stražarskom govoreći:
\v 12 Uzmi ga i gledaj ga dobro, i ne čini mu zlo, nego mu čini šta ti god kaže.
\v 13 I poslaše Nevuzardan zapovednik stražarski i Nevusazvan, starešina nad dvoranima, i Nergal-sareser, starešina nad vračima, i svi knezovi cara vavilonskog,
\v 14 poslaše, te uzeše Jeremiju iz trema od tamnice, i predaše ga Godoliji sinu Ahikama sina Safanovog da ga odvede kući; tako osta među narodom.
\p 
\v 15 A Jeremiji dođe reč Gospodnja kad beše zatvoren u tremu od tamnice govoreći:
\v 16 Idi i reci Avdemelehu Etiopljaninu govoreći: Ovako veli Gospod nad vojskama Bog Izrailjev: Evo ja ću učiniti da se zbudu reči moje tome gradu na zlo, a ne na dobro, i navršiće se pred tobom u onaj dan.
\v 17 Ali ću tebe izbaviti u onaj dan, govori Gospod, i nećeš biti predan u ruke ljudima kojih se bojiš.
\v 18 Jer ću te doista sačuvati, te nećeš pasti od mača, i biće ti duša tvoja mesto plena zato što si se pouzdao u me, govori Gospod.
\c 40
\s1 Jeremija ostaje kod namesnika Godolije u zemlji. Godolija ne veruje u zaveru protiv svog života.
\p 
\v 1 Reč koja dođe Jeremiji od Gospoda kad ga Nevuzardan zapovednik stražarski pusti iz Rame uzevši ga pošto beše okovan u verige među svim robljem jerusalimskim i Judinim, koje se vođaše u Vavilon.
\v 2 I uzevši zapovednik stražarski Jeremiju reče mu: Gospod Bog tvoj izreče ovo zlo za ovo mesto;
\v 3 i nanese i učini kako reče, jer zgrešiste Gospodu i ne slušaste glas Njegov, zato vas snađe ovo.
\v 4 Ali sada, evo, ja te opraštam danas veriga što su ti na rukama; ako ti je volja poći sa mnom u Vavilon, hodi, ja ću se brinuti za te; ako li ti nije volja poći sa mnom u Vavilon, a ti nemoj; evo, sva ti je zemlja otvorena, idi kuda god hoćeš i kuda ti je drago.
\v 5 Ili kad se on još ne vraća, otidi k njemu, Godoliji sinu Ahikama, sina Safanovog, kog je postavio car vavilonski nad gradovima Judinim, i ostani s njim među narodom, ili idi kuda ti je drago. I dade mu zapovednik stražarski brašnjenice i dar, i otpusti ga.
\v 6 I tako dođe Jeremija ka Godoliji, sinu Ahikamovom u Mispu, i osta s njim u narodu, koji još osta u zemlji.
\p 
\v 7 A sve vojvode što behu u polju i ljudi njihovi kad čuše da je car vavilonski postavio Godoliju, sina Ahikamovog, nad zemljom, i da je na njemu ostavio ljude i žene i decu između siromašnog naroda u zemlji, koji ne bi odveden u Vavilon,
\v 8 dođoše u Mispu ka Godoliji Ismailo sin Netanijin i Joanan i Jonatan sinovi Karijini, i Seraja sin Tanumetov i sinovi Jofije Netofaćanina, i Jezanija sin nekog Mahaćanina, oni i ljudi njihovi.
\v 9 I zakle se Godolija sin Ahikama sina Safanovog njima i ljudima njihovim govoreći: Ne bojte se službe Haldejcima; ostanite u zemlji, i služite caru vavilonskom, i dobro će vam biti.
\v 10 A ja evo ću stajati u Mispi da dočekujem Haldejce koji će dolaziti k nama; a vi berite vinograde i voće i ulje, i ostavljajte u sudove svoje, i stojte u gradovima svojim koje držite.
\v 11 Tako i svi Judejci, koji behu među Moavcima i sinovima Amonovim i Edomcima i po svim zemljama, čuvši da je car vavilonski ostavio ostatak u Judeji i postavio nad njima Godoliju sina Ahikama sina Safanovog,
\v 12 vratiše se svi Judejci iz svih mesta kuda behu razagnani, i dođoše u zemlju Judinu ka Godoliji u Mispu, i nabraše vina i voća vrlo mnogo.
\p 
\v 13 A Joanan, sin Karijin i sve vojvode što behu u polju dođoše ka Godoliji u Mispu,
\v 14 i rekoše mu: Znaš li da je Valis car sinova Amonovih poslao Ismaila sina Netanijinog da te ubije? Ali im ne poverova Godolija, sin Ahikamov.
\v 15 Tada Joanan, sin Karijin, reče Godoliji nasamo u Mispi govoreći: Idem da ubijem Ismaila sina Netanijinog, niko neće doznati. Zašto da te ubije i da se raseju svi Judejci koji su se skupili oko tebe i da propadne ostatak Judin?
\v 16 Ali Godolija, sin Ahikamov, reče Joananu sinu Karijinom: Nemoj to činiti, jer nije istina šta kažeš za Ismaila.
\c 41
\s1 Ismailo ubija Godoliju i više Judejaca i Haldejaca. Joanan ga goni. Judejci hoće da idu u Misir.
\p 
\v 1 A sedmog meseca dođe Ismailo, sin Netanije sina Elisaminog, carskog roda, i knezovi carevi, deset ljudi s njim, ka Godoliji sinu Ahikamovom u Mispu, i jedoše onde u Mispi s njim.
\v 2 Potom usta Ismailo, sin Netanijin i deset ljudi što behu s njim, i ubiše mačem Godoliju, sina Ahikama sina Safanovog; tako pogubiše onog koga beše postavio car vavilonski nad zemljom.
\v 3 I sve Judejce koji behu s njim, s Godolijom, u Mispi, i Haldejce koji se zatekoše onde, vojnike, pobi Ismailo.
\p 
\v 4 A sutradan, pošto ubi Godoliju, dok još niko ne dozna,
\v 5 dođoše ljudi iz Sihema, iz Siloma i iz Samarije, osamdeset ljudi, obrijane brade i razdrtih haljina i isparani po telu, i imahu u rukama dar i kad, da prinesu u dom Gospodnji.
\v 6 Tada Ismailo, sin Netanijin, iziđe im iz Mispe na susret i iđaše plačući, i sretavši se s njima reče im: Hodite ka Godoliji, sinu Ahikamovom.
\v 7 A kad dođoše usred grada, pokla ih Ismailo, sin Netanijin, s ljudima koji behu s njim i baci ih u jamu.
\v 8 A među njima se nađe deset ljudi koji rekoše Ismailu: Nemoj nas pogubiti, jer imamo sakriveno blago u polju, pšenice i ječma i ulja i meda. I ostavi ih, i ne pobi ih s braćom njihovom.
\p 
\v 9 A jama u koju pobaca Ismailo sva telesa ljudi koje pobi uz Godoliju beše ona koju načini car Asa bojeći se Vase cara Izrailjevog; i Ismailo sin Netanijin napuni je pobijenih ljudi.
\v 10 I zarobi Ismailo sav ostatak naroda što beše u Mispi, kćeri careve i sav narod što beše ostao u Mispi, nad kojim beše postavio Nevuzardan zapovednik stražarski Godoliju, sina Ahikamovog; i zarobivši ih Ismailo, sin Netanijin, pođe da pređe k sinovima Amonovim.
\p 
\v 11 Ali Joanan, sin Karijin, i sve vojvode što behu s njim čuše sve zlo što učini Ismailo sin Netanijin.
\v 12 Tada uzeše sve svoje ljude i pođoše da udare na Ismaila, sina Netanijinog, kog nađoše kod velike vode u Gavaonu.
\v 13 I sav narod što beše s Ismailom kad vide Joanana sina Karijinog i sve vojvode što behu s njim, obradova se,
\v 14 i sav narod što Ismailo zarobi iz Mispe obrnu se i otide k Joananu, sinu Karijinom.
\v 15 A Ismailo sin Netanijin pobeže s osam ljudi od Joanana, i otide k sinovima Amonovim.
\v 16 I tako Joanan, sin Karijin i sve vojvode što behu s njim uzeše sav ostatak naroda što povratiše od Ismaila, sina Netanijinog, koji ubivši Godoliju, sina Ahikamovog, beše ih odveo iz Mispe, vojnike i žene i decu i dvorane, i odvedoše ih iz Gavaona;
\v 17 i otišavši stadoše u gostionici Himamovoj kod Vitlejema; da bi otišli i prešli u Misir,
\v 18 radi Haldejaca, jer ih se bojahu, što Ismailo, sin Netanijin, ubi Godoliju, sina Ahikamovog, kog beše postavio car vavilonski nad zemljom.
\c 42
\s1 Jeremija po zapovesti Gospodnjoj zabranjuje Joananu i drugim Judejcima da idu u Misir.
\p 
\v 1 Po tom dođoše sve vojvode i Joanan, sin Karijin i Jezanija sin Osajin, i sav narod, malo i veliko.
\v 2 I rekoše Jeremiji proroku: Pusti preda se našu molbu, i pomoli se za nas Gospodu Bogu svom, za sav ovaj ostatak, jer nas je ostalo malo od mnogih, kao što nas oči tvoje vide,
\v 3 da bi nam pokazao Gospod Bog tvoj put kojim ćemo ići i šta ćemo raditi.
\v 4 A Jeremija prorok reče im: Poslušaću; evo, pomoliću se Gospodu Bogu vašem po vašim rečima, i šta vam odgovori Gospod kazaću vam, neću vam zatajiti ni reč.
\v 5 A ovo rekoše Jeremiji: Gospod neka nam je svedok, istinit i veran, da ćemo činiti sve što ti Gospod Bog tvoj zapovedi za nas.
\v 6 Bilo dobro ili zlo, poslušaćemo reč Gospoda Boga svog ka kome te šaljemo, da bi nam dobro bilo kad poslušamo glas Gospoda Boga svog.
\p 
\v 7 A posle deset dana dođe reč Gospodnja Jeremiji;
\v 8 te sazva Joanana, sina Karijinog i sve vojvode što behu s njim, i sav narod, malo i veliko,
\v 9 i reče im: Ovako veli Gospod Bog Izrailjev, ka kome me poslaste da iznesem preda Nj molbu vašu:
\v 10 Ako ostanete u ovoj zemlji, sazidaću vas, i neću vas razoriti, i nasadiću vas i neću vas istrebiti; jer mi je žao sa zla koje sam vam učinio.
\v 11 Ne bojte se cara vavilonskog, kog se bojite; ne bojte ga se, govori Gospod, jer sam ja s vama da vas sačuvam i da vas izbavim iz njegove ruke.
\v 12 I učiniću vam milost da se smiluje na vas, i vrati vas u zemlju vašu.
\v 13 Ako li kažete: Nećemo da ostanemo u toj zemlji, ne slušajući glas Gospoda Boga svog
\v 14 govoreći: Ne, nego idemo u zemlju misirsku, da ne vidimo rat i glas trubni ne čujemo i ne budemo gladni hleba, i onde ćemo se naseliti,
\v 15 onda čujte reč Gospodnju, koji ste ostali od Jude; ovako veli Gospod nad vojskama Bog Izrailjev: Ako vi okrenete lice svoje da idete u Misir i odete da se naselite onde,
\v 16 onde će vas u zemlji misirskoj stignuti mač kog se bojite, i glad, radi koje se brinete, goniće vas onde u Misiru i onde ćete pomreti.
\v 17 I svi ljudi koji su okrenuli lice svoje da idu u Misir da se onde nasele, izginuće od mača i od gladi i od pomora, i nijedan ih neće ostati niti će koji uteći od zla koje ću pustiti na njih.
\p 
\v 18 Jer ovako veli Gospod nad vojskama, Bog Izrailjev: Kao što se gnev moj i jarost moja izli na stanovnike jerusalimske, tako će se izliti gnev moj na vas, ako odete u Misir, i bićete uklin i čudo i kletva i rug, i nećete više videti ovog mesta.
\v 19 Gospod vam govori, ostanci Judini! Ne idite u Misir. Znajte da vam ja svedočim danas.
\v 20 Jer varaste duše svoje kad me poslaste ka Gospodu Bogu svom rekavši: Pomoli se za nas Gospodu Bogu našem, i kako kaže Gospod Bog naš, javi nam i učinićemo.
\v 21 A kad vam javih danas, nećete da poslušate glas Gospoda Boga svog niti išta što mi zapovedi za vas.
\v 22 Znajte, dakle, da ćete izginuti od mača i od gladi i od pomora na mestu kuda ste radi otići da se stanite.
\c 43
\s1 Judejci protiv opomene Božije idu u Misir i uzimaju sa sobom samog proroka, koji tamo proriče upad Navuhodonosorov.
\p 
\v 1 A kad izgovori Jeremija svem narodu sve reči Gospoda Boga njihovog koje mu Gospod Bog njihov zapovedi za njih, sve te reči,
\v 2 tada Azarija, sin Osajin, i Joanan, sin Karijin i svi oni ljudi oholi rekoše Jeremiji govoreći: Nije istina šta govoriš; nije te poslao Gospod Bog naš da nam kažeš: Ne idite u Misir da se onde stanite.
\v 3 Nego Varuh, sin Nirijin, podgovara te na nas da nas preda u ruke Haldejcima da nas pogube ili da nas presele u Vavilon.
\v 4 I tako Joanan, sin Karijin i sve vojvode i sav narod ne poslušaše glas Gospodnji da ostanu u zemlji Judinoj.
\v 5 Nego Joanan, sin Karijin i sve vojvode uzeše sav ostatak Judin koji se beše vratio da živi u zemlji Judinoj iz svih naroda u koje behu razagnani,
\v 6 ljude i žene i decu i kćeri careve, i sve duše što beše ostavio Nevuzardan zapovednik stražarski s Godolijom, sinom Ahikama, sina Safanovog, i Jeremiju proroka i Varuha sina Nirijinog,
\v 7 i odoše u zemlju misirsku, jer ne poslušaše glas Gospodnji; i dođoše do Tafnesa.
\p 
\v 8 I dođe reč Gospodnja Jeremiji u Tafnesu govoreći:
\v 9 Uzmi u ruke velikog kamenja, i pokrij ga kalom u peći za opeke što je na vratima doma Faraonovog u Tafnesu da vide Judejci;
\v 10 i reci im: Ovako veli Gospod nad vojskama, Bog Izrailjev: Evo, ja ću poslati i dovesti Navuhodonosora cara vavilonskog, slugu svog, i metnuću presto njegov na ovo kamenje koje sakrih, i razapeće carski šator svoj na njemu.
\v 11 Jer će doći i zatrti zemlju misirsku; ko bude za smrt otići će na smrt, ko za ropstvo, u ropstvo, ko za mač, pod mač.
\v 12 I raspaliću oganj u kućama bogova misirskih; i popaliće ih i odvešće ih u ropstvo, i ogrnuće se zemljom misirskom kao što se pastir ogrće plaštem svojim, i otići će odande s mirom.
\v 13 I izlomiće stupove u domu sunčanom što je u zemlji misirskoj, i kuće bogova misirskih popaliće ognjem.
\c 44
\s1 Judejcima u Misiru zbog njihovog idolopoklonstva preti Bog teškim kaznama.
\p 
\v 1 Reč koja dođe Jeremiji za sve Judejce koji življahu u zemlji misirskoj, koji življahu u Migdolu i u Tafnesu i u Nofu i u zemlji Patrosu, govoreći:
\v 2 Ovako veli Gospod nad vojskama Bog Izrailjev: Vi videste sve zlo što navedoh na Jerusalim i na sve gradove Judine, i evo su danas pusti i nema nikoga da živi u njima,
\v 3 za zloću njihovu koju činiše da bi me gnevili hodeći da kade i služe drugim bogovima, kojih ne znaše ni oni ni vi ni oci vaši.
\v 4 I slah k vama sve sluge svoje proroke zarana jednako govoreći: Ne činite taj gad na koji mrzim.
\v 5 Ali ne poslušaše niti prignuše uha svog da se vrate od zloće svoje, da ne kade drugim bogovima.
\v 6 Zato se izli jarost moja i gnev moj, i razgore se u gradovima Judinim i po ulicama jerusalimskim, te postaše razvaline i pustoš, kao što se vidi danas.
\v 7 A sada ovako veli Gospod Bog nad vojskama, Bog Izrailjev: zašto sami sebi činite tako veliko zlo da istrebite iz Jude ljude i žene, decu i koja sisaju, da ne ostane u vas ostatka,
\v 8 gneveći me delima ruku svojih, kadeći drugim bogovima u zemlji misirskoj, u koju dođoste da se stanite da biste se istrebili i postali kletva i rug u svih naroda na zemlji.
\v 9 Jeste li zaboravili zla otaca svojih i zla careva Judinih i zla žena njihovih, i svoja zla i zla žena svojih, koja činiše u zemlji Judinoj i po ulicama jerusalimskim?
\v 10 Ne pokoriše se do danas niti se pobojaše, niti hodiše po mom zakonu i uredbama mojim, koje stavih pred vas i pred oce vaše.
\p 
\v 11 Za to ovako veli Gospod nad vojskama, Bog Izrailjev: evo, ja ću vam obratiti lice svoje na zlo, da istrebim sve Judejce.
\v 12 I uzeću ostatak Judin, koji okrenu lice svoje da ide u zemlju misirsku da se onde stani, i izginuće svi; u zemlji će misirskoj pasti i izginuti od mača i od gladi, malo i veliko, izginuće od mača i od gladi, i biće uklin i čudo i prokletstvo i rug.
\v 13 I pohodiću one koji nastavaju u zemlji misirskoj, kao što sam pohodio Jerusalim, mačem, glađu i pomorom;
\v 14 i nijedan od ostatka Judinog, što otidoše u zemlju misirsku da se onde stane, neće uteći niti se izbaviti da se vrate u zemlju Judinu, u koju se žele vratiti da se nasele; jer se neće vratiti, osim koji pobegnu.
\p 
\v 15 Tada odgovoriše Jeremiji svi ljudi koji znahu da žene njihove kade drugim bogovima, i sve žene, kojih stajaše onde velik zbor, i sav narod što življaše u zemlji misirskoj, u Patrosu, govoreći:
\v 16 Šta nam kaza u ime Gospodnje, nećemo te poslušati;
\v 17 nego ćemo činiti sve što je izašlo iz naših usta kadeći carici nebeskoj i lijući joj nalive, kao što smo činili mi i oci naši, carevi naši i knezovi naši po gradovima Judinim i po ulicama jerusalimskim, jer bejasmo siti hleba i beše nam dobro i zlo ne viđasmo.
\v 18 A od kad prestasmo kaditi carici nebeskoj i liti joj nalive, ništa nemamo i ginemo od mača i od gladi.
\v 19 I kad kadimo carici nebeskoj i lijemo joj nalive, eda li joj bez glavara svojih pečemo kolače služeći joj i lijemo joj nalive?
\p 
\v 20 Tada reče Jeremija svemu narodu, ljudima i ženama, i svemu narodu, koji mu onako odgovoriše, govoreći:
\v 21 Eda li se ne opomenu Gospod kada, kojim kadiste u gradovima Judinim i po ulicama jerusalimskim vi i oci vaši, carevi vaši i knezovi vaši i narod zemaljski? I ne dođe li Mu u srce?
\v 22 I ne može Gospod više podnositi zloću dela vaših i gadove koje činiste, te zemlja vaša posta pustoš i čudo i prokletstvo, da niko na živi u njoj, kako se vidi danas.
\v 23 Zato što kadiste i što grešiste Gospodu i ne slušaste glas Gospodnji, i po zakonu Njegovom i uredbama Njegovim i svedočanstvima Njegovim ne hodiste, zato vas zadesi ovo zlo, kako se vidi danas.
\p 
\v 24 Još reče Jeremija svemu narodu i svim ženama:
\p Čujte reč Gospodnju, svi Judejci, koji ste u zemlji misirskoj.
\v 25 Ovako veli Gospod nad vojskama, Bog Izrailjev, govoreći: vi i žene vaše rekoste ustima svojim i rukama svojim izvršiste govoreći: Izvršavaćemo zavete svoje što zavetovasmo kadeći carici nebeskoj i lijući joj nalive. Doista, ispuniste zavete svoje i izvršiste.
\v 26 Zato čujte Judejci reč Gospodnju, svi Judejci koji stanujete u zemlji misirskoj: evo, ja se zaklinjem velikim imenom svojim, veli Gospod, da se ime moje neće više izricati ustima ni jednog Judejca u svoj zemlji misirskoj da bi rekao: tako da je živ Gospod Gospod!
\v 27 Evo, ja ću paziti na njih zla radi, ne dobra radi, i Judejci koji su u zemlji misirskoj, svi će ginuti od mača i od gladi, dokle ih ne bude ni jednog.
\v 28 A koji uteku od mača, vratiće se iz zemlje misirske u zemlju Judinu, malo njih, jer sav ostatak Judin, što otidoše u zemlju misirsku da se onde nastane, poznaće čija će se reč navršiti, moja ili njihova.
\v 29 A ovo da vam je znak, govori Gospod, da ću vas pohoditi na tom mestu da znate da će se doista ispuniti reči moje vama na zlo;
\v 30 ovako veli Gospod: Evo, ja ću dati Faraona Vafrija, cara misirskog, u ruke neprijateljima njegovim i u ruke onim koji traže dušu njegovu, kao što sam dao Sedekiju cara Judinog u ruke Navuhodonosoru caru vavilonskom, neprijatelju njegovom i koji tražaše dušu njegovu.
\c 45
\s1 Prorok teši Varuha Božijim obećanjem da će mu poštedeti život.
\p 
\v 1 Reč koju reče Jeremija prorok Varuhu sinu Nirijinom, kad pisaše ove reči u knjigu iz usta Jeremijinih, četvrte godine Joakima, sina Josijinog, govoreći:
\v 2 Ovako veli Gospod Bog Izrailjev za tebe, Varuše:
\v 3 Rekao si: Teško meni! Jer Gospod dodade mi žalost na tugu; iznemogoh uzdišući, i mira ne nalazim.
\v 4 Reci mu ovo: Ovako veli Gospod: Evo, šta sam sagradio ja razgrađujem, i šta sam posadio iskorenjavam po svoj toj zemlji.
\v 5 A ti li ćeš tražiti sebi velike stvari? Ne traži; jer evo, ja ću pustiti zlo na svako telo, govori Gospod; ali ću tebi dati dušu tvoju mesto plena u svim mestima, kuda odeš.
\c 46
\s1 Proricanje o propasti Misiraca. Uteha Izrailju.
\p 
\v 1 Reč Gospodnja koja dođe Jeremiji proroku za narode:
\p 
\v 2 Za Misirce, za vojsku Faraona Nehaona cara misirskog, koja beše na reci Efratu kod Harkemisa, i razbi je Navuhodonosor car vavilonski četvrte godine Joakima sina Josijinog cara Judinog.
\b
\q1 
\v 3 Pripravite štite i štitiće,
\q2 i idite u boj;
\q1 
\v 4 Prežite konje, i pojašite, konjici;
\q2 postavite se sa šlemovima;
\q1 utrite koplja,
\q2 oblačite se u oklope.
\q1 
\v 5 Zašto ih vidim gde se poplašiše,
\q2 vraćaju se natrag,
\q1 junaci njihovi polomiše se
\q2 i beže bez obzira?
\q1 Strah je od svuda,
\q2 govori Gospod.
\b
\q1 
\v 6 Da ne uteče laki,
\q2 niti se izbavi jaki;
\q1 da se na severu na bregu reke Efrata
\q2 spotaknu i padnu.
\b
\q1 
\v 7 Ko je to što se diže kao potok,
\q2 i vode mu se kolebaju kao reke?
\q1 
\v 8 Misir se diže kao potok
\q2 i njegove se vode kolebaju kao reke;
\q1 i veli: Idem, pokriću zemlju,
\q2 zatrću grad i one koji žive u njemu.
\q1 
\v 9 Izlazite, konji,
\q2 besnite, kola;
\q1 i neka izađu junaci,
\q2 Husi i Fudi, koji nose štitove,
\q2 i Ludeji, koji nose i natežu luk.
\q1 
\v 10 Jer je ovaj dan Gospodu Gospodu nad vojskama dan osvete,
\q2 da se osveti neprijateljima svojim;
\q1 mač će ih proždreti
\q2 i nasitiće se i opiće se krvlju njihovom;
\q1 jer će biti žrtva Gospoda Gospoda nad vojskama
\q2 u zemlji severnoj na reci Efratu.
\q1 
\v 11 Iziđi u Galad i uzmi balsama,
\q2 devojko kćeri misirska;
\q1 zaludu su ti mnogi lekovi,
\q2 nećeš se izlečiti.
\q1 
\v 12 Narodi čuše sramotu tvoju,
\q2 i vike tvoje puna je zemlja,
\q1 jer se spotiču junak o junaka,
\q2 te obojica padaju.
\b
\p 
\v 13 Reč koju reče Gospod Jeremiji proroku o dolasku Navuhodonosora cara vavilonskog da potre zemlju misirsku:
\b
\q1 
\v 14 Javite u Misiru,
\q2 i oglasite u Migdolu,
\q2 oglasite i u Nofu i u Tafnesu,
\q1 i recite: Stani i pripravi se,
\q2 jer mač proždre šta je oko tebe.
\q1 
\v 15 Zašto se povaljaše junaci tvoji?
\q2 Ne stoje, jer ih Gospod obara.
\q1 
\v 16 Čini, te se mnogi spotiču i padaju jedan na drugog,
\q2 i govore:
\q1 Ustani da se vratimo k narodu svom i na postojbinu svoju
\q2 ispred mača nasilnikovog.
\q1 
\v 17 Viču onde:
\q2 Faraon car misirski propade, prođe mu rok.
\b
\q1 
\v 18 Tako da sam ja živ, govori car,
\q2 kome je ime Gospod nad vojskama;
\q1 kao Tavor među gorama
\q2 i kao Karmil na moru doći će.
\q1 
\v 19 Spremi šta ti treba da se seliš, stanovnice,
\q2 kćeri misirska;
\q1 jer će Nof opusteti i spaliće se
\q2 da neće niko živeti u njemu.
\b
\q1 
\v 20 Misir je lepa junica;
\q2 ali pogibao ide, ide sa severa.
\q1 
\v 21 I najamnici su njegovi usred njega kao teoci ugojeni,
\q2 ali se i oni obrnuše i pobegoše, ne ostaše,
\q1 jer dođe na njih dan nesreće njihove,
\q2 vreme pohođenja njihovog.
\b
\q1 
\v 22 Glas će njihov ići kao glas zmijinji,
\q2 jer oni idu s vojskom
\q1 i doći će sa sekirama na nj
\q2 kao oni koji seku drva.
\q1 
\v 23 I oni će poseći šumu njegovu, govori Gospod,
\q2 ako joj i nema mere,
\q1 jer ih je više nego skakavaca
\q2 i nema im broja.
\q1 
\v 24 Posrami se kći misirska,
\q2 predana je u ruke narodu severnom.
\b
\p 
\v 25 Govori Gospod nad vojskama, Bog Izrailjev: Evo, ja ću pohoditi ljudstvo u Noji, i Faraona i Misir i bogove njegove i careve njegove, Faraona i sve koji se uzdaju u nj.
\v 26 I daću ih u ruke onima koji traže dušu njihovu, u ruke Navuhodonosoru caru vavilonskom i u ruke slugama njegovim; a posle će biti naseljen kao pre, govori Gospod.
\b
\q1 
\v 27 A ti se ne boj, slugo moj Jakove,
\q2 i ne plaši se, Izrailju,
\q1 jer evo ja ću te izbaviti iz daleke zemlje
\q2 i seme tvoje iz zemlje ropstva njegovog;
\q1 i Jakov će se vratiti i počivaće,
\q2 i biće miran i niko ga neće plašiti.
\q1 
\v 28 Ti se ne boj, slugo moj Jakove, govori Gospod,
\q2 jer sam ja s tobom;
\q1 jer ću učiniti kraj svim narodima, u koje te prognah,
\q2 ali tebi neću učiniti kraja,
\q1 nego ću te pokarati s merom,
\q2 a neću te ostaviti sasvim bez kara.
\c 47
\s1 Proricanje o propasti Filisteja, Tira i Sidona.
\p 
\v 1 Reč Gospodnja koja dođe Jeremiji proroku za Filisteje pre nego Faraon osvoji Gazu.
\b
\q1 
\v 2 Ovako veli Gospod:
\q1 Evo, voda dolazi sa severa,
\q2 i biće kao potok koji se razliva,
\q1 i potopiće zemlju i šta je u njoj,
\q2 grad i one koji žive u njemu;
\q1 i ljudi će vikati,
\q2 i ridaće svi stanovnici zemaljski.
\q1 
\v 3 Od topota kopita jakih konja njegovih,
\q2 od tutnjave kola njegovih,
\q2 i praske točkova njegovih,
\q1 neće se obazreti očevi na sinove,
\q2 jer će im ruke klonuti,
\q1 
\v 4 Od onog dana koji će doći da istrebi sve Filisteje
\q2 i da zatre Tir i Sidon i sve ostale pomoćnike,
\q1 jer će Gospod istrebiti Filisteje,
\q2 ostatak ostrva Kaftora.
\q1 
\v 5 Oćelaviće Gaza, propašće Askalon i ostatak doline njihove;
\q2 dokle ćeš se rezati?
\q1 
\v 6 Jaoh, maču Gospodnji,
\q2 kad ćeš se smiriti?
\q1 Vrati se u korice svoje,
\q2 stani i smiri se.
\q1 
\v 7 Ali kako bi se smirio?
\q2 Jer mu Gospod dade zapovest na Askalon i na primorje;
\q2 onamo ga odredi.
\c 48
\s1 Proricanje o propasti Moava.
\p 
\v 1 Za Moava ovako govori Gospod nad vojskama, Bog Izrailjev:
\b
\q1 Teško Nevonu! Jer će se opustošiti;
\q2 Kirijatajim će se posramiti i uzeti;
\q2 Mizgav će se posramiti i prepasti.
\q1 
\v 2 Neće se više hvaliti Moav Esevonom;
\q2 jer mu zlo misle:
\q1 Hodite da ga istrebimo
\q2 da nije više narod.
\q1 I ti, Madmane, opustećeš;
\q2 mač će te goniti.
\b
\q1 
\v 3 Čuje se vika iz Oronajima,
\q2 pustošenje i satiranje veliko.
\q1 
\v 4 Moav se satre;
\q2 stoji vika dece njegove.
\q1 
\v 5 Jer će se putem luitskim dizati plač bez prestanka;
\q2 i kako se silazi u Oronajim, neprijatelji će čuti strašnu viku;
\q1 
\v 6 Bežite, izbavite duše svoje,
\q2 i budite kao vres u pustinji.
\q1 
\v 7 Jer što se uzdaš u svoja dela i u blago svoje,
\q2 zato ćeš se i ti uzeti,
\q1 i Hemos će otići u ropstvo,
\q2 sveštenici njegovi i knezovi njegovi skupa.
\q1 
\v 8 I doći će zatirač u svaki grad,
\q2 neće se sačuvati ni jedan grad;
\q1 dolina će propasti i ravnica će se opustošiti,
\q2 jer Gospod reče.
\b
\q1 
\v 9 Podajte krila Moavu, neka brzo odleti;
\q2 jer će gradovi njegovi opusteti da neće niko živeti u njima.
\b
\p 
\v 10 Proklet bio ko nemarno radi delo Gospodnje, i proklet ko usteže mač svoj od krvi!
\b
\q1 
\v 11 Moav je bio u miru od detinjstva svog
\q2 i počivao na droždini svojoj,
\q1 niti se pretakao iz suda u sud,
\q2 niti je u ropstvo išao;
\q1 zato mu osta kus njegov,
\q2 i miris se njegov nije promenio.
\b
\p 
\v 12 Zato, evo, idu dani, govori Gospod, da mu pošaljem premetače, koji će ga premetnuti, i sudove njegove isprazniti i mehove njegove pokidati.
\v 13 I Moav će se osramotiti s Hemosa, kao što se osramotio dom Izrailjev s Vetilja, gada svog.
\b
\q1 
\v 14 Kako govorite:
\q2 Jaki smo i junaci u boju?
\q1 
\v 15 Moav će se opustošiti i gradovi će njegovi propasti,
\q2 i najbolji mladići njegovi sići će na zaklanje,
\q1 govori car,
\q2 kome je ime Gospod nad vojskama.
\q1 
\v 16 Blizu je pogibao Moavova,
\q2 i zlo njegovo vrlo hiti.
\q1 
\v 17 Žalite ga svi koji ste oko njega,
\q2 i koji god znate za ime njegovo,
\q1 recite:
\q2 Kako se slomi jaki štap, slavna palica?
\b
\q1 
\v 18 Siđi sa slave svoje, i sedi na mesto zasušeno,
\q2 kćeri, koja živiš u Devonu;
\q1 jer će zatirač Moavov doći na tebe
\q2 i raskopaće gradove tvoje.
\q1 
\v 19 Stani na putu, i pogledaj,
\q2 koja živiš u Aroiru,
\q1 upitaj onog koji beži i onu koja gleda da se izbavi,
\q2 reci: Šta bi?
\q1 
\v 20 Posrami se Moav;
\q2 jer se razbi;
\q1 ridajte i vičite;
\q2 javite u Arnon da se Moav opustoši.
\b
\p 
\v 21 Jer sud dođe na zemlju ravnu, na Olon i na Jasu i Mifat,
\v 22 i na Devon i na Nevon i na Vet-Devlatajim,
\v 23 i na Kirijatajim i na Vet-Gamul i na Vet-Meon,
\v 24 i na Keriot i na Vosoru, i na sve gradove zemlje moavske, koji su daleko i koji su blizu.
\v 25 Odbijen je rog Moavu, i mišica se njegova slomi, govori Gospod.
\p 
\v 26 Opojte ga, jer se podigao na Gospoda; neka se valja Moav u bljuvotini svojoj, i bude i on podsmeh.
\v 27 Jer, nije li tebi Izrailj bio podsmeh? Je li se zatekao među lupežima, te kad god govoriš o njemu poskakuješ?
\b
\q1 
\v 28 Ostavite gradove i naselite se u steni, stanovnici moavski,
\q2 i budite kao golubica koja se gnezdi u kraju i raselini.
\q1 
\v 29 Čusmo ponos Moavov
\q2 da je veoma ponosit,
\q1 oholost njegovu i ponos,
\q2 razmetanje njegovo i obest njegovu.
\q1 
\v 30 Znam ja, govori Gospod,
\q2 obest njegovu;
\q1 ali neće biti tako;
\q2 laži njegove neće učiniti ništa.
\q1 
\v 31 Zato ću ridati za Moavom,
\q2 vikati za svim Moavom,
\q2 uzdisaće se za onima u Kir-eresu.
\q1 
\v 32 Više nego za Jazirom plakaću za tobom,
\q2 lozo sivamska;
\q1 odvode tvoje pređoše more,
\q2 dopreše do mora jazirskog;
\q1 zatirač napade na letinu tvoju
\q2 i na berbu tvoju.
\q1 
\v 33 I radost i veselje otide s rodnog polja,
\q2 iz zemlje moavske,
\q1 i učinih te nesta u kacama vina;
\q2 niko neće gaziti pevajući;
\q2 pesma neće se više pevati.
\b
\p 
\v 34 Od vike esevonske, koja dopre do Eleale, podigoše viku do Jase, od Sigora do Oronajima, kao junica od tri godine, jer će i voda nimrimskih nestati.
\v 35 I učiniću, govori Gospod, da ne bude Moavu čoveka koji bi prinosio žrtvu na visini i kadio bogovima svojim.
\v 36 Zato će srce moje pištati za Moavom kao svirala, i srce će moje pištati kao svirala za ljudima u Kir-eresu, jer će mu sva tečevina propasti.
\p 
\v 37 Jer će sve glave biti ćelave i sve brade obrijane, i sve ruke izrezane, i oko bedara kostret.
\v 38 Na svim krovovima Moavovim i po ulicama njegovim biće sam plač, jer ću razbiti Moava kao sud na kome nema miline, govori Gospod.
\v 39 Ridajte: Kako je satrven! Kako Moav obrnu pleći sramotan? I posta Moav podsmeh i strahota svima koji su oko njega.
\b
\q1 
\v 40 Jer ovako govori Gospod:
\q1 Evo, kao orao doleteće
\q2 i raširiće krila svoja nad Moavom.
\q1 
\v 41 Keriot je pokoren i tvrda se mesta zauzeše,
\q2 i srca će u junaka Moavovih biti u onaj dan kao srce u žene koja se porađa.
\q1 
\v 42 I Moav će se istrebiti da ne bude narod,
\q2 jer se podiže na Gospoda.
\q1 
\v 43 Strah i jama i zamka oko tebe je, stanovniče moavski,
\q2 govori Gospod.
\q1 
\v 44 Ko uteče od straha, pašće u jamu,
\q2 a ko izađe iz jame, uhvatiće se u zamku;
\q1 jer ću pustiti na njega, na Moava, godinu pohođenja njihovog,
\q2 govori Gospod.
\b
\q1 
\v 45 U senu esevonskom ustaviše se koji bežahu od sile;
\q2 ali će oganj izaći iz Esevona
\q2 i plamen isred Siona,
\q1 i opaliće kraj Moavu
\q2 i teme nemirnicima.
\q1 
\v 46 Teško tebi, Moave,
\q2 propade narod Hemosov,
\q1 jer sinove tvoje zarobiše,
\q2 i kćeri tvoje odvedoše u ropstvo.
\q1 
\v 47 Ali ću povratiti roblje Moavovo u poslednje vreme,
\q2 govori Gospod.
\q1 Dovde je sud Moavu.
\c 49
\s1 Proricanje o propasti Amona, Edoma, Damaska, Kidara, Asora i Elama.
\p 
\v 1 Za sinove Amonove: Ovako veli Gospod:
\b
\q1 Zar Izrailj nema sinove?
\q2 Zar nema naslednike?
\q1 Zašto Malhom nasledi zemlju Gadovu?
\q2 I zašto se narod njegov naseli u njegovim gradovima?
\q1 
\v 2 Zato evo idu dani, govori Gospod,
\q2 kad ću učiniti da se čuje vika ubojna u Ravi sinova Amonovih,
\q1 i ona da bude gomila razvalina,
\q2 i sela njena popaljena ognjem;
\q1 i Izrailj će ovladati onima koji behu njim ovladali,
\q2 govori Gospod.
\b
\q1 
\v 3 Ridaj Esevone, jer je Gaj opustošen,
\q2 vičite sela ravska,
\q1 pripašite oko sebe kostret,
\q2 naričite i trčite oko plotova;
\q1 jer će Malhom otići u ropstvo,
\q2 sveštenici njegovi i knezovi njegovi skupa.
\q1 
\v 4 Što se hvališ dolinama?
\q2 Rastopila se dolina tvoja, kćeri odmetnico!
\q1 Koja se uzdaš u blago svoje:
\q2 Ko bi udario na me?
\q1 
\v 5 Evo ja ću pustiti na te strah od svuda unaokolo,
\q2 govori Gospod Gospod nad vojskama,
\q1 i raspršaćete se svi,
\q2 i neće biti nikoga da skupi bežan.
\b
\p 
\v 6 Ali ću posle povratiti roblje sinova Amonovih, govori Gospod.
\b
\p 
\v 7 Za Edoma, ovako veli Gospod nad vojskama:
\b
\q1 Zar nema više mudrosti u Temanu?
\q2 Nesta li saveta razumnima?
\q2 Iščile li mudrost njihova?
\q1 
\v 8 Bežite, obratite pleći, zavrite se duboko,
\q2 stanovnici dedanski,
\q1 jer ću pustiti na Isava pogibao njegovu
\q2 u vreme kad ću ga pohoditi.
\q1 
\v 9 Da ti dođu berači,
\q2 ne bi li ti ostavili pabiraka?
\q1 Da dođu lupeži noću,
\q2 ne bi li odneli koliko im je dosta?
\q1 
\v 10 Ali ja ogoluznih Isava,
\q2 otkrih potaje njegove da se ne može sakriti;
\q1 propade seme njegovo,
\q2 braća njegova i susedi njegovi, niko ne osta.
\q1 
\v 11 Ostavi sirote svoje,
\q2 ja ću im život sačuvati,
\q1 i udovice tvoje neka se uzdaju u me.
\b
\p 
\v 12 Jer ovako veli Gospod: Evo, koji ne bi trebalo da piju iz čaše, doista će piti; a ti li ćeš ostati bez kara? Nećeš ostati bez kara, nego ćeš zacelo piti.
\v 13 Jer sobom se zaklinjem, govori Gospod, da će Vosora biti pustoš, rug, čudo i prokletstvo, i svi će gradovi njeni biti pustinja večna.
\b
\q1 
\v 14 Čuh glas od Gospoda,
\q2 i glasnik bi poslan k narodima da reče:
\q1 Skupite se i idite na nju,
\q2 i dignite se u boj.
\q1 
\v 15 Jer gle, učiniću te da budeš mali među narodima
\q2 i prezren među ljudima.
\q1 
\v 16 Obest tvoja i ponositost srca tvog prevari tebe,
\q2 koji živiš u raselinama kamenim
\q2 i držiš se visokih humova;
\q1 da načiniš sebi gnezdo visoko kao orao,
\q2 i odande ću te svaliti,
\q2 govori Gospod.
\b
\p 
\v 17 I zemlja će edomska biti pustinja, ko prođe mimo nju, svak će se čuditi i zviždati radi svih rana njenih.
\v 18 Kao kad se zatre Sodom i Gomor i susedstvo njihovo, veli Gospod, neće se naseliti onde niko niti će se baviti onde sin čovečji.
\v 19 Gle, kao lav izaći će podižući se više nego Jordan na stan Silnoga; ali ću ga brzo oterati iz te zemlje, i postaviću nad njom onog ko je izabran; jer ko je kao ja? I ko će se preti sa mnom? I koji će mi pastir odoleti?
\v 20 Zato čujte nameru Gospodnju što je naumio za Edomce i misli njegove što je smislio za stanovnike temanske: zaista najmanji iz stada razvlačiće ih, zaista će opusteti stan s njima.
\v 21 Od praske padanja njihovog zemlja će se tresti, i vika će se njihova čuti na crvenom moru.
\v 22 Gle, doći će i doleteće kao orao i raširiće krila svoja nad Vosorom, i biće srce u junaka edomskih kao srce u žene koja se porađa.
\b
\p 
\v 23 Za Damask.
\b
\q1 Posrami se Emat i Arfad,
\q2 jer ču zle glase;
\q1 rastopiše se, strah je na moru,
\q2 ne može se umiriti.
\q1 
\v 24 Damask klonu,
\q2 obrati se da beži,
\q1 drhat ga poduze,
\q2 tuga i bolovi osvojiše ga kao porodilju.
\q1 
\v 25 Kako se ne ostavi slavni grad?
\q2 Grad radosti moje?
\q1 
\v 26 Zato će popadati mladići njegovi na ulicama njegovim,
\q2 i svi će vojnici njegovi izginuti u onaj dan,
\q2 govori Gospod nad vojskama.
\q1 
\v 27 I raspaliću oganj u zidovima damaštanskim,
\q2 i proždreće dvore Ven-Adadove.
\b
\p 
\v 28 Za Kidar i za carstva asorska, koja razbi Navuhodonosor car vavilonski, ovako veli Gospod:
\b
\q1 Ustanite, idite na Kidar,
\q2 i zatrite sinove istočne.
\q1 
\v 29 Uzeće im šatore i stada,
\q2 zavese njihove i sudove njihove i kamile njihove oteće,
\q2 i vikaće na njih strašno odsvuda.
\q1 
\v 30 Bežite, selite se daleko, sakrijte se duboko, stanovnici asorski,
\q2 govori Gospod,
\q1 jer je Navuhodonosor car vavilonski namerio nameru protiv vas,
\q2 i smislio misao protiv vas.
\b
\q1 
\v 31 Ustanite, idite k narodu mirnom, koji živi bez straha,
\q2 govori Gospod,
\q1 koji nema vrata ni prevornica,
\q2 žive sami.
\q1 
\v 32 I kamile će njihove biti plen,
\q2 i mnoštvo stoke njihove grabež,
\q1 i rasejaću ih u sve vetrove,
\q2 one što se s kraja strižu,
\q1 i dovešću pogibao na njih sa svih strana,
\q2 govori Gospod.
\q1 
\v 33 I Asor će biti stan zmajevski,
\q2 pustinja do veka:
\q1 niko se neće onde naseliti,
\q2 niti će se baviti u njemu sin čovečji.
\b
\p 
\v 34 Reč Gospodnja koja dođe Jeremiji proroku za Elam, u početku carovanja Sedekije cara Judinog, govoreći:
\p 
\v 35 Ovako veli Gospod nad vojskama: Evo, ja ću slomiti luk Elamu, glavnu silu njegovu;
\v 36 i dovešću na Elam četiri vetra s četiri kraja nebesa, i u sve te vetrove rasejaću ih, tako da neće biti naroda kuda neće otići prognanici elamski.
\v 37 I uplašiću Elamce pred neprijateljima njihovim, i pred onima koji traže dušu njihovu; i pustiću zlo na njih, žestinu gneva svog, govori Gospod, i pustiću za njima mač dokle ih ne zatrem.
\v 38 I namestiću presto svoj u Elamu, i istrebiću odande cara i knezove, govori Gospod.
\p 
\v 39 Ali u poslednje vreme povratiću roblje elamsko, govori Gospod.
\c 50
\s1 Proricanje o propasti Vavilona i o spasenju judejskog naroda.
\p 
\v 1 Reč koju reče Gospod za Vavilon i za zemlju haldejsku preko Jeremije proroka.
\b
\q1 
\v 2 Javite narodima i razglasite,
\q2 podignite zastavu,
\q1 razglasite, ne tajite,
\q2 recite:
\q1 Uze se Vavilon, posrami se Vil,
\q2 razbi se Merodah;
\q1 posramiše se idoli njegovi,
\q2 razbiše se gadni bogovi njegovi.
\b
\p 
\v 3 Jer se narod podiže na nj sa severa, koji će mu zemlju opusteti, da neće biti nikoga da živi u njoj; i ljudi i stoka pobeći će i otići.
\p 
\v 4 U te dane i u to vreme, govori Gospod, doći će sinovi Izrailjevi i sinovi Judini zajedno, ići će plačući i tražiće Gospoda Boga svog.
\v 5 Pitaće za put u Sion, i obrativši se onamo reći će: Hodite, sjedinimo se s Gospodom zavetom večnim, koji se ne zaboravlja.
\p 
\v 6 Narod je moj stado izgubljeno; pastiri njegovi zavedoše ga, te luta po gorama, ide s brda na humove, zaboravivši stan svoj.
\v 7 Ko ih nađe, proždiraše ih, i neprijatelji njihovi govoriše: Nećemo biti krivi, jer zgrešiše Gospodu, stanu pravde, Gospodu, nadi otaca njihovih.
\p 
\v 8 Bežite iz Vavilona i iziđite iz zemlje haldejske i budite kao ovnovi pred stadom.
\v 9 Jer, evo, ja ću podignuti i dovešću na Vavilon zbor velikih naroda iz zemlje severne, koji će se uvrstati da se biju s njim, i uzeće ga; strele su im kao u dobrog junaka, ne vraćaju se prazne.
\v 10 I zemlja će se haldejska opleniti, svi koji će je pleniti nasitiće se, govori Gospod.
\b
\q1 
\v 11 Jer se veseliste, jer se radovaste
\q2 pleneći moje nasledstvo;
\q1 jer besneste kao junica na travi
\q2 i rzaste kao jaki konji.
\q1 
\v 12 Mati se vaša osramoti vrlo,
\q2 roditeljka vaša postide se;
\q1 evo biće poslednja među narodima,
\q2 pustinja, zemlja suva i pustoš.
\q1 
\v 13 Od gneva Gospodnjeg neće se u njoj živeti,
\q2 nego će sva opusteti;
\q1 ko god prođe mimo Vavilon, čudiće se
\q2 i zviždaće radi svih rana njegovih.
\q1 
\v 14 Postavite se oko Vavilona
\q2 svi koji natežete luk,
\q1 streljajte ga, ne žalite strela;
\q2 jer je sagrešio Gospodu.
\q1 
\v 15 Vičite na nj unaokolo;
\q2 pruža ruku;
\q1 temelji mu padoše,
\q2 zidovi su mu razvaljeni;
\q1 jer je osveta Gospodnja, osvetite mu se;
\q2 kako je činio, onako mu činite.
\q1 
\v 16 Istrebite iz Vavilona sejača
\q2 i onog koji maše srpom o žetvi;
\q1 od mača nasilnikovog neka se vrati svaki svom narodu,
\q2 i svaki u svoju zemlju neka beži.
\b
\p 
\v 17 Izrailj je stado razagnano, lavovi ga rasplašiše; najpre ga jede car asirski, a posle mu kosti izlomi Navuhodonosor, car vavilonski.
\v 18 Zato ovako veli Gospod nad vojskama, Bog Izrailjev: Evo, ja ću pohoditi cara vavilonskog i zemlju njegovu, kao što sam pohodio cara asirskog.
\v 19 I povratiću Izrailja u torove njegove, i pašće po Karmilu i Vasanu; i po gori Jefremovoj i Galadu sitiće se duša njegova.
\v 20 U one dane i u ono vreme, govori Gospod, tražiće se bezakonje Izrailjevo, ali ga neće biti; i gresi Judini, ali se neće naći, jer ću oprostiti onima koje ostavim.
\b
\q1 
\v 21 Iziđi na zemlju meratijamsku
\q2 i na stanovnike fekodske;
\q1 zatri i istrebi iza njih, govori Gospod,
\q2 i učini sve kako ti zapovedim.
\q1 
\v 22 Vika je ubojna u zemlji
\q2 i polom velik.
\q1 
\v 23 Kako se slomi i skrši malj cele zemlje?
\q2 Kako Vavilon posta čudo među narodima?
\q1 
\v 24 Ja ti metnuh zamku, Vavilone,
\q2 i ti se uhvati ne doznavši,
\q1 našao si se i uhvatio si se,
\q2 jer si se zaratio s Gospodom.
\q1 
\v 25 Gospod otvori riznicu svoju
\q2 i izvadi oružje gneva svog;
\q1 jer je to delo Gospoda Gospoda nad vojskama
\q2 u zemlji haldejskoj.
\q1 
\v 26 Hodite na nju s kraja zemlje,
\q2 otvorite žitnice njene;
\q1 gazite je kao stogove,
\q2 i potrite je da ne ostane od nje ostatka.
\q1 
\v 27 Pokoljite mačem sve teoce njene,
\q2 neka siđu na zaklanje;
\q1 teško njima! Jer dođe dan njihov,
\q2 vreme pohođenja njihovog.
\b
\p 
\v 28 Čuje se glas onih koji beže i koji pobegoše iz zemlje vavilonske da jave u Sionu osvetu Gospoda Boga našeg, osvetu dvora Njegovog.
\p 
\v 29 Sazovite na Vavilon mnoštvo; svi koji natežete luk, stanite u logor prema njemu unaokolo da ne pobegne ni jedan, platite mu po delima njegovim; kako je činio, onako mu učinite, jer se je suprot Gospodu uznosio, suprot Svecu Izrailjevom.
\v 30 Zato će mladići njegovi pasti po ulicama njegovim, i svi će vojnici njegovi izginuti u onaj dan, govori Gospod.
\b
\q1 
\v 31 Evo mene na tebe, ponositi,
\q2 govori Gospod Gospod nad vojskama,
\q1 jer dođe dan tvoj,
\q2 vreme da te pohodim.
\q1 
\v 32 Ponositi će se spotaći i pasti,
\q2 i neće biti nikoga da ga podigne;
\q1 i raspaliću oganj u gradovima njegovim,
\q2 i spaliće svu okolinu njegovu.
\b
\p 
\v 33 Ovako veli Gospod nad vojskama: Sila se čini sinovima Izrailjevim i sinovima Judinim; koji ih zarobiše, drže ih, neće da ih puste.
\v 34 Izbavitelj je njihov silan, ime Mu je Gospod nad vojskama, On će doista braniti stvar njihovu da umiri zemlju i smete stanovnike vavilonske.
\b
\q1 
\v 35 Mač na Haldejce,
\q2 govori Gospod,
\q1 i na stanovnike vavilonske
\q2 i na knezove njegove i na mudrace njegove.
\q1 
\v 36 Mač na laže njegove,
\q2 i poludeće;
\q1 mač na junake njegove,
\q2 i prepašće se.
\q1 
\v 37 Mač na konje njegove,
\q2 i na kola njegova
\q1 i na svu mešavinu što je usred njega,
\q2 i postaće kao žene;
\q1 mač na blago njegovo,
\q2 i razgrabiće se.
\q1 
\v 38 Suša na vode njegove,
\q2 i usahnuće,
\q1 jer je zemlja idolska,
\q2 i oko lažnih bogova luduju.
\b
\p 
\v 39 Zato će se onde nastaniti divlje zveri i buljine, i sove će onde stanovati; i neće se naseliti do veka i neće se u njoj živeti nikada.
\v 40 Kao kad Gospod zatre Sodom i Gomor i susedstvo njihovo, govori Gospod, neće se niko onde naseliti, niti će se baviti u njoj sin čovečji.
\b
\q1 
\v 41 Evo, narod će doći sa severa, velik narod,
\q2 i carevi silni podignuće se od krajeva zemaljskih.
\q1 
\v 42 Luk i koplje nosiće,
\q2 žestoki će biti, niti će žaliti;
\q1 glas će im kao more bučati
\q2 i jahaće na konjima,
\q1 spremni kao junaci za boj,
\q2 na tebe, kćeri vavilonska.
\b
\q1 
\v 43 Car vavilonski kad čuje glas o njima,
\q2 klonuće mu ruke,
\q1 tuga će ga spopasti
\q2 i bolovi kao porodilju.
\b
\p 
\v 44 Gle, kao lav izaći će podižući se više nego Jordan na stan Silnoga; ali ću ga brzo oterati iz te zemlje, i postaviću nad njom onog ko je izabran; jer ko je kao ja? I ko će se preti sa mnom? I koji će mi pastir odoleti?
\v 45 Zato čujte nameru Gospodnju što je naumio za Vavilon, i misli Njegove što je smislio za zemlju haldejsku: zaista najmanji iz stada razvlačiće ih, zaista će opusteti stan s njima.
\v 46 Od praske kad se uzme Vavilon potrešće se zemlja, i vika će se čuti po narodima.
\c 51
\s1 Nastavak: Midi ruše Vavilon; Judejcima dopušten povratak.
\q1 
\v 1 Ovako govori Gospod:
\q1 Evo, ja ću podignuti na Vavilon
\q2 i na one koji žive usred onih koji ustaju na me,
\q2 vetar koji mori.
\q1 
\v 2 Poslaću na Vavilon vijače koji će ga razvijati
\q2 i zemlju njegovu isprazniti,
\q2 jer će ga opkoliti sa svih strana u dan nevolje njegove.
\q1 
\v 3 Strelac neka nateže luk na strelca
\q2 i na onog koji se ponosi svojim oklopom,
\q1 i ne žalite mladića njegovih,
\q2 potrite mu svu vojsku,
\q1 
\v 4 Neka padnu pobijeni u zemlji haldejskoj
\q2 i izbodeni na ulicama njegovim.
\q1 
\v 5 Jer nije ostavio Izrailja i Jude Bog njihov, Gospod nad vojskama,
\q2 ako i jeste zemlja njihova puna krivice Svecu Izrailjevom.
\b
\q1 
\v 6 Bežite iz Vavilona i izbavite svaki dušu svoju
\q2 da se ne istrebite u bezakonju njegovom,
\q1 jer je vreme osvete Gospodnje,
\q2 plaća mu šta je zaslužio.
\q1 
\v 7 Vavilon beše zlatna čaša u ruci Gospodnjoj,
\q2 kojom opoji svu zemlju;
\q1 vino njegovo piše narodi,
\q2 zato poludeše narodi.
\q1 
\v 8 Ujedanput pade Vavilon i razbi se;
\q2 ridajte za njim;
\q1 donesite balsama za rane njegove,
\q2 ne bi li se iscelio.
\q1 
\v 9 Lečismo Vavilon,
\q2 ali se ne isceli;
\q1 ostavite ga,
\q2 i da idemo svaki u svoju zemlju;
\q1 jer do neba dopire sud njegov
\q2 i diže se do oblaka.
\q1 
\v 10 Gospod je izneo pravdu našu;
\q2 hodite, da pripovedamo na Sionu delo Gospoda Boga svog.
\b
\q1 
\v 11 Čistite strele,
\q2 uzmite štitove;
\q1 Gospod podiže duh careva midskih,
\q2 jer je Vavilonu namislio da ga zatre;
\q1 jer je osveta Gospodnja,
\q2 osveta crkve Njegove.
\b
\q1 
\v 12 Na zidovima vavilonskim podignite zastavu,
\q2 utvrdite stražu,
\q1 postavite stražare,
\q2 namestite zasede;
\q1 jer je Gospod namislio,
\q2 i učiniće šta je rekao za stanovnike vavilonske.
\q1 
\v 13 O ti, što stanuješ kraj vode velike
\q2 i imaš mnogo blaga!
\q1 Dođe kraj tvoj
\q2 i svršetak lakomstvu tvom.
\q1 
\v 14 Gospod nad vojskama zakle se sobom:
\q1 Napuniću te ljudima kao skakavcima,
\q2 i oni će ti pevati pesmu.
\b
\q1 
\v 15 On je stvorio zemlju silom svojom,
\q2 utvrdio vasiljenu mudrošću svojom,
\q2 i razumom svojim razapeo nebesa.
\q1 
\v 16 Kad pusti glas svoj,
\q2 buče vode na nebesima,
\q1 podiže paru s krajeva zemaljskih,
\q2 i pušta munje s daždem,
\q2 i izvodi vetar iz staja njegovih.
\q1 
\v 17 Svaki čovek posta bezuman od znanja,
\q2 svaki se zlatar osramoti likom rezanim;
\q1 jer su laž likovi njegovi liveni
\q2 i nema duha u njima.
\q1 
\v 18 Taština su, delo prevarno;
\q2 kad ih pohodim, poginuće.
\q1 
\v 19 Nije takav deo Jakovljev;
\q2 jer je On Tvorac svemu
\q1 i On je deo nasledstva njegovog;
\q2 ime Mu je Gospod nad vojskama.
\b
\q1 
\v 20 Ti si mi bio malj,
\q2 oružje ubojno,
\q1 i tobom satrh narode
\q2 i tobom rasuh carstva.
\q1 
\v 21 I tobom satrh konja i jahača njegovog;
\q2 i tobom satrh kola i koji seđahu na njima.
\q1 
\v 22 I tobom satrh čoveka i ženu,
\q2 i satrh tobom starca i dete,
\q2 i satrh tobom momka i devojku.
\q1 
\v 23 I tobom satrh pastira i stado njegovo,
\q2 i tobom satrh orača i volove njegove ujarmljene,
\q2 i satrh tobom knezove i vlastelje.
\b
\p 
\v 24 I platiću Vavilonu i svim stanovnicima haldejskim za sve zlo koje učiniše Sionu, na vaše oči, govori Gospod.
\b
\q1 
\v 25 Evo mene na tebe,
\q2 goro, koja satireš, govori Gospod,
\q2 koja zatireš svu zemlju,
\q1 i zamahnuću rukom svojom na te
\q2 i svaliću te sa stena,
\q2 i načiniću od tebe goru izgorelu.
\q1 
\v 26 I neće uzeti od tebe kamena za ugao
\q2 ni kamena za temelj,
\q1 jer ćeš biti pustoš večna,
\q2 govori Gospod.
\b
\q1 
\v 27 Podignite zastavu u zemlji,
\q2 zatrubite u trube među narodima,
\q1 pripravite narode na nj,
\q2 sazovite na nj carstvo araratsko, minijsko i ashanasko;
\q1 postavite vojvodu suprot njemu,
\q2 dovedite konje kao skakavce bodljikaste.
\q1 
\v 28 Pripravite narode suprot njemu,
\q2 careve midske i vojvode njihove
\q1 i sve vlastelje njihove
\q2 i svu zemlju države njihove.
\q1 
\v 29 I zemlja će se zatresti i uzmučiti,
\q2 jer će se misao Gospodnja izvršiti na Vavilonu
\q1 da obrati zemlju vavilonsku u pustinju
\q2 da niko ne živi u njoj.
\q1 
\v 30 Prestaše vojevati junaci vavilonski,
\q2 stoje u gradu,
\q1 nesta sile njihove,
\q2 postaše kao žene,
\q1 izgoreše stanovi njihovi,
\q2 prevornice polomiše se.
\q1 
\v 31 Glasnik će sretati glasnika,
\q2 i poslanik će sretati poslanika
\q1 da jave caru vavilonskom
\q2 da mu je uzet grad sa svih krajeva,
\q1 
\v 32 I da se brodovi uzeše
\q2 i jezera izgoreše ognjem
\q2 i vojnici se prepali.
\q1 
\v 33 Jer ovako veli Gospod nad vojskama
\q2 Bog Izrailjev:
\q1 Kći je vavilonska kao gumno;
\q2 vreme je da se nabije, još malo,
\q2 pa će doći vreme da se požnje.
\b
\q1 
\v 34 Izjede me i potre me Navuhodonosor,
\q2 car vavilonski,
\q1 načini od mene nepotreban sud,
\q2 proždre me kao zmaj,
\q1 napuni trbuh svoj milinama mojim,
\q2 i otera me.
\q1 
\v 35 Nepravda koja se čini meni i mom telu neka dođe na Vavilon,
\q2 reći će stanovnica sionska,
\q1 i krv moja na stanovnike haldejske,
\q2 govoriće Jerusalim.
\q1 
\v 36 Zato ovako veli Gospod:
\q1 Evo, ja ću raspraviti parbu tvoju
\q2 i osvetiću te;
\q1 i osušiću more njegovo,
\q2 i izvore ću njegove osušiti.
\q1 
\v 37 I Vavilon će postati gomila,
\q2 stan zmajevski,
\q1 čudo i podsmeh,
\q2 da niko neće živeti u njemu.
\b
\q1 
\v 38 Rikaće svi kao lavovi
\q2 i viti kao lavići.
\q1 
\v 39 Kad se ugreju, izneću im da piju,
\q2 i opojiću ih da se razvesele
\q1 i zaspe večnim snom,
\q2 da se ne probude,
\q2 govori Gospod.
\q1 
\v 40 Svešću ih na zaklanje kao jaganjce,
\q2 kao ovnove s jarcima.
\b
\q1 
\v 41 Kako se predobi Sisah i uze se hvala sve zemlje?
\q2 Kako Vavilon posta čudo među narodima?
\q1 
\v 42 More usta na Vavilon,
\q2 pokri ga mnoštvo vala njegovih.
\q1 
\v 43 Gradovi njegovi postaše pustoš,
\q2 zemlja sasušena i pusta,
\q1 zemlja gde niko ne živi,
\q2 niti prolazi kroz nju sin čovečji.
\q1 
\v 44 I pohodiću Vila u Vavilonu
\q2 i izvući ću iz usta njegovih šta je proždrao,
\q1 i neće se više sticati k njemu narodi,
\q2 i zid će vavilonski pasti.
\b
\q1 
\v 45 Iziđi iz njega, narode moj,
\q2 i izbavite svaki svoju dušu od žestokog gneva Gospodnjeg.
\q1 
\v 46 Nemojte da odmekne srce vaše
\q2 i da se uplašite od glasa koji će se čuti u zemlji;
\q1 a doći će glas jedne godine,
\q2 a posle njega drugi glas druge godine,
\q1 i nasilje će biti u zemlji,
\q2 i gospodar će ustati na gospodara.
\b
\q1 
\v 47 Zato evo idu dani
\q2 kad ću pohoditi rezane likove vavilonske,
\q1 i sva će se zemlja njegova posramiti,
\q2 i svi će pobijeni njegovi pasti usred njega.
\q1 
\v 48 Nebo i zemlja i sve što je u njima pevaće nad Vavilonom,
\q2 jer će doći na nj sa severa zatirač,
\q2 govori Gospod.
\q1 
\v 49 I kao što je Vavilon učinio da padnu pobijeni Izrailjevi,
\q2 tako će pasti u Vavilonu pobijeni sve zemlje.
\b
\q1 
\v 50 Koji utekoste od mača, idite,
\q2 ne stojte;
\q1 pominjite Gospoda izdaleka,
\q2 i Jerusalim neka vam je u srcu.
\q1 
\v 51 Posramismo se,
\q2 što čusmo rug,
\q1 stid popade lice naše,
\q2 što tuđini uđoše u svetinju doma Gospodnjeg.
\b
\q1 
\v 52 Zato, gle, idu dani,
\q2 govori Gospod,
\q1 kad ću pohoditi rezane likove njegove,
\q2 i po svoj zemlji njegovoj ječaće ranjenici.
\q1 
\v 53 Da se Vavilon i na nebo popne,
\q2 i na visini da utvrdi silu svoju,
\q1 doći će od mene na nj zatirači,
\q2 govori Gospod.
\b
\q1 
\v 54 Čuje se velika vika iz Vavilona,
\q2 i velik polom iz zemlje haldejske.
\q1 
\v 55 Jer Gospod zatire Vavilon,
\q2 i ukida u njemu veliku vrevu;
\q1 i vali će njihovi bučati kao velika voda,
\q2 vika će se njihova razlegati.
\q1 
\v 56 Jer dođe na nj, na Vavilon, zatirač,
\q2 junaci se njegovi zarobiše,
\q2 lukovi se njihovi potrše;
\q1 jer je Gospod Bog koji plaća,
\q2 doista će platiti.
\q1 
\v 57 Opojiću knezove njegove i mudrace njegove,
\q2 vojvode njegove i vlastelje njegove
\q2 i junake njegove,
\q1 da će zaspati večnim snom
\q2 i neće se probuditi,
\q1 govori car,
\q2 kome je ime Gospod nad vojskama.
\b
\q1 
\v 58 Ovako veli Gospod nad vojskama:
\q1 Široki zidovi vavilonski sasvim će se raskopati,
\q2 i visoka vrata njegova ognjem će se spaliti,
\q1 te su ljudi uzalud radili,
\q2 i narodi se trudili za oganj.
\b
\p 
\v 59 Reč što zapovedi prorok Jeremija Seraji sinu Nirije sina Masijinog, kad pođe od Sedekije, cara Judinog, u Vavilon četvrte godine carovanja njegovog; a Seraja beše glavni posteljnik.
\v 60 A Jeremija napisa u jednu knjigu sve zlo koje htede doći na Vavilon, sve ove reči što su napisane za Vavilon.
\v 61 I reče Jeremija Seraji: Kad dođeš u Vavilon, tada gledaj i pročitaj sve ove reči;
\v 62 i reci: Gospode, Ti si govorio za ovo mesto da ćeš ga zatrti da niko ne živi u njemu, ni čovek ni živinče, nego da je pustoš do veka.
\v 63 A kad pročitaš ovu knjigu, veži kamen za nju, i baci je u Efrat.
\v 64 I reci: Tako će potonuti Vavilon i neće se podignuti oda zla koje ću pustiti na nj, i oni će iznemoći.
\p Dovde su reči Jeremijine.
\c 52
\s1 Kratka istorija razorenja Jerusalima; pomilovanje cara Joahina.
\p 
\v 1 Dvadeset i jedna godina beše Sedekiji kad poče carovati, i carova jedanaest godina u Jerusalimu. Materi mu beše ime Amutala, kći Jeremijina, iz Livne.
\v 2 On činjaše što je zlo pred Gospodom sasvim kako je činio Joakim.
\v 3 Jer od gneva Gospodnjeg zbi se Jerusalimu i Judi, te ih odbaci ispred sebe.
\p A Sedekija se odmetnu od cara vavilonskog.
\v 4 I tako, devete godine njegova carovanja, desetog dana dođe Navuhodonosor car vavilonski sa svom vojskom svojom na Jerusalim; i stadoše u logor pod njim, i načiniše opkope oko njega.
\v 5 I grad bi opkoljen do jedanaeste godine carovanja Sedekijinog.
\v 6 I devetog dana, četvrtog meseca, nasta velika glad u gradu, te narod zemaljski nemaše hleba.
\v 7 Tada grad bi provaljen, i vojnici svi pobegoše i iziđoše iz grada noću na vrata između dva zida uz vrt carev, a Haldejci behu svuda oko grada; i otidoše putem k pustinji.
\v 8 Ali vojska haldejska potera cara, i stigoše Sedekiju u polju jerihonskom, a sva vojska što beše s njim razbeže se od njega.
\v 9 I uhvatiše cara i odvedoše ga k caru vavilonskom u Rivlu u zemlji ematskoj; i onde mu sudi.
\v 10 I pokla car vavilonski sinove Sedekijine na njegove oči, i sve knezove Judine pokla u Rivli.
\v 11 I Sedekiji iskopa oči, i svezav ga u dvoje verige bronzane odvede ga car vavilonski u Vavilon i metnu ga u tamnicu gde osta do smrti svoje.
\b
\p 
\v 12 A desetog dana petog meseca godine devetnaeste carovanja Navuhodonosora cara vavilonskog dođe u Jerusalim Nevuzardan, zapovednik stražarski, koji služaše caru vavilonskom.
\v 13 I popali dom Gospodnji i dom carski i sve domove u Jerusalimu; sve velike kuće popali ognjem.
\v 14 I sve zidove jerusalimske u naokolo razvali sva vojska haldejska što beše sa zapovednikom stražarskim.
\v 15 A narod siromašni i ostatak naroda što osta u gradu, i prebege što prebegoše k caru vavilonskom, i ostali prosti narod, odvede Nevuzardan, zapovednik stražarski.
\v 16 Samo od siromašnog naroda u zemlji ostavi Nevuzardan zapovednik stražarski koji će biti vinogradari i ratari.
\p 
\v 17 I stupove bronzane što behu u domu Gospodnjem, i podnožja i more bronzano koje beše u domu Gospodnjem, izlomiše Haldejci, i bronzu od njih odnesoše u Vavilon.
\v 18 I lonce i lopate i viljuške i kotliće i kadionice i sve sve sudove bronzane kojima služahu, uzeše.
\v 19 I umivaonice i klešta s kotlićima i loncima i svećnjacima i kadionicama i čašama, šta god beše zlatno i šta god beše srebrno, uze zapovednik stražarski.
\v 20 Dva stupa, jedno more, i dvanaest volova bronzanih što behu pod podnožjima, što načini car Solomun za dom Gospodnji, ne beše mere bronzi od svih tih sudova.
\v 21 A stupovi behu svaki od osamnaest lakata u visinu, a u naokolo od dvanaest lakata, a četiri prsta beše svaki debeo i šupalj;
\v 22 i ozgo na njemu beše oglavlje bronzano, i oglavlje beše visoko pet lakata, i pletenica i šipci oko oglavlja, sve od bronze; takav beše i drugi stup sa šipcima.
\v 23 I beše devedeset i šest šipaka sa svake strane; svega šipaka na pletenici u naokolo beše sto.
\b
\p 
\v 24 Uze zapovednik stražarski i Seraju, prvog sveštenika, i Sofoniju, drugog sveštenika, i tri vratara.
\v 25 A iz grada uze jednog dvoranina, koji beše nad vojnicima, i sedam ljudi koji stajahu pred carem, koji se nađoše u gradu, i prvog pisara vojničkog, koji popisivaše narod po zemlji u vojsku, i šezdeset ljudi iz naroda zemaljskog, koji se nađoše u gradu.
\v 26 Uze ih Nevuzardan zapovednik stražarski i odvede k caru vavilonskom u Rivlu.
\v 27 A car ih vavilonski pobi i pogubi u Rivli u zemlji ematskoj. Tako bi preseljen Juda iz zemlje svoje.
\p 
\v 28 Ovo je narod što ga preseli Navuhodonosor: sedme godine tri hiljade i dvadeset i tri Judejca;
\v 29 godine osamnaeste Navuhodonosorove preseli iz Jerusalima osam stotina i trideset i dve duše;
\v 30 godine dvadeset treće Navuhodonosorove preseli Nevuzardan zapovednik stražarski Judejaca sedam stotina i četrdeset i pet duša; svega četiri hiljade i šest stotina duša.
\b
\p 
\v 31 A trideset sedme godine od kako se zarobi Joahin car Judin, dvanaestog meseca, dvadeset petog dana, Evil-Merodah car vavilonski iste godine zacarivši se izvadi iz tamnice Joahina, cara Judinog.
\v 32 I lepo govori s njim, i namesti mu presto više prestola drugih careva koji behu kod njega u Vavilonu.
\v 33 I promeni mu haljine tamničke, i on jeđaše svagda s njim svega veka svog.
\v 34 I hrana mu se jednako davaše od cara vavilonskog, svaki dan, svega veka njegovog do smrti njegove. 
