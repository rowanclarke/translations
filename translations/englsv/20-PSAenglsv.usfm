\v 9 \w You|strong="H7489"\w* rule \w them|strong="H1270"\w* \w with|strong="H3627"\w* \w a|strong="H3068"\w* \w scepter|strong="H7626"\w* \w of|strong="H7626"\w* \w iron|strong="H1270"\w*, || \w You|strong="H7489"\w* crush \w them|strong="H1270"\w* \w as|strong="H1270"\w* \w a|strong="H3068"\w* \w vessel|strong="H3627"\w* \w of|strong="H7626"\w* \w a|strong="H3068"\w* \w potter|strong="H3335"\w*.”
\v 10 \w And|strong="H4428"\w* \w now|strong="H6258"\w*, \w O|strong="H3068"\w* \w kings|strong="H4428"\w*, \w act|strong="H7919"\w* \w wisely|strong="H7919"\w*, || \w Be|strong="H4428"\w* \w instructed|strong="H3256"\w*, \w O|strong="H3068"\w* \w judges|strong="H8199"\w* \w of|strong="H4428"\w* earth,
\v 11 \w Serve|strong="H5647"\w* \w YHWH|strong="H3068"\w* \w with|strong="H3068"\w* \w fear|strong="H3374"\w*, || \w And|strong="H3068"\w* \w rejoice|strong="H1523"\w* \w with|strong="H3068"\w* \w trembling|strong="H7461"\w*.
\v 12 \w Kiss|strong="H5401"\w* \w the|strong="H3605"\w* Chosen \w One|strong="H3605"\w* \bd [[\bd*\it or\it* \w Son|strong="H1248"\w*\bd ]]\bd*, \w lest|strong="H6435"\w* \w He|strong="H3588"\w* \w is|strong="H1870"\w* angry, || \w And|strong="H1870"\w* \w you|strong="H3588"\w* perish [\w from|strong="H1197"\w*] \w the|strong="H3605"\w* \w way|strong="H1870"\w*, || \w When|strong="H3588"\w* \w His|strong="H3605"\w* anger \w burns|strong="H1197"\w* \w but|strong="H3588"\w* \w a|strong="H3068"\w* \w little|strong="H4592"\w*, || \w O|strong="H3068"\w* \w the|strong="H3605"\w* blessedness \w of|strong="H1870"\w* \w all|strong="H3605"\w* trusting \w in|strong="H1870"\w* \w Him|strong="H3605"\w*!
\c 3
\p 
\v 1 \w A|strong="H3068"\w* \w PSALM|strong="H4210"\w* \w OF|strong="H1121"\w* \w DAVID|strong="H1732"\w*, \w IN|strong="H6440"\w* \w HIS|strong="H1732"\w* \w FLEEING|strong="H1272"\w* \w FROM|strong="H6440"\w* \w THE|strong="H6440"\w* \w FACE|strong="H6440"\w* \w OF|strong="H1121"\w* \w HIS|strong="H1732"\w* \w SON|strong="H1121"\w* ABSALOM. \w YHWH|strong="H3068"\w*, how \w my|strong="H1732"\w* distresses \w have|strong="H1121"\w* multiplied! Many \w are|strong="H1121"\w* rising \w up|strong="H1121"\w* \w against|strong="H6440"\w* \w me|strong="H6440"\w*.
\v 2 \w Many|strong="H7227"\w* \w are|strong="H4100"\w* saying \w of|strong="H3068"\w* \w my|strong="H3068"\w* soul, “\w There|strong="H3068"\w* \w is|strong="H3068"\w* \w no|strong="H6965"\w* salvation \w for|strong="H5921"\w* \w him|strong="H5921"\w* \w in|strong="H5921"\w* \w God|strong="H3068"\w*.” Selah.
\v 3 \w And|strong="H5315"\w* \w You|strong="H5315"\w*, \w O|strong="H3068"\w* \w YHWH|strong="H3068"\w*, [\w are|strong="H7227"\w*] \w a|strong="H3068"\w* shield \w for|strong="H5315"\w* \w me|strong="H5315"\w*, || \w My|strong="H5315"\w* glory, \w and|strong="H5315"\w* lifter up \w of|strong="H5315"\w* \w my|strong="H5315"\w* head.
\v 4 \w My|strong="H3068"\w* voice [\w is|strong="H3068"\w*] \w to|strong="H3068"\w* \w YHWH|strong="H3068"\w*: \w I|strong="H3068"\w* call \w and|strong="H3068"\w* \w He|strong="H3068"\w* answers \w me|strong="H1157"\w* \w from|strong="H3068"\w* \w His|strong="H3068"\w* holy hill, Selah.
\v 5 \w I|strong="H3068"\w* \w have|strong="H3068"\w* lain \w down|strong="H7121"\w*, \w and|strong="H3068"\w* \w I|strong="H3068"\w* sleep, || \w I|strong="H3068"\w* \w have|strong="H3068"\w* awoken, \w for|strong="H7121"\w* \w YHWH|strong="H3068"\w* sustains \w me|strong="H6963"\w*.
\v 6 \w I|strong="H3588"\w* \w am|strong="H3068"\w* \w not|strong="H3588"\w* afraid \w of|strong="H3068"\w* myriads \w of|strong="H3068"\w* people, || \w That|strong="H3588"\w* \w they|strong="H3588"\w* \w have|strong="H3068"\w* \w set|strong="H5564"\w* \w against|strong="H3068"\w* \w me|strong="H3588"\w* \w all|strong="H7901"\w* around.
\v 7 Rise, \w O|strong="H3068"\w* \w YHWH|strong="H3068"\w*! Save \w me|strong="H5921"\w*, \w my|strong="H5921"\w* \w God|strong="H3808"\w*! \w For|strong="H5921"\w* \w You|strong="H5921"\w* \w have|strong="H5971"\w* struck \w all|strong="H5439"\w* \w my|strong="H5921"\w* enemies [\w on|strong="H5921"\w*] \w the|strong="H5921"\w* cheek. \w You|strong="H5921"\w* \w have|strong="H5971"\w* broken \w the|strong="H5921"\w* teeth \w of|strong="H5971"\w* \w the|strong="H5921"\w* wicked.
\v 8 \w This|strong="H3588"\w* \w salvation|strong="H3467"\w* [\w is|strong="H3068"\w*] \w of|strong="H3068"\w* \w YHWH|strong="H3068"\w*; \w Your|strong="H3068"\w* blessing [\w is|strong="H3068"\w*] \w on|strong="H3068"\w* \w Your|strong="H3068"\w* \w people|strong="H7563"\w*! Selah.
\c 4
\p 
\v 1 \w TO|strong="H1732"\w* \w THE|strong="H1732"\w* OVERSEER. \w WITH|strong="H1732"\w* \w STRINGED|strong="H5058"\w* \w INSTRUMENTS|strong="H5058"\w*. \w A|strong="H3068"\w* \w PSALM|strong="H4210"\w* \w OF|strong="H4210"\w* \w DAVID|strong="H1732"\w*. \w In|strong="H1732"\w* \w my|strong="H1732"\w* calling answer me, || \w O|strong="H3068"\w* God \w of|strong="H4210"\w* \w my|strong="H1732"\w* righteousness. \w In|strong="H1732"\w* adversity You gave enlargement \w to|strong="H1732"\w* me; Favor me, \w and|strong="H1732"\w* hear \w my|strong="H1732"\w* prayer.
\v 2 Sons \w of|strong="H8085"\w* \w men|strong="H7121"\w*! Until \w when|strong="H8085"\w* [\w is|strong="H6664"\w*] \w my|strong="H8085"\w* glory \w for|strong="H7121"\w* shame? \w You|strong="H7121"\w* love \w a|strong="H3068"\w* vain thing, \w you|strong="H7121"\w* seek \w a|strong="H3068"\w* lie. Selah.
\v 3 \w And|strong="H1121"\w* know \w that|strong="H1121"\w* \w YHWH|strong="H3068"\w* || \w Has|strong="H4100"\w* separated \w a|strong="H3068"\w* saintly \w one|strong="H1121"\w* \w to|strong="H5704"\w* \w Himself|strong="H1245"\w*. \w YHWH|strong="H3068"\w* hears \w in|strong="H1121"\w* \w my|strong="H1245"\w* calling \w to|strong="H5704"\w* \w Him|strong="H1245"\w*.
\v 4 “Tremble, \w and|strong="H3068"\w* \w do|strong="H3068"\w* \w not|strong="H3045"\w* sin”; Say [\w thus|strong="H8085"\w*] \w in|strong="H3068"\w* \w your|strong="H3068"\w* \w heart|strong="H8085"\w* \w on|strong="H3068"\w* \w your|strong="H3068"\w* bed, || \w And|strong="H3068"\w* \w be|strong="H3068"\w* silent. Selah.
\v 5 Sacrifice sacrifices \w of|strong="H5921"\w* righteousness, || \w And|strong="H3824"\w* trust \w in|strong="H5921"\w* \w YHWH|strong="H3068"\w*.
\v 6 Many \w are|strong="H3068"\w* saying, “\w Who|strong="H3068"\w* shows us good?” \w Lift|strong="H3068"\w* \w on|strong="H3068"\w* us \w the|strong="H3068"\w* light \w of|strong="H3068"\w* \w Your|strong="H3068"\w* face, \w O|strong="H3068"\w* \w YHWH|strong="H3068"\w*,
\v 7 \w You|strong="H6440"\w* \w have|strong="H3068"\w* \w given|strong="H5375"\w* \w joy|strong="H5921"\w* \w in|strong="H5921"\w* \w my|strong="H3068"\w* heart, || \w From|strong="H6440"\w* \w the|strong="H6440"\w* \w time|strong="H7227"\w* \w their|strong="H3068"\w* grain \w and|strong="H3068"\w* \w their|strong="H3068"\w* wine || \w Have|strong="H3068"\w* \w been|strong="H5375"\w* multiplied.
\v 8 Together \w I|strong="H5414"\w* \w lie|strong="H5414"\w* \w down|strong="H5414"\w* \w and|strong="H1715"\w* sleep \w in|strong="H5414"\w* peace, || \w For|strong="H6256"\w* \w You|strong="H5414"\w*, \w O|strong="H3068"\w* \w YHWH|strong="H3068"\w*, alone, || \w Cause|strong="H5414"\w* \w me|strong="H5414"\w* \w to|strong="H6256"\w* dwell \w in|strong="H5414"\w* confidence!
\c 5
\p 
\v 1 \w TO|strong="H1732"\w* \w THE|strong="H1732"\w* OVERSEER. [BLOWN] INTO \w THE|strong="H1732"\w* PIPES. \w A|strong="H3068"\w* \w PSALM|strong="H4210"\w* \w OF|strong="H4210"\w* \w DAVID|strong="H1732"\w*. Hear \w my|strong="H1732"\w* sayings, \w O|strong="H3068"\w* \w YHWH|strong="H3068"\w*, || Consider \w my|strong="H1732"\w* meditation.
\v 2 \w Be|strong="H3068"\w* attentive \w to|strong="H3068"\w* \w the|strong="H3068"\w* voice \w of|strong="H3068"\w* \w my|strong="H3068"\w* cry, || \w My|strong="H3068"\w* King \w and|strong="H3068"\w* \w my|strong="H3068"\w* \w God|strong="H3068"\w*, || \w For|strong="H3068"\w* \w I|strong="H3068"\w* pray \w to|strong="H3068"\w* You habitually.
\v 3 \w YHWH|strong="H3068"\w*, [\w in|strong="H4428"\w*] \w the|strong="H3588"\w* morning \w You|strong="H3588"\w* \w hear|strong="H7181"\w* \w my|strong="H3588"\w* \w voice|strong="H6963"\w*, || [\w In|strong="H4428"\w*] \w the|strong="H3588"\w* morning \w I|strong="H3588"\w* set \w in|strong="H4428"\w* array \w for|strong="H3588"\w* \w You|strong="H3588"\w*, || \w And|strong="H4428"\w* \w I|strong="H3588"\w* look out [expectantly].
\v 4 \w For|strong="H3068"\w* \w You|strong="H6963"\w* [\w are|strong="H3068"\w*] \w not|strong="H8085"\w* \w a|strong="H3068"\w* \w God|strong="H3068"\w* desiring wickedness, || Evil \w does|strong="H3068"\w* \w not|strong="H8085"\w* inhabit \w You|strong="H6963"\w*.
\v 5 \w The|strong="H3588"\w* boastful \w do|strong="H7562"\w* \w not|strong="H3808"\w* station \w themselves|strong="H1481"\w* \w before|strong="H3808"\w* \w Your|strong="H3588"\w* eyes: \w You|strong="H3588"\w* \w have|strong="H3588"\w* hated all working \w iniquity|strong="H7562"\w*.
\v 6 \w You|strong="H3605"\w* \w destroy|strong="H3605"\w* \w those|strong="H3605"\w* speaking lies, || \w YHWH|strong="H3068"\w* \w detests|strong="H8130"\w* \w a|strong="H3068"\w* \w man|strong="H3605"\w* \w of|strong="H5869"\w* blood \w and|strong="H5869"\w* deceit.
\v 7 \w And|strong="H3068"\w* \w I|strong="H3068"\w*, \w in|strong="H3068"\w* \w the|strong="H3068"\w* abundance \w of|strong="H3068"\w* \w Your|strong="H3068"\w* kindness, || \w I|strong="H3068"\w* enter \w Your|strong="H3068"\w* house, || \w I|strong="H3068"\w* bow myself \w toward|strong="H3068"\w* \w Your|strong="H3068"\w* holy temple \w in|strong="H3068"\w* \w Your|strong="H3068"\w* fear.
\v 8 \w O|strong="H3068"\w* \w YHWH|strong="H3068"\w*, lead \w me|strong="H1004"\w* \w in|strong="H1004"\w* \w Your|strong="H1004"\w* \w righteousness|strong="H2617"\w*, || \w Because|strong="H7230"\w* \w of|strong="H1004"\w* those observing \w me|strong="H1004"\w*, || Make \w Your|strong="H1004"\w* way straight before \w me|strong="H1004"\w*,
