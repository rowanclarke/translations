\v 20 \w Esto|strong="H2063"\w* \w haremos|strong="H6213"\w* \w con|strong="H5921"\w* \w ellos|strong="H5921"\w* \w para|strong="H5921"\w* dejarlos \w vivir|strong="H2421"\w*, \w y|strong="H5921"\w* \w así|strong="H2063"\w* \w la|strong="H5921"\w* \w ira|strong="H7110"\w* \w no|strong="H3808"\w* caerá \w sobre|strong="H5921"\w* \w nosotros|strong="H5921"\w* \w a|strong="H3068"\w* causa \w del|strong="H5921"\w* \w juramento|strong="H7621"\w* \w que|strong="H3808"\w* \w les|strong="H5921"\w* \w hicimos|strong="H6213"\w*.  
\v 21 \w Los|strong="H3605"\w* jefes \w dijeron|strong="H1696"\w* con respecto \w a|strong="H3068"\w* \w ellos|strong="H3605"\w*: Déjenlos \w vivir|strong="H2421"\w*. \w Y|strong="H3068"\w* \w fueron|strong="H1961"\w* \w leñadores|strong="H2404"\w* y aguadores \w para|strong="H1961"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* congregación, según \w los|strong="H3605"\w* jefes les prometieron.   
