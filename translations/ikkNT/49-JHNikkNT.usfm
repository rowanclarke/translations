\id JHN Ika New Testament 2009
\h Jọnụ
\toc1 Oziọma Jizọs' Kraịstị Nọkẹ Kẹ Jọnụ Dọn De Ẹ
\toc2 Jọnụ
\toc3 Jọn
\mt2 Oziọma Jizọs' Kraịstị Nọkẹ Kẹ
\mt1 Jọnụ
\mt2 Dọn De Ẹ
\c 1
\cl Isi Nke Mbụ
\s1 Jesu Wụ Oku Osolobuẹ
\p 
\v 1 Ogẹn mbidọn, oku hụ rị arị; Oku hụ lẹ Osolobuẹ rị; Oku hụ wụ Osolobuẹ.
\v 2 Oku ahụn lẹ Osolobuẹ rị ogẹn mbidọn.
\v 3 Osolobuẹ ke ihiẹn ile rịnị ghahan'a; o nwọnni ihiẹn Osolobuẹ ke hụn o kelẹni ghahan'a.
\v 4 Imẹ ẹ kẹ ndụn rị; ndụn hụ wụ ukpẹ ịhịan ile.
\v 5 Ukpẹ hụ e nwun imẹ ishi, kanị ishi, mkpọkịkị, a s'ẹka tinyụn a mọbụ ghọha a.
\p 
\v 6 O nwọn okẹnnyẹ ohu Osolobuẹ zihẹ; ẹfan a wụ Jọnụ.
\v 7 Ọ bịa d'a shịa ẹri banyeni ukpẹ hụ, kẹni ịhịan ile nụ ẹri ẹ, kweri.
\v 8 Ẹlẹ 'ya wụ ukpẹ hụ, kalẹ ọ bịa d'a shịa ẹri banyeni ukpẹ hụ.
\v 9 Onyẹ hụ wụ Ezigbo Ukpẹ hụ hụn e ye ịhịan ile ukpẹ lala imẹ ụwa ogẹn ahụn.
\p 
\v 10 Osolobuẹ ke ụwa ghahan'a, kanị ụwa amarịnn'a ogẹn o gi bịa.
\v 11 Ọ bịa d'e kunrun ndị nke ẹ, kanị ndị nke ẹ anabanhann'a.
\v 12 Kanị, ndị ile hụn nabanhan n'a, ndị ile hụn kwerini n'ẹ, o ye wẹ ikẹn ni wẹ wụrụ ụmụ Osolobuẹ:
\v 13 ẹlẹ ịhịan mụ wẹ; egini wẹ uche ịhịan mụ wẹ, o nwọnni okẹnnyẹ ọwụlẹ han wẹ mụ wẹ, kama, Osolobuẹ mụ wẹ.
\p 
\v 14 Oku hụ nọ hẹnrin ịhịan, ọ nọ sọn ẹnyi biri elu-ụwa. Ẹfọma lẹ ezioku jun imẹ ẹ! Ẹnyi a hụnọlẹ ọghọ a, ọghọ akpụ Nwa ohu Chuku-Nẹdi mụ.
\p 
\v 15 Jọnụ ku banyen'ẹ, yi oro sị, “Ọnwan wụ onyẹ hụn m rị e ku ogẹn m gi sị, ‘Onyẹ hụn lalanị m mẹmẹgụụ ka m, makẹlẹ ọ rị a rị nị wẹ d'a mụ m.’ ”
\p 
\v 16 Makẹ ihiẹn ahụn jun imẹ ẹ, ẹnyi hụ e nwẹhẹn ngọzi mmagi-mmagi.
\v 17 Wẹ ye Iwu ghahanị Mozizi; kanị ẹfọma lẹ ezioku ghaha ẹka Jesu Kristi.
\v 18 O nwọnni onyẹ hụntu Osolobuẹ, kanị akpụ Nwa ohu ọ mụ sụọ, hụn wụ Osolobuẹ, hụn nọkunmẹ n'ẹ, e mẹgụọ ẹnyi marịn a.
\s1 Ọshẹri Jọnụ Hụn E Mẹ Mirin-Chuku Shịa
\r (Mat 3.1-12; Mak 1.1-8; Luk 3.1-18)
\p 
\v 19 Ọnwan wụ ẹri Jọnụ shịa ogẹn ndị-ndu ndị Ju gi gha Jerusalẹm zihẹ ndị nchụ-ẹjan lẹ ndị Livaị d'a jụ a, sị, “Onyẹ k'ị wụ?”
\v 20 Jọnụ a ghọrịnị; mba, o kupụ a, sị, “Ẹlẹ m Kraịstị Onyẹ Nzụọpụha hụ Osolobuẹ Tumẹ.” Ọ ghọrịnị.
\p 
\v 21 Wẹ nọzị jụ a, sị, “Onyẹ k'ị wụ? Ịyụ wụ Ẹlaịja?”
\p Ọ nọ sị, “Mba.”
\p “Ịyụ wụ Onyẹ-amụma hụ \it pụ-ichẹn\it*?”
\p Ọ sị, “Mba.”
\p 
\v 22 Wẹ nọ sị a, “Onyẹ k'ị wụ nwan? Gwa ẹnyi kẹni ẹnyi marịn ihiẹn ẹnyi sikọ d'a gwa ndị zihẹ ni ẹnyi. K'i jẹnkọ d'e ku banyeni enwẹn i?”
\p 
\v 23 Ọ nọ gi ihiẹn onyẹ-amụma wụ Azaya ku za wẹ, sị,
\q1 “Mmẹ wụ
\q2 ‘Olu hụ rị e yi oro imẹ atụ,
\q1 a sị,
\q2 “Kwa nị ụzọ Di-nwọnni-ẹnyi n'o zinrin!” ’ ”
\p 
\v 24 Ndị Itu ndị Farisi hụn rị imẹ ndị hụ wẹ zi
\v 25 nọ jụ a, sị, “Kị haịn nwan i gi e mẹ mirin-Chuku mbụnị y'ẹlẹ Mezaya mọbụ Ẹlaịja mọbụ Onyẹ-amụma hụ pụ-ichẹn?”
\p 
\v 26 Jọnụ nọ za wẹ, sị, “M gi mirin mmaka e mẹ mirin-Chuku, kanị o nwọn onyẹ rị imẹ ụnụ hụn ụnụ marịnlẹni.
\v 27 Ịya wụ onyẹ hụ lalanị m mẹmẹgụụ. Erudẹni m onyẹ sikọ d'a tọpụ akpụkpọ-ụkụ a.”
\p 
\v 28 Ọnwan mẹ imẹ Bẹtanị, nfetu Jọdanị, ebe Jọnụ nọ e mẹ mirin-Chuku.
\s1 Nwa-ebulu Osolobuẹ
\p 
\v 29 Eki e fọn, ọ nọ hụn Jizọsị k'ọ lala ebe ọ rị, Jọnụ nọ sị, “Lee n'ẹ! Ọnwan wụ Nwa-ebulu Osolobuẹ hụn e wepụ njọ ụwa!
\v 30 'Ya wụ onyẹ m rị e ku ogẹn m gi sị, ‘Omẹgụụ, okẹnnyẹ ohu kanị m lala; ịya ka m makẹni ọ rị a-rị nị wẹ d'a mụ m.
\v 31 E te marịn m'a, kanị m rị e gi mirin e mẹ mirin-Chuku kẹni ndị Izrẹlụ marịn a.’ ”
\v 32 Jọnụ nọ shịa ẹri, sị, “M hụn Mmọn-nsọ k'o gi ụdị nduru gha elu-igwee hidanla, nọkwasị a.
\v 33 E te marịn m'a, kanị onyẹ hụn zi ni m sị m, ‘Onyẹ i jẹnkọ d'a hụn kẹ Mmọn-nsọ hidan d'a nọkwasị a d'e sọn ẹ nọdị, ịya wụ onyẹ hụ jẹnkọ d'e gi Mmọn-nsọ mẹ ịhịan mirin-Chuku.’
\v 34 A hụnọlẹ m'a; e kuọlẹ m nị ịya wụ Onyẹ Hụ Osolobuẹ Tumẹ.”
\s1 Ụmụ-azụụn Ibuzọ Jesu Kpọ
\p 
\v 35 Eki e fọn, Jọnụ nị ụmụ-azụụn a ẹbụọ wuzo,
\v 36 'ya Jọnụ nọ hụn Jesu k'ọ ghafekọ, ọ nọ sị, “Lẹhụ Nwa-ebulu Osolobuẹ!”
\v 37 Ụmụ-azụụn Jọnụ ẹbụọ ahụn a nụ k'o ku ihiẹnni, wẹ nọ sọnmẹ Jesu.
\v 38 Ogẹn Jesu gi gbehutọ, ọ hụn wẹ kẹ wẹ rị e sọn ẹ, ọ nọ sị wẹ, “K'ị ụnụ rị a chọ?” Wẹ nọ za, sị, “Rabaị, elebe k'i bi?” (“Rabaị” wụ “onyẹ-nkuzi.”)
\p 
\v 39 Ọ nọ sị wẹ, “Bịa nị d'e lee ẹ.” Wẹ nọ jẹn d'a hụn ebe o bi; ihiẹn rịkẹ ọkụlọkụ ẹnọ efinnaị rị a kụ ogẹn hụ; wẹ nọ du ẹ nọdịchanrịn ụhụọhịn hụ.
\p 
\v 40 Onyẹ ohu imẹ ụmụ-azụụn ẹbụọnị nụ ihiẹn Jọnụ ku sọnmẹ Jesu wụ Andụrụ nwẹnẹ Saịmọnụ Pita.
\v 41 Ọ nọ bu ụzọ chọjẹn nwẹnẹ ẹ wụ Saịmọnụ, sị a, “Ẹnyi a hụnọlẹ Onyẹ Hụ Osolobuẹ Tumẹ wụ Kraịstị.”
\v 42 Andụrụ nọ weri Pita d'e kunrun Jizọsị. Jizọs' e lee Pita, ọ nọ sị a, “'Yụ wụ Saịmọnụ nwa Jọnụ. Ẹfan ị jẹnkọ d'a wụ Kẹfasị.” (Anị ẹfannị asụsụ Griki wụ Pita, 'ya wụ “ọmụma.”)
\p 
\v 43 Eki e fọn, Jesu chọ n'o jẹn Galili; ọ hụn Filipu, ọ nọ sị a, “Sọnmẹ m.”
\v 44 (Filipu wụ onyẹ Bẹsaịda, obodo Andụrụ lẹ Pita.)
\v 45 Filipu a hụn Natanẹlụ, ọ nọ sị a, “Ẹnyi a hụnọlẹ onyẹ hụ Mozizi de banyen'ẹ imẹ Iwu, hụn ndị-amụma dezikwọ banyen'ẹ—Jesu onyẹ Nazarẹtị nwa Josẹfụ rọ.”
\p 
\v 46 Natanẹlụ nọ sị a, “Nị ihiẹn ọwụlẹ rị mma s'ẹka gha Nazarẹtị pụha?” Filipu nọ sị a, “Bịa d'e lee.”
\v 47 Ogẹn Jizọsị gi hụn Natanẹlụ k'ọ lala ebe ọ rị, ọ nọ sị, “Ọnwan wụchanrịn onyẹ Izrẹlụ hụn nwọnlẹni ẹro!”
\p 
\v 48 Natanẹlụ nọ jụ a, sị, “Nanị k'i dọn marịn m?”
\p Jizọsị nọ za, sị, “A hụngụọ m'ị okpuru osisi figi hụ nị Filipu d'a kpọ ị!”
\p 
\v 49 Natanẹlụ nọ sị, “Onyẹ-nkuzi, eziẹ ịyụ wụ Nwa Osolobuẹ; ịyụ wụ Eze ndị Izrẹlụ!”
\p 
\v 50 Jizọsị nọ sị a, “Y'e kweriọlẹ makẹni m gwa ị hụ nị m hụn ị okpuru osisi figi?! Ị jẹnkọ d'a hụn ihiẹn ndị ka ọnwan!”
\v 51 Ọ nọ sị wẹ, “M rị a gwa ụnụ ezioku, ụnụ sikọ d'a hụn kẹ elu-igwee kpupụ, hụn kẹ ndị mmọn-ozi Osolobuẹ rị e jẹnjẹn, e jẹnlụa d'e kunrun Nwa nke Ịhịan.”
\c 2
\cl Isi Nke Ẹbụọ
\s1 Jesu E Gi Mirin Hẹnrin Manya
\p 
\v 1 Hụn mẹ ẹ akpụ-ụhụọhịn ẹtọ, o nwọn agbamẹhụhụọ rị obodo Kana rị Galili. Nnẹ Jizọsị rị ebahụn.
\v 2 Wẹ kpọzịkwọ Jizọsị lẹ ụmụ-azụụn a agbamẹkụkwọ hụ.
\v 3 Ogẹn manya gi gụụ, nnẹ Jesu nọ sị Jesu, “Manya wẹ a gụụ.”
\v 4 Jizọsị nọ sị a, “Okpoho, hatu m ye nụ, ogẹn m e ke ru.”
\v 5 Nnẹ ẹ nọ sị ndị rị e jẹn ozi, “Ihiẹn ọwụlẹ ọ sị ụnụ mẹ, ụnụ e mẹ.”
\p 
\v 6 O nwọn ite-mirin isin wẹ gi ọmụma mẹmẹ rị ebahụn. Ohu-ohu imẹ wẹ jẹnkọ d'e ripụ ogbogoro mirin isẹn mọbụ ẹsa. W'e gi wẹ e dọnmẹ mirin wẹ gi a chanchan ihiẹn, hụn wẹ gi e mẹzu omẹnalị ndị Ju. \fig Ite mirin|src="lb00135b.jpg" size="col" loc="JHN 2" copy="Horace Knowles; The British & Foreign Bible Society" ref="2.6-7"\fig*
\p 
\v 7 Jesu nọ sị idibo ndị hụ, “Gbajun ni ite ndị hụ mirin.” 'Ya wẹ nọ gbajun wẹ d'a pụ ọnụ.
\v 8 Ọ nọ sị wẹ, “Kuru ni nwan ẹkẹrẹ jẹnni onyẹ-isi ocho.” 'Ya wẹ nọ mẹ ihiẹn o ku.
\p 
\v 9 Onyẹ-isi ocho nọ danmịn mirin hụ hẹnringụụ manya, bụ ọ marịn ebe ọ gha bịa, (kanị, ndị hụ rị e jẹn ozi a marịnghọ), ọ nọ kpọ okẹnnyẹ hụ rị a gba-ẹkụkwọ,
\v 10 sị a, “Ndị ọzọ ile e bu ụzọ e wepụha manya ka a sụọ, ịhịan ile rajungụụ ẹfọ wẹ kebe wepụha hụn sụọlẹni; kalẹ y'e bu hụnnị sụọnị tọ d'e ru ogẹnni.”
\p 
\v 11 Imẹ Kana rị Galili kẹ Jesu nọ rụn ọrụn-atụmẹnya ibuzọnị hụn o gi ghọsị ọghọ a, ụmụ-azụụn a nọ kweri n'ẹ.
\v 12 Omẹgụụ, Jesu nọ si Kapanọm—'ya lẹ nnẹ ẹ lẹ umunẹ ẹ lẹ ụmụ-azụụn a, wẹ nọ nọdị ebẹhụ ẹkẹrẹ.
\s1 Jesu E Jẹn Ụlọ-nsọ
\r (Mat 21.12-13; Mak 11.15-17; Luk 19.45-46)
\p 
\v 13 Ogẹn ndị Ju gi e mẹ Mmẹmmẹ-Nghafe e rumẹ, 'ya Jesu nọ si Jerusalẹm.
\v 14 Ọ nọ hụn ndị rị Ụlọ-nsọ ebẹhụ e re efin lẹ atụnrụn lẹ oluikuku lẹzi ndị a gbahutọ ego ebe wẹ nọdịyesọnmẹ ni teburu wẹ.
\v 15 Ọ nọ kpa iberi (aya), gi ẹ chụpụ wẹ ile lẹ okẹn-efin wẹ lẹ nduru wẹ imẹ Ụlọ-nsọ, bụọyịya egho ndị a gbahutọ egho, hukpumẹsọnmẹ teburu wẹ. \fig Ọ nọ kpa iberi…gi ẹ chụpụ wẹ…imẹ Ụlọ-nsọ|src="lb00316c.jpg" size="col" loc="JHN 2" copy="Horace Knowles; The British & Foreign Bible Society" ref="2.15"\fig*
\v 16 Ọ nọ sị ndị rị e re nduru, “Wepụ nị ihiẹn ndịnị wẹ ebeni; egizilẹni ụlọ Nẹdi m hẹnrin ebe wẹ nọ a zụ afịa!”
\v 17 Ụmụ-azụụn a nọ nyanhan ni wẹ de ẹ imẹ Ẹkụkwọ-nsọ nị, “Adụdụ ụlọ ị jẹnkọ d'e bu m ri.”
\p 
\v 18 Ya ndị-ndu ndị Ju nọ nwan sị a, “Ghọsị ẹnyi ahịma ẹnyi e gi marịn nị Osolobuẹ sị ị mẹ ihiẹnni.”
\p 
\v 19 Jizọsị nọ za wẹ sị, “Tikpọ nị Ụlọ-nsọnị, e gi m akpụ-ụhụọhịn ẹtọ wesi e elu.”
\p 
\v 20 Ndị-ndu ndị Ju nọ sị a, “Ụlọ-nsọnị wẹ gi ahụa isin-kwasị-ọgụnnaị tụn k'i jẹnkọ d'e gi akpụ-ụhụọhịn ẹtọ wesi elu?”
\v 21 Kanị Ụlọ-nsọ Jesu rị e ku oku ẹ wụ ẹhụ a.
\v 22 Ogẹn o gi ghagụụ ọnwụn lihi, ụmụ-azụụn a nọ nyanhan n'o kuọghọ ihiẹnni, wẹ nọ gi ihiẹn Ẹhụhụọ-nsọ ku lẹ ihiẹn Jesu ku dọn.
\s1 Jesu Marịn Kẹ Ịhịan Nọ
\p 
\v 23 Ogẹn Jesu gi rị imẹ Jerusalẹm ogẹn Mmẹmmẹ-Nghafe, ndị bu ọda nọ kweri n'ẹ makẹni wẹ hụn ọrụn-atụmẹnya ndị ọ rị a rụn.
\v 24 Kanị Jizọsị ebuni enwẹn ẹ ye wẹ, makẹni ọ marịngụọ kẹ ịhịan ile nọ.
\v 25 Ẹlẹ hụn onyẹ ọwụlẹ e gi gwa a kẹ ịhịan nọ, makẹni 'ya lẹ enwẹn ẹ a marịngụọ ihiẹn rị imẹ ịhịan.
\c 3
\cl Isi Nke Ẹtọ
\s1 Nikodimọsị A Bịa D'a Hụn Jizọsị
\p 
\v 1 O nwọn okẹnnyẹ ohu w'a kpọ Nikodimọsị. Onyẹ Itu Ndị Farisi rọ, onyẹ ohu imẹ ndị-isi ndị Ju k'ọ wụ.
\v 2 O gi imẹ uhinhin bịa d'e kunrun Jizọsị, sị a, “Onyẹ-nkuzi, ẹnyi a marịngụọ n'ị wụ onyẹ-nkuzi gha ebe Osolobuẹ rị bịa, makẹlẹ o nwọnni onyẹ jẹnkọ d'e ri-ẹka rụn ọrụn-atụmẹnya ndịnị ị rị a rụn mmanị Osolobuẹ nọyen'ẹ.”
\p 
\v 3 Jesu nọ za, sị, “Ezioku kẹ m rị a gwa ị, mmanị wẹ mụdọnzi ịhịan, ọ saẹka hụn Alị-eze Osolobuẹ.”
\v 4 Nikodimọsị nọ sị a, “Nanị kẹ w'a dọn mụdọnzi ịhịan ebe ọ kagụụ ẹgẹdi? Nị ịhịan sazị ẹka banye ẹfọ nnẹ ẹ, a mụzị w'a nke mgbe ẹbụọ?”
\v 5 Jizọsị nọ za a, sị, “Ezioku kẹ m rị a gwa ị, mmanị wẹ mụ ịhịan ghahanị mirin lẹ Mmọn-nsọ, ọ sakọ ẹka banye Alị-eze Osolobuẹ.
\v 6 Hụn ịhịan mụ wụ ịhịan; hụn Mmọn-nsọ mụ wụ mmọn.
\v 7 Y'a tụlẹ i ẹnya nị m sị nị wẹ sikọ d'a mụdọnzirịrị ụnụ.”
\v 8 Ufere e fesi ebe ọwụlẹ ọ chọ—ụnụ a nụ ụzụn a, kanị ụnụ ara marịn ebe ọ gha a bịa mọbụ ebe o fekọ—ẹrịra k'ọ rị ebe onyẹ ọwụlẹ Mmọn Osolobuẹ mụ rị.
\p 
\v 9 Nikodimọsị nọ sị a, “Nanị kẹ ọnwan e dọn saẹka mẹ?”
\p 
\v 10 Jizọsị nọ sị a, “Ị wụ onyẹ-nkuzi imẹ Izrẹlụ, bụ y'a ghọtanị ihiẹn ndịnị?
\v 11 Ezioku kẹ m rị a gwa ụnụ, ẹnyi rị e ku ihiẹn ẹnyi marịn, a shịa ẹri ihiẹn ẹnyi hụn, kanị ụnụ ara nabanhan ẹri ẹnyi.
\v 12 Ebe o mẹ nwan nị m gwa ụnụ ihiẹn ndị rị elu-ụwa bụ ụnụ e kwerini, nanị kẹ ụnụ a dọn kweri omẹni a gwa m ụnụ ihiẹn ndị rị elu-igwee?
\v 13 Makẹni, o nwọnni onyẹ jẹntu elu-igwee wezụka onyẹ hụ gha elu-igwee bịa—wụ Nwa nke Ịhịan.”
\p 
\v 14 “Ẹrịra Mozizi dọn wesi agwọ hụ elu imẹ atụ kẹ wẹ jẹnkọ d'e wesi Nwa nke Ịhịan elu,
\v 15 kẹni onyẹ ọwụlẹ hụn kwerini n'ẹ hụn ụzọ nwọn ndụn itẹbitẹ.”
\p 
\v 16 “Makẹni Osolobuẹ nwẹ ihiẹn-ọsụsụọ jẹnni ndị rị ụwa ọda-ọda, 'ya haịn o gi ye akpụ Nwa ohu o nwẹ, kẹn'ọ wụrụ nị onyẹ ọwụlẹ hụn kwerini n'ẹ alakọ iwi, kama o nwọn ndụn itẹbitẹ.
\v 17 Eziẹ, Osolobuẹ ezini Nwa a d'a ma ndị rị ụwa ikpe, kama, o zi ẹ kẹni wẹ hụn ụzọ nwọn nzụọpụha ghahan'a.
\v 18 Ikpe amanị onyẹ ọwụlẹ kwerini n'ẹ, kanị ikpe a magụọ onyẹ ọwụlẹ hụn kwerilẹni, makẹni o kwerini imẹ ẹfan akpụ Nwa ohu Osolobuẹ.
\v 19 Ọnwan kẹ wẹ gi hangbu wẹ eṅẹn: nị ukpẹ a bịagụọ imẹ ụwa, kalẹ ishi ka ịhịan a sụọ karị ukpẹ, makẹni eje ihiẹn kẹ w'e mẹ.
\v 20 Ize ukpẹ e ze ndị ile e mẹ eje-ihiẹn, w'a ra bịa ebe ukpẹ rị makẹ eje-ihiẹn wẹ rị e mẹ gha a pụha ifọn.”
\p 
\v 21 “Kanị ndị hụn e mẹ ihiẹn rị mma a bịa ebe ukpẹ rị, kẹni ịhịan ile hụn a nị wẹ rị e mẹ ihiẹn Osolobuẹ chọ.”
\s1 Jizọsị Lẹ Jọnụ Hụn E mẹ Mirin-Chuku
\p 
\v 22 Omẹgụụ, Jizọsị lẹ ụmụ-azụụn a nọ si Azụụn Judia, ọ nọ du wẹ nọdị ebẹhụ, e mẹ ndị ịhịan mirin-Chuku.
\v 23 Jọnụ nkẹ rịzị obodo Enọm hụn nọkunmẹ Salim e mẹ mirin-Chuku makẹni mirin rị ebahụn ọda-ọda. Ịhịan hụ e jẹn d'e kunrun ẹ, ọ hụ e mẹ wẹ mirin-Chuku.
\v 24 W'e ke bu Jọnụ che imẹ ụlọ-ngan ogẹn hụ.
\p 
\v 25 Ogẹn hụ, ụmụ-azụụn Jọnụ lẹ onyẹ Ju nọ dọma oku ịchan-ẹhụ w'a chansọnmẹ hụn wụ ọdịnalị ofufe wẹ gi e dọn enwẹn wẹ nsọ.
\v 26 Wẹ nọ bịa d'e kunrun Jọnụ, sị a, “Onyẹ-nkuzi, onyẹ hụ yụ lẹ 'ya rịtan nfetu Jọdanị, onyẹ hụn ị gwasọnmẹ ndị ịhịan oku ẹ, lee ẹ nwan k'ọ rị ebeni e mẹ mirin-Chuku, ịhịan ile hụ e jẹn d'e kunrun ẹ.”
\p 
\v 27 Jọnụ nọ za, sị, “O nwọnni onyẹ hụn e nwẹhẹn ihiẹn ọwụlẹ mmanị wẹ gha elu-igwee y'ẹ ihiẹn hụ.
\v 28 Ụnụ lẹ enwẹn ụnụ wụ ọshẹri m nị e kughọ m'a nị ‘Ẹlẹ m Kristi, kanị wẹ zi m buru n'ẹ ụzọ.’
\v 29 Okpoho hụn wẹ rị a lụ wụ nke okẹnnyẹ hụn rị a lụ n'a. Ọwụ okẹnnyẹ hụ rị a gba ẹkụkwọ, hụn wuzoye n'ẹ e gọn ẹ ntịn, a ghọghọ ọda-ọda ọ nụ olu okẹnnyẹ hụn rị a gba ẹkụkwọ. Ya wụ nị ịghọghọ m e zuọlẹ nwan oke.
\v 30 Ọ k'a rịwaye mkpa, kanị mmẹ nwẹn k'e belụa.
\p 
\v 31 Onyẹ hụn gha elu bịa ka ịhịan ile; onyẹ hụn gha ụwa bịa wụ nke ụwa, o ku oku ihiẹn rị imẹ ụwa. Hụn gha elu-igwee bịa ka ịhịan ile.
\v 32 Ọ hụ a shịa ẹri ihiẹn ọ hụn lẹ ihiẹn ọ nụ, kanị o nwọnni onyẹ e gi ẹri ẹ e dọn.
\v 33 Onyẹ ọwụlẹ gi oku ẹ dọn a ghọsịọlẹ nị Osolobuẹ wụ onyẹ-ezioku.
\v 34 Makẹni onyẹ Osolobuẹ zihẹ k'ọ wụ, oku Osolobuẹ k'ọ rị e ku, makẹni Osolobuẹ e yehọdụ n'a Mmọn-nsọ.
\v 35 Ihiẹn Nwa a a sụọ Chuku-Nẹdi, ọ wegụọ ihiẹn ile che ẹ ẹka.
\v 36 Onyẹ hụn kweri ni Nwa Osolobuẹ nwọn ndụn itẹbitẹ; onyẹ hụn jụ n'o kwerikọnị Nwa Osolobuẹ ahụnkọ ndụn; mba, iwe-lẹ-ọnụma kẹ Osolobuẹ k'e gi sọnsọnmẹ ẹ.”
\c 4
\cl Isi Nke Ẹnọ
\s1 Jizọsị Lẹ Okpoho Onyẹ Samerịa
\p 
\v 1 Ogẹn ahụn, Jesu nọ nwan marịn nị itu-ndị Farisi a nụgụọ nị ụmụ-azụụn ndị Jesu rị e nwẹhẹn e mẹ mirin-Chuku kadẹ nke Jọnụ.
\v 2 (Kanị, ẹlẹ Jesu rị e mẹ wẹ mirin-Chuku, ụmụ-azụụn a sụọ rị e mẹ.)
\v 3 Ya Jesu nọ gha Judia pụ, kinkọ Galili.
\v 4 Ọ nọ ghasi alị Samerịa makẹlẹ ọ rị mkpa n'o k'a gharịrị ebẹhụ.
\v 5 'Ya ọ nọ pụha obodo ohu w'a kpọ Sika, hụn rị imẹ Samerịa, ẹhụ alị hụ Jekọpụ ye nwa a wụ Josẹfụ.
\v 6 Ọmị Jekọpụ rị ebẹhụ; ndụn gụụ Jesu makẹ ijẹn o jẹn; otudẹni, ọ nọ nọdị alị ẹhụ ọmị hụ. (Ihiẹn rịkẹ ọkụlọkụ mmẹbụọ efinnaị rọ, ogẹn hụ anwụn gi a rị isi.)
\p 
\v 7 'Ya kẹ okpoho ohu, onyẹ alị Samerịa, nọ bịa d'a dọrị mirin. Jesu nọ sị a, “Ye m mirin ra.”
\v 8 (Ogẹn hụ, ụmụ-azụụn a e jẹnmẹgụọ imẹ obodo d'e ṅọnhẹn ihiẹn-oriri.)
\v 9 Okpoho onyẹ Samerịa hụ nọ sị a, “Nanị kẹ ịyụ wụ onyẹ Ju dọn nwan a rịọ mmẹ wụ okpoho onyẹ Samerịa mirin?” (O ku ọnwan makẹni ndị-Ju lẹ ndị-Samerịa ara mẹkọ.)
\v 10 Jizọsị nọ za a, sị, “Omẹni i te marịn ihiẹn Osolobuẹ e ye lẹ onyẹ hụn rị a sị ị, ‘Ye m mirin ra’, nkẹ y'a rịọ a, o ye i mirin hụn e ye ndụn.”
\v 11 Okpoho hụ nọ sị a, “Di-ọkpa, ọmịnị mi emi bụ y'e gi mkpu y'e gi dọ mirin. Elebe kẹ y'a nọ nwan nwẹhẹn mirin hụ e ye ndụn?
\v 12 'Yụ ka Jekọpụ nẹdi ẹnyi kanị hụn ye ẹnyi ọmịnị, hụn 'ya lẹ ụmụ a lẹ ihiẹn-uriri ẹ ra mirin rịn'a?”
\v 13 Jesu nọ sị a, “Onyẹ ọwụlẹ hụn ra mirinni, ẹgụn mirin jẹnkọ d'a gụnzị a.
\v 14 Kanị, onyẹ ọwụlẹ hụn ra mirin hụ m jẹnkọ d'e ye ẹ, ẹgụn mirin agụnkọzị a; kama, mirin hụ m sikọ d'e ye ẹ jẹnkọ d'e hẹnrin n'ẹ isi-mirin hụn rị imẹ ẹ e hupụha ndụn itẹbitẹ.”
\p 
\v 15 Okpoho hụ nọ sị a, “Di-ọkpa, ye m nwan mirin hụ amamgbe ẹgụn-mirin gha a gụnzị m mọbụ a bịamazị m ebeni d'a dọ mirin.”
\v 16 Jizọsị nọ sị a, “Jẹn d'a kpọ di i, y'e kinhẹn azụụn.”
\v 17 Okpoho hụ nọ sị a, “Enwọn m di.” Jesu nọ sị a, “Ezioku kẹ i ku ebe ị nọ sị, ‘Enwọn m di’,
\v 18 makẹni y'a lụpụgụọ di isẹn, bụ okẹnnyẹ hụn ịyụ lẹ 'ya rị nwan ẹlẹ di i; ezioku k'i ku!”
\p 
\v 19 Okpoho hụ nọ sị a, “Di-ọkpa, a hụnọlẹ m'a nị ị wụ onyẹ-amụma.
\v 20 Ndị-nẹdi ẹnyi wẹ kanị nọ uguni fe ofufe, bụ ụnụ ndị Ju sị nị Jerusalẹm wụ ebe furu ịhịan jẹnkọ d'a nọrịrị e fe ofufe.”
\v 21 Jesu nọ sị a, “Okpoho, gi ihiẹn m rị e ku dọn: ogẹn lala, hụn o gi mẹ ni ẹlẹzi enu uguni mọbụ imẹ Jerusalẹm kẹ ụnụ sikọ d'a nọ fe Chuku-Nẹdi.
\v 22 Ụnụ amarịn onyẹ ụnụ rị e fe; kanị, ẹnyi a marịnghọ onyẹ ẹnyi rị e fe, makẹni ẹka ndị Ju kẹ nzụọpụha gha a bịa.
\v 23 Kanị ogẹn lala, o rugụọdẹ nwan, hụn ndị hụn e fe ezigbo ofufe k'e fe Chuku-Nẹdi ofufe imẹ-mmọn lẹ nkẹ ezioku. Makẹni ndị hụn e fe ofufe nọ ẹrịra kẹ Chuku-Nẹdi chọ nị w'e fe ẹ ofufe.
\v 24 Osolobuẹ wụ Mmọn, ẹlẹ ịhịan; ndị hụn k'e fe ẹ ofufe sikọ d'e ferịrị a imẹ-mmọn, gi ezioku fee ẹ.”
\v 25 Okpoho hụ nọ sị a, “A marịngụọ m nị Onyẹ Hụ Osolobuẹ Tumẹ wụ Mezaya, (hụn w'a kpọ Kraịstị), lala; ọ bịa, ọ gwachanrịn ẹnyi ihiẹn ile.”
\v 26 Jesu nọ sị a, “Mmẹ hụn rị a gwa ị oku rọ.”
\p 
\v 27 Ozigbo hụra, ụmụ-azụụn a nọ lụa. Ọ nọ tụ wẹ ẹnya ọda-ọda n'ọ rị e sọn okpoho e ku oku; kanị o nwọnni onyẹ sị, “K'ị chọ”, mọbụ “Kị haịn i gi rị e sọn ẹ e ku oku.”
\v 28 Ya okpoho hụ nọ la ite mirin ẹ tọ, kin-azụụn si imẹ obodo; ọ nọ sị ndị rịn'a,
\v 29 “Bịa nị d'e lee onyẹ hụn gwa m ihiẹn ile m mẹ. Onyẹ ma kẹ 'ya wụ Onyẹ Hụ Osolobuẹ Tumẹ wụ Kraịstị?”
\v 30 Wẹ nọ gha imẹ obodo pụha, ruhẹmẹ ebe Jesu rị.
\p 
\v 31 Ogẹn hụ, ụmụ-azụụn hụ a rịọ Jesu, a sị, “Onyẹ-nkuzi, dodo ri ihiẹn-oriri.”
\v 32 Kanị ọ nọ sị wẹ, “M nwọn ihiẹn-oriri m'e ri hụn ụnụ marịnlẹni.”
\v 33 'Ya ụmụ-azụụn a nọ jụma ibe wẹ, sị, “O nwọndẹ nwan onyẹ wẹhẹ n'ẹ ihiẹn-oriri ra?”
\v 34 Jizọsị nọ sị wẹ, “Ihiẹn-oriri m wụ imẹ uche onyẹ zini m lẹ ịrụnchanrịn ọrụn a.
\v 35 Ẹlẹ ụnụ a sị, ‘Ọ họdụ ifọn ẹnọ nị ogẹn wẹ gi a ghọ ihiẹn-ugbo ru?’ Kanị m rị a gwa ụnụ, lehunmẹ ni ẹnya ebe ụnụ rị nị ụnụ hụn nị ihiẹn-ugbo a kagụọlẹ hụn w'a ghọ.
\v 36 Onyẹ hụn a ghọnị rị nwan a ghọ, a narịn ụgwọ-ọrụn a; ọ hụ e kpọnkikomẹ mkpụrụ a tọnị ndụn itẹbitẹ, kẹni onyẹ hụn kụnn'a lẹ onyẹ hụn ghọn'a hụn ụzọ nwọngbamẹ ịghọghọ.
\v 37 O mẹgụọ nwan kẹ wẹ dọn e ku,
\q1 ‘Onyẹ ọzọ a kụn,
\q2 onyẹ ọzọ a ghọ.’ ”
\p 
\v 38 “M zi ụnụ d'a ghọ ihiẹn ụnụ rụnlẹni; ndị ọzọ a rụngụọlẹ ọrụn, ụnụ a banhangụọ d'a ghọ mkpụrụ wẹ rụnpụha.”
\s1 Ndị Samerịa A Bịa D'e Kunrun Jesu
\p 
\v 39 Ndị Samerịa bu ọda wụ ndị obodo hụ nọ kwerini Jesu makẹni okpoho hụ sị, “Ọ gwa m ihiẹn ile m mẹ!”
\v 40 Ogẹn ndị Samerịa gi nwan bịa d'e kunrun Jesu, wẹ nọ rịọ a n'o sọn wẹ nọdị. 'Ya ọ nọ sọn wẹ nọdị akp'ọhịn ẹbụọ.
\v 41 Ndị bu ọda nọ gi ufiri ihiẹn ndị ọ rị e ku kwerizi, cheni ndị ibuzọ.
\v 42 Wẹ nọ sị okpoho hụ, “Ẹlẹzi ihiẹn i ku sụọ kẹ ẹnyi gi kweri, makẹlẹ ẹnyi lẹ enwẹn ẹnyi a nụọlẹ ọnụ a, marịn nị ezioku-ezioku, ọnwan wụ Onyẹ-nzụọpụha ụwa.”
\s1 Jizọsị A Zụọ Nwa Onyẹ-isi-ọrụn Eze
\p 
\v 43 Ogẹn akpụ-ụhụọhịn ẹbụọ gi ghafegụụ, Jesu nọ gha Samerịa si Galili.
\v 44 (Jizọsị lẹ enwẹn ẹ e kugụọ a nị w'a ra ye onyẹ-amụma mgbaye imẹ alị onyẹ-amụma ahụn.)
\v 45 Ogẹn o gi ru Galili, ndị Galili nọ nabanhan a, makẹni a hụngụọ wẹ ihiẹn ile o mẹ imẹ Jerusalẹm ogẹn Mmẹmmẹ-Nghafe (makẹni wẹ nwẹn e jẹnghọzị mmẹmmẹ hụ).
\p 
\v 46 Ọ nọ bịazị obodo Kana hụn rị imẹ Galili ebe ọ nọ gi mirin hẹnrin manya.
\p O nwẹ okẹnnyẹ ohu emu rị a kụ nwa-a-okẹnnyẹ imẹ Kapanọm. Okẹnnyẹni wụ onyẹ ohu imẹ ndị-isi-ọrụn eze.
\v 47 Ogẹn okẹnnyẹ hụ gi nụ nị Jizọsị a ghagụọ Judia kinhẹn Galili, ọ nọ buru ẹ, rịọ a 'ya bịa d'a zụọ nwa a makẹni o d'a nwụn.
\v 48 'Ya Jesu nọ sị a, “Manị ụnụ hụn ahịma lẹ ihiẹn atụmẹnya, ụnụ ekwerikọ.”
\v 49 Onyẹ-isi ọrụn hụ nọ sị a, “Di-ọkpa bịa ndọ-o, nwa m gini d'a nwụn.”
\v 50 Jizọsị nọ sị a, “Lama, nwa ị jẹnkọ d'a rị ndụn.” Okẹnnyẹ hụ nọ kweri oku Jizọsị gwa a, ọ nọ lama.
\v 51 Ebe ọ lakọ, ndị idibo ẹ nọ kunrun ẹ; wẹ nọ gwa a nị nwa a hụ a rịgụọ mma.
\v 52 Ọ nọ jụ wẹ kẹ ẹlẹ ogẹn k'o gi rịma mma. Wẹ nọ sị a, “Ọkụlọkụ ohu efinnaị ụnyanhụn kẹ ẹhụ-ọkụn hụ gi hapụ a.”
\v 53 Nẹdi ẹ nọ nyanhan nị ogẹn hụ kẹ Jizọsị gi sị a, “Nwa ị jẹnkọ d'a rị ndụn.” Ifiri ẹ, kẹ ya lẹ enwẹn ẹ kẹ ikpun-ụlọ a nọ kwerini Jesu.
\v 54 Ọnwan wụ ọrụn-atụmẹnya nke ẹbụọ Jesu rụn ogẹn o gi ghagụụ Judia bịa Galili.
\c 5
\cl Isi Nke Isẹn
\s1 Jesu A Zụọ Onyẹ Nwọnlẹni Onyẹ E Yen'ẹ Ẹka
\p 
\v 1 Omẹgụụ, Jesu nọ kin-azụụn si Jerusalẹm makẹni o nwọn mmẹmmẹ ndị Ju rịnị.
\p 
\v 2 Imẹ Jerusalẹm, ọ nwọn mirin rị ẹhụ Ọnụ-mgbọn Atụnrụn, hụn ndị Hibru a kpọ mirin Bẹtẹs'da [mọbụ mirin Bẹ'zata], hụn nwọn ụzọ isẹn wẹ kpumẹsọnmẹ elu wẹ hụn wẹ gha e ru ẹ.
\v 3 Igunrun ndị-emu rị a kụ e dinẹsọnmẹ ụzọ ndị hụ: kẹ ndị ẹnya-ishi, kẹ ndị ngụrọ, kẹ ndị oro kinmin, [e che ni wẹ mẹhunmẹ mirin hụ.
\v 4 Makẹni, o ru, mmọn-ozi Di-nwọnni-ẹnyi e hidan d'e mẹhunmẹ mirin hụ. Onyẹ ọwụlẹ imẹ ndị emu rị a kụ, hụn bu ụzọ banye imẹ mirin hụ ogẹn wẹ gi mẹhunmẹgụụ a, ọ dịnhịn emu ọwụlẹ rị a kụn'a.]
\p 
\v 5 Onyẹ ohu imẹ ndịnị dinẹ ebahụn rị a kụ emu kete ahụa ẹbụọ-arịa-ọgụnnaị.
\v 6 Ogẹn Jizọsị gi hụn a, marịn n'o tegụọ emu hụ kụma a, ọ nọ sị a, “Y'a chọghọ n'ị dịnhịn?”
\v 7 Okẹnnyẹ hụ emu rị a kụ nọ za, sị, “Di-ọkpa, enwọn m onyẹ e bu m e che imẹ mirinni ogẹn ọwụlẹ wẹ gi mẹhunmẹ ẹ; m chọ nị m banye imẹ ẹ, onyẹ ọzọ e bu m ụzọ banye.”
\p 
\v 8 Jizọsị nọ sị a, “Lihi ọtọ! Heri ute i, jẹnmẹ ijẹn!”
\v 9 Ozigbo, okẹnnyẹ ahụn nọ dịnhịn; ọ nọ buru ute ẹ, jẹnmẹ ijẹn.
\p Ụhụọhịn ahụn wụ ụhụọhịn izu-ikẹn.
\v 10 'Ya ndị-ndu ndị Ju nọ sị okẹnnyẹ hụ Jizọsị zụọ, “Ọnwan wụ Ụhụọhịn Izu-ikẹn, o furuni nị y'e bu ute i, ị rị a dan Iwu.”
\v 11 Ọ nọ za wẹ, sị, “Onyẹ hụn zụọ nị m sị m, ‘Heri ute i, jẹnmẹ ijẹn.’ ”
\v 12 Wẹ nọ jụ a, sị, “Onyẹ wụ onyẹ hụ sị ị, ‘Heri ute i jẹnmẹ ijẹn?’ ”
\v 13 Kanị okẹnnyẹ hụ wẹ zụọ amarịn onyẹ ọ wụ, makẹni Jizọsị a rụbangụọ imẹ igunrun rị ebahụn.
\p 
\v 14 Omẹgụụ, Jizọsị nọ hụn a imẹ Ụlọ-nsọ, ọ nọ sị a, “Lee ẹnya, y'a rịgụọ nwan mma! Emẹzilẹ njọ, amamgbe ihiẹn ka njọ gha e mẹ i.”
\v 15 'Ya okẹnnyẹ hụ nọ jẹnburu ndị-ndu ndị Ju d'a gwa wẹ nị Jesu wụ onyẹ hụ zụọ n'a.
\v 16 'Ya kẹ ndị-ndu ndị Ju nọ kpokpomẹ Jesu makẹni ọ rị e mẹ ihiẹn ndị nọ ẹnịna Ụhụọhịn Izu-ikẹn.
\v 17 Kanị Jizọsị nọ sị wẹ, “Echẹn kẹ Nẹdi m rịkwọ a rụn ọrụn, mmẹ nwẹn sikọ d'a gha a rụnzịkwọ ọrụn.”
\v 18 Ifiri ihiẹnni o ku, ndị-ndu ndị Ju nọ chọkẹnmẹdẹ nị wẹ gbu ẹ. Makẹlẹ, ẹlẹ n'ọ dan iwu Izu-ikẹn sụọ, kanị, ọ kpọzịkwọ Osolobuẹ Nẹdi ẹ—gi ọhụn ku nị 'ya lẹ Osolobuẹ han.
\s1 Ikẹn Jesu
\p 
\v 19 Jizọsị nọ sị wẹ, “Ezioku kẹ m rị a gwa ụnụ, Nwa a saẹka gi uche ẹ mẹ ihiẹn ọwụlẹ—mmanị ihiẹn ọ hụn Chuku-Nẹdi rị e mẹ; makẹni ihiẹn ọwụlẹ Chuku-Nẹdi mẹ, 'ya kẹ Nwa a e mẹzikwọ.
\v 20 Makẹni ihiẹn Nwa a a sụọ Chuku-Nẹdi, ọ ghọsị Nwa a ihiẹn 'ya lẹ enwẹn ẹ rị a rụn. O jẹnkọ d'e ye ẹ ikẹn gi rụn ọrụn kadẹ ndịnị wẹ rụn kẹni ọ tụ ụnụ ẹnya.
\v 21 Eziẹ, ẹrịra Chuku-Nẹdi dọn e weli ndị nwụnnị we ndụn ye wẹ kẹ Nwa a dọnzịkwọ e we ndụn e ye ndị Nwa a chọ n'o ye.
\v 22 Ọzọzị, Chuku-Nẹdi ara kin onyẹ ọwụlẹ ikpe, kama, o bugụọ okinkin-ikpe ile che Nwa a ẹka,
\v 23 kẹni ịhịan ile gbaye Nwa kẹ wẹ dọn a gbaye Chuku-Nẹdi. Onyẹ hụn ghalẹni a gbaye Nwa arịzịkwọnị a gbaye Chuku-Nẹdi hụn zihẹ n'ẹ.”
\p 
\v 24 “Ezioku kẹ m rị a gwa ụnụ, onyẹ hụn nụ oku m, kweye ni onyẹ zihẹni m, onyẹ ahụn e nwẹgụọ ndụn itẹbitẹ. Amakọ wẹ onyẹ hụ ikpe; kama, onyẹ hụ a ghagụọ ọnwụn banye ndụn.
\p 
\v 25 Ezioku kẹ m rị a gwa ụnụ, ogẹn lala—o rụgụọdẹ nwan—hụn ndị nwụnnị sikọ d'e gi nụ olu Nwa Osolobuẹ; ndị nụn'a jẹnkọ d'a rị ndụn.
\v 26 Kẹ Chuku-Nẹdi dọn nwọn ndụn imẹ enwẹn ẹ, ẹrịra k'o yeziwọ Nwa \it ikẹn\it* n'o nwọn ndụn imẹ enwẹn ẹ.
\v 27 O yegụọ Nwa a ikẹn n'o kin ịhịan ile ikpe—makẹni ịya wụ Nwa nke Ịhịan.
\v 28 Anịlẹ ni ọnwan tụ ụnụ ẹnya, makẹni ogẹn lala hụn ndị ile rị imẹ ili jẹnkọ d'e gi nụ olu ẹ
\v 29 pụha—ndị hụn mẹ mma jẹnkọ d'e lihi banye ndụn itẹbitẹ; ndị hụn mẹ njọ sikọ d'e lihi narịn ikpe-ọmụma.”
\s1 Ndị Hụn A Shịanị Jesu Ẹri
\p 
\v 30 “Asa m ẹka gi ikẹn m mẹ ihiẹn ọwụlẹ. M'a han eṅẹn kẹ Osolobuẹ dọn gwa m—'ya wụ nị ezigbo eṅẹn kẹ m'a han, makẹni arị m e mẹ uche m, kalẹ uche onyẹ hụn zihẹ ni m.
\v 31 M shịanị enwẹn m ẹri, 'ya wụ nị ẹri m wụ ntụ.
\p 
\v 32 M nwọn onyẹ ọzọ hụn a shịa nị m ẹri. A marịnghọ m nị ẹri ọ shịa nị m wụ ezioku.
\v 33 Ụnụ e zigụọ wẹ jẹnni Jọnụ, ọ shịagụọ ẹri wụ ezioku.
\v 34 (Ẹlẹ ni ẹri ịhịan shịa rị m mkpa, kanị m rị e ku ihiẹnni kẹni ụnụ hụn ụzọ nwọn nzụọpụha.)
\v 35 Jọnụ e te nwunghọ kẹ ukpẹ—a dụn, e ti, ụnụ nọ gi ukpẹ ẹ ghọghọ ẹkẹrẹ ogẹn.”
\p 
\v 36 “Kanị m nwọn ihiẹn a shịa nị m ẹri hụn ka hụn Jọnụ shịa. Ọrụn ndị hụn Nẹdi m ye m rụn, 'ya wụ ọrụn ndịnị m rị a rụn, uwẹ nwẹ a shịanị m ẹri nị Chuku-Nẹdi zihẹ m.”
\p 
\v 37 “Chuku-Nẹdi lẹ enwẹn ẹ hụn zihẹni m a shịagụọnị m ẹri. Ụnụ anụtuni olu ẹ; ụnụ ahụntuni k'ọ nọ;
\v 38 oku ẹ arị imẹ ndụn ụnụ, makẹni ụnụ ekwerini ni onyẹ hụn o zihẹ.
\p 
\v 39 Ụnụ a mụ ihiẹn ndị rị imẹ Ẹkụkwọ-nsọ a mụkẹnmẹ, makẹni ụnụ ro ni uwẹ kẹ ụnụ e gi nwọn ndụn-itẹbitẹ; bụ Ẹhụhụọ-nsọ rị a shịanị m ẹri,
\v 40 kanị ụnụ ekwerini bịa d'e kunrun m kẹni ụnụ nwọn ndụn.
\v 41 Ẹlẹ m chọkọ ọjịja-mma ịhịan;
\v 42 kanị a marịnghọ m ndị ụnụ wụ, nị ihiẹn Osolobuẹ a ra sụọ ụnụ.
\v 43 M gi ẹfan Nẹdi m bịa, ụnụ a nabanhannị m, kanị onyẹ ọzọ gi ẹfan nke ẹ bịa, ụnụ sikọ d'a nabanhan a.
\v 44 Nanị kẹ ụnụ e dọn kweri? Ụnụ hụn a chọ nị ibe ụnụ ja ụnụ mma, kanị o nwọnni ihiẹn ụnụ kpọ ịja-mma hụn gha ẹka onyẹ hụ 'ya sụọ wụ Osolobuẹ bịa.
\v 45 Erokwọlẹ ni nị m jẹnkọ d'e kpe ụnụ ẹka Chuku-Nẹdi; Mozizi wụ hụn e kpeni ụnụ, Mozizi ahụn ụnụ gi dọn ẹnya.
\v 46 Omẹni ụnụ gi oku Mozizi dọn, nkẹ ụnụ e gi oku m dọn, makẹni Mozizi de banyeni m.
\v 47 Kanị omẹni ụnụ egini ihiẹn Mozizi de dọn, nanị kẹ ụnụ e dọn gi oku m dọn?”
\c 6
\cl Isi Nke Isin
\s1 Jesu E Ye Mmadụ Ọgụn-iri kwasị nnụ-mmẹbụọ Ihiẹn-oriri
\r (Mat 14.13-21; Mak 6.30-44; Luk 9.10-17)
\p 
\v 1 Ọnwan e mẹgụụ, Jizọsị nọ fetu “Ohimin” Galili hụ shi azụụn hụn-ẹbọ. W'a kpọzị “Ohimin” Galili ohimin Taịberiasị.
\v 2 Igunrun hi-ogbe hụ e sọn ẹ, makẹni wẹ hụn ọrụn-atụmẹnya ndị ọ rị a rụnnị ndị emu rị a kụ.
\v 3 Jizọsị nọ si elu ugu, 'ya lẹ ụmụ-azụụn a nọ nọdị alị ebẹhụ.
\v 4 (Ogẹn hụ, mmẹmmẹ ndị Ju e mẹ ahụa-ahụa w'a kpọ Mmẹmmẹ-Nghafe e rumẹgụọ.)
\v 5 Jizọsị e wesi ẹnya elu, ọ nọ hụn igunrun ịhịan kẹ wẹ lala d'e kunrun ẹ. Ọ nọ sị Filipu, “Elebe kẹ ẹnyi a nọ ṅọn brẹdi kẹni ndịnị ri?”
\v 6 (O ku ihiẹnni n'o gi chọ ihiẹn rị Filipu ọnụ, makẹni 'ya lẹ enwẹn ẹ a marịngụọ ihiẹn o jẹnkọ d'e mẹ.)
\v 7 Filipu nọ za a, sị, “Egho ọrụn ifọn isin ezukọ ṅọn brẹdi sikọ d'e rusọnmẹ wẹ ẹka—ọsụọn'a ẹkẹrẹ-ẹkẹrẹ.”
\v 8 Onyẹ ohu imẹ ụmụ-azụụn Jesu w'a kpọ Andụrụ, hụn wụ nwẹnẹ Saịmọn' Pita, nọ sị a,
\v 9 “O nwọn nwata-okẹnnyẹ bu ogbe brẹdi isẹn wẹ gi ọka bali mẹmẹ lẹ azụn ẹbụọ ebeni; kalẹ, ebe wẹ sikọ d'a pụ igunrunni?”
\v 10 Jizọsị nọ sị, “Gwa nị wẹ nọdị alị.”
\p (Irurue rị ebẹhụ ọda.)
\p Ya ndị hụ nọ nọdị alị—ihiẹn rịkẹ ikẹnnyẹ ọgụn-iri-kwasị-nnụ-mmẹbụọ rị imẹ wẹ, ('ya wụ ihiẹn nọkẹ nnụ-uku isẹn).
\v 11 Jesu nọ weri ogbe brẹdi ndị hụ, o yegụụ Osolobuẹ ekele, ọ nọ keni ndị nọdị alị 'ya; ọ nọ mẹmẹzi azụn ẹrịra, wẹ nọ ri kẹ wẹ chọ.
\v 12 Ogẹn ẹfọ gi jungụụ wẹ, Jesu nọ sị ụmụ-azụụn a, “Kpọnkwama nị ifunfun ẹ họdụnị, amamgbe ihiẹn-anaị a la iwi.”
\v 13 'Ya wẹ nọ kpọnkwamẹ wẹ, che imẹ ụkpalị. Ifunfun brẹdi họdụnị imẹ ogbe-brẹdi bali isẹn hụ ogẹn ndị hụ gi rigụụ jun ụkpalị mmẹbụọ.
\p 
\v 14 Ogẹn ndị hụ gi hụn ọrụn-atụmẹnya hụn Jizọsị rụn, wẹ nọ gwama ibe wẹ, sị, “Ezioku-ezioku, ọnwan wụ onyẹ-amụma hụ ẹnyi rị e lee ẹnya a n'o jẹnkọ d'a bịa imẹ ụwa!”
\p 
\v 15 Ogẹn Jesu gi hụn nị w'e d'a bịa d'e gi ikẹn weri ẹ, kin ẹ eze, ọ nọ gha ebahụn pụ, 'ya sụọ nọ kin-azụụn shizi elu-ugu.
\s1 Jesu E Jẹn Ijẹn Elu Mirin
\r (Mat 14.22-33; Mak 6.45-52)
\p 
\v 16 O ru ogẹn ẹnyasị, ụmụ-azụụn Jesu nọ shi “Ohimin”,
\v 17 banye imẹ ụgbọ-mirin, buli, jẹnkọ Kapanọm. (Ọhịhị nọ gbachanrịn bụ Jesu eke bịakwọ d'e kunrun wẹ.)
\v 18 Mirin hụ e mẹhunmẹ ọda-ọda makẹlẹ okẹn-ufere rị a kpọ.
\v 19 Ogẹn wẹ gi nyanru ihiẹn rịkẹ maịlị ẹtọ mọbụ ẹnọ, wẹ nọ hụn Jesu kẹ o jẹnla ijẹn elu mirin, a nọkunmẹ ụgbọ. Egun nọ tụma wẹ.
\v 20 Kanị ọ nọ sị wẹ, “Mmẹ rọ, atụlẹ ni egun!”
\v 21 Wẹ nọ chọ n'ọ banye ni wẹ imẹ ụgbọ; ozigbo, ụgbọ hụ nọ ru mkpẹnrẹn mirin alị hụ wẹ jẹnkọ.
\s1 Igunrun Hụ A Chọma Jizọsị
\p 
\v 22 Eki e fọn, ọ nọ we ndị ahụn nọdị azụụn “Ohimin” hụ hụn-ẹbọ hụn ụmụ-azụụn Jizọsị gha bịa Kapanọm ẹnya nị ụgbọ ohu sụọ te rị ebẹhụ; nị Jesu esọnni ụmụ-azụụn a banye imẹ ụgbọ lẹ ni ụmụ-azụụn a sụọ gba gha ebẹhụ pụ.
\v 23 Kanị ogẹnni, ụgbọ ndị ọzọ gha Taịberiasị bịa rị nwan ẹhịụ ebahụn wẹ nọ ri brẹdi ogẹn Di-nwọnni-ẹnyi gi yegụụ ekele.
\v 24 Ogẹn ndị hụ gi nwan hụn nị kẹ Jesu kẹ ụmụ-azụụn a arịzị ebahụn, wẹ lẹ enwẹn wẹ nọ banye ụgbọ ndị hụ chọsọnmẹ Jesu shi Kapanọm'.
\s1 Jesu Wụ Ihiẹn-oriri Hụ Hụn E Ye Ndụn
\p 
\v 25 Ogẹn wẹ gi hụn Jesu azụụn “ohimin” hụ hụn-ẹbọ, wẹ nọ sị a, “Onyẹ-nkuzi, elee ogẹn k'i gi pụha ebeni?”
\v 26 Jesu nọ za wẹ, sị, “Ezioku kẹ m rị a gwa ụnụ, ụnụ rị a chọ m makẹni ụnụ ri brẹdi, o jun ụnụ ẹfọ, ẹlẹ makẹni ụnụ hụn ọrụn-atụmẹnya ndị hụn m rụn.
\v 27 Egilẹ ni ifiri ihiẹn-oriri hụn e wiwini a rụngbu enwẹn ụnụ, ka gi ni ifiri ihiẹn-oriri ahụn sikọ d'a tọ jẹnrin ejẹn, e ye ndụn itẹbitẹ, rụngbu enwẹn ụnụ, ihiẹn-oriri hụ Nwa nke Ịhịan jẹnkọ d'e ye ụnụ; makẹni ịya wụ Nwa nke Ịhịan kẹ Chuku wụ Nẹdi tumẹ.”
\p 
\v 28 Wẹ nọ sị a, “Kị ẹnyi jẹnkọ d'a rụn hụn wụ ọrụn Osolobuẹ chọ nị ẹnyi rụn?”
\p 
\v 29 Jesu nọ za wẹ, sị, “Ọnwan wụ ọrụn Osolobuẹ chọ nị ụnụ rụn: Ọ chọ nị ụnụ kweri ni onyẹ hụn o zihẹ.”
\p 
\v 30 Wẹ nọ sị a, “Elee ọrụn-atụmẹnya k'i jẹnkọ nwan d'a rụnghọsị ẹnyi kẹni ẹnyi hụn a, ẹnyi e kweyeni ihiẹn i ku? Kịnị kẹ i jẹnkọ d'e mẹ?
\v 31 Ndị nẹdi ẹnyi kanị ri mana imẹ atụ; ya kẹ wẹ de imẹ Ẹkụkwọ-nsọ, sị, ‘O ye wẹ brẹdi gha elu-igwee bịa ri.’ ”
\v 32 Jizọsị nọ sị wẹ, “Ezioku kẹ m rị a gwa ụnụ, ẹlẹ Mozizi ye ụnụ brẹdi gha elu-igwee bịa; Nẹdi m wụ hụn rị nwan e ye ụnụ ezigbo brẹdi gha elu-igwee bịa.
\v 33 Makẹni brẹdi Osolobuẹ wụ onyẹ hụ gha elu-igwee bịa, hụn e ye ụwa ndụn.”
\v 34 Wẹ nọ sị a, “Di-ọkpa, yemẹ ẹnyi brẹdini ogẹn ile.”
\p 
\v 35 Jizọsị nọ sị wẹ, “Mmẹ wụ brẹdi hụn e ye ndụn. Ẹgụn agụnkọ onyẹ hụn bịa d'e kunrun ni m; ẹgụn mirin agụnkọ onyẹ hụn kwerini ni m.
\p 
\v 36 Kanị, nọkẹ kẹ m dọn gwa ụnụ mbụ, ụnụ a hụnọlẹ m, kanị ụnụ e kwerini.
\v 37 Ndị ile Nẹdi m ye m sikọ d'a bịa d'e kunrun m; a chụpụkọ m onyẹ ọwụlẹ hụn bịa d'e kunrun ni m.”
\v 38 Makẹni ẹlẹ m gha elu-igwee bịa d'e mẹ uche m, kanị m bịa d'e mẹ uche onyẹ hụn zihẹ ni m.
\v 39 Ọnwan wụ uche onyẹ zihẹni m: nị etuhukọ m onyẹ ọwụlẹ imẹ ndị ile o ye m, kama, nị m jẹnkọ d'a gha ọnwụn weli wẹ Ụhụọhịn-ikpazụụn.
\v 40 Makẹni uche Nẹdi m wụ nị onyẹ ọwụlẹ hụn hụn Nwa, kweri n'ẹ, jẹnkọ d'e nwọn ndụn itẹbitẹ; m sikọ d'e weli ẹ Ụhụọhịn-ikpazụụn.
\p 
\v 41 Ndị Ju nọ dẹnwịnnwịnma n'a makẹni ọ sị, “Mmẹ wụ brẹdi hụ hụn gha elu-igwee bịa.”
\v 42 Wẹ hụ a sị, “Ẹlẹ Jesu nwa Josẹfụ wụ ọnwan—hụn ẹnyi marịn ndị mụn'a? Nanị k'o dọn nwan a sị, ‘M gha elu-igwee bịa?’ ”
\p 
\v 43 Jizọsị nọ za wẹ, sị, “Edẹnwịnnwịnzịlẹ ni.
\v 44 O nwọnni onyẹ jẹnkọ d'a s'ẹka bịa d'e kunrun m mmanị Chuku-Nẹdi hụn zihẹ ni m dọha a; m jẹnkọ d'e weli onyẹ ahụn Ụhụọhịn-ikpazụụn.
\v 45 Wẹ de ẹ imẹ Ẹkụkwọ ndị-amụma nị, ‘Osolobuẹ sikọ d'a kuzi wẹ ile.’ Onyẹ ọwụlẹ hụn rị e gọn Chuku-Nẹdi ntịn, a mụnarịn a, ịya wụ onyẹ hụn a bịa d'e kunrun ni m.
\v 46 (Ẹlẹ n'o nwẹ onyẹ hụn hụntu Chuku-Nẹdi—onyẹ hụ hụn gha ebe Chuku rị bịa, 'ya sụọ hụntu Chuku-Nẹdi.)
\v 47 Ezioku kẹ m rị a gwa ụnụ, onyẹ ọwụlẹ kwerini nwọn ndụn itẹbitẹ.
\p 
\v 48 Mmẹ wụ brẹdi hụn e ye ndụn.
\v 49 Ndị nẹdi ụnụ kanị ri mana\f + \fr 6:49 \fk mana: \ft Ịya kẹ wẹ kpọ ihiẹn-oriri hụ Osolobuẹ gha elu-igwee zihẹ ni ndị Izrẹlụ imẹ atụ ogẹn Mozizi.\f* hụ wẹ ri imẹ atụ, kanị, a nwụnhụnghọ wẹ.
\v 50 Kanị ọnwan wụ brẹdi hụn gha elu-igwee bịa hụn o mẹ ni onyẹ ri n'ẹ anwụnhụnkọ.
\v 51 Mmẹ wụ brẹdi hụ rị ndụn hụn gha elu-igwee bịa. Onyẹ ọwụlẹ ri brẹdini jẹnkọ d'a rị ndụn jẹnrin ejẹn. Brẹdi hụ m sikọ d'e ye makẹ ufiri ndụn ndị rị imẹ ụwa wụ ẹhụ m.”
\p 
\v 52 'Ya kẹ ndị Ju ahụn nọ dọma ndọndọ imẹ wẹ, a sị, “Nanị kẹ okẹnnyẹni a dọn ye ẹnyi ẹhụ a ri?”
\p 
\v 53 'Ya Jizọsị nọ sị wẹ, “Ezioku kẹ m rị a gwa ụnụ, mmanị ụnụ ri ẹhụ Nwa nke Ịhịan, ra ẹdeke ẹ,—ụnụ enwọnkọ ndụn imẹ ụnụ.
\v 54 Onyẹ ri ẹhụ m, ra ẹdeke m, ọ wụrụ onyẹ nwẹ ndụn itẹbitẹ; m sikọ d'e weli ẹ Ụhụọhịn-ikpazụụn.
\v 55 Makẹni, ẹhụ m wụ ezigbo ihiẹn-oriri, ẹdeke m wụzịkwọ ezigbo ihiẹn-ọrịra.
\v 56 Onyẹ hụn ri ẹhụ m ra ẹdeke m, bi imẹ m, mmẹ lẹ enwẹn m bi imẹ ẹ.”
\p 
\v 57 “Kẹ m dọn rị ndụn makẹni Chuku-Nẹdi hụn zihẹ ni m rị ndụn, ẹrịra kẹ onyẹ hụn ri ni m k'a dọn rị ndụn makẹ ufiri m.
\v 58 Ọnwan wụ ezigbo brẹdi hụn gha elu-igwee bịa; ọ nọnị kẹ ihiẹn ahụn ndị mbụ ri, omẹgụụ a nwụnhụnkwọ wẹ. Onyẹ hụn ri brẹdini jẹnkọ d'a rị ndụn jẹnrin ejẹn.”
\p 
\v 59 Ogẹn Jesu gi rị a kuzi imẹ ụlọ-ofufe ndị Ju rị imẹ obodo Kapanọm k'o gi ku ihiẹn ndịnị.
\s1 Oku Hụn E Ye Ndụn Itẹbitẹ
\p 
\v 60 Ndị bu ọda imẹ ụmụ-azụụn a a nụ ihiẹnni, wẹ nọ sị, “Okuni e zekẹkwọ! Onyẹ sikọ d'a saẹka nabanhan a?”
\p 
\v 61 Kanị, Jizọs' a marịngụọ nị ụmụ-azụụn a rị e dẹnwịnnwịn makẹ ihiẹnni o ku. Ọ nọ sị wẹ, “Ọnwan k'e mẹ ụnụ ekwerizilẹ?
\v 62 Kị ụnụ jẹnkọ d'e mẹzi nwan omẹni ụnụ a hụn Nwa nke Ịhịan k'o lakọ elu-igwee ebe ọ rị mbụ?
\v 63 Mmọn-nsọ ịya sụọ e ye ndụn, ihiẹn ịhịan mmaka ara ban erere ọwụlẹ: oku ndịnị m rị a gwa ụnụ wụ oku imẹ-mmọn lẹ oku hụn e ye ndụn.
\v 64 Kanị ndị hụ imẹ ụnụ ekwerini.” (Gha isi mbidọn lala, Jesu a marịngụọ ndị hụn jẹnkọlẹni d'e kweri lẹ onyẹ hụn jẹnkọ d'e re n'ẹ.)
\v 65 Ọ nọ sịzị, “Ọnwan haịn m gi sị ụnụ n'o nwọnni onyẹ jẹnkọ d'a saẹka bịa d'e kunrun m mmanị Chuku-Nẹdi mẹ ẹ n'ọ bịa.”
\p 
\v 66 Makẹ ọnwan, ụmụ-azụụn Jesu bu ọda nọ kin-azụụn, esọnzini w'ẹ.
\p 
\v 67 Ya Jizọsị nọ sị ụmụ-azụụn a mmẹbụọ hụ, “Ụnụ lẹ enwẹn ụnụ sikọ d'a pụzịdẹ nwan ra?”
\v 68 Saịmọnụ wụ Pita nọ za a, sị, “Di-nwọnni-ẹnyi, onyẹ kẹ ẹnyi jẹnburukọ? Ịyụ nwọn oku ndị e ye ndụn itẹbitẹ.
\v 69 Ẹnyi e kwerighọ, marịnzịkwọ, nị ịyụ wụ Onyẹ-nsọ Osolobuẹ.”
\v 70 Jizọsị nọ sị wẹ, “Mmẹ họrị ụnụ mmẹbụọ, ẹlẹ 'ya? Kanị onyẹ ohu imẹ ụnụ wụ Ekwensụ!”
\v 71 (Judasị nwa Saịmọnụ Iskarọtụ k'ọ rị e ku, makẹni ọ wụ onyẹ ohu imẹ ụmụ-azụụn mmẹbụọ hụ bụ 'ya jẹnkọ d'e re ẹ.)
\c 7
\cl Isi Nke Ẹsa
\s1 Ogẹn Umunẹ Jesu Kelẹni Kweri N'ẹ
\p 
\v 1 Omẹgụụ, Jesu nọ ghagbarị imẹ Galili, latọgụụ Judia; o jẹnhunmẹni imẹ Judia, makẹni ndị-ndu ndị Ju rị a chọ nị wẹ gbu ẹ.
\v 2 Ogẹn hụ, mmẹmmẹ ndị Ju gi a nọdịsọnmẹ imẹ Ọdụ\f + \fr 7:2 \ft Livitikọsị 23.34\f* e rugụọ.
\v 3 'Ya umunẹ Jesu nọ sị a, “O furu n'ị gha ebeni pụ, si Judia, kẹni ụmụ-azụụn ị hụn ọrụn-atụmẹnya ndị ị rị a rụn.
\v 4 Makẹni o nwọnni onyẹ hụn a rụn ọrụn imẹ nzuzue ọwụnị ọ chọ nị wẹ marịn a. Ebe o mẹ ni i rị e mẹ ihiẹn ndịnị ile, we nwan enwẹn i ghọsị ụwa.”
\v 5 (Ọnwan mẹ makẹni kẹ umunẹ ẹ dẹ e kwerini n'ẹ.)
\p 
\v 6 'Ya Jizọsị nọ sị wẹ, “Ogẹn furu ni m e ke ru, kanị ogẹn ile furu ụnụ.
\v 7 Izize ụnụ ezekọ ụwa, kalẹ izize m e ze wẹ makẹlẹ m rị a gwa wẹ nị ihiẹn w'e mẹ jọ njọ.
\v 8 Jẹnmẹ ni nwan mmẹmmẹni, mmẹ lẹ enwẹn m eke jẹnkọ mmẹmmẹ hụnnị, makẹni ogẹn furu ni m e ke ru.”
\v 9 O kugụụ ihiẹnni, ọ nọ nọdịkwọ imẹ Galili.
\s1 Jesu E Jẹn Mmẹmmẹ-ọdụ
\p 
\v 10 Kanị ogẹn umunẹ Jesu gi jẹnmẹgụụ mmẹmmẹ hụ, ọ nọzị jẹnmẹ, kanị nzuzue k'o gi jẹn.
\p 
\v 11 Ndị-ndu ndị-Ju hụ a chọ a imẹ mmẹmmẹ hụ, wẹ hụ a sị, “Elebe k'ọ rị?”
\v 12 Ndị rị igunrun rịsọnmẹ ebẹhụ hụ a kasọnmẹ murinmurin. Ndịnị sị, “Ezigbo ịhịan k'ọ wụ,” ndịnị sị, “Mba, ọ rịhụ e dufie ndị alị.”
\v 13 Kanị, makẹni egun ndị-ndu ndị Ju rị a tụ wẹ, o nwọnni onyẹ s'ẹka ku oku ẹ ifọnrin-ifọn.
\p 
\v 14 Ogẹn mmẹmmẹ hụ gi rugụụ ahanmahan, Jizọsị nọ si Ụlọ-nsọ d'a kuzimẹ.
\v 15 Ọ nọ tụ ndị-ndu ndị Ju ẹnya, wẹ nọ sị, “Nanị kẹ okẹnnyẹni dọn marịn ihiẹn ọda ẹnịna, bụ o ke jẹntu ọzụnzụn ọwụlẹ?”
\v 16 Jesu nọ za wẹ, sị, “Nkuzi m ẹlẹ nke m kanị nke onyẹ zihẹ ni m rọ.
\v 17 Omẹni ịhịan a kwademẹ obi ẹ n'o jẹnkọ d'e mẹ uche Osolobuẹ, onyẹ hụ sikọ d'a marịn omẹni nkuzi m gha ẹka Osolobuẹ bịa ra m gi ikẹn m e ku.
\v 18 Onyẹ hụn e gi ikẹn ẹ e ku rị a chọ nị wẹ ja a mma; kanị onyẹ rị e mẹ nị wẹ ye onyẹ zihẹn'ẹ ọghọ wụ onyẹ ezioku, ntụ a rị imẹ ẹ.”
\p 
\v 19 “Mozizi ye ụnụ Iwu, ẹlẹ 'ya? Kanị o nwọnni onyẹ ohu imẹ ụnụ hụn e dọnmẹ Iwu hụ. Kị haịn ụnụ gi a chọ nị ụnụ gbu m?”
\p 
\v 20 Igunrun hụ nọ za, sị, “Eje-mmọn rị imẹ i! Onyẹ rị a chọ n'o gbu i?”
\p 
\v 21 Jesu nọ sị, “M rụn ọrụn-atụmẹnya ohu, ọ nọ tụ ụnụ ile ẹnya.
\v 22 Mozizi ye ụnụ iwu ịkwa-ugun. (Kanị ẹlẹ Mozizi bidọn ịkwa-ugun, ndị nẹdi ụnụ kanị bidọn ẹ.) Ụnụ a kwadẹ okẹnnyẹ ugun Ụhụọhịn Izu-ikẹn kẹni ụnụ hụn ụzọ mẹzu iwu hụ.
\v 23 Omẹni wẹ hụ a kwa okẹnnyẹ ugun Ụhụọhịn Izu-ikẹn amamgbe w'a dan Iwu Mozizi, kị haịn ụnụ gi e we ni m iwe makẹni m zụọchanrịn okẹnnyẹni ẹhụ a ile Ụhụọhịn Izu-ikẹn?
\v 24 Ahanzilẹ ni eṅẹn kẹ ụnụ hụn a, kama, e leban nị ihiẹn ẹnya ọhụnma kẹni ụnụ hụn ụzọ han eṅẹn rị mma.”
\s1 Onyẹ Kẹ Jesu Wụ?
\p 
\v 25 Ya ndị hụ imẹ ndị Jerusalẹm nọ sị, “Ẹlẹ ọnwan wụ okẹnnyẹ hụ ndị-ndu rị a chọ nị wẹ gbu?
\v 26 Lee ẹ nwan k'ọ rị ebeni e ku oku id'ẹnya ịhịan ile, a gba w'a nkịntịn! A marịngụọdẹ wẹ nwan nị 'ya wụ Kraịstị, Onyẹ Hụ Osolobuẹ Tumẹ ra?
\v 27 Kanị ẹnyi a marịnghọ ebe okẹnnyẹni gha bịa; ogẹn Kraịstị jẹnkọ d'e gi bịa, o nwọnni onyẹ jẹnkọ d'a marịn ebe ọ gha bịa.”
\p 
\v 28 Ogẹn Jesu gi rị a kuzi imẹ Ụlọ-nsọ, ọ nọ weshi olu elu, sị, “Eziẹ, ụnụ a marịngụọ m, marịnzịkwọ ebe m gha bịa! Kanị, egini m ihiẹn ẹka m bịa; onyẹ hụn zihẹ ni m furu wẹ gi dọn ẹnya—'ya kẹ ụnụ marịnlẹni!
\v 29 A marịnghọ m'a makẹni m gha ebe ọ rị bịa, 'ya zihẹ m.”
\p 
\v 30 'Ya wẹ nọ chọ nị wẹ nwụnrụn a; kanị o nwọnni onyẹ mẹtụ a ẹka, makẹni ogẹn ẹ e ke ru.
\v 31 K'osilẹrị, ndị bu ọda rị ebẹhụ nọ kwerini n'ẹ; wẹ hụ a sị, “Ogẹn Kraịstị wụ Mezaya, Onyẹ Hụ Osolobuẹ Tumẹ, k'e gi bịa, n'ọ rụnkarị okẹnnyẹni ọrụn-atụmẹnya?”
\s1 E Zi Wẹ Ndị-ụnakpa Ụlọ-nsọ D'a Nwụnhan Jesu
\p 
\v 32 Ndị Itu-Farisi a nụ kẹ igunrun hụ rị e ku ihiẹn ndịnị wẹ banyeni Jizọsị, 'ya ndị-isi nchụ-ẹjan lẹ ndị Itu-Farisi nọ zi ndị ụnakpa Ụlọ-nsọ d'a nwụnhan a.
\p 
\v 33 Jizọsị nọ sị, “M jẹnkọ d'e sọn ụnụ nọdị ẹkẹrẹ, omẹgụụ, a laburu m onyẹ hụn zihẹ ni m;
\v 34 ụnụ jẹnkọ d'a chọ m, kanị, ụnụ ahụnkọ m; ebe m rị, ụnụ e ri-ẹka bịa.”
\v 35 Ndị-isi ndị Ju nọ sị ibe wẹ, “Elebe kẹ okẹnnyẹni chọ n'o jẹn, hụn ẹnyi jẹnkọlẹni d'a hụn a? Ọ chọ n'o jẹn alị ndị Griki—alị ndị wụlẹni ndị Ju—ebe ndị nke ẹnyi rịsọnmẹ d'a kuzimẹ imẹ igunrun ndị wụlẹni ndị-Ju?
\v 36 K'o gi ihiẹnni e ku: ‘Ụnụ sikọ d'a chọ m, kanị, ụnụ ahụnkọ m; ebe m rị, ụnụ asakọ ẹka bịa a.’?”
\s1 Mirin Hụn E Ye Ndụn
\p 
\v 37 Ụhụọhịn ịkpazụụn mmẹmmẹ hụ, hụn wụ ụhụọhịn kachanrịn mkpa, Jesu nọ wuzo ọtọ, yi oro, sị, “Omẹni o nwọn onyẹ ẹgụn mirin rị a gụn, 'ya bịa d'e kunrun m n'ọ ra!
\v 38 Onyẹ ọwụlẹ hụn kwerini ni m, ya ra; o sikọ d'a rị n'a kẹ Ẹhụhụọ-nsọ dọn ku:
\q1 ‘Mirin hụn e ye ndụn
\q2 jẹnkọ d'a gha imẹ ẹ
\q2 e hupụha kẹ iyi.’ ”
\p 
\v 39 Jizọsị gi ọnwan e ku oku Mmọn-nsọ hụn ndị kwerini n'ẹ jẹnkọ d'e nwẹhẹn. W'e ke ye wẹ Mmọn-nsọ ogẹn hụ makẹni Jesu e ke banye ọghọ a.
\s1 Igunrun Hụ E Kebe
\p 
\v 40 Ogẹn wẹ gi nụ oku ndịnị, ndị hụ imẹ igunrun hụ nọ sị, “Ezioku, ọnwan wụ onyẹ-amụma Hụ \it pụ-ichẹn\it*.”
\v 41 Ndị ọzọ sị, “Ọnwan wụ Kraịstị, Onyẹ Hụ Osolobuẹ Tumẹ!” Kanị ndị hụ imẹ wẹ sị, “Kraịstị k'a ghadẹ nwan Galili bịa ra?!
\v 42 Ẹhụhụọ-nsọ e kugụọn'a nị Kraịstị, Onyẹ Hụ Osolobuẹ Tumẹ, sikọ d'a gha ebọn Defidi pụha; n'o sikọ d'a gha Bẹtulẹhẹm, obodo Defidi te bi bịa?”
\v 43 Oku banyeni Jizọsị nọ kebe igunrun ahụn.
\v 44 Ndị hụ imẹ wẹ te chọ nị wẹ nwụnrụn a, kanị o nwọnni onyẹ mẹtụ a ẹka.
\s1 Ndị-ndu Ndị Ju A Jụ N'e Kwerikọnị Wẹ Jesu
\p 
\v 45 Ogẹn ndị-ụnakpa Ụlọ-nsọ ahụn gi kinhẹn azụụn d'e kunrun ndị-isi nchụ-ẹjan lẹ ndị Itu-Farisi, wẹ nọ jụma wẹ, sị, “Kị haịn ụnụ gilẹni wẹhẹ ẹ?”
\v 46 Ndị ụnakpa Ụlọ-nsọ hụ nọ za, sị, “O nwọnni onyẹ kutu oku kẹ okẹnnyẹni!”
\p 
\v 47 Ndị Itu-Farisi nọ jụ wẹ, sị, “E dufiegụọzịdẹ wẹ nwan ụnụ nwẹn ra?
\v 48 O nwọnghọ kaka akpụ onyẹ-ndu mọbụ onyẹ Itu-Farisi ohu ụnụ marịn hụn kwerini n'ẹ?
\v 49 Igunrunni amarịn Iwu Mozizi, ndị wẹ bụ ọnụ kẹ wẹ wụ.”
\p 
\v 50 Nikodimọsị hụn jẹn d'e kunrun Jesu mbụ, hụn wụ onyẹ ohu imẹ wẹ nọ sị wẹ,
\v 51 “Iwu ẹnyi a madẹ ịhịan ikpe bụ ebuni wẹ ụzọ nụ ọnụ a mọbụ chọpụha ihiẹn o mẹ ra?”
\p 
\v 52 Wẹ nọ za, sị, “Ị wụzịdẹ onyẹ Galili ra? Mụ Ẹkụkwọ-nsọ n'ị marịn nị onyẹ-amụma ara gha \f + \fr 7:52 \ft …onyẹ-amụma hụ pụ-ichẹn aghakọ…\f* Galili bịa.” [
\v 53 Onyẹ ọwụlẹ nọ lashi iwe ẹ.
\c 8
\cl Isi Nke Ẹsatọ
\s1 Okpoho Hụ Zọ-ụkụ-ye-ọfịa
\p 
\v 1 Kanị, Jesu nọ si Ugu Olivu.
\v 2 O ru ụzọ-ụtụntụn, o kinhẹnzi Ụlọ-nsọ. Ndị hụ ile nọ bịa d'e kunrun ẹ, ọ nọ nọdị alị, kuzimẹ wẹ.
\p 
\v 3 Ya ndị-nkuzi Iwu lẹ ndị Itu-Farisi nọ wẹhẹ okpoho ohu wẹ nwụn ebe ọ rị a zọ-ụkụ-eye-ọfịa. Wẹ nọ bu ẹ tumẹ ihun ịhịan ile.
\v 4 Wẹ nọ sị Jizọsị, “Onyẹ-nkuzi, wẹ nwụn okpohoni ebe ọ rị a zọ ụkụ e ye ọfịa.
\v 5 Imẹ Iwu, Mozizi sị ẹnyi gi ọmụma magbu okpoho nọ ẹnịna, kalẹ, k'i k'e ku nwan banyen'ẹ?”
\v 6 (Wẹ jụ a ihiẹnni nị wẹ gi ẹ kwọndọn Jizọsị, kẹni wẹ hụn ihiẹn wẹ k'a sị nị ya k'o mẹ.) Ya kẹ Jizọsị nọ hulụa alị, gi mkpịnsịn-ẹka a demẹ ihiẹn alị.
\v 7 Ogẹn wẹ gi tọ a jụ a, o nọ lihi ọtọ, sị wẹ, “Onyẹ ọwụlẹ imẹ ụnụ mẹtulẹni njọ, 'ya bu ụzọ ma a ọmụma.”
\v 8 'Ya ọ nọ hulụazị alị, demẹ ihiẹn alị.
\v 9 Ogẹn wẹ gi nụ ihiẹnni, wẹ ile nọ pụma, ohu-ohu, ndị kanị bu ụzọ pụma, d'e ru n'ọ họdụ Jizọsị sụọ; okpoho hụ turuhụkwọ ebẹhụ ihun Jizọsị.
\v 10 Ya Jesu nọ lihi ọtọ, sị a, “Okpoho, elebe kẹ wẹ rị? O nwọnni onyẹ ma ị ikpe?”
\v 11 Ọ nọ sị, “Di-ọkpa, o nwọnni.” Jizọsị nọ sị a, “Mmẹ nwẹn ẹ amakọkwọ ị ikpe. Jẹnmẹ. Kanị, gha kikẹnni jẹnmẹ, emẹzilẹ njọ.”]
\s1 Jizọsị Wụ Ukpẹ Ụwa
\p 
\v 12 Jizọsị nọ sịzị ndị ahụn o te rị a kuzi, “Mmẹ wụ ukpẹ ụwa. Onyẹ ọwụlẹ hụn rị e sọnni m aghakọ imẹ ishi, kama, o sikọ d'e nwọn ukpẹ hụ hụn e ye ndụn.”
\p 
\v 13 Ndị-Farisi nọ shịarị a, sị, “Ị rị nwan a shịanị enwẹn i ẹri, egikọ wẹ ẹri i dọn.”
\p 
\v 14 Jesu nọ za, sị, “Ọsụọn'a nị m shịa nị enwẹn m ẹri, ẹri m furu wẹ gi dọn, makẹlẹ a marịnghọ m ebe m gha bịa lẹ ebe m jẹnkọ. Ụnụ amarịn ebe m gha bịa mọbụ ebe m jẹnkọ.
\v 15 Ụnụ e gi ihiẹn ẹnya e legha a han eṅẹn. O nwọnni onyẹ m'a hannị eṅẹn.
\v 16 Kanị ọ sụọ n'a nị m jẹnkọ d'a han eṅẹn, eṅẹn m'a han wụ ezioku, makẹni ẹlẹ mmẹ sụọ a han a, kama mmẹ lẹ Chuku-Nẹdi hụn zihẹ ni m gba a han a.
\p 
\v 17 Imẹ Iwu ụnụ, wẹ de ẹ nị ẹri mmadụ ẹbụọ kẹ wẹ gi e dọn.
\v 18 M rị a shịanị enwẹn m ẹri; Nẹdi m hụn zihẹ ni m rị a shịazịkwọ nị m ẹri.”
\v 19 Ya wẹ nọ sị a, “Elebe kẹ Nẹdi i rị?” Jesu nọ za, sị, “Ụnụ amarịn m, ụnụ amarịnzịkwọ Nẹdi m. Omẹlẹ ụnụ marịn m amarịn, nkẹ ụnụ a marịnzịkwọ Nẹdi m.”
\p 
\v 20 Jesu ku ihiẹn ndịnị ogẹn o gi rị ẹhụ ebe w'e buche oyiye imẹ Ụlọ-nsọ a kuzi, bụ o nwọnni onyẹ nwụnrụnn'a makẹni ogẹn ẹ e ke ru.
\s1 Ebe Jesu Gha Bịa Lẹ Ebe O Jẹnkọ
\p 
\v 21 Jizọsị nọzị gwa wẹ, sị, “M jẹnkọ d'a pụ; ụnụ sikọ d'a chọ m—kanị ụnụ jẹnkọ d'a nwụntọ imẹ njọ ụnụ. Ụnụ asakọ ẹka bịa ebe m jẹnkọ.”
\p 
\v 22 Ndị-ndu ndị Ju nọ sị, “Ọ sị nị ẹnyi asakọ ẹka bịa ebe o jẹnkọ. 'Ya wụ n'o jẹnkọ d'e gbudẹ nwan enwẹn ẹ ra?” Ịya k'o gidẹ nwan ihiẹnni e ku ra?
\p 
\v 23 Jizọsị nọ za wẹ, sị, “Ụnụ gha ibe alị bịa, kalẹ m gha elu bịa. Ụnụ wụ nke ụwanị, kanị ẹlẹ m nke ụwanị.
\v 24 'Ya haịn m gi gwa ụnụ nị ụnụ sikọ d'a nwụntọ imẹ njọ ụnụ. Ụnụ jẹnkọ d'a nwụntọ imẹ njọ ụnụ mmanị ụnụ kweri nị m wụ onyẹ ahụn m sị nị 'ya kẹ m wụ.”
\p 
\v 25 Wẹ nọ sị a, “Onyẹ k'ị wụ?” Jesu nọ sị wẹ, “Ihiẹn hụ m gwa ụnụ isi mbidọn kẹ m wụ.
\v 26 M nwọn ihiẹn bu ọda m k'a saẹka ku banyeni ụnụ, ihiẹn bu ọda m'e gi ma ụnụ ikpe; kanị, onyẹ hụn zihẹ ni m furu wẹ gi e dọn ẹnya, m rịhụ a gwa ụwa ihiẹn ndị m nụ ọnụ a.”
\v 27 (Kanị aghọtanị wẹ n'ọ rị a gwa wẹ banyeni Chuku-Nẹdi.)
\v 28 'Ya Jizọsị nọ sị, “Ogẹn ụnụ jẹnkọ d'e gi wesi Nwa nke Ịhịan enu kẹ ụnụ jẹnkọ d'e gi marịn nị m wụ onyẹ m wụ—Kraịstị, Onyẹ Hụ Osolobuẹ Tumẹ—nị m'a ra gi uche m mẹ ihiẹn ọwụlẹ, kama, nị m rị a gwa ụnụ ihiẹn ndịnị wẹ kẹ Nẹdi m dọn kuzi m.
\v 29 Onyẹ hụ zihẹ ni m nọyeni m anọyeni; ọ natọnị m, makẹni ogẹn ile kẹ m gi e mẹ ihiẹn a sụọn'a.”
\p 
\v 30 Ogẹn o gi rị e ku ihiẹn ndịnị wẹ, ndị bu ọda nọ kweri.
\s1 Ezioku Jẹnkọ D'e Mẹ Ụnụ Weri Enwẹn Ụnụ
\p 
\v 31 Jizọsị nọ sị ndị Ju hụn kwerini n'ẹ, “Omẹni ụnụ e sọn nkuzi m, 'ya wụ ụnụ wụ ụmụ-azụụn m nke-esi.
\v 32 Ụnụ mẹ ẹ, ụnụ jẹnkọ d'a marịn ezioku, ezioku jẹnkọ d'e mẹ ụnụ nwọnrin enwẹn ụnụ.”
\v 33 Wẹ nọ za a, sị, “Ẹnyi wụ ụmụ Ebraham, ẹnyi awụtuni igbọn onyẹ ọwụlẹ. K'i rị a sịnị, ‘Ụnụ jẹnkọ d'e weri enwẹn ụnụ’?”
\v 34 Jesu nọ sị wẹ, “Ezioku kẹ m rị a gwa ụnụ, onyẹ ọwụlẹ hụn e mẹ njọ wụ igbọn njọ.
\v 35 Igbọn ara nwọn ọnọdị imẹ ezi-lẹ-ụlọ jẹnrin ejẹn, kanị, nwa nwọn ọnọdị imẹ ezi-lẹ-ụlọ jẹnrin ejẹn.
\v 36 'Ya wụ, omẹni Nwa Osolobuẹ mẹ ụnụ weri enwẹn ụnụ, ụnụ jẹnkọ d'e nwọnrin enwẹn ụnụ nke-esi.
\v 37 A marịnghọ m nị ụnụ wụ ụmụ Ebraham, kanị ụnụ rị nwan a chọ nị ụnụ gbu m, makẹni oku m enwọn ọnọdị imẹ ụnụ.
\v 38 M'e ku ihiẹn m hụn ebe Nẹdi m rị, kalẹ ụnụ e mẹ ihiẹn ụnụ nụ ọnụ nẹdi ụnụ.”
\p 
\v 39 Wẹ nọ za a, sị, “Ebraham wụ nẹdi ẹnyi.” Jesu nọ sị wẹ, “Omẹni eziẹ rọ nị ụnụ wụ ụmụ Ebraham, nkẹ ụnụ hụ e mẹ ihiẹn Ebraham mẹ.
\v 40 Kanị ụnụ chọ nwan nị ụnụ gbu m, onyẹ hụn gwa ụnụ ezioku hụn m nụ ọnụ Osolobuẹ. Ebraham e mẹni ihiẹn nọ ẹrịra!
\v 41 Ụnụ rịhụ e mẹ ihiẹn nẹdi ụnụ e mẹ.”
\p Wẹ nọ sị a, “Ẹnyi ẹlẹ ụmụ ọwụ; Osolobuẹ lẹ enwẹn ẹ sụọ wụ Nẹdi ẹnyi nwọn.”
\p 
\v 42 Jizọsị nọ sị wẹ, “Omẹni Osolobuẹ wụ Nẹdi ụnụ, nkẹ ihiẹn m a sụọ ụnụ, makẹni m gha ebe Osolobuẹ rị bịa; ịya mẹ m nwan rị ebeni. Ẹlẹ mmẹ gi ihiẹn ẹka m bịa, ịya zihẹ m.
\v 43 Kị haịn ụnụ gilẹni a ghọta ihiẹn m rị e ku? Ụnụ arị a ghọta makẹni ụnụ asanị ẹka nabanhan oku m.
\p 
\v 44 Ụnụ wụ nke Ekwensụ nẹdi ụnụ, ihiẹn Ekwensụ nẹdi ụnụ chọ kẹ ụnụ chọ nwan nị ụnụ mẹ. Ogbu-ọchụ k'ọ wụ gha isi mbidọn lala; ọ kwadọntuni ezioku—makẹni ezioku arị imẹ ẹ. Ọ gha a tụ ntụ, o nwọnni ihiẹn ọ wụ ebe ọ rị, makẹni onyẹ ntụ lẹ nẹdi ntụ ile k'ọ wụ.
\v 45 Ya haịn ụnụ gilẹni kweri ihiẹn m rị e ku, makẹni m rị e ku ezioku.
\v 46 Onyẹ imẹ ụnụ sikọ d'a saẹka ghọsị nị m mẹ njọ? O mẹ nwan nị ezioku ke m rị a gwa ụnụ, kị haịn nwan ụnụ gilẹni kweri ihiẹn m rị e ku?
\v 47 Onyẹ ọwụlẹ hụn wụ nke Osolobuẹ e gi oku Osolobuẹ e dọn. Ihiẹn haịn ụnụ gilẹni e gi oku Osolobuẹ e dọn wụ nị ụnụ ẹlẹ nke Osolobuẹ.”
\s1 Jizọsị Lẹ Ebraham
\p 
\v 48 Ndị-ndu ndị Ju nọ za, sị, “Ẹlẹ ezioku kẹ ẹnyi rị e ku nị ị wụ onyẹ Samerịa, nị eje-mmọn rị imẹ i?”
\v 49 Jesu nọ za, sị, “Eje-mmọn a rị imẹ m; m'a gbaye Nẹdi m, kanị ụnụ ara gbaye m.
\v 50 Arị m e mẹ nị wẹ ye m ọghọ; kanị, o nwọnghọ onyẹ rị e mẹ ni wẹ ye m ọghọ—Nẹdi m rọ; ịya a han eṅẹn.
\v 51 Ezioku kẹ m rị a gwa ụnụ, onyẹ ọwụlẹ mẹ ihiẹn m ku ahụnkọ ọnwụn, kaka.”
\p 
\v 52 Ndị Ju nọ sị a, “O wegụọ nwan ẹnyi ẹnya ọhụnma-ọhụnma nị eje-mmọn rị imẹ i! Ebraham lẹ ndị-amụma a nwụnghọ, kanị ị sị, ‘Onyẹ ọwụlẹ hụn dọnmẹ oku m ahụnkọ ọnwụn.’
\v 53 'Yụ ka nẹdi ẹnyi wụ Ebraham hụn nwụnnị lẹ ndị-amụma ndị nwụnzịkwọ ọnwụn? Onyẹ k'i ro nị 'ya kẹ ị wụ?”
\p 
\v 54 Jizọsị nọ za, sị, “M ja enwẹn m mma, ọjịja-mma m wụ ihiẹn mmaka. Onyẹ hụn a ja m mma wụ Nẹdi m, hụn ụnụ sị nị 'ya wụ Osolobuẹ ụnụ,
\v 55 bụ ụnụ amarịn a, kalẹ a marịnghọ m'a. M sị n'a marịn m'a, m jẹnkọ d'a wụ onyẹ ntụ kẹ ụnụ; kanị a marịnghọ m'a; m'e mẹ ihiẹn o ku.
\v 56 Nẹdi ụnụ kanị wụ Ebraham ghọghọ n'o jẹnkọ d'a hụn ogẹn m; ọ hụn a, ẹfọ nọ sụọ a ụsụọ.”
\p 
\v 57 'Ya ndị Ju nọ sị a, “Y'e ke ru ahụa iri-kwasị-ọgụnnaị, y'a hụnọlẹ Ebraham?”
\p 
\v 58 Jesu nọ sị wẹ, “Ezioku kẹ m rị a gwa ụnụ, nị wẹ d'a mụ Ebraham, m rị arị!”
\p 
\v 59 'Ya wẹ nọ tụtụrụ ọmụma nị wẹ ma a, kanị Jesu nọ warị, gha imẹ Ụlọ-nsọ pụ.
\c 9
\cl Isi Nke Itenẹi
\s1 Jizọsị A Zụọ Okẹnnyẹ Wẹ Mụ Ẹnya-ishi
\p 
\v 1 Ogẹn Jizọsị gi ghafekọ, ọ nọ hụn onyẹ ẹnya kpu-ishi kete w'a mụl'a.
\v 2 Ụmụ-azụụn a nọ jụ a, sị, “Onyẹ-nkuzi, onyẹ mẹ njọ hụn wẹ gi mụ okẹnnyẹni ẹnya-ishi, ịya lẹ enwẹn ra ndị mụn'a?”
\v 3 Jesu nọ za, sị, “Ẹlẹni okẹnnyẹni mọbụ ndị mụn'a mẹ njọ, kanị wẹ mụ a ẹnya-ishi kẹni ikẹn Osolobuẹ hụn ụzọ pụha ifọn imẹ ndụn a.
\v 4 Ẹnyi sikọ d'a gha a rụn ọrụn onyẹ hụn zihẹ ni m ebe eki kelẹni gi, makẹni, ọhị gba, o nwọnni onyẹ jẹnkọ d'a saẹka rụn ọrụn.
\v 5 Hụnnị m rị imẹ ụwa, mmẹ wụ ukpẹ ụwa.”
\p 
\v 6 Ogẹn o gi kugụụ ihiẹnni, ọ nọ jụ ẹsọn tọ alị, gi ẹsọn hụ mẹmẹ ụrụa, gi ẹ te onyẹ ẹnya-ishi hụ ẹnya.
\v 7 Ọ nọ sị a, “Jẹnmẹ d'e fin ihun imẹ mirin Silụam.” (Alị ẹfannị wụ “E zijẹngụọ.”) Ọ nọ jẹn d'e fin ihun ẹ, ọ nọ leghama ụzọ, lụaha.
\v 8 Ndị nọchimẹn'ẹ lẹ ndị marịn n'ọ te rịọ ụrịọ hụ a sị, “Ọnwan ẹlẹ onyẹ hụ a nọdị alị a rịọ ụrịọ?”
\v 9 Ndị hụ imẹ wẹ hụ a sị, “Ịya rọ.” Ndị ọzọ sị, “Mba, ẹlẹ ya; kanị o yi ẹ eyi.”
\p Kanị 'ya nwẹn nọ sị, “Ẹghẹẹ, mmẹ wụ okẹnnyẹ hụ.”
\v 10 Wẹ hụ a jụ a, a jụdọnzi, a sị, “Nanị k'i dọn nwan leghama ụzọ?”
\v 11 Ọ nọ sị, “Okẹnnyẹ hụ w'a kpọ Jizọsị/Jesu mẹmẹ ụrụa gi ẹ te m ẹnya, ọ nọ sị m, ‘Jẹn Silụam d'e fin ihun.’ 'Ya m nọ jẹnmẹ d'e fin ihun, m nọ leghama ụzọ!”
\v 12 Wẹ nọ jụ a, sị, “Elebe k'ọ rị?” Ọ nọ sị, “Amarịn m.”
\s1 Ndị Itu-Farisi E Leban Nzụọrị Hụ Ẹnya
\p 
\v 13 Wẹ nọ weri onyẹ hụ ẹnya te kpu-ishi jẹnni ndị Itu-Farisi.
\v 14 (Ụhụọhịn Izu-ikẹn kẹ Jesu mẹmẹ ụrụa gi ẹ shịapụ a ẹnya.)
\v 15 'Ya ndị Itu-Farisi nọ jụma a k'ọ dọn leghama ụzọ. Ọ nọ sị wẹ, “O bu ụrụa che m ẹnya, e fin m ihun m—e leghamagụọ m nwan ụzọ.”
\v 16 Ndị hụ imẹ ndị Itu-Farisi nọ sị, “Okẹnnyẹni ẹlẹ nke Osolobuẹ makẹni ọ rịnị e dọnmẹ iwu Izu-ikẹn.” Ndị ọzọ sị, “Nanị kẹ onyẹ-njọ dọn saẹka a rụn ọrụn-atụmẹnya ndịnị?” Wẹ nọ kebe.
\v 17 Wẹ nọ sịzị onyẹ ẹnya-ishi hụ, “K'i nwọn y'e ku banyen'ẹ, ebe o mẹ ni 'ya shịapụ ị ẹnya?” Ọ nọ sị, “Ọ wụ onyẹ-amụma.”
\p 
\v 18 Ndị-ndu ndị Ju e te kwerini nị ẹnya te kpu ẹ ishi d'e ru n'a kpọ wẹ ndị mụn'a.
\v 19 Wẹ nọ jụ ndị mụn'a, sị, “Ọnwan wụ nwa ụnụ hụn ụnụ sị nị ụnụ mụ a ẹnya-mpịn? Nanị k'o dọn nwan leghama ụzọ?”
\v 20 Ndị mụn'a nọ za, sị, “Ẹnyi a marịnghọ nị ọnwan wụ nwa ẹnyi; nị ẹnyi mụ a ẹnya-mpịn.
\v 21 Kanị, ẹnyi amarịn k'o dọn nwan leghama ụzọ mọbụ onyẹ shịapụ a ẹnya. O rugụọ ogo; jụn'a. 'Ya sikọ d'e ku ọnụ a.”
\v 22 (Ndị mụ n'a ku ẹrịra makẹlẹ egun ndị-ndu ndị Ju rị a tụ wẹ. Makẹni, ndị-ndu ndị Ju e kwerigbamaọlẹ nị onyẹ hụn jẹnkọ d'a sị nị Jesu wụ Kristi, Onyẹ Hụ Osolobuẹ Tumẹ, a chụpụ w'a imẹ ụlọ-ofufe.
\v 23 'Ya haịn ndị mụn'a gi sị, “O rugụọ ogo; jụn'a.”)
\p 
\v 24 'Ya wẹ nọ kpọzị okẹnnyẹ hụ ẹnya te kpu ishi, jụmazị a ajụjụ nke mgbe ẹbụọ, sị a, “Ku ezioku n'i ye Osolobuẹ ọghọ! Ẹnyi a marịnghọ nị okẹnnyẹni wụ onyẹ-njọ.”
\v 25 Ọ nọ za, sị, “Amarịn m omẹni ọ wụ onyẹ-njọ mọbụ ẹlẹ onyẹ-njọ. Kanị ihiẹn ohu m marịn wụ nị ẹnya te kpu m ishi, kalẹ, e leghamagụọ m nwan ụzọ!”
\v 26 Ya wẹ nọ sị a, “K'o mẹ i? Nanị k'o dọn shịapụ ị ẹnya?”
\v 27 Ọ nọ sị wẹ, “A gwagụọ m ụnụ, kanị ụnụ egini ẹ dọn; kị haịn ụnụ gi a chọ nị ụnụ nụzị a? Ụnụ chọzikwọ nị ụnụ wụrụ ụmụ-azụụn a?”
\p 
\v 28 Ya wẹ nọ kpọma a iyi, sị, “Nwa-azụụn a k'ị wụ, kanị ẹnyi nwẹn wụ ụmụ-azụụn Mozizi.
\v 29 Ẹnyi a marịnghọ nị Osolobuẹ gwa Mozizi oku, kanị nke okẹnnyẹni, ẹnyi amarịndẹ ebe ọ gha bịa!”
\v 30 Okẹnnyẹ hụ nọ za, sị, “Ọnwan wụ ihiẹn a tụ ẹnya! Ụnụ amarịn ebe ọ gha bịa, bụ ọ shịapụ m ẹnya.
\v 31 Ẹnyi a marịnghọ nị Osolobuẹ ara gọn onyẹ-njọ ntịn, kanị o gọn onyẹ hụn e fe n'ẹ lẹ onyẹ hụn e mẹ uche ẹ ntịn.
\v 32 Kete ụwa e bidọnlẹ, anụtuni wẹ nị onyẹ ọwụlẹ shịapụ ẹnya onyẹ wẹ mụ ẹnya-mpịn.
\v 33 Ọwụlẹ okẹnnyẹni ẹlẹ nke Osolobuẹ, o ke sa ẹka mẹ ihiẹn ọwụlẹ.”
\p 
\v 34 Wẹ nọ za a, sị, “Imẹ njọ kẹ wẹ nọchanrịn mụ ị; ị rị nwan a chọ nị kuzi ẹnyi?!” Wẹ nọ chụpụ a imẹ ụlọ-ofufe.
\s1 Ẹnya-ishi Imẹ-mmọn
\p 
\v 35 Ogẹn Jizọsị gi nụ nị a chụpụgụọ w'a, ọ hụn a, ọ nọ sị a, “Y'e kwerighọ nị Nwa nke Ịhịan?”
\p 
\v 36 Ọ nọ za, sị, “Onyẹ k'ọ wụ di-ọkpa? Gwa m, kẹni m hụn ụzọ kweri n'ẹ!”
\p 
\v 37 Jizọsị nọ sị a, “Y'a hụngụọ a—onyẹ hụn rị e du i e ku oku rọ.”
\p 
\v 38 Ọ nọ sị, “Di-nwọnni-ẹnyi, e kwerighọ m.” Ọ nọ sekpu alị, fe ẹ.
\p 
\v 39 Jesu nọ sị, “M bịa ụwanị d'a han eṅẹn, kẹni ndị ẹnya-ishi leghama ụzọ, ndị hụn e legha ụzọ a wụrụ ndị ẹnya-ishi.”
\p 
\v 40 Ndị Itu-Farisi nọkunmẹ n'ẹ a nụ ihiẹnni o ku, wẹ nọ jụ a, sị, “Ẹnyi wụzịkwọ ndị ẹnya-ishi?”
\p 
\v 41 Jizọsị nọ za wẹ, sị, “Omẹni ụnụ wụ ndị ẹnya-mpịn, wẹ e ke sị nị ụnụ mẹ njọ; kalẹ, ebe ụnụ sị nị ụnụ hụ e legha ụzọ, njọ ụnụ hụkwọnị ụnụ.”
\c 10
\cl Isi Nke Iri
\s1 Ilu Jesu Gi Ezigbo Onyẹ-ndu Atụnrụn Ta
\p 
\v 1 “Ezioku kẹ m rị a gwa ụnụ, onyẹ ọwụlẹ hụn ghalẹni ọnụmụzọ banye imẹ ụlọ-atụnrụn, kanị ọ gha ụzọ ọzọ nyinban, onyẹ ahụn wụ onyẹ-ohin lẹ onyẹ e chekin ịhịan ụzọ a napụ a ihiẹn ẹ. \fig Igunrun atụnrụn lẹ onyẹ-ndu atụnrụn|src="lb00014b.jpg" size="span" loc="JHN 10" copy="Horace Knowles; The British & Foreign Bible Society" ref="10.1-5"\fig*
\v 2 Onyẹ hụ gha ọnụmụzọ banye, 'ya wụ onyẹ-ndu atụnrụn ndị hụ.
\v 3 Ịya kẹ onyẹ nche a kpọpụ nị ụzọ; atụnrụn ndị hụ e gọn ntịn olu ẹ. Ọ kpọ atụnrụn a ẹfan, o dupụha wẹ.
\v 4 O wepụhagụụ wẹ ile wụ ndị nke ẹ, o buruni wẹ ụzọ; atụnrụn ndị hụ e sọn ẹ makẹni wẹ marịn olu ẹ.
\v 5 Esọnkọ wẹ onyẹ wẹ marịnlẹni, kama, w'a gban'a ọsọ, makẹni amarịn wẹ olu ẹ.”
\p 
\v 6 Jizọsị gi iluni gwa wẹ oku, kanị a ghọtanị wẹ.
\s1 Jizọsị Wụ Ezigbo Onyẹ-ndu Atụnrụn Hụ
\p 
\v 7 'Ya Jizọsị nọzị sị wẹ, “Ezioku kẹ m rị a gwa ụnụ, mmẹ wụ ọnụmụzọ atụnrụn gha a banye.
\v 8 Ndị ọzọ ile bu m ụzọ bịa wụ ndị ohin lẹ ndị e chekin ịhịan a napụ a ihiẹn ẹ; kanị atụnrụn ndị hụ egọnni wẹ ntịn.
\v 9 Mmẹ wụ ọnụmụzọ. Onyẹ ọwụlẹ hụn gha m banye sikọ d'e nwọn nzụọpụha; o jẹnkọ d'a gha e jẹn, a lụa, a hụnsọnmẹ ẹfịfịa o sikọ d'e ri.
\v 10 Onyẹ ohin ara bịa wezụka n'ọ bịa n'o zun, n'o gbu lẹ n'o tikpọ, kanị m bịa kẹni wẹ nwọn ndụn, nwọn ẹ mmagi-mmagi.”
\p 
\v 11 “Mmẹ wụ ezigbo onyẹ-ndu atụnrụn. Ezigbo onyẹ-ndu atụnrụn gi ufiri atụnrụn e ye ndụn a.
\v 12 Nke onyẹ wẹ wehụ ọrụn, hụn wụlẹni onyẹ-ndu atụnrụn ndị hụ, hụn atụnrụn ndị ahụn wụlẹni nke ẹ, ọ hụn ẹwọrọ\f + \fr 10:12 \fl Griki: \ft wofu\f* k'ọ lala, ọ la atụnrụn ndị hụ tọ, gbapụ—ẹwọrọ hụ nwụnrụn wẹ, ọ chụzịza wẹ.
\v 13 Onyẹ wẹ we ọrụn a gbapụ makẹni ọ wụhụ onyẹ wẹ we ọrụn, ẹlẹ ịya nwọn atụnrụn, o nwọnni ihiẹn ọ kpọ atụnrụn ndị hụ.
\p 
\v 14 Mmẹ wụ ezigbo onyẹ-ndu atụnrụn. A marịnghọ m atụnrụn m; atụnrụn m a marịnghọzị m—
\v 15 rịkẹ kẹ Nẹdi m dọn marịn m, a marịn m Nẹdi m. M rị e ye ndụn m makẹ ifiri atụnrụn.
\v 16 M nwọn atụnrụn ndị ọzọ rịlẹni imẹ igunrunni. M jẹnkọ d'e wẹhẹzi wẹ. Wẹ jẹnkọ d'e gọn ntịn olu m, kẹni ọ wụrụ igunrun ohu lẹ onyẹ-ndu ohu.
\v 17 Ihiẹn m sụọ Nẹdi m makẹni m rị e we ndụn m e ye kẹni m werizi ẹ.
\v 18 O nwọnni onyẹ rị a napụ m ndụn m; kama, mmẹ rị e gi uche m e ye ẹ. Ọ rị m ẹka iyen'ẹ; ọ rịzị m ẹka iwerizin'ẹ. Nẹdi m sị m mẹ ihiẹnni.”
\p 
\v 19 Ya kẹ ndị-ndu ndị Ju nọ kebezi makẹ ihiẹn ndịnị ọ rị e ku.
\v 20 Ndị bu ọda imẹ wẹ hụ a sị, “Eje-mmọn rị imẹ ẹ; ẹra rị a pụ a! Kẹ ẹnyi rị e gọnn'ẹ ntịn?”
\v 21 Ndị ọzọ hụ a sị, “Oku ndịnị ẹlẹ oku onyẹ eje-mmọn rị imẹ ẹ. Nị eje-mmọn saẹka shịapụ ẹnya onyẹ ẹnya-ishi?”
\s1 A Ju Wẹ Jesu
\p 
\v 22 Ogẹn hụ wụ ogẹn oyi. Wẹ rị imẹ Jerusalẹm, e mẹ Mmẹmmẹ wẹ gi e dọn Ụlọ-nsọ nsọ\f + \fr 10:22 \ft Mmẹmmẹ Hanụka\f*,
\v 23 Jizọsị ghakọ ẹtụ-ụlọ Solomọnụ hụn rị Ụlọ-nsọ,
\v 24 'ya ndị-ndu ndị-Ju nọ fihunmẹ ẹ, sị a, “Elee ogẹn kẹ y'e kọnmẹru ẹnyi obi elu? Omẹni 'yụ wụ Kraịstị, Onyẹ Hụ Osolobuẹ Tumẹ, gwapụ ẹnyi?”
\p 
\v 25 Jizọsị nọ za, sị, “A gwagụọ m ụnụ, kanị ụnụ ekwerini. Ọrụn-atụmẹnya ndị m gi ẹfan Nẹdi m a rụn wụ ọshẹri m;
\v 26 kalẹ ụnụ ekwerini makẹlẹ ụnụ ẹlẹ atụnrụn m.
\v 27 Atụnrụn m a marịnghọ olu m; a marịnghọ m wẹ; w'e sọn m esọn.
\v 28 Mm'e ye wẹ ndụn itẹbitẹ; alakọ wẹ ntikpọ. O nwọnni onyẹ sikọ d'a napụ nị m wẹ.
\v 29 Nẹdi m hụn we wẹ che m ẹka ka ihiẹn ile; o nwọnni onyẹ jẹnkọ d'e ri-ẹka wepụ wẹ ẹka Nẹdi m.”
\p 
\v 30 “Mmẹ lẹ Nẹdi m wụ ohu.”
\p 
\v 31 Ndị-ndu ndị-Ju nọ burusọnmẹzi ọmụma, chọ nị wẹ magbu ẹ.
\v 32 Jizọsị nọ za wẹ, sị, “A rụnghọsịgụọ m ụnụ ọrụn-ọma bu ọda gha ẹka Nẹdi m bịa: elee hụn imẹ wẹ kẹ ụnụ jẹnkọ d'e gini ufiri ẹ ma m ọmụma?”
\v 33 Ndị-ndu ndị-Ju nọ za, sị, “Ẹlẹ ọrụn rị mma kẹ ẹnyi k'a ma n'ị ọmụma, kanị, arụ i ku. Makẹni ịhịan mmaka k'ị wụ bụ ị rị e weri enwẹn i n'ị wụ Osolobuẹ.”
\v 34 Jesu nọ za wẹ, sị, “Ẹlẹ wẹ de ẹ imẹ Iwu ụnụ, sị, ‘M sị nị ụnụ wụ chi\f + \fr 10:34 \fl mọbụ: \ft Ụnụ nọ kẹ Osolobuẹ (Ẹbụ-ọma 82.6)\f*.’
\v 35 Ebe o mẹ ni w'a ra s'ẹka gbehutọ oku rị imẹ Ẹhụhụọ-nsọ, omẹni ọ kpọ ndị hụ wẹ zijẹnni oku Osolobuẹ mbụ ‘chi’, ‘ndị rị kẹ Chuku’,
\v 36 nanị kẹ ụnụ gi rị a sị nị, mmẹ, hụn Chuku-Nẹdi dọn nsọ zihẹ imẹ ụwa, rị e ku arụ, makẹni m sị, ‘M wụ Nwa Osolobuẹ’?
\v 37 Omẹlẹ arị m a rụn ihiẹn Nẹdi m a rụn, egilẹ ni ihiẹn m ku dọn.
\v 38 Kanị omẹni m hụ a rụn wẹ, ọsụọn'a nị ụnụ egini ihiẹn m ku dọn, gi ni ọrụn-atụmẹnya ndị m rụn dọn, kẹni o we ụnụ ẹnya nị Chuku-Nẹdi rị imẹ m, mmẹ nwẹn rị imẹ Chuku-Nẹdi.”
\v 39 'Ya wẹ nọ chọzị nị wẹ nwụnrụn a, kanị ọ nọ gbụnahịn wẹ.
\p 
\v 40 Jizọsị nọ kin-azụụn, fetu Iyi Jọdanị, si ebẹhụ Jọnụ nọ mẹ mirin-Chuku ogẹn mbụ, ọ nọ nọdị ebẹhụ.
\v 41 Ndị bu ọda nọ bịa d'e kunrun ẹ, wẹ hụ a sị, “Jọnụ a rụnnị ọrụn-atụmẹnya kaka akpụ-ohu, kanị, ihiẹn ile Jọnụ ku banyeni okẹnnyẹni wụ ezioku.”
\v 42 Ndị bu ọda nọ kwerini Jesu ebahụn.
\c 11
\cl Isi Nke Mmanaị
\s1 Ọnwụn Lazarọsị
\p 
\v 1 O nwọn okẹnnyẹ ohu w'a kpọ Lazarọsị hụn emu rị a kụ. Onyẹ Bẹtanị, obodo Meri lẹ nwẹnẹ ẹ okpoho wụ Mata rọ.
\v 2 Merini wụ hụn hu udẹn e shin ọhụnma ye Di-nwọnni-ẹnyi wụ Jesu ụkụ, gi ntutu ẹ fikọrị a; nwẹnẹ ẹ wụ Lazarọsị kẹ emu rị nwan a kụ.
\v 3 'Ya umunẹ-ikpoho ẹbụọnị nọ zi ozi jẹnni Jizọsị, sị, “Di-nwọnni-ẹnyi, emu rị a kụ onyẹ ahụn ihiẹn ẹ a sụọ ị.”
\p 
\v 4 Kanị, ogẹn Jizọsị gi nụ ihiẹnni, ọ nọ sị, “Emuni ẹlẹ nke ọnwụn, kama, o k'e wẹhẹni Osolobuẹ ọghọ; o jẹnkọ d'a wụ ụzọ Nwa Osolobuẹ jẹnkọ d'e gi nwọnhẹn ọghọ.”
\v 5 (Ihiẹn Mata lẹ nwẹnẹ-ẹ-okpoho wụ Meri lẹzi Lazarọsị a sụọkwọ Jesu asụọ.)
\p 
\v 6 Ọ nụgụụ nị emu rị a kụ Lazarọsị, kugụụ ihiẹnni o ku, ọ nọ nọdịzị ebẹhụ ọ rị akpụ-ụhụọhịn ẹbụọ.
\p 
\v 7 Omẹgụụ, ọ nọ nwan sị ụmụ-azụụn a, “Nị ẹnyi kin ni azụụn si Judia.”
\v 8 Ụmụ-azụụn a nọ sị a, “Onyẹ-nkuzi, o ke te ndị Ju chọ nị wẹ ma ị ọmụma ebẹhụ, ị chọkọ n'ị kinzi ebẹhụ?”
\v 9 Jesu nọ sị, “Ẹlẹ mgbahunmẹ ọkụlọkụ mmẹbụọ kẹ anwụn gi a rị elu? Ndị hụn a ghahunmẹ ebe eki rị elu ara kpọgburu, makẹni wẹ gi ukpẹ ụwanị e legha ụzọ.
\v 10 Kanị ndị hụn a ghahunmẹ imẹ ukinkin a kpọgburu akpọgburu, makẹni ukpẹ a rị imẹ wẹ.”
\v 11 Ogẹn o gi kugụụ ihiẹnni, ọ nọzị sị wẹ, “Ụran e buruọlẹ ọwụ ẹnyi wụ Lazarọsị, kalẹ, m jẹnkọ ebẹhụ d'a kpọtiẹn ẹ.”
\p 
\v 12 Ụmụ-azụụn a nọ sị a, “Di-nwọnni-ẹnyi, omẹni ọ rị ụran, o sikọ d'a rị mma.”
\v 13 (Jizọsị gi ẹ e ku ni ọ nwụnhụngụọ, kanị wẹ rị e ro n'ọ rị e ku ụran mmaka.)
\v 14 'Ya Jizọsị nọ gwapụ wẹ, sị, “Lazarọsị a nwụnhụngụọ,
\v 15 kanị, makẹ ufiri ụnụ, ẹfọ rị a sụọ m ụsụọ nị arị m ebahụn, makẹni o k'e mẹ ụnụ kweri. Kanị, bịa nị nwan nị ẹnyi jẹn d'e kunrun ẹ.”
\v 16 Tamọsị (hụn w'a kpọ Ejimẹ) nọ sị ụmụ-azụụn ibe ẹ, “Nị ẹnyi nwẹn jẹnzi, kẹni ẹnyi sọn onyẹ-nkuzi nwụn!”
\s1 Jesu Wụ Onyẹ Hụn E Weli Ndị Nwụnnị
\p 
\v 17 Ogẹn Jizọsị gi ru ebahụn, ọ nọ hụn a nị Lazarọsị a rịọlẹ imẹ ili kete akpụ-ụhụọhịn ẹnọ.
\v 18 Bẹtanị nọkunmẹ Jerusalẹm, ẹgbata wẹ wụ ihiẹn rịkẹ maịlị ẹbụọ.
\v 19 Ndị Ju bu ọda a ghaọlẹ Jerusalẹm bịa d'e kunrun Meri lẹ Mata nị wẹ rọkọ wẹ obi makẹ ọnwụn nwẹnẹ-wẹ-okẹnnyẹ.
\p 
\v 20 Ogẹn Mata gi nụ nị Jizọsị lala, ọ nọ jẹnmẹ d'e kunrun ẹ, kanị Meri nọdị alị imẹ ụlọ.
\v 21 Mata nọ sị Jesu, “Di-nwọnni-ẹnyi, omẹni i te rị ebeni, nwẹnẹ m e ke nwụn.
\v 22 Kanị a marịnghọ m nị kẹ kikẹnni ọ nwụnhụgụụ, Osolobuẹ jẹnkọ d'e ye i ihiẹn ọwụlẹ ị rịọ a.”
\p 
\v 23 Jizọsị nọ sị a, “Nwẹnẹ i jẹnkọ d'a gha ọnwụn lihizi.”
\p 
\v 24 Mata nọ sị a, “A marịnghọ m n'o jẹnkọ d'e lihi ogẹn ndị nwụnnị sikọ d'e gi lihi Ụhụọhịn-ikpazụụn.”
\p 
\v 25 Jizọsị nọ sị a, “Mmẹ wụ onyẹ hụn e weli ndị nwụnnị; mmẹ wụ onyẹ hụn e ye ndụn. Ndị hụn kwerini ni m, ọ sụọ n'a nị wẹ nwụnhụn anwụnhụn, wẹ sikọ d'a rị ndụn;
\v 26 onyẹ ọwụlẹ rị ndụn hụn kwerini ni m anwụnkọ, kaka. Y'e gighọ a dọn?”
\p 
\v 27 Mata nọ za a, sị, “Ẹghẹẹ Di-nwọnni-ẹnyi, e kwerighọ m nị 'yụ wụ Onyẹ Hụ Osolobuẹ Tumẹ, Nwa Osolobuẹ, hụn wẹ rị e lee ẹnya a n'ọ lala imẹ ụwa.”
\s1 Jizọsị Kwan Ẹkwan
\p 
\v 28 Ogẹn Mata gi kugụụ ihiẹnni, ọ nọ kin-azụụn d'a kpọ nwẹnẹ ẹ wụ Meri. Ọ nọ kagwa a, sị, “Onyẹ-nkuzi rị ebeni, ọ rị a kpọ ị.”
\v 29 Ogẹn o gi nụ ihiẹnni, ọ nọ lihi ọtọ ozigbo, jẹn d'e kunrun ẹ.
\v 30 Ogẹn hụ Jesu e ke banye imẹ obodo hụ—echẹn k'ọ rịkwọ ebe Mata nọ kunrun ẹ.
\v 31 Ndị Ju ahụn wẹ lẹ Meri rị imẹ ụlọ rị a rọkọ a obi a hụn Meri k'o lihi ọtọ ozigbo pụ, wẹ nọ sọnmẹ ẹ makẹni wẹ ro n'o jẹnkọ ili hụ d'a kwan ẹkwan.
\p 
\v 32 Ogẹn Meri gi ru ebẹhụ Jizọsị rị, hụn Jizọsị, ọ nọ dann'a alị, sị a, “Di-nwọnni-ẹnyi, omẹni i te rị ebeni, nwẹnẹ m e ke te nwụn!”
\p 
\v 33 Ogẹn Jizọsị gi hụn a k'ọ rị a kwan ẹkwan, hụnzị ndị Ju ndị 'ya lẹ wẹ wị kẹ wẹ rị a kwan, ọ nọ mẹtụ a obi ọda-ọda, fụtụ a.
\p 
\v 34 Ọ nọ sị wẹ, “Elebe kẹ ụnụ liye ẹ?” Wẹ nọ sị a, “Di-nwọnni-ẹnyi, bịa d'e lee ẹ.”
\p 
\v 35 Jizọsị nọ kwan ẹkwan.
\v 36 'Ya ndị Ju ahụn nọ sị, “Euu, lee kẹ ihiẹn ẹ sụọhan a!”
\p 
\v 37 Kanị ndị hụ imẹ wẹ nọ sị, “Onyẹni shịapụ ẹnya onyẹ ẹnya-ishi, o ke sa ẹka gbọndọn okẹnnyẹni anwụnlẹ?”
\s1 Jizọsị A Gha Imẹ Ọnwụn Weli Lazarọsị
\p 
\v 38 O mẹtụkẹnmẹzi Jesu obi, ọ nọ bịa ebe ili hụ rị. Ili hụ wụ okporo hụn wẹ gi ọmụma hi-ogbe nukin ọnụ a.
\v 39 Jizọsị nọ sị, “Nupụ nị ọmụma hụ.”
\p Mata, nwẹnẹ okẹnnyẹ hụ nwụnhụnnị nọ sị a, “Di-nwọnni-ẹnyi, o sikọ d'e shin ọda-ọda, makẹlẹ o mẹọlẹ akpụ-ụhụọhịn ẹnọ wẹ li ẹ.”
\p 
\v 40 Jizọsị nọ sị a, “Agwanị m'ị n'i jẹnkọ d'a hụn kẹ Osolobuẹ hihan ogbe omẹni y'e kwerighọ?”
\p 
\v 41 E nupụ wẹ ọmụma hụ, Jizọsị nọ wesi ẹnya elu, sị, “E kele m'i Baba, makẹni y'a nụgụọ ekpere m,
\v 42 a marịngụọ m nị y'a nụ ekpere m ogẹn ile, kanị ifiri ndịnị rị ebeni kẹ m gi ku ihiẹnni, kẹni wẹ kweri nị 'yụ zihẹ m.”
\v 43 Ogẹn o gi kugụụ ihiẹnni, ọ nọ gi okẹn olu yi oro, sị, “Lazarọsị, pụha!”
\v 44 Okẹnnyẹ nwẹn nwụnnị nọ pụha, ẹkwa wẹ gi li ẹ a fụkpumẹ ẹ: ohu fụkpumẹ ọkụ lẹ ẹka, ohu fụkpumẹzi ẹ ihun. Jizọsị nọ sị wẹ, “Tọpụ n'a n'o jẹnmẹ.” \fig Okẹnnyẹ nwẹn nwụnnị nọ pụha!|src="DN00459b.jpg" size="col" loc="JHN 11" copy="Darwin Dunham; United Bible Societies" ref="11.43-44"\fig*
\s1 E Rini Wẹ Jesu Ngo Kẹni Wẹ Gbu Ẹ
\r (Mat 26.1-5; Mak 14.1-2; Luk 22.1-2)
\p 
\v 45 Ndị bu ọda imẹ ndị Ju ahụn bịa d'a hụn Meri, a hụn ihiẹn ndị Jesu mẹ, wẹ nọ kweri n'ẹ.
\v 46 Kanị ndị hụ imẹ wẹ nọ jẹn d'e kunrun ndị Itu-Farisi, gwa wẹ ihiẹn Jizọsị mẹ.
\v 47 'Ya ndị Itu-Farisi lẹ ndị-isi nchụ-ẹjan nọ kpọ Ọgwa Ndị-isi Nkịkwama, sị, “Kị ẹnyi jẹnkọ nwan d'e mẹ? Lee ni ọrụn-atụmẹnya ile okẹnnyẹni rị a rụn!
\v 48 Omẹni ẹnyi a nị a rụnsọnmẹ ẹnịna, ịhịan ile jẹnkọ d'e kweri n'ẹ; ogẹn hụ, ndị Rom rị a kịnị ẹnyi sikọ d'a bịa d'e mẹ ihiẹn banyen'ẹ, wẹ sikọ d'e tikpọ Ụlọ-nsọ ẹnyi lẹ alị ẹnyi!”
\p 
\v 49 Ya kẹ onyẹ ohu imẹ wẹ ẹfan a wụ Kayafasị, hụn wụ onyẹ-isi nchụ-ẹjan ahụa hụ, nọ sị wẹ, “Ụnụ a marịn ihiẹn kaka!
\v 50 Ụnụ a marịn n'ọ ka ụnụ mma nị onyẹ ohu nwụndọnni ịhịan ile, karị nị ndị alị ẹnyi ile a la iwi?”
\v 51 (Kanị, ezioku rị n'a wụ nị ebe o mẹ ni Kayafasị wụ onyẹ-isi nchụ-ẹjan ahụa hụ, amụma k'o bu ihiẹn hụ—nị Jesu jẹnkọ d'a nwụnnị ndị Ju ọnwụn; bụ ọ marịn nị amụma k'o bu.
\v 52 Ẹlẹdẹ ndị Ju sụọ k'o k'a nwụnnị, kanị, kẹni o gizi ọnwụn a wegbama ndị nke Osolobuẹ ile rịsọnmẹ ebe ile.)
\p 
\v 53 Gha ụhụọhịn hụ jẹnmẹ, ndị-ndu ndị Ju nọ tụma iroro kẹ w'e dọn gbu Jesu.
\v 54 Ufiri ẹ, Jesu akpazịnị ebe ịhịan rị imẹ Judia, kama ọ nọ gha ebẹhụ pụ, shi obodo ohu w'a kpọ Ifrem, hụn rị ẹgbẹrẹ nọkunmẹ atụ—ịya lẹ ụmụ-azụụn a nọ nọdị ebẹhụ.
\p 
\v 55 Ogẹn Mmẹmmẹ-Nghafe e rumẹ, ndị bu ọda nọ ghasọnmẹ alị ọfịa si Jerusalẹm d'e mẹ omẹnalị w'e gi e dọn enwẹn wẹ nsọ, hụn wẹ gi a kwademẹ mmẹmmẹ hụ.
\v 56 Wẹ hụ a chọ Jesu, a jụ ibe wẹ ebẹhụ wẹ wuzo imẹ Ụlọ-nsọ, sị, “K'i ro? Ọ bịakọdẹ mmẹmmẹni ra?”
\v 57 Ogẹn hụ, ndị-isi nchụ-ẹjan lẹ ndị Itu-Farisi e yegụọ wẹ iwu banyeni Jesu: nị ọwụnị onyẹ ọwụlẹ marịn ebe ọ rị, 'ya bịa d'a gwa wẹ, kẹni wẹ hụn ụzọ nwụnrụn a.
\c 12
\cl Isi Nke Mmẹbụọ
\s1 E Hukpu Wẹ Jesu Udẹn
\r (Mat 26.6-13; Mak 14.3-9)
\p 
\v 1 Ogẹn o gi họdụ akp'ọhịn isin nị Mmẹmmẹ-Nghafe ru, Jizọsị nọ jẹn Bẹtanị, iwe Lazarọsị, okẹnnyẹ hụ ọ gha ọnwụn weli.
\v 2 Wẹ nọ shi ni Jesu ihiẹn-oriri ẹnyasị ahụn. Mata hụ e jẹn ozi, e buye wẹ ihiẹn-oriri ahụn; Lazarọsị rị ndị rị e sọn ẹ e ri ihiẹn-oriri.
\p 
\v 3 'Ya kẹ Meri nọ wẹhẹ udẹn e shin ọhụnma ṅanranị wẹ gi osisi nadị mẹmẹ, hụn wẹ gwalẹni. Udẹn hụ k'e jun ihiẹn nọ kẹ ọgọ-nta ohu lẹ nkirishi. Ọ nọ hu ẹ ye Jesu ụkụ, gi ntutu rị a isi e fikọrị a; ishin udẹn hụ nọ kungbama ụlọ hụ ile.
\v 4 Kanị onyẹ ohu imẹ ụmụ-azụụn Jizọsị, 'ya wụ Judasị nwa Iskarọtụ (hụn jẹnkọ d'e re n'ẹ), nọ sị,
\v 5 “Kị haịn wẹ gilẹni re udẹnni, we egho ẹ ye ndị igbẹnnyẹ? O rugụọ ihiẹn rịkẹ egho-ọrụn akp'ọhịn ọgụn-mmisẹn.”
\v 6 (Ẹlẹ ni ndị igbẹnnyẹ rị a mkpa haịn o gi ku ihiẹnni. Kanị, onyẹ-ohin k'ọ wụ: ịya nwẹ e dọnmẹ ni Jesu wẹ egho; o werisọnmẹ egho wẹ ye ẹ dọnmẹ.)
\p 
\v 7 Kanị Jizọsị nọ sị, “Hatu n'ẹ, n'o gi ẹ kwademẹ olili m.
\p 
\v 8 Ụnụ lẹ ndị igbẹnnyẹ rị ogẹn ile, kanị mmẹ nwẹn esọnkọ ụnụ nọdị ogẹn ile.”
\s1 E Rini Wẹ Lazarọsị Ngo
\p 
\v 9 Ndị Ju bu ọda a nụ nị Jesu rị Bẹtanị, 'ya wẹ nọ bịa ebahụn. Kanị, ẹlẹ ifiri Jesu sụọ kẹ wẹ gi bịa, kanị, wẹ chọzị nị wẹ hụn Lazarọsị, hụn ọ gha ọnwụn weli.
\v 10 'Ya ndị-isi nchụ-ẹjan nọ rimẹni Lazarọsị ngo ni wẹ gbuzi ya nwẹn,
\v 11 makẹlẹ ufiri ẹ kẹ ndị Ju bu ọda gi rị a jụ nke wẹ a tọ, e kwerini Jesu.
\s1 Onyẹ Mmẹri A Banhan Jerusalẹm
\r (Mat 21.1-11; Mak 11.1-11; Luk 19.28-40)
\p 
\v 12 Ogẹn eki gi fọn, igunrun hi-ogbe hụn bịa Mmẹmmẹ-Nghafe nọ nụ nị Jesu lala Jerusalẹm.
\v 13 'Ya wẹ nọ werisọnmẹ iguru, jẹn d'e kunrun ẹ. Ya wẹ nọ yimẹ,
\q1 “Ja nị Osolobuẹ mma;
\q1 onyẹ ahụn gi ẹfan Di-nwọnni-ẹnyi bịa
\q2 wụ onyẹ Chuku gọzi agọzi!
\q1 Ẹghẹẹ,
\q1 Eze Izrẹlụ
\q2 wụ onyẹ Chuku gọzi agọzi.”
\p 
\v 14 Jesu nọ chọrị nwa jaki, nyinrin ẹ jẹnmẹ, nọkẹ kẹ Ẹkụkwọ-nsọ dọn ku—Ẹhụhụọ-nsọ sị,
\q1 
\v 15 “Obodo Zayọnụ, a tụlẹ egun!
\q1 Lee Eze i k'ọ lala,
\q1 ọ rị elu nwa jaki.”
\p 
\v 16 Ụmụ-azụụn Jesu a ghọtanị ihiẹnni ogẹn hụ, kanị, ogẹn Jesu gi nwẹringụụ ọghọ, wẹ nọ nyanhan nị Ẹkụkwọ-nsọ ku ihiẹnni banyen'ẹ, nyanhanzịkwọ nị wẹ mẹ n'ẹ ihiẹn ndịnị.
\p 
\v 17 Ndị rị igunrun ahụn wẹ lẹ Jizọsị wị ogẹn o gi gha ili kpọpụha Lazarọsị, ogẹn o gi gha imẹ ọnwụn weli ẹ, hụ a gwasọnmẹ ndị ọzọ ihiẹn mẹni.
\v 18 'Ya haịn igunrun hụ gi bịa d'e kunrun ẹ—makẹni wẹ nụ n'ọ rụn ọrụn-atụmẹnyanị.
\p 
\v 19 'Ya ndị Itu-Farisi nọ sị ibe wẹ, “Ụnụ hụ a hụn a?! Ihiẹn ile ẹnyi rị e mẹ a rị a danye kaka! Lee nwan, ụwa ile e sọnmẹgụọ a!”
\s1 Ndị Griki Hụn Chọ Nị Wẹ Hụn Jesu
\p 
\v 20 Ogẹn hụ, o nwẹ ndị Griki hụn rị ndị jẹn Jerusalẹm d'e fe ofufe ogẹn mmẹmmẹ hụ.
\v 21 Wẹ nọ jẹn d'e kunrun Filipu hụn wụ onyẹ obodo Bẹsaịda rị imẹ Galili. Wẹ nọ sị a, “Di-ọkpa, ẹnyi chọ nị ẹnyi hụn Jesu.”
\v 22 Filipu nọ jẹn d'a gwa Andụrụ, ya wẹ ẹbụbụọ nọ wịrị jẹnmẹ d'a gwa Jesu.
\p 
\v 23 Jesu nọ za wẹ, sị, “Ogẹn e rugụọ hụn w'e gi ye Nwa nke Ịhịan ọghọ.
\v 24 M rị a gwa ụnụ ezioku, akpụrụ-ọka nọdị nke ẹ akarịkọ ohu sụọ wezụka n'ọ dan alị nwụnhụn. Ọ nwụnhụn, 'ya wụ ọ mị mkpụrụ ọda-ọda.
\v 25 Nke ndị hụ ndụn wẹ ka wẹ mkpa, ndụn wẹ sikọ d'e tuhunahịn wẹ; kanị, nke ndị hụ o mẹ ni ndụn wẹ akanị wẹ mkpa elu ụwanị, ndụn wẹ k'a rịnị wẹ—e nwẹ wẹ ndụn itẹbitẹ.
\v 26 Onyẹ ọwụlẹ hụn chọ n'ọ gba nị m odibo jẹnkọ d'e sọnrịrị m, kẹni odibo m hụn ụzọ sọn m nọdị ebe m rị; Nẹdi m jẹnkọ d'e ye onyẹ ọwụlẹ gba nị m odibo ọghọ.”
\s1 Jesu E Ku Banyeni Ọnwụn A
\p 
\v 27 “Obi rị nwan e feri m. Kẹ m k'e ku nwan? Nị m sị, ‘Baba, anịlẹ ogẹn-afụnfụnnị bịa nị m’? Mba! Makẹni, 'ya haịn m gi rị ebeni—m bịa kẹni m hụn ụzọ ta afụnfụnnị.
\v 28 Baba, ye ẹfan ị ọghọ!” 'Ya kẹ olu nọ gha elu-igwee sị, “E yegụọlẹ m ẹfan m ọghọ. M jẹnkọ d'e yezi ẹ ọghọ.”
\p 
\v 29 Igunrun ahụn rị ebẹhụ nụ olu hụ. Ndị hụ sị akpabọ rọ, ndị ọzọ sị mmọn-ozi a gwaọl'a oku!
\p 
\v 30 Kanị, Jesu nọ sị wẹ, “Ẹlẹ ufiri m kẹ olu hụ gi bịa, kalẹ ufiri ụnụ.
\v 31 Kikẹnni kẹ wẹ jẹnkọ d'a ma ụwanị ikpe; kikẹnni kẹ wẹ sikọ d'a chụpụ onyẹ hụn a kị ụwanị.
\v 32 Mmẹ nwẹn, ogẹn wẹ k'e gi gha alị wesi m enu, m jẹnkọ d'a dọhanị enwẹn m ịhịan ile.”
\v 33 (O gi ihiẹnni o ku ghọsị ụdị ọnwụn o jẹnkọ d'a nwụn.)
\p 
\v 34 Igunrun hụ nọ sị a, “Iwu ẹnyi gwa ẹnyi nị Kraịstị, Onyẹ Hụ Osolobuẹ Tumẹ, jẹnkọ d'a rị ndụn jẹnrin ejẹn. Kị ị rị a sịnị nị wẹ sikọ d'e wesi Nwa nke Ịhịan elu? Onyẹ wụ Nwa nke Ịhịannị?”
\p 
\v 35 Jesu nọ sị wẹ, “Ukpẹ jẹnkọ d'e sọnzi ụnụ nọdịzị ẹkẹrẹ sụọ. A gha nị ogẹnni ụnụ nwọn ukpẹ, amamgbe ishi e kunrun ụnụ. Makẹni, onyẹ hụn a gha imẹ ishi, imẹ mkpọkịkị, amarịnkọ ebe o jẹnkọ.
\v 36 'Ya wụ, kwerini ni ukpẹ ogẹnni ụnụ nwọn ukpẹ, kẹni ụnụ hụn ụzọ wụrụ ụmụ ukpẹ.”
\p Ogẹn Jesu gi kugụụ ihiẹnni, ọ nọ gha ebe wẹ rị pụ d'a warị, ahụnzịnị w'a.
\s1 Ndị Hụ Ekwerini Ni Jesu
\p 
\v 37 Ọsụọn'a nị Jesu rụnchanrịn ọrụn-atụmẹnya bu ọda id'ẹnya wẹ, ekwerini ni wẹ ẹ,
\v 38 kẹni ihiẹn onyẹ-amụma wụ Azaya ku hụn ụzọ mẹzu: Azaya sị,
\q1 “Di-nwọnni-ẹnyi, onyẹ kweri ozi ẹnyi zi?
\q1 Onyẹ kẹ Di-nwọnni-ẹnyi ghọsị ikẹn ẹ?”
\p 
\v 39 Asanị wẹ ẹka kweri, makẹni, rịkẹ kẹ Azaya dọnzi ku ẹ,
\q1 
\v 40 “Chuku e mẹgụọ ẹnya kpu wẹ ishi,
\q1 tikin obi wẹ—
\q1 amamgbe wẹ e gi ẹnya wẹ legha ụzọ,
\q1 gi obi wẹ ghọta,
\q1 e gbehutọ wẹ d'e kunrun m;
\q1 a zụọ m wẹ—'ya kẹ Chuku ku.”
\p 
\v 41 Azaya ku ihiẹnni makẹni ọ hụn ọghọ Jizọsị, ọ nọ ku banyeni ọghọ a.
\v 42 K'osilẹrị, ndị bu ọda hụn rịdẹ imẹ ndị-ndu wẹ kwerini Jesu ekweri. Kanị, egun ndị Itu-Farisi anịnị wẹ ku ẹ ebe ịhịan rị, amamgbe wẹ a chụpụ wẹ imẹ ụlọ-ofufe.
\p 
\v 43 “Ọjịja-mma ịhịan k'a ja wẹ ka wẹ a sụọ karị hụn Osolobuẹ k'a ja wẹ.”
\s1 Ihiẹn Jesu Ku Kẹ Wẹ K'e Gi Han Eṅẹn
\p 
\v 44 Jesu nọ weshi olu elu, sị, “Onyẹ ọwụlẹ hụn kwerini ni m ẹlẹ mmẹ k'o kwerini, kanị onyẹ hụn zihẹni m k'o kwerini.
\v 45 Onyẹ ọwụlẹ hụn nị m, a hụngụọ onyẹ hụn zihẹ ni m.
\v 46 M banhan imẹ ụwa d'a wụ ukpẹ, amamgbe ndị hụn kwerini ni m a tọ imẹ ishi, imẹ mkpọkịkị.
\v 47 Onyẹ nụ ihiẹn m ku bụ o mẹ n'ẹ, amakọ m'a ikpe. Makẹni, abịanị m d'a ma ụwa ikpe, kama, m bịa d'a zụọpụha a.
\v 48 Onyẹ hụn jụ nị m, hụn kwerilẹni oku m, nwọn onyẹ k'a ma a ikpe: ihiẹn hụn m ku, ya jẹnkọ d'a ma a ikpe Ụhụọhịn-ikpazụụn.
\v 49 Makẹni, ẹlẹ m gi uche m e ku, kanị Nẹdi m hụn zihẹni m ye m iwu ihiẹn m sikọ d'a sị lẹ ihiẹn m sikọ d'e ku.
\v 50 A marịnghọ m nị iwu ẹ e ye ndụn itẹbitẹ. 'Ya wụ, ihiẹn m'e ku wụchanrịn ihiẹn Chuku-Nẹdi sị m ku.”
\c 13
\cl Isi Nke Mmẹtọ
\s1 Jesu Chanchan Ụmụ-azụụn A Ụkụ
\p 
\v 1 Nị Mmẹmmẹ-Nghafe d'e ru, Jesu a marịngụọ nị ogẹn ẹ e rugụọ hụn o gi hapụ ụwanị, buru Nẹdi ẹ. Ebe o nwẹ ihiẹn-ọsụsụọ ndị nke ẹ rị imẹ ụwa, ọ nọ nwan ghọsịchanrịn wẹ ya wụ ihiẹn-ọsụsụọ d'e ru isi ẹ.
\p 
\v 2 Ekwensụ e bugụọlẹ a che imẹ obi Judasị nwa Saịmọnụ Iskarọtụ n'ọ re ẹ.
\p Ogẹn wẹ gi rị e ri ihiẹn-oriri ẹnyasị,
\v 3 Jizọsị a marịngụọ nị Chuku-Nẹdi e weọlẹ ihiẹn ile che ẹ ẹka, n'ọ gha ebe Osolobuẹ rị bịa lẹ n'o laburukọ Osolobuẹ:
\v 4 ọ nọ gha ebe ọ rị e ri ihiẹn-oriri lihi ọtọ, yipụ ẹkwa o yiye elu ẹ, jeri tọwẹlụ wẹ gi e finchan ẹhụ.
\v 5 Ọ nọ hu mirin ye imẹ afẹrẹ, chanchanma ụmụ-azụụn a ụkụ, e gi tọwẹlụ hụ o je e finchanpụ wẹ ịya.
\v 6 Ọ ru Saịmọnụ hụn w'a kpọ Pita, Pita nọ sị a, “Di-nwọnni-ẹnyi, ịyụ k'a chanmazị m ọkụ?!”
\v 7 Jizọsị nọ za, sị, “Y'a marịn ihiẹn m rị e mẹ kikẹnni; kanị omẹgụụ, ị k'a ghọta a.”
\v 8 Pita nọ sị a, “O nwọnni ogẹn y'e gi chanchan m ụkụ!” Jesu nọ sị a, “Omẹni achanchannị m'ị, y'e nwọnkọ okeri ọwụlẹ imẹ m.”
\v 9 Saịmọnụ wụ Pita nọ sị a, “Ya wụ nị ẹlẹdẹ ụkụ m sụọ kị k'a chan, Di-nwọnni-ẹnyi—chanzị m nwan ẹka lẹ isi!”
\v 10 Jesu nọ za a, sị, “Onyẹ hụn wụgụụ ẹhụ, ọ rịzịnị mkpa n'ọ wụzị ẹhụ, mmanị ụkụ a—makẹni o nwunchanrịngụọ. Ụnụ e nwungụọ nke-esi—kanị ẹlẹ ụnụ ile.”
\v 11 Makẹni Jesu a marịngụọ onyẹ hụn jẹnkọ d'e ren'ẹ, 'ya haịn o gi sị, “Ẹlẹ ụnụ ile nwun.”
\p 
\v 12 Ogẹn o gi chanchangụụ wẹ ọkụ, yirigụzị ẹwuru ẹ, o werizi ọnọdị a teburu hụ. 'Ya ọ nọ sị wẹ, “Ụnụ a ghọtaghọ ihiẹn m mẹ ni ụnụ?
\v 13 Ụnụ a kpọ m ‘Onyẹ-nkuzi’, a kpọ m ‘Di-nwọnni-ẹnyi’; o furu efuru, makẹni 'ya kẹ m wụ.
\v 14 O mẹ nwan nị mmẹ nwẹn, hụn wụ Nna-ụnụ lẹ Onyẹ-nkuzi ụnụ, chanchan ụnụ ụkụ, o furu nị ụnụ chanchanzịkwọ ibe ụnụ ụkụ.
\v 15 A ghọsịọlẹ m ụnụ nzọmụkụ ụnụ jẹnkọ d'e sọn, kẹni ụnụ mẹzikwọ nị ibe ụnụ kẹ m dọn mẹ ni ụnụ.
\v 16 Ezioku kẹ m rị a gwa ụnụ, odibo ara ka nna a; onyẹ wẹ zi ozi ara ka onyẹ zin'ẹ.
\v 17 Omẹni ụnụ a marịnghọ ihiẹn ndịnị, Osolobuẹ jẹnkọ d'a gọzi ụnụ omẹni ụnụ e mẹ wẹ.
\p 
\v 18 Kanị, ẹlẹ ụnụ ile kẹ m rị e ku; a marịnghọ m ndị hụn m họrị. Kanị, wẹ jẹnkọ d'e gi ihiẹn k'e mẹni mẹzu ihiẹn Ẹhụhụọ-nsọ ku, nị, ‘Onyẹ hụn ri brẹdi m e bugụọ nụmanị m.’
\v 19 M rị nwan a gwatọ ụnụ ihiẹnni o gini d'e mẹ, kẹni—o mẹ, nị ụnụ kweri nị mmẹ wụ Onyẹ Hụ.
\v 20 Ezioku kẹ m rị a gwa ụnụ, onyẹ ọwụlẹ hụn nabanhan onyẹ hụn m zihẹ, nabanhan m; onyẹ ọwụlẹ hụn nabanhan nị m, nabanhan onyẹ hụn zihẹ ni m.”
\s1 Jesu E Ku Onyẹ Hụn Sikọ D'e Ren'ẹ
\r (Mat 26.20-25; Mak 14.17-21; Luk 22.21-23)
\p 
\v 21 Ogẹn Jizọsị gi kugụụ ihiẹnni, obi eruzin'ẹ alị, ọ nọ sị, “Ezioku kẹ m rị a gwa ụnụ, onyẹ ohu imẹ ụnụ jẹnkọ d'e we m ye wẹ.” \fig Jesu lẹ ụmụ-azụụn a e rigbama ihiẹn-oriri n'o d'a nwụn|src="WA03910b.jpg" size="span" loc="JHN 13" copy="Graham Wade;∼United Bible Society" ref="13.21"\fig*
\v 22 Ụmụ-azụụn a nọ lemẹ ibe wẹ, makẹni ihiẹn o ku gba wẹ ngharị-ẹnya, amarịn wẹ onyẹ ọ rị e ku.
\v 23 Onyẹ ohu imẹ ụmụ-azụụn a, onyẹ hụn ihiẹn ẹ a sụọ Jesu, nọsọn Jesu.
\v 24 'Ya Saịmọnụ w'a kpọ Pita nọ gi ẹka gwa a 'ya jụ Jizọsị onyẹ o rị e ku.
\v 25 'Ya nwa-azụụn hụ nọ nọkunmẹkẹnmẹ Jizọsị, sị a, “Di-nwọnni-ẹnyi, onyẹ rọ?”
\v 26 Jesu nọ za, sị, “Onyẹ hụn m jẹnkọ d'e ye brẹdini, m surugụụ a imẹ afẹrẹ rọ.” 'Ya ọ nọ suru brẹdi hụ imẹ afẹrẹ, we ẹ ye Judasị nwa Saịmọnụ Iskarọtụ.
\p 
\v 27 Ogẹn Judasị gi narịngụụ brẹdi ahụn, Ekwensụ nọ banye imẹ ẹ. Jesu nọ sị a, “Mẹ ihiẹn ị k'e mẹ ozigbo!”
\v 28 Kanị, o nwọnni onyẹ ọzọ rị ebahụn e ri ihiẹn-oriri hụn ghọta ihiẹn Jesu gi gwa Judasị okuni.
\v 29 Makẹni Judasị e kwọndọn ni wẹ ego, o nwẹ ndị ro ni Jizọsị rị a gwa a 'ya d'e ṅọnhẹn ihiẹn wẹ sikọ d'e gi mẹ mmẹmmẹ hụ, mọbụ 'ya d'e ye ndị igbẹnnyẹ ihiẹn.
\v 30 Ogẹn Judasị gi narịngụụ brẹdi hụ, ọ nọ pụ ozigbo; imẹ uchinchin rọ.
\s1 Iwu Ọhụn
\r (Jẹrimaya 31.31; Gal 3.24-25; Hib 8.13; 1Jn 2.8)
\p 
\v 31 Ogẹn Judasị gi pụgụụ, Jesu nọ sị, “Wẹ jẹnkọ nwan d'e bushi Nwa nke Ịhịan elu—gi Nwa nke Ịhịan bushi Osolobuẹ elu.
\v 32 Omẹni wẹ bushi Osolobuẹ elu ghaha n'a, Osolobuẹ sikọ d'e bushizikwọ Nwa a enu imẹ 'ya lẹ enwẹn ẹ; o jẹnkọ d'e busi ẹ elu ozigbo.
\v 33 Ụmụ m, mmẹ lẹ ụnụ sikọ d'a nọdịzị ẹkẹrẹ sụọ. Ụnụ jẹnkọ d'a chọ m, ụnụ ahụnkọ m. Kẹ m dọn gwa ndị-ndu ndị Ju kẹ m rị nwan a gwa ụnụ: ‘Ụnụ asakọ ẹka bịa ebe m jẹnkọ.’
\v 34 M rị nwan e ye ụnụ iwu ọhụn: e nwẹ ni ihiẹn-ọsụsụọ ibe ụnụ. Kẹ m dọn nwẹ ihiẹn-ọsụsụọ ụnụ kẹ ụnụ k'a dọn nwẹ ihiẹn-ọsụsụọ ibe ụnụ.
\v 35 Omẹni ihiẹn ibe ụnụ a sụọ ụnụ, 'ya kẹ ịhịan ile e gi marịn nị ụnụ wụ ụmụ-azụụn m.”
\s1 Jesu E ku Ẹ Nị Pita Jẹnkọ D'a Ghọrị N'ọ Marịn A
\r (Mat 26.31-35; Mak 14.27-31; Luk 22.31-34)
\p 
\v 36 Saịmọnụ w'a kpọ Pita nọ sị a, “Di-nwọnni-ẹnyi, elebe k'i jẹnkọ?” Jizọsị nọ za, sị, “Ebe m jẹnkọ, y'a sakọ ẹka sọn m kikẹnni—kanị omẹgụụ, i jẹnkọ d'e sọn m.”
\v 37 Pita nọ sị a, “Di-nwọnni-ẹnyi, kị haịn o gi mẹ ni asakọ m ẹka sọn i kikẹnni? M k'a nwụndẹni i ọnwụn!”
\v 38 Jesu nọ za, sị, “N'ị nwụnnị m ọnwụn? Ezioku kẹ m rị a gwa ị, ọkpa gini d'a kwan, i jẹnkọ d'a ghọrị mgbe ẹtọ nị 'y'a marịn m.”
\c 14
\cl Isi Nke Mmẹnọ
\s1 Jesu Sụọ Kẹ W'a Gha D'e Kunrun Chuku-Nẹdi
\p 
\v 1 Jizọsị nọ sị wẹ, “Anịlẹ ni obi ụnụ sọngbu ụnụ. Kweri ni ni Osolobuẹ; kwerizikwọ nị nị m.
\v 2 Iwẹ Nẹdi m, mmughẹ bu ọda rị a. Omẹni ẹlẹ ẹrịra, nkẹ m'a gwa ụnụ. M shikọ nwan d'a kwademẹ ni ụnụ ebe ụnụ jẹnkọ d'e bi.
\v 3 M jẹngụụ d'a kwademẹ ni ụnụ ebe ụnụ jẹnkọ d'e bi, e kinhẹn m azụụn d'e weri ụnụ, kẹni ụnụ rịzịkwọ ebe m rị.
\v 4 Ụnụ a marịngụọ ụzọ ebẹhụ m jẹnkọ.”
\p 
\v 5 Tamọsị nọ sị a, “Di-nwọnni-ẹnyi, ẹnyi amarịn ebe i jẹnkọ, ẹghanị kẹ ẹnyi e dọn marịn ụzọ a?”
\v 6 Jizọsị nọ sị a, “Mmẹ wụ ụzọ lẹ ezioku lẹ ndụn. O nwọnni onyẹ sikọ d'a sa ẹka bịa d'e kunrun Chuku-Nẹdi mmanị ghahanị m.
\v 7 Omẹni ụnụ a marịngụọ m, ụnụ jẹnkọ d'a marịnzịkwọ Nẹdi m. Ụnụ a marịngụọ a nwan gha kikẹnni jẹnmẹ; ụnụ a hụngụọ a.”
\p 
\v 8 Filipu nọ sị a, “Di-nwọnni-ẹnyi, ghọsịhụ ẹnyi Chuku-Nẹdi, ẹfọ e jun ẹnyi.”
\v 9 Jesu nọ sị a, “Filipu, hụnnị ile mmẹ lẹ ụnụ rị, 'y'a marịn m? Onyẹ ọwụlẹ hụnnị m, a hụngụọ Chuku-Nẹdi. K'ị rị a sịnị, ‘Ghọsị ẹnyi Chuku-Nẹdi.’?
\v 10 Ụnụ ekwerini nị m rị imẹ Chuku-Nẹdi lẹ ni Chuku-Nẹdi rị imẹ m? Arị m e gi uche m a gwa ụnụ oku ndịnị m rị a gwa ụnụ; mba, Chuku-Nẹdi hụn rị imẹ m ya rị a rụn ọrụn a.”
\p 
\v 11 “Kweri ni ihiẹn m ku nị m rị imẹ Chuku-Nẹdi, Chuku-Nẹdi rịzịkwọ imẹ m. Kanị, omẹni ụnụ egikọ oku-ọnụ m kweri, gi ni ihiẹn ndị m rị a rụn kweri.”
\p 
\v 12 “Ezioku kẹ m rị a gwa ụnụ, onyẹ hụn kwerini ni m sikọ d'a rụn ọrụn ndị hụn m rị a rụn; o jẹnkọ d'a rụnkarịdẹ ndịnị m rị a rụn, makẹlẹ m laburukọ Chuku-Nẹdi.
\v 13 Ihiẹn ọwụlẹ ụnụ gi ẹfan m rịọ, m sikọ d'e mẹ ẹ, kẹni \it mmẹ wụ\it* Nwa hụn ụzọ wẹhẹ ni Chuku-Nẹdi ọghọ.
\v 14 Ụnụ gi ẹfan m rịọ m ihiẹn ọwụlẹ, m jẹnkọ d'e mẹ ẹ.”
\s1 Jizọsị E Kwe Nkwa N'o K'e Zihẹ Mmọn-nsọ
\p 
\v 15 “Omẹni ihiẹn m a sụọghọ ụnụ, ụnụ jẹnkọ d'e dọnmẹ iwu m,
\v 16 a rịọ m Chuku-Nẹdi n'o zihẹ ni ụnụ Onyẹ-nkasị-obi ọzọ n'ọ nọyeni ụnụ jẹnrin ejẹn.
\v 17 Onyẹ ahụn wụ Mmọn-nsọ—onyẹ hụn a ghọsị ezioku; ụwa asaẹka nabanhan a, makẹni ụwa as'ẹka hụn a mọbụ marịn a. Kanị ụnụ a marịnghọ a, makẹni o bi imẹ ụnụ; o k'e bisọnmẹ imẹ ụnụ.
\v 18 Ẹlẹ m k'a latọ ụnụ rịkẹ ndị nwọnlẹni nnẹ lẹ Nẹdi; m sikọ d'a bịa d'e kunrun ụnụ.
\p 
\v 19 Ọ họdụ ẹkẹrẹ nị ụwa hụnbehi m, kanị ụnụ jẹnkọ d'a hụn m. Makẹni m rị ndụn, ụnụ lẹ enwẹn ụnụ sikọ d'a rịzị ndụn.
\v 20 O ru ụhụọhịn hụ, ụnụ jẹnkọ d'a marịn nị m rị imẹ Nẹdi m, nị ụnụ rị imẹ m, mmẹ nwẹn rị imẹ ụnụ.
\v 21 Ndị hụn marịn ihiẹn m ku, gi wẹ e bi, uwẹ wụ ndị ihiẹn m sụọ. Ndị ihiẹn m sụọ kẹ ihiẹn wẹ k'a sụọ Nẹdi m; ihiẹn wẹ jẹnkọ d'a sụọzịkwọ mmẹ nwẹn, e we m enwẹn m ghọsị wẹ.”
\p 
\v 22 Nwa-azụụn a ohu w'a kpọ Judasị (kalẹ ẹlẹ nwa Iskarọtụ) nọ sị a, “Di-nwọnni-ẹnyi, kị mẹzi i k'e gi ghọsị ẹnyi enwẹn i bụ 'y'a ghọsịkọ ụwa?”
\p 
\v 23 Jesu nọ za a, sị, “Onyẹ ọwụlẹ ihiẹn m a sụọ jẹnkọ d'e mẹ ihiẹn m ku. Ihiẹn ẹ k'a sụọ Nẹdi m, mmẹ lẹ Nẹdi m a bịa d'e kunrun ẹ, du ẹ bi.
\v 24 Onyẹ ọwụlẹ ihiẹn m ghalẹni a sụọ ara mẹ ihiẹn ndị m ku—bụ oku ndịnị ụnụ rị a nụ ẹlẹ nke m, wẹ wụ nke Chuku-Nẹdi hụn zihẹni m.
\v 25 A gwagụọ m ụnụ ihiẹn ndịnị hụnnị mmẹ lẹ ụnụ rị;
\v 26 kanị, Onyẹ-nkasị-obi wụ Mmọn-nsọ, hụn Chuku-Nẹdi jẹnkọ d'e gi ẹfan m zihẹ, jẹnkọ d'a kuzi ụnụ ihiẹn ile; o sikọ d'a nyanhan nị ụnụ ihiẹn ile m gwa ụnụ.
\p 
\v 27 Udọn kẹ m rị a latọ nị ụnụ; udọn nke m kẹ m rị e ye ụnụ—ẹlẹ kẹ ụwa dọn e ye kẹ m'e ye. Anịlẹ ni obi ụnụ sọngbu ụnụ, atụlẹ ni egun.
\v 28 Ụnụ a nụghọ kẹ m sị ụnụ, ‘M pụkọ apụkọ’ lẹ ni ‘m sikọ d'e kinhẹn d'e kunrun ụnụ.’ Omẹni ihiẹn m sụọ ụnụ, nkẹ ụnụ hụ a ghọghọ nị m jẹnkọ d'e kunrun Chuku-Nẹdi, makẹni 'ya ka m.
\v 29 A gwatọgụọ m nwan ụnụ ihiẹnni hụnnị o kelẹni mẹ—kẹni, o mẹ, ụnụ e kweri.
\v 30 Ogẹn arịa m'e gi gwamazị ụnụ ihiẹn bu ọda, makẹni onyẹ hụn a kị ụwanị lala; o nwẹni ikẹn ọwụlẹ o nwọn ebe m rị,
\v 31 kanị, m rị e mẹ nị ụwa marịn nị ihiẹn Chuku-Nẹdi sụọ m a sụọ, nị ihiẹn Chuku-Nẹdi sị m mẹ kẹ m'e mẹ; lihi ni nwan nị ẹnyi gha ebeni pụ.”
\c 15
\cl Isi Nke Mmisẹn
\s1 Ezigbo Osisi-vaịnị Lẹ Aganaba A
\p 
\v 1 “Mmẹ wụ ezigbo vaịnị; Nẹdi m wụ hụn e lepụ a ẹnya. \fig vaịnị|src="hk00112b.jpg" size="span" loc="JHN 15" copy="Horace Knowles; The British & Foreign Bible Society" ref="15.1"\fig*
\v 2 Agalaba ọwụlẹ rị imẹ m hụn mịlẹni mkpụrụ, o bepụ a; kanị agalaba hụn mị mkpụrụ, o befọn ẹ, kẹni ọ mịkẹnmẹ.
\v 3 Oku m gwa ụnụ e befọngụọ ụnụ, mẹ ụnụ nwunchan, kẹni ụnụ mịkẹnmẹ mkpụrụ.
\v 4 Nọdịsọnmẹ ni imẹ m, mmẹ nwẹn a nọdịsọnmẹ imẹ ụnụ. K'o dọn wụrụ nị agalaba nọdị nke ẹ ara saẹka mị mkpụrụ, mmanị ọ nyankụnma osisi ẹ, ẹrịra k'o dọn wụrụ nị ụnụ asakọ ẹka mị mkpụrụ wezụka nị ụnụ nọdịsọnmẹ imẹ m.”
\p 
\v 5 “Mmẹ wụ ukun vaịnị, ụnụ nwẹn wụsọnmẹ agalaba rịn'a; Onyẹ hụn nọdị imẹ m, mmẹ nwẹn hụ imẹ ẹ, 'ya sikọ d'a mị mkpụrụ ọda-ọda, makẹni, wezụka m, ụnụ a s'ẹka mẹ ihiẹn ọwụlẹ.
\v 6 Onyẹ ọwụlẹ hụn nọdịlẹni imẹ m, e tuhu w'a, lẹkẹ ebe wẹ nọ bepụ agalaba, ọ kpọpụ nkụn; w'e kpọngbamẹ agalaba ndị nọ ẹrịra, tụ wẹ ye ọkụn, dụnpụ.
\v 7 Omẹni ụnụ a nọdị imẹ m, oku m a nọdịzịkwọ imẹ ụnụ, rịọ nị ihiẹn ọwụlẹ ụnụ chọ; Osolobuẹ jẹnkọ d'e mẹ ni ụnụ 'ya.
\v 8 Omẹni ụnụ a mị mkpụrụ ọda-ọda, o jẹnkọ d'a ghọsị nị ụnụ wụ ụmụ-azụụn m: ọhụn jẹnkọ d'e wẹhẹ ni Nẹdi m ọghọ.
\p 
\v 9 Kẹ Chuku-Nẹdi dọn nwẹ ihiẹn-ọsụsụọ ebe m rị kẹ m dọn nwẹ ihiẹn-ọsụsụọ ebe ụnụ rị; rịsọnmẹkwọ nị ndị ihiẹn wẹ a sụọ m.
\v 10 Omẹni ụnụ e dọnmẹ iwu m, ụnụ sikọ d'a rịsọnmẹ ndị ihiẹn wẹ a sụọ m—lẹkẹ kẹ m dọn dọnmẹ iwu Nẹdi m ye m, gi ẹ wụsọnmẹ onyẹ ihiẹn ẹ asụọ Nẹdi m.
\v 11 A gwatọgụọ m ụnụ ihiẹn ndịnị, kẹni ịghọghọ m rị imẹ ụnụ lẹ ni ịghọghọ ụnụ zu oke.
\p 
\v 12 Ọnwan wụ iwu m: e nwẹ ni ihiẹn-ọsụsụọ ibe ụnụ kẹ m dọn nwẹ ihiẹn-ọsụsụọ ụnụ.”
\p 
\v 13 “O nwọnni onyẹ nwẹ ihiẹn-ọsụsụọ ka ọnwan: nị ịhịan gi ifiri ndị ọwụ a we ndụn a ye.
\v 14 Ndị ọwụ m kẹ ụnụ wụ—omẹni ụnụ e mẹ ihiẹn m sị ụnụ mẹ.
\v 15 Arịzị m a kpọ ụnụ igbọn, makẹlẹ igbọn ara marịn ihiẹn di-nwọnn'ẹ rị e mẹ. Kama, m kpọ ụnụ ndị ọwụ m makẹni a gwagụọ m ụnụ ihiẹn ile m nụ ọnụ Nẹdi m.”
\p 
\v 16 “Ẹlẹ ụnụ họrị m; mba, mmẹ họrị ụnụ, tumẹ ụnụ kẹni ụnụ jẹn d'a mị mkpụrụ—mkpụrụ hụn sikọ d'a tọnị, kẹni Chuku-Nẹdi ye ụnụ ihiẹn ọwụlẹ ụnụ gi ẹfan m rịọ.
\v 17 M rị e ye ụnụ iwuni: e nwẹ ni ihiẹn-ọsụsụọ ibe ụnụ.”
\s1 Izize Ụnụ Jẹnkọ D'e Ze Ụwa
\p 
\v 18 “Omẹni izize ụnụ rị e ze ụwa, nyanhankwọ nị nị izize m bu ụzọ ze ẹ.
\v 19 Omẹni ụnụ te wụ nke ụwa, nkẹ ihiẹn ụnụ a sụọ ụwa rịkẹ nke ẹ. Kanị, ebe o mẹ ni ụnụ ẹlẹ nke ụwa makẹni a họpụgụọ m ụnụ imẹ ụwa, 'ya haịn izize ụnụ gi e ze ụwa.
\v 20 Nyanhan nị ihiẹn m gwa ụnụ, nị, ‘Odibo ara ka nna a.’ Omẹni wẹ kpokpo m ekpokpo, wẹ sikọ d'e kpokpozikwọ ụnụ; omẹni wẹ mẹ ihiẹn m sị wẹ mẹ, wẹ jẹnkọ d'e mẹzikwọ ihiẹn ụnụ sị wẹ mẹ.
\v 21 Wẹ k'e mẹ ụnụ ihiẹn ndịnị wẹ makẹni ụnụ wụ nke m, ụnụ rị a za ẹfan m, makẹni amarịn wẹ onyẹ hụn zihẹni m.
\v 22 Omẹni abịanị m d'a gwa wẹ oku, ikpe njọ e ke ma wẹ; kanị o nwọnzini nwan ihiẹn wẹ k'e gi wanahịn njọ wẹ mẹ.
\v 23 Onyẹ ọwụlẹ rị e ze izize m rị e zezikwọ izize Nẹdi m.
\v 24 Omẹni arụnnị m ọrụn wẹ rụntulẹni imẹ wẹ, ikpe njọ e ke ma wẹ; kanị, a hụnchanrịngụọ wẹ nwan ọrụn-atụmẹnya ndị m rụn—bụ ize mmẹ lẹ Nẹdi m hụkwọ e ze wẹ.
\v 25 Kanị, ọ rị ẹnịna nị wẹ hụn ụzọ mẹzu ihiẹn hụ wẹ de imẹ Iwu wẹ, nị, ‘Izize m rị e ze wẹ bụ o nwọnni ihiẹn m mẹ.’
\p 
\v 26 Kanị, Onyẹ nkasị-obi hụ m jẹnkọ d'a gha ebe Chuku-Nẹdi rị zihẹni ụnụ bịa, o jẹnkọ d'a shịanị m ẹri. Onyẹ nkasị-obi hụ wụ Mmọn-nsọ—Onyẹ hụn a ghọsị ezioku. O k'a gha ebe Chuku-Nẹdi rị bịa.
\v 27 Ụnụ lẹ enwẹn ụnụ sikọ d'a shịazịkwọ nị m ẹri, makẹni mmẹ lẹ ụnụ rị gha isi mbidọn lala.”
\c 16
\cl Isi Nke Mmisin
\p 
\v 1 “A gwatọgụọ m ụnụ ihiẹn ndịnị amamgbe ụnụ a danpụ imẹ okukwe.
\v 2 Wẹ jẹnkọ d'a chụpụ ụnụ imẹ ụlọ-ofufe; ezioku-ezioku, ogẹn lala hụn onyẹ ọwụlẹ gbuni ụnụ jẹnkọ d'e weridẹ ẹ ni ọrụn ọma k'ọ rị a rụnnị Osolobuẹ.
\v 3 Wẹ jẹnkọ d'e mẹ ihiẹnni makẹlẹ w'e ke marịn Chuku-Nẹdi mọbụ mmẹ lẹ enwẹn m.
\v 4 Kanị, a gwatọgụọ m ụnụ ihiẹn ndịnị, kẹni ogẹn w'e gi mẹ, ụnụ a nyanhan nị a gwatọgụọ m ụnụ.”
\p “E te gwanị m ụnụ ihiẹn ndịnị isi mbidọn, makẹni m rị imẹ igunrun ụnụ.
\v 5 Kanị m jẹnkọ nwan d'e kunrun onyẹ hụn zihẹni m, bụ o nwọnni onyẹ ọwụlẹ imẹ ụnụ jụ m kẹ elebe kẹ m jẹnkọ?
\v 6 Hụn nkẹ ụnụ e gi jụ m'a, ụnụ a sụkụrụ makẹni m gwa ụnụ ihiẹn ndịnị m gwa ụnụ.”
\s1 Ọrụn Mmọn-nsọ Sikọ D'a Rụn
\p 
\v 7 “Kanị ezioku kẹ m rị a gwa ụnụ, erere ụnụ rọ omẹni a pụ m; makẹni, Onyẹ-nkasị-obi abịakọ mmanị m lama alama. Kanị, m lamagụụ kẹ m'a nọ zihẹ ni ụnụ 'ya.
\v 8 Ogẹn o jẹnkọ d'e gi bịa, ọ sikọ d'a ghọsị ndị ụwa nị a ghọtanị wẹ ihiẹn njọ wụ, nị a ghọtanị wẹ ihiẹn Osolobuẹ chọ, lẹni aghọtanị wẹ kẹ okinkin-ikpe nọ.
\v 9 nị aghọtanị wẹ ihiẹn njọ wụ—makẹni njọ wụ nị e kwerini ni wẹ m;
\v 10 nị aghọtanị wẹ ihiẹn Osolobuẹ chọ—makẹni mmẹ nwẹn jẹnkọ ebe Nẹdi m rị, ụnụ ahụnkọzị m;
\v 11 nị a ghọtanị wẹ kẹ okinkin-ikpe nọ makẹni Osolobuẹ a magụọ onyẹ hụn a kị ụwanị ikpe.
\p 
\v 12 Ihiẹn bu ọda họdụ hụn m chọ nị m gwa ụnụ, kanị ụnụ asakọ ẹka ghọta a kikẹnni.
\v 13 Ogẹn Mmọn-nsọ, Onyẹ hụn a ghọsị ezioku, k'e gi bịa, o sikọ d'e du ụnụ ye imẹ ezioku ile. Makẹlẹ, ẹlẹ uche ẹ k'o k'e ku; kama, ihiẹn ọwụlẹ ọ nụ, 'ya k'o jẹnkọ d'e ku. O jẹnkọ d'a gwazịkwọ ụnụ ihiẹn ndị k'e mẹ ihun.
\v 14 O jẹnkọ d'e ye m ọghọ, makẹni o sikọ d'e weri ihiẹn wụ nke m, hụn m k'e ye ẹ, gwa ụnụ ya—
\v 15 ihiẹn ile Nẹdi m nwọn wụ nke m; 'ya haịn m gi sị nị Mmọn-nsọ jẹnkọ d'e weri ihiẹn wụ nke m gwa ụnụ.”
\s1 Ẹkwan Jẹnkọ D'e Hẹnrin Ịghọghọ
\p 
\v 16 “Ọ nọbe ẹkẹrẹ, ụnụ ahụnkọzị m; ọ nọbezi ẹkẹrẹ ụnụ jẹnkọ d'a hụn m.”
\v 17 Ndị hụ imẹ ụmụ-azụụn a nọ sị ibe wẹ, “K'o gi ihiẹnni ọ rị a gwa ẹnyi e ku—nị, ‘Ọ nọbe ẹkẹrẹ, ụnụ ahụnkọzị m; ọ nọbezi ẹkẹrẹ ụnụ jẹnkọ d'a hụn m,’ ọ sịzị, ‘Makẹni m jẹnkọ ebe Chuku-Nẹdi rị’?”
\v 18 Wẹ hụ a sị, “K'o gi ‘Ọ nọbe ẹkẹrẹni’ e ku? Ẹnyi aghọtanị ihiẹn ọ rị e ku!”
\p 
\v 19 Jesu a marịngụọ nị wẹ chọ nị wẹ jụ a ajụjụ, ọ nọ sị wẹ, “Ụnụ rị a jụtarị ibe ụnụ ihiẹn m gi sị, ‘Ọ nọbe ẹkẹrẹ, ụnụ ahụnkọzị m, ọ nọbezi ẹkẹrẹ, ụnụ jẹnkọ d'a hụn m.’?
\v 20 Ezioku kẹ m rị a gwa ụnụ, ụnụ jẹnkọ d'a kwan ẹkwan, goo—kanị ụwa jẹnkọ d'a ghọghọ; ọ k'a gha a fụ ụnụ. Kanị, o nọbe, ụfụ ahụn e hẹnrin ịghọghọ.”
\p 
\v 21 “Imẹ gha e mẹ okpoho, ọ tụrụ a atụrụ makẹni ogẹn ẹ e rugụọ; kanị ọ mụgụụ, ọ nyanhankọzị afụnfụn hụ ebe ọ n'a ghọghọ n'ọ mụbanhagụọ nwa imẹ ụwa.
\v 22 Ẹrịra kẹ ụnụ rị nwan a kwan; kanị, m k'a hụnzị ụnụ—ogẹn hụ, ịghọghọ sikọ d'e jun ụnụ obi, o nwọnni onyẹ jẹnkọ d'a napụ ụnụ ịghọghọ ụnụ.
\v 23 O ru ogẹn hụ, o nwọnzini ihiẹn ụnụ jẹnkọ d'a rịọ m. Ezioku kẹ m rị a gwa ụnụ, gi ni ẹfan m rịọ Chuku-Nẹdi ihiẹn ọwụlẹ, o sikọ d'e ye ụnụ 'ya.
\v 24 D'e rukwọ nwan ogẹnni, ụnụ egituni ẹfan m rịọ ihiẹn ọwụlẹ; rịọ nị, ụnụ jẹnkọ d'e nwọnhẹn, kẹni ịghọghọ ụnụ zu oke.”
\s1 Imẹri Ụwa
\p 
\v 25 “M gi ilu gwa ụnụ ihiẹn ndịnị; kanị ogẹn lala hụn m sikọ d'e gi gwapụ ụnụ banyeni Chuku-Nẹdi, egikọzị m ilu ogẹn hụ.
\v 26 O ru ogẹn ahụn, ụnụ jẹnkọ d'e gi ẹfan m rịọ. Ekuni m nị m jẹnkọ d'a rịọdọnni ụnụ Chuku-Nẹdi,
\v 27 makẹni ihiẹn ụnụ a sụọ Chuku-Nẹdi lẹ enwẹn ẹ a sụọ; ihiẹn ụnụ a sụọ a asụọ makẹni ihiẹn m a sụọ ụnụ a sụọ, lẹzi makẹni ụnụ kweri nị m gha ebe Osolobuẹ rị bịa.
\p 
\v 28 M gha ebe Chuku-Nẹdi rị bịa imẹ ụwa; m pụkọzị nwan imẹ ụwa kẹni m laburu Chuku-Nẹdi.”
\v 29 'Ya ụmụ-azụụn a nọ sị a, “Ị rị e kuchanpụ a nwan ọhụnma-ọhụnma, ẹlẹzi ilu!
\v 30 Echẹn kẹ ẹnyi marịn nwan n'ị marịnchanrịn ihiẹn ile, n'o nwọnni onyẹ furu n'ọ jụ ị ajụjụ; ọnwan kẹ ẹnyi gi kweri n'ị gha ebe Osolobuẹ rị bịa.”
\v 31 Jesu nọ za, sị, “Ụnụ e kwerigụọ nwan?
\v 32 Ogẹn lala—o rugụọdẹ nwan, ogẹn ụnụ jẹnkọ d'e gi gbayịya, onyẹ-onyẹ e si iwe ẹ, na mmẹ sụọ tọ. Kanị, ẹlẹ mmẹ sụọ wị, Nẹdi m nọyeni m anọyeni.
\v 33 A gwagụọ m ụnụ ihiẹn ndịnị kẹni obi gi ifiri m ru ụnụ alị. Imẹ ụwa, ụnụ jẹnkọ d'e nwọn nsọngbu; ka kwọndọn ni obi ụnụ, n'e mẹrigụọ m ụwa!”
\c 17
\cl Isi Nke Mmẹsa
\s1 Ekpere Jizọsị Mẹni Ndị Nke Ẹ Ile
\p 
\v 1 Ogẹn Jizọsị gi kugụụ ihiẹn ndịnị wẹ, ọ nọ lee ẹnya elu-igwee, sị, “Baba, ogẹn hụ e rugụọ! Ye Nwa ị ọghọ, kẹni Nwa ị hụn ụzọ ye i ọghọ—
\v 2 ebe o mẹ ni y'e bugụọ ịhịan ile che okpuru ẹ, kẹni o ye ndị ile hụn i ye ẹ ndụn itẹbitẹ.
\v 3 Ọnwan wụ ndụn itẹbitẹ: ịmarịn n'ị—'yụ, hụn ya sụọ wụ Osolobuẹ nke-esi lẹ ịmarịn Jizọs' Kraịstị hụn i zihẹ.”
\p 
\v 4 “E yegụọ m'ị ọghọ imẹ ụwanị ghahanị ịrụnchanrịn ọrụn hụn i ye m rụn.
\v 5 Baba, yezi m nwan ọghọ ị, ọghọ ohu hụ mmẹ lẹ 'yụ nwọngbama nị ụwa d'e bidọn.”
\p 
\v 6 “E mẹgụọ m ndịnị marịn ị, marịn ẹfan ị—ndịnị ị gha imẹ ụwa weye m. Wẹ wụ nke i; 'yụ we wẹ ye m; e mẹgụọ wẹ ihiẹn i ku.
\v 7 A marịngụọ wẹ nwan nị ihiẹn ile i ye m gha ẹka ị bịa,
\v 8 makẹlẹ a gwagụọ m wẹ ihiẹn ndị hụ ị sị m gwa wẹ. A nabanhangụọ wẹ ihiẹn ndị hụ; a marịngụọ wẹ nị m gha ebe ị rị bịa nke-esi. E kwerigụọ wẹ nị 'yụ zihẹ m.”
\p 
\v 9 “M rị e mẹ ni wẹ ekpere; ẹlẹ ndị ụwa kẹ m rị e mẹ ni ekpere, kalẹ ndị hụn i ye m; makẹni, nke i kẹ wẹ wụ.
\v 10 Ihiẹn ile m nwẹ wụ nke i, nke i wụzịkwọ nke m. W'e wẹhẹ ni m ọghọ.
\v 11 Arịkọzị m nwan imẹ ụwa, kanị wẹ rị imẹ ụwa—mmẹ nwẹn lala d'e kunrun i. Nẹdi hụn rị nsọ, gi ẹfan ị chemẹ wẹ, ẹfan ị ahụn i ye m, kẹni wẹ wụrụ ohu kẹ mmẹ lẹ 'yụ dọn wụ ohu.
\v 12 Ogẹn mmẹ lẹ wẹ gi rị, m gi ẹfan ị chemẹ wẹ—ẹfan ahụn i ye m. E chemẹgụọ m wẹ: etuhuni m kaka onyẹ ohu imẹ wẹ—wezụka onyẹ ahụn mẹ ihiẹn wẹ e gi tikpọ a—kẹni ihiẹn Ẹkụkwọ-nsọ ku hụn ụzọ mẹzu.
\v 13 Kanị, m lala nwan d'e kunrun i; m rị e ku ihiẹn ndịnị imẹ ụwa kẹni wẹ hụn ụzọ nwẹ ịghọghọ m imẹ ndụn wẹ, nwẹ ẹ hụn zu oke.”
\p 
\v 14 “E yegụọ m wẹ oku i, izize wẹ nọ zemẹ ụwa—makẹni ẹlẹ wẹ nke ụwa, rịkẹ kẹ o dọn mẹ ni mmẹ lẹ enwẹn m ẹlẹ nke ụwa.
\v 15 Arị m a rịọ ị n'ị gha imẹ ụwa wepụ wẹ; kama, m rị a rịọ n'ị chemẹ wẹ makẹ Eje-onyẹ hụ gha e mẹ wẹ ihiẹn ọwụlẹ.
\v 16 Ẹlẹ wẹ nke ụwa—k'o dọn mẹ ni ẹlẹ m nke ụwa.
\v 17 Gi ezioku dọn wẹ nsọ: oku i wụ ezioku.
\v 18 Kẹ i dọn zihẹ m imẹ ụwa kẹ m dọn rị e zi wẹ e ye imẹ ụwa.”
\p 
\v 19 “M rị nwan e gi ifiri wẹ e wepụha enwẹn m, kẹni m hụn a nị wẹ wụrụ ndị wẹ wepụha n'ị, hụn wẹ dọn nsọ nke-esi.
\p 
\v 20 Ẹlẹ ndịnị sụọ kẹ m rị e mẹ ni ekpere; kama, m rịzịkwọ e mẹni ndị hụn jẹnkọ d'e gi ufiri ozi wẹ zi kweri ni m.
\v 21 M rị a rịọ nị wẹ ile wụrụchanrịn ohu, nọkẹ kẹ ịyụ, Baba, dọn rị imẹ m, mmẹ nwẹn hụzịkwọ imẹ i; m rị a rịọ nị wẹ rịzịkwọ imẹ ẹnyi—kẹni ụwa hụn ụzọ kweri nị ịyụ zihẹ m.
\v 22 E wegụọ m ọghọ hụ i ye m ye wẹ, kẹni wẹ wụrụ ohu kẹ mmẹ lẹ 'yụ dọn wụ ohu:
\v 23 kẹni ọ wụrụ nị mmẹ nwẹn hụ imẹ wẹ, 'yụ nwẹn hụ imẹ m; a wụrụchanrịn wẹ ohu, ụwa e gi ẹ marịn nị ịyụ zihẹ m lẹni uwẹ wụ ndị nke m rị ị obi kẹ mmẹ nwẹ dọn rị ị obi.”
\p 
\v 24 “Baba! M chọ nị ndị ile i we ye m sọn m nọdị ebe m rị, nị wẹ hụn ọghọ m hụn i ye m makẹ ihiẹn-ọsụsụọ i nwẹ jẹnni m n'i d'e kedẹ ụwa.”
\p 
\v 25 “Euu Nẹdi m, Onyẹ ezi-omumẹ, ọsụọn'a nị ụwa amarịn n'ị, mmẹ nwẹn a marịnghọ ị, ndịnị wẹ a marịnghọzị nị ịyụ zihẹ m.
\v 26 E mẹgụọ m wẹ marịn ị, m jẹnkọ d'a gha e mẹzikwọ wẹ a marịn ị, kẹni ihiẹn-ọsụsụọ i nwọn ebe m rị hụn ụzọ rị imẹ wẹ lẹni mmẹ nwẹn rịzị imẹ wẹ.”
\c 18
\cl Isi Nke Mmẹsatọ
\s1 A Bịa Wẹ D'a Nwụnrụn Jesu
\r (Mat 26.47-56; Mak 14.43-50; Luk 22.47-53)
\p 
\v 1 Ogẹn Jesu gi mẹgụụ ekpereni, 'ya lẹ ụmụ-azụụn a nọ fetu Ọdanmgbugbu Kidrọnụ. O nwẹ ụgba rị ebẹhụ; Jesu lẹ ụmụ-azụụn a nọ banye ụgba ahụn.
\v 2 (Judasị, hụn ren'ẹ a marịnghọzị ebahụn, makẹni Jesu lẹ ụmụ-azụụn a a nọ ebẹhụ e zu mbụ-lẹ-ẹbụọ.)
\p 
\v 3 'Ya Judasị nọ weri igunrun ndị-agha Rom lẹ ndị-ụnakpa Ụlọ-nsọ, ndị hụn ndị-isi nchụ-ẹjan lẹ ndị itu-Farisi zihẹ, banhan imẹ alị vaịnị hụ. Wẹ busọnmẹ ihiẹn-ọgụn ichẹn-ichẹn lẹ ọwa lẹ ukpẹ.
\p 
\v 4 Jesu a marịngụọ ihiẹn ile jẹnkọ d'e mẹ n'ẹ, 'ya ọ nọ jẹnpụha ihun, jụ wẹ, sị, “Onyẹ kẹ ụnụ rị a chọ?”
\v 5 Wẹ nọ za, sị, “Jesu, onyẹ Nazarẹtị.” Ọ nọ sị wẹ, “Mmẹ rọ.” (Judasị hụn ren'ẹ wuzoyeni wẹ ebahụn ogẹn o gi ku ihiẹnni.)
\v 6 Ogẹn Jesu gi sị wẹ, “Mmẹ rọ”, wẹ nọ jẹnkin azụụn, danchanrịn \it alị\it*.
\v 7 Jizọsị nọ jụzị wẹ, sị, “Onyẹ kẹ ụnụ chọkọ?” Wẹ nọ sị, “Jizọsị onyẹ Nazarẹtị.”
\v 8 Jizọsị nọ sị, “A gwagụọ m ụnụ nị mmẹ rọ. O mẹ nwan nị mmẹ kẹ ụnụ rị a chọ, nị nị ndịnị họdụnị lama.”
\v 9 (O ku ihiẹnni kẹni ihiẹn hụ o ku mbụ hụn ụzọ mẹzu: “Etuhuni m kaka onyẹ ohu imẹ ndị hụn i ye m.”)
\p 
\v 10 Ya kẹ Saịmọnụ wụ Pita, hụn bu ọpịa-agha, nọ sepụha a, banpụ odibo onyẹ-isi nchụ-ẹjan ntịn ẹka-ihiẹn. (Ẹfan odibo ahụn wụ Makusu.)
\v 11 Jizọsị nọ sị Pita, “Wekin ọpịa-agha ị ọnọdị a! Nị m jụ n'a rakọ m mkpu afụnfụn hụn Nẹdi m ye m?”
\s1 E We Wẹ Jesu Jẹnni Anasị N'o Kin Ẹ Ikpe
\p 
\v 12 Ya ndị-agha Rom lẹ Onyẹ-isi-agha wẹ kanị lẹ ndị-ụnakpa ndị Ju nọ nwụnrụn Jesu, kẹn ẹ ẹgbụn.
\v 13 Wẹ nọ bu ụzọ we ẹ jẹnni Anasị. Anasị wụ nẹdi nwunyẹ Kayafasị. Kayafasị wụ onyẹ-isi nchụ-ẹjan ahụa hụ.
\v 14 (Kayafasịnị wụ onyẹ hụn dụn ndị-isi ndị Ju ọdụn n'ọ kakwọ wẹ mma nị onyẹ ohu nwụndọnni ịhịan ile ọnwụn.)
\s1 Pita A Ghọrị N'ọ Marịn Jesu
\r (Mat 26.69-75; Mak 14.66-68; Luk 22.55-57)
\p 
\v 15 Saịmọnụ wụ Pita lẹ nwa-azụụn ọzọ nọ sọnmẹ Jesu. (Onyẹ-isi nchụ-ẹjan marịn nwa-azụụn ọzọ hụ amarịn, 'ya nwa-azụụn hụ nọ sọn Jesu banye imẹ ezi ọgwa onyẹ-isi nchụ-ẹjan.)
\v 16 Kanị Pita abanhannị. Ya nwa-azụụn ọzọ hụ nọ kin-azụụn d'a gwa okpoho hụn rị e che nche ọnụ-mgbọn oku, webanhan Pita.
\v 17 Okpoho ahụn rị ọnụ-mgbọn nọ sị Pita, “Y'ẹlẹ onyẹ ohu imẹ ụmụ-azụụn okẹnnyẹ hụ?” Pita nọ sị, “Mba, ẹlẹ mmẹ.”
\p 
\v 18 Oyi rị a tụ; 'ya ndị idibo lẹ ndị-ụnakpa hụ nọ fịye ọkụn, fihunmẹ ọkụn hụ, a nyan a. 'Ya Pita nọ jẹn d'e sọn wẹ turu ebẹhụ, a nyan ọkụn.
\s1 Onyẹ-isi Nchụ-ẹjan A Jụ Jesu Ajụjụ
\r (Mat 26.59-66; Mak 14.55-64; Luk 22.66-71)
\p 
\v 19 Ogẹn ahụn, onyẹ-isi nchụ-ẹjan hụ a jụ Jesu ajụjụ banyeni ụmụ-azụụn a lẹ nkuzi ẹ.
\v 20 Jesu nọ sị, “Id'ẹnya ịhịan ile kẹ m nọ ku ihiẹn m ku; imẹ ụlọ-ofufe rị ichẹn-ichẹn lẹ imẹ Ụlọ-nsọ—ebe ndị Ju ile nọ e zu kẹ m nọ kuzi nkuzi m; ekutuni m ihiẹn ọwụlẹ nzuzue.
\v 21 K'ị rị nwan a jụnị m ajụjụ? Jụ ndị hụn nụ ihiẹn m ku, a marịngụọ wẹ ihiẹn m ku.”
\v 22 Ogẹn Jesu gi ku ihiẹnni, ụnakpa ohu turu ẹhụ ebahụn nọ fịan Jesu ihiẹn, sị, “Ẹrịra kẹ ya a gwa onyẹ-isi nchụ-ẹjan oku!”
\v 23 Jesu nọ sị a, “Omẹni o nwọn eje-oku m ku, gwa ịhịan ile rị ebeni ihiẹn ọ wụ; kanị, mbụnị ezioku kẹ m ku, k'ị fịanị m ihiẹn?”
\v 24 Ya Anasị nọ si wẹ weri ya lẹ ẹgbụn hụ wẹ kẹn ẹ jẹnni Kayafasị onyẹ-isi nchụ-ẹjan.
\s1 Pita A Ghọrịzị N'ọ Marịn Jesu
\r (Mat 26.71-75; Mak 14.69-72; Luk 22.58-62)
\p 
\v 25 Pita turukwọ ebẹhụ a nyan ọkụn. 'Ya ndị ọzọ nọ sị, “Y'ẹlẹ onyẹ ohu imẹ ụmụ-azụụn okẹnnyẹ hụ?” Kanị, Pita nọ ghọrị, sị, “Mba, ẹlẹ mmẹ.”
\v 26 Onyẹ ohu imẹ ndị idibo onyẹ-isi nchụ-ẹjan, hụn wụ nwẹnẹ okẹnnyẹ hụ Pita banpụ ntịn nọ sị Pita, “Ahụnnị m 'yụ nị 'ya imẹ ụgba ahụn?”
\v 27 Pita nọ ghọrịzị. Ozigbo, ọkpa nọ kwan.
\s1 E We Wẹ Jesu D'e Kunrun Paịleti
\r (Mat 27.1-2, 11-14; Mak 15.1-5; Luk 23.1-5)
\p 
\v 28 Ụzọ-ụtụntụn biribiri, wẹ nọ gha iwe Kayafasị weri Jizọsị si imẹ ọgwa Gọvanọ hụn rị a kịnị. Kanị, abanyeni wẹ imẹ ọgwa hụ, makẹni achọnị wẹ nị wẹ mẹrụ enwẹn wẹ, kẹni wẹ hụn ụzọ ri Oriri-Nghafe hụ.
\v 29 'Ya Paịleti nọ jẹnburu wẹ ezi, sị, “Elee ikpe kẹ ụnụ rị e kpe okẹnnyẹni?”
\v 30 Wẹ nọ sị a, “Omẹni okẹnnyẹni ẹlẹ eje-ịhịan, ẹnyi eke wẹhẹni i y'ẹ.”
\v 31 Paịleti nọ sị wẹ, “Weri n'ẹ, nị ụnụ lẹ enwẹn ụnụ d'e gi iwu ụnụ kin ẹ ikpe.” Ndị-ndu ndị Ju nọ sị a, “Iwu ụnụ tini ẹnyi sị ẹnyi egbulẹ onyẹ ọwụlẹ.”
\v 32 (Hụnnị kẹ ihiẹn Jesu ku banyeni ụdị ọnwụn o jẹnkọ d'a nwụn gi mẹzu.)
\p 
\v 33 Paịleti nọ sizị imẹ ọgwa a, zi wẹ kpọ Jesu; ya ọ nọ jụma Jesu, “Ịyụ wụ eze ndị Ju?”
\v 34 Jesu nọ sị a, “Uche i k'i gidẹ nwan a jụ ajụjụnị ra ndị ọzọ gwa ị oku m?”
\v 35 Paịleti nọ sị a, “I rodẹ ni m wụ onyẹ Ju ra? Ndị Ju ibe i lẹ ndị-isi nchụ-ẹjan we i che m ẹka; k'i mẹ?”
\v 36 Jesu nọ sị, “Alị-eze m ẹlẹ nke ụwanị. Omẹni alị-eze m te wụ nke ụwanị, nkẹ ndị m rị a kị a lụ ọgụn gi gbọndọn wẹ ebulẹ m che ẹka ndị-ndu ndị Ju. Mba, alị-eze m ẹlẹ nke ebeni.”
\p 
\v 37 'Ya Paịleti nọ jụ a, sị, “Eze k'ị wụ nwan?” Jizọsị nọ shịarị a, sị, “Ịyụ ku ni m wụ eze. M bịa d'a shịanị ezioku ẹri: ifiri ẹ kẹ wẹ gi mụ m; ịya haịn m gi bịa imẹ ụwa. Onyẹ ọwụlẹ hụn wụ nke ezioku e gọn ntịn oku m.”
\v 38 Paịleti nọ jụ a, sị, “Kị wụ ezioku?”
\p Paịleti e kugụụ ọhụn, ọ nọ jẹnburuzi ndị hụ ezi.
\s1 A Ma Wẹ Jesu Ikpe-ọnwụn
\r (Mat 27.15-31; Mak 15.6-20; Luk 23.13-25)
\p Ya Paịleti nọ sị ndị hụ rị ezi, “Ahụnnị m ihiẹn ọwụlẹ o mẹ hụn m'e gi ma a ikpe.
\v 39 Kanị, kẹ omẹnalị ụnụ dọn rị, m'a hatu ni ụnụ onyẹ-ngan ohu ogẹn Mmẹmmẹ-Nghafe ọwụlẹ; ụnụ a chọghọ nị m hatu ni ụnụ Eze ndị Ju?”
\v 40 Wẹ nọ yi oro, shịarị a, sị, “Mba, ẹlẹ ịya! Barabasị kẹ ẹnyi chọ!” (Barabasịnị rị ndị a lụsọn ndị Rom rị a kịnị.)
\c 19
\cl Isi Nke Mmitenẹi
\p 
\v 1 Ya Paịleti nọ weri Jesu, we ẹ ye ndị-agha, wẹ nọ gbu ẹ mkpịnsịn.
\p 
\v 2 Ndị-agha hụ nọ gi mkpịnsịn ogun rịsọnmẹ kpa okpu-eze, bu ẹ che ẹ isi; e yimẹ w'ẹ ẹwuru e nwun ufie-rọnị, ufie-rọnị\f + \fr 19:2 \ft ẹwuru ndị nze lẹ ndị-ịdafịn\f*.
\v 3 Wẹ nọ bịa d'e kunrun ẹ mgbe ole-lẹ-ole, a sị, “Isi i chei, eze ndị Ju!” E jẹnburu w'ẹ, a fịan a ihiẹn.
\p 
\v 4 Paịleti nọ jẹnzi d'a gwa wẹ, sị, “Lee ẹ, m jẹnkọ d'e wepụha nị ụnụ 'ya, nị ụnụ marịn nị ahụnnị m njọ o mẹ!”
\v 5 Ya Jizọsị nọ pụha: o kpuhụ okpu ogun; o yihụ ẹwuru pọpụ hụ wẹ yimẹ ẹ. Paịleti nọ sị wẹ, “Lee ni okẹnnyẹ hụ ebeni!”
\p 
\v 6 Ogẹn ndị-isi nchụ-ẹjan lẹ ụnakpa Ụlọ-nsọ gi hụn a, wẹ nọ yi, “Kpọgbu ẹ! Kpọgbu ẹ!” Paịleti nọ sị wẹ, “Weri n'ẹ nwan, nị ụnụ gi ẹka ụnụ kpọgbu ẹ; nị ahụnnị m eje-ihiẹn o mẹ hụn m sikọ d'e gi ma a ikpe.”
\v 7 Ndị-ndu ndị-Ju nọ za, sị, “Ẹnyi nwọnghọ Iwu. Iwu ẹnyi sị n'o furu hụn a nwụnnị, makẹni o weri enwẹn ẹ n'ọ wụ Nwa Osolobuẹ.”
\p 
\v 8 Ogẹn Paịleti gi nụ hụnnị, egun nọ tụkarịd'a k'ọ tụhan a mbụ.
\v 9 Ọ nọ shizi imẹ ọgwa a d'a jụ Jesu ajụjụ, sị, “Elebe k'ị gha bịa?” Kanị Jesu ashịarịn'a.
\v 10 Paịleti nọ sị a, “Ị rị a gba m nkịntịn? Y'a marịn nị m nwọn ikẹn hụn m'e gi hatu i lẹ hụn m'e gi kpọgbu i?”
\v 11 Jesu nọ shịarị a, sị, “O nwọnni ikẹn i nwọn ebe m rị wezụka nị Osolobuẹ gha elu ye 'y'ẹ. Ya wụ, onyẹ hụ bu m che ẹka ị mẹ njọ kanị.”
\v 12 Gha ogẹn Paịleti gi nụ hụnnị jẹnmẹ, ọ nọ mẹmẹ n'ọ hatu Jizọsị ye; kalẹ, igunrun hụ nọ yi oro, sị, “I hatu okẹnnyẹni ye, 'ya wụ nị y'ẹlẹ ọwụ eze-kanị wụ Siza; makẹlẹ, onyẹ ọwụlẹ weri enwẹn ẹ n'ọ wụ eze rị a lụsọn Siza ọgụn!”
\p 
\v 13 Ogẹn Paịleti gi nụ oku ndịnị, ọ nọ wepụha Jizọsị ihun-ezi, nọdị alị elu Oche Okinkin-ikpe elu Mgba-nkpo w'a kpọ “Mgba-nkpo Ọmụma.” (Kanị “Gabata” kẹ w'a kpọ a ọnụ Hibru hụn wụ asụsụ ndị Ju).
\v 14 Ụhụọhịn hụ wụ ụhụọhịn wẹ gi a kwademẹ Mmẹmmẹ-Nghafe. O rumẹ ogẹn anwụn gi a rị isi, Paịleti nọ sị ndị Ju, “Lee ni eze ụnụ!”
\v 15 Wẹ nọ yi oro, sị, “Gbu ẹ! Gbu ẹ! Kpọgbu ẹ!” Paịleti nọ jụ wẹ, sị, “Ụnụ chọ nị m kpọgbu eze ụnụ?” Ndị-isi nchụ-ẹjan nọ shịarị a, sị, “Siza, eze Rom, 'ya sụọ wụ eze ẹnyi nwọn!”
\v 16 Ya Paịleti nọ we Jesu ye ndị-agha d'a kpọgbu.
\s1 A Kpọgbu Wẹ Jizọsị
\r (Mat 27.32-34; Mak 15.21-32; Luk 23.26-43)
\p 'Ya ndị agha nọ weri Jesu.
\v 17 Ọ nọ buru obe\f + \fr 19:17 \ft Ogẹn hụ, obe osisi kẹ ndị-Rom gi e gbu onyẹ wẹ ma ikpe-ọnwụn. O ru, onyẹ wẹ ma ikpe ọnwụn e buru obe ẹ, sọnmẹ ndị-agha hụn jẹnkọ d'a kpọgbun'ẹ. Wẹ kpọmagụụ a elu ya wụ obe, a nọdị wẹ ebẹhụ, e che nche, d'e ru ni ọ nwụnhụn.\f* gha imẹ obodo ahụn pụ, si ebe w'a kpọ “Ebe-Okpokom'isi.” (“Gọgọta kẹ w'a kpọ a ọnụ Hibru hụn wụ asụsụ ndị-Ju”)
\v 18 Ebẹhụ kẹ wẹ nọ kpọma a elu-obe; wẹ kpọmazịkwọ ikẹnnyẹ ẹbụọ elu obe ichẹn-ichẹn che n'ẹ, onyẹ ohu rị azụụnnị, onyẹ ohu rị azụụnnị, Jizọsị rị etintin wẹ.
\v 19 Paịleti nọ de ihiẹn buche elu obe hụ. Ihiẹn o de wụ, “Jesu onyẹ Nazarẹtị, eze ndị Ju.”
\v 20 Ndị bu ọda gụn a, makẹni ebahụn wẹ nọ kpọgbu Jesu nọkunmẹ imẹ obodo hụ lẹzi makẹni wẹ gi asụsụ ndị Ju wụ Hibru lẹ asụsụ ndị Rom wụ Latịnị lẹ asụsụ Griki hụn alị ichẹn-ichẹn a sụ ogẹn hụ de ihiẹn hụ.
\v 21 Ndị-isi nchụ-ẹjan ndị-Ju nọ sị Paịleti, “Edelẹ ẹ ‘Eze ndị Ju,’ kama, de ‘Okẹnnyẹni sị, “Mmẹ wụ eze ndị Ju.” ’ ”
\v 22 Paịleti nọ shịarị, sị, “E degụọ m ihiẹn m de.”
\p 
\v 23 Ndị-agha hụ a kpọmagụụ Jesu elu-obe, wẹ nọ kịrị ẹkwa ndị o yi kebe wẹ ụzọ ẹnọ, onyẹ-onyẹ nọ weri ụzọ ohu-ohu. Nke ẹfẹ tueni o yiye enu ẹ, hụn nwọnlẹni ebe wẹ gi wegbama a makẹni ibe ẹkwa ohu rọchanrịn, gha elu d'e ru alị,
\v 24 ndị-agha ndị hụ a sị ibe wẹ, “Ẹnyi etikakọ n'a; nị ẹnyi tụ nkpọ gi marịn onyẹ sikọ d'e weri n'ẹ.” Ọnwan mẹ kẹni ihiẹn Ẹhụhụọ-nsọ ku hụn ụzọ mẹzu, Ẹkụkwọ-nsọ sị,
\q1 “E keri wẹ ẹwuru m,
\q1 tụ mkpọ gi weri ẹwuru m yiye elu ẹ.”
\p 'Ya kẹ ndị-aghanị mẹ.
\p 
\v 25 Ndị wuzo ẹhụ obe Jesu ogẹn ahụn wụ nnẹ ẹ, nwẹnẹ nnẹ ẹ okpoho, Meri nwunyẹ Klopasị lẹ Meri onyẹ Magidala.
\v 26 Jesu a hụn nnẹ ẹ lẹ nwa-azụụn hụ ihiẹn ẹ a sụọ Jesu kẹ wẹ turu ebẹhụ, ọ nọ sị nnẹ ẹ, “Okpoho, hụnnị wụ nwa ị.”
\v 27 Ọ nọzị sị nwa-azụụn a ahụn, “Hụnnị wụ nnẹ i.” Ya nwa-azụụn hụ nọ gha ẹrịra weri nnẹ Jesu si iwe 'ya wụ nwa-azụụn, nnẹ Jesu nọ du ẹ biri.
\s1 Ọnwụn Jesu
\r (Mat 27.45-56; Mak 15.33-41; Luk 23.44-49)
\p 
\v 28 Omẹgụụ, makẹni Jesu a marịngụọ nị ihiẹn ile e mẹchanrịngụọ, ọ nọ sị, “Ẹgụn mirin rị a gụn m.” O ku okuni n'o gi mẹzu ihiẹn Ẹkụkwọ-nsọ ku.
\v 29 Ite ohu manya rụ-ụka jun rị ebahụn; 'ya wẹ nọ weri ẹru suye imẹ manya hụ, gi mkpịnsịn ihiẹn-akụnkụn w'a kpọ haịsopu wesi ẹ elu, su ẹ ụgb'ọnụ.
\v 30 Manyanị a bangụụ Jizọsị ọnụ, ọ nọ sị, “Ọ gụgụọ!” Ya ọ nọ bu isi kọma alị, nwụnhụn.
\s1 A Dụn Wẹ Jesu Obo Ẹkụnkụn
\p 
\v 31 Makẹni Ụhụọhịn Nkwademẹ Izu-ikẹn rọ—ndị-ndu ndị Ju achọnị nị wẹ latọ ẹhịụ ndị ahụn elu-obe ebẹhụ, ebe o mẹ ni Ụhụọhịn-Izu-ikẹn hụ lalanị arịkẹnmẹkẹ nsọ. 'Ya wẹ nọ sị Paịleti 'ya sị ndị-agha a kpagisọnmẹ ndị hụ wẹ kpọma elu obe ụkụ\f + \fr 19:31 \ft Ọnwan kẹ wẹ gi e mẹ wẹ a nwụnkẹnrin.\f*, kẹni wẹ butusọnmẹ ẹhụ wẹ enu obe.
\v 32 'Ya kẹ ndị-agha hụ nọ jẹnmẹ d'a kpagisọnmẹ ikẹnnyẹ ndị hụ wẹ kpọgbu wẹ lẹ Jesu ụkụ—a kpagi wẹ nke onyẹ ibuzọ, kpagizịkwọ nke hụn-ẹbọ.
\p 
\v 33 Kanị ogẹn wẹ gi ru ebe Jesu rị, a hụn wẹ n'ọ nwụnhụngụọlẹ, 'ya wẹ nọlẹni kpagi ẹ ụkụ.
\v 34 Kama, onyẹ ohu imẹ ndị-agha hụ nọ dụn Jesu obo ẹkụnkụn, ẹdeke lẹ mirin nọ gbapụha.
\v 35 (Onyẹ hụ hụn kẹ ihiẹnni mẹ e kugụọ a, kẹni ụnụ lẹ enwẹn ụnụ hụn ụzọ kweri. Ihiẹn o ku wụ ezioku; ọ marịnghọ nị ezioku rọ).
\v 36 Ihiẹn ndịnị mẹ kẹni ihiẹn Ẹkụkwọ-nsọ ku hụn ụzọ mẹzu: Ẹhụhụọ-nsọ sị, “O nwọnni akpụ ọkpụkpụ a ohu hụn jẹnkọ d'a kpagini\f + \fr 19:36 \ft Ẹsọdọsị 12.46; Nọmbasị 9.12; Ẹbụ-ọma 34.20\f*.”
\v 37 Ẹkụkwọ-nsọ e kugụọzị ebe ọzọ, sị, “Wẹ jẹnkọ d'a gba onyẹ hụ wẹ dụn ihiẹn ilee.”
\s1 Olili Jesu
\r (Mat 27.57-61; Mak 15.42-47; Luk 23.50-56)
\p 
\v 38 Omẹgụụ, Josẹfụ, onyẹ obodo Arịmatịa, nọ jẹn d'a sị Paịleti 'ya buye ẹ ẹhụ Jizọsị (Josẹfụ gi nzuzue e sọn ụzọ Jesu makẹni egun ndị-ndu ndị Ju rị a tụ a). Paịleti nọ kweri, sị a d'e buru ẹhụ Jesu; 'ya ọ nọ jẹn d'e buru ẹ.
\v 39 Nikodimọsị hụn bịa d'e kunrun Jizọsị imẹ ukinkin ogẹn mbụ nọ sọnmẹ Josẹfụ. Nikodimọsị wẹhẹ udẹn e shin ọhụnma wẹ gi ẹhụhụọ maa lẹ alo mẹmẹ, hụn nyịnkarị nkirishi ẹkpa nnu.
\v 40 Ikẹnnyẹ ẹbụọ hụ nọ buru ẹhụ Jesu, gi ẹkwa linẹ fụgbamẹ 'ya lẹ ihiẹn ndị ahụn e shin ọhụnma—rịkẹ kẹ ndị Ju dọn a kwama ozun wẹ k'e li.
\v 41 O nwọn ụgba rị ebahụn wẹ nọ gbu Jesu; ili-okporo ọhụn wẹ kelẹni liyetu ịhịan rị imẹ ụgba hụ.
\v 42 Makẹni Ụhụọhịn hụ ndị Ju gi a kwademẹ Izu-ikẹn a gụmagụọ bụ ili hụ rị nsue, wẹ nọ gwẹrụ bu ẹhụ Jesu che ili ahụn rị ebẹhụ.
\c 20
\cl Isi Nke Ọgụn
\s1 Okpokoro Ili
\r (Mat 28.1-8; Mak 16.1-8; Luk 24.1-12)
\p 
\v 1 Ụzọ-ụtụntụn ụhụọhịn ibuzọ imẹ izu-ụka\f + \fr 20:1 \ft hụn wụ nwan ụhụọhịn Sọnde\f*, ebe eki kelẹni fọngụụ, Meri onyẹ Magidala nọ jẹn ili hụ hụn nọ kẹ okporo. 'Ya k'ọ nọ hụn a nị e nupụgụọ wẹ ọmụma hụn rị ọnụ ili hụ.
\v 2 Ọ nọ gi ọsọ jẹn d'e kunrun Saịmọnụ hụn w'a kpọ Pita lẹ nwa-azụụn ọzọ hụ ihiẹn ẹ a sụọ Jesu, sị wẹ, “E bupụgụọ wẹ Di-nwọnni-ẹnyi imẹ ili hụ bụ ẹnyi amarịn ebe wẹ buche ẹ.”
\v 3 'Ya kẹ Pita lẹ nwa-azụụn ọzọ hụ nọ gbashi ili hụ.
\v 4 Nwa-azụụn hụn-ẹbọ hụ nọ gbaghafe Pita, bu ụzọ ru ebahụn.
\v 5 O hulụa alị, nyọnye imẹ ili, 'ya ọ nọ hụn ẹkwa linẹ ndị ahụn wẹ te gi kwama Jesu ebe wẹ rị alị ebẹhụ, kanị ọ banyeni imẹ ili hụ. \fig Ili gba oghe lẹ ọmụma wẹ te gi nukin ẹ wẹ nupụgụụ|src="lb00329b.jpg" size="span" loc="JHN 20" copy="Horace Knowles; The British & Foreign Bible Society" ref="20.5"\fig*
\v 6 Saịmọn' Pita hụn sọnkọ a azụụn e ru ebẹhụ, ọ nọ shi imẹ ili hụ ozigbo-ozigbo. Ọ nọ hụn ẹkwa linẹ ndị hụ alị ebẹhụ,
\v 7 hụnzị ẹkwa hụ te rị isi Jesu. Ẹkwa hụ te rị isi Jesu lẹ linẹ ndị ahụn arị ụzọ ohu; kama, wẹ fụma ẹkwa hụ te rị isi Jesu, bu ẹ tọ nkọ ohu.
\v 8 Ya nwa-azụụn hụn-ẹbọ hụ, hụn bu ụzọ ru ili hụ nọ banyezikwọ; ọ hụn, ọ nọ kweri.
\v 9 (Ogẹn ahụn, w'e ke ghọtakwọ ihiẹn hụ Ẹhụhụọ-nsọ ku—n'o jẹnkọ d'a gha ọnwụn lihi.)
\v 10 Ya ụmụ-azụụn a ndị ahụn nọ lashisọnmẹ iwe wẹ.
\s1 Meri Onyẹ Magidala A Hụn Jesu K'ọ Ghagụụ Ọnwụn Lihi
\r (Mat 28.9-10; Mak 16.9-11)
\p 
\v 11 Kanị Meri e turukwọ ihun ili hụ, a kwan ẹkwan. K'o dọn rị a kwankwọ, o hulụa alị, nyọnye imẹ ili hụ,
\v 12 ọ nọ hụn ndị mmọn-ozi ẹbụọ yi ẹkwa ọchan kẹ wẹ nọdị alị ebahụn ẹhịụ Jesu te rị, onyẹ ohu rị ibe isi ẹ, hụn-ẹbọ rị ibe ọkụ a.
\v 13 Wẹ nọ jụ a, sị, “Okpoho, k'ị rị a kwannị?” Ọ nọ shịarị wẹ, sị, “E wepụgụọ wẹ Di-nwọnni-m, bụ a marịn m ebe wẹ buche ẹ!”
\v 14 Ogẹn o gi kugụụ ihiẹnni, ọ nọ gbehutọ, hụn Jesu k'o turu ebẹhụ, kanị ọ marịn nị Jesu rọ.
\v 15 Jesu nọ jụ a, sị “Okpoho, k'ị rị a kwannị? Onyẹ k'ị rị a chọ?” Meri ro ni onyẹ hụn e lefụ ugbo-nta hụ ẹnya rọ, 'ya ọ nọ sị a, “Di-ọkpa, ọwụnị 'yụ bupụ a, gwa m ebe i buche ẹ, m k'e jẹn d'e buru ẹ.”
\v 16 Jizọsị nọ hị a, “Meri!” Meri nọ gbehutọ bu ihun zinmẹ ẹ, gi asụsụ Hibru yi, “Raboni!” (Raboni wụ Onyẹ-nkuzi asụsụ ndị Ju)
\v 17 Jesu nọ sị a, “Ekwọndọnlẹ m ẹka, makẹni m'e ke jẹn elu-igwee d'e kunrun Chuku-Nẹdi. Ka jẹn d'e kunrun umunẹ m, y'a sị wẹ, ‘M lakọ elu-igwee d'e kunrun Nẹdi m hụn wụzị Nẹdi ụnụ, Osolobuẹ m hụn wụzị Osolobuẹ ụnụ.’ ”
\v 18 'Ya kẹ Meri onyẹ Magidala nọ jẹn d'a gwa ụmụ-azụụn Jesu, sị, “A hụngụọ m Di-nwọnni-ẹnyi!” Ya k'ọ nọzị gwachanrịn wẹ ihiẹn ndị hụ ọ gwa a.
\s1 Jesu E Nwọnpụha Ebe Ụmụ-azụụn A Rị
\r (Mat 28.16-20; Mak 16.14-18; Luk 24.36-49)
\p 
\v 19 Ẹnyasị ụhụọhịn hụ, hụn wụ ụhụọhịn ibuzọ imẹ izu-ụka, ụmụ-azụụn Jesu nọ kpọkin enwẹn wẹ ye ebe wẹ rị makẹni egun ndị-ndu ndị-Ju rị a tụ wẹ. Ya Jesu nọ nwọnpụha idẹnmizi d'e turu imẹ igunrun wẹ, sị, “Udọn 'ya rị nị ụnụ.”
\v 20 Ogẹn o gi kugụụ ihiẹnni, ọ nọ ghọsị wẹ ẹka a ẹbụọ lẹ ẹkụnkụn a. Ogẹn ụmụ-azụụn a gi hụn Di-nwọnni-ẹnyi, ịghọghọ e jun wẹ obi.
\v 21 Jizọsị nọzị nwan sị wẹ, “Udọn 'ya rịnị ụnụ. Kẹ Chuku-Nẹdi dọn zi m kẹ m rị nwan e zi ụnụ.”
\v 22 O kugụụ ihiẹnni, ọ nọ horokpu wẹ, sị, “Narịn nị Mmọn-nsọ.
\v 23 Ụnụ gbagharị ịhịan njọ wẹ, Osolobuẹ a gbagharị wẹ ya; omẹni ụnụ agbagharịnị wẹ njọ wẹ, Osolobuẹ agbagharịkọ wẹ.”
\s1 Jesu Lẹ Tamọsị Hụn Rụ-ụka
\p 
\v 24 Tamọsị (hụn w'a kpọ Ejimẹ), hụn wụ onyẹ ohu imẹ wẹ mmẹbụọ, arị imẹ wẹ ogẹn Jesu gi bịa.
\v 25 'Ya ụmụ-azụụn ibe ẹ nọ sị a, “Ẹnyi a hụngụọ Di-nwọnni-ẹnyi.” Kanị Tamọsị nọ sị wẹ, “Manị m hụn ebe wẹ dụsọnmẹ ẹ ntu ndị hụ ẹka ẹbụọ, bu mkpịnsịn-ẹka m che ebe ntu ndị hụ rụsọnmẹ ẹ ẹhụ ẹka ẹbụọ, e bu m ẹka che ẹkụnkụn a—ekwerikọ m!”
\p 
\v 26 Hụn mẹ ẹ izu-ụka, ụmụ-azụụn Jesu rịzị imẹ ụlọ; uwẹ lẹ Tamọsị rị. Ụzọ kpọkin akpọkin, kanị Jesu nọ nwọnpụha, turu imẹ igunrun wẹ, sị, “Udọn 'ya rịnị ụnụ.”
\v 27 'Ya ọ nọ sị Tamọsị, “Bu mkpịnsịn-ẹka ị che ebeni, lee ẹka m ẹbụọ; tịnpụ nwan ẹka ị buche m ẹkụnkụn. Arụzịlẹ ụka; kweri!”
\v 28 Tamọsị nọ za a, sị, “Di-nwọnni-m lẹ Chuku m!”
\v 29 Jesu nọ sị a, “I kweri makẹlẹ y'a hụngụọ m? Ngọzi wụ nke ndị hụn kelẹni hụn bụ e kweri wẹ.”
\s1 Ihiẹn Wẹ Deni Ẹkụkwọnị
\p 
\v 30 O nwẹghọzị ọrụn-atụmẹnya ndị ọzọ bu ọda wẹ deyelẹni imẹ ẹkụkwọnị hụn Jesu rụnzị idẹnya ụmụ-azụụn a.
\v 31 Kanị, wẹ deye ndịnị kẹni ụnụ hụn ụzọ kweri nị Jesu wụ Kraịstị, Nwa Osolobuẹ, Onyẹ Hụ Osolobuẹ Tumẹ; lẹ ni ụnụ gi ẹfan a nwọn ndụn ghahanị ikwerinin'ẹ.
\c 21
\cl Isi Nke Ohu-kwasị-ọgụn
\s1 Jesu E Nwọnpụhazị Ebe Ụmụ-azụụn A Rị
\p 
\v 1 Ihiẹn ndịnị e mẹgụụ, Jesu nọ nwọnpụhazị d'e kunrun ụmụ-azụụn a mkpẹnrẹn “Ohimin” Taịberiasị. Ẹnịna k'o dọn mẹ:
\v 2 Saịmọnụ hụn wụ Pita, lẹ Tamọsị (hụn w'a kpọ Ejimẹ) lẹ Natanẹlụ (onyẹ obodo Kana rị Galili) lẹ ụmụ-ikẹnnyẹ Zẹbẹdi lẹzi ụmụ-azụụn Jesu ẹbụọ ọzọ gba nọdị.
\v 3 Saịmọn' Pita nọ sị ndị ahụn ya lẹ wẹ rị, “E shi m d'e gbu azụụn.” Wẹ nọ sị a, “Ẹnyi sikọ d'e sọnmẹ i.” 'Ya wẹ nọ jẹnmẹ. Wẹ nọ banye ụgbọ-mirin d'e gbumẹ. Kanị, egbuni wẹ ihiẹn ọwụlẹ ukinkin hụ ile.
\p 
\v 4 Ogẹn eki gi fọngụụ, Jesu nọ turu mkpẹnrẹn mirin; kanị ụmụ-azụụn a amarịn nị Jesu rọ.
\v 5 'Ya k'ọ nọ jụ wẹ, sị, “Ụmụẹka, o ke nwọn azụn ụnụ gbu?” Wẹ nọ za, sị, “Kaka akp'ohu.”
\v 6 Ọ nọ sị wẹ, “Tụ nị ọga ụnụ ye azụụn ẹka-nni ụgbọ ụnụ, ụnụ jẹnkọ d'e gbu azụn.” 'Ya wẹ nọ tụye ọga hụ, o te nịzịnị wẹ dọbanhan imẹ ụgbọ, makẹni azụn wẹ gbu e bukẹ ọda.
\p 
\v 7 Nwa-azụụn hụ ihiẹn ẹ a sụọ Jesu nọ sị Pita, “Di-nwọnni-ẹnyi rọ maị!” Ogẹn Pita gi nwan nụ nị Di-nwọnni-ẹnyi rọ, ọ nọ yiri ẹwuru o yiye elu ẹ (makẹni o te yipụgụụ a). Ya ọ nọ tụban imẹ mirin.
\v 8 Ụmụ-azụụn isin ahụn họdụ imẹ ụgbọ nọ gi ụgbọ dọkpụnpụha ọga hụ azụn jun mkpẹnrẹn mirin. Gha ebẹhụ wẹ rị d'e ru mkpẹnrẹn-mirin eteni—ihiẹn rịkẹ ama-ụkụ iri kwasị ọgụn-isin sụọ rọ; o ruchanrịnnị polu ẹbụọ.
\v 9 Ogẹn wẹ gi ru mkpẹnrẹn mirin, wẹ nọ hụn oboko ọkụn ebahụn; azụn rị elu ẹ; brẹdi hụzịkwọ ebẹhụ.
\v 10 Jesu nọ sị wẹ, “Wẹhẹ ni azụn imẹ ndị hụn ụnụ gbu kikẹnni.”
\v 11 Ya Saịmọnụ wụ Pita nọ si imẹ ụgbọ-mirin, dọkpụnpụha ọga hụ mkpẹnrẹn mirin. Azụn hisọnmẹ ogbe jun ẹ, azụn mmẹtọ-kwasị-ọgụn-ẹsa. Azụn rị imẹ ọga hụ e bukẹnmẹkẹ ọda bụ ọga hụ etikanị.
\v 12 Jesu nọ sị wẹ, “Bịa nị nwan d'e ri ihiẹn-oriri ụtụntụn.” Bụ o nwọnni nwa-azụụn a ọwụlẹ egun nị jụ a, “Onyẹ k'ị wụ?” makẹni a marịngụọ wẹ nị Di-nwọnni-ẹnyi rọ.
\v 13 'Ya kẹ Jesu nọ jẹn d'e weri brẹdi hụ ye wẹ, werizikwọ azụn hụ ye wẹ.
\p 
\v 14 Ọnwan mẹ ẹ mgbe ẹtọ ụmụ-azụụn Jesu hụn a k'ọ ghagụụ ọnwụn lihi.
\s1 Jesu E Wekinhẹzi Pita Ọnọdị A
\p 
\v 15 Ogẹn wẹ gi rigụụ ihiẹn-oriri ụtụntụn ahụn, Jesu nọ sị Saịmọnụ wụ Pita, “Saịmọnụ nwa Jọnụ, ihiẹn m a sụọghọ ị karị ndịnị?” Ọ nọ za, sị, “Ẹghẹẹ Di-nwọnni-ẹnyi, 'y'a marịnghọ nị ihiẹn i a sụọghọ m.” Jesu nọ sị a, “Lefụ ụmụ-atụnrụn m ẹnya.”
\v 16 Jesu nọ jụ a hụn mẹ ẹ mgbe ẹbụọ, sị, “Saịmọnụ nwa Jọnụ, ihiẹn m a sụọghọ ị?” Ọ nọ za, sị, “Ẹghẹẹ Di-nwọnni-ẹnyi, 'y'a marịnghọ nị ihiẹn i a sụọghọ m.” Jesu nọ sịzị a, “Lefụ atụnrụn m ẹnya.”
\v 17 Jesu nọ jụzị a 'ya hụn mẹ ẹ mgbe ẹtọ, “Saịmọnụ nwa Jọnụ, ihiẹn m a sụọghọ ị?” Ọ nọ fụ Pita nị Jesu jụ a ya mgbe ẹtọ, “Ihiẹn m a sụọghọ ị?” Pita nọ sị a, “Di-nwọnni-ẹnyi, 'y'a marịnghọ ihiẹn ile; y'a marịnghọ nị ihiẹn i a sụọghọ m.” Jesu nọ sị a, “Lefụ atụnrụn m ẹnya.
\v 18 M rị a gwa ị ezioku, ogẹn i gi rị okoro, y'e kọnrin, e jẹn ebe ọwụlẹ sụọ n'ị; kanị ị kagụụ ẹgẹdi, i jẹnkọ d'a tịnpụ ẹka ị, ndị ọzọ e kọnmẹ i, we i si ebe i chọlẹni n'i jẹn.”
\v 19 (Jesu gi ihiẹnni o ku ghọsị ụdị ọnwụn Pita jẹnkọ d'a nwụn gi wẹhẹ ni Osolobuẹ ọghọ).
\p Jesu e kugụụ ihiẹnni, ọ nọ sị Pita, “Sọnmẹ m!”
\s1 Jesu Lẹ Pita Lẹ Nwa-azụụn Ahụn Ihiẹn Ẹ A Sụọ Jesu
\p 
\v 20 Pita e lee ẹnya azụụn, ọ nọ hụn nwa-azụụn ọzọ hụ ihiẹn ẹ a sụọ Jesu. (Hụn nọsọn Jizọsị ogẹn wẹ gi rị e ri ihiẹn-oriri ẹnyasị ahụn, nwa-azụụn hụ hụn jụ Jizọsị, sị, “Di-nwọnni-ẹnyi, onyẹ jẹnkọ d'e re i?”)
\v 21 Ogẹn Pita gi hụn a, ọ nọ jụ Jesu, sị, “Di-nwọnni-ẹnyi, okẹnnyẹni?”
\v 22 Jizọsị nọ sị a, “Omẹni m chọ n'ọ rị ndụn d'e ru mgbe m bịa, ẹlẹ hụn biri i? Sọnmẹ m!”
\v 23 'Ya okuni nọ kpọgbama imẹ igunrun ndị e sọn Jesu, nị nwa-azụụnnị anwụnkọ. Kanị, Jizọsị ekuni n'ọ nwụnkọ, ihiẹn o ku wụ, “Omẹni, m chọ n'ọ rị ndụn d'e ru mgbe m bịa, ẹlẹ hụn biri i?”
\p 
\v 24 Ya wụ nwa-azụụn wụ onyẹ hụn rị nwan e ku oku ihiẹn ndịnị; ịya detuzikwọ nwan ndịnị wẹ; ẹnyi a marịnghọ nị ihiẹn o ku wụ ezioku.
\s1 Mmẹkin
\p 
\v 25 Kanị, o nwẹzikwọ ihiẹn ndị-ọzọ bu ọda Jesu mẹ. Omẹni wẹ dechanrịn wẹ ile ohu-ohu, e roghọ m'a nị ụwa ile erugụkọ ẹhụhụọ wẹ sikọ d'e gi de wẹ.
