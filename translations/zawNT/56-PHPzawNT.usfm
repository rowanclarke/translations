\id PHP
\h Filipenses
\toc1 Te Guijtz Lo Rebeṉ Filipos
\toc2 Filipenses
\toc3 Fil.
\mt1 Te Guijtz Lo Rebeṉ Filipos
\c 1
\s1 Latzguiib yu' Pabl bacuaani loj rebeṉguidoo xten guedx Filipos
\p 
\v 1 Pabl näjza Timoteu, nani najc rexmos Jesucrist, rucuaanu guijtzre lo guiraa rexpejṉ Jesucrist nani rbäjz guedx Filipos, loj rebejṉ nani ruluii xtidx Dios neṉ reguidoo näjza loj rediaconos.
\v 2 Gacnäj Dios la'tu con yäḻrbedxi-lajz xten Xtadnu näjza xten Dad Jesucrist.
\s1 Rniab Pabl lo Dios xcuent rebejṉ nani rililajz
\p 
\v 3 Che rnaj lazä la'tu, rudedä xquixtios lo Dios.
\v 4 Che rniabä lo Dios, rbaa lazä rniabä lo Dios xcuent la'tu,
\v 5 sa'csi abidxaag sa'nu lo xtidx Jesucrist che guslojli huililajztu hasta ṉajli.
\v 6 Anancheä Dios nani gusloj cayunsa'c dzuun neṉ lastootu, lagajc laani suluxsa'c dzuunga dxejli ni jiääd Jesucrist.
\v 7 ¿Xhiru xhigab nungäjḻ gunä? Ni rapä la'tu neṉ lastoä sa'csi cayacnäjtu narä neṉ latzguiib luxh rsiudzu'tztu riye'tztu lo bejṉ, gulii najc rediidx nani rusule'ä xcuent Jesucrist näjza la'tu rusule'tu rediidxga.
\v 8 Dios nanchee xho rbaṉnää́tu, xho sanälazä guiraatu lo xcäḻsanälajz Jesucrist.
\v 9 Rniabä lo Dios te tioobru xcäḻrinälajztu näj xcäḻnajntu nägajc churu xcäriejn guiraatu,
\v 10 te cuetu nani najc dzunsa'c te si'c guibaṉ nayatu, te na'c ga'ptu nicla tej dojḻ cheni jiääd Jesucrist.
\v 11 Te guidxa lastootu yälnasa'c xten te yäḻnabaṉsa'c ni runiidx Jesucrist, te guspaa lajztu Dios, guiliä'ptu xpala'nni.
\s1 Jesucrist najc xcäḻnabaṉä
\p 
\v 12 Rlazä gacbeetu betzä: guiraa nani gusacä ni'c cayacnäj guire'chru xtidx Jesucrist.
\v 13 Ni'c guiraa rebejṉ, renani yu' jusgaad sigajc renani yu' garenca lajt, anajnreni niäuä latzguiib xcuent Crist.
\v 14 Xhidajlru resa'nu cheni gucbeereni yu'ä latzguiib, gusudzu'tzru lajzreni, direni nidxejb, guniirureni xtidx Dios.
\p 
\v 15 Guliica yu' reni rusule' xtidx Jesucrist sa'csi rdxe'ch lajzreni, rdxe'chzareni loä. Yu'za reni rusule' xtidx Jesucrist sa'csi laaca najc xhigabreni.
\v 16 Yu'reni rusule' xtidx Jesucrist sa'csi rdxe'chreni, xhet sa'csi laaca najc xhigabreni, alga rujnreni xhigab gustioobrureni trabajw nani tedä neṉ latzguiib.
\v 17 Niluxh yu' reni rusule' rediidxga sa'csi sanälajzreni Jesucrist. Anajnreni yu'ä latzguiibre te gusule'äru guliipac najc xtidx Jesucrist.
\v 18 Niluxh ¿xhiru najcni? Palga rujnsireni laaca o palga guluiipac laaca najc xhigabreni rusule'reni xtidx Crist; rbaa lazä sa'csi care'ch xtiidxni niluxh sibaaru lazä.
\v 19 Ananä laaca guiriä loj guiraa recosre sa'csi canabtu lo Dios xcuentä. Luxh xcäḻracnäj Sprit xten Jesucrist
\v 20 rujn runloä, rbäzäza dina jianxtuiä. Ni'cni dina guidxebä guiniä, si'cni runäpac, sigajcza runä ṉaj te gac guiliä'pä xpala'n Jesucrist con tiexhä palga guibaṉä o palga guetä.
\v 21 Sa'csi palga guibaṉä, su'ä lo Jesucrist; luxh palga guetä sunäru gaan.
\v 22 Palga guibaṉäru lo guedxliujre, sajcru gunä xtzuun Dad Jesucrist, ni'cni dina gacbeä xhinic cueä xca'ä.
\v 23 Nagajn najcni par narä cueä lo guiro'preni. Te lajt runä xhigab: malaii guetä te cha'a cadro yu' Jesucrist sa'csi ni'c najc hueenru par narä.
\v 24 Niluxh stee lajt nancheä nungäjḻ guibaṉäru lo guedxliujre xcuent la'tu.
\v 25 Niluxh narä racbeäpac siannää́ru la'tu, su'äru lojtu te chanuurutu lo xtidx Jesucrist, te guibalajztu lo yäḻrililajz,
\v 26 te guibalajzrutu xcuentä loj Jesucrist che guibisacä lojtu stehuält.
\p 
\v 27 Coḻhuiitis guibajṉtu si'cpac ni rnii xtidx Jesucrist, te palga jiädhuiätu o palga ruti narä, jiejn diagä sugadzu'tztu, rujntu tejsi xhigab, nadxaag sa'tu rujntu tejsi dzuun con yäḻrililajz xten xtidx Jesucrist.
\v 28 Na'c guidxejbditu renani rdxe'ch lojtu. Laareni huenliisi ruseṉ agunijtreni ni'c rdxe'chreni, ni'cni la'tu huenliisi ruseṉ aguḻaatu neṉ dojḻ si'c baniidx Dios, ni'cni ditu guidxe'ch.
\v 29 Sa'csi lojtu abaniidx Jesucrist chalilajztu xtiidxni. Niluxh xhet ni'ctis; nägajcza tedtu trabajw xcuent laani.
\v 30 Cadejdtu lagajc trabajw ni cahuiitu gudedä luxh ṉaj riejn diajgtu cadedsicä trabajwga.
\c 2
\s1 Xcäḻnalaslajz näjza xcäḻgurobduxh Jesucrist
\p 
\v 1 ¿La ruspaa Jesucrist lajztu? ¿La racnäj xcäḻrinälajztu la'tu? ¿La yu' Sprit Dxan xtenni con la'tu? ¿La yu' xcäḻsanälajzni näj xcäḻrulaslajzni lastootu?
\v 2 Palga yu'ni, coḻguspaa lazä, coḻyejn tejsi xhigab con narä, coḻga'p lagajc yäḻsanälajzga, coḻguidxaag sa'tu, coḻyejn tejsi xhigab.
\v 3 Na'c guntu nicla tej dzuun sa'csi cayutu lagajc la'tu, na'cza guntu dzuun te chä'p xpala'ntu. Coḻyejn xtzuuntu con yäḻnalaslajz, coḻhuii loj sa'tu si'c beṉroru lojtu.
\v 4 Na'c jiu chu tejtu lagajctis xhixtenni, coḻjiu tejgatu xhixten sa'ni.
\p 
\v 5 Coḻga'p lagajc sa' xhigab nani gojpza Jesucrist
\v 6 nani mase najcni sigajc Dios, dini niniazdzu'tz xcäḻrnibee Dios,
\v 7 alga basa'nni te laad yäḻrnibee nani rajpni con Xtadni Dios te gujcni mos cheni gojlni lo guedxliujre. Gujcni si'ctis te bejṉ.
\v 8 Che gujcni si'ctis beṉ guedxliuj, gujcni beṉ nadolajz, beṉ nasobdiidx. Basoobni xtidx Dios, gujtni lo crujz, luxh yäḻrejt lo crujz najc te yäḻrtuiduxh.
\v 9 Ni'cni baspaṉsac Diosni, gule'cni Crist te lajt ni najc jiaaru, badeedza Dios sajcru lajni lo laj guiraa relaj ni rusä't bejṉ.
\v 10 Luxh che jiejn diajgreni laj Jesucrist, suzuxhijb guiraa reni yu' xhaguibaa, guiraa reni yu' lo guedxliuj, näjza guiraa reni yu' nez neṉ yuj.
\v 11 Te guiraareni gacbeepac, guiniizareni: “Jesucrist najc Dad”, te si'c chä'pduxh xpala'n Xtadnu Dios.
\s1 Rexpejṉ Jesucrist najc si'c bajl ni rusanij lo guedxliuj
\p 
\v 12 Ni'cni, resa'ä ni sanälazä, sigajcni rusoobtu xtidxä cheni suganää́ la'tu, sigajcza coḻgusoob xtidxä ṉaj ni yu'ä zijt, coḻhuii tejgatu xho gac ḻaatu neṉ dojḻ, coḻyajc bejṉ ni rusoob diidx con yäḻrdxejb.
\v 13 Sa'csi Dios najc ni rujn dzuun neṉ lastootu te rajc rujntu xhigabsa'c, dxejc racnäjzani la'tu te rajc rujntu si'cni rlajzni.
\p 
\v 14 Loj guira'ti ni rujntu, na'c gusmojm̲tu, na'cza gun tiop lajztu,
\v 15 te rut gucuaquijditu, te gactu bejṉ ni ruchaag chutis bejṉ, gactu xi'n Dios, bejṉ nani xhet xtojḻdini yu' laḻ ni tre'tu loj rebeṉguijdx ni rujn redzundxuudx. Nez lojreni gactu si'c te bajl ni rdimbicha' si'c rebalxhaguibaa che nacäjy,
\v 16 sa'csi arapdzu'tztu xtidx yäḻnabajṉ ni runiidx Crist neṉ lastootu te guspaatu lazä dxej cheni jiääd Jesucrist, sa'csi xhet xlia'di gujc xtzunä, xhetza xlia'di cayunä dzuun ṉaj.
\v 17 Mase lagajc xtienä guixe' te guiza' te gojn ni xca' Dios xcuent xcäḻrililajztu, rbaa lazä, sibalaznää́za la'tu.
\v 18 Sigajcza coḻguibaa lajztu, coḻguibalaznäj narä.
\s1 Timoteu con Epafrodito
\p 
\v 19 Nez loj Dad Jesucrist cayunloä guxhaḻgacä Timoteu lojtu te näjza narä guibaa lazä che agucbeä xho yu'tu nejzga.
\v 20 Sa'csi rutru rapädi nani rujn tejsi xhigab, tej ni guliipac gun dzuun, jiupacni la'tu.
\v 21 Guiraa rebejṉre rujntis xtzuuncareni, direni jiu gunreni xtzuun Jesucrist.
\v 22 Niluxh la'tu anajntu xho rujn Timoteu; si'c racnäj te bi'n xtadni, si'cza racnäjni narä lo xtidx Jesucrist.
\v 23 Ni'cni rlazä guxhaḻäni te jiädhuiini la'tu, fixgaä́si don xho sasaj xcuentä ree.
\v 24 Cabäzäza nez lo Dad Jesucrist don la näjza narä sajl jiädhuigacätu.
\p 
\v 25 Niluxh rchaloä nanabpac guxhaḻä bejtznu Epafrodito ni najc sa'ä loj dzuun, loj retrabajw ni cadejdnu. Lagajc la'tu baxhaḻtuni te jiuni narä, fiini xhini'c rquinä.
\v 26 Laani rlazduxhni fiini lojtu, lacti cayu'ni yärsia' sa'csi gucbeetu gucxhuuni.
\v 27 Guliica gucxhuuni cuentro, ameer niejtni, niluxh Dios balaslajzni laani, luxh xhet laatisni, balaslajzzani narä te di nidedäru loj yäḻnahuinlajz ni yu'ä ree.
\v 28 Ni'cni rlazä guxhaḻgacäni te guibalajztu che fisactu lojni, näjza te na'cru gac-huinlazä xcuent la'tu.
\v 29 Coḻca'ni con yäḻrbalajz si'c bejtztu lo xtidx Dios, sigajcza coḻyejn reni najc sigajc laani.
\v 30 Xcuent xtzuun Jesucrist ameer niejtni, dini niu xcäḻnabajṉtisni te bejnni redzuun nani di niajcdi niujntu lagajc la'tu xcuentä.
\c 3
\s1 Te yäḻnabaṉsa'cpac
\p 
\v 1 N̲aj rebetzä, coḻguibalajz nez lo Dad Jesucrist. Xhet najcdi gucuasacä lagajc rediidx nani abacuaä lojtu, sa'csi sacnäjni la'tu.
\v 2 Coḻnati renani najc si'c bä'cw. Coḻnatiza rebejṉ nani rujn dzun guijdx. Coḻnatiza reni ru' bee tiejxhtisreni luxh xlia'si rujnreni si'c.
\v 3 Renani guliipac yu' bee najc nuure nani ahuililajz xtidx Dios, rienzanu xtzuunni si'cni rlajzni sa'csi ayu' Sprit Dxan xtenni neṉ lastoonu. Rbalaaznu sa'csi najcnu xpejṉ Dad Jesucrist, xhet xcuentdi redzuun ni rujn tiejxhnu.
\v 4 Narä sajcza guibalazä xcuent ni rujn tiexhä. Palga yu' chu tej ni rbalajz, narä rbalazäru
\v 5 sa'csi guyu'ä bee che guyu'ä xhujṉ gubijdx; narä nacä te rexpejṉ Israel; narä nacä tej rexpejṉ toBenjamín, nacä te hebreo, luxh xtadä najc te beṉ hebreo; xcuent leii nacä te farisee.
\v 6 Basobduxhä guiralii rextidx Dios ni caj lo leii ni'cni basacsiduxhä rexpeṉ Jesucrist; xcuent yäḻnabaṉsa'c xten leii, xhetliidi xtoḻä yu'; basobdzu'tzä xtidx leii.
\v 7 Niluxh ṉaj rediidx nani galoo benä xhigab sacduxh, ṉaj xhet sajcdini sa'csi sanälazä Jesucrist.
\v 8 Niluxh maazru runä: runä xhigab xhet sajcdi guiraa nani rapä, sa'csi maazru sacduxh yäḻriembee Jesucrist ni najc Dad xtenä. Xcuent Jesucrist gulälazä guira'ti, guira'ti najc si'c guixbiujy nez loä te gunä gaan Jesucrist,
\v 9 te chu'ä lojni, xhet xcuentdi xcäḻnabaṉsa'cä ni najc xcuent leii, alga xcuent yäḻnabaṉsa'c ni najc xcuent xcäḻrililajz Jesucrist, yäḻnabaṉsa'c ni najc xten Dios xcuent yäḻrililajz.
\v 10 Ni'cni rlazä gumbeäru Jesucrist loj yäḻrnibee ni rajpni sa'csi huistie gubaṉsa'cni sacni loj rebeṉgut, te gumbeäru retrabajwduxh ni gudejdni, te ganä xho gunä ni rlajz Dios si'c gucbee Jesucrist, bejnzani ni rlajz Dios che gujtni.
\v 11 Te gac guidzuṉä lo yäḻguibaṉsac loj rebeṉgut te xca'ä yäḻnabajṉ par tejpas lo Dios.
\p 
\v 12 Dizana guiniä “abenä gaan” o “anacä beṉsa'c”, alga sanuätis te gunä gaan yäḻnabajṉ nani cua'ä lo Jesucrist.
\v 13 La'tu rebetzä, dipacna gunä cuent alabenä gaan, niluxh tejtis nani runä, riaḻlazä nani agudejd, rusgaä ṉaä si'cni guiniazä nani churu gac.
\v 14 Si'cni sanuutis ruxuṉ bejṉ te gunni gaan xhi guzalajzni, si'cza sanuutis cayunä dzuun nani baniidx Jesucrist loä, te che abenä gaan dzuunga sica'ä ni guzalajzni, nalajznu sibejdx Dios narä cha'a loj Jesucrist.
\p 
\v 15 Guiraanu nani ahuililajznu, nanab jiennu lagajc xhigabga, niluxh palga la'tu guntu ste'ca xhigab, rchaloä lagajc Dios suluilojni lojtu xcuent ni et laadi cayujntu.
\p 
\v 16 N̲aj, cadrotis abidzuṉnu lo nani abiembeenu, sigajcza nanab guibaṉsijcnu, chanuutis gusoobnu rediidxga; nungäjḻ guibajṉnu loj rediidxre, jiennu tejsi xhigab.
\p 
\v 17 Rebetzä, coḻtanajl narä, coḻyejn si'c runä narä, coḻhuiiza rebejṉ nani nabajṉ si'c nabaṉä.
\v 18 Xhidajl huält aguniä lojtu, ṉaj ronäli rnisacä lojtu, yu' xhidajl reni rdxe'ch lojtu, rniyajreni nani bejn Jesucrist che gudijxni xtojḻnu lo crujz.
\v 19 Redee che luux xnezyujreni sinitlojreni, sa'csi xtioozreni najc yäḻrausa'c; luxh rbaali lajzreni rujnreni dzun xtujy; luxh riutisreni xcäḻnasa'c guedxliujre.
\v 20 Niluxh nuure, xhaguibaali najc laadxnu, luxh ro'cli cabääznu jiääd nani rusḻaanu neṉ dojḻ, nalaaznu lagajc Dad Jesucrist.
\v 21 Laani suchaani tiexhnu ni rajpnu lo guedxliujre, te gac tiexhnu sigajc najc tiejxhni lo xcäḻrnibeeni. Sujnni dee con yäḻrnibeduxh ni rajpni te rnibeeni loj guirali'ti, guiraa nejz.
\c 4
\s1 Coḻguibalajztis xcuent Dad Jesucrist
\p 
\v 1 Ni'cni rniä lojtu, rebetzä nani sanälazä, lojtu ni rlazä fisacä, lojtu ni ruspaa lazä, lojtu ni najc yäḻnasa'c xtenä, coḻsudzu'tz loj xtidx Jesucrist.
\p 
\v 2 Rniabduxhä lo Evodia näjza lo Síntique, rulidxäreni gunreni tejsi xhigab xcuent Dad Jesucrist.
\v 3 Sigajcza rniabä lojlu betzä, ni runnäj narä dzuun, gucnäj regunaare ni bennäj narä dzuun, bideednu trabajw xcuent xtidx Jesucrist. Gucnäjza Clemente näjza guiraa reni bennäj narä dzuun; alajreni caj neṉ reguijtz xten yäḻnabajṉ par tejpas.
\p 
\v 4 Coḻguibalaznäjtis Dad Jesucrist; stehuält rniä: coḻguibalajz.
\v 5 Sugacbee guiraa rebejṉ xho najc xcäḻnabajṉtu lo xtidx Dios. Asiäddzuṉgajxh dxej xten Dad Jesucrist.
\p 
\v 6 Na'c guidxejbtu, coḻnabtis lo Dad guira'ti, coḻgudeedza xquixtios lojni laḻ ni cabedx-canabtu lojni.
\v 7 Dios guniidx xcäḻrbedxilazduxhni, nicla guntu xhigab lacti najc yäḻrbedxilajzga. Yäḻrbedxilajzga ga'p lastootu näjza xcäriejntu loj Dad Jesucrist.
\s1 Coḻyejn xhigabsa'c
\p 
\v 8 Mbaj ṉaj, deetis guiniä lojtu rebetzä, sa'tis rediidxre gusaantu chu loj rexhigabtu: guiraa ni najc guliipac; guiraa rediidx ni nanab guiliä'pni xpala'nni, guira'ti nani nacsa'c; guira'ti nani naya; guira'ti nani najc saru; guira'ti nani rapsa'c xpala'n lajni; näj palga yu' xhi dzuun ni nacsa'cpac, o palga yu' xhi te diidx ni sajc guiliä'p xpala'nni, xcuent guiraa reni'c coḻyejn xhigab.
\v 9 Nani bisieedtu, nani cua'tu, nani biejn diajgtu, nani bahuiitu benä, ni'c guntu te Dios ni rbecdxilajz, laani jiannäjni la'tu.
\s1 Gojṉ xten refilipenses ni xca' Pabl
\p 
\v 10 Rbaduxh lazä nez loj Dad Jesucrist sa'csi banasac lajztu gacnäjtu narä. Guliini; galooli rlajztu niacnäjtu narä, luxh di niajcdini.
\v 11 Dinä guiniä si'c sa'csi yu' xhi cayädxä, sa'csi abisiedä guibaali lazä loj xhitis ni rapä.
\v 12 Sajc guibaṉä che guxii rapä; sajc guibaṉä che xhidal rapä; abisiedä guibaṉä xhotis: sajc gauduxhä, sajcza guilianä; sajc gapä xhidajl xhixtenä, sajcza tedä trabajw.
\v 13 Guira'tini sajc gunä sa'csi Jesucrist racnäj narä.
\v 14 Niluxh xhet najcdi; laaca dzuun bejntu che bejntu xhigab gacnäjtu narä laḻ ni cadedä trabajw.
\p 
\v 15 Gacbee guejbtu, dad filipenses, che gusloj caguluiä xtidx Jesucrist lojtu, cheni biriä reguedx Macedonia, nicla tej guidoo di niacnäj narä, la'tistu gucnäj narä.
\v 16 Cheni yu'äli guedx Tesalónica, baxhaḻtu meel loä tej-tio'p huält.
\v 17 Niluxh narä di rlazä xca'ätis xhixtentu ni guniidxtu, nani rlazä najc tioobru xcäḻnasa'ctu nez lo Dios xcuent dzuun ni rujntu ruxhaḻtu meel loä.
\v 18 N̲aj acua'ä guiraa ni baxhaḻtu, arapä xhidajl, arapduxhä sa'csi acua'ä nani biädnä Epafradito baxhaḻtu loä, te gojṉ ni rlianejxh si'c guxhyaal, te dzunsa'c ni rchaglajz Dios.
\v 19 Dios xtenä guniidx lojtu guiraa nani riäädx xca'tu, si'ctisni rajpni reyäḻnasa'cduxh xhaguibaa con Dad Jesucrist.
\v 20 Coḻguiliä'p xpala'n Dios xtadnu guixe-guixee par tejpas. Si'c gacni.
\s1 Lult xtixtios
\p 
\v 21 Coḻdeed xtixtios lo guiraa rebejṉ ni abia lastooni nez loj Dad Jesucrist. Rebejtznu ni yu' ree näj narä ruxhaḻnu xtixtios lojtu.
\v 22 Guiraa rebeṉree ni abia lastooni nez loj Dad Jesucrist ruxhaḻ xtixtios, niluxh ruxhaḻru resa' César xtixtios lojtu.
\p 
\v 23 Suga'p xcäḻracnäj Dad Jesucrist lastootu. Sugacni si'c.
