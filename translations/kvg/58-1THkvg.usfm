\id 1TH - NT0243 Kuni/Boazi [kvg] (Kuni Dialect) - Fumey Dec/2015
\ide UTF-8
\h 1 Tesalonika
\toc1 1 Tesalonika
\toc2 1 Thessalonians
\toc3 1 Tes
\mt1 1 Tesalonika
\mt2 Pol-qa bugukhokhof pepa, Klisten bawan ezoqam-te, ndigu Tesalonika taon-te giyagam
\is1 Megeat Manqat-qase
\ip Pol nqanek bugukhokhof pepa, Klisten bawan ezoqam-te gepeawam, ndigu Tesalonika taon-te giyagam, ta khøuwa-te ndøgo, ndego Kolin taon-té gegoám. Tesalonika ndøgo, taon kandambaqape ndøgoám. Masedonia manqei-té, neka ndaola-té.
\ip Pol qambo-misika, manqei vinivinimba-te ge-okhoam, ezoqa Mbumbukiam-qa Manqat ge꞉zømesimam, ndego até Tesalonika taon-té-a, vø̄goam (Kel 17:1-14). Yaq teqa nømendim mokho-te, ezoqa nøme mø̀ndø-unimanqatiním. Ezoqa kopokopo nøme ndigu, Zu bawan-ák. Geté ezoqa kopoáv, ndigu bawan vini-ák. Ndigu Zu ezoqa nøme, ndigu Yesu unimanqatinteav qagoam, ndigu Klisten ezoqam, ngenøgim-té ginø-abumám. Pol taqa yaq-te ge-ewag, ndego Timoti ndøkhofotáv ti-te, ngenek tiqa unimanqatin-te, zita tøpøzu manqat vømøzø̄-ein. Yaq taqa zita-te, Timoti nqawa gendovesez, ndego Pol tiqa matev eqeieqei-qa yaq-te vømbø̄e-votot. Yaq Pol nqanek pepa ndakin, nqánek gene-peawám: Tiqa unimanqatin-te, zita tøpøzu nøme nonqó. Neka ndego tiqa bevap, løvøte neka Yesu-qa qavane-qa yaq-te, vøzømbē-qavøiu.
\c 1
\p 
\v 1 \x - \xo 1:1 \xt Kel 17:1-9\x*Nqanek pepa, no Pol neka Sailes neka Timoti, ni nipeaomít. Zo-té qeitø-peaomít, zo Klisten bawan ezoqam, Tesalonika taon-te ndozoyage, zo Mbumbukiam, ndego Tat, neka Evezøza, Yesu Keliso, tiqa mokho-te ndozotu꞉gu.
\p Mbumbukiam-qa kuku matev neka sambi matev, ndø̀goát, zo-te.
\s1 Pol-qa ike manqat Mbumbukiam-te, Tesalonika Klisten bawan ezoqam-qa yaq-te
\p 
\v 2 Ni zoqa yaq-te qeiguligulimatun, ni Mbumbukiam ike manqat oskia nimbo-manqaté, zo ezoqa ewaqape-qa yaq-te.
\v 3 \x - \xo 1:3 \xt 1 Ko 13:13; Kol 1:4-6\x*Niqa guligulim-te, Mbumbukiam-te, nigi Tat, ni oskia teimbo-matavupatún ndǿgo, av zo Yesu Keliso ndøzøte-unimanqatinat, neka zoqa sasae-qa yaq-te, ndøgo kuku matev-us ndozogo, neka zoqa føgøføgakh waniap-qa yaq-te, zo nigi Evezøza Yesu Keliso-te ndozoto-taza.
\p 
\v 4 Nǿfuap, zo Mbumbukiam ndezømbo-khafuat, ni mø̀tinøtén, ndego zo mø̀ndø-vevesám, vozō-tegi-ezoqam-ez.
\v 5 \x - \xo 1:5 \xt 1 Ko 2:4-5\x*Zapa ndǿgo, ni Manqat Mbomambaqape qeindapavun, ndøgo ambá av nqǣgo, manqat mba ndøgeavūn. Geté bazaføgakh neka Nqova Mbomambaqapé namba me꞉geavún. Yaq zo āv qazøte-qeivím nqǽgo: Niqa manqat unimanqatín. Zo mø̀zøte-zøtéz, ni zo mokho-te ande āv khatīyagam. Ni zo nitigoám.
\v 6 \x - \xo 1:6 \xt Kel 17:5-9\x*Ezoqa nøme, zo føgakh-te ambá gini-abumám. Geté zo niqa matev neka Evezøza-qa matev, zòmbo-paevém neka manqat khanakhanakh-us vozōndapem. Ta khanakhanakh ndøgo, Nqova Mbomambaqape-té qando-okhó.
\v 7 Yaq ta mokho-te nqanek, ezoqa ewaqape, Masedonia neka Akaya plovins-te, Yesu ndi-unimanqatinat, ndigu zoqa matev eqeieqei me꞉vewé neka paev-qa ndøgó.
\v 8 Evezøza-qa manqat, zo ezoqa qazozø-manqatam, ambá av nqǣgo, Masedonia neka Akaya plovins-te mbā qanø-panqavøēm. Geté manqei-manqei ate ndægo, ezoqa ewaqape, zoqa unimanqatin-qa yaq-te sùgumu-ewagát, ndøgo Mbumbukiam-te ndøzøgo. Ni ti-te ndigu, manqat einiav tøgoat, kopømbá. Zapa ndǿgo, ndigu mø̀ndøyogém.
\v 9 Ndigu ekezan, emanqat mø̀ndæ-vototupatún, av zo ni qazøte-khatomb, ni zo-te qeigeavun, neka zo tae khøuwiap-te qazogoam, unimanqatin khandi Mbumbukiam-te ande āv khazøtē-qambuz, ndego zo ndakin ndozombo-vizap,
\v 10 neka zo tege Yo Yesu ande āv khazømbøē-keoge, yan-te tendovis, ndego Mbumbukiam løvøte-te gekhandi꞉v, yaq ndego ni Mbumbukiam-qa manqa ovøyam-te, teqa qaqa-te vǿkhandī꞉n.
\c 2
\s1 Pol Tesalonika taon-te, Mbumbukiam-qa Manqat ge꞉zømesimam
\p 
\v 1 Nǿfuap! Zo zøkeza mø̀zøte-zøtéz, ni zo-te qeigeavun, ni ambá av nqǣgo, khokhō seigeavūn. Geté mokho kandambá qafakhan.
\v 2 \x - \xo 2:2 \xt Kel 16:19-24; 17:1-9\x*Zo mø̀zøte-zøtéz, ni bugukhokhof Filipai taon-te qeigoam, ezoqa ni gèngiænotám, neka vø̄i-potonumam. Yaq ni zo-te qeitøndu-niav, ni ezoqa nøme, niqa manqa manqate-te tokømbem-qa nigoám. Geté Mbumbukiam ni mø̀ndøni-tøké, neka ni zo teqa Manqat Mbomambaqape, kha føgakh-mba vøizø̄-manqatam.
\v 3 Ni ezoqa manqa qeizø-løvutatun, ni ambá av nqǣgo, khokho manqat nizø-manqatē o matavap soqøsoqa nigū o ezoqa khavozam-qa nigū.
\v 4 \x - \xo 2:4 \xt Gal 1:10\x*Geté ni Mbumbukiam mø̀ndø-gevenó neka ezoqa eqeieqei vø̄enæmb, neka teqa manqat, niqa zenda-te vō꞉ve. Ni teqa manqat qeimanqatatun, ni ambá av nqǣgo, ezoqa khanakhanakh asøtøve-qa nizøgō. Geté ni Mbumbukiam khanakhanakh asøtøve-qa nimbogó, ndego niqa mbøni neka matavap ndini-gevewat.
\v 5 Zo mø̀zøte-zøtéz. Ni ambá av nqǣgo, ezoqa enaq nizøge꞉mām o khanakhanakh manqat vøizø̄-etoumam, yaq moni-qā nizømbi-goām. Mbumbukiam mø̀ndæ-otév, nqanek manqat unimanqatín.
\v 6 Ni ambá av nqǣgo, nikeza iz eqawat-qa nizøgoām, zo niqa iz tozoni-eqatat, o ezoqa nøme vøní-eqatāt.
\v 7 Ni Keliso-gi u-anim nqeigu, ni tøni-poeɨn, ni ambá nizø-pouweɨ́n, av nqægo, zo ni ezoqa kandakanda zøténæmbát. Geté ni zo mokho-te qeigoam, ni matev aiyaiyav-té qeitøgoám. Ni zo qeizø-kewagam, ni andé evo me nitigoám, ndugu nakheis tete nduzø-etoam.
\v 8 Ni kuku kandambá zo-te. Yaq ni ambá av nqǣgo, zo Mbumbukiam-qa Manqat Mbomambaqape mba niti-zømesimām. Geté ni até nikeza yagé-a, vøizø̄-etoam. Zapa ndǿgo, ni kuku khàpe nimbi-khouwév zo-te.
\v 9 \x - \xo 2:9 \xt Kel 20:34\x*Nǿfuap! Zo ndozombo-matâváp, ni sasae føgakh-qape qeikhanazat, zo mokho-te qeigoam. Ni pavpave nekā lovølova, sèisasaetám, neka niqa yage nonqo, moni vø̄i-qaqasumam. Zapa ndǿgo, ni Mbumbukiam-qa Manqat qati-zømesimam, ni poeveáv, ni zogi ezoqa kopo-te sa teito-tambet, viniv vøizǿ-etoām.
\p 
\v 10 Zo mø̀zøte-zøtéz neka Mbumbukiam vø̄e-otev, ni zo namba qazi꞉yagam, ni āv tøtiyagám, av Mbumbukiam ndømbøe-poev. Ni matev eqeieqei-té qeitøyagám neka manqa-zapa-qase goneáv.
\v 11 \x - \xo 2:11-12 \xt Kel 20:31\x*Neka zo mø̀zøte-zøtéz, ni zo ezoqa kopokopo-te, ate ndøzøte꞉go, āv teizømbe-matønumám, av eve nde꞉go, ekeza nakheis-te te꞉matønumat.
\v 12 Ni zo nìgugubám neka zita vøizø̄-tøpazam neka vøizø̄-pouweam, av nqægo: Zo āv tøneyagé, av Mbumbukiam ndømbøe-poev, ndego zo teqa megeat matev-te neka waev kandambaqape-te ndezø-akhayam.
\s1 Klisten ezoqam, matev føgøføgakh ambá qazømbe-fakhanumám, geté ndigu føgakh-mbá giwaniapám
\p 
\v 13 \x - \xo 2:13 \xt 2 Tes 2:13\x*Ni Mbumbukiam, ike manqate oskia nimbo-manqaté. Zapa ndǿgo, zo teqa manqat qazoyogem ni-te, zo ambá av nqǣgo, khokho sozondapēm, av ezoqam-qa manqat sa ndozo-upøgim. Geté zo Mbumbukiam-qá Manqat zondapém. Yaq ndøgo unimanqatín. Nqanek manqat, zoqá mokho-té qanu-sasaeát, zo ndozo-unimanqatinat.
\v 14 \x - \xo 2:14 \xt Kel 17:5\x*Nǿfuap! Matev ndøgo, zo-te qafakhanam, até kopó, av Mbumbukiam-gi Klisten bawan vinivinimba qazømbe-fakhanumam, ndigu Zudia plovins-te, Keliso Yesu-qa mokho-te ndu꞉gu. Zogi ezoqam, zo matev soqøsoqa, āv gizømbe-matønumám, av Zu ezoqam, Zudia plovins-te ndøgo, Klisten ezoqam-te gizømbe-matønumam.
\v 15 \x - \xo 2:15 \xt Kel 9:23, 29; 13:45, 50; 14:2, 5, 19\x*Ezoqam ngínik, nigi Evezøza Yesu neka Mbumbukiam-gi manqa vevezam ezoqam, løvøte-te gi-abumam neka ni vø̄ngiænotam. Mbumbukiam khanakhanakh mbaín ti-te. Neka tiqa matev qaqa-ús, ezoqa ewaqape-te.
\v 16 Ndigu ni tokømbem-qa nigoám. Ni bawan vini-ak, ambá nití-zømesimák, yaq ndigu vǿe-khandī꞉z. Ta mokho-te ndøgo, ndigu manqa-zapazapa nøme mba mo꞉kapuimít, atema vømǿtøvā. Geté Mbumbukiam-qa qaqa khakheitáp. Segezǿ-fakhán.
\s1 Pol Tesalonika ezoqam-te, nqawa vesezam-qa gegoam
\p 
\v 17 Nǿfuap! Ni zo qeizuvaz, yaq khapémbá qa-auwam, ni vao kandambá qeigoam, zo-te. Neka ni zoqa bugug nqawa qeivi-qa nigoám. Unimanqatín. Ni qámbá zo-te. Geté niqa matavap-te neka mbøni-te, ni namba zi꞉gú.
\p 
\v 18 Ni zo-te nqawa okho-qa nimbogoám. No Pol, no khøuwa kopoáv, ambá notøndo-navɨ́n, zo-te. Geté Saitan ni gètokømbemám.
\v 19 \x - \xo 2:19 \xt Filip 2:15-16; 4:1; 2 Tes 1:4\x*Nigi Evezøza Yesu tendoqavan, yaq ni gekham-qā yaq-tē qeitǿ-tāmb neka gekha mokhō qatí-khambuvemēm neka teqa megemege-te ndo꞉go, khanakhanakh-us vøtíwanāt? Ndøgo zo zøkhapús.
\v 20 Unimanqatín. Ezoqam zó, ni nqati-khambuvap neka khanakhanakh nqānī-āsø̄tø̄vē.
\c 3
\p 
\v 1 \x - \xo 3:1 \xt Kel 17:15\x*Ni kopømba mbain qagoam, sekemba amba qati-kewagam, yaq ni matavap āv qatigoném nqǽgo: Ni nikezan, Atens taon-te até nitøkhǽ-sokhoát.
\v 2 \x - \xo 3:2 \xt Kel 16:1-3\x*Geté ni Timoti nitøndú-khofotøvém, zo-te, ndego nigi Klisten nøfu, ni Mbumbukiam-qa sasae namba nqati-sasaeat, ndego ni Manqat Mbomambaqape manqa manqate-te ngini-tøke, Keliso-qa yaq-te. Yaq ndego zo tèabezømbe-tøké neka zita zǿtøpáz, zoqa unimanqatin matev bezømbē-føgakh.
\v 3 \x - \xo 3:3 \xt 2 Tim 3:12\x*Soqaín ndøgo, matev soqøsoqa ndøgo, zo-te qafakhanam, zoqa unimanqatin matev tøkukugim. Zo zøkeza mø̀zøte-zøtéz, matev soqøsoqa av nqægo tøndo-okhoat, ndøgo Mbumbukiam-qá poév, ni-te.
\v 4 Ni zo namba qatigoam, ni mø̀izø-manqatám, av nqægo, “Ni matev føgakh-qape, ndìzimø-qeivím.” Yaq zo mø̀zøte-zøtéz, matev mø̀ndø-fakhanám.
\v 5 Yaq nakémbá, no kopømba mbain qagoam, sekemba amba qate-kewagam, no Timoti notøndo-khofotáv. No nøtenat-qa nøgoám, zoqa unimanqatin matev, āv khapezømbēgo-a. Soqaín ndøgo, ndego ezoqam, ndego ezoqa nde꞉khamasim, zo te꞉khamasim, yaq niqa sasae føgakh-qape, zo mokho-te qeikhanazat, vømǿ-khokhō.
\p 
\v 6 \x - \xo 3:6 \xt Kel 18:5\x*Geté ndakin Timoti nango gendovesez, zo-te gegoam, ndego zoqa unimanqatin matev neka kuku matev-qa yaq-te, manqat mbomambaqape ndø-ndapavún. Neka ndego ni āv ginimbi-eín nqǽgo: Zo ni oskia zoni-mataváp, khanakhanakh-ús, neka zo vao kandambá ni-te. Neka zo ni nqawa nømende-qa zogó, ate av-té, ni zo nqawa zømete-qa nqati꞉gu.
\v 7 \x - \xo 3:7 \xt 2 Tes 1:4\x*Nǿfuap! Ni yage føgakh-qape-te nqeiyage, ezoqa matev soqøsoqa ngini-matanam, yaq Timoti zoqa unimanqatin-qa yaq-te emanqat ginimbi-votot, ndøgo ni møqæ ni-etoám.
\v 8 Yaq ndakin niqa yage kopømbaqapé. Zapa ndǿgo, ni mø̀tinøtén, zo Evezøza mokho-te, bazaføgakh-ús ndozo-waniap.
\v 9 Ni khanakhanakh kandambá, zoqa yaq-te. Ni nøtenateáv, Mbumbukiam zoqa yaq-te, ike manqat eqeieqei ande āv kheimbøé-einīm.
\v 10 Pavpave nekā lovølova, ni Mbumbukiam-te oskia nivi꞉matún. Bazaføgakh-ús. Ni zoqa bugug nango bàniqeivím neka zo manqat nøme batī-zømesim, ndøgo zo zøtezateav ndøgo, neka zoqa unimanqatin matev bezømbē-khouwev.
\p 
\v 11 \x - \xo 3:11 \xt 2 Tes 2:16-17\x*Ni āv qati-guligulím nqǽgo: Mbumbukiam, ndego nigi Tat, neka nigi Evezøza Yesu, ndigu niqa nakhoa ekeza ndǿkhakheinømém, ni zo-te teitøndu-niav.
\v 12 Neka Evezøza, zoqa kuku matev gezǿ-khouwév, yaq ndøgo kandambaqape ndǿgoát, yaqyaq-a nekā ezoqa nøme-te, ate av-té, ni zo-te kuku nqanimbi꞉gu.
\v 13 Yaq ndego zo gezǿtøké, zo bazaføgakh-us zówaniapát. Yaq zo Mbumbukiam-qa megemege-te, ndego nigi Tat, manqa-zapazapa-yav neka eqeieqei-qape sozógoát, ta khøuwa-te ndøgo, nigi Evezøza Yesu, ekeza ezoqam ate ndi꞉gu namba, tendoqavan.
\c 4
\s1 Yage eqeieqei-qa yaq-te, av Mbumbukiam ndømbøe-poev
\p 
\v 1 Nǿfuap! Manqat nøme nqánek: Ni zo mø̀ti-zømesimám, ande āv khazøté-yagāt, yaq Mbumbukiam khanakhanakh vømbøé-asøtāv. Ni mø̀tinøtén, zo āv tøzøte-yagé. Yaq ndakin ni zo nìzøviám, neka nigi Evezøza Yesu-qa iz-te, manqat āv qazimbí-løvuá nqǽgo: Ta matev-te ndøgo, zo vø̀fisám.
\v 2 Zo mø̀zøte-zøtéz, nigi Evezøza Yesu-qa iz-te, zo gekha manqat nitī-zømesimam.
\v 3 \x - \xo 4:3 \xt 1 Tes 5:23; 1 Pita 1:16\x*Mbumbukiam-qa poev nqánek: Zo ndaføyamba-qape ndøyagé neka mambe okho matev, kha mbokhanø̀za᷄m.
\v 4 \x - \xo 4:4-5 \xt 1 Ko 6:13\x*Neka zøkeza kha gèqeiví. Matev eqeieqei-té qayagé, av Mbumbukiam ndømbøe-poev.\f + \fr 4:4 \ft Mokho nøme nqánek: Zo angana, zøkeza sakheis eqeieqei zøkeogé. Vizap-ús. Ate av-té, Mbumbukiam ndømbøe-poev.\f*
\v 5 Ezoqa me꞉qovèsa᷄m, av bavokho ezoqam ndi꞉matanam, ndigu Mbumbukiam zøtezateav ndigu.
\v 6 Khafeap ndøgo, Mbumbukiam geve, ndølø̀vua᷄m. Qoge Klisten qafu-te, manqa-zapa ndø̀go᷄, tegu zas voqó-aqonøvēm. Evezøza yaq-fia ndø̀tá, ti-te ndigu, matev av nqægo ndimatanam. Ni zo mø̀izø-manqatám, neka vø̄i-gugubam.
\v 7 \x - \xo 4:7 \xt 1 Pita 1:15-16; Iblu 12:14\x*Mbumbukiam, ni ambá av nqǣgo, manqa-zapa gone-qā nimbi-akhā. Geté ni ndǿgo tinimbi-akhá: Ni ndaføyamba-qape zíyagát.
\v 8 \x - \xo 4:8 \xt Luk 10:16; 2 Ko 1:22\x*Yaq nakémbá, gekha ezoqām ndego, nqanek nømendim manqat ndesanqawe, ndego ambá av nqǣgo, ezoqam-qā manqat ndøsanqawē, geté ndego Mbumbukiam-qá manqat ndøsanqawé, ndego zo ekeza Nqova Mbomambaqape ndezø-etoam.
\p 
\v 9 \x - \xo 4:9 \xt Zion 13:34\x*No zo-te, kuku matev-qa yaq-te, Klisten bawan ezoqam mokho-te, manqat nøme peaweav tøgoat, ndøgo kopømbá. Zapa ndǿgo, zo Mbumbukiam ekeza me꞉zømás, zo kuku āv khazømbé-goāt, yaqyaq-a.
\v 10 Neka unimanqatín, zo kuku ndøzø̂gó, Klisten ezoqam-te ate ndi꞉gu, nandav Masedonia plovins ate ndægo. Nǿfuap. Ni manqat āv qazimbí-løvuá nqǽgo: Zoqa kuku matev, bèkhouwevtét.
\p 
\v 11 \x - \xo 4:11 \xt Ef 4:28\x*Zo bazaføgakh ndø-asøzú. Matev eqeieqei-té qayagé, neka zøkeza yage mba ndøndapét. Neka zøkeza zendá qane-sasaeát, ate av-té, ni zo qati-gugubam.
\v 12 Zo matev av ndægo tozogoat, yaq bavokho-ak zo ndø̀zøvizám neka zo ezoqa nøme-te zotótabák, lou neka gigiap-qa yaq-te.
\s1 Evezøza tendoqavan, taqa yaq-te
\p 
\v 13 Nǿfuap! Ni poeveáv, zo ndigu Klisten ezoqam-qa yaq-te zøtezateav tøgoat, ndigu gipakhaez. Soqaín ndøgo, zo mbøni tøzøvavat, av ezoqa nøme ndi꞉gu, ndigu Yesu-te vintøzateav ndigu.
\v 14 \x - \xo 4:14 \xt Lom 14:9; 1 Ko 15:3-4, 12\x*Ni āv qazi꞉-unimanqatinát nqǽgo: Yesu mø̀ndønaním, neka nango vø̄khandi꞉v. Yaq ni ate nqánek qazi-unimanqatinát: Ndigu Klisten ezoqam, gipakhaez, Mbumbukiam Yesu namba ndé-upozó, ndego tendoqavan.
\p 
\v 15 \x - \xo 4:15-16 \xt 1 Ko 15:51-52\x*Manqat ndøgo, ni ndakin teizø-ein, Evezøza ekeza ndø-eín, av nqægo: Ta khøuwa-te ndøgo, ndego Evezøza tendoqavan, ni ezoqam, zua nqaziyage, ni ndigu zíløvubák, ndigu bugukhokhof go꞉pakhaetat.
\v 16 Zapa ndǿgo, manqat bazaføgakh-us-qape ndówáv, neka enzol ezoqam-gi kawa ezoqa nøme vǿ-akhā neka Mbumbukiam-qa kipi wag vǿpā. Yaq Evezøza yan-té gendóvís. Yaq løvøte ezoqam, ndigu Keliso gi-unimanqatinim, ndigu bugukhokhof løvøte-té gindúsúz.
\v 17 Yaq taqa zita-te, Mbumbukiam, ni zua nqaziyage, gékhatómb, vǿ-eqanō, ti namba ndigu, løvøte-te gindusuz. Khaiya ozoz-té genǿkhatómb, yaq ni ova nqo꞉go, Evezøza namba vizimǿ-qaqandām. Yaq ni Evezøzá namba zí꞉yagát, miavmiav.
\v 18 Zo yaqyaq-a, nqanek manqat, zita me꞉tøpøzú.
\c 5
\s1 Yesu gendóqaván. Ni é-bizi-khakheinám
\p 
\v 1 Nǿfuap! Ni zo taqa yaq-te manqat peaweav tøgoat, gekha khøuwa neka gekha viav Yesu tendoqavan, ndøgo kopømbá.
\v 2 \x - \xo 5:2 \xt Met 24:42-43; 2 Pita 3:10; Veve 3:3\x*Zapa ndǿgo, zo mø̀zøte-zøtéz, Evezøza-qa Khøuwa, ndego tendoqavan, andé aqonam ezoqam me mé꞉geáv, lova khoev teqa-nqawa. Nakhamas-té.
\v 3 \x - \xo 5:3 \xt Met 24:39; Luk 21:34-35\x*Ezoqa géqaqavét. Neka āv giní-manqatát nqǽgo, “Ni sambi matev-té qaziyagé. Fofogeap mbaín.” Geté ndigu nqova zǿndáf. Ezoqa ngiæzoat matev, ande sævam-qa nqosøgeap, gui-ovaɨn, nakhamas-té qanøzǿ-fakhán. Yaq ezoqa kopømba mbaín tikhokhoz.
\p 
\v 4 Geté zo, nøfuap, zo ambá av nqǣgo, bøivun-tē qazoyagē. Yaq nakémbá, ta khøuwa kopømba mbaín, zo ande aqonam ezoqam me, nqova tøzøndaf.
\v 5 \x - \xo 5:5 \xt Lom 13:12\x*Zo ate ndøzøte꞉go, zo waev neka paveat-gí ezoqám. Ni ambá av nqǣgo, lova neka bøivun-gī ezoqām.
\v 6 Yaq nakémbá, ni bizi-sømbiàpe᷄t, kopømba ande av ezoqa nøme ndi꞉gu. Geté ni oskia bìzio-feanoát neka niqa kha eqeieqei bizinøzøgím.
\v 7 Ezoqa ndigu, ndisømbiam, ndigu lovølova ndøsømbi꞉matún. Neka ezoqa ndigu, ibøkha soqa ndi-izam, ndigu lovølova ndø-izumatún.
\v 8 \x - \xo 5:8 \xt Isa 59:17; Ef 6:14, 17\x*Geté ni paveat-gí ezoqám. Yaq nakémbá, ni nikeza kha, eqeieqei bizinøzøgím. Ni unimanqatin matev neka kuku matev binigú. Matev av nqægo, andé sanqava khakhazam nonqó, savim-te taqambo-tøkeat. Neka niqa vintønat matev Yesu-te, av nqægo, ndego ni gēkhandī꞉n, ni andé nakhag ezoqam-qá wawaq me bizi꞉-uzáp.
\v 9 Ni Mbumbukiam, ambá av nqǣgo, ndø̄go tene-vevendām, ni qaqa nígū, neka vǿngiænō. Geté ndego ni ndǿgo tene-vevendám: Ni Yesu Keliso mokho-te gékhandí꞉n, ndego nigi Evezøza.
\v 10 \x - \xo 5:10 \xt Lom 14:8-9; 1 Tes 4:14\x*Yesu ta zapaya nqánek genenaním: Ni té namba bizi꞉yagé, oskiá ndøgo, ni e-ma tizio-pakhaen o tiziyagat, ndego tendoqavan.
\v 11 Yaq nakémbá, zo yaqyaq-a, zita ndøtøpøzú neka unimanqatin-te vø̄tøkeam. Ate av-té, ndakin ndøzøte꞉go.
\s1 Pol-qa vaev guguna manqat
\p 
\v 12 Nǿfuap! Ni āv qazimbi-viám nqǽgo: Zo megetapak ezoqam, gèzøvizáp, ndigu zoqa Klisten bawan mokho-te, sasae bazaføgakh-us nandigu, ndigu zo nandizømbo-megetap neka nandi-guguza, Evezøza mokho-te.
\v 13 Zo ndigu møe-mbá sozozǿ-vizupát neka kuku kandambá sozozǿ-goát, tiqa sasae zapaya. Neka zo yaqyaq-a, sambi bèzøgó.
\p 
\v 14 \x - \xo 5:14 \xt 2 Tes 3:6, 11\x*Nǿfuap! Ni manqat nøme āv qazimbí-løvuá nqǽgo: Ezoqam ndigu, ndiwauwi꞉zat, gèguguzá. Neka ndigu, kha føgakhateav ndigu, neka ndigu, tiqa unimanqatin-te føgakh mbain ndigu, gèzøtøkeé. Neka aiyaiyav matev ndøgó, ezoqa ewaqape-te.
\v 15 \x - \xo 5:15 \xt Lom 12:17; 1 Pita 3:9\x*Gèqeiví, av nqægo: Ezoqa manqa-zapa tego zo-te, zo ndego ta manqa-zapa ndøgo, mbøe-qavø̀ina᷄m. Geté zo yaqyaq-a, matev mbomømboma oskia ndømatanám, neka até ezoqa ewaqape-té-a, matev mbomømboma vozó-matønumāt.
\p 
\v 16 \x - \xo 5:16 \xt Filip 4:4\x*Zo khanakhanakh-us oskia ndøgó.
\v 17 Neka oskia ndøguligulím.
\v 18 \x - \xo 5:18 \xt Ef 5:20\x*Neka gekha matēv ndøgo, tøzø-fakhanumat, zo Mbumbukiam ike manqat mbomanqaté. Matev av nqægo, Mbumbukiam-qá poév, zo-te, zo Keliso Yesu mokho-te ndozotu꞉-yage.
\p 
\v 19 \x - \xo 5:19 \xt Ef 4:30\x*Zo Nqova Mbomambaqape, nakhoa mbøe-khakhàza᷄m, ndego zo mokho-te nandu꞉-sasaeat.
\v 20 Nqova Mbomambaqape, ezoqa nøme-te manqat tevevezam, yaq ndego ezoqam zo te꞉zømas, ta manqat ndøgo, ndøsanqàwe᷄m.
\v 21 \x - \xo 5:21-22 \xt 1 Zion 4:1\x*Geté zo manqat ate ndægo vø̀geveaném neka vø̄qeivim, nqanek manqat Mbumbukiam-tē qapøtendē-wav-a. Yaq manqat ndøgo, unimanqatin tøgoat, zo vø̀ndapém.
\v 22 Geté matev soqain ate ndægo, zo zósanqawém.
\p 
\v 23 \x - \xo 5:23 \xt 2 Tes 3:3\x*No āv qate-guligulím nqǽgo: Mbumbukiam, ndego ni sambi matev ndini-etoam, zo tèabete-khakheinøvém, teqa bøi-te vøzøté-ndaføyamba-ēz. Neka ndego zoge nqova neka zoqa matavap neka zoqa kha, eqeieqei tèabete-khatiwí. Yaq zo manqa-zapazapa mbaín, sozógoát, nigi Evezøza Yesu Keliso tendoqavan.
\v 24 Mbumbukiam, ndego zo gezøndo-akha, ndego unimanqatín. Ndego ndø̀matanám.
\p 
\v 25 \x - \xo 5:25 \xt Kol 4:3; 2 Tes 3:1\x*Nǿfuap! Zo até ní-a, gìnindu-guligulím.
\p 
\v 26 Zo tozo-møvabat, zenda kaka vø̀-itiamát, Klisten zøfuap ate ndi꞉gu namba, neka vø̄ngenøndamat, ate av-té, Mbumbukiam-qa bøi-te eqeieqei ndægo.
\p 
\v 27 No Evezøza-qa iz-te, nqazǿ-pouwe: Zo nqanek pepa, Klisten ezoqa ewaqape-té qazonǿ-geveømém.
\p 
\v 28 Nigi Evezøza Yesu Keliso-qa kuku matev, ndø̀goát, zo-te. 
