\id JOL - Aguaruna 
\h Joel 
\toc1 Joel 
\toc2 (Joel) 
\toc3 Jl. 
\mt1 Joel 
\c 1  
\s1 Manchi ajakan amukbau 
\p  
\v 1 Joel Petuelan uchiji aajakua nuna Apajuí Israel aents aidaun ujakti tusa akateak aatus tiuwai: 
\b  
\q1  
\v 2-4 Atum chichaman jintinkagtin múun aidautijum 
\q1 juju shiig antuktajum, 
\q1 tuja ashí aents aidautigmeshkam antuktajum. 
\q1 ¡Ipak usumta imajin manchi maki makichik niimtin 
\q1 aidau kakegak iina ajake aidaunak 
\q1 tikich manchi aidau amuak ukubaun ashí amutjamkaji! 
\q1 Tuja ¿atumesh wajutiya junin wantinush wainkauwaitjume? 
\q1 Yaunchuk atumi muunjum aidau 
\q1 batsamajaku aina duka makichkish 
\q1 junin wantinunak wainkachu ainawai. 
\b  
\q1 ¡Nuadui atumi uchijum aidau nunú pachisjum ujaktajum, 
\q1 tuja dita ujaktinme dita uchiji aidaun, 
\q1 nuna uchiji aidau ujaktinme dita uchiji aidaun! 
\b  
\q1  
\v 5 ¡Nampen aidauwah, nantagtajum, 
\q1 vino umin aidautigmek buuttajum, 
\q1 atum vino umumainuk atsuttawai! 
\q1  
\v 6 Manchi shiig kuashat, 
\q1 suntag maaniatatus shimaujai betek 
\q1 iina nugkeen untsaantugmae. 
\q1 Nuna nai aidauk shiig empek asag, 
\q1 león kajenun naíya iman ainawai. 
\q1  
\v 7 Iman asag uva ajakbau aidaunak higo ajakbau aidaujai ashí tsupije. 
\q1 Imatikau asa kanawe aidaunak ashí pakajug saeptuchu emake. 
\q1  
\v 8 Imatikau asamtai, nuwa nii aishinatag tibau jakamtai, 
\q1 wake besemag pujaku nugkutain nugkuja 
\q1 buutama imanikag, 
\q1 aents aidauk makichkish etsagmainchau buutuinak 
\q1 jakamunum nugkutain nugkuinawai. 
\q1  
\v 9 Tuja Apajuí anentag suwaku vino, trigo, 
\q1 cebada ejemainuk atsutai, 
\q1 jega Apajuí emematku ijuntainmag 
\q1 ejegainachu asamtai, sacerdote aidaushkam buutuinawai. 
\q1  
\v 10 Ajanum ajak ayauk kagaka asae, 
\q1 imaniku asamtai trigok, vinok, aceitek makichkish atsawai. 
\q1 Tuja nugkak uwejush tutuptina nunin 
\q1 wake besemag wajas asae. 
\b  
\q1  
\v 11 Atum ajanum takau aidautigmek, 
\q1 uva ajakbaunum takau aidautigmek, 
\q1 wake besemag dekapeakjum buuttajum. 
\q1 Atumek trigo cebadajai ashí jinaamtai, 
\q1 shiig wainka juwakugme. 
\q1  
\v 12 Uva aidau, higo aidau, munchi aidau, palmera aidau, 
\q1 manzana aidau, tikich numi aidau aatus 
\q1 ashí jinaamtai, aents aidauk buutuinawai. 
\q1 Nuninak shiig aneamunak idayinak 
\q1 wake besemag batsatui. 
\q1  
\v 13 Vino, trigo, cebada aina duka atsau asamtai, 
\q1 aents aidauk Apajuínak anentag ejetuinatsui. 
\q1 Nuadui Apajuí emematku ijuntainmak makichkish atsawai. 
\q1 Nunú diisjum atum sacerdote Apajuí altarjin 
\q1 takau aidautigmek wake besemag pujaku nugkutai 
\q1 jáanch nugkugjum kashi buu buutkawajum tsawaitajum. 
\q1  
\v 14 Nuniakjum Apajuí emematku ijuntainum 
\q1 apu múun aidau ashí Israel aents aidaujai ijumjatajum. 
\q1 Dutikajum, ijagma pujusjum Apajuí ausatajum. 
\q1  
\v 15 ¡Apajuí taatnuk namput wajaschae! 
\q1 ¡Tsawan ishamain atina duka ashí jegawai! 
\q1 ¡Pegkegchau takat idaiku Apajuí umigtsujinig, 
\q1 Apajuí ashí senchigtina nunú 
\q1 suwimak ishamainun amastatui! 
\b  
\q1  
\v 16 Ii yuwatin agmaya nunak manchi aidau 
\q1 iish wainjinig dukeen amutuk ijinae. 
\q1 Nuadui Apajuí emematku ijuntainum 
\q1 shiig aneasa takau ayag duka nunimainchau wajasji. 
\q1  
\v 17 Trigo ajakbau aidauk, yumi yutushtai ashí jinae, 
\q1 nuadui juuka yumain shiig atsau asamtai, 
\q1 trigo chimpitai aidauk 
\q1 wainak batsamas mamuka utsanui. 
\q1  
\v 18 ¡Iina bakaji aidauk buutuinawai! 
\q1 ¡Uwig aidaushkam buutuinawai! 
\q1 ¡Tagku aidauk yumainji chijichi atsutai, 
\q1 nujantai jinuinawai! 
\b  
\q1  
\v 19 Tuja jii kegak dupa aidaunak, numi aidaunashkam apea ijinae. 
\q1 ¡Apajuíjuh, wait aneasam yaijatkata! 
\q1  
\v 20 Entsa aidauk kuyuka buku waigke, 
\q1 tuja jii kegak dupanak ashí ijinae. 
\q1 ¡Imanikmatai kuntin ikamia aidaushkam 
\q1 Apajuí yaimpakti tusag ima aminak segapainawai! 
\c 2  
\q1  
\v 1 ¡Jerusalégnum uwija kachuji umpuagtajum! 
\q1 ¡Adeagtinme tusa umputai Tuke Pujuu emematku 
\q1 ijuntainum umpuagtajum! 
\q1 Nuna antuinak ashí aents aidau 
\q1 Judá nugken batsamin aidauk sapigmainak kujaitnume, 
\q1 wagki Tuke Pujuu taatin tsawan ashí jegae. 
\q1  
\v 2 Nunú tsawanta duka suwe atinai, 
\q1 nunú tsawantinig yujagkim suwe wajastinai. 
\b  
\q1 Suntag aidau shiig kuashat depetmainchau 
\q1 muja aidaunum shiyaktatui, 
\q1 nunikag etsa kashikmas yama jiinak etsantug, 
\q1 ashí mujan patamtuwama numamtuk 
\q1 ashí nugkan pampankattawai. 
\q1 Duka yaunchkesh imanuk wainkachbauwai, 
\q1 tuja atakea duish imanuk wainnakchatnai. 
\q1  
\v 3 Nunú iman aina duka jii kegaujai betek asa, 
\q1 nii juwi taatatus minakug ashí apea nagkaemawai. 
\q1 Nunú tatsaigkik nugkak shiig pegkeg ayi, 
\q1 nunú taamtai nagkamas nugkak uwegshujai betek wajase. 
\q1 ¡Nuna uwemtumainuk makichkish atsawai! 
\q1  
\v 4 Nunú manchi aina duka 
\q1 aents caballonum maanitan yacha aidau 
\q1 maaniamunum jetejatmaina imanik utsantawai. 
\q1  
\v 5 Ikam utsaana tsekeamuji antamak 
\q1 carro maanitai shimak wajukama imatui, 
\q1 duka kagaku apeam tsachigtuwama imatui, 
\q1 suntag shiig kuashat ijunag uminas 
\q1 shiwaajin jetektatus ijunama imanai. 
\q1  
\v 6-9 Nunú manchi aina duka kasajai betek 
\q1 jeganum wakag niimtai ujaimua nuni utsanui. 
\q1 Suntag aidaujai betek yaakat peejamunash 
\q1 tujintsuk pachiachbaunum yaaktan utsantawai. 
\q1 Nunidau asag dita shimamunak nunisag 
\q1 makichkish tunitsuk, shitanitnash shitanitsuk, 
\q1 ukunmakesh wakettsuk shimutui. 
\q1 Tuja akentai aidaun shiig kuashat aketmash 
\q1 ditak nunisag shimawai. 
\q1 Imanik manchi minidaun wainkag 
\q1 aents aidauk senchi ishamainak yapinig puju wajasag kujainawai. 
\b  
\q1  
\v 10 Tuja nugkak nayaimpijai senchi uujui, 
\q1 nunitai etsa, nantu kajinag suwe wajase. 
\q1 Tuja yaya aidaushkam etsantainatsui. 
\q1  
\v 11 Tuke Pujuu niina suntaji aidaujai minak 
\q1 chichamujig ipamtajai betek wajawai, 
\q1 Tuke Pujuu suntajig senchigtin ainawai, 
\q1 Tuke Pujuu tabaun umin aidauk 
\q1 shiig kuashat dekapamainchau ainawai. 
\q1 ¡Tsawan Apajuí minamuk ishamain atatui! 
\q1 ¡Imanun atsaneg pujumainuk makichkish atsawai! 
\s1 Tuke Pujuu niina aentsji aidaun wait anentamu 
\q1  
\v 12 Tujash Tuke Pujuu yamai juna aatus tawai: 
\b  
\q1 “Atum pegkegchau takajum duka 
\q1 idaisajum atumi anentaimijai umigtuktajum, 
\q1 nuniakjum ijagma pujusjum buutkujum Apajuí ausatajum. 
\q1  
\v 13 ¡Pegkegchau takatak idaikujum 
\q1 mina umigtuktajum! 
\q1 Wake besemag dekapeakjum, 
\q1 jáanchjum japiki ichí yujatsuk 
\q1 atumek pempeentumakjum kajegmamkatajum, 
\q1 nuniakjum dekas dewakjapi tumamtajum. 
\q1 Wika kakagchauch wait anenkagtinaitjai. 
\q1 Wika wamak kajechuitjai, nuadui wika 
\q1 tsagkugkagtugtasan pujajai. 
\q1  
\v 14 Nuniagminish nii suwimkan amastag tiu akush tsagkugtamag 
\q1 trigon, vinon nii anentag susatnun shiig kuashat amaschajaintash. 
\b  
\q1  
\v 15-16 “¡Jerusalégnum uwija kachuji umpuagtajum! 
\q1 ¡Ashí aents aidau ijumjatajum! 
\q1 ¡Múuntuch aidau, uchi aidau, 
\q1 uchi muntsu muntsuaku aidaushkam, 
\q1 tuja yama nuwedau aidaushkam jegá batsataidauk ashí kaunatnume! 
\q1 Nunikagmatai ijagma pujusjum pegkegchau takat 
\q1 idaisajum umintsatajum Apajuí ememattasajum. 
\q1  
\v 17 Sacerdote aidaushkam kaunatnume, 
\q1 nunikag altarnum jeganta wajasag 
\q1 buutuinak aatus Apajuín segatnume: 
\b  
\q1 “¡Tuke Pujuuwah, 
\q1 amina aentsjum aidau tsagkujata, 
\q1 makichik aentskesh ditan dushijati tusamek idaisaipa! 
\q1 ¡Tuja tikich aents aidau depetkatnume tusamesh idaisaipa! 
\q1 Aents tudau aidau tuke aneasag inimpainak: 
\q1 ‘¿Atumi Apajuíjish wajukame?’ tusag dushiki 
\q1 batsamtinme tusamek idaisaipa”, tiuwai. 
\b  
\q1  
\v 18-19 Tusa imatjumin Apajuí juju nugka juna aneau asa, 
\q1 wait anenjamag chichagtamak: 
\b  
\q1 “Juju shiig antuktajum: 
\q1 Trigon, vinon, aceiten shiig kuashat amastatjime, 
\q1 dutikamtai nunú yuwakjum 
\q1 shiig aneasjum pujustatjume. 
\q1 Ataktu awagkinuk tikich aents aidau 
\q1 dushiktai atinme tusanuk idaisashtatjime. 
\q1  
\v 20-21 Nujinmaya aidau manchijai betek 
\q1 atumin ajaantugmatsuk jetepakaja nunak 
\q1 uwegshunum utsagtatjai. 
\q1 Untsu igku jetepaktata nunak, 
\q1 nayants jakau tutaya nuwi utsaan ijinattajai. 
\q1 Tuja ukuunum jetepaktata nunak 
\q1 nayants mediterraneonum utsaan ijinattajai. 
\q1 ¡Dutika ai nunú kauja senchi mejettawai! 
\b  
\q1 “Mina aentsug juju nugkanum batsatutigmek 
\q1 ishamkagtukaigpa, ayatak shiig aneastajum, 
\q1 Tuke Pujuu atumin ayamjutpak, yaunchkesh 
\q1 wainkachbau aidaun iwainaktatui. 
\q1  
\v 22 Kuntin ikamia aidautigmesh, 
\q1 ¡ishamkagtukaigpajum! 
\q1 ¡Ataktu chijichi tsapaktatui! 
\q1 Numi aidaushkam kuashat nejeagtatui, 
\q1 tuja uva aidaush, higo aidaush shiig kuashat aittawai. 
\q1  
\v 23 ¡Atum Jerusalégnumia aidautigmek 
\q1 shiig aneasjum Tuke Pujuu atumi Apajuíjum emematkujum 
\q1 kuntin maajum apeatajum! 
\q1 Apajuí yaunchuk yumin yutumtikjauwa dutiksag 
\q1 yamaishkam yumi yutugtin jegamtai yutumtijattawai. 
\q1 Niina anenken iwaintugmak yagkug yagkujut aig 
\q1 yumi yutut tepeamtai yutuwama nujai betek yutumtijattawai. 
\q1  
\v 24 Nuadui trigo, vino, aceite, shiig kuashat aittawai. 
\b  
\q1  
\v 25 “Atumi ajaji aidaun manchi amukmatai, 
\q1 tuja shiwag aidau tsaigtamkamtai, ajakjinchau 
\q1 wajasujum nunak Apajuí yaunchuk aajakua imanuk awajtugmastatui. 
\q1  
\v 26-27 Atumek shiig yuwajum pujusjum 
\q1 Apajuí ememattinaitjume, 
\q1 wagki nii atumin ayamjutpak 
\q1 wainchatai ishamain aidaun kuashat iwainajui. 
\q1 Nuadui niina aentsji aidauk wainka inatsamak yujashtinai. 
\b  
\q1 “Witjai Israel aents aidaun Apajuíjinuk, 
\q1 wika mina aentsug aidaujai pujajai. 
\q1 Nuadui ima wiki dita Apajuíjig atinaitjai. 
\s1 Apajuí Wakani taamu 
\q1  
\v 28 Nunú uminkamtai, 
\q1 mina Wakanjun ashí susagtinaitjai, 
\q1 dutika ai nuwa aidau, aishmag aidau ashí mina pachitus etsejiagtinai. 
\q1 Tuja múuntuch aidaujaig 
\q1 kajanum chichatnaitjai, 
\q1 untsu datsauch aidaunak pan wantintukan augtinaitjai. 
\q1  
\v 29 Tuja nunú tsawantaik, inak nuwa aidaunash, 
\q1 aishmag aidaunashkam mina Wakanjun susagtinaitjai. 
\q1  
\v 30 Yaunchkesh wainkachbaun ishamain aidaun nayaimpinum iwainagtinaitjai, 
\q1 dutikakun nugkanmashkam, 
\q1 numpan, jiin, senchi bukuitaun iwainagtinaitjai. 
\q1  
\v 31 Etsag etsanjashtinai, 
\q1 tuja nantushkam numpa iman wajastinai, 
\q1 juka eke Tuke Pujuu iina apuji Apajuí minitin 
\q1 tsawan ishamain atina nunú jegatsaig nagkaemaktinai. 
\q1  
\v 32 Imanitaish ima Tuke Pujuunak kajitus umijuinak 
\q1 segaidauk uwemjagtinai. 
\q1 Tuke Pujuu anagkagtuauwa duka imanisag 
\q1 muja Sión yaakat Jerusalégnum uwemtak atinai, 
\q1 Apajuí etejamu aidauk jatsuk uwemjagtinai”, tawai. 
\c 3  
\s1 Apajuí aents aidau pegkegchaujin diijus suwimkan susatin 
\q1  
\v 1 Nunú tsawan jegakuig, 
\q1 Judá wegantu aidau Jerusalégnumia aidaujai 
\q1 achija yajuakbau batsatunak awakjatnaitjai. 
\q1  
\v 2-3 Untsu aents tikich nugkanmaya aidaunak 
\q1 Josafat nugka pakajin ashí ijumjatnaitjai, 
\q1 dutika ijumjan, dita mina aentsug Israel aents aidaun 
\q1 achija yajuakag tikich nugkanum dapampaak 
\q1 emegkajag, dita nugke aidaunashkam atanjag, 
\q1 dita uchiji, nawanji aidaunash kuichkin juwinak, 
\q1 tikich nugkanum sujujag nunú kuichkia duwi 
\q1 vinon sumak umuinak nampenak, 
\q1 nuigtushkam nunú kuichkia duik 
\q1 nuwa akika dutiktai aidaun yujaju asagmatai, suwimkan susagtinaitjai. 
\s1 Tuke Pujuu aents tikich nugkanmaya aidau pegkegchaujin diijus suwimka susatin 
\p  
\v 4 Atum Tiro nugkanum, Sidón nugkanum, filisteo nugkanum batsamin aidautijum mina aentsug Israel aents aidau jeteajum dusha ¿wisha itugkamu asagmea jeteajume? Atsa ¿iikmakmi tusagmek aikajum? Nunú atum eke jeteatsjuminig, wiyá atumnak suwimkan amasan ijinattajime.  
\v 5 Atumek oro, plata, tuja ashí tikich waji pegkeg akik midau aidau yajuakjum, atumi apajuímtaijum emematku ijuntai jegamkamunum ashí utsauwaitjume.  
\v 6 Atum Tironmaya, Sidógnumia aidautijum Judá wegantu aidau Jerusalégnumia aents aidaujai achija yajuakjum, griego aidaun inataiji atinme tusajum Grecia nugkanum sujujuitjume.  
\v 7 Dutikam nuwi batsatun wi ditanak jiija yajuakan ikaunmattajai. Untsu atumnak mina aentsug waitkasuitjum dutiksanuk wishakam iikattajime.  
\v 8 Dutikakun, atumi uchijum aidaun, nawanjum aidaujaí, Judá wegantu aidaunum sujutjattajime. Dutika ai dita yajuakag Sabá aents aidaunum sujujagtinai. Witjai Tuke Pujuunuk, nunak dekas uminkatnun tajai. 
\b  
\q1  
\v 9 Juju chicham tikich aents aidaunum etsegkatajum, 
\q1 dutikajum ¡suntag maanitan yacha aidau ijumjajum 
\q1 shiig umintsatajum! 
\q1 ¡Nunikjum Apajuín aentsji aidaujai maaniatajum! 
\q1  
\v 10 Atumi takataijum aidau maaniaku jukitin, 
\q1 nagki, puyagjai najankatajum. 
\q1 Tuja aents sapig aina nunú, wajiu wajastinme. 
\q1  
\v 11-12 Ashí atum Judá wegantu aidaun 
\q1 shiwaaji aidautijum 
\q1 Josafat nugkanum wamak kaunajum ijunjatajum. 
\q1 Tuja aents kakagchauch maanitan dakitin akush, 
\q1 maanitan yacha wajasag ashí ijunjatnume. 
\q1 Nunikagmin ashí aents jutii aidauti nugken ijus 
\q1 batsamin aidaunak Tuke Pujuu suwimkan susattawai. 
\q1  
\v 13 Wagki nunú aents aidauk shiig pegkegchau ainawai, 
\q1 nunin asagmatai, 
\q1 trigo tsamaku tsupija juutiama numamtuk tsupigta; 
\q1 tuja ajak juutak tsawantak uminkae, 
\q1 nuadui uva tsamakmatai juuka 
\q1 vino najanatasa najatiama numamtuk awajkata. 
\q1 ¡Dita tudauji aidauk dekas shiig múuntai! 
\q1  
\v 14 Tuke Pujuu taatin tsawan uminu asamtai, 
\q1 Josafat nugkanum aents aidau shiig kuashat ijunjaje. 
\q1  
\v 15 Tuja nantuk etsajai mai kajinak suwe wajastatui. 
\q1 Yaya aidaushkam etsanjachagtatui. 
\q1  
\v 16 Tuke Pujuu kajeka muja Siógnum pujusa chichaak 
\q1 ipamtajai betek wajatai, nuna antukag 
\q1 nugkak nayaimpijai uugtatui. 
\q1 Imanitaish Israel aents aidaunak 
\q1 Tuke Pujuu niina aentsji asagmatai kuitamkattawai. 
\s1 Judá wegantu aidauk atakea duish shiig batsamsagtin 
\q1  
\v 17 Tuja Tuke Pujuu niina aentsji aidaun chichajak: 
\q1 “Atumek nunú tsawan uminkui, 
\q1 mina pachittsajum dekas iina Apajuíjiyapi tujuttinaitjume. 
\q1 Wika muja Sión wi etegkamua nuwi pujajai. 
\q1 Jerusalégkak pegkejam mina aneetaijui, 
\q1 nuadui shiwag tikich nugkanmaya aidauk 
\q1 ataktu utuawajag makichkish dajagchagtinai. 
\q1  
\v 18 Apajuí shiwag aidaun suwimkan susa ijinamtai nagkamas, 
\q1 shiig kuashat uva ayau asamtai, 
\q1 vino najanamu aidauk shiig kuashat aittawai, 
\q1 tuja baka aidaushkam shiig kuashat ayau asamtai, 
\q1 nuna muntsuji ijugbauk shiig kuashat 
\q1 mujanmaya yumi betsaka akagama iman atinai. 
\q1 Judá wegantu aidaun nugkenig yumi shiig kuashat aitnai. 
\q1 Mina jegajuiya yumi pukuni jiinki 
\q1 Sitim nugka pakajin ashí ukattinai. 
\q1  
\v 19 Untsu Egipto nugkanmaya aidau, 
\q1 Edom nugkanmaya aidaujai 
\q1 Judá wegantu aidaun utugchatji atsaunak, 
\q1 tuke aneas jetekag dita nugkenig 
\q1 aents utugchatjinchaunak ijinawaju asagmatai, 
\q1 suwimkan susagtatjai. 
\q1 Dutika ai, dita nugkega duka aents atsau 
\q1 bashiak pegkegchau wajas asattawai. 
\q1  
\v 20 Judá wegantu aidau jinauwa nunak wi iikmatkattajai. 
\q1 Nuna dutikau aidauk suwimkan jutsukek pujuschagtatui. 
\q1  
\v 21 Untsu Judá wegantu aidau nugkeg 
\q1 agkan bashiakag asashtinai, 
\q1 Jerusalégchakam agkantak aents atsauk achatnai. 
\q1 Tuja wika Jerusalégnum 
\q1 muja Sión wi etegkamua nuwi pujuttajai”, tawai.