\p \w El|strong="H3588"\w* \w nombre|strong="H8034"\w* \w de|strong="H3588"\w* \w su|strong="H3588"\w* hermano fue \w Joctán|strong="H3355"\w*.  
\v 26 \w Joctán|strong="H3355"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Almodad, \w a|strong="H3068"\w* Selef, \w a|strong="H3068"\w* Hazar-mavet, \w a|strong="H3068"\w* Jera,  
\v 27 \w a|strong="H3068"\w* Adoram, \w a|strong="H3068"\w* Uzal, \w a|strong="H3068"\w* \w Dicla|strong="H1853"\w*,  
\v 28 \w a|strong="H3068"\w* Obal, \w a|strong="H3068"\w* Abimael, \w a|strong="H3068"\w* \w Seba|strong="H7614"\w*,  
\v 29 \w a|strong="H3068"\w* Ofir, \w a|strong="H3068"\w* \w Havila|strong="H2341"\w* y \w a|strong="H3068"\w* \w Jobab|strong="H3103"\w*. \w Todos|strong="H3605"\w* \w éstos|strong="H3605"\w* fueron \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Joctán|strong="H3355"\w*.  
\v 30 Su vivienda \w fue|strong="H1961"\w* desde Mesa en dirección \w a|strong="H3068"\w* Sefar, en la montaña \w oriental|strong="H6924"\w*.   
\p
\v 31 Estos son \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Sem|strong="H8035"\w* según sus \w familias|strong="H4940"\w*, sus lenguas y sus tierras en sus \w naciones|strong="H1471"\w*.   
\p
\v 32 Tales fueron \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Noé|strong="H5146"\w* por sus \w familias|strong="H4940"\w* en sus \w naciones|strong="H1471"\w*. \w De|strong="H1121"\w* éstas fueron divididas las \w naciones|strong="H1471"\w* \w de|strong="H1121"\w* la tierra después del \w diluvio|strong="H3999"\w*.   
\c 11  
\s1 Babilonia  
\p
\v 1 Entonces \w toda|strong="H3605"\w* \w la|strong="H3605"\w* tierra \w tenía|strong="H1961"\w* una sola \w lengua|strong="H8193"\w* y las mismas \w palabras|strong="H1697"\w*.  
\v 2 \w Aconteció|strong="H1961"\w* \w que|strong="H1961"\w* al salir \w hacia|strong="H8033"\w* \w el|strong="H3427"\w* \w oriente|strong="H6924"\w*, encontraron \w una|strong="H4672"\w* llanura en la tierra de Sinar y \w se|strong="H1961"\w* establecieron \w allí|strong="H8033"\w*.   
\p
\v 3 Entonces \w se|strong="H1961"\w* dijeron unos \w a|strong="H3068"\w* otros: Vengan, fabriquemos adobes y quemémoslos con fuego. El \w ladrillo|strong="H3835"\w* les sirvió en lugar de piedra, y el asfalto en lugar de argamasa.  
\v 4 \w Y|strong="H3068"\w* dijeron: Vengan, construyámonos una \w ciudad|strong="H5892"\w* \w y|strong="H5921"\w* una \w torre|strong="H4026"\w* cuya cúspide llegue \w al|strong="H5921"\w* \w cielo|strong="H8064"\w*. Hagámonos un \w nombre|strong="H8034"\w*, \w en|strong="H5921"\w* caso \w de|strong="H5921"\w* \w que|strong="H5921"\w* seamos esparcidos \w por|strong="H5921"\w* \w la|strong="H5921"\w* superficie \w de|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* tierra.   
\p
\v 5 Pero \nd \+w Yavé|strong="H3068"\+w*\nd* \w descendió|strong="H3381"\w* para \w ver|strong="H7200"\w* la \w ciudad|strong="H5892"\w* y la \w torre|strong="H4026"\w* \w que|strong="H1121"\w* \w edificaban|strong="H1129"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hombres|strong="H1121"\w*.  
\v 6 \w Y|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* dijo: \wj \+w Ciertamente|strong="H2005"\+w* \+w son|strong="H3808"\+w* un \+w pueblo|strong="H5971"\+w* y \+w todos|strong="H3605"\+w* \+w ellos|strong="H1992"\+w* \+w tienen|strong="H1992"\+w* \+w la|strong="H3605"\+w* misma \+w lengua|strong="H8193"\+w*. \+w Éste|strong="H2088"\+w* \+w es|strong="H2088"\+w* solo \+w el|strong="H3605"\+w* principio \+w de|strong="H5971"\+w* \+w su|strong="H1992"\+w* \+w obra|strong="H6213"\+w* y \+w nada|strong="H3808"\+w* \+w les|strong="H1992"\+w* \+w hará|strong="H6213"\+w* desistir \+w de|strong="H5971"\+w* \+w lo|strong="H2088"\+w* \+w que|strong="H3808"\+w* planean \+w hacer|strong="H6213"\+w*.\wj*  
\v 7 \wj Vamos, \+w descendamos|strong="H3381"\+w* ya y confundamos \+w allí|strong="H8033"\+w* su \+w lengua|strong="H8193"\+w* para \+w que|strong="H3808"\+w* \+w nadie|strong="H3808"\+w* \+w entienda|strong="H8085"\+w* el \+w lenguaje|strong="H8193"\+w* del \+w otro|strong="H8193"\+w*.\wj*   
\p
\v 8 \nd \+w Yavé|strong="H3068"\+w*\nd* \w los|strong="H5921"\w* dispersó \w de|strong="H5921"\w* \w allí|strong="H8033"\w* \w por|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* superficie \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra, \w y|strong="H5921"\w* desistieron \w de|strong="H5921"\w* construir \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w*.  
\v 9 \w Por|strong="H5921"\w* \w eso|strong="H3651"\w* \w lo|strong="H5921"\w* \w llamó|strong="H7121"\w* Babel, \w porque|strong="H3588"\w* \w allí|strong="H8033"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w confundió|strong="H1101"\w* \w la|strong="H5921"\w* \w lengua|strong="H8193"\w* \w de|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* tierra. \w Desde|strong="H5921"\w* \w allí|strong="H8033"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w los|strong="H5921"\w* esparció \w por|strong="H5921"\w* \w la|strong="H5921"\w* superficie \w de|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* tierra.   
