\q1
\v 10  30 \w gold|strong="H2091"\w* \w bowls|strong="H3713"\w*,  
\q1 410 \w other|strong="H4932"\w* \w silver|strong="H3701"\w* \w bowls|strong="H3713"\w*,  
\q1 \w and|strong="H3967"\w* 1,000 \w other|strong="H4932"\w* \w vessels|strong="H3627"\w*.   
\p
\v 11  \w All|strong="H3605"\w* \w these|strong="H3605"\w* \w gold|strong="H2091"\w* \w and|strong="H3967"\w* \w silver|strong="H3701"\w* \w vessels|strong="H3627"\w* totaled 5,400. \w Sheshbazzar|strong="H8339"\w* \w brought|strong="H5927"\w* \w them|strong="H5927"\w* \w all|strong="H3605"\w* \w along|strong="H5973"\w* \w when|strong="H5927"\w* \w the|strong="H3605"\w* \w captives|strong="H1473"\w* \w were|strong="H3627"\w* \w brought|strong="H5927"\w* \w up|strong="H5927"\w* \w from|strong="H5927"\w* Babylon \w to|strong="H5927"\w* \w Jerusalem|strong="H3389"\w*.   
\c 2  
\p
\v 1  \w These|strong="H4428"\w* \w are|strong="H1121"\w* \w the|strong="H7725"\w* \w people|strong="H1121"\w* \w of|strong="H1121"\w* \w the|strong="H7725"\w* \w province|strong="H4082"\w* \w who|strong="H1121"\w* \w were|strong="H1121"\w* \w going|strong="H5927"\w* \w up|strong="H5927"\w*, \w from|strong="H7725"\w* \w the|strong="H7725"\w* \w captives|strong="H7628"\w* \w of|strong="H1121"\w* \w the|strong="H7725"\w* \w exile|strong="H1540"\w* whom \w King|strong="H4428"\w* \w Nebuchadnezzar|strong="H5020"\w* \w of|strong="H1121"\w* Babylon \w had|strong="H4428"\w* forced \w into|strong="H1540"\w* \w exile|strong="H1540"\w* \w in|strong="H4428"\w* Babylon. \w They|strong="H3389"\w* \w returned|strong="H7725"\w* \w to|strong="H7725"\w* \w Jerusalem|strong="H3389"\w* \w and|strong="H1121"\w* \w Judah|strong="H3063"\w*, \w each|strong="H4082"\w* \w to|strong="H7725"\w* \w his|strong="H7725"\w* own \w city|strong="H5892"\w*.  
