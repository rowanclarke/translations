\v 19 Los esclavos \w de|strong="H4480"\w* los \w jefes|strong="H8269"\w* \w de|strong="H4480"\w* las \w provincias|strong="H4082"\w* \w salieron|strong="H3318"\w* \w de|strong="H4480"\w* la \w ciudad|strong="H5892"\w*, y el \w ejército|strong="H2428"\w*, tras \w ellos|strong="H4480"\w*.
\v 20 Cada cual \w mató|strong="H5221"\w* \w al|strong="H5921"\w* \w que|strong="H5921"\w* iba \w contra|strong="H5921"\w* \w él|strong="H5921"\w*. \w Los|strong="H5921"\w* sirios \w huyeron|strong="H5127"\w*, \w e|strong="H3068"\w* \w Israel|strong="H3478"\w* \w los|strong="H5921"\w* \w persiguió|strong="H7291"\w*. Pero Ben-hadad, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Siria, \w escapó|strong="H4422"\w* \w a|strong="H3068"\w* \w caballo|strong="H5483"\w* \w con|strong="H5921"\w* algunos \w jinetes|strong="H6571"\w*.
\v 21 El \w rey|strong="H4428"\w* de \w Israel|strong="H3478"\w* \w salió|strong="H3318"\w* y atacó \w a|strong="H3068"\w* la caballería y \w a|strong="H3068"\w* los carruajes, y derrotó \w a|strong="H3068"\w* los sirios con una \w gran|strong="H1419"\w* matanza.
\p 
\v 22 \w Luego|strong="H5927"\w* \w el|strong="H5921"\w* \w profeta|strong="H5030"\w* \w fue|strong="H3212"\w* \w al|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w y|strong="H3588"\w* \w le|strong="H5921"\w* dijo: \w Vé|strong="H3212"\w*, \w fortalécete|strong="H2388"\w*. \w Considera|strong="H3045"\w* \w y|strong="H3588"\w* \w mira|strong="H7200"\w* \w lo|strong="H5921"\w* \w que|strong="H3588"\w* \w tienes|strong="H3045"\w* \w que|strong="H3588"\w* \w hacer|strong="H6213"\w*, \w porque|strong="H3588"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Siria volverá \w contra|strong="H5921"\w* \w ti|strong="H5921"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* primavera \w del|strong="H5921"\w* próximo \w año|strong="H8141"\w*.
\p 
\v 23 \w Y|strong="H3068"\w* \w los|strong="H1992"\w* esclavos \w del|strong="H4480"\w* \w rey|strong="H4428"\w* \w de|strong="H4480"\w* Siria \w le|strong="H5921"\w* dijeron: \w Sus|strong="H1992"\w* \tl ʼelohim\tl* \w son|strong="H3808"\w* \tl ʼelohim\tl* \w de|strong="H4480"\w* \w las|strong="H1992"\w* montañas. \w Por|strong="H5921"\w* \w eso|strong="H3651"\w* fueron \w más|strong="H4480"\w* fuertes \w que|strong="H4480"\w* \w nosotros|strong="H5921"\w*, pero \w si|strong="H3808"\w* combatimos \w contra|strong="H5921"\w* \w ellos|strong="H1992"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* llanura, \w sin|strong="H3808"\w* duda seremos \w más|strong="H4480"\w* fuertes \w que|strong="H4480"\w* \w ellos|strong="H1992"\w*.
\v 24 \w Haz|strong="H6213"\w* \w esto|strong="H2088"\w*: \w Saca|strong="H5493"\w* \w a|strong="H3068"\w* \w cada|strong="H1697"\w* uno \w de|strong="H8478"\w* los \w reyes|strong="H4428"\w* \w de|strong="H8478"\w* su puesto, y coloca \w capitanes|strong="H6346"\w* \w en|strong="H5493"\w* su \w lugar|strong="H4725"\w*.
\v 25 Organiza otro \w ejército|strong="H2428"\w* para ti, \w como|strong="H3651"\w* \w el|strong="H5307"\w* \w que|strong="H3808"\w* perdiste, \w caballo|strong="H5483"\w* \w por|strong="H3651"\w* \w caballo|strong="H5483"\w* y carruaje \w por|strong="H3651"\w* carruaje. \w Pelearemos|strong="H3898"\w* contra \w ellos|strong="H1992"\w* en la llanura, y \w sin|strong="H3808"\w* duda seremos \w más|strong="H3808"\w* \w fuertes|strong="H2428"\w* \w que|strong="H3808"\w* \w ellos|strong="H1992"\w*. \w Escuchó|strong="H8085"\w* la \w voz|strong="H6963"\w* \w de|strong="H3898"\w* \w ellos|strong="H1992"\w*, y \w lo|strong="H3808"\w* \w hizo|strong="H6213"\w* \w así|strong="H3651"\w*.
\p 
\v 26 \w Aconteció|strong="H1961"\w* \w el|strong="H5973"\w* \w año|strong="H8141"\w* siguiente \w que|strong="H1961"\w* Ben-hadad pasó revista \w a|strong="H3068"\w* \w los|strong="H5973"\w* sirios, y \w fue|strong="H1961"\w* \w a|strong="H3068"\w* Afec \w para|strong="H1961"\w* \w combatir|strong="H4421"\w* \w contra|strong="H5973"\w* \w Israel|strong="H3478"\w*.
