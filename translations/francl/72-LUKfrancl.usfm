\v 8 \w Jésus|strong="G2424"\w* \w lui|strong="G2532"\w* \w répondit|strong="G3004"\w* : « \w Il|strong="G2532"\w* \w est|strong="G3588"\w* \w écrit|strong="G1125"\w* : \qt Tu adoreras le Seigneur ton Dieu, et tu le serviras lui seul.\qt* »  
\v 9 \w Le|strong="G2532"\w* démon \w le|strong="G2532"\w* \w conduisit|strong="G2532"\w* \w encore|strong="G2532"\w* \w à|strong="G1519"\w* \w Jérusalem|strong="G2419"\w*, \w et|strong="G2532"\w* \w l|strong="G1161"\w*’\w ayant|strong="G2532"\w* placé \w sur|strong="G1909"\w* \w le|strong="G2532"\w* pinacle \w du|strong="G2532"\w* \w temple|strong="G2411"\w*, \w il|strong="G2532"\w* \w lui|strong="G2532"\w* \w dit|strong="G3004"\w* : « \w Si|strong="G1487"\w* \w tu|strong="G2532"\w* \w es|strong="G3588"\w* \w Fils|strong="G5207"\w* \w de|strong="G2532"\w* \w Dieu|strong="G2316"\w*, \w jette-toi|strong="G2532"\w* \w d|strong="G1519"\w*’\w ici|strong="G1782"\w* \w en|strong="G2532"\w* \w bas|strong="G2736"\w*.  
