\v 4 \w Oh|strong="H1121"\w* \w hombres|strong="H1121"\w*, \w a|strong="H3068"\w* vosotros \w clamo|strong="H7121"\w*; y mi \w voz|strong="H6963"\w* \add es\add* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hombres|strong="H1121"\w*.   
