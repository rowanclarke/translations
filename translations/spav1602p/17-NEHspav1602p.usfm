\v 29 Después \w de|strong="H5048"\w* ellos \w restauró|strong="H2388"\w* \w Sadoc|strong="H6659"\w* \w hijo|strong="H1121"\w* \w de|strong="H5048"\w* Imer, \w enfrente|strong="H5048"\w* \w de|strong="H5048"\w* su \w casa|strong="H1004"\w*: y después \w de|strong="H5048"\w* \w él|strong="H1121"\w* \w restauró|strong="H2388"\w* \w Semaías|strong="H8098"\w* \w hijo|strong="H1121"\w* \w de|strong="H5048"\w* Secanías, guar­da \w de|strong="H5048"\w* \w la|strong="H8104"\w* \w puerta|strong="H8179"\w* \w oriental|strong="H4217"\w*.
\m 
\v 30 Tras \w él|strong="H1121"\w* \w restauró|strong="H2388"\w* \w Hananías|strong="H2608"\w* \w hijo|strong="H1121"\w* \w de|strong="H5048"\w* Selemías, y Anún \w hijo|strong="H1121"\w* \w sexto|strong="H8345"\w* \w de|strong="H5048"\w* Salaf, la \w otra|strong="H8145"\w* \w medida|strong="H4060"\w*. \w Después|strong="H8145"\w* \w de|strong="H5048"\w* \w él|strong="H1121"\w* \w restauró|strong="H2388"\w* Mesulam, \w hijo|strong="H1121"\w* \w de|strong="H5048"\w* Berequías, \w enfrente|strong="H5048"\w* \w de|strong="H5048"\w* su cámara.
\m 
\v 31 \w Después|strong="H5704"\w* \w de|strong="H5048"\w* \w él|strong="H1121"\w* \w restauró|strong="H2388"\w* Malquías \w hijo|strong="H1121"\w* del platero, \w hasta|strong="H5704"\w* la \w casa|strong="H1004"\w* \w de|strong="H5048"\w* \w los|strong="H1121"\w* netineos \w y|strong="H5704"\w* \w de|strong="H5048"\w* \w los|strong="H1121"\w* tratantes, \w enfrente|strong="H5048"\w* \w de|strong="H5048"\w* la \w puerta|strong="H8179"\w* del Juicio, \w y|strong="H5704"\w* \w hasta|strong="H5704"\w* la sala \w de|strong="H5048"\w* la esquina.
\m 
\v 32 \w Y|strong="H3068"\w* entre la sala de la esquina hasta la \w puerta|strong="H8179"\w* de las \w ovejas|strong="H6629"\w*, res­tauraron los plateros y los tratan­tes.
\c 4
\m 
\v 1 \w Y|strong="H3068"\w* \w SUCEDIÓ|strong="H1961"\w* \w que|strong="H3588"\w* \w como|strong="H3588"\w* \w oyó|strong="H8085"\w* Sanbalat \w que|strong="H3588"\w* nosotros edificábamos \w el|strong="H3588"\w* \w muro|strong="H2346"\w*, encolerizóse \w y|strong="H3588"\w* \w enojóse|strong="H2734"\w* \w en|strong="H3588"\w* \w gran|strong="H3966"\w* \w manera|strong="H3966"\w*, \w e|strong="H3068"\w* \w hizo|strong="H5927"\w* escarnio \w de|strong="H3588"\w* \w los|strong="H1961"\w* judíos.
\m 
\v 2 \w Y|strong="H3068"\w* habló delante \w de|strong="H3898"\w* sus hermanos y del ejército \w de|strong="H3898"\w* Samaria, y dijo: ¿\w Qué|strong="H3605"\w* \w hacen|strong="H6213"\w* \w estos|strong="H3605"\w* débiles judíos? ¿se fortificarán? ¿han \w de|strong="H3898"\w* sacrificar? ¿han \w de|strong="H3898"\w* acabar en \w un|strong="H3162"\w* día? ¿han \w de|strong="H3898"\w* resucitar las piedras \w de|strong="H3898"\w* \w los|strong="H3605"\w* montones \w de|strong="H3898"\w* escombro \w que|strong="H3605"\w* fueron quemados?
\m 
\v 3 \w Y|strong="H3068"\w* \w estaba|strong="H5975"\w* \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w él|strong="H5921"\w* Tobías amonita, \w el|strong="H5921"\w* cual dijo: Aun \w lo|strong="H5921"\w* \w que|strong="H5921"\w* \w ellos|strong="H5921"\w* edifican, \w si|strong="H6440"\w* subiere una zorra derribará su muro \w de|strong="H5921"\w* \w pie|strong="H5975"\w*­dra.
\m 
\v 4 Oye, oh Dios nuestro, \w que|strong="H3808"\w* somos en menosprecio, y vuelve el baldón de ellos sobre su cabe­za, y dalos en presa en la \w tierra|strong="H6083"\w* de su cautiverio:
\m 
\v 5 \w Y|strong="H3068"\w* \w no|strong="H3808"\w* cubras su iniquidad, \w ni|strong="H3808"\w* su pecado sea raído \w delante|strong="H5704"\w* \w de|strong="H5704"\w* tu rostro; \w porque|strong="H3808"\w* \w se|strong="H3045"\w* airaron contra los \w que|strong="H3808"\w* edificaban.
\m 
\v 6 Edificamos \w pues|strong="H1961"\w* \w el|strong="H5921"\w* muro, \w y|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* muralla \w fue|strong="H1961"\w* juntada \w hasta|strong="H5921"\w* su mitad: \w porque|strong="H5921"\w* \w el|strong="H5921"\w* pueblo \w tenía|strong="H1961"\w* \w una|strong="H6471"\w* mente \w para|strong="H5921"\w* trabajar.
\m 
\v 7 Mas acaeció \w que|strong="H5971"\w* oyendo Sanbalat y Tobías, y \w los|strong="H5973"\w* árabes, y \w los|strong="H5973"\w* amonitas, y \w los|strong="H5973"\w* \w de|strong="H5973"\w* Asdod, \w que|strong="H5971"\w* \w los|strong="H5973"\w* \w muros|strong="H2346"\w* \w de|strong="H5973"\w* Jerusalem eran reparados, porque ya \w los|strong="H5973"\w* portillos comenzaban \w a|strong="H3068"\w* cerrarse, encoleri­záronse mucho;
\m 
\v 8 \w Y|strong="H3068"\w* conspiraron todos \w a|strong="H3068"\w* una \w para|strong="H5921"\w* venir \w a|strong="H3068"\w* combatir \w a|strong="H3068"\w* Jerusalem, \w y|strong="H5921"\w* \w a|strong="H3068"\w* hacerle daño.
\m 
\v 9 \w Entonces|strong="H3588"\w* oramos \w a|strong="H3068"\w* nuestro Dios, \w y|strong="H3588"\w* \w por|strong="H3588"\w* causa \w de|strong="H3588"\w* \w ellos|strong="H3605"\w* pusi­mos guarda \w contra|strong="H1961"\w* \w ellos|strong="H3605"\w* \w de|strong="H3588"\w* día \w y|strong="H3588"\w* \w de|strong="H3588"\w* noche.
\m 
\v 10 \w Y|strong="H3068"\w* dijo \w Judá|strong="H3063"\w*: Las fuerzas \w de|strong="H4480"\w* \w los|strong="H3605"\w* acarreadores \w se|strong="H1961"\w* han enflaque­cido, y \w el|strong="H1931"\w* escombro \w es|strong="H1931"\w* mucho, y \w no|strong="H6213"\w* podemos edificar \w el|strong="H1931"\w* muro.
\m 
\v 11 \w Y|strong="H3068"\w* nuestros enemigos dijeron: \w No|strong="H6213"\w* sepan, ni vean, hasta \w que|strong="H3027"\w* entremos en \w medio|strong="H3027"\w* de \w ellos|strong="H3027"\w*, y los matemos, y \w hagamos|strong="H6213"\w* cesar la \w obra|strong="H4399"\w*.
\m 
\v 12 \w Y|strong="H3068"\w* sucedió, \w que|strong="H5921"\w* \w como|strong="H5921"\w* vinieron \w los|strong="H5921"\w* judíos \w que|strong="H5921"\w* habita­ban \w entre|strong="H5921"\w* \w ellos|strong="H5921"\w*, \w nos|strong="H5921"\w* dieron aviso diez veces \w de|strong="H5921"\w* todos \w los|strong="H5921"\w* lugares \w de|strong="H5921"\w* \w donde|strong="H5921"\w* volvían \w a|strong="H3068"\w* \w nosotros|strong="H5921"\w*.
\m 
\v 13 Entonces puse \w por|strong="H5921"\w* \w los|strong="H5921"\w* bajos \w del|strong="H5921"\w* lugar, detrás \w del|strong="H5921"\w* \w muro|strong="H2346"\w*, \w en|strong="H5921"\w* \w las|strong="H5921"\w* alturas \w de|strong="H5921"\w* \w los|strong="H5921"\w* peñascos, puse \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w por|strong="H5921"\w* familias \w con|strong="H5921"\w* sus espa­das, \w con|strong="H5921"\w* sus lanzas, \w y|strong="H5921"\w* \w con|strong="H5921"\w* sus arcos.
\m 
\v 14 Después miré, y levantéme, y dije \w a|strong="H3068"\w* los principales y \w a|strong="H3068"\w* los magistrados, y al resto del pue­blo: No temáis delante \w de|strong="H3898"\w* ellos: acordaos del Señor grande y terrible, y pelead por vuestros hermanos, por vuestros hijos y por vuestras hijas, por vuestras esposas y por vuestras casas.
\m 
\v 15 \w Y|strong="H3068"\w* sucedió \w que|strong="H5704"\w* \w como|strong="H5704"\w* oyeron nuestros enemigos \w que|strong="H5704"\w* \w lo|strong="H6213"\w* \w había|strong="H6213"\w*­mos entendido, Dios disipó \w el|strong="H6213"\w* consejo \w de|strong="H5704"\w* ellos, \w y|strong="H5704"\w* volvímonos todos \w al|strong="H5704"\w* muro, cada uno \w a|strong="H3068"\w* su \w obra|strong="H4399"\w*.
\m 
\v 16 \w Mas|strong="H1571"\w* \w sucedió|strong="H1961"\w* \w que|strong="H1931"\w* desde \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w la|strong="H1931"\w* \w mitad|strong="H8432"\w* \w de|strong="H5971"\w* \w los|strong="H1931"\w* \w mancebos|strong="H5288"\w* traba­jaba \w en|strong="H8432"\w* \w la|strong="H1931"\w* \w obra|strong="H4399"\w*, \w y|strong="H1571"\w* \w la|strong="H1931"\w* otra \w mitad|strong="H8432"\w* \w de|strong="H5971"\w* \w ellos|strong="H1931"\w* \w tenía|strong="H1961"\w* lanzas \w y|strong="H1571"\w* escudos, \w y|strong="H1571"\w* arcos, \w y|strong="H1571"\w* corazas; \w y|strong="H1571"\w* \w los|strong="H1931"\w* príncipes \w estaban|strong="H1961"\w* tras toda \w la|strong="H1931"\w* casa \w de|strong="H5971"\w* Judá.
\m 
\v 17 Los \w que|strong="H4325"\w* edificaban en el muro, y los \w que|strong="H4325"\w* llevaban cargas y los \w que|strong="H4325"\w* cargaban, con la una mano trabajaban en la obra, y en la otra tenían la espada.
\m 
\v 18 Porque los que edificaban, cada uno tenía su espada ceñida \w a|strong="H3068"\w* sus lomos, y así edificaban: y el que tocaba la trompeta estaba junto \w a|strong="H3068"\w* mí.
\m 
\v 19 \w Y|strong="H3068"\w* dije \w a|strong="H3068"\w* los principales, y \w a|strong="H3068"\w* los magistrados y al resto del pue­blo: La obra es grande y larga, y nosotros estamos apartados en el muro, lejos los unos de los otros:
\m 
\v 20 En el lugar donde oyereis la voz de la trompeta, reuníos allí \w a|strong="H3068"\w* nosotros: nuestro Dios peleará por nosotros.
\m 
\v 21 Nosotros pues trabajábamos en la obra; y la mitad de ellos tenían lanzas desde la subida del alba hasta salir las estrellas.
\m 
\v 22 También dije entonces al pue­blo: Cada uno con su criado se quede dentro de Jerusalem, y hágannos de noche centinela, y de día \w a|strong="H3068"\w* la obra.
\m 
\v 23 \w Y|strong="H3068"\w* ni yo, ni mis hermanos, ni mis mozos, ni la gente de guardia que me seguía, desnudamos nuestra vestidura: cada uno se des­nudaba \add solamente\add* para lavarse.
\c 5
\m 
\v 1 ENTONCES \w fue|strong="H1961"\w* \w grande|strong="H1419"\w* el cla- mor del \w pueblo|strong="H5971"\w* y \w de|strong="H5971"\w* sus esposas \w contra|strong="H1961"\w* \w los|strong="H1961"\w* \w judíos|strong="H3064"\w* sus hermanos.
\m 
\v 2 \w Y|strong="H3068"\w* \w había|strong="H3426"\w* quien decía: Nosotros, nuestros \w hijos|strong="H1121"\w* y nuestras \w hijas|strong="H1323"\w*, somos \w muchos|strong="H7227"\w*: hemos por tanto \w tomado|strong="H3947"\w* \w grano|strong="H1715"\w* para comer y \w vivir|strong="H2421"\w*.
\m 
\v 3 \w Y|strong="H3068"\w* \w había|strong="H3426"\w* quienes decían: Hemos empeñado nuestras \w tierras|strong="H7704"\w*, y nuestras \w viñas|strong="H3754"\w*, y nuestras \w casas|strong="H1004"\w*, \w para|strong="H6148"\w* comprar \w grano|strong="H1715"\w* en el ham­bre.
\m 
\v 4 \w Y|strong="H3068"\w* \w había|strong="H3426"\w* quienes decían: Hemos tomado prestado \w dinero|strong="H3701"\w* para el tributo del \w rey|strong="H4428"\w*, sobre nuestras tie­rras y \w viñas|strong="H3754"\w*.
\m 
\v 5 \w Ahora|strong="H6258"\w* bien, nuestra \w carne|strong="H1320"\w* \w es|strong="H3027"\w* como la \w carne|strong="H1320"\w* \w de|strong="H1121"\w* nuestros her­\w manos|strong="H3027"\w*, nuestros \w hijos|strong="H1121"\w* como sus \w hijos|strong="H1121"\w*: y he \w aquí|strong="H2009"\w* \w que|strong="H6258"\w* nosotros sujetamos nuestros \w hijos|strong="H1121"\w* y nues­tras \w hijas|strong="H1323"\w* \w a|strong="H3068"\w* servidumbre, y \w hay|strong="H3426"\w* algunas \w de|strong="H1121"\w* nuestras \w hijas|strong="H1323"\w* sujetas: \w mas|strong="H6258"\w* no \w hay|strong="H3426"\w* facultad en nuestras \w manos|strong="H3027"\w* \w para|strong="H6258"\w* rescatarlas, \w porque|strong="H2009"\w* nuestras \w tierras|strong="H7704"\w* y nuestras \w viñas|strong="H3754"\w* son \w de|strong="H1121"\w* otros.
\m 
\v 6 \w Y|strong="H3068"\w* enojéme en \w gran|strong="H3966"\w* \w manera|strong="H1697"\w* cuando \w oí|strong="H8085"\w* su \w clamor|strong="H2201"\w* y estas pala­bras.
\m 
\v 7 \w Medité|strong="H4427"\w*\add lo\add* entonces \w para|strong="H5921"\w* conmi­go, \w y|strong="H5921"\w* reprendí \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w principales|strong="H2715"\w* \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* magistrados, \w y|strong="H5921"\w* díjeles: ¿Tomáis cada uno usura \w de|strong="H5921"\w* vues­tros hermanos? \w Y|strong="H3068"\w* convoqué \w con|strong="H5921"\w*­tra \w ellos|strong="H5921"\w* una \w grande|strong="H1419"\w* asamblea.
\m 
\v 8 \w Y|strong="H3068"\w* díjeles: Nosotros \w rescatamos|strong="H7069"\w* \w a|strong="H3068"\w* nuestros hermanos \w judíos|strong="H3064"\w* \w que|strong="H3808"\w* habían sido \w vendidos|strong="H4376"\w* \w a|strong="H3068"\w* las gen­tes, conforme \w a|strong="H3068"\w* \w la|strong="H1571"\w* facultad \w que|strong="H3808"\w* \add había\add* en nosotros: ¿\w y|strong="H1571"\w* vosotros \w aun|strong="H1571"\w* vendéis \w a|strong="H3068"\w* vuestros herma­nos, \w y|strong="H1571"\w* serán \w vendidos|strong="H4376"\w* \w a|strong="H3068"\w* nosotros? \w Y|strong="H3068"\w* callaron, \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w tuvieron|strong="H4672"\w* \w qué|strong="H3808"\w* responder.
\m 
\v 9 \w Y|strong="H3068"\w* dije: \w No|strong="H3808"\w* \w es|strong="H1697"\w* \w bien|strong="H2896"\w* \w lo|strong="H1697"\w* \w que|strong="H3808"\w* \w hacéis|strong="H6213"\w*, ¿\w no|strong="H3808"\w* \w andaréis|strong="H3212"\w* \w en|strong="H3212"\w* \w temor|strong="H3374"\w* \w de|strong="H1697"\w* nuestro Dios, \w por|strong="H1697"\w* \add no ser\add* \w el|strong="H6213"\w* opro­bio \w de|strong="H1697"\w* las \w gentes|strong="H1471"\w* enemigas nues­tras?
\m 
\v 10 \w También|strong="H1571"\w* \w yo|strong="H4994"\w*, \w y|strong="H1571"\w* mis hermanos, \w y|strong="H1571"\w* mis \w criados|strong="H5288"\w*, les hemos presta­do \w dinero|strong="H3701"\w* \w y|strong="H1571"\w* \w grano|strong="H1715"\w*: \w relevémosles|strong="H5800"\w* \w ahora|strong="H4994"\w* de \w este|strong="H2088"\w* gravamen.
\m 
\v 11 \w Ruégoos|strong="H4994"\w* \w que|strong="H4994"\w* les devolváis \w hoy|strong="H3117"\w* sus \w tierras|strong="H7704"\w*, sus \w viñas|strong="H3754"\w*, sus oli­vares, y sus \w casas|strong="H1004"\w*, y la centésima parte del \w dinero|strong="H3701"\w* y \w grano|strong="H1715"\w*, del \w vino|strong="H8492"\w* y del \w aceite|strong="H3323"\w* \w que|strong="H4994"\w* \w demandáis|strong="H5383"\w* de ellos.
\m 
\v 12 \w Y|strong="H3068"\w* \w dijeron|strong="H1697"\w*: \w Devolveremos|strong="H7725"\w*, y \w nada|strong="H3808"\w* \w les|strong="H1992"\w* demandaremos; \w hare|strong="H6213"\w*­mos \w así|strong="H3651"\w* \w como|strong="H3651"\w* \w tú|strong="H6213"\w* \w dices|strong="H1697"\w*. \w Entonces|strong="H3651"\w* convoqué \w los|strong="H1992"\w* \w sacerdotes|strong="H3548"\w*, y \w jura|strong="H7650"\w*­mentélos \w que|strong="H3808"\w* harían conforme \w a|strong="H3068"\w* \w esto|strong="H2088"\w*.
\m 
\v 13 \w Además|strong="H1571"\w* \w sacudí|strong="H5287"\w* \w mi|strong="H1961"\w* vestidura, \w y|strong="H1571"\w* dije: \w Así|strong="H3602"\w* \w sacuda|strong="H5287"\w* \w Dios|strong="H3068"\w* \w de|strong="H5971"\w* su \w casa|strong="H1004"\w* \w y|strong="H1571"\w* \w de|strong="H5971"\w* su \w trabajo|strong="H3018"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* hombre \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w cumpliere|strong="H6965"\w* \w esto|strong="H2088"\w*, \w y|strong="H1571"\w* \w así|strong="H3602"\w* \w sea|strong="H1961"\w* \w sacudido|strong="H5287"\w* \w y|strong="H1571"\w* vacío. \w Y|strong="H3068"\w* respondió \w toda|strong="H3605"\w* \w la|strong="H1571"\w* \w congregación|strong="H6951"\w*: ¡Amén! \w Y|strong="H3068"\w* alabaron al \w SEÑOR|strong="H3068"\w*. \w Y|strong="H3068"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* \w hizo|strong="H6213"\w* conforme \w a|strong="H3068"\w* \w esto|strong="H2088"\w*.
\m 
