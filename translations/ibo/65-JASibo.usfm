\id JAS - Biblica® Open Igbo Contemporary Bible 2020
\h Jemis
\toc1 Jemis
\toc2 Jemis
\toc3 Jem
\mt1 Jemis
\c 1
\p 
\v 1 Jemis, nwaodibo Chineke na nke Onyenwe anyị Jisọs Kraịst,
\b
\p Na-edegara agbụrụ iri na abụọ ndị gbasara nʼelu ụwa niile akwụkwọ ozi a:
\b
\p Ndeewonụ!
\b
\s1 Ọnwụnwa na nsogbu
\p 
\v 2 Ụmụnna m, ka obi unu jupụta nʼọṅụ mgbe ọbụla ọnwụnwa dị iche iche gbara unu gburugburu.
\v 3 Nʼihi na mgbe a na-anwa okwukwe unu ọnwụnwa, ntachiobi unu na-enwe ohere ito eto.
\v 4 Ka nguzosike unu pụta ìhè, ka unu zuo oke ma nwezuokwa ihe niile, na-adịghị ihe ọbụla nke ga-akọ unu.
\v 5 Ọ bụrụ na ọ dị onye na-enweghị amamihe, ya rịọ Chineke, onye na-enye onye ọbụla rịọrọ ya amamihe nʼafọ ofufu na-ataghịkwa onye ọbụla ụta, a ga-ewerekwa ya nye ya.
\v 6 Ma rịọọ nʼokwukwe na-enweghị obi abụọ, nʼihi na onye na-enwe obi abụọ dị ka ebili mmiri oke osimiri mgbe ikuku na-ebugharị ya.
\v 7 Onye dị otu ahụ ekwesighị ile anya na ọ ga-esite nʼaka Onyenwe anyị nata ihe ọbụla.
\v 8 Nʼihi na mmadụ dị otu a bụ onye ihu abụọ, onye na-adịghị eguzo nʼotu ebe nʼihe ọbụla ọ na-eme.
\p 
\v 9 Ka nwanna ọbụla bụ ogbenye ṅụrịa ọṅụ, mgbe ọbụla e weliri ya elu.
\v 10 Ka onye bụ ọgaranya mgbe a na-eme ka ọ nọdụ ya dị ala, nʼihi na ndị bara ụba ga-akpọnwụ dị ka okoko osisi.
\v 11 Nʼihi na mgbe ọbụla anwụ waliri chasie ike, wepụta okpomọkụ, ọ na-eme ka ahịhịa kpọnwụọ, ka okoko osisi daa nʼala, mma ya agwụsịakwa. Nʼotu aka ahụ, onye ahụ bara ụba ga-akpọnwụ ọ bụladị mgbe ọ na-ejegharị nʼime ije ozi ya.
\p 
\v 12 Ngọzị na-adịrị onye ahụ nke na-anọgide na-adịghị ada mba nʼoge ọnwụnwa. Nʼihi na mgbe oge ọnwụnwa ahụ gasịrị, ọ ga-anata ụgwọ ọrụ, nke bụ okpueze ndụ, nke Chineke kwere nkwa inye ndị niile hụrụ ya nʼanya.
\p 
\v 13 Ka onye ọbụla hapụ ị sị, mgbe a na-anwa ya, “Ọ bụ Chineke na-anwa m ọnwụnwa a.” Nʼihi na ọ dịghị mgbe a pụrụ ịnwa Chineke ka o mee ihe ọjọọ, ọ dịkwaghị anwa mmadụ ọbụla ka o mee ihe ọjọọ.
\v 14 Kama ọnwụnwa na-abịara mmadụ site nʼọchịchọ nke obi ya. Ọ bụkwa ọchịchọ ọjọọ nke mmadụ na-arafu ya, dọkpụfuo ya.
\v 15 Ọchịchọ ahụ, mgbe ha bara ụba nʼime obi, na-eduba mmadụ na mmehie. Mgbe mmehie bara ụba, ọ na-eduba nʼọnwụ.
\p 
\v 16 Ekwela ka onye ọbụla duhie unu ụmụnna m.
\v 17 Onyinye ọbụla dị mma, na nke zuruoke na-esite nʼeluigwe abịa. Ọ na-esite nʼebe Nna nke ìhè niile onye na-adịghị agbanwe agbanwe, ọ naghị ezonarị ụmụ mmadụ ihu ya.
\v 18 Nʼihi imezu nzube ya, o sitere nʼokwu ya bụ eziokwu mụọ anyị. O mekwara nke a ka anyị bụrụ ụmụ mbụ nke ihe o kere eke.
\s1 Ịṅa ntị na ime ihe anyị nụrụ
\p 
\v 19 Unu aghaghị icheta nke a ụmụnna m ndị m hụrụ nʼanya. Ka onye ọbụla nwee ntị na-anụ ihe ọsịịsọ, na ire dị arọ ikwu okwu, ma bụrụkwa onye iwe na-adịghị ewe ọsịịsọ.
\v 20 Nʼihi na iwe nke mmadụ anaghị arụpụta ezi omume nke Chineke.
\v 21 Ya mere, wezuganụ ụzọ rụrụ arụ niile na ihe ọbụla dị njọ nke fọdụrụ nʼime ndụ unu. Ma jirinụ obi umeala nabataranụ onwe unu okwu ndụ ahụ nke a kụrụ nʼobi unu, nke nwere ike ịzọpụta mkpụrụobi unu.
\p 
\v 22 Unu abụla ndị na-eji ntị ha na-anụ okwu ndụ ahụ naanị, na-arafu onwe ha, kama bụrụnụ ndị na-eme ihe okwu ahụ kwuru.
\v 23 Nʼihi na onye ọbụla na-ege ntị nʼokwu ọbụla ma hapụ iji ihe ọ nụrụ mee ihe, dị ka nwoke na-ele ihu ya nʼenyo.
\v 24 O lesịa onwe ya pụọ, o chefuo ihe ihu ya yiri ma nwa oge nta gasịa.
\v 25 Ma nwoke ahụ nọgidesịrị ike na-ele anya nʼime iwu ahụ zuruoke, nke na-eme ka mmadụ nwere onwe ya, ee, nwoke ahụ na-aga nʼihu ile na ime ihe iwu ahụ kwuru, hapụkwa ichefu ya, ka a ga-agọzi nʼihe niile ọ na-eme.
\p 
\v 26 Ọ bụrụ na mmadụ ọbụla echee na ya bụ onye na-ekpere Chineke ma hapụ ijide ire ya aka maọbụ ịkwa ire ya nga, onye dị otu a na-arafu onwe ya, okpukpe Chineke ya bụkwa ihe na-abaghị uru.
\v 27 Ezi okpukpe Chineke, nke Chineke Nna anyị na-anabata dịka okpukpe dị ọcha, na nke na-enweghị mmerụ, bụ nke a, ilekọta ndị na-enweghị nne na nna, na ndị di ha nwụrụ nʼime nsogbu ha na idebe onwe anyị nʼenweghị ntụpọ site nʼaka ndị ụwa.
\c 2
\s1 Ile mmadụ anya nʼihu
\p 
\v 1 Ụmụnna m, dịka ndị kweere nʼOnyenwe anyị Jisọs Kraịst, onye dị ebube, ka unu hapụ ile mmadụ anya nʼihu.
\v 2 Ọ bụrụ na onye ọgaranya yi uwe mara mma, yikwara mgbaaka ọlaedo na mkpịsịaka ya, abata nʼụlọ nzukọ unu, ọ bụrụkwa na nwa ogbenye abata nke yi uwe na-adịghị ọcha,
\v 3 ọ bụrụ na unu elee onye ọgaranya ahụ yi uwe mara mma anya sị ya, “Bịa nọdụ nʼotu oche a e debere iche nʼihi gị,” ma unu asị onye ogbenye ahụ, “Di anyị, guzo nʼebe ahụ,” maọbụ “Bịa nọdụ ala nʼakụkụ ebe a ụkwụ m dị,”
\v 4 ọ bụ na unu akpabeghị oke nʼetiti onwe unu, bụrụkwa ndị ji ile anya nʼihu na obi ọjọọ na-ekpe ikpe?
\p 
\v 5 Geenụ ntị ka m gwa unu ụmụnna m, ọ bụ na unu amataghị na Chineke ahọpụtala ndị ahụ ụwa gụrụ dịka ndị ogbenye, mee ka ha bụrụ ọgaranya site nʼokwukwe ha, ka ha ketakwa alaeze ahụ o kwere nkwa inye ndị hụrụ ya nʼanya?
\v 6 Ma gịnị ka unu na-eme? Unu na-akparị ndị ogbenye! Ọ bụghị ndị ọgaranya na-emegbu unu? Ọ bụkwaghị ha bụ ndị na-adọkpụgharị unu aga nʼụlọikpe?
\v 7 Ọ bụghị ha bụ ndị na-ekwulu aha ọma ahụ nke a gụrụ unu?
\p 
\v 8 Ọ bụrụ na unu na-edebezuo iwu nke eze anyị dịka e dere ya nʼAkwụkwọ Nsọ, “Hụnụ ndị agbataobi unu nʼanya dịka unu onwe unu,”\f + \fr 2:8 \ft \xt Lev 19:18\xt*\f* unu na-eme ihe ziri ezi.
\v 9 Ma ọ bụrụ na unu ele mmadụ anya nʼihu, unu na-eme mmehie. Nʼebe iwu dịkwa, unu bụ ndị na-emebi iwu.
\v 10 Nʼihi na onye ọbụla nke na-edebe iwu ahụ niile ma sụọ ngọngọ nʼotu, a bụrụla onye ikpe iwu ahụ niile maara.
\v 11 Nʼihi na onye ahụ sịrị, “Akwala iko,”\f + \fr 2:11 \ft \xt Ọpụ 20:14; Dit 5:18\xt*\f* bụkwa onye sịrị, “Egbula mmadụ.”\f + \fr 2:11 \ft \xt Ọpụ 20:13; Dit 5:17\xt*\f* Ya mere, ọ bụrụ na ị kwaghị iko ma i gburu mmadụ, ị bụ onye na-emebi iwu.
\p 
\v 12 Ya mere, na-ekwunu okwu, ma na-ebikwanụ ndụ dị ka ndị a ga-ekpe ikpe site nʼiwu ahụ na-eme ka mmadụ nwere onwe ha.
\v 13 Nʼihi na agaghị emere onye ọbụla ebere nke na-adịghị emere onye ọzọ ebere. Nʼihi na ebere na-adị ukwuu karịa ikpe ọmụma ya.
\s1 Okwukwe na omume
\p 
\v 14 Olee uru ọ bara ụmụnna m, na mmadụ sịrị, enwere m okwukwe, ma okwukwe ahụ apụtaghị ihe nʼọrụ ya? Ụdị okwukwe ahụ ọ pụrụ ịzọpụta ya?
\v 15 Ọ bụrụ na otu nwanne anyị nwoke maọbụ nwanne anyị nwanyị yi nkịrịnka akwa, ọ bụrụkwa na o nweghị ihe oriri ga-ezuru ya nʼụbọchị,
\v 16 ma otu onye nʼime unu asị ha, “Laa nʼudo, kpuchiekwa onwe gị nke ọma, rijuokwa afọ,” nʼenyeghị ya ihe dị mkpa maka ahụ ya, uru gịnị ka ọ bara?
\v 17 Nʼụzọ dị otu a, okwukwe naanị ya bụ ihe na-abaghị uru ma ọ bụrụ na ọrụ esoghị ya.
\p 
\v 18 Otu onye ga-asị, “I nwere okwukwe; e nwere m ọrụ.”
\p Gosi m okwukwe gị ma e wepụ ọrụ gị, aga m egosi gị okwukwe site nʼọrụ
\v 19 I kweere na ọ bụ naanị otu Chineke, i mere nke ọma, ọ bụladị ndị mmụọ ọjọọ kweere ma kụja.
\p 
\v 20 Gị onye nzuzu, ị na-achọ ka e gosi gị na okwukwe bụ ihe na-abaghị uru ma ọ bụrụ na ọrụ e soghị ya?
\v 21 Ọ bụ na nna anyị Ebraham abụghị onye a gụrụ nʼonye ezi omume site nʼọrụ ya, mgbe o jiri otu nwa ya bụ Aịzik chụọ aja nʼebe ịchụ aja?
\v 22 Unu ahụghị na okwukwe ya na ọrụ soro rụkọọ nʼotu, e sitekwara nʼọrụ ya mee ka okwukwe ya zuo oke.
\v 23 Ọ bụ site na nke a ka ihe e dere nʼakwụkwọ nsọ jiri mezuo, nke na asị, “Ebraham kweere na Chineke, a gụrụ nke a nye ya dị ka ezi omume,”\f + \fr 2:23 \ft \xt Jen 15:6\xt*\f* kpọọkwa ya enyi Chineke.
\v 24 Unu ahụla na a na-esite nʼihe mmadụ rụrụ gụọ ya nʼonye ezi omume, ọ bụkwaghị naanị nʼokwukwe.
\p 
\v 25 Nʼotu ụzọ ahụ, agụnyeghị Rehab, nwanyị akwụna ahụ nʼonye ezi omume nʼihi ọrụ ọ rụrụ, mgbe ọ kpọbatara ndị nnyopụta ahụ ma zipụkwa ha site nʼụzọ dị iche?
\v 26 Dịka anụ ahụ na-enweghị mmụọ si bụrụ ihe nwụrụ anwụ, otu a ka ọ dịkwa okwukwe na-enweghị ọrụ.
\c 3
\s1 Ịzụ ire anyị
\p 
\v 1 Ụmụnna m, ka ọtụtụ nʼime unu hapụ ịgbalị ịbụ ndị ozizi, nʼihi na unu maara na anyị bụ ndị ozizi ka a ga-ekpe ikpe nʼọnọdụ sikarịrị ike.
\v 2 Nʼihi na anyị niile na-asọ ngọngọ site nʼọtụtụ ụzọ. Ma onye ọbụla nke na-adịghị emehie site nʼikwuhie ọnụ bụ onye tozuru oke na onye pụrụ ijide anụ ahụ ya niile aka.
\p 
\v 3 Ọ bụrụ na anyị e tinye mkpụmkpụ igwe e ji ekechi ọnụ ịnyịnya ibu nʼọnụ ya, ka o rubere anyị isi, anyị na-eduru ya gaa ebe anyị chọrọ.
\v 4 Otu a kwa, ọ bụladị ụgbọ mmiri buru ibu nke ikuku dị ike na-ebugharị nʼosimiri, ka onye na-anya ụgbọ mmiri pụrụ ime ka ọ gaa ebe ọ chọrọ site nʼịtụgharịa ụmara ntakịrị e ji anya ụgbọ.
\v 5 Otu a ka ọ dịkwa ire anyị. Ọ bụ akụkụ anụ ahụ anyị dị nta, ma ọ na-anya isi banyere ọtụtụ ihe. Tulee otu oke ọhịa si dị ukwuu, bụ nke icheku ọkụ dịkarịsịrị nta na-eme ka o nwuru ọkụ.
\v 6 Ire anyị bụ ọkụ. E debere ire nʼetiti akụkụ anụ ahụ ndị ọzọ dịka ụwa ajọ omume. Ọ na-emerụ ahụ niile, na-amụnye ọkụ nʼusoro ndụ mmadụ. Ya onwe ya bụkwa ihe ọkụ ala mmụọ na-amụnye ọkụ.
\p 
\v 7 Mmadụ enweela ike zụọ, na-agbalịkwa ịzụ anụmanụ dị iche iche, na nnụnụ, na anụ na-akpụ akpụ, na anụ bi na mmiri;
\v 8 ma mmadụ ọbụla adịghị nke nwere ike ịzụ ire. Ọ bụ ihe dị oke njọ na-adịghị ekwe nchịkọta, ma jupụtakwa na nsi na-ebute ọnwụ.
\p 
\v 9 Ọ bụ ya ka anyị ji eto Onyenwe anyị na Nna anyị. Ọ bụkwa ya ka anyị ji abụ mmadụ ibe anyị ọnụ, bụ ndị Chineke mere nʼoyiyi nke ya.
\v 10 Site nʼotu ọnụ anyị ka ịja mma na ịbụ ọnụ na-esi apụta. Ụmụnna m, nke a abụghị ihe ziri ezi.
\v 11 Ọ bụ ihe pụrụ ime na mmiri dị mma ịṅụ aṅụ na mmiri nnu ga-esite nʼotu isi iyi ahụ na-asọpụta?
\v 12 Ụmụnna m, osisi fiig ọ pụrụ ịmị oliv, ka osisi grepu ọ pụrụ ịmịpụta fiig? Nʼụzọ dị otu a, anyị makwaara na mmiri nnu apụghịkwa ịsọpụta mmiri dị mma ọṅụṅụ.
\s1 Ụdị amamihe abụọ dị
\p 
\v 13 Ọ dị onye ọbụla nʼime unu na-agụ onwe ya dị ka onye maara ihe na onye nwere nghọta? Ya gosi amamihe ya na nghọta ya site nʼibi ezi ndụ na ịrụ ọrụ ọma site nʼobi dị umeala.
\v 14 Ma ọ bụrụ na obi unu ejupụta nʼihe ilu na ekworo na ịchọ naanị ihe nke onwe unu, mgbe ahụ, unu ekwesighị ịnya isi sị otu a na-agọnarị eziokwu.
\v 15 Ụdị amamihe dị otu ahụ esiteghị nʼeluigwe bịa. Ọ bụ amamihe nke ụwa. Ọ bụghị nke mmụọ nsọ. Ọ bụ nke mmụọ ọjọọ.
\v 16 Nʼihi nʼebe ọbụla obi ilu na ekworo dị, ebe ahụ ka ọgbaaghara na omume ọjọọ niile dị.
\p 
\v 17 Ma amamihe na-esite nʼeluigwe abịa bụrụ ụzọ dị ọcha, emesịa, ọ hụrụ udo nʼanya, ọ na-eme obiọma, o jupụtara nʼebere, na-ewepụtakwa ọrụ ọma. Ihu abụọ na obi abụọ adịghịkwa nʼime ya.
\v 18 Ma ndị ahụ bụ ndị na-eme udo bụ ndị na-agha mkpụrụ udo. Ha ga-aghọta mkpụrụ ezi omume.
\c 4
\s1 Nyenụ onwe unu nʼaka Chineke
\p 
\v 1 Gịnị bụ ihe na-ebute ọgụ na esemokwu nʼetiti unu. Ebee ka ha siri bịa? Ọ bụghị ọchịchọ ọjọọ unu nwere nʼime onwe unu?
\v 2 Ọ bụrụ na unu chọọ ma unu achọtaghị ya, unu egbuo mmadụ. Unu na-enwe anya ukwu nʼihe onye ọzọ nwere ma ọ bụrụ na unu enwetaghị ya, unu amalite ịlụ ọgụ na ibu agha. Unu enweghị maka unu chọrọ arịọghị ya nʼekpere.
\v 3 Unu na-arịọ ma unu adịghị anata, nʼihi na unu na-arịọ nʼebumnobi ọjọọ. Unu na-arịọ ka unu mefuo ya nʼihe ụtọ nke ụwa.
\p 
\v 4 Ndị na-ekwesighị ntụkwasị obi! Ọ bụ na unu amaghị na unu na ụwa bụrụ enyi, unu ga-esi otu a bụrụ ndị iro Chineke? Onye ọbụla nke chọrọ ịbụ enyi nke ụwa, na-eme onwe ya onye iro nke Chineke.
\v 5 Unu chere na ihe e dere nʼakwụkwọ nsọ na-ekwu nʼefu mgbe ọ na-asị, “Chineke na-ekwosi ekworo ike nʼihi Mmụọ Nsọ ya nke o mere ka o biri nʼime anyị.”
\v 6 Ma ọ na-enye anyị amara karịa. Ya mere, Akwụkwọ nsọ ji sị,
\q1 “Chineke na-eguzo imegide ndị na-ebuli onwe ha elu,
\q2 ma ọ na-enye ndị dị umeala nʼobi amara.”\f + \fr 4:6 \ft \xt Ilu 3:34\xt*\f*
\p 
\v 7 Ya mere, nyenụ Chineke onwe unu. Guzonụ megide ekwensu, ọ ga-esi nʼebe unu nọ gbapụ.
\v 8 Bịakwutenụ Chineke nso, ya onwe ya ga-abịakwutekwa unu nso. Kwọọnụ aka unu, unu ndị mmehie, meekwanụ ka obi unu dị ọcha, unu ndị obi abụọ.
\v 9 Ruonụ ụjụ, tienụ aka nʼobi nʼọnọdụ mwute, kwaakwanụ akwa. Ka ọchị unu ghọọ ihu mgbarụ, ka iru ụjụ werekwa ọnọdụ ịṅụrị ọṅụ.
\v 10 Wedanụ onwe unu ala nʼihu Onyenwe anyị ọ ga-ebulikwa unu elu.
\p 
\v 11 Ụmụnna m, unu ekwula okwu ọjọọ megide ibe unu. Nʼihi na onye na-ekwu okwu ọjọọ megide nwanna ya, maọbụ onye na-ekpe nwanna ya ikpe, na-ekwu okwu megide iwu. Ọ na-ekpekwa iwu ahụ ikpe. Mgbe unu na-ekpe iwu ahụ ikpe, unu adịghị edebe ya kama unu bụ ndị na-ekpe ya ikpe.
\v 12 Ọ bụ naanị otu onye o nye iwu. Ọ bụkwa naanị otu onye ikpe dị. Ọ bụ naanị ya nwere ike ịzọpụta mmadụ. O nwekwara ike ịla onye ọbụla nʼiyi. Ma gị, onye ka ị na-eche na ị bụ iji na-ekpe nwanna gị ikpe?
\s1 Ịnya isi banyere ihe echi ga-abụ
\p 
\v 13 Ugbu a geenụ ntị unu bụ ndị na-asị, “Taa maọbụ echi, anyị ga-aga ebe dị otu a, maọbụ obodo dị otu a, ịzụ ahịa na ire ahịa, anyị ga-anọkwa ebe ahụ otu afọ kpaa ego.”
\v 14 Olee otu unu si mara ihe ga-eme echi? Gịnị ka unu na-eche na ndụ unu bụ? Mmadụ dị ka anwụrụ ọkụ nke a na-ahụ anya nwa oge nta, nke ikuku na-emesịa bufuo.
\v 15 Kama ihe unu ga-ekwu bụ nke a, “Ọ bụrụ na Onyenwe anyị ekwe, anyị ga-adị ndụ, mee nke a maọbụ nke ọzọ.”
\v 16 Ma ihe unu na-eme bụ ịnya isi na ịkpa nganga. Ụdị ịnya isi a bụ ihe ọjọọ.
\v 17 Ya mere, mmadụ ọbụla maara ihe bụ ezi ihe ma jụ ime ya na-emehie.
\c 5
\s1 Ịdọ aka na ntị nye ndị ọgaranya
\p 
\v 1 Ugbu a geenụ ntị unu ndị ọgaranya, oge eruola mgbe unu kwesiri ịkwa akwa na ịsụ ude nʼihi nsogbu na-akwado ịbịakwasị unu.
\v 2 Akụnụba unu ebidola ịta nchara, mkpu eripịakwala uwe unu.
\v 3 Ọlaọcha na ọlaedo unu agbaala nchara. Nchara\f + \fr 5:3 \ft Maọbụ, \fqa ajarị\f* a ga-abụkwa ama megide unu, ọ ga-erepịa anụ ahụ unu dịka ọkụ. Unu akpakọtala akụ nʼụbọchị ikpeazụ ndị a.
\v 4 Geenụ ntị! Ụzụ akwa ndị ọrụ unu, ndị unu jụrụ ịkwụ ụgwọ ọrụ ha dị ka o kwesiri na-agbago imegide unu. Ụzụ akwa ndị ọrụ unu, ndị unu ghọgburu, eruola ntị Onyenwe anyị, Onye pụrụ ime ihe niile.
\v 5 Unu ebiela ndụ nke oke oriri na oke ọṅụṅụ nʼelu ụwa, na ndụ inye anụ ahụ unu ihe ọbụla na-akpa ya mkpa. Ma ugbu a, anụ ahụ unu ahụ gbara abụba ejikerela na-eche ụbọchị mgburi ya.
\v 6 Unu amala ndị aka ha dị ọcha ikpe, gbukwaa ha, ọ bụladị mgbe ha na-egbochighị unu.
\s1 Ndidi nʼime ahụhụ
\p 
\v 7 Nweenụ ntachiobi, ụmụnna m, cherenụ ọbịbịa Onyenwe anyị. Lee otu onye ọrụ ubi si eji ndidi na-eche mkpụrụ ọ kụrụ nʼala ubi ka ọ mịa. O ji ndidi na-eche ka mmiri ozuzo nke mbụ na nke ikpeazụ zokwasị ubi ya.
\v 8 Unu onwe unu kwesikwara inwe ndidi guzosiekwa ike nʼihi na ọbịbịa Onyenwe anyị dị nso.
\v 9 Ụmụnna m, unu atamula ntamu megide ibe unu, ka a hapụ ikpe unu ikpe! Lee, onye ikpe ahụ guzo nʼọnụ ụzọ.
\p 
\v 10 Ụmụnna m, dị ka ihe ilere anya banyere inwe ndidi na ahụhụ, mụtanụ ihe site nʼaka ndị amụma bụ ndị kwuru okwu nʼaha Onyenwe anyị.
\v 11 Anyị na-agụ ha ugbu a dịka ndị a gọziri agọzi nʼihi iguzosike ha. Unu anụla maka ogologo ntachiobi nke Job nwere, unu ahụkwala nzube Onyenwe anyị nʼihi na Onyenwe anyị jupụtara nʼebere na ọmịiko.
\p 
\v 12 Karịsịa ụmụnna m, unu aṅụla iyi. Unu aṅụkwala iyi mgbe ọbụla, ọ bụladị iji eluigwe maọbụ ụwa, maọbụ ihe ọbụla ọzọ ṅụọ iyi. Kama ka “E” unu bụrụ “E.” Ka “E e,” unu bụrụkwa “E e.” Ka unu hapụ isite nʼụzọ dị otu a mehie ma wetakwara onwe unu ikpe ọmụma.
\s1 Ekpere nke sitere nʼokwukwe
\p 
\v 13 Ọ dị onye ọbụla nʼetiti unu nọ na nsogbu? Ka onye dị otu ahụ kpee ekpere. Ọ dị onye na-aṅụrị ọṅụ? Ya bụọ abụ otuto.
\v 14 Ọ dị onye nọ nʼetiti unu ahụ na-esighị ike? Ya kpọọ ndị okenye chọọchị ka ha kpeere ya ekpere, ka ha wụkwasịkwa ya mmanụ otite nʼisi kpọkuokwa aha Onyenwe anyị.
\v 15 Ekpere nke okwukwe ga-azọpụta onye ọrịa ahụ. Onyenwe anyị ga-ekulite ya, ọ bụrụkwa na o mehiere, a ga-agbaghara ya.
\v 16 Ya mere kwupụtaranụ ibe unu mmehie unu. Kpeekwaranụ ibe unu ekpere ka e nwe ike gwọọ unu. Ekpere onye ezi omume dị ike dịkwa ire.
\p 
\v 17 Ịlaịja bụ mmadụ dị ka anyị, ma o kpere ekpere rịọ ka mmiri hapụ izo, mmiri ezokwaghị nʼala ahụ ruo afọ atọ na ọnwa isii.
\v 18 Emesịa, o kpekwara ekpere ọzọ, eluigwe nyere mmiri ozuzo, meekwa ka ala pupụta ihe oriri.
\p 
\v 19 Ụmụnna m, ọ bụrụ na onye ọbụla nʼetiti unu esite nʼeziokwu ahụ jehie, ma otu onye nʼime unu akpọghachi ya azụ,
\v 20 chetanụ nke a na onye ọbụla kpọghachitere onye mmehie azụ site na njehie ya, ga-azọpụta ha nʼaka ọnwụ ma kpuchiekwa ọtụtụ mmehie.
