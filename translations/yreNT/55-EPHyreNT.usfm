\id EPH - Yaouré NT [yre] -Côte d'Ivoire 1999 (web version -2013 bd) 
\h Efɛz 
\toc1 'Fluba nɛn Pɔl -a crɛn -tɛ Efɛz 'nɔn lɛ 
\toc2 Efɛz 
\toc3 Efez 
\mt2 'Fluba nɛn Pɔl -a crɛn -tɛ 
\mt1 Efɛz 
\mt2 'nɔn lɛ 
\c 1  
\p  
\v 1 'An 'bɔ Pɔl bɛ, Bali 'bɔ 'ci 'sɔ 'a nɛn an drɛ Zozi Crizi -le 'pasiazan -a. Mɛɛn 'fluba 'gʋɛ -a crɛn -tɛ. Maan crɛn -tɛ Bali -le minnun nɛn Efɛz 'fla bɛ -wlɛ. Zozi Crizi 'lee 'ka 'bɔ bɛ, ka drɛ min -tʋwli "a, ɛn 'ka 'pɛ -sru 'ka 'e tɔadɩ -yee 'wɩ 'ji dɩ. 
\p  
\v 2 -Kaa "tɩ Bali 'lee Minsan Zozi Crizi 'o 'wee "yi 'lee 'wee -fʋdɩ -trɔɔ -nɔn 'cɛɛ. 
\s1 Pɔl Bali 'tɔ 'bɔ "yi "nɛn yaa drɛ -cɛɛ bɛ -a man 
\p  
\v 3 -Kaa Bali 'tɔ 'bɔ! -Yɛɛ cɩ -kaa san Zozi Crizi "tɩ "a, ɛn -yɛɛ fɛa 'vɩ -kaa man. E ciɩla Zozi Crizi -va ɛn "yi 'tɔ 'tʋdʋ pɛɛnɔn nɛn -yee lei 'saun 'lɔ bɛ 'e drɛ -cee vɛ -a laji lou. 
\p  
\v 4 Te Bali 'ka tian 'trɛ drɛlɛ dɩɛ, ɛn e -kaa 'si "va, ka drɛ Zozi 'le vɛ -a -le "wɛan. Bali -kaa 'si "va 'nan -e -kaa drɛ 'yee vɛ -a, -e 'tɔ 'tʋ 'e vɩlɛ 'e 'kɔn 'e 'padɩ -kaa man -a 'lɛ dɩ. 
\p Bali -kaa ye "yi "le "wɛan,  
\v 5 yaa 'vɩ 'e 'cɛn 'nan 'e -kaa dra 'yee 'nɛnnun -a. E ciɩla Zozi Crizi -va 'nan -e 'e -kaa drɛ 'yee 'nɛnnun -a. Yaa drɛ "le zɩ e cɩ -a 'bɔ 'ci 'sɔ 'a bɛ -yee 'wɩ 'zʋ.  
\v 6 Yaa drɛ 'nan -e -kaa 'e 'tɔ -dan vɩ 'yee "yi "man. "Yi zɩɛ yaa drɛ -cɛɛ -a -pɩ nɛn e 'sɔ -yrɛ tɩglɩ bɛ -yee "wɛan. 
\p  
\v 7 Zozi Crizi nyɛn nɛn e -sran bɛ, -yɛɛ -maan ɛn Bali -kaa 'si 'wɩ 'ji, ɛn e -cee 'wɩ 'wlidɩnun fui. Bali -le "yi "bɛ, -a -kɔɔn "manvɛ "ka "dɩ, -yee "wɛan nɛn yaa drɛ zɩ.  
\v 8 'Wɩ 'kpa, Bali 'yee "yi "nɔn -cɛɛ 'e 'ciɩladɩ "da. E 'wɩ 'tɔdɩ -nɔn -cɛɛ 'nan, -e -kaa 'yee 'wɩ 'ci man.  
\v 9 Ɛn "nyian bɛ, -a 'ci 'sɔ wɩ nɛn 'e yɔɔdɩ blamin man bɛ, yaa ta 'bɔla -cɛɛ. -A -cin a Bali ji 'e 'cɛn 'nan, 'e -ciala Crizi -va -e 'yee 'ci 'sɔ wɩ zɩɛ -a drɛ.  
\v 10 Tʋ 'le 'srandɩ -a nɛn e "cɛan 'wɩ zɩɛ -a drɛdɩ man. Ɛn 'wɩ 'bɔ zɩɛ -nyrɛn 'nan, fɛ pɛɛnɔn nɛn laji bɛ, 'lee fɛ pɛɛnɔn nɛn 'trɛda bɛ, Bali 'e o tre 'e cin man, -e o tazan 'e drɛ -tʋwli. -A 'bɔ nɛn Crizi -a. 
\p  
\v 11 'Wɩ 'kpa, Zozi Crizi 'bɛ -maan, ɛn 'wɩ nɛn Bali -a 'vɩ 'e 'cɛn 'nan e dra 'kʋ Zuif 'nɔn lɛ bɛ, yaa drɛ 'kʋe vɛ -a. 'Wɩ zɩɛ Bali -a drɛ "le zɩ e cɩ -a 'bɔ 'ci 'sɔ 'a bɛ -yee 'wɩ 'zʋ.  
\v 12 Yaa drɛ zɩɛ 'nan, -e kʋʋ nɛn 'kʋ 'bli cɩ 'e tɛdɛ Crizi da bɛ, 'kʋe "wɛan Bali 'tɔ 'e drɛ -dan.  
\v 13 Bali ciɩla Zozi Crizi -va, ɛn e 'wɩ zɩɛ -a drɛ kaa nɛn ka 'ka Zuif 'nɔn 'a dɩɛ, 'cee vɛ -a "nyian. Kɔɔ ka Bali -le 'wɩ tɩglɩ 'man, ɛn ka yi -tɛra "da. 'Wɩ 'nɔnnɔn zɩɛ -nyrɛn 'nan Zozi 'ka 'nan -e Bali 'e 'ka 'si 'wɩ 'ji. Ka yi -tɛra Zozi da -yee "wɛan nɛn, Bali lei 'saun nɛn Bali -a 'vɩ 'e 'cɛn 'nan 'e -nɔan "minnun lɛ bɛ, e drɛ 'cee vɛ -a. 'Ka -kɔnnɛn pladɩ nɛn 'nan, ka drɛ Bali -le vɛ -a.  
\v 14 'Wɩ 'kpa, -te Bali 'yee lei 'saun 'nɔn -cɛɛ bɛ, -yɛɛ cɩ "le fɛnun nɛn Bali -taa -a -nɔnlɛ -cɛɛ bɛ, -a va fɛ tɛdɛ -le 'wɩ 'zʋ. Ɛn -yɛɛ -ci -kɔɔnman -cɛɛ 'nan, tʋ -fɔla "da "ji bɛ, Bali -kaa "sia 'wɩ 'ji "fo te fɛnun pɛɛnɔn zɩɛ o drɛ -cee vɛ -a. -Kaa Bali 'tɔ drɛ -dan 'wɩ nɛn yaa drɛ zɩɛ -a man! 
\s1 Pɔl Bali trʋ 'ba 
\p  
\v 15-16 'Wɩ zɩɛ -yee "wɛan bɛ, 'an 'bɔ "nyian, ma'an 'flian Bali muo "fɔdɩ -a 'cee "wɛan dɩ, ɛn an Bali trʋ "baa tʋ pɛɛnɔn man 'cee 'wɩ man. Kɔɔ an 'cee yi -tɛradɩ Minsan Zozi da 'wɩ 'man, ɛn maan 'man "nyian 'nan, ka Zozinɔn pɛɛnɔn ye "yi.  
\v 17 Bali nɛn -yɛɛ cɩ -kaa san Zozi Crizi -le Bali -a, ɛn -yɛɛ cɩ -kaa "tɩ "nɛn -a -kɔɔn "manvɛ "ka "dɩɛ -a bɛ, maan trʋ 'ba 'nan 'e 'wɩ 'tɔdɩ nɛn e "sia 'yee lei 'saun 'va bɛ, -a -nɔn 'cɛɛ, ɛn 'e 'fli -kɔɔn 'cɛɛ, -e 'ka -tɔ 'kpa kɔlɛgɔlɛ.  
\v 18 Ɛn maan trʋ 'ba "nyian 'nan, 'e 'ka yiɛ 'lɛ 'sʋ, -e 'ka 'wɩ nɛn 'ka 'bli a -yrɛ ɛn -yee "wɛan Bali 'ka laabʋ bɛ, -a -tɔ. Ɛn "nyian fɛnun "kaga "nɛn Bali -a 'vɩ 'nan, 'e -nɔan 'yee minnun lɛ te -a -kɔɔn "manvɛ "ka "dɩɛ, -e 'ka -tɔ.  
\v 19 Ɛn "nyian Bali -le 'plɛblɛ nɛn e ya fɛ pɛɛnɔn 'ta lou "bɛ, -e 'ka -yee -dan ci yɩ. -Yee 'plɛblɛ zɩɛ, -a 'bɔ 'a nɛn e 'nyranman "paa -kaa nɛn -kaa yi -tɛra Zozi da bɛ -kaa man.  
\v 20 -Yee 'plɛblɛ -tʋwli zɩɛ, -a 'bɔ 'a nɛn e Crizi wluan -kanɔn 'va, ɛn yaa -nyran 'e 'pɛ "yi "da laji lou.  
\v 21 Yaa drɛ zɩɛ 'nan -e Crizi 'e 'kɔn lei -wlidɩnun pɛɛnɔn 'lee fɛ pɛɛnɔn nɛn 'plɛblɛ a -yrɔ "bɛ, 'lee fɛ pɛɛnɔn nɛn e min "paala bɛ o da. 'Trɛda fɛ pɛɛnɔn bɛ, -yɛɛ cɩ o da. Tʋ nɛn -kaa cɩ -ji 'gʋɛ, -a -ji 'saza "cɛɛ e cɩ o da dɩ, 'pian tʋ nɛn e -taa 'li bɛ -a -ji oo, te -yɛɛ cɩ o da.  
\v 22 'Wɩ 'kpa, Bali fɛ pɛɛnɔn 'pla Crizi cɛin wlu. Crizi 'bɔ nɛn fɛ pɛɛnɔn 'tazan -a bɛ, Bali -a -tɔ -leglizi -wulo -a.  
\v 23 -Leglizi 'nɔn 'bɔ 'bɛ cɩ Crizi po -a. Ɛn Crizi nɛn e fɛ pɛɛnɔn 'nan 'si bɛ, e -leglizi -ji 'fa 'yee "yi "a. 
\c 2  
\s1 Crizi -le "wɛan 'belidɩ a -kaa 'lɔ 
\p  
\v 1 'E tɛdɛ bɛ, ka'a 'ta 'wʋla Bali wei da dɩ, ɛn ka 'wɩ 'wlidɩ "dra, -yee "wɛan Bali "le 'va bɛ, te ka ya 'ka 'kadɩ.  
\v 2 Ka 'wɩ 'wlidɩnun drɛ 'e tɛdɛ "le 'trɛda minnun pɛɛnɔn 'zʋ. Ka 'ta 'wʋla Satan nɛn e -yʋ -wlidɩnun "paala bɛ, -a wei da. Satan zɩɛ, -a lei 'bɛ 'nyranman "paa minnun nɛn wa'a 'ta 'wʋla Bali wei da dɩɛ waa.  
\v 3 Ɛn -kaa 'bɔ "nyian, -kaa ya 'e tɛdɛ "le minnun zɩɛ -wee 'wɩ 'zʋ. -Kaa 'fli -nɔn -kaa 'bɔ 'ci 'sɔ wɩnun -wlidɩ "lɛ. 'Wɩ nɛn e cɩ -kaa 'bɔ 'ci 'sɔ 'a bɛ, 'lee 'wɩ nɛn e -tɔala -kaa 'bɔ 'wulo -ji bɛ, -a -sru "nɛn -kaa 'ta 'wʋla. Tʋ zɩɛ -a man bɛ, te -kaa ya Bali -le nyran -blɩdɩ wlu "le minnun pɛɛnɔn 'le 'wɩ 'zʋ. 
\p  
\v 4 'Pian Bali a 'e fadɩ min nyrinda -a, ɛn e -kaa ye "yi "bʋʋ.  
\v 5 -Yee "wɛan -kaa 'bɔ nɛn -cee 'wɩ 'wlidɩ "le "wɛan -kaa ya -kaa kadɩ -a 'lɛ bɛ, e 'belidɩ -nɔn -cɛɛ -kaa 'vale Crizi -a. -A -cin 'e 'kɔn -kaa 'ji 'nan, Bali -le "yi 'saza 'bɛ -kaa 'si 'wɩ 'ji.  
\v 6 Ɛn "nyian -kaa 'vale Crizi -a, Bali -kaa wluan -kanɔn 'va, ɛn e -kaa nyran 'e 'va laji lou.  
\v 7 E 'yee 'kpa kɔɔn -cɛɛ Zozi Crizi -ji 'nan, -e 'e 'yee "yi "nɛn -a -kɔɔn "manvɛ "ka "dɩɛ, -a -ci -kɔɔn tʋ 'le 'srannan. 
\p  
\v 8 'Wɩ 'kpa, Bali -le "yi 'saza 'bɛ -maan 'ka 'si 'wɩ 'ji. Ɛn 'ka 'sidɩ 'wɩ 'ji zɩɛ 'cee yi -tɛradɩ Bali da man nɛn e drɛ 'cee vɛ -a. Ya'a 'silɛ 'ka 'bɔ 'va dɩ, 'pian Bali 'bɛ "yi drɛ 'cɛɛ 'e "tun.  
\v 9 Bali 'ka 'ka 'silɛ 'wɩ 'ji 'wɩ 'tʋ nɛn kaa drɛ bɛ -a man dɩ. Yaa drɛ zɩɛ 'nan, -e min -tʋ 'e vɩlɛ 'e 'fli -kɔɔn -a 'wɩ 'a dɩ.  
\v 10 Bali 'bɔ 'bɛ -kaa drɛ. Ɛn e -kaa drɛ min -trɛ -a Zozi Crizi -ji 'nan, -e drɛ wɩ "yinun nɛn Bali -a man drɛ 'e 'cɛn bɛ, -kaa 'ta wʋla "da. 
\s1 Crizi -le "wɛan bɛ -kaa sɛn 'e cin va 
\p  
\v 11 Kaa nɛn ka 'ka Zuif 'nɔn 'a dɩɛ, Zuif 'nɔn -a ve 'ka man 'nan, ka 'ka 'ka 'fɔdɩ -klɔnmɔn -va dɩ. Ɛn waa ve 'o 'fli man 'nan, o ya 'o 'fɔdɩ -klɔnmɔn -va. E ya 'wɩ "tun "a, kɔɔ plɔ nɛn min -a 'pla o man 'e 'pɛ -a. Zɩ ka cɩ 'e tɛdɛ bɛ, -a da nɛn 'ka 'ci "nrɔn!  
\v 12 -A -cin 'e 'kɔn 'ka 'ji 'nan, tʋ zɩɛ -a man bɛ, te 'ka 'sizan 'wɩ 'ji "ka "dɩ. Ɛn "nyian te Bali -le minnun bɛ, ka 'ka o vanɔn 'a "fo "dɩ. Ɛn "nyian te 'wɩ nɛn Bali "e 'nan, 'e dra 'yee minnun lɛ bɛ, e 'ka 'cee vɛ -a "fo "dɩ. Ɛn "nyian te ka ya 'trɛda 'e "tun, ka'a Bali tɔa dɩ, ɛn 'ka 'bli 'ka fɛ -tʋ lɛ dɩ.  
\v 13 Tʋ zɩɛ -a man bɛ, te ka ya 'ka 'sidɩ Bali man -kɔɔbli. 'Pian 'bɛ nɛn 'gʋɛ, 'ka 'vale Zozi Crizi -a ka drɛ min -tʋwli "a, ɛn Crizi nyɛn nɛn e -sran bɛ, -yɛɛ 'ka pli Bali man. 
\p  
\v 14 Crizi 'bɔ 'bɛ -fʋdɩ -trɔɔ -nɔn -cɛɛ. Zuif 'nɔn 'lee minnun nɛn o 'ka Zuif 'nɔn 'a dɩɛ, e o drɛ 'lɛglɔn 'tʋwli "a. Nɔan nɛn "nɛn 'e pladɩ 'lɛglɔn "fli zɩɛ o yei te e o "cɛan 'e cin man, ɛn te e 'wɩ -fɔala o yei "bɛ, yaa fui 'yee -kadɩ -a yiba "plan da.  
\v 15 Kɔɔ Moizi -le -pei -tɔ wɩnun 'lee 'e 'ta 'srɔɛnnun bɛ, -a 'bɔ nɛn yaa klu -sran. E 'lɛglɔn "fli zɩɛ o 'si, ɛn e o -sɛn 'e cin va 'e 'va 'nan, -e 'o 'kɔn min -trɛ -a.  
\v 16 Ɛn "nyian -yee -kadɩ yiba "plan da 'bɔ 'a nɛn, e 'wɩ nɛn "nɛn 'lɛglɔn "fli zɩɛ o yei "bɛ, -a klu -sran. E o -tɛ 'e cin da 'kɔlɛ 'tʋwli "ji, ɛn e o yei "sɛn 'e cin va 'o 'vale Bali -a. 
\p  
\v 17 Ɛn "nyian bɛ, Crizi 'bɛ 'ta 'sinan 'nɔnnɔn zɩɛ -a 'palɛ minnun pɛɛnɔn lɛ. E 'nan, Bali 'lee o 'bɔ bɛ, 'wɩ 'ka "nyian o yei "dɩ. 'Sinan zɩɛ, kaa nɛn ka 'ka Zuif 'nɔn 'a dɩɛ, e ya 'cee vɛ -a. Ɛn "nyian 'kʋ 'bɔ nɛn kʋ cɩ Zuif 'nɔn 'a bɛ, e ya 'kʋe vɛ -a.  
\v 18 -Yee "wɛan -kaa 'bɔ pɛɛnɔn bɛ, -te min a Zuif min -a oo, -te min 'ka Zuif min -a dɩ oo, Crizi le "wɛan bɛ -si a 'e 'lɛ 'sʋdɩ, -e -kaa -pli -kaa "tɩ Bali man -yee lei 'saun 'le 'plɛblɛ 'a. 
\p  
\v 19 'Wɩ nɛn Crizi -a drɛ bɛ, -yee "wɛan kaa nɛn ka 'ka Zuif 'nɔn 'a dɩɛ, ka 'ka "nyian -pɛnnɔn 'a dɩ, ɛn ka 'ka "le minnun nɛn o -blɩnan "ka "dɩɛ -wee 'wɩ 'zʋ dɩ. 'Pian Bali -le minnun bɛ, ka drɛ o vanɔn 'a, ɛn ka drɛ -yee "kɔnnɛn 'nɔn 'a.  
\v 20 'Ka 'bɔ nɛn Bali 'ka 'si, ɛn e cɩ 'yee 'kɔn 'tɔnan. 'Kɔn zɩɛ Zozi 'le 'pasianɔn 'lee Bali 'lewei vɩnɔn 'bɛ cɩ cɛin -a, ɛn Zozi Crizi 'bɔ 'bɛ cɩ 'kɔn zɩɛ -a -pʋ -fɔ -kɔlɛ 'plɛblɛ 'a.  
\v 21 -Yɛɛ -maan -e 'kɔn zɩɛ e wluan lou, te e ya 'e 'fɔdɩ 'e cin man fɛnyian, 'nan -e 'e drɛ Minsan -le 'kɔn 'saun 'a.  
\v 22 Ɛn Zozi Crizi 'bɛ -maan "nyian, ɛn ka drɛ 'kɔn zɩɛ -a -tɔvɛ -a, 'nan -e -kaa pɛɛnɔn -kaa drɛ Bali -le 'kɔn nɛn -a lei 'saun -nyɛanla 'ji bɛ -a. 
\c 3  
\s1 'Nyranman nɛn Bali -a -pɛba 'wʋ Pɔl -lɔ bɛ -nyrɛn 'gʋ 
\p  
\v 1 'Wɩ pɛɛnɔn zɩɛ -yee "wɛan bɛ, 'an 'bɔ Pɔl, an Bali muo -fɔa. 'Ka 'tɔ 'ji nɛn an ya -pʋ 'kuin, kɔɔ an Zozi Crizi -le 'wɩ 'nɔnnɔn 'vɩ minnun nɛn o 'ka Zuif 'nɔn 'a dɩɛ -wlɛ. 
\p  
\v 2 "Yi "nɛn Bali 'bɔ -a -pɛba 'wʋ 'an 'lɔ 'nan -e 'an "cee -ci -kɔɔn "bɛ, maan -tɔa 'nan, kaa -nan wɩ 'man.  
\v 3 'Wɩ yɔɔdɩ zɩɛ, Bali 'bɔ 'bɛ -nan kɔɔn 'mɛn. -A 'bɔ nɛn an "sia -a crɛn -tɛnan 'cɛɛ bɛ. 
\p  
\v 4 -Te kaa ta 'vɩ bɛ, kaa -kɔnnɛn "ye 'nan, 'wɩ nɛn Crizi -a drɛ minnun -le vɛ -a, te -a -ci a 'e yɔɔdɩ o man bɛ, e 'ka 'e yɔɔdɩ "mɛn "man dɩ.  
\v 5 'Li 'e tɛdɛ bɛ, Bali 'ka 'wɩ zɩɛ -a -nan -kɔɔnlɛ minnun lɛ dɩ. 'Pian 'bɛ nɛn 'gʋɛ, Bali lei 'saun -a -nan kɔɔn Zozi 'le 'pasianɔn nɛn Bali o 'si "va "bɛ -wlɛ. Ɛn yaa -nan kɔɔn "nyian Bali 'lewei vɩnɔn lɛ.  
\v 6 'Wɩ yɔɔdɩ zɩɛ -nyrɛn 'nan: Zozi Crizi -le "wɛan bɛ, fɛ nɛn Bali "e 'nan 'e -nɔan 'yee minnun lɛ bɛ, ɛn 'wɩ nɛn e 'nan 'e dra -wlɛ "bɛ, minnun nɛn o 'ka Zuif 'nɔn 'a dɩɛ, o 'tɔ a "va. Ɛn minnun zɩɛ, 'o 'vale Zuif 'nɔn 'a bɛ, o drɛ 'kɔlɛ -tʋwli "le vɛ -a. 'Wɩ 'bɔ zɩɛ -yɛɛ cɩ Zozi 'le 'wɩ 'nɔnnɔn nɛn waa 'man bɛ -a.  
\v 7 Ɛn -a 'bɔ nɛn Bali -a -pɛba 'wʋ 'an 'lɔ 'nan 'an vɩ minnun lɛ. Bali 'bɔ 'le 'plɛblɛ 'a nɛn e 'yee "yi zɩɛ -a -nɔn 'mɛn. 
\p  
\v 8 'An 'bɔ nɛn an 'ka fɛ -tʋ -a Bali -le minnun yei "dɩɛ, 'an lɛ nɛn Bali "yi zɩɛ -a drɛ 'nan -e 'an Zozi 'le 'wɩ 'nɔnnɔn vɩ minnun nɛn o 'ka Zuif 'nɔn 'a dɩɛ -wlɛ. 'Wɩ "yi "nɛn -a -kɔɔn "manvɛ "ka "dɩ ɛn Crizi -a drɛ minnun lɛ bɛ -a 'bɔ nɛn.  
\v 9 Bali "yi zɩɛ -a drɛ 'mɛn "nyian 'nan -e 'an 'wɩ yɔɔdɩ 'bɔ 'ci 'si minnun pɛɛnɔn lɛ 'wein. Bali nɛn e fɛ pɛɛnɔn drɛ bɛ, e 'wɩ zɩɛ -a yɔɔ minnun man -a pou sianan 'li 'e 'cɛn, ɛn e 'bɔ cɛɛgʋ yi -a.  
\v 10 Bali -a drɛ zɩɛ 'nan, -e tʋ nɛn -kaa cɩ -ji 'gʋɛ, e 'wɩ yɔɔdɩ zɩɛ -a ta bɔla. Bali -le 'wɩ 'tɔdɩ nɛn -a -kɔɔn "manvɛ "ka "dɩɛ, -leglizi 'a nɛn yaa -ci -kɔɔnman laji fɛ pɛɛnɔn nɛn 'plɛblɛ a -wlɔ "bɛ, 'lee laji fɛ pɛɛnɔn nɛn e min "paala bɛ, -wlɛ.  
\v 11 Bali -a drɛ "le zɩ -a -cin cɩ -a 'bɔ 'ji 'e 'cɛn bɛ -yee 'wɩ 'zʋ. Bali ciɩla -kaa san Zozi Crizi, -va ɛn e 'wɩ zɩɛ -a drɛ. 
\p  
\v 12 'Wɩ nɛn Crizi -a drɛ bɛ, -yee "wɛan -si a 'e 'lɛ 'sʋdɩ -cɛɛ -e -kaa -pli Bali man, te "klan 'ka -kaa 'ji dɩ. -Cee yi -tɛradɩ Zozi da 'bɛ dra.  
\v 13 'Wɩ zɩɛ -yee "wɛan maan 'vɩ 'cɛɛ 'nan, te 'ka "koe 'e 'si 'ka da 'mɛn yra yɩdɩ -le "wɛan dɩ! An ya 'an yra yɩnan 'nan -e 'ka "nɛn "blɩ -e 'tɔ -dan 'e drɛ 'cee vɛ -a. 
\s1 Pɔl Bali trʋ 'ba 
\p  
\v 14 'Wɩ pɛɛnɔn zɩɛ -yee "wɛan 'an "po -sɔɔnman -kaa "tɩ Bali wlu.  
\v 15 -Yɛɛ cɩ 'lɛglɔn 'tʋdʋ pɛɛnɔn nɛn 'trɛda 'lee laji lou "bɛ -a san -a.  
\v 16 Fɛnun nɛn Bali lɔ bɛ, -a -kɔɔn "manvɛ "ka "dɩ. -Yee "wɛan an Bali trʋ "baa 'nan, -yee lei 'saun 'e 'nyranman 'pa 'ka man, -e 'ka "koe 'lee 'cee 'plɛblɛ 'e 'pa "da Crizi -sru 'ta wʋdɩ -ji.  
\v 17 Maan trʋ "baa "nyian 'nan, 'cee yi -tɛradɩ Crizi 'bɔ da -a nɛn 'ka 'kɔn tʋ pɛɛnɔn man Crizi -lɔ. Ɛn maan trʋ "baa "nyian 'nan, yɩdɩ "yi 'saza nɛn 'e 'kɔn 'cee 'wɩ pɛɛnɔn drɛdɩ pou sianan.  
\v 18 An 'wɩ pɛɛnɔn zɩɛ -a laabo Bali lɔ 'nan, -e 'ka 'vale Bali -le minnun pɛɛnɔn 'a bɛ, yɩdɩ "yi "nɛn Crizi 'ka ye "yɩ "a bɛ, 'ka 'kɔla -yee -dan ci mandɩ -a.  
\v 19 -Yee yɩdɩ "yi "nɛn e "mlian blamin -le 'wɩ 'tɔdɩ da bɛ, maan laabo Bali lɔ 'nan, 'ka -kɔnnɛn "yɩ 'ka 'bɔ 'a. Ɛn Bali 'e drɛ -e 'ka 'kɔn 'ka fadɩ Bali 'bɔ 'le -dan a. 
\p  
\v 20 Bali nɛn -yee 'plɛblɛ 'bɛ 'nyranman "paa -kaa man bɛ, -kɔladɩ a -yrɔ, -e 'e 'wɩ drɛ 'e 'ciɩladɩ "da. Fɛ -tʋ "ka -e -kaa laabʋ -yrɔ, ɛn 'wɩ 'tʋ "ka -e -kaa ci "nrɔn "da, te -a -pɛ 'ka 'sɔa -a drɛdɩ -a dɩ.  
\v 21 -Kaa Bali 'tɔ drɛ -dan! 'Wɩ nɛn Zozi Crizi -a drɛ bɛ -a man, Bali 'tɔ 'e 'kɔn -dan -leglizi -ji! 'E 'kɔn zɩɛ 'li 'trilii! Amɛn! 
\c 4  
\s1 -Leglizi 'nɔn a "le min -tʋwli "le 'wɩ 'zʋ 
\p  
\v 1 'An 'bɔ nɛn, an ya -pʋ 'kuin Minsan -le nyranman 'padɩ man 'gʋɛ, 'wɩ pɛɛnɔn nɛn Bali -a drɛ -cee vɛ -a bɛ, -yee "wɛan an toba -fɔa 'cɛɛ 'nan, 'cee 'ta wʋ -pɛ 'e 'kɔn "le min nɛn Bali -a laabʋ bɛ -yee vɛ zʋ.  
\v 2 Te 'ka 'fli 'sia -dandan 'ka cin man dɩ! 'Ka 'kɔn min -trɔɔ -a! Ɛn 'ka 'man -sran 'wɩ 'ji 'ka cin va! Ɛn 'ka 'kʋla 'ka cin va yɩdɩ "yi "a!  
\v 3 Bali lei 'saun 'ka drɛ "le min -tʋwli "le 'wɩ 'zʋ. 'Ka man -wɛɛ -e 'ka 'fʋ "da zɩ, te -fʋdɩ -trɔɔ a 'ka yei. 
\p  
\v 4 Bali -kaa laabʋ 'nan, -e -kaa drɛ -yee minnun -a. -Yee "wɛan -kaa drɛ 'kɔlɛ -tʋwli "a, ɛn Bali lei nɛn -kaa 'lɔ bɛ, e ya -tʋwli, ɛn 'wɩ nɛn -kaa 'bli a -yrɛ "bɛ, e ya -tʋwli.  
\v 5 -Kaa san a -tʋwli. -Cee yi -tɛradɩ Crizi da bɛ, e ya -tʋwli. Ɛn o -kaa -batize drɛ 'wɩ 'tʋwli "man.  
\v 6 Bali a -tʋwli. -Yɛɛ cɩ -kaa pɛɛnɔn "tɩ "a. E -kaa pɛɛnɔn "paala. E -ciala -kaa pɛɛnɔn 'va ɛn 'e 'nyranman "paa. E -nyɛanla -kaa pɛɛnɔn 'ji. 
\p  
\v 7 -Kaa -tʋdʋ pɛɛnɔn bɛ, -kaa "yi -dan 'yɩ -cee vɛ -a, "le zɩ Crizi -a -nɔn bɛ -yee 'wɩ 'zʋ.  
\v 8 Kɔɔ e ya 'e 'crɛn -tɛdɩ Bali -le 'fluba 'ji 'nan: 
\q1 «"Yɛɛ -kʋ lou "bɛ, 
\q1 e fɛ pɛɛnɔn klɩ, e o kuun. 
\q1 Ɛn e "yinun -nɔn minnun lɛ.» 
\m  
\v 9 -Te waa 'vɩ 'nan, e -kʋ lou "bɛ, -a -ci nɛn 'nɔn? -A -ci nɛn 'nan, 'e tɛdɛ bɛ, e sɔɔnla fɛnan "tradra "nan.  
\v 10 Min 'bɔ nɛn e -sɔɔnla fɛnan "tradra "nan bɛ, -a min 'lein zɩɛ -yɛɛ kʋ "nyian labli 'ta lou "nun, 'dʋ -e 'e fɛ pɛɛnɔn 'nan 'si.  
\v 11 Min 'bɔ 'lein zɩɛ -yɛɛ "yinun drɛ 'yee minnun lɛ. Yaa -mie drɛ Zozi 'le 'pasianɔn 'a, ɛn yaa -mie drɛ Bali 'lewei vɩnɔn 'a, ɛn yaa -mie drɛ Zozi 'le 'wɩ 'nɔnnɔn vɩnɔn 'a, ɛn yaa -mie drɛ minnun nɛn o yiɛ -tɔa -leglizi -va, te o Bali -le 'wɩ "paaman o ji bɛ waa.  
\v 12 Yaa drɛ zɩɛ 'nan, -e 'o Bali -le minnun man wʋʋ -e 'o 'yee 'nyranman 'pa, -e -yee -leglizi nɛn -a 'bɔ po -a bɛ, 'e 'tɔ 'plɛblɛ.  
\v 13 'Wɩ zɩɛ -a drɛdɩ -a nɛn, -kaa pɛɛnɔn dra "le min -tʋwli "le 'wɩ 'zʋ -cee yi -tɛradɩ Crizi da -ji. Ɛn "nyian bɛ, -kaa dra "le min -tʋwli "le 'wɩ 'zʋ -cee Bali -pɩ 'bɔ -tɔdɩ -ji. -Te e drɛ zɩɛ bɛ, -a -nan nɛn -kaa -kɔan "le min nɛn e -klɔnmɔn -fɔ bɛ -yee 'wɩ 'zʋ, ɛn zɩ Crizi cɩ bɛ, min -taa -a yɩlɛ -kaa 'lɔ. 
\p  
\v 14 Yaa drɛ zɩɛ 'nan, -e -kaa vɩlɛ -kaa kɔn "nyian "le nannannun -le 'wɩ 'zʋ dɩ. Kɔɔ nannannun lɛ nɛn minnun see "paa wɩnun ve -pɛ "yi 'lee -pɛ bʋ -a, -e 'o -sɔɔnla o -sru. Min see "paanɔn zɩɛ o ya -wlidɩ, ɛn -dawli 'tɔ 'tʋdʋ pɛɛnɔn a o ji, -e 'o min 'si -si tɩglɩ da.  
\v 15 'Pian -cee vɛ bɛ -kaa 'wɩ tɩglɩ vɩ, ɛn -kaa cin yɩ "yi, -e -kaa trʋla Crizi man. -Yɛɛ cɩ -leglizi -wulo -a.  
\v 16 -Leglizi bɛ, Crizi 'bɔ po nɛn. Ɛn -a man mɛn -tʋdʋ bɛ, klɔda 'bɛ -maan 'o ya 'o 'fɔdɩ 'e cin man. Ɛn miɛnmiɛnnun 'bɛ -maan "nyian 'o cin "kuan 'plɛblɛ. Zɩ man mɛn -tʋ "e -kɔla "wo bɛ, -a da nɛn e 'nyranman "paa ɛn -leglizi nɛn Crizi 'bɔ po -a bɛ e -tɔa "kli, te e trʋman, te yɩdɩ "yi "a -ji. Trʋdɩ zɩɛ, Crizi -va nɛn e "sia. 
\s1 'Ka 'pɛ 'e 'si 'cee 'ta wʋ -pɛ ceje -sru! 
\p  
\v 17 Minsan nɛn an drɛ -yee vɛ -a bɛ, -a 'tɔ da nɛn an 'wɩ "paala 'cɛɛ 'nan: Te 'cee 'ta wʋ -pɛ 'e 'kɔn "nyian "le minnun nɛn wa'a Bali tɔa dɩɛ -wee vɛ -zʋ dɩ! 'O 'bɔ 'ci 'sɔ wɩnun -wlidɩ -sru "nɛn o 'ta wo, te e ya 'wɩ "tun "a.  
\v 18 O "trɔɛn "a "yuyu, ɛn o 'ka "va 'nan 'o Bali -tɔa "dɩ. -Yee "wɛan 'belidɩ nɛn Bali a -nɔn bɛ, e ya o man -kɔɔbli, ɛn o ya klun va.  
\v 19 'Wɩ 'tʋ 'ka "nyian o tɛa 'yra -a dɩ. 'O 'fli -nɔn 'wɩ 'wlidɩ "drɛdɩ lɛ, ɛn 'wɩ 'wlidɩ 'tɔ 'tʋdʋ pɛɛnɔn bɛ, wa'a 'kaan -a drɛdɩ -a dɩ. 
\p  
\v 20 'Pian 'cee vɛ bɛ, 'wɩ nɛn waa paa 'ka 'ji Crizi da bɛ, 'wɩ 'wlidɩnun zɩɛ -a -tʋwli 'ka "va "dɩ.  
\v 21 Maan -tɔa 'nan 'wɩ 'kpa, ka Crizi -le 'wɩ 'man, ɛn o -yee 'wɩ paa 'ka 'ji. 'Wɩ nɛn waa paa 'ka 'ji zɩɛ Zozi 'le 'wɩ tɩglɩ nɛn.  
\v 22 Waa paa 'ka 'ji 'nan, 'ka 'pɛ 'e 'si 'ka drɛ wɩ cejenun -sru. -Yee "wɛan 'ka drɛla "da! Kɔɔ te ka'a tian Zozi 'tɔlɛ dɩɛ, ka 'wɩ 'wlidɩnun drɛ "kaga te -a 'le 'srannan "nɛn -kadɩ -a.  
\v 23 'Bɛ nɛn 'gʋɛ, e ya "le Bali lei 'saun 'e 'cee ci "nrɔndɩ pɛɛnɔn lila 'e 'trɛ "fo.  
\v 24 Ɛn "nyian bɛ, 'cee 'ta wʋ -pɛ 'e 'kɔn "le min -trɛ -le 'wɩ 'zʋ. Min zɩɛ Bali 'bɛ dra -e 'e Bali 'sia 'e "pa 'ji. -A drɛ wɩ -kɔan 'e 'sʋdɩ "ji, ɛn e -kɔan Bali -le vɛ -a "fo. Ɛn e 'ta wo Bali -le 'wɩ tɩglɩ da. 
\p  
\v 25 -Yee "wɛan 'ka 'si 'wlu 'sɛndɩ man, ɛn 'wɩ tɩglɩ nɛn 'ka vɩ 'ka cin lɛ! Kɔɔ -kaa pɛɛnɔn -kaa drɛ 'kɔlɛ -tʋwli "man mɛnnun -a.  
\v 26 Ɛn "nyian bɛ, 
\q1 «-Te 'bli 'fɔ 'ka 'ji bɛ, 
\q1 te 'ka 'wɩ 'wlidɩ "drɛ dɩ!» 
\m Te yidɛ 'e 'fɔ "va 'cee 'bli 'fɔdɩ "ji "man dɩ!  
\v 27 "Tɔgɔ -si 'e 'lɛ 'sʋ Satan lɛ, -e 'e 'ka man yɩ.  
\v 28 Ɛn "nyian bɛ, min nɛn e crin wo bɛ, 'e 'si -a drɛdɩ man! 'Pian 'e 'nyranman 'pa, -e 'e "nɛn "fɛ -blɩ, te e 'yalɛ -tɛnɔn "le -nɔan "nyian! 
\p  
\v 29 Ɛn "nyian bɛ, te wei -wlidɩ "tʋwli 'e bɔla 'ka 'le "fo "dɩ! 'Pian 'wɩ nɛn e min peenun "le 'wɩ "paa "va "bɛ -a 'bɔ nɛn 'ka vɩ! Ɛn 'wɩ nɛn e "yi dra minnun lɛ bɛ, -a 'bɔ nɛn 'ka vɩ!  
\v 30 Te 'ka Bali lei 'saun 'ta drɛ -trɔdrɔ dɩ! -A 'bɔ 'a nɛn Bali 'ka -kɔnnɛn 'pla -e 'e -kɔɔn 'nan ka -kɔan 'yee vɛ -a tʋ nɛn e 'ka "sia 'wɩ 'ji bɛ, -a man. 
\p  
\v 31 -Yee "wɛan min man wɩ 'padɩ, 'lee 'bli 'fɔdɩ min ji, 'lee nyran siadɩ, 'lee 'wɩ 'blɩdɩ, 'lee min sɛɛ wʋdɩ, 'lee 'wɩ 'wlidɩ 'tɔ 'tʋdʋ pɛɛnɔn bɛ, te -a -tʋwli 'e 'kɔn 'ka yei "fo "dɩ!  
\v 32 'Pian 'ka 'kɔn 'kpa 'ka cin lɛ, 'ka cin dra nɛn 'e 'ka 'tɛ, ɛn 'ka cin man wɩ 'cɛ "le zɩ Bali 'ka 'man wɩ 'cɛ Crizi -le "wɛan "bɛ -yee 'wɩ 'zʋ. 
\c 5  
\p  
\v 1 'Wɩ nɛn Bali -a drɛ bɛ, -a 'bɔ nɛn 'ka drɛ! Ka drɛ -yee 'nɛnnun nɛn e o ye "yi "bɛ waa.  
\v 2 -Yee "wɛan 'ka cin yɩ "yi "le zɩ Crizi -kaa 'yɩ "yi "bɛ -yee 'wɩ 'zʋ! E -kaa 'yɩ "yi "le "wɛan, e wɩɩ "man ɛn e -ka -kaa 'lɛji. E drɛ "le 'nan 'sraga nɛn yaa 'bʋ Bali lɛ ɛn -a -koei 'nɔnnɔn Bali ci 'sɔ. 
\s1 'Cee 'ta wʋ -pɛ 'e -kɔɔn 'nan ka drɛ 'tɛ 'san -le vɛ -a! 
\p  
\v 3 'Ka drɛ wɩ 'e -kɔɔn 'nan ka drɛ Bali -le minnun -a! Nyinnandɩ lɩ 'lee -kɔnnɛn -a te wa'a 'o cin 'palɛ dɩɛ, te 'e 'kɔn 'ka yei "dɩ! Ɛn 'wɩ pɛɛnɔn nɛn e min "tri -tɔa Bali 'lɛ, 'lee min yiɛ nɛn ya'a 'ciɩla fɛ da dɩɛ, te -a -tʋwli 'e 'kɔn 'ka yei "dɩ!  
\v 4 'Wɩdɩ min man -wlidɩ, 'lee -blʋ wei -fɔdɩ, 'lee -sɛɛ "wlidɩ "wʋdɩ bɛ, te -a -tʋwli 'e 'kɔn "nyian 'ka yei "dɩ! 'Pian 'wɩ nɛn e cɩ "le 'ka drɛ bɛ, -nyrɛn Bali muo "fɔdɩ -a.  
\v 5 -A -cin 'e 'kɔn 'ka 'ji 'nan, minnun nɛn o nyianla lɩ 'lee -kɔnnɛn -a te wa'a 'o cin 'palɛ dɩɛ, 'lee minnun nɛn o 'wɩ nɛn e min "tri -tɔa Bali 'lɛ bɛ waa dra bɛ, 'lee minnun nɛn 'o yiɛ 'ka 'ciɩla fɛ da dɩɛ, o -nyrannan 'ka Crizi 'lee Bali -le mingɔnnɛn 'trɛda dɩ. Kɔɔ 'wɩnun zɩɛ -a drɛdɩ bɛ, e ya "le fɛ nɛn e 'ka Bali -a dɩɛ, -a 'bɔ nɛn min -a 'su. 
\p  
\v 6 Te 'ka 'wɩ "man -e min 'e 'ka see "paa -e 'ka 'wɩ 'wlidɩ zɩɛ -a -tʋ drɛ dɩ! Kɔɔ minnun nɛn o 'ka "vale 'o 'ta wʋla Bali wei da dɩ, ɛn o 'wɩnun zɩɛ -a dra bɛ, Bali -le nyran -blɩdɩ a o man -pɛnnan.  
\v 7 -Yee "wɛan te 'ka -fɔ o -sru "fo "dɩ! 
\p  
\v 8 'E tɛdɛ bɛ, ka 'bɔ te "ka "ya wo "nyian klun va. 'Pian 'bɛ nɛn 'gʋɛ ka ya 'tɛ 'san da, ka drɛ Minsan -le vɛ -a -le "wɛan. -Yee "wɛan 'cee 'ta wʋ -pɛ 'e -kɔɔn 'nan ka drɛ 'tɛ 'san -le vɛ -a!  
\v 9 Min nɛn e ya 'tɛ 'san da bɛ, -a san 'wɩ "yi 'tɔ 'tʋdʋ pɛɛnɔn dra, ɛn -a san drɛ wɩ -kɔan 'e 'sʋdɩ "ji, ɛn -a san 'wɩ dra min va 'e 'ci -a -tʋwli.  
\v 10 -Yee "wɛan 'wɩ nɛn e cɩ Minsan ci 'sɔ 'a bɛ, 'ka man -wɛɛ -e 'ka fa 'si sidɔ!  
\v 11 'Wɩ nɛn klun va wɩnun -a ɛn ya'a 'wɩ "yi dra min lɛ dɩɛ, te 'ka drɛ dɩ! 'Pian 'ka ta bɔla!  
\v 12 Kɔɔ 'wɩnun nɛn min -mienun -a dra 'e yɔɔdɩ bɛ, -a -nan wɩ vɩdɩ min -tɛa 'yra -a.  
\v 13 'Pian -te Bali -le 'tɛ 'san -a ta 'bɔla bɛ, min -a ye 'wein.  
\v 14 Ɛn fɛ pɛɛnɔn nɛn e -ta 'tɛ 'san da bɛ, -a 'bɔ "nyian "e "drɛ wo 'tɛ 'san -a. -Yee "wɛan waa 'vɩ 'nan: 
\q1 «Yi -tɛzan 'i 'fuʋ! 
\q1 'I 'wluan -kanɔn 'va, 
\q1 -e Crizi -le 'tɛ 'san 
\q1 'e 'i 'man drɛ 'wein.» 
\p  
\v 15 'Wɩ pɛɛnɔn zɩɛ -yee "wɛan bɛ, 'ka yiɛ 'tɔ 'ka 'fli -va! Ɛn 'cee 'ta wʋ -pɛ 'e -kɔɔn 'nan, ka Bali -le 'wɩ -tɔa! Te 'ka 'wɩ drɛ "le minnun nɛn wa'a 'o 'ci "nrɔnman Bali -le 'wɩ da dɩɛ -wee 'wɩ 'zʋ dɩ!  
\v 16 Tʋ nɛn Bali -a -nɔn 'cɛɛ bɛ, 'wɩ "yinun nɛn 'ka drɛ -ji! Kɔɔ tʋ nɛn -kaa cɩ -ji 'gʋɛ 'wɩ 'wlidɩ "drɛdɩ 'fa "da.  
\v 17 -Yee "wɛan te 'ka 'wɩ drɛ "le -blʋnɔn 'zʋ dɩ, 'pian zɩ Minsan cɩ "vale 'nan 'ka 'wɩ drɛ bɛ, 'ka man -wɛɛ -e 'ka -tɔ! 
\p  
\v 18 Te 'ka 'wɛn 'mlin 'e 'ciɩla "da dɩ! Kɔɔ 'wɩ 'nɔnnɔan drɛdɩ nɛn yaa "paa min lɔ. 'Pian 'cee vɛ bɛ, Bali lei 'saun nɛn 'e 'ka 'pla "fo.  
\v 19 'Ka cin "koe "tɔ Bali -le 'fluba 'ji "drenun -fɔdɩ -a, 'lee Bali 'tɔ bɔ "drenun -fɔdɩ -a, 'lee "drenun nɛn Bali lei 'saun -a -cin -tɔa 'ka 'ji bɛ -a -fɔdɩ -a. "Drenun zɩɛ -a 'bɔ 'a nɛn 'ka Minsan 'tɔ bɔ 'ka 'bli pɛɛnɔn 'a.  
\v 20 -Kaa "tɩ Bali bɛ, 'ka muo "fɔ tʋ pɛɛnɔn man, ɛn 'ka muo "fɔ 'wɩ pɛɛnɔn 'ji, -kaa san Zozi Crizi 'tɔ 'ji. 
\ms1 Zozinɔn, 'ka 'wɩ drɛ 'ka cin va "yi! 
\s1 Lɩmɔn 'lee 'e 'sran -le 'wɩ 
\p  
\v 21 'Ka cin wei man "yi! Zɩ ka "klandɩ Crizi -lɔ -ci -kɔɔn zɩɛ! 
\p  
\v 22 'Ka lɩmɔnnun bɛ, 'ka 'ta wʋla 'ka 'sran wei da! -A -ci -kɔɔndɩ nɛn 'nan, ka 'ta wʋla Minsan wei da.  
\v 23 Kɔɔ -klɔnmɔn 'bɛ 'e nan "paala, "le zɩ Crizi -leglizi "paala bɛ -yee 'wɩ 'zʋ. -Leglizi 'bɛ cɩ "le Crizi 'bɔ po -le 'wɩ 'zʋ, ɛn minnun nɛn -ji bɛ, Crizi 'bɛ o "sia 'wɩ 'ji.  
\v 24 -Leglizi 'nɔn 'ta wʋla Crizi wei da, -a -tʋwli "nɛn lɩmɔnnun 'o drɛ "nyian o -sran lɛ 'wɩ pɛɛnɔn 'ji. 
\s1 -Klɔnmɔn 'lee 'e nan -le 'wɩ 
\p  
\v 25 'Ka -klɔnmɔnnun bɛ, 'ka nannun yɩ "yi, "le zɩ Crizi -leglizi ye "yi "bɛ -yee 'wɩ 'zʋ! Crizi wɩɩ "man ɛn e -ka -leglizi 'nɔn 'lɛji,  
\v 26 'nan -e -leglizi 'nɔn 'o drɛ Bali -le vɛ -a "fo. -A -batize drɛdɩ 'yi 'a, 'lee Bali wei vɩdɩ -a nɛn Crizi -leglizi drɛ 'saun Bali 'lɛ.  
\v 27 Yaa drɛ zɩɛ 'nan, -e -leglizi 'e drɛ 'e 'bɔ 'le vɛ -a, te e "bia fɛnyian, te "tri 'ka "man "dɩ, te -a man 'ka 'e yrudɩ dɩ, ɛn te 'wɩ 'wlidɩ 'ka "man "fo "dɩ. 'Pian -e -leglizi 'e 'kɔn 'saun Bali 'lɛ, te 'tɔ 'tʋ 'ka "man "dɩ. 
\p  
\v 28 Yɩdɩ "yi zɩɛ -a 'bɔ 'a nɛn -klɔnmɔnnun 'o nan yɩ "yi! Min nɛn 'e nan ye "yi "bɛ, te 'e 'fli ye "yi.  
\v 29 Kɔɔ min -tʋ 'ka 'naan 'e 'bɔ 'fli man dɩ, 'e 'fli ci fɛ -wɛɛman, ɛn 'e yiɛ -tɔa 'e 'fli -va. Zɩ Crizi -a dra -leglizi lɛ zɩɛ.  
\v 30 -Leglizi 'bɔ 'bɛ cɩ Crizi po -a, ɛn -cɛɛ cɩ -a man mɛnnun -a.  
\v 31 'Wɩ nɛn 'e 'crɛn -tɛdɩ Bali -le 'fluba 'ji bɛ, 'ka 'ci "nrɔn "da. E ya 'e 'crɛn -tɛdɩ 'nan: 
\q1 «-Klɔnmɔn "sia 'e "tɩ 'lee 'e "bʋ "man 
\q1 -e 'e pei 'fɔ 'e nan va, 
\q1 -e 'o drɛ min -tʋwli "a.» 
\m  
\v 32 'Wɩ -dan tʋ a 'e yɔɔdɩ 'wɩ zɩɛ -a -sru. "An -ci ve 'cɛɛ 'nan, zɩ Crizi 'lee 'yee -leglizi 'nɔn cɩ zɩɛ.  
\v 33 'Pian 'wɩ 'tʋwli zɩɛ e ya "nyian 'ka 'bɔ 'le vɛ -a. 'Ka -klɔnmɔnnun bɛ, 'ka nan yɩ "yi "le zɩ 'ka 'fli ye "yi "bɛ -yee 'wɩ 'zʋ! Ɛn 'ka lɩmɔnnun bɛ, 'ka 'sran 'sia min -a! 
\c 6  
\s1 'Nɛn 'lee 'e "tɩ "le 'wɩ 
\p  
\v 1 'Ka nannannun bɛ, [Minsan -le "wɛan bɛ,] 'ka 'ta wʋla 'ka "tɩ 'lee 'ka "bʋ "wei da! -Yɛɛ cɩ 'wɩ "yi "a.  
\v 2 Kɔɔ Bali "e 'nan: «'I yiɛ 'e 'nan 'i "tɩ 'lee 'i "bʋ "man!» -Yɛɛ cɩ -pei -tɔ wɩ tɛdɛ nɛn Bali 'wɩ 'tʋ 'pla -a -sru "bɛ -a.  
\v 3 'Wɩ zɩɛ -nyrɛn 'nan: «'I 'ci "nran ye, ɛn i "mɔan 'trɛda.» 
\p  
\v 4 'Ka 'nɛn "tɩnun bɛ, 'wɩ nɛn e 'nɛn 'ci -tɔa lou 'e "tɩ 'lee 'e "bʋ "man bɛ, te 'ka drɛ -wlɛ "dɩ! 'Pian 'ka o 'lɛbʋ 'wɩ "paadɩ -a o ji 'lee 'wɩ pladɩ -a -wlɛ. 'Ka drɛ 'wɩ nɛn e "sia Minsan va bɛ -a yra man. 
\s1 Nɔan 'lee 'e 'tazan -le 'wɩ 
\p  
\v 5 'Ka nɔannun bɛ, 'ka 'ta wʋla 'ka 'tanɔn wei da! 'Ka "klan Bali lɔ ɛn 'ka drɛ 'ka 'ci 'fɩdaa 'a! Ɛn 'ka 'ci "nrɔn 'nan, ka ya -a drɛnan Crizi lɛ!  
\v 6 Te 'ka drɛ o yiɛ lɛ 'saza 'nan -e 'o 'ka yɩ "yi "dɩ! 'Pian 'ka -kɔɔn 'nan Crizi 'sunɔn nɛn 'kaa! Ɛn 'wɩ nɛn e cɩ Bali ci 'sɔ 'a bɛ -a 'bɔ nɛn 'ka drɛ 'ka 'bli pɛɛnɔn 'a!  
\v 7 'Ka 'ta 'e 'kɔn "fava 'nyranman 'panan -wlɛ. Ɛn 'ka 'ci "nrɔn 'nan, Crizi lɛ nɛn ka cɩ 'nyranman zɩɛ -a 'panan, 'nan blamin lɛ "cɛɛ dɩ!  
\v 8 -A -cin 'e 'kɔn 'ka 'ji 'nan, -te min a nɔan -a oo, ɛn -te e 'ka nɔan -a dɩ oo, e ya 'wɩ "tun "a. 'Pian zɩ min -tʋ 'nyranman 'pa bɛ, -a da nɛn Minsan -a -ko "paa. 
\p  
\v 9 Kaa nɛn ka cɩ o tanɔn 'a bɛ, -a -tʋwli "nɛn "nyian 'cee vɛ -a. 'Ka 'cee nɔannun 'sia min -a! Te 'ka 'kɔn o man -wluwlu dɩ! -A -cin 'e 'kɔn 'ka 'ji 'nan, 'ka 'san a waa -tʋwli, e ya laji. Ya'a min bo "va 'vaa -e 'e va wɩ drɛ dɩ. 
\s1 'Ka 'man 'e 'kɔn 'e wʋʋdɩ tʋ -wlidɩ "le "wɛan! 
\p  
\v 10 Maan 'le -sɛanla 'cɛɛ 'nan, 'ka 'tɔ -kli! 'Cee drɛdɩ min -tʋwli "a 'ka 'vale Minsan -a 'bɛ dra, te -yee 'plɛblɛ nɛn e ya fɛ pɛɛnɔn 'ta lou "bɛ, e 'ka -tɔa -kli.  
\v 11 Bali -le -kuli -tan fɛnun nɛn yaa -nɔn 'cɛɛ bɛ, 'ka 'man wʋʋ -a, -e 'ka 'kɔla "tɔdɩ -a Satan -le see "paa wɩnun 'lɛ.  
\v 12 Kɔɔ -kuli nɛn -kaa 'lɛ bɛ, blamin man "cɛɛ -kaa -taan "dɩ, 'pian -kaa -taan lei -wlidɩnun pɛɛnɔn nɛn laji bɛ, o man. 'Plɛblɛ a -wlɔ, ɛn o min "paala, ɛn o 'nyranman "paa klun va.  
\v 13 -Yee "wɛan Bali -le -kuli -tan fɛnun nɛn yaa -nɔn 'cɛɛ bɛ, 'ka 'sia! -Te kaa drɛla "da "bɛ, tʋ nɛn yi -wlidɩ bɔa 'ka man bɛ, ka -kɔlaman -tɔdɩ -a -kli -e 'ka bɔla "ji 'kloun 'gloun. 
\p  
\v 14 'Ka 'man 'e 'kɔn 'e wʋʋdɩ! 'Ka 'ta wʋla 'wɩ tɩglɩ da! -Yɛɛ cɩ "le 'ka -tiɛn 'kɔlɛ 'le 'wɩ 'zʋ. 'Wɩ nɛn 'e 'sʋdɩ "ji "bɛ 'ka drɛ! -Yɛɛ cɩ "le 'ka 'kɔlɛ "nɛn yɔɔvɛ -le 'wɩ 'zʋ -kuli -lɔ.  
\v 15 -Fʋdɩ -trɔɔ nɛn Bali -a -nɔn 'cɛɛ Zozi Crizi -le 'wɩ 'nɔnnɔn 'a bɛ, 'ka 'tɔ "da 'plɛblɛ! -Yɛɛ cɩ "le 'ka 'cɛin -man -manwua "le 'wɩ 'zʋ.  
\v 16 Ɛn "nyian bɛ, 'ka yi -tɛra Zozi da "fo! -Yɛɛ cɩ "le 'ka 'man yɔɔvɛ -le 'wɩ 'zʋ Satan -le -tin 'wlɛnun nɛn 'tɛ nrɛn a "nɛn "bɛ -wlɔ.  
\v 17 Bali 'ka 'si 'wɩ 'ji, 'ka 'tɔ "da 'plɛblɛ! -Yɛɛ cɩ "le 'ka 'wulo -man yɔɔ 'kpɔngbo kle "le 'wɩ 'zʋ -kuli -lɔ. Ɛn -kuli -tan sɛn nɛn Bali lei 'saun -a -nɔn 'cɛɛ bɛ, 'ka 'kun "man! -Yɛɛ cɩ Bali wei -a. 
\p  
\v 18 'Wɩ pɛɛnɔn zɩɛ -a drɛdɩ -ji bɛ, Bali nɛn 'ka trʋ 'ba, ɛn 'ka laabʋ -yrɔ 'nan, 'e 'pa 'ka 'va. Tʋ pɛɛnɔn man 'ka Bali trʋ 'ba "le zɩ -yee lei 'saun -a -cin -tɔa 'ka 'ji bɛ -yee 'wɩ 'zʋ. 'Ka yiɛ -trɔa 'wɩ zɩɛ -a drɛdɩ da, te 'ka 'pɛ 'e plʋ dɩ! 'Ka Bali trʋ 'ba Bali -le minnun pɛɛnɔn lɛ! 
\p  
\v 19 Ɛn "nyian bɛ, 'ka Bali trʋ 'ba 'mɛn 'nan, 'wɩ nɛn 'kɔ 'an vɩ bɛ 'e -cin -tɔ 'an 'ji. Ɛn 'nan -si 'e 'lɛ 'sʋ 'mɛn, -e 'an Zozi 'le 'wɩ 'nɔnnɔn nɛn -a -ci a 'e yɔɔdɩ minnun man bɛ, -a -ci vɩ -wlɛ.  
\v 20 'Bɛ 'bɔ nɛn an ya -pʋ 'kuin 'gʋ oo, Zozi 'le 'wɩ 'nɔnnɔn 'pɛ 'ba a 'an 'lɔ -e 'an vɩ minnun lɛ. -Yee "wɛan 'ka Bali trʋ 'ba 'mɛn 'nan, -si 'e 'lɛ 'sʋ -e 'an vɩ, "le zɩ e cɩ 'mɛn 'nyranman -a bɛ -yee 'wɩ 'zʋ. 
\p  
\v 21 -Kaa "bʋɩ Zozizan Tisik nɛn -kaa ye "yi "bɛ, -a yiɛ yra Minsan -le 'nyranman 'padɩ da. -A 'bɔ 'bɛ "ta "lo 'wɩ nɛn 'an man 'gʋɛ -a 'sinan 'palɛ 'cɛɛ.  
\v 22 -Yee "wɛan maan 'pa 'sia 'ka 'va 'nan, -e 'wɩ nɛn 'kʋ man bɛ 'ka -tɔ. Ɛn an ya "va 'nan 'e 'ka "koe "tɔ 'ka da. 
\p  
\v 23 -Kaa "tɩ Bali 'lee Minsan Zozi Crizi 'o 'wee -fʋdɩ -trɔɔ, 'lee 'wee yɩdɩ "yi, 'lee yi -tɛradɩ Zozi Crizi da -nɔn 'kʋ "bʋɩ Zozinɔn pɛɛnɔn lɛ.  
\v 24 Bali -le "yi 'e 'kɔn minnun pɛɛnɔn nɛn o -kaa san Zozi Crizi ye "yi -a 'leda "ka "dɩɛ o va.