\id LAM - Yorumsuz Türkçe Çeviri (YTC) 
\h AĞITLAR 
\toc1 AĞITLAR 
\toc2 AĞITLAR 
\toc3 AĞITLAR 
\mt1 AĞITLAR  
\c 1  
\q1
\v 1 İnsanlarla dolu olan kent,  
\q2 nasıl da yapayalnız oturuyor!  
\q1 Uluslar arasında büyük olan,  
\q2 dul kadın gibi oldu!  
\q1 Ülkeler arasında bey olan  
\q2 Köle oldu!   
\q1
\v 2 Geceleyin acı acı ağlıyor.  
\q2 Gözyaşları yanaklarında.  
\q1 Bütün sevgilileri arasında  
\q2 onu teselli eden yok.  
\q1 Bütün dostları ona hainlik etti.  
\q2 Ona düşman oldular.   
\q1
\v 3 Yahuda sıkıntı çekmek,  
\q2 ve ağır kölelik etmek için sürgüne gitti.  
\q1 Uluslar arasında oturuyor.  
\q2 Rahat bulamıyor.  
\q2 Sıkıntısında bütün zulmedenleri ona yetişti.   
\q1
\v 4 Siyon yolları yas tutuyor,  
\q2 çünkü kimse kutsal toplantıya gelmiyor.  
\q1 Bütün kapıları ıssız.  
\q2 Kâhinleri inliyor.  
\q1 El değmemiş kızları sıkıntıda,  
\q2 kendisi de acı içinde.   
\q1
\v 5 Düşmanları baş oldu.  
\q2 Düşmanlarının işi yolunda;  
\q1 çünkü Yahve,\f + \fr 1:5 \ft “Yahve” Tanrı’nın asıl ismidir, diğer çevirilerde bazen “RAB” (tamamı büyük harflerle) olarak çevrilir.\f* günahlarının çokluğu yüzünden onu sıkıntıya soktu.  
\q2 Yavruları düşmanın önünde sürgüne gitti.   
\q1
\v 6 Siyon kızının bütün görkemi kendisinden ayrıldı.  
\q2 Beyleri otlak bulamayan geyiklere döndüler.  
\q2 Kovalayanın önünde güçsüz kaldılar.   
\q1
\v 7 Yeruşalem, sıkıntı ve sefalet günlerinde,  
\q2 eski günlerindeki bütün güzel şeylerini hatırlıyor;  
\q1 onun halkı düşmanın eline düştüğünde ve kimse ona yardım etmediğinde,  
\q1 düşmanlar onu gördüler.  
\q2 Onun kimsesizliğiyle alay ettiler.   
\q1
\v 8 Yeruşalem büyük günah işledi.  
\q2 Bu yüzden kirli oldu.  
\q1 Ona saygı gösterenlerin hepsi onu hor görüyor,  
\q2 çünkü çıplaklığını gördüler.  
\q2 Evet, inliyor ve arkasını dönüyor.   
\q1
\v 9 Kirliliği eteklerindeydi.  
\q2 Kendi sonunu hatırlamadı.  
\q1 Bu yüzden aşağı inmesi şaşılacak şeydi.  
\q2 Teselli edeni yok.  
\q1 “Ey Yahve, sıkıntımı gör;  
\q2 çünkü düşman kendini yüceltti.”   
\q1
\v 10 Düşman elini onun bütün güzel şeyleri üzerine uzattı;  
\q2 çünkü ulusların kendi kutsal yerine girdiğini gördü,  
\q2 onlar hakkında senin topluluğuna girmesinler diye buyurmuştun.   
\q1
\v 11 Bütün halkı inliyor.  
\q2 Ekmek arıyor.  
\q2 Canlarını ferahlatmak için güzel şeylerini yiyecek için verdiler.  
\q1 “Bak, ey Yahve, ve gör,  
\q2 çünkü sefil oldum.”   
\q1
\v 12 “Sizin için önemsiz mi bu,  
\q2 ey bütün sizler, yoldan geçenler?  
\q2 Bakın ve görün, benim başıma gelen,  
\q2 Yahve'nin kızgın öfkesi gününde beni sıkıntıya soktuğu sıkıntı gibi  
\q2 bir sıkıntı var mı?”   
\q1
\v 13 “Yukarıdan kemiklerime ateş gönderdi,  
\q2 ve onlara karşı galip geldi.  
\q1 Ayaklarım için ağ serdi.  
\q2 Beni geri çevirdi.  
\q2 Beni harap etti ve bütün gün baygınım.”   
\q1
\v 14 “Günahlarımın boyunduruğu onun eliyle bağlandı.  
\q2 Birbirine kenetlendiler.  
\q2 Boynuma çıktılar.  
\q2 Gücümü tüketti.  
\q1 Karşı durmaya gücüm yetmeyenlerin ellerine Efendi\f + \fr 1:14 \ft “Efendi” olarak tercüme edilen sözcük “Adonay”dır.\f* beni teslim etti.”   
\q1
\v 15 “Efendi içimdeki bütün yiğitlerimi hiçe saydı.  
\q2 Gençlerimi kırıp geçirmek için bana karşı heybetli bir topluluk çağırdı.  
\q2 Efendi, Yahuda'nın el değmemiş kızını üzüm sıkma teknesinde çiğnedi.”   
\q1
\v 16 “Bunlardan dolayı ağlıyorum.  
\q2 Gözüm, gözüm yaşlar akıtıyor,  
\q2 çünkü canımı ferahlatacak olan tesellici benden uzak.  
\q2 Çocuklarım harap oldu,  
\q2 çünkü düşman galip geldi.”   
\q1
\v 17 Siyon ellerini açtı.  
\q2 Onu teselli eden yok.  
\q1 Yahve, Yakov hakkında,  
\q2 çevresindekiler ona düşman olsunlar diye buyurdu.  
\q2 Yeruşalem onların arasında kirli bir şey oldu.   
\q1
\v 18 “Yahve adildir,  
\q2 çünkü buyruğuna karşı isyan ettim.  
\q1 Lütfen, ey bütün halklar,  
\q2 dinleyin ve üzüntümü görün.  
\q2 El değmemiş kızlarım ve gençlerim sürgüne gittiler.”   
\q1
\v 19 “Sevgililerimi çağırdım,  
\q2 ama onlar beni aldattılar.  
\q1 Canlarını tazelemek için kendilerine yiyecek ararken,  
\q2 kâhinlerim ve ihtiyarlarım kentte ruhlarını teslim ettiler.”   
\q1
\v 20 “Bak, ey Yahve; çünkü sıkıntıdayım.  
\q2 Yüreğim sıkılıyor.  
\q1 Yüreğim içimde dönüyor,  
\q2 çünkü ağır bir şekilde isyan ettim.  
\q1 Dışarıda kılıç yoksun bırakmada.  
\q2 Evde ölüm gibi.”   
\q1
\v 21 “İnlediğimi duydular.  
\q2 Beni teselli eden yok.  
\q1 Bütün düşmanlarım sıkıntımı duydu.  
\q2 Bunu yaptığın için seviniyorlar.  
\q1 İlan ettiğin günü getireceksin,  
\q2 ve onlar da benim gibi olacaklar.”   
\q1
\v 22 “Onların bütün kötülükleri senin önüne gelsin.  
\q2 Bütün günahlarım için bana yaptığını onlara da yap.  
\q1 Çünkü iniltilerim çok,  
\q2 yüreğim de baygın.”   
\c 2  
\p
\v 1 Yahve öfkesiyle Siyon kızını nasıl bir bulutla örttü!  
\q1 İsrael'in güzelliğini gökten yeryüzüne indirdi,  
\q2 öfkesi gününde ayağının taburesini hatırlamadı.   
\q1
\v 2 Yahve Yakov'un bütün yurtlarını acımadan yuttu.  
\q1 Gazabıyla Yahuda kızının kalelerini yıktı,  
\q2 onları yere kadar indirdi.  
\q2 Krallığı ve beylerini bozdu.   
\q1
\v 3 İsrael'in bütün boynuzunu kızgın öfkeyle kesti.  
\q2 Sağ elini düşmanın önünden geri çekti.  
\q1 Yakov'u her tarafını yiyip bitiren alevli ateş gibi yaktı.   
\q1
\v 4 Düşman gibi yayını gerdi,  
\q2 sağ eliyle düşman gibi dikildi.  
\q1 Göze hoş gelenlerin tümünü öldürdü.  
\q2 Siyon kızının çadırı üzerine ateş gibi gazabını döktü.   
\q1
\v 5 Efendi sanki bir düşman gibi oldu.  
\q2 İsrael'i yuttu.  
\q1 Bütün saraylarını yuttu.  
\q2 Kalelerini yıktı.  
\q2 Yahuda kızında yas ve ağıdı artırdı.   
\q1
\v 6 Kendi çardağını,  
\q2 bahçe çardağıymış gibi söküp attı.  
\q1 Toplantı yerini yıktı.  
\q2 Yahve Siyon'da kutsal toplantıyı ve Şabat'ı unutturdu.  
\q2 Şiddetli öfkesiyle kralı ve kâhini hor gördü.   
\q1
\v 7 Yahve sunağını kaldırıp attı.  
\q2 Tapınağından nefret etti.  
\q1 Yeruşalem saraylarının duvarlarını düşmanın eline verdi.  
\q2 Yahve'nin evinde kutsal toplantı gününde olduğu gibi gürültü yaptılar.   
\q1
\v 8 Yahve Siyon kızının duvarını yıkmaya karar verdi.  
\q2 İpi gerdi.  
\q2 Elini yıkmaktan çekmedi;  
\q1 siperlerle duvara ağıt yaktırdı. İkisi birlikte zayıfladılar.   
\q1
\v 9 Kapıları yere battı.  
\q2 Kapı sürgülerini kırıp yok etti.  
\q1 Kralı ve beyleri yasanın olmadığı uluslar arasındalar.  
\q2 Evet, peygamberleri Yahve'den görüm bulmuyorlar.   
\q1
\v 10 Siyon kızının ihtiyarları yerde oturuyorlar.  
\q2 Sessiz kalıyorlar.  
\q1 Başları üzerine toprak attılar.  
\q2 Çul giydiler.  
\q2 Yeruşalem'in kızları başlarını yere eğdiler.   
\q1
\v 11 Yaş dökmekten gözlerim tükendi.  
\q2 Yüreğim sıkıntılı.  
\q1 Halkımın kızının yıkımı yüzünden  
\q2 Ciğerim yere döküldü,  
\q2 çünkü çocuklar ve emziktekiler kentin sokaklarında bayılmakta.   
\q1
\v 12 Kent sokaklarında yaralılar gibi bayılınca,  
\q2 canları annelerinin koynuna döküldüğü zaman,  
\q2 annelerine, “Buğday ve şarap nerede?” diye soruyorlar.   
\q1
\v 13 Sana ne tanıklık edeyim?  
\q2 Ey Yeruşalem kızı, seni neye benzeteyim?  
\q1 Neyi sana kıyas edeyim de,  
\q2 teselli edeyim, ey Siyon'un el değmemiş kızı?  
\q1 Çünkü sendeki gedik deniz kadar büyük.  
\q2 Seni kim iyileştirebilir?   
\q1
\v 14 Peygamberlerin senin için sahte,  
\q2 ve akılsızca görümler gördüler.  
\q2 Senin suçunu açığa çıkarıp  
\q2 sürgününü geri çevirmediler,  
\q2 ama senin için sahte vahiyler ve sürgün nedenlerini gördüler.   
\q1
\v 15 Yoldan geçenlerin hepsi sana el çırpıyor.  
\q2 Yeruşalem kızına baş sallayıp ıslık çalıyorlar,  
\q1 “İnsanların 'Güzelliğin kusursuzluğu,  
\q2 bütün dünyanın sevinci' dediği kent bu mu?” diyorlar.   
\q1
\v 16 Bütün düşmanların sana karşı ağızlarını kocaman açtılar.  
\q2 Islık çalıp diş gıcırdatıyorlar.  
\q1 Şöyle diyorlar, “Onu yuttuk. Gerçekten de beklediğimiz gün budur.  
\q2 Onu bulduk.  
\q2 Onu gördük.”   
\q1
\v 17 Yahve tasarladığını yaptı.  
\q2 Eski günlerde buyurduğu sözünü yerine getirdi.  
\q1 Yıktı, acımadı.  
\q1 Düşmanı senin için sevindirdi.  
\q2 Düşmanlarının boynuzunu yükseltti.   
\q1
\v 18 Yürekleri Yahve'ye feryat etti.  
\q2 Ey Siyon kızının duvarı,  
\q2 gözyaşların gece gündüz ırmak gibi aksın.  
\q1 Rahatlama.  
\q2 Gözlerin dinlenmesin.   
\q1
\v 19 Kalk, geceleyin, nöbetlerin başında bağır!  
\q1 Yahve'nin yüzü önünde yüreğini su gibi dök.  
\q2 Her sokak başında açlıktan bayılan çocuklarının canı için  
\q2 Ellerini O'na doğru kaldır.   
\q1
\v 20 “Bak, ey Yahve, ve kime böyle yaptığını gör!  
\q2 Kadınlar yavrularını, dizleri üzerinde tutup oynattıkları çocuklarını mı yesinler?  
\q2 Kâhin ve peygamber Efendi'nin tapınağında mı öldürülsünler?”   
\q1
\v 21 “Gençler ve yaşlılar sokaklarda yerde yatıyorlar.  
\q2 El değmemiş kızlarımla gençlerim kılıçla düştüler.  
\q1 Öfken gününde onları öldürdün.  
\q2 Boğazladın, ama acımadın.”   
\q1
\v 22 “Kutsal toplantı gününde olduğu gibi, her yandan dehşetlerimi çağırdın.  
\q2 Yahve'nin öfkesi gününde kaçıp kurtulan ya da geride kalan olmadı.  
\q2 Düşmanım, bakıp büyüttüğüm çocuklarımı tüketti.”   
\c 3  
\q1
\v 1 Ben, O'nun gazabının değneğiyle  
\q2 sıkıntı gören adamım.   
\q1
\v 2 Beni güttü, ışıkta değil,  
\q2 karanlıkta yürüttü.   
\q1
\v 3 Gerçekten de bütün gün  
\q2 elini bana karşı çevirip duruyor.   
\q1
\v 4 Etimi ve derimi yıprattı,  
\q2 kemiklerimi kırdı.   
\q1
\v 5 Karşıma duvar yaptı,  
\q2 beni acı ve sıkıntıyla kuşattı.   
\q1
\v 6 Uzun zamandır ölü olanlar gibi  
\q2 beni karanlık yerlerde oturttu.   
\q1
\v 7 Çevreme duvar ördü, dışarı çıkamıyorum.  
\q2 Zincirlerimi ağırlaştırdı.   
\q1
\v 8 Evet, feryat edip yardım çağırınca,  
\q2 duama set çekiyor.   
\q1
\v 9 Yollarıma yontma taşlarla duvar ördü,  
\q2 yollarımı eğri etti.   
\q1
\v 10 Benim için pusuda yatan bir ayı,  
\q2 gizlenmiş bir aslandır.   
\q1
\v 11 Yolumu saptırdı,  
\q2 ve beni paraladı.  
\q2 Beni harap etti.   
\q1
\v 12 Yayını gerdi,  
\q2 beni ok için hedef gibi dikti.   
\q1
\v 13 Kılıfındaki oklarını böbreklerime sapladı.   
\q1
\v 14 Halkımın tümüne alay konusu,  
\q2 gün boyu onların türküsü oldum.   
\q1
\v 15 Beni acıyla doldurdu.  
\q2 Beni pelinle doldurdu.   
\q1
\v 16 Dişlerimi çakıl taşlarıyla kırdı.  
\q2 Üzerimi külle örttü.   
\q1
\v 17 Canımı esenlikten uzaklaştırdın.  
\q2 Bolluğu unuttum.   
\q1
\v 18 “Gücüm,  
\q2 Yahve'den beklediğim umut da yok oldu” dedim.   
\q1
\v 19 Sıkıntımı, sefaletimi,  
\q2 pelinle acıyı hatırla.   
\q1
\v 20 Canım onları hâlâ hatırlıyor,  
\q2 ve içimde eğiliyor.   
\q1
\v 21 Bunu aklıma getiriyorum,  
\q2 bu yüzden umudum var.   
\q1
\v 22 Yahve'nin sevgi dolu iyiliklerinden ötürü tükenmedik,  
\q2 çünkü merhametleri son bulmaz.   
\q1
\v 23 Onlar her sabah yenilenir.  
\q2 Senin sadakatin büyüktür.   
\q1
\v 24 “Benim payım Yahve'dir” der canım.  
\q2 “Bu yüzden O'na güvenirim.”   
\q1
\v 25 Yahve kendisini bekleyenlere,  
\q2 kendisini arayan cana iyidir.   
\q1
\v 26 İnsanın umut etmesi,  
\q2 ve Yahve'nin kurtarışını sessizce beklemesi iyidir.   
\q1
\v 27 İnsanın gençliğinde boyunduruğu taşıması iyidir.   
\q1
\v 28 Tek başına otursun da sussun,  
\q2 çünkü üzerine onu koyan O'dur.   
\q1
\v 29 Ağzını toprağa koysun,  
\q2 belki umut olur.   
\q1
\v 30 Kendisine vurana yanağını uzatsın.  
\q2 Utanca doysun.   
\q1
\v 31 Çünkü Yahve sonsuza dek kendisinden atmaz.   
\q1
\v 32 Çünkü O, kederlendirse de,  
\q2 sevgi dolu iyiliklerinin çokluğuna göre yine merhamet eder.   
\q1
\v 33 Çünkü O, isteyerek sıkıntı vermez,  
\q2 insanoğullarını kederlendirmez.   
\q1
\v 34 Yeryüzünün bütün tutsaklarını ayak altında ezmeyi,   
\q1
\v 35 yüceler Yücesi'nin yüzü önünde insanın hakkını saptırmayı,   
\q1
\v 36 davasında insana haksızlık etmeyi, Efendi razı olmaz.   
\q1
\v 37 Efendi buyurmadıkça,  
\q2 kim bir şey söyler de gerçekleşir?   
\q1
\v 38 Kötülük de iyilik de Yüceler Yücesi'nin ağzından çıkmıyor mu?   
\q1
\v 39 İnsan, yaşayan insan,  
\q2 neden günahlarının cezası için yakınır?   
\q1
\v 40 Yollarımızı araştıralım, deneyelim,  
\q2 ve yine Yahve'ye dönelim.   
\q1
\v 41 Göklerdeki Tanrı'ya\f + \fr 3:41 \ft “Tanrı” olarak tercüme edilen İbranice kelime “אֱלֹהִ֑ים” (Elohim)’dir.\f* ellerimizle birlikte yüreğimizi de yükseltelim.   
\q1
\v 42 “Suç işledik ve isyan ettik.  
\q2 Sen bağışlamadın.”   
\q1
\v 43 “Bizi öfkeyle örttün ve bizi kovaladın.  
\q2 Öldürdün. Acımadın.   
\q1
\v 44 Kendini bulutla örttün,  
\q2 böylece hiçbir dua ondan geçemiyor.   
\q1
\v 45 Bizi halkların arasında pislik ve süprüntü yaptın.”   
\q1
\v 46 “Bütün düşmanlarımız bize karşı ağızlarını kocaman açtılar.   
\q1
\v 47 Dehşet ve çukur üzerimize geldi,  
\q2 kırgın ve yıkım.”   
\q1
\v 48 Halkımın kızının yıkımı yüzünden,  
\q2 gözüm su ırmaklarıyla akıyor.   
\q1
\v 49 Gözüm hiç ara vermeden,  
\q2 durmadan akıyor.   
\q1
\v 50 Yahve aşağı bakıp  
\q2 gökten görene kadar.   
\q1
\v 51 Kentimin bütün kızları yüzünden,  
\q2 gözlerim canımı sarstı.   
\q1
\v 52 Sebepsiz yere bana düşman olanlar  
\q2 bir kuş gibi beni acımasızca kovaladılar.   
\q1
\v 53 Hayatımı zindanda kesip kopardılar,  
\q2 üzerime taş attılar.   
\q1
\v 54 Başımın üstünden sular aktı.  
\q2 “Kesip koparıldım” dedim.   
\q1
\v 55 Zindanının dibinden adını çağırdım,  
\q2 ey Yahve.   
\q1
\v 56 Sesimi duydun:  
\q2 “Kulağını inlememden,  
\q2 ve feryadımdan gizleme.”   
\q1
\v 57 Seni çağırdığım gün yaklaştın.  
\q2 “Korkma” dedin.   
\q1
\v 58 Ey Yahve, canımın davalarını sen gördün.  
\q2 Hayatımı kurtardın.   
\q1
\v 59 Ey Yahve, bana olan haksızlığı gördün.  
\q2 Davamı yargıla.   
\q1
\v 60 Bütün intikamlarını,  
\q2 ve bana karşı yaptıkları bütün tasarıları gördün.   
\q1
\v 61 Ey Yahve, onların aşağılamasını,  
\q2 ve bana karşı olan bütün tasarılarını,   
\q1
\v 62 bana karşı çıkanların dudaklarını,  
\q2 ve bütün gün bana karşı kurdukları düzenlerini duydun.   
\q1
\v 63 Oturuşlarını ve kalkışlarını görüyorsun.  
\q2 Ben onların türküsü oldum.   
\q1
\v 64 Onlara ellerinin işine göre karşılık vereceksin, ey Yahve.   
\q1
\v 65 Onlara yürek katılığı vereceksin,  
\q2 lanetin onlara olsun.   
\q1
\v 66 Onları öfkeyle kovalayacak,  
\q2 ve onları Yahve'nin göklerinin altından yok edeceksin.   
\c 4  
\q1
\v 1 Altın nasıl da donuklaştı!  
\q2 Saf altın nasıl değişti!  
\q1 Kutsal yerin taşları  
\q2 her sokak başına döküldü.   
\q1
\v 2 Saf altınla kıyaslanan,  
\q2 Siyon'un değerli oğulları,  
\q1 nasıl oldu da çömlekçi elinin işi,  
\q2 toprak testiler gibi sayıldılar!   
\q1
\v 3 Çakallar bile memelerini verir,  
\q2 yavrularını emzirirler.  
\q1 Ama halkım kızı,  
\q2 çöldeki devekuşları gibi acımasız oldu.   
\q1
\v 4 Emzikteki çocuğun dili susuzluktan damağına yapışıyor.  
\q2 Küçük çocuklar ekmek istiyor,  
\q2 kimse onlar için koparmıyor.   
\q1
\v 5 Lezzetli yiyecekler yiyenler sokaklarda perişan oldular.  
\q2 Mor giysiler içinde büyütülenler gübre yığınlarını kucakladılar.   
\q1
\v 6 Çünkü halkım kızının suçu,  
\q2 el değmeden bir anda yıkılan Sodom'un günahından daha büyüktür.   
\q1
\v 7 Soyluları kardan daha temizdi.  
\q2 Sütten daha beyazdı.  
\q1 Bedence yakuttan daha kırmızıydı.  
\q2 Safir gibi parlıyordu.   
\q1
\v 8 Görünüşleri kömürden daha kara oldu.  
\q2 Sokaklarda tanınmaz oldular.  
\q1 Derileri kemiklerine yapıştı.  
\q2 Kurudular.  
\q2 Odun gibi oldular.   
\q1
\v 9 Kılıçla öldürülenler kıtlığın öldürdüklerinden iyidir;  
\q2 çünkü bunlar tarla ürünlerinin yokluğundan yıpranarak erimekteler.   
\q1
\v 10 Merhametli kadınların elleri kendi çocuklarını kaynattı.  
\q2 Onlar halkım kızının yıkımında yiyecekleri oldular.   
\q1
\v 11 Yahve gazabını tamamladı.  
\q2 Kızgın öfkesini döktü.  
\q2 Siyon'da, onun temellerini yiyip bitiren bir ateş tutuşturdu.   
\q1
\v 12 Düşman ve hasım Yeruşalem kapılarından içeri girecek diye,  
\q2 yeryüzü kralları ve dünya sakinlerinin hiçbiri inanmazdı.   
\q1
\v 13 Peygamberlerinin günahları,  
\q2 ve kâhinlerinin suçları yüzünden bu,  
\q2 çünkü onlar kentin ortasında doğruların kanını döktüler.   
\q1
\v 14 Sokaklarda körler gibi dolaşıyorlar.  
\q2 Kanla kirlenmişler,  
\q2 Öyle ki, insanlar giysilerine dokunamaz oldu.   
\q1
\v 15 “Çekilin!” diye bağırdılar onlara.  
\q2 “Kirli! Çekilin! Çekilin! Dokunmayın!  
\q1 Kaçıp başıboş dolaştıklarında, insanlar uluslar arasında.”  
\q2 “Artık burada yaşayamazlar” dediler.   
\q1
\v 16 Yahve'nin öfkesi onları dağıttı.  
\q2 Artık onlara bakmayacak.  
\q1 Kâhinlere saygı göstermediler.  
\q2 Yaşlıları kayırmadılar.   
\q1
\v 17 Boş yere yardım beklerken,  
\q2 artık gözlerimiz sönüyor,  
\q2 bizi kurtaramayacak bir ulusu gözledikçe gözledik.   
\q1
\v 18 Adımlarımızı avlıyorlar,  
\q2 sokaklarımızda gezemiyoruz.  
\q1 Sonumuz yakın.  
\q2 Günlerimiz doldu,  
\q2 çünkü sonumuz geldi.   
\q1
\v 19 Bizi kovalayanlar gökteki kartallardan daha hızlı.  
\q2 Dağlarda bizi kovaladılar.  
\q2 Çölde bize pusu kurdular.   
\q1
\v 20 Yaşam soluğumuz,  
\q2 Yahve'nin meshedilmişi,  
\q2 onların çukurlarında yakalandı;  
\q1 hani onun için,  
\q2 Uluslar arasında onun gölgesinde yaşayacağız dediğimiz.   
\q1
\v 21 Sevin ve coş, Uz diyarında oturan ey Edom kızı.  
\q1 Kâse sana da geçecek.  
\q2 Sarhoş olacaksın,  
\q2 ve soyunacaksın.   
\q1
\v 22 Suçlarının cezası tamamlandı, ey Siyon kızı.  
\q2 Artık seni sürgüne götürmeyecek.  
\q1 Ey Edom kızı, senin suçlarını ziyaret edecek.  
\q2 Senin günahlarını ortaya çıkaracak.   
\c 5  
\q1
\v 1 Ey Yahve, başımıza gelenleri hatırla.  
\q2 Bak da utancımızı gör.   
\q1
\v 2 Mirasımız yabancılara,  
\q2 evlerimiz ellere verildi.   
\q1
\v 3 Yetim ve babasız kaldık.  
\q2 Annelerimiz dul kadınlar gibi.   
\q1
\v 4 Suyumuzu parayla içmek zorunda kaldık.  
\q2 Odunumuz bize satılıyor.   
\q1
\v 5 Bizi kovalayanlar ensemizde.  
\q2 Yorgunuz ve rahatımız yok.   
\q1
\v 6 Ekmekle doymak için ellerimizi  
\q2 Mısırlılar'a ve Aşurlular'a verdik.   
\q1
\v 7 Atalarımız günah işledi, artık yoklar.  
\q2 Onların suçlarını biz yüklendik.   
\q1
\v 8 Köleler bizi yönetiyor.  
\q2 Onların elinden bizi kurtaracak kimse yok.   
\q1
\v 9 Çöldeki kılıç yüzünden  
\q2 ekmeğimizi hayatımız pahasına kazanıyoruz.   
\q1
\v 10 Kıtlığın yakıcı sıcağından  
\q2 derimiz fırın gibi karardı.   
\q1
\v 11 Siyon'daki kadınların,  
\q2 Yahuda kentlerindeki el değmemiş kızların ırzına geçtiler.   
\q1
\v 12 Beyler ellerinden asıldı.  
\q2 Yaşlıların yüzlerine saygı gösterilmedi.   
\q1
\v 13 Gençler değirmen taşı taşıdılar.  
\q2 Çocuklar odun yükleri altında tökezledi.   
\q1
\v 14 Yaşlılar kent kapısından,  
\q2 gençler de ezgilerinden kesildi.   
\q1
\v 15 Yüreğimizin sevinci kesildi.  
\q2 Oyunumuz yasa dönüştü.   
\q1
\v 16 Başımızdan taç düştü.  
\q2 Vay halimize, çünkü günah işledik!   
\q1
\v 17 Bu yüzden yüreğimiz baygın.  
\q2 Bu şeylerden ötürü gözlerimiz karardı:   
\q1
\v 18 Siyon Dağı ıssız kalmış olduğu için,  
\q2 onun üzerinde çakallar dolaşıyor.   
\q1
\v 19 Sen, ey Yahve, sonsuza dek kalırsın.  
\q2 Tahtın kuşaktan kuşağa sürer.   
\q1
\v 20 Neden bizi daima unutuyorsun,  
\q2 ve bizi bu kadar uzun bir süre bırakıyorsun?   
\q1
\v 21 Bizi kendine döndür, ey Yahve, ve biz dönelim.  
\q2 Günlerimizi eskisi gibi yenile.   
\q1
\v 22 Ama sen bizi tümüyle reddettin.  
\q2 Bize karşı çok öfkelisin.   