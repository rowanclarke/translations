\v 22 \w No|strong="H3808"\w* \w edificarán|strong="H1129"\w*, \w y|strong="H3588"\w* otro \w morará|strong="H3427"\w*; \w no|strong="H3808"\w* \w plantarán|strong="H5193"\w*, \w y|strong="H3588"\w* otro comerá: \w por|strong="H3588"\w*­\w que|strong="H3588"\w* según \w los|strong="H3427"\w* \w días|strong="H3117"\w* \w de|strong="H3588"\w* \w los|strong="H3427"\w* \w árboles|strong="H6086"\w* serán \w los|strong="H3427"\w* \w días|strong="H3117"\w* \w de|strong="H3588"\w* mi \w pueblo|strong="H5971"\w*, \w y|strong="H3588"\w* mis escogidos \w perpetuarán|strong="H1086"\w* las \w obras|strong="H4639"\w* \w de|strong="H3588"\w* sus \w manos|strong="H3027"\w*.   
