\id 2CO - Okphela
\h 2 iKọritia
\toc1 2 iKọritia
\toc2 2 iKọritia
\toc3 2 iKọri
\mt2 Ebe onuzi-eva ni iPọlu ọ kẹkẹ ghi ẹgbọ
\mt1 IKọritia
\mt2 Eni e miesuọ
\c 1
\p 
\v 1 Mhẹmhẹ iPọlu, aghiusomhi na kẹẹ ọyi iJesu iKirisiti ni Ẹshinẹgba ọ zẹ abi o ghọle ọli shi mhi khi, li shi inyọghuo awa iTimoti. Mhẹmhẹ mhi kẹkẹ ebe ona ghi igbaa oyi eni e mie iJesu iKirisiti suọ onayi Ẹshinẹgba ni e la ẹoli iKọriti ali eni a pfa na nya ni e la ekẹ Akhaya.\f + \fr 1:1 \ft Li zẹ \fq Ika 18.1\f*
\p 
\v 2 Mhi lema Ẹshinẹgba ita awa ali iJesu iKirisiti Ọnọmhuẹ e ka li okhale na ẹ, e ri opfọmhẹ na ẹ.
\s1 Ẹshinẹgba ọna irudushi nya
\p 
\v 3 Awa kuẹghiẹ Ẹshinẹgba, ni ọ khi ita iJesu iKirisiti Ọnọmhuẹ ọyawa, lọli ọ khi ita ọna ilẹlemhi, ni ọ khi Ẹshinẹgba na irudushọ nya.
\v 4 Lọli ọ ri udu ẹ shi awa ọ ini awa la osoli khi osoli, ni awa li dobẹ ri udu shi eni e la osoli ọ, ikhi irudushọ onabi Ẹshinẹgba ọ rọ shi awa ọ.
\v 5 Itobọ khi awa li nu iKirisiti mẹ osoli ebubu eyọli, awa li ya rọte obọ oyi iKirisiti kemhi irudushọ oyi Ẹshinẹgba ni o gbeku ọ.
\v 6 Anye kha mẹ osoli, ni a rọ mhọli irudushọ ali imiepfuese lọ. Okekhia khi eri a ri udu shi anye ọ, ẹẹ a ri udu shi ọ, ni o rẹ ẹ mhọli irabọmudu ri egbe mie osoli onabi anye li ri egbe mie.
\v 7 Iregbenga ni anye regbenga ẹ, o kie migha, itobọ khi anye lẹsẹ khi abi a li nu anye mẹ osoli eyi anye, ighọ a li nu anye mhọli okemhi shi irudushọ oyanye.
\p 
\v 8 Inyọghuo, anye ẹ nono ni a lẹsẹ osoli ni anye mẹ obini Esha. Eri anye mẹ ukpokpomhi ọmunu ni o nẹ anye abọ. Ni o khia khi eri anye ke khẹna egbe anye eghuli ukhomhi.\f + \fr 1:8 \ft Li zẹ \fq 1 iKọri 15.32\f*
\v 9 Eri anye she ri ọli shi udu khi eni eghuli o mema ke ya gbe anye ke khi. Eri a mẹ ona ini anye khi regbenga egbe anye, sẹ ni Ẹshinẹgba tsẹ ni ọọ guise ọni ọ ghu-a le.
\v 10 Lọli ọ rue anye okhẹna eghuli ukhomhi le, ọ ya rue awa ọ le. Lọli awa ri udu nga khi ọ ya gbo rue awa ọ le.
\v 11 A li ri iromhi ke kpaghiẹ anye obọ, ini ebubu ẹgbọ e mẹ asha ri itobọ oyanye kphẹmhi na Ẹshinẹgba, ọni ọ pfo udu ri iromhi ni ebubu ẹgbọ e sọ a tsẹ.
\s1 IPọlu ọ mu ugbamhi eyọli pfi
\p 
\v 12 Anye ma tono obọ udu shi ọ, udu oyi anye ni ọọ gue anye ẹzọ o gbo pfi ọtsẹlẹ shi ọ, khi, angeli oyanye elemhi agbọ ona ali angeli ni anye nu ẹ ngeli, khi ikhueghie elemhi-a ali igẹsikia oyi Ẹshinẹgba o ri anye ẹ gbe akanya. Ọa khi ilẹsingme agbọ anye te riẹlẹ ona, ama okhale oyi Ẹshinẹgba a rọ riẹlẹ ọli.
\v 13-14 Emini a dobẹ ya zẹ, ni o ya gbo lo ẹ esọ anye kẹkẹ ghi ẹ. O kha riẹ khia khi emini anye ẹ ngme ọa lọ ẹ esọ pfo ne, anye mhọli ọ shi udu khi o ya lo ẹ esọ pfo nya ẹlẹlese, ni a ri anye ke tono obọ udu, abi anye li rẹ ẹ ya ke tono obọ udu, ogbẹlẹ oyi iJesu Ọnọmhuẹ ọyawa.
\p 
\v 15 Itobọ khi mhi aa mhọli akhọkhọmhẹ shi ona, mhi rọ nono ni mhi kpẹ bhale ya bino ẹ, ni a mhọli ikhivọsẹ asha eva.
\v 16 Mhi she gba li khi mhi bhale ya bino ẹ ini mhia lẹ iMasidonia ali ini mhia jele, ni mhi mẹ asha mie ẹ ikpaghọ rọ ye ekẹ iJudia.\f + \fr 1:16 \ft Li zẹ \fq Ika 19.21\f*
\v 17 Eri a dabi khi mhia dobẹ ya liẹ khi emini mhi ya riẹlẹ na, ni mhi riẹlẹ ọli? Abi khi eri mhi li abi ọgbọ ni ọ khẹ, “Ii.” Ọ gbolo ẹ, “Iiye.” Ini mhi ba riẹlẹ ọghuẹmhẹ oyi ọgbọ?
\v 18 Abi ungmemhi oyi Ẹshinẹgba o migha shi igẹsikia, ighọ emini mhi gueyẹ ẹ ọa li khi unu eva ni o ri utoghuo liẹ “Ii.” Ali “Iiye.”
\v 19 Itobọ khi iJesu iKirisiti Omi Ẹshinẹgba ni mhẹmhẹ ali iSivanọsi ali iTimoti anye rọ tsẹ abọ yẹ ẹ, ọa khi, “Ii.” Ali “Iiye,” ẹghẹghẹ oghuo. Ama Ẹshinẹgba “Ii,” ọ khi.\f + \fr 1:19 \ft Li zẹ \fq Ika 18.5\f*
\v 20 Irari khi emiemini Ẹshinẹgba ọ rọ nga nya, iJesu iKirisiti ọ rẹwẹ nya khi, “Ii.” Irarighọ, rọte iJesu iKirisiti awa te ẹ mie “Atsẹ.” Ni anye rọ ri ufumhi na Ẹshinẹgba.
\v 21 Ama Ẹshinẹgba ọ ri anye ali ẹẹ migha elemhi iKirisiti. Lọli ọ zẹ awa.
\v 22 Ọ she shi ọlẹlẹ oyọli shi awa egbe. Ọ ri Ayẹmhẹ-nọ-pfuasẹ shi awa udu abi ọlẹlẹ ni ọ khi iyóbọ shi emini Ẹshinẹgba ọ ya riẹlẹ na awa.
\v 23 Ama mhi zẹ Ẹshinẹgba ọtsẹlẹ, lọli ọ lẹsẹ udu oyẹmhẹ. Itobọ khi mhi aa nono ni mhi ri elemhi ibibi nu ẹ ngme, lọli mhi aa rọ ke ye iKọriti.
\v 24 Ọa khi eri anye ri ekpabọ gueyẹ ẹ emini a ya miesuọ. Anye lẹsẹ khi a migha gbagbagba shi irudunga. Itobọ ni a mhọli oghẹlẹ anye rọ nu ẹ gbe akanya.
\c 2
\p 
\v 1 Lọli o zẹ ni mhi rọọ khi, mhi aa ke gbo ya bhale deba ẹ, ini mhi khi yese ẹ udu-a.
\v 2 Ini mhi yese ẹ udu-a, ọghuo ọ la akaghọ ni ọ ya ri egbe mu ẹ. Sẹ ni ọni ọgbọ ni mhi yese udu-a.
\v 3 Lọli o zẹ ni mhi rọ kẹkẹ ebe oghọ ghi ẹ, itobọ khi mhi aa nono ni mhi bhale ya mẹ iyese-udu-a obọ eyi eni e kha rẹmhẹ ghẹlẹ. Irari khi mhi lẹsẹ khi ini mhia ghẹlẹ ẹghẹghẹ aghọ, ẹẹ a liẹ ke ghẹlẹ.
\v 4 Elemhi ukpokpomhi osoli ali amẹ eviẹ mhi te ẹ kẹkẹ ebe ona ghi ẹ, ọa khi eri mhiẹ ni udu o ba yese ẹ-a, ama ni a rọ lẹsẹ abi mhi nono ingme oyẹ nya ramhi.
\v 5 Ama ini ọgbọkhọghuo ọ pfi iyese udu-a, ọa khi mhẹmhẹ ọ mema lolo yese udu-a, ama ẹẹ nya ọ rọte opfoghuo yese udu-a. Ama khi, mhia nono ni mhi ngme ọli ze dọsẹ ana.
\v 6 Osoli ni ebubu ẹ e lama shi a na ọgbọ ọnana, e bu.
\v 7 Ama a rọ topfa li a gbo ri udu shi ọli ọ, ini ọ khi yese udu-a dọsẹ odẹ, ni o te ya pfanọ ku ọli alo.
\v 8 Mhi lema ẹ, a zẹ ni ọ lẹsẹ khi egbegbọ a nono ingme oyọli.
\v 9 Eri mhi mu ẹ fẹ bino ni mẹ ini a ri ungmemhi oyẹmhẹ ya gbe akanya.
\v 10 Ini a rọ topfa ọgbọkhọghuo shi emini ọ riẹlẹ, mhẹmhẹ mhi li rọ topfa li. Ini o khia khi mhi mhuẹ emini mhi kha rọ topfa, mhi she rọ topfa. IKirisiti ọ khi ọtsẹlẹ ọyẹmhẹ khi mhi she rọ topfa.
\v 11 Ẹghẹghẹ aghọ, ọkphaghiẹ ọa mẹ ashikhọghuo regbenga dobẹ mu awa ọ ya le, itobọ khi awa aa khi eni ẹa lẹsẹ igbamhi eyi ọkphaghiẹ.
\s1 Egbe akanya ena ishobọ onogbọ
\p 
\v 12 Abi mhi rọ bhale iTiroasi ya gue usomhi onete oyi iKirisiti le, mhi mẹ ọli khi Ẹshinẹgba ọ khueghie odẹ-a na mẹ shi akanya oyọli, shi oobọ.
\v 13 Udu oyẹmhẹ ọa sheshe, itobọ khi mhi aa mẹ iTatọsi oobọ. Ighọ mhi tsẹ ẹgbọ ena obọ okhila, mhi ya je iMasidonia.\f + \fr 2:13 \ft Li zẹ \fq Ika 20.1\f*
\p 
\v 14 Ama, awa kuẹghiẹ Ẹshinẹgba. Lọli ọ zẹ ni iKirisiti ọ rọ ri awa la orọlọ ni a la mie obọ abi eni e mu ọ le. Ọ ri awa ri ilẹsẹ oyi iKirisiti ẹ gbhiaku asha kpa abi ikphela.
\v 15 Ẹshinẹgba ọ she ri awa mele ighiusomhi eyọli-a, ni awa ba ri usomhi onete oyọli gbhiaku asha kpa, abi ikphela oyi ituale ni ọọ pfie o liẹ gbhiaku, ni o lo iteva ẹgbọ eni a mie ẹ pfuese ali eni ẹ nono ni wẹwẹ e pfua.
\v 16 Uwẹmhi úgbọ oyi eghuli, usomhi oyawa ona o khi shi eni e ya pfua, ama upfiemhi oyi agbọ o khi shi eni a mie ẹ pfuese ọ. Ọghuo ọ dobẹ gbe onana?
\v 17 Anye aa khi eni e ri ungmemhi oyi Ẹshinẹgba nono ẹpfue abi ẹgbọ eghuo ẹ li. Ama ighiusomhi eyi Ẹshinẹgba ni e ri igẹsikia ngme ungmemhi oyọli anye khi. Ekpabọ oyi iKirisiti anye rọ gue usomhi oyanye le. Ẹshinẹgba ọ khi ọtsẹlẹ ọyanye.
\c 3
\s1 Eni ẹẹ ga ena ishobọ onogbọ
\p 
\v 1 Ọa ya li abinẹ khi eri anye ke ẹ titi egbe anye mena? Anye ẹa li abi eni ẹ mie ebe ni a titi wẹ shi neni e tsabọ ungmemhi ye ẹ, ali ni e kha gbolo te aghọ vu e gbo mie ẹ ebe oghọghọ olese? Anye ẹa mhọli emini anye ri ebe eghọghọ ọ riẹlẹ.
\v 2 Ẹẹ oyẹ ẹ a khi ebe oyanye ni a kẹkẹ shi ekelemhi udu oyi anye ni ẹgbọ nya e mẹ ẹẹ zẹ.
\v 3 Eri o rọkhasẹ khi ebe ni iKirisiti lọlighuo ọ kẹkẹ, a khi. Itobọ khi a mie itsabọ ungmemhi oyanye suọ. Ọa khi ọgbọ ọ ri atsu kẹkẹ ẹ shi ebe, ama Ayẹmhẹ oyi Ẹshinẹgba ọ kẹkẹ ẹ. Ọa khi ukiẹkiẹmhi ẹchẹ ọ kẹkẹ ẹ shi ama elemhi udu oyi ẹgbọ.\f + \fr 3:3 \ft Li zẹ \fq Okiali 24.12; iJere 31.33; Ezik 11.19; 36.26\f*
\p 
\v 4 Onana o khi iregbenga ni anye mhọli na Ẹshinẹgba rọte obọ oyi iKirisiti.
\v 5 Ọa khia khi eri anye ghọ guẹ ẹ gbe oni akanya ona, ama Ẹshinẹgba ọ ri iguẹgbe-akanya ona na anye.
\v 6 Lọli ọ ri anye khi eguẹgbe oyi akanya igue ungmemhi oyọli le, na ishobọ onogbọ, ni ọa khi oni a kẹkẹ shi ebe, ama ena elemhi Ayẹmhẹ. Irari khi emini a kẹkẹ shi ebe, eri o ri eghuli ẹ bhale, ama Ayẹmhẹ o ri agbọ a na ọgbọ.\f + \fr 3:6 \ft Li zẹ \fq iJere 31.31\f*
\p 
\v 7 Ushi oyi iMosisi ni o ri eghuli bhale, ni a kẹkẹ shi ikiekiemhi echẹ, ufumhi ni o gẹ nyanyanya, ni ọọ kala, o deba bhale. Ini oni ufumhi ona ni o zẹ khi ẹgbọ iZirẹni ẹa ke dobẹ ẹ bino iMosisi alo ukhomhi tatata, o kala,\f + \fr 3:7 \ft Li zẹ \fq Okiali 34.29\f*
\v 8 Sẹẹ ufumhi oyi ikanya eyi Ayẹmhẹ ni o ri agbọ a na ọgbọ o ke bẹshi ya li?
\v 9 Ini ufumhi o la ugamhi ni o ri eghuli ẹ bhale, sẹẹ ugamhi ni o ri ipfuasẹ ẹ bhale ọa li ya mhọli ufumhi oni o funẹ?
\v 10 Itobọ ona, awa dobẹ ya liẹ khi emini o kpẹ lighọ mhọli ufumhi ni o gẹ nyanyanya ẹlẹlẹ, ọa ke mhọli ufumhi, itobọ ufumhi oyi emini o ke to-ẹoli ọli.
\v 11 Ini emini oo kala, o mhọli ufumhi, sẹẹ ufumhi ni o la oni o migha agbọagbọ ọọ liẹ fu nẹ.
\p 
\v 12 Itobọ khi anye mhọli oni irudushi ona anye rọ li ghọ mhọli igbeudu.
\v 13 Anye ẹa li abi iMosisi ọ li, ni o ri ijẹjẹti ku alo ini ẹgbọ iZirẹni e khi mẹ abi oni ufumhi ni oo gẹ nyanyanya oghọ, ọ li i kala li alo-a.\f + \fr 3:13 \ft Li zẹ \fq Okiali 34.33\f*
\v 14 Ama eri a guese wẹ udu, irari khi ramhi amo, eri a kie ri oni ijẹjẹti oghọ ku wẹ alo, ini ẹẹ zẹ ebe ishobọ ona ẹlẹlẹ. Ini ọgbọ ọ rọ ghi iKirisiti ko tsẹ, ọ rọ ọ rue ọgbọ oni ijẹjẹti alo-a.
\v 15 Ighọ o kie li ogbe na amo, eri ijẹjẹti o kie guese wẹ udu ini ẹẹ zẹ oni Ushi oyi iMosisi.
\v 16 Ama ini ọgbọ da mupfi bhale deba Ọnọmhuẹ ne, ọ rue ọli oni ijẹjẹti odẹ-a.\f + \fr 3:16 \ft Li zẹ \fq Okiali 34.34\f*
\v 17 Ọnọmhuẹ ni a ngme shi akana ena, lọli khi iKirisiti, Ayẹmhẹ oyọli ọ te ẹ gbe akanya, ali khi ashini Ayẹmhẹ oyi Ọnọmhuẹ o da la ne, ẹpfua o la akaghọ.
\v 18 Alo eyawa nya ni aa ri ijẹjẹti ku, o ri ufumhi oyi Ọnọmhuẹ ẹ gẹ nyanyanya abi ughegbe. Oni ufumhi oghọ, obọ oyi Ọnọmhuẹ o te bhale, ni ọ khi ọni Ayẹmhẹ. Lọli ọ mu awa pfi ya li abi lọli, rọte ufumhi ni o rue ẹ nga ọ.
\c 4
\s1 Osoli ali ọsuemhẹ ni e la akanya oyi iKirisiti
\p 
\v 1 Irarighọ, aborọkhia khi ilẹlemhi oyi Ẹshinẹgba anye rọ mie akanya igue ungmemhi le ona eghọ, lọli egbe ẹa rọ pfọ anye-a.
\v 2 Eri anye ri ochoghọ she kie angeli osheli ali omama. Anye ẹa ya ngeli angeli ikpamhika wẹkhi eri anye ẹ mu ungmemhi oyi Ẹshinẹgba ukhomhi pfi kpọkẹ. Ochoghọ eri anye ri emini e khi igẹsikia khasẹ gboo, abi o khi shi ukpẹloe oyi Ẹshinẹgba. Onana o ri ẹgbọ mie shi ọ khi eni a ri egbe ẹ nga anye khi rọte udu oyẹwẹ ni ọọ gue wẹ ẹzọ.
\v 3 A kha usomhi onete ni anye gue ẹ le sheli, eri a rọli sheli na eni e ya pfua.
\v 4 Ọkphaghiẹ ni ọọ mhẹsẹ ẹ shi agbọ ona, ọ she zuse ẹgbọ ni ẹa miesuọ udu ini e khi mẹ ákpá ali ufumhi ni o la usomhi onete oyi iKirisiti, ọni lọli ali Ẹshinẹgba e li abeghuo tee.
\v 5 Irari khi anye aa ri egbe anye tse abọ, ama iJesu iKirisiti anye rọ ọ tse abọ, khi lọli ọ khi Ọnọmhuẹ, ali khi eni ẹẹ ga enayẹ ẹ anye khi, irari oyi iJesu.
\v 6 Ebe-no-pfuasẹ ọọ, “Ẹshinẹgba ọ gueyẹ ákpá o rọte alo ebili gẹ lasele.” Mena ọni Ẹshinẹgba ọ ri ákpá oyọli ẹ gẹ shi elemhi udu oyanye, ni ẹẹ a rọ lẹsẹ khi ufumhi oyẹluẹ khi, alo eyi iJesu iKirisiti a te ẹ mẹ ọli.\f + \fr 4:6 \ft Li zẹ \fq Igbae 1.3\f*
\p 
\v 7 Eri anye li abi akhe afuẹ ni a ri oni ẹpfue onana shi. Ona o rọkhasẹ khi ekpabọ eniẹmhi, obọ oyi Ẹshinẹgba e te ẹ bhale, ọa khi obọ oyanye.
\v 8 Isheghuo a na anye osoli, ama ọa pfuse anye-a. Isheghuo anye mhọli akhọkhọmhẹ, ama anye ẹa la okhẹna.
\v 9 A mẹ anye omi olimhi ama Ẹshinẹgba ọa tsua anye pfi-a. A gbe anye de ekẹ, ama anye ẹ ghua.
\v 10-11 Ogbẹlẹ kpa anye rọ la okhẹna eghuli itobọ oyi iJesu. Eri onana ni anye ẹ mẹ egbe o li abi irọkhọkhọ eghuli ni iJesu ọ ghu, ẹghẹghẹ aghọ ni ọ ri egbọli khasẹ elemhi agbọ oyanye.
\v 12 Onana o guele khi akanya ni anye gbe ẹ na iJesu, eri o ri anye la okhẹna eghuli ogbẹlẹkpa, ama agbọ onogbọ o rọ ọ na ẹ.
\v 13 Ebe-no-pfuasẹ ọọ, “Irari khi mhi mhọli irudunga mhi rọ ngme.” Oni ayẹmhẹ irudunga onana, anye li rọ ngme.\f + \fr 4:13 \ft Li zẹ \fq Iwolo 116.10\f*
\v 14 Anye lẹsẹ khi Ẹshinẹgba ni ọ rọte eghuli guise iJesu Ọnọmhuẹ le bhale agbọ ọ ya li rọte eghuli guise anye le, o rue anye ali ẹẹ bhale odalo oyọli.
\v 15 Itobọ oyẹẹ a rọ riẹlẹ enana nya, ni ebubu ẹgbọ e lẹsẹ okhale ni Ẹshinẹgba o li, isheghọ ni e ke sọ iromhi ikphẹmhi ri ufumhi na Ẹshinẹgba.
\s1 Agbọ irudunga
\p 
\v 16 Itobọ onana, egbe ẹa tigbe ya pfọ anye-a, ini anye ririẹ kuanọ-a pfo, ama ogbẹlẹ kpa ekelemhi udu oyanye o rọ ọ khi onogbọ-a shi ọ.
\v 17 Eri ikuku osoli ni ẹa ya tẹsẹ eyi anye, e muno anye egbe ẹ khẹ ufumhi na agbọagbọ. Lọli o zẹ khi osoli eyi anye e li abi emhi afuẹ shi anye ọ.
\v 18 Emini áá mẹ ẹloe ẹa ya la ọ agbọagbọ, ama emini aa ya mẹ ẹloe ẹẹ la ọ agbọagbọ. Lọli o zẹ khi anye ri udu oyanye shi emini aa ya mẹ ẹloe.
\c 5
\s1 Apfẹ oyawa na iloghie
\p 
\v 1 Anye lẹsẹ khi ini idiegbe oyanye ona, na elemhi agbọ, ni o li abi okholo, o ghua, anye mhọli idiegbe olese ni o rọte obọ oyi Ẹshinẹgba bhale. Ikhi idiegbe no ọa ya ghu ni o la iloghie, owa ni ọa khi abọ a rọ mama li.
\v 2 Memena eri anye la oni elemhi idiegbe na agbọ ona a to ekperumhẹ-a, irari khi eri ọọ ghọle anye ni a kpha oni owa na iloghie sọ anye.
\v 3 Itobọ khi ini a rọli sọ anye, anye ẹa ke ya la irumheba.
\v 4 Irari khi abi anye kie li la idiegbe ona agbọ ena, eri anye ẹ to ekperumhẹ-a abi eni egbe ẹ to. Ọa khi eri anye ẹa ke nono ni anye ké la oni idiegbe oyanye ona, ama eri ọ ghọle anye ni a ri idiegbe na iloghie ni ọa ya ghu ghue eghọ sọ anye. Ẹghẹghẹ aghọ ni agbọ o to idiegbe ni ọọ ghu luẹ elemhi imuọle.
\v 5 Ẹshinẹgba ọ ma anye shi agbọ na agbọagbọ ona, lọli ọ gbo ri ọni Ayẹmhẹ shi anye egbe ni ọ khi iyobọ khi lọli ya riẹlẹ emini ọ rọ nga na awa.
\v 6 Irarighọ, anye rọ ọ mhọli igbedu ẹghẹghẹ kpa.
\p Anye gbo lẹsẹ khi ini anye kha da la apfẹ elemhi idiegbe oyanye ne, anye ẹa ke nu Ọnọmhuẹ la.
\v 7 Ama irudunga o ri anye la agbọ, ọa khi emini anye ri ukpẹloe mẹ, o ri anye la agbọ.
\v 8 Udu oyanye o migha gbaa shi ọ, khi, oo kha ti anye ẹloe ni anye lase idiegbe oyanye ona le, ni anye nu Ọnọmhuẹ la apfẹ.
\v 9 Irarighọ, eri anye rọ li shi udu oyanye khi anye mema ya riẹlẹ emini o ghọle ọli, okekhia khi anye ke la apfẹ elemhi idiegbe oyanye o, okekhi anye ẹa la apfẹ elemhi idiegbe oyanye.
\v 10 Irari khi awa nya, awa mema bhale ya migha odalo ukpẹkhomhi iguẹzọ oyi iKirisiti, ni ọgbọgbọ ọ rọ mie ifata ni o khi oyọli, shi emini ọ riẹlẹ abi ọ rọ la idiegbe oyọli, shi oni o ti o, shi oni ọa ti.\f + \fr 5:10 \ft Li zẹ \fq iRom 14.10\f*
\s1 Akanya iri-ẹgbọ ali Ẹshinẹgba riẹlẹ
\p 
\v 11 Irarighọ, aborọkhia khi anye lẹsẹ emini inulishi oyi Ọnọmhuẹ o khi eghọ, lọli anye rọ rọshẹka rọli ẹ lo ẹgbọ esọ. Emini anye khi o ga khueghie-a shi Ẹshinẹgba ọ, anye gbo sa khi o gbo lighọ khueghie-a shi udu oyẹẹ, ni ọọ gue ẹ ẹzọ.
\v 12 Ọa khi eri anye titi egbe anye ẹ khasẹ ẹ, ama eri anye ri ẹghẹghẹ ẹ na ẹ ni a mẹ asha ri anye ke gha. Ẹghẹghẹ aghọ ni a mẹ emini a ya sọ ẹgbọ eni e ri emini ri ukpẹloe ẹ mẹ ẹ gha, ocho ni e kha rọ ri emini e la udu, ke gha.
\v 13 Ini anye ẹa ke lẹsẹ emini anye ẹ riẹlẹ, irari oyi Ẹshinẹgba lọ, anye kha ke lesẹ emini ẹẹ riẹlẹ o, irari oyẹ ẹ lọ.
\v 14 Inono oyi iKirisiti o mhẹsẹ ẹ na anye, itobọ khi anye mẹ ọli mẹ khi ọgbọ ọtuọghuo o ghu-a na agbọ nya, irarighọ eri awa li ghu pfa olamhẹ.
\v 15 Eri iKirisiti ọ ghu-a na ọgbọkpa ini eni e la agbọ e khi ke la agbọ na egbe wẹ, ama ni e ke la agbọ na oni ọ ghu-a ni a gbo guise le na wẹ.
\p 
\v 16 Itobọ ighọ, rọte ana je odalo, anye ẹa ke ri ukpẹloe ni ẹgbọ na agbọ e rọ bino ẹgbọ ke bino ọgbọ khọghuo. Ini o ririẹ khia khi anye kpẹ lina ri ukpẹloe agbọ bino iKirisiti ẹghẹghẹ ni o dọsẹ, anye ẹa kẹ lighọ.
\v 17 Irarighọ, ini ọgbọ ọ da she ku ma iKirisiti ọ ne, ọgbọ ọnọgbọ ni a lẹsẹ ma ọ ke khi, agbọ onodiọ o she dọsẹ, agbọ onogbọ ọ ke la.
\v 18 Ẹshinẹgba ọ ga riẹlẹ eni emhi enana nya. Lọli ọ ri awa ni awa kpẹ khi ebe ọli nu egbeọli riẹlẹ, rọte obọ oyi iKirisiti. Ọ ri akanya na awa, awa rọ ke ri ẹgbọẹse nu luẹ riẹlẹ.
\v 19 Eri Ẹshinẹgba ọ ri ẹgbọ na agbọ nya nu egbọli i riẹlẹ rọte obọ oyi iKirisiti, ni o khia khi Ẹshinẹgba ọa ri olamhẹ mu ota sọ wẹ. Ighọ ọ she ri usomhi ni a rọ ri ẹgbọ ali Ẹshinẹgba a riẹlẹ nga awa obọ.
\v 20 Irarighọ eni e to ẹloli iKirisiti awa ke ri irarighọ khi, ni o rọ li abinẹ khi eri Ẹshinẹgba ọ rọte unu oyawa a lema ẹgbọ. Anye lema ẹ na iKirisiti, a ka nu Ẹshinẹgba rọ riẹlẹ.
\v 21 Eri Ẹshinẹgba ọ ri iKirisiti ni ọa mhọli olamhẹ mele ona olamhẹ itobọ oyawa, ẹghẹghẹ aghọ, ni awa mẹ asha rọte iKirisiti mhọli ipfuasẹ oyi Ẹshinẹgba.
\c 6
\p 
\v 1 Abi eni wẹwẹ ali Ẹshinẹgba e ga a gbe akanya oghuo, anye lema ẹ, a khi zẹ ni a mie okhale oyi Ẹshinẹgba shi afuẹ.
\v 2 Irari khi Ẹshinẹgba ọọ liẹ,
\q1 “Abi ẹghẹghẹ ni mhi rọ ya
\q1 riẹlẹ isomhelemhi na ẹ,
\q2 o rọ ramhi,
\q1 mhi ri esọ shi ẹ ekẹ,
\q2 abi ogbẹlẹ imiepfuese
\q2 oyẹẹ o rọ ramhi,
\q1 mhi kpaghiẹ ẹ obọ.”
\m Mhi gueyẹ ẹ khi memena o khi ẹghẹghẹ isomhelemhi, amo khi ogbẹlẹ imiepfuese.\f + \fr 6:2 \ft Li zẹ \fq Aza 49.8\f*
\p 
\v 3 Anye ẹa ya pfi ọzuodẹ shi ọgbọkhọghuo odẹ, ini ẹgbọ e khi mẹ emini ọa ti okhọghuo gue shi akanya oyi Ẹshinẹgba ni anye ẹ gbe.
\v 4 Ama abi ighumha eyi Ẹshinẹgba ni anye khi, eri anye ri emini anye khi khasẹ odẹkhodẹ, abi anye li ri egbe mie osoli ali umhamẹ ali iyese-udu-a.
\v 5 A gbe anye itali, a gbo mu anye shi ọgba-ighumha, a la onyaghu kuale anye utse, anye gbe akanya agbeghua, anye mhuẹ umha-ke-lẹsẹ ali okiamhi.\f + \fr 6:5 \ft Li zẹ \fq Ika 16.23\f*
\v 6 Ama anye kie la elemhi ipfuasẹ ali ilẹsẹ, ali irabọmudu ali isomhelemhi, rọte Ayẹmhẹ-nọ-pfuasẹ ali inono ni o rọte udu igẹsikia lasele.
\v 7 Anye ẹ ngme ingmemhi igẹsikia, ali ekpabọ oyi Ẹshinẹgba o la anye egbe ẹ gbe akanya. Akhegbe oyanye khi iguẹ-ngeli odalo oyi Ẹshinẹgba, abi ọkhọli-okhuẹ ọ liẹ mu itsua okhọli mhuẹ obita ali ọgobọ.
\v 8 A ri ekpẹ na anye a gbo yẹghẹ anye-a, a ngme onete oyanye, a gbo ngme onobe oyanye. Anye ẹgbọ igẹsikia, a lu anye elo-ẹgbhuẹ,
\v 9 E li anye abi eni aa lẹsẹ, ama a kie lẹsẹ anye, a li anye abinẹ khi eni e ghuloa anye khi, ama, a mẹ ọli mẹ khi anye kie la agbọ. A na anye osoli ama aa gbolo anye-a,
\v 10 Anye mhọli iyese-elemhi-a, ama anye kiele e ghẹlẹ, anye li abi eni ẹa mhuẹ, ama eri anye ri ebubu ẹgbọ khi eni e pfue. Anye li abi eni ẹa mhọli emhi khọghuo, ama emhikpa anye mhuẹ.
\p 
\v 11 Ẹgbọ iKọriti, anye she ri igẹsikia nu ẹ ngme, anye khueghie udu oyi anye-a gbodogio deba ẹ.
\v 12 Anye ẹa ti egbe je ukhokho inono ni anye mhọli na ẹẹ, ẹẹ tsẹ áà ke nono anye.
\v 13 Irarighọ, mhi nu ẹ ngme abi eniyẹ eyẹmhẹ, a li mhọli usamhi nabi anye sa deba ẹ na anye. A khueghie udu oyẹ ẹ-a na anye gbodogio.
\p 
\v 14 Khi zẹ ni u nu ọni ọa miesuọ ke riẹlẹ emhi kugbe. Sẹ, igẹsikia ali ẹgbhọli e li guẹ la asheghuo kugbe? Elọ o ku ákpá ali obili gbe?
\v 15 Elọ e ku iKirisiti ali Ọkphaghiẹ? Abi elọ ọni ọ miesuọ ali ọni ọa miesuọ e mhọli kugbe?
\v 16 Ilama-kugbe onoghuo o la Owa Oyi Ẹshinẹgba ali ikhumhi ọ? Irari khi Owa Oyi Ẹshinẹgba ni ọ la ọ, awa khi, ẹzẹzẹ abi Ẹshinẹgba ọ ngme ọli khi,
\q1 “Mhi ya la wẹ elemhi,
\q2 mhi la wẹ iteva a kia,
\q1 mhi khi Ẹshinẹgba ọyẹwẹ,
\q2 wẹwẹ e khi ẹgbọ eyẹmhẹ.”\f + \fr 6:16 \ft Li zẹ \fq iLẹv 26.12; Ezik 37.27; 1 iKọri 3.16; 6.19\f*
\q1 
\v 17 “Irarighọ, a rọte wẹ iteva lasele,
\q2 ni a khi ọda shi wẹ ọ,
\q1 ali a khi ri obọ ti
\q1 emini ọa pfuasẹ,
\q2 ẹghẹghẹ aghọ
\q2 ni mhi ti ẹ mama egbe.”
\q1 Ẹshinẹgba Ọnọmhuẹ nọ funẹ nya,
\q2 ọ ngme na.\f + \fr 6:17 \ft Li zẹ \fq Aza 52.11\f*
\q2 
\v 18 “Mhi ya khi ita ẹ,
\q2 ẹẹ a khi imimhẹ
\q2 emọse ali ikpotso.”
\q1 Ẹshinẹgba Ọnọmhuẹ nọ funẹ nya
\q2 ọ ngme na.\f + \fr 6:18 \ft Li zẹ \fq 2 iSam 7.14; 1 Okhẹ 17.13; Aza 43.6; iJere 31.9\f*
\c 7
\p 
\v 1 Aborọkhia khi awa mhọli ishobọ ena, emọle mhẹ, awa kpe idiegbe ali ayẹmhẹ oyawa-a, rọte emini e ri ichimhi ẹ shi ọgbọ egbe ali ayẹmhẹ nya. Awa ke rọshẹka ini awa dobẹ ramhi irọpfuasẹ pfo nya, itobọ khi awa a na ulishi Ẹshinẹgba.
\s1 Igbaa oyi eni e mie iJesu iKirisiti suọ e ri egbe mu iPọlu
\p 
\v 2 A khueghie udu oyẹ ẹ-a na anye. Anye ẹa li ọgbọkhọghuo onobe, wẹkhi eri anye yese ọgbọkhọghuo udu-a, ukẹ-liẹ khi eri anye li ọgbọkhọghuo le.
\v 3 Ọa khi eri mhi ngme ona rọ pfuẹchẹ ẹ-a, irari khi mhi kpẹ ngme ọli khi ingme oyẹ ẹ o la anye elemhi udu ramhi ni anye rọ ya lama nu ẹ ghua, okekhi ni anye rọ nu ẹ la agbọ.
\v 4 Mhi lolo regbenga ẹ, mhi ma rẹ ẹ gha gba. Elemhi osoli ni anye mẹ nya, eri iridushiọ ali oghẹlẹ oyanye o vọ ọ tsuakua.
\p 
\v 5 Irari khi abi mhi rọ lo iMasidonia le, idiegbe oyanye ona ọa mhọli iyẹmhẹa okhọghuo. Odẹ-khodẹ a na anye osoli, eghuo e nu anye wola, ulishi o la anye udu.\f + \fr 7:5 \ft Li zẹ \fq 2 iKọri 2.13\f*
\v 6 Ama Ẹshinẹgba na irudushọ, ni ọ ri udu ẹ shi ọni egbe e pfọ-a ọ, ọ ri iTatọsi ni ọ bhale ri udu ke shi anye ọ.
\v 7 Ọa khi ibhale oyọli tsẹ o ri udu shi anye ọ, ama abi a li ri udu shi ọli ọ. Ọ gbo gueyẹ anye abi o liẹ ghọle ẹ ni a mẹ mhẹ, ali abi a li viẹ oya, ali abi ingme oyẹmhẹ ọ li mu ẹ egbe. Irarighọ, oghẹlẹ oyẹmhẹ o rọ fu dọsẹ abi o kpẹ li ghue.
\p 
\v 8 Ini ebe ni mhi kẹkẹ ghi ẹ, o ri iyese-udu-a na ẹ, ọa limhẹ egbe abinẹ khi emini ọa ti ni mhi riẹlẹ. O kie rẹmhẹ chima, mhi mẹ khi ebe oyẹmhẹ o rẹ ẹ yese udu-a ukuku ẹghẹghẹ.
\v 9 Ama egbe e kiele mu mhẹ, ọa khi itobọ khi mhi ri udu oyẹẹ yese-a, ama itobọ khi iyese-udu-a oyẹẹ o rẹ ẹ mu pfi. Eri a mhọli iyese-udu-a abi Ẹshinẹgba ọ nono ọli shi. Irarighọ, ọa li ẹ onobe.
\v 10 Irari khi iviẹ-osoli ni o ghọle Ẹshinẹgba, eri o ri ọgbọ ọ mudu pfi, o rọli ẹ nono ni a mie ọli pfuese. Onana ọa ri ọgbọ ngomhi obọ-a. Ama ini ọgbọ viẹ osoli abi ẹgbọ na agbọ, eghuli o rọ ọ bhale.
\v 11 A lẹsẹ bino emini iviẹ-osoli ni o ghọle Ẹshinẹgba ọ rọ na ẹ. Abi a li rọshẹka ni a rọkhasẹ khi aa mhuẹ umhaguẹli. Elemhi e bi ẹ. Abọ e sha ẹ, ni o rẹ ẹ yila. A gbolo nono ni a sọ ingme shi odẹ igẹsikia! A rọkhasẹ khi aa mhọli ashini a te riẹlẹ oni ingme dọ-a, ẹghẹghẹ kpa.
\p 
\v 12 Irarighọ, ini mhi ririẹ kẹkẹ ebe oghọ ghi ẹ, ọa khi irari eni e li ingme wẹkhi irari eni ẹa li ingme. Ama eri mhi kẹkẹ ebe ona ghi ẹ, ni a ba mẹ abi ingme oyanye o li mu ẹ egbe odalo oyi Ẹshinẹgba.
\v 13 Enana nya e ri udu shi anye ọ.
\p Abi o li ri irudushọ na anye, ighọ egbe ma mu anye abi anye rọ mẹ abi iTatọsi ọ li ghẹlẹ, itobọ ayẹmhẹ oyọli o ti ngẹ abi ẹẹ nya a ri egbe mu ọli.
\v 14 Mhi kpẹ rẹ ẹ tono obọ udu khasẹ iTatọsi, ama aa ri omama mu mhẹ. Abi emini anye gueyẹ ẹ nya e li khi igẹsikia, ighọ abi anye rẹẹ gha khasẹ iTatọsi o li ya khi igẹsikia.
\v 15 Ighọ inono ni ọ mhọli na ẹ o li nga shi ọ, ini ọọ sato abi a li suọ esọ na li, ali abi a ri ulishi ali iguọmhise-egbe mie lọli.
\v 16 O ma rẹmhẹ ghẹlẹ gba khi eni e zẹ ri egbe ẹ nga a khi.
\c 8
\s1 Abi eni e miesuọ e liẹ somhopfa
\p 
\v 1 Inyọghuo, anye ẹ nono ni a lẹsẹ afu ni Ẹshinẹgba ọ rọ na igbaa nya eyi eni e mie iJesu iKirisiti suọ ni e la ekẹ iMasidonia.
\v 2 Eri a rọte osoli ni e mẹ mu wẹ fẹ bino, ama eri e kie ri ukpokpomhi oghẹlẹ e somhopfa, abi o riẹ khia khi ẹa mhuẹ.
\v 3 Mhi gue ọli ẹ yẹ ẹ egbegbọ khi eri e pfue elemhi somhopfa dọsẹ ashini e mhuẹ ramhi.
\v 4 E lema anye, anye kpẹkpẹ anye zẹ ni wẹwẹ e mhọli okemhi shi oghẹlẹ ni o la irikpaghiobọ na ẹgbọ eyi Ẹshinẹgba ni e la ekẹ iJudia.\f + \fr 8:4 \ft Li zẹ \fq iRom 15.26\f*
\v 5 Eri e ga riẹlẹ dọsẹ abi anye sa khi e li ya riẹlẹ. E kpẹ te ododẹ ri egbe wẹ na Ọnọmhuẹ, neni e ke ri egbe wẹ na anye abi Ẹshinẹgba ọ nono ni e li riẹlẹ.
\v 6 Irarighọ, anye rọ lema iTatọsi, ọni ọ rẹ ẹ bẹlẹ oni egbegbi akanya ona, ọ kpaghiẹ ẹ ni a ri eminete ni a gba ekẹ le ramhi ukpẹsẹ.
\v 7 Eri a guẹ ẹ riẹlẹ emhikpa dọsẹ ẹgbọẹse nya. A toto irudunga nẹ, a guẹ ẹ ngme ẹmuẹ nẹ, a gbo lẹsẹ nẹ. A ma nono ni a rue obọ-a, a gbo nono ingme oyanye nẹ. Zobẹ ni u dọsẹ ọgbọkpa okpokhẹ ilili.
\p 
\v 8 Ọa khi itoto mhi rọ mhẹsẹ ọli na ẹ ama eri mhia mhẹsẹ igẹsikia ni o la inono ni a mhọli bino, abi mhi li rọli ẹ khọkhọ ọmuegbe ni ẹgbọẹse e mhọli na anye.
\v 9 A lẹsẹ abi okhale oyi iJesu iKirisiti Ọnọmhuẹ ọyawa o li, khi aboriẹkhia khi ọni ọ pfue ọ khi, eri ọ ri egbe ọli mele ọna umhamẹ-a shi itobọ oyẹ ẹ, ni ọ mẹ asha ri umhamẹ oyọli rẹ ẹ pfue.
\p 
\v 10 Ude ni mhi ya ye ẹ ena, ni o rọ ti ẹ egbe lọ: O ma ti ini isomhopfa ni a te ekẹ bẹlẹ aolukpe ni a rọli ramhi ukpẹsẹ, abi a li kpẹ te ododẹ khi eni e mhọli ọghuẹmhẹ somhopfa, ni e gbo somhopfa.
\v 11 A zobẹ ni a pfuse oni akanya gbe pfo, ni abi o li te ekẹ mu ẹ egbe ni a rọ somhopfa, ni a lighọ somhi oni opfa abi abọ e tẹ ẹ.
\v 12 Emini a mhọli ọa mu Ẹshinẹgba ẹloe. Emini o mu ẹloe khi abi a li mhọli ọghuẹmhẹ ni a rọte emini a mhuẹ somhopfa, ọa khi oni aa mhuẹ, áá bino.
\p 
\v 13 Ọa khi eri mhia mie ẹgbọ eghuo itsua shi ekẹ ni mhi rọ ri itsua na ẹgbọẹse tsua. Ama ni a ga li abeghuo.
\v 14 Aborọkhia khi a mhọli gbeku ọ memena eghọ, o ti ni a kpaghiẹ eni ẹa mhuẹ obọ. Ini wẹwẹ e ke li mhuẹ gbeku ọ ẹlẹlese, ni ẹẹ aa ke rọ mhọli, wẹwẹ e li kpaghiẹ ẹ obọ, isheghọ o guẹ ti ẹ egbe abeghuo.
\v 15 Abi a li kẹkẹ ọli shi Ebe-no-pfuasẹ khi,
\q1 “Ọni ọ ti ẹ gbili
\q2 ọa ya tigbe mhọli gbeku ọ,
\q1 ama ọni ọ ti ikukuwẹ gbili,
\q2 emhi khọghuo
\q2 ọa tigbe ẹ baliku.”\f + \fr 8:15 \ft Li zẹ \fq Okiali 16.18\f*
\s1 A ghie iTatọsi je iKọriti
\p 
\v 16 Mhi kphẹmhi na Ẹshinẹgba ni ọ li ri ọmuegbe onabi mhi mhọli na ẹ, shi iTatọsi udu.
\v 17 Irari khi ọa khi eri ọ lẹsẹ lama shi emini anye lema li ọ riẹlẹ tsẹ, ama eri o she kpẹ la li udu khi lọli ẹ bhale deba ẹ.
\v 18 Anye li ghie inyọghuo ọọghuo deba li ẹ bhale. Ọgbọ ni a ga lolo mu ekpẹ ẹ na elemhi igbaa oyi eni e mie iJesu iKirisiti suọ nya shi akanya itsabọ usomhi onete oyi Ẹshinẹgba ọ khi.
\v 19 Ọa khi oghọ tsẹ, eri eni igbaa nya eyi eni e mie iJesu iKirisiti suọ, e zẹ ọli ọ deba anye kia abi anye li tsua eni isomhopfa ikpaghọ ni anye rọ ya na ẹ kia. Ikhi ikpaghiobọ ni e ya ri ikuẹghiẹ ghi eva oyi ọni Ọnọmhuẹ, ni o rọkhasẹ khi anye mhọli ọmuegbe rọọ kpaghiobọ.
\p 
\v 20 Anye ẹa nono ni ọgbọkhọghuo ọ mẹ emhi akhọkhọmhẹ okhọghuo gue shi abi anye li ri isomhopfa ikpaghọ okpokhẹ ena kia.
\v 21 Emini o zẹ khi anye lina riẹlẹ ọli khi, eri anye rọshẹka ni anye rọkhasẹ khi anye guẹ ri eni isomhopfa ikpaghọ ena kia. Ọa khi odalo oyi Ẹshinẹgba tsẹ ama li shi odalo oyi ẹgbọ nya.\f + \fr 8:21 \ft Li zẹ \fq Ekpi 3.4\f*
\p 
\v 22 Anye gbo li ghie inyọghuo ọlese ma aava ena egbe ẹ ghi ẹ. Anye she mu ọli fẹ itingmingmẹ, anye mẹ ọli mẹ khi ọ ma nono ni lọli kpaghiẹ obọ. Eena o mema ghọle ọli ọ rọ kpaghiẹ obọ, eena ni ọ she mẹ khi eni a ri egbe ẹ nga a khi.
\v 23 ITatọsi ọnuzava oyẹmhẹ ali oni anye ga a gbe akanya kugbe ọ khi, ama inyọghuo awa enekpọle, etoẹloli igbaa nya eyi eni e mie iJesu iKirisiti suọ, ni e ri ufumhi na iKirisiti.
\v 24 Irarighọ, a ri inono oyẹẹ khasẹ eni ẹgbọ ena, ali emini o zẹ ni anye rọ rẹẹ a gha, ni igbaa eyi eni e mie iJesu iKirisiti suọ e mẹ ọli.
\c 9
\s1 Ikpaghiobọ ni a rọ na ẹgbọ eyi Ẹshinẹgba
\p 
\v 1 Mhi aa kha ke gbo kẹkẹ ingme ikpaghiobọ ni a nono ni a rọ na ẹgbọ eyi Ẹshinẹgba ni e la ekẹ iJudia shi ebe ghi ẹ.
\v 2 Mhi lẹsẹ khi ọọ ghọle ẹ ni a rọ kpaghiẹ obọ, mhi gbo rọli rẹẹ ẹ neta ọmọse khasẹ ẹgbọ na obini iMasidonia, khi aolukpe, ẹẹ ni a la Akhaya a te muegbe ni a rọ ya kpaghiẹ obọ, ali khi ọmuegbe oyẹẹ o she li guise ẹgbọ eghuo le, ni e rọ li riẹlẹ ikpaghiobọ.
\v 3 Ama eri mhi ghi inyọghuo awa ena ghi ẹ ni a rọ mu egbe shi ekẹ, ini eta ọmọse ni anye rẹ ẹ na shi isomhopfa ni a somhi, o khi li abi afuẹ ni anye rẹ ẹ na eta ọmọse, ama ni o kie khi abi anye ẹ khi a li.
\v 4 Irari khi ini ọnge iMasidonia ọkhọghuo ọ deba mhẹ bhale, ni aa rọ mu egbe shi ekẹ, omama o ya mu anye shi abi anye li lighọ bẹshi regbenga ẹ rẹẹ neta ọmọse. Ẹẹ omama o ya mu nẹ.
\v 5 Lọli o zẹ ni mhi rọ ghie eni inyọghuo awa ena ralo na mhẹ, ni e ya muegbe isomhopfa okpokhẹ oyi ukpaghọ, ni ẹ khi a ya rọ bhale shi ekẹ neni mhi bhale. Ẹghẹghẹ aghọ ni a rọkhasẹ khi eri o pfo ẹ udu li oni okpokhẹ ni ọa khi oyi ichiobọ.
\p 
\v 6 A sato khi ọni ọ chi-obọ ri emhi kọ khi ukukuọ ọ ya mẹ khiẹsẹ. Ọni ọ ri emhi kọ tuọ, emini e bu o ya mẹ khiẹsẹ.
\v 7 Ọgbọgbọ ọ ri irarighọ ke rọna abi o pfo ọli udu, ama ọ khi ri iwọlọ rọna, ali o khi li abinẹ khi oni a ri ekpabọ rẹ ẹ riẹlẹ, irari khi Ẹshinẹgba ọ ma nono ọni ọ ri oghẹlẹ ẹ rue obọ-a.
\v 8 Ẹshinẹgba ọ dobẹ ya ri ikhivọsẹ ni o dọsẹ oni a nono na ẹ, ni a rọ bhale ya ẹ khi a mhọli emhikpa gbeku ọ dọsẹ abi a nono ọli shi, ni a rọ dobẹ ke riẹlẹ eminete khi eminete na ẹgbọẹse ẹghẹghẹ kpa.
\v 9 Ẹzẹzẹ abi a li kẹkẹ ọli shi Ebe-no-pfuasẹ, ni ọọ,
\q1 “Ọ li okpokhẹ tuọtuọ,
\q2 ọ somhi eni ẹa mhuẹ opfa,
\q1 ọgbọ ọa ya yele
\q1 iguẹ-ngeli oyọli-a ghue
\q2 agbọagbọ.”\f + \fr 9:9 \ft Li zẹ \fq Iwolo 112.9\f*
\m 
\v 10 Ẹshinẹgba ni ọ ri ukpamhi ẹ na ọgbọ rọ kọ, ọ gbo ri eminale na ọgbọkpa a le. Ọ ya gbo ri ikpamhi ni a rọ ọ kọ ghi ẹ, ọ gbo rẹwẹ zẹ, ọ rẹwẹ fu ni a mẹ khiẹsẹ. Isheghọ ni onete ni u riẹlẹ na ẹgbọ o mọ umọmhi nẹ, ni u pfa le.\f + \fr 9:10 \ft Li zẹ \fq Aza 55.10\f*
\v 11 Ọ ya rẹ ẹ pfue odẹkhodẹ ni a ke li okpokhẹ ẹghẹghẹ kpa, ni ebubu ẹgbọ e ke kphẹmhi na Ẹshinẹgba ini anye tsua isomhopfa eyẹ ghi wẹ.
\v 12 Oni ugamhi ni a lina ri okpokhẹ oyẹẹ ona ga ena, ọa khi ẹgbọ eyi Ẹshinẹgba na pfa na tsẹ o kpaghiẹ obọ, ẹgbọ ebubu e ri itobọ ona a kphẹmhi na Ẹshinẹgba.
\v 13 Eri akanya ni a gbe na ẹgbọ eyi Ẹshinẹgba o ri ufumhi na Ẹshinẹgba, o rẹwẹ kuẹghiẹ Ẹshinẹgba. Ona o rọkhasẹ khi eni e mie usomhi onete oyi iKirisiti suọ a khi, ni a ri oni usomhi gbe akanya, abi a li li okpokhẹ na wẹ ali ẹgbọ elese.
\v 14 Inono ni e rọte ekelemhi udu mhọli na ẹ, e te ẹ sọ iromhi na ẹ, itobọ ikhivọsẹ ni Ẹshinẹgba ọ rẹ ẹ khivọsẹ na wẹ.
\v 15 Awa ke kphẹmhi na Ẹshinẹgba shi isomhopfa oyọli ni unu ọa dobẹ ngme pfo.
\c 10
\s1 IPọlu ọ ri akanya aghiusomhi oyọli lo ẹgbọ esọ
\p 
\v 1 Eri a rọli shi khi eri mhia pfọ ini mhi la odalo oyẹ ẹ nu ẹ ngme, ama ini mhi aa nu ẹ migha, mhi nu ẹ ẹ ngme ingmemhi ni e ze. Mena, mhi lema ẹ a ri esọ shi mhẹ ekẹ, irari khi egbegbi iKirisiti luẹ ọ, ọna ipfọmhẹ ali ikuegbe-a ọ khi.
\v 2 Ẹgbọ eghuo ẹ liẹ khi eri mhia ngeli abi ẹgbọ na agbọ ẹẹ li. Irarighọ mhi ya ri uruli ni o zẹ nu wẹ ngme emini mhi nu wẹ ya ngme ini mhi bhale. A kpẹkpẹ a khi yẹsẹ mhẹ lighọ ngeli deba ẹ.
\v 3 Irari khi ini o ri riẹ khia khi elemhi agbọ anye la, anye ẹa ya khọli abi ẹgbọ na agbọ e liẹ khọli.
\v 4 Irari khi itsua okhọli eyanye, ẹa khi eni áá mẹ alo gbugbugbu, ama obọ oyi Ẹshinẹgba e te bhale. E mhọli itoto ni e rọ dobẹ ẹ guọghọ ekpabọ itoto oyi ọkphaghiẹ-a. Anye ẹ guọghọ ekhakọ-a,
\v 5 ali isamhi ighagha nya-a, ni ẹ khi ọzuodẹ, ni e ti egbewẹ nga a dọsẹ ilẹsẹ eyi Ẹshinẹgba. Anye ẹ mu isamhi ebe nya iko, anye rẹwẹ ẹ nyẹsẹ ukhomhi na iKirisiti.
\v 6 Anye mu egbe ni anye rọ ya na umha-suesọ nya osoli ini isuesọ-negbe oyẹẹ o gba se.
\p 
\v 7 Ọa khi abi emhi o li ọdagbe a liẹ bino ọli? Ọngẹ ẹ ọkhọghuo ọ la ọ ni ọọ lu egbọli onayi iKirisiti, ọ gbo sa ingme egbọli bino, irari khi ọyi iKirisiti anye li khi abi lọli ọli khi ọyi iKirisiti.
\v 8 Omama ọa ya mu mhẹ shi ọ, ini mhi riẹ tono obọ udu dọsẹ odẹ shi afu ni Ọnọmhuẹ ọ rọ na mhẹ, mhi rọ kpaghiẹ ẹ obọ, ni ọa khi oni a rọ yese ẹ.
\v 9 Mhi aa nono ni mhi li abinẹ khi eri mhi ri ebe ni mhi kẹkẹ ẹ nyamhise ẹ alo.
\v 10 Irari khi eri ẹgbọ eghuo ẹ liẹ khi, ebe eyi iPọlu e ma khọ dọsẹ, ama ini ọ nu awa la ana ọ pfọ-a, ingmemhi eyọli ẹa ke mu amẹ.
\v 11 A zẹ ẹgbọ eghọghọ lẹsẹ khi emini anye kẹkẹ shi ebe ini anye ẹa la aghọ, khi wẹwẹ anye gbolo ẹ riẹlẹ, ini anye bhale migha.
\p 
\v 12 Anye ẹa gbudu ya ri egbe anye khọkhọ eni ẹẹ titi egbe wẹ. Irari khi eni eri e ri egbewẹ mhẹsẹ egbewẹ, ni e ri egbewẹ khọkhọ egbewẹ, eyẹghẹ e khi.
\v 13 Ama anye ẹa ya tono obọ udu da odẹ, ama ashini Ẹshinẹgba ọ ri afu na anye ramhi anye ya tono obọ udu ramhi, ikhi akanya ni anye gbe ni o ramhi ẹ egbe.
\v 14 Anye ẹa ya titi egbe anye dọsẹ ashini anye kha titi egbe anye ramhi, irari khi anye e mema rue usomhi onete oyi iKirisiti bhale ghi ẹ, ni a ga lẹsẹ gboo.
\v 15 Anye ẹa ya ri ikanya ni ẹgbọẹse e gbe ke tono obọ udu abinẹ khi anye gbe wẹ. Ochoghọ eri anye ri udu shi khi irudunga oyẹ ẹ o ya ke nga shi ọ, ni anye gbo dobẹ gbe akanya ni e funẹ iteva oyẹ ẹ, abi Ẹshinẹgba ọ mhẹsẹ ọli ni anye.
\v 16 Isheghọ ni anye dobẹ tsabọ usomhi onete obini ekẹ oboese ni o kpẹ obọ na ẹ, ini anye khi tigbe ri ikanya ni a gbe oboese tono obọ udu.
\p 
\v 17 Ọni ọọ tono obọ udu, ọ ke ri emini Ọnọmhuẹ ọ riẹlẹ tono obọ udu.\f + \fr 10:17 \ft Li zẹ \fq iJere 9.24\f*
\v 18 Irari khi ọa khi ọni ọ ti egbe ọli nga ẹgbọ ẹẹ mie khi ọ ti, ama ọni Ọnọmhuẹ ọ mie, ọ khi oni a mie.
\c 11
\s1 IPọlu ali ighiusomhi na kẹẹ eyi ẹgbhọli
\p 
\v 1 Mhi lema ẹ a kpẹpkẹ a rọshẹka ri egbe mie ọyẹghẹ oyẹmhẹ ukuku ọ tsẹ!
\v 2 Ingme oyẹẹ o ma mu mhẹ egbe gba abi o li mu Ẹshinẹgba egbe, itobọ khi eri a li abi ọmueshi ni ọa mẹ ọmọse ghue, ni mhi she rọ nga na ọmọse ọghuo, ikhi iKirisiti.
\v 3 Ulishi ọọ mu mhẹ ini a ya yese ẹ udu-a ali khi a ya tsua inono na tselele ni a mhọli na iKirisiti pfia, ẹzẹzẹ abi ẹnyẹ ọ li ri ikpamhika eyọli di Iivu.\f + \fr 11:3 \ft Li zẹ \fq Igbae 3.1-5,13\f*
\v 4 Irari khi ini ọgbọẹse o bhale deba ẹ ya ri iJesu ọlese tse abọ ye ẹ, ni mhia rọ tsabọ yẹ ẹ ghue, okekhia khi ayẹmhẹ olese ni o khi ọda shi oni a kpẹ mie, a ke mie, okekhia usomhi onete olese ni o khi ọda shi oni a kpẹ mie a ke mie, eri a mema nyanya mie ọli.
\p 
\v 5 Mhi aa sa khi mhi kpọ dọsẹ ighiusomhi na kẹẹ ena aakemẹghue eyẹ ẹ ni e ghọ mu ẹ ẹloe eghọ.
\v 6 Ini o ri riẹ khia khi ungmemhi ọa lolo bie shi mhẹ unu, mhia khi ọni ọa lẹsẹ ebe. Anye she ri ona lo ẹ esọ gboo, odẹkhodẹ.
\p 
\v 7 Eri mhi ri ona lamhẹ ni mhi aa rọọ khi oki nga ẹ ike abi mhi rọ gue usomhi onete oyi Ẹshinẹgba ye ẹ? Ni mhi rọ ri egbe mhẹ tiemhie ekẹ ni mhi rọ rẹ ẹ fu?
\v 8 Igbaa nya eyi eni e mie iJesu iKirisiti suọ elese ee fali mhẹ ota abi mhi rọ la iteva oyẹ ẹ gbe akanya. Mhi mie wẹ rọ zuse na ẹ.
\v 9 Abi mhi rọ la ayẹ ẹ, mhi aa ri ingme ukpaghọ nasẹ ẹ, inyọghuo awa ni e rọte iMasidonia bhale e tsua emhikpa ni mhi i nono ghi mhẹ. Abi o kpẹ li ookhokho, ni mhi aa kpẹ ri itsua na e tsua ighọ o kie ya li odalo.\f + \fr 11:9 \ft Li zẹ \fq iFili 4.15-18\f*
\v 10 Ini igẹsikia oyi iKirisiti o da kie la mhẹ egbe ne, ọgbọkhọghuo ọa la ọ ni ọ dobẹ ya khu mhẹ mhi khi ke lina tono obọ udu elemhi ekẹ Akhaya.
\v 11 Ọa khi eri mhi aa nono ingme oyẹ, ini mhi ke da liẹ khi mhi aa nono ni mhi ri itsua na ẹ tsua. Ẹshinẹgba ọ lẹsẹ khi mhi nono ingme oyẹẹ.
\p 
\v 12 Mhi ya kie ke riẹlẹ emini mhi kie kpẹ riẹlẹ. Ẹghẹghẹ aghọ, eni ẹẹ nono ni wẹwẹ e liẹ khi ikanya eyẹwẹ ali eyanye khi abeghuo e li, ni mhi rọli khi wẹ unu-a.
\v 13 Emọse eghọghọ, ighiusomhi na kẹẹ eyi ẹgbhọli e khi, ni e ri ikanya ni ẹ gbe ẹ lono ẹgbhọli, ni ẹẹ li ẹgbọ ikokoalo, ni e ri egbe wẹ shi khi ighiusomhi na kẹẹ eyi iKirisiti wẹwẹ e khi.
\v 14 Ọa ke khi emini áá khọkhọ, irari khi eri ọkphaghiẹ ọ ri egbọli mele agẹni ọyi ákpá a li ẹgbọ ikokoalo.
\v 15 Irarighọ, ọa khi emhi ọshabọ ini ighiusomhi eyọli, ẹẹ li ikokoalo ri egbewẹ mele ighiusomhi ni e migha shi ipfuasẹ. Ikpukhokho, e ya mẹ isọ-ẹzọ oyẹwẹ mie.
\s1 Osoli ni iPọlu ọ mẹ na iKirisiti
\p 
\v 16 Mhi gbo ngme ọli, ọgbọkhọghuo ọ khi sa khi ọyẹghẹ mhi khi, ama ini u ke lighọ sa, kie lighọ mie mhẹ abi ọyẹghẹ, ni mhi mẹ emhi rọ ke neta ọmọse.
\v 17 Ama ọa khi emini Ọnọmhuẹ ọ kha liẹ mhi ngme mhia ngme memena. Eri mhi ga ngme abi ọyẹghẹ elemhi ingme ineta ọmọse ona.
\v 18 Aborọkhia khi ẹgbọẹse e ri emini e riẹlẹ ẹẹ neta ọmọse eghọ, mhi ya li lana lighọ.
\v 19 Ilẹsingme dọsẹ oyẹẹ o zẹ ni a rọ ri oghẹlẹ mie eyẹghẹ shi iteva oyẹẹ ena!
\v 20 Ẹgbọ ni ẹẹ mu ẹ ighumha, ni e ri ikpamhika do ẹ ighiatọ, ni e rẹẹ le emhi, ni e ri ukpẹloe e gbe ẹ e gbo pfi ima shi ẹ alo, wẹwẹ áá mie.
\v 21 Omama o khi, ni mhi rọ liẹ khi eri anye pfọ alo-a, ni anye a rọ lina ngeli deba ẹ.
\p O kha khia khi onete o khi ni eni ighiusomhi eyi ẹgbhọli eghọ e rọ ke neta ọmọse shi emhi afuẹ ni ẹẹ riẹlẹ deba ẹ, mhi ya li nu wẹ la ana neta ọmọse. Ama a rọli shi udu khi ọgbọ ni ọọ neta ọmọse shi angeli oghọghọ, khi ọọyẹghẹ ọ khi.
\p 
\v 22 Ghe khẹ, e khẹ khi Iburu wẹwẹ e khi, Iburu mhi li khi, ẹẹ khi iZirẹni wẹwẹ e khi, iZirẹni mhi li khi. Imimi Aburaamu ni e khi, lọli mhi li khi.
\v 23 Ighiusomhi eyi iKirisiti ẹẹ khi wẹwẹ e khi? Mhi la ana ya li ọyẹghẹ! Mhi ga ti dọsẹ wẹ e! Mhi ga gbe akanya dọsẹ wẹ. Mhi la owa ighumha itingme ni e bu nẹ, iti-ingmẹ ni a gbe mhẹ itali e bu dọsẹ eyẹwẹ. Iti-ingmẹ ni eghuli o kha gbe mhẹ e bu nẹ.\f + \fr 11:23 \ft Li zẹ \fq Ika 16.23\f*
\v 24 Agbhagbhamhi ishe ẹgbọ iJu e gbe mhẹ itali oghuo ọa la egbhuẹva.\f + \fr 11:24 \ft Li zẹ \fq iDẹut 25.3\f*
\v 25 Itesẹ ẹgbọ iRomu e gbe mhẹ ikpokpo, a tono mhẹ echẹ utoghuo. Itesẹ ọkọ okẹ oniẹmhi ni mhi lo e kuluẹ, ogbẹlẹghuo ali ẹliyọsẹ nya mhi la ukhomhi okẹ oniẹmhi, ni o tsua mhẹ gasẹ, ni mhia mẹ abi mhi li kia.\f + \fr 11:25 \ft Li zẹ \fq Ika 16.22; 14.19\f*
\v 26 Iti ingmi-ingmẹ mhi ye asha, ni mhi kha ri egbe na okẹ oniẹmhi ali ighiatọ gbe-a, mhi gbo la okhẹna oyi ẹgbọ iJu eyẹmhẹ, ali iJẹta. Mhi li la egbegbi okhẹna elemhi ifui apfẹ, mhi la okhẹna ọdagbe ifufu, mhi la okhẹna ukhomhi okẹ oniẹmhi, mhi gbo la okhẹna oyi ẹgbọ eghuo, ni e li abi eni e mie Ọnọmhuẹ suọ.\f + \fr 11:26 \ft Li zẹ \fq Ika 9.23; 14.15\f*
\v 27 Ẹghẹghẹ kpa mhi rọ la irọshẹka ali akanya agbeghua, mhia mẹ olesẹ lesẹ ẹlẹ-iyọsẹ eni e bu, okiamhi ali okiamẹ o gbe mhẹ. Eminale eyẹmhẹ e pfo mhẹ isheghuo, isheghuo ulili o gbe mhẹ, mhi aa mẹ itsua sọ.
\v 28 Ini a ri obọ ri eghọ shi ekẹ, ogbẹlẹkpa usamhi ni mhi sa shi ingme oyi igbaa nya eyi eni e mie iJesu iKirisiti suọ o rọ nasẹ mhẹ.
\v 29 Ọghuo o famhi lọsẹ ni ọa li pfi ọlọsẹmhẹ na mhẹ? Abi khi ọgbọkhọghuo ọ lamhẹ olamhẹ ni ọa ri egbe lala mhẹ?
\p 
\v 30 Ini mhi riẹ neta ọmọse, emini e ri ọlọsẹmhẹ oyẹmhẹ ya khasẹ mhi rọ ya neta ọmọse.
\v 31 Ẹshinẹgba ita Ọnọmhuẹ iJesu ọ lẹsẹ khi ọa khi ẹgbhọli mhia lo. Ikhivọsẹ khi eva oyọli agbọagbọ
\v 32 Abi mhi rọ la ẹoli iDamasikọsi, eri igọvunọ ni o gbe akanya deba oghie Arẹtasi ọ ri idogẹli kpẹ khẹ mhẹ odẹ unuẹkpẹ ni a tẹ lo oni ẹoli, ni e ba gba mhẹ mu.
\v 33 Ama eri ọgbọ rue mhẹ pfilo ugi rọte okele ni o la ugbe ni a khi gasẹ oni ẹoli bẹna tiemhi, ni mhi rọ mẹ asha na vu.\f + \fr 11:33 \ft Li zẹ \fq Ika 9.23-25\f*
\c 12
\s1 Irọkhasẹ ni iPọlu ọ mẹ
\p 
\v 1 Mhi ya kie ke neta ọmọse, ama, mhi lẹsẹ khi ọa mhọli eleli ni o rọ ọ bhale. Irarighọ ingme imekẹ ali irọkhasẹ ni Ọnọmhuẹ ọ rọ na mhẹ mhi ke ya ke ngme nga memena.
\v 2 Mhi lẹsẹ ọmọse ọghuo ni ọ la elemhi iKirisiti ni a rue je idane agbhagbhamhi onuzi-esẹ, oonokpe-igbẹne. Ini elemhi idiegbe ọ la o, ini ọa khi elemhi idiegbe o, mhia lẹsẹ. Ama Ẹshinẹgba ọ lẹsẹ.
\v 3 Abi mhi ngme, mhiẹ khi Ẹshinẹgba tsẹ ọ lẹsẹ ini elemhi idiegbe ọ la, ini ọa la elemhi idiegbe.
\v 4 Eri a rue ọli ekẹ-a zai, ya nga Apfẹ oyi Ẹshinẹgba na iloghie. Ọ suọ emini ẹa zẹ ya guele, ni aa ya lama shi a gbudu ngme unu le.
\v 5 Ọni ọmọse oghọ mhi rọ ya neta ọmọse. Ama mhia ya ri egbemhẹ neta ọmọse, sẹẹ ni umha mhuẹ ekpabọ oyẹmhẹ.
\v 6 Ini mhi ri riẹ neta ọmọse, mhia ya riẹlẹ ingme ọyẹghẹ, itobọ khi igẹsikia mhia ngme tsẹ. Mhi ya rọshẹka ini mhi khi ngme da odẹ. Ẹghẹghẹ aghọ ọngẹẹ ọkhọghuo ọa ya timhẹ nga dọsẹ abi a kha timhẹ nga ramhi, rọte emini a mẹ khi mhi riẹlẹ ali emini a suọ khi mhi ngme.
\p 
\v 7 Eri a ri emini o li abi ugba ni o ya ke nasẹ mhẹ shi mhẹ egbe ni o khi aghiusomhi ọyi ọkphaghiẹ, ini mhi khi vuse ike dọsẹ shi irọkhasẹ ebubu ni mhi mẹ.
\v 8 Itesẹ mhi lema Ẹshinẹgba o mie mhẹ oni emhi anasẹmhẹ ona pfi-a.
\v 9 Ama emini ọ rọ sọ mhẹ ọ khi, “Ekpabọ eyẹmhẹ o she bu ẹ, irari khi ini o lọsẹ, lọli ekpabọ eyẹmhẹ e rọ mẹ asha ri egbe ẹ khasẹ.” Irarighọ mhi rọ ri oghẹlẹ ri ọlọsẹmhẹ oyẹmhẹ ya neta ọmọse, ni ekpabọ eyi iKirisiti e mẹ asha rẹmhẹ gbe akanya.
\v 10 Ini mhi mhuẹ ọlọsẹmhẹ, ali ni a rọ tsue mhẹ, ali ni mhi rọ la umhamẹ ali ni a rọ mu okhọli vule shi mhẹ ọ, ali ni mhi rọ mhọli iyese-udu-a, o kha da khi itobọ oyi iKirisiti, eri o ri egbe ẹ mu mhẹ. Irari khi ini o lọsẹ mhẹ, lọli mhi rọ mhọli itoto.
\s1 Ingme oyi ẹgbọ iKọriti o mu iPọlu egbe
\p 
\v 11 Eri mhi chi ọọyẹghẹ-a, ama ẹẹ a yẹsẹ mhẹ ẹ chi ọli-a. Ẹẹ a kha ke titi mhẹ. Ini mhi aa ririẹ khi emhi khọghuo, mhia mhuẹ emhikhọghuo ni mhi te kpọ dọsẹ eni a lui, “Ighiusomhi na kẹẹ ena aakemẹghue.”
\v 12 Elemhi iregbemie osoli, mhi rọ la iteva oyẹẹ gbe riẹlẹ ọlẹlẹ ọnyaloa ali ọshabọ ni o rọkhasẹ khi aghiusomhi na kẹẹ ọyi iKirisiti mhi khi.
\v 13 Eri ikhivọsẹ ni igbaa nya eyi eni e mie iJesu iKirisiti suọ elese e mẹ mie o de ẹ unu-a? Abi mhi aa li ri ingme ikpaghiobọ ukpaghọ nasẹ ẹ lọ? A kpẹkpẹ, a rọ topfa mhẹ shi ọ.
\p 
\v 14 Utonuzesẹ na ni mhi rọ mu egbe ni mhi rọ bhale ya bino ẹ. Mhi aa ya mhila ẹ emhi khọghuo. Ẹẹ oyẹẹ mhia nono, ọa khi ukpaghọ oyẹẹ. Ọa kpẹ khi eniyẹ ẹ ri emhi na eni e bia wẹ ẹ le, ama eni e bia eniyẹ e ri emhi na wẹ ẹ le.
\v 15 Irarighọ, mhi rọ ya ri oghẹlẹ ri ukpaghọ ni mhi mhọli nya ali mhẹmhẹ nya na ẹ, rọ kpaghiẹ ẹ obọ. Inono onikeke a ya mhọli deba mhẹ ini mhi mhọli inono oniẹmhi na ẹ?
\p 
\v 16 A lama shi ọ khi mhi aa khi itsua na ẹ ni aa tsua. Ama ẹgbọ eghuo e ya liẹ khi ikpamhika mhi rọ ri ẹgbhọli di ẹ mu.
\v 17 Eri mhi ri ẹgbọ ni mhi ghie ghi ẹ mu ẹ ma ekẹ?
\v 18 Eri mhi lema iTatọsi o ke lẹ, mhiẹ inyọghuo awa ọnọkpọle ọ kphase ọli. Eri a ya liẹ khi eri iTatọsi ọ mu ẹ ma ekẹ? Ọa fẹ lighọ. Abi khi aa lẹsẹ khi usamhi oghuo mhẹmhẹ ali lọli anye mhọli shi udu ni anye rọ riẹlẹ emini mhẹmhẹ ali lọli anye ga riẹlẹ?
\p 
\v 19 Otsẹ eri a dabi khi eri anye kie kpẹ rọshẹka ke khẹ egbe anye shi ekẹ odalo oyẹ ẹ. Ọa khi ighọ. Ama abi iKirisiti ọ nono ni anye li ngme, anye li odalo oyi Ẹshinẹgba. Emọle, eri anye riẹlẹ emini anye riẹlẹ nya rọ kpaghiẹ ẹ obọ.
\v 20 Egbe limhẹ khi ini mhi ramhi aghọ khi mhia ya bhale ya mẹ ẹ shi abi mhia nono ni a li, ali khi aa ya mẹ mhẹ abi a nono ni mhi li. Ulishi ọọ mu mhẹ khi mhi ya bhale ya ẹ shi uwola ali ubọgbọ, ali udu ni ọọ to, ali ukphẹ, ali ikemhi ikui-iku, ali iyese egbe eva-a, ali ineta, ali itipfuabọ-nga, ali ozughu iteva oyẹẹ.
\v 21 Egbe limhẹ khi ini mhi ke bhale, khi Ẹshinẹgba ọ ya ri omama mu mhẹ odalo oyẹẹ. Mhi ya viẹ na ebubu ẹ ni ẹa kie rọte agbọ olamhẹ oyẹwẹ mupfi lasele. Ni a kie la angeli efiala, ikhi usamhi irumheba, ali olamhẹ ighuẹ imumu.
\c 13
\s1 Itse-agua ali otsẹ enekpukhokho
\p 
\v 1 Utonuzesẹ na ni mhia bhale ya bino ẹ. Abi Ebe-no-pfuasẹ o ngme ni ọọ, “Ọtsẹlẹ eva, okekhi esẹ, a rọ ọ mu ma ingme, ni a rọ sọ ẹzọ.”\f + \fr 13:1 \ft Li zẹ \fq iDẹut 17.6; 19.15\f*
\v 2 Mhi kpẹ tse agua yẹ ẹ, ẹẹ ni a kpẹ lamhẹ olamhẹ, ali ẹgbọẹse eni e kpọle nya. Mhi kpẹ ngme ọli ibhale onuzi-eva oyẹmhẹ. Memena, mhi gbo ngme ọli abi mhi la oboese, mhi tse agua khi ini mhi gbo bhale khi mhi aa ya zẹ wẹ obọ khi mhi aa na wẹ osoli.
\v 3 Onana o ya rọkhasẹ ẹ khi iKirisiti mhi ngme ẹ na. Ini ọ sẹsẹ ẹ ingme se, a rọ ya lẹsẹ khi ọ mhọli ekpabọ iteva oyẹẹ.
\v 4 Ini o ri riẹ khia khi ọa mhuẹ itoto abi a rọ tali ma apfida gbe-a, ekpabọ oyi Ẹshinẹgba ọ rọ a la agbọ. Eri awa aa li mhuẹ itoto abi iKirisiti. Ama a ya mẹ ọli khi anye ya ri ekpabọ oyi Ẹshinẹgba la agbọ, ẹzẹzẹ abi iJesu ọ li, ni anye rọ ga ẹ.
\p 
\v 5 A mhẹsẹ egbe ẹ bie bino ni a mẹ ini a kie la elemhi irudunga oyẹ ẹ. Ini a mhẹsẹ egbe ẹ bino ni a rọ mẹ khi iJesu iKirisiti ọa la agbọ oyẹẹ, a lẹsẹ khi a she de oni imhẹsẹbino.
\v 6 Mhi lẹsẹ khi a ya mẹ ọli mẹ khi anye ẹa de oni imhẹsẹbino.
\v 7 Anye lema Ẹshinẹgba, a khi riẹlẹ dọ-a. Ona ọa khi ni anye rọ rọkhasẹ khi anye she mẹ emini anye ẹ nono mu mhuẹ, ama ni o rẹ ẹ ke riẹlẹ emini e gbe akanya ini anye riẹ li abi eni de.
\v 8 Irari khi anye ẹa ya riẹlẹ emini o mu okhọli vule shi igẹsikia ọ, ama emini o ya mu igẹsikia mhuẹ anye ya riẹlẹ.
\v 9 Egbe ma mu anye, ini o lọsẹ anye ni ẹẹ a rọ mhọli itoto. Ighọ anye gbo liẹ sọ iromhi Ẹshinẹgba ọ rẹ ẹ ke ngeli shi ẹghẹghẹ, abi ọ nono ni a li ke ngeli.
\v 10 Lọli o zẹ khi mhia kẹkẹ ebe ona abi mhia rọ nu ẹ la oobọ ena. Ighọ lọ, ini mhi khi rọli ze mu ẹ, ini mhi bhale deba ẹ. Irari khi eri mhia nono ni mhi ri afu ni Ọnọmhuẹ ọ rọ na mhẹ gbe akanya, ni mhi rọ kpaghiẹ ẹ obọ, ni ọa khi ni mhi rọ bighi ẹ de.
\p 
\v 11 Ni mhi rọ gbe ọli ukhomhi inyọghuo-mhẹ, Okhila! A mu udu oyẹ ẹ pfi, a suọ olema oyẹmhẹ, a lama shi egbe ẹ ọ, a ri opfọmhẹ nu egbe ke la. Ẹghẹghẹ aghọ ni Ẹshinẹgba na inono ali opfọmhẹ ọ nu ẹ la.
\p 
\v 12 A ke tse egbe egbegbi otsẹ, a ghẹlẹ mu egbe.
\v 13 Ẹgbọ eyi Ẹshinẹgba nya ẹẹ tsẹ ẹ.
\p 
\v 14 Okhale oyi iJesu iKirisiti Ọnọmhuẹ, ali inono oyi Ẹshinẹgba, ali iregbemu onayi Ayẹmhẹ-nọ-pfuasẹ, e ka nu ẹẹ nya la.
