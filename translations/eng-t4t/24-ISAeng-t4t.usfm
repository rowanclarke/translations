\p
\v 1 \w One|strong="H8141"\w* \w year|strong="H8141"\w* \w King|strong="H4428"\w* \w Sargon|strong="H5623"\w* \w of|strong="H4428"\w* Assyria \w sent|strong="H7971"\w* \w the|strong="H7971"\w* chief \w commander|strong="H8661"\w* \w of|strong="H4428"\w* \w his|strong="H7971"\w* army \add to take his soldiers\add* \w to|strong="H7971"\w* \w capture|strong="H3920"\w* Ashdod \add city in Philistia\add*.  
\v 2 \w At|strong="H5921"\w* \w that|strong="H1931"\w* \w time|strong="H6256"\w*, \w Yahweh|strong="H3068"\w* \w told|strong="H1696"\w* \w me|strong="H5921"\w*, “\w Take|strong="H1980"\w* \w off|strong="H5921"\w* \w the|strong="H5921"\w* rough \w sackcloth|strong="H8242"\w* \w that|strong="H1931"\w* \w you|strong="H5921"\w* \w have|strong="H3068"\w* \w been|strong="H3068"\w* wearing \w and|strong="H1121"\w* \w take|strong="H1980"\w* \w off|strong="H5921"\w* \w your|strong="H3068"\w* \w sandals|strong="H5275"\w*.” \add So\add* \w I|strong="H5921"\w* \w did|strong="H6213"\w* \w what|strong="H6213"\w* \w he|strong="H1931"\w* \w told|strong="H1696"\w* \w me|strong="H5921"\w* \w to|strong="H1696"\w* \w do|strong="H6213"\w*, \w and|strong="H1121"\w* \add then\add* \w I|strong="H5921"\w* \w walked|strong="H1980"\w* \w around|strong="H5921"\w* \w naked|strong="H6174"\w* \w and|strong="H1121"\w* \w barefoot|strong="H3182"\w* \add for three years\add*.   
