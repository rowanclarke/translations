\v 12 Te \w dongah|strong="G3767"\w*, \wj “ \+w Tongpa|strong="G0444"\+w* \+w hlangtang|strong="G2104"\+w* \+w pakhat|strong="G5100"\+w* tah, \+w a|strong="G1438"\+w* \+w ram|strong="G0932"\+w* \+w loh|strong="G2983"\+w* ham \+w kho|strong="G5561"\+w* \+w hla|strong="G3117"\+w* \+w la|strong="G1519"\+w* \+w cet|strong="G4198"\+w* \+w tih|strong="G2532"\+w* ha \+w voei|strong="G5290"\+w* hamla cai\wj*.  
