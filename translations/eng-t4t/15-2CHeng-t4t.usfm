\v 3 \w For|strong="H3117"\w* \w many|strong="H7227"\w* \w years|strong="H3117"\w* \w the|strong="H3117"\w* Israeli \w people|strong="H3808"\w* \w did|strong="H3478"\w* \w not|strong="H3808"\w* know \w the|strong="H3117"\w* true \w God|strong="H3808"\w*, \w and|strong="H3478"\w* \w they|strong="H3117"\w* \w did|strong="H3478"\w* \w not|strong="H3808"\w* \w have|strong="H3478"\w* \w priests|strong="H3548"\w* \w or|strong="H3808"\w* \w God|strong="H3808"\w*’s \w laws|strong="H8451"\w*.  
\v 4 \w But|strong="H7725"\w* \w when|strong="H7725"\w* \w they|strong="H3068"\w* experienced \w trouble|strong="H6862"\w*, \w they|strong="H3068"\w* \w turned|strong="H7725"\w* \w to|strong="H7725"\w* \w Yahweh|strong="H3068"\w* \w our|strong="H3068"\w* \w God|strong="H3068"\w*, \w and|strong="H3478"\w* \w requested|strong="H1245"\w* \w him|strong="H5921"\w* \w to|strong="H7725"\w* help \w them|strong="H5921"\w*. \w And|strong="H3478"\w* \w he|strong="H3068"\w* helped \w them|strong="H5921"\w*.  
\v 5 \w At|strong="H3427"\w* \w that|strong="H3588"\w* \w time|strong="H3318"\w*, \w people|strong="H3427"\w* \w were|strong="H1992"\w* \w not|strong="H3588"\w* \w safe|strong="H7965"\w* \w when|strong="H3588"\w* \w they|strong="H1992"\w* traveled, \w because|strong="H3588"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w people|strong="H3427"\w* \w who|strong="H3605"\w* \w lived|strong="H3427"\w* \w in|strong="H3427"\w* \w the|strong="H3605"\w* nearby countries \w were|strong="H1992"\w* experiencing \w many|strong="H7227"\w* difficulties.  
\v 6 \w The|strong="H3605"\w* \w people|strong="H1471"\w* \w of|strong="H5892"\w* various \w nations|strong="H1471"\w* \w were|strong="H1471"\w* thoroughly \w defeated|strong="H3807"\w* \w by|strong="H5892"\w* \add armies of\add* \w other|strong="H3605"\w* \w nations|strong="H1471"\w*, \w and|strong="H5892"\w* \w people|strong="H1471"\w* \w in|strong="H5892"\w* \w some|strong="H3605"\w* \w cities|strong="H5892"\w* \w were|strong="H1471"\w* \w crushed|strong="H3807"\w* \w by|strong="H5892"\w* \add armies from\add* \w other|strong="H3605"\w* \w cities|strong="H5892"\w*, \w because|strong="H3588"\w* God \w was|strong="H5892"\w* allowing \w them|strong="H2000"\w* \w to|strong="H1471"\w* experience many difficulties.  
\v 7 \w But|strong="H3588"\w* \w you|strong="H3588"\w* people, \w you|strong="H3588"\w* must \w be|strong="H3426"\w* \w strong|strong="H2388"\w* \w and|strong="H3027"\w* \w do|strong="H3027"\w* \w not|strong="H3588"\w* \w become|strong="H7503"\w* \w discouraged|strong="H7503"\w*, \w because|strong="H3588"\w* \add God\add* \w will|strong="H3027"\w* \w reward|strong="H7939"\w* \w you|strong="H3588"\w* \w for|strong="H3588"\w* \w what|strong="H3588"\w* \w you|strong="H3588"\w* \w do|strong="H3027"\w* \add to please him.”\add*   
