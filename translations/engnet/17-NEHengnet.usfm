\p 
\v 9 \w Then|strong="H6213"\w* \w I|strong="H1697"\w* \w said|strong="H1697"\w*, “\w The|strong="H6213"\w* \w thing|strong="H1697"\w* \w that|strong="H1471"\w* \w you|strong="H6213"\w* \w are|strong="H1471"\w* \w doing|strong="H6213"\w* \w is|strong="H1697"\w* wrong! \w Should|strong="H6213"\w* \w you|strong="H6213"\w* \w not|strong="H3808"\w* \w conduct|strong="H1697"\w* yourselves \w in|strong="H6213"\w* \w the|strong="H6213"\w* \w fear|strong="H3374"\w* \w of|strong="H1697"\w* \w our|strong="H6213"\w* \w God|strong="H3808"\w* \w in|strong="H6213"\w* \w order|strong="H1697"\w* \w to|strong="H3212"\w* avoid \w the|strong="H6213"\w* \w reproach|strong="H2781"\w* \w of|strong="H1697"\w* \w the|strong="H6213"\w* \w Gentiles|strong="H1471"\w* \w who|strong="H2896"\w* \w are|strong="H1471"\w* \w our|strong="H6213"\w* enemies?
\v 10 \w Even|strong="H1571"\w* \w I|strong="H2088"\w* \w and|strong="H3701"\w* \w my|strong="H5800"\w* relatives \w and|strong="H3701"\w* \w my|strong="H5800"\w* associates \w are|strong="H1571"\w* \w lending|strong="H5383"\w* \w them|strong="H5800"\w* \w money|strong="H3701"\w* \w and|strong="H3701"\w* \w grain|strong="H1715"\w*. \w But|strong="H1571"\w* \w let|strong="H4994"\w* \w us|strong="H4994"\w* \w abandon|strong="H5800"\w* \w this|strong="H2088"\w* practice \w of|strong="H5288"\w* seizing \w collateral|strong="H4855"\w*!
\v 11 \w This|strong="H7725"\w* very \w day|strong="H3117"\w* \w return|strong="H7725"\w* \w to|strong="H7725"\w* \w them|strong="H7725"\w* \w their|strong="H7725"\w* \w fields|strong="H7704"\w*, \w their|strong="H7725"\w* \w vineyards|strong="H3754"\w*, \w their|strong="H7725"\w* \w olive|strong="H2132"\w* \w trees|strong="H2132"\w*, \w and|strong="H3967"\w* \w their|strong="H7725"\w* \w houses|strong="H1004"\w*, along \w with|strong="H1004"\w* \w the|strong="H3117"\w* interest \w that|strong="H3117"\w* \w you|strong="H3117"\w* \w are|strong="H3117"\w* \w exacting|strong="H5383"\w* \w from|strong="H7725"\w* \w them|strong="H7725"\w* \w on|strong="H3117"\w* \w the|strong="H3117"\w* \w money|strong="H3701"\w*, \w the|strong="H3117"\w* \w grain|strong="H1715"\w*, \w the|strong="H3117"\w* \w new|strong="H8492"\w* \w wine|strong="H8492"\w*, \w and|strong="H3967"\w* \w the|strong="H3117"\w* \w olive|strong="H2132"\w* \w oil|strong="H3323"\w*.”
\p 
\v 12 \w They|strong="H1992"\w* replied, “\w We|strong="H6213"\w* \w will|strong="H1697"\w* \w return|strong="H7725"\w* \w these|strong="H2088"\w* \w things|strong="H1697"\w*, \w and|strong="H7725"\w* \w we|strong="H3068"\w* \w will|strong="H1697"\w* \w no|strong="H3808"\w* \w longer|strong="H3808"\w* \w demand|strong="H1245"\w* \w anything|strong="H1697"\w* \w from|strong="H7725"\w* \w them|strong="H1992"\w*. \w We|strong="H6213"\w* \w will|strong="H1697"\w* \w do|strong="H6213"\w* \w just|strong="H1697"\w* \w as|strong="H1697"\w* \w you|strong="H7725"\w* \w say|strong="H7725"\w*.” \w Then|strong="H2088"\w* \w I|strong="H1697"\w* \w called|strong="H7121"\w* \w the|strong="H6213"\w* \w priests|strong="H3548"\w* \w and|strong="H7725"\w* \w made|strong="H6213"\w* \w the|strong="H6213"\w* wealthy \w and|strong="H7725"\w* \w the|strong="H6213"\w* officials \w swear|strong="H7650"\w* \w to|strong="H7725"\w* \w do|strong="H6213"\w* \w what|strong="H1697"\w* \w had|strong="H3548"\w* \w been|strong="H3808"\w* \w promised|strong="H7650"\w*.
