\p \w Then|strong="H1768"\w* \w Shadrach|strong="H7715"\w*, \w Meshach|strong="H4336"\w*, \w and|strong="H6032"\w* Abednego \w emerged|strong="H5312"\w* \w from|strong="H4481"\w* \w the|strong="H4481"\w* \w fire|strong="H5135"\w*.
\v 27 Once \w the|strong="H1768"\w* satraps, \w prefects|strong="H5460"\w*, \w governors|strong="H6347"\w*, \w and|strong="H4430"\w* ministers \w of|strong="H4430"\w* \w the|strong="H1768"\w* \w king|strong="H4430"\w* \w had|strong="H4430"\w* \w gathered|strong="H3673"\w* \w around|strong="H3673"\w*, \w they|strong="H1768"\w* \w saw|strong="H2370"\w* \w that|strong="H1768"\w* \w those|strong="H1768"\w* \w men|strong="H1400"\w* \w were|strong="H1400"\w* physically \w unharmed|strong="H7981"\w* by \w the|strong="H1768"\w* \w fire|strong="H5135"\w*. \w The|strong="H1768"\w* \w hair|strong="H8177"\w* \w of|strong="H4430"\w* their \w heads|strong="H7217"\w* \w was|strong="H1655"\w* \w not|strong="H3809"\w* \w singed|strong="H2761"\w*, \w nor|strong="H3809"\w* \w were|strong="H1400"\w* their \w trousers|strong="H5622"\w* \w damaged|strong="H8133"\w*. \w Not|strong="H3809"\w* \w even|strong="H1768"\w* \w the|strong="H1768"\w* \w smell|strong="H7382"\w* \w of|strong="H4430"\w* \w fire|strong="H5135"\w* \w was|strong="H1655"\w* \w to|strong="H4430"\w* \w be|strong="H3809"\w* found \w on|strong="H7981"\w* them!
\p 
\v 28 \w Nebuchadnezzar|strong="H5020"\w* \w exclaimed|strong="H6032"\w*, “\w Praised|strong="H1289"\w* \w be|strong="H3809"\w* \w the|strong="H3606"\w* God \w of|strong="H4430"\w* \w Shadrach|strong="H7715"\w*, \w Meshach|strong="H4336"\w*, \w and|strong="H6032"\w* Abednego, \w who|strong="H1768"\w* \w has|strong="H1768"\w* \w sent|strong="H7972"\w* forth \w his|strong="H5922"\w* \w angel|strong="H4398"\w* \w and|strong="H6032"\w* \w has|strong="H1768"\w* rescued \w his|strong="H5922"\w* \w servants|strong="H5649"\w* \w who|strong="H1768"\w* \w trusted|strong="H7365"\w* \w in|strong="H5922"\w* \w him|strong="H5922"\w*, ignoring \w the|strong="H3606"\w* edict \w of|strong="H4430"\w* \w the|strong="H3606"\w* \w king|strong="H4430"\w* \w and|strong="H6032"\w* giving up \w their|strong="H3606"\w* \w bodies|strong="H1655"\w* rather \w than|strong="H1768"\w* \w serve|strong="H6399"\w* \w or|strong="H3809"\w* pay \w homage|strong="H5457"\w* \w to|strong="H5922"\w* \w any|strong="H3606"\w* god \w other|strong="H3861"\w* \w than|strong="H1768"\w* \w their|strong="H3606"\w* God!
\v 29 \w I|strong="H4481"\w* \w hereby|strong="H4481"\w* \w decree|strong="H2942"\w* \w that|strong="H1768"\w* \w any|strong="H3606"\w* \w people|strong="H5972"\w*, nation, \w or|strong="H3809"\w* \w language|strong="H3961"\w* group \w that|strong="H1768"\w* \w blasphemes|strong="H7955"\w* \w the|strong="H3606"\w* god \w of|strong="H4481"\w* \w Shadrach|strong="H7715"\w*, \w Meshach|strong="H4336"\w*, \w or|strong="H3809"\w* Abednego \w will|strong="H1768"\w* \w be|strong="H3809"\w* dismembered \w and|strong="H4336"\w* \w his|strong="H5922"\w* home \w reduced|strong="H7739"\w* \w to|strong="H5922"\w* rubble! \w For|strong="H5922"\w* \w there|strong="H1768"\w* exists \w no|strong="H3809"\w* other god \w who|strong="H1768"\w* \w can|strong="H3202"\w* \w deliver|strong="H5338"\w* \w in|strong="H5922"\w* \w this|strong="H1836"\w* way.”
\v 30 \w Then|strong="H4430"\w* \w Nebuchadnezzar|strong="H4430"\w* \w promoted|strong="H6744"\w* \w Shadrach|strong="H7715"\w*, \w Meshach|strong="H4336"\w*, \w and|strong="H4336"\w* Abednego \w in|strong="H4430"\w* \w the|strong="H4430"\w* \w province|strong="H4083"\w* \w of|strong="H4430"\w* Babylon.
\c 4
\p 
\v 1 “King \w Nebuchadnezzar|strong="H5020"\w*, \w to|strong="H1934"\w* all peoples, nations, \w and|strong="H1005"\w* language groups \w that|strong="H1965"\w* live \w in|strong="H5020"\w* all \w the|strong="H5020"\w* land: Peace \w and|strong="H1005"\w* prosperity!
\v 2 I am delighted \w to|strong="H5922"\w* tell \w you|strong="H5922"\w* \w about|strong="H5922"\w* \w the|strong="H5922"\w* signs \w and|strong="H1763"\w* wonders \w that|strong="H5922"\w* \w the|strong="H5922"\w* most high God has done \w for|strong="H5922"\w* \w me|strong="H5922"\w*.
\q1 
\v 3 “How great \w are|strong="H1768"\w* \w his|strong="H4481"\w* signs!
\q1 How mighty \w are|strong="H1768"\w* \w his|strong="H4481"\w* wonders!
\q1 \w His|strong="H4481"\w* kingdom \w will|strong="H1768"\w* last forever,
\q1 \w and|strong="H2493"\w* \w his|strong="H4481"\w* authority continues \w from|strong="H4481"\w* one generation \w to|strong="H2942"\w* \w the|strong="H3606"\w* next.”
\s1 Nebuchadnezzar Dreams of a Tree Chopped Down
\p 
\v 4 I, Nebuchadnezzar, was relaxing \w in|strong="H5954"\w* my home, living luxuriously \w in|strong="H5954"\w* my palace.
\v 5 \w I|strong="H1768"\w* saw \w a|strong="H3068"\w* \w dream|strong="H2493"\w* \w that|strong="H1768"\w* frightened \w me|strong="H6925"\w* badly. \w The|strong="H6925"\w* things \w I|strong="H1768"\w* imagined \w while|strong="H5705"\w* lying \w on|strong="H5705"\w* \w my|strong="H1768"\w* bed – these visions \w of|strong="H1768"\w* \w my|strong="H1768"\w* \w mind|strong="H7308"\w* – \w were|strong="H1768"\w* terrifying \w me|strong="H6925"\w*.
\v 6 \w So|strong="H1768"\w* \w I|strong="H1768"\w* issued \w an|strong="H3606"\w* order \w for|strong="H1768"\w* \w all|strong="H3606"\w* \w the|strong="H3606"\w* wise men \w of|strong="H1768"\w* Babylon \w to|strong="H3046"\w* \w be|strong="H3809"\w* brought before me \w so|strong="H1768"\w* \w that|strong="H1768"\w* \w they|strong="H1768"\w* \w could|strong="H1768"\w* \w make|strong="H3046"\w* \w known|strong="H3046"\w* \w to|strong="H3046"\w* me \w the|strong="H3606"\w* \w interpretation|strong="H6591"\w* \w of|strong="H1768"\w* \w the|strong="H3606"\w* \w dream|strong="H2493"\w*.
\v 7 When \w the|strong="H5922"\w* magicians, astrologers, wise men, \w and|strong="H1934"\w* diviners entered, I recounted \w the|strong="H5922"\w* dream \w for|strong="H5922"\w* \w them|strong="H5922"\w*. But they \w were|strong="H1934"\w* unable \w to|strong="H5922"\w* make \w known|strong="H1934"\w* its interpretation \w to|strong="H5922"\w* \w me|strong="H5922"\w*.
\v 8 Later Daniel entered (\w whose|strong="H3606"\w* name \w is|strong="H3606"\w* Belteshazzar after \w the|strong="H3606"\w* name \w of|strong="H5491"\w* my god, \w and|strong="H7236"\w* \w in|strong="H8631"\w* whom there \w is|strong="H3606"\w* \w a|strong="H3068"\w* spirit \w of|strong="H5491"\w* \w the|strong="H3606"\w* holy gods). I recounted \w the|strong="H3606"\w* dream for him \w as|strong="H3606"\w* well,
\v 9 saying, “Belteshazzar, chief \w of|strong="H4481"\w* \w the|strong="H3606"\w* magicians, \w in|strong="H1753"\w* \w whom|strong="H4481"\w* \w I|strong="H4481"\w* know there \w to|strong="H4481"\w* be \w a|strong="H3068"\w* spirit \w of|strong="H4481"\w* \w the|strong="H3606"\w* holy gods \w and|strong="H8065"\w* \w whom|strong="H4481"\w* \w no|strong="H3606"\w* mystery baffles, consider \w my|strong="H4481"\w* dream \w that|strong="H3606"\w* \w I|strong="H4481"\w* saw \w and|strong="H8065"\w* \w set|strong="H8065"\w* forth \w its|strong="H4481"\w* interpretation!
\v 10 Here \w are|strong="H5922"\w* \w the|strong="H5922"\w* \w visions|strong="H2376"\w* \w of|strong="H4481"\w* \w my|strong="H5922"\w* \w mind|strong="H7217"\w* while \w I|strong="H4481"\w* \w was|strong="H1934"\w* \w on|strong="H5922"\w* \w my|strong="H5922"\w* \w bed|strong="H4903"\w*.
\q1 While \w I|strong="H4481"\w* \w was|strong="H1934"\w* \w watching|strong="H2370"\w*,
\q1 there \w was|strong="H1934"\w* \w a|strong="H3068"\w* tree \w in|strong="H5922"\w* \w the|strong="H5922"\w* middle \w of|strong="H4481"\w* \w the|strong="H5922"\w* land.
\q1 \w It|strong="H1934"\w* \w was|strong="H1934"\w* enormously tall.
\q1 
\v 11 \w The|strong="H4481"\w* tree grew large \w and|strong="H3652"\w* strong.
\q1 \w Its|strong="H7113"\w* top reached far into \w the|strong="H4481"\w* sky;
\q1 \w it|strong="H4481"\w* could be seen \w from|strong="H4481"\w* \w the|strong="H4481"\w* borders \w of|strong="H4481"\w* all \w the|strong="H4481"\w* land.
\q1 
\v 12 Its foliage \w was|strong="H2423"\w* attractive \w and|strong="H6523"\w* its fruit plentiful;
\q1 on it \w there|strong="H1297"\w* \w was|strong="H2423"\w* food enough \w for|strong="H1768"\w* all.
\q1 Under it \w the|strong="H1768"\w* \w wild|strong="H1251"\w* \w animals|strong="H2423"\w* used \w to|strong="H5974"\w* seek shade,
\q1 \w and|strong="H6523"\w* \w in|strong="H1768"\w* its branches \w the|strong="H1768"\w* birds \w of|strong="H2920"\w* \w the|strong="H1768"\w* \w sky|strong="H8065"\w* used \w to|strong="H5974"\w* nest.
\q1 All creatures used \w to|strong="H5974"\w* feed themselves \w from|strong="H1768"\w* it.
\q1 
\v 13 While \w I|strong="H4481"\w* \w was|strong="H3825"\w* watching \w in|strong="H5922"\w* \w my|strong="H5922"\w* \w mind|strong="H3825"\w*’s visions \w on|strong="H5922"\w* \w my|strong="H5922"\w* bed,
\q1 \w a|strong="H3068"\w* holy sentinel \w came|strong="H2423"\w* down \w from|strong="H4481"\w* heaven.
\q1 
\v 14 \w He|strong="H1768"\w* called \w out|strong="H6966"\w* loudly \w as|strong="H1768"\w* follows:
\q1 ‘Chop down \w the|strong="H5922"\w* tree \w and|strong="H4437"\w* lop off \w its|strong="H3046"\w* branches!
\q1 Strip off \w its|strong="H3046"\w* foliage
\q1 \w and|strong="H4437"\w* scatter \w its|strong="H3046"\w* fruit!
