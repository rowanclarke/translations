\v 15 \w De|strong="H1121"\w* la \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* \w Gad|strong="H1410"\w*: \w Geuel|strong="H1345"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Maqui.   
\p
\v 16 Estos son \w los|strong="H1121"\w* \w nombres|strong="H8034"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* varones \w que|strong="H1121"\w* \w Moisés|strong="H4872"\w* \w envió|strong="H7971"\w* \w a|strong="H3068"\w* explorar la tierra. \w Y|strong="H3068"\w* \w a|strong="H3068"\w* \w Oseas|strong="H1954"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Nun|strong="H5126"\w*, \w Moisés|strong="H4872"\w* lo \w llamó|strong="H7121"\w* \w Josué|strong="H3091"\w*.  
\v 17 \w Moisés|strong="H4872"\w* los \w envió|strong="H7971"\w* \w a|strong="H3068"\w* reconocer la tierra de \w Canaán|strong="H3667"\w* y les dijo: Suban allí \w por|strong="H2088"\w* el Neguev y \w luego|strong="H5927"\w* remonten la montaña.  
\v 18 Observen \w cómo|strong="H4100"\w* \w es|strong="H1931"\w* \w la|strong="H1931"\w* tierra, \w al|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w que|strong="H4100"\w* \w la|strong="H1931"\w* ocupa, \w si|strong="H1931"\w* \w es|strong="H1931"\w* \w fuerte|strong="H2389"\w* \w o|strong="H3068"\w* débil, \w si|strong="H1931"\w* escaso \w o|strong="H3068"\w* \w numeroso|strong="H7227"\w*,  
\v 19 \w cómo|strong="H4100"\w* \w es|strong="H1931"\w* \w la|strong="H1931"\w* tierra en \w la|strong="H1931"\w* \w cual|strong="H4100"\w* \w él|strong="H1931"\w* \w habita|strong="H3427"\w*, \w si|strong="H1931"\w* \w es|strong="H1931"\w* \w buena|strong="H2896"\w* \w o|strong="H3068"\w* \w mala|strong="H7451"\w*, \w cómo|strong="H4100"\w* son las \w ciudades|strong="H5892"\w* en las cuales viven, \w si|strong="H1931"\w* abiertas \w o|strong="H3068"\w* fortificadas,  
\v 20 y \w cómo|strong="H4100"\w* \w es|strong="H1931"\w* \w el|strong="H1931"\w* terreno, \w si|strong="H1931"\w* fértil \w o|strong="H3068"\w* estéril, \w si|strong="H1931"\w* \w hay|strong="H3426"\w* \w árboles|strong="H6086"\w* en \w él|strong="H1931"\w* \w o|strong="H3068"\w* \w no|strong="H4100"\w*. \w Esfuércense|strong="H2388"\w* y \w tomen|strong="H3947"\w* del \w fruto|strong="H6529"\w* de \w la|strong="H1931"\w* tierra. \w Era|strong="H1931"\w* \w el|strong="H1931"\w* \w tiempo|strong="H3117"\w* de las primeras \w uvas|strong="H6025"\w*.   
\p
\v 21 \w Subieron|strong="H5927"\w* \w y|strong="H5704"\w* exploraron la tierra \w desde|strong="H5704"\w* el \w desierto|strong="H4057"\w* \w de|strong="H5704"\w* Zin \w hasta|strong="H5704"\w* \w Rehob|strong="H7340"\w*, \w en|strong="H5704"\w* la entrada \w a|strong="H3068"\w* Hamat.  
