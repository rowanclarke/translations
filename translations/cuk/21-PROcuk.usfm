\id PRO - Kuna, San Blas - Bible -Panama 2014 (DBL -2014)
\h Proverbios
\toc1 Binsaed-Nuegan-Garda
\toc2 Proverbios
\toc3 Pr
\mt1 BINSAED-NUEGAN-GARDA
\mt2 PROVERBIOS
\imt2 GEBE-SOGLENAID
\imt1 Garda-nug
\ip \it Binsaed-Nuegan-Garda.\it* We-gardade, Hebreo-gayaba, \it mashalʼye\it* bileged. A sogleged, “Binsaed-Nuegan-nikadye.” Soglebalid, “ebo-wilubsaedye,” “ibmar-soglegedye,” degi, “burbar-ibmar-soglegedye.”
\is1 Binsaed-Nuegan-Gardagi weyob sunmaklenaid
\ip Binsaed-Nuegan-Gardagi binsaed-nuegana narmaklegar mamaid. We-gardagi igar-akar-akar egi sunmaklenaid: Binsaed-nue-nikadaedgi, Binsaed-Nuegan-soglemaladgi, degine, namaklemalad nanaibalid. We-igarbali, Israel-dulemar Binsaed-Nuegan amidii gusmalad.
\ip We-garda-gebe-onodedgine, anmarga Israel-e-rey, David-e-machi-Salomón, we-binsaed-nikaa-sunmakleged-narmaksad.
\ip De-ukinbali, Jaqué-machi-Agur, Itielʼga-sunmaksad, degi, Ucalʼga-sunmaksad naimogad. Rey-Lemuel-ibmar-sogsamalad naimogad.
\ip We-gardagine, weyob ilemakar sunmaklenaid:
\io1 1. Binsaed-nikagulegedi, Bab-Jehová-dobee-nanaedgi-danikid (1:1-7).
\io1 2. Igarmar-uklenaid, degi, Binsaed-Nikagued (1:8–9:18).
\io1 3. Salomón-e-binsaed-nikad (10:1–22:16).
\io1 4. Binsaed-Nuegan-ibmar-wisigued (22:17–24:22).
\io1 5. Binsaed-Nuegan-baigan (24:23-34).
\io1 6. Rey-Ezequías, Salomón-binsaed-nuegan-sogsad nue-ilemakar narmaksad (25:1–29:27).
\io1 7. Agur-e-binsaed-nuegan-sogsad (30:1-33).
\io1 8. Rey-Lemuel Binsaed-Nuegan narmaksad (31:1-9).
\io1 9. Ome-innikidaed-e-nug-odummoleged (31:10-31).
\ip Be itogua.
\c 1
\ms1 1. BINSAED-NIKAGULEGEDI, BAB-JEHOVÁ-DOBEE-NANAEDGI-DANIKID
\mr (1:1-7)
\q1 
\v 1 David-machi-Salomón Israel-e-rey, we-binsaed-nuegan narmaksad:
\q2 
\v 2 Adi, binsaed-nikaa guega,
\q2 igarmar-nuegan-mamaidba nanaega,
\q2 gayaburba-dummagan-mamaid mamarega,
\q2 
\v 3 igar-mamaid-wisguega,
\q2 itoakwaa ibmar-imakega,
\q2 igar-innikii-mamaidba ibmar-imakega,
\q2 igar-nabolegedgi igar-maidba imakega,
\q2 emarbi-dulemar-dake nanaega.
\q2 
\v 4 Dule-nue-ibmar-wissulid ibmar-dukuar-maid-wisi imakega,
\q2 sapingan nue-ibmar-wisi guega,
\q2 sapingan mag-neg-itoakwaa nanaegar.
\q3 Agala, Salomón, we-binsaed-nuegan narmaksad.
\q1 
\v 5 Dule-binsaed-ibedi, dule-nue-ibmar-wisidi, we-binsaed-nued itodaed,
\q2 adi, gatik binsaed-nikaa guega, egi durdakbaligar.
\q1 
\v 6 Adi, binsaed-nuegan magar-itogega,
\q2 e-burbagan-mamaid magar-itogega,
\q1 dule-binsaed-nikaa-e-ibmar-soged magar itogega,
\q2 oegedgi-sunmakleged magar-itobaligar.
\b
\q1 
\v 7 Binsaed-nikaguedi, Bab-Jehová-dobee-nanaedgi danikid.
\q2 Dule-binsaedsurmaladi, binsaed-nikagued abesulid,
\q2 binsaed-nueganba nanabisulid.
\ms1 2. IGARMAR-UKLENAID, DEGI, BINSAED-NIKAGUED
\mr (1:8–9:18)
\s1 Be-bab-be-unaed be itogo
\q1 
\v 8 Machi, be-bab-be-unaed nue be itogo.
\q2 Be-nan-be-odurdakedba be dao.
\q1 
\v 9 Be-ibmar-durdaksad bega orgurginyobi ibnuedga guoed,
\q2 bega ordubyobi ibnuedga guoed.
\s1 Dule-isganamarse melle binsaed-galego
\q1 
\v 10 Machi, dule-isganamar be-yardakbi-gualile,
\q2 melle ese binsaed galego.
\q1 
\v 11 Bega sokarmalale: “Anmarba be dage.
\q2 Anmar dule-ibmar-oakalossulid oburgwenae.
\q2 Anmar binsa-nabir-itogedba dule-baisur-binsadiid oburgwenae.
\q1 
\v 12 Igi napa dule-burgwaled-doe,
\q2 deyob, anmar dule-neg-oakalossulid oburgwenamoga.
\q1 
\v 13 Anmar ibmar-nuegan ichesuli sumaloed.
\q2 Anmar ibmar-sumaloedi, anmar-neggi ichesuli urbemaloed.
\q1 
\v 14 Anmarba be akae.
\q2 Anmar ibmar-suoedi, anmar bega ukmogoed.”
\q1 
\v 15 Machi, melle amarba be akao,
\q2 amar-igar-isganagi be banguo.
\q1 
\v 16 Ar we-dule-isganamar, ibmar-isgana bur gwae imakbidamalad,
\q2 gwae dule-oburgwebidamalad.
\q1 
\v 17 Ar sikwimar e-wagab e-gaedsinai daksale,
\q2 egi gwen dogosulid.
\q1 
\v 18 Ar we-dule-isganamardi, na dukin yardakledimalad,
\q2 emar na dukin oburgwedimalad.
\q1 
\v 19 Dulemar-dogdar-maniginbi-binsamalad, deyob gunonidamalad.
\q2 Dulemar-dogdar-maniginbi-binsamalad, dule-baidse burgwenonidamogad.
\s1 Binsaed-nikaguedgi sunmaklenaid
\q1 
\v 20 Binsaed-Nikaguedi, binnasuli galimbaba goled,
\q2 dulemar-bukidar-ambikued-abargi isseed sunmaked.
\q1 
\v 21 Binsaed-Nikaguedi, dulemar-igar-itoged-abargi sunmaked,
\q2 neggweburse-doged-yawagakgi sunmaked.
\p Weyob soged:
\q1 
\v 22 “Sapingan, bemar-amba-nue-ibmar-wissurmalad,
\q2 ¿ar sanagwadse, ibmar-wissuli be gudii gumaloe?
\q1 ¿Ar sanagwadse, be dulemargi-dododiid, bar dulemargi dodosuli gumaloe?
\q2 Dule-binsaed-satemalad, bemar, ¿sanagwadse ibmar-wisigued-isdar-daked sae be dakmalode?
\q1 
\v 23 ¡An-ibmar-sabsur-soged be itomala!
\q2 An-burba-nued an bega unnitiba ukoed.
\q2 An-binsaed-wisguega an be-imakoed.
\q1 
\v 24 An bese gochamar-inigwele, yapa be an-itogusmalad.
\q2 An bese achasmar-inigwele, gwen be amba ibsassurmalad.
\q1 
\v 25 Binsaed-nuegan-an-bega-uknaigusmaladi, aka be obachamalad.
\q2 An-sabsur-bega-ibmar-sogsadi, gwen be itossurmalad.
\q1 
\v 26 A-ulale, bemar sabsur-odurdaklealile, an bemarga binnasuli alloed.
\q2 Bemargi dobed nagunonikile, an bemarga alloed.
\q1 
\v 27 Burwa-dummad-goledyob bemargi dobed nagunonikile, an bemarga alloed.
\q2 Burwa-ololedyobi bemargi nunmak-itoleged-dummad nagunonikile, an bemarga alloed.
\b
\q1 
\v 28 ”A-ibagine, geb be anse gordamaloed.
\q2 Degi-inigwele, andi bemar-abin-imakosulid.
\q1 Be an-amidii gumaloenad,
\q2 degi-inigwele, be an-amiosurmalad.
\q1 
\v 29 Ar bemar binsaed-nikagued abessurmalad,
\q2 Bab-Jehová-dobee be nanassurmalad.
\q1 
\v 30 An-bemarga-binsaed-nued-uked be itossurmalad,
\q2 an-bemarga-sabsur-ibmar-sogsad be abessurmalad.
\q1 
\v 31 Na be-daed begi gannar aibinoed,
\q2 be dule-yardakdimaladgi, na dukin be yardaklemaloed.
\q1 
\v 32 Be-isgusadba, be-ibmar-wissulidba, na be dukin berguoed.
\q2 Be baisur-ibmar-dakedba, na be dukin oburgoed.
\q1 
\v 33 Ar dule anba-ibsaerdi, bogidik gudii guoed.
\q2 Ibmar-isgana-dobsuli gudii guoed.”
\c 2
\s1 Binsaed-nikagued-amileged ibnuedid
\q1 
\v 1 Machi, an ibmar-bega-soged be itogele,
\q2 an-igar-maidba be nanaele,
\q1 
\v 2 binsaed-nikaguedba be ibsaele,
\q2 be-ulubgi bela-bela ise-itoagwar be ibmar imakele,
\q1 geb be Bab-Jehováʼba-ibsaleged magar be itononikoed,
\q2 magar be Bab-Dummad daknonikoed.
\q1 
\v 3 Machi, nue-ibmar-wisigued be egisele,
\q2 magar-ibmar-itoged be egisele,
\q1 
\v 4 binsaed-nikagued maniyob be e-bina-sogdiile,
\q2 or-nuegan-dukuar-bukwadyob be amiele,
\q1 
\v 5 geb be Bab-Jehováʼba-ibsaleged magar be itononikoed,
\q2 magar be Bab-Dummad daknonikoed.
\b
\q1 
\v 6 Ar Bab-Jehováʼbi binsaed-nikagued uked,
\q2 Bab-Dummadbi nue-ibmar-wisi be-imaked.
\q1 
\v 7 Bab-Jehová dule-ibmar-innikii-imakmaladga binsaed-nikagued uked.
\q2 Bab-Jehová amar-bendakdaed,
\q2 amarba gudidaed.
\q1 
\v 8 Bab-Jehová dule-igar-maidba-ibmar-imakmalad nue-dakdidaed,
\q2 Bab-Jehová dule-eba-nanadimalad edarbedidaed.
\s1 Igar-inniki-imakleged-wisguleged
\q1 
\v 9 Geb agine, igar-inniki-mamaidba-imakleged,
\q2 igar-nabolegedgi-igar-maidba-imakleged,
\q1 emarbi-dulemar-dakleged,
\q2 magar-itoge be guoed, wede ibi-obare.
\q1 
\v 10 Binsaed-nikagued be-ulubgi nagunonikile,
\q2 nue-ibmar-wisidi, yeer-itoge be-imakoed.
\q1 
\v 11 Itoakwaadaedi be-bendakoed,
\q2 nue-ibmar-wisiguedi be-bendakbaloed.
\s1 Dulemar-isganagi-bangued
\q1 
\v 12 Binsaed-nikagued, igar-isganaba-nanaega be-imakosulid,
\q2 dulemar-sunnasur-sunmakmaladgi be-ollor-imakoed.
\q1 
\v 13 Dulemar-igar-isganaba-bur-nanaega, igar-nuedgi-banguddamaladgi,
\q2 binsaed-nikaguedi, be-ollor-imakoed.
\q1 
\v 14 Dulemar-ibmar-isgana-saedgi-wergumaladgi, ibmar-isgana-imakedba iba-onodamaladgi,
\q2 binsaed-nikaguedi, be-ollor-imakoed.
\q1 
\v 15 Dulemar-igar-noar-noar-gudidamaladgi, igarmar-innikisulidba-gudidamaladgi,
\q2 binsaed-nikaguedi, be ollor-imakoed.
\s1 Dule-baid-e-omegi-bangued
\q1 
\v 16 Machi, binsaed-nikaguedi, dule-baid-e-omegi be-ollor-imakoed.
\q2 Binsaed-nikaguedi, ome-agumakedba-emar-binsaed-gaedgi, be-ollor-imakoed.
\q1 
\v 17 A-ome, Bab-Dummad-asabin na abirgunagwar-gued-igar-mesisad ieded,
\q2 degidbali, na e-suigi bar binsassulid.
\q1 
\v 18 A-ome-negse naye be sogele,
\q2 burgwed-igarse be-sedoed.
\q1 
\v 19 Dule a-omese-gochale, bar gannarse guosulid,
\q2 bar gannaryob nued-gudii guosulid.
\s1 Nued-gudigued, degi, sabsur-odurdakleged
\q1 
\v 20 Machi, deyobi, dule-nued-nanadimalad-igarba be nanaoed,
\q2 igar-innikigwadbi be imakdii guoed.
\q1 
\v 21 Ar dule-igar-maidba-ibmar-imakmaladi we-napneggi gudii gumaloed.
\q2 Dule-egi-ibmar-akar-soged-satemaladi, we-napneggi undar-suitii gudii gumaloed.
\q1 
\v 22 Dule-isganamardi we-napneggi bergumaloed,
\q2 dule-ichomaladdi oburgwilemaloed.
\c 3
\s1 Uaya-nikaa-daedgi unaed
\q1 
\v 1 Machi, melle an-igar-odurdaked be iego,
\q2 be-gwage-ulubgi an-igar-maid be sedigu guo.
\q1 
\v 2 Ar deyob be imakele, we-napneggi suitii mai be guoed,
\q2 weligwar-itodii be guoed.
\q1 
\v 3 Sabgued-igar melle be iego,
\q2 napiragwad-igar melle be iebalo.
\q1 Igi wingwa be-dukargi-naigu be gudidae, deyobi be imako,
\q2 be-gwage-ulubgi sedigu be imako.
\q1 
\v 4 Deyob be imakele, Bab-Dummad nabir be-dakoed,
\q2 dulemar nabir be-dakmogoed.
\q1 
\v 5 Melle be-ibmar-wisidba be nanadii guo.
\q2 Bab-Jehováʼgi bela-belad-ulubgi-bensuli be nanadii imako.
\q1 
\v 6 Bela be ibmar-imakedgi Bab-Jehováʼse idakdii be imako.
\q2 Deyob be imakele, Bab-Jehová bega igar nueganbi imakoed.
\q1 
\v 7 Mer be binsao, “An ibmar nue-wisye.”
\q2 Bur be Bab-Jehová dobee nanae,
\q2 bur be ibmar-isgana-imakedgi bangue.
\q1 
\v 8 Deyob be nanaele, we-igala, bela bega ina-nuedga guoed,
\q2 bela bega be-abagan ogannogoed.
\q1 
\v 9 Be-ibmar-nikad-Bab-Jehováʼga-ukedgi Bab-Jehová-nug be odummoge.
\q2 Gebe be-ibmar-sanmaked-Bab-Jehováʼga-ukedgi Bab-Jehová-nug be odummoge.
\q1 
\v 10 Deyob be imakele, be-ibmar-gwag-saboged-uu ena sii guoed,
\q2 be-vino-binigan e-galugi ena sii guoed.
\q1 
\v 11 Machi, Bab-Jehová sabsur-be-odurdakalile, melle isdar be itogo,
\q2 melle be urwebalo.
\q1 
\v 12 Igi baba na e-mimmi-sabedba sabsur-odurdakdae,
\q2 deyobi, Bab-Jehová dulemar-sabedi sabsur-odurdakdamogad.
\s1 Binsaed-nikagued-odummoleged
\q1 
\v 13 Dule binsaed-nikagued nikunonikile, we-dulegi nued binsalegoed.
\q2 Dule ibmar-nue-wisi gunonikir, we-dulegi nued binsalegoed.
\q1 
\v 14 Binsaed-nikagued maniba bur bule ibnuedid,
\q2 orba bur bule egi ibmar-nuegan amileged.
\q1 
\v 15 Binsaed-nikagued, akwa-nuegan-manisailadba bur ibnuedid.
\q2 Ibmar-nue-wisigued, ibmar-nueganbina-sogleged-ebo yobsulid.
\q1 
\v 16 Ar binsaed-nikagued we-napneggi suitii mai be-imakoed.
\q2 Deginbali, mani-ibedga be-imakbaloed,
\q2 nug-nued-nikaguedga be-imakbaloed.
\q1 
\v 17 A-igarmarba-nanalegedi, yeer-ito dule-saedid,
\q2 bela e-igarmar bogidik-gudii dule-imakedid.
\q1 
\v 18 Dule binsaed-nikagued-amisale, egi burba-dula-gudigued nikued.
\q2 Dule binsaed-nuedgi-akas-gudiile, Bab-Dummad, we-dulegi nued binsaed.
\s1 Binsaed-nikagued, degi, napneg-nagusad
\q1 
\v 19 Bab-Jehová binsaed-nikaguedgi, napneg nasiksad.
\q2 Nue-ibmar-wisiguedgi, nibneg nasiksabalid.
\q1 
\v 20 Na ibmar nue-wisidba, diimar bachik-bachik nasiksad,
\q2 nibneg-akale, dii-wiega imaksad.
\s1 Binsaed-nikaguedgi-ibmar-imakedi weligwar dule-imaked
\q1 
\v 21 Machi, nue-binsakwaa be ibmar imako.
\q2 Itoakwaa-ibmar-imaked melle be iego.
\q1 
\v 22 Deyob be imakele, burba-dula-gudii be-imakoed.
\q2 Bega ordubyobi ibnuedga guoed.
\q1 
\v 23 Geb agine, bonisuli be nanadii gudoed,
\q2 be yoledii guosulid.
\q1 
\v 24 Be megid-sogele, be dobguosulid.
\q2 Be gabidogu, bogidikidgi be gabidoed.
\q1 
\v 25 Ukiagwar-bonigan-noardaedi, be dobguosulid,
\q2 dule-Bab-wissurmaladgi ukiagwar boni-dummagan-noardaedi, be dobguosurbalid.
\q1 
\v 26 Ar Bab-Jehová beba gudiguoed,
\q2 dulemar-isganase yardaklegega be-imakosulid.
\s1 Igi be dulemargi daergebe
\q1 
\v 27 Dule-baidga-ibmar-nued-imaked begi siile, ega be imako,
\q2 melle ega imaksuli be guo.
\q1 
\v 28 Melle ega be sogo: “Be nagwerye, banedse an be-bendakoye.”
\q2 Ar emi sunna be a-dule-bendakele, bendaksabin be imako.
\q1 
\v 29 Melle be-ai-begi-bensuli-gudiidgi be aibino.
\q1 
\v 30 Melle dule-gwen-be-oakalossulidbo be urwo,
\q2 ar dule gwen-be-oakalossulid.
\q1 
\v 31 Melle dule-sabsurdamalad-e-ibmar-imakdiidgi be nobguo,
\q2 melle e-daedba be nanabalo.
\s1 Bab-Dummad dule-isgana-isdar-daked, dule-nueddi bendaked
\q1 
\v 32 Ar Bab-Jehová dule-isganamar nue isdar-dakdaed.
\q2 Ar dule-nuegan-ebodi walikaa gudidaed.
\q1 
\v 33 Bab-Jehová, dule-nued-daed-e-neguyagi nued binsadaed,
\q2 dule-isgana-e-neguyadi, ukabsadaed.
\q1 
\v 34 Bab-Jehová, dule-emargi-dododimaladgi dododamogad,
\q2 ar dule-san-bipi-imakmaladdi, bendakdaed.
\q1 
\v 35 Dule-binsaed-ibegan-nug odummolegergebed.
\q2 Ar dule-binsaedsulidamaladdi, egi dodoleddaed.
\c 4
\s1 Be-bab-be-unaed be itoge
\q1 
\v 1 Machimala, bab-be-unaed nue be itomala,
\q2 ibmar-nue-wisiguega nue-ise-itogale be imakmala.
\q1 
\v 2 Igar-nuegangi an be-odurdakgwelo,
\q2 melle an-ibmar-odurdaked be itosuli guo.
\q1 
\v 3 An bipigwaunni, an-babba-an-gudigusgua,
\q2 an-nana anbina bela-belad-sogdigusgua,
\q1 
\v 4 an-bab an-odurdaksad, weyob anga sogsad:
\q2 “An-bega-ibmar-soged, ulubgi be nue-sedii imako.
\q1 An-bega-ibmar-soged be imako.
\q2 Deyob be imakele, we-napneggi suitii be gudiguoed.
\q1 
\v 5 Binsaed-nikagued be amie,
\q2 ibmar-nue-wisigued be amie.
\q1 Melle be an-gayaburba iego,
\q2 melle egi be banguo.
\q1 
\v 6 Binsaed-nikaguedgi melle be bangue,
\q2 ar a, be-bendakdii guoed.
\q1 Binsaed-nikaguedbina bur be soge,
\q2 ar a, be-edarbedii guoed.
\q1 
\v 7 Ibmar-baigan-idu, nue-binsaed-nikagued bur be amie.
\q2 Bela ibmar baiganba, ibmar-nue-wisigued bur be amie.
\q1 
\v 8 Binsaed-nikaguedbina bur be soge,
\q2 ar a, be-nug-odummogoed.
\q1 Binsaed-nikagued bur be sabgue,
\q2 ar a, be-nug-ogannogoed.
\q1 
\v 9 Binsaed-nikaguedi bega akwa-nuegan-ologurgingi-sigeyob gued.
\q2 Ologurgin-nonogi sigeyobi bega gued.”
\s1 Binsaed-nikaguedi burba-dulad-uked, nued-gudii be-imakbalid
\q1 
\v 10 Machi, we-napneggi suibaksaar be gudiguega,
\q2 an bega-ibmar-soged, nue be itoge.
\q1 
\v 11 Binsaed-nikagued-igarba an be-semaid,
\q2 igar-innikigwadba-nanaega an be-imaked.
\q1 
\v 12 Be binnaa nadapsogele, bega ibmar-nueganbi guoed.
\q2 Amba be gwae-gwae nadapsogele, bega ibmar-nueganbi gubaloed.
\q1 
\v 13 An be-odurdaked mer be iego, melle be indako,
\q2 nue be sedio, we burba-dulagudiguega be-imaked.
\q1 
\v 14 Dule-isganamarba melle be akae.
\q2 Amar-igarba melle be nanae.
\q1 
\v 15 A-dulemargi be bangue.
\q2 Melle a-dulemar-walikaa be gudigue.
\q1 
\v 16 Dule-isganamar ibmar-isgana-imaksurmalale, geg gabdamalad,
\q2 dule-oakalosurmalale, geg gabdamalad.
\q1 
\v 17 Ibmar-isgana-imaked mas-gunnedba bur-yeer itodamalad.
\q2 Sabsur-emar-imaked, vino-gobedba bur-yeer itodamalad.
\b
\q1 
\v 18 Igi bolegoe neg-ainakwiardae, deyobi, dule-nuegan-e-nanaedi gued.
\q2 Dule-nuegan-e-daedi, neg ibegwaledse-nasgumai-nasgumai-daeyobi gued.
\q1 
\v 19 Dulemar-isgana-e-nanaeddi negsichid-naidyobi gued,
\q2 wissurmalad, ibigi na yoledimala.
\s1 An-be-unaed nue be itogo, ina-nuedga bega guoed
\q1 
\v 20 Machi, an bega binsaed-uked, nue be itoge,
\q2 ibmar-bega-an-soged, nuekwaa be itoge.
\q1 
\v 21 An be-odurdakedgi melle be bangue,
\q2 gwage-ulubgi nue-sedii be imake.
\q1 
\v 22 Ar dule binsaed-nikagunonikile, ega burba-duladga gued,
\q2 we-dulega ina-nuedga gubalid.
\q1 
\v 23 Bela ibmar-sunsogmalad-baiganba, be-binsaedi nue-itoakwaa be ebugo.
\q2 Ar we-binsalegedgine, gudiguleged danikid.
\q1 
\v 24 Gaya-isgana-sunmaked be indake,
\q2 melle bar be gakansadii nanae.
\q1 
\v 25 Ibmar-nueganginbi be atake,
\q2 yoo ibmar-danimaloedgi-atakdii be sae.
\q1 
\v 26 Be-nanadiid nue be dake.
\q2 Bela be-ibmar-imakedi innikigwadbi be imake.
\q1 
\v 27 Melle igar-nuedgi be aibane.
\q2 ¡Igar-isganagi be bangue!
\c 5
\s1 Abirgunagwarsuli-nanaedgi bangued
\q1 
\v 1 Machi, an-binsaed-nikagued an bega-ukedi, nue be itoge,
\q2 an ibmar-nue-wisidi an bega-sogedi, nue-ise-itogar be imake.
\q1 
\v 2 Adi, be sunmakalile, nue-itoakwaa sunmakegar,
\q2 nue-ibmar-wisi be guegar.
\q1 
\v 3 Ome-sui-dikarba-yoleged-e-agumakedi, ibmar-nuediyob sunmaked.
\q2 E-gwabin-ibmar-biedi, ibmar-nueganbi sogdaed.
\q1 
\v 4 Dule ese-binsaed-galesale, ina-gagbisailadyobi ega gued,
\q2 es-suid-nugar-darbogwadba bur bule dule-naibi-saeyob gued.
\q1 
\v 5 Dule a-ome-ebogwa negsichidgi nanaele, burgwedse nilemaid.
\q2 Neg-uanse selemaid.
\q1 
\v 6 A-ome dule-egi-sunmakmalad bai-itosulid.
\q2 E-sunnasur-daedi, na bargasulid,
\q2 e-ichakwa-nanadiidi na aku itoged.
\b
\q1 
\v 7 Machi, emigi nue be an-itoge.
\q2 An-ibmarmar-bega-sogedba be nanae.
\q1 
\v 8 Ome-e-sui-yardakdiidgi, be bangue.
\q2 Melle e-neg-yawagakse be warmako,
\q1 
\v 9 adi, melle dule-baid-aku-be-dakedga be-arbasadgi-ibmar-nikusad be ukegar,
\q2 melle be-burba-gandikid dule-baidga be ukegar.
\q1 
\v 10 Degiile, dule-baid be-ganguedgi yeer-itogoed.
\q2 Degiile, be-arbasad-mani dule-baid-negse dogoed.
\q1 
\v 11 Geb agine, bela binna-binna be-san bergumaidba,
\q2 be bodii gudoed.
\q1 
\v 12 Agi be sogdoed: “Ar wede, ibiga dule-anga-binsaed-uksamalad an itossuli.
\q2 Ar wede, ibiga dule-sabsur-an-odurdaknaigua, an itossuli.
\q1 
\v 13 Dule-anga-binsaed-daknanai-gusmalad an itossulid.
\q2 Dule-an-odurdaknanai-gusmaladba an ibsassulid.
\q1 
\v 14 Emide, dulemar-abargi, an oitolegednaga gudiid,
\q2 wis ugak an gudiid.”
\s1 Ome-dikarba-yolesulid
\q1 
\v 15 Be nog-gobbigualile,
\q2 be-ome-ebo be nog gobo.
\q1 
\v 16 Unnila be-omesebi be golo,
\q2 melle be-omesulidse be golo.
\q1 
\v 17 Be-ome unnila begadbiid,
\q2 melle dule-baidga be-ome be urmakdii nanao.
\q1 
\v 18 Ome-bega-uklesadgi nued-binsalesun.
\q2 Nuchukwagwadgi bega abirgin-uklesad-ebo be wergudii gusun.
\q1 
\v 19 Ome goe-sapuryob, yeer dakleged.
\q2 Ome wasa-omeyob, yeer dakleged.
\q1 Bele-bele be-imakar-sogele, egi be wergudii sao.
\q2 E-sabguedgi be wergudii guo.
\q1 
\v 20 Machi, melle ome-baidse-binsaed-galedii be guo,
\q2 melle ome-baid be-werguega, be imako.
\s1 Dule-isganamar-e-odurdaklegoed
\q1 
\v 21 Bab-Jehová bela dulemar-e-daed nue-wisid.
\q2 Dulemar-nanaedi egi gwen yoggumaisulid.
\q1 
\v 22 Ibmar-isgana, dule-isganagi aibinoed,
\q2 e-isguedgi ollorguosulid.
\q1 
\v 23 Dule-isgana, igar-maidba-nanabisulidbali burgwidoed.
\q2 Na e-binsaed-satedbali, burgwidsunnoed.
\c 6
\s1 Emar-anar-mani-bennukedgi mer be binsao
\q1 
\v 1 Machi, dule-mani-gasad-anar, be bennukoye sogsale,
\q2 igidibe, dule-baidga, be bennukoye igar mesisale,
\q1 
\v 2 na be imakoye sogsadgi,
\q2 na be dukin yardaklesdo.
\q1 
\v 3 Degisoggu, machi, emidi be-aise be yardaklesad.
\q2 Ar agi be ollorgubiele, weyob be imaksunna:
\q1 Ese be nae, egi be wilenae, ega be sognae,
\q2 an-bega-bennukoye-sogsadi, be anga osuloye.
\q1 
\v 4 Melle be ogabe,
\q2 melle be banega saboge.
\q1 
\v 5 Igi goe-sapur, dule-e-makbied-idu wakinne,
\q2 deyobi, dule-be-yardakbiedgi be wakinmoga.
\q1 Igi nuu dule e-gabied-idu wakinne,
\q2 deyobi, dule-be-yardakbiedgi be wakinmoga.
\s1 Melle dule-wiegalaga guo
\q1 
\v 6 Dule-wiegala, nue be igli dake,
\q2 e-ibmar-imaked nue be dake,
\q2 binsaed-nikaguega eba be durdake.
\q1 
\v 7 Igli, ega-igar-uked sated,
\q2 e-dummad sated, e-idued satebalid.
\q1 
\v 8 Degi-inigwele, dii-wisulidgine na e-mas onmaked,
\q2 ibmar-durba-weleged-ibagine na e-mas onmakdaed.
\b
\q1 
\v 9 Dule-wiegala, be meremaidi, ¿sanadse gwisguoye be soge?
\q2 ¿Sanadse gabmaid be atakoe?
\q1 
\v 10 Be gabsiile, nono-yakumaksiile, sikwas napi-gabele,
\q2 sakwa-bipirmakar wis obunnosiile,
\q1 
\v 11 ukiarmakale, dule-atursaeyobi, begi wileged nonikoed.
\q2 Ukiarmakale, dule-negsuligudiidyobi, begi ibmarsuligued yolenonikoed.
\s1 Dule-isganamar-e-odurdaklegoed
\q1 
\v 12 Dule-isgana, dule-galagwensuli-nanaed,
\q2 dule-gakansaedginbi-gudiid,
\q1 
\v 13 dule-yardakega, ibya-biri-emar-daked,
\q2 dule-yardakega googi sunmaked, naggi sunmaked.
\q1 
\v 14 We-dulemar unnila ibmar-isgana-imakedginbi binsadidaed,
\q2 aimar-ourwed yeer-itodaed.
\q1 
\v 15 A-ulale, ukiagwar egi bonigan yolenonikoed,
\q2 ukiagwar berguoed.
\s1 Bab-Dummad ibmar-sogagugle (7) isdar-daked
\q1 
\v 16 Bab-Jehová ibmar soganergwa (6) sae-daked,
\q2 napi-ibmar-sogagwenad-baid bur-bela-bela isdar daked.
\q1 We-ibmarmar-sogagugled (7) isdar daked:
\q2 
\v 17 Dule-na-san-dummarba-imaked,
\q2 dule-gadi-gakansaed,
\q2 dule-binsarsunna-aimar-gindaked,
\q2 
\v 18 dule-galagwensuli-dule-baidgi-binsaed,
\q2 dule-ibmar-isganabi-imakdidaed,
\q2 
\v 19 dule-ibmar-daksad-gakansaar-ibmar-soged,
\q2 gwenadgan-gwenadgan-ourwed-dule.
\q3 We-ibmarmar, Bab-Jehová isdar daked.
\s1 Be-sergan-bega-sunmakedba be ibsae
\q1 
\v 20 Machi, be-bab-be-odurdakedba be ibsae.
\q2 Be-nan-be-unaedba, be dae.
\q1 
\v 21 Be-gwagegi-sedigu, be imake,
\q2 ordub-be-dukargi-naiyob, be imake.
\q1 
\v 22 We-binsaed-nuegan, be bia nadele, be-idumai guoed.
\q2 Be gabidele, be-edarboed.
\q1 We-binsaed-nuegan, be atakar-sogele, bega sunmaknai guoed.
\q2 
\v 23 Igarmar-Mamaidi, gwalluyobi gued,
\q1 ibmar-odurdakleged neg-meegwadyobi gued.
\q2 Igar-nuegan-mamaidba-nanalegedi, be-odurdakoed igi be nanaergebe.
\s1 Abirgunagwarsuli-nanalegedgi bangued
\q1 
\v 24 We-binsaed-nuegan, melle be ome-isganabo galagwensuli nanadiguega be-imakoed.
\q2 Melle be ome-sui-dikarba-galagwensuli-gudiidbo nanaega be-imakoed.
\q2 Melle we-ome-e-ibmar-nued-sogedgi be binsaed-galediguega be-imakoed.
\q1 
\v 25 Melle ome-isgana-e-yeerdaklegedbina be sogo.
\q2 Ome-isgana be-dakedgi, melle ese be-binsaed galego.
\q1 
\v 26 Ar ome-gambanuchu-imaked unnila masbina gudiid.
\q2 Ome-sui-dikarba-yolegeddi, bela be-sanbina sogdiid.
\q1 
\v 27 Ar dule na e-nukugi soo-sisale,
\q2 ¿ei mor gummaksasulir be insae?
\q1 
\v 28 Ar dule soo-birgi nanaele, ¿ei nag gummaksasulir be insae? Ei gummaksale.
\q2 
\v 29 Dule, dule-baid-ome-ebo negsichigi nanaedi, soogi-gummakeyob boni-amiedsemogad.
\b
\q1 
\v 30 Dule-atursaed ukudmaada-itogedba ibmar-atursasale,
\q2 ¿isdar dakdamarsursi?
\q1 
\v 31 Dule-atursaed daklesardi, ilagugle (7) ibmar-atursasad bennukoed.
\q2 Sulirdi, bela e-neggi-ibmar-nikad ukoed.
\q1 
\v 32 Dule ome-baidbo negsichidgi nanaele, we-dule, binsaed-satedid.
\q2 Dule deyob-daedi, na dukin san-wioged.
\q1 
\v 33 Unnila binged-amiedid, na dukin naibid-amiedid.
\q2 E-nug-gagalesad gwen ega alliosulid.
\q1 
\v 34 Ar we-ome-e-sui nobedba uludele, na san gwen bargaosulid,
\q2 igi-barsaye gwen sogosulid.
\q1 
\v 35 Dule amba ome-e-suiga ibmar-ukye sogele,
\q2 gwen abingaosulid.
\q1 Ar amba ega ibmar-dummarba-ukye sogele,
\q2 igi-barsaye gwen sogosulid.
\c 7
\s1 Binsaed-nikaguedi, ome-negsichigi-nanaedgi be-ollorsaoed
\q1 
\v 1 Machi, bega-an-ibmar-sogedba be dae,
\q2 igargan-an-bega-ukedba be nanae.
\q1 
\v 2 Igargan-an-bega-ukedba be nanaele, be dula gudiguoed.
\q2 Be-ibyagwag be akweyobi, an-bega-ibmar-sogedba be ibsae.
\q1 
\v 3 An-be-unaedi, olargan-googi-yoiyobi, be sedii sae,
\q2 be-gwagegi nue-ebinsadii be imake.
\q1 
\v 4 Binsaed-nikaguedga be soge: “Be an-bunye.”
\q2 Ibmar-wisiguedga be soge: “Be an-ai-nuedye.”
\q1 
\v 5 Adi, wemar, ome-sui-dikarba-yolediidgi, be-ollor-imakoed,
\q2 ome-e-agumakedba-emar-binsaed-gaedgi, be-ollor-imakoed.
\s1 Ome-emar-binsaed-gaed, degi, sapingwa-binsaedsulidaed
\q1 
\v 6 An-neggi, yawagak-bipigwad-imbaba an atakded.
\q2 
\v 7 An dakalid, sapingana-binsaedsurmalad-abargi, machi-wargwen bur-binsaed-sated gudii.
\q1 
\v 8 We-sapingwade, igar-abingunaidse warmakdapid,
\q2 agi ome-e-sui-dikarba-yolediid-negse naded.
\q1 
\v 9 Deunni, neg-sedomaid, neg nue-gutuleded,
\q2 degi, neg nue-mutikguded.
\b
\q1 
\v 10 Geb agine, ome e-abin-noalid. Ome gambanuchu-imakedyob mor-yoid.
\q2 E-daedi, mag-dakleged, macherganbina sognadapid.
\q1 
\v 11 We-ome neg-gagadidaed, gwinni-gwinni daed,
\q2 geg neggi siged, galimbabi wisid.
\q1 
\v 12 Galimbaba gudidaed, dulemar-bukidar-ambikuedgi gudidabalid.
\q2 Igi-saele machered-wargwen-yardakodibeye binsadidaed.
\q1 
\v 13 We-ome, sapingwa-daksagua, gadebinne imaksad,
\q2 ei wagar usa imaksad.
\q2 Ega bingesuli sogded:
\b
\q1 
\v 14 “Gwenatigwar-guega Bab-Dummadga an ibmar-ukoye an sogsad.
\q2 Deyob an sogsadi, emi deyob an imaksad.
\q1 
\v 15 A-ulale, an be-abin noalid.
\q2 An be-amidii gusad,
\q2 emide an be-abingunonisunnad.
\q1 
\v 16 An-gabedgi atue-nued-yeerdakleged, lino-dubgi-sobaled-Egiptoʼgi-danikid an ogichad.
\q2 
\v 17 An-gabedgi ina-wawadikmalad, mirraʼye-nugad, áloeʼye-nugad, degine, canelaʼye-nugad an eosad.
\q1 
\v 18 Anba be dage. Anmar nog-gobmai oibodagoed.
\q2 Oibogedse anmar nog-gobmai imakmaloed.
\q1 
\v 19 Ar an-sui neggi gudisulid,
\q2 dikasuli neggwebur-baidse naded.
\q1 
\v 20 Mani-ichesuli sesa-naded,
\q2 geb nii-dalu-naidse gannar negse aibiroed.”
\s1 Sapingwa ome-ega-agumakedgi binsaed-galesad
\q1 
\v 21 Weyobi, ome, agumaksadgi,
\q2 machigwa-binsaed-gasad.
\q1 
\v 22 Moli-alugwasualedi, e-oburgwilegedse ebipilemaiyobi, machigwa ome-sorba-nai nadapid.
\q2 Goe-sapur galesgunaidgi sigu egi yolenonikiyobi, machigwa gued.
\q1 
\v 23 Igi nuu burgwed-wissuli saki-naidse naddae,
\q2 machigwa deyobi gued.
\s1 Ome-emar-binsaed-gaedgi banguo, degisulile, be burgoed
\q1 
\v 24 Machi, emigi nue be an-itoge,
\q2 an-be-unaed nue-itosii be imake.
\q1 
\v 25 Melle a-omegi-binsadii be sae,
\q2 melle a-omese be binsaed galege.
\q1 
\v 26 Ar a-omese bukidar machergan yardaklediid.
\q2 Machergan-bukidargus ese burgwedanikid.
\q1 
\v 27 We-ome-negse be nadele, be burgoed.
\q2 A-igar burgwedse dule-semaid.
\c 8
\s1 Binsaed-Nikagued dulemarse gornaid
\q1 
\v 1 Binsaed-Nikagued, ¿anmarse iseedi gornaisursi?
\q2 Ibmar-wisigued, ¿iseedi gornaisursi?
\q1 
\v 2 Binsaed-Nikagued, igarba yar-birigwagi gorgwisdaed,
\q2 igarmar-abingunanaidgi gorgwisdaed.
\q1 
\v 3 Neggwebur-doged-e-yawagakmar-dikarba ise-gollar gornaidaed.
\q2 E-yawagak-dogedgine binnasuli weyob-gornaid:
\q1 
\v 4 “Machergan, bemarse an gornaid,
\q2 bela-dulemar-bukwadse an gornaid.
\q1 
\v 5 Bemar-ibmar-wissurmalad, itoakwaa be gudisamala.
\q2 Bemar-binsaedsate-gudimalad, ibmar-magar-itoged be amimala.
\q1 
\v 6 Nue an-itomalo, an ibmar-nuegan sogesokalid.
\q2 An-gwabinduku igar-innikigwadba sunmaksokalid.
\q1 
\v 7 An ibmar-sogedi gakangi sunmakosulid,
\q2 ar gakanmar an nabir-daksulid.
\q1 
\v 8 An-gayaburbamar, igar-innikigwadbi sunmaked,
\q2 darbo sunmaksulid, ibmar-isganagi sunmaksulid.
\q1 
\v 9 An-gayaburbamar, dule-magar-neg-itogedgala baisursunna-noed.
\q2 Dule-binsaed-ibeganga, an-gayaburbamar innikigwadbi ega noed.
\q1 
\v 10 Mani-abelegedba an-ibmar-odurdakedbina bur bule be sogmala.
\q2 Olo-nued-abelegedba ibmar-wisgulegedbina bur bule be sogmala.
\q1 
\v 11 Ar Binsaed-Nikagued, dimmurgiid-e-akwa-yeerdaklegedba bur bule ibnuedid.
\q2 Ibmar-bur-nued egi obinsulid,
\q2 ar ibmar-baid-ebo geg wilub-imakleged.”
\s1 Binsaed-Nikagued-e-damalad
\q1 
\v 12 “Ani an Binsaed-Nikaguedi, itoakwaa-binsaedbogwa an gudiid.
\q2 Ibmar-wisigued an nikad, itoakwaadaed an nikabalid.
\q1 
\v 13 Dule, Bab-Jehová-dobekwaa nanadiile,
\q2 isdar ibmar-isgana daked.
\q1 Ar san-dummarba-imaked, an isdarsun daked,
\q2 san-bule-bule-saed, an isdar dakbalid.
\q2 Sunnasur-daed, galagwensur-sunmaked, an isdarsun dakbalid.
\q1 
\v 14 Binsaed-uklegeddi, angi maid,
\q2 nuekwa-igar-nabolegeddi, angi maibalid.
\q1 Neg-magar-itolegeddi, angi maid,
\q2 gargangueddi, angi maibalid.
\q1 
\v 15 Ani an Binsaed-Nikaguedi, an-sogedba reymar wis negsedimalad.
\q2 An-sogedba dule-nug-nikamalad, wis igar-innikii nabodimalad.
\q1 
\v 16 An-sogedba dule-nug-nikamalad negsedimalad,
\q2 an-sogedba dule-negsedimalad napneg-sedimalad.
\q1 
\v 17 Dule-an-sabmaladi, an sabmogad.
\q2 Dule-an-amidimaladi, baisursunna an-amimalad.
\q1 
\v 18 Ibmar-bukidar-nikuleged angi danikid,
\q2 nuga-nued-nikuleged angi danibalid.
\q1 Nue-nasguleged-degisadeguad angi danikid,
\q2 igar-inniki-imakleged angi danibalid.
\q1 
\v 19 An-binsaed-ukedi, olo-nuedba bur-nuedid.
\q2 Angi-binsaed-nued-amilegedi, mani-nuedba bur-nuedid.
\q1 
\v 20 Ani an Binsaed-Nikaguedi, igar-inniki-imaklegedba an nanaed,
\q2 igar-inniki-naboleged-igarba an gudiid.
\q1 
\v 21 Dule-an-sabesar-gudimalad an onasgudiid,
\q2 ibmar-nued-bukidar-nikubaliga an imakdiid.”
\s1 Binsaed-Nikagued-e-danikid
\q1 
\v 22 “Bab-Jehová ibmar-obinyed-iduale, bato anga burba-dulad uksad.
\q2 Amba-yoo ibmar-obinyegua, bato an-obinnisad.
\q1 
\v 23 Yoo neg-nagued-iduale, Bab-Jehová an-obinnisad.
\q2 Napneg amba yoo nagugua, sailanagi an-obinnisad.
\q1 
\v 24 An gwalulesgua, demar-wilagan amba yoo nagued.
\q2 An gwalulesgua, suke-dummagan amba yoo megmalad.
\q1 
\v 25 Yala-dummagan-nagued-idu, an gwalulesad,
\q2 yala-senigana-ambikued-idu, an gwalulesad.
\q1 
\v 26 Bab-Dummad amba yoo napneg-nasikgua,
\q2 amba yoo sapurmar-bukwad-nasikgua,
\q1 amba yoo napa-buru-napneg-sobsad-obinyegua,
\q2 bato an gwalulesad.
\q1 
\v 27 Bab-Dummad mogir-arad-nasiknaigua, a-idu, bato an gudiid.
\q2 Mogir-demarbo-abingunaid-nasiknaigua, a-idu, bato an gudiid.
\q1 
\v 28 Bab-Dummad mogirmar-nasiknaigua, a-idu, bato an gudiid.
\q2 Demar-wiladgine suke-dummagan-ogannonaigua, a-idu, bato an gudiid.
\q1 
\v 29 Bab-Dummad demar-mer-murega, demargala igar-abingunanaid-ilemaknaigua, a-idu, bato an gudiid.
\q2 Napneg-e-sailagan-mesnaigua, a-idu, bato an gudiid.
\q1 
\v 30 Bab-Dummadbogwa bela igar-ilemaknai an gusad.
\q2 Iba-ilibali weligwar an-itodidaed.
\q2 Bab-Dummad-asabinni iba-ilibali an wergudidaed.
\q1 
\v 31 Bab-Dummad-napneg-obinnisadgi an wergudiid,
\q2 dulemar-gudimaladba an wergudiid.”
\s1 Burba-dula-gudigued amie, melle burgwedgi binsae
\p 
\v 32 Ani an Binsaed-Nikaguedi sogbalid:
\q1 “Degisoggu, mimmigan, nue an-itomalo:
\q2 Dule an-igar-maidba-nanadiile, egi ise-nued binsalesad.
\q1 
\v 33 An-binsaed-uked be-nue-itomala,
\q2 binsaed-nikaa be damala, mer baisur-dakmala.
\q1 
\v 34 Dulemar-nabir-an-itodimalad, bane-bane an-yawagak-naba an-edarbedimalad,
\q2 we-dulemargi ise-nued binsalesad.
\q1 
\v 35 Ar dule an-aminonidibe, burba-dula-maid aminonikoed.
\q2 Bab-Jehová we-dulegi nabir binsanonikoed.
\q1 
\v 36 Dule an-obandibe, na dukin bonigan-amioed.
\q2 Dule isdar an-dakdibe, na burgwed-amied.”
\c 9
\s1 Binsaed-Nikagued, binsaedsulidaedse gochad
\q1 
\v 1 Binsaed-Nikagued na e-neg-sobsad,
\q2 e-buarmar walagugle (7) ogwichisad.
\q1 
\v 2 Binsaed-Nikagued iba-dummad onosad,
\q2 vino-nued imaknai gualid,
\q2 mese guakwaa siinai guarbalid.
\q1 
\v 3 Binsaed-Nikagued, e-garda-berbemalad barmisad,
\q2 neggwebur-siid-birise barmisad
\q2 agi iseedi gorbukwa gumalagar.
\q1 
\v 4 Dule-binsaedsurmaladga weyob sogded:
\q2 “Dule-binsaedsurmalad, anse be dagmala.
\q1 
\v 5 Dagmala, an-mas-nued gundamala,
\q2 an-vino-oburusad be gobdamala.
\q1 
\v 6 Ar be nabir-gudii gubimalale, be binsaedsuli-gudimalad osulomalargebed,
\q2 binsaed-nikaa be gudigumalargebed.
\q2 Deyobi, geb be nabir-gudii guoed.”
\s1 Dule-isgana-e-daed, degi, dule-binsaed-ibed-e-daed
\q1 
\v 7 “Be dule-gwen-nabir-dasurmaladse be gotedibe,
\q2 melle ibmar-isgana be imakye,
\q2 aka bese-urwega ese be goloed.
\q1 Ar be dule-isganase uluddibe,
\q2 aka bese-urwega guoed.
\q1 
\v 8 Dule-gwen-nabir-dasulidse, mer be gole.
\q2 Aka sae-be-dakega ese be goloed.
\q1 Dule-binsaed-nikadse be gotedibe, mer ibmar-isgana be imakye,
\q2 we-duledi, be-sabguoed.
\q1 
\v 9 Dule-binsaed-nikagued be odurdakele, a-dule, bur bule binsaed-nikaa naoed.
\q2 Dule-inniki-gudiid be odurdakele, a-dule, bur bule binsaed-nikaa naoed.
\b
\q1 
\v 10 ”Dule binsaed-nikarba-gubidibe, Bab-Jehová-dobekwaa-gudii guergebed,
\q2 Dule, Bab-Dummad-Isligwaled wisgubiele, ibmar-wisirba-gued na oyonaid.
\q1 
\v 11 Ar ani, Binsaed-Nikagued, angi be-ibagan-gudiid suitii guoed,
\q2 an-nukad deyob guoed.
\q2 Be-burba-dula-gudiid birgaba sugumai guoed.
\q1 
\v 12 Be nabir-binsaed-nikarbaddibe, we-binsaed-nikagued ibnuedga bega gunonikoed.
\q2 Be galagwensulidaeddibe, na be dukin nunmaked-itodii guoed.”
\s1 Binsaedsulidi, binsaed-satemaladse gornaid
\q1 
\v 13 Binsaedsulid, yaisur neg-gagadaed,
\q2 gwen ibmar wissulid,
\q2 gwen nabir binsasurbalid.
\q1 
\v 14 Binsaedsulid, e-neg-yawagak-naba sigoed.
\q2 Neggwebur-dogedgine, bela-e-dakmalagala, neggwebur-birigwagi sigoed.
\q1 
\v 15 Binsaedsulid, dule-igarba-gudidamaladse gorsidaed,
\q2 binsaedsate-gudidamaladse gorsidaed.
\q1 
\v 16 Weyob dule-binsaed-satemaladga sogdedaed:
\q2 “Be anse dagmala.
\q1 
\v 17 Dii-atursaaled bur-nued gobleged,
\q2 mas-nued arbakee-dukuar-gullegedi, bur-nued gulleged.”
\b
\q1 
\v 18 Ar we-dule-binsaed-satemaladdina, agi burgwed-amileged wissurmalad.
\q2 Ar dule-binsaedsulidba-ibsasmaladi, emisgindi neg-urba mamaid.
\c 10
\ms1 3. SALOMÓN-E-BINSAED-NIKAD
\mr (10:1–22:16)
\p 
\v 1 Salomón-e-binsaed-nuegan-narmaklesad:
\q1 Machi-binsaed-ibedi, e-bab-gwage-weligwar imaked.
\q2 Machi-binsaedsuliddina, e-nanga gwage-nunmaked-ukega gued.
\b
\q1 
\v 2 Ibmar-isganagi-mani-amilegedi, ibnuedga gusulid.
\q2 Ibmar-inniki-imaklegeddina, burgwedgi-san-onogega emar-imaked.
\b
\q1 
\v 3 Bab-Jehová, dule-innikidaedi, ukudmaada-gudiguega imaksulid.
\q2 Dule-isgana-sulibinsa-ibmarbina-itodimaladdi obaned.
\b
\q1 
\v 4 Dule-wiesailamaladi, wilegega gued.
\q2 Dule-gadi-arbamaladdina, e-ibmar ega nasgumai gued.
\b
\q1 
\v 5 Dule-binsaed-nikadaedi, yorgine ibmar-gwag-gullemalad na onmaked.
\q2 Dule ibmar-gwag-weleged-e-ibagangi gabedbi-gudiiddi, we-dule, na dukin binged-amied.
\b
\q1 
\v 6 Bab-Dummadi, dule-innikidaedgi, nued binsaed.
\q2 Gaya-isgana-sunmaklegedi, unnila dule-wiogega emar-imaked.
\b
\q1 
\v 7 Dule-innikidaed-e-nuggi nued sunmakledidaed.
\q2 Dule-isgana-e-nuggindina, bar-egi-binsalesulid.
\b
\q1 
\v 8 Dule-binsaed-ibed igar-maidba ibsaed.
\q2 Dule-binsaedsulidaeddi, e-sunmakedgi na dukin san-wioged.
\b
\q1 
\v 9 Dule-nuekwa-nanadiidi, bonisuli nanadiid.
\q2 Dule-galagwensuli-nanadiiddina, ibagwengi e-isgued magar-daklenonikoed.
\b
\q1 
\v 10 Dule ibmar-isgana-gunaid baisur-dakedi, emarga naibid-uked.
\q2 Dule-binsaedsulid e-sunmakedgi na boni-amioed.
\b
\q1 
\v 11 Dule-innikidaed-e-sunmakedi, dulega ibnuedga gued.
\q2 Dule-isgana-e-sunmakeddina, unnila yamo dule-ourwega sunmaked.
\b
\q1 
\v 12 Sae-emar-dakedgi, urwed amileged.
\q2 Sabgueddina, isgussuliyob emar-dake imaked.
\b
\q1 
\v 13 Dule-itoakwaa-gudiid-e-sunmakedgine, binsaed-nikagued amileged.
\q2 Dule-binsaedsulidaeddina, e-yargan-gordii gued.
\b
\q1 
\v 14 Dule-binsaed-ibegan, e-ibmar-wisigued bur bule amied.
\q2 Dule-binsaedsulidaeddina, e-sunmakedgi ukiagwar boni-onogedsedaed.
\b
\q1 
\v 15 Dule-mani-ibedi, manigi e-gangued siid.
\q2 Dule-wilegeddina, wileged ega boniga-gumogad.
\b
\q1 
\v 16 Dule-innikidaed-e-ibmar-imakedi, ega ibnuedga gued.
\q2 Dule-isgana-e-ibmar-imakeddina, ega ib-isganaga gued.
\b
\q1 
\v 17 Dule igar-odurdaklegedba-ibsaele, burba-dulad-nikaa gudii gued.
\q2 Dule igar-odurdaklegedba-ibsasuliddina, igar-isganaba naddaed.
\b
\q1 
\v 18 Dule-gakansaerbadi, sae-emar-daked odukued.
\q2 Dule-emargi-isdar-sunmakedi, binsaedsuli gued.
\b
\q1 
\v 19 Dule-gadi-sunmaked, gege isgued sogsuli gued.
\q2 Dule gwabinduku-bargaed-nikaddina, we-dule, dule-binsaed-ibedid.
\b
\q1 
\v 20 Dule-innikidaed-e-sunmakedi, mani-nuedyobid.
\q2 Dule-isgana-e-binsaeddina, ibnuedga gusulid.
\b
\q1 
\v 21 Dule-innikidaed-e-sunmakedi, dulemarga binsaed-nued uked.
\q2 Dule-binsaedsuliddina, noar-binsaedba na dukin burgwed-amied.
\b
\q1 
\v 22 Bab-Jehová-nued-emargi-binsaedi, ibmar-nuegan uked,
\q2 bukib-binsaed-igar egi maisulid.
\b
\q1 
\v 23 Dule-binsaedsulidaedi, na galagwensuli-gudiidgi wergudiid.
\q2 Dule-binsaed-nikarbaddina, e-binsaed-nikarbadgi na wergudimogad.
\b
\q1 
\v 24 Dule-isgana, na ibmar-dobgudiid egi aibined.
\q2 Dule-innikidaeddina, na ibmar-abediid ega nabir gued.
\b
\q1 
\v 25 Dule-isgana boni-dummagan-abin gwen gwisguosulid, yog-berguar gued.
\q2 Dule-innikidaeddina, boni-dummagan-abin gwen-sikirmaksuli degisadeguoed.
\b
\q1 
\v 26 Igi-ina-soled nugar-iii-imake,
\q2 igi waabali ibya aurmake,
\q2 deyobi, dule-wiegala e-dummadga gued.
\b
\q1 
\v 27 Dule-Bab-Jehováʼgi-dobekwaa-nanadiidi, ibagan-suitii gudii gued.
\q2 Dule-isganamardina, ibagan-suitii gudii gusulid.
\b
\q1 
\v 28 Dule-innikidaedgala, iba-nuegan ega danidaed.
\q2 Dule-isganagardina, iba-isganamar ega nonidaed.
\b
\q1 
\v 29 Bab-Jehová-Igar-Maidi, dule-innikidaedga bendakleged-igar gued.
\q2 Dule-ibmar-isgana-imakdimaladgardina, ega boniga binyed.
\b
\q1 
\v 30 Dule-innikidamaladi, bonigan-abin akar-guosulid.
\q2 Dule-isganamardina, we-napneggi gudii guosulid.
\b
\q1 
\v 31 Dule-innikidaed-e-sunmakedi, binsaed-nika sunmaked.
\q2 Dule-galagwensuli-sunmakeddina, gaya-maklemaloed.
\b
\q1 
\v 32 Dule-innikidaed-e-sunmakedi, yeer-ito dule-imaked.
\q2 Dule-isganamardina, galagwensuli ibmar-isganagi sunmaked.
\b
\c 11
\q1 
\v 1 Bab-Jehová nibir-innikisulid isdar daked.
\q2 Nibir-innikigwaddina, nued daked.
\b
\q1 
\v 2 San-odummolegedgi, nug-oicholeged danikid.
\q2 San-bipi-imaklegedgindina, binsaed-nikagued danikid.
\b
\q1 
\v 3 Dule-innikidaedgala, e-daed e-iduedga gued.
\q2 Dule-isganadina, na e-isguedgi dukin boni-amied.
\b
\q1 
\v 4 Igar-naboleged-ibagan-nonikile, be-ibmar-bukidar-nikadi be-bendakosurguoed.
\q2 Ibmar-inniki-imaklegedgindina, burgwed-igar amilesulid.
\b
\q1 
\v 5 Dule-innikidaedgala, e-ibmar-inniki-imakedi ega igar-nuegan oyoged.
\q2 Dule-isganadina, e-ibmar-isgana-imakdiidgi na dukin wilegoed.
\b
\q1 
\v 6 Dule-innikidamaladi, ibmar-inniki-imakedgi bendaklemalad.
\q2 Dule-isganamardina, sulibinsa-ibmarbina-sogedgi bipirmakmalad.
\b
\q1 
\v 7 Dule-isgana-burgwidele, na ibmar-edarbediid eba-yoggudoed,
\q2 na e-nug-dummarba-guedgi-gabdakdiid bela eba-bergudbaloed.
\b
\q1 
\v 8 Dule-innikidaedga, bonigan-noalile, akar-gusulid.
\q2 Dule-isganadina, boniganse ibitogoed.
\b
\q1 
\v 9 Dule-isgana, e-gwabin-dukugi dule-e-neg-nabamaid wioged.
\q2 Dule-innikidaeddina, e-binsaed-nued-nikarbadgi na san-onoged.
\b
\q1 
\v 10 Dule-innikidaed-nasgudele, bela dulemar wergued.
\q2 Dule-isgana-burgwiderdina, wergued-dummad nagued.
\b
\q1 
\v 11 Dule-innikidaedi, e-ibmar-nued-oyogedgi neggwebur-ogannoged.
\q2 Dule-isgana-e-gwabin-dukudina, neggwebur-wioged.
\b
\q1 
\v 12 Dule-inniki-binsasulidi, mesagwar emar-imaked.
\q2 Dule-itoakwaa-binsaeddina, na e-gwabin-bargaed wisid.
\b
\q1 
\v 13 Dule-yogasaar-sunmakedi, ibmar-soged odukusulid.
\q2 Dule-na-burba-bargaed-nikaddina, itoakwaa sunmaked.
\b
\q1 
\v 14 Negseleged-igar inniki-maisulile, dulemar galagwensuli guddaed.
\q2 Dule-binsaed-nued-dakmaladgi neg-inniki-seleged danikid.
\b
\q1 
\v 15 Be dule-akudaked-mani-gasad-anar, mani be bennukoye sogsale, na be dukin boni-amioed.
\q2 Be dule-akudaked-mani-gasad-anar, be mani bennukosurye sogsardi, be bonisuli gudii guoed.
\b
\q1 
\v 16 Ome gwage-nued-nikad-oyodiile, e-nug ogannoledii guoed.
\q2 Dule ibmar-imakerbaddi, unnila ibmar-bukidar-nika-gudii guoed.
\b
\q1 
\v 17 Dule gwage-nued-nikad-oyodiile, ega ibmar-nuedga gued.
\q2 Dule-sabsurdaeddina, na dukin nunmaked amied.
\b
\q1 
\v 18 Dule-isgana ibmar-isgana-imakedgi-ibmar-amied binsaledid.
\q2 Dule-ibmar-inniki-imakedgi-ibmar-amied, ega ibnuedga gued.
\b
\q1 
\v 19 Dule-innikidaed, burba-dulad-nika gudiid.
\q2 Dule-ibmar-isganabina-sogdiiddina, burgwed-igar ega ukleged.
\b
\q1 
\v 20 Bab-Jehová dule-gwage-isgana-nikadi, nabir-daksulid,
\q2 ar we-dulemar, ibmar-isganaginbi binsadimalad.
\q2 Bab-Dummad dule-inniki-gudiiddina yeerdaked.
\b
\q1 
\v 21 Dule-isgana, amba sabsur odurdaklegedsegad.
\q2 Dule-innikidamaladdina, sabsur-odurdaklegosurmalad.
\b
\q1 
\v 22 Olo-nued-sin-e-asugi-yoiyobi,
\q2 ome-yeerdakleged-binsaedsulidaed gued.
\b
\q1 
\v 23 Dule-innikidaedi, unnila ibmar-nued-imakedbi abeged.
\q2 Dule-isganamar-e-ibmar-abegeddina, unnila urwedginbi binsadiid.
\b
\q1 
\v 24 Dule-wilub-obicha-ibmar-ukedi, aka ibmar-bukidar ega ukleged.
\q2 Dule, mani-ganikid gwen-bennukdisulile, dule-wilegedga gudoed.
\b
\q1 
\v 25 Dule-wilub-obicha-ibmar-ukedi, ibmar ega nasgued.
\q2 Dule emar-ogannodiile, ogannoledii gumogoed.
\b
\q1 
\v 26 Dule ibmargwag-gulleged na ebi gaasa-imakele, dulemar egi isdar sunmaked.
\q2 Dule ibmargwag-gulleged emarga weligwaledgi manigi-ukdibe, dulemar egi nued binsaed.
\b
\q1 
\v 27 Dule ibmar-nued-imakedi, aimar-nued amied.
\q2 Dule ibmar-isganabina-gudiiddi, ibmar-isgana egi aibined.
\b
\q1 
\v 28 Dule e-ibmar-nikadgi-alakwaa-naidibe, we-dule galakudoed.
\q2 Dule-innikidaeddina, sapi-durbamakgwichidyob gudoed.
\b
\q1 
\v 29 Dule dukin e-neguya-oichogedi, na e-neguya-obelogega imaked.
\q2 Dule-binsaedsulidaeddi, dule-binsaed-ibed-e-maiga gudii gued.
\b
\q1 
\v 30 Dule-innikidaed-e-ibmar-imakedi, nued-gudii e-imaked.
\q2 Dule, dule-bamalad-ibmar-nued-imake-saedi, dule-binsaed-ibedid.
\b
\q1 
\v 31 Dule-innikidaedga, we-napneggi ibmar-nued ukleged.
\q2 Dule-isganamar-bulesunna, ar e-ibmar-isgana-imakdiidba we-napneggi sabsur-odurdaklemaloed.
\b
\c 12
\q1 
\v 1 Dule igar-nuegan-mamaidbina-itogerbadi, binsaed-nikaguedbina nue-soged.
\q2 Dule igar-nuegan-mamaid-isdar-dakeddi, dule-binsaedsulidaedid.
\b
\q1 
\v 2 Dule-nueddaedgi Bab-Jehová nabir-binsaed.
\q2 Dule-galagwensuli-binsaeddi, Bab-Dummadse apor-gued.
\b
\q1 
\v 3 Dule ibmar-isgana-imakedgi gargangued amiosulid.
\q2 Dule-innikidaed-e-gargangueddi, gwen gigli guosulid.
\b
\q1 
\v 4 Ome-innikidaedi, e-sui-nug odummoged.
\q2 Ome-galagwensulidaeddina, e-sui-nug oichoged.
\b
\q1 
\v 5 Dule-innikidaed-e-igarmar-amiedi, ibmar-inniki-imakedgi binsaed.
\q2 Dule-isgana-e-sunmakeddina, unnila emar-yardakedgi sunmaked.
\b
\q1 
\v 6 Dule-isgana-e-sunmakedi, emar-yardakar sunmaked, ablis-eogedgi sunmaked.
\q2 Dule-nuegan-e-sunmakeddina, dulemar egi bendakleged amied.
\b
\q1 
\v 7 Bab-Dummad sulibinsa dule-isganamar-imaked, degidba berguddamalad.
\q2 Dule-innikidaed-e-mimmigandina, gwen-berguosulid.
\b
\q1 
\v 8 Dule e-binsaed-nikaguedba, e-nug odummoleged.
\q2 Dule-gwage-isgana-nikaddina, isdar dakleged.
\b
\q1 
\v 9 Dule-san-dummarba-imaked-masgunned-satedba,
\q2 bur nuedid, dule-mesagwar-gudiid wis-e-mai-ega-ibmar-imaked-nikar.
\b
\q1 
\v 10 Dule-innikidaedi, na e-moli-nikad nued akwediid.
\q2 Dule-isganadina, baisur e-ibmar daked.
\b
\q1 
\v 11 Dule-sapurba-gadi-arbaedi, mas nikagudaed.
\q2 Dule, dule-gegeganaba-gudiiddina, binsaedsuli gued.
\b
\q1 
\v 12 Ibmar-isganabina-surbinsa-itolegedi, dule-isganaga boniga gued.
\q2 Dule-innikidaeddina, sapi-nued-durbamakgwichiyob gued.
\b
\q1 
\v 13 Dule-isgana na dukin gakansaar-sunmakedgi boni-amied.
\q2 Dule-innikidaeddina, boniganse galakusulid.
\b
\q1 
\v 14 Dulemar-na-e-sunmakedba ibmar abingaed.
\q2 E-ibmar-imakedba ibmar abingabalid.
\b
\q1 
\v 15 Dule-binsaedsulidaed na e-igar inniki-maiye bidaed.
\q2 Dule-binsaed-nikarbaddina, unaleged-igarba ibsaed.
\b
\q1 
\v 16 Dule-binsaedsulidaedi, baisursunna uluddaed.
\q2 Dule-itoakwaadaeddina, egi-dule-urwed igi-barsaye sogdaed.
\b
\q1 
\v 17 Dule-inniki-gudiid ibmar-napiragwad sunmaked,
\q2 dule ibmar-gusad-gakansaar-barsogeddina, unnila gakanbi-sunmaked.
\b
\q1 
\v 18 Dule-yogasaar-sunmakedi, es-suidse-naibigulegeyob emar-imaked.
\q2 Dule-binsaed-nikarbad-e-sunmakeddina, ina-nuedyob gued.
\b
\q1 
\v 19 Dule-ibmar-napiragwad-sunmakedi, sereddii megoed.
\q2 Dule-gakanbi-sunmakeddina, sikwas gudii guoed.
\b
\q1 
\v 20 Dule-galagwensuli-binsaedi, emar-yardakedgi binsaed.
\q2 Dulemar-neg-bogidik-imakmaladdina, werguleged uked.
\b
\q1 
\v 21 Dule-innikidaedi, boniganse akar-guosulid.
\q2 Dule-isganamardina, boniganse ibitomaloed.
\b
\q1 
\v 22 Bab-Jehová dule-gadi-gakansamaladi, gwen-nabir daksulid.
\q2 Dule-inniki-gudiiddi, nued daked.
\b
\q1 
\v 23 Dule-binsaed-nikarbadi, ibmar-wisirba na san-imaksulid.
\q2 Dule-binsaed-sulidaeddina, galagwensulidaed na oyoged.
\b
\q1 
\v 24 Dule-gadi-arbaedi, negseoedid.
\q2 Dule-wiegaladina, maiga gudii guoed.
\b
\q1 
\v 25 Sulibinsa-itogedi, dule-gwage wioged.
\q2 Gaya-nueddina, emar-weligwar imaked.
\b
\q1 
\v 26 Dule-innikidaedi, binsaed-nued emarga uked.
\q2 Dule-isganadina, e-isguedgi emar-oichoged.
\b
\q1 
\v 27 Dule-wiegala masgunnedsuli gudidaed,
\q2 dule-arbaegaladina, ibmar-nikagu daed.
\b
\q1 
\v 28 Ibmar-inniki-imakleged-igargi undar-dula-gudiid amileged,
\q2 we-igargine burgwed-igar amilesulid.
\b
\c 13
\q1 
\v 1 Machi-binsaed-ibed, e-bab-ega-binsaed-uked nabir-itoged.
\q2 Machi-uayasuliddina, ega-binsaed-uked isdar-itoged.
\b
\q1 
\v 2 Dule-inniki-sunmaked, na e-sunmakedgi ibnued amidii guoed.
\q2 Dule-emargi-yolemaladdina, unnila urwedginbi gudii guoed.
\b
\q1 
\v 3 Dule-na-e-gwabinduku-nabir-bargaed, na dukin e-san bendakdiid.
\q2 Dule-na-e-gwabinduku-wissur-bargaeddina, na dukin e-san wioged.
\b
\q1 
\v 4 Dule-wiegala, na e-ibmar-abediid gwen-abingaosulid.
\q2 Dule-gadi-arbaeddina, na e-ibmar-abediid abingaedsegad.
\b
\q1 
\v 5 Dule-innikidaed gakan-igar gwen nabir-daksulid.
\q2 Dule-isganadina, binged-amiedid, degine, emar-wiogedid.
\b
\q1 
\v 6 Ibmar-inniki-imakleged dule-inniki-gudiid-bendakedid.
\q2 Ibmar-isganadina, dule-isgudiid-wiogega imaked.
\b
\q1 
\v 7 Abar-dulemar mani-nikayob gudidamalad,
\q2 degi-inigwele, ibmardi gwen nikasurmalad.
\q1 Abar-dulemar ibmarsuliyob gudidamalad,
\q2 degi-inigwele, ibmardi nue-nika gudidamalad.
\b
\q1 
\v 8 Dule-mani-ibed mani-nikadbali, sunna dule-isganase galesar gudiid.
\q2 Dule-wilegeddina, we-boni nikasulid, ar dulemar bai daksulid.
\b
\q1 
\v 9 Dule-innikidaed-e-gudiidi, gwallu-gaeyob weligwaled oyodiid.
\q2 Dule-isgana-gudimaladdina, negsichid-naiyob gued.
\b
\q1 
\v 10 Dule-san-dummarba-imaked emarga urwed-amied.
\q2 Dule-na-san-bipi-imakeddi, binsaed-nikaguedba gudiid.
\b
\q1 
\v 11 Mani-yogasaar-amileged baisursunna-berguddaed.
\q2 Dule-mani-saboged-wisiddina, binnasdikii ibmar-nikumaidaed.
\b
\q1 
\v 12 Ibmar-edarbelediid-abingalesulile, gwage-nunmaked emarga uked.
\q2 Ibmar-edarbelediid-abingalenonikile, weligwaled anmarga uked.
\b
\q1 
\v 13 Dule igar-soglemaid isdar-dakele, na dukin boni-amied.
\q2 Dule igar-soglemaidba ibsaele, ibmar-nued ega ukleged.
\b
\q1 
\v 14 Dule-binsaed-ibed-e-ibmar-odurdaked, burba-dulad emarga uked.
\q2 Dule-binsaed-ibed-e-ibmar-odurdaked, burgwed-igargi nabir emar-bendakbalid.
\b
\q1 
\v 15 Unaleged-igar-innikigwad-uklegedi, nabir-itole neg-imaked.
\q2 Dule-igar-maidba-ibsadisuliddina, boni-dummad na abgadii guoed.
\b
\q1 
\v 16 Dule-itoakwaadaed, binsaed-nued-nikadgi ibmar imaked.
\q2 Dule-binsaed-sulidaeddina, galagwensulidaed na oyoged.
\b
\q1 
\v 17 Dule-gayaburba-berbeged-isgana, boni emarga amied.
\q2 Dule-gayaburba-berbeged-nueddina, ibmar-nued emarga uked.
\b
\q1 
\v 18 Dule, unaleged-igar isdar-dakele, dule-wilegedga gued, e-nuggi dodolebalid.
\q2 Dule, unaleged-igar nabir-itogele, nug-dummarba nikuoed.
\b
\q1 
\v 19 Ibmar-abeleged-abingalesale, emar-gwage-weligwar imaked.
\q2 Ibmar-isganagi-banguleged, dule-binsaedsulidga gwen nabir-nosulid.
\b
\q1 
\v 20 Dule, dule-binsaed-nued-nikadba akaele, binsaed-nued-nika gumogoed.
\q2 Dule, dule-binsaedsulidba akaele, na dukin boni-amied.
\b
\q1 
\v 21 Dule-isgana, ibmar-isganase bargaledidaed.
\q2 Dule-innikidamaladdina, ibmar-nuegan abingaed.
\b
\q1 
\v 22 Dule-nued-daed e-wagangala, ibmar-nuegan obeged.
\q2 Dule-isgana-e-ibmar-nikaddina, dule-innikidaedga obeged.
\b
\q1 
\v 23 Dule-wilemalad-e-nainugi, nue-ibmar sanmaked.
\q2 Degi-inigwele, dule-ibmar-isgana-imakedba, bela we-ibmar yoggued.
\b
\q1 
\v 24 Dule, e-machi-odurdaksulile, e-machi-isdar-dakeyob gued.
\q2 Dule, e-machi-sabele, e-machi yolenonikile, igar-maidba odurdakoed.
\b
\q1 
\v 25 Dule-innikidaed, nue-immee masgunned.
\q2 Dule-isganadina, amba ukudmaada gudii guoed.
\b
\c 14
\q1 
\v 1 Ome-binsaed-ibed e-neguya onasgued.
\q2 Ome-binsaed-sulidaeddina, na dukin e-neguya obeloged.
\b
\q1 
\v 2 Dule-inniki-nanadiid, Bab-Jehová-sogedba gudiid.
\q2 Dule-igar-isganaba-gudiiddina, isdar Bab-Dummad-dakdiid.
\b
\q1 
\v 3 Dule-binsaedsulidaed-e-sunmaked, unnila na san-odummogedgi sunmaked.
\q2 Dule-binsaed-ibeddina, e-sunmakedgi bendakleged.
\b
\q1 
\v 4 Dule moli-bebe-nikad-satele, e-ob-aila binsa ollo sigoed.
\q2 Ar moli-bebe-nikad-e-arbaedgi masgulleged nue-amileged.
\b
\q1 
\v 5 Dule-ibmar-gusad-barsoged-innikigwad, wissur-gakansaed.
\q2 Dule-ibmar-gusad-barsoged-napiragwadsuliddi, unnila gakangi sunmaked.
\b
\q1 
\v 6 Dule-galagwensulidaedi aisaar binsaed-nued nikubi gudidaenad, degi-inigwele, gwen amiosur guoed.
\q2 Dule-binsaed-nued-nikarbaddina, baisursunna ibmar durdaked.
\b
\q1 
\v 7 Dule-binsaedsulidaedgi be bannaba gudisae,
\q2 ar a-dulegi, gwen be binsaed-nued amiosulid.
\b
\q1 
\v 8 Dule-itoakwaadaedi, binsaed-nued-nikadba na magar neg-itoge gudiid.
\q2 Dule-binsaedsulidaeddina, na e-binsaedgi yardaklediid.
\b
\q1 
\v 9 Dule-binsaedsulidaedi, unnila isguedgi burgudiid.
\q2 Dule-nuedmargindina, Bab-Dummad nued-binsaed.
\b
\q1 
\v 10 Dule, na sana-walagwen e-nunmaked magar itoged.
\q2 E-wergued, dule-baid eba itogosulid.
\b
\q1 
\v 11 Dule-isgana-e-neguya bela bergudoed.
\q2 Dule-innikidaed-e-neguyadina, nasgumai gudoed.
\b
\q1 
\v 12 Imbagwenale, dule na e-ibmar-imakedi, inniki-imakye bidaed,
\q2 degi-inigwele, e-ibmar-imakedgine, sunna burgwed-igar amied.
\b
\q1 
\v 13 Imbagwenale, alled-abalagine, gwage-nunmaked itoleged.
\q2 Imbagwenale, weligwar-itogedgine, nunmak itoledabalid.
\b
\q1 
\v 14 Dule-binsaedsulidaedi, na e-igar-isganagi wergudiid.
\q2 Dule-nued-daeddina, na ibmar-nued-imakedgi wergudimogad.
\b
\q1 
\v 15 Dule-baisur-binsaedi, baisursunna binsaed-galeged.
\q2 Dule-itoakwaa-binsaeddina, ibmar-imaked-iduale itoakwaa binsaed.
\b
\q1 
\v 16 Dule-binsaed-ibedi, ibmar-isgana-abin dobekwaa nanaed,
\q2 igar-isganagi bachikii gudidaed.
\q1 Dule-binsaedsulidaeddina, na san-buled imaked,
\q2 gwen-akar-guosurye na binsadabalid.
\b
\q1 
\v 17 Dule-baisursunna-urwedi, galagwensuli ibmar imaked.
\q2 Dule-itoakwaa-binsaeddina, na san-bargaed oyoged.
\b
\q1 
\v 18 Dule-baisur-binsaedi, unnila galagwensur-binsaleged abingaoed.
\q2 Dule-itoakwaa-binsaedgala binsaed-nikarbad uklegoed.
\b
\q1 
\v 19 Dule-isganamar, dule-nued-asabin yokorgi-sindigar sigmaloed.
\q2 Dule-isganamar, dule-innikidamalad-e-igar-itogedgi, gan-bipigi sii gumaloed.
\b
\q1 
\v 20 Dule-wilegedi, e-aimarbela isdarsunna dakdamalad.
\q2 Dule-mani-ibeddina, bukidar e-aimar nikad.
\b
\q1 
\v 21 Dule, dule-mesagwar-imakdiile, bato isgusye sogleged.
\q2 Dule, dule-wileged-sabgudiile, we-dulegi ise-nued binsalesad.
\b
\q1 
\v 22 Dule-galagwensuli-binsadiid igar-noar imaked.
\q2 Dule-ibmar-inniki-imakdiiddi, sabgued-igar amied, igar-innikigwad amibalid.
\b
\q1 
\v 23 Nue-arbalegedgine, ibmar-nuegan amileged.
\q2 Binsa-gayaginbi-soglegeddina, wilegedga emar-imaked.
\b
\q1 
\v 24 Dule-binsaed-ibedi, e-binsaed-nikaguedgi e-nug dungued.
\q2 Dule-binsaedsulidaeddina, e-binsaedsulidaedgi na e-wileged amied.
\b
\q1 
\v 25 Dule-ibmar-gusad-barsoged-innikigwadi, burgwedgi nue-emar-bendaked.
\q2 Dule-ibmar-gusad-barsoged-napiragwadsuliddi, unnila gakansaedba emar-wioged.
\b
\q1 
\v 26 Bab-Jehováʼgi-dobekwaa-nanalegedgine, bela-bela bendakleged siid.
\q2 E-mimmigana, Bab-Dummadgi bendakleged nue-amimarmogad.
\b
\q1 
\v 27 Bab-Jehováʼgi-dobekwaa-nanalegedgine, nued-gudiguleged amileged.
\q2 Dule-deyob-gudiile, muis burgosulid.
\b
\q1 
\v 28 Rey-e-garganguedi e-dulemar-bukidarad-nikadba siid.
\q2 Dule-nuga-nikadi e-dulemar-satedba, bingesaar dakleged, agi nollomaksiid.
\b
\q1 
\v 29 Dule baisursunna-urwesulidi, magasar neg-itoged.
\q2 Dule-bargaedsuli-gudiiddina, galagwensuli-binsaed yoga-oyogar imaked.
\b
\q1 
\v 30 Dule-gwage-bogidik-nikadi, nued-gudii gued.
\q2 Dule-nobgueddina, bela na san-oichoged.
\b
\q1 
\v 31 Dule-wileged-apor-imakedi, Bab-Dummadgine-yolenaid.
\q2 Dule-wileged-sabgudiiddina, Bab-Dummad-e-nug odummodiid.
\b
\q1 
\v 32 Dule-isgana e-ibmar-isgana-imakedgi boni-amied.
\q2 Dule-innikidaeddina, e-daedgine na san-bendaked amied.
\b
\q1 
\v 33 Dule-binsaed-ibed-e-gwagegine binsaed-nikagued naid.
\q2 Dule-binsaedsulidaeddina, binsaed-nikagued magar-itosulid.
\b
\q1 
\v 34 Ibmar-inniki-imaklegedgi neggwebur ogannolesiid.
\q2 Isguedgindina, neggweburmar wiolesiid.
\b
\q1 
\v 35 Rey, e-mai-itoakwaa-gudiidgi, nued-binsaed oyoged.
\q2 Dule-e-nuggi-dododiidgardina, e-urwed oyoged.
\b
\c 15
\q1 
\v 1 Binnalegwadgi dule-urwenaid-abin-imakedi, urweleged bargaleged.
\q2 Urwedgi dule-urwenaid-abin-imakeddi, urweleged baligannoged.
\b
\q1 
\v 2 Dule-binsaed-ibed-e-sunmakedi, binsaed-nuegan uked.
\q2 Dule-binsaedsulidaed-e-sunmakeddina, binsaed-isgana uked.
\b
\q1 
\v 3 Bab-Jehová bela negdakmaid.
\q2 Dule-nuedgi nakulemaid, dule-isganagi nakulemaibalid.
\b
\q1 
\v 4 Gayaburba-gwage-gadi-gadi-imakedi, ina-nuediyobid.
\q2 Gayaburba-isganadina, emarga gwage-naibid uked.
\b
\q1 
\v 5 Dule-binsaedsulidaedi, e-bab-e-unaed isdarsunna itodaed.
\q2 Dule-e-bab-e-unaed-nabir-itogeddina, itoakwaadaed oyoged.
\b
\q1 
\v 6 Dule-innikidaed-e-neggine, ibmar-bukidar nikaguad.
\q2 Dule-isganadina, na e-ibmar-bukidar-amiedgine, bonigan ega noed.
\b
\q1 
\v 7 Dule-binsaed-ibegan-e-sunmakedgi, binsaed-nuegan ainied.
\q2 Dule-binsaedsulidamaladdina deyob sunmaksulid.
\b
\q1 
\v 8 Bab-Jehová dule-isgana-ega-ibmar-ogumakar-ukedi, gwen nabir-daksulid.
\q2 Bab-Jehová, dule-innikidaed-ese-goledgindina, yeer itodaed.
\b
\q1 
\v 9 Bab-Jehová dule-isgana-e-daed gwen nabir-daksulid.
\q2 Dule-igar-inniki-imakdiiddina, nue-sabed.
\b
\q1 
\v 10 Dule-galagwensuli-gudiidga, sabsur-odurdakleged-igar maid.
\q2 Dule-odurdakleged-igar-isdar-dakdiiddi, unnila oburgweleged-igar ega maid.
\b
\q1 
\v 11 Bab-Jehováʼgi, neg-uan dukumaisulid,
\q2 burgwed-igar dukumaisurbalid.
\q2 Degite, ¡dule-gwage-bule-sunna!
\b
\q1 
\v 12 Dule-gwen-nabir-dasulidi, dule-ese-goled isdar-itodaed,
\q2 degite, dule-binsaed-ibedbali, akasurbalid.
\b
\q1 
\v 13 Gwage-weligwaledi, wagargi magar dakleged.
\q2 Gwage-wile-itogedi, wagargi magar daklebalid.
\b
\q1 
\v 14 Dule-magar-neg-itogedi, unnila binsaed-nuedbina gudidaed.
\q2 Dule-binsaed-sulidaeddina, ibmar-galagwensulid na e-masgunnedyob imakdiid.
\b
\q1 
\v 15 Dule-wile-itodiidgala, iba-nuegan gwen naisulid.
\q2 Dule-weligwaledgardina, bane-bane ibabi neg-naid.
\b
\q1 
\v 16 Dule ibmar-bukidar-nikad-ular, sulibinsa-itodiidba bur nuedid,
\q2 dule wis-ibmar-belagwa-nika-gudiir, Bab-Jehová-dobekwaa-gudigubalir.
\b
\q1 
\v 17 Isdar-itogedgi, moli-san-isesaar-gunsiidba bur nuedid,
\q2 sabedgi wis mas-yoaledbi gunsiir.
\b
\q1 
\v 18 Dule-gadi-urwedi, emarga gadi-urwed amied.
\q2 Dule na san-bargaed-nikaddina, neg-bogidik imaked.
\b
\q1 
\v 19 Dule-wiegalaga neg ikoganbi gued.
\q2 Dule-innikidaedgardina, akwan-eogaleyob igar-maid.
\b
\q1 
\v 20 Machi-binsaed-ibedi, e-bab-weligwar imaked.
\q2 Machi-binsaedsulidaeddina, e-nan-mesagwar imaked.
\b
\q1 
\v 21 Dule-binsaedsulidaedi, e-binsaedsulidba na wergudiid.
\q2 Dule-magar-neg-itogeddina, na dukin e-daed-gudiid nudaked.
\b
\q1 
\v 22 Binsaed-nuegan-satele, igarmar apurnonidaed.
\q2 Dule-binsaed-nuegan-bukidaradbali, neg nasguddaed.
\b
\q1 
\v 23 Ibmar-nued-soglegedi yeer-itole emar-imaked.
\q2 Ibmar-nued-soglegedi, e-ibagi-sogledele, bur bule nuedid.
\b
\q1 
\v 24 Dule-binsaed-ibedi, igar-nueganba nakwemaid.
\q2 Degidbali, burgwisale, odurdakleged-neg dakosulid.
\b
\q1 
\v 25 Bab-Jehová, dule-san-dummarba-imakdiid-e-neg obeloged.
\q2 Omegan-ei-sui-burgwismalad e-napaneg-abingunanaiddi, Bab-Jehová akar-guega imakosulid.
\b
\q1 
\v 26 Bab-Jehová, dule-isgana-e-binsaed isdarsun-daked,
\q2 gayaburba-nuegandi, nued itoged.
\b
\q1 
\v 27 Dule-ibmarbina-suli-binsa-itogedi e-neguyaga boni-uked.
\q2 Dule manigi-binsaed-galeged-isdarsun-dakeddina, nued-gudii gued.
\b
\q1 
\v 28 Dule-innikidaedi, emar-abin-imaksokalile, ise-binsaar imaked.
\q2 Dule-isganadina, e-sunmaked ibmar-isganaginbi sunmaked.
\b
\q1 
\v 29 Bab-Jehová dule-isganamar-itosulid.
\q2 Dule-innikidaed-ese-goterdi, nue-itoged.
\b
\q1 
\v 30 Dule, weligwaledba-emar-dakedi, emar-gwage-weligwar imaked.
\q2 Gayaburba-nuegana, emar-niga-ogannoged.
\b
\q1 
\v 31 Dule, emar-ega-ibmar-nabir-sogedi nabir-itogele,
\q2 dule-binsaed-ibegan-abargi gudii guoed.
\b
\q1 
\v 32 Dule, odurdakleged-igar isdarsunna dakele, na dukin isdarsunna dakdiid.
\q2 Dule, odurdakleged-igar nued-abin-gaele, ibmar-nue-wisidga gued.
\b
\q1 
\v 33 Bab-Jehováʼgi-dobekwaa-nanalegedgi binsaed-nikagued amileged, egi odurdakleged-igar-nued amilebalid.
\q2 Ar dule na e-nug-odummoleged-abegele, na san-bipii imakgwelergebed.
\b
\c 16
\q1 
\v 1 Dule na e-gwagegine-soged, ibmar-imakoye,
\q2 degi-inigwele, ibmar-imakleged Bab-Jehováʼse bergusiid.
\b
\q1 
\v 2 Dule na bela-ibmar-imakedi, inniki-imakdiiye-bied,
\q2 degi-inigwele, Bab-Jehová sogoed, bule ibmar-inniki-imakdidibe.
\b
\q1 
\v 3 Be ibmar-imakbied, Bab-Jehováʼga be uke,
\q2 deyob be imakele, nabir bega igarga gunonikoed.
\b
\q1 
\v 4 Bab-Jehová-ibmar-imakedi, igar-nikaa imaked.
\q2 Ar dule-isganagase-bakale, odurdakleged-iba ega imaklesmogad.
\b
\q1 
\v 5 Bab-Jehová dule-na-san-buled-imakdiid gwen-nabir-daksulid,
\q2 ar we-dule sogedba-odurdaklegedsegad.
\b
\q1 
\v 6 Isgued-nudaklegegala, unnila sabgued-nikadba, degi, innikigwadba nudakleged.
\q2 Bab-Jehová-dobekwaa-gudiidgine, isguedgi banguleged.
\b
\q1 
\v 7 Bab-Jehová dule-e-daed nued-dakele,
\q2 dule-e-isdarmaladse-bakale, ebo-nued-gudii imakbalid.
\b
\q1 
\v 8 Dule ibmar-isgana-imakdiidgi ibmar-bukidar-amied,
\q2 aba bur nuedid, dule ibmar-inniki-imakdiidba wis-belagwasaar-gudii gued.
\b
\q1 
\v 9 Dule ibmar-imakoye na sogedi,
\q2 Bab-Jehová-sogedba we-dulega ibmar-gumai guoed.
\b
\q1 
\v 10 Ar rey-sogdibe, ibmar deyob guoye,
\q2 rey-igar-mesnonikidi irgwen-sogar meged.
\b
\q1 
\v 11 Nibir-innikigwadi, nibir-e-bate-sogedbalid, Bab-Jehováʼgadid,
\q2 ar Bab-Dummad bela ibmar-wilubsaleged imaksad.
\b
\q1 
\v 12 Rey, ibmar-isgana-imaklegedi nabir-daksulid,
\q2 ar e-garganguedi, unnila ibmar-inniki-imaklegedgi siid.
\b
\q1 
\v 13 Rey, gayaburba-innikigwad-sunmakleged yeer daked,
\q2 dule-napiragwad-sunmakedi, nued dakbalid.
\b
\q1 
\v 14 Rey-e-urwedi, burgwed-igar-daged obared.
\q2 Dule-binsaed-ibeddina, rey-e-gwage bogidik imaked.
\b
\q1 
\v 15 Rey weligwaledba-emar-dakedi, igar-nuegan-oyoged.
\q2 Rey-emargi-nued-binsaedi, dii-wieyob gued.
\b
\q1 
\v 16 Or-nued-nikuedba, binsaed-nued-nikued bur-nuedid.
\q2 Mani-nikuedba, ibmar-nue-wisigued bur-nuedid.
\b
\q1 
\v 17 Dule-innikidaedi ibmar-isganaba nanadisulid.
\q2 Dule-deyob-gudiidi na san-burba-bendakdiid.
\b
\q1 
\v 18 San-odummolegedgine, ibitoged-igar maid.
\q2 San-dummarba-imaklegedgine, yoleged-igar maid.
\b
\q1 
\v 19 Dule san-dummarba-imakdimalad-abargi ibmar-nuegan-abingaedba,
\q2 bur nuedid, dule-mesagwar-gudimalad-abargi wilesakwasaar-gudii gued.
\b
\q1 
\v 20 Dule gayaburba-itogedi ibmar-nuegan amied.
\q2 Dule Bab-Jehováʼgi bengudisulile, ise-nued egi binsalesad.
\b
\q1 
\v 21 Dule-binsaed-ibed-sunsogedgindi, sogleged, dule-gurgin-nued-nikadye.
\q2 Dule gayaburba-nuedgi-sunmaked, dule-eba-daega imaked.
\b
\q1 
\v 22 Dule-itoakwaa-ibmar-imakedi, undar-gudiguoed.
\q2 Dule-binsaedsulidaeddina, e-binsadiidgi na sabsur-odurdaklegoed.
\b
\q1 
\v 23 Dule-binsaed-ibed-sunsoged, e-sunmaked nabir na bargaed.
\q2 E-gayaburba-sunmakedgine, ibmar-nuegan-wisguleged onisiid.
\b
\q1 
\v 24 Gayaburba-nuegan achanis-malegedyobi, gwage-ulubgine yeer-ito emar-imaked.
\q2 Gayaburba-nuegan, san-burbagala ina-nuediyob gued.
\b
\q1 
\v 25 Imbagwenale, dule, na e-ibmar-imakedi inniki-imakye bidaed,
\q2 degi-inigwele, e-ibmar-imakedgine, sunna burgwed-igar amied.
\b
\q1 
\v 26 Dule-arbadiid mas-gunnega arbaergebed,
\q2 ar e-ukumaad-itoged oarbaega-imaked.
\b
\q1 
\v 27 Dule-isgana, unnila igar-isgana-imaked amidiid.
\q2 E-sunmakedi, igi-soo-ibmar-ogumake, deyob emar-imaked.
\b
\q1 
\v 28 Dule-isgana, emarga urwed-amied.
\q2 Dule-binsa-yogasaar-ibmar-sogedi, ai-nuegan-mamaredid.
\b
\q1 
\v 29 Dule-gadi-urwed e-ai-yardakerbad,
\q2 e-ai-galagwensulidae imaked.
\b
\q1 
\v 30 Dule-ibyagi-sunmaked, ibmar-isgana-imakedgi binsadaed.
\q2 Dule-gaya-gunnar-imaked, ibmar-isgana bato imaksa gudiid.
\b
\q1 
\v 31 Dule-selebagus-nono-sipu-gudiidi, ologurgin-nikayob gudiid.
\q2 Ibmar-inniki-imakdiidbali, e-nug ogannolediid.
\b
\q1 
\v 32 Dule-na-niga-gandik-oyodiidba bur-nuedid,
\q2 dule-na-e-gwage-bargaed-nika gudigued.
\q1 Dule gandikidgi neggwebur-suedba bur nuedid,
\q2 dule na san-bargaed-wisi gudigued.
\b
\q1 
\v 33 Ibmar-imaklegegala, wilub-daklegar imakleged.
\q2 Degi-inigwele, ibmar-guoed, Bab-Jehováʼse bergusiid.
\b
\c 17
\q1 
\v 1 Urwed-abargi san-nued-gunsiidba
\q2 bur-nuedid, weligwaledgi madu-dutusulid-gunsiir.
\b
\q1 
\v 2 Mai-binsaed-ibedi, machi-galagwensurdaed-e-dummadga gudiguoed.
\q2 Mai-binsaed-ibedi, machi-galagwensurdaed-e-gwenadganba e-babgan-ega-ibmar-obesad nikumogoed.
\b
\q1 
\v 3 Olo, soogi wilubdakleged, bormo-crisolʼgi mani wilubdaklebalid.
\q2 Dule-e-binsaeddina, Bab-Jehováʼse wilubdaklemogad.
\b
\q1 
\v 4 Dule-isgana, dulemar-gaya-isgana-sunmakedba ibsaed.
\q2 Dule-gakansaegwa, dule-gaya-isgana-sogedba gudiid.
\b
\q1 
\v 5 Dule dule-wilegedgi-dododiidi, Bab-Dummadgi dodoged.
\q2 Dule, dule-wileged-naibi-itodiidga-allediidi, odurdaklegedsegad.
\b
\q1 
\v 6 Dad-e-werguedi, e-wagan-nikadgi siid.
\q2 Mimmigan-e-werguedi, e-babgangi simogad.
\b
\q1 
\v 7 Dule-binsaedsulidaedi, gaya-nuegan-sunmakedi egi nosulid.
\q2 Dule-dummagan-negsemamaid, gakansaar-sunmakedi, egi nosurmogad.
\b
\q1 
\v 8 Dule manigi-emar-binsaed-gaed-gudiidi, na binsadaed, ede, ina-nika-gudiiye.
\q2 Ar deyobi, yogasaar ibmar-amididaed.
\b
\q1 
\v 9 Dule, dule-egi-isgusad-egi-isgussuliyob-dakedi, ai-nikued-igar ogannoged.
\q2 Ar dule, dule-egi-isgusadga ibmar gannar-gannar-obarele, aimar-isdaradga imaked.
\b
\q1 
\v 10 Dule-itoakwaa-binsaedga sabsur-ibmar-soglegele, irgwen-itogaled.
\q2 Dule-binsaedsulidaeddina, molidubgi ila-dulataledse (100) bibyolenaidibe, amba itosulid.
\b
\q1 
\v 11 Dule-uayasatedaedi, gusgu urwed-amididaed.
\q2 Ibagwengine, dule-eba-bur-egi-obined abingunonikoed.
\b
\q1 
\v 12 Dule-binsaedsulidaed e-ibmar-imakedgi-alamakdiid-abinguedba
\q2 bur-baisulid, wiob-urwediid-abingued.
\b
\q1 
\v 13 Dule, ibmar-nued-ega-imaklesad-ular, ibmar-ichakwa-ukdibe,
\q2 e-neguyagine, bipisaale bonigan berguosulid.
\b
\q1 
\v 14 Dule, urwed-onoye-sogele, diwar-dummad-noedyobi, dummad-neg-gagaed.
\q2 Degisoggu, bur-nuedid urwedgi yog-banguar-imaked.
\b
\q1 
\v 15 Bab-Jehová ibmar-sogbo isdar daked:
\q2 Dule, dule-ibmar-oakalosad, ibmar-oakalossulidyob daked.
\q2 Dule, dule-ibmar-oakalossulid, ibmar-oakalosadyob daked.
\b
\q1 
\v 16 Dule-binsaedsulidaedga mani-uklenonikile, ¿igi imako na itoge?
\q2 ¿Egi binsaed-nikagued amio na itoge? Suli.
\q2 Ar edi, dule-ibmar-wissulidid.
\b
\q1 
\v 17 Dule, ai-guedgine, gusgu ai-sabguerbad.
\q2 Degisoggu, boni-dummad-ibagan-nonikile, gwenad-gargwenadyob gued.
\b
\q1 
\v 18 Dule-itoakwaa-binsasulidi, yogasaar emarbogwa igar-mesed,
\q2 dule-mani-gasad-anar mani-bennukega gubalid.
\b
\q1 
\v 19 Dule-isguedbina-itogerbadi, unnila urwedbina gudidaed.
\q2 Dule-san-dummarba-imakedi, na dukin boni-amidaed.
\b
\q1 
\v 20 Dule-gwage-isgana, bipisaagwale ibmar-nued amiosulid.
\q2 Dule-gadi-gakansaar-sunmakedi, ibmar-isgana egi aibinoed.
\b
\q1 
\v 21 Dule, machi-binsaedsulidaed-nikale, bukib-binsaed ega uked.
\q2 Dule-binsaedsulidaed-e-babga-guedi, wergued egi amilesulid.
\b
\q1 
\v 22 Dule, gwage-weligwaled-nikale, ina-nuedga gued.
\q2 Gwage-wile-itolegeddi, niga-obated.
\b
\q1 
\v 23 Dule-isgana dukuar dule-baidse manigi binsaed galeged.
\q2 Agala, ibmar-galagwensuli-imakleged geg bergued.
\b
\q1 
\v 24 Dule-itoakwaa-binsaedi, binsaed-nued-nikuedginbi binsaed.
\q2 Dule-binsaedsulidaeddina, aku neg-itoged, gabdakedginbi gudiid.
\b
\q1 
\v 25 Dule-binsaedsulidaedi, e-bab-ourwed gudiid.
\q2 E-nanga, gwage-nunmaked-uked gudibalid.
\b
\q1 
\v 26 Dule-ibmar-oakalossulid sabsur-odurdaklegele, ibnuedsulid.
\q2 Dule-ibmar-innikidamalad naibi-imaklegele, ibnuedsurbalid.
\b
\q1 
\v 27 Dule-magar-neg-itogedi, nabir na e-gwabinduku bargaed.
\q2 Dule-itoakwaa-binsaedi, nabir na san-bargamogad.
\b
\q1 
\v 28 Dule-binsaedsulidaedi bogidik gudiile, binsaed-ibedyob daklemogad.
\q2 Sunmaksurbalile, dule-itoakwaa-binsaedye, egi binsalebalid.
\b
\c 18
\q1 
\v 1 Dule-na-eginbi-binsaedi, unnila egarbi ibmar-nued abeged,
\q2 dule-ega-binsaed-nued-ukeddi, abesulid.
\b
\q1 
\v 2 Dule-binsaedsulidaedi, magar-ibmar-itoged baisur-daked,
\q2 unnila e-ibmar-sogedgi na san-odummodiid.
\b
\q1 
\v 3 Ibmar-isgana-imaklegedgine, dule-sae-dakleged nononidaed.
\q2 Bingegulegedba-mai dule-nug-gagaleged danidaed.
\b
\q1 
\v 4 Dule-e-gayaburba, dii-wiladyob gued.
\q2 Diwar-iirmakemaiyob egi binsaed-nikagued ainimaid.
\b
\q1 
\v 5 Dule-ibmar-oakalosad ibmar-oakalossuliyob-imakedi, ibnuedsulid.
\q2 Dule-ibmar-oakalossulidga ega igar-innikigwad-imaksulile, ibnuedsurbalid.
\b
\q1 
\v 6 Dule-binsaedsulidaed-e-sunmakedi, unnila neg-urwed onoged,
\q2 e-sunmaked emarga urwed-amied.
\b
\q1 
\v 7 Dule-binsaedsulidaed e-sunmakedgi na dukin san-wioged,
\q2 e-sunmaked na dukin egi aibinega-imaked.
\b
\q1 
\v 8 Gakangi-sunmaklegedi, mas-nued-gullegeyobid.
\q2 Gakangi-sunmaklegedi, ulubse uboged.
\b
\q1 
\v 9 Dule, e-arbaedgi nue-arbasulile,
\q2 dule-ibmar-ogiloged-e-sordaga gued.
\b
\q1 
\v 10 Bab-Jehová-e-nug, neg-matusulid-gandikid-geg-ayaredyobid.
\q2 Dule, bendakleged-amiegala, a-negse abarmakdedaed.
\q2 Bab-Jehová-e-nug dule-innikimaladga deyob gued.
\b
\q1 
\v 11 Igi neggwebur-e-akwa-galu-matusulid-ebirnai,
\q1 mani-ibmalad na deyob e-ibmar-nikad egi ebirnai itoged.
\q2 Degisoggu, gwen akar-guosuliyob na binsamalad.
\b
\q1 
\v 12 Dule, ibitoged-idu, e-daed bule-bule na san-oyoged.
\q2 Dule, e-nug-ogannoleged-idu, e-daed na san-bipii oyoged.
\b
\q1 
\v 13 Yogasaar gwen ibmar-itossuli-emar-abinsaele, binsaedsulidalegedid,
\q2 dule-emar-obingeg-saedid.
\b
\q1 
\v 14 Dule-uelleged bonigan-itomaidgi niga-gandikgudele, gwae nugudoed.
\q2 Ar dule-uelleged niga-batismaile, ¿adi, igi nuguosunna?
\b
\q1 
\v 15 Dule-itoakwaadaed ibmar-nuegan baramied.
\q2 Dule-binsaed-ibed gatik ibmar-wisgued-nikuegala, nue ibmar-itodaed.
\b
\q1 
\v 16 Ibmar-binsa-uklegedba belagwable yawagakmar argaed,
\q2 abali, dule-dummaganse warmakleged.
\b
\q1 
\v 17 Dule-na-e-inse-san-bendakedi, e-ibmar-sogedi, e-gussuliyob sunmaked.
\q2 Geb dule-baid-ebo-boni-nikadi, sorba ibmar-sognonimogale, akar egi sunmaknonimogoed.
\b
\q1 
\v 18 Ibmargi-wilubdaklegar-imakleged igar-apurnaid nabir nudaked.
\q2 Dule-gandikidga, dule-gandikid-baidbo boni-nika-gunair, nabir ega igar-nudakbalid.
\b
\q1 
\v 19 Neggwebur-e-akwa-galu-ebiris-bukwad-earedba bur undarad, gwenad-oululesad-e-gwage gadi-gadi-imaked.
\q2 Neggwebur-yawagak-geg-argaedba bur undarad, gwenadgan-na-muchub-muchub-urwemalad walikaa-gudigued.
\b
\q1 
\v 20 Dule na e-sunmakedba yeer-itodiid,
\q2 na e-sunmakedba immee gudiid.
\b
\q1 
\v 21 Sunmaklegedgine, burba-dulad maid, burgwed-igar maibalid.
\q2 Dule na e-sunmakedbali, e-igar abingaoed.
\b
\q1 
\v 22 Dule ome-nikunonikile, ibnued nikued.
\q2 Bab-Jehová-egi-nued-binsaed ega oyoleged.
\b
\q1 
\v 23 Dule-wileged wilesakwaa ibmar egised.
\q2 Dule-mani-ibeddina, sabsur dule-abin-imaked.
\b
\q1 
\v 24 Dule, aimar-nikale, aigwar guergebed.
\q2 Abar-aimar nikad, gwenad-gargwenadba bur bule walikaa daed.
\b
\c 19
\q1 
\v 1 Dule-emargi-gakansaar-sunmakedba,
\q2 bur nuedid, dule-wileged inniki-nanadii gued.
\b
\q1 
\v 2 Itoakwaa ibmar-imaksulidi, nuedsulid.
\q2 Dule gwae-gwae-ibmar-imakedi, gadi noar-ibmar-imakdaed.
\b
\q1 
\v 3 Dule-binsaedsulidaedi, e-binsaedsulidba yogasaar nanaddaed.
\q2 Geb sogdedaed: “An-akargusadi, Bab-Jehováʼginye.”
\b
\q1 
\v 4 Dule, ibmar-nuegan-nikadba bukidar aimar-nikuega gued.
\q2 Ar dule-wilegeddi, na e-aise-bakale, egi bangued.
\b
\q1 
\v 5 Dule-ibmar-daksad-gakansaar-sogedi, sabsur-odurdaklegosuli guosulid.
\q2 Dule-gakansili na gwen san-onogosulid.
\b
\q1 
\v 6 Dulemar-bukidar, dule-obinebak-ibmar-uked-e-aiga-guega amimalad.
\q2 Bela dulemar, dule-ibmar-binsa-uked-e-aiga gumalad.
\b
\q1 
\v 7 Ar bela dule-wileged-e-gwenadgan, dule-wileged-isdar-dakele, e-aimar-bursunna, bur bule isdar dakoed.
\q2 Dule-wilegedi, na e-bendakega e-aimar-amidiguo-inigwele, bipisaar amiosulid.
\b
\q1 
\v 8 Dule ibmar-magar-itoged-amiedi, na e-san sabed.
\q2 Na ibmar-durdaksad imakele, ibmar-nued amioed.
\b
\q1 
\v 9 Dule-ibmar-daksad-gakansaar-sogedi, sabsur-odurdaklegosuli guosulid.
\q2 Dule-gakansaar-sunmakedi, na burgwed-amioed.
\b
\q1 
\v 10 Dule-binsaedsulidaedi, ibmar-mani-gargerbad-nikuedi, egi nosulid.
\q2 Dule-maiga-gudiid-bursunna, bur bule dule-dummagan-e-dummadga-guedi egi nosulid.
\b
\q1 
\v 11 Dule-binsaed-nikadaedi, na urwed wisi bargaed.
\q2 Dule-egi-nosad-egi-nossuliyob-dakeddi, e-nug dummarbaa imaked.
\b
\q1 
\v 12 Rey-urwedi, achumigur-nono-wawaad-uurmakedyob gued.
\q2 Ar rey-e-nued-binsaeddi, gagangi boo-bateyobi neg-imaked.
\b
\q1 
\v 13 Machi-binsaedsulidaedi, na e-bab-wile-itogega imaked.
\q2 Ome-e-ulus-ulusdaedi, dii-yakedyob gued, binna-binna sui-wioged.
\b
\q1 
\v 14 Nega, degi, ibmar-nuegan, babgan uked.
\q2 Ome-binsaed-nikadaeddi, Bab-Jehová uked.
\b
\q1 
\v 15 Wieguedi, dulega gabed-uked.
\q2 Dule-wiegala ukudmaada gudii guoed.
\b
\q1 
\v 16 Dule-Bab-Dummad-Igar-Maidba-ibsaedi, dukin san-bendaked.
\q2 Dule-Bab-Jehová-Igar-Mesisad-isdar-dakeddi, burgoed.
\b
\q1 
\v 17 Dule-wilegedga-ibmar-ukedi, Bab-Jehováʼga-ibmar-uknaiyob gued.
\q2 Bab-Jehová dule-ibmar-uksadga gannar ibmar uked.
\b
\q1 
\v 18 Be-machi nued-nanaegala, bipigwadgi be unao.
\q2 Be sabsur-odurdakalile, melle oburgwedse be imako.
\b
\q1 
\v 19 Dule-gadi-urwedi, sabsur-odurdaklegoed.
\q2 E-urwed-bargaega egi binsa alamakleged, aka bur bule uluddaed.
\b
\q1 
\v 20 Bega-binsaed-uklegedi, be itoge.
\q2 Be-unaedi mer be isdar-itoge, ar dule-binsaed-ibedga be guoed.
\b
\q1 
\v 21 Dule ibmar-imakega bukidar igar-amied,
\q2 degi-inigwele, Bab-Jehová-ibmar-imakbiedbi imakleged.
\b
\q1 
\v 22 Dule emar-innikii-eba-daed abeged.
\q2 Dule-gakansiliba, bur nuedid, dule-wilegedga-gued.
\b
\q1 
\v 23 Bab-Jehová-dobekwaa-nanaedi, dula-gudii dule-imaked.
\q2 Bogidik-gudii dule-imaked,
\q2 mer-bonigan-nikuega dule-imaked.
\b
\q1 
\v 24 Dule-wiegala mas-gunnega bateyagi e-argan ododaenad,
\q2 degi-inigwele, wiedba e-gayaba mas odosulid.
\b
\q1 
\v 25 Dule-binsaedsulidaedi, unnila sabsur-odurdakedgi ibmar-durdaked.
\q2 Dule-binsaed-nikagueddi, na ibmar-durdakega irgwen-ounaed abeged.
\b
\q1 
\v 26 Dule e-bab-ibe-ibmar-atursaedi, neggi e-nan-ononnobalidi,
\q2 a-dule, machi-isganad, dule-binged-satedid.
\b
\q1 
\v 27 Machi, dule-be-unaed be itosulile,
\q2 binsaed-nikaguedgi be bangudoed.
\b
\q1 
\v 28 Dule-ibmar-daksad-gakansaar-soged igar-nabolenaidgi dodoged.
\q2 Dule-isgana ibmar-isganaginbi sunmaked.
\b
\q1 
\v 29 Dule-emargi-dododimaladga sabsur-odurdakleged-igar guagwar maid.
\q2 Dule-binsaedsulidaedga bibyoleged-igar guagwar maimogad.
\b
\c 20
\q1 
\v 1 Inna-gagbidi, bingedsuli dule-imaked.
\q2 Sisa neg-gagaega dule-imaked.
\q2 Dule, wemar-gobsale, binsaedsuli naddaed.
\b
\q1 
\v 2 Rey-urwedi, achumigur-nono-wawaad-uurmakedyob gued.
\q2 Dule rey-ourwega-imakedi, na dukin boni amied.
\b
\q1 
\v 3 Dule-e-urwedgi-banguedi, bur nug-dummarba gued.
\q2 Dule-binsaedsulidaeddi, urwed-amied.
\b
\q1 
\v 4 Dule-wiegala yorgi neg imaksulid,
\q2 ibmar-gwag-weleged-ibagangi ibmar-gwag weosulid.
\b
\q1 
\v 5 Dule-binsaedi, dii-wiladyob gued,
\q2 dule-ibmar-nue-wisiddi irgwensuli dule-binsaed-baramied.
\b
\q1 
\v 6 Dule-bukidar sogdamalad, ede dule-nuedye.
\q2 Degi-inigwele, dule-inniki-ibmar-sogeddi, ¿doa amioe?
\b
\q1 
\v 7 Dule-nuedi, innikigwadba nanaed.
\q2 E-mimmigan e-bab-nanaedba-nanadimarmogadi, egi ise-nued binsalesad.
\b
\q1 
\v 8 Ar rey igar-nabogega e-ologanagi sigisale,
\q2 unnila e-atakedgi bela ibmar-isgana baramied.
\b
\q1 
\v 9 Dule geg soged: “Andi gwage swilidik-nikaye,
\q2 andi isgued sateye.”
\b
\q1 
\v 10 Bab-Jehová ibmar-sogbogwad nabir daksulid:
\q2 Nibir-noaled, wilubsaed-noaled.
\b
\q1 
\v 11 Machigwa e-ibmar-imakedba magar dakleged,
\q2 e-daed innikigwadid, degi, nuedbalid.
\b
\q1 
\v 12 Bab-Jehová ibmar-sogbo yeerdakle obinnisad:
\q2 Uaya, ibmar-itogegar.
\q2 Ibya, ibmar-dakegar.
\b
\q1 
\v 13 Mer be dule-wilegedga-guega, mer be gabedginbi binsae.
\q2 Bur be arbaedginbi binsae,
\q2 adi, mas obinebaka be nikuoed.
\b
\q1 
\v 14 Dule-ibmar-bakedi, yamo sogdedaed: “¡Wedi nuedsuli! ¡Wedi ibmar-isgana!”
\q2 Ar we-ibmar-baksad-sorbardi, weligwar itodaed.
\b
\q1 
\v 15 We-napneggi, ormar-nika-inigwele, akwa-nuegan-nika-inigwele,
\q2 dule-binsaed-ibed-e-sunmakeddi, we-ibmarmarba bur nuedid.
\b
\q1 
\v 16 Dule-akudaked-anar dule-mani-bennukoye-sogsad-ibe, ibmar-nued be sue.
\q2 Mani-bennukegala, dule-e-ibmar-nued be gae.
\b
\q1 
\v 17 Dule, emar-yardakedgi masgunned-amiedi yeer-itoged,
\q2 degi-inigwele, a-masgunnedi durgan-gunneyob gued.
\b
\q1 
\v 18 Igarmar-nuegan-amilegedi, binsaed-nued-dakedba amileged.
\q2 Bila-onolegegala, igar-nikaa imaklegergebed.
\b
\q1 
\v 19 Dule-galagwensuli-sunmakedi, ibmar odukusulid.
\q2 Degisoggu, dulemar-gadi-galagwensuli-sunmakmaladba mer be akae.
\b
\q1 
\v 20 Dule e-bab-ukabsaele, e-nan-ukabsaele,
\q2 nuchukwaa burgoed.
\b
\q1 
\v 21 Gebegi ibmar-irgwensursunna-nikulegedgi,
\q2 be yeer itogosulid.
\b
\q1 
\v 22 Mer be sogo, an buged-mai imakoye.
\q2 Mer be Bab-Jehováʼgi bensuli gue,
\q2 ar e be-bendakoed.
\b
\q1 
\v 23 Bab-Jehová nibirmar-noaled isdar-daked,
\q2 ibmar-wilubdaked-noaled abesulid.
\b
\q1 
\v 24 Bab-Jehová, dule-iduega gued.
\q2 Degisoggu, dule na yoedse igi-guoed wissulid.
\b
\q1 
\v 25 Nue-binsassuli Bab-Dummadga-ibmar-imakoye-soged bonidar-dummadid.
\q2 Geb sogsad-sorba, binsadele, an ibiga deyob sogsadibeye.
\q2 Deyob-binsaedi, bonidar-dummadid.
\b
\q1 
\v 26 Rey-binsaed-ibedi, dule-isganamar-oaisakied.
\q2 Ob-ubigwar-imaklegeyob ese ubigwar gumalad.
\b
\q1 
\v 27 Dule-burba, Bab-Jehová-anmarga-uksadi, bela gwage-ulubse binsaed-baramied.
\q2 Ar a-burba, gwallu-meegwadyob dulega uksad.
\b
\q1 
\v 28 Wile-dule-daklegedi, degi, napiragwadgi-ibmar-soglegedi, rey-bendakega gued.
\q2 Rey-e-negdakmaidi, wile-dule-daklegedgi gangumaid.
\b
\q1 
\v 29 Sapingan-e-werguedi, e-garganguedgi siid.
\q2 Sergan-e-werguedi, e-ibmar-wisidgi simogad.
\b
\q1 
\v 30 Bibyolegedgi, degi, naibisalegedgi, dule-isgana nudakleged.
\q2 Sabsur-imaklegedgi, galagwensur-binsaleged nudakleged.
\b
\c 21
\q1 
\v 1 Bab-Jehováʼgi, rey-e-binsaed diwar-iirmakmaiyob gued.
\q2 Deyobi, rey, Bab-Dummad-ibmar-abegedba ibmar-imaked.
\b
\q1 
\v 2 Dule na war-wargwengi e-ibmar-imaked nueganbi-imakye binsaed.
\q2 Ar Bab-Jehováʼdi, dule-ibiga-ibmar-imakbied, bato wisid.
\b
\q1 
\v 3 Bab-Dummad ibdurgan-ogumakar-ukedba, bur nued-daked,
\q2 igar-inniki-imakleged, degi, innikigwadba-ibmar-imakleged.
\b
\q1 
\v 4 Emar-ibgwensur-dakedi, san-dummarba-imakedi, dule-isganamar-e-binsaedi,
\q2 bela wemar isgumaladid.
\b
\q1 
\v 5 Nue-itoakwaa-igarmar-amilegedi, ibmar-nuedga gued.
\q2 Gwae-gwae-igar-amilegeddi, ibmar-nuedga gusulid.
\b
\q1 
\v 6 Gakansaedgi ibmar-nuegan-ichesur-nikuedi, booyob berguddaed,
\q2 dule-oburgwega gubalid.
\b
\q1 
\v 7 Dule-isganamar, dukin e-sabsur-ibmar-imakedse berguoed.
\q2 Ar igar-inniki-imaklegedi, imakbisurmalad.
\b
\q1 
\v 8 Dule-isgana-e-daedi, innikisulid, boni-nikad.
\q2 Dule-nued-daeddi, innikigwadid.
\b
\q1 
\v 9 Neg-dummadgi ome-gadi-urwedbo-gudisaedba,
\q2 bur nuedid, neg-bipigwadgi-gudisaed.
\b
\q1 
\v 10 Dule-isgana unnila ibmar-isganaginbi binsaed.
\q2 Ar bipisaale, wile dule-bamalad-daksulid.
\b
\q1 
\v 11 Dule-ibmar-nue-wissulid, dule-emargi-dododiid-sabsur-odurdaklegedgi ibmar durdaked.
\q2 Dule-binsaed-nikagued ibmargi-odurdaklegele, dule-ibmar-nue-wissulidi ibmar durdaked.
\b
\q1 
\v 12 Dule-nued, dule-isgana-e-neg dakdedaed,
\q2 igi dule-isgana e-ibmar-nikadi berguddae.
\b
\q1 
\v 13 Dule, dule-wileged-e-ibmar-egised itosulile,
\q2 na ibmar-egichiarmogar, dulemar e-itogosurmarmogad.
\b
\q1 
\v 14 Ibmar-binsa-uklegedi dulemar-wagab-uksulidi, sae-itoged boo imaked.
\q2 Ibmarbina-sogdiidgi a-ibmar bega-uklenonikile, sabsur-urwed boo imaked.
\b
\q1 
\v 15 Igar-innikigwad-imaklesale, dule-nued na yeer-itodaed.
\q2 Dule-isganagardi, dobed nagunonidaed.
\b
\q1 
\v 16 Dule, itoakwaa nanadisulile,
\q2 burgwarmai dakledagoed.
\b
\q1 
\v 17 Dule, galagwensuli-gudiguedginbi-binsaedi, dule-wilegedga guoed.
\q2 Dule, mummudbi-gaamakdiidi, degi, ina-wawadginbi-mani-oediidi, bipisaale, mani-ibedga gwen guosulid.
\b
\q1 
\v 18 Dule-isgana, dule-nued-anar sabsur-odurdaklegoed.
\q2 Dule-emargi-aibined dule-inniki-nanadiid-anar, sabsur-odurdaklegoed.
\b
\q1 
\v 19 Ome-gadi-urwed-nikuedba, ome-gadi-isdar-itoged-nikuedba,
\q2 bur nuedid, ome-sate walagwen-gudisaed.
\b
\q1 
\v 20 Dule-binsaed-nikagued-e-neggi ibmar-nuegan obinebaka nikad,
\q1 ina-wawadikmalad obinebaka nikabalid.
\q2 Dule-binsaedsulidaeddi, bela ibmar-nikad binsa diiga imakdaed.
\b
\q1 
\v 21 Dule, igar-inniki-imakleged-amidiile, wile-dule-dakleged-amidibalile, san-dula-gudiguleged amied.
\q2 Igar-inniki-imakleged amied.
\q2 Nug-dummarba-guleged amibalid.
\b
\q1 
\v 22 Dule-binsaed-ibed dulemar-gandikmalad-ibe neggwebur sued.
\q2 Dule-binsaed-ibed dule-gandikmalad-e-ibmargi-bensuli-gudiid-ibe e-ibmar obelobalid.
\b
\q1 
\v 23 Dule na itoakwaa-sunmaked, e-gwabinduku-bargabalid,
\q2 bonigangi ollorgued.
\b
\q1 
\v 24 Dule-na-doggus-san-buled-imakedi, dule-na-san-dummarba-imakedi, dule-emar-mesagwar-imakedi, weyob egi sogleged,
\q2 wilub-obicha sabsur-isdar-nanadiidye.
\b
\q1 
\v 25 Dule-wiegala bela ibmar nikubienad,
\q2 degi-inigwele, budar arbaed.
\b
\q1 
\v 26 Dule-wiegala, dule-baid-ibe ibmar-abedii osedoddaed.
\q2 Dule-nueddi, wilub-obicha ibmar uked.
\b
\q1 
\v 27 Bab-Dummad, dule-isganamar-ega-ibmar-ukedi, isdar-daked.
\q2 Bur bule isdar daked, nabiridgi ega uksurmalar.
\b
\q1 
\v 28 Dule-ibmar-daksad-gakansaar-soged burgoed.
\q2 Dule, a-duleba-ibsaeddi, deyob guedsemogad.
\b
\q1 
\v 29 Dule-isgana na ibmar-sogsadi gege ogwadaed.
\q2 Dule-nueddi, na e-daed nudaked.
\b
\q1 
\v 30 Nue-binsaed-nikaguedi, nue-ibmar-wisiguedi,
\q2 degi, binsaed-nuegana, gwen Bab-Jehováʼgi obinsulid.
\b
\q1 
\v 31 Dule bila-onogega moli guakwaa nasiked.
\q2 Degi-inigwele, bila-onogedgi-nakwegala, Bab-Jehováʼgi siid.
\b
\c 22
\q1 
\v 1 Ibmar-nuegan-bukidar-nikadba, bur nuedid, nug-nued nikued.
\q2 Bukidar-or-nikuedba, degi, mani-nikuedba, bur nuedid begi dulemar nued sunmaked.
\b
\q1 
\v 2 Mani-ibed, degi, dule-wileged, ¿ibugi emar gumala?
\q2 Bab-Jehová-ebobela-obinnisadgi emar gumalad.
\b
\q1 
\v 3 Dule-itoakwaadaed magar bonigan-daked, bonigangi banguddaed.
\q2 Dule-binsaedsulidaeddi, bonigan-idu bangusulid,
\q2 degisoggu, boni amisdasunnad.
\b
\q1 
\v 4 San-bipi-imaklegedgi, Bab-Jehová-nug-odummolegedgi we-ibmar-sogbaagwad danikid:
\q2 Ibmar-nuegan-nikued, nug-dummarba-gued, dula-gudii-saed, danikid.
\b
\q1 
\v 5 Dule-isganamar-gudiidbina, ikomar bukwad, sakimar bukwad.
\q2 Dule-na-san-sabgudiiddi, a-ibmarmargi bangued.
\b
\q1 
\v 6 Igar-innikigwadgi mimmigan be odurdake.
\q2 Amba sered-ugakgusale, we-ibmargi banguosulid.
\b
\q1 
\v 7 Dule-mani-ibed, dule-wilemalad-e-dummad gued.
\q2 Dule-mani-ganikid, dule-mani-ega-uksad-e-maiga gued.
\b
\q1 
\v 8 Dule-ibmar-isgana-imaked, bonigan amied.
\q2 Bab-Dummad isdar-itogedgi we-dule-obelogoed.
\b
\q1 
\v 9 Dule emar-wiledakele, egi nued binsalegoed.
\q2 Ar we-dule, dule-wilemaladga masgunned uked.
\b
\q1 
\v 10 Dule-gadi-urwed-amied be ononnoge,
\q2 adi, na abin-abin-imaklegedi, urwelegedi, degi, sabsur-ibmar-soglegedi, berguoed.
\b
\q1 
\v 11 Dule innikigwadgi-ibmar-sogedi, e-sunmaked-yeer-itolegedi,
\q2 rey e-aiga imakoed.
\b
\q1 
\v 12 Bab-Jehová dule-binsaed-ibedgi nakuleged.
\q2 Bab-Jehová, dule-gakansili-e-ibmar-sogeddi oyoged, e-sunmaked gakanye.
\b
\q1 
\v 13 Dule-wiegala yapa-arbaedba sogdaed: “Achumigur-nono-wawaad magaba gudiiye.
\q2 An noddibe, an-gunnoye.”
\b
\q1 
\v 14 Ome-sui-dikarba-yoleged-e-gaya, yaa-matusur-siidyob gued.
\q2 A-yaagine, dule-Bab-Jehová-ourwega-imakedi, argwanoed.
\b
\q1 
\v 15 Uayasulidaedi, gusgu burwigana-e-daedid.
\q2 Molidubgi-bibyolegedgi uayasulidaed surgued.
\b
\q1 
\v 16 Dule, mani-bur bule-nikuega, dule-wileged-mesagwar imaked.
\q2 Dule, mani-ibedga binsa-ibmar-ukedi, na dule-wilegedga guoed.
\ms1 4. BINSAED-NUEGAN-IBMAR-WISIGUED
\mr (22:17–24:22)
\q1 
\v 17 Dule-binsaed-ibed-e-sunmakedi, nuekwaa be itoge.
\q2 An be-odurdakedba, be ibmar imake.
\q1 
\v 18 Ar be we-ibmar nonogi-gaele,
\q2 bela be gannar-gannar sogdiile, be yeer-itogoed.
\q1 
\v 19 Bab-Jehováʼgi be mer benguega,
\q2 emi an be-owisonaid.
\b
\q1 
\v 20 Emi, an bega durgwen-gakambe (30) binsaed-nuegan-ibmar-wisigued narmaksad.
\q2 
\v 21 Adi, be gayaburba-napiragwadi, wisi guega,
\q2 adi, dule-bese-ibmar-egised-abin nabir be ibmar sogegar.
\s2 1
\q1 
\v 22 Melle dule-wileged-ibe be ibmar-atursae, ar wede, dule-wilegedid.
\q2 Melle igar-naboleged-neggi dule-ibmar-sate-gudiid be sabsur-imakbalo.
\q1 
\v 23 Ar Bab-Jehová wemar-ular gwisguoed,
\q2 geb dule-wileged-ibe-ibmar-susad-annik ibmar sumogoed.
\s2 2
\q1 
\v 24 Melle be dule-emar-sabsur-imaked-e-aiga gue.
\q2 Melle be dule-emar-wiogedba akabali.
\q1 
\v 25 Ar e-ichakwadamalad be durdaksale,
\q2 na be dukin boni-dummad amioed.
\s2 3
\q1 
\v 26 Melle be emar-anar ibmar-imakoye sogo.
\q2 Melle be emar-anar mani-bennukega gubalo.
\q1 
\v 27 Ar be bennukega mani-sate-gualile,
\q2 be-gabedse-bakale, be-ibe sumaloed.
\s2 4
\q1 
\v 28 Melle be-dadgan dikasurgus-nainu-abingunaidgi
\q2 ibmar-ogwichismalad be oniro.
\s2 5
\q1 
\v 29 ¿Dule e-arbaedgi nued-arbaed be dakdii?
\q2 Dule-deyob-arbaedi, reymarga arbadii guoed, dule-binsarmaladga arbaosulid.
\c 23
\s2 6
\q1 
\v 1 Be dule-dummadbo mas-gunsokalile,
\q2 nue ebinsao, doa-asabin be sii.
\q1 
\v 2 Ar be gadi-mas-gunnele,
\q2 masgunned bargao.
\q1 
\v 3 Melle be e-mas-yeer-gullegedbina soge,
\q2 ar we-masdi, unnila dule-yardakedid.
\s2 7
\q1 
\v 4 Melle be ibmar-nuegan-nikuega surbinsa-itodii gue.
\q2 Melle be ibmar-gargerbamaladginbi binsadii gue.
\q1 
\v 5 Ar be nuekwaa dakdele, be daksaled,
\q2 ibmar-gargerbamalad baisursunna berguddaed.
\s2 8
\q1 
\v 6 Melle be dule-nallegaladbo mas-gunne.
\q2 Melle be e-mas-yeer-gullegedbina sogbalo.
\q1 
\v 7 Ar e-masde, gammugi-sailagia-megeyob gued.
\q2 Bega sogoed: “Mas-gunne, gobe.”
\q2 Degi-inigwele, gwen gwage-nuedgi bega sogosulid.
\q1 
\v 8 A-sorbali, be bela mas-guchad agoed,
\q2 ega be nuedgi-sunmaksadi, binsa be sunmakoed.
\s2 9
\q1 
\v 9 Melle be dule-binsaedsulidaedga binsaed dako.
\q2 Ega be ibmar-sogoedi, be-abin isdar-itogoed.
\s2 10
\q1 
\v 10 Melle dikasurgus-nainu-abingunaidgi ibmar-ogwichismalad be oniro.
\q2 Mer be dule-sergansated-e-nainugi dogbalo.
\q1 
\v 11 Ar wemar Dule-E-Bendaked-Gandikid nikad.
\q2 Dule-sergansated-bendakegala, be-abin gwisguoed.
\s2 11
\q1 
\v 12 Ibmar-durdaksadba be ibmar imake,
\q2 binsaed-nued-uklegedi, be nue-itoge.
\s2 12
\q1 
\v 13 Melle be mimmigan-odurdaksuli gue,
\q2 molidubgi-bibyolegedba burgosulid.
\q1 
\v 14 Ar bur be molidubgi-bibyogele,
\q2 burgwed-igargi be ollor-imaknaid.
\s2 13
\q1 
\v 15 Machi, be dule-binsaed-ibedga gunonikile, gwagegi an weligwar itomogoed.
\q2 
\v 16 Be-sunmakedi, napiragwadba be sunmakele, ulubgi an yeer itononikoed.
\s2 14
\q1 
\v 17 Melle be dule-isganamargi nobgue,
\q2 bur be bane-bane Bab-Dummad-nug odummodii imake.
\q1 
\v 18 Adi, yoedse bega ibmar nueganbi guoed,
\q2 na be ibmar-edarbediid nikudapoed.
\s2 15
\q1 
\v 19 Machi, nue be itoge, binsaed-nikaa be dae,
\q2 igar-innikigwadbarbi be nanadii sae.
\q1 
\v 20 Dule-gadi-mumgumaladba mer be akae.
\q2 Dule-gadi-masgunmaladba mer be akadii gubali.
\q1 
\v 21 Ar dule-gadi-mumgumaladi, degi, gadi-mas-gunmaladi, dule-wilegedga gumaloed.
\q2 Ar dule-gabedginbi-binsaedi, unnila mor-siir-siir-yoi gudiguoed.
\s2 16
\q1 
\v 22 Be-bab-we-napnegse-be-odenonikid be itoge,
\q2 be-nan seredgusale, mer be isdar-dako.
\q1 
\v 23 Igar-napiragwad, nue-binsaed-nikagued, be amie.
\q2 Ibmar-durdaked, nue-ibmar-wisigued, be amie.
\q2 Wemala, mer be ibmar-baid-anar ogwao.
\q1 
\v 24 Dule-nued-e-baba na bela-bela yeer itoged.
\q2 Dule na machi-binsaed-ibed-nikad, weligwar itoged.
\q1 
\v 25 Be-bab, degi, be-nan, werguega be imake.
\q2 Be-sergan-we-napnegse-be-senonikid wergumalaga be imake.
\s2 17
\q1 
\v 26 Machi, an-bega-binsaed-dakdiidgi be binsae,
\q2 an-nanadiid be dake.
\q1 
\v 27 Ar ome-gambanuchu-imakedi, yaa-dummad-matusursiidyob gued.
\q2 Dule-baid-ome-galagwensur-nanaedi, dia-garagwad-matusursiidyob gued.
\q1 
\v 28 We-omedi, dule-atursaedyob matarmakdidaed.
\q2 We-ome, machergan-bukidar-e-ome-dikarba-yolemalaga imaked.
\s2 18
\q1 
\v 29 Dule-mumgued-iedisulidi, dule-sisamar-galagwensuli-gobedi,
\q2 boed amied,
\q2 ibmar-nunmaked-itoged amied,
\q2 urwed amied,
\q2 isdar-itoged amied,
\q2 binsa-nailikgued amied,
\q2 ibya-gudure-gued amied.
\q3 
\v 30 Dule-mumgued-iedisulidi, dule-sisamar-galagwensuli-gobedi, deyob gued.
\q1 
\v 31 Vino-gisi-daklesidaedbina mer be soge,
\q2 vino-noggi-dakarmaksidaedbina mer be sogbali.
\q2 E-goblegedi, nolloo gobleged.
\q1 
\v 32 Degi-inigwele, dubgi-warmakeyobi, be itogoed.
\q2 Naibe-e-gichi-begi-ubodeyobi, be itogoed.
\q1 
\v 33 Ibya-apurega be-imakoed,
\q2 galagwensuli-binsaega be-imakoed.
\q1 
\v 34 Magadba-yakumaknadapiyob be itogoed,
\q2 urmor-suar-dukugi-maiyob be itogoed.
\q1 
\v 35 Be sogdagoed: “An-naibi-imaksamala,
\q2 degite, gwen nunmak an itosulid.
\q1 An-bibyosmala, degite, gwen bai an itosulid.
\q2 An dadakusale, gannar an mumgunabaloed.”
\c 24
\s2 19
\q1 
\v 1 Melle be dule-isganamargi nobgue,
\q2 melle be eba-akaedgi binsabali.
\q1 
\v 2 Ar e-gwagegi unnila emar-sabsur-imakedgi binsamalad,
\q2 unnila ibmar-isgana-imakedgi sunmakmalad.
\s2 20
\q1 
\v 3 Nue-binsaed-nikaguedba neg sobleged.
\q2 Nue-ibmar-wisidba neg-e-sailamar mesleged.
\q1 
\v 4 Itoakwaa-binsalegedba e-gabednegmaryaba
\q2 ibmar-gargermaladi, degi, ibmar-yeerdaklemaladi enoleged.
\s2 21
\q1 
\v 5 Dule-binsaed-ibedi, dule-gandikidid.
\q2 Dule-nue-ibmar-wisidi, dule-dutusulidid.
\q1 
\v 6 Nue-igar-amiale, bila onoleged.
\q2 Bukidar-dulemar-binsaed-dakmaladgi nakwileged siid.
\s2 22
\q1 
\v 7 Dule-binsaedsulidaedi, dule-binsaed-ibedga gwen guosurguoed.
\q2 Igar-itolegedgi sunmakosulid, ar aku-itoged na ibi obaroe.
\s2 23
\q1 
\v 8 Dule unnila ibmar-isganaginbi-binsaedi, egi-soglegoed:
\q2 “Dule-isganaye.”
\q1 
\v 9 Dule-binsaedsulidaedi, unnila isguedginbi binsaed.
\q2 Bela dulemar dule-emargi-dododiid isdar-dakmalad.
\s2 24
\q1 
\v 10 Ar be bonigan-abin sikirmakele,
\q2 amba be-gangued nollogwad.
\s2 25
\q1 
\v 11 Dulemar-burgwed-igarse-nadapmalad be ollor-imake,
\q2 dulemar e-burgwed-modanimalad be bendake.
\q1 
\v 12 Ar amba be sogele: “An wissulinye.”
\q2 ¿Dule-gwage-wilubdakedi, gwen wisguosur be insae?
\q1 Dule-begi-nakulegedi gwen wisguosur, ¿be insae?
\q2 Bab-Jehová dulemar-e-daedba dulemarga ibmar-uked.
\s2 26
\q1 
\v 13 Machi, achanis be mae, ar yeer-maleged,
\q2 achanis ochii maleged.
\q1 
\v 14 Binsaed-nikaguedi, achanisyob bega ochii gumogoed.
\q2 Binsaed-nikagued be amisale, yoedse bega ibmar nueganbi guoed,
\q2 be-ibmar-edarbediid be nikudapoed.
\s2 27
\q1 
\v 15 Dule-isgana, melle be dule-nued-oakalogedgi binsae.
\q2 Melle be e-neg-obelogedgi binsabali.
\q1 
\v 16 Dule-nuedi, amba ilagugle (7) aimukuele, gannar gwisgubaloed.
\q2 Dule-isganamardi aimukusale, geg bar gannar gwisgued.
\s2 28
\q1 
\v 17 Be-isdaradi aimukusale, mer be yeer-itogo.
\q2 Be-isdarad akar-gusale, mer be wergubalo.
\q1 
\v 18 Ar Bab-Jehová egi-be-wergue be-dakalile, be-daed nabir-dakosulid.
\q2 Ar egi be werguele, Bab-Jehová be-isdarad bar sabsur odurdakosulid.
\s2 29
\q1 
\v 19 Melle be dule-isganamarba akae.
\q2 Melle be egi nobgubalo.
\q1 
\v 20 Ar dule-isgana nuedgi berguosulid.
\q2 Dule-isgana gwallu-akitedaedyob bergudoed.
\s2 30
\q1 
\v 21 Machi, Bab-Jehová-dobekwaa be nanae,
\q2 rey-nug be odummoge.
\q2 Uayasulidamaladba mer be akae.
\q1 
\v 22 Ar wemar ukiagwale, sabsur-odurdaklemaloed.
\q2 Ar dule wissulid, ibi-bonigan egi danikoe.
\ms1 5. BINSAED-NUEGAN-BAIGAN
\mr (24:23-34)
\p 
\v 23 Dule-binsaed-ibegan amba we-ibmar sogsamarbalid:
\q1 Igar-nabirolegedgi dule-wargwenbarbi-nagued nuedsulid.
\q2 
\v 24 Dule-igar-naboged, dule-ibmar-oakalosad ibmar-oakalossuliyob dakele,
\q1 neggweburmarse ukabsalegoed,
\q2 dulemarse isdar daklebaloed.
\q1 
\v 25 Ar dule-igar-nabogedi, dule-ibmar-oakalosad-sabsur-odurdakerdi, dulemar yeer dakmaloed,
\q2 dulemar egi ise-nued binsamaloed.
\b
\q1 
\v 26 Napiragwadgi dule-abinsaed,
\q2 yeer-itole dule-imaked.
\b
\q1 
\v 27 Ibmar-digoed guakwa be urbe,
\q2 ibmar-digega be-nainumar guakwa be nasike,
\q2 geb a-sorbali, be-neg be soboed.
\b
\q1 
\v 28 Melle be ibmar-daksasuli dule-baidgi sunmako,
\q2 melle be egi gakansabalo.
\q1 
\v 29 Melle be sogo: “Igi be an-imaksa, deyob an be-imakmogoed.
\q2 An deyopira imaked nikamoga.”
\b
\q1 
\v 30 Dule-wiegala-e-nainu-dikarba an nasad,
\q2 dule-binsaedsulidaed-e-uva-digaled-dikarba an nasad.
\q1 
\v 31 A-nainugine, ikomar yaisur an daksad,
\q2 e-nainu bula-moodo-nai an daksabalid,
\q2 e-galu-emakaled-nainu-ebiris-naidi aimukumai an daksabalid.
\q1 
\v 32 An weyob ibmar-daksadi bipisaale, an iessulid.
\q2 We-ibmargine, ibmar-soggwen an durdaksad:
\q1 
\v 33 Ar be sikwas gabele,
\q2 ar be sikwas megele,
\q1 ar be sikwas obunnogele,
\q2 unnila be sakwa-obirmasmaile,
\q1 
\v 34 wilegedi, dule-atursaedyob begi nonikoed,
\q2 ibmar-sate-guedi, dule-gingi-nikadyob begi nonikoed.
\c 25
\ms1 6. REY-EZEQUÍAS, SALOMÓN-BINSAED-NUEGAN-SOGSAD NUE-ILEMAKAR NARMAKSAD
\mr (25:1–29:27)
\p 
\v 1 We-binsaed-nuegana Salomón onosbalid. Judá-rey-Ezequíasʼga dule-garda-narmakmaladi we-binsaedmar nue-ilemakar narmaksad.
\b
\q1 
\v 2 Ibmar-dukuar-mamaidi, Bab-Dummad-e-gandikid-e-wilub oyoged.
\q2 Reymar, igar-dukuar-mamaid-balamiedi, dule-gandikmaladga gued.
\b
\q1 
\v 3 Dule, nagase nibneg-nibgued balamiosulid,
\q2 degi, nagase napneg-e-ulub-naid balamiosulid.
\q2 Amba deyobi, reymar-binsaedi gege ulubse balamilemogad.
\b
\q1 
\v 4 Mani-dulenaidgi-durgan-welegoed be mie.
\q2 Geb a-manigine, dule-mani-sobedi, nog soboed.
\q1 
\v 5 Rey-asabin dule-isgana be onoge.
\q2 Geb rey igar-innikigwadba yar-seoed.
\b
\q1 
\v 6 Melle rey-asabin dule-nug-nikadga be san-imako.
\q2 Melle dule-dummagan-imbagi yogasaar sigis be imako,
\q1 
\v 7 rey bur bega soged nabirid: “Wese be sigda”
\q2 adi, melle dule-dummagan-abin rey be-obingegsaegar.
\b
\q1 Be-sunnagwad be ibmar-daksale,
\q2 
\v 8 melle gwae-gwae dummaganse-odonao.
\q1 Ar dule yamo be-abin osulosale, igi be saoe.
\q2 Aka dukin be bingeguoed.
\b
\q1 
\v 9 Bebogwa igar-gwatirisad be nudako.
\q2 Degi-inigwele, melle dule-bega-ibmar-sogedi, dule-baidga sogmogo.
\q1 
\v 10 Ar be dule-baidga ibmar-sogele, we-dule, sunna be-nug oichoged.
\q2 Degidbali, bar be, nug-nued-nika guosulid.
\b
\q1 
\v 11 Iba-sogedba ibmar-soglegedi,
\q2 galimbaba dutumar-oyapateyobi gued.
\b
\q1 
\v 12 Dule-binsaed-ibedi, nuedgi dulega gannabasaar-ibmar-sogsiile, dulega olargan-dummaganba bur bule ibnuedid,
\q2 ega ormadaremaladba bur bule sunsogedid.
\b
\q1 
\v 13 Igi-neg-diopisulidgi, neg-diopigwad yeer-itoledae,
\q2 debayobi, dule-garda-berbeged-innikigwadi, e-dummadga niga-gandikid ukmogad.
\b
\q1 
\v 14 Igi-dii-wioeyobi neg-ainakwis sii dakledae,
\q2 debayobi, dule ibmar-ukoye-sogdidaedi, gege ibmar-ukdaed.
\b
\q1 
\v 15 Gwae-gwaesuli, binnasdikigwadgi, dule-nuga-nikad-e-binsaed ogwaleged.
\q2 Nuedgi, urwedginsuli-sunmaklegedi, bela igar-bulegangi obilleged.
\b
\q1 
\v 16 Be achanis amisale, melle dogdar-mao.
\q2 Ar doggus be masale, be agdoed.
\b
\q1 
\v 17 Melle bali-bali dule-baid-negse nanao.
\q2 Ichakwagwad, bali-bali-nanaer, abakalegi budar-be-dakedba, isdar be-dakalile.
\b
\q1 
\v 18 Dule, e-aigi gakansaar-sunmakedi, akwa-mamaredyob gued.
\q2 Es-suidyobi, degi, es-swiswidikidyob gubalid. Emar-wioged.
\b
\q1 
\v 19 Dule, suli-suli-itogedgine, dule-isganagi bensuli gunonikile, nugar-nunmakedyob gued.
\q2 Degi, nailik-mali-bisgar-gudiidyobi gued. Binsaedsuli daed.
\b
\q1 
\v 20 Dule-bukib-binsaedba-wile-itodiidgala namaklemaladgi-namakedi, nuedsulid.
\q2 Ega ukagi-yaa-siidgi balu-eogeyobid.
\q1 Degi, neg-dambipigwadgi mor-esuedyobid.
\q2 Gwen gadi-gadi imakosulid.
\b
\q1 
\v 21 Be-isdarad ukudmaada-itogele, masgi ogunno,
\q2 uku-uku-itogele, ogobo.
\q1 
\v 22 Deyob be a-dule-imakele, be nue-obingegsaoed,
\q2 Bab-Jehováʼdi bega ibmar-buged ukoed.
\b
\q1 
\v 23 Dii-burwa-goledbali dii-wied danidaed.
\q2 Gaya-isgana-sunmakedbali, neg-urwed noardaed.
\b
\q1 
\v 24 Ome-ursili-ebo neg-dummadgi-megedbali, bur nabirsursi,
\q2 neg-sukungwaba-meremair.
\b
\q1 
\v 25 Igi-uku-uku-itolegedgi dii-dambipigwad gobledae,
\q2 deyobi, gayaburba-nuegan dikasur-danikir, itoledaed.
\b
\q1 
\v 26 Dule-innikidaedi, dule-isgana-abin sikirmakele, dii-isgumaidaeyobi gued.
\q2 Diagi-ib-isgana-mileddaeyobi gued.
\b
\q1 
\v 27 Achanis-gadi-maele, ichakwagwad.
\q2 Dukin-san-dummarba-imaked-amiedi, ichakwabalid.
\b
\q1 
\v 28 Dule-san-bargaed-wissulidi,
\q2 neggwebur-galu-matusulid-sateyobi gued.
\b
\c 26
\q1 
\v 1 Dambed-sibudik-sibudik-bated, yorgi batesulid.
\q2 Ibmar-gwag-weleged, dii-wiedgi welesurmogad.
\q2 Dule-binsaedsulidaed-e-nuga gwen odummolesurmogad.
\b
\q1 
\v 2 Igi-sikwigolo igarsuli gukudidae, igi-wirsob uu-suli gudidae,
\q2 debayobi, yogasaar-ukabsalegedi, gwen igarga guosulid.
\b
\q1 
\v 3 Moli-bibyoged-duba, moli-bibyogega gued.
\q2 Moli-gaya-bargaedi, moli-uayasuid-gaya-bargaega gued.
\q2 Suardi, dule-binsaedsulidaed-bibyogega gumogad.
\b
\q1 
\v 4 Melle be dule-binsaedsulidaed barwisogo,
\q2 aka be bur dule-binsaedsulidaedga gudoed.
\b
\q1 
\v 5 Dule-binsaedsulidaedga, bakar be ibmar-sogo,
\q2 adi, melle e-ibmar-sogedba binsaed-ibedga na san-imakegar.
\b
\q1 
\v 6 Dule, dule-binsaedsulidaedba garda barmiele, mali-siklegar-maiyob gued.
\q2 Duleba garda-barmissuliyobi gued.
\b
\q1 
\v 7 Dule-binsaedsulidaedi, binsaed-nuegangi-sunmakele, nabirsulid.
\q2 E-sunmakedi, mali-burgwar-bellemaknaidyobi itoleged. Baisursunna itoleged.
\b
\q1 
\v 8 Dule-binsaedsulidaedga nug-odummolegedi, akwa gunnu-akwa-miedgi-atinnar-naidyob gued.
\q2 Dule-binsaedsulidaed-e-nug-odummolegedi, gwen nabirsulid.
\b
\q1 
\v 9 Dule-binsaedsulidaedi, binsaed-nuegangi-sunmakele, aku-itodabalid.
\q2 E-sunmakedi, dule-mummud e-argangi iko-yolesayobid, aku-itodaed.
\b
\q1 
\v 10 Dule, e-neggi dule-binsaedsulidaed-oarbaele, sigu-mied-dule yogasaar sigu-miedba dule-onailiksaedyobid.
\q2 Wissulid bia sigu argwatapoe.
\b
\q1 
\v 11 Igi achu na e-agsad gannar maddae,
\q2 debayobi, dule-binsaedsulidaedi, gannar-gannar ibmar-nabirsulid obariddaed.
\b
\q1 
\v 12 ¿Dule-binsaed-ibedye-na-sogdiid be dakdii?
\q2 Dule-binsaed-ibedye-na-sogdiidba bur baisursunna, dule-binsaedsulidaedi ibmargi odurdakleged.
\b
\q1 
\v 13 Dule-wiegala, yamo wiedbali weyob sogdedaed:
\q2 “¡Igarba achu-sapur gudii daklesa!
\q2 ¡Neg-galimbaba achumigur achiksa-gudii daklesa!”
\b
\q1 
\v 14 Igi yawagak, e-naidgi egemakwisdae,
\q2 debayobi, dule-wiegala e-megedgi nikwamakmaidaed.
\b
\q1 
\v 15 Dule-wiegala mas-gunnega bateyagi e-argan ododaenad,
\q2 degi-inigwele, wiedba e-gayaba mas odosulid.
\b
\q1 
\v 16 Dule-wiegala, dule-binsaed-ibegan-e-walagugledba (7),
\q2 bur binsaed-ibediyob itodaed.
\b
\q1 
\v 17 Igi achu uaya-ebilenaidgi emargi aibine,
\q2 deyobi, dule, dulemar-urwenaid-imbagi gotemogale, boni-amied.
\b
\q1 
\v 18 Igi dule oes yogasaar sigu-soo-nikad mie,
\q2 
\v 19 deyobi, dule, e-ai-yamoged.
\q1 Geb sorba ega sogdaed,
\q2 “unnila, binsa an begi dodonaiye.”
\b
\q1 
\v 20 Dule, soo-yagi sapan urbesulile, soo akitedaed.
\q2 Deyobmodo, gakansaleged satele, urwed satedaed.
\b
\q1 
\v 21 Sogungi soo oaramakledaed, sapangi soo ogaledaed.
\q2 Deyobmodo, dule-ursilidgi urwed noardamogad.
\b
\q1 
\v 22 Gakangi-sunmaklegedi, mas-nued-gullegeyobid.
\q2 Gakangi-sunmaklegedi, ulubse uboged.
\b
\q1 
\v 23 Igi yamo napsa-nog manigi oglege,
\q2 debayobi, dule-gwage-isgana-e-sunmakedi yamo nabiridyobi sunmakdaed.
\b
\q1 
\v 24 Sae-dule-dakedi, yamo nueganbi dulega sunmakdaed,
\q2 ar e-ulubgindina, sae dule-dakdaed.
\q1 
\v 25 Ar sae-dule-dakedi, yamo bega nueganbi sunmakele, melle be itogo,
\q2 ar e-gwage-ulubgindi, dogdar isdar binsadaed.
\q1 
\v 26 Amba yamo sae-dule-daksuliyob na san-saele,
\q2 dulemar-abargindi e-isgued magar daklenonikoed.
\b
\q1 
\v 27 Dule yaa-dummad-akwiele, na dukin a-yaagi-argwanega guoed.
\q2 Ar dule akwa-dummad obaparmakele, na dukin e-birgi-sigega imakoed.
\b
\q1 
\v 28 Gakansaed-gwabin-duku, gayaburba-nuegan isdar-itodaed.
\q2 Yamo-nabiridyob-sunmaklegedi bela neg-oichoddaed.
\b
\c 27
\q1 
\v 1 Melle be san-dummarba-imakedgi binsao,
\q2 ar be wissulid, ibagan begi igi-daniki.
\b
\q1 
\v 2 Melle be dukin san-dummarba-imako,
\q2 dule-baigan be-nug-odummogedi, bur nabirid.
\b
\q1 
\v 3 Akwa ukusulid, ukubbela ukusurbalid,
\q2 dule-binsaedsulid-e-urweddi, aba bur bule yeer-gangued.
\b
\q1 
\v 4 Urwedi, yeer-gangued.
\q2 Sae-itogedgi-urwedi, dule-wioged.
\q2 Nobeddi, geg bargaleged.
\b
\q1 
\v 5 Arbakee-sabgulegedba,
\q2 bur nuedid, bakar-bega-ibmar-soged.
\b
\q1 
\v 6 Be-isdarad-yamo-be-wagar-uedba,
\q2 bur nuedid, be-ai-nued sabsur-bega-ibmar-soged.
\b
\q1 
\v 7 Dule, nue-immeles-gudiile, bar ibmar abedasulid.
\q2 Achanisse-bakar, budar madaed.
\q1 Dule, ukudmaada-gudiirdi, ibmar-gagbiregedse-bakar gunned,
\q2 ochigwayobi itodaed.
\b
\q1 
\v 8 Dule, dikasuli aineba gaamakdiidi, dikasuli nuu e-uugi gaamakdiyobid,
\q2 neguyagi sate daed.
\b
\q1 
\v 9 Gwallu-wawadikmaladi, ina-wawadikmaladi, e-yapanned weligwar dule-saed,
\q2 debayobi, ai-nued-binsaed-ukedi, dulega niga-ogannoged.
\b
\q1 
\v 10 Melle be-ai-obanedgi be binsao.
\q2 Melle be-bab-e-ai-obanedgi be binsabalo.
\b
\q1 Melle be-boni-itodiidi,
\q2 be-gwenad-negse be sedo.
\b
\q1 Bur be-gwenad-bebo-urwediidba,
\q2 bur nabirid, dule-be-neg-dikarba-maidse be naed.
\b
\q1 
\v 11 Machi, dule-binsaed-nikaa be dae, weligwar be an-imake.
\q2 Adi, an deebali, mesagwar-an-imakdimalad-gayamakoed.
\b
\q1 
\v 12 Dule-itoakwaa-binsaedi, boni-noed bato daksabindaed.
\q2 Degisoggu, mer boni-noega imakdaed.
\q1 Dule-binsaed-sateddi, boni-noalir akudakdaed.
\q2 Degisoggu, egi nue wileddasunnad.
\b
\q1 
\v 13 Dule, dule-baid-ular mani-gasad-bennukoye-sogsale, mani-bennuksulile, e-ibe be mor weenao,
\q2 dule-baid-mani-gasad-ular, be e-mor sioed.
\b
\q1 
\v 14 Dule bolegoedba binnasuli e-aise nuedgi-goler,
\q2 e-ai-gabmaidga ukabsalegedyob gued.
\b
\q1 
\v 15 Ome-ursili, dii-wied-ibagi, dii-gargarmaknaiyobi gued.
\q2 Urwedbi wisdaed.
\q1 
\v 16 Dule, e-igar-gaye-sogele, geg gaed,
\q2 burwayobid, burwadi geg galeged.
\q2 Argangi ibmar-gwallu-geg-abingalegeyobid.
\b
\q1 
\v 17 Esgoro, esgoro-baidgi oswiswimakleged.
\q2 Dule na ebo-idakmalale, igar-nuedse onomalad.
\b
\q1 
\v 18 Dule, sapi-nue-akwele, e-san gunnoed,
\q2 dule, e-dummadga nue-nakulediile, e-nug odummolegoed.
\b
\q1 
\v 19 Igi diigi, magar wagar dakledae,
\q2 deyobi, dule e-binsaedbali, na magar-daklesimogad.
\b
\q1 
\v 20 Igi-neg-uan ollorgusisuli, degi, burgwed-igar galemaisuli,
\q2 debayobi, dule ibmarbin-gadisogedi, napi-ibmar abedaed.
\b
\q1 
\v 21 Bormo-crisolʼgi mani wilubdakleged, soogi or wilubdaklemogad,
\q2 duledi, e-nug-odummolegedgi mag-daklemogad, igid-dule gue.
\b
\q1 
\v 22 Dule-binsaedsulid be nagele, amba uki be nagbalile, degi, ibmar-gwagyob be osarwele,
\q2 amba e-binsaed-sateddi, e-ibe be osulogosurguoed.
\b
\q1 
\v 23 Be-sibad-wawaadmar nue be dakdii sao,
\q2 be-molimar gatik nue be akwedii sao.
\q1 
\v 24 Ar ibmar-nuegana, degisadeguadsulid.
\q2 Manimala, degisadeguadsurbalid.
\q1 
\v 25 Sapur emilesale, gagan-aradik ainidagoed.
\q2 Sapurgi gagan-dutugana weledagoed.
\q1 
\v 26 Sibad-wawaadmar bega mor-yoed ukoed.
\q2 Sibaddi, bega nainu-bakega guoed.
\q1 
\v 27 Sibad-e-nunis bukidar be nikuoed,
\q2 adi, bedi, be-ome, be-mimmigana egi nabir itomaloed,
\q2 degine, bela-bega-arbamaladi, yeer-itomarmogoed.
\b
\c 28
\q1 
\v 1 Dule-isgana dule-e-balegin-danikiyobi, oes abarmakmaidaed.
\q2 Dule-nueddina, achumigur-nono-wawaadyobi, dobsurdaed.
\b
\q1 
\v 2 Yargi, nue-neg-isgusnaile, dummagan-negdakmalad ogwalemaidaed.
\q2 Dule-yar-seed nue-binsaed-nikale, igar-nikaa yar-selemaidaed.
\b
\q1 
\v 3 Dule-isgana mesagwar-dule-wilediid-imakedi, dii burwaba-mesa ibmar-digar-naidgi wieyobid,
\q2 bela ibmar-naid obeloged.
\b
\q1 
\v 4 Dule, Igar-maidgi-banguddamaladi, dule-isgana-nug odummoddamalad.
\q2 Dule, Igar-Maidba-nanadimaladdi, dule-isganamarbo gaardamalad.
\b
\q1 
\v 5 Dule-isganamar, igar-innikigwad aku itodamalad.
\q2 Dule, Bab-Jehová-Igarba-nanadimaladdi, bela magar ibmar-itodamalad.
\b
\q1 
\v 6 Dule-mani-ibed-sunnasurdaedba,
\q2 bur nuedid, dule-wileged-nueddaed.
\b
\q1 
\v 7 Dule, Igar-Maidba-nanadiile, dule-binsaed-nikadaedid.
\q2 Dule, dule-galagwensurdamaladba-nanaeddi, e-bab-obingegsaedid.
\b
\q1 
\v 8 Dule, dule-baidga-mani-gaar-ukedi, e-gakagi mani-onogele, yamolegoed.
\q2 Aka wiledimalad-bendakega, dule-wilemalad-bendakedga, omelodaed.
\b
\q1 
\v 9 Dule, Igar-Maid-itobisulile,
\q2 Bab-Dummad, a-dule-ese-goled itogosurmogad.
\b
\q1 
\v 10 Dule, igar-isganaba dule-innikidaed-nidele, dukin egi igar-isgana aibinmogoed.
\q2 Dule-gwage-nuegandi ibmar-nued abingaoed.
\b
\q1 
\v 11 Dule-mani-ibedi, na binsadaed, ede, binsaed-ibedye.
\q2 Dule-wileged-ibmar-nue-wisiddi, bela wisid, we-dulede, doa-dule.
\b
\q1 
\v 12 Dule-innikidamalad nakwisale, iba-dummad onoleddaed.
\q2 Dule-isganamar nakwenonikirdi, bela dulemar dobedba dukuddaed.
\b
\q1 
\v 13 Dule, e-isgued gwageginbi sediile, nued-gudii guosulid.
\q2 Dule, e-isgued na barsogerdi, egi banguerdi, Bab-Dummad wiledakoed.
\b
\q1 
\v 14 Dule, gusgu Bab-Jehová-dobee nanadiidi, egi ise-nued binsalesad.
\q2 Dule, gwage-dutusuliddi, nue-wilegoed.
\b
\q1 
\v 15 Dule-yar-seed-isgana, dule-wilemalad-mesagwar-imakmaile,
\q2 achumigur-nono-wawaad mas-gaeyobid, wiob mas-gasa gunaiyobid.
\b
\q1 
\v 16 Dummadga-negsemaid aku-neg-itogedi, bur bule dulega neg-gagaed.
\q2 Dummadga-negsemaid ibmar-nueganbina surbinsa-itosuliddi, undar suitii gudigued.
\b
\q1 
\v 17 Emar-gindaksad-ular, dule balegillediile, oburgwilegedsegad.
\q2 Gwen dule e-ular-gwisguosulid.
\b
\q1 
\v 18 Dule, igar-nuedba napira nanadiidi, bendaklegoed.
\q2 Dule-galagwensur-garmakdiiddi, ibagwengi dummad-wiolegoed.
\b
\q1 
\v 19 Dule, arbaele, mas-bukidar-nika guoed.
\q2 Dule, arbasulile, wilegedga gudoed.
\b
\q1 
\v 20 Dule-nueddaedi, egi-ise-nued-binsaledii guoed.
\q2 Dule, gwae-gwae mani-ibedga-gubieddi, sabsur-odurdaklesuli guosulid, odurdaklegedsegad.
\b
\q1 
\v 21 Dulemar bela emarbi be dakoed,
\q2 akar-akar be dakosulid.
\q1 Akar-akar be dakele, igar-nuedsulid.
\q2 Ar madu-wargwengi bato binsaed-galeddamalad.
\b
\q1 
\v 22 Dule-manibina-surbinsa-itogedi, gwae mani-ibedga gubidaed,
\q2 ar egi wileged-dummad danikodeeye binsasurdaed.
\b
\q1 
\v 23 Dule, dule-baidga, nuedgi-sabsur-ibmar-sogele, sorba egi nued sunmakleged.
\q2 Dulega-nuedgi-sunmakedba bur bule egi nued sunmakledaed.
\b
\q1 
\v 24 Dule, e-sergan-ibe, ibmar-atursaele, ede, ibmar-oakalossurye sogbalile,
\q2 we-dule, dule-isgana-e-aid.
\b
\q1 
\v 25 Dule, ibmarbin-sogerbadi, neg-gagaedid.
\q2 Dule Bab-Jehováʼgi bensulirdi, Bab-Dummadgi nasgumai guoed.
\b
\q1 
\v 26 Dule, dukin na egi-bensulile, dule-binsaedsulidaedid.
\q2 Dule, binsaed-nikaguedgi ibmar-saele, bendakleged.
\b
\q1 
\v 27 Dule, dule-wilemalad-bendakedi, wilegedga guosulid.
\q2 Dule, dule-wilemalad-bendaksuliddi, sabsur-ukabsalegoed.
\b
\q1 
\v 28 Dule-isganamar nakwisale, bela dulemar dobedba dukuddaed.
\q2 Dule-isganamar bergunonikirdi, dule-innikidamalad nasguddaed.
\b
\c 29
\q1 
\v 1 Dule, nuedgi-ega-ibmar-sogleged amba itossulile,
\q2 wiledaklesuli, sabsur ukiagwale, sarsolegoed.
\b
\q1 
\v 2 Dule-innikidamalad nasgudele, neggwebur yeer itodaed.
\q2 Dule-isganamar negsealile, neggwebur bukib binsaddaed.
\b
\q1 
\v 3 Dule, binsaed-nueganbina itogerbale, weligwar e-bab-saed.
\q2 Dule, gambanuchu-samaladgi mani-miele, bela na mani-nikadi obeloged.
\b
\q1 
\v 4 Rey, igar-innikigwadba-negseedi, yar-nue-innikii sedaed.
\q2 Ar rey, unnila neggweburgi mani-gaedginbi binsaerdi, neggwebur-wioddaed.
\b
\q1 
\v 5 Dule, e-aiga yamo-nueganbi-sunmakedi,
\q2 e-ai-yardakega sunmakdaed.
\b
\q1 
\v 6 Dule-ibmar-isgana-imakedi, dukin e-isguedse yamoleged.
\q2 Dule-innikiidaeddi, weligwaledba namakdaed.
\b
\q1 
\v 7 Dule-nueddaedi, dule-wilemalad-bendakdidaed.
\q2 Dule-ibmar-isgana-imakeddi, dule-wilemaladgi binsadasulid.
\b
\q1 
\v 8 Aimargi-gadi-dodomaladi, neggwebur-oimaker saed.
\q2 Dule-binsaed-ibegandi, bogidik neg-imaked.
\b
\q1 
\v 9 Dule-binsaed-ibedi, dule-binsaedsulidbo abin-abin-imakele,
\q2 amba ebo-urwodibe, ebo alledibe, gwen igar nudakosurmalad.
\b
\q1 
\v 10 Dule-gindakmaladi, dule-nuegan-sae dakdamalad,
\q2 dule-nuegan-oburgwebidamalad.
\b
\q1 
\v 11 Dule-binsaedsulidi uludele, bar galedasulid.
\q2 Dule-binsaed-ibeddi, nabir san-bargaed wisid.
\b
\q1 
\v 12 Dummadga-negdakmaid gakansaedba-ebipiledele,
\q2 bela ega dummaganga-arbamaladi ibmar-isgana-imakedga guoed.
\b
\q1 
\v 13 Dule-wilegedi, mesagwar-dule-imakedbogwa emarbimalad.
\q2 Bab-Jehová ebobela magar-atake imaksad.
\b
\q1 
\v 14 Rey, igar-innikigwadba dule-wilemaladga igar nabogele,
\q2 e-yar-seedi, degisadeguoed.
\b
\q1 
\v 15 Sarsolegedi, nuedgi-sabsur-ibmar-sogedi, binsaed-nikaa dule-imaked.
\q2 Mimmi-uayasulidaeddi, e-nan-bingedar imaked.
\b
\q1 
\v 16 Ibmar-isgana-imakmalad bukidarale, isgued bukidardaed.
\q2 Dule-nueddamaladdi, dule-isganamar-bergued dakoed.
\b
\q1 
\v 17 Be-mimmi be unaele, bonisuli-gudii be-imakoed,
\q2 weligwaled bega ukoed.
\b
\q1 
\v 18 Bab-Dummad-gayaburba barsoglesulile, neggwebur yogasaar nanaddaed.
\q2 Dule Igar-Maid-sogedba nanadiile, egi ise-nued binsaleged.
\b
\q1 
\v 19 Mai, uayasuli-gualile, gayaginbi-ega-ibmar-soged unnisurdaed.
\q2 Nabir ibsaegala, wis bibyoleged abeledabalid.
\b
\q1 
\v 20 Dule nue-binsasulidgi-sunmakedi, nue be dake.
\q2 Ar dule-binsaedsulid-sunmaked-bursunna, bur bule yogasaar sunmakdaed.
\b
\q1 
\v 21 Dule, na e-mai, bipigwad-akar unadii nanassulile,
\q2 sorba, bukib-binsaed-dummad ega ukoed.
\b
\q1 
\v 22 Dule-urwegala, urwed onogerbadaed.
\q2 Dule-yaisur-urwedi, yeer-isguddaed.
\b
\q1 
\v 23 Dule-san-dummarbadaedi, nug-bipii guoed.
\q2 Dule-san-bipi-imakeddi, nug-dummarbaa guoed.
\b
\q1 
\v 24 Dule, ibmar-atursaed-duleba-akaedi, dukin na san-wioged.
\q2 Dule-ibmar-atursaed-galenonikile, amba dule-eba-akadidse ise-egisar-gunanaidibe geg barsoged.
\b
\q1 
\v 25 Ar be dulemar-dobee-itogele, dukin be yamolegoed.
\q2 Be Bab-Jehováʼgi-bensulile, bonigangi be ollorgudoed.
\b
\q1 
\v 26 Dule-bukidar, dummadga-negdakmaid ega-ibmar-imakegala amidamalad.
\q2 Unnila Bab-Jehováʼbi dulemarga igar-nabomaid.
\b
\q1 
\v 27 Dule-innikimaladi, dule-ibmar-isgana-imakmalad isdar dakdaed.
\q2 Dule-ibmar-isgana-imakmaladi, dule-innikimalad isdar dakdamogad.
\c 30
\ms1 7. AGUR-E-BINSAED-NUEGAN-SOGSAD
\mr (30:1-33)
\p 
\v 1 Jaqué-machi-Agur-ibmarmar-sogsad. Agur, Itielʼga, degi, Ucalʼga weyob sunmaksad:
\q1 
\v 2 “Andi dulemarba bur bule ibmar-wissulid,
\q2 akusunna an ibmar itoged.
\q1 
\v 3 Binsaed-nikaguedi an durdaksasulid,
\q2 Bab-Dummad-Isligwaledbela an akusunna itoged.
\b
\q1 
\v 4 ”¿Doa nibnegse nakwiapi?
\q2 ¿Doa nibneg-akar aidenoniki?
\q1 ¿Doa e-argangi burwa gaoe?
\q2 ¿Doa e-mor-dummadgi demar gaoe?
\q1 ¿Doa napneg-naid-dikarmar omesisa?
\q2 ¿Ar be wisi, doa we-ibmarmar-imaksa, degi, e-machi-nug be wisbali?
\b
\q1 
\v 5 ”Bela Bab-Dummad-gayaburbagi bensuli guleged.
\q2 Bab-Dummadi, sigu-abgaedyob dule-egi-bendakleged-amimalad-irwa gwisgued.
\q1 
\v 6 Melle Bab-Dummad bega-sabsur-ibmar-sogega,
\q2 degi, melle dule-gakansaedga be-imakbaliga,
\q2 melle-e-gayaburbamar-maid be obulogo.
\b
\q1 
\v 7 ”Bab-Dummadye, unnila ibmar-sogbo an bese egised.
\q2 An burgwed-iduale, melle be anga imaksuli guo,
\q2 be anga we-ibmar-sogbogwad imakedsego:
\q1 
\v 8 Igar-isganagi, gakan-igargi, be an-ollor-imake.
\q2 Melle dule-wilegedga, dule-mani-ibedga be an-imakbalo.
\q2 Unnila ibmar-nue-abelemaladi be anga ukmai imako.
\q1 
\v 9 Ar an mani-ibedga gudele, abakar na be-iealile,
\q2 abakale an sokalile: ¿Ar doa wede Bab-Jehováʼye?
\q1 Degine, an wiledibalile, abakar ibmar-atursaarbalile,
\q2 degidbali, an be-nug-ichoge dakledagoed.
\b
\q1 
\v 10 ”Melle mai-e-dummad-asabinni e-maigi ichakwa sunmako,
\q2 adi, melle, we-mai be-ukabsaega, degidbali, be dummad-wilegoed.
\b
\q1 
\v 11 ”Ar gwen-gwena dulemar gadi-e-bab-ukabsadaed,
\q2 degi, e-nangi ise-nued binsasurdabalid.
\q1 
\v 12 Ar gwen-gwena dulemar san-swilidikye na bidamalad.
\q2 Degi-inigwele, isguedginbi gudidamalad.
\q1 
\v 13 Ar gwen-gwena nuga-nikamaladye na sogdidamalad,
\q2 yamo bule-bule dulemarga gudidamalad.
\q1 
\v 14 Gwen-gwena dulemar dule-wilemalad-wiogega, dule-ibmar-nue-abedimalad-wiogega,
\q2 es-suidyobi, e-nugar-imaksa gudidamalad, estinyobi, e-akugar-imaksa gudidamalad.
\b
\q1 
\v 15 ”Nus-abe-gobed, mimmigan warbo nikad,
\q2 amala unnila weyob sokardamalad: ‘Udage, napi-udage.’
\b
\q1 ”Ibmarmar geg wis-nubin-itodamaladi, sogbaa nikabalid.
\q2 Ibmar-sogbakegwaddi, ‘gusye’ geg sogdaed.
\q1 
\v 16 A-ibmarmar, wemalad:
\q1 Burgwarmalad-meged-galu, napi-dule-burgwarmalad-abedaed.
\q2 Ome-geg-mimmi-baked, mimmigan-abedaed.
\q1 Napa diibina napi-sogdaed.
\q2 Soo-duurmaksiid napi-sapan-abedaed.
\b
\q1 
\v 17 ”Dule, urwakwaa e-bab-dakele, degi, e-nan-sogedba dasulile,
\q2 sikwisichid e-ibe ibya-onosun,
\q2 mula-non-ginnid, dula-gunsun.
\b
\q1 
\v 18 ”Ibmar-sogbaagwad an geger itoged,
\q2 ibmar-sogbakegwaddi, an nue-aku itoged.
\q1 
\v 19 A-ibmarmar, wemalad:
\q1 Mogir-billiba-sulubagi-nalla-naguedi, igi an magar itogoe.
\q2 Akwasaila-dummadgi-naibe-nakwedi, igi an nabir magar itogoe.
\q1 Demargi-ur-dummad-nadapir-geg-dogedi, igi an nabir magar itogoe.
\q2 Degine, igi an magar itobaloe, dule abirgunagwar-gudii gubidaed.
\b
\q1 
\v 20 ”Ome, machered-dikarba-yoleged-e-daed weyobdo:
\q2 Ome, machered-baid-ebo nog-gobdedaed,
\q1 a-sorbali, na abalukdedaed.
\q2 An neg-oakalossurye sogdedaed.
\b
\q1 
\v 21 ”Dulemar-ibmar-abedasulid-sogbaa nikadi, napneg-wawanmaker saed.
\q2 Sogbakegwaddi, napneg-giglimaker imaked.
\q1 
\v 22 A-ibmarmar, wemalad:
\q1 Mai reyga megider, geger dakleged.
\q2 Dule-binsaedsulid mani-ibedga-guder, geger dakleged.
\q1 
\v 23 Ome-galagwensuli-nanaed sui-nikuder, geger dakleged.
\q2 Mai-ome e-dummad-omegi dummadga-guder, bur bule geger dakleged.
\b
\q1 
\v 24 ”Napneggi ibdurgan-burwigwad sogabake nikad,
\q2 dule-binsaed-ibedbali bur binsaed-ibeganad.
\q1 
\v 25 A-ibdurgan wemardo:
\q1 Iglimar, sorda-gandikidsurmaladid,
\q2 degi-inigwele, yor-mosale, e-mas saboddamalad.
\q1 
\v 26 Nubimar, dogdar sorda nikasurmalad,
\q2 degi-inigwele, akwa-ollogana-yaba e-gabedneg sobmalad.
\q1 
\v 27 Sesmar, e-idued satemalad,
\q2 degi-inigwele, darekwaa nadapdamalad.
\q1 
\v 28 Asbanmar, baisursunna argangi galemalad,
\q2 degite, reyneggi gudidamalad.
\b
\q1 
\v 29 ”Ibmar-sogbaa nikabalid, yeerdakle-gandikidba garmakdidaed.
\q2 Sogbakegwaddi, gandikidba nanadidaed.
\q1 
\v 30 A-ibmarmar, wemalad:
\q1 Achumigur-nono-wawaad, ibmar-durgan-bamaladba bur buledid, ibmar-abin sikirmaked satedaed.
\q2 
\v 31 Gannir-machered, san-dummarbaa imakdidaed.
\q1 Sibad-machered, e-bebe burwisur-dakledaed.
\q2 Degine, rey, e-sorda-bila-onomalad-asabin e-ologurgin-sii nadapdaed.
\b
\q1 
\v 32 ”Dule-binsaedsuliyobi be san-odummosale, melle bar egi be binsao.
\q2 Ibmar-isgana-imakedgi be binsas-gudiile, melle bar egi be binsao.
\q1 
\v 33 Dule, moli-nunis-eguredi, egi e-nunis-gwamakaled amied.
\q2 Binnasur be asa-ogolele, bega abe ariodagoed.
\q1 Be urwed-amiele,
\q2 urwenai be gudoed.”
\c 31
\ms1 8. REY-LEMUEL BINSAED-NUEGAN NARMAKSAD
\mr (31:1-9)
\p 
\v 1 Rey-Lemuel-ibmarmar-sogsad. E-nana we-igargi Lemuel-odurdaksad:
\b
\q1 
\v 2 “Machi, ¿igi an bega ibmar sogsale?
\q2 An-nukugi-dungued, ¿igi an be-unasale?
\q1 Bab-Dummadse-ise-egislegaled-mimmi-gued,
\q2 ¿igi na bega binsaed uksale?
\b
\q1 
\v 3 ”Melle omeganbina surbinsa itogo.
\q2 Bukidar reymar omeganse galakumaid.
\b
\q1 
\v 4 ”Lemuel, reymar sisa-gobedi, igar-nuedsulid.
\q2 Dule-dummagan-negdakmaidi mumguedi, igar-nuedsurbalid.
\q1 
\v 5 Abakale, mumgudedgi, igar-maid iedmalale,
\q2 dule-wilemaladgi bar binsasuli gudmalale.
\q1 
\v 6 Bur be dulemar-burgwedanigus-maidga sisa uke,
\q2 bur be dulemar-sae-itodiidga vino uke,
\q1 
\v 7 adi, itoba na mumgumalagar, ibmar-abesa-gudiid, iemalagar,
\q2 ise-wilegar-gudiidgi mer bar binsamalagar.
\b
\q1 
\v 8 ”Dule-belagwadamalad-ular be sunmake,
\q2 dule-sergan-sated-ibmar-ular be gwisgue.
\q1 
\v 9 Wemar-ular be sunmake,
\q2 igar-napiragwadba ega be igar itoge,
\q1 dule-wilese-gudimalad be bendake.
\q2 Dule-ibmar-nue-abesagudimalad be bendake.”
\ms1 9. OME-INNIKIDAED-E-NUG-ODUMMOLEGED
\mr (31:10-31)
\q1 
\v 10 Ome-innikigwadba-e-daed-oyogedi, ¿doa amioe?
\q2 Ar akwa-nuegan-gargerbamaladba bur sunsogedid.
\b
\q1 
\v 11 E-sui egi bensurdaed.
\q2 E-omeba ibmar nikagudaed, ega ibmar galakusurdaed.
\q1 
\v 12 Ome e-suiga, bane-bane ibidar-nuedga gued,
\q2 ibmar-isganaga ega gusulid.
\q1 
\v 13 Ome, lino-dub-baknaddaed, sibad-wawaad-e-absar baknaddabalid,
\q2 na yeer-itogedba e-gonugargi morgi arbadaed.
\q1 
\v 14 Igi-ur-dummagan-ibmar-ukedi, dikasuli-mas-sedanidae,
\q2 debayobi, ome mas sedanidaed.
\q1 
\v 15 Bolegoedba gwichiguardaed,
\q2 masgi na e-mimmigan ogunnardaed,
\q2 e-maimarga, neggi-ibmar-imaklegedi urmakdaed.
\q1 
\v 16 Nainu-nued amidaed, geb nainu bakdaed,
\q2 nainugi, uvaʼbi bipirmaknai imakdaed.
\q1 
\v 17 Ome, arbaega, guagwar gunaidaed,
\q2 gandikidba na surgan-minaidaed.
\q1 
\v 18 Ome, e-ibmar-ukedi nueganbi nasgumaidaed.
\q2 Mutikidbali, e-neggi gwallu-dummad akinsisulid,
\q2 ar mutik-mutik arbasidaed.
\q1 
\v 19 Argan-nailik mor-sobed-naku gani sidaed.
\q2 Argan-baidsik, dub ebisidaed.
\q1 
\v 20 Ome, dule-wileged-bendakdaed,
\q2 dule-ibmar-abesaagudiid-bendakdaed.
\q1 
\v 21 Dambed-sibudik-sibudik batealile, e-mimmiganga bukib-binsadasulid.
\q2 Ar bela e-mimmigan dambed-mor yoyoidbi damalad.
\q1 
\v 22 Ome na dukin, ubsan-mor-uki mor-baid makdaed,
\q2 mor-suir-akwagiid yoidaed, lino-mor-sunsogmalad yoidabalid.
\q1 
\v 23 Dulemar bela neggweburgi e-sui mag-dakedbimalad.
\q2 E-sui, ibmar-dummadga dummagan-abargi simogad.
\q1 
\v 24 Ome, lino-mor-nued-sobedi, saderba-mor-nagumalad-imakedi,
\q2 dulemar-ibmar-ukmaladga manigi ukdaed.
\q1 
\v 25 Ome, innikigwadba gudidaed. E-nug dummarbaa gued.
\q2 Ibmar-guoedga, bukib binsadasulid, ega alledaed.
\q1 
\v 26 Sunmakdele, binsaed-nikaa sunmakdedaed,
\q2 dule-odurdakdele, sabekwaa dule-odurdakdaed.
\q1 
\v 27 E-neguya-selemaidgi nue-nakuledaed,
\q2 e-mani-amiedginbi na mas-gundaed.
\b
\q1 
\v 28 E-mimmigan, e-nanga sokardaed, bedi nan-nuedye.
\q2 E-sui, e-ome-nug odummodamogad. Ega sogdaed:
\q1 
\v 29 “Ome-nuegan bukidar nikaye,
\q2 degi-inigwele, bedi amarba bur bule ome-nuedye.”
\b
\q1 
\v 30 Yeerdaklegedi, dule-yamogedid. Yeerdaklegedi, sikwas yeer dakledaed.
\q2 Ome Bab-Jehová-dobee-nanaeddi, e-nug odummolegoed.
\b
\q1 
\v 31 Dulemar, ome-e-ibmar-imaked magar dakmarsun.
\q2 Bela dulemar-abargi e-nug odummolesun.
