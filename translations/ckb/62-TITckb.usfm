\id TIT - Biblica® Open Kurdi Sorani Standard Version
\h تیتۆس
\toc1 نامەی پۆڵس بۆ تیتۆس
\toc2 تیتۆس
\toc3 تیتۆس
\mt1 نامەی پۆڵس بۆ تیتۆس
\c 1
\p 
\v 1 لە پۆڵسەوە، بەندەی خودا و نێردراوی عیسای مەسیح، لە پێناوی گەشەکردنی باوەڕی ئەوانەی خودا هەڵیبژاردوون بۆ ناسینی ئەو ڕاستییەی کە بەرەو لەخواترسییان دەبات،
\v 2 بە هیوای ئەو ژیانە هەتاهەتاییەی کە خودا، ئەوەی هەرگیز درۆ ناکات، لەپێش دەستپێکی زەمان بەڵێنی داوە.
\v 3 لە کاتی خۆیدا وشەکەی بە ڕاگەیاندن دەرخست، ئەوەی بەگوێرەی فەرمانی خودای ڕزگارکەرمان بە من سپێردرا.
\b
\p 
\v 4 بۆ تیتۆسی کوڕی ڕاستەقینەم بەگوێرەی باوەڕی هاوبەشمان:
\b
\p با نیعمەت\f + \fr 1:4 \ft نیعمەت بەخشینێکی خودایە بە مرۆڤ بەبێ شایستەبوونی پێی دەبەخشێت.\f* و ئاشتی لە خودای باوک و عیسای مەسیحی ڕزگارکەرمانەوە لەگەڵت بێت.
\b
\s1 ڕاسپاردەی دانانی پیران
\p 
\v 5 لەبەر ئەمە تۆم لە دوورگەی کریت\f + \fr 1:5 \ft دوورگەیەکە لە دەریای ناوەڕاست.‏\f* بەجێهێشت، تاکو ئەو شتانەی ماونەتەوە ڕێکیان بخەیت و لە هەموو شارێکدا پیران دابنێیت، وەک ڕامسپاردوویت.
\v 6 پیر دەبێت گلەیی لەسەر نەبێت، مێردی یەک ژن بێت، منداڵەکانی باوەڕدار بن و کەس لەسەر بەڕەڵایی و یاخیبوون سکاڵایان لێ نەکات.
\v 7 لەبەر ئەوەی چاودێر سەرکاری خودایە، پێویستە گلەیی لەسەر نەبێت، خۆسەپێن و تووڕە و سەرخۆش و شەڕفرۆش نەبێت، چاوی لە دەستکەوتی ناڕەوا نەبێت،
\v 8 بەڵکو میوان دۆست بێت، حەز لە چاکە بکات، ژیر بێت، ڕاستودروست و پیرۆز و خۆڕاگر بێت.
\v 9 دەست بە پەیامی متمانەوە بگرێت کە بەگوێرەی فێرکردنە، تاکو بتوانێت بە فێرکردنی دروست خەڵک هانبدات، سەرزەنشتی بەرهەڵستکاران بکات.
\s1 دژایەتی مامۆستا درۆزنەکان
\p 
\v 10 باسی ئەو شتانە دەکەم، چونکە خەڵکی یاخی زۆرن کە فێڵبازن و قسەی پووچ دەکەن، بە تایبەتی لەو تاقمەی کە دەڵێن دەبێ باوەڕدار خەتەنە بکرێت.
\v 11 دەبێت دەمی ئەمانە دابخرێت، چونکە بۆ دەستکەوتی ناڕەوا، بە فێرکردنە ناپەسەندەکانیان تەواوی خێزانەکان هەڵدەگەڕێننەوە.
\v 12 یەکێک لە پێغەمبەرانی دوورگەی کریت گوتوویەتی: «کریتییەکان هەمیشە درۆ دەکەن، دەعبای بەدکارن، نەوسنی تەمبەڵن.»
\v 13 ئەم شایەتییە ڕاستە. لەبەر ئەوە بە توندی سەرزەنشتیان بکە، تاکو لە باوەڕەکەدا دروست بن و
\v 14 سەرنج نەدەنە ئەفسانەی جولەکە و ڕاسپاردەی ئەو کەسانەی کە لە ڕاستی هەڵدەگەڕێنەوە.
\v 15 بۆ پاک هەموو شتێک پاکە، بەڵام بۆ گڵاو و بێباوەڕان هیچ شتێک پاک نییە. لەڕاستیدا، بیر و ویژدانیشیان گڵاو بووە.
\v 16 بانگەشەی ئەوە دەکەن کە خودا دەناسن بەڵام بە کردەوە نکۆڵی لێ دەکەن. ئەوانە قێزەونن و گوێڕایەڵ نین و بەکەڵکی هیچ چاکەکارییەک نایەن.
\c 2
\s1 ڕاسپاردە بۆ باوەڕداران
\p 
\v 1 بەڵام تۆ دەبێت بە فێرکردنی دروست خەڵکی فێر بکەیت.
\v 2 پیرەمێردەکان فێر بکەن کە وریابن، بەڕێز، ژیر، دروست بن لە باوەڕ و خۆشەویستی و دانبەخۆداگرتن.
\p 
\v 3 هەروەها پیرێژنەکان فێر بکەن کە بە ڕێزەوە بژین، بوختانکەر نەبن و خوو بە شەرابەوە نەگرن، بەڵکو شتی چاک فێری خەڵکی بکەن،
\v 4 تاکو ئامۆژگاری ژنە گەنجەکان بکەن کە مێرد و منداڵیان خۆشبوێت،
\v 5 ژیر و پاک بن، بە ماڵەوە سەرقاڵ بن، چاک بن و ملکەچی مێردەکانیان بن، نەوەک کفر بە وشەی خودا بکرێت.
\p 
\v 6 بە هەمان شێوە، هانی پیاوە گەنجەکان بدە ژیر بن.
\v 7 لە هەموو شتێکدا بۆیان ببە بە نموونەی چاکەکاری. لە فێرکردندا دروستی و دڵسۆزی پیشان بدە،
\v 8 با قسەت دروست بێت و ڕەخنەی لێ نەگیرێت، تاکو ناحەز شەرمەزار بێت، چونکە هیچی خراپ نادۆزێتەوە لە دژتان بیڵێت.
\p 
\v 9 کۆیلەکانیش لە هەموو شتێکدا ملکەچی گەورەکانیان بن، ڕازییان بکەن، بەرپەرچیان نەدەنەوە،
\v 10 هیچیان لێ نەدزن، بەڵکو ئەوپەڕی دەستپاکی پیشان بدەن، تاکو لە هەموو شتێکدا فێرکردنی خودای ڕزگارکەرمان بڕازێننەوە.
\p 
\v 11 نیعمەتی خودا دەرکەوت و ڕزگاری پێشکەشی هەموو خەڵک دەکات.
\v 12 ئەوەی فێرمان دەکات نکۆڵی لە خوانەناسی و هەوەسە دنیاییەکان بکەین، بە ژیری و ڕاستودروستی و لەخواترسی بژین لەم دنیایە،
\v 13 لە چاوەڕوانی هیوای بەرەکەتدار، دەرکەوتنی شکۆی خودای گەورە و ڕزگارکەرمان، عیسای مەسیح،
\v 14 ئەوەی بۆ ئێمە خۆی بەختکرد، تاکو لە هەموو سەرپێچییەک بمانکڕێتەوە و گەلێکی تایبەت بۆ خۆی پاک بکاتەوە، دڵگەرم بۆ چاکەکاری.
\p 
\v 15 ئەو شتانە فێری خەڵکی بکە، هانیان بدە و بە هەموو دەسەڵاتێک سەرزەنشتیان بکە. ڕێگا مەدە کەس بە کەمت بزانێت.
\c 3
\s1 ڕزگاری بەهۆی ڕۆحی پیرۆز
\p 
\v 1 یادی باوەڕداران بخەرەوە ملکەچی فەرمانڕەوایان و دەسەڵاتداران بن، گوێڕایەڵ بن، بۆ هەموو کارێکی چاک ئامادەبن،
\v 2 قسە بە کەس نەڵێن، شەڕفرۆش نەبن، خۆنەویست بن، لەگەڵ هەموو خەڵک دڵنەرمی پیشان بدەن.
\p 
\v 3 پێشتر ئێمەش گێل و یاخی و گومڕا بووین، کۆیلەی هەموو جۆرە هەوەسبازی و چێژ وەرگرتنێک بووین، لە قین و ئیرەییدا دەژیاین، ئێسکگران بووین، ڕقمان لە یەکتری بوو.
\v 4 بەڵام، کاتێک میهرەبانی خودای ڕزگارکەرمان و خۆشەویستییەکەی دەرکەوت،
\v 5 نەک بەهۆی کاری ڕاستودروست کە ئێمە کردوومانە، بەڵکو بە بەزەیی خۆی ڕزگاری کردین، ئەویش لە ڕێگەی ئەو شوشتنەوەیە بوو، کە بەهۆیەوە ڕۆحی پیرۆز لەدایکبوونەوەیەکی نوێ و ژیانێکی نوێی پێ بەخشین،
\v 6 ئەوەی لە ڕێگەی عیسای مەسیحی ڕزگارکەرمانەوە بە دڵفراوانییەوە ڕشتی بەسەرماندا،
\v 7 تاکو، پاش ئەوەی بە نیعمەتی ئەو بێتاوان کراین، بەگوێرەی هیوای ژیانی هەتاهەتایی ببینە میراتگر.
\v 8 ئەم قسەیە ڕاستە. دەمەوێ سوور بیت لەسەر ئەم شتانە، تاکو ئەوانەی باوەڕیان بە خودا هێنا بایەخ بەوە بدەن کە بۆ کرداری چاک خۆیان تەرخان بکەن. ئەم شتانە باش و سوودبەخشە بۆ خەڵک.
\s1 دوورکەوتنەوە لە قسەی پووچ
\p 
\v 9 بەڵام لە گفتوگۆی گێلانە و ڕەچەڵەک و ناکۆکی و شەڕ لەسەر تەورات دووربکەوە، چونکە بێ سوود و پووچە.
\v 10 ناکۆکیکار ئاگادار بکەوە، لەدوای جارێک و دووان، لێی دووربکەوە.
\v 11 دەزانیت کەسانی وەک ئەو، لادەر و گوناهبارە و خۆی حوکمی بەسەر خۆیدا داوە.
\b
\s1 دوا ڕاسپاردە
\p 
\v 12 کاتێک ئەرتیماس یان تیخیکۆس دەنێرمە لات، هەوڵ بدە لە نیکۆپۆلیس بێیت بۆ لام، چونکە بەتەمام زستان لەوێ بمێنمەوە.
\v 13 هەوڵ بدە زیناسی پارێزەر و ئەپۆلۆس بنێری، تاکو پێویستیان بە هیچ نەبێت.
\b
\p 
\v 14 پێویستە خەڵکەکەمان فێربن کە خۆیان بۆ کرداری چاک و پێداویستییە گرنگەکان تەرخان بکەن، تاکو بێ بەرهەم نەبن.
\b
\p 
\v 15 هەموو ئەوانەی لەگەڵمدان سڵاوت لێدەکەن.
\p سڵاو لەوانە بکە کە لە باوەڕدا ئێمەیان خۆشدەوێت.
\b
\p با نیعمەت لەگەڵ هەمووتان بێت.
