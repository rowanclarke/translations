\p
\v 17  \w When|strong="H7971"\w* \w Moses|strong="H4872"\w* \w sent|strong="H7971"\w* \w them|strong="H7971"\w* \w to|strong="H7971"\w* \w investigate|strong="H8446"\w* \w the|strong="H7971"\w* land \w of|strong="H2022"\w* \w Canaan|strong="H3667"\w*, \w he|strong="H7971"\w* told \w them|strong="H7971"\w*, “\w Go|strong="H5927"\w* \w up|strong="H5927"\w* through \w the|strong="H7971"\w* \w Negev|strong="H5045"\w*, \w and|strong="H4872"\w* \w then|strong="H2088"\w* \w go|strong="H5927"\w* \w up|strong="H5927"\w* \w into|strong="H5927"\w* \w the|strong="H7971"\w* \w hill|strong="H2022"\w* \w country|strong="H2022"\w*  
