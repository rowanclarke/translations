\id NAM
\h Nahúm
\toc3 Nah
\toc2 Nahúm
\toc1 Nahúm
\mt1 Nahúm
\c 1
\p 
\v 1 \w Profecía|strong="H2377"\w* sobre \w Nínive|strong="H5210"\w*. Rollo de la \w visión|strong="H2377"\w* de Nahúm de Elcós.
\v 2 \nd \w Yavé|strong="H3068"\w*\nd* \w es|strong="H1931"\w* \nd \w ʼEL|strong="H1931"\w*\nd* \w celoso|strong="H7072"\w* y justiciero. \nd \w Yavé|strong="H3068"\w*\nd* \w es|strong="H1931"\w* \w vengador|strong="H5358"\w* y \w lleno|strong="H1167"\w* de indignación. \w Se|strong="H1931"\w* venga de \w sus|strong="H1931"\w* \w adversarios|strong="H6862"\w* y \w guarda|strong="H5201"\w* \w su|strong="H1931"\w* \w enojo|strong="H2534"\w* contra \w ellos|strong="H1931"\w*.
\s1 La reserva para sus adversarios
\p 
\v 3 \nd \w Yavé|strong="H3068"\w*\nd* es lento para la ira y \w grande|strong="H1419"\w* en \w poder|strong="H3581"\w*. De \w ninguna|strong="H3808"\w* manera dejará \w sin|strong="H3808"\w* \w castigo|strong="H5352"\w* \add al culpable\add*. \nd \w Yavé|strong="H3068"\w*\nd* camina en la tempestad y en la tormenta, y las \w nubes|strong="H6051"\w* \w son|strong="H3808"\w* el polvo de sus \w pies|strong="H7272"\w*.
\v 4 Reprende al \w mar|strong="H3220"\w* y \w lo|strong="H3605"\w* hace secar. Evapora \w todos|strong="H3605"\w* \w los|strong="H3605"\w* ríos. \w Basán|strong="H1316"\w* y \w la|strong="H3605"\w* montaña Carmelo se marchitan y \w la|strong="H3605"\w* \w flor|strong="H6525"\w* del \w Líbano|strong="H3844"\w* se desvanece.
\p 
\v 5 \w Ante|strong="H6440"\w* \w Él|strong="H3605"\w* \w tiemblan|strong="H7493"\w* las montañas y las colinas \w se|strong="H4480"\w* derriten. \w Ante|strong="H6440"\w* su \w presencia|strong="H6440"\w* \w se|strong="H4480"\w* conmueve \w la|strong="H3605"\w* tierra, \w el|strong="H3605"\w* \w mundo|strong="H8398"\w* y \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w que|strong="H4480"\w* viven \w en|strong="H4480"\w* \w él|strong="H3605"\w*.
\v 6 \w Ante|strong="H6440"\w* su \w ira|strong="H2534"\w*, ¿\w quién|strong="H4310"\w* podrá estar \w en|strong="H4480"\w* \w pie|strong="H5975"\w*? ¿\w Quién|strong="H4310"\w* podrá resistir \w el|strong="H4310"\w* ardor \w de|strong="H4480"\w* su \w ira|strong="H2534"\w*? Su \w furor|strong="H2534"\w* \w se|strong="H4480"\w* derrama como \w el|strong="H4310"\w* fuego, y \w ante|strong="H6440"\w* \w Él|strong="H4310"\w* \w se|strong="H4480"\w* desmenuzan las rocas.
\p 
\v 7 \nd \w Yavé|strong="H3068"\w*\nd* es \w bueno|strong="H2896"\w*, \w fortaleza|strong="H4581"\w* en el \w día|strong="H3117"\w* de la \w angustia|strong="H6869"\w*. \w Conoce|strong="H3045"\w* \w a|strong="H3068"\w* los \w que|strong="H3045"\w* confían en Él.
\v 8 Pero con \w impetuosa|strong="H5674"\w* inundación pondrá completo fin \w a|strong="H3068"\w* sus enemigos y \w los|strong="H7291"\w* \w perseguirá|strong="H7291"\w* hasta la \w oscuridad|strong="H2822"\w*.
\v 9 ¿\w Qué|strong="H4100"\w* traman ustedes contra \nd \w Yavé|strong="H3068"\w*\nd*? \w Él|strong="H1931"\w* \w hará|strong="H6213"\w* exterminio. Ciertamente \w no|strong="H3808"\w* \w se|strong="H1931"\w* \w levantará|strong="H6965"\w* \w dos|strong="H6471"\w* \w veces|strong="H6471"\w* \w la|strong="H1931"\w* opresión.
\v 10 \w Aunque|strong="H3588"\w* estén entretejidos \w como|strong="H3588"\w* espinos \w y|strong="H3588"\w* empapados \w en|strong="H5704"\w* \w su|strong="H3588"\w* embriaguez, serán consumidos \w como|strong="H3588"\w* hojarasca.
\v 11 Un \w consejero|strong="H3289"\w* \w perverso|strong="H1100"\w* \w salió|strong="H3318"\w* \w de|strong="H4480"\w* \w ti|strong="H4480"\w* quien maquinó \w mal|strong="H7451"\w* \w contra|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\p 
\v 12 \nd \w Yavé|strong="H3068"\w*\nd* dice: \wj \w Aunque|strong="H3808"\w* tengan \w mucha|strong="H7227"\w* fuerza \w y|strong="H3541"\w* sean \w muchos|strong="H7227"\w*, serán cortados \w y|strong="H3541"\w* \w pasarán|strong="H5674"\w*. \w Aunque|strong="H3808"\w* te \w afligí|strong="H6031"\w*, ya \w no|strong="H3808"\w* te afligiré,\wj*
\v 13 \wj \w porque|strong="H5921"\w* \w ahora|strong="H6258"\w* \w quebraré|strong="H7665"\w* su \w yugo|strong="H5921"\w* \w de|strong="H5921"\w* \w sobre|strong="H5921"\w* \w ti|strong="H5921"\w* \w y|strong="H5921"\w* romperé tus correas.\wj*
\p 
\v 14 \w Pero|strong="H3588"\w* \w con|strong="H5921"\w* respecto \w a|strong="H3068"\w* \w ti|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w ordenó|strong="H6680"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* quede memoria \w de|strong="H5921"\w* tu \w nombre|strong="H8034"\w*. \wj \w Destruiré|strong="H3772"\w* esculturas \w e|strong="H3068"\w* \w imágenes|strong="H4541"\w* fundidas \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* tus \tl ʼelohim\tl*, \w y|strong="H3588"\w* \w la|strong="H5921"\w* convertiré \w en|strong="H5921"\w* tu \w sepultura|strong="H6913"\w*, \w porque|strong="H3588"\w* eres vil. \wj*
\s1 Buenas noticias
\p 
\v 15 ¡Miren sobre las montañas los pies del que trae buenas noticias, del que anuncia la paz! ¡Celebra tus solemnidades, oh Judá, y cumple tus votos porque nunca más pasará por ti el perverso! Fue destruido por completo.
\c 2
\s1 Restauración
\p 
\v 1 ¡\w El|strong="H5921"\w* destructor subió \w contra|strong="H5921"\w* \w ti|strong="H5921"\w*! Guarda \w la|strong="H5921"\w* fortaleza, vigila \w el|strong="H5921"\w* camino, fortalece tu retaguardia, reúne \w toda|strong="H3605"\w* tu fuerza.
\p 
\v 2 \w Porque|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* restaurará \w el|strong="H5921"\w* resplandor \w de|strong="H5921"\w* Jacob, \w y|strong="H5921"\w* \w el|strong="H5921"\w* resplandor \w de|strong="H5921"\w* Israel, aunque devastadores \w la|strong="H5921"\w* devastaron \w y|strong="H5921"\w* destruyeron \w las|strong="H5921"\w* ramas \w de|strong="H5921"\w* su vid.
\p 
\v 3 \w Los|strong="H3588"\w* escudos \w de|strong="H3588"\w* sus valientes están enrojecidos, sus guerreros están vestidos \w de|strong="H3588"\w* púrpura \w y|strong="H3588"\w* sus carruajes \w son|strong="H3588"\w* acero fulgurante. \w El|strong="H3588"\w* día \w de|strong="H3588"\w* \w su|strong="H3588"\w* formación hacen temblar \w los|strong="H3588"\w* cipreses.
\v 4 Carruajes corren alocadamente en las calles, se lanzan \w a|strong="H3068"\w* las plazas como antorchas encendidas, como relámpagos.
\v 5 Se da aviso \w a|strong="H3068"\w* sus valientes, y ellos se dirigen atropellados hacia su muro y se prepara la defensa.
\v 6 Se abren las compuertas de los ríos, y el palacio se derrumba.
\v 7 Está decretado: Ella será despojada y removida. Sus esclavas hacen arrullos como palomas y se golpean los pechos.
\v 8 Aunque Nínive \w fue|strong="H1540"\w* \w como|strong="H5921"\w* un estanque \w de|strong="H5921"\w* aguas \w a|strong="H3068"\w* través \w de|strong="H5921"\w* sus días, ahora \w están|strong="H3824"\w* huyendo. Gritan: ¡Deténganse! ¡Deténganse! Pero nadie vuelve atrás.
\v 9 ¡Saquen \w la|strong="H1931"\w* plata y \w el|strong="H1931"\w* oro! Hay riquezas sin fin, toda clase \w de|strong="H4325"\w* objetos deseables.
\p 
\v 10 ¡Está vacía, sí, está desolada \w y|strong="H3519"\w* devastada! Desfallecen \w los|strong="H3605"\w* corazones \w y|strong="H3519"\w* se golpean las rodillas. \w La|strong="H3605"\w* angustia está en \w todo|strong="H3605"\w* \w el|strong="H3605"\w* cuerpo \w y|strong="H3519"\w* \w todos|strong="H3605"\w* sus rostros palidecen.
\v 11 ¿Dónde está \w la|strong="H3605"\w* guarida \w de|strong="H6440"\w* \w los|strong="H3605"\w* leones y \w el|strong="H3605"\w* sitio donde se recogían \w el|strong="H3605"\w* león, \w la|strong="H3605"\w* leona y \w los|strong="H3605"\w* leoncillos, y \w no|strong="H6440"\w* había \w quién|strong="H3605"\w* \w los|strong="H3605"\w* espantara?
\v 12 \w El|strong="H1931"\w* león \w hacía|strong="H8033"\w* presas suficientes para \w sus|strong="H1931"\w* cachorros y descuartizaba para \w sus|strong="H1931"\w* leonas. \w Su|strong="H1931"\w* cueva \w se|strong="H1931"\w* llenaba de víctimas, \w su|strong="H1931"\w* guarida de rapiña.
\p 
\v 13 \wj ¡Ciertamente Yo estoy contra ti! Palabra de \nd \w Yavé|strong="H3068"\w*\nd* de las huestes. Encenderé y reduciré \w a|strong="H3068"\w* humo tus carruajes, y la espada devorará \w a|strong="H3068"\w* tus leoncillos. Raeré de la tierra tus presas. Nunca más se escuchará la voz de tus mensajeros.\wj*
\c 3
\s1 Absoluta derrota de Nínive
\p 
\v 1 ¡\w Ay|strong="H1945"\w* \w de|strong="H1818"\w* \w la|strong="H3605"\w* \w ciudad|strong="H5892"\w* sanguinaria completamente llena \w de|strong="H1818"\w* mentiras y pillaje! Su presa \w no|strong="H3808"\w* \w se|strong="H3808"\w* \w va|strong="H3068"\w* \w nunca|strong="H3808"\w*.
\v 2 Chasquido de látigo, \w ruido|strong="H6963"\w* estruendoso de ruedas, galope de \w caballos|strong="H5483"\w* y traqueo de carruajes.
\v 3 Los \w jinetes|strong="H6571"\w* atacan, \w espadas|strong="H2719"\w* relumbran, lanzas relampaguean, \w multitud|strong="H7230"\w* de \w muertos|strong="H2491"\w*, una masa de cadáveres. \w Tropiezan|strong="H3782"\w* con los \w muertos|strong="H2491"\w*
\v 4 \w a|strong="H3068"\w* causa de las numerosas \w fornicaciones|strong="H2183"\w* de la prostituta encantadora, la amante de los hechizos que esclaviza \w pueblos|strong="H1471"\w* con \w fornicaciones|strong="H2183"\w* y \w hechicerías|strong="H3785"\w*.
\p 
\v 5 \wj ¡\w Aquí|strong="H2005"\w* estoy \w contra|strong="H5921"\w* \w ti|strong="H5921"\w*! \wj*\w dice|strong="H5002"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w de|strong="H5921"\w* \w las|strong="H5921"\w* huestes. \wj \w Te|strong="H5921"\w* levantaré \w la|strong="H5921"\w* falda \w hasta|strong="H5921"\w* \w la|strong="H5921"\w* \w cara|strong="H6440"\w*, \w y|strong="H5921"\w* \w mostraré|strong="H7200"\w* tu desnudez \w a|strong="H3068"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w* \w y|strong="H5921"\w* tu vergüenza \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w reinos|strong="H4467"\w*.\wj*
\v 6 \wj \w Echaré|strong="H7993"\w* repugnancia \w sobre|strong="H5921"\w* \w ti|strong="H5921"\w* \w y|strong="H5921"\w* \w te|strong="H5921"\w* \w haré|strong="H7760"\w* vil. \w Haré|strong="H7760"\w* un espectáculo \w de|strong="H5921"\w* \w ti|strong="H5921"\w*.\wj*
\v 7 \wj \w Los|strong="H3605"\w* \w que|strong="H4480"\w* \w te|strong="H4480"\w* \w vean|strong="H7200"\w* huirán \w de|strong="H4480"\w* \w ti|strong="H4480"\w* y dirán: ¡\w Nínive|strong="H5210"\w* \w fue|strong="H1961"\w* devastada! ¿\w Quién|strong="H4310"\w* \w se|strong="H1961"\w* compadecerá \w de|strong="H4480"\w* \w ella|strong="H3605"\w*? ¿Dónde \w buscaré|strong="H1245"\w* \w consoladores|strong="H5162"\w* \w para|strong="H4480"\w* \w ti|strong="H4480"\w*? \wj*
\p 
\v 8 ¿Eres tú mejor \w que|strong="H4325"\w* Tebas, la \w que|strong="H4325"\w* \w estaba|strong="H3427"\w* situada junto \w a|strong="H3068"\w* las \w aguas|strong="H4325"\w* del Nilo con \w aguas|strong="H4325"\w* \w alrededor|strong="H5439"\w* \w de|strong="H4325"\w* ella, cuyo \w muro|strong="H2346"\w* era \w el|strong="H2975"\w* \w mar|strong="H3220"\w*?
\v 9 \w Etiopía|strong="H3568"\w* y \w Egipto|strong="H4714"\w* \w eran|strong="H1961"\w* su poderío ilimitado. Fut y Libia \w estaban|strong="H1961"\w* entre sus ayudadores.
\v 10 Pero \w también|strong="H1571"\w* \w ella|strong="H1931"\w* \w fue|strong="H1980"\w* deportada, \w llevada|strong="H1980"\w* \w en|strong="H5921"\w* \w cautiverio|strong="H1473"\w*. \w Sus|strong="H1931"\w* pequeños \w fueron|strong="H1980"\w* estrellados \w en|strong="H5921"\w* \w las|strong="H5921"\w* encrucijadas, \w echaron|strong="H3032"\w* \w suertes|strong="H1486"\w* \w sobre|strong="H5921"\w* \w sus|strong="H1931"\w* nobles \w y|strong="H1571"\w* \w sus|strong="H1931"\w* poderosos \w fueron|strong="H1980"\w* atados \w con|strong="H5921"\w* grillos.
\v 11 \w Así|strong="H1571"\w* \w también|strong="H1571"\w* tú \w serás|strong="H1961"\w* embriagada, \w estarás|strong="H1961"\w* escondida. \w También|strong="H1571"\w* tú \w buscarás|strong="H1245"\w* refugio del enemigo.
\v 12 Tus plazas fortificadas \w son|strong="H6310"\w* \w como|strong="H5973"\w* \w higueras|strong="H8384"\w* cargadas \w de|strong="H5921"\w* \w higos|strong="H8384"\w* maduros, \w que|strong="H5921"\w* \w al|strong="H5921"\w* sacudirlas \w caen|strong="H5307"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w boca|strong="H6310"\w* \w que|strong="H5921"\w* \w los|strong="H5921"\w* come.
\v 13 \w Mira|strong="H2009"\w*, tus tropas en \w medio|strong="H7130"\w* \w de|strong="H5971"\w* ti son como mujeres. Las \w puertas|strong="H8179"\w* \w están|strong="H2009"\w* completamente \w abiertas|strong="H6605"\w* \w para|strong="H5971"\w* tus enemigos. El fuego consume tus \w cerrojos|strong="H1280"\w*.
\p 
\v 14 \w Provéete|strong="H7579"\w* \w de|strong="H4325"\w* \w agua|strong="H4325"\w* para el asedio, refuerza tus defensas, entra en el lodo, \w pisa|strong="H7429"\w* el \w barro|strong="H2563"\w* y mantén firme el molde del ladrillo.
\v 15 \w Allí|strong="H8033"\w* el fuego te devorará como la langosta devora, te derribará la \w espada|strong="H2719"\w*, \w aunque|strong="H8033"\w* te multipliques como el langostón.
\v 16 \w Multiplicaste|strong="H7235"\w* tus mercaderes \w más|strong="H7235"\w* que las \w estrellas|strong="H3556"\w* del \w cielo|strong="H8064"\w*. Los pulgones se despliegan y vuelan.
\v 17 Tus jefes \w son|strong="H3808"\w* como enjambres de langostas \w que|strong="H3808"\w* \w se|strong="H3045"\w* pegan en muros de piedra en \w día|strong="H3117"\w* frío. Al salir el \w sol|strong="H8121"\w* vuelan, y \w nadie|strong="H3808"\w* \w sabe|strong="H3045"\w* de \w dónde|strong="H4725"\w* vienen.
\p 
\v 18 ¡Oh \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Asiria, tus \w pastores|strong="H7462"\w* \w se|strong="H5921"\w* \w durmieron|strong="H5123"\w*! \w Reposaron|strong="H7931"\w* tus valientes, tu tropa \w está|strong="H7931"\w* dispersa \w por|strong="H5921"\w* \w las|strong="H5921"\w* montañas \w y|strong="H5921"\w* \w no|strong="H5921"\w* hay quien \w la|strong="H5921"\w* mueva \w a|strong="H3068"\w* reunión.
\v 19 \w No|strong="H3808"\w* \w hay|strong="H4310"\w* cura \w para|strong="H5921"\w* tu quebranto. Tu \w llaga|strong="H4347"\w* \w es|strong="H3588"\w* incurable. \w Todos|strong="H3605"\w* \w los|strong="H5921"\w* \w que|strong="H3588"\w* \w oigan|strong="H8085"\w* tu fama \w batirán|strong="H8628"\w* \w manos|strong="H3709"\w* \w con|strong="H5921"\w* respecto \w a|strong="H3068"\w* \w ti|strong="H5921"\w*, \w pues|strong="H3588"\w* ¿\w sobre|strong="H5921"\w* \w quién|strong="H4310"\w* \w no|strong="H3808"\w* \w pasó|strong="H5674"\w* \w de|strong="H5921"\w* \w continuo|strong="H8548"\w* tu \w maldad|strong="H7451"\w*? 
