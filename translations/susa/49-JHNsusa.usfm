\id JHN - Revised Susu Gospels 
\h يَيَ 
\toc1 عِنيِلَ عِسَ عَننَبِ يَيَ نَشَن سّبّشِ 
\toc2 يَيَ 
\mt1 عِنيِلَ عِسَ عَننَبِ يَيَ نَشَن سّبّشِ 
\imt1 مَسٍنيِ ندٍ يِ كِتَابُي شَ قٍ رَ 
\ip كِتَابُي نَشَن شِلِ «عِنيِلَ عِسَ،» عَ دْشْ نَانِ نَ عَ رَ. نَمِحْنمّ نَانِ نَن عِنيِلَ عِسَ شَ تَرُشُي سّبّ عَلَ شَشِلِ سّنِيّنشِ سَابُي رَ. عٍ شِلِ نّ مَتِيُ، مَرَكِ، لُكِ، نُن يَيَ. 
\ip عَننَبِ مَتِيُ، عَننَبِ مَرَكِ، نُن عَننَبِ لُكِ، عٍ عِنيِلَ عِسَ نَشَن سّبّ، عٍ مَنِيَ عٍ بٌورٍ رَ. نَ سَشَنيِ قِندِشِ تَرُشُي نَن نَ، نَشَن عِسَ بَرِ كِ، عَ حّرّ كِ، نُن عَ قَشَ كِ مَسٍنمَ وٌن بّ. عِنيِلَ عِسَ عَننَبِ يَيَ نَشَن سّبّ، نَ قَن عِسَ شَ تَرُشُي مَسٍنمَ، كْنْ كَوَندِ نَن فبٌ عَ كُي. عَ عِسَ نَن شَ قٍ تَفِ رَبَمَ، عَلَكٌ مِشِيٍ شَ عَ كٌلٌن عَ عِسَ قِندِشِ عَلَ شَ مِشِ سُفَندِشِ يَتِ يَتِ نَن نَ. 
\ip عَننَبِ يَيَ عَ مَسٍنمَ دُنِحَ بِرِن بّ عَ عَ لَنمَ وٌن شَ لَ عِسَ رَ، وٌن شَ دَنشَنِيَ عَ مَ. نَ قِندِ مَ كِسِ نَن نَ عِبُنَدَ مَ بّ، كِسِ نَشَن مُ كَنَمَ عَبَدَن. عَننَبِ يَيَ مِشِ رَلِمَنِيَمَ يِ كِتَابُي كُي عَلَكٌ عٍ نَشَ سِيكّ عَلَ شَ لَايِدِ شَ قٍ مَ. عِسَ قِندِشِ سّرّشّ شُنفبٍ نَن نَ نَشَن دُنِحَ شُنسَرَ مَ. وٌن شَ نَ كٌلٌن، وٌن شَ لَ عَ رَ. 
\ip عِنيِلَ عِسَ عَننَبِ يَيَ نَشَن سّبّشِ، عَ وَ مَ عِسَ تِدٍ نَن مَسٍنقٍ وٌن بّ. عَ تَلِ وْيّنيِ فبٍفبٍ رَوَلِمَ نَ قَلَقٍ رَ. عَ عَ قَلَمَ عَ عِسَ قِندِشِ «عِبُنَدَ مَ شَ نَءِيَلَنيِ رَ.» عَ عَ مَسٍنمَ عَ عِسَ لُشِ نّ عَلْ «شُرُ سٍيٍ دّ مَدٌنيِ» دَنشَنِيَتْييٍ بّ. عَ عِسَ مِسَالِمَ «نَادّ» نُن «كِرَ» رَ. عِسَ لُشِ عَلْ «يٍ» نُن «بَلٌي» مِشِيٍ بّ. عِسَ مُنَقَنيِ فبٌ عَدَ مَ بّ. 
\ip عَلَ شَ وٌن مَلِ نَ كٌلٌنقٍ رَ عَلَكٌ عِسَ شَ قٍ شَ لُ وٌن بْحّ كُي. عَمِنَ. 
\mt1 عِنيِلَ عِسَ 
\mt1 عَننَبِ يَيَ نَشَن سّبّشِ 
\cl سٌرَ 
\c 1  
\s1 عَلَ شُي قِندِقٍ عِبُنَدَ مَ رَ 
\q1  
\v 1 عَ قْلْ قْلّ، عَلَ شُي نُ نَ، 
\q1 عَلَ شُي نُ نَ عٍ نُن عَلَ، 
\q1 عَلَ شُي نُ قِندِشِ عَلَ يّتّ كَن نَن نَ. 
\q1  
\v 2 كَبِ عَ قْلّ، عَلَ نُن عَ شُي نَن نُ عَ رَ. 
\q1  
\v 3 عَلَ سٍ بِرِن دَاشِ عَ تَن نَن سَابُي رَ، 
\q1 سٍسٍ مُ نَ نَشَن مُ دَاشِ عَ تَن سَابُي رَ. 
\q1  
\v 4 مَرَكِسِ سْتْمَ عَ تَن نَن نَ، 
\q1 كِسِ نَشَن قِندِشِ نَءِيَلَنيِ رَ عَدَ مَدِيٍ بّ. 
\q1  
\v 5 نَ نَءِيَلَنيِ يَنبَمَ دِ مِ كُي، 
\q1 دِ مِ قَن مُ تِن عَ رَ. 
\b  
\q1  
\v 6 عَلَ نَشَ شّمّ ندٍ شّي، نَشَن نُ شِلِ يَيَ. 
\q1  
\v 7 سٍيدٍ نَن نُ عَ رَ، نَشَن قَ سٍيدٍحْشْيَ بَدٍ نَ نَءِيَلَنيِ شَ قٍ رَ، 
\q1 عَلَكٌ بِرِن شَ دَنشَنِيَ عَ سَابُي رَ. 
\q1  
\v 8 عَ تَن شَ مُ قِندِشِ نَ نَءِيَلَنيِ رَ، 
\q1 كْنْ عَ تَن قَ نّ عَ شَ سٍيدٍ بَ نَ نَءِيَلَنيِ شَ قٍ رَ. 
\q1  
\v 9 نَشَن قِندِشِ نَءِيَلَنيِ رَ، نَءِيَلَنيِ يَتِ نَ عَ رَ، 
\q1 نَشَن قَمَ دُنِحَ مَ، عَ شَ عَدَ مَدِيٍ بِرِن عِيَلَن. 
\b  
\q1  
\v 10 عَلَ شُي نَشَ سَبَتِ دُنِحَ مَ. 
\q1 دُنِحَ دَا عَ تَن نَن سَابُي رَ، 
\q1 كْنْ دُنِحَ تٌندِ نّ عَ كٌلٌندٍ. 
\q1  
\v 11 عَ قَ نّ عَ شْنيِ، 
\q1 كْنْ عَ شَ مِشِيٍ مُ عَ رَ سّنّ. 
\q1  
\v 12 كْنْ نَشَن تَن بِرِن عَ رَ سّنّ، عٍ دَنشَنِيَ عَ مَ، 
\q1 عَ نَشَ نْي قِ نٍيٍ تَن مَ، عٍ شَ قِندِ عَلَ شَ دِيٍ رَ. 
\q1  
\v 13 نَ مُ كٍلِ عٍ بْنسْي شَ مَ، 
\q1 شَ نَ مُ قَتٍ بّندّ وَشْنيِ مَ، 
\q1 شَ نَ مُ مِشِ ندٍ وَشْنيِ مَ. 
\q1 عَلَ يّتّ نَن عَ نِيَ عٍ شَ بَرِ عَ نّينّ رَ، عٍ قِندِ عَ شَ دِيٍ رَ. 
\b  
\q1  
\v 14 عَلَ شُي نَشَ قِندِ عِبُنَدَ مَ رَ، 
\q1 عَ سَبَتِ مُشُ يَ مَ. 
\q1 مُشُ بَرَ عَ شَ نْرّ تٌ، 
\q1 عَ بَبَ نْرّ نَشَن قِشِ عَ شَ دِ كٍرٍنيِ مَ، 
\q1 هِننّنتٍيَ نُن نْندِ كَمَلِشِ نَشَن يِ. 
\b  
\q1  
\v 15 يَيَ نَشَ عَ شُي عِتٍ، عَ سٍيدٍحْشْيَ بَ عَ شَ قٍ مَ، 
\q1 «ﭑ يِ نَن مَ قٍ مَسٍن وٌ بّ، ﭑ تٌ عَ قَلَ، 
\q1 ‹نَشَن قَمَ ﭑ شَنبِ رَ، عَ تِدٍ فبٌ ﭑ بّ، 
\q1 بَرِ مَ بٍينُن ﭑ تَن شَ دَا، عَ تَن نُ نَ.›» 
\b  
\q1  
\v 16 وٌن بِرِن بَرَ هِننّ سْتْ عَ سَابُي رَ. 
\q1 عَ شَ هِننّ بَرَ فبٌ يّ وٌن يِ رَ. 
\q1  
\v 17 عَلَ سّرِيّ كِتَابُي قِ وٌن مَ عَننَبِ مُنسَ نَن سَابُي رَ. 
\q1 عَ شَ هِننّ نُن نْندِ تَن قَشِ وٌن مَ 
\q1 عَ شَ مِشِ سُفَندِشِ عِسَ نَن سَابُي رَ. 
\q1  
\v 18 عَدَ مَ يٌ مُ نَ نَشَن بَرَ عَلَ تٌ، 
\q1 كْنْ عَلَ شَ دِ كٍرٍنيِ، نَشَن نَ عَ بَبَ عَلَ قّ مَ، 
\q1 عَ تَن بَرَ عَ مَسٍن. 
\s1 عَننَبِ يَيَ شَ سٍيدٍحْشْيَ 
\r مَتِيُ ٣‏؛١ ٬ ١٢، مَرَكِ ١‏؛١ ٬ ٨، لُكِ ٣‏؛١ ٬ ١٨ 
\p  
\v 19 يَيَ شَ سٍيدٍحْشْيَ نَن يَ. دَرِ سَلَمُ يُوِقِ كُنتِفِيٍ نَشَ سّرّشّدُبّيٍ نُن لٍوِ دِ ندٍيٍ شّي يَيَ شْن مَ، عٍ شَ عَ مَشْرِن، «ندٍ عِ تَن نَ؟»  
\v 20 يَيَ مُ تٌندِ عٍ يَابِدٍ، عَ نَشَ عَ مَسٍن عٍ بّ عَ قِيشّ رَ، «عَلَ شَ مِشِ سُفَندِشِ مُ ﭑ تَن شَ رَ.»  
\v 21 عٍ مَن نَشَ عَ مَشْرِن، «عِ قَ قِندِشِ ندٍ رَ؟ عَننَبِ عٍلِيَ نَن نَ عِ رَ؟» يَيَ نَشَ عٍ يَابِ، «عَدٍ، عٍلِيَ مُ ﭑ نَ.» عٍ نَشَ عَ مَشْرِن، «نَمِحْنمّ نَن عِ رَ مُشُ نَشَن مَمّقٍ عَ شَ قَ؟» يَيَ نَشَ عٍ يَابِ، «عَدٍ.»  
\v 22 نَ كُي، عٍ نَشَ فبِلٍن عَ مَشْرِن نَ، «ندٍ عِ رَ؟ عِ عِ يّتّ مَحْشُنشِ ندٍ رَ؟ عَ يَبَ مُشُ بّ، مُشُ شَ سَ دّنتّفّ سَ مُشُ شّيمَيٍ بّ.» 
\p  
\v 23 يَيَ نَشَ عَ مَسٍن عٍ بّ عَلْ عَ سّبّشِ عَننَبِ عٍسَيِ شَ كِتَابُي كُي كِ نَشّ، «ﭑ تَن قِندِشِ مِشِ نَن نَ نَشَن عَ شُي عِتٍمَ فبٍنفبٍرٍنيِ مَ، ‹وٌ كِرَ مَتِنشِن مَرِفِ بّ!›» 
\p  
\v 24 قَرِ سّنِ ندٍ نَشٍيٍ نُ بَرَ شّي يَيَ شْن،  
\v 25 عٍ نَشَ عَ مَشْرِن، «شَ عِ مُ قِندِشِ عَلَ شَ مِشِ سُفَندِشِ رَ، عِ مُ قِندِشِ عٍلِيَ رَ، عِ مُ قِندِشِ نَمِحْنمّ رَ مُشُ نَشَن مَمّقٍ، عِ قَ مِشِيٍ شُنشَمَ يٍ شْورَ مُنقٍ رَ؟»  
\v 26 يَيَ نَشَ عٍ يَابِ، «ﭑ تَن مِشِيٍ شُنشَمَ يٍ نَن شْورَ، كْنْ مِشِ كٍرٍن نَ وٌ يَ مَ، وٌ مُ نَشَن كٌلٌن.  
\v 27 نَ نَن قَمَ ﭑ شَنبِ رَ. نَ بِنيّ مُ نَ ﭑ تَن يِ رَ، ﭑ حَن شَ عَ شَ سَنكِرِ لُوتِ يَتِ قُلُن.»  
\v 28 نَ قٍ بِرِن دَنفِ بٍتَنِ نّ، يُرُدّن شُرٍ نَاكِرِ مَ، يَيَ نُ مِشِيٍ شُنشَمَ يٍ شْورَ دّننَشّ. 
\s1 عِسَ نَن نَ عَلَ شَ سّرّشّ رَ 
\r مَتِيُ ٣‏؛١٣ ٬ ١٧، مَرَكِ ١‏؛٩ ٬ ١١، لُكِ ٣‏؛٢١ ٬ ٢٢ 
\p  
\v 29 نَ كُيٍ عِبَ، يَيَ نَشَ عِسَ تٌ قَ رَ عَ يِرٍ، عَ نَشَ عَ مَسٍن، «عَلَ شَ سّرّشّ نَن يِ كِ، دُنِحَ شَ يُنُبِ شَقَرِ مَ نَشَن نَ.  
\v 30 ﭑ نُ يِ نَن مَ قٍ مَسٍنقٍ وٌ بّ ﭑ تٌ عَ قَلَ، ﭑ نَشّ، ‹شّمّ نَشَن قَمَ ﭑ شَنبِ رَ، عَ تِدٍ فبٌ ﭑ بّ، بَرِ مَ بٍينُن ﭑ تَن شَ دَا، عَ تَن نُ نَ.›  
\v 31 ﭑ تَن يَتِ مُ نُ نَ كَنيِ كٌلٌن، كْنْ ﭑ قَ مِشِيٍ شُنشَدٍ يٍ شْورَ نّ عَلَكٌ عَ تَن شَ مَكّنّن عِسِرَيِلَكَيٍ بّ.» 
\p  
\v 32 يَيَ نَشَ سٍيدٍحْشْيَ بَ، عَ عَ مَسٍن، «ﭑ بَرَ عَلَ شَشِلِ سّنِيّنشِ تٌ فٌرٌ رَ كٍلِقٍ كٌورٍ مَ عَلْ فَنبّ، عَ دْشْ عَ مَ.  
\v 33 ﭑ تَن يَتِ مُ نُ عَ كٌلٌن، كْنْ عَلَ نَشَن ﭑ شّي مِشِيٍ شُنشَدٍ يٍ شْورَ، عَ نُ بَرَ عَ مَسٍن ﭑ بّ، ‹عِ ﭑ شَشِلِ سّنِيّنشِ تٌمَ فٌرٌ رَ نَشَن مَ، عَ لُ عَ مَ، نَ كَنيِ نَن ﭑ شَشِلِ سّنِيّنشِ رَفٌرٌ مَ مِشِيٍ مَ.›  
\v 34 ﭑ تَن بَرَ عَ تٌ. ﭑ بَرَ قِندِ سٍيدٍ رَ عَ عَلَ شَ دِ نَن عَ رَ.» 
\s1 عِسَ قْشِرَبِرّ سِنفٍيٍ 
\p  
\v 35 نَ كُيٍ عِبَ، يَيَ مَن نُ نَ نَا، عَ نُن عَ قْشِرَبِرّ مِشِ قِرِن.  
\v 36 يَيَ تٌ عِسَ تٌ دَنفِ رَ، عَ نَشَ عَ مَسٍن، «عَلَ شَ سّرّشّ نَن يِ كِ!»  
\v 37 عَ قْشِرَبِرّ قِرِنيِيٍ تٌ عَ شُي مّ، عٍ نَشَ بِرَ عِسَ قْشْ رَ.  
\v 38 عِسَ تٌ عَ كٌبٍ رَتٌ، عَ نَشَ عٍ تٌ عَ قْشْ رَ، عَ نَشَ عٍ مَشْرِن، «وٌ مُنسٍ قٍنقٍ؟» عٍ قَن نَشَ عَ يَابِ، «رَبُنِ، عِ يِفِيَشِ مِندٍن؟» عٍ تٌ عَ شِلِ «رَبُنِ»، نَ نَن قَلَشِ عٍ شَ شُي «كَرَ مْشْ».  
\v 39 عَ نَشَ عَ قَلَ عٍ بّ، «وٌن شّي، وٌ شَ سَ نَ كٌلٌن.» نُنمَرٍ تّمُي نَن نُ عَ رَ. عٍ نَشَ سِفَ نَ يِرٍ كٌلٌندٍ، عٍ قَ لُ عِسَ قّ مَ. 
\p  
\v 40 سِمْن ثِيّرِ شُنيَ عَندِرٍ نُ نَ نَ مِشِ قِرِنيِيٍ يَ مَ، نَشٍيٍ يَيَ شَ مَسٍنيِ مّ، عٍ قَ بِرَ عِسَ قْشْ رَ.  
\v 41 عَ نَشَ سِفَ عَ تَارَ يِرٍ كٍرٍن نَ، عَ عَ قَلَ عَ بّ، «مُشُ بَرَ عَل مَسِيهُ تٌ!» نَ نَن قَلَشِ عٍ شَ شُي، «عَلَ شَ مِشِ سُفَندِشِ».  
\v 42 عَندِرٍ نَشَ ثِيّرِ شَنِن عِسَ يِرٍ. عِسَ تٌ عَ تٌ، عَ نَشَ عَ قَلَ عَ بّ، «يُنُسَ شَ دِ سِمْن نَن عِ رَ، كْنْ عِ شِلِ قَمَ قَلَدٍ كٍقَسِ، نَ نَن نَ كِ ‹ثِيّرِ،› نَشَن وَ مَ عَ قَلَقٍ ‹قَنيٍ›.» 
\p  
\v 43 نَ كُيٍ عِبَ، عِسَ نَشَ نَتّ تٌنفٌ عَ شَ سِفَ فَلِلٍ. عَ تٌ قِلِثُ تٌ، عَ نَشَ عَ قَلَ عَ بّ، «بِرَ ﭑ قْشْ رَ.»  
\v 44 قِلِثُ، عَندِرٍ، نُن ثِيّرِ بِرِن قِندِ بٍتٍسَيِدَكَيٍ نَن نَ.  
\v 45 قِلِثُ نَشَ سِفَ نَتَنَيّلِ يِرٍ، عَ عَ قَلَ عَ بّ، «مِشِ نَشَن مَ قٍ قَلَشِ مُنسَ نُن نَمِحْنمّيٍ شَ كِتَابُييٍ كُي، مُشُ بَرَ عَ تٌ. عِسَ نَسَرّتِكَ نَن عَ رَ، يُسُقُ شَ دِ!»  
\v 46 نَتَنَيّلِ نَشَ عَ مَشْرِن، «قٍ قَنيِ ندٍ نْمَ مِنِدٍ نَسَرّتِ؟» قِلِثُ نَشَ عَ يَابِ، «قَ، عِ يّتّ يَتِ شَ عَ تٌ.»  
\v 47 عِسَ تٌ نَتَنَيّلِ تٌ قَ رَ، عَ نَشَ عَ قَلَ عَ شَ قٍ رَ، «عِسِرَيِلَكَ يَتِ نَن يِ كِ، مَءِقُيَ يٌ مُ نَ نَشَن بْحّ مَ!»  
\v 48 نَتَنَيّلِ نَشَ عَ مَشْرِن، «عِ ﭑ كٌلٌنشِ دِ؟» عِسَ نَشَ عَ يَابِ، «بٍينُن قِلِثُ شَ عِ شِلِ، عِ تٌ نُ شْرّ بِلِ بُن مَ، ﭑ تَن عِ تٌ نّ.»  
\v 49 نَتَنَيّلِ نَشَ عَ قَلَ عَ بّ، «كَرَ مْشْ، عِ تَن قِندِشِ عَلَ شَ دِ يَتِ نَن نَ! عِسِرَيِلَ مَنفّ نَن عِ رَ!»  
\v 50 عِسَ نَشَ عَ قَلَ عَ بّ، «ﭑ تٌ عَ قَلَشِ، عَ ﭑ عِ تٌ نّ شْرّ بِلِ بُن مَ، عِ لَشِ ﭑ نَ نَ قٍ نَن مَ؟ عِ قٍ فبّتّيٍ تٌمَ نّ نَشٍيٍ دَنفِ نَ رَ.»  
\v 51 عَ مَن نَشَ عَ مَسٍن عَ بّ، «ﭑ شَ عَ قَلَ وٌ بّ عَ نْندِ كِ مَ، وٌ قَمَ نّ كٌورٍ تٌدٍ، عَ رَبِشِ، عَلَ شَ مَلٍكّيٍ نُ تٍ عٍ نُ فٌرٌ عَدَ مَ شَ دِ مَ.» 
\c 2  
\s1 قُتِشِرِ شُلُنيِ 
\p  
\v 1 نَ شِ سَشَن ندٍ مَ، قُتِشِرِ شُلُنيِ ندٍ نَشَ رَبَ كَانَ، نَشَن نَ فَلِلٍ بْشِ مَ. عِسَ نفَ نُ نَ نَ شُلُن مِشِيٍ يَ مَ.  
\v 2 عِسَ قَن نُ شِلِشِ نَا، عَ نُن عَ قْشِرَبِرّيٍ.  
\v 3 وّنِ تٌ حْن، عِسَ نفَ نَشَ عَ قَلَ عَ بّ، «وّنِ بَرَ حْن يِ مِشِيٍ يِ رَ.»  
\v 4 عِسَ نَشَ عَ مَشْرِن، «ﭑ نفَ، عِ وَ مَ مُنسٍ شْن مَ ﭑ نَ؟ ﭑ مَ وَشَتِ مُ نُ عَ لِ سِندٍن.»  
\v 5 عَ نفَ نَشَ عَ قَلَ بَنشِ كٌنيِيٍ بّ، «عَ نَ نَشَن يٌ قَلَ وٌ بّ، وٌ عَ رَبَ.» 
\p  
\v 6 قّحّ سٍننِ فّمّ دَاشِ نُ نَ مّننِ، نَشٍيٍ رَقٍمَ يٍ رَ يُوِقِيٍ عٍ يّتّ رَ سّنِيّنمَ نَشَن نَ. لِتِرِ تٌنفٌ سٌلٌمَسَشَن هَن لِتِرِ كّمّ مْشْحّن نُ نْمَ سَدٍ قّحّ كٍرٍن كُي.  
\v 7 عِسَ نَشَ عَ قَلَ كٌنيِيٍ بّ، «وٌ يِ قّحّيٍ رَقٍ يٍ رَ.» عٍ نَشَ عٍ بِرِن نَقٍ تَثُ.  
\v 8 عَ مَن نَشَ عَ قَلَ عٍ بّ، «يَكْسِ، وٌ عَ ندٍ بَ، وٌ عَ شَنِن شُلُن شُنيِ شْن مَ.» عٍ نَشَ نَ قَن نَبَ.  
\v 9 شُلُن شُنيِ تٌ نَ يٍ مِن عِسَ نُ بَرَ نَشَن مَقِندِ وّنِ رَ، عَ مُ نُ عَ كٍلِدٍ كٌلٌن، كْنْ كٌنيِ نَشٍيٍ يٍ بَشِ، نٍيٍ تَن عَ كٌلٌن. عَ تٌ عَ مِن، عَ نَشَ فِنّقٍنيِ شِلِ،  
\v 10 عَ عَ قَلَ عَ بّ، «شُلُن كَنيِ بِرِن وّنِ قَنيِ نَن سِنفٍ رَ مِنِمَ، مِشِيٍ نَ سِيسِ، عٍ قَ وّنِ فبّتّ رَ مِنِ. كْنْ عِ تَن بَرَ وّنِ قَنيِ رَفَتَ هَن يِ تّمُي!» 
\p  
\v 11 نَ نَشَ قِندِ عِسَ شَ تْنشُمَ سِنفٍ رَ. عَ عَ رَبَ كَانَ نّ، فَلِلٍ بْشِ مَ. نَ قٍ كُي، عَ عَ شَ نْرّ نَن مَكّنّن، عَ قْشِرَبِرّيٍ نَشَ لَ عَ رَ. 
\p  
\v 12 نَ شَنبِ، عَ نَشَ سَ فٌرٌ كَثّرّنَمُ، عَ نُن عَ نفَ، عَ شُنيَيٍ، نُن عَ قْشِرَبِرّيٍ. عٍ نَشَ سَ شِ ندٍيٍ رَدَنفِ نَا. 
\s1 عِسَ يُلّيٍ كٍرِقٍ هْرْ مْبَنشِ كُي 
\r مَتِيُ ٢١‏؛١٢ ٬ ١٣، مَرَكِ ١١‏؛١٥ ٬ ١٧، لُكِ ١٩‏؛٤٥ ٬ ٤٦ 
\p  
\v 13 يُوِقِيٍ شَ سَيَمَلٍكّ دَنفِ سَلِ تٌ مَكْرّ، عِسَ نَشَ تٍ دَرِ سَلَمُ.  
\v 14 عَ نَشَ سَ لِ، نِنفٍ، يّشّي، نُن فَنبّ مَتِيٍ نُ نَ هْرْ مْبَنشِ يِرٍ، كْبِرِ مَسَرّيٍ قَن نُ دْشْشِ نَا.  
\v 15 عِسَ نَشَ لُوتِ ندٍيٍ يَءِلَن لُشُسِنيِ رَ، عَ يُلّيٍ بِرِن كٍرِ هْرْ مْبَنشِ كُي، عَ نُن عٍ شَ نِنفٍيٍ نُن يّشّييٍ. عَ نَشَ كْبِرِ مَسَرّيٍ شَ كْبِرِ رَيٍنسٍن بْشِ، عَ عٍ شَ تٍيبِلِيٍ رَبِرَ.  
\v 16 عَ نَشَ عَ قَلَ فَنبّ مَتِيٍ قَن بّ، «وٌ يٍيٍ تٌنفٌ بٍ! وٌ بَ ﭑ بَبَ شَ بَنشِ قِندِقٍ مَكِتِ رَ!»  
\v 17 عَ قْشِرَبِرّيٍ نَشَ رَتُ نَ كِتَابُي سّبّلِ مَ نَشَن عَ قَلَمَ، «شَنُنتٍيَ بَرَ فبٌ يّ ﭑ بْحّ كُي عِ شَ بَنشِ شَ قٍ رَ.» 
\p  
\v 18 نَ كُي، يُوِقِ كُنتِفِيٍ نَشَ عَ مَشْرِن، «عِ تْنشُمَ مَكَابَشِ مُندُن نَبَمَ نَشَن عَ مَسٍنمَ مُشُ بّ عَ عَ لَن عِ شَ يِ مْولِ رَبَ؟»  
\v 19 عِسَ نَشَ عٍ يَابِ، «وٌ يِ هْرْ مْبَنشِ رَبِرَ. شِ سَشَن بُن مَ ﭑ تَن عَ رَكٍلِمَ.»  
\v 20 يُوِقِ كُنتِفِيٍ نَشَ عَ قَلَ، «يِ هْرْ مْبَنشِ نَشَن تِشِ حّ تٌنفٌ نَانِ نُن سٍننِ بُن مَ، عِ تَن نَ رَكٍلِمَ نّ شِ سَشَن بُن مَ؟»  
\v 21 كْنْ عِسَ تٌ هْرْ مْبَنشِ شَ قٍ قَلَ، تَالِ وْيّنيِ نَن نُ عَ رَ. عَ نُ عَ قَتٍ نَن مَ قٍ قَلَقٍ.  
\v 22 عَ تٌ كٍلِ قَشّ مَ، عَ قْشِرَبِرّيٍ نَشَ رَتُ عَ شَ وْيّنيِ مَ. نَ كُي، عٍ نَشَ لَ كِتَابُي شُي رَ، عٍ نَشَ لَ عِسَ شُي رَ. 
\p  
\v 23 عِسَ تٌ نُ نَ دَرِ سَلَمُ، سَيَمَلٍكّ دَنفِ سَلِ وَشَتِ، مِشِ فبٍفبٍ نَشَ دَنشَنِيَ عَ مَ عٍ تٌ تْنشُمَ مَكَابَشِيٍ تٌ، عَ نُ نَشٍيٍ رَبَمَ.  
\v 24 كْنْ عِسَ مُ نُ لَمَ عٍ رَ، بَرِ مَ عَ نُ عَدَ مَدِ بِرِن كٌلٌن.  
\v 25 عَ هَيِ يٌ مُ نُ عَ مَ، مِشِ يٌ شَ عِبُنَدَ مَ شَ قٍ قَلَ عَ بّ، بَرِ مَ عَ تَن نُ عَدَ مَدِ بْحّ كٌلٌن. 
\c 3  
\s1 عِسَ نُن نِكٌدٍ مُ شَ سُمُنيِ 
\p  
\v 1 يُوِقِ كُنتِفِ ندٍ نُ نَ قَرِ سّنِيٍ يَ مَ، نَشَن شِلِ نِكٌدٍ مُ.  
\v 2 عَ نَشَ سِفَ عِسَ شْن مَ كْي رَ، عَ عَ قَلَ عَ بّ، «كَرَ مْشْ، مُشُ عَ كٌلٌن كَرَ مْشْ نَن عِ رَ عَلَ نَشَن شّيشِ. عِ تْنشُمَ مَكَابَشِ نَشٍيٍ رَبَقٍ، مِشِ يٌ مُ نْمَ عٍ رَبَدٍ شَ عَ كَنيِ نُن عَلَ شَ مُ عَ رَ.» 
\p  
\v 3 عِسَ نَشَ عَ مَسٍن عَ بّ، «ﭑ شَ نْندِ يَتِ قَلَ عِ بّ، شَ مِشِ مُ بَرِ عَ نّينّ رَ، عَ مُ نْمَ سٌدٍ عَلَ شَ مَنفّيَ نِينِ بُن مَ.»  
\v 4 نِكٌدٍ مُ نَشَ عَ مَشْرِن، «مِشِ مْشِ نْمَ فبِلٍندٍ عَ نفَ تّيفّ، عَ مَن فبِلٍن بَرِ رَ؟»  
\v 5 عِسَ نَشَ عَ يَابِ، «عَ نْندِ عِ مَ ﭑ شَ عَ قَلَ عِ بّ، شَ مِشِ مُ بَرِ عَ نّينّ رَ، يٍ نُن عَلَ شَشِلِ سّنِيّنشِ سَابُي رَ، عَ مُ نْمَ سٌدٍ عَلَ شَ مَنفّيَ نِينِ بُن مَ.» 
\p  
\v 6 «قَتٍ بّندّ نَن مِشِ قَتٍ بّندّ بَرِ مَ. كْنْ مِشِ شَشِلِ تَن بَرِ مَ عَلَ شَشِلِ سّنِيّنشِ نَن سَابُي رَ.  
\v 7 ﭑ تٌ عَ قَلَشِ عِ بّ عَ قٌ وٌ شَ بَرِ عَ نّينّ رَ، نَ نَشَ عِ تّرّننَ.  
\v 8 قٌيٍ مِنِمَ عَ نَ وَ مِنِقٍ دّدّ بِرِ رَ. عِ عَ شُي نَن مّمَ، كْنْ عِ مُ عَ كٍلِدٍ كٌلٌن، عِ مُ عَ سِفَدٍ قَن كٌلٌن. مِشِ نَ بَرِ عَ نّينّ رَ عَلَ شَشِلِ سّنِيّنشِ سَابُي رَ، عَ لُمَ نَ كِ نّ.» 
\p  
\v 9 نِكٌدٍ مُ نَشَ عَ مَشْرِن، «نَ رَبَمَ دِ؟»  
\v 10 عِسَ نَشَ عَ يَابِ، «عِ تَن نَشَن قِندِشِ عِسِرَيِلَ كَرَ مْشْ شُنفبٍ رَ، عِ مُ نَ كٌلٌن؟  
\v 11 ﭑ شَ نْندِ يَتِ قَلَ عِ بّ، مُشُ قٍيٍ نَن قَلَمَ مُشُ نَشٍيٍ كٌلٌن. مُشُ مَن قٍيٍ نَن سٍيدٍ بَمَ مُشُ نَشٍيٍ تٌشِ، كْنْ وٌ بَرَ تٌندِ مُشُ شَ سٍيدٍحْشْيَ رَ.  
\v 12 شَ وٌ مُ لَ ﭑ شُي رَ، ﭑ تٌ يِ دُنِحَ قٍيٍ قَلَقٍ وٌ بّ، شَ ﭑ سَ عَرِيَننَ قٍيٍ نَن قَلَ وٌ بّ، وٌ لَمَ عَ رَ دِ؟  
\v 13 مِشِ يٌ مُ نُ تٍ عَرِيَننَ، قٌ عَدَ مَ شَ دِ نَشَن كٍلِشِ عَرِيَننَ.» 
\p  
\v 14 «عَننَبِ مُنسَ تٌ نُ نَ فبٍنفبٍرٍنيِ مَ، عَ نَشَ بْشِمَسٍ مِسَالِ ندٍ يَءِلَن وُرٍ فبٍيلِ رَ، عَ عَ عِتٍ وُرِ كُيٍ مَ. عَدَ مَ شَ دِ قَن لَنمَ عَ شَ عِتٍ وُرِ كْن نَ نَ كِ نّ،  
\v 15 عَلَكٌ نَشَن يٌ دَنشَنِيَ عَ مَ، نَ كَنيِ شَ كِسِ سْتْ نَشَن مُ حْنمَ عَبَدَن.  
\v 16 عَلَ دُنِحَ شَنُ نّ هَن عَ نَشَ عَ شَ دِ كٍرٍنيِ قِ، عَلَكٌ مِشِ يٌ نَشَن نَ دَنشَنِيَ عَ مَ، عَ نَشَ لْي، عَ شَ كِسِ نّ عَبَدَن.  
\v 17 عَلَ مُ عَ شَ دِ شّي دُنِحَ شَ رَتْندٍ، عَ عَ شّي نّ عَ شَ قَ دُنِحَ رَكِسِ.  
\v 18 نَشَن يٌ نَ دَنشَنِيَ عَ مَ، كِيتِ مُ كَنَمَ نَ كَنيِ رَ، كْنْ نَشَن يٌ مُ دَنشَنِيَ عَ مَ، كِيتِ حَن بَرَ فّ كَنَدٍ نَ كَنيِ رَ، بَرِ مَ عَ مُ دَنشَنِيَشِ عَلَ شَ دِ كٍرٍنيِ مَ.  
\v 19 كِيتِ نَن يَ؛ عَلَ شَ نَءِيَلَنيِ بَرَ قَ دُنِحَ، كْنْ دِ مِ رَقَن عَدَ مَدِيٍ مَ دَنفِ نَ نَءِيَلَنيِ رَ، بَرِ مَ عٍ كّوَلِ مُ قَن.  
\v 20 نَءِيَلَنيِ مُ رَقَن قٍ كٌبِ رَبَ يٌ مَ. عٍ مُ مِنِمَ نَءِيَلَنيِ مَ، عٍ شَ وَلِ كٌبِيٍ نَشَ قَ سَ كّنّ مَ.  
\v 21 كْنْ نَشَن يٌ حّرّ مَ عَلَ شَ نْندِ مَ، عَ تَن مِنِمَ نَءِيَلَنيِ مَ، عَلَكٌ عَلَ وَشْنقٍ عٍ نَشَن نَبَقٍ، نَ شَ سَ كّنّ مَ.» 
\s1 عَننَبِ يَيَ سٍيدٍ بَقٍ عِسَ شَ قٍ رَ 
\p  
\v 22 نَ شَنبِ، عِسَ نُن عَ قْشِرَبِرّيٍ نَشَ كٍلِ دَرِ سَلَمُ عٍ سٌ يُدَيَ بْشِ مَ. عِسَ نَشَ وَشَتِ ندٍ رَبَ مّننِ عَ نُن عَ قْشِرَبِرّيٍ، عٍ نُ مِشِيٍ شُنشَمَ يٍ شْورَ.  
\v 23 يَيَ قَن نُ مِشِيٍ شُنشَمَ يٍ شْورَ عٍنٌن نّ، سَلِمٌن قّ مَ، بَرِ مَ يٍ فبٍفبٍ نُ نَ نَا. مِشِيٍ نُ سِفَمَ عَ شْن، عَ تَن نُ عٍ شُنشَ يٍ شْورَ.  
\v 24 عَ عَ لِشِ نَ تّمُي، عَ مُ نُ سَشِ فٍيلِ سِندٍن. 
\p  
\v 25 لْشْ ندٍ، وْيّنيِ نَشَ مِنِ يَيَ قْشِرَبِرّيٍ نُن يُوِقِ ندٍ تَفِ مَرَ سّنِيّنيِ شَ قٍ رَ.  
\v 26 عٍ نَشَ سِفَ يَيَ يِرٍ، عٍ عَ قَلَ عَ بّ، «كَرَ مْشْ، وٌ نُن شّمّ نَشَن نُ عَ رَ يُرُدّن نَاكِرِ مَ، عِ بَرَ نَشَن مَ قٍ سٍيدٍ بَ، عَ نَ مِشِيٍ شُنشَقٍ يٍ شْورَ. بِرِن نَ سِفَقٍ عَ يِرٍ.»  
\v 27 يَيَ نَشَ عٍ يَابِ، «مِشِ مُ قٍقٍ سْتْمَ، قٌ عَلَ نَ نَشَن قِ عَ مَ.  
\v 28 وٌ تَن يَتِ بَرَ قِندِ ﭑ مَ سٍيدٍيٍ رَ، عَ ﭑ عَ مَسٍن نّ، ‹ﭑ تَن شَ مُ قِندِشِ عَلَ شَ مِشِ سُفَندِشِ رَ. ﭑ شّيشِ عَ يَ رَ نّ.›  
\v 29 شّمّ نَشَن فِنّ قٍنشِ، عَ تَن نَن قِندِ مَ فِنّ كَنيِ رَ. عَ دّقَنبٌورٍ تَن لُمَ عَ قّ مَ نّ، عَ عَ تُلِ مَتِ عَ رَ حّلّشِنيِ كُي. ﭑ تَن لُمَ نَ كِ نّ عِسَ بّ. ﭑ مَ سّيوّ بَرَ كَمَلِ.  
\v 30 قٌ عِسَ شَ قٍ شَ عِتٍ نّ، ﭑ فبٍ شَ عِفٌرٌ.» 
\p  
\v 31 «نَشَن كٍلِشِ كٌورٍ، عَ تَن دَنفِ بِرِن نَ. نَشَن كٍلِشِ دُنِحَ مَ، دُنِحَ مِشِ نَن عَ رَ نَشَن وْيّنمَ عَ دُنِحَ كِ مَ، كْنْ نَشَن تَن كٍلِشِ عَرِيَننَ، عَ تَن دَنفِ بِرِن نَ.  
\v 32 عَ تَن قٍ نَن سٍيدٍ بَمَ، عَ بَرَ نَشَن تٌ، عَ مَن بَرَ نَشَن مّ، كْنْ مِشِ يٌ مُ لَمَ عَ شَ سٍيدٍحْشْيَ رَ.  
\v 33 مِشِ نَشَن لَمَ نَ سٍيدٍحْشْيَ رَ، عَ بَرَ عَ كٌلٌن عَ عَلَ نْندِ نَن قَلَمَ.  
\v 34 عَلَ شَ شّيرَ عَلَ شَ مَسٍنيِ نَن تِمَ، بَرِ مَ عَ كَمَلِشِ عَلَ شَشِلِ سّنِيّنشِ رَ.  
\v 35 بَبَ عَلَ عَ شَ دِ شَنُشِ نّ، عَ قٍ بِرِن سَ عَ بّلّشّ.  
\v 36 نَشَن نَ دَنشَنِيَ عَلَ شَ دِ مَ، عَ بَرَ عَبَدَن كِسِ سْتْ. كْنْ نَشَن نَ عَلَ شَ دِ شُي مَتَندِ، نَ كَنيِ تَن مُ كِسِمَ. عَلَ شَ شْنّ نَن بِرَ مَ عَ قْشْ رَ.» 
\c 4  
\s1 سَمَرِ فِنّ ندٍ نُن سَمَرِكَيٍ دَنشَنِيَقٍ عِسَ مَ 
\p  
\v 1 عِسَ نَشَ عَ كٌلٌن عَ قَرِ سّنِيٍ بَرَ عَ مّ، عَ قْشِرَبِرّيٍ نَ وُيَقٍ، عَ مَن نَ مِشِيٍ شُنشَقٍ يٍ شْورَ دَنفِ يَيَ رَ.  
\v 2 كْنْ عَ قَ لِ عِسَ يّتّ شَ مُ نُ مِشِيٍ شُنشَمَ يٍ شْورَ، عَ قْشِرَبِرّيٍ نَن نُ عَ رَبَمَ.  
\v 3 عِسَ تٌ رَكٌلٌن نَ قٍ مَ، عَ نَشَ كٍلِ يُدَيَ، عَ فبِلٍن فَلِلٍ بْشِ مَ. 
\p  
\v 4 نَ بِيَاسِ كُي، عَ نُ لَن عَ شَ سَمَرِ بْشِ عِفِرِ سِفَقٍ رَ فَلِلٍ.  
\v 5 عَ نَشَ سَمَرِ تَا ندٍ لِ نَشَن شِلِ سُكَرُ، دّننَشّ مَكْرّ شّ رَ، يُوِقِيٍ بٍنبَ يَشُبَ نَشَن قِ عَ شَ دِ يُسُقُ مَ.  
\v 6 يَشُبَ شَ كْلْنيِ نَ مّننِ نّ. عِسَ تٌ نُ بَرَ تَفَن عَ شَ بِيَاسِ كُي، عَ نَشَ عَ مَفٌرٌ نَ كْلْن دّ رَ. يَنيِ تَفِ نَن نُ عَ رَ. 
\p  
\v 7 سَمَرِ فِنّ ندٍ تٌ قَ يٍ بَدٍ، عِسَ نَشَ عَ قَلَ عَ بّ، «ﭑ كِ يٍ، ﭑ شَ عَ مِن.»  
\v 8 عَ عَ لِشِ عِسَ قْشِرَبِرّيٍ نُ بَرَ سِفَ دٌنسٍ سَرَدٍ تَا كُي.  
\v 9 فِنّ نَشَ عَ قَلَ عِسَ بّ، «عِ تَن يُوِقِ، ﭑ تَن سَمَرِ فِنّ. عِ ﭑ مَشْرِنمَ يٍ مِن دَاشِ مَ مُنقٍ رَ؟» فِنّ نَ قَلَ نّ بَرِ مَ يُوِقِيٍ نُن سَمَرِكَيٍ مُ سٍسٍ مَسَرَ مَ عٍ بٌرٍ تَفِ.  
\v 10 عِسَ نَشَ عَ قَلَ، «شَ عِ سَ عَ كٌلٌن نُ، عَلَ وَ مَ عِ كِقٍ نَشَن نَ، عِ تَن نَن عَ مَكُلَمَ كِسِ يٍ رَ نُ، عَ قَ نَ قِ عِ مَ. شَ عِ سَ عَ كٌلٌن نُ مِشِ نَشَن عَ قَلَقٍ عِ بّ يِ كِ، ‹ﭑ كِ يٍ رَ،› عِ تَن قَن عَ مَكُلَمَ نّ يٍ رَ نُ نَشَن عِ رَكِسِمَ.»  
\v 11 فِنّ نَشَ عَ مَشْرِن، «ﭑ بَ، يٍ بَسٍ يٌ مُ عِ يِ رَ، يِ كْلْنيِ قَن تِلِن. عِ قَ نَ كِسِ يٍ سْتْمَ مِندٍن؟  
\v 12 كَ عِ تَن دَنفِ مُشُ بٍنبَ يَشُبَ رَ؟ عَ تَن نَن يِ كْلْنيِ قِ مُشُ مَ. عَ تَن يّتّ بَرَ عَ يٍ مِن، عَ نُن عَ شَ دِيٍ، عَ نُن عَ شَ فْورّ.»  
\v 13 عِسَ نَشَ عَ يَابِ، «نَشَن يٌ يِ كْلْن يٍ مِن، يٍ شْلِ مَن فبِلٍنمَ عَ سُشُ رَ.  
\v 14 كْنْ نَشَن يٍ مِنمَ ﭑ نَشَن قِمَ عَ مَ، يٍ شْلِ مُ عَ سُشُمَ سْنْن. نَ يٍ قِندِ مَ دُلٌنيِ نَن نَ عَ بْحّ مَ، عَ فبٌ عَ عِ، عَ قِندِ عَبَدَن كِسِ رَ.»  
\v 15 فِنّ نَشَ عَ قَلَ عَ بّ، «ﭑ بَ، نَ يٍ قِ ﭑ مَ، عَلَكٌ يٍ شْلِ نَشَ ﭑ سُشُ، ﭑ نَشَ قَ يٍ بَدٍ سْنْن.» 
\p  
\v 16 عِسَ نَشَ عَ قَلَ عَ بّ، «سِفَ عِ سَ عِ شَ مْرِ شِلِ، وٌ قَ بٍ.»  
\v 17 فِنّ نَشَ عَ يَابِ، «ﭑ مُ دْشْشِ شّمّ شْن.» عِسَ نَشَ عَ قَلَ، «عِ نْندِ نَن قَلَشِ، عَ عِ مُ دْشْشِ شّمّ شْن.  
\v 18 عِ بَرَ دْشْ شّمّ سُولِ بِرِن شْن مَ، عِ مَن نُن شّمّ نَشَن عَ رَ يِ تّمُي، قُتِ مُ وٌ تَفِ. نَ تَن، عِ نْندِ نَن قَلَشِ.» 
\p  
\v 19 فِنّ نَشَ عَ قَلَ عِسَ بّ، «عَوَ، ﭑ بَرَ عَ كٌلٌن قَ، عَ نَمِحْنمّ نَن نَ عِ رَ.  
\v 20 مُشُ بٍنبَيٍ عَلَ بَتُ يِ فٍيَ نَن قَرِ، كْنْ وٌ تَن يُوِقِيٍ عَ قَلَمَ عَ قٌ عَلَ شَ بَتُ دَرِ سَلَمُ نّ.»  
\v 21 عِسَ نَشَ عَ قَلَ عَ بّ، «ﭑ مَ دِ، عِ شَ لَ ﭑ نَ، وَشَتِ نَ قَقٍ بَبَ عَلَ مُ بَتُمَ يِ فٍيَ مَ، عَ مُ بَتُمَ دَرِ سَلَمُ قَن.  
\v 22 وٌ تَن سَمَرِكَيٍ، وٌ سَلِمَ، كْنْ وٌ مُ عَلَ كٌلٌن. مُشُ تَن يُوِقِيٍ، مُشُ سَلِمَ، مُشُ مَن عَلَ كٌلٌن، بَرِ مَ عَلَ شَ كِسِ قَتَنمَ يُوِقِيٍ نَن نَ.  
\v 23 كْنْ وَشَتِ نَ قَقٍ، عَ حَن بَرَ عَ لِ، بَبَ عَلَ بَتُلَيٍ عَ بَتُمَ عَ نْندِ كِ مَ عٍ شَشِلِ قِيشّ نَن نَ. بَبَ عَلَ وَ مَ نَ بَتُلَ مْولِيٍ نَن شْن مَ.  
\v 24 عَلَ قِندِشِ شَشِلِ نَن نَ. عَ بَتُلَيٍ لَن نّ عٍ شَ عَ بَتُ عٍ شَشِلِ قِيشّ نَن نَ عَ نْندِ كِ مَ.» 
\p  
\v 25 فِنّ نَشَ عَ قَلَ عَ بّ، «ﭑ عَ كٌلٌن عَ عَل مَسِيهُ قَقٍ، عَلَ شَ مِشِ سُفَندِشِ. عَ تَن نَ قَ، عَ قٍ بِرِن تَفِ رَبَمَ نّ وٌن بّ.»  
\v 26 عِسَ نَشَ عَ قَلَ عَ بّ، «ﭑ تَن نَن نَ رَ، ﭑ تَن عَلَ شَ مِشِ سُفَندِشِ نَن وْيّنقٍ عِ بّ يِ كِ.» 
\p  
\v 27 عِسَ قْشِرَبِرّيٍ تٌ عِسَ لِ، عَ نَ وْيّنقٍ نَ فِنّ رَ، عٍ دّ نَشَ عِشَرَ، كْنْ عٍ مُ عَ مَشْرِن، «عِ وَ مَ مُنسٍ شْن» شَ نَ مُ عَ رَ «وٌ نَ مُنسٍ قَلَقٍ؟» 
\p  
\v 28 فِنّ نَشَ عَ شَ قّحّ لُ نَا، عَ سِفَ تَا كُي، عَ سَ عَ قَلَ مِشِيٍ بّ،  
\v 29 «وٌ قَ. وٌ شَ شّمّ ندٍ مَتٌ نَشَن بَرَ ﭑ مَ كّوَلِ بِرِن قَلَ ﭑ بّ، عَ مُ ﭑ كٌلٌن. عَلَ شَ مِشِ سُفَندِشِ نَ عَ رَ بَ، كَ؟»  
\v 30 نَ كُي، تَاكَيٍ نَشَ مِنِ سِفَقٍ رَ عِسَ يِرٍ. 
\p  
\v 31 نَ وَشَتِ بُن مَ، عِسَ قْشِرَبِرّيٍ نُ وْيّنقٍ عَ بّ، عٍ عَ قَلَ، «كَرَ مْشْ، عِ دّفٍ.»  
\v 32 كْنْ عِسَ نَشَ عَ مَسٍن عٍ بّ، «بَلٌي نَ ﭑ تَن يِ رَ، وٌ تَن مُ نَشَن كٌلٌن.»  
\v 33 عَ قْشِرَبِرّيٍ نَشَ عٍ بٌرٍ مَشْرِن، «ثٍ، مِشِ ندٍ نَن قَشِ دٌنسٍ رَ عَ شْن مَ بَ؟»  
\v 34 عِسَ نَشَ عَ مَسٍن عٍ بّ، «ﭑ تَن مَ بَلٌي قِندِشِ ﭑ شّيمَ وَشْنقٍ رَبَقٍ نَن نَ، ﭑ شَ عَ شَ وَلِ رَكَمَلِ عَ بَرَ نَشَن سٌ ﭑ يِ.  
\v 35 وٌ تَن مُ عَ قَلَمَ شّ، ‹كِكٍ نَانِ نَن لُشِ بٍينُن شّ شَبّ شَ عَ لِ›؟ ﭑ شَ عَ قَلَ وٌ بّ، وٌ وٌ يَ رَ سِفَ، وٌ شّيٍ مَتٌ، عٍ رَفبٍيلِشِ كِ نَشّ. شّ شَبَ تّمُي بَرَ عَ لِ.  
\v 36 شّ شَبّ حَن بَرَ عَ شَ وَلِ سَرٍ سْتْ قْلْ. عَ شَ وَلِ عَ نِيَمَ نّ مِشِ شَ كِسِ سْتْ عَبَدَن. نَ كُي، نَشَن شّ بِمَ نُن نَشَن شّ شَبَمَ، عٍ بِرِن لُمَ سّيوّ كٍرٍن نّ.  
\v 37 يِ مَسٍنيِ قِندِشِ نْندِ نَن نَ، ‹مِشِ ندٍ شّ فَرَنسَنمَ، فبّتّ عَ شَبَمَ.›  
\v 38 ﭑ تَن وٌ شّيشِ شّ شَبَدٍ نّ، وٌ مُ نَشَن نَوَلِشِ. مِشِ فبّتّيٍ نَن وَلِشِ، كْنْ وٌ تَن نَن عٍ شَ وَلِ رَحْنيِ تٌمَ.» 
\p  
\v 39 سَمَرِكَ نَشٍيٍ نُ سَبَتِشِ نَ تَا كُي، عٍ فبٍفبٍ نَشَ دَنشَنِيَ عِسَ مَ نَ فِنّ شَ سٍيدٍحْشْيَ شَ قٍ رَ، عَ تٌ عَ قَلَ، «ﭑ بَرَ كّوَلِ نَشَن بِرِن نَبَ، عَ بَرَ عَ بِرِن تَفِ رَبَ ﭑ بّ.»  
\v 40 نَ كُي، سَمَرِكَيٍ تٌ قَ عِسَ يِرٍ، عٍ نَشَ عَ مَيَندِ عَ شَ لُ عٍ شْنيِ. عِسَ نَشَ شِ قِرِن نَبَ نَا.  
\v 41 مِشِ فبٍفبٍ مَن نَشَ دَنشَنِيَ عَ شَ مَسٍنيِ سَابُي رَ.  
\v 42 عٍ نَشَ عَ قَلَ نَ فِنّ بّ، «سِنفٍ مُشُ نُ دَنشَنِيَشِ عِ تَن نَن شَ وْيّنيِ شَ قٍ رَ، كْنْ يَكْسِ مُشُ تَن يّتّ بَرَ عَ شُي مّ. مُشُ بَرَ عَ كٌلٌن قَ، عَ يِ قِندِشِ دُنِحَ رَكِسِمَ نَن يَتِ رَ.» 
\s1 عِسَ شّمّ ندٍ شَ دِ رَيَلَنقٍ 
\p  
\v 43 نَ شِ قِرِن دَنفِ شَنبِ، عِسَ نَشَ كٍلِ نَا، عَ سِفَ فَلِلٍ،  
\v 44 بَرِ مَ عَ تَن يَتِ عَ عَ مَسٍن نّ عَ نَمِحْنمّ سٍسٍ يٌ مُ بِنيَمَ عَ شْنيِ.  
\v 45 عَ تٌ سٌ فَلِلٍ، نَاكَيٍ نَشَ عَ رَ سّنّ عَ قَنيِ رَ، بَرِ مَ عٍ قَن نُ بَرَ سَيَمَلٍكّ دَنفِ سَلِ رَبَ دَرِ سَلَمُ، عٍ عَ شَ كَابَنَكٌي تٌ، عَ نَشٍيٍ رَبَ نَا. 
\p  
\v 46 نَ كُي، عِسَ مَن نَشَ سٌ كَانَ، فَلِلٍ بْشِ مَ، عَ يٍ مَقِندِ وّنِ رَ دّننَشّ. مَنفّ شَ وَلِكّ شُنفبٍ ندٍ نُ نَ نَا، نَشَن شَ دِ نُ قُرَشِ كَثّرّنَمُ.  
\v 47 عَ تٌ عَ مّ عَ عِسَ بَرَ قَ فَلِلٍ كٍلِقٍ يُدَيَ، عَ نَشَ سِفَ عَ يِرٍ، عَ عَ مَشَندِ عَ شَ قَ عَ شَ دِ شّمّ رَيَلَن نَشَن نُ سَشِ سَيَ قُرٍ مَ.  
\v 48 عِسَ نَشَ عَ قَلَ عَ بّ، «وٌ تَن مُ دَنشَنِيَمَ قٍوٌ، قٌ وٌ تْنشُمَيٍ نُن كَابَنَكٌي تٌ!»  
\v 49 مَنفّ شَ وَلِكّ نَشَ عَ مَيَندِ، «مَرِفِ، تَلُ ﭑ شْنيِ بٍينُن ﭑ مَ دِ شَ قَشَ!»  
\v 50 عِسَ نَشَ عَ يَابِ، «سِفَ، عِ شَ دِ بَرَ كِسِ.» نَ وَلِكّ نَشَ لَ عِسَ شَ مَسٍنيِ رَ، عَ نَشَ سِفَ.  
\v 51 عَ نُ نَ فبِلٍنقٍ تّمُي نَشّ، عَ شَ كٌنيِيٍ نَشَ عَ رَلَن، عٍ عَ قَلَ عَ بّ، «عِ شَ دِ بَرَ كِسِ!»  
\v 52 عَ قَن نَشَ عٍ مَشْرِن، «عَ قِسَ مُن تّمُي؟» عٍ نَشَ عَ يَابِ، «عَ قَتٍ شِنبٍلِشِ شٌرٌ يَنيِ تَفِ حْندْن.»  
\v 53 نَ دِ بَبَ نَشَ عَ كٌلٌن عَ شَ دِ يَلَن قْلْ كَبِ عِسَ عَ قَلَ عَ بّ تّمُي نَشّ، «عِ شَ دِ بَرَ كِسِ.» نَ نَن عَ رَ، نَ شّمّ نُن عَ شَ دٍنبَيَ بِرِن نَشَ دَنشَنِيَ عِسَ مَ. 
\p  
\v 54 نَ نَشَ قِندِ عِسَ شَ تْنشُمَ مَكَابَشِ قِرِن ندٍ رَ. عَ عَ رَبَ فَلِلٍ نّ، عَ تٌ فبِلٍن كٍلِقٍ يُدَيَ. 
\c 5  
\s1 عِسَ نَمَتّ رَيَلَنقٍ 
\p  
\v 1 نَ دَنفِ شَنبِ، يُوِقِيٍ شَ سَلِ ندٍ تٌ عَ لِ، عِسَ نَشَ تٍ دَرِ سَلَمُ.  
\v 2 يٍ يِرٍ ندٍ نُ نَ دَرِ سَلَمُ، نَشَن شِلِ بٍتٍسٍدَ عٍبُرُ شُي. عَ نُ نَ تَا نَادّ شُنفبٍ نَن قّ مَ، نَشَن شِلِ شُرُ سٍيٍ نَادّ. لٍيلٍ سُولِ نَن نُ نَ نَ يٍ يِرٍ.  
\v 3‏-4 قُرٍ مَ وُيَشِ نُ سَشِ نَ لٍيلٍيٍ بُن مَ، عَلْ دْنشُييٍ، نَمَتّيٍ، نُن نَشٍيٍ سَلٌنيِيٍ بِرِن تُوشِ عَ مَ.  
\v 5 شّمّ ندٍ نُ نَ نَا، نَشَن نُ نَمَتَشِ كَبِ حّ تٌنفٌ سَشَن نُن سٌلٌمَسَشَن.  
\v 6 عِسَ تٌ نُ عَ كٌلٌن عَ يِ شّمّ نُ بَرَ بُ عَ نَمَتَشِ رَ، عَ تٌ عَ سَشِ تٌ، عَ نَشَ عَ مَشْرِن، «عِ وَ مَ عَ شْن عِ شَ يَلَن؟»  
\v 7 نَمَتّ نَشَ عَ يَابِ، «مَرِفِ، يٍ نَ عِمَشَ، مِشِ يٌ مُ نَ نَشَن ﭑ نَفٌرٌ مَ عَ شْورَ. بٍينُن ﭑ تَن شَ يٍ يِرٍ لِ، مِشِ فبّتّ بَرَ فٌرٌ عَ شْورَ.»  
\v 8 عِسَ نَشَ عَ قَلَ عَ بّ، «كٍلِ، عِ عِ شَ دَفِ تٌنفٌ، عِ عِ حّرّ.»  
\v 9 عَ نَشَ يَلَن كٍرٍن نَ. عَ نَشَ عَ شَ دَفِ تٌنفٌ، عَ عَ حّرّ. 
\p نَ لْشْي تٌ نُ قِندِشِ مَلَبُ لْشْي نَن نَ،  
\v 10 يُوِقِ كُنتِفِيٍ نَشَ عَ قَلَ نَ شّمّ رَيَلَنشِ بّ، «مَلَبُ لْشْي نَن تٌ، عَ مُ لَنمَ عِ شَ عِ شَ دَفِ شَنِن عِ شُن.»  
\v 11 كْنْ عَ تَن نَشَ عٍ يَابِ، «شّمّ نَشَن ﭑ نَيَلَنشِ، نَ نَن عَ قَلَ ﭑ بّ، ‹عِ عِ شَ دَفِ تٌنفٌ، عِ عِ حّرّ.›»  
\v 12 عٍ نَشَ عَ مَشْرِن، «ندٍ نَ قَلَشِ عِ بّ؟»  
\v 13 كْنْ شّمّ مُ نُ عَ كٌلٌن نَشَن عَ رَيَلَنشِ، بَرِ مَ عِسَ نُ بَرَ لْي عَ مَ حَمَ يَ مَ.  
\v 14 نَ دَنفِ شَنبِ، عِسَ مَن نَشَ نَ شّمّ لِ هْرْ مْبَنشِ، عَ نَشَ عَ قَلَ عَ بّ، «يَكْسِ عِ بَرَ يَلَن، كْنْ عَ لَنمَ عِ شَ فبِلٍن يُنُبِ قْشْ رَ عَلَكٌ قٍ فبّتّ نَشَ عِ سْتْ نَشَن دَنفِ نَ قُرٍ سِنفٍ رَ.»  
\v 15 شّمّ نَشَ سِفَ عَ سَ عَ قَلَ يُوِقِ كُنتِفِيٍ بّ، عَ عِسَ نَن عَ رَيَلَنشِ. 
\p  
\v 16 عِسَ تٌ نَ قٍ رَبَ مَلَبُ لْشْي نّ، يُوِقِ كُنتِفِيٍ نَشَ سٌ عِسَ فٍرٍقٍ.  
\v 17 عِسَ نَشَ عَ قَلَ عٍ بّ، «هَن تٌ ﭑ بَبَ نَ وَلِقٍ، ﭑ قَن نَ وَلِقٍ.»  
\v 18 نَ تّمُي، يُوِقِيٍ نَشَ قٍ بِرِن نَبَ عَلَكٌ عٍ شَ عَ قَشَ، بَرِ مَ عَ نُ مَلَبُ لْشْي سّرِيّ كَنَمَ، عَ مَن نُ عَ قَلَمَ عَ عَلَ نَن عَ بَبَ رَ. نَ نَ عَ رَ عٍ بِرِن تِدٍ لَنشِ. 
\s1 عَلَ شَ دِ وَلِمَ عَ بَبَ نَن شَ يَامَرِ مَ 
\p  
\v 19 نَ كُي، عِسَ نَشَ عَ مَسٍن عٍ بّ، «ﭑ شَ نْندِ يَتِ قَلَ وٌ بّ، عَلَ شَ دِ مُ نْمَ قٍقٍ رَبَدٍ عَ يّتّ رَ، قٌ عَ نَ نَشَن تٌ عَ بَبَ عَلَ رَ. عَلَ شَ دِ، عَ بَبَ عَلَ نَن قْشِ رَبَمَ.  
\v 20 بَرِ مَ بَبَ عَلَ عَ شَ دِ شَنُشِ نّ، عَ مَن قٍ نَشَن بِرِن نَبَمَ، عَ عَ مَسٍنمَ عَ شَ دِ بّ. عَ حَن قَمَ قٍيٍ مَسٍندٍ عَ بّ نَشٍيٍ مَكَابَ دَنفِ يٍيٍ رَ، عَلَكٌ وٌ دّ شَ عِشَرَ.  
\v 21 بَبَ عَلَ مِشِيٍ رَكٍلِمَ قَشّ مَ كِ نَشّ، عَ عٍ رَكِسِ، عَلَ شَ دِ قَن كِسِ قِمَ عَ نَ وَ عَ قِقٍ نَشٍيٍ مَ.  
\v 22 بَبَ عَلَ حَن مُ مِشِ يٌ مَكِيتِمَ، عَ مِشِ مَكِيتِقٍ بِرِن لُشِ عَ شَ دِ نَن مَ،  
\v 23 عَلَكٌ بِرِن شَ عَلَ شَ دِ بِنيَ عَلْ عٍ بَبَ عَلَ بِنيَمَ كِ نَشّ. نَشَن يٌ مُ عَلَ شَ دِ بِنيَ، عَ مُ بَبَ عَلَ قَن بِنيَشِ نَشَن عَ شَ دِ شّيشِ دُنِحَ.» 
\p  
\v 24 «ﭑ شَ نْندِ قَلَ وٌ بّ، نَشَن عَ تُلِ مَتِمَ ﭑ نَ، عَ قَ لَ ﭑ شّيمَ رَ، نَ كَنيِ بَرَ كِسِ عَبَدَن. نَ كَنيِ مُ كِيتِ شْرْشْي سْتْمَ، عَ بَرَ فّ رَتَنفَدٍ يَهَننَمَ مَ، عَ بَرَ كِسِ سْتْ.  
\v 25 ﭑ شَ عَ قَلَ وٌ بّ عَ نْندِ كِ مَ، وَشَتِ قَقٍ عَ لِدٍ، عَ حَن بَرَ عَ لِ، قَشَمِشِيٍ عَلَ شَ دِ شُي مّمَ نّ. نَشٍيٍ نَ عَ شُي مّ، نٍيٍ كِسِمَ نّ.  
\v 26 بَبَ عَلَ تٌ قِندِشِ كِسِ كَنيِ رَ كِسِ سْتْمَ نَشَن نَ، عَ بَرَ عَ شَ دِ قَن قِندِ كِسِ كَنيِ رَ كِسِ سْتْمَ نَشَن نَ.  
\v 27 عَ مَن بَرَ نْي سٌ عَ يِ رَ عَدَ مَدِيٍ مَكِيتِقٍ مَ، بَرِ مَ عَدَ مَ شَ دِ نَن عَ رَ.  
\v 28 وٌ نَشَ كَابَ يِ قٍ مَ، بَرِ مَ وَشَتِ قَقٍ عَ لِدٍ، نَشٍيٍ نَ فَبُرِ كُي، عٍ بِرِن عَ شُي مّمَ نّ،  
\v 29 عٍ مِنِ عٍ شَ فَبُرِيٍ كُي. نَشٍيٍ قِندِ قٍ قَنيِ رَبَيٍ رَ، نٍيٍ نَ كٍلِ، عٍ كِسِ نَن سْتْمَ. كْنْ نَشٍيٍ قِندِ قٍ كٌبِ رَبَيٍ رَ، نٍيٍ تَن نَ كٍلِ، عٍ فبَلٌي نَن سْتْمَ.» 
\p  
\v 30 «ﭑ تَن مُ نْمَ قٍقٍ رَبَدٍ ﭑ يّتّ رَ. ﭑ عَ مّمَ بَبَ عَلَ رَ كِ نَشّ، ﭑ تَن كِيتِ سَمَ نَ كِ نّ. نَ كُي، ﭑ مَ كِيتِ تِنشِن، بَرِ مَ ﭑ مُ بِرَ مَ ﭑ يّتّ وَشْنقٍ شَ قْشْ رَ، ﭑ بِرَشِ ﭑ شّيمَ نَن وَشْنقٍ قْشْ رَ.» 
\p  
\v 31 «شَ ﭑ سَ سٍيدٍ بَ ﭑ يّتّ بّ، عَ مُ لَنمَ.  
\v 32 بَبَ عَلَ نَن سٍيدٍ بَمَ ﭑ بّ. ﭑ قَن عَ كٌلٌن عَ تَن سٍيدٍحْشْيَ نَشَن بَمَ ﭑ مَ قٍ رَ، عَ قِندِشِ نْندِ نَن نَ.  
\v 33 وٌ تَن يَتِ بَرَ مِشِيٍ شّي يَيَ شْن، عَ قَن نَشَ سٍيدٍحْشْيَ بَ نْندِ شَ قٍ رَ.  
\v 34 ﭑ هَيِ مُ نَ عَدَ مَ تَن شَ سٍيدٍحْشْيَ مَ، كْنْ ﭑ يِ قٍيٍ مَسٍنشِ نّ وٌ بّ عَلَكٌ وٌ شَ كِسِ.  
\v 35 يَيَ نُ لُشِ نّ عَلْ لَنثُي رَدّشّشِ نَشَن يَنبَمَ. وٌ بَرَ سّيوَ نَ نَءِيَلَنيِ رَ وَشَتِ ندٍ بُن مَ.» 
\p  
\v 36 «كْنْ سٍيدٍحْشْيَ ندٍ نَ ﭑ بّ نَشَن دَنفِ يَيَ فبٍ رَ. ﭑ قٍيٍ نَشٍيٍ رَبَمَ، بَبَ عَلَ بَرَ نَشٍيٍ سٌ ﭑ يِ ﭑ شَ عٍ رَبَ، نٍيٍ نَن قِندِشِ سٍيدٍحْشْيَ رَ ﭑ مَ قٍ رَ، عَ بَبَ عَلَ نَن ﭑ شّيشِ.  
\v 37 بَبَ عَلَ نَشَن ﭑ شّيشِ، عَ قَن يَتِ بَرَ سٍيدٍ بَ ﭑ مَ قٍ رَ. وٌ سِنفٍ مُ نُ عَ شُي مّ، وٌ مُ نُ عَ يَتَفِ تٌ،  
\v 38 عَ شَ مَسٍنيِ مَن مُ سَبَتِشِ وٌ بْحّ مَ، بَرِ مَ وٌ مُ لَشِ عَ شَ شّيرَ رَ.  
\v 39 وٌ لُمَ كِتَابُييٍ مَتٌ رَ، بَرِ مَ وٌ حْشْ عَ مَ، عَ وٌ عَبَدَن كِسِ سْتْمَ عٍ تَن نَن سَابُي رَ. عَ قَ لِ، نَ كِتَابُييٍ يَتِ نَن ﭑ مَ قٍ سٍيدٍ بَمَ،  
\v 40 كْنْ وٌ تٌندِشِ قَدٍ ﭑ مَ وٌ شَ كِسِ سْتْ.» 
\p  
\v 41 «ﭑ مُ وَ مَ عَدَ مَدِيٍ شَ مَتْشْي شْن.  
\v 42 ﭑ وٌ كٌلٌن. عَلَ شَ شَنُنتٍيَ مُ نَ وٌ بْحّ كُي.  
\v 43 ﭑ قَشِ ﭑ بَبَ نَن شِلِ رَ، كْنْ وٌ مُ ﭑ نَسّنّشِ. شَ مِشِ فبّتّ سَ قَ عَ يّتّ كَن نَن شِلِ رَ، وٌ مُ تٌندِ مَ نَ تَن نَسّنّدٍ.  
\v 44 وٌ تٌ وَ مَ وٌ شَ مَتْشْي سْتْ وٌ بٌرٍ رَ، كْنْ وٌ مُ مَتْشْي قٍنمَ نَشَن قَتَنشِ عَلَ كٍرٍنيِ تَن نَ، وٌ قَ دَنشَنِيَمَ دِ؟» 
\p  
\v 45 «وٌ نَشَ عَ مَحْشُن دٍ عَ ﭑ تَن نَن وٌ كَلَمُمَ بَبَ عَلَ شْن. عَننَبِ مُنسَ، وٌ شَشِلِ تِشِ نَشَن نَ، نَ نَن وٌ كَلَمُمَ.  
\v 46 شَ وٌ سَ لَشِ مُنسَ رَ نُ، وٌ لَمَ نّ ﭑ قَن نَ نُ، بَرِ مَ مُنسَ ﭑ تَن نَن مَ قٍ سّبّ.  
\v 47 كْنْ شَ وٌ مُ لَشِ عَ شَ كِتَابُي رَ، وٌ قَ لَمَ ﭑ تَن مَ مَسٍنيِ رَ دِ؟» 
\c 6  
\s1 عِسَ دٌنسٍ قِقٍ شّمّ مِشِ وُلُ سُولِ مَ 
\r مَتِيُ ١٤‏؛١٣ ٬ ٢١، مَرَكِ ٦‏؛٣٠ ٬ ٤٤، لُكِ ٩‏؛١٠ ٬ ١٧ 
\p  
\v 1 نَ شَنبِ، عِسَ نَشَ فِرِ فَلِلٍ بَا نَاكِرِ مَ، عٍ نَشَن شِلِ قَلَمَ تِبٍرِيَسِ بَا.  
\v 2 حَمَ فبٍفبٍ نُ بِرَشِ عَ قْشْ رَ، بَرِ مَ عٍ نُ عَ شَ تْنشُمَ مَكَابَشِيٍ تٌشِ، عَ نُ نَشٍيٍ رَبَمَ قُرٍ مَيٍ بّ.  
\v 3 عِسَ نَشَ تٍ فٍيَ قَرِ، عَ سَ دْشْ نَا عَ نُن عَ قْشِرَبِرّيٍ.  
\v 4 يُوِقِيٍ شَ سَيَمَلٍكّ دَنفِ سَلِ نُ بَرَ مَكْرّ. 
\p  
\v 5 عِسَ تٌ عَ يَ رَ سِفَ، عَ نَشَ حَمَ فبٍفبٍ تٌ قَ رَ عَ يِرٍ، عَ نَشَ قِلِثُ مَشْرِن، «وٌن سَ نْمَ تَامِ سَرَدٍ مِندٍن عَلَكٌ يِ مِشِ بِرِن شَ عٍ دّفٍ؟»  
\v 6 عَ نَ قَلَ نّ عَلَكٌ عَ شَ قِلِثُ مَتٌ، بَرِ مَ عِسَ حَن نُ عَ كٌلٌن عَ قَقٍ نَشَن نَبَدٍ.  
\v 7 قِلِثُ نَشَ عَ يَابِ، «هَلِ وٌن تَامِ سَرَ شِ كّمّ قِرِن وَلِ سَرٍ نَن نَ، نَ مُ عَ نِيَمَ يِ حَمَ مِشِ بِرِن شَ نْ تَامِ شُنتُندِ سْتْدٍ.»  
\v 8 عِسَ قْشِرَبِرّ عَندِرٍ، سِمْن ثِيّرِ شُنيَ، عَ نَشَ عَ قَلَ،  
\v 9 «مّنفِ تَامِ سُولِ نَ يِ شّمّ دِ مّدِ يِ رَ، عَ نُن يّشّ قِرِن، كْنْ نَ قِندِشِ مُنسٍ رَ يِ حَمَ بّ؟»  
\v 10 عِسَ نَشَ عَ مَسٍن، «وٌ عَ قَلَ حَمَ بّ عٍ شَ عٍ مَفٌرٌ.» حٌوفٍ شِندٍ فبٍفبٍ تٌ نُ نَ نَا، مِشِيٍ نَشَ دْشْ بْشِ، عٍ شّمّ مِشِ وُلُ سُولِ حْندْن.  
\v 11 نَ تّمُي، عِسَ نَشَ نَ تَامِ سُولِ تٌنفٌ، عَ عَلَ تَنتُ، عَ عٍ عِتَشُن حَمَ مَفٌرٌشِ مَ، عَ عَ رَبَ نَ كِ نّ يّشّ قَن نَ. بِرِن نَشَ عَ سْتْ، هَن عٍ بِرِن نَشَ وَ سَ.  
\v 12 حَمَ تٌ لُفَ، عِسَ نَشَ عَ قَلَ عَ قْشِرَبِرّيٍ بّ، «وٌ دٌنسٍ دْنشْي شُنتُنيِيٍ مَلَن، عَلَكٌ سٍسٍ نَشَ مَكَنَ.»  
\v 13 نَ كُي، عٍ نَشَ مِشِيٍ شَ دٌنسٍ دْنشْي شُنتُنيِيٍ مَلَن هَن دٍبٍ قُ نُن قِرِن نَشَ رَقٍ. نَ بِرِن قَتَن مّنفِ تَامِ فُندِ سُولِ نَن نَ. 
\p  
\v 14 حَمَ تٌ عِسَ شَ تْنشُمَ مَكَابَشِ تٌ، عٍ نَشَ عَ قَلَ، «مُشُ بَرَ نَمِحْنمّ نَشَن مَمّ عَ شَ قَ دُنِحَ مَ، عَ تَن نَن يَتِ يِ كِ!»  
\v 15 عِسَ تٌ عَ كٌلٌن عَ عٍ نُ قَقٍ عَ سُشُدٍ نّ عٍ شَ عَ قِندِ مَنفّ رَ، عَ نَشَ كٍلِ عٍ شُن مَ، عَ سَ لُ عَ كٍرٍنيِ مَ فٍيَ قَرِ. 
\s1 عِسَ حّرّقٍ يٍ قَرِ 
\p  
\v 16 نُنمَرٍ تٌ سٌ، عِسَ قْشِرَبِرّيٍ نَشَ فٌرٌ بَا دّ رَ،  
\v 17 عٍ بَكِ كُنكُي كُي، عٍ شَ بَا عِفِرِ سِفَقٍ رَ كَثّرّنَمُ. دِ مِ نُ بَرَ سِن، كْنْ عِسَ مُ نُ فبِلٍن عٍ يِرٍ سِندٍن.  
\v 18 قٌيٍ بٍلٍبٍلٍ نَشَ مِنِ، بَا نَشَ شَاحّ.  
\v 19 عٍ تٌ لَالَ بَ كِلٌ سُولِ شَ نَ مُ سٍننِ حْندْن، عٍ نَشَ عِسَ تٌ حّرّ رَ يٍ قَرِ، عَ قَقٍ عٍ مَبِرِ كُنكُي يِرٍ. عٍ نَشَ فَاشُ.  
\v 20 كْنْ عِسَ نَشَ عَ قَلَ عٍ بّ، «ﭑ تَن نَن عَ رَ. وٌ نَشَ فَاشُ.»  
\v 21 عٍ تٌ نُ وَ مَ عَ شَ تٍ كُنكُي كُي، كُنكُي نَشَ عٍ سِفَدٍ لِ كٍرٍن نَ. 
\s1 كِسِ تَامِ نَشَن قَتَنشِ عَلَ رَ 
\p  
\v 22 كُيٍ نَشَ عِبَ حَمَ رَ بَا دّ، عِسَ قْشِرَبِرّيٍ كُنكُي تٌنفٌ دّننَشّ. عٍ نُ عَ كٌلٌن عَ نَ كُنكُي كٍرٍنيِ نَن نُ نَ نَا، عَ قَ لِ عِسَ مُ بَكِ عَ كُي، قٌ عَ قْشِرَبِرّيٍ دٌرٌ.  
\v 23 كُنكُي فبّتّ نَشٍيٍ كٍلِ تِبٍرِيَسِ، نٍيٍ نَشَ عٍ لِ مّننِ، عٍ تَامِ دٌن دّننَشّ، مَرِفِ نَشَن سٌ عٍ يِ عَ تٌ فّ عَلَ تَنتُدٍ.  
\v 24 مِشِيٍ تٌ عَ كٌلٌن عَ عِسَ مُ نُ نَ مّننِ سْنْن، عَ قْشِرَبِرّيٍ قَن مُ نَ، عٍ قَن نَشَ بَكِ كُنكُييٍ كُي، عٍ فِرِ كَثّرّنَمُ، عِسَ قٍندٍ. 
\p  
\v 25 عٍ تٌ عِسَ لِ بَا نَاكِرِ مَ، عٍ نَشَ عَ مَشْرِن، «كَرَ مْشْ، عِ قَشِ بٍ مُن تّمُي؟»  
\v 26 عِسَ نَشَ عٍ يَابِ، «عَ نْندِ كِ مَ ﭑ شَ عَ قَلَ وٌ بّ، وٌ مُ ﭑ قٍنقٍ شّ ﭑ تٌ تْنشُمَ مَكَابَشِ رَبَ وٌ يَ شْرِ. وٌ ﭑ قٍنقٍ نّ وٌ تٌ لُفَشِ تَامِ رَ.  
\v 27 وٌ نَشَ وَلِ دُنِحَ بَلٌي شَ قٍ رَ، نَشَن بْرْ مَ. وٌ شَ وَلِ بَلٌي نَن مَ قٍ رَ نَشَن بُمَ، عَ عَبَدَن كِسِ قِ وٌ مَ. عَدَ مَ شَ دِ نَن نَ بَلٌي قِمَ وٌ مَ، بَرِ مَ بَبَ عَلَ بَرَ عَ تَن نَن مَتْنشُمَ عَ شَ مِشِ سُفَندِشِ رَ.»  
\v 28 نَ كُي، حَمَ نَشَ عِسَ مَشْرِن، «مُشُ لَنمَ مُشُ شَ مُنسٍ رَبَ عَلَكٌ مُشُ شَ نُ كّوَلِيٍ رَبَ عَلَ وَ مَ نَشٍيٍ شْن؟»  
\v 29 عِسَ نَشَ عٍ يَابِ، «عَلَ وَ مَ كّوَلِ نَشَن شْن، عَ قِندِشِ يِ نَن نَ؛ وٌ شَ دَنشَنِيَ عَ شَ شّيرَ مَ.»  
\v 30 عٍ مَن نَشَ عَ مَشْرِن، «عِ تْنشُمَ مَكَابَشِ مُندُن نَبَمَ مُشُ يَ شْرِ عَلَكٌ مُشُ شَ لَ عِ رَ؟ عِ قَ كّوَلِ مُندُن نَبَمَ؟  
\v 31 مُشُ بٍنبَيٍ تَامِ ندٍ دٌن نّ فبٍنفبٍرٍنيِ مَ نَشَن فٌرٌ كٍلِقٍ كٌورٍ مَ. عَ سّبّشِ كِتَابُي كُي، ‹عَلَ نَشَ تَامِ قِ عٍ مَ بَلٌي رَ، نَشَن كٍلِ كٌورٍ مَ.›»  
\v 32 عِسَ مَن نَشَ عَ مَسٍن عٍ بّ، «ﭑ شَ عَ مَسٍن وٌ بّ عَ نْندِ كِ مَ، عَننَبِ مُنسَ مُ كٌورٍ تَامِ قِ وٌ مَ. ﭑ بَبَ نَن كٌورٍ تَامِ يَتِ قِمَ وٌ مَ.  
\v 33 بَرِ مَ تَامِ نَشَن قَتَنشِ عَلَ رَ، عَ تَن نَن فٌرٌ مَ كٍلِ كٌورٍ، عَ كِسِ قِ دُنِحَ مَ.» 
\p  
\v 34 نَ كُي، عٍ نَشَ عَ قَلَ عَ بّ، «مَرِفِ، مُشُ كِ نَ تَامِ رَ تّمُي بِرِن.»  
\v 35 عِسَ نَشَ عٍ يَابِ، «ﭑ تَن نَن نَ كِسِ تَامِ رَ. نَشَن نَ قَ ﭑ تَن مَ، عَ مُ كَامّ كٌلٌنمَ عَبَدَن. نَشَن نَ دَنشَنِيَ ﭑ تَن مَ، عَ مُ يٍ شْلِ كٌلٌنمَ سْنْن.  
\v 36 كْنْ عَلْ ﭑ عَ قَلَشِ وٌ بّ كِ نَشّ، هَلِ وٌ تٌ بَرَ ﭑ تٌ، وٌ مُ لَشِ ﭑ نَ.  
\v 37 بَبَ عَلَ مِشِ نَشَن بِرِن قِمَ ﭑ مَ، عَ قَمَ نّ ﭑ مَ، ﭑ مُ مّيمَ عٍ رَ عَبَدَن،  
\v 38 بَرِ مَ ﭑ كٍلِشِ كٌورٍ مَ ﭑ شّيمَ وَشْنقٍ نَن نَبَدٍ. ﭑ مُ قَشِ ﭑ يّتّ وَشْنقٍ شَ رَبَدٍ.  
\v 39 ﭑ شّيمَ وَ مَ نّ ﭑ شَ عَ شَ مِشِ بِرِن نَكٍلِ قَشّ مَ لْشْ دْنشْي. عَ مِشِ نَشٍيٍ قِشِ ﭑ مَ، هَلِ كٍرٍن نَشَ لْي.  
\v 40 نَ نَن قِندِشِ ﭑ بَبَ سَفٌي رَ، عَ نَشَن يٌ نَ دَنشَنِيَ عَ شَ دِ مَ، نَ كَنيِ شَ عَبَدَن كِسِ سْتْ، ﭑ مَن شَ عَ رَكٍلِ قَشّ مَ لْشْ دْنشْي مَ.» 
\p  
\v 41 نَ كُي، يُوِقِيٍ نَشَ سٌ عَ مَقَلَقٍ، بَرِ مَ عَ نُ بَرَ عَ قَلَ، «ﭑ تَن نَن نَ تَامِ رَ نَشَن فٌرٌ كٍلِ كٌورٍ.»  
\v 42 عٍ نُ عَ قَلَمَ نّ، عٍ نَشّ، «عِسَ شَ مُ يِ كِ، يُسُقُ شَ دِ؟ وٌن مُ عَ نفَ نُن عَ بَبَ كٌلٌن؟ عَ قَ عَ قَلَمَ دِ، عَ عَ فٌرٌشِ نّ كٍلِ كٌورٍ؟»  
\v 43 عِسَ نَشَ عٍ يَابِ، «وٌ بَ وْيّنقٍ وٌ بٌرٍ تَفِ نَ مْولِ رَ.  
\v 44 مِشِ يٌ مُ نْمَ قَدٍ ﭑ مَ، شَ بَبَ عَلَ، نَشَن ﭑ شّيشِ، مُ عَ كَنيِ مَبّندُن ﭑ مَ. ﭑ قَن قَمَ عَ كَنيِ رَكٍلِدٍ قَشّ مَ لْشْ دْنشْي.  
\v 45 عَ سّبّشِ نَمِحْنمّيٍ شَ كِتَابُي كُي، ‹عَلَ قَمَ نّ عٍ بِرِن شَرَندٍ.› نَشَن يٌ نَ بَبَ عَلَ شُي رَ مّ، عَ عَ شَ مَسٍنيِ سُشُ، نَ كَنيِ تَن قَمَ نّ ﭑ مَ.  
\v 46 مِشِ يٌ مُ نَ نَشَن بَرَ بَبَ عَلَ تٌ، بَقٍ مِشِ رَ نَشَن قَتَنشِ عَلَ رَ. نَ كٍرٍن نَن بَرَ بَبَ عَلَ تٌ.» 
\p  
\v 47 «ﭑ شَ عَ قَلَ وٌ بّ عَ نْندِ كِ مَ، نَشَن نَ دَنشَنِيَ ﭑ مَ، عَ بَرَ عَبَدَن كِسِ سْتْ.  
\v 48 ﭑ تَن نَن نَ كِسِ تَامِ رَ.  
\v 49 وٌ بٍنبَيٍ تَامِ دٌن نّ فبٍنفبٍرٍنيِ مَ، كْنْ عٍ بِرِن نَشَ قَشَ.  
\v 50 تَامِ نَشَن فٌرٌشِ كٍلِ كٌورٍ، عَ نَ بٍ. نَشَن يٌ نَ يِ تَن دٌن، نَ كَنيِ مُ قَشَمَ.  
\v 51 ﭑ تَن نَن نَ نَ كِسِ تَامِ رَ نَشَن فٌرٌشِ كٍلِ كٌورٍ. نَشَن يٌ نَ يِ تَامِ تَن دٌن، عَ كِسِمَ نّ عَبَدَن. يِ تَامِ قِندِشِ ﭑ قَتٍ نَن نَ، ﭑ نَشَن قِمَ سّرّشّ رَ عَلَكٌ دُنِحَ شَ كِسِ سْتْ.» 
\p  
\v 52 نَ كُي، سْنشْي نَشَ مِنِ يُوِقِيٍ تَفِ، عٍ نُ عَ قَلَ، «ثٍ، يِ شّمّ نْمَ عَ قَتٍ سُبٍ سٌدٍ وٌن يِ رَ دِ، وٌن شَ عَ دٌن؟»  
\v 53 عِسَ نَشَ عَ مَسٍن عٍ بّ، «ﭑ شَ عَ قَلَ وٌ بّ عَ نْندِ كِ مَ، شَ وٌ مُ عَدَ مَ شَ دِ قَتٍ سُبٍ دٌن، شَ وٌ مُ عَ وُلِ مِن، كِسِ مُ وٌ بّ.  
\v 54 نَشَن ﭑ سُبٍ دٌنمَ، عَ ﭑ وُلِ مِن، نَ كَنيِ كِسِمَ نّ عَبَدَن، ﭑ عَ رَكٍلِمَ نّ قَشّ مَ لْشْ دْنشْي.  
\v 55 ﭑ قَتٍ نَن قِندِشِ بَلٌي يَتِ رَ. ﭑ وُلِ نَن قِندِشِ مِنسٍ يَتِ رَ.  
\v 56 نَشَن ﭑ سُبٍ دٌنمَ، عَ ﭑ وُلِ مِن، ﭑ بَرَ سَبَتِ نَ كَنيِ عِ، عَ قَن بَرَ سَبَتِ ﭑ قَن عِ.  
\v 57 بَبَ عَلَ تٌ ﭑ شّيشِ، كِسِ قَتَنمَ نَشَن نَ، كِسِ نَ ﭑ قَن يِ عَ تَن سَابُي رَ. نَ مْولِ مَن نَ، نَشَن بَلٌمَ ﭑ تَن مَ، نَ كَنيِ كِسِمَ ﭑ سَابُي رَ.  
\v 58 تَامِ نَشَن فٌرٌشِ كٍلِ كٌورٍ، عَ نَ بٍ. عَ مُ لُشِ عَلْ وٌ بٍنبَيٍ تَامِ نَشَن دٌن. عٍ تَن قَشَ نّ. نَشَن يِ تَامِ تَن دٌنمَ، نَ كَنيِ كِسِمَ نّ عَبَدَن.»  
\v 59 عِسَ يِ مَسٍنيِ تِ نّ عَ نُ مِشِيٍ كَوَندِ مَ تّمُي نَشّ كَثّرّنَمُ سَلِدٍ كُي. 
\s1 عِسَ قْشِرَبِرّ فبٍفبٍ حَنِفٍ مَسَرَقٍ 
\p  
\v 60 عٍ تٌ عَ شَ مَسٍنيِ مّ، عَ قْشِرَبِرّ وُيَشِ نَشَ عَ قَلَ، «يِ مَسٍنيِ تَن شْرْشْ دٍ! ندٍ نْمَ تِندٍ عَ رَ؟»  
\v 61 عِسَ تٌ عَ كٌلٌن عَ عَ قْشِرَبِرّيٍ نَ يِ وْيّنيِ قَلَقٍ عٍ بٌرٍ تَفِ، عَ نَشَ عٍ مَشْرِن، «ﭑ مَ مَسٍنيِ بَرَ وٌ رَشْنْ؟  
\v 62 شَ عَ سَ لِ فٌ، وٌ سَ عَدَ مَ شَ دِ تٌ تٍ رَ كٌورٍ مَ، عَ كٍلِشِ دّننَشّ؟  
\v 63 عَلَ شَشِلِ سّنِيّنشِ نَن كِسِ قِمَ مِشِ مَ. قَتٍ بّندّ تَن مُ نْمَ سٍسٍ رَ. ﭑ مَسٍنيِ نَشَن تِشِ وٌ بّ، عَ عَلَ شَشِلِ سّنِيّنشِ نُن كِسِ سْتْ كِ نَن مَسٍنمَ.  
\v 64 كْنْ مِشِ ندٍيٍ نَ وٌ يَ مَ، نَشٍيٍ مُ دَنشَنِيَشِ.» عِسَ نَ قَلَ نّ بَرِ مَ كَبِ عَ قْلّ، عَ نُ عَ كٌلٌن نَشٍيٍ مُ دَنشَنِيَشِ، عَ نُن نَشَن قَمَ عَ يَنقَدٍ، عَ عَ سَ كُنتِفِيٍ بّلّشّ.  
\v 65 عَ مَن نَشَ عَ مَسٍن، «نَ نَن عَ رَ، ﭑ عَ قَلَشِ نّ وٌ بّ، عَ مِشِ يٌ مُ نْمَ قَدٍ ﭑ شْن مَ، شَ بَبَ عَلَ مُ نَ دَنشَنِيَ قِ عَ مَ.» 
\p  
\v 66 نَ شَنبِ، عَ قْشِرَبِرّ فبٍفبٍ نَشَ حَنِفٍ مَسَرَ، عٍ فبِلٍن عَ قْشْ رَ.  
\v 67 نَ كُي، عِسَ نَشَ عَ قْشِرَبِرّ قُ نُن قِرِنيِيٍ مَشْرِن، «وٌ تَن فٌ؟ وٌ قَن وَ مَ كٍلِقٍ ﭑ شُن مَ؟»  
\v 68 سِمْن ثِيّرِ نَشَ عَ يَابِ، «مَرِفِ، شَ مُشُ فبِلٍن عِ قْشْ رَ، مُشُ قَ سِفَمَ ندٍ شْن مَ؟ عَبَدَن كِسِ مَسٍنيِ نَ عِ تَن نَن يِ.  
\v 69 مُشُ بَرَ لَ عَ رَ، مُشُ مَن بَرَ فّ عَ كٌلٌندٍ، عَ عِ تَن نَن نَ عَلَ شَ سّنِيّنتْي رَ.»  
\v 70 عِسَ نَشَ عٍ يَابِ، «ﭑ تَن شَ مُ وٌ سُفَندِ، وٌ تَن مِشِ قُ نُن قِرِنيِيٍ؟ كْنْ مِشِ كٍرٍن نَ وٌ يَ مَ، عَدَ مَ سٍنتَنّ نَن عَ رَ.»  
\v 71 عَ نُ سِمْن عِسِكَرِيٌتِ شَ دِ يُدَ سِ نَن مَ، نَشَن نُ نَ عَ قْشِرَبِرّ قُ نُن قِرِنيِيٍ يَ مَ. عَ تَن نَن نُ قَمَ عَ يَنقَدٍ، عَ عَ سَ كُنتِفِيٍ بّلّشّ. 
\c 7  
\s1 عِسَ شُنيَيٍ شَ دَنشَنِيَتَرٍحَ 
\p  
\v 1 نَ شَنبِ، عِسَ نَشَ فَلِلٍ بْشِ عِسَ قْلْ. عَ مُ نُ يُدَيَ تَن عِحّرّ مَ، بَرِ مَ يُوِقِ كُنتِفِيٍ نُ كَتَقٍ نّ عٍ شَ عَ قَشَ.  
\v 2 يُوِقِيٍ شَ بَفٍ تِ سَلِ تٌ نُ بَرَ مَكْرّ،  
\v 3 عِسَ شُنيَيٍ نَشَ عَ قَلَ عَ بّ، «عَ لَن نّ عِ شَ كٍلِ يِ بْشِ مَ، عِ سِفَ يُدَيَ، عَلَكٌ عِ قْشِرَبِرّيٍ نَشٍيٍ سَ نَ نَا، عٍ قَن شَ عِ شَ وَلِيٍ تٌ، عِ نَشٍيٍ رَبَمَ.  
\v 4 مِشِ مُ عَ شَ وَلِ نْشُنمَ شَ عَ وَ مَ دُنِحَ شَ عَ كٌلٌن. عِ تٌ يِ تْنشُمَيٍ رَبَمَ، عَ لَنمَ عِ شَ عٍ رَبَ كّنّ مَ.»  
\v 5 عٍ نَ قَلَ نّ، بَرِ مَ هَلِ عٍ تٌ قِندِشِ عَ شُنيَيٍ رَ، عٍ مُ نُ لَشِ عَ رَ.  
\v 6 عِسَ نَشَ عَ مَسٍن عٍ بّ، «ﭑ مَ وَشَتِ مُ نُ عَ لِ سِندٍن، كْنْ وَشَتِ يٌ مُ نَ وٌ تَن شَ قٍ مَ.  
\v 7 دُنِحَ مُ نْمَ وٌ تَن شْندٍ، كْنْ عٍ ﭑ تَن شْنمَ، بَرِ مَ ﭑ سٍيدٍحْشْيَ بَمَ عٍ شَ قٍ رَ، عَ عٍ شَ وَلِيٍ كٌبِ.  
\v 8 وٌ تَن شَ تٍ دَرِ سَلَمُ، وٌ سَ سَلِ رَبَ نَا. ﭑ تَن مُ سِفَمَ، بَرِ مَ ﭑ مَ وَشَتِ مُ فّشِ عَ لِدٍ سِندٍن.»  
\v 9 عَ نَ قَلَ شَنبِ، عَ نَشَ لُ فَلِلٍ. 
\s1 عِسَ كَوَندِ تِقٍ دَرِ سَلَمُ 
\p  
\v 10 عَ شُنيَيٍ تٌ تٍ سَلِ رَبَدٍ دَرِ سَلَمُ، عِسَ قَن نَشَ سِفَ، كْنْ عَ فُندٌ كِ مَ.  
\v 11 سَلِ تٌ نُ رَبَقٍ، يُوِقِ كُنتِفِيٍ نُ عَ قٍنقٍ دَرِ سَلَمُ، عٍ نُ مَشْرِنيِ تِ، «عَ نَ مِندٍن؟»  
\v 12 مِشِيٍ نُ وْيّن فبٍفبٍ مَكْيِكْيِمَ عٍ بٌرٍ تُلِ عِسَ شَ قٍ رَ. ندٍيٍ عَ قَلَمَ عَ مِشِ قَنيِ نَن عَ رَ، ندٍيٍ عَ قَلَمَ عَ عَ نَ حَمَ رَتَنتَنقٍ نَن تُي.  
\v 13 كْنْ عٍ تٌ نُ فَاشُشِ يُوِقِ كُنتِفِيٍ يَ رَ، مِشِ يٌ مُ نُ سُو سَمَ عَ شَ قٍ قَلَدٍ كّنّ مَ. 
\p  
\v 14 يُوِقِيٍ نُ سَلِ نَشَن نَبَقٍ، لْشُن كٍرٍن نَ عَ رَ. نَ تٌ نُ بَرَ سِفَ هَن عَ تَفِ، عِسَ نَشَ تٍ هْرْ مْبَنشِ كُي، عَ كَوَندِ تِ قْلْ.  
\v 15 يُوِقِ كُنتِفِيٍ نَشَ كَابَ، عٍ نُ عَ قَلَ، «يِ شّمّ لْننِشِ يِ مْولِ رَ دِ، عَ تٌ مُ شَرَنشِ؟»  
\v 16 عِسَ نَشَ عٍ يَابِ، «ﭑ كَوَندِ نَشَن تِمَ، عَ مُ كٍلِشِ ﭑ تَن شَ مَ. عَ كٍلِشِ ﭑ شّيمَ نَن مَ.  
\v 17 مِشِ نَشَن وَ مَ عَلَ وَشْنقٍ رَبَقٍ، عَ نْمَ نّ عَ كٌلٌندٍ شَ يِ شَرَنيِ قَتَنشِ عَلَ نَن نَ. شَ ﭑ فبٍ فبَنسَن نَ عَ رَ، مِشِيٍ عَ كٌلٌنمَ نّ نُ.  
\v 18 مِشِ نَشَن وْيّنمَ عَ يّتّ شَشِلِ مَ، عَ مَتْشْي قٍنقٍ عَ يّتّ نَن بّ. كْنْ نَشَن مَتْشْي قٍنقٍ عَ شّيمَ بّ، نْندِ قَلّ نَن نَ كَنيِ رَ، تِنشِنتَرٍيَ يٌ مُ نَشَن بْحّ مَ.  
\v 19 عَننَبِ مُنسَ يَتِ نَن عَلَ شَ سّرِيّ سٌشِ وٌ يِ رَ، كْنْ وٌ مُ عَ رَتِنمّشِ. مُنقٍ رَ وٌ وَ مَ ﭑ قَشَقٍ؟»  
\v 20 حَمَ نَشَ عَ قَلَ، «حِننّ نَن نَ عِ قْشْ رَ! ندٍ كَتَقٍ عِ قَشَدٍ؟»  
\v 21 عِسَ نَشَ عٍ يَابِ، «ﭑ كَابَنَكٌ كٍرٍن نَن نَبَ، عَ قَ وٌ بِرِن دّ عِشَرَ.  
\v 22 مُنسَ عَ بٍنبَيٍ شَ سّرِيّ قَلَشِ نّ وٌ بّ عَ وٌ شَ وٌ شَ دِ شّمّيٍ سُننَ. وٌ نَ رَبَمَ هَلِ مَلَبُ لْشْي.  
\v 23 شَ شّمّ سُننَمَ مَلَبُ لْشْي عَلَكٌ عَننَبِ مُنسَ شَ سّرِيّ نَشَ قَ كَنَ، وٌ شْنْمَ ﭑ تَن مَ مُنقٍ رَ، ﭑ تٌ قُرٍ مَ قَتٍ بِرِن نَيَلَن مَلَبُ لْشْي مَ؟  
\v 24 وٌ شَ قٍيٍ كُي مَتٌ عَ قَنيِ رَ بٍينُن وٌ شَ كِيتِ سَ. كِيتِ شَ تِنشِن.» 
\p  
\v 25 دَرِ سَلَمُكَ ندٍيٍ نُ عَ قَلَقٍ، «كُنتِفِيٍ مُ نَ كَتَقٍ يِ شَ قَشَدٍ؟  
\v 26 عَ مَتٌ، عَ تَن نَن وْيّنقٍ كّنّ مَ يِ كِ، كْنْ عٍ مُ سٍسٍ قَلَمَ عَ بّ! كَ عٍ بَرَ لَ عَ رَ، عَ عَلَ شَ مِشِ سُفَندِشِ نَ عَ رَ؟  
\v 27 كْنْ وٌن بِرِن عِسَ بَرِدٍ كٌلٌن. عَلَ شَ مِشِ سُفَندِشِ تَن نَ قَ، عَ بَرِدٍ مُ كٌلٌنمَ.» 
\p  
\v 28 نَ كُي، عِسَ نَشَ كَوَندِ تِ عَ شُي عِتٍشِ رَ هْرْ مْبَنشِ كُي، «وٌ ﭑ كٌلٌن، وٌ ﭑ كٍلِدٍ قَن كٌلٌن؟ كْنْ ﭑ تَن مُ قَشِ ﭑ يّتّ كَن حَنِفٍ شَ مَ. نْندِ كَنيِ نَن ﭑ شّيشِ، كْنْ وٌ تَن مُ عَ كٌلٌن.  
\v 29 ﭑ تَن عَ كٌلٌن، بَرِ مَ ﭑ قَتَنشِ عَ تَن نَن نَ. عَ تَن نَن ﭑ شّيشِ.» 
\p  
\v 30 نَ كُي، عٍ نَشَ كَتَ عَ سُشُدٍ، كْنْ عٍ مُ نْ، بَرِ مَ عَ شَ وَشَتِ مُ نُ عَ لِشِ سِندٍن.  
\v 31 كْنْ حَمَ يَ مَ مِشِ فبٍفبٍ نَشَ دَنشَنِيَ عِسَ مَ، عٍ نُ عَ قَلَ، «عَلَ شَ مِشِ سُفَندِشِ نَ قَ، عَ تْنشُمَ مَكَابَشِيٍ رَبَمَ دَنفِ يِ شّمّ رَ؟» 
\p  
\v 32 قَرِ سّنِيٍ تٌ عَ مّ، حَمَ نُ نَشَن مَكْيِكْيِقٍ عِسَ شَ قٍ رَ، عٍ تَن نُن سّرّشّدُبّ كُنتِفِيٍ نَشَ هْرْ مْبَنشِ كْسِبِلِيٍ شّي، عٍ شَ سَ عِسَ سُشُ.  
\v 33 عِسَ نَشَ عَ مَسٍن، «ﭑ نَ وٌ يَ مَ سِندٍن دٌندٌرٌنتِ، ﭑ قَ سِفَ ﭑ شّيمَ يِرٍ.  
\v 34 وٌ قَمَ نّ ﭑ قٍندٍ، كْنْ وٌ مُ ﭑ تٌمَ. ﭑ سَ لُمَ دّننَشّ، وٌ مُ نْمَ نَا لِدٍ.»  
\v 35 يُوِقِ كُنتِفِيٍ نَشَ عٍ بٌرٍ مَشْرِن، «يِ وَ مَ سِفَقٍ مِندٍن، وٌن مُ سَ نْمَ عَ تٌدٍ دّننَشّ؟ كَ عَ وَشِ نّ عَ شَ سَ سَبَتِ حَمَنّ فبّتّ عَلْ مُشُ شَ مِشِ ندٍيٍ، عَلَكٌ عَ شَ سَ سِ فبّتّيٍ شَرَن؟  
\v 36 عَ تٌ عَ مَسٍنشِ عَ مُشُ قَمَ عَ قٍندٍ كْنْ مُشُ مُ عَ تٌمَ، عَ عَ سَ لُمَ دّننَشّ، مُشُ مُ نْمَ نَا لِدٍ، عَ وَشِ مُنسٍ قَلَقٍ؟» 
\s1 كِسِ يٍ 
\p  
\v 37 نَ سَلِ وَشَتِ لْشْ دْنشْي مَ، نَشَن تِدٍ فبٌ بٌورٍ بِرِن بّ، عِسَ نَشَ كٍلِ، عَ عَ مَسٍن عَ شُي عِتٍشِ رَ، «يٍ شْلِ نَ نَشَن يٌ مَ، عَ شَ قَ ﭑ شْن، عَ شَ عَ مِن.  
\v 38 عَلْ كِتَابُي عَ مَسٍنشِ كِ نَشّ، نَشَن يٌ نَ دَنشَنِيَ ﭑ مَ، كِسِ يٍ بُلَمَ نّ عَ بْحّ كُي، عَلْ شُرٍ نَشَن سُسُمَ.»  
\v 39 عَ نُ نَ عَلَ شَشِلِ نَن مَ قٍ مَسٍنقٍ، عَ شَ دَنشَنِيَتْييٍ نُ قَمَ نَشَن سْتْدٍ. نَ وَشَتِ، عَلَ شَشِلِ مُ نُ قَشِ سِندٍن، بَرِ مَ عِسَ شَ شُننَكٍلِ مُ نُ مَكّنّنشِ سِندٍن. 
\p  
\v 40 حَمَ تٌ عَ شَ مَسٍنيِ مّ، ندٍيٍ نَشَ عَ قَلَ، «مُشُ نُ نَمِحْنمّ نَشَن مَمّشِ عَ شَ قَ، عَ تَن نَن يَتِ يِ كِ!»  
\v 41 فبّتّ قَن نَشَ عَ قَلَ، «عَلَ شَ مِشِ سُفَندِشِ نَن نَ يِ رَ!» كْنْ ندٍيٍ قَن نَشَ عَ قَلَ، «عَلَ شَ مِشِ سُفَندِشِ قِندِ مَ فَلِلٍكَ رَ؟  
\v 42 كِتَابُي مُ عَ مَسٍنشِ شّ، عَ عَلَ شَ مِشِ سُفَندِشِ كٍلِمَ دَوُدَ بْنسْي نّ، عَ كٍلِ بّتّلّيمُ، دَوُدَ شْنيِ؟»  
\v 43 نَ كُي، حَمَ مُ نُ لَنشِ عِسَ شَ قٍ مَ.  
\v 44 ندٍيٍ نُ وَ مَ عَ سُشُقٍ، كْنْ مِشِ يٌ مُ نْ. 
\p  
\v 45 نَ كُي، كْسِبِلِيٍ نَشَ فبِلٍن سّرّشّدُبّ كُنتِفِيٍ نُن قَرِ سّنِيٍ يِرٍ. نَ كُنتِفِيٍ نَشَ عٍ مَشْرِن، «مُنقٍ رَ وٌ مُ قَشِ عَ رَ بٍ؟»  
\v 46 كْسِبِلِيٍ نَشَ عٍ يَابِ، «عَ شَ مَسٍنيِ دَنفِ عَدَ مَدِيٍ شَ مَسٍنيِ بِرِن نَ.»  
\v 47 قَرِ سّنِيٍ قَن نَشَ عٍ يَابِ، «ثٍ، عَ بَرَ وٌ قَن مَدَشُ؟  
\v 48 مِشِ كٍرٍن نَ كُنتِفِيٍ شَ نَ مُ قَرِ سّنِيٍ يَ مَ نَشَن لَشِ عَ رَ؟  
\v 49 يِ حَمَ تَن مُ سّرِيّ كِتَابُي كٌلٌن. مِشِ دَنكَشِيٍ نَن عٍ رَ.» 
\p  
\v 50 كْنْ نِكٌدٍ مُ، نَشَن نُ بَرَ سِفَ عِسَ يِرٍ، عَ نَشَ عَ قَلَ عَ بٌورٍ كُنتِفِيٍ بّ،  
\v 51 «وٌن مَ سّرِيّ كِ مَ، مِشِ نّ مَكِيتِمَ، عَ مُ مَشْرِنمَ شّ عَلَكٌ عَ شَ كٌلٌن سِندٍن عَ قٍ نَشَن نَبَشِ؟»  
\v 52 عٍ نَشَ عَ يَابِ، «فَلِلٍكَ نَن نَ عِ قَن نَ؟ عَ مَتٌ كِتَابُي كُي، نَمِحْنمّ يٌ مُ كٍلِمَ فَلِلٍ بْشِ!»  
\v 53 نَ شَنبِ، كَنكَن نَشَ سِفَ عَ شْنيِ. 
\c 8  
\s1 فِنّ يّنّلَ مَكِيتِقٍ 
\p  
\v 1 عِسَ نَشَ سِفَ عٌلِوِ فٍيَ مَ.  
\v 2 كُيٍ تٌ عِبَ، عَ نَشَ سِفَ هْرْ مْبَنشِ. حَمَ تٌ قَ عَ يِرٍ، عَ نَشَ دْشْ، عَ سٌ عٍ كَوَندِقٍ. 
\p  
\v 3 سّرِيّ كَرَ مْشْيٍ نُن قَرِ سّنِيٍ قَن نَشَ قَ فِنّ ندٍ رَ، عٍ نَشَن سُشُشِ عَ نَ يّنّ رَبَقٍ. عٍ نَشَ عَ تِ مِشِ بِرِن يَ عِ،  
\v 4 عٍ عَ قَلَ عِسَ بّ، «كَرَ مْشْ، مُشُ يِ فِنّ سُشُشِ يّنّ نَن شُن.  
\v 5 سّرِيّ كِ مَ، عَننَبِ مُنسَ مُشُ يَمَرِشِ نّ مُشُ شَ يِ فِنّ مْولِ مَفْنْ فّمّ رَ هَن عَ قَشَ. عِ تَن عَ تٌشِ دِ؟» 
\p  
\v 6 عٍ نُ نَ فَنتَنيِ نَن تٍقٍ عَ بّ نَ مَشْرِنيِ رَ، عَ شَ قٍ ندٍ قَلَ، عٍ نْمَ عَ كَلَمُدٍ نَشَن مَ. عِسَ نَشَ عَ عِفٌرٌ، عَ نُ قَ سّبّلِ تِ بْشِ مَ عَ بّلّشّسٌلٍ رَ.  
\v 7 عٍ تٌ دْشْ عَ رَ، عَ نَشَ كٍلِ، عَ عَ قَلَ عٍ بّ، «يُنُبِ مُ نَ نَشَن مَ وٌ يَ مَ، نَ سِنفٍ شَ يِ فِنّ فْنْ.»  
\v 8 عَ مَن نَشَ عَ عِفٌرٌ، عَ نُ قَ سّبّلِ تِ بْشِ مَ.  
\v 9 عٍ تٌ عَ شَ وْيّنيِ مّ، عٍ بِرِن نَشَ سِفَ كٍرٍن كٍرٍن، قْلْقٍ قٌرِيٍ مَ. فِنّ فبَنسَن تٌ لُ عِسَ يَ عِ،  
\v 10 عِسَ نَشَ كٍلِ، عَ فِنّ مَشْرِن، «نَشٍيٍ قَ عِ رَ، عٍ نَ مِندٍن؟ مِشِ يٌ مُ لُ نَشَن عِ مَكِيتِمَ؟»  
\v 11 فِنّ نَشَ عَ يَابِ، «ﭑ مَرِفِ، مِشِ يٌ مُ لُ.» عِسَ نَشَ عَ قَلَ عَ بّ، «عَوَ، ﭑ قَن مُ عِ مَكِيتِمَ. سِفَ، عِ نَشَ يُنُبِ رَبَ سْنْن.» 
\s1 عِسَ نَن نَ دُنِحَ نَءِيَلَنيِ رَ 
\p  
\v 12 عِسَ مَن نَشَ وْيّنيِ تٌنفٌ، عَ عَ مَسٍن حَمَ بّ، «ﭑ تَن نَن نَ دُنِحَ نَءِيَلَنيِ رَ. نَشَن نَ بِرَ ﭑ قْشْ رَ، عَ مُ حّرّ مَ دِ مِ كُي مُكُ. كِسِ نَءِيَلَنيِ نَن يَنبَمَ نَ كَنيِ بّ.»  
\v 13 نَ كُي، قَرِ سّنِيٍ نَشَ عَ قَلَ عَ بّ، «عِ نَ عِ يّتّ كَن نَن سٍيدٍ بَقٍ. عِ شَ سٍيدٍحْشْيَ مُ قِندِشِ نْندِ رَ.»  
\v 14 عِسَ نَشَ عٍ يَابِ، «هَلِ ﭑ سٍيدٍ بَ ﭑ يّتّ بّ، ﭑ مَ سٍيدٍحْشْيَ قِندِشِ نْندِ نَن نَ، بَرِ مَ ﭑ عَ كٌلٌن ﭑ كٍلِشِ دّننَشّ، ﭑ مَن عَ كٌلٌن ﭑ سِفَقٍ دّننَشّ. كْنْ وٌ تَن مُ ﭑ كٍلِدٍ كٌلٌن، وٌ مُ ﭑ سِفَدٍ قَن كٌلٌن.  
\v 15 وٌ تَن مِشِ مَكِيتِمَ عَدَ مَ شَشِلِ نَن نَ. ﭑ تَن مُ مِشِ يٌ مَكِيتِمَ.  
\v 16 كْنْ شَ ﭑ سَ مِشِ مَكِيتِمَ، ﭑ مَ كِيتِ قِندِ مَ نْندِ نَن نَ، بَرِ مَ ﭑ كٍرٍن شَ مُ عَ رَ. ﭑ تَن نُن بَبَ عَلَ نَن عَ رَ، عَ تَن نَشَن ﭑ شّيشِ.  
\v 17 عَ سّبّشِ وٌ شَ سّرِيّ كِتَابُي كُي، عَ شَ مِشِ قِرِن شَ سٍيدٍحْشْيَ بَشِ لَن عٍ بٌرٍ مَ، نَ شَ سُشُ نْندِ رَ.  
\v 18 ﭑ تَن نَن نَ ﭑ يّتّ سٍيدٍ رَ. بَبَ عَلَ قَن، عَ تَن نَشَن ﭑ شّيشِ، عَ قَن سٍيدٍحْشْيَ بَمَ ﭑ مَ قٍ رَ.»  
\v 19 عٍ نَشَ عِسَ مَشْرِن، «عِ بَبَ نَ مِندٍن؟» عَ نَشَ عٍ يَابِ، «وٌ مُ ﭑ كٌلٌن، وٌ مُ ﭑ بَبَ قَن كٌلٌن. شَ وٌ ﭑ كٌلٌن نّ نُ، وٌ ﭑ بَبَ قَن كٌلٌنمَ نّ نُ.»  
\v 20 عِسَ يِ مَسٍنيِ تِ هْرْ مْبَنشِ، هَدِيَ سَسٍ يِرٍ نّ، كْنْ مِشِ يٌ مُ عَ سُشُ، بَرِ مَ عَ شَ وَشَتِ مُ نُ عَ لِشِ سِندٍن. 
\s1 عِسَ قِندِشِ عَلَ شَ شّيرَ نَن نَ 
\p  
\v 21 عِسَ مَن نَشَ عَ مَسٍن عٍ بّ، «ﭑ قَمَ نّ سِفَدٍ. وٌ ﭑ قٍنمَ نّ، كْنْ وٌ لْيمَ نّ وٌ شَ يُنُبِيٍ شَ قٍ رَ. ﭑ سِفَمَ دّننَشّ، وٌ تَن مُ نْمَ سِفَدٍ نَا.»  
\v 22 يُوِقِ كُنتِفِيٍ نَشَ عَ قَلَ عٍ بٌرٍ تَفِ، «ثٍ، عَ تٌ عَ قَلَمَ، عَ عَ سِفَمَ دّننَشّ، وٌن تَن مُ نْمَ سِفَدٍ نَا، عَ وَشِ عَ يّتّ نَن قَشَقٍ بَ؟»  
\v 23 عِسَ نَشَ عَ مَسٍن عٍ بّ، «دُنِحَ مِشِيٍ نَن نَ وٌ رَ. كْنْ ﭑ تَن كٍلِشِ كٌورٍ نّ. وٌ شْنيِ قِندِشِ يِ دُنِحَ نَن نَ، كْنْ ﭑ تَن شْنيِ مُ عَ رَ.  
\v 24 ﭑ عَ قَلَشِ وٌ بّ نَ نَن مَ، عَ وٌ لْيمَ نّ وٌ شَ يُنُبِيٍ شَ قٍ رَ. شَ وٌ مُ لَ عَ رَ، عَ ﭑ تَن نَن نَ نَشَن نَ عَبَدَن، وٌ قَشَمَ نّ وٌ شَ يُنُبِيٍ نَ وٌ مَ.»  
\v 25 عٍ نَشَ عَ مَشْرِن، «عِ قِندِشِ ندٍ رَ؟» عِسَ نَشَ عٍ يَابِ، «كَبِ عَ قْلّ، ﭑ نَ قَلَمَ وٌ بّ.  
\v 26 مَرَكْرْ سِ فبٍفبٍ نَن ﭑ يِ رَ وٌ تَن مَبِرِ، نَشَن قِندِ مَ كِيتِ شْرْشْي رَ وٌ بّ. نْندِ قَلّ نَن ﭑ شّيمَ رَ. ﭑ نَشَن مّشِ عَ رَ، ﭑ نَ نَن قَلَمَ دُنِحَ بّ.»  
\v 27 عٍ مُ عَ قَهَامُ عَ عِسَ نُ وْيّنقٍ عٍ بّ بَبَ عَلَ نَن مَ قٍ رَ.  
\v 28 نَ كُي، عِسَ نَشَ عَ مَسٍن عٍ بّ، «وٌ نَ عَدَ مَ شَ دِ رَتٍ وُرِ كْن نَ تّمُي نَشّ، وٌ عَ كٌلٌنمَ نّ، عَ ﭑ تَن نَن نَ نَشَن نَ عَبَدَن، ﭑ مَن مُ قٍقٍ رَبَمَ ﭑ يّتّ رَ، ﭑ مُ قٍقٍ قَلَمَ قٌ ﭑ بَبَ نَ نَشَن مَسٍن ﭑ بّ.  
\v 29 ﭑ تَن نُن ﭑ شّيمَ نَن عَ رَ. عَ مُ ﭑ نَبّحِنشِ، بَرِ مَ ﭑ عَ وَشْنقٍ نَن نَبَمَ تّمُي بِرِن.»  
\v 30 عِسَ تٌ نُ يِ قٍيٍ مَسٍنمَ، مِشِ فبٍفبٍ نَشَ دَنشَنِيَ عَ مَ. 
\s1 عِبُرَهِمَ شَ دِيٍ نُن عِبُلِسَ شَ دِيٍ 
\p  
\v 31 نَ كُي، عِسَ نَشَ عَ مَسٍن يُوِقِيٍ بّ نَشٍيٍ نُ بَرَ دَنشَنِيَ عَ مَ، «شَ وٌ لُ ﭑ شُي رَبَتُ رَ، وٌ قِندِشِ ﭑ قْشِرَبِرّيٍ يَتِ نَن نَ.  
\v 32 وٌ نَ نْندِ كٌلٌن، عَ وٌ شْرّيَمَ نّ.»  
\v 33 عٍ نَشَ عَ يَابِ، «عَننَبِ عِبُرَهِمَ بْنسْي نَن نَ مُشُ رَ. هَن تٌ، مُشُ تَن مُ نُ قِندِ مِشِ يٌ شَ كٌنيِيٍ رَ! مُنقٍ رَ عِ عَ قَلَشِ عَ مُشُ شْرّيَمَ نّ؟»  
\v 34 عِسَ نَشَ عَ قَلَ عٍ بّ، «ﭑ شَ نْندِ قَلَ وٌ بّ، مِشِ نَشَن يُنُبِ رَبَمَ عَ بَرَ لُ يُنُبِ شَ كٌنيِيَ كُي.  
\v 35 مِشِ شَ كٌنيِ مُ لُمَ قْشْي رَ عَبَدَن. كْنْ مِشِ شَ دِ تَن، عَ شْنيِ نَن نَ قْشْي رَ عَبَدَن.  
\v 36 نَ كُي، شَ عَلَ شَ دِ وٌ شْرّيَ، عَ لِمَ وٌ شْرّيَ نَن يَتِ سْتْشِ.» 
\p  
\v 37 «ﭑ عَ كٌلٌن تَن، عَ عِبُرَهِمَ بْنسْي نَن نَ وٌ رَ، كْنْ وٌ كَتَقٍ ﭑ قَشَدٍ نّ وٌ تٌ تٌندِشِ ﭑ مَ مَسٍنيِ رَ.  
\v 38 ﭑ تَن بَرَ نَشَن تٌ بَبَ عَلَ رَ، ﭑ نَ نَن قَلَمَ. وٌ قَن بَرَ نَشَن مّ وٌ بَبَ رَ، وٌ نَ نَن نَبَمَ.»  
\v 39 عٍ نَشَ عَ يَابِ، «عَننَبِ عِبُرَهِمَ نَن نَ مُشُ بَبَ رَ.» عِسَ نَشَ عَ مَسٍن عٍ بّ، «شَ عِبُرَهِمَ شَ دِيٍ نَن يَتِ وٌ رَ نُ، وٌ لُمَ عِبُرَهِمَ قْشِ نَن نَبَ رَ نُ.  
\v 40 كْنْ وٌ تَن نَ كَتَقٍ ﭑ قَشَدٍ، ﭑ تَن نَشَن نْندِ قَلَمَ وٌ بّ ﭑ نَشَن مّشِ عَلَ رَ. عِبُرَهِمَ وَلِ كِ مُ لَنشِ نَ مَ.  
\v 41 وٌ نَ وٌ بَبَ نَن قْشِ رَبَقٍ.» عٍ نَشَ عَ قَلَ عَ بّ، «يّنّ دِيٍ شَ مُ نَ مُشُ تَن نَ دٍ! عَلَ كٍرٍن نَن نَ مُشُ بَبَ رَ.»  
\v 42 عِسَ نَشَ عَ مَسٍن عٍ بّ، «شَ عَلَ نَن وٌ بَبَ رَ نُ، وٌ ﭑ شَنُمَ نّ نُ، بَرِ مَ ﭑ تٌ نَ وٌ يَ مَ بٍ، ﭑ كٍلِشِ عَلَ نَن مَ. ﭑ مُ قَشِ ﭑ يّتّ شَ رَ، عَ تَن نَن ﭑ شّيشِ.  
\v 43 مُنقٍ رَ وٌ مُ ﭑ شُي قَهَامُمَ؟ وٌ مُ نْشِ ﭑ مَ مَسٍنيِ رَ مّدٍ.  
\v 44 وٌ تَن بَبَ قِندِشِ عِبُلِسَ نَن نَ، عَ شْلِ مَن وٌ مَ وٌ شَ عَ تَن نَن سَفٌ رَبَ. كَبِ عَ قْلّ، قَشّتِ نَن عَ رَ. عَ مُ تِنمَ نْندِ رَ، بَرِ مَ نْندِ يٌ مُ نَ عَ شَ قٍ كُي. عَ تٌ وُلٍ قَلَمَ، عَ عَ يّتّ شُي نَن يَتِ قَلَقٍ، بَرِ مَ وُلٍ قَلّ نَن عَ رَ نَشَن قِندِشِ وُلٍ بِرِن بَبَ رَ.  
\v 45 كْنْ ﭑ تَن تٌ نْندِ نَن قَلَمَ، وٌ مُ لَمَ ﭑ نَ.  
\v 46 ندٍ نْمَ ﭑ كَلَمُدٍ يُنُبِ مَ؟ شَ ﭑ نْندِ نَن قَلَمَ، مُنقٍ رَ وٌ مُ لَشِ ﭑ نَ؟  
\v 47 مِشِ نَشَن كٍلِشِ عَلَ مَ، نَ عَلَ شُي مّمَ. نَ كُي، وٌ تَن مُ عَ مّمَ بَرِ مَ وٌ مُ كٍلِشِ عَلَ مَ.» 
\p  
\v 48 يُوِقِ كُنتِفِيٍ نَشَ عَ قَلَ، «نْندِ نَ مُشُ بّ. سَمَرِكَ حِننّ كَنيِ نَن عِ تَن نَ.»  
\v 49 عِسَ نَشَ عٍ يَابِ، «حِننّ مُ ﭑ تَن قْشْ رَ. ﭑ تَن ﭑ بَبَ نَن بِنيَمَ، كْنْ وٌ تَن ﭑ يٍلٍبُمَ.  
\v 50 ﭑ مُ ﭑ يّتّ عِفبٌمَ. عَلَ نَن ﭑ مَ قٍ عِتٍمَ. كِيتِ بِرِن نَ عَ تَن نَن يِ رَ.  
\v 51 ﭑ شَ عَ قَلَ وٌ بّ عَ نْندِ كِ مَ، شَ نَشَن يٌ ﭑ شُي سُشُ، نَ كَنيِ مُ سَيَ كٌلٌنمَ عَبَدَن.» 
\p  
\v 52 يُوِقِيٍ نَشَ عَ قَلَ عَ بّ، «مُشُ بَرَ فّ عَ كٌلٌندٍ قَ عَ حِننّ نَن نَ عِ قْشْ رَ. عِبُرَهِمَ نُن نَمِحْنمّيٍ بِرِن لَاشِرَ نّ، كْنْ عِ تَن نَشّ، ‹شَ نَشَن يٌ ﭑ شُي سُشُ، عَ كَنيِ مُ سَيَ كٌلٌنمَ عَبَدَن.›  
\v 53 ثٍ، مُشُ بٍنبَ عِبُرَهِمَ تٌ قَ لَاشِرَ نّ، عِ تَن دَنفِ عَ رَ؟ نَمِحْنمّيٍ قَن لَاشِرَ نّ. عِ تَن قَ عِ يّتّ قِندِشِ ندٍ رَ؟»  
\v 54 عِسَ نَشَ عٍ يَابِ، «شَ ﭑ تَن نَن ﭑ يّتّ مَتْشْمَ، مَتْشْي قُقَقُ نَن نَ كِ. ﭑ بَبَ نَن ﭑ مَ قٍ عِتٍشِ، وٌ نَشَن مَ، عَ وٌ مَرِفِ عَلَ!  
\v 55 وٌ مُ عَ تَن عَلَ كٌلٌن، كْنْ ﭑ تَن عَ كٌلٌن. شَ ﭑ عَ قَلَ، عَ ﭑ مُ عَ كٌلٌن، ﭑ بَرَ قِندِ وُلٍ قَلّ رَ، عَلْ وٌ تَن. ﭑ تَن عَلَ كٌلٌن، ﭑ مَن عَ شَ مَسٍنيِ رَبَتُمَ.  
\v 56 وٌ بٍنبَ عِبُرَهِمَ سّيوَ نّ ﭑ قَ لْشْي تٌقٍ رَ. عَ عَ تٌ نّ يَتِ، عَ حّلّشِن.»  
\v 57 يُوِقِ كُنتِفِيٍ نَشَ عَ يَابِ، «هَلِ حّ تٌنفٌ سُولِ، عِ مُ نُ عَ سْتْ سِندٍن. مُنسٍ عَ نِيَشِ عِ شَ عَ قَلَ عَ عِ تَن بَرَ عِبُرَهِمَ تٌ؟»  
\v 58 عِسَ نَشَ عَ مَسٍن عٍ بّ، «ﭑ شَ عَ قَلَ وٌ بّ عَ نْندِ كِ مَ، بٍينُن عِبُرَهِمَ شَ بَرِ، ﭑ تَن نَ.»  
\v 59 عٍ نَشَ فّمّيٍ تٌنفٌ كٍرٍن نَ، عٍ شَ عَ مَفْنْ نَ مَسٍنيِ شَ قٍ رَ، كْنْ عِسَ نَشَ عَ نْشُن، عَ مِنِ هْرْ مْبَنشِ كُي. 
\c 9  
\s1 عِسَ دْنشُي يَ رَبْوقٍ 
\p  
\v 1 عِسَ تٌ نُ كِرَ شْن، عَ نَشَ دْنشُي ندٍ تٌ نَشَن بَرِشِ دْنشُيَ كُي.  
\v 2 عَ قْشِرَبِرّيٍ نَشَ عَ مَشْرِن، «كَرَ مْشْ، ندٍ شَ يُنُبِ عَ نِيَشِ يِ شّمّ شَ بَرِ عَ دْنشُشِ، عَ تَن كَ عَ بَرِ مِشِيٍ؟»  
\v 3 عِسَ نَشَ عٍ يَابِ، «عَ شَ يُنُبِ مُ عَ رَ، عَ بَرِ مِشِيٍ قَن فبٍ مُ عَ رَ. عَ رَبَشِ نّ عَلَكٌ عَلَ شَ وَلِ شَ مَكّنّن عَ شَ قٍ كُي.  
\v 4 قَننِ كُيٍ عِبَشِ، قٌ وٌن شَ ﭑ شّيمَ شَ وَلِ رَبَ، بَرِ مَ كْي نَ قَقٍ. عَ نَ سٌ، مِشِ مُ نْمَ وَلِدٍ سْنْن.  
\v 5 ﭑ تٌ نَ دُنِحَ مَ يِ كِ، ﭑ تَن نَن نَ دُنِحَ نَءِيَلَنيِ رَ.» 
\p  
\v 6 عَ نَ قَلَ شَنبِ، عِسَ نَشَ دّيٍ بْشُن بْشِ، عَ بّندّ يٌفٌن عَ رَ. عَ نَشَ نَ مَسٌ دْنشُي يَ مَ،  
\v 7 عَ قَ عَ قَلَ عَ بّ، «سَ عِ يَ رَشَ سِلْمُ يٍ يِرٍ.» نَ سِلْمُ شِلِ نَن قَلَشِ عٍ شَ شُي، «شّيرَ». نَ كُي، دْنشُي نَشَ سَ عَ يَ رَشَ، عَ فبِلٍن، عَ يَ سٍ تٌمَ. 
\p  
\v 8 عَ دْشْبٌورٍيٍ نُن نَشٍيٍ نُ دَرِشِ عَ تٌ رَ كُلّ مَتِدٍ، عٍ نَشَ عَ قَلَ، «يِ شّمّ شَ مُ نُ دْشْمَ بٍ، عَ نُ كُلّ مَتِ؟»  
\v 9 ندٍيٍ نَشّ، «عِيٌ، عَ تَن نَن عَ رَ.» فبّتّيٍ نَشّ، «عَدٍ، عٍ مَنِيَشِ نّ.» كْنْ عَ تَن شّمّ نَشَ وْيّن عٍ بّ، عَ عَ قَلَ، «ﭑ تَن نَن يَتِ عَ رَ!»  
\v 10 نَ كُي، عٍ نَشَ عَ مَشْرِن، «عِ يَ قَ رَبْوشِ دِ؟»  
\v 11 عَ نَشَ عٍ يَابِ، «شّمّ نَشَن شِلِ قَلَمَ عِسَ، نَ نَن بّندّ يٌفٌن دّيٍ رَ، عَ عَ سَ ﭑ يَ مَ، عَ قَ عَ قَلَ ﭑ بّ، ‹سَ عِ يَ رَشَ سِلْمُ يٍ يِرٍ.› نَ كُي، ﭑ تٌ سَ ﭑ يَ رَشَ، ﭑ نَشَ سٍ تٌ.»  
\v 12 عٍ نَشَ قَ عَ مَشْرِن، «يِ شّمّ نَ مِندٍن؟» عَ نَشَ عٍ يَابِ، «ﭑ مُ عَ كٌلٌن.» 
\p  
\v 13 عٍ نَشَ دْنشُي رَيَلَنشِ شَنِن قَرِ سّنِيٍ يِرٍ.  
\v 14 عِسَ دّيٍ مَسُنبُشِ بّندّ رَ لْشْ نَشّ، عَ دْنشُي يَ رَبْو، مَلَبُ لْشْي نَن نُ عَ رَ.  
\v 15 نَ كُي، قَرِ سّنِيٍ قَن نَشَ سٌ عَ مَشْرِنقٍ، عَ يَ رَبْوشِ كِ نَشّ. عَ نَشَ عٍ يَابِ، «عَ بّندّ يٌفٌنشِ نَن سَ ﭑ يَ مَ، ﭑ عٍ رَشَ، عٍ سٍ تٌ.»  
\v 16 قَرِ سّنِ ندٍيٍ نَشَ عَ قَلَ، «يِ شّمّ عِسَ، عَ مُ كٍلِشِ عَلَ شَ مَ، بَرِ مَ عَ مُ مَلَبُ لْشْي سّرِيّ رَبَتُمَ.» كْنْ فبّتّيٍ نُ عَ قَلَمَ، «يُنُبِتْي نْمَ يِ كَابَنَكٌ مْولِيٍ رَبَدٍ؟» نَ كُي، قَرِ سّنِيٍ مُ نُ لَنشِ عٍ بٌرٍ مَ.  
\v 17 عٍ مَن نَشَ دْنشُي رَيَلَنشِ مَشْرِن، «عَ تٌ عِ تَن نَن يَ رَبْوشِ، عِ تَن عَ شَ قٍ تٌشِ دِ؟» عَ نَشَ عٍ يَابِ، «نَمِحْنمّ نَن عَ رَ.» 
\p  
\v 18 يُوِقِ كُنتِفِيٍ نُ سِيكّشِ نَ دْنشُي شَ قٍ رَ. عٍ مُ نُ عَ كٌلٌن شَ دْنشُي يَتِ يَتِ نَن نُ عَ رَ. نَ كُي، عٍ نَشَ عَ بَرِ مِشِيٍ شِلِ،  
\v 19 عٍ عٍ مَشْرِن، «وٌ شَ دِ نَن يَ، وٌ نَشَن مَ عَ عَ دْنشُشِ نَن بَرِشِ؟ عَ يَ قَ رَبْوشِ دِ؟»  
\v 20 عَ بَرِ مِشِيٍ نَشَ عٍ يَابِ، «مُشُ عَ كٌلٌن، عَ مُشُ شَ دِ نَن عَ رَ. مُشُ مَن عَ كٌلٌن، عَ عَ بَرِشِ دْنشُيَ نَن كُي.  
\v 21 كْنْ عَ يَ قَ رَبْوشِ كِ نَشّ، مُشُ مُ نَ تَن كٌلٌن. مُشُ مَن مُ عَ كٌلٌن مِشِ يٌ نَ رَبَشِ عَ بّ. وٌ عَ تَن نَن مَشْرِن. دِ مّدِ شَ مُ عَ رَ، عَ يّتّ عَ شَ دّنتّفّ سَمَ.»  
\v 22 عَ شَ مِشِيٍ نَ يَابِ تِ نّ، بَرِ مَ عٍ نُ فَاشُشِ يُوِقِ كُنتِفِيٍ يَ رَ. نٍيٍ نُ بَرَ لَن عَ مَ عَ مِشِ يٌ نَشَن نَ عَ قَلَ عِسَ عَلَ شَ مِشِ سُفَندِشِ نَن عَ رَ، عٍ شَ تْنيِ دْشْ نَ كَنيِ مَ عَ نَشَ سٌ سَلِدٍ كُي.  
\v 23 نَ نَن عَ نِيَ عَ بَرِ مِشِيٍ نَشَ عَ قَلَ، «دِ مّدِ شَ مُ عَ رَ، وٌ عَ تَن نَن مَشْرِن.» 
\p  
\v 24 نَ كُي، قَرِ سّنِيٍ نَشَ نَ دْنشُي رَيَلَنشِ شِلِ عَ قِرِن ندٍ، عٍ عَ قَلَ عَ بّ، «عِ عِ كَلِ عَلَ رَ، عِ نْندِ قَلَ. مُشُ تَن عَ كٌلٌن عَ يُنُبِتْي نَن نَ نَ شّمّ رَ.»  
\v 25 عَ نَشَ عٍ يَابِ، «شَ يُنُبِتْي نَن عَ رَ، ﭑ تَن مُ عَ كٌلٌن. كْنْ ﭑ قٍ كٍرٍن تَن كٌلٌن؛ ﭑ نُ دْنشُشِ نّ، كْنْ ﭑ يَ بَرَ قَ سٍ تٌ.»  
\v 26 عٍ مَن نَشَ عَ مَشْرِن، «عَ مُنسٍ رَبَ عِ رَ؟ عَ عِ يَ رَبْوشِ دِ؟»  
\v 27 عَ نَشَ عٍ يَابِ، «ﭑ حَن بَرَ نَ قَلَ وٌ بّ، كْنْ وٌ مُ تِن ﭑ شُي رَ مّدٍ. وٌ مَن قَ وَ مَ ﭑ شَ فبِلٍن عَ مَ مُنقٍ رَ؟ كَ وٌ قَن وَشِ قِندِقٍ عَ قْشِرَبِرّيٍ نَن نَ؟»  
\v 28 عٍ نَشَ عَ كٌنبِ، عٍ عَ قَلَ عَ بّ، «عِ تَن نَن قِندِشِ عَ قْشِرَبِرّ رَ! عَننَبِ مُنسَ قْشِرَبِرّيٍ نَن نَ مُشُ تَن نَ!  
\v 29 مُشُ عَ كٌلٌن تَن، عَ عَلَ وْيّن نّ عَننَبِ مُنسَ بّ، كْنْ يِ شّمّ عِسَ تَن، مُشُ مُ عَ كٍلِدٍ كٌلٌن.»  
\v 30 شّمّ نَشَ عٍ يَابِ، «قٍ مَكَابَشِ نَن يَ! عَ بَرَ ﭑ يَ رَبْو، كْنْ وٌ تَن مُ عَ كٍلِدٍ كٌلٌن!  
\v 31 وٌن عَ كٌلٌن تَن، عَ عَلَ مُ يُنُبِتْي شَ دُبَ تٌنفٌمَ. نَشَن فَاشُمَ عَ يَ رَ، عَ عَ سَفٌ رَبَ، عَ نَ نَن شَ مَشَندِ سُشُمَ.  
\v 32 دُنِحَ بِرِن عَ كٌلٌن مِشِ مُ نْمَ دْنشُي يَ رَبْودٍ نَشَن بَرِشِ دْنشُيَ كُي.  
\v 33 شَ يِ شّمّ مُ كٍلِشِ عَلَ شَ مَ نُ، عَ مُ نْمَ قٍقٍ رَبَدٍ.»  
\v 34 عٍ نَشَ عَ يَابِ، «عِ تَن نَشَن بَرِشِ يُنُبِ كُي، عِ وَشِ قِندِقٍ مُشُ كَرَ مْشْ رَ؟» عٍ نَشَ قَ عَ كٍرِ سَلِدٍ. 
\p  
\v 35 عِسَ تٌ عَ مّ، عَ عٍ بَرَ عَ كٍرِ سَلِدٍ، عَ نَشَ سَ عَ قٍن، عَ عَ مَشْرِن، «عِ دَنشَنِيَشِ عَدَ مَ شَ دِ مَ؟»  
\v 36 عَ نَشَ عَ يَابِ، «مَرِفِ، عَ قَلَ ﭑ بّ مِشِ نَشَن عَ رَ، عَلَكٌ ﭑ شَ دَنشَنِيَ عَ مَ.»  
\v 37 عِسَ نَشَ عَ قَلَ عَ بّ، «عِ حَن بَرَ عَ تٌ. عَ تَن نَن مَن وْيّنقٍ عِ بّ يِ كِ.»  
\v 38 عَ نَشَ عَ قَلَ عِسَ بّ، «مَرِفِ، ﭑ بَرَ دَنشَنِيَ.» عَ قَ عَ سُيِدِ عَ بّ.  
\v 39 عِسَ نَشَ عَ مَسٍن، «ﭑ قَشِ يِ دُنِحَ مَ مِشِيٍ مَكِيتِقٍ نَن مَ، عَلَكٌ دْنشُي شَ سٍ تٌ، يَ كَنيِ شَ دْنشُ.»  
\v 40 قَرِ سّنِ نَشٍيٍ نُ نَ نَا، عٍ نَشَ عَ شُي مّ، عٍ عَ مَشْرِن، «ثٍ، دْنشُي نَن نَ مُشُ قَن نَ؟»  
\v 41 عِسَ نَشَ عَ مَسٍن عٍ بّ، «شَ دْنشُي نَن نَ وٌ رَ نُ، يُنُبِ مُ لُمَ وٌ مَ. كْنْ وٌ تٌ عَ قَلَمَ، عَ وٌ يَ قَن، وٌ شَ يُنُبِ بَرَ لُ وٌ مَ.» 
\c 10  
\s1 شُرُ سٍ دّ مَدٌنيِ شَ تَالِيٍ 
\p  
\v 1 «ﭑ شَ نْندِ قَلَ وٌ بّ، مُحّتِ نُن سُوتٍ مُ سٌمَ فْورّ نَادّ رَ. عٍ تُفَنمَ نّ سَنسَنيِ شُن مَ.  
\v 2 نَشَن سٌمَ فْورّ نَادّ رَ، نَ نَن قِندِشِ شُرُ سٍ دّ مَدٌنيِ رَ.  
\v 3 نَادّ كَنتَمَ نَن نَادّ رَبِمَ عَ بّ. عَ نَ وْيّن شُرُ سٍيٍ رَ، عٍ بِرِن بِرَ عَ قْشْ رَ. عَ كَنكَن شِلِ عَ شِلِ رَ، عٍ بِرِن مِنِ تَندٍ.  
\v 4 عَ نَ عَ فبٍ بِرِن نَمِنِ، عَ سَ تِمَ عٍ يَ رَ نّ، عٍ قَن بِرَ عَ قْشْ رَ، بَرِ مَ عٍ عَ شُي كٌلٌن.  
\v 5 شَ مِشِ فبّتّ نَ عَ رَ عٍ مُ نَشَن كٌلٌن، عٍ مُ بِرَ مَ عَ قْشْ رَ مُكُ. عٍ عٍ فِمَ نّ نَ تَن يَ رَ، بَرِ مَ عٍ مُ عَ شُي كٌلٌن.»  
\v 6 عِسَ نَشَ نَ تَالِ وْيّنيِ قَلَ عٍ بّ، كْنْ عٍ مُ عَ شَ مَسٍنيِ قَهَامُ. 
\p  
\v 7 نَ كُي، عِسَ مَن نَشَ عَ مَسٍن، «ﭑ شَ عَ قَلَ وٌ بّ عَ نْندِ كِ مَ، ﭑ تَن نَن نَ يّشّييٍ شَ نَادّ رَ.  
\v 8 نَشٍيٍ سِنفٍ قَ ﭑ بّ، مُحّتِيٍ نُن سُوتٍيٍ نَن نَ عٍ بِرِن نَ. يّشّييٍ مُ عٍ تَن شُي رَ مّ.  
\v 9 ﭑ تَن نَن نَ فْورّ نَادّ رَ. نَشَن يٌ نَ سٌ ﭑ سَابُي رَ، عَ كَنيِ كِسِمَ نّ، عَ نُ سٌ، عَ نُ مِنِ، عَ نُ بَلٌي سْتْ.  
\v 10 مُحّتِ تَن مُ قَمَ قٍقٍ مَ بَقٍ مُحّ تِدٍ، قَشّ تِدٍ، نُن كَسَرّ سَدٍ. ﭑ تَن قَشِ نّ، عَلَكٌ مِشِيٍ شَ كِسِ سْتْ، عٍ شَ دُنِحّءِفِرِ شَ قَن عَ قَنيِ رَ.» 
\p  
\v 11 «ﭑ مِسَالِشِ شُرُ سٍ كَنتَمَ قَنيِ نَن نَ، نَشَن مُ تٌندِ مَ قَشَدٍ عَ شَ شُرُ سٍ كَنتّ كُي.  
\v 12 وَلِكّ نَن عَ فِمَ وُلَ بَرٍ يَ رَ، بَرِ مَ شُرُ سٍيٍ مُ قِندِشِ عَ فبٍ رَ، عَ بْحّ مُ نَ عٍ كَنتَقٍ رَ. عَ شُرُ سٍيٍ رَبّحِنمَ نّ، وُلَ بَرٍ ندٍيٍ قَشَ، عَ ندٍيٍ رَيٍنسٍن يّ.  
\v 13 وَلِكّ مُ عَ حّنفِ سَمَ شُرُ سٍيٍ شَ قٍ شْن.  
\v 14 ﭑ تَن مِسَالِشِ شُرُ سٍ كَنتّ قَنيِ نَن نَ. شُرُ سٍيٍ كَنتّ نُن عَ شَ شُرُ سٍيٍ، عٍ عٍ بٌرٍ كٌلٌن،  
\v 15 عَلْ ﭑ تَن نُن بَبَ عَلَ مُشُ مُشُ بٌرٍ كٌلٌنشِ كِ نَشّ. ﭑ قَن بَرَ تِن قَشَدٍ ﭑ مَ شُرُ سٍيٍ بّ.» 
\p  
\v 16 «يّشّي فبّتّيٍ قَن نَ ﭑ بّ نَشٍيٍ مُ نَ يِ فْورّ كُي. قٌ ﭑ شَ قَ نّ نٍيٍ قَن نَ. عٍ قَن ﭑ شُي رَ مّمَ نّ، يّشّييٍ بِرِن قِندِ فْورّ كٍرٍن نَ، شُرُ سٍ دّ مَدٌنيِ كٍرٍن بّ.  
\v 17 نَ نَن عَ تٌشِ بَبَ عَلَ ﭑ شَنُشِ، بَرِ مَ ﭑ نَن ﭑ نِي قِمَ، عَلَكٌ ﭑ مَن شَ عَ رَ سُشُ.  
\v 18 مِشِ شَ مُ ﭑ تَن نِي بَمَ دٍ، ﭑ تَن يّتّ يَتِ عَ قِمَ. نْي نَ ﭑ بّ، ﭑ شَ ﭑ نِي قِ. نْي مَن نَ ﭑ بّ، ﭑ شَ فبِلٍن عَ رَ سُشُ رَ. ﭑ بَبَ ﭑ يَمَرِشِ نَ نَن نَ.» 
\p  
\v 19 يُوِقِيٍ مَن مُ نُ لَنشِ عٍ بٌرٍ مَ نَ مَسٍنيِ شَ قٍ رَ.  
\v 20 مِشِ فبٍفبٍ نُ عَ قَلَقٍ نّ، «حِننّ نَن نَ يِ قْشْ رَ. عَ بَرَ دَشُ. وٌ وٌ تُلِ مَتِمَ عَ رَ مُنقٍ رَ؟»  
\v 21 كْنْ بٌورٍيٍ نُ عٍ يَابِمَ، «حِننّ نَ مِشِ نَشَن قْشْ رَ، عَ مُ وْيّنمَ يِ مْولِ رَ دٍ! كَ حِننّ نْمَ دْنشُي يَ رَبْودٍ؟» 
\s1 يُوِقِيٍ شَ دَنشَنِيَتَرٍحَ 
\p  
\v 22 شِنبٍلِ تّمُي تٌ نُ عَ رَ، دَرِ سَلَمُكَيٍ نُ نَ هْرْ مْبَنشِ رَبِ سَلِ نَن نَبَقٍ.  
\v 23 عِسَ نُ حّرّقٍ هْرْ مْبَنشِ يِرٍ ندٍ، دّننَشّ شِلِ «مَنفّ سُلٍمَنِ شَ بُنتُنيِ.»  
\v 24 يُوِقِيٍ نَشَ عِسَ رَبِلِن مّننِ، عٍ عَ قَلَ عَ بّ، «عِ سِيكّ بَمَ مُشُ مَ مُن تّمُي؟ شَ عِ تَن نَن قِندِشِ عَلَ شَ مِشِ سُفَندِشِ رَ، عَ قَلَ مُشُ بّ عَ قِيشّ رَ.»  
\v 25 عِسَ نَشَ عٍ يَابِ، «ﭑ حَن بَرَ عَ قَلَ وٌ بّ، كْنْ وٌ مُ لَشِ ﭑ نَ. ﭑ قٍ نَشٍيٍ رَبَمَ ﭑ بَبَ شِلِ رَ، نٍيٍ نَن قِندِشِ سٍيدٍحْشْيَ رَ ﭑ مَ قٍ رَ.  
\v 26 كْنْ وٌ مُ دَنشَنِيَشِ، بَرِ مَ ﭑ مَ يّشّييٍ شَ مُ وٌ رَ.  
\v 27 ﭑ فبٍ يّشّييٍ تَن ﭑ شُي مّمَ، ﭑ عٍ كٌلٌن، عٍ بِرَ مَ ﭑ قْشْ رَ.  
\v 28 ﭑ تَن عَبَدَن كِسِ نَن قِمَ عٍ مَ. عٍ مُ لْيمَ عَبَدَن، سٍسٍ مَن مُ عٍ بَمَ ﭑ يِ رَ.  
\v 29 ﭑ بَبَ، عَ تَن نَشَن عٍ سٌ ﭑ يِ رَ، عَ دَنفِ بِرِن نَ. سٍسٍ مُ نْمَ عٍ بَدٍ عَ تَن بَبَ عَلَ يِ رَ.  
\v 30 ﭑ تَن نُن بَبَ عَلَ، مُشُ بِرِن كٍرٍن.» 
\p  
\v 31 يُوِقِيٍ مَن نَشَ فّمّيٍ تٌنفٌ، عٍ شَ عِسَ مَفْنْ عَ قَشَ شِلِ مَ،  
\v 32 كْنْ عَ نَشَ عَ قَلَ عٍ بّ، «ﭑ بَرَ وَلِ قَنيِ فبٍفبٍ رَبَ وٌ يَ شْرِ، نَشٍيٍ قَتَنشِ بَبَ عَلَ مَ. وٌ عَ قَلَ ﭑ بّ بَ، وٌ قَ وَشِ ﭑ قَشَقٍ ﭑ مَ وَلِ قَنيِ مُندُن مَ؟»  
\v 33 عٍ نَشَ عَ يَابِ، «مُشُ مُ عِ مَفْنْقٍ شّ عِ شَ وَلِ قَنيِ ندٍ شَ مَ. مُشُ عِ مَفْنْمَ عِ تٌ عَلَ رَ سْتْقٍ. عِ تَن عِبُنَدَ مَ وَشِ عِ يّتّ قِندِقٍ عَلَ رَ!»  
\v 34 عِسَ نَشَ عٍ يَابِ، «عَ مُ سّبّشِ شّ وٌ شَ سّرِيّ كِتَابُي كُي، عَ عَلَ عَ مَسٍن نّ، ‹ﭑ تَن عَلَ بَرَ عَ قَلَ، عَلَيٍ نَن وٌ رَ›؟  
\v 35 كِتَابُي شُي تَن مُ كَنَمَ. عَ شَ مَسٍنيِ قَشِ نَشٍيٍ مَ، عَلَ بَرَ عٍ شِلِ قَلَ، ‹عَلَيٍ›.  
\v 36 ﭑ بَرَ عَ قَلَ عَلَ شَ دِ نَن ﭑ نَ، كْنْ عَ مُ لَنمَ وٌ شَ عَ قَلَ ﭑ بَرَ عَلَ رَ سْتْ، بَرِ مَ بَبَ عَلَ ﭑ تَن نَن سُفَندِشِ، عَ ﭑ شّي دُنِحَ مَ.  
\v 37 شَ ﭑ مُ ﭑ بَبَ شَ وَلِيٍ شَ رَبَمَ، وٌ نَشَ لَ ﭑ نَ.  
\v 38 كْنْ شَ ﭑ عَ رَبَ، وٌ شَ لَ نَ وَلِ رَ، هَلِ وٌ مُ لَ ﭑ تَن نَ. وٌ شَ لَ ﭑ مَ وَلِ رَ، عَلَكٌ وٌ شَ عَ كٌلٌن عَ بَبَ عَلَ نَ ﭑ عِ، ﭑ قَن نَ بَبَ عَلَ عِ.»  
\v 39 عِسَ تٌ نَ قَلَ، مِشِيٍ مَن نَشَ كَتَ عَ سُشُدٍ، كْنْ عَ نَشَ مِنِ عٍ بّلّشّ. 
\p  
\v 40 عِسَ نَشَ فبِلٍن يُرُدّن نَاكِرِ مَ، عَ لُ مّننِ، يَيَ مِشِيٍ شُنشَ يٍ شْورَ قْلْ دّننَشّ.  
\v 41 مِشِ فبٍفبٍ نَشَ سِفَ عَ يِرٍ، عٍ نُ عَ قَلَ عٍ بٌرٍ بّ، «عَننَبِ يَيَ تَن مُ تْنشُمَ مَكَابَشِ يٌ رَبَ، كْنْ عَ نَشَن بِرِن مَسٍن يِ شّمّ شَ قٍ رَ، عَ بِرِن قِندِشِ نْندِ نَن نَ.»  
\v 42 مّننِكَ فبٍفبٍ نَشَ دَنشَنِيَ عِسَ مَ. 
\c 11  
\s1 لَسَرُ رَكٍلِقٍ قَشّ مَ 
\p  
\v 1 شّمّ ندٍ نُ قُرَشِ بٍتَنِ نَشَن شِلِ لَسَرُ. عَ مَافِنّيٍ قَن نُ سَبَتِشِ نَا، مَرِيَمَ نُن مَرَتَ.  
\v 2 مَرِيَمَ نَن لَبُندّ تُرٍ سَ مَرِفِ سَنيِيٍ مَ، عَ قَ عٍ مَقُرُكُ عَ شُنسّشّ رَ. عَ تَن نَن مَاشّمّ قِندِ لَسَرُ رَ، نَشَن نُ قُرَشِ.  
\v 3 نَ كُي، لَسَرُ مَافِنّيٍ نَشَ شّيرَ شّي عِسَ مَ، عَ شَ سَ عَ قَلَ عَ بّ، «مَرِفِ، عِ شَنُنتٍنيِ قُرَشِ.»  
\v 4 عِسَ تٌ عَ مّ، عَ نَشَ عَ مَسٍن، «يِ قُرٍ مُ سَ رَحْنمَ قَشّ شَ مَ، عَ قَمَ عَلَ شَ نْرّ نَن مَكّنّندٍ، عَلَكٌ عَلَ شَ دِ قَن شَ مَتْشْي سْتْ عَ سَابُي رَ.» 
\p  
\v 5 عِسَ نُ مَرَتَ نُن مَرِيَمَ نُن عٍ مَاشّمّ لَسَرُ شَنُشِ كِ قَنيِ.  
\v 6 عَ تٌ لَسَرُ قُرَقٍ مّ، عَ مُ سِفَ دّدّ، عَ نَشَ لُ نَا شِ قِرِن مَن.  
\v 7 نَ شَنبِ، عَ نَشَ عَ قَلَ عَ قْشِرَبِرّيٍ بّ، «وٌن شَ فبِلٍن يُدَيَ بْشِ مَ.»  
\v 8 عَ قْشِرَبِرّيٍ نَشَ عَ قَلَ، «كَرَ مْشْ، يُوِقِيٍ كَتَشِ عِ قَشَدٍ دّننَشّ يَ، عِ تَن فبِلٍنقٍ مّننِ نّ؟»  
\v 9 عِسَ نَشَ عٍ يَابِ، «وَشَتِ قُ نُن قِرِن شَ مُ نَ قّيحّن كٍرٍن كُي؟ شَ نَشَن يٌ عَ حّرّ مَ يَنيِ رَ، عَ مُ عَ سَنيِ رَدِنمَ بَرِ مَ يِ دُنِحَ نَءِيَلَنيِ يَنبَمَ عَ بّ.  
\v 10 كْنْ شَ نَشَن يٌ عَ حّرّ مَ كْي رَ، عَ عَ سَنيِ رَدِنمَ نّ، بَرِ مَ نَءِيَلَنيِ يٌ مُ عَ بّ.» 
\p  
\v 11 عَ نَ قَلَ شَنبِ، عِسَ مَن نَشَ عَ مَسٍن، «وٌن شَنُنتٍنيِ لَسَرُ بَرَ شِ، كْنْ ﭑ سِفَقٍ عَ رَشُنُدٍ.»  
\v 12 عَ قْشِرَبِرّيٍ نَشَ عَ قَلَ عَ بّ، «مَرِفِ، شَ عَ نَ شِقٍ، عَ يَلَنمَ نّ.»  
\v 13 عِسَ تٌ لَسَرُ شِقٍ قَلَ، عَ نُ عَ قَشَقٍ نَن مَ، كْنْ عَ قْشِرَبِرّيٍ تَن حْشْ عَ مَ، عَ عَ نُ مَلَبُي شِ شْلِ نَن مَ.  
\v 14 نَ كُي، عِسَ نَشَ وْيّن عٍ بّ عَ قِيشّ رَ، «لَسَرُ بَرَ لَاشِرَ  
\v 15 كْنْ نَ رَبَقٍ ﭑ شَنبِ، عَ بَرَ قِندِ سّيوّ رَ ﭑ بّ، بَرِ مَ عَ شْلِ ﭑ مَ وٌ شَ دَنشَنِيَ سْتْ يِ قٍ كُي. يَكْسِ، وٌن شَ سِفَ عَ يِرٍ.»  
\v 16 نَ تّمُي تٌمَسِ، عَ نُ قَلَمَ نَشَن بّ «فُلِ»، عَ نَشَ عَ قَلَ عِسَ قْشِرَبِرّ بٌورٍيٍ بّ، «وٌن بِرِن شّي، وٌن نُن كَرَ مْشْ بِرِن شَ قَشَ!» 
\p  
\v 17 عِسَ تٌ سٌ نَا، عَ نَشَ عَ لِ لَسَرُ قُرٍ بَرَ شِ نَانِ رَبَ فَبُرِ كُي.  
\v 18 كِلٌ سَشَن حْندْن نَن نُ نَ بٍتَنِ نُن دَرِ سَلَمُ تَفِ. عٍ تٌ مَكْرّ،  
\v 19 يُوِقِ فبٍفبٍ نُ بَرَ قَ مَرَتَ نُن مَرِيَمَ شْنيِ، عٍ مَاشّمّ حْنقٍ كُنقَ بَدٍ.  
\v 20 مَرَتَ تٌ عِسَ قَقٍ مّ، عَ نَشَ سَ عَ رَلَن، كْنْ مَرِيَمَ تَن دْشْشِ نَشَ لُ بَنشِ.  
\v 21 مَرَتَ نَشَ عَ قَلَ عِسَ بّ، «مَرِفِ، شَ عِ نُ نَ بٍ نُ، ﭑ مَاشّمّ مُ قَشَمَ نُ.  
\v 22 كْنْ هَلِ يَكْسِ، ﭑ عَ كٌلٌن عَ عِ نَ قٍقٍ مَشْرِن عَلَ مَ، عَ عَ رَبَمَ نّ عِ بّ.»  
\v 23 عِسَ نَشَ عَ قَلَ عَ بّ، «عِ شُنيَ كٍلِمَ نّ قَشّ مَ.»  
\v 24 مَرَتَ نَشَ عَ يَابِ، «ﭑ عَ كٌلٌن تَن، عَ كٍلِمَ نّ قَشّ مَ دُنِحَ رَحْنيِ، قَشَمِشِيٍ كٍلِمَ تّمُي نَشّ.»  
\v 25 عِسَ نَشَ عَ مَسٍن عَ بّ، «ﭑ تَن نَن نَ مَرَكٍلِ نُن كِسِ رَ. نَشَن نَ دَنشَنِيَ ﭑ مَ، عَ كِسِمَ نّ، هَلِ عَ قَشَ.  
\v 26 نَشَن يٌ بَلٌشِ، عَ دَنشَنِيَشِ ﭑ مَ، نَ كَنيِ مُ لْيمَ عَبَدَن. عِ لَشِ نَ رَ؟»  
\v 27 عَ نَشَ عَ يَابِ، «عِيٌ، مَرِفِ! ﭑ لَشِ عَ رَ عَ عِ تَن نَن نَ عَلَ شَ مِشِ سُفَندِشِ رَ، عَلَ شَ دِ، نَشَن لَن عَ شَ قَ دُنِحَ مَ.» 
\p  
\v 28 مَرَتَ نَ قَلَ شَنبِ، عَ نَشَ سِفَ عَ شُنيَ مَرِيَمَ قْشْ رَ، عَ عَ قَلَ عَ بّ عٍ دٌرٌ مَ، «كَرَ مْشْ بَرَ قَ، عَ نَ عِ شِلِقٍ.»  
\v 29 مَرِيَمَ تٌ عَ مّ، عَ نَشَ كٍلِ كٍرٍن نَ، عَ سِفَ عِسَ رَلَندٍ.  
\v 30 نَ تّمُي، عِسَ مُ نُ سٌشِ تَا كُي. مَرَتَ عَ لِ دّننَشّ، عَ نُ نَ مّننِ نّ سِندٍن.  
\v 31 يُوِقِ نَشٍيٍ قَشِ كُنقَ بَدٍ، نَشٍيٍ نُ نَ مَرِيَمَ قّ مَ بَنشِ كُي، عٍ تٌ عَ تٌ كٍلِ رَ مَقُرٍن نَ، عٍ نَشَ بِرَ عَ قْشْ رَ تَندٍ. عٍ حْشْ عَ مَ عَ عَ نَ سِفَقٍ فَبُرِ يِرٍ نّ، عَ شَ سَ وَ نَا. 
\p  
\v 32 مَرِيَمَ تٌ عِسَ يِرٍ لِ، عَ قّقّ عَ تٌ، عَ نَشَ سُيِدِ عَ بّ، عَ عَ قَلَ، «مَرِفِ، شَ عِ نُ نَ بٍ نُ، ﭑ مَاشّمّ مُ قَشَمَ نُ!»  
\v 33 عِسَ تٌ مَرِيَمَ تٌ، عَ نَ وَقٍ، يُوِقِ نَشٍيٍ نُ نَ عَ قْشْ رَ، نٍيٍ قَن وَقٍ، عَ نَشَ سُننُن، عَ بْحّ نَشَ رَحَاشُ عَ مَ.  
\v 34 عَ نَشَ مَشْرِنيِ تِ، «وٌ عَ رَفَتَشِ مِندٍن؟» عٍ نَشَ عَ يَابِ، «مَرِفِ، قَ، مُشُ شَ نَ مَسٍن عِ بّ.»  
\v 35 عِسَ نَشَ وَ.  
\v 36 نَ كُي، يُوِقِيٍ نَشَ عَ قَلَ، «عَ مَتٌ، لَسَرُ نُ رَقَنشِ عَ مَ كِ نَشّ!»  
\v 37 كْنْ ندٍيٍ عٍ يَ مَ، عٍ نَشَ عَ قَلَ، «ثٍ، يِ نَشَن دْنشُي يَ رَبْو، عَ مُ نُ نْمَ لَسَرُ رَتَنفَدٍ قَشّ مَ شّ؟» 
\p  
\v 38 عِسَ بْحّ مَن نَشَ رَحَاشُ عَ مَ. عَ نَشَ سِفَ فَبُرِ يِرٍ. قْنمّ ندٍ نَن نُ عَ رَ، فّمّ بٍلٍبٍلٍ دْشْشِ نَ دّ رَ.  
\v 39 عِسَ نَشَ عَ قَلَ، «وٌ فّمّ بَ نَا.» مَرَتَ، قَشَمِشِ مَافِنّ، عَ نَشَ عَ قَلَ، «مَرِفِ، عَ شَ مَرَفَتّ شِ نَانِ نَن تٌ! عَ عَ لِمَ عَ قُرٍ شِرِ بَرَ مِنِ يِ وَشَتِ مَ.»  
\v 40 عِسَ نَشَ عَ قَلَ عَ بّ، «ﭑ مُ عَ قَلَ شّ عِ بّ، عَ شَ عِ دَنشَنِيَ، عِ عَلَ سّنبّ مَكَابَشِ تٌمَ نّ؟»  
\v 41 نَ كُي، عٍ نَشَ فّمّ بَ قْنمّ فَبُرِ دّ مَ. عِسَ نَشَ عَ يَ رَتٍ كٌورٍ، عَ عَ قَلَ، «ﭑ بَبَ عَلَ، ﭑ بَرَ عِ تَنتُ عِ تٌ ﭑ شُي رَ مّشِ.  
\v 42 ﭑ تَن حَن عَ كٌلٌن، عِ ﭑ شُي رَ مّمَ تّمُي بِرِن، كْنْ ﭑ نَ قَلَشِ حَمَ نَن مَ قٍ رَ نَشٍيٍ تِشِ بٍ، عٍ شَ لَ عَ رَ عَ عِ تَن نَن ﭑ شّيشِ.»  
\v 43 عَ نَ قَلَ شَنبِ، عِسَ نَشَ عَ شُي عِتٍ سّنبّ رَ، عَ عَ قَلَ، «لَسَرُ، مِنِ!»  
\v 44 عَ تَن قَشَمِشِ نَشَ مِنِ عَ سَنيِيٍ نُن عَ بّلّشّيٍ مَشِرِشِ كَسَنفٍ كُي، عَ يَتَفِ مَن مَكُنقُكُنقُشِ دُفِ فبّتّ قَن نَ. عِسَ نَشَ عَ قَلَ مِشِيٍ بّ، «وٌ كَسَنفٍ بَ عَ مَ، وٌ عَ مَقُلُن، عَ شَ نْ عَ حّرّدٍ.» 
\s1 يُوِقِ كُنتِفِيٍ نَتّ تٌنفٌقٍ عِسَ قَشَقٍ رَ 
\r مَتِيُ ٢٦‏؛١ ٬ ٥، مَرَكِ ١٤‏؛١ ٬ ٢، لُكِ ٢٢‏؛١ 
\p  
\v 45 يُوِقِ نَشٍيٍ نُ بَرَ قَ مَرِيَمَ يِرٍ، عٍ عِسَ شَ كَابَنَكٌ تٌ، عٍ فبٍفبٍ نَشَ دَنشَنِيَ عَ مَ.  
\v 46 كْنْ ندٍيٍ نَشَ سَ دّنتّفّ سَ قَرِ سّنِيٍ بّ، عِسَ قٍ نَشَن نَبَشِ.  
\v 47 نَ كُي، سّرّشّدُبّ كُنتِفِيٍ نُن قَرِ سّنِيٍ نَشَ يُوِقِيٍ شَ كِيتِسَ شُنفبٍيٍ مَلَن. عٍ نَشَ عَ قَلَ، «وٌن مُنسٍ رَبَمَ؟ يِ شّمّ نَ كَابَنَكٌ فبٍفبٍ نَن نَبَقٍ.  
\v 48 شَ وٌن عَ لُ عَ يّتّ يِ، بِرِن دَنشَنِيَمَ نّ عَ مَ، رْ مَكَيٍ قَن قَمَ وٌن مَ هْرْ مْبَنشِ كَنَدٍ، عٍ وٌن سِ سْنتْ!»  
\v 49 عٍ شَ سّرّشّدُبّ كُنتِفِ كَيَقَ، نَشَن نُ نَ عٍ شُنيِ رَ نَ وَشَتِ، عَ نَشَ عَ قَلَ عٍ بّ، «وٌ تَن مُ سٍسٍ كٌلٌن يِ قٍ كُي.  
\v 50 كَ وٌ مُ عَ قَهَامُشِ عَ مِشِ كٍرٍن قَشَقٍ حَمَ بّ، نَ نَن قَن وٌ بّ، دِنّ وٌن سِ بِرِن شَ سْنتْ؟» 
\p  
\v 51 كَيَقَ شَ نَ وْيّنيِ مُ قَتَن عَ تَن يّتّ شَ رَ. عَ تٌ نُ قِندِشِ نَ وَشَتِ سّرّشّدُبّ كُنتِفِيٍ شُنيِ رَ، عَلَ نَن نَ مَسٍنيِ قِ عَ مَ، عَ عِسَ نُ قَقٍ قَشَدٍ عِسِرَيِلَ حَمَ بّ.  
\v 52 كْنْ نَ مَن مُ رَبَ عِسِرَيِلَكَيٍ فبَنسَن شَ بّ. عِسَ نُ قَقٍ قَشَدٍ نّ عَلَكٌ عَلَ شَ عَ شَ دِيٍ قَن مَلَن، نَشٍيٍ رَيٍنسٍنشِ يِرٍ بِرِن، عَ شَ عٍ بِرِن قِندِ حَمَ كٍرٍن نَ. 
\p  
\v 53 نَ كُي، كَبِ نَ مَلَنيِ لْشْي، يُوِقِ كُنتِفِيٍ نَشَ نَتّ تٌنفٌ عِسَ قَشَقٍ رَ.  
\v 54 نَ نَن عَ رَ عِسَ مُ نْ مِنِدٍ كّنّ مَ سْنْن. عَ تَن نُن عَ قْشِرَبِرّيٍ نَشَ كٍلِ نَا، عٍ سِفَ عٍقِرَ مِ تَا كُي فبٍنفبٍرٍنيِ قّ مَ. 
\p  
\v 55 يُوِقِيٍ شَ سَيَمَلٍكّ دَنفِ سَلِ تٌ نُ بَرَ مَكْرّ، مِشِ فبٍفبٍ نَشَ كٍلِ دَاشَيٍ تٍقٍ رَ دَرِ سَلَمُ، عٍ شَ عٍ يّتّ رَ سّنِيّن بٍينُن سَلِ شَ عَ لِ.  
\v 56 عٍ نُ نَ عِسَ قٍنقٍ. عٍ نَشَ عٍ بٌرٍ مَشْرِن هْرْ مْبَنشِ تّتّ كُي، «وٌ شَ مَحْشُنيِ مَ، عِسَ قَمَ سَلِدٍ، كَ عَ مُ قَمَ؟»  
\v 57 سّرّشّدُبّ كُنتِفِيٍ نُن قَرِ سّنِيٍ نُ بَرَ يَامَرِ قِ، عَ مِشِ يٌ نَشَن نَ عِسَ تٌ، نَ كَنيِ شَ عَ قَلَ عٍ بّ عَلَكٌ عٍ شَ عَ سُشُ. 
\c 12  
\s1 مَرِيَمَ لَبُندّ تُرٍ مَسٌقٍ عِسَ سَنيِ مَ 
\p  
\v 1 شِ سٍننِ بٍينُن سَيَمَلٍكّ دَنفِ سَلِ شَ عَ لِ، عِسَ نَشَ سِفَ بٍتَنِ، لَسَرُ شْنيِ، عَ نُ بَرَ نَشَن نَكٍلِ قَشّ مَ.  
\v 2 عٍ نَشَ دٌنسٍ قَنيِ يَءِلَن، عٍ قَ حَمَ شِلِ، عٍ شَ عٍ دّفٍ يِرٍ كٍرٍن عِسَ شَ بِنيّ بُن مَ. مَرَتَ نُ دٌنسٍ عِتَشُنمَ مِشِيٍ مَ، لَسَرُ نُن عِسَ نَشَ لُ تٍيبِلِ رَ. 
\p  
\v 3 مَرِيَمَ نَشَ سَ نَرَدَ لَبُندّ تُرٍ لِتِرِ تَفِ تٌنفٌ. نَرَدَ تِنسٍشِ نَن نُ عَ رَ، نَشَن سَرٍ شْرْشْ كِ قَنيِ. عَ نَشَ عَ مَسٌ عِسَ سَنيِيٍ مَ، عَ عٍ مَقُرُكُ عَ شُنسّشّ رَ. لَبُندّ تُرٍ شِرِ نَشَ دِن بَنشِ بِرِن نَ.  
\v 4 يُدَ سِ عِسِكَرِيٌتِ، عِسَ قْشِرَبِرّ نَشَن نُ قَمَ عَ يَنقَدٍ، عَ نَشَ عَ قَلَ،  
\v 5 «عَ نُ لَنمَ يِ لَبُندّ شَ مَتِ كْبِرِ كٌلٍ كّمّ سَشَن نَ، عَ قِ سٍتَرٍيٍ مَ.»  
\v 6 عَ يِ قَلَ نّ بَرِ مَ عَ تَن نَن نُ عِسَ قْشِرَبِرّيٍ شَ كْبِرِ رَفَتَمَ، عَ نُ قَ ندٍ مُحَ. سٍتَرٍيٍ شَ قٍ مُ نُ نَ عَ بْحّ كُي قٍوٌ!  
\v 7 نَ كُي، عِسَ نَشَ عَ قَلَ، «فبِلٍن مَرِيَمَ قْشْ رَ. يِ نُ رَفَتَشِ عَ يِ رَ نّ، ﭑ مَ مَرَفَتّ نَن مَ قٍ رَ.  
\v 8 سٍتَرٍيٍ لُمَ نّ وٌ يَ مَ تّمُي بِرِن، كْنْ ﭑ تَن مُ لُمَ وٌ يَ مَ عَبَدَن شّ.» 
\p  
\v 9 عٍ تٌ عَ مّ عَ عِسَ بَرَ قَ بٍتَنِ، يُوِقِيٍ حَمَ فبٍفبٍ قَن نَشَ سِفَ. عٍ مُ سِفَ عِسَ شَ قٍ فبَنسَن شَ مَ. عٍ نُ وَ مَ لَسَرُ قَن تٌقٍ، عِسَ نَشَن نَكٍلِ قَشّ مَ.  
\v 10 نَ كُي، سّرّشّدُبّ كُنتِفِيٍ نَشَ نَتّ تٌنفٌ عٍ شَ لَسَرُ قَن قَشَ،  
\v 11 بَرِ مَ يُوِقِ فبٍفبٍ نُ فبِلٍنقٍ عٍ قْشْ رَ عَ تَن نَن مَ قٍ رَ، عٍ نُ قَ دَنشَنِيَ عِسَ مَ. 
\s1 عِسَ سٌقٍ دَرِ سَلَمُ 
\p  
\v 12 نَ كُيٍ عِبَ، حَمَ فبٍفبٍ نَشَن نُ قَشِ سَيَمَلٍكّ دَنفِ سَلِ رَبَدٍ، عٍ نَشَ عَ مّ عَ عِسَ نَ قَقٍ دَرِ سَلَمُ.  
\v 13 عٍ نَشَ تُفِ قّنسّيٍ تٌنفٌ، عٍ سِفَ عَ رَلَندٍ عٍ شُي عِتٍ رَ، 
\q1 «تَنتُي نَ وٌن نَكِسِمَ بّ! 
\q1 بَرَكَ نَ عَ بّ نَشَن قَقٍ مَرِفِ شِلِ رَ، 
\q1 عِسِرَيِلَ مَنفّ!» 
\m  
\v 14 عِسَ نَشَ سٌقَلٍ لَنمَ ندٍ سْتْ، عَ دْشْ عَ قَرِ، عَلْ عَ سّبّشِ كِتَابُي كُي كِ نَشّ، 
\q1  
\v 15 «سِيٌنِكَيٍ، وٌ نَشَ فَاشُ. 
\q1 وٌ شَ مَنفّ نَ قَقٍ، 
\q1 عَ دْشْشِ سٌقَلٍ قَرِ.» 
\m  
\v 16 نَ وَشَتِ عِسَ قْشِرَبِرّيٍ مُ قَهَامُي سْتْ نَ قٍ مَ، كْنْ عِسَ تٌ كٍلِ قَشّ مَ، عٍ نَشَ رَتُ كِتَابُي سّبّلِ مَ نَشَن نُ بَرَ كَمَلِ نَ قٍ كُي. 
\p  
\v 17 حَمَ نَشَن لَسَرُ تٌ كٍلِ رَ قَشّ مَ، عٍ نَشَ سٍيدٍ بَ عِسَ بّ.  
\v 18 نَ نَن عَ نِيَ، حَمَ نَشَ سِفَ عَ رَلَندٍ، بَرِ مَ عٍ نُ بَرَ نَ تْنشُمَ مَكَابَشِ شَ قٍ مّ.  
\v 19 نَ كُي، قَرِ سّنِيٍ نَشَ عَ قَلَ عٍ بٌرٍ بّ، «وٌ بَرَ عَ تٌ، وٌن مُ نْمَ سٍسٍ رَ. دُنِحَ بِرِن بَرَ بِرَ عَ قْشْ رَ!» 
\s1 عِسَ عَ شَ قَشّ شَ قٍ مَسٍنقٍ 
\p  
\v 20 فِرّكِ مِشِ ندٍيٍ قَن نُ بَرَ تٍ سَلِ رَبَدٍ دَرِ سَلَمُ، عٍ شَ سَ عَلَ بَتُ.  
\v 21 عٍ نَشَ قَ قِلِثُ شْن، نَشَن كٍلِ بٍتٍسَيِدَ، فَلِلٍ بْشِ مَ، عٍ عَ قَلَ عَ بّ، «ﭑ بَ، مُشُ وَ مَ عِسَ تٌقٍ.»  
\v 22 قِلِثُ نَشَ سَ عَ قَلَ عَندِرٍ بّ، عٍ قِرِن بِرِن نَشَ سِفَ عٍ سَ عَ قَلَ عِسَ بّ.  
\v 23 عِسَ نَشَ عٍ يَابِ، «وَشَتِ بَرَ عَ لِ عَدَ مَ شَ دِ شَ شُننَكٍلِ شَ مَكّنّن.  
\v 24 ﭑ شَ عَ قَلَ وٌ بّ عَ نْندِ كِ مَ، شَ مَالٍ شْرِ مُ سِ، عَ مُ دِحّ عَ يّتّ مَ بْشِ بُن، عَ لُمَ نَ كِ، عَ كٍرٍن فبَنسَن. كْنْ شَ عَ سَ دِحّ عَ يّتّ مَ بْشِ بُن، عَ عَ بٌفِ فبٍفبٍ نَن نَمِنِمَ.  
\v 25 نَشَن فبَكُمَ عَ يّتّ شَ دُنِحَ قٍ رَ، عَ لْيمَ نّ. نَشَن مُ كَنكَنمَ عَ يّتّ شَ قٍ مَ يِ دُنِحّءِفِرِ كُي، عَ عَبَدَن كِسِ نَن سْتْمَ.  
\v 26 شَ نَشَن يٌ وَ مَ ﭑ مَ وَلِ سُشُقٍ، عَ شَ بِرَ ﭑ قْشْ رَ نّ، ﭑ تَن نَ لُ دّدّ، ﭑ مَ وَلِكّ قَن نَ نَا. شَ نَشَن يٌ ﭑ مَ وَلِ سُشُ، بَبَ عَلَ عَ كَنيِ بِنيَمَ نّ.» 
\p  
\v 27 «ﭑ بْحّ تْورْشِ نّ يِ كِ، كْنْ ﭑ قَ مُنسٍ قَلَمَ؟ ﭑ شَ عَ قَلَ بَبَ عَلَ بّ عَ شَ ﭑ نَتَنفَ يِ حَشَنكَتّ وَشَتِ مَ؟ عَدٍ، يِ حَشَنكَتّ نَشَن قَقٍ ﭑ لِدٍ، ﭑ قَشِ نَ نَن يَتِ مَ.  
\v 28 ﭑ بَبَ عَلَ، عَ نِيَ عِ شِلِ شَ عِتٍ.» عِسَ تٌ نَ قَلَ، شُي ندٍ نَشَ كٍلِ كٌورٍ مَ، عَ عَ قَلَ، «ﭑ بَرَ عَ عِتٍ، ﭑ مَن فبِلٍنمَ نّ عَ عِتٍ رَ.»  
\v 29 حَمَ نَشٍيٍ نُ تِشِ نَا، عٍ تٌ عَ مّ، ندٍيٍ نَشَ عَ قَلَ عَ فَلَنيِ نَن شُي عَ رَ، كْنْ فبّتّ نَشَ عَ قَلَ، «مَلٍكّ نَن وْيّنشِ عَ بّ!»  
\v 30 عِسَ نَشَ عَ مَسٍن عٍ بّ، «نَ شُي مُ مِنِشِ ﭑ تَن ﭑ مَ قٍ شَ مَ، عَ مِنِشِ وٌ تَن نَن مَ قٍ مَ.  
\v 31 يِ دُنِحَ مَكِيتِ وَشَتِ بَرَ عَ لِ. مَنفّيَ قَقٍ بَدٍ يِ دُنِحَ نْلَ يِ رَ.  
\v 32 مِشِيٍ نَ ﭑ نَتٍ وُرِ مَفَلَنبُشِ كْن نَ ﭑ قَشَقٍ رَ، ﭑ مِشِ بِرِن نَقَمَ نّ ﭑ مَ.»  
\v 33 عِسَ عَ قَشَ كِ مَسٍن نَ كِ نّ. 
\p  
\v 34 نَ كُي، حَمَ نَشَ عَ قَلَ عِسَ بّ، «مُشُ تَن بَرَ عَ مّ سّرِيّ كِتَابُي كُي، عَ عَلَ شَ مِشِ سُفَندِشِ بُمَ عَبَدَن. مُنقٍ رَ عِ تَن عَ قَلَمَ عَ قٌ عَدَ مَ شَ دِ شَ رَتٍ؟ ندٍ قِندِشِ يِ عَدَ مَ شَ دِ رَ؟»  
\v 35 عِسَ نَشَ عٍ يَابِ، «عَلَ شَ نَءِيَلَنيِ مَن لُمَ نّ وٌ يَ مَ دٌندٌرٌنتِ. وٌ شَ حّرّ نَ نَءِيَلَنيِ كُي، عَلَكٌ دِ مِ نَشَ وٌ تّرّننَ. نَشَن حّرّ مَ دِ مِ كُي عَ مُ عَ سِفَدٍ تٌمَ.  
\v 36 نَءِيَلَنيِ تٌ يَنبَمَ وٌ بّ يِ كِ، وٌ شَ لَ عَ رَ نّ، عَلَكٌ وٌ شَ قِندِ نَءِيَلَنيِ شَ دِيٍ نَن نَ.» 
\s1 حَمَ دَنشَنِيَتَرٍ 
\p عِسَ تٌ فّ نَ قَلَدٍ، عَ نَشَ سِفَ، عَ سَ عَ نْشُن عٍ مَ.  
\v 37 عَ نُ بَرَ تْنشُمَ مَكَابَشِ فبٍفبٍ رَبَ عٍ يَ شْرِ، كْنْ نَ بِرِن كُي، عٍ مُ دَنشَنِيَ عَ مَ.  
\v 38 نَ رَبَ نّ عَلَكٌ عَننَبِ عٍسَيِ شُي شَ كَمَلِ، عَ تٌ عَ مَسٍن، 
\q1 «مَرِفِ، ندٍ لَشِ مَسٍنيِ رَ، عٍ بَرَ نَشَن مّ مُشُ رَ؟ 
\q1 عَلَ سّنبّ بَرَ مَكّنّن ندٍ بّ؟» 
\m  
\v 39 نَ كُي، عٍ مُ نْ دَنشَنِيَدٍ عِسَ مَ، بَرِ مَ عٍسَيِ عَ مَسٍن نّ، 
\q1  
\v 40 «عَلَ بَرَ عٍ يَ دْنشُ، 
\q1 عَ عٍ شَشِلِ بَلَن، 
\q1 عَلَكٌ عٍ يَ نَشَ قَ سٍ عِفبّ، 
\q1 عٍ شَشِلِ نَشَ قَ قٍ كٌلٌن، 
\q1 عٍ نَشَ قَ عٍ بْحّ رَقِندِ ﭑ مَ، 
\q1 ﭑ شَ عٍ رَيَلَن.» 
\m  
\v 41 عَننَبِ عٍسَيِ نَ قَلَ نّ عَ تٌ نُ بَرَ عِسَ شَ نْرّ تٌ. نَ كُي، عَ نُ عِسَ شَ قٍ نَن قَلَقٍ. 
\p  
\v 42 كْنْ نَ بِرِن كُي، هَلِ كُنتِفِيٍ يَ مَ، عٍ فبٍفبٍ نَشَ لَ عِسَ رَ. كْنْ عٍ مُ نُ سُو سَمَ عَ قَلَدٍ كّنّ مَ بَرِ مَ عٍ نُ فَاشُشِ قَرِ سّنِيٍ يَ رَ، نٍيٍ نَشَ قَ تْنيِ دْشْ عٍ مَ، سٌقٍ رَ سَلِدٍ كُي.  
\v 43 عَدَ مَدِيٍ شَ مَتْشْي سْتْقٍ نَن نُ رَقَن عٍ مَ دَنفِ عَلَ شَ مَتْشْي رَ. 
\s1 عِسَ شَ مَسٍنيِ دْنشْي حَمَ بّ 
\p  
\v 44 عِسَ نَشَ عَ شُي عِتٍ، عَ عَ قَلَ، «نَشَن نَ دَنشَنِيَ ﭑ مَ، عَ مُ دَنشَنِيَشِ ﭑ تَن شَ مَ، عَ دَنشَنِيَشِ ﭑ شّيمَ نَن مَ.  
\v 45 نَشَن نَ ﭑ تَن تٌ، عَ بَرَ ﭑ شّيمَ تٌ.  
\v 46 ﭑ تٌ قَشِ دُنِحَ، نَءِيَلَنيِ نَن ﭑ نَ، عَلَكٌ نَشَن يٌ نَ دَنشَنِيَ ﭑ مَ، نَ كَنيِ نَشَ لُ دِ مِ كُي سْنْن.  
\v 47 شَ نَشَن يٌ ﭑ شُي مّ، كْنْ عَ مُ عَ رَبَتُ، ﭑ تَن مُ نَ كَنيِ مَكِيتِمَ، بَرِ مَ ﭑ مُ قَشِ دُنِحَ مَكِيتِدٍ شّ. ﭑ قَشِ دُنِحَ رَكِسِدٍ نّ.  
\v 48 نَشَن نَ تٌندِ ﭑ نَ، عَ مُ تِن ﭑ مَ مَسٍنيِ رَ، نَ كَنيِ مَكِيتِمَ نَ نَ. ﭑ مَسٍنيِ نَشَن تِمَ، نَ نَن قِندِ مَ عَ مَكِيتِمَ رَ لْشْ دْنشْي.  
\v 49 بَرِ مَ ﭑ مَ مَسٍنيِ مُ قَتَنشِ ﭑ تَن شَ رَ. عَ قَتَنشِ بَبَ عَلَ نَن نَ، نَشَن ﭑ شّيشِ يَامَرِ رَ، عَ لَنمَ ﭑ شَ نَشَن قَلَ، ﭑ شَ نَشَن مَسٍن.  
\v 50 ﭑ عَ كٌلٌن عَ شَ سّرِيّ قِندِ مَ كِسِ نَن نَ، نَشَن مُ حْنمَ عَبَدَن. نَ نَن عَ رَ، ﭑ قٍ مَسٍنمَ وٌ بّ عَلْ بَبَ عَلَ عَ مَسٍنشِ كِ نَشّ.» 
\c 13  
\s1 عِسَ عَ قْشِرَبِرّيٍ سَنيِ مَشَقٍ 
\p  
\v 1 بٍينُن سَيَمَلٍكّ دَنفِ سَلِ شَ عَ لِ، عِسَ نَشَ عَ كٌلٌن عَ فبٍ مُ نُ لُشِ عَ شَ كٍلِ دُنِحَ مَ فبِلٍنقٍ رَ بَبَ عَلَ مَ. عَ قْشِرَبِرّيٍ عَ نَشٍيٍ سْتْ دُنِحَ مَ، نٍيٍ نُ رَقَن عَ مَ. هَن عَ قَشَ تّمُي نَشّ، عٍ شَ شَنُنتٍيَ نُ نَ عَ بّ. 
\p  
\v 2 نُنمَرٍ، عٍ بِرِن نُ عٍ دّفٍقٍ. عِبُلِسَ حَن نُ بَرَ سٌ سِمْن عِسِكَرِيٌتِ شَ دِ يُدَ سِ شَشِلِ كُي، عَ شَ عِسَ يَنقَ.  
\v 3 عِسَ تٌ نُ عَ كٌلٌن عَ بَبَ عَلَ بَرَ قٍ بِرِن سَ عَ سَفٌي، عَ مَن تٌ عَ كٌلٌن عَ عَ كٍلِشِ عَلَ نَن مَ، عَ مَن فبِلٍنقٍ عَ تَن نَن مَ،  
\v 4 عَ نَشَ كٍلِ عٍ دّفٍدٍ، عَ عَ شَ دٌنمَ قَرِ عِفٌرٌي بَ عَ مَ، عَ قَ دُفِ ندٍ شِرِ عَ تَفِ.  
\v 5 عَ نَشَ يٍ سَ ثَانِ كُي، عَ قَ سٌ عَ قْشِرَبِرّيٍ سَنيِيٍ مَشَقٍ، عَ نُ عٍ مَقُرُكُ نَ دُفِ رَ.  
\v 6 عَ تٌ سِمْن ثِيّرِ لِ، نَ نَشَ عَ قَلَ عَ بّ، «مَرِفِ، عِ وَشِ نّ عِ شَ ﭑ تَن سَنيِيٍ مَشَ؟»  
\v 7 عِسَ نَشَ عَ يَابِ، «ﭑ نَشَن نَبَقٍ يِ كِ، عِ مُ عَ قَهَامُمَ يِ وَشَتِ تَن مَ، كْنْ عِ قَمَ نّ عَ كُي كٌلٌندٍ يَرٍ.»  
\v 8 ثِيّرِ نَشَ عَ قَلَ عَ بّ، «عَدٍ، عِ تَن مُ ﭑ سَنيِ مَشَمَ قٍوٌ!» عِسَ نَشَ عَ يَابِ، «شَ ﭑ مُ عِ سَنيِيٍ مَشَ، وٌن مُ لُمَ قٍ كٍرٍن سْنْن.»  
\v 9 سِمْن ثِيّرِ نَشَ عَ قَلَ عَ بّ، «ﭑ مَرِفِ، شَ عَ نَ نَ كِ نّ، عِ نَشَ ﭑ سَنيِ فبَنسَن شَ مَشَ. عِ شَ ﭑ بّلّشّيٍ نُن ﭑ شُنيِ بِرِن مَشَ.»  
\v 10 عِسَ نَشَ عَ يَابِ، «مِشِ نَشَن بَرَ عَ مَشَ، عَ هَيِ مُ نَ عَ قَتٍ مَشَقٍ مَ بَقٍ عَ سَنيِ رَ. عَ حَن بَرَ سّنِيّن قٍوٌ! وٌ سّنِيّنشِ، كْنْ وٌ بِرِن مُ عَ رَ.»  
\v 11 عَ عَ قَلَ نّ عَ عٍ بِرِن مُ سّنِيّنشِ، بَرِ مَ عَ عَ قْشِرَبِرّ كٌلٌن نَشَن قَمَ عَ يَنقَدٍ. 
\p  
\v 12 عِسَ تٌ فّ عٍ سَنيِيٍ مَشَدٍ، عَ مَن نَشَ عَ شَ دٌنمَ قَرِ عِفٌرٌي رَفٌرٌ عَ مَ، عَ مَن عَ مَفٌرٌ عٍ دّفٍدٍ، عَ عَ قَلَ عٍ بّ، «ﭑ نَشَن نَبَشِ وٌ بّ يِ كِ، وٌ عَ قَهَامُشِ؟  
\v 13 وٌ تٌ عَ قَلَمَ ﭑ بّ ‹كَرَ مْشْ›، شَ نَ مُ عَ رَ ‹مَرِفِ›، وٌ نْندِ نَن عَ رَ، بَرِ مَ نَ نَن يَتِ ﭑ نَ.  
\v 14 نَ كُي، ﭑ تَن نَشَن قِندِشِ وٌ مَرِفِ نُن وٌ كَرَ مْشْ رَ، شَ ﭑ تَن بَرَ وٌ سَنيِيٍ مَشَ، وٌ قَن لَن نّ وٌ شَ وٌ بٌرٍ سَنيِيٍ مَشَ.  
\v 15 ﭑ نَشَن نَبَشِ وٌ بّ، عَ شَ قِندِ مِسَالِ نَن نَ، عَلَكٌ وٌ قَن شَ نَ مْولِ نَن نَبَ وٌ بٌرٍ تَفِ.  
\v 16 ﭑ شَ عَ قَلَ وٌ بّ عَ نْندِ كِ مَ، كٌنيِ مُ دَنفِ عَ مَرِفِ رَ، شّيرَ قَن مُ دَنفِ عَ شّيمَ رَ.  
\v 17 وٌ تٌ بَرَ قَهَامُي سْتْ يِ قٍيٍ مَ، هّيرِ نَ وٌ بّ شَ وٌ عٍ رَبَ.» 
\p  
\v 18 «ﭑ مُ وٌ بِرِن شَ مَ. ﭑ تَن نَشَن وٌ سُفَندِشِ، ﭑ وٌ كٌلٌن. كْنْ نَشَن نَ كِتَابُي كُي، قٌ عَ شَ كَمَلِ نّ، عَ تٌ سّبّشِ، ‹مُشُ نُن نَشَن بّلّشّ نَ لٍنفٍ كٍرٍن كُي، نَ بَرَ عَ كٌبٍ سٌ ﭑ نَ.›  
\v 19 ﭑ نَ قٍ قَلَشِ نّ وٌ بّ بٍينُن عَ شَ رَبَ، عَلَكٌ عَ رَبَ تّمُي وٌ شَ عَ كٌلٌن عَ ﭑ تَن نَن نَ نَشَن نَ عَبَدَن.  
\v 20 ﭑ شَ عَ قَلَ وٌ بّ عَ نْندِ كِ مَ، نَشَن يٌ نَ ﭑ مَ شّيرَ رَ سّنّ، عَ ﭑ تَن نَن نَسّنّشِ. نَشَن يٌ نَ ﭑ قَن نَسّنّ، نَ كَنيِ ﭑ شّيمَ نَن نَسّنّشِ.» 
\s1 يُدَ سِ شَ يَنقَنتٍيَ 
\r مَتِيُ ٢٦‏؛٢٠ ٬ ٢٥، مَرَكِ ١٤‏؛١٧ ٬ ٢١، لُكِ ٢٢‏؛٢١ ٬ ٢٣ 
\p  
\v 21 عَ نَ قَلَ شَنبِ، عِسَ بْحّ نَشَ سُننُن، عَ قَ عَ قَلَ، «ﭑ شَ عَ قَلَ وٌ بّ عَ نْندِ كِ مَ، مِشِ كٍرٍن نَ وٌ يَ مَ، عَ ﭑ يَنقَمَ نّ، عَ ﭑ سَ كُنتِفِيٍ بّلّشّ.»  
\v 22 عَ قْشِرَبِرّيٍ نَشَ عٍ بٌرٍ مَتٌ، عٍ مُ عَ كٌلٌن عِسَ نُ مِشِ يٌ شَ قٍ قَلَقٍ.  
\v 23 عِسَ قْشِرَبِرّ، عَ نَشَن شَنُشِ، عَ نُ نَ عَ قّ مَ تٍيبِلِ رَ.  
\v 24 نَ كُي، سِمْن ثِيّرِ نَشَ عَ بّلّشّ مَفِرَ نَ بّ، عَ شَ عِسَ مَشْرِن عَ كَنيِ مَ، عِسَ نُ بَشِ نَشَن مَ قٍ قَلَدٍ.  
\v 25 نَ قْشِرَبِرّ نَشَ عَ مَسٌ عِسَ رَ، عَ عَ مَشْرِن، «مَرِفِ، ندٍ عَ رَ؟»  
\v 26 عِسَ نَشَ عَ يَابِ، «ﭑ نُ تَامِ رَفٌرٌ بْرّ شْورَ، ﭑ عَ سٌ مِشِ نَشَن يِ رَ، عَ تَن نَن نَ كِ.» عِسَ تٌ فّ نَ قَلَدٍ، عَ نَشَ تَامِ رَ سِن بْرّ شْورَ، عَ عَ سٌ سِمْن عِسِكَرِيٌتِ شَ دِ يُدَ سِ يِ رَ.  
\v 27 يُدَ سِ تٌ نَ تَامِ رَ سُشُ، سٍنتَنّ نَشَ عَ بْحّ مَسَرَ كٍرٍن نَ. عِسَ نَشَ عَ قَلَ عَ بّ، «عِ وَ مَ نَشَن نَبَقٍ، عَ رَبَ مَقُرٍن مَقُرٍن.»  
\v 28 نَشٍيٍ نُ مَفٌرٌشِ عٍ دّفٍدٍ، عٍ سٍسٍ مُ عَ كٌلٌن عِسَ نَ قَلَقٍ عَ بّ قٍ نَشَن مَ.  
\v 29 يُدَ سِ تٌ قِندِ عٍ شَ كْبِرِ رَفَتّ رَ، ندٍيٍ نَشَ عَ مَحْشُن عَ عِسَ نُ عَ شّيقٍ سَرٍ ندٍ سٌدٍ سَلِ شَ قٍ رَ، شَ نَ مُ عَ رَ عَ شَ سَ مِسِكِينّيٍ كِ.  
\v 30 يُدَ سِ تٌ نَ تَامِ شُنتُنيِ رَ سُشُ، عَ نَشَ مِنِ كٍرٍن نَ. كْي نُ بَرَ سٌ. 
\s1 يَامَرِ نّينّ 
\p  
\v 31 يُدَ سِ تٌ مِنِ، عِسَ نَشَ عَ مَسٍن، «وَشَتِ بَرَ عَ لِ قَ، عَدَ مَ شَ دِ شَ شُننَكٍلِ شَ مَكّنّن، عَلَ قَن شَ نْرّ شَ مَكّنّن عَ سَابُي رَ.  
\v 32 عَلَ شَ نْرّ تٌ مَكّنّنمَ عَ سَابُي رَ، عَلَ يّتّ قَن عَدَ مَ شَ دِ شَ شُننَكٍلِ مَكّنّنمَ نّ. عَ قَقٍ نَ نَن نَبَدٍ يَكْسِ.  
\v 33 ﭑ مَ دِيٍ، عَ فبٍ مُ لُشِ ﭑ شَ كٍلِ وٌ شُن مَ. وٌ ﭑ قٍنمَ نّ، كْنْ ﭑ نَشَن قَلَ يُوِقِ كُنتِفِيٍ بّ، ﭑ قَ نَ نَن قَلَمَ وٌ قَن بّ، ‹ﭑ سِفَمَ دّننَشّ، وٌ تَن مُ نْمَ سِفَدٍ نَا.›» 
\p  
\v 34 «ﭑ شَ يَامَرِ نّينّ قِ وٌ مَ؛ وٌ شَ وٌ بٌرٍ شَنُ نّ. ﭑ تَن وٌ شَنُشِ كِ نَشّ، وٌ قَن شَ وٌ بٌرٍ شَنُ نَ كِ.  
\v 35 دُنِحَ بِرِن وٌ كٌلٌنمَ ﭑ قْشِرَبِرّيٍ رَ نَ قٍ نَن مَ، شَ وٌ وٌ بٌرٍ شَنُ.» 
\s1 عِسَ عَ قَلَقٍ ثِيّرِ بّ عَ عَ يّتّ رَ سَنمَ نّ عَ مَ 
\r مَتِيُ ٢٦‏؛٣١ ٬ ٣٥، مَرَكِ ١٤‏؛٢٧ ٬ ٣١، لُكِ ٢٢‏؛٣١ ٬ ٣٤ 
\p  
\v 36 سِمْن ثِيّرِ نَشَ عَ مَشْرِن، «مَرِفِ، عِ سِفَمَ مِندٍن؟» عِسَ نَشَ عَ يَابِ، «ﭑ سِفَقٍ دّننَشّ، عِ مُ نْمَ بِرَدٍ ﭑ قْشْ رَ سِندٍن، كْنْ عِ قَن قَمَ بِرَدٍ ﭑ قْشْ رَ هَن نَا.»  
\v 37 سِمْن ثِيّرِ مَن نَشَ عَ مَشْرِن، «مَرِفِ، مُنقٍ رَ ﭑ مُ نْمَ بِرَدٍ عِ قْشْ رَ يَكْسِ؟ ﭑ تِنشِ ﭑ شَ قَشَ عِ شَ قٍ رَ!»  
\v 38 عِسَ نَشَ عَ يَابِ، «عِ تِنشِ عِ شَ قَشَ ﭑ مَ قٍ رَ؟ ﭑ شَ نْندِ يَتِ نَن قَلَ عِ بّ، بٍينُن كٌنكٌرٍ شَ عَ رَتٍ، عِ عِ يّتّ رَ سَنمَ نّ ﭑ مَ سَنمَيَ سَشَن.» 
\c 14  
\s1 عِسَ نَن نَ كِرَ، نْندِ، نُن كِسِ رَ 
\p  
\v 1 عِسَ نَشَ عَ قَلَ عَ قْشِرَبِرّيٍ بّ، «وٌ نَشَ كْنتْقِلِ. وٌ وٌ شَشِلِ تِ عَلَ رَ، وٌ شَ وٌ شَشِلِ تِ ﭑ قَن نَ.  
\v 2 لِنفِرَ فبٍفبٍ نَن نَ ﭑ بَبَ شْنيِ، شَ نَ مُ عَ رَ ﭑ مُ عَ قَلَمَ وٌ بّ نُ، عَ ﭑ سِفَقٍ يِفِيَ يَءِلَندٍ وٌ بّ.  
\v 3 شَ ﭑ سِفَ، ﭑ نَشَ سَ نَ يَءِلَن وٌ بّ، ﭑ مَن قَمَ نّ وٌ قْشْ رَ، عَلَكٌ وٌن بِرِن شَ سَ لُ يِرٍ كٍرٍن.  
\v 4 ﭑ سِفَقٍ دّننَشّ، وٌ نَ كِرَ كٌلٌن.» 
\p  
\v 5 تٌمَسِ نَشَ عَ قَلَ عَ بّ، «مَرِفِ، مُشُ مُ عِ سِفَدٍ كٌلٌن. مُشُ قَ نَ كِرَ كٌلٌنمَ دِ؟»  
\v 6 عِسَ نَشَ عَ يَابِ، «ﭑ تَن نَن نَ كِرَ رَ، نْندِ رَ، نُن كِسِ رَ. مِشِ يٌ مُ سٌمَ بَبَ عَلَ شْنيِ شَ ﭑ تَن سَابُي شَ مُ عَ رَ.  
\v 7 شَ وٌ بَرَ ﭑ تَن كٌلٌن، وٌ ﭑ بَبَ قَن كٌلٌنمَ نّ. كٍلِ يِ وَشَتِ مَ، وٌ بَرَ عَ كٌلٌن، وٌ مَن بَرَ عَ تٌ.» 
\p  
\v 8 قِلِثُ نَشَ عَ قَلَ عَ بّ، «مَرِفِ، بَبَ عَلَ مَسٍن مُشُ بّ. عَ لِمَ نَ بَرَ مُشُ وَ سَ.»  
\v 9 عِسَ نَشَ عَ قَلَ عَ بّ، «قِلِثُ، ﭑ بَرَ بُ وٌ تَفِ كِ قَنيِ، كْنْ هَن يَ عِ مُ ﭑ كٌلٌن؟ نَشَن نَ ﭑ تَن تٌ، عَ بَرَ بَبَ عَلَ تٌ. عِ تَن قَ عَ قَلَمَ دِ، عَ ﭑ شَ بَبَ عَلَ مَسٍن وٌ بّ؟  
\v 10 عِ مُ لَشِ عَ رَ عَ بَبَ عَلَ نُن ﭑ تَن نَن عَ رَ، ﭑ قَن نُن بَبَ عَلَ نَن عَ رَ؟ ﭑ تَن مَسٍنيِ نَشٍيٍ تِمَ وٌ بّ، عٍ مُ قَتَن ﭑ تَن يّتّ شَ رَ. عٍ قَتَنمَ بَبَ عَلَ نَن نَ. ﭑ تَن نُن بَبَ عَلَ نَشَن عَ رَ تّمُي بِرِن، عَ تَن نَن يّتّ نَ عَ شَ وَلِ رَبَقٍ.  
\v 11 وٌ شَ لَ ﭑ نَ، عَ بَبَ عَلَ نُن ﭑ تَن نَن عَ رَ، ﭑ قَن نُن بَبَ عَلَ نَن عَ رَ. شَ وٌ سِيكّشِ نَ مَ، وٌ شَ لَ عَ رَ ﭑ مَ وَلِيٍ تَن شَ قٍ رَ.» 
\p  
\v 12 «ﭑ شَ عَ قَلَ وٌ بّ عَ نْندِ كِ مَ، ﭑ تَن وَلِ نَشٍيٍ رَبَمَ، شَ نَشَن دَنشَنِيَ ﭑ مَ، نَ كَنيِ قَن نَ وَلِ مْولِيٍ رَبَمَ نّ. عَ حَن عَ رَبَمَ نّ نَشٍيٍ دَنفِ ﭑ تَن فبٍ رَ، بَرِ مَ ﭑ تَن سِفَقٍ بَبَ عَلَ نَن يِرٍ.  
\v 13 وٌ نَشَن بِرِن مَشَندِ مَ ﭑ شِلِ رَ، ﭑ عَ رَبَمَ نّ وٌ بّ عَلَكٌ بَبَ عَلَ شَ مَتْشْي سْتْ عَ شَ دِ سَابُي رَ.  
\v 14 شَ وٌ ﭑ مَشَندِ قٍقٍ نَشَن مَ ﭑ شِلِ رَ، ﭑ عَ رَبَمَ نّ.» 
\s1 عَلَ شَشِلِ سّنِيّنشِ 
\p  
\v 15 «شَ وٌ ﭑ شَنُ، وٌ ﭑ مَ يَامَرِيٍ رَبَتُمَ نّ.  
\v 16 ﭑ تَن قَن، ﭑ بَبَ عَلَ مَشَندِ مَ نّ عَ شَ سَابُي قَنيِ فبّتّ شّي وٌ مَ، نَشَن لُمَ وٌ قّ مَ عَبَدَن.  
\v 17 نَ نَن قِندِشِ عَلَ شَشِلِ رَ، نَشَن نْندِ مَكّنّنمَ. دُنِحَ تَن مُ نْمَ عَ سْتْدٍ، بَرِ مَ عٍ مُ عَ تٌمَ، عٍ مَن مُ عَ كٌلٌن. كْنْ وٌ تَن عَ كٌلٌن، بَرِ مَ عَ سَبَتِمَ وٌ عِ.» 
\p  
\v 18 «ﭑ مُ وٌ رَبٌلٌمَ شّ دٍ، وٌ شَ لُ عَلْ كِرِدِيٍ. ﭑ مَن قَمَ نّ وٌ يِرٍ.  
\v 19 عَ فبٍ مُ لُشِ ﭑ شَ لْي دُنِحَ مَ، كْنْ وٌ تَن قَمَ نّ ﭑ تٌدٍ. ﭑ تَن تٌ بَلٌشِ، وٌ قَن بَلٌمَ نّ.  
\v 20 وٌ عَ كٌلٌنمَ نّ نَ لْشْي، عَ ﭑ تَن نُن ﭑ بَبَ نَن عَ رَ، وٌ قَن نُن ﭑ تَن نَن عَ رَ، ﭑ قَن نُن وٌ تَن نَن عَ رَ.  
\v 21 نَشَن ﭑ مَ يَامَرِيٍ سُشُشِ، عَ عٍ رَبَتُ، نَ كَنيِ نَن ﭑ شَنُشِ. عَنُن، نَشَن نَ ﭑ تَن شَنُشِ، ﭑ بَبَ عَ كَنيِ شَنُمَ نّ، ﭑ قَن عَ شَنُ، ﭑ نَن ﭑ يّتّ مَكّنّن عَ بّ.» 
\p  
\v 22 يُدَ سِ، نَشَن مُ قِندِ عِسِكَرِيٌتِ رَ، عَ نَشَ عِسَ مَشْرِن، «مَرِفِ، مُنقٍ رَبَشِ عِ تٌ قَقٍ عِ يّتّ مَكّنّندٍ مُشُ تَن بّ، عِ مُ عِ يّتّ مَكّنّن دُنِحَ تَن بّ؟»  
\v 23 عِسَ نَشَ عَ يَابِ، «شَ نَشَن يٌ ﭑ شَنُ، عَ ﭑ شُي سُشُمَ نّ. ﭑ بَبَ عَ كَنيِ شَنُمَ نّ، مُشُ نُن ﭑ بَبَ قَ عَ يِرٍ، مُشُ سَبَتِ عَ عِ.  
\v 24 نَشَن مُ ﭑ شَنُشِ، عَ مُ ﭑ شُي سُشُمَ. وٌ مَسٍنيِ نَشَن مّقٍ ﭑ نَ، ﭑ فبٍ شَ مُ عَ رَ. عَ قَتَنشِ بَبَ عَلَ نَن نَ، نَشَن ﭑ شّيشِ.» 
\p  
\v 25 «ﭑ تٌ وٌ يَ مَ، ﭑ بَرَ نَ بِرِن مَسٍن وٌ بّ،  
\v 26 كْنْ بَبَ عَلَ قَمَ نّ سَابُي قَنيِ شّيدٍ وٌ يِرٍ ﭑ شِلِ رَ. نَ سَابُي لَنشِ عَلَ شَشِلِ سّنِيّنشِ نَن مَ. نَ نَن قَمَ وٌ رَتُدٍ ﭑ مَ مَسٍنيِ بِرِن نَ، عَ قَ وٌ شَرَن نَ رَ.» 
\p  
\v 27 «ﭑ بْحّسَ قِمَ وٌ مَ نَشَن قَتَنشِ ﭑ تَن نَ، نَشَن مُ كٍلِشِ دُنِحَ مَ. وٌ نَشَ كْنتْقِلِ، وٌ نَشَ فَاشُ.  
\v 28 وٌ بَرَ ﭑ شُي مّ، ‹ﭑ نَ سِفَقٍ، كْنْ ﭑ مَن قَمَ وٌ يِرٍ›. شَ وٌ ﭑ شَنُ، عَ لَنمَ وٌ شَ سّيوَ ﭑ مَ سِفّ رَ بَبَ عَلَ يِرٍ، بَرِ مَ عَ دَنفِ ﭑ تَن نَ.  
\v 29 ﭑ عَ قَلَشِ نّ وٌ بّ، بٍينُن عَ شَ رَبَ، عَلَكٌ عَ نَ رَبَ، وٌ شَ دَنشَنِيَ ﭑ مَ.» 
\p  
\v 30 «ﭑ مُ وْيّن فبٍفبٍ قَلَمَ وٌ بّ سْنْن، بَرِ مَ يِ دُنِحَ نَ نْلَ نَشَن يِ، عَ نَ قَقٍ. عَ مُ نْمَ ﭑ تَن نَ عَ مْولِ يٌ رَ،  
\v 31 كْنْ عَلَكٌ دُنِحَ شَ عَ كٌلٌن عَ ﭑ تَن بَبَ عَلَ شَنُشِ نّ، بَبَ عَلَ ﭑ يَمَرِشِ نَشَن نَ، ﭑ عَ رَبَمَ نّ. وٌ كٍلِ، وٌن شّي.» 
\c 15  
\s1 سَنسِ بِلِ نُن عَ سَلٌنيِيٍ 
\p  
\v 1 «ﭑ مِسَالِشِ وُرِ بِلِ نَن نَ، ﭑ بَبَ عَلَ نَن قِندِشِ عَ مّينِمَ رَ.  
\v 2 وُرِ بِلِ سَلٌنيِ نَشٍيٍ مُ بٌفِ رَ مِنِمَ ﭑ بّ، عَلَ عٍ سّفّمَ نّ. سَلٌنيِ نَشٍيٍ بٌفِمَ، عَلَ شَ عٍ مَفبَرَن، عَلَكٌ عٍ بٌفِ شَ فبٌ.  
\v 3 وٌ تَن نَشٍيٍ قِندِشِ نَ سَلٌنيِيٍ رَ، وٌ حَن بَرَ رَ سّنِيّن ﭑ مَ مَسٍنيِ سَابُي رَ.  
\v 4 وٌ لُ ﭑ مَ قٍ نّ، عَلْ ﭑ قَن لُمَ وٌ شَ قٍ كِ نَشّ. سَنسِ سَلٌنيِ مُ نْمَ بٌفِدٍ عَ يّتّ رَ شَ عَ مُ قَتُشِ سَنسِ بِلِ شَ مَ. وٌ قَن لُمَ نَ كِ نّ، شَ وٌ مُ لُ ﭑ مَ قٍ.  
\v 5 ﭑ تَن نَن نَ عَلَ شَ سَنسِ بِلِ رَ، وٌ قَن قِندِشِ نَ سَنسِ سَلٌنيِيٍ نَن نَ. نَشَن نَ لُ ﭑ مَ قٍ، ﭑ قَن لُ عَ شَ قٍ، عَ لُ نّ عَلْ سَنسِ سَلٌنيِ نَشَن عَ بٌفِ فبٍفبٍ رَ مِنِمَ. شَ وٌ نُن ﭑ تَن شَ مُ عَ رَ، وٌ تَن مُ نْمَ قٍقٍ رَ.  
\v 6 شَ نَشَن مُ لُ ﭑ مَ قٍ، عَ لُمَ نّ عَلْ سَنسِ سَلٌنيِ مَسّفّشِ نَشَن وْلّمَ، عَ شَرَ. وَلِكّيٍ نٍيٍ مَلَنمَ نّ، عٍ عٍ وْلّ تّ شْورَ، عٍ فَن.  
\v 7 شَ وٌ لُ ﭑ مَ قٍ، ﭑ مَ مَسٍنيِيٍ قَن لُ وٌ بْحّ مَ، وٌ نَ وَ قٍقٍ شْن، وٌ عَ مَشَندِ. عَ رَبَمَ نّ وٌ بّ.  
\v 8 ﭑ بَبَ مَتْشْي سْتْمَ، وٌ تَن نَ لُ عَلْ سَنسِ سَلٌنيِ نَشٍيٍ بٌفِمَ عَ قَنيِ رَ، وٌ عَ مَسٍن نَ وَلِ قَنيِيٍ كُي، عَ وٌ قِندِشِ ﭑ قْشِرَبِرّيٍ نَن نَ.  
\v 9 ﭑ بَبَ عَلَ ﭑ تَن شَنُشِ كِ نَشّ، ﭑ قَن وٌ شَنُشِ نَ كِ نّ. وٌ لُ ﭑ مَ شَنُنتٍيَ كُي.  
\v 10 شَ وٌ ﭑ مَ يَامَرِيٍ رَبَتُ، وٌ لُمَ ﭑ مَ شَنُنتٍيَ كُي، عَلْ ﭑ قَن لُشِ ﭑ بَبَ شَ شَنُنتٍيَ كُي كِ نَشّ، ﭑ تٌ عَ شَ يَامَرِيٍ رَبَتُشِ.» 
\p  
\v 11 «ﭑ يِ قٍيٍ مَسٍنشِ نّ وٌ بّ، عَلَكٌ ﭑ مَ سّيوّ شَ لُ وٌ بّ، وٌ شَ سّيوّ شَ كَمَلِ.» 
\p  
\v 12 «ﭑ مَ يَامَرِ قِندِشِ يِ نَن نَ؛ وٌ وٌ بٌرٍ شَنُ عَلْ ﭑ وٌ شَنُشِ كِ نَشّ.  
\v 13 شَ مِشِ عَ نِي قِ عَ شَنُنتٍنيِيٍ شَ قٍ رَ، شَنُنتٍيَ يٌ مُ نَ نَشَن دَنفِ نَ تَن نَ.  
\v 14 وٌ تَن قِندِشِ ﭑ شَنُنتٍنيِيٍ نَن نَ، شَ وٌ ﭑ مَ يَامَرِيٍ رَبَتُ.  
\v 15 ﭑ مُ قَ نْمَ عَ قَلَدٍ وٌ بّ ‹كٌنيِيٍ›، بَرِ مَ كٌنيِ مُ عَ كٌلٌن عَ مَرِفِ نَشَن يٌ رَبَقٍ. ﭑ تَن بَرَ عَ قَلَ وٌ بّ ‹ﭑ شَنُنتٍنيِيٍ›، بَرِ مَ ﭑ نَشَن بِرِن مّشِ ﭑ بَبَ رَ، ﭑ بَرَ وٌ رَكٌلٌن عَ بِرِن نَ.  
\v 16 وٌ تَن شَ مُ ﭑ سُفَندِ. ﭑ تَن نَن وٌ سُفَندِ، ﭑ وٌ قِندِ ﭑ مَ شّيرَيٍ رَ، وٌ شَ سَ لُ عَلْ سَنسِ سَلٌنيِيٍ نَشٍيٍ بٌفِمَ، وٌ سَ وَلِ قَنيِيٍ رَبَ نَشٍيٍ مُ كَنَمَ. نَ كُي، وٌ نَ قٍقٍ مَشْرِن بَبَ عَلَ مَ ﭑ تَن شِلِ رَ، عَ عَ سٌمَ نّ وٌ يِ.  
\v 17 ﭑ وٌ يَمَرِشِ نّ يِ قٍيٍ مَ، عَلَكٌ وٌ شَ وٌ بٌرٍ شَنُ.» 
\s1 دُنِحَ عِسَ قْشِرَبِرّيٍ شْنقٍ 
\p  
\v 18 «شَ دُنِحَ وٌ شْن، وٌ شَ عَ كٌلٌن عَ ﭑ تَن نَن سِنفٍ شْن.  
\v 19 شَ وٌ قِندِ دُنِحَ مِشِيٍ نَن نَ نُ، وٌ رَقَنمَ نّ دُنِحَ مَ نُ، عَلْ عَ فبٍ مِشِيٍ. كْنْ دُنِحَ مِشِيٍ مُ وٌ رَ، بَرِ مَ ﭑ تَن بَرَ وٌ سُفَندِ عٍ يَ مَ. نَ نَن عَ تٌشِ، دُنِحَ وٌ شْنشِ.  
\v 20 وٌ شَ رَتُ وْيّنيِ مَ ﭑ نَشَن مَسٍن وٌ بّ، ‹كٌنيِ مُ دَنفِمَ عَ مَرِفِ رَ.› شَ عٍ بَرَ ﭑ تَن حَشَنكَتَ، عٍ وٌ قَن حَشَنكَتَمَ نّ. شَ عٍ ﭑ تَن شُي سُشُ، عٍ وٌ قَن فبٍ سُشُمَ.  
\v 21 عٍ يِ قٍ بِرِن نِيَمَ نّ وٌ رَ ﭑ تَن شِلِ شَ قٍ رَ، بَرِ مَ عٍ مُ ﭑ شّيمَ كٌلٌن.  
\v 22 شَ ﭑ مُ سَ قَ وْيّندٍ عٍ بّ نُ، عٍ مُ يُنُبِ سْتْمَ نُ. كْنْ يَكْسِ، عٍ مُ قَ نْمَ سٍسٍ قَلَدٍ نَشَن كِيتِ قَنمَ عٍ رَ.  
\v 23 نَشَن نَ ﭑ تَن شْن، عَ بَرَ ﭑ بَبَ قَن شْن.  
\v 24 شَ ﭑ مُ كَابَنَكٌي رَبَ عٍ تَفِ نُ نَشٍيٍ سِنفٍ مُ نُ رَبَ، عٍ مُ يُنُبِ سْتْمَ نُ. كْنْ يَكْسِ، عٍ بَرَ نَ بِرِن تٌ، عٍ مَن قَ ﭑ تَن نُن ﭑ بَبَ شْن.  
\v 25 كْنْ نَشَن سّبّشِ عٍ شَ سّرِيّ كِتَابُي كُي، قٌ عَ شَ كَمَلِ، عَ تٌ عَ مَسٍنشِ، ‹عٍ ﭑ شْنشِ نّ تُن.›» 
\p  
\v 26 «ﭑ سَابُي قَنيِ نَشَن شّيمَ وٌ مَ كٍلِقٍ بَبَ عَلَ يِرٍ، نَشَن قِندِشِ بَبَ عَلَ شَشِلِ رَ، نَشَن نْندِ مَكّنّنمَ، عَ تَن نَ قَ، عَ سٍيدٍ بَمَ نّ ﭑ مَ قٍ رَ.  
\v 27 وٌ قَن سٍيدٍ بَمَ نّ، بَرِ مَ وٌ نَ ﭑ قْشْ رَ كَبِ عَ قْلّ.» 
\c 16  
\p  
\v 1 «ﭑ يِ قٍ بِرِن مَسٍنشِ نّ وٌ بّ، عَلَكٌ وٌ نَشَ قَ بِرَ تَنتَنيِ كُي.  
\v 2 عٍ قَمَ نّ تْنيِ دْشْدٍ وٌ مَ، سٌقٍ رَ سَلِدٍيٍ كُي. وَشَتِ حَن قَقٍ، نَشَن نَ وٌ قَشَ، عَ نَ قَشّ مَحْشُنمَ كّوَلِ قَنيِ نَن نَ عَلَ بّ.  
\v 3 عٍ نَ قٍيٍ رَبَمَ نّ، بَرِ مَ عٍ مُ بَبَ عَلَ كٌلٌن، عٍ مُ ﭑ قَن كٌلٌن.  
\v 4 كْنْ ﭑ يِ قٍيٍ بِرِن مَسٍنشِ نّ وٌ بّ، عَلَكٌ عٍ وَشَتِ نَ عَ لِ، وٌ شَ رَتُ، عَ ﭑ عٍ شَ قٍ قَلَ نّ وٌ بّ.» 
\s1 عَلَ شَشِلِ سّنِيّنشِ شَ وَلِ 
\p «ﭑ مُ يِ قٍ بِرِن مَسٍن وٌ بّ عَ قْلّ رَ، بَرِ مَ ﭑ نُ نَ وٌ قّ مَ.  
\v 5 كْنْ يَكْسِ، ﭑ قَ سِفَقٍ ﭑ شّيمَ يِرٍ، وٌ مُ ﭑ مَشْرِنمَ، ‹عِ نَ سِفَقٍ مِندٍن؟›  
\v 6 ﭑ تٌ يِ قٍيٍ مَسٍنشِ وٌ بّ، نَ نَن وٌ بْحّ سُننُنشِ.  
\v 7 كْنْ ﭑ شَ عَ قَلَ وٌ بّ عَ نْندِ كِ مَ، ﭑ مَ سِفّ نَن مُنَقَنيِ فبٌ وٌ بّ، بَرِ مَ شَ ﭑ مُ سِفَ، سَابُي قَنيِ مُ قَمَ وٌ مَ. كْنْ شَ ﭑ سِفَ، ﭑ عَ شّيمَ نّ وٌ مَ.  
\v 8 عَ نَ قَ، عَ مِشِيٍ رَكٌلٌنمَ نّ يُنُبِ شَ قٍ رَ، تِنشِنيِ شَ قٍ رَ، نُن كِيتِ شَ قٍ رَ.  
\v 9 عَ عٍ رَكٌلٌنمَ نّ يُنُبِ شَ قٍ رَ، بَرِ مَ عٍ مُ دَنشَنِيَشِ ﭑ مَ.  
\v 10 عَ عٍ رَكٌلٌنمَ نّ تِنشِنيِ شَ قٍ رَ، بَرِ مَ ﭑ نَ سِفَقٍ بَبَ عَلَ يِرٍ، وٌ مُ ﭑ تٌمَ قَ.  
\v 11 عَ عٍ رَكٌلٌنمَ نّ كِيتِ شَ قٍ رَ، بَرِ مَ يِ دُنِحَ نَ نْلَ كٌبِ نَشَن يِ رَ، عَ حَن بَرَ مَكِيتِ.» 
\p  
\v 12 «مَسٍنيِ فبّتّيٍ مَن نَ، كْنْ وٌ مُ نْمَ عٍ بِرِن قَهَامُدٍ يَكْسِ.  
\v 13 عَلَ شَشِلِ نَ قَ وٌ مَ، عَ نَ نْندِ بِرِن يَ مَبْو مَ وٌ بّ. عَ شَ مَسٍنيِ مُ قَتَنشِ عَ يّتّ كَن نَ. عَ نَشَن مّمَ ﭑ بَبَ رَ، عَ نَ نَن مَسٍنمَ وٌ بّ. قٍ نَشٍيٍ قَمَ رَبَدٍ، عَ نٍيٍ نَن مَسٍنمَ وٌ بّ.  
\v 14 عَ قَمَ ﭑ مَ شُننَكٍلِ مَكّنّندٍ، بَرِ مَ عَ نَشَن سْتْمَ ﭑ تَن نَ، عَ نَ نَن كَوَندِ مَ وٌ بّ.  
\v 15 نَشَن بِرِن نَ بَبَ عَلَ يِ، عَ قِندِشِ ﭑ قَن فبٍ نَن نَ. ﭑ عَ قَلَ نَ نَن مَ، ‹عَ نَشَن سْتْمَ ﭑ تَن نَ، عَ نَ نَن كَوَندِ مَ وٌ بّ.›» 
\s1 سُننُنيِ مَسَرَ مَ نّ سّيوّ رَ 
\p  
\v 16 عِسَ مَن نَشَ عَ قَلَ عٍ بّ، «وَشَتِ دِ نَن لُشِ بٍينُن ﭑ شَ لْي وٌ مَ، كْنْ وَشَتِ دِ مَن نَ دَنفِ، وٌ مَن ﭑ تٌمَ نّ.»  
\v 17 عَ قْشِرَبِرّيٍ نَشَ عٍ بٌرٍ مَشْرِن، «عِسَ وَ مَ مُنسٍ قَلَقٍ يِ كِ، ‹عَ فبٍ مُ لُشِ ﭑ شَ لْي وٌ مَ دٌندٌرٌنتِ، كْنْ وٌ مَن قَمَ ﭑ تٌدٍ.› عَ شَ وْيّنيِ نَ دِ عَ تٌ عَ قَلَشِ، ‹ﭑ نَ سِفَقٍ بَبَ عَلَ يِرٍ؟›»  
\v 18 عٍ مَن نُ عٍ بٌرٍ مَشْرِنقٍ، «عَ مُنسٍ مَ، عَ ‹وَشَتِ دِ›؟ وٌن تَن مُ عَ كٌلٌن عَ سٍسٍ قَلَقٍ يِ كِ.» 
\p  
\v 19 عِسَ تٌ عَ كٌلٌن عَ عٍ نُ وَ مَ عَ مَشْرِنقٍ، عَ نَشَ عَ مَسٍن عٍ بّ، «ﭑ تٌ عَ قَلَشِ، ‹وَشَتِ دِ نَن لُشِ بٍينُن ﭑ شَ لْي وٌ مَ، كْنْ وَشَتِ دِ مَن نَ دَنفِ، وٌ مَن ﭑ تٌمَ نّ،› وٌ وٌ بٌرٍ مَشْرِنقٍ نَ نَن مَ؟  
\v 20 ﭑ شَ عَ قَلَ وٌ بّ عَ نْندِ كِ مَ، وٌ وَ مَ نّ، وٌ فبٍلٍفبٍلٍ، كْنْ دُنِحَ تَن حّلّشِنمَ نّ. وٌ سُننُنمَ نّ نَ قٍ مَ، كْنْ وٌ شَ سُننُنيِ قَمَ مَسَرَدٍ سّيوّ رَ.  
\v 21 فِنّ نَشَن نَ دِتِنيِ رَ، عَ تْورْ مَ نّ كِ قَنيِ عَ شَ وَشَتِ تٌ بَرَ عَ لِ. كْنْ شَ عَ فّ دِ بَرِدٍ، عَ حَن مُ رَتُمَ نَ تْورّ مَ، عَ تٌ سّيوَشِ دِ نّينّ بَرِقٍ رَ دُنِحَ.  
\v 22 نَ كُي، وٌ قَن نَ سُننُنيِ نَن كُي يِ وَشَتِ مَ. كْنْ ﭑ فبِلٍنمَ نّ وٌ تٌ رَ، وٌ بْحّ سّيوَ، مِشِ يٌ مُ نَ سّيوّ بَمَ وٌ يِ.  
\v 23 نَ لْشْي نَ عَ لِ، وٌ مُ ﭑ مَشْرِنمَ سٍسٍ مَ سْنْن. ﭑ شَ عَ قَلَ وٌ بّ عَ نْندِ كِ مَ، وٌ نَ بَبَ عَلَ مَشَندِ قٍقٍ مَ ﭑ شِلِ رَ، عَ عَ سٌمَ نّ وٌ يِ.  
\v 24 هَن يَ، وٌ سِنفٍ مُ نُ عَلَ مَشَندِ قٍقٍ مَ ﭑ تَن شِلِ رَ. وٌ مَشَندِ تِ. وٌ عَ سْتْمَ نّ، عَلَكٌ وٌ شَ سّيوَ عَ كَمَلِشِ رَ.» 
\s1 عِسَ شَ شُننَكٍلِ مَكّنّنقٍ 
\p  
\v 25 «ﭑ يِ قٍ بِرِن مَسٍنشِ وٌ بّ تَالِ وْيّنيِ نَن نَ، كْنْ وَشَتِ نَ قَقٍ، ﭑ مُ وْيّنمَ وٌ بّ تَالِ وْيّنيِ رَ سْنْن، ﭑ بَبَ عَلَ شَ قٍ مَسٍن وٌ بّ عَ قِيشّ رَ.  
\v 26 نَ وَشَتِ مَ، وٌ بَبَ عَلَ مَشَندِ مَ ﭑ شِلِ نَن نَ. ﭑ مُ عَ قَلَقٍ شّ دٍ، عَ ﭑ تَن نَن بَبَ عَلَ مَشَندِ مَ وٌ بّ،  
\v 27 بَرِ مَ بَبَ عَلَ يّتّ يَتِ وٌ شَنُشِ نّ. عَ وٌ شَنُشِ نّ ﭑ تٌ رَقَن وٌ مَ، وٌ مَن تٌ لَشِ عَ رَ عَ ﭑ كٍلِشِ عَ تَن عَلَ نَن مَ.  
\v 28 ﭑ كٍلِشِ بَبَ عَلَ نَن مَ، ﭑ قَ دُنِحَ مَ. ﭑ مَن قَ كٍلِقٍ نّ دُنِحَ مَ، سِفَقٍ رَ بَبَ عَلَ يِرٍ.» 
\p  
\v 29 عِسَ قْشِرَبِرّيٍ نَشَ عَ قَلَ عَ بّ، «عَ مَتٌ، عِ مُ وْيّنقٍ تَالِ وْيّنيِ شَ رَ سْنْن، عِ قَ نَ وْيّنقٍ عَ قِيشّ نَن نَ!  
\v 30 مُشُ بَرَ عَ كٌلٌن قَ، عَ عِ قٍ بِرِن كٌلٌن، هَلِ مِشِ يٌ مُ عِ مَشْرِن. نَ كُي، مُشُ لَشِ عَ رَ عَ عِ كٍلِشِ عَلَ نَن مَ.»  
\v 31 عِسَ نَشَ عٍ يَابِ، «وٌ بَرَ دَنشَنِيَ يَكْسِ؟  
\v 32 وَشَتِ نَ قَقٍ، عَ حَن بَرَ عَ لِ، وٌ يٍنسٍنمَ نّ، وٌ قَ ﭑ نَبٌلٌ. كْنْ بَبَ عَلَ تَن مُ ﭑ نَبٌلٌمَ. عَ لُمَ نّ ﭑ سّيتِ مَ.  
\v 33 ﭑ يِ قٍ بِرِن مَسٍنشِ نّ وٌ بّ، عَلَكٌ بْحّسَ شَ لُ وٌ يِ رَ ﭑ سَابُي رَ. وٌ مَنتْورْلِ سْتْمَ نّ دُنِحَ مَ، كْنْ وٌ شَ لِمَنِيَ، ﭑ تَن بَرَ نْ دُنِحَ رَ.» 
\c 17  
\s1 عِسَ عَلَ مَشَندِقٍ 
\p  
\v 1 عِسَ تٌ فّ نَ قٍيٍ قَلَدٍ، عَ نَشَ عَ يَ رَتٍ كٌورٍ، عَ عَ قَلَ، «ﭑ بَبَ عَلَ، وَشَتِ بَرَ عَ لِ. عِ شَ عِ شَ دِ شَ شُننَكٍلِ مَكّنّن، عَلَكٌ عِ شَ دِ قَن شَ عِ شَ نْرّ مَكّنّن.  
\v 2 عِ بَرَ مَنفّيَ قِ عَ مَ دُنِحَ مِشِيٍ بِرِن شُن نَ، عَلَكٌ عَ شَ عَبَدَن كِسِ قِ مِشِ بِرِن مَ، عِ نَشٍيٍ قِشِ عَ مَ.  
\v 3 عَبَدَن كِسِ قِندِشِ يِ نَن نَ؛ عٍ شَ عِ كٌلٌن، عِ تَن كٍرٍن نَشَن قِندِشِ عَلَ يّتّ رَ، عٍ مَن شَ عِ شَ مِشِ سُفَندِشِ عِسَ كٌلٌن عِ شَ شّيرَ رَ.  
\v 4 ﭑ بَرَ عِ شَ نْرّ مَكّنّن دُنِحَ مَ، ﭑ فّ وَلِ رَ عِ ﭑ تِ نَشَن نَ.  
\v 5 ﭑ بَبَ عَلَ، يَكْسِ، ﭑ نْرْ عِ قّ مَ، عَلْ ﭑ نُ نْرْشِ عِ قّ مَ كِ نَشّ، بٍينُن دُنِحَ شَ دَا.» 
\p  
\v 6 «ﭑ بَرَ عِ شَ قٍ مَسٍن مِشِيٍ بّ، عِ نَشٍيٍ قِشِ ﭑ مَ دُنِحَ. عِ شَ مِشِيٍ نَن عٍ رَ عِ نَشٍيٍ تَشُشِ ﭑ نَ. عٍ بَرَ عِ شُي رَتِنمّ.  
\v 7 عٍ بَرَ عَ كٌلٌن قَ، عَ عِ نَشَن بِرِن سٌشِ ﭑ يِ رَ، عَ قَتَنشِ عِ تَن نَن نَ،  
\v 8 بَرِ مَ ﭑ بَرَ عِ شُي رَدَنفِ عٍ مَ، عٍ قَن بَرَ لَ عَ رَ. عٍ بَرَ عَ كٌلٌن يَتِ، عَ ﭑ كٍلِشِ عِ تَن نَن مَ، عٍ لَ عَ رَ، عَ عِ تَن نَن ﭑ شّيشِ.  
\v 9 ﭑ مُ دُبَمَ دُنِحَ بّ. ﭑ دُبَمَ عِ شَ مِشِيٍ نَن بّ، عِ نَشٍيٍ تَشُشِ ﭑ نَ.  
\v 10 نَشٍيٍ بِرِن قِندِشِ ﭑ فبٍ رَ، عِ فبٍ نَ عٍ رَ. نَشٍيٍ بِرِن قِندِشِ عِ فبٍ رَ، ﭑ فبٍ نَ عٍ رَ. ﭑ مَ قٍ عِتٍمَ نّ عٍ تَن سَابُي رَ.  
\v 11 ﭑ مُ قَ لُمَ دُنِحَ سْنْن. ﭑ قَقٍ عِ يِرٍ نّ يِ كِ، كْنْ عٍ تَن لُمَ بٍ نّ. ﭑ بَبَ سّنِيّنشِ، عٍ مَكَنتَ عِ شِلِ سّنبّ رَ، عِ نَشَن قِشِ ﭑ مَ، عَلَكٌ عٍ قَن شَ قِندِ كٍرٍن نَ عَلْ وٌن تَن قِندِشِ كٍرٍن نَ كِ نَشّ.  
\v 12 ﭑ تٌ نُ عٍ يَ مَ، ﭑ بَرَ عٍ كَنتَ عِ شِلِ سّنبّ رَ، عِ نَشَن قِشِ ﭑ مَ. ﭑ تٌ عٍ مَكَنتَ، مِشِ كٍرٍن مُ لْي عٍ يَ مَ قٌ فبَلٌي رَفَتَشِ نَشَن كٍرٍن بّ، عَلَكٌ كِتَابُي سّبّلِ شَ كَمَلِ.  
\v 13 كْنْ ﭑ تٌ قَقٍ عِ يِرٍ نّ يِ كِ، ﭑ يِ قٍيٍ قَلَمَ دُنِحَ مَ، عَلَكٌ ﭑ مَ سّيوّ شَ لُ عٍ بّ، عَ شَ لُ عٍ بْحّ مَ عَ كَمَلِشِ رَ.  
\v 14 ﭑ تٌ عِ شَ مَسٍنيِ قَلَ عٍ بّ، دُنِحَ بَرَ عٍ شْن، بَرِ مَ عٍ تٌندِشِ بِرَدٍ دُنِحَ قٍ قْشْ رَ عَلْ ﭑ قَن تٌ مُ تِنشِ بِرَدٍ دُنِحَ قٍ قْشْ رَ.  
\v 15 ﭑ مُ عِ مَشَندِ مَ شّ عِ شَ عٍ تٌنفٌ دُنِحَ مَ. ﭑ عِ مَشَندِقٍ نّ عِ شَ عٍ رَتَنفَ سٍنتَنّ مَ.  
\v 16 عٍ مُ بِرَ مَ دُنِحَ قٍ قْشْ رَ، عَلْ ﭑ قَن تٌ مُ لُمَ نَ قٍ مْولِ كُي.  
\v 17 عِ شَ عٍ سَ عِ يّتّ نَن سَفٌي نْندِ كُي. عِ شُي نَن قِندِشِ نْندِ رَ.  
\v 18 ﭑ بَرَ عٍ شّي دُنِحَ، عَلْ عِ قَن ﭑ شّي كِ نَشّ.  
\v 19 ﭑ بَرَ ﭑ يّتّ سَ عِ سَفٌي عٍ بّ، عَلَكٌ عٍ تَن قَن، عٍ شَ سَ عِ سَفٌي نْندِ كُي.» 
\p  
\v 20 «ﭑ مُ دُبَمَ نَ مِشِيٍ فبَنسَن شَ بّ. ﭑ مَن دُبَمَ مِشِيٍ بّ نَشٍيٍ قَمَ دَنشَنِيَدٍ ﭑ مَ عٍ سَابُي رَ.  
\v 21 ﭑ دُبَمَ نّ عٍ بّ عَلَكٌ عٍ شَ قِندِ كٍرٍن نَ، عَلْ ﭑ نُن عِ تَن ﭑ بَبَ عَلَ قِندِشِ كٍرٍن نَ كِ نَشّ. ﭑ مَن دُبَمَ عٍ بّ عَلَكٌ عٍ شَ قِندِ كٍرٍن نَ وٌن قْشْ رَ، وٌن بِرِن شَ قِندِ كٍرٍن نَ. نَ كُي، دُنِحَ نْمَ عَ كٌلٌندٍ عَ عِ تَن نَن ﭑ شّيشِ.  
\v 22 عِ بَرَ شُننَكٍلِ نَشَن قِ ﭑ مَ، ﭑ قَن بَرَ عَ قِ عٍ مَ، عَلَكٌ عٍ قَن شَ قِندِ كٍرٍن نَ، عَلْ وٌن تَن قِندِشِ كٍرٍن نَ كِ نَشّ.  
\v 23 ﭑ تَن نَ عٍ عِ، عِ قَن نَ ﭑ عِ، عَلَكٌ عٍ شَ كٍرٍنحَ شَ كَمَلِ. نَ كُي، دُنِحَ عَ كٌلٌنمَ نّ عَ عِ تَن نَن ﭑ شّيشِ، عَ عِ مَن عٍ تَن شَنُشِ عَلْ عِ ﭑ قَن شَنُشِ كِ نَشّ.» 
\p  
\v 24 «ﭑ بَبَ عَلَ، بٍينُن دُنِحَ شَ دَا، عِ نُ بَرَ نْرّ قِ ﭑ مَ عِ شَ شَنُنتٍيَ شَ قٍ رَ. عَ شْلِ ﭑ مَ ﭑ مَ مِشِيٍ، عِ نَشٍيٍ قِشِ ﭑ مَ، نٍيٍ قَن شَ لُ ﭑ سّيتِ مَ عَرِيَننَ، عٍ شَ ﭑ مَ نْرّ تٌ.  
\v 25 ﭑ بَبَ، عِ تِنشِن. ﭑ عِ كٌلٌن. دُنِحَ تَن مُ عِ كٌلٌن، كْنْ عٍ عَ كٌلٌن عَ عِ تَن نَن ﭑ شّيشِ.  
\v 26 ﭑ بَرَ عٍ رَكٌلٌن عِ شَ قٍ رَ، ﭑ مَن ندٍ سَمَ نّ عَ قَرِ، عَلَكٌ شَنُنتٍيَ شَ لُ عٍ بْحّ مَ عِ ﭑ شَنُشِ نَشَن نَ، عَلْ ﭑ قَن نَ عٍ بْحّ عِ كِ نَشّ.» 
\c 18  
\s1 عِسَ سُشُقٍ 
\r مَتِيُ ٢٦‏؛٤٧ ٬ ٥٦، مَرَكِ ١٤‏؛٤٣ ٬ ٥٠، لُكِ ٢٢‏؛٤٧ ٬ ٥٣ 
\p  
\v 1 عِسَ تٌ فّ عَلَ مَشَندِدٍ، عَ تَن نُن عَ قْشِرَبِرّيٍ نَشَ سِفَ سٍدِرٌن شُرٍ نَاكِرِ مَ سَنسِ يِرٍ.  
\v 2 يُدَ سِ، نَشَن قِندِ عِسَ يَنقَمَ رَ، عَ قَن نُ نَ كٌلٌن، بَرِ مَ عِسَ نُن عَ قْشِرَبِرّيٍ نُ دَرِشِ عٍ مَلَن نَ مّننِ نّ.  
\v 3 يُدَ سِ نَشَ رْ مَكَيٍ، سّرّشّدُبّ كُنتِفِيٍ، نُن قَرِ سّنِيٍ شَ سْورِ فَلِ شَنِن نَا، لَنثُييٍ نُن فٍرٍ سٌسٍيٍ نَ عٍ يِ رَ. عٍ مَن نَشَ سّشّ مَشِرِ وُرِ مَ، عٍ عَ رَدّشّ عَلَكٌ عٍ شَ كِرَ تٌ.  
\v 4 عِسَ تٌ نُ قٍ بِرِن كٌلٌن نَشَن نُ قَقٍ عَ لِدٍ، عَ نَشَ عٍ رَلَن، عَ عٍ مَشْرِن، «وٌ ندٍ قٍنقٍ؟»  
\v 5 عٍ نَشَ عَ يَابِ، «مُشُ عِسَ نَسَرّتِكَ نَن قٍنقٍ.» عِسَ نَشَ عَ قَلَ، «ﭑ تَن نَن نَ عَ رَ.» يُدَ سِ، نَشَن قِندِ عَ يَنقَمَ رَ، عَ قَن نُ تِشِ نَ فَلِ يَ مَ.  
\v 6 عِسَ تٌ عَ قَلَ عٍ بّ، «ﭑ تَن نَن نَ عَ رَ»، عٍ نَشَ فبِلٍن شَنبِ، عٍ بِرَ بْشِ.  
\v 7 عِسَ مَن نَشَ عٍ مَشْرِن، «وٌ ندٍ قٍنقٍ؟» عٍ مَن نَشَ عَ يَابِ، «عِسَ نَسَرّتِكَ.»  
\v 8 عِسَ نَشَ عٍ يَابِ، «ﭑ بَرَ عَ قَلَ وٌ بّ، ﭑ تَن نَن عَ رَ. شَ وٌ ﭑ تَن نَن قٍنقٍ، وٌ عَ لُ يِ بٌورٍيٍ تَن شَ سِفَ.»  
\v 9 نَ كُي، عِسَ شَ مَسٍنيِ نَن نُ قَقٍ كَمَلِدٍ، عَ تٌ نُ بَرَ عَ قَلَ، «عِ مِشِ نَشٍيٍ قِ ﭑ مَ، كٍرٍن مُ لْي عٍ يَ مَ.» 
\p  
\v 10 سِمْن ثِيّرِ نَشَ عَ شَ سَنتِدّفّمَ رَ مِنِ، عَ سّرّشّدُبّ كُنتِفِ شَ كٌنيِ مَلِكُ يِرٍقَنيِ تُلِ بٌلٌن.  
\v 11 عِسَ نَشَ عَ قَلَ سِمْن ثِيّرِ بّ، «سَنتِدّفّمَ رَ سٌ عَ تّي عِ. قٌ ﭑ شَ تِن تْورّ رَ بَبَ عَلَ نَشَن نَفِرِ ﭑ مَ.» 
\s1 عِسَ شَنِنقٍ عَنَنِ نُن كَيَقَ يِرٍ 
\s1 ثِيّرِ عَ يّتّ رَ سَنقٍ عِسَ مَ 
\p  
\v 12 رْ مَ سْورِ مَنفّ نُن عَ شَ سْورِيٍ، عَ نُن يُوِقِيٍ شَ سْورِيٍ نَشَ عِسَ سُشُ، عٍ عَ شِرِ،  
\v 13 عٍ عَ شَنِن عَنَنِ شْن مَ. عَنَنِ شَ دِ فِنّ نَن دْشْ كَيَقَ شْن. كَيَقَ نُ بَرَ قِندِ سّرّشّدُبّ كُنتِفِ رَ نَ حّ رَ.  
\v 14 كَيَقَ نَن نُ بَرَ يُوِقِ كُنتِفِيٍ رَ سِ، عَ عَ قَن عٍ بّ، مِشِ كٍرٍن نَن شَ قَشَ حَمَ بّ. 
\p  
\v 15 سِمْن ثِيّرِ نَشَ بِرَ عِسَ قْشْ رَ، عَ نُن عِسَ قْشِرَبِرّ فبّتّ ندٍ. نَ قْشِرَبِرّ تٌ نُ قِندِشِ سّرّشّدُبّ كُنتِفِ كٌلٌن مِشِ رَ، عَ نَشَ نْ سٌدٍ سّرّشّدُبّ كُنتِفِ شَ تّتّ كُي، عٍ عِسَ شَنِن دّننَشّ.  
\v 16 ثِيّرِ نَشَ لُ تَندٍ نَادّ دّ رَ، هَن عَ بٌورٍ، سّرّشّدُبّ كُنتِفِ كٌلٌنمَ، عَ نَشَ وْيّن نَادّ كَنتَمَ رَ عَ شَ تِن ثِيّرِ قَن شَ سٌ.  
\v 17 كٌنيِ فِنّ نَشَن نُ نَادّ كَنتَقٍ، عَ نَشَ ثِيّرِ مَشْرِن، «نَ شّمّ عِسَ قْشِرَبِرّ ندٍ شَ مُ عِ قَن نَ؟» عَ نَشَ عَ يَابِ، «عَدٍ، ﭑ تَن مُ عَ رَ!»  
\v 18 شِنبٍلِ تٌ مِنِ، كٌنيِيٍ نُن كْسِبِلِيٍ نَشَ تّ شُرُ، عٍ قَ لُ نَ قّ مَ. ثِيّرِ قَن نَشَ عَ مَسٌ عٍ رَ. 
\p  
\v 19 سّرّشّدُبّ كُنتِفِ نَشَ عِسَ مَشْرِن عَ قْشِرَبِرّيٍ شَ قٍ مَ، عَ نُن عَ شَ كَوَندِيٍ.  
\v 20 عِسَ نَشَ عَ يَابِ، «ﭑ تَن مَسٍنيِيٍ تِشِ كّنّ نَن مَ، دُنِحَ بِرِن بّ. ﭑ نَن ﭑ مَ كَوَندِ بِرِن تِشِ سَلِدٍيٍ نَن كُي، شَ نَ مُ هْرْ مْبَنشِ كُي، يُوِقِيٍ بِرِن عٍ لُمَ مَلَن نَ دّننَشّ. ﭑ مُ سٍسٍ قَلَ دُنشُي رَ.  
\v 21 عِ ﭑ تَن مَشْرِنمَ مُنقٍ رَ؟ نَشٍيٍ ﭑ شُي رَ مّ، نٍيٍ نَن مَشْرِن. عٍ تَن نَن عَ كٌلٌن ﭑ بَرَ قٍيٍ نَشٍيٍ قَلَ.»  
\v 22 عِسَ تٌ نَ قَلَ، كْسِبِلِ ندٍ نَشَن نُ تِشِ نَا، عَ نَشَ عَ دّ رَفَرِن، عَ عَ قَلَ، «ثٍ، عِ سّرّشّدُبّ كُنتِفِ يَابِمَ نَ كِ نّ؟»  
\v 23 عِسَ نَشَ عَ يَابِ، «شَ ﭑ وْيّن كٌبِ نَن قَلَشِ، عَ مَسٍن. كْنْ شَ ﭑ مُ وْيّن كٌبِ شَ قَلَشِ، عِ ﭑ دّ رَفَرِنشِ مُنقٍ رَ؟»  
\v 24 نَ تّمُي، عَنَنِ نَشَ عَ شِرِشِ رَ سَنبَ كَيَقَ مَ، سّرّشّدُبّ كُنتِفِيٍ شُنيِ. 
\p  
\v 25 سِمْن ثِيّرِ نُ دْشْشِ تّ رَ، عَ نَ عَ مَشَرَقٍ. نَ تّمُي عٍ نَشَ عَ مَشْرِن، «عِسَ قْشِرَبِرّ شَ مُ عِ قَن نَ؟» ثِيّرِ نَشَ عٍ يَابِ، «عَدٍ، عَ قْشِرَبِرّ مُ نَ ﭑ تَن نَ.»  
\v 26 سّرّشّدُبّ كُنتِفِ شَ كٌنيِ ندٍ نُ نَ نَا، ثِيّرِ نُ بَرَ نَشَن بَرٍنيِ تُلِ بٌلٌن. عَ نَشَ ثِيّرِ مَشْرِن، «ﭑ مُ عِ تٌ شّ نَ سَنسِ يِرٍ، وٌ نُن عِسَ؟»  
\v 27 ثِيّرِ مَن نَشَ نَ مَتَندِ، كٌنكٌرٍ قَن نَشَ عَ رَتٍ كٍرٍن نَ. 
\s1 عِسَ تِقٍ فٌمِنَ ثِلَتِ يَ عِ 
\r مَتِيُ ٢٧‏؛١ ٬ ٢، ١١ ٬ ١٤، مَرَكِ ١٥‏؛١ ٬ ٥، لُكِ ٢٣‏؛١ ٬ ٥ 
\p  
\v 28 نَ تّمُي، عٍ نَشَ عِسَ تٌنفٌ كَيَقَ شْنيِ، عٍ عَ شَنِن فٌمِنَ شْنيِ. كُيٍ نُ بَشِ عِبَدٍ. يُوِقِ كُنتِفِيٍ تَن مُ تِن سٌدٍ فٌمِنَ شْنيِ، عَلَكٌ عٍ شَ سّنِيّنيِ نَشَ قَ كَنَ، عٍ مُ قَ نْ سَيَمَلٍكّ دَنفِ سَلِ دٌنيِ دٌندٍ.  
\v 29 نَ كُي، فٌمِنَ ثِلَتِ نَشَ مِنِ عٍ يِرٍ تَندٍ، عَ عٍ مَشْرِن، «وٌ يِ شّمّ كَلَمُقٍ مُنسٍ مَ؟»  
\v 30 عٍ نَشَ عَ يَابِ، «شَ يِ شّمّ مُ قِندِ قٍ كٌبِ رَبَ شَ رَ، مُشُ مُ قَمَ عَ رَ عِ شْن مَ نُ.»  
\v 31 ثِلَتِ نَشَ عَ قَلَ عٍ بّ، «وٌ عَ شَنِن، وٌ شَ سَ عَ مَكِيتِ وٌ شَ سّرِيّ كِ مَ.» يُوِقِيٍ نَشَ عَ قَلَ، «وٌ شَ سّرِيّ مُ تِنمَ مُشُ شَ مِشِ قَشَ مُشُ يّتّ رَ.»  
\v 32 نَ كُي، عِسَ شَ وْيّنيِ نَن نُ قَقٍ كَمَلِدٍ، عَ تٌ نُ بَرَ عَ يّتّ قَشَ كِ مَسٍن. 
\p  
\v 33 ثِلَتِ مَن نَشَ سٌ عَ شْنيِ، عَ عِسَ شِلِ، عَ عَ مَشْرِن، «عِ تَن نَن قِندِشِ يُوِقِيٍ شَ مَنفّ رَ؟»  
\v 34 عِسَ نَشَ عَ يَابِ، «عِ وْيّنقٍ عِ يّتّ شَشِلِ نَن مَ بَ، كَ مِشِيٍ نَن ﭑ مَ قٍ قَلَ عِ بّ؟»  
\v 35 ثِلَتِ نَشَ عَ يَابِ، «ثٍ، يُوِقِ نَن نَ ﭑ قَن نَ؟ عِ بٌورٍ يُوِقِيٍ نُن سّرّشّدُبّ كُنتِفِيٍ نَن عِ سَشِ ﭑ بّلّشّ. عِ مُنسٍ رَبَشِ؟»  
\v 36 عِسَ نَشَ عَ يَابِ، «ﭑ مَ مَنفّيَ مُ قِندِشِ دُنِحَ دَاشِ شَ رَ، شَ نَ مُ عَ رَ ﭑ مَ مِشِيٍ فٍرٍ سٌمَ نّ نُ، عٍ تٌندِ ﭑ شَ لُ يُوِقِيٍ سَفٌ. ﭑ مَ مَنفّيَ مُ قِندِشِ دُنِحَ دَاشِ رَ.»  
\v 37 نَ كُي، ثِلَتِ نَشَ عَ مَشْرِن، «عِ تَن نَن نَ يُوِقِيٍ شَ مَنفّ رَ؟» عِسَ نَشَ عَ يَابِ، «عِ تَن نَن عَ قَلَشِ. ﭑ بَرِشِ نّ دُنِحَ بّندّ قُحِ قَرِ، عَلَكٌ ﭑ شَ نْندِ مَسٍن عَ بِرِن بّ. مِشِ نَشَن وَ مَ نْندِ شْن، عَ ﭑ شُي سُشُمَ نّ.»  
\v 38 ثِلَتِ مَن نَشَ عَ مَشْرِن، «نْندِ نَ دِ؟» ثِلَتِ تٌ نَ قَلَ، عَ نَشَ مِنِ تَندٍ يُوِقِيٍ يِرٍ، عَ عَ قَلَ عٍ بّ، «ﭑ مُ قٍ حَاشِ يٌ تٌشِ يِ شّمّ لَن عَ شَ حَشَنكَتَ نَشَن مَ.  
\v 39 وٌ تٌ دَرِشِ عَ رَ ﭑ شَ فٍيلِمَنِ كٍرٍن بّحِن وٌ بّ سَيَمَلٍكّ دَنفِ سَلِ لْشْي، وٌ وَ مَ ﭑ شَ يُوِقِيٍ شَ مَنفّ بّحِن وٌ بّ؟»  
\v 40 عٍ نَشَ سْنشْي رَتٍ، «عَدٍ، نَ مُ عَ رَ! بَرَبَسِ نَن شَ رَبٌلٌ.» سُوتٍ نَن نُ بَرَبَسِ رَ. 
\c 19  
\s1 عِسَ قَشَقٍ نَتّ تٌنفٌ كِ 
\p  
\v 1 نَ تّمُي ثِلَتِ نَشَ يَامَرِ قِ عَ سْورِيٍ شَ عِسَ بُلَن سّبّرّ رَ.  
\v 2 سْورِيٍ نَشَ مَنفّ كَتَنيِ مَنِيّ يَءِلَن تُنبٍيٍ رَ، عٍ عَ سَ عَ شُن مَ، عٍ قَ مَنفّ دٌنمَ فبٍيلِ رَفٌرٌ عَ مَ.  
\v 3 عٍ نُ عٍ مَسٌمَ عَ رَ، عٍ نُ عَ قَلَ، «عِ كّنَ، يُوِقِيٍ شَ مَنفّ،» عٍ نُ قَ عَ مَدِن. 
\p  
\v 4 ثِلَتِ مَن نَشَ مِنِ تَندٍ، عَ عَ قَلَ يُوِقِ حَمَ بّ، «ﭑ بَرَ يِ شّمّ مَسٍن وٌ بّ، عَلَكٌ وٌ شَ عَ كٌلٌن عَ ﭑ مُ قٍقٍ تٌشِ عَ مَ عَ حَشَنكَتَمَ نَشَن مَ.»  
\v 5 نَ كُي، سْورِيٍ نَشَ عِسَ رَ مِنِ تَندٍ، نَ تُنبٍ مَنفّ كَتَنيِ سَشِ عَ شُن مَ، بُرُ مُسِ فبٍيلِ رَفٌرٌشِ عَ مَ. ثِلَتِ نَشَ عَ قَلَ عٍ بّ، «عَ تَن نَن يِ كِ!»  
\v 6 سّرّشّدُبّ كُنتِفِيٍ نُن هْرْ مْبَنشِ كْسِبِلِيٍ تٌ عَ تٌ، عٍ نَشَ سْنشْ، «عَ قَشَ! عَ بَنبَن وُرِ مَفَلَنبُشِ مَ!» ثِلَتِ نَشَ عَ قَلَ عٍ بّ، «وٌ عَ تٌنفٌ، وٌ تَن نَن شَ سَ عَ بَنبَن وُرِ مَفَلَنبُشِ مَ، بَرِ مَ ﭑ تَن مُ قٍقٍ تٌشِ عَ لَن عَ شَ قَشَ نَشَن مَ.»  
\v 7 يُوِقِيٍ نَشَ عَ يَابِ، «سّرِيّ نَ مُشُ قَن يِ. نَ سّرِيّ كِ مَ، عَ لَن عَ شَ قَشَ، بَرِ مَ عَ بَرَ عَ يّتّ قِندِ عَلَ شَ دِ رَ.» 
\p  
\v 8 ثِلَتِ تٌ نَ مّ، عَ نَشَ فَاشُ كِ قَنيِ رَ.  
\v 9 عَ مَن نَشَ سٌ عَ شْنيِ، عَ عِسَ مَشْرِن، «عِ تَن، عِ كٍلِشِ مِندٍن؟» كْنْ عِسَ مُ يَابِ يٌ قِ.  
\v 10 ثِلَتِ نَشَ قَ عَ قَلَ عَ بّ، «عِ تٌندِشِ ﭑ تَن نَن يَابِدٍ؟ عِ مُ عَ كٌلٌن عَ نْي نَشَن نَ ﭑ تَن بّ، ﭑ نْمَ عِ رَبٌلٌدٍ، ﭑ مَن نْمَ عِ قَشَدٍ وُرِ مَفَلَنبُشِ مَ؟»  
\v 11 عِسَ نَشَ عَ يَابِ، «نْي يٌ مُ عِ بّ ﭑ تَن شُن مَ قٌ عَلَ نَشَن قِشِ عِ مَ. نَ نَن عَ رَ، نَشَن ﭑ سَشِ عِ بّلّشّ، نَ نَن شَ يُنُبِ فبٌ.» 
\p  
\v 12 ثِلَتِ تٌ نَ مّ، عَ نَشَ سٌ كَتَقٍ عَ شَ عِسَ رَبّحِن، كْنْ يُوِقِيٍ نَشَ سْنشْ، «شَ عِ يِ شّمّ بّحِن، عِ بَرَ فٍرٍ فِرِ رْ مَ مَنفّ شُنفبٍ مَ. نَشَن يٌ عَ يّتّ قِندِ مَنفّ رَ، عَ بَرَ تِ رْ مَ مَنفّ شُنفبٍ كَنكٍ.»  
\v 13 نَ كُي، ثِلَتِ تٌ عٍ شُي مّ، عَ نَشَ عِسَ رَ مِنِ تَندٍ. ثِلَتِ نَشَ دْشْ بُنتُنيِ رَ، كِيتِسَ كِبَنيِ كُي، دّننَشّ شِلِ قَلَمَ عٍبُرُ شُي «فَبَتَ».  
\v 14 نَ لْشْي يُوِقِيٍ نُ نَ قٍيٍ يَءِلَنقٍ سَيَمَلٍكّ دَنفِ سَلِ شَ قٍ رَ. يَنيِ تَفِ ثِلَتِ نَشَ عَ قَلَ يُوِقِيٍ بّ، «وٌ شَ مَنفّ نَن يَ!»  
\v 15 عٍ مَن نَشَ سْنشْ، «عَ قَشَ! عَ قَشَ! عَ بَنبَن وُرِ مَفَلَنبُشِ مَ!» ثِلَتِ نَشَ عَ قَلَ، «ﭑ شَ وٌ شَ مَنفّ قَشَ وُرِ مَفَلَنبُشِ مَ؟» سّرّشّدُبّ كُنتِفِيٍ نَشَ عَ يَابِ، «مَنفّ يٌ مُ نَ مُشُ تَن بّ بَقٍ رْ مَ مَنفّ شُنفبٍ رَ!»  
\v 16 نَ تّمُي عَ نَشَ عِسَ سَ عٍ سَفٌي، عَ يَامَرِ قِ عِسَ شَ بَنبَن وُرِ مَفَلَنبُشِ مَ. 
\s1 عِسَ بَنبَنقٍ وُرِ مَفَلَنبُشِ مَ 
\r مَتِيُ ٢٧‏؛٣٢ ٬ ٤٤، مَرَكِ ١٥‏؛٢١ ٬ ٣٢، لُكِ ٢٣‏؛٢٦ ٬ ٤٣ 
\p سْورِيٍ تٌ عِسَ سُشُ،  
\v 17 عٍ نَشَ عَ رَ مِنِ تَا كُي سِفَقٍ رَ «شُن كٌنكٌتَ يِرٍ،» نَشَن شِلِ قَلَمَ عٍبُرُ شُي «فٌلٌفٌتَ.» عِسَ نَشَ سِفَ نَا، عَ وُرِ مَفَلَنبُشِ رَتٍشِ عَ مَ.  
\v 18 عٍ عِسَ بَنبَن وُرِ مَفَلَنبُشِ مَ مّننِ نّ. عٍ نَشَ مِشِ قِرِن فبّتّ قَن بَنبَن، عٍ كٍرٍن تِ يِرٍقَنيِ مَ، عٍ بٌورٍ تِ كْولَ مَ، عٍ عِسَ تِ عٍ تَفِ.  
\v 19 ثِلَتِ نَشَ يَامَرِ قِ عَ يِ سّبّلِ شَ فبَكُ عِسَ شُن مَ وُرِ مَفَلَنبُشِ مَ، «عِسَ نَسَرّتِكَ، يُوِقِيٍ شَ مَنفّ».  
\v 20 يُوِقِ فبٍفبٍ نَشَ نَ سّبّلِ شَرَن، بَرِ مَ عِسَ نُ بَنبَنشِ دّننَشّ، نَ مَكْرّ تَا رَ. نَ سّبّلِ قَن نُ سّبّشِ عٍبُرُ شُي، لَتّنِ شُي، عَ نُن فِرّكِ شُي.  
\v 21 نَ كُي، سّرّشّدُبّ كُنتِفِيٍ نَشَ عَ قَلَ ثِلَتِ بّ، «عِ نَشَ عَ سّبّ ‹يُوِقِيٍ شَ مَنفّ›. عِ شَ عَ سّبّ نّ، ‹يِ شّمّ عَ قَلَ نّ، عَ يُوِقِيٍ شَ مَنفّ نَن عَ رَ.›»  
\v 22 ثِلَتِ نَشَ عٍ يَابِ، «ﭑ نَشَن سّبّشِ، ﭑ بَرَ فّ نَ سّبّدٍ.» 
\p  
\v 23 سْورِيٍ تٌ فّ عِسَ بَنبَندٍ، عٍ نَشَ عَ شَ دُفِيٍ تٌنفٌ، عٍ عٍ عِتَشُن نَ سْورِ نَانِ مَ. عٍ نَشَ عَ شَ دٌنمَ قَرِ عِفٌرٌي قَن تٌنفٌ. نَ دٌنمَ تٌ مُ نُ دّفّشِ،  
\v 24 عٍ نَشَ عَ قَلَ عٍ بٌرٍ بّ، «وٌن نَشَ عَ عِبْو. وٌن شَ عَ تٌنفٌمَ سُفَندِ بٍرٍ ندٍ رَ.» نَ بِرِن نَبَ نّ، عَلَكٌ نَشَن سّبّشِ كِتَابُي كُي، نَ شَ رَكَمَلِ؛ 
\q1 «عٍ بَرَ ﭑ مَ دُفِيٍ عِتَشُن عٍ بٌرٍ مَ، 
\q1 عٍ ﭑ مَ دٌنمَ تٌنفٌمَ سُفَندِ بٍرٍ رَ.» 
\m سْورِيٍ عَ رَبَ نَ كِ نّ. 
\p  
\v 25 عِسَ نفَ قَن نُ نَ عَ شَ وُرِ مَفَلَنبُشِ قّ مَ، عَ نُن عَ نفَ شُنيَ. كٌلٌثَ شَ فِنّ مَرِيَمَ، نُن مَرِيَمَ مَفِدَلَكَ قَن نُ نَ مّننِ.  
\v 26 عِسَ تٌ عَ نفَ تٌ عَ قْشِرَبِرّ مَشَنُشِ قّ مَ، عَ نَشَ عَ قَلَ عَ نفَ بّ، «ﭑ نفَ، يِ بَرَ قِندِ عِ شَ دِ رَ.»  
\v 27 عَ نَشَ قَ عَ قَلَ عَ قْشِرَبِرّ قَن بّ، «عَ مَتٌ، عِ نفَ نَن يَ.» كٍلِ نَ وَشَتِ مَ، نَ قْشِرَبِرّ نَشَ عِسَ نفَ شَنِن عَ شْنيِ. 
\s1 عِسَ شَ قَشّ 
\r مَتِيُ ٢٧‏؛٤٥ ٬ ٥٦، مَرَكِ ١٥‏؛٣٣ ٬ ٤١، لُكِ ٢٣‏؛٤٤ ٬ ٤٩ 
\p  
\v 28 نَ شَنبِ، عِسَ تٌ نُ عَ كٌلٌن عَ قٍ بِرِن بَرَ كَمَلِ، عَ نَشَ عَ قَلَ، «يٍ شْلِ نَ ﭑ مَ.» عَ نَ قَلَ نّ عَلَكٌ كِتَابُي شَ مَسٍنيِ شَ كَمَلِ.  
\v 29 سٍ سَسٍ ندٍ نُ نَ مّننِ، نَشَن نُ رَقٍشِ وّنِ مُلُشُنشِ رَ. عٍ نَشَ سٍ ندٍ رَ سِن نَ وّنِ عِ، عٍ عَ شِرِ هِسٌثِ وُرِ كُيٍ رَ، عٍ عَ مَسٌ عِسَ دّ رَ.  
\v 30 عَ تٌ ندٍ مِن، عَ نَشَ عَ قَلَ، «عَ بِرِن بَرَ كَمَلِ!» عَ نَشَ عَ شُن سِن، عَ قَ لَاشِرَ. 
\p  
\v 31 نَ لْشْي يُوِقِيٍ نُ سٍيٍ رَقَلَمَ سَيَمَلٍكّ دَنفِ سَلِ شَ قٍ رَ. عٍ مُ تِن قُرٍيٍ شَ لُ وُرِ مَفَلَنبُشِ مَ نَ مَلَبُ لْشْي، بَرِ مَ سَلِ شُنفبٍ نَن نُ عَ رَ. نَ كُي، عٍ نَشَ ثِلَتِ مَيَندِ عَ شَ نَ مِشِ بَنبَنشِيٍ سَنيِيٍ فِرَ، عَلَكٌ عٍ شَ قَشَ مَقُرٍن، عٍ شَ بَ نَ.  
\v 32 سْورِيٍ نَشَ قَ، عٍ قَ نَ مِشِ قِرِنيِ سَنيِيٍ فِرَ، نَشٍيٍ نُ بَنبَنشِ عِسَ يِرٍقَنيِ مَ، عَ نُن عَ كْولَ مَ.  
\v 33 كْنْ عٍ تٌ عِسَ لِ، عٍ نَشَ عَ تٌ عَ حَن بَرَ قَشَ. نَ كُي، عٍ مُ عَ تَن سَنيِيٍ فِرَ،  
\v 34 كْنْ سْورِ ندٍ نَشَ عَ سّيتِ سْشْ تَنبّ رَ، يٍ نُن وُلِ نَشَ مِنِ كٍرٍن نَ.  
\v 35 نَشَن نَ قٍ تٌشِ، عَ بَرَ نَ قٍ سٍيدٍ بَ. عَ شَ سٍيدٍحْشْيَ قِندِشِ نْندِ نَن نَ. عَ تَن يّتّ عَ كٌلٌن، عَ عَ نَ نْندِ نَن قَلَقٍ وٌ بّ، عَلَكٌ وٌ قَن شَ دَنشَنِيَ.  
\v 36 نَ قٍيٍ رَبَ نّ عَلَكٌ كِتَابُي شَ مَسٍنيِ شَ كَمَلِ، نَشَن عَ مَسٍنشِ، «عَ شْرِ كٍرٍن مُ فِرَ مَ.»  
\v 37 عَ مَن سّبّشِ يِرٍ فبّتّ، «عٍ عٍ يَ تِمَ نّ مِشِ رَ، عٍ بَرَ نَشَن سْشْ.» 
\s1 عِسَ شَ مَرَفَتّ 
\r مَتِيُ ٢٧‏؛٥٧ ٬ ٦٦، مَرَكِ ١٥‏؛٤٢ ٬ ٤٧، لُكِ ٢٣‏؛٥٠ ٬ ٥٦ 
\p  
\v 38 نَ قٍ بِرِن شَنبِ، يُسُقُ عَرِ مَتٍكَ نَشَ سَ عِسَ قُرٍ مَشَندِ ثِلَتِ مَ. عِسَ قْشِرَبِرّ ندٍ نَن نُ عَ رَ، كْنْ عَ مُ نُ عَ مَسٍنمَ كّنّ مَ، عَ تٌ نُ فَاشُشِ يُوِقِ كُنتِفِيٍ يَ رَ. ثِلَتِ تٌ تِن، يُسُقُ نَشَ سَ عِسَ قُرٍ تٌنفٌ.  
\v 39 نِكٌدٍ مُ، نَشَن نُ بَرَ سِفَ عِسَ يِرٍ فُندٌ كُي كْي رَ تّمُي دَنفِشِ، نَ قَن نَشَ لَبُندّ كِلٌ تٌنفٌ سَشَن مِرِ نُن عَلٌوٍ دَاشِ شَنِن عِسَ قُرٍ يِرٍ.  
\v 40 عٍ نَشَ عِسَ قُرٍ مَقِلِن دُفِيٍ رَ، عٍ لَبُندّ سَ عَ مَ، عَلْ يُوِقِيٍ دَرِشِ عَ رَ كِ نَشّ.  
\v 41 بْشِ ندٍ نُ مَكْرّ عِسَ قَشَدٍ رَ، فَبُرِ نّينّ نُ بَرَ يَءِلَن دّننَشّ. قُرٍ يٌ مُ نُ رَفَتَشِ عَ كُي سِندٍن.  
\v 42 عٍ نَشَ عِسَ رَفَتَ نَ يِرٍ مَكْرّشِ، بَرِ مَ عٍ فبَتَشِ سَيَمَلٍكّ دَنفِ سَلِ شَ قٍ رَ. عَ نُ لَن نّ يُوِقِيٍ شَ فّ قٍ بِرِن يَءِلَندٍ بٍينُن كْي شَ سٌ نَ لْشْي. 
\c 20  
\s1 عِسَ شَ مَرَكٍلِ 
\r مَتِيُ ٢٨‏؛١ ٬ ٨، مَرَكِ ١٦‏؛١ ٬ ٨، لُكِ ٢٤‏؛١ ٬ ١٢ 
\p  
\v 1 سَندٍ لْشْي مَرِيَمَ مَفِدَلَكَ نَشَ سِفَ فَبُرِ يِرٍ سُبَشّ مَ بٍينُن كُيٍ شَ مَيَلَن. عَ تٌ مّننِ لِ، عَ نَشَ عَ تٌ نَ فّمّ شُنفبٍ نُ بَرَ بَ فَبُرِ دّ مَ.  
\v 2 نَ كُي، عَ نَشَ سِفَ عَ فِ رَ سِمْن ثِيّرِ نُن عِسَ قْشِرَبِرّ بٌورٍ يِرٍ، عِسَ نُ نَشَن شَنُشِ، عَ عَ قَلَ عٍ بّ، «عٍ بَرَ مَرِفِ قُرٍ تٌنفٌ فَبُرِ كُي، مُشُ قَن مُ عَ كٌلٌن عٍ عَ سَشِ دّدّ.»  
\v 3 نَ كُي، ثِيّرِ نُن عِسَ نَ قْشِرَبِرّ بٌورٍ قَن نَشَ مِنِ سِفَقٍ رَ فَبُرِ يِرٍ.  
\v 4 عٍ قِرِنيِ نَشَ سِفَ عٍ فِ رَ، كْنْ عِسَ قْشِرَبِرّ مَشَنُشِ نَشَ فَبُرِ لِ بٍينُن ثِيّرِ سِنفٍ شَ نَا لِ.  
\v 5 عَ تٌ عَ قٍلٍن عَلَكٌ عَ شَ فَبُرِ كُي مَتٌ، عَ نَشَ كَسَنفٍ دُفِيٍ تٌ، كْنْ عَ مُ سٌ نَ كُي.  
\v 6 سِمْن ثِيّرِ تٌ مّننِ لِ، عَ نَشَ سٌ قْنمّ كُي كٍرٍن نَ، عَ قَ دُفِ بٍنتٍنيِ تٌ نَشَن نُ سَشِ عِسَ قُرٍ مَ،  
\v 7 عَ نُن دُفِ نَشَن نُ مَكُنقُكُنقُشِ عِسَ يَتَفِ مَ. نَ دُفِ نُ سَشِ عَ شَتِ مَ، عَ سَ كِ يَءِلَنشِ عَ قَنيِ رَ.  
\v 8 نَ تّمُي، عِسَ قْشِرَبِرّ بٌورٍ، نَشَن سِنفٍ فَبُرِ يِرٍ لِ، عَ قَن نَشَ سٌ نَ كُي. عَ نَشَ عَ بِرِن تٌ، عَ دَنشَنِيَ.  
\v 9 عٍ مُ نُ قَهَامُي سْتْشِ كِتَابُي شَ مَسٍنيِ مَ سِندٍن، قَ قَلَ عَ قٌ عَلَ شَ مِشِ سُفَندِشِ شَ كٍلِ قَشّ مَ.  
\v 10 نَ دَنفِ شَنبِ نَ قْشِرَبِرّ قِرِنيِيٍ نَشَ فبِلٍن عٍ شْنيِ. 
\s1 عِسَ مِنِقٍ مَرِيَمَ مَفِدَلَكَ مَ 
\r مَرَكِ ١٦‏؛٩ ٬ ١١ 
\p  
\v 11 مَرِيَمَ تٌ نُ تِشِ فَبُرِ سٌدٍ دّ رَ، عَ نُ نَ وَقٍ. عَ تٌ عَ قٍلٍن عَ شَ فَبُرِ كُي مَتٌ،  
\v 12 عَ نَشَ مَلٍكّ قِرِن تٌ. عٍ مَشِرِشِ دُفِ قِيشّ رَ، عٍ دْشْشِ عِسَ قُرٍ نُ سَشِ دّننَشّ. كٍرٍن نُ نَ عَ شُنسَدٍ رَ، بٌورٍ نُ نَ عَ سَنلَابٍ رَ.  
\v 13 عٍ نَشَ مَرِيَمَ مَشْرِن، «ﭑ مَ دِ، عِ وَقٍ مُنقٍ مَ؟» عَ نَشَ عٍ يَابِ، «عٍ بَرَ ﭑ مَرِفِ قُرٍ تٌنفٌ، ﭑ مُ عَ كٌلٌن عٍ عَ سَشِ دّدّ.» 
\p  
\v 14 عَ تٌ فّ نَ قَلَدٍ، عَ نَشَ عَ كٌبٍ رَتٌ، عَ قَ مِشِ ندٍ تٌ، عَ تِشِ نَا. عَ مُ عَ كٌلٌن عَ عِسَ نَن عَ رَ.  
\v 15 عِسَ نَشَ عَ مَشْرِن، «ﭑ مَ دِ، عِ وَ مَ مُنقٍ رَ؟ عِ نَ ندٍ قٍنقٍ؟» مَرِيَمَ حْشْ عَ مَ، سَنسِ مّينِمَ نَن نُ عَ رَ. نَ كُي، عَ نَشَ عَ يَابِ، «ﭑ بَ، شَ عِ تَن نَن نَ قُرٍ تٌنفٌشِ، عِ شَ نَ يِرٍ مَسٍن ﭑ بّ عَلَكٌ ﭑ شَ سِفَ عَ تٌنفٌدٍ.»  
\v 16 عِسَ نَشَ عَ قَلَ عَ بّ، «مَرِيَمَ.» مَرِيَمَ تٌ عَ مَقِندِ، عَ نَشَ عَ رَتِن، «رَبُنِ!» نَ نَن قَلَشِ عٍبُرُ شُي، «كَرَ مْشْ».  
\v 17 عِسَ نَشَ عَ قَلَ عَ بّ، «عِ نَشَ عِ بّلّشّ دِن ﭑ نَ، بَرِ مَ ﭑ مُ نُ تٍ بَبَ عَلَ يِرٍ سِندٍن. سِفَ ﭑ نفَشَكٍرٍنيِيٍ يِرٍ، عِ عَ قَلَ عٍ بّ، عَ ﭑ قَقٍ تٍدٍ ﭑ بَبَ شْنيِ، ﭑ مَرِفِ عَلَ نَشَن قِندِشِ وٌ قَن بَبَ رَ، وٌ قَن مَرِفِ عَلَ.» 
\p  
\v 18 مَرِيَمَ مَفِدَلَكَ نَشَ سِفَ شِبَارُ رَ عِسَ قْشِرَبِرّيٍ يِرٍ، عَ عَ قَلَ عٍ بّ، «ﭑ بَرَ مَرِفِ تٌ!» عَ مَن نَشَ عِسَ شَ شّيرَ عِبَ عٍ بّ. 
\s1 عِسَ مِنِقٍ عَ قْشِرَبِرّيٍ مَ 
\r مَتِيُ ٢٨‏؛١٦ ٬ ٢٠، مَرَكِ ١٦‏؛١٤ ٬ ١٨، لُكِ ٢٤‏؛٣٦ ٬ ٤٩ 
\p  
\v 19 نَ سَندٍ لْشْي كٍرٍنيِ، عِسَ قْشِرَبِرّيٍ نُ مَلَنشِ بَنشِ كُي نُنمَرٍ رَ، نَادّ بِرِن مَبَلَنشِ يُوِقِ كُنتِفِيٍ شَ يَرَفَاشُي مَ. عِسَ نَشَ مِنِ عٍ مَ، عَ تِ عٍ تَفِ، عَ عَ قَلَ، «عَلَ شَ وٌ بْحّ سَ.»  
\v 20 عَ تٌ نَ قَلَ عٍ بّ، عَ نَشَ عَ بّلّشّيٍ نُن عَ سّيتِ مَسٍن عٍ بّ. عٍ نَشَ سّيوَ مَرِفِ تٌقٍ رَ.  
\v 21 عِسَ مَن نَشَ عَ مَسٍن عٍ بّ، «بْحّسَ شَ لُ وٌ بّ. ﭑ بَرَ وٌ شّي عَلْ بَبَ عَلَ ﭑ شّيشِ كِ نَشّ.»  
\v 22 عَ تٌ فّ نَ قَلَدٍ، عَ نَشَ قٌيٍ قٍلُن عٍ مَ، عَ عَ قَلَ، «وٌ شَ لُ عَلَ شَشِلِ سّنِيّنشِ شَ فٌرٌ وٌ مَ.  
\v 23 شَ وٌ دِحّ مِشِ هَاكّ مَ، نَ هَاكّ بَرَ حْن، كْنْ شَ وٌ مُ دِحّ، نَ هَاكّ لُمَ عَ مَ.» 
\s1 تٌمَسِ عِسَ تٌقٍ 
\p  
\v 24 عِسَ مِنِ عَ شَ شّيرَ قُ نُن قِرِنيِيٍ مَ تّمُي نَشّ، تٌمَسِ، عٍ نَشَن شِلِمَ «فُلِ»، عَ مُ نُ نَ عٍ يَ مَ مّننِ.  
\v 25 نَ كُي، بٌورٍيٍ نَشَ عَ قَلَ عَ بّ، «مُشُ بَرَ مَرِفِ تٌ!» كْنْ عَ تَن نَشَ عٍ يَابِ، «شَ ﭑ تَن مُ لَنتُمَ قْشِ تٌ عَ بّلّشّ كُي، ﭑ نَن ﭑ بّلّشّسٌلٍ رَ سٌ نَا، شَ ﭑ مَن مُ ﭑ بّلّشّ سَ عَ سّيتِ مَ عٍ دّننَشّ سْشْ، ﭑ تَن مُ لَمَ عَ رَ قٍوٌ!» 
\p  
\v 26 شِ سٌلٌمَسَشَن دَنفِ شَنبِ، عِسَ قْشِرَبِرّيٍ مَن تٌ نُ مَلَنشِ بَنشِ كُي، تٌمَسِ نُ نَ عٍ يَ مَ. هَلِ نَادّ بِرِن تٌ نُ مَبَلَنشِ، عِسَ نَشَ مِنِ عٍ مَ مّننِ، عَ تِ عٍ تَفِ، عَ عٍ شّيبُ، «بْحّسَ شَ لُ وٌ بّ.»  
\v 27 نَ تّمُي، عِسَ نَشَ عَ قَلَ عَ بّ، «ﭑ بّلّشّ مَتٌ. عِ شَ عِ بّلّشّسٌلٍ سَ ﭑ سّيتِ مَ عٍ دّننَشّ سْشْ. عِ نَشَ تّفّ ﭑ عِ. عِ شَ دَنشَنِيَ.»  
\v 28 تٌمَسِ نَشَ عَ قَلَ عَ بّ، «ﭑ مَرِفِ عَلَ!»  
\v 29 عِسَ نَشَ عَ مَسٍن عَ بّ، «عِ دَنشَنِيَشِ نّ، عِ تٌ بَرَ ﭑ تٌ؟ هّيرِ نَ مِشِيٍ بّ نَشٍيٍ بَرَ دَنشَنِيَ، هَلِ عٍ مُ ﭑ تٌشِ.» 
\s1 يِ كِتَابُي سّبّ قٍ نَشَن مَ 
\p  
\v 30 عِسَ كَابَنَكٌ فبٍفبٍ رَبَ نّ عَ قْشِرَبِرّيٍ يَ شْرِ، نَشٍيٍ مُ سّبّشِ يِ كِتَابُي كُي.  
\v 31 كْنْ نَشٍيٍ شَ قٍ تَن سّبّشِ يِ كِ، عٍ سّبّشِ نّ عَلَكٌ وٌ شَ لَ عَ رَ، عَ عِسَ نَن نَ عَلَ شَ مِشِ سُفَندِشِ رَ، عَلَ شَ دِ. نَ كُي، وٌ نَ دَنشَنِيَ عَ مَ، وٌ كِسِ سْتْمَ نّ عَ سَابُي رَ. 
\c 21  
\s1 عِسَ مِنِقٍ عَ قْشِرَبِرّ ندٍيٍ مَ 
\p  
\v 1 نَ قٍيٍ دَنفِ شَنبِ، عِسَ مَن نَشَ مِنِ عَ قْشِرَبِرّيٍ مَ تِبٍرِيَسِ بَا دّ رَ. عَ عَ يّتّ مَكّنّن عٍ بّ يِ كِ نّ.  
\v 2 سِمْن ثِيّرِ، تٌمَسِ عٍ نَشَن شِلِمَ «فُلِ،» نَتَنَيّلِ نَشَن كٍلِ كَانَ تَا فَلِلٍ بْشِ مَ، سٍبٍدٍ شَ دِيٍ، نُن عِسَ قْشِرَبِرّ قِرِن فبّتّيٍ، نٍيٍ بِرِن نُ نَ يِرٍ كٍرٍن.  
\v 3 سِمْن ثِيّرِ نَشَ عَ قَلَ عٍ بّ، «ﭑ تَن سِفَقٍ يّشّ سُشُدٍ.» عٍ نَشَ عَ قَلَ عَ بّ، «وٌن بِرِن نَ عَ رَ.» نَ كُي، عٍ نَشَ مِنِ، عٍ بَكِ كُنكُي كُي، كْنْ نَ كْي بِرِن نَ، عٍ مُ سٍسٍ سُشُ. 
\p  
\v 4 كُيٍ تٌ نُ عِبَقٍ، عِسَ نُ تِشِ بَا دّ رَ، كْنْ عَ قْشِرَبِرّيٍ مُ نُ عَ كٌلٌن عَ عَ تَن نَن عَ رَ.  
\v 5 عِسَ نَشَ عٍ مَشْرِن، «ﭑ مَ دِيٍ، وٌ بَرَ يّشّ ندٍ سْتْ؟» عٍ نَشَ عَ يَابِ، «عَدٍ، مُشُ مُ سٍسٍ سُشُشِ.»  
\v 6 عَ نَشَ عَ قَلَ عٍ بّ، «وٌ يّلّ وٌلِ كُنكُي يِرٍقَنيِ مَ، وٌ عَ ندٍ سْتْمَ نّ.» عٍ تٌ عَ وٌلِ، عٍ مُ نُ نْمَ يّلّ رَتٍدٍ، بَرِ مَ يّشّ فبٌ عَ كُي.  
\v 7 نَ كُي، عِسَ قْشِرَبِرّ، عَ نَشَن شَنُشِ، عَ نَشَ عَ قَلَ ثِيّرِ بّ، «وٌن مَرِفِ نَ عَ رَ.» سِمْن ثِيّرِ تٌ نَ مّ، عَ نَشَ دٌنمَ رَفٌرٌ عَ مَ، عَ بَفَن يٍ مَ سِفَقٍ رَ عِسَ يِرٍ.  
\v 8 بٌورٍيٍ قَن نَشَ عَ لِ كُنكُي كُي، يّلّ نَشَن نَقٍشِ يّشّيٍ رَ، عَ شِرِشِ كُنكُي رَ. عٍ مُ نُ مَكُيَ شَرٍ دّ رَ، قٌ نْنفْن كّمّ قِرِن حْندْن. 
\p  
\v 9 عٍ تٌ تٍ شَرٍ دّ رَ، عٍ نَشَ تّ شُرُشِ تٌ، يّشّ سَشِ عَ تّ وٌلٍ رَ، تَامِ قَن نَ نَ.  
\v 10 عِسَ نَشَ عَ قَلَ عٍ بّ، «وٌ قَ يّشّ ندٍ رَ وٌ بَشِ نَشَن سُشُدٍ.»  
\v 11 نَ كُي سِمْن ثِيّرِ نَشَ تٍ كُنكُي كُي، عَ يّلّ بّندُن شَرٍ مَ. عَ نُ رَقٍشِ يّشّ شُنفبٍيٍ نَن نَ، عَ فُندِ كّمّ تٌنفٌ سُولِ نُن سَشَن. كْنْ هَلِ يّشّ تٌ نُ فبٌشِ يّلّ كُي نَ كِ، يّلّ مُ عِبْو. 
\p  
\v 12 عِسَ نَشَ عَ قَلَ عٍ بّ، «وٌ قَ وٌ دّفٍ.» عَ قْشِرَبِرّيٍ مُ سُو سَ عَ مَشْرِندٍ ندٍ عَ رَ، بَرِ مَ بِرِن نُ عَ كٌلٌن مَرِفِ نَن عَ رَ.  
\v 13 عِسَ نَشَ قَ تَامِ تٌنفٌ، عَ عَ عِتَشُن عٍ مَ، عَ مَن نَشَ يّشّ سٌ عٍ يِ رَ.  
\v 14 عَ سَشَن ندٍ نَن نُ نَ كِ، عِسَ عَ يّتّ مَسٍنمَ عَ قْشِرَبِرّيٍ بّ، كَبِ عَ كٍلِ قَشّ مَ. 
\s1 عِسَ نُن ثِيّرِ 
\p  
\v 15 عٍ تٌ فّ عٍ دّ عِبَدٍ، عِسَ نَشَ سِمْن ثِيّرِ مَشْرِن، «سِمْن، يَيَ شَ دِ، عِ ﭑ شَنُشِ دَنفِ يٍيٍ بِرِن نَ؟» عَ نَشَ عَ يَابِ، «عِيٌ، مَرِفِ. عِ تَن عَ كٌلٌن ﭑ عِ شَنُشِ كِ نَشّ.» عِسَ نَشَ عَ قَلَ عَ بّ، «مّينِ ﭑ مَ يّشّي يْرّيٍ مَ.»  
\v 16 عَ مَن نَشَ فبِلٍن عَ مَشْرِن نَ عَ قِرِن ندٍ، «سِمْن، يَيَ شَ دِ، عِ ﭑ شَنُشِ؟» عَ نَشَ عَ يَابِ، «عِيٌ، مَرِفِ. عِ تَن عَ كٌلٌن ﭑ عِ شَنُشِ كِ نَشّ.» عِسَ نَشَ عَ قَلَ عَ بّ، «مّينِ ﭑ مَ يّشّييٍ مَ.»  
\v 17 عَ مَن نَشَ فبِلٍن عَ مَشْرِن نَ عَ سَشَن ندٍ، «سِمْن، يَيَ شَ دِ، عِ ﭑ شَنُشِ؟» ثِيّرِ نَشَ سُننُن عِسَ تٌ عَ مَشْرِن سَنمَيَ سَشَن ندٍ، «عِ ﭑ شَنُشِ؟» عَ نَشَ عَ يَابِ، «مَرِفِ، عِ تَن قٍ بِرِن كٌلٌن. عِ تَن عَ كٌلٌن ﭑ عِ شَنُشِ كِ نَشّ.» عِسَ نَشَ عَ قَلَ عَ بّ، «مّينِ ﭑ مَ يّشّييٍ مَ.  
\v 18 ﭑ شَ نْندِ يَتِ نَن قَلَ عِ بّ، عِ قٌنِكٍ تّمُي، عِ تَن نَن نُ عِ يّتّ تَفِ عِشِرِ مَ، عِ وَ سِفَقٍ دّدّ، عِ سِفَ. كْنْ عِ نَ قٌرِ، عِ عِ بّلّشّ عِتَلَمَ نّ، مِشِ فبّتّ عِ تَفِ شِرِ، عَ عِ شَنِن يِرٍ عِ مُ وَ مَ سِفَقٍ دّننَشّ.»  
\v 19 عِسَ نَ قَلَ نّ عَلَكٌ عَ شَ ثِيّرِ قَشَ كِ نَن مَسٍن، ثِيّرِ قَمَ عَلَ مَتْشْدٍ نَشَن سَابُي رَ. عَ نَ قَلَ شَنبِ، عَ نَشَ عَ قَلَ ثِيّرِ بّ، «بِرَ ﭑ قْشْ رَ.» 
\s1 عِسَ نُن عَ قْشِرَبِرّ مَشَنُشِ 
\p  
\v 20 ثِيّرِ تٌ عَ كٌبٍ رَتٌ، عَ نَشَ عِسَ قْشِرَبِرّ تٌ عٍ قْشْ رَ، عِسَ نُ نَشَن مَشَنُشِ. سَيَمَلٍكّ دَنفِ سَلِ، عَ تَن نَن عَ مَسٌ عِسَ رَ عٍ دّفٍ تّمُي، عَ عَ مَشْرِن، «مَرِفِ، ندٍ قَمَ عِ يَنقَدٍ؟»  
\v 21 ثِيّرِ تٌ عَ تٌ، عَ نَشَ عِسَ مَشْرِن، «مَرِفِ، نَ تَن فٌ؟»  
\v 22 عِسَ نَشَ عَ يَابِ، «شَ ﭑ وَ مَ عَ شَ سِمَيَ شَ بُ هَن ﭑ فبِلٍن تّمُي، نَ مُنسٍ قَنمَ عِ تَن مَ؟ عِ تَن شَ بِرَ ﭑ قْشْ رَ.»  
\v 23 نَ كُي، دَنشَنِيَتْي ندٍيٍ حْشْ نَشَ لُ عَ مَ عَ نَ قْشِرَبِرّ تَن مُ قَشَمَ، كْنْ عِسَ مُ نَ قَلَ. عَ عَ قَلَ نّ، «شَ ﭑ وَ مَ عَ شَ سِمَيَ شَ بُ هَن ﭑ فبِلٍن تّمُي، نَ مُنسٍ قَنمَ عِ تَن مَ؟» 
\s1 سّبّلِ دْنشْي 
\p  
\v 24 نَ قْشِرَبِرّ يَتِ نَن يِ قٍ بِرِن سّبّ، عَ قِندِ سٍيدٍ قَنيِ رَ. مُشُ عَ كٌلٌن عَ شَ سٍيدٍحْشْيَ قِندِشِ نْندِ نَن نَ. 
\p  
\v 25 عِسَ قٍ فبٍفبٍ رَبَ نّ نَشٍيٍ مُ سّبّشِ يِ كِتَابُي كُي. شَ نَ بِرِن سّبّ نّ نُ، ﭑ لَشِ عَ رَ عَ نَ كِتَابُييٍ بِرِن سَدٍ مُ سْتْمَ دُنِحَ مَ نُ.