\id 1CH  
\h 1 Crónicas 
\toc3 1 Cr 
\toc2 1 Crónicas 
\toc1 Primer libro de las Crónicas 
\mt1 1 Crónicas  
\c 1  
\s1 Genealogías importantes para Israel  
\p
\v 1 Adam, Set, Enós,  
\v 2 \w Cainán|strong="H7018"\w*, \w Mahalaleel|strong="H4111"\w*, \w Jared|strong="H3382"\w*,  
\v 3 Enoc, Matusalén, Lamec,  
\v 4 \add Hijos de\add* \w Noé|strong="H5146"\w*: \w Sem|strong="H8035"\w*, Cam y Jafet.   
\p
\v 5 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* Jafet: \w Gomer|strong="H1586"\w*, \w Magog|strong="H4031"\w*, Madai, \w Javán|strong="H3120"\w*, \w Tubal|strong="H8422"\w*, \w Mesec|strong="H4902"\w* y Tiras.  
\v 6 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Gomer|strong="H1586"\w*: Askenaz, Rifat y Togarma.  
\v 7 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Javán|strong="H3120"\w*: Elisa, \w Tarsis|strong="H8659"\w*, Quitim y Dodanim.   
\p
\v 8 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* Cam: Cus, Mizraim, Fut y \w Canaán|strong="H3667"\w*.  
\v 9 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* Cus: \w Seba|strong="H7614"\w*, \w Havila|strong="H2341"\w*, Sabta, Raama y Sabteca. \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* Raama: \w Seba|strong="H7614"\w* y \w Dedán|strong="H1719"\w*.  
\v 10 Cus \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Nimrod, \w quien|strong="H1931"\w* \w fue|strong="H1961"\w* \w poderoso|strong="H1368"\w* en \w la|strong="H1931"\w* tierra.  
\v 11 Mizraim \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Ludim, Anamim, Lehabim, Naftuhim,  
\v 12 Patrusim, los Casluhim, de quienes proceden los \w filisteos|strong="H6430"\w*, y los caftoreos.  
\v 13 \w Canaán|strong="H3667"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Sidón|strong="H6721"\w*, su \w primogénito|strong="H1060"\w*, y \w a|strong="H3068"\w* Het,  
\v 14 y al \w jebuseo|strong="H2983"\w*, al amorreo, al gergeseo,  
\v 15 al \w heveo|strong="H2340"\w*, al araceo, al sineo,  
\v 16 al arvadeo, al Zemareo y al hamateo.   
\p
\v 17 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Sem|strong="H8035"\w*: \w Elam|strong="H5867"\w*, Asur, Arfaxad, \w Lud|strong="H3865"\w*, Aram, \w Uz|strong="H5780"\w*, \w Hul|strong="H2343"\w*, Geter y \w Mesec|strong="H4902"\w*.  
\v 18 Arfaxad \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Sela|strong="H7974"\w*, y \w Sela|strong="H7974"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Heber|strong="H5677"\w*.  
\v 19 \w A|strong="H3068"\w* \w Heber|strong="H5677"\w* le \w nacieron|strong="H3205"\w* \w dos|strong="H8147"\w* \w hijos|strong="H1121"\w*: \w el|strong="H3588"\w* \w nombre|strong="H8034"\w* del uno fue \w Peleg|strong="H6389"\w*, \w porque|strong="H3588"\w* \w en|strong="H3588"\w* sus \w días|strong="H3117"\w* fue dividida \w la|strong="H3588"\w* tierra. \w El|strong="H3588"\w* \w nombre|strong="H8034"\w* \w de|strong="H3588"\w* \w su|strong="H3588"\w* hermano fue \w Joctán|strong="H3355"\w*.  
\v 20 \w Joctán|strong="H3355"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Almodad, Selef, Hazar-mavet, y Jera,  
\v 21 Adonirán, Uzal, \w Dicla|strong="H1853"\w*,  
\v 22 \w Ebal|strong="H5858"\w*, Abimael, \w Seba|strong="H7614"\w*,  
\v 23 Ofir, \w a|strong="H3068"\w* \w Havila|strong="H2341"\w* y \w Jobab|strong="H3103"\w*. \w Todos|strong="H3605"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Joctán|strong="H3355"\w*.  
\v 24 De \w Sem|strong="H8035"\w*: Arfaxad, \w Sela|strong="H7974"\w*,  
\v 25 \w Heber|strong="H5677"\w*, \w Peleg|strong="H6389"\w*, \w Reu|strong="H7466"\w*,  
\v 26 \w Serug|strong="H8286"\w*, Nacor, Taré  
\v 27 y Abram, \w el|strong="H1931"\w* \w cual|strong="H1931"\w* \w es|strong="H1931"\w* Abraham.   
\p
\v 28 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* Abraham: \w Isaac|strong="H3327"\w* \w e|strong="H3068"\w* \w Ismael|strong="H3458"\w*.   
\p
\v 29 Éstas son sus generaciones: el \w primogénito|strong="H1060"\w* de \w Ismael|strong="H3458"\w* fue Nebaiot, luego \w Cedar|strong="H6938"\w*, Adbeel, \w Mibsam|strong="H4017"\w*,  
\v 30 \w Misma|strong="H4927"\w*, \w Duma|strong="H1746"\w*, Massa, \w Hadad|strong="H2301"\w*, Tema,  
\v 31 \w Jetur|strong="H3195"\w*, Nafis y Cedema. Tales fueron \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Ismael|strong="H3458"\w*.   
\p
\v 32 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w que|strong="H1121"\w* Cetura, \w concubina|strong="H6370"\w* \w de|strong="H1121"\w* Abraham, dio \w a|strong="H3068"\w* luz fueron: Zimram, \w Jocsán|strong="H3370"\w*, \w Medán|strong="H4091"\w*, \w Madián|strong="H4080"\w*, \w Isbac|strong="H3435"\w* y Súa. \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Jocsán|strong="H3370"\w*: \w Seba|strong="H7614"\w* y \w Dedán|strong="H1719"\w*.  
\v 33 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Madián|strong="H4080"\w*: Efa, Efer, Hanoc, Abida y Elda. \w Todos|strong="H3605"\w* \w éstos|strong="H3605"\w* fueron \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Cetura.   
\p
\v 34 Abraham \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Isaac|strong="H3327"\w*. \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Isaac|strong="H3327"\w*: \w Esaú|strong="H6215"\w* \w e|strong="H3068"\w* \w Israel|strong="H3478"\w*.   
\p
\v 35 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Esaú|strong="H6215"\w*: Elifaz, \w Reuel|strong="H7467"\w*, \w Jeús|strong="H3266"\w*, \w Jaalam|strong="H3281"\w* y \w Coré|strong="H7141"\w*.  
\v 36 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* Elifaz: \w Temán|strong="H8487"\w*, Omar, Zefo, \w Gatam|strong="H1609"\w*, Cenaz, \w Timna|strong="H8555"\w* y \w Amalec|strong="H6002"\w*.  
\v 37 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Reuel|strong="H7467"\w*: Nahat, \w Zera|strong="H2226"\w*, Sama y Miza.   
\p
\v 38 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Seir|strong="H8165"\w*: \w Lotán|strong="H3877"\w*, \w Sobal|strong="H7732"\w*, \w Zibeón|strong="H6649"\w*, \w Aná|strong="H6034"\w*, \w Disón|strong="H1789"\w*, Ezer y Disán.  
\v 39 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Lotán|strong="H3877"\w*: \w Hori|strong="H2753"\w* y Homam. \w Timna|strong="H8555"\w* fue hermana \w de|strong="H1121"\w* \w Lotán|strong="H3877"\w*.  
\v 40 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Sobal|strong="H7732"\w*: Alván, Manahat, \w Ebal|strong="H5858"\w*, Sefo y Onam. \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Zibeón|strong="H6649"\w*: Aja y \w Aná|strong="H6034"\w*.  
\v 41 \w Disón|strong="H1787"\w* fue \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Aná|strong="H6034"\w*. \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Disón|strong="H1787"\w*: Amram, Esbán, Itrán y Querán.  
\v 42 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* Ezer: \w Bilhán|strong="H1092"\w*, \w Zaaván|strong="H2190"\w* y Jaacán. \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* Disán: \w Uz|strong="H5780"\w* y Arán.   
\p
\v 43 Éstos son \w los|strong="H1121"\w* \w reyes|strong="H4428"\w* \w que|strong="H1121"\w* \w reinaron|strong="H4428"\w* en la tierra \w de|strong="H6440"\w* Edom \w antes|strong="H6440"\w* \w de|strong="H6440"\w* haber \w rey|strong="H4428"\w* \w de|strong="H6440"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*: \w Bela|strong="H1106"\w*, \w hijo|strong="H1121"\w* \w de|strong="H6440"\w* Beor, y \w el|strong="H1121"\w* \w nombre|strong="H8034"\w* \w de|strong="H6440"\w* su \w ciudad|strong="H5892"\w* \w era|strong="H1121"\w* Dinaba.  
\v 44 \w Al|strong="H8478"\w* \w morir|strong="H4191"\w* \w Bela|strong="H1106"\w*, \w reinó|strong="H4427"\w* \w en|strong="H8478"\w* su \w lugar|strong="H8478"\w* \w Jobab|strong="H3103"\w*, \w hijo|strong="H1121"\w* \w de|strong="H8478"\w* \w Zera|strong="H2226"\w* \w de|strong="H8478"\w* \w Bosra|strong="H1224"\w*.  
\v 45 \w Al|strong="H8478"\w* \w morir|strong="H4191"\w* \w Jobab|strong="H3103"\w*, \w reinó|strong="H4427"\w* \w en|strong="H8478"\w* su \w lugar|strong="H8478"\w* \w Husam|strong="H2367"\w*, \w de|strong="H8478"\w* la tierra \w de|strong="H8478"\w* los temanitas.  
\v 46 \w Al|strong="H8478"\w* \w morir|strong="H4191"\w* \w Husam|strong="H2367"\w*, \w reinó|strong="H4427"\w* \w en|strong="H8478"\w* su \w lugar|strong="H8478"\w* Hadad, \w hijo|strong="H1121"\w* \w de|strong="H8478"\w* Bedad, \w el|strong="H1121"\w* \w que|strong="H1121"\w* derrotó \w a|strong="H3068"\w* \w Madián|strong="H4080"\w* \w en|strong="H8478"\w* \w el|strong="H1121"\w* \w campo|strong="H7704"\w* \w de|strong="H8478"\w* \w Moab|strong="H4124"\w*. \w El|strong="H1121"\w* \w nombre|strong="H8034"\w* \w de|strong="H8478"\w* su \w ciudad|strong="H5892"\w* fue Avit.  
\v 47 \w Al|strong="H8478"\w* \w morir|strong="H4191"\w* Hadad, \w reinó|strong="H4427"\w* \w en|strong="H8478"\w* su \w lugar|strong="H8478"\w* \w Samla|strong="H8072"\w*, \w de|strong="H8478"\w* Masreca.  
\v 48 \w Al|strong="H8478"\w* \w morir|strong="H4191"\w* \w Samla|strong="H8072"\w*, \w reinó|strong="H4427"\w* \w en|strong="H8478"\w* su \w lugar|strong="H8478"\w* \w Saúl|strong="H7586"\w*, \w de|strong="H8478"\w* Rehobot, que está junto \w al|strong="H8478"\w* Éufrates.  
\v 49 \w Al|strong="H8478"\w* \w morir|strong="H4191"\w* \w Saúl|strong="H7586"\w*, \w reinó|strong="H4427"\w* \w en|strong="H8478"\w* su \w lugar|strong="H8478"\w* \w Baal-hanán|strong="H1177"\w*, \w hijo|strong="H1121"\w* \w de|strong="H8478"\w* Acbor.  
\v 50 \w Al|strong="H8478"\w* \w morir|strong="H4191"\w* \w Baal-hanán|strong="H1177"\w*, \w reinó|strong="H4427"\w* \w en|strong="H8478"\w* su \w lugar|strong="H8478"\w* Hadad. El \w nombre|strong="H8034"\w* \w de|strong="H8478"\w* su \w ciudad|strong="H5892"\w* fue Pai. El \w nombre|strong="H8034"\w* \w de|strong="H8478"\w* su esposa, Mehetabel, \w hija|strong="H1323"\w* \w de|strong="H8478"\w* Matred, \w hija|strong="H1323"\w* \w de|strong="H8478"\w* Mezaab.   
\p
\v 51 Al \w morir|strong="H4191"\w* Hadad, \w sucedieron|strong="H1961"\w* en Edom \w los|strong="H1961"\w* jeques \w Timna|strong="H8555"\w*, Alva, Jetet,  
\v 52 Aholibama, Ela, Pinón,  
\v 53 Cenaz, \w Temán|strong="H8487"\w*, Mibzar,  
\v 54 \w Magdiel|strong="H4025"\w* \w e|strong="H3068"\w* Iram. Tales fueron los jeques de Edom.   
\c 2  
\s1 Descendientes de Israel  
\p
\v 1 Éstos son \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*: \w Rubén|strong="H7205"\w*, \w Simeón|strong="H8095"\w*, \w Leví|strong="H3878"\w*, \w Judá|strong="H3063"\w*, Isacar, \w Zabulón|strong="H2074"\w*,  
\v 2 \w Dan|strong="H1835"\w*, \w José|strong="H3130"\w*, \w Benjamín|strong="H1144"\w*, Neftalí, \w Gad|strong="H1410"\w* y Aser.   
\p
\v 3 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*: \w Er|strong="H6147"\w*, Onán y \w Sela|strong="H7956"\w*. Estos \w tres|strong="H7969"\w* \w le|strong="H5869"\w* \w nacieron|strong="H3205"\w* \w de|strong="H1121"\w* la \w hija|strong="H1323"\w* \w de|strong="H1121"\w* Súa, \w cananea|strong="H3669"\w*. Pero \w Er|strong="H6147"\w*, \w primogénito|strong="H1060"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*, \w fue|strong="H1961"\w* perverso ante \nd \+w Yavé|strong="H3068"\+w*\nd*, Quien lo \w mató|strong="H4191"\w*.  
\v 4 Tamar su \w nuera|strong="H3618"\w* le dio \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* Fares y \w a|strong="H3068"\w* \w Zera|strong="H2226"\w*. \w Todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H2568"\w* \w Judá|strong="H3063"\w* fueron \w cinco|strong="H2568"\w*.   
\p
\v 5 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* Fares: \w Hezrón|strong="H2696"\w* y Hamul.  
\v 6 \w Hijos|strong="H1121"\w* \w de|strong="H2568"\w* \w Zera|strong="H2226"\w*: \w Zimri|strong="H2174"\w*, Etán, \w Hemán|strong="H1968"\w*, Calcol y Dara. \w Todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H2568"\w* Judá fueron \w cinco|strong="H2568"\w*.  
\v 7 \w Hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Carmi|strong="H3756"\w* fue Acán, perturbador \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, porque transgredió en cuanto \w a|strong="H3068"\w* lo maldito.  
\v 8 \w Hijo|strong="H1121"\w* \w de|strong="H1121"\w* Etán: \w Azarías|strong="H5838"\w*.  
\v 9 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w que|strong="H1121"\w* le \w nacieron|strong="H3205"\w* \w a|strong="H3068"\w* \w Hezrón|strong="H2696"\w*: \w Jerameel|strong="H3396"\w*, \w Ram|strong="H7410"\w* y Quelubai.   
\p
\v 10 \w Ram|strong="H7410"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Aminadab|strong="H5992"\w*, y \w Aminadab|strong="H5992"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Naasón|strong="H5177"\w*, \w jefe|strong="H5387"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*.  
\v 11 \w Naasón|strong="H5177"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Salmón, y Salmón \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Booz|strong="H1162"\w*.  
\v 12 \w Booz|strong="H1162"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Obed|strong="H5744"\w*, y \w Obed|strong="H5744"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Isaí|strong="H3448"\w*.  
\v 13 \w Isaí|strong="H3448"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Eliab su \w primogénito|strong="H1060"\w*, el \w segundo|strong="H8145"\w* Abinadab, el \w tercero|strong="H7992"\w* Simea,  
\v 14 el \w cuarto|strong="H7243"\w* Natanael, el \w quinto|strong="H2549"\w* \w Radai|strong="H7288"\w*,  
\v 15 el \w sexto|strong="H8345"\w* Ozem, el \w séptimo|strong="H7637"\w* \w David|strong="H1732"\w*,  
\v 16 \w de|strong="H1121"\w* \w los|strong="H1121"\w* cuales Sarvia y Abigail fueron hermanas. \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Sarvia fueron \w tres|strong="H7969"\w*: \w Abisai|strong="H7969"\w*, \w Joab|strong="H3097"\w* y \w Asael|strong="H6214"\w*.  
\v 17 Abigail dio \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* \w Amasa|strong="H6021"\w*, cuyo padre fue \w Jeter|strong="H3500"\w* \w ismaelita|strong="H3459"\w*.   
\p
\v 18 \w Caleb|strong="H3612"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Hezrón|strong="H2696"\w*, \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Jeriot \w de|strong="H1121"\w* su esposa \w Azuba|strong="H5806"\w*. \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* ella fueron Jeser, \w Sobab|strong="H7727"\w* y Ardón.  
\v 19 Al \w morir|strong="H4191"\w* \w Azuba|strong="H5806"\w*, \w Caleb|strong="H3612"\w* \w tomó|strong="H3947"\w* como esposa \w a|strong="H3068"\w* Efrata, la cual dio \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* \w Hur|strong="H2354"\w*.  
\v 20 \w Hur|strong="H2354"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Uri, y Uri \w a|strong="H3068"\w* \w Bezaleel|strong="H1212"\w*.   
\p
\v 21 Después \w Hezrón|strong="H2696"\w* \w se|strong="H1931"\w* unió \w a|strong="H3068"\w* \w la|strong="H1931"\w* \w hija|strong="H1323"\w* \w de|strong="H1121"\w* Maquir, padre \w de|strong="H1121"\w* \w Galaad|strong="H1568"\w*, \w a|strong="H3068"\w* \w la|strong="H1931"\w* \w cual|strong="H1931"\w* \w tomó|strong="H3947"\w* cuando \w él|strong="H1931"\w* \w tenía|strong="H1931"\w* 60 \w años|strong="H8141"\w*, y \w ella|strong="H1931"\w* dio \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* Segub.  
\v 22 Segub \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Jaír|strong="H2971"\w*, quien poseyó 23 \w ciudades|strong="H5892"\w* en la tierra de \w Galaad|strong="H1568"\w*.  
\v 23 Pero Gesur y Aram \w tomaron|strong="H3947"\w* las \w aldeas|strong="H1323"\w* \w de|strong="H1121"\w* \w Jaír|strong="H2971"\w*, y Kenat y sus \w aldeas|strong="H1323"\w*: 60 pueblos. \w Todas|strong="H3605"\w* éstas las \w tomaron|strong="H3947"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Maquir, padre \w de|strong="H1121"\w* \w Galaad|strong="H1568"\w*.  
\v 24 Después que \w Hezrón|strong="H2696"\w* murió en Caleb-efrata, Abías, esposa de \w Hezrón|strong="H2696"\w*, dio \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* Asur, padre de Tecoa.   
\p
\v 25 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Jerameel|strong="H3396"\w*, \w primogénito|strong="H1060"\w* \w de|strong="H1121"\w* \w Hezrón|strong="H2696"\w*, \w fueron|strong="H1961"\w*: \w Ram|strong="H7410"\w*, su \w primogénito|strong="H1060"\w*, Buna, Orén, Ozem y Ahías.  
\v 26 \w Jerameel|strong="H3396"\w* \w tuvo|strong="H1961"\w* otra mujer \w llamada|strong="H8034"\w* \w Atara|strong="H5851"\w*, \w que|strong="H1931"\w* \w fue|strong="H1961"\w* madre de Onam.  
\v 27 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Ram|strong="H7410"\w*, \w primogénito|strong="H1060"\w* \w de|strong="H1121"\w* \w Jerameel|strong="H3396"\w*: Maaz, \w Jamín|strong="H3226"\w* y Equer.  
\v 28 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* Onam: Samai y Jada. \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* Samai: \w Nadab|strong="H5070"\w* y Abisur.  
\v 29 El \w nombre|strong="H8034"\w* de la esposa de Abisur fue Abihail, la cual dio \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* Ahbán y \w a|strong="H3068"\w* Molid.  
\v 30 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Nadab|strong="H5070"\w*: \w Seled|strong="H5540"\w* y Apaim. \w Seled|strong="H5540"\w* \w murió|strong="H4191"\w* \w sin|strong="H3808"\w* \w hijos|strong="H1121"\w*.  
\v 31 \w Isi|strong="H3469"\w* fue \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Apaim, y \w Sesán|strong="H8348"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Isi|strong="H3469"\w*, \w e|strong="H3068"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Sesán|strong="H8348"\w*, Ahlai.  
\v 32 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* Jada, hermano \w de|strong="H1121"\w* Samai: \w Jeter|strong="H3500"\w* y Jonatán. \w Jeter|strong="H3500"\w* \w murió|strong="H4191"\w* \w sin|strong="H3808"\w* \w hijos|strong="H1121"\w*.  
\v 33 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* Jonatán: Pelet y Zaza. Tales \w fueron|strong="H1961"\w* \w los|strong="H1121"\w* descendientes \w de|strong="H1121"\w* \w Jerameel|strong="H3396"\w*.  
\v 34 \w Sesán|strong="H8348"\w* \w no|strong="H3808"\w* \w tuvo|strong="H1961"\w* \w hijos|strong="H1121"\w*, \w sino|strong="H3588"\w* \w hijas|strong="H1323"\w*. \w Pero|strong="H3588"\w* \w Sesán|strong="H8348"\w* \w tenía|strong="H1961"\w* un esclavo \w egipcio|strong="H4713"\w* \w llamado|strong="H8034"\w* Jarha.  
\v 35 \w A|strong="H3068"\w* éste, \w Sesán|strong="H8348"\w* \w dio|strong="H5414"\w* su \w hija|strong="H1323"\w* como esposa, y ella \w dio|strong="H5414"\w* \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* Atai.  
\v 36 Atai \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Natán, Natán \w a|strong="H3068"\w* \w Zabad|strong="H2066"\w*,  
\v 37 \w Zabad|strong="H2066"\w* \w a|strong="H3068"\w* Eflal, Eflal \w a|strong="H3068"\w* \w Obed|strong="H5744"\w*,  
\v 38 \w Obed|strong="H5744"\w* \w a|strong="H3068"\w* \w Jehú|strong="H3058"\w*, \w Jehú|strong="H3058"\w* \w a|strong="H3068"\w* \w Azarías|strong="H5838"\w*,  
\v 39 \w Azarías|strong="H5838"\w* \w a|strong="H3068"\w* \w Heles|strong="H2503"\w*, \w Heles|strong="H2503"\w* \w a|strong="H3068"\w* Elasa,  
\v 40 Elasa \w a|strong="H3068"\w* Sismai, Sismai \w a|strong="H3068"\w* Salum,  
\v 41 Salum \w a|strong="H3068"\w* Jecamías, y Jecamías \w a|strong="H3068"\w* Elisama.   
\p
\v 42 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Caleb|strong="H3612"\w*, hermano \w de|strong="H1121"\w* \w Jerameel|strong="H3396"\w*: Mesa \w su|strong="H1931"\w* \w primogénito|strong="H1060"\w*, \w que|strong="H1931"\w* \w fue|strong="H1931"\w* \w el|strong="H1931"\w* padre \w de|strong="H1121"\w* Zif, y \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Maresa|strong="H4762"\w*, padre \w de|strong="H1121"\w* \w Hebrón|strong="H2275"\w*.  
\v 43 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Hebrón|strong="H2275"\w*: \w Coré|strong="H7141"\w*, Tapúa, Requem y Sema.  
\v 44 Sema \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Raham, padre de Jorcoam, y Requem \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Samai.  
\v 45 \w Maón|strong="H4584"\w* fue \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Samai, y \w Maón|strong="H4584"\w* padre \w de|strong="H1121"\w* Bet-sur.  
\v 46 Efa, \w concubina|strong="H6370"\w* de \w Caleb|strong="H3612"\w*, dio \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* \w Harán|strong="H2771"\w*, Mosa y Gazez. \w Harán|strong="H2771"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Gazez.   
\p
\v 47 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* Jahdai: \w Regem|strong="H7276"\w*, Jotam, Gesam, \w Pelet|strong="H6404"\w*, Efa y Saaf.  
\v 48 Maaca, \w concubina|strong="H6370"\w* de \w Caleb|strong="H3612"\w*, dio \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* Seber y Tirhana.  
\v 49 También dio \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* Saaf, padre de Madmana, y \w a|strong="H3068"\w* Seva, padre de Macbena, y padre de Gibea; y Acsa fue \w hija|strong="H1323"\w* de \w Caleb|strong="H3612"\w*.  
\v 50 Éstos \w fueron|strong="H1961"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Caleb|strong="H3612"\w*: \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Hur|strong="H2354"\w*, \w primogénito|strong="H1060"\w* \w de|strong="H1121"\w* Efrata: \w Sobal|strong="H7732"\w*, padre \w de|strong="H1121"\w* Quiriat-jearim,  
\v 51 \w Salma|strong="H8007"\w*, padre de Belén, y Haref, padre de Bet-gader.   
\p
\v 52 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Sobal|strong="H7732"\w*, padre \w de|strong="H1121"\w* Quiriat-jearim: Haroe, la mitad \w de|strong="H1121"\w* \w los|strong="H1121"\w* manahetitas.  
\v 53 \w Familias|strong="H4940"\w* de Quiriat-jearim: los itritas, los futitas, los sumatitas y los misraítas, de los cuales \w salieron|strong="H3318"\w* los zoratitas y los estaolitas.   
\p
\v 54 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Salma|strong="H8007"\w*: Belén, y \w los|strong="H1121"\w* netofatitas, Atrot-beth-joab, y Hazi-hammanahti, zoraíta.   
\p
\v 55 \w Las|strong="H1992"\w* \w familias|strong="H4940"\w* de \w los|strong="H1992"\w* \w escribas|strong="H5608"\w* \w que|strong="H1992"\w* \w habitaban|strong="H3427"\w* en \w Jabes|strong="H3258"\w*: \w los|strong="H1992"\w* tirateos, \w los|strong="H1992"\w* simeateos y \w los|strong="H1992"\w* sucateos, \w los|strong="H1992"\w* cuales son \w los|strong="H1992"\w* ceneos, \w que|strong="H1992"\w* proceden de Hamat, padre de la \w casa|strong="H1004"\w* de Recab.   
\c 3  
\s1 Descendientes de David  
\p
\v 1 Éstos \w son|strong="H1961"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w David|strong="H1732"\w* \w que|strong="H1121"\w* le \w nacieron|strong="H3205"\w* en \w Hebrón|strong="H2275"\w*: Amnón, \w el|strong="H1121"\w* \w primogénito|strong="H1060"\w*, \w de|strong="H1121"\w* Ahinoam \w jezreelita|strong="H3159"\w*; \w el|strong="H1121"\w* \w segundo|strong="H8145"\w*, \w Daniel|strong="H1840"\w*, \w de|strong="H1121"\w* Abigail la \w de|strong="H1121"\w* Carmel;  
\v 2 \w el|strong="H1121"\w* \w tercero|strong="H7992"\w*, Absalón, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Maaca, \w hija|strong="H1323"\w* \w de|strong="H1121"\w* Talmai, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* Gesur; \w el|strong="H1121"\w* \w cuarto|strong="H7243"\w*, Adonías, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Haguit;  
\v 3 el \w quinto|strong="H2549"\w*, Sefatías, de Abital; el \w sexto|strong="H8345"\w*, \w Itream|strong="H3507"\w*, de su esposa Egla.  
\v 4 Estos \w seis|strong="H8337"\w* le \w nacieron|strong="H3205"\w* en \w Hebrón|strong="H2275"\w*, \w donde|strong="H8033"\w* \w reinó|strong="H4427"\w* \w siete|strong="H7651"\w* \w años|strong="H8141"\w* y \w seis|strong="H8337"\w* \w meses|strong="H2320"\w*. Luego \w reinó|strong="H4427"\w* en Jerusalén 33 \w años|strong="H8141"\w*.  
\v 5 Estos cuatro le \w nacieron|strong="H3205"\w* en Jerusalén, de Betsabé, \w hija|strong="H1323"\w* de Amiel: Simea, \w Sobab|strong="H7727"\w*, Natán y \w Salomón|strong="H8010"\w*.  
\v 6 \w Y|strong="H3068"\w* otros nueve: \w Ibhar|strong="H2984"\w*, Elisama, Elifelet,  
\v 7 \w Noga|strong="H5052"\w*, Nefeg, Jafía,  
\v 8 Elisama, Eliada y Elifelet.  
\v 9 \w Todos|strong="H3605"\w* \w éstos|strong="H3605"\w* \w fueron|strong="H1732"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w David|strong="H1732"\w*, sin contar \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* las \w concubinas|strong="H6370"\w*. Tamar fue sobrina\f + \fr 3:9 \ft Lit. hermana de ellos.\f* \w de|strong="H1121"\w* \w ellos|strong="H3605"\w*.   
\p
\v 10 \w Roboam|strong="H7346"\w* fue \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Salomón|strong="H8010"\w*, cuyo \w hijo|strong="H1121"\w* fue Abías, \w e|strong="H3068"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* éste Asa, cuyo \w hijo|strong="H1121"\w* fue Josafat,  
\v 11 \w de|strong="H1121"\w* quien fue \w hijo|strong="H1121"\w* \w Joram|strong="H3141"\w*, \w cuyo|strong="H3141"\w* \w hijo|strong="H1121"\w* fue Ocozías, \w e|strong="H3068"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* éste \w Joás|strong="H3101"\w*,  
\v 12 del cual fue \w hijo|strong="H1121"\w* Amasías, \w e|strong="H3068"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* éste \w Azarías|strong="H5838"\w*, cuyo \w hijo|strong="H1121"\w* fue Jotam.  
\v 13 \w Hijo|strong="H1121"\w* \w de|strong="H1121"\w* éste fue Acaz, del cual fue \w hijo|strong="H1121"\w* Ezequías, cuyo \w hijo|strong="H1121"\w* fue \w Manasés|strong="H4519"\w*,  
\v 14 del cual fue \w hijo|strong="H1121"\w* Amón, cuyo \w hijo|strong="H1121"\w* fue \w Josías|strong="H2977"\w*.  
\v 15 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Josías|strong="H2977"\w*: \w Johanán|strong="H3110"\w*, su \w primogénito|strong="H1060"\w*, \w el|strong="H1121"\w* \w segundo|strong="H8145"\w* \w Joacim|strong="H3079"\w*, \w el|strong="H1121"\w* \w tercero|strong="H7992"\w* Sedequías, \w el|strong="H1121"\w* \w cuarto|strong="H7243"\w* Salum.  
\v 16 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Joacim|strong="H3079"\w*: Jeconías, cuyo \w hijo|strong="H1121"\w* fue Sedequías.   
\p
\v 17 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* Jeconías \w el|strong="H1121"\w* cautivo: Salatiel,  
\v 18 Malquiram, Pedaías, Senazar, Jecamías, \w Hosama|strong="H1953"\w* y Nedabías.  
\v 19 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* Pedaías: \w Zorobabel|strong="H2216"\w* y Simei. \w E|strong="H3068"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Zorobabel|strong="H2216"\w*: Mesulam, \w Hananías|strong="H2608"\w* y Selomit, su hermana.  
\v 20 También estos \w cinco|strong="H2568"\w*: \w Hasuba|strong="H2807"\w*, Ohel, Berequías, Hasadías y Jusab-hesed.  
\v 21 \w E|strong="H3068"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Hananías|strong="H2608"\w*: \w Pelatías|strong="H6410"\w* y \w Jesaías|strong="H3470"\w*; su \w hijo|strong="H1121"\w*, Refaías; su \w hijo|strong="H1121"\w*, Arnán; su \w hijo|strong="H1121"\w*, \w Abdías|strong="H5662"\w*; su \w hijo|strong="H1121"\w*, Secanías.  
\v 22 \w Hijo|strong="H1121"\w* \w de|strong="H1121"\w* Secanías fue \w Semaías|strong="H8098"\w*; \w e|strong="H3068"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Semaías|strong="H8098"\w*: Hatús, \w Igal|strong="H3008"\w*, \w Barías|strong="H1282"\w*, \w Nearías|strong="H5294"\w* y Safat: \w seis|strong="H8337"\w*.  
\v 23 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Nearías|strong="H5294"\w* fueron estos \w tres|strong="H7969"\w*: Elioenai, Ezequías y \w Azricam|strong="H5840"\w*.  
\v 24 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* Elioenai fueron estos \w siete|strong="H7651"\w*: Hodavías, Eliasib, \w Pelaías|strong="H6411"\w*, Acub, \w Johanán|strong="H3110"\w*, \w Dalaías|strong="H1806"\w* y Anani.   
\c 4  
\s1 Descendientes de Judá  
\p
\v 1 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*: Fares, \w Hezrón|strong="H2696"\w*, \w Carmi|strong="H3756"\w*, \w Hur|strong="H2354"\w* y \w Sobal|strong="H7732"\w*.  
\v 2 Reaía, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Sobal|strong="H7732"\w*, \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Jahat, y Jahat \w a|strong="H3068"\w* Ahumai y Lahad. Éstas son las \w familias|strong="H4940"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* zoratitas.  
\v 3 Esta es la descendencia de Etam: \w Jezreel|strong="H3157"\w*, \w Isma|strong="H3457"\w* \w e|strong="H3068"\w* Ibdas. El \w nombre|strong="H8034"\w* de su hermana: Haze-lelponi.  
\v 4 Penuel fue padre \w de|strong="H1121"\w* \w Gedor|strong="H1446"\w*, y \w Ezer|strong="H5829"\w*, padre \w de|strong="H1121"\w* Husa. Tales fueron \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Hur|strong="H2354"\w*, \w primogénito|strong="H1060"\w* \w de|strong="H1121"\w* Efrata, padre \w de|strong="H1121"\w* Belén.  
\v 5 Asur, padre de Tecoa, \w tuvo|strong="H1961"\w* \w dos|strong="H8147"\w* mujeres: Hela y Naara.  
\v 6 Naara dio \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* Ahuzam, Hefer, Temeni y Ahastari. Tales fueron \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Naara.  
\v 7 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Hela: Zeret, Jezoar, Etnán y Cos,  
\v 8 \w el|strong="H1121"\w* cual \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Anub, \w a|strong="H3068"\w* Zobeba, y la \w familia|strong="H4940"\w* \w de|strong="H1121"\w* Aharhel, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Harum.   
\p
\v 9 \w Pero|strong="H3588"\w* \w Jabes|strong="H3258"\w* \w fue|strong="H1961"\w* \w más|strong="H3588"\w* ilustre \w que|strong="H3588"\w* sus hermanos. \w Su|strong="H3588"\w* madre lo \w llamó|strong="H7121"\w* \w Jabes|strong="H3258"\w* \w y|strong="H3588"\w* dijo: ¡\w Ciertamente|strong="H3588"\w* lo di \w a|strong="H3068"\w* luz \w con|strong="H3588"\w* dolor!  
\v 10 \w Jabes|strong="H3258"\w* invocó al \nd ʼElohim\nd* \w de|strong="H5973"\w* \w Israel|strong="H3478"\w*: ¡Oh, \w que|strong="H1115"\w* \w me|strong="H5973"\w* des \w bendición|strong="H1288"\w* y ensanches \w mi|strong="H1961"\w* territorio, \w que|strong="H1115"\w* \w tu|strong="H6213"\w* \w mano|strong="H3027"\w* \w esté|strong="H1961"\w* \w conmigo|strong="H5973"\w* y \w me|strong="H5973"\w* libres \w del|strong="H5973"\w* \w mal|strong="H7451"\w*, \w para|strong="H1961"\w* \w que|strong="H1115"\w* \w no|strong="H6213"\w* \w me|strong="H5973"\w* dañe! \w Y|strong="H3068"\w* \nd ʼElohim\nd* \w le|strong="H5973"\w* concedió \w lo|strong="H6213"\w* \w que|strong="H1115"\w* \w pidió|strong="H7592"\w*.   
\p
\v 11 Quelub, hermano de Súa \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Mehlír, \w el|strong="H1931"\w* \w cual|strong="H1931"\w* \w fue|strong="H1931"\w* padre de Estón.  
\v 12 Estón \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Bet-rafa, Paseah y Tehina, el cual fue padre de Ir-nahas. Estos son los varones de Reca.  
\v 13 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* Cenaz: Otoniel y \w Seraías|strong="H8304"\w*. \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* Otoniel: Hatat y Meonotai,  
\v 14 quien \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Ofra; \w y|strong="H3588"\w* \w Seraías|strong="H8304"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Joab|strong="H3097"\w*, padre \w de|strong="H3588"\w* \w los|strong="H1961"\w* habitantes del \w valle|strong="H1516"\w* \w de|strong="H3588"\w* \w Carisim|strong="H2798"\w*, \w porque|strong="H3588"\w* \w fueron|strong="H1961"\w* artesanos.  
\v 15 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Caleb|strong="H3612"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Jefone: \w Iru|strong="H5900"\w*, Ela y Naam. \w Hijo|strong="H1121"\w* \w de|strong="H1121"\w* Ela fue Cenaz.  
\v 16 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* Jehalelel: Zif, Zifa, \w Tirías|strong="H8493"\w* y Asareel.  
\v 17 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* Esdras: \w Jeter|strong="H3500"\w*, \w Mered|strong="H4778"\w*, Efer y Jalón. \w Y|strong="H3068"\w* ella \w concibió|strong="H2029"\w* \w a|strong="H3068"\w* Miriam, \w a|strong="H3068"\w* Samai y \w a|strong="H3068"\w* Isba, padre \w de|strong="H1121"\w* Estemoa.  
\v 18 Su esposa Jehudaía dio \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* Jered, padre \w de|strong="H1121"\w* \w Gedor|strong="H1446"\w*, \w a|strong="H3068"\w* \w Heber|strong="H2268"\w*, padre \w de|strong="H1121"\w* Soco y \w a|strong="H3068"\w* Jecutiel, padre \w de|strong="H1121"\w* Zanoa. Tales fueron \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Bitia, \w hija|strong="H1323"\w* \w de|strong="H1121"\w* \w Faraón|strong="H6547"\w*, la \w que|strong="H1121"\w* \w Mered|strong="H4778"\w* \w tomó|strong="H3947"\w* por esposa.  
\v 19 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* la esposa \w de|strong="H1121"\w* Hodías, hermana \w de|strong="H1121"\w* Naham, fueron \w el|strong="H1121"\w* padre \w de|strong="H1121"\w* Queila garmita, y Estemoa maacateo.  
\v 20 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* Simón: Amnón, Rina, Benhanán y Tilón. \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Isi|strong="H3469"\w*: Zohet y Benzohet.  
\v 21 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Sela|strong="H7956"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*: \w Er|strong="H6147"\w*, padre \w de|strong="H1121"\w* Leca, y Laada, padre \w de|strong="H1121"\w* \w Maresa|strong="H4762"\w*, y las \w familias|strong="H4940"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w que|strong="H1121"\w* trabajan lino en Bet-asbea,  
\v 22 y Joacim, y los varones \w de|strong="H1697"\w* Cozeba, y \w Joás|strong="H3101"\w*, y Saraf, los cuales dominaron en \w Moab|strong="H4124"\w* y volvieron \w a|strong="H3068"\w* Lehem, según registros antiguos.  
\v 23 \w Éstos|strong="H1992"\w* eran alfareros, y \w habitaban|strong="H3427"\w* \w en|strong="H5973"\w* medio \w de|strong="H5973"\w* plantíos y cercados, \w cerca|strong="H5973"\w* \w del|strong="H5973"\w* \w rey|strong="H4428"\w*, ocupados \w en|strong="H5973"\w* \w su|strong="H1992"\w* servicio.   
\s1 Descendientes de Simeón  
\p
\v 24 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Simeón|strong="H8095"\w*: \w Nemuel|strong="H5241"\w*, \w Jamín|strong="H3226"\w*, \w Jarib|strong="H3402"\w*, \w Zera|strong="H2226"\w*, \w Saúl|strong="H7586"\w*,  
\v 25 Salum, \w Mibsam|strong="H4017"\w* y \w Misma|strong="H4927"\w*.  
\v 26 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Misma|strong="H4927"\w*: \w Hamuel|strong="H2536"\w*, Zacur, y Simei.  
\v 27 Simei tuvo 16 \w hijos|strong="H1121"\w* \w y|strong="H5704"\w* \w seis|strong="H8337"\w* \w hijas|strong="H1323"\w*, pero sus hermanos \w no|strong="H3808"\w* tuvieron \w muchos|strong="H7227"\w* \w hijos|strong="H1121"\w*, \w ni|strong="H3808"\w* \w se|strong="H3808"\w* \w multiplicaron|strong="H7235"\w* \w en|strong="H5704"\w* su \w familia|strong="H4940"\w* \w como|strong="H5704"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5704"\w* \w Judá|strong="H3063"\w*.  
\v 28 Vivieron en Beerseba, Molada, Hazar-sual,  
\v 29 \w Bilha|strong="H1090"\w*, Ezem, Tolad,  
\v 30 Betuel, \w Horma|strong="H2767"\w*, \w Siclag|strong="H6860"\w*,  
\v 31 Bet-marcabot, Hazar-susim, Bet-birai \w y|strong="H5704"\w* Saaraim. Éstas \w fueron|strong="H1732"\w* sus \w ciudades|strong="H5892"\w* \w hasta|strong="H5704"\w* el \w reinado|strong="H4427"\w* \w de|strong="H5704"\w* \w David|strong="H1732"\w*.  
\v 32 Sus \w aldeas|strong="H2691"\w*: Etam, \w Aín|strong="H5871"\w*, Rimón, Toquén y Asán: \w cinco|strong="H2568"\w* \w pueblos|strong="H2568"\w*.  
\v 33 \w Todas|strong="H3605"\w* sus \w aldeas|strong="H2691"\w* estaban situadas \w en|strong="H5704"\w* torno \w a|strong="H3068"\w* \w estas|strong="H2063"\w* \w ciudades|strong="H5892"\w* \w hasta|strong="H5704"\w* \w baal|strong="H1168"\w*. \w Éstos|strong="H2063"\w* son \w los|strong="H3605"\w* habitantes \w de|strong="H5704"\w* \w ellos|strong="H3605"\w* \w y|strong="H5704"\w* su genealogía.   
\p
\v 34 Asimismo Mesobab, Jamlec, Josías, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Amasías,  
\v 35 \w Joel|strong="H3100"\w*, \w Jehú|strong="H3058"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Josibías, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Seraías|strong="H8304"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Asiel,  
\v 36 Elioenai, Jaacoba, \w Jesohaía|strong="H3439"\w*, \w Asaías|strong="H6222"\w*, \w Adiel|strong="H5717"\w*, \w Jesimiel|strong="H3450"\w*, \w Benaía|strong="H1141"\w*,  
\v 37 \w Ziza|strong="H2124"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Sifi, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Alón, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Jedaías|strong="H3042"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Simri|strong="H8113"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Semaías|strong="H8098"\w*.   
\p
\v 38 Éstos son los jefes entre sus \w familias|strong="H4940"\w* según sus \w nombres|strong="H8034"\w*. Las \w casas|strong="H1004"\w* de sus padres fueron multiplicadas muchísimo.  
\v 39 Llegaron \w hasta|strong="H5704"\w* la \w entrada|strong="H3996"\w* \w de|strong="H5704"\w* \w Gedor|strong="H1446"\w*, \w hasta|strong="H5704"\w* el \w oriente|strong="H4217"\w* del \w valle|strong="H1516"\w*, \w en|strong="H5704"\w* \w busca|strong="H1245"\w* \w de|strong="H5704"\w* \w pastos|strong="H4829"\w* \w para|strong="H5704"\w* sus \w ganados|strong="H6629"\w*.  
\v 40 \w Hallaron|strong="H4672"\w* \w pastos|strong="H4829"\w* \w buenos|strong="H2896"\w* \w y|strong="H3588"\w* abundantes. \w La|strong="H3588"\w* tierra era muy \w espaciosa|strong="H7342"\w*, tranquila \w y|strong="H3588"\w* apacible, \w porque|strong="H3588"\w* \w los|strong="H3427"\w* \w de|strong="H4480"\w* Cam \w la|strong="H3588"\w* \w habitaron|strong="H3427"\w* anteriormente.   
\p
\v 41 \w Éstos|strong="H2088"\w* \w que|strong="H3588"\w* fueron inscritos \w por|strong="H3588"\w* sus \w nombres|strong="H8034"\w* vinieron \w en|strong="H5704"\w* \w días|strong="H3117"\w* \w de|strong="H3588"\w* Ezequías, \w rey|strong="H4428"\w* \w de|strong="H3588"\w* \w Judá|strong="H3063"\w*, \w y|strong="H3588"\w* \w destruyeron|strong="H2763"\w* las tiendas \w y|strong="H3588"\w* cabañas \w que|strong="H3588"\w* \w hallaron|strong="H4672"\w* \w allí|strong="H8033"\w*. Las \w destruyeron|strong="H2763"\w* \w hasta|strong="H5704"\w* \w hoy|strong="H3117"\w*, \w y|strong="H3588"\w* vivieron \w allí|strong="H8033"\w* \w en|strong="H5704"\w* \w lugar|strong="H8478"\w* \w de|strong="H3588"\w* ellos, \w por|strong="H3588"\w* \w cuanto|strong="H3588"\w* \w allí|strong="H8033"\w* \w había|strong="H4672"\w* \w pastos|strong="H4829"\w* \w para|strong="H5704"\w* sus \w ganados|strong="H6629"\w*.  
\v 42 Asimismo 500 \w hombres|strong="H1121"\w* \w de|strong="H4480"\w* \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w Simeón|strong="H8095"\w* \w fueron|strong="H1980"\w* \w a|strong="H3068"\w* la montaña \w de|strong="H4480"\w* \w Seír|strong="H8165"\w* y llevaron como \w jefes|strong="H7218"\w* \w a|strong="H3068"\w* \w Pelatías|strong="H6410"\w*, \w Nearías|strong="H5294"\w*, Refaías y Uziel, \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w Isi|strong="H3469"\w*.  
\v 43 Destruyeron \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w que|strong="H5704"\w* quedaron \w de|strong="H5704"\w* \w Amalec|strong="H6002"\w* \w y|strong="H5704"\w* vivieron \w allí|strong="H8033"\w* \w hasta|strong="H5704"\w* \w hoy|strong="H3117"\w*.   
\c 5  
\s1 Descendientes de Rubén  
\p
\v 1 \w Hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Rubén|strong="H7205"\w*, \w primogénito|strong="H1060"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*. \w Él|strong="H1931"\w* \w era|strong="H1931"\w* \w el|strong="H1931"\w* \w primogénito|strong="H1060"\w*, \w pero|strong="H3588"\w* \w porque|strong="H3588"\w* profanó \w el|strong="H1931"\w* lecho \w de|strong="H3588"\w* \w su|strong="H1931"\w* padre, \w su|strong="H1931"\w* primogenitura \w fue|strong="H1931"\w* \w dada|strong="H5414"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w José|strong="H3130"\w*, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*, \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w fue|strong="H1931"\w* posible registrarlo \w como|strong="H3588"\w* \w primogénito|strong="H1060"\w*.  
\v 2 \w Aunque|strong="H3588"\w* \w la|strong="H3588"\w* primogenitura correspondió \w a|strong="H3068"\w* \w José|strong="H3130"\w*, \w Judá|strong="H3063"\w* \w fue|strong="H3063"\w* superior \w entre|strong="H3588"\w* sus hermanos \w y|strong="H3588"\w* \w el|strong="H3588"\w* jefe \w de|strong="H4480"\w* \w ellos|strong="H4480"\w*, \w pero|strong="H3588"\w* \w el|strong="H3588"\w* privilegio \w de|strong="H4480"\w* primogenitura \w fue|strong="H3063"\w* \w para|strong="H3588"\w* \w José|strong="H3130"\w*.   
\p
\v 3 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Rubén|strong="H7205"\w*, \w primogénito|strong="H1060"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, fueron: Hanoc, Falú, \w Hezrón|strong="H2696"\w* y \w Carmi|strong="H3756"\w*.  
\v 4 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Joel|strong="H3100"\w*: \w Semaías|strong="H8098"\w*, \w Gog|strong="H1463"\w*, Simei,  
\v 5 Micaía, Reaía, y  
\v 6 Beera, \w el|strong="H1931"\w* \w cual|strong="H1931"\w* \w fue|strong="H1931"\w* transportado \w por|strong="H4428"\w* Tiglat-pileser, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* asirios. \w Éste|strong="H1931"\w* \w fue|strong="H1931"\w* \w jefe|strong="H5387"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* rubenitas.  
\v 7 Sus hermanos según sus \w familias|strong="H4940"\w*, cuando fueron contados según sus generaciones, tenían \w a|strong="H3068"\w* \w Jeiel|strong="H3273"\w* \w como|strong="H4940"\w* \w jefe|strong="H7218"\w*, \w Zacarías|strong="H2148"\w*,  
\v 8 \w Bela|strong="H1106"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5704"\w* Azaz, \w hijo|strong="H1121"\w* \w de|strong="H5704"\w* Sema, \w hijo|strong="H1121"\w* \w de|strong="H5704"\w* \w Joel|strong="H3100"\w*, \w quien|strong="H1931"\w* vivió \w en|strong="H5704"\w* \w Aroer|strong="H6177"\w* \w hasta|strong="H5704"\w* \w Nebo|strong="H5015"\w* \w y|strong="H5704"\w* Baal-meón.   
\p
\v 9 \w Se|strong="H4480"\w* estableció también \w hacia|strong="H4480"\w* \w el|strong="H3588"\w* \w oriente|strong="H4217"\w* \w hasta|strong="H5704"\w* \w la|strong="H3588"\w* entrada \w del|strong="H4480"\w* \w desierto|strong="H4057"\w* \add que se extiende\add* \w desde|strong="H4480"\w* \w el|strong="H3588"\w* \w río|strong="H5104"\w* \w Éufrates|strong="H6578"\w*, \w porque|strong="H3588"\w* tenía \w mucho|strong="H7235"\w* \w ganado|strong="H4735"\w* \w en|strong="H4480"\w* \w la|strong="H3588"\w* tierra \w de|strong="H4480"\w* \w Galaad|strong="H1568"\w*.  
\v 10 Pero \w en|strong="H5921"\w* \w tiempo|strong="H3117"\w* \w de|strong="H5921"\w* \w Saúl|strong="H7586"\w* guerrearon \w contra|strong="H5921"\w* \w los|strong="H3427"\w* agarenos, \w los|strong="H3427"\w* cuales \w cayeron|strong="H5307"\w* \w en|strong="H5921"\w* su \w mano|strong="H3027"\w*. \w Y|strong="H3068"\w* \w ellos|strong="H3027"\w* vivieron \w en|strong="H5921"\w* sus tiendas \w en|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* región \w oriental|strong="H4217"\w* \w de|strong="H5921"\w* \w Galaad|strong="H1568"\w*.   
\s1 Descendientes de Gad  
\p
\v 11 \w Los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H5048"\w* \w Gad|strong="H1410"\w* vivieron \w enfrente|strong="H5048"\w* \w a|strong="H3068"\w* \add los rubenitas\add* \w en|strong="H5704"\w* la tierra \w de|strong="H5048"\w* \w Basán|strong="H1316"\w* \w hasta|strong="H5704"\w* \w Salca|strong="H5548"\w*.  
\v 12 \w Joel|strong="H3100"\w* fue el \w jefe|strong="H7218"\w* en \w Basán|strong="H1316"\w*. El \w segundo|strong="H4932"\w* Safán, luego Jaanai, después Safat.  
\v 13 Sus hermanos, según las \w familias|strong="H1004"\w* de sus padres, fueron Micael, Mesulam, \w Seba|strong="H7652"\w*, \w Jorai|strong="H3140"\w*, Jacán, \w Zía|strong="H2127"\w* y \w Heber|strong="H5677"\w*: \w siete|strong="H7651"\w*.  
\v 14 Éstos fueron \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Abihail, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Huri, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Jaroa, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Galaad|strong="H1568"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Micael, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Jesisai, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Jahdo, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Buz.  
\v 15 También Ahí, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Abdiel, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Guni, fue \w jefe|strong="H7218"\w* en la \w casa|strong="H1004"\w* \w de|strong="H1121"\w* sus padres.   
\p
\v 16 Vivieron \w en|strong="H5921"\w* \w Galaad|strong="H1568"\w*, \w Basán|strong="H1316"\w* \w y|strong="H5921"\w* sus \w aldeas|strong="H1323"\w*, \w y|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H3427"\w* campos \w de|strong="H5921"\w* \w alrededor|strong="H5921"\w* \w de|strong="H5921"\w* \w Sarón|strong="H8289"\w* \w hasta|strong="H5921"\w* sus confines.  
\v 17 \w Todos|strong="H3605"\w* \w éstos|strong="H3605"\w* fueron contados según sus generaciones en \w los|strong="H3605"\w* \w días|strong="H3117"\w* de Jotam, \w rey|strong="H4428"\w* de \w Judá|strong="H3063"\w*, y en \w tiempo|strong="H3117"\w* de \w Jeroboam|strong="H3379"\w*, \w rey|strong="H4428"\w* de \w Israel|strong="H3478"\w*.   
\p
\v 18 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w Rubén|strong="H7205"\w* y \w de|strong="H4480"\w* \w Gad|strong="H1425"\w*, y la media \w tribu|strong="H7626"\w* \w de|strong="H4480"\w* \w Manasés|strong="H4519"\w*, \w hombres|strong="H1121"\w* \w valientes|strong="H2428"\w*, \w hombres|strong="H1121"\w* \w que|strong="H4480"\w* portaban \w escudo|strong="H4043"\w* y \w espada|strong="H2719"\w*, expertos \w en|strong="H4480"\w* \w el|strong="H1121"\w* manejo \w del|strong="H4480"\w* \w arco|strong="H7198"\w* y \w diestros|strong="H1869"\w* \w en|strong="H4480"\w* la \w guerra|strong="H4421"\w*, eran 44.760 \w que|strong="H4480"\w* \w salían|strong="H3318"\w* \w a|strong="H3068"\w* la \w guerra|strong="H4421"\w*.  
\v 19 Éstos tuvieron \w guerra|strong="H4421"\w* \w contra|strong="H5973"\w* \w los|strong="H5973"\w* agarenos, y \w Jetur|strong="H3195"\w*, Nafis y Nodab.  
\v 20 \w En|strong="H5921"\w* \w medio|strong="H3027"\w* \w del|strong="H5921"\w* combate \w clamaron|strong="H2199"\w* \w a|strong="H3068"\w* \w su|strong="H3588"\w* \nd ʼElohim\nd*, \w y|strong="H3588"\w* \w les|strong="H5921"\w* fue favorable \w porque|strong="H3588"\w* confiaron \w en|strong="H5921"\w* \w Él|strong="H5921"\w*. \w Los|strong="H5921"\w* agarenos \w y|strong="H3588"\w* \w todos|strong="H3605"\w* sus aliados fueron entregados \w en|strong="H5921"\w* sus \w manos|strong="H3027"\w*.  
\v 21 Tomaron sus \w ganados|strong="H4735"\w*: 50.000 \w camellos|strong="H1581"\w*, 250.000 \w ovejas|strong="H6629"\w* y 2.000 \w asnos|strong="H2543"\w*, además de 100.000 \w personas|strong="H5315"\w*.  
\v 22 \w Muchos|strong="H7227"\w* \w cayeron|strong="H5307"\w* \w muertos|strong="H2491"\w*, \w porque|strong="H3588"\w* \w la|strong="H3588"\w* \w batalla|strong="H4421"\w* era \w de|strong="H3588"\w* \nd ʼElohim\nd*. Vivieron \w en|strong="H5704"\w* sus lugares \w hasta|strong="H5704"\w* \w el|strong="H3588"\w* \w cautiverio|strong="H1473"\w*.   
\s1 Descendientes de la media tribu de Manasés  
\p
\v 23 \w Los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H5704"\w* la media \w tribu|strong="H7626"\w* \w de|strong="H5704"\w* \w Manasés|strong="H4519"\w* vivieron \w en|strong="H5704"\w* la tierra \w desde|strong="H5704"\w* \w Basán|strong="H1316"\w* \w hasta|strong="H5704"\w* \w Baal-hermón|strong="H1179"\w*, \w Senir|strong="H8149"\w* \w y|strong="H5704"\w* la montaña \w Hermón|strong="H2768"\w*, \w y|strong="H5704"\w* \w se|strong="H1992"\w* \w multiplicaron|strong="H7235"\w* muchísimo.  
\v 24 Estos son los \w jefes|strong="H7218"\w* de las \w casas|strong="H1004"\w* paternas: Efer, \w Isi|strong="H3469"\w*, Eliel, \w Azriel|strong="H5837"\w*, \w Jeremías|strong="H3414"\w*, Hodavías y Jahdiel, \w hombres|strong="H1368"\w* \w valientes|strong="H1368"\w* y \w esforzados|strong="H1368"\w*, varones de renombre y \w jefes|strong="H7218"\w* de las \w casas|strong="H1004"\w* paternas.   
\p
\v 25 Pero \w se|strong="H5971"\w* rebelaron \w contra|strong="H6440"\w* el \nd ʼElohim\nd* \w de|strong="H6440"\w* sus padres, y \w se|strong="H5971"\w* prostituyeron al seguir \w a|strong="H3068"\w* los \tl ʼelohim\tl* \w de|strong="H6440"\w* los \w pueblos|strong="H5971"\w* \w de|strong="H6440"\w* la tierra, \w a|strong="H3068"\w* los cuales \nd \+w Yavé|strong="H3068"\+w*\nd* quitó \w de|strong="H6440"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ellos.  
\v 26 \w Por|strong="H2088"\w* \w lo|strong="H2088"\w* cual el \nd ʼElohim\nd* \w de|strong="H5704"\w* \w Israel|strong="H3478"\w* incitó el \w espíritu|strong="H7307"\w* \w de|strong="H5704"\w* Pul, \w rey|strong="H4428"\w* \w de|strong="H5704"\w* los asirios, \w es|strong="H2088"\w* decir el \w espíritu|strong="H7307"\w* \w de|strong="H5704"\w* Tiglat-pileser, \w rey|strong="H4428"\w* \w de|strong="H5704"\w* los asirios, quien deportó \w a|strong="H3068"\w* los rubenitas, \w gaditas|strong="H1425"\w* \w y|strong="H5704"\w* \w a|strong="H3068"\w* la media \w tribu|strong="H7626"\w* \w de|strong="H5704"\w* \w Manasés|strong="H4519"\w*. Los llevó \w a|strong="H3068"\w* Halah, Habor, Hara \w y|strong="H5704"\w* \w al|strong="H5704"\w* \w río|strong="H5104"\w* \w Gozán|strong="H1470"\w*, \w hasta|strong="H5704"\w* \w hoy|strong="H3117"\w*.   
\c 6  
\s1 Descendientes de Leví  
\p
\v 1 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Leví|strong="H3878"\w*: Gersón, Coat y \w Merari|strong="H4847"\w*.   
\p
\v 2 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* Coat: Amram, Izhar, Hebrón y Uziel.   
\p
\v 3 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Amram|strong="H6019"\w*: Aarón, Moisés y Miriam.  
\p \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* Aarón: Nadab, Abiú, Eleazar \w e|strong="H3068"\w* Itamar.  
\v 4 Eleazar engendró \w a|strong="H3068"\w* Finees. Finees engendró \w a|strong="H3068"\w* Abisúa.  
\v 5 Abisúa engendró \w a|strong="H3068"\w* Buqui. Buqui engendró \w a|strong="H3068"\w* Uzi.  
\v 6 Uzi engendró \w a|strong="H3068"\w* Zeraías. Zeraías engendró \w a|strong="H3068"\w* Meraiot.  
\v 7 Meraiot engendró \w a|strong="H3068"\w* Amarías. Amarías engendró \w a|strong="H3068"\w* Ahitob.  
\v 8 Ahitob engendró \w a|strong="H3068"\w* Sadoc. Sadoc engendró \w a|strong="H3068"\w* Ahimaas.  
\v 9 Ahimaas engendró \w a|strong="H3068"\w* Azarías. Azarías engendró \w a|strong="H3068"\w* Johanán.  
\v 10 Johanán engendró \w a|strong="H3068"\w* Azarías, quien tuvo \w el|strong="H1121"\w* sacerdocio en la Casa \w que|strong="H1121"\w* Salomón edificó en Jerusalén.  
\v 11 Azarías engendró \w a|strong="H3068"\w* Amarías. Amarías engendró \w a|strong="H3068"\w* Ahitob.  
\v 12 Ahitob engendró \w a|strong="H3068"\w* Sadoc. Sadoc engendró \w a|strong="H3068"\w* Salum.  
\v 13 Salum engendró \w a|strong="H3068"\w* Hilcías. Hilcías engendró \w a|strong="H3068"\w* Azarías.  
\v 14 Azarías engendró \w a|strong="H3068"\w* Seraías. \w Y|strong="H3068"\w* Seraías engendró \w a|strong="H3068"\w* Josadac.   
\p
\v 15 Josadac fue llevado cautivo cuando \nd \+w Yavé|strong="H3068"\+w*\nd* deportó \w a|strong="H3068"\w* Judá y \w a|strong="H3068"\w* Jerusalén por medio \w de|strong="H1121"\w* Nabucodonosor.   
\p
\v 16 Hijos \w de|strong="H5921"\w* Leví: Gersón, Coat \w y|strong="H5921"\w* Merari.   
\p
\v 17 Éstos \w son|strong="H1961"\w* \w los|strong="H5921"\w* nombres \w de|strong="H5921"\w* \w los|strong="H5921"\w* hijos \w de|strong="H5921"\w* Gersón: Libni \w y|strong="H5921"\w* Simei.  
\v 18 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* Coat: Amram, Izhar, Hebrón y Uziel.  
\v 19 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* Merari: Mahli y Musi.  
\p Éstas son las familias \w de|strong="H1121"\w* Leví según sus descendencias:   
\p
\v 20 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* Gersón: Libni, Jahat, Zima,  
\v 21 Joa, Iddo, Zera y Jeatrai.   
\p
\v 22 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Coat: Aminadab, \w Coré|strong="H7141"\w*, Asir,  
\v 23 Elcana, Ebiasaf, Asir,  
\v 24 Tahat, Uriel, Uzías, Saúl,  
\v 25 Elcana, Amasai, Ahimot,  
\v 26 Elcana, Zofai, Nahat,  
\v 27 Eliab, Jeroham y Elcana.  
\v 28 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* Samuel \w fueron|strong="H1647"\w*: Joel \w el|strong="H1121"\w* primogénito, y Abías \w el|strong="H1121"\w* segundo.   
\p
\v 29 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Merari|strong="H4847"\w* fueron: Mahli, Libni, Simei, Uza,  
\v 30 Simea, Haguía, Asaías.   
\s1 Principios para el servicio del canto  
\p
\v 31 Éstos son \w los|strong="H1121"\w* \w que|strong="H1121"\w* David estableció para \w el|strong="H1121"\w* servicio del canto en la Casa \w de|strong="H1121"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* desde cuando \w el|strong="H1121"\w* Arca reposó allí,  
\v 32 quienes servían en \w el|strong="H1121"\w* canto delante \w de|strong="H1121"\w* la tienda del Tabernáculo \w de|strong="H1121"\w* Reunión, hasta \w que|strong="H1121"\w* Salomón edificó la Casa \w de|strong="H1121"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* en Jerusalén. Después estuvieron en su ministerio según su costumbre.   
\p
\v 33 \w Éstos|strong="H3605"\w* y sus hijos eran \w los|strong="H3605"\w* \w que|strong="H3605"\w* ejercían su servicio. \w De|strong="H5414"\w* \w los|strong="H3605"\w* hijos \w de|strong="H5414"\w* Coat: \w el|strong="H3605"\w* cantor Hemán, hijo \w de|strong="H5414"\w* Joel, hijo \w de|strong="H5414"\w* Samuel,  
\v 34 \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Elcana, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Jeroham, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Eliel, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Toa,  
\v 35 \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Zuf, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Elcana, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Mahat, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Amasai,  
\v 36 \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Elcana, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Joel, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Azarías, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Sofonías,  
\v 37 \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Tahat, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Asir, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Ebiasaf, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Coré,  
\v 38 \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Izhar, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Coat, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Leví, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Israel,  
\v 39 \w su|strong="H1992"\w* hermano Asaf, \w el|strong="H3588"\w* \w cual|strong="H3588"\w* \w estaba|strong="H1961"\w* \w a|strong="H3068"\w* \w su|strong="H1992"\w* mano derecha, Asaf, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* Berequías, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* Simea,  
\v 40 hijo \w de|strong="H5414"\w* Micael, hijo \w de|strong="H5414"\w* Baasías, hijo \w de|strong="H5414"\w* Malquías,  
\v 41 \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Etni, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Zera, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Adaía,  
\v 42 \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Etán, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Zima, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Simei,  
\v 43 hijo de Jahat, hijo de Gersón, hijo de Leví.  
\v 44 Los hijos de Merari, sus hermanos, estaban \w a|strong="H3068"\w* la izquierda: Etán, hijo de Quisi, hijo de Abdi, hijo de Maluc,  
\v 45 hijo de Hasabías, hijo de Amasías, hijo de Hilcías,  
\v 46 \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Amsi, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Bani, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Semer,  
\v 47 \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Mahli, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Musi, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Merari, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Leví.   
\p
\v 48 Sus hermanos levitas fueron asignados \w a|strong="H3068"\w* todo \w el|strong="H1121"\w* ministerio del Tabernáculo \w de|strong="H1121"\w* la Casa \w de|strong="H1121"\w* \nd ʼElohim\nd*.  
\v 49 Pero Aarón y sus \w hijos|strong="H1121"\w* ofrecían sacrificios sobre \w el|strong="H1121"\w* altar del holocausto y del incienso, ministraban en toda la obra del Lugar Santísimo y hacían \w los|strong="H1121"\w* sacrificios \w que|strong="H1121"\w* apaciguan \w por|strong="H5414"\w* \w Israel|strong="H3478"\w* según todo lo \w que|strong="H1121"\w* mandó Moisés esclavo \w de|strong="H1121"\w* \nd ʼElohim\nd*.   
\p
\v 50 Estos son \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Aarón: Finees, Abisúa,  
\v 51 Buqui, Uzi, Zeraías,  
\v 52 Meraiot, Amarías, Ahitob,  
\v 53 Sadoc, Ahimaas.   
\s1 Lugares de residencia de los levitas  
\p
\v 54 Éstos son los lugares de residencia según sus campamentos en su territorio.  
\p \w A|strong="H3068"\w* los hijos de Aarón de la familia de los coatitas, porque \w a|strong="H3068"\w* ellos les tocó la primera suerte,  
\v 55 les dieron Hebrón, en tierra \w de|strong="H1121"\w* Judá, y sus campos \w de|strong="H1121"\w* alrededor.  
\v 56 Pero \w el|strong="H1121"\w* territorio \w de|strong="H1121"\w* la ciudad y sus aldeas se dieron \w a|strong="H3068"\w* Caleb, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Jefone.   
\p
\v 57 De Judá dieron Hebrón, la ciudad de refugio, \w a|strong="H3068"\w* los hijos de Aarón. Además \add dieron ciudades\add* con sus campos de alrededor: Libna, Jatir, Estemoa,  
\v 58 Hilén, Debir,  
\v 59 Asán y Bet-semes.  
\v 60 De la tribu de Benjamín \add dieron ciudades\add* con sus campos de alrededor: Geba, Alemet y Anatot. Todas sus ciudades fueron 13, repartidas por sus familias.   
\p
\v 61 \w A|strong="H3068"\w* los hijos de Coat que quedaron les dieron por sorteo diez ciudades de la media \w tribu|strong="H4294"\w* de Manasés.   
\p
\v 62 \w A|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Gersón, por sus familias, fueron dadas \w de|strong="H1121"\w* las \w tribus|strong="H4294"\w* \w de|strong="H1121"\w* Isacar, Aser, Neftalí y Manasés en Basán, 13 ciudades.   
\p
\v 63 \w A|strong="H3068"\w* los hijos de Merari, por sus familias, les dieron 12 ciudades por sorteo de las \w tribus|strong="H4294"\w* de \w Rubén|strong="H7205"\w*, Gad y Zabulón.   
\p
\v 64 Así los hijos de Israel dieron \w a|strong="H3068"\w* los levitas las ciudades con sus campos de alrededor.  
\v 65 De las \w tribus|strong="H4294"\w* de los hijos de Judá, Simeón y Benjamín, dieron por sorteo las ciudades que llamaron por sus nombres.   
\p
\v 66 De la tribu de Efraín dieron ciudades con sus campos de alrededor \w a|strong="H3068"\w* las familias de los hijos de Coat,  
\v 67 y las siguientes ciudades de refugio con sus campos de alrededor: Siquem en la región montañosa de Efraín, Gezer,  
\v 68 Jocmeam, Bet-horón,  
\v 69 Ajalón y Gat-rimón.  
\v 70 De la media tribu de Manasés \add dieron ciudades\add* con sus campos de alrededor: Aner y Bileam, para los que quedaron de las familias de los hijos de Coat.   
\p
\v 71 De la familia de la media tribu de Manasés dieron \add ciudades\add* con sus campos de alrededor \w a|strong="H3068"\w* los hijos de Gersón: Golán en Basán y Astarot.  
\v 72 De la tribu de Isacar \add dieron ciudades\add* con sus campos de alrededor: Cedes, Daberat,  
\v 73 Ramot y Anem.  
\v 74 De la tribu de Aser \add dieron ciudades\add* con sus campos de alrededor: Masal, Abdón,  
\v 75 Hucoc y Rehob.  
\v 76 De la tribu de Neftalí \add dieron ciudades\add* con sus campos de alrededor: Cedes, en Galilea, Hamón y Quiriataim.  
\v 77 \w A|strong="H3068"\w* los hijos de Merari que quedaron de la tribu de Zabulón dieron \add ciudades\add* con sus campos de alrededor: Rimón y Tabor.  
\v 78 De la tribu de Rubén, dieron \add ciudades\add* con sus campos de alrededor al otro lado del Jordán, frente \w a|strong="H3068"\w* Jericó, al oriente del Jordán: Beser, en la región despoblada, Jaza,  
\v 79 Cademot y Mefaat.  
\v 80 \w Y|strong="H3068"\w* de la tribu de Gad \add dieron ciudades\add* con sus campos de alrededor: Ramot de Galaad, Mahanaim,  
\v 81 Hesbón y Jazer.   
\c 7  
\s1 Descendientes de Isacar  
\p
\v 1 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* Isacar: \w Tola|strong="H8439"\w*, Fúa, \w Jasub|strong="H3437"\w* y Simrón: cuatro.  
\v 2 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Tola|strong="H8439"\w*: Uzi, Refaías, \w Jeriel|strong="H3400"\w*, Jahmai, \w Jibsam|strong="H3005"\w* y Semuel, \w jefes|strong="H7218"\w* \w de|strong="H1121"\w* las \w casas|strong="H1004"\w* paternas. \w De|strong="H1121"\w* \w Tola|strong="H8439"\w* \w fueron|strong="H1732"\w* \w contados|strong="H4557"\w* por sus \w familias|strong="H1004"\w* 22.6000 \w hombres|strong="H1368"\w* \w valientes|strong="H1368"\w* en sus generaciones en \w el|strong="H1121"\w* \w tiempo|strong="H3117"\w* \w de|strong="H1121"\w* \w David|strong="H1732"\w*.  
\v 3 \w El|strong="H3605"\w* \w hijo|strong="H1121"\w* \w de|strong="H2568"\w* Uzi fue Israhías, y \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H2568"\w* Israhías: Micael, \w Obadías|strong="H5662"\w*, \w Joel|strong="H3100"\w* \w e|strong="H3068"\w* \w Isías|strong="H3449"\w*, un total \w de|strong="H2568"\w* \w cinco|strong="H2568"\w* \w jefes|strong="H7218"\w*.  
\v 4 \w Había|strong="H3588"\w* \w con|strong="H5921"\w* \w ellos|strong="H5921"\w* \w en|strong="H5921"\w* sus \w familias|strong="H1004"\w* \w y|strong="H3588"\w* sus \w casas|strong="H1004"\w* paternas, 36.000 \w hombres|strong="H1121"\w* guerreros, \w porque|strong="H3588"\w* tuvieron \w muchas|strong="H7235"\w* mujeres \w e|strong="H3068"\w* \w hijos|strong="H1121"\w*.  
\v 5 Sus hermanos, según \w todas|strong="H3605"\w* las \w familias|strong="H4940"\w* de Isacar, contados por sus genealogías, eran 87.000 \w hombres|strong="H1368"\w* \w valientes|strong="H1368"\w*.   
\s1 Descendientes de Benjamín  
\p
\v 6 Hijos de \w Benjamín|strong="H1144"\w*: \w Bela|strong="H1106"\w*, Bequer y \w Jediael|strong="H3043"\w*: \w tres|strong="H7969"\w*.  
\v 7 \w Hijos|strong="H1121"\w* \w de|strong="H2568"\w* \w Bela|strong="H1106"\w*: Ezbón, Uzi, Uziel, Jerimot \w e|strong="H3068"\w* Iri: \w cinco|strong="H2568"\w* \w jefes|strong="H7218"\w* \w de|strong="H2568"\w* \w casas|strong="H1004"\w* paternas, \w hombres|strong="H1368"\w* \w valientes|strong="H1368"\w* y \w de|strong="H2568"\w* la descendencia \w de|strong="H2568"\w* \w los|strong="H1121"\w* cuales fueron contados 22.034.  
\v 8 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* Bequer: \w Zemira|strong="H2160"\w*, \w Joás|strong="H3135"\w*, Eliezer, Elioenai, \w Omri|strong="H6018"\w*, Jerimot, Abías, Anatot y Alamet. \w Todos|strong="H3605"\w* \w éstos|strong="H3605"\w* fueron \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Bequer.  
\v 9 Contados por sus descendencias, por sus \w familias|strong="H1004"\w*, los que eran \w jefes|strong="H7218"\w* de \w familias|strong="H1004"\w* resultaron 20.200 \w hombres|strong="H1368"\w* \w valientes|strong="H1368"\w*.  
\v 10 \w Hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Jediael|strong="H3043"\w* fue \w Bilhán|strong="H1092"\w*. \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Bilhán|strong="H1092"\w*: \w Jeús|strong="H3266"\w*, \w Benjamín|strong="H1144"\w*, Aod, Quenaana, Zetán, \w Tarsis|strong="H8659"\w* y Ahisahar.  
\v 11 \w Todos|strong="H3605"\w* \w éstos|strong="H3605"\w* fueron \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Jediael|strong="H3043"\w*, \w jefes|strong="H7218"\w* \w de|strong="H1121"\w* familias, \w hombres|strong="H1368"\w* \w valientes|strong="H1368"\w*, 17.200 \w que|strong="H1121"\w* \w salían|strong="H3318"\w* \w a|strong="H3068"\w* \w combatir|strong="H4421"\w* \w en|strong="H3318"\w* \w la|strong="H3605"\w* \w guerra|strong="H4421"\w*.  
\v 12 Supim y Hupim fueron \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Hir. \w Husim|strong="H2366"\w* fue \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Aher.   
\s1 Descendientes de Neftalí  
\p
\v 13 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* Neftalí: \w Jahzeel|strong="H3185"\w*, \w Guni|strong="H3337"\w*, \w Jezer|strong="H7967"\w* y Salum, \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Bilha|strong="H1090"\w*.   
\s1 Descendientes de Manasés  
\p
\v 14 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Manasés|strong="H4519"\w*: Asriel, al cual dio \w a|strong="H3068"\w* luz su \w concubina|strong="H6370"\w* siria, quien también dio \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* Maquir, padre \w de|strong="H1121"\w* \w Galaad|strong="H1568"\w*.  
\v 15 Maquir \w tomó|strong="H3947"\w* \w como|strong="H1961"\w* esposa \w a|strong="H3068"\w* la hermana de Hupim y Supim. \w Se|strong="H1961"\w* \w llamaba|strong="H8034"\w* Maaca. El \w nombre|strong="H8034"\w* del \w segundo|strong="H8145"\w* descendiente \w fue|strong="H1961"\w* Zelofehad, quien \w tuvo|strong="H1961"\w* \w hijas|strong="H1323"\w*.  
\v 16 Maaca, esposa \w de|strong="H1121"\w* Maquir, dio \w a|strong="H3068"\w* luz un \w hijo|strong="H1121"\w*, y lo \w llamó|strong="H7121"\w* \w Peres|strong="H6570"\w*. \w El|strong="H1121"\w* \w nombre|strong="H8034"\w* \w de|strong="H1121"\w* su hermano fue Seres, \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* del cual fueron Ulam y Requem.  
\v 17 \w El|strong="H1121"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Ulam fue Bedán. Éstos fueron \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Galaad|strong="H1568"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Maquir, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Manasés|strong="H4519"\w*.  
\v 18 Su hermana Hamolequet dio \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* Isod, Abiezer, Mahala y Semida.  
\v 19 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Semida \w fueron|strong="H1961"\w* Ahián, Siquem, Likhi y Aniam.   
\s1 Descendientes de Efraín  
\p
\v 20 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* Efraín: Sutela, \w Bered|strong="H1260"\w*, Tahat, Elada, Tahat,  
\v 21 \w Zabad|strong="H2066"\w* Sutela, \w Ezer|strong="H5827"\w* \w y|strong="H3588"\w* Elad. \w Pero|strong="H3588"\w* \w los|strong="H1121"\w* \w hombres|strong="H1121"\w* \w de|strong="H3588"\w* Gat, \w naturales|strong="H3205"\w* \w de|strong="H3588"\w* aquella tierra, \w los|strong="H1121"\w* \w mataron|strong="H2026"\w* \w porque|strong="H3588"\w* \w bajaron|strong="H3381"\w* \w a|strong="H3068"\w* quitarles sus \w ganados|strong="H4735"\w*.  
\v 22 Su padre Efraín les hizo duelo \w muchos|strong="H7227"\w* \w días|strong="H3117"\w*, y sus hermanos llegaron \w a|strong="H3068"\w* consolarlo.  
\v 23 Luego \w se|strong="H1961"\w* unió \w a|strong="H3068"\w* \w su|strong="H3588"\w* esposa, \w la|strong="H3588"\w* \w cual|strong="H3588"\w* \w concibió|strong="H2029"\w* \w y|strong="H3588"\w* dio \w a|strong="H3068"\w* luz un \w hijo|strong="H1121"\w*, al \w cual|strong="H3588"\w* \w llamó|strong="H7121"\w* \w Bería|strong="H1283"\w*, \w porque|strong="H3588"\w* \w su|strong="H3588"\w* \w casa|strong="H1004"\w* \w estaba|strong="H1961"\w* \w en|strong="H3588"\w* aflicción.  
\v 24 \w Y|strong="H3068"\w* su \w hija|strong="H1323"\w* fue Seera, la cual \w edificó|strong="H1129"\w* Bet-horón, la baja y la alta, y también Uzen-seera.  
\v 25 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* este Bería fueron Refa, Resef, Telah, Tahán,  
\v 26 \w Laadán|strong="H3936"\w*, Amiud, Elisama,  
\v 27 Non y \w Josué|strong="H3091"\w*.  
\v 28 La herencia \w y|strong="H5704"\w* lugar \w de|strong="H5704"\w* residencia \w de|strong="H5704"\w* ellos fue Bet-ʼEl \w con|strong="H5704"\w* sus \w aldeas|strong="H1323"\w*, \w y|strong="H5704"\w* hacia \w el|strong="H1008"\w* \w oriente|strong="H4217"\w* \w Naarán|strong="H5295"\w*, \w y|strong="H5704"\w* \w en|strong="H5704"\w* \w el|strong="H1008"\w* \w occidente|strong="H4628"\w* \w Gezer|strong="H1507"\w* \w y|strong="H5704"\w* sus \w aldeas|strong="H1323"\w*, asimismo Siquem \w con|strong="H5704"\w* sus \w aldeas|strong="H1323"\w*, \w hasta|strong="H5704"\w* \w Gaza|strong="H5804"\w* \w y|strong="H5704"\w* sus \w aldeas|strong="H1323"\w*;  
\v 29 \w y|strong="H5921"\w* \w junto|strong="H5921"\w* \w al|strong="H5921"\w* territorio \w de|strong="H5921"\w* \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Manasés|strong="H4519"\w*, Bet-seán, Taanac, Meguido \w y|strong="H5921"\w* \w Dor|strong="H1756"\w*, cada uno \w con|strong="H5921"\w* sus \w aldeas|strong="H1323"\w*. \w En|strong="H5921"\w* estos lugares vivieron \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w José|strong="H3130"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.   
\s1 Descendientes de Aser  
\p
\v 30 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* Aser: \w Imna|strong="H3232"\w*, \w Isúa|strong="H3438"\w*, \w Isúi|strong="H3440"\w*, \w Bería|strong="H1283"\w* y su hermana \w Sera|strong="H8294"\w*.  
\v 31 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Bería|strong="H1283"\w*: \w Heber|strong="H2268"\w* y Malquiel, \w el|strong="H1931"\w* \w cual|strong="H1931"\w* \w fue|strong="H1931"\w* padre \w de|strong="H1121"\w* Birzavit.  
\v 32 \w Heber|strong="H2268"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Jaflet, \w Semer|strong="H7763"\w*, Hotam y Súa, hermana de ellos.  
\v 33 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* Jaflet: \w Pasac|strong="H6457"\w*, \w Bimhal|strong="H1118"\w* y Asvat.  
\v 34 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* Semer fueron: Ahi, Rohga, Jehúba y Aram.  
\v 35 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* su hermano Helem fueron: Zofa, \w Imna|strong="H3234"\w*, Seles y Amal.  
\v 36 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* Zofa: \w Súa|strong="H5477"\w*, Harnefer, \w Súal|strong="H7777"\w*, \w Beri|strong="H1275"\w*, \w Imra|strong="H3236"\w*,  
\v 37 \w Beser|strong="H1221"\w*, \w Hod|strong="H1936"\w*, Sama, \w Silsa|strong="H8030"\w*, Itrán y Beera.  
\v 38 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Jeter|strong="H3500"\w*: Jefone, \w Pispa|strong="H6462"\w* y Ara.  
\v 39 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* Ula: Ara, \w Haniel|strong="H2592"\w* y Rezia.  
\v 40 \w Todos|strong="H3605"\w* \w éstos|strong="H3605"\w* fueron \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Aser, \w jefes|strong="H7218"\w* \w de|strong="H1121"\w* \w familias|strong="H1004"\w* paternas, \w escogidos|strong="H1305"\w*, \w hombres|strong="H1368"\w* \w valientes|strong="H1368"\w*, \w jefes|strong="H7218"\w* \w de|strong="H1121"\w* líderes. Fueron \w contados|strong="H4557"\w* por sus \w familias|strong="H1004"\w* entre \w los|strong="H1121"\w* \w que|strong="H1121"\w* podían tomar las armas. \w El|strong="H3605"\w* \w número|strong="H4557"\w* \w de|strong="H1121"\w* \w ellos|strong="H3605"\w* \w fue|strong="H6635"\w* 26.000 \w hombres|strong="H1368"\w*.   
\c 8  
\s1 Otros descendientes de Benjamín  
\p
\v 1 \w Benjamín|strong="H1144"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* su \w primogénito|strong="H1060"\w*, \w Bela|strong="H1106"\w*, Asbel el \w segundo|strong="H8145"\w*, Ahara el \w tercero|strong="H7992"\w*,  
\v 2 \w Noha|strong="H5119"\w* el \w cuarto|strong="H7243"\w*, y Rafa el \w quinto|strong="H2549"\w*.  
\v 3 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Bela|strong="H1106"\w* \w fueron|strong="H1961"\w* Adar, \w Gera|strong="H1617"\w*, Abiud,  
\v 4 Abisúa, \w Naamán|strong="H5283"\w*, Ahoa,  
\v 5 \w Gera|strong="H1617"\w*, Sefufán y Huram.  
\v 6 \w Estos|strong="H1992"\w* son \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Ehud, \w jefes|strong="H7218"\w* \w de|strong="H1121"\w* casas paternas \w que|strong="H1121"\w* vivieron en Geba y fueron llevados \w cautivos|strong="H1540"\w* \w a|strong="H3068"\w* Manahat:  
\v 7 \w Naamán|strong="H5283"\w*, Ahías y \w Gera|strong="H1617"\w*. \w Éste|strong="H1931"\w* \w los|strong="H1931"\w* llevó \w cautivos|strong="H1540"\w*, y \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Uza y Ahiud.  
\v 8 Saharaim \w engendró|strong="H3205"\w* hijos \w en|strong="H4480"\w* los \w campos|strong="H7704"\w* \w de|strong="H4480"\w* \w Moab|strong="H4124"\w*, después \w que|strong="H4480"\w* repudió \w a|strong="H3068"\w* \w Husim|strong="H2366"\w* y \w a|strong="H3068"\w* Baara, quienes eran sus esposas.  
\v 9 \w Engendró|strong="H3205"\w* \w con|strong="H4480"\w* su esposa Hodes \w a|strong="H3068"\w* \w Jobab|strong="H3103"\w*, Sibia, \w Mesa|strong="H4331"\w*, Malcam,  
\v 10 Jeúz, Saquías y Mirma. Éstos fueron sus \w hijos|strong="H1121"\w*, \w jefes|strong="H7218"\w* \w de|strong="H1121"\w* casas paternas.  
\v 11 También con \w Husim|strong="H2366"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Abitob y \w a|strong="H3068"\w* Elpaal.  
\v 12 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Elpaal fueron: \w Heber|strong="H5677"\w*, \w Misam|strong="H4936"\w* y Semed, \w el|strong="H1931"\w* \w cual|strong="H1931"\w* \w edificó|strong="H1129"\w* Ono y \w Lod|strong="H3850"\w* con \w sus|strong="H1931"\w* \w aldeas|strong="H1323"\w*,  
\v 13 \w Bería|strong="H1283"\w* y Sema, quienes eran \w jefes|strong="H7218"\w* de \w las|strong="H1992"\w* casas paternas de \w los|strong="H1992"\w* \w habitantes|strong="H3427"\w* de Ajalón. \w Echaron|strong="H1272"\w* \w a|strong="H3068"\w* \w los|strong="H1992"\w* \w habitantes|strong="H3427"\w* de Gat.  
\v 14 Ahío, \w Sasac|strong="H8349"\w*, Jeremot,  
\v 15 \w Zebadías|strong="H2069"\w*, \w Arad|strong="H6166"\w*, Ader,  
\v 16 Micael, Ispa y Joha fueron \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Bería|strong="H1283"\w*.  
\v 17 \w Zebadías|strong="H2069"\w*, Mesulam, Hizqui, \w Heber|strong="H2268"\w*,  
\v 18 Ismerai, Jezlías y \w Jobab|strong="H3103"\w* fueron \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Elpaal.  
\v 19 Jaquim, Zicri, \w Zabdi|strong="H2067"\w*,  
\v 20 Elienai, Ziletai, Eliel,  
\v 21 \w Adaías|strong="H5718"\w*, Beraías y Simrat fueron \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Simei.  
\v 22 Ispán, \w Heber|strong="H5677"\w*, Eliel,  
\v 23 \w Abdón|strong="H5658"\w*, Zicri, \w Hanán|strong="H2605"\w*,  
\v 24 \w Hananías|strong="H2608"\w*, \w Elam|strong="H5867"\w*, Anatotías,  
\v 25 Ifdaías y \w Peniel|strong="H6439"\w* fueron \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Sasac|strong="H8349"\w*.  
\v 26 Samserai, \w Seharías|strong="H7841"\w*, Atalías,  
\v 27 Jaresías, Elías y Zicri fueron \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Jeroham|strong="H3395"\w*.   
\p
\v 28 Éstos fueron \w jefes|strong="H7218"\w* de casas paternas según sus familias, y vivieron en Jerusalén.  
\v 29 En \w Gabaón|strong="H1391"\w* \w vivía|strong="H3427"\w* \w el|strong="H3427"\w* padre de \w Gabaón|strong="H1391"\w*, cuya esposa se \w llamó|strong="H8034"\w* Maaca,  
\v 30 y su \w hijo|strong="H1121"\w* \w primogénito|strong="H1060"\w* \w Abdón|strong="H5658"\w*. Luego nacieron Zur, \w Cis|strong="H7027"\w*, \w Baal|strong="H1168"\w*, \w Nadab|strong="H5070"\w*,  
\v 31 \w Gedor|strong="H1446"\w*, Ahío y Zequer.  
\v 32 Miclot \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Simea. \w Éstos|strong="H1992"\w* también vivieron \w frente|strong="H5048"\w* \w a|strong="H3068"\w* \w sus|strong="H1992"\w* hermanos \w en|strong="H5973"\w* Jerusalén.  
\v 33 \w Ner|strong="H5369"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Cis|strong="H7027"\w*, y \w Cis|strong="H7027"\w* \w a|strong="H3068"\w* \w Saúl|strong="H7586"\w*. \w Saúl|strong="H7586"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Jonatán, Malquisúa, Abinadab y Es-baal.  
\v 34 \w Hijo|strong="H1121"\w* \w de|strong="H1121"\w* Jonatán fue Merib-baal, y Merib-baal \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Micaía.  
\v 35 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Micaía fueron: Pitón, Melec, Tarea y Acaz.  
\v 36 Acaz \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Joada, Joada \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Alemet, Azmavet y \w Zimri|strong="H2174"\w*. \w Zimri|strong="H2174"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Mosa.  
\v 37 Mosa \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Bina, cuyo \w hijo|strong="H1121"\w* fue Rafa, cuyo \w hijo|strong="H1121"\w* fue Elasa, cuyo \w hijo|strong="H1121"\w* fue Azel.  
\v 38 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Azel fueron \w seis|strong="H8337"\w*, cuyos \w nombres|strong="H8034"\w* son: \w Azricam|strong="H5840"\w*, Bocru, \w Ismael|strong="H3458"\w*, \w Searías|strong="H8187"\w*, \w Obadías|strong="H5662"\w* y \w Hanán|strong="H2605"\w*. \w Todos|strong="H3605"\w* \w éstos|strong="H3605"\w* fueron \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Azel.  
\v 39 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* su hermano Esec fueron: su \w primogénito|strong="H1060"\w* Ulam, \w Jehús|strong="H3266"\w* \w el|strong="H1121"\w* \w segundo|strong="H8145"\w*, Elifelet \w el|strong="H1121"\w* \w tercero|strong="H7992"\w*.  
\v 40 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Ulam \w fueron|strong="H1961"\w* \w hombres|strong="H1368"\w* \w valientes|strong="H1368"\w* \w que|strong="H1869"\w* manejaban \w el|strong="H3605"\w* \w arco|strong="H7198"\w*, \w los|strong="H1121"\w* cuales \w tuvieron|strong="H1961"\w* \w muchos|strong="H7235"\w* \w hijos|strong="H1121"\w* y \w nietos|strong="H1121"\w*: un total \w de|strong="H1121"\w* 150.  
\p \w Todos|strong="H3605"\w* \w éstos|strong="H3605"\w* \w fueron|strong="H1961"\w* descendientes \w de|strong="H1121"\w* \w Benjamín|strong="H1144"\w*.   
\c 9  
\s1 Los que regresaron de Babilonia  
\p
\v 1 \w Todo|strong="H3605"\w* \w Israel|strong="H3478"\w* \w fue|strong="H3063"\w* registrado \w según|strong="H5921"\w* sus genealogías, \w y|strong="H5921"\w* \w están|strong="H2009"\w* inscritos \w en|strong="H5921"\w* \w el|strong="H5921"\w* rollo \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w reyes|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*. \w Y|strong="H3068"\w* \add los\add* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w* fueron llevados \w cautivos|strong="H1540"\w* \w a|strong="H3068"\w* Babilonia, \w por|strong="H5921"\w* causa \w de|strong="H5921"\w* su infidelidad.   
\p
\v 2 \w Los|strong="H3427"\w* \w primeros|strong="H7223"\w* que regresaron \w a|strong="H3068"\w* sus posesiones en sus \w ciudades|strong="H5892"\w* fueron \w los|strong="H3427"\w* israelitas: \w sacerdotes|strong="H3548"\w*, \w levitas|strong="H3881"\w* y servidores del Templo.   
\p
\v 3 \w En|strong="H4480"\w* Jerusalén \w se|strong="H4480"\w* establecieron algunos \w de|strong="H4480"\w* \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w Judá|strong="H3063"\w*, \w Benjamín|strong="H1144"\w*, Efraín y \w Manasés|strong="H4519"\w*:  
\v 4 \w Utai|strong="H5793"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Amiud, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Omri|strong="H6018"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Imri, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Bani|strong="H1137"\w*, \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Fares, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*.  
\v 5 \w De|strong="H4480"\w* \w los|strong="H1121"\w* silonitas, \w Asaías|strong="H6222"\w*, \w el|strong="H1121"\w* \w primogénito|strong="H1060"\w*, y sus \w hijos|strong="H1121"\w*.  
\v 6 \w De|strong="H4480"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w Zera|strong="H2226"\w*, Jeuel y sus hermanos. Eran 690.  
\v 7 \w De|strong="H4480"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w Benjamín|strong="H1144"\w*, \w Salú|strong="H5543"\w*, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* Mesulam, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* Hodavías, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* \w Asenúa|strong="H5574"\w*,  
\v 8 Ibneías, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Jeroham|strong="H3395"\w*, Ela, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Uzi, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Micri, y Mesulam, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Sefatías, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Reuel|strong="H7467"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Ibnías.  
\v 9 Sus hermanos según sus \w familias|strong="H1004"\w*: 956. \w Todos|strong="H3605"\w* \w estos|strong="H3605"\w* hombres fueron \w jefes|strong="H7218"\w* de \w familia|strong="H1004"\w* en sus \w casas|strong="H1004"\w* paternas.   
\p
\v 10 \w De|strong="H4480"\w* los \w sacerdotes|strong="H3548"\w*: \w Jedaías|strong="H3048"\w*, \w Joiarib|strong="H3080"\w*, Jaquín,  
