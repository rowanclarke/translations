\id PRO
\h Awařen Iweznen
\toc1 Awařen Iweznen
\toc2 Awařen Iweznen
\toc3 Awřn.
\mt1 Awařen Iweznen
\c 1
\s1 Awař Amezwaru - Lɣaraḍ n wawařen iweznen
\m 
\v 1 Awařen iweznen n Suliman,
\m mmis n Dawud, ajeǧid n Israil,
\m 
\v 2 ḥima ad issen \add bnadem\add* tiɣit d ttarbiyyet,
\m ḥima ad ifhem awařen \add ccuren s\add* řefhamet,
\m 
\v 3 ḥima ad iqbeř ttarbiyyet d řeɛqeř,
\m tasegda d řḥeqq d řeṣfayet,
\m 
\v 4 ḥima ad iwc asfarz i iḥafiyyen,
\m tussna d uḥadur i uḥudri.
\m 
\v 5 Ejj amiɣis ad iseř
\m u ad yarni di řefhamet nnes,
\m ejj wenni ifehhmen ad ikseb řeqnaɛet,
\m 
\v 6 ḥima ad ifhem awař iweznen d lmatal,
\m awařen n imiɣisen
\m d řemɛani innufaren nsen.
\m 
\v 7 Tiggʷudi n SIDI d beddu n tussna,
\m \add maca\add* ibuhařiyyen
\m sseḥqaran tiɣit d ttarbiyyet. \x ◘ \xo 1:7 \xt Ayub 28:28; Izhd. 111:10; Awřn. 9:10; Amb. 12:13\x*
\b
\s1 Ccwar n babas i mmis
\m 
\v 8 Seř, a mmi, ɣar ttarbiyyet n babac,
\m war ttagi ca taɣuri n yemmac,
\m 
\v 9 maɣar nitenti \add ad iřint\add*
\m d ttaj icna x uzeǧif nnec,
\m d tseddyin \add izewwqen\add* i yiri nnec.
\m 
\v 10 \add A\add* mmi, mařa xsen imednab
\m ad cek ɣwan,
\m war d asen ttegg ca array.
\m 
\v 11 Mařa nitni qqaren:
\m “Uyur akidneɣ, ejj ad nḥama
\m i \add usizzeř n\add* idammen,
\m ejj aneɣ ad negg ijj n řfex
\m i umezdag, břa ssibbet,
\m 
\v 12 ejj aneɣ ad ten nṣarḍ am ddaren,
\m am mammec \add tṣareḍ\add* řaxart,
\m am kemřem,
\m am mammec imsar
\m ak-d yinni ihekkwan
\m deg weḥfur \add n wenḍeř\add*.
\m 
\v 13 Ad naf ɛřamkur řeḥwayej yiɣřan aṭṭas,
\m tudrin nneɣ ad tent neccur s tkeccaḍt.
\m 
\v 14 Cek ad tenḍared taqedduḥt nnec jar aneɣ,
\m ad ɣarneɣ \add tiři\add* marra ict n tecyart.”
\m 
\v 15 \add A\add* mmi, war kidsen ggur deg webrid,
\m siggʷej aḍar nnec x umesruq nsen,
\m 
\v 16 maɣar iḍaren nsen ttazzřen ɣar řɣar,
\m u nitni ttqeǧiqen
\m maḥend ad ssizzřen idammen. \x ◘ \xo 1:16 \xt Ica. 59:7; Rum. 3:15\x*
\m 
\v 17 Maɣar s řbaṭeř ad tᵉttwabezzeɛ tracca,
\m zzat i tiṭṭawin n marra
\m min ɣar iǧa wafriwen,
\m 
\v 18 \add maɣar\add* nitni ttḥaman
\m idammen \add n yixef\add* nsen,
\m tteggen řfex i řeɛmur \add n yixef\add* nsen.
\m 
\v 19 Ammu i iǧan ibriden n kuř ijj
\m wenni ittazzřen ɣar arbeḥ,
\m aqa aya itteṭṭef řeɛmar n sidis. \x ◘ \xo 1:19 \xt Ayub 8:13\x*
\b
\s1 Tiɣit
\m 
\v 20 Tiɣit tᵉttřaɣa s jjhed \add diha\add* barra,
\m tessgeɛɛed tmijja nnes deg wazzayen.
\m 
\v 21 Ɣar umezwar n imucan i daysen řharaj,
\m tᵉttbarraḥ nettat,
\m ɣar wadafen n tewwura n tendint
\m tessawař awařen nnes.
\m 
\v 22 “Ař meřmi ɣa qqimen
\m iḥafiyyen ttexsen taqubbanect,
\m \add ař meřmi\add* d asen i ɣa iɛjeb
\m uḥecci i imestehzayen,
\m u \add ař meřmi\add* ɣa carhen
\m ibuhařiyyen tussna?
\m 
\v 23 Dewřem ɣar uwebbex inu!
\m Xzarem, necc ad xawem ssfarrɣeɣ
\m arruḥ inu,
\m awařen inu ad awem ten ɛeřmeɣ.”
\b
\m 
\v 24 “Aqa zeɛma řaɣiɣ u kenniw war texsem,
\m sswiẓẓḍeɣ necc afus inu,
\m \add maca\add* uřa d ijj war d as iḥekkar. \x ◘ \xo 1:24 \xt Ica. 65:12; 66:4; Irm. 13:10\x*
\m 
\v 25 Tenḍarem ccwar inu,
\m awebbex inu war t teqbiřem.
\m 
\v 26 \add S uyenni\add* uřa d necc
\m ad ḍeḥceɣ x uḍeyyeɛ nwem,
\m necc ad \add zzaywem\add* stehzeɣ
\m xmi dd ɣa yas unexřiɛ nwem,
\m 
\v 27 xmi dd ɣa yas unexřiɛ nwem
\m am yijj n ureddeǧ,
\m aḍeyyeɛ nwem am yict n tḥaryaḍt,
\m xmi xawem dd ɣa tewḍa
\m řeḥṣaret d teggʷudi. \x ◘ \xo 1:27 \xt Ayub 27:9; 35:12; Ica. 1:15; Irm. 11:11; 14:12; Ḥiz. 8:18; Mixa 3:4\x*
\m 
\v 28 Xenni ad xafi dd-řaɣan,
\m maca necc war dd-ttarriɣ,
\m ad xafi arzun, \add maca\add* war d ayi ttifen,
\m 
\v 29 minzi nitni carhen tussna,
\m u war ixḍaren \add ad ṭṭfen di\add* tiggʷudi n SIDI.
\m 
\v 30 Nitni war xsen ca řecwar inu,
\m marra awebbex inu nḍaren t.
\m 
\v 31 Nitni ad ccen zi řɣiǧet n webrid nsen,
\m u ad jjiwnen s ixarriṣen n yixef nsen,
\m 
\v 32 minzi uffuɣ n iḥafeyyen
\m \add x webrid\add* ad ten ineɣ,
\m u afřaḥ n ibuhařiyyen ad ten isshellek.
\m 
\v 33 Wi ɣari i ɣa isřen, ad izdeɣ di řaman,
\m ad yiři di řehna břa anexřiɛ n tuɛeffna.”
\b
\b
\c 2
\m 
\v 1 Mmi inu, mařa tqebřed awařen inu
\m u ad teḥḍid tiweṣṣa inu ɣarek,
\m 
\v 2 maḥend amezzuɣ nnec ad iwc taynit i tiɣit
\m \add uca\add* uř nnec ad imeyyeř ɣar řefhamet,
\m 
\v 3 \add wah,\add* mařa tᵉttřaɣid-dd x řeɛqeř,
\m ad tessxedmed tmijja nnec
\m maḥend \add ad tafed\add* řefhamet,
\m 
\v 4 mařa tarezzud xas
\m am \add tarezzud\add* x nnuqart,
\m \add mařa\add* xas tarezzud
\m am x txubay innuffaren, \f ◼ \fr 2:4 \fk tixubay\ft - niɣ ‘řeknuz’.\f*  \x ◘ \xo 2:4 \xt Mt. 13:44\x*
\m 
\v 5 xenni ad tfehmed i tiggʷudi n SIDI,
\m u ad tafed tussna n AREBBI.
\b
\m 
\v 6 Maɣar SIDI ittic tiɣit,
\m zeg uqemmum nnes tᵉtteffeɣ-dd
\m tussna d řefhamet. \x ◘ \xo 2:6 \xt 1 Ij. 3:9, 12; Yaɛ. 1:5\x*
\m 
\v 7 I yinni igguren nican issewjed asen twiza,
\m i yinni igguren di řekmaret
\m \add aqa-t\add* d taseddart i useřqi,
\m 
\v 8 ḥima ad qqimen ttᵉṭṭfen
\m deg imesraq n řḥeqq,
\m u Netta ad issar abrid
\m n yinni daysen řaman zzates.
\b
\m 
\v 9 Xenni i ɣa tfehmed tasegda d řḥeqq,
\m uřa d řeṣfayet,
\m kuř řatar iṣebḥen \add maḥend ad t teḍfared\add*.
\m 
\v 10 Maɣar tiɣit ad tadef ɣar wuř nnec,
\m u tussna ad tarḍa x řeɛmar nnec.
\m 
\v 11 Aḥadur ad xak iḥḍa,
\m řefhamet ad xak tessar:
\b
\m 
\v 12 ... maḥend ad cek tfekk
\m zeg webrid n uɛeffan,
\m zeg weryaz nni iqeǧben awař nnes,
\m 
\v 13 zeg inni isemḥen
\m deg imesraq iseggmen,
\m maḥend ad uyuren ibriden n ṭṭřam,
\m 
\v 14 inni ifarrḥen maḥend ad ggen řɣar,
\m \add u\add* ssřiwřiwen x řexdaɛat n řɣar,
\m 
\v 15 zeg yinni farɣen imesraq nsen
\m d yinni imeyyřen ssa d ssa
\m di řatarat \add n yixef\add* nsen,
\b
\m 
\v 16 ... maḥend ad cek tfekk
\m zi temɣart tbarranect,
\m zi temɣart zi barra i ittɣarran s
\m wawařen nnes, \x ◘ \xo 2:16 \xt Awřn. 5:3; 6:24; 7:5\x*
\m 
\v 17 tenni isemḥen
\m deg umeddukkeř n temẓi nnes,
\m u tᵉttu řɛahd n AREBBI nnes.
\m 
\v 18 Minzi thekkwa ɣar řmewt
\m \add jmiɛ\add* ak-d taddart nnes,
\m u řatarat nnes \add hekkwant\add*
\m ɣar řexyařat \add n imettan\add*.
\m 
\v 19 Marra inni ɣares ɣa yadfen,
\m war dd-ttɛiqqiben ɛemmarṣ,
\m war ttakkwaḍen ɛemmarṣ
\m ɣar imesraq n tudart.
\b
\m 
\v 20 ... \add wah,\add* ḥima ad tuyured
\m abrid n iṣebḥanen,
\m u ad tᵉṭṭfed
\m deg imesraq n imseggaden,
\m 
\v 21 maɣar inni igguren nican
\m ad zedɣen di temmurt,
\m u inni igguren s řekmaret
\m ad dayes qqimen. \x ◘ \xo 2:21 \xt Izhd. 37:29\x*
\m 
\v 22 \add Maca\add* iɛeffanen
\m ad ttwaqeḍɛen zi temmurt,
\m iɣeddaren ad zzayes ttwaqeřɛen. \x ◘ \xo 2:22 \xt Ayub 18:17; Izhd. 104:35\x*
\b
\b
\c 3
\m 
\v 1 Mmi inu, war ttᵉttu
\m \add taɣuri\add* inu n Ccariɛa,
\m ejj uř nnec ad iḥḍa tiweṣṣa inu,
\m 
\v 2 maɣar nitenti ad ac dd-iwyent
\m aṭṭas n wussan,
\m uřa d iseggʷusa n tudart d řehna. \x ◘ \xo 3:2 \xt Aɛwd. 8:1; 30:20\x*
\m 
\v 3 Tamexsiwt icewwaren d řaman
\m war ten tejjid ad zzayek ffɣen,
\m qqen i-ten ɣar yiri nnec,
\m ari ten x teřwiḥt n wuř nnec, \x ◘ \xo 3:3 \xt Uf. 13:9; Aɛwd. 6:8\x*
\m 
\v 4 \add xenni\add* ad tafed arḍa
\m d řefhamet iṣebḥen
\m di tiṭṭawin n AREBBI u n bnadem.
\m 
\v 5 Tiqq di SIDI s wuř nnec kuřci,
\m war ttcařa x řefhamet \add n yixef\add* nnec.
\m 
\v 6 Ssen i-t di marra ibriden nnec,
\m \add xenni\add* Netta ad iseggem imesraq nnec. \x ◘ \xo 3:6 \xt 1 Im. 28:9\x*
\m 
\v 7 War ttegg ixef nnec d amiɣis.
\m Ggʷed SIDI u beɛɛed
\m x min iǧan d aɛeffan. \x ◘ \xo 3:7 \xt Rum. 12:16\x*
\m 
\v 8 Aya ad yiři d agenfu
\m i iẓewran \add n tudart\add* nnec,
\m d wenɛac i iɣsan nnec.
\m 
\v 9 Weqqar SIDI s wagřa nnec,
\m s tmezwarut n marra ṣṣabet nnec. \x ◘ \xo 3:9 \xt Uf. 23:19; 34:26; Aɛwd. 26:2-11; Mal. 3:10; Lk. 14:13\x*
\m 
\v 10 \add Xenni\add* ad ttwaccuren
\m řehrit nnec s ufeyyeḍ,
\m u tisirin nnec \add n uḍiř\add*
\m ad dduqqzen s binu n jdid. \x ◘ \xo 3:10 \xt Aɛwd. 28:8\x*
\b
\m 
\v 11 Mmi inu, war neṭṭar ttarbiyyet n SIDI,
\m war ttarra aɛrur x uwebbex nnes, \x ◘ \xo 3:11 \xt Ayub 5:17; Ɛbr. 12:5\x*
\m 
\v 12 maɣar wenni issɛizza SIDI,
\m ad t iɛaqeb ɛawed,
\m am ittegg babas ak-d mmis
\m wenni x yarḍa. \x ◘ \xo 3:12 \xt Asa. 3:19\x*
\b
\m 
\v 13 Sseɛd n bnadem nni ittafen tiɣit,
\m uřa d bnadem nni ittkessaben řefhamet,
\m 
\v 14 maɣar min tᵉttawi nettat,
\m teḥřa x tsebbabt di nnuqart,
\m u řɣiǧet nnes \add teḥřa\add* x wureɣ ittissiqen. \x ◘ \xo 3:14 \xt Ayub 28:15; Izhd. 19:11; Awřn. 8:11, 19; 16:16\x*
\m 
\v 15 Nettat tiɣřa x řmarjan,
\m u marra min di \add tzemmared\add*
\m ad temmeẓred,
\m war izemmar akides ittemqudda. \x ◘ \xo 3:15 \xt Awřn. 8:11\x*
\m 
\v 16 Tuzzeggart n wussan \add ɣares\add*
\m deg ufus nnes,
\m agřa d ccan aqa aten x uzeřmaḍ nnes.
\m 
\v 17 Ibriden nnes d ibriden n řeḍrafet,
\m u marra imesraq nnes aqa aten d řehna.
\m 
\v 18 Nettat d tacejjart n tudart
\m i yinni ɣares iřesqen,
\m kuř ijjen wenni dayes itteṭṭfen,
\m ad yiři d amesɛud. \f ◼ \fr 3:18 \fk tacejjart\ft - niɣ ‘addag’ (‘iddagen’).\f*
\b
\m 
\v 19 SIDI igga dsas n temmurt s tiɣit nnes,
\m s řefhamet nnes igga ijenwan.
\m 
\v 20 Zi tussna nnes dduqqzen-dd
\m \add waman\add* ihewřen,
\m ttnecnicen-dd iseynuten nnda. \x ◘ \xo 3:20 \xt Amz. 1:9, 10\x*
\m 
\v 21 Mmi inu, war tent tejjid
\m ad ffɣent zi tiṭṭawin nnec,
\m ḥḍa aftan d uḥaḍur, \f ◼ \fr 3:21 \ft \bd ’tent‘\bd* - awař-a iceyyar ɣar tiɣit d řefhamet i x issawař umseřmad n tiɣit di ayet 13 n wudem-a.\f*
\m 
\v 22 \add maɣar\add* ad iřin d tudart i řeɛmar nnec
\m uřa d arḍa i yiri nnec.
\m 
\v 23 Xenni ad tuyured abrid nnec di řaman,
\m war tᵉttneqriḍed deg uḍar nnec. \x ◘ \xo 3:23 \xt Izhd. 37:24; 91:11, 12\x*
\m 
\v 24 Mařa truḥed ad tezzřed,
\m war tennxeřɛid,
\m u \add xmi\add* i ɣa tezzřed, ad yiẓid yiḍeṣ nnec. \x ◘ \xo 3:24 \xt Lawi 6:19; Ayub 11:19; Izhd. 3:6; 4:9; 91:5, 6\x*
\m 
\v 25 War tteggʷed zeg unexřiɛ n deɣya
\m uřa zeg wareyyeb s \add ufus\add* n iɛeffanen
\m xmi dd ɣa yas. \x ◘ \xo 3:25 \xt Ayub 5:21\x*
\m 
\v 26 Maɣar SIDI ad ac yiři d asenned nnec,
\m Netta ad iḥḍa afus nnec zi tsarrift.
\b
\m 
\v 27 War qeṭṭeɛ řxar x bab nnes,
\m mařa aqa-t deg ufus nnec
\m maḥend ad tegged \add řxar\add*.
\m 
\v 28 War qqar i jjar nnec:
\m ‘Ruḥ uca ɛqeb-dd,
\m tiwecca ad \add ac tt\add* wceɣ!’,
\m mařa \add tamesřact\add* aqa-tt akidek.
\m 
\v 29 War nekkwi řɣar ak-d jjar nnec,
\m umi akidek izeddeɣ di řaman.
\m 
\v 30 War temcubbuc
\m ak-d ijj n bnadem břa ssibbet,
\m mařa netta war d ac iggi řɣar.
\m 
\v 31 War ttasem zeg ijj n bu-řexcunet,
\m ḥḍa maḥend war tᵉttixḍared
\m uřa \add d ijj\add* zi marra ibriden nnes. \x ◘ \xo 3:31 \xt Izhd. 37:1; 73:3; Awřn. 23:17\x*
\m 
\v 32 maɣar wenni itteffɣen zeg webrid,
\m aqa-t d nnɛi i SIDI,
\m \add maca\add* \add Netta ittegg\add* řaman nnes
\m deg inni igguren nican. \x ◘ \xo 3:32 \xt Izhd. 25:14\x*
\m 
\v 33 Nneɛřet n SIDI
\m \add aqa-tt\add* x taddart n uɛeffan,
\m \add maca\add* tazeddiɣt n imseggaden
\m ad tt ibarek. \x ◘ \xo 3:33 \xt Lawi 26:14-45; Aɛwd. 28:15-68; Mal. 2:2\x*
\m 
\v 34 Mařa d imestehzayen,
\m ad \add zzaysen\add* isstehza Netta,
\m \add maca mařa\add* d inni ittwaḥṣaren,
\m ad \add asen\add* iscen arḍa nnes. \x ◘ \xo 3:34 \xt Yaɛ. 4:6; 1 Bṭ. 5:5\x*
\m 
\v 35 Imiɣisen ad warten ccan,
\m \add maca\add* ibuhařiyyen
\m ad ssarbun řefḍiḥet x yixef nsen.
\b
\b
\c 4
\m 
\v 1 Sřem, kenniw iḥenjiren,
\m ɣar ttarbiyyet n baba\add twem\add*,
\m ḥekkarem mliḥ
\m maḥend ad teksim tussna s řefhamet,
\m 
\v 2 maɣar necc ad awem wceɣ
\m taɣuri iṣebḥen,
\m war semmḥem di tɣuri inu.
\m 
\v 3 Maɣar necc tuɣa ayi d mmis i baba,
\m areqqaɣ d ayenni n \add mmis\add*
\m zzat i wudem n yemma. \x ◘ \xo 4:3 \xt 1 Im. 29:1\x*
\m 
\v 4 Netta isseřmed ayi, inna ayi:
\m “Ejj uř nnec ad iṭṭef deg wawařen inu,
\m ḥḍa tiweṣṣa inu, \add xenni\add* ad teddared!” \x ◘ \xo 4:4 \xt 1 Im. 28:9\x*
\m 
\v 5 Jbed-dd ɣarek tiɣit,
\m jbed-dd ɣarek řeɛqeř,
\m war tᵉttu u war tḥeyyid
\m x wawařen n uqemmum inu.
\m 
\v 6 War semmeḥ \add di tiɣit\add*,
\m \add xenni\add* nettat ad cek teḥḍa,
\m sɛizz i-tt u nettat ad cek tessar. \f ◼ \fr 4:6 \fk War semmeḥ \bdit di tiɣit\bdit*\ft - s Tɛibranit ‘war semmeḥ dayes’.\f*
\m 
\v 7 Beddu n tiɣit d uḍuf n tiɣit,
\m ṭṭef řefhamet s marra min ɣarek. \x ◘ \xo 4:7 \xt Awřn. 23:23\x*
\m 
\v 8 Sgeɛɛed i-tt-i-dd,
\m xenni nettat ad cek tessgeɛɛed,
\m nettat ad ac tegg ccan mařa tdarrɛed as.
\m 
\v 9 Nettat ad ac tewc ijj n ttaj tecna
\m x uzeǧif nnec,
\m ad ac tewc ijj n ttaj izewwqen. \x ◘ \xo 4:9 \xt Awřn. 1:19\x*
\b
\m 
\v 10 Seř, \add a\add* mmi, u ksi awařen inu,
\m \add xenni\add* ad mmarnin
\m iseggʷusa n tudart nnec.
\m 
\v 11 Ssřemdeɣ ac abrid n tiɣit,
\m nedheɣ cek di řatarat iseggmen.
\m 
\v 12 Mařa tuyured, aṣurif nnec
\m war ittneḥṣṣar,
\m mařa tazzřed, war ttneqriḍed.\x ◘ \xo 4:12 \xt Izhd. 91:11\x*
\m 
\v 13 Cebbar di ttarbiyyet,
\m war \add xas\add* temmsebḍa,
\m ḥḍa tt, maɣar nettat d tudart nnec.
\m 
\v 14 War ggur x umesruq n iɛeffanen,
\m war ttidif abrid n yinni itteggen řɣar, \x ◘ \xo 4:14 \xt Izhd. 1:1; Awřn. 1:10, 15\x*
\m 
\v 15 ḥeyyed xas, war xas ggur,
\m ffeɣ zzayes u ad tekked xas.
\m 
\v 16 Maɣar nitni war ttᵉṭṭṣen
\m am war \add zemmaren\add* ad ggen tuɛeffna,
\m ittraḥ asen iḍeṣ nsen
\m mařa war ssneqriḍen ḥed \add ɛad\add*,
\m 
\v 17 maɣar nitni ttᵉtten aɣrum n řɣecc,
\m u nitni sessen binu zi tmegga n řexcunet.
\b
\m 
\v 18 Amesruq n imseggaden
\m am tfawt ittissiqen n teffut,
\m tenni tarenni deg useqseq
\m ař imɣar wass qaɛ.
\m 
\v 19 Abrid n iɛeffanen am taǧest,
\m nitni war ssinen min di i ɣa nqarḍen.
\m 
\v 20 Mmi inu, ewc taynit i wawařen inu,
\m ewc amezzuɣ nnec i wawařen inu,
\m 
\v 21 war ten ttejji ad ɣefřen
\m zi tiṭṭawin nnec,
\m xemmeř i-ten daxeř deg wuř nnec,
\m 
\v 22 maɣar nitni d tudart
\m i yinni ten i ɣa yafen,
\m uřa d agenfu i arrimet nsen marra. \x ◘ \xo 4:22 \xt Awřn. 4:13\x*
\b
\m 
\v 23 Ḥḍa uř nnec x marra
\m min izemmar ad ittwaḥḍa,
\m maɣar zzayes ffɣen iẓewran n tudart.
\m 
\v 24 Kkes ixarriqen n uqemmum nnec,
\m sbeɛɛed xak afaryeḍ n iyencicen nnec.
\m 
\v 25 Ejj tiṭṭawin nnec ad xzarent ɣar zzat,
\m \add ejj\add* abřiwen nnec ad xzaren
\m ɣar \add min iǧan\add* arendad nnec.
\m 
\v 26 Waṭa řatar n uḍar nnec,
\m ejj ad iřin marra ibriden nnec sarrḥen.
\m 
\v 27 War farreɣ \add ɣar\add* yefus uřa \add ɣar\add* uzeřmaḍ,
\m sbeɛɛed aḍar nnec zi tuɛeffna. \x ◘ \xo 4:27 \xt Aɛwd. 5:32; 28:14\x*
\b
\b
\c 5
\s1 Aɣekkʷi zi temɣart tabarranit
\m 
\v 1 Mmi inu, ewc taynit i tiɣit inu,
\m ewc amezzuɣ i řefhamet inu,
\m 
\v 2 maḥend ad tewced ḥaḍur,
\m u iyencicen nnec ad ḥḍan x tussna.
\m 
\v 3 Minzi iyencicen n temɣart tabarranit
\m ttudumen s tamment n teɣraṣt,
\m aneɣ nnes d ařeqqaɣ x zzect, \x ◘ \xo 5:3 \xt Awřn. 2:16; 6:24\x*
\m 
\v 4 maca ɣar uneggar
\m \add aqa-tt\add* d tamerzagt am cciḥ,
\m teqḍeɛ am yijj n ssif
\m s \add tnayen n\add* wudmawen.
\m 
\v 5 Iḍaren nnes ttawyen ɣar řmewt,
\m iṣuraf nnes neddhen ɣar řaxart. \x ◘ \xo 5:5 \xt Awřn. 7:27\x*
\m 
\v 6 Ařami war tᵉṭṭifed \add ɛemmarṣ\add*
\m abrid n tudart,
\m ggurent řatarat \add n iḍaren\add* nnes
\m ssa d ssa břa ma tessned cek.
\b
\m 
\v 7 Xenni řexxu, \add a\add* iḥenjiren, sřem-dd ɣari,
\m war tḥeyyadem ca
\m x wawařen n uqemmum inu.
\m 
\v 8 Siggʷej abrid nnec xas,
\m war ttades tawwart n taddart nnes,
\m 
\v 9 ḥima war tᵉtticed ccan nnec i inneɣni,
\m iseggʷusa nnec i wenni itteqsiḥen aṭṭas, \x ◘ \xo 5:9 \xt Awřn. 6:34,35\x*
\m 
\v 10 ḥima ibarraniyyen
\m war ttjawanen deg wagřa nnec,
\m u marra \add řɣiǧet n\add* umarret nnec
\m war dd-tᵉttis di taddart
\m n wenni war ittwissnen,
\m 
\v 11 u ad tzehhared ɣar uneggar,
\m xmi ɣa tᵉttwacc arrimet nnec
\m d weysum nnec,
\m 
\v 12 ad tinid: “Mammec ggiɣ necc
\m carheɣ ttarbiyyet,
\m \add mammec\add* inḍar uř inu awebbex?
\m 
\v 13 \add Mammec\add* war sřiɣ ɣar tmijja
\m n yinni d ayi idarrben,
\m war wciɣ amezzuɣ inu
\m i imseřmaden inu?
\m 
\v 14 Ɛřaḥař tuɣa ufiɣ ixef inu
\m di ɛřam kuř řɣar,
\m di řwesṭ n wegraw \add n řgens\add* u n tmesmunt!”
\m 
\v 15 Suw aman zeg wanu nnec,
\m uřa d aman issizzřen
\m zi řaǧaɣ n řɛunṣar nnec.
\m 
\v 16 Iři ad ssefyen waman
\m \add n řɛunṣar\add* nnec barra,
\m \add am\add* tɣezratin n waman x ibriden.
\m 
\v 17 Ejj i-ten ad iřin i cek weḥḥdek,
\m war iǧi i ibarraniyyen i din zzatek.
\m 
\v 18 Ad ittwabarek řɛunṣar nnec,
\m farḥ i temɣart \add zeg wussan\add* n temẓi nnec.
\m 
\v 19 Tudadt iɛizzen uřa d tiɣeydet n wezɣar
\m icewwaren \add nettat\add*!
\m Ejj ibbac nnes ad cek ssyiwyen
\m di marra ussan,
\m sellem ixef nnec řebda ɣar tayri nnes!
\m 
\v 20 Mayemmi, \add a\add* mmi,
\m ad cek teɣwa temɣart tabarranect,
\m ad tdarrɛed i weḥsin n temɣart
\m war tessined?
\m 
\v 21 Maɣar ibriden n bnadem
\m aqa aten \add din\add* zzat i tiṭṭawin n SIDI,
\m Netta yarzu di marra imesraq nnes. \x ◘ \xo 5:21 \xt 2 Im. 16:9; Ayub 31:4; 34:21; Awřn. 15:3; Irm. 16:17; 32:19\x*
\m 
\v 22 Řmuɛsiyyet \add n yixef\add* nnes
\m ad tḥebbes aɛeffan,
\m s iseɣwan n ddnub nnes ad ittwacedd.
\m 
\v 23 Netta ad immet
\m umi war din tuɣi ttarbiyyet,
\m ad iweddar
\m s tubbuheřya nnes tameqqrant.
\b
\b
\c 6
\m 
\v 1 Mmi inu, mařa tdewřed
\m d amarhun i jjar nnec,
\m tewcid ticti nnec n ufus i yijj n ubarrani,
\m 
\v 2 \add mařa\add* tdewřed teqqned
\m zeg wawařen n uqemmum nnec,
\m tᵉttwaḥebbsed zeg wawařen
\m n uqemmum nnec,
\m 
\v 3 \add xenni\add* egg ta, \add a\add* mmi, u fekk ixef nnec,
\m maɣar tdewřed ɣar ufus n jjar nnec:
\m uyur, bendeq \add xas\add*
\m u zeyyar x wenni cek yudsen.
\m 
\v 4 War ttic ca iḍeṣ i tiṭṭawin nnec,
\m uřa d anudem i wabřiwen nnec. \x ◘ \xo 6:4 \xt Izhd. 132:4\x*
\m 
\v 5 Fekk ixef nnec zeg ufus \add nnes\add*
\m am tɣeyḍet n weɣzar,
\m am yijj n wejḍiḍ zeg ufus n unegmar.
\b
\m 
\v 6 Uyur ɣar tkeḍfet, \add cek, a\add* ameɛguz,
\m xzar mammec tuyur nettat
\m u dweř d amiɣis.
\m 
\v 7 Waxxa nettat war ɣares bu umgewwed,
\m niɣ aweqqaf niɣ řḥakem,
\m 
\v 8 \add ɛad\add* tessewjad aɣrum nnes deg unebdu,
\m teyru macca nnes di řweqt n tmeyra.
\m 
\v 9 Ař meřmi ɣa teqqimed tezzřed,
\m \add cek, a\add* ameɛguz?
\m Meřmi ɣa tekkared zeg iḍeṣ nnec? \x ◘ \xo 6:9 \xt Awřn. 13:4; 20:4; 24:33,34\x*
\m 
\v 10 Arni cwayt n yiḍeṣ,
\m arni cwayt n uwarrec,
\m arni cwayt n ubuzzeř s ifassen imunen, \x ◘ \xo 6:10 \xt Awřn. 24:33\x*
\m 
\v 11 \add aqa da\add* ad xak dd-iwḍa zzeřḍ
\m am yijj n uxewwan,
\m řeɣben nnec am yijj n weryaz
\m i ɣar iǧa řesnaḥ. \x ◘ \xo 6:11 \xt Awřn. 24:34\x*
\b
\m 
\v 12 Bnadem i war isekkwin, aryaz n řɣecc,
\m iggur s ijj n uqemmum
\m iccuren s min iɛewjen.
\m 
\v 13 Iɣemmez s tiṭṭawin nnes,
\m issawař s iḍaren nnes,
\m ittceyyar s iḍewḍan nnes.
\m 
\v 14 Uř nnes \add iccur\add* s řexdaɛat,
\m inekkwa řebda řɣar,
\m ittsebbab imenɣiyyen.
\m 
\v 15 X uya deɣya ad dd-yas uḍeyyeɛ nnes,
\m deg ict n tecti ad ittwarẓ
\m am war din ittiři ugenfu.
\b
\m 
\v 16 Setta \add n tmesřayin\add*-a icarreh i-tent SIDI,
\m \add wah\add* sebɛa aqa atent d nnɛi i řeɛmar nnes:
\m 
\v 17 tiṭṭawin n nnfaxet,
\m ijj n yiřes issxarriqen,
\m uřa d ifassen issazzařen
\m idammen imezdagen, \x ◘ \xo 6:17 \xt Awřn. 30:13\x*
\m 
\v 18 uř inekkwan timeɛmač iɣeccen,
\m iḍaren nni ittqeǧiqen maḥend ad azzřen
\m ɣar min iǧan d aɛeffan, \x ◘ \xo 6:18 \xt Rum. 3:15\x*
\m 
\v 19 acehhad issxarriqen
\m nni dd-ideǧqen i ixarriqen,
\m uřa wenni ittsebbaben
\m imenɣiyyen jar tawmat.
\b
\m 
\v 20 \add A\add* mmi, ḥḍa tawṣeyyet n babac,
\m u war menḍar taɣuri n yemmac. \x ◘ \xo 6:20 \xt Awřn. 1:8\x*
\m 
\v 21 Qqen i-tent řebda x wuř nnec,
\m cedd i-tent ɣar yiri nnec. \x ◘ \xo 6:21 \xt Awřn. 3:3\x*
\m 
\v 22 Mařa teggured, aya ad cek igewwed,
\m mařa tezzred, aya ad cek iḥḍa,
\m mařa tfaqed aqa man aya
\m ad kidek issiweř. \x ◘ \xo 6:22 \xt Awřn. 3:23, 24\x*
\m 
\v 23 Minzi tawṣeyyet d řefnar
\m d tɣuri d tfawt,
\m iwebbax n ttarbiyyet
\m aqa aten d abrid n tudart \x ◘ \xo 6:23 \xt Izhd. 19:9; 119:105\x*
\m 
\v 24 nni cek i ɣa iḥḍan zi temɣart taɛeffant,
\m zi řehrud izewwqen
\m n yiřes n temɣart zi barra. \x ◘ \xo 6:24 \xt Awřn. 2:16; 5:3; 7:5\x*
\b
\m 
\v 25 War ɛecceq ca aẓri nnes deg wuř nnec,
\m ḥḍa war cek teḥṣir s wabřiwen nnes,
\m 
\v 26 minzi zi ssibbet
\m n ict n temɣart n farq-ccɣeř,
\m \add bnadem ad iksi\add*
\m \add mɣir\add* ict n txebbazt n weɣrum,
\m \add wah,\add* tamɣart n ijj n weryaz nneɣni
\m aqa tarezzu řeɛmar iɣřan.
\m 
\v 27 Ma izemmar ḥed ad yarbu timessi
\m deg weḥsin n warruḍ nnes,
\m břa ma ad yarɣ warruḍ nnes? \f ◼ \fr 6:27 \fk aḥsin\ft - niɣ ‘abeḥrur’.\f*
\m 
\v 28 Ma izemmar ḥed
\m ad yuyur x řefḥem \add itteḥduduqen\add*,
\m břa ma ad cemḍen iḍaren nnes?
\m 
\v 29 Ammu \add uřa d\add* wenni i ɣa yadfen
\m ɣar temɣart n jjar nnes,
\m \add wah\add* kuř ijjen wenni tt i ɣa ihadan,
\m war ittwiḥsib d amezdag.
\m 
\v 30 Aceffar war t ssḥeqqaren
\m mařa yucar,
\m ḥima ad issyiwen řeɛmar nnes
\m mařa dayes řaẓ.
\m 
\v 31 \add Maca\add* mařa ittwaf,
\m ammu xas i ɣa ixeǧeṣ sebɛa n tseqqar.
\m Ittxeṣṣa as ad iwc
\m marra min ɣares di taddart.\x ◘ \xo 6:31 \xt Uf. 22:1, 4\x*
\m 
\v 32 \add Maca\add* wenni itteggen zzina
\m ak-d ict n temɣart,
\m war ɣares bu wuř imten.
\m Wenni itteggen aya,
\m ittareddeǧ řeɛmar nnes.
\m 
\v 33 Druct d řefḍiḥet ad ten yaf,
\m řeḥya nnes war imeḥḥi ca.
\m 
\v 34 Maɣar tusmi \add tᵉttawi-dd\add* asɛar n weryaz,
\m netta war ittessen aḥinni
\m deg wass n wentaqem.
\m 
\v 35 War iḥesseb ddeyyet i weṣřeḥ,
\m war tt iqebbeř, ad yugi,
\m waxxa tessemɣarid
\m di terzeft ɛad s waṭṭas.
\b
\b
\c 7
\s1 Tamɣart issɣekkwan d uḥudri
\m 
\v 1 Mmi inu, ḥḍa awařen inu,
\m xemmeř tiweṣṣa inu ɣarek.
\m 
\v 2 Ḥḍa tiweṣṣa inu
\m u cek ad teqqimed teddared,
\m \add ḥḍa\add* taɣuri inu am mummu n tiṭṭ nnec. \x ◘ \xo 7:2 \xt Lawi 18:5; Awřn. 4:4\x*
\m 
\v 3 Qqen i-tent ɣar iḍewḍan nnec,
\m ari tent x teřwiḥt n wuř nnec. \x ◘ \xo 7:3 \xt Aɛwd. 6:8; 11:18\x*
\m 
\v 4 Ini i tiɣit: ‘Cem d učma!’,
\m u semma řefhamet: ‘Ameddukkeř \add inu\add*!’,
\m 
\v 5 maḥend \add nitenti\add* ad cek ḥḍant
\m zi temɣart tabarranect,
\m zi temɣart zi barra
\m i cek ittɣarran s wawařen nnes. \x ◘ \xo 7:5 \xt Awřn. 5:3\x*
\b
\m 
\v 6 Maɣar zi řkazi n taddart inu,
\m jar ccebbac \add n řkazi\add* sewḍeɣ ɣar wadday,
\m 
\v 7 sewḍeɣ ɣar iḥafiyyen \add inni war ittḥikin\add*,
\m jar iḥenjiren \add n bnadem\add*
\m ḥekkareɣ ijj n uḥudri
\m s wuř war imten.
\m 
\v 8 Netta iẓwa abrid ɣar teɣmart nnes,
\m u iṭṭef abrid ɣar taddart nnes.
\m 
\v 9 Ɣar tbambast, ɣar tmeddit n wass,
\m di řaǧaɣ n ǧiřet d tubbarcent,
\m 
\v 10 xzar, \add aqa\add* ict n temɣart tusa-dd
\m i umsagar akides,
\m deg warruḍ n temɣart n farq-ccɣeř
\m u s teḥraymect n wuř.
\b
\m 
\v 11 Nettat textix u tɣewweɣ,
\m iḍaren nnes war qqimen ɛad di taddart. \x ◘ \xo 7:11 \xt Awřn. 9:13\x*
\m 
\v 12 Ict n twařa di barra,
\m \add xenni\add* ɛawed deg wazzayen,
\m ɣar marra tiɣemmar \add n ibriden\add* tᵉttḥama.
\m 
\v 13 Nettat tᵉṭṭef i-t u tessudem i-t,
\m teqjar udem nnes, tenna as:
\m 
\v 14 “Tuɣa xafi \add maḥend ad wceɣ\add*
\m tiwhibin n řehna.
\m Ass-a ssqefřeɣ lwuɛud inu.
\m 
\v 15 X uya i dd-ffɣeɣ
\m maḥend ad cek mmsagareɣ,
\m maḥend ad xak arzuɣ u \add ammu i cek\add* ufiɣ.
\m 
\v 16 Necc ssuɣ maltat x qama inu,
\m řizarat izewwqen zi řeqten azdad zi Miṣra.
\m 
\v 17 Necc rucceɣ tassut inu
\m \add s\add* mirru d wecfiř d řqarfa. \x ◘ \xo 7:17 \xt Izři 4:14. \x*
\m 
\v 18 As-dd, ejj aneɣ ad nejjiwen
\m asḥinneb ař tuffut,
\m ejj aneɣ ad narr meẓri di řirart n tayri.
\m 
\v 19 Maɣar aryaz war iǧi di taddart,
\m netta \add isafar\add* iggʷej aṭṭas.
\m 
\v 20 Iksi ict n tkemmust
\m \add n tmenyat\add* n nnuqart akides,
\m ad yareggʷeḥ ɣar wass n tziri iqefřen.”
\m 
\v 21 \add Ammu\add* i t tᵉṭṭef s waṭṭas n řhard nnes,
\m teɣwa i-t s řehrud nnes izewwqen
\m n iyencicen nnes.
\b
\m 
\v 22 Deɣya netta yardef i-tt,
\m am yijj n ufunas igguren ɣar řgurnet,
\m am ict n ssnesřet \add x iḍaren\add* \add n wenni igguren\add*
\m ɣar umarret n ubuhaři
\m 
\v 23 - ařami dd as tcarreg fřitca tsa -
\m am yijj n wejḍiḍ iḍwin deg ijj n wenday,
\m u war issin aqa wanita ittwagg
\m ḍidd i tudart nnes. \x ◘ \xo 7:23 \xt Awřn. 1:17\x*
\b
\m 
\v 24 \add Xenni\add* řexxu, \add a\add* iḥenjiren, sřem-dd ɣari,
\m u sřem ɣar wawařen n uqemmum inu.
\m 
\v 25 Ejj uř nnec war ittweddir
\m deg ibriden nnes,
\m war ttmeyyiř ɣar imesraq nnes.
\m 
\v 26 Maɣar deg waṭṭas ittwayezmen
\m inni teɣḍer,
\m imɣar waṭṭas \add lɛadad n\add* marra inni tenɣa.
\m 
\v 27 Taddart nnes \add teccur\add*
\m \add s\add* ibriden ɣar řaxart
\m nni ihekkwan
\m ɣar ixxamen n daxeř n řmewt. \x ◘ \xo 7:27 \xt Awřn. 2:18; 5:5\x*
\b
\b
\c 8
\s1 Ařaɣi n tiɣit
\m 
\v 1 Ma war tᵉttřiɣi tiɣit u war tesgiɛɛid
\m řefhamet tmijja nnes? \x ◘ \xo 8:1 \xt Awřn. 1:20, 21\x*
\m 
\v 2 X tqiccat n řegɛudi x webrid,
\m mani ttemseřqan imesraq
\m tbedd Nettat d abeddi.
\m 
\v 3 Ɣar uɣezdis n tewwura,
\m ɣar wadaf n tendint,
\m mani ɣa tadfed x tewwura,
\m tᵉttřaɣa s jjehd:
\b
\m 
\v 4 “I kenniw, \add a\add* iryazen, ttřaɣiɣ,
\m tmijja inu \add tᵉtteffeɣ\add* ɣar tarwa n bnadem.
\m 
\v 5 \add Kenniw\add* iḥafiyyen,
\m fehmem \add xenni\add* min iǧan d aftan,
\m \add kenniw\add* ibuhařiyyen,
\m fehmem \add s\add* wuř \add nwem\add*.
\m 
\v 6 Sřem, minzi ad ssiwřeɣ
\m awařen i dd-ijebbden řeften,
\m anurzem n iyencicen inu
\m \add jebbed-dd\add* timesřayin iseggden,
\m 
\v 7 maɣar aneɣ inu ad yini tidett s nneyyet,
\m řhard iɛeffnen aqa-t d nnɛi
\m i iyencicen inu.
\m 
\v 8 Marra awařen n uqemmum inu
\m \add tteffɣen-dd\add* zi tsegda,
\m war daysen uřa d ict n řḥajjet
\m ixnunnesen niɣ ifarɣen.
\m 
\v 9 Aqa aten marra ṣfan
\m i wenni di teǧa řefhamet,
\m uřa s řeqyas i yinni \add ixsen\add* ad afen tussna.
\b
\m 
\v 10 Ksim ttarbiyyet inu, war iǧi nnuqart,
\m uřa tussna ktar x wureɣ iqquren,
\m 
\v 11 maɣar tiɣit ḥsen zi řmarjan,
\m marra min di izemmar \add bnadem\add*
\m ad imeẓri,
\m war \add izemmar\add* ad dayes yarwes. \x ◘ \xo 8:11 \xt Ayub 28:15; Izhd. 19:11; Awřn. 3:14, 15; 16:16\x*
\m 
\v 12 Necc, tiɣit, zeddɣeɣ ɣar weftan,
\m ttafeɣ tussna s uḥadur.
\m 
\v 13 Tiggʷudi n SIDI d acrah n řɣar,
\m nnfaxet, tacennaɛt d umesruq aɛeffan,
\m necc carrheɣ uřa d aqemmum
\m \add iccur s\add* řexdaɛat.
\m 
\v 14 Ɣari acawar d twiza,
\m necc d řefhamet, ɣari jjehd.
\m 
\v 15 Zzayi ḥekkmen ijeǧiden,
\m \add zzayi\add* ttareysen ayt n jjehd s tsegda.
\m 
\v 16 Zzayi ḥekkmen řḥukkam
\m d tarwa n taṣiřet,
\m marra řquḍat n temmurt.
\m 
\v 17 Necc ttexseɣ marra
\m inni d ayi ittexsen,
\m d yinni xafi yarezzun zic, ad ayi afen.
\m 
\v 18 Agřa d ccan aqa aten ɣari,
\m agřa iqqimen d tsegda. \x ◘ \xo 8:18 \xt Awřn. 3:16\x*
\m 
\v 19 Fruta inu tecna x wureɣ ittissiqen,
\m \add wah\add* x wureɣ azdad,
\m řɣiǧet inu teɛdu nnuqart iqquren.\x ◘ \xo 8:19 \xt Awřn. 3:14\x*
\m 
\v 20 Necc ggureɣ x umesruq n tsegda,
\m di řwesṭ n imesraq n řḥeqq,
\m 
\v 21 ḥima ad arreɣ inni d ayi ittexsen
\m ad ṭṭfen ict n tesɣart d řwart,
\m necc ad ccureɣ ixxamen n txubay nsen.
\b
\m 
\v 22 SIDI igga ayi d amezwaru n webrid nnes,
\m \add ɛad\add* qbeř amezwaru n tmegga nnes
\m zeg wecḥař uya.
\m 
\v 23 Zi řebda ittwazeǧeɛ xafi \add jjehd\add*,
\m zeg umezwaru,
\m zi řweqt n umezwaru
\m i di tᵉttwagg temmurt, \x ◘ \xo 8:23 \xt Yḥ. 1:1\x*
\m 
\v 24 umi war din tuɣi ɛad \add aman\add* ihewřen,
\m necc ttwaxeřqeɣ-dd,
\m umi war din tuɣi ɛad řɛunṣarat
\m ccurent s waman.
\m 
\v 25 Qbeř ma ad ttwaggen idurar,
\m qbeř \add ma ad iřint\add* tewririn,
\m tuɣa xeřqeɣ-dd necc.
\m 
\v 26 Netta tuɣa ɛad war dd-ixřiq
\m tammurt d iyyaren,
\m uřa d tamezwarut n tɛejjajt n ddunect.
\m 
\v 27 Umi Netta igga ijenwan, tuɣa ayi din,
\m umi Netta yarcem ict n tqurarect
\m x wudem n \add waman\add* ihewřen. \x ◘ \xo 8:27 \xt Ayub 26:10\x*
\b
\m 
\v 28 Umi Netta igga iseynuten sennej,
\m umi ttwajehdent
\m řɛunṣarat n \add waman\add* ihewřen, \x ◘ \xo 8:28 \xt Amz. 7:11\x*
\m 
\v 29 umi Netta igga i řebḥar aymir nnes,
\m maḥend aman
\m war dd-ɛeddun řumur nnes,
\m umi Netta iɛbar dsusa n temmurt, \x ◘ \xo 8:29 \xt Amz. 1:9, 10; Ayub 38:10, 11; Izhd. 104:9\x*
\m 
\v 30 tuɣa ayi d amudrus iɛizzen
\m ɣar uɣezdis nnes.
\m Necc tuɣa ayi marra d tarrit n meẓri
\m ass x wass,
\m ttirareɣ zzat i wudem nnes řebda, \x ◘ \xo 8:30 \xt Yḥ. 5:17\x*
\m 
\v 31 ttirareɣ di marra tammurt nnes,
\m am tuɣa tarrit n meẓri inu
\m ak-d tarwa n bnadem.
\b
\m 
\v 32 \add Xenni\add* řexxu, \add a\add* iḥenjiren \add inu\add*,
\m sřem-dd ɣari!
\m Sseɛd n yinni iḥeṭṭan ibriden inu. \x ◘ \xo 8:32 \xt Izhd. 119:1, 2; 128:1; Lk. 11:28\x*
\m 
\v 33 Sřem ɣar ttarbiyyet
\m u dewřem d imiɣisen,
\m war neṭṭarem \add ttarbiyyet\add*.
\m 
\v 34 Sseɛd n bnadem nni ɣari isřan,
\m wenni iṭṭfen acbar ɣar tewwura inu
\m zeg wass ař wass,
\m iḥetta x tɣemmar n tewwura inu,
\m 
\v 35 maɣar wenni d ayi yufin, ad yaf tudart,
\m u ad iṭṭef arḍa n SIDI. \x ◘ \xo 8:35 \xt Awřn. 12:2\x*
\m 
\v 36 Wenni i d ayi ixḍan, iyezzem řeɛmar nnes,
\m marra inni d ayi icarrhen, ttexsen řmewt.
\b
\b
\c 9
\m 
\v 1 Tiɣit tebna taddart nnes,
\m tegga tessuyda ipilaren nnes,
\m \add aqa aten di\add* sebɛa.
\m 
\v 2 Nettat tɣarṣ i řmař nnes,
\m txeǧeḍ binu nnes.
\m Ɛawed tessu ṭṭabřa nnes.
\m 
\v 3 Nettat tessekk
\m timsexxarin nnes timeẓyanin.
\m X tqiccatin n řegɛudi n tendint tᵉttřaɣa: \x ◘ \xo 9:3 \xt Awřn. 8:2\x*
\m 
\v 4 “Wenni iǧan d aḥafi,
\m ejj i-t ad dd-yas danita!”
\m Nettat teqqar
\m i yinni war ɣar iǧi ca wuř imten:
\m 
\v 5 “Asem-dd, ccem zeg weɣrum inu,
\m swem zi binu nni d awem dd-xeǧḍeɣ.
\m 
\v 6 Jjem taqubbanect, uca ddarem,
\m ḍfarem abrid n řefhamet.”
\b
\m 
\v 7 “Wenni ittwebbxen amestehziy,
\m issarebbu řefḍiḥet i yixef nnes,
\m wenni ittɛaqaben aɛeffan,
\m aqa \add netta yarebbu\add* abeqqiḍ
\m n řefḍiḥet nnes.
\m 
\v 8 War ttɛeyyab amestehziy
\m ḥima netta war cek icarreh,
\m ɛeyyeb \add a\add*miɣis, xenni netta ad cek ixs. \x ◘ \xo 9:8 \xt Mt. 7:6\x*
\m 
\v 9 Ewc i umiɣis,
\m \add xenni\add* ad idweř d miɣis ktar,
\m sɣar tussna i umsegged,
\m \add xenni\add* netta ad ifhem ktar.”
\m 
\v 10 Tiggʷudi n SIDI d beddu n tiɣit,
\m tussna n Umqeddas d Ameqqran
\m d beddu n řefhamet. \x ◘ \xo 9:10 \xt Ayub 28:28; Izhd. 111:10; Awřn. 1:7\x*
\m 
\v 11 Maɣar zzayi ad ktaren wussan nnec,
\m iseggʷusa n tudart ad ttwarnin i cek. \x ◘ \xo 9:11 \xt Awřn. 10:27\x*
\m 
\v 12 Mařa cek d miɣis,
\m \add xenni\add* ad tiřid d miɣis i yixef nnec,
\m u mařa testehezzid,
\m ad tarbud aya simant nnec.”
\b
\m 
\v 13 Tamɣart tabuhařect tᵉttbuhřuy,
\m \add nettat\add* d taqubbanit, war tessen walu. \x ◘ \xo 9:13 \xt Awřn. 7:11\x*
\m 
\v 14 Nettat tᵉttɣima
\m ɣar tewwart n taddart nnes,
\m x ijj n kursi, \add x\add* řegɛudi n tendint
\m 
\v 15 ḥima ad třaɣa x inni iɛeddun,
\m inni igguren nican imesraq nsen, \add tenna\add*:
\m 
\v 16 “Wenni iǧan d aḥafi,
\m ejj i-t ad dd-yas danita!”
\m Nettat teqqar
\m i yinni war ɣar iǧi ca wuř imten:
\m 
\v 17 “Aman ittwacaren d imiẓiden,
\m aɣrum innuffaren aqa icna.” \x ◘ \xo 9:17 \xt Awřn. 20:17\x*
\m 
\v 18 Netta war issin aqa din řexyařat,
\m aqa inewjiwen nnes
\m deg waǧaɣ n řaxart \add i iǧan\add*. \x ◘ \xo 9:18 \xt Awřn. 2:18\x*
\b
\b
\c 10
\s1 Awařen iwezznen n Suliman - tasɣart 1a
\m 
\v 1 \bd Awařen iweznen n Suliman\bd*
\b
\m Ijj n mmis d amiɣis issfarraḥ babas,
\m \add maca\add* ijj n ubuhaři n mmis
\m d wenni d amnus \add ameqqran\add* n yemmas. \x ◘ \xo 10:1 \xt Awřn. 15:20\x*
\m 
\v 2 Tixubay n tuɛeffna war nneffɛent,
\m \add maca\add* tasegda tᵉttfekka zi řmewt. \x ◘ \xo 10:2 \xt Awřn. 11:4\x*
\m 
\v 3 SIDI war ittejji řeɛmar n imseggaden
\m ad iḥeyyef,
\m \add maca\add* meẓri n iɛeffanen
\m iɛarren i-t ɣar řaggʷaj.
\m 
\v 4 Wi ixeddmen s ufus yarxun,
\m ittawi-dd zzeřḍ,
\m \add maca\add* afus n yinni ittceṭṭaren
\m ittawi-dd agřa. \x ◘ \xo 10:4 \xt Awřn. 12:24\x*
\m 
\v 5 Wenni iyarrwen deg unebdu
\m d ijj n mmis ifehhmen,
\m \add maca\add* wenni itteṭṭṣen di tmeyra
\m d ijj n mmis n řefḍiḥet.
\m 
\v 6 Lbarakat \add aressant\add*
\m x uzeǧif n imseggaden,
\m \add maca\add* lɛunf issdurruy
\m aqemmum n iɛeffanen.
\m 
\v 7 Řidaret i umsegged \add ad dd-yawi\add* lbaraka,
\m \add maca\add* isem n iɛeffanen ad yarṣuḍ.
\m 
\v 8 Wenni d amiɣis deg wuř,
\m ad iqbeř tiweṣṣa,
\m \add maca\add* wenni \add issawařen\add* tubbuheřya
\m s iyencicen nnes, ad iwḍa. \x ◘ \xo 10:8 \xt Awřn. 10:10\x*
\m 
\v 9 Wenni igguren di řeṣfayet,
\m iggur di řaman,
\m \add maca\add* wenni \add igguren\add* ibriden ifarɣen,
\m ad ittwassen.
\m 
\v 10 Wenni ittɣemmazen s tiṭṭawin,
\m ittegg řeḥriq,
\m wenni \add issawařen\add* tubbuheřya
\m s iyencicen nnes, ad iwḍa.
\m 
\v 11 Aqemmum n umsegged d tařa n tudart,
\m \add maca\add* lɛunf issdurruy
\m aqemmum n iɛeffanen. \x ◘ \xo 10:11 \xt Awřn. 10:6, 13:14\x*
\m 
\v 12 Acrah tessekkara-dd imcubbecen,
\m \add maca\add* tayri tessdurruy marra ixeṭṭan. \x ◘ \xo 10:12 \xt 1 Kur. 13:7; 1 Bṭ. 4:8\x*
\m 
\v 13 X iyencicen n wenni ɣar iǧa řefhamet
\m tᵉttwaf tiɣit,
\m \add maca\add* aɛmud
\m i wenni war ɣar iǧi bu řeɛqeř. \x ◘ \xo 10:13 \xt Awřn. 20:30\x*
\m 
\v 14 Imiɣisen ttxemmaren tussna,
\m \add maca\add* aqemmum n ubuhaři
\m ittades ɣar uhellek.
\m 
\v 15 I bu-wagřa min iǧan nnes
\m d tandint ijehden nnes,
\m lebla n imezřaḍ d ahellek nsen.
\m 
\v 16 Řɣiǧet n umsegged aqa-tt i tudart,
\m řmunet n uɛeffan i ddenb.
\m 
\v 17 Wenni iḥeṭṭan ttarbiyyet,
\m \add aqa-t x\add* webrid n tudart,
\m \add maca\add* wenni isemmḥen deg uwebbex,
\m ad iweddar.
\m 
\v 18 Wi itteffaren acrahi,
\m ɣares iyencicen ssxarriqen,
\m wi ittceqqafen aqa-t d abuhaři.
\m 
\v 19 Ɣar waṭṭas n wawařen
\m war iqqim uxeṭṭu ineqqeṣ,
\m \add maca\add* wenni imennɛen iyencicen nnes,
\m aqa \add ittegg\add* s řeɛqeř.
\m 
\v 20 Nnuqart iqquren d iřes n umsegged,
\m uř n iɛeffanen war isekkwin.
\m 
\v 21 Iyencicen n imseggaden sseccan aṭṭas,
\m \add maca\add* ibuhařiyyen mmuten
\m umi war ɣarsen bu wuř imten.
\m 
\v 22 Lbaraka n SIDI tᵉttawi-dd agřa,
\m arber \add n bnadem\add* war dayes yarenni walu.
\m 
\v 23 I ubuhaři tameggit n řefḍihet
\m am yict n řuraret,
\m \add maca\add* i weryaz n řefhamet
\m \add adebbar\add* s tiɣit \add am man aya\add*. \x ◘ \xo 10:23 \xt Awřn. 14:9\x*
\m 
\v 24 Min zi itteggʷed uɛeffan ad t iřqef,
\m \add maca\add* asitem n imseggaden ad yiři.
\m 
\v 25 Mařa teɛdu-dd tḥaryaḍt,
\m aɛeffan war ittɣimi,
\m \add maca\add* amsegged ad iqqim imten i řebda.
\m 
\v 26 Am binu asemmam i teɣmas
\m d ddexxan i tiṭṭawin,
\m ammu i igga umeɛguz i yinni t issekken.
\m 
\v 27 Tiggʷudi n SIDI tarenni
\m deg ussan \add i tudart\add*,
\m \add maca\add* iseggʷusa n iɛeffanen
\m ttwassquḍḍeḍen. \x ◘ \xo 10:27 \xt Awřn. 9:11\x*
\m 
\v 28 Tarajit n imseggaden d řefraḥet,
\m \add maca\add* řayas n iɛeffanen ggur ad ifna. \x ◘ \xo 10:28 \xt Ayub 8:13, 14; 11:20; Izhd. 112:10\x*
\m 
\v 29 Abrid n SIDI d lburj \add ijehden\add*
\m i wenni igguren nican,
\m \add maca\add* d ahellek i yinni itteggen řɣecc. \x ◘ \xo 10:29 \xt Awřn. 13:6\x*
\m 
\v 30 Amsegged ɛemmarṣ ad inhezz i řebda,
\m \add maca\add* iɛeffanen war zeddɣen di temmurt.
\m 
\v 31 Aqemmum n umsegged
\m ittawi-dd tiɣit s waṭṭas,
\m \add maca\add* ijj n yiřes iɛemmar s řexdaɛat
\m ad ittwaqess.
\m 
\v 32 Iyencicen n umsegged ssnen min yarḍan,
\m \add maca\add* aqemmum n uɛeffan
\m \add issen\add* řexdaɛat waha.
\b
\b
\c 11
\m 
\v 1 Řmizan aɣeccac d nnɛi i SIDI,
\m \add maca\add* aẓru n řewzen nican
\m ittaf arḍa nnes. \x ◘ \xo 11:1 \xt Lawi 19:36; Aɛwd. 25:13; Awřn. 16:11; 20:10, 23\x*
\m 
\v 2 Mařa tusa-dd nnfaxet,
\m tusa-dd uřa d řefḍiḥet,
\m \add maca\add* ɣar imwaḍɛen \add teǧa\add* tiɣit. \x ◘ \xo 11:2 \xt Awřn. 15:33; 16:18; 18:12\x*
\m 
\v 3 Řeṣfayet n inni igguren nican
\m tneddeh i-ten,
\m \add maca\add* taḥraymect n iɣeddaren
\m taředdeǧ i-ten. \x ◘ \xo 11:3 \xt Awřn. 13:6\x*
\b
\m 
\v 4 Agřa war ineffeɛ
\m ɣar wass n uduqqez \add n ufugem\add*,
\m \add maca\add* tasegda tᵉttfekka zi řmewt. \x ◘ \xo 11:4 \xt Awřn. 10:2; Ḥiz. 7:19; Ṣaf. 1:18\x*
\m 
\v 5 Tasegda n wenni igguren nican
\m ittarra abrid nnes nican,
\m \add maca\add* aɛeffan iweṭṭa s tuɛeffna nnes.
\m 
\v 6 Tasegda n inni igguren nican
\m ad ten tfekk,
\m \add maca\add* iɣeddaren ad ttwacarfen
\m deg umeẓri \add nsen\add*.
\b
\m 
\v 7 Mařa immut bnadem aɛeffan,
\m ifna řayas nnes,
\m uřa d min ttrajan
\m \add yeryazen\add* daysen teryast ad ifna.
\m 
\v 8 Amsegged ad dd-ittwafekk
\m zi řeḥṣaret,
\m uca \add xenni\add* aɛeffan ad dd-yas
\m deg wemcan nnes.\x ◘ \xo 11:8 \xt Izhd. 34:20; Awřn. 21:18\x*
\m 
\v 9 Amnafeq ittareddeǧ jjar nnes
\m s uqemmum nnes,
\m \add maca\add* imseggaden
\m ad ttwafekken s tussna. \f ◼ \fr 11:9 \fk lmunafiq\ft - niɣ ‘bu n tnayen n wudmawen’.\f*
\b
\m 
\v 10 Tandint tᵉttesřiwřiw
\m mařa imseggaden aqa aten mliḥ,
\m u mařa ttwahellken iɛeffanen,
\m aqa din asřiwřew.
\m 
\v 11 Tᵉttwassgeɛɛed tendint
\m s lbaraka n inni igguren nican,
\m \add maca\add* s uqemmum n iɛeffanen
\m ad tᵉttwahdem.
\m 
\v 12 Wenni war ɣar iǧi ca wuř imten,
\m isseḥqara jjar nnes,
\m \add maca\add* aryaz wenni ɣar iǧa řefhamet
\m ittesqar.
\m 
\v 13 Wenni igguren da d diha s texbarjit,
\m ittɛarra min innuffaren,
\m \add maca\add* wenni \add i di iǧa\add* arruḥ
\m dayes řaman, aqa issnuffara tamesřact.
\m 
\v 14 Mařa war din adebbar, iweṭṭa řgens,
\m \add maca\add* ad yiři usenjem s řemɣaret n umcawar. \x ◘ \xo 11:14 \xt 1 Ij. 12:1-20\x*
\b
\m 
\v 15 Wenni iḍemmnen řbarrani,
\m war dd as tᵉtteffeɣ ca mliḥ,
\m \add maca\add* wenni icarrhen
\m inni itteggen ticti x ufus,
\m aqa-t di řaman.
\m 
\v 16 Tamɣart tᵉttaf arḍa, tᵉṭṭef
\m di řɛezz \add nnes\add*,
\m \add maca\add* ayt n bu-řexcunet
\m ttᵉṭṭfen deg wagřa.
\b
\m 
\v 17 Bnadem s tmexsiwt icewwaren
\m ittegg řxar i řeɛmar nnes,
\m \add maca\add* aqessaḥ ittɣezza
\m aysum \add n yixef\add* nnes.
\m 
\v 18 Aɛeffan imejjar řɣiǧet n řɣecc,
\m \add maca\add* wenni izarrɛen tasegda,
\m \add imejjar\add* ict n řmunet imetnen.
\m 
\v 19 Tasegda nican \add tᵉttawi ɣar\add* tudart,
\m wenni yareddfen řɣar,
\m \add yarezzu\add* řmewt nnes.
\b
\m 
\v 20 Inni ɣarsen uř ifarɣen
\m aqa aten d nnɛi i SIDI,
\m \add maca\add* inni igguren nican
\m Netta yareṭṭa daysen.
\m 
\v 21 S tidett, aɛeffan war ittɣimi břa řexřaṣ,
\m \add maca\add* tarwa n imseggaden
\m ad ttwassnejmen. \x ◘ \xo 11:21 \xt Awřn. 16:5\x*
\m 
\v 22 \add Amecnaw\add* ict n txadent n wureɣ
\m di tinzar n yiřef,
\m \add ammu i teǧa\add* ict n temɣart tecna
\m war di iǧa umeyyez.
\m 
\v 23 Meẓri n imseggaden
\m mɣir ɣar min iṣebḥen,
\m \add maca\add* řayas n iɛeffanen
\m aqa-t nhřa řeɛbar.
\b
\m 
\v 24 Aqa din \add ijjen\add* wenni ibeṭṭan s wecrim,
\m \add waxxa amenni\add* ittwarni as ɛad ktar,
\m u aqa din \add ijjen\add* wenni imennɛen \add ktar\add*
\m x min icuwwaren,
\m waxxa man aya \add ineddeh\add* ɣar zzeřḍ.
\m 
\v 25 Řeɛmar nni ittbarken ad ittwassjiwen,
\m u wenni itticen aman,
\m ad as immewc waman
\m i netta simant nnes. \x ◘ \xo 11:25 \xt Izhd. 112:9; 2 Kur. 9:9\x*
\m 
\v 26 Wenni ittxemmařen imendi,
\m ineɛɛeř i-t cceɛb,
\m \add maca\add* lbaraka ad tiři
\m x uzeǧif n wenni iznuzan \add imendi\add*.
\b
\m 
\v 27 Wenni ittceṭṭaren di ṭṭweɛ n
\m min iṣebḥen,
\m yarezzu min yarḍan,
\m \add maca\add* wenni ittḥaman řɣar, ad t iřqef. \x ◘ \xo 11:27 \xt Izhd. 7:17; 9:16; 10:2; 57:7\x*
\m 
\v 28 Wenni ittcařen x wagřa nnes, ad iwḍa,
\m \add maca\add* imseggaden ttneɛniɛen
\m am ifetwan izizawen.\x ◘ \xo 11:28 \xt Izhd. 1:3, 4; 92:13\x*
\m 
\v 29 Wenni ihekkwřen \add aytbab n\add* taddart nnes,
\m ad iwart asemmiḍ,
\m u abuhaři \add ad yiři\add* d amsexxar
\m n wenni di iǧa wuř amiɣis.
\m 
\v 30 Řɣiǧet n umseggad
\m d ict n tcejjart n tudart,
\m wenni yarebbḥen řeɛmur aqa-t d amiɣis. \f ◼ \fr 11:30 \fk tacejjart\ft - niɣ ‘addag’ (‘iddagen’).\f*
\m 
\v 31 Xzar, aqa ad ittwaxeǧeṣ
\m umsegged di temmurt,
\m \add xenni\add* mahu aɛeffan d umednub. \x ◘ \xo 11:31 \xt 1 Bṭ. 4:17, 18\x*
\b
\b
\c 12
\m 
\v 1 Wenni ittexsen ttarbiyyet,
\m ittexs tussna,
\m \add maca\add* wenni icarrhen awebbex
\m aqa netta d aqeffuḥ.
\m 
\v 2 Bnadem d aṣebḥan ittaf arḍa n SIDI,
\m \add maca\add* aryaz inekkwan taḥraymect
\m ad t ibarreḥ d bu-umarwas.
\m 
\v 3 Bnadem war izemmar
\m ad iqqim ibedd umi ittegg řɣar,
\m \add maca\add* aẓwar n imseggaden
\m war izemmar ad inhezz. \x ◘ \xo 12:3 \xt Awřn. 10:25\x*
\b
\m 
\v 4 Tamɣart imeḥḍen
\m d ttaj n weryaz nnes,
\m \add maca\add* tenni t yarrin ittseḍḥa,
\m \add d tenni\add* am wareṣṣuḍ deg iɣsan nnes. \x ◘ \xo 12:4 \xt 1 Kur. 11:7\x*
\m 
\v 5 Ixemmimen n imseggaden d řḥeqq,
\m ixarriṣen n iɛeffanen d řɣecc \add marra\add*.
\m 
\v 6 Awařen n iɛeffanen
\m řebten deg idammen,
\m \add maca\add* aqemmum n yinni igguren nican
\m ad ten issenjem.\x ◘ \xo 12:6 \xt Awřn. 1:11, 18; 11:9\x*
\m 
\v 7 Iɛeffanen ttneqřaben u war ǧin ɛad,
\m \add maca\add* taddart n imseggaden
\m ad teqqim tbedd. \x ◘ \xo 12:7 \xt Izhd. 37:36-40; Awřn. 11:21\x*
\m 
\v 8 Ittwassemɣar bnadem
\m ɛlaḥsab řqedd n řeɛqeř nnes,
\m \add maca\add* wenni di iǧa wuř ifarɣen,
\m ad ittwasseḥqar.
\m 
\v 9 Iḥřa wenni war iḥessben
\m x ixef nnes aṭṭas,
\m \add maca\add* ɣares ijj n umsexxar,
\m x wenni ittcennɛen s ixef nnes,
\m \add maca\add* aɣrum war ɣares yeǧi. \x ◘ \xo 12:9 \xt Awřn. 13:7\x*
\m 
\v 10 Amsegged issen
\m řeɛmar n řebhimet nnes,
\m \add maca\add* arreḥmat n uɛeffan qesḥent. \x ◘ \xo 12:10 \xt Aɛwd. 25:4\x*
\m 
\v 11 Wenni icarrzen tammurt nnes,
\m ad ijjawen s weɣrum,
\m \add maca\add* wenni yareddfen min iǧan ixwan,
\m war ɣares ca wuř imten. \x ◘ \xo 12:11 \xt Awřn. 28:19\x*
\m 
\v 12 Aɛeffan ittexs \add min iǧan di\add* tracca
\m n yinni itteggen řɣar,
\m \add maca\add* aẓwar n imseggaden
\m ittɣima ittic.
\b
\m 
\v 13 Deg uxeṭṭu n iyencicen
\m \add dayes\add* ijj n řfex d aɛeffan,
\m \add maca\add* amsegged ad injem zi řeḥṣaret. \x ◘ \xo 12:13 \xt Awřn. 10:14; 18:7\x*
\m 
\v 14 Zi řɣiǧet n uqemmum \add nnes\add*
\m ittwassjiwen bnadem s řxir,
\m min dd-ttawyen ifassen n bnadem
\m ad ɣares dd-idweř. \x ◘ \xo 12:14 \xt Awřn. 13:2\x*
\m 
\v 15 Abrid n ubuhaři nican di tiṭṭawin nnes,
\m \add maca\add* wenni ittesřan i ccwar,
\m aqa netta d amiɣis. \x ◘ \xo 12:15 \xt Awřn. 3:7\x*
\m 
\v 16 Abuhaři isscana řhemm nnes
\m deg wass d ijj,
\m \add maca\add* wenni ifettnen,
\m ittdařa řeḥya nnes.
\m 
\v 17 Wenni dd-ineṭṭqen tidett,
\m isscana tasegda,
\m \add maca\add* acehhad issxarriqen
\m \add isscana\add* acmat. \x ◘ \xo 12:17 \xt Awřn. 14:5\x*
\m 
\v 18 Aqa din wenni ittharwaḍen
\m am tejjut n ssif,
\m \add maca\add* iřes n imiɣisen
\m ittawi-dd agenfu. \x ◘ \xo 12:18 \xt Izhd. 57:5; 59:8; Awřn. 16:27\x*
\m 
\v 19 Iyencicen \add iccuren s\add* tidett
\m ad ttwaḍmen i řebda,
\m \add maca\add* iřes issxarriqen \add mɣir\add*
\m i yijj n umur waha.
\m 
\v 20 Acmat aqa-t deg wuř
\m n yinni inekkwan tuɛeffna,
\m \add maca\add* i yinni inessḥen řehna,
\m \add aqa din\add* řefraḥet.
\m 
\v 21 Amsegged war t iřeqqef řɣecc,
\m \add maca\add* iɛeffanen ad ttwaccuren s řɣar.
\m 
\v 22 Iyencicen isxarriqen d nnɛi i SIDI,
\m \add maca\add* inni ittemṣurrufen s řaman
\m yarḍan as.
\m 
\v 23 Bnadem ifetnen issdurruy tussna nnes,
\m \add maca\add* uř n ibuhařiyyen
\m isɣuyyu s tubbuheřya di řexřa. \x ◘ \xo 12:23 \xt Awřn. 13:16; 15:2\x*
\m 
\v 24 Afus n wenni imeḥḍen ad iḥkem,
\m \add maca\add* řeɛgez ineddeh ɣar tesmuɣi. \x ◘ \xo 12:24 \xt Awřn. 10:4\x*
\m 
\v 25 Amnus deg wuř n bnadem
\m isshekkwa i-t,
\m \add maca\add* awař iṣebḥen issfarraḥ i-t. \x ◘ \xo 12:25 \xt Awřn. 15:13\x*
\m 
\v 26 Amseggad isscana abrid i jjar nnes,
\m \add maca\add* abrid n uɛeffan
\m yarra i-ten ad weddaren.
\m 
\v 27 Ameɛguz war iḍeffar ca aneymar nnes.
\m \add maca\add* agřa iɣřan n iwdan aqa d amḥaḍ.
\m 
\v 28 Deg umesruq n tsegda \add teǧa\add* tudart,
\m abrid n řatar nnes war dayes bu řmewt.
\b
\b
\c 13
\s1 Awařen iwezznen n Suliman - tasɣart 1b
\m 
\v 1 Ijj n mmis d amiɣis
\m \add d ṣṣifet n\add* uwebbex n babas,
\m \add maca\add* amestehziy
\m war ittesři ɣar utextix.
\m 
\v 2 Zi řɣiǧet n wawařen nnes
\m ad yecc bnadem řxar,
\m \add maca\add* řeɛmar n iɣeddaren
\m \add ad yecc\add* lɛunf. \x ◘ \xo 13:2 \xt Awřn. 12:14\x*
\m 
\v 3 Wenni yessaren aqemmum nnes,
\m iḥeṭṭa řeɛmar nnes,
\m \add maca\add* wenni yarezzmen
\m iyencicen nnes aṭṭas,
\m \add ittraja\add* t uhellek.
\m 
\v 4 Řeɛmar n umeɛguz yarjef,
\m \add waxxa aya\add* war ineffeɛ di walu,
\m \add maca\add* řeɛmar n yinni ittceṭṭaren
\m ad ittwassjiwnen.
\m 
\v 5 Awařen n ixarriqen
\m icarreh i-ten umsegged,
\m \add maca\add* aɛeffan issarzag ixef nnes
\m u issfeṭṭaḥ \add inneɣni\add*.
\m 
\v 6 Tasegda tḥeṭṭa
\m wenni igguren abrid \add nnes\add* nican,
\m \add maca\add* tuɛeffna ad t isshellek amednub. \x ◘ \xo 13:6 \xt Awřn. 10:29; 11:3, 5, 6\x*
\b
\m 
\v 7 Aqa din inni ittarran ixef nsen
\m d bu-wagřa, \add waxxa\add* war ɣarsen walu,
\m u aqa din inni ittarran ixef nsen
\m d imezřaḍ, \add waxxa\add* ɣarsen aṭṭas. \x ◘ \xo 13:7 \xt Awřn. 12:9\x*
\m 
\v 8 Ddeyyet i řeɛmar n ca n yijjen
\m d agřa nnes,
\m \add maca\add* amezřuḍ war ittesři ca
\m uřa d ijj n uhuddi.
\b
\m 
\v 9 Tafawt n imseggaden ad tarɣ s řefraḥet,
\m \add maca\add* řefnar n iɛeffanen ad ixsi. \x ◘ \xo 13:9 \xt Ayub 18:5, 6; 21:17; Awřn. 4:18\x*
\m 
\v 10 Zi tnefsect ittas-dd mɣir umenɣi,
\m \add maca\add* inni ikessin acawar, ɣarsen tiɣit.
\m 
\v 11 Agřa n deɣya, ad yiři drus,
\m \add maca\add* wenni iyarrwen s ufus,
\m ad yarbeḥ. \x ◘ \xo 13:11 \xt Awřn. 10:2; 20:21\x*
\b
\m 
\v 12 Řayas yuyřen issɛiǧa uř,
\m \add maca\add* twarrit n meẓri iccuren,
\m aqa tt d tacejjart n tudart. \f ◼ \fr 13:12 \fk tacejjart\ft - niɣ ‘addag’ (‘iddagen’).\f*
\m 
\v 13 Wenni isseḥqaran awař,
\m ad zzayes ittwaqqen,
\m \add maca\add* wenni itteggʷeden tawṣeyyet,
\m ad ittwaxeǧeṣ.
\m 
\v 14 Taɣuri n umiɣis d řɛunṣar n tudart,
\m maḥend ad yařweř \add bnadem\add*
\m i texcifin n řmewt. \x ◘ \xo 13:14 \xt Awřn. 10:11; 14:27\x*
\b
\m 
\v 15 Řeɛqeř iṣebḥen ittawi-dd arḍa,
\m \add maca\add* abrid n iɣeddaren
\m aqa iqseḥ aṭṭas.
\m 
\v 16 Kuř ijjen wenni ifettnen,
\m ixeddem s tussna,
\m \add maca\add* abuhaři ittbezzaɛ taɣyuři \add nnes\add*.\x ◘ \xo 13:16 \xt Awřn. 12:23; 15:2\x*
\m 
\v 17 Amsexxar aɛeffan iweṭṭa di řɣar,
\m \add maca\add* amsexxar d amtiqqi
\m \add ittawi-dd\add* agenfu.
\m 
\v 18 Zzřeḍ d řefḍiḥet aqa aten
\m i wenni yugin ttarbiyyet,
\m \add maca\add* wenni iksin awebbex
\m \add ɣar wuř nnes\add*, ad ittwaweqqar. \x ◘ \xo 13:18 \xt Awřn. 15:32\x*
\b
\m 
\v 19 Ijj n usitem iccuren d amiẓid i řeɛmar,
\m \add maca\add* i ibuhařiyyen d nnɛi
\m maḥend ad ḥeyyden x řɣar.
\m 
\v 20 Wenni igguren ak-d imiɣisen,
\m ad idweř d amiɣis,
\m \add maca\add* wenni ittemṣurrufen
\m ak-d ibuhařiyyen, ad t iřqef ddeǧ.
\m 
\v 21 Řɣar ad iḍfar imednab,
\m \add maca\add* amsegged ad t xeǧḍen s řxar.
\m 
\v 22 Wenni iṣebḥen ittejja tasɣart
\m i wayyawen nnes,
\m \add maca\add* agřa n ayt-bu-ddnub
\m ittwaxemmeř i umsegged. \x ◘ \xo 13:22 \xt Ayub 15:29; 27:17\x*
\b
\m 
\v 23 Arber n imezřaḍ
\m ittawi-dd macca s waṭṭas,
\m \add maca\add* aqa din inni ittwahellken
\m řami \add din\add* anqas n řḥeqq. \x ◘ \xo 13:23 \xt Awřn. 12:11; 18:9\x*
\m 
\v 24 Wenni imennɛen aɛmud nnes,
\m icarh mmis,
\m \add maca\add* wenni t ittexsen,
\m ittekkar akides ittwebbex i-t di řweqt. \x ◘ \xo 13:24 \xt Awřn. 23:13\x*
\m 
\v 25 Amsegged ad icc
\m ař ɣa ijjawen řeɛmar nnes,
\m \add maca\add* aɛeddis n iɛeffanen
\m ad iqqim itteḥwaja \add řebda\add*.
\b
\b
\c 14
\m 
\v 1 Tiɣit n temɣarin
\m tbenna taddart nnes,
\m \add maca\add* tubbuheřya theddem i-tt
\m s ifassen nnes.
\m 
\v 2 Wenni igguren di řeṣfayet nnes,
\m itteggʷed SIDI,
\m \add maca\add* wenni itteffɣen zeg ibriden nnes,
\m isseḥqara i-t. \x ◘ \xo 14:2 \xt Ayub 12:4\x*
\m 
\v 3 Deg uqemmum n ubuhaři
\m \add aqa din\add* řmecɛeḍ i nnfaxet \add nnes\add*,
\m \add maca\add* iyencicen n imiɣisen ḥeṭṭan ten.
\b
\m 
\v 4 Mani war ǧin ifunasen,
\m ittɣima řmedwed ixwa
\m \add maca\add* s jjehd n ufunas
\m aqa din ṣṣabet temɣar.
\b
\m 
\v 5 Acehhad d tidett war issxarriq ca,
\m \add maca\add* acehhad issxarriqen
\m ittsuḍ ixarriqen. \x ◘ \xo 14:5 \xt Uf. 23:1; Awřn. 12:17\x*
\m 
\v 6 I umestehziy war din tiɣit
\m xmi tt yarezzu,
\m \add maca\add* i ufehham ihwen \add xas\add*,
\m \add maḥend ad yaf\add* tussna.
\b
\m 
\v 7 Aggʷej x weryaz abuhaři,
\m \add maɣar\add* cek war \add ɣares\add* tᵉttifed ca
\m iyencicen \add i issawařen\add* tussna.
\m 
\v 8 Tiɣit n wenni ifettnen
\m aqa-tt d řefhamet
\m n webrid \add n yixef\add* nnes,
\m \add maca\add* tubbuheřya n ibuhařiyyen d acmat.
\m 
\v 9 Ibuhařiyyen stehzan
\m s \add weɛdař\add* n umarwas,
\m \add maca\add* jar inni igguren nican
\m ittwaf řxaḍar.
\b
\m 
\v 10 Uř issen tarzugi nnes,
\m řbarrani war izemmar
\m ad yaca s řefraḥet nnes.
\m 
\v 11 Taddart n iɛeffanen ad tᵉttwareddeǧ,
\m \add maca\add* taqiḍunt n inni igguren nican
\m ad tᵉnnewwar.
\m 
\v 12 Ad taɣ ittɣiř as i ca n yijjen
\m aqa abrid nican,
\m \add maca\add* aneggar nnes \add mɣir\add* ibriden
\m \add ittawyen\add* ɣar řmewt. \x ◘ \xo 14:12 \xt Awřn. 16:25\x*
\m 
\v 13 Waxxa ɣar weḍḥac uř ittegg řeḥriq,
\m \add wah\add*, aneggaru n řefraḥet
\m tᵉttakkwaḍ-dd acḍan. \x ◘ \xo 14:13 \xt Awřn. 5:4\x*
\b
\m 
\v 14 Wenni ɣar iǧa wuř iffɣen zeg webrid,
\m ad ittwassjiwen s ibriden nnes,
\m u aryaz aṣebḥan s yixef nnes. \x ◘ \xo 14:14 \xt Awřn. 1:31\x*
\m 
\v 15 Wenni iǧan d aḥafi, ittamen di kuř awař,
\m \add maca\add* wenni ifettnen iḥeṭṭa aṣurif nnes.
\m 
\v 16 Amiɣis itteggʷed u ittḥeyyad x řɣar,
\m \add maca\add* abuhaři iseɛɛar,
\m umi ittɣiř as aqa-t di řaman.
\m 
\v 17 Wenni ittxeyyaqen deɣya,
\m ad igg tubbuheřya,
\m u aryaz inekkwan taḥraymect,
\m ad ittwacarh.
\m 
\v 18 Iḥafiyyen ad warten tubbuheřya,
\m \add maca\add* inni ifettnen,
\m ad asen qqnen s ijj n ttaj n tussna.
\m 
\v 19 Iɣeccacen ad aḍaren
\m zzat i wudem n iṣebḥanen,
\m iɛeffanen \add ad aḍaren\add*
\m zzat i tewwura n imseggaden.
\b
\m 
\v 20 Amezřuḍ icarreh i-t \add ɛad\add*
\m umeddukkeř nnes,
\m \add maca\add* aṭṭas d inni ittexsen ayt n bu-wagřa. \x ◘ \xo 14:20 \xt Awřn. 19:4, 7\x*
\m 
\v 21 Wenni isseḥqaran jjar nnes,
\m ittegg ddnub,
\m \add maca\add* sseɛd n wenni ittḥinnan
\m x inni ittwaḥṣaren.
\m 
\v 22 Inni dd-ixeǧqen řɣar,
\m ma war ttweddarin nitni?
\m Tamexsiwt icewwaren d řaman
\m aqa ɣar yinni ittxarraṣen
\m di min iṣebḥen. \x ◘ \xo 14:22 \xt Lk. 6:38\x*
\b
\m 
\v 23 Di marra řweḥřan n warber dayes řefḍeř,
\m \add maca\add* řhard n iyencicen
\m ineddeh ɣar weḥwaj waha. \f ◼ \fr 14:23 \fk řhard\ft - s Tɛibranit ‘awař’.\f*
\m 
\v 24 Ttaj n imiɣisen d agřa nsen,
\m tubbuheřya n ibuhařiyyen
\m d tubbuheřya \add waha\add*.
\m 
\v 25 Acehhad amtiqqi issenjam řeɛmur,
\m \add maca\add* wenni yarexxun i ixarriqen,
\m icemmet.
\m 
\v 26 Di tiggʷudi n SIDI \add dayes\add* ttiqet ijehden,
\m Netta ad yiři d amcan n tarewřa
\m i iḥenjiren nnes.
\m 
\v 27 Tiggʷudi n SIDI d řɛunṣar n tudart,
\m i usenjem zeg iceddiyen n řmewt. \x ◘ \xo 14:27 \xt Awřn. 10:11; 13:14\x*
\m 
\v 28 Deg waṭṭas n řgens
\m \add ixemmeř\add* ucewwar n ujeǧid,
\m \add maca\add* di tikkest n cceɛb
\m \add ixemmeř\add* uhellek n řḥakem.
\m 
\v 29 Wenni ɣar iǧa ttasiɛ n řxaḍar,
\m ɣares řefhamet temɣar,
\m \add maca\add* wenni di iǧa buḥbeř iḥṣaren
\m issekkar tubbuheřya.
\m 
\v 30 Uř iṣṣeḥ, aqa d tudart i arrimet,
\m \add maca\add* tusmi d areṣṣuḍ n yeɣsan.
\m 
\v 31 Wenni iḥeṣṣaren ameḥdaj,
\m isseḥqara wenni t i-dd-ixeřqen,
\m \add maca\add* wenni ittḥinnan x umezřuḍ,
\m ittcenneɛ i-t. \x ◘ \xo 14:31 \xt Awřn. 14:21; 17:5\x*
\b
\m 
\v 32 Aɛeffan ittaẓẓeř x yixef nnes
\m s řɣar nnes i ittegg,
\m \add maca\add* amsegged ɣares mani i ɣa yarweř
\m \add ɛad\add* di řmewt nnes.
\m 
\v 33 Tiɣit tarsa deg wuř n ifehhamen,
\m \add maca\add* min iǧan
\m daxeř deg ibuhariyyen
\m ad ittwassnen. \x ◘ \xo 14:33 \xt Awřn. 10:14; 12:23; 13:16\x*
\b
\m 
\v 34 Tasegda tessɛuǧa řgens,
\m \add maca\add* řefḍiḥet n ccuɛub d ddnub.
\m 
\v 35 Řxaḍar n ujeǧid
\m yarsa x umsexxar ifehhmen
\m \add maca\add* wenni ifeṭṭḥen
\m iřeqqef i-t uduqqez nnes \add n ufugem\add*.
\b
\b
\c 15
\s1 Awařen iwezznen n Suliman - tasɣart 1c
\m 
\v 1 Twarrit ifsusen
\m tessesmaḍ axeyyeq,
\m \add maca\add* awař itteqqsen
\m issekkara-dd axeyyeq. \x ◘ \xo 15:1 \xt Awřn. 25:15\x*
\m 
\v 2 Iřes n imiɣisen ijebbed tussna ɣar zzat,
\m \add maca\add* aqemmum n ibuhařiyyen
\m ittazzeř s tubbuheřya. \x ◘ \xo 15:2 \xt Awřn. 12:23; 13:16; 15:28\x*
\m 
\v 3 Tiṭṭawin n SIDI di kuř amcan,
\m ttḥekkarent i iṣebḥanen d iɛeffanen. \x ◘ \xo 15:3 \xt Ayub 34:21; Awřn. 5:21; Irm. 16:17; 32:19\x*
\m 
\v 4 Iřes nni issgenfan d tacejjart n tudart,
\m \add maca\add* arrhaj nnes ittareẓẓa buḥbeř. \f ◼ \fr 15:4 \fk tacejjart\ft - niɣ ‘addag’ (‘iddagen’).\f*  \x ◘ \xo 15:4 \xt Awřn. 12:18; 13:14\x*
\m 
\v 5 Abuhaři ineṭṭar ttarbiyyet n babas,
\m \add maca\add* wenni ittḥekkaran
\m i uwebbex, aqa iften.
\m 
\v 6 Di taddart n umseggad dayes řkenz imɣar,
\m \add maca\add* di min dd-ittawi uɛeffan
\m dayes tamara.
\b
\m 
\v 7 Iyencicen n imiɣisen ttbezzaɛen tussna,
\m \add maca\add* uř n ibuhařiyyen war iǧi nican.
\m 
\v 8 Taɣarṣt i ittqeddamen iɛeffanen
\m d nnɛi i SIDI,
\m \add maca\add* taẓaǧit n inni igguren nican
\m aqa-tt i Netta d arḍa. \x ◘ \xo 15:8 \xt Awřn. 21:27; Ica. 1:11; Irm. 6:20; Ɛam. 5:21\x*
\m 
\v 9 Abrid n uɛeffan d nnɛi i SIDI,
\m \add maca\add* wenni iḍeffaran tasegda,
\m ittexs i-t Netta.
\m 
\v 10 Ttarbiyyet iqesḥen třeqqef
\m wenni isemḥen deg webrid,
\m u wenni icarrhen awebbex,
\m ad immet.
\m 
\v 11 Řaxart d \add tesraft n\add* uhellek
\m \add aqa din arezmen\add* zzat i SIDI,
\m mecḥař ɛad wuřawen n tarwa n bnadem? \x ◘ \xo 15:11 \xt 2 Im. 6:30; Izhd. 7:10; 44:22; Irm. 17:9, 10; Yḥ. 2:24, 25; 21:17; Řex. 1:24\x*
\m 
\v 12 Amestehziy war ittexs
\m wenni t i ɣa iwebbxen,
\m war ittriḥ ca ɣar imiɣisen.
\m 
\v 13 Uř ifarḥen ittegg udem icnan,
\m \add maca\add* amnus deg wuř isekkef buḥbeř. \x ◘ \xo 15:13 \xt Awřn. 17:22; 18:14\x*
\m 
\v 14 Uř ifehhmen yarezzu tussna,
\m \add maca\add* aqemmum n ibuhařiyyen
\m issecca ixef nnes s tubbuheřya.
\m 
\v 15 I yinni ittwaḥṣaren marra ussan nsen
\m aqa iɛeffnen,
\m \add maca\add* uř ifarḥen
\m \add am\add* ict n zzardet war iqeṭṭin.
\m 
\v 16 Iḥřa drus ak-d teggʷudi n SIDI,
\m x ijj n řkenz d ameqqran s řeḥweř. \x ◘ \xo 15:16 \xt Izhd. 37:16; Awřn. 16:8\x*
\m 
\v 17 Iḥřa ijj n ṭṭebṣi n řxuḍart
\m mani \add tḥekkem\add* tayri,
\m x ijj n uyenduz iṣeḥḥen ak-d wecrah. \x ◘ \xo 15:17 \xt Awřn. 17:1\x*
\b
\m 
\v 18 Aryaz ittarrujduden
\m issekkara imenɣiyyen,
\m \add maca\add* wenni ɣar iǧa ttasiɛ n řxaḍar
\m issexsay amenɣi. \x ◘ \xo 15:18 \xt Awřn. 28:25; 29:22\x*
\m 
\v 19 Abrid n umeɛguz
\m am cbarq ak-d isennanen,
\m \add maca\add* amesruq n yinni igguren nican
\m aqa ittwassgeɛɛed.
\b
\m 
\v 20 Mmis amiɣis issfarreḥ babas,
\m \add maca\add* bnadem abuhaři
\m isseḥqara yemmas. \x ◘ \xo 15:20 \xt Awřn. 10:1\x*
\m 
\v 21 Tubbuheřya aqa-tt d řefraḥet
\m i wenni war ɣar iǧi bu wuř imten,
\m \add maca\add* ijj n weryaz n řefhamet
\m iggur nican. \x ◘ \xo 15:21 \xt Awřn. 10:23; 14:9\x*
\m 
\v 22 Inwayen feccřen
\m mařa war din iǧi ccwar,
\m \add maca\add* s waṭṭas n imcawaren
\m ad yiři \add wenway\add*. \f ◼ \fr 15:22 \fk Inwayen\ft - niɣ ‘inekkwan’ niɣ ‘ixarriṣen’.\f*  \x ◘ \xo 15:22 \xt Awřn. 11:14\x*
\m 
\v 23 Aryaz ɣares řefraḥet
\m di temwarrit iṣebḥen
\m zeg uqemmum nnes.
\m Mecḥař iṣbeḥ wawař di řweqt nnes!
\b
\m 
\v 24 Abrid n tudart \add ineddeh\add*
\m ɣar sennej i ufehham,
\m maḥend netta ad iḥeyyed
\m x řaxart swadday.
\m 
\v 25 Taddart n bu-nnfaxet
\m ad tt iqřeɛ SIDI,
\m \add maca\add* aymir \add n yeyyar\add* n tajjač
\m issemtan i-t Netta. \x ◘ \xo 15:25 \xt Awřn. 2:21, 22; 12:7; 14:11\x*
\m 
\v 26 Ixemmimen n uɛeffan d nnɛi i SIDI,
\m \add maca\add* awařen icewwaren d imezdagen. \x ◘ \xo 15:26 \xt Awřn. 6:18\x*
\m 
\v 27 Wenni yarezzun x arbeḥ
\m iɣeṭṭeř taddart nnes di arrẓiyyet,
\m \add maca\add* wenni icarrhen tarzifin, ad iddar. \x ◘ \xo 15:27 \xt Awřn. 1:19\x*
\b
\m 
\v 28 Uř n imseggaden ittxarraṣ
\m maḥend ad dd-yarr,
\m \add maca\add* aqemmum n iɛeffanen
\m ittfeyyeḍ s řɣar.
\m 
\v 29 Iggʷej SIDI x iɛeffanen,
\m \add maca\add* taẓaǧit n imseggaden ittesřa as. \x ◘ \xo 15:29 \xt Izhd. 10:17; 34:19; 145:18, 19\x*
\b
\m 
\v 30 Tafawt \add di\add* tiṭṭawin tessfarreḥ uř,
\m řexbar aṣebḥan issyuma iɣsan. \x ◘ \xo 15:30 \xt Awřn. 25:25\x*
\m 
\v 31 Amezzuɣ ittesřan
\m ɣar uwebbex i tudart,
\m ad issens di řwesṭ n imiɣisen.
\b
\m 
\v 32 Wenni ineṭṭaren ttarbiyyet,
\m isseḥqara ixef nnes,
\m \add maca\add* wenni ittesřan ɣar uwebbex,
\m issyawan uř \add nnes\add*. \x ◘ \xo 15:32 \xt Awřn. 13:18\x*
\m 
\v 33 Tiggʷudi n SIDI d ttarbiyyet ɣar tiɣit,
\m u awaḍeɛ ittizwar i ccan. \x ◘ \xo 15:33 \xt Awřn. 1:7; 9:10; 18:12\x*
\b
\b
\c 16
\m 
\v 1 Bnadem ɣares ixarriṣen
\m deg wuř \add nnes\add*,
\m \add maca\add* tamwarrit n yiřes
\m \add tᵉttas-dd\add* zi SIDI. \x ◘ \xo 16:1 \xt Awřn. 16:1; 19:21; 20:24; Irm. 10:23\x*
\m 
\v 2 Marra ibriden n weryaz
\m ṣfan di tiṭṭawin nnes,
\m \add maca\add* SIDI ittqeǧab buḥbeřat. \x ◘ \xo 16:2 \xt Awřn. 21:2\x*
\m 
\v 3 Sars řexdayem nnec i SIDI,
\m \add xenni\add* ad ttwassmettnen inwayen nnec. \x ◘ \xo 16:3 \xt Izhd. 37:5; 55:23; Mt. 6:25; Lk. 12:22; 1 Bṭ. 5:7\x*
\m 
\v 4 SIDI ixřeq-dd marra i lɣaraḍ nnes,
\m ɛad uřa d aɛeffan \add igga i-t\add* i wass n řɣar.\x ◘ \xo 16:4 \xt Ayub 21:30\x*
\b
\m 
\v 5 Kuř amɛeffar d nnɛi i SIDI, afus xas,
\m netta war ittᵉttwabarri \add ɛemmarṣ\add*. \x ◘ \xo 16:5 \xt Awřn. 6:17; 8:13; 11:21\x*
\m 
\v 6 S tmexsiwt icewwaren d řaman
\m ad ittwasseṣřeḥ x řɣecc,
\m u s tiggʷudi n SIDI
\m ittḥeyyad weryaz x řɣar.
\m 
\v 7 Mařa usin-dd ibriden n ijj n weryaz
\m x řxaḍar n SIDI,
\m ad yarr Netta uřa d řɛedyan nnes
\m ad kides ggen řehna.
\b
\m 
\v 8 Iḥra drus ak-d tsegda
\m x waṭṭas n řɣiǧet břa řḥeqq. \x ◘ \xo 16:8 \xt Izhd. 37:16; Awřn. 15:16\x*
\m 
\v 9 Uř n bnadem ittxarreṣ abrid nnes,
\m \add maca\add* SIDI ineddeh iṣuraf nnes. \f ◼ \fr 16:9 \fk iṣuraf\ft - s Tɛibranit ‘aṣurif’.\f*
\m 
\v 10 Řḥukm břa adwař x iyencicen n ujeǧid,
\m aqemmum nnes war ixeṭṭi deg weḥkam.
\m 
\v 11 Řmizan \add nican\add* d ṭṭawyat n řmizan nican
\m aqa aten n SIDI,
\m marra iẓra n řewzen di tecyart
\m d řxedmet nnes. \x ◘ \xo 16:11 \xt Lawi 19:36; Aɛwd. 25:13-16; Awřn. 11:1; 20:10, 23\x*
\m 
\v 12 D nnɛi i ijeǧiden xmi ɣa ggen řɣar,
\m maɣar řɛarc ittwassemten zi tsegda.
\b
\m 
\v 13 Iyencicen \add i iccuren\add* s tsegda
\m tteɛjiben i ujeǧid,
\m u wenni issawařen nican, ittexs i-t netta.
\m 
\v 14 Asɛar n ujeǧid \add am\add* lmalakat n řmewt,
\m \add maca\add* aryaz amiɣis izemmar
\m ad ɣares tt i-dd yarr. \x ◘ \xo 16:14 \xt Awřn. 19:12; 20:2\x*
\m 
\v 15 Di tfawt n wudem \add ittissiqen\add* n ujeǧid
\m \add teǧa\add* tudart,
\m arḍa nnes am useynu n wenẓar
\m di tefsut. \x ◘ \xo 16:15 \xt Awřn. 19:12\x*
\b
\m 
\v 16 Aqa teḥřa tarezzut n tiɣit
\m x wureɣ ittissiqen,
\m u \add mecḥař ktar\add* ad tiři twafit n řefhamet
\m sennej x \add twafit n\add* nnuqart. \x ◘ \xo 16:16 \xt Ayub 28:15; Izhd. 19:11; 119:72; Awřn. 3:14, 15; 8:11, 19\x*
\m 
\v 17 Abrid n yinni igguren nican
\m ittḥeyyad x řɣar.
\m Wenni iḥeṭṭan abrid nnes,
\m iḥeṭṭa řeɛmar nnes.
\m 
\v 18 Tanefsect tᵉttizwar-dd i arẓẓiyyet,
\m u nnfaxet tᵉttas-dd qbeř i uweṭṭu. \x ◘ \xo 16:18 \xt Awřn. 11:2; 17:19\x*
\m 
\v 19 Iḥřa aqnaɛ n buḥbeř
\m ak-d inni ittwaḥṣaren,
\m x ubeṭṭu n tkeccaḍt ak-d ayt-nnfaxet.
\m 
\v 20 Wenni ittxarraṣen mliḥ
\m di ca n tmesřact, ad yaf řxar,
\m sseɛd n wenni ittcařan x SIDI.\x ◘ \xo 16:20 \xt Izhd. 2:12; 34:9; 125:1; Ica. 30:18; Irm. 17:7\x*
\b
\m 
\v 21 Wenni ɣar iǧa wuř d amiɣis,
\m ad t semman bu-weftan,
\m u taẓyudi \add n řhard\add* n iyencicen
\m tarenni di řefhamet.
\m 
\v 22 Řeɛqeř d řɛunṣar n tudart i bab nnes,
\m \add maca\add* ttarbiyyet i ibuhařiyyen
\m d tubbuheřya \add waha\add*.\x ◘ \xo 16:22 \xt Awřn. 13:14\x*
\m 
\v 23 Uř n umiɣis ittarra aqemmum nnes ifehhem,
\m zeg iyencicen nnes ad fehmen ktar.
\m 
\v 24 Awařen icewwaren
\m \add ggin am\add* tamment n teɣrast,
\m \add aqa aten\add* d imiẓiden i řeɛmar
\m d ugenfu i yeɣsan.
\b
\m 
\v 25 Ad taɣ ittɣiř as i ca n yijjen
\m aqa abrid nnes nican,
\m \add maca\add* aneggar nnes \add mɣir\add* ibriden
\m \add ittawyen\add* ɣar řmewt. \x ◘ \xo 16:25 \xt Awřn. 14:12\x*
\m 
\v 26 Řaẓ n ucewwař ixeddem as i netta,
\m maɣar aqemmum nnes ineddeh i-t.
\m 
\v 27 Aryaz i war isekkwin iɣezza řɣar,
\m x iyencicen nnes
\m am yict n tmessi ittceɛɛařen. \x ◘ \xo 16:27 \xt Awřn. 12:18\x*
\m 
\v 28 Aryaz \add iccuren\add* s řexdaɛat
\m issekkara amenɣi,
\m u axbarji ittawi-dd \add ɛad\add* abeṭṭu
\m ak-d umeddukkeř iṣebḥen aṭṭas. \x ◘ \xo 16:28 \xt Awřn. 15:18; 26:21; 29:22\x*
\m 
\v 29 Aryaz bu-řexcunet ittɣarra jjar nnes,
\m ineddeh i-t ɣar ijj n webrid
\m i war iǧin mliḥ.
\m 
\v 30 Netta itteqqen tiṭṭawin nnes
\m maḥend ad ixarreṣ
\m marra ddarbat n řexdaɛet,
\m ittkemmec iyencicen nnes,
\m \add aqa da\add* igga řɣar. \x ◘ \xo 16:30 \xt Awřn. 6:13, 14\x*
\b
\m 
\v 31 Acuwwaf icaben d ijj n ttaj izewwqen,
\m tzemmared ad tt tafed x webrid n tsegda.
\m 
\v 32 Iḥřa bu-ttasiɛ n řxaḍar
\m x ijj n weryaz ijehden
\m u wenni ittebbaten buḥbeř nnes \add iḥřa\add*
\m x wenni iḥewwsen ict n tendint.
\m 
\v 33 Taqedduḥt temmenḍar deg weḥsin,
\m \add maca\add* mkuř array ittas-dd zi SIDI.
\b
\b
\c 17
\m 
\v 1 Iḥřa ijj n uzeɛɛif n weɣrum
\m yuẓɣen ak-d řehna,
\m x ict n taddart teccur s tɣarṣa,
\m dayes amenɣi. \x ◘ \xo 17:1 \xt Awřn. 15:17\x*
\m 
\v 2 Ijj n yismeɣ ifetnen ad iḍebbar
\m x ijj n mmis nni ittawyen ɣar řefḍiḥet,
\m di řwesṭ n yaytmas ad ibḍa netta řwart.
\m 
\v 3 Aṭenjir n usefsi i nnuqart
\m u afarran i wureɣ,
\m \add maca\add* SIDI ittjarrab uřawen. \x ◘ \xo 17:3 \xt Awřn. 27:21; Irm. 17:10\x*
\m 
\v 4 Aɛeffan ixezzar ɣar iyencicen iɛeffanen,
\m bu-ixarriqen ittic amezzuɣ
\m i yiřes iccuren s řɣecc.
\m 
\v 5 Wenni ittḥeccen x umezřuḍ,
\m issfeṭṭeḥ wenni t-i-dd-ixeřqen,
\m wenni ifarrḥen x arẓiyyet,
\m war ittwiḥsib d amezdag. \x ◘ \xo 17:5 \xt Awřn. 14:31\x*
\m 
\v 6 Ttaj n iwessura d ayyawen,
\m talwizt n iḥenjiren d ibabaten nsen.
\b
\m 
\v 7 Ayencic n ccan
\m war dd-ittis ak-d ubuhaři,
\m \add xenni\add* ɛessak ɛad ayencic issxarriqen
\m ak-d umcenneɛ.
\m 
\v 8 Tarzeft n arrecwet
\m d ijj n weẓru izewwqen
\m di tiṭṭawin n bab nnes,
\m mani ma yarra s uzeǧif, ittefřiḥ.
\m 
\v 9 Wenni issdurruyen axeṭṭu,
\m yarezzu tayri,
\m \add maca\add* wenni ittɛawaden
\m ict n řḥajjet zi jdid,
\m ibeṭṭa imeddukkař icnan.
\m 
\v 10 Ittqarra utextex x ufehham
\m aṭṭas x mya n teyyita x yijj n ubuhaři.
\b
\m 
\v 11 Amɣewweɣ yarezzu mɣir x řɣar,
\m \add x uya\add* ad ɣares dd-ittwassekk
\m ijj n umsexxar iqesḥen ḍidd nnes.
\m 
\v 12 Ejj ad immeřqa ca n ddub
\m i umi ttwacaren tarwa ak-d ca n yijjen,
\m \add maca\add* war iǧi abuhaři di tubbuheřya nnes.
\m 
\v 13 Wenni ittxeǧaṣen min iṣebḥen s řɣar,
\m war tᵉttḥeyyid arẓiyyet x taddart nnes. \x ◘ \xo 17:13 \xt Aɛwd. 32:35; Awřn. 20:22; 24:29; Rum. 12:17; 1 Ts. 5:15; 1 Bṭ. 3:9\x*
\m 
\v 14 Beddu n umenɣi
\m \add amecnaw\add* arzam n řḥemřet n waman.
\m Ejj amenɣi ad yars qbeř i ɣa idduqqez. \x ◘ \xo 17:14 \xt Awřn. 20:3\x*
\m 
\v 15 Wenni ittbarran aɛeffan
\m u wenni ittbarraḥen
\m aqa amsegged d aɛeffan,
\m aqa nitni s tnayen idsen
\m d nnɛi i SIDI. \x ◘ \xo 17:15 \xt Uf. 23:7; Awřn. 24:24; Ica. 5:23\x*
\b
\m 
\v 16 Mayemmi din i ɣa iřint tmenyat
\m deg ufus n ubuhaři
\m maḥend ad iseɣ tiɣit,
\m am war ɣares uř \add i man aya\add*?
\m 
\v 17 Ameddukkeř \add d tidett\add* ittexs řebda,
\m u tawmat tᵉttwaxřeq-dd i řeḥṣaret.
\m 
\v 18 Bnadem nni war ɣar iǧi wuř imten,
\m iccat afus,
\m ittegg ixef nnes d aḍman i jjar nnes.
\m 
\v 19 Wenni ittexsen axeṭṭu,
\m ittexs amcubbec,
\m wenni itteggen tawwart nnes tgeɛɛed,
\m yarezzu tareẓẓit. \x ◘ \xo 17:19 \xt Awřn. 16:18\x*
\m 
\v 20 Wenni ɣar iǧa uř ifarɣ,
\m war ittif min iṣebḥen,
\m wenni ifarrɣen s iyencicen nnes,
\m ad iwḍa di arẓiyyet.
\b
\m 
\v 21 Wenni dd-yurwen ijj n ubuhaři,
\m \add ittawi-dd\add* acḍan i yixef nnes,
\m babas n ubuhaři war izemmar ad ifarḥ.
\m 
\v 22 Uř ifarḥen ijebbed agenfu,
\m \add maca\add* buḥbeř iceḍnen issaẓaɣ iɣsan. \x ◘ \xo 17:22 \xt Awřn. 15:13\x*
\m 
\v 23 Aɛeffan ad dd-iksi tarzeft \add n arrecwet\add*
\m zeg weḥsin,
\m ḥima ad issfarɣ imesraq n řḥeqq.
\m 
\v 24 Afehham \add ittegg\add* tiɣit zzat i tmuɣři nnes,
\m \add maca\add* tiṭṭawin n ubuhaři
\m \add ttawyent\add* ař ṭṭarf n temmurt. \x ◘ \xo 17:24 \xt Amb. 2:14; 8:1\x*
\b
\m 
\v 25 Ijj n mmis abuhaři d řeɛdab i babas,
\m d ijj n řeḥřiq amerzag
\m i wenni t-i-dd yurwen. \x ◘ \xo 17:25 \xt Awřn. 10:1; 15:20; 19:13\x*
\m 
\v 26 Aweddeb n umsegged war iǧi nican,
\m \add am uřa d\add* tiyyita i ayt n ṭṭasiřet
\m di ssibbet n řeṣfayet \add nsen\add*.
\m 
\v 27 Wenni ɣar teǧa tussna,
\m imenneɛ awařen nnes,
\m aryaz afehham \add dayes\add* buḥbeř nnes yarsa.
\m 
\v 28 Uřa abuhaři issɣaden,
\m ad ittwaḥseb d amiɣis,
\m wenni ibellɛen iyencicen nnes
\m \add ad ittwaḥseb\add* d afettan.
\b
\b
\c 18
\m 
\v 1 Wenni iɛezzřen ixef nnes,
\m yarezzu x meẓri nnes,
\m netta idduqquz x marra
\m min izemmaren ad yiři d adebbar.
\m 
\v 2 Abuhaři war d as tᵉtteɛjib řefhamet,
\m \add itteɛjib as\add* mɣir aɛarri n wuř nnes.
\b
\m 
\v 3 Xmi dd-ittadef uɛeffan,
\m ittas-dd uřa d aseḥqar,
\m u ak-d řefḍiḥet ittas-dd řɛar.
\m 
\v 4 Awařen zeg uqemmum n weryaz
\m \add am\add* waman yuǧɣen,
\m řɛunṣar n tiɣit d \add ict n\add* tiɣzart ittazzřen.
\m 
\v 5 War iǧi ca mliḥ ad tessɛizzed aɛeffan,
\m maḥend ad tessḥeyyded
\m amsegged di ccreɛ. \x ◘ \xo 18:5 \xt Lawi 19:15; Aɛwd. 1:17; 16:19; Awřn. 24:23\x*
\m 
\v 6 Iyencicen n ubuhaři neddhen \add t\add*
\m ɣar umcebbec,
\m aqemmum nnes ittřaɣa-dd i weɛmud.
\m 
\v 7 Aqemmum n ubuhaři d ahellek nnes,
\m iyencicen nnes d řfex i řeɛmar nnes. \x ◘ \xo 18:7 \xt Awřn. 10:14; 12:13; 13:3\x*
\b
\m 
\v 8 Awařen n ixbarjiyyen am ḥalawit,
\m hekkwant deg ixxamen
\m n daxeř n uɛeddis. \x ◘ \xo 18:8 \xt Awřn. 26:22\x*
\m 
\v 9 Wenni iǧan d amarxu di řxedmet nnes,
\m aqa t d umas n bab n uředdeǧ.
\b
\m 
\v 10 Isem n SIDI d ijj n lburj imten,
\m amsegged ittazzeř ɣar dinni,
\m uca ittwassakkwaḍ ař din di řaman. \x ◘ \xo 18:10 \xt 2 Ṣm. 22:51; Izhd. 18:3; 61:4; Awřn. 29:25\x*
\m 
\v 11 Agřa n bu-wagřa
\m d tandint nnes ijehden,
\m \add tanita\add* am yijj n řḥiḍ yuɛřan qaɛ
\m di řbař nnes. \x ◘ \xo 18:11 \xt Awřn. 10:15\x*
\b
\m 
\v 12 Qbeř ma i ɣa ittwarẓ,
\m ittgeɛɛad wuř n bnadem,
\m \add maca\add* awaḍeɛ ittizwař as i ccan. \x ◘ \xo 18:12 \xt Awřn. 11:2; 15:33; 16:18\x*
\m 
\v 13 Wenni dd-ittarran awař
\m qbeř i ɣa iseř,
\m d man aya d tubbuheřya
\m d řefḍiḥet i netta.
\m 
\v 14 Buḥbeř n weryaz
\m ittsenned i-t ɣar řehřac nnes,
\m \add maca\add* buḥbeř ittwarẓen,
\m wi izemmaren ad t iksi?
\m 
\v 15 Uř n ufehham yarezzu tussna,
\m amezzuɣ n umiɣis yarezzu tussna.
\m 
\v 16 Tarzeft n bnadem tarezzem as tiwwura,
\m tneddeh i-t zzat i wudem n imeqqranen.
\m 
\v 17 Wenni d amezwaru di ddeɛwet nnes
\m ittban d amsegged,
\m \add maca xenni\add* ad dd-yas jjar nnes
\m uca ittnecceb di tmesřact. \x ◘ \xo 18:17 \xt Awřn. 25:8\x*
\m 
\v 18 Taqedduḥt ittejjan imenɣan ttbeddan,
\m tbeṭṭa jar inni ɣar teǧa ṣṣulṭa.
\m 
\v 19 Ijj n uma nni umi di ggin řɛib,
\m \add ittwaṭṭef ktar\add* x ict n tendint ijehden,
\m imenɣan ggin am zzekrun n řeqṣar.
\b
\m 
\v 20 Zi řɣiǧet n uqemmum n ijj n weryaz
\m ittyawan uɛeddis nnes,
\m ad ijjawen zi ṣṣabet n iyencicen nnes. \x ◘ \xo 18:20 \xt Awřn. 12:14; 13:2\x*
\m 
\v 21 Řmewt d tudart deg ufus n yiřes,
\m kuř ijjen wenni ten ittexsen,
\m ad yecc rɣiǧet nsen. \x ◘ \xo 18:21 \xt Awřn. 21:23; Yaɛ. 3:2\x*
\m 
\v 22 Wenni yufin tamɣart,
\m yufa min iṣebḥen,
\m u netta iṭṭef arḍa n SIDI. \x ◘ \xo 18:22 \xt Awřn. 19:14\x*
\m 
\v 23 S uḥeccem issawař umezřuḍ,
\m bu-wagřa ittarra-dd s řeqsaḥet.
\m 
\v 24 Aryaz nni ɣar ǧan imeddukkař \add aṭṭas\add*,
\m ad iwḍa di tamara,
\m \add maca\add* ca n imuren
\m ameddukkeř ittexs \add i cek\add*
\m ktar zi tawmat. \x ◘ \xo 18:24 \xt Awřn. 17:17\x*
\b
\b
\c 19
\m 
\v 1 Iḥřa ijj n umezřuḍ
\m igguren di řeṣfayet nnes,
\m x wenni ɣar iǧan iyencicen farɣen,
\m u aqa t d abuhaři \add i yeǧa\add*. \x ◘ \xo 19:1 \xt Awřn. 28:6\x*
\m 
\v 2 Břa tussna uřa d řeɛmar war iǧi ca mliḥ,
\m wenni ittqeǧqen s iḍaren \add nnes\add*, ad ixḍa.
\m 
\v 3 Tubbuheřya n bnadem
\m issfarraɣ abrid nnes,
\m u \add xenni\add* uř nnes ad isɛar x SIDI. \x ◘ \xo 19:3 \xt Yaɛ. 1:13, 14, 15\x*
\m 
\v 4 Agřa ittawi-dd aṭṭas n imeddukkař,
\m \add maca\add* amezřuḍ isemmeḥ dayes
\m umeddukkeř nnes.\x ◘ \xo 19:4 \xt Awřn. 14:20\x*
\b
\m 
\v 5 Acehhad issxarriqen
\m war ittwaḥesseb ca d amezdag,
\m wenni dd-yarexxun i ixarriqen,
\m war inejjem. \x ◘ \xo 19:5 \xt Aɛwd. 19:19; Awřn. 21:28\x*
\m 
\v 6 Aṭṭas ttzawgen zzat i wudem n umcenneɛ,
\m kuř ijj ittexs ad yiři d ameddukkeř
\m n weryaz i ɣar iǧa terzifin.
\m 
\v 7 Marra aytmas n umezřuḍ carrhen t,
\m mecḥař ttiggʷejjen xas
\m imeddukkař nnes!
\m Netta iḍeffar awařen
\m nni war isekkwin walu. \x ◘ \xo 19:7 \xt Awřn. 14:20\x*
\m 
\v 8 Wenni iṭṭfen uř \add amiɣis\add*,
\m ittexs řeɛmar nnes,
\m wenni iḥeṭṭan řefhamet,
\m ad yaf min icnan.
\b
\m 
\v 9 Ijj n ucehhad issxarriqen
\m war ittwaḥesseb ca d amezdag,
\m wenni yarexxun i ixarriqen,
\m ad ittwahellek.
\m 
\v 10 Afeyyec war dd-yusi x ubuhaři,
\m mammec ɛad x umsexxar
\m maḥend ad iselleṭ x řḥukkam. \x ◘ \xo 19:10 \xt Awřn. 30:22\x*
\m 
\v 11 Řeɛqeř n bnadem ittarra i-t
\m ad igg s ttasiɛ n řxaḍar
\m tusa-dd xas maḥend ad imeyyek
\m x \add u\add*xeṭṭu nnes.
\m 
\v 12 Asxeḍ n ujeǧid
\m am zzhir n weyrad di temẓi nnes,
\m \add maca\add* arḍa nnes am nnda x arbiɛ. \x ◘ \xo 19:12 \xt Awřn. 16:14, 15; 20:2\x*
\m 
\v 13 Mmis abuhaři d arẓiyyet i babas,
\m amcubbec n temɣart igga
\m am tuddimt \add n tzeqqa\add* war iqeṭṭin. \x ◘ \xo 19:13 \xt Awřn. 10:1; 15:20; 17:25; 21:19; 27:15\x*
\m 
\v 14 Taddart d wagřa
\m aqa aten d řwart n řejdud
\m \add maca\add* ict n temɣart ifehhmen
\m aqa-tt n SIDI. \x ◘ \xo 19:14 \xt Awřn. 18:22\x*
\m 
\v 15 Řeɛgez yarra \add bnadem\add*
\m ad iwḍa deg iḍeṣ yuǧɣen,
\m u řeɛmar \add iccur\add* s řɣecc ad iǧaẓ. \x ◘ \xo 19:15 \xt Awřn. 6:9; 10:4; 20:13\x*
\m 
\v 16 Wenni iḥeṭṭan tawṣeyyet,
\m iḥeṭṭa řeɛmar nnes,
\m wenni war iḥeṭṭin ibriden nnes,
\m ad immet. \x ◘ \xo 19:16 \xt Awřn. 3:21, 22; Lk. 11:28\x*
\b
\m 
\v 17 Wenni ittḥinnan x umezřuḍ,
\m yareṭṭeř i SIDI.
\m Netta ad as ixeǧeṣ řxedmet nnes.
\m 
\v 18 Webbex mmic, mařa ɛad din ca n řayas,
\m \add maca\add* war t neqq ca,
\m war ttejji ca ad iksi aya řeɛmar nnec. \x ◘ \xo 19:18 \xt Awřn. 13:24; 23:13; Afa. 6:4\x*
\m 
\v 19 Wenni isɛaren aṭṭas,
\m ad ittwaxeǧeṣ \add i manayenni\add*,
\m maɣar mařa texsed ad t tmenɛed,
\m xenni ad dayes tarenyed \add waha\add*.
\m 
\v 20 Seř cek ɣar ucawar
\m uca qbeř ttarbiyyet,
\m maḥend ad tdewřed d amiɣis
\m ɣar uneggar.
\m 
\v 21 Aqa din aṭṭas n ixemmimen
\m deg wuř n weryaz,
\m \add maca\add* ccwar n SIDI ittɣima ibedd. \x ◘ \xo 19:21 \xt Ayub 23:13; Izhd. 33:11; 115:3; Ica. 46:10\x*
\b
\m 
\v 22 Tamexsiwt icewwaren n bnadem
\m d řeḍrafet nnes,
\m \add ammu i iǧa\add* ijj n umezřuḍ ḥsen
\m x ijj n bu-ixarriqen.
\m 
\v 23 Tiggʷudi n SIDI tneddeh ɣar tudart,
\m maɣar itteṭṭeṣ ijjiwen,
\m war ɣares dd-ittas ca
\m min war iḥřin. \x ◘ \xo 19:23 \xt Izhd. 34:10\x*
\m 
\v 24 Ameɛguz issnuffar afus nnes
\m di ṭṭebṣi,
\m war t-i-dd-ittarri \add ɛawed\add*
\m ɣar uqemmum nnes. \f ◼ \fr 19:24 \fk aḥsin\ft - niɣ ‘abeḥrur’.\f*  \x ◘ \xo 19:24 \xt Awřn. 26:15\x*
\m 
\v 25 Wwet amestehziy,
\m ammu i ɣa iften
\m wenni war ɣares bu řefhamet,
\m u ɛaqeb afehham,
\m \add xenni\add* ad ikseb řefhamet. \x ◘ \xo 19:25 \xt Awřn. 21:11\x*
\b
\m 
\v 26 Wenni itteggen ɣezzu di babas
\m niɣ wenni issuffuɣen yemmas,
\m aqa d mmis n řefḍiḥet
\m nni yarran \add bnadem\add* ad iseḍḥa.
\m 
\v 27 Sbedd-dd, a mmi,
\m maḥend ad tesřed ɣar uwebbex,
\m mařa texsed ad tḥeyyded
\m x wawařen iccuren s tussna.
\m 
\v 28 Ijj n ucehhad i war isekkwin
\m iɣeṭṭeř zi řḥeqq,
\m uca aqemmum n iɛeffanen
\m iṣarreḍ řɣecc.
\m 
\v 29 Imestehzayen tᵉttraja aten řeḥkamet,
\m u tiyitta deg weɛrur i ibuhařiyyen.
\b
\b
\c 20
\m 
\v 1 Binu d ijj n umestehziy,
\m ccrab d bu-ssḍeɛ,
\m kuř ijjen wenni zzayes i ɣa iweddaren,
\m \add ɛemmarṣ\add* war iddikkwiř d amiɣis.
\m 
\v 2 Ahuddi n ujeǧid am zzhir n wayrad:
\m wenni t isseɛaren,
\m ixeṭṭa ak-d řeɛmar nnes.\x ◘ \xo 20:2 \xt Awřn. 16:14; 19:12\x*
\m 
\v 3 Asmaḥ deg umcubbec
\m aqa d ccan i weryaz,
\m \add maca\add* kuř abuhaři ad idduqqez. \x ◘ \xo 20:3 \xt Awřn. 17:14\x*
\m 
\v 4 Zi řweqt n řexrif war icarrez umeɛguz,
\m \add xenni\add* ad ittar di řweqt n tmeyra,
\m \add maca\add* war ittif walu.
\m 
\v 5 Ixarriṣen deg wuř n bnadem
\m aman yuǧɣen,
\m \add maca\add* ijj n weryaz s řefhamet
\m issen ad ten yayem. \x ◘ \xo 20:5 \xt Awřn. 18:4\x*
\m 
\v 6 Aṭṭas n iwdan ttřaɣan x ca n ijjen
\m ‘ameddukkeř nsen d amtiqqi’,
\m \add maca\add* aryaz d amtiqqi,
\m man wen t i ɣa yafen?
\m 
\v 7 Amsegged iggur di řeṣfayet nnes,
\m sseɛd n iḥenjiren nnes
\m \add i ittejja\add* awarni as.
\b
\m 
\v 8 Ijj n ujeǧid nni ittɣiman
\m x řkursi n ccreɛ,
\m ittṣeffa marra řɣar s tiṭṭawin nnes. \x ◘ \xo 20:8 \xt Awřn. 20:26\x*
\b
\m 
\v 9 Wi izemmaren ad yini:
\m “Necc ssizedgeɣ uř inu,
\m necc izdigeɣ zi ddnub inu!”? \x ◘ \xo 20:9 \xt 1 Ij. 8:46; Ayub 14:4; Izhd. 51:7; Amb. 7:20; 1 Yḥ. 1:8\x*
\m 
\v 10 Ijj n řewzen d ijj n řewzen nneɣni,
\m ijj n ifa d ijj n ifa nneɣni,
\m aqa aten s tnayen idsen d nnɛi i SIDI. \x ◘ \xo 20:10 \xt Aɛwd. 25:13; Awřn. 11:1; 20:23\x*
\m 
\v 11 Aḥudri isscana di tmegga nnes,
\m ma řxedmet nnes teṣfa
\m niɣ aqa nican \add i teǧa\add*.
\m 
\v 12 Amezzuɣ ittesřan d tiṭṭ ittwařan,
\m SIDI igga i-ten s tnayen idsen. \x ◘ \xo 20:12 \xt Uf. 4:11; Izhd. 94:9\x*
\m 
\v 13 War ttexs iḍeṣ
\m maḥend war teddikkwiřed d amezřuḍ,
\m arzem tiṭṭawin nnec,
\m syiwen ixef nnec s weɣrum. \x ◘ \xo 20:13 \xt Awřn. 19:15\x*
\b
\m 
\v 14 ‘War iḥři, war iḥři!’, iqqar umsewweq,
\m \add maca\add* mařa yuyur,
\m \add ammu i\add* ittcenneɛ ixef nnes.
\m 
\v 15 Ureɣ iǧa, uřa d aṭṭas n řmarjan,
\m \add maca\add* iyencicen \add ccuren\add* s tussna
\m d ict n řqecɛet iɣřan aṭṭas. \x ◘ \xo 20:15 \xt Awřn. 3:14, 15\x*
\m 
\v 16 Mařa ijjen iddakkwař
\m d aḍman i yijj n ubarrani,
\m \add xenni\add* ksi arruḍ nnes u ksi t d ddiyyet
\m i yinni war ittwassnen. \x ◘ \xo 20:16 \xt Awřn. 11:15; 27:13\x*
\m 
\v 17 D amiẓid i bnadem aɣrum
\m \add nni iṭṭef s\add* ixarriqen,
\m awarni as ad iccur uqemmum nnes
\m s iqayasen. \x ◘ \xo 20:17 \xt Awřn. 9:17\x*
\m 
\v 18 Ixemmimen ttekmiřen s ucawar,
\m x uyenni ndeh amenɣi s udebbar. \f ◼ \fr 20:18 \fk Ixemmimen\ft - niɣ ‘inwayen’ niɣ ‘inekkwan’ niɣ ‘ixarriṣen’.\f*
\m 
\v 19 Wenni igguren da d diha s texbarjit,
\m ittɛarra min innuffaren,
\m war tsebbeb ak-d wenni issḥinniben
\m s iyencicen nnes iṣebhen. \x ◘ \xo 20:19 \xt Awřn. 11:13\x*
\b
\m 
\v 20 Wenni i ɣa ineɛřen x babas d yemmas,
\m řefnar nnes ad ittwassexsi
\m di taǧest tabarcant. \x ◘ \xo 20:20 \xt Uf. 21:17; Lawi 20:9; Aɛwd. 27:16; Mt. 15:4\x*
\m 
\v 21 Mařa tasɣart tᵉttwakseb deɣya
\m s tazřa deg umezwaru,
\m war dd-tiweḍ d lbaraka ɣar uneggar. \x ◘ \xo 20:21 \xt Awřn. 13:11; 28:20\x*
\m 
\v 22 War qqar: “Necc ad xeřfeɣ řɣar!”
\m \add maca\add* tceř x SIDI u Netta ad cek issenjem. \x ◘ \xo 20:22 \xt Aɛwd. 32:35; Awřn. 17:13; 24:29; Rum. 12:17; 1 Ts. 5:15; 1 Bṭ. 3:9\x*
\m 
\v 23 Ijj n řewzen d ijj n řewzen nneɣni,
\m aqa aten d nnɛi i SIDI,
\m řmizanat iɣeccen war ǧin ca mliḥ. \x ◘ \xo 20:23 \xt Awřn. 20:10\x*
\m 
\v 24 Iṣuraf n ijj n weryaz aqa aten n SIDI,
\m \add xenni\add* mammec ɣa yegg bnadem
\m ad issen abrid nnes? \x ◘ \xo 20:24 \xt Ayub 31:4; Izhd. 37:23; 139:2, 3; Irm. 10:23\x*
\m 
\v 25 Aqa-t d řfex i bnadem
\m i ɣa iřaɣan s uqeǧeq ‘amqeddes’,
\m u \add ɛad\add* awarni lwuɛud nnes \add i igga\add*
\m ad ixarreṣ.
\m 
\v 26 Ijj n ujeǧid amiɣis ittṣeffa iɛeffanen,
\m ittejja tajarrart
\m \add n teřwiḥt itteḥřuǧuḍen i usarwet\add*
\m ad xasen iɛqeb.
\b
\m 
\v 27 Twarrit n nnefs n buḥbeř n bnadem
\m d řefnar n SIDI nni yarezzun
\m di daxeř n ixxamen n uɛeddis.
\m 
\v 28 Tamexsiwt icewwaren d řaman
\m ḥeṭṭan ajeǧid,
\m u řɛarc nnes issejhed i-t
\m s tmexsiwt icewwaren.
\m 
\v 29 Talwizt n iḥudriyyen d jjehd nsen,
\m u lɛaḍama n iwessura d acuwwaf icaben. \x ◘ \xo 20:29 \xt Awřn. 16:31\x*
\m 
\v 30 Iyezzimen ittazzřen s idammen
\m ssizdigen \add bnadem\add* zi řɣar,
\m u tiyyita \add ṣeffant\add* uřa d takrict.\x ◘ \xo 20:30 \xt Awřn. 10:13\x*
\b
\b
\c 21
\m 
\v 1 Uř n ujeǧid
\m am tɣezratin n waman
\m deg ufus n SIDI.
\m Netta ineddeh i-t, mani ma ixs Netta.
\b
\m 
\v 2 Marra ibriden n bnadem
\m nican di tiṭṭawin nnes,
\m \add maca\add* SIDI ittqeǧab uřawen. \x ◘ \xo 21:2 \xt Awřn. 16:2\x*
\m 
\v 3 Timegga n tsegda d řḥeqq,
\m d tina i SIDI ḥsen zi \add tewhibt n\add* tɣarṣt. \x ◘ \xo 21:3 \xt 1 Ṣm. 15:22; Izhd. 50:8, 14; Ica. 1:11, 16; Ḥuc. 6:6\x*
\m 
\v 4 Nnfaxet n tiṭṭawin d uř aɛeffar,
\m arber n iɛeffanen d ddenb.
\m 
\v 5 Ixemmimen n wenni imeḥḍen
\m \add ttawyen\add* mɣir ɣar ufeyyeḍ,
\m \add maca\add* marra wenni ittqeǧiqen aṭṭas
\m \add ittawi\add* ɣar řeḥwej waha. \x ◘ \xo 21:5 \xt Awřn. 10:4; 13:4\x*
\m 
\v 6 Asmuni n wagřa s yiřes issxarriqen,
\m \add ammu i teǧa\add* twarrit n nnefs
\m iɛeddun deɣya
\m n yinni yarezzun řmewt. \x ◘ \xo 21:6 \xt Awřn. 10:2, 4; 13:11\x*
\m 
\v 7 Lɛunf n iɛeffanen ittjarra i-ten,
\m maɣar ttagin ad ggen min iseggmen.
\m 
\v 8 Abrid n bu-umarwas ittefriɣ,
\m \add maca\add* amezdag ittegg min iǧan nican.
\b
\m 
\v 9 Iḥřa ad tzedɣed
\m deg ict teɣmart n tzeqqa, x \add tzeddiɣt\add*
\m ak-d ict n temɣart ittemcubbucen
\m deg ict n taddart tcarc. \x ◘ \xo 21:9 \xt Awřn. 21:19; 25:24; 27:15\x*
\m 
\v 10 Řeɛmar n iɛeffanen ittmeẓri di řɣar,
\m amqarreb nnes war ɣares ittif arḍa
\m di tiṭṭawin nnes.
\m 
\v 11 Mařa ittwaxeǧeṣ umestehziy,
\m iddakkwař wenni
\m war ɣares bu řefhamet d amiɣis,
\m mařa ssřemden amiɣis,
\m ikessi netta tussna. \x ◘ \xo 21:11 \xt Awřn. 19:25\x*
\m 
\v 12 \add Ijj n\add* Umsegged ittbeqqec mliḥ
\m taddart n uɛeffan,
\m iɣeṭṭeř iɛeffanen di arẓiyyet.
\m 
\v 13 Wenni ittbellaɛen amezzuɣ nnes
\m ɣar iɣuyyan n umezřuḍ,
\m uřa d netta ad isɣuy
\m \add maca\add* war xas dd-ttarran.
\m 
\v 14 Ṣṣedqet di tnuffra teṣřeḥḥu weɣḍab,
\m tarzeft \add immewcen\add* deg weḥsin \add n warruḍ\add*
\m \add teṣřeḥḥu\add* axeyyeq imɣaren. \x ◘ \xo 21:14 \xt Awřn. 17:8; 18:16\x*
\m 
\v 15 Aqa d řefraḥet i umsegged
\m maḥend ad igg min \add iǧan\add* nican,
\m \add maca\add* d aceřwaw i yinni itteggen řɣecc.
\m 
\v 16 Bnadem nni itteffɣen
\m zeg webrid n řeɛqeř,
\m ad yareyyeḥ deg wegraw
\m n řexyařat \add n imettan\add*.
\m 
\v 17 Wenni ittexsen afarraj, ad iḥwaj,
\m wenni ittexsen binu d zzect,
\m war iddikkwiř d bu wagřa.
\m 
\v 18 Aɛeffan d ddeyyet i imseggaden,
\m u aɣeddar ad dd-yiři
\m deg wemcan n yinni igguren nican. \x ◘ \xo 21:18 \xt Awřn. 11:8\x*
\b
\m 
\v 19 Iḥřa ad tzedɣed di temmurt ixřan,
\m x \add tazeddiɣt\add* ak-d ict n temɣart
\m ittemcubbucen u itteqqsen. \x ◘ \xo 21:19 \xt Awřn. 21:9; 25:24\x*
\m 
\v 20 Ijj n řkenz ittwaḥwajen d zzect
\m aqa aten di tzeddiɣt n imiɣisen,
\m \add maca\add* bnadem abuhaři iṣarreḍ i-t.
\m 
\v 21 Wenni yarezzun x tsegda
\m d tmexsiwt icewwaren,
\m ittaf tudart d tsegda d ccan.
\m 
\v 22 Amiɣis ittgeɛɛad
\m x tendint n ayt n bu-teɣřuḍt,
\m iɣeṭṭeř jjehd n ttiqet nsen di temmurt.
\m 
\v 23 Wenni iḥeṭṭan aqemmum d yiřes nnes,
\m iḥeṭṭa řeɛmar nnes zi řeḥṣarat. \x ◘ \xo 21:23 \xt Awřn. 18:21\x*
\m 
\v 24 Wenni d bu-nnfaxet iffuccḥen
\m ttřaɣan as ‘amestehziy’,
\m netta ittegg s nnfaxet břa řeqyas.
\m 
\v 25 Ccehwet n umeɛguz tneqq i-t,
\m maɣar ifassen nnes ugin ad xedmen.
\b
\s1 Awařen iwezznen n Suliman - tasɣart 1d
\m 
\v 26 Ass imun ittcehha timesřayin n ucehhi,
\m \add maca\add* amsegged ad iwc,
\m war ittɣimi ittᵉṭṭef \add di ca i yixef nnes\add*. \x ◘ \xo 21:26 \xt Izhd. 37:26\x*
\m 
\v 27 Taɣarṣt n uɛeffan d nnɛi,
\m mahu mařa nitni ad tt awyen
\m s unekkwi iɣeccen. \x ◘ \xo 21:27 \xt Awřn. 15:8; Ica. 1:13; Irm. 6:20; Ɛam. 5:21\x*
\m 
\v 28 Acehhad issxarriqen ad ittwahellek,
\m \add maca\add* aryaz nni ittesřan,
\m ad issiweř \add tidett\add* řebda. \x ◘ \xo 21:28 \xt Awřn. 19:5, 9\x*
\m 
\v 29 Aryaz aɛeffan issejhed ixef nnes
\m ak-d wudem nnes,
\m \add maca\add* wenni igguren nican
\m issemten ibriden nnes.
\b
\m 
\v 30 War teǧi tiɣit uřa d řefhamet,
\m war din iǧi bu ucawar qibač i SIDI.
\m 
\v 31 Ayis ad as ḥezzmen i wass n umenɣi,
\m \add maca\add* řeɣřeb ɣar SIDI.\x ◘ \xo 21:31 \xt Izhd. 33:17\x*
\b
\b
\c 22
\m 
\v 1 Isem aṣebḥan iḥřa
\m x waṭṭas n wagřa,
\m aḥinni iḥřa x nnuqart d wureɣ.\x ◘ \xo 22:1 \xt Amb. 7:1\x*
\m 
\v 2 Bu-wagřa d umezřuḍ ttemsagaren,
\m SIDI i-ten iggin marra. \x ◘ \xo 22:2 \xt Awřn. 29:13\x*
\b
\m 
\v 3 \add Bnadem\add* ifettnen ittwařa řɣar
\m uca ittnuffar,
\m \add maca\add* iḥafiyyen arennin gguren
\m uca ad ttwaɛaqaben. \x ◘ \xo 22:3 \xt Awřn. 27:12\x*
\m 
\v 4 Řmunet i uwaḍeɛ d tiggʷudi n SIDI,
\m d agřa d ccan d tudart.
\m 
\v 5 Isennanen d řefxux aqa aten
\m x webrid n wenni ifarɣen,
\m wenni iḥeṭṭan řeɛmar nnes,
\m ittɣima ɣar řaggʷaj nsen.
\m 
\v 6 Darreb aḥudri
\m ɛlaḥsab řeqyas n webrid nnes,
\m waxxa netta iwsar, war xas ittḥeyyid ca.
\m 
\v 7 Bu-wagřa ittṣeǧaḍ x imezřaḍ,
\m bu-umarwas d ismeɣ
\m n wenni d as yareṭṭřen.
\b
\m 
\v 8 Wenni izarrɛen řɣecc, ad imjar řeɣben,
\m aɛmud n uduqqez nnes \add n ufugem\add* ad ifna. \x ◘ \xo 22:8 \xt Ayub 4:8; Isaiah 14:5.; Psalm 125:3; Ḥuc. 10:13\x*
\m 
\v 9 Wenni ɣar iǧa řxezrat ṣebḥent,
\m ad ittwabarek,
\m minzi netta ittic i imezřaḍ
\m zeg weɣrum nnes. \x ◘ \xo 22:9 \xt 2 Kur. 9:6\x*
\m 
\v 10 Aẓẓeř x umestehziy, ad iffeɣ řhemm,
\m aqa ibedd umḥarwaḍ d řefḍiḥet.
\m 
\v 11 Wenni ittexsen řeṣfayet n wuř,
\m wenni ɣar iǧa iyencicen \add iccuren\add* s arḍa,
\m ajeǧid ad yiři d ameddukkeř nnes. \x ◘ \xo 22:11 \xt Izhd. 101:6\x*
\m 
\v 12 Tiṭṭawin n SIDI ḥeṭṭant x tussna,
\m \add maca\add* awařen n uɣeddar ad ten ibḍeř.
\m 
\v 13 Ameɛguz iqqar:
\m “Aqa din ijj n wayrad di barra!
\m Ad taɣ balak ad ttwanɣeɣ
\m di řwesṭ n wazzayen!” \x ◘ \xo 22:13 \xt Awřn. 26:13\x*
\m 
\v 14 Aqemmum n temɣarin tibarraniyyin
\m d ict n tesraft yuǧɣen,
\m wenni x iffugem SIDI, ad dayes iwḍa. \x ◘ \xo 22:14 \xt Awřn. 2:16; 5:3; 7:5; 23:27\x*
\m 
\v 15 Tubbuheřya \add tᵉttɣima\add* třesseq
\m deg wuř n uḥudri,
\m aɛmud n uwebbex ad tt issuffeɣ zzayes. \x ◘ \xo 22:15 \xt Awřn. 13:24; 19:18; 23:14; 29:15, 17\x*
\m 
\v 16 Wenni iḥeṣṣaren amarxu,
\m ad yarni di řemɣaret nnes,
\m wenni itticen i bu-wagřa,
\m ad iḥwaj \add waha\add*. \x ◘ \xo 22:16 \xt Awřn. 14:31; 17:5\x*
\b
\s1 Awařen iweznen n ayt n tiɣit -tasɣart 1
\m 
\v 17 Ewc amezzuɣ nnec,
\m uca seř ɣar wawařen n imiɣisen,
\m arr uř nnec ɣar tussna inu.
\m 
\v 18 Maɣar aqa mliḥ
\m mařa txemmřed ten di daxeř nnec,
\m \add mařa\add* ad ten tesswejded jmiɛ
\m x iyencicen nnec.
\m 
\v 19 Maḥend ad yiři utecři nnec x SIDI,
\m ad ac ten ssecneɣ řexxu, wah i cek.
\m 
\v 20 Ma zeɛma war d ac uriɣ
\m awařen ifarzen aṭṭas,
\m \add ccuren\add* s ccwar d tussna,
\m 
\v 21 ḥima ad ac ssecneɣ řemten
\m n wawařen n tidett,
\m maḥend tzemmared ad dd-tarred s řaman
\m x wenni cek dd-issekken.
\b
\m 
\v 22 War ttkeccaḍ amarxu
\m maɣar netta d amarxu,
\m war řebbez řmeskin ɣar tewwart, \x ◘ \xo 22:22 \xt Uf. 23:6; Ayub 31:13; Izhd. 82:3, 4; Zak. 7:10\x*
\m 
\v 23 maɣar SIDI ad asen yaɣ tasɣart nsen,
\m Netta ad ikecceḍ řeɛmar
\m n yinni i-ten ittkeccaḍen. \x ◘ \xo 22:23 \xt Uf. 22:22, 23; Izhd. 10:18\x*
\m 
\v 24 War ttemddukkuř
\m ak-d aryaz ittarrujduden,
\m war ttidef ɣar bab n wesɛar,
\m 
\v 25 maḥend cek war tᵉttnimid ca
\m ak-d imesraq nnes,
\m ad tegged řfex i řeɛmar nnec.
\m 
\v 26 War ttadef jar inni itticen awař
\m s tmewciwt n ifassen,
\m jar inni iǧan d aḍman i imarwusa. \x ◘ \xo 22:26 \xt Awřn. 6:1; 11:15\x*
\m 
\v 27 Mařa war ɣarek min zi ɣa txeǧṣed,
\m mayemmi ijebbed qama nnec
\m zi sadu nnec? \x ◘ \xo 22:27 \xt Awřn. 20:16\x*
\b
\m 
\v 28 War smuṭṭuy aymir n wecḥař uya,
\m wenni ggin řejdud nnec. \x ◘ \xo 22:28 \xt Aɛwd. 19:14; 27:17; Awřn. 23:10\x*
\b
\m 
\v 29 Ma teẓrid ijj n weryaz imeḥḍen
\m di řḥirfa nnes?
\m Ad t ssbedden zzat i wudem n ijeǧiden,
\m war iǧi ad ibedd zzat i wudem
\m n midden war di iǧi řaman.
\b
\b
\c 23
\m 
\v 1 Mařa teqqimed
\m ɣar ijj n řḥakem,
\m maḥend ad tecced \add akides\add*,
\m ḥḍa mliḥ min \add iǧan\add* zzatek.
\m 
\v 2 Egg ijj n řmus x yiři nnec,
\m mařa cek d ijj n bu-řemɣaret n uɛeddis.
\m 
\v 3 War ttegg meẓri di macca nnes icnan,
\m maɣar aqa-t d macca n tuxxuna.
\b
\m 
\v 4 War ssiḥiř ixef nnec
\m ḥima ad tdewřed d bu-wagřa,
\m sarxu deg nneyyet nnec.
\m 
\v 5 Mařa ṭṭawent tiṭṭawin ɣares,
\m aqa war din \add agřa\add* ɛad!
\m Maɣar ad igg afriwen i yixef nnes,
\m ad iḍwa ɣar ujenna am yijj n ugider.
\b
\m 
\v 6 War ttᵉtt aɣrum
\m n wenni di teǧa tiṭṭ taɛeffant,
\m war meẓri di macca nnes icnan.
\m 
\v 7 Maɣar am mammec \add t\add* ittxarraṣ,
\m ammu \add i t ittegg\add* netta.
\m Iqqar: “Ecc, teswed!”,
\m \add maca\add* uř nnes war akidek iǧi.
\m 
\v 8 Azeɛɛif i teccid, ad t-i-dd-tɛuqqed,
\m awařen iṣebḥen nnec tḍeyyɛed ten.
\b
\m 
\v 9 War siweř deg umezzuɣ n ijj n ubuhaři,
\m maɣar netta ad isseḥqar
\m awařen n weftan nnec. \x ◘ \xo 23:9 \xt Awřn. 9:8; Mt. 7:6\x*
\b
\m 
\v 10 War smuṭṭuy aymir n wecḥař uya,
\m war ttadef deg iyyaren n iyujiřen, \x ◘ \xo 23:10 \xt Awřn. 22:28\x*
\m 
\v 11 maɣar Amefdi nsen d ameqqran,
\m Netta ad dd-yaɣ tasɣart nsen zzayek.
\b
\m 
\v 12 Arr uř nnec ɣar uwebbex,
\m imezzuɣen nnec ɣar wawařen n tussna.
\m 
\v 13 War ttᵉṭṭef ttarbiyyet x uḥudri,
\m waxxa teccated t s weɛmud,
\m war ittmetti. \x ◘ \xo 23:13 \xt Awřn. 13:24; 19:18; 22:15; 29:15, 17\x*
\m 
\v 14 Cek ad t tewted s weɛmud,
\m u ad tessnejmed řeɛmar nnes zi řaxart.
\b
\m 
\v 15 Mmi inu, mařa uř nnec d amiɣis,
\m ad ifarḥ uřa d uř inu akides.
\m 
\v 16 Tiẓẓař inu ad negzent s řefraḥet,
\m mařa iyencicen nnec
\m ssiwřen min iǧan iseggden. \f ◼ \fr 23:16 \fk tiẓẓař\ft - niɣ ‘tigeẓřin’.\f*
\m 
\v 17 Ejj uř nnec war ittisim zeg imednab,
\m maca \add ejj i-t ad yarr azeǧif\add*
\m ɣar tiggʷudi n SIDI ass imun! \x ◘ \xo 23:17 \xt Izhd. 37:1; 73:3; Awřn. 24:1\x*
\m 
\v 18 Maɣar xenni aqa din tiwecca,
\m u řayas nnec war ittareẓẓi. \x ◘ \xo 23:18 \xt Awřn. 24:14\x*
\m 
\v 19 Seř-dd cek, a mmi, iři d amiɣis,
\m ndeh uř nnec ɣar webrid.
\m 
\v 20 War ttɣimi ɣar iskarjiyyen,
\m uřa ɣar inni ilehhfen deg weysum, \x ◘ \xo 23:20 \xt Ica. 5:22; Lk. 21:34; Rum. 13:13; Afa. 5:18\x*
\m 
\v 21 maɣar askarjiy d amelhuf
\m ad dewřen d imezřaḍ,
\m u anudem issyiriḍ deg iḥřucen.
\b
\m 
\v 22 Seř-dd cek ɣar babac
\m wenni cek i dd-ijjin,
\m u war sseḥqiri yemmac mařa tewsar. \x ◘ \xo 23:22 \xt Awřn. 1:8\x*
\m 
\v 23 Seɣ-dd tidett, war \add tt\add* teznuza ca,
\m \add ammu\add* uřa d tiɣit d uwebbex d řefhamet. \x ◘ \xo 23:23 \xt Awřn. 4:7\x*
\m 
\v 24 Babas n umsegged ad ifarḥ s waṭṭas,
\m wenni dd-ijjin ijj \add mmis\add* d amiɣis,
\m ad as ifarḥ. \x ◘ \xo 23:24 \xt Awřn. 10:1; 15:20\x*
\m 
\v 25 Ejj ad ifarḥ babac uřa d yemmac,
\m ejj tenni cek i dd-yurwen ad tfarḥ.
\b
\m 
\v 26 Ewc ayi uř nnec, a mmi,
\m ejj tiṭṭawin nnec ad afent
\m arḍa deg ibriden inu.
\m 
\v 27 Maɣar tamɣart farq-ccɣeř
\m d ict n tesraft yuǧɣen,
\m u tamɣart zi barra d ijj n řɛunṣar iḥsar. \x ◘ \xo 23:27 \xt Awřn. 22:14\x*
\m 
\v 28 Wah, nettat tᵉttḥama
\m am yijj n uxewwan,
\m nettat tarenni
\m deg iɣeddaren jar iwdan.
\b
\m 
\v 29 Wi i ɣar iǧa wecḍan?
\m Wi i ɣar iǧa zzeřḍ?
\m Wi i ɣar iǧa umcubbec?
\m Wi i ɣar iǧa ucetci?
\m Wi i ɣar iǧan iyezzimen břa ssibbet?
\m Wi i ɣar ǧant tiṭṭawin bbarewyent?
\m 
\v 30 Ɣar inni ittɣiman ɣar binu ař tameddit,
\m ɣar yinni dd-yusin
\m ḥima ad qqasen binu ixeǧḍen. \x ◘ \xo 23:30 \xt Ica. 5:11, 22\x*
\m 
\v 31 War xezzar ɣar binu, xmi ittezwiɣ,
\m ittřiqřiq di řkas u netta ihwen \add i tissit\add*.
\m 
\v 32 Ɣar uneggar ittɣima izeɛɛef
\m am yijj n ufiɣar,
\m ittrucca ssem am třefsa.
\m 
\v 33 Tiṭṭawin nnec ad twařant
\m timɣarin tibarraniyyin,
\m u uř nnec ad issiweř s uxarweḍ.
\m 
\v 34 Cek ad tiřid am yijjen
\m i itteṭṭṣen di řwesṭ n řebḥar,
\m am ijjen i itteṭṭṣen
\m di tqiccat n teḥnact \add n uɣarrabu\add*
\m 
\v 35 \add ad tinid:\add* “Wtin ayi, \add maca\add* war yezmeɣ,
\m dexmen ayi, \add maca\add* war uciɣ ak-d walu.
\m Meřmi i dd ɣa faqeɣ?
\m Necc ad arzuɣ ɛawed \add ɣar binu\add*!”
\b
\b
\c 24
\m 
\v 1 War ttasem.
\m zeg iryazen iɛeffanen,
\m war arezzu ca tmunet akidsen. \x ◘ \xo 24:1 \xt Izhd. 37:1; Awřn. 3:31; 23:17\x*
\m 
\v 2 Maɣar uř nsen itteqqer ɣar ureddeǧ,
\m awařen n iyencicen nsen
\m \add i dd-ittwayen ɣar\add* arẓiyyet. \x ◘ \xo 24:2 \xt Izhd. 10:7\x*
\m 
\v 3 Taddart tᵉttwabna s tiɣit,
\m tᵉttwassemten s řefhamet,
\m 
\v 4 s tussna ttwaɛemmaren
\m ixxamen n daxeř,
\m s marra agřa iɣřan d wagřa iřiqqen.
\m 
\v 5 Aryaz amiɣis ijhed,
\m aryaz n tussna yarenni di jjehd nnes, \x ◘ \xo 24:5 \xt Awřn. 21:22\x*
\m 
\v 6 maɣar ittxeṣṣa
\m ad ittwandeh umenɣi s udebbar,
\m u s řemɣaret n umcawar ad yiři usenjem. \x ◘ \xo 24:6 \xt Awřn. 11:14; 15:22; 20:18\x*
\m 
\v 7 Tiɣit tuɛřa x ubuhaři,
\m netta war yarezzem aqemmun nnes
\m di tewwart \add n tendint\add*. \x ◘ \xo 24:7 \xt Awřn. 14:6\x*
\b
\m 
\v 8 Wenni ittxarriṣen di řɣar,
\m ad as řaɣan arrays n bu-teḥřaymect.
\m 
\v 9 Řemwayař n uxarreṣ n ubuhaři d ddenb,
\m u amestehziy d nnɛi i bnadem.
\m 
\v 10 Mařa tarxud zeg ixef nnec
\m deg wass n řeḥṣaret,
\m ammu uřa d jjhed nnec ad tᵉttwaḥṣar.
\m 
\v 11 Senjem inni ittwaṭṭfen
\m maḥend ad ttwanɣen,
\m inni ten ittawyen
\m ɣar mani ten i ɣa nɣen,
\m sbedd i-ten! \x ◘ \xo 24:11 \xt Izhd. 82:4\x*
\m 
\v 12 Mařa cek ad tinid:
\m “Xzar, aqa war nessin walu x man aya!”,
\m ma wenni iwezznen uřawen,
\m war t issargib?
\m Wenni iḥeṭṭan řeɛmar nnec, issen i-t!
\m Netta ad ixeǧeṣ bnadem
\m ɛlaḥsab řxedmet nnes. \x ◘ \xo 24:12 \xt Ayub 34:11; Izhd. 62:13; Irm. 32:19; Rum. 2:6; Asa. 22:12\x*
\b
\m 
\v 13 Ecc tamment, a mmi,
\m maɣar nettat teṣbeḥ,
\m tamment n teɣrast
\m aqa d tmiẓidt i waneɣ nnec.
\m 
\v 14 Ammu i teǧa tussna n tiɣit
\m i řeɛmar nnec.
\m Mařa tufid tt, \add xenni\add* teǧa tiwecca,
\m řayas nnec war ittwaqeṭṭeɛ ca. \x ◘ \xo 24:14 \xt Izhd. 19:11; 119:103; Awřn. 23:18\x*
\m 
\v 15 \add A\add* aɛeffan, war tᵉttḥama
\m x tzeddiɣt n umsegged,
\m war heddem amcan n wareyyeḥ nnes!
\m 
\v 16 Maɣar amsegged
\m ad iwḍa sebɛa n twařawin,
\m ad dd-ikkar ɛawed,
\m \add maca\add* iɛeffanen ad nnqarḍen s řɣar. \x ◘ \xo 24:16 \xt Ayub 5:19; Izhd. 34:20; Ɛam. 5:2; 8:14\x*
\m 
\v 17 War farreḥ i \add u\add*weṭṭu n řeɛdu nnec,
\m mařa netta inqarḍ,
\m ejj uř nnec war ifarreḥ, \x ◘ \xo 24:17 \xt Ayub 31:29; Awřn. 17:5\x*
\m 
\v 18 maḥend SIDI war t iẓarr
\m u man aya ad yiři d řɛib di tiṭṭawin nnes,
\m \add ařami\add* Netta ad xas issḥeyyed aɣḍab nnes.
\m 
\v 19 War ttxeyyiq aṭṭas
\m x wenni itteggen řɣar,
\m war ttasem zeg iɛeffanen, \x ◘ \xo 24:19 \xt Izhd. 37:1; 73:3; Awřn. 3:31; 23:17; 24:1\x*
\m 
\v 20 maɣar aqa wenni itteggen řɣar
\m war ɣares tiwecca,
\m řefnar n iɛeffanen ad ittwassexsi. \x ◘ \xo 24:20 \xt Ayub 18:5, 6; Awřn. 13:9; 20:20\x*
\m 
\v 21 \add A\add* mmi, ggʷed SIDI d ujeǧid,
\m war ttxeǧeḍ ca ixef nnec
\m ak-d yinni ixsen ad nqeřben \add kuřci\add*,
\m 
\v 22 maɣar ad dd-yas uḍeyyeɛ nsen
\m deg ijj n umur,
\m wi issnen aneggaru aɛeffan
\m n iseggʷusa nsen?
\b
\s1 Awařen iweznen n ayt n tiɣit -tasɣart 2
\m 
\v 23 \bd Uřa d yina d \bdit awařen iweznen\bdit* n imiɣisen.\bd*
\m Asfarz n wudmawen di ddeɛwet
\m war iǧi ca mliḥ. \x ◘ \xo 24:23 \xt Uf. 23:3, 6; Lawi 19:15; Aɛwd. 1:17; 16:19; Awřn. 18:5; 28:21; Yḥ. 7:24; Yaɛ. 2:1\x*
\m 
\v 24 Wenni iqqaren i uɛeffan: “Cek d amsegged!”,
\m wanita ad t neɛřen řegnus,
\m ad t carhen ccuɛub. \x ◘ \xo 24:24 \xt Awřn. 17:15; Ica. 5:23\x*
\m 
\v 25 \add Maca\add* inni ten i ɣa iḥakmen,
\m ad iřin mliḥ,
\m lbaraka s \add marra\add* řxar ad ɣarsen dd-tas.
\m 
\v 26 \add Am ijjen\add* wenni issudumen iyencicen,
\m \add ammu i yeǧa\add* wenni dd-ittarran
\m s wawařen iseggmen.
\m 
\v 27 Sewjed řxedmet nnec barra,
\m kemmeř i-tt i yixef nnec deg iyyar,
\m uca bna taddart nnec awarni man aya!
\m 
\v 28 War ttiři d acehhad břa ssibbet
\m x jjar nnec.
\m Ma \add iɛeddeř\add* ad tɣarred s iyencicen nnec?
\m 
\v 29 War qqar: “Am mammec i d ayi igga,
\m ammu i dd-as ɣa ggeɣ uřa d necc!”,
\m \add maɣar\add* Necc ad dd-xeřfeɣ zi kuř ijjen
\m ɛlaḥsab řxedmet nnes. \x ◘ \xo 24:29 \xt Rum. 12:17, 19\x*
\b
\m 
\v 30 Necc kkeɣ x yeyyar n ijj n umeɛguz,
\m x umarjeɛ n uḍiř n ijj n bnadem
\m s wuř nnes war imtinen.
\m 
\v 31 Xzar, tgeɛɛed-dd xas marra teyzit,
\m tedřa tzeggʷart udem n temmurt nnes,
\m aqa řḥiḍ nnes n weẓru ittwahdem.
\m 
\v 32 \add Řami\add* tt ẓriɣ, ksiɣ tt ɣar wuř inu,
\m ẓriɣ tt uca ksiɣ tt am yijj n uwebbex.
\m 
\v 33 “Ejj ayi ad ṭṭṣeɣ cwayt drust,
\m cwayt drust n unudem,
\m cwayt drust n ubuzzeř s ifassen ḍefṣen, \x ◘ \xo 24:33 \xt Awřn. 6:10, 11\x*
\m 
\v 34 \add dinni\add* dd ɣa yas zzeřḍ nnec,
\m uřa d řeɣben nnec
\m am yijj n weryaz s řesnaḥ.” \x ◘ \xo 24:34 \xt Awřn. 6:11\x*
\b
\b
\c 25
\s1 Awařen iweznen n Suliman - tasɣart 2
\m 
\v 1 \bd Uřa d ina d awařen iweznen n Suliman\bd*
\m \bd nni ittɛawaden urin ten iryazen n Ḥizqiya,\bd*
\m \bd ajeǧid n Yahuda.\bd*
\m 
\v 2 Aqa d ccan n AREBBI
\m maḥend ad issar ict n tmesřact,
\m \add maca\add* ccan n ijeǧiden
\m d abeqqec deg ict n tmesřact. \x ◘ \xo 25:2 \xt Rum. 11:33\x*
\m 
\v 3 Řuɛřa n ujenna d řaǧaɣ n temmurt,
\m d wuř n ijeǧiden war ǧin i ubeqqec.
\m 
\v 4 Kkes kuffu zi nnuqart,
\m ad dd-teffeɣ ict n řqecɛet i wemziř.
\m 
\v 5 Sbeɛɛed iɛeffanen
\m zi zzat n wudem n ujeǧid,
\m \add xenni\add* ad ittwassemten
\m řɛarc nnes s tsegda. \x ◘ \xo 25:5 \xt Awřn. 20:8, 28\x*
\m 
\v 6 War tfeyyec zzat i wudem n ujeǧid,
\m war ttbeddi mani ttbeddan imeqqranen.
\m 
\v 7 Maɣar iḥřa ad ac inin: “Geɛɛed-dd da!”,
\m uřa ma ad cek ssehwan
\m zzat i wudem n ijj n umcenneɛ
\m nni ẓrint tiṭṭawin nnec. \x ◘ \xo 25:7 \xt Lk. 14:7-11\x*
\b
\m 
\v 8 War ttqeǧiq ad tedɛid,
\m maɣar min texsed ad tegged
\m ɣar uneggar nnes,
\m mařa jjar nnec ad cek issefḍeḥ? \x ◘ \xo 25:8 \xt Awřn. 18:17\x*
\m 
\v 9 Carreɛ ak-d jjar nnec,
\m \add maca\add* war ssuffuɣ ssirr n wenneɣni,
\m 
\v 10 ḥima wenni d as ittesřan
\m war cek issḥeccem ca,
\m maɣar \add řexdenni\add* war izemmar
\m ad tᵉttwassbeɛɛed řefḍiḥet nnec \add ɛad\add*.
\b
\m 
\v 11 \add Am\add* tteffaḥin n wureɣ
\m x ṭṭbasa n nnuqart,
\m \add ammu ǧan\add* wawařen ssiwřen ten
\m s řeqyas nnes.
\m 
\v 12 \add Am\add* ict n txadent n wureɣ
\m u \add am\add* ict n tseddect n wureɣ iɣřan qaɛ,
\m \add ammu i iǧa\add* uwebbex amiɣis
\m ɣar umezzuɣ ittesřan.
\m 
\v 13 Am wedfeř asemmaḍ
\m deg ijj n wass n tmeyra,
\m \add ammu i\add* iǧa umsexxar dayes řaman
\m i wenni t issekkan,
\m \add maɣar\add* issfaqa řeɛmar n bab nnes. \x ◘ \xo 25:13 \xt Awřn. 13:17\x*
\m 
\v 14 \add Am\add* iseynuten d usemmiḍ břa anẓar,
\m \add ammu\add* aryaz nni ittɛeffar
\m deg ict n terzeft war isekkwin.
\b
\m 
\v 15 S ttasiɛ n řxaḍar ittwasseqneɛ řḥakem,
\m ijj n yiřes amiẓid ittareẓẓa iɣsan. \x ◘ \xo 25:15 \xt Awřn. 15:1; 16:14\x*
\m 
\v 16 \add Mařa\add* tufid tamment,
\m ecc min teḥwajed waha,
\m niɣ ad taff teccid ktar zi min teḥwajed,
\m u balak ad tt-i-dd tɛuqqed.
\m 
\v 17 War ssrusa aḍar nnec
\m aṭṭas di taddart n jjar nnec,
\m niɣ ad cek ijjiwen u ad cek iɛiff.
\b
\m 
\v 18 \add Am\add* wefḍis d ssif d fřitca iqeḍɛen,
\m \add ammu i iǧa\add* weryaz nni icehhden
\m s ẓur x jjar nnes. \x ◘ \xo 25:18 \xt Izhd. 11:2; 57:5; 59:8; 120:4; Awřn. 12:18\x*
\m 
\v 19 \add Am\add* tiɣmest yarẓen
\m u \add am\add* uḍar inqraḍen,
\m \add ammu\add* i iǧa utecři
\m x wenni war di iǧi ttiqet
\m deg wass n řeḥṣaret.
\m 
\v 20 \add Am\add* wenni ittekksen apartessu nnes
\m deg ijj n wass ismeḍ
\m u \add am\add* řxeǧ i tteggen x niṭrun,
\m \add ammu i iǧa\add* wenni ittɣennajen izřan
\m zzat i yijjen s wuř icḍen. \x ◘ \xo 25:20 \xt Rum. 12:15\x*
\m 
\v 21 Mařa iǧuẓ wenni cek icarrhen,
\m \add xenni\add* ewc as aɣrum,
\m mařa iffud, ewc as ad isu, \x ◘ \xo 25:21 \xt Uf. 23:4, 5; Rum. 12:20\x*
\m 
\v 22 maɣar ammu i tyarrwed
\m řefḥem \add itteḥduduqen\add* x uzeǧif nnes,
\m u SIDI ad cek ixeǧeṣ.
\b
\m 
\v 23 Asemmiḍ zi ccamal ittawi-dd anẓar,
\m iřes aɣeddar \add ittawi-dd\add* udmawen ixeyyqen.
\m 
\v 24 Iḥřa ad tzedɣed
\m deg ict teɣmart n tzeqqa,
\m uřa x \add tazeddiɣt\add*
\m ak-d ict n temɣart ittemcubbucen
\m deg ict n taddart tcarc. \x ◘ \xo 25:24 \xt Awřn. 21:9, 19\x*
\m 
\v 25 \add Am\add* waman iṣemmaḍen
\m i yijj n řeɛmar yuḥeř,
\m \add ammu i iǧa\add* řexbar aṣebḥan
\m zeg ict n temmurt tiggʷej.
\m 
\v 26 \add Am\add* ijj n řɛunṣar ittwafesden
\m u \add am\add* ijj n wanu ɣeccen t,
\m \add ammu i iǧa\add* umsegged ittzeɛziɛen
\m zzat i wudem n iɛeffanen.
\m 
\v 27 Macca n waṭṭas n tamment
\m war iǧi ca mliḥ,
\m \add maca\add* tarezzut
\m di tmesřayin yewɛaren d ccan.
\m 
\v 28 \add Am\add* ict n tendint ihedmen břa řḥiḍ,
\m \add ammu i iǧa\add* ijj n weryaz
\m war itteṭṭef buḥbeř nnes. \x ◘ \xo 25:28 \xt Awřn. 16:32\x*
\b
\b
\c 26
\m 
\v 1 \add Am\add* wedfeř deg unebdu
\m u \add am\add* wenẓar di tmeyra,
\m \add ammu\add* war dd-ittis ccan ak-d ubuhaři.
\m 
\v 2 Am ẓẓawec ittfarfaren,
\m am tfařǧest iṭṭawen \add ssa d ssa\add*,
\m ammu i tegga ict n nneɛřet břa ssibbet,
\m nettat war třeqqef. \f ◼ \fr 26:2 \fk ẓẓawec\ft - niɣ ‘afrux’.\f*
\m 
\v 3 Arekkuḍ i uyis, sřimet i weɣyuř,
\m u aɛmud i weɛrur n ibuhařiyyen. \x ◘ \xo 26:3 \xt Izhd. 32:9, 10; Awřn. 10:13\x*
\m 
\v 4 War dd-ttarri x ubuhaři
\m anect tubbuheřya nnes,
\m maḥend uřa d cek
\m war dayes tarekkwesed.
\m 
\v 5 Arr-dd x ubuhaři
\m ɛlaḥsab tubbuheřya nnes,
\m maḥend war ittɣiř netta d amiɣis
\m di tiṭṭawin nnes.
\m 
\v 6 \add Am\add* wenni ittqessen iḍaren n yixef nnes
\m u \add am\add* wenni isessen lɛunf,
\m \add ammu i yeǧa\add* wenni issekkan tibratin
\m s ufus n ijj n ubuhaři.
\m 
\v 7 Timessaḍin n uneɛḍab arehfent,
\m \add ammu i yeǧa\add* uřa d awař iweznen
\m deg uqemmum n ibuhařiyyen.
\m 
\v 8 Am wenni ittceddan
\m aẓru iɣřan deg iǧiy,
\m ammu i iǧa wenni itteggen ccan i ubuhaři.
\m 
\v 9 \add Am\add* ict n tiwent n tzeggʷart
\m dd-iggeɛɛden deg ufus n uskarji,
\m \add ammu i iǧa\add* lmatal
\m deg uqemmum n ibuhařiyyen.
\m 
\v 10 Aṭṭas izemmar ad dd-issuffeɣ
\m marra \add zeg yixef nnes\add*,
\m \add maca\add* řmunet n ubuhaři
\m d wenni t ɣa icran, ad xsaren.
\m 
\v 11 Am ijj n weqzin iɛeqben ɣar min iɛuqq,
\m \add ammu i\add* ittɛawad ijj n ubuhaři
\m tubbuheřya nnes. \x ◘ \xo 26:11 \xt 2 Bṭ. 2:22\x*
\m 
\v 12 Ma teẓriḍ \add ɛemmarṣ\add* ijj n weryaz
\m i itteggen ixef nnes d amiɣis?
\m Aqa din řayas aṭṭas i yijj n ubuhaři
\m uřa xas. \x ◘ \xo 26:12 \xt Awřn. 29:20\x*
\b
\m 
\v 13 Ameɛguz iqqar:
\m “\add Aqa din\add* ijj n wayrad izehharen
\m deg webrid,
\m ijj n weyrad \add yuyur\add* deg wazzayen!” \x ◘ \xo 26:13 \xt Awřn. 22:13\x*
\m 
\v 14 \add Am\add* tewwart tᵉttunnuḍ i teɣmart nnes,
\m \add ammu i ittunuḍ\add* uřa d ameɛguz
\m di qama nnes.
\m 
\v 15 Ameɛguz issnuffar afus nnes di ṭṭebṣi,
\m aqa netta yarxu maḥend ad t issiweḍ
\m ɣar uqemmum nnes. \f ◼ \fr 26:15 \fk aḥsin\ft - niɣ ‘abeḥrur’.\f*  \x ◘ \xo 26:15 \xt Awřn. 19:24\x*
\m 
\v 16 Ameɛguz ittwařa ixef nnes d amiɣis,
\m zi sebɛa \add iryazen\add* nni \add izemmaren\add*
\m ad dd-arren s řefhamet.
\b
\m 
\v 17 \add Am\add* wenni ittcebbaren
\m deg imezzuɣen n weqzin,
\m \add ammu i yeǧa\add* wenni ittadfen
\m deg umcubbec nni war iǧi nnes.
\m 
\v 18 Am ijj n umejnun
\m nni iccaten iṣefḍawen
\m d fřitcat d \add ssem\add* ineqqen,
\m 
\v 19 ammu \add i iǧa\add* weryaz nni icemten jjar nnes,
\m uca iqqar: “Aqa ttqessareɣ waha, niɣ lla!”
\b
\m 
\v 20 Mařa war iǧi ukeccuḍ, ad texsi tmessi,
\m u mařa war \add din\add* iǧi uxbarji,
\m yaressa umcubbec. \x ◘ \xo 26:20 \xt Awřn. 22:10\x*
\m 
\v 21 \add Am iǧa\add* řefḥem i řefḥem itteḥduduqen
\m d ukeccuḍ i tmessi,
\m \add ammu i\add* yeǧa ijj n weryaz ittemcubbucen,
\m maḥend ad dd-isnekkar amenɣi. \x ◘ \xo 26:21 \xt Awřn. 15:18; 29:22\x*
\m 
\v 22 Awařen n uxbarjiy am ḥalawit,
\m tinni hekkwant
\m deg ixxamen n daxeř n uɛeddis. \x ◘ \xo 26:22 \xt Awřn. 18:8\x*
\m 
\v 23 \add Am\add* kuffu n nnuqart x uceǧiq n třaxt,
\m \add ammu i ǧan\add* iyencicen imiziḍen
\m n yijjen s wuř d aɛeffan.
\m 
\v 24 Wenni di iǧa wecrah,
\m issnuffara \add i-t\add* s yiřes nnes
\m \add maca\add* deg wuř nnes ittxarreṣ di řɣecc.
\m 
\v 25 Mařa netta ittḥeccem s tmijja nnes,
\m war t ttiqqi ca,
\m maɣar sebɛa n nnɛawat
\m \add aqa din\add* deg wuř nnes.
\m 
\v 26 Uřa mařa iřeḥḥef wecrah nnes
\m deg wecmat,
\m tuɛeffna nnes ad tᵉttwaɛarra
\m deg wegraw \add n řgens\add*.
\m 
\v 27 Wenni iɣzin \add ijj n weḥfur n\add* turṣuḍi,
\m ad dayes iwḍa simant nnes
\m u taṣḍart ad dd-tedweř
\m ɣar wenni tt isseqnunnuyen. \x ◘ \xo 26:27 \xt Izhd. 7:16; 9:16; 10:2; 57:7; Amb. 10:8\x*
\m 
\v 28 Iřes issxarriqen
\m icarreh wenni ittareddǧen,
\m ijj n uqemmum ařeqqaɣ \add s teḥraymect\add*
\m ittawi-dd řxarbet.
\b
\b
\c 27
\m 
\v 1 War ttfeyyec zeg wass n tiwecca,
\m maɣar war tessined ca
\m min dd ɣa yawi wass. \x ◘ \xo 27:1 \xt Yaɛ. 4:13, 14\x*
\m 
\v 2 Ejj ijj n ubarrani ad cek icenneɛ,
\m war iǧi aqemmum nnec,
\m ijj n midden, war iǧi iyencicen nnec.
\m 
\v 3 Aẓru idqeř, ijdi iwezzen,
\m \add maca\add* afugem n ubuhaři
\m idqeř xasen s tnayen idsen.
\m 
\v 4 Asɛar d uduqqez n weɣḍab
\m aqa aten qesḥen,
\m \add maca\add* man wen izemmaren
\m ad iqqim ibedd ɣar tusmi?
\m 
\v 5 Teḥřa ttarbiyyet s bṭayṭay
\m x tayri innuffaren.
\m 
\v 6 Iyezzimen n wenni \add cek\add* ittexsen
\m aqa d \add řeɛřamat n\add* řaman,
\m \add maca\add* isudimen n yinni \add cek\add* icarrhen
\m aqa d aṭṭas.
\b
\m 
\v 7 Wenni ijjiwnen, iɛejjen
\m x tamment n teɣraṣt,
\m \add maca\add* i wenni iǧuẓen
\m marra min yarezgen d amiẓid. \f ◼ \fr 27:7 \fk Wenni ... wenni\ft - s Tɛibranit ‘řeɛmar’.\f*
\m 
\v 8 Am ijj n wejḍiḍ iṭṭaw,
\m \add iggʷed\add* zi řɛucc nnes,
\m ammu \add i iǧa\add* weryaz nni i ɣa iṭellɛen
\m barra x wemcan nnes.
\m 
\v 9 Zzect d řebxur ssfarraḥen uř,
\m \add ammu ɛawed\add* tamseɛɛaft icnan
\m n ijj n umeddukkeř zi ccwar n wuř.
\m 
\v 10 War semmeḥ deg umeddukkeř nnec,
\m uřa deg umeddukkeř n babac,
\m war ttidef ca ɣar taddart n umac
\m deg wass n arẓiyyet nnec.
\m Iḥřa ijj n wajjar yudes
\m x ijj n tewmat yiggʷej. \x ◘ \xo 27:10 \xt Awřn. 17:17; 18:24\x*
\b
\m 
\v 11 Iři d amiɣis, \add a\add* mmi, u sfarḥ uř inu,
\m maḥend zemmareɣ ad dd-arreɣ
\m x wenni d ayi ɣa isseḥqaren.
\m 
\v 12 Wenni ifettnen ittwařa řɣar
\m uca issnuffara ixef nnes,
\m \add maca\add* iḥafiyyen arennin gguren
\m uca ittxeṣṣa ad ttwaɛaqaben. \x ◘ \xo 27:12 \xt Awřn. 22:3\x*
\m 
\v 13 Ksi arruḍ nnes,
\m maɣar iddakkwař d aḍman
\m i yijj n ubarrani,
\m ksi t d ddiyyet
\m i yict n temɣart zi barra. \x ◘ \xo 27:13 \xt Awřn. 6:1, 2; 11:15; 17:18; 20:16\x*
\m 
\v 14 Wenni ittbarken ameddukkeř nnes zic
\m ɣar tuffut s tmijja ijehden,
\m aqa man aya ad as ittwaḥseb d nneɛřet.
\m 
\v 15 \add Amecnaw\add* tuddimt war ittbeddin
\m deg wass n wenẓar ijehden,
\m \add ammu i teǧa\add* temɣart ittemcubbucen. \x ◘ \xo 27:15 \xt Awřn. 19:13\x*
\m 
\v 16 Wenni ittexsen ad as ibelleɛ,
\m \add aqa-t am wenni\add* ittexsen
\m ad iqala i usemmiḍ,
\m u afus nnes afusi
\m ad iṭṭef zzect \add itteḥruǧuḍen\add*.
\m 
\v 17 \add Am\add* wenni isseqḍaɛen uzzař s wuzzař,
\m \add ammu i\add* isseqḍaɛ weryaz
\m timegga n wenni t yudsen.
\m 
\v 18 Wenni iḥeṭṭan x ijj n wartu,
\m ad icc řɣiǧet nnes,
\m wenni iḥeṭṭan bab nnes,
\m ad ittwacenneɛ.
\m 
\v 19 Am dd-ittban uɣembub deg uɣembub
\m deg waman,
\m ammu dd-ittban wuř n bnadem
\m x bnadem ɛawed.
\m 
\v 20 \add Am\add* řaxart d ushellek war ttyiwinen,
\m \add ammu\add* uřa d tiṭṭawin n iwdan
\m war ttiwḍent ad jjiwnent. \x ◘ \xo 27:20 \xt Amb. 1:8\x*
\m 
\v 21 Aṭenjir n usefsi i nnuqart
\m d ufarran i wureɣ,
\m \add ammu i iǧa uřa d\add* aryaz
\m am mammec t ttmeddaḥen. \x ◘ \xo 27:21 \xt Awřn. 17:3\x*
\m 
\v 22 Mařa teddzed abuhaři s wezduz
\m di řmehraz jar řḥebb n imendi,
\m tubbuheřya nnes war xas tḥeyyid.
\b
\m 
\v 23 Ḥḍa maḥend ad tessned
\m mammec dd-ittban wuǧi nnec,
\m wejjeh uř nnec ɣar tḥimriwin.
\m 
\v 24 Maɣar řeksibet war tᵉttɣimi i řebda,
\m niɣ ma ad iqqim ttaj \add n weɛzař\add*
\m zi jjiř ař jjiř nneɣni?
\m 
\v 25 Mařa iruḥ arbiɛ
\m uca iban-dd uɣemmuy \add aziza\add*,
\m ittwaḥtec afsu x idurar,
\m 
\v 26 \add xenni ad iřin\add* izmaren i warruḍ nnec,
\m uřa d iɣayḍen i tmesɣiwt n yijj n yeyyar. \x ◘ \xo 27:26 \xt 1 Tim. 6:8\x*
\m 
\v 27 uca ad ɣarek yiři min teḥwajed
\m n uɣi n tɣayṭin i macca nnec,
\m \add ad yiři d\add* macca i taddart nnec,
\m uřa d řeɛweč i temsexxarin nnec timeẓyanin.
\b
\b
\c 28
\m 
\v 1 Iɛeffanen ttrakkwařen
\m waxxa war \add dinni\add*
\m wi \add i-ten\add* iḍaffaren,
\m \add maca\add* imseggaden daysen taryast
\m am n ijj n wayrad. \x ◘ \xo 28:1 \xt Lawi 26:36; Aɛwd. 28:28; Ica. 57:21\x*
\m 
\v 2 Zi ssibbet n uɛeddi n temmurt
\m \add aqa din\add* aṭṭas n řḥukkam nnes,
\m \add maca\add* s ijj n bnadem s řeɛqeř d tussna,
\m ad teqqim ṣṣulṭa \add tbedd\add*
\m i yijj n řweqt d azirar.
\m 
\v 3 Aryaz amezřuḍ nni ittzeyyaren x imarxa,
\m \add am\add* wenẓar ittawyen marra,
\m \add ař\add* war ittɣimi ɛad weɣrum.
\m 
\v 4 Inni ittejjan Ccariɛa
\m ssemɣaran aɛeffan,
\m \add maca\add* inni iḥeṭṭan Ccariɛa
\m ttmenɣan akidsen.
\m 
\v 5 Iryazen iɛeffanen war fehhmen řḥeqq,
\m \add maca\add* inni yarezzun SIDI,
\m fehhmen i kuřci.
\m 
\v 6 Iḥřa umezřuḍ nni igguren iṣfa,
\m x wenni igguren ifarɣ di tnayen n ibriden,
\m \add waxxa\add* netta ɣares agřa. \x ◘ \xo 28:6 \xt Awřn. 19:1\x*
\m 
\v 7 Wenni iḥeṭṭan Ccariɛa,
\m d ijj n mmis ifehhem,
\m \add maca\add* wenni d ameddukkeř n imelhaf,
\m yarra babas ad iseḍḥa. \x ◘ \xo 28:7 \xt Awřn. 29:3\x*
\m 
\v 8 Wenni issemɣaran agřa nnes
\m s arriba d warbeḥ,
\m issmuna aya i wenni ittḥinnan
\m x imezřaḍ. \x ◘ \xo 28:8 \xt Lawi 25:35-37\x*
\m 
\v 9 Wenni issḥeyyaden amezzuɣ nnes
\m zeg useǧi n Ccariɛa,
\m \add ɛad\add* taẓaǧit nnes d nnɛi.
\m 
\v 10 Wenni ittarran inni igguren nican
\m ad weddaren x ijj n webrid aɛeffan,
\m netta simant nnes
\m ad iwḍa di tesraft nnes,
\m \add maca\add* inni i di teǧa řekmaret
\m ad warten min iṣebḥen. \x ◘ \xo 28:10 \xt Awřn. 26:27\x*
\m 
\v 11 Bu-wagřa ittegg ixef nnes d amiɣis
\m di tiṭṭawin nnes,
\m \add maca\add* ijj n umezřuḍ
\m nni di teǧa řefhamet,
\m yargeb xas.
\b
\m 
\v 12 Mařa ad sřiwřiwen imseggaden
\m s řefraḥet,
\m aqa din aɛuǧi ameqqran,
\m \add maca\add* mařa kkaren-dd iɛeffanen,
\m ad issnuffar bnadem \add ixef nnes\add*. \x ◘ \xo 28:12 \xt Awřn. 11:10, 11\x*
\m 
\v 13 Wenni iddařen ixeṭṭan nnes,
\m war ittefřiḥ,
\m \add maca\add* wenni zzaysen ineɛɛmen
\m u ittḥeyyad xasen, ad yaf arreḥmet. \x ◘ \xo 28:13 \xt Izhd. 32:3, 5; 1 Yḥ. 1:9, 10\x*
\m 
\v 14 Sseɛd n bnadem
\m nni ittweqqaren břa abeddi,
\m \add maca\add* wenni isseqsaḥen uř nnes,
\m ad iwḍa di řɣar.
\m 
\v 15 \add Am\add* ijj n weyrad ittarrujduden,
\m \add am\add* ijj n ddub \add ittřaẓan\add*
\m ittazzřen zi ssa ɣar diha,
\m \add ammu i iǧa\add* ijj n řḥakem aɛeffan
\m x ijj n řgens amezřuḍ.
\m 
\v 16 Řḥakem nni břa řefhamet,
\m \add aqa-t d řḥakem x\add* waṭṭas n werbaḥ
\m s ubeɛɛej,
\m \add maca\add* wenni icarrhen arbeḥ,
\m ad izzuggart ussan nnes.
\m 
\v 17 Ijj n bnadem ittwaḥṣaren
\m umi issizzeř idammen n ca n yijjen,
\m ad yarweř ɣar weḥfur n wenḍeř
\m \add n yixef nnes\add*.
\m War ttejji ḥed ad t issbedd!
\m 
\v 18 Wenni igguren \add abrid nnes\add* di řeṣfayet,
\m ad injem,
\m \add maca\add* wenni igguren
\m ifarɣ di tnayen n ibriden,
\m war ittɛeṭṭar ad iwḍa.
\m 
\v 19 Wenni icarrzen tammurt nnes,
\m ad ijjawen s weɣrum,
\m \add maca\add* wenni iḍeffaren aryaz ixwan,
\m ad ijjawen zzeřḍ.
\m 
\v 20 Aryaz i di iǧa řaman aṭṭas
\m \add ad iksi\add* aṭṭas n lbarakat,
\m \add maca\add* wenni ittqeǧiqen ḥima ad igg agřa,
\m war ittwiḥsib d amezdag. \x ◘ \xo 28:20 \xt Awřn. 13:11; 20:21; 23:4\x*
\b
\m 
\v 21 Asfarz n wudmawen war icni ca,
\m \add maɣar\add* i yijj n uřeqquz n weɣrum
\m \add izemmar\add* ca n weryaz ad ixḍa. \x ◘ \xo 28:21 \xt Awřn. 18:5; 24:23\x*
\m 
\v 22 Aryaz s tiṭṭ taɛeffant
\m ittqeǧiq ɣar wagřa,
\m \add maca\add* netta war issin
\m aqa řexses ad ɣares dd-yas.
\m 
\v 23 Wenni ittɛaqaben ijj n bnadem,
\m aqa ɣar uneggar ad yaf arḍa ktar
\m x wenni isscanan taẓyuḍi s yiřes nnes.
\m 
\v 24 Wenni ittkeccaḍen babas niɣ yemmas
\m uca iqqar: “War iǧi d ddenb!”,
\m aqa-t d acric n ijj n bu-řaxart.
\m 
\v 25 Wenni di iǧa nnfaxet,
\m issekkara-dd amcubbec,
\m \add maca\add* wenni ittcařan x SIDI,
\m ad idweř labas xas. \x ◘ \xo 28:25 \xt Awřn. 13:10; 15:18; 29:22\x*
\m 
\v 26 Wenni ittcařan x wuř nnes,
\m aqa d abuhaři,
\m \add maca\add* wenni igguren
\m \add abrid nnes\add* di tiɣit,
\m ad injem.
\m 
\v 27 Wenni itticen i imezřaḍ,
\m war dayes ittiři bu řeɣben,
\m \add maca\add* wenni itteqqnen tiṭṭawin nnes,
\m ad ittwanɛeř aṭṭas. \x ◘ \xo 28:27 \xt Aɛwd. 15:7, 8, 10; Awřn. 19:17; 22:9\x*
\m 
\v 28 Mařa kkaren-dd iɛeffanen,
\m \add xenni\add* ittnuffar bnadem,
\m \add maca\add* mařa ttwahellken nitni,
\m ad mmarenyen imseggaden.\x ◘ \xo 28:28 \xt Awřn. 28:12\x*
\b
\b
\c 29
\m 
\v 1 Aryaz, wenni isseqsḥen yiri \add nnes\add*
\m awarni řami t ɛaqben
\m aṭṭas n twařawin,
\m ad yarẓ deg ijj n umur,
\m \add xenni\add* war din iǧi \add ɛad\add* ugenfu.
\m 
\v 2 Mařa dewřen imseggaden s ṣṣulṭa,
\m \add xenni\add* ifarreḥ řgens,
\m \add maca\add* mařa iḥekkem uɛeffan,
\m iweɛɛeḍ řgens. \x ◘ \xo 29:2 \xt Awřn. 11:10; 28:12, 28\x*
\m 
\v 3 Bnadem ittexsen tiɣit, issfarraḥ babas,
\m \add maca\add* wenni ittmunan
\m ak-d temɣarin n farq-ccɣeř,
\m yareddeǧ agřa \add nnes\add*. \x ◘ \xo 29:3 \xt Awřn. 10:1; 15:20; 28:7; Lk. 15:13\x*
\b
\m 
\v 4 Ajeǧid issbedda tammurt s řḥeqq,
\m \add maca\add* aryaz nni issgeɛɛaden
\m ḍḍariba aṭṭas n twařawin,
\m iheddem i-tt.
\m 
\v 5 Aryaz nni isswaṭan jjar nnes,
\m ittbezzaɛ ict n tracca i iḍaren nnes.
\m 
\v 6 Deg uɛeddi n ijj n weryaz aɛeffan
\m \add innuffar dayes\add* ijj n řfex,
\m \add maca\add* amsegged ittesřiwřew u ifarreḥ.
\m 
\v 7 Amsegged issen ddeɛwet n imarxa,
\m aɛeffan war ifehhem walu di tussna. \x ◘ \xo 29:7 \xt Ayub 29:16\x*
\m 
\v 8 Imestehzayyen ssekkaran
\m aɣewweɣ di tendint,
\m \add maca\add* imiɣisen ssneqřaben aɣḍab.
\m 
\v 9 \add Mařa\add* amiɣis iksi-dd tanfuč
\m i yijj n ubuhaři,
\m \add xenni\add* netta ggur ad ixeyyeq wanita
\m u ad iḍḥec, \add maca\add* war din řhudnet.
\b
\m 
\v 10 Iryazen umi itteɛjib idammen
\m carrhen wenni ikemmřen,
\m \add maca\add* inni igguren nican
\m xezzaren ɣar řeɛmar nnes.
\m 
\v 11 Abuhaři iḍeǧeq i marra buḥbeř nnes,
\m \add maca\add* amiɣis ittqemmeɛ i-t. \x ◘ \xo 29:11 \xt Awřn. 14:33\x*
\m 
\v 12 Řḥakem nni itticen taynit
\m i řhard n ixarriqqen,
\m zzayes ad iřin
\m marra imsexxaren nnes d iɛeffanen.
\m 
\v 13 Amezřuḍ d weryaz ittwaḥsaren řebda,
\m msagaren,
\m SIDI issnewwar tiṭṭawin nsen
\m s tnayen idsen. \x ◘ \xo 29:13 \xt Awřn. 22:2\x*
\m 
\v 14 Ajeǧid nni itticen s tidett tasɣart
\m i imarxa di ccreɛ,
\m řkursi nnes ad iqqim ibedd i řebda. \x ◘ \xo 29:14 \xt Awřn. 20:28; 25:5\x*
\b
\m 
\v 15 Aɛmud d uwebbex tticen tiɣit,
\m \add maca\add* aḥenjir jjin t i yixef nnes,
\m yarra yemmas ad tseḍḥa. \x ◘ \xo 29:15 \xt Awřn. 10:1; 13:24; 17:21, 25; 22:15; 23:13\x*
\m 
\v 16 Mařa dewřen iɛeffanen jehden,
\m \add xenni\add* yarenni uxeṭṭu,
\m \add maca\add* imseggaden
\m ad ẓaren weṭṭu nsen. \x ◘ \xo 29:16 \xt Izhd. 37:36; 58:11; 91:8\x*
\m 
\v 17 Arebba mmic u netta ad cek issareyyeḥ,
\m netta ad iwc \add lbarakat\add* timiẓidin
\m i řeɛmar nnec. \x ◘ \xo 29:17 \xt Awřn. 13:24; 22:15; 23:13, 14\x*
\m 
\v 18 Mařa war din řewḥiy, ittfuccuḥ řgens,
\m sseɛd n wenni iḥeṭṭan Ccariɛa.
\m 
\v 19 Ijj n ismeɣ war ittejji
\m ad t arrebban s wawařen,
\m maɣar waxxa netta ifehhem xak,
\m war xak dd-ittarri ca.
\m 
\v 20 Ma cek \add ɛemmarṣ\add* war teẓrid ijj n weryaz
\m ittqeǧiq s wawařen nnes?
\m Aqa din řayas ktar i ubuhaři uřa xas. \x ◘ \xo 29:20 \xt Awřn. 26:12\x*
\m 
\v 21 \add Mařa\add* ijjen issubeḍ ismeɣ nnes zi temẓi,
\m ad idweř ɣar uneggar war t ittqidi.
\b
\m 
\v 22 Aryaz ittarrujduden
\m issekkara-dd amcubbec,
\m u bab n wesɛar \add ittegg\add* aṭṭas n ixeṭṭan. \x ◘ \xo 29:22 \xt Awřn. 15:18; 26:21\x*
\m 
\v 23 Nnfaxet n bnadem ad t isswaḍeɛ,
\m \add maca\add* amwaḍeɛ n buḥbeř
\m ad as ittwagg ccan. \x ◘ \xo 29:23 \xt Ayub 22:29; Awřn. 15:33; 18:12; Ica. 66:2; Mt. 23:12; Lk. 14:11; 18:14; Yaɛ. 4:6, 10; 1 Bṭ. 5:5\x*
\m 
\v 24 Wenni ibeṭṭan ak-d uxewwan,
\m icarreh ixef nnes,
\m \add maɣar\add* netta ittesřa i nneɛřet,
\m \add maca\add* war t iqqar ca. \x ◘ \xo 29:24 \xt Lawi 5:1\x*
\m 
\v 25 Tiggʷudi zeg iwdan tneddeh ɣar řfex,
\m \add maca\add* wenni ittcařan x SIDI,
\m ad ittwassgeɛɛed di řaman.
\m 
\v 26 Aṭṭas arezzun udem n řḥakem,
\m \add waxxa\add* tasɣart n kuř ijj tᵉttas-dd zi SIDI. \x ◘ \xo 29:26 \xt Awřn. 19:6\x*
\m 
\v 27 Aryaz aɣeccac d nnɛi i imseggaden,
\m \add maca\add* wenni igguren nican
\m deg webrid nnes,
\m aqa-t d nnɛi i uɛeffan.
\b
\b
\c 30
\s1 Awařen iweznen n Ajur
\m 
\v 1 \bd Awařen n Ajur,\bd*
\m \bd mmis n Yaki, \bdit zi teqbič\bdit* n Massa.\bd*
\m Necc arbeřeɣ, \add a\add* Arebbi,
\m necc arbeřeɣ, \add a\add* Arebbi, u kemmřeɣ.
\m 
\v 2 Maɣar necc d aqeffuḥ, war iǧi d bnadem,
\m řefhamet n bnadem war ɣari teǧi.
\m 
\v 3 Necc war řmideɣ tiɣit,
\m maḥend ad ɣari tiři tussna
\m n Umqeddas Ameqqran.
\m 
\v 4 Wi igeɛɛden ɣar ujenna uca ihwa-dd?
\m Man wen iyarrwen asemmiḍ
\m deg ifassen nnes?
\m Wi issennḍen aman deg warruḍ?
\m Wi yarekknen
\m marra tineggura n temmurt?
\m Man Isem nnes u man Isem n Mmis?
\m Cek tessned t, ma war iǧi amenni? \x ◘ \xo 30:4 \xt Ayub 38:4; Izhd. 104:3; Ica. 40:12\x*
\b
\m 
\v 5 Kuř awař n Arebbi ittwaṣeffa,
\m aqa Netta d adurri
\m i yinni ɣares dd-yarekkwařen. \x ◘ \xo 30:5 \xt Izhd. 12:7; 18:31; 19:9; 119:140, 2 Tim. 2:16\x*
\m 
\v 6 War arenni ɣar wawařen nnes,
\m ḥima Netta war cek ittwebbex,
\m u ad tbaned-dd cek d bu-ixarriqen. \x ◘ \xo 30:6 \xt Aɛwd. 4:2; 12:32; Asa. 22:18\x*
\b
\m 
\v 7 Necc ttareɣ ac tnayen n tmesřayin,
\m war xafi tent qeṭṭeɛ qbeř i ɣa mmteɣ.
\m 
\v 8 Siggʷej xafi min ibeḍřen
\m d řhard ixarriqen,
\m war d ayi ttic zzeřḍ uřa d wagřa,
\m carreg ayi tasɣart inu
\m i d ayi dd-ittasen zeg weɣrum,
\m 
\v 9 mařa lla, xmi ɣa jjiwneɣ,
\m ad taɣ ad Cek nkareɣ,
\m ad iniɣ ‘Wi iǧan SIDI?’,
\m niɣ xenni, mařa zeřḍeɣ, ad acareɣ,
\m u ad ggeɣ řɛib deg Yisem n AREBBI inu.
\m 
\v 10 War ceqqef deg ijj n umsexxar
\m ɣar sidis nnes,
\m ḥima netta war cek ineɛɛeř
\m u \add xenni\add* cek ad dayek yiři řɛib.
\b
\m 
\v 11 \add Aqa din\add* ijj n jjiř i ineɛɛřen babas,
\m u war ittbarek yemmas,
\m 
\v 12 ijj n jjiř \add i yeǧan\add* d amezdag
\m di tiṭṭawin nnes,
\m \add maca\add* war ittwasird zi řexmej nnes,
\m 
\v 13 ijj n jjiř s řxezrat inefxen,
\m s wabřiwen nnes igeɛɛden, \x ◘ \xo 30:13 \xt Awřn. 6:17\x*
\m 
\v 14 ijj n jjiř s teɣmas am řesyuf
\m d teɣmas n teɣmart am řemwas,
\m ḥima ad ṣarḍen
\m inni ittwaḥṣaren zi temmurt
\m d imezřaḍ zeg iwdan. \x ◘ \xo 30:14 \xt Awřn. 12:18\x*
\b
\m 
\v 15 Tadda ɣares tnayen n yessis:
\m ‘Ewc!’ ‘Ewc!’
\m Aqa din třata nni ɛemmarṣ ad jjiwnen.
\m Arebɛa ɛemmarṣ ad inin: “Cfa!”
\m 
\v 16 Řaxart d řemřawet ibellɛen,
\m tammurt i war ijjiwnen ɛemmarṣ
\m zeg waman,
\m uřa d tmessi
\m war qqarent ɛemmarṣ: “Cfa!”
\b
\m 
\v 17 Tiṭṭ i isstehzan zi babas,
\m u tesseḥqar ṭṭaɛet i yemmas,
\m ad tt qeřɛen ibaɣřiwen ɣar teɣzart,
\m u imeẓyanen n ugider ad tt ccen.
\b
\m 
\v 18 Třata-ya \add n tmesřayin\add*
\m ɛdunt ayi s řeɛjeb,
\m arebɛa war tent ssineɣ:
\m 
\v 19 abrid n ugider deg ujenna,
\m abrid n ufiɣar x teṣḍart,
\m abrid n uɣarrabu deg wuř n řebḥar,
\m u abrid n weryaz ak-d teɛzarect.
\m 
\v 20 Ammu i ittegg
\m abrid n ict n temɣart izennan:
\m nettat tᵉttett, tessirid aqemmum nnes,
\m teqqar: “Necc war ggiɣ walu d řɣecc!”
\b
\m 
\v 21 Sadu třata \add n tmesřayin-a\add*
\m tenhezz temmurt,
\m sadu arebɛa i war tzemmar ad tarbu:
\m 
\v 22 sadu ijj n umsexxar
\m mařa netta idweř d ajeǧid,
\m sadu ijj n ubuhaři
\m mařa netta ijjiwen aɣrum,
\m 
\v 23 sadu ict n temɣart tᵉttwasseḥqar
\m mařa nettat tᵉttwassemřec,
\m u sadu ict n tayya
\m mařa tᵉṭṭef řwart n lallas.
\b
\m 
\v 24 Arebɛa-ya d imeẓyanen qaɛ x temmurt,
\m \add ɛad\add* nitni d imiɣisen qaɛ:
\m 
\v 25 Tikeḍfin war ǧint d řgens ijehden,
\m \add maca ɛad\add* nitenti ssewjadent
\m macca nsen deg unebdu. \x ◘ \xo 30:25 \xt Awřn. 6:8\x*
\m 
\v 26 Ikawkawen n teṣḍart
\m d ijj n řgens nhřa jjhed,
\m \add maca\add* nitni bennan
\m tazeddiɣt nsen di teṣḍart.
\m 
\v 27 Tamuɣri war ɣares bu ajeǧid,
\m \add waxxa amenni\add* iffeɣ s usettef marra.
\m 
\v 28 Azermummi tzemmared
\m ad t tᵉṭṭfed s tnayen n ifassen,
\m \add ɛad aqa-t\add* netta di řeqṣur n ijeǧiden.
\b
\m 
\v 29 Třata-ya ṣṣurufen s řɛezz,
\m arebɛa gguren s tecři tecneɛ:
\m 
\v 30 Ayrad, bu-teɣruḍt jar řmar,
\m wenni war ittwexxiren zzat i ḥed,
\m 
\v 31 ijj n \add uɣiřas\add* s tejɛinnatin nnes beysent,
\m niɣ ijj n umyan,
\m u ijj n ujeǧid nni ɣar iǧa
\m uřaɣi n umenɣi. \x ◘ \xo 30:31 \xt Ayub 39:19-28\x*
\b
\m 
\v 32 Mařa cek teggid s tubbuheřya
\m umi tessgeɛɛded ixef nnec,
\m niɣ txemmemed di teḥraymect:
\m sars \add a\add*fus x uqemmum! \x ◘ \xo 30:32 \xt Ayub 21:5\x*
\m 
\v 33 Maɣar asendu n uɣi ittawi-dd trussi,
\m u asendu n wenzaren
\m ittawi-dd idammen,
\m u asendu n uxeyyeq,
\m ittawi-dd amcubbec.
\b
\b
\c 31
\s1 Awařen iweznen n yemmas n Lamuyil
\m 
\v 1 \bd Awařen n Lamuyil, ajeǧid \bdit n teqbič n\bdit* Massa,\bd*
\m \bd \bdit i zi t\bdit* tɛeřmed yemmas.\bd*
\b
\m 
\v 2 Min \add din\add*, \add a\add* mmi,
\m min \add din\add*, \add a\add* mmi n weḥsin inu,
\m min \add i ɣa tegged\add*, \add a\add* mmi n lwuɛud inu?
\m 
\v 3 War ttic tizemmar nnec i temɣarin,
\m uřa ibriden nnec
\m i tinni itthellaken ijeǧiden. \x ◘ \xo 31:3 \xt Aɛwd. 17:17\x*
\m 
\v 4 War dd-tusi i ijeǧiden, \add a\add* Lamuyil,
\m war dd-tusi i ijeǧiden
\m maḥend ad swen binu,
\m uřa i ayt n jjehd
\m maḥend ad meẓren di ccrab.
\m 
\v 5 Niɣ ad isuw u ad ittu lfariḍa,
\m u ad issfarɣ tanfuč n marra imxeyyben.
\m 
\v 6 Ewc ccrab i yinni i ɣa ittwahellken,
\m uřa d binu i yinni d imerzagen
\m di řeɛmar nsen.
\m 
\v 7 Ejj i-t ad isuw u ad ittu zzeřḍ nnes,
\m \add ejj i-t\add* war ttxarraṣ di tamara nnes ɛad.
\m 
\v 8 Arzem aqemmum nnec i iziynan,
\m i ddeɛwet n marra inni ittwajjen.
\m 
\v 9 Arzem aqemmum nnec,
\m ḥkem s řḥukm nican,
\m uca aɣ tasɣart i umezřuḍ. \x ◘ \xo 31:9 \xt Lawi 19:15; Aɛwd. 1:16\x*
\b
\s1 Asemɣar n temɣart imeḥḍen
\m 
\v 10 \bd Alif.\bd* \bd Man wen i ɣa yafen\bd*
\m \bd ict n temɣart imeḥḍen?\bd*
\m Ttaman nnes iɛdu marra řmarjan. \x ◘ \xo 31:10 \xt Awřn. 12:4\x*
\m 
\v 11 \bd Bit.\bd* Xas i ittcařa wuř n weryaz nnes,
\m war d as ittxeṣṣi řefḍeř.
\m 
\v 12 \bd Gimel.\bd* Nettat tᵉttegg as min iṣebḥen,
\m war iǧi řɣar,
\m marra ussan n tudart nnes.
\m 
\v 13 \bd Dalit.\bd* Nettat tarezzu taḍuft d tiffest,
\m u txeddem s ifassen nnes imeḥḍen.
\m 
\v 14 \bd Hi.\bd* Nettat tegga am tɣarruba n usebbab,
\m zi řaggʷaj tᵉttawi-dd macca nnes.
\m 
\v 15 \bd Waw.\bd* Nettat tᵉttnakkar
\m umi ɛad teǧa ǧiřet,
\m tᵉttic macca i taddart nnes,
\m u tasɣart \add nsent\add*
\m i temsexxarin nnec timeẓyanin.
\m 
\v 16 \bd Zayin.\bd* Nettat tᵉttxarraṣ deg iyyar
\m u tᵉtteṭṭef i-t,
\m zi řɣiǧet n ifassen nnes
\m teẓẓu tizayarin deg umarjeɛ.
\m 
\v 17 \bd Xit.\bd* Nettat tbekkes
\m tijɛinnatin nnes s jjehd,
\m u tessemḥaḍ iɣaǧen nnes.
\m 
\v 18 \bd Tit.\bd* Nettat tḥekkar
\m i řefḍeř n tsebbabt nnes,
\m řefnar nnes war ixessi di ǧiřet.
\m 
\v 19 \bd Yud.\bd* Nettat tesswiẓẓeḍ ifassen nnes
\m ɣar trukka,
\m u ifassen nnes ṭṭfen amekkuk n uxeyyaḍ.
\m 
\v 20 \bd Kaf.\bd* Nettat tarezzem
\m afus nnes i umeḥdaj,
\m tesswaẓẓaḍ ifassen nnes i umezřuḍ.
\m 
\v 21 \bd Lamid.\bd* Nettat war tᵉtteggʷed
\m zi taddart nnes
\m di ssibbet n wedfeř,
\m maɣar marra taddart nnes
\m ɣares arruḍ arjuwani.
\m 
\v 22 \bd Mim.\bd* Nettat tegga i yixef nnes
\m tisuntawin n zwaq,
\m arruḍ nnes \add s\add* řeqṭen azdad
\m d \add ufiřu\add* arjuwani.
\m 
\v 23 \bd Nun.\bd* Aryaz nnes ittwassen di tewwura,
\m xmi ittɣima ak-d imɣaren n temmurt.
\m 
\v 24 \bd Samix.\bd* Nettat tᵉttegg arruḍ n řeqṭen
\m uca tezznuza \add i-t\add*,
\m nettat tezznuza ibuyas
\m i usebbab zi Kenɛan.
\m 
\v 25 \bd Ɛayin.\bd* Jjehd d řɛezz d arruḍ nnes,
\m nettat tḍeḥḥec \add tesfarnin\add*
\m x wass i dd ɣa yasen.
\m 
\v 26 \bd Pi.\bd* Nettat tarezzem
\m aqemmum nnes s tiɣit,
\m \add aqa din\add* taɣuri s tmexsiwt icewwaren
\m x yiřes nnes.
\m 
\v 27 \bd Tsadi.\bd* Nettat tḥeṭṭa
\m x min ittemmsaran di taddart,
\m aɣrum n řeɛgez war tᵉttett.
\m 
\v 28 \bd Quf.\bd* Iḥenjiren nnes ttekkaren,
\m ssemɣaran tt s řefraḥet,
\m uřa d aryaz nnes ittmeddeḥ i-tt.
\m 
\v 29 \bd Rix.\bd* Aṭṭas n tyessit
\m ggint timegga jehdent,
\m \add maca\add* cem teɛdud-dd ten marra.
\m 
\v 30 \bd Cin.\bd* Řebhut tcemmet u aẓri ittɣecca
\m \add maca\add* tamɣart nni itteggʷden SIDI,
\m ittxeṣṣa ad tt ssemɣaren.
\m 
\v 31 \bd Taf.\bd* Wcem as zi řɣiǧet n ifassen nnes,
\m jjem timegga nnes
\m ad as ṣebbḥent ɣar tewwura. 
