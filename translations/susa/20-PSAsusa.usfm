\id PSA
\h يَبُرَ
\toc1 يَبُرَ دَوُدَ
\toc2 يَبُرَ
\toc3 يَب
\mt1 يَبُرَ دَوُدَ
\imt1 مَسٍنيِ ندٍ يِ كِتَابُي شَ قٍ رَ
\ip يِ كِتَابُي قِندِشِ بّيتِ كِتَابُي نَن نَ. عَننَبِ دَوُدَ نَشَ يِ بّيتِ وُيَشِيٍ سّبّ عَلَ سَابُي رَ، عَ عٍ مَلَن كِتَابُي كُي دَنشَنِيَتْييٍ بّ. عَ نَشَ بّيتِ ندٍيٍ سَ كِتَابُي كُي نَمِحْنمّ فبّتّيٍ نَشٍيٍ سّبّ عَلْ عَسَقِ يَبُرَ ٥٠. بّيتِبَيٍ نُ يِ بّيتِيٍ بَمَ عَلَ شَ هْرْ مْبَنشِ كُي سَلِ تّمُي. دَوُدَ تٌ بّيتِ ندٍيٍ سّبّ، عَ نَشَ يَامَرِ قِ بّيتِبَيٍ مَ نَ بّيتِ لَنمَ عَ شَ بَ كِ نَشّ يَبُرَ ٣‏؛٣، ٤‏؛١. تٌ دَنشَنِيَتْييٍ قَن نْمَ يِ بّيتِيٍ بَدٍ عٍ فبٍ كِ.
\ip بَقٍ نَ رَ، يِ بّيتِيٍ قِندِشِ مِسَالِ شُنفبٍ نَن نَ دَنشَنِيَتْييٍ بّ كَبِ تّمُي شْنكُيٍ. مِشِ نْمَ رَكْرْ سِدٍ يِ بّيتِيٍ كُي عَ عَلَ وَ مَ نّ مِشِيٍ شَ عٍ بْحّ شَ قٍ مَسٍن عَ بّ. شَ كْنتْقِلِ ندٍ نَ مِشِيٍ قُرِ كُي، عَلَ تِنمَ عٍ شَ نَ مَسٍن عَ بّ، عَ قِندِ عَلَ مَشَندِ رَ. شَ مِشِيٍ نَ سٌقٍ قَهَامُي كُي عَلَ شَ فبٌي شَ قٍ رَ، عٍ نْمَ نَ قَن مَسٍندٍ عَلَ بّ، عَ قِندِ عَلَ مَتْشْي رَ. عَدَ مَدِ لَنمَ عَ شَ نَ قٍ مْولِ بِرِن مَسٍن عٍ مَرِفِ عَلَ بّ. عَلَ وَ مَ نَ دّ مَسَرّ مْولِ شْن مَ عَ تَن نُن دَنشَنِيَتْييٍ تَفِ.
\ip عَلَ شَ عِ مَلِ يِ شَرَنيِ رَ، عَ شَ عَ نِيَ عِ قَن شَ مَسٍنيِ تِ عَلَ بّ نَشَن نَ عِ قُرِ كُي، عَلَكٌ عَ قَن شَ عِ يَابِ، وٌ دّ شَ قَن. عَمِنَ.
\mt1 يَبُرَ دَوُدَ
\c 1
\s1 كِرَ قِرِنيِ
\s2 عَلَ شَ سّرِيّ
\q1 
\v 1 حّلّشِنيِ نَ عَدَ مَ نَن بّ،
\q1 نَشَن مُ بِرَ مَ مِشِ حَاشِ شَ مَرَ سِ قْشْ رَ،
\q1 نَشَن مُ عَ حّرّ مَ يُنُبِتْي قْشْ رَ،
\q1 نَشَن مُ عَ مَكْرّ مَ مِشِيٍ رَ،
\q1 نَشٍيٍ يٌمَ عَلَ قٍ مَ.
\q1 
\v 2 حّلّشِنيِ نَ عَدَ مَ نَن بّ،
\q1 عَلَتَلَ شَ سّرِيّ رَقَن نَشَن مَ،
\q1 نَشَن عَ حْشْ سَمَ عَلَتَلَ شَ سّرِيّ شْن مَ كْي نُن يَنيِ.
\q1 
\v 3 نَ عَدَ مَ مَنِيّ
\q1 وُرِ بِلِ رَ نَشَن تِشِ شُرٍ دّ.
\q1 عَ بٌفِمَ عَ وَشَتِ.
\q1 عَ بُرّشّ مُ لِسِمَ.
\q1 نَ عَدَ مَ، قٍقٍ سُشُمَ، عَ سْونّيَمَ نّ عَ بّ.
\b
\q1 
\v 4 كْنْ عَ مُ نَ كِ شّ مِشِ حَاشِيٍ تَن بّ.
\q1 عٍ تَن مَنِيّ مَالٍ لَفِ رَ قٌيٍ نَشَن شَنِنمَ.
\q1 
\v 5 مِشِ حَاشِيٍ بْنْمَ نّ كِيتِ وَشَتِ،
\q1 عٍ مُ لُمَ تِنشِن مِشِيٍ يَ مَ.
\q1 لُدٍ مُ نَ عٍ بّ.
\q1 
\v 6 عَلَتَلَ مّينِمَ تِنشِنتْييٍ مَ عَ شَ كِرَ شْن مَ،
\q1 كْنْ مِشِ حَاشِ تَن شَ كِرَ قِندِ مَ فبَلٌي كِرَ نَن نَ.
\c 2
\s1 عَلَ شَ مِشِ سُفَندِشِ
\s2 عَلَ شَ سّرِيّ
\q1 
\v 1 مُنقٍ رَ سِيٍ بْحّ تٍشِ قُقَقُ؟
\q1 
\v 2 دُنِحَ مَنفّيٍ بَرَ كٍلِ،
\q1 شُنمَتِيٍ بَرَ تِ عَلَتَلَ
\q1 نُن عَ شَ مِشِ سُفَندِشِ كَنكٍ.
\q1 
\v 3 نَ دُنِحَ مَنفّيٍ نَشّ،
\q1 «وٌن شَ وٌن بَ عٍ يِ رَ،
\q1 وٌن شَ مِنِ عٍ شَ نْي بُن مَ.»
\b
\q1 
\v 4 مَرِفِ نَشَن نَ كٌورٍ مَ،
\q1 نَ نَ يٍلٍقٍ عٍ مَ.
\q1 
\v 5 عَ شْنْمَ عٍ مَ،
\q1 عَ عٍ مَفَاشُمَ.
\q1 
\v 6 عَلَ شَ مَسٍنيِ نَن يَ،
\q1 «ﭑ تَن نَن مَنفّ سُفَندِ،
\q1 ﭑ عَ دْشْ سِيٌنِ فٍيَ قَرِ، ﭑ مَ يِرٍ سّنِيّنشِ.»
\b
\q1 
\v 7 نَ مَنفّ سُفَندِشِ شَ مَسٍنيِ نَن يَ،
\q1 «ﭑ شَ عَلَتَلَ شَ نَتّ مَسٍن وٌ بّ.
\q1 عَلَ بَرَ عَ مَسٍن ﭑ بّ، ‹تٌ، عِ بَرَ قِندِ ﭑ مَ دِ رَ.
\q1 ﭑ تَن بَرَ قِندِ عِ بَبَ رَ.
\q1 
\v 8 عِ شَ ﭑ مَشَندِ ﭑ شَ سِ بِرِن قِ عِ مَ،
\q1 عٍ شَ قِندِ كّ رَ عِ بّ.
\q1 دُنِحَ بِرِن شَ قِندِ عِ فبٍ رَ.
\q1 
\v 9 عِ عٍ يَمَرِ مَ سَوُرِ رَ،
\q1 عِ عٍ كَنَمَ عَلْ وُرٍ قّحّ بْو مَ كِ نَشّ،
\q1 عَ كٍبٍلَيٍ يٍنسٍن يّ.›»
\b
\q1 
\v 10 يَكْسِ وٌ تَن مَنفّيٍ، وٌ شَشِلِ سْتْ.
\q1 كُنتِفِيٍ، وٌ بِرَ نْندِ قْشْ رَ.
\q1 
\v 11 وٌ عَلَتَلَ بَتُ فَاشُي رَ،
\q1 وٌ سّيوَ عَ شَ قٍ رَ،
\q1 وٌ فَاشُ عَ يَ رَ.
\q1 
\v 12 وٌ وٌ شُن سِن عَ شَ مِشِ سُفَندِشِ بّ.
\q1 شَ نَ مُ عَ رَ، عَ وٌ هَلَكِمَ نّ وٌ شَ دُنِحّءِفِرِ كُي.
\q1 عَلَ شَ شْنّ دّشّمَ عَلْ تّ نُ سٌ قِيلِ رَ.
\q1 حّلّشِنيِ نَ عَدَ مَ نَن بّ،
\q1 نَشَن كَنتَرِ قٍنمَ عَلَ رَ.
\c 3
\s1 دَوُدَ نُن عَ شَ دِ عَبِسَلٌمِ
\s2 عَلَ مَشَندِ
\d 
\v 1 دَوُدَ شَ بّيتِ عَ نُ عَ فِمَ عَ شَ دِ عَبِسَلٌمِ مَ تّمُي نَشّ.
\q1 
\v 2 عَلَتَلَ، ﭑ يَشُييٍ بَرَ وُيَ.
\q1 ﭑ فٍرٍقَيٍ بَرَ فبٌ.
\q1 
\v 3 مِشِ وُيَشِ عَ قَلَمَ،
\q1 عَلَ مُ نْمَ ﭑ نَكِسِدٍ. \qs حّنفِ رَتٍ.\qs*
\q1 
\v 4 كْنْ عِ تَن عَلَتَلَ، عِ قِندِشِ ﭑ كَنتَمَ نَن نَ.
\q1 ﭑ مَ بِنيّ نُن ﭑ مَ شُننَكٍلِ قَتَنشِ عِ تَن نَن نَ.
\q1 
\v 5 ﭑ نَن ﭑ شُي رَتٍ عَلَ مَ،
\q1 عَ ﭑ يَابِمَ كٍلِ عَ شَ فٍيَ سّنِيّنشِ قَرِ. \qs حّنفِ رَتٍ.\qs*
\q1 
\v 6 ﭑ نَن ﭑ سَمَ، ﭑ شَ شِ،
\q1 ﭑ مَن شُنُمَ شَشِلِ سَ كُي،
\q1 بَرِ مَ عَلَتَلَ نَن نَ ﭑ دّ مّنمَ رَ.
\q1 
\v 7 ﭑ مُ فَاشُمَ يِ حَمَ دُنِحَ يَ رَ،
\q1 نَشٍيٍ مُ وَ مَ ﭑ مَ قٍ شْن مَ.
\q1 
\v 8 عَلَتَلَ يَندِ، ﭑ نَكِسِ، ﭑ مَرِفِ عَلَ.
\q1 عِ ﭑ يَشُييٍ دّ رَفَرِنمَ نّ،
\q1 عِ مِشِ حَاشِ حِنيِيٍ مَفِرَ مَ نّ.
\q1 
\v 9 مَرَكِسِمَ نَن نَ عَلَتَلَ رَ.
\q1 عِ شَ بَرَكّ سَ عِ شَ حَمَ شَ قٍ. \qs حّنفِ رَتٍ.\qs*
\c 4
\s1 عَلَتَلَ كٍرٍن نَن نْمَ ﭑ كَنتَدٍ
\s2 عَلَ مَشَندِ
\d 
\v 1 دَوُدَ شَ بّيتِ بّيتِبَيٍ شَ مَنفّ بّ. عَ شَ بَ كْرَ شُي رَ.
\q1 
\v 2 ﭑ مَرِفِ عَلَ تِنشِنشِ، ﭑ نَ ﭑ شُي رَتٍ عِ مَ،
\q1 يَندِ عَ رَتِن ﭑ بّ.
\q1 ﭑ مَ تْورّ كُي، عِ ﭑ بْحّ سَمَ.
\q1 هِننّ ﭑ نَ، ﭑ مَ دُبّ سُشُ.
\b
\q1 
\v 3 عَدَ مَدِيٍ، وٌ ﭑ مَ بِنيّ مَسَرَ مَ يَافِ رَ هَن مُن تّمُي؟
\q1 وٌ بِرَ مَ قٍ قُقَقُ نُن وُلٍ قْشْ رَ هَن مُن تّمُي؟
\q1 
\v 4 وٌ شَ عَ كٌلٌن عَلَتَلَ بَرَ تِنشِنتْي سُفَندِ.
\q1 ﭑ نَن ﭑ شُي رَتٍ عَلَتَلَ مَ، عَ عَ رَ مّمَ نّ.
\q1 
\v 5 وٌ قَن شَ فَاشُ،
\q1 وٌ فبِلٍن يُنُبِ قٍ قْشْ رَ.
\q1 وٌ وٌ يّتّ رَ سِ كْي رَ،
\q1 وٌ شَ وٌ رَشَرَ.
\q1 
\v 6 وٌ شَ سّرّشّ بَ تِنشِنيِ كُي،
\q1 وٌ شَ وٌ يّتّ تَشُ عَلَتَلَ رَ.
\b
\q1 
\v 7 مِشِ فبٍفبٍ عَ قَلَمَ،
\q1 «ندٍ نْمَ هّيرِ مَسٍندٍ وٌن بّ؟»
\q1 عَلَتَلَ، عِ شَ نْرّ مَسٍن مُشُ بّ.
\q1 
\v 8 عِ بَرَ ﭑ بْحّ رَقٍ سّيوّ رَ
\q1 دَنفِقٍ شّ شَبَ تّمُي رَ.
\q1 
\v 9 ﭑ نَ ﭑ سَ، ﭑ شِمَ بْحّسَ كُي،
\q1 بَرِ مَ عِ تَن عَلَتَلَ، عِ كٍرٍن نَن نْمَ ﭑ كَنتَدٍ.
\c 5
\s1 ﭑ سٌمَ عَلَ شْنيِ
\s2 عَلَ مَشَندِ
\d 
\v 1 دَوُدَ شَ بّيتِ بّيتِبَيٍ شَ مَنفّ بّ شُلٍ شُي رَ
\q1 
\v 2 عَلَتَلَ، عِ تُلِ مَتِ ﭑ مَ مَشَندِ رَ،
\q1 عِ شَ ﭑ مَ تْورّ كٌلٌن.
\q1 
\v 3 ﭑ مَرِفِ عَلَ، عِ تُلِ مَتِ ﭑ مَ مَشَندِ رَ،
\q1 ﭑ نَ عِ تَن نَن مَشَندِقٍ.
\q1 
\v 4 عَلَتَلَ، كُيٍ نّ عِبَمَ، عِ ﭑ شُي رَ مّمَ.
\q1 فّيسّفّ، ﭑ نَن ﭑ يّتّ رَفبِلٍنمَ عِ مَ، ﭑ عِ مّمّ.
\q1 
\v 5 عِ مُ حّلّشِنمَ قٍ كٌبِ رَ.
\q1 قٍ حَاشِ مُ نْمَ مَكْرّدٍ عِ يِرٍ رَ.
\q1 
\v 6 يّتّ عِفبٌي مُ تِمَ عِ يَ عِ.
\q1 عِ تِنشِنتَرٍيٍ بِرِن شْنشِ.
\q1 
\v 7 عِ وُلٍ قَلّ رَهَلَكِمَ.
\q1 عِ قَشَتِيٍ نُن يَنقَنتٍيٍ شْنمَ.
\b
\q1 
\v 8 كْنْ ﭑ تَن سٌمَ عِ شَ بَنشِ كُي عِ شَ قٌنِسِرٍيَ سَابُي نَن نَ.
\q1 ﭑ نَن ﭑ عِفٌرٌ مَ عِ شَ هْرْ مْبَنشِ سّنِيّنشِ كُي فَاشُي رَ.
\q1 
\v 9 عَلَتَلَ، ﭑ يَشُييٍ شَ قٍ رَ،
\q1 ﭑ شُن تِ عِ شَ تِنشِنيِ رَ،
\q1 عِ شَ كِرَ يَءِلَن ﭑ يَ رَ.
\q1 
\v 10 نْندِ مُ نَ ﭑ يَشُييٍ شَ مَسٍنيِ سٍسٍ كُي.
\q1 عٍ يُفٍ مُ قَن.
\q1 عٍ شَ وْيّنيِ مِشِ رَقِلِمَ نّ،
\q1 بَرِ مَ عٍ دّ عِحْشُن.
\q1 
\v 11 عَلَ، عٍ حَشَنكَتَ.
\q1 عٍ شَ يَنقّ شَ فبِلٍن عٍ مَ.
\q1 عٍ كٍرِ عٍ شَ قٍ كٌبِ مَ،
\q1 بَرِ مَ عٍ بَرَ عِ مَتَندِ.
\b
\q1 
\v 12 كْنْ مِشِ نَشَن بِرِن عَ يّتّ تَشُمَ عِ رَ،
\q1 عٍ بِرِن شَ سّيوَ،
\q1 عٍ شَ حّلّشِنيِ نَشَ حْن عَبَدَن.
\q1 عِ شِلِ رَقَنشِ مِشِ نَشٍيٍ مَ، عٍ مَكَنتَ،
\q1 عٍ شَ سّيوَ عِ شَ قٍ رَ،
\q1 
\v 13 بَرِ مَ عِ تَن عَلَتَلَ، عِ بَرَكّ سَمَ مِشِ تِنشِنشِ شَ قٍ.
\q1 عِ شَ هِننّ نَشَن عٍ رَبِلِنشِ،
\q1 عَ بَرَ قِندِ عٍ شَ كَنتَرِ رَ.
\c 6
\s1 قُرٍ مَ وَ شُي
\s2 عَلَ مَشَندِ
\d 
\v 1 دَوُدَ شَ بّيتِ بّيتِبَيٍ شَ مَنفّ بّ. عَ شَ بَ كْرَ لُوتِ سٌلٌمَسَشَن شُي رَ.
\q1 
\v 2 عَلَتَلَ، عِ نَشَ ﭑ حَشَنكَتَ عِ شَ شْنّ كُي،
\q1 عِ نَشَ ﭑ تْورْ عِ شَ بْحّ تٍ كُي.
\q1 
\v 3 عَلَتَلَ، هِننّ ﭑ نَ، ﭑ بَرَ هَلَكِ.
\q1 عَلَتَلَ، ﭑ نَيَلَن، ﭑ شْرِيٍ نَ سّرّنقٍ نّ يِ كِ.
\q1 
\v 4 ﭑ نِي بِرِن نَ سّرّنقٍ تْورّ رَ.
\q1 عَلَتَلَ، هَن تّمُي مُندُن قَ؟
\q1 
\v 5 عَلَتَلَ، قَ ﭑ نِي رَكِسِ.
\q1 ﭑ نَتَنفَ عِ شَ قٌنِسِرٍيَ شَ قٍ رَ.
\q1 
\v 6 مِشِ مُ نْمَ رَتُدٍ عِ مَ فَبُرِ كُي.
\q1 ندٍ نْمَ عِ تَنتُدٍ عَلِفِيَمَ؟
\q1 
\v 7 ﭑ بَرَ تْورْ هَن ﭑ سّنبّ بِرِن بَرَ حْن.
\q1 كْي يٌ كْي ﭑ وَ مَ،
\q1 هَن ﭑ مَ سَدٍ بِرِن بُندَ ﭑ يَ يٍ رَ.
\q1 
\v 8 سُننُنيِ بَرَ ﭑ يَ مَقْورْ.
\q1 ﭑ مُ سٍسٍ تٌقٍ ﭑ يَشُييٍ شَ فبٌي شَ قٍ رَ.
\b
\q1 
\v 9 وٌ وٌ مَسِفَ ﭑ نَ، وٌ تَن تِنشِنتَرٍيٍ،
\q1 بَرِ مَ ﭑ وَ شُي بَرَ عَلَتَلَ لِ.
\q1 
\v 10 عَلَتَلَ بَرَ ﭑ مَ مَشَندِ مّ.
\q1 عَلَتَلَ بَرَ ﭑ مَ دُبّ سُشُ.
\q1 
\v 11 ﭑ يَشُييٍ بِرِن يَافِمَ نّ، هَن عٍ عٍ فِ.
\c 7
\s1 كِيتِسَ قَنيِ نَن نَ عَلَ رَ
\s2 عَلَ مَشَندِ
\d 
\v 1 دَوُدَ شَ بّيتِ مْولِ ندٍ عَلَتَلَ بّ كُسِ بُنيَمِنكَ شَ قٍ رَ.
\q1 
\v 2 ﭑ مَرِفِ عَلَتَلَ، عِ تَن نَن نَ ﭑ كَنتَمَ رَ.
\q1 ﭑ نَتَنفَ ﭑ يَشُييٍ مَ، ﭑ بَ عٍ يِ رَ،
\q1 
\v 3 عٍ نَشَ ﭑ قَشَ عَلْ يّتّ مِشِ قَشَمَ كِ نَشّ.
\q1 عَ نَ نَشَن سُشُ، نَ مُ بَمَ عَ يِ رَ.
\q1 
\v 4 ﭑ مَرِفِ عَلَتَلَ،
\q1 شَ ﭑ بَرَ كْبِرِ رَ مُرُتَ،
\q1 
\v 5 شَ ﭑ بَرَ قٍ حَاشِ رَبَ مِشِ رَ،
\q1 مُشُ نُن نَشَن دْشْشِ بْحّسَ كُي،
\q1 شَ ﭑ بَرَ ﭑ فٍرٍقَ مُحَ تْوحّفّ كُي،
\q1 
\v 6 ﭑ يَشُييٍ شَ ﭑ كٍرِ، عٍ شَ ﭑ مَسْتْ،
\q1 عٍ شَ ﭑ مَبٌرٌن، عٍ ﭑ قَشَ.
\b
\q1 
\v 7 عَلَتَلَ، ﭑ مَلِ، عِ بْحّ شَ تٍ ﭑ يَشُييٍ مَ.
\q1 ﭑ دّ مّن، سّرِيّ نَ عِ تَن نَشَن يِ رَ.
\q1 
\v 8 عِ شَ نْي شَ لُ حَمَيٍ شُن،
\q1 عٍ شَ لُ عِ شَ يَامَرِ بُن مَ.
\q1 
\v 9 عَلَتَلَ، حَمَيٍ مَكِيتِ.
\q1 عَلَتَلَ، ﭑ مَ نْندِ مَكّنّن عٍ بّ
\q1 ﭑ مَ تِنشِنيِ نُن ﭑ مَ سّرِيّ بّرّ رَ.
\q1 
\v 10 دَنيِ سَ قٍ كٌبِ رَبَيٍ شَ قٍ مَ.
\q1 سّنبّ قِ مِشِ تِنشِنشِيٍ مَ
\q1 عِ تَن، عَلَ نَشَن تِنشِن،
\q1 نَشَن بِرِن سٌندٌن مَ قٍ كٌلٌن.
\b
\q1 
\v 11 عَلَ، ﭑ كَنتَمَ نَ عِ تَن نَن نَ،
\q1 نَشَن مِشِ تِنشِنشِ رَكِسِمَ.
\q1 
\v 12 كِيتِسَ قَنيِ نَن نَ عَلَ رَ،
\q1 نَشَن شْنْمَ تِنشِنتَرٍيٍ مَ تّمُي بِرِن.
\q1 
\v 13 شَ مِشِ حَاشِيٍ مُ فبِلٍن عٍ يُفٍ قْشْ رَ،
\q1 عَلَ عَ شَ سَنتِدّفّمَ رَلُفَنمَ نّ،
\q1 عَ عَ شَ شَلِ مَشِرِ.
\q1 
\v 14 عَلَ نَ قَشَتِسٍ يَءِلَنمَ مِشِ حَاشِيٍ نَن شِلِ مَ،
\q1 عَ عَ شَ تَنبّيٍ دّ قِندِ تّ رَ.
\b
\q1 
\v 15 مِشِ حَاشِ لُمَ قٍ حَاشِ نَن تُن نَبَ رَ.
\q1 عَ عَ حْشْ سَ عَ شْن مَ هَن عَ قِندِ عَ رَ.
\q1 
\v 16 عَ يِلِ فٍمَ هَن عَ تِلِن،
\q1 عَ قَ بِرَ عَ يّتّ شَ يِلِ فٍشِ كُي.
\q1 
\v 17 عَ شَ قٍ حَاشِ نُن عَ شَ فٍرٍفِرِ بَرَ فبِلٍن عَ مَ.
\b
\q1 
\v 18 ﭑ عَلَتَلَ تَنتُمَ نّ عَ شَ تِنشِنيِ شَ قٍ رَ.
\q1 ﭑ سُوكِ بَمَ نّ عَلَتَلَ شِلِ رَ، عَلَ شِلِ شُنفبٍ كَنيِ.
\c 8
\s1 شِلِ شُنفبٍ كَنيِ نَن لَنشِ عَلَ مَ
\s2 عَلَ مَتْشْي
\d 
\v 1 دَوُدَ شَ بّيتِ بّيتِبَيٍ شَ مَنفّ بّ. عَ شَ بَ مَشَسٍ لُوتِ دَاشِ شُي رَ.
\q1 
\v 2 مُشُ مَرِفِ عَلَتَلَ!
\q1 شِلِ شُنفبٍ كَنيِ نَن لَنشِ عِ مَ دُنِحَ بّندّ قُحِ قَرِ،
\q1 عِ تَن نَشَن مَ نْرّ نَ كٌورٍ مَ.
\q1 
\v 3 دِ مّيٍ نُن دِيْرّيٍ عِ سّنبّ مَتْشْمَ،
\q1 عِ عِ يَشُييٍ نُن عِ فٍرٍقَيٍ دّ بَلَنمَ نَ مَتْشْي رَ.
\b
\q1 
\v 4 ﭑ نَ كٌورٍ مَتٌ،
\q1 عِ نَشَن يَءِلَنشِ عِ بّلّشّ رَ، كِكٍ عَ نُن تُنبُييٍ،
\q1 
\v 5 ﭑ نَن ﭑ يّتّ مَشْرِنمَ نّ،
\q1 «مُنسٍ لَنشِ عَدَ مَ مَ
\q1 عِ تٌ عِ مَحْشُنمَ عَ شَ قٍ مَ؟
\q1 مُنسٍ لَنشِ عَدَ مَدِ مَ
\q1 عِ تٌ عِ حّنفِ سَمَ عَ شَ قٍ شْن مَ؟
\q1 
\v 6 عِ عَ دَاشِ كِ نَشّ،
\q1 عَ فبٍ مُ لُشِ عَ شَ قِندِ مَلٍكّ رَ.
\q1 عِ بَرَ بِنيّ نُن قِسَمَنتٍيَ قِ عَ مَ.
\q1 
\v 7 عِ بَرَ يَامَرِ سٌ عَ يِ رَ عِ شَ دَالِسٍيٍ بِرِن شُن مَ.
\q1 عِ بَرَ دُنِحَ قِندِ عَ سَنيِ بُن مَ سٍ رَ؛
\q1 
\v 8 يّشّييٍ، نِنفٍيٍ، وُلَءِ سُبٍيٍ،
\q1 
\v 9 شْنِ نَشٍيٍ حّرّ مَ كٌورٍ مَ،
\q1 يّشّ نَشٍيٍ بِرِن حّرّ مَ بَا مَ.
\q1 
\v 10 مُشُ مَرِفِ عَلَتَلَ!
\q1 شِلِ شُنفبٍ كَنيِ نَن لَنشِ عِ مَ دُنِحَ بّندّ قُحِ قَرِ!»
\c 9
\s1 عَلَتَلَ كٌلٌنشِ عَ شَ تِنشِنيِ نَن مَ
\s2 عَلَ مَتْشْي
\d 
\v 1 دَوُدَ شَ بّيتِ بّيتِبَيٍ شَ مَنفّ بّ. عَ شَ بَ عَلْ بّيتِ نَشَن شِلِ «دِ شَ قَشّ.»
\q1 
\v 2 عَلَتَلَ، ﭑ عِ تَنتُمَ ﭑ سٌندٌنيِ بِرِن نَ،
\q1 ﭑ عِ شَ وَلِ قَنيِ عِشَرَنمَ مِشِ بِرِن بّ.
\q1 
\v 3 ﭑ سّيوَ مَ نّ عِ شَ قٍ رَ،
\q1 عِ تَن عَلَتَلَ شِلِ شُنفبٍ كَنيِ،
\q1 ﭑ عِ مَتْشْ بّيتِ رَ.
\q1 
\v 4 ﭑ يَشُييٍ فبِلٍنمَ نّ عٍ كٍلِدٍ.
\q1 شَ عٍ بَرَ تِ عِ يَ عِ،
\q1 عٍ سَنيِيٍ مُ شَنمَ بْشِ،
\q1 عٍ نِي مُ شَنمَ دُنِحَ،
\q1 
\v 5 بَرِ مَ عِ شَ تِنشِنيِ كُي،
\q1 عِ تَن مَنفّ بَرَ كِيتِ سٌ ﭑ يِ.
\q1 
\v 6 عِ بَرَ سِ فبّتّيٍ كَلَمُ،
\q1 عِ قٍ كٌبِ رَبَيٍ رَهَلَكِمَ،
\q1 عِ عٍ شِلِ رَلْيمَ نّ هَن دُنِحَ حْن.
\q1 
\v 7 عِ بَرَ عٍ شَ تَايٍ سْنتْ،
\q1 نَ تَا سْنتْشِيٍ لُمَ نّ نَ كِ هَن،
\q1 عٍ شَ قٍ نّيمُ مِشِيٍ رَ!
\q1 
\v 8 عَلَتَلَ شَ مَنفّيَ تِشِ، دَنيِ مُ نَ عَ مَ.
\q1 عَ شَ كِبَنيِ دْشْشِ كِيتِ سَقٍ نَن مَ.
\q1 
\v 9 عَ دُنِحَ مَكِيتِمَ تِنشِنيِ كُي،
\q1 عَ دْشْشِ سِيٍ شُن مَ تِنشِنيِ كُي.
\q1 
\v 10 تْورْ مِشِيٍ كَنتَمَ نَن نَ عَلَتَلَ رَ،
\q1 عٍ رَتَنفَمَ نَ عَ تَن نَن نَ عٍ شَ كْنتْقِلِيٍ كُي.
\q1 
\v 11 عَلَتَلَ، عِ كٌلٌنمَ لَشِ عِ رَ،
\q1 بَرِ مَ عِ سِنفٍ مُ نُ عِ قٍنمَ رَبٌلٌ.
\q1 
\v 12 عَلَتَلَ دْشْشِ عَ شَ فٍيَ سّنِيّنشِ شُن،
\q1 وٌن شَ عَ تَنتُ بّيتِيٍ رَ.
\q1 عَ بَرَ قٍ نَشٍيٍ رَبَ،
\q1 وٌن شَ نٍيٍ مَسٍن سِ بِرِن بّ.
\q1 
\v 13 عَلَ رَتُشِ وُلِ قِلِشِ مَ،
\q1 عَ قَن نَ حْشْمَ نّ.
\q1 عَ تْورْ مِشِيٍ وَ شُي دَنشُنشِ.
\b
\q1 
\v 14 عَلَتَلَ، كِنِكِنِ ﭑ مَ.
\q1 عِ شَ ﭑ مَتٌ.
\q1 عَ مَتٌ ﭑ يَشُييٍ نَ ﭑ تْورْقٍ كِ نَشّ.
\q1 عِ تَن نَشَن ﭑ نَكِسِمَ سَيَ كِرَ مَ،
\q1 
\v 15 عَلَكٌ ﭑ شَ عِ تَنتُ سِيٌنِ حَمَ تَفِ،
\q1 ﭑ شَ سّيوَ عِ شَ كِسِ رَ.
\b
\q1 
\v 16 سِيٍ نُ فَنتَنيِ نَشَن تٍشِ عٍ يَشُييٍ بّ،
\q1 عٍ بَرَ عٍ يّتّ سَنيِيٍ سُشُ عَ رَ.
\q1 
\v 17 عَلَتَلَ كٌلٌنشِ عَ شَ تِنشِنيِ نَن مَ.
\q1 تِنشِنتَرٍيٍ سُشُمَ عٍ يّتّ بّلّشّ قْشِ نَن سَابُي رَ.
\q1 
\v 18 مَتَندِلَ نَشٍيٍ نّيمُمَ عَلَ مَ،
\q1 عٍ بِرِن نَحْنمَ عَلِفِيَمَ نّ.
\q1 
\v 19 عَلَ قَمَ رَتُدٍ تْورْ مِشِ مَ،
\q1 عَ مُ نّيمُمَ عٍ مَ عَبَدَن.
\b
\q1 
\v 20 عَلَتَلَ، كٍلِ، عِ نَشَ عَ لُ عَدَ مَ شَ نْ عِ رَ.
\q1 عَ مَكِيتِ.
\q1 
\v 21 عَلَتَلَ، عِ شَ عٍ مَفَاشُ.
\q1 عٍ شَ عَ كٌلٌن عِبُنَدَ مَ فبَنسَن نَن عٍ رَ.
\c 10
\s1 عِ نَشَ نّيمُ سٍتَرٍ مَ
\s2 عَلَ مَشَندِ
\q1 
\v 1 عَلَتَلَ، عِ عِ مَكُيَشِ ﭑ نَ مُنقٍ رَ؟
\q1 عِ عِ نْشُنشِ مُشُ مَ مُشُ شَ تْورّ كُي مُنقٍ رَ؟
\q1 
\v 2 يّتّ عِفبٌي سٍتَرٍيٍ تْورْ مَ،
\q1 عَ شَ مَحْشُنيِ كٌبِ نْمَ عٍ رَ.
\q1 
\v 3 عَ عَ يّتّ عِفبٌمَ عَ شَ وَلِ حَاشِ شَ قٍ رَ.
\q1 عَلَتَلَ شْنْمَ عَ شَ نَاقُلِ سْتْ كِ مَ.
\q1 
\v 4 مِشِ حَاشِ يّتّ عِفبٌي نَشّ،
\q1 «عَلَ مُ نَ! عَ مُ نْمَ سٍسٍ رَبَدٍ ﭑ نَ!»
\q1 عَ شَ مَحْشُنيِ بِرِن نَن يَ.
\q1 
\v 5 عَ شَ وَلِ بِرِن سْونّيَمَ نّ.
\q1 عَ مُ فَاشُمَ عَلَ شَ كِيتِ يَ رَ.
\q1 عَ يٌمَ عَ يَشُييٍ مَ.
\q1 
\v 6 عَ مَحْشُنمَ عَ بْحّ مَ،
\q1 «سٍسٍ مُ عَ نِيَمَ ﭑ بِرَ.
\q1 تْورّ مَن مُ ﭑ سُشُمَ.»
\q1 
\v 7 عَ دّ مِشِ دَنكَمَ، عَ وُلٍ قَلَ.
\q1 عَ قٍ حَاشِ تِنشِنتَرٍ نَن تُن قَلَمَ.
\q1 
\v 8 عَ مِشِ مّلّنمَ تَا قَرِ مَ،
\q1 عَ شَ مِشِ قَنيِ قَشَ.
\q1 عَ مُ تَفَنمَ قٍ حَاشِ رَبَقٍ رَ مِشِ قَنيِ رَ.
\q1 
\v 9 عَ سٍتَرٍيٍ مّلّنمَ عَلْ يّتّ.
\q1 عَ عٍ سُشُ عَ شَ فَنتَنيِ رَ.
\q1 
\v 10 نَ سٍتَرٍيٍ لُمَ عَ شَ نْي بُن مَ.
\q1 
\v 11 عَ عَ قَلَمَ عَ بْحّ كُي،
\q1 «عَلَ مُ سٍسٍ تٌمَ.
\q1 عَ يَ رَشِشِ.»
\b
\q1 
\v 12 عَلَتَلَ كٍلِ! عِ نَشَ نّيمُ سٍتَرٍ مَ.
\q1 
\v 13 مُنقٍ رَ مِشِ حَاشِ يٌمَ عَلَ مَ؟
\q1 مُنقٍ رَ عَ عَ قَلَمَ عَ يّتّ بّ،
\q1 «عَلَ مُ ﭑ حَشَنكَتَمَ»؟
\q1 
\v 14 كْنْ عَلَ، عِ تْورّ نُن نِمِسّ تٌمَ.
\q1 عِ تْورْ مِشِيٍ مَلِمَ.
\q1 نَشَن مُ نْمَ عَ يّتّ كَنتَدٍ،
\q1 عَ عَ يّتّ تَشُمَ عِ تَن نَ نَ.
\q1 عِ تَن نَن نَ كِرِدِ مَلِمَ رَ.
\q1 
\v 15 مِشِ حَاشِ سّنبّ كَنَ!
\q1 عٍ حَشَنكَتَ عٍ شَ قٍ حَاشِ شَ قٍ رَ!
\q1 عٍ رَلْي يِ دُنِحَ مَ!
\b
\q1 
\v 16 مَنفّ نَن عَلَتَلَ رَ.
\q1 نَ مُ كَنَمَ عَبَدَن.
\q1 كُيٍ بَتُي مُ لُمَ عَ شَ بْشِ مَ.
\q1 
\v 17 عَلَتَلَ، عِ عِ تُلِ تِشِ مِشِ مَفٌرٌشِيٍ رَ.
\q1 عِ لِمَنِيَ قِمَ عٍ مَ.
\q1 عِ عٍ شَ مَشَندِ سُشُمَ.
\q1 
\v 18 عِ تْورْ مِشِ نُن كِرِدِ كَنتَمَ،
\q1 عَلَكٌ عَدَ مَدِ نَشَن قِندِشِ بّندّ رَ،
\q1 عَ نَشَ عٍ مَفَاشُ.
\c 11
\s1 تِنشِنيِ رَقَن عَلَ مَ
\s2 عَلَ مَتْشْي
\d 
\v 1 دَوُدَ شَ بّيتِ بّيتِبَيٍ شَ مَنفّ بّ
\q1 ﭑ بَرَ عَلَتَلَ قِندِ ﭑ يِفِ رَ.
\q1 وٌ عَ قَلَمَ ﭑ بّ دِ،
\q1 «عِ عِ فِ عَلْ شْنِ نَشَن تُفَنمَ سِفَقٍ رَ فٍيَ مَ،
\q1 
\v 2 بَرِ مَ مِشِ حَاشِيٍ بَرَ عٍ شَ شَلِيٍ تٌنفٌ،
\q1 عٍ شَ مِشِ بْحّ قَنيِيٍ قَشَ.»
\q1 
\v 3 شَ سّرِيّ مُ نَ مِشِيٍ تَفِ سْنْن،
\q1 تِنشِنتْي قَ مُنسٍ رَبَمَ؟
\q1 
\v 4 عَلَتَلَ نَ عَ شَ هْرْ مْبَنشِ سّنِيّنشِ كُي.
\q1 عَ شَ كِبَنيِ نَ عَرِيَننَ.
\q1 عَ عَدَ مَدِيٍ مَتٌمَ عَ قَنيِ رَ،
\q1 عَ شَ عَ كٌلٌن نَشَن نَ عٍ سٌندٌنيِ كُي.
\q1 
\v 5 عَلَتَلَ تِنشِنتْي نُن تِنشِنتَرٍ مَتٌمَ.
\q1 فبَلٌي رَقَن نَشٍيٍ مَ، عَ نٍيٍ رَحَاشُ.
\q1 
\v 6 عَ تِنشِنتَرٍ لُمَ تْورّ مْولِ بِرِن كُي.
\q1 نَ لُمَ نّ عَلْ تّ وٌلٍنشِ نُن قٌيٍ حَاشِ.
\q1 
\v 7 عَلَتَلَ تِنشِن.
\q1 تِنشِنيِ رَقَن عَ مَ.
\q1 تِنشِنتْي قَمَ عَ يَتَفِ تٌدٍ.
\c 12
\s1 حَاشُحَ بَرَ فبٌ يّ
\s2 عَلَ مَشَندِ
\d 
\v 1 دَوُدَ شَ بّيتِ بّيتِبَيٍ شَ مَنفّ بّ. عَ شَ بَ كْرَ لُوتِ سٌلٌمَسَشَن شُي رَ.
\q1 
\v 2 عَلَتَلَ، مُشُ رَكِسِ!
\q1 لَنلَنتٍيَ مُ نَ سْنْن،
\q1 نْندِ قَلّيٍ بَرَ حْن عَدَ مَدِيٍ تَفِ.
\q1 
\v 3 كَنكَن عَ بٌورٍ تْوحّفّمَ،
\q1 عَ عَ يَنقَمَ وْيّن حْشُنمّ رَ.
\q1 قِلَنكَقُي نَن عٍ رَ.
\q1 
\v 4 عَلَتَلَ شَ عٍ دّ بَلَن. عٍ دّ عِفبٌ.
\q1 
\v 5 عٍ نَشّ، «مُشُ سّنبّ فبٌ، مُشُ قَتَ وْيّندٍ.
\q1 ندٍ نْمَ مُشُ رَ؟»
\b
\q1 
\v 6 عَلَتَلَ عَ مَسٍنمَ،
\q1 «ﭑ كٍلِمَ تْورْ مِشِ نُن سٍتَرٍ شَ قٍ رَ يَ.
\q1 ﭑ عٍ رَتَنفَمَ مِشِيٍ مَ نَشٍيٍ عٍ حَشَنكَتَمَ.»
\q1 
\v 7 عَلَتَلَ شَ مَسٍنيِ سّنِيّن.
\q1 عَ لُمَ عَلْ فبٍتِ
\q1 مِشِ نَشَن نَشُنُمَ سَنيَ سٌلٌقٍرٍ
\q1 عَلَكٌ عَ فبِ شَ بَ.
\q1 
\v 8 عَلَتَلَ، عِ تْورْ مِشِ كَنتَمَ،
\q1 عِ مُشُ رَتَنفَمَ يِ مِشِ مْولِ مَ تّمُي بِرِن.
\q1 
\v 9 نَ مِشِ حَاشِيٍ عٍ مَحّرّ مَ يِرٍ بِرِن،
\q1 حَاشُحَ بَرَ فبٌ يّ عَدَ مَدِيٍ يَ مَ.
\c 13
\s1 هَن مُن تّمُي؟
\s2 عَلَ مَشَندِ
\d 
\v 1 دَوُدَ شَ بّيتِ بّيتِبَيٍ شَ مَنفّ بّ
\q1 
\v 2 عَلَتَلَ، عِ نّيمُمَ ﭑ مَ هَن مُن تّمُي؟
\q1 عِ عِ نْشُنمَ ﭑ مَ هَن مُن تّمُي؟
\q1 
\v 3 ﭑ بْحّ تْورْ مَ هَن مُن تّمُي؟
\q1 ﭑ سٌندٌنيِ حَشَنكَتَمَ هَن مُن تّمُي؟
\q1 ﭑ لُمَ ﭑ يَشُييٍ بُن مَ هَن مُن تّمُي؟
\q1 
\v 4 ﭑ مَرِفِ عَلَتَلَ، عَ مَتٌ، عِ شَ ﭑ يَابِ.
\q1 تِ ﭑ قَنفَ رَ، شَ نَ مُ ﭑ قَشَمَ نّ،
\q1 
\v 5 ﭑ يَشُييٍ قَ عَ قَلَ، «ﭑ بَرَ نْ عَ رَ.»
\q1 ﭑ يَشُييٍ حّلّشِنمَ نّ ﭑ مَ بِرّ رَ.
\q1 
\v 6 كْنْ ﭑ تَن بَرَ لَ عِ شَ هِننّ رَ،
\q1 ﭑ بْحّ بَرَ حّلّشِن عِ شَ كِسِ شَ قٍ رَ.
\q1 ﭑ بّيتِ بَمَ عَلَتَلَ بّ عَ شَ هِننّ نَن مَ.
\c 14
\s1 حَاشُحَ
\s2 عَلَ مَتْشْي
\d 
\v 1 دَوُدَ شَ بّيتِ بّيتِبَيٍ شَ مَنفّ بّ
\q1 شَشِلِتَرٍ عَ قَلَمَ عَ بْحّ كُي، «عَلَ مُ نَ.»
\q1 عَ بْحّ بَرَ كَنَ، عَ حَاشُحَ نَن تُن نَبَمَ.
\q1 قٍ قَنيِ رَبَيٍ مُ نَ سْنْن.
\q1 
\v 2 عَلَتَلَ عَ يَ رَفٌرٌقٍ عَدَ مَدِيٍ مَ كٍلِ عَرِيَننَ،
\q1 عَ شَ عَ تٌ شَ لْننِلَ ندٍ نَ نَ نَشَن عَلَ قٍنمَ.
\q1 
\v 3 كْنْ بِرِن بَرَ كِرَ بّحِن، عٍ حَاشُ.
\q1 هَلِ قٍ قَنيِ رَبَمَ كٍرٍن مُ نَ سْنْن.
\q1 
\v 4 مَحْشُنيِ قَنيِ مُ نَ قٍ كٌبِ رَبَيٍ بّ؟
\q1 عٍ نَ ﭑ مَ حَمَ شَ فٍينِ نَن تُن دٌنقٍ.
\q1 عٍ مُ عَلَتَلَ شِلِمَ قٍقٍ مَ.
\q1 
\v 5 كْنْ عٍ قَمَ سّرّندٍ عَلَ يَ رَ،
\q1 نَشَن نَ تِنشِنتْييٍ يَ مَ.
\q1 
\v 6 وٌ بَرَ وَ سٍتَرٍيٍ وَشْنقٍ كَنَقٍ،
\q1 كْنْ عٍ كَنتَ مَرِفِ عَلَتَلَ نَ نَ.
\q1 
\v 7 ندٍ قَمَ كِسِ رَ عِسِرَيِلَ بّ كٍلِقٍ سِيٌن؟
\q1 عَلَتَلَ نَن قَمَ عَ شَ حَمَ رَ مِنِدٍ كٌنيِيَ كُي.
\q1 يَشُبَ بْنسْي سّيوَ مَ نّ، عِسِرَيِلَ حّلّشِنمَ نّ!
\c 15
\s1 سَلِ مِشِ
\s2 عَلَ شَ سّرِيّ
\d 
\v 1 دَوُدَ شَ بّيتِ
\q1 عَلَتَلَ، ندٍ نْمَ لُدٍ عِ شَ سَلِدٍ كُي؟
\q1 ندٍ نْمَ سَبَتِدٍ عِ شَ فٍيَ سّنِيّنشِ قَرِ؟
\q1 
\v 2 مِشِ نَشَن حّرّ مَ تِنشِنيِ كِرَ شْن مَ،
\q1 نَشَن قٍ قَنيِ رَبَمَ،
\q1 نَشَن نْندِ قَلَمَ عَ بْحّ قِيشّ رَ.
\q1 
\v 3 عَ مُ مِشِ مَقَلَمَ،
\q1 عَ مُ قٍ حَاشِ رَبَمَ عَ بٌورٍ رَ،
\q1 عَ مَن مُ عَ رَيَافِمَ.
\q1 
\v 4 عَ عَ مَكُيَمَ مِشِ رَ نَشَن مُ رَقَن عَلَ مَ،
\q1 كْنْ عَ مِشِ بِنيَمَ نَشَن فَاشُمَ عَلَ يَ رَ.
\q1 هَلِ عَ تْورْ مَ، عَ مُ عَ شَ مَرَكَلِ مَسَرَ مَ.
\q1 
\v 5 عَ مُ مِشِ دٌنِمَ كْبِرِ رَ عَلَكٌ عَ شَ فٍينِ سْتْ.
\q1 عَ مُ كْبِرِ رَ سُشُمَ عَ شَ وُلٍ سَ مِشِ شُن مَ.
\q1 يِ مِشِ مْولِ مُ دِنكٌنمَ عَبَدَن.
\c 16
\s1 عَلَ شَنُنتٍنيِ
\s2 عَلَ مَتْشْي
\d 
\v 1 دَوُدَ شَ سُوكِ
\q1 عَلَ، عِ شَ ﭑ كَنتَ!
\q1 ﭑ مَ كَنتَرِ نَ عِ يِ رَ.
\q1 
\v 2 عَلَتَلَ، ﭑ مَرِفِ نَن عِ رَ.
\q1 ﭑ مَ قٍ قَنيِ بِرِن نَ عِ تَن نَن يِ.
\q1 
\v 3 يِ بْشِ سّنِيّنتْييٍ رَقَن ﭑ مَ.
\q1 مِشِ شُنفبٍ نَن عٍ رَ.
\q1 
\v 4 كُيٍ بَتُييٍ شَ تْورّ فبٌمَ نّ.
\q1 كْنْ ﭑ تَن مُ سّرّشّ وُلِ دَاشِ بَمَ كُيٍيٍ بّ.
\q1 ﭑ دّ مُ عٍ شِلِ قَلَمَ.
\q1 
\v 5 سٍسٍ مُ نَ ﭑ يِ رَ، قٌ عَلَتَلَ.
\q1 ﭑ وَشْنقٍ بِرِن، عَلَ نَن عَ رَ.
\q1 ﭑ مَ دُنِحّءِفِرِ بِرِن نَ عَلَ يِ رَ.
\q1 
\v 6 عَلَ نَشَن سٌشِ ﭑ يِ رَ نَ قَن ﭑ بّ،
\q1 ﭑ بَرَ حّلّشِن عَ رَ.
\q1 
\v 7 ﭑ بَرَ عَلَتَلَ تَنتُ، عَ مَرَ سِ قِمَ ﭑ مَ.
\q1 هَلِ كْي رَ، ﭑ شَشِلِ سْتْمَ نّ.
\q1 
\v 8 لْشْ يٌ لْشْ ﭑ شَشِلِ تِشِ عَلَتَلَ رَ.
\q1 شَ عَ نَ ﭑ سّيتِ مَ، ﭑ مُ بِرَ مَ.
\q1 
\v 9 ﭑ بْحّ حّلّشِنمَ نّ،
\q1 ﭑ شَشِلِ سّيوَ مَ نّ،
\q1 ﭑ قَتٍ قَن مَلَبُمَ نّ بْحّسَ كُي،
\q1 
\v 10 بَرِ مَ عِ مُ ﭑ نِي رَبّحِنمَ عَلِفِيَمَ.
\q1 عِ مُ عِ شَنُنتٍنيِ لُمَ فَبُرِ كُي.
\q1 
\v 11 عِ سِمَيَ كِرَ مَسٍنمَ ﭑ بّ.
\q1 حّلّشِنيِ فبٍفبٍ نَ عِ يِرٍ.
\q1 قٍ قَنيِ مُ حْنمَ عِ يِرٍ قَنيِ مَ عَبَدَن.
\c 17
\s1 ﭑ مَ كِيتِ بٌلٌن
\s2 عَلَ مَشَندِ
\d 
\v 1 دَوُدَ شَ عَلَ مَشَندِ
\q1 عَلَتَلَ، ﭑ مَ مَشَندِ رَ مّ تِنشِنيِ شَ قٍ رَ.
\q1 عِ تُلِ مَتِ ﭑ وَ شُي رَ.
\q1 عِ تُلِ مَتِ ﭑ مَ مَشَندِ شُي رَ وُلٍ مُ نَ نَشَن كُي.
\q1 
\v 2 عِ شَ ﭑ مَ كِيتِ بٌلٌن،
\q1 بَرِ مَ نَشَن تِنشِن، عِ نَ كٌلٌن.
\q1 
\v 3 عِ نَ ﭑ بْحّ مَتٌ كْي رَ،
\q1 عِ نَ ﭑ مَ دُنِحّءِفِرِ مَتٌ يَنيِ رَ،
\q1 عِ مُ تَنتَنيِ يٌ تٌمَ ﭑ نَ.
\q1 ﭑ مُ تِنمَ وْيّن حَاشِ شَ مِنِ ﭑ دّ عِ.
\q1 
\v 4 مِشِ فبّتّيٍ قٍ حَاشِ رَبَمَ،
\q1 كْنْ ﭑ تَن بَرَ عِ شَ يَامَرِ سُشُ.
\q1 ﭑ مُ بِرَ مَ سُوتٍيٍ شَ كِرَيٍ قْشْ رَ.
\q1 
\v 5 ﭑ بِرَ مَ عِ تَن نَن قْشْ رَ،
\q1 ﭑ مُ نَ كِرَ بّحِنمَ.
\q1 
\v 6 عَلَ، ﭑ عِ شِلِمَ نّ، بَرِ مَ عِ يَابِ قِمَ مِشِ مَ.
\q1 يَندِ، عِ شَ عِ تُلِ مَتِ ﭑ مَ مَشَندِ رَ.
\q1 
\v 7 عِ شَ هِننّ مُشُ رَ،
\q1 عِ تَن نَشَن مِشِيٍ رَكِسِمَ عٍ يَشُييٍ مَ،
\q1 نَشٍيٍ يِفِيَ قٍنمَ عِ رَ.
\q1 
\v 8 مّينِ ﭑ مَ عَلْ عِ يَ قِرِنيِيٍ.
\q1 ﭑ نْشُن عَلْ تْشّيْرّ
\q1 نَشَن عَ نْشُنمَ عَ نفَ فَبُتٍنيِيٍ بُن مَ.
\b
\q1 
\v 9 نَ نَ عَ تٌمَ، مِشِ حَاشِ نَشٍيٍ ﭑ نَبِلِنشِ،
\q1 عٍ مُ نْمَ ﭑ نَ.
\q1 
\v 10 يّتّ عِفبٌي نَن عٍ رَ، عٍ دّ عِفبٌ.
\q1 
\v 11 عٍ بَرَ قَ ﭑ قْشْ رَ يَكْسِ،
\q1 عٍ ﭑ نَبِلِن، عٍ عَلَكٌ عٍ شَ ﭑ قَشَ.
\q1 
\v 12 عٍ لُشِ عَلْ يّتّ نَشَن سُبٍ قٍنمَ،
\q1 عَلْ يّتّ كَامّشِيٍ نَشٍيٍ فبَتَشِ سُبٍ قَشَدٍ.
\q1 
\v 13 عَلَتَلَ، كٍلِ! ﭑ يَشُييٍ فٍرٍ، عِ شَ نْ عٍ رَ.
\q1 ﭑ نَتَنفَ مِشِ حَاشِيٍ مَ عِ شَ سَنتِدّفّمَ رَ.
\q1 
\v 14 ﭑ نَتَنفَ نَ دُنِحَ مِشِ مْولِيٍ مَ،
\q1 نَشٍيٍ عٍ مَسُندِ سْتْمَ يِ دُنِحّءِفِرِ فبَنسَن كُي.
\q1 عٍ رَلُفَ نَ مَسُندِ رَ، عِ نَشَن نَفَتَشِ عٍ بّ.
\q1 عٍ شَ دِيٍ قَن شَ وَ سَ نَ رَ،
\q1 عَ دْنشْي شَ لُ عٍ شَ مَمَدِيٍ بّ!
\q1 
\v 15 كْنْ ﭑ تَن قَمَ نّ عِ يَتَفِ تٌدٍ تِنشِنيِ سَابُي رَ.
\q1 ﭑ نَ شُنُ، ﭑ وَ سَمَ نّ عِ يَتَفِ رَ.
\c 18
\s1 عَلَ سّنبّ مَفَاشُشِ
\s2 عَلَ مَتْشْي
\d 
\v 1 عَلَتَلَ شَ كٌنيِ دَوُدَ شَ بّيتِ بّيتِبَيٍ شَ مَنفّ بّ. عَ يِ بّيتِ نَن بَ عَلَتَلَ بّ عَ تٌ عَ رَتَنفَ سْلُ نُن عَ يَشُي بِرِن مَ.
\q1 
\v 2 عَلَتَلَ، ﭑ سّنبّ نُن ﭑ شَنُنتٍنيِ نَن عِ رَ.
\q1 
\v 3 ﭑ نَكِسِمَ عَلَتَلَ لُمَ عَلْ قَنيٍ، عَ قِندِ ﭑ بّ تّتّ رَ.
\q1 ﭑ مَرِفِ عَلَ لُمَ عَلْ فّمّ شُنفبٍ، ﭑ يِفِيَمَ دّننَشّ.
\q1 سّنبّمَ نَن عَ رَ نَشَن ﭑ نَكِسِمَ،
\q1 نَشَن ﭑ مَكَنتَمَ.
\q1 
\v 4 ﭑ شَ عَ قَلَ ﭑ شُي عِتٍشِ رَ؛
\q1 عَلَ تَنتُ! عَلَ بَرَ ﭑ نَكِسِ ﭑ يَشُييٍ مَ.
\q1 
\v 5 سَيَ نُ بَرَ ﭑ نَبِلِن،
\q1 قَشّ نُ بَرَ فبَكُ ﭑ شُن مَ.
\q1 
\v 6 لَاشِرَ نُ بَرَ مَكْرّ ﭑ نَ،
\q1 فَبُرِ نُ بَرَ عَ دّ رَبِ ﭑ يَ رَ.
\q1 
\v 7 ﭑ عَلَتَلَ مَشَندِ مَ ﭑ مَ تْورّ كُي،
\q1 ﭑ نَن ﭑ مَرِفِ عَلَ شِلِمَ ﭑ شُي عِتٍشِ رَ.
\q1 عَ ﭑ شُي مّمَ عَ شَ هْرْ مْبَنشِ كُي،
\q1 عَ عَ تُلِ مَتِمَ ﭑ وَ شُي رَ.
\q1 
\v 8 بْشِ نَشَ سّرّن،
\q1 فٍيَ نَشَ رَ مَشَ عَلَ شَ شْنّ شَ قٍ رَ.
\q1 
\v 9 عَ شَ شْنّ نَشَ لُ عَلْ تُورِ نَشَن تٍمَ،
\q1 عَلْ تّ نَشَن مِنِمَ عَ دّ عِ،
\q1 عَلْ تّ وٌلٍ دّشّشِ.
\q1 
\v 10 عَلَ نَشَ كُيٍ عِبْو قِرِن نَ، عَ فٌرٌ،
\q1 عَ سَنيِيٍ تِشِ نُشُي عِقْورْشِ قَرِ.
\q1 
\v 11 عَ تِ مَلٍكّ شُن مَ،
\q1 عَ حّرّ كٌورٍ مَ قٌيٍ قَرِ.
\q1 
\v 12 عَ عَ نْشُن دِ مِ كُي،
\q1 تُنّ نُن نُشُي عِقْورْشِيٍ تَفِ.
\q1 
\v 13 سٍيَمَكْنيِ نَشَ مِنِ عَ يَ رَ نُشُييٍ كُي.
\q1 بَلَبَلَنيِ نُن تّ نَشَ فٌرٌ.
\q1 
\v 14 عَلَتَلَ شُي نَشَ لُ عَلْ فَلَنيِ كٍلِقٍ كٌورٍ،
\q1 عَلَ شِلِ شُنفبٍ كَنيِ نَشَ عَ شُي رَ مِنِ،
\q1 بَلَبَلَنيِ نُن تّ قَن نَشَ فٌرٌ.
\q1 
\v 15 عَ نَشَ عَ شَ تَنبّيٍ وٌلِ،
\q1 عَ عَ يَشُييٍ رَيٍنسٍن سٍيَمَكْنيِ يَ رَ.
\q1 
\v 16 بَا نُن بْشِ نَشَ رَبِ عَلَتَلَ شَ شْنّ يَ رَ.
\b
\q1 
\v 17 عَلَتَلَ نَشَ ﭑ سُشُ كٍلِقٍ كٌورٍ مَ،
\q1 عَ ﭑ بَ يٍ شْورَ.
\q1 
\v 18 عَ نَشَ ﭑ نَتَنفَ ﭑ يَشُي سّنبّمَيٍ مَ،
\q1 ﭑ شْنمِشِ نَشٍيٍ سّنبّ فبٌ ﭑ بّ.
\q1 
\v 19 عٍ نَشَ ﭑ فٍرٍ ﭑ مَ تْورّ كُي،
\q1 كْنْ عَلَتَلَ نَشَ ﭑ نَتَنفَ.
\q1 
\v 20 عَ نَشَ ﭑ نَمِنِ فبَلٌي كُي عَ شَ شَنُنتٍيَ سَابُي رَ.
\q1 
\v 21 عَلَتَلَ بَرَ ﭑ مَ تِنشِنيِ سَرٍ رَفبِلٍن ﭑ مَ،
\q1 عَ بَرَ ﭑ مَلِ ﭑ مَ كّوَلِ سّنِيّنشِ شَ قٍ رَ.
\q1 
\v 22 ﭑ بَرَ لُ عَلَتَلَ شَ كِرَ شْن،
\q1 ﭑ مُ ﭑ مَرِفِ عَلَ بّحِن كٌبِحَ رَ.
\q1 
\v 23 ﭑ بَرَ عَ شَ سّرِيّ بِرِن سُشُ،
\q1 ﭑ مُ تٌندِشِ عَ شَ يَامَرِيٍ رَبَتُدٍ.
\q1 
\v 24 ﭑ بَرَ تِنشِن عَ يَ رَ،
\q1 ﭑ مُ تِن بِرَدٍ يُنُبِ قْشْ رَ.
\q1 
\v 25 عَلَتَلَ بَرَ ﭑ مَ تِنشِنيِ سَرٍ رَفبِلٍن ﭑ مَ،
\q1 عَ بَرَ ﭑ مَلِ ﭑ مَ كّوَلِ سّنِيّنشِ شَ قٍ رَ.
\b
\q1 
\v 26 عِ دُفُتّفّحَ مَسٍنمَ دُفُتّفّحَ كَنيِ بّ.
\q1 عِ تِنشِنيِ مَسٍنمَ تِنشِنتْي بّ.
\q1 
\v 27 عِ سّنِيّنيِ مَسٍنمَ سّنِيّنتْي بّ،
\q1 كْنْ عِ كْوتَ ندٍ رَبَمَ مِشِ حَاشِ رَ.
\q1 
\v 28 عِ يّتّ مَفٌرٌي رَكِسِمَ نّ،
\q1 كْنْ عِ يّتّ عِفبٌي تَن مَفٌرٌ مَ نّ.
\q1 
\v 29 عَلَتَلَ، عِ تَن نَن نَءِيَلَنيِ رَ ﭑ بّ.
\q1 ﭑ مَرِفِ عَلَ، ﭑ بَ دِ مِ كُي.
\q1 
\v 30 شَ وٌن بِرِن نَ عَ رَ،
\q1 ﭑ مُ فَاشُمَ فَلِ شُنفبٍ فٍرٍدٍ.
\q1 ﭑ نْمَ فٍرٍ شْرْشْي رَ عَلَ شَ مَلِ سَابُي رَ.
\q1 
\v 31 عَلَ شَ كِرَ قَن.
\q1 عَلَتَلَ شَ مَسٍنيِ تِنشِن.
\q1 عَ مِشِيٍ كَنتَمَ نَشٍيٍ يِفِيَ قٍنمَ عَ رَ.
\q1 
\v 32 عَلَ فبّتّ مُ نَ، قٌ عَلَتَلَ.
\q1 سّنبّمَ مُ نَ، قٌ وٌن مَرِفِ عَلَ.
\q1 
\v 33 عَلَ نَن سّنبّ قِمَ ﭑ مَ،
\q1 عَ ﭑ نَحّرّ سّنِيّنيِ كُي.
\q1 
\v 34 عَ ﭑ مَلِمَ ﭑ شَ لُ عَلْ شٍلِ،
\q1 نَشَن قَتَ حّرّدٍ يِرٍ شْرْشْي.
\q1 
\v 35 عَ بَرَ ﭑ نَقَلَ فٍرٍ كُي،
\q1 عَ ﭑ مَلِمَ شَلِ قَنيِ رَوَلِدٍ.
\q1 
\v 36 عِ بَرَ ﭑ شُن نَكٍلِ،
\q1 عِ بَرَ ﭑ تٌنفٌ عِ شْنيّ عِ،
\q1 عِ بَرَ عِ حّنفِ سَ ﭑ شْن مَ.
\q1 نَ نَن عَ نِيَشِ ﭑ دَرِيّ سْتْشِ،
\q1 
\v 37 ﭑ سّنبّ سْتْشِ، عَلَكٌ ﭑ نَشَ بِرَ.
\b
\q1 
\v 38 ﭑ بِرَ مَ ﭑ يَشُييٍ قْشْ رَ هَن ﭑ عٍ سُشُ.
\q1 ﭑ مُ فبِلٍنمَ عٍ قْشْ رَ قٌ ﭑ نْ عٍ رَ.
\q1 
\v 39 ﭑ نٍيٍ رَبِرَ مَ نّ هَن عٍ مُ نْ كٍلِدٍ سْنْن،
\q1 عٍ قَ لُ ﭑ سَنيِ بُن.
\q1 
\v 40 عِ سّنبّ سٌمَ ﭑ يِ رَ ﭑ مَ فٍرٍ كُي.
\q1 عِ ﭑ يَشُييٍ رَفٌرٌ مَ ﭑ بُن مَ،
\q1 
\v 41 عِ عَ نِيَ ﭑ شَ نْ عٍ رَ.
\q1 ﭑ شْنمِشِيٍ مُ وْيّنمَ سْنْن.
\q1 
\v 42 عٍ مِشِيٍ شِلِمَ عٍ شَ قَ عٍ مَلِ،
\q1 كْنْ مِشِ يٌ مُ عٍ رَكِسِمَ.
\q1 عٍ عَلَتَلَ شِلِمَ، كْنْ عَ قَن مُ عٍ يَابِمَ.
\q1 
\v 43 ﭑ عٍ لُشُتَمَ نّ عٍ قَ لُ عَلْ شُبٍ،
\q1 قٌيٍ نَشَن شَنِنمَ.
\q1 ﭑ عٍ بٌرٌنمَ عَلْ بّندّ.
\b
\q1 
\v 44 عِ بَرَ ﭑ نَتَنفَ حَمَ مُرُتَشِ مَ،
\q1 عِ قَ ﭑ قِندِ سِيٍ شُنيِ رَ.
\q1 ﭑ مُ نَشَن كٌلٌن نَ بَرَ لُ ﭑ بُن مَ.
\q1 
\v 45 عٍ ﭑ شُي رَبَتُمَ،
\q1 شْحّيٍ وْيّن حْشُنمّ قَلَمَ ﭑ بّ.
\q1 
\v 46 عٍ مُ سُو سَمَ ﭑ يَ رَ.
\q1 عٍ مِنِمَ عٍ شَ تّتّ مَكَنتَشِ كُي فَاشُي رَ.
\q1 
\v 47 عَلَتَلَ سّنبّ مُ حْنمَ عَبَدَن.
\q1 تَنتُي نَ ﭑ مَ كَنتَمَ بّ.
\q1 تَنتُي نَ ﭑ مَرِفِ عَلَ مَرَكِسِمَ بّ.
\q1 
\v 48 عَلَ نَن ﭑ فبٍحْشْمَ.
\q1 عَلَ نَن سِيٍ رَبِرَ مَ ﭑ مَ نْي بُن مَ.
\q1 
\v 49 عَلَ نَن ﭑ نَتَنفَمَ ﭑ يَشُييٍ مَ.
\q1 عِ تَن نَن ﭑ عِتٍمَ ﭑ يَشُييٍ شُن مَ.
\q1 عِ تَن نَن ﭑ نَتَنفَمَ سُوتٍيٍ مَ.
\q1 
\v 50 عَلَتَلَ، ﭑ عِ تَنتُمَ سِيٍ تَفِ نَ بِرِن نَن مَ،
\q1 ﭑ بّيتِ بَمَ نّ عِ بّ.
\q1 
\v 51 عَ شُننَكٍلِ نُن هِننّ قِمَ نّ عَ شَ مِشِ سُفَندِشِ مَ،
\q1 نَشَن قِندِ مَنفّ دَوُدَ نُن عَ شَ دِيٍ رَ عَبَدَن.
\c 19
\s1 عَلَ شَ نْرّ نُن سّرِيّ
\s2 عَلَ مَتْشْي
\d 
\v 1 دَوُدَ شَ بّيتِ بّيتِبَيٍ شَ مَنفّ بّ
\q1 
\v 2 كٌورٍ عَلَ شَ نْرّ مَسٍنمَ.
\q1 كٌورٍ وَلَشّ عَلَ شَ وَلِ مَسٍنمَ.
\q1 
\v 3 يَنيِ لْننِ مَسٍنمَ لْشْ يٌ لْشْ.
\q1 دِ مِ شَشِلِ مَسٍنمَ كْي يٌ كْي.
\q1 
\v 4 شُي يَتِ يَتِ مُ عَ رَ،
\q1 وْيّنيِ قَن مُ عَ رَ.
\q1 تُلِ مُ نْمَ عٍ شُي مّدٍ.
\q1 
\v 5 عٍ قْشِ تٌمَ دُنِحَ بِرِن مَ.
\q1 عٍ قْشِ يِرٍ مَكُيٍ بِرِن لِمَ،
\q1 هَن سٌفٍ سَ سَمَ كَنكِرَ نَشَن كُي.
\q1 
\v 6 سٌفٍ مِنِمَ نّ عَلْ شّمّ نَشَن بَشِ فِنّ دْشْدٍ،
\q1 عَ قَ مِنِ عَ شَ كٌنكٌي كُي،
\q1 عَلْ مِشِ شُنفبٍ نَشَن حّرّ مَ عَ يّتّ شَ كِرَ شْن.
\q1 
\v 7 عَ حّرّ قْلْمَ سٌفٍتٍدٍ، عَ سَ حْن سٌفٍفٌرٌدٍ.
\q1 سٍسٍ مُ نْمَ عَ وُيٍنيِ بَدٍ.
\b
\q1 
\v 8 عَلَتَلَ شَ سّرِيّ، سّرِيّ قَنيِ نَ عَ رَ.
\q1 عَ سّنبّ قِمَ مِشِ مَ.
\q1 عَلَتَلَ شَ نْندِ، نْندِ يَتِ نَ عَ رَ.
\q1 عَ لْننِتَرٍ قِندِ مَ لْننِلَ رَ.
\q1 
\v 9 عَلَتَلَ شَ نْي، نْي تِنشِنشِ نَ عَ رَ.
\q1 عَ مِشِ بْحّ رَحّلّشِنمَ نّ.
\q1 عَلَتَلَ شَ مَسٍنيِ، مَسٍنيِ تِنسٍشِ نَ عَ رَ.
\q1 عَ مِشِ شَشِلِ يَ رَبِمَ نّ.
\q1 
\v 10 عَلَتَلَ شَ يَرَفَاشُي، قٍ سّنِيّنشِ نَ عَ رَ.
\q1 عَ مُ حْنمَ عَبَدَن.
\q1 عَلَتَلَ شَ يَامَرِ، يَامَرِ قَنيِ نَ عَ رَ.
\q1 عَ بِرِن تِنشِن.
\q1 
\v 11 عَلَ شَ يَامَرِ، عَ قَن شّيمَ بّ،
\q1 عَ قَن دَنفِ شّيمَ قَنيِ بِرِن نَ.
\q1 عَلَ شَ يَامَرِ، عَ حْشُن كُمِ بّ،
\q1 عَ حْشُن دَنفِ كُمِ قَنيِ بِرِن نَ.
\b
\q1 
\v 12 عِ شَ كٌنيِ شَشِلِ سْتْمَ نّ عِ شَ سّرِيّ كُي.
\q1 عَ فٍينِ فبٍفبٍ تٌمَ نّ نَا.
\q1 
\v 13 ندٍ نْمَ عَ يّتّ كَن يُفٍ حَاشِيٍ بِرِن كٌلٌندٍ؟
\q1 عِ شَ ﭑ مَ يُنُبِ نْشُنشِ شَقَرِ ﭑ مُ نَشَن كٌلٌن.
\q1 
\v 14 عِ شَ ﭑ مَ يُنُبِ مَكّنّنشِ مَكُيَ ﭑ نَ.
\q1 عَ نَشَ ﭑ سُشُ سّنبّ رَ.
\q1 نَ تّمُي ﭑ قَمَ قِندِدٍ مِشِ تِنشِنشِ رَ،
\q1 نَشَن مُ يُنُبِ حَاشِ رَبَمَ.
\q1 
\v 15 وْيّنيِ نَشَن كٍلِمَ ﭑ دّ عِ،
\q1 عَ نُن وْيّنيِ نَشَن كٍلِمَ ﭑ بْحّ مَ،
\q1 عَلَ شَ نَ تٌنفٌ ﭑ بّ حّلّشِنيِ رَ.
\q1 عَلَتَلَ، ﭑ كَنتَمَ نَن عِ رَ، عِ بَرَ ﭑ شُنسَرَ.
\c 20
\s1 عَلَ شَ مَنفّ مَلِ
\s2 عَلَ مَشَندِ
\d 
\v 1 دَوُدَ شَ بّيتِ بّيتِبَيٍ شَ مَنفّ بّ
\q1 
\v 2 عَلَتَلَ شَ عِ يَابِ عِ شَ تْورّ كُي.
\q1 يَشُبَ مَرِفِ عَلَ شَ عِ رَتَنفَ.
\q1 
\v 3 عَلَ شَ عِ مَلِ كٍلِقٍ عَ شَ يِرٍ سّنِيّنشِ،
\q1 عَ شَ عِ مَلِ كٍلِقٍ سِيٌن فٍيَ قَرِ.
\q1 
\v 4 عَلَ شَ عِ شَ سّرّشّ بِرِن سُشُ،
\q1 عَ شَ حّلّشِن عِ شَ سّرّشّ فَن دَاشِيٍ رَ. \qs حّنفِ رَتٍ.\qs*
\q1 
\v 5 عَلَ شَ عِ وَشْنقٍ قِ عِ مَ،
\q1 عَ شَ عِ شَ وَلِ سْونّيَ عِ بّ.
\q1 
\v 6 وٌن وٌن شُي عِتٍمَ حّلّشِنيِ كُي.
\q1 وٌن وٌن مَ تْنشُمَ عِتٍمَ وٌن مَرِفِ عَلَ شِلِ رَ.
\q1 عَلَتَلَ شَ عِ شَ مَشَندِ بِرِن نَسُشُ.
\b
\q1 
\v 7 ﭑ عَ كٌلٌن عَ عَلَتَلَ عَ شَ مِشِ سُفَندِشِ رَكِسِمَ نّ.
\q1 عَ عَ يَابِمَ نّ عَ سّنبّ رَ كٍلِقٍ رَ عَ شَ يِرٍ سّنِيّنشِ.
\q1 
\v 8 ندٍ لَمَ عَ شَ سْورِ رَفِسٍ رَ،
\q1 ندٍ لَمَ عَ شَ سٌييٍ رَ،
\q1 كْنْ وٌن تَن لَشِ وٌن مَرِفِ عَلَتَلَ شِلِ نَن نَ.
\q1 
\v 9 سٌييٍ تَن بِرَ مَ نّ،
\q1 كْنْ وٌن تَن تِشِ تُن.
\q1 
\v 10 عَلَتَلَ شَ مَنفّ رَكِسِ،
\q1 عَ شَ وٌن مَ مَشَندِ سُشُ.
\c 21
\s1 مَنفّ بَرَكَتْي
\s2 عَلَ مَتْشْي
\d 
\v 1 دَوُدَ شَ بّيتِ بّيتِبَيٍ شَ مَنفّ بّ
\q1 
\v 2 عَلَتَلَ، مَنفّ بَرَ سّيوَ عِ سّنبّ رَ.
\q1 عَ شَ حّلّشِنيِ فبٌ بَرِ مَ عِ بَرَ عَ رَكِسِ.
\q1 
\v 3 عِ بَرَ عَ وَشْنقٍ رَبَ،
\q1 عِ بَرَ عَ شَ دُبّ سُشُ. \qs حّنفِ رَتٍ.\qs*
\q1 
\v 4 عِ قَمَ بَرَكّ رَ عَ بّ،
\q1 عِ تْنشُمَ مَنفّ دَاشِ دْشْمَ عَ شُن مَ،
\q1 عَ يَءِلَنشِ شّيمَ رَ.
\q1 
\v 5 عَ بَرَ عِ مَشَندِ عَ شَ سِمَيَ شَ قٍ رَ.
\q1 عِ بَرَ نَ مَشَندِ سُشُ،
\q1 عَ شَ سِمَيَ شْن نَشَ كُيَ هَن.
\q1 
\v 6 عِ تٌ عَ رَكِسِ، عَ شَ بِنيّ نَشَ فبٌ.
\q1 عِ نَشَ شُننَكٍلِ نُن بِنيّ قِ عَ مَ.
\q1 
\v 7 عِ نَشَ عَ قِندِ بَرَكَتْي شُنفبٍ رَ.
\q1 عِ نَشَ عَ رَ سّيوَ عِ يَ عِ.
\q1 
\v 8 مَنفّ لَمَ عَلَتَلَ نَن نَ.
\q1 عَ مُ بِرَ مَ عَلَ شِلِ شُنفبٍ شَ هِننّ سَابُي رَ.
\b
\q1 
\v 9 عِ قَمَ عِ يَشُي بِرِن سُشُدٍ.
\q1 عِ قَمَ نْدٍ عِ شْنمِشِيٍ رَ.
\q1 
\v 10 عِ نَ قَ، عِ عٍ حْنمَ نّ،
\q1 عَلْ تّ بٍلٍبٍلٍ وُرِ فَنمَ كِ نَشّ.
\q1 عَلَتَلَ شْنْمَ عٍ مَ هَن تّ عٍ فَن.
\q1 
\v 11 عِ بْنسْييٍ بَمَ نّ دُنِحَ مَ، عِ عَدَ مَدِيٍ رَحْن.
\q1 
\v 12 عٍ بَرَ وَ قٍ حَاشِ رَبَقٍ عِ رَ.
\q1 عٍ بَرَ كَتَ هَن،
\q1 كْنْ نَ مُ قِندِشِ سْونّيَ يٌ رَ عٍ بّ،
\q1 
\v 13 بَرِ مَ عِ تَن نَن قَمَ عٍ رَفِدٍ عِ شَ شَلِ رَ.
\q1 
\v 14 عَلَتَلَ، عِ شَ عِ سّنبّ مَسٍن عٍ بّ.
\q1 مُشُ وَ مَ بّيتِ بَقٍ عِ يَ شْرِ،
\q1 مُشُ شَ عِ مَتْشْ عِ سّنبّ شَ قٍ رَ.
\c 22
\s1 عَلَ، عِ نَشَ عِ مَكُيَ ﭑ نَ
\s2 عَلَ مَشَندِ
\d 
\v 1 دَوُدَ شَ بّيتِ بّيتِبَيٍ شَ مَنفّ بّ. عَ شَ بَ عَلْ بّيتِ نَشَن شِلِ «سُبَشّ شٍلِ.»
\q1 
\v 2 عَلَ، ﭑ مَرِفِ عَلَ، عِ ﭑ نَبٌلٌشِ مُنقٍ رَ؟
\q1 عِ كِسِ مَكُيَ ﭑ نَ، عِ مُ ﭑ وَ شُي رَ مّ؟
\q1 
\v 3 ﭑ مَرِفِ عَلَ، كْي نُن يَنيِ، ﭑ عِ شِلِمَ،
\q1 كْنْ عِ مُ ﭑ مَ شِلِ رَتِنمَ.
\q1 
\v 4 كْنْ عِ تَن سّنِيّنتْي،
\q1 عِ شَ كِبَنيِ رَبِلِنشِ عِسِرَيِلَ شَ تَنتُي رَ.
\q1 
\v 5 مُشُ بٍنبَيٍ بَرَ دَنشَنِيَ عِ مَ.
\q1 عِ بَرَ عٍ رَكِسِ عٍ شَ دَنشَنِيَ سَابُي رَ.
\q1 
\v 6 عٍ تٌ عِ شِلِ، عِ نَشَ عٍ شْرّيَ.
\q1 عٍ بَرَ دَنشَنِيَ عِ مَ.
\q1 عِ مُ عٍ لُ يَافِ كُي.
\b
\q1 
\v 7 كْنْ ﭑ تَن بَرَ قِندِ مِشِ شُرِ رَ عَلْ دٌندٌلِ،
\q1 عَلْ مِشِ مُ نَ ﭑ تَن نَ.
\q1 عَدَ مَدِيٍ ﭑ نَيَافِمَ، مِشِيٍ ﭑ مَيٍلٍمَ.
\q1 
\v 8 مِشِ نَشَن بِرِن ﭑ تٌمَ،
\q1 عٍ يٌمَ ﭑ مَ.
\q1 عٍ دّ ثّتّسِمَ ﭑ مَ،
\q1 عٍ عٍ بّلّشّسٌلٍ تِمَ ﭑ مَ عَ حَاشِ رَ.
\q1 
\v 9 عٍ نَشّ، «عِ يَ تِ عَلَتَلَ رَ.
\q1 عَ عِ رَكِسِمَ، عَ عِ رَتَنفَمَ،
\q1 بَرِ مَ عِ رَقَن عَ مَ!»
\q1 
\v 10 عٍٍ عَلَ، عِ بَرَ ﭑ نَمِنِ ﭑ نفَ تّيفّ،
\q1 عِ بَرَ ﭑ سَ عَ كَنكٍ مَ.
\q1 
\v 11 ﭑ شَشِلِ تِشِ عِ رَ كَقِ ﭑ بَرِ تّمُي.
\q1 عِ قِندِشِ ﭑ مَرِفِ عَلَ رَ كَقِ ﭑ بَشِ قٌيٍ تٌدٍ.
\q1 
\v 12 عِ نَشَ عِ مَكُيَ ﭑ نَ،
\q1 بَرِ مَ كْنتْقِلِ بَرَ وُيَ ﭑ شُن.
\q1 مَلِلَ يٌ مُ نَ ﭑ قّ مَ.
\b
\q1 
\v 13 سّنبّمَيٍ بَرَ ﭑ نَبِلِن عَلْ بَسَن تُورَيٍ.
\q1 
\v 14 عٍ دّ رَبِشِ عَلْ يّتّ شَاحّيٍ.
\q1 
\v 15 ﭑ نِي نَ بَقٍ ﭑ قَتٍ، ﭑ شْرِيٍ نَ بَقٍ عٍ رَدْشْدٍيٍ.
\q1 ﭑ بْحّ مُ سَمَ، لِمَنِيَ بَرَ بَ ﭑ يِ.
\q1 
\v 16 ﭑ سّنبّ دٌلٌشِ عَلْ بٌورَ.
\q1 ﭑ نّنيِ بَرَ كَنكَن ﭑ كْن نَ.
\q1 عِ نَ ﭑ مَقِندِقٍ بّندّ رَ.
\q1 
\v 17 مِشِ حَاشِ فَلِ بَرَ ﭑ نَبِلِن عَلْ بَرٍيٍ.
\q1 عٍ بَرَ ﭑ بّلّشّ نُن ﭑ سَنيِ تُنبَ.
\q1 
\v 18 ﭑ شْرِ بِرِن سَشِ كّنّ مَ.
\q1 عٍ يَ بَنبَنشِ ﭑ نَ.
\q1 
\v 19 عٍ ﭑ مَ دُفِيٍ عِتَشُنمَ عٍ بٌرٍ مَ،
\q1 عٍ ﭑ مَ دُفِ قَنيِ مَتٌمَ عَ لَنمَ عَ شَ لُ نَشَن بّ.
\b
\q1 
\v 20 عَلَتَلَ، عِ نَشَ عِ مَكُيَ ﭑ نَ!
\q1 ﭑ مَ سّنبّمَ نَن عِ رَ.
\q1 عِ شَ عِ شُلُن ﭑ مَلِدٍ.
\q1 
\v 21 عِ شَ ﭑ نِي رَكِسِ سَنتِدّفّمَ مَ.
\q1 عِ شَ ﭑ نَتَنفَ نَ بَرٍيٍ مَ.
\q1 
\v 22 عِ شَ ﭑ نَكِسِ نَ يّتّيٍ مَ.
\q1 عِ شَ ﭑ نَكِسِ نَ تُورَيٍ قٍرِيٍ مَ.
\b
\q1 
\v 23 ﭑ عِ شِلِ مَسٍنمَ نّ ﭑ مَ مِشِيٍ بّ،
\q1 ﭑ عِ مَتْشْمَ نّ حَمَ تَفِ.
\q1 
\v 24 وٌ تَن نَشَن فَاشُمَ عَلَتَلَ يَ رَ،
\q1 وٌ شَ عَ تَنتُ.
\q1 وٌ تَن نَشَن كٍلِشِ وٌ بٍنبَ يَشُبَ بْنسْي،
\q1 وٌ شَ عَ مَتْشْ.
\q1 وٌ تَن نَشَن كٍلِمَ عِسِرَيِلَ بْنسْي،
\q1 وٌ شَ فَاشُ عَ يَ رَ.
\q1 
\v 25 عَلَ مُ يٌمَ مِسِكِينّ شَ تْورّ مَ.
\q1 عَ مُ عَ يّتّ نْشُنمَ عَ مَ شّ،
\q1 عَ عَ شَ مَشَندِ سُشُمَ نّ.
\q1 
\v 26 عَلَ، ﭑ عِ مَتْشْمَ حَمَ شُنفبٍ يَ مَ.
\q1 ﭑ قَمَ ﭑ مَ لَايِدِ رَكَمَلِدٍ مِشِيٍ بّ،
\q1 نَشٍيٍ فَاشُمَ عَلَ يَ رَ.
\q1 
\v 27 مِشِ مَفٌرٌشِيٍ قَمَ عٍ دّفٍدٍ، هَن عٍ وَ سَ.
\q1 نَشٍيٍ عَلَتَلَ قٍنمَ، عٍ قَمَ عَ مَتْشْدٍ.
\q1 عَلَ شَ سِمَيَ قِ وٌ مَ.
\q1 
\v 28 دُنِحَ بِرِن قَمَ رَتُدٍ عَلَتَلَ شَ قٍ مَ،
\q1 عٍ مَن بِرِن عٍ يَ رَقِندِ مَ عَ مَ.
\q1 سِ بِرِن قَمَ عٍ مَفٌرٌدٍ عَ بّ،
\q1 
\v 29 بَرِ مَ بِرِن نَ عَلَتَلَ شَ مَنفّيَ نَن بُن.
\q1 عَ سِ بِرِن يَمَرِ مَ.
\q1 
\v 30 دُنِحَ سّنبّمَيٍ نَ فّ عٍ دّفٍدٍ،
\q1 عٍ بِرِن قَمَ عٍ مَفٌرٌدٍ عَلَ بّ.
\q1 نَشٍيٍ بِرِن قِندِ مَ بّندّ رَ،
\q1 عٍ قَمَ عٍ شُن سِندٍ عَلَ بّ.
\q1 عٍ مُ نْمَ عٍ يّتّ نِي رَتَنفَدٍ.
\q1 
\v 31 عَدَ مَدِيٍ بِرِن قَمَ عَلَ بَتُدٍ.
\q1 عٍ عٍ مَرِفِ شَ قٍ قَلَمَ عٍ بٌرٍ بّ.
\q1 
\v 32 عَلَ قَمَ عَ شَ تِنشِنيِ مَسٍندٍ
\q1 مِشِ بِرِن بّ نَشٍيٍ قَمَ بَرِدٍ.
\q1 عَلَ بَرَ نَ رَفِرِ.
\c 23
\s1 عَلَتَلَ ﭑ مّينِمَ
\s2 عَلَ مَتْشْي
\d دَوُدَ شَ بّيتِ
\q1 
\v 1 عَلَتَلَ ﭑ مّينِمَ
\q1 عَلْ شُرُ سٍ كَنتّ عَ شَ شُرُ سٍ مّينِمَ كِ نَشّ.
\q1 سٍ بِرِن نَ ﭑ يِ رَ ﭑ هَيِ نَ نَشَن مَ.
\q1 
\v 2 عَلَتَلَ ﭑ شَنِنمَ قٍ قَنيِ مَ،
\q1 عَلْ شُرُ سٍ كَنتّ شُرُ سٍيٍ شَنِنمَ حٌوفٍ قَنيِ مَ كِ نَشّ،
\q1 عَلْ عَ عٍ شُن تِمَ يٍ رَشَرَشِ رَ كِ نَشّ.
\q1 
\v 3 عَ سّنبّ قِمَ ﭑ مَ.
\q1 عَ ﭑ تِمَ كِرَ تِنشِنشِ شْن، بَرِ مَ عَلَتَلَ نَن عَ رَ.
\q1 
\v 4 هَلِ ﭑ حّرّ دِ مِ كُي، ﭑ مُ فَاشُمَ،
\q1 بَرِ مَ عِ نَ ﭑ سّيتِ مَ.
\q1 عِ ﭑ كَنتَمَ، عِ ﭑ شُن تِمَ يِرٍ قَنيِ رَ.
\q1 
\v 5 عِ دٌنسٍ رَقَلَمَ ﭑ بّ ﭑ يَشُييٍ يَ شْرِ.
\q1 عِ سٍ شِرِ حْشُنمّ سَمَ ﭑ مَ.
\q1 عِ ﭑ مَ ثْوتِ رَقٍمَ مِنسٍ رَ عَ قَنيِ رَ.
\q1 
\v 6 هّيرِ نُن هِننّنتٍيَ بِرَ مَ ﭑ قْشْ رَ ﭑ مَ دُنِحّءِفِرِ كُي.
\q1 ﭑ لُمَ نّ عَلَ شَ هْرْ مْلِنفِرَ كُي لْشْ يٌ لْشْ،
\q1 هَن ﭑ مَ دُنِحّءِفِرِ حْن.
\c 24
\s1 ندٍ سٌمَ عَلَ شَ هْرْ مْبَنشِ كُي؟
\s2 عَلَ شَ سّرِيّ
\d دَوُدَ شَ بّيتِ
\q1 
\v 1 عَلَتَلَ نَن فبٍ نَ بْشِ نُن عَ عِسٍيٍ بِرِن نَ،
\q1 دُنِحَ نُن عَدَ مَدِ بِرِن.
\q1 
\v 2 عَ تَن نَن بْشِ دْشْشِ بَايٍ نُن شُرٍيٍ تَفِ.
\q1 
\v 3 ندٍ نْمَ تٍدٍ عَلَتَلَ شَ فٍيَ قَرِ؟
\q1 ندٍ نْمَ سٌدٍ عَ شَ هْرْ مْبَنشِ كُي؟
\q1 
\v 4 نَشَن شَ وَلِ قَن،
\q1 نَشَن بْحّ سّنِيّن،
\q1 نَشَن مُ بِرَ مَ قٍ قُقَقُ قْشْ رَ،
\q1 نَشَن مُ وُلٍ قَلَمَ،
\q1 نَ كَنيِ نَن سٌمَ عَلَ شَ هْرْ مْبَنشِ كُي.
\q1 
\v 5 عَلَتَلَ بَرَكّ سَمَ عَ مَ،
\q1 عَ رَكِسِمَ عَلَ عَ سَرٍ رَفبِلٍنمَ عَ مَ.
\q1 
\v 6 يِ مِشِ مْولِ نَن عَلَ قٍنمَ.
\q1 يَشُبَ شَ مِشِيٍ وَ مَ عَلَ كٌلٌنقٍ. \qs حّنفِ رَتٍ.\qs*
\b
\q1 
\v 7 تّتّ نَادّيٍ شَ رَبِ،
\q1 هْرْ مْبَنشِ نَادّ قٌرِيٍ قَن شَ رَبِ.
\q1 نْرّ كَنيِ نَ سٌقٍ.
\q1 
\v 8 ندٍ نَ يِ نْرّ كَنيِ رَ؟
\q1 عَلَتَلَ سّنبّمَ نَن عَ رَ،
\q1 عَلَتَلَ، نَشَن سّنبّ فبٌ فٍرٍ كُي.
\q1 
\v 9 تّتّ نَادّيٍ شَ رَبِ،
\q1 هْرْ مْبَنشِ نَادّ قٌرِيٍ قَن شَ رَبِ.
\q1 نْرّ كَنيِ نَ سٌقٍ.
\q1 
\v 10 ندٍ نَ يِ نْرّ كَنيِ رَ؟
\q1 مَنفّ عَلَتَلَ نَن نْرّ كَنيِ رَ.
\c 25
\s1 عَلَ، هِننّ ﭑ نَ
\s2 عَلَ مَشَندِ
\d دَوُدَ فبٍ
\q1 
\v 1 ﭑ شَشِلِ تِشِ عِ تَن عَلَتَلَ نَن نَ.
\q1 
\v 2 ﭑ مَرِفِ عَلَ، ﭑ بَرَ ﭑ يّتّ تَشُ عِ رَ
\q1 عَلَكٌ يَافِ نَشَ ﭑ سْتْ،
\q1 عَلَكٌ ﭑ يَشُييٍ نَشَ ﭑ مَيٍلٍ.
\q1 
\v 3 نَشَن يٌ لَ عِ رَ، نَ كَنيِ مُ يَافِ سْتْمَ،
\q1 كْنْ يَنقَنتٍ تَن، يَافِ سْتْمَ نّ عَ قَنيِ رَ.
\b
\q1 
\v 4 عَلَتَلَ، عِ شَ كِرَ مَسٍن ﭑ بّ،
\q1 ﭑ شَرَن عِ شَ كِرَ رَ.
\q1 
\v 5 ﭑ نَحّرّ عِ شَ نْندِ كِرَ شْن،
\q1 عِ مَن شَ ﭑ مَتِنكَن عِ شَ كِرَ رَ،
\q1 بَرِ مَ عِ تَن عَلَ نَن ﭑ نَكِسِمَ.
\q1 ﭑ شَشِلِ تِشِ عِ رَ لْشْي بِرِن.
\q1 
\v 6 عَلَتَلَ، عِ مَحْشُن عِ شَ مَرَقَنيِ نُن عِ شَ قٌنِسِرٍيَ مَ،
\q1 بَرِ مَ عٍ نَ نَ كَبِ دُنِحَ قْلّ.
\q1 
\v 7 عِ نَشَ عِ مَحْشُن ﭑ مَ يُنُبِ مَ،
\q1 ﭑ نَشَن نَبَشِ ﭑ مَ سّفّتَلَيَ كُي،
\q1 ﭑ عِ رَشْنْشِ تّمُي نَشّ.
\q1 عَلَتَلَ، عِ مَحْشُن ﭑ مَ عِ شَ قٌنِسِرٍيَ كُي،
\q1 بَرِ مَ عِ قَن.
\b
\q1 
\v 8 عَلَتَلَ قَن، عَ تِنشِن.
\q1 نَ نَن عَ تٌشِ عَ كِرَ مَسٍنمَ يُنُبِتْييٍ بّ.
\q1 
\v 9 عَ تَن نَن مِشِ مَفٌرٌشِ رَحّرّ مَ تِنشِنيِ كُي.
\q1 عَ عٍ مَتِنكَنمَ عَ شَ كِرَ رَ.
\q1 
\v 10 عَلَتَلَ شَ قٌنِسِرٍيَ نُن تِنشِنيِ نَ مِشِيٍ بّ،
\q1 نَشٍيٍ عَ شَ سَاتّ نُن عَ شَ يَامَرِ مَبَنبَنمَ.
\q1 
\v 11 عَلَتَلَ، ﭑ مَ يُنُبِيٍ شَقَرِ عِ شِلِ شَ قٍ رَ،
\q1 بَرِ مَ عٍ مُ شُرُن.
\q1 
\v 12 ندٍ فَاشُمَ عَلَتَلَ يَ رَ؟
\q1 عَلَتَلَ كِرَ مَسٍنمَ نَ كَنيِ بّ
\q1 عَ لَنمَ عَ شَ حّرّ نَشَن مَ.
\q1 
\v 13 عَ عَلِفِيَمَ لِمَ نّ سّيوّ كُي.
\q1 عَ بْنسْي قَن قَمَ سَبَتِدٍ يِ بْشِ مَ.
\q1 
\v 14 عَلَتَلَ عَ شَ فُندٌ مَسٍنمَ مِشِيٍ بّ،
\q1 نَشٍيٍ فَاشُ عَ يَ رَ.
\q1 عَ عَ شَ سَاتّ مَسٍنمَ نّ عٍ بّ.
\q1 
\v 15 ﭑ شَشِلِ تِشِ عَلَتَلَ رَ لْشْي بِرِن
\q1 بَرِ مَ عَ تَن نَن ﭑ نَتَنفَمَ قٍ حَاشِ مَ.
\b
\q1 
\v 16 عَلَتَلَ، يَندِ، هِننّ ﭑ نَ،
\q1 بَرِ مَ تْورْ مِشِ نَن ﭑ نَ،
\q1 ﭑ مَلِمَ قَن مُ نَ.
\q1 
\v 17 ﭑ بْحّ بَرَ تْورْ. ﭑ نَمِنِ نَ تْورّ كُي.
\q1 
\v 18 عِ يَ رَ سِفَ ﭑ مَ سُننُنيِ نُن ﭑ مَ حَشَنكَتّ مَ،
\q1 عِ شَ دِحّ ﭑ مَ يُنُبِ بِرِن مَ.
\q1 
\v 19 عِ شَ عَ مَتٌ ﭑ يَشُييٍ وُيَشِ كِ نَشّ.
\q1 عٍ ﭑ شْنشِ عَ حَاشِ رَ.
\q1 
\v 20 ﭑ نِي مَكَنتَ، عِ شَ ﭑ نَتَنفَ،
\q1 عَلَكٌ يَافِ نَشَ ﭑ سْتْ عِ شَ نِينِ بُن مَ.
\q1 
\v 21 سّرِيّ نُن تِنشِنيِ شَ ﭑ كَنتَ
\q1 بَرِ مَ ﭑ شَشِلِ تِشِ عِ تَن نَ.
\q1 
\v 22 عَلَ، عِسِرَيِلَ شُنسَرَ عَ شَ تْورّ بِرِن مَ.
\c 26
\s1 تِنشِنتْي حّرّ كِ
\s2 عَلَ مَشَندِ
\d دَوُدَ فبٍ
\q1 
\v 1 عَلَتَلَ، عِ شَ ﭑ مَ كِيتِ سَ،
\q1 بَرِ مَ ﭑ حّرّ كِ تِنشِن.
\q1 ﭑ بَرَ ﭑ يّتّ تَشُ عِ رَ،
\q1 ﭑ مُ بِرَ مَ.
\q1 
\v 2 عَلَتَلَ، ﭑ بْحّ مَتٌ،
\q1 ﭑ سٌندٌنيِ مَكِيتِ،
\q1 
\v 3 بَرِ مَ ﭑ لَشِ عِ شَ هِننّ رَ،
\q1 ﭑ مَن ﭑ حّرّ مَ عِ شَ سّرِيّ مَ.
\q1 
\v 4 ﭑ مُ لُمَ وُلٍ قَلّيٍ يَ مَ،
\q1 ﭑ مُ حّرّ مَ قِلَنكَقُييٍ تَفِ.
\q1 
\v 5 قٍ كٌبِ رَبَيٍ مُ رَقَن ﭑ مَ،
\q1 ﭑ تَن نُن مِشِ حَاشِيٍ مُ لُمَ يِرٍ كٍرٍن.
\q1 
\v 6 عَلَتَلَ، ﭑ نَن ﭑ حّرّ كِ رَ سّنِيّن،
\q1 ﭑ مَن لُمَ نّ عِ شَ سّرّشّبَدٍ.
\q1 
\v 7 ﭑ تَنتُي بّيتِ بَمَ،
\q1 ﭑ عِ شَ كَابَنَكٌي مَسٍنمَ.
\q1 
\v 8 عَلَتَلَ، عِ شَ هْرْ مْبَنشِ رَقَن ﭑ مَ،
\q1 عِ شَ نْرّ نَ دّننَشّ.
\b
\q1 
\v 9 عِ نَشَ ﭑ نِي بَ عَلْ يُنُبِتْييٍ نُن قَشَتِيٍ.
\q1 
\v 10 عٍ قٍ حَاشِيٍ رَبَمَ،
\q1 عٍ كْبِرِ رَ سُشُمَ تِنشِنتَرٍيَ رَ.
\q1 
\v 11 كْنْ ﭑ تَن لُمَ تِنشِنيِ كُي.
\q1 ﭑ شُن سَرَ، عِ شَ دِحّ.
\q1 
\v 12 ﭑ حّرّ كِ تِنشِن.
\q1 ﭑ عَلَتَلَ تَنتُمَ نّ مَلَنيِيٍ كُي.
\c 27
\s1 عِ شَشِلِ تِ عَلَتَلَ رَ
\s2 عَلَ مَشَندِ
\d دَوُدَ فبٍ
\q1 
\v 1 عَلَتَلَ نَن نَ ﭑ مَ نَءِيَلَنيِ رَ.
\q1 ﭑ نَكِسِمَ نَ عَ رَ.
\q1 ﭑ لَن ﭑ شَ فَاشُ ندٍ يَ رَ؟
\q1 ﭑ مَ دُنِحّءِفِرِ نَ عَلَتَلَ نَن مَ نِينِ بُن مَ.
\q1 ﭑ لَن ﭑ شَ فَاشُ ندٍ يَ رَ؟
\q1 
\v 2 ﭑ فٍرٍقَيٍ نُن ﭑ يَشُي نَشٍيٍ قٍ حَاشِ رَبَمَ،
\q1 عٍ نَ قَ ﭑ نَهَلَكِدٍ،
\q1 عٍ تَن نَن بِرَ مَ.
\q1 
\v 3 هَلِ سْورِ فَالِ ﭑ نَبِلِن،
\q1 ﭑ بْحّ مُ سّرّنمَ.
\q1 هَلِ سْورِ فَالِ قَ ﭑ فٍرٍدٍ،
\q1 ﭑ بْحّ سُو سَمَ نّ.
\b
\q1 
\v 4 ﭑ قٍ كٍرٍن نَن مَشْرِن عَلَتَلَ مَ،
\q1 ﭑ نَ نَ نَن قٍنقٍ.
\q1 ﭑ وَ مَ لُقٍ عَلَتَلَ شَ هْرْ مْبَنشِ نَن كُي
\q1 ﭑ مَ دُنِحّءِفِرِ بِرِن،
\q1 عَلَكٌ ﭑ شَشِلِ شَ تِ عَلَتَلَ شَ قٍ قَنيِ رَ،
\q1 ﭑ مَن شَ نْ عَ شَ هْرْ مْبَنشِ مَتٌدٍ.
\q1 
\v 5 عَ ﭑ نَتَنفَمَ نّ تْورّ مَ هْرْ مْبَنشِ كُي.
\q1 عَ ﭑ نْشُنمَ نّ نَ نِينِ بُن مَ.
\q1 عَ ﭑ نَتٍمَ نّ فٍيَ قَرِ.
\q1 
\v 6 عَ ﭑ شُن نَكٍلِمَ نّ ﭑ يَشُييٍ يَ شْرِ نَشٍيٍ ﭑ نَبِلِنشِ.
\q1 ﭑ سّرّشّ بَمَ نّ عَ شَ هْرْ مْبَنشِ كُي حّلّشِنيِ رَ.
\q1 ﭑ سُوكِ بَ، ﭑ بّيتِ بَ عَلَتَلَ بّ.
\b
\q1 
\v 7 عَلَتَلَ، عِ تُلِ مَتِ ﭑ شُي رَ، ﭑ نَ عِ مَشَندِقٍ.
\q1 هِننّ ﭑ نَ، عِ مَن شَ ﭑ يَابِ.
\q1 
\v 8 ﭑ بْحّ وَ مَ عِ قٍنقٍ.
\q1 عَلَتَلَ، ﭑ عِ قٍنمَ نّ.
\q1 
\v 9 عِ نَشَ عِ كٌبٍ تِ ﭑ نَ.
\q1 عِ نَشَ مّي عِ شَ كٌنيِ رَ شْنّ كُي.
\q1 عِ تَن نَن نَ ﭑ مَلِمَ رَ.
\q1 ﭑ مَ مَرَكِسِمَ عَلَ، عِ نَشَ ﭑ نَبٌلٌ،
\q1 عِ نَشَ ﭑ نَبّحِن.
\q1 
\v 10 شَ ﭑ نفَ نُن ﭑ بَ ﭑ نَبٌلٌ،
\q1 عَلَتَلَ تَن عَ مَكْرّ مَ نّ ﭑ نَ.
\b
\q1 
\v 11 عَلَتَلَ، عِ شَ كِرَ مَسٍن ﭑ بّ.
\q1 ﭑ شُن تِ كِرَ تِنشِنشِ رَ،
\q1 عَلَكٌ ﭑ يَشُييٍ نَشَ ﭑ سُشُ.
\q1 
\v 12 عِ نَشَ ﭑ نَبٌلٌ ﭑ يَشُييٍ شَ عٍ سَفٌ رَبَ ﭑ نَ،
\q1 بَرِ مَ عٍ بَرَ قِندِ تْوحّفّلَيٍ رَ ﭑ بّ.
\q1 قٍ كٌبِ رَبَيٍ نَن لَنشِ عٍ مَ.
\q1 
\v 13 ﭑ لَشِ عَ رَ ﭑ عَلَتَلَ شَ قٍ قَنيِ تٌمَ نّ
\q1 يِ دُنِحَ بّندّ قُحِ قَرِ.
\b
\q1 
\v 14 عِ شَشِلِ تِ عَلَتَلَ رَ.
\q1 عِ سّنبّ شُن شَ مَسَ، عِ شَ لِمَنِيَ.
\q1 عِ شَشِلِ تِ عَلَتَلَ رَ.
\c 28
\s1 عَلَ حّنفِ دْشْشِ عَ شَ مِشِيٍ شْن مَ
\s2 عَلَ مَشَندِ
\d دَوُدَ فبٍ
\q1 
\v 1 عَلَتَلَ، ﭑ بَرَ عِ شِلِ.
\q1 عِ شَ سّنبّ لُمَ ﭑ بّ عَلْ قَنيٍ.
\q1 عِ تُلِ مَتِ ﭑ نَ، شَ نَ مُ عَ رَ ﭑ لُمَ عَلْ قَشَ مِشِ.
\q1 
\v 2 ﭑ نَ ﭑ بّلّشّ عِتٍ عِ بّ عِ شَ يِرٍ سّنِيّنشِ مَبِرِ،
\q1 عِ شَ ﭑ مَ مَشَندِ شُي رَ مّ.
\q1 
\v 3 عِ نَشَ ﭑ لُ عَلْ مِشِ حَاشِيٍ نُن تِنشِنتَرٍيٍ.
\q1 عٍ عٍ بٌورٍ يَنقَمَ، عٍ بْحّ مُ قَن.
\q1 
\v 4 عٍ شَ وَلِ كٌبِ سَرٍ رَفبِلٍن عٍ مَ.
\q1 عٍ نَشَن نَبَشِ مِشِيٍ رَ، عِ شَ نَ رَبَ عٍ قَن نَ.
\q1 عَ لَنمَ عٍ شَ نَ مْولِ سْتْ،
\q1 
\v 5 بَرِ مَ عٍ مُ عَلَتَلَ شَ وَلِ كٌلٌن.
\q1 عَ قَمَ عٍ رَبِرَدٍ، عٍ مُ كٍلِ سْنْن.
\q1 
\v 6 عَلَتَلَ تَنتُ،
\q1 عَ بَرَ ﭑ مَ دُبّ سُشُ.
\q1 
\v 7 عَلَتَلَ نَن نَ ﭑ سّنبّ نُن ﭑ كَنتَمَ رَ.
\q1 ﭑ شَشِلِ تِشِ عَ تَن نَن نَ نَشَن ﭑ مَلِمَ.
\q1 ﭑ بْحّ سّيوَ مَ نّ، ﭑ قَ بّيتِ بَ عَ بّ.
\q1 
\v 8 عَلَتَلَ نَن عَ شَ حَمَ سّنبّ رَ،
\q1 عَ قِندِ عَ شَ مِشِ سُفَندِشِ كَنتَمَ رَ.
\q1 
\v 9 عِ شَ حَمَ رَكِسِ، عِ شَ بَرَكّ رَفٌرٌ عٍ مَ.
\q1 مّينِ عٍ مَ
\q1 عَلْ شُرُ سٍ دّ مَدٌنيِ مّينِمَ عَ شَ فْورّ مَ كِ نَشّ.
\q1 عِ حّنفِ دْشْ عٍ شْن مَ عَبَدَن.
\c 29
\s1 عَلَتَلَ شُي مَفَاشُشِ
\s2 عَلَ مَتْشْي
\d دَوُدَ شَ بّيتِ
\q1 
\v 1 مَلٍكّيٍ، وٌ عَلَتَلَ مَتْشْ،
\q1 عَ شَ بِنيّ نُن عَ سّنبّ شَ قٍ رَ.
\q1 
\v 2 وٌ شَ عَلَتَلَ مَتْشْ،
\q1 وٌ شَ عَ بَتُ عَ نْرّ سّنِيّنشِ كُي.
\q1 
\v 3 عَلَتَلَ شُي مّمَ بَا مَ،
\q1 عَلَ بِنيّ كَنيِ شُي لُمَ عَلْ فَلَنيِ،
\q1 عَ عَ شُي رَ سِفَمَ بَا شُنفبٍيٍ مَ.
\q1 
\v 4 عَلَتَلَ شُي سّنبّ فبٌ،
\q1 عَ مَفَاشُ.
\q1 
\v 5 عَلَتَلَ شُي وُرِ بِلِ شُنفبٍيٍ عِفِرَ مَ،
\q1 عَلْ نَشٍيٍ نَ لِبَن بْشِ مَ.
\q1 
\v 6 عَلَتَلَ لِبَن وُرِ بِلِيٍ عِتُفَنمَ عَلْ نِنفٍ دِ،
\q1 عَ سِرِيٌن فٍيَ عِتُفَنمَ عَلْ سّشّ عِ نِنفٍ.
\q1 
\v 7 عَلَتَلَ شُي تّ رَيٍنسٍنمَ عَلْ سٍيَمَكْنيِ.
\q1 
\v 8 عَلَتَلَ شُي كَدٍ سِ فبٍنفبٍرٍنيِ رَ سّرّنمَ.
\q1 
\v 9 عَلَتَلَ شُي عَ نِيَمَ شٍلِيٍ نُن سِيٍ شَ بَرِ.
\q1 حَمَ بِرِن عٍ شُي عِتٍمَ عَ شَ هْرْ مْبَنشِ كُي،
\q1 عَ عَ قَلَ، «مَتْشْي نَ عَلَ بّ!»
\q1 
\v 10 عَلَتَلَ نُ نَ عَ شَ كِبَنيِ كُي دُنِحَ بَنبَرَن يّ تّمُي نَشّ.
\q1 عَ شَ مَنفّيَ مُ حْنمَ عَبَدَن.
\q1 
\v 11 عَلَتَلَ نَن سّنبّ قِمَ عَ شَ حَمَ مَ،
\q1 عَ بَرَكّ نُن بْحّسَ قِمَ عٍ مَ.
\c 30
\s1 عَلَ شَ شْنّ مُ بُمَ
\s2 عَلَ مَتْشْي
\d 
\v 1 دَوُدَ شَ بّيتِ عَ نَشَن سّبّ عَلَ شَ هْرْ مْبَنشِ شَ قٍ رَ
\q1 
\v 2 ﭑ بَرَ عِ مَتْشْ عَلَتَلَ،
\q1 بَرِ مَ عِ بَرَ ﭑ نَكٍلِ.
\q1 عِ مُ تِن ﭑ يَشُييٍ شَ شُننَكٍلِ سْتْ ﭑ شُن مَ.
\q1 
\v 3 ﭑ مَرِفِ عَلَتَلَ، ﭑ تٌ عِ شِلِ،
\q1 عِ نَشَ ﭑ نَيَلَن.
\q1 
\v 4 عَلَتَلَ، عِ نَشَ ﭑ نِي رَكِسِ سَيَ مَ،
\q1 عِ مُ تِن ﭑ شَ فٌرٌ فَبُرِ كُي.
\q1 
\v 5 دَنشَنِيَتْييٍ، وٌ شَ بّيتِ بَ عَلَتَلَ بّ،
\q1 وٌ شَ عَ شِلِ مَتْشْ.
\q1 
\v 6 عَ شَ شْنّ مُ بُمَ،
\q1 كْنْ عَ هِننّمَ عِ رَ عِ شَ سِمَيَ بِرِن كُي.
\q1 نُنمَرٍ، مِشِيٍ وَ مَ، كْنْ فّيسّفّ عٍ قَ حّلّشِن.
\b
\q1 
\v 7 ﭑ بْحّسَ سْتْ تّمُي نَشّ ﭑ نَشَ عَ قَلَ،
\q1 «ﭑ مُ نْمَ بِرَدٍ.»
\q1 
\v 8 عَلَتَلَ، تّمُي دَنفِشِ عِ نَشَ ﭑ سّنبّ لُ عَلْ فٍيَ،
\q1 كْنْ يَكْسِ عِ بَرَ عِ نْشُن ﭑ مَ.
\q1 ﭑ بْحّ بَرَ عِقُ.
\q1 
\v 9 عَلَتَلَ، ﭑ نَشَ عِ شِلِ، ﭑ نَشَ عِ مَشَندِ.
\q1 
\v 10 ﭑ نَشَ عَ قَلَ عِ بّ،
\q1 «ﭑ مَ قَشّ قِندِ مَ فٍينِ مُندُن نَ عِ بّ؟
\q1 شَ ﭑ بَرَ فٌرٌ فَبُرِ كُي،
\q1 نَ نْمَ قِندِدٍ مَتْشْي رَ عِ بّ؟
\q1 نَ نْمَ عِ شَ لَنلَنتٍيَ مَسٍندٍ دُنِحَ بّ؟»
\q1 
\v 11 عَلَتَلَ، عِ تُلِ مَتِ ﭑ نَ، عِ شَ كِنِكِنِ ﭑ مَ.
\q1 عَلَتَلَ، ﭑ مَلِ.
\b
\q1 
\v 12 عِ بَرَ ﭑ مَ نِمِسّ مَسَرَ سّيوّ رَ.
\q1 عِ بَرَ ﭑ مَ سُننُن دٌنمَ مَسَرَ حّلّشِن دٌنمَ رَ.
\q1 
\v 13 ﭑ مَرِفِ عَلَتَلَ، نَ نَ عَ رَ ﭑ مُ دُندُ مَ،
\q1 ﭑ تَنتُي بّيتِ بَمَ نّ عِ بّ عَبَدَن.
\c 31
\s1 لَقٍ عَلَ رَ
\s2 عَلَ مَشَندِ نُن عَلَ مَتْشْي
\d 
\v 1 دَوُدَ شَ بّيتِ بّيتِبَيٍ شَ مَنفّ بّ
\q1 
\v 2 عَلَتَلَ، ﭑ بَرَ ﭑ شَشِلِ تِ عِ رَ.
\q1 عِ نَشَ تِن ﭑ شَ لُ يَافِ كُي،
\q1 عِ شَ كِيتِ قَنيِ سَ ﭑ مَ.
\q1 
\v 3 عِ شَ عِ تُلِ مَتِ ﭑ نَ، ﭑ نَكِسِ.
\q1 عِ شَ لُ ﭑ بّ عَلْ قَنيٍ،
\q1 عَلْ يِرٍ مَكَنتَشِ عَلَكٌ ﭑ شَ كِسِ.
\q1 
\v 4 ﭑ مَ سّنبّمَ نُن ﭑ مَ كَنتَمَ نَن عِ رَ.
\q1 عِ شَ ﭑ شُن تِ كِرَ قَنيِ شْن عِ شِلِ قَنيِ شَ قٍ رَ.
\q1 
\v 5 ﭑ يَشُييٍ بَرَ يّلّ عِتَلَ ﭑ يَ رَ،
\q1 كْنْ عِ قَمَ ﭑ نَتَنفَدٍ نَ مَ.
\b
\q1 
\v 6 ﭑ بَرَ ﭑ شَشِلِ تِ عِ رَ.
\q1 عَلَتَلَ نْندِ مَرِفِ، عِ بَرَ ﭑ نَكِسِ.
\q1 
\v 7 كُيٍ بَتُي مُ رَقَن ﭑ مَ،
\q1 ﭑ تَن، نَن ﭑ تَشُمَ عَلَتَلَ نَن نَ.
\q1 
\v 8 ﭑ سّيوَ مَ نّ عِ شَ هِننّ شَ قٍ رَ،
\q1 بَرِ مَ عِ بَرَ ﭑ مَ تْورّيٍ تٌ،
\q1 ﭑ سٌندٌنيِ نَ حَشَنكَتَ، عِ نَ كٌلٌن.
\q1 
\v 9 عِ مُ ﭑ سٌشِ ﭑ يَشُييٍ يِ رَ، عِ بَرَ ﭑ شْرّيَ.
\b
\q1 
\v 10 عَلَتَلَ، هِننّ ﭑ نَ،
\q1 بَرِ مَ ﭑ نَ تْورْقٍ.
\q1 ﭑ قَتٍ بِرِن بَرَ بَ ﭑ مَ.
\q1 
\v 11 ﭑ مَ سِمَيَ نَ حْنقٍ تْورّ كُي.
\q1 ﭑ مَ دُنِحّءِفِرِ شْرْشْ.
\q1 ﭑ سّنبّ بَرَ حْن ﭑ مَ يُنُبِ شَ قٍ رَ.
\q1 ﭑ قَتٍ بَرَ كَنَ
\v 12 ﭑ يَشُييٍ شَ قٍ رَ.
\q1 ﭑ بَرَ يَافِ ﭑ دْشْبٌورٍيٍ شْن مَ.
\q1 ﭑ بٌورٍيٍ، شَ نَ مُ عَ رَ نَشٍيٍ ﭑ تٌمَ تَا كُي،
\q1 عٍ عٍ فِمَ نّ ﭑ مَ.
\b
\q1 
\v 13 عٍ بِرِن بَرَ نّيمُ ﭑ مَ عَلْ ﭑ حَن بَرَ قَشَ.
\q1 ﭑ لُشِ عَلْ سٍ لْيشِ.
\q1 
\v 14 ﭑ بَرَ ﭑ يَشُييٍ شُي مّ.
\q1 فبَلٌي نَ ﭑ نَبِلِنيِ.
\q1 عٍ بَرَ لَن عَ مَ عٍ شَ ﭑ قَشَ.
\q1 
\v 15 كْنْ ﭑ تَن بَرَ ﭑ تَشُ عِ رَ، عِ تَن ﭑ مَرِفِ عَلَتَلَ.
\q1 
\v 16 ﭑ نَ عِ سَفٌي.
\q1 ﭑ نَتَنفَ ﭑ يَشُييٍ مَ نَشٍيٍ وَ مَ ﭑ حَشَنكَتَقٍ.
\q1 
\v 17 عِ شَ عِ شَ كٌنيِ تٌ، ﭑ نَكِسِ عِ شَ هِننّ رَ.
\q1 
\v 18 عَلَتَلَ، ﭑ نَ عِ شِلِ، عِ نَشَ ﭑ لُ يَافِ كُي.
\q1 عَلَ شَ مِشِ حَاشِيٍ رَيَافِ،
\q1 عَلَ شَ عٍ رَ سَبَرِ قَشّ رَ.
\q1 
\v 19 عَلَ شَ عٍ شُي رَدُندُ،
\q1 بَرِ مَ يِ وُلٍ قَلّيٍ عٍ يّتّ عِفبٌمَ، عٍ يٌ تِنشِنتْييٍ مَ.
\b
\q1 
\v 20 عِ شَ هِننّ فبٌ،
\q1 عِ نَشَن نَفَتَشِ عِ يَرَفَاشُييٍ بّ،
\q1 نَشٍيٍ عِ شَ كَنتَرِ قٍنمَ.
\q1 
\v 21 عِ بَرَ عٍ يِفِيَ عَلَكٌ قٍ كٌبِ رَبَيٍ نَشَ عٍ سُشُ.
\q1 عِ بَرَ عٍ رَتَنفَ وُلٍ قَلّيٍ مَ.
\q1 
\v 22 عَلَتَلَ تَنتُ، بَرِ مَ عَ بَرَ هِننّ ﭑ نَ ﭑ مَ تْورّ كُي.
\q1 
\v 23 ﭑ مَ فَاشُي كُي، ﭑ نُ بَرَ عَ قَلَ،
\q1 «عِ بَرَ عِ نْشُن ﭑ مَ،»
\q1 كْنْ عِ بَرَ ﭑ مَ مَشَندِ سُشُ.
\b
\q1 
\v 24 دَنشَنِيَتْييٍ، وٌ شَ عَلَتَلَ شَنُ.
\q1 عَلَتَلَ تٌفٌندِيَتْييٍ رَكِسِمَ نّ،
\q1 كْنْ عَ يّتّ عِفبٌي حَشَنكَتَمَ نّ.
\q1 
\v 25 وٌ تَن نَشٍيٍ وٌ شَشِلِ تِشِ عَلَتَلَ رَ،
\q1 وٌ وٌ سّنبّ سٌ، وٌ شَ لِمَنِيَ.
\c 32
\s1 عَلَ يُنُبِ شَقَرِقٍ
\s2 عَلَ مَتْشْي
\d دَوُدَ شَ لْننِ بّيتِ
\q1 
\v 1 حّلّشِنيِ نَ عَدَ مَ بّ
\q1 نَشَن شَ يُنُبِ بَرَ بَ،
\q1 نَشَن شَ قٍ كٌبِ بَرَ شَقَرِ.
\q1 
\v 2 حّلّشِنيِ نَ عَدَ مَ بّ
\q1 عَلَتَلَ بَرَ دِحّ نَشَن مَ قٍ كٌبِ مَ،
\q1 عَ نُن مَءِقُي مُ نَ نَشَن شَشِلِ يَ مَ.
\q1 
\v 3 دَنمِ ﭑ دُندُشِ، ﭑ مُ نْمَ مِنِدٍ تْورّ كُي.
\q1 ﭑ نُ تْورْ مَ نّ يَنيِ بِرِن نَ.
\q1 
\v 4 كْي نُن يَنيِ عِ شَ تْورّ نَ ﭑ قَرِ.
\q1 ﭑ سّنبّ بَرَ كَنَ،
\q1 عَ بَرَ لُ عَلْ فبٍنفبٍرٍن يِرٍ.
\b
\q1 
\v 5 ﭑ بَرَ ﭑ مَ يُنُبِ مَسٍن عِ بّ،
\q1 ﭑ مُ ﭑ مَ يُنُبِ نْشُنشِ قَ.
\q1 ﭑ بَرَ عَ قَلَ،
\q1 «قٌ ﭑ شَ ﭑ مَ يُنُبِ يَ شَرَن عَلَتَلَ بّ.»
\q1 عِ تَن عَلَتَلَ بَرَ ﭑ مَ يُنُبِ بَ ﭑ مَ.
\b
\q1 
\v 6 مِشِ تِنشِنشِ بِرِن شَ عِ مَشَندِ عَ وَشَتِ.
\q1 شَ تْورّ فبٌ عَلْ بَنبَرَنيِ،
\q1 عَ مُ سٍسٍ نِيَمَ عَ رَ.
\q1 
\v 7 ﭑ مَ كَنتَرِ لَنشِ عِ تَن نَن مَ.
\q1 عِ مَن سُننُنيِ بَمَ ﭑ مَ.
\q1 ﭑ عِ تَنتُمَ نّ عِ شَ مَرَتَنفّ شَ قٍ رَ.
\b
\q1 
\v 8 ﭑ وٌ شَرَنمَ نّ كِرَ رَ
\q1 وٌ لَن وٌ شَ بِرَ نَشَن قْشْ رَ.
\q1 ﭑ وٌ رَ سِمَ نّ،
\q1 ﭑ نَن ﭑ حّنفِ سَمَ نّ وٌ شَ قٍ شْن مَ.
\q1 
\v 9 وٌ نَشَ لُ عَلْ سٌي،
\q1 شَ نَ مُ عَ رَ سٌقَلٍ شَشِلِتَرٍ،
\q1 نَشَن مُ رَحّرّ مَ قٌ كَرَقٌي رَ.
\b
\q1 
\v 10 قٍ شْنّ فبٍفبٍ رَفَتَشِ مِشِ حَاشِ بّ،
\q1 كْنْ نَشَن عَ شَشِلِ تِشِ عَلَتَلَ رَ،
\q1 عَلَ شَ قٌنِسِرٍيَ نَ كَنيِ رَبِلِنمَ نّ.
\q1 
\v 11 مِشِ تِنشِنشِيٍ، وٌ سّيوَ عَلَتَلَ رَ،
\q1 وٌ مَن شَ حّلّشِن.
\q1 وٌ عَلَ تَنتُ حّلّشِنيِ كُي وٌ شُي عِتٍشِ رَ،
\q1 وٌ تَن مِشِ تِنشِنشِيٍ بِرِن.
\c 33
\s1 عَلَ نَ وْيّن، عَ قٍ رَفِرِ مَ نّ
\s2 عَلَ مَتْشْي
\q1 
\v 1 تِنشِنتْييٍ، وٌ شَ عَلَتَلَ مَتْشْ وٌ شُي عِتٍشِ رَ.
\q1 تِنشِنتْييٍ لَن عٍ شَ عَلَ مَتْشْ.
\q1 
\v 2 وٌ شَ عَلَتَلَ تَنتُ كْرَ رَ،
\q1 وٌ شَ بّيتِ بَ كْرَ رَ لُوتِ قُ دَاشِ.
\q1 
\v 3 وٌ شَ بّيتِ نّينّ بَ عَ بّ،
\q1 وٌ شَ نَ رَبَ مَشَسٍيٍ رَ وٌ شُي عِتٍشِ رَ.
\q1 
\v 4 عَلَتَلَ شَ مَسٍنيِ تِنشِن،
\q1 عَ عَ شَ وَلِ بِرِن نَبَمَ سْوبّ رَ.
\q1 
\v 5 تِنشِنيِ نُن سّرِيّ رَقَن عَ مَ،
\q1 دُنِحَ بِرِن نَقٍشِ عَلَتَلَ شَ هِننّ رَ.
\q1 
\v 6 عَلَتَلَ نَشَ كٌورٍ دَا عَ شَ وْيّنيِ رَ.
\q1 عَ تٌ وْيّن كٍرٍن قَلَ، تُنبُييٍ نَشَ مِنِ كٍرٍن نَ.
\q1 
\v 7 عَ نَشَ بَا قَن مَلَن يِرٍ كٍرٍن،
\q1 عَ شَ يٍ رَفَتَ.
\q1 
\v 8 بْشِ بِرِن شَ فَاشُ عَلَتَلَ يَ رَ.
\q1 دُنِحَ مِشِ بِرِن شَ عَ بِنيَ.
\q1 
\v 9 عَ نَ وْيّن، عَ قٍ رَفِرِ مَ نّ.
\q1 عَ نَ يَامَرِ قِ، عَ رَبَمَ نّ.
\q1 
\v 10 عَلَتَلَ سِيٍ شَ نَتّيٍ كَنَمَ نّ.
\q1 عَ مُ عٍ شَ وَلِ سْونّيَمَ.
\q1 
\v 11 كْنْ عَلَتَلَ شَ قٍ رَفِرِشِيٍ بُمَ عَبَدَن.
\q1 عَ وَشْنقٍ سْونّيَمَ نّ وَشَتِ بِرِن.
\q1 
\v 12 حّلّشِنيِ نَ سِ بّ نَشَن مَرِفِ قِندِشِ عَلَتَلَ رَ.
\q1 حّلّشِنيِ نَ بْنسْي بّ عَلَتَلَ نَشَن سُفَندِشِ.
\q1 
\v 13 عَلَتَلَ عَ يَ رَفٌرٌ مَ دُنِحَ مَ كٍلِقٍ عَرِيَننَ،
\q1 عَ مِشِ بِرِن مَتٌ.
\q1 
\v 14 كٍلِقٍ عَ شْنيِ، عَ دُنِحَ مِشِ بِرِن مَتٌمَ نّ.
\q1 
\v 15 نَشَن عَدَ مَدِيٍ بْحّ دَاشِ،
\q1 عَ عَ حّنفِ سَمَ عٍ شَ وَلِيٍ شْن.
\b
\q1 
\v 16 مَنفّ يٌ مُ كِسِمَ عَ شَ سْورِيٍ سَابُي رَ.
\q1 سْورِ قَن مُ كِسِمَ عَ يّتّ سّنبّ رَ.
\q1 
\v 17 سْورِ حْشْ عَ مَ عَ شَ سٌي نْمَ عَ رَكِسِدٍ،
\q1 كْنْ نَ تَن مُ قِندِ مَ كِسِ رَ عَ بّ.
\q1 
\v 18 عَلَتَلَ نَن مّينِمَ مِشِيٍ مَ
\q1 نَشٍيٍ فَاشُمَ عَ يَ رَ،
\q1 نَشٍيٍ عٍ شَشِلِ تِمَ عَ شَ هِننّ رَ،
\q1 
\v 19 عَلَكٌ عٍ نِي نَشَ لَاشِرَ،
\q1 عَلَكٌ عٍ شَ بَلٌ كَامّ وَشَتِ.
\q1 
\v 20 وٌن شَشِلِ تِشِ عَلَتَلَ نَن نَ.
\q1 عَ تَن نَن وٌن مَلِمَ رَ،
\q1 عَ تَن نَن وٌن كَنتَمَ رَ.
\q1 
\v 21 وٌن بْحّيٍ سّيوَشِ عَ تَن نَن مَ قٍ رَ،
\q1 بَرِ مَ وٌن بَرَ لَ عَ شِلِ سّنِيّنشِ رَ.
\q1 
\v 22 عَلَتَلَ، عِ شَ هِننّ مُشُ رَ،
\q1 بَرِ مَ مُشُ شَشِلِ تِشِ عِ تَن نَن نَ.
\c 34
\s1 عَلَ يَرَفَاشُييٍ سَرٍ
\s2 عَلَ مَتْشْي
\d 
\v 1 دَوُدَ تٌ عَ يّتّ قِندِ دَشُي رَ عَبِمٍلٍكِ يَ عِ عَلَكٌ عَ شَ عَ بّحِن، عَ نَشَ يِ بّيتِ سّبّ.
\q1 
\v 2 ﭑ عَلَتَلَ تَنتُمَ وَشَتِ بِرِن.
\q1 عَ شَ مَتْشْي مُ بَمَ ﭑ دّ عِ.
\q1 
\v 3 ﭑ عَلَتَلَ مَتْشْمَ ﭑ بْحّ كُي.
\q1 تْورْ مِشِيٍ قَمَ نّ نَ مّدٍ، عٍ قَ سّيوَ.
\q1 
\v 4 وٌن بِرِن شَ عَلَتَلَ بِنيَ،
\q1 وٌن شَ عَ شِلِ مَتْشْ.
\b
\q1 
\v 5 ﭑ تٌ عَلَتَلَ مَشَندِ، عَ نَشَ ﭑ يَابِ،
\q1 عَ ﭑ مَ فَاشُي بِرِن بَ ﭑ يِ.
\q1 
\v 6 نَشَن نَ عَ يَ تِ عَلَ رَ،
\q1 عَ سّيوَ مَ نّ، عَ مُ يَافِمَ.
\q1 
\v 7 شَ تْورْ مِشِ عَ شُي رَ مِنِ،
\q1 عَلَتَلَ عَ مّمَ نّ، عَ قَ عَ رَكِسِ عَ شَ تْورّ كُي.
\b
\q1 
\v 8 عَلَتَلَ شَ مَلٍكّ عَلَ يَرَفَاشُييٍ رَبِلِنمَ نّ،
\q1 عَ عٍ كَنتَ.
\q1 
\v 9 وٌ عَ مَتٌ، عَلَتَلَ قَن دٍ!
\q1 حّلّشِنيِ نَ عَدَ مَ بّ نَشَن شَشِلِ تِشِ عَ رَ.
\q1 
\v 10 سّنِيّنتْييٍ، وٌ شَ فَاشُ عَلَتَلَ يَ رَ،
\q1 عَلَكٌ وٌ هَيِ بِرِن شَ قَن.
\q1 
\v 11 كَامّ يّتّيٍ سُشُمَ نّ،
\q1 كْنْ عَلَتَلَ قٍنمَيٍ هَيِ بِرِن قَنمَ نّ.
\b
\q1 
\v 12 ﭑ مَ دِيٍ، وٌ قَ، وٌ شَ قَ وٌ تُلِ مَتِ ﭑ نَ.
\q1 ﭑ شَ عَلَتَلَ يَرَفَاشُي مَسٍن وٌ بّ.
\q1 
\v 13 ندٍ وَ مَ سِمَيَ شْنكُيٍ شْن؟
\q1 ندٍ وَ مَ لُقٍ سّيوّ كُي تّمُي بِرِن؟
\q1 
\v 14 شَ وٌ وَ مَ نَ شْن،
\q1 وْيّن حَاشِيٍ نَشَ مِنِ وٌ دّ عِ،
\q1 وٌ نَشَ وُلٍ يٌ قَلَ.
\q1 
\v 15 وٌ شَ قٍ حَاشِ لُ نَ، وٌ شَ قٍ قَنيِ رَبَ.
\q1 وٌ شَ وٌ تُننَبّشِ بْحّسَ قٍنقٍ رَ.
\b
\q1 
\v 16 عَلَتَلَ تِنشِنتْييٍ تٌمَ نّ،
\q1 عَ عَ تُلِ مَتِمَ عٍ وَ شُي رَ.
\q1 
\v 17 عَلَتَلَ عَ كٌبٍ سٌمَ قٍ كٌبِ رَبَيٍ رَ،
\q1 عَلَكٌ عٍ شِلِ شَ نّيمُ دُنِحَ رَ.
\q1 
\v 18 تِنشِنتْييٍ نَ عٍ مَوَ عَلَتَلَ بّ،
\q1 عَ عَ تُلِ مَتِمَ نّ عٍ رَ،
\q1 عَ عٍ بَ عٍ شَ تْورّيٍ كُي.
\q1 
\v 19 عَلَتَلَ لُمَ مِشِ قّ مَ نَشَن سُننُنشِ عَ بْحّ مَ،
\q1 عَ مِشِ رَكِسِمَ نَشَن شَشِلِ بَرَ عِقُ.
\b
\q1 
\v 20 تْورّ فبٍفبٍ تِنشِنتْي لِمَ نّ،
\q1 كْنْ عَلَتَلَ عَ رَكِسِمَ نَ بِرِن مَ.
\q1 
\v 21 عَلَتَلَ مّينِمَ نّ عَ مَ،
\q1 سٍسٍ مُ عَ تٌمَ.
\q1 
\v 22 قٍ حَاشِ نَن مِشِ حَاشِ قَشَمَ.
\q1 تِنشِنتْي يَشُييٍ قَمَ حَشَنكَتَدٍ.
\q1 
\v 23 عَلَتَلَ عَ شَ كٌنيِيٍ شُن سَرَ مَ نّ.
\q1 نَشَن عَ شَشِلِ تِمَ عَلَ رَ،
\q1 نَ مُ كِيتِ حَاشِ سْتْمَ.
\c 35
\s1 مِشِ حَاشِ سَرٍ
\s2 عَلَ مَشَندِ
\d دَوُدَ فبٍ
\q1 
\v 1 عَلَتَلَ، عِ شَ مِشِ تْورْ نَشَن وَ مَ ﭑ تْورْقٍ.
\q1 نَشَن وَ مَ ﭑ فٍرٍقٍ، نَ كَنيِ فٍرٍ.
\q1 
\v 2 كٍلِ، عِ شَ ﭑ مَلِ عِ شَ فٍرٍ سٌسٍ رَ.
\q1 
\v 3 عِ شَ شَلِ نُن تَنبّ شَ عِتٍ ﭑ يَشُييٍ شِلِ مَ.
\q1 عَ قَلَ ﭑ بّ، عَ عِ تَن نَن ﭑ مَ مَرَكِسِمَ رَ.
\q1 
\v 4 عَلَ شَ ﭑ يَشُييٍ رَيَافِ، عَ شَ عٍ شَشِلِ عِقُ،
\q1 نَشٍيٍ وَ مَ ﭑ قَشَقٍ.
\q1 نَشٍيٍ قٍ حَاشِيٍ مَشِرِ مَ ﭑ شُن مَ،
\q1 عَلَ شَ عٍ رَيَافِ، عَ شَ عٍ كٍرِ.
\q1 
\v 5 عٍ شَ لُ عَلْ مَالٍ لَفِ قٌيٍ نَشَن نَيٍنسٍنمَ.
\q1 عَلَتَلَ شَ مَلٍكّ شَ عٍ كٍرِ.
\q1 
\v 6 عَلَ شَ عٍ لُ دِ مِ كُي،
\q1 عَلَ شَ عٍ شَ كِرَ مَسَلَشُن.
\q1 عَلَتَلَ شَ مَلٍكّ شَ عٍ كٍرِ.
\q1 
\v 7 عٍ بَرَ يّلّ عِتَلَ ﭑ يَ رَ،
\q1 عٍ بَرَ يِلِ فٍ ﭑ بِرَ مَ دّننَشّ،
\q1 عَلَكٌ عٍ شَ ﭑ قَشَ هَلِ ﭑ مُ قٍ حَاشِ يٌ رَبَشِ عٍ رَ.
\q1 
\v 8 عَلَ شَ نَ سَرٍ رَفبِلٍن عٍ مَ.
\q1 عَلَ شَ عٍ سُشُ يّلّ كُي، عَلَ شَ عٍ رَبِرَ يِلِ كُي.
\q1 
\v 9 نَ تّمُي ﭑ بْحّ حّلّشِنمَ نّ عَلَتَلَ رَ.
\q1 ﭑ سّيوَ مَ نّ عَ شَ مَرَكِسِ شَ قٍ رَ.
\q1 
\v 10 ﭑ بْحّ عَ قَلَمَ نّ،
\q1 «عَلَتَلَ، عِ مَنِيّ مُ نَ.
\q1 ندٍ نْمَ تْورْ مِشِ رَتَنفَدٍ سّنبّمَ مَ؟
\q1 ندٍ نْمَ سٍتَرٍ رَتَنفَدٍ مُحّتِيٍ مَ؟»
\b
\q1 
\v 11 وُلٍ قَلّيٍ ﭑ تْوحّفّمَ،
\q1 عٍ نُ قٍ قَلَ عٍ مُ نَشَن كٌلٌن.
\q1 
\v 12 عٍ ﭑ مَ قٍ قَنيِ سَرٍ رَفبِلٍنمَ قٍ حَاشِيٍ رَ.
\q1 مِشِ بِرِن بَرَ ﭑ نَبٌلٌ.
\q1 
\v 13 كْنْ عٍ تَن نُ قُرَشِ تّمُي نَشّ،
\q1 ﭑ نُ لُمَ سُننُن نَ عٍ بّ،
\q1 ﭑ نُ قَ سُنيِ سُشُ، ﭑ عَلَ مَشَندِ عٍ بّ تّمُي بِرِن.
\q1 
\v 14 ﭑ سُننُنشِ عٍ بّ عَلْ ﭑ سُننُنمَ ﭑ بٌورٍ بّ كِ نَشّ،
\q1 شَ نَ مُ عَ رَ ﭑ نفَشَكٍرٍنيِ بّ.
\q1 ﭑ كِنِكِنِشِ عٍ بّ عَلْ ﭑ كِنِكِنِمَ ﭑ نفَ بّ كِ نَشّ.
\q1 
\v 15 كْنْ تْورّ تٌ ﭑ تَن لِ، عٍ بِرِن نَشَ حّلّشِن.
\q1 عٍ نَشَ كَقُ عٍ بٌرٍ مَ ﭑ شِلِ مَ،
\q1 عٍ شَ ﭑ حَشَنكَتَ، عٍ شَ ﭑ نَهَلَكِ.
\q1 
\v 16 مِشِ حَاشِيٍ نُن كٌنبِتِيٍ،
\q1 عٍ بِرِن ﭑ مَ قٍ شْنشِ، عٍ نُ يٍلٍ.
\q1 
\v 17 ﭑ مَرِفِ، مُنقٍ رَ عِ تِنمَ نَ مْولِ شَ رَبَ؟
\q1 ﭑ نِي رَتَنفَ عٍ شَ فٍرٍ مَ، ﭑ نِي رَكِسِ يِ يّتّيٍ مَ.
\q1 
\v 18 نَ كُي ﭑ عِ تَنتُمَ نّ مَلَنيِ شُنفبٍ كُي،
\q1 ﭑ عِ مَتْشْمَ حَمَ فبٍفبٍ تَفِ.
\b
\q1 
\v 19 عَلَ شَ ﭑ نَتَنفَ ﭑ يَشُييٍ مَ،
\q1 نَشٍيٍ وَ مَ يٌقٍ ﭑ مَ.
\q1 عَلَ شَ ﭑ نَتَنفَ ﭑ شْنمِشِيٍ
\q1 نَشٍيٍ وَ مَ ﭑ كٌنبِقٍ هَلِ ﭑ مُ قٍ يٌ رَبَشِ عٍ رَ.
\q1 
\v 20 عٍ مُ وْيّن قَنيِ يٌ قَلَمَ،
\q1 عٍ مِشِ قَنيِ مَدَشُمَ تُن.
\q1 
\v 21 عٍ ﭑ تْوحّفّمَ عَ قَلَقٍ رَ، «مُشُ بَرَ عَ تٌ.»
\q1 
\v 22 عَلَتَلَ، عِ بَرَ نَ بِرِن تٌ. عِ نَشَ دُندُ دٍ.
\q1 ﭑ مَرِفِ، عِ نَشَ عِ مَكُيَ ﭑ نَ.
\q1 
\v 23 ﭑ مَرِفِ عَلَ، كٍلِ،
\q1 عِ شَ ﭑ شُن مَفٍرٍ سٌ،
\q1 عِ شَ ﭑ شُن مَقَلَ.
\q1 
\v 24 ﭑ مَرِفِ عَلَتَلَ، عِ شَ ﭑ مَ كِيتِ سَ عِ شَ تِنشِنيِ رَ،
\q1 عَلَكٌ ﭑ يَشُييٍ نَشَ ﭑ مَيٍلٍ.
\q1 
\v 25 عِ نَشَ تِن عٍ شَ عَ قَلَ،
\q1 «مُشُ بَرَ نْ عَ رَ، مُشُ بَرَ عَ مَسْتْ.»
\q1 
\v 26 عَلَ شَ ﭑ شْنمِشِيٍ رَيَافِ،
\q1 ﭑ يَشُييٍ شَشِلِ شَ عِقُ.
\q1 
\v 27 عَلَ شَ ﭑ شَنُنتٍنيِيٍ رَ سّيوَ،
\q1 نَشٍيٍ عَ قَلَمَ عٍ شُي عِتٍشِ رَ،
\q1 «تَنتُي نَ عَلَتَلَ بّ
\q1 نَشَن عَ شَ كٌنيِ لُمَ بْحّسَ كُي.»
\q1 
\v 28 ﭑ عِ شَ تِنشِنيِ مَسٍنمَ نّ،
\q1 ﭑ عِ تَنتُمَ نّ تّمُي بِرِن.
\c 36
\s1 عَدَ مَ شَ حَاشُحَ نُن عَلَ شَ هِننّ
\s2 عَلَ مَتْشْي
\d 
\v 1 عَلَتَلَ شَ كٌنيِ دَوُدَ شَ بّيتِ بّيتِبَيٍ شَ مَنفّ بّ
\q1 
\v 2 ﭑ بَرَ مِشِ حَاشِ شَ مَتَندِ مَحْشُن ﭑ بْحّ كُي.
\q1 عَ مُ عَ كٌلٌن عَ لَنمَ عَ شَ فَاشُ عَلَ يَ رَ.
\q1 
\v 3 عَ عَ يّتّ عِفبٌمَ هَن عَ مُ نْمَ عَ شَ يُنُبِ تٌدٍ،
\q1 عَ مُ نْمَ عَ حّرّ كِ شْندٍ.
\q1 
\v 4 عَ شَ وْيّنيِ حَاشُ، عَ نُ مِشِ مَدَشُ تُن.
\q1 عَ مُ قٍ قَنيِ يٌ كٌلٌن.
\q1 
\v 5 عَ قٍ حَاشِ مَحْشُنمَ كْي رَ، عَ قَ كِرَ حَاشِ سُشُ،
\q1 بَرِ مَ عَ مُ تٌندِ مَ قٍ كٌبِ لُدٍ.
\b
\q1 
\v 6 عَلَتَلَ، عِ شَ هِننّ كٌورٍ لِمَ،
\q1 عِ شَ دُفُتّفّحَ سِفَمَ هَن نُشُي.
\q1 
\v 7 عِ شَ تِنشِنيِ فبٌ عَلْ فٍيَيٍ.
\q1 عِ شَ كِيتِ تِلِن عَلْ بَا.
\q1 عِ تَن نَن عَدَ مَدِيٍ نُن سُبٍيٍ رَكِسِمَ.
\q1 
\v 8 عَلَ، عِ شَ هِننّ قَن.
\q1 عَدَ مَدِيٍ بِرِن يِفِيَ سْتْمَ نّ عِ يِ رَ،
\q1 عَلْ تْشْي يْرّيٍ لُمَ عٍ نفَ فَبُتٍنيِيٍ بُن مَ كِ نَشّ.
\q1 
\v 9 عٍ وَ سَمَ عِ شَ نّمّ نَن نَ،
\q1 عِ شَ قٍ قَنيِ لُمَ عٍ بّ عَلْ يٍ شِنبٍلِ.
\q1 
\v 10 عِ تَن نَن فبَنسَن نْمَ عَدَ مَ رَبَلٌدٍ.
\q1 عِ شَ نَءِيَلَنيِ بَرَ مُشُ شَ كِرَ عِيَلَن.
\q1 
\v 11 عِ شَ هِننّ عِ كٌلٌنمَيٍ رَ،
\q1 عِ شَ عِ شَ تِنشِنيِ مَسٍن تِنشِنتْييٍ بّ.
\q1 
\v 12 عِ شَ ﭑ نَتَنفَ يّتّ عِفبٌييٍ مَ،
\q1 عِ نَشَ عَ لُ مِشِ حَاشِيٍ شَ ﭑ كٍرِ.
\q1 
\v 13 تِنشِنتَرٍيٍ بِرَ مَ نّ،
\q1 عٍ مُ نْمَ كٍلِدٍ سْنْن.
\c 37
\s1 مِشِ حَاشِ نُن مِشِ قَنيِ مَسُندِ
\s2 عَلَ شَ سّرِيّ
\d دَوُدَ فبٍ
\q1 
\v 1 عِ نَشَ كْنتْقِلِ مِشِ حَاشِيٍ رَ.
\q1 عِ نَشَ تِن لُدٍ عَلْ عٍ تَن.
\q1 
\v 2 عٍ لِسِمَ نّ مَقُرٍن عَلْ حٌوفٍ،
\q1 عٍ قَشَمَ نّ عَلْ سَنسِيٍ.
\q1 
\v 3 عِ شَ عِ تَشُ عَلَتَلَ رَ، عِ شَ قٍ قَنيِ رَبَتُ.
\q1 عِ شَ لُ يِ بْشِ مَ، نْندِ شَ قِندِ عِ شَ بَلٌي رَ.
\q1 
\v 4 عَلَتَلَ شَ قِندِ عِ وَشْنقٍ رَ.
\q1 نَ كُي عَ عِ وَشْنقٍ رَفِرِ مَ نّ.
\q1 
\v 5 عِ عِ شَشِلِ تِ عَلَتَلَ رَ، عَ بِرِن تَشُ عَ رَ.
\q1 عَ تَن نَن قٍ رَفِرِ مَ.
\q1 
\v 6 عَلَ قَمَ عِ شَ نْندِ مَكّنّندٍ
\q1 عَلْ عَ سٌفٍ رَ مِنِمَ كِ نَشّ فّيسّفّ.
\q1 عَ عِ شَ شُننَكٍلِ مَكّنّنمَ
\q1 عَلْ سٌفٍ نَشَن يَنبَمَ يَنيِ رَ.
\q1 
\v 7 عِ بْحّ رَشَرَ عَلَتَلَ يَ عِ،
\q1 عِ شَ مَمّ تِ، عَلَ نَ نَ.
\q1 عِ نَشَ مِشِ حَاشِ تْونّ هَلِ عَ شَ قٍ بِرِن سْونّيَشِ.
\q1 
\v 8 عِ نَشَ شْنْ، عِ عِ بْحّ مَفٌرٌ.
\q1 نَ تْونّ لُ نَ، عَ مُ قٍيٍ سْونّيَمَ عِ بّ.
\b
\q1 
\v 9 عَلَ قَمَ مِشِ حَاشِيٍ رَحْندٍ،
\q1 كْنْ نَشٍيٍ عٍ شَشِلِ تِشِ عَلَ رَ،
\q1 عٍ قَمَ يِ بْشِ سْتْدٍ كّ رَ.
\q1 
\v 10 عَ مُ بُمَ مِشِ حَاشِيٍ شَ لْي دُنِحَ مَ.
\q1 عٍ مُ تٌمَ دّدّ.
\q1 
\v 11 نَشٍيٍ بْحّيٍ مَفٌرٌشِ،
\q1 عٍ تَن نَن قَمَ يِ بْشِ سْتْدٍ كّ رَ، عٍ لُ بْحّسَ كُي.
\q1 
\v 12 تِنشِنتَرٍ تِنشِنتْي يَنقَمَ، عَ شْنْ عَ مَ.
\q1 
\v 13 كْنْ مَرِفِ يٍلٍمَ نَ مِشِ حَاشِ مَ،
\q1 بَرِ مَ عَ عَ كٌلٌن عَ قَمَ نَشَن سْتْدٍ.
\q1 
\v 14 مِشِ حَاشِيٍ سَنتِدّفّمَ بَمَ عَ تّي عِ،
\q1 عٍ شَلِ قَن سُشُ،
\q1 عَلَكٌ عٍ شَ مِسِكِينّ نُن سٍتَرٍ تْورْ،
\q1 عٍ شَ تِنشِنتْي كْن نَشَبَ.
\q1 
\v 15 كْنْ عٍ تَن نَن قَمَ قَشَدٍ عٍ يّتّ شَ سَنتِدّفّمَ سَابُي رَ.
\q1 عٍ شَ شَلِيٍ قَمَ فِرَدٍ.
\q1 
\v 16 سٍ شُرِ نَشَن نَ تِنشِنتْي يِ رَ،
\q1 عَ قِسَ مِشِ حَاشِيٍ شَ بَننَيَ بّ،
\q1 
\v 17 بَرِ مَ عَلَتَلَ عٍ سّنبّ كَنَمَ نّ،
\q1 عَ قَ تِنشِنتْي مَلِ.
\q1 
\v 18 عَلَتَلَ حّنفِ سَشِ مِشِ قَنيِ شْن.
\q1 عٍ كّ بُمَ نّ عَبَدَن.
\q1 
\v 19 عٍ مُ يَافِمَ تْورّ تّمُي، عٍ لُفَمَ نّ كَامّ وَشَتِ.
\q1 
\v 20 كْنْ مِشِ حَاشِيٍ قَشَمَ نّ.
\q1 عَلَتَلَ يَشُييٍ لُمَ نّ عَلْ قِيلِ،
\q1 نَشَن سّشّ لِسِمَ، عَ قَ فَن.
\q1 
\v 21 مِشِ حَاشِ دٌنِ تٌنفٌمَ نّ، كْنْ عٍ مُ عَ قِمَ.
\q1 مِشِ قَنيِ تَن مِشِيٍ كِمَ عَ شَ قٌنِسِرٍيَ كُي.
\q1 
\v 22 عَلَتَلَ شَ بَرَكَتْييٍ يِ بْشِ سْتْمَ نّ كّ رَ،
\q1 كْنْ عَلَ نَشَن دَنكَمَ، نَ كَنيِ قَمَ هَلَكِدٍ.
\b
\q1 
\v 23 نَشَن حّرّ كِ رَقَن عَلَتَلَ مَ،
\q1 عَ نَ كَنيِ مَلِمَ نّ عَ شَ دُنِحّءِفِرِ كُي.
\q1 
\v 24 هَلِ عَ سَ دِنكٌن، عَ مُ بِرَ مَ،
\q1 بَرِ مَ عَ بّلّشّ نَ عَلَتَلَ يِ رَ.
\q1 
\v 25 كَبِ ﭑ دِ مّدِ تّمُي، هَن ﭑ شّمْشِ رَ،
\q1 ﭑ مُ تِنشِنتْي كٍرٍن تٌشِ عَلَ نَشَن نَبّحِنشِ،
\q1 نَشَن شَ دِيٍ تَامِ مَكُلَمَ.
\q1 
\v 26 تِنشِنتْي كِ تِمَ، عَ مِشِيٍ دٌنِمَ.
\q1 عَ شَ دِيٍ بَرَكّ سْتْمَ نّ.
\b
\q1 
\v 27 عِ شَ قٍ كٌبِ لُ نَ، عِ شَ قٍ قَنيِ رَبَ.
\q1 نَ كُي عِ سِمَيَ شْنكُيٍ سْتْمَ نّ.
\q1 
\v 28 سّرِيّ رَقَن عَلَتَلَ مَ.
\q1 عَ مُ عَ شَ هِننّنتٍيٍ رَبّحِنمَ.
\q1 عَ عٍ كَنتَمَ نّ عَبَدَن.
\q1 كْنْ مِشِ حَاشِيٍ بْنسْي قَمَ نّ هَلَكِدٍ.
\b
\q1 
\v 29 تِنشِنتْييٍ قَمَ نّ يِ بْشِ سْتْدٍ كّ رَ،
\q1 عٍ لُ بٍ عَبَدَن.
\q1 
\v 30 تِنشِنتْي لْننِ نَن مَسٍنمَ،
\q1 سّرِيّ نَن مِنِمَ عَ دّ كُي.
\q1 
\v 31 عَ مَرِفِ عَلَ شَ سّرِيّ نَ عَ بْحّ كُي،
\q1 عَ مُ بِرَ مَ كِرَ شْن.
\b
\q1 
\v 32 مِشِ حَاشِ تِنشِنتْي يَنقَمَ، عَ شَ عَ قَشَ.
\q1 
\v 33 كْنْ عَلَتَلَ مُ تِنشِنتْي لُمَ عَ يَشُييٍ سَفٌي.
\q1 عَ مُ تِنمَ عٍ شَ عَ تْوحّفّ كِيتِ تّمُي.
\b
\q1 
\v 34 عِ شَشِلِ تِ عَلَتَلَ رَ، عَ شَ كِرَ سُشُ،
\q1 عَلَكٌ عَ شَ عِ رَكٍلِ، عِ شَ يِ بْشِ سْتْ كّ رَ.
\q1 نَ تّمُي عِ مِشِ حَاشِيٍ تٌمَ نّ عٍ هَلَكِشِ.
\q1 
\v 35 تّمُي دَنفِشِ ﭑ بَرَ سّنبّمَ حَاشِ ندٍ تٌ.
\q1 عَ شُنفبٌ عَلْ وُرِ تٌقَنيِ.
\q1 
\v 36 كْنْ ﭑ تٌ دَنفِ عَ يِرٍ عَ قِرِن ندٍ،
\q1 ﭑ نَشَ عَ لِ عَ شَ قٍ شُبٍن.
\q1 ﭑ نَشَ عَ قٍن، كْنْ ﭑ مُ عَ تٌ.
\b
\q1 
\v 37 عِ شَ مِشِ قَنيِ نَن مَتٌ، تِنشِنتْي نَن عِفبّ.
\q1 نَ مِشِ مْولِ قِندِ مَ بَرَكَتْي نَن نَ.
\q1 
\v 38 كْنْ يُنُبِتْييٍ تَن قَمَ نّ سْنتْدٍ،
\q1 عٍ بْنسْي بِرِن قَ هَلَكِ.
\q1 
\v 39 عَلَتَلَ تِنشِنتْييٍ رَكِسِمَ نّ،
\q1 عَ قِندِ عٍ شَ مَكَنتَمَ رَ عٍ شَ تْورّ كُي.
\q1 
\v 40 عَ عٍ مَلِمَ نّ، عَ عٍ رَتَنفَ.
\q1 عَ عٍ رَتَنفَ مِشِ حَاشِيٍ مَ، عَ عٍ رَكِسِ،
\q1 بَرِ مَ عٍ يِفِيَشِ عَ تَن نَن مَ.
\c 38
\s1 ﭑ سّنبّ بَرَ كَنَ
\s2 عَلَ مَشَندِ
\d 
\v 1 دَوُدَ شَ مَشَندِ بّيتِ
\q1 
\v 2 عَلَتَلَ، عِ نَشَ ﭑ حَشَنكَتَ عِ شَ شْنّ كُي،
\q1 عِ نَشَ ﭑ هَلَكِ عِ شَ بْحّتٍ كُي.
\q1 
\v 3 عِ بَرَ ﭑ مَشْنْ عِ شَ تَنبّ رَ، عِ بَرَ ﭑ نَبِرَ.
\q1 
\v 4 يَلَنيِ يٌ مُ نَ ﭑ بّ عِ شَ شْنّ كُي.
\q1 ﭑ مَ يُنُبِ بَرَ عَ نِيَ ﭑ قَتٍ بِرِن شَ تْورْ.
\q1 
\v 5 ﭑ مَ يُنُبِيٍ بَرَ فبٌ ﭑ شُن مَ.
\q1 نَ كٌتٍ بَرَ بِنيَ، ﭑ مُ عَ نْمَ سْنْن.
\q1 
\v 6 ﭑ مَ قِيٍ بَرَ فبٌ، عٍ شِرِ بَرَ حَاشُ.
\q1 نَ بِرِن قَتَنشِ ﭑ مَ شَشِلِتَرٍحَ نَن نَ.
\q1 
\v 7 ﭑ بْحّ بَرَ كَنَ، شُننَكٍلِ مُ نَ ﭑ بّ.
\q1 ﭑ لُمَ قّيحّن نَ سُننُنيِ نَن كُي.
\q1 
\v 8 ﭑ قَتٍ بِرِن وٌلٍنشِ، يَلَنيِ يٌ مُ نَ سْنْن.
\q1 
\v 9 ﭑ سّنبّ بَرَ كَنَ، ﭑ قَتٍ بِرِن بَرَ بَ ﭑ مَ.
\q1 ﭑ بْحّ تْورْشِ تُن.
\q1 
\v 10 ﭑ مَرِفِ، عِ ﭑ وَشْنقٍ كٌلٌن،
\q1 ﭑ مَ تْورّ مُ نْشُنشِ عِ مَ.
\q1 
\v 11 ﭑ بْحّ مُ سَشِ، ﭑ سّنبّ بَرَ حْن.
\q1 ﭑ يَ مُ نَءِيَلَنيِ تٌمَ سْنْن.
\q1 
\v 12 ﭑ شَنُنتٍنيِيٍ نُن ﭑ بٌورٍيٍ بَرَ كٍلِ ﭑ شُن مَ
\q1 ﭑ مَ قُرٍ شَ قٍ رَ، ﭑ نفَشَكٍرٍنيِيٍ بَرَ عٍ مَكُيَ ﭑ نَ.
\q1 
\v 13 نَشٍيٍ وَ مَ ﭑ قَشَقٍ، عٍ بَرَ يّلّ عِتَلَ ﭑ يَ رَ.
\q1 نَشٍيٍ وَ مَ ﭑ تْورْقٍ، عٍ بَرَ ﭑ كٌنبِ،
\q1 عٍ ﭑ تْوحّفّمَ تّمُي بِرِن.
\q1 
\v 14 كْنْ ﭑ مُ ﭑ تُلِ مَتِ نَ وْيّنيِيٍ رَ،
\q1 ﭑ مُ ﭑ دّ رَبِ ﭑ شَ عٍ يَابِ.
\q1 
\v 15 ﭑ لُمَ عَلْ تُلِ شْرِ، ﭑ لُمَ عَلْ بٌبٌي.
\b
\q1 
\v 16 عَلَتَلَ، ﭑ شَشِلِ تِشِ عِ تَن نَن نَ.
\q1 ﭑ مَرِفِ عَلَ، عِ تَن نَن فبَنسَن نْمَ ﭑ يَابِدٍ.
\q1 
\v 17 ﭑ نَشّ، «عِ نَشَ تِن ﭑ يَشُييٍ شَ يٌ ﭑ مَ،
\q1 عٍ شَ حّلّشِن ﭑ مَ تْورّ شَ قٍ رَ.»
\q1 
\v 18 عَ فبٍ مُ لُشِ ﭑ شَ بِرَ،
\q1 ﭑ نَ تْورْقٍ تّمُي بِرِن.
\q1 
\v 19 ﭑ بَرَ ﭑ تِ ﭑ مَ يُنُبِ رَبَشِيٍ رَ،
\q1 ﭑ يَنفٌي نَشٍيٍ رَبَشِ، نَ قٍ بَرَ ﭑ كْنتْقِلِ.
\q1 
\v 20 ﭑ يَشُييٍ تَن كّندّ، عٍ سّنبّ فبٌ.
\q1 ﭑ شْنمِشِيٍ بَرَ وُيَ، هَلِ نْندِ مُ نَ عٍ بّ.
\q1 
\v 21 نَشٍيٍ قٍ قَنيِ مَسَرَ مَ قٍ حَاشِ رَ، عٍ ﭑ تْورْ مَ،
\q1 بَرِ مَ ﭑ تَن بِرَ مَ قٍ قَنيِ نَن قْشْ رَ.
\q1 
\v 22 عَلَتَلَ، عِ نَشَ ﭑ نَبّحِن.
\q1 ﭑ مَرِفِ عَلَ، عِ نَشَ عِ مَكُيَ ﭑ نَ.
\q1 
\v 23 ﭑ مَرِفِ، عِ شَ قَ مَقُرٍن ﭑ مَلِدٍ.
\q1 ﭑ مَرِفِ، ﭑ مَ مَرَكِسِمَ نَن عِ رَ.
\c 39
\s1 عَدَ مَ لُمَ عَلْ قٌيٍ
\s2 عَلَ مَشَندِ
\d 
\v 1 دَوُدَ شَ بّيتِ بّيتِبَيٍ شَ مَنفّ يٍدُتُن بّ
\q1 
\v 2 ﭑ بَرَ عَ قَلَ، «ﭑ قٍ بِرِن نَبَمَ،
\q1 عَلَكٌ ﭑ نَشَ يُنُبِ رَبَ ﭑ دّ رَ.
\q1 ﭑ قٍ بِرِن نَبَمَ،
\q1 عَلَكٌ ﭑ نَشَ نَ وْيّنيِ مْولِ قَلَ مِشِ حَاشِيٍ يَ شْرِ.»
\q1 
\v 3 ﭑ مَ تْورّ شُنفبٍ كُي،
\q1 ﭑ نَشَ دُندُ، ﭑ مُ سٍسٍ قَلَ، ﭑ نَشَ ﭑ سَبَرِ تُن.
\q1 
\v 4 ﭑ بْحّ نُ سَتُنمَ، ﭑ مَ تْورّ نَشَ لُ عَلْ تّ دّشّشِ.
\q1 نَ بَرَ عَ نِيَ ﭑ شَ يِ وْيّنيِ قَلَ،
\q1 
\v 5 «عَلَتَلَ، عَ مَسٍن ﭑ بّ ﭑ قَشَمَ تّمُي مُندُن،
\q1 ﭑ مَ سِمَيَ سِفَمَ هَن مِندٍن،
\q1 عَلَكٌ ﭑ شَ ﭑ سّنبّ شَ شُرُنيِ كٌلٌن.
\q1 
\v 6 عِ بَرَ ﭑ مَ سِمَيَ رَدُنكٍ، عَ شْن مُ كُيَ سْنْن.
\q1 عَدَ مَ لُمَ عَلْ قٌيٍ نَشَن دَنفِمَ.» \qs حّنفِ رَتٍ.\qs*
\q1 
\v 7 عَدَ مَ لُشِ نّ عَلْ نِينِ، نَشَن مِنِمَ، عَ قَ دَنفِ.
\q1 عَ نَاقُلِ مَلَنمَ، كْنْ نَشَن قَمَ عَ سْتْدٍ،
\q1 عَ مُ نَ كٌلٌن.
\q1 
\v 8 ﭑ مَرِفِ، ﭑ قَ ﭑ شَشِلِ تِمَ ندٍ رَ؟
\q1 عِ تَن نَن فبَنسَن نْمَ ﭑ مَلِدٍ.
\q1 
\v 9 ﭑ نَكِسِ ﭑ مَ يُنُبِيٍ بِرِن مَ.
\q1 عِ نَشَ ﭑ نَيَافِ دَشُييٍ يَ شْرِ.
\q1 
\v 10 ﭑ بَرَ دُندُ، ﭑ مُ سٍسٍ قَلَمَ،
\q1 بَرِ مَ عِ تَن نَن نَ وَلِقٍ.
\q1 
\v 11 عِ شَ قُرٍ بَ ﭑ مَ، بٍينُ عِ شَ ﭑ نَحْن تْورّ كُي.
\q1 
\v 12 عِ مِشِ حَشَنكَتَمَ عَ شَ يُنُبِ شَ قٍ رَ.
\q1 نَشَن نَقَن عَدَ مَ مَ، عِ نَ بَمَ عَ يِ.
\q1 نَ قٍ لُمَ نّ عَلْ كُلِ نَشَن بٌفِسٍ قَنيِ شُن نَكَنَمَ
\q1 بٍينُ مِشِ شَ عَ مَتٌنفٌ.
\q1 عَدَ مَدِ مِسَالِشِ قٌيٍ نَن نَ نَشَن دَنفِمَ. \qs حّنفِ رَتٍ.\qs*
\b
\q1 
\v 13 عَلَتَلَ، ﭑ مَ دُبّ سُشُ،
\q1 عِ شَ عِ تُلِ مَتِ ﭑ مَ مَشَندِ رَ.
\q1 عِ شَ ﭑ وَ شُي مّ، بَرِ مَ عِ شَ شْحّ نَن ﭑ نَ.
\q1 ﭑ لُمَ عَلْ ﭑ بٍنبَيٍ،
\q1 ﭑ مُ بُمَ يِ دُنِحَ بّندّ قُحِ قَرِ.
\q1 
\v 14 عِ شَ عِ شَ حَشَنكَتّ رَفبِلٍن ﭑ قْشْ رَ سِندٍن،
\q1 شَ نَ مُ عَ رَ ﭑ قَشَمَ نّ.
\c 40
\s1 ﭑ مُ نْمَ دُندُدٍ
\s2 عَلَ مَشَندِ نُن عَلَ مَتْشْي
\d 
\v 1 دَوُدَ شَ بّيتِ بّيتِبَيٍ شَ مَنفّ بّ
\q1 
\v 2 ﭑ بَرَ ﭑ شَشِلِ تِ عَلَتَلَ رَ،
\q1 عَ بَرَ عَ تُلِ مَتِ ﭑ نَ.
\q1 
\v 3 عَ بَرَ ﭑ بَ بٌورَ شْورَ،
\q1 عَ ﭑ سَنيِ رَدِكِ قَنيٍ رَ.
\q1 
\v 4 عَ بَرَ بّيتِ نّينّ سَ ﭑ بْحّ مَ
\q1 نَشَن قِندِشِ تَنتُي رَ عَلَ بّ.
\q1 مِشِ فبٍفبٍ نَ نَ مّ، عٍ فَاشُمَ نّ عَلَ يَ رَ،
\q1 عٍ عٍ يّتّ تَشُ عَلَتَلَ رَ.
\b
\q1 
\v 5 حّلّشِنيِ نَ عَدَ مَ نَن بّ
\q1 نَشَن عَ شَشِلِ تِشِ عَلَتَلَ رَ،
\q1 نَشَن مُ عَ كٌبٍ رَتٌشِ يّتّ عِفبٌي مَ،
\q1 نَشَن مُ عَ كٌبٍ رَتٌشِ كُيٍ بَتُقٍ مَ.
\q1 
\v 6 ﭑ مَرِفِ عَلَتَلَ،
\q1 عِ بَرَ عِ شَ قٍ قَنيِ فبٍفبٍ مَسٍن مُشُ بّ.
\q1 عِ مَنِيّ مُ نَ.
\q1 ﭑ وَ مَ نَ بِرِن تَفِ رَبَقٍ مِشِيٍ بّ،
\q1 كْنْ عِ شَ قٍ قَنيِ وُيَ هَن عَ بَرَ دَنفِ عَ عِ.
\q1 
\v 7 عِ مُ وَ مَ سّرّشّ تُن شَ شْن مَ.
\q1 عِ بَرَ ﭑ تُلِ رَبِ.
\q1 عِ مُ وَ مَ سّرّشّ فَن دَاشِ شْن مَ،
\q1 عِ مُ وَ مَ سّرّشّ يُنُبِ شَقَرِ دَاشِ قَن شْن مَ.
\q1 
\v 8 ﭑ بَرَ قَ كِتَابُي مَكُنتَنشِ رَ نَشَن سّبّشِ ﭑ بّ.
\q1 
\v 9 ﭑ مَرِفِ عَلَ، ﭑ بَرَ تِن عِ وَشْنقٍ مَ.
\q1 عِ شَ سّرِيّ نَ ﭑ سٌندٌنيِ كُي.
\q1 
\v 10 ﭑ تِنشِنيِ مَسٍنمَ حَمَ بّ.
\q1 عِ شَ عَ كٌلٌن عَلَتَلَ، ﭑ مُ قَمَ دُندُدٍ عِ شَ قٍ مَ.
\q1 
\v 11 ﭑ مُ نْمَ دُندُدٍ عِ شَ نْندِ مَ.
\q1 ﭑ عِ شَ قٍ قَنيِ نُن عِ شَ مَرَكِسِ قٍ قَلَمَ نّ.
\q1 ﭑ مُ عِ شَ قٌنِسِرٍيَ نُن عِ شَ نْندِ نْشُنمَ حَمَ مَ.
\b
\q1 
\v 12 عِ تَن عَلَتَلَ، عِ مُ قَمَ تٌندِدٍ ﭑ بّ عِ شَ مَرَقَنيِ مَ.
\q1 عِ شَ قٌنِسِرٍيَ نُن عِ شَ نْندِ ﭑ كَنتَمَ نّ تّمُي بِرِن.
\q1 
\v 13 تْورّ فبٍفبٍ بَرَ ﭑ نَبِلِن.
\q1 ﭑ مَ يُنُبِ قَن بَرَ فبٌ هَن عَ بَرَ دَنفِ عَ عِ.
\q1 عٍ بَرَ وُيَ دَنفِقٍ ﭑ شُنسّشّيٍ رَ.
\q1 لِمَنِيَ بَرَ بَ ﭑ يِ رَ.
\q1 
\v 14 عَلَتَلَ، يَندِ، ﭑ نَتَنفَ.
\q1 عَلَتَلَ، يَندِ، ﭑ مَلِ.
\q1 
\v 15 نَشٍيٍ وَ مَ ﭑ نِي بَقٍ،
\q1 نَشٍيٍ وَ مَ ﭑ مَ قٍ حَاشِ شْن مَ،
\q1 عٍ بِرِن شَ مَكُيَ ﭑ نَ يَافِ كُي.
\q1 
\v 16 نَشٍيٍ ﭑ مَيٍلٍمَ، يَافِ شَ عٍ دّ عِشَرَ.
\b
\q1 
\v 17 نَشٍيٍ بِرِن بِرَشِ عِ قْشْ رَ،
\q1 عٍ شَ سّيوَ، عٍ شَ حّلّشِن عِ شَ قٍ رَ.
\q1 نَشٍيٍ وَ مَ عِ شَ كِسِ شْن مَ،
\q1 عٍ شَ عَ قَلَ تّمُي بِرِن، «تَنتُي نَ عَلَتَلَ بّ.»
\q1 
\v 18 سٍتَرٍ نُن مِسِكِينّ نَن نَ ﭑ نَ،
\q1 كْنْ مَرِفِ بَرَ رَتُ ﭑ مَ قٍ مَ.
\q1 عِ تَن نَن نَ ﭑ مَ مَلِمَ رَ عَ نُن ﭑ نَكِسِمَ.
\q1 ﭑ مَرِفِ عَلَتَلَ، عِ نَشَ دُفُندِ!
\c 41
\s1 قُرٍ مَ عَلَ مَشَندِقٍ
\s2 عَلَ مَشَندِ
\d 
\v 1 دَوُدَ شَ بّيتِ بّيتِبَيٍ شَ مَنفّ بّ
\q1 
\v 2 حّلّشِنيِ نَ مِشِ بّ نَشَن هِننّمَ تْورْ مِشِ رَ.
\q1 عَلَتَلَ عَ رَتَنفَمَ نّ عَ شَ تْورّ مَ.
\q1 
\v 3 عَلَتَلَ عَ رَتَنفَمَ نّ، عَ عَ رَبَلٌ.
\q1 عَ حّلّشِنمَ نّ دُنِحَ.
\q1 عِ مُ عَ لُمَ عَ يَشُييٍ سَفٌي.
\q1 
\v 4 عَلَتَلَ عَ مَلِمَ نّ عَ قُرَ تّمُي، عَ عَ رَيَلَن.
\b
\q1 
\v 5 ﭑ عَ قَلَمَ عَ بّ،
\q1 «عَلَتَلَ، هِننّ ﭑ نَ.
\q1 ﭑ نَيَلَن بَرِ مَ ﭑ بَرَ يُنُبِ رَبَ عِ رَ.»
\q1 
\v 6 ﭑ يَشُييٍ وْيّن حَاشِيٍ قَلَمَ، عٍ نَشّ،
\q1 «عَ قَشَمَ مُن تّمُي؟
\q1 عَ شِلِ لْيمَ مُن لْشْي؟»
\q1 
\v 7 نَشَن قَمَ ﭑ شّيبُدٍ عَ قِلَنكَقُي وْيّنيِ قَلَمَ.
\q1 قٍ حَاشِ فبٌ عَ بْحّ كُي.
\q1 عَ نَ كٍلِ ﭑ شُن مَ، عَ نَ مْولِ قَلَمَ.
\b
\q1 
\v 8 ﭑ شْنمِشِيٍ ﭑ مَ قٍ مَكْلِكْلِمَ عٍ بٌورٍ بّ،
\q1 عٍ شَ ﭑ تْورْ.
\q1 
\v 9 عٍ نَشّ، «قُرٍ حَاشِ بَرَ عَ سُشُ،
\q1 عَ بَرَ تَفَن، عَ مُ كٍلِمَ سْنْن.»
\q1 
\v 10 هَلِ ﭑ دّقَنبٌورٍ، ﭑ نُ لَشِ نَشَن نَ،
\q1 مُشُ نُن نَشَن نُ مُشُ دّفٍمَ يِرٍ كٍرٍن،
\q1 نَ بَرَ عَ كٌبٍ تِ ﭑ نَ.
\b
\q1 
\v 11 عَلَتَلَ، هِننّ ﭑ نَ، عِ شَ ﭑ نَكٍلِ،
\q1 عَلَكٌ ﭑ شَ ﭑ يَشُييٍ سَرٍ رَفبِلٍن عٍ مَ.
\q1 
\v 12 ﭑ عَ كٌلٌن ﭑ نَقَن عِ مَ،
\q1 بَرِ مَ عِ مُ ﭑ لُمَ ﭑ يَشُييٍ سَفٌي.
\q1 
\v 13 عِ ﭑ مَلِمَ نّ بَرِ مَ ﭑ تِنشِن.
\q1 عِ بَرَ تِن ﭑ شَ لُ عِ سّيتِ مَ عَبَدَن.
\q1 
\v 14 تَنتُي نَ عِسِرَيِلَ مَرِفِ عَلَتَلَ بّ عَبَدَن.
\q1 عَمِنَ. عَمِنَ.
\c 42
\s1 ﭑ سٌندٌنيِ نِمِسَشِ مُنقٍ رَ؟
\s2 عَلَ مَشَندِ
\d 
\v 1 كٌرَ شَ دِيٍ شَ لْننِ بّيتِ بّيتِبَيٍ شَ مَنفّ بّ
\q1 
\v 2 عَلَ، ﭑ وَ مَ لُقٍ عِ يِرٍ.
\q1 ﭑ عِ قٍنمَ عَلْ شٍلِ يٍ قٍنمَ كِ نَشّ.
\q1 
\v 3 ﭑ هَيِ نَ عَلَ حِحّ مَ.
\q1 ﭑ عَ يِرٍ لِمَ مُن تّمُي؟
\q1 
\v 4 يَكْسِ ﭑ وَ مَ كْي رَ،
\q1 ﭑ وَ مَ يَنيِ رَ.
\q1 مِشِ ﭑ مَشْرِنمَ،
\q1 «عِ مَرِفِ عَلَ نَ مِندٍن؟»
\q1 
\v 5 ﭑ نَ رَتُ يِ قٍ مَ، ﭑ بْحّ سّيوَ مَ نّ.
\q1 سِنفٍ ﭑ نُ حَمَ رَحّرّ مَ عَلَ شَ هْرْ مْبَنشِ نَن كُي،
\q1 عٍ نُ بّيتِ بَقٍ حّلّشِنيِ كُي،
\q1 عٍ تَنتُي رَ سِفَ عَلَ مَ.
\q1 
\v 6 مُنقٍ رَ ﭑ سٌندٌنيِ نِمِسَشِ؟
\q1 مُنقٍ رَ ﭑ بْحّ سُننُنشِ؟
\q1 ﭑ شَ ﭑ شَشِلِ تِ عَلَ رَ،
\q1 ﭑ مَن شَ عَ تَنتُ عَ شَ كِسِ شَ قٍ رَ.
\q1 
\v 7 ﭑ مَرِفِ عَلَ، ﭑ بْحّ نِمِسَشِ ﭑ يّتّ كَن مَ قٍ رَ.
\q1 نَ نَ عَ رَ ﭑ نَن ﭑ نَتُمَ عِ مَ يُرُدّن،
\q1 ﭑ نَ دّننَشّ يِ تّمُي،
\q1 شٍرِ مٌن نُن مِسَرِ فٍيَيٍ نَ دّننَشّ.
\q1 
\v 8 ﭑ مَ تْورّ شُن نَن تُن مَسَقٍ.
\q1 عَ لُمَ عَلْ سُسُي يٍ نَشَن سِنمَ شُرٍ يٍ شُن.
\q1 
\v 9 عَلَتَلَ هِننّمَ ﭑ نَ يَنيِ رَ،
\q1 ﭑ قَن بّيتِ بَمَ عَ بّ كْي رَ.
\q1 ﭑ عَلَ مَشَندِ مَ نَشَن ﭑ نَبَلٌمَ.
\q1 
\v 10 ﭑ بَرَ عَ قَلَ عَلَ بّ،
\q1 نَشَن سّنبّ فبٌ عَلْ قَنيٍ،
\q1 «عِ نّيمُشِ ﭑ مَ مُنقٍ رَ؟
\q1 عِ ﭑ لُشِ تْورّ كُي
\q1 ﭑ يَشُييٍ شَ نْي بُن مَ مُنقٍ رَ؟»
\q1 
\v 11 ﭑ يَشُييٍ ﭑ تْورْ مَ كٌنبِ رَ لْشْ يٌ لْشْ.
\q1 عٍ ﭑ مَشْرِنمَ، «عِ مَرِفِ عَلَ نَ مِندٍن؟»
\q1 
\v 12 ﭑ سٌندٌنيِ نِمِسَشِ مُنقٍ رَ؟
\q1 ﭑ بْحّ سُننُنشِ مُنقٍ رَ؟
\q1 ﭑ شَ ﭑ شَشِلِ تِ عَلَ رَ،
\q1 ﭑ مَن شَ عَ تَنتُ عَ شَ كِسِ شَ قٍ رَ.
\q1 ﭑ مَرِفِ نَن نَ ﭑ مَ مَرَكِسِمَ رَ.
\c 43
\s1 ﭑ بْحّ سُننُنشِ مُنقٍ رَ؟
\s2 عَلَ مَشَندِ
\q1 
\v 1 عَلَ، عِ شَ ﭑ مَ كِيتِ سَ.
\q1 عِ شَ ﭑ شُن مَقَلَ حَمَ دَنشَنِيَتَرٍ شْن مَ.
\q1 عِ شَ ﭑ نَتَنفَ يَنقَنتٍيٍ نُن وُلٍ قَلّيٍ مَ.
\q1 
\v 2 عَلَ ﭑ مَ كَنتَمَ نَ عِ تَن نَن نَ،
\q1 عِ ﭑ نَبّحِنشِ مُنقٍ رَ؟
\q1 عِ ﭑ لُشِ تْورّ كُي ﭑ يَشُييٍ شَ نْي بُن مَ مُنقٍ رَ؟
\q1 
\v 3 عِ شَ ﭑ مَ كِرَ عِيَلَن عِ شَ نْندِ رَ،
\q1 عِ شَ ﭑ شُن تِ سِفَقٍ رَ عِ يِرٍ عِ شَ فٍيَ سّنِيّنشِ قَرِ.
\q1 
\v 4 ﭑ نَن ﭑ مَكْرّ مَ نّ عَلَ شَ سّرّشّبَدٍ رَ،
\q1 عَلَ نَشَن قِندِشِ ﭑ مَ سّيوّ نُن ﭑ مَ حّلّشِنيِ رَ.
\q1 ﭑ بّيتِ بَمَ ﭑ مَرِفِ عَلَ بّ كْرَ رَ.
\q1 
\v 5 ﭑ سٌندٌنيِ نِمِسَشِ مُنقٍ رَ؟
\q1 ﭑ بْحّ سُننُنشِ مُنقٍ رَ؟
\q1 ﭑ شَ ﭑ شَشِلِ تِ عَلَ رَ،
\q1 ﭑ مَن شَ عَ تَنتُ عَ شَ كِسِ شَ قٍ رَ.
\c 44
\s1 مُشُ مُ عِ شَ سَاتّ كَنَمَ
\s2 عَلَ مَشَندِ
\d 
\v 1 كٌرَ شَ دِيٍ شَ لْننِ بّيتِ بّيتِبَيٍ شَ مَنفّ بّ
\q1 
\v 2 عَلَ، مُشُ بَرَ عَ مّ مُشُ بٍنبَيٍ سَابُي رَ،
\q1 عِ وَلِ نَشَن نَبَشِ تّمُي دَنفِشِ.
\q1 
\v 3 عِ بَرَ سِيٍ كٍرِ بٍ
\q1 عَلَكٌ مُشُ بٍنبَيٍ شَ سَبَتِ يِ بْشِ مَ.
\q1 
\v 4 عٍ مُ بٍ سْتْ عٍ شَ سَنتِدّفّمَ شَ رَ،
\q1 عٍ مُ كِسِ سْتْ عٍ يّتّ سّنبّ شَ رَ.
\q1 عِ تَن نَن سّنبّ بَرَ عٍ رَكِسِ،
\q1 عِ تَن نَن شَ هِننّ بَرَ قِندِ نَ سَابُي رَ.
\q1 
\v 5 عَلَ، عِ تَن نَن قِندِ ﭑ مَ مَنفّ رَ.
\q1 يَندِ، عِ شَ يَشُبَ بْنسْي رَكِسِ.
\q1 
\v 6 مُشُ قَمَ مُشُ يَشُييٍ رَفبِلٍندٍ عِ تَن نَن سَابُي رَ،
\q1 مُشُ قَمَ عٍ رَفٌرٌدٍ عِ شِلِ رَ.
\q1 
\v 7 ﭑ مُ ﭑ شَشِلِ تِشِ ﭑ مَ شَلِ شَ رَ،
\q1 ﭑ مَ سَنتِدّفّمَ مُ نْمَ ﭑ نَكِسِدٍ.
\q1 
\v 8 كْنْ عِ تَن نَن مُشُ رَتَنفَمَ مُشُ يَشُييٍ مَ،
\q1 عِ تَن نَن مُشُ شْنمِشِيٍ رَيَافِمَ.
\q1 
\v 9 مُشُ عَلَ نَن مَتْشْمَ تّمُي بِرِن،
\q1 مُشُ عِ تَن نَن شِلِ تَنتُمَ عَبَدَن. \qs حّنفِ رَتٍ.\qs*
\b
\q1 
\v 10 كْنْ يَكْسِ عِ بَرَ مُشُ رَبّحِن،
\q1 عِ بَرَ مُشُ رَيَافِ.
\q1 عِ مُ مُشُ شَ سْورِيٍ مَلِمَ سْنْن.
\q1 
\v 11 عِ بَرَ مُشُ رَفِ مُشُ يَشُييٍ يَ رَ، نَشٍيٍ مُشُ شْنشِ،
\q1 نٍيٍ بَرَ مُشُ هَرِفٍ بِرِن بَ مُشُ يِ رَ.
\q1 
\v 12 عِ بَرَ مُشُ رَبّحِن عَلَكٌ عٍ شَ مُشُ قَشَ عَلْ شُرُ سٍيٍ،
\q1 عِ بَرَ مُشُ رَيٍنسٍن حَمَنّ فبّتّيٍ مَ.
\q1 
\v 13 عِ بَرَ عِ شَ حَمَ مَتِ سَرٍ شُرِ رَ،
\q1 نَشَن مُ قِندِ مَ فٍينِ رَ عِ بّ.
\q1 
\v 14 عِ بَرَ مُشُ رَيَافِ مُشُ دْشْبٌورٍيٍ شْن مَ.
\q1 مُشُ رَبِلِنيِيٍ يٌمَ مُشُ مَ.
\q1 
\v 15 عِ بَرَ عَ نِيَ سِ فبّتّيٍ شَ مُشُ مَيٍلٍ،
\q1 عٍ نُ عٍ شُنيِيٍ لِنتَن مُشُ مَ.
\q1 
\v 16 ﭑ شَشِلِ عِقُشِ تّمُي بِرِن، ﭑ بَرَ يَافِ.
\q1 
\v 17 نَشٍيٍ ﭑ شْنشِ، نٍيٍ ﭑ مَيٍلٍمَ، عٍ ﭑ كٌنبِمَ.
\q1 عٍ وَ مَ عٍ فبٍحْشْقٍ.
\b
\q1 
\v 18 هَلِ يِ بِرِن تٌ رَبَشِ مُشُ رَ،
\q1 مُشُ مُ نّيمُشِ عِ مَ،
\q1 مُشُ مُ عِ شَ سَاتّ كَنَشِ.
\q1 
\v 19 مُشُ بْحّ مُ فبِلٍنشِ عِ قْشْ رَ،
\q1 مُشُ مُ مُشُ مَكُيَشِ عِ شَ كِرَ رَ،
\q1 
\v 20 نَشَن عَ نِيَمَ عِ شَ مُشُ لُ وُلَبَرٍيٍ تَفِ،
\q1 مُشُ شَ قَشَ.
\q1 
\v 21 شَ مُشُ سَ نّيمُ مُشُ مَرِفِ عَلَ شِلِ مَ،
\q1 شَ نَ مُ عَ رَ مُشُ نَشَ عَلَ فبّتّيٍ بَتُ،
\q1 
\v 22 عَلَ مُ عَ كٌلٌنمَ شّ؟
\q1 عَ مُ مِشِ فُندٌ بِرِن كٌلٌن؟
\q1 
\v 23 كْنْ مِشِيٍ نَ مُشُ قَشَقٍ عَلْ شُرُ سٍيٍ.
\q1 عٍ نَ رَبَمَ تّمُي بِرِن عِ تَن نَن مَ قٍ رَ.
\b
\q1 
\v 24 ﭑ مَرِفِ، شُنُ. عِ شِقٍ مُنقٍ رَ؟
\q1 كٍلِ، عِ نَشَ مّي مُشُ رَ تّمُي بِرِن.
\q1 
\v 25 عِ يَتَفِ نْشُنمَ مُشُ مَ مُنقٍ رَ؟
\q1 عِ نّيمُشِ مُشُ شَ تْورّ نُن يَافِ مَ مُنقٍ رَ؟
\q1 
\v 26 مُشُ بِرَ نّ بْشِ، مُشُ مُ نْمَ كٍلِدٍ سْنْن.
\q1 
\v 27 يَندِ، كٍلِ، قَ مُشُ مَلِ.
\q1 عِ شَ مُشُ شُن سَرَ عِ شَ هِننّ شَ قٍ رَ.
\c 45
\s1 مَنفّ شَ قُتِ
\s2 عَلَ مَتْشْي
\d 
\v 1 كٌرَ شَ دِيٍ شَ لْننِ بّيتِ بّيتِبَيٍ شَ مَنفّ بّ. عَ شَ بَ عَلْ بّيتِ نَشَن شِلِ «قُفٍ تٌقَنيِيٍ.» شَنُنتٍيَ سِفِ.
\q1 
\v 2 وْيّن قَنيِيٍ بَرَ ﭑ بْحّ رَقٍ.
\q1 ﭑ شَ يِ وَلِ رَبَ مَنفّ بّ.
\q1 ﭑ نّنيِ لُمَ نّ عَلْ سّبّلِتِ قَنيِ شَ كَلٍ.
\b
\q1 
\v 3 عِ تٌقَن عَدَ مَدِ بِرِن بّ،
\q1 عِ قَتَ وْيّن حْشُنمّ تِدٍ،
\q1 بَرِ مَ عَلَ بَرَكّ سَمَ عِ شَ قٍ مَ تّمُي بِرِن.
\q1 
\v 4 عِ شَ عِ شَ سَنتِدّفّمَ شِرِ عِ تَفِ،
\q1 عَلَكٌ عِ شَ شُننَكٍلِ نُن عِ شَ بِنيّ شَ كٌلٌن.
\q1 سْورِ سّنبّمَ نَن عِ رَ.
\q1 
\v 5 عِ سّنبّ فبٌ.
\q1 تٍ عِ شَ سْورِ رَفِسٍ قَرِ، نْندِ، مَفٌرٌي، نُن تِنشِنيِ شَ قٍ رَ.
\q1 عِ شَ قٍ شُنفبٍ رَبَ.
\q1 
\v 6 عِ شَ تَنبّيٍ مَفَاشُ.
\q1 عٍ قَمَ عِ يَشُييٍ سٌندٌنيِ سْشْدٍ،
\q1 سِيٍ بِرَ مَ نّ عِ سَنيِيٍ بُن.
\b
\q1 
\v 7 «عَلَ، عِ شَ مَنفّ كِبَنيِ بُمَ نّ عَبَدَن.
\q1 تِنشِنيِ نَن قِندِشِ عِ شَ مَنفّيَ تْنشُمَ رَ.»
\b
\q1 
\v 8 تِنشِنيِ نَن نَقَن عِ مَ.
\q1 حَاشُيحَ مُ رَقَن عِ مَ قٍقٍ مَ.
\q1 نَ نَن عَ تٌشِ عِ مَرِفِ عَلَ بَرَ عِ سُفَندِ سّيوّ كُي.
\q1 قِسَمَنتٍ نَن عِ رَ دَنفِقٍ عِ بٌورٍيٍ رَ.
\q1 
\v 9 لَبُندّ نُن سٍ شِرِ حْشُنمّ نَ عِ شَ دُفِ مَ.
\q1 شُلُنيِ تِمَ عِ شَ مَنفّ بَنشِ تٌقَنيِ كُي.
\q1 كْرَيٍ حّلّشِنيِ شُي رَ مِنِمَ عِ بّ.
\q1 
\v 10 مَنفّيٍ شَ دِ فِنّيٍ لُمَ عِ سّيتِ مَ،
\q1 عِ شَ فِنّ قَن نَ عِ قّ مَ، عَ مَشِرِشِ شّيمَ تٌقَنيِ رَ.
\b
\q1 
\v 11 ﭑ مَ دِ فِنّ، عِ تُلِ مَتِ ﭑ نَ.
\q1 عِ نَشَ كَنكَن عِ بْنسْي مَ،
\q1 شَ نَ مُ عَ رَ عِ شَ دٍنبَيَ نُن عِ بَبَ مَ.
\q1 
\v 12 عِ شَ عِ عِفٌرٌ مَنفّ بّ
\q1 نَشَن قِندِشِ عِ مَرِفِ رَ.
\q1 عِ تٌقَن، عِ رَقَن عَ مَ كِ قَنيِ.
\q1 
\v 13 تِرٍكَيٍ قَمَ بُنسٍيٍ رَ عِ بّ،
\q1 نَاقُلِ كَنيِيٍ قَن قَنمَ عِ بِنيَدٍ.
\b
\q1 
\v 14 مَنفّ شَ دِ فِنّ سٌمَ بَنشِ كُي،
\q1 عَ مَشِرِشِ دُفِ تٌقَنيِ رَ، شّيمَ نَ عَ مَ.
\q1 
\v 15 عَ شَ كٌنيِ فِنّيٍ عَ مَتِمَ مَنفّ شْن.
\q1 مَنفّ قَن مَشِرِشِ دُفِ تٌقَنيِ رَ.
\q1 
\v 16 فِنّ سٌ تّمُي، مِشِ بِرِن حّلّشِنشِ،
\q1 عٍ شُلُنيِ تِمَ.
\b
\q1 
\v 17 عِ شَ دِيٍ قَمَ لُدٍ عَلْ عِ بٍنبَيٍ،
\q1 عٍ قِندِ مَنفّيٍ رَ بْشِ بِرِن شُن مَ.
\q1 
\v 18 ﭑ عِ تَن قِندِ مَ شِلِ كَنيِ نَن نَ عَبَدَن.
\q1 بْنسْي بِرِن عِ مَتْشْمَ نّ وَشَتِ يٌ وَشَتِ.
\c 46
\s1 وٌن مُ فَاشُمَ
\s2 عَلَ مَتْشْي
\d 
\v 1 كٌرَ شَ دِيٍ شَ بّيتِ بّيتِبَيٍ شَ مَنفّ بّ فِنّدِ مّدِ شُي دَاشِ
\q1 
\v 2 عَلَ، وٌن كَنتَمَ نَن عَ رَ.
\q1 وٌن مَ كَنتَرِ نَ عَ يِ رَ.
\q1 عَ وٌن مَلِمَ وٌن مَ تْورّ بِرِن كُي.
\q1 
\v 3 شَ بْشِ سَ سّرّن، وٌن مُ فَاشُمَ.
\q1 شَ فٍيَ سَ بِرَ بَا مَ، وٌن مُ فَاشُمَ.
\q1 
\v 4 شَ مْرْنيِيٍ سَ شَاحّ، وٌن مُ فَاشُمَ.
\q1 شَ فٍيَ سَ عَ عِمَشَ، عَ سّرّن، وٌن مُ فَاشُمَ.
\b
\q1 
\v 5 شُرٍ نَن عَ رَ، نَشَن سَلٌنيِيٍ عَلَ شَ تَا رَ سّيوَ مَ.
\q1 عَلَ شِلِ شُنفبٍ كَنيِ شَ هْرْ مْلِنفِرَ سّنِيّنشِ نَ مّننِ نّ.
\q1 
\v 6 عَلَ نَ نَ تَا كُي، نَ تَا مُ عَ رَ مَشَمَ،
\q1 عَ عَ مَلِمَ سُبَشّ نّقّ عَ لِ.
\q1 
\v 7 سِيٍ سْنشْي رَتٍمَ،
\q1 مَنفّيَيٍ بِرَ مَ نّ.
\q1 عَلَ نّقّ عَ شُي رَ مِنِ،
\q1 دُنِحَ بِرِن شُنُنمَ نّ.
\q1 
\v 8 مَنفّ عَلَتَلَ نَ وٌن سّيتِ مَ.
\q1 وٌن مَ كَنتَرِ نَ يَشُبَ مَرِفِ عَلَ يِ رَ.
\q1 
\v 9 وٌ قَ عَلَتَلَ شَ وَلِ مَتٌ،
\q1 عَ فبَلٌي نَشَن لُشِ بْشِ مَ.
\q1 
\v 10 عَ تَن نَن فٍرٍ حْنمَ دُنِحَ بِرِن مَ.
\q1 عَ شَلِ فِرَ مَ نّ.
\q1 عَ تَنبّ كَنَمَ نّ،
\q1 عَ مَكَنتَسٍ فَن.
\b
\q1 
\v 11 «وٌ وٌ رَشَرَ، وٌ شَ عَ كٌلٌن عَلَ نَ ﭑ تَن نَن نَ.
\q1 ﭑ سِ بِرِن يَمَرِ مَ.
\q1 ﭑ مَ يَامَرِ نَ دُنِحَ بِرِن مَ.»
\b
\q1 
\v 12 عَلَتَلَ نَ وٌن سّيتِ مَ،
\q1 وٌن مَ كَنتَرِ نَ يَشُبَ مَرِفِ عَلَ يِ رَ.
\c 47
\s1 عَلَ قِسَمَنتٍ مَنفّ
\s2 عَلَ مَتْشْي
\d 
\v 1 كٌرَ شَ دِيٍ شَ بّيتِ بّيتِبَيٍ شَ مَنفّ بّ
\q1 
\v 2 وٌ تَن سِيٍ بِرِن، وٌ وٌ بّلّشّ بْنبْ،
\q1 وٌ سْنشْ، وٌ شُي عِتٍ حّلّشِنيِ كُي عَلَ بّ!
\q1 
\v 3 عَلَتَلَ شِلِ شُنفبٍ كَنيِ مَفَاشُ.
\q1 مَنفّ شُنفبٍ نَن عَ رَ دُنِحَ بِرِن شُن مَ.
\q1 
\v 4 عَ بَرَ سِيٍ رَفٌرٌ وٌن بُن مَ،
\q1 عٍ شَ لُ وٌن سَفٌي.
\q1 
\v 5 عَ بَرَ بْشِ قِ وٌن مَ كّ رَ،
\q1 نَشَن قِندِشِ يَشُبَ بْنسْي شَ شُننَكٍلِ رَ.
\q1 عَ وٌن شَنُ. \qs حّنفِ رَتٍ.\qs*
\q1 
\v 6 عَلَ تٍمَ حّلّشِن شُي نَن تَفِ،
\q1 عَ قَمَ سَرَيٍ قٍ شُي مَ.
\q1 
\v 7 وٌ بّيتِ بَ عَلَ بّ، وٌ بّيتِ بَ!
\q1 وٌ بّيتِ بَ وٌن مَ مَنفّ بّ، وٌ بّيتِ بَ!
\q1 
\v 8 عَلَ نَن مَنفّ رَ دُنِحَ بِرِن شُن مَ،
\q1 وٌ شَ لْننِ بّيتِ بَ.
\q1 
\v 9 عَلَ مَفٌرٌشِ مَنفّ كِبَنيِ سّنِيّنشِ كُي،
\q1 سِ بِرِن مَنفّ نَن عَ رَ.
\q1 
\v 10 سِيٍ شَ مَنفّيٍ كَقُمَ عِبُرَهِمَ مَرِفِ عَلَ شَ حَمَ مَ،
\q1 بَرِ مَ عَلَ نَن عَ رَفِرِ مَنفّيٍ شَ دُنِحَ كَنتَ.
\q1 عَلَ نَ سٍ بِرِن شُن.
\c 48
\s1 عَلَ شَ تَا سِيٌن
\s2 عَلَ مَتْشْي
\d 
\v 1 كٌرَ شَ دِيٍ شَ بّيتِ. سِفِ سّنِيّنشِ.
\q1 
\v 2 عَلَتَلَ فبٌ.
\q1 عَ لَنمَ وٌن شَ عَ مَتْشْ
\q1 عَ شَ تَا كُي عَ شَ فٍيَ سّنِيّنشِ قَرِ.
\q1 
\v 3 عَلَ شَ فٍيَ سِيٌن تٌقَن،
\q1 عَ رَقَن دُنِحَ بِرِن مَ.
\q1 نَ قِندِ مَنفّ شُنفبٍ شَ تَا نَن نَ.
\q1 
\v 4 عَلَ عَ حّنفِ سَمَ عَ شَ تَا مَكَنتَشِ شْن،
\q1 عَ بَرَ عَ يّتّ قِندِ عَ كَنتَمَ رَ.
\q1 
\v 5 مَنفّيٍ تٌ عٍ مَلَن سِيٌن فٍرٍ شِلِ مَ،
\q1 
\v 6 عٍ نَشَ كَابَ نَ تٌقٍ رَ.
\q1 عٍ نَشَ فَاشُ، عٍ قَ عٍ فِ.
\q1 
\v 7 عٍ تٌ فَاشُ نَ يَ رَ،
\q1 عٍ نَشَ سّرّن عَلْ فِنّ نَشَن نَ دِ بَرِقٍ،
\q1 
\v 8 شَ نَ مَرَ عَلْ تَرَ سِسِ شَ كُنكُييٍ
\q1 قٌيٍ شُنفبٍ نَشٍيٍ عِمَشَمَ.
\q1 
\v 9 وٌن مَرِفِ عَلَ كَابَنَكٌ نَشَن نَبَشِ عَ شَ تَا كُي،
\q1 وٌن بَرَ نَ مّ، وٌن بَرَ نَ تٌ.
\q1 مَنفّ عَلَتَلَ نَ تَا رَكِسِمَ تّمُي بِرِن. \qs حّنفِ رَتٍ.\qs*
\q1 
\v 10 عَلَ، مُشُ نَ سٌ عِ شَ هْرْ مْلِنفِرَ كُي،
\q1 مُشُ رَتُمَ عِ شَ هِننّ نَن مَ.
\q1 
\v 11 عَلَ شِلِ شُنفبٍ كَنيِ،
\q1 عِ شِلِ تَنتُمَ نّ دُنِحَ يِرٍ بِرِن.
\q1 عِ شَ مَنفّيَ تِنشِن.
\q1 
\v 12 حَمَ حّلّشِنمَ نّ سِيٌن فٍيَ قَرِ،
\q1 يُدَكَيٍ سّيوَ مَ نّ عِ شَ كِيتِ شَ قٍ رَ.
\q1 
\v 13 وٌ شَ سِيٌن مَبِلِن،
\q1 وٌ شَ عَ شَ سْورِ تِدٍيٍ كْنتِ.
\q1 
\v 14 وٌ شَ عَ تّتّ نُن عَ يِرٍ مَكَنتَشِيٍ مَتٌ،
\q1 عَلَكٌ وٌ شَ نَ قَلَ وٌ شَ دِيٍ بّ.
\q1 
\v 15 عَلَ نَن نَ وٌن مَرِفِ عَلَ رَ عَبَدَن.
\q1 عَ وٌن نَحّرّ مَ هَن عَلِفِيَمَ.
\c 49
\s1 عَلِفِيَمَ سِفَقٍ مُ كَنَمَ
\s2 عَلَ شَ سّرِيّ
\d 
\v 1 كٌرَ شَ دِيٍ شَ بّيتِ بّيتِبَيٍ شَ مَنفّ بّ
\q1 
\v 2 وٌ وٌ تُلِ مَتِ يِ رَ، وٌ تَن حَمَ بِرِن.
\q1 دُنِحَ حَمَ بِرِن، وٌ وٌ تُلِ مَتِ ﭑ نَ.
\q1 
\v 3 تِدٍ شُرِ كَنيِ، تِدٍ شُنفبٍ كَنيِ،
\q1 سٍتَرٍ عَ نُن سٍ كَنيِ،
\q1 وٌ بِرِن شَ وٌ تُلِ مَتِ.
\q1 
\v 4 ﭑ قَمَ وْيّنيِ هَفِفّ نَن قَلَدٍ وٌ بّ،
\q1 ﭑ بْحّ شَشِلِ قَنيِ نَشَن مَحْشُنشِ.
\q1 
\v 5 ﭑ نَن ﭑ تُلِ تِشِ تَالِ رَ،
\q1 ﭑ قَمَ نَ تَفِ رَبَدٍ وٌ بّ كْرَ شُي رَ.
\b
\q1 
\v 6 مُنقٍرَ ﭑ قَ فَاشُمَ فبَلٌي لْشْي يَ رَ،
\q1 ﭑ يَشُييٍ شَ قٍ كٌبِ ﭑ نَبِلِنمَ تّمُي نَشّ؟
\q1 
\v 7 عٍ لَشِ عٍ شَ بَننَيَ نَن نَ،
\q1 عٍ نُ قَ عٍ يّتّ مَتْشْ عٍ هَرِفٍ شَ فبٌي رَ.
\q1 
\v 8 عٍ مُ نْمَ عٍ بٌرٍ شُنسَرَدٍ،
\q1 عٍ مُ نْمَ عٍ شُنسَرٍ قِدٍ عَلَ مَ.
\q1 
\v 9 عٍ نِي شُنسَرٍ شْرْشْ،
\q1 عٍ مُ نْمَ عَ قِدٍ عَبَدَن.
\q1 
\v 10 عٍ تَن مُ قَشَمَ؟
\q1 عٍ مُ سِفَمَ عَلِفِيَمَ؟
\q1 
\v 11 وٌن عَ تٌمَ، لْننِلَيٍ قَشَمَ،
\q1 لْننِتَرٍيٍ قَن قَشَمَ نّ.
\q1 عٍ قَ عٍ هَرِفٍ لُ مِشِ فبّتّيٍ يِ رَ.
\q1 
\v 12 مِشِ نَشٍيٍ عٍ شِلِيٍ سَشِ بْشِيٍ شُن مَ،
\q1 عٍ مَحْشُنشِ نّ عٍ شَ بَنشِيٍ لُمَ نّ نَا عَبَدَن،
\q1 عٍ شْنيِ مُ كَنَمَ كٍلِ لَنقَنمَيٍ مَ،
\q1 عَ سَ دْشْ لَنقَنمَ فبّتّيٍ رَ.
\q1 
\v 13 هَلِ مِشِ شُنفبٍ، عَ مُ بُمَ.
\q1 عَ قَشَمَ نّ عَلْ سُبٍيٍ.
\q1 
\v 14 مِشِ نَشٍيٍ لَشِ عٍ يّتّ رَ، عٍ شَ كِرَ نَن يَ.
\q1 عٍ شُي رَقَن نَشٍيٍ مَ، نٍيٍ بِرَ مَ نّ عٍ قْشْ رَ.
\q1 
\v 15 عٍ عَلِفِيَمَ لِمَ نّ.
\q1 قَشّ عٍ رَلْيمَ نّ.
\q1 مِشِ تِنشِنشِيٍ عٍ مَبٌرٌنمَ نّ.
\q1 عٍ شَ تٌقَنيِ كَنَمَ نّ.
\q1 عَلِفِيَمَ قِندِ مَ نّ عٍ شْنيِ رَ.
\b
\q1 
\v 16 كْنْ عَلَ ﭑ نِي شُنسَرَ مَ نّ عَلِفِيَمَ،
\q1 عَ ﭑ شَنِن. \qs حّنفِ رَتٍ.\qs*
\b
\q1 
\v 17 مِشِ نَ قِندِ بَننَ رَ، عَ هَرِفٍ نَ فبٌ،
\q1 عِ نَشَ فَاشُ،
\q1 
\v 18 بَرِ مَ عَ مُ سٍسٍ شَنِنمَ عَلِفِيَمَ.
\q1 عَ هَرِفٍ مُ بِرَ مَ عَ قْشْ رَ.
\q1 
\v 19 عَ حّلّشِنمَ نّ عَ هَرِفٍ رَ عَ شَ دُنِحّءِفِرِ كُي،
\q1 بَرِ مَ بِرِن عَ مَتْشْمَ نَ شَ قٍ رَ،
\q1 
\v 20 كْنْ عَ قَ سِفَ عَلِفِيَمَ
\q1 عَ عَ بٍنبَيٍ لِ نَ،
\q1 نَشٍيٍ مُ دُنِحَ تٌمَ سْنْن.
\q1 
\v 21 شَ بَننَ مِشِ شَشِلِ مُ نَ،
\q1 عَ لُشِ نّ عَلْ سُبٍ نَشٍيٍ قَشَمَ.
\c 50
\s1 سّرّشّ نَشَن نَقَن عَلَ مَ
\s2 عَلَ شَ سّرِيّ
\d عَسَقِ شَ بّيتِ
\q1 
\v 1 عَلَتَلَ نَ وْيّنقٍ.
\q1 عَ نَ دُنِحَ بِرِن شِلِقٍ،
\q1 كٍلِ سٌفٍتٍدٍ هَن سٌفٍفٌرٌدٍ.
\q1 
\v 2 كٍلِقٍ سِيٌن،
\q1 عَلَ شَ تٌقَنيِ يَنبَمَ.
\q1 
\v 3 وٌن مَرِفِ عَلَ نَ قَقٍ،
\q1 عَ مُ دُندُشِ.
\q1 تّ بٍلٍبٍلٍ نَ عَ يَ رَ،
\q1 قٌيٍ شُنفبٍ قَن نَ عَ رَبِلِنيِ.
\q1 
\v 4 عَ شُي تٍمَ كٌورٍ مَ،
\q1 عَ شُي فٌرٌ مَ بْشِ
\q1 كِيتِ سَدٍ عَ شَ مِشِيٍ بّ.
\q1 
\v 5 «ﭑ بَتُلَيٍ،
\q1 نَشٍيٍ لَايِدِ تٌنفٌشِ ﭑ بّ سّرّشّ رَ،
\q1 وٌ شَ وٌ مَلَن.»
\q1 
\v 6 عَلَ شَ مَسٍنيِ تِنشِنشِ كٍلِمَ كٌورٍ نَن مَ،
\q1 بَرِ مَ كِيتِسَ نَن نَ عَلَ رَ.
\b
\q1 
\v 7 «ﭑ مَ مِشِيٍ، وٌ وٌ تُلِ مَتِ، ﭑ شَ وْيّن.
\q1 عِسِرَيِلَ، ﭑ بَرَ وٌ كَلَمُ.
\q1 عَلَ نَن ﭑ نَ، وٌ مَرِفِ عَلَ.
\q1 
\v 8 ﭑ مُ شْنْشِ وٌ شَ سّرّشّيٍ شَ قٍ رَ.
\q1 وٌ سّرّشّ فَن دَاشِيٍ بَمَ ﭑ بّ تّمُي بِرِن.
\q1 
\v 9 ﭑ مُ تُورَ تٌنفٌمَ وٌ شْنيِ.
\q1 ﭑ مُ سِ كٌنتٌنيِ قَن تٌنفٌمَ وٌ شَ كُلّ.
\q1 
\v 10 ﭑ فبٍ نَن نَ سُبٍ بِرِن نَ وُلَ عِ.
\q1 ﭑ فبٍ نَن نَ سُبٍ بِرِن نَ فٍيَيٍ مَ.
\q1 
\v 11 ﭑ فبٍ نَن نَ شْنِ بِرِن نَ كٌورٍ مَ.
\q1 ﭑ فبٍ نَن نَ سُبٍ بِرِن نَ قِيلِ مَ.
\q1 
\v 12 شَ كَامّ ﭑ سُشُمَ نُ، ﭑ مَ قَلَمَ وٌ تَن بّ.
\q1 ﭑ فبٍ نَن نَ دُنِحَ بِرِن نَ.
\q1 
\v 13 ﭑ تَن تُورَ سُبٍ دٌنمَ؟ عَدٍ.
\q1 ﭑ تَن سِ كٌنتٌنيِ وُلِ مِنمَ؟ عَدٍ.
\q1 
\v 14 عَ لَنمَ وٌ شَ تَنتُي رَ سِفَ ﭑ مَ،
\q1 نَ شَ قِندِ وٌ شَ سّرّشّيٍ رَ.
\q1 وٌ شَ وٌ شَ لَايِدِيٍ رَكَمَلِ ﭑ بّ، ﭑ تَن عَلَ شِلِ شُنفبٍ كَنيِ.
\q1 
\v 15 وٌ شَ ﭑ شِلِ وٌ شَ تْورّ كُي.
\q1 ﭑ قَمَ وٌ رَتَنفَدٍ،
\q1 وٌ قَن قَمَ ﭑ مَتْشْدٍ.»
\b
\q1 
\v 16 عَلَ شَ مَسٍنيِ نَن يَ، مِشِ حَاشِيٍ بّ،
\q1 «وٌ نَ ﭑ مَ يَامَرِ نُن ﭑ مَ سَاتّ دُرُ سِقٍ مُنقٍ رَ؟
\q1 
\v 17 ﭑ مَ سّرِيّ مُ رَقَن وٌ مَ.
\q1 وٌ مُ ﭑ مَ وْيّنيِ دَنشُنمَ.
\q1 
\v 18 وٌ نُن مُحّتِيٍ نَ عَ رَ.
\q1 وٌ نُن يّنّ رَبَيٍ نَ عَ رَ.
\q1 
\v 19 قٍ حَاشِ نَن تُن مِنِمَ وٌ دّ عِ،
\q1 وٌ وُلٍ نَن تُن قَلَمَ.
\q1 
\v 20 وٌ نُن نَشَن نفَ كٍرٍن عَ رَ،
\q1 وٌ نَ تْوحّفّمَ.
\q1 
\v 21 وٌ نَشَن نَبَشِ، نَ نَن يَ.
\q1 هَن يَكْسِ ﭑ بَرَ ﭑ سَبَرِ.
\q1 وٌ حْشْ عَ مَ عَ ﭑ نَ وٌ سّيتِ مَ،
\q1 كْنْ ﭑ قَمَ شَاحّدٍ وٌ مَ،
\q1 ﭑ قَمَ عَ بِرِن يَ بَدٍ وٌ بّ.
\q1 
\v 22 وٌ شَ يِ قٍ مّ،
\q1 وٌ تَن نَشٍيٍ نّيمُشِ عَلَ مَ،
\q1 شَ نَ مَرَ ﭑ وٌ شَ قٍ كَنَمَ نّ.
\q1 مِشِ يٌ مُ وٌ رَتَنفَمَ.
\q1 
\v 23 نَشَن تَنتُي سّرّشّ بَمَ ﭑ بّ،
\q1 نَ مِشِ بَرَ ﭑ مَتْشْ.
\q1 مِشِ نَشَن عَ حّرّ كِ مَتٌمَ عَ قَنيِ رَ،
\q1 ﭑ قَمَ ﭑ تَن عَلَ شَ مَرَكِسِ مَسٍندٍ عَ بّ.»
\c 51
\s1 دَوُدَ شَ يُنُبِ
\s2 عَلَ مَشَندِ
\d 
\v 1 دَوُدَ شَ بّيتِ بّيتِبَيٍ شَ مَنفّ بّ.
\v 2 عَننَبِ نَتَن وْيّنقٍ دَوُدَ بّ عَ يُنُبِ رَبَ بَتِسٍبَ رَ تّمُي نَشّ.
\q1 
\v 3 عَلَ، هِننّ ﭑ نَ عَلْ عِ دَرِشِ عَ رَ كِ نَشّ.
\q1 دِحّ ﭑ مَ قٍ حَاشِ مَ عِ شَ بْحّ قَنيِ سَابُي رَ.
\q1 
\v 4 عِ شَ ﭑ نَسّنِيّن ﭑ مَ قٍ كٌبِ بِرِن مَ.
\q1 عِ شَ ﭑ مَ يُنُبِ شَقَرِ.
\q1 
\v 5 ﭑ بَرَ ﭑ مَ يُنُبِ كٌلٌن.
\q1 ﭑ مُ نْمَ نّيمُدٍ نَ مَ.
\q1 
\v 6 ﭑ نَ قٍ حَاشِ رَبَشِ عِ كٍرٍن نَن نَ.
\q1 ﭑ نَشَن نَبَشِ عَ مُ رَقَن عِ مَ.
\q1 عِ نَ ﭑ مَكِيتِ،
\q1 نْندِ لُمَ نّ عِ بّ.
\q1 
\v 7 ﭑ بَرِشِ يُنُبِ قٍ نَن كُي،
\q1 كَبِ نفَ قُرِ بَ نّينّ رَ.
\q1 
\v 8 كْنْ نْندِ نَ لُ مِشِ بْحّ كُي،
\q1 نَ نَن نَقَن عِ مَ.
\q1 نَ لْننِ مَسٍن ﭑ بّ.
\b
\q1 
\v 9 ﭑ سّنِيّن هِسٌثِ بُرّشّ رَ،
\q1 عَلَكٌ ﭑ شَ قِيشّ.
\q1 ﭑ سّنِيّن،
\q1 عَلَكٌ ﭑ شَ قِيشّ قْين عَلْ شِحّ.
\q1 
\v 10 حّلّشِنيِ نُن سّيوّ قِ ﭑ مَ،
\q1 عَلَكٌ ﭑ بْحّ شَ سَ.
\q1 
\v 11 عِ كٌبٍ تِ ﭑ مَ يُنُبِ رَ،
\q1 عِ شَ ﭑ مَ قٍ كٌبِ بِرِن بَ ﭑ مَ.
\q1 
\v 12 ﭑ مَرِفِ عَلَ، ﭑ بْحّ مَقِندِ بْحّ سّنِيّنشِ رَ،
\q1 شَشِلِ قَنيِ قِ ﭑ مَ.
\q1 
\v 13 عِ نَشَ ﭑ مَكُيَ عِ يَ تٌدٍ رَ.
\q1 عِ نَشَ عِ شَشِلِ سّنِيّنشِ بَ ﭑ يِ رَ.
\q1 
\v 14 كِسِ سّيوّ نُن لِمَنِيَ قِ ﭑ مَ
\q1 نَشَن ﭑ مَلِمَ.
\q1 
\v 15 ﭑ عِ شَ كِرَ مَسٍنمَ نّ عِ مَتَندِلَيٍ بّ،
\q1 عَلَكٌ عٍ مَن شَ بِرَ عِ قْشْ رَ.
\q1 
\v 16 ﭑ نَكِسِمَ عَلَ،
\q1 ﭑ بَرَ مِشِ قَشَ.
\q1 يَندِ، ﭑ شُنسَرَ،
\q1 عَلَكٌ ﭑ شَ عِ شَ قٍ قَنيِ مَسٍن.
\q1 
\v 17 ﭑ مَرِفِ، نَ نِيَ ﭑ بّ،
\q1 ﭑ شَ عِ تَنتُ.
\q1 
\v 18 سّرّشّ مُ رَقَن عِ مَ،
\q1 شَ نَ مُ عَ رَ ﭑ نَ بَمَ نّ عِ بّ نُ.
\q1 عِ مُ وَ مَ سّرّشّ فَن دَاشِ شْن.
\q1 
\v 19 سّرّشّ قَنيِ قِندِشِ يّتّ مَفٌرٌي نَن نَ.
\q1 عَلَ وَ مَ يِ سّرّشّ مْولِ نَن شْن مَ.
\b
\q1 
\v 20 عِ شَ هِننّ سِيٌنِ رَ،
\q1 عِ شَ دَرِ سَلَمُ تّتّ رَكٍلِ.
\q1 
\v 21 نَ تّمُي عِ حّلّشِنمَ نّ سّرّشّ تِنشِنشِ
\q1 نُن سّرّشّ فَن دَاشِ رَ.
\q1 نَ تّمُي تُورَيٍ نَن بَمَ سّرّشّ رَ عِ شَ سّرّشّبَدٍ.
\c 52
\s1 دّ حَاشِ
\s2 عَلَ شَ سّرِيّ
\d 
\v 1 دَوُدَ شَ لْننِ بّيتِ بّيتِبَيٍ شَ مَنفّ بّ.
\v 2 مَسٍنيِ نَن يَ دٌوٍفٍ عٍدٌنكَ شَ قٍ رَ، نَشَن عَ قَلَ سْلُ بّ عَ دَوُدَ نَ عَشِمٍلٍكِ شْنيِ.
\q1 
\v 3 عِ عِ يّتّ عِفبٌمَ قٍ كٌبِ رَبَقٍ رَ مُنقٍ رَ؟
\q1 عَلَ شَ هِننّ بُمَ نّ عَبَدَن.
\q1 
\v 4 عِ دّ لُمَ عَلْ قِنّ نَشَن قٍ حَاشِ رَبَمَ.
\q1 يَنقَنتٍ نَن عِ رَ.
\q1 
\v 5 قٍ حَاشِ رَقَن عِ مَ دَنفِقٍ قٍ قَنيِ رَ.
\q1 وُلٍ رَقَن عِ مَ دَنفِقٍ نْندِ رَ. \qs حّنفِ رَتٍ.\qs*
\q1 
\v 6 عِ وْيّن شُي شَاحّ، عِ دّ مُ قَن.
\q1 
\v 7 نَ كُي عَلَ قَمَ عِ رَهَلَكِدٍ تّمُي بِرِن.
\q1 عَ عِ سُشُمَ نّ، عَ عِ كٍرِ عِ شَ بَنشِ كُي، عَ عِ كٍرِ دُنِحَ مَ. \qs حّنفِ رَتٍ.\qs*
\q1 
\v 8 تِنشِنتْي نَشٍيٍ قِندِ مَ سٍيدٍيٍ رَ
\q1 عٍ قَمَ يٍلٍدٍ نَ كَنيِ مَ يِ كِ نّ،
\q1 
\v 9 «وٌ نَ مِشِ مَتٌ،
\q1 نَشَن مُ نُ عَ شَشِلِ تِشِ عَلَ رَ.
\q1 عَ نَشَ لَ عَ شَ نَاقُلِ رَ،
\q1 عَ عَ يّتّ كَنتَ عَ شَ يَنقَنتٍيَ رَ.
\q1 
\v 10 كْنْ، ﭑ تَن نَشَن لَشِ عَلَ شَ هِننّ رَ،
\q1 ﭑ مَ قٍ بِرِن نَ سْونّيَقٍ
\q1 عَلْ عٌلِوِ وُرِ تٌقَنيِ نَشَن نَ عَلَ شْنيِ.»
\q1 
\v 11 ﭑ عِ تَنتُمَ نّ عَبَدَن عِ شَ وَلِ شَ قٍ رَ.
\q1 ﭑ شَشِلِ تِشِ عِ شِلِ قَنيِ نَن نَ عِ شَ دَنشَنِيَتْييٍ تَفِ،
\q1 بَرِ مَ عِ قَن.
\c 53
\s1 شَشِلِتَرٍ شَ مَسٍنيِ
\s2 عَلَ شَ سّرِيّ
\d 
\v 1 دَوُدَ شَ لْننِ بّيتِ بّيتِبَيٍ شَ مَنفّ بّ. عَ شَ بَ شُلٍ شُي رَ.
\q1 
\v 2 شَشِلِتَرٍ عَ قَلَمَ عَ بْحّ كُي، «عَلَ مُ نَ.»
\q1 عٍ قٍ هَرَ مُشِيٍ رَبَمَ، عٍ مُ تِنشِن.
\q1 مِشِ يٌ مُ نَ نَشَن قٍ قَنيِ رَبَمَ.
\b
\q1 
\v 3 عَلَ عَ يَ رَفٌرٌ مَ عَدَ مَدِيٍ مَ كٍلِقٍ عَرِيَننَ،
\q1 عَ شَ عٍ مَتٌ شَ شَشِلِمَ ندٍ نَ نَ نَشَن عَلَ قٍنمَ.
\q1 
\v 4 كْنْ بِرِن بَرَ مَكُيَ عَلَ رَ، عٍ نُ قٍ حَاشِ رَبَ.
\q1 هَلِ مِشِ كٍرٍن مُ نَ نَشَن قٍ قَنيِ رَبَمَ.
\q1 
\v 5 تِنشِنتَرٍيٍ شَشِلِ مُ نَ؟
\q1 عٍ نُ ﭑ مَ حَمَ تْورْ تُن.
\q1 عٍ مُ عَلَ شِلِمَ قٍوٌ.
\q1 
\v 6 عٍ قَمَ سّرّندٍ فَاشُي رَ نَ نَن مَ،
\q1 بَرِ مَ عَلَ قَمَ نَ مِشِ مْولِيٍ رَيٍنسٍندٍ،
\q1 نَشٍيٍ وَ مَ وٌ تْورْقٍ.
\q1 
\v 7 ندٍ كٍلِمَ سِيٌن عَ شَ عِسِرَيِلَ رَكِسِ؟
\q1 عَلَ نَ عَ شَ حَمَ رَ مِنِ كٌنيِيَ كُي،
\q1 يَشُبَ بْنسْي سّيوَ مَ نّ، عِسِرَيِلَ حّلّشِنمَ نّ.
\c 54
\s1 ﭑ مَرِفِ تِمَ ﭑ بُن مَ
\s2 عَلَ مَشَندِ
\d 
\v 1 دَوُدَ شَ لْننِ بّيتِ بّيتِبَيٍ شَ مَنفّ بّ. عَ شَ بَ كْرَ شُي رَ.
\v 2 سِقِكَيٍ تٌ عَ قَلَ سْلُ بّ عَ دَوُدَ عَ نْشُنشِ عٍ شْنيِ، دَوُدَ نَشَ يِ بّيتِ بَ.
\q1 
\v 3 عَلَ، ﭑ نَكِسِ عِ شِلِ رَ، ﭑ مَ كِيتِ سَ عِ سّنبّ رَ.
\q1 
\v 4 عَلَ، ﭑ مَ دُبّ سُشُ، عِ تُلِ مَتِ ﭑ مَ وْيّنيِ رَ.
\q1 
\v 5 شْحّ ندٍيٍ بَرَ كٍلِ ﭑ شِلِ مَ،
\q1 مِشِ كٌبِ نَشٍيٍ وَ مَ ﭑ قَشَقٍ.
\q1 عٍ مُ عَلَ كٌلٌن قٍقٍ مَ. \qs حّنفِ رَتٍ.\qs*
\q1 
\v 6 عَلَ ﭑ مَلِمَ، ﭑ مَرِفِ تِمَ ﭑ بُن مَ.
\q1 
\v 7 عَ ﭑ يَشُييٍ شَ كٌبِحَ سَرٍ رَفبِلٍنمَ عٍ مَ.
\q1 عِ شَ عٍ هَلَكِ عِ شَ دُفُتّفّحَ كُي.
\q1 
\v 8 ﭑ بَرَ عَ حَنِفٍ ﭑ شَ سّرّشّ بَ عِ بّ.
\q1 عَلَتَلَ، ﭑ عِ شِلِ تَنتُمَ نّ بَرِ مَ عِ قَن،
\q1 
\v 9 عِ مَن ﭑ نَكِسِمَ ﭑ مَ تْورّ كُي، ﭑ قَ نْ ﭑ يَشُييٍ رَ.
\c 55
\s1 يَنقَنتٍيٍ
\s2 عَلَ مَشَندِ
\d 
\v 1 دَوُدَ شَ لْننِ بّيتِ بّيتِبَيٍ شَ مَنفّ بّ. عَ شَ بَ كْرَ شُي رَ.
\q1 
\v 2 عَلَ، ﭑ مَ دُبّ سُشُ،
\q1 عِ نَشَ عِ نْشُن ﭑ مَ مَشَندِ مَ.
\q1 
\v 3 عِ تُلِ مَتِ ﭑ نَ، عِ شَ ﭑ يَابِ.
\q1 شَنمّرِ نُن فَاشُي بَرَ فّ ﭑ سُشُدٍ
\q1 
\v 4 ﭑ يَشُييٍ شَ وْيّنيِ شَ قٍ رَ،
\q1 عَ نُن مِشِ حَاشِيٍ شَ وَلِ كٌبِ شَ قٍ رَ.
\q1 عٍ وَ مَ ﭑ تْورْقٍ، عٍ ﭑ تْوحّفّمَ شْنّ كُي.
\q1 
\v 5 ﭑ بْحّ بَرَ سّرّن، ﭑ سٌندٌنيِ بَرَ فَاشُ قَشّ يَ رَ.
\q1 
\v 6 فَاشُي نُن سّرّنيِ بَرَ ﭑ سُشُ عَ حَاشِ رَ.
\q1 نَ بَرَ ﭑ نَتَفَن.
\q1 
\v 7 شَ فَبُتٍنيِ نَن نُ نَ ﭑ بّ نُ عَلْ فَنبّ،
\q1 ﭑ نُ بَرَ سِفَ يِفِيَ قٍندٍ نُ،
\q1 
\v 8 ﭑ نُ ﭑ فِمَ نّ، ﭑ سِفَ يِرٍ مَكُيٍ،
\q1 ﭑ سِفَمَ وُلَ عِ نّ نُ. \qs حّنفِ رَتٍ.\qs*
\q1 
\v 9 ﭑ شَ ﭑ فِ مَقُرٍن، عَلْ قٌيٍ شُنفبٍ.
\q1 
\v 10 ﭑ مَرِفِ، قٍ كٌبِ رَبَيٍ رَيٍنسٍن يّ.
\q1 عِ نَشَ عٍ لُ عٍ شَ لَن قٍ كٌبِ مَ،
\q1 بَرِ مَ كٌبِحَ نُن فٍرٍ بَرَ فبٌ تَا كُي.
\q1 
\v 11 كْي نُن يَنيِ رَ قٍ كٌبِ رَبَيٍ تَا رَبِلِنمَ،
\q1 عٍ شَ قٍ حَاشِ نُن تِنشِنتَرٍيَ رَبَ تَا كُي.
\q1 
\v 12 عٍ بَرَ قٍ بِرِن كَنَ.
\q1 فبّسّنشْننّيَ نُن مَءِقُي بَرَ فبٌ تَا كُي.
\q1 
\v 13 شَ يَشُي نَن تُن ﭑ كٌنبِمَ نُ، ﭑ دِحّمَ.
\q1 شَ ﭑ شْنمِشِ نَن تُن كٍلِمَ ﭑ شِلِ مَ نُ،
\q1 ﭑ نَن ﭑ نْشُنمَ نّ عَ مَ نُ.
\b
\q1 
\v 14 كْنْ عِ تَن ﭑ لَنقَنمَ نَن عِ رَ، ﭑ شَنُنتٍنيِ، ﭑ دّقَنبٌورٍ.
\q1 
\v 15 وٌن دّ قَن، وٌن بِرِن سِفَمَ عَلَ شَ هْرْ مْبَنشِ.
\b
\q1 
\v 16 عٍ شَ عٍ تّرّننَ قَشّ رَ،
\q1 عٍ شَ فٌرٌ فَبُرِ كُي عٍ حِحّ رَ،
\q1 بَرِ مَ عٍ عٍ حّرّ مَ قٍ حَاشِيٍ نَن تُن كُي.
\b
\q1 
\v 17 كْنْ ﭑ بَرَ عَلَ شِلِ. عَلَتَلَ ﭑ نَكِسِمَ نّ.
\q1 
\v 18 ﭑ فبٍلٍفبٍلٍمَ كْي عَ نُن يَنيِ رَ. عَ بَرَ ﭑ شُي مّ.
\q1 
\v 19 ﭑ يَشُييٍ تٌ وُيَ، عَ بَرَ ﭑ نَتَنفَ نَ فٍرٍ مَ.
\q1 
\v 20 عَلَ نَشَن نَ عَ شَ كِبَنيِ كُي كَبِ عَ قْلّ،
\q1 عَ عَ تُلِ مَتِمَ ﭑ نَ، عَ قَ ﭑ يَشُييٍ رَبِرَ، \qs حّنفِ رَتٍ\qs*
\q1 بَرِ مَ عٍ تٌندِشِ تُوبِدٍ.
\q1 عٍ مُ فَاشُ عَلَ يَ رَ.
\q1 
\v 21 يِ مِشِيٍ بَرَ عٍ بٌرٍ فٍرٍ، عٍ سَاتّ كَنَ.
\q1 
\v 22 عٍ دّ عِحْشُن عَلْ شِحّ، كْنْ فٍرٍ نَ عٍ بْحّ كُي.
\q1 عٍ شَ وْيّنيِ سَلَشُن عَلْ تُرٍ،
\q1 كْنْ عٍ مِشِ تْورْ مَ عَلْ سَنتِدّفّمَ نَشَن بَشِ عَ تّي عِ.
\q1 
\v 23 عِ شَ عِ شَشِلِ تِ عَلَتَلَ رَ، عَ عِ مَلِمَ نّ.
\q1 عَ مُ تِنمَ تِنشِنتْي شَ بِرَ.
\q1 
\v 24 عَلَ، يِ فٍرٍ سٌي نُن يِ يَنقَنتٍيٍ شَنِن عَلِفِيَمَ.
\q1 عِ نَشَ عٍ شَ سِمَيَ كْنتِ رَكَمَلِ.
\q1 عَلَ، ﭑ بَرَ ﭑ تَشُ عِ رَ.
\c 56
\s1 ﭑ مُ فَاشُمَ سْنْن
\s2 عَلَ مَشَندِ نُن عَلَ مَتْشْي
\d 
\v 1 دَوُدَ شَ سُوكِ بّيتِبَيٍ شَ مَنفّ بّ. عَ شَ بَ عَلْ بّيتِ نَشَن شِلِ، «فَنبّ نَ وُرِ مَكُيٍ قَرِ.» عَ عَ بَ قِلِسِتَكَيٍ عَ سُشُ تّمُي نَشّ فَتِ.
\q1 
\v 2 عَلَ، هِننّ ﭑ نَ بَرِ مَ مِشِيٍ نَ ﭑ فٍرٍقٍ.
\q1 عٍ فٍرٍ تِمَ ﭑ بّ تّمُي بِرِن.
\q1 
\v 3 ﭑ يَشُييٍ قّيحّنمَ فٍرٍ رَ.
\q1 عَلَ شُنفبٍ، ﭑ فٍرٍقَيٍ بَرَ وُيَ.
\q1 
\v 4 ﭑ نَ فَاشُ تّمُي نَشّ،
\q1 ﭑ نَن ﭑ شَشِلِ تِمَ عِ تَن نَن نَ.
\q1 
\v 5 ﭑ عَلَ شَ مَسٍنيِ مَتْشْمَ.
\q1 ﭑ مُ فَاشُمَ سْنْن،
\q1 بَرِ مَ ﭑ بَرَ لَ عَلَ رَ.
\q1 عِبُنَدَ مَ فبَنسَن نْمَ مُنسٍ رَبَدٍ ﭑ نَ؟
\b
\q1 
\v 6 تّمُي بِرِن ﭑ يَشُييٍ وَ مَ ﭑ تْورْقٍ عٍ شَ وْيّنيِ رَ.
\q1 ﭑ مَ قٍقٍ مُ رَقَنشِ عٍ مَ.
\q1 
\v 7 عٍ لَنشِ ﭑ مَ حَشَنكَتّ مَ،
\q1 عٍ بِرَ ﭑ قْشْ رَ يِرٍ بِرِن عَلَكٌ عٍ شَ ﭑ قَشَ.
\q1 
\v 8 عِ نَشَ تِن عٍ شَ رَتَنفَ عٍ شَ قٍ حَاشِيٍ مَ.
\q1 عَلَ، عِ شَ شْنّ شَ عٍ رَبِرَ.
\q1 
\v 9 عِ ﭑ مَ دُنِحّءِفِرِ كٌلٌن، عِ ﭑ يَيٍ تٌشِ.
\q1 ﭑ مَ تْورّ بِرِن سّبّشِ عِ يِ رَ.
\b
\q1 
\v 10 ﭑ نَ عِ شِلِ تّمُي نَشّ،
\q1 ﭑ يَشُييٍ فبِلٍنمَ نّ ﭑ قْشْ رَ.
\q1 ﭑ عَ كٌلٌن ﭑ نُن عَلَ نَ عَ رَ.
\q1 
\v 11 ﭑ عَلَ شَ وْيّنيِ مَتْشْمَ،
\q1 ﭑ عَلَتَلَ شَ مَسٍنيِ مَتْشْمَ.
\q1 
\v 12 ﭑ مُ فَاشُمَ سْنْن، بَرِ مَ ﭑ بَرَ لَ عَلَ رَ.
\q1 عِبُنَدَ مَ فبَنسَن نْمَ مُنسٍ رَبَدٍ ﭑ نَ؟
\q1 
\v 13 عَلَ، ﭑ شَ ﭑ مَ لَايِدِ رَكَمَلِ عِ بّ،
\q1 ﭑ مَ تَنتُي سّرّشّيٍ رَ،
\q1 
\v 14 بَرِ مَ عِ بَرَ ﭑ نَتَنفَ قَشّ مَ.
\q1 عِ مُ تِن ﭑ شَ بِرَ،
\q1 عَلَكٌ ﭑ شَ حّرّ عِ شَ كِرَ شْن مَ يِ بّندّ قُحِ قَرِ.
\c 57
\s1 ﭑ بَرَ لِمَنِيَ سْتْ
\s2 عَلَ مَشَندِ
\d 
\v 1 دَوُدَ شَ سُوكِ بّيتِبَيٍ شَ مَنفّ بّ. عَ شَ بَ عَلْ بّيتِ نَشَن شِلِ «عِ نَشَ هَلَكِ تِ.» دَوُدَ نَشَ يِ بَ عَ تٌ عَ فِ سْلُ مَ، عَ سَ سٌ قْنمّ كُي.
\q1 
\v 2 عَلَ، هِننّ ﭑ نَ، يَندِ عِ شَ هِننّ ﭑ نَ.
\q1 ﭑ مَرَتَنفّ قٍنمَ عِ يِرٍ
\q1 عَلْ تْشّيْرّ عَ قٍنمَ عَ نفَ فَبُتٍنيِ بُن مَ كِ نَشّ
\q1 هَن قٍ شْرْشْي شَ دَنفِ.
\q1 
\v 3 ﭑ بَرَ عَلَ شِلِ شُنفبٍ كَنيِ مَشَندِ
\q1 نَشَن ﭑ مَ قٍ بِرِن سْونّيَمَ.
\q1 
\v 4 ﭑ شْنمِشِيٍ ﭑ حَشَنكَتَمَ تّمُي نَشّ،
\q1 عَلَ ﭑ نَكِسِمَ نّ كٍلِقٍ عَرِيَننَ، \qs حّنفِ رَتٍ\qs*
\q1 عَ هِننّ نُن نْندِ رَفٌرٌ مَ ﭑ مَ.
\q1 
\v 5 يّتّيٍ بَرَ ﭑ نَبِلِن،
\q1 ﭑ سَشِ عٍ تَفِ، عٍ تَن نَشٍيٍ عَدَ مَدِيٍ قَشَمَ.
\q1 عٍ حِنيِيٍ لُشِ عَلْ تَنبّيٍ،
\q1 عٍ نّنيِيٍ لُشِ عَلْ سَنتِدّفّمَ نَشَن بَشِ عَ تّي عِ.
\q1 
\v 6 عَلَ، عِ شَ عِ شَ بِنيّ مَسٍن كٌورٍ مَ،
\q1 عِ شَ عَ مَسٍن بْشِ مَ.
\q1 
\v 7 عٍ بَرَ يّلّ تِ ﭑ يَ رَ، عَ فبٍ مُ لُشِ ﭑ شَ سٌ عَ رَ.
\q1 عٍ بَرَ يِلِ فٍ ﭑ يَ رَ، كْنْ عٍ تَن نَن بِرَشِ عَ كُي. \qs حّنفِ رَتٍ.\qs*
\q1 
\v 8 عَلَ، ﭑ بْحّ بَرَ لِمَنِيَ، ﭑ بَرَ لِمَنِيَ سْتْ.
\q1 ﭑ بّيتِ بَمَ نّ، ﭑ عِ تَنتُمَ نّ.
\q1 
\v 9 ﭑ بْحّ بَرَ كٍلِ ﭑ نَ،
\q1 ﭑ شَ ﭑ مَ كْرَيٍ تٌنفٌ، ﭑ شَ بّيتِ بَ هَن سُبَشّ.
\q1 
\v 10 مَرِفِ، ﭑ عِ تَنتُمَ نّ سِيٍ تَفِ.
\q1 ﭑ بّيتِ بَمَ نّ عِ بّ بْنسْييٍ تَفِ.
\q1 
\v 11 عِ شَ هِننّ كٌورٍ لِمَ نّ،
\q1 عِ شَ تِنشِنيِ تٍمَ نّ هَن نُشُييٍ.
\q1 
\v 12 عَلَ، عِ شَ عِ شَ بِنيّ مَسٍن كٌورٍ مَ،
\q1 عِ شَ عَ مَسٍن بْشِ مَ.
\c 58
\s1 عَدَ مَدِيٍ سَرٍ
\s2 عَلَ شَ سّرِيّ
\d 
\v 1 دَوُدَ شَ سُوكِ بّيتِبَيٍ شَ مَنفّ بّ. عَ شَ بَ عَلْ بّيتِ نَشَن شِلِ «عِ نَشَ كَسَرّ تِ».
\q1 
\v 2 وٌ شَ وْيّنيِ مُ تِنشِن.
\q1 عَدَ مَدِيٍ، وٌ نْمَ كِيتِ سَدٍ نْندِ رَ؟
\q1 
\v 3 عَدٍ، وٌ قٍ حَاشِ رَبَمَ وٌ بْحّ كُي،
\q1 وٌ قٍ حَاشِ رَبَمَ يِ بْشِ مَ،
\q1 وٌ مِشِ رَتَنتَنمَ دُنِحَ مَ.
\q1 
\v 4 كَقِ عٍ بَرِ تّمُي، عٍ قِندِشِ مِشِ حَاشِ نَن نَ.
\q1 وُلٍ قَلّيٍ بَرَ لْي كَبِ عٍ بَرِ لْشْي.
\q1 
\v 5 عٍ شَ شْنّ لُشِ نّ عَلْ بْشِمَسٍ شْنّ،
\q1 عَلْ بْشِمَسٍ نَشَن مُ بْشِمَسٍ سُشُي شُي رَ مّمَ.
\q1 
\v 6 هَلِ بْشِمَسٍ سُشُي قَنيِ، عَ مُ نْمَ عَ سُشُدٍ.
\b
\q1 
\v 7 عَلَ، عِ شَ عٍ حِنيِ كَنَ عٍ دّ عِ،
\q1 بَرِ مَ عٍ لُشِ نّ عَلْ يّتّ.
\q1 عَلَتَلَ، عِ شَ عٍ دّ وَنوَن.
\q1 
\v 8 عٍ حْنمَ نّ عَلْ يٍ نَشَن عِقِلِمَ بْشِ.
\q1 عٍ شَ تَنبّ مُ حّرّ مَ سّنبّ رَ.
\q1 
\v 9 عَ لُمَ عَلْ بٌي نَشَن قَتٍ لْيمَ لِنفِ كُي.
\q1 عَ لُمَ عَلْ دِ نَشَن بَشِ عَ نفَ قَتٍ عِ، عَ مُ قٌيٍ تٌ.
\q1 
\v 10 بٍينُن تُندٍ شَ قُرَ يٍفٍ مَلِنسِنشِ رَ،
\q1 شَ نَ مُ عَ رَ يٍفٍ شَرٍ رَ،
\q1 عَلَ عٍ كْمَ نّ، عَ عٍ وْلّ عَ عِ.
\b
\q1 
\v 11 مِشِ تِنشِنشِ قَمَ حّلّشِندٍ
\q1 بَرِ مَ عَ قَمَ فبٍحْشْي سْتْدٍ.
\q1 عَ قَمَ عَ سَنيِ مَشَدٍ مِشِ حَاشِ وُلِ رَ.
\q1 
\v 12 عَدَ مَدِيٍ قَمَ عَ قَلَدٍ،
\q1 «عِيٌ، عَلَ مِشِ تِنشِنشِ سَرٍ قِمَ.
\q1 عِيٌ، عَلَ كِيتِ سَمَ نّ دُنِحَ مَ.»
\c 59
\s1 بَرٍ شَاحّيٍ
\s2 عَلَ مَشَندِ
\d 
\v 1 دَوُدَ شَ سُوكِ بّيتِبَيٍ شَ مَنفّ بّ. عَ شَ بَ عَلْ بّيتِ نَشَن شِلِ «عِ نَشَ هَلَكِ تِ». عَ نَشَ عَ بَ سْلُ تٌ سْورِيٍ شّي عٍ شَ دَوُدَ قَشَ عَ شَ بَنشِ كُي.
\q1 
\v 2 ﭑ مَرِفِ عَلَ، ﭑ نَتَنفَ ﭑ يَشُييٍ مَ.
\q1 ﭑ مَ قٍ شَ تٍ دَنفِقٍ ﭑ يَشُييٍ شَ قٍ رَ.
\q1 
\v 3 ﭑ نَتَنفَ تِنشِنتَرٍيٍ مَ.
\q1 ﭑ نَكِسِ قَشّتِيٍ مَ،
\q1 
\v 4 بَرِ مَ عٍ وَ مَ ﭑ قَشَقٍ.
\q1 سّنبّمَيٍ نَ عٍ مَلَنقٍ ﭑ شِلِ مَ،
\q1 هَلِ ﭑ مُ قِندِ قٍ كٌبِ رَبَ رَ،
\q1 هَلِ ﭑ مُ يُنُبِ يٌ رَبَ عَلَتَلَ رَ.
\q1 
\v 5 هَلِ ﭑ مُ نَ قٍ حَاشِ رَبَقٍ،
\q1 عٍ عٍ فِمَ ﭑ قْشْ رَ، عٍ شَ ﭑ فٍرٍ.
\q1 كٍلِ، عِ قَ ﭑ مَلِ! يَندِ ﭑ مَ قٍ مَتٌ.
\q1 
\v 6 عِسِرَيِلَ مَرِفِ عَلَتَلَ، مَنفّ عَلَ، كٍلِ،
\q1 عِ شَ سِ دَنشَنِيَتَرٍيٍ رَتْن.
\q1 عِ نَشَ دِحّ يِ يَنقَنتٍ تِنشِنتَرٍيٍ مَ. \qs حّنفِ رَتٍ.\qs*
\q1 
\v 7 عٍ قَمَ كْي رَ عَلْ بَرٍ شَاحّيٍ عٍ قَ تَا رَبِلِن.
\q1 
\v 8 عٍ دّ لُمَ عَلْ بَرٍ دّ شُنقّ مِنِمَ نَشَن كُي.
\q1 عٍ شَ وْيّنيِ مِشِ تْورْ مَ عَلْ سَنتِدّفّمَ.
\q1 عٍ نَشّ، «ندٍ نْمَ وٌن مَ وْيّنيِ مّدٍ؟»
\q1 
\v 9 كْنْ عَلَتَلَ، عِ تَن نَن يٍلٍمَ عٍ مَ.
\q1 عِ سِ دَنشَنِيَتَرٍيٍ بِرِن مَيٍلٍمَ.
\q1 
\v 10 ﭑ نَن ﭑ يّتّ رَتَنفَمَ عٍ سّنبّ مَ عِ تَن نَن سَابُي رَ.
\q1 عَلَ نَن نَ ﭑ مَ كَنتَمَ رَ.
\b
\q1 
\v 11 ﭑ مَرِفِ عَلَ، نَشَن شَ هِننّ فبٌ،
\q1 عِ شَ تِ ﭑ يَ رَ،
\q1 عِ شَ ﭑ يَشُييٍ رَبِرَ.
\q1 
\v 12 ﭑ مَرِفِ، ﭑ مَ كَنتَمَ، عِ نَشَ عٍ قَشَ كٍرٍن نَ.
\q1 عِ شَ عٍ رَبِرَ عَلَكٌ ﭑ مَ حَمَ نَشَ نّيمُ عِ سّنبّ مَ.
\q1 
\v 13 عٍ يُنُبِ رَبَمَ عٍ شَ وْيّنيِيٍ رَ.
\q1 عِ شَ عٍ سُشُ عٍ شَ يّتّ عِفبٌحَ كُي.
\q1 عٍ دَنكّيٍ نُن وُلٍيٍ نَن تُن قَلَمَ.
\q1 
\v 14 عِ شَ عٍ رَحْن عِ شَ شْنّ رَ، عَلَكٌ عٍ نَشَ تٌ سْنْن،
\q1 عَلَكٌ عٍ شَ عَ كٌلٌن عَلَ نَن مَنفّ رَ
\q1 يَشُبَ بْنسْي نُن دُنِحَ بِرِن شُن مَ. \qs حّنفِ رَتٍ.\qs*
\b
\q1 
\v 15 عٍ قَمَ كْي رَ عَلْ بَرٍ شَاحّيٍ عٍ قَ تَا رَبِلِن.
\q1 
\v 16 بَرٍيٍ دٌنسٍ قٍنمَ يِرٍ بِرِن كْي رَ،
\q1 كْنْ عٍ مُ لُفَمَ.
\q1 
\v 17 ﭑ عِ سّنبّ مَتْشْمَ بّيتِ رَ.
\q1 ﭑ عِ شَ هِننّ مَتْشْمَ فّيسّفّ،
\q1 بَرِ مَ ﭑ مَ كَنتَمَ نَن عِ رَ،
\q1 عِ ﭑ كَنتَمَ ﭑ مَ تْورّ كُي.
\q1 
\v 18 ﭑ مَ سّنبّمَ، ﭑ بّيتِ بَمَ عِ بّ.
\q1 ﭑ مَرِفِ عَلَ نَن ﭑ كَنتَمَ رَ،
\q1 ﭑ مَرِفِ عَلَ نَن ﭑ هِننّمَ ﭑ نَ.
\c 60
\s1 عَلَ قَمَ شُننَكٍلِ رَ
\s2 عَلَ مَشَندِ
\d 
\v 1 دَوُدَ شَ لْننِ سُوكِ بّيتِبَيٍ شَ مَنفّ بّ. عَ شَ بَ عَلْ بّيتِ نَشَن شِلِ «قُفٍ تٌقَنيِ عَلْ عَلَ شَ سَاتّ.»
\v 2 عِسِرَيِلَ تٌ سِرٍنِكَيٍ فٍرٍ، عٍ يِ بّيتِ بَ نَ تّمُي نّ. عٍ نُ كٍلِشِ مٍسٌثٌتَمِيَ نُن سٌبَ بْشِ مَ. يٌوَبَ نَشَ عٍدٌنكَ وُلُ قُ نُن قِرِن قَشَ قٌلٍ كُي قْشْي نَ دّننَشّ.
\q1 
\v 3 عَلَ، عِ بَرَ مُشُ رَلْي،
\q1 عِ بَرَ ندٍ بَ مُشُ شَ فَلِ رَ،
\q1 عِ بَرَ شْنْ مُشُ مَ،
\q1 كْنْ يَكْسِ، عِ شَ سّنبّ قِ مُشُ مَ.
\q1 
\v 4 عِ بَرَ بْشِ رَ سّرّن،
\q1 عِ بَرَ عَ عِبْو.
\q1 عِ شَ نَ يَءِلَن مُشُ بّ
\q1 بَرِ مَ بْشِ وَ مَ كَنَقٍ.
\q1 
\v 5 عِ بَرَ قٍ شْرْشْييٍ دْشْ عِ شَ مِشِيٍ مَ،
\q1 هَن عٍ بَرَ لُ عَلْ سِيسِلَ.
\q1 
\v 6 كْنْ نَشٍيٍ فَاشُشِ عِ يَ رَ،
\q1 عِ بَرَ تْنشُمَ سٌ عٍ يِ رَ،
\q1 عٍ شَ نْ عٍ يَشُييٍ رَ.
\b
\q1 
\v 7 عِ شَ عِ شَنُنتٍنيِيٍ رَكِسِ عِ سّنبّ رَ،
\q1 عِ شَ مُشُ شَ دُبّ سُشُ.
\b
\q1 
\v 8 عَلَ شَ مَسٍنيِ نَن يَ،
\q1 عَ نَشَن قَلَشِ هْرْ مْبَنشِ سّنِيّنشِ كُي،
\q1 «ﭑ سِكٍمِ تَا قِمَ نّ وٌ مَ شُننَكٍلِ كُي،
\q1 ﭑ سُكْتِ فٍيَ لَنبَنيِ قَن قِ وٌ مَ.
\q1 
\v 9 فَلَدِ بْشِ، ﭑ فبٍ. مَنَسِ بْشِ، ﭑ فبٍ.
\q1 عٍقِرَ مِكَيٍ نَن قِندِ مَ ﭑ مَ فٍرٍ سٌي رَ.
\q1 ﭑ مَنفّ دْشْمَ نّ يُدَيَ.
\q1 
\v 10 مٌوَبَكَيٍ قِندِ مَ ﭑ مَ كٌنيِيٍ نَن نَ.
\q1 عٍدٌن قِندِ ﭑ مَ بْشِ رَ.
\q1 ﭑ فٍرٍ شُي رَتٍمَ نّ قِلِسِتَ.»
\b
\q1 
\v 11 عَلَ، ندٍ نْمَ ﭑ شَنِندٍ نَ تَا مَكَنتَشِ كُي؟
\q1 ندٍ نْمَ ﭑ شَنِندٍ هَن عٍدٌن بْشِ مَ؟
\q1 
\v 12 عِ تَن فبَنسَن، عِ تَن نَشَن مُشُ رَلْي،
\q1 عِ تَن نَشَن مُ نُ نَ مُشُ شَ سْورِيٍ سّيتِ مَ.
\q1 
\v 13 مُشُ مَلِ مُشُ يَشُييٍ فٍرٍدٍ.
\q1 عَدَ مَدِ شَ مَلِ، سٍسٍ مُ عَ رَ،
\q1 
\v 14 كْنْ عَلَ شَ مَلِ تَن قَمَ مُشُ يَشُي بِرِن هَلَكِدٍ.
\c 61
\s1 كٍلِقٍ يِرٍ مَكُيٍ
\s2 عَلَ مَشَندِ
\d 
\v 1 دَوُدَ شَ بّيتِ بّيتِبَيٍ شَ مَنفّ بّ. عَ شَ بَ كْرَ شُي رَ.
\q1 
\v 2 عَلَ، عِ تُلِ مَتِ ﭑ مَ مَشَندِ رَ.
\q1 ﭑ مَ مَشَندِ رَ مّ.
\q1 
\v 3 ﭑ عِ مَشَندِ مَ كٍلِقٍ رَ بْشِ مَكُيٍ.
\q1 ﭑ بْحّ مُ سَشِ.
\q1 ﭑ شَنِن فٍيَ قَرِ نَشَن عِتٍ دَنفِقٍ ﭑ نَ.
\q1 
\v 4 عِ قِندِشِ ﭑ بّ يِرٍ نَن نَ
\q1 ﭑ كَنتَشِ دّننَشّ ﭑ يَشُييٍ يَ عِ.
\q1 
\v 5 ﭑ وَ مَ لُقٍ عِ شْنيِ تّمُي بِرِن.
\q1 ﭑ وَ مَ لُقٍ عِ شَ كَنتَرِ كُي،
\q1 عَلْ شْنِ يْرّ لُمَ عَ نفَ فَبُتٍنيِ بُن مَ كِ نَشّ.
\q1 
\v 6 ﭑ مَرِفِ عَلَ، عِ بَرَ عِ تُلِ مَتِ ﭑ مَ مَشَندِ رَ.
\q1 عِ بَرَ كّ قِ ﭑ مَ،
\q1 نُن مِشِ بِرِن مَ نَشٍيٍ فَاشُشِ عِ شِلِ يَ رَ.
\b
\q1 
\v 7 مَنفّ شَ سِمَيَ شُنمَسَ،
\q1 عَلَكٌ عَ شَ بُ عَ فبٍفبٍ رَ.
\q1 
\v 8 عَ شَ مَنفّيَ شَ بُ عِ يَ عِ تّمُي بِرِن،
\q1 عِ شَ هِننّ عَ رَ، عِ شَ قِندِ عَ دُفُتّفّ رَ.
\q1 
\v 9 عِيٌ، ﭑ مُ تَفَنمَ بّيتِ بَقٍ رَ عِ شِلِ بِنيٍ بّ،
\q1 بَرِ مَ عِ ﭑ مَ مَشَندِ يَابِمَ تّمُي بِرِن.
\c 62
\s1 عَلَ شَ بْحّسَ
\s2 عَلَ شَ سّرِيّ
\d 
\v 1 دَوُدَ شَ بّيتِ بّيتِبَيٍ شَ مَنفّ يٍدُتُن بّ
\q1 
\v 2 ﭑ بْحّ سَشِ عَلَ نَن سَابُي رَ،
\q1 ﭑ مَ كِسِ قَتَنشِ عَ تَن نَن نَ.
\q1 
\v 3 عَ لُشِ ﭑ بّ عَلْ قَنيٍ،
\q1 ﭑ مَ مَرَكِسِمَ نُن ﭑ مَكَنتَمَ نَن عَ رَ.
\q1 ﭑ مُ نْمَ بِرَدٍ سْنْن.
\q1 
\v 4 وٌ دُتُنمَ مِشِيٍ مَ هَن مُن تّمُي،
\q1 وٌ شَ عٍ رَبِرَ، عَلْ بَنشِ نُن تّتّ قٌرِ؟
\q1 
\v 5 عٍ وُلٍ قَلَمَ عَلَكٌ عٍ شَ مِشِيٍ بَ يِرٍ قَنيِ عٍ نُ دّننَشّ.
\q1 عٍ دُبّ تِمَ عٍ دّ رَ، كْنْ عٍ دَنكّ تَن تِمَ عٍ بْحّ رَ. \qs حّنفِ رَتٍ.\qs*
\q1 
\v 6 ﭑ بْحّسَ سْتْمَ عَلَ نَن نَ،
\q1 بَرِ مَ ﭑ شَشِلِ تِشِ عَ تَن نَن نَ.
\q1 
\v 7 عَ لُشِ عَلْ قَنيٍ نَ عَ رَ ﭑ بّ،
\q1 ﭑ مَ مَرَكِسِمَ نُن ﭑ مَ مَكَنتَمَ نَن عَ رَ.
\q1 ﭑ مُ نْمَ بِرَدٍ سْنْن.
\q1 
\v 8 ﭑ مَ كِسِ نُن ﭑ مَ بِنيّ نَ عَلَ نَن يِ.
\q1 عَلَ ﭑ مَكَنتَمَ نَن عَ رَ، ﭑ يِفِ تِدٍ نَن عَ رَ.
\q1 
\v 9 حَمَ، وٌ شَ وٌ تَشُ عَ رَ،
\q1 وٌ شَ وٌ شَ كْنتْقِلِ مَسٍن عَ بّ.
\q1 عَ تَن نَن نْمَ وٌن مَلِدٍ. \qs حّنفِ رَتٍ.\qs*
\q1 
\v 10 عَدَ مَدِيٍ لُمَ عَلْ قٌيٍ نَشَن دَنفِمَ.
\q1 مِشِ شُنفبٍ قِندِ مَ مِشِ شُرِ رَ،
\q1 شَ عٍ شَ قٍ بَرَ مَنِيَ، عَ يٍلٍبُ عَلْ قٌيٍ.
\q1 
\v 11 وٌ نَشَ هَرِفٍ قٍن قٍ كٌبِ رَ،
\q1 وٌ نَشَ عَ قٍن مُحّ رَ.
\q1 شَ وٌ شَ نَاقُلِ سَ فبٌ،
\q1 وٌ نَشَ وٌ شَشِلِ تِ نَ رَ.
\q1 
\v 12 عَلَ بَرَ قٍ قِرِن قَلَ ﭑ نَشٍيٍ مّشِ.
\q1 كٍرٍن، سّنبّ نَ عَلَ بّ.
\q1 
\v 13 عَ قِرِن ندٍ، ﭑ مَرِفِ نَن هِننّنتٍ رَ،
\q1 بَرِ مَ عَ مِشِيٍ سَرٍ رَفبِلٍنمَ عٍ مَ.
\c 63
\s1 عَلَ شَ هِننّ قَن سِمَيَ بّ
\s2 عَلَ مَتْشْي
\d 
\v 1 دَوُدَ شَ بّيتِ، عَ نَشَن بَ يُدَيَ، عَ تٌ نُ فبٍنفبٍرٍنيِ مَ تّمُي نَشّ
\q1 
\v 2 عَلَ نَن ﭑ مَرِفِ رَ.
\q1 عَلَ ﭑ عِ قٍنمَ، بَرِ مَ ﭑ هَيِ نَ عِ مَ،
\q1 عَلْ قَتٍ هَيِ تٌ نَ يٍ مَ فبٍنفبٍرٍنيِ مَ.
\q1 
\v 3 ﭑ لُمَ عِ شَ هْرْ مْبَنشِ كُي
\q1 عَلَكٌ ﭑ شَ عِ سّنبّ نُن عِ شَ بِنيّ تٌ.
\q1 
\v 4 عِ شَ هِننّ قَن سِمَيَ بّ.
\q1 ﭑ بَرَ عِ مَتْشْ.
\q1 
\v 5 ﭑ عِ تَنتُمَ ﭑ مَ سِمَيَ بِرِن كُي،
\q1 ﭑ نَن ﭑ بّلّشّيٍ عِتٍمَ عِ مَبِرِ.
\q1 
\v 6 ﭑ بْنسْي وَ سَمَ نّ عِ تَنتُقٍ رَ سّيوّ كُي.
\q1 
\v 7 ﭑ نَ ﭑ سَ ﭑ عِ شَ قٍ مَحْشُنمَ كْي بِرِن،
\q1 
\v 8 بَرِ مَ عِ تَن نَن ﭑ مَلِمَ.
\q1 ﭑ سّيوَ مَ نّ عِ نِينِ بُن مَ.
\q1 
\v 9 ﭑ نِي بَرَ قَتُ عِ مَ، عِ بّلّشّ لُمَ نّ ﭑ بُن مَ.
\q1 
\v 10 نَشٍيٍ كَتَمَ ﭑ قَشَدٍ، عٍ تَن نَن قَشَمَ.
\q1 
\v 11 سَنتِدّفّمَ قَمَ نّ عٍ سْشْدٍ،
\q1 وُلَءِ بَرٍيٍ قَ عٍ عِبْودٍ.
\q1 
\v 12 مَنفّ سّيوَ مَ نّ عَلَ شَ قٍ رَ.
\q1 نَشٍيٍ عٍ كَلِمَ عَلَ شِلِ رَ، نٍيٍ قَمَ نّ عَ مَتْشْدٍ.
\q1 كْنْ وُلٍ قَلّيٍ دّيٍ بَلَنمَ نّ.
\c 64
\s1 عَدَ مَ شَ مَحْشُنيِ تِلِن
\s2 عَلَ مَشَندِ
\d 
\v 1 دَوُدَ شَ بّيتِ بّيتِبَيٍ شَ مَنفّ بّ
\q1 
\v 2 عَلَ، عِ تُلِ مَتِ ﭑ وَ شُي رَ،
\q1 ﭑ نَتَنفَ ﭑ يَشُييٍ مَ.
\q1 
\v 3 ﭑ نْشُن مِشِ حَاشِيٍ مَ
\q1 نَشٍيٍ وَ مَ ﭑ تْورْقٍ تِنشِنتَرٍيَ كُي.
\q1 
\v 4 عٍ دّ شَاحّ عَلْ سَنتِدّفّمَ،
\q1 عٍ شَ وْيّن حَاشِيٍ لُمَ عَلْ تَنبّيٍ.
\q1 
\v 5 عٍ مُ فَاشُمَ تِنشِنتْي يَ رَ،
\q1 عٍ لُمَ عَ حَشَنكَتَ رَ تُن.
\q1 
\v 6 عٍ دّ كٌبِ، عٍ يّلّ عِتَلَمَ مِشِ يَ رَ.
\q1 عٍ نَشّ، «ندٍ نَ كٌلٌنمَ؟»
\q1 
\v 7 عٍ يَنقَنتٍيَ يَءِلَنمَ، عٍ عَ قَلَ،
\q1 «وٌن شَ كٍلِ عَ يَنقَ شِلِ مَ. عَ سْونّيَمَ نّ.»
\q1 عَدَ مَ شَ مَحْشُنيِ تِلِن.
\q1 
\v 8 كْنْ عَلَ نَ تَنبّيٍ وٌلِ، عٍ عٍ لِمَ نّ كٍرٍن نَ.
\q1 
\v 9 عٍ بَرَ وُلٍ قَلَ.
\q1 نَشٍيٍ عٍ تٌمَ، عٍ عٍ فِمَ نّ.
\q1 
\v 10 نَ فَاشُي عَدَ مَ بِرِن سُشُمَ نّ.
\q1 عٍ عَلَ شَ وَلِ مَسٍنمَ،
\q1 عٍ عَ شَ وَلِ كٌلٌنمَ نّ.
\q1 
\v 11 تِنشِنتْي سّيوَ مَ نّ عَلَتَلَ رَ،
\q1 عَ قَ لُ عَ نِينِ بُن مَ.
\q1 سٌندٌن قَنيِ كَنيِ حّلّشِنمَ نّ.
\c 65
\s1 سَابُي قَنيِ
\s2 عَلَ مَتْشْي
\d 
\v 1 دَوُدَ شَ بّيتِ بّيتِبَيٍ شَ مَنفّ بّ
\q1 
\v 2 مَتْشْي نَ عِ تَن عَلَ بّ سِيٌنِ فٍيَ قَرِ.
\q1 مُشُ لَايِدِ نَشَن تٌنفٌشِ عِ بّ،
\q1 مُشُ نَ بِرِن نَكَمَلِمَ نّ.
\q1 
\v 3 عَلَ، عِ مُشُ شَ مَشَندِ بِرِن مّمَ نّ.
\q1 دُنِحَ بِرِن قَمَ نّ بِرَدٍ عِ قْشْ رَ.
\q1 
\v 4 تَنتَنيِ تٌ نْ مُشُ رَ، عِ بَرَ مُشُ شَ يُنُبِ شَقَرِ.
\q1 
\v 5 عِ نَشَن سُفَندِ مَ عَ شَ مَكْرّ عِ شَ سَلِدٍ رَ،
\q1 نَ حّلّشِنمَ نّ بَرِ مَ عَ بُمَ نّ عِ شْنيِ.
\q1 مُشُ بَرَ وَ سَ عِ شَ قٍ قَنيِ رَ،
\q1 قٍ سّنِيّنشِ نَشَن كٍلِشِ عِ شَ هْرْ مْلِنفِرَ.
\q1 
\v 6 عِ مُشُ شَ مَشَندِ يَابِمَ كَابَنَكٌ نُن تِنشِنيِ رَ.
\q1 عَلَ، عِ بَرَ قِندِ مُشُ رَكِسِمَ رَ.
\q1 دُنِحَ يِرٍ بِرِن شَشِلِ تِشِ عِ رَ.
\q1 
\v 7 عِ بَرَ فٍيَ دَا عِ سّنبّ رَ
\q1 بَرِ مَ سّنبّمَ نَن عِ رَ.
\q1 
\v 8 عِ بَرَ بَا شُي رَدُندُ، مْرْنيِ شُي مُ نَ.
\q1 عِ بَرَ حَمَ قَن مَسَبَرِ.
\q1 
\v 9 دُنِحَ بِرِن فَاشُمَ نّ عِ شَ كَابَنَكٌي يَ رَ.
\q1 كٍلِقٍ سٌفٍتٍدٍ هَن سٌفٍفٌرٌدٍ،
\q1 عٍ بِرِن عٍ حّلّشِن شُي رَ مِنِمَ نّ عِ شَ قٍ رَ.
\q1 
\v 10 عِ بْشِ مّينِ، عَ عَ رَقٍ قٍ قَنيِ رَ.
\q1 عِ شُرٍ رَقٍمَ يٍ رَ عَلَكٌ مِشِيٍ شَ بَلٌي سْتْ.
\q1 
\v 11 عِ تُنّ يٍ سَمَ بْشِ مَ عَلَكٌ بْشِ شَ بْرْشْ سَنسِ بّ.
\q1 عِ بَرَكّ سَمَ شّ مَ، عَ شَ قَن.
\q1 
\v 12 شّ شَبَ تّمُي عِ قٍ قَنيِ رَ مِنِمَ نّ.
\q1 عِ شَ سَنسِ سَسٍ رَقٍمَ نّ، هَن عَ قِلِ عَ مَ.
\q1 
\v 13 فبٍنفبٍرٍنيِ قِيلِيٍ نُن فٍيَيٍ قَنمَ نّ.
\q1 
\v 14 شُرُ سٍيٍ يِرِوَ مَ نّ قِيلِ مَ.
\q1 سَنسِ يِرِوَ مَ نّ فٍيَ بُنيِيٍ.
\q1 نَ بِرِن، عَلَ شَ قٍ قَنيِ نَن مَسٍنمَ وٌن بّ سّيوّ كُي.
\c 66
\s1 عَلَ شَ كَابَنَكٌي مَفَاشُ
\s2 عَلَ مَتْشْي
\d بّيتِ نُن سُوكِ بّيتِبَيٍ شَ مَنفّ بّ
\q1 
\v 1 عَدَ مَدِيٍ بِرِن شُي شَ عِتٍ سّيوّ رَ عَلَ بّ.
\q1 
\v 2 وٌ شَ عَ شِلِ بِنيَ بّيتِ رَ،
\q1 وٌ شَ عَ بِنيَ مَتْشْي رَ.
\q1 
\v 3 وٌ شَ عَ قَلَ عَلَ بّ،
\q1 «عِ شَ كَابَنَكٌي مَفَاشُ.
\q1 عِ سّنبّ فبٌ هَن. هَلِ عِ يَشُييٍ سّرّنمَ عِ يَ رَ.
\q1 
\v 4 دُنِحَ بِرِن عِ بَتُمَ،
\q1 عٍ عِ بِنيَ بّيتِ رَ، عٍ عِ شِلِ مَتْشْ.» \qs حّنفِ رَتٍ.\qs*
\q1 
\v 5 وٌ قَ عَلَ شَ وَلِ مَتٌدٍ.
\q1 عَ نَ قٍ رَبَ عَدَ مَدِيٍ تَفِ، نَ مَفَاشُ.
\q1 
\v 6 عَ بَا قِندِ شَرٍ رَ،
\q1 عَ مِشِ رَفِرِ شُرٍ مَ عٍ سَنيِ شَرَشِ رَ.
\q1 نَ كُي، وٌن حّلّشِنمَ نّ عَ رَ.
\q1 
\v 7 عَ دُنِحَ يَمَرِ مَ سّنبّ رَ عَبَدَن.
\q1 عَ يَ تِشِ سِيٍ رَ، مَتَندِلَيٍ مُ نْمَ كٍلِدٍ سْنْن. \qs حّنفِ رَتٍ.\qs*
\q1 
\v 8 سِيٍ، وٌ شَ وٌن مَرِفِ عَلَ تَنتُ،
\q1 وٌ شَ وٌ شُي رَ مِنِ عَ مَتْشْقٍ رَ.
\q1 
\v 9 عَ بَرَ سِمَيَ قِ وٌن مَ،
\q1 عَ مُ تِن وٌن شَ بِرَ،
\q1 
\v 10 بَرِ مَ عَلَ وٌن بْحّ كٌلٌن.
\q1 عَ بَرَ وٌن مَتٌ عَلْ مِشِ فبٍتِ مَتٌمَ كِ نَشّ
\q1 عَ عَ رَشُنُ عَلَكٌ عَ فبِ شَ بَ.
\q1 
\v 11 عِ بَرَ مُشُ شُن تِ يّلّ كُي رَ،
\q1 عِ مَن بَرَ كٌتٍ دْشْ مُشُ شُن مَ.
\q1 
\v 12 عِ بَرَ عَ لُ مِشِيٍ شَ نْ مُشُ رَ،
\q1 مُشُ شَ تْورْ يٍ نُن تّ شْورَ.
\q1 كْنْ عَ رَحْنيِ، عِ بَرَ مُشُ شُن تِ دَشَمُي يِرٍ رَ.
\q1 
\v 13 ﭑ قَمَ سّرّشّ فَن دَاشِ رَ عِ شَ بَنشِ كُي،
\q1 ﭑ نَن ﭑ مَ لَايِدِ رَكَمَلِمَ نّ،
\q1 
\v 14 ﭑ نَشٍيٍ قَلَ ﭑ دّ رَ ﭑ نُ تْورّ كُي تّمُي نَشّ.
\q1 
\v 15 ﭑ شُرُ سٍ تُرَشِيٍ بَمَ نّ سّرّشّ فَن دَاشِ رَ،
\q1 عَلْ يّشّي كٌنتٌنيِيٍ، تُورَيٍ، نُن سِ دٌنبِيٍ. \qs حّنفِ رَتٍ.\qs*
\q1 
\v 16 وٌ قَ، وٌ شَ وٌ تُلِ مَتِ،
\q1 وٌ تَن نَشٍيٍ فَاشُمَ عَلَ يَ رَ.
\q1 ﭑ شَ عَ مَسٍن عَلَ نَشَن نَبَشِ ﭑ بّ.
\q1 
\v 17 ﭑ بَرَ عَ شِلِ، ﭑ بَرَ عَ مَتْشْ.
\q1 
\v 18 شَ يَنقَنتٍيَ نُ نَ ﭑ بْحّ كُي نُ،
\q1 ﭑ مَرِفِ مُ نُ عَ تُلِ مَتِمَ ﭑ نَ.
\q1 
\v 19 كْنْ عَلَ بَرَ ﭑ شُي رَ مّ،
\q1 عَ ﭑ مَ دُبّ سُشُ.
\q1 
\v 20 تَنتُي نَ عَلَ بّ نَشَن بَرَ ﭑ مَ مَشَندِ شُي مّ،
\q1 عَ مَن بَرَ هِننّ ﭑ نَ.
\c 67
\s1 سِ بِرِن شَ عَلَ شَ مَرَكِسِ كٌلٌن
\s2 عَلَ مَتْشْي
\d 
\v 1 بّيتِ نُن سُوكِ بّيتِبَيٍ شَ مَنفّ بّ. عَ شَ بَ كْرَ شُي رَ.
\q1 
\v 2 عَلَ شَ هِننّ وٌن نَ،
\q1 عَلَ شَ بَرَكّ رَفٌرٌ وٌن مَ،
\q1 عَلَ شَ نَءِيَلَنيِ شَ يَنبَ وٌن مَ، \qs حّنفِ رَتٍ\qs*
\q1 
\v 3 عَلَكٌ عَ شَ كِرَيٍ شَ كٌلٌن دُنِحَ مَ،
\q1 عَلَكٌ سِ بِرِن شَ عَ شَ مَرَكِسِ كٌلٌن.
\q1 
\v 4 عَلَ، سِيٍ شَ عِ تَنتُ، سِ بِرِن شَ عِ تَنتُ.
\q1 
\v 5 عٍ شَ بّيتِ بَ حّلّشِنيِ كُي،
\q1 بَرِ مَ عِ سِيٍ مَكِيتِمَ نْندِ رَ،
\q1 عِ تَن نَن عٍ رَحّرّ مَ يِ دُنِحَ بّندّ قُحِ قَرِ. \qs حّنفِ رَتٍ.\qs*
\q1 
\v 6 عَلَ، سِيٍ شَ عِ تَنتُ،
\q1 سِ بِرِن شَ عِ تَنتُ.
\b
\q1 
\v 7 بْشِ بَرَ دَشَمُي رَ مِنِ وٌن بّ،
\q1 تَنتُي نَ وٌن مَرِفِ عَلَ بّ.
\q1 
\v 8 عَلَ شَ بَرَكّ سَ وٌن مَ،
\q1 دُنِحَ بِرِن شَ فَاشُ عَ يَ رَ.
\c 68
\s1 عَلَ نَن دُنِحَ مَنفّ رَ
\s2 عَلَ مَتْشْي
\d 
\v 1 دَوُدَ شَ بّيتِ بّيتِبَيٍ شَ مَنفّ بّ
\q1 
\v 2 عَلَ شَ كٍلِ، عَ يَشُييٍ شَ يٍنسٍن يّ.
\q1 نَشٍيٍ عَ شْنمَ، عٍ شَ عٍ فِ عَ يَ رَ.
\q1 
\v 3 عِ عِ يَشُييٍ رَلْيمَ نّ
\q1 عَلْ قٌيٍ تّ تُورِ رَلْيمَ كِ نَشّ.
\q1 كَاقِرِ لْيمَ نّ عَلَ يَ عِ،
\q1 عَلْ تُرٍ شُنُمَ تّ عِ كِ نَشّ.
\q1 
\v 4 كْنْ مِشِ تِنشِنشِ حّلّشِنمَ نّ،
\q1 عٍ عٍ سّيوّ شُي عِتٍمَ نّ عَلَ يَ عِ.
\q1 عٍ تَن لُمَ نَ حّلّشِنيِ نَن كُي.
\q1 
\v 5 وٌن شَ بّيتِ بَ عَلَ بّ، وٌن شَ عَ شِلِ مَتْشْ بّيتِ رَ.
\q1 نَشَن حّرّ مَ نُشُي قَرِ، وٌن شَ عَ رَ سّنّ.
\q1 عَ شِلِ عَلَتَلَ.
\q1 وٌن شَ وٌن سّيوّ شُي رَتٍ عَ مَ.
\q1 
\v 6 عَلَ، مِسِكِينّ بَبَ نَن عَ رَ.
\q1 عَلَ، كَاحّ مَكَنتّ نَن عَ رَ.
\q1 عَلَ شْنيِ سّنِيّن.
\q1 
\v 7 عَلَ دٍنبَيَ قِمَ دٍنبَيَتَرٍ مَ،
\q1 عَلَ شْرّيَ قِمَ فٍيلِمَنِيٍ مَ، عٍ حّلّشِنمَ نّ.
\q1 كْنْ عَلَ مَتَندِيٍ لُمَ نّ فبٍنفبٍرٍنيِ مَ.
\b
\q1 
\v 8 عَلَ، عِ نُ نَ عِ شَ حَمَ يَ رَ وُلَ عِ تّمُي نَشّ،
\q1 
\v 9 بْشِ بِرِن نُ سّرّنمَ نّ.
\q1 تُنّ يٍ نُ فٌرٌ مَ عَلَ يَ عِ،
\q1 عِسِرَيِلَ مَرِفِ عَلَ، نَشَن نَ سِيٌنِ.
\q1 
\v 10 عَلَ نُ تُنّ يٍ رَفٌرٌ مَ بْشِ مَ،
\q1 عَ شَ سّنبّ قِ عَ شَ بْشِ تَفَنشِ مَ.
\q1 
\v 11 عِ بَرَ عِ شَ حَمَ رَ سَبَتِ نَا.
\q1 عِ بَرَ تْورْ مِشِ مَلِ نَا.
\q1 عِ نَ بِرِن نَبَشِ نّ بَرِ مَ عِ قَن.
\q1 
\v 12 مَرِفِ مَسٍنيِ قَنيِ سٌمَ عَ شَ شّيرَيٍ يِ رَ.
\q1 فَلِ بٍلٍبٍلٍ نَن عٍ رَ. عٍ نَشّ،
\q1 
\v 13 «فٍرٍ سٌي مَنفّيٍ نَ عٍ فِقٍ،
\q1 عٍ نَ عٍ فِقٍ وٌ يَ رَ.
\q1 وٌ شَ فِنّيٍ نَشٍيٍ لُشِ بَنشِ،
\q1 عٍ قَمَ يِ فٍرٍ نَاقُلِ عِتَشُندٍ.
\q1 
\v 14 وٌ قَمَ وٌ مَلَبُدٍ وٌ شَ شُرُ سٍيٍ قّ مَ.
\q1 عَلَ مّينِمَ نّ عَ شَ حَمَ مَ
\q1 عَلْ عَ مّينِمَ فَنبّيٍ مَ كِ نَشّ.
\q1 عٍ فَبُتٍنيِ لُمَ عَلْ فبٍتِ نُن شّيمَ نَن نَ عٍ مَ.»
\q1 
\v 15 عَلَ شِلِ شُنفبٍ كَنيِ بَرَ مَنفّيٍ رَيٍنسٍن
\q1 سَلَمٌن فٍيَ مَ بَلَبَلَنيِ سَابُي رَ.
\q1 
\v 16 بَسَن فٍيَ، عَلَ نَشَن دَاشِ، كٌندٍ وُيَشِ نَشَن بّ،
\q1 
\v 17 وٌ نَ عَلَ شَ فٍيَ سُفَندِشِ مَتٌقٍ تْونّ رَ مُنقٍ رَ،
\q1 عَ بَرَ عَ شَ هْرْ مْلِنفِرَ تِ دّننَشّ؟
\q1 عَلَ لُمَ نّ مّننِ تّمُي بِرِن.
\q1 
\v 18 عَلَتَلَ شَ فٍرٍ سٌي شَ فِسٍيٍ وُيَ دَنفِ وُلُ قُ رَ.
\q1 عَ شَ فٍرٍ سٌي قَن دَنفِ وُلُ وُلُيٍ رَ.
\q1 عَلَ نَ عٍ يَ مَ.
\q1 سِنَيِ فٍيَ نَ يِرٍ سّنِيّنشِ كُي.
\q1 
\v 19 ﭑ مَرِفِ عَلَتَلَ، عِ بَرَ تٍ كٌورٍ مَ.
\q1 عِ بَرَ فٍيلِمَنِيٍ شَنِن.
\q1 عَدَ مَدِيٍ بَرَ عِ بُحَ،
\q1 مَتَندِلَيٍ قَن بَرَ وَ سٌقٍ عِ شْنيِ.
\q1 
\v 20 تَنتُي نَ عِ بّ لْشْي بِرِن،
\q1 عَ وٌن مَ كٌتٍ شَنِنقٍ لْشْ يٌ لْشْ.
\q1 وٌن مَ مَرَكِسِمَ نَ عَلَ نَن نَ.
\q1 
\v 21 وٌن مَرِفِ عَلَتَلَ وٌن نَكٍلِمَ نّ قَشّ مَ.
\q1 وٌن مَ مَرَكِسِمَ نَ عَلَ نَن نَ.
\q1 
\v 22 عَلَ عَ يَشُييٍ شُنيِ كَنَمَ نّ.
\q1 نَشٍيٍ حّرّ كِرَ حَاشِ شْن مَ،
\q1 عَ نٍيٍ قَن شُن شْرِ بْو مَ نّ.
\q1 
\v 23 مَرِفِ نَشّ، «ﭑ قَمَ نّ عٍ رَ كٍلِقٍ بَسَن،
\q1 ﭑ قَ عٍ رَ كٍلِقٍ بَا مَ،
\q1 
\v 24 عَلَكٌ وٌ شَ قَ عٍ وُلِ تٌ وٌ سَنلَابٍ رَ.
\q1 وٌ شَ بَرٍيٍ قَن عٍ دٌنمَ نّ.»
\b
\q1 
\v 25 عَلَ، مُشُ بَرَ عِ تٌ قَ رَ حَمَ يَ مَ.
\q1 عَلَ نُن عَ شَ مَنفّ سُفَندِشِ نَ سٌقٍ هْرْ مْلِنفِرَ كُي.
\q1 
\v 26 بّيتِبَيٍ نَ يَرٍ، كْرَ بْنبْييٍ نَ عٍ قْشْ رَ،
\q1 فِنّيٍ نَ مَشَسٍ رَ مَشَقٍ عٍ رَبِلِنيِ.
\q1 
\v 27 وٌ شَ عَلَ تَنتُ مَلَنيِيٍ،
\q1 عِسِرَيِلَ شَ دِيٍ، وٌ شَ عَلَتَلَ تَنتُ.
\q1 
\v 28 بُنيَمِن نَن يَ،
\q1 نَشَن بَرِشِ دْنشْي رَ.
\q1 عَ تَن نَن قِندِشِ عٍ شَ مَنفّ رَ.
\q1 يُدَيَ مَنفّيٍ نَن يَ، عٍ نُن عٍ شَ مِشِيٍ.
\q1 سَبُلٌن مَنفّيٍ نَن يَ،
\q1 نَقَتَلِ مَنفّيٍ نَن يَ.
\b
\q1 
\v 29 عَلَ، عِ شَ مَسٍنيِ تِ سّنبّ رَ.
\q1 عِ شَ عِ سّنبّ مَسٍن عَلْ تّمُي دَنفِشِ.
\q1 
\v 30 عِ شَ بَنشِ نَ دَرِ سَلَمُ.
\q1 مَنفّيٍ قَمَ عِ بُحَدٍ نَا.
\q1 
\v 31 عِ شَ شَاحّ مِسِرَ مَ،
\q1 نَشَن مَنِيّ مَلِ شُنفبٍ رَ نَشَن نَ يٍ شْورَ.
\q1 عَ لُمَ عَلْ تُورَ فَلِ، نِنفٍ يْرّيٍ بِرَشِ نَشٍيٍ قْشْ رَ.
\q1 نَ نِنفٍ يْرّيٍ لُمَ عَلْ سِ فبّتّيٍ
\q1 نَشٍيٍ دُوتِ قِمَ مِسِرَ مَ.
\q1 سِ فبّتّيٍ نَشٍيٍ وَ مَ فٍرٍ شْن، عِ شَ عٍ رَيٍنسٍن يّ.
\q1 
\v 32 مِسِرَ شّيرَيٍ، عَ نُن كُسِ شّيرَيٍ، شَ قَ دُوتِ رَ عَلَ بّ.
\b
\q1 
\v 33 مَنفّ نَشٍيٍ بِرِن نَ دُنِحَ، نُن عَ رَبِلِنيِ،
\q1 وٌ شَ بّيتِ بَ عَلَ بّ، وٌ شَ عَلَتَلَ تَنتُ،
\q1 
\v 34 نَشَن حّرّ مَ نُشُي قَرِ كٌورٍ مَ كَبِ عَ رَكُيَ،
\q1 نَشَن فَلَنيِ شُي رَ مِنِمَ سّنبّ رَ.
\q1 
\v 35 وٌ شَ عَ كٌلٌن، عَلَ سّنبّ فبٌ.
\q1 عَ عِسِرَيِلَ يَمَرِ مَ عَ سّنبّ رَ،
\q1 سّنبّ نَشَن كٍلِمَ كٌورٍ مَ.
\b
\q1 
\v 36 عَلَ، عِ نَ عِ شَ هْرْ مْلِنفِرَ كُي.
\q1 عَلَ، عِ مَفَاشُ.
\q1 عِسِرَيِلَ مَرِفِ عَلَ سّنبّ قِمَ نّ عَ شَ حَمَ مَ.
\q1 عَلَ تَنتُ!
\c 69
\s1 ﭑ نَ بِرِقٍ
\s2 عَلَ مَشَندِ
\d 
\v 1 دَوُدَ شَ بّيتِ بّيتِبَيٍ شَ مَنفّ بّ. عَ شَ بَ عَلْ بّيتِ نَشَن شِلِ، «قُفٍ تٌقَنيِيٍ.»
\q1 
\v 2 عَلَ، ﭑ نَكِسِ!
\q1 يٍ بَرَ تٍ هَن ﭑ كْنيِ.
\q1 
\v 3 ﭑ نَ بِرِقٍ بٌورَ تِلِنشِ كُي،
\q1 ﭑ سَنيِ مُ تِدٍ يٌ سْتْقٍ.
\q1 ﭑ نَ مَدُلَقٍ يٍ شْورَ.
\q1 
\v 4 ﭑ بَرَ عِ شِلِ هَن ﭑ بَرَ تَفَن،
\q1 ﭑ شُي يٌ مُ نَ سْنْن،
\q1 ﭑ يَ بَرَ ﭑ شْنْ عِ قٍنقٍ رَ.
\q1 
\v 5 ﭑ شْنمِشِيٍ بَرَ وُيَ دَنفِ ﭑ شُنسّشّ رَ.
\q1 سّنبّمَيٍ نَن عٍ رَ نَشٍيٍ وَ مَ ﭑ قَشَقٍ.
\q1 عٍ قِندِ ﭑ يَشُييٍ رَ هَلِ ﭑ مُ قٍقٍ رَبَشِ عٍ رَ.
\q1 ﭑ مُ قٍ حَاشِ يٌ رَبَشِ عٍ رَ،
\q1 كْنْ عٍ وَ مَ ﭑ شَ سَرٍ ندٍ قِ.
\q1 
\v 6 عَلَ، عِ ﭑ مَ تَنتَنيِ كٌلٌن،
\q1 ﭑ مَ يُنُبِيٍ مُ نْشُنشِ عِ مَ.
\b
\q1 
\v 7 مَنفّ عَلَتَلَ، عِ نَشَ عَ لُ
\q1 دَنشَنِيَتْييٍ شَ يَافِ ﭑ مَ قٍ رَ.
\q1 عِسِرَيِلَ مَرِفِ عَلَ، عِ نَشَ عَ لُ
\q1 عِ قٍنمَيٍ شَ عِقُ ﭑ مَ قٍ رَ.
\q1 
\v 8 عٍ ﭑ كٌنبِمَ عِ تَن نَن مَ قٍ رَ.
\q1 ﭑ بَرَ يَافِ هَن.
\q1 
\v 9 ﭑ شُنيَيٍ مُ ﭑ كٌلٌن سْنْن،
\q1 ﭑ بَرَ لُ ﭑ تَارَيٍ بّ عَلْ شْحّ ندٍ.
\q1 
\v 10 ﭑ وَ مَ عِ وَشْنقٍ رَبَقٍ.
\q1 عِ كٌنبِمَيٍ بَرَ قِندِ ﭑ يَشُييٍ رَ.
\q1 
\v 11 ﭑ وَ مَ، ﭑ سُنمَ.
\q1 نَ بِرِن مَن كُي، مِشِيٍ ﭑ كٌنبِمَ.
\q1 
\v 12 ﭑ سُننُن دٌنمَ رَفٌرٌ مَ ﭑ مَ، عٍ ﭑ مَيٍلٍمَ.
\q1 
\v 13 نَشٍيٍ دْشْشِ تَا سٌدٍ دّ رَ، نٍيٍ ﭑ مَقَلَمَ،
\q1 سِيسِلَيٍ ﭑ مَيٍلٍمَ سِفِ رَ.
\b
\q1 
\v 14 كْنْ عَلَتَلَ، ﭑ بَرَ عِ مَشَندِ.
\q1 عَلَ عِ شَ هِننّ ﭑ نَ بَرِ مَ عِ شَ هِننّ فبٌ.
\q1 
\v 15 ﭑ نَكِسِ عَلَكٌ ﭑ نَشَ بِرِ بٌورَ شْورَ،
\q1 ﭑ نَتَنفَ ﭑ شْنمِشِيٍ مَ.
\q1 
\v 16 عِ نَشَ تِن ﭑ شَ مَدُلَ، يٍ نَشَ ﭑ نَلْي،
\q1 ﭑ نَشَ فٌرٌ عَلِفِيَمَ.
\q1 
\v 17 عَلَتَلَ، ﭑ شُي رَتِن،
\q1 عِ تَن نَشَن قَن، نَشَن شَ هِننّ فبٌ.
\q1 عِ شَ كِنِكِنِ ﭑ مَ، عِ شَ ﭑ مَلِ.
\q1 
\v 18 عِ نَشَ عِ نْشُن عِ شَ كٌنيِ مَ.
\q1 ﭑ نَ تْورّ كُي، يَندِ ﭑ مَلِ.
\q1 
\v 19 عِ شَ عِ مَكْرّ ﭑ نَ،
\q1 عِ شَ ﭑ شُنسَرَ، عِ شَ ﭑ نَكِسِ ﭑ يَشُييٍ مَ.
\b
\q1 
\v 20 عِ بَرَ ﭑ مَ تْورّ نُن ﭑ مَ يَافِ كٌلٌن،
\q1 ﭑ يَشُييٍ بِرِن نَ عِ يَ عِ.
\q1 
\v 21 كٌنبِ بَرَ ﭑ بْحّ كَنَ هَن ﭑ بَرَ قُرَ.
\q1 ﭑ هَيِ نَ كِنِكِنِ مَ، كْنْ عَ مُ نَ.
\q1 ﭑ هَيِ نَ مِشِ مَدُندُ مَيٍ مَ، كْنْ عٍ مُ تٌمَ.
\q1 
\v 22 عٍ ثْسْنّ سَمَ ﭑ مَ دٌنسٍ،
\q1 عٍ مِنسٍ شْنّ سٌمَ ﭑ يِ رَ، يٍ حْشْي رَ.
\q1 
\v 23 عٍ شَ تٍيبِلِ شَ قِندِ فَنتَنيِ رَ عٍ بّ،
\q1 عٍ شَ نَاقُلِ شَ قِندِ يّلّ رَ نَشَن عٍ سُشُمَ.
\q1 
\v 24 عٍ يَ شَ عِقْورْ، عٍ شَ دْنشُ.
\q1 عٍ تَفِ شَ عٍ شْنْ هَن عٍ شَ بِرَ.
\q1 
\v 25 عِ شَ شْنْ عٍ مَ، عٍ شَ نَ تّ كٌلٌن.
\q1 
\v 26 عٍ شَ فْورّ شَ حْن،
\q1 عَدَ مَدِيٍ نَشَ لُ عٍ شْنيِ سْنْن،
\q1 
\v 27 بَرِ مَ عٍ تْورْ مِشِيٍ شَ تْورّ شُن مَسَمَ،
\q1 عِ نَشٍيٍ حَشَنكَتَ.
\q1 عٍ مِشِيٍ مَيٍلٍمَ، عِ نَشٍيٍ هَلَكِ.
\q1 
\v 28 عِ شَ عٍ شَ يُنُبِ بِرِن تٌ،
\q1 عَلَكٌ عٍ نَشَ عِ شَ كِسِ سْتْ سْنْن.
\q1 
\v 29 عٍ شِلِيٍ شَ بَ سِمَيَ سّبّلِ كُي،
\q1 عٍ نَشَ لُ تِنشِنتْييٍ يَ مَ.
\b
\q1 
\v 30 ﭑ تَن نَ تْورْقٍ يِ تّمُي،
\q1 عَلَ، عِ شَ ﭑ نَكِسِ، عِ شَ ﭑ نَكٍلِ.
\q1 
\v 31 ﭑ قَمَ عَلَ شِلِ مَتْشْدٍ بّيتِ رَ،
\q1 ﭑ قَمَ تَنتُي رَ سِفَدٍ عَ مَ.
\q1 
\v 32 نَ رَقَن عَلَتَلَ مَ دَنفِقٍ سّرّشّ رَ،
\q1 هَلِ نِنفٍ كَمَلِشِ نَ عَ رَ،
\q1 هَلِ تُورَ قٍرِ كَنيِ نَ عَ رَ، تٌرٍيٍ نَ نَشَن بّ.
\q1 
\v 33 تْورْ مِشِيٍ سّيوَ مَ نّ نَ تٌقٍ رَ.
\q1 نَشٍيٍ عَلَ قٍنمَ، عٍ سِمَيَ شْنكُيٍ سْتْمَ نّ.
\q1 
\v 34 عَلَتَلَ عَ تُلِ مَتِمَ سٍتَرٍيٍ رَ،
\q1 عَ مُ نّيمُمَ عَ شَ مِشِيٍ مَ عٍ شَ تْورّ كُي.
\b
\q1 
\v 35 كٌورٍ نُن بْشِ شَ عَ مَتْشْ،
\q1 بَا نُن يّشّييٍ شَ عَ بِنيَ.
\q1 
\v 36 عَلَ قَمَ سِيٌنِ رَكِسِدٍ،
\q1 عَ يُدَ تَايٍ تِمَ نّ.
\q1 عَ مَن حَمَ سَبَتِ نَا،
\q1 نَا شَ قِندِ عٍ فبٍ رَ.
\q1 
\v 37 نَ قِندِ مَ عَ شَ كٌنيِيٍ شَ مَمَدِيٍ كّ نَن نَ.
\q1 عَلَ شَنُنتٍنيِيٍ قَمَ نّ لُدٍ نَا.
\c 70
\s1 عَلَ قٍنمَيٍ شَ سّيوَ
\s2 عَلَ مَشَندِ
\d 
\v 1 دَوُدَ شَ مَشَندِ بّيتِ بّيتِبَيٍ شَ مَنفّ بّ
\q1 
\v 2 عَلَ، ﭑ نَكِسِ!
\q1 عَلَتَلَ، قَ ﭑ مَلِ مَقُرٍن.
\q1 
\v 3 عَلَ شَ مِشِيٍ رَيَافِ نَشٍيٍ وَ مَ ﭑ قَشَقٍ.
\q1 عَلَ شَ عٍ كٍرِ،
\q1 عَلَ شَ عٍ يَ عِقُ، نَشٍيٍ وَ مَ ﭑ تْورْقٍ.
\q1 
\v 4 عَلَ شَ عٍ كٍرِ يَافِ كُي، نَشٍيٍ عَ قَلَمَ ﭑ بّ، «عِ شَ تْورْ!»
\b
\q1 
\v 5 عِ قٍنمَيٍ شَ سّيوَ.
\q1 نَشٍيٍ وَ مَ عِ شَ كِسِ شْن، عٍ شَ عَلَ مَتْشْ تّمُي بِرِن.
\q1 
\v 6 عَلَ، ﭑ قِندِشِ مِسِكِينّ نُن تْورْ مِشِ نَن نَ،
\q1 قَ ﭑ مَلِ، عِ نَشَ دُفُندِ.
\c 71
\s1 قٌرِ شَ مَشَندِ
\s2 عَلَ مَشَندِ
\q1 
\v 1 عَلَتَلَ، ﭑ كَنتَمَ نَ عِ تَن نَن نَ،
\q1 عِ نَشَ تِن ﭑ شَ لُ يَافِ كُي.
\q1 
\v 2 عِ شَ ﭑ نَكِسِ، عِ شَ ﭑ مَلِ عِ شَ تِنشِنيِ كُي.
\q1 عِ تُلِ مَتِ ﭑ نَ، عِ ﭑ نَكِسِ.
\q1 
\v 3 عِ شَ ﭑ كَنتَ.
\q1 عِ بَرَ عَ قَلَ ﭑ بّ ﭑ شَ لُ عِ شَ نِينِ بُن مَ تّمُي بِرِن،
\q1 عَلَكٌ ﭑ شَ كِسِ.
\q1 ﭑ كَنتَمَ نَ عِ تَن نَن نَ.
\q1 
\v 4 ﭑ مَرِفِ عَلَ، ﭑ نَتَنفَ مِشِ حَاشِيٍ سّنبّ مَ،
\q1 ﭑ نَتَنفَ شْننَنتٍ تِنشِنتَرٍيٍ مَ.
\q1 
\v 5 ﭑ مَرِفِ عَلَتَلَ، ﭑ شَشِلِ تِشِ عِ تَن نَن نَ
\q1 كَبِ ﭑ دِ مّدِ تّمُي،
\q1 
\v 6 كَبِ ﭑ نُ نَ ﭑ نفَ تّيفّ عِ.
\q1 عِ تَن نَن عَ نِيَ ﭑ شَ بَرِ.
\q1 ﭑ عِ مَتْشْمَ تّمُي بِرِن.
\q1 
\v 7 ﭑ قِندِشِ مِسَالِ نَن نَ مِشِ وُيَشِ بّ،
\q1 بَرِ مَ ﭑ كَنتَمَ سّنبّمَ نَ عِ تَن نَن نَ.
\q1 
\v 8 ﭑ عِ مَتْشْمَ تّمُي بِرِن.
\b
\q1 
\v 9 عِ نَشَ مّي ﭑ نَ ﭑ مَ قٌرِحَ كُي،
\q1 عِ نَشَ ﭑ نَبّحِن ﭑ مَ سّنبّتَرٍيَ كُي.
\q1 
\v 10 ﭑ يَشُييٍ ﭑ مَقَلَمَ،
\q1 عٍ وْيّنمَ عٍ بٌرَ رَ عَلَكٌ عٍ شَ ﭑ قَشَ.
\q1 
\v 11 عٍ نَشّ، «عَلَ بَرَ عَ رَبٌلٌ،
\q1 وٌن شَ بِرَ عَ قْشْ رَ، وٌن شَ عَ سُشُ.
\q1 مِشِ يٌ مُ نْمَ عَ رَتَنفَدٍ.»
\q1 
\v 12 عَلَ، عِ نَشَ عِ مَكُيَ ﭑ نَ.
\q1 ﭑ مَرِفِ عَلَ، قَ ﭑ مَلِ مَقُرٍن.
\q1 
\v 13 عَلَ شَ عٍ رَيَافِ، عَ شَ عٍ رَحْن، نَشٍيٍ ﭑ تْوحّفّمَ.
\q1 عَلَ شَ عٍ رَيَافِ، عَ شَ عٍ يَ عِقُ، نَشٍيٍ وَ مَ ﭑ تْورْقٍ.
\q1 
\v 14 ﭑ شَشِلِ تِشِ عِ رَ كُدّ عِ.
\q1 ﭑ لُمَ عِ مَتْشْ رَ تّمُي بِرِن.
\q1 
\v 15 ﭑ عِ شَ تِنشِنيِ نُن عِ شَ كِسِ تَنتُمَ لْشْي بِرِن،
\q1 بَرِ مَ عٍ وُيَ هَن ﭑ حَن مُ نْمَ عٍ بِرِن كٌلٌندٍ.
\q1 
\v 16 ﭑ عِ شَ كَابَنَكٌ رَبَشِيٍ مَتْشْمَ نّ.
\q1 ﭑ مَرِفِ عَلَتَلَ، ﭑ قَمَ عِ شَ تِنشِنيِ فبَنسَن مَسٍندٍ.
\b
\q1 
\v 17 عَلَ، عِ نَ ﭑ شَرَنقٍ كَبِ ﭑ دِ مّدِ تّمُي.
\q1 هَن يَ ﭑ عِ شَ كَابَنَكٌي مَتْشْمَ.
\q1 
\v 18 عَلَ، عِ نَشَ ﭑ نَبّحِن يَكْسِ،
\q1 ﭑ بَرَ قٌرِ، ﭑ شُنسّشّ قَن بَرَ قُفَ.
\q1 عِ نَشَ ﭑ نَبّحِن
\q1 عَلَكٌ ﭑ شَ عِ سّنبّ مَسٍن تٌ نُن تِنَ مِشِيٍ بّ.
\q1 
\v 19 عَلَ، عِ شَ تِنشِنيِ فبٌ عَلْ فٍيَ.
\q1 عِ شَ كَابَنَكٌ وُيَ.
\q1 عِ مَنِيّ نَ مِندٍن؟
\q1 
\v 20 هَلِ عِ تٌ بَرَ عَ نِيَ مُشُ شَ تْورْ، مُشُ شَ هَلَكِ،
\q1 عِ قَمَ مُشُ رَكِسِدٍ،
\q1 عِ قَمَ مُشُ رَكٍلِدٍ فَبُرِ تِلِنشِ كُي.
\q1 
\v 21 عِ شَ ﭑ شُن نَكٍلِ، عِ شَ ﭑ مَدُندُ.
\q1 
\v 22 ﭑ مَرِفِ عَلَ، نَ كُي ﭑ عِ تَنتُمَ نّ كْرَ رَ
\q1 عِ شَ دُفُتّفّحَ شَ قٍ رَ.
\q1 عِسِرَيِلَ شَ سّنِيّنتْي، ﭑ بّيتِ بَمَ عِ بّ كْرَ رَ.
\q1 
\v 23 ﭑ بّيتِ بَمَ نّ عِ بّ، ﭑ عِ مَتْشْ،
\q1 بَرِ مَ عِ بَرَ ﭑ شُن سَرَ.
\q1 
\v 24 ﭑ عِ شَ تِنشِنيِ مَتْشْمَ نّ تّمُي بِرِن،
\q1 بَرِ مَ نَشٍيٍ نُ وَ مَ ﭑ تْورْقٍ،
\q1 عٍ بَرَ لُ يَافِ كُي.
\c 72
\s1 عِسِرَيِلَ مَنفّ
\s2 عَلَ مَشَندِ
\d سُلٍمَنِ فبٍ
\q1 
\v 1 عَلَ، عِ شَ عَ نِيَ مَنفّ شَ كِيتِ تِنشِنشِ سَ.
\q1 عِ شَ تِنشِنيِ شَ لُ مَنفّ شَ دِ دّ عِ.
\q1 
\v 2 نَ كُي عَ شَ عِ شَ حَمَ مَكِيتِ نْندِ رَ،
\q1 عَ شَ تِنشِن تْورْ مِشِيٍ بّ.
\q1 
\v 3 مَسٍنيِ شَ تِ فٍيَيٍ قَرِ، حَمَ بْحّ سَشِ رَ،
\q1 شِبَارُي شَ يٍنسٍن بْشِ مَ، تِنشِنيِ نَن حَمَ يَمَرِ مَ.
\q1 
\v 4 مَنفّ شَ سّرِيّ رَبَ تْورْ مِشِيٍ بّ،
\q1 عَ شَ سٍتَرٍ شَ دِيٍ رَكِسِ، عَ شَ عٍ فٍرٍقَيٍ رَيٍنسٍن.
\q1 
\v 5 مِشِيٍ شَ فَاشُ عِ يَ رَ عَبَدَن،
\q1 دَنمِ سٌفٍ نُن كِكٍ يَنبَمَ.
\b
\q1 
\v 6 مَنفّ شَ لُ عَلْ تُنّ نَشَن بِرَ مَ شّيٍ مَ،
\q1 نَشَن بْشِ رَقَنمَ.
\q1 
\v 7 تِنشِنتْي شَ قٍ قَنمَ نَ وَشَتِ نّ،
\q1 دَنمِ كِكٍ يَنبَمَ، بْحّسَ فبٌمَ نّ.
\q1 
\v 8 عَ شَ مَنفّيَ فبٌمَ نّ،
\q1 سَ قْلْ سٌفٍتٍدٍ هَن عَ سَ دْشْ سٌفٍفٌرٌدٍ رَ،
\q1 عَ قْلْ عٍقِرَتِ شُرٍ مَ هَن سَ دْشْ بْشِ دَنيِ رَ.
\q1 
\v 9 مِشِ نَشٍيٍ نَ وُلَ عِ، عٍ شِنبِ سِنمَ نّ عَ بُن مَ،
\q1 عَ يَشُييٍ لُ عَ سَنيِ بُن مَ.
\q1 
\v 10 تَرَ سِسِ مَنفّيٍ نُن سُرِ مَنفّيٍ قَمَ نّ بُحَيٍ رَ.
\q1 سٍيبَ نُن سٍبَ مَنفّيٍ قَن دُوتِ قِمَ نّ عَ مَ.
\q1 
\v 11 مَنفّ بِرِن عٍ شِنبِ سِنمَ نّ عَ بُن مَ،
\q1 سِيٍ بِرِن لُ عَ شَ يَامَرِ بُن مَ.
\q1 
\v 12 نَ كُي سٍتَرٍيٍ قَمَ نّ عَ شِلِدٍ مَرَكِسِمَ.
\q1 عَ مِسِكِينّ سّنبّتَرٍ مَلِمَ نّ.
\q1 
\v 13 عَ كِنِكِنِمَ نّ سّنبّتَرٍيٍ نُن سٍتَرٍيٍ مَ،
\q1 عَ تْورْ مِشِيٍ رَكِسِ.
\q1 
\v 14 عَ عٍ شْرّيَمَ نّ مَءِقُي نُن قٍ كٌبِيٍ مَ،
\q1 بَرِ مَ عٍ قِندِشِ عَ شَنُنتٍنيِيٍ نَن نَ.
\q1 
\v 15 عَ شَ مَنفّيَ شَ بُ!
\q1 عَ سٍيبَ بْشِ شَ شّيمَ سْتْمَ نّ.
\q1 مِشِيٍ شَ عَلَ مَشَندِ عَ بّ تّمُي بِرِن،
\q1 عٍ نَشَ تَفَن دُبَدٍ عَ بّ.
\b
\q1 
\v 16 عَلَ دٌنسٍ يِرِوَ مَ نّ بْشِ كُي.
\q1 فٍيَيٍ رَقٍمَ نّ سَنسِيٍ رَ،
\q1 عٍ بٌفِيٍ لُ عَلْ سَنسِ بٌفِ نَشٍيٍ نَ لِبَن.
\q1 مِشِيٍ فبٌمَ نّ تَا كُي عَلْ بْشِ سّشّ.
\q1 
\v 17 مَنفّ عَلَ شِلِ فبٌ عَبَدَن!
\q1 دَن مُ نَ عَ شِلِ مَ سٌفٍ بُن مَ.
\q1 سِ بِرِن بَرَكّ سْتْمَ نّ عَ سَابُي رَ،
\q1 عٍ قَ عَ مَتْشْ.
\b
\q1 
\v 18 عِسِرَيِلَ مَرِفِ عَلَتَلَ تَنتُ.
\q1 عَ كٍرٍن نَن كَابَنَكٌي رَبَمَ.
\q1 
\v 19 عَ شِلِ شُنفبٍ شَ تَنتُ عَبَدَن.
\q1 دُنِحَ بِرِن شَ عَ شَ بِنيّ كٌلٌن.
\q1 عَمِنَ! عَمِنَ!
\b
\d 
\v 20 يِسَيِ شَ دِ دَوُدَ شَ مَشَندِيٍ رَحْنيِ نَن نَ كِ.
\c 73
\s1 حَاشُحَ سَرٍ
\s2 عَلَ مَشَندِ
\d 
\v 1 عَسَقِ شَ بّيتِ
\q1 نْندِ هَفِفّ نَن يَ؛ عَلَ قَن عِسِرَيِلَ بّ،
\q1 عَ قَن مِشِيٍ بّ نَشٍيٍ سٌندٌنيِ سّنِيّنشِ.
\b
\q1 
\v 2 عَ فبٍ مُ نُ لُشِ ﭑ تَن يَتِ شَ بَ كِرَ مَ،
\q1 ﭑ سَنيِيٍ شَ بِرَ كِرَ فبّتّ قْشْ رَ.
\q1 
\v 3 ﭑ نُ يّتّ عِفبٌي تْونّمَ،
\q1 ﭑ تٌ عَ تٌ مِشِ حَاشِيٍ قِندِشِ نَاقُلِ كَنيِيٍ رَ.
\q1 
\v 4 سٍسٍ مُ عٍ عِقُمَ هَن عٍ شَ قَشّ، عٍ قَتٍ يَلَنشِ تُن.
\q1 
\v 5 عٍ مُ عَدَ مَدِيٍ شَ تْورّ كٌلٌن،
\q1 عٍ مُ حَشَنكَتَشِ عَلْ بٌورٍيٍ.
\b
\q1 
\v 6 يّتّ عِفبٌحَ قِندِشِ شُنمَسٍ نَن نَ عٍ بّ،
\q1 عٍ مِشِ تْورْ مَ لْشْ يٌ لْشْ.
\q1 
\v 7 عٍ عٍ يَ تِمَ سٍ بِرِن نَ،
\q1 عٍ وَشْنقٍ بَرَ دَنفِ عَ عِ.
\q1 
\v 8 عٍ يٌمَ مِشِ مَ،
\q1 عٍ قٍ حَاشِ حَنِفٍمَ يّتّ عِفبٌحَ كُي.
\q1 
\v 9 عٍ عَلَ قٍ مَبٍرٍ مَ، عٍ دّ مُ دِكِمَ سٍسٍ قَلَقٍ رَ دُنِحَ مَ.
\b
\q1 
\v 10 نَ نَن عَ رَ، عَلَ شَ حَمَ عَ شُن تِمَ عٍ رَ،
\q1 عٍ لَ عٍ شَ وْيّنيِيٍ رَ.
\q1 
\v 11 عٍ نَشّ، «عَلَ تَن وٌن حّرّ كِ كٌلٌنمَ دِ؟
\q1 قَهَامُي مُندُن نَ عَ بّ؟»
\q1 
\v 12 مِشِ حَاشِيٍ نَ نَ كِ نّ.
\q1 عٍ بْحّ سَشِ نَاقُلِ يِرِوَقٍ كُي.
\b
\q1 
\v 13 ﭑ حْشْ عَ مَ، «ﭑ نَن ﭑ بْحّ رَ سّنِيّنشِ نّ قُ.
\q1 ﭑ فبِلٍنقٍ قٍ كٌبِيٍ قْشْ رَ، نَ مُ قَنشِ ﭑ بّ.
\q1 
\v 14 ﭑ حَشَنكَتَشِ تّمُي بِرِن،
\q1 لْشْ يٌ لْشْ ندٍ سَمَ ﭑ مَ كٌتٍ شُن.»
\q1 
\v 15 شَ ﭑ سَ نَ مْولِ قَلَ نُ،
\q1 ﭑ بَرَ يَنقَنتٍيَ رَبَ عِ شَ دِيٍ رَ نُ.
\b
\q1 
\v 16 عَوَ، ﭑ نَشَ قَهَامُي قٍن يِ قٍ مَ.
\q1 نَ نُ شْرْشْ ﭑ بّ،
\q1 
\v 17 هَن ﭑ سٌ لْشْي عَلَ شَ هْرْ مْلِنفِرَ كُي،
\q1 ﭑ قَ عَ مَحْشُن قٍ نَشَن قٍ كٌبِ رَبَيٍ لِمَ.
\q1 
\v 18 عِ عٍ تِمَ كِرَ سَلَشُنشِ نَن شْن مَ،
\q1 عِ قَ عٍ شُن نَكَنَ.
\q1 
\v 19 عٍ شَ قٍ حْنمَ كٍرٍنيِ نَن نَ، قٍ مَفَاشُشِ عٍ شَنِنمَ نّ.
\q1 
\v 20 مَرِفِ، عَلْ شِيٍ دَنفِمَ كِ نَشّ مِشِ شُنُ تّمُي،
\q1 عِ نَ كٍلِ، عٍ قَن شَ قٍ بَمَ عِ يَ عِ نَ كِ نّ.
\b
\q1 
\v 21 ﭑ بْحّ تٌ نُ مَحَاشُمَ،
\q1 عَ نُ لُشِ نّ ﭑ بّ عَلْ تَنبّ نَن ﭑ سْشْمَ.
\q1 
\v 22 دَشُي نَن نُ ﭑ نَ، ﭑ مُ نُ سٍسٍ قَهَامُشِ.
\q1 ﭑ نُ لُشِ نّ عَلْ شُرُ سٍ شَشِلِتَرٍ عِ يَ عِ.
\q1 
\v 23 كْنْ هَن يَ ﭑ نَ عِ سّيتِ مَ،
\q1 ﭑ يِرٍقَنيِ بّلّشّ سُشُشِ عِ يِ رَ.
\q1 
\v 24 عِ ﭑ نَحّرّ مَ عِ شَ مَرَ سِ رَ،
\q1 عِ مَن ﭑ نَسّنّمَ نّ عِ شَ نْرّ كُي.
\q1 
\v 25 ندٍ فبّتّ نَ ﭑ يِ رَ كٌورٍ مَ؟
\q1 بَ عِ تَن نَ، سٍسٍ فبّتّ شْلِ مُ ﭑ مَ يِ دُنِحَ مَ.
\q1 
\v 26 ﭑ قَتٍ نُن ﭑ شَشِلِ تَفَنمَ نّ،
\q1 كْنْ عَلَ ﭑ بْحّ سَمَ نّ عَبَدَن.
\q1 
\v 27 نَشٍيٍ عٍ مَكُيَمَ عِ رَ، بْنْ مِشِ نَن عٍ رَ.
\q1 عِ مِشِيٍ دّ بَلَنمَ، نَشٍيٍ بِرِن عِ قِنسِرِوَلِمَ.
\q1 
\v 28 كْنْ ﭑ مَ هّيرِ قِندِشِ ﭑ مَسٌقٍ نَن نَ عَلَ رَ.
\q1 ﭑ بَرَ مَرِفِ عَلَتَلَ سُفَندِ ﭑ شُن تَشُدٍ رَ،
\q1 عَلَكٌ ﭑ شَ عِ شَ وَلِ قَنيِيٍ بِرِن مَسٍن دُنِحَ بّ.
\c 74
\s1 عَلَ شَ هْرْ مْلِنفِرَ كَنَشِ شَ قٍ
\s2 عَلَ مَشَندِ
\d عَسَقِ شَ لْننِ بّيتِ
\q1 
\v 1 عَلَ، مُنقٍ رَ عِ مُشُ رَبّحِنشِ كٍرٍنيِ رَ؟
\q1 مُنقٍ رَ عِ شَ شْنّ تُرُ مَ عِ شَ حَمَ شِلِ مَ عِ نَشَن نَبَلٌقٍ؟
\q1 
\v 2 عِ شَ رَتُ عِ شَ حَمَ مَ عِ نَشَن شُن سَرَشِ،
\q1 عِ كّ قِمَ نَشَن مَ،
\q1 عِ سَبَتِشِ نَشَن يَ مَ سِيٌن فٍيَ مَ.
\q1 
\v 3 عِ شَ عَ يِرٍ مَتٌ عَ يَشُييٍ نَشَن كَنَشِ،
\q1 عِ شَ عِ شَ هْرْ مْبَنشِ تٌ عٍ نَشَن كَسَرَشِ.
\q1 
\v 4 عِ يَشُييٍ بَرَ عٍ شُي عِتٍ عِ شَ نَرَلَن بَنشِ كُي،
\q1 عٍ بَرَ عٍ شَ قّلّكِيٍ رَتٍ نَا.
\q1 
\v 5 عٍ نُ لُشِ عَلْ بٍيرَ كَنيِ نَشٍيٍ قْتْنيِ سّفّمَ.
\q1 
\v 6 عٍ بَرَ هْرْ مْلِنفِرَ شُنمَسٍيٍ كَنَ بٍيرَ نُن دّرّ مَيٍ رَ،
\q1 
\v 7 عٍ نَا فَن تّ رَ.
\q1 عٍ بَرَ نَ يِرٍ مَبٍرٍ عِ شِلِ سَبَتِشِ دّننَشّ.
\q1 
\v 8 عٍ نُ عَ قَلَمَ نّ عٍ بْحّ مَ، «وٌن شَ عٍ سْنتْ!»
\q1 عٍ بَرَ عَلَ شَ بَتُدٍيٍ بِرِن فَن.
\b
\q1 
\v 9 عِ شَ كَابَنَكٌي مُ تٌمَ،
\q1 نَمِحْنمّيٍ قَن مُ نَ مُشُ يَ مَ كْرّ.
\q1 مُشُ مُ عَ كٌلٌن يِ قٍ بُمَ هَن تّمُي مُندُن.
\q1 
\v 10 عٍٍ عَلَ، يَشُي مَيٍلٍ تِمَ هَن تّمُي مُندُن؟
\q1 دَنيِ مُ نَ عٍ شَ كٌنبِيٍ مَ؟
\q1 
\v 11 مُنقٍ رَ عِ مُ عِ سّنبّ مَفَاشُشِ مَسٍن عٍ بّ؟
\q1 عِ شَ كٍلِ، عِ شَ عٍ سْنتْ!
\b
\q1 
\v 12 كَبِ تّمُي شْنكُيٍ، عَلَ نَن نَ ﭑ مَ مَنفّ رَ،
\q1 عَ تَن نَشَن قِندِشِ شُننَكٍلِ سَابُي رَ دُنِحَ مَ.
\q1 
\v 13 عِ تَن نَن بَا عِبْو عِ سّنبّ رَ،
\q1 عِ دَالِسٍ مَفَاشُشِيٍ شُنيِيٍ عِبُتُشُن نَا.
\q1 
\v 14 عِ تَن نَن عٍ شُنيِيٍ عِبُتُشُن،
\q1 عِ عٍ قِ دٌنسٍ رَ وُلَءِ سُبٍيٍ مَ.
\q1 
\v 15 عِ تَن نَن دُلٌنيِيٍ نُن شُرٍيٍ رَبْو،
\q1 عِ تَن نَن دَبٌنيِيٍ رَشْرِ، نَشٍيٍ مُ دَرِشِ شْرِ رَ.
\q1 
\v 16 يَنيِ نُن كْي قِندِشِ عِ فبٍ نَن نَ،
\q1 كِكٍ نُن سٌفٍ، عِ تَن نَن عٍ دَاشِ.
\q1 
\v 17 عِ تَن نَن بْشِيٍ نَانِنيِيٍ بِرِن سَشِ.
\q1 عِ تَن نَن سٌفٌقُرٍ نُن حّمّ دَا.
\b
\q1 
\v 18 عِ شَ رَتُ عَ مَ عَ مُشُ يَشُييٍ نَ عِ تَن عَلَتَلَ نَن مَبٍرٍقٍ،
\q1 حَمَ شَشِلِتَرٍ نَ عِ شِلِ بّشُقٍ!
\q1 
\v 19 يَندِ، عِ نَشَ عِ شَ حَمَ شَنُشِ رَبٌلٌ
\q1 عَلْ فَنبّ دِ رَبٌلٌمَ سّفّ يِ رَ كِ نَشّ.
\q1 عِ نَشَ نّيمُ عِ شَ مِسِكِينّيٍ مَ.
\q1 
\v 20 عِ شَ عِ حْشْ سَ عِ شَ سَاتّ مَ،
\q1 بَرِ مَ قٍ كٌبِيٍ بَرَ فبٌ يِ بْشِ مَ هَن عَ بَرَ دَنفِ عَ عِ.
\q1 
\v 21 عِ نَشَ تْورْ مِشِيٍ لُ عٍ شَ يَافِ كُي.
\q1 مِسِكِينّيٍ نُن سٍتَرٍيٍ شَ عِ شِلِ مَتْشْ.
\q1 
\v 22 عَلَ، عِ شَ كٍلِ عِ شِلِ شُنمَقَلَقٍ رَ.
\q1 عِ شَ رَتُ شَشِلِتَرٍ شَ مَبٍرٍ مَ.
\q1 
\v 23 عِ نَشَ نّيمُ عِ يَشُييٍ شَ وْيّنيِيٍ مَ،
\q1 عِ نَشَ نّيمُ عِ فٍرٍقَيٍ شَ سْنشْي مَ نَشَن مُ حْنمَ.
\c 75
\s1 عَلَ شَ كِيتِ
\s2 عَلَ مَتْشْي
\d 
\v 1 عَسَقِ شَ بّيتِ بّيتِبَيٍ مَنفّ بّ. عَ شَ بَ عَلْ بّيتِ نَشَن شِلِ «عِ نَشَ كَسَرّ تِ.»
\q1 
\v 2 مُشُ مَرِفِ عَلَ، مُشُ بَرَ عِ مَتْشْ.
\q1 مَتْشْي نَ عِ بّ، عِ تَن نَشَن نَ مُشُ سّيتِ مَ،
\q1 عِ تَن نَشَن شَ كَابَنَكٌي قَلَمَ يِرٍ بِرِن.
\b
\q1 
\v 3 عِ نَشّ، «ﭑ مَ وَشَتِ سُفَندِشِ نَ عَ لِ،
\q1 ﭑ تَن نَن كِيتِ سَمَ تِنشِنيِ رَ.
\q1 
\v 4 دُنِحَ نُن عَ شَ مِشِيٍ قَمَ شُنُدٍ،
\q1 كْنْ ﭑ تَن نَن عَ كِنكِيٍ سّنبّ سٌمَ.
\q1 
\v 5 ﭑ عَ قَلَمَ يّتّ عِفبٌي نُن مِشِ كٌبِيٍ بّ،
\q1 ‹وٌ نَشَ وٌ يّتّ عِفبٌ، وٌ نَشَ وٌ شُنيِ عِتٍ.
\q1 
\v 6 وٌ نَشَ وٌ شُنيِ عِتٍ كٌورٍ مَ،
\q1 وٌ بَ يّتّ عِفبٌحَ وْيّنيِ قَلَقٍ رَ.›»
\b
\q1 
\v 7 وٌ شَ عَ كٌلٌن شُننَكٍلِ مُ كٍلِمَ سٌفٍتٍدٍ،
\q1 عَ مُ كٍلِمَ سٌفٍفٌرٌدٍ، عَ مُ كٍلِمَ فبٍنفبٍرٍنيِ مَ.
\q1 
\v 8 عَلَ نَن كِيتِ سَمَ،
\q1 عَ مِشِ ندٍ شَ قٍ رَفٌرٌ، عَ مِشِ ندٍ شَ قٍ عِتٍ.
\q1 
\v 9 تْنبِلِ ندٍ نَ عَلَتَلَ شْنيّ،
\q1 وّنِ شَاحّ رَقَلَشِ نَ نَشَن كُي.
\q1 عَ نَ سٌمَ دُنِحَ مِشِ حَاشِيٍ نَن يِ،
\q1 عٍ عَ مِن هَن عَ حْن.
\q1 
\v 10 ﭑ نَ مَسٍنيِ تِمَ تّمُي بِرِن،
\q1 ﭑ يَشُبَ مَرِفِ عَلَ مَتْشْمَ بّيتِ رَ.
\b
\q1 
\v 11 «ﭑ مِشِ حَاشِيٍ شَ يّتّ عِفبٌحَ شُن نَكَنَمَ نّ،
\q1 ﭑ تِنشِنتْييٍ شُن نَكٍلِ.»
\c 76
\s1 عَلَ شَ شُننَكٍلِ
\s2 عَلَ مَتْشْي
\d 
\v 1 عَسَقِ شَ بّيتِ بّيتِبَيٍ شَ مَنفّ بّ. عَ شَ بَ كْرَ شُي رَ.
\q1 
\v 2 عَلَ كٌلٌنشِ يُدَيَ بْشِ مَ، عَ شِلِ فبٌ عِسِرَيِلَ.
\q1 
\v 3 عَ شْنيِ نَ سَلَمُ، عَ شَ بَنشِ نَ سِيٌن.
\q1 
\v 4 عَ فٍرٍ سٌسٍيٍ عَلْ شَلِيٍ، وُرٍ لٍقَيٍ، نُن سَنتِدّفّمَيٍ كَنَ مّننِ نّ.
\b
\q1 
\v 5 عِ شَ نْرّ فبٌ عَلْ كٌيِنمَ،
\q1 نَشَن فبِلٍن كٍلِقٍ فٍيَيٍ مَ، سُبٍيٍ وُيَ دّننَشّ.
\q1 
\v 6 عِ بَرَ نْ سّنبّمَيٍ رَ، نَشٍيٍ مُ شُنُمَ سْنْن،
\q1 نَشٍيٍ مُ نْ فٍرٍ تِدٍ عِ كَنكٍ.
\q1 
\v 7 عِ تَن يَشُبَ مَرِفِ عَلَ تٌ كٍلِ عٍ شِلِ مَ،
\q1 عٍ شَ سٌي رَفِيٍ نُن عٍ شَ سٌي نَشَ هَلَكِ.
\q1 
\v 8 عِ مَفَاشُ! عِ شَ شْنّ كُي، ندٍ سُو سَمَ عِ يَ رَ؟
\q1 
\v 9 عِ تٌ كِيتِ سَ كٌورٍ مَ، دُنِحَ نَشَ سَبَرِ فَاشُي كُي.
\q1 
\v 10 عِ شَ كِيتِ نَشَ تْورْ مِشِيٍ رَكِسِ.
\q1 
\v 11 عِ شَ شْنّ عِبُنَدَ مَ مَبِرِ قِندِشِ عِ مَتْشْي نَن نَ.
\q1 عِ شَ بْحّتٍ لُشِ نّ عَلْ بّلّتِ عِ عِ تَفِ عِشِرِ مَ نَشَن نَ فٍرٍ كُي.
\b
\q1 
\v 12 وٌ شَ وٌ شَ دَاكَن نَكَمَلِ وٌ مَرِفِ عَلَتَلَ بّ،
\q1 وٌ شَ قَ سّرّشّيٍ رَ عَ شْن مَ،
\q1 وٌ تَن نَشٍيٍ بِرِن عَ رَبِلِنشِ.
\q1 
\v 13 عَ تَن نَن حّنفِ بَمَ سّنبّمَيٍ قَتٍ عِ،
\q1 عَ مَفَاشُ دُنِحَ مَنفّيٍ بّ.
\c 77
\s1 عَلَ شَ مَرَتَنفّ مُ مَسَرَ مَ
\s2 عَلَ مَشَندِ
\d 
\v 1 عَسَقِ شَ بّيتِ بّيتِبَيٍ شَ مَنفّ يٍدُتُن بّ
\q1 
\v 2 ﭑ نَن ﭑ شُي رَتٍقٍ عَلَ نَن مَ.
\q1 عَ عَ تُلِ مَتِمَ نّ ﭑ شُي رَ.
\q1 
\v 3 لْشْ شْرْشْييٍ نَ قَ ﭑ مَ، ﭑ نَن ﭑ مَرِفِ شِلِمَ نّ.
\q1 كْي رَ، ﭑ نَن ﭑ بّلّشّ عِتَلَ عَ بّ،
\q1 كْنْ ﭑ مُ مَدُندُي سْتْمَ.
\q1 
\v 4 ﭑ نَن ﭑ نَتُ عَلَ مَ، ﭑ وَ ﭑ بْحّ مَ.
\q1 ﭑ نَن ﭑ مَحْشُن عَ مَ، لِمَنِيَ بَ ﭑ يِ.
\b
\q1 
\v 5 عِ مُ تِنمَ ﭑ شَ شِ.
\q1 ﭑ شَشِلِ عِقُشِ، حَن ﭑ مُ نْمَ وْيّندٍ.
\q1 
\v 6 ﭑ نَن ﭑ مَحْشُنمَ وَشَتِ دَنفِشِيٍ مَ.
\q1 
\v 7 ﭑ نَن ﭑ نَتُمَ نٍيٍ مَ ﭑ مَ بّيتِيٍ سَابُي رَ.
\q1 ﭑ نَن ﭑ يّتّ مَشْرِن،
\q1 
\v 8 «ﭑ مَرِفِ مّيمَ نّ عِبُنَدَ مَ رَ عَبَدَن؟
\q1 عَ مُ هِننّمَ مِشِيٍ رَ سْنْن؟
\q1 
\v 9 دَنيِ نَ عَ شَ قَنيِ مَ؟
\q1 عَ تٌندِ مَ عَ شَ لَايِدِيٍ كَمَلِدٍ؟
\q1 
\v 10 عَ بَرَ نّيمُ عَ شَ هِننّ مَ؟
\q1 عَ شَ شْنّ بَرَ نْ عَ شَ كِنِكِنِ رَ؟
\q1 
\v 11 ﭑ مَ تْورّ كُي عَ لُمَ ﭑ بّ
\q1 عَلْ عَلَ شِلِ شُنفبٍ كَنيِ نَ مَسَرَقٍ.»
\b
\q1 
\v 12 عَ لَنمَ ﭑ شَ رَتُ عَلَتَلَ شَ وَلِيٍ مَ،
\q1 عَ شَ كَابَنَكٌي عَ نَشٍيٍ رَبَشِ تّمُي دَنفِشِ.
\q1 
\v 13 ﭑ نَن ﭑ شَشِلِ رَ سِفَمَ نّ عِ شَ كّوَلِ بِرِن مَ،
\q1 ﭑ نَن ﭑ مَحْشُنمَ نّ عِ شَ وَلِيٍ مَ.
\q1 
\v 14 عَلَ، عِ شَ كِرَ سّنِيّن.
\q1 عَلَ فبّتّ مُ نَ، عِ مَنِيّ مُ نَ!
\q1 
\v 15 عِ تَن عَلَ نَن كَابَنَكٌي رَبَمَ،
\q1 عِ قٍ مَفَاشُشِيٍ مَسٍن حَمَنّيٍ تَفِ.
\q1 
\v 16 عِ عِ شَ حَمَ شُن سَرَشِ عِ سّنبّ نَن نَ،
\q1 يَشُبَ نُن يُسُقُ شَ مَمَدِيٍ.
\b
\q1 
\v 17 عَلَ، بَا شُنفبٍ تٌ عِ تٌ،
\q1 عَ دُلٌنيِ نَشَ سّرّن.
\q1 
\v 18 نُشُييٍ نَشَ يٍ فبٍفبٍ رَفٌرٌ،
\q1 فَلَنيِ نَشَ بُلَ كٌورٍ مَ،
\q1 سٍيَمَكْنيِيٍ نَشَ لُ عَلْ تَنبّ وٌلِشِيٍ.
\q1 
\v 19 عِ شَ سَرِنيِ شُي نَشَ بُلَ،
\q1 سٍيَمَكْنيِ نَشَ دُنِحَ عِيَلَن،
\q1 بْشِ نَشَ عَ عِمَشَ، عَ سّرّن.
\q1 
\v 20 عِ نَشَ كِرَ رَبْو بَا مَ،
\q1 عِ دَنفِ يٍ شُنفبٍ تَفِ، كْنْ عِ قْشِ مُ تٌ.
\q1 
\v 21 عِ نَشَ عِ شَ حَمَ رَحّرّ عَلْ شُرُ سٍ فْورّ
\q1 عَننَبِ مُنسَ نُن هَرُنَ سَابُي رَ.
\c 78
\s1 عَلَ نُن عِسِرَيِلَ
\s2 عَلَ مَتْشْي
\d 
\v 1 عَسَقِ شَ لْننِ بّيتِ
\q1 ﭑ مَ حَمَ، وٌ وٌ تُلِ مَتِ ﭑ مَ شَرَنيِ رَ،
\q1 وٌ وٌ، تُلِ مَتِ ﭑ مَ مَسٍنيِ رَ.
\q1 
\v 2 ﭑ مِسَالِ ندٍ قَلَمَ وٌ بّ،
\q1 ﭑ قٍ دَنفِشِيٍ مَدْشْ،
\q1 
\v 3 مُشُ قٍ نَشٍيٍ مّ، مُشُ قٍ نَشٍيٍ كٌلٌن،
\q1 مُشُ بَبَيٍ سَابُي رَ.
\q1 
\v 4 مُشُ مُ نٍيٍ نْشُنمَ عٍ بْنسْييٍ مَ،
\q1 مُشُ عَلَتَلَ شَ مَتْشْي قَلَمَ نّ عٍ شَنبِرَتِيٍ بّ،
\q1 مُشُ عَ سّنبّ نُن عَ شَ كَابَنَكٌي مَسٍنمَ نّ عٍ بّ.
\b
\q1 
\v 5 عَلَ بَرَ يَامَرِيٍ مَسٍن يَشُبَ بّ،
\q1 عَ سّرِيّ سَ عِسِرَيِلَ بْشِ كُي،
\q1 عَ وٌن بٍنبَيٍ يَمَرِ عٍ شَ نَ مَسٍن عٍ شَ دِيٍ بّ،
\q1 
\v 6 عَلَكٌ دِ نَشٍيٍ قَمَ تِنَ، نٍيٍ شَ نْ عَ كٌلٌندٍ،
\q1 عٍ قَن شَ عَ مَسٍن عٍ فبٍ دِيٍ بّ عٍ قَمَ نَشٍيٍ بَرِدٍ.
\q1 
\v 7 نَ كُي عٍ قَمَ عٍ شَ لَنلَنتٍيَ سَدٍ عَلَ مَ،
\q1 عٍ مُ نّيمُمَ عَ شَ وَلِ شُنفبٍيٍ مَ،
\q1 عٍ عٍ حْشْ سَمَ نّ عَ شَ يَامَرِيٍ شْن مَ.
\q1 
\v 8 عٍ مُ لُمَ عَلْ عٍ بٍنبَيٍ،
\q1 نَشٍيٍ تُلِ شْرْشْ، نَشٍيٍ قِندِ مَتَندِلَيٍ رَ،
\q1 نَشٍيٍ تُن مُ رَبّشِ،
\q1 نَشٍيٍ شَشِلِ مُ تِشِ عَلَ كٍرٍن نَ.
\b
\q1 
\v 9 عٍقِرَ مِكَيٍ شَلِ كَنيِيٍ نَشَ عٍ كٌبٍ سٌ فٍرٍ رَ،
\q1 
\v 10 عٍ مُ عَلَ شَ سَاتّ رَكَمَلِ،
\q1 عٍ مُ بِرَ عَ شَ سّرِيّ قْشْ رَ.
\q1 
\v 11 عٍ نَشَ نّيمُ عَ شَ وَلِ مَفَاشُشِيٍ رَ،
\q1 عَ نُن عَ شَ كَابَنَكٌي رَ عَ نَشٍيٍ مَسٍن عٍ بّ.
\q1 
\v 12 عَ كَابَنَكٌ رَبَ نّ عٍ بٍنبَيٍ يَ شْرِ مِسِرَ، سٌوَن قِيلِ مَ.
\q1 
\v 13 عَ نَشَ بَا عِبْو، عَ عٍ رَفِرِ، عَ يٍ رَتِ عَلْ بِلِشِ.
\q1 
\v 14 عَ نَشَ عٍ رَحّرّ نُشُي سَابُي رَ يَنيِ رَ،
\q1 عَ نَشَ عٍ رَحّرّ تّ يَنبّ رَ كْي رَ.
\q1 
\v 15 عَ نَشَ قَنيٍ عِبْو فبٍنفبٍرٍنيِ مَ،
\q1 عَ يٍ فبٍفبٍ رَ مِنِ نَ كُي عَلْ دَبٌنيِ.
\q1 
\v 16 عَ نَشَ يٍ رَ مِنِ فّمّ لٌنفٌرِ رَ، عَ لُ عَلْ شُرٍ.
\b
\q1 
\v 17 كْنْ عٍ مُ فبِلٍن عٍ شَ يُنُبِ رَبَقٍ قْشْ رَ،
\q1 عٍ قَ عَلَ مَتَندِ فبٍنفبٍرٍنيِ مَ.
\q1 
\v 18 عٍ نَشَ عَلَ مَتٌ دٌنسٍيٍ مَشْرِنقٍ رَ.
\q1 
\v 19 عٍ نَشَ عَلَ مَبٍرٍ عَ قَلَقٍ رَ،
\q1 «عَلَ نْمَ وٌن نَبَلٌدٍ يِ فبٍنفبٍرٍنيِ كُي؟
\q1 
\v 20 عَ بَرَ يٍ رَ مِنِ قَنيٍ كُي،
\q1 كْنْ عَ نْمَ تَامِ قَن قِدٍ عٍ مَ؟»
\b
\q1 
\v 21 عَلَ تٌ نَ مّ، عَ نَشَ شْنْ كِ قَنيِ رَ،
\q1 عَ قَ تّ رَدّشّ يَشُبَ شَ حَمَ شِلِ مَ،
\q1 عَ قَ شْنْ عِسِرَيِلَ حَمَ مَ،
\q1 
\v 22 بَرِ مَ عٍ مُ نُ لَشِ عَلَ رَ،
\q1 عٍ مُ عٍ شَشِلِ تِشِ عَ شَ كِسِ رَ.
\q1 
\v 23 نَ كُي عَلَ نَشَ يَامَرِ قِ كٌورٍ نَادّيٍ شَ رَبِ،
\q1 
\v 24 «مَنَ» شَ فٌرٌ عٍ مَ بَلٌي رَ،
\q1 نَشَن قِندِ كٌورٍ تَامِ رَ.
\q1 
\v 25 بِرِن نَشَ نَ سّنبّمَيٍ شَ تَامِ دٌن، عٍ قَ وَ سَ نَ رَ.
\q1 
\v 26 عَلَ نَشَ قٌيٍ رَقَ كٍلِ سٌفٍتٍدٍ بِرِ،
\q1 عَ قٌيٍ رَقَ عَ سّنبّ رَ كٍلِ يِرٍقَنيِ مَ،
\q1 
\v 27 نَشَن عَ نِيَ شْنِيٍ شَ فٌرٌ عٍ مَ
\q1 عَ فبٍفبٍ رَ عَلْ شُبٍ نُن بَا دّ مّيّنيِ.
\q1 
\v 28 عَ نَشَ عٍ فبٍفبٍ رَيٌلٌن عٍ يٌنكِندٍ تَفِ،
\q1 عٍ شَ كِرِ بَنشِيٍ رَبِلِنيِ مَ.
\q1 
\v 29 عٍ نَشَ نَ دٌن هَن عٍ وَ سَ.
\q1 عَلَ نُ بَرَ عٍ هَيِ لِ.
\b
\q1 
\v 30 كْنْ هَلِ عٍ تٌ نُ بَرَ دٌنسٍ سْتْ،
\q1 عَ مُ بُ
\v 31 عَلَ شَ شْنّ مَن نَشَ فٌرٌ عٍ مَ،
\q1 عَ عِسِرَيِلَ سّنبّمَيٍ نُن عٍ قٌنِكٍ قَشَ.
\q1 
\v 32 هَلِ نَ بِرِن تٌ رَبَ، حَمَ مُ تِن فبِلٍندٍ عٍ شَ يُنُبِيٍ قْشْ رَ.
\q1 عٍ مُ لَ عَلَ شَ كَابَنَكٌي رَ.
\q1 
\v 33 نَ كُي عَ نَشَ عٍ لُ عٍ شَ قُيَنتٍ كُي،
\q1 هَن عٍ شَ قٍ نَشَ رَحْن فَاشُي كُي.
\q1 
\v 34 قٌ قَشّ نَ دُتُن عٍ مَ، عٍ قَ سٌ عَلَ قٍنقٍ،
\q1 عٍ عٍ يّتّ رَفبِلٍن عَ مَ،
\q1 
\v 35 عٍ عٍ رَتُ عَ عَلَ نَن عٍ سّنبّ رَ،
\q1 عَ عَلَ شِلِ شُنفبٍ كَنيِ نَن عٍ رَكِسِمَ رَ.
\q1 
\v 36 كْنْ عٍ نُ وَ مَ عَ مَدَشُقٍ عٍ شَ وْيّنيِيٍ نَن نَ،
\q1 عٍ وُلٍ قَلَ عَ بّ عٍ دّ رَ.
\q1 
\v 37 عَ شَ قٍ مُ نُ نَ عٍ بْحّ مَ،
\q1 عٍ مُ نُ بِرَ مَ عَ شَ سَاتّ قْشْ رَ.
\b
\q1 
\v 38 كْنْ عَلَ تٌ قِندِ هِننّنتٍ رَ،
\q1 عَ نَشَ عٍ شَ يُنُبِيٍ شَقَرِ، عَ عٍ حَشَنكَتَقٍ لُ نَا.
\q1 عَ نَشَ دِحّ عٍ مَ سَنيَ وُيَشِ،
\q1 عَ مُ تِن عَ شَ شْنّ بِرِن شَ مِنِ.
\q1 
\v 39 عَ نُ عَ كٌلٌن عَ بّندّ نَن تُن لَنشِ عٍ مَ،
\q1 عٍ حّنفِ نَ دَن، عَ مُ فبِلٍن سْنْن.
\b
\q1 
\v 40 سَنمَيَ يٍرِ عٍ مُرُتَمَ عَ مَ فبٍنفبٍرٍنيِ مَ،
\q1 سَنمَيَ يٍرِ عٍ عَ رَشْنْمَ نَ يِرٍ مَشَرٍ مَ؟
\q1 
\v 41 عٍ نُ لُمَ عَلَ مَتٌ رَ،
\q1 عٍ نُ تِ عِسِرَيِلَ شَ سّنِيّنتْي كَنكٍ.
\q1 
\v 42 عٍ مُ عٍ رَتُ عَ سّنبّ مَ.
\q1 عٍ نّيمُ عَ مَ عَ عٍ رَكِسِ عٍ فٍرٍقَيٍ مَ تّمُي نَشّ.
\q1 
\v 43 عٍ نّيمُ عَ شَ تْنشُمَيٍ مَ عَ نَشٍيٍ مَسٍن مِسِرَ بْشِ مَ.
\q1 عٍ نّيمُ عَ شَ كَابَنَكٌي مَ عَ نَشٍيٍ رَبَ سٌوَن قِيلِ مَ.
\q1 
\v 44 عَ نَشَ عٍ شَ نِلِ شُرٍ نُن عَ سَلٌنيِيٍ قِندِ وُلِ رَ
\q1 هَن عٍ مُ نْ نَ يٍ مِندٍ.
\q1 
\v 45 عَ نَشَ شّيرِيٍ رَدِن عٍ مَ عٍ هَلَكِقٍ رَ.
\q1 عَ نَشَ لَنشَنسَرِ مَيٍ مَلَن مّننِ عٍ كَسَرَقٍ رَ.
\q1 
\v 46 عَ نَشَ تُفُمِيٍ رَدِن عٍ شَ شّيٍ مَ،
\q1 كَتٌي نَشَ شّ بٌفِ دٌن فبِكِ.
\q1 
\v 47 عَ نَشَ عٍ شَ وّنِ سَنسِيٍ كَنَ بَلَبَلَنيِ رَ،
\q1 عَ نَشَ عٍ شَ سِكٌمٌرٌ بِلِيٍ تُشُنسَن تُنّ شِنبٍلِ رَ.
\q1 
\v 48 بَلَبَلَنيِ نَشَ عٍ شَ شُرُ سٍيٍ قَشَ،
\q1 فَلَنيِ نَشَ عٍ شَ فْورّيٍ سْنتْ.
\q1 
\v 49 عَ نَشَ عَ شَ شْنّ شْرْشْي رَ مِنِ عٍ مَ،
\q1 عَ بْحّ نَشَ تٍ عٍ مَ،
\q1 هَن عَ نَشَ مَلٍكّ كَسَرَتِيٍ رَفٌرٌ عٍ شِلِ مَ.
\q1 
\v 50 عَ نَشَ عَ شَ شْنّ قُلُن عٍ مَ،
\q1 عَ مُ عٍ نِي رَتَنفَ قَشّ مَ، عَ قٍ شْرْشْييٍ رَدِن عٍ مَ.
\q1 
\v 51 عَ نَشَ مِسِرَ دِ سِنفٍ بِرِن قَشَ،
\q1 عٍ هَمِ بْنسْييٍ قٌنِكٍ بِرِن قَشَ.
\b
\q1 
\v 52 نَ نَن عَ رَ عَ نَشَ عَ شَ حَمَ رَ مِنِ عَلْ يّشّي فْورّ،
\q1 عَ نَشَ عٍ رَحّرّ عَلْ شُرُ سٍيٍ فبٍنفبٍرٍنيِ مَ.
\q1 
\v 53 عَ نَشَ عٍ شَنِن بْحّسَ كُي فَاشُي يٌ مُ عٍ سْتْ،
\q1 كْنْ عَ نَشَ عٍ يَشُييٍ مَدُلَ بَا مَ.
\q1 
\v 54 نَ كِ، عَ نَشَ عٍ شَنِن عَ شَ بْشِ سّنِيّنشِ مَ،
\q1 عَ شَ فٍيَ عَ نَشَن سْتْ عَ سّنبّ رَ.
\q1 
\v 55 عَ نَشَ بْنسْييٍ كٍرِ عٍ يَ رَ،
\q1 عَ قَ نَ بْشِيٍ عِتَشُن عِسِرَيِلَ بْنسْييٍ مَ كّ رَ،
\q1 عَ مّننِ قِندِ عٍ سَبَتِدٍ رَ.
\b
\q1 
\v 56 كْنْ عٍ مَن نَشَ فٍرٍفِرِ عَلَ شِلِ شُنفبٍ كَنيِ مَ،
\q1 عٍ تٌندِ عَ شَ يَامَرِيٍ رَبَتُدٍ.
\q1 
\v 57 عٍ نَشَ عٍ مَكُيَ عَلَ رَ،
\q1 عٍ قِندِ يَنقَنتٍ رَ عَلْ عٍ بٍنبَيٍ عَ رَبَشِ كِ نَشّ،
\q1 عٍ لُ عَلْ شَلِ كَنَشِ.
\q1 
\v 58 عٍ نَشَ عَ رَشْنْ عٍ شَ كُيٍ بَتُدٍيٍ رَ،
\q1 عٍ عَ رَتْونّ عٍ شَ وُرِ مَسٌلِشِيٍ رَ.
\q1 
\v 59 عَلَ تٌ نَ قٍ مّ، عَ نَشَ شْنْ كِ قَنيِ، عَ عِسِرَيِلَ رَبٌلٌ.
\q1 
\v 60 عَ نَشَ عَ شَ لِنفِرَ رَبّحِن سِلٌ،
\q1 عَ نُ نَشَن تِشِ مِشِيٍ تَفِ.
\q1 
\v 61 عَ نَشَ عَ شَ سَاتّ كَنكِرَ لُ يَشُي سَفٌي،
\q1 عٍ كَنكَن عَ شَ نْرّ شَ تْنشُمَ مَ.
\q1 
\v 62 عَ تٌ شْنْ عَ شَ حَمَ عِسِرَيِلَ مَ،
\q1 عَ نَشَ عَ نِيَ عٍ شَ سْنتْ سَنتِدّفّمَ رَ.
\q1 
\v 63 عٍ شَ قٌنِكٍيٍ نَشَ فَن تّ رَ،
\q1 عٍ شَ فِنّدِ مّدِيٍ مُ مَتْشْي سْتْ،
\q1 
\v 64 عٍ شَ سّرّشّدُبّيٍ نَشَ قَشَ سَنتِدّفّمَ رَ،
\q1 عٍ شَ كَاحّ فِنّيٍ قَن مُ وَ.
\b
\q1 
\v 65 مَرِفِ نَشَ كٍلِ
\q1 عَلْ مِشِ نَشَن كٍلِشِ شِ شْلِ مَ،
\q1 عَلْ سْورِ نَشَن نْمَ عَ شَ سِيسِ رَ.
\q1 
\v 66 عَ نَشَ عَ يَشُييٍ بْنبْ،
\q1 عَ عٍ لُ يَافِ كُي نَشَن مُ حْنمَ.
\q1 
\v 67 عَ نَشَ يُسُقُ بْنسْي رَبّحِن،
\q1 عَ تٌندِ عٍقِرَ مِ بْنسْي سُفَندِدٍ.
\q1 
\v 68 عَ نَشَ يُدَ بْنسْي سُفَندِ،
\q1 عَ نُن سِيٌن فٍيَ نَشَن نُ رَقَنشِ عَ مَ.
\q1 
\v 69 عَ نَشَ عَ شَ هْرْ مْلِنفِرَ تِ عَلْ يِرٍ عِتٍشِ،
\q1 عَلْ عَ دُنِحَ تِشِ كِ نَشّ، عَ شَ بُ شْنكُيٍ رَ.
\q1 
\v 70 عَ نَشَ عَ شَ كٌنيِ دَوُدَ سُفَندِ،
\q1 عَ عَ تٌنفٌ فْورّ يَ مَ،
\q1 
\v 71 عَ نُ مّينِقٍ يّشّي مَ دّننَشّ،
\q1 عَلَكٌ عَ شَ مّينِ عَلَ شَ حَمَ مَ،
\q1 نَشَن قِندِشِ يَشُبَ بْنسْي عِسِرَيِلَ رَ.
\q1 
\v 72 دَوُدَ نَشَ مّينِ عٍ مَ عَ بْحّ قِيشّ رَ،
\q1 عَ عٍ مَسُشُ شَشِلِمَيَ رَ.
\c 79
\s1 عَلَ فبٍحْشْقٍ
\s2 عَلَ مَشَندِ
\d 
\v 1 عَسَقِ شَ بّيتِ
\q1 عَلَ، سِيٍ بَرَ سٌ عِ شَ بْشِ كُي،
\q1 عٍ عِ شَ هْرْ مْلِنفِرَ قِندِ يِرٍ سّنِيّنتَرٍ رَ،
\q1 عٍ دَرِ سَلَمُ كَنَ.
\q1 
\v 2 عٍ بَرَ عِ شَ كٌنيِيٍ قُرٍيٍ قِندِ شْنِيٍ شَ بَلٌي رَ،
\q1 عٍ بَرَ عِ شَنُنتٍنيِيٍ سٌ وُلَءِ سُبٍ يِ رَ.
\q1 
\v 3 عٍ بَرَ عٍ سْنتْ دَرِ سَلَمُ رَبِلِنيِ، عٍ مُ رَفَتَ.
\q1 
\v 4 سِ نَشٍيٍ نَ مُشُ رَبِلِنيِ عٍ مُشُ كٌنبِمَ،
\q1 عٍ يٌمَ مُشُ مَ.
\b
\q1 
\v 5 عَلَتَلَ، عِ شْنْمَ نّ مُشُ مَ عَبَدَن؟
\q1 عِ شَ تْونّ دَنمَ مُن تّمُي؟
\q1 
\v 6 عِ شَ شْنْ حَمَنّيٍ مَ نَشٍيٍ مُ عِ كٌلٌن،
\q1 عِ شَ شْنْ مَنفّيَيٍ مَ نَشٍيٍ مُ عِ بَتُمَ،
\q1 
\v 7 بَرِ مَ عٍ بَرَ عِسِرَيِلَ شُن نَكَنَ،
\q1 عٍ بَرَ عَ شَ لِنفِرَ رَبِرَ.
\q1 
\v 8 عِ نَشَ رَتُ مُشُ شَ يُنُبِ دَنفِشِيٍ مَ.
\q1 عِ شَ هِننّ مُشُ رَ مَقُرٍن،
\q1 بَرِ مَ سّنبّ يٌ مُ نَ مُشُ بّ سْنْن.
\q1 
\v 9 كَقُ مُشُ مَ، مُشُ رَكِسِمَ عَلَ،
\q1 عِ شِلِ شَ نْرّ شَ قٍ رَ.
\q1 عِ شَ مُشُ رَكِسِ،
\q1 عِ شَ مُشُ شَ يُنُبِيٍ شَقَرِ عِ شِلِ شَ قٍ رَ.
\q1 
\v 10 مُنقٍ رَ حَمَنّيٍ عَ قَلَمَ،
\q1 «عٍ مَرِفِ عَلَ نَ مِندٍن؟»
\q1 عٍ شَ عَ كٌلٌن عِ قَمَ عِ شَ كٌنيِيٍ وُلِ فبٍحْشْدٍ مُشُ يَ شْرِ.
\q1 
\v 11 عِ شَ عِ تُلِ مَتِ فٍيلِمَنِيٍ وَ شُي رَ،
\q1 عِ سّنبّ شَ نٍيٍ رَكِسِ نَشٍيٍ شَ كِيتِسَيٍ وَ مَ عٍ قَشَقٍ.
\q1 
\v 12 ﭑ مَرِفِ، عِ شَ سَرٍ دْشْ سٌلٌقٍرٍ رَفبِلٍن نَ سِيٍ مَ،
\q1 نَشٍيٍ بَرَ عِ بّشُ.
\q1 
\v 13 نَ كُي، مُشُ تَن عِ شَ حَمَ قَن قَمَ نّ عِ بَتُدٍ،
\q1 مُشُ تَن عِ شَ شُرُ سٍيٍ قَمَ نّ عِ شَ مَتْشْي مَسٍندٍ مُشُ بْنسْي بّ عَبَدَن.
\c 80
\s1 عَلَ مّينِقٍ عَ شَ سَنسِيٍ مَ
\s2 عَلَ مَشَندِ
\d 
\v 1 عَسَقِ شَ بّيتِ بّيتِبَيٍ شَ مَنفّ بّ. عَ شَ بَ عَلْ بّيتِ نَشَن شِلِ «قُفٍ تٌقَنيِيٍ عَلْ عَلَ شَ سَاتّ.»
\q1 
\v 2 عِسِرَيِلَ كَنتَمَ، عِ عِ تُلِ مَتِ ﭑ نَ،
\q1 عِ تَن نَشَن يُسُقُ بْنسْي رَحّرّ مَ عَلْ شُرُ سٍ فْورّ.
\q1 عِ شَ عِ شَ نْرّ مَسٍن،
\q1 عِ تَن نَشَن مَفٌرٌشِ مَلٍكّ مَسٌلِشِيٍ تَفِ.
\q1 
\v 3 عِ سّنبّ رَ مِنِ عٍقِرَ مِ، بُنيَمِن، نُن مَنَسِ بْنسْي يَ عِ،
\q1 عِ شَ مُشُ رَكِسِ.
\q1 
\v 4 عَلَ، عِ شَ مُشُ رَفبِلٍن،
\q1 عِ شَ هِننّ مُشُ رَ عَلَكٌ مُشُ شَ كِسِ سْتْ.
\b
\q1 
\v 5 مَنفّ عَلَ، عِ تٌندِ مَ عِ شَ حَمَ شَ مَشَندِ سُشُدٍ
\q1 عِ شَ شْنّ شَ قٍ رَ هَن مُن تّمُي؟
\q1 
\v 6 عِ عٍ رَبَلٌمَ عٍ يَيٍ رَ،
\q1 عِ عٍ يَيٍ قِمَ عٍ مَ مِنسٍ رَ هَن مُن تّمُي؟
\q1 
\v 7 عِ بَرَ لَنتَرٍيَ رَ سٌ مُشُ نُن مُشُ دْشْبٌورٍيٍ تَفِ،
\q1 عٍ يٌمَ مُشُ مَ.
\q1 
\v 8 مَنفّ عَلَ، عِ شَ مُشُ رَفبِلٍن،
\q1 عِ شَ هِننّ مُشُ رَ عَلَكٌ مُشُ شَ كِسِ سْتْ.
\b
\q1 
\v 9 عِ وّنِ بِلِ ندٍ تَلَ نّ مِسِرَ نَشَن قِندِشِ عِ شَ حَمَ رَ.
\q1 عِ نَشَ سِيٍ ندٍيٍ كٍرِ يِرٍ ندٍ، عِ قَ عَ تَن سِ نَا.
\q1 
\v 10 عِ تٌ نَ يِرٍ يَءِلَن عَ بّ،
\q1 عَ نَشَ عَ سَنكٍيٍ مَسْرْن، عَ بْشِ رَقٍ.
\q1 
\v 11 فٍيَيٍ نَشَ لُ عَ شَ نِينِ بُن مَ،
\q1 عَ سَلٌنيِيٍ نُ شُنفبٌ عَلْ سّدِرِ وُرِيٍ.
\q1 
\v 12 عَ سَلٌنيِيٍ نُ كُيَ رَ هَن عٍ بَا نُن شُرٍ دّ لِ.
\q1 
\v 13 كْنْ عِ تَن بَرَ عَ شَ تّتّ كَنَ،
\q1 دَنفِ مِشِيٍ قَ عَ بٌفِ بَ.
\q1 
\v 14 وُلَءِ شْسّيٍ نَا يٍفٍلٍنمَ،
\q1 بُورُنيِ سُبٍيٍ قَن بَلٌمَ عَ بٌفِيٍ رَ. مُنقٍ رَ؟
\b
\q1 
\v 15 مَنفّ عَلَ يَندِ، عِ شَ فبِلٍن قَ رَ،
\q1 عِ يَ رَفٌرٌ مُشُ مَ كٍلِ كٌورٍ،
\q1 عِ مُشُ مَتٌ، كِنِكِنِ نَ وّنِ بِلِ مَ،
\q1 
\v 16 عِ نَشَن سِ عِ يّتّ بّ عِ بّلّشّ رَ.
\q1 
\v 17 يَكْسِ عَ بَرَ فَن، عَ سّفّ عِ شَ شْنّ سَابُي رَ.
\q1 
\v 18 عِ بّلّشّ شَ لُ عَدَ مَ شَ دِ مَ، نَشَن نَ عِ يِرٍقَنيِ مَ،
\q1 عِ نَشَن شُن نَكٍلِشِ.
\q1 
\v 19 مُشُ مُ مُشُ مَكُيَمَ عِ رَ سْنْن.
\q1 عِ شَ كِسِ قِ مُشُ مَ عَلَكٌ مُشُ مَن شَ عِ بَتُ.
\q1 
\v 20 مَنفّ عَلَ، عِ شَ مُشُ رَفبِلٍن،
\q1 عِ شَ هِننّ مُشُ رَ عَلَكٌ مُشُ شَ كِسِ سْتْ.
\c 81
\s1 تُلِ مَتِقٍ عَلَ مَ
\s2 عَلَ مَشَندِ
\d 
\v 1 عَسَقِ شَ بّيتِ بّيتِبَيٍ شَ مَنفّ بّ. عَ شَ بَ مَشَسٍ لُوتِ دَاشِ شُي رَ.
\q1 
\v 2 وٌ شَ سّيوَ شُي رَتٍ عَلَ مَ،
\q1 نَشَن قِندِشِ وٌن سّنبّ رَ.
\q1 وٌ وٌ شُي رَ سِفَ يَشُبَ مَرِفِ عَلَ مَ.
\q1 
\v 3 وٌ شَ بّيتِ بَ مَشَسٍ نُن كْرَ شُي رَ.
\q1 
\v 4 وٌ شَ قٍرِ قٍ كِكٍ نّينّ تٍ تّمُي،
\q1 وٌن مَ سَلِ لْشْي نَ عَ رَ.
\q1 
\v 5 نَ قِندِشِ عَلَ شَ سّرِيّ نَن نَ عِسِرَيِلَ بّ،
\q1 يَشُبَ مَرِفِ عَلَ شَ يَامَرِ نَ عَ رَ.
\q1 
\v 6 يَامَرِ نَ عَ رَ عَلَ نَشَن سٌ يُسُقُ بْنسْي يِ رَ،
\q1 عَ تٌ مِنِ مِسِرَ بْشِ شِلِ مَ.
\b
\q1 ﭑ نَشَ شُي ندٍ مّ ﭑ مُ نَشَن كٌلٌن، عَ نَشّ،
\q1 
\v 7 «ﭑ بَرَ كٌتٍ بَ عٍ شُن مَ،
\q1 ﭑ بَرَ دٍبٍ بِنيٍ بَ عٍ بّلّشّيٍ.
\q1 
\v 8 وٌ تٌ ﭑ شِلِ وٌ شَ حَشَنكَتّ كُي،
\q1 ﭑ نَشَ وٌ رَكِسِ، ﭑ نَشَ وٌ يَابِ كٍلِقٍ سٍسَرِنيِ يِرٍ،
\q1 ﭑ نَشَ وٌ مَتٌ مٍرِبَ يٍ يِرٍ.
\q1 
\v 9 ﭑ مَ حَمَ عِسِرَيِلَ، وٌ وٌ تُلِ مَتِ ﭑ مَ مَرَ سِ رَ.
\q1 
\v 10 وٌ نَشَ عَلَ فبّتّ بَتُ،
\q1 وٌ نَشَ وٌ شِنبِ سِن عَلَ فبّتّ مَ.
\q1 
\v 11 ﭑ تَن نَن نَ وٌ مَرِفِ عَلَ رَ،
\q1 نَشَن وٌ رَ مِنِ مِسِرَ بْشِ رَ.
\q1 وٌ وٌ دّ رَبِ عَ بٍلٍبٍلٍ رَ، ﭑ عَ رَقٍمَ نّ.»
\b
\q1 
\v 12 «كْنْ ﭑ مَ حَمَ مُ عَ تُلِ مَتِشِ ﭑ نَ،
\q1 عِسِرَيِلَ مُ ﭑ شُي رَتِنمّ.
\q1 
\v 13 نَ كُي ﭑ نَشَ عٍ لُ عٍ شَ بْحّ شْرْشْيَ كُي،
\q1 عٍ شَ حّرّ عٍ يّتّ شَشِلِ مَ.
\q1 
\v 14 شَ عَ سَ لِ نُ ﭑ مَ حَمَ نَشَ عَ تُلِ مَتِ ﭑ نَ،
\q1 شَ عِسِرَيِلَ سَ تِن ﭑ مَ كِرَ رَ نُ،
\q1 
\v 15 ﭑ قَمَ نّ عَ يَشُي بِرِن نَيَافِدٍ كٍرٍن نَ،
\q1 ﭑ عٍ رَفٌرٌ تّمُي بِرِن.
\q1 
\v 16 عَلَتَلَ يَشُييٍ قَمَ فَاشُدٍ عَ يَ رَ،
\q1 عٍ هَلَكِ عَبَدَن.
\q1 
\v 17 كْنْ ﭑ وٌ تَن بَلٌمَ نّ دٌنسٍ قَنيِ رَ،
\q1 ﭑ كُمِ رَ مِنِمَ نّ فّمّ كُي وٌ بّ.»
\c 82
\s1 عَلَ شَ كِيتِ عَ شَ سّنبّمَيٍ بّ
\s2 عَلَ مَتْشْي
\d 
\v 1 عَسَقِ شَ بّيتِ
\q1 عَلَ تِشِ عَ شَ مَلَنيِ يَ رَ،
\q1 عَ كِيتِ سَقٍ كٌورٍ سّنبّمَيٍ يَ مَ.
\q1 
\v 2 «وٌ كِيتِ سَمَ كٌبِحَ رَ هَن مُن تّمُي؟
\q1 وٌ نْندِ قِمَ مِشِ حَاشِيٍ مَ مُنقٍ رَ؟
\q1 
\v 3 وٌ شَ مِسِكِينّيٍ نُن كِرِدِيٍ شَ كِيتِ سَ سّرِيّ كِ مَ.
\q1 وٌ شَ سٍتَرٍيٍ نُن قُشَرِلَيٍ رَتَنفَ كِيتِ حَاشِ مَ.
\q1 
\v 4 وٌ شَ سٍتَرٍيٍ نُن تْورْ مِشِيٍ رَكِسِ.
\q1 وٌ شَ عٍ بَ مِشِ كٌبِيٍ بّلّشّيٍ عِ.»
\b
\q1 
\v 5 كْنْ عٍ مُ قَهَامُي سْتْ نَ قٍقٍ مَ.
\q1 عٍ عٍ حّرّ مَ دِ مِ نَن كُي تُن.
\q1 دُنِحَ سَنبُنيِ بِرِن سّرّنمَ.
\q1 
\v 6 ﭑ عَ قَلَ نّ، «كٌورٍ سّنبّمَيٍ نَن وٌ رَ،
\q1 عَلَ شِلِ شُنفبٍ كَنيِ شَ دِيٍ نَن وٌ بِرِن نَ،
\q1 
\v 7 كْنْ وٌ قَشَمَ نّ عَلْ عَدَ مَدِيٍ،
\q1 وٌ بِرَ مَ نّ عَلْ دُنِحَ مَنفّيٍ.»
\b
\q1 
\v 8 عِ تَن عَلَ، كٍلِ، عِ شَ دُنِحَ مَكِيتِ،
\q1 بَرِ مَ عِ تَن نَن فبٍ نَ سِيٍ بِرِن نَ.
\c 83
\s1 عِسِرَيِلَ يَشُييٍ
\s2 عَلَ مَشَندِ
\d 
\v 1 عَسَقِ شَ بّيتِ
\q1 
\v 2 عٍٍ عَلَ، عِ نَشَ عِ سَبَرِ!
\q1 عَلَ، عِ نَشَ لُ دُندُي كُي،
\q1 
\v 3 بَرِ مَ عِ يَشُييٍ مُ عٍ رَشَرَشِ،
\q1 عِ شْنمَيٍ بَرَ عٍ شُنيِيٍ عِكٍلِ.
\q1 
\v 4 عٍ نَ يَنقّ شْرْشْي مَشِرِقٍ عِ شَ حَمَ شِلِ مَ،
\q1 عٍ نَ عٍ بٌورٍ بْحّ رَتٍقٍ عِ شَنُنتٍنيِيٍ شِلِ مَ.
\q1 
\v 5 عٍ نَشّ، «وٌن شَ عٍ شِلِ حْن سِيٍ يَ مَ،
\q1 عَلَكٌ بِرِن شَ نّيمُ عِسِرَيِلَ شِلِ مَ.»
\q1 
\v 6 عٍ بَرَ لَن عٍ بٌورٍ مَ عِ شِلِ مَ.
\q1 
\v 7 عٍدٌنكَيٍ، سُمَيِلَ بْنسْي، مٌوَبَكَيٍ، هَفَرِكَيٍ،
\q1 
\v 8 فٍبَلَكَيٍ، عَمٌنِكَيٍ، عَمَلّكِكَيٍ،
\q1 قِلِسِتَكَيٍ، تِرٍكَيٍ،
\q1 
\v 9 نُن عَسِرِيَكَيٍ بِرِن بَرَ كَقُ لٌتِ بْنسْي مَ.
\b
\q1 
\v 10 عِ شَ عٍ بْنبْ عَلْ عِ عَ رَبَ مَدِيَنكَيٍ رَ كِ نَشّ.
\q1 عِ شَ عٍ بْنبْ عَلْ عِ عَ رَبَ مَنفّ يَبِنِ نَ كِ نَشّ،
\q1 عَ نُن عَ شَ سْورِ مَنفّ سِسٍرَ رَ كِ نَشّ كِسٌن شُرٍ يِرٍ.
\q1 
\v 11 عٍ سْنتْ نّ عٍندٌرِ،
\q1 عٍ قُرٍ نَشَ لُ بْشِ مَ، عٍ مُ رَفَتَ.
\q1 
\v 12 عِ شَ قٍ شْرْشْي رَبَ عٍ شَ كُنتِفِيٍ رَ،
\q1 عَلْ عِ رَبَ عٌرٍبِ نُن سٍيبِ رَ كِ نَشّ.
\q1 عٍ شَ يَرٍرَتِيٍ شَ لُ عَلْ سّبَ نُن سَلَمُنَ، نَشٍيٍ عَ قَلَ،
\q1 
\v 13 «وٌن شَ عَلَ شَ حَمَ شَ بْشِ قِندِ وٌن فبٍ رَ.»
\q1 
\v 14 ﭑ مَرِفِ عَلَ، عِ شَ نَ مِشِيٍ لُ عَلْ سّشّ، قٌيٍ نَشَن شَنِنمَ.
\q1 
\v 15 عِ شَ عٍ شُن نَكَنَ عَلْ تّ قْتْنيِ فَنمَ كِ نَشّ فٍيَيٍ قَرِ.
\q1 
\v 16 عِ شَ بِرَ عٍ قْشْ رَ شْنّ كُي عَلْ تُرُننَادّ مَفَاشُشِ.
\q1 
\v 17 مَرِفِ، عِ شَ عٍ رَيَافِ عَلَكٌ عٍ شَ فبِلٍن عِ مَ.
\q1 
\v 18 يَافِ نُن فَاشُي شَ لُ عٍ بْحّ مَ،
\q1 عِ شَ عٍ بْنسْي رَحْن عَبَدَن.
\q1 
\v 19 عٍ شَ عَ كٌلٌن عَ عِ تَن نَن شِلِ عَلَتَلَ،
\q1 عَ عَلَ شِلِ شُنفبٍ كَنيِ نَ عِ تَن نَن نَ دُنِحَ شُن نَ.
\c 84
\s1 سِفَقٍ رَ سَلِدٍ شُنفبٍ
\s2 عَلَ مَتْشْي
\d 
\v 1 كٌرَ شَ دِيٍ شَ بّيتِ بّيتِبَيٍ شَ مَنفّ بّ. عَ شَ بَ مَشَسٍ لُوتِ دَاشِ شُي رَ.
\q1 
\v 2 مَنفّ عَلَتَلَ، عِ شَ لِنفِرَ تٌقَن!
\q1 
\v 3 ﭑ وَ مَ سٌقٍ عِ شَ تّتّ كُي ﭑ بْحّ بِرِن نَ.
\q1 نَ وَشْنيِ مِنِمَ ﭑ دّ عِ عِ تَن عَلَ نَن بّ، عِ تَن نَشَن حِحّ عَ رَ.
\q1 
\v 4 هَلِ شْنِ شُنشُرِيٍ عَلْ تُرُننَ نُن دٍبٍلِنيِ
\q1 عٍ تّي سَمَ عِ شَ سّرّشّبَدٍ سّيتِ مَ عٍ شَ دِيٍ لُمَ دّننَشّ.
\q1 عِ تَن عَلَتَلَ سّنبّمَ، ﭑ مَ مَنفّ نُن ﭑ مَرِفِ،
\q1 
\v 5 سّيوّ نَ مِشِيٍ بّ، نَشٍيٍ سَبَتِشِ عِ شَ بَنشِ كُي.
\q1 عٍ لُمَ عِ مَتْشْ رَ دّننَشّ عَبَدَن. \qs حّنفِ رَتٍ.\qs*
\q1 
\v 6 سّيوّ نَ مِشِيٍ بّ نَشٍيٍ سّنبّ لَنشِ عِ تَن عَلَ مَ،
\q1 نَشٍيٍ كِرَ سُشُشِ سِفَقٍ رَ سَلِدٍ شُنفبٍ.
\q1 
\v 7 عٍ بَكَ فُلُنبَ عِفِرِ مَ تّمُي نَشّ،
\q1 عٍ يٍ دُلٌنيِيٍ تٌ نّ، تُنّ يٍ فبٍفبٍ بَرَ نَا رَقٍ.
\q1 
\v 8 عٍ كٍلِ يِرٍ قَنيِ ندٍ، عٍ سِفَ يِرٍ قَنيِ فبّتّ.
\q1 عٍ نَ بِرِن تٌ نّ كِرَ شْن سِفَقٍ رَ عَلَ يِرٍ
\q1 عٍ عٍ يّتّ مَسٍن عَ بّ دّننَشّ.
\q1 
\v 9 ﭑ مَرِفِ عَلَتَلَ سّنبّمَ، ﭑ مَ دُبّ سُشُ!
\q1 يَشُبَ مَرِفِ عَلَ، عِ ﭑ مَ مَشَندِ رَ مّ. \qs حّنفِ رَتٍ.\qs*
\q1 
\v 10 عَلَ، هِننّ عِ شَ مِشِ سُفَندِشِ رَ
\q1 نَشَن قِندِشِ مُشُ شَ وُرٍ لٍقَ رَ.
\b
\q1 
\v 11 شِ كٍرٍن نَدَنفِقٍ عِ شَ بَنشِ كُي،
\q1 نَ حْشُن دَنفِقٍ شِ وُلُ وُلُ رَ يِرٍ فبّتّ.
\q1 ﭑ لُقٍ عِ شَ بَنشِ دّ رَ، نَ قَن لُقٍ رَ تِنشِنتَرٍيٍ شْنيِ،
\q1 
\v 12 بَرِ مَ عَلَ شُنفبٍ قِندِشِ وٌن مَ كَنتَرِ نَن نَ،
\q1 عَ هِننّ نُن بِنيّ قِمَ نّ وٌن مَ.
\q1 عَ مُ تٌندِ مَ تِنشِنتَرٍيٍ كِدٍ هّيرِ رَ.
\q1 
\v 13 مَرِفِ سّنبّمَ، هّيرِ نَ مِشِ بّ نَشَن عَ يّتّ تَشُمَ عِ رَ.
\c 85
\s1 عَلَ شَ هِننّ
\s2 عَلَ مَشَندِ
\d 
\v 1 كٌرَ شَ دِيٍ شَ بّيتِ بّيتِبَيٍ شَ مَنفّ بّ
\q1 
\v 2 مَرِفِ، عِ شَنُنتٍيَ مَسٍنمَ عِ شَ حَمَ بّ،
\q1 عِ يَشُبَ بْنسْي شُن نَكٍلِمَ.
\q1 
\v 3 عِ دِحّمَ عِ شَ حَمَ شَ قٍ حَاشِيٍ مَ،
\q1 عِ عَ شَ يُنُبِيٍ بِرِن شَقَرِ مَ. \qs حّنفِ رَتٍ.\qs*
\q1 
\v 4 عِ عِ شَ شْنّ رَفبِلٍنمَ عَ قْشْ رَ،
\q1 عِ دِحّمَ عَ مَ.
\b
\q1 
\v 5 عَلَ، عِ مَن شَ مُشُ رَكِسِ،
\q1 عِ مَن شَ هِننّ مُشُ رَ.
\q1 
\v 6 عِ شْنْمَ نّ مُشُ مَ عَبَدَن؟
\q1 نَ شْنّ مُ بَمَ مُشُ شَ يِ وَشَتِ كُي؟
\q1 
\v 7 عِ مُ نْمَ دِحّدٍ مُ مَ،
\q1 عِ شَ حَمَ شَ كِسِ، عٍ شَ سّيوَ؟
\q1 
\v 8 عَلَتَلَ، عِ شَ دُفُتّفّحَ مَسٍن مُشُ بّ، عِ شَ مُشُ رَكِسِ.
\b
\q1 
\v 9 ﭑ نَن ﭑ تُلِ مَتِمَ نّ ﭑ مَرِفِ عَلَ شَ مَسٍنيِ رَ،
\q1 بَرِ مَ عَ بْحّسَ نَن قِمَ عَ شَ حَمَ تِنشِنشِ مَ.
\q1 عَلَ شَ عٍ مَلِ فبِلٍنقٍ رَ عٍ شَ دَشُحَ مَ.
\q1 
\v 10 عَ كِسِ يَتِ يَتِ نَن قِمَ مِشِيٍ مَ نَشٍيٍ فَاشُمَ عَ يَ رَ،
\q1 عَلَكٌ عَ شَ نْرّ شَ سَبَتِ وٌن مَ بْشِ كُي.
\b
\q1 
\v 11 دُفُتّفّحَ نُن نْندِ نَ يِرٍ كٍرٍن.
\q1 تِنشِنيِ نُن بْحّسَ حّرّ مَ كِرَ كٍرٍن شْن.
\q1 
\v 12 نْندِ كٍلِمَ لَنبَنيِ مَ،
\q1 تِنشِنيِ كٍلِمَ كٌورٍ مَ.
\q1 
\v 13 عَلَتَلَ هّرِ قِمَ نّ وٌن مَ،
\q1 عَلَكٌ وٌن مَ بْشِ شَ دَشَمُي رَ مِنِ.
\q1 
\v 14 تِنشِنيِ حّرّ مَ عَ يَ رَ،
\q1 عَ قِندِ سَنيِ قْشِ رَ كِرَ شْن مَ.
\c 86
\s1 ﭑ هَيِ نَ عَلَ مَ
\s2 عَلَ مَشَندِ
\d 
\v 1 دَوُدَ شَ عَلَ مَشَندِ
\q1 مَرِفِ، عِ عِ تُلِ مَتِ ﭑ نَ، عِ شَ ﭑ يَابِ.
\q1 مِسِكِينّ قُشَرِشِ نَ ﭑ نَ.
\q1 
\v 2 عِ شَ ﭑ مَكَنتَ، عِ دُفُتّفّ نَ ﭑ نَ.
\q1 ﭑ مَرِفِ عَلَ، عِ شَ عِ شَ كٌنيِ دِ رَكِسِ نَشَن عَ تَشُشِ عِ رَ.
\q1 
\v 3 كِنِكِنِ ﭑ مَ، ﭑ مَرِفِ،
\q1 بَرِ مَ ﭑ عِ شِلِمَ لْشْي بِرِن.
\q1 
\v 4 عِ شَ سّيوّ قِ عِ شَ كٌنيِ دِ مَ،
\q1 ﭑ شَشِلِ تِشِ عِ تَن نَن نَ، ﭑ مَرِفِ.
\q1 
\v 5 عِ تَن مَرِفِ، عِ قَن، عِ كِنِكِنِ،
\q1 عِ شَ دُفُتّفّحَ فبٌ مِشِيٍ بّ نَشٍيٍ بِرِن عِ شِلِمَ.
\q1 
\v 6 مَرِفِ، عِ شَ عِ تُلِ مَتِ ﭑ مَ مَشَندِ رَ،
\q1 عِ شَ ﭑ مَ دُبّ سُشُ.
\q1 
\v 7 ﭑ عِ شِلِمَ ﭑ مَ تْورّ كُي، بَرِ مَ عِ ﭑ نَتِنمَ.
\b
\q1 
\v 8 ﭑ مَرِفِ، عِ مَنِيّ مُ نَ عَلَيٍ تَفِ،
\q1 عِ شَ كَابَنَكٌييٍ دَنفِ وَلِ بِرِن نَ.
\q1 
\v 9 عِ سِ نَشٍيٍ دَا دُنِحَ مَ، نٍيٍ قَمَ نّ عٍ شِنبِ سِندٍ عِ بُن مَ،
\q1 عٍ عِ شِلِ مَتْشْ،
\q1 
\v 10 بَرِ مَ عِ فبٌ، عِ مَن كَابَنَكٌي رَبَمَ.
\q1 عِ تَن كٍرٍن ثٍتِ نَ نَن عَلَ رَ.
\q1 
\v 11 ﭑ مَرِفِ، عِ شَ عِ شَ كِرَ مَسٍن ﭑ بّ،
\q1 ﭑ شَ ﭑ حّرّ عِ شَ نْندِ كُي.
\q1 بْحّ قَنيِ قِ ﭑ مَ، عَلَكٌ ﭑ شَ فَاشُ عِ شِلِ يَ رَ.
\q1 
\v 12 ﭑ عِ مَتْشْمَ ﭑ بْحّ قِيشّ بِرِن نَ، ﭑ مَرِفِ عَلَ.
\q1 ﭑ عِ شِلِ مَتْشْمَ نّ عَبَدَن،
\q1 
\v 13 بَرِ مَ عِ شَ هِننّ تِلِن.
\q1 عِ بَرَ ﭑ نِي رَتَنفَ قَشّ مَ.
\b
\q1 
\v 14 عٍٍ عَلَ، يّتّ عِفبٌي ندٍيٍ بَرَ كٍلِ ﭑ شِلِ مَ،
\q1 فبَلٌتْييٍ وَ مَ ﭑ قَشَقٍ.
\q1 عٍ مُ عِ كٌلٌن قٍوٌ.
\q1 
\v 15 كْنْ ﭑ مَرِفِ، عِ تَن نَن قِندِشِ عَلَ رَ،
\q1 نَشَن كِنِكِنِمَ، نَشَن هِننّمَ عِبُنَدَ مَ رَ،
\q1 نَشَن بْحّ مُ تٍمَ مَقُرٍن،
\q1 نَشَن مُ تَفَنمَ دُفُتّفّحَ نُن شَنُنتٍيَ مَ.
\q1 
\v 16 عِ شَ عِ يَ رَقِندِ ﭑ مَ، عِ شَ هِننّ ﭑ نَ.
\q1 عِ شَ سّنبّ قِ عِ شَ كٌنيِ دِ مَ،
\q1 عِ شَ عِ شَ كٌنيِ فِنّ شَ دِ رَكِسِ.
\q1 
\v 17 تْنشُمَ ندٍ رَ مِنِ ﭑ بّ سٍيدٍ رَ،
\q1 عَلَكٌ نَشٍيٍ ﭑ شْنشِ، عٍ شَ عَ تٌ، عٍ شَ يَافِ،
\q1 عِ شَ مَلِ نُن عِ شَ مَدُندُي شَ قٍ رَ.
\c 87
\s1 بَرِقٍ سِيٌنِ
\s2 عَلَ مَتْشْي
\d 
\v 1 كٌرَ شَ دِيٍ شَ بّيتِ
\q1 عَلَتَلَ شَ تَا تِشِ فٍيَ سّنِيّنشِيٍ قَرِ.
\q1 
\v 2 سِيٌنِ نَادّيٍ رَقَن مَرِفِ مَ،
\q1 دَنفِ يَشُبَ شَ لِنفِرَ بِرِن نَ.
\q1 
\v 3 مِشِيٍ عَلَ شَ تَا مَتْشْمَ عَ قَنيِ رَ \qs حّنفِ رَتٍ.\qs*
\q1 
\v 4 «ﭑ شَ عَ قَلَ رَشَبِ نُن بَبِلْن ﭑ كٌلٌنمَ،
\q1 عَ نُن قِلِسِتَ، تِرٍ، نُن كُسِ.
\q1 
\v 5 عَ قَلَشِ سِيٌنِكَيٍ شَ قٍ رَ،
\q1 ‹عٍ تٌ بَرِشِ نَا، مَرِفِ عَلَ عٍ مَكَنتَمَ نّ.›»
\q1 
\v 6 عَلَتَلَ بَرَ عَ سّبّ سِيٍ شَ بُكِ كُي،
\q1 «يِ تَن بَرِشِ نَا.» \qs حّنفِ رَتٍ.\qs*
\q1 
\v 7 بّيتِبَيٍ عَ قَلَمَ عٍ شُي عِتٍشِ رَ،
\q1 «ﭑ مَ سَابُي بِرِن نَ عِ تَن نّ.»
\c 88
\s1 سَيَ كِرَ
\s2 عَلَ مَشَندِ
\d 
\v 1 كٌرَ شَ دِيٍ شَ بّيتِ بّيتِبَيٍ شَ مَنفّ بّ. عَ شَ بَ شُلٍ رَ. هٍمَن عٍسِرَكَ شَ لْننِ بّيتِ.
\q1 
\v 2 مَرِفِ، ﭑ نَكِسِمَ عَلَ،
\q1 ﭑ عِ شِلِمَ يَنيِ نُن كْي رَ.
\q1 
\v 3 عِ شَ ﭑ مَ مَشَندِ سُشُ،
\q1 عِ شَ ﭑ مَ دُبّ تٌنفٌ.
\q1 
\v 4 ﭑ بَرَ تْورْ ﭑ مَ دُنِحّءِفِرِ كُي،
\q1 يَكْسِ ﭑ بَرَ مَكْرّ سَيَ رَ.
\q1 
\v 5 ﭑ نَ مِشِيٍ يَ مَ نَشٍيٍ نَ سَيَ كِرَ شْن مَ.
\q1 ﭑ سّنبّ يٌ مُ نَ سْنْن.
\q1 
\v 6 عَ لُشِ نّ عَلْ ﭑ حَن سَشِ قُرٍيٍ تَفِ فَبُرِ كُي،
\q1 عِ مُ رَتُشِ نَشٍيٍ شَ قٍ مَ سْنْن،
\q1 نَشٍيٍ بَرَ مَكُيَ عِ شَ هِننّ رَ.
\q1 
\v 7 عِ بَرَ ﭑ نَ سٌ يِلِ تِلِنشِ كُي دِ مِ شْورَ.
\q1 
\v 8 عِ شَ شْنّ بَرَ دُتُن ﭑ مَ،
\q1 عَ ﭑ مَكٌتٌ عَلْ بَا مْرْنيِ مِشِ مَكٌتٌمَ كِ نَشّ. \qs حّنفِ رَتٍ.\qs*
\q1 
\v 9 عِ بَرَ ﭑ دّقَنبٌورٍيٍ مَكُيَ ﭑ نَ،
\q1 عِ بَرَ عٍ بْحّيٍ رَحَاشُ عٍ مَ.
\q1 ﭑ لُمَ بَنشِ كُي، ﭑ مُ مِنِمَ قٍقٍ مَ.
\q1 
\v 10 ﭑ مَرِفِ، ﭑ عِ شِلِمَ لْشْ يٌ لْشْ يَيٍ رَ،
\q1 ﭑ نَ ﭑ بّلّشّيٍ تِشِ عِ بّ.
\b
\q1 
\v 11 عِ كَابَنَكٌي رَبَمَ مِشِ قَشَشِيٍ نَن بّ؟
\q1 عٍ نْمَ كٍلِدٍ، عٍ عِ مَتْشْ؟
\q1 
\v 12 عِ شَ دُفُتّفّحَ شَ قٍ قَلَمَ فَبُرِ كُي؟
\q1 عِ شَ شَنُنتٍيَ مَسٍنمَ نَا؟
\q1 
\v 13 عِ شَ كَابَنَكٌ تٌمَ عَلِفِيَمَ؟
\q1 عِ شَ تِنشِنيِ كٌلٌنمَ يِرٍ دّننَشّ شَ قٍ بَرَ نّيمُ مِشِ رَ؟
\b
\q1 
\v 14 ﭑ مَرِفِ، ﭑ تَن عِ شِلِمَ،
\q1 فّيسّفّ يٌ فّيسّفّ ﭑ عِ مَشَندِ مَ.
\q1 
\v 15 مَرِفِ، عِ تٌندِ مَ ﭑ بّ مُنقٍ رَ؟
\q1 عِ عِ كٌبٍ سٌمَ ﭑ نَ مُنقٍ رَ؟
\q1 
\v 16 ﭑ نَ تْورّ كُي كَبِ ﭑ دِ مّدِ تّمُي.
\q1 ﭑ فَاشُشِ، شَشِلِسَ بِرِن بَرَ بَ ﭑ يِ رَ.
\q1 
\v 17 عِ شَ شْنّ سّنبّ بَرَ دَنفِ عَ عِ،
\q1 عِ شَ قٍ مَفَاشُشِيٍ بَرَ نْ ﭑ نَ.
\q1 
\v 18 عٍ ﭑ نَبِلِنشِ عَلْ بَنبَرَنيِ،
\q1 عٍ دُ سُ ﭑ شُن نَ.
\q1 
\v 19 عِ بَرَ ﭑ شَنُنتٍنيِيٍ بِرِن مَكُيَ ﭑ نَ،
\q1 ﭑ دْشْبٌورٍ بَرَ كٍلِ ﭑ شُن مَ.
\c 89
\s1 عَلَ شَ سَاتّ
\s2 عَلَ مَتْشْي
\d 
\v 1 عٍتَنِ عٍسِرَكَ شَ لْننِ بّيتِ
\q1 
\v 2 ﭑ بّيتِ بَمَ ﭑ مَرِفِ شَ دُفُتّفّحَ شَ قٍ رَ.
\q1 ﭑ نَ مَسٍنمَ نّ بْنسْي بِرِن بّ، عَ قَلَقٍ رَ،
\q1 
\v 3 «عِ شَ دُفُتّفّحَ مَبَنبَنشِ كٌورٍ مَ عَبَدَن.
\q1 عِ شَ هِننّ مُ كَنَمَ.»
\b
\q1 
\v 4 «ﭑ بَرَ سَاتّ شِرِ ﭑ نُن ﭑ مَ مِشِ سُفَندِشِ رَ،
\q1 ﭑ بَرَ يِ كّرّ تٌنفٌ ﭑ مَ كٌنيِ دِ دَوُدَ بّ.
\q1 
\v 5 ‹ﭑ عِ بْنسْي رَ سَبَتِمَ نّ عَبَدَن،
\q1 ﭑ عِ شَ كِبَنيِ تِ تّمُي بِرِن.›» \qs حّنفِ رَتٍ.\qs*
\q1 
\v 6 ﭑ مَرِفِ، نَشٍيٍ نَ كٌورٍ مَ عٍ عِ مَتْشْمَ،
\q1 مَلٍكّيٍ عِ تَنتُمَ عِ شَ دُفُتّفّحَ شَ قٍ رَ.
\q1 
\v 7 ندٍ نَ كٌورٍ مَ نَشَن مَنِيَمَ مَرِفِ عَلَ رَ؟
\q1 ندٍ لُشِ عَلْ مَرِفِ عَلَ مَلٍكّيٍ يَ مَ؟
\q1 
\v 8 عَلَ مَفَاشُ عَ شَ سّنِيّنتْييٍ شَ مَلَنيِ،
\q1 عٍ بِرِن عٍ مَفٌرٌ عَ بّ.
\q1 
\v 9 مَرِفِ عَلَ، ندٍ سّنبّ فبٌ عَلْ عِ تَن مَنفّ عَلَ؟
\q1 عِ شَ دُفُتّفّحَ نَ يِرٍ بِرِن.
\q1 
\v 10 عِ تَن نَن بَا يَمَرِ مَ،
\q1 عِ عَ مْرْنيِيٍ رَشَرَ.
\q1 
\v 11 عِ تَن نَن نْ مِسِرَ رَ، عِ عَ سْنتْ.
\q1 عِ عِ يَشُييٍ رَيٍنسٍن عِ سّنبّ رَ.
\q1 
\v 12 عِ تَن نَن فبٍ كٌورٍ رَ، عِ تَن نَن فبٍ بْشِ رَ.
\q1 عِ تَن نَن دُنِحَ بِرِن دَا.
\q1 
\v 13 سٍ نَشَن نَ كْولَ مَ، سٍ نَشَن نَ يِرٍقَنيِ مَ،
\q1 عِ تَن نَن عَ بِرِن دَاشِ.
\q1 تَبٌرٌ نُن شٍرِ مٌن فٍيَيٍ عِ شِلِ مَتْشْمَ.
\q1 
\v 14 عِ سّنبّ فبٌ.
\q1 
\v 15 تِنشِنيِ نُن نْندِ نَن نَ عِ شَ كِبَنيِ سَنبُنيِ رَ،
\q1 شَنُنتٍيَ نُن دُفُتّفّحَ قَن تِشِ عِ يَ رَ.
\b
\q1 
\v 16 مَرِفِ، سّيوّ نَ حَمَ بّ نَشَن عِ شِلِ مَتْشْمَ،
\q1 عٍ عٍ حّرّ مَ عِ شَ نَءِيَلَنيِ نَن مَ.
\q1 
\v 17 عٍ سّيوَ مَ عِ شِلِ شَ قٍ رَ،
\q1 عٍ شُن نَكٍلِمَ عِ شَ تِنشِنيِ سَابُي رَ.
\q1 
\v 18 عِ تَن نَن قِندِشِ عٍ شَ نَءِيَلَنيِ نُن عٍ سّنبّ رَ.
\q1 مُشُ سّنبّ فبٌ عِ شَ هِننّ شَ قٍ رَ.
\q1 
\v 19 مُشُ مَرِفِ نَن نَ مُشُ كَنتَمَ نُن مُشُ شَ مَنفّ رَ،
\q1 عِسِرَيِلَ شَ سّنِيّنتْي نَ عَ رَ.
\b
\q1 
\v 20 عِ وْيّن نّ عِ شَ حَمَ بّ لَامَتُنيِ رَ، عَ قَلَقٍ رَ،
\q1 «ﭑ بَرَ سّنبّ قِ فٍرٍ سٌي ندٍ مَ،
\q1 ﭑ نَشَن شُن نَكٍلِشِ حَمَ تَفِ.
\q1 
\v 21 ﭑ بَرَ ﭑ مَ كٌنيِ دَوُدَ تٌ،
\q1 ﭑ تُرٍ سّنِيّنشِ سُرُ سُرُ عَ شُنيِ مَ سُفَندِ رَ.
\q1 
\v 22 ﭑ نَ ﭑ بّلّشّ رَ سٌمَ عَ بُن مَ،
\q1 ﭑ سّنبّ قِمَ نّ عَ مَ عَ قَنيِ رَ.
\q1 
\v 23 عَ يَشُي مُ عَ تّرّننَمَ،
\q1 تِنشِنتَرٍ مُ عَ تْورْ مَ.
\q1 
\v 24 ﭑ عَ يَشُييٍ عِبُتُشُنمَ نّ،
\q1 ﭑ عَ شْنمَيٍ بْنبْمَ نّ.
\q1 
\v 25 ﭑ شَنُنتٍيَ نُن ﭑ مَ دُفُتّفّحَ لُمَ نّ عَ مَ،
\q1 عَ سّنبّ فبٌمَ ﭑ شِلِ نَن سَابُي رَ.
\q1 
\v 26 بَايٍ نُن شُرٍيٍ بِرِن سَمَ نّ عَ شَ مَنفّيَ بُن مَ.
\q1 
\v 27 عَ عَ قَلَمَ نّ ﭑ بّ،
\q1 ‹ﭑ بَبَ نَن عِ رَ، ﭑ مَرِفِ عَلَ، ﭑ مَ مَرَكِسِمَ.›
\q1 
\v 28 ﭑ عَ قِندِ مَ نّ ﭑ مَ دِ سِنفٍ رَ،
\q1 نَشَن شُنفبٌ دُنِحَ مَنفّيٍ بِرِن بّ.
\q1 
\v 29 ﭑ نَ ﭑ مَ دُفُتّفّحَ مَبَنبَنمَ نّ عَ بّ،
\q1 مُشُ سَاتّ نَشَن شِرِشِ، عَ مُ كَنَمَ عَبَدَن.
\q1 
\v 30 ﭑ عَ بْنسْي رَ سَبَتِمَ نّ،
\q1 ﭑ عَ شَ مَنفّ كِبَنيِ مَبَنبَنمَ نّ قَننِ كٌورٍ نَ.
\q1 
\v 31 عَ شَ دِيٍ نَ ﭑ مَ سّرِيّ رَبٌلٌ،
\q1 عٍ مُ عٍ حّرّ ﭑ مَ يَامَرِ بُن مَ،
\q1 
\v 32 عٍ ﭑ شُي مَتَندِ، عٍ مُ ﭑ وَشْنقٍ سُشُ،
\q1 
\v 33 ﭑ عٍ بْنبْمَ لُشُسِنيِ نَن نَ،
\q1 ﭑ عٍ حَشَنكَتَمَ قُرٍ حَاشِيٍ رَ.
\q1 
\v 34 كْنْ ﭑ مُ ﭑ مَ دُفُتّفّحَ بَمَ عَ مَ.
\q1 ﭑ مُ ﭑ شُي يَنقَمَ،
\q1 
\v 35 ﭑ مُ ﭑ مَ سَاتّ كَنَمَ،
\q1 ﭑ مَن مُ ﭑ شُي مَسَرَ مَ.
\q1 
\v 36 ﭑ نَ ﭑ كَلِشِ ﭑ مَ سّنِيّنيِ رَ،
\q1 ﭑ مُ عَننَبِ دَوُدَ يَنقَمَ.
\q1 
\v 37 عَ بْنسْي كِسِمَ نّ عَبَدَن،
\q1 عَ شَ كِبَنيِ لُمَ نّ ﭑ يَ عِ عَلْ سٌفٍ،
\q1 
\v 38 عَ رَ سَبَتِمَ نّ عَلْ كِكٍ،
\q1 نَشَن قِندِ مَ سٍيدٍحْشْيَ رَ عَبَدَن.» \qs حّنفِ رَتٍ.\qs*
\q1 
\v 39 كْنْ عِ تَن بَرَ عِ شَ مِشِ سُفَندِشِ مَكُيَ عِ رَ،
\q1 عِ بَرَ مّي عَ رَ، عِ شْنْ عَ مَ.
\q1 
\v 40 عِ بَرَ عِ شَ سَاتّ كَنَ عِ شَ كٌنيِ بّ،
\q1 عِ عَ بَ عَ شَ كِبَنيِ كُي.
\q1 
\v 41 عِ بَرَ عَ شَ تّتّ بْو، عِ بَرَ عَ مَكَنتَدٍ كَنَ.
\q1 
\v 42 مِشِ نَشٍيٍ دَنفِمَ، عٍ هَرِفٍ بَمَ نَا.
\q1 عَ دْشْبٌورٍيٍ يٌمَ عَ مَ.
\q1 
\v 43 عِ بَرَ عَ يَشُييٍ سّنبّ سٌ، هَن عٍ بَرَ سّيوَ.
\q1 
\v 44 عِ مُ عَ شَ سَنتِدّفّمَ وَلِ رَ سْونّيَ،
\q1 عِ مُ عَ مَلِشِ فٍرٍ كُي.
\q1 
\v 45 عِ بَرَ عَ شَ قٍ رَشُبٍن،
\q1 عِ بَرَ عَ شَ كِبَنيِ وٌلِ بْشِ.
\q1 
\v 46 عِ بَرَ ندٍ بَ عَ شَ قٌنِكٍيَ رَ،
\q1 عِ يَافِ دُ سُ عَ شُن نَ. \qs حّنفِ رَتٍ.\qs*
\q1 
\v 47 عَلَتَلَ، عِ عِ نْشُنمَ ﭑ مَ هَن مُن تّمُي؟
\q1 عِ شَ شْنّ دّشّمَ عَلْ تّ هَن مُن لْشْي؟
\q1 
\v 48 عِ شَ رَتُ عَ مَ ﭑ مَ سِمَيَ دُنكٍ كِ نَشّ.
\q1 عِ عِبُنَدَ مَ دَاشِ قُيَن نَن نَ؟
\q1 
\v 49 ندٍ بَلٌشِ نَشَن مُ قَشَمَ؟
\q1 ندٍ نْمَ عَ يّتّ بَدٍ سَيَ كِرَ شْن مَ؟
\q1 
\v 50 ﭑ مَرِفِ، عِ شَ دُفُتّفّحَ سِنفٍ نَ مِندٍن،
\q1 عِ عِ كَلِ نَشَن نَ دَوُدَ بّ عِ شَ تِنشِنيِ كُي؟
\q1 
\v 51 ﭑ مَرِفِ، عِ شَ عِ حْشْ سَ عِ شَ كٌنيِيٍ شَ يَافِ شْن مَ.
\q1 عِ شَ نَ كٌتٍ تٌ مِشِ وُيَشِيٍ نَشَن دْشْ ﭑ شُن مَ.
\q1 
\v 52 ﭑ مَرِفِ، عِ شَ عِ رَتُ عَ مَ عِ يَشُييٍ ﭑ مَبٍرٍ مَ كِ نَشّ،
\q1 ﭑ تَن عِ شَ مِشِ سُفَندِشِ.
\b
\q1 
\v 53 تَنتُي نَ مَرِفِ بّ عَبَدَن. عَمِنَ. عَمِنَ.
\c 90
\s1 عَدَ مَ بِرِن قَشَمَ نّ
\s2 عَلَ مَشَندِ
\d 
\v 1 عَلَ شَ مِشِ مُنسَ شَ عَلَ مَشَندِ
\q1 ﭑ مَرِفِ، عِ تَن قِندِشِ مُشُ كَنتَمَ نَن نَ عَبَدَن.
\q1 
\v 2 بٍينُن فٍيَيٍ نُن دُنِحَ شَ دَا،
\q1 عِ تَن نَن نُ نَ عَلَ رَ عَبَدَن.
\b
\q1 
\v 3 عِ عِبُنَدَ مَ رَفبِلٍنمَ بّندّ عِ.
\q1 عِ نَ نَن قَلَ، «عَدَ مَدِ شَ فبِلٍن بّندّ.»
\q1 
\v 4 حّ وُلُ كٍرٍن لُشِ نّ عِ بّ
\q1 عَلْ لْشْ كٍرٍن نَشَن بَرَ دَنفِ،
\q1 عَلْ وَشَتِ كٍرٍن نَشَن بَرَ دَنفِ كْي كُي.
\q1 
\v 5 عِ عَ نِيَ عَدَ مَدِ مُ كٍلِ عَ شَ شِشْلِ مَ.
\q1 عَ لُشِ عَلْ حٌوفٍ نَشَن مِنِمَ عَ يّتّ رَ.
\q1 
\v 6 عَ كٍلِ سُبَشّ مَ، عَ قُفَ،
\q1 نُنمَرٍ تّمُي عَ حَن بَرَ لِسِ، عَ شَرَ.
\b
\q1 
\v 7 عِ شَ شْنّ مُشُ حْنمَ نّ،
\q1 عَ مُشُ مَفَاشُ.
\q1 
\v 8 عِ مُشُ شَ يُنُبِ بِرِن كٌلٌن،
\q1 هَلِ مُشُ شَ قٍ حَاشِ نَشٍيٍ قِندِشِ فُندٌ رَ.
\q1 
\v 9 مُشُ شَ سِمَيَ بِرِن لُمَ عِ شَ شْنّ بُن مَ.
\q1 مُشُ شَ دُنِحّءِفِرِ شَ بُي بِرِن، حّنفِ رَتٍ كٍرٍن.
\q1 
\v 10 مُشُ شَ سِمَيَ بُمَ حّ تٌنفٌ سٌلٌقٍرٍ،
\q1 حّ تٌنفٌ سٌلٌمَسَشَن شَ عَ سْونّيَ،
\q1 كْنْ نَ بِرِن قِندِشِ تْورّ نُن حَشَنكَتّ نَن نَ.
\q1 سِمَيَ دَنفِمَ نّ مَقُرٍن مَقُرٍن، عَ مُشُ لُ دِ مِ كُي.
\q1 
\v 11 ندٍ عِ شَ شْنّ سّنبّ كٌلٌن؟
\q1 ندٍ فَاشُمَ نَ يَ رَ؟
\q1 
\v 12 عَ مُشُ رَتُ سِمَيَ رَحْنيِ مَ،
\q1 عَلَكٌ مُشُ شَ شَشِلِ سْتْ مُشُ شَ دُنِحّءِفِرِ كُي.
\b
\q1 
\v 13 ﭑ مَرِفِ، عِ شَ عِ يَ رَقِندِ مُشُ مَ
\q1 عِ شَ شْنّ بُمَ هَن مُن تّمُي؟
\q1 كِنِكِنِ عِ شَ كٌنيِ دِيٍ مَ.
\q1 
\v 14 كُيٍ نَ عِبَ، عِ شَ مُشُ رَوَ سَ عِ شَ دُفُتّفّحَ رَ،
\q1 عَلَكٌ مُشُ شَ سّيوَ مُشُ شَ سِمَيَ بِرِن كُي.
\q1 
\v 15 عِ تْورّ شَسَبِ نَشَن دْشْ مُشُ مَ،
\q1 عِ يَافِ شَسَبِ نَشَن سَ مُشُ مَ،
\q1 عِ مَن شَ مُشُ رَ سّيوَ نَ شَسَبِ رَ.
\q1 
\v 16 عِ شَ عِ شَ كَابَنَكٌي مَسٍن مُشُ بّ، عِ شَ كٌنيِيٍ.
\q1 عِ شَ نْرّ شَ مِنِ مُشُ شَ دِيٍ مَ.
\q1 
\v 17 مُشُ مَرِفِ عَلَ شَ تٌقَنيِ شَ لُ مُشُ يَ عِ.
\q1 عَ شَ مُشُ شَ وَلِ سْونّيَ،
\q1 عَ شَ بَرَكَ سَ مُشُ شَ وَلِ مَ!
\c 91
\s1 فَاشُتَرٍحَ
\s2 عَلَ مَتْشْي
\q1 
\v 1 نَشَن لُمَ عَلَ شِلِ شُنفبٍ كَنيِ شَ كَنتَرِ بُن مَ،
\q1 عَ عَ مَلَبُمَ نّ عَلَ شَ كَنتّ كُي.
\q1 
\v 2 ﭑ نَ عَ مَسٍنمَ عَلَتَلَ بّ،
\q1 «عِ تَن نَن نَ ﭑ مَ كَنتَرِ نُن ﭑ مَكَنتَدٍ رَ،
\q1 عِ تَن ﭑ مَرِفِ عَلَ، ﭑ لَشِ نَشَن نَ.»
\b
\q1 
\v 3 عَ تَن نَن عِ رَتَنفَمَ فَنتَنيِيٍ مَ نَشٍيٍ تٍمَ عِ بّ،
\q1 عَ عِ رَتَنفَ وُفَنيِ مَ.
\q1 
\v 4 عَ عِ مَكَنتَمَ نّ
\q1 عَلْ تْشْي عَ شَ دِيٍ مَكَنتَمَ كِ نَشّ
\q1 عَ فَبُتٍنيِ بُن مَ.
\q1 عَ شَ دُفُتّفّحَ لُمَ نّ عَلْ سْورِ شَ وُرٍ لٍقَ.
\q1 
\v 5 عِ مُ فَاشُمَ فبَلٌي رَ كْي رَ،
\q1 عِ مُ فَاشُمَ شَلِيٍ رَ يَنيِ رَ،
\q1 
\v 6 عِ مُ فَاشُمَ وُفَنيِ رَ دِ مِ كُي،
\q1 عِ مُ فَاشُمَ قُرٍ حَاشِ رَ سٌفٍ بُن مَ.
\q1 
\v 7 مِشِ وُلُ نْمَ نّ بِرَدٍ عِ كْولَ مَ،
\q1 مِشِ وُلُ قُ نْمَ بِرَدٍ عِ يِرٍقَنيِ مَ،
\q1 كْنْ سٍسٍ مُ عِ تٌمَ.
\q1 
\v 8 عِ نَ بِرِن تٌمَ نّ عِ يَ عِ،
\q1 عِ قِندِ سٍيدٍ رَ تِنشِنتَرٍ شَ حَشَنكَتّ مَ،
\q1 
\v 9 بَرِ مَ عِ بَرَ لَ عِ مَرِفِ رَ، عَ بَرَ قِندِ عِ شَ كَنتَرِ رَ.
\q1 عَلَ شِلِ شُنفبٍ كَنيِ قِندِشِ عِ شَ مَكَنتَدٍ نَن نَ.
\q1 
\v 10 سٍسٍ مُ عِ لِمَ،
\q1 وُفَنيِ يٌ مُ سٌمَ عِ شْنيِ،
\q1 
\v 11 بَرِ مَ عَ عَ شَ مَلٍكّيٍ يَمَرِ مَ عٍ شَ عِ مَكَنتَ يِرٍ بِرِن.
\q1 
\v 12 عٍ عِ تٌنفٌمَ نّ عٍ بّلّشّيٍ كُي،
\q1 عَلَكٌ عِ نَشَ عِ سَنيِ رَدِن فّمّ رَ.
\q1 
\v 13 عِ نْمَ يّتّيٍ نُن بْشِمَسٍيٍ رَ،
\q1 عِ سّنبّ دَنفِ بَرَتّيٍ نُن بِيدَيٍ رَ.
\b
\q1 
\v 14 عَلَتَلَ شَ مَسٍنيِ نَن يَ؛
\q1 «عَ تٌ لَشِ ﭑ نَ، ﭑ عَ رَكِسِمَ نّ.
\q1 ﭑ عَ مَكَنتَمَ نّ بَرِ مَ عَ ﭑ شِلِ كٌلٌن.
\q1 
\v 15 عَ نَ ﭑ شِلِ، ﭑ عَ يَابِمَ نّ.
\q1 تْورّ نَ عَ لِ، ﭑ لُمَ نّ عَ سّيتِ مَ.
\q1 ﭑ عَ رَكِسِمَ نّ، ﭑ عَ شُن نَكٍلِ.
\q1 
\v 16 ﭑ سِمَيَ شْنكُيٍ قِمَ نّ عَ مَ،
\q1 ﭑ نَ ﭑ مَ كِسِ مَسٍن عَ بّ.»
\c 92
\s1 سِمَيَ كَمَلِشِ
\s2 عَلَ مَتْشْي
\d 
\v 1 بّيتِ نَشَن بَمَ مَلَبُي لْشْي
\q1 
\v 2 مَرِفِ بَتُقٍ قٍ قَنيِ نَ عَ رَ.
\q1 عَلَ شِلِ شُنفبٍ كَنيِ، عَ لَنمَ عِ شِلِ شَ مَتْشْ بّيتِ رَ.
\q1 
\v 3 كُيٍ عِبَ، عَ لَنمَ عِ شَ شَنُنتٍيَ شَ مَتْشْ،
\q1 كْي كُي، مُشُ شَ عِ تَنتُ عِ شَ دُفُتّفّحَ شَ قٍ رَ.
\q1 
\v 4 مَتْشْي شَ بَ كْرَ لُوتِ قُ دَاشِ شُي رَ نُن عَدَ مَدِ شُي رَ.
\q1 
\v 5 مَرِفِ، ﭑ حّلّشِنمَ عِ شَ كَابَنَكٌي رَ،
\q1 ﭑ نَن ﭑ سّيوّ شُي عِتٍمَ عِ شَ وَلِ شَ قٍ رَ.
\q1 
\v 6 مَرِفِ، عِ نَشَن نَبَمَ، عَ مَكَابَ، عِ شَشِلِ تِلِن.
\q1 
\v 7 شَشِلِتَرٍ مُ سٍسٍ كٌلٌنمَ نَ كُي،
\q1 عَ مُ قَهَامُي سْتْمَ عِ شَ قٍ مَ.
\q1 
\v 8 عَلَ كٌلٌنتَرٍيٍ لُمَ عَلْ سَنسِ
\q1 نَشَن بُلَمَ قِيلِ مَ، عَ قُفَ،
\q1 كْنْ نَ دَنفِ شَنبِ، عَ حْن عَبَدَن.
\b
\q1 
\v 9 كْنْ عِ تَن مَرِفِ، مَتْشْي نَ عِ بّ تّمُي بِرِن.
\q1 
\v 10 ﭑ مَرِفِ، عِ يَشُييٍ هَلَكِمَ نّ،
\q1 عِ قٍ كٌبِ رَبَيٍ بِرِن نَيٍنسٍن يّ.
\q1 
\v 11 عِ سّنبّ قِمَ نّ ﭑ مَ عَلْ سّشّ نِنفٍ،
\q1 عِ تُرٍ قَنيِ سَ ﭑ مَ.
\q1 
\v 12 ﭑ يَيٍ عَ تٌمَ ﭑ فٍرٍقَيٍ شُن فٌرٌ مَ كِ نَشّ،
\q1 ﭑ تُلِ عٍ فِ شُي مّ.
\q1 
\v 13 تِنشِنتْييٍ شَ قٍ قَنمَ نّ عَلْ تُفِ بِلِ،
\q1 عٍ شَ قٍ تٍ عَلْ سّدِرِ وُرِ بِلِ نَشٍيٍ نَ لِبَن.
\q1 
\v 14 عٍ سَبَتِشِ عَلَتَلَ شَ هْرْ مْبَنشِ تّتّ كُي،
\q1 عٍ شَ قٍ قَنمَ نّ وٌن مَرِفِ عَلَ يَ عِ.
\q1 
\v 15 هَلِ عٍ قٌرِشِ عٍ شُنسّشّ قِيشّشِ،
\q1 سّنبّ نَ عٍ بّ قٍ قَنيِ رَبَقٍ رَ،
\q1 
\v 16 عَلَكٌ عٍ شَ عَ مَسٍن،
\q1 «عَلَتَلَ تِنشِن، ﭑ تِشِ عَ شَ سّرِيّ نَن قَرِ،
\q1 تِنشِنتَرٍيَ يٌ مُ نَ عَ مَ.»
\c 93
\s1 مَنفّ عَلَ
\s2 عَلَ مَتْشْي
\q1 
\v 1 مَرِفِ عَلَتَلَ نَن نَ مَنفّ رَ.
\q1 شُننَكٍلِ نَ عَ يِ، عَ سّنبّ فبٌ.
\q1 عَ شَ دُنِحَ شَنشِ، عَ مُ سّرّنمَ.
\b
\q1 
\v 2 عِ شَ مَنفّيَ قْلّ مُ نَ، عَ دَن مُ نَ.
\q1 عِ تَن نَن نَ عَلَ رَ عَبَدَن.
\q1 
\v 3 مَرِفِ، بَا مْرْنيِ رَوُندُ مَ عَلْ فَلَنيِ،
\q1 فَلَنيِ نَشَن فٌرٌ مَ، عَ بُلَ.
\q1 
\v 4 عِ سّنبّ فبٌ نَ شُي بّ،
\q1 عِ شَ شُننَكٍلِ دَنفِ بَا مْرْنيِيٍ رَ.
\q1 مَرِفِ سّنبّ فبٌ كٌورٍ مَ.
\q1 
\v 5 عِ شَ سّرِيّ شَنشِ، سّنِيّنتْي نَن لَنشِ عِ مَ عَبَدَن.
\c 94
\s1 عَلَ شَ حَشَنكَتّ
\s2 عَلَ شَ سّرِيّ
\q1 
\v 1 ﭑ مَرِفِ عَلَ نَشَن عَ فبٍحْشْمَ،
\q1 عِ شَ عِ مَكّنّن عِ شَ نْرّ كُي.
\q1 
\v 2 عِ تَن نَشَن دُنِحَ كِيتِ سَمَ، عِ شَ كٍلِ،
\q1 عِ شَ يّتّ عِفبٌي شَ وَلِيٍ رَفبِلٍن عٍ مَ.
\q1 
\v 3 ﭑ مَرِفِ، عَ لَنمَ مِشِ كٌبِيٍ شُن شَ رَكٍلِ هَن مُن تّمُي؟
\q1 
\v 4 عَ لَنمَ مِشِ حَاشِيٍ شَ عٍ يّتّ مَتْشْ تُن عٍ شَ يّتّ عِفبٌحَ كُي؟
\q1 
\v 5 عَلَتَلَ، عٍ عِ شَ حَمَ تْورْ مَ، عٍ عِ شَ مِشِيٍ هَلَكِمَ.
\q1 
\v 6 عٍ كَاحّ فِنّيٍ نُن شْحّ قَشَمَ، عٍ كِرِدِيٍ نِي بَمَ.
\q1 
\v 7 عٍ نُ قَ عَ قَلَ، «عَلَتَلَ مُ يِ قٍيٍ تٌمَ،
\q1 يَشُبَ مَرِفِ عَلَ مُ يِ رَكْرْ سِمَ.»
\b
\q1 
\v 8 وٌ تَن شَشِلِتَرٍيٍ، نَشٍيٍ لُمَ حَمَ تَفِ،
\q1 وٌ شَشِلِ سْتْمَ مُن تّمُي؟
\q1 
\v 9 نَشَن تُلِ دَاشِ، نَ لُمَ عَ مُ قٍ مّ؟
\q1 نَشَن يَ دَاشِ، نَ لُمَ عَ مُ سٍ تٌ؟
\q1 
\v 10 نَشَن حَمَنّيٍ شُرُ مَ، نَ مُ عٍ حَشَنكَتَمَ؟
\q1 عَ تَن نَن شَشِلِ قِمَ عِبُنَدَ مَ مَ.
\q1 
\v 11 عَلَتَلَ عَ كٌلٌن عَ عَدَ مَدِيٍ شَ مَحْشُنيِيٍ نَ نّ قُقَقُ.
\b
\q1 
\v 12 عَلَتَلَ، سّيوّ نَ مِشِ بّ عِ نَشَن مَتِنشِنمَ،
\q1 عِ نَشَن مَتِنشِنمَ عِ شَ سّرِيّ رَ،
\q1 
\v 13 عَلَكٌ عَ شَشِلِ شَ سَ تْورّ لْشْييٍ،
\q1 هَن مِشِ حَاشِيٍ عٍ فبٍ حَشَنكَتّ سْتْمَ تّمُي نَشّ.
\q1 
\v 14 عَلَتَلَ مُ عَ شَ حَمَ رَبٌلٌمَ،
\q1 عَ مُ عَ شَ مِشِيٍ رَبّحِنمَ.
\q1 
\v 15 كِيتِ تِنشِنشِ قَمَ نّ سَدٍ،
\q1 تِنشِنتْييٍ بْحّ بِرَ مَ نّ نَ قْشْ رَ.
\b
\q1 
\v 16 ندٍ ﭑ شُن مَقَلَمَ مِشِ حَاشِيٍ شْن مَ؟
\q1 ندٍ تِمَ ﭑ بّ مِشِ كٌبِيٍ شِلِ مَ؟
\q1 
\v 17 شَ ﭑ مَرِفِ مُ قِندِ ﭑ مَلِمَ رَ نُ،
\q1 ﭑ مَ قٍ دَنمَ نّ فَبُرِ كُي نُ.
\q1 
\v 18 ﭑ مَرِفِ، ﭑ نَ مَحْشُن عَ ﭑ سَنيِ مُ تِمَ سْنْن،
\q1 عِ شَ دُفُتّفّحَ ﭑ دّ مّنمَ.
\q1 
\v 19 ﭑ مَ كْنتْقِلِيٍ نَ وُيَ،
\q1 عِ عٍ بَمَ ﭑ مَ، عِ قَ ﭑ نَسّيوَ.
\b
\q1 
\v 20 عِ نْمَ تِندٍ مَنفّيَ تِنشِنتَرٍ رَ،
\q1 نَشَن يَامَرِ تِمَ قٍ كٌبِ رَ؟
\q1 
\v 21 عٍ كَقُمَ عٍ بٌرٍ مَ تِنشِنتْي قَشَقٍ رَ،
\q1 عٍ مِشِ تْوحّفّ كِيتِ كُي.
\q1 
\v 22 كْنْ مَرِفِ نَن نَ ﭑ كَنتَمَ رَ،
\q1 عَ لُمَ عَلْ قَنيٍ ﭑ سَبَتِمَ نَشَن قَرِ.
\q1 
\v 23 عَ عٍ شَ وَلِ كٌبِيٍ رَفبِلٍنمَ نّ عٍ مَ،
\q1 عَ عٍ شُن نَكَنَ عٍ شَ حَاشُحَ رَ.
\q1 مُشُ مَرِفِ عَلَ عٍ سْنتْمَ نّ.
\c 95
\s1 مَنفّ عَلَ مَتٌقٍ
\s2 عَلَ مَتْشْي
\q1 
\v 1 وٌن شَ بّيتِ بَ مَرِفِ بّ سّيوّ رَ،
\q1 وٌن شَ وٌن شُي عِتٍ وٌن نَكِسِمَ سّنبّمَ بّ.
\q1 
\v 2 وٌن شَ عَ مَتْشْ،
\q1 وٌن شَ عَ مَتْشْي بَ عَ بّ بّيتِيٍ رَ،
\q1 
\v 3 بَرِ مَ عَلَتَلَ، عَلَ شُنفبٍ نَ عَ رَ،
\q1 نَشَن قِندِشِ مَنفّ شُنفبٍ رَ سّنبّمَيٍ بِرِن شُن مَ.
\q1 
\v 4 يِرٍ تِلِنشِ نَ عَ بّلّشّ.
\q1 فٍيَ شُنتَفِيٍ قِندِشِ عَ فبٍ نَن نَ،
\q1 
\v 5 عَلْ بَا نُن بْشِ عَ نَشٍيٍ دَاشِ عَ بّلّشّ رَ.
\b
\q1 
\v 6 وٌ قَ، وٌن شَ سُيِدِ، وٌن شَ وٌن عِفٌرٌ،
\q1 وٌن شَ وٌن شِنبِ سِن عَلَتَلَ يَ عِ نَشَن وٌن دَا،
\q1 
\v 7 بَرِ مَ عَ تَن نَن وٌن مَرِفِ عَلَ رَ.
\q1 وٌن قِندِشِ عَ شَ حَمَ نَن نَ عَ نَشَن دّ مَدٌنمَ،
\q1 عَلْ شُرُ سٍ دّ مَدٌنيِ مّينِمَ فْورّ مَ كِ نَشّ.
\b
\q1 وٌ شَ عَ شُي مّ تٌ.
\q1 
\v 8 وٌ نَشَ وٌ بْحّيٍ رَشْرْشْ عَلْ نَشَن نَبَشِ مٍرِبَ،
\q1 عَلْ نَشَن نَبَشِ مَسَ فبٍنفبٍرٍنيِ مَ تّمُي دَنفِشِ.
\q1 
\v 9 وٌ بٍنبَيٍ ﭑ مَتٌ نّ نَ لْشْي،
\q1 هَلِ عٍ تٌ نُ بَرَ ﭑ وَلِ قْشِ تٌ.
\q1 
\v 10 نَ بْنسْي شَ قٍ نَشَ رَحَاشُ ﭑ مَ حّ تٌنفٌ نَانِ بُن مَ.
\q1 ﭑ نَشَ عَ قَلَ، «حَمَ شُرُتَرٍ نَن يِ كِ،
\q1 نَشَن مُ ﭑ وَشْنقٍ كٌلٌن.»
\q1 
\v 11 نَ كُي ﭑ نَشَ ﭑ كَلِ ﭑ مَ شْنّ كُي،
\q1 «عٍ مُ سٌمَ ﭑ مَ مَلَبُدٍ كُي قٍقٍ مَ!»
\c 96
\s1 كِيتِسَ نَ قَقٍ
\s2 عَلَ مَتْشْي
\q1 
\v 1 وٌ بّيتِ نّينّ ندٍ بَ عَلَتَلَ بّ!
\q1 دُنِحَ بِرِن شَ بّيتِ بَ عَلَتَلَ بّ!
\q1 
\v 2 وٌ بّيتِ بَ مَرِفِ بّ، وٌ عَ شِلِ مَتْشْ.
\q1 وٌ شَ عَ شَ كِسِ مَسٍن مِشِيٍ بّ تّمُي بِرِن.
\q1 
\v 3 وٌ شَ عَ شَ نْرّ قَلَ سِ بِرِن بّ،
\q1 وٌ عَ شَ كَابَنَكٌي مَسٍن حَمَ بِرِن تَفِ.
\q1 
\v 4 مَرِفِ عَلَ فبٌ، عَ لَنمَ وٌن شَ عَ مَتْشْ،
\q1 نَشَن دَنفِ سّنبّمَيٍ بِرِن نَ.
\q1 
\v 5 سِيٍ بِرَ مَ عَلَ نَشٍيٍ قْشْ رَ،
\q1 عٍ قِندِشِ كُيٍيٍ قُقَقُ فبَنسَن نَن نَ،
\q1 كْنْ عَلَتَلَ نَن كٌورٍ دَا.
\q1 
\v 6 نْرّ نُن نَءِيَلَنيِ كٍلِمَ عَ تَن نَن مَ،
\q1 سّنبّ نُن نَءِيَلَنيِ لُمَ نّ عَ شَ هْرْ مْبَنشِ كُي.
\b
\q1 
\v 7 بْنسْي بِرِن، وٌ شَ تَنتُي رَ سِفَ عَلَتَلَ مَ،
\q1 وٌ عَلَتَلَ مَتْشْ عَ شُننَكٍلِ نُن عَ شَ سّنبّ شَ قٍ رَ.
\q1 
\v 8 وٌ شَ عَ شِلِ بِنيَ عَلْ عَ لَنمَ وٌ شَ عَ رَبَ كِ نَشّ.
\q1 وٌ شَ قَ هَدِيَ رَ، وٌ شَ عَ رَ سٌ عَ شَ هْرْ مْبَنشِ تّتّ كُي.
\q1 
\v 9 وٌ شَ سُيِدِ مَرِفِ بّ عَ شَ نْرّ يَ عِ.
\q1 دُنِحَ بِرِن شَ سّرّن عَ يَ رَ.
\b
\q1 
\v 10 وٌ شَ عَ قَلَ سِ بِرِن بّ، «عَلَتَلَ نَن نَ مَنفّ رَ.
\q1 دُنِحَ شَنشِ، عَ مُ عَ عِمَشَمَ.
\q1 عَلَ حَمَيٍ مَكِيتِمَ تِنشِنيِ رَ.
\q1 
\v 11 كٌورٍ شَ سّيوَ، بْشِ شَ حّلّشِن.
\q1 بَا نُن عَ كُي عِسٍيٍ شَ وُندُ سّيوّ رَ.
\q1 
\v 12 شّيٍ نُن عٍ شَ بٌفِ سٍيٍ شُي شَ عِتٍ،
\q1 وٌندِ وُرِ بِلِيٍ شَ عٍ سّيوَ شُي عِتٍ
\q1 
\v 13 عَلَتَلَ يَ رَ نَشَن قَقٍ.
\q1 عَ قَقٍ دُنِحَ مَكِيتِدٍ.
\q1 عَ دُنِحَ مَكِيتِمَ تِنشِنيِ نَن نَ،
\q1 عَ حَمَيٍ مَكِيتِ نْندِ رَ.»
\c 97
\s1 مَنفّ عَلَ مَفَاشُ
\s2 عَلَ مَتْشْي
\q1 
\v 1 عَلَتَلَ نَن نَ مَنفّ رَ.
\q1 دُنِحَ شَ حّلّشِن، سُرِيٍ شَ سّيوَ.
\q1 
\v 2 نُشُي نُن كُيٍ عِقْورْشِ عَ رَبِلِنمَ.
\q1 عَ شَ كِبَنيِ دْشْشِ تِنشِنيِ نُن نْندِ قَرِ.
\q1 
\v 3 تّ تِشِ عَ يَ رَ، عَ عَ يَشُييٍ بِرِن فَنمَ عَ رَبِلِنيِ.
\q1 
\v 4 عَ دُنِحَ عِيَلَنمَ عَ شَ سٍيَمَكْنيِيٍ رَ،
\q1 دُنِحَ مِشِيٍ نَ عَ تٌ، عٍ سّرّنمَ نّ.
\q1 
\v 5 فٍيَيٍ شُنُمَ دُنِحَ مَرِفِ عَلَتَلَ يَ رَ عَلْ كُمِ دٌلٍ.
\q1 
\v 6 كٌورٍ عَ شَ تِنشِنيِ مَسٍنمَ،
\q1 سِ بِرِن عَ شَ نْرّ تٌمَ.
\q1 
\v 7 كُيٍ بَتُيٍ قَمَ نّ يَافِدٍ عَ يَ رَ،
\q1 سّنبّمَيٍ عٍ قٍلٍنمَ نّ عَ بُن مَ.
\q1 
\v 8 سِيٌنِكَيٍ نَ عَ شُي مّ، عٍ سّيوَ مَ نّ،
\q1 يُدَيَكَيٍ حّلّشِنمَ نّ عِ تَن عَلَتَلَ شَ كِيتِ رَ،
\q1 
\v 9 بَرِ مَ عِ تَن مَرِفِ شُن نَكٍلِشِ سّنبّمَيٍ بِرِن بّ.
\b
\q1 
\v 10 عَلَتَلَ شَنُنتٍنيِ شَ قٍ حَاشِ شْن.
\q1 عَلَتَلَ عَ بَتُلَيٍ مَكَنتَمَ نّ، عَ عٍ بَ مِشِ كٌبِيٍ بّلّشّ.
\q1 
\v 11 نَءِيَلَنيِ نَ تِنشِنتْييٍ نَن بّ،
\q1 سّيوّ نَ مِشِيٍ بّ نَشٍيٍ بْحّ قِيشّ.
\q1 
\v 12 تِنشِنتْييٍ، وٌ سّيوَ مَرِفِ رَ،
\q1 وٌ شَ تَنتُي رَ سِفَ عَ شِلِ سّنِيّنشِ مَ.
\c 98
\s1 بّيتِ نّينّ بَمَ عَلَتَلَ بّ
\s2 عَلَ مَتْشْي
\d 
\v 1 بّيتِ
\q1 وٌ بّيتِ نّينّ بَ عَلَتَلَ بّ،
\q1 بَرِ مَ عَ بَرَ كَابَنَكٌي رَبَ،
\q1 عَ بّلّشّ سّنبّمَ بَرَ شُننَكٍلِ سْتْ عَ بّ.
\q1 
\v 2 مَرِفِ بَرَ عَ شَ كِسِ مَسٍن،
\q1 عَ بَرَ عَ شَ تِنشِنيِ سَ كّنّ مَ حَمَنّيٍ يَ عِ.
\q1 
\v 3 عَ مُ نّيمُ عَ شَ دُفُتّفّحَ نُن عَ شَ شَنُنتٍيَ مَ عِسِرَيِلَ بْنسْي مَبِرِ.
\q1 دُنِحَ بِرِن بَرَ وٌن مَرِفِ عَلَ شَ كِسِ تٌ.
\b
\q1 
\v 4 دُنِحَ بِرِن شَ عَلَتَلَ مَتْشْ،
\q1 عٍ شَ بّيتِ بَ سّيوّ كُي.
\q1 
\v 5 وٌ شَ عَلَتَلَ مَتْشْ كْرَ شُي نُن بّيتِ رَ،
\q1 
\v 6 وٌ شَ سَرَيٍ قٍ سّيوّ رَ وٌ مَنفّ عَلَتَلَ يَ عِ.
\b
\q1 
\v 7 بَا نُن دُنِحَ شَ عٍ شُي رَ مِنِ،
\q1 
\v 8 شُرٍيٍ شَ عٍ بّلّشّيٍ بْنبْ،
\q1 فٍيَيٍ شَ عٍ شُي عِتٍ سّيوّ رَ
\v 9 عَلَتَلَ يَ رَ،
\q1 بَرِ مَ عَ قَقٍ دُنِحَ مَكِيتِدٍ.
\q1 عَ دُنِحَ مَكِيتِمَ تِنشِنيِ نَن نَ،
\q1 عَ حَمَيٍ مَكِيتِمَ نْندِ رَ.
\c 99
\s1 مَنفّ عَلَتَلَ سّنِيّن
\s2 عَلَ مَتْشْي
\q1 
\v 1 عَلَ دْشْشِ عَ شَ كِبَنيِ كُي كٍرُبِمِ مَلٍكّيٍ تَفِ.
\q1 عَ شَ حَمَ تِشِ فَاشُي كُي، بْشِ نَ سّرّنقٍ.
\q1 
\v 2 عَلَتَلَ فبٌ سِيٌنِ، عَ تِشِ سِيٍ بِرِن شُن مَ.
\q1 
\v 3 عٍ شَ عِ شِلِ شُنفبٍ مَفَاشُشِ مَتْشْ عَ شَ سّنِيّنيِ شَ قٍ رَ.
\b
\q1 
\v 4 مَنفّ سّنبّ شَ مَتْشْ،
\q1 تِنشِنيِ رَقَن عَ مَ،
\q1 عَ كِيتِ سَمَ نْندِ رَ يَشُبَ شَ بْشِ مَ.
\q1 
\v 5 وٌ مَرِفِ عَلَتَلَ مَتْشْ،
\q1 وٌ وٌ مَفٌرٌ عَ بُن مَ عَ شَ سّنِيّنيِ شَ قٍ رَ.
\b
\q1 
\v 6 مُنسَ نُن هَرُنَ نُ نَ عَ شَ سّرّشّدُبّيٍ يَ مَ،
\q1 عَننَبِ سَمُوٍلِ نُ نَ مِشِيٍ يَ مَ نَشٍيٍ عَ مَشَندِ مَ.
\q1 عٍ تٌ عَ شِلِ، عَ نَشَ عٍ يَابِ.
\q1 
\v 7 عَ تٌ سّرِيّ نُن يَامَرِ مَسٍن عٍ بّ نُشُي كُي،
\q1 عٍ نَشَ عَ شُي سُشُ.
\b
\q1 
\v 8 مُشُ مَرِفِ عَلَتَلَ، عِ بَرَ عٍ شَ مَشَندِ سُشُ.
\q1 عِ تٌ عِسِرَيِلَ حَشَنكَتَ عٍ شَ يُنُبِ شَ قٍ رَ،
\q1 عِ مَن بَرَ دِحّ عٍ مَ.
\b
\q1 
\v 9 وٌ شَ وٌ مَرِفِ عَلَتَلَ مَتْشْ،
\q1 وٌ شَ وٌ شِنبِ سِن عَ شَ فٍيَ سّنِيّنشِ قَرِ،
\q1 بَرِ مَ وٌن مَرِفِ عَلَتَلَ سّنِيّن!
\c 100
\s1 تَنتُي بّيتِ
\s2 عَلَ مَتْشْي
\d 
\v 1 تَنتُي بّيتِ
\q1 دُنِحَ بِرِن شَ عَلَتَلَ مَتْشْ!
\q1 
\v 2 وٌ شَ عَلَتَلَ بَتُ سّيوّ كُي.
\q1 وٌ شَ قَ عَ يَ عِ وٌ سّيوّ شُي عِتٍشِ رَ.
\q1 
\v 3 وٌ شَ عَ كٌلٌن عَلَتَلَ نَن وٌ مَرِفِ عَلَ رَ.
\q1 عَ تَن نَن وٌن دَاشِ، وٌن قِندِشِ عَ فبٍ نَن نَ.
\q1 وٌن قِندِشِ عَ شَ حَمَ نَن نَ،
\q1 نَشَن لُشِ عَلْ عَ شَ شُرُ سٍ فْورّ عَ نَشَن دّ مَدٌنمَ.
\b
\q1 
\v 4 وٌ سٌ عَ شَ نَادّيٍ رَ عَ تَنتُقٍ رَ،
\q1 وٌ سٌ عَ شَ هْرْ مْبَنشِ تّتّ كُي عَ مَتْشْقٍ رَ!
\q1 وٌ تَنتُي رَ سِفَ عَ مَ، وٌ عَ شِلِ مَتْشْ،
\q1 
\v 5 بَرِ مَ عَلَتَلَ قَن، عَ شَ شَنُنتٍيَ بُمَ نّ عَبَدَن،
\q1 عَ شَ دُفُتّفّحَ مُ حْنمَ دُنِحَ بّندّ قُحِ قَرِ مَ.
\c 101
\s1 دَوُدَ شَ نَتّيٍ
\s2 عَلَ مَتْشْي
\d 
\v 1 دَوُدَ شَ بّيتِ
\q1 ﭑ دُفُتّفّحَ نُن تِنشِنيِ مَتْشْمَ نّ.
\q1 ﭑ بّيتِ بَمَ عِ تَن نَن بّ عَلَتَلَ.
\q1 
\v 2 ﭑ قٍ بِرِن نَبَمَ لُقٍ رَ تِنشِنتْي شَ كِرَ شْن.
\q1 عِ قَمَ ﭑ يِرٍ مُن تّمُي؟
\q1 ﭑ نَ ﭑ حّرّ مَ نّ ﭑ بْحّ قِيشّشِ رَ ﭑ مَ مِشِيٍ تَفِ.
\q1 
\v 3 ﭑ مُ ﭑ يَ تِمَ قٍ تِنشِنتَرٍ رَ،
\q1 ﭑ مُ تِنمَ يَنقَنتٍ شَ كِرَ رَ،
\q1 ﭑ نُن عٍ تَن مُ لَنمَ قٍ يٌ مَ.
\q1 
\v 4 ﭑ تَن نُن مِشِ حَاشِ تَفِ كُيَ،
\q1 ﭑ مُ وَ مَ يُنُبِ شْن.
\b
\q1 
\v 5 ﭑ مِشِ دّ بَلَنمَ نّ نَشَن عَ بٌورٍ مَقَلَمَ.
\q1 ﭑ مُ تِنمَ يّتّ مَتْشْي نُن يّتّ عِفبٌحَ رَ.
\q1 
\v 6 ﭑ نَ ﭑ حْشْ سَمَ نّ يِ بْشِ دُفُتّفّيٍ شْن مَ،
\q1 عَلَكٌ عٍ شَ لُ ﭑ سّيتِ مَ.
\q1 ﭑ وَ مَ تِنشِنتْييٍ نَن شْن مَ، عٍ شَ ﭑ مَلِ.
\q1 
\v 7 يَنقَنتٍيٍ مُ لُمَ ﭑ مَ مِشِيٍ يَ مَ،
\q1 وُلٍ قَلّيٍ مُ تِمَ ﭑ يَ عِ.
\q1 
\v 8 فّيسّفّ بِرِن ﭑ مِشِ كٌبِيٍ سْنتْمَ نّ،
\q1 عَلَكٌ نَ مِشِ مْولِ نَشَ لُ عَلَتَلَ شَ تَا كُي.
\c 102
\s1 قُرٍ مَ شَ مَشَندِ
\s2 عَلَ مَشَندِ نُن عَلَ مَتْشْي
\d 
\v 1 تْورْ مِشِ نَشَن عَلَتَلَ مَشَندِقٍ عَ شَ تْورّ كُي.
\q1 
\v 2 عَلَتَلَ، عِ شَ ﭑ مَ مَشَندِ سُشُ،
\q1 عِ شَ عِ تُلِ مَتِ ﭑ وَ شُي رَ.
\q1 
\v 3 عِ نَشَ عِ كٌبٍ سٌ ﭑ نَ ﭑ مَ تْورّ كُي.
\q1 عِ شَ ﭑ مَ مَشَندِ سُشُ مَقُرٍن.
\b
\q1 
\v 4 ﭑ مَ سِمَيَ نَ لْيقٍ عَلْ تُورِ لْيمَ كُيٍ مَ كِ نَشّ،
\q1 ﭑ شْرِيٍ نَ حْنقٍ عَلْ يٍفٍ فَنمَ تّ رَ كِ نَشّ،
\q1 
\v 5 ﭑ بْحّ نَ لِسِقٍ عَلْ سّشّ نَشَن نَ قِيلِ مَ.
\q1 ﭑ مُ دٌنسٍ دٌنمَ سْنْن.
\q1 
\v 6 ﭑ نَ وَ ﭑ شُي عِتٍشِ رَ، ﭑ شْرِيٍ بِرِن مَكّنّنمَ نّ.
\q1 
\v 7 ﭑ بَرَ لُ عَلْ شُندِ نَشَن تٌمَ وُلَ عِ،
\q1 عَلْ كٌوقٌلٍ نَشَن نَ بَنشِ تٌنبٌلٌنيِ كُي.
\q1 
\v 8 ﭑ مُ نْمَ شِدٍ.
\q1 ﭑ كِرٌشِ عَلْ شْنِ نَشَن نَ كٍرٍنيِ مَ بَنشِ قَرِ.
\q1 
\v 9 ﭑ يَشُييٍ يٌمَ ﭑ مَ لْشْي بِرِن،
\q1 عٍ ﭑ شِلِ رَوَلِمَ دَنكّ وْيّنيِ رَ.
\q1 
\v 10 ﭑ دّ رَقٍشِ تّشُبٍ رَ عَلْ دٌنسٍ،
\q1 ﭑ يَيٍ سِلْنمَ ﭑ مَ مِنسٍ شُن مَ
\q1 
\v 11 عِ شَ بْحّتٍ نُن عِ شَ شْنّ شَ قٍ رَ.
\q1 عِ بَرَ ﭑ كٍرِ ثٌن!
\q1 
\v 12 ﭑ مَ سِمَيَ بَرَ لُ عَلْ نِينِ نَشَن لْيمَ دِ مِ كُي،
\q1 عَلْ سّشّ نَشَن لِسِمَ قِيلِ مَ.
\b
\q1 
\v 13 كْنْ عِ تَن عَلَتَلَ لُمَ نّ عِ شَ كِبَنيِ كُي عَبَدَن،
\q1 عِ شِلِ مُ لْيمَ دُنِحَ مَ.
\q1 
\v 14 عِ قَمَ نّ كٍلِدٍ عِ شَ كِنِكِنِ سِيٌنِ مَ،
\q1 بَرِ مَ عَ لَنشِ عِ شَ هِننّ عَ رَ يِ وَشَتِ سُفَندِشِ مَ.
\q1 
\v 15 عَ فّمّيٍ نُن عَ بْشِ رَقَن عِ شَ كٌنيِ دِيٍ مَ.
\q1 
\v 16 سِيٍ بِرِن قَمَ فَاشُدٍ عَلَتَلَ شِلِ يَ رَ،
\q1 مَنفّيٍ بِرِن قَمَ عٍ شِنبِ سِندٍ عِ شَ نْرّ يَ رَ.
\q1 
\v 17 عَلَتَلَ مَن قَمَ نّ سِيٌنِ تِدٍ،
\q1 عَ عَ يّتّ مَسٍن عَ شَ نْرّ كُي.
\q1 
\v 18 عَ عَ يَ رَقِندِ مَ نّ مِسِكِينّ شَ مَشَندِ مَ،
\q1 عَ مُ يٌ عَ شَ دُبّ مَ.
\b
\q1 
\v 19 نَ شَ سّبّ بْنسْييٍ بّ نَشٍيٍ قَمَ،
\q1 عَلَكٌ مِشِ نَشٍيٍ مُ دَاشِ سِندٍن عٍ شَ عَلَتَلَ مَتْشْ،
\q1 
\v 20 بَرِ مَ عَ عَ يَ رَفٌرٌ مَ وٌن مَ كٍلِقٍ عَ شَ يِرٍ سّنِيّنشِ عِتٍشِ.
\q1 عَلَتَلَ بْشِ مَتٌمَ كٍلِقٍ كٌورٍ مَ،
\q1 
\v 21 عَلَكٌ عَ شَ فٍيلِمَنِيٍ وَ شُي رَ مّ،
\q1 عَ شَ مِشِيٍ رَتَنفَ نَشٍيٍ نَ قَشّ شَ كِرَ مَ،
\q1 
\v 22 عَلَكٌ عٍ شَ عَلَتَلَ شِلِ مَسٍن سِيٌنِ تَا كُي،
\q1 عٍ شَ عَ مَتْشْ بّيتِ رَ دَرِ سَلَمُ،
\q1 
\v 23 سِيٍ نَ عٍ مَلَن تّمُي نَشّ عَلَتَلَ بَتُقٍ رَ.
\b
\q1 
\v 24 عَ بَرَ ﭑ مَ سّنبّ بَ ﭑ يِ رَ ﭑ مَ دُنِحّءِفِرِ كُي،
\q1 عَ بَرَ ﭑ مَ سِمَيَ رَدُنكٍ.
\q1 
\v 25 ﭑ نَشَ عَ قَلَ عَ بّ، «ﭑ مَرِفِ عَلَ،
\q1 عِ نَشَ ﭑ نِي بَ ﭑ مَ سِمَيَ تَفِ رَ،
\q1 عِ تَن نَشَن بُمَ عَبَدَن،
\q1 
\v 26 عِ تَن نَن دُنِحَ دَا،
\q1 عِ تَن نَن كٌورٍ عِتَلَ عِ شْنيّ رَ.
\q1 
\v 27 عٍ تَن حْنمَ نّ، كْنْ عِ تَن بُمَ نّ عَبَدَن،
\q1 عٍ بِرِن قٌرِ مَ نّ عَلْ سٌسٍ، كْنْ عِ تَن عٍ مَسَرَ مَ نّ عَلْ دٌنمَ.
\q1 عِ عٍ مَسَرَ مَ نّ، عَلْ دٌنمَ نَشَن نَفٌرٌ مَ، عَ وْلّ.
\q1 
\v 28 كْنْ عِ تَن مُ مَسَرَ مَ، عِ مُ حْنمَ عَبَدَن.
\q1 
\v 29 عِ شَ كٌنيِيٍ شَ دِيٍ قَمَ نّ سَبَتِدٍ بٍ،
\q1 عٍ بْنسْي قَ بُ شَشِلِسَ كُي عِ يَ عِ.»
\c 103
\s1 عَلَ شَ مَرَقَنيِ
\s2 عَلَ مَتْشْي
\d 
\v 1 دَوُدَ شَ بّيتِ
\q1 ﭑ شَ عَلَتَلَ تَنتُ ﭑ نِي بِرِن نَ،
\q1 ﭑ شَ عَ شِلِ سّنِيّنشِ مَتْشْ.
\q1 
\v 2 ﭑ شَ عَلَتَلَ تَنتُ ﭑ نِي بِرِن نَ،
\q1 ﭑ نَشَ نّيمُ عَ شَ هِننّ مَ.
\q1 
\v 3 عَ تَن نَن دِحّمَ عِ شَ يُنُبِيٍ مَ،
\q1 عَ عِ شَ قُرٍيٍ رَيَلَن،
\q1 
\v 4 عَ عِ رَتَنفَ قَشّ مَ،
\q1 عَ عِ رَبِلِن عَ شَ شَنُنتٍيَ نُن عَ شَ كِنِكِنِ رَ.
\q1 
\v 5 عَ هِننّمَ عِ رَ عِ شَ دُنِحّءِفِرِ كُي،
\q1 عَلَكٌ عِ مَن شَ سّنبّ سْتْ عِ شَ قٌرِحَ كُي عَلْ سّفّ.
\b
\q1 
\v 6 عَلَتَلَ حّرّ مَ تِنشِنيِ كُي،
\q1 عَ كِيتِ تِنشِنشِ سَمَ تْورْ مِشِيٍ بّ.
\q1 
\v 7 عَ بَرَ عَ شَ كِرَ مَسٍن عَننَبِ مُنسَ بّ،
\q1 عَ عَ شَ كَابَنَكٌييٍ مَسٍن عِسِرَيِلَكَيٍ بّ.
\q1 
\v 8 عَلَتَلَ كِنِكِنِمَ مِشِيٍ مَ، عَ هِننّ عٍ رَ،
\q1 عَ مُ شْنْمَ عٍ مَ مَقُرٍن مَقُرٍن، عَ شَ شَنُنتٍيَ فبٌ.
\q1 
\v 9 عَ مُ مِشِيٍ تْورْ مَ تّمُي بِرِن،
\q1 عَ شَ شْننَنتٍيَ مُ بُمَ.
\q1 
\v 10 عَ مُ وٌن حَشَنكَتَمَ وٌن مَ يُنُبِ رَبَشِ كِ مَ،
\q1 عَ مُ وٌن مَ يُنُبِ سَرٍ رَفبِلٍنمَ وٌن مَ.
\q1 
\v 11 كٌورٍ عِتٍشِ بْشِ شُن مَ كِ نَشّ،
\q1 عَ شَ شَنُنتٍيَ قَن فبٌشِ نَ كِ نّ عَ يَرَفَاشُييٍ بّ.
\q1 
\v 12 سٌفٍتٍدٍ مَكُيَشِ سٌفٍفٌرٌدٍ رَ كِ نَشّ،
\q1 عَ وٌن مَ يُنُبِيٍ قَن مَكُيَشِ وٌن نَ نَ كِ نّ.
\q1 
\v 13 بَبَيٍ كِنِكِنِمَ عٍ شَ دِيٍ مَ كِ نَشّ،
\q1 عَلَتَلَ قَن كِنِكِنِمَ عَ يَرَفَاشُييٍ مَ نَ كِ نّ،
\q1 
\v 14 بَرِ مَ عَ عَ كٌلٌن وٌن يَءِلَنشِ سٍ نَشَن نَ،
\q1 عَ رَتُشِ عَ مَ عَ بّندّ نَن وٌن نَ.
\q1 
\v 15 عَدَ مَدِيٍ شَ سِمَيَ مَنِيَ سَنسِ رَ نَشَن قُفَمَ قِيلِ مَ،
\q1 
\v 16 كْنْ قٌيٍ نَ بْنبْ عَ رَ، عَ شَرَ مَ نّ، عَ لْي.
\q1 
\v 17 كْنْ عَلَتَلَ عَ يَرَفَاشُييٍ شَنُمَ نّ عَبَدَن،
\q1 عَ شَ تِنشِنيِ بِرَ مَ نّ عٍ بْنسْييٍ قْشْ رَ،
\q1 
\v 18 نَشٍيٍ عَ شَ سَاتّ بِنيَمَ،
\q1 عٍ عَ شَ سّرِيّ رَبَتُ.
\q1 
\v 19 عَلَتَلَ بَرَ عَ شَ كِبَنيِ دْشْ كٌورٍ مَ،
\q1 عَ دُنِحَ بِرِن يَمَرِ.
\b
\q1 
\v 20 وٌ تَن مَلٍكّيٍ، وٌ شَ عَلَتَلَ تَنتُ،
\q1 وٌ تَن نَشٍيٍ سّنبّ فبٌ، وٌ تَن نَشٍيٍ عَ رَبَتُمَ.
\q1 
\v 21 وٌ تَن سّنبّمَ نَشٍيٍ نَ كٌورٍ مَ، وٌ شَ عَلَتَلَ تَنتُ،
\q1 وٌ تَن نَشٍيٍ عَ وَشْنقٍ رَبَمَ.
\q1 
\v 22 وٌ تَن بِرِن نَشٍيٍ دَاشِ، وٌ شَ عَلَتَلَ تَنتُ يِرٍ بِرِن عَ شَ مَنفّيَ بُن مَ.
\q1 ﭑ شَ عَلَتَلَ تَنتُ ﭑ نِي بِرِن نَ.
\c 104
\s1 عَلَتَلَ شَ دَالِسٍيٍ
\s2 عَلَ مَتْشْي
\q1 
\v 1 ﭑ شَ عَلَتَلَ تَنتُ ﭑ نِي بِرِن نَ.
\b
\q1 ﭑ مَرِفِ عَلَتَلَ، عِ سّنبّ فبٌ،
\q1 نْرّ نُن يَنبّ نَ عِ مَ،
\q1 
\v 2 عَ لُشِ عَلْ نَءِيَلَنيِ يَتِ قِندِشِ عِ شَ فُبَ نَن نَ.
\q1 عِ كٌورٍ عِتَلَشِ عَلْ دُفِ شُنفبٍ عِ سَبَتِشِ نَشَن بُن مَ،
\q1 
\v 3 عِ شَ كٌنكٌي تِشِ نُشُييٍ قَرِ يٍ رَفَتَشِ دّننَشّ.
\q1 عِ نُشُييٍ قِندِ عِ شَ حّرّ سٍ رَ،
\q1 عِ عِ حّرّ قٌيٍ قَرِ.
\q1 
\v 4 عِ قٌيٍ شّيمَ عِ شَ مَسٍنيِ رَ،
\q1 عِ تّ رَ سَنبَمَ عِ شَ وَلِ رَبَقٍ رَ.
\b
\q1 
\v 5 عَلَ دُنِحَ تِشِ نّ عَلْ بَنشِ تِشِ كِ نَشّ،
\q1 عَ مُ عَ مَمَشَمَ قٍوٌ.
\q1 
\v 6 عَ بَا دُ سُ نّ عَ شُن مَ عَلْ دُفِ،
\q1 عَ فٍيَيٍ شُنتَفِ مَكٌتٌ.
\q1 
\v 7 عِ تٌ شَاحّ يٍ مَ، عَ عَ فِ عِ شَ فَلَنيِ شُي مَ،
\q1 
\v 8 فٍيَيٍ نُن فُلُنبَيٍ قَ لُ يِرٍ عِ نُ وَ دّننَشّ شْن.
\q1 
\v 9 عِ نَانِنيِ سَشِ يٍ بّ عَ مُ تُفَنمَ نَشَن شُن مَ،
\q1 عَلَكٌ عَ نَشَ فبِلٍن دِن نَ شَرٍ مَ.
\b
\q1 
\v 10 عِ دُلٌنيِيٍ قِندِ شُرٍيٍ رَ،
\q1 نَشٍيٍ سُسُمَ فٍيَ لٌنفٌرِيٍ رَ،
\q1 
\v 11 عَ يٍ شْلِ بَ بُرُنيِ سُبٍيٍ بِرِن مَ،
\q1 عَ يٍ شْلِ بَ وُلَءِ سٌقَلٍيٍ مَ.
\q1 
\v 12 شْنِيٍ سَبَتِشِ نٍيٍ قّ مَ،
\q1 عٍ عٍ شُي رَ مِنِمَ وُرِ سَلٌنيِيٍ كْن نَ بُرّشّيٍ لٌنفٌرِ رَ.
\q1 
\v 13 عِ فٍيَيٍ بُندَ مَ يٍ رَ كٍلِ كٌورٍ مَ،
\q1 بْشِ وَ سَمَ عِ شَ وَلِ رَ.
\q1 
\v 14 عِ حٌوفٍ رَ مِنِمَ شُرُ سٍيٍ بّ،
\q1 عِ سَنسِيٍ رَبُلَمَ عَدَ مَدِيٍ بّ،
\q1 عٍ بَلٌي سْتْمَ نَشٍيٍ رَ.
\q1 
\v 15 عِ وّنِ قِمَ مِشِيٍ مَ، نَشَن عٍ بْحّ رَقَنمَ عٍ مَ،
\q1 عِ تُرٍ رَ مِنِمَ عٍ بّ، نَشَن عٍ كِرِ رَتٌقَنمَ،
\q1 عِ عٍ بَلٌمَ دٌنسٍ رَ، نَشَن سّنبّ قِمَ عٍ مَ.
\q1 
\v 16 لِبَن وُرِ بِلِيٍ، مَرِفِ نَشٍيٍ سِشِ،
\q1 عٍ بَرَ يٍ سْتْ عَ قَنيِ رَ،
\q1 
\v 17 شْنِيٍ عٍ تّي سَمَ عٍ كْن نَ.
\q1 فبٌنفبٌي عٍ تّي سَمَ سِثِرّ وُرِ بِلِيٍ كْن نَ،
\q1 
\v 18 وُلَءِ سِيٍ شِمَ فٍيَيٍ قَرِ،
\q1 سَفَلٍيٍ لُمَ فّمّ لٌنفٌرِيٍ رَ.
\b
\q1 
\v 19 عِ كِكٍ يَءِلَنشِ سَلِ وَشَتِيٍ كٌلٌنقٍ نَن نَ.
\q1 سٌفٍ عَ دُلَ تّمُي كٌلٌن.
\q1 
\v 20 عِ دِ مِ رَقَمَ كْي رَ، بُرُن سُبٍيٍ حّرّ مَ تّمُي نَشّ.
\q1 
\v 21 يّتّيٍ نَ عٍ شُي رَ مِنِ دٌنسٍ قٍنقٍ رَ، عَلَ عٍ كِمَ بَلٌي رَ.
\q1 
\v 22 سٌفٍ نّقّ مِنِ، عٍ فبِلٍن عٍ شَ قْنمّيٍ رَ.
\q1 
\v 23 مِشِيٍ تَن مِنِ، عٍ سَ قّيحّن وَلِدٍ.
\b
\q1 
\v 24 عَلَتَلَ، عِ شَ دَالِسٍيٍ وُيَ.
\q1 عِ عٍ بِرِن دَاشِ شَشِلِمَيَ نَن نَ.
\q1 بْشِ رَقٍشِ عِ شَ دَالِسٍيٍ رَ،
\q1 
\v 25 بَا قَن نَقٍشِ عِ شَ دَالِسٍيٍ رَ،
\q1 ندٍيٍ شُرُن، ندٍيٍ شُنفبٌ، عٍ وُيَ.
\q1 
\v 26 كُنكُي شُنفبٍيٍ حّرّ مَ مّننِ قَرِ،
\q1 ثٍرٍ مُي حّرّ مَ بَا بُن مَ حّلّشِنيِ رَ.
\b
\q1 
\v 27 يِ دَالِسٍ بِرِن عٍ شَشِلِ تِشِ عِ تَن نَن نَ عٍ بَلٌي شَ قٍ رَ.
\q1 
\v 28 عِ نَ عٍ كِ، عٍ عَ سْتْمَ نّ عِ سَابُي رَ، عٍ وَ سَ.
\q1 
\v 29 عِ نَ عٍ كُمَ، عٍ فَاشُمَ نّ.
\q1 عِ نَ عٍ حّنفِ بَ، عٍ قَشَمَ نّ، عٍ فبِلٍن بّندّ.
\q1 
\v 30 عِ نَ عِ حّنفِ رَ سٌ عٍ قَتٍ، عٍ مَن بَلٌ،
\q1 بْشِ مَن قَ قَن.
\b
\q1 
\v 31 عَلَتَلَ شَ نْرّ شَ بُ عَبَدَن!
\q1 عَلَتَلَ شَ سّيوَ عَ شَ دَالِيٍ رَ!
\q1 
\v 32 عَ نَ بْشِ مَتٌ، عَ سّرّنمَ نّ،
\q1 عَ نَ دِن فٍيَيٍ رَ، عٍ فَنمَ نّ.
\q1 
\v 33 ﭑ عَلَتَلَ مَتْشْمَ نّ قَننِ ﭑ بَلٌشِ،
\q1 ﭑ بّيتِ بَمَ نّ ﭑ مَرِفِ عَلَ بّ قَننِ ﭑ نَ دُنِحَ مَ.
\q1 
\v 34 ﭑ مَ دُبّ شَ رَقَن عَ مَ.
\q1 ﭑ سّيوَ مَ نّ عَلَتَلَ شَ قٍ رَ.
\q1 
\v 35 كْنْ يُنُبِتْييٍ تَن شَ لْي دُنِحَ مَ.
\q1 مِشِ حَاشِيٍ نَشَ لُ نَا سْنْن!
\q1 ﭑ بَرَ عَلَتَلَ مَتْشْ ﭑ نِي بِرِن نَ.
\q1 وٌ عَلَتَلَ تَنتُ!
\c 105
\s1 عِسِرَيِلَ شَ شْرّيَ
\s2 عَلَ مَتْشْي
\q1 
\v 1 وٌ عَلَتَلَ شِلِ مَتْشْ،
\q1 وٌ عَ شَ كَابَنَكٌي مَسٍن حَمَيٍ تَفِ.
\q1 
\v 2 وٌ بّيتِ بَ عَ بّ عَ شَ كَابَنَكٌييٍ شَ قٍ رَ.
\q1 
\v 3 وٌ شَ سّيوَ عَ شِلِ سّنِيّنشِ شَ قٍ رَ،
\q1 مِشِ نَشٍيٍ عَلَتَلَ قٍنمَ، عٍ شَ حّلّشِن.
\q1 
\v 4 وٌ شَ عَلَتَلَ شَ سّنبّ قٍن،
\q1 وٌ شَ كَتَ لُدٍ عَ يَ عِ تّمُي بِرِن.
\q1 
\v 5 وٌ شَ رَتُ عَ شَ كَابَنَكٌي مَ،
\q1 وٌ نَشَ نّيمُ عَ شَ كِيتِ مَ،
\q1 
\v 6 وٌ تَن عَلَ شَ كٌنيِ عِبُرَهِمَ بْنسْي،
\q1 وٌ تَن يَشُبَ شَ دِيٍ عَ نَشٍيٍ سُفَندِ.
\q1 
\v 7 عَ تَن نَن وٌن مَرِفِ عَلَتَلَ رَ،
\q1 عَ كِيتِ سَمَ دُنِحَ بِرِن مَ.
\b
\q1 
\v 8 عَلَتَلَ عَ رَتُمَ عَ شَ سَاتّ مَ تّمُي بِرِن،
\q1 عَ مُ نّيمُمَ عَ شَ لَايِدِ مَ عَبَدَن،
\q1 
\v 9 عَ نَشَن تٌنفٌشِ عِبُرَهِمَ نُن عِسِيَفَ بّ مَرَكَلِ رَ.
\q1 
\v 10 عَ بَرَ نَ نَتّ تٌنفٌ يَشُبَ بّ،
\q1 عَ بَرَ نَ سَاتّ شِرِ عِسِرَيِلَ رَ،
\q1 
\v 11 عَ مَسٍنقٍ رَ، «ﭑ بَرَ كَنَان بْشِ قِ وٌ مَ كّ رَ.»
\b
\q1 
\v 12 بٍينُ عٍ شَ وُيَ مّننِ،
\q1 
\v 13 عٍ نُ نَ لِنتَنقٍ تُن،
\q1 
\v 14 عَلَ مُ تِن مِشِ يٌ شَ نْ عٍ رَ.
\q1 عَ نَشَ عَ شْرْشْ حَمَنّ مَنفّيٍ بّ عَ قَلَقٍ رَ،
\q1 
\v 15 «وٌ نَشَ ﭑ مَ حَمَ سُفَندِشِ تْورْ دٍ،
\q1 وٌ نَشَ قٍ حَاشِ رَبَ ﭑ مَ نَمِحْنمّيٍ رَ.»
\b
\q1 
\v 16 بٍينُ عَلَ شَ كَامّ رَفٌرٌ دُنِحَ مَ،
\q1 عَ بَلٌي بَ دُنِحَ يِ رَ،
\q1 
\v 17 عَ نَشَ عَ شَ مِشِ ندٍ يُسُقُ رَ سِفَ عٍ يَرَ كٌنيِيَ كُي.
\q1 
\v 18 عَ سَنيِيٍ نُن عَ كْنيِ نُ بَلَنشِ يْلْنشْنيِ رَ،
\q1 
\v 19 هَن عَلَ شَ لَايِدِ نَشَ كَمَلِ،
\q1 عَ نْندِ قِ عَ مَ تّمُي نَشّ.
\q1 
\v 20 نَ تّمُي مَنفّ شُنفبٍ نَشَ يَامَرِ قِ عَ شَ مِنِ فٍيلِ كُي،
\q1 عَ شَ قُلُن.
\q1 
\v 21 مَنفّ نَشَ يُسُقُ قِندِ عَ شَ بَنشِ شُنيِ رَ،
\q1 عَ عَ فبٍ سٍ بِرِن سَ عَ نْي بُن مَ،
\q1 
\v 22 عَلَكٌ مَنفّ شَ مِشِيٍ شَ لُ عَ وَشْن كِ،
\q1 بْشِ قٌرِيٍ شَ شَشِلِ سْتْ عَ سَابُي رَ.
\b
\q1 
\v 23 نَ دَنفِ شَنبِ، عِسِرَيِلَ حَمَ يَشُبَ بْنسْي نَشَ قَ مِسِرَ،
\q1 عٍ سَبَتِ هَمِ شَ بْشِ مَ.
\b
\q1 
\v 24 عَلَ نَشَ عَ شَ حَمَ وُيَ دَنفِقٍ عٍ يَشُييٍ رَ.
\q1 
\v 25 عَ نَشَ مِسِرَكَيٍ بْحّ مَسَرَ،
\q1 هَن عٍ قَ عَ شَ حَمَ شْن، عٍ نَتّ حَاشِ تٌنفٌ عٍ شَ قٍ رَ.
\q1 
\v 26 نَ تّمُي عَ نَشَ عَ شَ كٌنيِ دِ مُنسَ شّي،
\q1 عَ نُن عَ شَ مِشِ سُفَندِشِ هَرُنَ.
\q1 
\v 27 عٍ نَشَ عَلَ شَ تْنشُمَيٍ مَكَابَشِيٍ رَبَ،
\q1 هَمِ شَ بْشِ شَ مِشِيٍ تَفِ.
\q1 
\v 28 عٍ تٌ عَلَ شَ مَسٍنيِ تِ مِسِرَكَيٍ بّ،
\q1 عَلَ نَشَ دِ مِ رَ سِن بْشِ مَ، كُيٍ نَشَ عِقْورْ.
\q1 
\v 29 عَ نَشَ مّننِ يٍ مَقِندِ وُلِ رَ، يّشّيٍ قَ قَشَ.
\q1 
\v 30 عٍ شَ بْشِ نَشَ رَقٍ لَنشَنسَرِ مَيٍ رَ،
\q1 عٍ سٌ هَن مَنفّ شَ بَنشِ كُي.
\q1 
\v 31 عَ نَشَ يَامَرِ قِ شّيرِيٍ نُن سَاسِيٍ شَ دِن بْشِ بِرِن نَ.
\q1 
\v 32 عَ نَشَ بَلَبَلَنيِ نُن تُنّ رَفٌرٌ بْشِ مَ،
\q1 سٍيَمَكْنيِ نَشَ دِن مّننِ رَ.
\q1 
\v 33 عَ نَشَ عٍ شَ وّنِ بِلِيٍ نُن عٍ شَ شْرّ بِلِيٍ كَنَ،
\q1 عَ نُن وُرِ بِلِيٍ بِرِن نَشٍيٍ نُ نَ عٍ شَ بْشِ مَ.
\q1 
\v 34 عَ نَشَ يَامَرِ قِ كَتٌي شَ وُيَ هَن،
\q1 
\v 35 عٍ قَ سَنسِيٍ بِرِن كَنَ مِسِرَ بْشِ مَ،
\q1 عٍ بْشِ دَشَمُي بِرِن دٌن.
\q1 
\v 36 عَ رَحْنيِ عَ نَشَ دِ سِنفٍ بِرِن قَشَ عٍ شَ بْشِ كُي،
\q1 عٍ نَشٍيٍ بَرِ عٍ سّنبّ رَ.
\b
\q1 
\v 37 عَلَ نَشَ عَ شَ حَمَ رَ مِنِ كْبِرِ نُن شّيمَ رَ،
\q1 مِشِ يٌ مُ قَشَ عٍ يَ مَ.
\q1 
\v 38 مِسِرَكَيٍ نَشَ سّيوَ عٍ شَ مِنِ رَ،
\q1 بَرِ مَ عٍ نُ بَرَ فَاشُ عِسِرَيِلَكَيٍ يَ رَ.
\q1 
\v 39 عَلَ نَشَ نُشُي عِتَلَ عٍ شُن مَ يَنيِ رَ،
\q1 عَ تّ تِ كٌورٍ مَ كْي رَ نَءِيَلَنيِ رَ.
\q1 
\v 40 عٍ تٌ عَ مَشَندِ، عَ نَشَ قَ كْنكْلّيٍ رَ عٍ بّ،
\q1 نَشَن قِندِشِ كٌورٍ بَلٌي رَ عٍ بّ.
\q1 
\v 41 عَ نَشَ قَنيٍ رَبِ، عَ يٍ رَ مِنِ عٍ بّ،
\q1 عَلْ شُرٍ نَشَن حّرّ مَ فبٍنفبٍرٍن يِرٍ تَفِ.
\q1 
\v 42 عَلَ تٌ رَتُ عَ شَ لَايِدِ سّنِيّنشِ مَ،
\q1 عَ نَشَن تٌنفٌ عَ شَ كٌنيِ دِ عِبُرَهِمَ بّ،
\q1 
\v 43 عَ نَشَ عَ شَ حَمَ رَ مِنِ سّيوّ كُي،
\q1 عَ عَ رَفِرِ عَ شَ مِشِ سُفَندِشِيٍ شَ حّلّشِن بّيتِ بَ.
\q1 
\v 44 عَ نَشَ سِ فبّتّيٍ شَ بْشِ قِ عٍ مَ،
\q1 حَمَنّيٍ شَ نَاقُلِ نَشَ قِندِ عٍ فبٍ رَ،
\q1 
\v 45 عَلَكٌ عٍ شَ عَلَ شُي سُشُ،
\q1 عٍ شَ عَ شَ يَامَرِيٍ رَبَتُ.
\b
\q1 وٌ شَ عَلَتَلَ مَتْشْ!
\c 106
\s1 نّيمُقٍ عَلَ شَ شَنُنتٍيَ مَ
\s2 عَلَ مَتْشْي
\q1 
\v 1 وٌ شَ عَلَتَلَ مَتْشْ.
\b
\q1 وٌ شَ عَ تَنتُ بَرِ مَ عَ قَن،
\q1 عَ شَ شَنُنتٍيَ بُمَ عَبَدَن.
\q1 
\v 2 ندٍ عَلَتَلَ شَ وَلِ شُنفبٍ مَسٍنمَ،
\q1 ندٍ عَ شَ مَتْشْي بَمَ؟
\q1 
\v 3 سّيوّ نَ تِنشِنتْييٍ بّ،
\q1 نَشٍيٍ بِرَ مَ تِنشِنيِ قْشْ رَ لْشْي بِرِن.
\q1 
\v 4 عَلَتَلَ، عِ شَ رَتُ ﭑ مَ عِ هِننّمَ عِ شَ حَمَ رَ تّمُي نَشّ،
\q1 عِ نَ عٍ رَكِسِ، عِ شَ ﭑ قَن مَلِ،
\q1 
\v 5 عَلَكٌ ﭑ شَ عِ شَ مِشِ سُفَندِشِيٍ شَ هّرِ سْتْ،
\q1 ﭑ شَ سّيوَ عِ شَ حَمَ رَ،
\q1 ﭑ شَ حّلّشِن عِ كّ تٌنفٌمَيٍ يَ مَ.
\b
\q1 
\v 6 مُشُ بَرَ يُنُبِ رَبَ عَلْ مُشُ بٍنبَيٍ،
\q1 مُشُ بَرَ قٍ كٌبِيٍ رَبَ حَاشُحَ كُي.
\q1 
\v 7 مُشُ بٍنبَيٍ تٌ نُ نَ مِسِرَ بْشِ مَ،
\q1 عٍ مُ عٍ حْشْ سَ عِ شَ كَابَنَكٌي شْن مَ،
\q1 عٍ مُ رَتُ عِ شَ شَنُنتٍيَ مَ.
\q1 عٍ نَشَ عٍ كٌبٍ رَ سٌ عِ رَ شُلُنيُمِ بَا قّ مَ.
\q1 
\v 8 كْنْ عَ نَشَ عٍ رَكِسِ عَ شِلِ شَ قٍ رَ،
\q1 عَلَكٌ عَ شَ عَ سّنبّ مَسٍن.
\q1 
\v 9 عَ تٌ شَاحّ شُلُنيُمِ بَا مَ، عَ نَشَ شْرِ،
\q1 عٍ نَشَ عَ عِفِرِ عَ شَرَشِ رَ.
\q1 
\v 10 عَ نَشَ عٍ رَكِسِ عٍ شْنمِشِيٍ بّلّشّ عِ،
\q1 عَ عٍ شُنسَرَ عٍ يَشُييٍ بّلّشّ.
\q1 
\v 11 يٍ نَشَ دُ سُ عٍ يَشُييٍ شُن نَ،
\q1 هَلِ مِشِ كٍرٍن عَ مُ كِسِ.
\q1 
\v 12 نَ كُي عٍ نَشَ لَ عَ شَ مَسٍنيِ رَ،
\q1 عٍ عَ مَتْشْ بّيتِ رَ.
\q1 
\v 13 كْنْ عَ مُ بُ، عٍ مَن نَشَ نّيمُ عَ شَ وَلِيٍ مَ،
\q1 عٍ تٌندِ عَ وَشْنقٍ رَبَدٍ.
\q1 
\v 14 عٍ نَشَ بِرَ عٍ يّتّ وَشْنقٍ قْشْ رَ فبٍنفبٍرٍنيِ مَ،
\q1 عٍ عَلَتَلَ مَتٌ.
\q1 
\v 15 عَ نَشَ عٍ وَشْنسٍ سٌ عٍ يِ رَ،
\q1 كْنْ نَ دَنفِ شَنبِ، عَ نَشَ عٍ رَحْن.
\b
\q1 
\v 16 عَلَ شَ حَمَ نَشَ مُنسَ نُن هَرُنَ تْونّ،
\q1 نَشٍيٍ قِندِشِ عَلَتَلَ شَ كٌنيِ سّنِيّنشِيٍ رَ.
\q1 
\v 17 بْشِ نَشَ عَ رَبِ،
\q1 عَ دَتَن نُن عَبِرَ مِ شَ مِشِيٍ رَفٌرٌ عَ كُي.
\q1 
\v 18 تّ نَشَ عٍ قْشِرَبِرّ حَاشِيٍ فَن.
\q1 
\v 19 عٍ نَشَ نِنفٍ مِسَالِ يَءِلَن وُرٍ رَ،
\q1 عٍ عَ بَتُ كُيٍ رَ.
\q1 
\v 20 نِنفٍ نَشَن سّشّ دٌنمَ،
\q1 عٍ نَشَ نَ مِسَالِ قِندِ عٍ مَرِفِ عَلَتَلَ حْشْي رَ.
\q1 
\v 21 عٍ نَشَ نّيمُ عٍ رَكِسِمَ عَلَ مَ،
\q1 نَشَن قٍ شُنفبٍيٍ رَبَ مِسِرَ،
\q1 
\v 22 نَشَن كَابَنَكٌييٍ رَبَ هَمِ بْشِ مَ،
\q1 نَشَن قٍ مَفَاشُشِيٍ رَبَ شُلُنيُمِ بَا مَ.
\q1 
\v 23 عَلَ نُ وَ مَ عٍ سْنتْقٍ،
\q1 كْنْ عَ شَ مِشِ سُفَندِشِ مُنسَ نَشَ عَ مَشَندِ،
\q1 عَ شَ عَ شَ شْنّ شْرْشْي لُ نَ.
\q1 
\v 24 عٍ نَشَ تٌندِ عَ شَ بْشِ قَنيِ سُشُدٍ،
\q1 عٍ مُ لَ عَ شَ لَايِدِ رَ.
\q1 
\v 25 عٍ نَشَ تِ عَلَتَلَ كَنكٍ عٍ شَ كِرِ بَنشِيٍ كُي،
\q1 عٍ مُ عَ شُي سُشُ.
\q1 
\v 26 نَ كُي عَ نَشَ لَايِدِ تٌنفٌ عٍ بّ،
\q1 عَ شَ عٍ قَشَ فبٍنفبٍرٍنيِ مَ،
\q1 
\v 27 عَ شَ عٍ بْنسْي قَشَ حَمَنّيٍ تَفِ،
\q1 عَ شَ عٍ رَيٍنسٍن دُنِحَ مَ.
\q1 
\v 28 عٍ نَشَ بَلِ ثٍيٌرِ بَتُ،
\q1 عٍ سّرّشّ سُبٍ دٌن نَشَن بَشِ مِشِ قَشَشِيٍ بّ.
\q1 
\v 29 عٍ نَشَ عَلَ رَشْنْ عٍ شَ قٍ كٌبِيٍ رَ،
\q1 هَن عَ نَشَ قُرٍ حَاشِ ندٍ رَفٌرٌ عٍ مَ.
\q1 
\v 30 قِنٍشَسِ تٌ كٍلِ، عَ نَشَ عَلَ مَشَندِ عٍ بّ،
\q1 قُرٍ حَاشِ نَشَ بَ عٍ رَ.
\q1 
\v 31 مِشِ نَشَ نَ تِنشِنيِ كٌلٌن عَ بّ عَبَدَن.
\q1 
\v 32 عَلَتَلَ شَ حَمَ نَشَ عَ رَشْنْ مٍرِبَ شُرٍ قّ مَ.
\q1 عَننَبِ مُنسَ نَشَ تْورْ عٍ شَ قٍ رَ،
\q1 
\v 33 عَ تٌ وْيّن شْرْشْي قَلَ عٍ شَ عَلَ مَتَندِ شَ قٍ رَ.
\b
\q1 
\v 34 عٍ مُ كَنَان سِيٍ سْنتْ عَلْ عَلَتَلَ عٍ يَمَرِ كِ نَشّ.
\q1 
\v 35 عٍ نَشَ سَبَتِ عٍ يَ مَ، عٍ بِرَ عٍ نَامُنيِيٍ قْشْ رَ.
\q1 
\v 36 عٍ نَشَ نٍيٍ شَ كُيٍيٍ بَتُ، نَ قَ قِندِ فَنتَنيِ رَ عٍ بّ.
\q1 
\v 37 عٍ نَشَ عٍ شَ دِ شّمّيٍ نُن عٍ شَ دِ فِنّ بَ سّرّشّ رَ حِننّيٍ بّ.
\q1 
\v 38 عٍ تٌ عٍ شَ دِيٍ قَشَ سّرّشّ رَ كَنَان شَ كُيٍيٍ بّ،
\q1 عٍ نَشَ بْشِ قِندِ بْشِ سّنِيّنتَرٍ رَ.
\q1 
\v 39 عٍ عٍ يّتّ قِندِ مِشِ سّنِيّنتَرٍ رَ نَ كِ نّ،
\q1 عٍ عٍ مَرِفِ يَنقَ.
\b
\q1 
\v 40 نَ كُي عَلَتَلَ نَشَ شْنْ عَ شَ حَمَ مَ،
\q1 عَ كّ تٌنفٌمَيٍ مُ رَقَنشِ عَ مَ سْنْن.
\q1 
\v 41 عَ نَشَ عٍ رَبٌلٌ سِ فبّتّيٍ يِ رَ،
\q1 عٍ يَشُييٍ نَشَ عٍ يَمَرِ.
\q1 
\v 42 عٍ يَشُييٍ نَشَ نْ عٍ رَ،
\q1 عٍ قَ لُ عٍ سّنبّ بُن مَ.
\q1 
\v 43 سَنيَ وُيَشِ عَلَ نَشَ عٍ رَكِسِ،
\q1 كْنْ عٍ مُ فبِلٍن عَ مَتَندِقٍ رَ.
\q1 نَ كُي عٍ نَشَ لْي عٍ شَ يُنُبِيٍ شَ قٍ رَ.
\b
\q1 
\v 44 كْنْ عَلَ نَشَ عٍ تْورّ تٌ،
\q1 عَ نَشَ عٍ وَ شُي مّ.
\q1 
\v 45 عَ نَشَ رَتُ عَ شَ سَاتّ مَ،
\q1 عَ كِنِكِنِ عٍ مَ عَ شَ شَنُنتٍيَ تِلِنشِ شَ قٍ رَ.
\q1 
\v 46 عَ نَشَ عَ نِيَ مِشِيٍ شَ كِنِكِنِ عٍ مَ كٌنيِيَ كُي.
\b
\q1 
\v 47 مُشُ مَرِفِ عَلَتَلَ، مُشُ رَكِسِ.
\q1 عِ شَ مُشُ رَ مِنِ سِيٍ تَفِ،
\q1 عَلَكٌ مُشُ شَ عِ شِلِ سّنِيّنشِ تَنتُ،
\q1 مُشُ شَ سّيوَ عِ مَتْشْقٍ رَ.
\q1 
\v 48 تَنتُي نَ عِسِرَيِلَ مَرِفِ عَلَتَلَ بّ عَبَدَن!
\q1 حَمَ بِرِن شَ عَ قَلَ؛ «عَمِنَ!»
\q1 وٌ شَ عَلَ مَتْشْ!
\c 107
\s1 تَنتُي سّرّشّ كِسِ شَ قٍ رَ
\s2 عَلَ مَتْشْي
\q1 
\v 1 وٌ عَلَتَلَ تَنتُ، بَرِ مَ عَ قَن،
\q1 عَ شَ شَنُنتٍيَ بُمَ عَبَدَن!
\q1 
\v 2 عَلَتَلَ نَشَن شُن سَرَ،
\q1 عَ نَشٍيٍ بَشِ عٍ يَشُييٍ يِ رَ،
\q1 
\v 3 عَ نَشٍيٍ رَ مِنِشِ سِيٍ تَفِ سٌفٍتٍدٍ نُن سٌفٍفٌرٌدٍ مَبِرِ،
\q1 عَ نَشٍيٍ قَشِ كٍلِقٍ كْولَ نُن بَا مَبِرِ،
\q1 عٍ بِرِن شَ عَلَتَلَ تَنتُ.
\b
\q1 
\v 4 ندٍيٍ لْيشِ فبٍنفبٍرٍنيِ مَ،
\q1 عٍ مُ سَبَتِدٍ يٌ تٌشِ.
\q1 
\v 5 كَامّ نُن يٍ شْلِ نُ عٍ هَلَكِمَ،
\q1 لِمَنِيَ نَشَ بَ عٍ يِ.
\q1 
\v 6 عٍ تٌ عٍ دّ رَوَ عَلَتَلَ بّ عٍ شَ تْورّ كُي،
\q1 عَ نَشَ عٍ قُلُن عٍ شَ حَشَنكَتّ مَ.
\q1 
\v 7 عَ نَشَ عٍ رَحّرّ كِرَ تِنشِنشِ ندٍ شْن مَ،
\q1 عَلَكٌ عٍ شَ يِرٍ قَنيِ تٌ عٍ سَبَتِمَ دّننَشّ.
\q1 
\v 8 عٍ شَ عَلَتَلَ تَنتُ عَ شَ شَنُنتٍيَ شَ قٍ رَ،
\q1 نُن عَ شَ كَابَنَكٌييٍ شَ قٍ رَ عَ نَشَن نَبَشِ عَدَ مَدِيٍ بّ،
\q1 
\v 9 بَرِ مَ عَ يٍ شْلِ بَمَ مِشِيٍ مَ،
\q1 عَ كَامّتْييٍ رَوَ سَمَ دٌنسٍ قَنيِيٍ رَ.
\b
\q1 
\v 10 ندٍيٍ نُ سَبَتِشِ دِ مِ كُي نُن قَشّ شَ نْي بُن مَ،
\q1 فٍيلِ شْرْشْي كُي، يْلْنشْنيِ مَبَلَنشِ عٍ مَ.
\q1 
\v 11 بَرِ مَ عٍ مُرُتَ نّ عَلَ شَ مَسٍنيِ شِلِ مَ،
\q1 عٍ عَلَ شَ مَرَ سِ شْن.
\q1 
\v 12 عَ نَشَ عٍ بْحّ مَقِيشّ تْورّ رَ.
\q1 عٍ نَشَ دَفَلَن يّ، مِشِ يٌ مُ عٍ مَلِ.
\q1 
\v 13 عٍ نَشَ مَرِفِ مَشَندِ نِمِسّ كُي،
\q1 عَ نَشَ عٍ رَكِسِ عٍ شَ حَشَنكَتّ مَ.
\q1 
\v 14 عَ نَشَ عٍ رَ مِنِ دِ مِ كُي نُن قَشّ شَ نْي بُنمَ،
\q1 عَ نَشَ لُوتِيٍ بٌلٌن عٍ نُ شِرِشِ نَشٍيٍ رَ.
\q1 
\v 15 عٍ شَ مَرِفِ بَتُ عَ شَ دُفُتّفّحَ شَ قٍ رَ،
\q1 نُن عَ شَ وَلِ مَكَابَشِيٍ شَ قٍ رَ عَدَ مَدِيٍ بّ.
\q1 
\v 16 بَرِ مَ عَ بَرَ وُرٍ نَادّيٍ وُرُ،
\q1 عَ كٌندٌنيِيٍ كَنَ.
\q1 
\v 17 شَشِلِتَرٍيٍ نُ بَرَ عٍ يّتّ سُشُ عٍ شَ مُرُتّ نُن عٍ شَ قٍ حَاشِيٍ رَ، عٍ لُ نِمِسّ كُي.
\q1 
\v 18 دٌنسٍ بِرِن بَرَ نُ رَحَاشُ عٍ مَ،
\q1 عٍ نُ قَ نَ قَشّ نَن دّءِ.
\q1 
\v 19 عٍ شَ نَ شْرْرْي كُي، عٍ نَشَ عٍ شُي رَتٍ عَلَتَلَ مَ،
\q1 عَ نَشَ عٍ رَكِسِ عٍ شَ شْرْرْي مَ.
\q1 
\v 20 عَ نَشَ عَ شَ مَسٍنيِ رَ سَنبَ عٍ مَ، عَ عٍ رَيَلَن،
\q1 عَ عٍ بَ عٍ شَ حَشَنكَتّ كُي.
\q1 
\v 21 عٍ شَ مَرِفِ تَنتُ عَ شَ دُفُتّفّحَ نُن عَ شَ وَلِ مَكَابَشِيٍ شَ قٍ رَ عَدَ مَدِيٍ بّ.
\q1 
\v 22 عٍ شَ سّرّشّيٍ بَ عَ شَ وَلِ قَنيِيٍ كٌلٌن قٍ رَ عَ بّ.
\q1 عٍ مَن شَ عَ شَ وَلِ قَنيِيٍ عِقَلَ عٍ شُي عِتٍشِ رَ سّيوّ كُي!
\q1 
\v 23 نَشٍيٍ نُ بِيَاسِمَ كُنكُي شُنفبٍيٍ كُي بَا مَ،
\q1 عٍ مَن نُ يُلّيَ رَبَ يٍيٍ شُن مَ،
\q1 
\v 24 نٍيٍ بَرَ مَرِفِ وَلِ قْشِيٍ
\q1 نُن عَ شَ وَلِ مَكَابَشِيٍ تٌ بَا مَ.
\q1 
\v 25 عَ نَشَ مَسٍنيِ تِ، تُرُننَادّ قٌيٍ نَشَ كٍلِ
\q1 عَ مْرْنيِيٍ رَ مَشَ،
\q1 
\v 26 عَ نُ بِيَاسِلَيٍ شَ كُنكُي عِتٍ عَ نُ عَ سِن،
\q1 عٍ نُ نَ حَشَنكَتّ كُي.
\q1 
\v 27 عٍ شُن نَشَ مَفِ عَ رَ عٍ نَشَ لُ عَلْ سِيسِلَيٍ.
\q1 عٍ شَ شَشِلِمَيَ بِرِن نَشَ لُ عٍ مَ قُ.
\q1 
\v 28 عٍ شَ نِمِسّ كُي عٍ نَشَ مَرِفِ شِلِ عٍ شُي عِتٍشِ رَ،
\q1 عَ نَشَ عٍ رَتَنفَ نَ فبَلٌي مَ.
\q1 
\v 29 عَ نَشَ تُرُننَادّ قٌيٍ عِتِ، عَ عَ مَسَبَرِ،
\q1 مْرْنيِيٍ نَشَ عٍ رَشَرَ.
\q1 
\v 30 عٍ نَشَ سّيوَ نٍيٍ شَ مَرَشَرّ رَ،
\q1 عَ نَشَ عٍ شُنتِ عٍ وَشْندٍ رَ.
\q1 
\v 31 عٍ شَ مَرِفِ تَنتُ عَ شَ دُفُتّفّحَ نُن عَ وَلِ مَكَابَشِيٍ شَ قٍ رَ عَدَ مَدِيٍ بّ!
\q1 
\v 32 عٍ شَ عَ شَ قٍ فبٌ حَمَ بّ،
\q1 عٍ شَ عَ مَتْشْ قٌرِيٍ شَ مَلَنيِ!
\q1 
\v 33 عَ شُرٍ شُنفبٍيٍ مَسَرَ مَ فبٍنفبٍرٍنيِ رَ،
\q1 عَ دُلٌنيِ قِندِ بْشِ مَشَرٍ رَ.
\q1 
\v 34 عَ بْشِ قَنيِ قِندِ مَ قْشْي يِرٍ رَ،
\q1 نَ بْشِكَيٍ شَ قٍ حَاشِ شَ قٍ رَ.
\q1 
\v 35 عَ فبٍنفبٍرٍنيِ قِندِ مَ شُرٍ رَ
\q1 عَ يِرٍ مَشَرٍ قِندِ شُرٍ فُلِ رَ،
\q1 
\v 36 عَ كَامّتْييٍ رَ سَبَتِ نَا،
\q1 عٍ تَا تِ نَا عٍ سَبَتِدٍ.
\q1 
\v 37 عٍ شّ سَمَ، عٍ وُرِ بِلِيٍ سِمَ
\q1 نَشٍيٍ بٌفِ بَرَكَمَ.
\q1 
\v 38 عَ دُبَمَ عٍ بّ، عٍ وُيَ،
\q1 عَ مُ سٍسٍ بَمَ عٍ شَ شُرُ سٍ كْنتِ رَ.
\q1 
\v 39 ندٍيٍ فبٍيٍ شُرُنمَ،
\q1 تْورّ نُن حَشَنكَتّ رَ.
\q1 
\v 40 عَ مَرَحَاشُي دُ سُمَ قٌرِيٍ شُن نَ،
\q1 عَ عٍ رَلْي فبٍنفبٍرٍنيِ مَ كِرَيٍ مُ دّننَشّ مَ،
\q1 
\v 41 عَ مِسِكِينّيٍ بَمَ تْورّ كُي،
\q1 عَ عٍ شَ دٍنبَيَيٍ رَوُيَ عَلْ شُرُ سٍيٍ.
\q1 
\v 42 مِشِ تِنشِنشِيٍ نَ تٌمَ عٍ حّلّشِنمَ عَ رَ،
\q1 كْنْ تِنشِنتَرٍيٍ بِرِن دّ بَلَنمَ نّ.
\q1 
\v 43 شَشِلِمَ نَشَن نَ، عَ شَ عَ حْشْ سَ يِ قٍ بِرِن شْنمَ،
\q1 عَ شَ مَرِفِ شَ دُفُتّفّحَ قَهَامُ.
\c 108
\s1 شُننَكٍلِ عَلَ سَابُي رَ
\s2 عَلَ مَشَندِ
\d 
\v 1 دَوُدَ شَ بّيتِ
\q1 
\v 2 عَلَ، ﭑ بَرَ نَتّ تٌنفٌ ﭑ بْحّ كُي.
\q1 ﭑ مَرِفِ شُننَكٍلِ كَنيِ، ﭑ ﭑ شُي رَ مِنِمَ نّ بّيتِيٍ رَ.
\q1 
\v 3 ﭑ ﭑ مَ كْرَيٍ نُن ﭑ مَ مَشَسٍيٍ بٍرٍ مَ نّ سُبَشّ مَ.
\q1 
\v 4 ﭑ مَرِفِ، ﭑ عِ بَتُمَ نّ سِيٍ تَفِ،
\q1 ﭑ عِ مَتْشْمَ نّ بّيتِ رَ حَمَنّيٍ يَ مَ،
\q1 
\v 5 بَرِ مَ عِ شَ دُفُتّفّحَ فبٌ دَنفِ كٌورٍ رَ،
\q1 عِ شَ شَنُنتٍيَ عِتٍ عَلْ نُشُييٍ.
\b
\q1 
\v 6 عَلَ، عِ شُنيِ رَكٍلِ كٌورٍ مَ،
\q1 عِ شَ نْرّ شَ لُ بْشِ بِرِن شُن مَ،
\q1 
\v 7 عَلَكٌ عِ شَنُنتٍنيِيٍ شَ كِسِ عِ سّنبّ سَابُي رَ.
\q1 يَندِ، ﭑ مَ دُبَ سُشُ.
\b
\q1 
\v 8 عَلَ بَرَ وْيّن عَ شَ لِنفِرَ سّنِيّنشِ كُي،
\q1 «ﭑ ﭑ شُن نَكٍلِمَ نّ،
\q1 ﭑ سِكٍمِ بْشِ عِتَشُن،
\q1 ﭑ سُكْتِ فُلُنبَ سْتْمَ نّ.
\q1 
\v 9 ﭑ فبٍ نَن فَلَدِ رَ، ﭑ فبٍ نَن مَنَسِ رَ.
\q1 عٍقِرَ مِ بْشِ تَن لُمَ نّ عَلْ ﭑ شُن مَكَنتَسٍ،
\q1 يُدَيَ قِندِ ﭑ مَ مُنيَاتِ رَ.
\q1 
\v 10 ﭑ ﭑ سَنيِ مَشَمَ مٌوَبَ بْشِ مَ،
\q1 ﭑ ﭑ مَ سَنكِرِ وٌلِمَ عٍدٌن نَن مَ عَ شَ قِندِ ﭑ فبٍ رَ.
\q1 ﭑ فٍرٍ تِ شُي مّمَ نّ قِلِسِتَ بْشِ مَ.»
\b
\q1 
\v 11 «ندٍ ﭑ شُن تِمَ تَا مَكَنتَشِ رَ؟
\q1 ندٍ ﭑ شَنِنمَ عٍدٌن بْشِ مَ؟
\q1 
\v 12 عَلَ مُ عَ رَ، نَشَن مُشُ رَبّحِنشِ فٍرٍ كُي؟
\q1 
\v 13 عِ شَ قَ مُشُ مَلِدٍ، عِ شَ مُشُ بَ مُشُ يَشُييٍ يِ رَ.
\q1 عَدَ مَدِيٍ شَ مَلِ قُقَقُ نَ عَ رَ.
\q1 
\v 14 وٌن قَمَ وٌن سّنبّ رَ مِنِدٍ عَلَ شَ مَلِ سَابُي رَ.
\q1 عَ تَن نَن قَمَ وٌن يَشُييٍ عِوُرُدٍ.»
\c 109
\s1 تْوحّفّلَ شَ مَشَندِ
\s2 عَلَ مَشَندِ
\d 
\v 1 دَوُدَ شَ بّيتِ بّيتِبَيٍ شَ مَنفّ بّ
\q1 ﭑ مَرِفِ عَلَ، ﭑ نَشَن مَتْشْمَ، عِ نَشَ لُ دُندُي كُي،
\q1 
\v 2 بَرِ مَ مِشِ حَاشِيٍ نَ وُلٍ قَلَقٍ ﭑ شُن مَ.
\q1 عٍ دّ مُ قَن، عٍ وُلٍ قَلَ تُن.
\q1 
\v 3 عٍ نَ ﭑ نَبِلِنقٍ شْننَنتٍيَ وْيّنيِيٍ رَ،
\q1 هَلِ ﭑ مُ قٍ حَاشِ يٌ رَبَشِ عٍ رَ.
\q1 
\v 4 ﭑ نَ قٍ قَنيِ رَبَ عٍ بّ، عٍ ﭑ فٍرٍ.
\q1 ﭑ عَ رَفبِلٍنمَ عِ تَن عَلَ نَن مَ.
\q1 
\v 5 عٍ ﭑ مَ وَلِ قَنيِ سَرٍ رَفبِلٍنمَ ﭑ مَ عَ كٌبِ رَ،
\q1 ﭑ مَ شَنُنتٍيَ، عٍ نَ مَسَرَ مَ ﭑ بّ شْننَنتٍيَ رَ.
\b
\q1 
\v 6 عِ شَ نَ تْوحّفّتْي تَشُ مِشِ كٌبِ ندٍ رَ،
\q1 عَ دّقَنبٌورٍ شَ عَ يَنقَ.
\q1 
\v 7 عَ نَ مَكِيتِ، كِيتِ شَ كَنَ عَ رَ.
\q1 عِ نَشَ عَ شَ مَشَندِ سُشُ.
\q1 
\v 8 عَ شَ سِمَيَ شَ دُنكٍ كْتِ.
\q1 مِشِ فبّتّ شَ عَ شَ وَلِ تٌنفٌ.
\q1 
\v 9 عَ شَ دِيٍ شَ قِندِ كِرِدِيٍ رَ،
\q1 عَ شَ فِنّ شَ قِندِ كَاحّ رَ.
\q1 
\v 10 عَ شَ دِيٍ شَ قِندِ حّرّتِيٍ رَ نَشٍيٍ كُلّ مَتِمَ تُن.
\q1 عٍ شَ مَكُيَ عٍ بَرِدٍ رَ نَشَن بَرَ كَنَ.
\q1 
\v 11 دٌنِقَ شَ عَ كّ بِرِن تٌنفٌ،
\q1 عَ شَ فٍينِ بِرِن شَ قِندِ سِ فبّتّيٍ فبٍ رَ.
\q1 
\v 12 مِشِ يٌ نَشَ كِنِكِنِ عَ مَ،
\q1 مِشِ يٌ نَشَ هِننّ عَ شَ كِرِدِيٍ رَ.
\q1 
\v 13 عَ بْنسْي شَ سْنتْ،
\q1 عٍ شِلِيٍ شَ نّيمُ مِشِيٍ رَ.
\q1 
\v 14 عَلَتَلَ شَ رَتُ عَ شَ قٍ كٌبِيٍ مَ،
\q1 عَ نفَ شَ يُنُبِ نَشَ شَقَرِ.
\q1 
\v 15 عَلَتَلَ شَ رَتُ نَ يُنُبِيٍ مَ تّمُي بِرِن،
\q1 عَ شَ عٍ شَ قٍ رَنّيمُ دُنِحَ رَ،
\q1 
\v 16 بَرِ مَ عٍ مُ دُفُتّفّحَ رَكَمَلِمَ،
\q1 عٍ مِسِكِينّيٍ نُن قُشَرِلَيٍ تْورْ مَ،
\q1 هَن عٍ قَشَ سُننُنيِ كُي.
\q1 
\v 17 نَشَن مِشِ دَنكَمَ، نَ كَنيِ شَ دَنكّ سْتْ.
\q1 نَشَن دُبَمَ مِشِيٍ بّ، عَ شَ بَرَكّ سْتْ.
\q1 
\v 18 دَنكّ شَ رَفٌرٌ عَ مَ
\q1 عَلْ عَ دٌنمَ رَفٌرٌ مَ عَ مَ كِ نَشّ.
\q1 عَ شَ سٌ عَ قَتٍ عِ عَلْ يٍ،
\q1 عَ شَ سٌ عَ شْرِيٍ عَلْ تُرٍ.
\q1 
\v 19 عَ شَ لُ عَ مَ عَلْ عَ شَ سٌسٍ لُمَ عَ مَ كِ نَشّ،
\q1 عَ شَ بِلِن عَ مَ عَلْ عَ بّلّتِ بِلِنمَ عَ تَفِ كِ نَشّ تّمُي بِرِن.
\q1 
\v 20 عَلَتَلَ شَ نَ سَرٍ قِ ﭑ مَ يَشُييٍ بّ،
\q1 نَشٍيٍ قٍ كٌبِ قَلَمَ ﭑ شُن مَ.
\b
\q1 
\v 21 كْنْ عِ تَن ﭑ مَرِفِ عَلَتَلَ،
\q1 عِ شَ هِننّ ﭑ نَ عِ شِلِ شَ قٍ رَ،
\q1 عِ شَ ﭑ نَكِسِ عِ شَ دُفُتّفّحَ قَنيِ سَابُي رَ.
\q1 
\v 22 ﭑ لُشِ نّ عَلْ مِسِكِينّ قُشَرِلَ،
\q1 نَشَن بْحّ نَ تْورْقٍ كِ قَنيِ رَ.
\q1 
\v 23 ﭑ مَ قٍ حْنقٍ عَلْ نِينِ نَشَن كُيَمَ نُنمَرٍ رَ.
\q1 مِشِ ﭑ كٍرِ مَ عَلْ كَتٌي كٍرِ مَ كِ نَشّ.
\q1 
\v 24 ﭑ شِنبِيٍ سّرّنمَ، ﭑ قَتٍ حْنمَ،
\q1 سُنيِ شَ قٍ رَ.
\q1 
\v 25 عٍ ﭑ نَيَافِمَ تّمُي بِرِن.
\q1 عٍ نَ ﭑ تٌ، عٍ يٌمَ ﭑ مَ تُن.
\q1 
\v 26 ﭑ مَرِفِ عَلَ، عِ شَ ﭑ مَلِ،
\q1 عِ شَ ﭑ نَكِسِ عِ شَ دُفُتّفّحَ شَ قٍ رَ.
\q1 
\v 27 عٍ شَ عَ كٌلٌن، عِ سّنبّ نَ ﭑ مَلِقٍ.
\q1 
\v 28 عٍ تَن ﭑ دَنكَمَ،
\q1 كْنْ عِ بَرَكّ نَن قِمَ ﭑ مَ.
\q1 يَافِ قَمَ نّ دُ سُدٍ عٍ شُن نَ،
\q1 كْنْ ﭑ تَن عِ شَ كٌنيِ دِ، ﭑ سّيوَ مَ نّ.
\q1 
\v 29 ﭑ يَشُييٍ شَ عِقُ،
\q1 عٍ شَ يَافِ شَ دُ سُ عٍ شُن نَ.
\q1 
\v 30 ﭑ عَلَتَلَ تَنتُمَ نّ ﭑ شُي عِتٍشِ رَ،
\q1 ﭑ عَ مَتْشْمَ نّ حَمَ يَ مَ،
\q1 
\v 31 بَرِ مَ عَ تِشِ مِسِكِينّ سّيتِ مَ،
\q1 عَ شَ عٍ رَتَنفَ مِشِيٍ مَ نَشٍيٍ وَ مَ عٍ قَشَقٍ.
\c 110
\s1 عَلَتَلَ نَن مَنفّ شُنفبٍ دْشْمَ
\s2 عَلَ مَتْشْي
\d دَوُدَ شَ بّيتِ
\q1 
\v 1 عَلَتَلَ شَ مَسٍنيِ ﭑ مَرِفِ بّ؛
\q1 «عِ مَفٌرٌ ﭑ يِقَنيِ مَ،
\q1 هَن ﭑ شَ عِ سَنيِ تِ عِ يَشُييٍ قَرِ.»
\b
\q1 
\v 2 عَلَتَلَ عِ سّنبّ رَفبٌمَ نّ كٍلِقٍ سِيٌنِ،
\q1 هَن عِ عِ يَشُييٍ يَمَرِ.
\q1 
\v 3 عِ شَ سْورِيٍ لُمَ نّ عِ قْشْ رَ فٍرٍ كُي.
\q1 نَ كُيٍ نَ عِبَ سُبَشّ مَ،
\q1 عِ سّنبّ فبٌمَ نّ سّنِيّنيِ كُي عَلْ عِ قٌنِكٍ وَشَتِ.
\b
\q1 
\v 4 عَلَتَلَ بَرَ عَ كَلِ يِ لَايِدِ رَ،
\q1 نَشَن مُ كَنَمَ؛
\q1 «ﭑ بَرَ عِ قِندِ سّرّشّدُبّ رَ عَبَدَن،
\q1 عَ مٍلٍكِسٍدٍكِ دَاشِ.»
\q1 
\v 5 مَرِفِ لُمَ عِ يِقَنيِ مَ،
\q1 عَ مَنفّيٍ كَنَمَ نّ عَ شَ شْنّ لْشْي.
\q1 
\v 6 عَ عَ شَ كِيتِ رَحّرّ مَ نّ حَمَنّيٍ قَرِ،
\q1 عَ عٍ سْنتْ، عَ مَنفّ شُنفبٍ ندٍ شُن نَكَنَ.
\b
\q1 
\v 7 مَنفّ شُرٍ يٍ مِنمَ كِرَ عِ.
\q1 عَ شُن نَكٍلِمَ نَ نَن مَ.
\c 111
\s1 عَلَ مَتْشْمَ قٍ نَشٍيٍ مَ
\s2 عَلَ مَتْشْي
\q1 
\v 1 وٌ عَلَتَلَ مَتْشْ!
\b
\q1 ﭑ عَلَتَلَ بَتُمَ نّ ﭑ بْحّ بِرِن نَ،
\q1 تِنشِنتْييٍ نُن حَمَ يَ مَ.
\q1 
\v 2 مَرِفِ شَ وَلِيٍ مَكَابَ.
\q1 عٍ رَقَن مِشِيٍ مَ نَشٍيٍ تِنمَ عٍ مَتٌدٍ.
\q1 
\v 3 عَ شَ وَلِيٍ نْرْشِ،
\q1 عَ شَ تِنشِنيِ بُمَ نّ عَبَدَن.
\q1 
\v 4 عَ عَ نِيَ بِرِن شَ رَتُ عَ شَ كَابَنَكٌي مَ.
\q1 عَلَتَلَ هِننّمَ عَدَ مَدِيٍ رَ، عَ كِنِكِنِ عٍ مَ.
\q1 
\v 5 عَ بَلٌي قِمَ مِشِ مَ نَشَن فَاشُمَ عَ يَ رَ،
\q1 عَ رَتُ عَ شَ سَاتّ مَ عَبَدَن.
\q1 
\v 6 عَ بَرَ عَ شَ وَلِ سّنبّ مَسٍن عَ شَ حَمَ بّ،
\q1 حَمَنّ فبّتّيٍ كّ سٌقٍ رَ عٍ يِ.
\q1 
\v 7 عَ وَلِمَ نْندِ نُن تِنشِنيِ نَن قَرِ.
\q1 عَ شَ يَامَرِيٍ قِندِ مَ سّرِيّ قَنيِ نَن نَ،
\q1 
\v 8 نَشٍيٍ مُ كَنَمَ عَبَدَن،
\q1 عَدَ مَدِيٍ لَنمَ عٍ شَ نَشٍيٍ رَكَمَلِ.
\q1 
\v 9 عَ بَرَ عَ شَ حَمَ شُن سَرَ،
\q1 عَ بَرَ عَ شَ سَاتّ مَبَنبَن عَبَدَن.
\q1 عَ شِلِ سّنِيّن، عَ مَفَاشُ.
\b
\q1 
\v 10 شَشِلِمَيَ قْلْمَ عَلَتَلَ يَرَفَاشُي نَن مَ.
\q1 مِشِ نَشَن فَاشُمَ عَلَ يَ رَ،
\q1 عَ شَشِلِ قَنيِ سْتْمَ نّ.
\q1 عَدَ مَدِيٍ لَنمَ عٍ شَ عَ مَتْشْ عَبَدَن.
\c 112
\s1 تِنشِنتْي سَرٍ
\s2 عَلَ مَتْشْي
\q1 
\v 1 وٌ مَرِفِ عَلَ مَتْشْ!
\q1 هّيرِ نَ مِشِ بّ نَشَن فَاشُمَ مَرِفِ يَ رَ،
\q1 نَشَن تِنمَ عَ شَ يَامَرِيٍ رَبَتُدٍ.
\b
\q1 
\v 2 عَ بْنسْي سّنبّ فبٌمَ نّ بْشِ مَ.
\q1 بَرَكّ لُمَ تِنشِنتْي نَن مَ.
\q1 
\v 3 نَاقُلِ نُن بَننَيَ لُمَ عَ يِ رَ،
\q1 عَ شَ تِنشِنيِ شَنشِ عَبَدَن.
\q1 
\v 4 يَنبّ مِنِمَ دِ مِ كُي تِنشِنتْي بّ،
\q1 نَشَن كِنِكِنِمَ عَ بٌورٍ مَ،
\q1 نَشَن هِننّمَ عَدَ مَدِيٍ رَ،
\q1 نَشَن لُمَ حّرّ رَ تِنشِنيِ كُي.
\q1 
\v 5 بَرَكّ لُمَ مِشِ بّ نَشَن مِشِيٍ كِمَ،
\q1 نَشَن تِنمَ مِشِ دٌنِدٍ،
\q1 نَشَن وَلِمَ تِنشِنيِ رَ.
\q1 
\v 6 نَ كَنيِ مُ بِرَ مَ،
\q1 مِشِيٍ مُ نّيمُمَ عَ شَ تِنشِنيِ مَ.
\q1 
\v 7 عَ مُ فَاشُمَ شِبَارُ حَاشِ يَ رَ،
\q1 بَرِ مَ عَ شَشِلِ تِشِ عَلَتَلَ رَ، عَ بْحّ شَنشِ.
\q1 
\v 8 عَ بْحّ رَشَرَ، فَاشُي يٌ مُ عَ مَ.
\q1 عَ رَحْنيِ، عَ نْمَ نّ عَ يَشُييٍ رَ.
\b
\q1 
\v 9 عَ مِسِكِينّ كِمَ،
\q1 عَ حّرّ مَ تِنشِنيِ كُي تّمُي بِرِن،
\q1 عَ شُن نَكٍلِمَ تُن.
\q1 
\v 10 مِشِ حَاشِ تْورْ مَ نَ تٌقٍ رَ،
\q1 عَ عَ حِنيِ مَشِنمَ،
\q1 عَ شَ قٍ شُن نَكَنَمَ.
\q1 مِشِ حَاشِيٍ شَ نَتّ مُ كَمَلِمَ قٍقٍ مَ.
\c 113
\s1 عَلَتَلَ مَنِيّ مُ نَ
\s2 عَلَ مَتْشْي
\q1 
\v 1 وٌ عَلَتَلَ مَتْشْ!
\q1 عَلَتَلَ شَ كٌنيِ دِيٍ، وٌ شَ عَ مَتْشْ.
\q1 وٌ عَلَتَلَ شِلِ مَتْشْ.
\q1 
\v 2 تَنتُي نَ عَلَتَلَ بّ عَبَدَن.
\q1 
\v 3 تَنتُي نَ عَلَتَلَ بّ يِرٍ بِرِن،
\q1 كٍلِقٍ سٌفٍتٍدٍ مَبِرِ، هَن سٌفٍفٌرٌدٍ.
\b
\q1 
\v 4 عَلَتَلَ شَ نْي نَ حَمَنّيٍ شُن مَ،
\q1 عَ شَ نْرّ نَ كٌورٍ مَ.
\q1 
\v 5 ندٍ مَنِيّ وٌن مَرِفِ عَلَتَلَ رَ،
\q1 نَشَن مَفٌرٌشِ عَ شَ كِبَنيِ كُي كٌورٍ مَ،
\q1 
\v 6 نَشَن عَ يَ رَفٌرٌ مَ كٌورٍ نُن بْشِ مَ.
\b
\q1 
\v 7 عَ مِسِكِينّ شُن نَكٍلِمَ،
\q1 عَ تْورْ مِشِ بَمَ عَ شَ سٍتَرٍحَ كُي.
\q1 
\v 8 عَ عَ تِمَ عَ شَ كُنتِفِيٍ سّيتِ مَ.
\q1 
\v 9 عَ دِ فبٍفبٍ قِمَ فِنّ دِبَرِتَرٍ مَ،
\q1 عَلَكٌ عَ شَ سّيوَ سْتْ عَ شَ دِيٍ يَ مَ.
\b
\q1 وٌ عَلَتَلَ مَتْشْ!
\c 114
\s1 عِسِرَيِلَ بْشِ عَلَ شَ حَمَ رَ سّنّقٍ
\s2 عَلَ مَتْشْي
\q1 
\v 1 يَشُبَ بْنسْي نَشَن قِندِشِ عِسِرَيِلَ رَ،
\q1 عٍ نَشَ مِنِ مِسِرَ شَ كٌنيِيَ رَ،
\q1 
\v 2 عٍ سَبَتِ يُدَيَ عَلَ شَ هْرْ مْلِنفِرَ لُشِ دّننَشّ.
\q1 عِسِرَيِلَ بْشِ نَشَ قِندِ عَلَ شَ مَنفّيَ رَ.
\b
\q1 
\v 3 شُلُنيُمِ بَا تٌ عِسِرَيِلَ حَمَ تٌ،
\q1 عَ نَشَ رَبِ مَقُرٍن.
\q1 يُرُدّن شُرٍ تٌ عٍ تٌ قَ رَ،
\q1 عَ مَن نَشَ كِرَ قِ عٍ مَ.
\q1 
\v 4 عِسِرَيِلَ فٍيَيٍ تٌ عٍ تٌ،
\q1 عٍ نَشَ تُفَن تُفَن حّلّشِنيِ رَ،
\q1 عَلْ يّشّي كٌنتٌنيِيٍ نُن يّشّي يْرّيٍ تُفَنمَ كِ نَشّ.
\b
\q1 
\v 5 مُنسٍ عَ نِيَشِ نَ بَا شَ رَبِ مَقُرٍن؟
\q1 مُنسٍ عَ نِيَشِ يُرُدّن شُرٍ كِرَ قِشِ عٍ مَ؟
\q1 
\v 6 مُنسٍ عَ نِيَشِ عِسِرَيِلَ فٍيَيٍ شَ حّلّشِن
\q1 عَلْ يّشّي كٌنتٌنيِيٍ نُن يّشّيٍ يْرّيٍ؟
\b
\q1 
\v 7 دُنِحَ بِرِن شَ سّرّن مَرِفِ يَ رَ،
\q1 نَشَن قِندِ يَشُبَ مَرِفِ عَلَ رَ،
\q1 
\v 8 نَشَن يٍ دُلٌنيِ رَ مِنِ قَنيٍ شْرْشْي كُي.
\c 115
\s1 عَلَتَلَ فبٌ كُيٍيٍ بّ
\s2 عَلَ مَتْشْي
\q1 
\v 1 مَتْشْي مُ لَنمَ مُشُ تَن بّ،
\q1 مَتْشْي لَنمَ عَلَتَلَ نَن بّ،
\q1 عَ شَ هِننّ نُن دُفُتّفّحَ شَ قٍ رَ.
\q1 
\v 2 مُنقٍ رَ حَمَنّيٍ عَ قَلَمَ،
\q1 «عٍ شَ عَلَ نَ مِندٍن؟»
\q1 
\v 3 مُشُ مَرِفِ عَلَ نَ كٌورٍ مَ،
\q1 عَ عَ وَشْنقٍ بِرِن نَبَمَ.
\b
\q1 
\v 4 كْنْ عٍ شَ كُيٍيٍ يَءِلَنشِ شّيمَ نُن فبٍتِ نَن نَ،
\q1 عٍ يّتّ بّلّشّيٍ سَابُي رَ.
\q1 
\v 5 دّ نَ عٍ بّ، كْنْ عٍ مُ وْيّنمَ،
\q1 يَ نَ عٍ بّ، كْنْ عٍ مُ سٍ تٌمَ،
\q1 
\v 6 تُلِ نَ عٍ بّ، كْنْ عٍ مُ شُي مّمَ،
\q1 حْي نَ عٍ بّ، كْنْ عٍ مُ سٍ شِرِ مّمَ.
\q1 
\v 7 بّلّشّ نَ عٍ بّ، كْنْ عٍ مُ سٍ مَسُشُمَ،
\q1 سَنيِ نَ عٍ بّ، كْنْ عٍ مُ عٍ حّرّ مَ.
\q1 شُي يٌ مُ مِنِمَ عٍ كْن نَ!
\q1 
\v 8 عٍ يَءِلَنمَيٍ قَمَ نّ لُدٍ عَلْ عٍ تَن.
\q1 مِشِ نَشٍيٍ عٍ شَشِلِ تِمَ عٍ رَ عٍ قِندِ مَ سّنبّتَرٍيٍ نَن نَ.
\b
\q1 
\v 9 عِسِرَيِلَ بْنسْي، عِ شَشِلِ تِ عَلَتَلَ رَ،
\q1 نَشَن قِندِ عِ شَ دّ مّرِ نُن عِ كَنتَمَ رَ.
\q1 
\v 10 هَرُنَ بْنسْي، عِ شَشِلِ تِ عَلَتَلَ رَ،
\q1 نَشَن قِندِ عِ شَ دّ مّرِ نُن عِ كَنتَمَ رَ.
\q1 
\v 11 وٌ تَن نَشٍيٍ قِندِشِ عَلَ يَرَفَاشُييٍ رَ،
\q1 وٌ وٌ شَشِلِ تِ عَلَتَلَ رَ،
\q1 نَشَن قِندِ عِ شَ دّ مّرِ نُن عِ كَنتَمَ رَ.
\b
\q1 
\v 12 مَرِفِ عَ حْشْ سَشِ وٌن شْن مَ.
\q1 عَ وٌن بَرَكَمَ نّ.
\q1 عِسِرَيِلَ بْنسْي يٌ، هَرُنَ بْنسْي يٌ،
\q1 
\v 13 نُن عَلَ يَرَفَاشُييٍ بِرِن يٌ،
\q1 عٍ بَرَكّ سْتْمَ نّ.
\b
\q1 
\v 14 عَلَتَلَ شَ وٌ تَن نُن وٌ شَ دِيٍ يِرِوَ.
\q1 
\v 15 عَلَتَلَ نَشَن كٌورٍ نُن بْشِ دَا،
\q1 عَ شَ بَرَكّ قِ وٌ مَ.
\b
\q1 
\v 16 عَلَتَلَ نَن فبٍ كٌورٍ رَ،
\q1 كْنْ عَ نَشَ دُنِحَ تَن قِ عَدَ مَدِيٍ مَ.
\q1 
\v 17 مِشِ قَشَشِيٍ شَ مُ عَلَتَلَ مَتْشْمَ،
\q1 مِشِ نَشٍيٍ سِفَمَ عَلِفِيَمَ عٍ مُ نْمَ مَتْشْي رَبَدٍ،
\q1 
\v 18 كْنْ وٌن تَن نَشٍيٍ نَ دُنِحَ،
\q1 عَ لَنمَ وٌن شَ تَنتُي رَ سِفَ عَلَتَلَ مَ،
\q1 قْلْ يِ تّمُي مَ هَن دَن مُ نَشَن مَ.
\b
\q1 وٌ عَلَتَلَ مَتْشْ!
\c 116
\s1 عَلَ شَ كِسِ قَشّ مَ
\s2 عَلَ مَتْشْي
\q1 
\v 1 ﭑ عَلَتَلَ شَنُمَ بَرِ مَ عَ ﭑ شُي مّمَ.
\q1 عَ نَشَ كِنِكِنِ ﭑ وَ شُي مَ.
\q1 
\v 2 عَ تٌ عَ تُلِ مَتِ ﭑ نَ،
\q1 ﭑ عَ مَشَندِ مَ نّ ﭑ مَ سِمَيَ بِرِن كُي.
\b
\q1 
\v 3 قَشّ لُوتِ نُ بَرَ ﭑ شِرِ،
\q1 عَلِفِيَمَ تْورّ نُ بَرَ ﭑ لِ،
\q1 نِمِسّ نُن كْنتْقِلِ نُ بَرَ نْ ﭑ نَ،
\q1 
\v 4 كْنْ نَ تّمُي ﭑ نَشَ عَلَتَلَ مَشَندِ،
\q1 «عَلَتَلَ، يَندِ، ﭑ نَكِسِ!»
\b
\q1 
\v 5 هِننّنتٍ نَن عَلَتَلَ رَ، عَ تِنشِن.
\q1 وٌن مَرِفِ عَلَ كِنِكِنِمَ وٌن مَ.
\q1 
\v 6 عَ مِشِ مَفٌرٌشِ كَنتَمَ.
\q1 ﭑ سّنبّ تٌ حْن، عَ نَشَ ﭑ نَكِسِ.
\b
\q1 
\v 7 ﭑ شَ ﭑ نِي رَشَرَ،
\q1 بَرِ مَ عَلَتَلَ بَرَ قٍ قَنيِ رَبَ ﭑ بّ.
\b
\q1 
\v 8 عَلَتَلَ، عِ بَرَ ﭑ نِي رَتَنفَ قَشّ مَ،
\q1 عِ يَيٍ بَ ﭑ يَ رَ،
\q1 عِ ﭑ سَنيِ سّنبّ سٌ،
\q1 
\v 9 عَلَكٌ ﭑ شَ حّرّ عِ تَن عَلَتَلَ يَ رَ مِشِ بَلٌشِ يَ مَ.
\q1 
\v 10 ﭑ تٌ نُ ﭑ شَشِلِ تِمَ عِ رَ،
\q1 ﭑ نَشَ عَ قَلَ عِ بّ، «ﭑ نَ تْورْقٍ.»
\q1 
\v 11 لِمَنِيَ تٌ بَ ﭑ يِ رَ،
\q1 ﭑ نَشَ عَ قَلَ، «وُلٍ قَلّ نَن مِشِ بِرِن نَ.»
\b
\q1 
\v 12 عَلَتَلَ، ﭑ عِ سَرٍ قِمَ دِ، عِ شَ هِننّ شَ قٍ رَ؟
\q1 
\v 13 ﭑ عِ شَ مَرَتَنفّ مَسٍنمَ نّ حَمَ بّ،
\q1 عَلَتَلَ شِلِ مَتْشْقٍ رَ.
\q1 
\v 14 ﭑ نَ ﭑ مَ لَايِدِيٍ رَكَمَلِمَ نّ عَلَتَلَ بّ،
\q1 عَ شَ حَمَ بِرِن يَ شْرِ.
\b
\q1 
\v 15 عَلَتَلَ عَ حْشْ سَمَ نّ عَ بَتُلَيٍ شَ سِمَيَ شْن مَ.
\q1 
\v 16 عِ تَن عَلَتَلَ شَ كٌنيِ دِ نَن ﭑ نَ،
\q1 عِ شَ كٌنيِ فِنّ شَ دِ،
\q1 عِ نَشَن نَقُلُنشِ سَيَ لُوتِ رَ.
\b
\q1 
\v 17 ﭑ تَنتُي سّرّشّ بَمَ نّ عِ بّ،
\q1 ﭑ عِ شِلِ مَتْشْمَ نّ.
\q1 
\v 18 ﭑ نَ ﭑ مَ لَايِدِيٍ رَكَمَلِمَ نّ عَلَتَلَ بّ،
\q1 عَ شَ حَمَ بِرِن يَ شْرِ،
\q1 
\v 19 عَلَتَلَ شَ بَنشِ تّتّ كُي،
\q1 دَرِ سَلَمُ حَمَ يَ شْرِ.
\b
\q1 وٌ مَرِفِ مَتْشْ!
\c 117
\s1 عَلَ شَ شَنُنتٍيَ
\s2 عَلَ مَتْشْي
\q1 
\v 1 سِ بِرِن شَ عَلَتَلَ مَتْشْ،
\q1 بْنسْي بِرِن شَ عَ تَنتُ،
\q1 
\v 2 بَرِ مَ عَ شَ شَنُنتٍيَ فبٌ وٌن مَبِرِ،
\q1 عَ شَ دُفُتّفّحَ مُ حْنمَ عَبَدَن.
\b
\q1 وٌ عَلَتَلَ مَتْشْ!
\c 118
\s1 شَشِلِ تِقٍ عَلَتَلَ رَ
\s2 عَلَ مَتْشْي
\q1 
\v 1 وٌ عَلَتَلَ تَنتُ بَرِ مَ عَ قَن،
\q1 عَ شَ شَنُنتٍيَ مُ حْنمَ عَبَدَن.
\b
\q1 
\v 2 عِسِرَيِلَ شَ عَ قَلَ،
\q1 «عَ شَ شَنُنتٍيَ مُ حْنمَ عَبَدَن!»
\q1 
\v 3 هَرُنَ بْنسْي شَ عَ قَلَ،
\q1 «عَ شَ شَنُنتٍيَ مُ حْنمَ عَبَدَن!»
\q1 
\v 4 عَلَ يَرَفَاشُييٍ شَ عَ قَلَ،
\q1 «عَ شَ شَنُنتٍيَ مُ حْنمَ عَبَدَن!»
\b
\q1 
\v 5 ﭑ مَ تْورّ كُي، ﭑ نَشَ عَلَتَلَ مَشَندِ.
\q1 عَ نَشَ ﭑ مَ دُبَ سُشُ ﭑ قُلُنقٍ رَ.
\q1 
\v 6 عَلَتَلَ نَ ﭑ سّيتِ مَ، ﭑ مُ فَاشُمَ قٍقٍ مَ.
\q1 عَدَ مَدِ نْمَ مُنسٍ نِيَدٍ ﭑ نَ؟
\q1 
\v 7 عَلَتَلَ نَ ﭑ قْشْ رَ، عَ ﭑ مَلِمَ.
\q1 ﭑ قَمَ نّ نْدٍ ﭑ يَشُييٍ رَ.
\b
\q1 
\v 8 شَشِلِ تِقٍ عَلَتَلَ رَ، نَ نَن قَن بٍينُن شَشِلِ تِقٍ عَدَ مَدِ رَ.
\q1 
\v 9 يّتّ تَشُقٍ عَلَتَلَ رَ دَنفِ يّتّ تَشُقٍ دُنِحَ مَنفّيٍ رَ.
\b
\q1 
\v 10 سِ بِرِن نُ ﭑ نَبِلِنشِ ﭑ فٍرٍ شِلِ مَ،
\q1 كْنْ عَلَتَلَ نَشَ عَ نِيَ ﭑ شَ نْ عٍ رَ.
\q1 
\v 11 عٍ نُ ﭑ نَبِلِنشِ عَ حَاشِ رَ،
\q1 كْنْ ﭑ نَشَ نْ عٍ رَ عَلَتَلَ شِلِ رَ.
\q1 
\v 12 عٍ نَشَ دِن ﭑ نَ عَلْ كُمِ تْنسْي،
\q1 كْنْ عٍ نَشَ حْن عَلْ سّشّ شَرَشِ فَنمَ كِ نَشّ.
\q1 عَلَتَلَ نَن عَ نِيَ ﭑ شَ نْ عٍ رَ.
\b
\q1 
\v 13 عٍ نُ ﭑ مَتُتُنمَ سّنبّ رَ،
\q1 عَ فبٍ مُ نُ لُشِ ﭑ شَ بِرَ،
\q1 كْنْ عَلَتَلَ نَشَ ﭑ مَلِ.
\q1 
\v 14 عَلَتَلَ نَن نَ ﭑ سّنبّ نُن ﭑ مَ سّيوّ رَ،
\q1 عَ بَرَ ﭑ نَكِسِ!
\b
\q1 
\v 15 سّيوّ نُن شُننَكٍلِ شُي نَشَ مِنِ تِنشِنتْييٍ شْنيِ عَ قَلَقٍ رَ،
\q1 
\v 16 «عَلَتَلَ نَشَ وَلِ سّنبّ رَ!
\q1 عَ نَشَ عَ مَنفّيَ مَسٍن،
\q1 عَ كَابَنَكٌي رَبَ.»
\b
\q1 
\v 17 ﭑ مُ قَشَ، ﭑ نَشَ كِسِ،
\q1 عَلَكٌ ﭑ شَ عَلَتَلَ شَ كَابَنَكٌي مَسٍن حَمَ بّ.
\q1 
\v 18 عَلَتَلَ بَرَ ﭑ حَشَنكَتَ،
\q1 كْنْ عَ مُ ﭑ لُشِ ﭑ شَ قَشَ.
\b
\q1 
\v 19 وٌ تِنشِنيِ نَادّيٍ رَبِ ﭑ بّ،
\q1 ﭑ سٌمَ مّننِ عَلَتَلَ تَنتُقٍ رَ.
\q1 
\v 20 عَلَتَلَ شَ نَادّ نَن يِ كِ،
\q1 تِنشِنتْييٍ سٌمَ نَشَن كُي.
\q1 
\v 21 ﭑ عِ تَنتُمَ نّ، بَرِ مَ عِ بَرَ ﭑ مَ دُبَ سُشُ،
\q1 عِ بَرَ قِندِ ﭑ نَكِسِمَ رَ.
\b
\q1 
\v 22 بَنشِتِيٍ مّي فّمّ نَشَن نَ،
\q1 نَ بَرَ قِندِ بَنشِ سَنفَنتِمّ رَ.
\q1 
\v 23 نَ كٍلِشِ مَرِفِ نَن مَ.
\q1 كَابَنَكٌي نَ عَ رَ وٌن تَن بّ.
\q1 
\v 24 لْشْي نَن يِ كِ عَلَتَلَ نَشَن حَنِفٍشِ،
\q1 وٌن شَ حّلّشِن، وٌن شَ سّيوَ عَ شَ قٍ رَ.
\b
\q1 
\v 25 يَندِ عَلَتَلَ، مُشُ رَكِسِ!
\q1 يَندِ عَلَتَلَ، مُشُ شُن نَكٍلِ.
\q1 
\v 26 بَرَكَ نَ مِشِ مَ نَشَن قَقٍ مَرِفِ شِلِ رَ.
\q1 مُشُ عَلَتَلَ مَتْشْمَ عَ شَ بَنشِ كُي.
\q1 
\v 27 مَرِفِ نَن نَ عَلَتَلَ رَ،
\q1 نَشَن شَ نْرّ بَرَ يَنبَ وٌن مَ.
\q1 وٌ شَ سّرّشّ شِرِ سّرّشّبَدٍ سّيتِ مَ.
\b
\q1 
\v 28 ﭑ مَرِفِ عَلَ نَن عِ رَ، ﭑ عِ تَنتُمَ نّ،
\q1 ﭑ مَرِفِ عَلَ نَن عِ رَ، ﭑ عِ مَتْشْمَ نّ.
\q1 
\v 29 وٌ عَلَتَلَ تَنتُ بَرِ مَ عَ قَن.
\q1 عَ شَ شَنُنتٍيَ مُ حْنمَ عَبَدَن.
\c 119
\s1 عَلَ شَ سّرِيّ كٍرٍنيِ
\s2 عَلَ شَ سّرِيّ
\q1 
\v 1 سّيوّ نَ مِشِيٍ بّ نَشٍيٍ حّرّ كِ تِنشِن،
\q1 نَشٍيٍ بِرَشِ عَلَتَلَ شَ سّرِيّ قْشْ رَ.
\q1 
\v 2 سّيوّ نَ مِشِيٍ بّ نَشٍيٍ عَلَ شَ مَسٍنيِ مّمَ،
\q1 نَشٍيٍ عَ قٍنمَ عٍ بْحّ بِرِن نَ.
\q1 
\v 3 نٍيٍ مُ تِنشِنتَرٍيَ رَبَمَ قٍقٍ مَ،
\q1 عٍ بِرَ مَ عَلَ شَ كِرَ نَن قْشْ رَ.
\q1 
\v 4 عِ بَرَ عِ سَفٌ مَسٍن مُشُ بّ،
\q1 عَلَكٌ مُشُ شَ مُشُ حْشْ سَ عَ شْن مَ عَ قَنيِ رَ.
\q1 
\v 5 ﭑ وَ مَ قٍ بِرِن نَبَقٍ
\q1 عَلَكٌ ﭑ شَ عِ شَ يَامَرِيٍ رَبَتُ.
\q1 
\v 6 نَ كُي ﭑ مُ قَمَ يَافِدٍ عِ وَشْنقٍ شَ قٍ رَ.
\q1 
\v 7 ﭑ نَ عِ شَ يَامَرِيٍ كٌلٌن،
\q1 ﭑ عِ بَتُمَ نّ ﭑ بْحّ قِيشّ رَ.
\q1 
\v 8 ﭑ عِ شَ يَامَرِيٍ رَتِنمّمَ نّ،
\q1 عِ نَشَ مّ ﭑ نَ كٍرٍنيِ رَ.
\b
\q1 
\v 9 قٌنِكٍ حّرّ مَ سّنِيّنيِ كُي دِ؟
\q1 عَ بِرَ عِ شَ مَسٍنيِ قْشْ رَ.
\q1 
\v 10 ﭑ عِ قٍنمَ ﭑ بْحّ بِرِن نَن نَ.
\q1 عِ نَشَ ﭑ لُ ﭑ شَ مَكُيَ عِ شَ يَامَرِيٍ رَ.
\q1 
\v 11 ﭑ عِ شَ مَسٍنيِ رَفَتَمَ نّ ﭑ بْحّ مَ،
\q1 عَلَكٌ ﭑ نَشَ يُنُبِ رَبَ عِ رَ.
\q1 
\v 12 مَتْشْي نَ عِ بّ عَلَتَلَ.
\q1 عِ شَ يَامَرِيٍ مَسٍن ﭑ بّ.
\q1 
\v 13 ﭑ عِ شَ سّرِيّ دُرُ سِمَ نّ،
\q1 عِ نَشَن مَسٍنشِ عِ كّرّ رَ.
\q1 
\v 14 ﭑ سّيوَشِ بِرَقٍ رَ عِ شَ مَسٍنيِ قْشْ رَ،
\q1 عَلْ ﭑ نَ قِندِ بَننَ بٍلٍبٍلٍ رَ.
\q1 
\v 15 ﭑ ﭑ حْشْ سَشِ عِ سَفٌ شْن مَ،
\q1 ﭑ عِ شَ كِرَ مَتٌمَ نّ.
\q1 
\v 16 عِ شَ يَامَرِيٍ رَقَن ﭑ مَ،
\q1 ﭑ مُ نّيمُمَ عِ شَ مَسٍنيِ مَ.
\b
\q1 
\v 17 قٍ قَنيِ رَبَ ﭑ تَن، عِ شَ كٌنيِ دِ بّ،
\q1 عَلَكٌ ﭑ شَ كِسِ، ﭑ شَ عِ شَ مَسٍنيِ رَتِنمّ.
\q1 
\v 18 ﭑ يَ رَبِ عَلَكٌ ﭑ شَ عِ شَ سّرِيّ قَنيِ عِفبّ.
\q1 
\v 19 شْحّ نَن لَنشِ ﭑ مَ يِ دُنِحَ مَ،
\q1 عِ نَشَ عِ شَ يَامَرِيٍ نْشُن ﭑ مَ.
\q1 
\v 20 ﭑ هَيِ نَ عِ شَ تِنشِنيِ مَ.
\q1 
\v 21 عِ عِ شُي رَتٍمَ يّتّ عِفبٌي شِلِ مَ،
\q1 مِشِ دَنكَشِ نَشٍيٍ عِ شَ يَامَرِيٍ رَبّحِنمَ.
\q1 
\v 22 عِ شَ ﭑ نَتَنفَ يَافِ نُن مَرَحَاشُي مَ،
\q1 بَرِ مَ ﭑ عِ شَ مَسٍنيِ سُشُشِ.
\q1 
\v 23 هَلِ مَنفّيٍ ﭑ تْوحّفّمَ،
\q1 عِ شَ كٌنيِ دِ عَ حْشْ سَمَ نّ عِ شَ يَامَرِيٍ نَن شْن مَ.
\q1 
\v 24 عِ شَ مَسٍنيِ رَقَن ﭑ مَ،
\q1 عٍ ﭑ نَسِمَ عَ قَنيِ رَ.
\b
\q1 
\v 25 ﭑ نَ تْورّ شُنفبٍ كُي.
\q1 يَندِ، عِ شَ ﭑ نَكِسِ عِ شَ مَسٍنيِ رَ.
\q1 
\v 26 ﭑ تٌ ﭑ مَ حّرّ كِ مَسٍن عِ بّ، عِ ﭑ يَابِ نّ.
\q1 يَندِ، عِ شَ عِ شَ يَامَرِ مَسٍن ﭑ بّ.
\q1 
\v 27 ﭑ مَلِ عِ سَفٌ قَهَامُقٍ رَ،
\q1 عَلَكٌ ﭑ شَ ﭑ حْشْ سَ عِ شَ كَابَنَكٌي شْن مَ.
\q1 
\v 28 ﭑ نَ وَقٍ نِمِسّ مَ.
\q1 ﭑ شُن نَكٍلِ عَلْ عِ عَ لَايِدِشِ كِ نَشّ.
\q1 
\v 29 وُلٍ قَلَقٍ مَكُيَ ﭑ نَ.
\q1 هِننّ ﭑ نَ عِ شَ سّرِيّ سَابُي رَ.
\q1 
\v 30 ﭑ بَرَ دُفُتّفّحَ كِرَ سُفَندِ،
\q1 ﭑ بْحّ بِرَ مَ عِ شَ سّرِيّ نَن قْشْ رَ.
\q1 
\v 31 عَلَتَلَ، ﭑ شِرِشِ عِ شَ سّرِيّ نَن نَ،
\q1 عِ نَشَ ﭑ لُ يَافِ كُي.
\q1 
\v 32 ﭑ نَ ﭑ حّرّقٍ عِ شَ يَامَرِيٍ شَ كِرَ نَن شْن مَ،
\q1 بَرِ مَ عِ بَرَ عَ نِيَ عِ وَشْنقٍ شَ لُ ﭑ بْحّ مَ.
\b
\q1 
\v 33 عَلَتَلَ، ﭑ مَتِنشِن عِ شَ يَامَرِيٍ رَ،
\q1 عَلَكٌ ﭑ شَ لُ عِ شَ كِرَ شْن مَ ﭑ مَ سِمَيَ بِرِن كُي.
\q1 
\v 34 شَشِلِ قَنيِ قِ ﭑ مَ،
\q1 عَلَكٌ ﭑ شَ ﭑ حْشْ سَ عِ شَ سّرِيّ شْن مَ،
\q1 ﭑ مَن شَ عَ رَبَتُ ﭑ بْحّ بِرِن نَ
\q1 
\v 35 ﭑ نَحّرّ عِ شَ يَامَرِيٍ شَ كِرَ شْن مَ،
\q1 بَرِ مَ عٍ رَقَن ﭑ مَ
\q1 
\v 36 ﭑ بْحّ رَقِندِ عِ شَ مَسٍنيِ مَ،
\q1 عِ نَشَ عَ رَقِندِ بَننَيَ تِنشِنتَرٍيَ مَ.
\q1 
\v 37 ﭑ يَيٍ بَ سٍيٍ رَ نَشٍيٍ حْنمَ،
\q1 ﭑ نَكِسِ عِ شَ كِرَ شْن مَ.
\q1 
\v 38 عِ شَ لَايِدِ رَكَمَلِ عِ شَ كٌنيِ دِ بّ،
\q1 عِ نَشَن نَفَتَشِ عِ يَرَفَاشُييٍ يَ رَ.
\q1 
\v 39 ﭑ بَ يَافِ كُي ﭑ فَاشُشِ نَشَن يَ رَ،
\q1 بَرِ مَ عِ شَ سّرِيّ قَن.
\q1 
\v 40 ﭑ وَ مَ بِرَقٍ عِ شَ مَسٍنيِ قْشْ رَ عَ قَنيِ رَ.
\q1 ﭑ نَكِسِ عِ شَ تِنشِنيِ كُي.
\b
\q1 
\v 41 عَلَتَلَ، قَ عِ شَ شَنُنتٍيَ نُن عِ شَ كِسِ رَ ﭑ بّ،
\q1 عَلْ عِ عَ لَايِدِ كِ نَشّ.
\q1 
\v 42 نَ تّمُي، ﭑ نْمَ نّ ﭑ مَبٍرٍ مَ يَابِدٍ،
\q1 بَرِ مَ ﭑ تَن لَشِ عِ شَ مَسٍنيِ رَ.
\q1 
\v 43 عِ نَشَ نْندِ مَسٍنيِ بَ ﭑ دّ عِ،
\q1 بَرِ مَ ﭑ شَشِلِ تِشِ عِ شَ كِيتِ رَ.
\q1 
\v 44 ﭑ عِ شَ سّرِيّ رَبَتُمَ نّ عَبَدَن.
\q1 
\v 45 ﭑ لُمَ شْرّيَ نَن كُي،
\q1 بَرِ مَ ﭑ نَ عِ سَفٌ نَن قٍنقٍ.
\q1 
\v 46 ﭑ عِ شَ مَسٍنيِ قَلَمَ نّ مَنفّيٍ بّ،
\q1 ﭑ مُ قَمَ لُدٍ يَافِ كُي.
\q1 
\v 47 بِرَقٍ عِ شَ يَامَرِيٍ قْشْ رَ، نَ رَقَن ﭑ مَ.
\q1 
\v 48 ﭑ نَ ﭑ بّلّشّيٍ عِتٍمَ تَنتُي رَ
\q1 عِ شَ يَامَرِيٍ شَ قٍ رَ، نَشٍيٍ رَقَن ﭑ مَ.
\q1 ﭑ وَ مَ ﭑ حْشْ سَقٍ عِ شَ سّرِيّيٍ شْن مَ.
\b
\q1 
\v 49 عِ شَ رَتُ عِ شَ مَسٍنيِ مَ،
\q1 عِ نَشَن مَسٍن عِ شَ كٌنيِ دِ بّ،
\q1 نَشَن شَشِلِ سَ قِمَ ﭑ مَ يَرٍ.
\q1 
\v 50 ﭑ مَدُندُ مَ ﭑ مَ تْورّ كُي
\q1 عِ شَ لَايِدِ نَن سَابُي رَ.
\q1 
\v 51 يّتّ عِفبٌي ﭑ مَيٍلٍمَ نّ،
\q1 كْنْ ﭑ مُ عِ شَ سّرِيّ كِرَ بّحِنمَ.
\q1 
\v 52 عَلَتَلَ، ﭑ تٌ ﭑ نَتُ عِ شَ كِيتِ تِنشِنشِيٍ مَ
\q1 عِ نَشَن سَشِ تّمُي دَنفِشِ،
\q1 ﭑ بْحّ لِمَنِيَمَ نّ.
\q1 
\v 53 ﭑ بْحّ تٍشِ عَ حَاشِ رَ تِنشِنتَرٍيٍ شِلِ مَ
\q1 نَشٍيٍ عِ شَ سّرِيّ رَبٌلٌمَ.
\q1 
\v 54 ﭑ سَبَتِ دّدّ، ﭑ بّيتِ بَمَ نّ عِ شَ يَامَرِيٍ شَ قٍ رَ.
\q1 
\v 55 كْي رَ ﭑ نَ ﭑ نَتُمَ نّ عِ شِلِ مَ.
\q1 عَلَتَلَ، ﭑ قَمَ نّ عِ شَ سّرِيّيٍ رَتِنمّدٍ.
\q1 
\v 56 ﭑ دَرِشِ عِ سَفٌ رَبَتُقٍ نَن نَ.
\b
\q1 
\v 57 عَلَتَلَ، عِ تِدٍ فبٌ ﭑ بّ.
\q1 ﭑ بَرَ لَايِدِ تٌنفٌ عِ شَ مَسٍنيِ رَبَتُقٍ رَ.
\q1 
\v 58 ﭑ وَ مَ لُقٍ عِ سّيتِ مَ ﭑ بْحّ بِرِن نَ.
\q1 هِننّ ﭑ نَ عَلْ عِ عَ مَسٍن كِ نَشّ.
\q1 
\v 59 ﭑ تٌ ﭑ حّرّ كِ مَتٌ،
\q1 ﭑ بَرَ فبِلٍن عِ شَ مَسٍنيِ مَ.
\q1 
\v 60 ﭑ فبَتَمَ نّ،
\q1 ﭑ مُ دُفُندِ مَ عِ شَ يَامَرِيٍ رَبَتُقٍ رَ.
\q1 
\v 61 هَلِ مِشِ حَاشِيٍ كَنكَن ﭑ مَ،
\q1 ﭑ مُ نّيمُمَ عِ شَ سّرِيّيٍ مَ.
\q1 
\v 62 كْي تَفِ، ﭑ كٍلِمَ نّ، ﭑ عِ مَتْشْ عِ شَ كِيتِ تِنشِنشِ شَ قٍ رَ.
\q1 
\v 63 عِ يَرَفَاشُي بِرِن قِندِشِ ﭑ حّرّبٌورٍ نَن نَ،
\q1 نُن نَشٍيٍ عِ سَفٌ رَبَتُمَ.
\q1 
\v 64 عَلَتَلَ عِ شَ شَنُنتٍيَ نَ دُنِحَ بِرِن مَ،
\q1 ﭑ شَرَن عِ شَ يَامَرِيٍ رَ.
\b
\q1 
\v 65 عَلَتَلَ، عِ بَرَ قٍ قَنيِ رَبَ ﭑ تَن عِ شَ كٌنيِ بّ،
\q1 عَلْ عِ عَ لَايِدِشِ كِ نَشّ.
\q1 
\v 66 ﭑ شَرَن قٍ تَفِ رَ سَدٍ نُن قٍ كٌلٌنيِ رَ، بَرِ مَ ﭑ لَشِ عِ شَ يَامَرِيٍ رَ.
\q1 
\v 67 ﭑ نُ بَرَ لْي بٍيمَنُ عِ شَ ﭑ مَ قٍ مَفٌرٌ،
\q1 كْنْ يَكْسِ قَ ﭑ نَ عِ شَ مَسٍنيِ نَن نَبَتُقٍ.
\q1 
\v 68 عِ قَن، عِ قٍ قَنيِ رَبَمَ،
\q1 ﭑ شَرَن عِ شَ يَامَرِيٍ رَ.
\q1 
\v 69 هَلِ يّتّ عِفبٌي وُلٍ سَمَ ﭑ شُن،
\q1 ﭑ عِ شَ يَامَرِيٍ رَبَتُمَ نّ ﭑ بْحّ بِرِن نَ.
\q1 
\v 70 عٍ بْحّ شْرْشْ عَلْ فّمّ،
\q1 كْنْ عِ شَ سّرِيّ حْشُن ﭑ بّ.
\q1 
\v 71 ﭑ مَ تْورّ بَرَ ﭑ مَلِ عِ شَ يَامَرِيٍ كٌلٌنقٍ رَ.
\q1 
\v 72 عِ شَ مَسٍنيِ قَن ﭑ بّ شّيمَ نُن فبٍتِ رَ.
\b
\q1 
\v 73 عِ تَن نَن ﭑ دَاشِ، عِ تَن نَن ﭑ نَقَلَشِ عِ شْنيّ رَ.
\q1 قَهَامُي قِ ﭑ مَ عِ شَ يَامَرِيٍ كٌلٌنقٍ رَ.
\q1 
\v 74 عِ يَرَفَاشُييٍ شَ سّيوَ ﭑ تٌقٍ رَ،
\q1 بَرِ مَ ﭑ شَشِلِ تِشِ عِ شَ مَسٍنيِ رَ.
\q1 
\v 75 عَلَتَلَ، ﭑ عَ كٌلٌن عِ شَ كِيتِ تِنشِنشِ رَ،
\q1 ﭑ عَ كٌلٌن عِ ﭑ مَ قٍ مَفٌرٌشِ شَنُنتٍيَ نَن مَ.
\q1 
\v 76 يَندِ، عِ شَ شَنُنتٍيَ شَ ﭑ مَدُندُ،
\q1 عَلْ عِ عَ لَايِدِ ﭑ تَن، عِ شَ كٌنيِ بّ كِ نَشّ.
\q1 
\v 77 عِ شَ كِنِكِنِ ﭑ مَ عَلَكٌ ﭑ شَ كِسِ،
\q1 بَرِ مَ عِ شَ سّرِيّ رَقَن ﭑ مَ.
\q1 
\v 78 يّتّ عِفبٌي شَ يَافِ سْتْ،
\q1 بَرِ مَ ﭑ مُ قٍ يٌ رَبَشِ عٍ رَ عٍ ﭑ تْورْ مَ نَشَن مَ.
\q1 ﭑ تَن حْشْ سَمَ عِ سَفٌ نَن شْن مَ.
\q1 
\v 79 عِ يَرَفَاشُييٍ شَ فبِلٍن ﭑ مَ،
\q1 عَ نُن نَشٍيٍ عِ شَ مَسٍنيِ كٌلٌن.
\q1 
\v 80 ﭑ بْحّ شَ عِ شَ يَامَرِيٍ سُشُ،
\q1 عَلَكٌ يَافِ نَشَ قَ دُ سُ ﭑ شُن نَ.
\b
\q1 
\v 81 عَ شْلِ ﭑ مَ ﭑ شَ عِ شَ كِسِ سْتْ،
\q1 كْنْ ﭑ شَشِلِ تِشِ عِ شَ مَسٍنيِ نَن نَ.
\q1 
\v 82 ﭑ عِ شَ لَايِدِ رَكَمَلِشِ مَمّقٍ.
\q1 ﭑ عَ قَلَمَ ﭑ بْحّ كُي، «عِ ﭑ مَدُندُ مَ مُن تّمُي؟»
\q1 
\v 83 ﭑ لُشِ عَلْ كُندِ نَشَن نَ رَشَرَقٍ،
\q1 كْنْ ﭑ مُ نّيمُمَ عِ شَ يَامَرِيٍ رَ.
\q1 
\v 84 ﭑ شَ مَمّ تِ هَن مُن تّمُي،
\q1 بٍينُن عِ شَ ﭑ يَشُييٍ حَشَنكَتَ؟
\q1 
\v 85 يّتّ عِفبٌي فَنتَنيِ تِمَ ﭑ يَ رَ.
\q1 سّرِيّ مُ نَ كِ.
\q1 
\v 86 عِ شَ يَامَرِ بِرِن تِنشِن.
\q1 ﭑ نَتَنفَ تْوحّفّ مَ.
\q1 
\v 87 عَ فبٍ مُ لُشِ عٍ شَ ﭑ مَ قٍ كَنَ،
\q1 كْنْ ﭑ تٌندِ نّ عِ شَ يَامَرِيٍ رَبٌلٌدٍ.
\q1 
\v 88 ﭑ نَكِسِ عِ شَ شَنُنتٍيَ رَ،
\q1 عَلَكٌ ﭑ شَ عِ شَ مَسٍنيِ سُشُ.
\b
\q1 
\v 89 عَلَتَلَ، عِ شَ مَسٍنيِ نَ كٌورٍ مَ عَبَدَن.
\q1 
\v 90 عِ شَ شَنُنتٍيَ بُمَ نّ كٍلِقٍ تٌ بْنسْي مَ هَن بْنسْي نَشٍيٍ سَ قَمَ.
\q1 عِ دُنِحَ شَنشِ نَن دَا.
\q1 
\v 91 عِ شَ سّرِيّ بُمَ هَن تٌ،
\q1 بِرِن نَ عِ شَ مَنفّيَ نَن بُن مَ.
\q1 
\v 92 شَ ﭑ مُ سّيوَ عِ شَ سّرِيّ رَ نُ،
\q1 ﭑ بَرَ بْنْ ﭑ مَ تْورّ كُي نُ.
\q1 
\v 93 ﭑ مُ نّيمُمَ عِ شَ مَسٍنيِ رَ قٍوٌ،
\q1 بَرِ مَ عِ ﭑ كِسِشِ عٍ تَن نَن سَابُي رَ.
\q1 
\v 94 ﭑ بَرَ ﭑ يّتّ قِ عِ مَ، ﭑ نَكِسِ.
\q1 ﭑ تِنمَ عِ سَفٌ سُشُقٍ رَ.
\q1 
\v 95 مِشِ حَاشِيٍ وَ مَ ﭑ قَشَقٍ،
\q1 كْنْ ﭑ تَن حْشْ سَشِ عِ شَ مَسٍنيِ شْن مَ.
\q1 
\v 96 ﭑ عَ كٌلٌن دُنِحَ قٍ بِرِن حْنمَ نّ،
\q1 كْنْ عِ شَ سّرِيّ مُ كَنَمَ عَبَدَن.
\b
\q1 
\v 97 عِ شَ سّرِيّ رَقَن ﭑ مَ.
\q1 ﭑ نَ ﭑ حْشْ سَشِ عَ شْن مَ كُدّ.
\q1 
\v 98 عِ شَ يَامَرِيٍ ﭑ قِندِ مَ قَهَامُلَ نَن نَ
\q1 دَنفِ ﭑ يَشُييٍ رَ، بَرِ مَ عٍ نَ ﭑ بْحّ كُي تّمُي بِرِن.
\q1 
\v 99 ﭑ شَشِلِ قَن ﭑ كَرَ مْشْيٍ شَشِلِ بّ،
\q1 بَرِ مَ ﭑ نَ ﭑ حْشْ سَشِ عِ شَ مَسٍنيِ نَن شْن مَ.
\q1 
\v 100 ﭑ قٍ كٌلٌن دَنفِقٍ قٌرِيٍ رَ،
\q1 بَرِ مَ ﭑ عِ سَفٌ رَبَتُشِ.
\q1 
\v 101 ﭑ بَرَ ﭑ سَنيِ بَ كِرَ حَاشِيٍ شْن مَ،
\q1 ﭑ شَ بِرَ عِ شَ مَسٍنيِ قْشْ رَ.
\q1 
\v 102 ﭑ مُ عِ شَ سّرِيّ بّحِن،
\q1 بَرِ مَ عِ تَن نَن يَتِ ﭑ شَرَن نَ رَ.
\q1 
\v 103 عِ شَ مَسٍنيِ حْشُن ﭑ دّ كُي دَنفِ كُمِ رَ.
\q1 
\v 104 ﭑ شَشِلِ قَنيِ سْتْ عِ سَفٌ نَن نَ.
\q1 نَ كُي ﭑ بَرَ كِرَ حَاشِيٍ تَن شْن.
\b
\q1 
\v 105 عِ شَ مَسٍنيِ قِندِشِ لَنثُي نَن نَ ﭑ سَن تِدٍ،
\q1 عَ قِندِ نَءِيَلَنيِ رَ ﭑ مَ كِرَ شْن مَ.
\q1 
\v 106 ﭑ بَرَ لَايِدِ تٌنفٌ نَشَن مُ كَنَمَ،
\q1 ﭑ قَمَ نّ بِرَدٍ عِ شَ سّرِيّ تِنشِنشِ قْشْ رَ.
\q1 
\v 107 ﭑ بَرَ تْورْ عَ فبٍ رَ.
\q1 عَلَتَلَ، ﭑ نَكِسِ عِ شَ مَسٍنيِ رَ.
\q1 
\v 108 عَلَتَلَ، ﭑ بَرَ عِ مَشَندِ،
\q1 عِ شَ ﭑ مَ مَتْشْي سُشُ سّرّشّ رَ،
\q1 عِ شَ ﭑ شَرَن عِ سَفٌ رَ.
\q1 
\v 109 ﭑ نِي نَ قَشّ يَ عِ تّمُي بِرِن،
\q1 كْنْ ﭑ مُ نّيمُمَ عِ شَ سّرِيّ مَ.
\q1 
\v 110 مِشِ حَاشِيٍ فَنتَنيِ تٍمَ ﭑ بّ،
\q1 كْنْ ﭑ مُ ﭑ مَكُيَمَ عِ سَفٌ رَ.
\q1 
\v 111 عِ شَ مَسٍنيِ قِندِشِ ﭑ كّ نَن نَ عَبَدَن،
\q1 عَ ﭑ بْحّ رَ سّيوَ مَ نّ.
\q1 
\v 112 ﭑ بْحّ بِرَ مَ نّ عِ شَ يَامَرِيٍ قْشْ رَ عَبَدَن.
\b
\q1 
\v 113 ﭑ قِلَنكَقُي شْنمَ،
\q1 كْنْ عِ شَ سّرِيّ رَقَن ﭑ مَ.
\q1 
\v 114 ﭑ كَنتَرِ نُن ﭑ مَكَنتَمَ نَ عِ تَن نَن نَ،
\q1 ﭑ شَشِلِ تِشِ عِ شَ مَسٍنيِ رَ.
\q1 
\v 115 وٌ وٌ مَسِفَ ﭑ نَ، وٌ تَن مِشِ كٌبِيٍ،
\q1 عَلَكٌ ﭑ شَ عَلَ شَ يَامَرِيٍ رَتِنمّ.
\q1 
\v 116 ﭑ دّ مّن عَلْ عِ عَ لَايِدِ كِ نَشّ، عَلَكٌ ﭑ شَ كِسِ.
\q1 عِ نَشَ قٍ كَنَ ﭑ شَشِلِ تِشِ نَشَن نَ.
\q1 
\v 117 عِ شَ تِ ﭑ قَنفَ رَ، عَلَكٌ ﭑ شَ كِسِ.
\q1 ﭑ يَ تِشِ عِ شَ يَامَرِيٍ رَ.
\q1 
\v 118 عِ شَ تٌندِ مِشِيٍ رَ نَشٍيٍ عٍ مَكُيَمَ عِ شَ سّرِيّ رَ،
\q1 بَرِ مَ مَدَشُحَ نُن وُلٍ نَ عٍ شَ قٍ بِرِن كُي.
\q1 
\v 119 عِ مِشِ كٌبِيٍ حْنمَ نّ يِ دُنِحَ مَ،
\q1 عَلْ شَبُي فبٍتِ فبِ بَمَ كِ نَشّ.
\q1 نَ نَن عَ رَ عِ شَ مَسٍنيِ رَقَن ﭑ مَ.
\q1 
\v 120 ﭑ قَتٍ سّرّنمَ عِ شَ مَفَاشُي رَ،
\q1 ﭑ هَنمّشِ عِ شَ كِيتِ رَ.
\b
\q1 
\v 121 ﭑ وَلِمَ نْندِ نُن تِنشِنيِ نَن نَ.
\q1 عِ نَشَ ﭑ لُ ﭑ يَشُييٍ يِ رَ.
\q1 
\v 122 عِ شَ ﭑ مَ قٍ سْونّيَ عِ سّنبّ رَ،
\q1 عِ نَشَ لُ يّتّ عِفبٌي شَ نْ ﭑ نَ.
\q1 
\v 123 ﭑ يَ تِشِ عِ شَ كِسِ رَ تّمُي بِرِن،
\q1 عَ نُن عِ شَ مَسٍنيِ تِنشِنشِ.
\q1 
\v 124 هِننّ عِ شَ كٌنيِ رَ عِ شَ شَنُنتٍيَ كُي.
\q1 ﭑ شَرَن عِ شَ يَامَرِيٍ رَ.
\q1 
\v 125 قَهَامُي قِ ﭑ تَن، عِ شَ كٌنيِ مَ،
\q1 عَلَكٌ ﭑ شَ عِ شَ مَسٍنيِ كُي كٌلٌن.
\q1 
\v 126 مِشِيٍ نَ عِ شَ سّرِيّ مَتَندِقٍ.
\q1 عَلَتَلَ، عَ لَنمَ عِ شَ تِ عٍ يَ رَ يَكْسِ.
\q1 
\v 127 عِ شَ يَامَرِيٍ رَقَنشِ ﭑ مَ دَنفِقٍ شّيمَ قَنيِ رَ،
\q1 
\v 128 ﭑ تٌ عَ مَحْشُن عِ سَفٌ تِنشِن،
\q1 ﭑ كِرَ بِرِن شْنمَ نّ نَشَن مُ قِندِ نْندِ رَ.
\b
\q1 
\v 129 عِ شَ مَسٍنيِ ﭑ دّ عِشَرَ مَ،
\q1 ﭑ عَ رَبَتُمَ نَ نَن مَ.
\q1 
\v 130 عِ شَ مَسٍنيِ كُي مَتٌقٍ،
\q1 عَ شَشِلِ قِمَ نّ شَشِلِتَرٍيٍ مَ.
\q1 
\v 131 عَ نَ ﭑ نِي رَ ﭑ شَ عِ سَفٌ كٌلٌن.
\q1 
\v 132 عِ يَ رَقِندِ ﭑ مَ، عِ شَ هِننّ ﭑ نَ،
\q1 عَلْ عِ دَرِشِ عَ رَبَ رَ كِ نَشّ عِ شَنُنتٍنيِيٍ بّ.
\q1 
\v 133 عِ شَ ﭑ تِ عِ شَ مَسٍنيِ قَرِ،
\q1 عِ نَشَ لُ قٍ حَاشِ يٌ شَ نْ ﭑ نَ.
\q1 
\v 134 ﭑ بَ عَدَ مَدِيٍ شَ نْي بُن مَ،
\q1 عَلَكٌ ﭑ شَ عِ شَ يَامَرِيٍ رَتِنمّ.
\q1 
\v 135 عِ يَتَفِ نْرّ رَيَنبَ عِ شَ كٌنيِ مَ،
\q1 عِ شَ ﭑ شَرَن عِ شَ يَامَرِيٍ رَ.
\q1 
\v 136 ﭑ لُمَ وَ رَ عَ فبٍ رَ،
\q1 بَرِ مَ ﭑ عَ كٌلٌن مِشِيٍ مُ عِ شَ سّرِيّ رَتِنمّمَ.
\b
\q1 
\v 137 عَلَتَلَ عِ تِنشِن، عِ شَ كِيتِيٍ قَن تِنشِن.
\q1 
\v 138 عِ شَ مَسٍنيِ تِنشِن، عَ مَن قِندِشِ نْندِ يَتِ نَن نَ.
\q1 
\v 139 ﭑ بْحّ رَحَاشُمَ نّ ﭑ مَ،
\q1 بَرِ مَ ﭑ يَشُييٍ مُ عٍ تُلِ مَتِمَ عِ شَ مَسٍنيِ رَ.
\q1 
\v 140 عِ شَ مَسٍنيِ بَرَ عَ يّتّ شَ نْندِ مَسٍن،
\q1 عَ رَقَن ﭑ تَن عِ شَ كٌنيِ مَ.
\q1 
\v 141 هَلِ ﭑ شُرُن، مِشِيٍ يٌمَ ﭑ مَ،
\q1 ﭑ مُ نّيمُمَ عِ سَفٌ مَ.
\q1 
\v 142 عِ شَ تِنشِنيِ بُمَ عَبَدَن.
\q1 عِ شَ سّرِيّ نْندِ نَ عَ رَ.
\q1 
\v 143 سُننُنيِ نُن تْورّ ﭑ سُشُشِ،
\q1 كْنْ عِ شَ يَامَرِيٍ نْشُن ﭑ بّ.
\q1 
\v 144 عِ شَ سّرِيّيٍ تِنشِن عَبَدَن.
\q1 قَهَامُي قِ ﭑ مَ عَلَكٌ ﭑ شَ كِسِ.
\b
\q1 
\v 145 عَلَتَلَ، ﭑ نَ ﭑ دّ رَوَقٍ عِ بّ ﭑ بْحّ بِرِن نَ.
\q1 ﭑ يَابِ، عَلَكٌ ﭑ شَ نْ عِ شَ يَامَرِيٍ رَتِنمّدٍ.
\q1 
\v 146 ﭑ نَ ﭑ دّ رَوَقٍ عِ بّ.
\q1 ﭑ نَكِسِ، عَلَكٌ ﭑ شَ نْ عِ سَفٌ رَبَدٍ.
\q1 
\v 147 ﭑ كٍلِمَ بٍيمَنُ سُبَشّ شَ عَ لِ،
\q1 ﭑ عِ مَشَندِ عِ شَ ﭑ دّ مّن.
\q1 ﭑ شَشِلِ تِشِ عِ شَ مَسٍنيِ نَن نَ.
\q1 
\v 148 ﭑ مُ شِمَ كْي رَ،
\q1 ﭑ نَ ﭑ مَحْشُنمَ عِ شَ مَسٍنيِ نَن تُن مَ.
\q1 
\v 149 عِ عِ تُلِ مَتِ ﭑ شُي رَ عِ شَ شَنُنتٍيَ شَ قٍ رَ.
\q1 عَلَتَلَ، ﭑ نَكِسِ عِ شَ كِيتِ بّرّ رَ.
\q1 
\v 150 مِشِيٍ بَرَ مَسٌ ﭑ نَ،
\q1 نَشٍيٍ وَ مَ قٍ حَاشِيٍ شْن.
\q1 عٍ مَكُيَ عِ شَ سّرِيّ رَ.
\q1 
\v 151 كْنْ عِ تَن عَلَتَلَ، عِ مَكْرّ ﭑ نَ،
\q1 عِ شَ يَامَرِيٍ قِندِشِ نْندِ نَن نَ.
\q1 
\v 152 ﭑ عَ كٌلٌن كَبِ عَ رَكُيَ،
\q1 عِ بَرَ عِ شَ مَسٍنيِ مَبَنبَن عَلَكٌ عَ شَ بُ عَبَدَن.
\b
\q1 
\v 153 ﭑ مَ تْورّ مَتٌ، عِ شَ ﭑ نَكِسِ،
\q1 بَرِ مَ ﭑ مُ نّيمُشِ عِ شَ سّرِيّ مَ.
\q1 
\v 154 عِ شَ ﭑ شُن مَقَلَ، عِ شَ ﭑ شُن سَرَ.
\q1 ﭑ نَكِسِ عَلْ عِ عَ لَايِدِ كِ نَشّ.
\q1 
\v 155 كِسِ مَكُيَ مِشِ حَاشِيٍ رَ،
\q1 بَرِ مَ عٍ مُ بِرَ مَ عِ شَ يَامَرِيٍ قْشْ رَ.
\q1 
\v 156 عَلَتَلَ، عِ شَ كِنِكِنِ فبٌ.
\q1 ﭑ نَكِسِ عِ شَ كِيتِ بّرّ رَ.
\q1 
\v 157 ﭑ فٍرٍقَيٍ وُيَ،
\q1 كْنْ ﭑ مُ فبِلٍن عِ سَفٌ قْشْ رَ.
\q1 
\v 158 عِ يَنقَمَيٍ تٌقٍ رَحَاشُ ﭑ مَ،
\q1 بَرِ مَ عٍ مُ عِ شَ مَسٍنيِ سُشُمَ.
\q1 
\v 159 عَ مَتٌ، عِ شَ يَامَرِيٍ رَقَن ﭑ مَ.
\q1 عَلَتَلَ، ﭑ نَكِسِ عِ شَ شَنُنتٍيَ شَ قٍ رَ.
\q1 
\v 160 عِ شَ مَسٍنيِ نْندِ نَ عَ رَ،
\q1 عِ شَ كِيتِ تِنشِنشِ بُمَ نّ عَبَدَن.
\b
\q1 
\v 161 مَنفّيٍ ﭑ تْورْ مَ هَلِ ﭑ مُ قٍ حَاشِ يٌ رَبَشِ عٍ رَ،
\q1 كْنْ ﭑ فَاشُمَ عِ شَ مَسٍنيِ يَ رَ ﭑ بْحّ بِرِن نَ.
\q1 
\v 162 ﭑ سّيوَشِ عِ شَ لَايِدِ رَ،
\q1 عَلْ مِشِ نَشَن فٍينِ شُنفبٍ سْتْشِ.
\q1 
\v 163 ﭑ وُلٍ شْنشِ، عَ رَحَاشُ ﭑ مَ،
\q1 كْنْ عِ شَ سّرِيّ ﭑ شَنُنتٍنيِ نَ عَ رَ.
\q1 
\v 164 ﭑ عِ مَتْشْمَ سَنمَيَ سٌلٌقٍرٍ لْشْ يٌ لْشْ
\q1 عِ شَ كِيتِ تِنشِنشِ شَ قٍ رَ.
\q1 
\v 165 بْحّسَ فبٍفبٍ نَن نَ مِشِيٍ بّ،
\q1 عِ شَ سّرِيّ رَقَنشِ نَشٍيٍ مَ.
\q1 قٍقٍ مُ عٍ رَبِرَ مَ.
\q1 
\v 166 عَلَتَلَ، ﭑ شَشِلِ تِشِ عِ شَ كِسِ رَ،
\q1 ﭑ بِرَ مَ نّ عِ شَ يَامَرِيٍ قْشْ رَ.
\q1 
\v 167 ﭑ عِ شَ مَسٍنيِ سُشُمَ نّ،
\q1 بَرِ مَ عٍ رَقَن ﭑ مَ كِ قَنيِ رَ.
\q1 
\v 168 ﭑ بِرَ مَ نّ عِ سَفٌ نُن عِ شَ مَسٍنيِ قْشْ رَ.
\q1 عِ ﭑ حّرّ كِ بِرِن كٌلٌن.
\b
\q1 
\v 169 عَلَتَلَ، عِ شَ ﭑ مَ دُبَ سُشُ.
\q1 قَهَامُي قِ ﭑ مَ عِ شَ مَسٍنيِ سَابُي رَ.
\q1 
\v 170 ﭑ مَ مَشَندِ شَ عِ لِ.
\q1 ﭑ نَكِسِ عَلْ عِ عَ لَايِدِ كِ نَشّ.
\q1 
\v 171 عِ مَتْشْي شَ مِنِ ﭑ دّ عِ،
\q1 بَرِ مَ عِ ﭑ شَرَنقٍ عِ شَ يَامَرِيٍ نَن نَ.
\q1 
\v 172 ﭑ دّ شَ بّيتِ ندٍ بَ عِ شَ مَسٍنيِ شَ قٍ رَ،
\q1 بَرِ مَ عِ شَ يَامَرِيٍ بِرِن تِنشِن.
\q1 
\v 173 عِ شَ قَ ﭑ دّ مّن،
\q1 بَرِ مَ ﭑ عِ سَفٌ نَن سُفَندِشِ.
\q1 
\v 174 عَلَتَلَ، ﭑ نِي نَ عِ شَ كِسِ مَ،
\q1 عِ شَ سّرِيّ ﭑ نَسّيوَ مَ نّ.
\q1 
\v 175 عِ شَ ﭑ نَكِسِ عَلَكٌ ﭑ شَ نْ عِ مَتْشْدٍ.
\q1 عِ شَ كِيتِيٍ شَ ﭑ دّ مّن.
\q1 
\v 176 ﭑ نَبّحِنشِ نّ عَلْ يّشّ لْيشِ.
\q1 عِ شَ ﭑ تَن عِ شَ كٌنيِ قٍن،
\q1 بَرِ مَ ﭑ مُ نّيمُشِ عِ شَ يَامَرِيٍ مَ.
\c 120
\s1 رَتَنفَقٍ فٍرٍ مَ
\s2 عَلَ مَشَندِ
\d 
\v 1 بِيَاسِلَيٍ شَ بّيتِ ندٍ
\q1 ﭑ نَ عَلَتَلَ مَشَندِ ﭑ مَ تْورّ كُي،
\q1 عَ ﭑ يَابِمَ نّ.
\q1 
\v 2 عَلَتَلَ، ﭑ نَتَنفَ وُلٍ قَلّيٍ دّ مَ،
\q1 نَشٍيٍ مِشِيٍ مَدَشُمَ.
\b
\q1 
\v 3 مِشِ مَدَشُي، عَ قَمَ مُنسٍ رَبَدٍ؟
\q1 
\v 4 عَ قَمَ سْشْي نَن تِدٍ تَنبّ رَلُفَنشِيٍ رَ،
\q1 عَ قَمَ فَنيِ تِدٍ تّ وٌلٍيٍ رَ.
\b
\q1 
\v 5 عَ شْرْشْ ﭑ بّ لُقٍ رَ مٍسٍكِ بْشِ مَ،
\q1 عَ شْرْشْ ﭑ بّ لُقٍ رَ كٍدَرِ بْنسْي يَ مَ.
\q1 
\v 6 ﭑ بَرَ بُ يِ مِشِيٍ يَ مَ، نَشٍيٍ بْحّسَ شْنشِ.
\q1 
\v 7 ﭑ تَن نَ بْحّسَ نَن بّ،
\q1 كْنْ ﭑ نّقّ وْيّن، عٍ تَن وَ مَ فٍرٍ نَن شْن مَ.
\c 121
\s1 دّ مّرِ كٍلِمَ عَلَ مَ
\s2 عَلَ مَتْشْي
\d 
\v 1 بِيَاسِلَيٍ شَ بّيتِ ندٍ
\q1 ﭑ نَ ﭑ يَ رَتٍمَ فٍيَيٍ مَبِرِ.
\q1 ﭑ مَ دّ مّرِ كٍلِمَ مِندٍن؟
\q1 
\v 2 ﭑ مَ دّ مّرِ قَتَنمَ عَلَتَلَ نَن نَ،
\q1 نَشَن كٌورٍ نُن بْشِ دَاشِ.
\b
\q1 
\v 3 عَ مُ تِنمَ عِ شَ بِرَ.
\q1 عَ عِ كَنتَمَ، عَ مُ كِنسْنمَ.
\q1 
\v 4 عِسِرَيِلَ كَنتَمَ مُ كِنسْنمَ، عَ مُ شِمَ.
\q1 
\v 5 عَلَتَلَ نَن عِ كَنتَمَ.
\q1 عَ قِندِشِ نِينِ نَن نَ عِ بّ،
\q1 
\v 6 عَلَكٌ سٌفٍ نَشَ عِ تْورْ يَنيِ رَ،
\q1 كِكٍ نَشَ عِ تْورْ كْي رَ.
\q1 
\v 7 عَلَتَلَ عِ رَتَنفَمَ نّ تْورّ بِرِن مَ،
\q1 عَ عِ نِي مَكَنتَمَ.
\q1 
\v 8 عِ نَ مِنِ، عَلَتَلَ لُمَ نّ عِ سّيتِ مَ.
\q1 عِ نَ سٌ، عَلَتَلَ بِرَ مَ نّ عِ قْشْ رَ.
\q1 عَ نَ عِ سّيتِ مَ يَكْسِ، عَ نَ عِ سّيتِ مَ عَبَدَن.
\c 122
\s1 بْحّسَ شَ لُ دَرِ سَلَمُ
\s2 عَلَ مَتْشْي
\d 
\v 1 بِيَاسِلَيٍ شَ بّيتِ ندٍ دَوُدَ نَشَن سّبّ
\q1 ﭑ بَرَ سّيوَ ﭑ بِيَاسِ بٌورٍيٍ شَ وْيّنيِ مَ، عَ قَلَقٍ رَ،
\q1 «وٌن شّي عَلَتَلَ شَ بَنشِ!»
\b
\q1 
\v 2 «يَكْسِ مُشُ سَنيِيٍ تِشِ عِ تَن دَرِ سَلَمُ سٌدٍ دّ رَ.»
\b
\q1 
\v 3 دَرِ سَلَمُ تَا نَ عَ رَ نَشَن تِشِ لَنيِ كُي.
\q1 
\v 4 عَلَتَلَ شَ مِشِيٍ تٍمَ نّ نَا عٍ بْنسْي كِ مَ
\q1 عَلَكٌ عٍ شَ عَلَتَلَ شِلِ مَتْشْ عَلْ عَ يَمَرِشِ كِ نَشّ.
\q1 
\v 5 كِيتِسَ شَ كِبَنيِيٍ دْشْشِ مّننِ نّ،
\q1 دَوُدَ بْنسْي شَ مَنفّ كِبَنيِيٍ.
\b
\q1 
\v 6 وٌ بْحّسَ مَشَندِ دَرِ سَلَمُ بّ!
\q1 «عَلَ شَ عِ شَنُنتٍنيِيٍ رَتَنفَ قٍ شْرْشْي مَ.
\q1 
\v 7 عَلَ شَ عَ نِيَ بْحّسَ شَ لُ عِ شَ تّتّ كُي.
\q1 عَلَ شَ عِ رَتَنفَ فٍرٍ مَ.»
\q1 
\v 8 ﭑ نفَشَكٍرٍنيِيٍ نُن ﭑ شَنُنتٍنيِيٍ شَ قٍ رَ،
\q1 ﭑ عَ قَلَمَ نّ، «بْحّسَ شَ لُ وٌ بّ!
\q1 
\v 9 ﭑ عِ شَ هّيرِ قٍنمَ نّ وٌن مَرِفِ عَلَتَلَ شَ هْرْ مْلِنفِرَ شَ قٍ رَ.»
\c 123
\s1 عَلَ شَ كٌنيِيٍ
\s2 عَلَ مَشَندِ
\d 
\v 1 بِيَاسِلَيٍ شَ بّيتِ ندٍ
\q1 ﭑ نَ ﭑ يَ رَتٍمَ عِ تَن نَن نَ،
\q1 عِ تَن نَشَن مَ كِبَنيِ نَ كٌورٍ مَ.
\q1 
\v 2 مُشُ يَيٍ تِشِ مُشُ مَرِفِ عَلَتَلَ نَن نَ عَ شَ كِنِكِنِ شَ قٍ رَ،
\q1 عَلْ كٌنيِيٍ يَيٍ تِشِ عٍ مَرِفِ رَ كِ نَشّ.
\b
\q1 
\v 3 عَلَتَلَ، كِنِكِنِ مُشُ مَ،
\q1 بَرِ مَ حَمَ بَرَ يٌ مُشُ مَ،
\q1 
\v 4 يّتّ عِفبٌي بَرَ مُشُ مَبٍرٍ.
\c 124
\s1 عَلَ شَ مَرَتَنفّ
\s2 عَلَ مَتْشْي
\d 
\v 1 بِيَاسِلَيٍ شَ بّيتِ ندٍ دَوُدَ نَشَن سّبّ
\q1 عِسِرَيِلَ حَمَ شَ عَ قَلَ؛
\q1 شَ عَلَتَلَ مُ لُ وٌن سّيتِ مَ نُ،
\q1 
\v 2 شَ عَلَتَلَ مُ وٌن مَلِ فٍرٍ كُي نُ،
\q1 
\v 3 نَ فٍرٍقَيٍ بَرَ وٌن شُن نَكَنَ عٍ شَ شْنّ رَ نُ،
\q1 
\v 4 عَلْ بَنبَرَنيِ دِنمَ شُرٍ مَ كِ نَشّ،
\q1 
\v 5 عَ قَ مِشِيٍ مَدُلَ يٍ شْورَ سّنبّ رَ.
\b
\q1 
\v 6 تَنتُي نَ عَلَتَلَ بّ،
\q1 نَشَن مُ تِن عٍ شَ نْ وٌن نَ.
\q1 
\v 7 وٌن بَرَ كِسِ عَلْ شْنِ نَشَن كِسِشِ فَنتَنيِ رَ.
\q1 فَنتَنيِ بَرَ كَنَ، يّلّ بَرَ بْو عَ رَ،
\q1 وٌن بَرَ عٍ لُ نَا.
\q1 
\v 8 وٌن مَ دّ مّرِ نَ عَلَتَلَ شِلِ نَن نَ،
\q1 نَشَن كٌورٍ نُن بْشِ دَاشِ.
\c 125
\s1 عَلَتَلَ عَ شَ حَمَ رَبِلِنقٍ
\s2 عَلَ شَ سّرِيّ
\d 
\v 1 بِيَاسِلَيٍ شَ بّيتِ ندٍ
\q1 نَشٍيٍ عٍ شَشِلِ تِمَ عَلَتَلَ رَ،
\q1 عٍ سّنبّ سْتْمَ نّ عَلْ سِيٌنِ فٍيَ
\q1 نَشَن مُ سّرّنمَ، عَ بُ عَبَدَن.
\q1 
\v 2 دَرِ سَلَمُ رَبِلِنشِ فٍيَيٍ رَ كِ نَشّ،
\q1 عَلَتَلَ عَ شَ حَمَ قَن نَبِلِنشِ نَ كِ نّ عَبَدَن.
\b
\q1 
\v 3 مَنفَسَنيِ حَاشِ مُ تِنشِنتْي شَ بْشِ يَمَرِ مَ،
\q1 عَلَكٌ تِنشِنتْي بّلّشّ نَشَ لَن قٍ حَاشِ.
\b
\q1 
\v 4 عَلَتَلَ، هِننّ مِشِ قَنيِيٍ رَ، نَشٍيٍ بْحّ قِيشّ،
\q1 
\v 5 كْنْ عِ تَن عَلَتَلَ، عِ شَ تِنشِنتَرٍيٍ كٍرِ عٍ يُفٍ مَ.
\b
\q1 عَلَ شَ بْحّسَ لُ عِسِرَيِلَ بْشِ مَ.
\c 126
\s1 عَلَ مِشِ شْرّيَقٍ
\s2 عَلَ مَتْشْي
\d 
\v 1 بِيَاسِلَيٍ شَ بّيتِ ندٍ
\q1 عَلَتَلَ تٌ فٍيلِمَنِيٍ رَفبِلٍن سِيٌنِ،
\q1 عَ لُ نّ مُشُ بّ عَلْ شِيٍ.
\q1 
\v 2 مُشُ نَشَ يٍلٍ، مُشُ نَشَ بّيتِ بَ سّيوّ رَ.
\q1 سِيٍ نُ عَ قَلَمَ نّ عٍ بٌرٍ بّ،
\q1 «عَلَتَلَ بَرَ كَابَنَكٌي رَبَ يِيٍ بّ.»
\q1 
\v 3 عِيٌ، عَلَتَلَ بَرَ كَابَنَكٌي رَبَ مُشُ بّ،
\q1 مُشُ سّيوَشِ كِ قَنيِ رَ.
\b
\q1 
\v 4 عَلَتَلَ، مُشُ هَرِفٍ رَفبِلٍن مُشُ مَ
\q1 عَلْ يٍ رَفبِلٍنمَ نٍفٍوِ بْشِ شُرٍ شْرِشِيٍ رَ كِ نَشّ.
\q1 
\v 5 مِشِ نَشٍيٍ شّ سَمَ يَيٍ رَ،
\q1 عٍ قَمَ نّ عَ شَبَدٍ سّيوّ كُي.
\q1 
\v 6 مِشِ نَشَن سِفَمَ سَنسِ سِدٍ، عٍ نَ وَقٍ،
\q1 نَ مِشِ فبِلٍنمَ نّ بَلٌي رَ، عَ سّيوَشِ.
\c 127
\s1 عَلَ نَن بَنشِ تِقٍ
\s2 عَلَ مَتْشْي
\d 
\v 1 بِيَاسِلَيٍ شَ بّيتِ ندٍ سُلٍمَنِ نَشَن بَ
\q1 شَ عَلَتَلَ شَ مُ بَنشِ تِ، عَ تِمَيٍ وَلِمَ نّ قُقَقُ.
\q1 شَ عَلَتَلَ شَ مُ تَا مَكَنتَمَ، عَ كَنتَمَيٍ وَلِمَ نّ قُقَقُ.
\q1 
\v 2 وٌ كٍلِمَ سُبَشّ مَ، وٌ وَلِمَ هَن كْي رَ بَلٌي سْتْقٍ رَ.
\q1 نَ كُي وٌ وَلِمَ تُن.
\q1 كْنْ عَلَ عَ شَنُنتٍنيِيٍ مَن كِمَ عٍ سَ تّمُي.
\b
\q1 
\v 3 دِيٍ قِندِ مَ نّ كّ رَ مِشِ بّ عَلَتَلَ نَشَن كِمَ،
\q1 قٍ قَنيِ سَرٍ نَن عٍ رَ، نَشٍيٍ كٍلِمَ عَ تَن مَ.
\q1 
\v 4 دِيٍ نَشٍيٍ سْتْشِ قٌنِكٍ تّمُي،
\q1 نٍيٍ تِدٍ لُمَ نّ عَلْ سْورِيٍ شَ شَلِيٍ.
\q1 
\v 5 بَرَكّ نَ مِشِ بّ نَشَن شَ شَلِ سَسٍ رَقٍشِ.
\q1 عَ يَشُييٍ مُ نْمَ عَ رَيَافِدٍ حَمَ يَ عِ.
\c 128
\s1 دِ قِندِشِ بَرَكَ نَن نَ
\s2 عَلَ شَ سّرِيّ
\d 
\v 1 بِيَاسِلَيٍ شَ بّيتِ ندٍ
\q1 سّيوّ نَ عَلَتَلَ شَ يَرَفَاشُي نَن بّ،
\q1 نَشَن حّرّ مَ عَ شَ كِرَ شْن مَ.
\q1 
\v 2 عِ شَ وَلِ فٍينِ لُمَ عِ تَن نَن بّ،
\q1 عَ قِندِ سّيوّ نُن هَرِفٍ رَ عِ بّ.
\q1 
\v 3 عِ شَ فِنّ لُمَ نّ عَلْ وُرِ بٌفِلَ عِ شَ بَنشِ كُي،
\q1 عِ شَ دِيٍ لُمَ نّ عَلْ وُرِ نّينّيٍ عِ شَ تٍيبِلِ سّيتِ مَ.
\q1 
\v 4 عَ نَ نَ كِ نّ عَلَتَلَ شَ يَرَفَاشُي بّ،
\q1 عَ بَرَكَشِ.
\b
\q1 
\v 5 عَلَتَلَ شَ عِ بَرَكَ كٍلِقٍ سِيٌنِ.
\q1 عِ شَ دَرِ سَلَمُ هَرِفٍ تٌ عِ شَ سِمَيَ بِرِن كُي.
\q1 
\v 6 عِ شَ عِ شَ دِيٍ شَ دِيٍ تٌ.
\b
\q1 عَلَ شَ بْحّسَ لُ عِسِرَيِلَ بْشِ مَ.
\c 129
\s1 عَلَ شُننَكٍلِ قِقٍ تْورْ مِشِ مَ
\s2 عَلَ مَتْشْي
\d 
\v 1 بِيَاسِلَيٍ شَ بّيتِ ندٍ
\q1 عِسِرَيِلَ شَ عَ قَلَ؛
\q1 ﭑ فٍرٍقَيٍ بَرَ ﭑ تْورْ كَبِ ﭑ قٌنِكٍ تّمُي.
\q1 
\v 2 عٍ بَرَ ﭑ تْورْ عَ حَاشِ رَ كَبِ عَ قْلّ،
\q1 كْنْ عٍ مُ نْ ﭑ نَ.
\q1 
\v 3 عٍ بَرَ ﭑ قَرِ عِبْو عَلْ شّ سَيٍ بْشِ بْو مَ كِ نَشّ.
\q1 
\v 4 كْنْ عَلَتَلَ تِنشِن.
\q1 عَ بَرَ مِشِ كٌبِيٍ شَ لُوتِ شِرِشِيٍ بٌلٌن.
\b
\q1 
\v 5 عَلَ شَ سِيٌنِ شْنمِشِيٍ رَيَافِ.
\q1 
\v 6 عَلَ شَ عٍ لُ عَلْ بَنشِ قَرِ حٌوفٍ،
\q1 نَشَن شَرَ مَ بٍينُن عَ شَ تَلَ،
\q1 
\v 7 نَشَن مُ قِندِ مَ بَلٌي رَ شّ سَيٍ بّ.
\q1 
\v 8 دَنفِ مِشِيٍ نَشَ دُبَ وٌ بّ، عَ قَلَقٍ رَ،
\q1 «عَلَ شَ وٌ بَرَكَ.
\q1 مُشُ بَرَ دُبَ وٌ بّ عَلَتَلَ شِلِ رَ.»
\c 130
\s1 عَلَتَلَ مَرَكِسِمَ
\s2 عَلَ مَشَندِ
\d 
\v 1 بِيَاسِلَيٍ شَ بّيتِ ندٍ
\q1 عَلَتَلَ، ﭑ عِ شِلِمَ ﭑ مَ تْورّ تِلِنشِ نَن كُي.
\q1 
\v 2 ﭑ مَرِفِ، عِ شَ عِ تُلِ مَتِ ﭑ شُي رَ،
\q1 عِ شَ ﭑ مَ مَشَندِ رَ مّ كِنِكِنِ كُي.
\b
\q1 
\v 3 شَ عِ تَن عَلَتَلَ رَتُمَ مِشِيٍ شَ يُنُبِيٍ مَ،
\q1 ندٍ نْمَ تِدٍ عِ يَ رَ سْنْن؟
\q1 
\v 4 كْنْ عِ تَن يُنُبِيٍ شَقَرِ مَ نّ.
\q1 نَ كُي مِشِ فَاشُمَ نّ عِ يَ رَ.
\b
\q1 
\v 5 ﭑ شَشِلِ تِشِ عَلَتَلَ نَن نَ ﭑ نِي بِرِن نَ،
\q1 ﭑ يَ تِشِ عَ شَ مَسٍنيِ نَن نَ.
\q1 
\v 6 ﭑ شَشِلِ نَشَن تِشِ ﭑ مَرِفِ رَ،
\q1 نَ دَنفِ تَا مَكَنتّ شَ مَمّ تِ رَ كُيٍ عِبَ رَ.
\q1 عَ فبٌ نَ بّ.
\b
\q1 
\v 7 عِسِرَيِلَ، عِ شَ عِ شَشِلِ تِ عَلَتَلَ رَ،
\q1 بَرِ مَ عِ شَ شَنُنتٍيَ نَ عَ بْحّ كُي،
\q1 عَ عِ شُنسَرٍ بِرِن قِمَ نّ.
\q1 
\v 8 عَ تَن نَن عِسِرَيِلَ شُن سَرَ مَ عَ شَ يُنُبِيٍ بِرِن مَ.
\c 131
\s1 دَنشَنِيَتْي شَ مَرَشَرّ
\s2 عَلَ مَتْشْي
\d 
\v 1 بِيَاسِلَيٍ شَ بّيتِ ندٍ دَوُدَ نَشَن بَ
\q1 عَلَتَلَ، يّتّ عِفبٌي مُ ﭑ نَ،
\q1 ﭑ مُ لَ ﭑ يّتّ رَ.
\q1 ﭑ مُ سٌمَ قٍيٍ يَ مَ نَشٍيٍ سّنبّ فبٌ ﭑ بّ،
\q1 نَشٍيٍ دَنفِ ﭑ مَ قَهَامُي رَ.
\q1 
\v 2 ﭑ نَشَن نَبَشِ، ﭑ نَ ﭑ سَبَرِشِ نّ،
\q1 ﭑ نَ ﭑ نِي رَشَرَ عَلْ دِ دّ بَشِ.
\b
\q1 
\v 3 عِسِرَيِلَ، عِ شَ عِ شَشِلِ تِ عَلَتَلَ رَ تّمُي بِرِن.
\c 132
\s1 عَلَ شَ لَايِدِ دَوُدَ نُن دَرِ سَلَمُ بّ
\s2 عَلَ مَشَندِ
\d 
\v 1 بِيَاسِلَيٍ شَ بّيتِ ندٍ
\q1 عَلَتَلَ، عِ شَ رَتُ دَوُدَ مَ
\q1 عَ نُن عَ شَ تْورّ بِرِن مَ.
\b
\q1 
\v 2 عَ نَشَ عَ رَكَلِ عَلَتَلَ بّ،
\q1 عَ نَشَ عَ رَكَلِ يَشُبَ مَرِفِ عَلَ سّنبّمَ بّ،
\q1 
\v 3 «ﭑ مُ سٌمَ ﭑ شْنيِ، ﭑ مُ ﭑ سَمَ،
\q1 
\v 4 ﭑ مُ ﭑ يَ مَشِمَ،
\q1 ﭑ مُ ﭑ يَ مَفِرَ مَ،
\q1 
\v 5 هَن ﭑ سَ لِنفِرَ سْتْمَ يَشُبَ مَرِفِ عَلَ سّنبّمَ بّ تّمُي نَشّ.»
\b
\q1 
\v 6 وٌن نُ بَرَ عَ شَ قٍ مّ عٍقَرَتَ بْشِ مَ.
\q1 وٌن نَشَ عَ لِ يَارَ شَ شّ مَ.
\q1 
\v 7 «وٌن شّي عَ شَ هْرْ مْلِنفِرَ يِرٍ،
\q1 وٌن شَ وٌن شِنبِ سِن عَ سَنتِدٍ يَ عِ.
\q1 
\v 8 عَلَتَلَ، كٍلِ عِ شَ تَلُ عِ سَبَتِدٍ،
\q1 عِ تَن نُن عِ شَ سَاتّ كَنكِرَ.
\q1 
\v 9 عِ شَ سّرّشّدُبّيٍ شَ لُ شُننَكٍلِ كُي،
\q1 عِ دُفُتّفّيٍ شَ عٍ سّيوّ شُي رَتٍ.»
\b
\q1 
\v 10 عِ شَ كٌنيِ دَوُدَ شَ قٍ رَ،
\q1 عِ نَشَ مّي عِ شَ مَنفّ سُفَندِشِ رَ.
\b
\q1 
\v 11 عَلَتَلَ عَ كَلِ نّ دَوُدَ بّ،
\q1 مَرَكَلِ نَشَن مُ كَنَمَ،
\q1 عَ نَشّ، «ﭑ عِ بْنسْي ندٍ نَن دْشْمَ عِ شَ كِبَنيِ مَ.
\q1 
\v 12 شَ عِ شَ دِيٍ سَ ﭑ مَ سَاتّ بِنيَ،
\q1 عٍ ﭑ مَ يَامَرِيٍ رَبَتُ،
\q1 عٍ شَ دِيٍ قَن لُمَ نّ عِ شَ كِبَنيِ مَ عَبَدَن.»
\b
\q1 
\v 13 بَرِ مَ عَلَتَلَ بَرَ سِيٌنِ سُفَندِ،
\q1 مّننِ نَن نَقَنشِ عَ مَ عَ سَبَتِدٍ رَ.
\q1 
\v 14 عَ نَشّ، «ﭑ سَبَتِدٍ نَن بٍ رَ عَبَدَن.
\q1 ﭑ دْشْمَ بٍ ﭑ مَ كِبَنيِ كُي بَرِ مَ بٍ رَقَنشِ ﭑ مَ.
\q1 
\v 15 ﭑ بَرَكّ سَمَ نّ سِيٌنِكَيٍ مَ،
\q1 ﭑ بَلٌي قِ عٍ شَ مِسِكِينّيٍ مَ.
\q1 
\v 16 ﭑ كِسِ قِمَ نّ عٍ شَ سّرّشّدُبّيٍ مَ،
\q1 عٍ دُفُتّفّيٍ بّيتِ بَمَ نّ سّيوّ كُي.»
\b
\q1 
\v 17 «بٍ ﭑ دَوُدَ سّنبّ رَكٍلِمَ نّ،
\q1 ﭑ نَءِيَلَنيِ رَ مِنِمَ نّ ﭑ مَ مِشِ سُفَندِشِ بّ.
\q1 
\v 18 ﭑ يَافِ دُ سُمَ نّ عَ يَشُييٍ شُن نَ،
\q1 كْنْ ﭑ نْرّ دُ سُمَ عَ تَن نَن شُن نَ.»
\c 133
\s1 عَلَ شَ حَمَ شَ لَنيِ
\s2 عَلَ مَتْشْي
\d 
\v 1 بِيَاسِلَيٍ شَ بّيتِ ندٍ دَوُدَ نَشَن بَ
\q1 نفَشَكٍرٍنيِيٍ لَنمَ عٍ شَ لُ لَنيِ كُي.
\q1 قٍ قَنيِ يَتِ يَتِ نَن نَ كِ.
\q1 
\v 2 نَ قَن عَلْ تُرٍ نَشَن سُرُ سُرُ مَ هَرُنَ شُنيِ مَ،
\q1 عَ قَ فٌرٌ عَ دّشَبٍ مَ،
\q1 هَن عَ دُفِ لِ.
\q1 
\v 3 نَ لُمَ نّ عَلْ شِنِ نَشَن فٌرٌ مَ شٍرِ مٌن نُن سِيٌنِ فٍيَيٍ مَ،
\q1 بَرِ مَ عَلَتَلَ بَرَكّ نُن كِسِ رَفٌرٌ مَ نَا عَبَدَن.
\c 134
\s1 دُبَ سّرّشّدُبّ بّ
\s2 عَلَ مَتْشْي
\d 
\v 1 بِيَاسِلَيٍ شَ بّيتِ ندٍ
\q1 وٌ تَن عَلَتَلَ شَ كٌنيِيٍ،
\q1 وٌ شَ عَلَتَلَ مَتْشْ،
\q1 وٌ تَن نَشٍيٍ وَلِمَ كْي رَ عَلَتَلَ شَ هْرْ مْبَنشِ كُي.
\q1 
\v 2 وٌ شَ وٌ بّلّشّ عِتٍ هْرْ مْبَنشِ كُي عَلَتَلَ مَتْشْقٍ رَ.
\b
\q1 
\v 3 عَلَتَلَ نَشَن كٌورٍ نُن بْشِ دَا،
\q1 عَ شَ بَرَكّ سَ وٌ مَ كٍلِقٍ سِيٌنِ.
\c 135
\s1 عِسِرَيِلَ شَ مَتْشْي
\s2 عَلَتَلَ مَتْشْي
\q1 
\v 1 وٌ مَرِفِ عَلَتَلَ مَتْشْ،
\q1 وٌ عَ شِلِ مَتْشْ.
\q1 عَلَتَلَ شَ كٌنيِيٍ، وٌ شَ عَ مَتْشْ،
\q1 
\v 2 وٌ تَن نَشٍيٍ وَلِمَ عَلَتَلَ شَ هْرْ مْبَنشِ كُي،
\q1 وٌن تَن نَشٍيٍ وَلِمَ عَلَ شَ بَنشِ تّتّ كُي.
\b
\q1 
\v 3 وٌ شَ عَلَتَلَ مَتْشْ، بَرِ مَ عَ قَن.
\q1 وٌ شَ بّيتِ بَ عَ شِلِ مَتْشْقٍ رَ،
\q1 بَرِ مَ عَ رَقَن عَ مَ.
\q1 
\v 4 عَلَتَلَ بَرَ يَشُبَ سُفَندِ عَ يّتّ بّ،
\q1 عَلَكٌ عِسِرَيِلَ شَ قِندِ عَ شَ حَمَ قَنيِ رَ.
\b
\q1 
\v 5 ﭑ تَن عَ كٌلٌن عَ عَلَتَلَ فبٌ،
\q1 وٌن مَرِفِ دَنفِ عَلَيٍ بِرِن نَ.
\q1 
\v 6 عَلَتَلَ عَ وَشْنقٍ رَبَمَ نّ كٌورٍ نُن بْشِ مَ،
\q1 عَ عَ رَبَمَ نّ بَا تِلِنشِيٍ مَ.
\q1 
\v 7 عَ نُشُييٍ رَتٍمَ كٍلِ دُنِحَ تُنشُنيِ نَانِ مَ،
\q1 عَ تُنّ رَقَ نُن سٍيَمَكْنيِ،
\q1 عَ قٌيٍ شُنفبٍ رَ مِنِ عَ رَفَتَدٍ كُي.
\b
\q1 
\v 8 عَ مِسِرَ دِ سِنفٍيٍ بِرِن قَشَ،
\q1 كٍلِ مِشِيٍ مَ هَن عَ سَ شُرُ سٍيٍ لِ.
\q1 
\v 9 عَ نَشَ تْنشُمَيٍ نُن كَابَنَكٌي رَبَ مِسِرَ،
\q1 قِرَوُنَ نُن عَ شَ وَلِكّيٍ بِرِن شِلِ مَ.
\q1 
\v 10 عَ نَشَ سِيٍ وُيَشِ بْنبْ،
\q1 عَ مَنفّ سّنبّمَ فبٍفبٍ قَشَ.
\q1 
\v 11 عَ نَشَ عَمٌرِكَيٍ شَ مَنفّ سِشْن،
\q1 بَسَن مَنفّ عٌفٌ، نُن كَنَان مَنفّ بِرِن شَ بْشِ تٌنفٌ،
\q1 
\v 12 عَ نَشَ عَ قِ عَ شَ حَمَ عِسِرَيِلَ مَ كّ رَ.
\b
\q1 
\v 13 عَلَتَلَ، عِ شِلِ مُ لْيمَ عَبَدَن،
\q1 عِ شِلِ عِقَلَمَ نّ تّمُي بِرِن،
\q1 
\v 14 بَرِ مَ عَلَتَلَ قَمَ نّ عَ شَ حَمَ فبٍحْشْدٍ،
\q1 عَ قَ كِنِكِنِ عَ شَ كٌنيِيٍ مَ.
\b
\q1 
\v 15 سِ نَشٍيٍ مُ عَلَ كٌلٌن،
\q1 عٍ كُيٍيٍ يَءِلَنمَ شّيمَ نُن فبٍتِ نَن نَ عٍ بّلّشّيٍ رَ.
\q1 
\v 16 دّ نَ نَ كُيٍيٍ بّ، كْنْ عٍ مُ وْيّنمَ.
\q1 يَيٍ نَ عٍ بّ، كْنْ عٍ مُ سٍ تٌمَ.
\q1 
\v 17 تُلِيٍ نَ عٍ بّ، كْنْ عٍ مُ قٍ مّمَ.
\q1 حّنفِ يٌ مُ عٍ قَتٍ عِ.
\q1 
\v 18 عٍ رَقَلَمَيٍ شَ لُ عَلْ عٍ تَن،
\q1 عَ نُن نَشٍيٍ بِرِن لَمَ عٍ رَ.
\b
\q1 
\v 19 عِسِرَيِلَكَيٍ، وٌ تَن شَ عَلَتَلَ تَنتُ.
\q1 هَرُنَ بْنسْي، وٌ شَ عَلَتَلَ تَنتُ.
\q1 
\v 20 لٍوِ بْنسْي، وٌ شَ عَلَتَلَ تَنتُ.
\q1 وٌ تَن عَلَ يَرَفَاشُييٍ، وٌ شَ عَلَتَلَ تَنتُ.
\q1 
\v 21 تَنتُي نَ عَلَتَلَ بّ كٍلِقٍ سِيٌنِ.
\q1 تَنتُي نَ عَلَتَلَ بّ نَشَن سَبَتِشِ دَرِ سَلَمُ.
\q1 وٌ شَ عَلَتَلَ مَتْشْ!
\c 136
\s1 تَنتُي نَ عَلَ بّ عَ شَ شَنُنتٍيَ شَ قٍ رَ
\s2 عَلَ مَتْشْي
\q1 
\v 1 وٌ عَلَتَلَ تَنتُ، بَرِ مَ عَ قَن،
\q2 دَن مُ نَ عَ شَ شَنُنتٍيَ مَ.
\q1 
\v 2 وٌ عَلَتَلَ تَنتُ نَشَن دَنفِ عَلَيٍ بِرِن نَ،
\q2 بَرِ مَ دَن مُ نَ عَ شَ شَنُنتٍيَ مَ.
\q1 
\v 3 وٌ مَرِفِيٍ شَ مَرِفِ تَنتُ،
\q2 بَرِ مَ دَن مُ نَ عَ شَ شَنُنتٍيَ مَ.
\b
\q1 
\v 4 وٌ شَ عَ تَن تَنتُ،
\q1 عَ تَن نَشَن كٍرٍن كَابَنَكٌي رَبَمَ،
\q2 بَرِ مَ دَن مُ نَ عَ شَ شَنُنتٍيَ مَ،
\q1 
\v 5 عَ تَن نَشَن كٌورٍ دَاشِ عَ شَ قَهَامُي رَ،
\q2 بَرِ مَ دَن مُ نَ عَ شَ شَنُنتٍيَ مَ،
\q1 
\v 6 عَ تَن نَشَن بْشِ عِتَلَ يٍيٍ قَرِ،
\q2 بَرِ مَ دَن مُ نَ عَ شَ شَنُنتٍيَ مَ،
\q1 
\v 7 عَ تَن نَشَن يَنبَ سٍ شُنفبٍيٍ دَاشِ،
\q2 بَرِ مَ دَن مُ نَ عَ شَ شَنُنتٍيَ مَ،
\q2 
\v 8 سٌفٍ، عَلَكٌ عَ شَ يَنيِ عِيَلَن،
\q2 بَرِ مَ دَن مُ نَ عَ شَ شَنُنتٍيَ مَ،
\q2 
\v 9 كِكٍ نُن تُنبُييٍ، عَلَكٌ عٍ شَ كْي عِيَلَن،
\q2 بَرِ مَ دَن مُ نَ عَ شَ شَنُنتٍيَ مَ.
\b
\q1 
\v 10 وٌ شَ عَ تَن نَن تَنتُ،
\q1 عَ تَن نَشَن مِسِرَكَيٍ شَ دِ سِنفٍيٍ قَشَ،
\q2 بَرِ مَ دَن مُ نَ عَ شَ شَنُنتٍيَ مَ،
\q1 
\v 11‏-12 عَ تَن نَشَن عِسِرَيِلَ رَ مِنِ مِسِرَ بْشِ مَ عَ سّنبّ نُن عَ شَ نْي رَ،
\q2 بَرِ مَ دَن مُ نَ عَ شَ شَنُنتٍيَ مَ،
\q1 
\v 13 عَ تَن نَشَن شُلُنيُمِ بَا عِبٌلٌن قِرِن نَ،
\q2 بَرِ مَ دَن مُ نَ عَ شَ شَنُنتٍيَ مَ،
\q1 
\v 14 عَ تَن نَشَن عِسِرَيِلَكَيٍ رَدَنفِ بَا تَفِ،
\q2 بَرِ مَ دَن مُ نَ عَ شَ شَنُنتٍيَ مَ،
\q1 
\v 15 عَ تَن نَشَن قِرَوُنَ نُن عَ شَ حَمَ رَ سِن شُلُنيُمِ بَا شْورَ،
\q2 بَرِ مَ دَن مُ نَ عَ شَ شَنُنتٍيَ مَ.
\b
\q1 
\v 16 وٌ شَ عَ تَن نَن تَنتُ،
\q1 عَ تَن نَشَن عَ شَ حَمَ رَدَنفِ فبٍنفبٍرٍنيِ رَ،
\q2 بَرِ مَ دَن مُ نَ عَ شَ شَنُنتٍيَ مَ،
\q1 
\v 17 عَ تَن نَشَن مَنفّ شُنفبٍيٍ قَشَ،
\q2 بَرِ مَ دَن مُ نَ عَ شَ شَنُنتٍيَ مَ،
\q1 
\v 18 عَ تَن نَشَن مَنفّ سّنبّمَيٍ قَشَ،
\q2 بَرِ مَ دَن مُ نَ عَ شَ شَنُنتٍيَ مَ،
\q1 
\v 19 عَلْ عَمٌرِ مَنفّ سِشْن،
\q2 بَرِ مَ دَن مُ نَ عَ شَ شَنُنتٍيَ مَ،
\q1 
\v 20 عَلْ بَسَن مَنفّ عٌفٌ،
\q2 بَرِ مَ دَن مُ نَ عَ شَ شَنُنتٍيَ مَ،
\q1 
\v 21‏-22 عَ تَن نَشَن عٍ شَ بْشِ قِ عَ شَ كٌنيِ عِسِرَيِلَ مَ كّ رَ،
\q1 بَرِ مَ دَن مُ نَ عَ شَ شَنُنتٍيَ مَ.
\b
\q1 
\v 23 وٌ شَ عَ تَن نَن تَنتُ،
\q1 عَ تَن نَشَن رَتُشِ مُشُ شَ كٌنيِيَ مَ،
\q2 بَرِ مَ دَن مُ نَ عَ شَ شَنُنتٍيَ مَ،
\q1 
\v 24 عَ تَن نَشَن مُشُ بَشِ مُشُ يَشُييٍ يِ رَ،
\q2 بَرِ مَ دَن مُ نَ عَ شَ شَنُنتٍيَ مَ،
\q1 
\v 25 عَ تَن نَشَن نّمّ قِمَ عَ شَ دَالِ بِرِن مَ،
\q2 بَرِ مَ دَن مُ نَ عَ شَ شَنُنتٍيَ مَ.
\b
\q1 
\v 26 وٌ عَلَ تَنتُ نَشَن نَ كٌورٍ مَ،
\q2 بَرِ مَ دَن مُ نَ عَ شَ شَنُنتٍيَ مَ.
\c 137
\s1 عِسِرَيِلَ شَ كٌنيِيَ بَبِلْن بْشِ مَ
\s2 عَلَ مَتْشْي
\q1 
\v 1 مُشُ نُ دْشْشِ بَبِلْن شُرٍيٍ دّ رَ سِيٌنِ شَ قٍ رَتُقٍ رَ.
\q1 
\v 2 مُشُ نُ بَرَ مُشُ شَ كْرَيٍ فبَكُ وُرِ بِلِيٍ كْن نَ.
\q1 
\v 3 مُشُ يَشُييٍ نُ سِيٌنِ بّيتِيٍ مَشْرِن مُشُ مَ،
\q1 عٍ نُ وَ مَ بّيتِ سّيوَشِ ندٍ شْن.
\q1 عٍ نَشّ، «سِيٌنِ بّيتِ ندٍ بَ مُشُ بّ.»
\b
\q1 
\v 4 مُشُ نْمَ بّيتِ بَدٍ عَلَتَلَ بّ يِ كٌنيِيَ كُي دِ؟
\q1 
\v 5 دَرِ سَلَمُ، شَ ﭑ نّيمُ عِ مَ، ﭑ بّلّشّ نَشَ نْ كْرَ رَبٍرٍدٍ سْنْن،
\q1 
\v 6 ﭑ نّنيِ شَ كَنكَن ﭑ دّ كُي.
\q1 نَ شَ رَبَ ﭑ نَ شَ عَ سَ لِ ﭑ نَشَ نّيمُ دَرِ سَلَمُ مَ،
\q1 شَ عَ شَ قٍ مُ قِندِ ﭑ مَ سّيوّ رَ.
\b
\q1 
\v 7 عَلَتَلَ، عِ شَ رَتُ عٍدٌنكَيٍ شَ قٍ رَبَ مَ دَرِ سَلَمُ شَ نِمِسّ لْشْي.
\q1 عٍ تَن نَن نُ عَ قَلَمَ،
\q1 «وٌن شَ عَ كَنَ هَن وٌن سَ عَ بَ عَ بُنيِ رَ.»
\b
\q1 
\v 8 بَبِلْن، وٌ شَ شُننَفٌرٍ بَرَ فّ حَنِفٍدٍ،
\q1 سّيوّ نَ عَ بّ نَشَن عِ سَرٍ رَفبِلٍنمَ عِ مَ،
\q1 عِ قٍ حَاشِ نَشَن نَبَشِ مُشُ رَ.
\q1 
\v 9 سّيوّ نَ مِشِ بّ نَشَن عِ شَ دِيٍ سُشُمَ،
\q1 عَ عٍ بُتُشُن قَنيٍ قَرِ.
\c 138
\s1 عَلَ بَتُقٍ بْحّ بِرِن نَ
\d دَوُدَ شَ بّيتِ
\q1 
\v 1 ﭑ عِ بَتُمَ نّ ﭑ بْحّ بِرِن نَ،
\q1 ﭑ عِ مَتْشْ عَلَيٍ يَ عِ.
\q1 
\v 2 ﭑ نَ ﭑ شِنبِ سِنمَ نّ عِ شَ هْرْ مْلِنفِرَ مَبِرِ،
\q1 ﭑ عِ شِلِ مَتْشْ عِ شَ شَنُنتٍيَ نُن دُفُتّفّحَ شَ قٍ رَ،
\q1 بَرِ مَ عِ بَرَ عِ شِلِ نُن عِ شَ مَسٍنيِ رَتٍ قٍ بِرِن شُن نَ.
\q1 
\v 3 ﭑ تٌ عِ شِلِ، عِ نَشَ ﭑ يَابِ،
\q1 عِ نَشَ ﭑ نَلِمَنِيَ عِ سّنبّ رَ.
\b
\q1 
\v 4 مَنفّ نَشٍيٍ بِرِن نَ يِ دُنِحَ مَ،
\q1 عٍ نَ عِ شَ مَسٍنيِ رَ مّ، عٍ شَ عِ مَتْشْ.
\q1 
\v 5 عٍ شَ عَلَتَلَ شَ كِرَ مَتْشْ،
\q1 بَرِ مَ عَلَتَلَ شَ نْرّ فبٌ.
\b
\q1 
\v 6 هَلِ عَلَتَلَ نَ كٌورٍ مَ،
\q1 عَ مّينِمَ نّ مِشِ مَفٌرٌشِيٍ مَ،
\q1 كْنْ عَ مَكُيَمَ نّ يّتّ عِفبٌييٍ رَ.
\q1 
\v 7 ﭑ نَ لُ تْورّ كُي، عِ ﭑ نَكِسِمَ نّ،
\q1 عِ ﭑ يَشُييٍ شَ شْنّ شُن نَكَنَمَ نّ،
\q1 عِ قَ ﭑ نَكِسِ عِ سّنبّ رَ.
\q1 
\v 8 عَلَتَلَ ﭑ مَ قٍيٍ رَكَمَلِمَ نّ.
\q1 عَلَتَلَ، دَن مُ نَ عِ شَ شَنُنتٍيَ مَ.
\q1 عِ نَشَ عِ شَ دَالِيٍ رَبٌلٌ.
\c 139
\s1 عَلَ مِشِيٍ كٌلٌنقٍ
\s2 عَلَ مَتْشْي
\d 
\v 1 دَوُدَ شَ بّيتِ بّيتِبَيٍ شَ مَنفّ بّ
\q1 عَلَتَلَ، عِ ﭑ بْحّ بِرِن كٌلٌن.
\q1 
\v 2 عِ ﭑ دْشْ تّمُي كٌلٌن، عِ ﭑ كٍلِ تّمُي كٌلٌن،
\q1 عِ ﭑ مَ مَحْشُنيِيٍ بِرِن كٌلٌن
\q1 بٍينُن ﭑ شَ عٍ مَحْشُن.
\q1 
\v 3 عِ ﭑ حّرّ تّمُي كٌلٌن، عِ ﭑ سَ تّمُي كٌلٌن،
\q1 عِ ﭑ مَ كِرَيٍ بِرِن كٌلٌن.
\q1 
\v 4 بٍينُن وْيّنيِ شَ مِنِ ﭑ دّ عِ،
\q1 عِ تَن حَن بَرَ عَ بِرِن كٌلٌن.
\q1 
\v 5 عِ ﭑ نَبِلِنمَ نّ عِ شْنيّيٍ رَ.
\q1 
\v 6 نَ قٍ كٌلٌنيِ مَكَابَشِ فبٌ ﭑ تَن بّ،
\q1 عَ دَنفِ ﭑ مَ قَهَامُي رَ.
\b
\q1 
\v 7 ﭑ سِفَمَ مِندٍن، ﭑ شَ ﭑ مَكُيَ عِ شَشِلِ رَ؟
\q1 ﭑ نَ ﭑ فِمَ مِندٍن، ﭑ شَ ﭑ نْشُن عِ مَ؟
\q1 
\v 8 شَ ﭑ سَ تٍ كٌورٍ نّ، عِ نَ مّننِ.
\q1 شَ ﭑ سَ فٌرٌ عَلِفِيَمَ نّ، ﭑ عِ لِمَ نّ نَا.
\q1 
\v 9 شَ ﭑ سَ كٍلِ سُبَشّ مَ، ﭑ بَا عِفِرِ،
\q1 
\v 10 عِ بّلّشّ ﭑ نَحّرّ مَ نّ، عِ سّنبّ ﭑ مَلِمَ نّ.
\q1 
\v 11 شَ عَ سَ لِ ﭑ قَ عَ قَلَ،
\q1 «ﭑ نْمَ ﭑ نْشُندٍ دِ مِ كُي نَءِيَلَنيِ مُ نَ دّننَشّ،»
\q1 
\v 12 عِ ﭑ تٌمَ نّ نَ دِ مِ كُي عَلْ ﭑ نَ سٌفٍ نَن بُن مَ.
\b
\q1 
\v 13 عِ تَن نَن ﭑ نِي دَاشِ،
\q1 عِ تَن نَن ﭑ نَقَلَشِ ﭑ نفَ تّيفّ.
\q1 
\v 14 ﭑ عِ مَتْشْمَ نّ بَرِ مَ ﭑ دَا كِ مَكَابَ.
\q1 عِ شَ وَلِ مَنِيّ مُ نَ.
\q1 ﭑ نَ كٌلٌنشِ عَ قَنيِ رَ.
\q1 
\v 15 ﭑ قَتٍ كِ مُ نُ نْشُنشِ عِ مَ
\q1 عَ تٌ يَءِلَنشِ فُندٌ كُي.
\q1 
\v 16 عِ يَيٍ نَشَ ﭑ تٌ بٍينُن ﭑ شَ قِندِ عَ رَ.
\q1 ﭑ مَ لْشْييٍ بِرِن نُ سّبّشِ عِ شَ بُكِ كُي بٍينُن ﭑ شَ دَالِ.
\q1 
\v 17 عَلَ، عِ شَ مَحْشُنيِيٍ فبٌ، عٍ تِلِن.
\q1 
\v 18 شَ ﭑ سَ عٍ كْنتِمَ نّ نُ، عٍ وُيَ مّيّنيِ شْرِ بّ.
\q1 نَ بِرِن كُي، ﭑ لُمَ عِ يِ.
\b
\q1 
\v 19 عَلَ، يَندِ، عِ شَ مِشِ حَاشِيٍ قَشَ،
\q1 عِ شَ قَشّتِيٍ مَكُيَ ﭑ نَ.
\q1 
\v 20 عِ يَشُييٍ قٍ حَاشِ قَلَمَ عِ شَ قٍ رَ، عٍ عِ شِلِ كَنَمَ.
\q1 
\v 21 عَلَتَلَ، عَ مُ لَنمَ ﭑ شَ عِ شْنمِشِيٍ شْن؟
\q1 عَ مُ لَنمَ عِ مَتَندِلَيٍ شَ رَحَاشُ ﭑ مَ؟
\q1 
\v 22 ﭑ عٍ شْنمَ نّ. عٍ بَرَ قِندِ ﭑ يَشُييٍ رَ.
\b
\q1 
\v 23 عَلَ عِ شَ ﭑ بْحّ كُي مَتٌ،
\q1 عِ شَ ﭑ مَ كْنتْقِلِ كٌلٌن.
\q1 
\v 24 عَ مَتٌ شَ ﭑ نَ كِرَ كٌبِ ندٍ نَن شْن مَ،
\q1 عِ نَشَن شْنشِ.
\q1 شَ عَ نَ نَ كِ نّ، عِ شَ ﭑ تِ كِسِ كِرَ نَن شْن مَ.
\c 140
\s1 مِشِ كٌبِ عَلْ بْشِمَسٍ
\s2 عَلَ مَشَندِ
\d 
\v 1 دَوُدَ شَ بّيتِ بّيتِبَيٍ شَ مَنفّ بّ
\q1 
\v 2 عَلَتَلَ، ﭑ نَتَنفَ مِشِ حَاشِيٍ يِ رَ،
\q1 نَشٍيٍ وَ مَ ﭑ تْورْقٍ،
\q1 
\v 3 نَشٍيٍ نَتّ تٌنفٌمَ عٍ بْحّ مَ فٍرٍ مَسٌقٍ رَ لْشْ يٌ لْشْ.
\q1 
\v 4 عٍ شَ وْيّنيِ شْنْ عَلْ بْشِمَسٍ شَ شْنّ. \qs حّنفِ رَتٍ.\qs*
\b
\q1 
\v 5 عَلَتَلَ، عِ شَ ﭑ نَتَنفَ مِشِ حَاشِيٍ بّلّشّ عِ.
\q1 عِ شَ ﭑ نَتَنفَ مِشِ كٌبِيٍ مَ نَشٍيٍ وَ مَ ﭑ نَبِرَقٍ.
\q1 
\v 6 عِ شَ ﭑ نَتَنفَ يّتّ عِفبٌي شَ فَنتَنيِ نُن لُوتِيٍ مَ،
\q1 نَشٍيٍ يّلّيٍ عِتَلَمَ ﭑ مَ كِرَيٍ رَ ﭑ سُشُقٍ رَ.
\q1 
\v 7 عَلَتَلَ، ﭑ مَرِفِ عَلَ نَن عِ رَ.
\q1 عِ شَ عِ تُلِ مَتِ ﭑ وَ شُي رَ.
\q1 
\v 8 عَلَتَلَ، ﭑ نَكِسِمَ سّنبّمَ،
\q1 نَشَن ﭑ نَتَنفَمَ ﭑ فٍرٍ لْشْي،
\q1 
\v 9 عِ نَشَ تِن مِشِ كٌبِيٍ وَشْنقٍ رَ،
\q1 عِ نَشَ نَ سْونّيَ عٍ بّ عَلَكٌ عٍ شُن نَشَ قَ رَكٍلِ. \qs حّنفِ رَتٍ.\qs*
\b
\q1 
\v 10 ﭑ فٍرٍقَيٍ شَ قٍ حَاشِ مَشِرِشِيٍ شَ فبِلٍن عٍ مَ.
\q1 
\v 11 تّ وٌلٍ شَ دْشْ عٍ شُن نَ،
\q1 عٍ شَ رَدِن تّ شْورَ، عٍ نَشَ قَ مِنِ نَ كُي سْنْن.
\q1 
\v 12 قٍ حَاشِ رَبَيٍ نَشَ سَبَتِ يِ بْشِ مَ،
\q1 تْورّ نَن تُن شَ رَفِرِ عٍ مَ.
\b
\q1 
\v 13 ﭑ عَ كٌلٌن عَلَتَلَ كِيتِ قَنيِ سَمَ نّ مِسِكِينّيٍ بّ،
\q1 عَ نْندِ قِمَ سٍتَرٍيٍ مَ.
\q1 
\v 14 تِنشِنتْييٍ عِ شِلِ مَتْشْمَ نّ،
\q1 نْندِلَيٍ كِسِمَ نّ عِ يَ عِ.
\c 141
\s1 مِشِ حَاشِيٍ شَ فَنتَنيِ
\s2 عَلَ مَشَندِ
\d 
\v 1 دَوُدَ شَ بّيتِ
\q1 عَلَتَلَ، ﭑ بَرَ عِ مَشَندِ، عِ شُلُن ﭑ مَلِقٍ رَ،
\q1 عِ شَ عِ تُلِ مَتِ ﭑ مَ مَشَندِ رَ.
\q1 
\v 2 ﭑ مَ دُبَ شَ تٍ عِ مَبِرِ عَلْ سُرَيِ شِرِ،
\q1 ﭑ مَ بّلّشّ تِ شَ لُ عَلْ نُنمَرٍ سّرّشّ.
\b
\q1 
\v 3 عَلَتَلَ، ﭑ دّ مَكَنتَ
\q1 عَلَكٌ قٍ حَاشِ يٌ نَشَ مِنِ ﭑ دّ كُي.
\q1 
\v 4 عِ نَشَ تِن ﭑ بْحّ شَ سِفَ قٍ حَاشِ مَ،
\q1 ﭑ نَشَ لَن وَلِ كٌبِ رَبَيٍ مَ ﭑ مَ فٍينِ شَ قٍ رَ.
\b
\q1 
\v 5 شَ تِنشِنتْي ﭑ بْنبْ، عَ قَن ﭑ بّ،
\q1 عَ شَ شُرُي قَن عَلْ لَبُندّ نَشَن سَمَ ﭑ قَتٍ مَ.
\q1 ﭑ مُ تٌندِ مَ نَ قٍ رَ.
\q1 كْنْ ﭑ عَلَ مَشَندِ مَ عَ شَ مِشِ حَاشِ وَشْنقٍ كَنَ.
\q1 
\v 6 عٍ شَ كِيتِسَيٍ شَ رَدِن فٍلٍنيِ رَ.
\q1 مِشِ حَاشِيٍ شَ عَ كٌلٌن ﭑ مَ مَسٍنيِ قَن.
\q1 
\v 7 عٍ شَ عَ قَلَ، «مُشُ شْرِيٍ بَرَ يٍنسٍن عَلِفِيَمَ،
\q1 عَلْ شّ سَ بْشِ بُشَمَ كِ نَشّ.»
\b
\q1 
\v 8 كْنْ ﭑ مَرِفِ عَلَتَلَ، ﭑ يَ تِشِ عِ تَن نَ.
\q1 ﭑ كَنتَرِ تٌمَ عِ سّيتِ مَ، عِ نَشَ ﭑ نِي رَبٌلٌ.
\q1 
\v 9 ﭑ نَتَنفَ فَنتَنيِيٍ مَ عٍ نَشٍيٍ تٍمَ ﭑ بّ،
\q1 ﭑ نَتَنفَ مِشِ حَاشِيٍ شَ يّلّيٍ مَ.
\q1 
\v 10 عٍ تَن شَ سُشُ نٍيٍ رَ، ﭑ تَن شَ كِسِ.
\c 142
\s1 دَنشَنِيَتْي شَ كَنتَرِ
\s2 عَلَ مَشَندِ
\d 
\v 1 دَوُدَ شَ لْننِ بّيتِ عَ تٌ نُ نَ قْنمّ رَ
\q1 
\v 2 ﭑ نَ ﭑ شُي رَتٍمَ عَلَتَلَ نَن مَ كِنِكِنِ شَ قٍ رَ.
\q1 
\v 3 ﭑ نَ ﭑ مَ كْنتْقِلِ دّنتّفّمَ عَ تَن نَن بّ،
\q1 ﭑ نَ ﭑ مَ نِمِسّ يَ بَ عَ بّ.
\q1 
\v 4 لِمَنِيَ نَ بَ ﭑ يِ رَ، عِ تَن ﭑ سِفَدٍ كٌلٌن.
\q1 عٍ بَرَ فَنتَنيِ تٍ ﭑ بّ ﭑ مَ كِرَ رَ.
\q1 
\v 5 ﭑ نَبِلِنيِ مَتٌ؛ مِشِ يٌ مُ نَ ﭑ بّ،
\q1 كَنتَرِ مُ نَ ﭑ بّ، مّينِمَ يٌ مُ نَ ﭑ بّ.
\b
\q1 
\v 6 عَلَتَلَ، عِ تَن نَن كٍرٍن ثٍتِ نَ ﭑ بّ سْنْن.
\q1 عِ كٍرٍن نَن قِندِشِ ﭑ كَنتَمَ رَ يِ دُنِحَ بّندّ قُحِ قَرِ.
\q1 
\v 7 عِ شَ ﭑ وَ شُي مّ، بَرِ مَ ﭑ سّنبّ بِرِن بَرَ حْن.
\q1 ﭑ بَ ﭑ كٍرِ مَيٍ يِ رَ، بَرِ مَ عٍ سّنبّ فبٌ ﭑ بّ.
\q1 
\v 8 ﭑ نَمِنِ فٍيلِ كُي، عَلَكٌ ﭑ شَ عِ شِلِ مَتْشْ.
\q1 نَ كُي تِنشِنتْييٍ قَمَ نّ عٍ مَلَندٍ ﭑ يِرٍ عِ شَ هِننّ شَ قٍ رَ.
\c 143
\s1 عَلَ شَ مَشَندِ هَفِفّ
\s2 عَلَ مَشَندِ
\d دَوُدَ شَ بّيتِ
\q1 
\v 1 عَلَتَلَ، عِ تُلِ مَتِ ﭑ مَ مَشَندِ رَ،
\q1 عِ شَ كِنِكِنِ ﭑ وَ شُي مَ.
\q1 عِ شَ ﭑ مَ دُبَ سُشُ عِ شَ دُفُتّفّحَ نُن عِ شَ تِنشِنيِ شَ قٍ رَ.
\q1 
\v 2 عِ نَشَ عِ شَ كٌنيِ مَكِيتِ، بَرِ مَ دَالِ يٌ مُ تِنشِن عِ يَ عِ.
\b
\q1 
\v 3 ﭑ يَشُي بِرَ مَ نّ ﭑ قْشْ رَ،
\q1 عَ ﭑ بٌرٌنمَ نّ بْشِ مَ،
\q1 عَ ﭑ لُمَ نّ قَشّ نِينِ بُن مَ عَلْ قَشَمِشِيٍ.
\q1 
\v 4 نَ كُي ﭑ شَشِلِ بَرَ عِقُ. لِمَنِيَ بَرَ بَ ﭑ يِ.
\b
\q1 
\v 5 ﭑ نَتُمَ نّ لْشْي دَنفِشِيٍ مَ،
\q1 ﭑ نَ ﭑ شَشِلِ رَ سِفَمَ عِ شَ وَلِ بِرِن مَ،
\q1 ﭑ نَ ﭑ حْشْ رَ سِفَ عِ شَ دَالِيٍ مَ.
\q1 
\v 6 ﭑ نَ ﭑ بّلّشّ عِتَلَمَ نّ عِ بّ،
\q1 ﭑ نِي عِ قٍنمَ نّ عَلْ فبٍنفبٍرٍنيِ يٍ قٍنمَ كِ نَشّ. \qs حّنفِ رَتٍ.\qs*
\b
\q1 
\v 7 عَلَتَلَ، يَندِ، عِ شُلُن ﭑ يَابِقٍ رَ.
\q1 لِمَنِيَ بَرَ فّ بَدٍ ﭑ يِ رَ.
\q1 عِ نَشَ عِ كٌبٍ رَ سٌ ﭑ نَ،
\q1 شَ نَ مُ ﭑ لُمَ نّ عَلْ قَشَمِشِيٍ.
\q1 
\v 8 كُيٍ نَ عِبَ، عِ شَ عِ شَ دُفُتّفّحَ مَسٍن ﭑ بّ،
\q1 بَرِ مَ ﭑ شَشِلِ تِشِ عِ تَن نَن نَ.
\q1 ﭑ حّرّ كِرَ مَسٍن ﭑ بّ،
\q1 بَرِ مَ ﭑ شَشِلِ تِشِ عِ تَن نَن نَ.
\q1 
\v 9 عَلَتَلَ، ﭑ نَتَنفَ ﭑ يَشُييٍ مَ،
\q1 بَرِ مَ ﭑ كَنتَرِ سْتْمَ عِ نِينِ نَن بُن مَ.
\q1 
\v 10 ﭑ شَرَن عِ وَشْنقٍ رَبَقٍ رَ،
\q1 بَرِ مَ عِ تَن نَن نَ ﭑ مَرِفِ عَلَ رَ.
\q1 عِ شَشِلِ سّنِيّنشِ شَ ﭑ تِ كِرَ قَنيِ شْن مَ.
\q1 
\v 11 عَلَتَلَ، عِ شَ ﭑ نَكِسِ عِ شِلِ شَ قٍ رَ،
\q1 عِ شَ ﭑ بَ تْورّ كُي عِ شَ تِنشِنيِ شَ قٍ رَ،
\q1 
\v 12 عِ شَ ﭑ يَشُييٍ دّ بَلَن عِ شَ دُفُتّفّحَ شَ قٍ رَ،
\q1 عِ شَ ﭑ فٍرٍقَيٍ شُن نَكَنَ،
\q1 بَرِ مَ عِ شَ كٌنيِ نَن لَنشِ ﭑ مَ.
\c 144
\s1 مُنسٍ نَ عَدَ مَدِ رَ عَلَ بّ؟
\s2 عَلَ مَشَندِ
\d 
\v 1 دَوُدَ شَ بّيتِ
\q1 تَنتُي نَ عَلَتَلَ بّ، نَشَن قِندِشِ ﭑ مَ قَنيٍ رَ،
\q1 نَشَن ﭑ بّلّشّ رَوَلِمَ عَ شَ فٍرٍ كُي،
\q1 
\v 2 نَشَن قِندِشِ ﭑ شَنُنتٍنيِ سّنبّمَ رَ،
\q1 نَشَن قِندِشِ ﭑ كَنتَمَ نُن ﭑ نَكِسِمَ رَ،
\q1 نَشَن نْمَ ﭑ يَشُييٍ رَ عَلَكٌ ﭑ شَ كَنتَرِ سْتْ.
\b
\q1 
\v 3 عَلَتَلَ، مُنسٍ نَ عَدَ مَ رَ عِ تٌ قَ مّينِشِ عَ مَ؟
\q1 مُنسٍ نَ عَدَ مَ شَ دِ رَ عِ تٌ قَ عِ حْشْ سَشِ عَ شْن مَ؟
\q1 
\v 4 عَدَ مَدِ لُشِ نّ عَلْ حّنفِ قٌيٍ،
\q1 عَ شَ سِمَيَ دَنفِمَ نّ عَلْ نِينِ دَنفِمَ كِ نَشّ.
\b
\q1 
\v 5 عَلَتَلَ، عِ شَ كٌورٍ رَبِ عِ فٌرٌقٍ رَ،
\q1 عِ قَ دِن فٍيَيٍ رَ عَلَكٌ تُورِ شَ تٍ.
\q1 
\v 6 عِ شَ سٍيَمَكْنيِ رَبُلَ يَشُييٍ رَيٍنسٍنقٍ رَ.
\q1 شَلِيٍ وٌلِ عَلَكٌ عٍ شَ سِفَ.
\q1 
\v 7 عِ شَ عِ بّلّشّ عِتَلَ كٍلِقٍ كٌورٍ مَ،
\q1 عَلَكٌ عِ شَ ﭑ نَكِسِ، عِ شَ ﭑ نَتَنفَ ﭑ يَشُييٍ مَ
\q1 عَلْ مِشِ رَتَنفَمَ مْرْنيِيٍ مَ كِ نَشّ.
\q1 
\v 8 ﭑ نَكِسِ وُلٍ قَلّيٍ مَ نَشٍيٍ وَ مَ ﭑ مَدَشُقٍ.
\b
\q1 
\v 9 عَلَ، ﭑ بّيتِ نّينّ بَمَ نّ عِ بّ ﭑ مَ كْرَ لُوتِ قُ دَاشِ شُي رَ.
\q1 
\v 10 ﭑ عِ مَتْشْمَ نّ، عِ تَن نَشَن مَنفّيٍ شُن نَكٍلِمَ،
\q1 نَشَن عِ شَ كٌنيِ دَوُدَ رَتَنفَمَ سَنتِدّفّمَ حَاشِ مَ.
\b
\q1 
\v 11 ﭑ نَكِسِ، ﭑ نَتَنفَ ﭑ يَشُييٍ مَ،
\q1 نَشَن وُلٍ قَلَمَ مِشِ مَدَشُقٍ رَ.
\q1 
\v 12 نَ تّمُي مُشُ شَ دِ شّمّيٍ قَنمَ نّ عَلْ وُرِ بِلِيٍ،
\q1 مُشُ شَ دِ فِنّيٍ تٌقَنمَ نّ عَلْ كْنتِفِبَ،
\q1 نَشٍيٍ مَسٌلِشِ مَنفّ بَنشِ كُي.
\q1 
\v 13 مُشُ شَ بَنشِيٍ رَقٍمَ نّ دَشَمُي مْولِ بِرِن نَ،
\q1 مُشُ شَ فْورّيٍ وُيَمَ نّ عَ وُلُ وُلُ مَ،
\q1 
\v 14 مُشُ شَ نِنفٍيٍ شُنفبٌمَ نّ،
\q1 لَنيُرُ يٌ مُ لُمَ عٍ مَ،
\q1 عٍ قُرِ مُ بِرَ مَ،
\q1 سْنشْي مُ مّمَ مُشُ مَلَندٍيٍ.
\b
\q1 
\v 15 سّيوّ نَ حَمَ بّ عَلَ قَمَ يِ قٍ مْولِ رَبَدٍ نَشَن نَ.
\q1 سّيوّ نَ حَمَ بّ عَلَتَلَ قِندِشِ نَشَن مَرِفِ عَلَ رَ.
\c 145
\s1 عَلَ شَ كَابَنَكٌي نُن شَنُنتٍيَ
\s2 عَلَ مَتْشْي
\d دَوُدَ شَ عَلَ مَتْشْي
\q1 
\v 1 ﭑ مَ مَنفّ عَلَ، ﭑ عِ مَتْشْمَ نّ،
\q1 ﭑ عِ شِلِ تَنتُمَ نّ عَبَدَن.
\q1 
\v 2 لْشْ يٌ لْشْ ﭑ عِ مَتْشْمَ نّ،
\q1 ﭑ عِ شِلِ تَنتُمَ نّ عَبَدَن.
\b
\q1 
\v 3 عَلَتَلَ سّنبّ فبٌ، مَتْشْي بِرِن نَ عَ تَن نَن بّ،
\q1 عَدَ مَدِ مُ نْمَ سٌدٍ نَ بِرِن كُي.
\q1 
\v 4 يِ وَشَتِ مِشِيٍ قَمَ نّ عِ شَ كَابَنَكٌي قَلَدٍ بٌورٍ وَشَتِ مِشِيٍ بّ.
\q1 
\v 5 عٍ قَمَ نّ عِ شَ نْرّ تٌقَنيِ مَسٍندٍ.
\q1 ﭑ لُمَ نّ عِ شَ كَابَنَكٌي مَحْشُن نَ.
\q1 
\v 6 عٍ قَمَ نّ عِ سّنبّ مَفَاشُشِ شَ قٍ قَلَدٍ.
\q1 ﭑ لُمَ نّ عِ شَ كَابَنَكٌي مَسٍن نَ.
\q1 
\v 7 عٍ قَمَ نّ حّلّشِندٍ عِ شَ هِننّ شُنفبٍ رَ،
\q1 عٍ عِ شَ تِنشِنيِ مَسٍنمَ نّ بّيتِ سّيوَشِ رَ.
\b
\q1 
\v 8 عَلَتَلَ هِننّ مِشِ رَ، عَ كِنِكِنِ،
\q1 عَ دِحّشِ، عَ شَ شَنُنتٍيَ فبٌ.
\q1 
\v 9 عَلَتَلَ قٍ قَنيِ رَبَمَ مِشِ بِرِن بّ،
\q1 عَ كِنِكِنِ عَ شَ دَالِ بِرِن مَ.
\q1 
\v 10 عَلَتَلَ، عِ شَ دَالِيٍ بِرِن عِ مَتْشْمَ نّ،
\q1 عِ شَ سّنِيّنتْييٍ عِ تَنتُمَ نّ.
\q1 
\v 11 عٍ عِ شَ مَنفّيَ شُنفبٍ شَ قٍ مَسٍنمَ نّ،
\q1 عٍ عِ سّنبّ شَ قٍ قَلَمَ نّ،
\q1 
\v 12 عَلَكٌ مِشِيٍ شَ عِ شَ كَابَنَكٌي كٌلٌن،
\q1 عَ نُن عِ شَ مَنفّيَ نْرْشِ.
\q1 
\v 13 عِ شَ مَنفّيَ مُ حْنمَ نّ،
\q1 عِ شَ نْي بُمَ نّ عَبَدَن.
\b
\q1 
\v 14 عَلَتَلَ بِرَ مِشِ مَلِمَ،
\q1 عَ مِشِ مَفٌرٌشِ شُن نَكٍلِمَ نّ.
\q1 
\v 15 دُنِحَ بِرِن عَ شَشِلِ تِشِ عِ رَ،
\q1 عِ تَن نَن عٍ بَلٌمَ عَ وَشَتِ.
\q1 
\v 16 عِ تَن نَن عِ بّلّشّ رَبِمَ،
\q1 عِ بِرِن نَوَ سَ عٍ هَيِ نَ نَشَن مَ.
\q1 
\v 17 عَلَتَلَ تِنشِن عَ شَ قٍ بِرِن كُي،
\q1 عَ دُفُتّفّشِ عَ شَ دَالِيٍ مَ.
\q1 
\v 18 عَلَتَلَ مَكْرّ عَ مَشَندِلَيٍ رَ،
\q1 نَشٍيٍ عَ مَشَندِ مَ عٍ بْحّ قِيشّ رَ.
\q1 
\v 19 عَ عَ يَرَفَاشُييٍ وَشْنقٍ رَبَمَ نّ،
\q1 عَ عٍ شَ دُبَ سُشُمَ نّ، عَ عٍ رَكِسِ.
\q1 
\v 20 عَلَتَلَ عَ شَنُنتٍنيِيٍ مَكَنتَمَ نّ،
\q1 كْنْ عَ مِشِ حَاشِيٍ بِرِن سْنتْمَ نّ.
\q1 
\v 21 ﭑ دّ عَلَتَلَ مَتْشْمَ نّ.
\q1 دَالِ شَ عَ شِلِ سّنِيّنشِ مَتْشْ تّمُي بِرِن.
\c 146
\s1 عَلَ شَ مَلِ فبٌ عَدَ مَ شَ مَلِ بّ
\s2 عَلَ مَتْشْي
\q1 
\v 1 وٌ عَلَتَلَ مَتْشْ!
\b
\q1 ﭑ نِي شَ عَلَتَلَ مَتْشْ،
\q1 
\v 2 ﭑ شَ عَ مَتْشْ ﭑ مَ سِمَيَ بِرِن نَ.
\q1 ﭑ ﭑ مَرِفِ عَلَتَلَ مَتْشْمَ نّ بّيتِ رَ، قَننِ ﭑ نَ ﭑ نِي رَ.
\b
\q1 
\v 3 وٌ نَشَ وٌ يّتّ تَشُ مِشِ شُنفبٍيٍ رَ،
\q1 بَرِ مَ عَدَ مَدِيٍ نَ عٍ رَ، نَشٍيٍ مُ نْمَ مِشِ رَكِسِدٍ.
\q1 
\v 4 عٍ نِي بَمَ نّ عٍ قَتٍ عِ، عٍ فبِلٍن بّندّ.
\q1 نَ لْشْي يَتِ، عٍ نَشَن حَنِفٍشِ، نَ بِرِن حْنمَ نّ.
\b
\q1 
\v 5 سّيوّ نَ مِشِ بّ، يَشُبَ مَرِفِ عَلَ نَشَن مَلِمَ.
\q1 سّيوّ نَ مِشِ بّ، نَشَن عَ شَشِلِ تِمَ عَ مَرِفِ عَلَتَلَ رَ،
\q1 
\v 6 عَلَ نَشَن كٌورٍ نُن بْشِ دَا،
\q1 عَلَ نَشَن بَا نُن عَ كُي سٍيٍ بِرِن دَا،
\q1 دُفُتّفّحَ نَ عَلَ نَشَن بّ عَبَدَن.
\q1 
\v 7 عَلَتَلَ تْوحّفّتْييٍ شُن مَقَلَمَ،
\q1 عَ دٌنسٍ قِمَ كَامّتْييٍ مَ،
\q1 عَ فٍيلِمَنِيٍ رَ مِنِمَ فٍيلِ كُي،
\q1 
\v 8 عَ دْنشُييٍ يَ رَبْو مَ،
\q1 عَ مِشِ مَفٌرٌشِيٍ شُن نَكٍلِمَ،
\q1 عَ تِنشِنتْييٍ شَنُمَ،
\q1 
\v 9 عَ مّينِمَ شْحّيٍ مَ،
\q1 عَ كِرِدِيٍ نُن كَاحّ فِنّيٍ بُن تِمَ،
\q1 كْنْ عَ مِشِ حَاشِيٍ تَن شُن نَكَنَمَ نّ.
\b
\q1 
\v 10 سِيٌنِ، وٌ مَرِفِ عَلَتَلَ شَ مَنفّيَ مُ حْنمَ عَبَدَن.
\q1 وٌ شَ عَلَتَلَ مَتْشْ!
\c 147
\s1 عَلَ سّنبّ مَنِيّ مُ نَ
\s2 عَلَ مَتْشْي
\q1 
\v 1 وٌ عَلَتَلَ مَتْشْ.
\q1 عَ لَنمَ عَلَتَلَ شَ مَتْشْ بّيتِ رَ.
\q1 قٍ قَنيِ نَ عَ رَ.
\b
\q1 
\v 2 عَلَتَلَ نَ فبِلٍنقٍ دَرِ سَلَمُ تِ رَ،
\q1 عَ عِسِرَيِلَ شَ مِشِ رَقَمَ نّ كٍلِقٍ كٌنيِيَ كُي،
\q1 
\v 3 عَ تْورْ مِشِيٍ رَلِمَنِيَمَ،
\q1 عَ عٍ رَيَلَنمَ عٍ شَ قُرٍ كُي.
\b
\q1 
\v 4 عَلَتَلَ تُنبُييٍ كْنتِ كٌلٌن،
\q1 عَ عٍ بِرِن شِلِمَ عٍ شِلِ رَ.
\q1 
\v 5 وٌن مَرِفِ عَلَتَلَ سّنبّ فبٌ،
\q1 دَن مُ نَ عَ شَ قَهَامُي مَ.
\q1 
\v 6 عَلَتَلَ مِشِ مَفٌرٌشِ بُن تِمَ،
\q1 كْنْ عَ يّتّ عِفبٌي شَ قٍ كَنَمَ.
\b
\q1 
\v 7 وٌ شَ بّيتِ بَ عَلَتَلَ بّ تَنتُي رَ،
\q1 وٌ شَ بّيتِ بَ عَلَ بّ كْرَيٍ شُي رَ.
\q1 
\v 8 عَ تَن نَن نُشُي رَ مِنِمَ كٌورٍ مَ،
\q1 عَ تُنّ رَقَ بْشِ مَ،
\q1 عَ سَنسِيٍ رَ سٌلِ فٍيَيٍ قَرِ.
\q1 
\v 9 عَ شُرُ سٍيٍ رَبَلٌمَ،
\q1 عَ دٌنسٍ قِمَ شَشَ يْرّيٍ مَ، عٍ نَ عٍ شُي رَ مِنِ تّمُي نَشّ.
\b
\q1 
\v 10 سٌي سّنبّ مُ قِندِشِ قٍقٍ رَ عَلَ بّ.
\q1 شّمّ شَ سّنبّ مُ قِندِشِ قٍقٍ رَ عَلَ بّ.
\q1 
\v 11 عَلَ يَرَفَاشُييَ نَن نَقَنمَ عَ مَ.
\q1 عَلَ وَ مَ مِشِ شْن نَشَن شَشِلِ تِشِ عَ شَ شَنُنتٍيَ رَ.
\b
\q1 
\v 12 دَرِ سَلَمُ، عِ شَ عَلَتَلَ مَتْشْ.
\q1 سِيٌنِ، عِ شَ عَلَ تَنتُ،
\q1 
\v 13 بَرِ مَ عَ تَن نَن عِ شَ نَادّ مَكَنتَمَ،
\q1 عَ تَن نَن بَرَكّ سَمَ عِ شَ حَمَ مَ.
\q1 
\v 14 عَ بْحّسَ قِمَ عِ شَ بْشِ مَ،
\q1 عَ دٌنسٍ قَنيِ قِمَ عِ مَ.
\b
\q1 
\v 15 عَلَتَلَ دُنِحَ يَمَرِ مَ،
\q1 عَ عَ وَشْنقٍ رَيٍنسٍنمَ مَقُرٍن مَقُرٍن.
\q1 
\v 16 عَ بَلَبَلَنيِ رَفٌرٌ مَ نّ عَلْ فّسّ قُتٍ،
\q1 عَ نَ رَيٍنسٍن عَلْ تّ شُبٍ.
\q1 
\v 17 عَ رَفٌرٌ بْشِ مَ، ندٍ نْمَ تِدٍ نَ شِنبٍلِ يَ رَ؟
\q1 
\v 18 عَ نَ عَ شُي رَ مِنِ عٍ مَ، عٍ شُنُمَ نّ،
\q1 عَ نَ قٌيٍ رَقَ، بَلَبَلَنيِ مَن قِندِ مَ نّ يٍ رَ.
\b
\q1 
\v 19 عَلَتَلَ بَرَ عَننَبِ يَشُبَ رَكٌلٌن عَ شَ مَسٍنيِ رَ،
\q1 عَ بَرَ عَ شَ سّرِيّ نُن عَ شَ يَامَرِيٍ مَسٍن عِسِرَيِلَ بّ.
\q1 
\v 20 عَ مُ نَ مْولِ رَفِرِشِ سِ فبّتّ يٌ بّ.
\q1 نٍيٍ لُمَ عَلَ شَ سّرِيّيٍ كٌلٌنتَرٍيَ نَن كُي.
\b
\q1 وٌ شَ عَلَتَلَ مَتْشْ!
\c 148
\s1 دُنِحَ شَ عَلَ مَتْشْ
\s2 عَلَ مَتْشْي
\q1 
\v 1 وٌ عَلَتَلَ مَتْشْ!
\b
\q1 وٌ عَلَتَلَ مَتْشْ كٍلِقٍ كٌورٍ مَ.
\q1 وٌ عَ مَتْشْ يِرٍ عِتٍشِ كُي.
\q1 
\v 2 عَلَتَلَ شَ مَلٍكّيٍ شَ عَ مَتْشْ،
\q1 عَ شَ فَلِيٍ شَ عَ مَتْشْ كٌورٍ مَ.
\q1 
\v 3 سٌفٍ نُن كِكٍ شَ عَ مَتْشْ،
\q1 تُنبُي دّشّشِيٍ قَن شَ عَ مَتْشْ.
\q1 
\v 4 كٌورٍ شَ عَ مَتْشْ، عَ نُن يٍ نَشَن تٌمَ نَا.
\q1 
\v 5 عٍ بِرِن شَ عَلَتَلَ شِلِ مَتْشْ،
\q1 بَرِ مَ عَ يَمَرِ نَن قِ، عٍ نَشَ دَا.
\q1 
\v 6 عَ نَشَ عٍ تِ عٍ تِدٍ، عٍ شَ لُ نَا عَبَدَن.
\q1 عَ نَشَ نَ سّرِيّ سَ، نَشَن مُ كَنَمَ.
\b
\q1 
\v 7 وٌ عَلَتَلَ مَتْشْ كٍلِقٍ بْشِ مَ.
\q1 بَا نُن نِمَسٍ بِرِن نَشٍيٍ نَ بَا تِلِنيِ كُي،
\q1 
\v 8 سٍيَمَكْنيِ، بَلَبَلَنيِ، كُندَ، نُشُييٍ،
\q1 نُن قٌيٍ شُنفبٍ نَشَن عَ شَ يَامَرِ رَتِنمّمَ،
\q1 
\v 9 فٍيَيٍ نُن تٍنتٍنيِيٍ، وُرِ بٌفِلَيٍ نُن سّدِرِ بِلِيٍ،
\q1 
\v 10 وُلَءِ سُبٍيٍ نُن شُرُ سٍيٍ، بُبُسٍيٍ نُن شْنِيٍ،
\q1 
\v 11 دُنِحَ مَنفّيٍ نُن سِيٍ،
\q1 مَنفّدِيٍ نُن دُنِحَ كُنتِفِيٍ،
\q1 
\v 12 قٌنِكٍيٍ نُن فِنّدِ مّدِيٍ، دِ مّيٍ نُن قٌرِيٍ،
\q1 
\v 13 عٍ بِرِن شَ عَلَتَلَ شِلِ مَتْشْ،
\q1 بَرِ مَ عَ شِلِ فبَنسَن نَن عِتٍشِ،
\q1 عَ نْرّ دَنفِ كٌورٍ نُن بْشِ رَ.
\b
\q1 
\v 14 عَ بَرَ مَنفّ سّنبّمَ رَكٍلِ عَ شَ حَمَ شُن نَ،
\q1 عَ شَ سّنِيّنتْييٍ نَشَن مَتْشْمَ،
\q1 سّنِيّنتْييٍ نَشَن قِندِشِ عِسِرَيِلَ عَ شَ حَمَ شَنُشِ رَ.
\b
\q1 وٌ عَلَتَلَ مَتْشْ!
\c 149
\s1 بّيتِ نّينّ
\s2 عَلَ مَتْشْي
\q1 
\v 1 وٌ عَلَتَلَ مَتْشْ!
\b
\q1 وٌ بّيتِ نّينّ بَ عَ بّ،
\q1 وٌ مَتْشْي رَبَ عَ بَتُلَيٍ تَفِ.
\q1 
\v 2 عِسِرَيِلَ شَ سّيوَ عَ دَالِ مَرِفِ رَ.
\q1 سِيٌنِ حَمَ شَ سّيوَ عٍ شَ مَنفّ رَ.
\q1 
\v 3 عٍ شَ عَ شِلِ مَتْشْ قَرٍ بٌرٌن يِ رَ،
\q1 عٍ شَ بّيتِيٍ بَ مَشَسٍ نُن كْرَ شُي رَ،
\q1 
\v 4 بَرِ مَ عَلَتَلَ سّيوَشِ عَ شَ حَمَ رَ،
\q1 عَ كِسِ قِمَ نّ يّتّ مَفٌرٌي مَ.
\q1 
\v 5 عَ شَ سّنِيّنتْييٍ شَ سّيوَ يِ بِنيّ رَ،
\q1 عٍ شَ عٍ سّيوّ شُي عِتٍ هَلِ عٍ شَ سَدٍيٍ مَ.
\q1 
\v 6 عَلَ مَتْشْي شَ لُ عٍ دّ عِ.
\q1 نَ لُشِ عَلْ سَنتِدّفّمَ شَاحّشِ عٍ بّلّشّ كُي،
\q1 
\v 7 عٍ نَشَن نَوَلِمَ عٍ فبٍ حْشْقٍ رَ،
\q1 سِ حَاشِيٍ حَشَنكَتَقٍ رَ.
\q1 
\v 8 عٍ عٍ يَشُييٍ شَ مَنفّيٍ سَمَ نّ يْلْنشْنيِيٍ رَ،
\q1 عٍ عٍ شَ يَرٍرَتِيٍ شِرِ مَ نّ عَ شْرْشْي رَ،
\q1 
\v 9 نَ قَ قِندِ عٍ شَ كٌبِحَ سَرٍ رَ.
\q1 شُننَكٍلِ بٍلٍبٍلٍ نَن نَ كِ عَلَ شَ سّنِيّنتْييٍ بّ.
\b
\q1 وٌ شَ عَلَتَلَ مَتْشْ!
\c 150
\s1 بِرِن عَلَ مَتْشْقٍ
\s2 عَلَ مَتْشْي
\q1 
\v 1 وٌ عَلَتَلَ مَتْشْ!
\b
\q1 وٌ شَ عَلَ مَتْشْ عَ شَ هْرْ مْبَنشِ كُي.
\q1 وٌ شَ عَ مَتْشْ كٌورٍ مَ.
\q1 
\v 2 وٌ شَ عَ مَتْشْ عَ شَ كَابَنَكٌي شَ قٍ رَ.
\q1 وٌ شَ عَ مَتْشْ عَ سّنبّ شُنفبٍ شَ قٍ رَ.
\b
\q1 
\v 3 وٌ شَ عَ مَتْشْ قٍرِ شُي نُن كْرَ شُي رَ،
\q1 
\v 4 وٌ شَ عَ مَتْشْ مَشَسٍ نُن قَرٍ بٌرٌن يِ رَ،
\q1 وٌ شَ عَ مَتْشْ كْرَ مَنِيّ نُن شُلٍ شُي رَ،
\q1 
\v 5 وٌ شَ عَ مَتْشْ مَشَسٍ شُي عِتٍشِ رَ.
\b
\q1 
\v 6 نِمَسٍ بِرِن شَ عَلَتَلَ مَتْشْ.
\b
\q1 وٌ عَلَتَلَ مَتْشْ!
