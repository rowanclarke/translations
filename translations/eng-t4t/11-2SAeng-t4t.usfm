\p \w The|strong="H5921"\w* \w first|strong="H7218"\w* \w was|strong="H8034"\w* Esh-Baal, \add whose other name was Jashobeam\add*, \w from|strong="H5921"\w* \w the|strong="H5921"\w* Hachmon clan (\w OR|strong="H3068"\w*, \w the|strong="H5921"\w* son \w of|strong="H7218"\w* Hachmon). \w He|strong="H1931"\w* \w was|strong="H8034"\w* \w the|strong="H5921"\w* \w leader|strong="H7218"\w* \w of|strong="H7218"\w* \w the|strong="H5921"\w* three \w men|strong="H1368"\w*. \w One|strong="H1931"\w* \w time|strong="H6471"\w* \w he|strong="H1931"\w* fought \w against|strong="H5921"\w* 800 enemies \w and|strong="H3967"\w* \w killed|strong="H2491"\w* \w them|strong="H5921"\w* \w all|strong="H5921"\w* \w with|strong="H5921"\w* \w his|strong="H1732"\w* spear.
