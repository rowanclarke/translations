\id TIT - Ikwerre 
\h Taịtosi 
\toc1 Ọkwukwo izi Pọlu gbaznennu Taịtosi 
\toc2 Taịtosi 
\toc3 Taịt 
\mt2 Ọkwukwo izi 
\mt2 Pọlu gbaznennu 
\mt1 Taịtosi 
\imt1 Nhne gbasịri ọkwukwo izi ka 
\im Pọlu kwuru nhne gbasịri Taịtosi nụ hne zị ichne ichne nụ rime ọkwukwo izi ọ gbarụ. Ọ karụ nụ ya nụ Taịtosi sno rnụ ẹrnu izi ọma nụ Esia Matị nụ Girisi (2 Kọrinti 2; Galasia 2:3). Pọlu kannụ a, ọ họhia ele risi nụ ele jeelekọta ọgbako Chiokike anya nụ Kiriti. 
\ip Pọlu kannụ Taịtosi ọ whnụ ele risi nụ ele neelekọta ọgbako Chiokike bụ ele, ele badnụ nookwu ọka ọma (1:5-9). Kpakara ele sno Nyenwe aị jọobu ele bịtaru ẹhni be snam, ele zá neesigha ọka (1:10-2:9). 
\ip Pọlu kwuru ọka gbasịri ele zị ichne ichne nụ rime ọgbako Chiokike ke zị nụ Kiriti. Ọ karụ nụ a nwernu rikne o wu bụdnu ikne kwnornu nụ Chiokike ziyaru Jizọsi Karaịsi, Chiokike znọhiaru aị, snụma aị hite nụ rikne Enine Nsọ, mee aị a panịzo bụdnu ikne ke nwernu olile anya bụdnu kwó okwo. Chiokike znọhiaru aị kwnornu nụ ọ bụ nye obirizi, ọ bụ́o kwnornu nhne ọma ọbula a mernu. 
\iot Nhne zị n'ọkwukwo izi ka 
\io1 Obekwu ikwu nụ okpukpe Pọlu kpenu Taịtosi \ior (1:1-4)\ior* 
\io1 Ezni ele risi ọgbako Chiokike \ior (1:5-16) \ior* 
\io1 Ezni ke Ọgbako Chiokike \ior (2:1---3:11) \ior* 
\io1 Ezni ke o znirni Taịtosi nụ obekwu ikwu ipne-aznụ \ior (3:12-15) \ior* 
\c 1  
\p  
\v 1 Mawa, Pọlu nye izi ke Chiokike nụ nye izi Jizọsi Karaịsi. Ẹrnu m bụ o mee ele Chiokike họhiaru nwe ọkwnata ovu, ma be mahịa ezi ọka ke noodubna n'ọtu ogwnu Chiokike,  
\v 2 ma be nwehịa olile anya bụdnu kwó okwo, hne Chiokike zá naagha aghalaghala, bụ ke o kweru mkwna sụ ọwa panịzoru.  
\v 3 O mernu ikwu-ọnu a whụya iwhne n'ige ke a hite nụ ọgbasa izi ọma, bụ ke o yisiri n'aka m lele nhne Chiokike Nye Ọznohia aị nyernu n'iwu.  
\v 4 M naagbanụ ị Taịtosi nnwọ m n'ezi n'ọkwnata ovu ke a kwekọtaru ọkwukwo. 
\p Oru, nụ udno ke hi n'aka Chiokike Nda aị nụ Jizọsi Karaịsi, Nye Ọznohia aị. 
\s1 Ẹrnu Taịtosi nụ rime  //  Kiriti 
\p  
\v 5 Nhne mernu me gharụru ị nụ Kiriti bụ ma ị bịkwata nhne ke kwesiri ọbikwa, họhia ele okno badnụ nụ rime ẹli-ọhna ọbula, lele kpa me kannụ ị.  
\v 6 Nye okno badnụ kwesiri ọ bụ nye nwée ọtna, nye lụ otu nnwerne, nye nwernu rụmu be tụkwasiri mkpọma, nye kpáhie agwa, ele mée risi rikne.  
\v 7 Kwnornu nụ nye risi jọobu nye nwée ọtna lele nye izi Chiokike, nye mée n'iche ovu a, wé ovu ẹhni wara wara, nye zá nọonwo manya gbu ogbu, nye mée nhne rikne, nye nwée ọwho-anya.  
\v 8 Ọ jọobu nye neelekọta ele izne, nye whnụrnu nhne ọma n'anya, nye zá neemewhe nhne ike, nye zị snam, zịri nsọ, nye neejikwaru ẹhni a.  
\v 9 O jikwaru ọka wam ke kwesiri ọkwnata ovu rikne lele kpa be znirni a, ma o mesi ele berere ovu rikne hite n'iznizni a zị snam, gesi masị ele neemegidne a nhne ọjo be. 
\p  
\v 10 Agịda ele kwé ekwe nooduwhu ele berere hite nụ ikwu-ọnu etekne, ke kakwo ele knesnigwụ omen'ẹli ele Ju aka rikne.  
\v 11 Be kwesiri o mee be kpusni ọnu be, ele noolulu agwna ezi-nụ-ọro, ele neezni nhne be kwésile o zni, kwnornu ịwai.  
\v 12 Otu nye ọwhnurninya be, nye Kiriti, karụ kpa, “Ele Kiriti bụ ele aghalaghala, ele ovu ọjo lele anọhia, ele ime-mgwụ, nụ ele okne nkọli.”  
\v 13 Nhne o kwuru bụ ezi ọka, ka kpayarụ bigbọsi be rikne, ma be gwuzosi rikne n'ọkwnata ovu,  
\v 14 ma be gharụ iznizni aghalaghala ele Ju nụ iwu ele badnụ ke hi n'aka ele whọgaru n'ezi ọka.  
\v 15 Kpakara nhne zị rịchna n'anya ele zị rịchna, kọvu nye rụru ọru nụ nye kwé ekwe, ọ zá nhne zị rịchna, kwnornu nụ akọniche be nụ echiche be rụru ọru.  
\v 16 Be karụ nụ be magwụ Chiokike, kọvu ẹrnu be neegesi nụ be nọogonahoru a. Ele sọ ize, ele risi rikne, ele nwée rikne mee nhne ọma ọbula. 
\c 2  
\s1 Iznizni zị snam 
\p  
\v 1 Gbalị zni iznizni zị snam.  
\v 2 Ele okno badnụ nwernu anya udno, ele nwernu ọso n'anya, ele zá neemewhe nhne ike, ele zị kwem n'ọkwnata ovu be, nụ ọwhnun'anya nụ ndidi.  
\v 3 Ele okno badnụ ele rinya masị wuru bụdnu lele ele zị nsọ, ele zá noobno ele berere nhne, ele zá nọonwo manya gbu ogbu, ele neezni nhne bụru ọma,  
\v 4 ma be zni ele nnwerne ikne anya udno, whnụ nzi be nụ rụmu be n'anya.  
\v 5 Be kwesiri ọ bụru ele zá neemewhe nhne ike, ele zị rịchna, ele rinya neelegidne ọro be anya nkarị, ele noobnonu nzi be nsnị, ma ele badnụ gharụ ọ kaja ikwu-ọnu Chiokike. 
\p  
\v 6 Kpam masị, neezni rụmu ikoro ma be bụru ele zá neemewhe nhne ike.  
\v 7 Nụ kpakara nhne i neeme, gesi ẹhni i nye ọma atụ n'ẹrnu ọma. Nụ nhne i neezni gwuzosi rikne nụ rime a, nye anya dụru ẹli.  
\v 8 Ikwu-ọnu bụru ọma ma nye ọbula ke neemegidne i tụ iwhnerne hne be nwée nhne ọjo be jeeji nookwugidne aị. 
\p  
\v 9 Zni ele ọhi be bnonu ele nwe be nsnị nụ kpakara nhne, neeme nhne jọoso be n'ọnu, be sá ọka nga be nookwunu be ọka.  
\v 10 Be znú nhne ele nwe be, kọvu be gesi nụ be jọotukwasi be mkpọma, neegesi nhne ọma ke zị nụ iznizni Chiokike Nye Ọznohia aị nụ kpakara nhne. 
\p  
\v 11 Oru Chiokike ke neegweya ọznohia whụyaru iwhne hne kpakara ele badnụ zị,  
\v 12 neezni aị a sịgbasi nhne nọogwnu anọ-ẹhni aị n'ọwa, nụ bụdnu ke zá nọotu ogwnu Chiokike, a wuru bụdnu ele zá neemewhe nhne ike, ome mma, nọotu ogwnu Chiokike nụ rime ọwa ka.  
\v 13 A nwernu olile anya zị ngọzi, bụ ọ whụya iwhne igwugwu ke Chiokike hna ezi nụ Nye Ọznohia aị Jizọsi Karaịsi.  
\v 14 Ọ bụ nye gweru ẹhni a nyee n'ọnodi aị ma ọ gbahịa aị nụ rime nhne ọjo, bịtannu ẹhni a ele ke a, ele zị rịchna, ele ovu neerne bẹkwnu n'ẹrnu ọma.  
\v 15 Zni kpakara nhne ka, naakwnagidne, bna mbna nụ kpakara rikne i nwernu. I kwé badnụ ọbula ledna ị anya. 
\c 3  
\s1 Bụdnu nye Karaịsi 
\p  
\v 1 Chenwanyanụ ele badnụ be bịta ẹhni be nụ mkpururu ele risi nụ ele nẹechi ẹchi, noobno nsnị, jiknernu ọ rnụ ẹrnu ọma,  
\v 2 be kwúkọ ọka ọjo megidne badnụ ọbula, be bụru ele udno, ele agwa ọma, ele ovu hieru ẹli hne kpakara ele badnụ zị. 
\p  
\v 3 N'ige mbọm, a bụ ele iwhnirniwhno, ele zá noobno nsnị, ele be duwhuru, noosno agịda nhne ọjo zị ọdo nụ ọdo ke nọogwnu aị, a wuru bụdnu ọjo, kwno awụwa, be snornu aị irno, aịla sno masị be irno.  
\v 4 Kọvu nga ovu ọma nụ ọwhnun'anya Chiokike Nye Ọznohia aị whụyaru iwhne,  
\v 5 ọ znọhia aị, ọ bụ́o kwnornu ẹrnu ọma a rnụrnu, kọvu kwnornu obirizi a. Hite n'ọsnusnu ke ọmu berere, Enine Nsọ nyernu aị bụdnu ikne.  
\v 6 Chiokike wụkwasiri aị Enine Nsọ k'agịda hite nụ Jizọsi Karaịsi Nye Ọznohia aị.  
\v 7 Hne o gwnụrnu aị lele ele mee mma hite n'oru, a bụru ele neekehịa olile anya bụdnu kwó okwo.  
\v 8 Ka bụ ọka kwesiri ọkwnata ovu. M naakaa, jị kwusi a rikne ma ele kweru nụ Chiokike bụru ele anya dụru ẹli, neeme nhne bụru ọma. Kpakara nhne ka bụru ọma naabna iru hne ele badnụ zị. 
\p  
\v 9 Kọvu zeru ajịji iwhnirniwhno, nụ ọgwnu rẹwhna ẹbnurnu, oknorno, ọlu ọgwnu kwnornu iwu, be bnána iru, be bụ nhne etekne.  
\v 10 Dọ nye ọbula ke neegweya okewa aka nụ nsnị mgba lawụru, i mekwo, gharụ a.  
\v 11 Ị magwụ nụ badnụ kị bụ nye aghorome, nye mmehie, ọ bụ nye naama ẹhni a ikpe. 
\s1 Ezni ipne-aznụ 
\p  
\v 12 Nga me jeeziya Atemasị nụ Taịkikosi, hna anụ zị, gbalị vakwnusi m nụ Nikopolisi, kwnornu nụ m jaadazị pịi n'ige okirika.  
\v 13 Gbalị yisinu Zenasi nye ọgwnu iwu nụ Apọlosi aka n'izne be, whnụ nụ be nwehịaru nhne ọbula be pioru.  
\v 14 Ele ke aị mụhia kpa be jeeji ige be rnụ ẹrnu ọma, rnụhia nhne zị mkpa, be wúkọ badnụ bnána nụ nhne.  
\v 15 Kpakara ele me nụ be zị neebekwu i. Bekwu kpakara ele whnụrnu aị n'anya nụ rime ọkwnata ovu. Oru Chiokike dazịnu kpakara anụ.