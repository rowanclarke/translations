\p
\v 12 \w Aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w David|strong="H1732"\w* \w tuvo|strong="H3372"\w* \w temor|strong="H3372"\w* \w a|strong="H3068"\w* \nd ʼElohim\nd* y preguntó: ¿\w Cómo|strong="H1963"\w* podrá \w el|strong="H1931"\w* Arca \w de|strong="H3372"\w* \nd ʼElohim\nd* ir \w a|strong="H3068"\w* mí?  
\v 13 Así \w que|strong="H3808"\w* \w David|strong="H1732"\w* \w no|strong="H3808"\w* llevó consigo el Arca \w a|strong="H3068"\w* la \w Ciudad|strong="H5892"\w* de \w David|strong="H1732"\w*, \w más|strong="H3808"\w* bien la desvió \w a|strong="H3068"\w* la \w casa|strong="H1004"\w* de \w Obed-edom|strong="H5654"\w* geteo.  
\v 14 \w El|strong="H5973"\w* Arca \w de|strong="H5973"\w* \nd ʼElohim\nd* \w estuvo|strong="H3427"\w* \w en|strong="H5973"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w con|strong="H5973"\w* \w la|strong="H3605"\w* \w familia|strong="H1004"\w* \w de|strong="H5973"\w* \w Obed-edom|strong="H5654"\w* \w tres|strong="H7969"\w* \w meses|strong="H2320"\w*. \w Y|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w bendijo|strong="H1288"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w de|strong="H5973"\w* \w Obed-edom|strong="H5654"\w*, y \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w que|strong="H3605"\w* tenía.   
\c 14  
\s1 David y su familia  
\p
\v 1 \w Hiram|strong="H2438"\w*, \w rey|strong="H4428"\w* de \w Tiro|strong="H6865"\w*, \w envió|strong="H7971"\w* \w mensajeros|strong="H4397"\w* \w a|strong="H3068"\w* \w David|strong="H1732"\w* con \w madera|strong="H6086"\w* de cedro, artesanos y ebanistas para que le \w edificaran|strong="H1129"\w* una \w casa|strong="H1004"\w*.  
\v 2 \w David|strong="H1732"\w* comprendió \w que|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w lo|strong="H5921"\w* estableció \w como|strong="H3588"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w y|strong="H3588"\w* \w que|strong="H3588"\w* \w su|strong="H3588"\w* \w reino|strong="H4438"\w* fue exaltado \w por|strong="H5921"\w* amor \w a|strong="H3068"\w* \w su|strong="H3588"\w* \w pueblo|strong="H5971"\w* \w Israel|strong="H3478"\w*.   
\p
\v 3 Entonces \w David|strong="H1732"\w* \w tomó|strong="H3947"\w* \w más|strong="H5750"\w* \w mujeres|strong="H1323"\w* \w en|strong="H5750"\w* Jerusalén, y \w engendró|strong="H3205"\w* \w más|strong="H5750"\w* \w hijos|strong="H1121"\w* \w e|strong="H3068"\w* \w hijas|strong="H1323"\w*.  
\v 4 Éstos \w son|strong="H1961"\w* \w los|strong="H1961"\w* \w nombres|strong="H8034"\w* de \w los|strong="H1961"\w* \w que|strong="H1961"\w* le \w nacieron|strong="H3205"\w* en Jerusalén: \w Samúa|strong="H8051"\w*, \w Sobab|strong="H7727"\w*, Natán, \w Salomón|strong="H8010"\w*,  
\v 5 \w Ibhar|strong="H2984"\w*, Elisúa, Elpelet,  
\v 6 \w Noga|strong="H5052"\w*, Nefeg, Jafía,  
\v 7 Elisama, Beeliada y Elifelet.   
\p
\v 8 \w Al|strong="H5921"\w* \w oír|strong="H8085"\w* \w los|strong="H5921"\w* \w filisteos|strong="H6430"\w* \w que|strong="H3588"\w* \w David|strong="H1732"\w* fue \w ungido|strong="H4886"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w*, \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w filisteos|strong="H6430"\w* \w subieron|strong="H5927"\w* \w en|strong="H5921"\w* \w busca|strong="H1245"\w* \w de|strong="H5921"\w* \w David|strong="H1732"\w*. \w Cuando|strong="H3588"\w* \w David|strong="H1732"\w* \w lo|strong="H5921"\w* \w oyó|strong="H8085"\w*, \w salió|strong="H3318"\w* \w contra|strong="H5921"\w* \w ellos|strong="H5921"\w*,  
\v 9 porque los \w filisteos|strong="H6430"\w* llegaron y se desplegaron por el \w valle|strong="H6010"\w* de Refaim.  
\v 10 Entonces \w David|strong="H1732"\w* \w consultó|strong="H7592"\w* \w a|strong="H3068"\w* \nd ʼElohim\nd*: ¿\w Iré|strong="H5927"\w* \w contra|strong="H5921"\w* \w los|strong="H5921"\w* \w filisteos|strong="H6430"\w*? ¿\w Los|strong="H5921"\w* entregarás \w en|strong="H5921"\w* \w mi|strong="H5921"\w* \w mano|strong="H3027"\w*?  
\p \nd \+w Yavé|strong="H3068"\+w*\nd* \w le|strong="H5921"\w* respondió: \wj \+w Vé|strong="H5927"\+w*, \+w porque|strong="H5921"\+w* Yo \+w los|strong="H5921"\+w* \+w entregaré|strong="H5414"\+w* \+w en|strong="H5921"\+w* tu \+w mano|strong="H3027"\+w*. \wj*   
\p
\v 11 \w Subieron|strong="H5927"\w* \w a|strong="H3068"\w* Baal-perazim, \w y|strong="H5921"\w* \w allí|strong="H8033"\w* \w David|strong="H1732"\w* \w los|strong="H5921"\w* derrotó. \w Luego|strong="H1931"\w* \w David|strong="H1732"\w* dijo: ¡\nd ʼElohim\nd* irrumpió \w contra|strong="H5921"\w* mis enemigos \w por|strong="H5921"\w* \w mi|strong="H5921"\w* \w mano|strong="H3027"\w*, \w como|strong="H5921"\w* corriente impetuosa! \w Por|strong="H5921"\w* \w esto|strong="H3651"\w* \w llamaron|strong="H7121"\w* \w aquel|strong="H1931"\w* \w lugar|strong="H4725"\w* Baal-perazim.  
\v 12 Ellos \w dejaron|strong="H5800"\w* \w allí|strong="H8033"\w* sus \tl ʼelohim\tl*, y \w David|strong="H1732"\w* ordenó que fueran quemados.   
\p
\v 13 Los \w filisteos|strong="H6430"\w* volvieron \w a|strong="H3068"\w* extenderse \w por|strong="H5750"\w* el \w valle|strong="H6010"\w*.  
\v 14 \w David|strong="H1732"\w* \w volvió|strong="H5750"\w* \w a|strong="H3068"\w* consultar \w a|strong="H3068"\w* \nd ʼElohim\nd*, \w y|strong="H5921"\w* \nd ʼElohim\nd* \w le|strong="H5921"\w* dijo: \wj \+w No|strong="H3808"\+w* \+w subas|strong="H5927"\+w* tras \+w ellos|strong="H1992"\+w*, \+w sino|strong="H3808"\+w* rodéalos \+w por|strong="H5921"\+w* detrás \+w y|strong="H5921"\+w* sal \+w a|strong="H3068"\+w* \+w ellos|strong="H1992"\+w* frente \+w a|strong="H3068"\+w* \+w las|strong="H1992"\+w* balsameras.\wj*  
\v 15 \wj \+w Cuando|strong="H3588"\+w* escuches \+w el|strong="H3588"\+w* \+w ruido|strong="H6963"\+w* \+w de|strong="H3588"\+w* marcha \+w en|strong="H3588"\+w* las copas \+w de|strong="H3588"\+w* las balsameras, \+w sal|strong="H3318"\+w* enseguida \+w a|strong="H3068"\+w* \+w la|strong="H3588"\+w* \+w batalla|strong="H4421"\+w*, \+w porque|strong="H3588"\+w* \+nd ʼElohim\+nd* \+w saldrá|strong="H3318"\+w* \+w delante|strong="H6440"\+w* \+w de|strong="H3588"\+w* ti \+w para|strong="H3588"\+w* derrotar al \+w ejército|strong="H4264"\+w* \+w de|strong="H3588"\+w* \+w los|strong="H1961"\+w* \+w filisteos|strong="H6430"\+w*.\wj*  
\v 16 \w David|strong="H1732"\w* \w hizo|strong="H6213"\w* tal \w como|strong="H5704"\w* \nd ʼElohim\nd* le \w ordenó|strong="H6680"\w* \w y|strong="H5704"\w* derrotaron \w al|strong="H5704"\w* \w ejército|strong="H4264"\w* \w de|strong="H5704"\w* los \w filisteos|strong="H6430"\w* \w desde|strong="H5704"\w* \w Gabaón|strong="H1391"\w* \w hasta|strong="H5704"\w* \w Gezer|strong="H1507"\w*.   
\p
\v 17 \w La|strong="H5921"\w* \w fama|strong="H8034"\w* \w de|strong="H5921"\w* \w David|strong="H1732"\w* fue divulgada \w por|strong="H5921"\w* \w todas|strong="H3605"\w* aquellas tierras, \w y|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w impuso|strong="H5414"\w* \w el|strong="H5921"\w* \w temor|strong="H6343"\w* \w de|strong="H5921"\w* \w David|strong="H1732"\w* \w sobre|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w*.   
\c 15  
\s1 Traslado del Arca de \nd Yavé\nd* a Jerusalén  
\p
\v 1 \w David|strong="H1732"\w* \w hizo|strong="H6213"\w* para \w él|strong="H6213"\w* \w casas|strong="H1004"\w* en la \w Ciudad|strong="H5892"\w* de \w David|strong="H1732"\w*. \w Preparó|strong="H3559"\w* un \w lugar|strong="H4725"\w* para \w el|strong="H6213"\w* Arca de \nd ʼElohim\nd* y levantó una tienda para ella.  
\v 2 \w Entonces|strong="H3588"\w* \w David|strong="H1732"\w* dijo: \w El|strong="H3588"\w* Arca \w de|strong="H3588"\w* \nd ʼElohim\nd* \w no|strong="H3808"\w* debe ser llevada \w sino|strong="H3588"\w* \w por|strong="H3588"\w* \w los|strong="H3588"\w* \w levitas|strong="H3881"\w*, \w porque|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w los|strong="H3588"\w* eligió \w para|strong="H5704"\w* \w que|strong="H3588"\w* \w la|strong="H3588"\w* \w lleven|strong="H5375"\w* \w y|strong="H3588"\w* le sirvan \w perpetuamente|strong="H5769"\w*.   
\p
\v 3 \w David|strong="H1732"\w* congregó \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* en Jerusalén para \w que|strong="H3605"\w* trasladaran \w el|strong="H3605"\w* Arca de \nd \+w Yavé|strong="H3068"\+w*\nd* al \w lugar|strong="H4725"\w* \w que|strong="H3605"\w* había preparado para \w ella|strong="H3605"\w*.   
\p
\v 4 \w David|strong="H1732"\w* reunió \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Aarón y \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w levitas|strong="H3881"\w*:  
\v 5 \w De|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Coat, Uriel \w el|strong="H1121"\w* \w principal|strong="H8269"\w* y 120 \w de|strong="H1121"\w* sus hermanos.  
\v 6 \w De|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Merari|strong="H4847"\w*, \w Asaías|strong="H6222"\w* \w el|strong="H1121"\w* \w principal|strong="H8269"\w*, y 229 \w de|strong="H1121"\w* sus hermanos.  
\v 7 \w De|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Gersón|strong="H1648"\w*, \w Joel|strong="H3100"\w* \w el|strong="H1121"\w* \w principal|strong="H8269"\w*, y 130 \w de|strong="H1121"\w* sus hermanos.  
\v 8 \w De|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Elizafán: \w Semaías|strong="H8098"\w* \w el|strong="H1121"\w* \w principal|strong="H8269"\w*, y 200 \w de|strong="H1121"\w* sus hermanos.  
\v 9 \w De|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Hebrón|strong="H2275"\w*, Eliel \w el|strong="H1121"\w* \w principal|strong="H8269"\w*, y 80 \w de|strong="H1121"\w* sus hermanos.  
\v 10 \w De|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Uziel, \w Aminadab|strong="H5992"\w* \w el|strong="H1121"\w* \w principal|strong="H8269"\w*, y 112 \w de|strong="H1121"\w* sus hermanos.   
\p
\v 11 \w David|strong="H1732"\w* \w llamó|strong="H7121"\w* \w a|strong="H3068"\w* los \w sacerdotes|strong="H3548"\w* \w Sadoc|strong="H6659"\w* y Abiatar, y \w a|strong="H3068"\w* los \w levitas|strong="H3881"\w* Uriel, \w Asaías|strong="H6222"\w*, \w Joel|strong="H3100"\w*, \w Semaías|strong="H8098"\w*, Eliel y \w Aminadab|strong="H5992"\w*.  
\v 12 Les dijo: Ustedes son los \w principales|strong="H7218"\w* padres de las familias de los \w levitas|strong="H3881"\w*. Santifíquense, ustedes y sus hermanos, para que suban el Arca de \nd \+w Yavé|strong="H3068"\+w* ʼElohim\nd* de \w Israel|strong="H3478"\w* al lugar que le preparé.  
\v 13 \w Pues|strong="H3588"\w* \w por|strong="H3588"\w* \w no|strong="H3808"\w* hacerlo ustedes \w la|strong="H3588"\w* \w primera|strong="H7223"\w* vez, \nd \+w Yavé|strong="H3068"\+w*\nd* nuestro \nd ʼElohim\nd* nos quebrantó, \w por|strong="H3588"\w* \w cuanto|strong="H3588"\w* \w no|strong="H3808"\w* le consultamos según \w el|strong="H3588"\w* orden prescrito.  
\v 14 Así que los \w sacerdotes|strong="H3548"\w* y los \w levitas|strong="H3881"\w* se santificaron para \w subir|strong="H5927"\w* el Arca de \nd \+w Yavé|strong="H3068"\+w* ʼElohim\nd* de \w Israel|strong="H3478"\w*.  
\v 15 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w levitas|strong="H3881"\w* \w llevaron|strong="H5375"\w* \w el|strong="H5921"\w* Arca \w de|strong="H5921"\w* \nd ʼElohim\nd* \w con|strong="H5921"\w* \w las|strong="H5921"\w* barras puestas \w sobre|strong="H5921"\w* sus \w hombros|strong="H3802"\w*, \w tal|strong="H1697"\w* \w como|strong="H5921"\w* \w Moisés|strong="H4872"\w* \w ordenó|strong="H6680"\w*, \w según|strong="H5921"\w* \w la|strong="H5921"\w* \w Palabra|strong="H1697"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.   
\p
\v 16 Asimismo \w David|strong="H1732"\w* dijo \w a|strong="H3068"\w* los \w jefes|strong="H8269"\w* \w de|strong="H8269"\w* los \w levitas|strong="H3881"\w* que designaran \w de|strong="H8269"\w* sus hermanos \w cantores|strong="H7891"\w* con \w instrumentos|strong="H3627"\w* \w de|strong="H8269"\w* \w música|strong="H7892"\w*, con \w salterios|strong="H5035"\w* y \w arpas|strong="H3658"\w* y \w címbalos|strong="H4700"\w* resonantes, y que alzaran la \w voz|strong="H6963"\w* con \w alegría|strong="H8057"\w*.   
\p
\v 17 \w Los|strong="H1121"\w* \w levitas|strong="H3881"\w* designaron \w a|strong="H3068"\w* \w Hemán|strong="H1968"\w*, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* \w Joel|strong="H3100"\w*, y \w de|strong="H4480"\w* sus parientes \w a|strong="H3068"\w* Asaf, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* Berequías, y \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w Merari|strong="H4847"\w* y \w de|strong="H4480"\w* sus hermanos, \w a|strong="H3068"\w* Etán, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* \w Cusaías|strong="H6984"\w*.  
\v 18 \w Con|strong="H5973"\w* ellos, \w a|strong="H3068"\w* sus hermanos \w de|strong="H5973"\w* \w segundo|strong="H4932"\w* grado, \w a|strong="H3068"\w* \w Zacarías|strong="H2148"\w*, hijo \w de|strong="H5973"\w* Jahaziel, Semiramot, \w Jehiel|strong="H3171"\w*, \w Unni|strong="H6042"\w*, Eliab, \w Benaía|strong="H1141"\w*, \w Maasías|strong="H4641"\w*, Matatías, Elifelehu, \w Micnías|strong="H4737"\w*, \w Obed-edom|strong="H5654"\w* y \w Jeiel|strong="H3273"\w*, \w los|strong="H5973"\w* \w porteros|strong="H7778"\w*.   
\p
\v 19 Así \w Hemán|strong="H1968"\w*, Asaf y Etán, que eran \w cantores|strong="H7891"\w*, sonaban \w címbalos|strong="H4700"\w* de bronce.  
\v 20 \w Zacarías|strong="H2148"\w*, Aziel, Semiramot, \w Jehiel|strong="H3171"\w*, Uni, Eliab, \w Maasías|strong="H4641"\w* \w y|strong="H5921"\w* \w Benaía|strong="H1141"\w*, tocaban \w salterios|strong="H5035"\w* \w de|strong="H5921"\w* tono alto.  
\v 21 Matatías, Elifelehu, \w Micnías|strong="H4737"\w*, Obede-dom, \w Jeiel|strong="H3273"\w* \w y|strong="H5921"\w* \w Azazías|strong="H5812"\w*, dirigían \w con|strong="H5921"\w* liras templadas \w en|strong="H5921"\w* tono alto.  
\v 22 Quenanías, \w principal|strong="H8269"\w* \w de|strong="H3588"\w* \w los|strong="H3588"\w* \w levitas|strong="H3881"\w* \w en|strong="H3588"\w* \w la|strong="H1931"\w* música, \w fue|strong="H1931"\w* designado \w para|strong="H3588"\w* elevar \w el|strong="H1931"\w* canto, \w porque|strong="H3588"\w* \w era|strong="H1931"\w* entendido \w para|strong="H3588"\w* \w esto|strong="H1931"\w*.   
\p
\v 23 Berequías y Elcana eran \w porteros|strong="H7778"\w* del Arca.  
