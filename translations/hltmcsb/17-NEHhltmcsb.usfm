\v 2 Te \w vaengah|strong="H9999"\w* \w ka|strong="H9901"\w* \w manuca|strong="H0251"\w* rhoek \w khuikah|strong="H4480"\w* \w pakhat|strong="H0259"\w* \w Hanani|strong="H2607"\w* \w ha\w* \w pawk|strong="H0935"\w*. \w Amah|strong="H1931"\w* \w neh|strong="H9999"\w* \w Judah|strong="H3063"\w* \w lamkah|strong="H4480"\w* \w hlang|strong="H0376"\w* rhoek khaw om. \w Amih|strong="H9908"\w* \w taengah\w* \w tamna|strong="H7628"\w* \w lamloh|strong="H4480"\w* \w aka\w* \w sueng|strong="H7604"\w* \w rhalyong|strong="H6413"\w* \w Judah|strong="H3064"\w* \w kawng|strong="H5921"\w* \w neh|strong="H9999"\w* \w Jerusalem|strong="H3389"\w* \w kawng|strong="H5921"\w* te ka \w dawt|strong="H7592"\w*.
