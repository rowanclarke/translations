\id PSA
\h Psalmi Davidovi
\toc1 Psalmi Davidovi
\toc2 Psalmi
\toc3 Ps
\mt1 Psalmi Davidovi
\c 1
\cl Psalam 1
\s1 Blaženstvo pobožnih. Nesreća bezbožnika.
\q1 
\v 1 Blago čoveku koji ne ide na veće bezbožničko,
\q2 i na putu grešničkom ne stoji,
\q2 i u društvu nevaljalih ljudi ne sedi,
\q1 
\v 2 Nego mu je omileo zakon Gospodnji
\q2 i o zakonu Njegovom misli dan i noć!
\b
\q1 
\v 3 On je kao drvo usađeno kraj potoka,
\q2 koje rod svoj donosi u svoje vreme,
\q2 i kome list ne vene;
\q1 šta god radi, u svemu napreduje.
\q1 
\v 4 Nisu takvi bezbožnici,
\q2 nego su kao prah koji rasipa vetar.
\b
\q1 
\v 5 Zato se neće bezbožnici održati na sudu,
\q2 ni grešnici na zboru pravedničkom.
\q1 
\v 6 Jer Gospod zna put pravednički;
\q2 a put bezbožnički propašće.
\c 2
\cl Psalam 2
\s1 Proricanje o carstvu sina Božijeg i o pobedi nad njegovim neprijateljima.
\q1 
\v 1 Zašto se bune narodi
\q2 i plemena pomišljaju zaludne stvari?
\q1 
\v 2 Ustaju carevi zemaljski,
\q2 i knezovi se skupljaju
\q2 na Gospoda i na pomazanika Njegovog.
\q1 
\v 3 „Raskinimo sveze njihove
\q2 i zbacimo sa sebe jaram njihov.”
\b
\q1 
\v 4 Onaj, što živi na nebesima, smeje se,
\q2 Gospod im se podsmeva.
\q1 
\v 5 Pa im govori u gnevu svom
\q2 i jarošću svojom zbunjuje ih:
\q1 
\v 6 „Ja sam pomazao cara svog na Sionu,
\q2 na svetoj gori svojoj.”
\b
\q1 
\v 7 Kazaću naredbu Gospodnju;
\q2 On reče meni: „Ti si sin moj, ja te sad rodih.
\q1 
\v 8 Išti u mene, i daću ti narode u nasledstvo,
\q2 i krajeve zemaljske tebi u državu.
\q1 
\v 9 Udarićeš ih gvozdenom palicom;
\q2 razbićeš ih kao lončarski sud.”
\b
\q1 
\v 10 Sad, carevi, orazumite se;
\q2 naučite se sudije zemaljske!
\q1 
\v 11 Služite Gospodu sa strahom,
\q2 i radujte se s trepetom.
\q1 
\v 12 Poštujte sina, da se ne razgnevi,
\q2 i vi ne izginete na putu svom;
\q1 jer će se gnev Njegov brzo razgoreti.
\q2 Blago svima koji se u Nj uzdaju!
\c 3
\cl Psalam 3
\s1 Pouzdanje u Boga protiv svih neprijatelja.
\d Psalam Davidov, kad je bežao od Avesaloma sina svog.
\q1 
\v 1 Gospode! Kako je mnogo neprijatelja mojih!
\q2 Mnogi ustaju na me.
\q1 
\v 2 Mnogi govore za dušu moju:
\q2 Nema mu pomoći od Boga.
\b
\q1 
\v 3 Ali Ti si, Gospode, štit koji me zaklanja, slava moja;
\q2 Ti podižeš glavu moju.
\q1 
\v 4 Glasom svojim vičem ka Gospodu,
\q2 i čuje me sa svete gore svoje.
\b
\q1 
\v 5 Ja ležem, spavam i ustajem,
\q2 jer me Gospod čuva.
\q1 
\v 6 Ne bojim se mnogo hiljada naroda
\q2 što sa svih strana navaljuje na me.
\b
\q1 
\v 7 Ustani, Gospode!
\q2 Pomozi mi, Bože moj!
\q1 Jer Ti udaraš po obrazu sve neprijatelje moje;
\q2 razbijaš zube bezbožnicima.
\b
\q1 
\v 8 Od Gospoda je spasenje;
\q2 neka bude na narodu Tvom blagoslov Tvoj!
\c 4
\cl Psalam 4
\s1 Davidova večernja molitva puna hrabrosti, date verom, protiv neprijatelja. Bog zastiđuje malodušnost prijatelja.
\d Načelniku pevačkom. Uz žice. Psalam Davidov.
\q1 
\v 1 Kad Te zovem čuj me, Bože, pravdo moja!
\q2 U teskobi daj mi prostor;
\q2 smiluj se na me i usliši molitvu moju.
\b
\q1 
\v 2 Sinovi čovečiji! Dokle će slava moja biti u sramoti?
\q2 Dokle ćete ljubiti ništavilo i tražiti laži?
\q1 
\v 3 Znajte da Gospod divno čuva svetog svog;
\q2 Gospod čuje kad Ga zovem.
\b
\q1 
\v 4 Gneveći se ne grešite;
\q2 razmislite u srcima svojim na posteljama svojim,
\q2 i utolite.
\q1 
\v 5 Prinesite žrtvu za pravdu,
\q2 i uzdajte se u Gospoda.
\b
\q1 
\v 6 Mnogi govore: Ko će nam pokazati šta je dobro?
\q2 Obrati k nama, Gospode, svetlo lice svoje.
\q1 
\v 7 A meni si dao u srce radost veću nego što je oni imaju,
\q2 kad im rodi pšenica i vino.
\b
\q1 
\v 8 Ja mirno ležem i spavam;
\q2 jer Ti, Gospode, sam daješ mi, te sam bez straha.
\c 5
\cl Psalam 5
\s1 Davidova jutrenja molitva puna vere u pomoć pravednog Boga protiv bezbožnih neprijatelja.
\d Načelniku pevačkom. Uza sviralu. Psalam Davidov.
\q1 
\v 1 Čuj, Gospode, reči moje,
\q2 razumi pomisli moje.
\q1 
\v 2 Slušaj viku moju, care moj i Bože moj!
\q2 Jer se Tebi molim, Gospode!
\q1 
\v 3 Ujutru slušaš glas moj,
\q2 ujutru stojim pred Tobom, i čekam.
\b
\q1 
\v 4 Jer si Ti Bog koji neće bezakonja;
\q2 u Tebe nema mesta ko je zao.
\q1 
\v 5 Bezbožnici neće izaći pred oči Tvoje;
\q2 Ti nenavidiš sve koji čine bezakonje.
\q1 
\v 6 Potireš lažljivce;
\q2 na krvopioce i lukave mrzi Gospod.
\b
\q1 
\v 7 A ja po velikoj milosti Tvojoj ulazim u dom Tvoj,
\q2 i klanjam se u svetoj crkvi Tvojoj sa strahom Tvojim.
\q1 
\v 8 Gospode! Vodi me u pravdi svojoj;
\q2 radi neprijatelja mojih poravni preda mnom put svoj.
\b
\q1 
\v 9 Jer nema u ustima njihovim istine;
\q2 u njima je nevaljalstvo;
\q1 grlo im je grob otvoren;
\q2 na jeziku im je dvoličenje.
\q1 
\v 10 Bože! Ne daj im napretka,
\q2 neka se razbiju pomisli njihove.
\q1 Za mnoga nevaljalstva njihova obori ih,
\q2 jer se pobuniše na Tebe.
\b
\q1 
\v 11 Pa će se radovati svi koji se u Te uzdaju;
\q2 doveka će se veseliti koje Ti zaklanjaš;
\q2 dičiće se koji ljube ime Tvoje.
\q1 
\v 12 Jer Ti, Gospode, blagosiljaš pravednika,
\q2 kao štitom zaklanjaš ga milošću svojom.
\c 6
\cl Psalam 6
\s1 Pokajnička molitva. Uzdanje u pomoć Gospodnju.
\d Načelniku pevačkom. Uz žice. Na osam žica. Psalam Davidov.
\q1 
\v 1 Gospode! Nemoj me pokarati u jarosti svojoj,
\q2 niti me u gnevu svom nakaziti.
\q1 
\v 2 Smiluj se na me, Gospode,
\q2 jer sam iznemogao;
\q1 isceli me,
\q2 jer su kosti moje ustreptale,
\q1 
\v 3 I duša se moja vrlo uzdrhtala.
\q2 A Ti, Gospode, dokle ćeš.
\b
\q1 
\v 4 Obrati se, Gospode, izbavi dušu moju,
\q2 pomozi mi radi milosti svoje.
\q1 
\v 5 Jer mrtvi ne spominju Tebe;
\q2 u grobu ko će Te slaviti?
\b
\q1 
\v 6 Iznemogoh uzdišući;
\q2 svaku noć kvasim odar svoj,
\q2 suzama svojim natapam postelju svoju.
\q1 
\v 7 Usahnu od žalosti oko moje,
\q2 postara se od množine neprijatelja mojih.
\b
\q1 
\v 8 Idite od mene svi koji činite bezakonje,
\q2 jer Gospod ču plač moj.
\q1 
\v 9 Ču Gospod molbu moju,
\q2 Gospod molitvu moju primi.
\q1 
\v 10 Nek se postide i prepadnu svi neprijatelji moji,
\q2 neka se povrate i postide odmah.
\c 7
\cl Psalam 7
\s1 Pravedni Bog spasava bezazlenost Davidovu od nepravednog neprijatelja.
\r (2. Samuilova 16)
\d Plačna pesma Davidova, koju je pevao Gospodu poradi Husa od plemena Venijaminova.
\q1 
\v 1 Gospode, Bože moj!
\q2 U Tebe se uzdam, sačuvaj me od svih koji me gone, i izbavi me.
\q1 
\v 2 Da mi neprijatelj ne iščupa dušu kao lav.
\q2 Čupa, a nema ko da izbavi.
\b
\q1 
\v 3 Gospode, Bože moj!
\q2 Ako sam to učinio,
\q2 ako je nepravda u rukama mojim,
\q1 
\v 4 Ako sam zlo vratio prijatelju svom,
\q2 ili krivo učinio onima koji na me na pravdi napadahu;
\q1 
\v 5 Neka goni neprijatelj dušu moju,
\q2 i neka je stigne,
\q1 i pogazi na zemlju život moj
\q2 i slavu moju u prah obrati.
\b
\q1 
\v 6 Ustani, Gospode, u gnevu svom;
\q2 digni se na žestinu neprijatelja mojih;
\q1 probudi se meni na pomoć, i otvori sud.
\q1 
\v 7 I ljudstvo će se sleći oko Tebe;
\q2 iznad njega izađi u visinu.
\b
\q1 
\v 8 Gospod sudi narodima.
\q2 Sudi mi, Gospode, po pravdi mojoj,
\q2 i po bezazlenosti mojoj neka mi bude.
\q1 
\v 9 Nek se prekine zloća bezbožnička,
\q2 a pravednika potpomozi,
\q1 jer Ti ispituješ srca i utrobe, Bože pravedni!
\q1 
\v 10 Štit je meni u Boga,
\q2 koji čuva one koji su pravog srca.
\q1 
\v 11 Bog je pravedan sudija,
\q2 i Bog je svaki dan gotov na gnev.
\b
\q1 
\v 12 Ako se neće bezbožnik da obrati,
\q2 On oštri mač svoj, nateže luk svoj, i naperuje ga;
\q1 
\v 13 I zapinje smrtnu strelu,
\q2 čini strele svoje da pale.
\q1 
\v 14 Gle, bezbožnik zače nepravdu,
\q2 trudan beše zločinstvom, i rodi sebi prevaru.
\q1 
\v 15 Kopa jamu i iskopa,
\q2 i pade u jamu koju je načinio.
\q1 
\v 16 Zloba njegova obrati se na njegovu glavu,
\q2 i zločinstvo njegovo pade na teme njegovo.
\b
\q1 
\v 17 Hvalim Gospoda za pravdu Njegovu,
\q2 i pevam imenu Gospoda Višnjeg.
\c 8
\cl Psalam 8
\s1 Božija veličina u stvaranju. Čovekova niskost i visina.
\d Načelniku pevačkom. Uz Getsku muzikalnu spravu. Psalam Davidov.
\q1 
\v 1 Gospode, Gospode naš!
\q2 Kako je veličanstveno ime Tvoje po svoj zemlji!
\q2 Podigao si slavu svoju više nebesa.
\q1 
\v 2 U ustima male dece i koja sisaju činiš sebi hvalu
\q2 nasuprot neprijateljima svojim,
\q2 da bi učinio da zamukne neprijatelj i nemirnik.
\b
\q1 
\v 3 Kad pogledam nebesa Tvoja,
\q2 delo prsta Tvojih,
\q2 mesec i zvezde, koje si Ti postavio;
\q1 
\v 4 Šta je čovek, te ga se opominješ,
\q2 ili sin čovečji, te ga polaziš?
\b
\q1 
\v 5 Učinio si ga malo manjeg od anđela,
\q2 slavom i čašću venčao si ga;
\q1 
\v 6 Postavio si ga gospodarem nad delima ruku svojih,
\q2 sve si metnuo pod noge njegove,
\q1 
\v 7 Ovce i volove sve, i divlje zverinje,
\q1 
\v 8 Ptice nebeske i ribe morske,
\q2 šta god ide morskim putevima.
\b
\q1 
\v 9 Gospode, Gospode naš!
\q2 Kako je veličanstveno ime Tvoje po svoj zemlji!
\c 9
\cl Psalam 9
\s1 Zahvalna pesma za spasenje od neprijatelja i molba za dalju pomoć.
\d Načelniku pevačkom. Uza sviralu. Benu. Psalam Davidov.
\q1 
\v 1 Hvalim Te, Gospode, iz svega srca svog,
\q2 kazujem sva čudesa Tvoja.
\q1 
\v 2 Radujem se i veselim se o Tebi,
\q2 pevam imenu Tvom, Višnji!
\b
\q1 
\v 3 Neprijatelji se moji vratiše natrag,
\q2 spotakoše se i nesta ih ispred lica Tvog;
\q1 
\v 4 Jer si svršio sud moj i odbranio me;
\q2 seo si na presto, sudija pravedni.
\b
\q1 
\v 5 Rasrdio si se na narode i ubio bezbožnika,
\q2 ime si im zatro doveka, za svagda.
\q1 
\v 6 Neprijatelju nesta mačeva sasvim;
\q2 gradove Ti si razvalio;
\q2 pogibe spomen njihov.
\b
\q1 
\v 7 Ali Gospod uvek živi;
\q2 spremio je za sud presto svoj.
\q1 
\v 8 On će suditi vasionom svetu po pravdi,
\q2 usudiće narodima pravo.
\b
\q1 
\v 9 Gospod je utočište ubogome,
\q2 utočište u nevolji.
\q1 
\v 10 U Tebe se uzdaju koji znaju ime Tvoje,
\q2 jer ne ostavljaš onih koji Te traže, Gospode!
\b
\q1 
\v 11 Pojte Gospodu, koji živi na Sionu;
\q2 kazujte narodu dela Njegova;
\q1 
\v 12 Jer On osvećuje krv, pamti je;
\q2 ne zaboravlja jauk nevoljnih.
\b
\q1 
\v 13 Smiluj se na me, Gospode;
\q2 pogledaj kako stradam od neprijatelja svojih,
\q2 Ti, koji me podižeš od vrata smrtnih,
\q1 
\v 14 Da bih kazivao sve hvale Tvoje na vratima kćeri Sionove,
\q2 i slavio spasenje Tvoje.
\b
\q1 
\v 15 Popadoše narodi u jamu, koju su iskopali;
\q2 u zamku, koju su sami namestili, uhvati se noga njihova.
\q1 
\v 16 Poznaše Gospoda;
\q2 On je sudio;
\q1 u dela ruku svojih zaplete se bezbožnik.
\b
\q1 
\v 17 Vratiće se u pakao bezbožnici,
\q2 svi narodi koji zaboravljaju Boga;
\b
\q1 
\v 18 Jer neće svagda biti zaboravljen ubogi,
\q2 i nada nevoljnicima neće nikad poginuti.
\b
\q1 
\v 19 Ustani, Gospode, da se ne posili čovek,
\q2 i da prime narodi sud pred Tobom.
\q1 
\v 20 Pusti, Gospode, strah na njih;
\q2 neka poznaju narodi da su ljudi.
\c 10
\cl Psalam 10
\s1 Jadikovanje zbog nestizanja Božije pomoći protiv obesti bezbožnikove i molitva za spasenje podjarmljenih.
\q1 
\v 1 Zašto, Gospode, stojiš daleko,
\q2 kriješ se kad je nevolja?
\b
\q1 
\v 2 S oholosti bezbožnikove muči se ubogi;
\q2 hvataju se ubogi prevarom koju izmišljaju bezbožnici.
\q1 
\v 3 Jer se bezbožnik diči željom duše svoje,
\q2 grabljivca pohvaljuje.
\q1 
\v 4 Bezbožnik u obesti svojoj ne mari za Gospoda:
\q2 „On ne vidi”.
\q2 Nema Boga u mislima njegovim.
\q1 
\v 5 Svagda su putevi njegovi krivi;
\q2 za sudove Tvoje ne zna;
\q2 na neprijatelje svoje neće ni da gleda.
\q1 
\v 6 U srcu svom kaže: Neću posrnuti;
\q2 zlo neće doći nikad.
\q1 
\v 7 Usta su mu puna nevaljalih reči, prevare i uvrede,
\q2 pod jezikom je njegovim muka i pogibao.
\q1 
\v 8 Sedi u zasedi iza kuće;
\q2 u potaji ubija pravoga;
\q2 oči njegove vrebaju ubogoga.
\q1 
\v 9 Sedi u potaji kao lav u pećini;
\q2 sedi u zasedi da uhvati ubogoga;
\q2 hvata ubogoga uvukavši ga u mrežu svoju.
\q1 
\v 10 Pritaji se, prilegne,
\q2 i ubogi padaju u jake nokte njegove.
\q1 
\v 11 Kaže u srcu svom:
\q2 „Bog je zaboravio, okrenuo je lice svoje, neće videti nikad.”
\b
\q1 
\v 12 Ustani Gospode!
\q2 Digni ruku svoju,
\q2 ne zaboravi nevoljnih.
\q1 
\v 13 Zašto bezbožnik da ne mari za Boga
\q2 govoreći u srcu svom da Ti nećeš videti?
\q1 
\v 14 Ti vidiš;
\q2 jer gledaš uvrede i muke
\q2 i pišeš ih na ruci.
\q1 Tebi predaje sebe ubogi;
\q2 siroti Ti si pomoćnik.
\q1 
\v 15 Satri mišicu bezbožnom i zlom,
\q2 da se traži i ne nađe bezbožnost njegova.
\b
\q1 
\v 16 Gospod je car svagda, doveka,
\q2 nestaće neznabožaca sa zemlje njegove.
\q1 
\v 17 Gospode! Ti čuješ želje ništih;
\q2 utvrdi srce njihovo;
\q2 otvori uho svoje,
\q1 
\v 18 Da daš sud siroti i nevoljniku,
\q2 da prestanu goniti čoveka sa zemlje.
\c 11
\cl Psalam 11
\s1 Pritešnjen od svojih neprijatelja uzda se David u Gospoda.
\d Načelniku pevačkom. Psalam Davidov.
\q1 
\v 1 U Gospoda se uzdam;
\q2 zašto govorite duši mojoj:
\q2 „Leti u goru kao ptica;
\q1 
\v 2 Jer evo grešnici nategoše luk,
\q2 zapeše strelu svoju za tetivu,
\q2 da iz mraka streljaju prave srcem.
\q1 
\v 3 Kad su raskopani temelji,
\q2 šta će učiniti pravednik?”
\b
\q1 
\v 4 Gospod je u svetom dvoru svom,
\q2 presto je Gospodnji na nebesima;
\q1 oči Njegove gledaju;
\q2 veđe Njegove ispituju sinove čovečije.
\q1 
\v 5 Gospod ispituje pravednoga;
\q2 a bezbožnoga i kome je milo činiti zlo nenavidi duša Njegova.
\q1 
\v 6 Pustiće na bezbožnike dažd od živog ugljevlja, ognja i sumpora;
\q2 i ognjeni vetar biće im deo iz čaše;
\q1 
\v 7 Jer je Gospod pravedan, ljubi pravdu;
\q2 lice će Njegovo videti pravednici.
\c 12
\cl Psalam 12
\s1 Jadikovanje zbog nestajanja pobožnih i obesti zlih. Uzdanje u Božiju pomoć.
\d Načelniku pevačkom. Uza spravu od osam žica. Psalam Davidov.
\q1 
\v 1 Pomagaj, Gospode;
\q2 jer nesta svetih, jer je malo vernih među sinovima čovečijim
\q1 
\v 2 Laž govore jedan drugom,
\q2 usnama lažljivim govore iz srca dvoličnog.
\b
\q1 
\v 3 Istrebiće Gospod sva usta lažljiva,
\q2 jezik veličavi,
\q1 
\v 4 Ljude, koji govore: Jezikom smo jaki,
\q2 usta su naša u nas,
\q2 ko je gospodar nad nama?
\b
\q1 
\v 5 Videći stradanje nevoljnih i uzdisanje ništih,
\q2 sad ću ustati, veli Gospod,
\q2 i izbaviti onog kome zlobe
\q1 
\v 6 Reči su Gospodnje reči čiste,
\q2 srebro u vatri očišćeno od zemlje,
\q2 sedam puta pretopljeno.
\b
\q1 
\v 7 Ti ćeš nas, Gospode, odbraniti,
\q2 i sačuvati nas od roda ovog doveka.
\q1 
\v 8 Bezbožnici idu naokolo;
\q2 kad se oni podižu, sramote se sinovi čovečiji.
\c 13
\cl Psalam 13
\s1 Čežnja za dugo očekivanom pomoći pod pritiskom neprijatelja. Čvrsto uzdanje u Božiju milost.
\d Načelniku pevačkom. Psalam Davidov.
\q1 
\v 1 Dokle ćeš me, Gospode, sasvim zaboravljati?
\q2 Dokle ćeš odvraćati lice svoje od mene?
\q1 
\v 2 Dokle ću se domišljati u duši svojoj, mutiti se u srcu svom dan i noć?
\q2 Dokle će se neprijatelj moj podizati nada mnom?
\b
\q1 
\v 3 Pogledaj, usliši me, Gospode, Bože moj!
\q2 Prosvetli oči moje da ne zaspim na smrt.
\q1 
\v 4 Da ne reče neprijatelj moj: Nadvladao sam ga;
\q2 da se ne raduju koji me gone, ako posrnem.
\b
\q1 
\v 5 A ja se uzdam u milost Tvoju;
\q2 radovaće se srce moje za spasenje Tvoje.
\q1 
\v 6 Pevaću Gospodu,
\q2 koji mi dobro čini.
\c 14
\cl Psalam 14
\s1 Uzdisanje za oslobođenjem od opšte pokvarenosti ljudi.
\d Načelniku pevačkom. Psalam Davidov.
\q1 
\v 1 Reče bezumnik u srcu svom: Nema Boga;
\q2 nevaljali su, gadna su dela njihova;
\q2 nema nikoga da dobro tvori.
\b
\q1 
\v 2 Gospod pogleda s neba na sinove čovečije,
\q2 da vidi ima li koji razuman, traži li koji Boga.
\b
\q1 
\v 3 Svi su zašli, svi se pokvarili,
\q2 nema nikoga dobro da tvori, nema ni jednog.
\b
\q1 
\v 4 Zar se neće opametiti koji čine bezakonje,
\q2 jedu narod moj kao što jedu hleb,
\q2 ne prizivaju Gospoda?
\b
\q1 
\v 5 Onde će zadrhtati od straha;
\q2 jer je Gospod u rodu pravednom.
\q1 
\v 6 Smejete se onome što ubogi radi;
\q2 ali Gospod njega zaklanja.
\b
\q1 
\v 7 Ko će poslati sa Siona pomoć Izrailju?
\q2 Kad Gospod povrati zarobljeni narod svoj,
\q2 onda će se radovati Jakov i veseliće se Izrailj.
\c 15
\cl Psalam 15
\s1 Ko će ostati pred Bogom?
\d Psalam Davidov.
\q1 
\v 1 Gospode! Ko može sedeti u senici Tvojoj?
\q2 Ko može nastavati na svetoj gori Tvojoj?
\b
\q1 
\v 2 Ko hodi bez mane,
\q2 tvori pravdu,
\q2 i govori istinu iz srca svog;
\q1 
\v 3 Ko ne opada jezikom svojim,
\q2 ne čini drugom zlo,
\q2 i ne ruži bližnjeg svog;
\q1 
\v 4 Ko ne gleda onog koga je Bog odbacio,
\q2 nego poštuje one koji se boje Gospoda;
\q2 ko se kune bližnjemu pa ne poriče;
\q1 
\v 5 Ko ne daje srebro svoje na dobit,
\q2 i ne prima mito na pravoga.
\q1 Ko ovako radi, neće posrnuti doveka.
\c 16
\cl Psalam 16
\s1 Dobro nasledstvo svetih i njihovo spasenje od smrti.
\d Zapis Davidov.
\q1 
\v 1 Čuvaj me, Bože;
\q2 jer se u Te uzdam.
\q1 
\v 2 Rekoh Gospodu: Ti si Gospod moj,
\q2 nemam dobra osim Tebe.
\b
\q1 
\v 3 U svetima koji su na zemlji
\q2 i u velikima sva je uteha moja.
\b
\q1 
\v 4 Neka drugi umnožavaju idole svoje, neka trče k tuđima;
\q2 ja im neću liti krvave nalive,
\q2 niti ću metnuti imena njihova u usta svoja.
\b
\q1 
\v 5 Gospod je moj deo nasledstva i čaše;
\q2 Ti podižeš dostojanje moje.
\q1 
\v 6 Uže mi je zahvatilo prekrasna mesta,
\q2 i deo mi je moj mio.
\b
\q1 
\v 7 Blagosiljam Gospoda, koji me urazumljuje;
\q2 tome me i noću uči šta je u meni.
\q1 
\v 8 Svagda vidim pred sobom Gospoda;
\q2 On mi je s desne strane da ne posrnem.
\b
\q1 
\v 9 Toga radi raduje se srce moje,
\q2 i veseli se jezik moj,
\q2 još će se i telo moje smiriti u uzdanju;
\q1 
\v 10 Jer nećeš ostaviti dušu moju u paklu,
\q2 niti ćeš dati da Svetac Tvoj vidi trulost.
\b
\q1 
\v 11 Pokazaćeš mi put životni;
\q2 obilje je radosti pred licem Tvojim,
\q2 uteha u desnici Tvojoj doveka.
\c 17
\cl Psalam 17
\s1 Molitva pravednikova radi spasenja od lukavstva moćnih i bogatih neprijatelja.
\d Molitva Davidova.
\q1 
\v 1 Usliši, Gospode, pravdu, čuj glas moj,
\q2 primi u uši molitvu moju ne iz usta lažljivih.
\q1 
\v 2 Od lica Tvog neka izađe sud moj,
\q2 oči Tvoje neka pogledaju na pravicu.
\b
\q1 
\v 3 Ispitaj srce moje, obiđi noću;
\q2 u ognju me okušaj,
\q2 i nećeš naći nepravde moje.
\q1 
\v 4 Usta se moja ne dohvataju dela ljudskih;
\q2 radi reči usta Tvojih držim se puteva oštrih.
\q1 
\v 5 Utvrdi stope moje na stazama svojim
\q2 da ne zalaze koraci moji.
\b
\q1 
\v 6 Tebe prizivam, jer ćeš me uslišiti Bože!
\q2 Prigni k meni uho svoje, i čuj reči moje.
\q1 
\v 7 Pokaži divnu milost svoju,
\q2 koji izbavljaš one koji se u Te uzdaju
\q2 od onih koji se protive desnici Tvojoj.
\b
\q1 
\v 8 Čuvaj me kao zenicu oka;
\q2 senom krila svojih zakloni me
\q1 
\v 9 Od bezbožnika koji me napadaju,
\q2 od neprijatelja duše moje, koji su me opkolili.
\b
\q1 
\v 10 Srce svoje zatvoriše;
\q2 ustima svojim govore oholo.
\q1 
\v 11 Izagnavši me opet su oko mene;
\q2 oči su svoje uprli da me obore na zemlju.
\q1 
\v 12 Oni su kao lav koji hoće da rastrže,
\q2 i kao lavić koji sedi u potaji.
\b
\q1 
\v 13 Ustani, Gospode, preteci ih, obori ih.
\q2 Odbrani dušu moju mačem svojim od bezbožnika,
\q1 
\v 14 Rukom svojom, Gospode, od ljudi ovih,
\q2 od ljudi ovog sveta, kojima je deo ovaj život,
\q1 kojima si trbuh napunio svog bogatstva,
\q2 da će im i sinovi biti siti
\q2 i ostatak ostaviti svojoj deci.
\b
\q1 
\v 15 A ja ću u pravdi gledati lice Tvoje;
\q2 kad se probudim, biću sit od prilike Tvoje.
\c 18
\cl Psalam 18
\s1 Zahvalnost na čudnom spasenju i uzdanje u jaku Božiju desnicu.
\r (2. Samuilova 22)
\d Načelniku pevačkom. Sluge Gospodnjeg Davida, koji izgovori Gospodu reči pesme ove, kad ga izbavi Gospod iz ruku svih neprijatelja njegovih i iz ruke Saulove. On reče:
\q1 
\v 1 Ljubiću Te, Gospode, kreposti moja,
\q2 
\v 2 Gospode, Grade moj, Zaklone moj, koji se oboriti ne može, Izbavitelju moj,
\q1 Bože moj, Kamena goro, na kojoj se ne bojim zla,
\q2 Štite moj, Rože spasenja mog, Utočište moje!
\q1 
\v 3 Prizivam Gospoda, kome se klanjati valja,
\q2 i opraštam se neprijatelja svojih.
\b
\q1 
\v 4 Obuzeše me smrtne bolesti,
\q2 i potoci nevaljalih ljudi uplašiše me.
\q1 
\v 5 Opkoliše me bolesti paklene,
\q2 stegoše me zamke smrtne
\b
\q1 
\v 6 U svojoj teskobi prizvah Gospoda,
\q2 i k Bogu svom povikah;
\q1 On ču iz dvora svog glas moj,
\q2 i vika moja dođe Mu do ušiju.
\b
\q1 
\v 7 Zatrese se i pokoleba se zemlja,
\q2 zadrmaše se i pomeriše iz temelja gore,
\q2 jer se On razljuti.
\q1 
\v 8 Podiže se dim od gneva Njegovog,
\q2 iz usta Njegovih oganj, koji proždire
\q2 i živo ugljevlje odskakaše od Njega.
\q1 
\v 9 Savi nebesa i siđe.
\q2 Mrak beše pod nogama Njegovim.
\q1 
\v 10 Sede na heruvima i podiže se,
\q2 i polete na krilima vetrenim.
\q1 
\v 11 Od mraka načini sebi krov, senicu oko sebe,
\q2 od mračnih voda, oblaka vazdušnih.
\q1 
\v 12 Od sevanja pred Njim
\q2 kroz oblake Njegove udari grad i živo ugljevlje.
\b
\q1 
\v 13 Zagrme na nebesima Gospod,
\q2 i Višnji pusti glas svoj, grad i živo ugljevlje.
\q1 
\v 14 Pusti strele svoje, i razmetnu ih;
\q2 silu munja, i rasu ih.
\q1 
\v 15 I pokazaše se izvori vodeni,
\q2 i otkriše se temelji vasiljeni
\q1 od pretnje Tvoje, Gospode,
\q2 od dihanja duha gneva Tvog.
\b
\q1 
\v 16 Tada pruži s visine ruku,
\q2 uhvati me, izvuče me iz vode velike.
\q1 
\v 17 Izbavi me od neprijatelja mog silnog
\q2 i od mojih nenavidnika, kad behu jači od mene.
\q1 
\v 18 Ustaše na me u dan nevolje moje,
\q2 ali mi Gospod bi potpora.
\q1 
\v 19 Izvede me na prostrano mesto,
\q2 i izbavi me, jer sam Mu mio.
\b
\q1 
\v 20 Dade mi Gospod po pravdi mojoj,
\q2 i za čistotu ruku mojih dariva me.
\q1 
\v 21 Jer se držah puteva Gospodnjih,
\q2 i ne odmetnuh se Boga svog,
\q1 
\v 22 Nego su svi zakoni Njegovi preda mnom,
\q2 i zapovesti Njegove ne uklanjam od sebe.
\q1 
\v 23 Bih Mu veran,
\q2 i čuvah se od bezakonja svog.
\q1 
\v 24 Dade mi Gospod po pravdi mojoj,
\q2 po čistoti ruku mojih pred očima Njegovim.
\b
\q1 
\v 25 Sa svetima postupaš sveto,
\q2 s čovekom vernim verno,
\q1 
\v 26 S čistim čisto,
\q2 a s nevaljalim nasuprot njemu.
\q1 
\v 27 Jer Ti pomažeš ljudima nevoljnim,
\q2 a oči ponosite ponižavaš.
\q1 
\v 28 Ti raspaljuješ videlo moje;
\q2 Gospod moj prosvetljuje tamu moju.
\q1 
\v 29 S Tobom razbijam vojsku,
\q2 i s Bogom svojim skačem preko zida.
\q1 
\v 30 Put je Gospodnji veran,
\q2 reč Gospodnja čista.
\q2 On je štit svima koji se u Nj uzdaju.
\b
\q1 
\v 31 Jer ko je Bog osim Gospoda,
\q2 i ko je odbrana osim Boga našeg?
\q1 
\v 32 Ovaj Bog opasuje me snagom,
\q2 i čini mi veran put.
\q1 
\v 33 Daje mi noge kao u jelena,
\q2 i na visine stavlja me.
\q1 
\v 34 Uči ruke moje boju,
\q2 i mišice moje čini da su luk od bronze.
\q1 
\v 35 Ti mi daješ štit spasenja svog;
\q2 desnica Tvoja drži me,
\q2 i milost Tvoja čini me velika.
\q1 
\v 36 Ti širiš korak moj,
\q2 te se ne spotiču noge moje.
\q1 
\v 37 Teram neprijatelje svoje i stižem ih,
\q2 i ne vraćam se dok ih ne istrebim.
\q1 
\v 38 Obaram ih, i ne mogu ustati,
\q2 padaju pod noge moje.
\q1 
\v 39 Jer me Ti opasuješ snagom za boj,
\q2 i koji ustanu na me, obaraš ih preda mnom.
\q1 
\v 40 Neprijatelja mojih pleći Ti mi obraćaš,
\q2 i potirem nenavidnike svoje.
\q1 
\v 41 Oni viču, ali nemaju pomagača,
\q2 ka Gospodu, ali ih On ne sluša.
\q1 
\v 42 Rasipam ih kao prah po vetru,
\q2 kao blato po ulicama gazim ih.
\b
\q1 
\v 43 Ti me izbavljaš od bune narodne,
\q2 postavljaš me da sam glava tuđim plemenima;
\q2 narod kog ne poznavah, služi mi.
\q1 
\v 44 Po samom čuvenju slušaju me,
\q2 tuđini pokorni su mi.
\q1 
\v 45 Tuđini blede,
\q2 drhću u gradovima svojim.
\b
\q1 
\v 46 Živ je Gospod,
\q2 i da je blagosloven branič moj!
\q2 Da se uzvisi Bog spasenja mog,
\q1 
\v 47 Bog, koji mi daje osvetu,
\q2 i pokorava mi narode,
\q1 
\v 48 Koji me izbavlja od neprijatelja,
\q2 podiže me nad one koji ustaju na me
\q2 i od čoveka žestokog izbavlja me!
\b
\q1 
\v 49 Toga radi hvalim Te, Gospode, pred narodima,
\q2 i pevam imenu Tvom,
\q1 
\v 50 Koji slavno izbavljaš cara svog,
\q2 i činiš milost pomazaniku svom Davidu
\q2 i nasleđu njegovom doveka.
\c 19
\cl Psalam 19
\s1 Krasota Božija u prirodi i rečima njegovim. Molitva radi oproštenja greha i čuvanja od nepravde.
\d Načelniku pevačkom. Psalam Davidov.
\q1 
\v 1 Nebesa kazuju slavu Božju,
\q2 i dela ruku Njegovih glasi svod nebeski.
\q1 
\v 2 Dan danu dokazuje,
\q2 i noć noći javlja.
\q1 
\v 3 Nema jezika, niti ima govora,
\q2 gde se ne bi čuo glas njihov.
\q1 
\v 4 Po svoj zemlji ide kazivanje njihovo
\q2 i reči njihove na kraj vasiljene.
\q1 Suncu je postavio stan na njima;
\q2 
\v 5 I ono izlazi kao ženik iz ložnice svoje,
\q2 kao junak veselo teče putem.
\q1 
\v 6 Izlazak mu je nakraj neba, i hod mu do kraja njegovog;
\q2 i niko nije sakriven od toplote njegove.
\b
\q1 
\v 7 Zakon je Gospodnji savršen,
\q2 krepi dušu;
\q1 svedočanstvo je Gospodnje verno,
\q2 daje mudrost neveštome.
\q1 
\v 8 Naredbe su Gospodnje pravedne,
\q2 vesele srce.
\q1 Zapovest je Gospodnja svetla,
\q2 prosvetljuje oči.
\q1 
\v 9 Strah je Gospodnji čist,
\q2 ostaje doveka.
\q1 Sudovi su Njegovi istiniti,
\q2 pravedni svikoliki.
\q1 
\v 10 Bolji su od zlata i dragog kamenja,
\q2 slađi od meda koji teče iz saća.
\q1 
\v 11 I slugu Tvog oni su prosvetlili;
\q2 ko ih drži ima veliku platu.
\b
\q1 
\v 12 Ko će znati sve svoje pogreške?
\q2 Očisti me i od tajnih;
\q1 
\v 13 I od voljnih sačuvaj slugu svog,
\q2 da ne ovladaju mnome.
\q1 Tada ću biti savršen
\q2 i čist od velikog prestupa.
\b
\q1 
\v 14 Da su Mu reči usta mojih ugodne,
\q2 i pomisao srca mog
\q2 pred Tobom, Gospode, kreposti moja i Izbavitelju moj!
\c 20
\cl Psalam 20
\s1 Narodna molitva za cara u doba ratne nevolje.
\d Načelniku pevačkom. Psalam Davidov.
\q1 
\v 1 Da te usliši Gospod u dan žalosni,
\q2 da te zaštiti ime Boga Jakovljevog.
\q1 
\v 2 Da ti pošalje pomoć iz svetinje,
\q2 i sa Siona da te potkrepi.
\q1 
\v 3 Da se opomene svih prinosa tvojih,
\q2 i žrtva tvoja paljenica da se nađe pretila.
\b
\q1 
\v 4 Da ti da Gospod po srcu tvom;
\q2 šta god počneš, da ti izvrši.
\q1 
\v 5 Radovaćemo se za spasenje tvoje,
\q2 i u ime Boga svog podignućemo zastavu.
\q1 Da ispuni Gospod sve molbe tvoje.
\b
\q1 
\v 6 Sad vidim da Gospod čuva pomazanika svog;
\q2 sluša ga sa svetog neba svog;
\q2 jaka je desnica Njegova, koja spasava.
\q1 
\v 7 Jedni se hvale kolima, drugi konjima,
\q2 a mi imenom Gospoda Boga svog.
\q1 
\v 8 Oni posrću i padaju,
\q2 a mi stojimo i ne kolebamo se.
\b
\q1 
\v 9 Gospode! Pomozi caru,
\q2 i usliši nas kad Te zovemo.
\c 21
\cl Psalam 21
\s1 Pesma zahvalnosti Bogu na dobročinstvima i pobedama darovanim caru.
\d Načelniku pevačkom. Psalam Davidov.
\q1 
\v 1 Gospode! S Tvoje se sile veseli car;
\q2 i kako mu je velika radost što Ti pomažeš!
\q1 
\v 2 Šta mu je srce želelo, dao si mu,
\q2 i molitve usta njegovih nisi odbio.
\q1 
\v 3 Jer si ga dočekao blagoslovima milosnim,
\q2 metnuo si mu na glavu venac od dragog kamenja.
\q1 
\v 4 Molio Te je za život
\q2 i dao si mu da mu se produže dani doveka.
\q1 
\v 5 Velika je slava njegova Tvojom pomoću;
\q2 slavu si i krasotu metnuo na nj.
\q1 
\v 6 Dao si mu blagoslove doveka,
\q2 razveselio si ga radošću lica svog.
\q1 
\v 7 Jer se car uzda u Gospoda i u milost Višnjeg;
\q2 i ne koleba se.
\b
\q1 
\v 8 Naći će ruka Tvoja sve neprijatelje Tvoje,
\q2 naći će desnica Tvoja one koji mrze na Tebe.
\q1 
\v 9 Učinićeš ih kao peć zažarenu,
\q2 kad se razgneviš;
\q1 gnev će ih Gospodnji progutati,
\q2 i oganj će ih proždreti.
\q1 
\v 10 Rod njihov istrebićeš sa zemlje,
\q2 i seme njihovo između sinova čovečijih;
\q1 
\v 11 Jer podigoše na Tebe zlo,
\q2 smisliše i ne mogoše izvršiti.
\q1 
\v 12 Jer ćeš ih metnuti za belegu,
\q2 iz lukova svojih pustićeš strele u lice njihovo.
\b
\q1 
\v 13 Podigni se Gospode, silom svojom;
\q2 mi ćemo pevati i slaviti jakost Tvoju.
\c 22
\cl Psalam 22
\s1 Stradanje i slava pravednikova.
\s2 (Psalam Hristov na krstu)
\d Načelniku pevačkom. Kad zora zabeli. Psalam Davidov.
\q1 
\v 1 Bože, Bože moj! Zašto si me ostavio
\q2 udaljivši se od spasenja mog,
\q2 od reči vike moje?
\q1 
\v 2 Bože moj! Vičem danju, a Ti me ne slušaš,
\q2 i noću ali nemam mira.
\b
\q1 
\v 3 Sveti, koji živiš u pohvalama Izrailjevim!
\q1 
\v 4 U Tebe se uzdaše oci naši,
\q2 uzdaše se, i Ti si ih izbavljao.
\q1 
\v 5 Tebe prizivaše, i spasavaše se;
\q2 u Tebe se uzdaše, i ne ostaše u sramoti.
\b
\q1 
\v 6 A ja sam crv, a ne čovek;
\q2 podsmeh ljudima i rug narodu.
\q1 
\v 7 Koji me vide, svi mi se rugaju,
\q2 razvaljuju usta, mašu glavom,
\q1 
\v 8 I govore: oslonio se na Gospoda, neka mu pomogne;
\q2 neka ga izbavi, ako ga miluje.
\b
\q1 
\v 9 Ta, Ti si me izvadio iz utrobe;
\q2 Ti si me umirio na sisi matere moje.
\q1 
\v 10 Za Tobom pristajem od rođenja,
\q2 od utrobe matere moje Ti si Bog moj.
\q1 
\v 11 Ne udaljuj se od mene;
\q2 jer je nevolja blizu, a nema pomoćnika.
\b
\q1 
\v 12 Opteče me mnoštvo telaca;
\q2 jaki volovi vasanski opkoliše me;
\q1 
\v 13 Razvališe na me usta svoja.
\q2 Lav je gladan i riče.
\b
\q1 
\v 14 Kao voda razlih se;
\q2 rasuše se sve kosti moje;
\q1 srce moje posta kao vosak,
\q2 rastopilo se u meni.
\q1 
\v 15 Sasuši se kao crep krepost moja,
\q2 i jezik moj prionu za grlo,
\q2 i u prah smrtni mećeš me.
\b
\q1 
\v 16 Opkoliše me psi mnogi;
\q2 četa zlikovaca ide oko mene,
\q2 probodoše ruke moje i noge moje.
\q1 
\v 17 Mogao bih izbrojati sve kosti svoje.
\q2 Oni gledaju, i od mene načiniše stvar za gledanje.
\q1 
\v 18 Dele haljine moje među sobom,
\q2 i za dolamu moju bacaju žreb.
\b
\q1 
\v 19 Ali Ti, Gospode, ne udaljuj se.
\q2 Silo moja, pohitaj mi u pomoć.
\q1 
\v 20 Izbavi od mača dušu moju,
\q2 od psa jedinicu moju.
\q1 
\v 21 Sačuvaj me od usta lavovih,
\q2 i od rogova bivolovih,
\q1 čuvši, izbavi me.
\b
\q1 
\v 22 Kazujem ime Tvoje braći;
\q2 usred skupštine hvaliću Te.
\q1 
\v 23 Koji se bojite Gospoda, hvalite Ga.
\q2 Sve seme Jakovljevo! Poštuj Ga.
\q2 Boj Ga se, sve seme Izrailjevo!
\q1 
\v 24 Jer se ne ogluši molitve ništeg niti je odbi;
\q2 ne odvrati od njega lice svoje,
\q2 nego ga usliši kad Ga zazva.
\b
\q1 
\v 25 Tebe ću hvaliti na skupštini velikoj;
\q2 zavete svoje svršiću pred onima koji se Njega boje.
\q1 
\v 26 Neka jedu ubogi i nasite se,
\q2 i neka hvale Gospoda koji Ga traže;
\q2 živo da bude srce vaše doveka.
\b
\q1 
\v 27 Opomenuće se i obratiće se ka Gospodu svi krajevi zemaljski,
\q2 i pokloniće se pred Njim sva plemena neznabožačka.
\q1 
\v 28 Jer je Gospodnje carstvo;
\q2 On vlada narodima.
\b
\q1 
\v 29 Ješće i pokloniće se svi pretili na zemlji;
\q2 pred Njim će pasti svi koji silaze u prah,
\q2 koji ne mogu sačuvati dušu svoju u životu.
\q1 
\v 30 Seme će njihovo služiti Njemu.
\q2 Kazivaće se za Gospoda rodu potonjem.
\q1 
\v 31 Doći će, i kazivaće pravdu Njegovu
\q2 ljudima njegovim, koji će se roditi;
\q2 jer je On učinio ovo.
\c 23
\cl Psalam 23
\s1 Pastir dobri.
\d Psalam Davidov.
\q1 
\v 1 Gospod je pastir moj,
\q2 ništa mi neće nedostajati.
\q1 
\v 2 Na zelenoj paši pase me,
\q2 vodi me na tihu vodu.
\q1 
\v 3 Dušu moju oporavlja,
\q2 vodi me stazama pravednim
\q2 imena radi svog.
\b
\q1 
\v 4 Da pođem i dolinom sena smrtnoga,
\q2 neću se bojati zla;
\q1 jer si Ti sa mnom;
\q2 štap Tvoj i palica Tvoja teši me.
\b
\q1 
\v 5 Postavio si preda mnom trpezu
\q2 na vidiku neprijateljima mojim;
\q1 namazao si uljem glavu moju,
\q2 i čaša je moja prepuna.
\q1 
\v 6 Da! Dobrota i milost Tvoja pratiće me
\q2 u sve dane života mog,
\q1 i ja ću nastavati u domu Gospodnjem zadugo.
\c 24
\cl Psalam 24
\s1 Dolazak cara slave.
\d Psalam Davidov.
\q1 
\v 1 Gospodnja je zemlja i šta je god u njoj,
\q2 vasiljena i sve što živi na njoj.
\q1 
\v 2 Jer je On na morima osnova,
\q2 i posred reka utvrdi je.
\b
\q1 
\v 3 Ko će izaći na goru Gospodnju?
\q2 I ko će stati na svetom mestu njegovom?
\q1 
\v 4 U koga su čiste ruke
\q2 i srce bezazleno,
\q1 ko ne izriče ime Njegovo uzalud
\q2 i ne kune se lažno.
\q1 
\v 5 On će dobiti blagoslov od Gospoda,
\q2 i milost od Boga, spasa svog.
\q1 
\v 6 Takav je rod onih koji Ga traže,
\q2 i koji su radi stajati pred licem Tvojim, Bože Jakovljev!
\b
\q1 
\v 7 Vrata! Uzvisite vrhove svoje,
\q2 uzvisite se vrata večna!
\q2 Ide car slave.
\q1 
\v 8 Ko je taj car slave?
\q2 Gospod krepak i silan,
\q2 Gospod silan u boju.
\q1 
\v 9 Vrata! Uzvisite vrhove svoje,
\q2 uzvisite se vrata večna!
\q2 Ide car slave.
\q1 
\v 10 Ko je taj car slave?
\q2 Gospod nad vojskama! On je car slave.
\c 25
\cl Psalam 25
\s1 Molitva za Božiju zaštitu, milostivo vođenje i oproštenje grehova.
\d Psalam Davidov.
\q1 
\v 1 K Tebi, Gospode, podižem dušu svoju.
\q2 
\v 2 Bože moj! U Tebe se uzdam;
\q1 ne daj da se osramotim,
\q2 da mi se ne svete neprijatelji moji.
\q1 
\v 3 I koji se god u Te uzdaju, neće se osramotiti;
\q2 osramotiće se oni koji se odmeću od Tebe besputno.
\b
\q1 
\v 4 Pokaži mi, Gospode, puteve svoje,
\q2 nauči me hoditi stazama Tvojim.
\q1 
\v 5 Uputi me istini svojoj, i nauči me;
\q2 jer si Ti Bog spasenja mog,
\q2 Tebi se nadam svaki dan.
\b
\q1 
\v 6 Opomeni se milosrđa svog, Gospode,
\q2 i milosti svoje;
\q2 jer su otkako je veka.
\q1 
\v 7 Grehova mladosti moje, i mojih prestupa ne pominji;
\q2 po milosti svojoj pomeni mene,
\q2 radi dobrote svoje, Gospode!
\b
\q1 
\v 8 Dobar je i pravedan Gospod;
\q2 toga radi pokazuje grešnicima put.
\q1 
\v 9 Upućuje krotke istini,
\q2 uči krotke hoditi putem Njegovim.
\q1 
\v 10 Svi su putevi Gospodnji milost i istina
\q2 onima koji drže zavet Njegov i otkrivenje Njegovo.
\b
\q1 
\v 11 Radi imena svog, Gospode, oprosti greh moj,
\q2 jer je velik.
\q1 
\v 12 Koji se čovek boji Gospoda?
\q2 On će mu pokazati koji put da izabere.
\q1 
\v 13 Duša će njegova u dobru počivati,
\q2 i seme će njegovo vladati zemljom.
\q1 
\v 14 Tajna je Gospodnja u onih koji Ga se boje,
\q2 i zavet svoj javlja im.
\q1 
\v 15 Oči su mi svagda upravljene ka Gospodu,
\q2 jer On izvlači iz zamke noge moje.
\b
\q1 
\v 16 Pogledaj me i smiluj se na me,
\q2 jer sam inokosan i nevoljnik.
\q1 
\v 17 Nek se raširi stisnuto srce moje,
\q2 iz teskobe moje izvadi me.
\q1 
\v 18 Vidi jade moje i muku moju,
\q2 i oprosti mi sve grehove moje.
\b
\q1 
\v 19 Pogledaj neprijatelje moje kako ih je mnogo
\q2 i kakvom me pakosnom nenavišću nenavide.
\q1 
\v 20 Sačuvaj dušu moju i izbavi me;
\q2 ne daj da se osramotim, jer se u Tebe uzdam.
\q1 
\v 21 Bezazlenost i pravda neka me sačuva,
\q2 jer se u Tebe uzdam.
\b
\q1 
\v 22 Izbavi, Bože, Izrailja
\q2 od svih nevolja njegovih.
\c 26
\cl Psalam 26
\s1 Molitva za spasenje bezazlenoga.
\d Psalam Davidov.
\q1 
\v 1 Sudi mi, Gospode, jer u prostoti svojoj hodim
\q2 i u Gospoda se uzdam;
\q2 neću se pokolebati.
\q1 
\v 2 Ispitaj me, Gospode, i iskušaj me;
\q2 pretopi šta je u meni i srce moje.
\q1 
\v 3 Jer je milost Tvoja pred očima mojim,
\q2 i hodim u istini Tvojoj.
\b
\q1 
\v 4 Ne sedim s bezumnicima,
\q2 i s lukavima se ne mešam.
\q1 
\v 5 Nenavidim društvo bezakoničko,
\q2 i s bezbožnicima ne sedim.
\b
\q1 
\v 6 Umivam pravdom ruke svoje,
\q2 i idem oko žrtvenika Tvog, Gospode,
\q1 
\v 7 Da razglašujem hvalu Tvoju
\q2 i kazujem sva čudesa Tvoja.
\b
\q1 
\v 8 Gospode! Omileo mi je stan doma Tvog,
\q2 i mesto naselja slave Tvoje.
\q1 
\v 9 Nemoj dušu moju pogubiti,
\q2 ni život moj s krvopiocima,
\q1 
\v 10 Kojima je zločinstvo u rukama,
\q2 i kojima je desnica puna mita.
\b
\q1 
\v 11 A ja hodim u prostoti svojoj,
\q2 izbavi me, i smiluj se na me.
\q1 
\v 12 Noga moja stoji na pravom putu;
\q2 na skupštinama ću blagosiljati Gospoda.
\c 27
\cl Psalam 27
\s1 I u ratnoj nevolji David traži Božiju zaštitu.
\d Psalam Davidov.
\q1 
\v 1 Gospod je videlo moje i spasenje moje;
\q2 koga da se bojim?
\q1 Gospod je krepost života mog;
\q2 koga da se strašim?
\b
\q1 
\v 2 Ako navale na me zlikovci
\q2 da pojedu telo moje,
\q1 protivnici i neprijatelji moji,
\q2 spotaći će se i pašće.
\b
\q1 
\v 3 Ako protiv mene vojska u logor stane,
\q2 neće se uplašiti srce moje;
\q1 ako se na me rat digne,
\q2 ja se ni onda neću bojati.
\b
\q1 
\v 4 Za jedno samo molim Gospoda,
\q2 samo to ištem,
\q1 da živim u domu Gospodnjem
\q2 sve dane života svog,
\q1 da gledam krasotu Gospodnju
\q2 i ranim u crkvu Njegovu.
\b
\q1 
\v 5 Jer bi me sakrio u kolibi svojoj
\q2 u zlo doba;
\q1 sklonio bi me pod krovom šatora svog;
\q2 na kamenu goru popeo bi me.
\b
\q1 
\v 6 Tada bih podigao glavu svoju
\q2 pred neprijateljima koji bi me opkolili;
\q1 prineo bih u Njegovom šatoru žrtvu hvale;
\q2 zapevao bih i hvalio Gospoda.
\b
\q1 
\v 7 Čuj, Gospode, glas moj, Tebe prizivam,
\q2 smiluj se na me i usliši me.
\q1 
\v 8 Srce moje govori pred Tobom što si rekao: „Tražite lice moje”.
\q2 Tražim lice Tvoje, Gospode!
\q1 
\v 9 Nemoj odvratiti od mene lice svoje,
\q2 nemoj u gnevu ostaviti slugu svog;
\q1 budi Pomoćnik moj; nemoj me odbiti,
\q2 i nemoj me ostaviti, Bože, Spasitelju moj!
\q1 
\v 10 Jer otac moj i mati moja ostaviše me;
\q2 ali Gospod neka me prihvati.
\b
\q1 
\v 11 Uputi me, Gospode, na put svoj
\q2 i vodi me pravom stazom
\q2 poradi onih koji me vrebaju.
\q1 
\v 12 Nemoj me dati na volju neprijateljima mojim;
\q2 jer ustaše na me lažni svedoci;
\q2 ali zloba govori sama protiv sebe.
\b
\q1 
\v 13 Verujem da ću videti dobrotu Gospodnju na zemlji živih.
\q1 
\v 14 Uzdaj se u Gospoda, budi slobodan;
\q2 neka bude srce tvoje krepko, uzdaj se u Gospoda.
\c 28
\cl Psalam 28
\s1 Molitva za spasenje od grešnika. Zahvalnost na uslišenju molitve.
\d Psalam Davidov.
\q1 
\v 1 K Tebi, Gospode, vičem;
\q2 grade moj, nemoj mi ćutati,
\q1 da ne bih, ako zaćutiš,
\q2 bio kao oni koji odlaze u grob.
\q1 
\v 2 Čuj molitveni glas moj, kad vapim k Tebi,
\q2 kad dižem ruke svoje k svetoj crkvi Tvojoj.
\b
\q1 
\v 3 Nemoj me zahvatiti s grešnicima,
\q2 i s onima koji čine nepravdu,
\q1 koji s bližnjima svojim mirno govore,
\q2 a u srcu im je zlo.
\q1 
\v 4 Podaj im, Gospode, po delima njihovim,
\q2 po zlom postupanju njihovom;
\q1 po delima ruku njihovih podaj im,
\q2 podaj im šta su zaslužili.
\q1 
\v 5 Jer ne paze na dela Gospodnja,
\q2 i na dela ruku Njegovih.
\q2 Da ih razori i ne sazida.
\b
\q1 
\v 6 Da je blagosloven Gospod,
\q2 jer usliši glas moljenja mog!
\q1 
\v 7 Gospod je krepost moja i štit moj;
\q2 u Njega se pouzda srce moje,
\q2 i On mi pomože.
\q1 Zato se veseli srce moje,
\q2 i pesmom svojom slavim Ga.
\b
\q1 
\v 8 Gospod je krepost naroda svog,
\q2 i obrana koja spasava pomazanika Njegovog.
\q1 
\v 9 Spasi narod svoj,
\q2 blagoslovi dostojanje svoje;
\q2 spasi ih i uzdiži ih doveka.
\c 29
\cl Psalam 29
\s1 Slava Božija u nepogodi.
\d Psalam Davidov.
\q1 
\v 1 Dajte Gospodu, sinovi Božji, dajte Gospodu slavu i čast.
\q2 
\v 2 Dajte Gospodu slavu imena Njegovog.
\q2 Poklonite se Gospodu u svetoj krasoti.
\b
\q1 
\v 3 Glas je Gospodnji nad vodom,
\q2 Bog slave grmi,
\q2 Gospod je nad vodom velikom.
\q1 
\v 4 Glas je Gospodnji silan,
\q2 glas je Gospodnji slavan.
\b
\q1 
\v 5 Glas Gospodnji lomi kedre,
\q2 Gospod lomi kedre livanske.
\q1 
\v 6 Kao tele skaču od Njega;
\q2 Livan i Sirion kao mlad bivo.
\b
\q1 
\v 7 Glas Gospodnji sipa plamen ognjeni.
\q1 
\v 8 Glas Gospodnji potresa pustinju,
\q2 potresa Gospod pustinju Kades.
\b
\q1 
\v 9 Glas Gospodnji oprašta košute bremena,
\q2 i sa šuma skida odelo;
\q2 i u crkvi Njegovoj sve govori o slavi Njegovoj.
\b
\q1 
\v 10 Gospod je sedeo nad potopom,
\q2 i sedeće Gospod kao car uvek.
\q1 
\v 11 Gospod će dati silu narodu svom,
\q2 Gospod će blagosloviti narod svoj mirom.
\c 30
\cl Psalam 30
\s1 Zahvalna pesma Davidova zbog spasenja njegovog života.
\d Psalam Davidov. Pesma kad se osveti dom.
\q1 
\v 1 Uzvišavaću Te, Gospode, jer si me oteo,
\q2 i nisi dao neprijateljima mojim da mi se svete.
\q1 
\v 2 Gospode, Bože moj!
\q2 Zavikah k Tebi, i iscelio si me.
\q1 
\v 3 Gospode! Izveo si iz pakla dušu moju,
\q2 i oživeo si me da ne siđem u grob.
\b
\q1 
\v 4 Pojte Gospodu, sveci Njegovi,
\q2 i slavite sveto ime Njegovo.
\q1 
\v 5 Gnev je Njegov za trenuće oka,
\q2 a do života milost Njegova,
\q1 večerom dolazi plač, a jutrom radost.
\b
\q1 
\v 6 I ja rekoh u dobru svom:
\q2 Neću posrnuti doveka.
\q1 
\v 7 Ti htede, Gospode, te gora moja stajaše tvrdo.
\q2 Ti odvrati lice svoje, i ja se smetoh.
\b
\q1 
\v 8 Tada Tebe, Gospode, zazivah,
\q2 i Gospoda molih:
\q1 
\v 9 „Kakva je korist od krvi moje, da siđem u grob?
\q2 Hoće li Te prah slaviti ili kazivati istinu Tvoju?
\q1 
\v 10 Čuj, Gospode, i smiluj se na me;
\q2 Gospode budi mi pomoćnik.”
\b
\q1 
\v 11 I Ti promeni plač moj na radost,
\q2 skide s mene vreću, opasa me veseljem.
\q1 
\v 12 Zato će Ti pevati slava moja
\q2 i neće umuknuti;
\q1 Gospode, Bože moj!
\q2 Doveka ću Te hvaliti.
\c 31
\cl Psalam 31
\s1 Koji se u Gospodu uzda neće dopasti sramote.
\d Načelniku pevačkom. Psalam Davidov.
\q1 
\v 1 U Tebe se, Gospode, uzdam;
\q2 nemoj me ostaviti pod sramotom doveka,
\q2 po pravdi svojoj izbavi me.
\q1 
\v 2 Prigni k meni uho svoje,
\q2 pohitaj, pomozi mi.
\q1 Budi mi kameni grad, tvrda ograda,
\q2 gde bih se spasao.
\b
\q1 
\v 3 Jer si Ti kamena gora moja i ograda moja,
\q2 imena svog radi vodi me i upravljaj mnom.
\q1 
\v 4 Izvadi me iz mreže koju mi tajno zamestiše;
\q2 jer si Ti krepost moja.
\q1 
\v 5 U Tvoju ruku predajem duh svoj;
\q2 izbavljao si me, Gospode, Bože istiniti!
\b
\q1 
\v 6 Nenavidim one koji poštuju propadljive idole;
\q2 ja se u Gospoda uzdam.
\q1 
\v 7 Radovaću se i veseliti se o milosti Tvojoj,
\q2 kad pogledaš na moju muku,
\q2 poznaš tugu duše moje,
\q1 
\v 8 Ne daš me u ruku neprijatelju,
\q2 postaviš noge moje na prostranom mestu.
\b
\q1 
\v 9 Smiluj se na me, Gospode, jer me je tuga;
\q2 od jada iznemože oko moje, duša moja i srce moje;
\q1 
\v 10 Iščile u žalosti život moj,
\q2 i godine moje u uzdisanju;
\q1 oslabi od muke krepost moja,
\q2 i kosti moje sasahnuše.
\b
\q1 
\v 11 Od mnoštva neprijatelja svojih postadoh podsmeh i susedima svojim,
\q2 i strašilo znancima svojim;
\q2 koji me vide na ulici beže od mene.
\q1 
\v 12 Zaboravljen sam kao mrtav, nema me u srcima;
\q2 ja sam kao razbijen sud.
\q1 
\v 13 Jer slušam grdnju od mnogih,
\q2 od svuda strah,
\q2 kad se dogovaraju na me, misle iščupati dušu moju.
\b
\q1 
\v 14 A ja se, Gospode, u Tebe uzdam
\q2 i velim: Ti si Bog moj.
\q1 
\v 15 U Tvojoj su ruci dani moji;
\q2 otmi me iz ruku neprijatelja mojih,
\q2 i od onih, koji me gone.
\q1 
\v 16 Pokaži svetlo lice svoje sluzi svom;
\q2 spasi me milošću svojom.
\q1 
\v 17 Gospode! Nemoj me ostaviti pod sramotom; jer Tebe prizivam.
\q2 Nek se posrame bezbožnici,
\q2 neka zamuknu i padnu u pakao.
\q1 
\v 18 Neka oneme usta lažljiva,
\q2 koja govore na pravednika obesno, oholo i s porugom.
\b
\q1 
\v 19 Kako je mnogo u Tebe dobra,
\q2 koje čuvaš za one koji Te se boje,
\q2 i koje daješ onima koji se u Te uzdaju pred sinovima čovečijim!
\q1 
\v 20 Sakrivaš ih pod krov lica svog od buna ljudskih;
\q2 sklanjaš ih pod sen od svadljivih jezika.
\b
\q1 
\v 21 Da je blagosloven Gospod,
\q2 što mi pokaza divnu milost
\q2 kao da me uvede u tvrd grad!
\q1 
\v 22 Ja rekoh u smetnji svojoj: Odbačen sam od očiju Tvojih;
\q2 ali Ti ču molitveni glas moj kad Te prizvah.
\b
\q1 
\v 23 Ljubite Gospoda svi sveti Njegovi;
\q2 Gospod drži veru;
\q2 i uvršeno vraća onima koji postupaju oholo.
\q1 
\v 24 Budite slobodni, i neka bude jako srce vaše,
\q2 svi koji se u Gospoda uzdate.
\c 32
\cl Psalam 32
\s1 Blaženstvo zbog oproštene krivice.
\d Nauk Davidov.
\q1 
\v 1 Blago onome, kome je oproštena krivica,
\q2 kome je greh pokriven.
\q1 
\v 2 Blago čoveku, kome Gospod ne prima grehe
\q2 i u čijem duhu nema lukavstva.
\b
\q1 
\v 3 Kad ćutah, posahnuše kosti moje od uzdisanja mog po vas dan.
\q1 
\v 4 Jer dan i noć tištaše me ruka Tvoja;
\q2 nesta soka u meni kao na letnjoj pripeci.
\b
\q1 
\v 5 Greh svoj kazah Tebi,
\q2 i krivice svoje ne zatajih;
\q1 rekoh: Ispovedam Gospodu prestupe svoje;
\q2 i Ti skide s mene krivicu greha mog.
\b
\q1 
\v 6 Zato neka Ti se moli svaki svetac, kad se možeš naći;
\q2 i onda potop velike vode neće ga stignuti.
\q1 
\v 7 Ti si zaklon moj, Ti me čuvaš od teskobe;
\q2 okružavaš me radostima u izbavljanju.
\b
\q1 
\v 8 Urazumiću te, i pokazaću ti put kojim da ideš;
\q2 savetovaću te, oko je moje na tebi.
\q1 
\v 9 Nemojte biti kao konj, kao mazga bez razuma,
\q2 kojima uzdom i žvalama valja obuzdati gubicu,
\q2 kad ne idu k Tebi.
\b
\q1 
\v 10 Mnogo muke ima bezbožnik,
\q2 a koji se uzda u Gospoda, oko Njega je milost.
\q1 
\v 11 Radujte se o Gospodu, i pevajte, pravednici;
\q2 veselite se svi koji ste pravog srca.
\c 33
\cl Psalam 33
\s1 Hvala svemogućoj milosti Božijoj.
\q1 
\v 1 Veselite se pravednici pred Gospodom;
\q2 pravednima dolikuje slaviti.
\q1 
\v 2 Slavite Gospoda guslama,
\q2 udarajte Mu u psaltir od deset žica.
\q1 
\v 3 Pevajte Mu pesmu novu,
\q2 složno udarajte podvikujući;
\b
\q1 
\v 4 Jer je prava reč Gospodnja,
\q2 i svako delo Njegovo istinito.
\q1 
\v 5 On ljubi pravdu i sud,
\q2 dobrote je Gospodnje puna zemlja.
\b
\q1 
\v 6 Rečju Gospodnjom nebesa se stvoriše,
\q2 i duhom usta Njegovih sva vojska njihova.
\q1 
\v 7 Kao u gomilu sabra vodu morsku,
\q2 i propasti metnu u spreme.
\b
\q1 
\v 8 Nek se boji Gospoda sva zemlja,
\q2 i neka strepi pred Njim sve što živi po vasiljeni;
\q1 
\v 9 Jer On reče, i postade;
\q2 On zapovedi, i pokaza se.
\b
\q1 
\v 10 Gospod razbija namere neznabošcima,
\q2 uništava pomisli narodima.
\q1 
\v 11 Namera je Gospodnja tvrda doveka,
\q2 misli srca njegova od kolena na koleno.
\q1 
\v 12 Blago narodu, kome je Bog Gospod,
\q2 plemenu, koje je On izabrao sebi za nasleđe.
\b
\q1 
\v 13 S neba gleda Gospod,
\q2 vidi sve sinove ljudske;
\q1 
\v 14 S prestola, na kome sedi,
\q2 pogleda na sve koji žive na zemlji.
\q1 
\v 15 On je stvorio sva srca njihova,
\q2 On i zna sva dela njihova.
\q1 
\v 16 Neće pomoći caru velika sila,
\q2 neće zaštititi jakoga velika snaga;
\q1 
\v 17 Nije u konju uzdanje da će pomoći;
\q2 ako mu je i velika snaga, neće izbaviti.
\b
\q1 
\v 18 Gle, oko je Gospodnje na onima koji Ga se boje,
\q2 i na onima koji čekaju milost Njegovu.
\q1 
\v 19 On će dušu njihovu izbaviti od smrti,
\q2 i prehraniti ih u gladne godine.
\b
\q1 
\v 20 Duša se naša uzda u Gospoda;
\q2 On je pomoć naša i štit naš.
\q1 
\v 21 O Njemu se veseli srce naše;
\q2 jer se u sveto ime Njegovo uzdamo.
\q1 
\v 22 Da bude milost Tvoja, Gospode, na nama,
\q2 kao što se uzdamo u Tebe.
\c 34
\cl Psalam 34
\s1 Potsticanje da se slavi pomoć Božija i da se čovek uči strahu Gospodnjem.
\r (1. Samuilova 21:13)
\d Psalam Davidov, kad se pred Avimelehom učini lud, i on ga otera, te otide.
\q1 
\v 1 Blagosiljam Gospoda u svako doba,
\q2 hvala je Njegova svagda u ustima mojim.
\q1 
\v 2 Gospodom se hvali duša moja;
\q2 neka čuju koji stradaju, pa neka se raduju.
\q1 
\v 3 Veličajte Gospoda sa mnom,
\q2 uzvišujmo ime Njegovo zajedno.
\b
\q1 
\v 4 Tražih Gospoda, i ču me,
\q2 i svih nevolja mojih oprosti me.
\q1 
\v 5 Koji u Njega gledaju prosvetljuju se,
\q2 i lica se njihova neće postideti.
\q1 
\v 6 Ovaj stradalac zavika,
\q2 i Gospod ga ču,
\q2 i oprosti ga svih nevolja njegovih.
\q1 
\v 7 Anđeli Gospodnji stanom stoje
\q2 oko onih koji se Njega boje,
\q2 i izbavljaju ih.
\b
\q1 
\v 8 Ispitajte i vidite kako je dobar Gospod;
\q2 blago čoveku koji se uzda u Nj.
\q1 
\v 9 Bojte se Gospoda, sveti Njegovi;
\q2 jer koji se Njega boje, njima nema oskudice.
\q1 
\v 10 Lavovi su ubogi i gladni,
\q2 a koji traže Gospoda,
\q2 ne nedostaje im nijednog dobra.
\b
\q1 
\v 11 Hodite, deco, poslušajte me;
\q2 naučiću vas strahu Gospodnjem.
\q1 
\v 12 Koji čovek želi život,
\q2 ljubi dane da bi video dobro?
\q1 
\v 13 Ustavljaj jezik svoj oda zla,
\q2 i usta svoja od prevarne reči.
\q1 
\v 14 Kloni se oda zla, i čini dobro,
\q2 traži mir i idi za njim.
\b
\q1 
\v 15 Oči su Gospodnje obraćene na pravednike,
\q2 i uši Njegove na jauk njihov.
\q1 
\v 16 Ali je strašno lice Gospodnje za one koji čine zlo,
\q2 da bi istrebio na zemlji spomen njihov.
\q1 
\v 17 Viču pravedni, i Gospod ih čuje,
\q2 i izbavlja ih od svih nevolja njihovih.
\q1 
\v 18 Gospod je blizu onih koji su skrušenog srca,
\q2 i pomaže onima koji su smernog duha.
\b
\q1 
\v 19 Mnogo nevolje ima pravednik,
\q2 ali ga od svih izbavlja Gospod.
\q1 
\v 20 Čuva Gospod sve kosti njegove,
\q2 ni jedna se od njih neće slomiti.
\q1 
\v 21 Bezbožnika ubiće zlo,
\q2 i koji nenavide pravednika prevariće se.
\q1 
\v 22 Gospod iskupljuje dušu sluga svojih,
\q2 i koji se god u Njega uzdaju, neće se prevariti.
\c 35
\cl Psalam 35
\s1 Molitva za spasenje od pakosnih neprijatelja.
\d Psalam Davidov.
\q1 
\v 1 Gospode! Budi suparnik suparnicima mojim;
\q2 udri one koji udaraju na me.
\q1 
\v 2 Uzmi oružje i štit,
\q2 i digni se meni u pomoć.
\q1 
\v 3 Potegni koplje,
\q2 i preseci put onima koji me gone,
\q2 reci duši mojoj: Ja sam spasenje tvoje.
\b
\q1 
\v 4 Neka se postide i posrame koji traže dušu moju;
\q2 neka se odbiju natrag i postide koji mi zlo hoće.
\q1 
\v 5 Neka budu kao prah pred vetrom,
\q2 i anđeo Gospodnji neka ih progoni.
\q1 
\v 6 Neka bude put njihov taman i klizav,
\q2 i anđeo Gospodnji neka ih tera.
\b
\q1 
\v 7 Jer nizašta zastreše mrežom jamu za mene,
\q2 nizašta iskopaše jamu duši mojoj.
\q1 
\v 8 Neka dođe na njega pogibao nenadna,
\q2 i mreža koju je namestio neka ulovi njega,
\q2 neka on u nju padne na pogibao.
\b
\q1 
\v 9 A duša će se moja radovati o Gospodu,
\q2 i veseliće se za pomoć Njegovu.
\q1 
\v 10 Sve će kosti moje reći: Gospode! Ko je kao Ti,
\q2 koji izbavljaš stradalca od onog koji mu dosađuje,
\q2 i ništega i ubogoga od onog koji ga upropašćuje?
\b
\q1 
\v 11 Ustaše na me lažni svedoci;
\q2 šta ne znam, za ono me pitaju.
\q1 
\v 12 Plaćaju mi zlo za dobro,
\q2 i sirotovanje duši mojoj.
\q1 
\v 13 Ja se u bolesti njihovoj oblačih u vreću,
\q2 mučih postom dušu svoju,
\q2 i molitva se moja vraćaše u prsima mojim.
\q1 
\v 14 Kao prijatelj, kao brat postupah;
\q2 bejah setan i s oborenom glavom
\q2 kao onaj koji za materom žali.
\b
\q1 
\v 15 A oni se raduju kad se ja spotaknem,
\q2 i kupe se, kupe se na me,
\q1 zadaju rane, ne znam zašto,
\q2 čupaju i ne prestaju.
\q1 
\v 16 S nevaljalim i podrugljivim besposličarima
\q2 škrguću na me zubima svojim.
\b
\q1 
\v 17 Gospode! Hoćeš li dugo gledati?
\q2 Otmi dušu moju od napadanja njihovog,
\q2 od ovih lavova jedinicu moju.
\q1 
\v 18 Priznaću Te u saboru velikom,
\q2 usred mnogog naroda hvaliću Te.
\b
\q1 
\v 19 Da mi se ne bi svetili koji mi zlobe nepravedno,
\q2 i namigivali očima koji mrze na me nizašta.
\q1 
\v 20 Jer oni ne govore o miru,
\q2 nego na mirne na zemlji izmišljaju lažne stvari.
\q1 
\v 21 Razvaljuju na me usta svoja,
\q2 i govore: Dobro! Dobro! Vidi oko naše.
\b
\q1 
\v 22 Vidiš, Gospode! Nemoj ćutati;
\q2 Gospode! Nemoj odstupiti od mene.
\q1 
\v 23 Probudi se, ustani na sud moj,
\q2 Bože moj i Gospode, i na parnicu moju.
\q1 
\v 24 Sudi mi po pravdi svojoj, Gospode, Bože moj,
\q2 da mi se ne svete.
\q1 
\v 25 Ne daj da govore u srcu svom: Dobro! To smo hteli!
\q2 Ne daj da govore: Proždresmo ga.
\b
\q1 
\v 26 Nek se postide i posrame
\q2 svi koji se raduju zlu mom,
\q1 nek se obuku u stid i u sram
\q2 koji se razmeću nada mnom.
\b
\q1 
\v 27 Neka se raduju i vesele koji mi žele pravdu,
\q2 i govore jednako: Velik Gospod,
\q2 koji želi mira sluzi svom!
\q1 
\v 28 I moj će jezik kazivati pravdu Tvoju,
\q2 i hvalu Tebi svaki dan.
\c 36
\cl Psalam 36
\s1 Žalba na bezbožnike. Milost Božija prema pravednicima.
\d Načelniku pevačkom. Sluge Gospodnjeg Davida.
\q1 
\v 1 Bezakoniku je bezbožna reč u srcu;
\q2 nema straha Božijeg pred očima njegovim.
\q1 
\v 2 Ali laže sebi u oči,
\q2 mesto da prizna svoje bezakonje i omrzne na nj.
\q1 
\v 3 Reči su usta njegovih nepravda i lukavstvo,
\q2 neće da se opameti da tvori dobro.
\q1 
\v 4 Bezakonje smišlja na postelji svojoj,
\q2 stoji na putu rđavom,
\q2 zlo mu nije mrsko.
\b
\q1 
\v 5 Gospode! Do neba je milost Tvoja,
\q2 i istina Tvoja do oblaka.
\q1 
\v 6 Pravda je Tvoja kao gore Božije,
\q2 sudovi Tvoji bezdana velika;
\q2 ljude i stoku Ti čuvaš, Gospode!
\b
\q1 
\v 7 Kako je dragocena milost Tvoja, Bože!
\q2 Sinovi ljudski u senu krila Tvojih ne boje se.
\q1 
\v 8 Hrane se od izobila doma Tvog,
\q2 i iz potoka sladosti svojih Ti ih napajaš.
\q1 
\v 9 Jer je u Tebe izvor životu,
\q2 Tvojom svetlošću vidimo svetlost.
\b
\q1 
\v 10 Raširi milost svoju na one koji Te znaju,
\q2 i pravdu svoju na dobra srca.
\q1 
\v 11 Ne daj da stane na mene noga ohola,
\q2 i ruka bezbožnička da me zaljulja.
\q1 
\v 12 Onamo neka padnu koji čine bezakonje,
\q2 neka se stropoštaju i ne mogu ustati.
\c 37
\cl Psalam 37
\s1 Sreća bezbožnika ne treba da žesti pravednike.
\d Psalam Davidov.
\q1 
\v 1 Nemoj se žestiti gledajući nevaljale,
\q2 nemoj zavideti onima koji čine bezakonje.
\q1 
\v 2 Jer se kao trava brzo kose,
\q2 i kao zeleno bilje venu.
\b
\q1 
\v 3 Uzdaj se u Gospoda i tvori dobro;
\q2 živi na zemlji i hrani istinu.
\q1 
\v 4 Teši se Gospodom,
\q2 i učiniće ti šta ti srce želi.
\b
\q1 
\v 5 Predaj Gospodu put svoj,
\q2 i uzdaj se u Njega, On će učiniti.
\q1 
\v 6 I izvešće kao videlo pravdu tvoju,
\q2 i pravicu tvoju kao podne.
\b
\q1 
\v 7 Osloni se na Gospoda, i čekaj Ga.
\q2 Nemoj se žestiti gledajući koga gde napreduje na putu svom,
\q2 čoveka, koji radi šta namisli.
\b
\q1 
\v 8 Utišaj gnev, i ostavi jarost;
\q2 nemoj se dražiti da zlo činiš.
\q1 
\v 9 Jer će se istrebiti koji čine zlo,
\q2 a koji čekaju Gospoda naslediće zemlju.
\b
\q1 
\v 10 Još malo, pa neće biti bezbožnika;
\q2 pogledaćeš na mesto njegovo, a njega nema.
\q1 
\v 11 A smerni će naslediti zemlju,
\q2 i naslađivaće se množinom mira.
\b
\q1 
\v 12 Zlo misli bezbožnik pravedniku,
\q2 i škrguće na nj zubima svojim.
\q1 
\v 13 Ali mu se Gospod smeje,
\q2 jer vidi da se primiče dan njegov.
\b
\q1 
\v 14 Mač potežu bezbožnici, zapinju luk svoj,
\q2 da obore ubogoga i ništega
\q2 i pokolju one koji idu pravim putem.
\q1 
\v 15 Mač će njihov udariti u njihovo srce,
\q2 i lukovi njihovi polomiće se.
\b
\q1 
\v 16 Bolje je malo u pravednika
\q2 nego bogatstvo mnogih bezbožnika.
\q1 
\v 17 Jer će se mišice bezbožnicima potrti,
\q2 a pravednike utvrđuje Gospod.
\b
\q1 
\v 18 Zna Gospod dane bezazlenima,
\q2 i deo njihov traje doveka.
\q1 
\v 19 Neće se postideti u zlo doba,
\q2 u dane gladne biće siti.
\b
\q1 
\v 20 A bezbožnici ginu,
\q2 i neprijatelji Gospodnji kao lepota šumska prolaze,
\q2 kao dim prolaze.
\b
\q1 
\v 21 Bezbožnik uzaima i ne vraća,
\q2 a pravednik poklanja i daje.
\q1 
\v 22 Jer koje On blagoslovi, oni naslede zemlju,
\q2 a koje On prokune, oni se istrebe.
\b
\q1 
\v 23 Gospod utvrđuje korake svakog čoveka
\q2 i mio Mu je put njegov.
\q1 
\v 24 Kad posrne da padne, neće pasti,
\q2 jer ga Gospod drži za ruku.
\b
\q1 
\v 25 Bejah mlad i ostareh,
\q2 i ne videh pravednika ostavljenog,
\q2 ni dece njegove da prose hleba.
\q1 
\v 26 Svaki dan poklanja i daje u zajam,
\q2 i na nasleđu je njegovom blagoslov.
\b
\q1 
\v 27 Uklanjaj se oda zla, i čini dobro,
\q2 i živi doveka.
\q1 
\v 28 Jer Gospod ljubi pravedni sud,
\q2 i ne ostavlja svece svoje; uvek se oni čuvaju;
\q2 a pleme će se bezbožničko istrebiti.
\q1 
\v 29 Pravednici će naslediti zemlju,
\q2 i živeće na njoj doveka.
\b
\q1 
\v 30 Usta pravednikova govore mudrost,
\q2 i jezik njegov kazuje istinu.
\q1 
\v 31 Zakon je Boga njegovog njemu u srcu,
\q2 stopala se njegova ne spotiču.
\b
\q1 
\v 32 Bezbožnik vreba pravednika,
\q2 i traži da ga ubije;
\q1 
\v 33 Ali ga Gospod neće pustiti u ruke njegove,
\q2 niti će dati da ga okrive kad se stanu suditi.
\b
\q1 
\v 34 Čekaj Gospoda i drži se puta Njegovog,
\q2 i On će te postaviti da vladaš zemljom;
\q2 videćeš kako će se istrebiti bezbožnici.
\b
\q1 
\v 35 Videh bezbožnika strašnog
\q2 koji se raširivaše kao granato drvo;
\q1 
\v 36 Ali prođe, i evo nema ga;
\q2 tražim ga i ne nahodim.
\b
\q1 
\v 37 Hrani čistotu i pazi pravdu,
\q2 jer će u čoveka mirnog ostati nasleđe.
\q1 
\v 38 A bezakonika će nestati sasvim;
\q2 nasleđe će se bezbožničko zatrti.
\b
\q1 
\v 39 Od Gospoda je spasenje pravednicima;
\q2 On je krepost njihova u nevolji.
\q1 
\v 40 Gospod će im pomoći, i izbaviće ih;
\q2 izbaviće ih od bezbožnika,
\q2 i sačuvaće ih, jer se u Njega uzdaju.
\c 38
\cl Psalam 38
\s1 Jadikovanje Davidovo zbog teških iskušenja u borbi sa bolešću i neprijateljima.
\d Psalam Davidov. Za spomen.
\q1 
\v 1 Gospode! Nemoj me karati u gnevu svom,
\q2 niti me nakaziti u jarosti svojoj.
\q1 
\v 2 Jer strele Tvoje ustreliše me,
\q2 i ruka me Tvoja tišti.
\b
\q1 
\v 3 Nema zdravog mesta na telu mom od gneva Tvog;
\q2 nema mira u kostima mojim od greha mog.
\q1 
\v 4 Jer bezakonja moja izađoše vrh glave moje,
\q2 kao teško breme otežaše mi.
\b
\q1 
\v 5 Usmrdeše se i zagnojiše se rane moje
\q2 od bezumlja mog.
\q1 
\v 6 Zgrčio sam se i pogurio veoma,
\q2 sav dan idem setan;
\q1 
\v 7 Jer sam iznutra pun ognja,
\q2 i nema zdravog mesta na telu mom.
\q1 
\v 8 Iznemogoh i veoma oslabih,
\q2 ričem od trzanja srca svog.
\b
\q1 
\v 9 Gospode! Pred Tobom su sve želje moje,
\q2 i uzdisanje moje nije od Tebe sakriveno.
\q1 
\v 10 Srce moje jako kuca,
\q2 ostavi me snaga moja,
\q2 i vid očiju mojih, ni njega mi nema.
\q1 
\v 11 Drugovi moji i prijatelji moji
\q2 videći rane moje odstupiše,
\q2 daleko stoje bližnji moji.
\b
\q1 
\v 12 Koji traže dušu moju nameštaju zamku,
\q2 i koji su mi zlu radi, govore o pogibli
\q2 i po sav dan misle o prevari.
\b
\q1 
\v 13 A ja kao gluv ne čujem
\q2 i kao nem koji ne otvara usta svoja.
\q1 
\v 14 Ja sam kao čovek koji ne čuje
\q2 ili nema u ustima svojim pravdanja.
\b
\q1 
\v 15 Jer Tebe, Gospode, čekam,
\q2 Ti odgovaraj za mene, Gospode, Bože moj!
\q1 
\v 16 Jer rekoh: Da mi se ne svete,
\q2 i da se ne razmeću nada mnom,
\q2 kad se spotakne noga moja.
\b
\q1 
\v 17 Jer sam gotov pasti,
\q2 i tuga je moja svagda sa mnom.
\q1 
\v 18 Priznajem krivicu svoju,
\q2 i tužim radi greha svog.
\q1 
\v 19 Neprijatelji moji žive, jaki su,
\q2 i sila ih ima što me nenavide na pravdi.
\q1 
\v 20 Koji mi vraćaju zlo za dobro,
\q2 neprijatelji su mi zato što sam pristao za dobrim.
\b
\q1 
\v 21 Nemoj me ostaviti, Gospode, Bože moj!
\q2 Nemoj se udaljiti od mene.
\q1 
\v 22 Pohitaj u pomoć meni,
\q2 Gospode, Spasitelju moj!
\c 39
\cl Psalam 39
\s1 Odluka da strpljivo ćuti videći ništavilo čovečije. Molba za Gospodnju utehu.
\d Načelniku pevačkom Iditunu. Psalam Davidov.
\q1 
\v 1 Rekoh: Čuvaću se na putevima svojim
\q2 da ne zgrešim jezikom svojim;
\q1 zauzdavaću usta svoja,
\q2 dok je bezbožnik preda mnom.
\q1 
\v 2 Bejah nem i glas ne pustih; ćutah i o dobru.
\q2 Ali se tuga moja podiže,
\q1 
\v 3 Zapali se srce moje u meni,
\q2 u mislima mojim razgore se oganj;
\q2 progovorih jezikom svojim:
\b
\q1 
\v 4 Kaži mi, Gospode, kraj moj,
\q2 i dokle će trajati dani moji?
\q2 Da znam kako sam ništa.
\q1 
\v 5 Evo s pedi dao si mi dane,
\q2 i vek je moj kao ništa pred Tobom.
\q2 Baš je ništa svaki čovek živ.
\q1 
\v 6 Baš hodi čovek kao utvara;
\q2 baš se uzalud kida, sabira,
\q2 a ne zna kome će dopasti.
\b
\q1 
\v 7 Pa šta da čekam, Gospode?
\q2 Nada je moja u Tebi.
\q1 
\v 8 Iz svega bezakonja mog izbavi me,
\q2 ne daj me bezumnome na podsmeh.
\q1 
\v 9 Nem sam, neću otvoriti usta svojih;
\q2 jer si me Ti udario.
\q1 
\v 10 Olakšaj mi udarac svoj,
\q2 silna ruka Tvoja ubi me.
\q1 
\v 11 Ako ćeš karati čoveka za prestupe,
\q2 rastočiće se kao od moljaca krasota njegova.
\q2 Baš je ništa svaki čovek.
\b
\q1 
\v 12 Slušaj molitvu moju, Gospode,
\q2 i čuj jauk moj.
\q1 Gledajući suze moje nemoj ćutati.
\q2 Jer sam gost u Tebe
\q2 i došljak kao i svi stari moji.
\q1 
\v 13 Nemoj me više gnevno gledati,
\q2 pa ću odahnuti pre nego otidem
\q2 i više me ne bude.
\c 40
\cl Psalam 40
\s1 Spaseni pravednik zahvaljuje Bogu; pokornost i molba.
\d Načelniku pevačkom. Davidov psalam.
\q1 
\v 1 Dugo čekah Gospoda,
\q2 i saže se k meni, i ču viku moju.
\q1 
\v 2 Izvadi me iz jame, koja buči, i iz gliba,
\q2 i postavi na kamen noge moje, i utvrdi stope moje.
\q1 
\v 3 I metnu u usta moja pesmu novu,
\q2 hvalu Bogu našem.
\q1 Vide mnogi, i počinju se bojati Gospoda,
\q2 i uzdati se u Njega.
\b
\q1 
\v 4 Blago onome koji na Gospoda stavlja nadanje svoje,
\q2 i ne obraća se oholima i onim koji teže na laž.
\q1 
\v 5 Mnoga su čudesa Tvoja,
\q2 koja si učinio Gospode, Bože moj,
\q2 i mnoge su misli Tvoje s nama.
\q1 Nema Ti ravna.
\q2 Hteo bih javljati i kazivati,
\q2 ali im broja nema.
\b
\q1 
\v 6 Žrtve i darove nećeš;
\q2 Ti si mi uši otvorio;
\q2 žrtvu paljenicu i koja se za greh prinosi ne tražiš.
\q1 
\v 7 I po tome rekoh: Evo idem,
\q2 kao što je u knjizi pisano za mene;
\q1 
\v 8 Hoću činiti volju Tvoju, Bože moj,
\q2 i zakon je Tvoj meni u srcu.
\b
\q1 
\v 9 Kazujem pravdu na saboru velikom;
\q2 evo, usta svojih ne ustavljam;
\q2 Gospode, Ti znaš.
\q1 
\v 10 Pravde Tvoje ne sakrivam u srcu svom,
\q2 kazujem vernost Tvoju i spasenje Tvoje;
\q1 i ne tajim milosti Tvoje i istine Tvoje od sabora velikog.
\b
\q1 
\v 11 Gospode, nemoj zatvoriti srca svog od mene;
\q2 milost Tvoja i istina Tvoja jednako neka me čuvaju.
\q1 
\v 12 Jer me opkoliše zla nebrojena;
\q2 stigoše me nepravde moje,
\q2 da ne mogu gledati;
\q1 ima ih više nego kose na glavi mojoj,
\q2 srce me moje ostavi.
\b
\q1 
\v 13 Gospode, voljan budi izbaviti me,
\q2 Gospode, pohitaj mi u pomoć.
\q1 
\v 14 Nek se postide i posrame
\q2 svi koji traže pogibao duši mojoj!
\q1 Nek se vrate natrag
\q2 i postide koji mi žele zlo.
\q1 
\v 15 Nek se povrate u smetnji svojoj
\q2 koji mi govore: Ha! Ha!
\b
\q1 
\v 16 Neka se teše i vesele Tobom
\q2 svi koji traže Tebe Gospode,
\q1 i koji ljube spasenje Tvoje,
\q2 neka jednako govore: Velik Gospod!
\q1 
\v 17 Ja sam nesrećan i ništ,
\q2 neka se Gospod postara za me!
\q1 Ti si pomoć moja i Izbavitelj moj,
\q2 Bože moj, ne časi.
\c 41
\cl Psalam 41
\s1 Jadikovanje u bolesti zbog zluradih neprijatelja i nevernih prijatelja.
\d Načelniku pevačkom. Psalam Davidov.
\q1 
\v 1 Blago onome koji razume ništega!
\q2 Gospod će ga izbaviti u zli dan.
\q1 
\v 2 Gospod će ga sačuvati i poživeće ga;
\q2 biće blažen na zemlji.
\q2 Nećeš ga dati na volju neprijateljima njegovim.
\q1 
\v 3 Gospod će ga ukrepiti bolnog na odru.
\q2 Sasvim menjaš postelju njegovu u bolesti njegovoj.
\b
\q1 
\v 4 Ja vičem: Gospode! Smiluj se na me,
\q2 isceli dušu moju, sagreših Ti.
\q1 
\v 5 Neprijatelji moji govore zlobno za mene:
\q2 „Kad će umreti, i ime njegovo poginuti?”
\q1 
\v 6 I ako ko dođe da me vidi, laska;
\q2 srce njegovo slaže u sebi nepravdu, i otišavši kazuje.
\q1 
\v 7 Šapću o meni među sobom neprijatelji moji,
\q2 i misle mi zlo:
\b
\q1 
\v 8 „Zla stvar dođe na njega;
\q2 legao je, neće više ustati.”
\q1 
\v 9 I čovek mira mog,
\q2 u kog se uzdah,
\q1 koji jeđaše hleb moj,
\q2 podiže na me petu.
\q1 
\v 10 Ali Ti, Gospode, smiluj se na me,
\q2 i podigni me; a ja ću im vratiti.
\b
\q1 
\v 11 Po tome ću poznati da sam Ti mio,
\q2 ako se ne uzraduje neprijatelj moj nada mnom.
\q1 
\v 12 A mene celog sačuvaj,
\q2 i daj mi da stojim pred licem Tvojim doveka.
\b
\q1 
\v 13 Blagosloven Bog Izrailjev od veka do veka.
\q2 Amin, amin.
\c 42
\cl Psalam 42
\s1 Žudnja za svetinjom u tuđoj zemlji.
\d Načelniku pevačkom. Nauk sinova Korejevih.
\q1 
\v 1 Kao što košuta traži potoke,
\q2 tako duša moja traži Tebe, Bože!
\q1 
\v 2 Žedna je duša moja Boga, Boga Živoga,
\q2 kad ću doći i pokazati se licu Božijem?
\q1 
\v 3 Suze su mi hleb dan i noć,
\q2 kad mi svaki dan govore: Gde je Bog tvoj?
\q1 
\v 4 Duša se moja proliva
\q2 kad se opominjem kako sam hodio sred mnogog ljudstva,
\q1 stupao u dom Božji,
\q2 a ljudstvo praznujući pevaše i podvikivaše.
\b
\q1 
\v 5 Što si klonula, dušo moja,
\q2 i što si žalosna?
\q1 Uzdaj se u Boga; jer ću Ga još slaviti,
\q2 Spasitelja mog i Boga mog.
\b
\q1 
\v 6 Klonula je u meni duša
\q2 zato što Te pominjem u zemlji jordanskoj,
\q2 na Ermonu, na gori maloj.
\b
\q1 
\v 7 Bezdana bezdanu doziva glasom slapova Tvojih;
\q2 sve vode Tvoje i vali Tvoji na mene navališe.
\q1 
\v 8 Danju je javljao Gospod milost svoju,
\q2 a noću Mu je pesma u mene,
\q2 molitva Bogu života mog.
\q1 
\v 9 Reći ću Bogu, gradu svom:
\q2 Zašto si me zaboravio?
\q2 Zašto idem setan od pakosti neprijateljeve?
\q1 
\v 10 Koji mi pakoste, prebijajući kosti moje,
\q2 rugaju mi se govoreći mi svaki dan: Gde ti je Bog?
\b
\q1 
\v 11 Što si klonula, dušo moja,
\q2 i što si žalosna?
\q1 Uzdaj se u Boga; jer ću Ga još slaviti,
\q2 Spasitelja mog i Boga mog.
\c 43
\cl Psalam 43
\s1 Nastavak.
\q1 
\v 1 Sudi mi, Bože,
\q2 i raspravi parbu moju s narodom rđavim!
\q2 Od čoveka nepravednog i lukavog izbavi me.
\q1 
\v 2 Jer si Ti Bog kreposti moje; zašto si me odbacio?
\q2 Zašto idem setan od pakosti neprijateljeve?
\b
\q1 
\v 3 Pošlji videlo svoje i istinu svoju,
\q2 neka me vode, i izvedu na svetu goru Tvoju i u dvorove Tvoje.
\q1 
\v 4 Onda ću pristupiti k žrtveniku Božijem,
\q2 k Bogu radosti i veselja svog,
\q2 i uz gusle slaviću Te, Bože, Bože moj!
\b
\q1 
\v 5 Što si klonula, dušo moja,
\q2 i što si žalosna?
\q1 Uzdaj se u Boga; jer ću Ga još slaviti,
\q2 Spasitelja mog i Boga mog.
\c 44
\cl Psalam 44
\s1 Jadikovanje što je Bog ostavio narod svoj.
\d Načelniku pevačkom. Nauk sinova Korejevih.
\q1 
\v 1 Bože, svojim ušima slušasmo,
\q2 oci nam naši pripovedaše
\q2 delo koje si učinio u njihovo vreme, u staro vreme.
\q1 
\v 2 Rukom svojom izgnao si narode, a njih posadio;
\q2 iskorenio si plemena, a njih namnožio.
\q1 
\v 3 Jer ne zadobiše zemlje svojim mačem,
\q2 niti im mišica njihova pomože,
\q1 nego Tvoja desnica i Tvoja mišica,
\q2 i svetlost lica Tvog,
\q2 jer Ti behu omileli.
\b
\q1 
\v 4 Bože, care moj, Ti si onaj isti,
\q2 pošlji pomoć Jakovu!
\q1 
\v 5 S Tobom ćemo izbosti neprijatelje svoje,
\q2 i s imenom Tvojim izgazićemo one koji ustaju na nas.
\q1 
\v 6 Jer se ne uzdam u luk svoj,
\q2 niti će mi mač moj pomoći.
\q1 
\v 7 Nego ćeš nas Ti izbaviti od neprijatelja naših,
\q2 i nenavidnike naše posramićeš.
\q1 
\v 8 Bogom ćemo se hvaliti svaki dan,
\q2 i ime Tvoje slavićemo doveka.
\b
\q1 
\v 9 Ali sad si nas povrgao i posramio,
\q2 i ne ideš s vojskom našom.
\q1 
\v 10 Obraćaš nas te bežimo ispred neprijatelja,
\q2 i neprijatelji nas naši haraju.
\q1 
\v 11 Dao si nas kao ovce da nas jedu,
\q2 i po narodima rasejao si nas.
\q1 
\v 12 U bescenje si prodao narod svoj,
\q2 i nisi mu podigao cene.
\q1 
\v 13 Dao si nas na podsmeh susedima našim,
\q2 da nam se rugaju i sramote nas koji žive oko nas.
\q1 
\v 14 Načinio si od nas priču u naroda,
\q2 gledajući nas mašu glavom tuđinci.
\q1 
\v 15 Svaki je dan sramota moja preda mnom,
\q2 i stid je popao lice moje.
\q1 
\v 16 Od reči podsmevačevih i rugačevih,
\q2 i od pogleda neprijateljevih i osvetljivčevih.
\b
\q1 
\v 17 Sve ovo snađe nas;
\q2 ali ne zaboravismo Tebe,
\q2 niti prestupismo zavet Tvoj.
\q1 
\v 18 Ne odstupi natrag srce naše,
\q2 i stope naše ne zađoše s puta Tvog.
\q1 
\v 19 Kad si nas bio u zemlji zmajevskoj,
\q2 i pokrivao nas senom smrtnim,
\q1 
\v 20 Onda da bejasmo zaboravili ime Boga svog
\q2 i podigli ruke svoje k Bogu tuđem,
\q1 
\v 21 Ne bi li Bog iznašao to?
\q2 Jer On zna tajne u srcu.
\q1 
\v 22 A ubijaju nas za Tebe svaki dan;
\q2 s nama postupaju kao s ovcama klanicama.
\b
\q1 
\v 23 Ustani, što spavaš, Gospode!
\q2 Probudi se, nemoj odbaciti zasvagda.
\q1 
\v 24 Zašto kriješ lice svoje?
\q2 Zaboravljaš nevolju i muku našu?
\q1 
\v 25 Duša naša pade u prah,
\q2 telo je naše bačeno na zemlju.
\q1 
\v 26 Ustani, pomoći naša,
\q2 i izbavi nas radi milosti svoje.
\c 45
\cl Psalam 45
\s1 U slavu Božijeg pomazanika i njegove neveste.
\d Načelniku pevačkom. Uz muzikalnu spravu sosan. Nauk sinova Korejevih. Pesma ljubavna.
\q1 
\v 1 Teče iz srca mog reč dobra;
\q2 rekoh: Delo je moje za cara;
\q2 jezik je moj trska hitrog pisara.
\b
\q1 
\v 2 Ti si najlepši između sinova ljudskih,
\q2 blagodat teče iz usta tvojih,
\q2 jer te je blagoslovio Bog doveka.
\q1 
\v 3 Pripaši, junače, uz bedro svoje
\q2 mač svoj, čast svoju i krasotu svoju.
\b
\q1 
\v 4 I tako okićen pohitaj,
\q2 sedi na kola za istinu i krotku pravdu,
\q2 i desnica će tvoja pokazati čudesa.
\q1 
\v 5 Oštre su strele tvoje;
\q2 narodi će pasti pod vlast tvoju;
\q2 prostreliće srca neprijatelja carevih.
\b
\q1 
\v 6 Presto je Tvoj, Bože, večan i nepokolebljiv;
\q2 skiptar je carstva Tvog skiptar pravice.
\q1 
\v 7 Ljubiš pravdu i mrziš na bezakonje;
\q2 toga radi pomaza te, Bože, Bog Tvoj uljem radosti
\q2 više nego drugove Tvoje.
\q1 
\v 8 Sve haljine tvoje mirišu smirnom, alojom i kasijom.
\q2 Koji žive u dvorima od minijske slonove kosti,
\q2 one te vesele.
\q1 
\v 9 Carske kćeri dvore te;
\q2 s desne ti strane stoji carica u ofirskom zlatu.
\b
\q1 
\v 10 Čuj, kćeri, pogledaj i obrati k meni uho svoje,
\q2 zaboravi narod svoj i dom oca svog.
\q1 
\v 11 I caru će omileti lepota tvoja;
\q2 jer je On Gospod tvoj, i Njemu se pokloni.
\q1 
\v 12 Kći Tirova doći će s darovima,
\q2 najbogatiji u narodu tebe će moliti.
\b
\q1 
\v 13 Sva je ukrašena kći careva iznutra,
\q2 haljina joj je zlatom iskićena.
\q1 
\v 14 U vezenoj haljini vode je k caru;
\q2 za njom vode k tebi devojke, druge njene.
\q1 
\v 15 Vode ih veselo i radosno,
\q2 ulaze u dvor carev.
\b
\q1 
\v 16 Mesto otaca tvojih biće sinovi tvoji,
\q2 postavićeš ih knezovima po svoj zemlji.
\q1 
\v 17 Učiniću da se ne zaboravlja ime tvoje od kolena na koleno;
\q2 potom će te slaviti narodi va vek veka.
\c 46
\cl Psalam 46
\s1 Gospod je naša čvrsta tvrdinja.
\d Načelniku pevačkom. Korejevih sinova. Uz muzikalnu spravu alamot. Pesma.
\q1 
\v 1 Bog nam je utočište i sila,
\q2 pomoćnik, koji se u nevoljama brzo nalazi.
\q1 
\v 2 Zato se nećemo bojati,
\q2 da bi se zemlja pomestila,
\q2 i gore se prevalile u srce morima.
\q1 
\v 3 Neka buči i kipi voda njihova,
\q2 nek se planine tresu od vala njihovih;
\b
\q1 
\v 4 Potoci vesele grad Božji,
\q2 sveti stan Višnjeg.
\q1 
\v 5 Bog je usred njega, neće se pomestiti,
\q2 Bog mu pomaže od zore.
\q1 
\v 6 Uzbučaše narodi, zadrmaše se carstva;
\q2 ali On pusti glas svoj i zemlja se rastapaše.
\q1 
\v 7 Gospod nad vojskama s nama je,
\q2 branič je naš Bog Jakovljev.
\b
\q1 
\v 8 Hodite i vidite dela Gospoda,
\q2 koji učini čudesa na zemlji,
\q1 
\v 9 Prekide ratove do kraja zemlje,
\q2 luk prebi, koplje slomi, i kola sažeže ognjem.
\q1 
\v 10 Utolite i poznajte da sam ja Bog;
\q2 ja sam uzvišen po narodima,
\q2 uzvišen na zemlji.
\q1 
\v 11 Gospod nad vojskama s nama je,
\q2 branič je naš Bog Jakovljev.
\c 47
\cl Psalam 47
\s1 Bog je car.
\d Načelniku pevačkom. Sinova Korejevih. Psalam.
\q1 
\v 1 Svi narodi, zapljeskajte rukama,
\q2 pokliknite Bogu glasom radosnim.
\q1 
\v 2 Jer je Višnji Gospod strašan,
\q2 car veliki nad svom zemljom.
\q1 
\v 3 Pokori nam narode i plemena pod noge naše.
\q1 
\v 4 Izbra nam dostojanje naše,
\q2 krasotu Jakova, koji Mu omile.
\b
\q1 
\v 5 Ide Bog uz podvikivanje,
\q2 Gospod uz glas trubni.
\q1 
\v 6 Pojte Bogu, pojte;
\q2 pojte caru našem, pojte;
\q1 
\v 7 Jer je Bog car od sve zemlje,
\q2 pojte pesmu.
\b
\q1 
\v 8 Bog caruje nad narodima;
\q2 Bog sedi na svetom prestolu svom.
\q1 
\v 9 Knezovi narodni sastavljaju se s narodom Boga Avramovog.
\q2 Jer su štitovi zemaljski Božiji.
\q1 Da je uzvišen!
\c 48
\cl Psalam 48
\s1 Radost Siona zbog Božije pomoći u ratnoj nevolji.
\d Pesma. Psalam sinova Korejevih.
\q1 
\v 1 Velik je Gospod
\q2 i slavan veoma u gradu Boga našeg,
\q2 na svetoj gori svojoj.
\q1 
\v 2 Prekrasna je visina,
\q2 uteha svoj zemlji gora Sion,
\q1 na severnoj strani njenoj
\q2 grad cara velikog.
\q1 
\v 3 Bog u dvorima njegovim
\q2 zna se da je branič.
\b
\q1 
\v 4 Jer, gle, carevi se zemaljski sabraše,
\q2 ali prođoše svi.
\q1 
\v 5 Videše i začudiše se,
\q2 prepadoše se i pobegoše.
\q1 
\v 6 Trepet obuze ih onde,
\q2 mučiše se kao porodilja.
\q1 
\v 7 Vetrom istočnim razbio si korablje tarsiske.
\q1 
\v 8 Šta slušamo to i vidimo
\q2 u gradu Gospoda nad vojskama,
\q1 u gradu Boga našeg,
\q2 Bog ga utvrdi doveka.
\b
\q1 
\v 9 Kazujemo, Bože, milost Tvoju
\q2 usred crkve Tvoje.
\q1 
\v 10 Kao što je ime Tvoje, Bože,
\q2 tako je i hvala Tvoja na krajevima zemaljskim;
\q2 pravde je puna desnica Tvoja.
\q1 
\v 11 Nek se veseli gora Sion,
\q2 nek se raduju kćeri judejske
\q2 sudova radi Tvojih.
\b
\q1 
\v 12 Pođite oko Siona i obiđite ga,
\q2 izbrojte kule njegove;
\q1 
\v 13 Pogledajte bedeme njegove,
\q2 razmotrite dvorove njegove,
\q2 da pripovedate mlađim naraštajima.
\q1 
\v 14 Jer je ovaj Bog
\q2 naš Bog uvek i doveka,
\q2 On će biti vođ naš doveka.
\c 49
\cl Psalam 49
\s1 Sreća se bezbožnikova svršuje bezbožnikovom smrću.
\d Načelniku pevačkom. Psalam sinova Korejevih.
\q1 
\v 1 Slušajte ovo svi narodi,
\q2 pazite svi koji živite po vasiljeni,
\q1 
\v 2 Prostaci i gospodo,
\q2 bogati i siromasi.
\q1 
\v 3 Usta će moja kazati premudrost,
\q2 i srce moje reći će razum.
\q1 
\v 4 Prignuću uho svoje k priči,
\q2 uz gusle ću otvoriti zagonetku svoju.
\b
\q1 
\v 5 Čega da se bojim u zle dane,
\q2 kad me zloba mojih neprijatelja opkoli?
\q1 
\v 6 Koji se uzdate u silu svoju,
\q2 i hvalite se velikim bogatstvom svojim!
\q1 
\v 7 Čovek neće nikako brata osloboditi,
\q2 neće dati Bogu otkup za nj.
\q1 
\v 8 Velik je otkup za dušu,
\q2 i neće biti nikad
\q1 
\v 9 Da ko doveka živi,
\q2 i ne vidi groba.
\b
\q1 
\v 10 Svi vide gde umiru
\q2 kao i neznalica i bezumnik što ginu,
\q2 i ostavljaju drugima imanje svoje.
\q1 
\v 11 Oni misle da će kuće njihove trajati doveka,
\q2 i stanovi njihovi od kolena na koleno;
\q2 imenima svojim zovu zemlje;
\q1 
\v 12 Ali čovek u časti neće dugo ostati,
\q2 izjednačiće se sa stokom, koju kolju.
\b
\q1 
\v 13 Ovaj im se put čini probitačan,
\q2 i koji za njima idu, hvale misli njihove;
\q1 
\v 14 Ali će ih kao ovce zatvoriti u pakao,
\q2 smrt će im biti pastir;
\q1 i ujutru hodiće po njima pravednici,
\q2 i oblik njihov zbrisaće pakao
\q2 rastavivši ih s naseljem.
\q1 
\v 15 Ali će Bog dušu moju izbaviti iz ruku paklenih;
\q2 jer me On prima.
\b
\q1 
\v 16 Ne boj se kad se ko bogati;
\q2 kad raste slava doma njegovog.
\q1 
\v 17 Jer kad umre, neće ništa poneti,
\q2 niti će poći za njim slava njegova.
\q1 
\v 18 Jer dušu njegovu blagosiljaju za života njegovog,
\q2 i slave tebe, što ugađaš sebi.
\q1 
\v 19 Ali će on otići u stan otaca svojih,
\q2 gde sveta nikad ne vide.
\q1 
\v 20 Čovek u časti, ako nije razuman,
\q2 izjednačiće se sa stokom, koju kolju.
\c 50
\cl Psalam 50
\s1 Prava žrtva zahvalnica.
\d Psalam Asafov.
\q1 
\v 1 Bog nad bogovima, Gospod, govori
\q2 i doziva zemlju od istoka sunčanog do zapada.
\q1 
\v 2 Sa Siona, koji je vrh krasote, javlja se Bog.
\b
\q1 
\v 3 Ide Bog naš, i ne ćuti;
\q2 pred Njim je oganj koji proždire,
\q2 oko Njega je bura velika.
\q1 
\v 4 Doziva nebo odozgo i zemlju,
\q2 da sudi narodu svom:
\q1 
\v 5 „Skupite mi svece moje,
\q2 koji su učinili sa mnom zavet na žrtvi.”
\q1 
\v 6 (I nebesa oglasiše pravdu Njegovu,
\q2 jer je taj sudija Bog.)
\b
\q1 
\v 7 Slušaj, narode moj, šta ću ti kazati,
\q2 Izrailju, šta ću ti javiti.
\q2 Ja sam Bog, Bog tvoj.
\q1 
\v 8 Neću te za žrtve tvoje karati;
\q2 tvoje žrtve paljenice svagda su preda mnom.
\q1 
\v 9 Ne treba mi uzimati teleta iz doma tvog,
\q2 ni jarića iz torova tvojih.
\q1 
\v 10 Jer je moje sve gorsko zverje,
\q2 i stoka po planinama na hiljade.
\q1 
\v 11 Znam sve ptice po gorama,
\q2 i krasota poljska preda mnom je.
\b
\q1 
\v 12 Da ogladnim, ne bih tebi rekao,
\q2 jer je moja vasiljena i sve što je u njoj.
\q1 
\v 13 Zar ja jedem meso volujsko,
\q2 ili krv jareću pijem?
\q1 
\v 14 Prinesi Bogu hvalu na žrtvu,
\q2 i izvršuj Višnjemu zavete svoje.
\q1 
\v 15 Prizovi me u nevolji svojoj, izbaviću te,
\q2 i ti me proslavi.
\b
\q1 
\v 16 A bezbožniku reče Bog:
\q2 Zašto kazuješ uredbe moje
\q2 i nosiš zavet moj u ustima svojim?
\q1 
\v 17 A sam mrziš na nauku,
\q2 i reči moje bacaš za leđa.
\q1 
\v 18 Kad vidiš lupeža, pristaješ s njim,
\q2 i s preljubočincima imaš deo.
\b
\q1 
\v 19 Usta si svoja pustio da govore zlo,
\q2 i jezik tvoj plete prevare.
\q1 
\v 20 Sediš i govoriš na brata svog,
\q2 sina matere svoje opadaš.
\q1 
\v 21 Ti si to činio, ja ćutah,
\q2 a ti pomisli da sam ja kao ti.
\q2 Obličiću te, metnuću ti pred oči grehe tvoje.
\b
\q1 
\v 22 Razumejte ovo koji zaboravljate Boga!
\q2 Inače ću zgrabiti, pa neće niko izbaviti.
\q1 
\v 23 Onaj mene poštuje
\q2 koji prinosi hvalu na žrtvu
\q2 i koji je putem na opazu.
\q1 Ja ću mu pokazati spasenje Božije.
\c 51
\cl Psalam 51
\s1 Davidova pokajnička molitva.
\r (2. Samuilova 12)
\d Načelniku pevačkom. Psalam Davidov. Kad dođe prorok Natan, pošto bi kod Vitsaveje.
\q1 
\v 1 Smiluj se na me, Bože, po milosti svojoj,
\q2 i po velikoj dobroti svojoj očisti bezakonje moje.
\q1 
\v 2 Operi me dobro od bezakonja mog,
\q2 i od greha mog očisti me.
\b
\q1 
\v 3 Jer ja znam prestupe svoje,
\q2 i greh je moj jednako preda mnom.
\q1 
\v 4 Samome Tebi zgreših,
\q2 i na Tvoje oči zlo učinih,
\q1 a Ti si pravedan u rečima svojim
\q2 i čist u sudu svom.
\q1 
\v 5 Gle, u bezakonju rodih se,
\q2 i u grehu zatrudne mati moja mnom.
\q1 
\v 6 Gle, istinu ljubiš u srcu,
\q2 i iznutra javljaš mi mudrost.
\b
\q1 
\v 7 Pokropi me isopom, i očistiću se;
\q2 umij me, i biću belji od snega.
\q1 
\v 8 Daj mi da slušam radost i veselje,
\q2 da se prenu kosti koje si potro.
\q1 
\v 9 Odvrati lice svoje od greha mojih,
\q2 i sva bezakonja moja očisti.
\q1 
\v 10 Učini mi, Bože, čisto srce,
\q2 i duh prav ponovi u meni.
\q1 
\v 11 Nemoj me odvrgnuti od lica svog,
\q2 i Svetog Duha svog nemoj uzeti od mene.
\q1 
\v 12 Vrati mi radost spasenja svog,
\q2 i duh vladalački neka me potkrepi.
\b
\q1 
\v 13 Naučiću bezakonike putevima Tvojim,
\q2 i grešnici k Tebi će se obratiti.
\q1 
\v 14 Izbavi me od krvi, Bože,
\q2 Bože, Spasitelju moj,
\q2 i jezik će moj glasiti pravdu Tvoju.
\q1 
\v 15 Gospode! Otvori usta moja,
\q2 i ona će kazati hvalu Tvoju.
\q1 
\v 16 Jer žrtvu nećeš: ja bih je prineo;
\q2 za žrtve paljenice ne mariš.
\q1 
\v 17 Žrtva je Bogu duh skrušen,
\q2 srce skrušeno i poništeno ne odbacuješ, Bože.
\b
\q1 
\v 18 Po dobroti svojoj, Gospode, čini dobro Sionu,
\q2 podigni zidove jerusalimske.
\q1 
\v 19 Onda će Ti biti mile žrtve pravde,
\q2 prinosi i žrtve paljenice;
\q2 onda će metati na žrtvenik Tvoj teoce.
\c 52
\cl Psalam 52
\s1 Pravednikova uteha kad mu se potsmevaju opadači.
\d Načelniku pevačkom. Nauk Davidov. Kad dođe Doig Idumejac i prokaza Saulu i reče mu da je David došao u kuću Avimelehovu.
\q1 
\v 1 Što se hvališ nevaljalstvom, silni?
\q2 Milost je Božija svaki dan sa mnom.
\q1 
\v 2 Nepravdu izmišlja jezik tvoj;
\q2 on je u tebe kao britva naoštrena, lukavi!
\q1 
\v 3 Voliš zlo nego dobro,
\q2 voliš lagati nego istinu govoriti.
\q1 
\v 4 Ljubiš svakojake reči od pogibli,
\q2 i jezik lukav.
\b
\q1 
\v 5 Toga radi Bog će te poraziti sasvim,
\q2 izbaciće te i iščupaće te iz stana,
\q2 i koren tvoj iz zemlje živih.
\q1 
\v 6 Videće pravednici i pobojaće se,
\q2 i podsmevaće mu se:
\q1 
\v 7 Gle čoveka koji ne držaše u Bogu kreposti svoje,
\q2 nego se uzdaše u veličinu bogatstva svog
\q2 i utvrđivaše se zloćom svojom.
\b
\q1 
\v 8 A ja, kao maslina zelena u domu Gospodnjem,
\q2 uzdam se u milost Božiju bez prestanka i doveka.
\q1 
\v 9 Doveka ću hvaliti Tebe, jer dobro činiš,
\q2 i uzdaću se u ime Tvoje;
\q2 jer si dobar k svecima svojim.
\c 53
\cl Psalam 53
\s1 Uzdisanje za oslobođenjem od opšte pokvarenosti ljudi.
\d Načelniku pevačkom. Uza sviralu. Nauk Davidov.
\q1 
\v 1 Reče bezumnik u srcu svom: Nema Boga;
\q2 pronevaljališe se i zagrdeše u bezakonju,
\q2 nema nikoga dobro da tvori.
\b
\q1 
\v 2 Bog s neba pogleda na sinove čovečije
\q2 da vidi ima li koji razuman,
\q2 i traži li koji Boga.
\b
\q1 
\v 3 Svi zastraniše, svi se pokvariše,
\q2 nema nikoga dobro da tvori,
\q2 nema ni jednog.
\b
\q1 
\v 4 Zar neće da se orazume koji god čine bezakonje,
\q2 jedu narod moj kao što jedu hleb,
\q2 i ne prizivaju Boga?
\b
\q1 
\v 5 Drhtaće od straha gde straha nema.
\q2 Jer će Bog rasuti kosti onih koji ustaju na tebe.
\q1 Ti ćeš ih posramiti,
\q2 jer ih Bog odvrže.
\b
\q1 
\v 6 Ko će poslati sa Siona spasenje Izrailju?
\q2 Kad Bog povrati zarobljeni narod svoj,
\q2 radovaće se Jakov, veseliće se Izrailj.
\c 54
\cl Psalam 54
\s1 Molitva za spasenje.
\r (1. Samuilova 23:19; 26:1)
\d Načelniku pevačkom. Uz žice. Nauk Davidov. Kad dođoše Zifeji i kazaše Saulu: David se krije kod nas.
\q1 
\v 1 Bože! Imenom svojim pomozi mi,
\q2 i krepošću svojom odbrani me na sudu.
\q1 
\v 2 Bože! Usliši molitvu moju,
\q2 čuj reči usta mojih.
\b
\q1 
\v 3 Jer tuđini ustaše na me;
\q2 i silni traže dušu moju;
\q2 nemaju Boga pred sobom.
\b
\q1 
\v 4 Gle, Bog je pomoćnik moj,
\q2 Gospod daje snagu duši mojoj.
\q1 
\v 5 Obratiće zlo na neprijatelje moje,
\q2 istinom svojom istrebiće ih.
\b
\q1 
\v 6 Rado ću prineti žrtvu,
\q2 proslaviću ime Tvoje, Gospode, jer je dobro.
\q1 
\v 7 Jer me izbavljaš od svake nevolje,
\q2 i na neprijatelje moje bez straha gleda oko moje.
\c 55
\cl Psalam 55
\s1 Molitva protiv lažne braće. Uteha u Gospoda.
\d Načelniku pevačkom. Uz žice. Nauk Davidov.
\q1 
\v 1 Usliši, Bože, molitvu moju,
\q2 i nemoj se sakriti od moljenja mog.
\q1 
\v 2 Pazi, i saslušaj me;
\q2 cvilim u jadu svom i uzdišem
\q1 
\v 3 Od vike neprijateljske i od dosade bezbožničke;
\q2 jer dižu na me zlo, i u gnevu gone me.
\b
\q1 
\v 4 Srce je moje uzdrhtalo u meni,
\q2 i strah smrtni popade me;
\q1 
\v 5 Strah i trepet dođe na me,
\q2 i groza poduze me.
\q1 
\v 6 I rekoh: Ko bi mi dao krila golubinja?
\q2 Ja bih odleteo i počinuo;
\q1 
\v 7 Daleko bih pobegao,
\q2 i nastanio se u pustinji.
\q1 
\v 8 Pohitao bih da utečem od vihora i od bure.
\b
\q1 
\v 9 Porazi, Gospode, i razdeli jezike njihove,
\q2 jer vidim nasilje i svađu u gradu;
\q1 
\v 10 Danju i noću to hodi po zidovima njegovim;
\q2 zločinstvo je i muka posred njega.
\q1 
\v 11 Usred njega je pogibao,
\q2 s ulice njegove ne odlazi prevara i lukavstvo.
\b
\q1 
\v 12 Jer ne ruži me neprijatelj moj,
\q2 to bih podneo;
\q1 ne ustaje na me javni nenavidnik,
\q2 od njega bih se sakrio.
\q1 
\v 13 Nego ti koji si mi bio to što ja sam,
\q2 drug moj i znanac moj.
\q1 
\v 14 S kojim mi beše radost deliti tajnu,
\q2 i u dom Božiji hodih kroz sabor narodni.
\q1 
\v 15 Neka ih ugrabi smrt,
\q2 neka živi siđu u pakao,
\q2 jer je zločinstvo u stanu njihovom i u njima.
\b
\q1 
\v 16 Ja Boga prizivam,
\q2 i Gospod će me spasti.
\q1 
\v 17 Večerom i jutrom i u podne
\q2 tužim i uzdišem,
\q2 i čuće glas moj;
\q1 
\v 18 Učiniće, te će duša moja biti mirna
\q2 od onih koji napadaju na me,
\q2 jer ih mnogo imam.
\q1 
\v 19 Da usliši, i ukroti ih Bog,
\q2 koji živi od veka;
\q2 jer se ne menjaju i ne boje se Boga.
\b
\q1 
\v 20 Dižu ruke svoje na one koji su s njima u miru,
\q2 i raskidaju svoju družbu.
\q1 
\v 21 Usta su im meka kao maslo,
\q2 a na srcu im je rat.
\q1 Reči su im blaže od ulja,
\q2 ali su goli mačevi.
\b
\q1 
\v 22 Stavi na Gospoda breme svoje,
\q2 i On će te potkrepiti.
\q2 Neće dati doveka pravedniku da posrne.
\b
\q1 
\v 23 Ti ćeš ih, Bože, svaliti u jamu pogibli;
\q2 krvopije i lukavi neće sastaviti polovine dana svojih.
\q2 A ja se u Tebe uzdam.
\c 56
\cl Psalam 56
\s1 Molitva za utehu u gonjenju.
\r (1. Samuilova 21:11)
\d Načelniku pevačkom. O nemoj golubici nadaleko. Zapis Davidov, kad ga Filisteji uhvatiše u Getu.
\q1 
\v 1 Smiluj se na me, Bože,
\q2 jer čovek hoće da me proguta,
\q2 neprijatelj me svaki dan pritešnjuje.
\q1 
\v 2 Neprijatelji moji svaki dan traže da me progutaju;
\q2 jer mnogi napadaju na me oholo.
\q1 
\v 3 Kad me je strah,
\q2 jer se u Tebe uzdam.
\q1 
\v 4 Bogom se hvalim za reč Njegovu;
\q2 u Boga se uzdam, ne bojim se;
\q2 šta će mi učiniti telo?
\b
\q1 
\v 5 Svaki dan izvrću reči moje;
\q2 šta god misle, sve meni o zlu.
\q1 
\v 6 Skupljaju se, prikrivaju se, paze za petama mojim;
\q2 jer traže dušu moju.
\q1 
\v 7 Kod ovakve zloće izbavi od njih,
\q2 u gnevu obori narode, Bože.
\b
\q1 
\v 8 U Tebe je izbrojano moje potucanje,
\q2 suze se moje čuvaju u sudu kod Tebe,
\q2 one su u knjizi Tvojoj.
\q1 
\v 9 Neprijatelji moji ustupaju natrag,
\q2 kad Tebe prizivam;
\q2 po tom znam da je Bog sa mnom.
\q1 
\v 10 Bogom se hvalim za reč Njegovu,
\q2 Gospodom se hvalim za reč Njegovu.
\q1 
\v 11 U Boga se uzdam, ne bojim se;
\q2 šta će mi učiniti čovek?
\b
\q1 
\v 12 Tebi sam se, Bože, zavetovao;
\q2 Tebe ću hvaliti;
\q1 
\v 13 Jer si izbavio dušu moju od smrti,
\q2 noge moje od spoticanja,
\q1 da bih hodio pred licem Božjim,
\q2 u svetlosti živih.
\c 57
\cl Psalam 57
\s1 Molitva Davidova za pomoć. Veličanje milosti Božije.
\r (1. Samuilova 22:1)
\d Načelniku pevačkom. Nemoj pogubiti. Zapis Davidov, kad od Saula uteče u pećinu.
\q1 
\v 1 Smiluj se na me, Bože,
\q2 smiluj se na me;
\q1 jer se u Tebe uzda duša moja,
\q2 i pod sen krila Tvojih sklanjam se dok ne prođu nevolje.
\q1 
\v 2 Prizivam Boga Višnjeg,
\q2 Boga, koji mi dobro čini;
\q1 
\v 3 Da pošalje s neba i sačuva me,
\q2 da posrami onog koji traži da me proždre;
\q2 da pošalje Bog milost svoju i istinu svoju.
\b
\q1 
\v 4 Duša je moja među lavovima,
\q2 ležim među onima koji dišu plamenom.
\q1 Zubi su sinova ljudskih koplja i strele,
\q2 i njihov jezik mač oštar.
\b
\q1 
\v 5 Uzvisi se više nebesa, Bože,
\q2 po svoj zemlji neka bude slava Tvoja!
\b
\q1 
\v 6 Metnuše zamku nogama mojim,
\q2 i stegoše dušu moju,
\q1 iskopaše preda mnom jamu,
\q2 i sami padoše u nju.
\q1 
\v 7 Utvrdilo se srce moje, Bože,
\q2 utvrdilo se srce moje;
\q2 pevaću Te i slaviću.
\q1 
\v 8 Probudi se, slavo moja,
\q2 probudi se, psaltire i gusle;
\q2 ustaću rano.
\q1 
\v 9 Hvaliću Gospoda po narodima,
\q2 pevaću Ti po plemenima.
\q1 
\v 10 Jer je velika do nebesa milost Tvoja,
\q2 i istina Tvoja do oblaka.
\b
\q1 
\v 11 Uzvisi se više nebesa, Bože,
\q2 po svoj zemlji neka bude slava Tvoja!
\c 58
\cl Psalam 58
\s1 Bog je još sudija na zemlji.
\d Načelniku pevačkom. Nemoj pogubiti. Zapis Davidov.
\q1 
\v 1 Govorite li zaista istinu, silni,
\q2 sudite li pravo, sinovi čovečiji?
\q1 
\v 2 Ta, bezakonja sastavljate u srcu,
\q2 mećete na merila zločinstva ruku svojih na zemlji.
\b
\q1 
\v 3 Od samog rođenja zastraniše bezakonici,
\q2 od utrobe materine tumaraju govoreći laž.
\q1 
\v 4 U njima je jed kao jed zmijinji,
\q2 kao gluve aspide, koja zatiskuje uho svoje,
\q1 
\v 5 Koja ne čuje glas bajačev,
\q2 vračara veštog u vračanju.
\b
\q1 
\v 6 Bože! Polomi im zube u ustima njihovim;
\q2 razbij čeljusti lavovima, Gospode!
\q1 
\v 7 Nek se proliju kao voda, i nestane ih.
\q2 Kad puste strele, neka budu kao slomljene.
\q1 
\v 8 Kao puž, koji se raščinja, neka iščile;
\q2 kao dete, koje žena pobaci, neka ne vide sunca.
\q1 
\v 9 Pre nego kotlovi vaši osete toplotu od potpaljenog trnja,
\q2 i sirovo i nagorelo neka raznese vihor.
\b
\q1 
\v 10 Obradovaće se pravednik kad vidi osvetu,
\q2 opraće noge svoje u krvi bezbožnikovoj.
\q1 
\v 11 I reći će ljudi: Zaista ima ploda pravedniku!
\q2 Zaista je Bog sudija na zemlji!
\c 59
\cl Psalam 59
\s1 Molitva za pomoć Božiju protiv zamki pakosnih neprijatelja.
\r (1. Samuilova 19:11)
\d Načelniku pevačkom. Nemoj pogubiti. Zapis Davidov, kad Saul posla da čuvaju kuću da bi ga ubili.
\q1 
\v 1 Izbavi me od neprijatelja mojih, Bože moj,
\q2 i od onih, što ustaju na me, zakloni me.
\q1 
\v 2 Izbavi me od onih koji čine bezakonje,
\q2 i od krvopija sačuvaj me.
\b
\q1 
\v 3 Evo, zlo namišljaju duši mojoj,
\q2 skupljaju se na me silni,
\q2 bez krivice moje i bez greha mog, Gospode.
\q1 
\v 4 Bez krivice moje steču se i oružaju se;
\q2 ustani za mene, i gledaj.
\q1 
\v 5 Ti, Gospode, Bože nad vojskama, Bože Izrailjev,
\q2 probudi se, obiđi sve ove narode,
\q2 nemoj požaliti odmetnika.
\b
\q1 
\v 6 Nek se vrate uveče,
\q2 laju kao psi i idu oko grada.
\q1 
\v 7 Evo ruže jezikom svojim,
\q2 mač im je u ustima, jer, vele, ko će čuti?
\b
\q1 
\v 8 Ali Ti ćeš se, Gospode, smejati njima
\q2 i posramiti sve ove narode.
\q1 
\v 9 Oni su jaki, ali ja na Tebe pogledam,
\q2 jer si Ti Bog, čuvar moj.
\q1 
\v 10 Bog, koji me miluje, ide preda mnom,
\q2 Bog mi daje bez straha da gledam neprijatelje svoje.
\b
\q1 
\v 11 Nemoj ih pobiti, da ne bi zaboravio narod moj;
\q2 raspi ih silom svojom i obori ih,
\q2 Gospode, braniču naš,
\q1 
\v 12 Za greh usta njihovih;
\q2 za reči jezika njihovog;
\q1 nek se uhvate u oholosti svojoj
\q2 za kletvu i laž koju su govorili.
\q1 
\v 13 Raspi u gnevu, raspi, da ih nema;
\q2 i neka poznaju da Bog vlada nad Jakovom
\q2 i do krajeva zemaljskih.
\b
\q1 
\v 14 Nek se vrate uveče,
\q2 laju kao psi, i idu oko grada.
\q1 
\v 15 Neka tumaraju tražeći hrane,
\q2 i ne nasitivši se neka noći provode.
\b
\q1 
\v 16 A ja ću pevati silu Tvoju,
\q2 rano ujutru glasiti milost Tvoju;
\q1 jer si mi bio odbrana
\q2 i utočište u dan nevolje moje.
\q1 
\v 17 Silo moja! Tebi ću pevati,
\q2 jer si Ti Bog čuvar moj,
\q2 Bog koji me miluje.
\c 60
\cl Psalam 60
\s1 Molitva u vreme rata.
\r (2. Samuilova 8:3,13)
\d Načelniku pevačkom. Uz muzikalnu spravu susan edut. Zapis Davidov. Za učenje; kad vojeva sa Sirijom Mesopotamskom i sa Sirijom Sovskom, i kad Joav vraćajući se pobi dvanaest hiljada Idumejaca na slanom polju.
\q1 
\v 1 Bože, rasrdio si se na nas, rasuo si nas, gnevio si se;
\q2 povrati nas.
\q1 
\v 2 Zatresao si zemlju, i razvalio si je;
\q2 stegni raseline njene, jer se njiha.
\q1 
\v 3 Dao si narodu svom da pozna ljutu nevolju,
\q2 napojio si nas vina od kog se zanesosmo.
\b
\q1 
\v 4 Podigni zastavu za one koji Te se boje,
\q2 da uteku od luka,
\q1 
\v 5 Da se izbave mili Tvoji.
\q2 Pomozi desnicom svojom i usliši me.
\b
\q1 
\v 6 Bog reče u svetinji svojoj:
\q2 Veseliću se,
\q1 razdeliću Sihem,
\q2 i dolinu Sokot razmeriću.
\q1 
\v 7 Moj je Galad,
\q2 moj je Manasija,
\q1 Jefrem je krepost glave moje,
\q2 Juda skiptar moj,
\q1 
\v 8 Moav čaša moja, iz koje se umivam,
\q2 na Edoma pružiću obuću svoju.
\q2 Pevaj mi, filistejska zemljo!
\b
\q1 
\v 9 Ko će me odvesti u tvrdi grad?
\q2 Ko će me otpratiti do Edoma?
\q1 
\v 10 Zar nećeš Ti, Bože, koji si nas odbacio,
\q2 i ne ideš, Bože, s vojskom našom?
\q1 
\v 11 Daj nam pomoć u teskobi.
\q2 A obrana je čovečija uzalud.
\q1 
\v 12 Bogom smo jaki:
\q2 On gazi neprijatelje naše.
\c 61
\cl Psalam 61
\s1 Molitva potištenog cara.
\d Načelniku pevačkom. Uz žice. Davidov.
\q1 
\v 1 Čuj, Bože, viku moju,
\q2 slušaj molitvu moju.
\q1 
\v 2 Od kraja zemlje vičem k Tebi,
\q2 kad klonu srce moje.
\q1 Izvedi me na goru,
\q2 gde se ne mogu popeti.
\q1 
\v 3 Jer si Ti utočište moje,
\q2 tvrdi zaklon od neprijatelja.
\b
\q1 
\v 4 Da živim u stanu Tvom doveka,
\q2 i počinem pod krovom krila Tvojih.
\q1 
\v 5 Jer Ti, Bože, čuješ zavete moje
\q2 i daješ mi dostojanje onih koji poštuju ime Tvoje.
\b
\q1 
\v 6 Dodaj dane k danima carevim,
\q2 i godine njegove produži od kolena na koleno.
\q1 
\v 7 Neka caruje doveka pred Bogom;
\q2 zapovedi milosti i istini neka ga čuvaju.
\b
\q1 
\v 8 Tako ću pevati imenu Tvom svagda,
\q2 izvršujući zavete svoje svaki dan.
\c 62
\cl Psalam 62
\s1 Uzdanje u Boga. Ništavilo čovečije.
\d Načelniku pevača Idutunovih. Psalam Davidov.
\q1 
\v 1 Ta, u Boga je mir duši mojoj,
\q2 od Njega je spasenje moje!
\q1 
\v 2 Ta, On je grad moj i spasenje moje,
\q2 utočište moje, neću posrnuti nimalo.
\b
\q1 
\v 3 Dokle ćete napadati na čoveka?
\q1 Svi hoćete da ga oborite kao zid navaljen,
\q2 kao ogradu isprovaljivanu.
\q1 
\v 4 Baš naumiše da ga svrgnu s visine,
\q2 omile im laž,
\q2 ustima blagosiljaju, a u srcu kunu.
\b
\q1 
\v 5 Da, u Bogu se smiri, dušo moja;
\q2 jer je u Njemu nada moja.
\q1 
\v 6 On je grad moj i spasenje moje,
\q2 utočište moje, neću posrnuti.
\q1 
\v 7 U Bogu je spasenje moje i slava moja,
\q2 tvrdi grad i pristanište meni je u Bogu.
\b
\q1 
\v 8 Narode! Uzdaj se u Njega u svako doba;
\q2 izlivajte pred Njim srce svoje;
\q2 Bog je naše utočište.
\b
\q1 
\v 9 Ta, sinovi su prostački ništa,
\q2 sinovi su gospodski laž,
\q1 da se metnu na merila,
\q2 bili bi lakši nego ništa.
\q1 
\v 10 Ne uzdajte se u vlast ni u otimanje,
\q2 nemojte biti ništavi;
\q1 kad raste bogatstvo,
\q2 ne dajte da vam srce prione za nj.
\b
\q1 
\v 11 Jednom reče Bog i više puta čuh,
\q2 da je krepost u Boga.
\q1 
\v 12 I u Tebe je, Gospode, milost;
\q2 jer Ti plaćaš svakome po delima njegovim.
\c 63
\cl Psalam 63
\s1 Čežnja za Bogom u njegovoj svetinji.
\r (1. Samuilova 22:5; 23:14)
\d Psalam Davidov, kad bijaše u pustinji Judejskoj.
\q1 
\v 1 Bože! Ti si Bog moj, k Tebi ranim,
\q2 žedna je Tebe duša moja,
\q1 za Tobom čezne telo moje
\q2 u zemlji suvoj, žednoj i bezvodnoj.
\q1 
\v 2 Tako bih Te ugledao u svetinji,
\q2 da bih video silu Tvoju i slavu Tvoju.
\q1 
\v 3 Jer je dobrota Tvoja bolja od života.
\q2 Usta bi moja hvalila Tebe;
\q1 
\v 4 Tako bih Te blagosiljao za života svog,
\q2 u ime Tvoje podigao bih ruke svoje.
\b
\q1 
\v 5 Kao salom i uljem nasitila bi se duša moja,
\q2 i radosnim glasom hvalila bi Te usta moja.
\q1 
\v 6 Kad Te se sećam na postelji,
\q2 sve noćne straže razmišljam o Tebi.
\q1 
\v 7 Jer si Ti pomoć moja,
\q2 i u senu krila Tvojih veselim se.
\q1 
\v 8 Duša se moja prilepila za Tebe,
\q2 desnica Tvoja drži me.
\b
\q1 
\v 9 Koji traže pogibao duši mojoj,
\q2 oni će otići pod zemlju.
\q1 
\v 10 Izginuće od mača,
\q2 i dopašće lisicama.
\q1 
\v 11 A car će se veseliti o Bogu,
\q2 hvaliće se svaki koji se kune Njim,
\q2 kad se zatisnu usta onima koji govore laž.
\c 64
\cl Psalam 64
\s1 Molitva Davidova da ga Gospod zaštiti od opadača.
\d Načelniku pevačkom. Psalam Davidov.
\q1 
\v 1 Čuj, Bože, glas moj u jadu mom;
\q2 od strašnog neprijatelja sačuvaj život moj.
\q1 
\v 2 Sakrij me od gomile bezakonika,
\q2 od čete zločinaca,
\q1 
\v 3 Koji naoštriše jezik svoj kao mač,
\q2 streljaju rečima, koje zadaju rane,
\q1 
\v 4 Da bi iz potaje ubili pravoga.
\q2 Iznenada udaraju na nj i ne boje se;
\q1 
\v 5 Utvrđuju sebe u zlim namerama,
\q2 dogovaraju se kako će zamke sakriti,
\q2 vele: Ko će ih videti?
\q1 
\v 6 Izmišljaju zločinstva
\q2 i govore: Svršeno je! Šta će se raditi, smišljeno je!
\q1 A šta je unutra i srce u čoveka duboko je.
\b
\q1 
\v 7 Ali će ih Bog poraziti;
\q2 udariće ih strela iznenada.
\q1 
\v 8 Oboriće jedan drugog jezikom svojim.
\q2 Ko ih god vidi, bežaće od njih.
\q1 
\v 9 Svi će se ljudi bojati
\q2 i kazivaće čudo Božije,
\q2 i poznaće u tome delo Njegovo.
\b
\q1 
\v 10 A pravednik će se veseliti o Gospodu
\q2 i uzdaće se u Njega,
\q2 i hvaliće se svi koji su pravog srca.
\c 65
\cl Psalam 65
\s1 Zahvalna pesma naroda Božijeg za duhovne i telesne darove.
\d Načelniku pevačkom. Psalam Davidov. Pesma.
\q1 
\v 1 U Tebi je uzdanje, Bože,
\q2 Tebi pripada hvala na Sionu,
\q2 i Tebi se izvršuju zaveti.
\q1 
\v 2 Ti slušaš molitvu;
\q2 k Tebi dolazi svako telo.
\q1 
\v 3 Bezakonja me pritiskaju,
\q2 Ti ćeš očistiti grehe naše.
\q1 
\v 4 Blago onome koga izabiraš i primaš,
\q2 da živi u dvoru Tvom!
\q1 Nasitićemo se dobrom doma Tvog,
\q2 svetinjom crkve Tvoje.
\b
\q1 
\v 5 Divno nam odgovaraš po pravdi svojoj,
\q2 Bože, Spasitelju naš,
\q1 uzdanico svih krajeva zemaljskih,
\q2 i naroda preko mora daleko.
\q1 
\v 6 Koji si postavio gore svojom silom,
\q2 opasao se jačinom,
\q1 
\v 7 Koji utišavaš huku morsku,
\q2 huku vala njihovih
\q2 i bunu po narodima!
\q1 
\v 8 Boje se Tvojih čudesa
\q2 koji žive na krajevima zemaljskim;
\q1 sve što se javlja jutrom i večerom
\q2 Ti budiš da slavi Tebe.
\b
\q1 
\v 9 Nadgledaš zemlju i zalivaš je,
\q2 obilno je obogaćavaš;
\q1 potok je Božji pun vode,
\q2 spremaš za njih žito,
\q2 jer si tako uredio.
\q1 
\v 10 Brazde njene napajaš,
\q2 ravniš grude njene,
\q1 kišnim kapljama razmekšavaš je,
\q2 blagosiljaš je da rađa.
\q1 
\v 11 Ti venčavaš godinu, kojoj dobro činiš;
\q2 stope su Tvoje pune masti.
\q1 
\v 12 Tiju paše po pustinjama,
\q2 i humovi se opasuju radošću.
\q1 
\v 13 Luke se osipaju stadima,
\q2 i polja se zaodevaju pšenicom;
\q2 vesele se i pevaju.
\c 66
\cl Psalam 66
\s1 Zahvalnost Bogu što je mudro vodio narod svoj.
\d Načelniku pevačkom. Pesma. Psalam.
\q1 
\v 1 Poklikni Bogu, sva zemljo!
\q2 
\v 2 Zapevajte slavu imenu Njegovom,
\q2 dajte Mu hvalu i slavu.
\q1 
\v 3 Recite Bogu: Kako si strašan u delima svojim!
\q2 Radi velike sile Tvoje laskaju Ti neprijatelji Tvoji.
\q1 
\v 4 Sva zemlja nek se pokloni Tebi i poje Tebi,
\q2 neka poje imenu Tvom.
\b
\q1 
\v 5 Hodite i vidite dela Boga strašnog
\q2 u delima svojim nad sinovima ljudskim.
\q1 
\v 6 On je pretvorio more u suhotu,
\q2 preko reke pređosmo nogama;
\q2 onde smo se veselili o Njemu;
\q1 
\v 7 Vlada silom svojom uvek,
\q2 oči Njegove gledaju na narode.
\q2 Buntovnici, da se niste podigli!
\b
\q1 
\v 8 Blagosiljajte, narodi, Boga našeg,
\q2 i glasite hvalu Njemu.
\q1 
\v 9 On je darovao duši našoj život,
\q2 i nije dao da poklizne noga naša.
\q1 
\v 10 Ti si nas okušao, Bože,
\q2 pretopio si nas, kao srebro što se pretapa.
\q1 
\v 11 Uveo si nas u mrežu,
\q2 metnuo si breme na leđa naša.
\q1 
\v 12 Dao si nas u jaram čoveku,
\q2 uđosmo u oganj i u vodu;
\q2 ali si nas izveo na odmor.
\b
\q1 
\v 13 Ući ću u dom Tvoj sa žrtvama što se sažižu,
\q2 izvršiću Ti zavete svoje,
\q1 
\v 14 Koje rekoše usta moja,
\q2 i kaza jezik moj u teskobi mojoj.
\q1 
\v 15 Žrtve paljenice pretile ću tu prineti
\q2 s dimom od pretiline ovnujske,
\q2 prineću Ti teoce s jarićima.
\b
\q1 
\v 16 Hodite, čujte svi koji se bojite Boga,
\q2 ja ću vam kazati šta je učinio duši mojoj.
\q1 
\v 17 K Njemu zavikah ustima svojim,
\q2 i jezikom svojim proslavih Ga.
\q1 
\v 18 Da sam video u srcu svom bezakonje,
\q2 ne bi me uslišio Gospod.
\q1 
\v 19 Ali Bog usliši,
\q2 primi glas moljenja mog.
\b
\q1 
\v 20 Blagosloven Bog,
\q2 koji ne odvrže molitve moje
\q2 i ne ostavi me bez milosti svoje!
\c 67
\cl Psalam 67
\s1 Slavljenje Boga zbog blagoslova koji je izlio na sve narode.
\d Načelniku pevačkom. Uz žice. Psalam. Pesma.
\q1 
\v 1 Bože, budi nam milostiv i blagosiljaj nas,
\q2 obasjavaj nas licem svojim.
\q1 
\v 2 Da bi se znao na zemlji put Tvoj,
\q2 po svima narodima spasenje Tvoje.
\q1 
\v 3 Da Te slave narodi, Bože,
\q2 da Te slave svi narodi!
\b
\q1 
\v 4 Da se vesele i raduju plemena;
\q2 jer sudiš narodima pravo,
\q2 i plemenima na zemlji upravljaš.
\q1 
\v 5 Da Te slave narodi, Bože,
\q2 da Te slave svi narodi!
\b
\q1 
\v 6 Zemlja dade plod svoj.
\q2 Da nas blagosilja Bog, Bog naš!
\q1 
\v 7 Da nas blagosilja Bog,
\q2 i da Ga se boje svi krajevi zemaljski!
\c 68
\cl Psalam 68
\s1 Pesma pobede.
\d Načelniku pevačkom. Davidov Psalam. Pesma.
\q1 
\v 1 Ustaće Bog, i rasuće se neprijatelji Njegovi,
\q2 i pobeći će od lica Njegovog koji mrze na Nj.
\q1 
\v 2 Ti ćeš ih razagnati kao dim što se razgoni;
\q2 kao što se vosak topi od ognja,
\q2 tako će bezbožnici izginuti od lica Božijeg.
\q1 
\v 3 A pravednici će se veseliti,
\q2 radovaće se pred Bogom,
\q2 i slaviti u radosti.
\b
\q1 
\v 4 Pojte Bogu, popevajte imenu Njegovom;
\q2 ravnite put Onome što ide preko pustinje;
\q2 Gospod Mu je ime, radujte Mu se.
\q1 
\v 5 Otac je sirotama i sudija udovicama
\q2 Bog u svetom stanu svom.
\q1 
\v 6 Bog samcima daje zadrugu,
\q2 sužnje izvodi na mesta obilna,
\q2 a nepokorni žive gde je suša.
\b
\q1 
\v 7 Bože! Kad si išao pred narodom svojim,
\q2 kad si išao preko pustinje,
\q1 
\v 8 Zemlja se tresaše, i nebo se rastapaše od lica Božijeg,
\q2 i ovaj Sinaj od lica Boga, Boga Izrailjevog.
\q1 
\v 9 Blagodatni si dažd izlivao, Bože,
\q2 i kad iznemagaše dostojanje Tvoje,
\q2 Ti si ga krepio.
\q1 
\v 10 Stado Tvoje življaše onde;
\q2 po dobroti svojoj, Bože, Ti si gotovio hranu jadnome.
\b
\q1 
\v 11 Gospod daje reč;
\q2 glasnika veliko je mnoštvo.
\q1 
\v 12 Carevi nad vojskama beže, beže,
\q2 a koja sedi doma, deli plen.
\q1 
\v 13 Smirivši se u svojim krajevima,
\q2 vi ste kao golubica,
\q2 kojoj su krila posrebrena, a perje joj se zlatni.
\q1 
\v 14 Kad je Svemogući rasipao careve na ovoj zemlji,
\q2 ona se blistaše kao sneg na Selmonu.
\b
\q1 
\v 15 Gora je vasanska gora Božija;
\q2 gora je vasanska gora humovita.
\q1 
\v 16 Zašto gledate zavidljivo, gore humovite?
\q2 Evo gora, na kojoj omile Bogu živeti,
\q2 i na kojoj će Gospod živeti doveka.
\q1 
\v 17 Kola Božijih ima sila,
\q2 hiljade hiljada.
\q2 Među njima je Gospod, Sinaj u svetinji.
\q1 
\v 18 Ti si izašao na visinu, doveo si roblje,
\q2 primio darove za ljude,
\q2 a i za one koji se protive da ovde nastavaš, Gospode Bože!
\b
\q1 
\v 19 Blagosloven Gospod svaki dan!
\q2 Ako nas ko pretovara, Bog nam pomaže.
\q1 
\v 20 Ovaj je Bog naš Bog Spasitelj,
\q2 u vlasti su Gospodu vrata smrtna.
\q1 
\v 21 Gospod satire glavu neprijateljima svojim
\q2 i vlasato teme onog koji ostaje u bezakonju svom.
\q1 
\v 22 Reče Gospod: Od Vasana ću dovesti,
\q2 dovešću iz dubine morske,
\q1 
\v 23 Da ti ogrezne noga u krvi neprijateljskoj
\q2 i jezik pasa tvojih da je liže.
\b
\q1 
\v 24 Videše kako ideš, Bože,
\q2 kako sveto ide Bog moj, car moj.
\q1 
\v 25 Napred iđahu pevači,
\q2 za njima svirači sred devojaka s bubnjevima:
\q1 
\v 26 Na saboru blagosiljajte Gospoda Boga,
\q2 koji ste iz izvora Izrailjevog!
\q1 
\v 27 Onde mladi Venijamin, starešina njihov;
\q2 knezovi Judini, vladaoci njihovi;
\q2 knezovi Zavulonovi, knezovi Neftalimovi.
\b
\q1 
\v 28 Bog tvoj darovao ti je silu.
\q2 Utvrdi, Bože, ovo što si učinio za nas!
\q1 
\v 29 U crkvi Tvojoj, u Jerusalimu,
\q2 carevi će prinositi dare.
\q1 
\v 30 Ukroti zver u ritu,
\q2 kod volova s teocima naroda,
\q1 da bi popadali pred Tobom sa šipkama srebra;
\q2 raspi narode koji žele bojeve.
\q1 
\v 31 Doći će vlastela iz Misira,
\q2 Etiopija će pružiti ruke svoje k Bogu.
\b
\q1 
\v 32 Carstva zemaljska, pojte Bogu,
\q2 popevajte Gospodu,
\q1 
\v 33 Koji sedi na nebesima nebesa iskonskih.
\q2 Evo grmi glasom jakim.
\q1 
\v 34 Dajte slavu Bogu;
\q2 veličanstvo je Njegovo nad Izrailjem
\q2 i sila Njegova na oblacima.
\q1 
\v 35 Divan si, Bože, u svetinji svojoj!
\q2 Bog Izrailjev daje silu i krepost narodu.
\q1 Blagosloven Bog!
\c 69
\cl Psalam 69
\s1 Sluga Gospodnji u golemoj nevolji.
\d Načelniku pevačkom. Uz muzikalnu spravu sosanim. Psalam Davidov.
\q1 
\v 1 Pomozi mi, Bože,
\q2 jer dođe voda do duše.
\q1 
\v 2 Propadam u dubokom glibu, gde nema dna;
\q2 tonem vodi u dubine, i vali me zatrpavaju.
\q1 
\v 3 Iznemogoh vičući, promuče mi grlo,
\q2 pobeleše mi oči pogledajući Boga.
\b
\q1 
\v 4 Onih koji mrze na me nizašta
\q2 ima više nego kose na glavi mojoj;
\q1 osiliše koji hoće da me pogube,
\q2 lažljivi neprijatelji moji.
\q2 Šta nisam otimao, valja da vratim.
\q1 
\v 5 Bože! Ti znaš je li u meni bezumlje,
\q2 i krivice moje nisu sakrivene od Tebe.
\b
\q1 
\v 6 Nemoj da se postide u meni
\q2 koji se uzdaju u Tebe, Gospode,
\q2 Gospode nad vojskama!
\q1 Nemoj da se posrame u meni
\q2 koji traže Tebe, Bože Izrailjev!
\q1 
\v 7 Jer Tebe radi podnosim rug,
\q2 i sramota popade lice moje.
\q1 
\v 8 Tuđin postadoh braći svojoj,
\q2 i neznan sinovima matere svoje.
\b
\q1 
\v 9 Jer revnost za kuću Tvoju jede me
\q2 i ruženja onih koji Tebe ruže padaju na me.
\q1 
\v 10 Plačem, postim se dušom svojom,
\q2 i to mi se prima za zlo;
\q1 
\v 11 Mesto haljine oblačim vreću,
\q2 i bivam im priča.
\q1 
\v 12 O meni se razgovaraju sedeći na vratima,
\q2 pijući vino pevaju me.
\b
\q1 
\v 13 A ja se molim Tebi, Gospode;
\q2 vreme je da se smiluješ, Bože;
\q1 po velikoj milosti svojoj usliši me,
\q2 jer je istinito spasenje Tvoje.
\q1 
\v 14 Izvadi me iz gliba, da ne propadnem;
\q2 da se izbavim od nenavidnika
\q2 i iz duboke vode;
\q1 
\v 15 Da me ne uzme voda na maticu,
\q2 da me ne proždre pučina,
\q2 i da ne sklopi jama nada mnom ždrela svog.
\b
\q1 
\v 16 Usliši me, Gospode,
\q2 jer je blagost Tvoja milosrdna,
\q2 po velikoj dobroti svojoj pogledaj me.
\q1 
\v 17 Nemoj odvratiti lice svoje od sluge svog;
\q2 jer me je tuga;
\q2 pohitaj, usliši me.
\q1 
\v 18 Približi se duši mojoj, izbavi je;
\q2 nasuprot neprijateljima mojim izbavi me.
\b
\q1 
\v 19 Ti znaš pod kakvim sam rugom, stidom i sramotom;
\q2 pred Tobom su svi neprijatelji moji.
\q1 
\v 20 Sramota satre srce moje, iznemogoh;
\q2 čekam hoće li se kome sažaliti, ali nema nikoga;
\q2 hoće li me ko potešiti, ali ne nalazim.
\q1 
\v 21 Daju mi žuč da jedem,
\q2 i u žeđi mojoj poje me octom.
\b
\q1 
\v 22 Trpeza njihova neka im bude mreža i zamka,
\q2 to neka im bude plata.
\q1 
\v 23 Neka im potamne oči njihove, da ne vide,
\q2 i njihove bedre raslabi zasvagda.
\q1 
\v 24 Izlij na njih jarost svoju,
\q2 i plamen gneva Tvog neka ih obuzme!
\q1 
\v 25 Stan njihov neka opusti,
\q2 i u njihovim šatorima neka ne bude nikoga da živi.
\q1 
\v 26 Jer koga si Ti porazio, oni gone,
\q2 i umnožavaju jade onima koje si Ti ranio.
\q1 
\v 27 Meći na njih krivicu za krivicom,
\q2 da ne dođu do pravde Tvoje.
\q1 
\v 28 Neka se izbrišu iz knjige živih,
\q2 i s pravednicima nek ne budu zapisani.
\b
\q1 
\v 29 A ja sam ništ i bolan;
\q2 pomoć Tvoja, Bože, nek me zakloni.
\b
\q1 
\v 30 Slaviću ime Božije u pesmi,
\q2 veličaću Ga u hvali.
\q1 
\v 31 To je Bogu milije od vola,
\q2 od teleta s rogovima i s papcima.
\q1 
\v 32 Videće ništi i radovaće se.
\q2 Koji tražite Boga, oživeće srce vaše.
\q1 
\v 33 Jer Bog čuje uboge,
\q2 i sužanja svojih ne ogluša se.
\b
\q1 
\v 34 Neka Ga hvale nebesa i zemlja,
\q2 mora i sve što se u njima miče!
\q1 
\v 35 Jer će Bog spasti Sion,
\q2 sazidaće gradove Judine;
\q2 i ljudi će se onde naseliti i naslediće ga.
\q1 
\v 36 I nasleđe će se sluga Njegovih utvrditi u njemu
\q2 i koji ljube ime Njegovo nastavaće na njemu.
\c 70
\cl Psalam 70
\s1 Molba Davidova za pomoć protiv njegovih neprijatelja.
\d Načelniku pevačkom. Psalam Davidov. Za spomen.
\q1 
\v 1 Bože, pohitaj da me izbaviš,
\q2 Gospode, da mi pomogneš!
\q1 
\v 2 Nek se postide i posrame
\q2 koji traže dušu moju!
\q1 Nek odstupe natrag,
\q2 i osramote se koji mi zlo žele!
\q1 
\v 3 Sa stidom nek se vrate natrag
\q2 koji mi govore: Ha! Ha!
\b
\q1 
\v 4 Nek se teše i vesele Tobom
\q2 koji traže Tebe,
\q1 i koji ljube spasenje Tvoje,
\q2 neka jednako govore: Velik je Bog!
\q1 
\v 5 A ja sam ništ i ubog,
\q2 Bože, pohitaj k meni!
\q1 Ti si pomoć moja i Izbavitelj moj,
\q2 Gospode, ne časi!
\c 71
\cl Psalam 71
\s1 Molitva za Božiju milost u starosti.
\q1 
\v 1 U Tebe se, Gospode, uzdam,
\q2 nemoj me ostaviti pod sramotom večnom.
\q1 
\v 2 Pravdom svojom izbavi me, i oprosti me,
\q2 prigni k meni uho svoje i pomozi mi.
\q1 
\v 3 Budi mi grad
\q2 gde bih svagda dolazio da živim,
\q1 uredi spasenje moje;
\q2 jer si Ti grad moj i krepost moja.
\b
\q1 
\v 4 Bože moj! Uzmi me iz ruke bezbožnikove,
\q2 iz ruke bezakonikove i nasilnikove.
\q1 
\v 5 Jer si Ti nadanje moje,
\q2 Gospod je Gospod pouzdanje moje od mladosti moje.
\q1 
\v 6 Tebe se držim od rođenja,
\q2 od utrobe matere moje Ti si branič moj;
\q1 Tobom se hvalim svagda.
\b
\q1 
\v 7 Čudo sam mnogima,
\q2 a Ti si utočište moje jako.
\q1 
\v 8 Usta su moja puna hvale Tvoje,
\q2 slave Tvoje svaki dan.
\q1 
\v 9 Nemoj me odbaciti pod starost,
\q2 kad me izdaje snaga moja, nemoj me ostaviti.
\q1 
\v 10 Jer neprijatelji moji misle o meni,
\q2 i koji vrebaju dušu moju dogovaraju se,
\q1 
\v 11 Govoreći: Bog ga je ostavio,
\q2 poterajte i uhvatite ga,
\q2 jer ga nema ko izbaviti.
\b
\q1 
\v 12 Bože! Ne budi daleko od mene;
\q2 Bože moj! Pohitaj mi u pomoć.
\q1 
\v 13 Nek se postide i poginu
\q2 protivnici duše moje;
\q1 neka popadne stid i sramota
\q2 na one koji mi traže zla!
\q1 
\v 14 A ja ću se svagda uzdati,
\q2 i ponavljaću hvale Tebi.
\q1 
\v 15 Usta će moja kazivati pravdu Tvoju,
\q2 svaki dan dobročinstva Tvoja,
\q2 jer im ne znam broja.
\q1 
\v 16 Ući ću u sili Gospoda Gospoda,
\q2 i slaviću samo Tvoju pravdu.
\b
\q1 
\v 17 Bože! Ti si me učio od mladosti,
\q2 i do danas kazujem čudesa Tvoja.
\q1 
\v 18 Ni u starosti i kad osedeh
\q2 nemoj me ostaviti, Bože,
\q1 eda bih kazivao mišicu Tvoju nasleđu,
\q2 svoj omladini silu Tvoju,
\q1 
\v 19 Pravda je Tvoja, Bože,
\q2 do najviše visine;
\q1 u velikim delima, koja si učinio,
\q2 Bože, ko je kao Ti?
\q1 
\v 20 Koliko si me puta bacao u velike i ljute nevolje,
\q2 pak si me opet ostavio među živima
\q2 i iz bezdana me zemaljskih opet izvadio.
\q1 
\v 21 Mnogo si me puta podizao
\q2 i ponavljao utehe.
\b
\q1 
\v 22 I ja Te hvalim uz psaltir,
\q2 Tvoju vernost, Bože moj;
\q2 udaram Ti u gusle, Sveče Izrailjev!
\q1 
\v 23 Raduju se usta moja kad pevam Tebi,
\q2 i duša moja, koju si izbavio.
\q1 
\v 24 I jezik moj svaki dan kazuje pravdu Tvoju;
\q2 jer su postiđeni i posramljeni oni koji mi traže zla.
\c 72
\cl Psalam 72
\s1 Pohvala velikom caru i njegovoj vladi.
\d Psalam o Solomunu.
\q1 
\v 1 Bože, daj caru sud svoj,
\q2 i pravdu svoju sinu carevom:
\q1 
\v 2 On će suditi narodu Tvom po pravdi,
\q2 i nevoljnicima Tvojim po pravici.
\q1 
\v 3 Rodiće narodu gore mirom,
\q2 i humovi pravdom.
\q1 
\v 4 On će suditi nevoljnima u narodu,
\q2 pomoći će sinovima ništega,
\q2 i nasilnika će oboriti,
\b
\q1 
\v 5 Bojaće se Tebe dok je sunca i meseca,
\q2 od kolena do kolena.
\q1 
\v 6 Sići će kao dažd na pokošenu livadu,
\q2 kao kaplje koje porašaju zemlju.
\q1 
\v 7 Procvetaće u dane njegove pravednik
\q2 i svuda mir dokle teče meseca.
\b
\q1 
\v 8 Vladaće od mora do mora,
\q2 i od reke do krajeva zemaljskih.
\q1 
\v 9 Pred njim će popadati divljaci,
\q2 i neprijatelji njegovi prah će lizati.
\q1 
\v 10 Carevi tarsiski i ostrvljani doneće dare,
\q2 carevi šavski i savski daće danak.
\q1 
\v 11 Klanjaće mu se svi carevi,
\q2 svi narodi biće mu pokorni.
\b
\q1 
\v 12 Jer će izbaviti ubogoga koji cvili
\q2 i nevoljnoga koji nema pomoćnika.
\q1 
\v 13 Biće milostiv ništem i ubogom,
\q2 i duše će jadnima spasti.
\q1 
\v 14 Od prevare i nasilja iskupiće duše njihove,
\q2 i skupa će biti krv njihova pred očima njegovim.
\b
\q1 
\v 15 Oni će dobro živeti,
\q2 i doneće mu zlato iz Šave;
\q1 i svagda će se moliti za njega,
\q2 i svaki će ga dan blagosiljati.
\q1 
\v 16 Biće pšenice na zemlji izobila;
\q2 po vrhovima gorskim lelujaće se klasje njeno
\q2 kao livanska šuma,
\q1 i po gradovima cvetaće ljudi
\q2 kao trava na zemlji.
\q1 
\v 17 Ime će njegovo biti uvek;
\q2 dokle teče sunca, ime će njegovo rasti.
\q1 Blagosloviće se u njemu,
\q2 svi će ga narodi zvati blaženim.
\b
\q1 
\v 18 Blagosloven Gospod Bog,
\q2 Bog Izrailjev, koji jedan čini čudesa!
\q1 
\v 19 I blagosloveno slavno ime Njegovo uvek!
\q2 Slave Njegove napuniće se sva zemlja.
\q2 Aman i amin.
\b
\q1 
\v 20 Svršiše se molitve Davida, sina Jesejevog.
\c 73
\cl Psalam 73
\s1 Srdnja i uteha pravednikova kad gleda sreću bezbožnikovu.
\d Psalam Asafov.
\q1 
\v 1 Ta dobar je Bog Izrailju,
\q2 onima koji su čista srca.
\q1 
\v 2 A noge moje umalo ne zađoše,
\q2 umalo ne popuznuše stopala moja,
\q1 
\v 3 Jer se rasrdih na bezumnike
\q2 videći kako bezbožnici dobro žive.
\b
\q1 
\v 4 Jer ne znaju za nevolju do same smrti,
\q2 i telo je njihovo pretilo.
\q1 
\v 5 Na poslovima čovečijim nema ih,
\q2 i ne muče se s drugim ljudima.
\q1 
\v 6 Toga radi optočeni su oholoću kao ogrlicom,
\q2 i obučeni u obest kao u stajaće ruho.
\q1 
\v 7 Od debljine izbuljeno im je oko,
\q2 srce puno klape.
\q1 
\v 8 Podsmevaju se,
\q2 pakosno govore o nasilju, oholo govore.
\q1 
\v 9 Usta svoja dižu u nebo,
\q2 i zemlju prolazi jezik njihov.
\q1 
\v 10 I zato se onamo navraćaju neki iz naroda njegovog,
\q2 i piju vodu iz punog izvora.
\q1 
\v 11 I govore: Kako će razabrati Bog?
\q2 Zar Višnji zna?
\q1 
\v 12 Pa eto, ovi bezbožnici
\q2 srećni na svetu umnožavaju bogatstvo.
\q1 
\v 13 Zar, dakle, uzalud čistim srce svoje,
\q2 i umivam bezazlenošću ruke svoje,
\q1 
\v 14 Dopadam rana svaki dan,
\q2 i muke svako jutro?
\q1 
\v 15 Kad bih kazao: Govoriću kao i oni,
\q2 izneverio bih rod sinova Tvojih.
\b
\q1 
\v 16 I tako stadoh razmišljati da bih ovo razumeo;
\q2 ali to beše teško u očima mojim.
\q1 
\v 17 Dok najposle ne uđoh u svetinju Božiju,
\q2 i doznah kraj njihov.
\b
\q1 
\v 18 Ta na klizavom mestu postavio si ih,
\q2 i bacaš ih u propast!
\q1 
\v 19 Kako začas propadaju, ginu,
\q2 nestaje ih od nenadne strahote!
\q1 
\v 20 Kao san, kad se čovek probudi,
\q2 tako probudivši ih, Gospode,
\q2 u ništa obraćaš utvaru njihovu.
\q1 
\v 21 Kad kipljaše srce moje
\q2 i rastrzah se u sebi,
\q1 
\v 22 Tada bejah neznalica i ne razumevah;
\q2 kao živinče bijah pred Tobom.
\b
\q1 
\v 23 Ali sam svagda kod Tebe,
\q2 Ti me držiš za desnu ruku.
\q1 
\v 24 Po svojoj volji vodiš me,
\q2 i posle ćeš me odvesti u slavu.
\q1 
\v 25 Koga imam na nebu?
\q2 I s Tobom ništa neću na zemlji.
\q1 
\v 26 Čezne za Tobom telo moje i srce moje;
\q2 Bog je grad srca mog i deo moj doveka.
\b
\q1 
\v 27 Jer evo koji odstupiše od Tebe, ginu;
\q2 Ti istrebljavaš svakog koji čini preljubu ostavljajući Tebe.
\q1 
\v 28 A meni je dobro biti blizu Boga.
\q2 Na Gospoda polažem nadanje svoje,
\q2 i kazivaću sva čudesa Tvoja.
\c 74
\cl Psalam 74
\s1 Molba za pomoć kad se strašno opustoši svetinja.
\d Nauk Asafov.
\q1 
\v 1 Zašto se, Bože, srdiš na nas dugo;
\q2 dimi se gnev Tvoj na ovce paše Tvoje?
\q1 
\v 2 Opomeni se sabora svog, koji si stekao od starine,
\q2 iskupio sebi u naslednu državu,
\q2 gore Siona, na kojoj si se naselio.
\q1 
\v 3 Podigni stope svoje na stare razvaline:
\q2 sve je razrušio neprijatelj u svetinji.
\b
\q1 
\v 4 Riču neprijatelji Tvoji na mestu sabora Tvojih,
\q2 svoje običaje postavljaju mesto naših običaja.
\q1 
\v 5 Vidiš, oni su kao onaj koji podiže sekiru
\q2 na spletene grane u drveta.
\q1 
\v 6 Sve u njemu što je rezano razbiše sekirama i bradvama.
\q1 
\v 7 Ognjem sažegoše svetinju Tvoju;
\q2 na zemlju obalivši oskvrniše stan imena Tvog.
\q1 
\v 8 Rekoše u srcu svom: Potrimo ih sasvim.
\q2 Popališe sva mesta sabora Božijih na zemlji.
\b
\q1 
\v 9 Običaja svojih ne vidimo, nema više proroka,
\q2 i nema u nas ko bi znao dokle će to trajati.
\q1 
\v 10 Dokle će se, Bože, rugati nasilnik?
\q2 Hoće li doveka protivnik prkositi imenu Tvom?
\q1 
\v 11 Zašto ustavljaš ruku svoju i desnicu svoju?
\q2 Pruži iz nedara svojih, i istrebi ih.
\b
\q1 
\v 12 Bože, care moj,
\q2 koji od starine tvoriš spasenje posred zemlje!
\q1 
\v 13 Ti si silom svojom raskinuo more,
\q2 i satro glave vodenim nakazama.
\q1 
\v 14 Ti si razmrskao glavu krokodilu,
\q2 dao ga onima koji žive u pustinji da ga jedu.
\q1 
\v 15 Ti si otvorio izvore i potoke,
\q2 Ti si isušio reke koje ne presišu.
\q1 
\v 16 Tvoj je dan i Tvoja je noć,
\q2 Ti si postavio zvezde i sunce.
\q1 
\v 17 Ti si utvrdio sve krajeve zemaljske,
\q2 leto i zimu Ti si uredio.
\b
\q1 
\v 18 Opomeni se toga, neprijatelj se ruga Gospodu,
\q2 i narod bezumni ne mari za ime Tvoje.
\q1 
\v 19 Ne daj zverima dušu grlice svoje,
\q2 nemoj zaboraviti stado stradalaca svojih zasvagda.
\b
\q1 
\v 20 Pogledaj na zavet;
\q2 jer su sve pećine zemaljske pune stanova bezakonja.
\q1 
\v 21 Nevoljnik nek se ne vrati sramotan,
\q2 ništi i ubogi neka hvale ime Tvoje.
\b
\q1 
\v 22 Ustani, Bože, brani stvar svoju,
\q2 opomeni se kako Ti se bezumnik ruga svaki dan!
\q1 
\v 23 Ne zaboravi obesti neprijatelja svojih,
\q2 vike, koju jednako dižu protivnici Tvoji!
\c 75
\cl Psalam 75
\s1 Zahvalnost Bogu koji sudi oholim.
\d Načelniku pevačkom. Nemoj pogubiti. Psalam Asafov. Pesma.
\q1 
\v 1 Hvalimo Te, Bože, hvalimo;
\q2 blizu je ime Tvoje.
\q2 Za Tebe kazuju čudesa Tvoja.
\b
\q1 
\v 2 „Kad vidim da je vreme,
\q2 sudiću pravo.
\q1 
\v 3 Njiha se zemlja sa svima koji žive na njoj,
\q2 ja utvrđujem stupove njene.”
\q1 
\v 4 Kažem hvališama: Ne hvalite se,
\q2 i bezakonicima: Ne dižite rog.
\q1 
\v 5 Ne dižite u vis rog svoj,
\q2 ne govorite tvrdoglavo.
\b
\q1 
\v 6 Jer uzvišavanje ne dolazi ni od istoka ni od zapada
\q2 ni od pustinje;
\q1 
\v 7 Nego je Bog sudija,
\q2 jednog ponižuje a drugog uzvišuje.
\q1 
\v 8 Jer je čaša u ruci Gospodu, vino vri,
\q2 natočio je punu, i razdaje iz nje.
\q1 I talog će njen progutati,
\q2 ispiće svi bezbožnici na zemlji.
\b
\q1 
\v 9 A ja ću kazivati doveka,
\q2 pevaću Bogu Jakovljevom.
\q1 
\v 10 „Sve ću rogove bezbožnicima polomiti,
\q2 a rogovi pravednikovi uzvisiće se.”
\c 76
\cl Psalam 76
\s1 Veličina nebeskog sudije.
\d Načelniku pevačkom. Uz žice. Psalam Asafov. Pesma.
\q1 
\v 1 Zna se u Judeji za Boga,
\q2 u Izrailja je veliko ime Njegovo.
\q1 
\v 2 U Salimu je stan Njegov
\q2 i naselje Njegovo na Sionu.
\q1 
\v 3 Onde je polomio krilate strele luku,
\q2 štit i mač i rat.
\b
\q1 
\v 4 Ti si svetao;
\q2 divniji od gora hajdučkih.
\q1 
\v 5 Koji su junačkog srca postaše plen,
\q2 zaspaše snom svojim,
\q2 i junaci ne nađoše ruku svojih.
\q1 
\v 6 Od pretnje Tvoje, Bože Jakovljev,
\q2 dremlju kola i konj.
\b
\q1 
\v 7 Ti si strašan,
\q2 i ko će se održati pred licem Tvojim
\q2 kad se razgneviš?
\q1 
\v 8 S neba javljaš sud;
\q2 zemlja se prepada i ćuti,
\q1 
\v 9 Kad Bog ustaje na sud,
\q2 da pomogne svima koji stradaju na zemlji.
\b
\q1 
\v 10 I gnev ljudski obraća se u slavu Tebi,
\q2 kad se jednom opašeš gnevom.
\q1 
\v 11 Polažite i izvršujte zavete Gospodu Bogu svom;
\q2 svi koji ste oko Njega, nosite dare Strašnome.
\q1 
\v 12 On ukroćava duh knezovima,
\q2 On je strašan carevima zemaljskim.
\c 77
\cl Psalam 77
\s1 Jadikovanje u teškoj nevolji; uteha u milosti koju je Bog ranije činio svom narodu.
\d Načelniku pevača Idutunovih. Asafov psalam.
\q1 
\v 1 Glas moj ide k Bogu, i ja prizivam Njega;
\q2 glas moj ide k Bogu, i On će me uslišiti.
\q1 
\v 2 U dan tuge svoje tražih Gospoda;
\q2 noću je ruka moja podignuta, i ne spušta se;
\q2 duša moja neće da se uteši.
\q1 
\v 3 Pominjem Boga, i uzdišem;
\q2 razmišljam, i trne duh moj.
\b
\q1 
\v 4 Držim oči svoje da su budne;
\q2 klonuo sam, i ne mogu govoriti.
\q1 
\v 5 Prebrajam stare dane i godine od vekova.
\q1 
\v 6 Opominjem se pesama svojih noću;
\q2 razgovaram se sa srcem svojim,
\q2 i ispitujem duh svoj:
\q1 
\v 7 „Zar će se doveka gneviti na nas Gospod,
\q2 i neće više ljubiti?
\q1 
\v 8 Zar je zasvagda prestala milost Njegova,
\q2 i reč se prekinula od kolena na koleno?
\q1 
\v 9 Zar je zaboravio milostiv biti
\q2 i u gnevu zatvorio milosrđe svoje?”
\b
\q1 
\v 10 I rekoh: Žalosna je za mene ova promena desnice Višnjega.
\b
\q1 
\v 11 Pamtim dela Gospodnja;
\q2 pamtim pređašnje čudo Tvoje.
\q1 
\v 12 Mislio sam o svim delima Tvojim,
\q2 razmišljao o radnji Tvojoj;
\q1 
\v 13 Bože! Put je Tvoj svet;
\q2 koji je Bog tako velik kao Bog naš?
\q1 
\v 14 Ti si Bog, koji si činio čudesa,
\q2 pokazivao silu svoju među narodima;
\q1 
\v 15 Mišicom si odbranio narod svoj,
\q2 sinove Jakovljeve i Josifove.
\b
\q1 
\v 16 Videše Te vode, Bože, videše Te vode,
\q2 i ustreptaše, i bezdane se zadrmaše.
\q1 
\v 17 Iz oblaka lijaše voda,
\q2 oblaci davahu glas,
\q2 i strele Tvoje lećahu.
\q1 
\v 18 Grmljahu gromovi Tvoji po nebu;
\q2 munje Tvoje sevahu po vasiljenoj,
\q2 zemlja se tresaše i njihaše.
\q1 
\v 19 Po moru beše put Tvoj,
\q2 i staze Tvoje po velikoj vodi,
\q2 i trag Tvoj ne poznavaše se.
\q1 
\v 20 Vodio si narod svoj kao ovce rukom Mojsijevom i Aronovom.
\c 78
\cl Psalam 78
\s1 Vernost Božija u vođenju njegovog neposlušnog naroda.
\d Nauk Asafov.
\q1 
\v 1 Čuj, narode moj, nauk moj,
\q2 prigni uho svoje k rečima usta mojih.
\q1 
\v 2 Otvaram za priču usta svoja,
\q2 kazaću stare pripovetke.
\q1 
\v 3 Šta slušasmo i doznasmo,
\q2 i što nam kazivaše oci naši,
\q1 
\v 4 Nećemo zatajiti od dece njihove,
\q2 naraštaju poznom javićemo
\q1 slavu Gospodnju i silu Njegovu i čudesa koja je učinio.
\b
\q1 
\v 5 Svedočanstvo podiže u Jakovu,
\q2 i u Izrailju postavi zakon,
\q1 koji dade ocima našim da ga predadu deci svojoj;
\q1 
\v 6 Da bi znao potonji naraštaj,
\q2 deca koja će se roditi,
\q2 pa i oni da bi kazivali svojoj deci.
\q1 
\v 7 Da polažu na Boga nadanje svoje,
\q2 i ne zaboravljaju dela Božijih,
\q2 i zapovesti Njegove da drže;
\q1 
\v 8 I da ne budu kao oci njihovi,
\q2 rod nevaljao i uporan,
\q1 rod koji ne beše čvrst srcem svojim,
\q2 niti veran Bogu duhom svojim.
\b
\q1 
\v 9 Sinovi Jefremovi naoružani, koji streljaju iz luka,
\q2 vratiše se natrag, kad beše boj.
\q1 
\v 10 Ne sačuvaše zavet Božji,
\q2 i po zakonu Njegovom ne hteše hoditi.
\q1 
\v 11 Zaboraviše dela Njegova,
\q2 i čudesa, koja im je pokazao,
\q1 
\v 12 Kako pred očima njihovim učini čudesa
\q2 u zemlji misirskoj, na polju Soanu;
\q1 
\v 13 Razdvoji more, i provede ih,
\q2 od vode načini zid;
\q1 
\v 14 I vodi ih danju oblakom,
\q2 i svu noć svetlim ognjem;
\q1 
\v 15 Raskida stene u pustinji,
\q2 i poji ih kao iz velike bezdane;
\q1 
\v 16 Izvodi potoke iz kamena,
\q2 i vodi vodu rekama.
\b
\q1 
\v 17 Ali oni još jednako grešiše Njemu,
\q2 i gneviše Višnjeg u pustinji.
\q1 
\v 18 I kušaše Boga u srcu svom,
\q2 ištući jela po volji svojoj,
\q1 
\v 19 I vikaše na Boga,
\q2 i rekoše: „Može li Bog zgotoviti trpezu u pustinji?”
\q1 
\v 20 Evo! On udari u kamen, i poteče voda,
\q2 i reke ustadoše;
\q1 može li i hleba dati?
\q2 Hoće li i mesa postaviti narodu svom?
\b
\q1 
\v 21 Gospod ču i razljuti se,
\q2 i oganj se razgore na Jakova,
\q2 i gnev se podiže na Izrailja.
\q1 
\v 22 Jer ne verovaše Bogu
\q2 i ne uzdaše se u pomoć Njegovu.
\q1 
\v 23 Tada zapovedi oblacima odozgo,
\q2 i otvori vrata nebeska,
\q1 
\v 24 I pusti, te im podažde mana za jelo,
\q2 i hleb nebeski dade im.
\q1 
\v 25 Hleb anđeoski jeđaše čovek;
\q2 posla im jela do sitosti.
\q1 
\v 26 Pusti nebom ustoku,
\q2 i navede silom svojom jug;
\q1 
\v 27 I kao prahom zasu ih mesom,
\q2 i kao peskom morskim pticama krilatim;
\q1 
\v 28 Pobaca ih sred logora njihovog,
\q2 oko šatora njihovih.
\q1 
\v 29 I najedoše se
\q2 i dade im šta su želeli.
\q1 
\v 30 Ali ih još i ne prođe želja,
\q2 još beše jelo u ustima njihovim,
\q1 
\v 31 Gnev se Božji podiže na njih
\q2 i pomori najjače među njima,
\q2 i mladiće u Izrailju pobi.
\b
\q1 
\v 32 Preko svega toga još grešiše,
\q2 i ne verovaše čudesima Njegovim.
\q1 
\v 33 I pusti, te dani njihovi prolaziše uzalud,
\q2 i godine njihove u strahu.
\q1 
\v 34 Kad ih ubijaše, onda pritecahu k Njemu,
\q2 i obraćahu se i iskahu Boga;
\q1 
\v 35 I pominjahu da je Bog odbrana njihova,
\q2 i Višnji Izbavitelj njihov.
\q1 
\v 36 Laskahu Mu ustima svojim,
\q2 i jezikom svojim lagahu Mu.
\q1 
\v 37 A srce njihovo ne beše Njemu verno,
\q2 i ne behu tvrdi u zavetu Njegovom.
\q1 
\v 38 Ali On beše milostiv,
\q2 i pokrivaše greh, i ne pomori ih,
\q1 često zaustavljaše gnev svoj,
\q2 i ne podizaše sve jarosti svoje.
\q1 
\v 39 Opominjaše se da su telo,
\q2 vetar, koji prolazi i ne vraća se.
\q1 
\v 40 Koliko Ga puta rasrdiše u pustinji,
\q2 i uvrediše u zemlji gde se ne živi!
\q1 
\v 41 Sve nanovo kušaše Boga,
\q2 i Sveca Izrailjevog dražiše.
\q1 
\v 42 Ne sećaše se ruke Njegove
\q2 i dana, u koji ih izbavi iz nevolje,
\q1 
\v 43 U koji učini u Misiru znake svoje
\q2 i čudesa svoja na polju Soanu;
\q1 
\v 44 I provrže u krv reke njihove i potoke njihove,
\q2 da ne mogoše piti.
\q1 
\v 45 Posla na njih bubine da ih kolju,
\q2 i žabe da ih more.
\q1 
\v 46 Letinu njihovu dade crvu,
\q2 i muku njihovu skakavcima.
\q1 
\v 47 Vinograde njihove pobi gradom,
\q2 i smokve njihove slanom.
\q1 
\v 48 Gradu predade stoku njihovu,
\q2 i stada njihova munji.
\q1 
\v 49 Posla na njih ognjeni gnev svoj,
\q2 jarost, srdnju i mržnju,
\q2 četu zlih anđela.
\q1 
\v 50 Ravni stazu gnevu svom,
\q2 ne čuva duše njihove od smrti,
\q2 i život njihov predade pomoru.
\q1 
\v 51 Pobi sve prvence u Misiru,
\q2 prvi porod po kolibama Hamovim.
\q1 
\v 52 I povede narod svoj kao ovce,
\q2 i vodi ih kao stado preko pustinje.
\q1 
\v 53 Vodi ih pouzdano, i oni se ne bojaše,
\q2 a neprijatelje njihove zatrpa more.
\q1 
\v 54 I dovede ih na mesto svetinje svoje,
\q2 na ovu goru, koju zadobi desnica Njegova.
\q1 
\v 55 Odagna ispred lica njihovog narode;
\q2 žrebom razdeli njihovo dostojanje,
\q2 i po šatorima njihovim naseli kolena Izrailjeva.
\b
\q1 
\v 56 Ali oni kušaše i srdiše Boga Višnjeg
\q2 i uredbe Njegove ne sačuvaše.
\q1 
\v 57 Odustaše i odvrgoše se, kao i oci njihovi,
\q2 slagaše kao rđav luk.
\q1 
\v 58 Uvrediše Ga visinama svojim,
\q2 i idolima svojim razdražiše Ga.
\q1 
\v 59 Bog ču i razgnevi se
\q2 i rasrdi se na Izrailja veoma.
\q1 
\v 60 Ostavi naselje svoje u Silomu,
\q2 šator, u kome življaše s ljudima.
\q1 
\v 61 I opravi u ropstvo slavu svoju
\q2 i krasotu svoju u ruke neprijateljeve.
\q1 
\v 62 I predade maču narod svoj,
\q2 i na dostojanje svoje zaplamte se.
\q1 
\v 63 Mladiće njegove jede oganj,
\q2 i devojkama njegovim ne pevaše svatovskih pesama;
\q1 
\v 64 Sveštenici njegovi padaše od mača,
\q2 i udovice njegove ne plakaše.
\q1 
\v 65 Najposle, kao iza sna probudi se Gospod,
\q2 prenu se kao junak kad se napije vina.
\q1 
\v 66 I pobi neprijatelje svoje s leđa,
\q2 večnoj sramoti predade ih.
\b
\q1 
\v 67 I ne hte šator Josifov,
\q2 i koleno Jefremovo ne izabra.
\q1 
\v 68 Nego izabra koleno Judino,
\q2 goru Sion, koja Mu omile.
\q1 
\v 69 I sagradi svetinju svoju kao gornje svoje stanove,
\q2 i kao zemlju utvrdi je doveka.
\q1 
\v 70 I izabra Davida, slugu svog,
\q2 i uze ga od torova ovčijih,
\q1 
\v 71 I od dojilica dovede ga
\q2 da pase narod Njegov, Jakova,
\q2 i nasledstvo Njegovo, Izrailja.
\q1 
\v 72 I on ih pase čistim srcem,
\q2 i vodi ih mudrim rukama.
\c 79
\cl Psalam 79
\s1 Jadanje na razorače Jerusalima.
\d Psalam Asafov.
\q1 
\v 1 Bože! Neznabošci dođoše u dostojanje Tvoje;
\q2 oskvrniše svetu crkvu Tvoju,
\q2 Jerusalim pretvoriše u zidine.
\q1 
\v 2 Truplje sluga Tvojih dadoše pticama nebeskim da ih jedu,
\q2 tela svetaca Tvojih zverima zemaljskim.
\q1 
\v 3 Proliše krv njihovu kao vodu oko Jerusalima,
\q2 i ne beše ko da pogrebe.
\q1 
\v 4 Postadosmo podsmeh u suseda svojih,
\q2 rugaju nam se i sramote nas koji su oko nas.
\b
\q1 
\v 5 Dokle ćeš se, Gospode, jednako gneviti,
\q2 jarost Tvoja goreti kao oganj?
\q1 
\v 6 Izlij gnev svoj na narode koji Te ne znaju,
\q2 i na carstva koja ne prizivaju Tvoje ime.
\q1 
\v 7 Jer izjedoše Jakova,
\q2 i naselje njegovo opusteše.
\b
\q1 
\v 8 Ne pominji pređašnja bezakonja naša,
\q2 već pohitaj da nas presreteš milosrđem svojim,
\q2 jer smo veoma ološali.
\q1 
\v 9 Pomozi nam, Bože, Spasitelju naš,
\q2 radi slave imena svog,
\q1 izbavi nas i očisti od greha naših
\q2 radi imena svog.
\q1 
\v 10 Zašto da govore neznabošci: Gde je Bog njihov?
\q2 Neka se pokaže pred očima našim osveta nad neznabošcima
\q2 za prolitu krv sluga Tvojih!
\b
\q1 
\v 11 Neka izađu pred lice Tvoje uzdasi sužanjski,
\q2 silom mišice svoje sačuvaj namenjene smrti.
\q1 
\v 12 Sedminom vrati u nedra susedima našim ruženje,
\q2 kojim Te ružiše, Gospode!
\q1 
\v 13 A mi, narod Tvoj i ovce paše Tvoje,
\q2 doveka ćemo Tebe slaviti
\q2 i od kolena na koleno kazivati hvalu Tvoju.
\c 80
\cl Psalam 80
\s1 Molitva da Gospod održi narod Izrailjski – čokot koji je sam posadio.
\d Načelniku pevačkom. Uz muzikalnu spravu sosanim edut. Asafov psalam.
\q1 
\v 1 Pastire Izrailjev, čuj!
\q2 Koji vodiš sinove Josifove kao ovce,
\q1 koji sediš na heruvimima,
\q2 javi se!
\q1 
\v 2 Pred Jefremom i Venijaminom i Manasijom
\q2 probudi krepost svoju,
\q2 i hodi da nam pomogneš.
\b
\q1 
\v 3 Bože! Povrati nas,
\q2 neka zasja lice Tvoje da se spasemo!
\b
\q1 
\v 4 Gospode, Bože nad vojskama!
\q2 Dokle ćeš se gneviti kad Te moli narod Tvoj?
\q1 
\v 5 Hraniš ih hlebom suznim,
\q2 i pojiš ih suzama trostrukom merom.
\q1 
\v 6 Učinio si da se oko nas svađaju susedi naši,
\q2 i neprijatelji se naši smeju među sobom.
\b
\q1 
\v 7 Bože nad vojskama! Povrati nas,
\q2 neka zasja lice Tvoje da se spasemo!
\b
\q1 
\v 8 Iz Misira si preneo čokot,
\q2 izagnao narode, i posadio ga.
\q1 
\v 9 Okrčio si za nj,
\q2 i on pusti žile, i zauze svu zemlju.
\q1 
\v 10 Gore se pokriše njegovim senom,
\q2 i loze su mu kao kedri Božiji.
\q1 
\v 11 Pustio je loze svoje do mora
\q2 i ogranke svoje do reke.
\q1 
\v 12 Zašto si mu razvalio ogradu,
\q2 da ga kida ko god prođe?
\q1 
\v 13 Gorski vepar podgriza ga,
\q2 i poljska zver jede ga.
\b
\q1 
\v 14 Bože nad vojskama! Obrati se,
\q2 pogledaj s neba i vidi,
\q2 i obiđi vinograd ovaj,
\q1 
\v 15 Sad ovaj, koji je posadila desnica Tvoja,
\q2 i sina kog si ukrepio sebi!
\q1 
\v 16 Popaljen je ognjem, isečen,
\q2 od strašnog pogleda Tvog propade.
\q1 
\v 17 Neka bude ruka Tvoja nad čovekom desnice Tvoje,
\q2 nad sinom čovečijim kog si utvrdio sebi!
\q1 
\v 18 I nećemo odstupiti od Tebe,
\q2 oživi nas, i ime Tvoje prizivaćemo.
\b
\q1 
\v 19 Gospode, Bože nad vojskama! Povrati nas,
\q2 neka zasja lice Tvoje, da se spasemo!
\c 81
\cl Psalam 81
\s1 Istinsko praznovanje.
\d Načelniku pevačkom. Uz Getsku spravu. Psalam Asafov.
\q1 
\v 1 Radujte se Bogu, koji nam daje krepost;
\q2 poklikujte Bogu Jakovljevom.
\q1 
\v 2 Podignite pesme, dajte bubanj,
\q2 slatke gusle sa psaltirom.
\q1 
\v 3 Trubite o meni u trubu,
\q2 o uštapu radi praznika našeg.
\b
\q1 
\v 4 Jer je takav zakon u Izrailja,
\q2 naredba od Boga Jakovljevog.
\q1 
\v 5 Za svedočanstvo postavi Josifu ovo,
\q2 kad iđaše na zemlju misirsku.
\q1 Jezik, kog ne znah, čuh!
\q1 
\v 6 „Uklonio sam ramena njegova od bremena,
\q2 ruke njegove oprostiše se kotarica.
\q1 
\v 7 U nevolji si me zazvao, i izbavih te,
\q2 usliših te usred groma,
\q2 na vodi Merivi iskušah te.
\q1 
\v 8 Slušaj, narode moj, i zasvedočiću ti,
\q2 Izrailju, o kad bi me poslušao:
\q1 
\v 9 Da ne bude u tebe tuđeg boga,
\q2 i bogu stranom nemoj se klanjati.
\q1 
\v 10 Ja sam Gospod, Bog tvoj,
\q2 koji sam te izveo iz zemlje misirske;
\q2 otvori usta svoja, i ja ću ih napuniti.
\b
\q1 
\v 11 Ali ne posluša narod moj glas moj,
\q2 Izrailj ne mari za me.
\q1 
\v 12 I ja ih pustih na volju srca njihova,
\q2 neka hode po svojim mislima.
\q1 
\v 13 O kad bi narod moj slušao mene,
\q2 i sinovi Izrailjevi hodili putevima mojim!
\q1 
\v 14 Brzo bih pokorio neprijatelje njihove,
\q2 i na protivnike njihove digao bih ruku svoju;
\q1 
\v 15 Koji mrze na Gospoda, bili bi im pokorni,
\q2 i dobri dani njihovi bili bi doveka;
\q1 
\v 16 Najboljom bi pšenicom hranio njih,
\q2 i medom bih iz kamena sitio ih.”
\c 82
\cl Psalam 82
\s1 U govoru Gospod preti nepravednim vlastima.
\d Psalam Asafov.
\q1 
\v 1 Bog stade na saboru Božijem,
\q2 usred bogova izreče sud:
\q1 
\v 2 „Dokle ćete suditi nepravo,
\q2 i bezbožnicima gledati ko je ko?
\q1 
\v 3 Sudite ubogome i siroti,
\q2 onog koga gone i ništega pravdajte.
\q1 
\v 4 Izbavljajte ubogoga i ništega,
\q2 iz ruke bezbožničke otimajte.
\b
\q1 
\v 5 Ne poznaše, niti razumeše,
\q2 hode po tami;
\q2 zadrmaše se zemlji svi temelji.
\b
\q1 
\v 6 Rekoh: Bogovi ste,
\q2 i sinovi Višnjeg svi.
\q1 
\v 7 Ali ćete kao ljudi pomreti,
\q2 i kao svaki knez pašćete.”
\b
\q1 
\v 8 Ustani, Bože, sudi zemlji;
\q2 jer su Tvoji po nasledstvu svi narodi.
\c 83
\cl Psalam 83
\s1 Molitva za pomoć protiv neprijatelja Izrailjevih.
\d Pesma. Psalam Asafov.
\q1 
\v 1 Bože! Nemoj zamuknuti,
\q2 nemoj ćutati, niti počivaj, Bože!
\q1 
\v 2 Jer evo neprijatelji Tvoji uzavreše,
\q2 i koji Te nenavide, podigoše glavu.
\q1 
\v 3 Po narod Tvoj zlo naumiše,
\q2 i dogovaraju se na izabrane Tvoje.
\q1 
\v 4 Rekoše: Hodite da ih istrebimo između naroda
\q2 da se više ne spominje ime Izrailjevo.
\q1 
\v 5 Složno pristaše
\q2 i suprot Tebi veru uhvatiše:
\q1 
\v 6 Naselja Edomova i Ismailovci,
\q2 Moav i Agareni,
\q1 
\v 7 Geval i Amon i Amalik,
\q2 Filisteji s Tircima;
\q1 
\v 8 I Asur udruže se s njima;
\q2 postadoše mišica sinovima Lotovim.
\b
\q1 
\v 9 Učini im onako kao Madijanu,
\q2 kao Sisari, kao Javinu na potoku Kisonu.
\q1 
\v 10 Koji su istrebljeni u Aendoru,
\q2 nagnojiše sobom zemlju.
\q1 
\v 11 Uradi s njima, s knezovima njihovim,
\q2 kao s Orivom i Zivom,
\q1 i sa svima glavarima njihovim
\q2 kao sa Zevejem i Salmanom.
\q1 
\v 12 Jer govore:
\q2 Osvojimo naselja Božija.
\b
\q1 
\v 13 Bože moj! Zapovedi neka budu kao prah,
\q2 kao pesak pred vetrom.
\q1 
\v 14 Kao što oganj sažiže šumu,
\q2 i kao plamen što zapaljuje gore,
\q1 
\v 15 Tako ih pognaj burom svojom
\q2 i vihorom svojim smeti ih.
\q1 
\v 16 Pokrij lice njihovo sramotom,
\q2 da bi tražili ime Tvoje, Gospode!
\q1 
\v 17 Neka se stide i srame doveka,
\q2 neka se smetu i izginu!
\q1 
\v 18 I neka znaju da si Ti, kome je ime Gospod,
\q2 jedini najviši nad svom zemljom.
\c 84
\cl Psalam 84
\s1 Čežnja za svetinjom.
\d Načelniku pevačkom. Uz Getsku spravu. Psalam sinova Korejevih.
\q1 
\v 1 Kako su mili stanovi Tvoji,
\q2 Gospode nad silama!
\q1 
\v 2 Gine duša moja želeći u dvore Gospodnje;
\q2 srce moje i telo moje otima se k Bogu Živom.
\b
\q1 
\v 3 I ptica nahodi kuću,
\q2 i lastavica gnezdo sebi
\q2 gde leže ptiće svoje,
\q1 kod oltara Tvojih,
\q2 Gospode nad silama, care moj i Bože moj!
\q1 
\v 4 Blago onima koji žive u domu Tvom!
\q2 Oni Te hvale bez prestanka.
\b
\q1 
\v 5 Blago onima kojima je sila u Tebi,
\q2 i kojima su u srcu putevi Tvoji!
\q1 
\v 6 Idući dolinom plačevnom,
\q2 pretvaraju je u izvore,
\q2 i dažd je odeva blagoslovima.
\q1 
\v 7 Idu zbor za zborom,
\q2 javljaju se pred Bogom na Sionu.
\b
\q1 
\v 8 Gospode, Bože nad silama!
\q2 Usliši molitvu moju, Bože Jakovljev!
\q1 
\v 9 Bože, braniču naš!
\q2 Sagni se i vidi lice pomazanika svog!
\b
\q1 
\v 10 Jer je bolje jedan dan u dvorima Tvojim
\q2 od hiljade.
\q1 Volim biti na pragu doma Božijeg
\q2 nego živeti u šatorima bezbožničkim.
\q1 
\v 11 Jer je Gospod Bog sunce i štit,
\q2 Gospod daje blagodat i slavu;
\q1 onima koji hode u bezazlenosti
\q2 ne uskraćuje nijednog dobra.
\q1 
\v 12 Gospode nad silama!
\q2 Blago čoveku, koji se u Te uzda!
\c 85
\cl Psalam 85
\s1 Molba da Gospod opet blagoslovi narod prema kojem je ranije bio milostiv.
\d Načelniku pevačkom. Psalam sinova Korejevih.
\q1 
\v 1 Smilovao si se, Gospode, na zemlju svoju,
\q2 povratio si roblje Jakovljevo.
\q1 
\v 2 Oprostio si nepravdu narodu svom,
\q2 pokrio si sve grehe njegove.
\q1 
\v 3 Zaustavio si svu jarost svoju,
\q2 ublažio žestinu gneva svog.
\b
\q1 
\v 4 Povrati nas Bože, Spasitelju naš,
\q2 prekini srdnju svoju na nas.
\q1 
\v 5 Zar ćeš se doveka gneviti na nas,
\q2 i protegnuti gnev svoj od kolena na koleno?
\q1 
\v 6 Zar se nećeš povratiti i oživeti nas,
\q2 da bi se narod Tvoj radovao o Tebi?
\q1 
\v 7 Pokaži nam, Gospode, milost svoju,
\q2 i pomoć svoju daj nam.
\b
\q1 
\v 8 Da poslušam šta govori Gospod Bog.
\q2 On izriče mir narodu svom i svecima svojim,
\q2 i onima koji se obraćaju srcem k Njemu.
\q1 
\v 9 Da, blizu je onih koji Ga se boje pomoć Njegova,
\q2 da bi naselio slavu u zemlji našoj!
\b
\q1 
\v 10 Milost i istina srešće se,
\q2 pravda i mir poljubiće se.
\q1 
\v 11 Istina će niknuti iz zemlje
\q2 i pravda će s neba proniknuti.
\q1 
\v 12 I Gospod će dati dobro,
\q2 i zemlja naša daće plod svoj.
\q1 
\v 13 Pravda će pred Njim ići,
\q2 i postaviće na put stope svoje.
\c 86
\cl Psalam 86
\s1 Molitva u velikoj nevolji.
\d Molitva Davidova.
\q1 
\v 1 Prigni, Gospode, uho svoje i usliši me,
\q2 jer sam nevoljan i ništ.
\q1 
\v 2 Sačuvaj dušu moju, jer sam Tvoj poklonik.
\q2 Spasi slugu svog, Bože moj, koji se u Te uzda.
\q1 
\v 3 Smiluj se na me, Gospode,
\q2 jer k Tebi vičem sav dan.
\q1 
\v 4 Oveseli dušu sluge svog,
\q2 jer k Tebi, Gospode, podižem dušu svoju.
\q1 
\v 5 Jer si Ti, Gospode, dobar i milosrdan
\q2 i veoma milostiv svima koji Te prizivaju.
\q1 
\v 6 Čuj, Gospode, molitvu moju,
\q2 i slušaj glas moljenja mog.
\q1 
\v 7 U dan tuge svoje prizivam Te,
\q2 jer ćeš me uslišiti.
\b
\q1 
\v 8 Nema među bogovima takvog kakav si Ti, Gospode,
\q2 i nema dela takvih kakva su Tvoja.
\q1 
\v 9 Svi narodi, koje si stvorio, doći će i pokloniti se pred Tobom, Gospode,
\q2 i slaviti ime Tvoje.
\q1 
\v 10 Jer si Ti velik i tvoriš čudesa;
\q2 Ti si jedan Bog.
\q1 
\v 11 Pokaži mi, Gospode, put svoj, i ići ću u istini Tvojoj;
\q2 učini neka se mili srcu mom bojati se imena Tvog.
\q1 
\v 12 Slaviću Te, Gospode Bože moj, svim srcem svojim,
\q2 i poštovaću ime Tvoje doveka.
\q1 
\v 13 Jer je milost Tvoja velika nada mnom,
\q2 i izvadio si dušu moju iz pakla najdubljeg.
\b
\q1 
\v 14 Bože, oholice ustaše na mene,
\q2 i gomila nasilnika traži dušu moju,
\q2 i nemaju Tebe pred sobom.
\q1 
\v 15 Ali Ti, Gospode, Bože milostivi i blagi,
\q2 strpljivi i bogati dobrotom i istinom,
\q1 
\v 16 Pogledaj na me i smiluj mi se,
\q2 daj silu svoju sluzi svom,
\q2 i pomozi sinu sluškinje svoje;
\q1 
\v 17 Učini sa mnom čudo dobrote.
\q2 Neka vide koji me nenavide,
\q2 i postide se, što si mi, Gospode, pomogao i utešio me.
\c 87
\cl Psalam 87
\s1 Sion se slavi što je obratio mnogobošce.
\d Korejevih sinova. Psalam. Pesma.
\q1 
\v 1 Šta je sam osnovao na gorama svetim,
\q2 
\v 2 Vrata sionska ljubi Gospod
\q2 više svih stanova Jakovljevih,
\q1 
\v 3 Slavno kazuju za Tebe, grade Božji!
\b
\q1 
\v 4 „Među one, koji me znaju, brojaću Misir i Vavilon.
\q2 Gle i Filisteji i Tir s etiopskom onde su se rodili.”
\q1 
\v 5 O Sionu će se govoriti: Taj se i taj rodio u njemu;
\q2 sam Višnji utvrđuje ga.
\q1 
\v 6 Gospod će u prepisu naroda zavikati:
\q2 Ovaj se rodio u njemu.
\b
\q1 
\v 7 I koji pevaju i vesele se,
\q2 svi su izvori moji u Tebi.
\c 88
\cl Psalam 88
\s1 Molitva u teškom iskušenju i u smrtnoj opasnosti.
\d Pesma. Psalam sinova Korejevih. Načelniku pevačkom, da se peva uza sviralu. Nauk Emana od plemena Zarina.
\q1 
\v 1 Gospode Bože, Spasitelju moj,
\q2 danju vičem i noću pred Tobom.
\q1 
\v 2 Nek izađe preda Te molitva moja,
\q2 prigni uho svoje k jauku mom;
\b
\q1 
\v 3 Jer je duša moja puna jada,
\q2 i život se moj primače paklu.
\q1 
\v 4 Izjednačih se s onima koji u grob odlaze,
\q2 postadoh kao čovek bez sile,
\q1 
\v 5 Kao među mrtve bačen,
\q2 kao ubijeni, koji leže u grobu,
\q1 kojih se više ne sećaš,
\q2 i koji su od ruke Tvoje daleko.
\q1 
\v 6 Metnuo si me u jamu najdonju,
\q2 u tamu, u bezdanu.
\q1 
\v 7 Oteža mi gnev Tvoj,
\q2 i svima valima svojim udaraš me.
\b
\q1 
\v 8 Udaljio si od mene poznanike moje,
\q2 njima si me omrazio;
\q2 zatvoren sam, i ne mogu izaći.
\q1 
\v 9 Oko moje usahnu od jada,
\q2 vičem Te, Gospode, sav dan,
\q2 pružam k Tebi ruke svoje.
\q1 
\v 10 Eda li ćeš na mrtvima činiti čudesa?
\q2 Ili će mrtvi ustati i Tebe slaviti?
\q1 
\v 11 Eda li će se u grobu pripovedati milost Tvoja,
\q2 i istina Tvoja u truljenju?
\q1 
\v 12 Eda li će u tami poznati čudesa Tvoja,
\q2 i pravdu Tvoju gde se sve zaboravlja?
\b
\q1 
\v 13 Ali ja, Gospode, k Tebi vičem,
\q2 i jutrom molitva moja sreta Te.
\q1 
\v 14 Zašto, Gospode, odbacuješ dušu moju,
\q2 i odvraćaš lice svoje od mene?
\q1 
\v 15 Mučim se i izdišem od udaraca,
\q2 podnosim strahote Tvoje,
\q2 bez nadanja sam.
\q1 
\v 16 Gnev Tvoj stiže me,
\q2 strahote Tvoje razdiru me.
\q1 
\v 17 Opteču me svaki dan kao voda,
\q2 stežu me odsvuda.
\q1 
\v 18 Udaljio si od mene druga i prijatelja;
\q2 poznanici moji sakrili su se u mrak.
\c 89
\cl Psalam 89
\s1 Uteha za Davidov dom u Božijem obricanju.
\d Nauk Etana od plemena Zarina.
\q1 
\v 1 Milosti ću Gospodnje pevati uvek,
\q2 od kolena na koleno javljaću istinu Tvoju ustima svojim.
\q1 
\v 2 Jer znam da je zavavek osnovana milost,
\q2 i na nebesima da si utvrdio istinu svoju, rekavši:
\q1 
\v 3 „Učinih zavet s izbranim svojim,
\q2 zakleh se Davidu, sluzi svom:
\q1 
\v 4 Doveka ću utvrđivati seme tvoje
\q2 i presto tvoj uređivati od kolena do kolena.”
\b
\q1 
\v 5 Nebo kazuje čudesa Tvoja, Gospode,
\q2 i istinu Tvoju sabor svetih.
\q1 
\v 6 Jer ko je nad oblacima ravan Gospodu?
\q2 Ko će se izjednačiti s Gospodom među sinovima Božijim?
\q1 
\v 7 Bogu se valja klanjati na saboru svetih,
\q2 strašniji je od svih koji su oko Njega.
\q1 
\v 8 Gospode, Bože nad vojskama!
\q2 Ko je silan kao Ti, Bože?
\q2 I istina je Tvoja oko Tebe.
\q1 
\v 9 Ti vladaš nad silom morskom;
\q2 kad podigne vale svoje, Ti ih ukroćavaš.
\q1 
\v 10 Ti si oborio oholi Misir kao ranjenika,
\q2 krepkom mišicom svojom rasejao si neprijatelje svoje.
\q1 
\v 11 Tvoje je nebo i Tvoja je zemlja;
\q2 Ti si sazdao vasiljenu i šta je god u njoj.
\q1 
\v 12 Sever i jug Ti si stvorio,
\q2 Tavor i Ermon o Tvom se imenu raduje.
\q1 
\v 13 Tvoja je mišica krepka,
\q2 silna je ruka Tvoja,
\q2 i visoka desnica Tvoja.
\q1 
\v 14 Blagost je i pravda podnožje prestolu Tvom,
\q2 milost i istina ide pred licem Tvojim.
\q1 
\v 15 Blago narodu koji zna trubnu poklič!
\q2 Gospode! U svetlosti lica Tvog oni hode;
\q1 
\v 16 Imenom se Tvojim raduju sav dan,
\q2 i pravdom Tvojom uzvišuju se.
\q1 
\v 17 Jer si Ti krasota sile njihove,
\q2 i po milosti Tvojoj uzvišuje se rog naš.
\q1 
\v 18 Jer je od Gospoda odbrana naša,
\q2 i od Svetog Izrailjevog car naš.
\b
\q1 
\v 19 Tada si govorio u utvari vernima svojim, i rekao:
\q2 „Poslah pomoć junaku,
\q2 uzvisih izbranog svog iz naroda.
\q1 
\v 20 Nađoh Davida, slugu svog,
\q2 svetim uljem svojim pomazah ga.
\q1 
\v 21 Ruka će moja biti jednako s njim,
\q2 i mišica moja krepiće ga.
\q1 
\v 22 Neće ga neprijatelj nadvladati,
\q2 i sin bezakonja neće mu dosaditi.
\q1 
\v 23 Potrću pred licem njegovim neprijatelje njegove,
\q2 i nenavidnike njegove poraziću.
\q1 
\v 24 Istina je moja i milost moja s njim;
\q2 i u moje ime uzvisiće se rog njegov.
\q1 
\v 25 Pružiću na more ruku njegovu,
\q2 i na reke desnicu njegovu.
\q1 
\v 26 On će me zvati:
\q2 Ti si Otac moj, Bog moj i grad spasenja mog.
\q1 
\v 27 I ja ću ga učiniti prvencem,
\q2 višim od careva zemaljskih.
\q1 
\v 28 Doveka ću mu hraniti milost svoju,
\q2 i zavet je moj s njim veran.
\q1 
\v 29 Produžiću seme njegovo doveka,
\q2 i presto njegov kao dane nebeske.
\q1 
\v 30 Ako sinovi njegovi ostave zakon moj,
\q2 i ne uzidu u zapovestima mojim;
\q1 
\v 31 Ako pogaze uredbe moje,
\q2 i zapovesti moje ne sačuvaju,
\q1 
\v 32 Onda ću ih pokarati prutom za nepokornost,
\q2 i ranama za bezakonje njihovo;
\q1 
\v 33 Ali milosti svoje neću uzeti od njega,
\q2 niti ću prevrnuti istinom svojom;
\q1 
\v 34 Neću pogaziti zavet svoj,
\q2 i šta je izašlo iz usta mojih neću poreći.
\q1 
\v 35 Jednom se zakleh svetošću svojom;
\q2 zar da slažem Davidu?
\q1 
\v 36 Seme će njegovo trajati doveka,
\q2 i presto njegov kao sunce preda mnom;
\q1 
\v 37 On će stajati uvek kao mesec
\q2 i verni svedok u oblacima.”
\b
\q1 
\v 38 A sad si odbacio i zanemario,
\q2 razgnevio si se na pomazanika svog;
\q1 
\v 39 Zanemario si zavet sa slugom svojim,
\q2 bacio si na zemlju venac njegov.
\q1 
\v 40 Razvalio si sve ograde njegove,
\q2 gradove njegove obratio si u zidine.
\q1 
\v 41 Plene ga svi koji prolaze onuda,
\q2 posta podsmeh u suseda svojih.
\q1 
\v 42 Uzvisio si desnicu neprijatelja njegovih,
\q2 obradovao si sve protivnike njegove.
\q1 
\v 43 Zavratio si oštrice mača njegovog,
\q2 i nisi ga ukrepio u boju;
\q1 
\v 44 Uzeo si mu svetlost,
\q2 i presto njegov oborio si na zemlju;
\q1 
\v 45 Skratio si dane mladosti njegove
\q2 i obukao ga u sramotu.
\b
\q1 
\v 46 Dokle ćeš se, Gospode, jednako odvraćati,
\q2 dokle će kao oganj plamteti gnev Tvoj?
\q1 
\v 47 Opomeni se kakav je vek moj,
\q2 kako si ni na šta stvorio sve sinove Adamove?
\q1 
\v 48 Koji je čovek živeo i nije smrti video,
\q2 i izbavio dušu svoju iz ruku paklenih?
\b
\q1 
\v 49 Gde su pređašnje milosti Tvoje, Gospode?
\q2 Kleo si se Davidu istinom svojom.
\q1 
\v 50 Opomeni se, Gospode, prekora slugu svojih,
\q2 koji nosim u nedrima svojim od svih silnih naroda,
\q1 
\v 51 Kojim kore neprijatelji Tvoji, Gospode,
\q2 kojim kore trag pomazanika Tvog.
\b
\q1 
\v 52 Blagosloven Gospod uvek!
\q2 Amin, amin.
\c 90
\cl Psalam 90
\s1 Bog je večan, grešni su ljudi prolazni. Molitva za milost.
\d Molitva Mojsija, čoveka Božijeg.
\q1 
\v 1 Gospode! Ti si nam utočište od kolena do kolena.
\q1 
\v 2 Pre nego se gore rodiše
\q2 i sazda se zemlja i vasiljena,
\q2 i od veka doveka, Ti si Bog.
\b
\q1 
\v 3 Ti vraćaš čoveka u trulež,
\q2 i govoriš: Vratite se sinovi ljudski!
\q1 
\v 4 Jer je hiljada godina pred očima Tvojim
\q2 kao dan jučerašnji, kad mine,
\q2 i kao straža noćna.
\b
\q1 
\v 5 Ti ih kao povodnjem odnosiš;
\q2 oni su kao san, kao trava, koja rano vene,
\q1 
\v 6 Ujutru cveta i uvene,
\q2 uveče se pokosi i sasuši.
\b
\q1 
\v 7 Jer nas nestaje od gneva Tvog,
\q2 i od jarosti Tvoje u smetnji smo.
\q1 
\v 8 Stavio si bezakonja naša preda se,
\q2 i tajne naše na svetlost lica svog.
\b
\q1 
\v 9 Svi se dani naši prekraćuju od srdnje Tvoje,
\q2 godine naše prolaze kao glas.
\q1 
\v 10 Dana godina naših svega ima do sedamdeset godina,
\q2 a u jačeg do osamdeset godina:
\q1 i sam je cvet njihov muka i nevolja;
\q2 jer teku brzo, i mi odlećemo.
\q1 
\v 11 Ko zna silu gneva Tvog i Tvoju jarost,
\q2 da bi Te se kao što treba bojao?
\b
\q1 
\v 12 Nauči nas tako brojati dane naše,
\q2 da bismo stekli srce mudro.
\q1 
\v 13 Povrati se, Gospode! Dokle ćeš?
\q2 Smiluj se na sluge svoje.
\q1 
\v 14 Ujutru nas nasiti dobrote svoje,
\q2 i radovaćemo se i veseliti u sve dane svoje.
\q1 
\v 15 Obraduj nas prema danima, u koje si nas mučio,
\q2 i prema godinama, u koje smo gledali nevolju.
\q1 
\v 16 Neka se pokaže na slugama Tvojim delo Tvoje,
\q2 i slava Tvoja na sinovima njihovim.
\q1 
\v 17 Neka bude dobra volja Gospoda Boga našeg s nama,
\q2 i delo ruku naših dovrši nam,
\q2 i delo ruku naših dovrši.
\c 91
\cl Psalam 91
\s1 Svemogući Bog je zaštita u svim opasnostima.
\q1 
\v 1 Koji živi u zaklonu Višnjeg,
\q2 u senu Svemogućeg počiva.
\q1 
\v 2 Govori Gospodu: Ti si utočište moje
\q2 i branič moj,
\q2 Bog moj, u kog se uzdam.
\b
\q1 
\v 3 On će te izbaviti iz zamke ptičareve,
\q2 i od ljutog pomora;
\q1 
\v 4 Perjem svojim oseniće te,
\q2 i pod krilima Njegovim zaklonićeš se;
\q2 istina je Njegova štit i ograda.
\q1 
\v 5 Nećeš se bojati strahote noćne,
\q2 strele, koja leti danju,
\q1 
\v 6 Pomora, koji ide po mraku,
\q2 bolesti, koja u podne mori.
\b
\q1 
\v 7 Pašće pored tebe hiljada
\q2 i deset hiljada s desne strane tebi,
\q2 a tebe se neće dotaći.
\q1 
\v 8 Samo ćeš gledati očima svojim,
\q2 i videćeš platu bezbožnicima.
\b
\q1 
\v 9 Jer si Ti, Gospode, pouzdanje moje.
\q2 Višnjeg si izabrao sebi za utočište.
\q1 
\v 10 Neće Te zlo zadesiti,
\q2 i udarac neće dosegnuti do kolibe Tvoje.
\b
\q1 
\v 11 Jer anđelima svojim zapoveda za Tebe
\q2 da Te čuvaju po svim putevima Tvojim.
\q1 
\v 12 Na ruke će Te uzeti
\q2 da gde ne zapneš za kamen nogom svojom.
\q1 
\v 13 Na lava i na aspidu nastupaćeš
\q2 i gazićeš lavića i zmaja.
\b
\q1 
\v 14 „Kad me ljubi, izbaviću Ga;
\q2 zakloniću Ga, kad je poznao ime moje.
\q1 
\v 15 Zazvaće me, i uslišiću Ga;
\q2 s Njim ću biti u nevolji, izbaviću Ga
\q2 i proslaviću Ga.
\q1 
\v 16 Dugog života nasitiću Ga,
\q2 i pokazaću mu spasenje svoje.”
\c 92
\cl Psalam 92
\s1 Hvala Bogu koji kažnjava bezbožnike i blagosilja pravednike.
\d Psalam. Pesma za subotu.
\q1 
\v 1 Lepo je hvaliti Gospoda,
\q2 i pevati imenu Tvom, Višnji,
\q1 
\v 2 Javljati jutrom milost Tvoju,
\q2 i istinu Tvoju noću,
\q1 
\v 3 Uz deset žica i uz psaltir,
\q2 i uz jasne gusle!
\q1 
\v 4 Jer si me razveselio, Gospode, delima svojim,
\q2 s dela ruku Tvojih radujem se.
\b
\q1 
\v 5 Kako su velika dela Tvoja, Gospode!
\q2 Veoma su duboke pomisli Tvoje.
\q1 
\v 6 Bezumnik ne zna,
\q2 i neznalica ne razume to.
\q1 
\v 7 Kad bezbožnici niču kao trava
\q2 i cvetaju svi koji čine bezakonje,
\q2 to biva zato da bi se istrebili doveka.
\q1 
\v 8 A Ti si, Gospode, visok uvek.
\q1 
\v 9 Jer evo neprijatelji Tvoji, Gospode,
\q2 jer evo neprijatelji Tvoji ginu,
\q2 i rasipaju se svi koji čine bezakonje;
\b
\q1 
\v 10 A moj rog Ti uzvišuješ kao rog u jednoroga,
\q2 ja sam pomazan novim uljem.
\q1 
\v 11 I oko moje vidi neprijatelje moje,
\q2 i o bezakonicima, koji ustaju na mene,
\q2 slušaju uši moje.
\b
\q1 
\v 12 Pravednik se zeleni kao Finik,
\q2 kao kedar na Livanu uzvišuje se.
\q1 
\v 13 Koji su zasađeni u domu Gospodnjem,
\q2 zelene se u dvorovima Boga našeg;
\q1 
\v 14 Rodni su i u starosti,
\q2 jedri i zeleni,
\q1 
\v 15 Javljajući da je pravedan Gospod, branič moj,
\q2 i da nema u Njemu nepravde.
\c 93
\cl Psalam 93
\s1 Veličanstvo carstva Božijeg.
\q1 
\v 1 Gospod caruje. Obukao se u veličanstvo,
\q2 obukao se Gospod u silu, i opasao se.
\q1 Zato je vasiljena tvrda,
\q2 i neće se pomeriti.
\q1 
\v 2 Presto Tvoj stoji od iskona;
\q2 od veka Ti si.
\b
\q1 
\v 3 Podižu reke, Gospode, podižu reke glas svoj,
\q2 podižu reke vale svoje:
\q1 
\v 4 Od hujanja vode mnoge i silne,
\q2 od vala morskih silniji je na visini Gospod.
\b
\q1 
\v 5 Svedočanstva su Tvoja veoma tvrda;
\q2 domu Tvom pripada svetlost, Gospode, na dugo vreme.
\c 94
\cl Psalam 94
\s1 Molitva protiv ugnjetača naroda Gospodnjeg.
\q1 
\v 1 Bože od osvete, Gospode,
\q2 Bože od osvete, pokaži se!
\q1 
\v 2 Podigni se, sudijo zemaljski,
\q2 podaj zaslugu oholima.
\q1 
\v 3 Dokle će se bezbožnici, Gospode,
\q2 dokle će se bezbožnici hvaliti?
\q1 
\v 4 Ruže i oholo govore,
\q2 veličaju se svi koji čine bezakonje.
\q1 
\v 5 Gaze narod Tvoj, Gospode,
\q2 i dostojanje Tvoje muče.
\q1 
\v 6 Udovicu i došljaka ubijaju,
\q2 i sirote more.
\q1 
\v 7 I govore: Neće videti Gospod,
\q2 i neće doznati Bog Jakovljev.
\b
\q1 
\v 8 Orazumite se, preludi ljudi!
\q2 Budale! Kad ćete biti pametni?
\q1 
\v 9 Koji je stvorio uho, zar ne čuje?
\q2 I koji je oko načinio, zar ne vidi?
\q1 
\v 10 Zar neće obličiti koji narode urazumljuje,
\q2 koji uči čoveka da zna?
\q1 
\v 11 Gospod zna misli ljudima kako su ništave.
\b
\q1 
\v 12 Blago čoveku koga Ti, Gospode, urazumljuješ,
\q2 i zakonom svojim učiš;
\q1 
\v 13 Da bi mu dao mir u zle dane,
\q2 dok se iskopa jama bezbožniku.
\q1 
\v 14 Jer neće odbaciti Gospod narod svoj,
\q2 i dostojanje svoje neće ostaviti.
\q1 
\v 15 Jer će se sud vratiti na pravdu,
\q2 u njega će naći svi pravog srca.
\b
\q1 
\v 16 Ko će ustati za mene suprot zlima?
\q2 Ko će stati za mene suprot onima koji čine bezakonje?
\q1 
\v 17 Kad mi Gospod ne bi bio pomoćnik,
\q2 brzo bi se duša moja preselila onamo gde se ćuti.
\q1 
\v 18 Kad kažem: Drhće mi noga,
\q2 milost Tvoja, Gospode, prihvata me.
\q1 
\v 19 Kad se umnože brige u srcu mom,
\q2 utehe Tvoje razgovaraju dušu moju.
\q1 
\v 20 Eda li će se blizu Tebe stati presto krvnički,
\q2 i onaj koji namišlja nasilje nasuprot zakonu?
\q1 
\v 21 Spremaju se na dušu pravednikovu,
\q2 i krv pravu okrivljuju.
\q1 
\v 22 Ali je Gospod moje pristanište,
\q2 i Bog je moj tvrdo utočište moje.
\q1 
\v 23 On će im vratiti za bezakonje njihovo,
\q2 za njihovu zloću istrebiće ih,
\q2 istrebiće ih Gospod, Bog naš.
\c 95
\cl Psalam 95
\s1 Pozivanje na hvaljenje Boga. Opomena neposlušnim.
\q1 
\v 1 Hodite, zapevajmo Gospodu,
\q2 pokliknimo Bogu, gradu spasenja svog!
\q1 
\v 2 Izađimo pred lice Njegovo s hvalom,
\q2 u pesmama pokliknimo Mu!
\q1 
\v 3 Jer je Gospod velik Bog
\q2 i velik Car nad svim bogovima.
\q1 
\v 4 U Njegovoj su ruci dubine zemaljske,
\q2 i visine gorske Njegove su.
\q1 
\v 5 Njegovo je more i On ga je stvorio,
\q2 i suhotu ruke su Njegove načinile.
\b
\q1 
\v 6 Hodite, poklonimo se, pripadnimo,
\q2 kleknimo pred Gospodom, Tvorcem svojim.
\q1 
\v 7 Jer je On Bog naš,
\q2 i mi narod paše Njegove
\q2 i ovce ruke Njegove.
\q1 Sad kad biste poslušali glas Njegov:
\q2 
\v 8 „Nemojte da vam odrveni srce vaše
\q2 kao u Merivi, kao u dan kušanja u pustinji,
\q1 
\v 9 Gde me kušaše oci vaši,
\q2 ispitaše i videše delo moje.
\q1 
\v 10 Četrdeset godina srdih se na rod onaj, i rekoh:
\q2 Ovi ljudi tumaraju srcem,
\q2 i ne znaju puteve moje;
\q1 
\v 11 I zato se zakleh u gnevu svom
\q2 da neće ući u mir moj.”
\c 96
\cl Psalam 96
\s1 Poklič narodima o carstvu Božijem.
\q1 
\v 1 Pevajte Gospodu pesmu novu,
\q2 pevaj Gospodu, sva zemljo!
\q1 
\v 2 Pevajte Gospodu, blagosiljajte ime Njegovo,
\q2 javljajte od dana na dan spasenje Njegovo.
\q1 
\v 3 Kazujte po narodima slavu Njegovu,
\q2 po svim plemenima čudesa Njegova.
\q1 
\v 4 Jer je velik Gospod i valja Ga hvaliti:
\q2 strašniji je od svih bogova.
\q1 
\v 5 Jer su svi bogovi u naroda ništa;
\q2 a Gospod je nebesa stvorio.
\q1 
\v 6 Slava je i veličanstvo pred licem Njegovim,
\q2 sila i krasota u svetinji Njegovoj.
\b
\q1 
\v 7 Dajte, Gospodu, plemena narodna,
\q2 dajte Gospodu slavu i čast.
\q1 
\v 8 Dajte Gospodu slavu prema imenu Njegovom.
\q2 Nosite dare i idite u dvore Njegove.
\q1 
\v 9 Poklonite se Gospodu u svetoj krasoti.
\q2 Strepi pred Njim, sva zemljo!
\b
\q1 
\v 10 Recite narodima: Gospod caruje;
\q2 zato je vasiljena tvrda i neće se pomestiti;
\q2 On će suditi narodima pravo.
\b
\q1 
\v 11 Nek se vesele nebesa, i zemlja se raduje;
\q2 nek pljeska more i šta je u njemu;
\q1 
\v 12 Neka skače polje i sve što je na njemu;
\q2 tada nek se raduju sva drveta šumska
\q2 
\v 13 Pred licem Gospodnjim;
\q1 jer ide, jer ide da sudi zemlji.
\q2 Sudiće vasiljenoj po pravdi,
\q2 i narodima po istini svojoj.
\c 97
\cl Psalam 97
\s1 Sion se raduje što je Bog visok nad svom zemljom.
\q1 
\v 1 Gospod caruje: nek se raduje zemlja!
\q2 Nek se vesele ostrva mnoga.
\q1 
\v 2 Oblak je i mrak oko Njega;
\q2 blagost i pravda podnožje prestolu njegovom.
\q1 
\v 3 Oganj pred Njim ide,
\q2 i pali naokolo neprijatelje Njegove.
\q1 
\v 4 Munje Njegove sevaju po vasiljenoj;
\q2 vidi i strepi zemlja.
\q1 
\v 5 Gore kao vosak tope se od lica Gospodnjeg,
\q2 od lica Gospoda svoj zemlji.
\b
\q1 
\v 6 Nebesa kazuju pravdu Njegovu,
\q2 i svi narodi vide slavu Njegovu.
\q1 
\v 7 Nek se stide svi koji se klanjaju kipovima,
\q2 koji se hvale idolima svojim.
\q2 Poklonite Mu se svi bogovi.
\b
\q1 
\v 8 Čuje i raduje se Sion,
\q2 i kćeri se judejske vesele
\q2 radi sudova Tvojih, Gospode!
\q1 
\v 9 Jer si Ti, Gospode, visok nad svom zemljom
\q2 i nadvišuješ sve bogove.
\b
\q1 
\v 10 Koji ljubite Gospoda, mrzite na zlo.
\q2 On čuva duše svetaca svojih;
\q2 iz ruku bezbožničkih otima ih.
\q1 
\v 11 Svetlost se prosipa na pravednika,
\q2 i veselje na one koji su pravog srca.
\q1 
\v 12 Radujte se pravedni o Gospodu,
\q2 i slavite sveto ime Njegovo.
\c 98
\cl Psalam 98
\s1 Klicanje i popevanje o pobedama Gospodnjim po svem svetu.
\d Psalam.
\q1 
\v 1 Pojte Gospodu pesmu novu,
\q2 jer učini čudesa.
\q1 Pomože Mu desnica Njegova
\q2 i sveta mišica Njegova.
\q1 
\v 2 Javi Gospod spasenje svoje,
\q2 pred narodima otkri pravdu svoju.
\q1 
\v 3 Opomenu se milosti svoje
\q2 i vernosti svoje k domu Izrailjevom.
\q1 Videše svi krajevi zemaljski
\q2 spasenje Boga našeg.
\b
\q1 
\v 4 Raduj se Gospodu, sva zemljo;
\q2 pevajte, poklikujte i popevajte!
\q1 
\v 5 Udarajte Gospodu u gusle,
\q2 u gusle i s glasom psalamskim.
\q1 
\v 6 U trube i rogove zatrubite
\q2 pred carem Gospodom.
\b
\q1 
\v 7 Neka pljeska more i šta je u njemu,
\q2 vasiljena i koji u njoj žive;
\q1 
\v 8 Reke neka pljeskaju rukama;
\q2 skupa gore nek se raduju
\q1 
\v 9 Pred licem Gospodnjim;
\q2 jer ide da sudi zemlji;
\q1 sudiće vasiljenoj pravedno,
\q2 i narodima verno.
\c 99
\cl Psalam 99
\s1 Svetost vlada u carstvu Gospodnjem.
\q1 
\v 1 Gospod caruje: neka strepe narodi;
\q2 sedi na heruvimima: nek se drma zemlja!
\q1 
\v 2 Gospod je na Sionu velik,
\q2 i visok nad svima narodima.
\q1 
\v 3 Neka slave veliko i strašno ime Tvoje;
\q2 da je svet!
\q1 
\v 4 Neka slave silu cara koji ljubi pravdu.
\q2 Ti si utvrdio pravdu;
\q2 sud i pravdu Ti si uredio u Jakovu.
\q1 
\v 5 Uzvišujte Gospoda Boga našeg,
\q2 i klanjajte se podnožju Njegovom;
\q2 da je svet!
\b
\q1 
\v 6 Mojsije i Aron, sveštenici Njegovi,
\q2 i Samuilo jedan od onih koji prizivaju ime Njegovo,
\q2 prizivahu Boga, i On ih usliši.
\q1 
\v 7 U stupu od oblaka govoraše njima;
\q2 oni čuvaše zapovesti Njegove
\q2 i uredbu koju im dade.
\b
\q1 
\v 8 Gospode, Bože naš,
\q2 Ti si ih uslišio;
\q1 Ti si im bio Bog blag
\q2 i plaćao za dela njihova.
\q1 
\v 9 Uzvišujte Gospoda Boga našeg,
\q2 i klanjajte se na svetoj gori Njegovoj,
\q2 jer je svet Gospod Bog naš.
\c 100
\cl Psalam 100
\s1 Pohvalna pesma za narod Božiji.
\d Psalam pohvalan.
\q1 
\v 1 Raduj se Gospodu, sva zemljo!
\q2 
\v 2 Služite Gospodu veselo;
\q2 idite pred lice Njegovo pevajući!
\b
\q1 
\v 3 Poznajte Gospod da je Bog.
\q2 On nas je stvorio, i mi smo dostojanje Njegovo,
\q2 narod Njegov i ovce paše Njegove.
\b
\q1 
\v 4 Ulazite na vrata Njegova sa slavom,
\q2 u dvore Njegove s hvalom.
\q2 Slavite Ga, i blagosiljajte ime Njegovo.
\b
\q1 
\v 5 Jer je dobar Gospod;
\q2 milost je Njegova uvek,
\q2 i istina Njegova od kolena na koleno.
\c 101
\cl Psalam 101
\s1 Ogledalo vlade Davidove.
\d Psalam Davidov.
\q1 
\v 1 Milost i pravdu pevam;
\q2 Tebe, Gospode, slavim.
\q1 
\v 2 Razmišljam o putu pravom,
\q2 kad bi god došao k meni,
\q1 hodim u bezazlenosti srca svog
\q2 u domu svom.
\q1 
\v 3 Ne stavljam pred oči svoje reči nepotrebne,
\q2 mrzim na dela koja su protiv zakona, ne pristajem za njima.
\q1 
\v 4 Srce pokvareno daleko je od mene;
\q2 zlih ne znam.
\b
\q1 
\v 5 Ko tajno opada bližnjeg svog,
\q2 tog izgonim;
\q1 ko je oholog oka i nadutog srca,
\q2 tog ne trpim.
\b
\q1 
\v 6 Oči su moje obraćene na verne na zemlji,
\q2 da bi sedeli sa mnom.
\q1 Ko hodi putem pravim,
\q2 taj služi meni.
\b
\q1 
\v 7 Ne živi u domu mom
\q2 koji radi lukavo;
\q1 koji govori laž,
\q2 ne stoji pred očima mojim.
\b
\q1 
\v 8 Jutrom zatirem sve bezbožnike na zemlji,
\q2 da bih istrebio iz grada Gospodnjeg sve koji čine bezakonje.
\c 102
\cl Psalam 102
\s1 Pokajnička molitva da Gospod opet podigne Sion.
\d Molitva nevoljnoga, kad mu je teško, pa pred Gospodom izliva tugu svoju.
\q1 
\v 1 Gospode! Čuj molitvu moju,
\q2 i vika moja nek izađe preda Te.
\q1 
\v 2 Nemoj odvratiti lice svoje od mene;
\q2 u dan kad sam u nevolji prigni k meni uho svoje,
\q1 u dan kad Te prizivam, pohitaj, usliši me.
\b
\q1 
\v 3 Jer prođoše kao dim dani moji,
\q2 kosti moje kao topionica ogoreše.
\q1 
\v 4 Pokošeno je kao trava i posahlo srce moje,
\q2 da zaboravih jesti hleb svoj.
\q1 
\v 5 Od uzdisanja mog
\q2 prionu kost moja za meso moje.
\q1 
\v 6 Postadoh kao gem u pustinji;
\q2 ja sam kao sova na zidinama.
\q1 
\v 7 Ne spavam,
\q2 i sedim kao ptica bez druga na krovu.
\q1 
\v 8 Svaki dan ruže me neprijatelji moji,
\q2 i koji su se pomamili na mene, mnom se uklinju.
\q1 
\v 9 Jedem pepeo kao hleb,
\q2 i piće svoje rastvaram suzama.
\q1 
\v 10 Od gneva Tvog i srdnje Tvoje;
\q2 jer podigavši me bacio si me.
\q1 
\v 11 Dani su moji kao sen, koji prolazi,
\q2 i ja kao trava osuših se.
\b
\q1 
\v 12 A Ti, Gospode, ostaješ doveka,
\q2 i spomen Tvoj od kolena do kolena.
\q1 
\v 13 Ti ćeš ustati, smilovaćeš se na Sion,
\q2 jer je vreme smilovati se na nj,
\q2 jer je došlo vreme;
\q1 
\v 14 Jer slugama Tvojim omile i kamenje njegovo,
\q2 i prah njegov žale.
\q1 
\v 15 Tada će se neznabošci bojati imena Gospodnjeg,
\q2 i svi carevi zemaljski slave Njegove;
\q1 
\v 16 Jer će Gospod sazidati Sion,
\q2 i javiti se u slavi svojoj;
\q1 
\v 17 Pogledaće na molitvu onih koji nemaju pomoći,
\q2 i neće se oglušiti molbe njihove.
\b
\q1 
\v 18 Napisaće se ovo potonjem rodu,
\q2 i narod nanovo stvoren hvaliće Gospoda.
\q1 
\v 19 Što je prinikao sa svete visine svoje,
\q2 Gospod pogledao s neba na zemlju.
\q1 
\v 20 Da čuje uzdisanje sužnjevo,
\q2 i odreši sinove smrtne;
\q1 
\v 21 Da bi kazivali na Sionu ime Gospodnje
\q2 i hvalu Njegovu u Jerusalimu,
\q1 
\v 22 Kad se skupe narodi i carstva
\q2 da služe Gospodu.
\b
\q1 
\v 23 Strošio je na putu krepost moju,
\q2 skratio dane moje.
\q1 
\v 24 Rekoh: Bože moj! Nemoj me uzeti u polovini dana mojih.
\q2 Tvoje su godine od kolena do kolena.
\b
\q1 
\v 25 Davno si postavio zemlju,
\q2 i nebesa su delo ruku Tvojih.
\q1 
\v 26 To će proći, a Ti ćeš ostati;
\q2 sve će to kao haljina ovetšati,
\q2 kao haljinu promenićeš ih i promeniće se.
\q1 
\v 27 Ali Ti si taj isti
\q2 i godine Tvoje neće isteći.
\q1 
\v 28 Sinovi će sluga Tvojih živeti,
\q2 i seme će se njihovo utvrditi pred licem Tvojim.
\c 103
\cl Psalam 103
\s1 Slavljenje milosti Božije prema grešnim i slabim ljudima.
\d Psalam Davidov.
\q1 
\v 1 Blagosiljaj, dušo moja, Gospoda,
\q2 i sve što je u meni sveto ime Njegovo.
\q1 
\v 2 Blagosiljaj, dušo moja, Gospoda,
\q2 i ne zaboravljaj nijedno dobro što ti je učinio.
\q1 
\v 3 On ti prašta sve grehe
\q2 i isceljuje sve bolesti tvoje;
\q1 
\v 4 Izbavlja od groba život tvoj,
\q2 venčava te dobrotom i milošću;
\q1 
\v 5 Ispunja dobrim želje tvoje,
\q2 ponavlja se kao u orla mladost tvoja.
\b
\q1 
\v 6 Gospod tvori pravdu i sud
\q2 svima kojima se krivo čini.
\q1 
\v 7 Pokaza puteve svoje Mojsiju,
\q2 sinovima Izrailjevim dela svoja.
\q1 
\v 8 Milostiv je i dobar Gospod,
\q2 spor na gnev i veoma blag.
\q1 
\v 9 Ne gnevi se jednako,
\q2 niti se doveka srdi.
\q1 
\v 10 Ne postupa s nama po gresima našim,
\q2 niti nam vraća po nepravdama našim.
\q1 
\v 11 Nego koliko je nebo visoko od zemlje,
\q2 tolika je milost Njegova k onima koji Ga se boje.
\q1 
\v 12 Koliko je istok daleko od zapada,
\q2 toliko udaljuje od nas bezakonja naša.
\q1 
\v 13 Kako otac žali sinove,
\q2 tako Gospod žali one koji Ga se boje.
\q1 
\v 14 Jer zna građu našu,
\q2 opominje se da smo prah.
\b
\q1 
\v 15 Dani su čovečiji kao trava;
\q2 kao cvet u polju, tako cveta.
\q1 
\v 16 Dune vetar na nj, i nestane ga,
\q2 niti će ga više poznati mesto njegovo.
\q1 
\v 17 Ali milost Gospodnja ostaje od veka i doveka
\q2 na onima koji Ga se boje,
\q2 i pravda Njegova na sinovima sinova,
\q1 
\v 18 Koji drže zavet Njegov, i pamte zapovesti Njegove,
\q2 da ih izvršuju.
\q1 
\v 19 Gospod na nebesima postavi presto svoj,
\q2 i carstvo Njegovo svim vlada.
\b
\q1 
\v 20 Blagosiljajte Gospoda anđeli Njegovi,
\q2 koji ste silni krepošću izvršujete reč Njegovu slušajući glas reči Njegove.
\q1 
\v 21 Blagosiljajte Gospoda sve vojske Njegove,
\q2 sluge Njegove, koje tvorite volju Njegovu.
\q1 
\v 22 Blagosiljajte Gospoda sva dela Njegova,
\q2 po svim mestima vlade Njegove!
\q1 Blagosiljaj, dušo moja Gospoda!
\c 104
\cl Psalam 104
\s1 Slava Božija u delima njegovim.
\q1 
\v 1 Blagosiljaj, dušo moja, Gospoda!
\q2 Gospode, Bože moj, velik si veoma,
\q2 obukao si se u veličanstvo i krasotu.
\q1 
\v 2 Obukao si svetlost kao haljinu,
\q2 razapeo nebo kao šator;
\q1 
\v 3 Vodom si pokrio dvorove svoje,
\q2 oblake načinio si da su Ti kola,
\q2 ideš ne krilima vetrenim.
\q1 
\v 4 Činiš vetrove da su Ti anđeli,
\q2 plamen ognjeni da su Ti sluge.
\b
\q1 
\v 5 Utvrdio si zemlju na temeljima njenim,
\q2 da se ne pomesti na vek veka.
\q1 
\v 6 Bezdanom kao haljinom odenuo si je;
\q2 na gorama stoje vode.
\q1 
\v 7 Od pretnje Tvoje beže,
\q2 od gromovnog glasa Tvog teku.
\q1 
\v 8 Izlaze na gore i silaze u doline,
\q2 na mesto koje si im utvrdio.
\q1 
\v 9 Postavio si među, preko koje ne prelaze,
\q2 i ne vraćaju se da pokriju zemlju.
\b
\q1 
\v 10 Izveo si izvore po dolinama,
\q2 između gora teku vode.
\q1 
\v 11 Napajaju sve zveri poljske;
\q2 divlji magarci gase žeđ svoju.
\q1 
\v 12 Na njima ptice nebeske žive;
\q2 kroz grane razleže se glas njihov.
\q1 
\v 13 Napajaš gore s visina svojih,
\q2 plodovima dela Tvojih siti se zemlja.
\b
\q1 
\v 14 Daješ te raste trava stoci,
\q2 i zelen na korist čoveku,
\q2 da bi izvadio hleb iz zemlje.
\q1 
\v 15 I vino veseli srce čoveku,
\q2 i lice se svetli od ulja,
\q2 i hleb srce čoveku krepi.
\b
\q1 
\v 16 Site se drveta Božija,
\q2 kedri livanski, koje si posadio.
\q1 
\v 17 Na njima ptice viju gnezda;
\q2 stanak je rodin na jelama.
\q1 
\v 18 Gore visoke divokozama,
\q2 kamen je utočište zečevima.
\b
\q1 
\v 19 Stvorio se mesec da pokazuje vremena,
\q2 sunce poznaje zapad svoj.
\q1 
\v 20 Stereš tamu, i biva noć,
\q2 po kojoj izlazi sve zverje šumsko;
\q1 
\v 21 Lavovi riču za plenom,
\q2 i traže od Boga hrane sebi.
\q1 
\v 22 Sunce grane,
\q2 i oni se sakrivaju i ležu u lože svoje.
\q1 
\v 23 Izlazi čovek na posao svoj,
\q2 i na rad svoj do večera.
\b
\q1 
\v 24 Kako je mnogo dela Tvojih, Gospode!
\q2 Sve si premudro stvorio;
\q2 puna je zemlja blaga Tvog.
\q1 
\v 25 Gle, more veliko i široko,
\q2 tu gmižu bez broja, životinja mala i velika;
\q1 
\v 26 Tu lađe plove,
\q2 krokodil, kog si stvorio da se igra po njemu.
\b
\q1 
\v 27 Sve Tebe čeka,
\q2 da im daješ piću na vreme.
\q1 
\v 28 Daješ im, primaju;
\q2 otvoriš ruku svoju, site se dobra.
\q1 
\v 29 Odvratiš lice svoje, žaloste se;
\q2 uzmeš im duh, ginu,
\q2 i u prah svoj vraćaju se.
\q1 
\v 30 Pošalješ duh svoj, postaju,
\q2 i ponavljaš lice zemlji.
\b
\q1 
\v 31 Slava Gospodu uvek;
\q2 nek se veseli Gospod za dela svoja!
\q1 
\v 32 On pogleda na zemlju, i ona se trese;
\q2 dotakne se gora, i dime se.
\q1 
\v 33 Pevaću Gospodu za života svog;
\q2 hvaliću Boga svog dok sam god.
\q1 
\v 34 Neka Mu bude mila beseda moja!
\q2 Veseliću se o Gospodu.
\q1 
\v 35 Neka nestane grešnika sa zemlje,
\q2 i bezbožnika neka ne bude više!
\q1 Blagosiljaj, dušo moja, Gospoda!
\q2 Aliluja!
\c 105
\cl Psalam 105
\s1 Veličanje Gospoda zbog njegovih dobročinstava prema Izrailju.
\q1 
\v 1 Hvalite Gospoda;
\q2 glasite ime Njegovo;
\q2 javljajte po narodima dela Njegova.
\q1 
\v 2 Pevajte Mu i slavite Ga;
\q2 kazujte sva čudesa Njegova.
\q1 
\v 3 Hvalite se svetim imenom Njegovim;
\q2 nek se veseli srce onih koji traže Gospoda.
\q1 
\v 4 Tražite Gospoda i silu Njegovu,
\q2 tražite lice Njegovo bez prestanka.
\q1 
\v 5 Pamtite čudesa Njegova koja je učinio,
\q2 znake Njegove i sudove usta Njegovih.
\q1 
\v 6 Seme Avramovo sluge su Njegove,
\q2 sinovi Jakovljevi izabrani Njegovi.
\b
\q1 
\v 7 On je Gospod Bog naš,
\q2 po svoj su zemlji sudovi Njegovi.
\q1 
\v 8 Pamti uvek zavet svoj,
\q2 reč, koju je dao na hiljadu kolena.
\q1 
\v 9 Šta je zavetovao Avramu,
\q2 i za šta se kleo Isaku.
\q1 
\v 10 To je postavio Jakovu za zakon,
\q2 i Izrailju za zavet večni,
\q1 
\v 11 Govoreći: Tebi ću dati zemlju hanansku u nasledni deo.
\b
\q1 
\v 12 Tada ih još beše malo na broj,
\q2 beše ih malo, i behu došljaci.
\q1 
\v 13 Iđahu od naroda do naroda,
\q2 iz jednog carstva k drugom plemenu.
\q1 
\v 14 Ne dade nikome da im naudi,
\q2 i karaše za njih careve:
\q1 
\v 15 „Ne dirajte u pomazanike moje,
\q2 i prorocima mojim ne činite zla.”
\b
\q1 
\v 16 I pusti glad na onu zemlju;
\q2 i potre sav hleb što je za hranu.
\q1 
\v 17 Posla pred njima čoveka;
\q2 u roblje prodan bi Josif.
\q1 
\v 18 Okovima stegoše noge njegove,
\q2 gvožđe tištaše dušu njegovu,
\q1 
\v 19 Dok se steče reč njegova,
\q2 i reč Gospodnja proslavi ga.
\q1 
\v 20 Posla car i odreši ga;
\q2 gospodar nad narodima, i pusti ga.
\q1 
\v 21 Postavi ga gospodarem nad domom svojim,
\q2 i zapovednikom nad svim što imaše.
\q1 
\v 22 Da vlada nad knezovima njegovim po svojoj volji,
\q2 i starešine njegove urazumljuje.
\b
\q1 
\v 23 Tada dođe Izrailj u Misir,
\q2 i Jakov se preseli u zemlju Hamovu.
\q1 
\v 24 I namnoži Bog narod svoj
\q2 i učini ga jačeg od neprijatelja njegovih.
\q1 
\v 25 Prevrnu se srce njihovo te omrznuše na narod Njegov,
\q2 i činiše lukavstvo slugama Njegovim.
\b
\q1 
\v 26 Posla Mojsija, slugu svog,
\q2 Arona izabranika svog.
\q1 
\v 27 Pokazaše među njima čudotvornu silu Njegovu
\q2 i znake Njegove u zemlji Hamovoj.
\q1 
\v 28 Pusti mrak i zamrači,
\q2 i ne protiviše se reči Njegovoj.
\q1 
\v 29 Pretvori vodu njihovu u krv,
\q2 i pomori ribu njihovu.
\q1 
\v 30 Provre zemlja njihova žabama,
\q2 i kleti careva njihovih.
\q1 
\v 31 Reče, i dođoše bubine,
\q2 uši po svim krajevima njihovim.
\q1 
\v 32 Mesto dažda posla na njih grad,
\q2 živi oganj na zemlju njihovu.
\q1 
\v 33 I pobi čokote njihove i smokve njihove,
\q2 i potre drveta u krajevima njihovim.
\q1 
\v 34 Reče, i dođoše skakavci
\q2 i gusenice nebrojene;
\q1 
\v 35 I izjedoše svu travu po zemlji njihovoj,
\q2 i pojedoše rod u polju njihovu.
\q1 
\v 36 I pobi sve prvence u zemlji njihovoj,
\q2 prvine svakog truda njihovog.
\b
\q1 
\v 37 Izvede Izrailjce sa srebrom i zlatom,
\q2 i ne beše sustala u plemenima njihovim.
\q1 
\v 38 Obradova se Misir izlasku njihovom,
\q2 jer strah njihov beše na nj pao.
\b
\q1 
\v 39 Razastre im oblak za pokrivač,
\q2 i oganj da svetli noću.
\q1 
\v 40 Moliše, i posla im prepelice,
\q2 i hlebom ih nebeskim hrani.
\q1 
\v 41 Otvori kamen i proteče voda,
\q2 reke protekoše po suvoj pustinji.
\q1 
\v 42 Jer se opominjaše svete reči svoje k Avramu,
\q2 sluzi svom.
\b
\q1 
\v 43 I izvede narod svoj u radosti,
\q2 izbrane svoje u veselju.
\q1 
\v 44 I dade im zemlju naroda
\q2 i trud tuđinaca u nasledstvo.
\q1 
\v 45 Da bi čuvali zapovesti Njegove,
\q2 i zakone Njegove pazili.
\q1 Aliluja.
\c 106
\cl Psalam 106
\s1 Pesma zahvalnosti na milosti kad je Izrailj zgrešio.
\d Aliluja.
\q1 
\v 1 Hvalite Gospoda,
\q2 jer je dobar,
\q1 jer je doveka milost Njegova.
\q1 
\v 2 Ko će iskazati silu Gospodnju?
\q2 Ispričati svu slavu Njegovu?
\q1 
\v 3 Blago onima koji drže istinu
\q2 i tvore pravo svagda!
\b
\q1 
\v 4 Opomeni me se, Gospode,
\q2 po svojoj milosti k narodu svom;
\q1 pohodi me pomoću svojom,
\q1 
\v 5 Da bih video u dobru izabrane Tvoje,
\q1 veselio se u veselju naroda Tvog,
\q2 hvalio se zajedno s nasledstvom Tvojim.
\b
\q1 
\v 6 Zgrešismo s ocima svojim,
\q2 postasmo krivci, bezakonici.
\q1 
\v 7 Oci naši u Misiru ne razumeše čudesa Tvojih,
\q2 ne opominjaše se velikih milosti Tvojih,
\q2 i vikaše kraj mora, kraj Crvenog Mora.
\q1 
\v 8 Ali im On pomože imena svog radi,
\q2 da bi pokazao silu svoju.
\q1 
\v 9 Zapreti Crvenom Moru, i presahnu;
\q2 i prevede ih preko bezdane kao preko pustinje;
\q1 
\v 10 I sačuva ih od ruke nenavidnikove,
\q2 i izbavi ih iz ruke neprijateljeve.
\q1 
\v 11 Pokri voda neprijatelje njihove,
\q2 nijedan od njih ne osta.
\q1 
\v 12 Tada verovaše rečima Njegovim,
\q2 i pevaše Mu hvalu.
\b
\q1 
\v 13 Ali brzo zaboraviše dela Njegova,
\q2 i ne počekaše volje Njegove.
\q1 
\v 14 Polakomiše se u pustinji,
\q2 i stadoše kušati Boga u zemlji gde se ne živi.
\q1 
\v 15 On ispuni molbu njihovu,
\q2 ali posla pogibao na dušu njihovu.
\b
\q1 
\v 16 Pozavideše Mojsiju
\q2 i Aronu, kog beše Gospod osvetio.
\q1 
\v 17 Rasede se zemlja,
\q2 i proždre Datana i zatrpa četu Avironovu.
\q1 
\v 18 I spali oganj četu njihovu,
\q2 i plamen sažeže bezbožnike.
\b
\q1 
\v 19 Načiniše tele kod Horiva,
\q2 i klanjahu se kipu.
\q1 
\v 20 Menjahu slavu svoju
\q2 na priliku vola, koji jede travu.
\q1 
\v 21 Zaboraviše Boga, Spasitelja svog,
\q2 koji je učinio velika dela u Misiru,
\q1 
\v 22 Divna u zemlji Hamovoj,
\q2 strašna na Crvenom Moru.
\q1 
\v 23 I htede ih istrebiti,
\q2 da Mojsije izabranik Njegov ne stade kao u raselini pred Njim,
\q1 i ne odvrati jarost Njegovu
\q2 da ih ne istrebi.
\b
\q1 
\v 24 Posle ne mariše za zemlju željenu,
\q2 ne verovaše reči Njegovoj.
\q1 
\v 25 Pobuniše se u šatorima svojim,
\q2 ne slušaše glas Gospodnji.
\q1 
\v 26 I On podiže ruku svoju na njih,
\q2 da ih pobije u pustinji,
\q1 
\v 27 Da pobije pleme njihovo među narodima,
\q2 i raseje ih po zemljama.
\b
\q1 
\v 28 I pristaše za Velfegorom,
\q2 i jedoše prineseno na žrtvu mrtvima.
\q1 
\v 29 I rasrdiše Boga delima svojim,
\q2 i udari u njih pogibao.
\q1 
\v 30 I ustade Fines, i umilostivi,
\q2 i prestade pogibao.
\q1 
\v 31 I to mu se primi u pravdu,
\q2 od kolena do kolena doveka.
\b
\q1 
\v 32 I razgneviše Boga na vodi Merivi,
\q2 i Mojsije postrada njih radi;
\q1 
\v 33 Jer dotužiše duhu njegovom,
\q2 i pogreši ustima svojim.
\b
\q1 
\v 34 Ne istrebiše narode,
\q2 za koje im je Gospod rekao;
\q1 
\v 35 Nego se pomešaše s neznabošcima,
\q2 i naučiše dela njihova.
\q1 
\v 36 Stadoše služiti idolima njihovim,
\q2 i oni im biše zamka.
\q1 
\v 37 Sinove svoje i kćeri svoje prinosiše na žrtvu đavolima.
\q1 
\v 38 Prolivaše krv pravu;
\q2 krv sinova svojih i kćeri svojih,
\q2 koje prinošahu na žrtvu idolima hananskim,
\q1 i oskvrni se zemlja krvnim delima.
\q1 
\v 39 Oskvrniše sebe delima svojim,
\q2 i činiše preljubu postupanjem svojim.
\b
\q1 
\v 40 I planu gnev Gospodnji na narod Njegov,
\q2 i omrznu Mu deo Njegov.
\q1 
\v 41 I predade ih u ruke neznabožačke,
\q2 i nenavidnici njihovi stadoše gospodariti nad njima.
\q1 
\v 42 Dosađivaše im neprijatelji njihovi,
\q2 i oni biše pokoreni pod vlast njihovu.
\q1 
\v 43 Mnogo ih je puta izbavljao,
\q2 ali Ga oni srdiše namerama svojim,
\q2 i biše poništeni za bezakonje svoje.
\b
\q1 
\v 44 Ali On pogleda na nevolju njihovu,
\q2 čuvši tužnjavu njihovu,
\q1 
\v 45 I opomenu se zaveta svog s njima,
\q2 i pokaja se po velikoj milosti svojoj;
\q1 
\v 46 I učini, te ih stadoše žaliti
\q2 svi koji ih behu zarobili.
\b
\q1 
\v 47 Spasi nas, Gospode Bože naš,
\q2 i pokupi nas iz neznabožaca,
\q1 da slavimo sveto ime Tvoje,
\q2 da se hvalimo Tvojom slavom!
\b
\q1 
\v 48 Blagosloven Gospod Bog Izrailjev
\q2 od veka i doveka!
\q1 I sav narod neka kaže:
\q2 Amin! Aliluja!
\c 107
\cl Psalam 107
\s1 Zahvalna pesma izbavljenih koji su prizivali Gospoda u nevolji.
\q1 
\v 1 Hvalite Gospoda, jer je dobar;
\q2 jer je doveka milost Njegova.
\q1 
\v 2 Tako neka kažu koje je izbavio Gospod,
\q2 koje je izbavio iz ruke neprijateljeve,
\q1 
\v 3 Skupio ih iz zemalja,
\q2 od istoka i zapada, od severa i mora.
\b
\q1 
\v 4 Lutaše po pustinji gde se ne živi,
\q2 puta gradu naseljenom ne nahodiše;
\q1 
\v 5 Behu gladni i žedni,
\q2 i duša njihova iznemagaše u njima;
\q1 
\v 6 Ali zavikaše ka Gospodu u tuzi svojoj;
\q2 i izbavi ih iz nevolje njihove.
\q1 
\v 7 I izvede ih na prav put,
\q2 koji ide u grad naseljeni.
\q1 
\v 8 Neka hvale Gospoda za milost Njegovu,
\q2 i za čudesa Njegova radi sinova ljudskih!
\q1 
\v 9 Jer siti dušu taštu,
\q2 i dušu gladnu puni dobra.
\b
\q1 
\v 10 Sedeše u tami i u senu smrtnom,
\q2 okovani u tugu i u gvožđe;
\q1 
\v 11 Jer ne slušaše reči Božijih,
\q2 i ne mariše za volju Višnjeg.
\q1 
\v 12 On poništi srce njihovo stradanjem;
\q2 spotakoše se, i ne beše koga da pomogne.
\q1 
\v 13 Ali zavikaše ka Gospodu u tuzi svojoj,
\q2 i izbavi ih iz nevolje njihove;
\q1 
\v 14 Izvede ih iz tame i sena smrtnog,
\q2 i raskide okove njihove.
\q1 
\v 15 Neka hvale Gospoda za milost Njegovu,
\q2 i za čudesa Njegova radi sinova ljudskih!
\q1 
\v 16 Jer razbi vrata bronzana,
\q2 i prevornice gvozdene slomi.
\b
\q1 
\v 17 Bezumnici stradaše za nevaljale puteve svoje,
\q2 i za nepravde svoje.
\q1 
\v 18 Svako se jelo gadilo duši njihovoj,
\q2 i dođoše do vrata smrtnih.
\q1 
\v 19 Ali zavikaše ka Gospodu u tuzi svojoj,
\q2 i izbavi ih iz nevolje njihove.
\q1 
\v 20 Posla reč svoju i isceli ih,
\q2 i izbavi ih iz groba njihovog.
\q1 
\v 21 Neka hvale Gospoda za milost Njegovu,
\q2 i za čudesa Njegova radi sinova ljudskih!
\q1 
\v 22 I neka prinesu žrtvu za hvalu,
\q2 i kazuju dela Njegova u pesmama!
\b
\q1 
\v 23 Koji plove po moru na korabljima,
\q2 i rade na velikim vodama,
\q1 
\v 24 Oni su videli dela Gospodnja,
\q2 i čudesa Njegova u dubini.
\q1 
\v 25 Kaže, i diže se silan vetar,
\q2 i ustaju vali na njemu,
\q1 
\v 26 Dižu se do nebesa i spuštaju do bezdana:
\q2 duša se njihova u nevolji razliva;
\q1 
\v 27 Posrću i ljuljaju se kao pijani;
\q2 sve mudrosti njihove nestaje.
\q1 
\v 28 Ali zavikaše ka Gospodu u tuzi svojoj,
\q2 i izvede ih iz nevolje njihove.
\q1 
\v 29 On obraća vetar u tišinu,
\q2 i vali njihovi umuknu.
\q1 
\v 30 Vesele se kad se stišaju,
\q2 i vodi ih u pristanište koje žele.
\q1 
\v 31 Neka hvale Gospoda za milost Njegovu,
\q2 i za čudesa Njegova radi sinova ljudskih!
\q1 
\v 32 Neka Ga uzvišuju na saboru narodnom,
\q2 na skupštini starešinskoj slave Ga!
\b
\q1 
\v 33 On pretvara reke u pustinju,
\q2 i izvore vodene u suhotu,
\q1 
\v 34 Rodnu zemlju u slanu pustaru
\q2 za nevaljalstvo onih koji žive na njoj.
\q1 
\v 35 On pretvara pustinju u jezera,
\q2 i suvu zemlju u izvore vodene,
\q1 
\v 36 I naseljava onamo gladne.
\q2 Oni zidaju gradove za življenje;
\q1 
\v 37 Seju polja,
\q2 sade vinograde
\q2 i sabiraju letinu.
\q1 
\v 38 Blagosilja ih i množe se jako,
\q2 i stoke im ne umanjuje.
\b
\q1 
\v 39 Pre ih beše malo,
\q2 padahu od zla i nevolje, što ih stizaše.
\q1 
\v 40 On sipa sramotu na knezove,
\q2 i ostavlja ih da lutaju po pustinji gde nema puteva.
\q1 
\v 41 On izvlači ubogoga iz nevolje,
\q2 i plemena množi kao stado.
\q1 
\v 42 Dobri vide i raduju se,
\q2 a svako nevaljalstvo zatiskuje usta svoja.
\b
\q1 
\v 43 Ko je mudar, neka zapamti ovo,
\q2 i neka poznaju milosti Gospodnje.
\c 108
\cl Psalam 108
\s1 Veličanje Božije dobrote i vernosti. Molba za pobedu nad neprijateljima.
\d Pesma. Psalam Davidov.
\q1 
\v 1 Gotovo je srce moje, Bože;
\q2 pevaću i hvaliću zajedno sa slavom svojom.
\q1 
\v 2 Preni se psaltire i gusle,
\q2 ustaću rano.
\q1 
\v 3 Slaviću Tebe, Gospode, po narodima,
\q2 pojaću Tebi po plemenima.
\q1 
\v 4 Jer je svrh nebesa milost Tvoja
\q2 i do oblaka istina Tvoja.
\b
\q1 
\v 5 Uzvisi se više nebesa, Bože,
\q2 i po svoj zemlji neka bude slava Tvoja!
\q1 
\v 6 Da bi se izbavili mili Tvoji,
\q2 pomozi desnicom svojom,
\q2 i usliši me.
\b
\q1 
\v 7 Bog reče u svetinji svojoj:
\q1 „Veseliću se,
\q2 razdeliću Sihem,
\q2 i dolinu Sokot razmeriću.
\q1 
\v 8 Moj je Galad, moj je Manasija,
\q2 Jefrem je krepost glave moje,
\q2 Juda skiptar moj.
\q1 
\v 9 Moav je čaša iz koje se umivam,
\q2 Edomu ću pružiti obuću svoju;
\q2 nad zemljom filistejskom popevaću.”
\b
\q1 
\v 10 Ko će me odvesti u tvrdi grad?
\q2 Ko će me otpratiti do Edoma?
\q1 
\v 11 Zar nećeš Ti, Bože, koji si nas odbacio,
\q2 i ne ideš, Bože, s vojskama našim?
\q1 
\v 12 Daj nam pomoć u teskobi,
\q2 odbrana je čovečija uzalud.
\q1 
\v 13 Bogom smo jaki;
\q2 On gazi neprijatelje naše.
\c 109
\cl Psalam 109
\s1 Molitva gonjenoga da se kazne njegovi neprijatelji i da se Bog smiluje na nj u bedi.
\d Načelniku pevačkom. Davidov psalam.
\q1 
\v 1 Bože, slavo moja, nemoj ćutati,
\q1 
\v 2 Jer se usta bezbožnička i usta lukava
\q2 na me otvoriše;
\q2 govore sa mnom jezikom lažljivim.
\q1 
\v 3 Rečima zlobnim sa svih strana gone me,
\q2 i oružaju se na me nizašta.
\q1 
\v 4 Za ljubav moju ustaju na mene,
\q2 a ja se molim.
\q1 
\v 5 Vraćaju mi zlo za dobro,
\q2 i mržnju za ljubav moju.
\b
\q1 
\v 6 Postavi nad njim starešinu bezbožnika,
\q2 i protivnik neka mu stane s desne strane.
\q1 
\v 7 Kad se stane suditi, neka izađe kriv,
\q2 i molitva njegova neka bude greh.
\q1 
\v 8 Neka budu dani njegovi kratki,
\q2 i vlast njegovu neka dobije drugi.
\q1 
\v 9 Deca njegova nek budu sirote,
\q2 i žena njegova udovica.
\q1 
\v 10 Deca njegova nek se potucaju i prose,
\q2 i neka traže hleba izvan svojih pustolina.
\q1 
\v 11 Neka mu uzme dužnik sve što ima,
\q2 i neka razgrabe tuđini muku njegovu.
\q1 
\v 12 Nek se ne nađe niko ko bi ga ljubio,
\q2 ni ko bi se smilovao na sirote njegove.
\q1 
\v 13 Nasleđe njegovo nek se zatre,
\q2 u drugom kolenu neka pogine ime njihovo.
\q1 
\v 14 Bezakonje starih njegovih nek se spomene u Gospoda,
\q2 i greh matere njegove nek se ne izbriše.
\q1 
\v 15 Neka budu svagda pred Gospodom,
\q2 i On neka istrebi spomen njihov na zemlji;
\b
\q1 
\v 16 Zato što se nije sećao činiti milost,
\q2 nego je gonio čoveka ništeg i ubogog,
\q2 i tužnom u srcu tražio smrt.
\q1 
\v 17 Ljubio je kletvu, neka ga i stigne;
\q2 nije mario za blagoslov, neka i otide od njega.
\q1 
\v 18 Nek se obuče u kletvu kao u haljinu,
\q2 i ona nek uđe u njega kao voda,
\q2 i kao ulje u kosti njegove.
\q1 
\v 19 Nek mu ona bude kao haljina, u koju se oblači,
\q2 i kao pojas, kojim se svagda paše.
\q1 
\v 20 Takva plata nek bude od Gospoda onima koji me nenavide,
\q2 i koji govore zlo na dušu moju.
\b
\q1 
\v 21 A meni, Gospode, Gospode, učini šta priliči imenu Tvom.
\q2 Ti si dobar, milošću svojom izbavi me.
\q1 
\v 22 Jer sam nevoljan i ništ,
\q2 i srce je moje ranjeno u meni.
\q1 
\v 23 Nestaje me kao sena, kad se odmiče;
\q2 teraju me kao skakavce.
\q1 
\v 24 Kolena moja iznemogoše od posta,
\q2 i telo moje omrša.
\q1 
\v 25 Postadoh podsmeh njima;
\q2 videći me mašu glavom svojom.
\b
\q1 
\v 26 Pomozi mi, Gospode, Bože moj,
\q2 spasi me po milosti svojoj.
\q1 
\v 27 Neka poznaju da je ovo Tvoja ruka,
\q2 i Ti, Gospode, da si ovo učinio.
\q1 
\v 28 Oni kunu, a Ti blagoslovi;
\q2 ustaju, ali nek se postide,
\q2 i sluga se Tvoj obraduje.
\q1 
\v 29 Nek se protivnici moji obuku u sramotu,
\q2 i kao haljinom nek se pokriju stidom svojim.
\b
\q1 
\v 30 Hvaliću Gospoda veoma ustima svojim,
\q2 i usred mnogih slaviću Ga,
\q1 
\v 31 Jer stoji s desne strane ubogome,
\q2 da bi ga spasao od onih koji osuđuju dušu njegovu.
\c 110
\cl Psalam 110
\s1 Hristos večni car i prvosveštenik.
\d Davidov psalam.
\q1 
\v 1 Reče Gospod Gospodu mom:
\q2 Sedi meni s desne strane,
\q1 dok položim neprijatelje Tvoje
\q2 za podnožje nogama Tvojim.
\b
\q1 
\v 2 Skiptar sile daje ti Gospod sa Siona:
\q2 vladaj sred neprijatelja svojih.
\q1 
\v 3 U dan rata Tvog
\q2 narod je Tvoj gotov u svetoj krasoti.
\q1 Kao rosa zori iz utrobe,
\q2 takva je u Tebe mladost Tvoja.
\q1 
\v 4 Gospod se zakleo,
\q2 i neće se pokajati:
\q2 ti si sveštenik doveka po redu Melhisedekovom.
\b
\q1 
\v 5 Gospod je tebi s desne strane.
\q2 Pobiće u dan gneva svog careve;
\q1 
\v 6 Sudiće narodima, napuniće zemlju trupova;
\q2 satrće glavu na zemlji širokoj.
\q1 
\v 7 Iz potoka će na putu piti,
\q2 i zato će podignuti glavu.
\c 111
\cl Psalam 111
\s1 Zahvalna pesma na duhovnim i telesnim darovima Božijim.
\d Aliluja.
\q1 
\v 1 Hvalim Te, Gospode, od svega srca
\q2 na veću pravedničkom i na saboru.
\q1 
\v 2 Velika su dela Gospodnja,
\q2 draga svima koji ih ljube.
\q1 
\v 3 Delo je Njegovo slava i krasota,
\q2 i pravda Njegova traje doveka.
\q1 
\v 4 Čudesa je svoja učinio da se ne zaborave;
\q2 dobar je i milostiv Gospod.
\q1 
\v 5 Hranu daje onima koji Ga se boje,
\q2 pamti uvek zavet svoj.
\q1 
\v 6 Silu dela svojih javio je narodu svom
\q2 davši im nasledstvo naroda.
\q1 
\v 7 Dela su ruku Njegovih istina i pravda;
\q2 verne su sve zapovesti Njegove;
\q1 
\v 8 Tvrde su za va vek veka,
\q2 osnovane na istini i pravdi.
\q1 
\v 9 Izbavljenje posla narodu svom;
\q2 postavi zavavek zavet svoj.
\q1 Ime je Njegovo sveto,
\q2 i valja Mu se klanjati.
\q1 
\v 10 Početak je mudrosti strah Gospodnji;
\q2 dobra su razuma svi koji ih tvore.
\q1 Hvala Njegova traje doveka.
\c 112
\cl Psalam 112
\s1 Blaženi su oni koji se boje Boga i koji su milostivi.
\d Aliluja.
\q1 
\v 1 Blago čoveku koji se boji Gospoda,
\q2 kome su veoma omilele zapovesti Njegove.
\q1 
\v 2 Silno će biti na zemlji seme njegovo,
\q2 rod pravednički biće blagosloven.
\q1 
\v 3 Obilje je i bogatstvo u domu njegovom,
\q2 i pravda njegova traje doveka.
\q1 
\v 4 U tami sjaje videlo pravednicima
\q2 od dobrog, milostivog i pravednog.
\q1 
\v 5 Blago onome koji je milostiv i daje u zajam!
\q2 On će dati tvrđu rečima svojim na sudu.
\q1 
\v 6 Jer neće posrnuti doveka,
\q2 pravednik će se spominjati uvek.
\q1 
\v 7 Ne boji se zlog glasa;
\q2 srce je njegovo stalno, uzda se u Gospoda.
\q1 
\v 8 Utvrđeno je srce njegovo, neće se pobojati,
\q2 i videće kako padaju neprijatelji njegovi.
\q1 
\v 9 Prosipa, daje ubogima;
\q2 pravda njegova traje doveka,
\q2 rog se njegov uzvišuje u slavi.
\q1 
\v 10 Bezbožnik vidi, i jedi se,
\q2 škrguće zubima svojim, i sahne.
\q1 Želja će bezbožnicima propasti.
\c 113
\cl Psalam 113
\s1 Bog je milostiv prema smirenim.
\d Aliluja.
\q1 
\v 1 Hvalite, sluge Gospodnje,
\q2 hvalite ime Gospodnje,
\b
\q1 
\v 2 Da bude ime Gospodnje blagosloveno
\q2 odsad i doveka.
\q1 
\v 3 Od istoka sunčanog do zapada
\q2 da se slavi ime Gospodnje.
\b
\q1 
\v 4 Uzvišen je nad svima narodima Gospod;
\q2 svrh nebesa je slava Njegova.
\q1 
\v 5 Ko je kao Gospod, Bog naš,
\q2 koji sedi na visini;
\q1 
\v 6 Koji se sagiba da vidi šta je na nebesima i na zemlji;
\q1 
\v 7 Koji iz praha podiže ubogoga,
\q2 i iz kala uzvišuje ništega;
\q1 
\v 8 I posađuje ga s knezovima,
\q2 s knezovima u narodu njegovom;
\q1 
\v 9 Od nerotkinje naseljava kuću,
\q2 učinivši je radosnom majkom sinovima.
\q1 Aliluja!
\c 114
\cl Psalam 114
\s1 Čudesa Božija kada je izvodio svoj narod iz Misira.
\q1 
\v 1 Kad izađe Izrailj iz Misira,
\q2 dom Jakovljev iz naroda tuđeg,
\q1 
\v 2 Judeja postade svetinja Božija,
\q2 Izrailj oblast Njegova.
\b
\q1 
\v 3 More vide i pobeže;
\q2 Jordan se obrati natrag.
\q1 
\v 4 Gore skakaše kao ovnovi,
\q2 brdašca kao jaganjci.
\b
\q1 
\v 5 Šta ti bi, more, te pobeže
\q2 i tebi, Jordane, te se obrati natrag?
\q1 
\v 6 Gore, što skačete kao ovnovi,
\q2 i brdašca, kao jaganjci?
\b
\q1 
\v 7 Pred licem Gospodnjim drhći, zemljo,
\q2 pred licem Boga Jakovljevog.
\q1 
\v 8 Koji pretvara kamen u jezero vodeno,
\q2 granit u izvor vodeni.
\c 115
\cl Psalam 115
\s1 Slava jedino Gospodu!
\q1 
\v 1 Ne nama, Gospode, ne nama,
\q2 nego imenu svom daj slavu,
\q2 po milosti svojoj, po istini svojoj.
\b
\q1 
\v 2 Zašto da govore narodi:
\q2 Gde li je Bog njihov?
\q1 
\v 3 Bog je naš na nebesima,
\q2 tvori sve što hoće.
\b
\q1 
\v 4 Idoli su njihovi srebro i zlato,
\q2 delo ruku čovečijih.
\q1 
\v 5 Usta imaju, a ne govore;
\q2 oči imaju, a ne vide;
\q1 
\v 6 Uši imaju, a ne čuju;
\q2 nozdrve imaju, a ne mirišu;
\q1 
\v 7 Ruke imaju, a ne hvataju;
\q2 noge imaju, a ne hode,
\q2 i ne puštaju glas iz grla svog.
\q1 
\v 8 Takvi su i oni koji ih grade,
\q2 i svi koji se uzdaju u njih.
\b
\q1 
\v 9 Dome Izrailjev, uzdaj se u Gospoda;
\q2 On im je pomoć i štit.
\q1 
\v 10 Dome Aronov, uzdaj se u Gospoda;
\q2 On im je pomoć i štit.
\q1 
\v 11 Koji se bojite Gospoda, uzdajte se u Gospoda;
\q2 On im je pomoć i štit.
\b
\q1 
\v 12 Gospod nas se opominje, blagosilja nas,
\q2 blagosilja dom Izrailjev,
\q2 blagosilja dom Aronov;
\q1 
\v 13 Blagosilja one koji se boje Gospoda,
\q2 male i velike.
\b
\q1 
\v 14 Da vam Gospod umnoži blagoslove,
\q2 vama i sinovima vašim!
\q1 
\v 15 Gospod da vas blagoslovi,
\q2 Tvorac neba i zemlje!
\b
\q1 
\v 16 Nebo je nebo Gospodnje,
\q2 a zemlju je dao sinovima čovečijim.
\q1 
\v 17 Neće Te mrtvi hvaliti, Gospode,
\q2 niti oni koji siđu onamo gde se ćuti.
\q1 
\v 18 Nego ćemo mi blagosiljati Gospoda
\q2 odsad i doveka.
\q1 Aliluja!
\c 116
\cl Psalam 116
\s1 Zahvalnost i zavet Gospodu zbog spasenja od smrti.
\q1 
\v 1 Milo mi je što Gospod usliši molitveni glas moj;
\q2 
\v 2 Što prignu k meni uho svoje;
\q2 i zato ću Ga u sve dane svoje prizivati.
\q1 
\v 3 Opkoliše me bolesti smrtne,
\q2 i jadi pakleni zadesiše me,
\q2 naiđoh na tugu i muku;
\q1 
\v 4 Ali prizvah ime Gospodnje:
\q2 Gospode! Izbavi dušu moju!
\b
\q1 
\v 5 Dobar je Gospod i pravedan,
\q2 i Bog je naš milostiv;
\q1 
\v 6 Čuva proste Gospod;
\q2 bejah u nevolji, i pomože mi.
\q1 
\v 7 Vrati se dušo moja, u mir svoj!
\q2 Jer je Gospod dobrotvor tvoj!
\b
\q1 
\v 8 Ti si izbavio dušu moju od smrti,
\q2 oko moje od suza,
\q2 nogu moju od spoticanja.
\q1 
\v 9 Hodiću pred licem Gospodnjim
\q2 po zemlji živih.
\b
\q1 
\v 10 Verovah kad govorih:
\q2 U ljutoj sam nevolji.
\q1 
\v 11 Rekoh u smetnji svojoj:
\q2 Svaki je čovek laža.
\b
\q1 
\v 12 Šta ću vratiti Gospodu
\q2 za sva dobra što mi je učinio?
\q1 
\v 13 Uzeću čašu spasenja,
\q2 i prizvaću ime Gospodnje.
\q1 
\v 14 Izvršiću obećanja svoja Gospodu
\q2 pred svim narodom Njegovim.
\b
\q1 
\v 15 Skupa je pred Gospodom smrt svetaca Njegovih.
\q1 
\v 16 O Gospode! Ja sam sluga Tvoj,
\q2 ja sam sluga Tvoj, sin sluškinje Tvoje;
\q2 raskovao si s mene okove moje.
\q1 
\v 17 Žrtvu za hvalu prineću Tebi,
\q2 i ime Gospodnje prizvaću.
\q1 
\v 18 Izvršiću obećanja svoja Gospodu
\q2 pred svim narodom Njegovim,
\q1 
\v 19 U dvoru doma Gospodnjeg,
\q2 usred tebe, Jerusalime.
\q1 Aliluja!
\c 117
\cl Psalam 117
\s1 Hvaljenje Gospoda.
\q1 
\v 1 Hvalite Gospoda svi narodi,
\q2 slavite Ga sva plemena;
\q1 
\v 2 Jer je velika milost Njegova k nama,
\q2 i istina Gospodnja traje doveka.
\q1 Aliluja!
\c 118
\cl Psalam 118
\s1 Pravedni se raduje pobedi.
\q1 
\v 1 Hvalite Gospoda, jer je dobar,
\q2 jer je doveka milost Njegova.
\b
\q1 
\v 2 Neka reče Izrailj
\q2 da je doveka milost Njegova;
\q1 
\v 3 Neka reče dom Aronov
\q2 da je doveka milost Njegova;
\q1 
\v 4 Neka kažu svi koji se boje Gospoda
\q2 da je doveka milost Njegova.
\b
\q1 
\v 5 Iz teskobe povikah ka Gospodu i usliši me,
\q2 izvede me na prostrano mesto Gospod.
\q1 
\v 6 Gospod je sa mnom, ne bojim se;
\q2 šta će mi učiniti čovek?
\q1 
\v 7 Gospod mi je pomoćnik:
\q2 slobodno ću gledati u neprijatelje svoje.
\b
\q1 
\v 8 Bolje je uzdati se u Gospoda
\q2 nego li se oslanjati na čoveka;
\q1 
\v 9 Bolje je uzdati se u Gospoda
\q2 negoli se oslanjati na knezove.
\b
\q1 
\v 10 Svi me narodi opkoliše;
\q2 ali ih u ime Gospodnje razbih.
\q1 
\v 11 Optekoše, opkoliše me;
\q2 ali ih u ime Gospodnje razbih.
\q1 
\v 12 Opkoliše me kao pčele saće,
\q2 i ugasiše se kao oganj u trnju:
\q2 u ime ih Gospodnje razbih.
\q1 
\v 13 Otisnuo si me da padnem,
\q2 ali me Gospod prihvati.
\b
\q1 
\v 14 Gospod je hvala moja i pesma;
\q2 On mi posta Spasitelj.
\q1 
\v 15 Glas radosti i spasenja
\q2 čuje se u kolibama pravedničkim:
\q1 „Desnica Gospodnja daje silu;
\q2 
\v 16 Desnica Gospodnja uzvišuje,
\q2 desnica Gospodnja daje silu.”
\b
\q1 
\v 17 Neću umreti, nego ću živ biti,
\q2 i kazivati dela Gospodnja.
\q1 
\v 18 Karajući pokara me Gospod;
\q2 ali me smrti ne dade.
\b
\q1 
\v 19 Otvorite mi vrata od pravde,
\q2 ući ću na njih, slaviću Gospoda.
\q1 
\v 20 „Evo vrata Gospodnja,
\q2 na koja ulaze pravednici!”
\q1 
\v 21 Hvalim Te, što si me uslišio,
\q2 i postao mi Spasitelj.
\q1 
\v 22 Kamen koji odbaciše zidari,
\q2 posta glava od ugla.
\q1 
\v 23 To bi od Gospoda
\q2 i divno je u našim očima.
\q1 
\v 24 Evo dan, koji stvori Gospod!
\q2 Radujmo se i veselimo se u nj!
\b
\q1 
\v 25 O Gospode, pomozi!
\q2 O Gospode, daj da bude u napredak!
\b
\q1 
\v 26 Blagosloven koji ide u ime Gospodnje!
\q2 Blagosiljamo vas iz doma Gospodnjeg.
\q1 
\v 27 Gospod je Bog krepak, i On nas obasja;
\q2 žrtvu prazničnu, vezanu vrpcama,
\q2 vodite k rogovima žrtveniku.
\b
\q1 
\v 28 Ti si Bog moj, Tebe hvalim,
\q2 Bože moj, Tebe uzvišujem.
\q1 
\v 29 Hvalite Gospoda, jer je dobar,
\q2 jer je milost Njegova doveka.
\c 119
\cl Psalam 119
\s1 Slava reči Božije (ili „zlatna azbuka” nazvana tako što u jevrejskom rukopisu po osam stihova počinju istim slovom, a po azbučnom redu).
\q1 
\v 1 Blago onima kojima je put čist,
\q2 koji hode u zakonu Gospodnjem.
\q1 
\v 2 Blago onima koji čuvaju otkrivenja Njegova,
\q2 svim srcem traže Ga;
\q1 
\v 3 Koji ne čine bezakonja,
\q2 hode putevima Njegovim!
\q1 
\v 4 Ti si dao zapovesti svoje,
\q2 da se čuvaju dobro.
\q1 
\v 5 Kad bi putevi moji bili upravljeni
\q2 da čuvam naredbe Tvoje!
\q1 
\v 6 Onda se ne bih postideo,
\q2 pazeći na zapovesti Tvoje;
\q1 
\v 7 Hvalio bih Te s pravim srcem,
\q2 učeći se pravednim zakonima Tvojim.
\q1 
\v 8 Čuvaću naredbe Tvoje,
\q2 nemoj me ostaviti sasvim.
\b
\q1 
\v 9 Kako će mladić očistiti put svoj?
\q2 Vladajući se po Tvojim rečima.
\q1 
\v 10 Svim srcem svojim tražim Tebe,
\q2 ne daj mi da zađem od zapovesti Tvojih.
\q1 
\v 11 U srce svoje zatvorio sam reč Tvoju,
\q2 da Ti ne grešim.
\q1 
\v 12 Blagosloven si, Gospode!
\q2 Nauči me naredbama svojim.
\q1 
\v 13 Ustima svojim javljam
\q2 sve sudove usta Tvojih.
\q1 
\v 14 Na putu otkrivenja Tvojih radujem se
\q2 kao za veliko bogatstvo.
\q1 
\v 15 O zapovestima Tvojim razmišljam,
\q2 i pazim na puteve Tvoje.
\q1 
\v 16 Naredbama Tvojim tešim se,
\q2 ne zaboravljam reči Tvoje.
\b
\q1 
\v 17 Učini milost sluzi svom,
\q2 da bih živeo i čuvao reč Tvoju.
\q1 
\v 18 Otvori oči moje,
\q2 da bih video čudesa zakona Tvog;
\q1 
\v 19 Gost sam na zemlji,
\q2 nemoj sakriti od mene zapovesti svoje.
\q1 
\v 20 Iznemože duša moja
\q2 želeći bez prestanka poznati sudove Tvoje.
\q1 
\v 21 Ti si strašan prokletim oholicama,
\q2 koje zastranjuju od zapovesti Tvojih.
\q1 
\v 22 Odvrati od mene rug i sramotu,
\q2 jer čuvam otkrivenja Tvoja.
\q1 
\v 23 Sede knezovi i dogovaraju se na mene;
\q2 a sluga Tvoj razmišlja o naredbama Tvojim.
\q1 
\v 24 Otkrivenja su Tvoja uteha moja,
\q2 savetnici moji.
\b
\q1 
\v 25 Duša moja leži u prahu;
\q2 oživi me po reči svojoj.
\q1 
\v 26 Kazujem puteve svoje, i čuješ me;
\q2 nauči me naredbama svojim.
\q1 
\v 27 Urazumi me o putu zapovesti svojih,
\q2 i razmišljaću o čudesima Tvojim.
\q1 
\v 28 Suze proliva duša moja od tuge,
\q2 okrepi me po reči svojoj.
\q1 
\v 29 Put lažni ukloni od mene
\q2 i zakon svoj daruj mi.
\q1 
\v 30 Put istini izbrah,
\q2 zakone Tvoje tražim.
\q1 
\v 31 Prionuh za otkrivenja Tvoja, Gospode;
\q2 nemoj me osramotiti.
\q1 
\v 32 Putem zapovesti Tvojih trčim,
\q2 jer si raširio srce moje.
\b
\q1 
\v 33 Pokaži mi, Gospode, put naredaba svojih,
\q2 da ga se držim do kraja.
\q1 
\v 34 Urazumi me, i držaću se zakona Tvog,
\q2 i čuvati ga svim srcem.
\q1 
\v 35 Postavi me na stazu zapovesti svojih,
\q2 jer mi je ona omilela.
\q1 
\v 36 Privij srce moje k otkrivenjima svojim,
\q2 a ne k lakomstvu.
\q1 
\v 37 Odvrati oči moje da ne gledaju ništavila,
\q2 putem svojim oživi me.
\q1 
\v 38 Ispuni sluzi svom reč svoju
\q2 da Te se boji.
\q1 
\v 39 Ukloni rug moj, kog se plašim;
\q2 jer su sudovi Tvoji blagi.
\q1 
\v 40 Mile su mi zapovesti Tvoje,
\q2 pravdom svojom oživi me.
\b
\q1 
\v 41 Neka dođe na me milost Tvoja, Gospode,
\q2 pomoć Tvoja po reči Tvojoj.
\q1 
\v 42 I ja ću odgovoriti onome koji me ruži;
\q2 jer se uzdam u reč Tvoju.
\q1 
\v 43 Nemoj uzeti nikad od usta mojih reči istine,
\q2 jer čekam sudove Tvoje.
\q1 
\v 44 I čuvaću zakon Tvoj svagda,
\q2 doveka i bez prestanka.
\q1 
\v 45 Hodiću slobodno,
\q2 jer tražim zapovesti Tvoje.
\q1 
\v 46 Govoriću o otkrivenjima Tvojim pred carevima,
\q2 i neću se stideti.
\q1 
\v 47 Tešiću se zapovestima Tvojim,
\q2 koje ljubim.
\q1 
\v 48 Ruke svoje pružam k zapovestima Tvojim, koje ljubim,
\q2 i razmišljam o naredbama Tvojim.
\b
\q1 
\v 49 Opomeni se reči svoje k sluzi svom,
\q2 na koju si mi zapovedio da se oslanjam.
\q1 
\v 50 U nevolji mojoj teši me
\q2 što me reč Tvoja oživljava.
\q1 
\v 51 Oholi mi se rugaju veoma;
\q2 ali ja ne odstupam od zakona Tvog.
\q1 
\v 52 Pamtim sudove Tvoje od iskona, Gospode,
\q2 i tešim se.
\q1 
\v 53 Gnev me obuzima na bezbožnike,
\q2 koji ostavljaju zakon Tvoj.
\q1 
\v 54 Naredbe su Tvoje pesma moja
\q2 u putničkom stanu mom.
\q1 
\v 55 Noću pominjem ime Tvoje, Gospode,
\q2 i čuvam zakon Tvoj.
\q1 
\v 56 To je moje,
\q2 da čuvam zapovesti Tvoje.
\b
\q1 
\v 57 Deo moj Ti si, Gospode;
\q2 naumio sam čuvati reči Tvoje.
\q1 
\v 58 Molim Ti se iz svega srca,
\q2 smiluj se na me po reči svojoj.
\q1 
\v 59 Razmatram puteve svoje,
\q2 i obraćam noge svoje k otkrivenjima Tvojim.
\q1 
\v 60 Hitim, i ne zatežem se
\q2 čuvati zapovesti Tvoje.
\q1 
\v 61 Mreže bezbožničke opkoliše me,
\q2 ali zakon Tvoj ne zaboravljam.
\q1 
\v 62 U po noći ustajem da Te slavim
\q2 za pravedne sudove Tvoje.
\q1 
\v 63 U zajednici sam sa svima koji se Tebe boje
\q2 i koji čuvaju zapovesti Tvoje.
\q1 
\v 64 Dobrote je Tvoje, Gospode, puna sva zemlja;
\q2 naredbama svojim nauči me.
\b
\q1 
\v 65 Učinio si dobro sluzi svom, Gospode,
\q2 po reči svojoj.
\q1 
\v 66 Dobroj misli i znanju nauči me,
\q2 jer zapovestima Tvojim verujem.
\q1 
\v 67 Pre stradanja svog lutah,
\q2 a sad čuvam reč Tvoju.
\q1 
\v 68 Ti si dobar, i dobro činiš;
\q2 nauči me naredbama svojim.
\q1 
\v 69 Oholi pletu na mene laž,
\q2 ali se ja svim srcem držim zapovesti Tvojih.
\q1 
\v 70 Zadriglo je srce njihovo kao salo,
\q2 a ja se tešim zakonom Tvojim.
\q1 
\v 71 Dobro mi je što stradam,
\q2 da se naučim naredbama Tvojim.
\q1 
\v 72 Miliji mi je zakon usta Tvojih
\q2 nego hiljade zlata i srebra.
\b
\q1 
\v 73 Ruke Tvoje stvorile su me i načinile me;
\q2 urazumi me, i naučiću se zapovestima Tvojim.
\q1 
\v 74 Koji se Tebe boje, videće me,
\q2 i radovaće se što se uzdam u Tvoju reč.
\q1 
\v 75 Znam da su sudovi Tvoji, Gospode, pravedni,
\q2 i po pravdi me karaš.
\q1 
\v 76 Neka bude dobrota Tvoja uteha moja,
\q2 kao što si rekao sluzi svom.
\q1 
\v 77 Neka dođe k meni milosrđe Tvoje, i oživim;
\q2 jer je zakon Tvoj uteha moja.
\q1 
\v 78 Nek se postide oholi;
\q2 jer me bez krivice oboriše.
\q2 Ja razmišljam o zapovestima Tvojim.
\q1 
\v 79 Nek se obrate k meni koji se Tebe boje,
\q2 i koji znaju otkrivenja Tvoja.
\q1 
\v 80 Srce moje neka bude savršeno u naredbama Tvojim,
\q2 da se ne postidim.
\b
\q1 
\v 81 Čezne duša moja za spasenjem Tvojim,
\q2 reč Tvoju čekam.
\q1 
\v 82 Čeznu oči moje za rečju Tvojom;
\q2 govorim: Kad ćeš me utešiti?
\q1 
\v 83 Postadoh kao meh u dimu,
\q2 ali Tvojih naredaba ne zaboravih.
\q1 
\v 84 Koliko će biti dana sluge Tvog?
\q2 Kad ćeš suditi onima koji me gone?
\q1 
\v 85 Oholi iskopaše mi jamu
\q2 nasuprot zakonu Tvom.
\q1 
\v 86 Sve su zapovesti Tvoje istina;
\q2 bez krivice me gone, pomozi mi.
\q1 
\v 87 Umalo me ne ubiše na zemlji,
\q2 ali ja ne ostavljam zapovesti Tvoje.
\q1 
\v 88 Po milosti svojoj oživi me,
\q2 i čuvaću otkrivenja usta Tvojih.
\b
\q1 
\v 89 Doveka je, Gospode, reč Tvoja
\q2 utvrđena na nebesima,
\q1 
\v 90 Od kolena do kolena istina Tvoja;
\q2 Ti si postavio zemlju, i stoji.
\q1 
\v 91 Po Tvojoj naredbi sve stoji sad;
\q2 jer sve služi Tebi.
\q1 
\v 92 Da nije zakon Tvoj bio uteha moja,
\q2 poginuo bih u nevolji svojoj.
\q1 
\v 93 Zapovesti Tvoje neću zaboraviti doveka,
\q2 jer me njima oživljavaš.
\q1 
\v 94 Ja sam Tvoj, pomozi mi,
\q2 jer tražim zapovesti Tvoje.
\q1 
\v 95 Bezbožnici gledaju da me ubiju;
\q2 a ja razmišljam o Tvojim otkrivenjima.
\q1 
\v 96 Svemu savršenom videh kraj;
\q2 ali je zapovest Tvoja veoma široka.
\b
\q1 
\v 97 Kako ljubim zakon tvoj!
\q2 Sav dan mislim o njemu.
\q1 
\v 98 Zapovest Tvoja čini me mudrijeg od neprijatelja mojih;
\q2 jer je sa mnom uvek.
\q1 
\v 99 Razumniji postah od svih učitelja svojih;
\q2 jer razmišljam o Tvojim otkrivenjima.
\q1 
\v 100 Mudriji sam od staraca;
\q2 jer zapovesti Tvoje čuvam.
\q1 
\v 101 Od svakog zlog puta zaustavljam noge svoje,
\q2 da bih čuvao reč Tvoju.
\q1 
\v 102 Od naredaba Tvojih ne odstupam;
\q2 jer si me Ti naučio.
\q1 
\v 103 Kako su slatke jeziku mom reči Tvoje,
\q2 slađe od meda ustima mojim!
\q1 
\v 104 Od zapovesti Tvojih postadoh razuman;
\q2 toga radi mrzim na svaki put lažni.
\b
\q1 
\v 105 Reč je Tvoja žižak nozi mojoj,
\q2 i videlo stazi mojoj.
\q1 
\v 106 Zakleh se da ću čuvati naredbe pravde Tvoje,
\q2 i izvršiću.
\q1 
\v 107 Poništen sam veoma, Gospode,
\q2 oživi me po reči svojoj.
\q1 
\v 108 Neka Ti bude ugodna, Gospode, dobrovoljna žrtva usta mojih,
\q2 i sudovima svojim nauči me.
\q1 
\v 109 Duša je moja u ruci mojoj neprestano u nevolji;
\q2 ali zakon Tvoj ne zaboravljam.
\q1 
\v 110 Bezbožnici su mi metnuli zamku;
\q2 ali od zapovesti Tvojih ne zastranih.
\q1 
\v 111 Prisvojih otkrivenja Tvoja zavavek;
\q2 jer su radost srcu mom.
\q1 
\v 112 Privoleo sam srce svoje da tvori naredbe Tvoje
\q2 navek, do kraja.
\b
\q1 
\v 113 Koji prestupaju zakon, ja na njih mrzim,
\q2 a zakon Tvoj ljubim.
\q1 
\v 114 Ti si zaklon moj i štit moj;
\q2 reč Tvoju čekam.
\q1 
\v 115 Idite od mene, bezakonici!
\q2 I čuvaću zapovesti Boga svog.
\q1 
\v 116 Ukrepi me po reči svojoj i biću živ,
\q2 i nemoj me osramotiti u nadanju mom.
\q1 
\v 117 Utvrdi me, i spašću se,
\q2 i razmišljaću o naredbama Tvojim bez prestanka.
\q1 
\v 118 Obaraš sve koji odstupaju od naredaba Tvojih;
\q2 jer su pomisli njihove laž.
\q1 
\v 119 Kao gar bacaš sve bezbožnike na zemlji;
\q2 toga radi omileše mi otkrivenja Tvoja.
\q1 
\v 120 Drhće od straha Tvog telo moje,
\q2 i sudova Tvojih bojim se.
\b
\q1 
\v 121 Činim sud i pravdu,
\q2 ne daj me onima koji me gone.
\q1 
\v 122 Odbrani slugu svog na dobro Njegovo,
\q2 da mi ne čine sile oholi.
\q1 
\v 123 Oči moje čeznu za spasenjem Tvojim
\q2 i za rečju pravde Tvoje.
\q1 
\v 124 Učini sluzi svom po milosti svojoj,
\q2 i naredbama svojim nauči me.
\q1 
\v 125 Ja sam sluga Tvoj;
\q2 urazumi me, i poznaću otkrivenja Tvoja.
\q1 
\v 126 Vreme je da Gospod radi;
\q2 oboriše zakon Tvoj.
\q1 
\v 127 Toga radi ljubim zapovesti Tvoje
\q2 većma nego zlato i drago kamenje.
\q1 
\v 128 Toga radi zapovesti Tvoje držim da su verne,
\q2 na svaki put lažni mrzim.
\b
\q1 
\v 129 Divna su otkrivenja Tvoja;
\q2 zato ih čuva duša moja.
\q1 
\v 130 Reči Tvoje kad se jave,
\q2 prosvetljuju i urazumljuju proste.
\q1 
\v 131 Otvaram usta svoja da odahnem,
\q2 jer sam žedan zapovesti Tvojih.
\q1 
\v 132 Pogledaj na me i smiluj se na me,
\q2 kao što radiš s onima koji ljube ime Tvoje.
\q1 
\v 133 Utvrdi stope moje u reči svojoj,
\q2 i ne daj nikakvom bezakonju da ovlada mnom.
\q1 
\v 134 Izbavi me od nasilja ljudskog,
\q2 i čuvaću zapovesti Tvoje.
\q1 
\v 135 Svetlošću lica svog obasjaj slugu svog,
\q2 i nauči me naredbama svojim.
\q1 
\v 136 Oči moje liju potoke,
\q2 zato što ne čuvaju zakon Tvoj.
\b
\q1 
\v 137 Pravedan si, Gospode,
\q2 i pravi su sudovi Tvoji.
\q1 
\v 138 Javio si pravdu u otkrivenjima svojim,
\q2 i istinu celu.
\q1 
\v 139 Revnost moja jede me,
\q2 zato što moji neprijatelji zaboraviše reči Tvoje.
\q1 
\v 140 Reč je Tvoja veoma čista,
\q2 i sluga je Tvoj veoma ljubi.
\q1 
\v 141 Ja sam malen i poništen,
\q2 ali zapovesti Tvoje ne zaboravljam.
\q1 
\v 142 Pravda je Tvoja pravda večna,
\q2 i zakon Tvoj istina.
\q1 
\v 143 Tuga i nevolja nađe me,
\q2 zapovesti su Tvoje uteha moja.
\q1 
\v 144 Večna je pravda u otkrivenjima Tvojim;
\q2 urazumi me, i biću živ.
\b
\q1 
\v 145 Vičem iz svega srca: Usliši me, Gospode;
\q2 sačuvaću naredbe Tvoje.
\q1 
\v 146 Prizivam Te, pomozi mi;
\q2 držaću se otkrivenja Tvojih.
\q1 
\v 147 Pretečem svanuće, i vičem;
\q2 reč Tvoju čekam.
\q1 
\v 148 Preteču oči moje jutarnju stražu,
\q2 da bih razmišljao o reči Tvojoj.
\q1 
\v 149 Čuj glas moj po milosti svojoj, Gospode;
\q2 po sudu svom oživi me.
\q1 
\v 150 Prikučuju se koji ljube bezakonje;
\q2 udaljili su se od zakona Tvog.
\q1 
\v 151 Ti si blizu, Gospode,
\q2 i sve su zapovesti Tvoje istina.
\q1 
\v 152 Odavna znam za otkrivenja Tvoja,
\q2 da si ih postavio zavavek.
\b
\q1 
\v 153 Pogledaj nevolju moju, i izbavi me,
\q2 jer ne zaboravljam zakon Tvoj.
\q1 
\v 154 Primi se stvari moje, i odbrani me;
\q2 po reči svojoj oživi me.
\q1 
\v 155 Daleko je od bezbožnika spasenje,
\q2 jer se ne drže naredaba Tvojih.
\q1 
\v 156 Milosrđe je Tvoje, Gospode, veliko;
\q2 po pravom sudu svom oživi me.
\q1 
\v 157 Mnogo je protivnika mojih i neprijatelja mojih;
\q2 ali ja ne odstupam od otkrivenja Tvojih.
\q1 
\v 158 Vidim odmetnike, i mrsko mi je;
\q2 jer ne čuvaju reči Tvoje.
\q1 
\v 159 Gledaj, kako ljubim zapovesti Tvoje, Gospode,
\q2 po milosti svojoj oživi me.
\q1 
\v 160 Osnova je reči Tvoje istina,
\q2 i večan je svaki sud pravde Tvoje.
\b
\q1 
\v 161 Knezovi me gone nizašta,
\q2 ali se srce moje boji reči Tvoje.
\q1 
\v 162 Radujem se reči Tvojoj
\q2 kao onaj koji zadobije velik plen.
\q1 
\v 163 Mrzim na laž i gadim se na nju,
\q2 ljubim zakon Tvoj.
\q1 
\v 164 Sedam puta na dan hvalim Te
\q2 za sudove pravde Tvoje.
\q1 
\v 165 Velik mir imaju oni koji ljube zakon Tvoj,
\q2 i u njih nema spoticanja.
\q1 
\v 166 Čekam spasenje Tvoje, Gospode,
\q2 i zapovesti Tvoje izvršujem.
\q1 
\v 167 Duša moja čuva otkrivenja Tvoja,
\q2 i ja ih ljubim veoma.
\q1 
\v 168 Čuvam zapovesti Tvoje i otkrivenja;
\q2 jer su svi putevi moji pred Tobom.
\b
\q1 
\v 169 Neka izađe tužnjava moja preda Te, Gospode!
\q2 Po reči svojoj urazumi me.
\q1 
\v 170 Neka dođe moljenje moje preda Te!
\q2 Po reči svojoj izbavi me.
\q1 
\v 171 Usta će moja pevati hvalu,
\q2 kad me naučiš naredbama svojim.
\q1 
\v 172 Jezik će moj kazivati reč Tvoju,
\q2 jer su sve zapovesti Tvoje pravedne.
\q1 
\v 173 Neka mi bude ruka Tvoja u pomoći;
\q2 jer mi omileše zapovesti Tvoje;
\q1 
\v 174 Žedan sam spasenja Tvog, Gospode,
\q2 i zakon je Tvoj uteha moja.
\q1 
\v 175 Neka živi duša moja i Tebe hvali,
\q2 i sudovi Tvoji neka mi pomognu.
\q1 
\v 176 Zađoh kao ovca izgubljena:
\q2 traži slugu svog;
\q2 jer zapovesti Tvoje ne zaboravih.
\c 120
\cl Psalam 120
\s1 Protiv opadača.
\d Pesma za penjanje.
\q1 
\v 1 Ka Gospodu zavikah u nevolji svojoj,
\q2 i usliši me.
\q1 
\v 2 Gospode! Izbavi dušu moju od usta lažljivih
\q2 i od jezika lukavog.
\b
\q1 
\v 3 Šta će Ti dati i šta će Ti prineti jezik lukavi?
\q1 
\v 4 On je kao oštre strele u jakoga,
\q2 kao ugljevlje smrekovo.
\b
\q1 
\v 5 Teško meni kad sam tuđin kod Meseha,
\q2 živim kod šatora kidarskih.
\q1 
\v 6 Dugo je živela duša moja s onima koji mrze na mir.
\q1 
\v 7 Ja sam miran;
\q2 ali kad stanem govoriti u njih je rat.
\c 121
\cl Psalam 121
\s1 Gospod je verni čuvar ljudi.
\d Pesma za penjanje.
\q1 
\v 1 Podižem oči svoje ka gorama;
\q2 odakle mi dolazi pomoć?
\q1 
\v 2 Pomoć je meni od Gospoda,
\q2 koji je stvorio nebo i zemlju.
\b
\q1 
\v 3 Neće dati da popuzne noga tvoja;
\q2 ne dremlje čuvar tvoj.
\q1 
\v 4 Gle, ne dremlje i ne spava
\q2 čuvar Izrailjev.
\b
\q1 
\v 5 Gospod je čuvar tvoj,
\q2 Gospod je sen tvoj,
\q2 On ti je s desne strane.
\q1 
\v 6 Danju te neće sunce ubiti
\q2 ni mesec noću.
\b
\q1 
\v 7 Gospod će te sačuvati od svakog zla,
\q2 sačuvaće dušu tvoju Gospod.
\q1 
\v 8 Gospod će čuvati ulazak tvoj i izlazak tvoj,
\q2 odsad i doveka.
\c 122
\cl Psalam 122
\s1 U slavu Jerusalima.
\d Pesma za penjanje. Davidova.
\q1 
\v 1 Obradovah se kad mi rekoše:
\q2 Hajdemo u dom Gospodnji!
\q1 
\v 2 Evo, stoje noge naše na vratima tvojim, Jerusalime!
\b
\q1 
\v 3 Jerusalim je izidan,
\q2 kao grad sliven u jednu zgradu.
\q1 
\v 4 Onamo idu plemena, plemena Gospodnja,
\q2 po naredbi Izrailjevoj
\q2 da slave ime Gospodnje.
\q1 
\v 5 Onde stoje prestoli sudski,
\q2 prestoli doma Davidovog.
\b
\q1 
\v 6 Ištite mira Jerusalimu;
\q2 neka bude dobro onima koji ljube Tebe!
\q1 
\v 7 Neka bude mir oko zidova tvojih,
\q2 i čestitost u dvorima tvojim!
\q1 
\v 8 Radi braće svoje, i prijatelja svojih
\q2 govorim: Mir ti!
\q1 
\v 9 Radi doma Gospoda Boga našeg
\q2 želim ti dobro.
\c 123
\cl Psalam 123
\s1 Duša koja pati od sramote i poruge izgleda milost Božiju.
\d Pesma za penjanje.
\q1 
\v 1 K Tebi podižem oči svoje,
\q2 koji živiš na nebesima!
\q1 
\v 2 Kao što su oči slugama
\q2 uprte u ruku gospodara njihovih,
\q1 kao oči sluškinjine
\q2 u ruku gospođe njene,
\q1 tako su oči naše
\q2 u Gospoda Boga našeg,
\q2 dok se smiluje na nas.
\b
\q1 
\v 3 Smiluj se na nas, Gospode, smiluj se na nas,
\q2 jer smo se dovoljno nasitili sramote;
\q1 
\v 4 Dovoljno se nasitila duša naša
\q2 ruga od ponositih, i sramote od oholih.
\c 124
\cl Psalam 124
\s1 Bog je sa nama u nevolji.
\d Pesma za penjanje. Davidova.
\q1 
\v 1 Da nije bio Gospod s nama,
\q2 neka reče Izrailj,
\q1 
\v 2 Da nije bio Gospod s nama,
\q2 kad ljudi ustaše na nas,
\q1 
\v 3 Žive bi nas proždrli,
\q2 kad se raspali gnev njihov na nas;
\q1 
\v 4 Potopila bi nas voda,
\q2 reka bi pokrila dušu našu;
\q1 
\v 5 Pokrila bi dušu našu silna voda.
\b
\q1 
\v 6 Blagosloven Gospod,
\q2 koji nas ne dade zubima njihovim da nas rastržu!
\q1 
\v 7 Duša se naša izbavi
\q2 kao ptica iz zamke lovačke;
\q2 zamka se raskide, i mi se izbavismo.
\b
\q1 
\v 8 Pomoć je naša u imenu Gospodnjem,
\q2 koji je stvorio nebo i zemlju.
\c 125
\cl Psalam 125
\s1 Ko se uzda u Gospoda neće dopasti sramote.
\d Pesma za penjanje.
\q1 
\v 1 Ko se uzda u Gospoda, on je kao gora Sion,
\q2 ne pomeša se, ostaje doveka.
\q1 
\v 2 Oko Jerusalima su gore,
\q2 i Gospod je oko naroda svog odsad i doveka.
\q1 
\v 3 Jer neće ostati skiptar bezbožnički
\q2 nad delom pravedničkim,
\q1 da ne bi pravednici pružili ruke svoje na bezakonje.
\q1 
\v 4 Učini, Gospode, dobro dobrima
\q2 i onima koji su prava srca.
\q1 
\v 5 A koji svrću na krive pute, oteraće Gospod
\q2 s onima koji čine bezakonje.
\q1 Mir Izrailju!
\c 126
\cl Psalam 126
\s1 Spasenje roblja Sionskog.
\d Pesma za penjanje.
\q1 
\v 1 Kad vraćaše Gospod roblje sionsko,
\q2 bejasmo kao u snu.
\q1 
\v 2 Tada usta naša behu puna radosti,
\q2 i jezik naš pevanja.
\q1 Tada govorahu po narodima:
\q2 Veliko delo čini Gospod na njima.
\q1 
\v 3 Veliko delo čini Gospod na nama;
\q2 razveselismo se.
\b
\q1 
\v 4 Vraćaj, Gospode, roblje naše,
\q2 kao potoke na sasušenu zemlju.
\q1 
\v 5 Koji su sa suzama sejali,
\q2 neka žanju s pevanjem.
\q1 
\v 6 Ide i plače koji nosi seme da seje;
\q2 poći će s pesmom noseći snopove svoje.
\c 127
\cl Psalam 127
\s1 Sve stoji do blagoslova Božijeg.
\d Pesma za penjanje. Solomunova.
\q1 
\v 1 Ako Gospod neće graditi dom,
\q2 uzalud se muče koji ga grade;
\q1 ako neće Gospod čuvati grad,
\q2 uzalud ne spava stražar.
\q1 
\v 2 Uzalud ranite,
\q2 kasno ležete,
\q1 jedete hleb umorni;
\q2 milom svom On daje san.
\b
\q1 
\v 3 Evo nasledstva od Gospoda:
\q2 deca, porod je dar od Njega.
\q1 
\v 4 Šta su strele u ruci jakome,
\q2 to su sinovi mladi.
\q1 
\v 5 Blago čoveku koji je njima napunio tul svoj!
\q2 Neće se osramotiti
\q2 kad se stanu razgovarati s neprijateljima na vratima.
\c 128
\cl Psalam 128
\s1 Blagosloven je dom pobožnog čoveka.
\d Pesma za penjanje.
\q1 
\v 1 Blago svakome, koji se boji Gospoda,
\q2 koji hodi putevima Njegovim!
\q1 
\v 2 Jer će jesti od trudova ruku svojih.
\q2 Blago tebi, i dobro ti je.
\b
\q1 
\v 3 Žena je tvoja kao rodna loza
\q2 usred doma tvog;
\q1 sinovi tvoji kao grane maslinove
\q2 oko stola tvog.
\q1 
\v 4 Gle, tako će biti blagosloven
\q2 čovek koji se boji Gospoda.
\b
\q1 
\v 5 Blagosloviće te Gospod sa Siona,
\q2 i gledaćeš dobro jerusalimsko
\q2 u sve dane života svog;
\q1 
\v 6 Videćeš sinove u sinova svojih.
\q2 Mir Izrailju!
\c 129
\cl Psalam 129
\s1 Postideće se svi koji dosađuju Izrailju.
\d Pesma za penjanje.
\q1 
\v 1 Mnogo mi dosađivaše od mladosti moje
\q2 neka reče Izrailj,
\q1 
\v 2 Mnogo mi dosađivaše od mladosti moje,
\q2 ali me ne svladaše.
\q1 
\v 3 Na leđima mojim oraše orači,
\q2 i vodiše duge brazde svoje.
\q1 
\v 4 Gospod je pravedan;
\q2 iseče konopce bezbožničke.
\q1 
\v 5 Postideće se, odbiće se svi
\q2 koji nenavide Sion.
\q1 
\v 6 Biće kao trava na krovovima,
\q2 koja se sasušuje pre nego se počupa,
\q1 
\v 7 Od koje neće žetelac napuniti ruke svoje,
\q2 niti naručja svoja vezilac;
\q1 
\v 8 I koji prolaze neće reći:
\q2 „Blagoslov Gospodnji na vama!
\q2 Blagosiljamo vas imenom Gospodnjim.”
\c 130
\cl Psalam 130
\s1 Molitva za praštanje grehova.
\d Pesma za penjanje.
\q1 
\v 1 Iz dubine vičem k Tebi, Gospode!
\q2 
\v 2 Gospode! Čuj glas moj.
\q1 Neka paze uši Tvoje
\q2 na glas moljenja mog.
\b
\q1 
\v 3 Ako ćeš na bezakonje gledati, Gospode,
\q2 Gospode, ko će ostati?
\q1 
\v 4 Ali je u Tebe praštanje,
\q2 da bi Te se bojali.
\b
\q1 
\v 5 Čekam Gospoda;
\q2 čeka duša moja;
\q2 uzdam se u reč Njegovu.
\q1 
\v 6 Duša moja čeka Gospoda
\q2 većma nego straže jutarnje, koje straže jutrom.
\b
\q1 
\v 7 Neka čeka Izrailj Gospoda;
\q2 jer je u Gospoda milost,
\q2 i velik je u Njega otkup.
\q1 
\v 8 I On će otkupiti Izrailja
\q2 od svih bezakonja Njegovih.
\c 131
\cl Psalam 131
\s1 Smernost srca.
\d Pesma za penjanje. Davidova.
\q1 
\v 1 Gospode! Ne nadima se srce moje,
\q2 niti se uznose oči moje;
\q1 niti idem na veliko,
\q2 ni na ono što je više od mene.
\q1 
\v 2 Smeran sam i krotak dušom svojom,
\q2 kao dete kraj matere;
\q2 kao dete duša je moja u meni.
\b
\q1 
\v 3 Nek se uzda Izrailj u Gospoda
\q2 odsad i doveka.
\c 132
\cl Psalam 132
\s1 Molitva za Davidov dom zbog Božijeg obricanja.
\d Pesma za penjanje.
\q1 
\v 1 Opomeni se, Gospode, Davida
\q2 i sve smernosti njegove,
\q1 
\v 2 Kako se kunuo Gospodu,
\q2 i zavetovao Bogu Jakovljevom:
\q1 
\v 3 „Neću ući u šator doma svog,
\q2 niti ću leći na postelju odra svog;
\q1 
\v 4 Neću dati sna očima svojim,
\q2 ni veđama svojim drema;
\q1 
\v 5 Dok ne nađem mesta Gospodu,
\q2 stana Bogu Jakovljevom.”
\b
\q1 
\v 6 Evo, čusmo da je u Jefremovoj zemlji,
\q2 nađosmo Ga na poljima kirijat-jarimskim.
\q1 
\v 7 Uđimo u stan Njegov,
\q2 poklonimo se podnožju nogu Njegovih.
\b
\q1 
\v 8 Stani, Gospode, na počivalištu svom,
\q2 Ti i kovčeg sile Tvoje.
\q1 
\v 9 Sveštenici Tvoji nek se obuku u pravdu,
\q2 i sveci Tvoji nek se raduju.
\q1 
\v 10 Radi Davida, sluge svog,
\q2 nemoj odvratiti lica od pomazanika svog.
\b
\q1 
\v 11 Zakle se Gospod Davidu u istini,
\q2 od koje neće odstupiti;
\q1 od poroda tvog
\q2 posadiću na prestolu tvom.
\q1 
\v 12 Ako sinovi tvoji uščuvaju zavet moj
\q2 i otkrivenja moja kojima ću ih naučiti,
\q1 onda će i sinovi njihovi
\q2 doveka sedeti na prestolu svom.
\b
\q1 
\v 13 Jer je izabrao Gospod Sion,
\q2 i omile Mu živeti na njemu.
\q1 
\v 14 Ovo je počivalište moje uvek,
\q2 ovde ću se naseliti; jer mi je omilelo.
\q1 
\v 15 Hranu ću njegovu blagosloviti,
\q2 nište njegove nasitiću hleba.
\q1 
\v 16 Sveštenike ću njegove obući u spasenje,
\q2 i sveti će se njegovi radovati.
\q1 
\v 17 Tu ću učiniti da uzraste rog Davidu,
\q2 postaviću videlo pomazaniku svom.
\q1 
\v 18 Neprijatelje ću njegove obući u sramotu;
\q2 a na njemu će cvetati venac njegov.
\c 133
\cl Psalam 133
\s1 Blagoslovena je bratska sloga.
\d Pesma za penjanje. Davidova.
\q1 
\v 1 Kako je lepo i krasno
\q2 kad sva braća žive zajedno!
\q1 
\v 2 Kao dobro ulje na glavi,
\q2 koje se stače na bradu, bradu Aronovu,
\q2 koje se stače na skut od haljine njegove;
\q1 
\v 3 Kao rosa na Ermonu,
\q2 koja silazi na gore sionske;
\q1 jer je onde utvrdio Gospod blagoslov
\q2 i život doveka.
\c 134
\cl Psalam 134
\s1 Zahvalna pesma u domu Gospodnjem noću.
\d Pesma za penjanje.
\q1 
\v 1 Sad blagosiljajte Gospoda, sve sluge Gospodnje,
\q2 koje stojite u domu Gospodnjem noću.
\q1 
\v 2 Podignite ruke svoje k svetinji,
\q2 i blagosiljajte Gospoda.
\b
\q1 
\v 3 Blagosloviće te sa Siona Gospod,
\q2 koji je stvorio nebo i zemlju.
\c 135
\cl Psalam 135
\s1 Svemogućnost Božija, nemoć idolska.
\d Aliluja.
\q1 
\v 1 Hvalite ime Gospodnje,
\q2 hvalite, sluge Gospodnje,
\q1 
\v 2 Koji stojite u domu Gospodnjem;
\q2 u dvorima doma Boga našeg.
\q1 
\v 3 Hvalite Gospoda, jer je dobar Gospod;
\q2 pojte imenu Njegovom, jer je slatko.
\q1 
\v 4 Jer Jakova izabra sebi Gospod,
\q2 Izrailja za dostojanje svoje.
\b
\q1 
\v 5 Jer poznah da je velik Gospod,
\q2 i Gospod naš svrh svih bogova.
\q1 
\v 6 Šta god hoće, sve Gospod čini,
\q2 na nebesima i na zemlji,
\q2 u morima i u svim bezdanima.
\q1 
\v 7 Izvodi oblake od kraja zemlje,
\q2 munje čini usred dažda,
\q2 izvodi vetar iz staja njegovih.
\b
\q1 
\v 8 On pobi prvence u Misiru
\q2 od čoveka do živinčeta.
\q1 
\v 9 Pokaza znake i čudesa usred tebe, Misire,
\q2 na Faraonu i na svim slugama njegovim.
\q1 
\v 10 Pobi narode velike,
\q2 i izgubi careve jake:
\q1 
\v 11 Siona, cara amorejskog
\q2 i Oga, cara vasanskog,
\q2 i sva carstva hananska;
\q1 
\v 12 I dade zemlju njihovu u dostojanje,
\q2 u dostojanje Izrailju, narodu svom.
\b
\q1 
\v 13 Gospode! Ime je Tvoje večno;
\q2 Gospode! Spomen je Tvoj od kolena do kolena.
\q1 
\v 14 Jer će suditi Gospod narodu svom,
\q2 i na sluge svoje smilovaće se.
\b
\q1 
\v 15 Idoli su neznabožački srebro i zlato,
\q2 delo ruku čovečijih;
\q1 
\v 16 Usta imaju, a ne govore;
\q2 oči imaju, a ne vide;
\q1 
\v 17 Uši imaju, a ne čuju;
\q2 niti ima dihanja u ustima njihovim.
\q1 
\v 18 Kakvi su oni onakvi su i oni koji ih grade,
\q2 i svi koji se uzdaju u njih.
\b
\q1 
\v 19 Dome Izrailjev, blagosiljaj Gospoda;
\q2 dome Aronov, blagosiljaj Gospoda;
\q1 
\v 20 Dome Levijev, blagosiljaj Gospoda;
\q2 koji se bojite Gospoda, blagosiljajte Gospoda.
\q1 
\v 21 Blagosloven Gospod na Sionu,
\q2 koji živi u Jerusalimu!
\q1 Aliluja!
\c 136
\cl Psalam 136
\s1 Veličanje večne milosti Božije i Božijih čuda.
\q1 
\v 1 Slavite Gospoda, jer je dobar;
\q2 jer je doveka milost Njegova;
\q1 
\v 2 Slavite Boga nad bogovima;
\q2 jer je doveka milost Njegova.
\q1 
\v 3 Slavite Gospodara nad gospodarima;
\q2 jer je doveka milost Njegova;
\b
\q1 
\v 4 Onog, koji jedan tvori čudesa velika;
\q2 jer je doveka milost Njegova;
\q1 
\v 5 Koji je stvorio nebesa premudro;
\q2 jer je doveka milost Njegova;
\q1 
\v 6 Utvrdio zemlju na vodi;
\q2 jer je doveka milost Njegova;
\q1 
\v 7 Stvorio velika videla;
\q2 jer je doveka milost Njegova;
\q1 
\v 8 Sunce, da upravlja danom;
\q2 jer je doveka milost Njegova;
\q1 
\v 9 Mesec i zvezde, da upravljaju noću;
\q2 jer je doveka milost Njegova;
\b
\q1 
\v 10 Koji pobi Misir u prvencima njegovim;
\q2 jer je doveka milost Njegova;
\q1 
\v 11 Izvede iz njega Izrailja;
\q2 jer je doveka milost Njegova;
\q1 
\v 12 Rukom krepkom i mišicom podignutom;
\q2 jer je doveka milost Njegova;
\q1 
\v 13 Koji razdvoji Crveno More;
\q2 jer je doveka milost Njegova;
\q1 
\v 14 I provede Izrailja kroz sred njega;
\q2 jer je doveka milost Njegova;
\q1 
\v 15 A Faraona i vojsku njegovu vrže u more crveno;
\q2 jer je doveka milost Njegova;
\q1 
\v 16 Prevede narod svoj preko pustinje;
\q2 jer je doveka milost Njegova;
\b
\q1 
\v 17 Pobi careve velike;
\q2 jer je doveka milost Njegova;
\q1 
\v 18 I izgubi careve znatne;
\q2 jer je doveka milost Njegova;
\q1 
\v 19 Siona, cara amorejskog;
\q2 jer je doveka milost Njegova;
\q1 
\v 20 I Oga, cara vasanskog;
\q2 jer je doveka milost Njegova;
\q1 
\v 21 I dade zemlju njihovu u dostojanje;
\q2 jer je doveka milost Njegova;
\q1 
\v 22 U dostojanje Izrailju, sluzi svom;
\q2 jer je doveka milost Njegova;
\b
\q1 
\v 23 Koji nas se opomenu u poniženju našem;
\q2 jer je doveka milost Njegova;
\q1 
\v 24 I izbavi nas od neprijatelja naših;
\q2 jer je doveka milost Njegova;
\q1 
\v 25 Koji daje hranu svakom telu;
\q2 jer je doveka milost Njegova;
\b
\q1 
\v 26 Slavite Boga nebeskog;
\q2 jer je doveka milost Njegova.
\c 137
\cl Psalam 137
\s1 Tugovanje zarobljenih u Vavilonu.
\q1 
\v 1 Na vodama vavilonskim
\q2 seđasmo i plakasmo
\q2 opominjući se Siona.
\q1 
\v 2 O vrbama sred njega vešasmo harfe svoje.
\q1 
\v 3 Onde iskahu koji nas zarobiše
\q2 da pevamo,
\q1 i koji nas oboriše
\q2 da se veselimo:
\q1 „Pevajte nam pesmu sionsku.”
\b
\q1 
\v 4 Kako ćemo pevati pesmu Gospodnju
\q2 u zemlji tuđoj?
\q1 
\v 5 Ako zaboravim tebe, Jerusalime,
\q2 neka me zaboravi desnica moja.
\q1 
\v 6 Neka prione jezik moj za usta moja,
\q2 ako tebe ne uspamtim,
\q1 ako ne uzdržim Jerusalima
\q2 svrh veselja svog.
\b
\q1 
\v 7 Napomeni, Gospode, sinovima Edomovim
\q2 dan jerusalimski,
\q2 kad govoriše: Raskopajte, raskopajte ga do temelja.
\q1 
\v 8 Kćeri vavilonska, krvnico,
\q2 blago onome ko ti plati
\q2 za delo koje si nama učinila!
\q1 
\v 9 Blago onome koji uzme i razbije
\q2 decu tvoju o kamen.
\c 138
\cl Psalam 138
\s1 Zahvalna pesma zbog pomoći Božije u nevolji.
\d Psalam Davidov.
\q1 
\v 1 Slavim Te, Gospode, od svega srca svog,
\q2 pred bogovima pevam Tebi.
\q1 
\v 2 Poklanjam se pred svetom crkvom Tvojom,
\q2 i slavim ime Tvoje,
\q1 za dobrotu Tvoju i za istinu Tvoju;
\q2 jer si po svakom imenu svom podigao reč svoju.
\q1 
\v 3 U dan, u koji zazvah, Ti si me uslišio,
\q2 dunuo slobodu u dušu moju.
\b
\q1 
\v 4 Slaviće Te, Gospode, svi carevi zemaljski,
\q2 kad čuju reči usta Tvojih;
\q1 
\v 5 I pevaće puteve Gospodnje,
\q2 jer je velika slava Gospodnja.
\q1 
\v 6 Jer je visok Gospod,
\q2 i vidi niskog,
\q2 i visokog izdaleka poznaje.
\b
\q1 
\v 7 Ako pođem u tuzi,
\q2 Ti ćeš me oživeti;
\q1 na zloću neprijatelja mojih
\q2 pružićeš ruku svoju
\q2 i zakloniće me desnica Tvoja.
\q1 
\v 8 Gospod će svršiti za mene.
\q2 Gospode! Milost je Tvoja doveka;
\q2 dela ruku svojih ne ostavljaj.
\c 139
\cl Psalam 139
\s1 Bog sve zna i sve vidi.
\d Načelniku pevačkom. Psalam Davidov.
\q1 
\v 1 Gospode! Ti me kušaš i znaš.
\q2 
\v 2 Ti znaš kad sedam i kad ustanem;
\q2 Ti znaš pomisli moje izdaleka;
\q1 
\v 3 Kad hodim i kad se odmaram, Ti si oko mene,
\q2 i sve puteve moje vidiš.
\q1 
\v 4 Još nema reči na jeziku mom,
\q2 a Ti, Gospode, gle, već sve znaš.
\q1 
\v 5 Sastrag i spred Ti si me zaklonio,
\q2 i stavio na me ruku svoju.
\q1 
\v 6 Čudno je za me znanje Tvoje,
\q2 visoko, ne mogu da ga dokučim.
\b
\q1 
\v 7 Kuda bih otišao od duha Tvog,
\q2 i od lica Tvog kuda bih pobegao?
\q1 
\v 8 Da izađem na nebo, Ti si onde.
\q2 Da siđem u pakao, onde si.
\q1 
\v 9 Da se dignem na krilima od zore,
\q2 i preselim se na kraj mora:
\q1 
\v 10 I onde će me ruka Tvoja voditi,
\q2 i držati me desnica Tvoja.
\q1 
\v 11 Da kažem: Da ako me mrak sakrije;
\q2 ali je i noć kao videlo oko mene.
\q1 
\v 12 Ni mrak neće zamračiti od Tebe,
\q2 i noć je svetla kao dan:
\q2 mrak je kao videlo.
\b
\q1 
\v 13 Jer si Ti stvorio šta je u meni,
\q2 sastavio si me u utrobi matere moje.
\q1 
\v 14 Hvalim Te, što sam divno sazdan.
\q2 Divna su dela Tvoja,
\q2 i duša moja to zna dobro.
\q1 
\v 15 Nijedna se kost moja nije sakrila od Tebe,
\q2 ako i jesam sazdan tajno,
\q2 otkan u dubini zemaljskoj.
\q1 
\v 16 Zametak moj videše oči Tvoje,
\q2 u knjizi je Tvojoj sve to zapisano,
\q1 i dani zabeleženi,
\q2 kad ih još nije bilo nijednog.
\b
\q1 
\v 17 Kako su mi nedokučive pomisli Tvoje, Bože!
\q2 Kako im je velik broj!
\q1 
\v 18 Da ih brojim, više ih je nego peska.
\q2 Kad se probudim, još sam s Tobom.
\b
\q1 
\v 19 Da hoćeš, Bože, ubiti bezbožnika!
\q2 Krvopije, idite od mene.
\q1 
\v 20 Oni govore ružno na Tebe;
\q2 uzimaju ime Tvoje uzalud neprijatelji Tvoji.
\q1 
\v 21 Zar da ne mrzim na one, koji na Te mrze, Gospode,
\q2 i da se ne gadim na one koji ustaju na Tebe?
\q1 
\v 22 Punom mrzošću mrzim na njih;
\q2 neprijatelji su mi.
\b
\q1 
\v 23 Okušaj me, Bože, i poznaj srce moje,
\q2 ispitaj me, i poznaj pomisli moje.
\q1 
\v 24 I vidi jesam li na zlom putu,
\q2 i vodi me na put večni.
\c 140
\cl Psalam 140
\s1 Molitva da se ne padne u mrežu lukavih neprijatelja.
\d Načelniku pevačkom. Psalam Davidov.
\q1 
\v 1 Izbavi me, Gospode, od čoveka zlog,
\q2 sačuvaj me od nasilnika,
\q1 
\v 2 Koji pomišljaju zlo u srcu
\q2 i svaki dan podižu rat;
\q1 
\v 3 Oštre jezik svoj kao zmija,
\q2 jed je aspidin u ustima njihovim.
\b
\q1 
\v 4 Sačuvaj me, Bože, od ruku bezbožničkih,
\q2 od nasilnika sahrani me,
\q2 koji misle da potkinu noge moje.
\q1 
\v 5 Oholi mi namestiše zamke i prugla,
\q2 metnuše mi mrežu na put,
\q2 pređu razapeše mi.
\b
\q1 
\v 6 Rekoh Gospodu: Ti si Bog moj,
\q2 usliši, Gospode, glas moljenja mog.
\q1 
\v 7 Gospode, Gospode, krepki Spasitelju moj,
\q2 zakloni glavu moju u dan ratni!
\q1 
\v 8 Ne daj, Gospode, bezbožniku šta želi,
\q2 ne daj mu da dokuči šta je naumio,
\q2 da se ne uznose.
\b
\q1 
\v 9 Otrov onih što su oko mene,
\q2 pogibao usta njihovih neka se obrati na njih.
\q1 
\v 10 Neka padne na njih živo ugljevlje;
\q2 neka ih On baci u oganj,
\q2 u propasti, da ne ustanu.
\q1 
\v 11 Čovek jezičan neće se utvrditi na zemlji,
\q2 nepravednog će zloća uvaliti u pogibao.
\b
\q1 
\v 12 Znam da će Gospod pokazati pravdu nevoljnome
\q2 i pravicu ubogima.
\q1 
\v 13 Da! Pravedni će slaviti ime Tvoje,
\q2 pravi će ostati pred licem Tvojim.
\c 141
\cl Psalam 141
\s1 Molitva da nas Bog sačuva od zlih.
\d Psalam Davidov.
\q1 
\v 1 Gospode, vičem k Tebi, pohitaj k meni,
\q2 čuj glas moljenja mog, kad vičem k Tebi.
\q1 
\v 2 Nek izađe molitva moja
\q2 kao kad pred lice Tvoje,
\q1 dizanje ruku mojih
\q2 kao prinos, večernji.
\b
\q1 
\v 3 Postavi, Gospode, stražu kod jezika mog,
\q2 čuvaj vrata usta mojih.
\q1 
\v 4 Ne daj srcu mom da zastrani na zle pomisli,
\q2 da čini dela bezbožna s ljudima koji postupaju nepravedno;
\q1 i da ne okusim sladosti njihove.
\b
\q1 
\v 5 Neka me bije pravednik, to je milost;
\q2 neka me kara, to je ulje za glavu moju;
\q1 glava moja neće odbaciti, ako će i više;
\q2 nego je molitva moja protiv zloće njihove.
\q1 
\v 6 Rasuše se po kamenim vrletima sudije njihove,
\q2 i čuše reči moje kako su blage.
\q1 
\v 7 Kao kad ko seče i teše,
\q2 tako se razleteše kosti naše
\q2 do čeljusti paklenih.
\b
\q1 
\v 8 Ali su k Tebi, Gospode, Gospode, upravljene oči moje,
\q2 u Tebe se uzdam,
\q2 nemoj odbaciti dušu moju.
\q1 
\v 9 Sačuvaj me od zamke, koju mi metnuše,
\q2 od lukavstva onih, koji čine bezakonje.
\q1 
\v 10 Pašće u mreže svoje bezbožnici,
\q2 a ja ću jedan proći.
\c 142
\cl Psalam 142
\s1 Duša u velikom strahu uzdiše i traži pomoć Božiju.
\r (1. Samuilova 24:3)
\d Nauk Davidov. Molitva, kad beše u pećini.
\q1 
\v 1 Glasom svojim ka Gospodu vičem,
\q2 glasom svojim Gospodu se molim.
\q1 
\v 2 Izlivam pred Njim moljenje svoje,
\q2 tugu svoju pred Njim kazujem,
\b
\q1 
\v 3 Kad iznemogne u meni duh moj.
\q2 Ti znaš stazu moju.
\q1 Na putu, kojim hodim,
\q2 sakriše mi zamku.
\q1 
\v 4 Pogledam nadesno,
\q2 i vidim da me niko ne zna;
\q1 nestade mi utočišta,
\q2 niko ne mari za dušu moju.
\b
\q1 
\v 5 Vičem k Tebi, Gospode;
\q2 velim: Ti si utočište moje,
\q2 deo moj na zemlji živih.
\q1 
\v 6 Čuj tužnjavu moju;
\q2 jer se mučim veoma.
\q1 Izbavi me od onih koji me gone,
\q2 jer su jači od mene.
\q1 
\v 7 Izvedi iz tamnice dušu moju,
\q2 da slavim ime Tvoje.
\q1 Oko mene će se skupiti pravednici,
\q2 kad mi učiniš dobro.
\c 143
\cl Psalam 143
\s1 Molitva da nas Bog izbavi i da nas vodi.
\d Psalam Davidov.
\q1 
\v 1 Gospode, usliši molitvu moju,
\q2 primi moljenje moje po istini svojoj,
\q2 usliši me po pravdi svojoj.
\q1 
\v 2 I ne idi na sud sa slugom svojim,
\q2 jer se neće opravdati pred Tobom niko živ.
\b
\q1 
\v 3 Neprijatelj goni dušu moju,
\q2 gazi u prah život moj,
\q1 posađuje me u mrak,
\q2 kao davno pomrle.
\q1 
\v 4 Trne u meni duh moj,
\q2 nestaje u meni srca mog.
\b
\q1 
\v 5 Pominjem dane stare,
\q2 prebrajam sve poslove Tvoje,
\q2 razmišljam o delima ruku Tvojih.
\q1 
\v 6 Pružam k Tebi ruke svoje;
\q2 duša je moja kao suva zemlja pred Tobom.
\b
\q1 
\v 7 Pohitaj, usliši me;
\q2 Gospode, nestaje duha mog,
\q1 nemoj odvratiti lice svoje od mene;
\q2 jer ću biti kao oni koji odlaze u grob.
\q1 
\v 8 Rano mi javi milost svoju,
\q2 jer se u Tebe uzdam.
\q1 Pokaži mi put, kojim da idem,
\q2 jer k Tebi podižem dušu svoju.
\b
\q1 
\v 9 Izbavi me od neprijatelja mojih, Gospode,
\q2 k Tebi pritečem.
\q1 
\v 10 Nauči me Tvoriti volju Tvoju,
\q2 jer si Ti Bog moj;
\q1 duh Tvoj blagi neka me vodi
\q2 po stazi pravoj.
\b
\q1 
\v 11 Imena radi svog, Gospode, oživi me,
\q2 po pravdi svojoj izvedi iz muke dušu moju.
\q1 
\v 12 I po milosti svojoj istrebi neprijatelje moje,
\q2 i pogubi sve koji muče dušu moju,
\q2 jer sam Tvoj sluga.
\c 144
\cl Psalam 144
\s1 Molitva da Bog zaštiti i blagoslovi svoj narod.
\d Psalam Davidov.
\q1 
\v 1 Blagosloven Gospod, grad moj,
\q2 koji uči ruke moje boju, prste moje ratu,
\q1 
\v 2 Dobrotvor moj i ograda moja,
\q2 utočište moje i Izbavitelj moj,
\q1 Štit moj, Onaj u koga se uzdam,
\q2 koji mi pokorava narod moj.
\b
\q1 
\v 3 Gospode! Šta je čovek, te znaš za nj,
\q2 i sin smrtnoga, te ga paziš?
\q1 
\v 4 Čovek je kao ništa;
\q2 dani su njegovi kao sen, koji prolazi.
\b
\q1 
\v 5 Gospode! Savij nebesa svoja, i siđi;
\q2 dotakni se gora, i zadimiće se.
\q1 
\v 6 Sevni munjom, i razagnaj ih;
\q2 pusti strele svoje, i raspi ih.
\q1 
\v 7 Pruži ruku svoju s visine, izbavi me
\q2 i izvadi me iz vode velike,
\q2 iz ruku tuđinaca,
\q1 
\v 8 Kojih usta govore ništavne stvari,
\q2 i kojih je desnica desnica lažna.
\b
\q1 
\v 9 Bože! Pesmu novu pevaću Ti,
\q2 u psaltir od deset žica udaraću Tebi,
\q1 
\v 10 Koji daješ spasenje carevima,
\q2 i Davida slugu svog izbavljaš od ljutog mača.
\q1 
\v 11 Izbavi me i otmi me iz ruke tuđinaca,
\q2 kojih usta govore ništavne stvari,
\q2 i kojih je desnica desnica lažna.
\b
\q1 
\v 12 Sinovi naši neka budu kao bilje,
\q2 koje veselo odraste u mladosti;
\q1 kćeri naše kao stupovi
\q2 prekrasno izrađeni u dvoru;
\q1 
\v 13 Žitnice naše pune,
\q2 obilne svakim žitom;
\q1 ovce naše nek se množe na hiljade i na sto hiljada
\q2 po stanovima našim.
\q1 
\v 14 Volovi naši neka budu tovni;
\q2 neka ne budu napadanja, ni bežanja,
\q2 ni tužnjave po ulicama našim.
\q1 
\v 15 Blago narodu, u kog je sve ovako!
\q2 Blago narodu, u kog je Gospod Bog!
\c 145
\cl Psalam 145
\s1 Milost i pravičnost Boga u njegovom carstvu.
\d Hvala Davidova.
\q1 
\v 1 Uzvišavaću Te, Bože moj, care moj,
\q2 blagosiljaću ime Tvoje od veka do veka.
\q1 
\v 2 Svaki ću Te dan blagosiljati,
\q2 i hvaliću ime Tvoje doveka i bez prestanka.
\q1 
\v 3 Velik je Gospod, i valja Ga slaviti,
\q2 i veličanstvo Njegovo ne može se dosegnuti.
\b
\q1 
\v 4 Od kolena do kolena hvaliće dela Tvoja,
\q2 i silu Tvoju kazivati.
\q1 
\v 5 O visokoj slavi Tvog veličanstva,
\q2 i o divnim delima Tvojim razmišljam.
\q1 
\v 6 Pripovedaće silu čudesa Tvojih,
\q2 i ja ću veličanstvo Tvoje kazivati.
\q1 
\v 7 Hvaliće veliku dobrotu Tvoju
\q2 i pravdu Tvoju pevaće.
\b
\q1 
\v 8 Podatljiv je i milosrdan Gospod,
\q2 dugo trpi i velike je milosti.
\q1 
\v 9 Dobar je Gospod prema svima,
\q2 i žalostiv na sva dela svoja.
\b
\q1 
\v 10 Neka Te slave, Gospode, sva dela Tvoja,
\q2 i sveci Tvoji neka Te blagosiljaju.
\q1 
\v 11 Neka kazuju slavu carstva Tvog,
\q2 i silu Tvoju pripovedaju.
\q1 
\v 12 Da bi javili sinovima ljudskim silu Tvoju,
\q2 i visoku slavu carstva Tvog.
\q1 
\v 13 Carstvo je Tvoje carstvo svih vekova,
\q2 i vlada Tvoja na sva kolena.
\b
\q1 
\v 14 Gospod prihvata sve koji padaju,
\q2 i ispravlja sve pognute.
\q1 
\v 15 Oči su svih k Tebi upravljene,
\q2 i Ti im daješ hranu na vreme;
\q1 
\v 16 Otvaraš ruku svoju,
\q2 i sitiš svašta živo po želji.
\q1 
\v 17 Pravedan je Gospod u svim putevima svojim,
\q2 i svet u svim delima svojim.
\q1 
\v 18 Gospod je blizu svih koji Ga prizivaju,
\q2 svih, koji Ga prizivaju u istini.
\q1 
\v 19 Želju ispunja onima koji Ga se boje,
\q2 tužnjavu njihovu čuje, i pomaže im.
\q1 
\v 20 Čuva Gospod sve koji Ga ljube,
\q2 a bezbožnike sve će istrebiti.
\b
\q1 
\v 21 Hvalu Gospodu neka govore usta moja,
\q2 i neka blagosilja svako telo sveto ime Njegovo
\q2 uvek i bez prestanka.
\c 146
\cl Psalam 146
\s1 Večna vernost Božija.
\d Aliluja.
\q1 
\v 1 Hvali, dušo moja, Gospoda.
\q2 
\v 2 Hvaliću Gospoda za života svog,
\q2 pevaću Bogu svom dok me je god.
\b
\q1 
\v 3 Ne uzdajte se u knezove,
\q2 u sina čovečijeg, u kog nema pomoći.
\q1 
\v 4 Iziđe iz njega duh, i vrati se u zemlju svoju:
\q2 taj dan propadnu sve pomisli njegove.
\b
\q1 
\v 5 Blago onome, kome je pomoćnik Bog Jakovljev,
\q2 kome je nadanje u Gospodu, Bogu njegovom,
\q1 
\v 6 Koji je stvorio nebo i zemlju,
\q2 more i sve što je u njima;
\q2 koji drži veru uvek,
\q1 
\v 7 Čini sud onima kojima se čini krivo;
\q2 daje hranu gladnima.
\b
\q1 Gospod dreši svezane,
\q2 
\v 8 Gospod otvara oči slepcima,
\q1 podiže oborene,
\q2 Gospod ljubi pravednike.
\q1 
\v 9 Gospod čuva došljake,
\q2 pomaže siroti i udovici;
\q2 a put bezbožnički prevraća.
\b
\q1 
\v 10 Gospod je car doveka,
\q2 Bog tvoj, Sione, od kolena do kolena.
\q1 Aliluja.
\c 147
\cl Psalam 147
\s1 Proslavljanje duhovnih i telesnih darova Božijih.
\q1 
\v 1 Hvalite Gospoda,
\q2 jer je slatko pevati Boga našeg,
\q2 jer Blagome prilikuje hvala.
\q1 
\v 2 Gospod zida Jerusalim,
\q2 sabira rasejane sinove Izrailjeve;
\q1 
\v 3 Isceljuje one koji su skrušenog srca,
\q2 i leči tuge njihove;
\q1 
\v 4 Izbraja mnoštvo zvezda,
\q2 i sve ih zove imenom.
\q1 
\v 5 Velik je Gospod naš
\q2 i velika je krepost Njegova,
\q2 i razumu Njegovom nema mere.
\q1 
\v 6 Prihvata smerne Gospod,
\q2 a bezbožne ponižava do zemlje.
\b
\q1 
\v 7 Redom pevajte Gospodu hvalu,
\q2 udarajte Bogu našem u gusle.
\q1 
\v 8 On zastire nebo oblacima,
\q2 sprema zemlji dažd,
\q2 čini te raste na gorama trava;
\q1 
\v 9 Daje stoci piću njenu,
\q2 i vranićima, koji viču k Njemu.
\q1 
\v 10 Ne mari za silu konjsku,
\q2 niti su Mu mili kraci čovečiji.
\q1 
\v 11 Mili su Gospodu oni koji Ga se boje,
\q2 koji se uzdaju u milost Njegovu.
\b
\q1 
\v 12 Slavi, Jerusalime, Gospoda;
\q2 hvali Boga svog, Sione!
\q1 
\v 13 Jer On utvrđuje prevornice vrata tvojih,
\q2 blagosilja sinove tvoje u tebi.
\q1 
\v 14 Ograđuje međe tvoje mirom,
\q2 nasićava te jedre pšenice.
\q1 
\v 15 Šalje govor svoj na zemlju,
\q2 brzo teče reč Njegova.
\q1 
\v 16 Daje sneg kao vunu,
\q2 sipa inje kao pepeo.
\q1 
\v 17 Baca grad svoj kao zalogaje,
\q2 pred mrazom Njegovim ko će ostati?
\q1 
\v 18 Pošalje reč svoju, i sve se raskravi;
\q2 dune duhom svojim, i poteku vode.
\q1 
\v 19 On je javio reč svoju Jakovu,
\q2 naredbe i sudove svoje Izrailju.
\q1 
\v 20 Ovo nije učinio ni jednom drugom narodu,
\q2 i sudova Njegovih oni ne znaju.
\q1 Aliluja!
\c 148
\cl Psalam 148
\s1 Neka ceo svet hvali Gospoda.
\d Aliluja.
\q1 
\v 1 Hvalite Gospoda na nebesima,
\q2 hvalite Ga na visini.
\q1 
\v 2 Hvalite Ga, svi anđeli Njegovi,
\q2 hvalite Ga, sve vojske Njegove!
\b
\q1 
\v 3 Hvalite Ga, sunce i meseče,
\q2 hvalite Ga, sve zvezde sjajne!
\q1 
\v 4 Hvalite Ga, nebesa nad nebesima
\q2 i vodo nad nebesima!
\b
\q1 
\v 5 Neka hvale ime Gospodnje,
\q2 jer On zapovedi i stvoriše se.
\q1 
\v 6 Postavi ih zasvagda i zavavek,
\q2 dade naredbu, koja neće proći.
\b
\q1 
\v 7 Hvalite Gospoda na zemlji,
\q2 velike ribe i sve bezdane;
\q1 
\v 8 Oganj i grad,
\q2 sneg i magla,
\q2 vetar silni, koji izvršuje reč Njegovu.
\b
\q1 
\v 9 Gore i svi humovi,
\q2 rodna drveta i svi kedri,
\q1 
\v 10 Zveri i sva stoka,
\q2 bubine i ptice krilate,
\b
\q1 
\v 11 Carevi zemaljski i svi narodi,
\q2 knezovi i sve sudije zemaljske,
\q1 
\v 12 Momci i devojke,
\q2 starci i deca
\b
\q1 
\v 13 Neka hvale ime Gospodnje;
\q2 jer je samo Njegovo ime uzvišeno,
\q2 slava Njegova na zemlji i na nebu.
\q1 
\v 14 On je uzvisio rog naroda svog,
\q2 slavu svih svetaca svojih,
\q1 sinova Izrailjevih,
\q2 naroda koji je blizu Njega.
\c 149
\cl Psalam 149
\s1 Neka Sion hvali Gospoda!
\d Aliluja.
\q1 
\v 1 Pojte Gospodu pesmu novu;
\q2 hvala da Mu je na saboru svetih.
\q1 
\v 2 Neka se veseli Izrailj o Stvoritelju svom,
\q2 sinovi sionski nek se raduju o caru svom.
\q1 
\v 3 Neka hvale ime Njegovo poklikujući,
\q2 u bubanj i gusle neka Mu udaraju.
\q1 
\v 4 Jer je mio Gospodu narod Njegov,
\q2 ukrašava smerne spasavajući ih.
\q1 
\v 5 Nek se vesele sveci u slavi,
\q2 i nek se raduju na posteljama svojim.
\q1 
\v 6 Slava je Božija u ustima njihovim,
\q2 i mač s obe strane oštar u ruci njihovoj,
\q1 
\v 7 Da se osvete narodima,
\q2 i pokaraju plemena;
\q1 
\v 8 Da svežu careve njihove u lance,
\q2 i vlastelu njihovu u okove gvozdene,
\q1 
\v 9 I izvrše na njima napisani sud.
\q2 Ova je čast svima svecima Njegovim.
\q1 Aliluja!
\c 150
\cl Psalam 150
\s1 Sve što diše neka hvali Gospoda!
\d Aliluja.
\q1 
\v 1 Hvalite Boga u svetinji Njegovoj,
\q2 hvalite Ga na tvrđi slave Njegove.
\q1 
\v 2 Hvalite Ga prema sili Njegovoj,
\q2 hvalite Ga prema visokom veličanstvu Njegovom.
\b
\q1 
\v 3 Hvalite Ga uz glas trubni,
\q2 hvalite Ga uz psaltir i gusle.
\q1 
\v 4 Hvalite Ga s bubnjem i veseljem,
\q2 hvalite Ga uz žice i organ.
\q1 
\v 5 Hvalite Ga uz jasne kimvale,
\q2 hvalite Ga uz kimvale gromovne.
\q1 
\v 6 Sve što diše neka hvali Gospoda!
\q2 Aliluja! 
