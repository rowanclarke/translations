\id MAT  
\ide UTF8
\h Matthäus 
\toc1 Ngantjani‐jaura Matthæungundru 
\toc2 Matthæungundru 
\toc3 Mat 
\mt1 Ngantjani‐jaura Matthæungundru.  
\c 1  
\lit (Ngantjani‐jaura Mariananka dankani ditjini.)  
\p
\v 1 Pantjipantjini‐jaura Jesu Christungundru, Davidani ngatamuraia, Abrahamani ngatamuraia;   
\p
\v 2 Abrahamali kantji patana wonti Isaak, Isaakali kantji patana wonti Jacob, Jakobali kantji patana wonti Juda ja neji ja ngatata nunkani;   
\p
\v 3 Judali kantji patana wonii Phares ja Zara Thamarangundru, Pharesali kantji patana wonti Esrom, Esromali kantji patana wonti Aram;   
\p
\v 4 Aramali kantji patana wonti Aminadab, Aminadabali kantji patana wonti Naasson, Naassonali kantji patana wonti Salmon;   
\p
\v 5 Salmonali kantji patana wonti Boas Rahabangundru, Boasali kantji patana wonti Obed Ruthangundru, Obedali kantji patana wonti Jessai;   
\p
\v 6 Jessaili kantji patana wonti mitaia kapara David, David mitaia kaparali kantji patana wonti Salomo Uriani noandru;   
\p
\v 7 Salomojeli kantji patana wonti Rehabeam, Rehabeamali kantji patana wonti Abia, Abiali kantji patana wonti Asa;   
\p
\v 8 Asali kantji patana wonti Josaphat, Josaphatali kantji patana wonti Joram, Joramali kantji patana wonti Usia;   
\p
\v 9 Usiali kantji patana wonti Jotham, Jothamali kantji patana wonti Ahas, Ahasali kantji patana wonti Hiskias;   
\p
\v 10 Hiskiasali kantji patana wonti Manasse, Manassili kantji patana wonti Amon, Amonali kantji patana wonti Josia;   
\p
\v 11 Josiali kantji patana wonti Jechonia ja ngatata nunkani, jendranguta tanali tanana wapalkana wonti Babylaia,   
\p
\v 12 Ja tanali tanana Babylaia matja wapalkana, Jechoniali kantji patana wonti Salathiel, Salathieli kantji patana wonti Serubabel;   
\p
\v 13 Serubabelali kantji patana wonti Abiud, Abiudali kantji patana wonti Eliakim, Eliakimali kantji patana wonti Azor;   
\p
\v 14 Azorali kantji patana wonti Sadok, Sadokali kantji patana wonti Achim, Achimali kantji patana wonti Eliud;   
\p
\v 15 Eliudali kantji patana wonti Eleasar, Eleasarali kantji patana wonti Matthan, Matthanali kantji patana wonti Jacob;   
\p
\v 16 Jacobali kantji patana wonti Joseph, Mariananka noa, nankangundru dankana wonti Jesus, tala nunkani Christus.   
\p
\v 17 Kapara pratjana Abrahamangundru Davidanilu marapratjana ja mandrumandru nganai; Davidandru Babylaia wapalkanantulu kapara marapratjana ja mandrumandru nganai; Babylaia wapalkanandru Christungulu kapara marapratjana ja mandrumandru nganai.   
\b  
\p
\v 18 Jesus Christus dankana wonti jeruja: Maria, ngandri nunkani, matja talpadakaterina Josephangu, windrila pudla jela ngamala, nandru mankamankana wonti, nani mandrantju nganana wonti Jaolali kulikirieli.   
\p
\v 19 Ngangau Joseph, noa nankani, talku nganana wonti, ja wata jertapaterina wonti nana nintali ngankala, nulu ngundrana wonti, nana kurukuru worarala.   
\p
\v 20 Nulu jenia ngundranani, mai, Godaia angela kulno ngapitjani nunkangu wondraterina wonti ja jatana wonti: „Josephajai, Davidani ngatamurajai, wata japali nganau, Maria, noa jinkani patala; ngangau mina nandru patana warai, Jaola kulikirindru nganai.   
\p
\v 21 Nandru kupa kanku kantji patala nganai; nina jundru JESUS dikala nganai; ngangau kana wolara nunkani Nulu kulkala nganai tanani madlentjandru.“   
\p
\v 22 Jenia pratjana pantjina wonti, ngangau morlalu pantjinanto, mina Prophetali Kaparandru kaukaubana wonti, nau jatana wonti:   
\p
\v 23 „Mai! ngameri kulno mandrantju nganala nganai, ja nandru kupa kanku kantji patala nganai, ja tanali tala nunkani dikala nganai «Emmanuel», jenia wondrai: Goda‐ngaianangunto.“   
\p
\v 24 Joseph mukandru matja jiritjina, nulu jeruja ngankana wonti, worderu Kaparaia angelali nunkangu jirijiribana warai, ja nulu noa nunkani patana wonti.   
\p
\v 25 Ja nulu wata nana ngujamana wonti, nandru kupa kanku dankanantulu, ja nulu tala nunkani dikana wonti: „JESUS“.   
\c 2  
\lit (Ngantjani‐jaura Epiphanias ditjini.)  
\p
\v 1 Jesus matja kupa dankana warai Bethlehemingu, Judaia mitani, Herodini mitaia kaparaia ditjini; mai, jendranguta kana kiri wora tiriwandru Jerusalemingu wokarana wonti,   
\p
\v 2 Ja jatana wonti: „Woderi nau, Juda‐kanaia‐kapara matja dankana? Ngangau ngaiani ditji waka nunkani najinala tiriwani, ja wokarana warai nunkangu pantjaterkana ngarila.“   
\p
\v 3 Herodes, mitaia kaparali, jenia matja ngarana, nau japali ngaruparana wonti, ja nunkangu jela Jerusalemala warupoto.   
\p
\v 4 Ja nulu kana wolaraia Priesta pirna ja jaura jinkinietja pratjana kampana wonti ja tanana jekijekibana wonti, woderi Christus dankananto.   
\p
\v 5 Ja tana nunkangu jatana wonti: „Bethlehemingu Judaiani“; ngangau jeruja Prophetali dakana wonti:   
\p
\v 6 „Ja jidni Bethlehemiai, Judaia mitani, jidni wata ngadanietja nganai Judaia kapara marapuni, a‐ai, ngangau jinkangundru kapara dunkala nganai, Nulu kana wolara ngakani, Israel, ngamalkala nganai.“   
\p
\v 7 Ngadani Herodili kana kiri worana kurukuru karkana wonti ja tanana jiglerali jekijekibana wonti, winta ditji waka wondraterinala.   
\p
\v 8 Ja nulu tanana Bethlehemia jinpana wonti ja jatana wonti: „Palkanimai ja kupa parparali wontianau, ja jura nina matja mankamankana, ngakangu jaura tikalkanau, ngani bakana wokarananto nunkangu pantjaterkana ngarila.“   
\p
\v 9 Tanali mitaia kapara matja ngarana, tana palkana wonti. Ja mai, ditji waka nina tanali tiriwa najinala, tanangu ngopera wapana wonti, nau wokaranantulu miri banbala, woderi kupa nganana wonti.   
\p
\v 10 Tanali nina ditji waka najina, tana murlali pirna mankina wonti;   
\p
\v 11 Ja tana pungani matja wirina, tanali kupa waka najina wonti Mariangu, ngandrini nunkanani jela; ja tana pantjaterkana ngarina wonti nunkangu, ja tanali poto pirna piltana wonti, ja nunkangu poto jinkina wonti: Marda, maralje, kuli ngumu ja kaldri pilki.   
\p
\v 12 Ja Godali tanana ngapitjani daudauana wonti, tana wata morla Herodingu tikananto. Ja palto worku tana nakaldra tikana wonti mitaia tananaia.  
\b  
\lit (Ngantjani‐jaura kilpawoldra marrani Godaia ditji ngoperani.)  
\p
\v 13 Tana matja puntina, mai, Kaparaia angela kulno Josephangu ngapitjani wondraterina wonti ja jatana wonti: „Jiritjiau ja kupa ja ngandri nunkani manina kurau ja kuri‐kariau Egypta mitaia, ja naka ngamamai, ngani jinkangu jatanantulu; ngangau Herodes jertapateriai kupa wontila ninapara nandrala.“   
\p
\v 14 Nau jiritjina wonti ja kupa ja ngandri nunkani manina kurana wonti tinkani, ja kutingana wonti Egypta mitaia.   
\p
\v 15 Ja nau naka ngamana wonti Herodes palinantulu, ngangau morlalu pantjinanto, mina Prophetali Kaparandru kaukaubana wonti, nau jatana wonti: „Egypta mitandru ngato Ngatamura ngakani karkana wonti.“   
\p
\v 16 Herodili matja najina, kana kiri worali nina jedibala wiri, nau pirna tiririna wonti, ja nulu jinpana wonti Bethlehemingu ja wondirani pratjanani nunkanani ja kupa kanku pratjana nandrana wonti, tana kilpawoldra mandru ja morla waka nganana wonti, tanangupini ditjini, tanana nulu kana kiri worangu jekibala wiri.   
\p
\v 17 Jendranguta morlalu pantjina wonti, mina Jeremiasili Prophetali kaukaubana wonti, nau jatana wonti:   
\p
\v 18 „Ramangu tanali ngaiala ngarana wonti, miritja ja jildri ja juajuangana pirna; Rahel nankani kupandru jindrana wonti ja wata ngantjana wonti ngankalkananto, ngangau tana panila nganai.“   
\p
\v 19 Herodes matja nari, mai, Kaperaia angela kulno ngapitjani Josephangu wondraterina wonti Egypta mitani,   
\p
\v 20 Ja jatana wonti: „Jiritjiau ja kupa ja ngandri nunkani manina kurau, ja tikau, Israel mitaia; ngangau tana matja nari, tanali kupaia tepi wontina wonti.“   
\p
\v 21 Nau jiritjina wonti ja kupa ja ngandri nunkani manina kurana wonti ja Israel mitani wokarana wonti.   
\p
\v 22 Nulu matja ngarana, Archelaus Judaia mitaia kapara nganai Herodini ngaperaia nunkanaia pirini, nau japali pantjina wonti nakani palkala; ja nulu ngapitjali jirijiribani jaura manina wonti, ja nau palkana wonti Galilaia mitaia.   
\p
\v 23 Ja nau wokarana wonti ja ngamana wonti ngura kulnuni, tala nunkani Nazareth; ngangau morlalu pantjinanto Prophetaia jaura: „Tanali nina Nazarethala dikala nganai.“  
\b  
\c 3  
\p
\v 1 Tanangupini ditjini Johannes multibanietja wokarana wonti ja Judaia pitarani jaura jinkina wonti,   
\p
\v 2 Ja jatana wonti: „Madlentjandru karitjianau, ngangau pariwilpaia milila karakara nganai.“   
\p
\v 3 Naupini nau nganai, nunkangundru Jesaiasali Prophetali kaukaubana wonti; „Karkanietjaia ngaiala pitarani parai: Kaparaia palto ngankinganimai, ja tidna‐palto nunkani talku ngankanimai.“   
\p
\v 4 Johannili kati Kameel njurdu ja dala mantamanta kapani nunkanani ngamalkana wonti, ja buka nunkani palaparu ja pitjambu nganana wonti.   
\p
\v 5 Jendranguta nunkangu dunkana wonti Jesusalemala ja Judaiala pratjaterina ja Jordanala pratjaterina.   
\p
\v 6 Ja nulu tanana multibana wonti Jordan kaiarani, ja tanali madlentji tanani talku dikana wonti.   
\p
\v 7 Nulu Pharisaiala ja Sadduzaiala marapu nunkani multibanilaia wokaranani najina, nau tanangu jatana wonti: „Wiparaia kuparu worajai! warlenulu jurangu wondrana warai japa mindrinanto tirini nunkanani, nau wokarala nganai?“   
\p
\v 8 Madlentjandru karitjinaia tandra talku punkibanau!   
\p
\v 9 Ja wata munta ngundraterianau: „Ngaiana Abraham ngaperi ngaianani ngamalkai“; ngangau ngani jurangu jatai: „Goda ngurunguru nganai, tanangupini mardandru kupa jiritjibala Abrahamangu.“   
\p
\v 10 Kalara matja pita kaparani parai; Pita pratjana, wata tandra ngumu punkibanani, wokaribala nganai ja turuni worala nganai.   
\p
\v 11 Ngato jurana ngapali multibai madlentjandru karitjimalkala; ngakangu ngadani kulno wokarala nganai, Nau morla ngurunguru nganai ngakangu, nunkangu ngani wata talku nganai, tidnaputa nunkani padakijiribala, Nulu jurana multibala nganai Jaolali kulukirieli ja turujeli.   
\p
\v 12 Marani nunkanani pirra nunkani parai, ja Nulu jiraua nunkani darpala nganai, ja buka tandra nunkani kampani pungaia mapala nganai, ja ngurdi Nulu japila nganai turujeli, nau wata paliai.   
\lit (Ngantjani‐jaura Jesuja multibanila ditjini.)  
\p
\v 13 Ngadani Jesus Galilaiandru Jordan kaiarani Johanningu wokarana wonti, nunkangundru multibanila manila.   
\p
\v 14 Johannili nina daudauana wonti ja jatana wonti: „Ngato jinkangundru multibanila maninanto, ja jidni ngakangu wokarai“?   
\p
\v 15 Jesujeli kalabana wonti ja nunkangu jatana wonti: „Karari jenia manuni kurau, ngangau jeruja talku nganai ngaldrangu, talkula pratjana morlalu kurala.“ Ngadani nulu nunkangu manuni kurana wonti.   
\p
\v 16 Jesujeli matja multibanila manina, Nau nurujeli ngapandru dunkana tarana wonti; ja mai, pariwilpa piririna wonti, ja nulu najina wonti Godaia Jaola ngarinani mulapara jeribaka wokarala nunkangu.   
\p
\v 17 Ja mai! Ngaiala pariwilpandru jatana wonti: „Naupini Ngatamura ngantjalu ngakani nganai, nunkangu ngani murlali nganai.“   
\c 4  
\lit (Ngantjani‐jaura Invocavit ditjini.)  
\p
\v 1 Jendranguta Jaolali Jesus pitaraia taralkana wonti, kutjieli nina wontjananto.   
\p
\v 2 Ja Nau pota mandrumandru marapratjana ditji, ja pota mandrumandru marapratjana tinka milja ngamana warai, Nau ngadani mauali nganana wonti.   
\p
\v 3 Ja wontjanietja nunkangu wokarana wonti ja jatana wonti: „Jidni Godaia Ngatamura ngananani, jatamai, tanapini marda bukarinanto.“   
\p
\v 4 Nulu kalabana wonti ja jatana wonti: „Dakanala parai: Kana wata windri bukandru tepiriai, a‐ai, jaura warupotundru, nauja Godaia manandru dunkai.“   
\p
\v 5 Ngadani kutjieli nina ngura kulikiria padakana wonti, ja nina Godaia punga wutjuni terkibana wonti,   
\p
\v 6 Ja nunkangu jatana wonti: „Jidni Godaia Ngatamura ngananani, ngarinalu kulkungamai; ngangau dakanala parai: Nulu angelani nunkanani jirijiribala nganai jinkangundru, tanali jidna marali ngamalkala nganai, wata jidni tidna mardani dakaterinanto.“   
\p
\v 7 Jesus nunkangu jatana wonti: „Nakaldra dakanala parai: Goda Kapara jinkani wata wontjamai“!   
\p
\v 8 Nakaldra kutjieli nina mardawonpa miri pirnaia taralkana wonti ja nunkangu wondrana wonti mitaia kaparaia warupotuja milila ja pirnala tanani,   
\p
\v 9 Ja nunkangu jatana wonti: „Tananapini warupoto ngato jinkangu jinkila nganai, jidni ngakangu pantjaterkana ngarinani ngatjila.“   
\p
\v 10 Ngadani Jesus nunkangu jatana wonti: „Kutingau Satanajai! ngangau dakanala parai: Jidni Godani Kaparani jinkanani ngatjiamai ja windri nunkangu wodatarana ngamamai.“   
\p
\v 11 Ngadani kutjieli nina worarana wonti, ja mai, angela wora nunkangu wokarana wonti ja nunkangu mili nganana wonti.  
\b  
\p
\v 12 Jesujeli matja ngarana, tanali Johannes kanjangari pungani widmana warai, Nau puntina wonti Galilaiaia;   
\p
\v 13 Ja Nulu Nazareth worarana wonti ja ngura manina wonti Kapernaum ngamala, nau panto dirkalani parai, Sebulon ja Naphthali wondirani;   
\p
\v 14 Ngangau morlalu pantjinanto, mina Jesaiasali Prophetali kaukanbana wonti, nau jatana wonti:   
\p
\v 15 „Sebulon mitali ja Naphthali mitali pantunkari, Jordan kaiarani jerankari, ja Galilaialali kojeli,   
\p
\v 16 Kana wolarali, tana ngalpurani ngamai, praitji pirna najina wonti, ja tanangu, tana naria pirini ja pungalani ngamai, tanangu praitji dunkana tarana wonti.“   
\p
\v 17 Jendranguta Jesujeli wonina wonti kaukaubala ja jatala: „Madlentjandru karitjianau, ngangau pariwilpaia milila karakara nganai.“   
\lit (Ngantjani‐jaura Andreas ditjini.)  
\p
\v 18 Jesus Galilaia pantuni dirkalani wirarina wonti, ja Nulu neji mara wulana najina wonti, Simon, nina talali dikai Petrus, ja Andreas ngatata nunkani; pudlali jama pantuni worana wonti, ngangau pudla paru maninietja nganana wonti.   
\p
\v 19 Ja Nau pudlangu jatana wonti: „Ngakangu karipaterialumai; ngato judlana kana maninietja ngankala nganai.“   
\p
\v 20 Pudlali nurujeli jama worarana wonti ja nunkangu karipaterina wonti.   
\p
\v 21 Ja Nau nakandru morla wapana wonti, ja Nulu neji mara mandru morla najina wonti, Jakobus, Zebedäuni ngatamura, ja Johannes, ngatata nunkani; pudlali botani Zebedäus, pudlani ngaperani jela, jama karpana wonti. Ja Nulu pudlana karkana wonti.   
\p
\v 22 Pudlali nurujeli bota ja ngaperi pudlani worarana wonti ja nunkangu karipaterina wonti.  
\b  
\p
\v 23 Ja Jesus Galilaiani paruparu wirarina wonti ja jaura pungani tananani ngujangujara jinkina wonti, ja ngantjani jaura mililandru kaukaubana wonti, ja muntja ja waltowalto pratjana Nulu tepi ngankana wonti kana wolarani.   
\p
\v 24 Ja pinti nunkangundru dunkana wonti Syria mitaia paruparu, ja tanali nunkangu muntja pratjana padakana wonti, tana muntja ja ketjaketjana pilki ja pilki nganana wonti, ja kana kutjinto ja pirala muntja ja tjunduru; ja Nulu tanana pratjana katitepi ngankana wonti.   
\p
\v 25 Ja kana wolara marapu nunkangu karipaterina wonti Galilaiandru ja Dekapolis mitandru ja Jerusalemingundru ja Judaiandru ja Jordan kaiari jerankarindru.   
\c 5  
\lit (Ngantjani — jaura kulikiri pratjanaia ditjini.)  
\p
\v 1 Matja Nulu kana wolara najina, Nau mardawonpaia tarana wonti; ja Nau matja ngamana ngarina, mili nunkani nunkangu wokarana wonti.   
\p
\v 2 Ja Nau mana wilparina wonti, ja Nulu tanangu ngujangujara jinkina wonti ja jatana wonti:   
\p
\v 3 Murlali pirna, tana mungarali wangiwangi, ngangau pariwilpaia milila tanangu nganai.   
\p
\v 4 Murlali pirna, tana ngaurongauro, ngangau tanali ngankalkani manila nganai.   
\p
\v 5 Murlali pirna, tana malti nganai, ngangau tanali mita maru ngamalkala nganai.   
\p
\v 6 Murlali pirna, tana mauali ja tertieli nganai talkulaia, ngangau tana bulurila nganai.   
\p
\v 7 Murlali pirna, tana kalumiltjamiltjariai, ngangau tanangu kalumiltjamiltjarina nganala nganai.   
\p
\v 8 Murlali pirna, tana ngara kulikiri nganai, ngangau tanali Goda najila nganai.   
\p
\v 9 Murlali pirna tana wadlietja, ngangau tanana tanali Godaia kupa dikala nganai.   
\p
\v 10 Murlali pirna tana, tanangu kana talkulandru tirikaripateriai, ngangau tanangu pariwilpaia milila nganala nganai.   
\p
\v 11 Murlali pirna jura nganai, tanali jurana ngirkibanani ja tirikaripaterinani ja madlentji marapu jurangu jatanani jedinali ngakangundru.   
\p
\v 12 Mankianimai ja murlali ngananau, ngangau kalala jurani pirna nganai pariwilpani; ngangau jeruja tana bakana Propheta worangu, jurangu ngopera ngananala, tirikaripaterina wonti.   
\p
\v 13 Jura mitaia kaldri nganai. Kaldri dunkarinani, minali tanali kaldri ngankala nganai? Nau baku nganai, ja kanali nina teribala nganai ja tidnali nankanankala nganai.   
\p
\v 14 Jura mitaia praitji nganai. Ngura kulno, mardawanpani miri paranani, wata kurukuru nganai.   
\p
\v 15 Tanali wata praitji miribai ja kokuni ngarinalu widmai, a‐ai, praitjaia potuni, ja nau pratjanani mintjiai, tana pungani ngamanani.   
\p
\v 16 Jeruja praitji jurani mintjiatimai kanani, ngangau tanali ngankani ngumu jurani najinanto ja Ngapari jurani pariwilpani jurakokananto.   
\p
\v 17 Wata ngundranau, ngani wokarana warai jirijiribani‐jaura kara, Prophetaia jaura kara dukarala, a‐ai, ngani wata wokarana warai, ninaia dukarala, windri morlalu kurala.   
\p
\v 18 Ngangau morlalu ngani jurangu jatai: „Pariwilpa ja mita maru mudanantulu, wata tiwi kulno kara, malka wakawaka kulno kara jirijiribani jaurandru mudala nganai, jenia pratjana morlalu pantjinantulu.“   
\p
\v 19 Warlenulu nunkangupini jirijiribani jaurandru kulno wakawaka dukaranani ja jeruja kanani ngujangujara jinkinani, nau wakawaka nganala nganai pariwilpaia mililani; warlenulu tanana ngankanani ja ngujangujara jinkinani, nau pirna nganala nganai pariwilpaia mililani.   
\lit (Ngantjani‐jaura G. D. VI. Trinitatis.)  
\p
\v 20 Ngangau ngani jurangu jatai: „Talkula jurani wata morla ngumu ngananani jaura jinkinietjaia ja Pharisaiaia, jura morlalu wata pariwilpaia mililani wirila nganai.“   
\p
\v 21 Jura matja ngarana, worderu Nauja pinaru worangu jatana wonti: „Wata narielu nandramai“! warlenulu narielu nandrai, nunkangu kalala parai.   
\p
\v 22 Ja ngani jurangu jatai: „Worananau ngatatani nunkanani baku tiririnani, nunkangu kalala parai; ja worananau ngatatani nunkanani jatai: «Raka», nunkangu kalala parai kaparani; ja worananau nunkangu jatai: «Jidni jirijiri», nunkangu kalala parai turu ngurali.“   
\p
\v 23 Ngangau jundru poto jinkani Altaraia padakanani, ja naka mangatandra wilparinani, ngatata jinkani jinkangu kuteriai,   
\p
\v 24 Jeruja poto jinkani naka Altara bankini woraramai, ja ngopera wapau, ja ngatatani jinkanani kulnukulnuni ngankateriamai, ja ngadani wokarau ja poto jinkani jinkiamai.   
\p
\v 25 Nurujeli murlali nganamai talpalani jinkanani, Jeruntjaia ditji jidni nunkangunto paltuni nganai; talpalali jidna kalala kuranietjani jinkiati, ja kalala kuranietjali jidna jinkiati milini, ja jidna kanjangari pungani widmaiati.   
\p
\v 26 Morlalu ngani jinkangu jatai: „Jidni wata morla nakandru dunkala nganai, jundru ngopera mudani marda jinkinantulu.“  
\b  
\p
\v 27 Jura matja ngarana, worderu Nauja pinaru worangu jatana wonti: „Wata pinta wokaribamai“!   
\p
\v 28 Ja ngani jurangu jatai: „Warlenulu widla najinani, nankangu milkirina, nulu matja ngarali nankangunto pinta wokaribana warai.“   
\p
\v 29 Milki ngunarali jidna karkarkanani, ninaia dukarau ja worau jinkangundru; ngangau jinkangu ngumu nganai jinkani palku buru kulno tintananto, Nulia palku buru pratjana turuni woraiati.   
\p
\v 30 Ja mara ngunarali jidna karkarkanani, ninaia wokaribau, ja jinkangundru worau; ngangau jinkangu ngumu nganai, jinkani palku buru kulno tintananto, palku buru pratjana turuni wiriati.   
\p
\v 31 Nauja jatana wonti: „Warlenulu noa nunkani woraranani, nulu nankangu narrani dakani jaura jinkinanto.“   
\p
\v 32 Ja ngani jurangu jatai: „Warlenulu noa nunkani woraranani, nani wata kantji palakantji ngananani, nulu nana pinta wokaribanietja ngankai; ja warlenulu narrani widla patanani, nulu pinta wokaribai.“   
\p
\v 33 Nakaldra jura matja ngarana, worderu Nauja pinaru worangu jatana wonti: „Wata jedinali jaura morlalu jatamai, ja Kaparani jaura morlalu jinkani kuramai.“   
\p
\v 34 Ja ngani jurangu jatai: „Wata jaura morlalu jatamai, wata pariwilpani kara, ngangau nauja Godaia ngamani piri nganai.   
\p
\v 35 Wata mitani kara, ngangau nauja nunkani tidnaia piri nganai, wata Jerusalemingu kara, ngangau nauja kapara pirnaia ngura nganai.   
\p
\v 36 Bakana wata jinkani mangatandrani jaura morlalu jatamai, ngangau jidni ngandandariai, para kulno maru kara, waru kara ngankala.“   
\p
\v 37 Jaura jurani nganaiatimai: „Kau, kau; pani, pani;“ mina pudlangu pinpi tarai, jenia madlentjandru dunkai.   
\p
\v 38 Jura matja ngarana, worderu Nauja jatana wonti: „Milki milkini, manatandra manatandrani.“   
\p
\v 39 Ja ngani jurangu jatai: „Madlentjani wata ngandrawalkaterianau, a‐ai, warlenulu jidna ngadla ngunari nandrai, nunkangu bakana nguru jinkiteriau.   
\p
\v 40 Ja warlenulu ngundrai jinkangu tjakakijiribamalila kati waka jinkani manila, nunkangu bakana kati pirna worarau.   
\p
\v 41 Ja warlenulu jidna winpai nunkangu jela karakara wirarila, nunkangu jela worita wirariau.   
\p
\v 42 Worananau jinkangu ngatjiai, nunkangu jinkiau; ja warlenulu ngantjai jinkangundru woljaia manila, wata nunkangundru kulkateriau.“   
\p
\v 43 Jura matja ngarana, worderu Nauja jatana wonti: „Kamaneli jinkani ngantjamai, ja talpalani jinkanani kalakalariamai.“   
\p
\v 44 Ja ngani jurangu jatai: „Talpala jurani ngantjanimai; tanali jurangu kalala madlentji kuranani, tanangu kalala ngumu kuranau; tana jurangu kalakalarinani, tanangu ngumu ngankanimai; tanali jurana ngirkibanani ja jurangu tirikaripaterinani, tanangundru ngatjianimai.   
\p
\v 45 Ngangau jura kupa nganananto Ngaperaia juranaia, Nauja pariwilpani; Nulia ditji pirna nunkani dunkalkai kanani madlentjani ja kanani ngumuni, ja talara jinkiai kana talkuni ja tjikatjikani.“   
\p
\v 46 Ngangau jura tanana ngantjanani, tanali jurana ngantjai, mina kalala jura ngamalkai? Wata mardatandrakampanietja jenildramata?   
\p
\v 47 Ja jura jaura murlali jinkinani windri ngatatani juranani, mina pilkildra jura ngankai? Wata mardatandrakampanietja jeruldramata?   
\p
\v 48 Talku ngananau worderu Ngaperi jurani pariwilpani talku nganai.   
\c 6  
\p
\v 1 Ngamalkaterianau, talkula jurani wata kana mudlani ngankala, tanali jurana najinanto; jura kalala pani Ngaperani juranani pariwilpani ngamalkaiati.   
\p
\v 2 Jundru kalumiltjamiltjarinali jinkinani, wata wima‐kokujeli ngaiala ngankamai, kana jeljujeljujeli jeribaka, tanali jaura pungani ja paltuni jeruja ngankai, jendrania kanali tanana jurakokananto. Morlalu ngani jurangu jatai: „Tanali kalala tanani matja ngamalkai.“   
\p
\v 3 Jundru kalumiltjamiltjarinali jinkinani, mara worangantju wata milkila nganananto, mina ngunarali ngankai.   
\p
\v 4 Kalumiltjamiltjarina jinkani kurukuru nganananto, ja Npaperali jinkanali kurukuruni najiai, ja Nulia jinkangu kalala jinkila nganai tinkari.   
\p
\v 5 Ja jidni ngatjinani, wata kana jeljujelju jeribaka nganamai, ngangau tanali ngantjai jaura pungani ja palto buruni terkana ngatjila, jendrania kanali tanana najinanto. Morlalu ngani jurangu jatai: „Tanali kalala tanani matja ngamalkai.“   
\p
\v 6 Jidni ngatjinani, punga wapuni wiriau, ja mana ngandrawalkateriau, ja ngatjiau Ngaperani jinkanani, Nauja kurukuruni nganai, ja Ngaperali jinkanali kurukuruni najiai, ja Nulia jinkangu kalala jinkila nganai tinkari.   
\p
\v 7 Jura ngatjinani, wata manabaka ngarranau kana ko jeribaka; ngangau tanali ngundrai, jaura marapundru Godali tanana ngarala nganai.   
\p
\v 8 Wata tanali jeribaka ngundranau; ngangau Ngaperi jurani milkila, mina jura ngamalkananto, windrila jura nunkangu ngatjinani.   
\p
\v 9 Jeruja ngatjianau: „Ngaperi ngaianini, jidni pariwilpani ngamala wapaia; Tala jinkani kulikiri pantjiatimai;   
\p
\v 10 Milila jinkani wokaraiatimai; Jertapaterina jinkani pantjiatimai, worderu pariwilpani jeruja bakana mitani;   
\p
\v 11 Buka ngaianini ngaianingu karari jinkiamai;   
\p
\v 12 Madlentji ngaianini woramai, worderu bakana ngaiani kana nguruja madlentji worala wapaia;   
\p
\v 13 Ja wata ngaianina wontjanilani wirilkamai, a‐ai, ngaianina madlentjani kulkamai; Ngangau jinkangu milila nganai ja ngurula ja pirnala ngurali. Amen.“   
\p
\v 14 Ngangau jura kanaia madlentji woranani, Ngaperali juranali pariwilpani madlentji jurani bakana woranani.   
\p
\v 15 Jura kanaia madlentji wata woranani, Ngaperali juranali pariwilpani madlentji jurani bakana wata woranani.   
\p
\v 16 Jura milja ngamanani, jura wata kana jeljujelju jeribaka mujarinanto; ngangau tana mudla marki ngankateriai kanani, tana miljangamanietja wondraterinanto. Morlalu ngani jurangu jatai: „Tanali kalala tanani matja ngamalkai.“   
\p
\v 17 Jidni milja ngamanani, jidni mangatandra gildieli wiribateriau, ja jidni mudla ngapali kulirkateriau,   
\p
\v 18 Ngangau jidni kanani wata miljangamanietja wondraterinanto, a‐ai, windri Ngaperani jinkanani, Nauja kurukuruni nganai; ja Ngaperali jinkanali kurukuruni najiai, ja Nulia jinkangu kalala jinkila nganai tinkari.   
\p
\v 19 Wata poto kampanimai mitani, tanana kakatjieli ja karumurujeli tidatida ngankai, ja kurikantjieli bakujai wontiterina, ja kurieli maniai.   
\p
\v 20 Poto kampanimai pariwilpani, tanana kakatjieli ja karumurujeli wata tidatida ngankai, ja kurikantjieli bulu bakujai ja wata kurieli maniai.   
\p
\v 21 Ngangau woderi ngantjani poto jurani parai, naka bakana jura ngara nganai.   
\p
\v 22 Palkuja praitji milki nganai. Jidni milki manju ngananani, jidni palku buru pratjana praitji ngananani.   
\p
\v 23 Jidni milki madlentji ngananani, jidni palku buru pratjana ngalpuru ngananani. Praitji jinkangu ngalpuru ngananani, worderu pirna ngalpuru munta?   
\lit (Ngantjani‐jaura G. D. XV. Trinitatis.)  
\p
\v 24 Kana kulno ngandandariai kapara mandruni mili ngamala, nau kulnuni kalakalarila nganai, ja kulno nulu ngantjala nganai kara; kulnuni nau wodatarana ngamala nganai, ja kulnuni gilbarila nganai kara. Jura ngandandariai Godani ja Mammonani mili ngamala.   
\p
\v 25 Ngangau ngani jurangu jatai: „Wata manujeli ngundranau tepini juranani, mina jura tajila ja tapala nganai; bakana wata palkuni juranani, mina jura widmaterila nganai. Wata tepi morla pirna nganai bukani ja palku katini?“   
\p
\v 26 Paia najianau ngaranani, tanalia wata jaupai ja kampai ja wata mapai kampani pungani, ja Ngaperali juranali pariwilpani tanangu buka jinkiai. Wata jura morla pirna nganai tanangu?   
\p
\v 27 Worana jurangundru ngurunguru nganai, tepini nunkanani tintipidi kulno juri ngankala manujeli ngundraterinali?   
\p
\v 28 Ja minandru jura manujeli ngundrai katini? Ngunandula najianau maruni, worderu tanaia punkai; tanalia wata ngankai ja wata turpai.   
\p
\v 29 Ngani jurangu jatai: „Bakana Salomo pirnalani nunkanani pratjanani wata widmaterina wonti tanangundru kulnuni jeribaka.“   
\p
\v 30 Godali kanta maruni jeruja widmanani, nauja karari nganai, ja tankubana tanali ninaia turupirini worai; Nulia jenia jurangu wata ngankananto, jura wuldrungundranietja worajai?   
\p
\v 31 Ngangau wata manujeli ngundraterianau ja jatanau: „Mina ngaiani tajila nganai kara? Mina ngaiani tapala nganai kara? Mina ngaiani widmaterila nganai kara?“   
\p
\v 32 Jenia pratjana kana kojeli wontiai; ngangau Ngaperali juranali pariwilpani ngujamai, jura jenia pratjana ngamalkananto.   
\p
\v 33 Ngopera wontianau Godaia milila ja talkula nunkani, ja jenia pratjana Nulia jurangu ngokala nganai.   
\p
\v 34 Ngangau wata manujeli ngundranau tankubanaia; ngangau tankubana ditji munta manujeli ngundraterila nganai. Matja nganai, ditji pilki nauja pilkildra nunkani manujeli ngundraterinanto.  
\b  
\c 7  
\p
\v 1 „Wata kalala kuranau, jeruja jura wata kalala manila nganai.   
\p
\v 2 Ngangau mina kalala jura kurai, jenipara kalala jura manila nganai; ja mina kokujeli jura nguja jinkiai, jenia koko jura nakaldra manina tikala nganai.   
\p
\v 3 Minandru jundru pita tiwitiwi ngatatani jinkanani milkini najiai, ja pita wondra milkini jinkanani jundru wata ngujamai?   
\p
\v 4 Worderu jidni ngatatani jinkanani jatananto kara: «Dabiau, ngato pita tiwitiwi milkindru jinkanani giltarananto;» ja mai, pita wondra milkini jinkanani parai?   
\p
\v 5 Jidni kana jeljujelju, ngopera pita wondra jinkani milkindru giltaramai, ja ngadani jundru ngumu najinanto, pita tiwitiwi ngatatani jinkanani milkindru giltarala.   
\p
\v 6 Kulikiri wata kintalani jinkianau ja marda ngumu wata pikini worana pararanau, tanali tanana tidnali nankaiati ja jurana purana karitjiati.   
\p
\v 7 Ngatjianimai, ja Nulia jurangu jinkila nganai; wontianimai, ja jura mankamankala nganai; nandranandranimai, ja mana jurangu wilpa pantjila nganai.   
\p
\v 8 Ngangau worana ngatjiai, nulu manila nganai; ja warle wontiai, nulu mankamankala nganai; ja warle nandranandrai, nunkangu mana wilpa pantjila nganai.   
\p
\v 9 Worana kana jurangundru nganai, nunkangu ngatamura nunkani ngatjiai bukaia, nulu nunkangu marda jinkila nganai?   
\p
\v 10 Ja nau nunkangu ngatjiai paruja, nulu nunkangu tjutju jinkila nganai?   
\p
\v 11 Ja jura, madlentji ngananani, ngujamai kupani juranani poto ngumu jinkila; worderu morla Ngaperali juranali pariwilpani poto ngumu jinkila nganai tanangu, tana nunkangu ngatjinani?   
\p
\v 12 Pratjana, mina jura ngantjai, kanali jurangu ngankananto, jenia bakana tanangu ngankanau; naupini jirijiribani jaura ja Prophetaia nganai.   
\p
\v 13 Manani wuldruni wirianau; ngangau mana maru nganai ja palto maru, nauja turuja wapai, ja marapu nunkangupini palkai.   
\p
\v 14 Ngangau mana wuldru nganai ja palto wuldru, nauja tepini wiriai, ja ngalje nganai, tanali ninapini mankamankai.   
\lit (Ngantjani‐jaura G. D. VIII. Trinitatis.)  
\p
\v 15 Jedikantji Prophetandru ngamalkaterianau; tjipi katieli tana jurangu wokarai, ja mandrani tana pandipandi puranietja nganai.   
\p
\v 16 Tanani tandrani jura tanana ngujamananto. Kanali bakana waina tandra kampala nganai dilkandru ja manawara dieltjirundru?   
\p
\v 17 A‐ai, pita nindri ngumu pratjanali tandra ngumu punkibai, ja pita nindri madlentjali tandra madlentji punkibai.   
\p
\v 18 Pita nindri ngumu ngandandariai tandra madlentji punkibala, ja pita nindri madlentji ngandandariai tandra ngumu punkibala.   
\p
\v 19 Pita nindri pratjanali wata tandra ngumu punkibanani, tanali wokaribala nganai ja turuni worala nganai.   
\p
\v 20 Ngangau tanani tandrani jura tanana ngujamananto.   
\p
\v 21 Wata tana pratjana, tana ngakangu jatai: «Kaparajai! Kaparajai!» pariwilpaia mililani wirila nganai, a‐ai, windri naupini, nulu Ngaperaia ngakanaia pariwilpalaia jertapaterina ngankai.   
\p
\v 22 Marapu ngakangu jatala nganai nunkanguka ditjini: «Kaparajai! Kaparajai! wata ngaiani talani jinkanani talpadakana wonti? Wata ngaiani talani jinkanani kutji dunkalkana wonti? Wata ngaiani talani jinkanani pirnala marapu ngankana wonti?»   
\p
\v 23 Jendranguta ngato tanangu kalabala nganai: «Wata ngato jurana ngujamana wonti; ngakangundru wapanimai; jura tjikatjika ngankanietja.»   
\b  
\p
\v 24 Warle tananapini jaura ngakani ngarai ja ngankai, nina ngato kana kiri jeribaka kurala nganai, nulu punga nunkani marda tulurani wotinala.   
\p
\v 25 Ja talara kunditji godana wonti, ja ngapa kumari wokarana wonti, ja watara ngakana wonti ja ninapini punga tertapana wonti, ja bulu tampuribana wonti; ngangau nina marda tulurana wotinala.   
\p
\v 26 Ja warle tananapini jaura ngakani ngarai ja wata ngankai, nau kana patipati jeribaka nganai, nulu punga nunkani mita ngalarani wotinala;   
\p
\v 27 Ja talara kunditji godana wonti, ja ngapa kumari wokarana wonti, ja watara ngakana wonti, ja ninapini punga tertapana wonti, ja nau tampurina wonti, ja tampurini nunkani pirna nganana wonti.“   
\p
\v 28 Jendranguta Jesujeli tananapini jaura matja mudana, kana wolara ngujangujarani nunkanani pirna ngaruparana wonti.   
\p
\v 29 Ngangau Nulu ngurungurujeli ngujangujara jinkina wonti, ja wata jaura jinkinietjali jeribaka.   
\c 8  
\lit (Ngantjani‐jaura G. D. III. Epiphanias.)  
\p
\v 1 Nau mardawonpandru ngarina tikanani, jendranguta kana wolara marapu nunkangu karipaterina wonti.   
\p
\v 2 Ja mai, kana kulno gambanto wokarana wonti ja nunkangu pantjaterkana ngarina wonti ja jatana wonti: „Kaparajai, jidni jertapaterinani, jidni ngurunguru nganai ngana kulikiri ngankala.“   
\p
\v 3 Ja Jesus mara warpina wonti, ja Nulu nina karakarana wonti ja jatana wonti: „Ngani jertapateriai, kulikiri nganamai.“ Ja nurujeli nau kulikiri pantjina wonti nunkani gambandru.   
\p
\v 4 Ja Jesus jatana wonti nunkangu: „Mai, wata jundru jenia kanani kaukaubamai, a‐ai, wapau, Priestani wondrateriamai, ja nina poto jinkiau, nina Mosili jirijiribana wonti, tanangu malka nganananto.“   
\p
\v 5 Ja Jesus Kapernaum ngurani matja wirina, juljaia kapara kulno nunkangu wokarana wonti ja nunkangu ngatjina wonti,   
\p
\v 6 Ja jatana wonti: „Kaparajai, mili ngakani pungani parai tjunduru, ja pirna ketjaketjai.“   
\p
\v 7 Ja Jesus nunkangu jatana wonti: „Ngani wokarala nganai, nina tepi ngankala.“   
\p
\v 8 Ja juljaia kaparali kalabana wonti ja jatana wonti: „Kaparajai, ngani wata talku nganai, jidni punga ngalpani ngakanani wirinanto; windri jaura kulno jatamai, ja mili ngakani tepirila nganai.   
\p
\v 9 Ngangau ngani kana nganai ja kaparani wodatarana ngamai; ja ngato mili wolara ngamalkai; ja ngani nunkangupini jatanani: «Jerra wapau!» ja nau wapai; ja kulnuni: «Kaparau!» ja nau wokarai; ja milini ngakanani: «Ninapini ngankau!» ja nulu jenia ngankai.“   
\p
\v 10 Jesujeli jenia matja ngarana, Nau ngaruparana wonti ja jatana wonti tanangu nunkangu karipaterinani: „Morlalu ngani jurangu jatai: Jenipara morlalu ngundrana ngato Israelani wata mankamankana warai.“   
\p
\v 11 Ja ngani jurangu jatai: „Marapu wokarala nganai tiriwandru ja jendakarandru ja Abrahamangu ja Isaakangu ja Jakobangu jela pariwipaia mililani ngamala nganai.   
\p
\v 12 Ja Nulu mililaia kupa teribala nganai ngalpuru pirnaia, naka tana pirna ngirikidala nganai ja mana katakatangala nganai.“   
\p
\v 13 Ja Jesus jatana wonti juljaia kaparani: „Tikamai; worderu jundru morlalu ngundrana warai, jeruja jinkangu nganaiatimai.“ Ja mili nunkani tepirina wonti nunkangupini ditjini.   
\b  
\p
\v 14 Ja Jesus Petruni pungani wirina wonti, ja Nulu paiara nunkani najina wonti, nani paranani muntja turuturu.   
\p
\v 15 Ja Nulu nana mara patana wonti, ja muntja turuturujeli nana worarana wonti; ja nani jiritjina wonti ja tanangu mili nganana wonti.   
\p
\v 16 Matja kalkaurarina, tanali nunkangu kana kutjinto marapu wokaralkana wonti, ja Nulu jaurali kutji worana dunkalkana wonti, ja Nulu muntja pratjana tepi ngankana wonti.   
\p
\v 17 Ngangau morlalu pantjinanto, mina Jesaiasali Prophetali kaukaubana wonti, nau jatana wonti: „Muntali Nulu waltowalto ngaianani manina wonti, ja muntja ngaianani waltana wonti.“   
\p
\v 18 Ja Jesujeli matja najina, kana wolarali nina kapikapinani, Nulu jirijiribana wonti jerankaria pararala.   
\p
\v 19 Ja jaura jinkinietja kulno nunkangu wokarana wonti ja jatana wonti: „Ngujangujara jinkinietjajai, ngani jinkangu karipaterila nganai, wodajeri jidni wapanani.“   
\p
\v 20 Ja Jesus nunkangu jatana wonti: „Kintala jampali minka ngamalkai, ja paiali ngaranani kunjila ngamalkai, ja Kanaia Ngatamurajeli piri pani ngamalkai, wodajeri kukadi terkala.“   
\p
\v 21 Nunkani milindru kulno nunkangu jatana wonti: „Kaparajai, ngakangu manuni kurau, ngani ngopera wapananto, ngaperi ngakani todila.“   
\p
\v 22 Jesus nunkangu jatana wonti: „Ngakangu karipateriau, ja narieli muntali nari tanani todinanto.“   
\lit (Ngantjani‐jaura G. D. IV. Epiphanias.)  
\p
\v 23 Ja Nau botani wirina wonti, ja mili nunkani nunkangu karipaterina wonti.   
\p
\v 24 Ja mai, watara pirna wilparina wonti pantuni, jeruja mandikilali bota walpana wonti; ja Nau mukaturarana wonti.   
\p
\v 25 Ja mili nunkangu wokarana wonti, ja tanali nina jiritjibana wonti ja jatana wonti: „Kaparajai, ngaianina kul‐kau, ngaiani palipaliati!“   
\p
\v 26 Ja Nau tanangu jatana wonti: „Minandru jura japali nganai, juru wuldrungundranietja?“ Ngadani Nau terkakana wonti ja watarani ja pantuni dikidikibana wonti, ja dalpura pirna pantjina wonti.   
\p
\v 27 Ja kana ngaruparana wonti ja jatana wonti: „Mina kana Nauja nganai; ngangau watara ja panto nunkangu pankiji?“   
\b  
\p
\v 28 Ja Nau jerankari matja pararana Gergesena mitani, nunkangu kana mandru kutjinto dankamalina wonti; pudla narikutundru matja dunkana, tiri pirna, jeruja kana ngandandarina wonti nunkangupini paltuni palkingala.   
\p
\v 29 Ja mai, pudla maritjina wonti ja jatana wonti: „Mina ngaianingu ja jinkangu, Jesujai, Godaia Ngatamurajai? Jidni ninkida wokarana warai, ngaianingu jupala ditji talkuja woljaia?“   
\p
\v 30 Tanangu worita piki ngami pirna marakana wonti.   
\p
\v 31 Kutji wora nunkangu ngatjina wonti ja jatana wonti: „Jundru ngaianina dunkalkanani, ngaianingu manuni kurau piki ngamini wirinanto.“   
\p
\v 32 Ja Nau tanangu jatana wonti: „Wapanau!“ tana matja dunkana, tana pikini wirina wonti; ja mai, piki ngami mardawonpa kalikalini kalikalibakana wonti pantuni, ja ngapani palipalina wonti.   
\p
\v 33 Ja ngamalkanietja japa mindrina wonti ja wapana wonti nguraia, ja pratjana kaukaubana wonti, bakana jenia kutjilandru.   
\p
\v 34 Ja mai, ngura warupotula dunkana wonti Jesungu mandurila; ja tanali nina matja najina, tana nunkangu ngatjina wonti, Nau tanani wondirandru puntinanto.   
\c 9  
\lit (Ngantjani‐jaura G. D. XVIV. Trinitatis.)  
\p
\v 1 Ja Nau botani wirina wonti ja pararana wonti, ja ngurani nunkanani wokarana wonti.   
\p
\v 2 Ja mai, tanali tjunduru kulno nunkangu wokaralkana wonti, nau turarani pirini paranani. Ja Jesujeli morlalu ngun‐drana tanani matja najina, Nulu tjundurani jatana wonti: „Murlali nganamai, ngatamurajai, madlentji jinkani matja worana warai!“   
\p
\v 3 Ja mai, jaura jinkinietja palpali warawarapana wonti: „Nulupini Goda ngirkibai.“   
\p
\v 4 Jesujeli ngundrana tanani matja ngujamana, Nau jatana wonti: „Minandru jura jenia madlentji ngundrai ngarali juranali?   
\p
\v 5 Mina morla ngaua nganai jatala kara: «Madlentji jinkani matja worana;» jatala kara: «Terkakamai ja wirariau?»   
\p
\v 6 Ja jura ngujamananto, Kanaia Ngatamurajeli ngurula ngamalkai, mitani madlentji worala,“ — Nau tjundurani jatana wonti: „Terkakamai, turarani piri jinkani patau, ja pungaia jinkanaia tikamai.“   
\p
\v 7 Ja nau terkakana wonti ja pungaia nunkanaia tikana wonti.   
\p
\v 8 Kana wolarali jenia matja najina, tana ngaruparana wonti ja Goda jurakokana wonti, ngangau Nulia jenia ngurula kanani jinkina warai.   
\b  
\lit (Ngantjani‐jaura Matthäus ditjini.)  
\p
\v 9 Ja Jesus nakandru wapana wonti, ja Nulu kana kulno najina wonti mardatandrakampanietjaia pungani ngamanani, tala nunkani Matthäus; ja Nau nunkangu jatana wonti: „Ngakangu karipateriau!“ Ja nau terkakana wonti ja nunkangu karipaterina wonti.   
\p
\v 10 Ja jendranguta Nau pungani bukani ngamana wonti; ja mai, mardatandrakampanietja ja madlentji ngankanietja marapu wokarana wonti ja Jesungu ja milini nunkanani jela bukaia ngamana ngarina wonti.   
\p
\v 11 Ja jenia Pharisaiali matja najina, tana milini nunkanani jatana wonti: „Minandru ngujangujara jinkinietjali juranali mardatandrakampanietjani ja madlentji ngankanietjani jelali tajiai?“   
\p
\v 12 Jesujeli jenia matja ngarana, Nau tanangu jatana wonti: „Ngurungurujeli wata kunki ngundrai, a‐ai, windri muntjali.   
\p
\v 13 Wapanau ja kiririanau, mina jenia wondrai: «Ngato kalumiltjamiltjarina ngantjai ja wata poto ngumu;» ngangau ngani wata wokarana warai kana talku karkala, a‐ai, windri kana madlentji.“   
\b  
\p
\v 14 Jendranguta Johannini mili nunkangu wokarana wonti ja jatana wonti: „Minandru ngaiani ja Pharisaia pota marapu milja ngamai, ja mili jinkani wata milja ngamai?“   
\p
\v 15 Ja Jesus tanangu jatana wonti: „Worderu noangantjanipirnaia kamaneli ngaurongauro ngamananto, noangantjanipirna tanangu jela ngananani? Ditji wokarala nganai, tanali noangantjanipirna tanangundru manila nganai; ngadani tanaia milja ngamala nganai.   
\p
\v 16 Wata kulnujeli katini womalani kati tjela ngumu karpai; ngangau kati tjela nakaldra katindru purateriai, ja wilpa morla pirna pantjiai.   
\p
\v 17 Ja tanali wata waina marra jungani womalani kurarai; junga purateriati, ja waina ngakaiati, ja junga tintateriati; a‐ai, tanali waina marra junga marrani kurarai ja pudlana jelalu kulkai.“   
\lit (Ngantjani‐jaura G. D. XXIV. Trinitatis.)  
\p
\v 18 Nulu jenia tanangu kaukaubanani, mai, kapara kulno wokarana wonti ja nunkangu pantjaterkana ngarina wonti ja jatana wonti: „Ngatamura mankara ngakani karari matja palina, kaparau, jidni mara nankangu kurateriamai, ja nani tepirila nganai.“   
\p
\v 19 Ja Jesus terkakana wonti ja nunkangu karipaterina wonti, ja mili nunkani bakana.   
\p
\v 20 Ja mai, widla kulno, nani kilpawoldra marapratjana ja mandru kumaranto nganana wonti, nunkangu tokuni wokarana wonti ja kati jelpi nunkani karana wonti.   
\p
\v 21 Ngangau nani jataterina wonti: „Ngato windri kati nunkani karanani, ngani tepirinani.“   
\p
\v 22 Jesujeli najina karitjina wonti ja nana najina wonti ja jatana wonti: „Murlali nganamai, ngatamurajai! morlalu ngundranali jinkanali jidna tepi ngankana warai.“ Ja widla tepirina wonti nunkangupini ditjini.   
\p
\v 23 Ja Jesus kaparaia pungani matja wokarana, Nulu wimakoko wilpinietja najina wonti, ja kanali miritja ngankanani, ja Nau tanangu jatana wonti:   
\p
\v 24 „Piri pinianimai; ngangau mankara wata nari, a‐ai, windri mukaturarai.“ Ja tana kinkana wonti nunkangu.   
\p
\v 25 Ja Nulu kana wolara matja narrana, Nau wirina wonti ja nana mankara mara patana wonti, ja mankara jiritjina wonti.   
\p
\v 26 Ja naupini pinti marurina wonti nunkangupini mitani paruparu.   
\b  
\p
\v 27 Ja Jesus nakandru morla palkana wonti, ja nunkangu butju mandru karipaterina wonti, pudla maritjina wonti, ja jatana wonti: „Davidani ngatamurajai, ngalingu kalumiltjamiltjariau!“   
\p
\v 28 Nau pungani wirinani, butju wulu nunkangu wokarana wonti, ja Jesus pudlangu jatana wonti: „Judla morlalu ngundrai, ngani ngurunguru nganai, jenia ngankala“? Pudla nunkangu jatana wonti: „Kau, Kaparajai!“   
\p
\v 29 Ngadani Nulu pudlana milki karakarana wonti ja jatana wonti: „Worderu judla morlalu ngundrana warai, jeruja jud‐langu pantjiatimai.“   
\p
\v 30 Ja pudla milki piririna wonti. Ja Jesujeli pudlana daudauana wonti ja jatana wonti: „Ngamalkaterialumai, wata kanali jenia ngujamananto.“   
\p
\v 31 Pudla dunkana wonti ja nunkangundru kaukaubana wonti nunkangupini mitani paruparu.   
\p
\v 32 Pudla puntinani, mai, tanali nunkangu kana ngapu kutjinto wokaralkana wonti.   
\p
\v 33 Ja Nulu kutji matja dunkalkana warai, kana ngapula jatana wonti. Ja kana wolara ngaruparana wonti ja jatana wonti: „Wata pota kulno jenia Israelani pantjinala.“   
\p
\v 34 Pharisaia jatana wonti: „Nulia kutji dunkalkai kutjia kaparali.“   
\p
\v 35 Ja Jesus wirarina wonti ngura pirnani ja wakani pratjanani, ja ngujangujara jinkina wonti jaura pungani tananani, ja ngantjani jaura mililandru kaukaubana wonti, ja tepi ngankana wonti muntja pratjana ja waltowalto pratjana kana wolarandru.   
\p
\v 36 Nulu kana wolara najina, Nau tanangu kalumiltjamiltjarina wonti, ngangau tana wilpawilpa ja piltjaru nganana wonti, tjipi jeribaka, tana ngamalkanietja pani.   
\p
\v 37 Jendranguta Nau milini nunkanani jatana wonti: „Kampananto marapu parai, ja ngankanietja windri ngalje.“   
\p
\v 38 Jendrania Kampania Kaparani ngatjianimai, Nulia ngankanietja jinpananto nunkani kampanaia.   
\c 10  
\p
\v 1 Ja Nulu mili nunkani marapratjana ja mandru matja karkana, Nulu tanangu ngurula jinkina wonti kutji murumuruja, tanana dunkalkananto ja tepi ngankananto muntja pratjana ja waltowalto pratjana.   
\p
\v 2 Mili marapratjana ja mandruja tala tanapini nganai: „Ngopera Simon, nina tanali dikai «Petrus» ja Andreas, ngatata nunkani; Jakobus, Zebedäuni ngatamura, ja Johannes, ngatata nunkani;   
\p
\v 3 Philippus ja Bartholomäus; Thomas ja Matthäus mardatandrakampanietja; Jakobus Alphäuni ngatamura, ja Leppäus, nina tanali dikai «Thaddäus»;   
\p
\v 4 Simon, Kana ngurandru ja Judas Iskarioth, nulu nina wondawondana wonti.“   
\p
\v 5 Tananapini marapratjana ja mandru Jesujeli jinpana wonti, ja Nulu tanangu jirijiribana wonti ja jatana wonti: „Kana koja paltuni jura wata wapananto, ja Samarita ngurani jura wata wirinanto;   
\p
\v 6 A‐ai, windri tjipia wapanau, tana Israel pungandru tintaterinala.   
\p
\v 7 Wapanau ja kaukaubanimai, ja jatanimai: «Pariwilpaia milila karakara nganai.»   
\p
\v 8 Muntja tepi ngankanimai, kana gambanto kulikiri ngankanimai, kana nari jiritjibanimai, kutji dunkalkanimai; bakujeli jura matja manina, bakujeli jinkianimai.   
\p
\v 9 Jura wata mardatandra maralje, bakana wata mardatandra bulu, bakana wata mardatandra nguja pilki pailtjini juranani ngamalkananto;   
\p
\v 10 Wata billi paltuja, bakana wata kati mandru, bakana wata tidnaputa, bakana wata wonapita; ngangau ngankanietjani talku nganai buka nunkani.   
\p
\v 11 Mina ngura pirnani kara, ngura wakani kara jura matja wirina, wolja jakalkanau, worana nunkangu talku nganai; naka ngamanimai, jura puntilalu.   
\p
\v 12 Jura pungani wirinani, nunkangu jaura murlali jinkianimai.   
\p
\v 13 Punga kara talku ngananani, murla jurani nunkangupini wokarananto, nau wata talku kara ngananani, murla jurani jurangu karitjina tikananto.   
\p
\v 14 Ja warle jurana wata patanani, bakana jaura jurani wata ngaranani, nunkangupini pungandru kara ngurandru kara puntianimai, ja puturu jurani tidnandru kantikantianimai.   
\p
\v 15 Morlalu ngani jurangu jatai: «Sodoma ja Gomorra mitalali kalala morla waka manila nganai kalala ditjini nunkangupini ngurani.»   
\p
\v 16 Mai, ngato jurana jinpai tjipi jeribaka pandipandi mandrani; kiri ngananau tjutju jeribaka ja jedini pani mulapara jeribaka.   
\p
\v 17 Ngamalkaterianau kanandru; ngangau tanali jurana kapara worangu ngulkujeli jinkila nganai ja jaura pungani tananani jurana wiriele nandrala nganai.   
\p
\v 18 Bakana najinajibanietjani ja mitaia kaparani tanali jurana wapalkala nganai ngakangundru, tanangu ja kana koni malka morlalu nganananto.   
\p
\v 19 Tanali jurana ngulkujeli jinkinani, wata manujeli ngundranau, worderu kara, mina kara jura jatananto; ngangau Nulia jurangu nunkangupini ditjini jinkila nganai, mina jura jatananto.   
\p
\v 20 Ngangau wata jura jatai, a‐ai, jurani Ngaperaia Jaola jatai jurangu.   
\p
\v 21 Nejieli ngatata nunkani naria ngulkujeli jinkila nganai, ja ngaperali kupa nunkani; ja kupa terkakala nganai ngaperani ja ngandrini ja pudlana naria jinkila nganai.   
\p
\v 22 Ja kana warupoto jurangu kalakalarila nganai ngakani talandru. Worana wonki nganai ngadajelu, nulu tepi ngurali manila nganai.   
\p
\v 23 Tana jurangu tirikaripaterinani ngura kulnuni ngura nguruja mindrianau. Ngangau morlalu ngani jurangu jatai: «Jura Israelaia ngura pratjana wata mudala nganai Kanaia Ngatamura wokaranantulu.»   
\p
\v 24 Mili wata morla pirna nganai ngujangujara jinkinietjani, bakana ngankanietja wata morla pirna kaparani nunkanani.   
\p
\v 25 Milini matja nganai, nau ngujangujara jinkinietjani nunkanani jeribaka pantjinani, ja ngankanietjani kaparani nunkanani jeribaka. Tanali punga ngamalkanietja Beelsebub matja dikana, worderu morla pungaia ngurula nunkani?   
\p
\v 26 Wata tanangundru japali ngananau! Ngangau panila kurirpi nganai, nau wata tinkari pantjila nganai; ja panila kurukuru nganai, nina tanali wata ngujamala nganai.   
\p
\v 27 Mina ngani jurangu jatai ngalpurani, jenia kaukaubanimai praitjani; ja mina jura kurukuru ngarai talpali, jenia kaukaubanimai punga mangatandrani.   
\p
\v 28 Wata japali ngananau tanangundru, tanali palku nari ngankai, ja ngandandariai mungara nari ngankala; morla japali ngananau nunkangundru, Nauja ngurunguru nganai, palku ja mungara turuja teribala.   
\p
\v 29 Tanali wata tiwilitja mandru mardatandra wakawaka kulnundru jinkimaliai? Ja wata kulno tanangundru mitani purila nganai jurani Ngaperani panini.   
\p
\v 30 Bakana para pratjana jurani mangatandrani matja windamana.   
\p
\v 31 Wata japali ngananau; jura morla pirna nganai tiwilitja marapuni.   
\p
\v 32 Warle ngana dikala nganai kanani, nina bakana ngato dikala nganai Ngaperani ngakanani pariwilpani.   
\p
\v 33 Warle ngana kutikutibala nganai kanani, nina bakana ngato kutikutibala nganai Ngaperani ngakanani pariwilpani.   
\p
\v 34 Wata ngundranau, ngani wokarana warai, murla kurala mitani; a‐ai, ngani wata wokarana warai murla kurala, windri kalti tiri.   
\p
\v 35 Ngangau ngani wokarana warai, puntibala materi ja ngaperi nunkani, mankara ja ngandri nankani, kalari ja paiara nankani;   
\p
\v 36 Ja pungaia ngurala kanaia talpala nganala nganai.   
\p
\v 37 Warle ngaperi kara, ngandri kara morla ngantjai ngakangu, nau ngakangu wata talku nganai; ja warle kaku kara, mankara kara morla ngantjai ngakangu, nau ngakangu wata talku nganai.   
\p
\v 38 Ja warle kunarku nunkani wata maniai ja ngakangu karipateriai, nau ngakangu wata talku nganai.   
\p
\v 39 Warle tepi nunkani mankamankana warai, nulu nina tintala nganai, ja warle tepi nunkani tintana warai ngakangundru, nulu nina mankamankala nganai.   
\p
\v 40 Warle jurana patai, nulu ngana patai; ja warle ngana patai, nulu ninaia patai, Nulia ngana jinpanala.   
\p
\v 41 Warle Propheta kulno patai Prophetaia talani, nulu Prophetaia kalala manila nganai; ja warle kana talku patai kana talkuja talani, nulu kana talkuja kalala manila nganai.   
\p
\v 42 Ja warle kulnuni tanangupini wakawakandru koko kulno ngapa malti jinkila nganai milia talani, morlalu ngani jurangu jatai: «Nulu kalala nunkani wata tintala nganai.»“   
\c 11  
\p
\v 1 Ja Jesujeli jendranguta matja mudana, milini nunkanani ngujangujara jinkila, Nau nakandru puntina wonti, ngujangujara jinkila ja jaura kaukaubala ngurani tananani.   
\lit (Ngantjani‐jaura G. D. III. Advent.)  
\p
\v 2 Johannili kanjangari pungani Christuni ngankana matja ngarana, nulu mili mandru nunkani jinpana wonti,   
\p
\v 3 Ja nunkangu jatana wonti: „Naumata jidni, Nau wokarananto kara, kulnuni ngaiani kalkananto kara?“   
\p
\v 4 Jesujeli kalabana wonti ja jatana wonti pudlangu: „Tikalumai, ja Johanningu kaukaubalumai, mina judla najila wapaia ja ngarala wapaia:   
\p
\v 5 Butjulali najiai, ja tjundurula wapai; gambala kulikiri pantjiai, ja talpakurulali ngarai; narila tepi terkakai, ja wangiwangieli ngantjani jaura ngarai;   
\p
\v 6 Ja murlali pirna naupini nganai, nau ngakangu wata buljubuljuriai.“   
\p
\v 7 Pudla tikanani, Jesujeli wonina wonti kana wolarani jatala Johanningundru: „Mina najila jura pitaraia palkana paraia? Kalanka kulno, watarali wijawijabanani?   
\p
\v 8 Mina najila jura palkana paraia? Kana kulno kati tjankanto? Mai, mitaia kaparaia pungani tanali ngamalkai kati tjanka.   
\p
\v 9 Mina najila jura palkana paraia? Propheta kulno? Morlalu ngani jurangu jatai: Nau morla pirna nganai Prophetani.   
\p
\v 10 Ngangau naupini nau nganai, nunkangundru dakanala parai: «Mai, ngato angela ngakani jinkangu mudlani ngopera jinpai, nulu palto jinkani jinkangu ngopera ngankingala nganai.»   
\b  
\p
\v 11 Morlalu ngani jurangu jatai: «Wata kulno tanangundru, widlandru dankanala, terkakana wonti morla pirna Johanningu multibanietjani. Worananau morla waka nganai pariwilpaia mililani, nau morla pirna nganai nunkangu.»   
\p
\v 12 Johannes multibanietjaia ditjindru kararielu pariwilpaia milila ngurulali wokarai, ja kana ngurungurujeli ninaia parumai.   
\p
\v 13 Ngangau Propheta worali ja jirijiribani jaurali Johanningulu talpadakana wonti;   
\p
\v 14 Ja jura ngantjanani jenia patala, naupini Elias nganai, nau wokarananto.   
\p
\v 15 Warle talpa ngamalkai ngarala, nulu ngaraiatimai!   
\p
\v 16 Worangu ngato ninapini nguja jeribaka kurananto? Tanaia kupa wakani jeribaka nganai, tana jinkimalini pirini ngamai ja kamaneli tanani karkai   
\p
\v 17 Ja jatai: «Ngaiani jurangu wilpina warai, ja jura wata kilina warai; ngaiani jindrana warai, ja jura wata ngaurongaurojeli nandraterina warai.»   
\p
\v 18 Ngangau Johannes wokarana warai wata tajina ja wata tapana, ja tanaia jatai: «Nulu kutji ngamalkai;»   
\p
\v 19 Ja Kanaia Ngatamura wokarana warai, Nulia tajiai ja tapai, ja tanaia jatai: «Najianau, Nauja kana mirantjatieli tajinietja ja tapanietja, mardatandrakampanietjaia ja madlentji ngankanietjaia kamaneli!» Ja Kirila kalala maniai nunkani kupandru.“   
\p
\v 20 Jendranguta Nulu wonina wonti, jaura kalkri jatala tanangupini ngurani, tanangu pirnala nunkani marapu pantjina wonti, ngangau tana wata madlentjandru karitjina wonti:   
\p
\v 21 „Jakajai jinkangu Choraziniai! jakajai jinkangu Bethsaidajai! ngangau Tyrus ja Sidon ngurani jenia pirnala pantjinani, judlangu pantjinala, pudla nurujeli kati murumurunto ja turuputani madlentjandru karitjinanto.   
\p
\v 22 Ja ngani judlangu jatai: «Tyrus ja Sidon ngurali kalala ditjini kalala morla waka manila nganai judlangu.»   
\p
\v 23 Ja jidni Kapernaum, jidni miririna pariwilpaia, turujelu jidni ngarila nganai; ngangau Sodom ngurani jenia pirnala pantjinani, jinkangu pantjinala, naupini nunkangupini ditjini kararielu terkananto.   
\p
\v 24 Ja ngani jurangu jatai: «Sodom mitalali kalala ditjini kalala morla waka manila nganai jinkangu.»“   
\lit (Ngantjani‐jaura Matthias ditjini.)  
\p
\v 25 Jendranguta Jesujeli kalabana wonti ja jatana wonti: „Ngato jidnana Ngaperiai, Kapara pariwilpaia ja mitaia, jurakokala wapaia; ngangau jundru jenia kana kirini ja ngujamanietjani kutibana warai ja kupani tinkari ngankana warai;   
\p
\v 26 Kau, Ngaperiai! jeruja jinkangu manju nganana wonti.   
\p
\v 27 Ngaperali ngakanali ngakangu warupoto jinkina wonti; ja wata kulnujeli Ngatamura ngujamai, windri Ngapili; ja bakana wata kulnujeli Ngapina ngujamai, windri Ngatamurajeli ja nulu, nunkangu Ngatamurajeli ngantjai jenia tinkari ngankala.   
\p
\v 28 Ngakangu kaparanau pratjana, jura wariwariai ja pariai, ngato jurana ngara waribala nganai.   
\p
\v 29 Pita wokara ngakani manianimai, ja ngakangundru kiririanau, ngangau ngani malti ja ngarali waka ngundrateriai, ja jura mankamankala nganai mungara ngara ngamala.   
\p
\v 30 Ngangau pita wokara ngakani manju, ja juditji ngakani ngaua nganai.“   
\b  
\c 12  
\p
\v 1 Jendranguta Jesus Sabbat ditjini buka maruni palkingana wonti, ja mili nunkani mauali nganana wonti ja wonina wonti, buka tandra wokaribala ja tajila.   
\p
\v 2 Pharisaiali jenia najina, tana nunkangu jatana wonti: „Mai, milieli jinkanali ngankai, jenia wata talku nganai Sabbat ditjini.“   
\p
\v 3 Nau tanangu jatana wonti; „Jura wata warapanala, mina Davidali ngankana wonti jendranguta, nau mauali nganana wonti ja tana nunkangunto?   
\p
\v 4 Worderu nau Godaia pungani wirina wonti ja wondrani buka tajina wonti, tanana tajila nunkangu ja tanangu nunkangunto wata manuni kuranala, a‐ai, windri Priestani?   
\p
\v 5 Jura wata warapanala jirijiribani jaurani, worderu Sabbat ditjini Priestali Godaia pungani Sabbat wokaribai, ja madlentji pani nganai?   
\p
\v 6 Ngani jurangu jatai: «Ninkida Kulno nganai, Nauja morla pirna nganai Godaia pungani.»   
\p
\v 7 Jura ngujamanani mina jenia wondrai: «Ngato ngantjai kalumiltjamiltjarina ja wata poto ngumu,» jura tanangu, madlentji panini, wata kalala dikanani.   
\p
\v 8 Ngangau Kanaia Ngatamura bakana Sabbat ditjia Kapara nganai.“   
\p
\v 9 Ja Nau nakandru wapana wonti ja jaura pungani tananani wokarana wirina wonti.   
\p
\v 10 Ja mai, naka kana kulno nganana wonti, nau mara muja nganana wonti. Ja tanali nina jakalkana wonti ja jatana wonti: „Jenia talku nganai, Sabbat ditjini tepi ngankala?“ Ngangau tana nunkangundru ngulkuterkananto.   
\p
\v 11 Nau tanangu jatana wonti: „Worana kana jurangundru nganai, nulia tjipi kulno ngamalkai, nau Sabbat ditjini kutuni purinani, nulia nina wata patala nganai ja dukarala nganai?   
\p
\v 12 Worderu morla pirna kana nganai tjipini? Jeruja bakana talku nganai Sabbat ditjini ngumu ngankala.“   
\p
\v 13 Ngadani Nau nunkangupini kanani jatana wonti: „Mara ngutateriau!“ ja nau ngutaterina wonti, ja mara tepi pantjina wonti nguruni jeribaka.   
\p
\v 14 Pharisaia dunkana wonti ja ngankamalina wonti, worderu nina nandrala.   
\p
\v 15 Ja Jesujeli jenia matja ngujamana, Nau nakandru puntina wonti, ja kana wolara marapu nunkangu karipaterina wonti, ja Nulu tanana pratjana tepi ngankana wonti.   
\p
\v 16 Ja Nulu tanana daudauana wonti, tanali nina wata tinkari ngankananto.   
\p
\v 17 Ngangau morlalu pantjinanto, mina Jesaiasali Prophetali kaukaubana wonti, nau jatana wonti:   
\p
\v 18 „Mai, Ngatamura ngakani, ninaia ngato kalkalkana wonti, ja Ngantjanipirna ngakani, worangu ngani mungara manju nganai; Ngato Jaola ngakani nunkangu kurala nganai, ja Nulia kana wolarani kalala kaukaubala nganai.   
\p
\v 19 Nulia wata jatamalila nganai ja maritjila nganai, ja tanali ngaiala nunkani wata paltuni ngarala nganai.   
\p
\v 20 Wokarini kalanka Nulia wata kantji wokaribala nganai, ja praitji, ngampu palina, Nulia wata kantji palimala nganai, Nulia kalala jinkinantulu kalalu ngankanaia.   
\p
\v 21 Ja kana wolarali talani nunkanani wolkareli kalkala nganai.“   
\p
\v 22 Jendranguta tanali nunkangu kana kulno kutjinto wapalkana wonti, nau butju ja ngapu nganana wonti; ja Nulu nina tepi ngankana wonti, jeruja ngapula ja butjula jatana wonti ja najina wonti.   
\p
\v 23 Ja kana wolara ngaruparana wonti ja jatana wonti: „Wata Naupini Davidani ngatamura nganai?“   
\p
\v 24 Pharisaiali jenia matja ngarana, tana jatana wonti: „Nulupini kutji windri Beelsebub, kutjia kaparali dunkalkai.“   
\p
\v 25 Jesujeli ngundrana tanani matja ngujamana, Nau tanangu jatana wonti: „Milila pratjana, munta piltjaru ngankaterinani, pitaru jeribaka pantjila nganai, ja ngura ja punga pratjana, munta piltjaru ngankaterinani, wata terkala nganai.   
\p
\v 26 Ja kutjieli kutji dunkalkanani, nau munta piltjaru ngankateriai; worderu milila nunkani terkananto?   
\p
\v 27 Ja ngato Beelsebubieli kutji dunkalkanani, waninali ngatamurajeli juranali tanana dunkalkai? Jendrania tana kalala kuranietja jurani nganala nganai.   
\p
\v 28 Ngato Godaia Jaolali kutji dunkalkanani, jeruja morlalu Godaia milila jurangu wokarana warai.   
\p
\v 29 Worderu kara kana kulno kana ngurunguruja pungani wirinanto poto nunkani watawatali manila, nulu wata ngopera kana ngurunguru dupudupu ngankanani? Ja ngadani nulu pungani pratjana watawatali manila nganai.   
\p
\v 30 Worana wata ngakangunto nganai, nau tula ngakani nganai; ja warle wata ngakangunto kampai, nulu piltjaru ngankai.“   
\p
\v 31 Jendrania ngani jurangu jatai: „Madlentji ja ngirkibani jaura pratjana Godali kanani kalingala nganai; windri Jaola ngirkibana Nulia wata kalingala nganai.   
\p
\v 32 Ja warle jaura madlentji jatanani Kanaia Ngatamurani, nunkangu Nulia kalingala nganai; warle jaura madlentji jatanani Jaola kulikirini, nunkangu Nulia wata kalingala nganai, wata nunkangupini mitani ja bakana wata ngadani.   
\p
\v 33 Pita nindri ngumu kuranau, ja tandra nunkani ngumu; pita nindri madlentji kuranau, ja tandra nunkani madlentji; ngangau tandrani jura pita nindri ngujamai.   
\p
\v 34 Wiparu kupa worajai! Worderu jura ngumu jatananto jura madlentji ngananani? Ngangau ngara manamirindru mana jatai.   
\p
\v 35 Kana ngumujeli ngara ngumundru ngumula dunkalkai; kana madlentjali ngara madlentjandru madlentji dunkalkai.   
\p
\v 36 Ngani jurangu jatai: «Jaura baku pratjanandru, tanana kana jatala nganai, tanali kalabananto kalala ditjini.   
\p
\v 37 Ngangau jinkani jaurandru Nulia jidna talku dikala nganai, ja jinkani jaurandru Nulia jinkangu kalala jinkila nganai.»“   
\p
\v 38 Jendranguta jaura jinkinietja ja Pharisaia palpali nunkangu kalabana wonti ja jatana wonti: „Ngujangujara jinkinietjajai, ngaiani ngantjai malka jinkangundru najila.“   
\p
\v 39 Nulu kalabana wonti ja tanangu jatana wonti: „Nguja madlentjali ja palakantjieli malka wontiai, ja tanali wata malka manila nganai, windri Prophetaia Jonani malka.   
\p
\v 40 Ngangau worderu Jonas paru pirna mandrani ditji parkulu ja tinka parkulu nganana wonti, jeruja bakana Kanaia Ngatamura mita mandrani ditji parkulu ja tinka parkulu nganala nganai.   
\p
\v 41 Ninive kana terkakala nganai kalala ditjini nunkangupini ngujani jela ja tanangu ngulkuterkala nganai, ngangau tana madlentjandru karitjina wonti Jonani ngujangujarandru; ja mai, ninkida morla pirna nganai Jonangu.   
\p
\v 42 Mitaia kapara widla kunankarindru terkakala nganai kalala ditjini nunkangupini ngujani jela ja tanangu ngulkuterkala nganai; ngangau nani mitaia wondirandru wokarana wonti, Salomoni kiri ngarala; ja mai, ninkida morla pirna nganai Salomongu.   
\p
\v 43 Kutji murumuru kanandru matja dunkana, nau pitarani palkingai, wontina ngara ngamala, ja wata mankamankai.   
\p
\v 44 Ngadani nau jatai: «Ngani tikala nganai pungaia ngakanaia, woderindru ngani matja dunkana.» Ja nau wokarana, nulu nina mankamankai kala, ja matja darpana, ja tjirkatjirkana.   
\p
\v 45 Ngadani nau palkai, ja nulu wapalkai kutji mara wora ja mandru, morla madlentji nunkangu, ja tana wiriai naka ngamala; ja ngadani naupini kana morla madlentji pantjila nganai ngoperalani. Jeruja bakana nunkangupini nguja madlentjani pantjila nganai.“   
\p
\v 46 Nulu kana wolarani kaukaubanani, mai, ngandri nunkani ja ngatata nunkani palarani terkana wonti ja jertapaterina wonti nunkangu ngankamalila.   
\p
\v 47 Kulno nunkangu jatana wonti: „Mai, ngandri jinkani ja ngatata jinkani palarani terkala wapaia ja jertapaterila wapaia jinkangu ngankamalila.“   
\p
\v 48 Nulu kalabana wonti ja jatana wonti nunkangu, nau jenia jatanani: „Worana ngandri ngakani ja warletana ngatata ngakani?“   
\p
\v 49 Ja Nulu nguna warpina wonti milini nunkanani ja jatana wonti: „Najianau, ngandri ngakani ja ngatata ngakani!“   
\p
\v 50 „Ngangau warle Ngaperaia ngakanaia pariwilpalaia jertapaterina ngankai, naupini ngatata ngakani ja kaku ngakani ja ngandri ngakani nganai.“   
\c 13  
\p
\v 1 Nunkangupini ditjini Jesus pungandru dunkana wonti, ja Nau panto dirkalani ngamana ngarina wonti.   
\p
\v 2 Ja kana wolara nunkangu jurborina wonti, ja Nau botani wirina wonti ja ngamana ngarina wonti, ja kana wolara dirkalani terkana wonti.   
\p
\v 3 Ja Nulu tanangu jaura marapu kaukaubana wonti jeribaka jaurali ja jatana wonti: „Mai, jaupanietja wapana wonti jaupala.   
\p
\v 4 Ja nulu jaupanani, palpa paltuni purina wonti, ja paia wokarana wonti ja nina tajina wonti.   
\p
\v 5 Ja palpa marda paltirani purina wonti ja wata mita tjanka marapu ngamalkana wonti ja nurujeli punkana wonti, ngangau mita puta nganana wonti.   
\p
\v 6 Ja ditji matja dunkana, nau winjarina wonti, ja ngangau kapara pani nganana wonti, nau mujarina wonti.   
\p
\v 7 Ja palpa dilkani purina wonti, ja dilka punkana wonti, ja nina palimana wonti.   
\p
\v 8 Ja palpa mita ngumuni purina wonti ja tandra punkibana wonti, kulnujeli tandra 100, kulnujeli tandra 60, kulnujeli tandra 30.   
\p
\v 9 Warle talpa ngamalkai ngarala, nulu ngaraiatimai!“   
\p
\v 10 Ja mili nunkani nunkangu wokarana wonti ja jatana wonti: „Minandru jidni tanangu jeribaka jaurali jatai?“   
\p
\v 11 Nulu kalabana wonti ja jatana wonti tanangu: „Jurangu matja jinkina warai, jaura kurukuru Godaia mililandru ngujamananto, ja tanangu jenia wata jinkina warai.   
\p
\v 12 Ngangau warle ngamalkai, nunkangu Nulia jinkila nganai, ja nulu morla marapu ngamalkala nganai; ja warle wata ngamalkai, nunkangundru Nulia bakana jenia manila nganai, mina nulu ngamalkai.   
\p
\v 13 Jendrangundruja ngani tanangu jeribaka jaurali jatai, ngangau tanali najina bulu najiai, ja ngarana bulu ngarai, ja wata ngujamai.   
\p
\v 14 Ja tanangu morlalu pantjiai Jesaiasani talpadakani jaura, nau jatana wonti: «Talpali jura ngarala nganai ja bulu ngundrala nganai, ja milkieli jura najila nganai ja bulu najila nganai.   
\p
\v 15 Ngangau tananipini kana wolaraia ngara pariai, ja tanaia talpa talpakuru, ja tanaia milki butju ngankateriai, ngangau tanalia milkieli bulu najinanto ja talpali bulu ngarananto ja ngarali bulu ngujamananto, ja wata madlentjandru karitjinanto, ngato tananaia tepi ngankananto.»   
\p
\v 16 Murlali pirna milki jurani nganai, ngangau tanalia najiai, ja talpa jurani, ngangau tanalia ngarai.   
\p
\v 17 Ngangau morlalu ngani jurangu jatai: «Propheta ja kana talku marapu wolkareli nganana wonti najila, mina jura najila wapaia, ja tanali jenia wata najina wonti, ja ngarala, mina jura ngarala wapaia, ja tanali jenia wata ngarana wonti.»“   
\p
\v 18 Jeribaka jaura jaupanietjandru ngaranau!   
\p
\v 19 „Warle jaura mililandru ngarai ja wata ngujamai, nunkangu kutji wokarai, ja nulu jenia dukarai, mina ngarani matja jaupana; naupini nau nganai, nina paltuni jaupana warai.   
\p
\v 20 Nina marda paltirani jaupana warai, nau nganai, nulu jaura ngarai ja nurujeli murlali nina patai;   
\p
\v 21 Nau kapara pani nganai, a‐ai, nau maraltja nganai. Ketjaketjana ja tirikaripaterina wokaranani jaurandru, nau wolja kalakalarila nganai.   
\p
\v 22 Nina dilkani jaupana warai, nau nganai, nulu jaura ngarai, ja nunkanipini mitaia manujeli ngundranali ja poto pirnaia jedibanali jaura palimai, ja nulu tandra pani punkibai.   
\p
\v 23 Nina mita ngumuni jaupana warai, nau nganai, nulu jaura ngarai ja ngujamai; nulupini tandra punkibai, kulnujeli tandra 100, kulnujeli tandra 60, kulnujeli tandra 30.“   
\lit (Ngantjani‐jaura G. D. V. Epiphanias.)  
\p
\v 24 Jeribaka jaura nguru Nulu tanangu kurana wonti ja jatana wonti: „Pariwilpaia milila kana kulno jeribaka nganai, nulu paua ngumu mitani nunkanani jaupana wonti.   
\p
\v 25 Matja kana muka turaranani, talpala nunkani wokarana wonti, ja nulu paua madlentji jaupana wonti ngumuni terti, ja kutingana wonti.   
\p
\v 26 Ja nindri punkanani ja tandrarinani, bakana nindri madlentji kantjirina wonti.   
\p
\v 27 Ja pungaia kaparaia mili wora wokarana wonti ja jatana wonti nunkangu: «Kaparajai! wata jundru paua ngumu mitani jinkanani jaupana paraia? Woderindru nindri madlentji?»   
\p
\v 28 Nau tanangu jatana wonti: «Talpalali jenia ngankana paraia.» Mili nunkangu jatana wonti: «Jundru ngantjai, ngaiani wapananto, nina mulkana dukarala?»   
\p
\v 29 Nau jatana wonti: «Pani; buka kanta jura bakana dukaraiati, nindri madlentji dukarana.   
\p
\v 30 Pudla wolja jela punkananto kampani ditjielu, ja kampani ditjini ngani kampanietjani jatala nganai: Ngopera nindri madlentji kampanau, ja kuma ngankanau, nina turujeli japila; ja buka tandra kampani pungani ngakanani mapani‐mai.»“   
\p
\v 31 Jeribaka jaura nguru Nulu tanangu kurana wonti ja jatana wonti: „Pariwilpaia milila tandra wakawaka jeribaka nganai, ninapini kana kulnujeli manina wonti ja mitani nunkanani jaupana wonti.   
\p
\v 32 Nau morla waka nganai tandra nguja marapuni; nau matja pirnarina, nau morla pirna nganai nindri nguja marapuni, ja pitariai, jeruja tjilpini nunkanani paia ngaranala wokarai, ja ngamai.“   
\p
\v 33 Jeribaka jaura nguru Nau tanangu jatana wonti: „Pariwilpaia milila pulkurutjeribani buka jeribaka nganai, nina widla kulnujeli manina wonti ja duldruwana wonti koko pirna parkulu buka turarani, nau pulkurutjeranantulu.“   
\p
\v 34 Tananapini pratjana Jesus kana wolarani jeribaka jaurali jatana wonti, ja jeribaka jaura panini Nau wata tanangu jatana wonti.   
\p
\v 35 Ngangau morlalu pantjinanto, mina Prophetali kaukaubana wonti, nau jatana wonti: „Ngani mana wilparila nganai jeribaka jaurali, ngato kaukaubala nganai, mina kurukuru nganana wonti mita pantjimanandru.“   
\p
\v 36 Ngadani Jesujeli kana wolara jinpana wonti ja pungani wokarana wonti. Ja mili nunkani nunkangu wokarana wonti ja jatana wonti: „Jeribaka jaura nindri madlentjandru mitani ngaianingu mildiri ngankamai.“   
\p
\v 37 Nulu tanangu kalabana wonti: „Nulu paua ngumu jaupai, Nau Kanaia Ngatamura nganai;   
\p
\v 38 Buka maru, mita maru nganai; paua ngumu mililaia kupa nganai; nindri madlentji madlentjaia kupa nganai;   
\p
\v 39 Talpalali, nulu jenia jaupana, nau kutji madlentji nganai; kampani ditji mita mudani nganai; kampanietja angela wora nganai.   
\p
\v 40 Worderu tanali nindri madlentji kampai ja turujeli japiai, jeruja bakana mita mudanani nganala nganai.   
\p
\v 41 Kanaia Ngatamurajeli angala worana nunkani jinpala nganai ja nunkani mililandru kampala nganai tjikatjika pratjana, ja tanana madlentji ngankanietja.   
\p
\v 42 Ja tanali tanana turu pirini worala nganai; naka tana ngirikidala nganai ja mana katakatangala nganai.   
\p
\v 43 Jendranguta kana talku mintjila nganai ditji pirna jeribaka tanani Ngaperaia mililani.“ Warle talpa ngamalkai ngarala, nulu ngaraiatimai!   
\p
\v 44 Nakaldra pariwilpaia milila poto pirna jeribaka nganai, nau mitani kurukuru parai; nina kana kulnujeli mankamankana wonti ja kutibana wonti, ja nunkangundru pirna mankina nau wapana wonti, ja warupoto, mina nulu ngamalkana, jinkina wonti, ja ninapini mita burungankana wonti.   
\p
\v 45 Nakaldra pariwilpaia milila jinkimalinietja jeribaka nganai, nulu marda ngumu wontiai.   
\p
\v 46 Ja nulu marda kulno ngumu pirna matja mankamankana, nau wapana wonti, ja warupoto, mina nulu ngamalkana, jinkina wonti, ja nina burungankana wonti.   
\p
\v 47 Nakaldra pariwilpaia milila jama pirna jeribaka nganai, nina kanali panto pirnani worai ja paru nguja marapu kampai.   
\p
\v 48 Ja naupini matja manamiririna, tanali nina taralkana wonti dirkalaia, ja tana ngamana ngarina wonti, ja tanali tanana ngumu pirrani kurana wonti, ja tanana madlentji worana wonti.   
\p
\v 49 Jeruja mita mudanani nganala nganai; angala wora dunkala nganai, ja tanali puntipuntibala nganai kana madlentji kana talkundru,   
\p
\v 50 Ja tanana turu pirini worala nganai; naka tana ngirikidala nganai ja mana katakatangala nganai.   
\p
\v 51 Jesus tanangu jatana wonti: „Jura tananapini pratjana ngundrana warai?“ Tana nunkangu jatana wonti: „Kau, Kaparajai!“   
\p
\v 52 Nau tanangu jatana wonti: „Jendrania jaura jinkinietja pratjana, tana mili pantjinala pariwilpaia mililaia, punga ngamalkanietja jeribaka nganai, tanali tanani poto pirnandru marra ja womala dunkalkai.“   
\p
\v 53 Ja jendranguta Jesujeli tananapini jeribaka jaura mudana wonti, Nau nakandru puntina wonti.   
\p
\v 54 Ja Nau ngura kamanelini wokarana wonti, ja Nulu tanangu ngujangujara jinkina wonti jaura pungani tananani, ja tana pirna ngaruparana wonti ja jatana wonti: „Wodajerindru Nulia ninapini kiri ja ngurula manina?   
\p
\v 55 Naupini wata pita ngankanietjaia ngatamura nganai? Ja ngandri nunkani Maria? Ja ngatata nunkani Jakobus ja Joses ja Simon ja Judas?   
\p
\v 56 Ja wata kaku nunkani pratjana ngaianangu jela nganai? Wodajerindru Nulia jenia pratjana manina?“   
\p
\v 57 Ja tana nunkangu kuterina wonti. Ja Jesus tanangu jatana wonti: „Propheta wata waka nganai, windri ngura kamanelini ja pungani nunkanani.“   
\p
\v 58 Ja Nulu wata pirnala marapu naka ngankana wonti, ngangau tanali wata morlalu ngundrana wonti.   
\c 14  
\p
\v 1 Tanangupini ditjini Herodes, mitaia kapakaparali, pinti Jesungundru ngarana wonti,   
\p
\v 2 Ja nau milini nunkanani jatana wonti: „Naupini Johannes multibanietja nganai, Nau narindru jiritjina warai; ngangau Nulu jenia pirnala ngankai.“   
\p
\v 3 Ngangau Herodili Johannes patana wonti ja dupudupu ngankana wonti ja nina kanjangari pungani widmana wonti, Herodias Philippuni ngatataia nunkanaia noandru.   
\p
\v 4 Ngangau Johannes nunkangu jatana wonti: „Jinkangu wata talku nganai nana ngamalkananto.“   
\p
\v 5 Nulu ngantjana wonti, nina nari ngankala, windri nau japali nganana wonti kana wolarandru; ngangau tanali nina Propheta ngundrana wonti.   
\p
\v 6 Herodili dankani ditji nunkani ngamalkana, Herodiani ngatani tanangu terti kilina wonti, ja Herodes nankangu murlali nganana wonti.   
\p
\v 7 Jendrania nau nankangu jaura morlalu jatana wonti, nankangu jinkila, minani nani ngatjinani.   
\p
\v 8 Ngandrieli nankanali nana matja kurukurubana, nani jatana wonti: „Jinkiau ngakangu ninkida pirrani Johannes multibanietja mangatandra.“   
\p
\v 9 Ja mitaia kapara burkali pantjina wonti; windri jaura morlalundru ja pungaia kamanelindru nulu jirijiribana wonti, nina nankangu jinkinanto.   
\p
\v 10 Ja nulu jinpana wonti ja Johannes mangatandra wokaribana wonti kanjangari pungani.   
\p
\v 11 Ja tanali mangatandra pirrani tikalkana wonti ja mankarani jinkina wonti, ja nandru nina ngandrini nankanani padakana wonti.   
\p
\v 12 Ja mili nunkani wokarana wonti ja palku nunkani manina wonti ja nina todina wonti ja wapana wonti, Jesungu jenia kaukaubala.   
\p
\v 13 Ja Jesujeli jenia matja ngarana, nau nakandru botali wapana wonti pitaraia pilki. Ja kana wolarali jenia matja ngarana, tana tidnali nunkangu karipaterina wonti ngura wolarandru.   
\p
\v 14 Ja Jesus dunkana wonti, ja Nulu kana wolara pirna najina wonti; ja Nau tanangu kalumiltjamiltjarina wonti, ja Nulu muntja tanani tepi ngankana wonti.   
\p
\v 15 Matja kalkaurarina, mili nunkani nunkangu wokarana wonti ja jatana wonti: „Ninkida pitaru nganai ja ditji matja wirina; kana wolara jinpau, tanaia nguraia wapananto buka tanani burungankala.“   
\p
\v 16 Jesus tanangu jatana wonti: „Tanaia wata wapananto; jura tanangu buka jinkianau.“   
\p
\v 17 Tana nunkangu jatana wonti: „Ngaiani ninkida windri buka ngunku mara wora ja paru mandru ngamalkai.“   
\p
\v 18 Nau jatana wonti: „Jura ngakangu tanana padakanimai.“   
\p
\v 19 Ja Nulu jirijiribana wonti, kana wolara kantani ngamana ngarinanto; ja Nulu buka mara wora ja paru mandru patana wonti, ja pariwilpani najina tarana wonti, ja tanana ngurungutana wonti; ja Nulu buka wokaribana wonti ja milini nunkanani jinkina wonti, ja milieli kana wolarani.   
\p
\v 20 Ja pratjanali tajina wonti ja jerturina wonti, ja tanali buka worduwordu kampana wonti, billi marapratjana ja mandru manamiri.   
\p
\v 21 Ja tana materi 5000 nganana wonti, matja tajina, kalitakali widlakupata.   
\p
\v 22 Ja wolja Jesujeli mili nunkani jinpana tertana wonti, tana botani wirinanto ja nunkangu ngopera jerankaria pararananto, Nulu ngopera kana wolara jinpananto.   
\p
\v 23 Ja Nulu kana wolara matja jinpana, Nau mardawonpaia tarana wonti ngatjila kulnulu. Ja matja kalkaurarina, Nau naka kulnulu nganana wonti.   
\p
\v 24 Bota matja panto mandrani ngananani, mandikilali nina jupana wonti; ngangau watara tanangu mudlani ngakana wonti.   
\p
\v 25 Nguramaranikuperi Jesus tanangu wokarana wonti ngapani wapana.   
\p
\v 26 Ja milieli nina najina ngapani wapanani, tana japali pirna pantjina wonti jo jatana wonti: „Kutji Nauja nganai!“ ja tana japali maritjina wonti.   
\p
\v 27 Nurujeli Jesus tanangu jatana wonti: „Murlali ngananimai, ngani Nauja; wata japali ngananimai!“   
\p
\v 28 Petrujeli nunkangu kalabana wonti ja jatana wonii: „Kaparajai! Jidni ngananani, ngana karkamai, ngani jinkangu ngapani wokarananto.“   
\p
\v 29 Nau jatana wonti: „Kaparau!“ Ja Petrus botandru ngarina wonti ja ngapani wapana wonti, Jesungu wokarala.   
\p
\v 30 Nulu watara pirna najina, nau japali pantjina wonti; ja nau nganana ngarina wonti kunakutila, nau maritjina wonti ja jatana wonti: „Kaparajai, ngana kulkamai!“   
\p
\v 31 Nurujeli Jesujeli nguna warpina wonti ja nina patana wonti ja jatana wonti: „Wuldrungundranietjajai, minandru jidni mangangankai?“   
\p
\v 32 Ja pudla botani tarana, watara mudana wonti.   
\p
\v 33 Tana kana botani wokarana wonti nunkangu pantjaterkana ngarila, ja jatana wonti: „Morlalu, Jidni Godaia Ngatamura nganai.“   
\p
\v 34 Ja tana matja pararana, tana Genezareth mitani wokarana wonti.   
\p
\v 35 Ja kanali nunkangupini ngurani nina matja ngujamana, tanali mita marapuni karakara jinpana wonti, ja tanali muntja pratjana nunkangu wokaralkana wonti.   
\p
\v 36 Ja tana nunkangu ngatjina wonti, tanali windri katijelbi nunkani karakarananto; ja worderuntjali karakarana wonti, tepi pantjina wonti.   
\c 15  
\p
\v 1 Ngadani Pharisaia ja jaura jinkinietja Jerusalemingundru Jesungu wokarana wonti ja jatana wonti:   
\p
\v 2 „Minandru milieli jinkanali pinaraia jirijiribani jaura dankarai? Ngangau tanali mara wata kulirkateriai buka tajila.“   
\p
\v 3 Nulu kalabana wonti ja tanangu jatana wonti: „Minandru jura Godaia jirijiribani jaura dankarai jurani jirijiribani jaurandru?“   
\p
\v 4 Ngangau Godali jirijiribana wonti ja jatana wonti: „Ngaperi ja ngandri pirna ngundramai!“ ja: „Warle ngaperani ja ngandrini jaura madlentji jatai, nau naria palinanto.“   
\p
\v 5 Ja jura jatai: „Worana npaperani kara ngandrini kara jatai: Poto ngumu ngato jinkiai, mina jinkangu ngumu nganai, nina jundru ngakangundru maninanto; ja nulu ngaperi nunkani kara, ngandri nunkani kara, wata pirna ngundrananto.“   
\p
\v 6 Ja jura Godaia jirijiribani jaura worana warai jurani jirijiribani jaurandru.   
\p
\v 7 Jura kana jeljujelju, ngumu Jesaiasali jurangundru talpadakana wonti ja jatana wonti:   
\p
\v 8 „Tanapini kana wolara manali ngakangu wokarai ja manamimieli ngana pirna ngundrai, ja tanani ngara ngakangu worita nganai.   
\p
\v 9 Bakujeli tanali ngana pirna ngundrai; ngangau tanali kanaia jirijiribani jaurandru ngujangujara jinkiai.“   
\p
\v 10 Ja Nulu kana wolara karkana wonti ja tanangu jatana wonti: „Ngaranimai, ja ngundranimai!   
\p
\v 11 Wata jendralipara, mina manani wiriai, kana murumaru ngankai; a‐ai, windri jendralipara, mina manandra dunkai, nulupini kana murumuru ngankai.“   
\p
\v 12 Jendranguta mili nunkani wokarana wonti ja nunkangu jatana wonti: „Jidni milkila, Pharisaiali ninaia jaura matja ngarana, tana kalakalarina warai?“   
\p
\v 13 Nulu kalabana wonti ja jatana wonti: „Nindri pratjana, tananapini Ngaperali ngakanali pariwilpani wata kuranala, tanana tanali dukarala nganai.   
\p
\v 14 Tana worani; ngangau tana butjuja palto wondranietja ja munta butju nganai; butjujeli butjuni palto wondranani, pudla kutuni purila nganai.“   
\p
\v 15 Petrujeli kalabana wonti ja nunkangu jatana wonti: „Ninapini jeribaka jaura ngaianingu mildiri ngankamai.“   
\p
\v 16 Jesus jatana wonti: „Bakana jura patipati nganai?   
\p
\v 17 Jura wata ngujamai, jenipara pratjana, mina manani wiriai, mandrani ngariai, ja ngadani palkingai?   
\p
\v 18 Jenipara, mina manandru dunkai, ngarandru wokarai; ja jendralipara kana murumuru ngankai.   
\p
\v 19 Ngangau ngarandru dunkai, ngundrana madlentji, naria nandrani, pinta wokaribana, palakantji, kurikantji, jedieli jaura morlalu kurani, ngirkibani.   
\p
\v 20 Tanalipini kana murumuru ngankai; mara murumurujeli tajina wata kana murumuru ngankai.“   
\lit (Ngantjani‐jaura G. D. Reminiscere.)  
\p
\v 21 Ja Jesus nakandru wapana wonti ja kutingana wonti Tyrus ja Sidon mitaia.   
\p
\v 22 Ja mai, Canaan widla kulno nunkangupini wondirandru dunkana wonti ja maritjina wonti ja nunkangu jatana wonti: „Kaparajai, Davidani ngatamurajai! ngakangu kalumiltjamiltjariau; ngatani ngakani kutjieli pirna jupai.“   
\p
\v 23 Ja Nulu wata jaura kulno kalabana wonti nankangu. Ja mili nunkani nunkangu wokarana wonti ja nunkangu ngatjina wonti ja jatana wonti: „Nanaia jinpamai: ngangau nania ngaianangu maritjina karipateriai.“   
\p
\v 24 Ja Nulu kalabana wonti ja jatana wonti: „Ngapili ngana jinpana wonti windri tanangupini tjipia, tana Israel pungandru tintaterinala.“   
\p
\v 25 Ja nani wokarana wonti ja nunkangu pantjaterkana ngarina wonti ja jatana wonti: „Kaparajai, ngakangu marangokau!“   
\p
\v 26 Ja Nulu kalabana wonti ja jatana wonti: „Wata jenia talku nganai, kupaia buka manina ja kintalani worana.“   
\p
\v 27 Nani jatana wonti: „Kau, Kaparajai; ja bakana kintalali buka worduwordu tajiai, kapara worani kurlindru purinani.“   
\p
\v 28 Jendranguta Jesujeli kalabana wonti ja nankangu jatana wonti: „Widlajai, morlalu ngundrana jinkani pirna nganai; mina jidni jertapateriai, jenia jinkangu pantjiatimai.“ Ja ngatani nankani tepirina wonti nunkangupini ditjini.   
\b  
\p
\v 29 Ja Jesus nakandru wapana wonti ja Galilaia pantuni wokarana wonti ja mardawonpani tarana wonti ja naka ngamana ngarina wonti.   
\p
\v 30 Ja kana wolara pirna nunkangu wokarana wonti, tanali padakana wonti tjunduru, butju, ngapu, dupudupu ja nguja marapu; ja tanali tanana Jesungu tidnani worana ngarina wonti, ja Nulu tanana tepi ngankana wonti.   
\p
\v 31 Jeruja kana wolara pirna ngaruparana wonti, ngangau tanali najina wonti, ngapula jatanani, dupudupula tepi, tjundurula wapanani ja butjulali najinani; ja tanali Israelani Goda jurakokana wonti.   
\p
\v 32 Jesujeli mili nunkani karkana wonti ja jatana wonti: „Ngani kana wolarani kalumiltjamiltjariai, ngangau ditji parkulu tanaia ngakangunto ngamana warai, ja tanalia panila ngamalkai tajila; ja ngato wata ngantjai, tananaia maua jinpala, tanaia paltuni wariwariati.“   
\p
\v 33 Ja mili nunkani nunkangu jatana wonti: „Wodajerindru ngaiani pitarani jeruntja buka maninanto, tananapini kana wolara jerto ngankala?“   
\p
\v 34 Ja Jesus tanangu jatana wonti: „Worderuntja buka ngunku jura ngamalkai?“ Tana jatana wonti: „Mara wora ja mandrumata ja paru wakawaka ngalje.“   
\p
\v 35 Ja Nulu kana wolarani jirijiribana wonti, tana mitani ngamana ngarinanto.   
\p
\v 36 Ja Nulu buka ngunku mara wora ja mandru ja paru patana wonti, ja Nulu tanana ngurungutana wonti ja wokaribana wonti ja milini nunkanani jinkina wonti, ja milieli kana wolarani.   
\p
\v 37 Ja pratjanali tajina wonti ja jerturina wonti, ja tanali buku worduwordu kampana wonti billi mara wora ja mandru manamiri.   
\p
\v 38 Ja tanali matja tajina materi 5000 nganana wonti kalitakali widlakupata.   
\p
\v 39 Ja Nulu kana wolara matja jinpana, Nau botani wirina wonti, ja Magdalaia wondirani wokarana wonti.   
\c 16  
\p
\v 1 Ja Pharisaia ja Sadducaia wokarana wonti nina wontjala, ja nunkangu ngatjina wonti, Nulu tanangu malka kulno pariwilpandru wondrananto.   
\p
\v 2 Nulu kalabana wonti ja tanangu jatana wonti: „Matja kalkaurarinani, jura jatai: Ditji ngumu nganala nganai ngangau pariwilpani kalkamaralje pirna nganai.   
\p
\v 3 Ja tankubana palkara: Karari ditjini talara wokarala nganai, ngangau pariwilpani nguramaralje pirna nganai, ja ngalpuru pantjiai. Jura kana jeljujelju! Pariwilpaia mudla jura kiri nganai ngujangujamala, windri miljaraia malka jura wata ngujangujamai.   
\p
\v 4 Nguja madlentjali ja pinta wokaribanietjali ngantjai malka kulno; ja tanalia wata malka manila nganai, windri Prophetaia Jonani malka.“ Ja Nulu tanana worarana kurana wonti ja wapana wonti.   
\p
\v 5 Ja mili nunkani jerankari wokarana wonti, ja tana kuritarana wonti buka padakala.   
\p
\v 6 Jesus tanangu jatana wonti: „Najianau ja ngamalkaterianau Pharisaiaia ja Sadducaiaia pulkurutjeribani bukandru.“   
\p
\v 7 Tana ngankamalina wonti ja jatana wonti: „Jenia Nauja jatai, ngangau ngaiana wata buka padakana warai.“   
\p
\v 8 Jesujeli jenia matja ngujamana, Nau tanangu jatana wonti: „Minandru jura ngankamaliai, jura wuldrungundranietja, ngangau jura wata buka padakana warai?   
\p
\v 9 Jura wata ngundrai ja wata mangatandra wilpariai buka ngunku mara wora materani 5000, ja worderuntja billi jura kampana paraia?   
\p
\v 10 Ja bakana wata buka ngunku mara wora ja mandru materani 4000, ja worderuntja billi jura kampala wiri?   
\p
\v 11 Worderu jura bulu ngujamai, ngani wata bukandru jatana warai, jurangu jatana: Jura ngamalkaterinanto Pharisaiaia ja Sadducaiaia pulkurutjeribani bukandru?“   
\p
\v 12 Jendranguta tanali ngujamana wonti, Nau wata jatana warai, tana ngamalkaterinanto bukaia pulkurutjeribani bukandru, a‐ai, Pharisaiaia ja Sadducaiaia ngujangujarandru.   
\lit (Ngantjani‐jaura Petruni ja Pauluni ditjini.)  
\p
\v 13 Jesus Cäsaraia Philippi mitani wokarana wonti, ja Nulu mili nunkani jekibana wonti ja jatana wonti: „Mina kana jatai, worana Kanaia Ngatamura nganai?“   
\p
\v 14 Tana jatana wonti: „Palpa jatai: Jidni Johannes multibanietja, palpa Elias, palpa Jeremias kara Propheta kulno kara.“   
\p
\v 15 Nau tanangu jatana wonti: „Mina jura jatai, worana ngani nganai?“   
\p
\v 16 Simon Petrujeli kalabana wonti ja jatana wonti: „Jidni Christus nganai, Godaia tepia Ngatamura,“   
\p
\v 17 Ja Jesujeli kalabana wonti ja nunkangu jatana wonti: „Murlali pirna jidni nganai, Simon, Jonani ngatamura; ngangau palkujeli ja kumarali jinkangu jenia wata tinkari ngankana warai, a‐ai, Ngaperali ngakanali pariwilpani.   
\p
\v 18 Ja ngani bakana jinkangu jatai: Jidni Petrus nganai, ja nunkangupini marda tulurani ngato milila ngakani wotila nganai, ja turu manali nina wata kalalu ngankala nganai.   
\p
\v 19 Ja ngato jinkangu pariwilpaia mililaia mana ngamalkijiribananto jinkila nganai; ja mina jundru mitani dupudupu ngankala nganai, jenia bakana pariwilpani dupudupu nganala nganai; ja mina jundru mitani dukarala nganai, jenia bakana pariwilpani walto nganala nganai.“   
\p
\v 20 Ngadani Nulu mili nunkani daudauana wonti, tanali jenia wata kulnuni kaukaubananto, Nau Jesus Christus nganai.   
\p
\v 21 Jendranguta Jesujeli wonina wonti, milini nunkanani wondraterila, Nau Jerusalemia wapananto ja pinaru woraugundru ja Priesta pirnandru ja jaura jinkinietjandru pirna ketjaketjananto, ja tanali nina nari ngankananto, ja Nau ditjini parkulani nakaldra jiritjinanto.   
\p
\v 22 Ja Petrujeli nina tjirimalkana wonti, ja wonina wonti nina daudauala ja jatana wonti: „Ngamalkateriamai, Kaparajai, wata jenia jinkangu pantjinanto.“   
\p
\v 23 Nau karitjina wonti ja Petrungu jatana wonti: „Ngakangu ngadaia nganamai, Satanajai! jundru ngana ngandrawalkai; ngangau jundru wata ngundrai, mina Godaia nganai, a‐ai, windri mina kanaia.“   
\p
\v 24 Jesus milini nunkanani jatana wonti: „Warle ngantjai ngakangu karipaterila, nau munta panila ngundrateriatimai, ja nulu kunarku nunkani maniatimai ja ngakangu karipateriatimai.   
\p
\v 25 Ngangau warle tepi nunkani ngantjai kulkala, nulu nina tintala nganai; ja warle tepi nunkani tintai ngakangundru, nulu nina mankamankala nganai.   
\p
\v 26 Jenia kanani ngumu nganai kara, nulu mita maru maninani, ja mungara tintaterinani? Mina kalala kanali jinkinanto kara mungarani nunkanani?   
\p
\v 27 Ngangau wolja Kanaia Ngatamura Ngaperaia nunkanaia pirnalali wokarala nganai nunkani angela worangunto; ja ngadani Nulu warupotuni kalala jinkila nganai tanani ngankanandru.   
\p
\v 28 Morlalu ngani jurangu jatai: Tanangundru palpa ninkida terkala wapaia, tanalipini nari wata wontjala nganai, tanalia Kanaia Ngatamura mililani nunkanani wokaranani najinantulu.“   
\c 17  
\lit (Ngantjani‐jaura G. D. VI. Epiphanias.)  
\p
\v 1 Ditji mara wora ja kulnuni Jesujeli Petrus ja Jakobus ja Johannes ngatata nunkani patana wonti, ja tanana pilki taralkana wonti mardawonpa pirnaia miri.   
\p
\v 2 Ja Nau tanangu njeranjerarina wonti, ja Nau mudla ditji jeri mintjina wonti, ja kati nunkani bulurina wonti praitji jeribaka.   
\p
\v 3 Ja mai, Moses ja Elias tanangu wondraterina wonti, pudla ngankamalina wonti nunkangu.   
\p
\v 4 Petrujeli kalabana wonti ja Jesungu jatana wonti: „Kaparajai, ninkida ngaianangu ngumu nganai; Jundru jenia ngantjai, ngaiani punga parkulu ninkida wotila nganai, jinkani kulno, Mosini kulno ja Eliani kulno.“   
\p
\v 5 Nau jeruja jatana, mai, talarapalku kulikirieli tanana walpadakana wonti. Ja mai, ngaiala talarapalkundru jatana wonti: „Naupini Ngatamura ngantjalu ngakani nganai, nunkangu ngani murlali nganai; ninaia ngaranimai.“   
\p
\v 6 Milieli jenia matja ngarana, tana mudlali purina wonti ja japali pirna nganana wonti.   
\p
\v 7 Ja Jesus tanangu wokarana wonti ja tanana karakarana wonti ja jatana wonti: „Jiritjianau, ja wata japali ngananau!“   
\p
\v 8 Matja tana milki tjenmana, tanali kana pani najina wonti, windri Jesus kulnulu.   
\p
\v 9 Ja tana mardawanpandru ngarina tikana, Jesujeli tanana daudauana wonti ja jatana wonti: „Ninaia mudla wata kulnuni kaukaubanau, Kanaia Ngatamura narindru jiritjinantulu.“   
\p
\v 10 Ja milieli nunkanali nina jakalkana wonti ja jatana wonti: „Minandru jaura jinkinietja jatai, Elias ngopera wokarananto?“   
\p
\v 11 Jesujeli kalabana wonti ja tanangu jatana wonti: „Elias morlalu wokarala nganai, ja nulu warupoto nakaldra talku kurala nganai.   
\p
\v 12 Ja ngani jurangu jatai: Elias matja wokarana warai, ja tanali nina wata ngujamana warai, a‐ai, nunkangu ngankana warai, mina tana jertapaterina warai. Jeruja bakana Kanaia Ngatamura tanangundru ketjaketjala nganai.“   
\p
\v 13 Ngadani milieli nunkanali ngujamana wonti, Nau tanangu Johannes multibanietjandru jatana warai.   
\p
\v 14 Ja tana kana wolarani wokarana, kana kulno nunkangu wokarana wonti ja nunkangu pantjaterkana ngarina wonti,   
\p
\v 15 Ja jatana wonti: „Kaparajai, ngatamurani ngakanani kalumiltjamiltjariau; ngangau nauwa pirala muntja nganai ja pirna ketjaketjai, ja pota marapu nauwa turuni puriai ja pota marapu ngapani.   
\p
\v 16 Ja ngato ninawa milini jinkanani wapalkana warai, ja tanaia ngandandarina warai, ninawa tepi ngankala.“   
\p
\v 17 Jesujeli kalabana wonti ja jatana wonti: „Jura nguja gilbarinietja ja tjautjauetja! Wintaranaia ngani jurangu jela nganananto? Wintaranaia ngato jurana ngamalkananto? Ninawa ngakangu padakanau ninkida.“   
\p
\v 18 Ju Jesujeli nina dikidikibana wonti, ja kutji murumuru nunkangundru dunkana wonti, ja kanku nunkangupini ditjini tepirina wonti.   
\p
\v 19 Jendranguta mili Jesungu pilki wokarana wonti ja jatana wonti: „Minandru ngaiani ngandandarina warai, ninaia dunkalkala?“   
\p
\v 20 Jesus tanangu jatana wonti: „Jurani gilbarinandru. Ngangau morlalu ngani jurangu jatai: Jura morlalu ngundranani tandra wakawaka jeribaka, jura nunkangupini mardawonpani jatala nganai: «Ninkidandru tiringau jelaniwa;» ja nauja jelaniwa tiringala nganai, ja watala jura ngandandarila nganai.   
\p
\v 21 Naupara nguja wata dunkai, windri ngatjinali ja milja ngamanali.“   
\p
\v 22 Tana Galilaiani wirarina, Jesus tanangu jatana wonti: „Tanali Kanaia Ngatamura kana marani ngulkujeli jinkila nganai.   
\p
\v 23 Ja tanali ninaia nandrala nganai, ja ditjini parkulani Nauja jiritjila nganai.“ Ja tana ngaurongauro pirna pantjina wonti.   
\p
\v 24 Tana Kapernaum ngurani wokarana, kalala kampanietja Petrungu wokarana wonti ja jatana wonti: „Jurani Ngujangujana jinkinietjali wata kalala jinkiai?“   
\p
\v 25 Nau jatana wonti: „Kau.“ Ja nau pungani wirina Jesujeli nina ngaringana wonti ja jatana wonti: „Mina jundru ngundrai, Simoniai? Worangundru mitaia kaparali kalala pilki ja pilki maniai, tanani kupandru kara, tulandru kara?“   
\p
\v 26 Petrus nunkangu jatana wonti: „Tulandru.“ Jesus nunkangu jatana wonti: „Jeruja kupa baku nganai.   
\p
\v 27 Ngangau ngaiana tanana wata ngirkibananto, pantuja wapau, ja manakira worau, ja paru ngoperala nau taranani, maniau; ja jundru mana matja pirakana, jundru Statera mardatandra mankamankala nganai: Nina maniau, ja tanangu jinkiau ngakangundru ja jinkangundru.“   
\c 18  
\lit (Ngantjani‐jaura Michaelis ditjini.)  
\p
\v 1 Nunkangupini ditjini mili Jesungu wokarana wonti ja jatana wonti: „Worana pariwilpaia mililani morla pirna nganai?“   
\p
\v 2 Ja Jesujeli kupa waka karkana wonti ja tanangu terti terkibana wonti,   
\p
\v 3 Ja jatana wonti: „Morlalu ngani jurangu jatai: Jura wata karitjinani ja kupa wakawaka jeribaka pantjinani, jura morlalu wata pariwilpaia mililani wirila nganai.   
\p
\v 4 Worana waka ngankateriai nunkangupini kupani jeribaka, naupini pariwilpaia mililani morla pirna nganai;   
\p
\v 5 Ja warle jenipara kupa waka kulno patai talani ngakanani, nulupini ngana patai.   
\p
\v 6 Warle tanangundru kulno wakawaka, ngakangu morlalu ngundranani, karkarkai, nunkangu ngumu nganai, marda wati jerkalani kurananto ja nina panto mandrani terti jikananto.   
\p
\v 7 Jakajai mitani karkarkanandru! Karkarkana kantji nganananto, ja jakajai nunkangupini kanani, nulu karkarkai.   
\p
\v 8 Marali kara, tidnali kara jidnana karkarkanani, ninaia wokaribamai jo jinkangundru woramai; Ngumu jinkangu nganai, tidna wordu kara, nguna wordu kara, tepini wirila; tanali jidna mara mandrunto kara, tidna mandrunto kara turu nguralia woraiati.   
\p
\v 9 Ja milkieli jidnana karkarkanani, ninaia dukaramai, ja jinkangundru woramai; Ngumu jinkangu nganai, milki kulnunto tepini wirila; tanali jidna milki mandrunto turu pirnaia woraiati.   
\p
\v 10 Ngamalkaterianau, jura kulno tanangundru wakawaka waka ngundraiati; ngangau ngani jurangu jatai: Tanani angelali pariwilpani milingera ngakani Ngaperi mudla pariwilpani najila wapaia.   
\p
\v 11 Ngangau Kanaia Ngatamura wokarana warai kulkala, mina tintaterina warai.   
\b  
\p
\v 12 Mina jura ngundrai? Kana kulnujeli 100 tjipi ngamalkanani ja kulno tanangundru tintaterinani, nulu wata 99 mardawonpani worarala nganai ja wapala nganai, nina manila, nau tintaterina warai?   
\p
\v 13 Ja jeruja ngananani, nulu nina mankamankana, morlalu ngani jurangu jatai: Nau nunkangu morla mankila nganai tanangu 99, tana wata tintaterina warai.   
\p
\v 14 Jeruja Ngaperi jurani pariwilpani wata jertapateriai, kulno tanangundru wakawaka tintaterinanto.   
\p
\v 15 Ngatatajeli jinkanali jinkangu madlentji ngankanani, wapau, ja kurukurubamai nina kulnujeli. Nulu jidna ngaranani, jundru ngatata jinkani kulkana warai.   
\p
\v 16 Nulu jidna wata ngaranani, maningamai jinkangu kulno kara mandru kara, ngangau jaura pratjana morlalu kuranietja mana mandruni kara parkulani kara parananto.   
\p
\v 17 Nulu tanana bulu ngaranani, mili wolarani kaukaubamai; nulu mili wolara bulu ngaranani, nau jinkangu kana ko ja mardatandra kampanietja jeribaka nganaiatimai.   
\p
\v 18 Morlalu ngani jurangu jatai: Mina jura mitani dupudupu ngankala nganai, jenia bakana pariwilpani dupudupu nganala nganai; ja mina jura mitani dukarala nganai, jenia bakana pariwilpani walto nganala nganai.   
\p
\v 19 Nakaldra ngani jurangu jatai: Mandru jurangundru kulnukulnuni ngananani poto kulnuni, ja nunkangundru ngatjinani, nina tanali manila nganai ngakani Ngaperandru pariwilpani.   
\p
\v 20 Ngangau woderi mandru kara, parkulu kara, jela ngamai talani ngakanani, naka ngani tanangu terti nganai.“   
\p
\v 21 Ngadani Petrus nunkangu wokarana wonti ja jatana wonti: „Kaparajai, worderuntja pota ngatatajeli ngakanali ngakangu madlentji ngankala nganai; ja worderuntja pota ngato madlentji nunkani worananto? Pota mara wora ja mandrumata?“   
\p
\v 22 Jesus nunkangu jatana wonti: „Ngani jinkangu jatai: Wata pota mara wora ja mandruta, a‐ai, 70 pota mara wora ja mandrumata.   
\lit (Ngantjani‐jaura G. D. XXII. Trinitatis.)  
\p
\v 23 Ngangau pariwilpaia milila mitaia kapara jeribaka nganai, nulu ngantjana wonti, milini nunkanani jelali windamala.   
\p
\v 24 Ja nulu matja wonina windamala, tanali mili kulno nunkangu wapalkana wonti, nau nunkangu 10,000 mardatandra pirna wilpanto nganana wonti.   
\p
\v 25 Ngangau nulu panila ngamalkana wonti jinkila, kaparali nunkanali jirijiribana wonti, nina ja noa nunkani ja ngatamura nunkani ja warupoto, mina nulu ngamalkana jinkinanto, kalala manila.   
\p
\v 26 Naupini mili nunkangu woraterina wonti ja ngatjina wonti nunkangu ja jatana wonti: «Kaparajai, manju nganamai ngakangu, ngato jinkangu warupoto jinkila nganai.»   
\p
\v 27 Kaparali nunkangu milini kalumiltjamiltjarina wonti ja nina kurakana wonti, ja poto wilpa nulu worani patana wonti.   
\p
\v 28 Ja naupini mili dunkana wonti, ja mili nguruni dankamalina wonti, nau nunkangu 100 mardatandra waka wilpanto nganana wonti, ja nulu nina patana wonti ja jupana wonti ja jatana wonti: «Jinkiamai, mina jidni ngakangu wilpanto nganai.»   
\p
\v 29 Ja mili nguru nunkangu tidnani woraterina wonti ja nunkangu ngatjina wonti ja jatana wonti: «Manju nganamai ngakangu, ngato jinkangu warupoto jinkila nganai.»   
\p
\v 30 Ja nulu wata ngantjana wonti, a‐ai, nau wapana wonti ja nina kanjangari pungani widmana wonti, nulu poto wilpa jinkinantulu.   
\p
\v 31 Mili ngurujeli jenia matja najina, mina pantjina warai, tana ngaurongauro pirna pantjina wonti ja wokarana wonti, ja tanali kaparani tananani pratjana kaukaubana wonti.   
\p
\v 32 Ngadani kaparali nunkanali nina karkana wonti ja nunkangu jatana wonti: «Jidni mili madlentji; ninapini poto wilpa warupoto ngato jinkangu worani patana warai, ngangau jidni ngakangu ngatjina warai;   
\p
\v 33 Wata jidni bakana kalumiltjamiltjarinanto mili nguruni, worderu ngani jinkangu kalumiltjamiltjarina warai?»   
\p
\v 34 Ja kapara nunkani tiririna wonti, ja nulu nina jupanietjani jinkina wonti, nulu nunkangu jinkinantulu, mina nau nunkangu poto wilpa nganana wonti.   
\p
\v 35 Jeruja bakana Ngaperali ngakanali pariwilpani jurangu ngankala nganai, jura wata ngarali woranani ngatataja jaranaia madlentji.“   
\b  
\c 19  
\p
\v 1 Ja jendranguta Jesujeli tananapini jaura matja mudana, Nau Galilaiandru puntina wonti ju Judaia wondirani wokarana wonti Jordan kaiarani jerankari.   
\p
\v 2 Ja nunkangu kana wolara pirna karipaterina wonti, ja Nulu tanana naka tepi ngankana wonti.   
\p
\v 3 Ja Pharisaia nunkangu wokarana wonti nina wontjala, ja nunkangu jatana wonti: „Jenia talku nganai kana kulnuni, noa nunkani worarala ngankana pilki ja pilkindru?“   
\p
\v 4 Nulu tanangu kalabana wonti ja jatana wonti: „Jura wata warapana warai, Pantjimanipirnali tanana ngopera materi ja widla pantjimana wonti,   
\p
\v 5 Ja jatana wonti: Jendrania kana kulnujeli ngaperi ja ngandri worarala nganai ja noani nunkanani jela ngamala nganai, ja pudla palku kulno nganala nganai?   
\p
\v 6 Jeruja pudla wata morla palku mandru, a‐ai, windri palku kulno nganai. Mina Godali matja ngokana, kanali wata puntibananto.“   
\p
\v 7 Tana nunkangu jatana wonti: „Minandru Mosili jirijiribana wonti, puntibani dakani jaura jinkila ja nana worarala?“   
\p
\v 8 Nau tanangu jatana wonti: „Mosili jenia manuni kurana wonti jurani ngara ngurungurundru, noa jurani worananto; ngopera wata jeruja nganana wonti.   
\p
\v 9 Ngani jurangu jatai: Warle noa nunkani woraranani, nani wata palakantji ngananani, ja noa nguru patanani, nulu pinta wokaribai; ja warle woraworarani widla patanani, nulu bakana pinta wokaribai.“   
\p
\v 10 Mili nunkani nunkangu jatana wonti: „Materaia poto noani nunkanani jeruja pirna ngananani, wata ngumu nganai noa patala.“   
\p
\v 11 Nau tanangu jatana wonti: „Wata pratjanali ninapini jaura patai, a‐ai, windri tanali, tanangu matja jinkina.   
\p
\v 12 Ngangau palpa eunucha nganai, tana ngandrindru jeruja dankanala; ja palpa eunucha nganai, tanana kanali ngankana warai; ja palpa eunucha nganai, tana pariwilpaia mililandru eunucha ngankaterinala. Worana ngurunguru nganai jenia patala, nulia pataiatimai.“   
\p
\v 13 Ngadani tanali kupa waka nunkangu padakana wonti, Nau tanangu mara kuraterinanto ja ngatjinanto; ja milieli tanana daudauana wonti.   
\p
\v 14 Jesus jatana wonti: „Kupa worani patanau, ja tananaia wata daudauanau ngakangu wokarananto, ngangau tanangu pariwilpaia milila nganai.“   
\p
\v 15 Ja Nau tanangu matja mara kuraterina, Nau nakandru wapana wonti.   
\p
\v 16 Ja mai, kulno nunkangu wokarana wonti ja jatana wonti: „Ngujangujara jinkinietja ngumujai, mina ngumula ngato ngankananto, tepi ngurali ngamalkala?“   
\p
\v 17 Nau nunkangu jatana wonti: „Minandru jundru ngana ngumu dikai? Wata kulno ngumu nganai, windri Goda kulnulu. Jundru ngantjanani tepini wirila, jirijiribani jaura ngamalkamai.“   
\p
\v 18 Nau nunkangu jatana wonti: „Wodanina?“ Jesus jatana wonti: „Jenia: Wata narielu nandramai, wata pinta wokaribamai, wata kurieli maniamai, wata jedi jaura morlalu jatamai.   
\p
\v 19 Ngaperi ja ngandri pirna ngundramai, ja ngurala jinkani ngantjamai jidni munta jeribaka.“   
\p
\v 20 Teri nunkangu jatana wonti: „Jenia pratjana ngato ngamalkai kupandru; mina ngato morla ngankananto?“   
\p
\v 21 Jesus nunkangu jatana wonti: „Jundru ngantjanani talku nganala, wapau ja poto jinkani jinkiamai kalalaia, ja wangiwangini bakujeli jinkiau; jeruja jundru pariwilpani poto pirna ngamalkala nganai; ja ngadani tikau ja ngakangu karipateriau.“   
\p
\v 22 Terieli nina jaura matja ngarana, nau ngaurongauro tikana wonti, ngangau nau poto pirna nganana wonti.   
\p
\v 23 Jesus milini nunkanani jatana wonti: „Morlalu ngani jurangu jatai: Jenia mati nganai, kana poto pirna pariwilpaia mililani wirinanto.   
\p
\v 24 Nakaldra ngani jurangu jatai: Morla ngaua nganai, Camuli kulno kuri pikiri wilpani palkingananto kana poto pirnani, nau Godaia mililani wirinanto.“   
\p
\v 25 Milieli nunkanali jenia matja ngarana, tana pirna ngaruparana wonti ja jatana wonti: „Warlengarla tepita manila nganai?“   
\p
\v 26 Jesujeli tanana najina pararana wonti ja jatana wonti: „Kana ngandandariai ngarla Godata wata ngandandariai.“   
\lit (Ngantjani‐jaura Pauluni karitjini ditjini.)  
\p
\v 27 Ngadani Petrulu kalabana wonti ja nunkangu jatana wonti: „Mai, ngaiani pratjana woraranala ja jinkangu karipaterinala; mina kalala ngaiani manila nganai?“   
\p
\v 28 Jesus tanangu jatana wonti: „Morlalu ngani jurangu jatai: Jura ngakangu karipaterina warai marra dankanani, Kanaia Ngatamura ngamanani pirnalaia pirini nunkanani, jura bakana pirnalaia pirini marapratjana ja mandruni ngamala nganai, Juda kanaia kapara marapratjana ja mandruni kalala kurala.   
\p
\v 29 Ja warle worarana warai punga worana kara, nejingatata worana kara, kaku worana kara, ngaperi kara, ngandri kara, noa kara, kupa worana kara, mita worana kara ngakani talandru, nulu 100 potajeli jenia manila nganai ja tepi ngurali patala nganui.   
\p
\v 30 Ja marapu ngoperala ngadaia nganala nganai, ja ngadala ngopera nganala nganai.“  
\b  
\c 20  
\lit (Ngantjani‐jaura G. D. Septuagesimä.)  
\p
\v 1 Pariwilpaia milila kana kulno jeribaka nganai, nau pungaia kapara nganai; nau tankubana wapana wonti, ngankanietja karkala wain maruja nunkanaia.   
\p
\v 2 Ja tana talpadakijiribamalina warai mardatandra kulnuja ditji kulnuni, nulu tanana jinpana wonti wain maruja nunkanaia.   
\p
\v 3 Ja nau wapana wonti takubana ditji mirini, ja nulu najina wonti kana nguru baku terkanani jinkimalini pirini,   
\p
\v 4 Ja nau tanangu jatana wonti: „Bakana jura wapanau wain maruja, ja mina talku nganai, ngato jurangu jinkila nganai.“   
\p
\v 5 Ja tana wapana wonti. Nakaldra nau wapana wonti toda ja ditji kunarkuni ja bakana jeruja ngankana wonti.   
\p
\v 6 Ditji ngaltingaltini nau wapana wonti, ja kana nguru nulu mankamankana wonti baku terkanani, ja nau tanangu jatana wonti: „Minandru jura ninkida ditjiwirdi baku terkai?“   
\p
\v 7 Tana nunkangu jatana wonti: „Wata kana kulnujeli ngaianina karkana warai.“ Nau tanangu jatana wonti: „Bakana jura wapanau wain maruja, ja mina talku nganala nganai, jura manila nganai.“   
\p
\v 8 Ja matja kalkauranina wain maruja kapara najinajibanietjani nunkanani jatana wonti: „Ngankanietja karkamai, ja tanangu kalala jinkiau, ja woniau ngadanietjandru ngoperaetjajelu.“   
\p
\v 9 Ja tana ditji ngaltingaltila wokarana wonti, ja tanali mardatandra kulno manina wonti.   
\p
\v 10 Ja ngoperaetja matja wokarana, tanali ngundrana wonti morla manila, ja bakana tanali mardatandra kulno manina wonti.   
\p
\v 11 Tanali nina manina, tana pungaia kaparani kalakalarina wonti,   
\p
\v 12 Ja jatana wonti: „Tanalipini ngadaetjali windri ditji kulno ngankana warai, ja jundru tanana ngaianingu jeribaka ngankana warai, ngaiani ditjiwirdi pirna ngankana warai ja woldrali ketjaketjana warai.“   
\p
\v 13 Nulu kalabana wonti ja tanangundru kulnuni jatana wonti: „Kamaneliai, ngato jinkangu wata tjikatjika ngankai; wata ngaldra talpadakijiribamalina warai mardatandra kulnuja?   
\p
\v 14 Patamai pilki jinkani ja wapamai! Ngani jertapateriai nunkangupini ngadanietjani kalala jinkila jinkangu jeribaka.   
\p
\v 15 Wata ngakangu talku nganai, potuni ngakanani ngankala worderu ngato ngantjai? Jidni milki madlentji, ngangau ngani ngumu nganai?   
\p
\v 16 Jeruja ngadala ngopera ja ngoperali ngadaia nganala nganai; ngangau marapu matja karkana, ja windri ngalje kalkalkana.“  
\b  
\p
\v 17 Ja Jesus Jerusalemia tarana, Nulu mili marapratjana ja mandru tjirimalkana wonti ja paltuni tanangu jatana wonti:   
\p
\v 18 „Mai, ngaiana Jerusalemia tarala wapaia, ja tanali Kanaia Ngatamura Priesta pirnani ja jaura jinkinietjani ngulkujeli jinkila nganai, ja tanali ninaia naria kurala nganai.   
\p
\v 19 Ja tanali ninaia kana koni ngulkujeli jinkila nganai, ninaia ngirkibala ja nandrala ja kunarkuni katibala; ja ditjini parkulani Nauja nakaldra jiritjila nganai.“   
\lit (Ngantjani‐jaura Jakobuni ditjini.)  
\p
\v 20 Ngadani Zebedäuni ngatamuraia ngandri ngatananto nunkangu wokarana wonti ja pantjaterkana ngarina wonti ja nunkangu ngatjina wonti minakulnuja.   
\p
\v 21 Nau nankangu jatana wonti: „Mina jundru ngantjai?“ Nani nunkangu jatana wonti: „Jatau, pudlapini ngatani ngakani kulno ngunarani ja kulno worangantjuni mililani jinkanani ngamananto.“   
\p
\v 22 Jesujeli kalabana wonti ja jatana wonti: „Judla wata milkila, mina judla ngatjiai. Judla ngurunguru nganai, nunkangupini kokundru tapala, nunkangundru ngato tapananto; ja nina multibanila manila kara, nina multibanila ngato maninanto?“ Pudla nunkangu jatana wonti: „Kauna, ngali ngurunguru nganai.“   
\p
\v 23 Ja Nau pudlangu jatana wonti: „Koko ngakani judla morlalu tapala nganai, ja nina multibanila, nina ngato maninanto, judla manila nganai; ja ngamana ngunarani ngakanani ja worangantjuni ngakanani jinkila, wata poto ngakani nganai, a‐ai, windri tanangu, worangu Ngaperali ngakanali ngankingana wonti.“  
\b  
\p
\v 24 Ja mili marapratjanali jenia matja ngarana, tana junkarina wonti neji marani.   
\p
\v 25 Jesujeli tanana karkana wonti ja jatana wonti: „Jura milkila, kana wolaraia kaparali tanangu jirijiribai, ja kana pirnali tanana jupai.   
\p
\v 26 Jeruja wata jurangu nganaiatimai, a‐ai, warle jurangundru ngantjai pirna pantjila, nau mili jurani nganaiatimai,   
\p
\v 27 Ja warle jurangundru ngantjai ngoperala nganala, nau mili jurani nganaiatimai.   
\p
\v 28 Worderu Kanaia Ngatamura wata wokarana warai mili ngamalkala, a‐ai, mili nganala, ja tepi nunkani jinkiterila kalala marapuja.“   
\p
\v 29 Ja tana Jericho ngurandru puntina, nunkangu kana wolara pirna karipaterina wonti.   
\p
\v 30 Ja mai, kana butju mandru paltuni ngamana wonti, pudlali matja ngarana, Jesus wiringanani, pudla maritjina wonti ja jatana wonti: „Kaparajai, Davidani ngatamurajai, ngalingu kalumiltjamiltjariamai!“   
\p
\v 31 Kana wolarali pudlana daudauana wonti, pudla ngapurinanto; ja pudla morla parparali maritjina wonti ja jatana wonti: „Kaparajai, Davidani ngatamurajai, ngalingu kalumiltjamiltjariamai!“   
\p
\v 32 Ja Jesus banbana wonti, ja Nulu pudlana karkana wonti ja jatana wonti: „Mina judla ngantjai, ngato judlangu ngankananto?“   
\p
\v 33 Pudla nunkangu jatana wonti: „Kaparajai, ngali milki piririnanto.“   
\p
\v 34 Jesus pudlangu kalumiltjamiltjarina wonti, ja Nulu pudlana milki karakarana wonti, ja nurujeli pudlali milkieli nakaldra najina wonti, ja pudla nunkangu karipaterina wonti.   
\c 21  
\lit (Ngantjani‐jaura G. D. Advent ja Palmarum.)  
\p
\v 1 Ja tana Jerusalemingu karakara nganana ja Bethphagingu mani nindri mardawanpani wokarana, jendranguta Jesujeli mili nunkani mandru jinpana wonti,   
\p
\v 2 Ja pudlangu jatana wonti: „Wirialumai nunkangupini ngura wakani judlani mudlankari, ja nurujeli judla donki ngandri mankamankala nganai workamantraterinani kuparanto; nana dukaralumai, ja pudlana ngakangu tikalkalumai.   
\p
\v 3 Ja kulnujeli judlana daudauanani, judla jatalumai: Kaparali pudlanaia karkai; ja nurujeli nulu pudlana jinpala nganai.“   
\p
\v 4 Jenia pratjana kantjirina wonti, ngangau morlalu pantjinanto, mina Prophetali kaukaubana wonti, nau jatana wonti:   
\p
\v 5 „Zionani ngatamurani kaukaubanimai: Mai, Kapara jinkani jinkangu wokarala wapaia malti, ja Nau dukateriai donkini ja kuparani potowaltanietjaia wolkani.“   
\p
\v 6 Mili wulu wapana wonti ja ngankana wonti, worderu Jesujeli pudlangu jirijiribana wonti.   
\p
\v 7 Ja pudlali donki ja kuparu tikalkana wonti, ja kati tanani tanali nunkangu kurana wonti ja nina kurana tarana wonti.   
\p
\v 8 Kana wolarali kati tanani paltuni jaupana wonti, ja kana ngurujeli ngunanguna wokaribana wonti pita nindrindru, ja tanana paltuni jaupana wonti.   
\p
\v 9 Ja kana wolara, tana ngopera wapana wonti ja karipaterina wonti, maritjina wonti ja jatana wonti: „Hosianna Davidani ngatamurani, ngaiani jurakokai ninaia, Nauja wokarai Kaparaia talani! Hosianna mirini!“   
\b  
\p
\v 10 Ja Nau Jerusalemingu matja wirina, ngura warupotula patijiritjina wonti ja jatana wonti: „Worana Naupini nganai?“   
\p
\v 11 Kana wolara jatana wonti: „Naupini Propheta Jesus nganai, Nazarethala, Galilaiandru.“   
\p
\v 12 Ja Jesus Godaia pungani wirina wonti, ja Nulu pratjana narrana wonti, tanali jinkimalina wonti ja burungankana wonti Godaia pungani, ja mardatandrakaritjimalkanietjaia kurli ja mulapara burungankanietjaia ngamani piri Nulu kokulterkibana wonti;   
\p
\v 13 Ja Nau tanangu jatana wonti: „Dakanala parai: Punga ngakani tanali ngatjini punga dikananto; ja jura ninaia watawatali maninietjaia minka ngankala wapaia.“   
\p
\v 14 Ja kana butju ja tjunduru nunkangu Godaia pungani wokarana wonti, ja Nulu tanana tepi ngankana wonti.   
\p
\v 15 Priesta pirnali ja jaura jinkinietjali jenia pirnala, Nulu ngankanani najina wonti, ja bakana kupa worana Godaia pungani maritjinani ja jatanani: „Hosianna Davidani ngatamurani!“ tana kuterina wonti,   
\p
\v 16 Ja nunkangu jatana wonti: „Jundru ngarai, mina tanapini jatai?“ Jesus tanangu jatana wonti: „Kau, jura wata warapanala: Kupa wakawaka ja ngamatapanietja manandru jundru jurakokananto ngankingana warai?“   
\p
\v 17 Ja Nulu tanana worarana wonti ja ngurandru wapana wonti Bathania nguraia ja naka tinkani turarana wonti.   
\p
\v 18 Tankubana palkara, Nau nguraia tikana, Nau mauali nganana wonti.   
\p
\v 19 Ja Nulu tandraia nindri kulno paltuni najina wonti ja nunkangu wokarana wonti, ja Nulu nunkangu panila mankamankana wonti, windri talpa; ja Nau nunkangu jatana wonti: „Ngurali wata morla jinkangu tandra punkaiatinimai.“ Ja nurujeli tandraia nindri mujarina wonti.   
\p
\v 20 Ja milieli nunkanali jenia najina, tana ngaruparana wonti, ja jatana wonti: „Worderu nurujeli nauja tandraia nindri mujarina warai?“   
\p
\v 21 Jesujeli kalabana wonti ja tanangu jatana wonti: „Morlalu ngani jurangu jatai: Jura morlalu ngundrana ngamalkanani ja wata mangangankanani, ngadani jura wata windri jenia tandraia nindrini ngankala nganai; bakana jura nunkangupini mardawonpani jatanani: «Dukarateriamai ja ngapa pirnani worateriamai», jenia morlalu pantjila nganai.   
\p
\v 22 Ja pratjana, mina jura ngatjinani juranani ngatjiai ja morlalu ngundrai, jura jenia manila nganai.“   
\p
\v 23 Ja Nau Godaia pungani wokarana wonti ja ngujangujara jinkina wonti. Ja nunkangu Priesta pirna ja kana wolaraia pinaru wokarana wonti ja jatana wonti: „Mina ngurulali jundru jenia ngankai, ja warle jinkangu ninapini ngurula jihkina warai?“   
\p
\v 24 Jesujeli kalabana wonti ja tanangu jatana wonti: „Bakana ngato jurana jaura kulno jakalkala nganai; jura ngakangu jenia jatanani, bakana ngani jurangu jatala nganai, mina ngurulali ngato jenia ngankai.   
\p
\v 25 Johannini multibanila, wodajerindru nau nganana wonti: Pariwilpandru kara kanandru kara?“ Tanali tjurujeli ngundrana wonti, ja jatana wonti: „Ngaiani jatanani, «pariwilpandru,» Nauja ngaianingu jatala nganai: Minandru jura nunkangu wata morlalu ngundrana wonti?   
\p
\v 26 Ngaiani jatanani, «kanandru,» ngaiani kana wolarandru japali nganananto, ngangau tanali marapujeli Johannes Propheta patai.“   
\p
\v 27 Ja tanali Jesungu kalabana wonti ja jatana wonti: „Ngaiani ko.“ Nau bakana tanangu jatana wonti: „Bakana ngani jurangu wata jatai, mina ngurulali ngato jenia ngankai.   
\p
\v 28 Mina jura ngundrai? Kana kulnujeli ngatamura mandru ngamalkana wonti, ja nau ngoperalani wokarana wonti ja jatana wonti: «Ngatamurajai, wapau, ja karari ngankau ngakani wain maruni.»   
\p
\v 29 Nulu kalabana wonti ja jatana wonti: «Ngato wata ngantjai.» Ngadani nau burkaljerina wonti ja wapana wonti.   
\p
\v 30 Nau ngadalani wokarana wonti ja nunkangu jeribaka jatana wonti. Nulu kalabana wonti ja jatana wonti: «Kau, kaparajai,» ja wata wapana wonti.   
\p
\v 31 Warle pudlangundru ngaperaia jertapaterina ngankana wonti?“ Tana jatana wonti: „Ngoperalali.“ Jesus tanangu jatana wonti: „Morlalu ngani jurangu jatai: Mardatandrakampanietja ja palakantji jurangu ngopera Godaia mililani wirila nganai.   
\p
\v 32 Ngangau Johannes jurangu wokarana wonti talkulaia paltuni ja jura nunkangu wata morlalu ngundrana wonti; mardatandrakampanietjali ja palakantjieli nunkangu morlalu ngundrana wonti. Ja jura jenia najina, wata ngadani madlentjandru karitjina wonti, nunkangu morlalu ngundrala.   
\p
\v 33 Jeribaka jaura kulno morla ngaranau: Kana kulno punga ngamalkanietja nganana wonti, nulu wain maru kurana wonti, ja pita terkibana karitjina wonti, ja wain nankani kutu mandrani bakuna wonti, ja punga wutju wotina wonti, ja nina marunajinajibanietja worangu worarana wonti, ja wapana wonti worita.   
\p
\v 34 Tandraia miljaru matja karakara nganana, nulu mili nunkani wain maru najinajibanietja worangu jinpana wonti, tanali tandra nunkani manijiribananto.   
\p
\v 35 Ja wain maru najinajibanietjali mili nunkani patana wonti, ja kulno nandrana wonti, kulno nari ngankana wonti, kulno mardali dakana wonti.   
\p
\v 36 Nakaldra nulu mili nguru jinpana wonti morla tanangu ngoperalani, ja tanali tanangu jeribaka ngankana wonti.   
\p
\v 37 Ngadani nulu ngatamura kunakulno jinpana wonti ja jatana wonti: Tana ngakani ngatamurani warawararila nganai.   
\p
\v 38 Wain maru najinajibanietja worali ngatamura nunkani najina, tana ngankamalina wonti: Naupini maratunkaia; kaparanau, ninaia ngaiana naria nandrananto maratunka nunkani ngaianani nganananto.   
\p
\v 39 Ja tanali nina patana wonti, ja nina wain marundru narrana wonti, ja naria nandrana wonti.   
\p
\v 40 Wain maruja kapara wokaranani, mina nulu tanangupara wain maru najinajibanietja worangu ngankala nganai?“   
\p
\v 41 Tana nunkangu jatana wonti: „Nulu tanana madlentjietja madlentji taribala nganai, ja nulu wain maru wain maru najinajibanietja nguruni jinkila nganai, tanali nunkangu tandra jinkinanto miljaru tananani.“   
\p
\v 42 Jesus tanangu jatana wonti: „Jura wata warapanala jaurani: Naupini marda, nina wotinietjali worana wonti, nau marda buru pantjina wonti. Kaparandru nau jenia pantjina wonti, ja ngaianangu milkini ngaruparana pirna nganai?   
\p
\v 43 Jendrania ngani jurangu jatai: Jurangundru Nulia Godaia milila manila nganai, ja kana wolara nguruni jinkila nganai, tanalipini tandra nunkani mandrai.   
\p
\v 44 Ja worana nunkangupini mardani puriai, nina nulu nankanankala nganai; worangu nau marda purila nganai, ninapini nulu turara ngankala nganai.“   
\p
\v 45 Ja Priesta pirnali ja Pharisaiali jeribaka jaura nunkani matja ngarana, tanali ngujamana wonti, Nau tanangundru jatai.   
\p
\v 46 Ja tanali wontjana wonti nina patala, windri tana japali nganana wonti kana wolarandru, ngangau tanali nina Propheta patana wonti.   
\c 22  
\lit (Ngantjani‐jaura G. D. 20. Trinitatis.)  
\p
\v 1 Ja Jesujeli kalabana wonti ja nakaldra jeribaka jaurali tanangu kaukaubana wonti ja jatana wonti:   
\p
\v 2 „Pariwilpaia milila mitaia kapara jeribaka nganai, nulu noapatamalini buka ngankingana wonti nunkani ngatamuraia.   
\p
\v 3 Ja nulu mili worana nunkani jinpana wonti kamaneli karkala noapatamalini bukaia ja tana delkina wonti.   
\p
\v 4 Nakaldra nulu mili nguru jinpana wonti ja jatana wonti: «Kamanelini jatanimai: Mai, buka ngakani ngato matja ngankingana, nganti pirna ngakani ja nganti manipirna ngato nandrana ja pratjana ngankingana warai; kaparanau noapatamalini bukaia.»   
\p
\v 5 Ja tanali bulu ngarana wonti ja wapana wonti, kulno mitaia nunkanaia, ja kulno ngankanaia nunkanaia;   
\p
\v 6 Palpali mili nunkani patana wonti ja tanana ngirkibana wonti ja naria nandrana wonti.   
\p
\v 7 Mitaia kaparali jenia ngarana, nau tiri pantjina wonti ja mili wolara nunkani jinpana wonti ja tanapini naria nandranietja nandrana wonti, ja ngura tanani nulu japina wonti.   
\p
\v 8 Ngadani nau milini nunkanani jatana wonti: «Noapatamalini buka ngato matja ngankingana, windri kamaneli wora wata talku nganai nunkanaia.»   
\p
\v 9 Ngangau palto kunarkuja wapanau, ja noapatamalini bukaia karkanimai pratjana, jura mankamankala nganai.   
\p
\v 10 Ja tana mili wapana wonti paltuni, ja tanali pratjana kampana wonti, tanana matja mankamankana, madlentji ja ngumu. Ja noapatamalini punga manamiririna wonti kamanelieli.   
\p
\v 11 Ja mitaia kapara wirina wonti kamaneli najinajibala, ja nulu naka najina wonti kana kulno noapatamalini kati pani.   
\p
\v 12 Ja nau jatana wonti nunkangu: «Kamaneliai, worderu jidni ninkida wirina warai noapatamalini kati pani?» Ja nau ngapurina wonti.   
\p
\v 13 Mitaia kapara milini nunkanani jatana wonti: «Ninaia mara ja tidna dupudupu ngankanau, ja ninaia patanau, ja woranimai ngalpuru pirnaia; naka nauja pirna ngirikidala nganai ja mana katakatangala nganai.»   
\p
\v 14 Ngangau marapu matja karkana ja windri ngalje kalkalkana.“   
\b  
\lit (Ngantjani‐jaura G. D. 23. Trinitatis.)  
\p
\v 15 Ngadani Pharisaia wapana wonti ja ngankamalina wonti, nina jaurali mintieli jeribaka patala.   
\p
\v 16 Ja tanali tanani ja Herodini mili nunkangu jinpana wonti ja jatana wonti: „Ngujangujara jinkinietjajai, ngaiani milkila jidni morlalu nganai, ja Godaia paltundru jundru ngujangujara morlalu jinkiai, ja jidni manubaku nganai kanani, ngangau jundru wata kana mudla ngundrai.   
\p
\v 17 Ngaianingu jatau: Mina jundru ngundrai, jenia talku nganai mitaia kaparani kalala jinkila kara, pani kara?“   
\p
\v 18 Jesujeli madlentji tanani matja ngujamana, Nau jatana wonti: „Minandru jura ngana wontjai, jura kana jeljujelju?   
\p
\v 19 Kalalaia mardatandra ngakangu wondralkanau.“ Tanali nunkangu mardatandra kulno wondralkana wonti.   
\p
\v 20 Ja Nau jatana wonti tanangu: „Waninunkani mudla naupini nganai, ja mina jaura dirkalani parai?“   
\p
\v 21 Tana nunkangu jatana wonti: „Mitaia kaparaia.“ Nau tanangu jatana wonti: „Jinkianau kaparaia poto kaparani ja Godaia poto Godani!“   
\p
\v 22 Tanali jenia matja ngarana, tana pirna ngaruparana wonti, ja nina worarana wonti ja wapana wonti.   
\b  
\p
\v 23 Nunkangupini ditjini bakana Sadducaia wokarana wonti, tanaia jatai: „Narila wata morla jiritjila nganai;“ ja tanali nina jakalkana wonti,   
\p
\v 24 Ja tana jatana wonti: „Ngujangujara jinkinietjajai, Moses jatana wonti: Kana kulno kupa pani palinani, ngatatajeli nunkanali noa nunkani patananto ja nejini nunkanani ngatamura jiritjibananto.   
\p
\v 25 Ngaianingu neji mara wora ja mandru nganana wonti, ja ngoperalali noa patana wonti ja palina wonti; ja ngangau nulu ngatamura pani ngamalkana, nulu noa nunkani ngatatani nunkanani worarana wonti.   
\p
\v 26 Nunkangu jeribaka bakana mandrulali ja parkulali mara wora ja mandrujelu.   
\p
\v 27 Pratjaterinani ngadani bakana widla palina wonti.   
\p
\v 28 Terkakani ditjini, waninunkani noa mara wora ja mandrundru nani nganala nganai, ngangau tanali marapujeli nana ngamalkana wonti?“   
\p
\v 29 Jesujeli kalabana wonti ja tanangu jatana wonti: „Jura tjautjau ngundrai, ngangau jura jaura worana ja Godaia ngurula wata ngujamai.   
\p
\v 30 Ngangau terkakani ditjini tanali wata noa patai ja wata noa pantjiai, a‐ai, tana Godaia angelani pariwilpani jeribaka nganala nganai.   
\p
\v 31 Nari jiritjinandru jura wata warapanala, mina Godali jurangu kaukaubana wonti, Nauja jatana wonti:   
\p
\v 32 «Ngani nganai Abrahamani Goda ja Isaakani Goda ja Jakobani Goda?» Goda wata naria Goda nganai, a‐ai, tepia.“   
\p
\v 33 Ja kana wolarali jenia matja ngarana, tana nunkani ngujangujarandru pirna ngaruparana wonti.   
\lit (Ngantjani‐jaura G. D. 18. Trinitatis.)  
\p
\v 34 Pharisaiali matja ngarana, Nulu Sadducaia ngapu ngankana warai, tana jerra jurborina wonti.   
\p
\v 35 Ja kulnujeli tanangundru, jirijiribani jaura jinkinietjali, nina jakalkana wonti ja wontjana wonti:   
\p
\v 36 „Ngujangujara jinkinietjajai, wodanau jirijiribani jauraia kapara nganai jirijiribani jaurani?“   
\p
\v 37 Jesus nunkangu jatana wonti: „Jundru Goda, Kapara jinkani, ngantjamai ngarali jinkanali mungarali jinkanali ja manujeli jinkanali.   
\p
\v 38 Naupini jirijiribani jauraia ngoperala ja kapara nganai;   
\p
\v 39 Ja kulno nunkangu jeribaka nganai: Ngurala jinkani ngantjamai, jidna munta jeribaka.   
\p
\v 40 Pudlangupini jirijiribani jaurani jirijiribani jaura ja Prophetaia pratjana parai.“   
\p
\v 41 Jendranguta Pharisaia mapaterina wonti, ja Jesujeli tanana jakalkana wonti,   
\p
\v 42 Ja jatana wonti: „Mina jura ngundrai Christungundru, wani Ngatamura Nauja?“ Tana jatana wonti nunkangu: „Davidani.“   
\p
\v 43 Nau tanangu jatana wonti: „Worderu Davidali Jaolali nina Kapara dikai, nau jatana wonti:   
\p
\v 44 «Kapara jatanala Kaparani ngakanani: Ngakangu ngunarani ngamana ngariau, ngato talpala jinkani jinkangu tidnani kuranantulu, tidnaparani piri jeribaka?»   
\p
\v 45 Davidali nina Kapara dikanani, worderu Nau nunkani ngatamura nganai?“   
\p
\v 46 Ja tana ngandandarina wonti nunkangu jaura kulno kalabala; ja wata kulnujeli morla wontjana wonti nina jakalkala nunkangupini ditjindru.   
\b  
\c 23  
\p
\v 1 Ngadani Jesujeli kana wolarani ja milini nunkanani kaukaubana wonti,   
\p
\v 2 Ja jatana wonti: „Mosini ngamani pirini jaura jinkinietja ja Pharisaia wora ngamai.   
\p
\v 3 Pratjana, mina tana jurangu jatai, jura ngamalkananto, jenia ngamalkanimai, ja ngankanimai; tanani ngankanani jeribaka wata ngankanimai, ngangau tana jatai, ja wata ngankai.   
\p
\v 4 Tanali bururu mati ja morla wondra workaworkamandrai ja kanani pilpirani kurai; windri tanali muntali wata ngantjai tanana mara ngalkieli patala.   
\p
\v 5 Tanani ngankana pratjana tanali ngankai, kanali tanana najinanto; tanali tjerapu maru ngankai ja katijelbi wirdi ngankai;   
\p
\v 6 Tanali ngantjai piri ngopera buka pirnani ja piri ngopera jaura pungani;   
\p
\v 7 Ja jaura murlali jinkimalini pirini, ja kanali tanana «Rabbi» dikananto.   
\p
\v 8 Tanali jurana wata «Rabbi» dikananto, ngangau Kulno jurani ngujangujara jinkinietja nganai, ja jura pratjana ngatata mara nganai.   
\p
\v 9 Ja wata kulno jurangundru ngaperi dikanimai mitani, ngangau Kulno Ngapari jurani nganai, Nauja pariwilpani.   
\p
\v 10 Tanali jurana wata ngujangujara jinkinietja dikananto, ngangau Kulno ngujangujara jinkinietja jurani nganai, Christus.   
\p
\v 11 Worana jurangundru morla pirna nganai, nauja jurani mili nganaiatimai.   
\p
\v 12 Warle pirna ngankateriai, nau waka pantjila nganai, ja warle waka ngankateriai, nau pirna pantjila nganai.   
\p
\v 13 Jakajai jurangu, jura jaura jinkinietja ja Pharisaia, jura kana jeljujelju! ngangau jura pariwilpaia milila ngandrawalkai kanani; ngangau jura munta wata wiriai, ja tana wirinani, jura ngandrawalkai wirinanto.   
\p
\v 14 Jakajai jurangu, jura jaura jinkinietja ja Pharisaia, jura kana jeljujelju! ngangau jura mangawaruja punga tajiai ja ngatjina wirdieli wondralkai; jendrangundruja jura kalala morla pirna manila nganai.   
\p
\v 15 Jakajai jurangu jura jaura jinkinietja ja Pharisaia, jura kana jeljujelju! jura panto pirnani ja mita mujani wirariai Juda kanaia kamaneli kulno ngankala, ja nau matja pantjina, jura nina turuja kupa ngankai pota mandru morla pirna jurangu.   
\p
\v 16 Jakajai jurangu, jura paltowondranietja butju! jura jatai: Warle Godaia pungani jaura morlalu kurai, jenia panila nganai; ja warle Godaia pungaia marda maraljani jaura morlalu kurai, nau bakuwilpa nganai.   
\p
\v 17 Jura kana patipati ja butju! mina morla pirna nganai, marda maralje kara, Godaia punga kara, nulu nina marda maralje kulikiri ngankai?   
\p
\v 18 Ja: Warle jaura morlalu kurai Altarani, jenia panila nganai; warle jaura morlalu kurai potuni, nau nunkangu parai, nau bakuwilpa nganai.   
\p
\v 19 Jura kana patipati ja butju! mina morla pirna nganai, poto kara, Altara kara, nulu poto kulikiri ngankai?   
\p
\v 20 Warle Altarani jaura morlalu kurai, nulu jaura morlalu kurai nunkangu ja pratjana nunkangu paranani;   
\p
\v 21 Ja warle jaura morlalu kurai Godaia pungani, nulu jaura morlalu kurai nunkangupini ja nunkangu, Nauja mandrani ngamai;   
\p
\v 22 Ja warle jaura morlalu kurai pariwilpani, nulu jaura morlalu kurai Godaia ngamani pirini, ja nunkangu, Nauja nunkangu ngamai.   
\p
\v 23 Jakajai jurangu, jura jaura jinkinietja ja Pharisaia, jura kana jeljujelju! ngangau jura manjura ja kalumba ja paua puntibai ja buru kulno marapratjanandru Godani jinkiai, ja jirijiribani jaura mati: Kalala ja kalumiltjamiltjarina ja morlalu ngundrana jura worarai. Tananapini jura ngankananto ja jenia wata worarananto.   
\p
\v 24 Paltowondranietja butju! jura wajluru ngandrawalkai ja Camuli julkai.   
\p
\v 25 Jakajai jurangu, jura jaura jinkinietja ja Pharisaia, jura kana jeljujelju! jura koko ja pirra tokuni kulikiri ngankai, ja mandrani puturu ja ngurdi nganai.   
\p
\v 26 Pharisaia butjujai! ngopera koko ja pirra mandrani kulikiri ngankamai, jeruja bakana toku kulikiririnanto.   
\p
\v 27 Jakajai jurangu, jura jaura jinkinietja ja Pharisaia, jura kana jeljujelju! ngangau jura wiribani nariwonpa jeribaka nganai, tanana palarani ngumu najiai ja mandrani narimoku ja murumuru manamiri nganai.   
\p
\v 28 Jeruja bakana jura, palarani jura talku wondrateriai kanani, ja mandrani jura jeljujelju ja madlentji manamiri nganai.   
\p
\v 29 Jakajai jurangu, jura jaura jinkinietja ja Pharisaia, jura kana jeljujelju! ngangau jura Prophetaia nariwonpa ngankijiribai ja kana talkuja nariwonpa tjirkatjirkai,   
\p
\v 30 Ja jura jatai: Matja ngaiana ngaperaia ngaiananaia ditjini ngamanani, ngaiana wata tanani kamaneli Prophetaia kumarani ngananani;   
\p
\v 31 Jeruja jura muntali morlalu kurai, jura Propheta nari nandranietjaia ngatamura nganai.   
\p
\v 32 Ja jura ngaperaia juranaia koko manamiri ngankanau!   
\p
\v 33 Jura tjutju ja wiparaia kuparu worajai! worderu jura turuja kalalandru puntila nganai?   
\lit (Ngantjani‐jaura Jesuja kupa dankani ditjini mandrulani ja Stephanani ditjini.)  
\p
\v 34 Mai, jendrania ngato jurangu Propheta worana ja kana kiri ja jaura jinkinietja worana jinpai; tanangundru jura palpa naria nandrala nganai ja palpa kunarkuni katibala nganai, ja tanangundru palpa jura jaura pungani juranani nandrala nganai ja ngura kulnundru ngura kulnuja tanangu tirikaripaterila nganai.   
\p
\v 35 Ngangau jurangu wokarananto kumari talku pratjana, jenia mitani nangana, Abel talkuja kumarandru Zachariani, Barachiani ngatamuraia kumaranilu, nina jura Godaia pungani ja Altarani terti naria nandrana wonti.   
\p
\v 36 Morlalu ngani jurangu jatai: Jenia pratjana nunkangupini ngujani wokarala nganai.   
\p
\v 37 Jerusalemiai, Jerusalemiai, jundru Propheta worana nandrai ja mardali dakai tanana jinkangu jinpanala; worderuntja pota ngato kupa jinkani jertapaterina wonti mapala, worderu warugati ngandrieli nankani wolka nankani ngaruni mapai, ja jura wata ngantjana wonti.   
\p
\v 38 Mai, punga jurani ngurawalpa parala nganai.   
\p
\v 39 Ngangau ngani jurangu jatai: Kararindru jura ngana wata morla najila nganai, jura jatanantulu: Ngaiani jurakokai ninaia, Nauja wokarai Kaparaia talani!“   
\b  
\c 24  
\p
\v 1 Ja Jesus dunkana wonti ja Godaia pungandru wapana wonti; ja mili nunkani nunkangu wokarana wonti, nunkangu Godaia punga wotini wondrala.   
\p
\v 2 Jesus tanangu jatana wonti: „Jura najiai jenia pratjana? Morlalu ngani jurangu jatai: Wata marda kulno marda kulnuni parala nganai ninaia tanali wata wokaribala nganai?“   
\p
\v 3 Nau maninindri mardawonpani ngamana ngarina, mili nunkani nunkangu pilki wokarana wonti ja jatana wonti: „Ngaianingu jatau, winta jenia pantjila nganai? Ja mina jinkani tikani ja mita maruja mudani malka nganai?“   
\p
\v 4 Ja Jesujeli kalabana wonti ja tanangu jatana wonti: „Ngamalkaterianau, kulnujeli jurana karkarkaiati.   
\p
\v 5 Ngangau marapu talani ngakanani wokarala nganai ja jatala nganai: «Ngani Christus nganai;» ja tanali marapu karkarkala nganai.   
\p
\v 6 Jura ngarala nganai tirimalina ja tirimalinani pinti; ngamalkaterianau ja wata japali pantjianau; ngangau jenia pratjana pantjinanto, ja mudani jendranguta wata kantji nganala wapaia.   
\p
\v 7 Ngangau kana wolara tiriterkakala nganai kana wolarani ja mitaia kaparaia milila mitaia kaparaia mililani ja maua pirna ja muntja pilki ja pilki nganala nganai, ja mita wiltjiwiltjila nganai mankamanka.   
\p
\v 8 Jenia pratjana ketjaketjanaia wonini nganai.   
\p
\v 9 Ngadani tanali jurana ngulkujeli jinkila nganai ketjaketjananto, ja jurana nari ngankala nganai, ja kana wolara pratjana jurangu kalakalarila nganai ngakani talandru.   
\p
\v 10 Ja ngadani marapu kalakalarila nganai ja ngulkuterkalkijiribamalila nganai ja kalakalarilkijiribamalila nganai.   
\p
\v 11 Ja Jedikantji‐Propheta marapu terkakala nganai, ja tanali marapu karkarkala nganai.   
\p
\v 12 Ja ngangau delkina pirna pirnarila nganai, kana marapuja ngantjani maltirila nganai.   
\p
\v 13 Worana wonki ngamai ngadajelu, nulu tepi pirna manila nganai.   
\p
\v 14 Ja tanali ninapini ngantjani jaura mililandru mita maruni kaukaubala nganai, kana warupotuni malka nganananto, ja ngadani mudani wokarala nganai.   
\lit (Ngantjani‐jaura G. D. 25. Trinitatis.)  
\p
\v 15 Jura «duljadulja‐tjautjau» najinani, nunkangundru Prophatali Danielali kaukaubana wonti, nau piri kulikirini terkai, — warle jenia warapai ngundraiatimai—.   
\p
\v 16 Ngadani tana Judaia mitala mardawonpaia japa mindriatinimai!   
\p
\v 17 Worana punga mangatandrani nganai, wata ngarina tikaiatimai, nunkani pungandru minakulno manila,   
\p
\v 18 Ja worana maruni nganai, wata karitjina tikaiatimai kati nunkani manila.   
\p
\v 19 Jakajai tanangu mandrantjani ja ngama jinkinietjani tanangupini ditjini!   
\p
\v 20 Ngatjianimai jurani japa mindrini wata pantjinanto kilpani kara, Sabbat ditjini kara.   
\p
\v 21 Ngangau ngadani ketjaketjana pirna nganala nganai, worderu mitaia woninandru wata nganana wonti kararielu ja bakana wata morla nganala nganai.   
\p
\v 22 Ja tanapara ditji wata wordurinani, kana pani tepi pirna ngamanani; windri kanandru, tanana Nulia kalkalkana wonti, tanapara ditji wordurila nganai.   
\p
\v 23 Jendranguta kulno jurangu jatanani: Mai, ninkida Christus nganai kara, jerra Nauja, jenia wata morlalu ngundranimai.   
\p
\v 24 Ngangau Jedikantji‐Christus wora ja Jedikantji‐Propheta wora terkakala nganai, ja tanali malka pirna ja pirnala jinkila nganai; ngangau tana ngurunguru ngananani, tanali bakana karkarkananto, tanana Nulia kalkalkanala.   
\p
\v 25 Mai, ngani jurangu jenia ngopera jatana warai.   
\p
\v 26 Tana jurangu jatanani: Mai, pitarani nau, wata wapanau; mai, nau punga mandrani, wata morlalu ngundranau.   
\p
\v 27 Ngangau worderu talara praitji dunkai tiriwandru ja mintjiai jendakarajelu, jeruja bakana Kanaia Ngatamuraia tikani nganala nganai.   
\p
\v 28 Ngangau woderi pundupundu parai, jerra kukunka jurboriai.   
\b  
\p
\v 29 Tanangupini ketjaketjani ditjini ngadani nurujeli ditji pirna ngalpuru pantjila nganai, ja pirali praitji nunkani wata jinkila nganai, ja ditji waka wora pariwilpandru purila nganai, ja pariwilpaia ngurula wiltjiwiltjila nganai.   
\p
\v 30 Ja ngadani Kanaia Ngatamuraia malka pariwilpani wondraterila nganai, ja ngadani kana wolara mitani juajuangala nganai, ja tanali Kanaia Ngatamura talara palkujeli pariwilpalali wokaranani najila nganai ngurunguru ja pirna.   
\p
\v 31 Ja Nulia angela worana nunkani jinpala nganai wima kokujeli ngaiala pirnali, ja tanali mapala nganai, tanana Nulia kalkalkanala, watara mandru ja mandrundru pariwilpaia wondiri kulnundru wondiri kulnujelu.   
\p
\v 32 Tandra nindrindru jeribaka malka kiririanimai; ngunanguna nunkani matja kuljakuljarina ja talpa matja punkana, jura ngujamai woldrakanja karakara nganai.   
\p
\v 33 Jeruja bakana jura ngujamananto, jura jenia pratjana najinani, nau manani karakara nganai.   
\p
\v 34 Morlalu ngani jurangu jatai: Naupini nguja wata mudala nganai jenia pratjana pantjinantulu.   
\p
\v 35 Pariwilpa ja mita maru mudala nganai; jaura ngakani wata mudala nganai.   
\p
\v 36 Ninapini miljaru ja ditji wata kulnujeli ngujamai, bakana wata angelali pariwilpani, a‐ai, windri Ngaperali ngakanali.   
\p
\v 37 Worderu Noani ditjini, jeruja bakana Kanaia Ngatamuraia tikani nganala nganai.   
\p
\v 38 Ngangau worderu tana ngarimataia ditjia woljaia ngamana wonti; tanali tajina wonti ja tapana wonti, noa patana wonti ja noa pantjina wonti nunkangupini ditjielu, jendranguta Noa bota pirnani wirina wonti;   
\p
\v 39 Ja tanali wata ngundrana wonti ngarimata wokaranantulu ja pratjana tundribanantulu; jeruja bakana Kanaia Ngatamuraia tikani nganala nganai.   
\p
\v 40 Jendranguta mandru maruni nganala nganai, kulno Nulia patala nganai, ja kulno Nulia worarala nganai;   
\p
\v 41 Widla mandrujeli turara ngankala nganai marda watieli, nana kulno Nulia patala nganai, ja nana kulno Nulia worarala nganai.   
\p
\v 42 Tepi ngamanau, ngangau jura wata milkila, mina ditjini Kapara jurani wokarala nganai.   
\p
\v 43 Jenia ngujamanau! Punga ngamalkanietja milkila ngananani mina ditji tinkani kurikantji wokarai, nau tepi ngamala nganai ja ngandrawalkala nganai, nau wata pungani nunkanani wirinanto.   
\p
\v 44 Jendrania bakana jura ngankingaterianau! Ngangau ditji kulnuni, nina jura wata ngundrai, Kanaia Ngatamura wokarala nganai.   
\p
\v 45 Worana mili talku ja kiri nganai, nina kaparali najinajibanietja milini nunkanani kuranala, nulu tanangu buka ditji talkuni jinkinanto?   
\p
\v 46 Murlali pirna jenipara mili, nina kaparali nunkanali, nau wokarana tikanani, jeruja ngankanani mankamankala nganai.   
\p
\v 47 Morlalu ngani jurangu jatai: Nulu nina kapara kurala nganai nunkani poto pratjanani.   
\p
\v 48 Naupara mili madlentji ngarali nunkanali jatanani: Kapara ngakani kalkai wokarala,   
\p
\v 49 Ja nulu woninani kamaneli nunkani nandrala, ja muntali nau tajinani ja tapanani tapanietjali jela:   
\p
\v 50 Jenipara milia kapara wokarala nganai miljaru kulnuni, nina nulu wata ngundrai, ja ditji kulnuni, nina nulu wata ngujamai,   
\p
\v 51 Ja nina terti tjelapalkala nganai, ja nunkangu kalala nunkani kana jeljujelju jeribaka kurala nganai; naka tana pirna ngirikidala nganai ja mana katakatangala nganai.“   
\c 25  
\lit (Ngantjani‐jaura G. D. 27. Trinitatis.)  
\p
\v 1 Ngadani pariwilpaia milila ngameri marapratjana jeri nganala nganai, tanali praitji tanani manina wonti ja wapana wonti noangantjanipirnani mandurila.   
\p
\v 2 Ja mara wora tanangundru kiri nganana wonti ja mara wora patipati.   
\p
\v 3 Patipatieli praitji tanani manina wonti, ja tanali wata gildi padakana wonti.   
\p
\v 4 Kirieli gildi manina wonti kokujeli tananali praitjanto.   
\p
\v 5 Ngangau noangantjanipirna ngujawakaterina wonti, tana pratjana jindina wonti ju mukaturarana wonti.   
\p
\v 6 Tinka tertini miritja pirna nganana wonti: „Mai, noangantjanipirna wokarai, wapanau nunkangu mandurila!“   
\p
\v 7 Jendranguta jenipara ngameri pratjana jiritjina wonti, ja praitji tanani tjirkatjirkana wonti.   
\p
\v 8 Tana patipati kirini jatana wonti: „Ngaianingu jinkianau jurani gildindru, ngangau praitji ngaianani palila wapaia.“   
\p
\v 9 Kirieli kalabana wonti ja jatana wonti: „A‐ai, pani‐riati ngaianingu ja jurangu; wapanau jinkimalinietjani ja jurangu burungankanau.“   
\p
\v 10 Tana matja wapana burungankala, noangantjanipirna wokarana wonti; ja tana matja ngankingaterina, nunkangunto noapatamalini bukaia wirina wonti, ja tanali mana nguru ngankana wonti.   
\p
\v 11 Ngadani bakana ngameri nguru wokarana wonti ja jatana wonti: „Kaparajai, Kaparajai, ngaianingu wilpa ngankau!“   
\p
\v 12 Nulu kalabana wonti ja jatana wonti: „Morlalu ngani jurangu jatai: Ngato jurana wata ngujamai.“   
\p
\v 13 Jendrania tepi ngamanau, ngangau jura miljaru ja ditji wata ngujamai, nunkangupini Kanaia Ngatamura wokarala nganai.  
\b  
\p
\v 14 Worderu kana kulno, nau jertapaterina wonti mita tulaia palkala, mili nunkani karkana wonti, ja tanangu poto nunkani jinkina kurana wonti.   
\p
\v 15 Ja kulnuni nulu mardatandra pirna mara wora, ja kulnuni mandru, ja kulnuni kulno jinkina wonti, tanani ngurula pilki ja pilkindru; ja nau nurujeli palkana wonti.   
\p
\v 16 Naupini, nulu mardatandra pirna mara wora matja manina, wapana wonti ja jinkimalina wonti, ja nulu mardatandra pirna mara wora morla patana wonti.   
\p
\v 17 Nunkangu jeribaka bakana nulupini, nulu mandru matja manina, mandru morla patana wonti.   
\p
\v 18 Naupini, nulu kulno matja manina, wapana wonti, ja kutu bakuna wonti mitani, ja kaparaia nunkanaia mardatandra kurukurumalkana wonti.   
\p
\v 19 Ditji marapuni ngadani tanapini milia kapara tikana wonti, ja tanangunto windamana wonti.   
\p
\v 20 Ja naupini, nulu mardatandra pirna mara wora maninala, wokarana wonti ja mardatandra pirna mara wora morla padakana wonti, ja jatana wonti: „Kaparajai, mardatandra pirna mara wora jundru ngakangn jinkinala; najiau, mardatandra mara wora morla ngato tanangu ngokana warai.“   
\p
\v 21 Kapara nunkani nunkangu jatana wonti: „Matja, jidni mili ngumu ja talku, jidni talku nganana warai ngaljengaljeni, ngato jidnana kapara kurala nganai marapuni: Wiriau Kaparaia jinkanaia mankinani.“   
\p
\v 22 Bakana naupini, nulu mardatandra pirna mandru maninala, wokarana wonti ja jatana wonti: „Kaparajai, mardatandra pirna mandru jundru ngakangu jinkinala; najiau, mardatandra pirna mandru morla ngato pudlangu ngokana warai.“   
\p
\v 23 Kapara nunkani nunkangu jatana wonti: „Matja, jidni mili ngumu ja talku, jidni talku nganana warai ngaljengaljeni, ngato jidnana kapara kurala nganai marapuni: Wiriau Kaparaia jinkanaia mankinani.“   
\p
\v 24 Bakana naupini, nulu mardatandra kulno maninala, wokarana wonti ja jatana wonti: „Kaparajai, ngato jidna ngujamanala, jidni kana ngurunguru nganai, jundru naka kampai, woderi jundru wata jaupanala, ja mapai, woderi jundru wata tarauanala;   
\p
\v 25 Ja ngangau ngani japali, ngani wapanala ja mardatandra pirna kulno jinkani mitani kurukurumalkanala: Najiau ninkida jinkani.“   
\p
\v 26 Kaparali nunkanali kalabana wonti ja nunkangu jatana wonti: „Jidni mili madlentji ja nguja, jidni milkila ngananala, ngato naka kampai, woderi ngato wata jaupanala, ja mapai, woderi ngato wata tarauanala;   
\p
\v 27 Jundru mardatandra ngakani mardatandrakaritjimalkanietjani jinkinanto, ja ngani wokaranani, ngato mardatandra ngakani kalalanto maninanto.   
\p
\v 28 Jeruja mardatandra pirna nunkangundru manianau, ja nunkangupini jinkianau, nulia mardatandra pirna marapratjana ngamalkai.   
\p
\v 29 Ngangau nunkangu, nulu ngamalkai, tanali jinkila nganai, ja nulu morla marapu ngamalkala nganai; nunkangundru, nulu wata ngamalkai, tanali bakana jenia manila nganai, mina nulu ngamalkai.   
\p
\v 30 Ja nina mili nguja ngalpuru pirnaia woranau; naka tana pirna ngirikidala nganai ja mana katakatangala nganai.“   
\lit (Ngantjani‐jaura G. D. 26. Trinitatis.)  
\p
\v 31 Kanaia Ngatamura wokaranani pirnalani nunkanani ja angela kulikiri pratjana nunkangunto, jendranguta Nauja ngamana ngarila nganai pirnalaia nunkanaia ngamani pirini,   
\p
\v 32 Ja tanali kana wolara warupoto nunkangu mapala nganai. Ja Nulia tanana puntibala nganai, worderu tjipi ngamalkanietjali tjipi puntibai tjipi ngaperandru,   
\p
\v 33 Ja tjipi Nulia ngunarani nunkanani terkibala nganai, ja tjipi ngaperi worangantjuni.   
\p
\v 34 Ngadani Kapara jatala nganai tanangu ngunarani nunkanani: „Kaparanau, jurana Ngaperali ngakanali jurakokai, ja mililu maratunka manianau, nina Nulia jurangu ngankingana wonti mita pantjimanandru.   
\p
\v 35 Ngani mauali nganana warai, jura ngana jerto ngankana warai; ngani tertieli nganana warai, jura ngana kaljura ngankana warai; ngani tula nganana warai, jura ngana patana warai;   
\p
\v 36 Ngani balu nganana warai, jura ngakangu kati widmana warai; ngani muntja nganana warai, jura ngakangu wokarana warai; ngani kanjangari pungani ngamana warai, jura ngakangu wirina warai.“   
\p
\v 37 Ngadani kana talkujeli nunkangu kalabala nganai ja jatala nganai: „Kaparajai, winta ngaiani jidna maua najina warai, ja jidna jerto ngankana warai? terti kara, ja jidna kaljura ngankana warai?   
\p
\v 38 Winta ngaiani jidna tula najina warai ja jidna patana warai? balu kara, ja jinkangu kati widmana warai?   
\p
\v 39 Winta ngaiani jidna muntja kara, kanjangari pungani kara najina warai ja jinkangu wokarana warai?“   
\p
\v 40 Ja kaparali kalabala nganai ja jatala nganai tanangu: „Morlalu ngani jurangu jatai: Mina jura ngankana warai ngakani ngatata wakawaka kulnuni, jenia jura ngakangu ngankana warai.“   
\p
\v 41 Ngadani Nauja bakana jatala nganai tanangu worangantjuni: „Wapanau ngakangundru, jura madlentji ngankanietja, ngurali turuja, nina matja ngankingana kutjini ja angelani nunkanani.   
\p
\v 42 Ngani mauali nganana warai, ja jura ngana wata jerto ngankana warai; ngani tertieli nganana warai, ja jura ngana wata kaljura ngankana warai;   
\p
\v 43 Ngani tula nganana warai, ja jura ngana wata patana warai; ngani balu nganana warai, ja jura ngakangu wata kati widmana warai; ngani muntja ja kanjangari pungani nganana warai, ja jura ngakangu wata wokarana warai.“   
\p
\v 44 Ngadani bakana tanali nunkangu kalabala nganai ja jatala nganai: „Kaparajai, winta ngaiani jidna najina warai maua kara, terti kara, tula kara, balu kara, muntja kara, kanjangari pungani kara, ja wata mili jinkani nganana warai?“   
\p
\v 45 Ngadani Nulia tanangu kalabala nganai ja jatala nganai: „Morlalu ngani jurangu jatai: Mina jura wata ngankana warai tanangundru wakawaka kulnuni jura ngakangu bakana wata ngankana warai.“   
\p
\v 46 Ja tanapini wapala nganai ngurali kalalaia; ja kana talku ngurali tepia.  
\b  
\c 26  
\p
\v 1 Ja jendranguta Jesujeli jenia jaura pratjana matja mudana, Nau milini nunkanani jatana wonti:   
\p
\v 2 Jura milkila, ditji mandruni Passa wokarai, ja tanali Kanaia Ngatamura ngulkujeli jinkila nganai, nina kunarkuni katibananto.   
\p
\v 3 Jendranguta Priesta pirna ja jaura jinkinietja ja kana wolaraia pinaru jurborina wonti Priesta pirnaia pirini, tala nunkani Kaiphas.   
\p
\v 4 Ja tanali kurukuru warawarapana wonti Jesus kirieli patala ja nari ngankala.   
\p
\v 5 Tana jatana wonti: „Wata ditji pirnani, ngangau kana wolara juajuangaiati.“   
\p
\v 6 Jesus Bethania ngurani Simon kana gambalaia pungani matja wokarana,   
\p
\v 7 Widla kulno nunkangu wokarana wonti, nandru Alabaster koko gildi ngumu pirnanto ngamalkana wonti, ja nunkangu mangatandrani nangana wonti, Nau kurlini ngamanani.   
\p
\v 8 Milieli nunkanali jenia najina, tana junkarina wonti ja jatana wonti: „Minani jenia tintana?   
\p
\v 9 Ngangau nandruja jenia gildi kalala marapuja jinkinanto, ja wangiwangini bakujeli jinkinanto.“   
\p
\v 10 Jesujeli jenia ngujamana, Nau tanangu jatana wonti: „Minandru jura nanaia widla jupai? nandruja ngankana ngumu ngakangu ngankana warai.   
\p
\v 11 Ngangau milingeru jura kana wangiwangi jurangunto ngamalkai, ngana jura wata milingeru ngamalkai.   
\p
\v 12 Nandruja ninapini gildi ngakangu palkuni nangana, nandruja jenia ngankana warai ngana wiribala todinaia ngakanaia.   
\p
\v 13 Morlalu ngani jurangu jatai: Woderi tanali paruparu ninapini ngantjani jaura kaukaubala nganai mita maruni, naka tanali bakana jatala nganai, mina nandruja ngankana warai, nanaia ngundrananto.“   
\p
\v 14 Jendranguta marapratjana ja mandrundru kulno, tala nunkani Judas Ischariot, Priesta pirnaia wapana wonti.   
\p
\v 15 Ja jatana wonti: „Mina kalala jura jertapateriai ngakangu jinkila, ngato nina jurangu wontawontala nganai?“ Tanali nunkangu mardatandra 30 jinkina wonti,   
\p
\v 16 Nunkangundruka ditjindru nulu milingeru wontjana wonti nina wontawontala.   
\p
\v 17 Pulkurutjeribanibuka pani ditji ngoperalani mili wora Jesungu wokarana wonti ja nunkangu jatana wonti: „Wodaninkinaia jidni jertapateriai, ngaiani Passa kuparu jinkani ngankingananto tajila?“   
\p
\v 18 Nau jatana wonti: „Nguraia wapanau nunkanguka, ja nunkangu jatanau: Ngujangujara jinkinietja jatai: Ditji ngakani karakara nganai, pungani jinkanani ngato milintali Passa kuparu tajila nganai.“   
\p
\v 19 Ja milieli jeruja ngankana wonti worderu Jesujeli tanangu jirijiribana warai, ja Passa kuparu ngankingana wonti.   
\p
\v 20 Ja matja kalkaurarina, Nau kurlini ngamana ngarina wonti mili marapratjana ja mandrunto.   
\p
\v 21 Ja tanali tajina, Nau jatana wonti: „Morlalu ngani jurangu jatai: Jurangundru kulnujeli ngana wontawontala nganai.“   
\p
\v 22 Ja tana ngaurongauro pirna pantjina wonti, ja wonina wonti pilki ja pilki nunkangu jatala: „Ngani nauja nganai Kaparajai?“   
\p
\v 23 Nulu kalabana wonti ja jatana wonti: „Ngalinulu mara kurai pirrani, nulu ngana wontawontala nganai.   
\p
\v 24 Kanaia Ngatamura wapai, worderu nunkangundru dakanala parai; jakajai nunkangupini kanani, nulia Kanaia Ngatamura wontawontala nganai. Nunkangupini kanani ngumu ngananala, nauja wata dankanala.“   
\p
\v 25 Judas, wontawontanietjali nunkanali kalabana wonti ja jatana wonti: „Ngani nauja nganai Rabbi?“ Nau nunkangu jatana wonti: „Jidni matja jatai.“   
\p
\v 26 Tanali tajinani, Jesujeli buka patana wonti ja ngurungutana wonti ja ninapini wokaribana wonti ja milini nunkanani jinkina wonti ja jatana wonti: „Patanimai ja tajianimai; naupini ngani palku nganai!“   
\p
\v 27 Ja Nulu koko patana wonti ja jurakokana wonti ja tanangu jinkina wonti ja jatana wonti: „Warupotujeli nunkangundru tapanimai!   
\p
\v 28 Ngangau naupina ngani kumari nganai Testamenta marraia, ninapini ngani marapuja nangateriai madlentji kalingala.   
\p
\v 29 Ngani jurangu jatai: Kararindru ngato wata morla nunkangupini waina nindri tandrandru tapala nganai nunkangupini ditjielu, ngato nina marra jurangunto tapala nganai Ngaperaia ngakanaia mililani.“   
\p
\v 30 Ja tana jurakokani wima matja jatana, tana maninindri mardawonpaia wapana wonti.   
\p
\v 31 Ngadani Jesus tanangu jatana wonti: „Jura pratjaterina nunkangupini tinkani ngakangu kintjakintjarila nganai, ngangau dakanala parai: Ngato ngamalkanietja nandrala nganai, ja tjipi ngami piltjaru nganala nganai.   
\p
\v 32 Ngadani ngani matja jiritjina warai, ngani jurangu ngopera Galilaiaia wapala nganai.“   
\p
\v 33 Petrulu kalabana wonti ja nunkangu jatana wonti: „Pratjana jinkangu kintjakintjarinani, ngani wata pota kulno jinkangu kintjakintjarila nganai.“   
\p
\v 34 Jesus nunkangu jatana wonti: „Morlalu ngani jinkangu jatai: Nunkangupini tinkani windrila paia ngaperi jatananto, jundru ngana pota parkulu jedieli worarala nganai.“   
\p
\v 35 Petrus nunkangu jatana wonti: „Ngani bakana jinkangunto palinanto, ngato jidnana wata jedieli worarala nganai.“ Jeruja bakana mili pratjana jatana wonti.   
\p
\v 36 Ngadani Jesus tanangunto piri kulnuni wokarana wonti, tala nunkani Gethsemane, ja milini jatana wonti: „Ninkida ngamana ngarianau, wolja ngani wapanani jerra ngatjila.“   
\p
\v 37 Ja Nulu Petrus ja Zebedäuni ngatamura wulana patana wonti, ja wonina wonti ngaurongauro ja japali nganala.   
\p
\v 38 Ngadani Nau tanangu jatana wonti: „Ngani mungara ngaurongauro pirna nganai narielu; ninkida ngamanimai ja ngakangunto tepi ngamanimai!“   
\p
\v 39 Ja Nau ngalje morla wapana wonti ja mudlali woraterina wonti ja ngatjina wonti ja jatana wonti: „Ngakani Ngaperiai; jenia kantji pantjinani, naupini koko ngakangu wiringananto, wata jeruja worderu ngani jertapateriai, a‐ai, worderu jundru.“   
\p
\v 40 Ja Nau mili worangu tikana wonti, ja tanana muka mankamankana wonti ja Petrungu jatana wonti: „Mina, jura ngandandariai ngalje ngakangunto tepi ngamala?   
\p
\v 41 Tepi ngamanau ja ngatjianau, jura wontjanilani wiriati; mungara manju nganai ja palku waltowalto.“   
\p
\v 42 Nakaldra pota mandrula Nau wapana wonti ja ngatjina wonti ja jatana wonti: „Ngakani Ngaperiai; naupini koko ngandandarinani ngakangu wiringala, ngato ninaia tapananto; jeruja jertapaterina jinkani pantjiatimai.“   
\p
\v 43 Ja Nau tikana, Nulu tanana nakaldra muka mankamankana wonti; ngangau tana milki parina wonti.   
\p
\v 44 Ja Nulu tanana worarana wonti ja nakaldra wapana wonti ja pota parkulula ngatjina wonti nakaldra jenia jaura jatana.   
\p
\v 45 Ngadani Nau milini nunkanani tikana wonti ja tanangu jatana wonti: „Mukaturaranau ja ngara ngamanau! Mai, naupini ditji karakara nganai, ja tanali Kanaia Ngatamura madlentji marani ngulkujeli jinkila nganai.   
\p
\v 46 Terkakanau ngaiana wapananto! mai, nauwa wokaraila, nuluwa ngana wontawontai.“   
\p
\v 47 Ja Nau jenia jatanani, mai, Judas, marapratjana ja mandrundru kulno, wokarana wonti, ja nunkangunto kana wolara pirna kalti tirieli ja pitali Priesta pirnandru ja kana wolaraia pinarandru.   
\p
\v 48 Wontawontanietjali nunkanali tanangu malka jinkina wonti ja jatana wonti: „Worananina ngato manatapala nganai, Nauja nganai; ninaia patanimai!“   
\p
\v 49 Ja nurujeli nau Jesungu wokarana wonti ja jatana wonti: „Murlali nganamai, Rabbi!“ ja nina manatapana wonti.   
\p
\v 50 Jesus nunkangu jatana wonti: „Kamaneliai, minani jidni wokarai?“ Ngadani tana karakararina wonti ja Jesungu mara kurana pararana wonti ja nina patana wonti.   
\p
\v 51 Ja mai, kulno tanangundru Jesungu jela, nguna warpipana wonti, ja mardakirra nunkani dukarana wonti, ja Priesta pirnaia mili kulno nandrana wonti, ja nina talpa wokaribana wonti.   
\p
\v 52 Jesus nunkangu jatana wonti: „Mardakirra jinkani nakaldra nunkani pirini widmana tikau; ngangau warletanali mardakirra patai, mardakirrali palila nganai.   
\p
\v 53 Jundru ngundrai, ngani karari ngandandariai Ngaperani ngakanani ngatjila, ja Nulia ngakangu angela morla marapu jinpananto legiona marapratjana ja mandruni?   
\p
\v 54 Worderu jaura wora morlalu pantjinanto, jeruja jenia pantjinanto?“   
\p
\v 55 Nunkangupini ditjini Jesus wolarani jatana wonti: „Jura ngakangu dunkana warai watawatali maninietjani jeribaka mardakirrali ja pitali ngana patala; ditji marapuni ngani jurangunto ngamana warai Godaia pungani ngujangujara jinkina, ja jura ngana wata patana warai.   
\p
\v 56 Jenia pratjana pantjiai, Prophetaia jaura morlalu pantjinanto.“ Ngadani mili pratjana nunkangundru puntina wonti ja japa mindrina wonti.   
\p
\v 57 Ja tanali Jesus patana wonti ja nina Kaiphasangu Priesta pirnaia wapalkana wonti, wodajeri jaura jinkinietja ja pinaru wora jurborina wonti.   
\p
\v 58 Petrus nunkangu woritandru karipaterina wonti Priesta pirnaia pungajelu; ja nau wirina wonti, ja milini jela ngamana ngarina wonti najila, mina pantjila nganai.   
\p
\v 59 Priesta pirnali ja pinaru worali ja kapara pratjanali jedi jaura wontina wonti Jesungu, nina nari ngankala.   
\p
\v 60 Ja tanali panila mankamankana wonti. Ja jedikantji marapu wokarana wonti, ja tanali panila mankamankana wonti. Ngadani jedikantji mandru wokarana wonti,   
\p
\v 61 Ja jatana wonti: „Naupini jatana warai: Ngani ngurunguru nganai, Godaia punga wokaribala ja ditjini parkulani nina nakaldra wotila.“   
\p
\v 62 Ja Priesta pirna terkakana wonti ja jatana wonti nunkangu: „Jundru panila kalabai mina pudlalia morlalu kurai jinkangu?“   
\p
\v 63 Jesus ngapu nganana wonti. Ja Priesta pirnali kalabana wonti ja nunkangu jatana wonti: „Ngato jinkangu jaura morlalu jakalkai Goda tepini, jidni ngaianingu jatananto, jidni Christus Godaia Ngatamura nganai.“   
\p
\v 64 Jesus nunkangu jatana wonti: „Jidni matja jatai. Morlalu ngani jurangu jatai: Kararindru jura najila nganai Kanaia Ngatamura ngurulaia ngunarani ngamanani, ja pariwilpalali talara palkujeli wokaranani.“   
\p
\v 65 Ngadani Priesta pirnali kati nunkani purana wonti ja jatana wonti: „Nulia Goda ngirkibana warai; minani ngaiani jaura morlalu morla ngamalkananto? Mai, karari jura ninaia Goda ngirkibanani ngarana warai.   
\p
\v 66 Mina jura ngundrai?“ Tanali kalabana wonti ja jatana wonti: „Nauja palinanto nari.“   
\p
\v 67 Ngadani tanali ngaltja nunkangu mudlani worana wonti, ja nina marali nandrana wonti; ja palpali nina mara mokujeli nandrana wonti,   
\p
\v 68 Ja jatana wonti: „Ngaianingu morlalu jatamai Christujai, warlenulu jidna nandrana warai?“   
\p
\v 69 Petrus palarani ngamana wonti piri tertini, ja nunkangu widla mili wokarana wonti ja jatana wonti: „Jidni bakana Jesungunto Galilaiala nganana warai!“   
\p
\v 70 Nau jedina wonti pratjanani ja jatana wonti: „Ngani ko, mina jidni jatai.“   
\p
\v 71 Nau dunkana manani, nina kulno ngurujeli najina wonti ja tanangu naka jatana wonti: „Bakana naupini Jesungu Nazaretalani jela nganana warai.“   
\p
\v 72 Ja nau nakaldra jedina wonti ja jaura morlalu jatana wonti: „Ngato nina kana wata ngujamai.“   
\p
\v 73 Ngalje ngadani tana naka terkana wokarana wonti ja Petrungu jatana wonti: „Morlalu, bakana jidni tanangundru kulno nganai, ngangau talieli jinkanali jidni wondrai.“   
\p
\v 74 Jendranguta nulu wonina wonti madlentji jataterila, ja jaura morlalu jatana wonti: „Ngato ninapini kana wata ngujamai.“ Ja nurujeli paia ngaperi jatana wonti.   
\p
\v 75 Ja Petrulu Jesuni jaura ngundrana wonti, nau nunkangu jatala wiri: „Windrila paia ngaperi jatananto, jundru ngana pota parkulu jedieli worarala nganai.“ Ja nau dunkana wonti ja burkali pirna jindrana wonti.   
\c 27  
\p
\v 1 Ja matja nguramarana, Priesta pirnali ja kana wolaraia pinaru pratjanali ngankamalina wonti Jesungundru, nina nari ngakala.   
\p
\v 2 Ja tanali nina dupudupu ngankana wonti ja nina wapalkana wonti ja nina Pontiungu Pilatungu mitaia kapakaparani jinkina wonti.   
\p
\v 3 Ngadani Judasali wontawontanietjali nunkanali matja najina, tanali nunkangu kalala jinkila nganai, nulu burkali mardatandra 30 Priesta pirnani ja pinaru worangu jinkina tikana wonti,   
\p
\v 4 Ja jatana wonti: „Ngato madlentji ngankana warai, ngangau ngato kumari kulikiri wontawontana warai.“ Tana jatana wonti: „Mina jenia ngaianingu? Muntali najiau!“   
\p
\v 5 Ja nulu tanana mardatandra Godaia pungani worana wonti ja wapana wonti ja waruwarukijiribaterina wonti.   
\p
\v 6 Priesta pirnali tanana mardatandra patana wonti ja jatana wonti: „Wata talku nganai, tananaia Godaia pungaia kokuni worala, ngangau jenia kumari mardatandra nganai.“   
\p
\v 7 Tana matja ngankamalina, tanali tanangundru bulurukoko ngankanietjaia mita burungankana wonti tula todila.   
\p
\v 8 Jendrangundruja tanali nina mita „kumari‐mita“ dikai kararilu.   
\p
\v 9 Jendranguta morlalu pantjina wonti mina Prophetali Jeremiasali kaukaubana wonti nau jatana wonti: „Ja tanali mardatandra 30 manina wonti burungankani kalala nunkangu, worana tanali Juda kana ngatamurandru burungankanala,   
\p
\v 10 Ja tanali tanana jinkina wonti bulurukoko ngankanietjaia mitani worderu Kaparali ngakangu jirijiribana wonti.“   
\p
\v 11 Jesus kapakapara mudlani terkana wonti. Ja kapakaparali nina jakalkana wanti ja jatana wonti: „Jidni Juda kanaia Kapara nganai?“ Jesus nunkangu jatana wonti: „Jidni matja jatai.“   
\p
\v 12 Ja Priesta pirna ja pinaru wora nunkangu ngulkuterkanani, Nulu wata kalabana wonti.   
\p
\v 13 Ngadani Pilatus nunkangu jatana wonti: „Jundru wata ngarai, worderuntja jaurali tana jinkangundru ngulkuterkai?“   
\p
\v 14 Ja Nulu nunkangu wata jaura kulno kalabana wonti, jeruja bakana kapakapara pirna ngaruparana wonti.   
\p
\v 15 Ditji pirnani kapakaparali milingeru wolarani kanjangarila kulno kurakana wonti, worananina tanali ngantjana wonti.   
\p
\v 16 Tanali jendranguta madlentji ngankanietja pirna kanjangari pungani ngamalkana wonti, tala nunkani Barabbas.   
\p
\v 17 Tana matja jurborina, Pilatus tanangu jatana wonti: „Worana jura ngantjai, nina ngato jurangu kurakananto, Barabbas kara, Jesus kara, nina tanali dikai Christus?“   
\p
\v 18 Ngangau nau milkila nganana wonti, tanali nina kuterilkanandru ngulkuterkana warai.   
\p
\v 19 Nau kalala jinkini pirini matja ngamana ngarina, noajeli nunkanali nunkangu jinpana wonti ja jatana wonti: „Panila jundru nunkangupini kana talkuni ngankamai; ngangau ngato karari ngapitjali nunkangundru pirna ketjaketjana warai.“   
\p
\v 20 Priesta pirnali ja pinaru wolarali kana wolara winpana wonti, tanali Barabbangundru ngatjinanto, ja Jesus nari ngankananto.   
\p
\v 21 Kapakaparali kalabana wonti ja tanangu jatana wonti: „Worana pudlangundru jura ngantjai, wodanina ngato pudlangundru kurakananto?“ Tana jatana wonti: „Barabbas.“   
\p
\v 22 Pilatus tanangu jatana wonti: „Mina ngato Jesungu ngankananto, nina tanali dikai Christus?“ Pratjana nunkangu jatana wonti: „Ninaia kunarkuni katibamai!“   
\p
\v 23 Kapakaparali jatana wonti: „Mina madlentji Nulia ngankana warai?“ Tana morla maritjina wonti ja jatana wonti: „Ninaia kunarkuni katibamai!“   
\p
\v 24 Pilatulu najina, jenia baku nganai, tana windri morla juajuangana wonti, nulu ngapa manina wonti ja mara kulirkaterina wonti kana wolara mudlani ja jatana wonti: „Ngani madlentji pani nganai nunkangu kana talku kumarani; muntali najianau!“   
\p
\v 25 Ja kana wolarali kalabana wonti ja jatana wonti: „Kumari nunkani ngaianingu ja kupani ngaianinani wokaraiatimai!“   
\p
\v 26 Ngadani nulu tanangu Barabbas kurakana wonti. Ja nulu jirijiribana wonti Jesus nandrananto, ja nina jinkina wonti kunarkuni katibala.   
\p
\v 27 Ngadani kapakaparaia mili wolarali Jesus kapakaparaia pungani wapalkana wonti, ja nunkangu mili pratjana jurborilkana wonti.   
\p
\v 28 Ja tanali kati nunkani dukarana wonti, ja nunkangu kati maralje widmana wonti.   
\p
\v 29 Ja tanali dilka pirapira dakana wonti, ja nunkangu mangatandrani kurana wonti, ja pita nunkangu mara ngunarani jinkina wonti, ja nunkangu pantjaterkana ngarina wonti ja nina ngirkibana wonti ja jatana wonti: „Murlali nganamai, Juda kanaia Kaparajai!“   
\p
\v 30 Ja tanali nunkangu ngaltja worana wonti, ja pita manina wonti, ja nina mangatandra nandrana wonti.   
\p
\v 31 Ja tanali nina matja ngirkibana, tanali kati maralje nunkangundru dukarana wonti, ju kati pilki nunkani nunkangu widmana wonti, ja nina wapalkana wonti kunarkuni katibala.   
\p
\v 32 Tana dunkana, tanali kana kulno Kyrenala mankamankana wonti, tala nunkani Simon; nina tanali watawatali patana wonti nulu kunarku nunkani waltananto.   
\p
\v 33 Ja tana wokarana wonti piri kulnuni, Golgatha tala nunkani, jenia wondrai: „Mangatandra piri.“   
\p
\v 34 Ja tanali nunkangu kaldri puratandrali ngokana jinkina wonti tapananto; ja Nulu jenia wontjana, Nulu wata ngantjana wonti tapala.   
\p
\v 35 Tanali nina matja kunarkuni katibana, tanali kati nunkani puntibana wonti wontjani malkali: Ngangau Prophetaia jaura morlalu pantjinanto: „Tanali kati ngakani puntibana wonti, ja ngakani kati pirnani tanali wontjani malka worana wonti.“   
\p
\v 36 Ja tana ngamana ngarina wonti ja nina najinajibana wonti.   
\p
\v 37 Ja tanali nunkangu mangatandrani miri jaura kurana wonti, minandru Nau palinanto jeruja: „Naupini Jesus Juda kanaia Kapara nganai.“   
\p
\v 38 Ngadani tanali nunkangu jela watawatali maninietja mandru kunarkuni katibana wonti, kulno nunkangu ngunarani, ja kulno nunkangu worangantjuni.   
\p
\v 39 Wiringanietjali nina ngirkibana wonti ja mangatandra walkina wonti,   
\p
\v 40 Ja jatana wonti: „Jundru Godaia punga tampuribanietja ja wotinietja ditjini parkulani, jidni munta kulkateriau! jidni Godaia Ngatamura ngananani, kunarkundru ngariamai!“   
\p
\v 41 Tanali jeribaka nina bakana Priesta pirnali ja jaura jinkinietjali ja pinarali ngirkibana wonti ja jatana wonti:   
\p
\v 42 „Kana nguru Nulia kulkana warai, ja muntali Nauja ngandandariai kulkaterila; Nauja Israelani Kapara ngananani, Nauja karari kunarkundru ngariatimai, ja ngaiana nunkangu morlalu ngundrala nganai.   
\p
\v 43 Nulia Godani morlalu ngundrana warai; Nulia karari ninaia kurakaiatimai, Nulia ninaia ngantjanani; ngangau Nauja jatana warai: Ngani Godaia Ngatamura nganai.“   
\p
\v 44 Tanangu jeribaka nina bakana watawatali maninietjali ngirkibana wonti, pudla nunkangu jela kunarkuni parana wonti.   
\p
\v 45 Todandru ngalpuru pirna pantjina wonti mita maruni ditji kunarkujelu.   
\p
\v 46 Ditji kunarkuni Jesus ngaiala pirnali maritjina wonti ja jatana wonti: „Eli, Eli, lama sabachthani?“ jenia wondrai: „Godajai ngakani, Godajai ngakani; minandru jundru ngana worarana warai?“   
\p
\v 47 Palpa tanangundru naka terkana, ja jenia ngarana, jatana wonti: „Nulupini Elias karkai.“   
\p
\v 48 Ja nurujeli tanangundru kulno mindrina wonti ja miritipa manina wonti, ja nina kaldrieli ngapatjanka ngankana wonti, ja nina pitani widmana wonti, ja nunkangu jinkina wonti tapananto.   
\p
\v 49 Kana nguru jatana wonti: „Worani; ngaiana najinanto Elias kara wokarala nganai ninaia kulkala.“   
\p
\v 50 Jesus nakaldra ngaiala pirnali maritjina wonti ja palina wonti.   
\p
\v 51 Ja mai, kati pirna Godaia pungani puraterina wonti terti mirindru ngarinalujelu; ja mita wiltjiwiltjina wonti, ja marda taldra tjelapalkaterina wonti.   
\p
\v 52 Ja nariwonpa wilparina wonti, ja kana kulikiria palku marapu, tana matja turarana, jiritjina wonti.   
\p
\v 53 Ja nunkani tepi terkakani ngadani, tana narikutundru dunkana wonti, ja ngura kulikiria wapana wonti, ja kana marapuni wondraterina wonti.   
\p
\v 54 Ja juljaiakapara, ja tana nunkangunto Jesus najinajibana, japali pirna pantjina wonti, tanali mita wiltjiwiltjinani najina wonti, ja jenia, mina pantjina warai, ja jatana wonti: „Morlalu Naupini Godaia Ngatamura nganana warai.“   
\p
\v 55 Naka bakana widla marapu nganana wonti, tanali woritandru jenia najina wonti; tana Jesungu Galilaiandru karipaterina warai mili nunkani nganala.   
\p
\v 56 Tanangundru nganana wonti Maria Magdalala, ja Maria, Jakobuni ja Joseni ngandri, ja Zebedäuni ngatamuraia ngandri.   
\p
\v 57 Matja kalkaurarina, kana poto pirna Arimathiala, tala nunkani Joseph, wokarana wonti; nau bakana Jesuni mili nganana wonti.   
\p
\v 58 Nau Pilatungu wapana wonti, ja Jesuni palkuni ngatjina wonti; ngadani Pilatus jirijiribana wonti nunkangu palku jinkinanto.   
\p
\v 59 Ja Josephali palku manina wonti, ja nina kati kulikirieli karana wonti,   
\p
\v 60 Ja nina narikutu marrani nunkanani kurana wonti, nina nulu marda taldrani bakuna wonti; ja nulu marda pirna narikutuja manani tirimalkana wonti ja wapana wonti.   
\p
\v 61 Naka Maria Magdalala nganana wonti, ja Maria kulno, pudla nariwonpankari ngamana wonti.   
\p
\v 62 Ditjini kulnuni, ngankingani ditjini ngadani, Priesta pirna ja Pharisaia Pilatungu jurlborina wonti,   
\p
\v 63 Ja jatana wonti: „Kaparajai, ngaiani mangatandra wilpariai, Naupini karkarkanietja nunkani tepia ditjini jatana paraia: Ditjini parkulani ngani jiritjila nganai.   
\p
\v 64 Jirijiribamai, tanali nariwonpa ditjini parkulanilu najinajibananto, mili nunkani wokaraiati ja nina kurieli maniati ja kana wolarani jataiati: Nauja narindru jiritjina warai; ja mudani jedibala morla tjautjau pantjiati ngoperalani.“   
\p
\v 65 Pilatus tanangu jatana wonti: „Ninkida jura najinajibanietja ngamalkai; wapanau, ja nina ngumu ngamalkanau, worderu jura ngujamai.“   
\p
\v 66 Tana wapana wonti ja nariwonpa ngumu ngamalkana wonti, ja mardani kandrieli malka kurana wonti najinajibanietjali jelali.   
\c 28  
\p
\v 1 Sabbath ditji matja mudana, ja nguramarana Godaia ditjini, Maria Magdalala ja Maria nguru wokarana wonti nariwonpa najila.   
\p
\v 2 Ja mai, mita pirna wiltjiwiltjina wonti; ngangau Kaparaia angela pariwilpandru ngarina wonti, ja marda manandru tirimalkana wonti, ja nunkangupini miri ngamana ngarina wonti.   
\p
\v 3 Nau mudla talara praitji jeribaka nganana wonti, ja kati nunkani bulu, taleri jeribaka.   
\p
\v 4 Najinajibanietja nunkangundru japali ngarrana wonti, ja nari jeribaka nganana wonti.   
\p
\v 5 Angelali widlani kalabana wonti ja jatana wonti: „Wata japali nganalumai; ngangau ngani milkila, judla Jesus wontiai, Nau kunarkuni palina.   
\p
\v 6 Nau wata ninkida nganai; ngangau Nau tepi terkakana warai, worderu Nau jatana paraia. Kaparalumai, ja najialumai piri, wodajeri Kapara parana warai,   
\p
\v 7 Ja nurujeli wapalumai, ja milini nunkanani jatalumai: Nau narindru tepi terkakana warai; ja mai, Nau jurangu ngopera wapala nganai Galilaia mitaia, naka jura nina najila nganai. Mai, ngani jenia judlangu jatana warai.“   
\p
\v 8 Ja pudla nurujeli narikutundru wapana wonti japali pirna ja mankinali, ja mindrina wonti jenia milini nunkanani kaukaubala.   
\p
\v 9 Pudla wapanani jenia milini nunkanani kaukaubala, mai, Jesus pudlangu mandurina wonti ja jatana wonti: „Murlali nganalumai!“ ja pudla nunkangu wokarana wonti ja nina tidna patana wonti ju nunkangu pantjaterkana ngarina wonti.   
\p
\v 10 Ngadani Jesus pudlangu jatana wonti: „Wata japali nganalumai; a‐ai, wapalumai ja jenia ngatatani ngakanani kaukaubalumai; ngangau tana Galilaiaia wapananto, ja naka tanali ngana najila nganai.“   
\p
\v 11 Pudla matja wapana, mai, najinajibanietja palpa ngurani wokarana wonti ja Priesta pirnani kaukaubana wonti pratjana, mina pantjina warai.   
\p
\v 12 Ja tana, ja pinaru wora matja mapaterina ja jaura ngankamalina, tanali najinajibanietjani mardatandra marapu jinkina wonti,   
\p
\v 13 Ja jatana wonti: „Jatanau: Mili nunkani tinkani wokarana warai, ja nina kurieli manina warai, ngaiani turaranani.   
\p
\v 14 Ja jenia kapakaparali ngaranani, ngaiani nina murlali daudauala nganai, ja jurana nunkangu murlali ngankala nganai.“   
\p
\v 15 Tanali mardatandra manina wonti, ja jeruja ngankana wonti, worderu tanali ngujangujara manina warai. Ja Juda kanali jenia kaukaubijiribamalina wonti kararielu.   
\p
\v 16 Tana mili marapratjana ja kulno Galilaiaia wapana wonti nunkangupini mardawonpaia, wodajeri Jesujeli tanangu jirijiribanala.   
\p
\v 17 Tanali nina najina, tana nunkangu pantjaterkana ngarina wonti; ja palpa mangangankana wonti.   
\p
\v 18 Ja Jesus tanangu wokarana wonti ja kaukaubana wonti ja jatana wonti: „Nulia ngurula pratjana ngakangu jinkina wonti pariwilpani ja mitani.   
\p
\v 19 Jeruja wapanau, ja kana wolara warupoto mili ngankanau, ja tanana multibanau Ngaperaia ja Ngatamuraia ja Jaolaia kulikiria talani.   
\p
\v 20 Ja tanangu ngujangujara jinkianau pratjana ngamalkala, mina ngato jurangu jirijiribanala. Ja mai, ngani jurangunto nganala nganai ditjini warupotuni mita mudanajelu.“   