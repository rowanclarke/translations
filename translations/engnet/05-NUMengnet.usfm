\v 5  So \w a|strong="H3068"\w* thousand \w from|strong="H3478"\w* \w every|strong="H3478"\w* \w tribe|strong="H4294"\w*, \w twelve|strong="H8147"\w* thousand \w armed|strong="H2502"\w* \w for|strong="H3478"\w* \w battle|strong="H6635"\w* \w in|strong="H3478"\w* all, \w were|strong="H3478"\w* provided \w out|strong="H2502"\w* \w of|strong="H4294"\w* \w the|strong="H8147"\w* thousands \w of|strong="H4294"\w* \w Israel|strong="H3478"\w*.   
\s1 Campaign Against the Midianites  
\p
\v 6  \w So|strong="H7971"\w* \w Moses|strong="H4872"\w* \w sent|strong="H7971"\w* \w them|strong="H7971"\w* \w to|strong="H7971"\w* \w the|strong="H7971"\w* \w war|strong="H6635"\w*, \w one|strong="H1121"\w* thousand \w from|strong="H3027"\w* \w every|strong="H7971"\w* \w tribe|strong="H4294"\w*, \w with|strong="H3027"\w* \w Phinehas|strong="H6372"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* Eleazar \w the|strong="H7971"\w* \w priest|strong="H3548"\w*, \w who|strong="H3548"\w* \w was|strong="H4872"\w* \w in|strong="H1121"\w* \w charge|strong="H3027"\w* \w of|strong="H1121"\w* \w the|strong="H7971"\w* \w holy|strong="H6944"\w* \w articles|strong="H3627"\w* \w and|strong="H1121"\w* \w the|strong="H7971"\w* \w signal|strong="H8643"\w* \w trumpets|strong="H2689"\w*.  
