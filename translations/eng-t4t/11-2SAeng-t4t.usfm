\p 
\v 1 \w There|strong="H1961"\w* \w was|strong="H1961"\w* \w a|strong="H3068"\w* \w long|strong="H1980"\w* \w war|strong="H4421"\w* \w between|strong="H4421"\w* \w those|strong="H1961"\w* \w who|strong="H4421"\w* wanted \w Saul|strong="H7586"\w*’s son \w to|strong="H1980"\w* \w be|strong="H1961"\w* \w their|strong="H1961"\w* king \w and|strong="H1980"\w* \w those|strong="H1961"\w* \w who|strong="H4421"\w* wanted \w David|strong="H1732"\w* \w to|strong="H1980"\w* \w be|strong="H1961"\w* \w their|strong="H1961"\w* king. \w But|strong="H1961"\w* \w more|strong="H1961"\w* \w and|strong="H1980"\w* \w more|strong="H1961"\w* people \w began|strong="H1961"\w* \w to|strong="H1980"\w* want \w David|strong="H1732"\w* \w to|strong="H1980"\w* \w be|strong="H1961"\w* \w the|strong="H1961"\w* king, \w while|strong="H1961"\w* \w the|strong="H1961"\w* number \w of|strong="H1004"\w* people \w who|strong="H4421"\w* wanted \w Saul|strong="H7586"\w*’s son \w to|strong="H1980"\w* \w be|strong="H1961"\w* \w the|strong="H1961"\w* king \w continued|strong="H1980"\w* \w to|strong="H1980"\w* \w become|strong="H1961"\w* smaller.
\s1 David’s sons born at Hebron
\li1 
\v 2 David’s wives gave birth to six sons at Hebron. The oldest was Amnon, whose mother was Ahinoam, from Jezreel \add city\add*.
\li2 
\v 3 The next one was Kileab, whose mother was Abigail, the widow of Nabal, from Carmel \add city\add*.
