\li1
\v 19 Mattenai, from \add the clan of\add* Joiarib;  
\li1 Uzzi, from \add the clan of\add* Jedaiah;   
\li1
\v 20 Kallai, from \add the clan of\add* Sallu/Sallai;  
\li1 Eber, from \add the clan of\add* Amok;   
\li1
\v 21 Hashabiah, from \add the clan of\add* Hilkiah;  
\li1 and Nethanel, from \add the clan of\add* Jedaiah.   
\s1 Duties of priests and Levites  
\p
\v 22 \w During|strong="H3117"\w* \w the|strong="H5921"\w* \w years|strong="H3117"\w* \w that|strong="H3117"\w* Eliashib, \w Joiada|strong="H3111"\w*, \w Johanan|strong="H3110"\w*, \w and|strong="H3117"\w* \w Jaddua|strong="H3037"\w* \add were Supreme Priests\add*, \w they|strong="H3117"\w* ◄\w wrote|strong="H3789"\w*/kept \w a|strong="H3068"\w* list \w of|strong="H3117"\w*► \w the|strong="H5921"\w* names \w of|strong="H3117"\w* \w the|strong="H5921"\w* clans \w who|strong="H3548"\w* \w were|strong="H3881"\w* descendants \w of|strong="H3117"\w* \w Levi|strong="H3881"\w*. \w When|strong="H3117"\w* \w Darius|strong="H1867"\w* \w was|strong="H3117"\w* \w the|strong="H5921"\w* \w king|strong="H5921"\w* \w of|strong="H3117"\w* Persia, \w they|strong="H3117"\w* stopped \w writing|strong="H3789"\w* \w that|strong="H3117"\w* list.  
\v 23 \w They|strong="H3117"\w* \w wrote|strong="H3789"\w* \w the|strong="H5921"\w* names \w of|strong="H1121"\w* \w the|strong="H5921"\w* \w leaders|strong="H7218"\w* \w of|strong="H1121"\w* \w the|strong="H5921"\w* clans \w who|strong="H1121"\w* \w were|strong="H1121"\w* \w descendants|strong="H1121"\w* \w of|strong="H1121"\w* \w Levi|strong="H3878"\w* \w in|strong="H5921"\w* \w the|strong="H5921"\w* \w Book|strong="H5612"\w* \w of|strong="H1121"\w* \w Events|strong="H1697"\w* \add in Israel\add*, \w but|strong="H5921"\w* \w they|strong="H3117"\w* stopped \w writing|strong="H3789"\w* \w those|strong="H1121"\w* names \w when|strong="H3117"\w* Eliashib’s \w grandson|strong="H1121"\w* \w Johanan|strong="H3110"\w* \add was the Supreme Priest\add*.   
\p
\v 24 \w These|strong="H3881"\w* \w are|strong="H1121"\w* \w the|strong="H1984"\w* \w leaders|strong="H7218"\w* \w of|strong="H1121"\w* \w the|strong="H1984"\w* clans \add who are\add* \w descendants|strong="H1121"\w* \w of|strong="H1121"\w* \w Levi|strong="H3881"\w*: \w Hashabiah|strong="H2811"\w*, \w Sherebiah|strong="H8274"\w*, \w Jeshua|strong="H3442"\w*, Binnui, \w Kadmiel|strong="H6934"\w* \w and|strong="H1121"\w* others \w who|strong="H1121"\w* \w were|strong="H1121"\w* divided into two \w groups|strong="H7218"\w*. \w The|strong="H1984"\w* two \w groups|strong="H7218"\w* faced each \w other|strong="H5048"\w*, \w one|strong="H1121"\w* group replying \w to|strong="H1121"\w* \w the|strong="H1984"\w* \w other|strong="H5048"\w*, during \w the|strong="H1984"\w* \w time|strong="H7218"\w* \w that|strong="H3881"\w* they \w praised|strong="H1984"\w* \w and|strong="H1121"\w* thanked God. They \w did|strong="H1732"\w* \w that|strong="H3881"\w* \w just|strong="H5980"\w* \w as|strong="H1121"\w* King \w David|strong="H1732"\w*, \w the|strong="H1984"\w* \w man|strong="H1121"\w* \w who|strong="H1121"\w* served God \w well|strong="H5980"\w*, \w had|strong="H1732"\w* instructed.  
\v 25 \w These|strong="H8104"\w* singers included \w Mattaniah|strong="H4983"\w*, \w Bakbukiah|strong="H1229"\w*, \w and|strong="H8104"\w* \w Obadiah|strong="H5662"\w*.  
\p \w The|strong="H8104"\w* men \w who|strong="H8104"\w* \w guarded|strong="H8104"\w* \w the|strong="H8104"\w* storerooms close \w to|strong="H8104"\w* \w the|strong="H8104"\w* \w gates|strong="H8179"\w* \add of the temple\add* \w were|strong="H7778"\w* \w Meshullam|strong="H4918"\w*, \w Talmon|strong="H2929"\w*, \w and|strong="H8104"\w* \w Akkub|strong="H6126"\w*.  
\v 26 \w They|strong="H3117"\w* \w did|strong="H3117"\w* \w that|strong="H3117"\w* work \w during|strong="H3117"\w* \w the|strong="H3117"\w* \w time|strong="H3117"\w* \w that|strong="H3117"\w* \w Joiakim|strong="H3113"\w*, \w who|strong="H3548"\w* \w was|strong="H3117"\w* \w the|strong="H3117"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Jeshua|strong="H3442"\w* \w and|strong="H1121"\w* \w the|strong="H3117"\w* \w grandson|strong="H1121"\w* \w of|strong="H1121"\w* Jehozadak, \add was the Supreme Priest,\add* \w and|strong="H1121"\w* \w I|strong="H3117"\w* \w was|strong="H3117"\w* \w the|strong="H3117"\w* \w governor|strong="H6346"\w*, \w and|strong="H1121"\w* \w Ezra|strong="H5830"\w* \w was|strong="H3117"\w* \w the|strong="H3117"\w* \w priest|strong="H3548"\w* \w who|strong="H3548"\w* knew \w the|strong="H3117"\w* Jewish laws very well.   
\s1 Nehemiah dedicated the wall  
\p
\v 27 \w When|strong="H6213"\w* \w we|strong="H3068"\w* dedicated \w the|strong="H3605"\w* \w wall|strong="H2346"\w* around \w Jerusalem|strong="H3389"\w*, \w we|strong="H3068"\w* summoned \w the|strong="H3605"\w* descendants \w of|strong="H2346"\w* \w Levi|strong="H3881"\w* \add who help the priests\add* \w from|strong="H3881"\w* \w the|strong="H3605"\w* nearby \w places|strong="H4725"\w* \w where|strong="H4725"\w* \w they|strong="H6213"\w* \add were living\add*. \w We|strong="H6213"\w* \w asked|strong="H1245"\w* \w them|strong="H6213"\w* \w to|strong="H6213"\w* \add join with us to\add* \w celebrate|strong="H6213"\w* \w when|strong="H6213"\w* \w we|strong="H3068"\w* dedicated \w the|strong="H3605"\w* \w wall|strong="H2346"\w*. \w We|strong="H6213"\w* \w wanted|strong="H1245"\w* \w them|strong="H6213"\w* \w to|strong="H6213"\w* \w sing|strong="H7892"\w* \w songs|strong="H7892"\w* \w to|strong="H6213"\w* \w thank|strong="H8426"\w* \add Yahweh\add* \w and|strong="H3389"\w* \w make|strong="H6213"\w* \w music|strong="H7892"\w* \w by|strong="H6213"\w* playing \w cymbals|strong="H4700"\w* \w and|strong="H3389"\w* \w harps|strong="H3658"\w* \w and|strong="H3389"\w* \w other|strong="H3605"\w* stringed \w instruments|strong="H7892"\w*.  
\v 28 \w We|strong="H7891"\w* summoned \w the|strong="H4480"\w* \w descendants|strong="H1121"\w* \w of|strong="H1121"\w* Levi \w who|strong="H1121"\w* habitually \w sang|strong="H7891"\w* together. \w They|strong="H3389"\w* came \w to|strong="H3389"\w* \w Jerusalem|strong="H3389"\w* \w from|strong="H4480"\w* nearby areas \add where they had settled\add*, \w and|strong="H1121"\w* \w from|strong="H4480"\w* \w places|strong="H5439"\w* \w around|strong="H5439"\w* Netophah \add town southeast of Jerusalem\add*,  
\v 29 \w and|strong="H1004"\w* \w from|strong="H5439"\w* three \w places|strong="H1004"\w* \add northeast of Jerusalem\add*—\w Beth|strong="H1004"\w* \w Gilgal|strong="H1537"\w* \add city\add* \w and|strong="H1004"\w* \w the|strong="H3588"\w* areas \w around|strong="H5439"\w* \w Geba|strong="H1387"\w* \w and|strong="H1004"\w* \w Azmaveth|strong="H5820"\w*. \w Those|strong="H1992"\w* \w singers|strong="H7891"\w* \w had|strong="H3588"\w* \w built|strong="H1129"\w* \w villages|strong="H2691"\w* \w to|strong="H3389"\w* live \w in|strong="H1004"\w* near \w Jerusalem|strong="H3389"\w*.   
\p
\v 30  \add When they came to Jerusalem\add*, \w the|strong="H3548"\w* \w priests|strong="H3548"\w* \w and|strong="H3548"\w* \add other\add* descendants \w of|strong="H8179"\w* \w Levi|strong="H3881"\w* \add who help the priests\add* performed rituals \w to|strong="H5971"\w* \w cause|strong="H5971"\w* \w themselves|strong="H2891"\w* \w to|strong="H5971"\w* \w be|strong="H5971"\w* acceptable \w to|strong="H5971"\w* God, \w and|strong="H3548"\w* \w then|strong="H3548"\w* \w they|strong="H5971"\w* performed similar rituals \w to|strong="H5971"\w* \w purify|strong="H2891"\w* \w the|strong="H3548"\w* \add other\add* \w people|strong="H5971"\w*, \w the|strong="H3548"\w* \w gates|strong="H8179"\w*, \w and|strong="H3548"\w* \w the|strong="H3548"\w* \w wall|strong="H2346"\w*.  
\v 31 \w Then|strong="H5975"\w* \w I|strong="H5921"\w* gathered \w together|strong="H5921"\w* \w the|strong="H5921"\w* \w leaders|strong="H8269"\w* \w of|strong="H8269"\w* \w Judah|strong="H3063"\w* \w on|strong="H5921"\w* \w top|strong="H5921"\w* \w of|strong="H8269"\w* \w the|strong="H5921"\w* \w wall|strong="H2346"\w*, \w and|strong="H3063"\w* \w I|strong="H5921"\w* \w appointed|strong="H5975"\w* \w them|strong="H5921"\w* \w to|strong="H5927"\w* \w lead|strong="H5927"\w* \w two|strong="H8147"\w* \w large|strong="H1419"\w* groups \w to|strong="H5927"\w* march \w around|strong="H5921"\w* \w the|strong="H5921"\w* \w city|strong="H8179"\w* \add on top of the wall\add*, thanking God. \add As they faced the city,\add* \w one|strong="H8147"\w* group walked \w to|strong="H5927"\w* \w the|strong="H5921"\w* \w right|strong="H3225"\w* \w toward|strong="H5921"\w* \w the|strong="H5921"\w* Dung \w Gate|strong="H8179"\w*.  
\v 32 Behind \w their|strong="H3212"\w* \w leaders|strong="H8269"\w* marched \w Hoshaiah|strong="H1955"\w* \w and|strong="H3063"\w* \w half|strong="H2677"\w* \w of|strong="H8269"\w* \w the|strong="H2677"\w* \w leaders|strong="H8269"\w* \w of|strong="H8269"\w* \w Judah|strong="H3063"\w*.  
\v 33-35 Behind them marched \w a|strong="H3068"\w* group of priests who were blowing trumpets. They were Azariah, Ezra, Meshullam, Judah, Benjamin, Shemaiah, and Jeremiah. Next came Zechariah, the son of Jonathan, the son of Shemaiah, the son of Mattaniah, the son of Micaiah, the son of Zaccur, \w a|strong="H3068"\w* descendant of Asaph.  
\v 36 Behind \w them|strong="H6440"\w* marched other members \w of|strong="H3627"\w* Zechariah’s clan: \w Shemaiah|strong="H8098"\w*, \w Azarel|strong="H5832"\w*, \w Milalai|strong="H4450"\w*, \w Gilalai|strong="H1562"\w*, \w Maai|strong="H4597"\w*, \w Nethanel|strong="H5417"\w*, \w Judah|strong="H3063"\w*, \w and|strong="H3063"\w* \w Hanani|strong="H2607"\w*. \w They|strong="H6440"\w* \w all|strong="H6440"\w* \w were|strong="H3063"\w* playing \w the|strong="H6440"\w* same \w kinds|strong="H3627"\w* \w of|strong="H3627"\w* \w musical|strong="H7892"\w* \w instruments|strong="H3627"\w* \w that|strong="H3627"\w* \w King|strong="H6440"\w* \w David|strong="H1732"\w* \w had|strong="H1732"\w* played \add many years previously\add*. \w Ezra|strong="H5830"\w*, \w the|strong="H6440"\w* \w man|strong="H6440"\w* \w who|strong="H3063"\w* knew \w the|strong="H6440"\w* Jewish laws very well, marched \w in|strong="H6440"\w* \w front|strong="H6440"\w* \w of|strong="H3627"\w* \w this|strong="H6440"\w* group.  
\v 37 \w When|strong="H5704"\w* \w they|strong="H5921"\w* \w reached|strong="H5921"\w* \w the|strong="H5921"\w* \w Fountain|strong="H5869"\w* \w Gate|strong="H8179"\w*, \w they|strong="H5921"\w* \w went|strong="H5927"\w* \w up|strong="H5927"\w* \w the|strong="H5921"\w* \w steps|strong="H4609"\w* \w to|strong="H5704"\w* \w David|strong="H1732"\w*’s \w City|strong="H5892"\w*, past \w his|strong="H1732"\w* \w palace|strong="H1004"\w*, \w and|strong="H1004"\w* \w then|strong="H5927"\w* \w to|strong="H5704"\w* \w the|strong="H5921"\w* \w wall|strong="H2346"\w* \w at|strong="H5921"\w* \w the|strong="H5921"\w* \w Water|strong="H4325"\w* \w Gate|strong="H8179"\w*, \w on|strong="H5921"\w* \w the|strong="H5921"\w* \w east|strong="H4217"\w* \w side|strong="H4217"\w* \add of the city\add*.   
\p
\v 38 \w The|strong="H5921"\w* \w other|strong="H8145"\w* group \w of|strong="H2346"\w* \w those|strong="H5921"\w* \w who|strong="H5971"\w* \w were|strong="H5971"\w* thanking \add Yahweh\add* \w marched|strong="H1980"\w* \w to|strong="H5704"\w* \w the|strong="H5921"\w* \w left|strong="H1980"\w* \w on|strong="H5921"\w* \w top|strong="H5921"\w* \w of|strong="H2346"\w* \w the|strong="H5921"\w* \w wall|strong="H2346"\w*. \w I|strong="H5704"\w* \w followed|strong="H1980"\w* \w them|strong="H5921"\w* \w with|strong="H1980"\w* \w half|strong="H2677"\w* \w of|strong="H2346"\w* \w the|strong="H5921"\w* \w people|strong="H5971"\w*. \add We marched\add* past \w the|strong="H5921"\w* \w Tower|strong="H4026"\w* \w of|strong="H2346"\w* \w the|strong="H5921"\w* \w Ovens|strong="H8574"\w* \w to|strong="H5704"\w* \w the|strong="H5921"\w* \w Broad|strong="H7342"\w* \w Wall|strong="H2346"\w*.  
\v 39  \add From there we marched\add* past Ephraim \w Gate|strong="H8179"\w*, \w Jeshanah|strong="H3466"\w* \w Gate|strong="H8179"\w*, \w the|strong="H5921"\w* \w Fish|strong="H1709"\w* \w Gate|strong="H8179"\w*, \w the|strong="H5921"\w* \w Tower|strong="H4026"\w* \w of|strong="H8179"\w* \w Hananel|strong="H2606"\w*, \w the|strong="H5921"\w* \w Tower|strong="H4026"\w* \w of|strong="H8179"\w* \w the|strong="H5921"\w* \w Hundred|strong="H3968"\w* Soldiers, \w to|strong="H5704"\w* \w the|strong="H5921"\w* \w Sheep|strong="H6629"\w* \w Gate|strong="H8179"\w*. \w We|strong="H5704"\w* finished marching \w near|strong="H5921"\w* \w the|strong="H5921"\w* \w gate|strong="H8179"\w* \w into|strong="H5921"\w* \w the|strong="H5921"\w* temple.  
\v 40 \w Both|strong="H8147"\w* \w the|strong="H5975"\w* groups reached \w the|strong="H5975"\w* \w temple|strong="H1004"\w* \w while|strong="H5973"\w* \w they|strong="H5975"\w* \w were|strong="H8147"\w* thanking God. \w They|strong="H5975"\w* \w stood|strong="H5975"\w* \w in|strong="H1004"\w* \w their|strong="H5975"\w* \w places|strong="H1004"\w* \w there|strong="H5975"\w*. \w The|strong="H5975"\w* \w leaders|strong="H5461"\w* \w who|strong="H5975"\w* \w were|strong="H8147"\w* \w with|strong="H5973"\w* \w me|strong="H5973"\w* \add also stood with me in our places\add*.   
\p
