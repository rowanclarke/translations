\b
\iex (We have not yet translated 12:26—14:33.)
\c 15
\s1 Absalom wanted to be the big boss instead of his father
\p 
\v 1 David \w had|strong="H1961"\w* \w a|strong="H3068"\w* \w grown|strong="H1961"\w* \w up|strong="H1961"\w* son. \w His|strong="H6440"\w* name \w was|strong="H1961"\w* Absalom. Some \w time|strong="H1961"\w* \w after|strong="H1961"\w* Solomon \w was|strong="H1961"\w* born, Absalom reckoned \w that|strong="H3651"\w* \w he|strong="H3651"\w* \w had|strong="H1961"\w* \w to|strong="H1961"\w* \w be|strong="H1961"\w* \w the|strong="H6440"\w* big boss, instead \w of|strong="H6440"\w* \w his|strong="H6440"\w* father. \w So|strong="H3651"\w* \w he|strong="H3651"\w* got \w a|strong="H3068"\w* special trailer \w and|strong="H2572"\w* some \w horses|strong="H5483"\w* \w to|strong="H1961"\w* pull \w it|strong="H6213"\w*, \w and|strong="H2572"\w* \w he|strong="H3651"\w* sat \w in|strong="H6213"\w* \w that|strong="H3651"\w* trailer \w and|strong="H2572"\w* \w went|strong="H6440"\w* \w around|strong="H6440"\w* \w in|strong="H6213"\w* \w it|strong="H6213"\w*. \w Whenever|strong="H1961"\w* \w he|strong="H3651"\w* \w went|strong="H6440"\w* \w in|strong="H6213"\w* \w that|strong="H3651"\w* trailer, \w he|strong="H3651"\w* \w told|strong="H6213"\w* 50 \w men|strong="H6213"\w* \w to|strong="H1961"\w* \w run|strong="H7323"\w* \w along|strong="H6440"\w* \w in|strong="H6213"\w* \w front|strong="H6440"\w* \w of|strong="H6440"\w* \w it|strong="H6213"\w*, \w so|strong="H3651"\w* \w that|strong="H3651"\w* \w he|strong="H3651"\w* \w looked|strong="H6440"\w* important.\fig Absalom went around in a special trailer that horses pulled|src="CO00773b.tif" size="col" copy="1996 David C. Cook" ref="15:1"\fig*
\v 2 \w And|strong="H3478"\w* \w he|strong="H3605"\w* \w used|strong="H1961"\w* \w to|strong="H3478"\w* \w get|strong="H3027"\w* \w up|strong="H5975"\w* \w early|strong="H7925"\w* \w to|strong="H3478"\w* \w go|strong="H1961"\w* \w and|strong="H3478"\w* \w stand|strong="H5975"\w* \w at|strong="H5921"\w* \w the|strong="H3605"\w* \w town|strong="H5892"\w* \w gate|strong="H8179"\w*. People \w used|strong="H1961"\w* \w to|strong="H3478"\w* \w walk|strong="H1870"\w* \w through|strong="H3027"\w* \w that|strong="H3605"\w* \w gate|strong="H8179"\w* \w into|strong="H5921"\w* Jerusalem \w whenever|strong="H3605"\w* \w they|strong="H5921"\w* \w went|strong="H3478"\w* \w to|strong="H3478"\w* see \w the|strong="H3605"\w* big boss. \w You|strong="H3605"\w* see, \w they|strong="H5921"\w* \w used|strong="H1961"\w* \w to|strong="H3478"\w* \w go|strong="H1961"\w* \w and|strong="H3478"\w* \w ask|strong="H4428"\w* \w David|strong="H3027"\w* \w to|strong="H3478"\w* \w help|strong="H1961"\w* \w them|strong="H5921"\w* sort \w out|strong="H5921"\w* \w their|strong="H3605"\w* problems. Absalom \w used|strong="H1961"\w* \w to|strong="H3478"\w* \w call|strong="H7121"\w* \w out|strong="H5921"\w* \w to|strong="H3478"\w* \w them|strong="H5921"\w*, “Hey, \w where|strong="H5921"\w* \w are|strong="H3478"\w* \w you|strong="H3605"\w* \w from|strong="H5921"\w*?” \w That|strong="H3605"\w* \w person|strong="H3027"\w* \w used|strong="H1961"\w* \w to|strong="H3478"\w* \w tell|strong="H3605"\w* \w him|strong="H7121"\w* \w the|strong="H3605"\w* \w name|strong="H7121"\w* \w of|strong="H4428"\w* \w his|strong="H3605"\w* \w tribe|strong="H7626"\w*.
\p 
\v 3 \w Then|strong="H4428"\w* Absalom used \w to|strong="H8085"\w* lie \w to|strong="H8085"\w* \w them|strong="H7200"\w* \w and|strong="H4428"\w* \w say|strong="H1697"\w*, “\w Listen|strong="H8085"\w* \w to|strong="H8085"\w* \w me|strong="H7200"\w*. \w You|strong="H7200"\w* \w are|strong="H1697"\w* \w right|strong="H5228"\w*. \w That|strong="H7200"\w* other \w person|strong="H7200"\w* \w did|strong="H7200"\w* wrong \w to|strong="H8085"\w* \w you|strong="H7200"\w*. \w My|strong="H8085"\w* father \w is|strong="H1697"\w* \w the|strong="H8085"\w* big boss, \w but|strong="H7200"\w* \w he|strong="H4428"\w* \w is|strong="H1697"\w* \w too|strong="H1697"\w* busy \w to|strong="H8085"\w* \w listen|strong="H8085"\w* \w to|strong="H8085"\w* everybody. \w He|strong="H4428"\w* doesn’t \w have|strong="H7200"\w* working \w men|strong="H2896"\w* \w to|strong="H8085"\w* \w sort|strong="H1697"\w* \w out|strong="H7200"\w* \w all|strong="H7200"\w* \w your|strong="H7200"\w* problems.
\v 4 \w I|strong="H7760"\w* \w should|strong="H4310"\w* \w be|strong="H1961"\w* \w the|strong="H3605"\w* \w judge|strong="H8199"\w* \w in|strong="H5921"\w* \w this|strong="H7760"\w* country. \w I|strong="H7760"\w* \w am|strong="H1961"\w* fair \w to|strong="H1961"\w* everybody. \w I|strong="H7760"\w* \w will|strong="H4310"\w* \w treat|strong="H7760"\w* everybody \w the|strong="H3605"\w* same \w way|strong="H4941"\w*. \w If|strong="H1961"\w* somebody \w comes|strong="H1961"\w* \w to|strong="H1961"\w* \w me|strong="H5921"\w* \w with|strong="H5921"\w* \w a|strong="H3068"\w* problem, \w I|strong="H7760"\w* \w will|strong="H4310"\w* sort \w it|strong="H7760"\w* \w out|strong="H5921"\w* \w for|strong="H5921"\w* \w them|strong="H5921"\w*.” \w That|strong="H3605"\w*’s \w what|strong="H4310"\w* Absalom \w used|strong="H1961"\w* \w to|strong="H1961"\w* say \w to|strong="H1961"\w* \w the|strong="H3605"\w* people.
\p 
\v 5 Sometimes people really \w did|strong="H1961"\w* think Absalom \w was|strong="H1961"\w* \w an|strong="H7126"\w* important man, \w so|strong="H7971"\w* \w they|strong="H3027"\w* got \w down|strong="H7812"\w* \w on|strong="H3027"\w* \w their|strong="H7971"\w* knees \w to|strong="H7971"\w* \w show|strong="H2388"\w* respect \w to|strong="H7971"\w* \w him|strong="H7971"\w*. \w Then|strong="H1961"\w* Absalom shook \w their|strong="H7971"\w* \w hands|strong="H3027"\w* \w and|strong="H7971"\w* hugged \w them|strong="H7971"\w*, \w to|strong="H7971"\w* \w get|strong="H3027"\w* \w them|strong="H7971"\w* \w to|strong="H7971"\w* \w like|strong="H1961"\w* \w him|strong="H7971"\w*.
\v 6 Absalom \w used|strong="H6213"\w* \w to|strong="H3478"\w* \w do|strong="H6213"\w* \w that|strong="H3605"\w* \w whenever|strong="H3605"\w* \w one|strong="H2088"\w* \w of|strong="H4428"\w* \w the|strong="H3605"\w* \w Israel|strong="H3478"\w* mob \w came|strong="H3478"\w* \w to|strong="H3478"\w* \w talk|strong="H1697"\w* \w to|strong="H3478"\w* David, \w to|strong="H3478"\w* \w ask|strong="H4428"\w* \w for|strong="H6213"\w* \w help|strong="H6213"\w*. \w So|strong="H6213"\w* \w that|strong="H3605"\w*’s \w the|strong="H3605"\w* \w way|strong="H1697"\w* \w he|strong="H6213"\w* got \w the|strong="H3605"\w* \w Israel|strong="H3478"\w* mob \w to|strong="H3478"\w* \w like|strong="H3478"\w* \w him|strong="H6213"\w*. \w They|strong="H6213"\w* didn’t \w like|strong="H3478"\w* \w his|strong="H3605"\w* father David \w any|strong="H3605"\w* \w more|strong="H6213"\w*.
\p 
\v 7-8 Absalom did that for 4 years. Then he said to his father, the big boss, “Old man, while I was living at the place called Geshur in Aram country, I said to God, ‘If you will let me go to Jerusalem first, I will go to Hebron later. I will get down on my knees and show respect to you there.’ God heard me say that. So is it all right for me to go to Hebron now?” But he was lying to his father.
\p 
\v 9 David answered, “\w All|strong="H3212"\w* right. \w You|strong="H6965"\w* can \w go|strong="H3212"\w* \w there|strong="H7965"\w*.” \w So|strong="H6965"\w* Absalom \w went|strong="H3212"\w* \w to|strong="H3212"\w* \w Hebron|strong="H2275"\w*.
\p 
\v 10 \w But|strong="H8085"\w* \w he|strong="H3605"\w* \w sent|strong="H7971"\w* messengers \w to|strong="H3478"\w* \w go|strong="H7971"\w* secretly \w all|strong="H3605"\w* around \w their|strong="H3605"\w* country, \w to|strong="H3478"\w* \w tell|strong="H8085"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w Israel|strong="H3478"\w* mob \w like|strong="H3478"\w* \w this|strong="H8085"\w*, “\w As|strong="H4427"\w* soon \w as|strong="H4427"\w* \w you|strong="H3605"\w* \w hear|strong="H8085"\w* \w the|strong="H3605"\w* \w trumpets|strong="H7782"\w* play \w out|strong="H7971"\w* \w loud|strong="H8085"\w*, \w you|strong="H3605"\w* mob \w have|strong="H3478"\w* \w to|strong="H3478"\w* \w call|strong="H8085"\w* \w out|strong="H7971"\w*, ‘Absalom \w is|strong="H3478"\w* \w our|strong="H3605"\w* big boss. \w They|strong="H3605"\w* \w have|strong="H3478"\w* picked \w him|strong="H7971"\w* \w to|strong="H3478"\w* \w be|strong="H3478"\w* \w the|strong="H3605"\w* big boss \w in|strong="H3478"\w* \w Hebron|strong="H2275"\w*.’” \fig This man is playing a trumpet|src="LB00187b.tif" size="col" ref="15:10"\fig*
\p 
\v 11-12 And he told 200 men to go with him to Hebron, to kill animals there and burn them for God. But they didn’t know that Absalom planned to make himself the big boss there. At the same time, he sent \w a|strong="H3068"\w* messenger to an old man called Ahithofel, from \w a|strong="H3068"\w* place called Giloh, to tell him to come. He was \w a|strong="H3068"\w* wise man, and he used to help David.
\p And so Absalom tricked lots of people and made them turn away from David. More and more people started to follow Absalom.
\s1 David ran away
\p 
\v 13 \w After|strong="H1961"\w* \w that|strong="H3478"\w*, \w a|strong="H3068"\w* \w messenger|strong="H5046"\w* \w came|strong="H1961"\w* \w to|strong="H3478"\w* \w David|strong="H1732"\w* \w and|strong="H3478"\w* said, “\w The|strong="H5046"\w* \w Israel|strong="H3478"\w* mob \w are|strong="H3478"\w* following Absalom \w now|strong="H1961"\w*, \w they|strong="H3478"\w* \w are|strong="H3478"\w* \w not|strong="H1732"\w* following \w you|strong="H5046"\w*.”
\p 
\v 14 \w David|strong="H1732"\w* \w got|strong="H6965"\w* \w a|strong="H3068"\w* shock. \w So|strong="H6435"\w* \w he|strong="H3588"\w* talked \w to|strong="H3212"\w* \w all|strong="H3605"\w* \w his|strong="H3605"\w* workers \w that|strong="H3588"\w* \w were|strong="H1961"\w* \w with|strong="H5921"\w* \w him|strong="H6440"\w* \w in|strong="H5921"\w* \w Jerusalem|strong="H3389"\w* \w city|strong="H5892"\w*. \w He|strong="H3588"\w* \w said|strong="H6310"\w*, “\w Quick|strong="H4116"\w*. \w We|strong="H3588"\w* \w have|strong="H1961"\w* \w to|strong="H3212"\w* \w run|strong="H3212"\w* \w away|strong="H3212"\w* \w from|strong="H6440"\w* \w this|strong="H3588"\w* \w city|strong="H5892"\w*, \w or|strong="H3808"\w* \w they|strong="H3588"\w* \w will|strong="H1961"\w* \w catch|strong="H5381"\w* \w us|strong="H5921"\w*. \w If|strong="H3588"\w* \w we|strong="H3068"\w* don’t \w hurry|strong="H4116"\w*, Absalom’s mob \w will|strong="H1961"\w* \w attack|strong="H5221"\w* \w this|strong="H3588"\w* \w city|strong="H5892"\w* \w and|strong="H6965"\w* \w kill|strong="H5221"\w* everybody.”
\p 
\v 15 \w The|strong="H3605"\w* workers said, “\w Yes|strong="H2009"\w*, boss. \w We|strong="H3605"\w* \w will|strong="H4428"\w* \w do|strong="H3605"\w* \w whatever|strong="H3605"\w* \w you|strong="H3605"\w* \w tell|strong="H3605"\w* us \w to|strong="H4428"\w* \w do|strong="H3605"\w*.”
\v 16 \w So|strong="H3318"\w* \w David|strong="H5800"\w* \w went|strong="H3318"\w* \w away|strong="H3318"\w* \w with|strong="H1004"\w* \w his|strong="H3605"\w* mob. \w He|strong="H3605"\w* told 10 \w of|strong="H4428"\w* \w his|strong="H3605"\w* wives \w to|strong="H3318"\w* stay \w behind|strong="H5800"\w* \w to|strong="H3318"\w* look \w after|strong="H7272"\w* \w his|strong="H3605"\w* \w house|strong="H1004"\w*.
\b
\iex (We have not yet translated 15:17-31.)
\b
\p 
\v 32 \w David|strong="H1732"\w* \w and|strong="H1732"\w* \w his|strong="H1732"\w* mob, \w they|strong="H8033"\w* \w went|strong="H1732"\w* \w to|strong="H5704"\w* \w the|strong="H5921"\w* \w top|strong="H7218"\w* \w of|strong="H7218"\w* \w the|strong="H5921"\w* hill \w called|strong="H8033"\w* Olive Trees Hill. People \w used|strong="H1961"\w* \w to|strong="H5704"\w* \w show|strong="H1961"\w* \w respect|strong="H5921"\w* \w to|strong="H5704"\w* God \w at|strong="H5921"\w* \w that|strong="H1732"\w* \w place|strong="H1961"\w*. \w A|strong="H3068"\w* \w man|strong="H7218"\w* \w called|strong="H8033"\w* \w Hushai|strong="H2365"\w* \w was|strong="H1961"\w* \w there|strong="H8033"\w* \w to|strong="H5704"\w* join \w up|strong="H5921"\w* \w with|strong="H5921"\w* \w David|strong="H1732"\w*’s mob. \w He|strong="H5704"\w* \w was|strong="H1961"\w* \w from|strong="H5921"\w* \w the|strong="H5921"\w* Arek mob, \w and|strong="H1732"\w* \w he|strong="H5704"\w* \w worked|strong="H5704"\w* \w for|strong="H5704"\w* \w David|strong="H1732"\w*. \w You|strong="H5921"\w* \w see|strong="H2009"\w*, \w he|strong="H5704"\w* heard \w about|strong="H1961"\w* Absalom’s plan \w to|strong="H5704"\w* attack Jerusalem, \w and|strong="H1732"\w* \w he|strong="H5704"\w* \w was|strong="H1961"\w* sad \w for|strong="H5704"\w* \w his|strong="H1732"\w* boss. \w He|strong="H5704"\w* \w even|strong="H5704"\w* \w tore|strong="H7167"\w* \w his|strong="H1732"\w* clothes \w and|strong="H1732"\w* put dirt \w on|strong="H5921"\w* \w his|strong="H1732"\w* \w head|strong="H7218"\w*, \w to|strong="H5704"\w* \w show|strong="H1961"\w* \w he|strong="H5704"\w* \w was|strong="H1961"\w* sad.
\v 33 \w But|strong="H1961"\w* \w David|strong="H1732"\w* said \w to|strong="H1961"\w* \w him|strong="H5921"\w*, “Don’t \w come|strong="H1961"\w* \w with|strong="H5921"\w* \w me|strong="H5921"\w*. \w You|strong="H5921"\w* might slow \w me|strong="H5921"\w* \w down|strong="H5921"\w*.
\v 34 \w I|strong="H6258"\w* want \w you|strong="H7725"\w* \w to|strong="H7725"\w* \w do|strong="H6565"\w* something different \w for|strong="H5650"\w* \w me|strong="H7725"\w*. \w Go|strong="H7725"\w* \w back|strong="H7725"\w* \w to|strong="H7725"\w* Jerusalem \w and|strong="H7725"\w* \w say|strong="H7725"\w* \w you|strong="H7725"\w* want \w to|strong="H7725"\w* work \w for|strong="H5650"\w* \w my|strong="H7725"\w* son, Absalom. \w Lie|strong="H1961"\w* \w to|strong="H7725"\w* \w him|strong="H7725"\w* \w and|strong="H7725"\w* \w say|strong="H7725"\w*, ‘Boss. \w I|strong="H6258"\w* want \w to|strong="H7725"\w* work \w for|strong="H5650"\w* \w you|strong="H7725"\w* \w now|strong="H6258"\w*. \w I|strong="H6258"\w* \w used|strong="H1961"\w* \w to|strong="H7725"\w* work \w for|strong="H5650"\w* \w your|strong="H7725"\w* father, \w but|strong="H1961"\w* \w now|strong="H6258"\w* \w I|strong="H6258"\w* want \w to|strong="H7725"\w* work only \w for|strong="H5650"\w* \w you|strong="H7725"\w*.’ \w If|strong="H1961"\w* \w you|strong="H7725"\w* \w do|strong="H6565"\w* \w that|strong="H4428"\w*, \w it|strong="H7725"\w* \w will|strong="H1961"\w* \w really|strong="H7725"\w* \w help|strong="H1961"\w* \w me|strong="H7725"\w*. \w If|strong="H1961"\w* \w that|strong="H4428"\w* old man Ahithofel tells \w my|strong="H7725"\w* son something, \w you|strong="H7725"\w* \w can|strong="H5650"\w* tell \w him|strong="H7725"\w* \w a|strong="H3068"\w* different story \w and|strong="H7725"\w* confuse \w him|strong="H7725"\w*.”
\b
\iex (We have not yet translated 15:35—16:4.)
\c 16
\s1 Shimmey swore at David
\p 
\v 5 \w David|strong="H1732"\w* \w and|strong="H1121"\w* \w his|strong="H1732"\w* mob \w came|strong="H3318"\w* close \w to|strong="H5704"\w* \w a|strong="H3068"\w* town \w called|strong="H8034"\w* Bahurim. \w A|strong="H3068"\w* \w man|strong="H1121"\w* \w called|strong="H8034"\w* Shimmey \w came|strong="H3318"\w* \w out|strong="H3318"\w* \w to|strong="H5704"\w* \w meet|strong="H3318"\w* \w them|strong="H3318"\w*. \w He|strong="H5704"\w* \w was|strong="H8034"\w* \w one|strong="H1121"\w* \w of|strong="H1121"\w* \w Saul|strong="H7586"\w*’s \w relatives|strong="H4940"\w*, \w and|strong="H1121"\w* \w his|strong="H1732"\w* \w father|strong="H1121"\w*’s \w name|strong="H8034"\w* \w was|strong="H8034"\w* \w Gera|strong="H1617"\w*. \w He|strong="H5704"\w* \w started|strong="H3318"\w* \w to|strong="H5704"\w* swear \w at|strong="H1004"\w* \w David|strong="H1732"\w* \w and|strong="H1121"\w* talk \w curses|strong="H7043"\w*.
\v 6 \w And|strong="H4428"\w* \w he|strong="H3605"\w* \w threw|strong="H5619"\w* \w stones|strong="H5619"\w* \w at|strong="H1732"\w* \w them|strong="H5619"\w*. \w David|strong="H1732"\w*’s \w soldiers|strong="H5650"\w* \w and|strong="H4428"\w* guards \w were|strong="H5971"\w* standing \w with|strong="H5971"\w* \w David|strong="H1732"\w*, \w but|strong="H5971"\w* Shimmey kept \w on|strong="H3605"\w* throwing \w stones|strong="H5619"\w* \w at|strong="H1732"\w* \w all|strong="H3605"\w* \w of|strong="H4428"\w* \w them|strong="H5619"\w*.
\v 7 \w And|strong="H1818"\w* \w he|strong="H3541"\w* \w cursed|strong="H7043"\w* David \w like|strong="H3318"\w* \w this|strong="H3541"\w*, “\w You|strong="H3318"\w* \w are|strong="H1818"\w* \w a|strong="H3068"\w* no good trouble maker. \w You|strong="H3318"\w* \w are|strong="H1818"\w* \w a|strong="H3068"\w* cheeky \w one|strong="H1100"\w*, \w a|strong="H3068"\w* murderer. \w You|strong="H3318"\w* \w are|strong="H1818"\w* boss \w for|strong="H3318"\w* nothing. \w Go|strong="H3318"\w* \w away|strong="H3318"\w*.
\v 8 \w You|strong="H5414"\w* killed lots \w of|strong="H1121"\w* \w Saul|strong="H7586"\w*’s \w family|strong="H1004"\w* dead, \w so|strong="H5414"\w* \w God|strong="H3068"\w* \w is|strong="H3068"\w* \w making|strong="H5414"\w* \w trouble|strong="H7451"\w* \w for|strong="H3588"\w* \w you|strong="H5414"\w* \w right|strong="H3068"\w* \w now|strong="H3588"\w*. \w You|strong="H5414"\w* \w made|strong="H5414"\w* \w yourself|strong="H5921"\w* \w the|strong="H3605"\w* big boss \w instead|strong="H8478"\w* \w of|strong="H1121"\w* \w him|strong="H5414"\w*. \w So|strong="H5414"\w* \w God|strong="H3068"\w* picked \w your|strong="H3068"\w* \w son|strong="H1121"\w* Absalom \w now|strong="H3588"\w* \w to|strong="H7725"\w* \w be|strong="H3027"\w* \w the|strong="H3605"\w* big boss \w instead|strong="H8478"\w* \w of|strong="H1121"\w* \w you|strong="H5414"\w*. \w You|strong="H5414"\w* \w are|strong="H1121"\w* \w a|strong="H3068"\w* murderer. \w Now|strong="H3588"\w* \w you|strong="H5414"\w* \w are|strong="H1121"\w* \w in|strong="H5921"\w* \w trouble|strong="H7451"\w* \w yourself|strong="H5921"\w*, \w and|strong="H1121"\w* \w it|strong="H5414"\w* \w is|strong="H3068"\w* \w your|strong="H3068"\w* \w own|strong="H3027"\w* \w fault|strong="H7451"\w*.”
\p 
\v 9 \w One|strong="H2088"\w* \w of|strong="H1121"\w* David’s boss \w soldiers|strong="H1121"\w* \w was|strong="H4428"\w* Abishai. \w He|strong="H2088"\w* \w was|strong="H4428"\w* \w the|strong="H5674"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Zeruiah|strong="H6870"\w*, David’s sister. \w He|strong="H2088"\w* said, “Boss. \w That|strong="H4428"\w* \w man|strong="H1121"\w* \w is|strong="H2088"\w* \w no|strong="H7218"\w* \w good|strong="H4100"\w*. \w He|strong="H2088"\w* \w can|strong="H4100"\w*’t swear \w at|strong="H4428"\w* \w you|strong="H4100"\w* \w like|strong="H1121"\w* \w that|strong="H4428"\w*. \w Let|strong="H4994"\w* \w me|strong="H4994"\w* \w cut|strong="H5493"\w* \w off|strong="H5493"\w* \w his|strong="H5493"\w* \w head|strong="H7218"\w*.”
\p 
\v 10 \w David|strong="H1732"\w* \w said|strong="H3651"\w* \w to|strong="H3068"\w* Abishai, \w and|strong="H1121"\w* \w to|strong="H3068"\w* Abishai’s brother Joab, “Don’t \w do|strong="H6213"\w* \w it|strong="H6213"\w*. \w It|strong="H6213"\w*’s got \w nothing|strong="H4100"\w* \w to|strong="H3068"\w* \w do|strong="H6213"\w* \w with|strong="H3068"\w* \w you|strong="H3588"\w* 2. Maybe \w God|strong="H3068"\w* \w himself|strong="H6213"\w* \w told|strong="H6213"\w* \w him|strong="H6213"\w*, ‘\w Go|strong="H3068"\w* \w and|strong="H1121"\w* \w swear|strong="H3588"\w* \w at|strong="H3068"\w* \w David|strong="H1732"\w*.’ \w If|strong="H3588"\w* \w God|strong="H3068"\w* \w told|strong="H6213"\w* \w him|strong="H6213"\w* \w to|strong="H3068"\w* \w do|strong="H6213"\w* \w that|strong="H3588"\w*, nobody \w can|strong="H4310"\w* stop \w him|strong="H6213"\w*.”
\b
\iex (We have not yet translated 16:11-14.)
\s1 The Absalom mob arrived in Jerusalem
\p 
\v 15 \w On|strong="H3605"\w* \w that|strong="H5971"\w* same day, David’s son, Absalom, \w came|strong="H3478"\w* \w to|strong="H3478"\w* \w Jerusalem|strong="H3389"\w* \w with|strong="H3389"\w* \w a|strong="H3068"\w* lot \w of|strong="H5971"\w* \w Israel|strong="H3478"\w* \w soldiers|strong="H5971"\w*. Ahithofel, \w that|strong="H5971"\w* wise old \w man|strong="H3605"\w*, \w he|strong="H3605"\w* \w was|strong="H3478"\w* \w with|strong="H3389"\w* \w him|strong="H3605"\w* too.
\v 16 \w Then|strong="H1961"\w* \w David|strong="H1732"\w*’s \w friend|strong="H7463"\w*, \w Hushai|strong="H2365"\w*, \w went|strong="H1732"\w* \w to|strong="H1961"\w* meet Absalom. \w He|strong="H1732"\w* called out, “Boss Absalom, \w you|strong="H1961"\w* \w are|strong="H4428"\w* \w great|strong="H7463"\w*. \w You|strong="H1961"\w* \w have|strong="H1961"\w* \w to|strong="H1961"\w* \w be|strong="H1961"\w* \w the|strong="H1961"\w* big boss \w for|strong="H4428"\w* ever.” \w But|strong="H1961"\w* \w he|strong="H1732"\w* told \w a|strong="H3068"\w* \w lie|strong="H1961"\w*. \w He|strong="H1732"\w* \w was|strong="H1961"\w* still working \w for|strong="H4428"\w* \w David|strong="H1732"\w*.
\p 
\v 17 Absalom said, “\w You|strong="H3808"\w* \w are|strong="H4100"\w* \w a|strong="H3068"\w* \w friend|strong="H7453"\w* \w of|strong="H2617"\w* David. \w You|strong="H3808"\w* used \w to|strong="H1980"\w* \w follow|strong="H1980"\w* \w him|strong="H2088"\w*. \w So|strong="H1980"\w* \w how|strong="H4100"\w* \w come|strong="H1980"\w* \w you|strong="H3808"\w* \w are|strong="H4100"\w* \w not|strong="H3808"\w* \w with|strong="H1980"\w* \w him|strong="H2088"\w* \w now|strong="H2088"\w*?”
\p 
\v 18 \w But|strong="H3588"\w* \w Hushai|strong="H2365"\w* lied \w again|strong="H1961"\w* \w and|strong="H3478"\w* said, “\w I|strong="H3588"\w* \w can|strong="H3808"\w*’t \w follow|strong="H1961"\w* \w him|strong="H3605"\w* \w any|strong="H3605"\w* \w more|strong="H3808"\w*. \w You|strong="H3588"\w* \w are|strong="H5971"\w* \w the|strong="H3605"\w* big boss \w now|strong="H1961"\w*. \w God|strong="H3068"\w* \w and|strong="H3478"\w* \w the|strong="H3605"\w* \w Israel|strong="H3478"\w* mob, \w they|strong="H3588"\w* \w have|strong="H1961"\w* picked \w you|strong="H3588"\w* \w to|strong="H3478"\w* \w be|strong="H1961"\w* \w the|strong="H3605"\w* big boss. \w I|strong="H3588"\w* \w belong|strong="H1961"\w* \w to|strong="H3478"\w* \w you|strong="H3588"\w*.
\v 19 \w This|strong="H3651"\w* \w is|strong="H4310"\w* \w the|strong="H6440"\w* best \w way|strong="H6440"\w* \w for|strong="H6440"\w* \w me|strong="H6440"\w* \w now|strong="H1961"\w*. \w I|strong="H3651"\w* \w will|strong="H4310"\w* \w work|strong="H5647"\w* \w for|strong="H6440"\w* \w you|strong="H6440"\w*, just \w like|strong="H1961"\w* \w I|strong="H3651"\w* \w worked|strong="H5647"\w* \w for|strong="H6440"\w* \w your|strong="H6440"\w* \w father|strong="H1121"\w*.” \w And|strong="H1121"\w* Absalom believed \w him|strong="H6440"\w*.
\p 
\v 20 \w So|strong="H6213"\w* Absalom said \w to|strong="H6213"\w* \w that|strong="H6213"\w* wise man, Ahithofel, “\w All|strong="H6213"\w* right, tell \w us|strong="H3051"\w*, \w what|strong="H4100"\w* \w do|strong="H6213"\w* \w we|strong="H3068"\w* \w do|strong="H6213"\w* first?”
\p 
\v 21 \w He|strong="H3588"\w* \w answered|strong="H8085"\w*, “10 \w of|strong="H1004"\w* \w your|strong="H3605"\w* father’s wives \w stayed|strong="H3478"\w* behind \w to|strong="H3478"\w* look \w after|strong="H3588"\w* \w the|strong="H3605"\w* \w house|strong="H1004"\w*. \w You|strong="H3588"\w* \w have|strong="H3478"\w* \w to|strong="H3478"\w* sleep \w with|strong="H1004"\w* \w them|strong="H3027"\w*, \w as|strong="H3588"\w* \w if|strong="H3588"\w* \w you|strong="H3588"\w* \w are|strong="H3478"\w* married \w to|strong="H3478"\w* \w them|strong="H3027"\w*. \w If|strong="H3588"\w* \w you|strong="H3588"\w* \w do|strong="H8104"\w* \w that|strong="H3588"\w*, \w you|strong="H3588"\w* \w will|strong="H3478"\w* \w make|strong="H8085"\w* \w your|strong="H3605"\w* father ashamed, \w and|strong="H3478"\w* \w he|strong="H3588"\w* \w will|strong="H3478"\w* hate \w you|strong="H3588"\w* properly. \w Then|strong="H8085"\w* everybody \w will|strong="H3478"\w* know \w that|strong="H3588"\w* \w you|strong="H3588"\w* \w are|strong="H3478"\w* \w the|strong="H3605"\w* big boss \w in|strong="H3478"\w* \w his|strong="H3605"\w* \w house|strong="H1004"\w* \w now|strong="H3588"\w*. Everybody \w will|strong="H3478"\w* \w hear|strong="H8085"\w* \w that|strong="H3588"\w* \w you|strong="H3588"\w* \w were|strong="H3478"\w* really brave, \w and|strong="H3478"\w* \w that|strong="H3588"\w* \w you|strong="H3588"\w* \w did|strong="H3478"\w* \w it|strong="H3588"\w* \w in|strong="H3478"\w* \w the|strong="H3605"\w* open. \w Then|strong="H8085"\w* \w they|strong="H3588"\w* \w will|strong="H3478"\w* follow \w you|strong="H3588"\w*.”
\v 22 \w So|strong="H5921"\w* \w the|strong="H3605"\w* workers \w put|strong="H5186"\w* \w up|strong="H5921"\w* \w a|strong="H3068"\w* tent \w on|strong="H5921"\w* \w the|strong="H3605"\w* flat \w roof|strong="H1406"\w* \w of|strong="H5869"\w* David’s big \w house|strong="H1406"\w*. Absalom \w went|strong="H3478"\w* \w into|strong="H5921"\w* \w the|strong="H3605"\w* tent \w and|strong="H3478"\w* slept \w with|strong="H5921"\w* \w his|strong="H3605"\w* father’s wives \w one|strong="H3605"\w* \w by|strong="H5921"\w* \w one|strong="H3605"\w*, \w just|strong="H3605"\w* \w like|strong="H3478"\w* \w he|strong="H3605"\w* \w was|strong="H3478"\w* married \w to|strong="H3478"\w* \w them|strong="H5921"\w*. \w And|strong="H3478"\w* \w a|strong="H3068"\w* lot \w of|strong="H5869"\w* \w people|strong="H5869"\w* saw \w him|strong="H5921"\w* \w do|strong="H5869"\w* \w that|strong="H3605"\w*, \w and|strong="H3478"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w Israel|strong="H3478"\w* mob heard \w about|strong="H5921"\w* \w it|strong="H5921"\w*.\x * \xo 16:22 \xt 2 Samuel 12:11-12\x*
\p 
\v 23 \w So|strong="H3651"\w* Absalom \w took|strong="H3289"\w* notice \w of|strong="H3117"\w* \w that|strong="H3605"\w* wise \w man|strong="H3605"\w*’s story, \w just|strong="H1697"\w* \w like|strong="H3651"\w* \w his|strong="H3605"\w* father \w used|strong="H3605"\w* \w to|strong="H3117"\w* \w take|strong="H3289"\w* notice \w of|strong="H3117"\w* \w him|strong="H3605"\w*. \w They|strong="H1992"\w* \w both|strong="H1571"\w* \w thought|strong="H1697"\w* \w that|strong="H3605"\w* \w he|strong="H3117"\w* talked straight, \w just|strong="H1697"\w* \w like|strong="H3651"\w* God \w does|strong="H1571"\w*. \w So|strong="H3651"\w* \w they|strong="H1992"\w* \w always|strong="H3605"\w* listened \w to|strong="H3117"\w* \w him|strong="H3605"\w* \w carefully|strong="H3605"\w*.
\c 17
\p 
\v 1 \w That|strong="H1732"\w* wise man, Ahithofel, said \w to|strong="H1732"\w* \w David|strong="H1732"\w*’s son Absalom, “\w Let|strong="H4994"\w* \w me|strong="H4994"\w* pick 12,000 soldiers. \w We|strong="H4994"\w* \w will|strong="H8147"\w* \w chase|strong="H7291"\w* \w your|strong="H4994"\w* father \w tonight|strong="H3915"\w*.
\v 2 Right \w now|strong="H5921"\w* \w he|strong="H1931"\w*’s upset \w and|strong="H4428"\w* tired. \w We|strong="H3605"\w* \w will|strong="H4428"\w* suddenly \w come|strong="H2729"\w* \w and|strong="H4428"\w* \w attack|strong="H5221"\w* \w his|strong="H3605"\w* mob, \w and|strong="H4428"\w* \w they|strong="H5921"\w* \w will|strong="H4428"\w* \w get|strong="H3027"\w* \w a|strong="H3068"\w* shock. \w All|strong="H3605"\w* \w his|strong="H3605"\w* mob \w will|strong="H4428"\w* \w run|strong="H5127"\w* \w away|strong="H5127"\w*. \w He|strong="H1931"\w*’s \w the|strong="H3605"\w* \w only|strong="H3605"\w* \w one|strong="H3605"\w* \w I|strong="H5921"\w* \w will|strong="H4428"\w* \w kill|strong="H5221"\w* dead.
\v 3 \w I|strong="H5971"\w* \w will|strong="H1961"\w* gather \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w other|strong="H3605"\w* \w men|strong="H5971"\w* \w together|strong="H5971"\w* \w and|strong="H7725"\w* \w bring|strong="H7725"\w* \w them|strong="H7725"\w* \w back|strong="H7725"\w* here \w to|strong="H7725"\w* \w you|strong="H3605"\w*. \w They|strong="H5971"\w* \w will|strong="H1961"\w* see \w that|strong="H5971"\w* \w their|strong="H3605"\w* boss \w is|strong="H3605"\w* dead, \w and|strong="H7725"\w* \w then|strong="H1961"\w* \w you|strong="H3605"\w* \w will|strong="H1961"\w* \w be|strong="H1961"\w* \w their|strong="H3605"\w* boss. \w We|strong="H7725"\w* \w will|strong="H1961"\w* \w not|strong="H1961"\w* hurt \w any|strong="H3605"\w* \w of|strong="H5971"\w* \w them|strong="H7725"\w*. \w They|strong="H5971"\w* \w will|strong="H1961"\w* \w all|strong="H3605"\w* \w be|strong="H1961"\w* \w safe|strong="H7965"\w*.”
\p 
\v 4 Absalom \w and|strong="H3478"\w* \w the|strong="H3605"\w* \w elders|strong="H2205"\w* \w of|strong="H1697"\w* \w Israel|strong="H3478"\w* \w agreed|strong="H3474"\w*. \w They|strong="H1697"\w* \w said|strong="H1697"\w*, “\w This|strong="H1697"\w* \w is|strong="H1697"\w* \w a|strong="H3068"\w* \w good|strong="H3474"\w* \w plan|strong="H1697"\w*.”
\s1 Hushai tricked Absalom
\p 
\v 5 \w Then|strong="H1571"\w* Absalom \w said|strong="H7121"\w*, “\w All|strong="H6310"\w* \w right|strong="H1571"\w*, \w what|strong="H4100"\w* \w about|strong="H8085"\w* \w that|strong="H8085"\w* man \w Hushai|strong="H2365"\w*, \w from|strong="H8085"\w* \w the|strong="H8085"\w* Arek mob? \w Tell|strong="H8085"\w* \w him|strong="H7121"\w* \w to|strong="H8085"\w* \w come|strong="H4994"\w* here. \w We|strong="H8085"\w* \w will|strong="H1571"\w* \w listen|strong="H8085"\w* \w to|strong="H8085"\w* \w him|strong="H7121"\w* \w too|strong="H1571"\w*.”
\p 
\v 6 \w Hushai|strong="H2365"\w* \w came|strong="H1697"\w*, \w and|strong="H6213"\w* Absalom \w told|strong="H1696"\w* \w him|strong="H6213"\w* \w the|strong="H6213"\w* \w things|strong="H1697"\w* Ahithofel \w said|strong="H1696"\w*. \w Then|strong="H1696"\w* \w he|strong="H6213"\w* \w asked|strong="H1696"\w* \w Hushai|strong="H2365"\w*, “\w So|strong="H6213"\w* \w what|strong="H1697"\w* \w do|strong="H6213"\w* \w you|strong="H6213"\w* think? \w Can|strong="H6213"\w* \w we|strong="H3068"\w* listen \w to|strong="H1696"\w* \w his|strong="H6213"\w* \w plan|strong="H1697"\w*? \w Or|strong="H6213"\w* maybe \w not|strong="H6213"\w*? \w What|strong="H1697"\w* \w do|strong="H6213"\w* \w you|strong="H6213"\w* reckon?”
\p 
\v 7 \w Hushai|strong="H2365"\w* lied \w and|strong="H2896"\w* answered, “\w That|strong="H3808"\w* \w old|strong="H2896"\w* \w man|strong="H2896"\w* usually talks straight. \w But|strong="H3808"\w* \w not|strong="H3808"\w* today. \w That|strong="H3808"\w* \w plan|strong="H6098"\w* \w he|strong="H3808"\w* just told \w you|strong="H3808"\w*, \w it|strong="H3808"\w*’s \w no|strong="H3808"\w* \w good|strong="H2896"\w*.
\v 8 \w You|strong="H3588"\w* \w know|strong="H3045"\w* \w that|strong="H3588"\w* \w your|strong="H3045"\w* father \w and|strong="H5971"\w* \w his|strong="H3045"\w* \w men|strong="H1368"\w* \w are|strong="H1992"\w* \w strong|strong="H1368"\w* \w soldiers|strong="H4421"\w*. \w They|strong="H1992"\w* \w are|strong="H1992"\w* good fighters, \w like|strong="H3808"\w* cheeky \w wild|strong="H7704"\w* animals. \w And|strong="H5971"\w* \w he|strong="H3588"\w* \w really|strong="H1992"\w* \w knows|strong="H3045"\w* \w what|strong="H3045"\w* \w he|strong="H3588"\w* \w is|strong="H5315"\w* doing \w too|strong="H3808"\w*. \w He|strong="H3588"\w* always sleeps \w a|strong="H3068"\w* \w long|strong="H5315"\w* way \w from|strong="H5315"\w* \w the|strong="H3588"\w* \w soldiers|strong="H4421"\w*, \w so|strong="H3808"\w* \w he|strong="H3588"\w* \w will|strong="H5971"\w* \w stay|strong="H3885"\w* safe.
\v 9 Maybe \w he|strong="H1931"\w* \w will|strong="H1961"\w* \w go|strong="H5971"\w* \w and|strong="H5971"\w* \w hide|strong="H2244"\w* \w in|strong="H8085"\w* \w a|strong="H3068"\w* cave \w in|strong="H8085"\w* \w the|strong="H8085"\w* hills. Nobody can find \w him|strong="H1931"\w* \w there|strong="H2009"\w*. \w But|strong="H1961"\w* \w then|strong="H1961"\w* \w he|strong="H1931"\w* \w and|strong="H5971"\w* \w his|strong="H8085"\w* \w soldiers|strong="H5971"\w* \w might|strong="H5971"\w* \w suddenly|strong="H2009"\w* \w come|strong="H1961"\w* \w and|strong="H5971"\w* attack \w your|strong="H8085"\w* mob \w of|strong="H5971"\w* \w soldiers|strong="H5971"\w*. Lots \w of|strong="H5971"\w* \w your|strong="H8085"\w* \w men|strong="H5971"\w* \w might|strong="H5971"\w* \w die|strong="H5307"\w*. Everybody \w will|strong="H1961"\w* \w hear|strong="H8085"\w* \w about|strong="H1961"\w* \w it|strong="H1931"\w* \w and|strong="H5971"\w* think, ‘Hey, \w look|strong="H2009"\w* \w out|strong="H5307"\w*. David’s mob finished \w up|strong="H1961"\w* Absalom’s mob.’
\v 10 Everybody \w knows|strong="H3045"\w* \w that|strong="H3588"\w* David \w and|strong="H1121"\w* \w his|strong="H3605"\w* \w men|strong="H1368"\w* \w are|strong="H1121"\w* \w brave|strong="H2428"\w* \w and|strong="H1121"\w* \w strong|strong="H2428"\w*. \w If|strong="H3588"\w* \w your|strong="H3605"\w* \w other|strong="H3605"\w* \w soldiers|strong="H2428"\w* \w think|strong="H3820"\w* \w he|strong="H1931"\w* beat \w our|strong="H3605"\w* mob, \w they|strong="H3588"\w* \w will|strong="H3478"\w* \w be|strong="H1121"\w* afraid. \w Even|strong="H1571"\w* \w the|strong="H3605"\w* \w brave|strong="H2428"\w* \w ones|strong="H1368"\w* \w will|strong="H3478"\w* \w be|strong="H1121"\w* afraid.
\p 
\v 11 \w No|strong="H3605"\w*, \w this|strong="H3588"\w* \w is|strong="H3478"\w* \w what|strong="H3588"\w* \w I|strong="H3588"\w* reckon. \w We|strong="H3588"\w* \w have|strong="H3478"\w* \w to|strong="H5704"\w* gather \w more|strong="H7230"\w* soldiers \w together|strong="H5921"\w* \w from|strong="H6440"\w* \w all|strong="H3605"\w* \w over|strong="H5921"\w* \w this|strong="H3588"\w* country, \w Israel|strong="H3478"\w*. Gather lots \w of|strong="H6440"\w* \w them|strong="H5921"\w* \w together|strong="H5921"\w*, \w too|strong="H5921"\w* \w many|strong="H7230"\w* \w to|strong="H5704"\w* count. \w You|strong="H3588"\w* \w are|strong="H3478"\w* \w their|strong="H3605"\w* big boss, \w so|strong="H1980"\w* \w you|strong="H3588"\w* \w have|strong="H3478"\w* \w to|strong="H5704"\w* \w lead|strong="H1980"\w* \w them|strong="H5921"\w* \w yourself|strong="H5921"\w*.
\v 12 \w Your|strong="H3605"\w* father \w can|strong="H3808"\w*’t hide \w from|strong="H5921"\w* \w us|strong="H5921"\w*. \w We|strong="H8033"\w* \w will|strong="H1571"\w* \w find|strong="H4672"\w* \w him|strong="H5921"\w*, \w and|strong="H8033"\w* \w we|strong="H3068"\w* \w will|strong="H1571"\w* quickly \w go|strong="H5117"\w* \w all|strong="H3605"\w* \w around|strong="H5921"\w* \w him|strong="H5921"\w*, \w and|strong="H8033"\w* \w then|strong="H5307"\w* \w we|strong="H3068"\w* \w will|strong="H1571"\w* attack \w him|strong="H5921"\w*. \w He|strong="H8033"\w* \w and|strong="H8033"\w* \w all|strong="H3605"\w* \w his|strong="H3605"\w* \w men|strong="H3605"\w* \w will|strong="H1571"\w* \w die|strong="H5307"\w*.
\v 13 \w If|strong="H1931"\w* \w he|strong="H1931"\w* \w is|strong="H1931"\w* hiding \w in|strong="H3478"\w* \w a|strong="H3068"\w* \w town|strong="H5892"\w*, \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w Israel|strong="H3478"\w* mob \w will|strong="H3478"\w* break \w the|strong="H3605"\w* wall \w and|strong="H3478"\w* \w the|strong="H3605"\w* houses \w of|strong="H5892"\w* \w that|strong="H3605"\w* \w town|strong="H5892"\w*. \w We|strong="H5704"\w* \w will|strong="H3478"\w* \w get|strong="H4672"\w* \w ropes|strong="H2256"\w*, \w and|strong="H3478"\w* \w we|strong="H3068"\w* \w will|strong="H3478"\w* \w drag|strong="H5498"\w* \w their|strong="H3605"\w* stones \w away|strong="H5375"\w*. \w There|strong="H8033"\w* \w will|strong="H3478"\w* \w not|strong="H3808"\w* \w even|strong="H1571"\w* \w be|strong="H3808"\w* \w a|strong="H3068"\w* \w small|strong="H1571"\w* \w stone|strong="H6872"\w* \w left|strong="H4672"\w*. \w We|strong="H5704"\w* \w will|strong="H3478"\w* \w do|strong="H3605"\w* \w that|strong="H3605"\w* \w until|strong="H5704"\w* \w we|strong="H3068"\w* \w find|strong="H4672"\w* \w him|strong="H4672"\w*.”
\p 
\v 14 Absalom \w and|strong="H3478"\w* \w the|strong="H3605"\w* elders \w of|strong="H3068"\w* \w Israel|strong="H3478"\w* heard \w what|strong="H2896"\w* \w Hushai|strong="H2365"\w* said, \w and|strong="H3478"\w* \w they|strong="H3068"\w* reckoned, “\w Hushai|strong="H2365"\w* \w from|strong="H3478"\w* \w the|strong="H3605"\w* Arek mob \w has|strong="H3068"\w* \w a|strong="H3068"\w* \w good|strong="H2896"\w* idea. \w It|strong="H6680"\w* \w is|strong="H3068"\w* \w better|strong="H2896"\w* \w than|strong="H2896"\w* \w the|strong="H3605"\w* \w other|strong="H3605"\w* \w plan|strong="H6098"\w* \w of|strong="H3068"\w* \w that|strong="H3605"\w* wise \w man|strong="H7451"\w* Ahithofel.” \w You|strong="H6680"\w* see, \w God|strong="H3068"\w* \w himself|strong="H3068"\w* \w made|strong="H6565"\w* \w them|strong="H6680"\w* think \w like|strong="H3478"\w* \w that|strong="H3605"\w*. \w He|strong="H3068"\w* wanted \w them|strong="H6680"\w* \w to|strong="H3478"\w* \w follow|strong="H3068"\w* \w Hushai|strong="H2365"\w*’s \w plan|strong="H6098"\w*, \w and|strong="H3478"\w* \w so|strong="H5668"\w* make big \w trouble|strong="H7451"\w* \w for|strong="H3068"\w* Absalom. \w God|strong="H3068"\w* confused \w them|strong="H6680"\w*, \w so|strong="H5668"\w* \w they|strong="H3068"\w* \w did|strong="H3478"\w* \w not|strong="H7451"\w* \w like|strong="H3478"\w* Ahithofel’s \w good|strong="H2896"\w* \w plan|strong="H6098"\w*.
\b
\iex (We have not yet translated 17:15-29.)
\c 18
\s1 David’s mob beat Absalom’s mob
\p 
\v 1-2 David gathered his soldiers together, and he split them into 3 big groups. He picked \w a|strong="H3068"\w* boss soldier to lead each group. They were Joab, and his brother Abishai, and Ittai, \w a|strong="H3068"\w* man that used to live in \w a|strong="H3068"\w* town called Gath. David told each big group to split into mobs with 1,000 men in each. And he picked one boss soldier for each mob of 1,000 soldiers. Then he told each of those mobs to do it again. This time each of them split into little groups with 100 men in each. David picked \w a|strong="H3068"\w* boss soldier for each group of 100 soldiers.
\p Then David said to everybody, “Let’s go and fight Absalom’s mob. I will go with you mob.”
\p 
\v 3 \w But|strong="H3588"\w* \w the|strong="H3588"\w* \w soldiers|strong="H5971"\w* \w said|strong="H3318"\w* \w to|strong="H3318"\w* \w him|strong="H7760"\w*, “\w No|strong="H3808"\w* way. \w You|strong="H3588"\w* \w can|strong="H3808"\w*’t \w come|strong="H1961"\w* \w with|strong="H3318"\w* \w us|strong="H7760"\w*. \w You|strong="H3588"\w* \w are|strong="H5971"\w* \w the|strong="H3588"\w* boss \w man|strong="H4191"\w*, \w but|strong="H3588"\w* \w we|strong="H3068"\w* \w are|strong="H5971"\w* \w just|strong="H6258"\w* \w nothing|strong="H3808"\w*. \w You|strong="H3588"\w* \w are|strong="H5971"\w* \w the|strong="H3588"\w* \w one|strong="H3808"\w* \w they|strong="H3588"\w* \w want|strong="H3808"\w* \w to|strong="H3318"\w* \w kill|strong="H4191"\w*. \w If|strong="H3588"\w* \w we|strong="H3068"\w* \w soldiers|strong="H5971"\w* \w all|strong="H4191"\w* \w run|strong="H5127"\w* \w away|strong="H5127"\w*, \w they|strong="H3588"\w* \w will|strong="H1961"\w* \w not|strong="H3808"\w* chase \w us|strong="H7760"\w*. \w If|strong="H3588"\w* \w we|strong="H3068"\w* \w all|strong="H4191"\w* \w die|strong="H4191"\w*, \w they|strong="H3588"\w* \w will|strong="H1961"\w* \w not|strong="H3808"\w* \w care|strong="H7760"\w*. \w They|strong="H3588"\w* \w will|strong="H1961"\w* say, ‘\w All|strong="H4191"\w* \w right|strong="H2896"\w*, \w leave|strong="H3318"\w* \w them|strong="H7760"\w*.’ \w But|strong="H3588"\w* \w if|strong="H3588"\w* \w you|strong="H3588"\w* \w die|strong="H4191"\w*, \w they|strong="H3588"\w* \w will|strong="H1961"\w* \w be|strong="H1961"\w* \w really|strong="H7760"\w* \w happy|strong="H2896"\w*. \w So|strong="H1961"\w* \w it|strong="H7760"\w*’s \w good|strong="H2896"\w* \w for|strong="H3588"\w* \w you|strong="H3588"\w* \w to|strong="H3318"\w* stay \w here|strong="H6258"\w* \w in|strong="H4191"\w* \w this|strong="H6258"\w* \w town|strong="H5892"\w*. \w If|strong="H3588"\w* \w the|strong="H3588"\w* fighting gets \w hard|strong="H5971"\w* \w for|strong="H3588"\w* \w us|strong="H7760"\w*, \w then|strong="H1961"\w* \w you|strong="H3588"\w* \w can|strong="H3808"\w* \w send|strong="H3318"\w* \w more|strong="H3808"\w* \w soldiers|strong="H5971"\w* \w to|strong="H3318"\w* \w help|strong="H5826"\w* \w us|strong="H7760"\w*.”
\p 
\v 4-5 David said, “All right, I will listen to what you mob say.” And he called out loud to the 3 boss soldiers, so everybody could hear. He said, “Joab. Abishai. Ittai. Don’t hurt that young man, Absalom. Don’t forget, he’s my son.”
\p And he stood at the gate and watched the soldiers as they left that town.
\p 
\v 6 David’s mob \w went|strong="H3318"\w* \w away|strong="H3318"\w* \w from|strong="H3318"\w* \w the|strong="H3318"\w* town, \w and|strong="H3478"\w* \w they|strong="H5971"\w* \w met|strong="H7125"\w* \w the|strong="H3318"\w* \w Israel|strong="H3478"\w* mob \w in|strong="H3478"\w* \w the|strong="H3318"\w* bush \w at|strong="H3478"\w* \w a|strong="H3068"\w* \w place|strong="H1961"\w* called Ephraim.
\v 7-8 They chased each other in the bush, and they attacked each other with spears and bows and arrows. David’s mob beat Absalom’s mob and killed lots of them dead. But even more soldiers died from things in the bush. 20,000 men died on that day.
\p 
\v 9 \w While|strong="H5921"\w* \w they|strong="H5921"\w* \w were|strong="H8064"\w* fighting, \w David|strong="H1732"\w*’s son Absalom \w rode|strong="H7392"\w* \w around|strong="H5921"\w* \w in|strong="H5921"\w* \w the|strong="H6440"\w* bush \w on|strong="H5921"\w* \w a|strong="H3068"\w* donkey. \w He|strong="H1732"\w* suddenly \w met|strong="H7122"\w* some \w of|strong="H7218"\w* \w David|strong="H1732"\w*’s \w men|strong="H1419"\w*, \w and|strong="H1419"\w* \w he|strong="H1732"\w* tried \w to|strong="H5921"\w* get \w away|strong="H5674"\w*. \w The|strong="H6440"\w* donkey \w ran|strong="H7218"\w* \w under|strong="H8478"\w* \w a|strong="H3068"\w* big tree, \w and|strong="H1419"\w* Absalom’s \w head|strong="H7218"\w* got stuck \w in|strong="H5921"\w* \w the|strong="H6440"\w* \w branches|strong="H7730"\w*. \w The|strong="H6440"\w* donkey \w kept|strong="H5414"\w* \w on|strong="H5921"\w* running, \w so|strong="H5414"\w* Absalom \w was|strong="H1732"\w* \w left|strong="H5414"\w* \w there|strong="H6440"\w*. \w He|strong="H1732"\w* \w hung|strong="H5414"\w* \w from|strong="H6440"\w* \w the|strong="H6440"\w* tree \w and|strong="H1419"\w* couldn’t get \w down|strong="H6440"\w*. \fig Absalom’s head got stuck in a tree|src="CO01086b.tif" size="col" copy="1996 David C. Cook" ref="18:9"\fig*
\p 
\v 10 \w One|strong="H7200"\w* \w of|strong="H7200"\w* David’s men \w saw|strong="H7200"\w* \w him|strong="H5046"\w*, \w and|strong="H7200"\w* \w he|strong="H7200"\w* \w went|strong="H7200"\w* \w to|strong="H7200"\w* \w the|strong="H7200"\w* boss soldier, \w Joab|strong="H3097"\w*, \w and|strong="H7200"\w* said, “\w I|strong="H2009"\w* just \w saw|strong="H7200"\w* Absalom \w hanging|strong="H8518"\w* \w from|strong="H7200"\w* \w a|strong="H3068"\w* tree.”
\p 
\v 11 \w Joab|strong="H3097"\w* said, “\w What|strong="H7200"\w*? \w You|strong="H5414"\w* really \w saw|strong="H7200"\w* \w him|strong="H5414"\w* \w like|strong="H3808"\w* \w that|strong="H7200"\w*? \w Why|strong="H4069"\w* didn’t \w you|strong="H5414"\w* \w kill|strong="H5221"\w* \w him|strong="H5414"\w* dead straight \w away|strong="H5414"\w*? \w I|strong="H5414"\w* \w will|strong="H5414"\w* \w give|strong="H5414"\w* lots \w of|strong="H5921"\w* \w money|strong="H3701"\w* \w and|strong="H3701"\w* \w a|strong="H3068"\w* boss soldier’s \w belt|strong="H2290"\w* \w to|strong="H5921"\w* \w a|strong="H3068"\w* \w man|strong="H7200"\w* \w that|strong="H7200"\w* \w does|strong="H3808"\w* something \w like|strong="H3808"\w* \w that|strong="H7200"\w*.”
\p 
\v 12 \w But|strong="H3588"\w* \w the|strong="H5921"\w* \w man|strong="H5288"\w* said, “\w I|strong="H3588"\w* \w can|strong="H4310"\w*’t \w do|strong="H8104"\w* \w that|strong="H3588"\w*. \w Yes|strong="H3588"\w*, \w I|strong="H3588"\w* \w might|strong="H1121"\w* \w get|strong="H3027"\w* lots \w of|strong="H1121"\w* \w money|strong="H3701"\w*, \w but|strong="H3588"\w* \w I|strong="H3588"\w* \w can|strong="H4310"\w*’t kill \w our|strong="H5921"\w* big boss’s \w son|strong="H1121"\w*. \w No|strong="H3808"\w* \w way|strong="H7971"\w*. \w We|strong="H3588"\w* \w all|strong="H5921"\w* \w heard|strong="H3588"\w* \w him|strong="H5921"\w* tell \w you|strong="H3588"\w* 3 boss \w soldiers|strong="H5288"\w*, ‘\w Keep|strong="H8104"\w* \w that|strong="H3588"\w* \w young|strong="H5288"\w* \w man|strong="H5288"\w*, Absalom, safe. Don’t forget, \w he|strong="H3588"\w*’s \w my|strong="H8104"\w* \w son|strong="H1121"\w*.’
\v 13 If \w I|strong="H1697"\w* kill \w him|strong="H6213"\w*, \w his|strong="H3605"\w* father \w will|strong="H4428"\w* hear \w about|strong="H1697"\w* \w it|strong="H6213"\w* \w straight|strong="H5048"\w* \w away|strong="H4480"\w*. \w He|strong="H6213"\w* knows \w everything|strong="H3605"\w*, \w and|strong="H4428"\w* \w he|strong="H6213"\w* \w will|strong="H4428"\w* kill \w me|strong="H5315"\w* \w dead|strong="H5315"\w* \w too|strong="H4480"\w*. \w And|strong="H4428"\w* \w I|strong="H1697"\w* reckon \w you|strong="H3605"\w* might \w not|strong="H3808"\w* \w help|strong="H4480"\w* \w me|strong="H5315"\w* \w either|strong="H4480"\w*. \w You|strong="H3605"\w* might \w say|strong="H1697"\w* \w to|strong="H6213"\w* \w him|strong="H6213"\w*, ‘\w It|strong="H6213"\w*’s \w nothing|strong="H3808"\w* \w to|strong="H6213"\w* \w do|strong="H6213"\w* \w with|strong="H6213"\w* \w me|strong="H5315"\w*.’”
\p 
\v 14 \w Joab|strong="H3097"\w* \w was|strong="H3820"\w* angry, \w and|strong="H6440"\w* \w he|strong="H3651"\w* \w said|strong="H3651"\w*, “\w I|strong="H3651"\w* \w can|strong="H3947"\w*’t \w wait|strong="H3176"\w* \w for|strong="H6440"\w* \w you|strong="H6440"\w* \w all|strong="H5750"\w* day.” \w And|strong="H6440"\w* \w he|strong="H3651"\w* \w got|strong="H3947"\w* 3 \w spears|strong="H7626"\w* \w and|strong="H6440"\w* \w went|strong="H6440"\w* \w to|strong="H3820"\w* Absalom. \w He|strong="H3651"\w* \w was|strong="H3820"\w* \w still|strong="H5750"\w* \w alive|strong="H2416"\w* \w and|strong="H6440"\w* hanging \w there|strong="H6440"\w* \w in|strong="H6440"\w* \w that|strong="H3651"\w* tree.
\p \w Joab|strong="H3097"\w* \w went|strong="H6440"\w* \w and|strong="H6440"\w* stabbed \w him|strong="H6440"\w* 3 \w times|strong="H6440"\w* \w in|strong="H6440"\w* \w the|strong="H6440"\w* chest.
\v 15 10 \w men|strong="H5288"\w* \w went|strong="H5437"\w* \w with|strong="H3627"\w* \w Joab|strong="H3097"\w*, \w and|strong="H5288"\w* \w they|strong="H5375"\w* finished Absalom properly.
\p 
\v 16 Straight \w away|strong="H7725"\w*, \w Joab|strong="H3097"\w* \w blew|strong="H8628"\w* \w the|strong="H3588"\w* \w trumpet|strong="H7782"\w*, \w to|strong="H7725"\w* tell David’s mob \w to|strong="H7725"\w* stop \w chasing|strong="H7291"\w* \w the|strong="H3588"\w* \w Israel|strong="H3478"\w* mob.
