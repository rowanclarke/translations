\v 30 \nd \w Yavé|strong="H3068"\w*\nd* resonará la majestad de su \w voz|strong="H6963"\w* y \w mostrará|strong="H7200"\w* su \w brazo|strong="H2220"\w* que descarga con furor su ira con llamas de fuego devorador, con aguacero, tempestad y \w granizo|strong="H1259"\w*.
\v 31 \w Pues|strong="H3588"\w* Asiria será destrozada \w por|strong="H3588"\w* causa \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w voz|strong="H6963"\w* \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd*. \w Él|strong="H3588"\w* \w hiere|strong="H5221"\w* \w con|strong="H3588"\w* \w la|strong="H3588"\w* \w vara|strong="H7626"\w*.
\v 32 \w Cada|strong="H3605"\w* golpe \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w vara|strong="H4294"\w* justiciera \w que|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* descargue \w en|strong="H5921"\w* \w ella|strong="H3605"\w* \w será|strong="H1961"\w* acompañado \w con|strong="H5921"\w* panderos \w y|strong="H5921"\w* \w arpas|strong="H3658"\w*. \w En|strong="H5921"\w* tumultuosa \w batalla|strong="H4421"\w* \w peleará|strong="H3898"\w* \w contra|strong="H5921"\w* \w ellos|strong="H5921"\w*.
\v 33 \w Porque|strong="H3588"\w* hace tiempo una hoguera \w profunda|strong="H6009"\w* \w y|strong="H1571"\w* \w ancha|strong="H7337"\w* \w está|strong="H1931"\w* dispuesta \w para|strong="H3588"\w* \w el|strong="H1931"\w* \w rey|strong="H4428"\w* \w con|strong="H3588"\w* abundante \w leña|strong="H6086"\w* \w en|strong="H3588"\w* Tofet. \w El|strong="H1931"\w* \w soplo|strong="H5397"\w* \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w la|strong="H1931"\w* enciende \w como|strong="H3588"\w* \w torrente|strong="H5158"\w* \w de|strong="H3588"\w* \w azufre|strong="H1614"\w*.
\c 31
\s1 Vanidad de la ayuda humana
\p 
\v 1 ¡\w Ay|strong="H1945"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w que|strong="H3588"\w* bajan \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w* \w en|strong="H5921"\w* \w busca|strong="H1875"\w* \w de|strong="H5921"\w* \w ayuda|strong="H5833"\w*! Confían \w en|strong="H5921"\w* \w caballos|strong="H5483"\w* \w y|strong="H3588"\w* fijan \w su|strong="H3588"\w* esperanza \w en|strong="H5921"\w* carruajes \w porque|strong="H3588"\w* \w son|strong="H3588"\w* \w muchos|strong="H7227"\w*, \w y|strong="H3588"\w* \w en|strong="H5921"\w* \w jinetes|strong="H6571"\w* \w porque|strong="H3588"\w* \w son|strong="H3588"\w* \w muy|strong="H3966"\w* \w fuertes|strong="H6105"\w*. \w Pero|strong="H3588"\w* \w no|strong="H3808"\w* miran \w al|strong="H5921"\w* \w Santo|strong="H6918"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w ni|strong="H3808"\w* \w buscan|strong="H1875"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\v 2 Pero \w Él|strong="H1931"\w* \w también|strong="H1571"\w* \w es|strong="H1931"\w* \w sabio|strong="H2450"\w*. Traerá \w el|strong="H1931"\w* desastre \w y|strong="H1571"\w* \w no|strong="H3808"\w* revoca \w su|strong="H1931"\w* \w Palabra|strong="H1697"\w*. \w Se|strong="H1931"\w* \w levantará|strong="H6965"\w* \w contra|strong="H5921"\w* \w la|strong="H1931"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* malhechores, \w contra|strong="H5921"\w* un \w auxilio|strong="H5833"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* obradores \w de|strong="H5921"\w* iniquidad.
\v 3 \w Los|strong="H3605"\w* \w egipcios|strong="H4714"\w* \w son|strong="H3808"\w* hombres, \w no|strong="H3808"\w* \tl ʼelohim\tl*. Sus \w caballos|strong="H5483"\w* \w son|strong="H3808"\w* \w carne|strong="H1320"\w*, \w no|strong="H3808"\w* \w espíritu|strong="H7307"\w*. De modo \w que|strong="H3808"\w* cuando \nd \w Yavé|strong="H3068"\w*\nd* extienda su \w mano|strong="H3027"\w*, \w caerán|strong="H5307"\w* \w el|strong="H3605"\w* protector y \w el|strong="H3605"\w* protegido. \w Todos|strong="H3605"\w* \w ellos|strong="H3027"\w* serán exterminados \w juntamente|strong="H3162"\w*.
\p 
\v 4 \w Como|strong="H3588"\w* ruge \w el|strong="H5921"\w* león \w o|strong="H3068"\w* \w el|strong="H5921"\w* cachorro \w de|strong="H5921"\w* león \w sobre|strong="H5921"\w* \w su|strong="H3588"\w* presa, \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w se|strong="H5921"\w* atemoriza \w por|strong="H5921"\w* \w el|strong="H5921"\w* griterío \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w pastores|strong="H7462"\w* \w que|strong="H3588"\w* llegan \w contra|strong="H5921"\w* \w él|strong="H5921"\w*, \w ni|strong="H3808"\w* \w se|strong="H5921"\w* intimida \w por|strong="H5921"\w* \w el|strong="H5921"\w* tumulto \w de|strong="H5921"\w* \w ellos|strong="H5921"\w*, \w así|strong="H3541"\w* \w descenderá|strong="H3381"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w de|strong="H5921"\w* \w las|strong="H5921"\w* huestes \w a|strong="H3068"\w* combatir \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* Montaña \w Sion|strong="H6726"\w* \w y|strong="H3588"\w* \w sobre|strong="H5921"\w* \w su|strong="H3588"\w* colina.
\v 5 \w Como|strong="H5921"\w* \w ave|strong="H6833"\w* \w que|strong="H5921"\w* revolotea, \w así|strong="H3651"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w de|strong="H5921"\w* \w las|strong="H5921"\w* huestes \w amparará|strong="H1598"\w* \w a|strong="H3068"\w* Jerusalén: \w la|strong="H5921"\w* \w amparará|strong="H1598"\w*, \w la|strong="H5921"\w* \w librará|strong="H5337"\w*, \w la|strong="H5921"\w* preservará \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w salvará|strong="H4422"\w*.
\p 
\v 6 \w Oh|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, regresen \w a|strong="H3068"\w* Aquel \w contra|strong="H3478"\w* Quien se rebelaron \w de|strong="H1121"\w* manera tan radical.
\v 7 \w Aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w el|strong="H1931"\w* hombre tirará \w con|strong="H3588"\w* desprecio \w sus|strong="H1931"\w* ídolos \w de|strong="H3588"\w* \w plata|strong="H3701"\w* \w y|strong="H3588"\w* \w de|strong="H3588"\w* \w oro|strong="H2091"\w* \w que|strong="H3588"\w* \w sus|strong="H1931"\w* \w manos|strong="H3027"\w* \w pecadoras|strong="H2399"\w* \w hicieron|strong="H6213"\w*.
\v 8 Asiria \w caerá|strong="H5307"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w* \w no|strong="H3808"\w* \w de|strong="H6440"\w* hombre. La devorará una \w espada|strong="H2719"\w* \w no|strong="H3808"\w* \w de|strong="H6440"\w* humanos, y sus jóvenes \w serán|strong="H1961"\w* sometidos \w a|strong="H3068"\w* trabajos forzados.
\v 9 \wj Su fortaleza se desvanecerá \w a|strong="H3068"\w* causa del terror. Sus líderes dejarán sus estandartes \w a|strong="H3068"\w* causa del pavor,\wj* \w dice|strong="H5002"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \wj Quien tiene su hoguera en \w Sion|strong="H6726"\w* y su \w horno|strong="H8574"\w* en Jerusalén.\wj*
\c 32
\s1 La justicia de un verdadero Rey
\p 
\v 1 \w Ciertamente|strong="H2005"\w* un \w rey|strong="H4428"\w* gobierna con \w justicia|strong="H6664"\w* y los magistrados actúan \w justamente|strong="H6664"\w*.
\v 2 Aquel Varón \w es|strong="H1961"\w* \w como|strong="H1961"\w* un escondedero \w contra|strong="H1961"\w* el \w viento|strong="H7307"\w*, \w como|strong="H1961"\w* un refugio \w contra|strong="H1961"\w* el fuerte aguacero, \w como|strong="H1961"\w* arroyos \w de|strong="H4325"\w* \w agua|strong="H4325"\w* en un campo seco y \w como|strong="H1961"\w* la \w sombra|strong="H6738"\w* \w de|strong="H4325"\w* una gran \w roca|strong="H5553"\w* en una tierra árida.
\v 3 Entonces los \w ojos|strong="H5869"\w* \w de|strong="H5869"\w* los \w que|strong="H3808"\w* \w ven|strong="H7200"\w* \w no|strong="H3808"\w* estarán cegados, y los \w oídos|strong="H8085"\w* \w de|strong="H5869"\w* los \w que|strong="H3808"\w* \w oyen|strong="H8085"\w* escucharán.
\v 4 El \w corazón|strong="H3824"\w* de los necios aprenderá para \w saber|strong="H3045"\w*, y la \w lengua|strong="H3956"\w* de los tartamudos \w se|strong="H3045"\w* apresurará \w a|strong="H3068"\w* \w hablar|strong="H1696"\w* claramente.
\v 5 El ruin \w nunca|strong="H3808"\w* \w más|strong="H5750"\w* \w será|strong="H3808"\w* \w llamado|strong="H7121"\w* \w generoso|strong="H7771"\w*, \w ni|strong="H3808"\w* tratarán \w de|strong="H5750"\w* excelencia al tramposo.
\v 6 \w Pues|strong="H3588"\w* \w el|strong="H3588"\w* necio \w habla|strong="H1696"\w* necedad. \w Su|strong="H3588"\w* \w corazón|strong="H3820"\w* se inclina \w hacia|strong="H6213"\w* las perversidades \w para|strong="H3588"\w* cometer impiedades, blasfemar contra \nd \w Yavé|strong="H3068"\w*\nd*, dejar insatisfecho al hambriento \w y|strong="H3588"\w* privar \w de|strong="H3588"\w* agua al sediento.
\v 7 Las \w armas|strong="H3627"\w* del canalla son perversas. Trama intrigas perversas para enredar al \w afligido|strong="H7451"\w* con calumnia, aunque \w el|strong="H1931"\w* pobre defienda \w lo|strong="H1931"\w* \w que|strong="H1931"\w* \w es|strong="H1931"\w* recto.
\v 8 Pero \w el|strong="H1931"\w* noble inventa planes nobles \w y|strong="H5921"\w* \w está|strong="H1931"\w* \w firme|strong="H6965"\w* \w en|strong="H5921"\w* \w ellos|strong="H1931"\w*.
\p 
\v 9 ¡Oh \w mujeres|strong="H1323"\w* indolentes, \w levántense|strong="H6965"\w*! \w Escuchen|strong="H8085"\w* mi \w voz|strong="H6963"\w*, \w hijas|strong="H1323"\w* confiadas:
\v 10 \w Dentro|strong="H5921"\w* \w de|strong="H5921"\w* algo \w más|strong="H3588"\w* \w de|strong="H5921"\w* un \w año|strong="H8141"\w* ustedes tendrán espanto, oh confiadas, \w porque|strong="H3588"\w* \w no|strong="H1097"\w* \w habrá|strong="H3117"\w* recolección \w de|strong="H5921"\w* uvas \w ni|strong="H1097"\w* \w habrá|strong="H3117"\w* cosecha.
\v 11 ¡\w Tiemblen|strong="H7264"\w*, oh indolentes! \w Tiemblen|strong="H7264"\w* \w las|strong="H5921"\w* \w que|strong="H5921"\w* viven confiadas. Desnúdense \w por|strong="H5921"\w* completo \w y|strong="H5921"\w* aten tela áspera \w a|strong="H3068"\w* su cintura.
\v 12 Golpéense \w el|strong="H5921"\w* pecho \w en|strong="H5921"\w* duelo \w por|strong="H5921"\w* \w los|strong="H5921"\w* \w campos|strong="H7704"\w* \w deleitosos|strong="H2531"\w*, \w por|strong="H5921"\w* \w la|strong="H5921"\w* \w viña|strong="H1612"\w* fructífera.
\p 
\v 13 \w En|strong="H5921"\w* \w las|strong="H5921"\w* tierras \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w crecerán|strong="H5927"\w* \w espinos|strong="H6975"\w* \w y|strong="H3588"\w* \w cardos|strong="H8068"\w* \w aun|strong="H3588"\w* \w en|strong="H5921"\w* \w las|strong="H5921"\w* \w casas|strong="H1004"\w* alegres \w y|strong="H3588"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w ciudad|strong="H7151"\w* jubilosa,
\v 14 \w porque|strong="H3588"\w* \w el|strong="H3588"\w* palacio queda abandonado. Cesa \w el|strong="H3588"\w* bullicio \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w ciudad|strong="H5892"\w*. \w La|strong="H3588"\w* colina \w y|strong="H3588"\w* \w el|strong="H3588"\w* atalaya \w se|strong="H1961"\w* convierten \w en|strong="H5704"\w* cavernas \w para|strong="H5704"\w* \w siempre|strong="H5769"\w*, \w en|strong="H5704"\w* delicia \w de|strong="H3588"\w* asnos salvajes \w y|strong="H3588"\w* pastizal \w de|strong="H3588"\w* \w rebaños|strong="H5739"\w*,
\v 15 \w hasta|strong="H5704"\w* \w cuando|strong="H5704"\w* \w el|strong="H5921"\w* \w Espíritu|strong="H7307"\w* \w de|strong="H5921"\w* \w lo|strong="H5921"\w* \w alto|strong="H4791"\w* \w sea|strong="H1961"\w* derramado \w sobre|strong="H5921"\w* \w nosotros|strong="H5921"\w*, \w el|strong="H5921"\w* \w desierto|strong="H4057"\w* \w se|strong="H1961"\w* convierta \w en|strong="H5921"\w* campo fértil \w y|strong="H5921"\w* \w el|strong="H5921"\w* campo fértil \w sea|strong="H1961"\w* considerado \w como|strong="H1961"\w* \w bosque|strong="H3293"\w*.
\p 
\v 16 Entonces la \w justicia|strong="H6666"\w* vivirá en \w el|strong="H3427"\w* \w desierto|strong="H4057"\w* y la equidad residirá en \w el|strong="H3427"\w* campo fértil.
\v 17 \w El|strong="H8252"\w* efecto \w de|strong="H5704"\w* la \w justicia|strong="H6666"\w* \w será|strong="H1961"\w* \w paz|strong="H7965"\w*. \w El|strong="H8252"\w* resultado \w de|strong="H5704"\w* la equidad \w será|strong="H1961"\w* \w reposo|strong="H8252"\w* \w y|strong="H5704"\w* seguridad \w perpetuos|strong="H5769"\w*.
\v 18 Mi \w pueblo|strong="H5971"\w* \w habitará|strong="H3427"\w* en un lugar pacífico, en viviendas seguras, en lugares \w de|strong="H5971"\w* \w reposo|strong="H4496"\w* apacible.
\v 19 Pero \w caerá|strong="H3381"\w* granizo cuando el \w bosque|strong="H3293"\w* sea talado. La \w ciudad|strong="H5892"\w* será completamente \w abatida|strong="H8213"\w*.
\v 20 ¡Cuán dichosos son ustedes, \w los|strong="H5921"\w* \w que|strong="H5921"\w* siembran \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w aguas|strong="H4325"\w*, \w los|strong="H5921"\w* \w que|strong="H5921"\w* dejan libres \w al|strong="H5921"\w* \w buey|strong="H7794"\w* \w y|strong="H5921"\w* \w al|strong="H5921"\w* \w asno|strong="H2543"\w*!
\c 33
\s1 La senda difícil hacia el reinado del verdadero Rey
\p 
\v 1 ¡\w Ay|strong="H1945"\w* de ti, destructor \w que|strong="H3808"\w* \w no|strong="H3808"\w* fuiste \w destruido|strong="H7703"\w*, y del \w que|strong="H3808"\w* traiciona y \w no|strong="H3808"\w* \w fue|strong="H3808"\w* traicionado! Tan pronto como acabes de destruir serás \w destruido|strong="H7703"\w*. Tan pronto como acabes de traicionar, serás traicionado.
\p 
\v 2 Oh \nd \w Yavé|strong="H3068"\w*\nd*, ten \w misericordia|strong="H2603"\w* \w de|strong="H6256"\w* nosotros. En Ti fijamos nuestra esperanza. \w Sé|strong="H1961"\w* nuestra fortaleza cada \w mañana|strong="H1242"\w*. \w Sé|strong="H1961"\w* también nuestra salvación en el \w tiempo|strong="H6256"\w* \w de|strong="H6256"\w* \w aflicción|strong="H6869"\w*.
\v 3 Los \w pueblos|strong="H5971"\w* huyen ante el \w sonido|strong="H6963"\w* \w de|strong="H5971"\w* tu \w voz|strong="H6963"\w* atronadora. Al levantarte \w se|strong="H5971"\w* dispersan las \w naciones|strong="H1471"\w*.
\v 4 Tu \w despojo|strong="H7998"\w* será recogido como el saltamonte recoge. Se abalanzarán sobre él como langostas.
\v 5 Exaltado \w es|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w porque|strong="H3588"\w* \w Él|strong="H3588"\w* \w mora|strong="H7931"\w* \w en|strong="H3588"\w* las \w alturas|strong="H4791"\w*. \w Él|strong="H3588"\w* \w llenó|strong="H4390"\w* \w de|strong="H3588"\w* \w justicia|strong="H6666"\w* \w y|strong="H3588"\w* equidad \w a|strong="H3068"\w* \w Sion|strong="H6726"\w*.
\v 6 \w Habrá|strong="H1961"\w* estabilidad \w de|strong="H6256"\w* \w los|strong="H1961"\w* \w tiempos|strong="H6256"\w* \w de|strong="H6256"\w* ustedes, una abundancia \w de|strong="H6256"\w* salvación, \w sabiduría|strong="H2451"\w* y \w conocimiento|strong="H1847"\w*. \w El|strong="H1931"\w* \w temor|strong="H3374"\w* reverente \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w es|strong="H1931"\w* \w el|strong="H1931"\w* tesoro \w de|strong="H6256"\w* \w Él|strong="H1931"\w*.
\p 
\v 7 \w Ciertamente|strong="H2005"\w* sus valientes \w claman|strong="H6817"\w* en las \w calles|strong="H2351"\w*. Los \w embajadores|strong="H4397"\w* de \w paz|strong="H7965"\w* \w lloran|strong="H1058"\w* \w amargamente|strong="H4751"\w*.
\v 8 Los \w caminos|strong="H4546"\w* están abandonados, los caminantes \w cesaron|strong="H7673"\w*. \w Él|strong="H5674"\w* anuló \w el|strong="H5674"\w* \w Pacto|strong="H1285"\w*, \w desprecia|strong="H3988"\w* las \w ciudades|strong="H5892"\w*, \w a|strong="H3068"\w* \w ningún|strong="H3808"\w* hombre \w tiene|strong="H2803"\w* en cuenta.
\v 9 La tierra gime y languidece. El \w Líbano|strong="H3844"\w* \w está|strong="H1961"\w* confundido y \w se|strong="H1961"\w* marchita. \w Sarón|strong="H8289"\w* \w es|strong="H1961"\w* \w como|strong="H1961"\w* un llano desolado. \w Basán|strong="H1316"\w* y la montaña Carmelo pierden \add su follaje\add*.
\p 
\v 10 \wj \w Ahora|strong="H6258"\w* me \w levantaré|strong="H5375"\w*,\wj* dice \nd \w Yavé|strong="H3068"\w*\nd*. \wj \w Ahora|strong="H6258"\w* seré exaltado. \w Ahora|strong="H6258"\w* seré engrandecido.\wj*
\v 11 \wj \w Concibieron|strong="H2029"\w* hojarasca y dieron \w a|strong="H3068"\w* luz \w rastrojo|strong="H7179"\w*. Su propia respiración será un fuego que los consumirá. \wj*
\v 12 \wj \w Los|strong="H1961"\w* \w pueblos|strong="H5971"\w* \w serán|strong="H1961"\w* completamente calcinados. \w Como|strong="H1961"\w* \w espinos|strong="H6975"\w* cortados \w serán|strong="H1961"\w* \w quemados|strong="H3341"\w* en el fuego. \wj*
\v 13 \wj Ustedes quienes están \w lejos|strong="H7350"\w*, \w escuchen|strong="H8085"\w* \w lo|strong="H6213"\w* \w que|strong="H3045"\w* \w hice|strong="H6213"\w*. Ustedes quienes están \w cerca|strong="H7138"\w* \w conozcan|strong="H3045"\w* mi poder.\wj*
\p 
\v 14 Los \w pecadores|strong="H2400"\w* están atemorizados en \w Sion|strong="H6726"\w*. \w El|strong="H4310"\w* \w temblor|strong="H7461"\w* se apoderó de los impíos. ¿\w Quién|strong="H4310"\w* de nosotros puede vivir en \w el|strong="H4310"\w* fuego consumidor? ¿\w Quién|strong="H4310"\w* de nosotros puede vivir \w eternamente|strong="H5769"\w* en carbones encendidos?
\v 15 El que \w anda|strong="H1980"\w* en \w justicia|strong="H6666"\w* y \w habla|strong="H1696"\w* con rectitud, el que rehúsa el lucro \w de|strong="H1818"\w* violencias, el que sacude su \w mano|strong="H3709"\w* para no recibir \w soborno|strong="H7810"\w*, el que tapa sus \w oídos|strong="H8085"\w* para no \w escuchar|strong="H8085"\w* propuestas sanguinarias, el que cierra sus \w ojos|strong="H5869"\w* para no \w ver|strong="H7200"\w* lo \w malo|strong="H7451"\w*.
\v 16 \w Éste|strong="H1931"\w* vivirá en las \w alturas|strong="H4791"\w*. Una fortaleza \w de|strong="H5414"\w* \w roca|strong="H5553"\w* \w será|strong="H1931"\w* \w su|strong="H1931"\w* \w refugio|strong="H4869"\w*. \w Se|strong="H1931"\w* \w le|strong="H1931"\w* \w dará|strong="H5414"\w* \w su|strong="H1931"\w* \w pan|strong="H3899"\w*, y \w sus|strong="H1931"\w* \w aguas|strong="H4325"\w* estarán seguras.
\p 
\v 17 Tus \w ojos|strong="H5869"\w* \w contemplarán|strong="H7200"\w* \w al|strong="H4428"\w* \w Rey|strong="H4428"\w* en su esplendor. \w Verán|strong="H7200"\w* una gran tierra \w a|strong="H3068"\w* la distancia.
\v 18 Tu \w corazón|strong="H3820"\w* reflexionará con respecto al horror y dirá: ¿Dónde está el \w escriba|strong="H5608"\w*? ¿Dónde está el que pesaba el tributo? ¿Dónde está el que inspeccionaba las \w torres|strong="H4026"\w*?
\v 19 \w Ya|strong="H3068"\w* \w no|strong="H3808"\w* \w verás|strong="H7200"\w* \w más|strong="H3808"\w* \w a|strong="H3068"\w* aquel \w pueblo|strong="H5971"\w* fiero, aquel \w pueblo|strong="H5971"\w* \w de|strong="H5971"\w* \w lengua|strong="H3956"\w* difícil \w de|strong="H5971"\w* entender, \w que|strong="H3808"\w* pronuncia un \w lenguaje|strong="H8193"\w* incomprensible.
\p 
\v 20 Contempla \w a|strong="H3068"\w* \w Sion|strong="H6726"\w*, \w la|strong="H3605"\w* \w ciudad|strong="H7151"\w* \w de|strong="H5869"\w* nuestras \w solemnidades|strong="H4150"\w*. Tus \w ojos|strong="H5869"\w* \w verán|strong="H7200"\w* \w a|strong="H3068"\w* Jerusalén, \w morada|strong="H5116"\w* tranquila, tienda \w que|strong="H3605"\w* \w nunca|strong="H5331"\w* será desamparada. Sus estacas \w nunca|strong="H5331"\w* se arrancarán, \w ni|strong="H1077"\w* será rota \w alguna|strong="H3605"\w* \w de|strong="H5869"\w* sus cuerdas.
\v 21 \w Porque|strong="H3588"\w* \w ciertamente|strong="H3588"\w* \w allí|strong="H8033"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w será|strong="H3808"\w* poderoso \w con|strong="H3588"\w* nosotros, \w en|strong="H3588"\w* un \w lugar|strong="H4725"\w* \w de|strong="H3588"\w* \w ríos|strong="H2975"\w* \w y|strong="H3588"\w* corrientes amplias \w en|strong="H3588"\w* \w los|strong="H3588"\w* cuales \w no|strong="H3808"\w* navegarán embarcaciones \w de|strong="H3588"\w* remos, \w ni|strong="H3808"\w* \w por|strong="H3588"\w* ellas \w pasará|strong="H5674"\w* nave \w grande|strong="H6716"\w*.
\p 
\v 22 \w Porque|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w es|strong="H1931"\w* nuestro \w Juez|strong="H8199"\w*. \nd \w Yavé|strong="H3068"\w*\nd* \w es|strong="H1931"\w* nuestro \w Legislador|strong="H2710"\w*. \nd \w Yavé|strong="H3068"\w*\nd* \w es|strong="H1931"\w* nuestro \w Rey|strong="H4428"\w*. \w Él|strong="H1931"\w* \w mismo|strong="H1931"\w* nos \w salvará|strong="H3467"\w*.
\v 23 Tus cuerdas se aflojaron. \w No|strong="H1077"\w* \w afirmaron|strong="H2388"\w* su mástil. \w No|strong="H1077"\w* \w entesaron|strong="H6566"\w* la vela. Entonces se \w repartirá|strong="H2505"\w* un botín \w de|strong="H4766"\w* muchos \w despojos|strong="H7998"\w*. Los cojos \w arrebatarán|strong="H2388"\w* el botín.
\v 24 Ningún habitante dirá: Estoy \w enfermo|strong="H2470"\w*, pues al \w pueblo|strong="H5971"\w* \w que|strong="H5971"\w* \w more|strong="H3427"\w* en ella le será perdonada su \w iniquidad|strong="H5771"\w*.
\c 34
\s1 Ira contra las naciones
\p 
\v 1 Acérquense, \w naciones|strong="H1471"\w*, para \w oír|strong="H8085"\w*, y \w escuchen|strong="H8085"\w* ustedes, \w pueblos|strong="H3816"\w*. \w Oiga|strong="H8085"\w* \w la|strong="H3605"\w* tierra y \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w que|strong="H3605"\w* hay en \w ella|strong="H3605"\w*, \w el|strong="H3605"\w* \w mundo|strong="H8398"\w* y \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w que|strong="H3605"\w* brota de \w él|strong="H3605"\w*.
\v 2 \w Porque|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w está|strong="H5921"\w* airado \w contra|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w* \w y|strong="H3588"\w* furioso \w contra|strong="H5921"\w* \w todos|strong="H3605"\w* sus \w ejércitos|strong="H6635"\w*. \w Las|strong="H5921"\w* destruirá \w por|strong="H5921"\w* completo, \w las|strong="H5921"\w* \w entregará|strong="H5414"\w* \w al|strong="H5921"\w* matadero.
\v 3 Sus \w muertos|strong="H2491"\w* serán tirados. Surgirá una hediondez \w de|strong="H1818"\w* sus cadáveres y las montañas serán empapadas con su \w sangre|strong="H1818"\w*.
\v 4 \w Toda|strong="H3605"\w* \w la|strong="H3605"\w* hueste del \w cielo|strong="H8064"\w* se disolverá. \w El|strong="H3605"\w* \w cielo|strong="H8064"\w* se envolverá como un rollo. \w Toda|strong="H3605"\w* su hueste caerá como \w la|strong="H3605"\w* hoja \w cae|strong="H5034"\w* de \w la|strong="H3605"\w* \w vid|strong="H1612"\w*, como un higo seco \w cae|strong="H5034"\w* de \w la|strong="H3605"\w* higuera.
\p 
\v 5 \wj \w Mi|strong="H5921"\w* \w espada|strong="H2719"\w* \w se|strong="H5921"\w* embriagará \w en|strong="H5921"\w* \w los|strong="H5921"\w* \w cielos|strong="H8064"\w*. \w Descenderá|strong="H3381"\w* \w para|strong="H5921"\w* \w juicio|strong="H4941"\w* \w en|strong="H5921"\w* Edom, \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* maldición.\wj*
\v 6 \w La|strong="H3588"\w* \w espada|strong="H2719"\w* \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* chorrea \w sangre|strong="H1818"\w*. Está untada \w de|strong="H3588"\w* sustancia \w de|strong="H3588"\w* \w sangre|strong="H1818"\w* \w de|strong="H3588"\w* \w corderos|strong="H3733"\w* \w y|strong="H3588"\w* machos cabríos, \w de|strong="H3588"\w* grasa \w de|strong="H3588"\w* \w riñones|strong="H3629"\w* \w de|strong="H3588"\w* carneros. \w Porque|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* tiene un \w sacrificio|strong="H2077"\w* \w en|strong="H3588"\w* \w Bosra|strong="H1224"\w*, \w y|strong="H3588"\w* una \w gran|strong="H1419"\w* \w matanza|strong="H2874"\w* \w en|strong="H3588"\w* Edom.
\v 7 Búfalos \w con|strong="H5973"\w* \w toros|strong="H6499"\w* y \w novillos|strong="H6499"\w* caen juntos. La \w tierra|strong="H6083"\w* se embriaga \w de|strong="H5973"\w* su \w sangre|strong="H1818"\w* y \w el|strong="H5973"\w* \w polvo|strong="H6083"\w* se humedece \w con|strong="H5973"\w* grasa.
\p 
\v 8 \w Porque|strong="H3588"\w* \w es|strong="H3588"\w* \w el|strong="H3588"\w* \w día|strong="H3117"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w venganza|strong="H5359"\w* \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w año|strong="H8141"\w* \w de|strong="H3588"\w* retribución \w para|strong="H3588"\w* \w la|strong="H3588"\w* \w causa|strong="H7379"\w* \w de|strong="H3588"\w* \w Sion|strong="H6726"\w*.
\v 9 Sus torrentes \w se|strong="H1961"\w* convierten en brea, su \w polvo|strong="H6083"\w* en \w azufre|strong="H1614"\w*, su \w tierra|strong="H6083"\w* en brea \w ardiente|strong="H1197"\w*
\v 10 \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* apaga de \w noche|strong="H3915"\w* \w ni|strong="H3808"\w* de \w día|strong="H3119"\w*, y su \w humo|strong="H6227"\w* \w sube|strong="H5927"\w* \w perpetuamente|strong="H5769"\w*. De \w generación|strong="H1755"\w* en \w generación|strong="H1755"\w* seguirá desolada. \w Nunca|strong="H3808"\w* \w jamás|strong="H5769"\w* \w pasará|strong="H5674"\w* alguien \w por|strong="H5769"\w* ella.
\v 11 \w El|strong="H5921"\w* pelícano \w y|strong="H5921"\w* \w el|strong="H5921"\w* erizo \w se|strong="H5921"\w* adueñan \w de|strong="H5921"\w* \w ella|strong="H5921"\w*. \w La|strong="H5921"\w* lechuza \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w cuervo|strong="H6158"\w* vivirán \w en|strong="H5921"\w* \w ella|strong="H5921"\w*. Cordel \w de|strong="H5921"\w* destrucción \w y|strong="H5921"\w* plomada \w de|strong="H5921"\w* asolamiento \w se|strong="H5921"\w* pondrán \w sobre|strong="H5921"\w* \w ella|strong="H5921"\w*.
\v 12 Reyes sin \w reino|strong="H4410"\w* \w llamarán|strong="H7121"\w* \w a|strong="H3068"\w* sus \w príncipes|strong="H8269"\w*, pero \w no|strong="H1961"\w* \w los|strong="H3605"\w* \w habrá|strong="H1961"\w*. \w Todos|strong="H3605"\w* sus gobernantes \w serán|strong="H1961"\w* \w nada|strong="H3605"\w*.
\p 
\v 13 Crecen \w los|strong="H1961"\w* espinos en sus palacios y ortigas y \w abrojos|strong="H2336"\w* en sus fortalezas. \w Se|strong="H1961"\w* convierte en guarida de chacales y en campo de avestruces.
\v 14 \w Las|strong="H5921"\w* fieras \w del|strong="H5921"\w* desierto \w se|strong="H5921"\w* encontrarán \w con|strong="H5921"\w* \w las|strong="H5921"\w* hienas, \w y|strong="H5921"\w* \w el|strong="H5921"\w* chivo salvaje \w llamará|strong="H7121"\w* \w a|strong="H3068"\w* su compañera. \w La|strong="H5921"\w* lechuza también \w hallará|strong="H4672"\w* \w allí|strong="H8033"\w* residencia \w y|strong="H5921"\w* tendrá \w reposo|strong="H4494"\w*.
\v 15 \w Allí|strong="H8033"\w* también habrá nido de búho. Pondrá sus huevos, los incubará y los empollará. \w Allí|strong="H8033"\w* se juntarán los \w buitres|strong="H1772"\w*, \w cada|strong="H8033"\w* uno con su \w compañera|strong="H7468"\w*.
\v 16 Escudriñen \w el|strong="H1931"\w* Rollo \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w y|strong="H3588"\w* lean \w si|strong="H3588"\w* \w faltó|strong="H5737"\w* alguno \w de|strong="H5921"\w* \w ellos|strong="H1931"\w*. \w Ninguno|strong="H3808"\w* \w faltó|strong="H5737"\w* \w con|strong="H5921"\w* \w su|strong="H1931"\w* \w compañera|strong="H7468"\w*, \w porque|strong="H3588"\w* \w su|strong="H1931"\w* \w boca|strong="H6310"\w* habló \w y|strong="H3588"\w* \w su|strong="H1931"\w* \w mismo|strong="H1931"\w* \w Espíritu|strong="H7307"\w* \w los|strong="H5921"\w* reunió.
\v 17 \w Él|strong="H1931"\w* realizó \w el|strong="H1931"\w* sorteo \w para|strong="H5704"\w* \w ellos|strong="H1992"\w*, \w y|strong="H5704"\w* \w su|strong="H1931"\w* \w mano|strong="H3027"\w* \w les|strong="H1992"\w* \w repartió|strong="H2505"\w* \w a|strong="H3068"\w* cordel. \w Para|strong="H5704"\w* \w siempre|strong="H5769"\w* \w la|strong="H1931"\w* \w poseerán|strong="H3423"\w*. Vivirán allí \w de|strong="H5704"\w* \w generación|strong="H1755"\w* \w en|strong="H5704"\w* \w generación|strong="H1755"\w*.
\c 35
\s1 Las bendiciones del reino de \nd Yavé\nd*
\p 
\v 1 El \w desierto|strong="H4057"\w* y la región despoblada se alegrarán, y el llano de Arabá se regocijará y \w florecerá|strong="H6524"\w*. Como la flor típica
\v 2 \w florecerá|strong="H6524"\w* exuberante \w y|strong="H3519"\w* desbordará \w de|strong="H5414"\w* júbilo. \w Se|strong="H1992"\w* alegrará \w y|strong="H3519"\w* \w cantará|strong="H7442"\w* alabanzas. Porque le \w será|strong="H5414"\w* \w dado|strong="H5414"\w* \w el|strong="H1992"\w* esplendor \w de|strong="H5414"\w* \add la montaña\add* \w Líbano|strong="H3844"\w*, la \w hermosura|strong="H1926"\w* \w de|strong="H5414"\w* \add la montaña\add* Carmelo \w y|strong="H3519"\w* \add de la región costera\add* \w de|strong="H5414"\w* \w Sarón|strong="H8289"\w*. \w Ellos|strong="H1992"\w* \w verán|strong="H7200"\w* la \w gloria|strong="H3519"\w* \w de|strong="H5414"\w* \nd \w Yavé|strong="H3068"\w*\nd*, la majestad \w de|strong="H5414"\w* nuestro \nd ʼElohim\nd*.
\v 3 Fortalezcan las \w manos|strong="H3027"\w* \w cansadas|strong="H7504"\w*, fortalezcan las \w rodillas|strong="H1290"\w* débiles.
\v 4 Digan \w a|strong="H3068"\w* \w los|strong="H1931"\w* \w de|strong="H3372"\w* \w corazón|strong="H3820"\w* \w apocado|strong="H4116"\w*: \w Esfuércense|strong="H2388"\w*, no \w teman|strong="H3372"\w*. \w Ciertamente|strong="H2009"\w* \nd ʼElohim\nd* viene con retribución: \w La|strong="H1931"\w* \w venganza|strong="H5359"\w* \w es|strong="H1931"\w* \w de|strong="H3372"\w* \nd ʼElohim\nd*. \w Él|strong="H1931"\w* vendrá y \w los|strong="H1931"\w* \w salvará|strong="H3467"\w*.
\p 
\v 5 Entonces los \w ojos|strong="H5869"\w* \w de|strong="H5869"\w* los \w ciegos|strong="H5787"\w* \w serán|strong="H6491"\w* \w abiertos|strong="H6605"\w*, y los oídos \w de|strong="H5869"\w* los \w sordos|strong="H2795"\w* destapados.
\v 6 \w Entonces|strong="H3588"\w* \w el|strong="H3588"\w* \w cojo|strong="H6455"\w* \w saltará|strong="H1801"\w* \w como|strong="H3588"\w* un venado. \w Cantará|strong="H7442"\w* \w la|strong="H3588"\w* \w lengua|strong="H3956"\w* del mudo, \w porque|strong="H3588"\w* \w aguas|strong="H4325"\w* brotarán \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w desierto|strong="H4057"\w* \w y|strong="H3588"\w* torrentes \w en|strong="H3588"\w* \w el|strong="H3588"\w* Arabá.
\v 7 La arena caliente \w se|strong="H1961"\w* convertirá en laguna, y el sequedal en manantiales \w de|strong="H4325"\w* \w agua|strong="H4325"\w*. La guarida \w de|strong="H4325"\w* chacales \w será|strong="H1961"\w* un lugar \w de|strong="H4325"\w* \w cañas|strong="H7070"\w* y juncos.
\p 
\v 8 \w Habrá|strong="H1961"\w* \w allí|strong="H8033"\w* una \w calzada|strong="H4547"\w*, \w la|strong="H1931"\w* \w cual|strong="H1931"\w* \w será|strong="H1961"\w* llamada \w Camino|strong="H1870"\w* de \w Santidad|strong="H6944"\w*. \w Ningún|strong="H3808"\w* impuro \w pasará|strong="H5674"\w* \w por|strong="H1870"\w* \w él|strong="H1931"\w*. \w El|strong="H1931"\w* \w que|strong="H1931"\w* ande \w por|strong="H1870"\w* \w este|strong="H1931"\w* \w Camino|strong="H1870"\w*, \w aunque|strong="H8033"\w* \w sea|strong="H1961"\w* torpe, \w no|strong="H3808"\w* \w se|strong="H1961"\w* extraviará.
\v 9 \w No|strong="H3808"\w* \w habrá|strong="H1961"\w* \w allí|strong="H8033"\w* león, \w ni|strong="H3808"\w* fiera \w subirá|strong="H5927"\w* por él, \w ni|strong="H3808"\w* \w será|strong="H1961"\w* hallada \w allí|strong="H8033"\w*, \w para|strong="H1961"\w* \w que|strong="H3808"\w* caminen \w los|strong="H1961"\w* \w redimidos|strong="H1350"\w*.
\v 10 \w Los|strong="H5921"\w* redimidos \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w volverán|strong="H7725"\w* \w y|strong="H5921"\w* llegarán \w a|strong="H3068"\w* \w Sion|strong="H6726"\w* \w con|strong="H5921"\w* gritos \w de|strong="H5921"\w* júbilo. \w Gozo|strong="H8057"\w* \w perpetuo|strong="H5769"\w* habrá \w sobre|strong="H5921"\w* sus \w cabezas|strong="H7218"\w*, \w gozo|strong="H8057"\w* \w y|strong="H5921"\w* \w alegría|strong="H8057"\w*. Huirán \w la|strong="H5921"\w* \w tristeza|strong="H3015"\w* \w y|strong="H5921"\w* \w el|strong="H5921"\w* lamento.
\c 36
\s1 Invasión de Senaquerib, rey de Asiria
\p 
\v 1 \w El|strong="H5921"\w* \w año|strong="H8141"\w* 14 \w del|strong="H5921"\w* \w rey|strong="H4428"\w* Ezequías, \w aconteció|strong="H1961"\w* \w que|strong="H5921"\w* Senaquerib, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Asiria, \w subió|strong="H5927"\w* \w contra|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w ciudades|strong="H5892"\w* \w fortificadas|strong="H1219"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w* \w y|strong="H5921"\w* \w las|strong="H5921"\w* \w tomó|strong="H5927"\w*.
\v 2 El \w rey|strong="H4428"\w* de Asiria \w envió|strong="H7971"\w* \w al|strong="H4428"\w* \tl \w Rabsaces|strong="H7262"\w*\tl*\f + \fr 36:2 \ft Rabsaces: el edecán del rey en asuntos militares.\f* con un gran \w ejército|strong="H2426"\w* desde Laquis \w a|strong="H3068"\w* Jerusalén contra el \w rey|strong="H4428"\w* Ezequías. Hizo \w alto|strong="H5945"\w* junto \w al|strong="H4428"\w* acueducto del \w estanque|strong="H1295"\w* de arriba, \w en|strong="H5975"\w* la senda del \w Campo|strong="H7704"\w* del Lavador.
\v 3 Eliaquim, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Hilcías|strong="H2518"\w*, \w mayordomo|strong="H5921"\w* \w del|strong="H5921"\w* palacio, \w Sebna|strong="H7644"\w* \w el|strong="H5921"\w* \w escriba|strong="H5608"\w*, \w y|strong="H5921"\w* Joa, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Asaf, \w el|strong="H5921"\w* cronista, \w salieron|strong="H3318"\w* \w a|strong="H3068"\w* \w él|strong="H5921"\w*.
\p 
\v 4 El \tl \w Rabsaces|strong="H7262"\w*\tl* les habló: Digan \w a|strong="H3068"\w* Ezequías: El \w gran|strong="H1419"\w* \w rey|strong="H4428"\w*, el \w rey|strong="H4428"\w* de Asiria, dice: ¿En \w qué|strong="H4100"\w* confías tú?
\v 5 Dijiste \w que|strong="H3588"\w* tienes un plan \w y|strong="H3588"\w* poderío \w para|strong="H5921"\w* \w la|strong="H5921"\w* \w guerra|strong="H4421"\w*, \w pero|strong="H3588"\w* solo \w son|strong="H3588"\w* vanas \w palabras|strong="H1697"\w*. \w Ahora|strong="H6258"\w* \w pues|strong="H3588"\w*, ¿\w en|strong="H5921"\w* \w quién|strong="H4310"\w* confías \w para|strong="H5921"\w* rebelarte \w contra|strong="H5921"\w* \w mí|strong="H5921"\w*?
\v 6 ¿Confías \w en|strong="H5921"\w* \w ese|strong="H2088"\w* bastón \w de|strong="H5921"\w* \w caña|strong="H7070"\w* quebrada \w que|strong="H5921"\w* \w es|strong="H2088"\w* \w Egipto|strong="H4714"\w*? \w Al|strong="H5921"\w* \w que|strong="H5921"\w* \w se|strong="H5921"\w* apoye \w en|strong="H5921"\w* \w él|strong="H5921"\w* \w se|strong="H5921"\w* \w le|strong="H5921"\w* clava \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w mano|strong="H3709"\w* \w y|strong="H5921"\w* \w se|strong="H5921"\w* \w la|strong="H5921"\w* atraviesa. \w Así|strong="H3651"\w* \w es|strong="H2088"\w* \w Faraón|strong="H6547"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w*, \w para|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* \w confían|strong="H5564"\w* \w en|strong="H5921"\w* \w él|strong="H5921"\w*.
\v 7 \w Si|strong="H3588"\w* \w me|strong="H3588"\w* replicas: \w En|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* nuestro \nd ʼElohim\nd* confiamos, ¿\w no|strong="H3808"\w* \w es|strong="H1931"\w* \w éste|strong="H2088"\w* \w el|strong="H1931"\w* \w mismo|strong="H1931"\w* \w de|strong="H3588"\w* \w quien|strong="H1931"\w* Ezequías \w quitó|strong="H5493"\w* \w los|strong="H1931"\w* lugares \w altos|strong="H1116"\w*, quemó \w sus|strong="H1931"\w* \w altares|strong="H4196"\w* \w y|strong="H3588"\w* exigió \w a|strong="H3068"\w* \w Judá|strong="H3063"\w* \w y|strong="H3588"\w* \w a|strong="H3068"\w* Jerusalén \w que|strong="H3588"\w* \w se|strong="H1931"\w* postraran \w solamente|strong="H3588"\w* \w en|strong="H3588"\w* \w ese|strong="H1931"\w* \w altar|strong="H4196"\w*?
\v 8 \w Ahora|strong="H6258"\w* \w pues|strong="H4994"\w*, haz un \w trato|strong="H5414"\w* \w con|strong="H5921"\w* \w mi|strong="H5921"\w* \tl ʼadón\tl*, \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Asiria, \w y|strong="H5921"\w* \w te|strong="H5921"\w* \w daré|strong="H5414"\w* 2.000 \w caballos|strong="H5483"\w* \w si|strong="H4994"\w* logras proveer jinetes \w para|strong="H5921"\w* \w ellos|strong="H5921"\w*.
\v 9 ¿\w Cómo|strong="H5921"\w* podrás resistir \w al|strong="H5921"\w* \w más|strong="H5921"\w* insignificante esclavo \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \tl ʼadón\tl*, \w si|strong="H6440"\w* confías \w en|strong="H5921"\w* \w que|strong="H5921"\w* \w Egipto|strong="H4714"\w* \w te|strong="H5921"\w* \w dará|strong="H7725"\w* carrozas \w y|strong="H5921"\w* \w jinetes|strong="H6571"\w*?
\v 10 ¿Subí yo \w sin|strong="H1107"\w* orden \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w contra|strong="H5921"\w* \w esta|strong="H2063"\w* tierra \w para|strong="H5921"\w* destruirla? \nd \w Yavé|strong="H3068"\w*\nd* \w me|strong="H5921"\w* dijo: \wj \w Sube|strong="H5927"\w* \w contra|strong="H5921"\w* esa tierra \w y|strong="H5921"\w* destrúyela.\wj*
\p 
\v 11 \w Entonces|strong="H3588"\w* Eliaquim, \w Sebna|strong="H7644"\w* \w y|strong="H3588"\w* Joa, \w dijeron|strong="H1696"\w* \w al|strong="H5921"\w* \tl \w Rabsaces|strong="H7262"\w*\tl*: \w Te|strong="H5921"\w* rogamos \w que|strong="H3588"\w* \w hables|strong="H1696"\w* \w a|strong="H3068"\w* tus esclavos \w en|strong="H5921"\w* arameo, \w porque|strong="H3588"\w* \w nosotros|strong="H5921"\w* \w lo|strong="H5921"\w* entendemos. \w No|strong="H3588"\w* \w nos|strong="H5921"\w* \w hables|strong="H1696"\w* \w en|strong="H5921"\w* hebreo \w a|strong="H3068"\w* \w oídos|strong="H8085"\w* \w del|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w que|strong="H3588"\w* \w está|strong="H5921"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w muro|strong="H2346"\w*.
\p 
\v 12 Pero \w el|strong="H5921"\w* \tl \w Rabsaces|strong="H7262"\w*\tl* respondió: ¿\w Mi|strong="H5921"\w* amo \w me|strong="H5921"\w* \w envió|strong="H7971"\w* \w a|strong="H3068"\w* decir estas \w palabras|strong="H1697"\w* solo \w a|strong="H3068"\w* tu amo \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w ti|strong="H5921"\w*? ¿\w No|strong="H3808"\w* \w me|strong="H5921"\w* \w envió|strong="H7971"\w* \w a|strong="H3068"\w* \w los|strong="H3427"\w* hombres \w que|strong="H3808"\w* \w están|strong="H3427"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w muro|strong="H2346"\w*, expuestos \w a|strong="H3068"\w* comer sus propios excrementos \w y|strong="H5921"\w* \w beber|strong="H8354"\w* su orina \w con|strong="H5973"\w* ustedes?
\v 13 \w Al|strong="H4428"\w* ponerse \w en|strong="H5975"\w* \w pie|strong="H5975"\w*, el \tl \w Rabsaces|strong="H7262"\w*\tl* \w gritó|strong="H7121"\w* \w en|strong="H5975"\w* hebreo \w a|strong="H3068"\w* \w voz|strong="H6963"\w* \w en|strong="H5975"\w* cuello: \w Escuchen|strong="H8085"\w* las \w palabras|strong="H1697"\w* del \w gran|strong="H1419"\w* \w rey|strong="H4428"\w* \w de|strong="H1697"\w* Asiria.
\v 14 \w El|strong="H3588"\w* \w rey|strong="H4428"\w* dice: \w No|strong="H3808"\w* \w los|strong="H3588"\w* \w engañe|strong="H5377"\w* Ezequías, \w porque|strong="H3588"\w* \w él|strong="H3588"\w* \w no|strong="H3808"\w* \w los|strong="H3588"\w* \w podrá|strong="H3201"\w* \w librar|strong="H5337"\w*,
\v 15 \w ni|strong="H3808"\w* les infunda Ezequías confianza en \nd \w Yavé|strong="H3068"\w*\nd*, \w al|strong="H4428"\w* decir: \w Ciertamente|strong="H5414"\w* \nd \w Yavé|strong="H3068"\w*\nd* nos \w librará|strong="H5337"\w*, y \w esta|strong="H2063"\w* \w ciudad|strong="H5892"\w* \w no|strong="H3808"\w* \w será|strong="H3808"\w* \w entregada|strong="H5414"\w* en \w manos|strong="H3027"\w* del \w rey|strong="H4428"\w* \w de|strong="H5414"\w* Asiria.
\v 16 \w No|strong="H6213"\w* \w escuchen|strong="H8085"\w* \w a|strong="H3068"\w* Ezequías, \w porque|strong="H3588"\w* \w así|strong="H3541"\w* dijo \w el|strong="H3588"\w* \w rey|strong="H4428"\w* \w de|strong="H3588"\w* Asiria: \w Hagan|strong="H6213"\w* \w conmigo|strong="H6213"\w* \w la|strong="H3588"\w* \w paz|strong="H1293"\w* \w y|strong="H3588"\w* \w salgan|strong="H3318"\w* \w a|strong="H3068"\w* mí. Cada uno coma \w de|strong="H3588"\w* \w su|strong="H3588"\w* \w vid|strong="H1612"\w* \w y|strong="H3588"\w* cada uno \w de|strong="H3588"\w* \w su|strong="H3588"\w* higuera, \w y|strong="H3588"\w* beba cada \w cual|strong="H3588"\w* \w el|strong="H3588"\w* \w agua|strong="H4325"\w* \w de|strong="H3588"\w* \w su|strong="H3588"\w* pozo
\v 17 \w hasta|strong="H5704"\w* \w que|strong="H5704"\w* yo venga \w y|strong="H5704"\w* los traslade \w a|strong="H3068"\w* una tierra \w como|strong="H5704"\w* la \w de|strong="H5704"\w* ustedes, tierra \w de|strong="H5704"\w* \w grano|strong="H1715"\w* \w y|strong="H5704"\w* \w de|strong="H5704"\w* \w vino|strong="H8492"\w*, tierra \w de|strong="H5704"\w* \w pan|strong="H3899"\w* \w y|strong="H5704"\w* \w de|strong="H5704"\w* \w viñas|strong="H3754"\w*.
\v 18 \w Que|strong="H6435"\w* \w no|strong="H6435"\w* los engañe Ezequías \w al|strong="H4428"\w* decir: \nd \w Yavé|strong="H3068"\w*\nd* nos \w librará|strong="H5337"\w*. ¿Alguno de los \tl ʼelohim\tl* de las \w naciones|strong="H1471"\w* \w libró|strong="H5337"\w* \w a|strong="H3068"\w* su tierra de la \w mano|strong="H3027"\w* del \w rey|strong="H4428"\w* de Asiria?
