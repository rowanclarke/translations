\v 9 \w As|strong="H3117"\w* \w for|strong="H3588"\w* \w the|strong="H6440"\w* stone \w I|strong="H3588"\w* \w have|strong="H3068"\w* \w set|strong="H5414"\w* \w before|strong="H6440"\w* \w Joshua|strong="H3091"\w* – \w on|strong="H5921"\w* \w the|strong="H6440"\w* \w one|strong="H1931"\w* stone \w there|strong="H2009"\w* \w are|strong="H3117"\w* \w seven|strong="H7651"\w* \w eyes|strong="H5869"\w*. \w I|strong="H3588"\w* \w am|strong="H3068"\w* \w about|strong="H5921"\w* \w to|strong="H3068"\w* \w engrave|strong="H6605"\w* \w an|strong="H5414"\w* \w inscription|strong="H6603"\w* \w on|strong="H5921"\w* \w it|strong="H5414"\w*,’ \w says|strong="H5002"\w* \w the|strong="H6440"\w* \nd \w Lord|strong="H3068"\w*\nd* \w who|strong="H1931"\w* rules \w over|strong="H5921"\w* \w all|strong="H5414"\w*, ‘\w to|strong="H3068"\w* \w the|strong="H6440"\w* \w effect|strong="H3117"\w* \w that|strong="H3588"\w* \w I|strong="H3588"\w* \w will|strong="H3068"\w* \w remove|strong="H4185"\w* \w the|strong="H6440"\w* \w iniquity|strong="H5771"\w* \w of|strong="H3068"\w* \w this|strong="H1931"\w* \w land|strong="H6440"\w* \w in|strong="H5921"\w* \w a|strong="H3068"\w* single \w day|strong="H3117"\w*.
\v 10 \w In|strong="H3068"\w* \w that|strong="H3117"\w* \w day|strong="H3117"\w*,’ \w says|strong="H5002"\w* \w the|strong="H5002"\w* \nd \w Lord|strong="H3068"\w*\nd* \w who|strong="H1931"\w* rules \w over|strong="H3068"\w* \w all|strong="H3117"\w*, ‘everyone \w will|strong="H3068"\w* \w invite|strong="H7121"\w* \w his|strong="H3068"\w* \w friend|strong="H7453"\w* \w to|strong="H3068"\w* fellowship \w under|strong="H8478"\w* \w his|strong="H3068"\w* \w vine|strong="H1612"\w* \w and|strong="H3068"\w* \w under|strong="H8478"\w* \w his|strong="H3068"\w* \w fig|strong="H8384"\w* \w tree|strong="H8384"\w*.’”
