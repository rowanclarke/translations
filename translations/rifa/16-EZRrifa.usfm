\id EZR
\h عِيزْرَا 
\toc1 عِيزْرَا 
\toc2 عِيزْرَا 
\toc3 عِز. 
\mt1 عِيزْرَا  
\c 1
\s1 ڒُومُورْ ن كُورَاشْ، أَجدْجِيذْ ن لْفُورْسْ  
\m
\v 1 ذڭْ ؤُسڭّْوَاسْ أَمزْوَارُو ن ؤُجدْجِيذْ كُورَاشْ ن لْفُورْسْ، حِيمَا أَذْ إِتّْوَاكمّڒْ وَاوَاڒْ ن سِيذِي زڭْ ؤُقمُّومْ ن إِرْمِييَا، إِسّكَّارْ سِيذِي بُوحْبڒْ ن كُورَاشْ أَجدْجِيذْ ن لْفُورْسْ مَاحنْذْ أَذْ إِتّْوَابَارّحْ ذِي مَارَّا ثَاڭلْذِيثْ نّسْ س ؤُقمُّومْ ذ ثِيرَا: \x ◘ \xo 1:‏1 \xt [2 إِم. 36‏:‏22، 23؛ إِرْم. 25‏:‏12؛ 29‏:‏10؛ دَان. 9‏:‏2]\x*   
\b  
\m
\v 2 ”أَمُّو إِ إِقَّارْ كُورَاشْ، أَجدْجِيذْ ن لْفُورْسْ: ’سِيذِي، أَربِّي ن إِجنْوَانْ، إِوْشَا أَيِي مَارَّا ثِيڭلْذِيوِينْ ن ثمُّورْثْ ؤُشَا نتَّا إِڭَّا خَافِي، أَذْ أَسْ بْنِيغْ إِشْثْ ن ثَادَّارْثْ ذِي ؤُرْشَالِيمْ، ثنِّي \add إِدْجَانْ\add* ذِي يَاهُوذَا.  
\v 3 مَانْ ونْ زَّايْومْ زِي ڒْڭنْسْ نّسْ، أَذْ يِيڒِي أَربِّي أَكِيذسْ، أجّْ إِ-ث أَذْ إِڭعّذْ غَارْ ؤُرْشَالِيمْ، ثنِّي \add إِدْجَانْ\add* ذِي يَاهُوذَا، أَذْ إِبْنَا ثَادَّارْثْ ن سِيذِي، أَربِّي ن إِسْرَائِيل. أَقَا-ث ذ أَربِّي ونِّي \add إِزدّْغنْ\add* ذِي ؤُرْشَالِيمْ.  
\v 4 قَاعْ ونِّي إِقِّيمنْ عَاذْ ذِي \add شَا ن ومْشَانْ\add* ن مَارَّا إِمُوشَانْ مَانِي إِزدّغْ ذ أَبَارَّانِي، أَذْ كَّارنْ إِرْيَازنْ ن ومْشَانْ نّسْ أَذْ أَسْ وْشنْ أَفُوسْ س نُّوقَارْثْ ذ وُورغْ، س وَاڭْڒَا ذ ڒْمَاڒْ، \add ؤُ مَانْ أَيَا\add* سنّجْ إِ ثوْهِيبْثْ إِمّوْشنْ س ڒْخَاضَارْ إِ ثَادَّارْثْ ن أَربّْ ذِي ؤُرْشَالِيمْ.‘ “   
\b  
\m
\v 5 \add خنِّي\add* كَّارنْ إِزدْجِيفنْ خْ إِبَابَاثنْ \add ن ڒَادْجَاثْ\add* ن يَاهُوذَا ذ بِينْيَامِينْ ؤُڒَا ذ إِكهَّاننْ ذ إِلَاوِييّنْ ؤُ مَارَّا إِنِّي ؤُمِي إِسّْفَاقْ أَربِّي بُوحْبڒْ، مَاحنْذْ أَذْ ڭعّْذنْ حِيمَا أَذْ بْنَانْ ثَادَّارْثْ ن سِيذِي ونِّي \add إِزدّْغنْ\add* ذِي ؤُرْشَالِيمْ.  
\v 6 مَارَّا إِنِّي ذ أَسنْ د-إِنّْضنْ وْشِينْ أَسنْ أَفُوسْ س ڒقْشُوعْ ن نُّوقَارْثْ، س وُورغْ، س وَاڭْڒَا، س ڒْمَاڒْ ؤُ س ڒقْشُوعْ إِغْڒَانْ، بْڒَا مِينْ إِمّوْشنْ س ڒْخَاضَارْ.  
\v 7 أَجدْجِيذْ كُورَاشْ إِسُّوفّغْ ڒقْشُوعْ ن ثَادَّارْثْ ن سِيذِي، ثِينِّي ثُوغَا إِكْسِي نابُوخَاذْنَاصَّارْ زِي ؤُرْشَالِيمْ ؤُشَا إِڭَّا إِ-ثنْثْ ذِي ثَادَّارْثْ ن أَربِّي نّسْ. \x ◘ \xo 1:‏7 \xt 2 إِج. 24‏:‏13؛ 2 إِم. 36‏:‏7\x*  
\v 8 كُورَاشْ، أَجدْجِيذْ ن لْفُورْسْ، إِسُّوفّغْ إِ-ثنْثْ غَارْ بَارَّا س ؤُفُوسْ ن مِيثْرَاذَاثْ، بَابْ ن ثْخُوبَايْ، ونِّي ثنْثْ إِوْشِينْ س ڒحْسَابْ إِ شِيشْبَاصَّارْ، ڒْحَاكمْ ن يَاهُوذَا. \x ◘ \xo 1:‏8 \xt عِز. 5‏:‏14\x*   
\m
\v 9 وَا ثُوغَا ذ ڒْقدّْ نْسنْ: ثْڒَاثِينْ ن طّْبَاصَا ن وُورغْ، أَڒفْ ن طّْبَاصَا ن نُّوقَارْثْ، ثسْعَا ؤُ-عِيشْرِينْ ن ڒمْوَاسْ،  
\v 10 ثْڒَاثِينْ ن إِفنْجَاڒنْ ن وُورغْ، أَربْعَا-مْيَا ؤُ -عشْرَا ن إِفنْجَاڒنْ إِنّغْنِي ن نُّوقَارْثْ ذ وَاڒفْ ن ڒقْشُوعْ نّغْنِيثْ.  
\v 11 مَارَّا ڒقْشُوعْ ن وُورغْ ذ نُّوقَارْثْ ثُوغَا إِوْضنْ خمْسَا-أَڒَافْ ؤُ-أَربْعَا-مْيَا. مَارَّا أَيَا يِيوْيِي ث شِيشْبَاصَّارْ أَكِيذسْ، \add جْمِيعْ\add* أَكْ-ذ أَيْثْ ن لْمنْفَا إِنِّي إِتّْوَانذْهنْ زِي بَابِيلْ غَارْ ؤُرْشَالِيمْ.   
\b  
\b  
\m  
\c 2
\s1 لِيسْثَا ن أَيْثْ ن ثْمحْبَاسْثْ نِّي إِعقْبنْ أَكْ-ذ زَارُوبَّابِيلْ  
\m
\v 1 إِنَا ذ أَيْثْ ن لْعَامَالَا نِّي د-إِڭعّْذنْ زِي ثْمحْبَاسْثْ - إِمنْفِييّنْ نِّي د-إِوْيِي نابُوخَاذْنَاصَّارْ، أَجدْجِيذْ ن بَابِيلْ، ذِي لْمنْفَا غَارْ بَابِيلْ - ؤُشَاعقْبنْ غَارْ ؤُرْشَالِيمْ ذ يَاهُوذَا، كُوڒْ إِجّْ غَارْ ثنْذِينْثْ نّسْ،  
\v 2 \add ؤُشَا\add* ؤُسِينْ-د أَكْ-ذ زَارُوبَّابِيلْ، يَاهُوشَاعْ، نَاهَامْيَا، سَارَايَا، رَاعْلَايَا، مُورْذَاخَا إِ، بِيلْشَانْ، مِيسْفَارْ، بِيغْوَايْ، رَاحُومْ ذ بَاعْنَا. وَا ذ \bd ڒْقدّْ ن يرْيَازنْ ن ڒْڭنْسْ ن إِسْرَائِيل\bd*. \f ◼ \fr 2:‏2 \ft \+bd ’ڒْقدّْ‘\+bd* - نِيغْ ’لْعَاذَاذْ‘.\f*   
\b  
\m
\v 3 أَيْثْ ن نْ فَارْعُوشْ، أَڒْفَاينْ ؤُ-مْيَا ؤُ-ثْنَاينْ ؤُ-سبْعِينْ \add ن يرْيَازنْ\add*.   
\m
\v 4 أَيْثْ ن شَافَاطْيَا، ثڒْثْ-مْيَا ؤُ-ثْنَاينْ ؤُ-سبْعِينْ \add ن يرْيَازنْ\add*.   
\m
\v 5 أَيْثْ ن أَرَاحْ، سبْعَا-مْيَا ؤُ-خمْسَا ؤُ-سبْعِينْ \add ن يرْيَازنْ\add*.   
\m
\v 6 إِحنْجِيرنْ ن فَاهَاثْ-مُوآبَ، زڭْ إِحنْجِيرنْ ن يشُوعَا \add ذ\add* يُو‘أَبْ، أَڒْفَاينْ ؤُ ثمْنمْ-مْيَا ؤُ-ثنْعَاشْ \add ن يرْيَازنْ\add*.   
\m
\v 7 أَيْثْ ن عِيلَامْ، أَڒفْ ؤُ-مِيثَايْنْ ؤُ-أَربْعَا ؤُ-خمْسِينْ \add ن يرْيَازنْ\add*.   
\m
\v 8 أَيْثْ ن زَاتُّو، ثسْعَا-مْيَا ؤُ-خمْسَا ؤُ-ربْعِينْ \add ن يرْيَازنْ\add*.   
\m
\v 9 أَيْثْ ن زَاكَّايْ، سبْعَا-مْيَا ؤُ-ستِّينْ \add ن يرْيَازنْ\add*.   
\m
\v 10 أَيْثْ ن بَانِي، ستَّا-مْيَا ؤُ-ثْنَاينْ ؤُ-ربْعِينْ \add ن يرْيَازنْ\add*.   
\m
\v 11 أَيْثْ ن بَابَايْ، ستَّا-مْيَا ؤُ-ثْڒَاثَا ؤُ-عِيشْرِينْ \add ن يرْيَازنْ\add*.   
\m
\v 12 أَيْثْ ن عَارْجَاذْ، أَڒفْ ؤُ-مِيثَايْنْ ؤُ-ثْنَاينْ ؤُ-عِيشْرِينْ \add ن يرْيَازنْ\add*.   
\m
\v 13 أَيْثْ ن أَذُونِيقَامْ، ستَّا-مْيَا ؤُ-ستَّا ؤُ-ستِّينْ \add ن يرْيَازنْ\add*.\x ◘ \xo 2:‏13 \xt 1 إِج. 10‏:‏14؛ 2 إِم. 9‏:‏13؛ أَسَا. 17‏:‏9. \x*   
\m
\v 14 أَيْثْ ن بِيغْوَايْ، أَڒْفَاينْ ؤُ-ستَّا ؤُ-خمْسِينْ \add ن يرْيَازنْ\add*.   
\m
\v 15 أَيْثْ ن عَاذِينْ، أَربْعَا-مْيَا ؤُ-أَربْعَا ؤُ-خمْسِينْ \add ن يرْيَازنْ\add*.   
\m
\v 16 أَيْثْ ن أَطِيرْ، زِي حِيزْقِييَا، ثْمنْيَا ؤُ-ثسْعِينْ \add ن يرْيَازنْ\add*.   
\m
\v 17 أَيْثْ ن بِيصَايْ، ثڒْثْ-مْيَا ؤُ-ثْڒَاثَا ؤُ-عِيشْرِينْ \add ن يرْيَازنْ\add*.   
\m
\v 18 أَيْثْ ن يُورَا، مْيَا ؤُ-ثنْعَاشْ \add ن يرْيَازنْ\add*.   
\m
\v 19 أَيْثْ ن حَاشُومْ، مِيثَاينْ ؤُ-ثْڒَاثَا ؤُ-عِيشْرِينْ \add ن يرْيَازنْ\add*.   
\m
\v 20 أَيْثْ ن جِيبَّارْ، خمْسَا ؤُ-ثسْعِينْ \add ن يرْيَازنْ\add*.   
\m
\v 21 أَيْثْ ن بَايْثْ-لَاحْمْ، مْيَا ؤُ-ثْڒَاثَا ؤُ-عِيشْرِينْ \add ن يرْيَازنْ\add*.   
\m
\v 22 إِرْيَازنْ نِي نَاطُوفَا، ستَّا ؤُ-خمْسِينْ \add ن يرْيَازنْ\add*.   
\m
\v 23 إِرْيَازنْ ن عَانَاثُوثْ، مْيَا ؤُ-ثْمنْيَا ؤُ-عِيشْرِينْ \add ن يرْيَازنْ\add*.   
\m
\v 24 أَرَّاونْ ن عَازْمَاوثْ، ثْنَاينْ ؤُ-ربْعِينْ \add ن يرْيَازنْ\add*.   
\m
\v 25 أَيْثْ ن قَارْيَاثْ-عَارِيمْ، كَافِيرَا ذ بِيعْرُوثْ، سبْعَا-مْيَا ؤُ-ثْڒَاثَا ؤُ-ربْعِينْ \add ن يرْيَازنْ\add*.   
\m
\v 26 أَيْثْ ن رَامَا ذ جَابَاعْ، ستَّا-مْيَا ؤُ-وَاحذْ ؤُ-عِيشْرِينْ \add ن يرْيَازنْ\add*.   
\m
\v 27 إِرْيَازنْ ن مِيخْمَاسْ، مْيَا ؤُ-ثْنَاينْ ؤُ-عِيشْرِينْ \add ن يرْيَازنْ\add*.   
\m
\v 28 إِرْيَازنْ ن بَايْثْ-إِلْ ذ عَايْ، مِيثَاينْ ؤُ-ثْڒَاثَا ؤُ-عِيشْرِينْ \add ن يرْيَازنْ\add*.   
\m
\v 29 أَيْثْ ن نابُو، ثْنَاينْ ؤُ-خمْسِينْ \add ن يرْيَازنْ\add*.   
\m
\v 30 أَيْثْ ن مَاغْبِيشْ، مْيَا ؤُ-ستَّا ؤُ-خمْسِينْ \add ن يرْيَازنْ\add*.   
\m
\v 31 أَيْثْ ن \add إِجّْ ن\add* عِيلَامْ نّغْنِي، أَڒفْ ؤُ-مِيثَايْنْ ؤُ-أَربْعَا ؤُ-خمْسِينْ \add ن يرْيَازنْ\add*.   
\m
\v 32 أَيْثْ ن حَارِيمْ، ثڒْثْ-مْيَا ؤُ-عِيشْرِينْ \add ن يرْيَازنْ\add*.   
\m
\v 33 أَيْثْ ن لُوذْ، حَاذِيذْ ذ ؤُنُو، سبْعَا-مْيَا ؤُ-خمْسَا ؤُ-عِيشْرِينْ \add ن يرْيَازنْ\add*.   
\m
\v 34 أَيْثْ ن أَرِيحَا، ثڒْثْ-مْيَا ؤُ-خمْسَا ؤُ-ربْعِينْ \add ن يرْيَازنْ\add*.   
\m
\v 35 أَيْثْ ن سَانَائا، ثڒْثْ-أَڒَافْ ؤُ-ستَّا-مْيَا ؤُ-ثْڒَاثِينْ \add ن يرْيَازنْ\add*.   
\b  
\m
\v 36 \bd إِكهَّاننْ.\bd*  
\m أَيْثْ ن يَاذَاعْيَا، زِي ثَادَّارْثْ ن يشُوعَا، ثسْعَا-مْيَا ؤُ-ثْڒَاثَا ؤُ-سبْعِينْ \add ن يرْيَازنْ\add*.   
\m
\v 37 أَيْثْ ن إِمِّيرْ، أَڒفْ ؤُ-ثْنَاينْ ؤُ-خمْسِينْ \add ن يرْيَازنْ\add*.   
\m
\v 38 أَيْثْ ن فَاشْحُورْ، أَڒفْ ؤُ-مِيثَايْنْ ؤُ-سبْعَا ؤُ-ربْعِينْ \add ن يرْيَازنْ\add*.   
\m
\v 39 أَيْثْ ن حَارِيمْ، أَڒفْ ؤُ-سْبعْطَاشْ \add ن يرْيَازنْ\add*.   
\b  
\m
\v 40 \bd إِلَاوِييّنْ.\bd*  
\m أَيْثْ ن يشُوعَا، أَيْثْ ن قَاذْمِييِيلْ، زڭْ أَيْثْ ن هُوذَاوْيَا، أَربْعَا ؤُ-سبْعِينْ \add ن يرْيَازنْ\add*.   
\b  
\m
\v 41 \bd إِمذْيَازنْ.\bd*  
\m أَيْثْ ن أَسَافْ، مْيَا ؤُ-ثْمنْيَا ؤُ-عِيشْرِينْ \add ن يرْيَازنْ\add*.\f ◼ \fr 2:‏41 \ft \+bd ’إِمذْيَازنْ‘\+bd* - نِيغْ ’إِمغْنُوجنْ‘.\f*   
\b  
\m
\v 42 \bd أَيْثْ ن إِعسَّاسنْ ن ثوُّورَا.\bd*  
\m أَيْثْ ن شَالُّومْ، أَيْثْ ن أَطِيرْ، أَيْثْ ن طَالْمُونْ، أَيْثْ ن عَاقُّوبْ، أَيْثْ ن حَاطِيطَا، أَيْثْ ن شُوبَايْ، أَقَا أَثنْ \add جْمِيعْ\add* مْيَا ؤُ-ثسْعَا ؤُ-ثْڒَاثِينْ \add ن يرْيَازنْ\add*.   
\b  
\m
\v 43 \bd إِمْسخَّارنْ ن زَّاوشْثْ ثَامقّْرَانْثْ.\bd*  
\m أَيْثْ ن صِيحَا، أَيْثْ ن حَاسُوفَا، أَيْثْ ن طَابَاعُوثْ،   
\m
\v 44 أَيْثْ ن قِيرُوشْ، أَيْثْ ن سِيعَاهَا، أَيْثْ ن فَاذُونْ،   
\m
\v 45 أَيْثْ ن لَابَانَا، أَيْثْ ن حَاجَابَا، أَيْثْ ن عَاقُّوبْ،   
\m
\v 46 أَيْثْ ن حَاجَابْ، أَيْثْ ن شَامْلَايْ، أَيْثْ ن حَانَانْ،   
\m
\v 47 أَيْثْ ن جَاذِيلْ، أَيْثْ ن حَاجَارْ، أَيْثْ ن رَآيَا،   
\m
\v 48 أَيْثْ ن رَاصِينْ، أَيْثْ ن نَاقُّوذَا، أَيْثْ ن جَازَّامْ،   
\m
\v 49 أَيْثْ ن عُوزَّا، أَيْثْ ن فَاسِيحْ، أَيْثْ ن بِيسَايْ،   
\m
\v 50 أَيْثْ ن أَسْنَا، أَيْثْ ن مَاعُونِيمْ، أَيْثْ ن نَافُوسِيمْ،   
\m
\v 51 أَيْثْ ن بَاقْبُوقْ، أَيْثْ ن حَاقُوفَا، أَيْثْ ن حَارْحُورْ،   
\m
\v 52 أَيْثْ ن بَاصْلُوثْ، أَيْثْ ن مَاحِيذَا، أَيْثْ ن حَارْشَا،   
\m
\v 53 أَيْثْ ن بَارْقُوسْ، أَيْثْ ن سِيسَارَا، أَيْثْ ن ثَامَاحْ،   
\m
\v 54 أَيْثْ ن نَاسِيحْ، أَيْثْ ن حَاطِيفَا.   
\b  
\m
\v 55 \bd أَيْثْ ن إِمْسخَّارنْ ن سُولِيمَانْ.\bd*  
\m أَيْثْ ن سُوطَايْ، أَيْثْ ن سُوفَارَاثْ، أَيْثْ ن فَارُوذَا،   
\m
\v 56 أَيْثْ ن يَاعَالَا، أَيْثْ ن ذَارْقُونْ، أَيْثْ ن جِيذِّيلْ،   
\m
\v 57 أَيْثْ ن شَافَاطْيَا، أَيْثْ ن حَاطِّيلْ، أَيْثْ ن فُوخَارَاثْ-هَا-ضَابَايِيمْ ذ أَيْثْ ن أَمِي.   
\b  
\m
\v 58 مَارَّا إِمْسخَّارنْ ن زَّاوشْثْ ثَامقّْرَانْثْ ذ إِحنْجِيرنْ ن إِمْسخَّارنْ ن سُولِيمَانْ، أَقَا أَثنْ \add جْمِيعْ\add* ثڒْثْ-مْيَا ؤُ-ثْنَاينْ ؤُ-ثسْعِينْ \add ن يرْيَازنْ\add*.   
\b  
\m
\v 59 إِنَا ذ إِنِّي د-إِڭعّْذنْ زِي ثَالْ-مِيلَاحْ، ثَالْ-حَارْشَا، كَارُوبْ، أَدَّانْ ذ إِمِّيرْ، \add مَاشَا\add* وَارْ زمَّارنْ أَذْ سّشْننْ زِي جِّيهثْ ن ثَادَّارْثْ ن ڒجْذُوذْ نْسنْ نِيغْ زِي جِّيهثْ ن زَّارِيعثْ نْسنْ، أَقَا نِيثْنِي \add قَارْسنْ-د\add* زِي إِسْرَائِيل:   
\m
\v 60 أَيْثْ ن ذَالَاجَا، أَيْثْ ن طُوبِييَّا، أَيْثْ ن نَاقُوذَا، ستَّا-مْيَا ؤُ-ثْنَاينْ ؤُ-خمْسِينْ \add ن يرْيَازنْ\add*.   
\m
\v 61 ؤُشَا زڭْ أَيْثْ ن إِكهَّاننْ: أَيْثْ ن حَابَايَا، أَيْثْ ن هَاقُّوصْ، أَيْثْ ن بَارْزِيلَّايْ، \add أَقَا زَّايْسنْ إِنِّي\add* إِوْينْ إِشْثْ ن ثمْغَارْثْ زِي يسِّيسْ ن ؤُجِيلْعَاذِي بَارْزِيلَّايْ ؤُ تّْوَاڒَاغَانْ س يِيسمْ نّسْ.   
\m
\v 62 نِيثْنِي أَرْزُونْ خْ ثوْرِيقْثْ ن ؤُزمّمْ نْسنْ \add ذڭْ وذْلِيسْ ن ثَاصِيڒثْ\add*، مَاشَا وَارْ ت ؤُفِينْ. س ؤُينِّي تّْوَاسُّوفّْغنْ نِيثْنِي زِي ثُوكهَّانْثْ.  
\v 63 لْوَالِي أَمقّْرَانْ إِنَّا أَسنْ، وَارْ تّتّنْ زِي ثْمسْڒَايِينْ إِقدّْسنْ قَاعْ أَڒْ غَا إِكَّارْ إِجّْ ن ؤُكهَّانْ أَكْ-ذ ؤُرِيمْ ذ ثُومِّيمْ.   
\b  
\m
\v 64 مَارَّا أَڭْرَاوْ \add ن ڒْڭنْسْ\add* \add ثُوغَا ذِي\add* ثْنَاينْ ؤُ-ربْعِينْ-أَڒفْ ؤُ-ثڒْثْ-مْيَا ؤُ-ستِّينْ \add ن يرْيَازنْ\add*،  
\v 65 نْهْڒَا إِسمْغَانْ ذ ثِييَّا نْسنْ. إِنَا ثُوغَا أَثنْ مَارَّا سبْعَا-أَڒَافْ ؤُ-ثڒْثْ-مْيَا ؤُ-سبْعَا ؤُ-ثْڒَاثِينْ ؤُشَا غَارْسنْ مِيثَاينْ ن إِمذْيَازنْ ذ ثْمذْيَازِينْ. \f ◼ \fr 2:‏65 \ft \+bd ’إِمذْيَازنْ ذ ثْمذْيَازِينْ‘\+bd* - نِيغْ ’إِمغْنُوجنْ ذ ثْمغْنُوجِينْ‘.\f*   
\b  
\m
\v 66 إِيْسَانْ نْسنْ \add ثُوغَا أَثنْ ذِي\add* سبْعَا-مْيَا ؤُ-ستَّا ؤُ-ثْڒَاثِينْ، ؤُ إِسَارْذَانْ نْسنْ \add ثُوغَا أَثنْ ذِي\add* مِيثَاينْ ؤُ-خمْسَا ؤُ-ربْعِينْ.   
\m
\v 67 إِڒغْمَانْ نْسنْ \add ثُوغَا أَثنْ ذِي\add* أَربْعَا-مْيَا ؤُ-خمْسَا ؤُ-ثْڒَاثِينْ \add ؤُ\add* إِغْيَاڒْ نْسنْ \add ثُوغَا أَثنْ ذِي\add* سبْعَا-مْيَا ؤُ-عِيشْرِينْ.   
\b  
\m
\v 68 ؤُمِي د-يُوسِينْ غَارْ ثَادَّارْثْ ن سِيذِي ذِي ؤُرْشَالِيمْ، وْشِينْ شَا ن إِزدْجِيفنْ خْ إِبَابَاثنْ \add ن ڒَادْجَاثْ\add* س ڒْخَاضَارْ إِ ثَادَّارْثْ ن أَربِّي حِيمَا أَذْ ت سّْبدّنْ ذڭْ ومْشَانْ نّسْ.  
\v 69 نِيثْنِي وْشِينْ إِ سّنْذُوقْ ن ثْخُوبَايْ إِ ڒْخذْمثْ أَنشْثْ ن وَاڭْڒَا نْسنْ وَاحِيثْ ؤُ-ستِّينْ-أَڒفْ ن ذْرَاخْمَاثْ ن وُورغْ ذ خمْسَا-أَڒَافْ ن مِينَايَاثْ ن نُّوقَارْثْ ذ مْيَا ن ثْشَامِيرَاثْ إِ إِكهَّاننْ. \f ◼ \fr 2:‏69 \ft \+bd ’ثِيخُوبَايْ‘\+bd* - نِيغْ ’ڒكْنُوزْ‘.\f*   
\m
\v 70 إِكهَّاننْ ذ إِلَاوِييّنْ ذ شَا زِي ڒْڭنْسْ ذ إِمذْيَازنْ ذ إِعسَّاسنْ ن ثوَّارْثْ ذ إِمْسخَّارنْ ن زَّاوشْثْ ثَامقّْرَانْثْ ڭِّينْ أَذْ زذْغنْ ذِي ثْندَّامْ نْسنْ ؤُ ؤُڒَا ذ مَارَّا إِسْرَائِيل \add إِڭَّا أَذْ إِزْذغْ\add* ذِي ثْندَّامْ نّسْ.   
\b  
\b  
\m  
\c 3
\s1 بدُّو ن ڒبْنِي ن زَّاوشْثْ ثَامقّْرَانْثْ  
\m
\v 1 \add ؤُمِي\add* د-يِيوضْ ؤُيُورْ وِيسّْ سبْعَا ؤُ أَيْثْ ن إِسْرَائِيل ثُوغَا أَثنْ ذِي ثْندَّامْ، إِسّْمُونْ ڒْڭنْسْ أَمْ يِيجّْ ن ورْيَازْ ذِي ؤُرْشَالِيمْ.  
\v 2 إِكَّارْ يَاهُوشَاعْ، مِّيسْ ن يُوصَاذَاقْ، أَكْ-ذ أَيْثْمَاسْ، إِكهَّاننْ، ذ زَارُوبَّابِيلْ، مِّيسْ ن شَاعَالْثِييِيلْ، أَكْ-ذ أَيْثْمَاسْ، ؤُشَا بْنَانْ أَعَالْطَارْ ن أَربِّي ن إِسْرَائِيل، حِيمَا أَذْ خَاسْ قدّْمنْ ثِيغَارْصَا ن وشْمَاضْ أَمْ مَامّشْ ثُورَا ذِي شَّارِيعَا ن مُوسَا، أَرْيَازْ ن أَربِّي. \x ◘ \xo 3:‏2 \xt أَعَوذ. 12‏:‏5، 6\x*  
\v 3 نِيثْنِي سّْبدّنْ أَعَالْطَارْ خْ ذْسُوسَا نّسْ \add مَانِي ث ثُوغَا ذ أَمزْوَارُو\add*، وَاخَّا ثوْضَا-د خَاسنْ ثِيڭّْوُوذِي زِي ڒڭْنُوسْ ن ثمُّورَا، ؤُشَا قدّْمنْ خَاسْ ثِيغَارْصَا ن وشْمَاضْ إِ سِيذِي، ثِيغَارْصَا ن وشْمَاضْ إِ ثُوفُّوثْ ؤُ إِ ثْمذِّيثْ. \x ◘ \xo 3:‏3 \xt ڒخْڒ. 28‏:‏3\x*  
\v 4 نِيثْنِيعيّْذنْ \add عَاوذْ\add* ڒْعِيذْ ن إِعُوشُّوثنْ، أَمْ مَامّشْ ث يُورَا، ؤُشَا \add قدّْمنْ\add* ثِيغَارْصَا ن وشْمَاضْ، أَسّْ إِضْفَارْ ؤُمَاسْ. \add ثُوغَا\add* ڒْقدّْ \add نْسنْثْ\add* إِ يِيجّْ ن وَاسّْ \add عْلَاحْسَابْ مِينْ إِتّْوَاڭّنْ\add* إِ وَاسّْ نِّي. \x ◘ \xo 3:‏4 \xt لَاوِي 23‏:‏34؛ ڒخْڒ. 29‏:‏12\x*  
\v 5 أَوَارْنِي أَسْ \add قدّْمنْ نِيثْنِي\add* ثَاغَارْصْثْ ن وشْمَاضْ نْ ڒبْذَا، \add ثِيغَارْصَا\add* إِ وُوسَّانْ ن ؤُيُورْ ن جْذِيذْ ؤُ إِ مَارَّا ڒعْيُوذَاثْ إِتّْوَاڭّنْ ن سِيذِي إِنِّي ثُوغَا إِتّْوَاقدّْسنْ، ؤُ \add عَاوذْ ثِيغَارْصَا ن\add* كُوڒْ إِجّْ ونِّي إِطّوْعنْ حِيمَا أَذْ إِقدّمْ إِشْثْ ن ثوْهِيبْثْ س ڒْخَاضَارْ إِ سِيذِي. \x ◘ \xo 3:‏5 \xt ڒخْڒ. 28‏:‏11‏-‏15؛ نَاح. 10‏:‏34\x*   
\m
\v 6 زڭْ وَاسّْ أَمزْوَارُو ن ؤُيُورْ وِيسّْ سبْعَا بْذَانْ نِيثْنِي أَذْ قدّْمنْ ثِيغَارْصَا ن وشْمَاضْ إِ سِيذِي، مَاشَا ذْسَاسْ ن زَّاوشْثْ ثَامقّْرَانْثْ ن سِيذِي وَارْ إِتّْوَاڭّْ \add عَاذْ\add*.  
\v 7 وْشِينْ نُّوقَارْثْ إِ إِمَاصُّوثنْ ؤُ إِ يِينِّي إِنقّْشنْ أَكشُّوضْ، ؤُشَا إِ \add أَيْثْ ن\add* سِيذُونْ ؤُ إِ \add أَيْثْ ن\add* صُورْ \add وْشِينْ نِيثْنِي\add* مَاشَّا ذ ثِيسِّيثْ ذ زّشْثْ، مَاحنْذْ أَذْ أَوْينْ أَكشُّوضْ ن ثْنڭْلِينْ ن لُوبْنَانْ غَارْ ڒبْحَارْ غَارْ يَافَا عْلَاحْسَابْ تّسْرِيحْ إِ ذ أَسنْ إِوْشَا كُورَاشْ، أَجدْجِيذْ ن لْفُورْسْ.  
\v 8 ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثْنَاينْ أَوَارْنِي وَاوَاضْ نْسنْ غَارْ ثَادَّارْثْ ن أَربِّي ذِي ؤُرْشَالِيمْ، ذڭْ ؤُيُورْ وِيسّْ ثْنَاينْ، بْذَانْ زَارُوبَّابِيلْ، مِّيسْ ن شَاعَالْثِييِيلْ، ذ يَاهُوشَاعْ، مِّيسْ ن يُوصَاذَاقْ، ذ أَيْثْمَاسْ نْسنْ إِ إِقِّيمنْ، إِكهَّاننْ ذ إِلَاوِييّنْ ذ مَارَّا إِنِّي د-يُوسِينْ زِي ثْمحْبَاسْثْ غَارْ ؤُرْشَالِيمْ، \add ذِي ڒْخذْمثْ\add*. نِيثْنِي ڭِّينْ إِلَاوِييّنْ زِي عِيشْڒِينْ إِسڭّْوُوسَا سنّجْ مَاحنْذْ أَذْ طّْفنْ أَشْبَارْ خْ ڒْخذْمثْ ن ثَادَّارْثْ ن سِيذِي.  
\v 9 ؤُشَا إِكَّارْ يشُوعَا ذ إِحنْجِيرنْ نّسْ ذ أَيْثْمَاسْ، أَكْ-ذ قَاذْمْيِيلْ ذ إِحنْجِيرنْ نّسْ، أَيْثْ ن يَاهُوذَا، أَمْ يِيجّْ ن ورْيَازْ مَاحنْذْ أَذْ طّْفنْ أَشْبَارْ خْ يِينِّي إِڭِّينْ ڒْخذْمثْ ذِي ثَادَّارْثْ ن أَربِّي، \add ؤُ عَاوذْ\add* إِحنْجِيرنْ ن حِينَاذَاذْ أَكْ-ذ إِحنْجِيرنْ نْسنْ ذ أَيْثْمَاثْسنْ إِلَاوِييّنْ.   
\m
\v 10 \add ؤُمِي\add* ثُوغَا إِبنَّاينْ سّْرُوسَانْ ذْسَاسْ إِ زَّاوشْثْ ثَامقّْرَانْثْ ن سِيذِي، سّْبدّنْ نِيثْنِي إِكهَّاننْ س وَارُّوضْ نْسنْ أَكْ-ذ ڒبْوَاقْ، ؤُڒَا ذ إِلَاوِييّنْ، أَيْثْ ن أَسَافْ، س ثدْجُونِينْ ن وُوزَّاڒْ، حِيمَا أَذْ سّمْغَارنْ سِيذِي أَمْ مَامّشْ ثُوغَا إِ ذ أَسنْ إِسّْشنْ ؤُفُوسْ ن ذَاوُوذْ، أَجدْجِيذْ ن إِسْرَائِيل.  
\v 11 نِيثْنِيغنّْجنْ س نُّوبْثَاثْ إِ سِيذِي س ؤُسمْغَارْ ذ ؤُقَاذِي، أَقَا نتَّا إِصْبحْ مِينْزِي ثَامخْسِيوْثْ نّسْ إِشوَّارنْ خْ إِسْرَائِيل ثتّْغِيمَا إِ ڒبْذَا. ؤُ مَارَّا ڒْڭنْسْ إِسْغُويْ س يِيجّْ ن ؤُسْڒِيوْڒوْ إِمْغَارْ إِ ؤُسمْغَارْ ن سِيذِي مَاغَارْ ذْسَاسْ إِ ثَادَّارْثْ ن سِيذِي ثُوغَا إِمَّارْسْ. \x ◘ \xo 3:‏11 \xt إِزهد. 136‏:‏1 \x*  
\v 12 أَطَّاسْ ن إِكهَّاننْ ذ إِلَاوِييّنْ ذ إِزدْجِيفنْ خْ إِبَابَاثنْ \add ن ڒَادْجَاثْ\add*، إِوسُّورَا إِنِّي إِژْرِينْ ثَادَّارْثْ ثَامزْوَارُوثْ، رُونْ س ثْمِيجَّا إِجهْذنْ ؤُمِي إِتّْوَاڭّْ ذْسَاسْ ن ثَادَّارْثْ-أَ زَّاثْ إِ ثِيطَّاوِينْ نْسنْ، \add مَاشَا ؤُڒَا ذ\add* أَطَّاسْ أَرنْينْ ذِي ثْمِيجَّا \add نْسنْ\add* س ؤُسْڒِيوْڒوْ ؤُ س ڒفْرَاحثْ،  
\v 13 أَڒَامِي وَارْ إِزمَّارْ ڒْڭنْسْ أَذْ ميّْزنْ جَارْ ڒْحسّْ ن ؤُسْڒِيوْڒوْ ذ ڒْحسّْ ن إِغُويَّانْ س إِمطَّاونْ نْ ڒْڭنْسْ، مِينْزِي ڒْڭنْسْ إِسْغُويْ س يِيجّْ ن ؤُسْڒِيوْڒوْ إِمْغَارْ أَڒَامِي إِتّْوَاسڒْ ڒْحسّْ زِي ڒَاڭّْوَاجْ.   
\b  
\b  
\m  
\c 4
\s1 ڒعْكَاسثْ خْ ڒبْنِي ن زَّاوشْثْ ثَامقّْرَانْثْ  
\m
\v 1 \add ؤُمِي\add* سْڒنْ إِغْرِيمنْ ن يَاهُوذَا ذ بِينْيَامِينْ، أَقَا أَيْثْ ن لْمنْفَا ثُوغَا بنَّانْ زَّاوشْثْ ثَامقّْرَانْثْ إِ سِيذِي، أَربِّي ن إِسْرَائِيل،  
\v 2 ؤُسِينْ-د نِيثْنِي غَارْ زَارُوبَّابِيلْ ذ إِزدْجِيفنْ خْ إِبَابَاثنْ \add ن ڒَادْجَاثْ\add* ؤُشَا نَّانْ أَسنْ: ”أجّْ أَنغْ أَذْ نبْنَا \add جْمِيعْ\add* أَكِيذْومْ، مِينْزِي ؤُڒَا ذ نشِّينْ نَارزُّو أَربِّي، أَمْ كنِّيوْ، مَاغَارْ نشِّينْ ثُوغَا نْقدّمْ ثِيغَارْصِي زڭْ وُوسَّانْ ن أَسَارْحَادُّونْ، أَجدْجِيذْ ن أَشُّورْ، ونِّي ذ أَنغْ ذَا إِسّْڭعّْذنْ.“ \x ◘ \xo 4:‏2 \xt 2 إِج. 17‏:‏29‏-‏41 \x*  
\v 3 مَاشَا زَارُوبَّابِيلْ ذ يَاهُوشَاعْ ذ إِزدْجِيفنْ إِقِّيمنْ جَارْ إِبَابَاثنْ ن إِسْرَائِيل، نَّانْ أَسنْ: ”وَارْ \add إِدْجِي\add* إِ كنِّيوْ ذ نشِّينْ مَاحنْذْ أَذْ نبْنَا \add جْمِيعْ\add* إِشْثْ ن ثَادَّارْثْ إِ أَربِّي نّغْ. نشِّينْ وحّْذْنغْ أَذْ ت نبْنَا إِ سِيذِي، أَربِّي ن إِسْرَائِيل، أَمْ مَامّشْ إِ ذ أَنغْ يُومُورْ ؤُجدْجِيذْ كُورَاشْ، أَجدْجِيذْ ن لْفُورْسْ.“ \x ◘ \xo 4:‏3 \xt عِز. 1‏:‏1، 2، 3\x*   
\m
\v 4 ؤُشَا إِمْسَارْ، أَقَا ڒْڭنْسْ ن ثمُّورْثْ سَّارْخُونْ إِفَاسّنْ ن ڒْڭنْسْ ن يَاهُوذَا ؤُشَا سِّيڭّْوِيذنْ ثنْ خْ ڒبْنِي.  
\v 5 شْرَانْ إِمْشَاوَارنْ ضِيدّْ نْسنْ، مَاحنْذْ أَذْ سّْبطّْڒنْ أَنْوَايْ نْسنْ، ؤُ \add أَيَا إِكَّا\add* مَارَّا ؤُسَّانْ ن كُورَاشْ، أَجدْجِيذْ ن لْفُورْسْ، أَڒْ ثَاڭلْذَا ن ذَارِييُوسْ، أَجدْجِيذْ ن لْفُورْسْ.  
\v 6 ؤُمِي ثُوغَا أَحَاشْوِيرُوشْ ذ أَجدْجِيذْ، غَارْ بدُّو ن ثْڭلْذَا نّسْ، ؤُرَانْ نِيثْنِي إِجّْ ن ؤُشثْشِي ضِيدّْ إِ إِمزْذَاغْ ن يَاهُوذَا ذ ؤُرْشَالِيمْ.   
\m
\v 7 ذڭْ وُوسَّانْ ن أَرْثَاحْشَاسْثَا يُورَا بِيشْلَامْ \add أَكْ-ذ\add* مِيثْرَاذَاثْ \add ذ\add* طَابَايِيلْ ذ إِعْشِيرنْ نّسْ إِنّغْنِي، إِ ؤُجدْجِيذْ أَرْثَاحْشَاسْثَا، أَجدْجِيذْ ن لْفُورْسْ. ثُوغَا ثَابْرَاثْ ثُورَا س ثِيرَا ن \add إِڒسْ ن\add* ثْرَامِيثْ ؤُ ثُوغَا ثَارْجْمنْ ت \add عَاوذْ\add* غَارْ ثْرَامِيثْ.   
\b  
\m
\v 8 رَاحُومْ، أَمْسُوفّغْ ن ڒحْكَامَاثْ، ذ ؤُمَارِيرْ شِيمْشَايْ ؤُرِينْ إِشْثْ ن ثبْرَاثْ إِ ؤُجدْجِيذْ أَرْثَاحْشَاسْثَا ضِيدّْ إِ ؤُرْشَالِيمْ، ثنِّي \add ذَايسْ يُورَا\add* أَمُّو:   
\b  
\m
\v 9 ”رَاحُومْ، أَمْسُوفّغْ ن ڒحْكَامَاثْ، ذ ؤُمَارِيرْ شِيمْشَايْ ذ إِنِّي إِقِّيمنْ زڭْ إِقْرِيننْ نْسنْ ذِي ڒْخذْمثْ، ڒْقُوضَاثْ، إِمْخَازْنِييّنْ، أَيْثْ ن شّنْعثْ ذ أَيْثْ ن لْفُورْسْ ذ أَيْثْ ن إِرِيخْ ذ بَابِيلُونْ ذ شُوشَانْ، أَقَا أَثنْ ذ إِعِيلَامِييّنْ،  
\v 10 ذ شُّوعُوبْ نّغْنِي، إِنِّي إِوْيِي ثنْ أَسْنَافَّارْ أَمقّْرَانْ أَمْشنّعْ غَارْ لْمنْفَا ؤُ إِسّزْذغْ إِ-ثنْ ذِي ثنْذِينْثْ ن سَامَارْيَا ؤُ ذِي جِّيهثْ إِقِّيمنْ خْ ؤُجمَّاضْ ن إِغْزَارْ \add ن لْفُورَاطْ\add* ... ؤُشَا عَاذْ.“   
\b  
\m
\v 11 ثَا ذ ثِيڒمْثْ ن ثبْرَاثْ إِ د-سّكّنْ نِيثْنِي إِ ؤُجدْجِيذْ أَرْثَاحْشَاسْثَا:  
\b  
\m ”إِمْسخَّارنْ نّشْ، إِرْيَازنْ نِّي \add إِدْجَانْ\add* خْ ؤُجمَّاضْ ن إِغْزَارْ \add ن لْفُورَاطْ\add* ... ؤُشَا عَاذْ.“   
\b  
\m
\v 12 ”إِڒِي أَذْ إِسّنْ ؤُجدْجِيذْ أَقَا ؤُذَاينْ إِ د-إِڭعّْذنْ زِي غَاركْ، أَقَا إِوْضنْ-د غَارْنغْ غَارْ ؤُرْشَالِيمْ ؤُشَا نِيثْنِي أَقَا بنَّانْ ثَانْذِينْثْ نِّي إِغوّْغنْ ثَاعفَّانْثْ، أَقَا تّْكمَّاڒنْ ڒحْيُوضْ ؤُعدّْڒنْ ذْسُوسَا.  
\v 13 \add خنِّي\add* ڒخُّو، إِتّْخصَّا أَذْ إِسّنْ ؤُجدْجِيذْ، مَاڒَا ثَانْذِينْثْ نِّي أَذْ ثتّْوَاسّْبدّْ ثْوَاڒَا نّغْنِي ؤُ ڒحْيُوضْ أَذْ تّْوَاكمّْڒنْ، أَقَا نتَّاثْ وَارْ ثتِّيشْ لْجِيزْيَا ڒَا ذ ڒعْشُورْ ؤُڒَا ذ ضَّارِيبَا ن وبْرِيذْ ؤُشَا \add أَمُّو إِ\add* غَا إِسّخْسَارْ أَرْبحْ ن إِجدْجِيذنْ.  
\v 14 \add خنِّي\add* ڒخُّو، ؤُمِي نشِّينْ نتّْمدْجَاحْ مَاشَّا نّغْ س ثْمدْجَاحْثْ ن ڒقْصَارْ ؤُ وَارْ ذ أَنغْ د-ثُوسِي مَاڒَا نشِّينْ نْخزَّارْ ؤُمِي إِتّْوَاسّْبهْذڒْ ؤُجدْجِيذْ، خْ ؤُينِّي نسّكّْ-د ثَابْرَاثْ-أَ ؤُشَا نسَّارْڭبْ أَيَا إِ ؤُجدْجِيذْ،  
\v 15 حِيمَا أَذْ أَرْزُونْ ذڭْ وذْلِيسْ ن إِمزْرُوينْ ن ڒجْذُوذْ نْومْ ؤُشَا أَذْ ثَافذْ ذڭْ وذْلِيسْ ن إِمزْرُوينْ ؤُشَا أَذْ \add زَّايسْ\add* ثسّْنذْ أَقَا ثَانْذِينْثْ-أَ ذ إِشْثْ ن ثنْذِينْثْ إِغوّْغنْ، ثِيوِي-د أَرّْژِييّثْ إِ إِجدْجِيذنْ ؤُ إِ لْعَامَالَاثْ ؤُ زڭْ وشْحَاڒْ ؤُيَا سّكَّارَانْ ذَايسْ أَغوّغْ. س ؤُينِّي ثتّْوَاهْذمْ ثنْذِينْثْ-أَ.  
\v 16 نشِّينْ نسَّارْڭبْ أَجدْجِيذْ، أَقَا، مَاڒَا أَذْ ثتّْوَابْنَا ثنْذِينْثْ-أَ \add عَاوذْ\add* ؤُشَا أَذْ تّْوَاكمّْڒنْ ڒحْيُوضْ نّسْ، خنِّي وَارْ غَاركْ تّتِّيڒِي شَا ثصْغَارْثْ \add عَاذْ\add* خْ ؤُجمَّاضْ ن إِغْزَارْ \add ن لْفُورَاطْ\add*.“   
\b  
\m
\v 17 إِسّكّْ ؤُجدْجِيذْ ثَامْوَارِّيثْ إِ رَاحُومْ، أَمْسُوفّغْ ن ڒحْكَامَاثْ، ؤُ إِ ؤُمَارِيرْ شِيمْشَايْ ذ إِنِّي إِقِّيمنْ زڭْ إِقْرِيننْ نْسنْ ذِي ڒْخذْمثْ إِنِّي إِزدّْغنْ ذِي سَامَارْيَا، ؤُ ؤُڒَا إِ يِينِّي إِقِّيمنْ \add زدّْغنْ\add* خْ ؤُجمَّاضْ ن إِغْزَارْ \add ن لْفُورَاطْ\add*:  
\b  
\m ”ڒهْنَا! ... ؤُشَا عَاذْ.“   
\b  
\m
\v 18 ”ثَابْرَاثْ إِ ذ أَنغْ د-ثسّكّمْ، أَقَا ثتّْوَاغَارْ خَافِي نِيشَانْ.  
\v 19 ؤُشَا \add أَوَارْنِي ڒَامِي\add* ؤُمُورغْ \add أَيَا\add*، ثتّْوَاڭّْ إِشْثْ ن ثَارزُّوثْ ؤُشَا ؤُفِينْ أَقَا ثَانْذِينْثْ-أَ ثْغوّغْ خْ إِجدْجِيذنْ زڭْ وشْحَاڒْ ؤُيَا ؤُشَا سّكَّارنْ ذَايسْ \add ڒبْذَا\add* أَغوّغْ ذ ڒحْوڒْ.  
\v 20 عَاوذْ ثُوغَا \add ذِينْ\add* إِجدْجِيذنْ إِمقّْرَاننْ خْ ؤُرْشَالِيمْ، إِنِّي ثُوغَا إِحكّْمنْ ذِي مَارَّا \add جّْوَايهْ\add* خْ ؤُجمَّاضْ ن إِغْزَارْ \add ن لْفُورَاطْ\add* أَڒَامِي ثتّْوَاخدْجصْ أَسنْ لْجِيزْيَا ذ ڒعْشُورْ ذ ضَّارِيبَا ن وبْرِيذْ.  
\v 21 إِوَا، ڒخُّو ؤُمُورمْ أَذْ سّْبدّمْ إِرْيَازنْ-أَ. ثَانْذِينْثْ وَارْ ثْبنِّي ثْوَاڒَا نّغْنِيثْ أَڒْ غَا إِتّْوَاسُّوفّغْ زَّايِي ڒُومُورْ \add إِ ؤُيَا\add*.  
\v 22 غَارْومْ أَقَا أَذْ ثَارْخُومْ زِي ثْمسْڒَاشْثْ-أَ. مَايمِّي غَا ثمْغَارْ ذْرُوشْثْ \add عَاذْ\add* إِ ثْخسَّارْثْ ن إِجدْجِيذنْ؟“   
\b  
\m
\v 23 ڒَامِي ثتّْوَاغَارْ ثبْرَاثْ ن ؤُجدْجِيذْ أَرْثَاحْشَاسْثَا إِ رَاحُومْ ذ شِيمْشَايْ، أَمَارِيرْ، ذ إِقْرِيننْ نْسنْ ذِي ڒْخذْمثْ، ؤُيُورنْ إِنَا س ثَازْڒَا غَارْ ؤُرْشَالِيمْ، غَارْ وُوذَاينْ ؤُشَا سّْبدّنْ ثنْ \add زِي ڒْخذْمثْ نْسنْ\add* س ؤُغِيڒْ ؤُ س ڒْخُونْشثْ.  
\v 24 خنِّي ثْبدّْ ڒْخذْمثْ إِ ثَادَّارْثْ ن أَربِّي ونِّي إِزدّْغنْ ذِي ؤُرْشَالِيمْ ؤُشَا إِقِّيمْ إِبدّْ أَڒْ أَسڭّْوَاسْ وِيسّْ ثْنَاينْ ن ثْڭلْذَا ن ذَارِييُوسْ، أَجدْجِيذْ ن لْفُورْسْ.   
\b  
\b  
\m  
\c 5
\s1 ڒبْنِي ن زَّاوشْثْ ثَامقّْرَانْثْ ذڭْ وُوسَّانْ ن ذَارِييُوسْ  
\m
\v 1 \add خنِّي\add* نبَّانْ إِنَابِييّنْ، إِنَابِييّنْ حَاڭَّايْ ذ زَاكَارِييَّا، مِّيسْ ن عِيذُو، إِ وُوذَاينْ نِّي \add إِدْجَانْ\add* ذِي يَاهُوذَا ذ ؤُرْشَالِيمْ. \add نَابّنْ\add* غَارْسنْ س يِيسمْ ن أَربِّي ن إِسْرَائِيل نِّي خَاسنْ \add إِتّْوَاڒَاغَا\add*. \x ◘ \xo 5:‏1 \xt Ḥag. 1‏:‏1؛ زَاك. 1‏:‏1\x*  
\v 2 خَاسْ ؤُشَا إِكَّارْ زَارُوبَّابِيلْ، مِّيسْ ن شَاعَالْثِييِيلْ، ذ يَاهُوشَاعْ، مِّيسْ ن يُوصَاذَاقْ، ؤُشَا نِيثْنِي بْذَانْ أَذْ بْنَانْ ثَادَّارْثْ ن أَربِّي ذِي ؤُرْشَالِيمْ \add عَاوذْ\add*، ؤُشَا إِنَابِييّنْ ن أَربِّي، إِنِّي أَكِيذْسنْ إِبدّنْ، \add ثُوغَا أَثنْ ذِينْ\add* أَكِيذْسنْ.   
\m
\v 3 ذِي ڒْوقْثْ نِّي يُوسَا-د ثَاثْنَايْ، لْوَالِي ن \add وقْلِيمْ\add* خْ ؤُجمَّاضْ ن إِغْزَارْ \add ن لْفُورَاطْ\add*، أَكْ-ذ شَاثَارْ-بُوزْنَايْ ؤُ غَارْسنْ إِقْرِيننْ نْسنْ ذِي ڒْخذْمثْ. نِيثْنِي نَّانْ أَسنْ أَمُّو: ”مَانْ ونْ إِ كنِّيوْ يُومُورنْ، مَاحنْذْ أَذْ ثبْنَامْ ثَادَّارْثْ-أَ ؤُ \add مَاحنْذْ\add* أَذْ ثْكمّْڒمْ ڒْحِيضْ-أَ؟“  
\v 4 خنِّي ننَّا أَسنْ إِسْمَاونْ ن يرْيَازنْ إِ ثُوغَا إِبنَّانْ ڒبْنِي-يَا.  
\v 5 \add مَاشَا\add* ثِيطّْ ن أَربِّي نْسنْ ثُوغَا-ت خْ إِمْغَارنْ ن وُوذَاينْ ؤُشَا نِيثْنِي ڭِّينْ وَارْ ثنْ سّْبدَّانْ \add زِي ڒْخذْمثْ\add* أَڒْ غَا ثَاوضْ ثْمسْڒَاشْثْ غَارْ ذَارِييُوسْ ؤُشَا أَوَارْنِي أَيَا أَذْ طّْفنْ ثَابْرَاثْ خْ مَانْ أَيَا.   
\b  
\m
\v 6 ثِيڒمْثْ ن ثبْرَاثْ نِّي إِسّكّْ ثَاثْنَايْ، لْوَالِي \add ن ثمُّورْثْ\add* خْ ؤُجمَّاضْ ن إِغْزَارْ \add ن لْفُورَاطْ\add*، أَكْ-ذ شَاثَارْ-بُوزْنَايْ ذ إِقْرِيننْ نّسْ ذِي ڒْخذْمثْ، إِقْرِيننْ نِّي \add إِدْجَانْ\add* خْ ؤُجمَّاضْ ن إِغْزَارْ \add ن لْفُورَاطْ\add*، غَارْ ؤُجدْجِيذْ ذَارِييُوسْ.   
\m
\v 7 نِيثْنِي سّكّنْ أَسْ-د إِشْثْ ن ثبْرَاثْ ثُورَا ذَايسْ أَمُّو:  
\b  
\m ”أَذْ يِيڒِي إِ ؤُجدْجِيذْ ذَارِييُوسْ ڒهْنَا زِي مَارَّا إِغزْذِيسنْ!“   
\b  
\m
\v 8 ”إِتّْخصْسَا أَذْ إِسّنْ ؤُجدْجِيذْ، أَقَا نشِّينْ نُويُورْ غَارْ لْعَامَالَا ن يَاهُوذَا، غَارْ ثَادَّارْثْ ن أَربِّي أَمقّْرَانْ. أَقَا ثتّْوَابنَّا \add ثَادَّارْثْ نِّي\add* س إِژْرَا إِمقّْرَاننْ إِ إِتّْخصَّانْ أَذْ تّْوَانّْضنْ \add غَارْ ومْشَانْ نْسنْ\add*، ؤُ إِتّْوَاتّڭّْ ؤُكشُّوضْ ذِي ڒحْيُوضْ. تّڭّنْ نِيثْنِي ڒْخذْمثْ-أَ س شْضَارثْ ؤُشَا ثڭُّورْ مْلِيحْ جَارْ إِفَاسّنْ نْسنْ.  
\v 9 نشِّينْ نسّقْسَا إِمْغَارنْ-أَ ؤُ ننَّا \add أَسنْ\add* أَمُّو: ’مَانْ ونْ إِ ذ أَومْ إِوْشِينْ ڒُومُورْ مَاحنْذْ أَذْ ثسّْبدّمْ ثَادَّارْثْ-أَ ؤُ أَذْ ثْكمّْڒمْ ڒْحِيضْ-أَ؟‘  
\v 10 نسّقْسَا ثنْ ؤُڒَا خْ إِسْمَاونْ نْسنْ حِيمَا أَذْ أَشْ ثنْ-إِ-د-نِينِي، أَڒَامِي نِيوضْ أَذْ نْزمّمْ إِسْمَاونْ ن يرْيَازنْ نِّي إِدْجَانْ غَارْ ؤُزدْجِيفْ نْسنْ.  
\v 11 نِيثْنِي أَرِّينْ أَنغْ-د، نَّانْ أَمُّو: ’نشِّينْ ذ إِمْسخَّارنْ ن أَربِّي ن إِجنْوَانْ ذ ثمُّورْثْ ؤُ نبْنَا ثَادَّارْثْ ثنِّي ثتّْوَابْنَا ذَانِيثَا أَطَّاسْ ن إِسڭّْوُوسَا زڭْ وَامِي. إِجّْ ن ؤُجدْجِيذْ ذ أَمقّْرَانْ ن إِسْرَائِيل إِبْنَا ت ؤُ إِكمّڒْ إِ-ت.  
\v 12 مَاشَا أَوَارْنِي ڒَامِي سّْعَارنْ ڒجْذُوذْ نّغْ أَربِّي ن إِجنْوَانْ، أَقَا إِوْشَا إِ-ثنْ ذڭْ ؤُفُوسْ ن نابُوخَاذْنَاصَّارْ، أَجدْجِيذْ ن بَابِيلْ، أَخَالْذِيوِي، ونِّي إِهذْمنْ ثَادَّارْثْ-أَ ؤُ إِنْذهْ ڒْڭنْسْ غَارْ لْمنْفَا غَارْ بَابِيلْ. \x ◘ \xo 5:‏12 \xt 2 إِم. 36‏:‏16‏-‏21\x*   
\b  
\m
\v 13 مَاشَا ذڭْ ؤُسڭّْوَاسْ أَمزْوَارُو ن كُورَاشْ، أَجدْجِيذْ ن بَابِيلْ، يُومُورْ كُورَاشْ أَذْ سّْبدّنْ ثَادَّارْثْ-أَ ن أَربِّي \add ثْوَاڒَاثْ نّغْنِي\add*. \x ◘ \xo 5:‏13 \xt 2 إِم. 36‏:‏22، 23؛ عِز. 1\x*  
\v 14 ؤُڒَا ذ ڒقْشُوعْ ن وُورغْ ذ نُّوقَارْثْ زِي ثَادَّارْثْ ن أَربِّي، ثِينِّي إِكّسْ نابُوخَاذْنَاصَّارْ زِي زَّاوشْثْ ثَامقّْرَانْثْ ذِي ؤُرْشَالِيمْ، إِسِّيذفْ إِ-ثنْثْ غَارْ زَّاوشْثْ ن بَابِيلْ، أَقَا إِسُّوفّغْ إِ-ثنْثْ كُورَاشْ زِي زَّاوشْثْ ذِي بَابِيلْ ؤُ إِوْشَا \add إِ-ثنْثْ\add* إِ \add إِجّْ ن ورْيَازْ\add* قَّارنْ أَسْ شِيشْبَاصَّارْ، ونِّي ثُوغَا إِڭَّا ذ لْوَالِي. \x ◘ \xo 5:‏14 \xt عِز. 1‏:‏8\x*  
\v 15 نتَّا إِنَّا أَسْ: كْسِي ڒقْشُوعْ-أَ، رُوحْ، ڭّمْ ثنْ ذِي زَّاوشْثْ ثَامقّْرَانْثْ ذِي ؤُرْشَالِيمْ. إِتّْخصَّا أَذْ ثتّْوَابْنَا ثَادَّارْثْ ن أَربِّي ذڭْ ومْشَانْ نّسْ \add ن زِيشْ\add*.   
\m
\v 16 خَاسْ ؤُشَا يُوسَا-د شِيشْبَاصَّارْ وَانِيثَا، ؤُشَا إِسَّارْسْ ذْسُوسَا إِ ثَادَّارْثْ ن أَربِّي ذِي ؤُرْشَالِيمْ ؤُ سّنِّي أَڒْ ڒخُّو أَقَا بنَّانْ \add ت\add*، \add مَاشَا\add* وَارْ ثتّْوَاكمّڒْ \add عَاذْ\add*.‘  
\v 17 خنِّي ڒخُّو، مَاڒَا يَارْضَا إِ ؤُجدْجِيذْ، أجّْ أَذْ أَرْزُونْ ذڭْ وخَّامْ ن ثْخُوبَايْ ن ؤُجدْجِيذْ ذِي بَابِيلْ، مَا س ثِيذتّْ إِمّوْشْ ڒُومُورْ زِي غَارْ ؤُجدْجِيذْ كُورَاشْ حِيمَا أَذْ ثتّْوَابْنَا ثَادَّارْثْ-أَ ن أَربِّي ذِي ؤُرْشَالِيمْ ثْوَاڒَا نّغْنِي ؤُشَا أَذْ أَنغْ د-إِتّْوَاسّكّْ \add خنِّي\add* لْقَارَارْ ن ؤُجدْجِيذْ.“   
\b  
\b  
\m  
\c 6
\s1 ڒُومُورْ ن ؤُجدْجِيذْ ذَارِييُوسْ  
\m
\v 1 خنِّي إِسُّوفّغْ ؤُجدْجِيذْ ذَارِييُوسْ ڒُومُورْ ؤُشَا أَرْزُونْ ذِي ثَادَّارْثْ ن إِذْلِيسنْ إِتّْوَانّْضنْ، مَانِي تّْوَاخمّْڒنْثْ ثْخُوبَايْ ذِينْ ذِي بَابِيلْ.  
\v 2 \add خنِّي\add* إِتّْوَافْ ذِي أَحْمَاثَا إِجّْ ن وذْلِيسْ إِتّْوَانّْضنْ ذِي لْقلْعَا ثنِّي \add إِدْجَانْ\add* ذِي لْعَامَالَا ن مِيذْيَا ؤُ ذَايسْ ثُوغَا ثِيرَا-يَا ن ڒِيذَارثْ:   
\b  
\m
\v 3 ”ذڭْ ؤُسڭّْوَاسْ أَمزْوَارُو ن ؤُجدْجِيذْ كُورَاشْ، إِسُّوفّغْ كُورَاشْ ڒُومُورْ-أَ: ’\add خْ\add* ثَادَّارْثْ ن أَربِّي ذِي ؤُرْشَالِيمْ. أَقَا إِتّْخصَّا أَذْ ثتّْوَابْنَا ثَادَّارْثْ نِّي \add ثْوَاڒَا نّغْنِيثْ\add* ذڭْ ومْشَانْ مَانِي قدّْمنْ ثِيغَارْصَا ؤُ \add إِتّْخصَّا\add* أَذْ تّْوَاعدّْڒنْ ذْسُوسَا نّسْ. ڒُوعْڒَا نّسْ \add أَذْ ثِيڒِي\add* ستِّينْ ن إِغَادْجنْ، ثِيرُو نّسْ ستِّينْ ن إِغَادْجنْ،  
\v 4 س ثْڒَاثَا ن ڒسْذُوذْ ن ثْصُوضَارْ ثِيمقّْرَانِينْ ذ إِجّْ ن سّدّْ ن ثفْڒَاوْثْ ذ جْذِيذْ. مِينْ ذِينْ إِخصّنْ أَذْ زَّايسْ ثتّْوَاكلّفْ زِي ثَادَّارْثْ ن ؤُجدْجِيذْ.  
\v 5 ؤُڒَا ذ ڒقْشُوعْ ن وُورغْ ذ نُّوقَارْثْ ن ثَادَّارْثْ ن أَربِّي، ثِينِّي إِكّسْ نابُوخَاذْنَاصَّارْ زِي زَّاوشْثْ ثَامقّْرَانْثْ نِّي \add إِدْجَانْ\add* ذِي ؤُرْشَالِيمْ ؤُ إِوْيِي ثنْثْ غَارْ بَابِيلْ، أَذْ تّْوَارّنْثْ. مَانْ أَيَا \add مَارَّا\add* أَذْ د-إِذْوڒْ غَارْ زَّاوشْثْ ثَامقّْرَانْثْ ذِي ؤُرْشَالِيمْ، غَارْ ومْشَانْ نّسْ. إِتّْخصَّا أَذْ ثمَّارْسذْ مَارَّا مَانْ أَيَا ذِي ثَادَّارْثْ ن أَربِّي.‘   
\b  
\m
\v 6 س ؤُيَا، ثَاثْنَايْ، لْوَالِي ن \add ثمُّورْثْ\add* خْ ؤُجمَّاضْ ن إِغْزَارْ \add ن لْفُورَاطْ\add*، شَاثَارْ-بُوزْنَايْ ذ إِقّْرِيننْ نّسْ ذِي ڒْخذْمثْ، إِقّْرِيننْ نِّي \add إِدْجَانْ\add* خْ ؤُجمَّاضْ ن إِغْزَارْ \add ن لْفُورَاطْ\add*، أَڭّْوجمْ سّنِّي!  
\v 7 جّمْ ڒْخذْمثْ ذِي طّْوعْ ن ثَادَّارْثْ-أَ ن أَربِّي، \add حِيمَا\add* لْوَالِي ن وُوذَاينْ أَكْ-ذ إِمْغَارنْ ن وُوذَاينْ أَذْ بْنَانْ ثَادَّارْثْ-أَ ن أَربِّي ثْوَاڒَا نّغْنِيثْ ذڭْ ومْشَانْ نّسْ.  
\v 8 عَاوذْ إِتّْوَاسُّوفّغْ-د زَّايِي ڒُومُورْ خْ مِينْ إِتّْخصَّا أَذْ ثڭّمْ إِ إِمْغَارنْ ن وُوذَاينْ-أَ مَاحنْذْ أَذْ ثتّْوَابْنَا ثَادَّارْثْ-أَ ن أَربِّي \add ثْوَاڒَاثْ نّغْنِي\add*. زڭْ وَاڭْڒَا ن ؤُجدْجِيذْ، زِي لْجِيزْيَا \add ن ثمُّورْثْ\add* خْ ؤُجمَّاضْ ن إِغْزَارْ \add ن لْفُورَاطْ\add*، أَذْ إِتّْوَاخدْجصْ س شْضَارثْ مِينْ إِتّْخصّنْ إِرْيَازنْ-أَ مَاحنْذْ وَارْ ثتّْبذِّي شَا \add ڒْْخذْمثْ\add*.  
\v 9 ؤُ مِينْ إِتّْخصّنْ زڭْ إِفُونَاسنْ إِمژْيَاننْ ذ إِشَارِّييّنْ ذ إِزْمَارنْ ذ ثْغَارْصِي ن وشْمَاضْ إِ أَربِّي ن إِجنْوَانْ، ؤُ مِينْ إِتّْخصّنْ زڭْ إِرْذنْ ذ ثْمدْجَاحْثْ ذ بِينُو ذ زّشْثْ عْلَاحْسَابْ أَوَاڒْ ن إِكهَّاننْ إِ إِدْجَانْ ذِي ؤُرْشَالِيمْ، أَذْ أَسنْ إِمّوْشْ زڭْ وَاسّْ غَارْ وَاسّْ، حِيمَا وَارْ إِتّْخصِّي ؤُڒَا ذ وَالُو،  
\v 10 حِيمَا أَذْ قدّْمنْ إِشْثْ ن ڒفْوَاحثْ إِتّْفُوحنْ إِ أَربِّي ن إِجنْوَانْ ؤُشَا أَذْ ژَّادْجنْ ذِي طّْوعْ ن ثُوذَارْثْ ن ؤُجدْجِيذْ ذ إِحنْجِيرنْ نّسْ.   
\m
\v 11 إِتّْوَاسُّوفّغْ-د زَّايِي ڒُومُورْ حِيمَا كُوڒْ إِجّنْ ونِّي إِ غَا إِبدّْڒنْ ثَاوْصيّثْ-أَ، أَذْ إِتّْوَاكّسْ إِجّْ ن وعْمُوذْ زِي ثَادَّارْثْ نّسْ أَذْ ث سّْبدّنْ، أَذْ خَاسْ إِتّْوَايڒْ نتَّا ؤُشَا ذِي سِّيبّثْ-أَ أَذْ ثذْوڒْ ثَادَّارْثْ نّسْ ذ إِشْثْ ن ثْزُوبَاشْثْ نْ ڒغْبَارْ. \x ◘ \xo 6:‏11 \xt 2 إِج. 10‏:‏27؛ دَان. 2‏:‏5؛ 3‏:‏29. \x*   
\m
\v 12 أجّْ أَذْ إِهْذمْ أَربِّي، ونِّي ذِينْ إِسّزْذْغنْ إِسمْ نّسْ، كُوڒْ أَجدْجِيذْ ذ كُوڒْ ڒْڭنْسْ نِّي إِ غَا إِسّْوِيژّْضنْ أَفُوسْ نّسْ مَاحنْذْ أَذْ إِبدّڒْ نِيغْ أَذْ يَاردّدْجْ ثَادَّارْثْ ن أَربِّي نِّي \add إِدْجَانْ\add* ذِي ؤُرْشَالِيمْ. نشّْ ذَارِييُوسْ، ذ ونِّي إِوْشِينْ ڒُومُورْ. أجّْ أَذْ إِتّْوَاڭّْ مَانْ أَيَا س شْضَارثْ.“   
\b  
\m  
\s1 أَذشّنْ ن زَّاوشْثْ ثَامقّْرَانْثْ ذ ڒْعِيذْ أَمزْوَارُو ن ثْغَارْصْثْ ن ؤُسعْذُو  
\m
\v 13 خنِّي ثَاثْنَايْ، لْوَالِي \add ن ثمُّورْثْ\add* خْ ؤُجمَّاضْ ن إِغْزَارْ \add ن لْفُورَاطْ\add*، أَكْ-ذ شَاثَارْ-بُوزْنَايْ ذ إِقْرِيننْ نّسْ ذِي ڒْخذْمثْ ڭِّينْ س شْضَارثْ عْلَاحْسَابْ \add ڒُْومُورْ\add* إِ ثُوغَا د-إِسّكّْ ؤُجدْجِيذْ ذَارِييُوسْ.  
\v 14 بْنَانْ إِمْغَارنْ ن وُوذَاينْ ؤُ نِيثْنِي أَرْنِينْ مْلِيحْ \add ذِي ڒبْنِي\add* ؤُمِي ثُوغَا إِتّْنبَّا حَاڭَّايْ ذ زَاكَارِييَّا، مِّيسْ ن عِيدُّو. نِيثْنِي بْنَانْ ؤُ كمّْڒنْ ت عْلَاحْسَابْ ڒُومُورْ ن أَربِّي ن إِسْرَائِيل ؤُ عْلَاحْسَابْ ڒُومُورْ ن كُورَاشْ ذ ذَارِييُوسْ ذ أَرْثَاحْشَاسْثَا، أَجدْجِيذْ ن لْفُورْسْ.  
\v 15 ؤُشَا \add أَمُّو\add* ثتّْوَاكمّڒْ ثَادَّارْثْ ذڭْ وَاسّْ وِيسّْ ثْڒَاثَا ن ؤُيُورْ أَذَارْ، أَقَا-ث ذ أَسڭّْوَاسْ وِيسّْ ستَّا ن ثْڭلْذَا ن ؤُجدْجِيذْ ذَارِييُوسْ.  
\v 16 أَيْثْ ن إِسْرَائِيل، إِكهَّاننْ ذ إِلَاوِييّنْ ذ أَيْثْ ن لْمنْفَا إِ إِقِّيمنْ، ذشّْننْ ثَادَّارْثْ-أَ ن أَربِّي س ڒفْرَاحثْ.  
\v 17 إِ ؤُذشّنْ ن ثَادَّارْثْ ن أَربِّي إِوْينْ نِيثْنِي مْيَا ن إِفُونَاسنْ، مِيثَاينْ ن إِشَارِّييّنْ ذ أَربْعَا-مْيَا ن إِزْمَارنْ \add ذ ثَاغَارْصْثْ\add*، ؤُ إِ ثَاغَارْصْثْ ن دّنْبْ ثنْعَاشْ ن إِمُويَانْ إِ مَارَّا إِسْرَائِيل عْلَاحْسَابْ ڒْقدّْ ن ثْقبَّاڒْ ن إِسْرَائِيل.  
\v 18 نِيثْنِي سّْبدّنْ إِكهَّاننْ س ثرْبِيعِينْ نْسنْ ؤُ إِلَاوِييّنْ ذِي ثرْبِيعِينْ نْسنْ إِ ثْسخَّارْثْ إِ أَربِّي نِّي \add إِدْجَانْ\add* ذِي ؤُرْشَالِيمْ، عْلَاحْسَابْ ثَاوْصيّثْ ن وذْلِيسْ ن مُوسَا. \x ◘ \xo 6:‏18 \xt ڒخْڒ. 3‏:‏6، 32؛ 8‏:‏11؛ 1 إِم. 24‏:‏1\x*   
\b  
\m
\v 19 ذڭْ \add وَاسّْ\add* وِيسّْ أَرْبعْطَاشْ ن ؤُيُورْ أَمزْوَارُو سّْوجْذنْ أَيْثْ ن لْمنْفَا إِ \add ثْغَارْصْثْ ن\add* ؤُسعْذُو. \x ◘ \xo 6:‏19 \xt ؤُف. 12‏:‏1‏-‏28؛ لَاوِي 23‏:‏5؛ ڒخْڒ. 28‏:‏16؛ أَعَوذ. 16‏:‏2\x*  
\v 20 مِينْزِي إِكهَّاننْ ذ إِلَاوِييّنْ ڭِّينْ أَذْ سِّيزْذْڭنْ إِخفْ نْسنْ أَمْ يِيجّْ ن ورْيَازْ. ثُوغَا-ثنْ مَارَّا ذ إِمزْذَاڭنْ ؤُ نِيثْنِي غَارْصنْ \add ثَاغَارْصْثْ ن\add* ؤُسعْذُو إِ مَارَّا أَيْثْ ن لْمنْفَا ؤُ إِ أَيْثْمَاثْسنْ إِكهَّاننْ ؤُ إِ يِيخفْ نْسنْ.  
\v 21 أَيْثْ ن إِسْرَائِيل، إِنِّي د-إِعقْبنْ زِي لْمنْفَا، شِّينْ زَّايسْ، ؤُڒَا ذ كُوڒْ إِجّنْ ونِّي ثُوغَا إِسَّارْخُونْ إِخفْ نّسْ زِي ڒخْمجْ ن ڒڭْنُوسْ ن ثمُّورْثْ \add ؤُشَا\add* \add يُوسَا-د\add* غَارْسنْ حِيمَا أَذْ يَارْزُو سِيذِي، أَربِّي ن إِسْرَائِيل.  
\v 22 سبْعَا ن وُوسَّانْعيّْذنْ نِيثْنِي ڒْعِيذْ ن وغْرُومْ بْڒَا أَنْثُونْ، مِينْزِي سِيذِي ثُوغَا إِسّفْرَاحْ إِ-ثنْ ؤُشَا إِسّْميّڒْ ؤُڒْ ن ؤُجدْجِيذْ ن أَشُّورْ غَارْسنْ مَاحنْذْ أَذْ إِسّجْهذْ إِفَاسّنْ نْسنْ غَارْ ڒْخذْمثْ ن ثَادَّارْثْ ن أَربِّي، أَربِّي ن إِسْرَائِيل.   
\b  
\b  
\m  
\c 7
\s1 ڒُومُورْ ن ؤُجدْجِيذْ أَرْثَاحْشَاسْثَا إِ عِيزْرَا  
\m
\v 1 أَوَارْنِي مَانْ أَيَا، ڒَامِي ثُوغَا ذ ثَاڭلْذَا ن أَرْثَاحْشَاسْثَا، أَجدْجِيذْ ن لْفُورْسْ، أَقَا \add ذِينْ\add* عِيزْرَا، مِّيسْ ن سَارَايَا، مِّيسْ ن عَازَارْيَا، مِّيسْ ن حِيلْقِييَا،  
\v 2 مِّيسْ ن شَالُّومْ، مِّيسْ ن صَاذُوقْ، مِّيسْ ن أَخِيطُوبْ،  
\v 3 مِّيسْ ن أَمَارْيَا، مِّيسْ ن عَازَارْيَا، مِّيسْ ن مَارَايُوثْ،  
\v 4 مِّيسْ ن زَارَاحْ-يَاهْ، مِّيسْ ن عُوزِي، مِّيسْ ن بُوقِّي،  
\v 5 مِّيسْ ن أَبِيشُوعَا، مِّيسْ ن فِينْحَاسْ، مِّيسْ ن أَلِيعَازَارْ، مِّيسْ ن هَارُونْ، أَرَّايْسْ ن إِكهَّاننْ.   
\m
\v 6 عِيزْرَا وَانِيثَا إِڭعّذْ-د زِي بَابِيلْ. نتَّا ثُوغَا ذ إِجّْ ن ؤُمْسڒْمَاذْ ذ أَمِيغِيسْ ن شَّارِيعَا ن مُوسَا ثنِّي ثُوغَا إِ ذ إِوْشَا سِيذِي، أَربِّي ن إِسْرَائِيل، ؤُشَا أَجدْجِيذْ إِوْشَا أَسْ مَارَّا خْ ثُوثْرَا نّسْ مِينْزِي أَفُوسْ ن سِيذِي، أَربِّي نّسْ، ثُوغَا-ث خَاسْ.  
\v 7 ذڭْ ؤُسڭّْوَاسْ وِيسّْ سبْعَا ن ؤُجدْجِيذْ أَرْثَاحْشَاسْثَا ڭعّْذنْ أَكِيذسْ غَارْ ؤُرْشَالِيمْ \add إِجّْ ن ڒْقدّْ\add* ن أَيْثْ ن إِسْرَائِيل ذ إِكهَّاننْ ذ إِلَاوِييّنْ ذ إِمذْيَازنْ ذ إِعسَّاسنْ ن ثوُّورَا ذ إِمْسخَّارنْ ن زَّاوشْثْ ثَامقّْرَانْثْ. \f ◼ \fr 7:‏7 \ft \+bd ’إِمذْيَازنْ‘\+bd* - نِيغْ ’إِمغْنُوجنْ‘.\f*  
\v 8 ذڭْ ؤُيُورْ وِيسّْ خمْسَا ن ؤُسڭّْوَاسْ وِيسّْ سبْعَا ن ؤُجدْجِيذْ يِيوضْ عِيزْرَا غَارْ ؤُرْشَالِيمْ.  
\v 9 ذڭْ \add وَاسّْ\add* أَمزْوَارُو ن ؤُيُورْ أَمزْوَارُو \add ثُوغَا-ث ذ\add* بدُّو ن وُوفُّوغْ زِي بَابِيلْ ؤُشَا ذڭْ ؤُمزْوَارُو ن ؤُيُورْ وِيسّْ خمْسَا يِيوضْ غَارْ ؤُرْشَالِيمْ، مِينْزِي ثُوغَا أَفُوسْ إِصبْحنْ ن أَربِّي خَاسْ،  
\v 10 مَاغَارْ عِيزْرَا إِڭَّا ذڭْ وُوڒْ نّسْ أَذْ يَارْزُو ذِي شَّارِيعَا ن سِيذِي ؤُ أَذْ ت إِڭّْ ؤُ أَذْ إِسّڒْمذْ ثِيوصَّا ذ لْفَارَايِيضْ ذِي إِسْرَائِيل.   
\m
\v 11 ثَا ذ ثِيڒمْثْ ن ثبْرَاثْ إِ إِوْشَا ؤُجدْجِيذْ أَرْثَاحْشَاسْثَا أَكْ-ذ عِيزْرَا، أَكهَّانْ ذ ؤُمْسڒْمَاذْ ن ثِيرَا \add إِقدّْسنْ\add*، \add ونِّي ذ\add* أَمْسڒْمَاذْ ذڭْ وَاوَاڒنْ ن ڒُومُورَاثْ ن سِيذِي ذ ثْوصَّا نّسْ إِ إِسْرَائِيل:   
\b  
\m
\v 12 ”أَرْثَاحْشَاسْثَا، أَجدْجِيذْ ن إِجدْجِيذنْ، إِ عِيزْرَا، أَكهَّانْ ذ ؤُمْسڒْمَاذْ ن شَّارِيعَا ن أَربِّي ن إِجنْوَانْ، ڒهْنَا إِمُونْ! ... ؤُشَا عَاذْ.“   
\b  
\m
\v 13 ”إِتّْوَاسُّوفّغْ-د زَّايِي ڒُومُورْ حِيمَا كُوڒْ إِجّْ ذِي ثْڭلْذِيثْ إِنُو زِي ڒْڭنْسْ ن إِسْرَائِيل ؤُ زڭْ إِكهَّاننْ ذ إِلَاوِييّنْ، ونِّي س يِيخفْ نّسْ إِخْسْ أَذْ يُويُورْ غَارْ ؤُرْشَالِيمْ، أَذْ كِيذكْ يُويُورْ.  
\v 14 أَقَا شكْ ثتّْوَاسّكّذْ س ؤُفُوسْ ن ؤُجدْجِيذْ ذ سبْعَا ن إِمْشَاوَارنْ نّسْ حِيمَا أَذْ ثْبقّْشذْ ذِي مَامّشْ ثدْجَا ڒْحَاڒْ ذِي يَاهُوذَا ؤُ ذِي ؤُرْشَالِيمْ، عْلَاحْسَابْ شَّارِيعَا ن أَربِّي ثنِّي \add إِدْجَانْ\add* ذڭْ إِفَاسّنْ نّشْ.  
\v 15 \add ثتّْوَاسكّذْ عَاوذْ\add* حِيمَا أَذْ ذِينْ ثَاوْيذْ نُّوقَارْثْ ذ وُورغْ نِّي ثُوغَا إِوْشَا ؤُجدْجِيذْ ذ إِمْشَاوَارنْ نّسْ س ڒْخَاضَارْ إِ أَربِّي ن إِسْرَائِيل، ونِّي غَارْ ثدْجَا ثْزذِّيغْثْ ذِي ؤُرْشَالِيمْ، \x ◘ \xo 7:‏15 \xt عِز. 8‏:‏25\x*  
\v 16 ؤُ \add عَاوذْ\add* مَارَّا نُّوقَارْثْ ذ وُورغْ إِ غَا ثَافذْ ذِي مَارَّا لْعَامَالَا ن بَابِيلْ، أَكْ-ذ ثوْهِيبِينْ ن ؤُطوّعْ ن ڒْڭنْسْ ذ إِكهَّاننْ، \add زڭْ\add* إِنِّي إِ غَا إِوْشنْ س ؤُطوّعْ إِ ثَادَّارْثْ ن أَربِّي نْسنْ ثنِّي \add إِدْجَانْ\add* ذِي ؤُرْشَالِيمْ،  
\v 17 حِيمَا خنِّي أَذْ ثسْغذْ س نُّوقَارْثْ-أَ س شْضَارثْ إِفُونَاسنْ، إِشَارِّييّنْ، إِزْمَارنْ أَكْ-ذ ثوْهِيبِينْ نّسْ \add ن ڒْغِيدْجثْ\add* ذ ثوْهِيبِينْ ن ؤُسيّبْ حِيمَا أَذْ ثنْثْ ثْقدّْمذْ خْ ؤُعَالْطَارْ ن ثَادَّارْثْ ن أَربِّي نّشْ، ثنِّي \add إِدْجَانْ\add* ذِي ؤُرْشَالِيمْ.  
\v 18 س مِينْ غَا إِقِّيمنْ ن نُّوقَارْثْ ذ وُورغْ ڭّمْ زَّايسْ مِينْ ثتّْوَاڒِيذْ شكْ ذ أَيْثْمَاشْ مْلِيحْ، عْلَاحْسَابْ ڒْخَاضَارْ ن أَربِّي نْومْ.  
\v 19 ؤُشَا ڒقْشُوعْ إِ ذ أَشْ إِمّوْشنْ إِ ثْسخَّارْثْ ذِي ثَادَّارْثْ ن أَربِّي، سعْذُو ثنْ \add غَارْ ذِينْ\add* زَّاثْ أَربِّي ن ؤُرْشَالِيمْ.  
\v 20 مِينْ غَا إِخصّنْ عَاذْ كْثَارْ إِ ثَادَّارْثْ ن أَربِّي نّشْ، مِينْ غَا يِيڒِي خَاكْ أَذْ ث ثْخدْجْصذْ، أوْشْ إِ-ث زڭْ وخَّامْ ن ثْخُوبَايْ ن ؤُجدْجِيذْ.  
\v 21 نشّْ، أَجدْجِيذْ أَرْثَاحْشَاسْثَا، سُّوفّغْ-د ڒُومُورْ إِ مَارَّا إِمحْضَاينْ خْ ثْخُوبَايْ \add ذِي ثمُّورْثْ\add* خْ ؤُجمَّاضْ ن إِغْزَارْ \add ن لْفُورَاطْ\add*، مَاحنْذْ أَذْ إِمّوْشْ س شْضَارثْ مَارَّا مِينْ زَّايْومْ غَا إِتَّارْ ؤُكهَّانْ عِيزْرَا، أَمْسڒْمَاذْ ن شَّارِيعَا ن أَربِّي ن إِجنْوَانْ،  
\v 22 أَڒْ مْيَا ثَالِينْثْ ن نُّوقَارْثْ، أَڒْ مْيَا إِكُورُوثنْ ن إِرْذنْ، أَڒْ مْيَا إِبَاثُوثنْ ن بِينُو ؤُ أَڒْ مْيَا إِبَاثُوثنْ ن زّشْثْ، ؤُشَا \add إِ\add* ثْمدْجَاحْثْ \add وَارْ ذِينْ\add* بُو ثوْصيّثْ.  
\v 23 مَارَّا مِينْ \add إِدْجَانْ\add* زِي ڒُومُورْ ن أَربِّي ن إِجنْوَانْ، أَذْ إِتّْوَاڭّْ س شْضَارثْ إِ ثَادَّارْثْ ن أَربِّي ن إِجنْوَانْ، مِينْزِي مَايمِّي إِ د غَا يَاسْ وغْضَابْ خْ ثْڭلْذِيثْ ن ؤُجدْجِيذْ ذ إِحنْجِيرنْ نّسْ؟  
\v 24 زِي جِّيهثْ ن مَارَّا إِكهَّاننْ ذ إِلَاوِييّنْ، ذ إِمغْنُوجنْ ذ إِعسَّاسنْ ن ثوُّورَا ذ إِمْسخَّارنْ ن زَّاوشْثْ ثَامقّْرَانْثْ ذ إِمْسخَّارنْ ن ثَادَّارْثْ ن أَربِّي وَانِيثَا، أَقَا أَذْ كنِّيوْ نْخبَّارْ، وَارْ إِزمَّارْ أَذْ خَاسنْ إِتّْوَاڭّْ ڒعْشُورْ، ڒَا ذ لْجِيزْيَا ؤُڒَا ذ ضَّارِيبَا ن وبْرِيذْ.  
\v 25 مَاشَا شكْ، عِيزْرَا، س ثِيغِيثْ إِ ذ أَشْ إِمّوْشنْ زِي أَربِّي نّشْ، ڒقّمْ إِمْضبَّارنْ ذ ڒْقُوضَاثْ نِّي إِ غَا إِحكْمنْ خْ مَارَّا ڒْڭنْسْ نِّي إِدْجَانْ \add ذِي ثمُّورْثْ\add* خْ ؤُجمَّاضْ ن إِغْزَارْ \add ن لْفُورَاطْ\add*، إِ مَارَّا إِنِّي إِسّْننْ إِزرْفَانْ ن أَربِّي. ؤُشَا إِ يِينِّي وَارْ ثنْ إِسِّيننْ، إِتّْخصَّا أَذْ ثنْ د-ثسَّارْڭْبذْ. \f ◼ \fr 7:‏25 \ft \+bd ’ڒقّمْ‘\+bd* - نِيغْ ’سمَّا‘. \+bd ’إِمْزُورْفَا‘\+bd* - نِيغْ ’ڒْقُوضَاثْ‘.\f*  
\v 26 كُوڒْ إِجّنْ ونِّي وَارْ إِضْفَارنْ شَّارِيعَا ن أَربِّي نْومْ ذ ؤُزرْفْ ن ؤُجدْجِيذْ، إِتّْخصَّا أَذْ إِتّْوَاحْكمْ س شْضَارثْ، مَا س ڒْموْثْ نِيغْ س لْمنْفَا نِيغْ س مُولْثَا ن وَاڭْڒَا نِيغْ س ڒحْبسْ.“   
\b  
\m
\v 27 أَسمْغَارْ إِ سِيذِي، أَربِّي ن ڒجْذُوذْ نّغْ، ونِّي إِڭِّينْ أَيَا أَمُّو ذڭْ وُوڒْ ن ؤُجدْجِيذْ حِيمَا أَذْ يَارْنِي أَشنّعْ ذِي ثَادَّارْثْ ن سِيذِي نِّي \add إِدْجَانْ\add* ذِي ؤُرْشَالِيمْ.  
\v 28 أَقَا نتَّا إِسّْشنْ أَيِي ثَامخْسِيوْثْ نّسْ إِشوَّارنْ زَّاثْ إِ وُوذمْ ن ؤُجدْجِيذْ ذ إِمْشَاوَارنْ نّسْ ذ مَارَّا ڒْحُوكَّامْ إِجهْذنْ ن ؤُجدْجِيذْ! ؤُشَا ؤُمِي خَافِي ثُوغَا أَفُوسْ ن سِيذِي، أَربِّي إِنُو، ڭِّيغْ ؤُڒْ ؤُ سّْمُونغْ إِزدْجِيفنْ ن إِسْرَائِيل حِيمَا أَذْ كِيذِي ڭعّْذنْ.   
\b  
\b  
\m  
\c 8
\s1 لِيسْثَا ن يِينِّي د-إِذوْڒنْ أَكْ-ذ عِيزْرَا  
\m
\v 1 إِنَا ذ إِزدْجِيفنْ خْ إِبَابَاثنْ \add ن ڒَادْجَاثْ\add*، أَكْ-ذ لِيسْثَا ن جَّاذِيرَا نْسنْ، إِنِّي أَكِيذِي د إِڭعّْذنْ زِي بَابِيلْ ؤُمِي ثُوغَا ثدْجَا ثْڭلْذَا ن ؤُجدْجِيذْ أَرْثَاحْشَاسْثَا.   
\b  
\m
\v 2 زڭْ أَيْثْ ن فِينْحَاسْ: جَارْشُومْ،  
\m زڭْ أَيْثْ ن إِثَامَارْ: ذَانِييَالْ،  
\m زڭْ أَيْثْ ن ذَاوُوذْ: حَاطُّوشْ.   
\m
\v 3 زڭْ أَيْثْ ن شَاكَانْيَا، زڭْ أَيْثْ ن فَارُوشْ: زَاكَارِييَّا ؤُ أَكِيذسْ تّْوَازمّمنْ مْيَا ؤُ-خمْسِينْ ن يرْيَازنْ أَكْ-ذ جَّاذِيرَا نْسنْ.   
\m
\v 4 زڭْ أَيْثْ ن فَاحَاثْ-مُوآبَ: إِلْيُوعِينَايْ، مِّيسْ ن زَارَاحْ-يَاهْ، ؤُ أَكِيذسْ مِيثَاينْ ن يرْيَازنْ.   
\m
\v 5 زڭْ أَيْثْ ن شَاكَانْيَا، مِّيسْ ن يَاحْزِييِيلْ، ؤُ أَكِيذسْ ثڒْثْ-مْيَا ن يرْيَازنْ.   
\m
\v 6 زڭْ أَيْثْ ن عَاذِينْ: عَابِيذْ، مِّيسْ ن يُونَاثَانْ، ؤُ أَكِيذسْ خمْسِينْ ن يرْيَازنْ.   
\m
\v 7 زڭْ أَيْثْ ن عِيلَامْ: إِشَاعْيَا، مِّيسْ ن عَاثَالْيَا، ؤُ أَكِيذسْ سبْعِينْ ن يرْيَازنْ.   
\m
\v 8 زڭْ أَيْثْ ن شَافَاطْيَا: زَابَاذْيَا، مِّيسْ ن مِيخَايِيلْ، ؤُ أَكِيذسْ ثْمنْيِينْ ن يرْيَازنْ.   
\m
\v 9 زڭْ أَيْثْ ن يُووَابْ: عُوبَاذْيَا، مِّيسْ ن يَاحِييِيلْ، ؤُ أَكِيذسْ مِيثَاينْ ؤُ-ثْمنْثَاشْ ن يرْيَازنْ.   
\m
\v 10 زڭْ أَيْثْ ن بَانِي: شَالُومِيثْ، مِّيسْ ن يُوشَافْيَا، ؤُ أَكِيذسْ مْيَا ؤُ-ستِّينْ ن يرْيَازنْ.   
\m
\v 11 زڭْ أَيْثْ ن بَابَايْ: زَاكَارِييَّا، مِّيسْ ن بَابَايْ، ؤُ أَكِيذسْ ثْمنْيَا ؤُ-عِيشْرِينْ ن يرْيَازنْ.   
\m
\v 12 زڭْ أَيْثْ ن عَاجَاذْ: يُوحَانَانْ، مِّيسْ ن هَاقَّاطَانْ، ؤُ أَكِيذسْ مْيَا ؤُ -عشْرَا ن يرْيَازنْ.   
\m
\v 13 زڭْ أَيْثْ ن أَذُونِيقَامْ، إِنڭُّورَا، ذ إِنَا ذ إِسْمَاونْ \add نْسنْ\add*: إِلِيفَالَاطْ، يَاعِييِيلْ ذ شَامْعِييَا ؤُ أَكِيذْسنْ ستِّينْ ن يرْيَازنْ.   
\m
\v 14 زڭْ أَيْثْ ن بِيغْوَايْ: عُوثَايْ ذ زَابُّوذْ ؤُ أَكِيذسْ سبْعِينْ ن يرْيَازنْ.   
\b  
\m  
\s1 أَسَافَارْ ذ ثْوَاسِيثْ غَارْ ؤُرْشَالِيمْ  
\m
\v 15 نشّْ سّْمُونغْ ثنْ غَارْ إِغْزَارْ نِّي إِتّكّنْ خْ أَهَاوَا. ذِينِّي نوْثَا إِقِيضَانْ نّغْ ثْڒَاثَا ن وُوسَّانْ ؤُ نشّْ حكَّارغْ إِ ڒْڭنْسْ ذ إِكهَّاننْ ؤُ وَارْ ؤُفِيغْ ؤُڒَا ذ إِجّنْ زڭْ إِلَاوِييّنْ.  
\v 16 \add خنِّي\add* سّكّغْ غَارْ أَلِيعَازَارْ، أَرِييِيلْ، شَامْعِييَا، إِلْ-نَاثَانْ، يَارِيبْ، أَلْنَاثَانْ، نَاثَانْ، زَاكَارِييَّا ؤُ غَارْ مَاشُولَّامْ، \add إِنِّي ذ\add* إِزدْجِيفنْ، ؤُ غَارْ يُويَارِيبْ ذ إِلْ-نَاثَانْ، \add إِرْيَازنْ\add* غَارْسنْ ڒفْهَامثْ.  
\v 17 ؤُمُورغْ ثنْ خْ عِيدُّو، أَزدْجِيفْ ذڭْ ومْشَانْ \add ؤُمِي قَّارنْ\add* كَاسِيفْيَا، ؤُشَا ڭِّيغْ أَسنْ أَوَاڒنْ ذڭْ ؤُقمُّومْ نْسنْ، حِيمَا أَذْ ثنْ إِنِينْ إِ عِيدُّو، إِ ؤُتْشْمَاسْ ؤُ إِ إِمْسخَّارنْ ن زَّاوشْثْ ثَامقّْرَانْثْ ذڭْ ومْشَانْ \add ؤُمِي قَّارنْ\add* كَاسِيفْيَا، مَاحنْذْ أَذْ أَنغْ د-أَوْينْ إِمْسخَّارنْ إِ ثَادَّارْثْ ن أَربِّي نّغْ.  
\v 18 ؤُمِي ثُوغَا خَانغْ أَفُوسْ إِصبْحنْ ن أَربِّي، سّكّنْ أَنغْ-د إِجّْ ن ورْيَازْ س ڒفْهَامثْ، إِجّنْ زڭْ إِحنْجِيرنْ ن مَاحْلِي، مِّيسْ ن لَاوِي، مِّيسْ ن إِسْرَائِيل، ؤُ \add وَانِيثَا\add* ذ شَارَابْيَا، أَكْ-ذ إِحنْجِيرنْ نّسْ ذ أَيْثْمَاسْ، \add مَارَّا إِذْسنْ\add* ثْمنْطَاشْ \add ن يرْيَازنْ\add*،  
\v 19 ؤُ \add عَاوذْ\add* حَاشَابْيَا ؤُ أَكِيذسْ إِشَاعْيَا زڭْ أَيْثْ ن مَارَارِي، أَكْ-ذ أَيْثْمَاسْ ذ إِحنْجِيرنْ نْسنْ، عِيشْرِينْ \add ن يرْيَازنْ\add*.  
\v 20 ؤُ زڭْ إِمْسخَّارنْ ن زَّاوشْثْ ثَامقّْرَانْثْ نِّي إِوْشِينْ ذَاوُوذْ ذ ڒْحُوكَّامْ إِ إِلَاوِييّنْ مَاحنْذْ أَذْ أَسنْ سخَّارنْ، أَقَا أَثنْ مِيثَاينْ ؤُ-عِيشْرِينْ ن إِمْسخَّارنْ ن زَّاوشْثْ ثَامقّْرَانْثْ إِنِّي مَارَّا تّْوَاڒَاغَانْ س إِسْمَاونْ نْسنْ.   
\m
\v 21 \add خنِّي\add* ڒَاغِيغْ ذِينِّي غَارْ إِغْزَارْ ن أَهَاوَا س يِيجّْ ن ؤُژُومِّي، مَاحنْذْ أَذْ نسَّاضَارْ إِخفْ نّغْ زَّاثْ إِ وُوذمْ ن أَربِّي نّغْ، مَاحنْذْ أَذْ زَّايسْ نتَّارْ ثِيشْڒِي ذ ثَامِيمُونْثْ إِ نشِّينْ ؤُ إِ ثَارْوَا نّغْ إِمژْيَاننْ ؤُ إِ وَاڭْڒَا نّغْ،  
\v 22 مَاغَارْ تّْسذْحِيغْ أَذْ تَّارغْ إِجّْ ن ڒْعسْكَارْ زِي غَارْ ؤُجدْجِيذْ مَاحنْذْ أَذْ أَنغْ ثْعَاونْ ذڭْ وبْرِيذْ ضِيدّْ إِ ڒعْذُو، مِينْزِي ثُوغَا نسَّاوَاڒْ ذڭْ ؤُجدْجِيذْ، ننَّا: ”أَفُوسْ ن أَربِّي أَقَا-ث ذ أَصبْحَانْ خْ مَارَّا إِنِّي ث يَارزُّونْ، مَاشَا جّهْذْ نّسْ ذ وغْضَابْ نّسْ \add أَذْ د-أَسنْ\add* خْ مَارَّا إِنِّي إِ خَاسْ إِتَّاڭّْوجنْ.“  
\v 23 إِوَا نشِّينْ نْژُومّْ ؤُ نتَّارْ أَيَا زِي أَربِّي نّغْ ؤُ نتَّا إِسْثَاجبْ أَنغْ إِ ثْژَادْجِيثْ يُودْجْغنْ نّغْ.   
\m
\v 24 \add خنِّي\add* فَارْزغْ ثنْعَاشْ \add ن يرْيَازنْ\add* زڭْ إِمقّْرَاننْ ن إِكهَّاننْ: شَارَابْيَا ذ حَاشَابْيَا ؤُ أَكِيذْسنْعشْرَا ن أَيْثْمَاثْسنْ.  
\v 25 وزْنغْ زَّاثْسنْ نُّوقَارْثْ ذ وُورغْ ذ ڒقْشُوعْ، أَقَا أَيَا ذ ثَاوْهِيبْثْ ن ؤُسْڭعّذْ إِ ثَادَّارْثْ ن أَربِّي نّغْ، ثنِّي إِسّْڭعّذْ ؤُجدْجِيذْ أَكْ-ذ إِمْشَاوَارنْ نّسْ ذ ڒْحُوكَّامْ نّسْ ذ مَارَّا إِنِّي \add ذِينْ\add* إِتّْوَافنْ زِي إِسْرَائِيل. \x ◘ \xo 8:‏25 \xt عِز. 7‏:‏14، 15\x*  
\v 26 وزْنغْ ؤُ ڭِّيغْ أَسنْ ذڭْ إِفَاسّنْ نْسنْ ستَّا-مْيَا ؤُ-خمْسِينْ ثَالِينْثْ ن نُّوقَارْثْ ؤُ مْيَا ن ڒقْشُوعْ ن نُّوقَارْثْ \add إِوزْننْ\add* مْيَا ثَالِينْثْ ؤُ مْيَا ثَالِينْثْ ن وُورغْ  
\v 27 ؤُ عِيشْرِينْ ن إِفنْجَاڒنْ ن وُورغْ سكّْوَانْ أَڒفْ ذْرَاخْمَاثْ ؤُڒَا ذ ثْنَاينْ ن ڒقْشُوعْ ن نّْحَاسْ، إِشلّلْ، إِشْنَا، إِغْڒَا أَمْ وُورغْ.  
\v 28 نِّيغْ أَسنْ: ”كنِّيوْ ذ إِمْقدَّاسنْ زَّاثْ إِ سِيذِي ؤُ ڒقْشُوعْ-أَ أَقَا قدّْسنْ \add إِ دْجَانْ\add*، ؤُڒَا ذ نُّوقَارْثْ-أَ ذ وُورغْ-أَ، أَقَا أَيَا ذ ثَاوْهِيبْثْ س ڒْخَاضَارْ إِ سِيذِي، أَربِّي ن ڒجْذُوذْ نْومْ.  
\v 29 عسّمْ ؤُ حْضَامْ أَيَا أَڒْ ث غَا ثْوزْنمْ زَّاثْ إِ وُوذمْ ن إِمقّْرَاننْ ن إِكهَّاننْ ذ إِلَاوِييّنْ ذ إِمقّْرَاننْ ن \add ڒَْادْجَاثْ ن\add* إِبَابَاثنْ ن إِسْرَائِيل ذِي ؤُرْشَالِيمْ، ذڭْ إِخَّامنْ ن ثَادَّارْثْ ن سِيذِي.“  
\v 30 \add خنِّي\add* طّْفنْ إِكهَّاننْ ذ إِلَاوِييّنْ ڒوْزنْ ن نُّوقَارْثْ ذ وُورغْ ذ ڒقْشُوعْ حِيمَا أَذْ أَوْينْ \add أَيَا مَارَّا\add* غَارْ ؤُرْشَالِيمْ غَارْ ثَادَّارْثْ ن أَربِّي نّغْ.   
\m
\v 31 ذڭْ وَاسّْ وِيسّْ ثنْعَاشْ ن ؤُيُورْ أَمزْوَارُو نكّسْ إِقِيضَانْ نّغْ مَاحنْذْ أَذْ نُويُورْ غَارْ ؤُرْشَالِيمْ. ثُوغَا أَفُوسْ ن أَربِّي خَانغْ ؤُشَا إِفكّْ أَنغْ زڭْ ؤُفُوسْ ن ڒعْذُو ؤُ \add زڭْ ؤُفُوسْ\add* ن يِينِّي \add إِ ذ أَنغْ\add* إِڭِّينْ ڒْفخْ ذڭْ وبْرِيذْ.  
\v 32 ؤُشَا نِيوضْ غَارْ ؤُرْشَالِيمْ ؤُ نقِّيمْ ذِينِّي ثْڒَاثَا ن وُوسَّانْ.  
\v 33 ذڭْ وَاسّْ وِيسّْ أَربْعَا إِتّْوَاوْزنْ نُّوقَارْثْ ذ وُورغْ ذ ڒقْشُوعْ ذِي ثَادَّارْثْ ن أَربِّي نّغْ ؤُشَا نوْشَا أَيَا إِ ؤُكهَّانْ مَارِيمُوثْ، مِّيسْ ن ؤُرِييَا، ؤُشَا أَلِيعَازَارْ، مِّيسْ ن فِينْحَاسْ، \add ثُوغَا-ث\add* أَكِيذسْ ؤُڒَا ذ يُوزَابَاذْ، مِّيسْ ن يشُوعَا، ذ نُوعَاذْيَا، مِّيسْ ن بَانُّويْ، نِيثْنِي س ثْنَاينْ ذ إِلَاوِييّنْ.  
\v 34 \add ذ مَانْ أَيَا إِمْسَارْ\add* عْلَاحْسَابْ ڒْقدّْ ذ ڒوْزنْ ن مَارَّا أَيَا ؤُ مَارَّا ڒوْزنْ إِتّْوَاوْزنْ ذِي ڒْوقْثْ نِّي ذ إِجّنْ.  
\v 35 أَيْثْ ن لْمنْفَا إِنِّي د-إِعقْبنْ زِي ثْمحْبَاسْثْ، سّْڭعّْذنْ إِ أَربِّي ن إِسْرَائِيل ثِيغَارْصَا ن وشْمَاضْ: ثنْعَاشْ ن إِفُونَاسنْ إِمژْيَاننْ إِ مَارَّا إِسْرَائِيل، ستَّا ؤُ-ثسْعِينْ ن إِشَارِّييّنْ ؤُ سبْعَا ؤُ-سبْعِينْ ن إِزْمَارنْ، ؤُ إِ ثْغَارْصْثْ ن دّنْبْ ثنْعَاشْ ن إِمُويَانْ، مَارَّا أَيَا ذ ثَاغَارْصْثْ ن وشْمَاضْ إِ سِيذِي.  
\v 36 نِيثْنِي وْشِينْ ثِيوصَّا ن ؤُجدْجِيذْ إِ إِجدْجِيذنْ \add إِ إِدْجَانْ\add* سَاذُو ؤُجدْجِيذْ ؤُ إِ لْوُولَاثْ \add ذِي ثمُّورْثْ\add* خْ ؤُجمَّاضْ ن إِغْزَارْ \add ن لْفُورَاطْ\add* ؤُ نِيثْنِي وْشِينْ أَفُوسْ إِ ڒْڭنْسْ ؤُ \add إِ ثْسخَّارْثْ ذِي\add* ثَادَّارْثْ ن أَربِّي.   
\b  
\b  
\m  
\c 9
\s1 ثْژَادْجِيثْ ذ نْذَامثْ ن عِيزْرَا  
\m
\v 1 أَوَارْنِي ڒَامِي إِتّْوَاكمّڒْ مَانْ أَيَا \add مَارَّا\add*، ؤُسِينْ-د غَارِي ڒْحُوكَّامْ، نَّانْ: ”ڒْڭنْسْ ن إِسْرَائِيل ذ إِكهَّاننْ ذ إِلَاوِييّنْ وَارْ قِّيمنْ تّْوَامْسبْضَانْ خْ ڒڭْنُوسْ ن ثمُّورَا-يَا، \add مَاغَارْ\add* جّْعَايفْ نْسنْ أَمْ ثِينِّي ن أَيْثْ ن كنْعَانْ ذ إِحِيتِّييّنْ ذ إِفِيرِيزِييّنْ ذ إِيابُوسِييّنْ ذ أَيْثْ ن عَامُّونْ ذ أَيْثْ ن مُوآبَ ذ إِمِيصْرِييّنْ ذ إِمُورِييّنْ.  
\v 2 نِيثْنِي إِوْينْ زڭْ يسِّيثْسنْ \add ثِيمْغَارِينْ\add* إِ يِيخفْ نْسنْ ؤُ إِ إِحنْجِيرنْ نْسنْ أَڒَامِي صُورنْ زَّارِيعثْ ذ ثَامْقدَّاسْثْ س ڒڭْنُوسْ ن ثمُّورَا-يَا، وَاهْ، أَفُوسْ ن ڒْحُوكَّامْ ذ إِمْضبَّارنْ ثُوغَا-ث ذ أَمزْوَارُو ذِي ڒغْذَارْ-أَ.“   
\m
\v 3 ؤُمِي سْڒِيغْ أَيَا، شَارّْڭغْ أَرُّوضْ إِنُو ذ ؤُسڒْهَامْ إِنُو، قڒْعغْ-د أَشُوَّافْ ن ؤُزدْجِيفْ ؤُ ن ثْمَارْثْ ؤُشَا قِّيمغْ جعَّارغْ.  
\v 4 \add خنِّي\add* مُوننْ-د خَافِي مَارَّا، إِنِّي إِتَّارْجِيجنْ زِي أَربِّي ن إِسْرَائِيل، ذِي سِّيبّثْ ن ڒغْذَارْ ن أَيْثْ ن لْمنْفَا، مَاشَا نشّْ قِّيمغْ جعَّارغْ أَڒْ \add ڒْْوقْثْ ن\add* ثوْهِيبْثْ ن ثْمذِّيثْ. \x ◘ \xo 9:‏4 \xt ڒخْڒ. 28‏:‏1‏-‏8\x*  
\v 5 غَارْ ثوْهِيبْثْ ن ثْمذِّيثْ كَّارغْ زڭْ ؤُسْوَاضعْ إِنُو س وَارُّوضْ إِنُو ذ ؤُسڒْهَامْ إِنُو \add إِشَارّْڭنْ\add* ؤُشَا ؤُضَارغْ خْ إِفَادّنْ ؤُ سّْوِيژّْضغْ إِفَاسّنْ إِنُو غَارْ سِيذِي، أَربِّي إِنُو. \x ◘ \xo 9:‏5 \xt ڒخْڒ. 28‏:‏1‏-‏8\x*   
\m
\v 6 نِّيغْ: ”أَربِّي إِنُو، نشّْ سذْحِيغْ ؤُ تّْوَاسّْبهْذْڒغْ أَڒْ وَارْ زْعِيمغْ أَذْ غَاركْ د-سّْڭعّْذغْ ؤُذمْ إِنُو، أَ أَربِّي إِنُو، مِينْزِي ڒْمُوعْصِييّثْ نّغْ ثمْغَارْ أَنغْ خْ ؤُزدْجِيفْ ؤُ أَمَارْوَاسْ نّغْ إِمْغَارْ أَڒْ أَجنَّا. \x ◘ \xo 9:‏6 \xt إِزهد. 38‏:‏5\x*  
\v 7 زڭْ وُوسَّانْ ن ڒجْذُوذْ نّغْ أَڒْ أَسّْ-أَ \add أَقَا أَنغْ\add* ذڭْ ؤُمَارْوَاسْ ذ أَمقّْرَانْ ؤُ خْ ڒْمُوعْصِييّثْ نّغْ نمّوْشْ نشِّينْ ذ إِجدْجِيذنْ نّغْ ذ إِكهَّاننْ نّغْ ذڭْ إِفَاسّنْ ن إِجدْجِيذنْ ن ثمُّورَا، \add أَقَا نمّوْشْ\add* إِ سِّيفْ، إِ ثْمحْبَاسْثْ، إِ ؤُكشّضْ ؤُ إِ ڒفْضِيحثْ خْ وُوذْمَاونْ نّغْ، أَمْ مَامّشْ \add إِ ثدْجَا\add* أَسّْ-أَ.  
\v 8 ڒخُّو ثُوغَا ذِينْ إِشْثْ ن ثْزحْزِيحْثْ ذ ثَامژْيَانْثْ ن أَرْضَا ن سِيذِي، أَربِّي نّغْ، حِيمَا أَذْ أَنغْ يجّْ شَا ن يِينِّي إِنّجْمنْ ؤُ حِيمَا أَذْ أَنغْ إِوْشْ إِجّْ ن ڒوْثذْ ذِي زَّاوشْثْ ثَامقّْرَانْثْ نّسْ إِقدّْسنْ ؤُ ثْفَاوْثْ إِ ثِيطَّاوِينْ نّغْ، \add أَ\add* أَربِّي نّغْ، ؤُ حِيمَا أَذْ أَنغْ د-يَارّْ نّفْسْ شْوَايْثْ ذِي ثسْمُوغِي نّغْ.  
\v 9 أَقَا نشِّينْ ذ إِسمْغَانْ، مَاشَا ذِي ثسْمُوغِي نّغْ وَارْ ذَايْنغْ إِسْمِيحْ أَربِّي نّغْ، مَاشَا نتَّا إِذْڒَا أَنغْ س ثْمخْسِيوْثْ نّسْ إِشوَّارنْ زَّاثْ إِ وُوذمْ ن إِجدْجِيذنْ ن لْفُورْسْ مَاحنْذْ أَذْ أَنغْ د-يَارّْ نّفْسْ إِ ؤُسْبذِّي ن ثَادَّارْثْ ن أَربِّي \add ثْوَاڒَاثْ نّغْنِي\add*، إِ وعْذَاڒْ ن ڒْخِيرْبَاثْ ؤُ حِيمَا أَذْ أَنغْ إِوْشْ إِجّْ ن ومْشَانْ إِتّْوَانّْضنْ س ڒْحِيضْ ذِي يَاهُوذَا ؤُ ذِي ؤُرْشَالِيمْ.“   
\m
\v 10 ”ؤُشَا ڒخُّو، مِينْ غَا نِينِي أَوَارْنِي ؤُيَا عَاذْ، \add أَ\add* أَربِّي نّغْ، مِينْزِي نسْمحْ ذِي ڒُومُورَاثْ نّشْ،  
\v 11 ثِينِّي ثُومُورذْ س ثْسخَّارْثْ ن إِمْسخَّارنْ نّشْ، إِنَابِييّنْ، إِنِّي إِنَّانْ: ’ثَامُّورْثْ ثنِّي إِ غَا ثَاذْفمْ مَاحنْذْ أَذْ ت ثطّْفمْ ذ ڒْوَارْثْ، ذ إِشْثْ ن ثمُّورْثْ ثتّْوَاسّخْمجْ س ڒخْمجْ ن ڒڭْنُوسْ ن ثمُّورَا، س جّْعَايفْ نْسنْ إِ زِي ت شُّورنْ زِي طَّارْفْ أَڒْ طَّارْفْ نّغْنِي س ثخْمُوجِي نْسنْ‘، \x ◘ \xo 9:‏11 \xt لَاوِي 18‏:‏25، 27؛ أَعَوذ. 7‏:‏3\x*   
\m
\v 12 \add ذ إِنِّي إِقَّارنْ ؤُڒَا عَاذْ\add* ڒخُّو: ’وَارْ تِّيشمْ ثِيحنْجِيرِينْ نْومْ ذ ثِيمْغَارِينْ إِ إِحنْجِيرنْ نْسنْ، ؤُڒَا ذ ثِيحنْجِيرِينْ نْسنْ وَارْ ثنْثْ تِّيوْيمْ إِ إِحنْجِيرنْ نْومْ ؤُشَا وَارْ أَرزُّومْ خْ ڒَامَانْ نْسنْ نِيغْ ڒْخَارْ نْسنْ إِ ڒبْذَا، حِيمَا أَذْ ثْذوْڒمْ ثْجهْذمْ ؤُ أَذْ ثشّمْ مُومُّو \add ن ڒْغِيدْجثْ\add* ن ثمُّورْثْ ؤُ أَذْ ت ثوْشمْ ذ ڒْوَارْثْ إِ ڒبْذَا إِ إِحنْجِيرنْ نْومْ.‘ “\x ◘ \xo 9:‏12 \xt أَعَوذ. 7‏:‏3؛ 11‏:‏8؛ 23‏:‏7\x*   
\m
\v 13 ”ؤُشَا أَوَارْنِي مَارَّا مِينْ إِ ذ أَنغْ إِمْسَارنْ ذِي سِّيبّثْ ن ثْمڭَّا نّغْ ثِيعفَّانِينْ ذ ؤُمَارْوَاسْ نّغْ أَمقّْرَانْ، \add أَ\add* أَربِّي نّغْ، أَقَا شكْ وَارْ ذ أَنغْ ثْخدْجْصذْ شَا مْغِيرْ ذْرُوسْ وَاهَا أَڒَامِي وَارْ نتّْوَاهلّكْ شَا س ڒْمُوعْصِييّثْ نّغْ ؤُ ثوْشِيذْ أَنغْ \add عَاذْ\add* إِنَا إِنِّي إِنّجْمنْ أَمْ ت ثدْجَا \add ڒخُّو\add*.  
\v 14 مَا نْزمَّارْ ڒخُّو أَذْ نَارْژْ ثْوَاڒَا نّغْنِيثْ ثِيوصَّا نّشْ ؤُ أَذْ نڭّْ أَذْ نذْوڒْ ذ إِضڭّْوَاڒنْ أَكْ-ذ ڒڭْنُوسْ نِّي \add إِڭِّينْ\add* جّْعَايفْ-أَ؟ مَا \add خنِّي\add* شكْ وَارْ خَانغْ ثْسعَّارذْ أَڒَامِي خَانغْ إِ غَا ثقْضِيذْ أَڒْ مَانِي وَارْ إِتّْغِيمِي إِجّْ ن ڒْبَاقِي ؤُڒَا ذ ونِّي إِنّجْمنْ؟  
\v 15 \add أَ\add* سِيذِي، أَربِّي ن إِسْرَائِيل، شكْ ذ أَمْسڭّذْ، مِينْزِي نشِّينْ ذ إِنِّي إِقِّيمنْ نّجْمنْ أَمْ \add ثدْجَا\add* أَسّْ-أَ. أَقَا نشِّينْ س ؤُمَارْوَاسْ \add إِ ندْجَا\add* زَّاثْ إِ وُوذمْ نّشْ، مِينْزِي ؤُڒَا ذ إِجّنْ وَارْ إِزمَّارْ أَذْ إِبدّْ زَّاثْ إِ وُوذمْ نّشْ ذِي سِّيبّثْ-أَ.“   
\b  
\b  
\m  
\c 10
\s1 ڒْڭنْسْ إِڭّْوجْ خْ ثمْغَارِينْ إِغْرِيبنْ  
\m
\v 1 ؤُمِي إِژُّودْجْ عِيزْرَا أَمُّو، إِنْعمْ، إِرُو ؤُشَا إِوْضَا \add خْ إِفَادّنْ\add* زَّاثْ إِ ثَادَّارْثْ ن أَربِّي، أَقَا إِسّْمُونْ-د خَاسْ ڒْغَاشِي ذ أَمقّْرَانْ أَطَّاسْ ن يرْيَازنْ ذ ثمْغَارِينْ ذ إِحنْجِيرنْ ن إِسْرَائِيل، مِينْزِي ڒْڭنْسْ إِرُو س إِمطَّاونْ إِمقّْرَاننْ.  
\v 2 \add خنِّي\add* شَاكَانْيَا، مِّيسْ ن يَاحِييِيلْ، إِجّنْ زڭْ أَيْثْ ن عِيلَامْ، إِطّفْ ذڭْ وَاوَاڒْ، إِنَّا إِ عِيزْرَا:  
\b  
\m ”نشِّينْ أَقَا نغْذَارْ أَربِّي نّغْ ؤُشَا نشِّينْ نِيوِي ثِيمْغَارِينْ ثِيبَارَّانِييِّينْ زِي ڒڭْنُوسْ ن ثمُّورْثْ، نسّزْذغْ إِ-ثنْثْ أَكِيذْنغْ. خنِّي ڒخُّو، أَقَا ذِينْ \add عَاذْ\add* ڒَايَاسْ إِ إِسْرَائِيل ذِي مَانْ أَيَا.  
\v 3 أجّْ أَنغْ أَذْ نڭّْ إِجّْ ن ڒْعَاهْذْ أَكْ-ذ أَربِّي حِيمَا أَذْ نَاژّڒْ خْ مَارَّا ثِيمْغَارِينْ ذ مِينْ زَّايْسنْثْ د-إِخڒْقنْ، عْلَاحْسَابْ أَشَاوَارْ ن سِيذِي إِنُو ؤُ ن يِينِّي إِتَّارْجِيجنْ إِ ڒُومُورْ ن أَربِّي، ؤُشَا \add خنِّي\add* أَذْ إِتّْوَاڭّْ عْلَاحْسَابْ شَّارِيعَا. \f ◼ \fr 10:‏3 \ft \+bd ’سِيذِي‘\+bd* - س ثْعِيبْرَانِيثْ ’سِيذِي إِنُو‘.\f*  
\v 4 كَّارْ، مِينْزِي ثَامسْڒَاشْثْ\add -أَ\add* أَقَا-ت خْ \add وعْرُورْ\add* نّشْ ؤُ نشِّينْ أَكِيذكْ نْبدّْ. إِڒِي ذ أَرْيَازْ، أڭّْ \add إِ-ت\add*!“   
\b  
\m
\v 5 \add خنِّي\add* إِكَّارْ عِيزْرَا ؤُشَا إِجَّا إِمقّْرَاننْ ن إِكهَّاننْ ذ إِلَاوِييّنْ ذ مَارَّا إِسْرَائِيل أَذْ جَّادْجنْ أَذْ ڭّنْ عْلَاحْسَابْ أَوَاڒْ-أَ ؤُشَا نِيثْنِي جُّودْجنْ.  
\v 6 \add خنِّي\add* إِكَّارْ عِيزْرَا \add إِفّغْ\add* \add زِي\add* زَّاثْ إِ وُوذمْ ن ثَادَّارْثْ ن أَربِّي، يُوذفْ غَارْ وخَّامْ ن يُوحَانَانْ، مِّيسْ ن إِلْيَاسِيبْ. \add ؤُمِي\add* يُوذفْ \add ذِينِّي\add*، وَارْ إِشِّي أَغْرُومْ وَارْ إِسْوِي أَمَانْ، مَاغَارْ إِشْضنْ خْ ڒغْذَارْ ن أَيْثْ ن لْمنْفَا.  
\v 7 ؤُشَا ڭِّينْ إِجّْ ن ؤُبَارّحْ ذِي يَاهُوذَا ذ ؤُرْشَالِيمْ إِ مَارَّا أَيْثْ ن لْمنْفَا مَاحنْذْ أَذْ مُوننْ ذِي ؤُرْشَالِيمْ.  
\v 8 قَاعْ ونِّي وَارْ د-يُوسِينْ ذِي \add ڒْمِيجَارْ ن\add* ثْڒَاثَا ن وُوسَّانْ، أَمْ مَامّشْ \add إِدْجَا\add* ذڭْ ؤُشَاوَارْ ن ڒْحُوكَّامْ ذ إِوسُّورَا، مَارَّا أَڭْڒَا نّسْ أَذْ أَسْ إِتّْوَاحَارّمْ ؤُ نتَّا سِيمَانْثْ نّسْ أَذْ إِتّْوَامّْسبْضَا خْ وڭْرَاوْ \add ن ڒْڭنْسْ\add* ن أَيْثْ ن لْمنْفَا   
\m
\v 9 ذِي ثْڒَاثَا ن وُوسَّانْ نّْجَارْونْ مَارَّا إِرْيَازنْ ن يَاهُوذَا ذ بِينْيَامِينْ ذِي ؤُرْشَالِيمْ. ثُوغَا ذڭْ وَاسّْ وِيسّْ عِيشْرِينْ ن ؤُيُورْ وِيسّْ ثسْعَا. مَارَّا ڒْڭنْسْ إِقِّيمْ ذڭْ وَازَّايْ ن ثَادَّارْثْ ن أَربِّي، تَّارْجِيجنْ زِي ثْمسْڒَاشْثْ\add -أَ\add* ؤُڒَا زڭْ ونْژَارْ إِ د-إِوتَّانْ س وَاطَّاسْ.  
\v 10 إِكَّارْ ؤُكهَّانْ عِيزْرَا، إِنَّا أَسنْ: ”كنِّيوْ ثغْذَارمْ ؤُ ثِيوْيمْ ثِيمْغَارِينْ ثِيبَارَّانِييِّينْ \add زِي ڒڭْنُوسْ\add* ثسّْزذْغمْ ثنْثْ أَكِيذْومْ \add ؤُ أَمُّو إِ\add* ثڭِّيمْ ثَارْنِيمْ ذڭْ ؤُمَارْوَاسْ ن إِسْرَائِيل.  
\v 11 خنِّي ڒخُّو، قَاذَامْ سِيذِي، أَربِّي ن ڒجْذُوذْ نْومْ، ؤُ ڭّمْ مِينْ إِخْسْ نتَّا ؤُشَا مّْسبْضَامْ خْ ڒڭْنُوسْ ن ثمُّورْثْ ؤُڒَا خْ ثمْغَارِينْ ثِيبَارَّانِييِّينْ.“   
\m
\v 12 مَارَّا أَڭْرَاوْ \add ن ڒْڭنْسْ\add* يَارَّا-د خَاسْ س جّْهذْ: ”أَقَا-ث خْ \add وعْرُورْ\add* نّغْ مَاحنْذْ أَذْ نڭّْ عْلَاحْسَابْ أَوَاڒنْ نّشْ!  
\v 13 مَاشَا أَقَا \add ذِينْ\add* أَطَّاسْ ن إِوْذَانْ ؤُ أَقَا ذ ڒْوقْثْ ن ونْژَارْ. وَارْ غَارْسنْ بُو جّهْذْ مَاحنْذْ أَذْ \add قِّيمنْ\add* بدّنْ بَارَّا ؤُڒَا ذ مَانْ أَيَا وَارْ إِدْجِي ذ إِشْثْ ن ڒْخذْمثْ ن إِجّْ نِيغْ ثْنَاينْ ن وُوسَّانْ، مِينْزِي أَطَّاسْ زَّايْنغْعدَّانْ ذِي ثْمسْڒَاشْثْ-أَ.  
\v 14 أجّْ أَذْ بدّنْ ڒْحُوكَّامْ نّغْ ذِي طّْوعْ ن مَارَّا أَڭْرَاوْ \add ن ڒْڭنْسْ\add* ؤُشَا أَذْ د-أَسنْ ذڭْ وُوسَّانْ إِتّْوَاڭّنْ مَارَّا إِنِّي ذِي ثْندَّامْ يِيوْينْ غَارْسنْ ثِيمْغَارِينْ ثِيبَارَّانِييِّينْ، سّْزذْغنْ ثنْثْ ذِي ثُوذْرِينْ نْسنْ، ؤُشَا \add جْمِيعْ أَكِيذْسنْ\add* ؤُڒَا ذ إِوسُّورَا ن كُوڒْ ثَانْذِينْثْ ذ ڒْقُوضَاثْ نّسْ، أَڒْ خَانغْ غَا إِبعّذْ ڒْحَاذُوقْ ن وغْضَابْ ن أَربِّي نّغْ.“   
\m
\v 15 مْغِيرْ يُونَاثَانْ، مِّيسْ عَسَائِيلْ، ذ يَاحَازْيَا، مِّيسْ ن ثِيقْوَا، ثُوغَا تّْعكّْسنْ خْ مَانْ أَيَا ؤُ مَاشُولَّامْ ذ شَابَاثَايْ، أَلَاوِي، وْشِينْ أَسنْ أَفُوسْ.   
\m
\v 16 \add مَاشَا\add* إِرْيَازنْ نِّي إِعقْبنْ زِي لْمنْفَا ڭِّينْ \add ث\add* أَمُّو. \add خنِّي\add* إِتّْوَافَارْزْ ؤُكهَّانْ عِيزْرَا \add ذ\add* يرْيَازنْ \add إِنِّي\add* ذ إِزدْجِيفنْ خْ إِبَابَاثنْ ن ڒَادْجَاثْ ن إِبَابَاثنْ نْسنْ. نِيثْنِي مَارَّا تّْوَاڒَاغَانْ س يِيسمْ نْسنْ ؤُشَا قِّيمنْ ذڭْ وَاسّْ أَمزْوَارُو ن ؤُيُورْ وِيسّْعشْرَا، حِيمَا أَذْ أَرْزُونْ ذِي ثْمسْڒَاشْثْ\add -أَ\add*.  
\v 17 ذڭْ وَاسّْ أَمزْوَارُو ن ؤُيُورْ أَمزْوَارُو كمّْڒنْ نِيثْنِي \add ثَارزُّوثْ\add* ذِي مَارَّا إِرْيَازنْ نِّي إِڭِّينْ أَذْ سّْزذْغنْ أَكِيذْسنْ ثِيمْغَارِينْ ثِيبَارَّانِييِّينْ.  
\v 18 إِتّْوَافْ بلِّي إِنِّي زڭْ أَيْثْ ن إِكهَّاننْ إِنِّي إِسّْزذْغنْ غَارْ إِخفْ نْسنْ ثمْغَارِينْ ثِيبَارَّانِييِّينْ، أَقَا أَثنْ زڭْ أَيْثْ ن يَاهُوشَاعْ، مِّيسْ ن يُوصَاذَاقْ، ؤُ زڭْ أَيْثْمَاسْ، مَاعَاسِييَا ذ أَلِيعَازَارْ ذ يَارِيبْ ذ جَاذَالْيَا.  
\v 19 نِيثْنِي وْثِينْ خْ ؤُفُوسْ أَذْ سّكّنْ ثِيمْغَارِينْ نْسنْ، ؤُ ؤُمِي ذَايْسنْ أَمَارْوَاسْ، \add أَذْ أَوْينْ\add* إِجّنْ زڭْ وُودْجِي إِ ؤُمَارْوَاسْ نْسنْ.   
\b  
\m
\v 20 زڭْ إِحنْجِيرنْ ن إِمِّيرْ: حَانَانِي ذ زَابَاذْيَا.   
\m
\v 21 زڭْ إِحنْجِيرنْ ن حَارِيمْ: مَاعَاسِييَا، إِلِييَا، شَامْعِييَا، يَاحِييِيلْ ذ عُوزِّييَا.   
\m
\v 22 زڭْ إِحنْجِيرنْ ن فَاشْحُورْ: إِلْيُوعِينَايْ، مَاعَاسِييَا، إِسْمَاعِيلْ، نَاثَانَايِيلْ، يُوزَابَاذْ ذ أَلْعَاسَا.   
\m
\v 23 زِي إِلَاوِييّنْ: جُوزَابَاذْ، شِيمْعِي، قَالَايَا، \add وَا ذ قَالِيطَا\add*، ذ فَاثْحْيَا، يَاهُوذَا ذ أَلِيعَازَارْ.   
\m
\v 24 زڭْ إِمذْيَازنْ: أَلْيَاسِيبْ.  
\m زڭْ إِعسَّاسنْ ن ثوُّورَا: شَالُّومْ، طَالَامْ ذ ؤُرِي. \f ◼ \fr 10:‏24 \ft \+bd ’إِمذْيَازنْ‘\+bd* - نِيغْ ’إِمغْنُوجنْ‘.\f*   
\m
\v 25 زِي إِسْرَائِيل: زڭْ أَيْثْ ن فَارْعُوشْ: رَامْيَا، جِيزِييَا، مَالْكِييَا، مِييَامِينْ، أَلِيعَازَارْ، مَالْكِييَا ذ بَانَايَا.   
\m
\v 26 زڭْ أَيْثْ ن عِيلَامْ: مَاتَّانْيَا، زَاكَارِييَّا، يَاحِييِيلْ، عَابْذِي، يَارِيمُوثْ ذ إِلِييَا.   
\m
\v 27 زڭْ أَيْثْ ن زَاتُّو: إِلْيُوعِينَايْ، إِلْيَاشِيبْ، مَاتَّانْيَا، يَارِيمُوثْ، زَابَاذْ ذ عَازِيزَا.   
\m
\v 28 زڭْ أَيْثْ ن بَابَايْ: يُوحَانَانْ، حَانَانْيَا، زَابَّايْ ذ عَاثْلَايْ.   
\m
\v 29 زڭْ أَيْثْ ن بَانِي: مَاشُولَّامْ، مَالُّوخْ، عَاذَايَا، يَاشُوبْ، شَآلْ ذ يَارَامُوثْ.   
\m
\v 30 زڭْ أَيْثْ ن فَاحَاثْ-مُوآبَ: عَاذْنَا، كَالَالْ، بَانَايَا، مَاعَاسِييَا، مَاتَّانْيَا، بَاصَالِييِيلْ، بِينُّويْ ذ مَانَاسَّا.   
\m
\v 31 زڭْ أَيْثْ ن حَارِيمْ: أَلِيعَازَارْ، يَاشِّي-يَاهْ، مَالْكِييَا، شَامْعِييَا، شِيمْعُونْ،  
\v 32 بِينْيَامِينْ، مَالُّوخْ ذ شَامَارْيَا.   
\m
\v 33 زڭْ أَيْثْ ن حَاشُومْ: مَاتَّانَايْ، مَاتَّاتَّا، زَابَاذْ، إِلِيفَالَاطْ، يَارِيمَايْ، مَانَاسَّا، شِيمْعِي.   
\m
\v 34 زڭْ أَيْثْ ن بَانِي: مَاعَاذَايْ، عَامْرَامْ ذ ؤُوْيِيلْ،  
\v 35 بَانَايَا، بَاذْيَا، كَالُوهِي،  
\v 36 وَانْيَا، مَارِيمُوثْ، إِلْيَاشِيبْ،  
\v 37 مَاتَّانْيَا، مَاتّْنَايْ، يَاعْسُو،  
\v 38 بَانِي، بِينُّويْ، شِيمْعِي،  
\v 39 شَالْمَايَا، نَاثَانْ، عَاذَايَا،  
\v 40 مَاكْنَاذْبَايْ، شَاشَايْ، شَارَايْ،  
\v 41 عَازَارْيِيلْ، شَالَامْيَا، شَامَارْيَا،  
\v 42 شَالُّومْ، أَمَارْيَا، يُوسُوفْ.   
\m
\v 43 زڭْ أَيْثْ ن نابُو: يَاعِييِيلْ، مَاتِّيثْيَا، زَابَاذْ، زَابِينَا، يَادُّو، يُووِيلْ ذ بَانَايَا.   
\b  
\m
\v 44 مَارَّا إِنَا ثُوغَا إِوْينْ ثِيمْغَارِينْ ثِيبَارَّانِييِّينْ ؤُشَا شَا زَّايْسنْ ثُوغَا غَارْسنْ ثِيمْغَارِينْ ؤُرْونْثْ-إِ-د إِحنْجِيرنْ. *   