\q1 \w and|strong="H4437"\w* \w the|strong="H5922"\w* birds \w from|strong="H1768"\w* \w its|strong="H3046"\w* branches!
\q1 
\v 15 \w But|strong="H3606"\w* leave \w its|strong="H6591"\w* taproot \w in|strong="H4437"\w* \w the|strong="H3606"\w* ground,
\q1 \w with|strong="H6903"\w* \w a|strong="H3068"\w* band \w of|strong="H4437"\w* iron \w and|strong="H4430"\w* bronze around it
\q1 surrounded by \w the|strong="H3606"\w* grass \w of|strong="H4437"\w* \w the|strong="H3606"\w* field.
