\v 25 \w So|strong="H6965"\w* \w Moses|strong="H4872"\w*/\w I|strong="H6965"\w* \w stood|strong="H6965"\w* \w up|strong="H6965"\w* \w and|strong="H6965"\w* \w went|strong="H3212"\w* \w to|strong="H3478"\w* \w the|strong="H6965"\w* tents \w of|strong="H2205"\w* \w Dathan|strong="H1885"\w* \w and|strong="H6965"\w* Abiram. \w The|strong="H6965"\w* Israeli \w leaders|strong="H2205"\w* \w followed|strong="H3212"\w* \w him|strong="H4872"\w*/\w me|strong="H3212"\w*.
\v 26 \w He|strong="H3605"\w*/\w I|strong="H5921"\w* \w told|strong="H1696"\w* \w the|strong="H3605"\w* \w people|strong="H1696"\w*, “\w Get|strong="H5493"\w* \w away|strong="H5493"\w* \w from|strong="H5493"\w* \w the|strong="H3605"\w* tents \w of|strong="H5921"\w* \w these|strong="H1696"\w* \w wicked|strong="H7563"\w* \w men|strong="H7563"\w*, \w and|strong="H2403"\w* \w do|strong="H5493"\w* \w not|strong="H6435"\w* \w touch|strong="H5060"\w* \w anything|strong="H3605"\w* \w that|strong="H3605"\w* belongs \w to|strong="H1696"\w* \w them|strong="H5921"\w*! \w If|strong="H6435"\w* \w you|strong="H3605"\w* \w touch|strong="H5060"\w* \w anything|strong="H3605"\w*, \w you|strong="H3605"\w* \w will|strong="H7563"\w* \w die|strong="H5595"\w* \w because|strong="H5921"\w* \w of|strong="H5921"\w* \w their|strong="H3605"\w* \w sins|strong="H2403"\w*!”
\v 27 \w So|strong="H5927"\w* \w all|strong="H5439"\w* \w the|strong="H5921"\w* \w people|strong="H1121"\w* \w moved|strong="H3318"\w* \w away|strong="H5927"\w* \w from|strong="H3318"\w* \w the|strong="H5921"\w* \w tents|strong="H4908"\w* \w of|strong="H1121"\w* \w Korah|strong="H7141"\w*, \w Dathan|strong="H1885"\w*, \w and|strong="H1121"\w* Abiram. \w Dathan|strong="H1885"\w* \w and|strong="H1121"\w* Abiram \w came|strong="H3318"\w* \w out|strong="H3318"\w* \w of|strong="H1121"\w* \w their|strong="H5921"\w* \w tents|strong="H4908"\w* \w with|strong="H5921"\w* \w their|strong="H5921"\w* wives \w and|strong="H1121"\w* \w children|strong="H1121"\w* \w and|strong="H1121"\w* babies, \w and|strong="H1121"\w* \w stood|strong="H5324"\w* \w at|strong="H5921"\w* \w the|strong="H5921"\w* \w entrances|strong="H6607"\w* \w of|strong="H1121"\w* \w their|strong="H5921"\w* \w tents|strong="H4908"\w*.
\p 
\v 28 \w Then|strong="H7971"\w* \w Moses|strong="H4872"\w*/\w I|strong="H3588"\w* said, “\w I|strong="H3588"\w* \w was|strong="H3068"\w* \w not|strong="H3808"\w* \w the|strong="H3605"\w* \w one|strong="H3605"\w* \w who|strong="H3605"\w* decided \w to|strong="H3068"\w* \w do|strong="H6213"\w* \w all|strong="H3605"\w* \w these|strong="H2063"\w* \w things|strong="H3605"\w* \w that|strong="H3588"\w* \w I|strong="H3588"\w* \w have|strong="H3068"\w* \w done|strong="H6213"\w*. \w It|strong="H3588"\w* \w was|strong="H3068"\w* \w Yahweh|strong="H3068"\w* \w who|strong="H3605"\w* \add chose me and\add* \w sent|strong="H7971"\w* \w me|strong="H7971"\w* \w to|strong="H3068"\w* \w do|strong="H6213"\w* \w them|strong="H7971"\w*. \w And|strong="H4872"\w* \w now|strong="H3588"\w* \w he|strong="H3588"\w* \w will|strong="H3068"\w* \w prove|strong="H3045"\w* \w that|strong="H3588"\w* \w to|strong="H3068"\w* \w you|strong="H3588"\w*.
\v 29 If \w these|strong="H3605"\w* \w men|strong="H3605"\w* \w die|strong="H4191"\w* \w in|strong="H5921"\w* \w a|strong="H3068"\w* normal \w way|strong="H7971"\w*, \w then|strong="H7971"\w* \w it|strong="H5921"\w* \w will|strong="H3068"\w* \w be|strong="H4191"\w* \w clear|strong="H3605"\w* \w that|strong="H3605"\w* \w Yahweh|strong="H3068"\w* \w did|strong="H3068"\w* \w not|strong="H3808"\w* choose \w me|strong="H7971"\w*.
\v 30 \w But|strong="H3588"\w* \w if|strong="H3588"\w* \w Yahweh|strong="H3068"\w* \w does|strong="H3068"\w* \w something|strong="H3605"\w* \w that|strong="H3588"\w* \w has|strong="H3068"\w* \w never|strong="H3045"\w* happened \w before|strong="H3045"\w*, \w if|strong="H3588"\w* \w he|strong="H3588"\w* causes \w the|strong="H3605"\w* ground \add that is under their feet\add* \w to|strong="H3381"\w* \w open|strong="H6475"\w* \w up|strong="H1104"\w* \w and|strong="H3068"\w* \w swallow|strong="H1104"\w* \w these|strong="H3605"\w* \w men|strong="H3605"\w* \add and their families\add* \w and|strong="H3068"\w* \w all|strong="H3605"\w* \w their|strong="H3605"\w* possessions, \w and|strong="H3068"\w* \w they|strong="H3588"\w* \w fall|strong="H3381"\w* \w into|strong="H3381"\w* \w the|strong="H3605"\w* \w opening|strong="H6310"\w* \w and|strong="H3068"\w* \w are|strong="H3068"\w* buried \w while|strong="H3588"\w* \w they|strong="H3588"\w* \w are|strong="H3068"\w* \w still|strong="H3588"\w* \w alive|strong="H2416"\w*, \w then|strong="H3588"\w* \w you|strong="H3588"\w* \w will|strong="H3068"\w* \w know|strong="H3045"\w* \w that|strong="H3588"\w* \w these|strong="H3605"\w* \w men|strong="H3605"\w* \w have|strong="H3068"\w* insulted \w Yahweh|strong="H3068"\w*.”
\p 
\v 31 \w As|strong="H1697"\w* soon \w as|strong="H1697"\w* Moses/\w I|strong="H1697"\w* \w said|strong="H1696"\w* \w this|strong="H1696"\w*, \w the|strong="H3605"\w* ground \w split|strong="H1234"\w* \w open|strong="H1234"\w* \w beneath|strong="H8478"\w* \w those|strong="H3605"\w* \w men|strong="H3605"\w*.
\v 32 \w It|strong="H1004"\w* \w swallowed|strong="H1104"\w* \w them|strong="H6605"\w* \w and|strong="H1004"\w* \w their|strong="H3605"\w* \w families|strong="H1004"\w* \w and|strong="H1004"\w* \w all|strong="H3605"\w* \w those|strong="H3605"\w* \w who|strong="H3605"\w* \w were|strong="H1004"\w* standing \w there|strong="H3605"\w* \w with|strong="H1004"\w* \w Korah|strong="H7141"\w* \w and|strong="H1004"\w* \w all|strong="H3605"\w* \w of|strong="H1004"\w* \w their|strong="H3605"\w* \w possessions|strong="H7399"\w*.
\v 33 \w They|strong="H1992"\w* \w fell|strong="H3381"\w* \w into|strong="H3381"\w* \w the|strong="H3605"\w* opening \w in|strong="H5921"\w* \w the|strong="H3605"\w* ground \w while|strong="H5921"\w* \w they|strong="H1992"\w* \w were|strong="H1992"\w* still \w alive|strong="H2416"\w*, \w and|strong="H3381"\w* \w all|strong="H3605"\w* \w their|strong="H3605"\w* possessions \w fell|strong="H3381"\w* \w into|strong="H3381"\w* \w the|strong="H3605"\w* opening \w also|strong="H1992"\w*. \w They|strong="H1992"\w* disappeared, \w and|strong="H3381"\w* \w the|strong="H3605"\w* ground \w closed|strong="H3680"\w* back \w up|strong="H5921"\w* again.
\v 34 \w They|strong="H3588"\w* screamed \w as|strong="H3588"\w* \w they|strong="H3588"\w* fell, \w and|strong="H3478"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* people \w who|strong="H3605"\w* \w were|strong="H3478"\w* standing nearby \w heard|strong="H6963"\w* \w them|strong="H5439"\w* scream. \w The|strong="H3605"\w* people \add were terrified and\add* \w cried|strong="H3478"\w* \w out|strong="H3605"\w* \w as|strong="H3588"\w* \w they|strong="H3588"\w* \w ran|strong="H5127"\w* \w away|strong="H5127"\w*, \w saying|strong="H6963"\w*, “\add We do not want\add* \w the|strong="H3605"\w* ground \w to|strong="H3478"\w* \w swallow|strong="H1104"\w* \w us|strong="H3588"\w* \w also|strong="H3478"\w*!”
\p 
\v 35 \w And|strong="H3967"\w* \w then|strong="H3318"\w* \w a|strong="H3068"\w* fire \w from|strong="H3318"\w* \w Yahweh|strong="H3068"\w* \w came|strong="H3318"\w* down \add from the sky\add* \w and|strong="H3967"\w* burned \w up|strong="H3318"\w* \w the|strong="H3068"\w* 250 men \w who|strong="H3068"\w* \w were|strong="H3318"\w* burning \w the|strong="H3068"\w* \w incense|strong="H7004"\w*!
\p 
\v 36 Then \w Yahweh|strong="H3068"\w* said to Moses/me,
\v 37 “Tell Aaron’s son Eleazar to take the pans that had incense in them away from the fire and to scatter the burning coals. The pans that those men \add were carrying\add* are ◄holy/dedicated to me► \add because they burned incense to me in them\add*.
\v 38 Those men have now died because of their sin; so \add Eleazar must\add* take their pans and hammer the metal to make it become very thin. He must make \w a|strong="H3068"\w* covering for the altar with that metal. Those pans were used to offer incense to me, so they are ◄holy/dedicated to me►. \add What happened to\add* those pans will now warn the Israeli people.”
\p 
\v 39 So Eleazar the priest collected the 250 pans for burning incense that had been used by the men who died in the fire. He hammered the pans very thin to make \w a|strong="H3068"\w* covering for the altar, as \w Yahweh|strong="H3068"\w* told Moses/me should be done.
\v 40 That warned the Israeli people that only those who were descendants of Aaron were permitted to burn incense for an offering to \w Yahweh|strong="H3068"\w*. If anyone else did that, the same thing that happened to Korah and those who were with him would happen to them.
\p 
\v 41 But the following morning, all the Israeli people started to complain against Aaron and Moses/me, saying “You have killed many people who belonged to \w Yahweh|strong="H3068"\w*!”
\p 
\v 42 When all the people gathered together to protest about what Aaron and Moses/I had done, they looked at the Sacred Tent and saw that the sacred cloud had covered it, and the glory of \w Yahweh|strong="H3068"\w* had appeared.
\v 43 Aaron and Moses/I went and stood in front of the Sacred Tent.
\v 44 Then \w Yahweh|strong="H3068"\w* said to Moses/me,
\v 45 “Get away from these people, in order that I can get rid of them immediately \add without injuring you two\add*!” But Aaron and Moses/I prostrated themselves/ourselves on the ground \add and prayed\add*.
\p 
\v 46 Moses/I said to Aaron, “Quickly take another pan and put in it some burning/hot coals from the altar. Put incense in the pan, and carry it out among the people to atone for the sins of the people. \w Yahweh|strong="H3068"\w* is very angry with them, and \add I know that\add* \w a|strong="H3068"\w* ◄severe plague/bad sickness► has already started among them.”
\v 47 So Aaron did what Moses/I told him. He took the burning incense out among the people. The plague had already started to strike the people, but Aaron continued to burn the incense so that God would forgive them for the sins they had committed.
\v 48 He stood between the people who had already died and those who were still alive, and then the plague stopped.
\v 49 But 14,700 people had already died from that plague/sickness, in addition to the people who died with Korah.
\v 50 Then after the plague had ended, Aaron and Moses/I returned to the entrance of the Sacred Tent.
\c 17
\s1 Aaron’s walking stick budded
\p 
\v 1 \w Then|strong="H1696"\w* \w Yahweh|strong="H3068"\w* \w said|strong="H1696"\w* \w to|strong="H1696"\w* \w Moses|strong="H4872"\w*/\w me|strong="H1696"\w*,
\v 2 “Tell \w the|strong="H3588"\w* Israeli \w people|strong="H1121"\w* \w to|strong="H1121"\w* bring \w to|strong="H1121"\w* \w you|strong="H3588"\w* twelve walking sticks. \w They|strong="H3588"\w* \w should|strong="H3548"\w* bring \w one|strong="H1121"\w* \w from|strong="H1121"\w* each \w of|strong="H1121"\w* \w the|strong="H3588"\w* leaders \w of|strong="H1121"\w* \w the|strong="H3588"\w* twelve tribes. \w You|strong="H3588"\w* \w should|strong="H3548"\w* carve each leader’s name \w on|strong="H1973"\w* \w his|strong="H3588"\w* stick.
\v 3 \w There|strong="H1961"\w* \w must|strong="H1121"\w* \w be|strong="H1961"\w* \w one|strong="H1121"\w* stick \w for|strong="H3588"\w* \w the|strong="H6440"\w* leader \w of|strong="H1121"\w* each tribe, \w so|strong="H6213"\w* \w you|strong="H3588"\w* \w must|strong="H1121"\w* carve Aaron’s name \w on|strong="H3068"\w* \w the|strong="H6440"\w* stick \w for|strong="H3588"\w* \w the|strong="H6440"\w* tribe \w of|strong="H1121"\w* Levi.
\v 4 \w Put|strong="H3947"\w* \w those|strong="H7126"\w* sticks inside \w the|strong="H3947"\w* Sacred Tent, \w in|strong="H4196"\w* front \w of|strong="H4196"\w* \w the|strong="H3947"\w* sacred chest \w that|strong="H3548"\w* \w has|strong="H3548"\w* \w in|strong="H4196"\w* \w it|strong="H7126"\w* \w the|strong="H3947"\w* tablets \w on|strong="H4196"\w* \w which|strong="H3548"\w* \w the|strong="H3947"\w* Ten Commandments \w are|strong="H3548"\w* written. \w That|strong="H3548"\w* \w is|strong="H3548"\w* \w the|strong="H3947"\w* place where \w I|strong="H7126"\w* always talk \w with|strong="H8313"\w* \w you|strong="H3947"\w*.
\v 5 Buds \w will|strong="H3068"\w* sprout \w on|strong="H3027"\w* \w the|strong="H6440"\w* stick \w of|strong="H1121"\w* \w the|strong="H6440"\w* \w man|strong="H1121"\w* \w whom|strong="H6440"\w* \w I|strong="H3808"\w* \w have|strong="H1961"\w* chosen \add to be the priest\add*. \add When the people see that\add*, \w they|strong="H3068"\w* \w will|strong="H3068"\w* \w stop|strong="H3808"\w* \w their|strong="H3068"\w* constantly complaining \w about|strong="H1961"\w* \w you|strong="H6440"\w* \add because they will realize that you are the one whom I have chosen\add*.”
\p 
\v 6 \w So|strong="H4191"\w* \w Moses|strong="H4872"\w*/\w I|strong="H5921"\w* told \w the|strong="H3605"\w* \w people|strong="H5971"\w* \w what|strong="H5921"\w* \w Yahweh|strong="H3068"\w* \w had|strong="H3068"\w* said. \w Then|strong="H4872"\w* \w each|strong="H3605"\w* \w of|strong="H1121"\w* \w the|strong="H3605"\w* twelve Israeli leaders, \w including|strong="H3605"\w* Aaron, \w brought|strong="H3478"\w* \w his|strong="H3605"\w* walking stick \w to|strong="H3478"\w* \w Moses|strong="H4872"\w*/\w me|strong="H5921"\w*.
\v 7 \w Moses|strong="H4872"\w*/\w I|strong="H2009"\w* \w placed|strong="H1961"\w* \w the|strong="H5921"\w* sticks \w inside|strong="H3068"\w* \w the|strong="H5921"\w* Sacred Tent \w in|strong="H5921"\w* front \w of|strong="H3068"\w* \w the|strong="H5921"\w* sacred chest.
\p 
\v 8 \w The|strong="H6440"\w* following morning, \w when|strong="H4872"\w* \w he|strong="H6440"\w*/\w I|strong="H6440"\w* \w went|strong="H4872"\w* into \w the|strong="H6440"\w* tent, \w he|strong="H6440"\w*/\w I|strong="H6440"\w* saw \w that|strong="H4872"\w* Aaron’s stick, \w which|strong="H4150"\w* represented \w the|strong="H6440"\w* tribe \w of|strong="H6440"\w* Levi, \w had|strong="H4872"\w* sprouted, \w it|strong="H6440"\w* \w had|strong="H4872"\w* produced leaves \w and|strong="H4872"\w* blossoms, \w and|strong="H4872"\w* \w it|strong="H6440"\w* \w had|strong="H4872"\w* \w also|strong="H4872"\w* produced almonds \w that|strong="H4872"\w* \w were|strong="H4872"\w* ripe!
\v 9 \w Moses|strong="H4872"\w*/\w I|strong="H3068"\w* \w brought|strong="H4872"\w* \w all|strong="H3068"\w* \w the|strong="H3068"\w* sticks \w out|strong="H1696"\w* \w of|strong="H3068"\w* \w the|strong="H3068"\w* Sacred Tent \w and|strong="H4872"\w* showed \w them|strong="H3068"\w* \w to|strong="H1696"\w* \w the|strong="H3068"\w* \w people|strong="H1696"\w*. Each \w of|strong="H3068"\w* \w the|strong="H3068"\w* twelve leaders took back \w his|strong="H3068"\w* own stick.
\p 
\v 10 \w Then|strong="H5307"\w* \w Yahweh|strong="H3068"\w* said \w to|strong="H5921"\w* Moses/\w me|strong="H6440"\w*, “\w Put|strong="H3615"\w* Aaron’s stick \w in|strong="H5921"\w* \w front|strong="H6440"\w* \w of|strong="H6440"\w* \w the|strong="H6440"\w* sacred chest, \w and|strong="H6440"\w* let \w it|strong="H5921"\w* stay \w there|strong="H8432"\w* permanently. \w That|strong="H5307"\w* \w will|strong="H5307"\w* \w be|strong="H6440"\w* \w a|strong="H3068"\w* warning \w to|strong="H5921"\w* \w people|strong="H5712"\w* who want \w to|strong="H5921"\w* rebel \add against me\add*. \w Then|strong="H5307"\w* \w no|strong="H6440"\w* \w more|strong="H5921"\w* \w people|strong="H5712"\w* \w will|strong="H5307"\w* \w die|strong="H5307"\w* \add because of complaining against me\add*.”
\v 11 \w So|strong="H3947"\w* \w Moses|strong="H4872"\w*/\w I|strong="H3588"\w* \w did|strong="H3068"\w* \w what|strong="H5921"\w* \w Yahweh|strong="H3068"\w* \w had|strong="H3068"\w* commanded.
\p 
\v 12 \w Then|strong="H1696"\w* \w the|strong="H5921"\w* Israeli \w people|strong="H5971"\w* \w said|strong="H1696"\w* \w to|strong="H1696"\w* \w Moses|strong="H4872"\w*/\w me|strong="H5414"\w*, “\w We|strong="H2009"\w* \w are|strong="H5971"\w* going \w to|strong="H1696"\w* die! \w All|strong="H5414"\w* \w of|strong="H8432"\w* \w us|strong="H5414"\w* \w are|strong="H5971"\w* \w surely|strong="H5414"\w* going \w to|strong="H1696"\w* die!
\v 13 Everyone \w who|strong="H5975"\w* comes \w close|strong="H6113"\w* \w to|strong="H4191"\w* \w Yahweh|strong="H3068"\w*’s Sacred Tent \w dies|strong="H4191"\w*. \w Are|strong="H5975"\w* \w the|strong="H5975"\w* rest \w of|strong="H4191"\w* us going \w to|strong="H4191"\w* \w die|strong="H4191"\w*, \w also|strong="H4191"\w*?” [RHQ]
\c 18
\s1 The duties of the priests and Levites
\p 
