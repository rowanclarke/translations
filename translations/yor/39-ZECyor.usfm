\id ZEC - Biblica® Open Yoruba Contemporary Bible 2017
\h Sekariah
\toc1 Ìwé Wòlíì Sekariah
\toc2 Sekariah
\toc3 Sk
\mt1 Ìwé Wòlíì Sekariah
\c 1
\s1 Ìpè láti padà sí ọ̀dọ̀ Ọlọ́run
\p 
\v 1 Ní oṣù kẹjọ ọdún kejì ọba Dariusi, ọ̀rọ̀ \nd Olúwa\nd* tọ wòlíì Sekariah ọmọ Berekiah, ọmọ Iddo pé:
\p 
\v 2 “\nd Olúwa\nd* ti bínú sí àwọn baba ńlá yín.
\v 3 Nítorí náà sọ fún àwọn ènìyàn. Èyí ni ohun tí \nd Olúwa\nd* àwọn ọmọ-ogun wí: ‘Ẹ padà sí ọ̀dọ̀ mi,’ báyìí ní \nd Olúwa\nd* àwọn ọmọ-ogun wí, ‘èmi náà yóò sì padà sí ọ̀dọ̀ yín,’ ni \nd Olúwa\nd* àwọn ọmọ-ogun wí.
\v 4 Ẹ má dàbí àwọn baba yín, àwọn tí àwọn wòlíì ìṣáájú ti ké sí wí pé, báyìí ní \nd Olúwa\nd* àwọn ọmọ-ogun wí, ‘Ẹ yípadà nísinsin yìí kúrò ní ọ̀nà búburú yín,’ àti kúrò nínú ìwà búburú yín; ṣùgbọ́n wọn kò gbọ́, bẹ́ẹ̀ ni wọn kò fetí sí ti èmi, ni \nd Olúwa\nd* wí.
\v 5 Àwọn baba yín, níbo ni wọ́n wà? Àti àwọn wòlíì, wọ́n ha wà títí ayé?
\v 6 Ṣùgbọ́n ọ̀rọ̀ mi àti ìlànà mi, ti mo pa ní àṣẹ fún àwọn ìránṣẹ́ mi wòlíì, kò ha tún bá àwọn baba yín?
\p “Wọ́n sì padà wọ́n wí pé, ‘Gẹ́gẹ́ bí \nd Olúwa\nd* àwọn ọmọ-ogun ti rò láti ṣe sí wa, gẹ́gẹ́ bi ọ̀nà wa, àti gẹ́gẹ́ bí ìṣe wa, bẹ́ẹ̀ ní o ti ṣe sí wa.’ ”
\s1 Ènìyàn láàrín àwọn igi miritili
\p 
\v 7 Ní ọjọ́ kẹrìnlélógún oṣù kọkànlá, tí ó jẹ́, oṣù Sebati, ní ọdún kejì Dariusi, ni ọ̀rọ̀ \nd Olúwa\nd* tọ wòlíì Sekariah, ọmọ Berekiah ọmọ Iddo wá, pé.
\p 
\v 8 Mo rí ìran kan ni òru, si wò ó, ọkùnrin kan ń gun ẹṣin pupa kan, òun sì dúró láàrín àwọn igi maritili tí ó wà ní ibi òòji; lẹ́yìn rẹ̀ sì ni ẹṣin pupa, adíkálà, àti funfun gbé wà.
\p 
\v 9 Nígbà náà ni mo wí pé, “Kí ni wọ̀nyí olúwa mi?”
\p Angẹli tí ń ba mi sọ̀rọ̀ sì wí fún mi pé, “Èmi ó fi ohun tí àwọn wọ̀nyí jẹ́ hàn ọ́.”
\p 
\v 10 Ọkùnrin tí ó dúró láàrín àwọn igi maritili sì dáhùn ó sì wí pé, “Wọ̀nyí ní àwọn tí \nd Olúwa\nd* ti rán láti máa rìn sókè sódò ni ayé.”
\p 
\v 11 Wọ́n si dá angẹli \nd Olúwa\nd* tí ó dúró láàrín àwọn igi maritili náà lóhùn pé, “Àwa ti rìn sókè sódò já ayé, àwa sí ti rí i pé gbogbo ayé wà ní ìsinmi àti àlàáfíà.”
\p 
\v 12 Nígbà náà ni angẹli \nd Olúwa\nd* náà dáhùn ó sì wí pé, “\nd Olúwa\nd* àwọn ọmọ-ogun, yóò ti pẹ́ tó tí ìwọ kì yóò fi ṣàánú fún Jerusalẹmu, àti fún àwọn ìlú ńlá Juda, ti ìwọ ti bínú sí ni àádọ́rin ọdún wọ̀nyí?”
\v 13 \nd Olúwa\nd* sì fi ọ̀rọ̀ rere àti ọ̀rọ̀ ìtùnú dá angẹli tí ń bá mi sọ̀rọ̀ lóhùn.
\p 
\v 14 Angẹli ti ń bá mi sọ̀rọ̀ sì wí fún mi pé, “Ìwọ kígbe wí pé, báyìí ni \nd Olúwa\nd* àwọn ọmọ-ogun wí, ‘Èmi ń fi ìjowú ńlá jowú fún Jerusalẹmu àti fún Sioni.
\v 15 Èmi sì bínú púpọ̀púpọ̀ si àwọn orílẹ̀-èdè tí ó rò wí pé òun ní ààbò. Nítorí nígbà tí mo bínú díẹ̀, wọ́n ran ìparun lọ́wọ́ láti tẹ̀síwájú.’
\p 
\v 16 “Nítorí náà, báyìí ni \nd Olúwa\nd* wí: ‘Mo padà tọ Jerusalẹmu wá pẹ̀lú àánú; ni \nd Olúwa\nd* àwọn ọmọ-ogun wí, a ó kọ́ ilé mi sínú rẹ̀, a o sí ta okùn ìwọ̀n kan jáde sórí Jerusalẹmu.’
\p 
\v 17 “Máa ké síbẹ̀ pé, báyìí ni \nd Olúwa\nd* àwọn ọmọ-ogun wí, ‘A o máa fi ìre kún ìlú ńlá mi síbẹ̀; \nd Olúwa\nd* yóò sì máa tu Sioni nínú síbẹ̀, yóò sì yan Jerusalẹmu síbẹ̀.’ ”
\s1 Ìwo mẹ́rin àti alágbẹ̀dẹ mẹ́rin
\p 
\v 18 Mo si gbé ojú sókè, mo sì rí, sì kíyèsi i, ìwo mẹ́rin.
\v 19 Mo sì sọ fún angẹli tí ó ń bá mi sọ̀rọ̀ pé, “Kí ni nǹkan wọ̀nyí?”
\p Ó si dà mí lóhùn pé, “Àwọn ìwo wọ̀nyí ni ó tí tú Juda, Israẹli, àti Jerusalẹmu ká.”
\p 
\v 20 \nd Olúwa\nd* sì fi alágbẹ̀dẹ mẹ́rin kan hàn mí.
\v 21 Nígbà náà ni mo wí pé, “Kí ni àwọn wọ̀nyí wá ṣe?”
\p O sì sọ wí pé, “Àwọn wọ̀nyí ni ìwo tí ó ti tú Juda ká, tó bẹ́ẹ̀ tí ẹnikẹ́ni kò fi gbé orí rẹ̀ sókè? Ṣùgbọ́n àwọn wọ̀nyí wá láti dẹ́rùbà wọ́n, láti lé ìwo àwọn orílẹ̀-èdè jáde, ti wọ́n gbé ìwo wọn sórí ilẹ̀ Juda láti tú ènìyàn rẹ̀ ká.”
\c 2
\s1 Okùn ìwọ̀n ti Jerusalẹmu
\p 
\v 1 Mó si tún gbé ojú mi, sókè, mo sì wò, sì kíyèsi i, ọkùnrin kan ti o mú okùn ìwọ̀n lọ́wọ́ rẹ̀.
\v 2 Mo sí wí pé, “Níbo ni ìwọ ń lọ?”
\p O sí wí fún mí pé, “Láti wọn Jerusalẹmu, láti rí iye ìbú rẹ̀, àti iye gígùn rẹ̀.”
\p 
\v 3 Sì kíyèsi i, angẹli tí ó ń bá mi sọ̀rọ̀ jáde lọ, angẹli mìíràn si jáde lọ pàdé rẹ̀.
\v 4 Ó si wí fún un pé, “Sáré, sọ fún ọ̀dọ́mọkùnrin yìí wí pé, ‘A ó gbé inú Jerusalẹmu bi ìlú ti kò ní odi, nítorí ọ̀pọ̀ ènìyàn àti ohun ọ̀sìn inú rẹ̀.
\v 5 \nd Olúwa\nd* wí pé: Èmi ó sì jẹ́ odi iná fún un yíká, èmi ó sì jẹ́ ògo láàrín rẹ̀.’
\p 
\v 6 “Wá! Wá! Sá kúrò ni ilẹ̀ àríwá,” ni \nd Olúwa\nd* wí, “nítorí pé bí afẹ́fẹ́ mẹ́rin ọ̀run ni mo tú yín káàkiri,” ni \nd Olúwa\nd* wí.
\p 
\v 7 “Gbà ara rẹ̀ sílẹ̀, ìwọ Sioni, ìwọ tí ó ń bà ọmọbìnrin Babeli gbé.”
\v 8 Nítorí báyìí ni \nd Olúwa\nd* àwọn ọmọ-ogun wí: “Lẹ́yìn ògo rẹ̀ ni a ti rán mi sí àwọn orílẹ̀-èdè tí ń kó yin: nítorí ẹni tí ó tọ́ yin, ó tọ́ ọmọ ojú rẹ̀.
\v 9 Nítorí kíyèsi i, èmi ó gbọn ọwọ́ mi sí orí wọn, wọn yóò sì jẹ́ ìkógun fún ìránṣẹ́ wọn: ẹ̀yin yóò sì mọ̀ pé, \nd Olúwa\nd* àwọn ọmọ-ogun ni ó rán mi.
\p 
\v 10 “Kọrin kí o sì yọ̀, ìwọ ọmọbìnrin Sioni. Nítorí èmi ń bọ̀ àti pé èmi yóò sì gbé àárín rẹ,” ni \nd Olúwa\nd* àwọn ọmọ-ogun wí.
\v 11 “Ọ̀pọ̀lọpọ̀ orílẹ̀-èdè ni yóò dàpọ̀ mọ́ \nd Olúwa\nd* ní ọjọ́ náà, wọn yóò sì di ènìyàn mi, èmi yóò sì gbé àárín rẹ, ìwọ yóò sì mọ̀ pé, \nd Olúwa\nd* àwọn ọmọ-ogun ni ó rán mi sí ọ.
\v 12 \nd Olúwa\nd* yóò sì jogún Juda ìní rẹ̀, ni ilẹ̀ mímọ́, yóò sì tún yan Jerusalẹmu.
\v 13 Ẹ̀ dákẹ́, gbogbo ẹran-ara níwájú \nd Olúwa\nd*: nítorí a jí i láti ibùgbé mímọ́ rẹ̀ wá.”
\c 3
\s1 Aṣọ mímọ́ fún olórí àlùfáà
\p 
\v 1 Ó sì fi Joṣua olórí àlùfáà hàn mí, ó dúró níwájú angẹli \nd Olúwa\nd*, Satani sí dúró lọ́wọ́ ọ̀tún rẹ̀ láti kọjú ìjà sí i.
\v 2 \nd Olúwa\nd* si wí fún Satani pé, “\nd Olúwa\nd* bá ọ wí ìwọ Satani; àní \nd Olúwa\nd* tí ó ti yan Jerusalẹmu, bá ọ wí, igi iná kọ́ ni èyí tí a mú kúrò nínú iná?”
\p 
\v 3 A sì wọ Joṣua ni aṣọ èérí, ó sì dúró níwájú angẹli náà.
\v 4 Ó sì dáhùn ó wí fún àwọn tí ó dúró níwájú rẹ̀ pé, “Bọ́ aṣọ èérí nì kúrò ní ara rẹ̀.”
\p Ó sì wí fún Joṣua pé, “Wò ó, mo mú kí àìṣedéédéé rẹ̀ kúrò lọ́dọ̀ rẹ̀, èmi yóò sì wọ̀ ọ́ ní aṣọ ẹ̀yẹ.”
\p 
\v 5 Mó sì wí pé, “Jẹ kí wọn fi gèlè mímọ́ wé e lórí.” Wọn sì fi gèlè mímọ́ wé e lórí, wọn sì fi aṣọ wọ̀ ọ́. Angẹli \nd Olúwa\nd* sì dúró tì í.
\p 
\v 6 Angẹli \nd Olúwa\nd* sì tẹnumọ́ ọn fún Joṣua pé:
\v 7 “Báyìí ni \nd Olúwa\nd* àwọn ọmọ-ogun wí: ‘Bí ìwọ ọ́ bá rìn ní ọ̀nà mi, bí ìwọ yóò bá sì pa àṣẹ mi mọ́, ìwọ yóò sì ṣe ìdájọ́ ilé mi pẹ̀lú, ìwọ yóò sì ṣe àkóso ààfin mi, èmi yóò fún ọ ní ààyè láti rìn láàrín àwọn tí ó dúró yìí.
\p 
\v 8 “ ‘Gbọ́, ìwọ Joṣua olórí àlùfáà, ìwọ, àti àwọn ẹgbẹ́ rẹ tí ó jókòó níwájú rẹ: nítorí ẹni ìyanu ni wọ́n: nítorí kíyèsi i, èmi yóò mú ẹ̀ka náà wá fun ìránṣẹ́ mi.
\v 9 Nítorí kíyèsi i, òkúta tí mo tí gbé kalẹ̀ níwájú Joṣua; lórí òkúta kan ni ojú méje wà: kíyèsi i, èmi yóò fín àkọlé rẹ̀,’ ni \nd Olúwa\nd* àwọn ọmọ-ogun wí, ‘Èmi yóò sì mú ẹ̀bi ilẹ̀ náà kúrò ní ọjọ́ kan.
\p 
\v 10 “ ‘\nd Olúwa\nd* àwọn ọmọ-ogun wí pé, ní ọjọ́ náà ni olúkúlùkù yóò pe ẹnìkejì láti jókòó rẹ̀ sábẹ́ igi àjàrà àti sábẹ́ igi ọ̀pọ̀tọ́.’ ”
\c 4
\s1 Ọ̀pá fìtílà wúrà àti àwọn igi olifi méjì
\p 
\v 1 Angẹli tí ó ń bá mi sọ̀rọ̀ sì tún dé, ó sì jí mi, bí ọkùnrin tí a jí lójú oorun rẹ̀,
\v 2 ó sì wí fún mi pé, “Kí ni ìwọ rí?”
\p Mo sì wí pé, “Mo wò, sì kíyèsi i, ọ̀pá fìtílà tí gbogbo rẹ̀ jẹ́ wúrà, pẹ̀lú àwokòtò rẹ̀ lórí rẹ̀ pẹ̀lú fìtílà méje rẹ̀ lórí rẹ̀, àti ẹnu méje fún fìtílà méjèèje, tí ó wà lórí rẹ̀.
\v 3 Igi olifi méjì sì wà létí rẹ̀, ọ̀kan ní apá ọ̀tún àwokòtò náà, àti èkejì ní apá òsì rẹ̀.”
\p 
\v 4 Mo sì dáhùn mo sì wí fún angẹli tí ó ń bá mi sọ̀rọ̀, pé, “Kín ni wọ̀nyí, olúwa mi?”
\p 
\v 5 Angẹli tí ó ń bá mi sọ̀rọ̀ dáhùn ó sì wí fún mi pé, “Ìwọ kò mọ ohun tí àwọn wọ̀nyí jásí?”
\p Mo sì wí pé, “Èmi kò mọ̀ ọ́n, olúwa mi.”
\p 
\v 6 Ó sì dáhùn ó sì wí fún mi pé, “Èyí ni ọ̀rọ̀ \nd Olúwa\nd* sí Serubbabeli tó wí pé: ‘Kì í ṣe nípa ipá, kì í ṣe nípa agbára, bí kò ṣe nípa Ẹ̀mí mi,’ ni \nd Olúwa\nd* àwọn ọmọ-ogun wí.
\p 
\v 7 “Ta ni ìwọ, ìwọ òkè ńlá? Ìwọ yóò di pẹ̀tẹ́lẹ̀ níwájú Serubbabeli: òun yóò sì fi ariwo mú òkúta téńté orí rẹ̀ wá, yóò máa kígbe wí pé, ‘Ọlọ́run bùkún fun! Ọlọ́run bùkún fun!’ ”
\p 
\v 8 Ọ̀rọ̀ \nd Olúwa\nd* sì tọ̀ mí wá, wí pé:
\v 9 “Ọwọ́ Serubbabeli ni a ti ṣe ìpìlẹ̀ ilé yìí, ọwọ́ rẹ̀ ni yóò sì parí rẹ̀; ìwọ yóò sì mọ̀ pé, \nd Olúwa\nd* àwọn ọmọ-ogun ni ó rán mi sí i yín.
\p 
\v 10 “Ṣùgbọ́n ta ni ha kẹ́gàn ọjọ́ ohun kékeré? Nítorí wọn ó yọ̀ nígbà ti wọ́n bá rí okùn ìwọ̀n nì lọ́wọ́ Serubbabeli.
\p “(Àwọn méje wọ̀nyí ni àwọn ojú \nd Olúwa\nd*, tí ó ń sáré síyìn-ín sọ́hùn-ún ní gbogbo ayé.)”
\p 
\v 11 Mo sì béèrè, mo sì sọ fún un pé, “Kí ni àwọn igi olifi méjì wọ̀nyí jásí, tí ó wà ní apá ọ̀tún fìtílà àti ní apá òsì rẹ̀?”
\p 
\v 12 Mo sì tún dáhùn, mo sì sọ fún un pé, “Kí ni àwọn ẹ̀ka méjì igi olifi wọ̀nyí jásí, tí ń tú òróró wúrà jáde nínú ara wọn láti ẹnu ọ̀pá oníhò wúrà méjì.”
\p 
\v 13 Ó sì dáhùn, ó wí fún mi pé, “Ìwọ kò mọ ohun tí àwọn wọ̀nyí jásí?”
\p Mo sì wí pé, “Bẹ́ẹ̀ kọ́, olúwa à mi.”
\p 
\v 14 Ó sì wí pé, “Àwọn méjì wọ̀nyí ni àwọn tí a fi òróró yàn, tí ó dúró ti Olúwa gbogbo ayé.”
\c 5
\s1 Ìwé kíkà ti n fò
\p 
\v 1 Nígbà náà ni mo yípadà, mo sì gbé ojú mi sókè, mo sì wò, sì kíyèsi i, ìwé kíká ti ń fò.
\p 
\v 2 Ó sì wí fún mi pé, “Kí ni ìwọ rí?”
\p Èmi sì dáhùn pé, “Mo rí ìwé kíká tí ń fò; gígùn rẹ̀ jẹ́ ogún ìgbọ̀nwọ́, ìbú rẹ̀ sì jẹ́ ìgbọ̀nwọ́ mẹ́wàá.”
\p 
\v 3 Ó sì wí fún mi pé, “Èyí ni ègún tí ó jáde lọ sí gbogbo ilẹ̀ ayé, nítorí gbogbo àwọn tí ó bá jalè ni a ó ké kúrò láti ìhín lọ nípa rẹ̀; gbogbo àwọn tí ó bá sì búra èké ni a ó ké kúrò láti ìhín lọ nípa rẹ̀.
\v 4 \nd Olúwa\nd* àwọn ọmọ-ogun wí pé, ‘Èmi yóò mú un jáde, Èmi yóò si wọ inú ilé olè lọ, àti inú ilé ẹni ti o bá fi orúkọ mi búra èké, yóò si wà ni àárín ilé rẹ̀, yóò si rún pẹ̀lú igi àti òkúta inú rẹ̀.’ ”
\s1 Obìnrin nínú agbọ̀n
\p 
\v 5 Angẹli tí ń bá mi sọ̀rọ̀ sì jáde lọ, ó sì wí fún mi pé, “Gbé ojú rẹ sókè nísinsin yìí, kí o sì wo nǹkan tí yóò jáde lọ.”
\p 
\v 6 Mo sì wí pé, “Kí ni nǹkan náà?”
\p Ó sì wí pé, “Èyí ni òsùwọ̀n tí ó jáde lọ.” Ó sì wí pé, “Èyí ni àwòrán ní gbogbo ilẹ̀ ayé.”
\p 
\v 7 Sì kíyèsi i, a gbé tálẹ́ǹtì òjé sókè, obìnrin kan sì nìyìí tí ó jókòó sí àárín àpẹẹrẹ òsùwọ̀n.
\v 8 Ó sì wí pé, “Èyí ni ìwà búburú.” Ó sì ti sí àárín òsùwọ̀n, ó sì ju ìdérí òjé sí ẹnu rẹ̀.
\p 
\v 9 Mo sì gbé ojú mi sókè, mo sì wò, sì kíyèsi i, obìnrin méjì jáde wá, ẹ̀fúùfù sì wá nínú ìyẹ́ wọn; nítorí wọ́n ní ìyẹ́ bí ìyẹ́ àkọ̀, wọ́n sì gbé àpẹẹrẹ òsùwọ̀n náà dé àárín méjì ayé àti ọ̀run.
\p 
\v 10 Mo sì sọ fún angẹli tí ó ń bá mi sọ̀rọ̀ pé, “Níbo ni àwọn wọ̀nyí ń gbé òsùwọ̀n náà lọ.”
\p 
\v 11 Ó si wí fún mi pé, “Sí orílẹ̀-èdè Babeli láti kọ ilé fún un. Tí ó bá ṣetán, a ó sì fi ìdí rẹ̀ mulẹ̀, a o sì fi ka orí ìpìlẹ̀ rẹ̀ níbẹ̀.”
\c 6
\s1 Kẹ̀kẹ́ ogun mẹ́rin tí ìdájọ́ Ọlọ́run
\p 
\v 1 Mo sì yípadà, mo sì gbé ojú mi sókè, mo sì wò, sì kíyèsi i, kẹ̀kẹ́ mẹ́rin jáde wá láti àárín òkè ńlá méjì, àwọn òkè ńlá náà sì jẹ́ òkè ńlá idẹ.
\v 2 Àwọn ẹṣin pupa wà ní kẹ̀kẹ́ èkínní; àti àwọn ẹṣin dúdú ní kẹ̀kẹ́ èkejì.
\v 3 Àti àwọn ẹṣin funfun ní kẹ̀kẹ́ ẹ̀kẹta; àti àwọn adíkálà àti alágbára ẹṣin ní kẹ̀kẹ́ ẹ̀kẹrin.
\v 4 Mo sì dáhùn, mo sì béèrè lọ́wọ́ angẹli tí ń bá mi sọ̀rọ̀ pé, “Kí ni ìwọ̀nyí, olúwa mi.”
\p 
\v 5 Angẹli náà si dáhùn ó sì wí fún mi pé, “Wọ̀nyí ni àwọn ẹ̀mí mẹ́rin ti ọ̀run, tí wọn ń lọ kúrò lẹ́yìn tí wọ́n ti fi ara wọn hàn níwájú Olúwa gbogbo ayé.
\v 6 Àwọn ẹṣin dúdú tí ó wà nínú rẹ̀ jáde lọ sí ilẹ̀ àríwá; àwọn funfun sì jáde lọ si ìwọ̀-oòrùn; àwọn adíkálà sì jáde lọ sí ìhà ilẹ̀ gúúsù.”
\p 
\v 7 Àwọn alágbára ẹṣin sì jáde lọ, wọ́n sì ń wá ọ̀nà àti lọ kí wọn bá a lè rìn síyìn-ín sọ́hùn-ún ni ayé; ó sì wí pé, “Ẹ lọ, ẹ lọ rìn síyìn-ín sọ́hùn-ún ní ayé!” Wọ́n sì rín síyìn-ín sọ́hùn-ún ní ayé.
\p 
\v 8 Nígbà náà ni ohùn kan sì ké sí mi, ó sì bá mi sọ̀rọ̀ wí pé, “Wò ó, àwọn wọ̀nyí tí ó lọ síhà ilẹ̀ àríwá ti mú ẹ̀mí mi parọ́rọ́ ni ilẹ̀ àríwá.”
\s1 Adé fún Joṣua
\p 
\v 9 Ọ̀rọ̀ \nd Olúwa\nd* sì tọ̀ mí wá, wí pé:
\v 10 “Mú nínú ìgbèkùn, nínú àwọn Heldai, tí Tobiah, àti ti Jedaiah, tí ó ti Babeli dé, kí ìwọ sì wá ní ọjọ́ kan náà, kí o sì wọ ilé Josiah ọmọ Sefaniah lọ.
\v 11 Kí o sì mú fàdákà àti wúrà, kí o sì fi ṣe adé púpọ̀, sì gbé wọn ka orí Joṣua ọmọ Josadaki, olórí àlùfáà.
\v 12 Sì sọ fún un pé, ‘Báyìí ni \nd Olúwa\nd* àwọn ọmọ-ogun sọ wí pé, wo ọkùnrin náà ti orúkọ rẹ̀ ń jẹ́ Ẹ̀ka; yóò sì yọ ẹ̀ka láti abẹ́ rẹ̀ wá, yóò si kọ́ tẹmpili \nd Olúwa\nd* wa.
\v 13 Òun ni yóò sì kọ́ tẹmpili \nd Olúwa\nd* òun ni yóò sì wọ̀ ní ògo, yóò sì jókòó, yóò sì jẹ ọba lórí ìtẹ́ rẹ̀; òun ó sì jẹ́ àlùfáà lórí ìtẹ́ rẹ̀; ìmọ̀ àlàáfíà yóò sì wá láàrín àwọn méjèèjì.’
\v 14 Adé wọ̀nyí yóò sì wà fún Helemu àti fún Tobiah, àti fún Jedaiah, àti fún Heni ọmọ Sefaniah fún ìrántí ni tẹmpili \nd Olúwa\nd*.
\v 15 Àwọn tí ó jìnnà réré yóò wá láti kọ́ tẹmpili \nd Olúwa\nd*, ẹ̀yin yóò sì mọ̀ pé, \nd Olúwa\nd* àwọn ọmọ-ogun ti rán mi sí yín. Yóò sì rí bẹ́ẹ̀ bí ẹ̀yin yóò bá gbà ohùn \nd Olúwa\nd*, Ọlọ́run yín gbọ́ nítòótọ́.”
\c 7
\s1 Òdodo àti àánú, kì í ṣe àwẹ̀
\p 
\v 1 Ó sì ṣe ní ọdún kẹrin Dariusi ọba, ọ̀rọ̀ \nd Olúwa\nd* tọ́ Sekariah wá ni ọjọ́ kẹrin oṣù Kisleu tí ń ṣe oṣù kẹsànán.
\v 2 Nígbà tí wọ́n ènìyàn Beteli rán Ṣareseri àti Regemmeleki, àti àwọn ènìyàn wọn sí ilé Ọlọ́run láti wá ojúrere \nd Olúwa\nd*.
\v 3 Àti láti bá àwọn àlùfáà tí ó wà ní ilé \nd Olúwa\nd* àwọn ọmọ-ogun, àti àwọn wòlíì sọ̀rọ̀ wí pé, “Ṣé kí èmi ó sọkún ní oṣù karùn-ún kí èmi ya ara mi sọ́tọ̀, bí mo ti ń ṣe láti ọdún mélòó wọ̀nyí wá bí?”
\p 
\v 4 Nígbà náà ni ọ̀rọ̀ \nd Olúwa\nd* àwọn ọmọ-ogun tọ̀ mí wá pé,
\v 5 “Sọ fún gbogbo àwọn ènìyàn ilẹ̀ náà, àti fún àwọn àlùfáà pé, ‘Nígbà tí ẹ̀yin gbààwẹ̀, tí ẹ sì ṣọ̀fọ̀ ní oṣù karùn-ún àti keje, àní fun àádọ́rin ọdún wọ̀nyí, ǹjẹ́ èmi ni ẹ̀yin ha ń gbààwẹ̀ yín fún?
\v 6 Nígbà tí ẹ sì jẹ, àti nígbà tí ẹ mu, fún ara yín kọ́ ni ẹ̀yin jẹ, àti fún ara yín kọ́ ni ẹ̀yin mú bí?
\v 7 Wọ̀nyí kọ́ ni ọ̀rọ̀ ti \nd Olúwa\nd* ti kígbe láti ọ̀dọ̀ àwọn wòlíì ìṣáájú wá, nígbà tí a ń gbé Jerusalẹmu, tí ó sì wà ní àlàáfíà, pẹ̀lú àwọn ìlú rẹ̀ tí ó yí i káàkiri, nígbà tí a ń gbé gúúsù àti pẹ̀tẹ́lẹ̀.’ ”
\p 
\v 8 Ọ̀rọ̀ \nd Olúwa\nd* sì tọ Sekariah wá, wí pé,
\v 9 “Báyìí ni \nd Olúwa\nd* àwọn ọmọ-ogun wí pé, ‘Ṣe ìdájọ́ òtítọ́, kí ẹ sì ṣe àánú àti ìyọ́nú olúkúlùkù sí arákùnrin rẹ̀.
\v 10 Má sì ṣe ni opó lára tàbí aláìní baba, àlejò, tàbí tálákà; kí ẹnikẹ́ni nínú yín má ṣe gbèrò ibi ní ọkàn sí arákùnrin rẹ̀.’
\p 
\v 11 “Ṣùgbọ́n wọ́n kọ̀ láti gbọ́, wọ́n sì gún èjìká, wọ́n sì pa ẹ̀yìn dà, wọ́n di etí wọn, kí wọn má ba à gbọ́.
\v 12 Wọ́n sé ọkàn wọn bí òkúta líle, kí wọn má ba à gbọ́ òfin, àti ọ̀rọ̀ tí \nd Olúwa\nd* àwọn ọmọ-ogun ti fi ẹ̀mí rẹ̀ rán nípa ọwọ́ àwọn wòlíì ìṣáájú wá. Ìbínú ńlá sì dé láti ọ̀dọ̀ \nd Olúwa\nd* àwọn ọmọ-ogun.
\p 
\v 13 “ ‘Ó sì ṣe, gẹ́gẹ́ bí ó ti kígbe, tí wọn kò sì fẹ́ gbọ́, bẹ́ẹ̀ ni wọ́n kígbe, tí èmi kò sì fẹ́ gbọ́,’ ni \nd Olúwa\nd* àwọn ọmọ-ogun wí.
\v 14 ‘Mo sì fi ìjì tú wọn ká sí gbogbo orílẹ̀-èdè tí wọn kò mọ̀. Ilẹ̀ náà sì dahoro lẹ́yìn wọn, tí ẹnikẹ́ni kò là á kọjá tàbí kí ó padà bọ̀, wọ́n sì sọ ilẹ̀ ààyò náà dahoro.’ ”
\c 8
\s1 Ọlọ́run ṣe ìpinnu láti bùkún Jerusalẹmu
\p 
\v 1 Ọ̀rọ̀ \nd Olúwa\nd* àwọn ọmọ-ogun si tún tọ́ mí wá.
\p 
\v 2 Báyìí ni \nd Olúwa\nd* àwọn ọmọ-ogun wí, “Owú ńlá ńlá ni mo jẹ fún Sioni, pẹ̀lú ìbínú ńlá ńlá ni mo fi jowú fún un.”
\p 
\v 3 Báyìí ni \nd Olúwa\nd* wí, “Mo yípadà sí Sioni èmi ó sì gbé àárín Jerusalẹmu. Nígbà náà ni a ó sì pé Jerusalẹmu ni ìlú ńlá òtítọ́; àti òkè ńlá \nd Olúwa\nd* àwọn ọmọ-ogun, ni a ó pè ní òkè ńlá mímọ́.”
\p 
\v 4 Báyìí ni \nd Olúwa\nd* àwọn ọmọ-ogun wí, “Arúgbó ọkùnrin, àti arúgbó obìnrin, yóò gbé ìgboro Jerusalẹmu, àti olúkúlùkù pẹ̀lú ọ̀pá ni ọwọ́ rẹ̀ fún ogbó.
\v 5 Ìgboro ìlú yóò sì kún fún ọmọdékùnrin, àti ọmọdébìnrin, tí ń ṣiré ní ìta wọn.”
\p 
\v 6 Báyìí ni \nd Olúwa\nd* àwọn ọmọ-ogun wí pé, “Bí ó bá ṣe ìyanu ní ojú ìyókù àwọn ènìyàn yìí ni ọjọ́ wọ̀nyí, ǹjẹ́ ó ha lè jẹ́ ìyanu ni ojú mi bí?” ni \nd Olúwa\nd* àwọn ọmọ-ogun wí.
\p 
\v 7 Báyìí ní \nd Olúwa\nd* àwọn ọmọ-ogun wí pé, “Kíyèsi i, èmi ó gba àwọn ènìyàn mi kúrò ni ilẹ̀ ìlà-oòrùn, àti kúrò ni ilẹ̀ ìwọ̀-oòrùn.
\v 8 Èmi ó sì mú wọn padà wá, wọn ó sì máa gbé àárín Jerusalẹmu. Wọn ó sì jẹ́ ènìyàn mi, èmi ó sì jẹ́ Ọlọ́run wọn, ní òtítọ́, àti ní òdodo.”
\p 
\v 9 Báyìí ni \nd Olúwa\nd* àwọn ọmọ-ogun wí pé, “Jẹ́ kí ọwọ́ yín le ẹ̀yin ti ń gbọ́ ọ̀rọ̀ wọ̀nyí ní ọjọ́ wọ̀nyí ni ẹnu àwọn wòlíì tí ó wà ni ọjọ́ tí a fi ìpìlẹ̀ ilé \nd Olúwa\nd* àwọn ọmọ-ogun lélẹ̀, jẹ́ ki ọwọ́ rẹ̀ le kí a bá lè kọ́ tẹmpili.
\v 10 Nítorí pé, ṣáájú ọjọ́ wọ̀nyí, owó ọ̀yà ènìyàn kò tó nǹkan, bẹ́ẹ̀ ni ọ̀yà ẹran pẹ̀lú, bẹ́ẹ̀ ni kò sí àlàáfíà fún ẹni ń jáde lọ, tàbí ẹni ti ń wọlé bọ, nítorí ìpọ́njú náà: nítorí mo dojú gbogbo ènìyàn, olúkúlùkù kọ aládùúgbò rẹ̀.
\v 11 Ṣùgbọ́n ní ìsinsin yìí èmi kì yóò ṣè sí ìyókù àwọn ènìyàn yìí gẹ́gẹ́ bí tí ìgbà àtijọ́,” ni \nd Olúwa\nd* àwọn ọmọ-ogun wí.
\p 
\v 12 “Nítorí irúgbìn yóò gbilẹ̀, àjàrà yóò ṣo èso rẹ̀, ilẹ̀ yóò sì hu ọ̀pọ̀lọpọ̀ nǹkan rẹ̀ jáde, àwọn ọ̀run yóò sì mu ìrì wọn wá; èmi ó sì mu kí èyí jẹ ogún ìní àwọn ìyókù ènìyàn yìí ni gbogbo nǹkan wọ̀nyí.
\v 13 Yóò sì ṣe, gẹ́gẹ́ bí ẹ̀yin tí jẹ́ ègún láàrín àwọn kèfèrí, ẹ̀yin ilé Juda, àti ilé Israẹli, bẹ́ẹ̀ ni èmi ó gbà yín sílẹ̀; ẹ̀yin o sì jẹ́ ìbùkún, ẹ má bẹ̀rù, ṣùgbọ́n jẹ́ ki ọwọ́ yín le.”
\p 
\v 14 Nítorí báyìí ni \nd Olúwa\nd* àwọn ọmọ-ogun wí: “Gẹ́gẹ́ bí mo ti rò láti ṣe yín níbi nígbà tí àwọn baba yín mú mi bínú,” ni \nd Olúwa\nd* àwọn ọmọ-ogun wí, tí èmi kò sì ronúpìwàdà.
\v 15 “Bẹ́ẹ̀ ni èmi sì ti ro ọjọ́ wọ̀nyí láti ṣe rere fún Jerusalẹmu, àti fún ilé Juda: ẹ má bẹ̀rù.
\v 16 Wọ̀nyí ni nǹkan tí ẹ̀yin ó ṣe: ki olúkúlùkù yín kí ó máa ba ọmọnìkejì rẹ̀ sọ òtítọ́; ṣe ìdájọ́ tòótọ́ àti àlàáfíà ní àwọn ibodè yín.
\v 17 Ẹ má ṣe jẹ́ kí ẹnìkan ro ibi ni ọkàn rẹ̀ sí ẹnìkejì rẹ̀; ẹ má fẹ́ ìbúra èké; nítorí gbogbo nǹkan wọ̀nyí ni mo kórìíra,” ni \nd Olúwa\nd* wí.
\p 
\v 18 Ọ̀rọ̀ \nd Olúwa\nd* àwọn ọmọ-ogun sì tọ mi wá wí pé.
\p 
\v 19 Báyìí ni \nd Olúwa\nd* àwọn ọmọ-ogun wí pé: “Àwẹ̀ oṣù kẹrin, karùn-ún, keje, àti tí ẹ̀kẹwàá, yóò jẹ́ ayọ̀ àti dídùn inú, àti àpéjọ àríyá fún ilé Juda; nítorí náà, ẹ fẹ́ òtítọ́ àti àlàáfíà.”
\p 
\v 20 Báyìí ni \nd Olúwa\nd* àwọn ọmọ-ogun wí pé, “Àwọn ènìyàn yóò sá à tún wa, àti ẹni tí yóò gbe ìlú ńlá púpọ̀.
\v 21 Àwọn ẹni tí ń gbé ìlú ńlá kan yóò lọ sí òmíràn, wí pé, ‘Ẹ jẹ́ kí a yára lọ gbàdúrà kí a sì wá ojúrere \nd Olúwa\nd*, àti láti wá \nd Olúwa\nd* àwọn ọmọ-ogun. Èmi pẹ̀lú yóò sì lọ.’
\v 22 Nítòótọ́, ọ̀pọ̀lọpọ̀ ènìyàn àti àwọn alágbára orílẹ̀-èdè yóò wá láti wá \nd Olúwa\nd* àwọn ọmọ-ogun ní Jerusalẹmu; àti láti gbàdúrà, àti láti wá ojúrere \nd Olúwa\nd*.”
\p 
\v 23 Báyìí ni \nd Olúwa\nd* àwọn ọmọ-ogun wí pé, “Ní àwọn ọjọ́ wọ̀nyí ni ọkùnrin mẹ́wàá láti inú gbogbo èdè àti orílẹ̀-èdè yóò dìímú, àní yóò di etí aṣọ ẹni tí i ṣe Júù mú, wí pé, ‘Àwa yóò ba ọ lọ, nítorí àwa tí gbọ́ pé, Ọlọ́run wà pẹ̀lú rẹ.’ ”
\c 9
\s1 Ìdájọ́ lórí àwọn ọ̀tá Israẹli
\p 
\v 1 Ọ̀rọ̀-ìmọ̀.
\q1 Ọ̀rọ̀ \nd Olúwa\nd* kọjú ìjà sí Hadiraki,
\q2 Damasku ni yóò sì jẹ́ ibi ìsinmi rẹ̀;
\q1 nítorí ojú \nd Olúwa\nd* ń bẹ lára ènìyàn,
\q2 àti lára gbogbo ẹ̀yà Israẹli.
\q1 
\v 2 Àti Hamati pẹ̀lú yóò ṣe ààlà rẹ̀
\q2 Tire àti Sidoni bí o tilẹ̀ ṣe ọlọ́gbọ́n gidigidi.
\q1 
\v 3 Tire sì mọ odi líle fún ara rẹ̀,
\q2 ó sì kó fàdákà jọ bí eruku,
\q2 àti wúrà dáradára bí ẹrẹ̀ ìgboro.
\q1 
\v 4 Ṣùgbọ́n, Olúwa yóò kó gbogbo ohun ìní rẹ̀ lọ,
\q2 yóò sì pa agbára rẹ̀ run ní ojú Òkun,
\q2 a ó sì fi iná jó o run.
\q1 
\v 5 Aṣkeloni yóò rí í, yóò sì bẹ̀rù;
\q2 Gasa pẹ̀lú yóò rí í, yóò sì káàánú gidigidi,
\q2 àti Ekroni: nítorí tí ìrètí rẹ̀ yóò ṣákì í.
\q1 Gasa yóò pàdánù ọba rẹ̀,
\q2 Aṣkeloni yóò sì di ahoro.
\q1 
\v 6 Ọmọ àlè yóò sì gbé inú Aṣdodu,
\q2 Èmi yóò sì gé ìgbéraga àwọn Filistini kúrò.
\q1 
\v 7 Èmi yóò sì mu ẹ̀jẹ̀ rẹ̀ kúrò ni ẹnu rẹ̀,
\q2 àti àwọn ohun èèwọ̀ kúrò láàrín eyín rẹ̀:
\q1 ṣùgbọ́n àwọn tó ṣẹ́kù yóò jẹ́ tí Ọlọ́run wa,
\q2 wọn yóò sì jẹ baálẹ̀ ní Juda,
\q2 àti Ekroni ni yóò rí bí Jebusi.
\q1 
\v 8 Èmi yóò sì dó yí ilẹ̀ mi ká
\q2 nítorí ogun àwọn tí wọ́n ń wá ohun tí wọn yóò bàjẹ́ kiri,
\q1 kò sí aninilára tí yóò bori wọn mọ́:
\q2 nítorí ni ìsinsin yìí ni mo fi ojú ṣọ́ wọn.
\s1 Ọba sioni ń bọ̀
\q1 
\v 9 Kún fún ayọ̀, ìwọ ọmọbìnrin Sioni,
\q2 hó ìhó ayọ̀, ìwọ ọmọbìnrin Jerusalẹmu.
\q1 Wò ó, ọba rẹ ń bọ̀ wá sọ́dọ̀ rẹ:
\q2 òdodo ni òun, ó sì ní ìgbàlà;
\q2 ó ní ìrẹ̀lẹ̀, ó sì ń gun kẹ́tẹ́kẹ́tẹ́,
\q2 àní ọmọ kẹ́tẹ́kẹ́tẹ́.
\q1 
\v 10 Èmi ó sì gbé kẹ̀kẹ́ kúrò ni Efraimu,
\q2 àti ẹṣin ogun kúrò ni Jerusalẹmu,
\q2 a ó sì ṣẹ́ ọrun ogun.
\q1 Òun yóò sì kéde àlàáfíà sí àwọn kèfèrí.
\q2 Ìjọba rẹ̀ yóò sì gbilẹ̀ láti Òkun dé Òkun,
\q2 àti láti odò títí de òpin ayé.
\q1 
\v 11 Ní tìrẹ, nítorí ẹ̀jẹ̀ májẹ̀mú mi pẹ̀lú rẹ,
\q2 Èmi ó dá àwọn ìgbèkùn rẹ̀ sílẹ̀ kúrò nínú ọ̀gbun.
\q1 
\v 12 Ẹ padà sínú odi agbára yín, ẹ̀yin òǹdè ti o ni ìrètí:
\q2 àní lónìí yìí èmi sọ pé, èmi o san án fún ọ ni ìlọ́po méjì.
\q1 
\v 13 Èmi ó fa Juda le bí mo ṣe fa ọrun mi le,
\q2 mo sì fi Efraimu kún un,
\q1 Èmi yóò gbé àwọn ọmọ rẹ ọkùnrin dìde, ìwọ Sioni,
\q2 sí àwọn ọmọ rẹ̀ ọkùnrin, ìwọ Giriki,
\q2 mo ṣe ọ́ bí idà alágbára.
\s1 \nd Olúwa\nd* yóò farahàn
\q1 
\v 14 \nd Olúwa\nd* yóò sì fi ara hàn ní orí wọn;
\q2 ọfà rẹ̀ yóò sì jáde lọ bí mọ̀nàmọ́ná.
\q1 \nd Olúwa\nd* Olódùmarè yóò sì fọn ìpè,
\q2 Òun yóò sì lọ nínú atẹ́gùn ìjì gúúsù.
\q2 
\v 15 \nd Olúwa\nd* àwọn ọmọ-ogun yóò dáàbò bò wọ́n;
\q1 wọn ó sì jẹ ni run,
\q2 wọn ó sì tẹ òkúta kànnàkànnà mọ́lẹ̀;
\q1 wọn ó sì mu ẹ̀jẹ̀ wọn bí wáìnì,
\q2 wọn ó sì kún bí ọpọ́n,
\q2 wọn ó sì rin ṣinṣin bí àwọn igun pẹpẹ.
\q1 
\v 16 \nd Olúwa\nd* Ọlọ́run wọn yóò sì gbà wọ́n là ni ọjọ́ náà
\q2 bí agbo ènìyàn rẹ̀:
\q1 nítorí wọn ó dàbí àwọn òkúta adé,
\q2 tí a gbé sókè bí àmì lórí ilẹ̀ rẹ̀.
\q1 
\v 17 Nítorí oore rẹ̀ tí tóbi tó, ẹwà rẹ̀ sì tí pọ̀!
\q2 Ọkà yóò mú ọ̀dọ́mọkùnrin dárayá,
\q2 àti ọtí wáìnì tuntun yóò mú àwọn ọ̀dọ́mọbìnrin ṣe bẹ́ẹ̀ pẹ̀lú.
\c 10
\s1 \nd Olúwa\nd* yóò gba Juda
\q1 
\v 1 Ẹ béèrè òjò nígbà àrọ̀kúrò ni ọwọ́ \nd Olúwa\nd*;
\q2 \nd Olúwa\nd* tí o dá mọ̀nàmọ́ná,
\q1 tí ó sì fi ọ̀pọ̀ òjò fún ènìyàn,
\q2 fún olúkúlùkù koríko ní pápá.
\q1 
\v 2 Nítorí àwọn òrìṣà tí sọ̀rọ̀ asán,
\q2 àwọn aláfọ̀ṣẹ sì tí rí èké,
\q1 wọn sì tí rọ àlá èké;
\q2 wọ́n ń tu ni nínú lásán,
\q1 nítorí náà àwọn ènìyàn náà ṣáko lọ bí àgùntàn,
\q2 a ṣẹ wọn níṣẹ̀ẹ́, nítorí Olùṣọ́-àgùntàn kò sí.
\b
\q1 
\v 3 “Ìbínú mi ru sí àwọn darandaran,
\q2 èmi o sì jẹ àwọn olórí ní yà
\q1 nítorí \nd Olúwa\nd* àwọn ọmọ-ogun ti bẹ agbo rẹ̀,
\q2 ilé Juda wò,
\q2 yóò sì fi wọn ṣe ẹṣin rẹ̀ dáradára ní ogun.
\q1 
\v 4 Láti ọ̀dọ̀ rẹ̀ ni òkúta igun ilé ti jáde wá,
\q2 láti ọ̀dọ̀ rẹ ni èèkàn àgọ́ tí wá,
\q2 láti ọ̀dọ̀ rẹ ni ọrún ogun tí wá,
\q2 láti ọ̀dọ̀ rẹ ni àwọn akóniṣiṣẹ́ gbogbo tí wá.
\q1 
\v 5 Gbogbo wọn yóò sì dàbí ọkùnrin
\q2 alágbára ni ogun tí ń tẹ àwọn ọ̀tá wọn mọ́lẹ̀ ní ìgboro, wọn ó sì jagun,
\q1 nítorí \nd Olúwa\nd* wà pẹ̀lú wọn,
\q2 wọn ó sì dààmú àwọn tí ń gun ẹṣin.
\b
\q1 
\v 6 “Èmi o sì mú ilé Juda ní agbára,
\q2 èmi o sì gba ilé Josẹfu là,
\q1 èmi ó sì tún mú wọn padà
\q2 nítorí mo tí ṣàánú fún wọn,
\q1 ó sì dàbí ẹni pé èmi kò ì tì í ta wọ́n nù;
\q2 nítorí èmi ni \nd Olúwa\nd* Ọlọ́run wọn,
\q1 èmi o sì gbọ́ tiwọn
\q1 
\v 7 Efraimu yóò sì ṣe bí alágbára,
\q1 ọkàn wọn yóò sì yọ̀ bi ẹni pé nípa ọtí wáìnì:
\q1 àní àwọn ọmọ wọn yóò rí í,
\q2 wọn o sì yọ̀, inú wọn ó sì dùn nínú \nd Olúwa\nd*.
\q1 
\v 8 Èmi ó kọ sí wọn, èmi ó sì ṣà wọ́n jọ;
\q2 nítorí èmi tí rà wọ́n padà;
\q1 wọn ó sì pọ̀ sí i gẹ́gẹ́ bí
\q2 wọ́n tí ń pọ̀ sí í rí.
\q1 
\v 9 Bí ó tilẹ̀ jẹ́ pé mo tú wọn káàkiri orílẹ̀-èdè:
\q2 síbẹ̀ wọn ó sì rántí mi ni ilẹ̀ jíjìn;
\q1 wọn ó sì gbé pẹ̀lú àwọn ọmọ wọn,
\q2 wọn ó sì tún padà.
\q1 
\v 10 Èmi ó sì tún mú wọn padà kúrò ni ilẹ̀ Ejibiti pẹ̀lú,
\q2 èmi ó sì ṣà wọn jọ kúrò ni ilẹ̀ Asiria.
\q1 Èmi ó sì mú wọn wá sí ilẹ̀ Gileadi àti Lebanoni;
\q2 a kì yóò sì rí ààyè fún wọn bí ó ti yẹ.
\q1 
\v 11 Wọn yóò sì la Òkun wàhálà já,
\q2 yóò sì bori rírú omi nínú Òkun,
\q1 gbogbo ibú odò ni yóò sì gbẹ,
\q2 a ó sì rẹ ìgbéraga Asiria sílẹ̀,
\q2 ọ̀pá aládé Ejibiti yóò sí lọ kúrò.
\q1 
\v 12 Èmi ó sì mú wọn ní agbára nínú \nd Olúwa\nd*;
\q2 wọn ó sì rìn sókè rìn sódò ni orúkọ rẹ̀,”
\q2 ni \nd Olúwa\nd* wí.
\b
\c 11
\q1 
\v 1 Ṣí àwọn ìlẹ̀kùn rẹ sílẹ̀, ìwọ Lebanoni,
\q2 kí iná bá lè jẹ igi kedari rẹ run.
\q1 
\v 2 Hu, igi junifa; nítorí igi kedari ṣubú,
\q2 nítorí tí a ba àwọn igi tí o lógo jẹ́:
\q2 hu, ẹ̀yin igi óákù tí Baṣani,
\q1 nítorí gé igbó àjàrà lulẹ̀.
\q1 
\v 3 Gbọ́ ohun igbe àwọn olùṣọ́-àgùntàn;
\q2 ògo wọn bàjẹ́;
\q1 gbọ́ ohùn bíbú àwọn ọmọ kìnnìún
\q2 nítorí ògo Jordani bàjẹ́.
\s1 Olùṣọ́-àgùntàn méjì
\p 
\v 4 Báyìí ni \nd Olúwa\nd* Ọlọ́run mi wí: “Bọ́ ọ̀wọ́ ẹran àbọ́pa.
\v 5 Tí àwọn olúwa wọn ń pa wọ́n, tí wọn kò sì ka ara wọn sí pé wọn jẹ̀bi: àti àwọn tí ń tà wọ́n wí pé, ‘Ìbùkún ni fún \nd Olúwa\nd*, nítorí tí mo dí ọlọ́rọ̀!’ Àwọn olùṣọ́-àgùntàn wọn kò sì ṣàánú wọn.
\v 6 Nítorí èmi kì yóò ṣàánú fún àwọn ara ilẹ̀ náà mọ́,” ni \nd Olúwa\nd* wí, “Ṣí kíyèsi í, èmi yóò fi olúkúlùkù ènìyàn lé aládùúgbò rẹ̀ lọ́wọ́, àti lé ọwọ́ ọba rẹ̀, wọn yóò sì fọ́ ilẹ̀ náà, èmi kì yóò sì gbà wọ́n lọ́wọ́ wọn.”
\p 
\v 7 Èmi yóò sì bọ́ ẹran àbọ́pa, àní ẹ̀yin òtòṣì nínú ọ̀wọ́ ẹran. Mo sì mu ọ̀pá méjì sọ́dọ̀; mo pè ọ̀kan ni Oore-ọ̀fẹ́, mo pè èkejì ni Àmùrè; mo sì bọ́ ọ̀wọ́ ẹran náà.
\v 8 Olùṣọ́-àgùntàn mẹ́ta ni mo sì gé kúrò ní oṣù kan.
\p Ọkàn mi sì kórìíra wọn, ọkàn wọn pẹ̀lú sì kórìíra mi.
\v 9 Mo sì wí pé, “Èmi kì yóò bọ́ yin: èyí ti ń ku lọ, jẹ́ kí òkú o kú; èyí tí a o ba sì gé kúrò, jẹ́ kí a gé e kúrò; ki olúkúlùkù nínú àwọn ìyókù jẹ́ ẹran-ara ẹnìkejì rẹ̀.”
\p 
\v 10 Mo sì mu ọ̀pá mi, ti a ń pè ní Oore-ọ̀fẹ́, mo ṣẹ́ si méjì, ki èmi bá lè da májẹ̀mú mi tí mo tí bá gbogbo àwọn ènìyàn náà dá.
\v 11 Ó sì dá ni ọjọ́ náà, bẹ́ẹ̀ ni àwọn òtòṣì nínú ọ̀wọ́ ẹran náà tí ó dúró tì mí mọ̀ pé, ọ̀rọ̀ \nd Olúwa\nd* ni.
\p 
\v 12 Mo sì wí fún wọn pé, “Bí ó bá dára ní ojú yin, ẹ fún mi ni owó ọ̀yà mi; bí bẹ́ẹ̀ kọ́, ẹ mú un lọ́wọ́.” Bẹ́ẹ̀ ni wọ́n wọn ọgbọ̀n owó fàdákà fún iye owó ọ̀yà mi.
\p 
\v 13 \nd Olúwa\nd* sì wí fún mi pé, “Sọ ọ sí amọ̀kòkò.” Iye dáradára náà, tí wọn yọ owó mi sí. Mo sì mu ọgbọ̀n owó fàdákà náà, mo sì sọ wọ́n sí àpótí ìṣúra ní ilé \nd Olúwa\nd*.
\p 
\v 14 Mo sì ṣẹ́ ọ̀pá mi kejì, àní Àmùrè, sí méjì, kí èmi lè ya ìbátan tí ó wà láàrín Juda àti láàrín Israẹli.
\p 
\v 15 \nd Olúwa\nd* sì wí fún mi pé, “Tún mú ohun èlò aṣiwèrè olùṣọ́-àgùntàn kan sọ́dọ̀ rẹ̀.
\v 16 Nítorí Èmi o gbé Olùṣọ́-àgùntàn kan dìde ni ilẹ̀ náà, tí kí yóò bẹ àwọn tí ó ṣègbé wò, ti kì yóò sì wá èyí tí ó yapa; tí kì yóò ṣe ìtọ́jú èyí tí a pa lára tàbí kí ó bọ́ àwọn tí ara wọn dá pépé: Ṣùgbọ́n òun yóò jẹ ẹran èyí tí ó ni ọ̀rá, àwọn èyí tiwọn fi èékánná wọn ya ara wọn pẹ́rẹpẹ̀rẹ.
\q1 
\v 17 “Ègbé ni fún olùṣọ́-àgùntàn asán náà,
\q2 tí ó fi ọ̀wọ́ ẹran sílẹ̀!
\q1 Idà yóò gé apá rẹ̀ àti ojú ọ̀tún rẹ̀:
\q2 apá rẹ̀ yóò gbẹ pátápátá,
\q2 ojú ọ̀tún rẹ̀ yóò sì fọ́ pátápátá!”
\c 12
\s1 A o pa àwọn ọ̀tá Jerusalẹmu run
\p 
\v 1 Ọ̀rọ̀-ìmọ̀. Ọ̀rọ̀ \nd Olúwa\nd* fún Israẹli ni.
\b
\p \nd Olúwa\nd* wí, ẹni tí ó na àwọn ọ̀run, tí ó sì fi ìpìlẹ̀ ayé sọlẹ̀, tí ó sì da ẹ̀mí ènìyàn tí ń bẹ ni inú rẹ̀,
\v 2 “Kíyèsi í, èmi yóò sọ Jerusalẹmu dí àgọ́ ìwárìrì sí gbogbo ènìyàn yíká, nígbà tí wọn yóò dó ti Juda àti Jerusalẹmu.
\v 3 Ní ọjọ́ náà, nígbà tí gbogbo orílẹ̀-èdè ayé bá parapọ̀ sí i, ni èmi yóò sọ Jerusalẹmu di òkúta ti ko ṣe yí kúrò fún gbogbo ènìyàn, gbogbo àwọn tí ó bá sì fẹ́ yí i ni a ó gé sí wẹ́wẹ́,
\v 4 ní ọjọ́ náà,” ni \nd Olúwa\nd* wí, “Ni èmi yóò fi ìdágìrì lu gbogbo ẹṣin, àti fi òmùgọ̀ kọlu ẹni tí ń gun un; èmi yóò sì ṣí ojú mi sí ilé Juda, èmi yóò sì bu ìfọ́jú lu gbogbo ẹṣin tí orílẹ̀-èdè.
\v 5 Àti àwọn baálẹ̀ Juda yóò sì wí ni ọkàn wọn pé, ‘Àwọn ara Jerusalẹmu ni agbára mi nípa \nd Olúwa\nd* àwọn ọmọ-ogun ni Ọlọ́run wọn.’
\p 
\v 6 “Ní ọjọ́ náà, ni èmi yóò ṣe àwọn baálẹ̀ Juda bí ààrò iná kan láàrín igi, àti bi ẹ̀fúùfù iná láàrín ìtí; wọn yóò sì jẹ gbogbo àwọn ènìyàn run yíká lápá ọ̀tún àti lápá òsì, a ó sì tún máa gbé inú Jerusalẹmu ní ipò rẹ̀.
\p 
\v 7 “\nd Olúwa\nd* pẹ̀lú yóò kọ́ tètè gba àgọ́ Juda là ná, kí ògo ilé Dafidi àti ògo àwọn ara Jerusalẹmu má ba gbé ara wọn ga sí Juda.
\v 8 Ní ọjọ́ náà ni \nd Olúwa\nd* yóò dáàbò bò àwọn tí ń gbé Jerusalẹmu; ẹni tí ó bá sì ṣe àìlera nínú wọn ní ọjọ́ náà, yóò dàbí Dafidi; ilé Dafidi yóò sì dàbí Ọlọ́run, bí angẹli \nd Olúwa\nd* níwájú wọn.
\v 9 Yóò sì ṣe ni ọjọ́ náà, èmi yóò wá láti pa gbogbo àwọn orílẹ̀-èdè run tí ó wá kọjú ìjà sí Jerusalẹmu.”
\s1 Ìṣọ̀fọ̀ fún ọba wọn tí wọn gún lọ́kọ̀
\p 
\v 10 “Èmi ó sì tu ẹ̀mí oore-ọ̀fẹ́ àti ẹ̀bẹ̀ sórí ilé Dafidi àti sórí Jerusalẹmu, wọn ó sì máa wo ẹni tí wọn tí gún ni ọ̀kọ̀, wọn ó sì máa ṣọ̀fọ̀ rẹ̀, bí ẹnìkan ti ń ṣọ̀fọ̀ fún ọmọ rẹ̀ kan ṣoṣo àti gẹ́gẹ́ bí ènìyàn tí wọn yóò sì wà ni ìbànújẹ́, bí ẹni tí ń banújẹ́ fún àkọ́bí rẹ̀.
\v 11 Ní ọjọ́ náà ni ẹkún, ńlá ńlá yóò wà ni Jerusalẹmu, gẹ́gẹ́ bí ọ̀fọ̀ Hadadi Rimoni ni àfonífojì Megido.
\v 12 Ilẹ̀ náà yóò ṣọ̀fọ̀, ìdílé, kọ̀ọ̀kan fun ara rẹ, lọ́tọ̀ọ̀tọ̀; ìdílé Dafidi lọ́tọ̀; àti àwọn aya wọn lọ́tọ̀; ìdílé Natani lọ́tọ̀, àti àwọn aya wọn lọ́tọ́.
\v 13 Ìdílé Lefi lọ́tọ̀, àti àwọn aya wọn lọ́tọ̀; ìdílé Ṣimei lọ́tọ̀, àti àwọn aya wọn lọ́tọ̀.
\v 14 Gbogbo àwọn ìdílé tí o kù, ìdílé, ìdílé, lọ́tọ̀ọ̀tọ̀, àti àwọn aya wọn lọ́tọ̀ọ̀tọ̀.
\c 13
\s1 Ìwẹ̀nùmọ́ kúrò nínú ẹsẹ̀
\p 
\v 1 “Ní ọjọ́ náà ìsun kan yóò ṣí sílẹ̀ fún ilé Dafidi àti fún àwọn ará Jerusalẹmu, láti wẹ̀ wọ́n mọ́ kúrò nínú ẹ̀ṣẹ̀ àti àìmọ́ wọn.
\p 
\v 2 “Yóò sì ṣe ní ọjọ́ náà ni \nd Olúwa\nd* àwọn ọmọ-ogun wí, ni èmi ó gé orúkọ àwọn òrìṣà kúrò ni ilẹ̀ náà, a kì yóò sì rántí wọn mọ́, àti pẹ̀lú èmi ó mú àwọn wòlíì èké àti àwọn ẹ̀mí àìmọ́ kúrò ni ilẹ̀ náà.
\v 3 Yóò sì ṣe, nígbà tí ẹnìkan yóò sọtẹ́lẹ̀ síbẹ̀, ni baba rẹ̀ àti ìyá rẹ̀ tí ó bí í yóò wí fún un pé, ‘Ìwọ ki yóò yè, nítorí ìwọ ń sọ ọ̀rọ̀ èké ni orúkọ \nd Olúwa\nd*.’ Àti baba rẹ̀ àti ìyá rẹ̀ tí o bí í yóò gun un ni àgúnpa nígbà tí ó bá sọtẹ́lẹ̀.
\p 
\v 4 “Yóò sì ṣe ní ọjọ́ náà, ojú yóò tí àwọn wòlíì èké olúkúlùkù nítorí ìran rẹ̀, nígbà tí òun ba tí sọtẹ́lẹ̀; bẹ́ẹ̀ ni wọn kì yóò sì wọ aṣọ wòlíì onírun rẹ̀ tí o fi ń tan ní jẹ.
\v 5 Ṣùgbọ́n òun o wí pé, ‘Èmi kí í ṣe wòlíì, àgbẹ̀ ni èmi; nítorí tí a ti fi mí ṣe ìránṣẹ́ láti ìgbà èwe mi wá.’
\v 6 Ẹnìkan ó sì wí fún un pé, ‘Ọgbẹ́ kín ní wọ̀nyí ni ẹ̀yìn rẹ?’ Òun o sì dáhùn pé, ‘Wọ̀nyí ni ibi tí a ti sá mi ní ilé àwọn ọ̀rẹ́ mi.’
\s1 A lu olùṣọ́-àgùntàn, agbo ẹran fọ́nká
\q1 
\v 7 “Dìde, ìwọ idà, sí Olùṣọ́-àgùntàn mi,
\q2 àti sí ẹni tí í ṣe ẹnìkejì mi,”
\q2 ni \nd Olúwa\nd* àwọn ọmọ-ogun wí:
\q1 “Kọlu Olùṣọ́-àgùntàn,
\q2 àwọn àgùntàn a sì túká:
\q2 èmi o sì yí ọwọ́ mi sí àwọn kéékèèké.
\q1 
\v 8 Yóò sì ṣe, ni gbogbo ilẹ̀,” ni \nd Olúwa\nd* wí,
\q2 “a ó gé apá méjì nínú rẹ̀ kúrò yóò sì kú;
\q2 ṣùgbọ́n apá kẹta yóò kù nínú rẹ̀.
\q1 
\v 9 Èmi ó sì mú apá kẹta náà la àárín iná,
\q2 èmi yóò sì yọ́ wọn bí a ti yọ́ fàdákà,
\q2 èmi yóò sì dán wọn wò, bi a tí ń dán wúrà wò:
\q1 wọn yóò sì pé orúkọ mi,
\q2 èmi yóò sì dá wọn lóhùn:
\q1 èmi yóò wí pé, ‘Àwọn ènìyàn mi ni,’
\q2 àwọn yóò sì wí pé, ‘\nd Olúwa\nd* ni Ọlọ́run wa.’ ”
\c 14
\s1 \nd Olúwa\nd* Wa Jọba
\p 
\v 1 Kíyèsi i, ọjọ́ \nd Olúwa\nd* ń bọ̀, a ó sì pín ìkógun rẹ̀ láàrín rẹ̀.
\p 
\v 2 Nítorí èmi ó kó gbogbo orílẹ̀-èdè jọ sí Jerusalẹmu fún ogun; a ó sì ko ìlú náà, a ó sì kó àwọn ilé, a ó sì ba àwọn obìnrin jẹ́, ààbọ̀ ìlú náà yóò lọ sí ìgbèkùn, a kì yóò sì gé ìyókù àwọn ènìyàn náà kúrò ni ìlú náà.
\v 3 Nígbà náà ni \nd Olúwa\nd* yóò jáde lọ, yóò sì bá àwọn orílẹ̀-èdè náà jà, gẹ́gẹ́ bí í ti ìjà ní ọjọ́ ogun.
\v 4 Ẹsẹ̀ rẹ̀ yóò sì dúró ni ọjọ́ náà lórí òkè Olifi, tí ó wà níwájú Jerusalẹmu ni ìlà-oòrùn, òkè Olifi yóò sì là á sí méjì, sí ìhà ìlà-oòrùn àti ìhà ìwọ̀-oòrùn, àfonífojì ńlá ńlá yóò wà: ìdajì òkè náà yóò sì ṣí síhà àríwá, àti ìdajì rẹ̀ síhà gúúsù.
\v 5 Ẹ̀yin ó sì sá sí àfonífojì àwọn òkè mi, nítorí pé àfonífojì òkè náà yóò dé Aseli: nítòótọ́, ẹ̀yin ó sá bí ẹ tí sá fún ìmìmì-ilẹ̀ ni ọjọ́ Ussiah ọba Juda: \nd Olúwa\nd* Ọlọ́run mi yóò sì wá, àti gbogbo àwọn Ẹni mímọ́ pẹ̀lú rẹ̀.
\p 
\v 6 Yóò sì ṣe ni ọjọ́ náà, ìmọ́lẹ̀ kì yóò mọ́, bẹ́ẹ̀ ni kì yóò ṣókùnkùn.
\v 7 Ṣùgbọ́n yóò jẹ́ ọjọ́ kan mímọ́ fún \nd Olúwa\nd*, kì í ṣe ọ̀sán, kì í ṣe òru; ṣùgbọ́n yóò ṣe pé, ni àṣálẹ́ ìmọ́lẹ̀ yóò wà.
\p 
\v 8 Yóò sì ṣe ní ọjọ́ náà, omi ìyè yóò tí Jerusalẹmu sàn lọ; ìdajì wọn síhà Òkun ìlà-oòrùn, àti ìdajì wọn síhà okùn ẹ̀yìn: nígbà ẹ̀rùn àti nígbà òtútù ni yóò rí bẹ́ẹ̀.
\p 
\v 9 \nd Olúwa\nd* yóò sì jẹ ọba lórí gbogbo ayé; ni ọjọ́ náà ni \nd Olúwa\nd* kan yóò wa orúkọ rẹ̀ nìkan náà ni orúkọ.
\p 
\v 10 A ó yí gbogbo ilẹ̀ padà bi pẹ̀tẹ́lẹ̀ kan láti Geba dé Rimoni lápá gúúsù Jerusalẹmu: yóò di bí aginjù, ṣùgbọ́n a ó sì gbé Jerusalẹmu sókè, yóò sì gbe ipò rẹ̀, láti ibodè Benjamini títí dé ibi ibodè èkínní, dé ibodè igun nì, àti láti ilé ìṣọ́ Hananeli dé ibi ìfúntí wáìnì ọba.
\v 11 Ènìyàn yóò sì máa gbé ibẹ̀, kì yóò sì sí ìparun mọ́; ṣùgbọ́n a ó máa gbé Jerusalẹmu láìléwu.
\p 
\v 12 Èyí ni yóò sì jẹ́ ààrùn tí \nd Olúwa\nd* yóò fi kọlu gbogbo àwọn ènìyàn ti ó tí ba Jerusalẹmu jà; ẹran-ara wọn yóò rù nígbà tí wọn dúró ni ẹsẹ̀ wọn, ojú wọn yóò sì rà ni ihò wọn, ahọ́n wọn yóò sì bàjẹ́ ni ẹnu wọn.
\v 13 Yóò sì ṣe ni ọjọ́ náà, ìrọ́kẹ̀kẹ̀ ńlá láti ọ̀dọ̀ \nd Olúwa\nd* wá yóò wà láàrín wọn; wọn ó sì di ọwọ́ ara wọn mú, ọwọ́ èkínní yóò sì dìde sì ọwọ́ èkejì rẹ̀.
\v 14 Juda pẹ̀lú yóò sì jà ni Jerusalẹmu: ọrọ̀ gbogbo àwọn kèfèrí tí ó wà káàkiri ni a ó sì kójọ, wúrà àti fàdákà, àti aṣọ, ní ọ̀pọ̀lọpọ̀.
\v 15 Bẹ́ẹ̀ ni ààrùn ẹṣin, ìbáaka, ìbákasẹ, àti tí kẹ́tẹ́kẹ́tẹ́, yóò sì wà, àti gbogbo ẹranko tí ń bẹ nínú àgọ́.
\p 
\v 16 Yóò sì ṣe, olúkúlùkù ẹni tí o kù nínú gbogbo àwọn orílẹ̀-èdè tí ó dìde sí Jerusalẹmu yóò máa gòkè lọ lọ́dọọdún láti sìn ọba, \nd Olúwa\nd* àwọn ọmọ-ogun, àti láti ṣe àjọyọ̀ àsè àgọ́ náà.
\v 17 Yóò sì ṣe, ẹnikẹ́ni tí kì yóò gòkè wá nínú gbogbo ìdílé ayé sí Jerusalẹmu láti sín ọba, \nd Olúwa\nd* àwọn ọmọ-ogun, òjò kì yóò rọ̀ fún wọn.
\v 18 Bí ìdílé Ejibiti kò bá sì gòkè lọ, tí wọn kò sì wá, fi ara wọn hàn tí wọn kò ní òjò; ààrùn náà yóò wà, tí \nd Olúwa\nd* yóò fi kọlù àwọn kèfèrí tí kò gòkè wá láti ṣe àjọyọ̀ àsè àgọ́ náà.
\v 19 Èyí ni yóò sì jẹ́ ìyà Ejibiti, àti ìyà gbogbo orílẹ̀-èdè tí kò gòkè wá láti pa àsè àgọ́ mọ́.
\p 
\v 20 Ní ọjọ́ náà ni “mímọ́ sí \nd Olúwa\nd*” yóò wà lára ṣaworo ẹṣin: àti àwọn ìkòkò ni ilé \nd Olúwa\nd* yóò sì dàbí àwọn ọpọ́n tí ń bẹ níwájú pẹpẹ.
\v 21 Nítòótọ́, gbogbo ìkòkò ni Jerusalẹmu àti ni Juda yóò jẹ́ mímọ́ sí \nd Olúwa\nd* àwọn ọmọ-ogun: àti gbogbo àwọn tí ń rú ẹbọ yóò wá, wọn ó sì mú ìkòkò díẹ̀, wọn ó sì bọ ẹran wọn nínú rẹ̀, ni ọjọ́ náà ni àwọn Kenaani kò ní sí mọ́ ni ilé \nd Olúwa\nd* àwọn ọmọ-ogun.
