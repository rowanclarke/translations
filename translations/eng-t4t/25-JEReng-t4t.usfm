\v 1  \add One day\add* \w Yahweh|strong="H3068"\w* said \w to|strong="H1980"\w* \w me|strong="H5921"\w*, “\w Go|strong="H1980"\w* \w and|strong="H1980"\w* \w buy|strong="H7069"\w* \w a|strong="H3068"\w* \w linen|strong="H6593"\w* waistcloth. \w Put|strong="H7760"\w* \w it|strong="H7760"\w* \w on|strong="H5921"\w*, \w but|strong="H3808"\w* \w do|strong="H3068"\w* \w not|strong="H3808"\w* wash \w it|strong="H7760"\w*.”  
