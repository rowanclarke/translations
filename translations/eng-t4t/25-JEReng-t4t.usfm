\c 25  
\s1 A prediction about being exiled for 70 years  
\p
\v 1 \w After|strong="H5921"\w* \w Jehoiakim|strong="H3079"\w* \w had|strong="H1961"\w* \w been|strong="H1961"\w* ruling \w Judah|strong="H3063"\w* \w for|strong="H5921"\w* almost four \w years|strong="H8141"\w*, \w Yahweh|strong="H3068"\w* \w gave|strong="H1961"\w* \w me|strong="H5921"\w* \w this|strong="H1931"\w* \w message|strong="H1697"\w* \w for|strong="H5921"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w people|strong="H5971"\w* \w of|strong="H1121"\w* \w Judah|strong="H3063"\w*. \w It|strong="H1931"\w* \w was|strong="H1961"\w* \w during|strong="H1961"\w* \w the|strong="H3605"\w* \w year|strong="H8141"\w* \w that|strong="H5971"\w* \w King|strong="H4428"\w* \w Nebuchadnezzar|strong="H5019"\w* \w started|strong="H1961"\w* \w to|strong="H1961"\w* \w rule|strong="H4428"\w* \w in|strong="H8141"\w* Babylon.  
