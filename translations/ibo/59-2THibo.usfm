\id 2TH - Biblica® Open Igbo Contemporary Bible 2020 
\h 2 Ndị Tesalonaịka 
\toc1 2 Ndị Tesalonaịka 
\toc2 2 Ndị Tesalonaịka 
\toc3 2Te 
\mt1 2 Ndị Tesalonaịka 
\c 1  
\p  
\v 1 Pọl, na Saịlas, na Timoti dere akwụkwọ a, 
\b  
\p Na-edegara nzukọ dị nʼobodo Tesalonaịka nʼime Chineke Nna anyị, na nʼime Onyenwe anyị Jisọs Kraịst. 
\b  
\p  
\v 2 Ka amara na udo nke sitere na Chineke Nna anyị, na Onyenwe anyị Jisọs Kraịst dịrị unu. 
\b  
\s1 Inye ekele na ekpere 
\p  
\v 3 Ụmụnna, anyị aghaghị ikele Chineke ekele mgbe niile banyere unu. O kwesiri ka anyị mee otu a, nʼihi okwukwe unu na-abawanye. Ịhụnanya onye ọbụla nʼime unu nwere nʼebe ibe ya nọ na-abawanyekwa.  
\v 4 Nʼihi nke a, anyị na-eji unu na-anya isi nʼetiti nzukọ Chineke niile. Anyị na-akọrọ ha otu unu si jiri ntachiobi nọgidesie ike nʼime nsogbu niile dakwasịrị unu, na otu unu si nwee okwukwe dị ukwuu, ọ bụladị nʼetiti oke mkpagbu a na-akpagbu unu. 
\p  
\v 5 Ihe ndị a niile na-egosi na ikpe Chineke bụ nke ziri ezi, nke e ji eme unu ndị kwesiri alaeze Chineke, nke unu na-ata ahụhụ nʼihi ya.  
\v 6 Chineke bụ onye ezi omume nʼezie. Ọ ga-eji mkpagbu kwụghachi ndị na-akpagbu unu.  
\v 7 Ọ ga-enyekwa unu bụ ndị a na-akpagbu na anyị onwe anyị ezumike. Ọ ga-eme nke a mgbe a ga-eme ka Onyenwe anyị Jisọs ya na ndị mmụọ ozi si nʼeluigwe pụta ìhè.  
\v 8 Ọ ga-abịa nʼụdị ire ọkụ taa ndị ahụ na-amaghị Chineke ahụhụ na ndị jụrụ ịnabata oziọma nke Onyenwe anyị Jisọs Kraịst.  
\v 9 Ndị a ga-ata ahụhụ mbibi ruo ebighị ebi, ebe ha na-agaghị ahụ ihu Onyenwe anyị na ebube nke ike ya,  
\v 10 nʼụbọchị ahụ ọ ga-abịa ịnara ịja mma na otuto, nʼime ndị nsọ ya, ya na ka ọ bụrụ ihe ịtụnanya nʼebe ndị kweerenụ nọ, nʼihi na unu kwenyere ama nke oziọma ahụ anyị gbaara unu. 
\p  
\v 11 Nʼihi nke a, anyị na-anọgide nʼekpere nʼihi unu, na-arịọ ka Chineke gụọ unu dịka ndị kwesiri ọkpụkpọ ọ kpọrọ unu, na-arịọkwa ka o site nʼike ya mee ka unu mezuo ebumnobi nke ihe dị mma, na ezi ọrụ niile nke okwukwe.  
\v 12 Ka e nye aha Onyenwe anyị Jisọs otuto nʼime unu, unu onwe unu nʼime ya kwa, dị ka amara nke Chineke anyị na nke Onyenwe anyị Jisọs Kraịst si dị. 
\c 2  
\s1 Onye mmebi iwu ahụ 
\p  
\v 1 Ma ihe banyere ọbịbịa Onyenwe anyị Jisọs Kraịst, na nzukọ anyị na ya ga-ezukọta, anyị na-adụsị unu ọdụ ike ụmụnna.  
\v 2 Ka unu ghara ịma jijiji maọbụ ịtụ egwu nʼuche unu nʼihi amụma, maọbụ okwu maọbụ akwụkwọ ozi e dere dị ka o sitere nʼaka anyị, nke na-asị nʼụbọchị Onyenwe anyị eruola.  
\v 3 Unu ekwela ka onye ọbụla duhie unu nʼụzọ ọbụla, nʼihi na ụbọchị ahụ agaghị abịa tutu ruo mgbe oke inupu isi ga-adị, na mgbe a ga-ekpughe onye mmebi iwu ahụ nke a kara akara ịla nʼiyi.  
\v 4 Onye mmebi iwu ahụ ga-ebuli onwe ya elu megide ihe niile a na-akpọ chi maọbụ nke a na-efe ofufe, nke ga-eme ka o dozie onwe ya nʼụlọnsọ Chineke, na-ekwupụta na ya bụ Chineke. 
\p  
\v 5 Unu echetaghị ihe m gwara unu nʼoge mụ na unu nọ banyere ya?  
\v 6 Ma ugbu a, unu maara na o nwere onye na-egbochi ya ka ọ hapụ ịpụta ihe. Nʼihi na mgbe ọ ga-apụta bụ mgbe oge ya ruru.  
\v 7 Ma ọrụ nzuzo nke mmebi iwu ebidolarị ugbu a, ma onye ahụ na-egbochi ya ịbabiga ụba oke ga-anọgide na-eme otu a tutu ruo mgbe oge e wezugara ya.  
\v 8 Mgbe ahụ, a ga-eme ka onye mmebi iwu ahụ pụta ìhè, bụ onye Onyenwe anyị Jisọs ga-eji ume ọ ga-esi nʼọnụ ya kupụta laa nʼiyi, ma mee ka ọ ghara ịdịkwa ọzọ site nʼọbịbịa ya.  
\v 9 Ọbịbịa onye mmebi iwu ahụ ga-abụ dị ka ọrụ ekwensu si dị, site nʼike ịrụ ọrụ ebube aghụghọ na ihe ịrịbama dị iche iche, na ọrụ ịtụnanya aghụghọ dị iche iche nke ụgha.  
\v 10 Ya na ụdị ọrụ ọjọọ dị iche iche nke ọ ga-eji duhie ndị ahụ na-ala nʼiyi. Ha ga-ala nʼiyi nʼihi na ha jụrụ ịhụ eziokwu nʼanya ma nwee nzọpụta.  
\v 11 Nʼihi nke a, Chineke ga-ahapụ ha ka e duhie ha, ka ha jiri obi ha niile nabata okwu ụgha ndị a.  
\v 12 Ihe nke a pụtara bụ na ndị niile na-ekweghị nʼeziokwu ahụ ma nwee mmasị nʼajọ omume ka a ga-ama ikpe. 
\s1 Guzoro chịm 
\p  
\v 13 Anyị kwesiri inye Chineke ekele mgbe niile nʼihi unu ụmụnna ndị Onyenwe anyị hụrụ nʼanya. Nʼihi na Chineke esitelarị na mmalite họpụta unu ka unu bụrụ ndị a zọpụtara site nʼọrụ ido nsọ nke Mmụọ Nsọ na site nʼokwukwe unu nʼeziokwu ahụ.  
\v 14 Nʼihi nke a, ọ kpọrọ unu site nʼoziọma anyị ka unu nweta otuto nke Onyenwe anyị Jisọs Kraịst. 
\p  
\v 15 Ya mere, ụmụnna, nọgidenụ nʼozizi ahụ anyị mere ka unu mụta site nʼozizi anyị ziri unu, maọbụ na akwụkwọ anyị deere unu. 
\p  
\v 16 Ka Onyenwe anyị Jisọs Kraịst nʼonwe ya, na Chineke Nna anyị, onye hụrụ anyị nʼanya, site nʼamara ya nye anyị agbamume dị ebighị ebi na ezi olileanya,  
\v 17 gbaa obi unu ume, ma mee ka unu guzosie ike nʼịrụ ọrụ na ikwukwa ihe niile dị mma. 
\c 3  
\s1 Arịrịọ ekpere 
\p  
\v 1 Nʼikpeazụ, ụmụnna, na-ekperenụ anyị ekpere ka ozi Onyenwe anyị gaa nʼihu na-agbasa ruo ebe niile ma bụrụ ihe a na-asọpụrụ, dị ka ọ gbasara nʼetiti unu.  
\v 2 Ka e nwee ike napụta anyị nʼaka ndị ajọ mmadụ, nʼihi na ọ bụghị mmadụ niile nwere okwukwe.  
\v 3 Ma Onyenwe anyị kwesiri ntụkwasị obi, ọ ga-echebe unu ma gbaakwa unu ume ka unu hapụ ịdaba nʼaka ajọ onye ahụ.  
\v 4 Anyị nwere nchekwube nʼime Onyenwe anyị na unu na-eme ma ga-anọgidekwa na-eme ihe niile anyị nyere unu nʼiwu.  
\v 5 Ka Onyenwe anyị duzie obi unu ịghọta ịhụnanya Chineke ya na ụdị ntachiobi Kraịst nwere. 
\s1 Ịdọ aka na ntị banyere ịnọ nkịtị 
\p  
\v 6 Ụmụnna, nke a bụ iwu anyị na-enye unu site nʼaha Onyenwe anyị Jisọs Kraịst. Ka unu zere onye ọbụla kpọrọ onwe ya onye kwere ekwe nʼime unu na-ebi ndụ umengwụ na onye na-adịghị eso ozizi nke unu natara nʼaka anyị.  
\v 7 Nʼihi na unu maara nke ọma nʼime onwe unu na unu kwesiri ịgbaso omume anyị. O nweghị mgbe ọbụla unu hụrụ anyị ka anyị na-agagharị hapụ ọrụ anyị kwesiri ịrụ.  
\v 8 O nweghị onye ọbụla anyị riri nri ya nke anyị na-ebughị ụzọ kwụọ ya ụgwọ. Kama anyị rụsịrị ọrụ ike, dọgbukwaa onwe anyị nʼọrụ ehihie na abalị, ka anyị ghara ịbụ ibu arọ nye onye ọbụla.  
\v 9 Ọ bụghị na anyị enweghị ikike ịnara unu ihe oriri, kama ọ bụ ka anyị kuziere unu site nʼomume anyị ihe unu ga na-eṅomi.  
\v 10 Ọ bụladị mgbe anyị na unu nọ, anyị nyere unu iwu a sị, “Onye ọbụla na-agaghị ọrụ ya erila nri.” 
\p  
\v 11 Ma anyị anụla na ụfọdụ nʼetiti unu na-anọ nkịtị na-arụghị ọrụ ọbụla, kama ndị dị otu a na-agagharị, na-etinye anya nʼihe na-agbasaghị ha. Ha anaghị arụ ọrụ ọbụla.  
\v 12 Anyị na-enye ndị a iwu, na-adụsịkwa ha ọdụ ike site nʼaha Onyenwe anyị Jisọs Kraịst, si ha wetuo obi ha ala rụsie ọrụ ha ike. Ka ha riekwa nri ha ji aka ha rụpụta.  
\v 13 Otu ọ dị ụmụnna, unu ekwela ka ike ịrụ ọrụ ọma gwụ unu. 
\p  
\v 14 Ma ọ bụrụ na ndị ọbụla adịghị erube isi nye ihe anyị kwuru nʼime akwụkwọ ozi a, hụbanụ ndị dị otu a ama ma kwụsịkwa iso ha nwekọ ihe ọbụla, ka ihere mekwa ha.  
\v 15 Nʼagbanyeghị nke a, unu agụkwala ha dị ka ndị iro unu, kama nyenụ ha ndụmọdụ dị ka ụmụnna. 
\b  
\s1 Ekele ikpeazụ 
\p  
\v 16 Ugbu a, ka Onyenwe anyị, onye udo na-esi nʼaka ya abịa tụkwasịrị unu udo ya mgbe niile, nʼime ọnọdụ ọbụla unu nọ nʼime ya. Onyenwe anyị nọnyekwara unu. 
\b  
\p  
\v 17 Mụ onwe m bụ Pọl ji aka m depụta ekele a, nke m na-ekele unu niile. Nke a bụ ihe e ji arịba akwụkwọ niile m dere ama. Otu a ka m si ede ihe. 
\b  
\p  
\v 18 Ka amara Onyenwe anyị Jisọs Kraịst dịnyere unu niile.