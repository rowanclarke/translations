\v 4 \w I|strong="H6440"\w* want \w him|strong="H6440"\w* \w to|strong="H7971"\w* know \w that|strong="H4397"\w* \w I|strong="H6440"\w* \w respect|strong="H6440"\w* \w him|strong="H6440"\w*, just \w like|strong="H6440"\w* \w a|strong="H3068"\w* work-man respects \w his|strong="H7971"\w* boss. Tell \w Esau|strong="H6215"\w* \w that|strong="H4397"\w* \w I|strong="H6440"\w* said, ‘\w I|strong="H6440"\w* \w went|strong="H3290"\w* \w and|strong="H7971"\w* stayed \w with|strong="H6440"\w* \w our|strong="H7971"\w* uncle Laban \w for|strong="H6440"\w* \w a|strong="H3068"\w* \w long|strong="H7971"\w* \w time|strong="H6440"\w*, \w and|strong="H7971"\w* \w now|strong="H7971"\w* \w I|strong="H6440"\w*’m coming \w back|strong="H8165"\w*.  
\v 5 \w I|strong="H5704"\w* \w have|strong="H5650"\w* cows, \w and|strong="H5650"\w* bulls, \w and|strong="H5650"\w* donkeys, \w and|strong="H5650"\w* sheep, \w and|strong="H5650"\w* goats, \w and|strong="H5650"\w* \w I|strong="H5704"\w* \w have|strong="H5650"\w* \w men|strong="H5650"\w* \w and|strong="H5650"\w* women \w that|strong="H5704"\w* work \w for|strong="H5704"\w* \w me|strong="H5973"\w*. \w I|strong="H5704"\w* \w sent|strong="H6680"\w* some \w men|strong="H5650"\w* \w to|strong="H5704"\w* say these \w things|strong="H5973"\w* \w to|strong="H5704"\w* \w you|strong="H6680"\w*, \w and|strong="H5650"\w* \w I|strong="H5704"\w* hope \w that|strong="H5704"\w* \w you|strong="H6680"\w* \w will|strong="H5650"\w* \w be|strong="H5650"\w* happy \w with|strong="H5973"\w* \w me|strong="H5973"\w*.’” \w So|strong="H3541"\w* \w those|strong="H5973"\w* \w men|strong="H5650"\w* \w went|strong="H3290"\w* \w and|strong="H5650"\w* \w told|strong="H6680"\w* \w Esau|strong="H6215"\w* \w those|strong="H5973"\w* \w things|strong="H5973"\w*.   
\p
