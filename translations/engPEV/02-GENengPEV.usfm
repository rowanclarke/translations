\p
\v 9 \w While|strong="H5750"\w* Jacob \w and|strong="H6629"\w* \w the|strong="H3588"\w* work-men \w were|strong="H6629"\w* \w still|strong="H5750"\w* \w talking|strong="H1696"\w* \w to|strong="H1696"\w* each \w other|strong="H5750"\w*, Laban’s daughter \w Rachel|strong="H7354"\w* came \w to|strong="H1696"\w* \w the|strong="H3588"\w* water-hole \w with|strong="H5973"\w* some \w sheep|strong="H6629"\w*. \w Those|strong="H1931"\w* \w sheep|strong="H6629"\w* belonged \w to|strong="H1696"\w* \w Rachel|strong="H7354"\w*’s father Laban, \w and|strong="H6629"\w* \w Rachel|strong="H7354"\w* looked \w after|strong="H3588"\w* \w those|strong="H1931"\w* \w sheep|strong="H6629"\w* \w for|strong="H3588"\w* \w her|strong="H1931"\w* father.   
\p
\v 10 \w As|strong="H1961"\w* soon \w as|strong="H1961"\w* \w Jacob|strong="H3290"\w* \w saw|strong="H7200"\w* \w Rachel|strong="H7354"\w* \w and|strong="H6629"\w* \w those|strong="H5921"\w* \w sheep|strong="H6629"\w*, \w he|strong="H5921"\w* felt really happy, \w because|strong="H5921"\w* \w Rachel|strong="H7354"\w* \w was|strong="H1961"\w* \w his|strong="H5921"\w* relative. \w Her|strong="H5921"\w* father \w Laban|strong="H3837"\w* \w was|strong="H1961"\w* \w the|strong="H5921"\w* brother \w of|strong="H1323"\w* \w Jacob|strong="H3290"\w*’s mother. \w So|strong="H1961"\w* \w Jacob|strong="H3290"\w* quickly \w went|strong="H3290"\w* \w to|strong="H1961"\w* \w the|strong="H5921"\w* water-hole, \w and|strong="H6629"\w* \w he|strong="H5921"\w* moved \w that|strong="H7200"\w* big stone \w that|strong="H7200"\w* \w was|strong="H1961"\w* \w on|strong="H5921"\w* \w top|strong="H6310"\w* \w of|strong="H1323"\w* \w the|strong="H5921"\w* water-hole, \w and|strong="H6629"\w* \w he|strong="H5921"\w* got \w water|strong="H8248"\w* \w for|strong="H5921"\w* \w Laban|strong="H3837"\w*’s \w sheep|strong="H6629"\w* \w to|strong="H1961"\w* \w drink|strong="H8248"\w*.  
