\id 1JN
\h Ioane I.
\toc1 Ioane I.
\toc2 Ioane I.
\toc3 Ioane I.
\mt1 Ioane I.
\c 1
\s1 O KA EPISETOLE HOOLAHA MUA A
\q1 
\v 1 O Ka mea mai kinohi mai, ka mea a makou i lohe ai, ka mea a ko makou mau maka i ike ai, ka mea a makou i manao ai, a i lawelawe ai no hoi me ko makou mau lima, no ka Logou o ke ola:
\q1 
\v 2 Ua hoikeia mai ke ola, a ua ike makou, a ke hoike aku nei no hoi makou, me ka hoakaka aku ia oukou ia ola mau loa; aia no ia me ka Makua, a ua hoikeia mai no ia makou;
\q1 
\v 3 O ua mea la a makou i ike io ai a i lohe io ai no hoi, oia ka makou e hai aku nei ia oukou, i lilo oukou i poe hoaaloha me makou; a o ko makou aloha pu ana. aia no ia me ka Makua, a me kana Keiki o Iesu Kristo.
\q1 
\v 4 Ke palapala aku nei makou i keia mau mea ia oukou, i mahuahua ai ko oukou olioli.
\b
\q1 
\v 5 Eia mai no ka olelo a makou i lohe ai ia ia, a ke hai aku nei no hoi makou ia oukou; he malamalama ke Akua, aohe pouli iki iloko ona.
\q1 
\v 6 Ina e olelo kakou, ua aloha pu kakou me ia, a hele hoi ma ka pouli, ua wahahee kakou, aole kakou i haua ma ka oiaio.
\q1 
\v 7 Aka, ina i hele kakou ma ka malamalama e like me ia e noho la ma ka malamalama, alaila, ua aloha pu kakou i kekahi i kekahi; a na ke koko o Iesu Kristo o kana Keiki, e huikala mai ia kakou i ko kakou hewa a pau.
\q1 
\v 8 Ina e olelo kakou, aole o kakou hewa, ua kuhihewa kakou, aole he oiaio iloko o kakou.
\q1 
\v 9 Ina e hai aku kakou i ko kakou hewa, he oiaio mai no ke Akua a he lokomaikai i ke kala mai i ko kakou hewa, a i ka hoomaemae mai ia kakou mai na mea pouo ole a pau.
\q1 
\v 10 Ina e olelo kakou, aole kakou i hana hewa, na hoolilo kakou ia ia i mea wahahee, aole hoi kana olelo iloko o kakou.
\c 2
\b
\q1 
\v 1 E A'U poe keiki aloha, ke palapala aku nei au i keia mau mea ia oukou, i ole ai oukou e hana hewa: aka, ina e lawehala kekahi, aia no ko kakou mea nana e uwao me ka Makua, o Iesu Kristo ka mea pono.
\q1 
\v 2 Oia no ke kalahala no ko kakou hewa; aole nae no ko kakou wale no, aka, uo ko ke ao nei a pau.
\q1 
\v 3 Eia ka mea e maopopo ai ia kakou ko kakou ike ana ia ia, ina e malama aku ana kakou i kana mau kauoha.
\q1 
\v 4 O ka mea e olelo aua, ua ike no au ia ia, a malama ole oia i kana mau kauoha, he mea wahahee ia, aole he oiaio iloko ona.
\q1 
\v 5 Aka, o ka mea e malama ana i kana olelo, ua hemolele ke aloha o ke Akua iloko ona, Ma ia mea o ike ai kakou, eia no kakou iloko ona.
\q1 
\v 6 O ka mea e olelo ana, ke noho nei oia iloko ona, he mea pono nona ke hele e like me ko ia la hele ana.
\b
\q1 
\v 7 E na hoahanau, aole he kanawai hou ka'u e palapala aku nei ia oukou, aka, o ke kanawai kahiko ka mea i loaa ia oukou mai kinohi mai: o ke kanawai kahiko, oia ka olelo a oukou i lohe ai mai kinohi mai.
\q1 
\v 8 He kanawai hou kekahi a'u e palapala aku nei ia oukou, he oiaio no ia iloko ona, a iloko o oukou no hoi; no ka mea, ua hala aku la ka pouli, ano la ua hiki mai nei ka malamalama oiaio.
\q1 
\v 9 O ka mea e olelo ana, ma ka malamalama ia, a ua inaina aku ia i kona hoahanau, aia no ia iloko o ka pouli a hiki i keia manawa.
\q1 
\v 10 O ka mea e aloha aku ana i kona hoahanau, ke noho io nei no ia i ka malamalama, aohe mea hoohihia iloko ona:
\q1 
\v 11 Aka, o ka mea e inaina aku ana i kona hoahanau, aia no ia maloko o ka pouli, a ke hele nei no ia ma ka pouli, aole ia i ike i kona wahi e hele ai, no ka mea, ua paa kona mau maka i ka pouli.
\b
\q1 
\v 12 E na pokii, ke palapala aku nei au ia oukou, no ka mea, ua pau ko oukou hewa i ke kalaia no kona inoa.
\q1 
\v 13 E na makuakane, ke palapala aku nei au ia oukou, no ka mea, ua ike aku oukou ia ia mai kinohi mai. Ke palapala aku nei au ia oukou, e na kanaka ui, no ka mea, ua lanakila oukou maluna o ka hewa E na keiki, ke palapala aku nei au ia oukou, no ka mea, ua ike oukou i ka Makua,
\q1 
\v 14 Ua palapala aku au ia oukou, e na makuakane, no ka mea, ua ike oukou ia ia mai kinohi mai. E na kanaka ui, ua palapala aku au ia oukou, no ka mea, na ikaika no oukou, ke noho la no ka olelo a ke Akua iloko o oukou, a ua lanakila no hoi oukou maluna o ka hewa.
\q1 
\v 15 Mai makemake aku i ko ke ao nei, aole hoi i na mea o keia ao. Ina e makemake aku ana kekahi i ko ke ao nei, aole iloko ona ka makemake i ka Makua;
\q1 
\v 16 No ka mea, o na mea a pau ma ko keia ao, o ke kuko o ke kino, a me ke kuko o ka maka, a me ka hoohanohano o keia ola ana, aole ia no ka Makua mai, aka, no ke ao nei no ia.
\q1 
\v 17 A o ke ao nei, ke panee aku nei a me na kuko ona: aka, o ka mea e hana ana i ko ke Akua makemake, e mau loa ana no ia.
\b
\q1 
\v 18 E na kamalii uuku, eia ka hope o ka manawa. Me ko oukou lohe ana i ka hiki ana mai o Anikristo, pela no e noho nei na Anikristo he nui; no ia mea, ua ike no kakou o ka hope keia o ka mauawa.
\q1 
\v 19 Hele aku lakou mai o kakou aku, aka, aole loa lakou no kakou; no ka mea, ina lakou no kakou, ina ua noho lakou me kakou: aka, hele lakou i maopopo ai, aole lakou a pau no kakou.
\q1 
\v 20 Ua poniia oukou e ka Mea Hemolele, a ua ike oukou i na mea a pau.
\q1 
\v 21 Aole au i palapala aku ia oukou no ko oukou ike ole ana i ka oiaio, aka, no ko oukou ike ana, a no ia hoi, aohe mea wahahee no ka oiaio mai.
\q1 
\v 22 Owai la ka mea wahahee ke ole ka mea e hoole ana, aole o Iesu ka Mesia? O ka mea e hoole ana i ka Makua a me ke Keiki, oia no ke Anikristo.
\q1 
\v 23 O na mea a pau e hoole aku ana i ke Keiki, aole no lakou ka Makua; aka, o ka mea e hooiaio ana i ke Keiki, nona no ka Makua.
\q1 
\v 24 Ka mea a oukou i lohe ai mai kinohi mai, o hooraau ia mea iloko o oukou: ina e noho mau iloko o oukou ka mea a oukou i lohe ai mai kinohi mai, alaila e noho oukou iloko o ke Keiki a iloko o ka Makua.
\q1 
\v 25 Eia ka olelo ana i olelo mua mai ai ia kakou, o ke ola mau loa.
\q1 
\v 26 Ua palapala aku au ia oukou i keia mau mea no ka poe e hoowalewale ana ia oukou.
\q1 
\v 27 Ke noho nei no iloko o oukou ka poniia mai o oukou e ia, aole hoi a oukou mea hemahema e ao aku ai kekahi ia oukou: aka, me ia poni ana i ao mai ai ia oukou i na mea a pau, a oia ka mea oiaio, aole wahahee ia; e like me kana ao ana mai ia oukou, pela e noho aku ai oukou iloko ona.
\q1 
\v 28 Ano la, e na keiki aloha, e noho oukou iloko ona; i wiwo ole ai kakou i kona wa e ikea mai ai, i ole ai kakou e hilahila imua ona, i kona hele ana mai.
\q1 
\v 29 Ina i ike oukou, he pono oia, ke ike nei no hoi oukou, ua hoohanauia mai e ia na mea a pau e hana ana i ka pono.
\c 3
\b
\q1 
\v 1 EIA hoi, manomano ke aloha a ka Makua i haawi mai ai ia kakou, i kapaia mai ai kakou he poe keiki na ke Akua; no ia mea, aole i ike mai ko ke ao nei ia kakou, no ka mea, aole lakou i ike ia ia.
\q1 
\v 2 E na punahele, ano la, he poe keiki kakou na ke Akua, aka, o ko kakou ano mahope aku, aole ikea ia; aka, ke ike nei kakou, a i kona wa e ikea mai ai, e like auanei kakou me ia: no ka mea, e ike kakou ia ia ma kona ano maoli.
\q1 
\v 3 O ka mea i loaa ia ia keia manaolana ma ona la, oia ke hoomaemae ia ia iho e like me ko ia la maemae ana.
\q1 
\v 4 O ka mea e hana aku ana i ka hewa, oia ka mea e haihai ana i ke kanawai; a o ka hewa, oia no ke ku e ana i ke kanawai.
\q1 
\v 5 Ua ike no oukou, ua hoikea mai oia, i lawe ae ia i ko kakou hewa: aole hewa iloko ona.
\q1 
\v 6 O ka mea e noho ana iloko ona, aole ia e hana hewa. O ka mea e hana i ka hewa, aole ia i nana ae ia ia, aole no hoi i ike ia ia.
\q1 
\v 7 E na pokii, e malama i hoopunipuni ole kekahi ia oukou: o ka mea i hana i ka pono, oia ka i pono, e like me ko ia la pono ana.
\q1 
\v 8 O ka mea e hana ana i ka hewa, no ka diabolo no ia; no ka mea, ua hana hewa mau ka diabolo, mai kinohi mai. No ia mea, ua hoikea mai ke Keiki a ke Akua, i hokae aku ai oia i ka ka diabolo hana ana.
\q1 
\v 9 O ka mea i hoohanauia mai e ke Akua, aole ia e hana hewa; no ka mea, ke noho mau nei kona hua iloko ona; aole e hiki ia ia ke hana hewa aku, no ka mea, ua hoohanauia mai no ia e ke Akua.
\q1 
\v 10 Malaila no i maopopo ai nakeiki a ke Akua, a me ka poe keiki na ka diabolo. O ka mea hana ole ma ka pono, aole ia na ke Akua, aole hoi ka mea aloha ole i kona hoahanau.
\q1 
\v 11 No ka mea, eia no ka olelo a oukou i lohe ai mai kinohi mai, e aloha aku kakou i kekahi i kekahi.
\q1 
\v 12 Aole like me Kaina, na ka mea ino no oia, a pepehi iho la ia i kona kaikaina a make. No ke aha la kela i pepehi ai ia ia? no ka mea, ua hewa kana hana iho, a na pono hoi ka kona kaikaina.
\b
\q1 
\v 13 Mai kahaha oukou, e na hoahanau o'u, ke hoomaau mai ko ke ao nei ia oukou.
\q1 
\v 14 Ke ike nei kakou, ua lilo ae kakou mai ka make ae i ke ola, no ka mea, ke aloha aku nei kakou i na hoahanau, O ka mea e aloha ole ana i kona hoahauau, ke noho nei oia ma ka make.
\q1 
\v 15 O ka mea e hoomaau ana i kona hoahanau, he mea pepehi kanaka ia: ua ike no oukou o ka mea pepehi kanaka, aole ke ola mau loa e noho ana iloko ona.
\q1 
\v 16 No ia mea, ua ike kakou i ke aloha, no ka mea, ua waiho iho la oia i kona ola no kakou; a he mea pono no hoi ia kakou, ke waiho ae i ko kakou ola no ka poe hoahanau.
\q1 
\v 17 O ka mea i loaa ia ia ka waiwai o keia ao, a ike ae la i ka nele o kona hoahanau, a papani ae i kona naau ia ia, pehea la ke aloha o ke Akua e noho ai iloko ona?
\q1 
\v 18 E na pokii o'u, mai aloha kakou ma ka waha, aole hoi ma ke alelo wale no; aka, ma ka hana ana a me ka oiaio.
\q1 
\v 19 Ma keia mea e ike ai kakou, no ka oiaio kakou, a e hooiaio aku kakou i ko kakou mau naau imua ona.
\q1 
\v 20 No ka mea, ina e hoohewa mai ko kakou naau ia kakou iho, ua oi aku ke Akua i ko kakou naau, a ua ike oia i na mea a pau.
\q1 
\v 21 E na punahele, ina e hoohewa ole mai ko kakou naau ia kakou iho, alaila ua loaa ia kakou ka wiwo ole imua o ke Akua.
\q1 
\v 22 O ka mea a kakou e noi aku ai, e loaa no ia kakou nona mai, no ka mea, ke malama nei kakou i kana mau kauoha, a ke hana nei no hoi kakou imua ona i kona mea e makemake ai.
\q1 
\v 23 Eia no kana kauoha mai, e manaoio aku kakou i ka inoa o kana Keiki o Iesu Kristo, a e aloha kekahi i kekahi, e like me ke kauoha ana i haawi mai ai ia kakou.
\q1 
\v 24 O ka mea e malama aku ana i kana mau kauoha, ua noho no ia iloko ona; a ua noho mai no hoi kela iloko ona. Nolaila hoi ke ike nei kakou, ke noho mai nei oia iloko o kakou, ma ka Uhane ana i haawi mai ai no kakou.
\c 4
\b
\q1 
\v 1 E NA punahele, mai manaoio aku oukou i na uhane a pau, aka, e hoao aku i na uhane, no ke Akua mai paha, aole paha: no ka mea, ua nui no na kaula wahahee i hele aku iwaena o ke ao nei.
\q1 
\v 2 Penei oukou e ike ai i ka Uhane o ke Akua: O kela uhane o keia uhane e hooiaio aku ana, ua hiki mai nei o Iesu Kristo ma ke kino, no ke Akua ia.
\q1 
\v 3 O kela uhane o keia uhane e hooiaio ole ana, ua hiki mai o Iesu Kristo ma ke kino, aole no ke Akua kela: a o ko Anikristo keia a oukou i lohe ai e hele mai ana; a eia mai nei iloko o ke ao nei i keia manawa.
\q1 
\v 4 No ke Akua oukou, e na pokii, a ua lanakila oukou maluna o lakou; no ka mea, ua oi aku ka mea iloko o oukou i ka mea iloko o ke ao nei.
\q1 
\v 5 No ke ao nei lakou; nolaila i olelo ai lakou i na mea o ke ao nei, ke lohe nei hoi ko ke ao nei ia lakou.
\q1 
\v 6 No ke Akua kakou; o ka mea i ike i ke Akua, oia ke lohe mai ia makou; o ka mea, aole no ke Akua, aole ia i lohe mai ia makou. Ma ia mea, ua ike no kakou i ka Uhane o ka oiaio, a me ka uhane o ka wahahee.
\b
\q1 
\v 7 E na punahele, e aloha kakou i kekahi i kekahi: no ka mea, no ke Akua mai ke aloha; o ka mea e aloha aku ana ua hoohanauia mai ia e ke Akua, a ua ike no oia i ke Akua.
\q1 
\v 8 O ka mea e aloha ole ana, aole ia i ike aku i ke Akua; no ka mea, he aloha ke Akua.
\q1 
\v 9 Ma ia mea, ua hoikeia mai ke aloha o ke Akua ia kakou, no ka mea, hoouna mai la ke Akua i kana Keiki hanaukahi i ke ao nei, i ola'i kakou ia ia.
\q1 
\v 10 Eia no ke aloha, aole nae kakou i aloha aku i ke Akua, aka, ua aloha mai kela ia kakou nei, a ua hoouna mai hoi oia i kana Keiki i kalahala no ko kakou hewa.
\q1 
\v 11 E na punahele, ina pela ko ke Akua aloha ana mai ia kakou, he pono ke aloha kakou i kekahi i kekahi.
\q1 
\v 12 Aole i ike aku kekahi i ke Akua; aka, ina e aloha aku kakou i kekahi i kekahi, ke noho mai nei no ke Akua iloko o kakou, a ua paa no hoi kona aloha iloko o kakou.
\q1 
\v 13 No ia mea, ke ike nei kakou, ua noho kakou iloko ona, a oia hoi iloko o kakou, no ka mea, ua haawi mai oia i kona Uhane no kakou.
\q1 
\v 14 A ua ike kakou a ke hoike aku nei no hoi, ua hoouna mai ka Makua i ke Keiki i mea e ola'i ko ke ao nei.
\q1 
\v 15 O ka mea e hooiaio ana ia Iesu o ke Keiki ia a ke Akua, ke noho nei ke Akua iloko ona, a oia no hoi iloko o ke Akua.
\q1 
\v 16 A ua ike kakou, a ua manaoio no hoi i ke aloha ana mai o ke Akua ia kakou. He aloha ke Akua; a o ka mea e noho ana iloko o ke aloha, ke noho nei oia iloko o ke Akua, a o ke Akua no hoi iloko ona.
\q1 
\v 17 No ia mea, ua paa ke aloha ia kakou, i wiwo ole kakou i ka la e hookolokolo ai; no ka mea, e like me ia ma keia ao, pela no kakou.
\q1 
\v 18 Aohe makau iloko o ke aloha; aka, e kipaku ana ke aloha oiaio i ka makau; no ka mea, he ehaeha ko ka makau: o ka mea makau, aole i hemolele ke aloha iloko ona.
\q1 
\v 19 Ke aloha aku nei kakou ia ia, no ka mea, ua aloha mua mai kela ia kakou.
\q1 
\v 20 Ina e olelo aku kekahi, Ke aloha aku nei au i ke Akua, a e hoomaau aku nae ia i kona hoahanau, he mea wahahee ia: no ka mea, o ka mea aloha ole i kona hoahanau ana i ike maka ai, pehea la e hiki ai ia ia ke aloha aku i ke Akua ana i ike maka ole ai?
\q1 
\v 21 Eia mai kana kauoha ia kakou, ina e aloha aku kekahi i ke Akua, e aloha aku no hoi oia i kona hoahanau.
\c 5
\b
\q1 
\v 1 O KA mea i manaoio o Iesu ka Mesia, na ke Akua ia i hoohanau mai: a o ka mea i aloha aku i ka mea nana i hoohanau mai, oia ke aloha aku i ka mea i hoohanauia mai e ia.
\q1 
\v 2 No ia mea, ke ike nei no kakou i ko kakou aloha ana i na keiki a ke Akua, ke aloha aku kakou i ke Akua me ka malama aku i kana mau kauoha.
\q1 
\v 3 No ka mea, eia no ke aloha o ke Akua, o ka malama aku i kana mau kauoha; aole hoi he mea luhi kana mau kauoha.
\q1 
\v 4 No ka mea, o ka mea a ke Akua i hoohanau mai, oia ke lanakila maluna o ke ao nei; eia ka mea e lanakila ai maluna o ke ao nei, o ko kakou manaoio ana.
\q1 
\v 5 Owai la ka mea e lanakila ana maluna o ko ke ao nei, ke ole ka mea i manaoio ia Iesu oia ke keiki a ke Akua?
\q1 
\v 6 O ka mea i hiki mai ma ka wai a me ke koko, o Iesu Kristo no ia; aole ma ka wai wale no, aka, ma ka wai a me ke koko: o ka Uhane ka mea e hoike mai, a he oiaio ka Uhane.
\q1 
\v 7 Ekolu mea nana e hoike mai iloko o ka lani, o ka Makua, o ka Logou, a me ka Uhane Hemolele; o keia mau mea ekolu, hookahi no ia.
\q1 
\v 8 A ekolu na mea nana e hoike mai ma ka honua, o ka uhane, o ka wai, a me ke koko; o keia mau mea ekolu, ua lilo i hookahi no.
\q1 
\v 9 Ina e manao kakou ua oiaio ka olelo hoike a kanaka, he oi loa aku no ka olelo hoike a ke Akua: eia no ka olelo hoike a ke Akua ana i olelo mai ai no kana Keiki.
\q1 
\v 10 O ka mea e manaoio ana i ke Keiki a ke Akua, aia no iloko ona ka hoike: o ka mea e manaoio ole i ke Akua, oia ke hoolilo ia ia i mea wahahee; no ka mea, aole i manaoio oia i ka olelo a ke Akua ana i olelo mai ai no kana Keiki.
\q1 
\v 11 Eia no ka olelo; ua haawi mai ke Akua i ke ola mau loa no kakou, a o ua ola la, aia no ia iloko o kana Keiki.
\q1 
\v 12 O ka mea i loaa ia ia ke Keiki he ola no kona; o ka mea i loaa ole ia ia ke Keiki a ke Akua, aole ona ola.
\b
\q1 
\v 13 Ua palapala aku au i keia mau mea ia oukou, i ka poe i manaoio i ka inoa o ke Keiki a ke Akua; i ike ai oukou, ua loaa ia oukou ke ola mau loa; a i manaoio ai oukou i ka inoa o ke Keiki a ke Akua.
\q1 
\v 14 Eia ka manaoio o kakou ia ia, ina e nonoi aku kakou i kahi mea e like me kona makemake, e hoolohe mai no oia ia kakou.
\q1 
\v 15 Ina i ike pono kakou, ua hoolohe mai oia ia kakou, i ka mea a kakou e nonoi aku ai, ke ike nei kakou, e loaa mai ka mea a kakou i nonoi aku ai ia ia.
\q1 
\v 16 Ina e ike kekahi i kona hoahanau, e hana ana i ka hewa ku ole i ka make, e pule aku ia, a e haawi mai oia ia ia i ke ola no na mea e hana ana i ka hewa aole i ku i ka make. He hewa no kekahi i ku i ka make; aole au e olelo aku e pule oia no ia mea.
\q1 
\v 17 O na mea pono ole a pau, he hewa wale no ia; aka, o kekahi hewa aole he mea ia e make ai.
\b
\q1 
\v 18 Ua ike no kakou, o ka mea i hoohanauia mai e ke Akua, aole e hana hewa ia: aka, o ka mea i hoohanauia mai e ke Akua, e malama ana oia ia ia iho, aole e hoopa ka mea hewa ia ia.
\q1 
\v 19 Ke ike nei kakou, no ke Akua kakou, a o ke ao nei a pau, ke moe nei ia iloko o ka hewa.
\q1 
\v 20 Ke ike nei kakou ua hiki mai nei ke Keiki a ke Akua, a ua haawi mai ia i ka noonoo ia kakou, i ike aku ai kakou i ka mea oiaio: a iloko o ka mea oiaio kakou, a iloko hoi o kana Keiki o Iesu Kristo. Oia no ke Akua oiaio, a me ke ola mau loa.
\q1 
\v 21 E na keiki aloha, e malama pono oukou ia oukou iho i na akua kii. Amene. 
