\id OBA - Gamo Full Bible final version 
\h Abdiyu Tinbite 
\toc1 Abdiyu Tinbite 
\toc2 Abdiyu Tinbite 
\toc3 Ab 
\mt1 Abdiyu Tinbite 
\imt1 Giddo Qofa 
\ip Hayssi guuththa maxaafazi beettiday Kirstoosi yelettanaappe kase 586 layththan Yerusalaamey laalettidaappe guye qonccen erettontta wodenna. He wode arshey mokkiza dugeha baggara diza Yuhudas adussa wodeesofe morkke gidida Eedoome asay Yerusalaame laaleteththan ufayettidi biitta oli oykkizayta maaddishe katamay haaro ubbaa bonqqees; Abdiyuy Eedoome asaa, hankko Isra7eele morkketara issi bolla mino qixaateynne xooneteththi gakkanayssa kaseti yootides. 
\iot Ha Maxaafay Oykkida Kumeththa Qofa 
\io1 Eedoome otoreteththinne qixaate \ior 1-9\ior* 
\io1 Eedoome menxe iitateth \ior 10-14\ior* 
\io1 Isra7eele xoono \ior 15-21\ior* 
\c 1  
\s1 Nabe Abdiyuy Beyida Ajjuuta 
\p  
\v 1 Abdiyuy be7ida ajjuuta; 
\q1 GODAY Eedoome gishshas 
\q2 Abdiyu kiittides; 
\q2 nu siyida Xoossa kiitay, 
\q2 «Tani Xoossay Eedoome bolla 
\q2 meto gaththana mala azazada 
\q2 deraa giddo as kiittadis» gees. 
\p  
\v 2 GODAY Eedoomes, 
\q1 «Ta nena dere asaappe laafisana; 
\q2 neni as ubbaan 
\q2 leqettidaaz gidana. 
\q1  
\v 3 Nenoo zaalla gomppan dizayssoo! 
\q2 Ne duussaso dhoqqasohon 
\q2 keexxidayssoo! 
\q2 ‹Ta dizasoppe tana ziqqaso 
\q2 woththana dandayzay oonee?› 
\q2 gizayssoo! 
\q2 Ne wozina otoroteththi 
\q2 nena baleththides. 
\q1  
\v 4 Ne golle kafo mala 
\q2 keeha pude piradhdhikokka, 
\q2 ne keeth xoolintte giddon 
\q2 keexxikokka 
\q2 ta nena heeppe 
\q2 haa duge woththana. 
\b  
\q1  
\v 5 «Kaysoti woykko bonqqizayti 
\q2 omars yiikko 
\q2 baas gidizayssa ekkeettes; 
\q2 Kath maxizayti piixe ashsheettes; 
\q2 gido attiin ne morkketi 
\q2 issinokka ashshettenna.\f + \fr 1:5 \fqa Piixe: \ft Piixe geetettizayssi amaraththo qaalan qaarmiya geetettees.\f* 
\q1  
\v 6 Intteno Eesawe zereththatoo! 
\q2 Intte keeth bonqqettides; 
\q2 hekko intte haaroy wuri 
\q2 bogettides. 
\q1  
\v 7 Nenara caaqettida laggeti 
\q2 nena baleththida; 
\q2 nena dosiza laggeti 
\q2 ne bolla morkketeththan dendida; 
\q2 ne kath midayti nees yarde 
\q2 woththidi nena 
\q2 ne dereppe gooddida; 
\q2 gido attiin istti hessa ne bolla 
\q2 ooththishin neni erabeekka. 
\b  
\q1  
\v 8 «He wode Eedoomeppe 
\q2 aadho eranchchata, 
\q2 Eesawe zumaappe 
\q2 erateth dhayssana. 
\q1  
\v 9 Eedoome deren de7iza 
\q2 asati wurikka hayqqana; 
\q2 Temaane oliza wolqqama 
\q2 olanchchati babbana. 
\s1 Xoossay Eedoome Qaxxayiza Gaaso 
\q1  
\v 10 «Ne isha Yaaqoobe zereththata 
\q2 neni gene wodhida gishshas 
\q2 ne kawuyada mernaas dhayana. 
\q1  
\v 11 Yerusalaame morkketi 
\q2 penge menththidi 
\q2 haarida miish ubbaa 
\q2 bonqqiza wode 
\q2 neni lanqera eqqa xeelladasa; 
\q2 hessa gishshas Yerusalaame bolla 
\q2 saama yeggi gishetti 
\q2 ekkidaytappe 
\q2 neni dummatakka. 
\q1  
\v 12 Yuhuda deren de7iza ishata bolla 
\q2 gakkida meton neni ufayettana 
\q2 koshshennashin ufayettadasa; 
\q2 qasse istta dhayoninne meton 
\q2 ufayettananne otorettana 
\q2 nees bessennashin otorettadasa. 
\q1  
\v 13 Ta derey dhayza gallas 
\q2 istta pengera 
\q2 neni gelana bessennashin; 
\q2 istti dhayza gallas metotishin 
\q2 neni ufayettana bessennashin; 
\q2 qasseka istti dhayza gallas 
\q2 ne istta haaro 
\q2 boggana nees bessennashin. 
\q1  
\v 14 Goodettidi qotettidayta wodhana 
\q2 ne oyddu oge bolla 
\q2 naagana bessennashin naagadasa; 
\q2 qasse attida asata 
\q2 meto gallas ne aaththa 
\q2 immanaas bessennashin 
\q2 immadasa.\x - \xo 1:14 \xt Isa 34:5-17; 63:1-6; Er 49:7-22; Hizi 25:12-14; 35:1-15; Amo 1:11-12; Mil 1:2-5\x* 
\b  
\q1  
\v 15 «Ta Xoossay asa ubbaa bolla 
\q2 pirdiza wodey gakkida gishshas 
\q2 Eedoomee! Ne ooththida 
\q2 iita oosoy 
\q2 ne bolla simmana; 
\q2 hessa gishshas ne ooso mala 
\q2 ne ekkana. 
\q1  
\v 16 Anjjettida ta zuma bolla 
\q2 intte waaye ushshu uyida mala 
\q2 intte yuushon diza hankko derey 
\q2 waaye ushshu uyana; 
\q2 uyidayti wurikka dhayana. 
\s1 Isra7eele Dere Xoono 
\q1  
\v 17 «Xiyoone zuman metoppe 
\q2 attanay daana; 
\q2 he zumayakka geesh gidana; 
\q2 Yaaqoobe derey bonqqettida 
\q2 ba haaro zaari ekkana. 
\q1  
\v 18 Yaaqoobe zereththati tama mala, 
\q2 Yooseefe zereththati 
\q2 tama laco mala gidiin 
\q2 Eesawe zereththati 
\q2 uttula mala gidana; 
\q2 tamay uttula miza mala 
\q2 Yaaqoobe zereththatinne 
\q2 Yooseefe zereththati 
\q2 Eesawe zereththata dhayssana. 
\b  
\q1  
\v 19 «Yuhuda dereppe 
\q2 dugeha baggara diza 
\q2 Negebe asay Eedoome 
\q2 biitta laattana; 
\q2 arshey wulliza baggara 
\q2 gadhan diza asati 
\q2 Filisxeeme, Efreemenne 
\q2 Samaariya biitta laattana; 
\q2 qasse Biniyaame zereththati 
\q2 Gala7aade biitta laattana. 
\q1  
\v 20 Beti bida Isra7eele asay 
\q2 Alahe geetettiza 
\q2 dereppe simmidi 
\q2 Kanaane biittafe 
\q2 Sirafta gakkanaas 
\q2 diza biitta laattana; 
\q2 bete biidi Sirafta deren diza 
\q2 Isra7eele asay 
\q2 Negeben diza katamata laattana. 
\q1  
\v 21 Attida Isra7eele asati 
\q2 Xiyoone zumaa bolla uttidi 
\q2 Eedoome dere ayssana; 
\q2 qasse kawoteththayka 
\q2 Xoossas gidana» gi yootides.