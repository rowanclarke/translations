\id DEU - Biblica® Open Kurdi Sorani Standard Version 
\h دواوتاری موسا 
\toc1 دواوتاری موسا 
\toc2 دواوتار 
\toc3 دواوتار 
\mt1 دواوتار 
\mt3 پێنجەم پەڕتووکی موسا 
\c 1  
\s1 فەرمانی بەڕێکەوتن لە حۆرێڤەوە 
\p  
\v 1 ئەمە ئەو وتانەیە کە موسا بە نەوەی ئیسرائیلی گوت، لە بەری ڕۆژهەڵاتی ڕووباری ئوردون، لە دەشتودەر لە عەراڤا\f + \fr 1:1 \ft شیوێک بوو لە دەریاچەی جەلیلەوە هەتا دەریای مردوو.‏\f*، بەرامبەر بە سوف لەنێوان پاران و تۆفەل و لاڤان و حەچێرۆت و دی زاهاڤ.  
\v 2 (لە حۆرێڤەوە لەسەر ڕێگای کێوی سێعیر بۆ قادێش بەرنێعە گەشتێکی یازدە ڕۆژەیە.) 
\p  
\v 3 لە یەکی مانگی یازدەی ساڵی چلەمین، موسا وەک هەموو ئەوەی یەزدان فەرمانی پێ کردبوو لەگەڵ نەوەی ئیسرائیلدا دوا.  
\v 4 ئەمە دوای ئەوە بوو کە سیحۆنی پاشای ئەمۆرییەکانی بەزاند کە لە حەشبۆن فەرمانڕەوا بوو، عۆگی پاشای باشانی شکاند کە لە عەشتارۆت فەرمانڕەوا بوو لە ئەدرەعی. 
\p  
\v 5 موسا لە بەری ڕۆژهەڵاتی ڕووباری ئوردون لە خاکی مۆئابدا دەستی بە ڕوونکردنەوەی ئەم فێرکردنە کرد و گوتی: 
\b  
\p  
\v 6 یەزدانی پەروەردگارمان لە حۆرێڤ پێی فەرمووین: «ئیتر بەسە! ماوەیەکی زۆرە لەم کێوە دانیشتوون،  
\v 7 ڕووتان وەربگێڕن و کۆچ بکەن و بڕۆن بۆ ناوچە شاخاوییەکانی ئەمۆرییەکان و دەرودراوسێکانی لە عەراڤا و چیا و زوورگەکانی\f + \fr 1:7 \ft زوورگ: لە تەپۆڵکە بەرزترە، هەروەک بەرزاییەکانی زوورگەزراو لە کوردستان.‏\f* خۆرئاوا و نەقەب و کەناری دەریای خاکی کەنعان و لوبنان هەتا ڕووباری گەورە، واتا ڕووباری فورات.  
\v 8 بڕوانن ئەوا خاکەکەم لەپێش داناون، بڕۆنە ناوی و دەست بەسەر ئەو خاکەدا بگرن کە یەزدان سوێندی بۆ ئیبراهیم و ئیسحاق و یاقوبی باوباپیرانتان خوارد کە بەوان و نەوەکانی دواتریان بدات.» 
\s1 دانانی دادوەرەکان 
\p  
\v 9 لەو کاتەدا لەگەڵتاندا دوام و گوتم، «ناتوانم بە تەنها بارتان هەڵبگرم،  
\v 10 یەزدانی پەروەردگارتان زۆری کردوون و ئەوەتا ئەمڕۆ ئێوە وەک ئەستێرەی ئاسمانن لە زۆریدا.  
\v 11 با یەزدانی پەروەردگاری باوباپیرانتان هەزار قات زیاترتان بکات و بەرەکەتدارتان بکات، هەروەک بەڵێنی پێدان،  
\v 12 بەڵام چۆن بە تەنها قورسایی و بارگرانی و ناکۆکییەکانتان هەڵبگرم؟  
\v 13 لە هۆزەکانتان پیاوی دانا و تێگەیشتوو و ڕێزدار هەڵبژێرن و لەسەرتان دایاندەنێم.» 
\p  
\v 14 ئێوەش وەڵامتان دامەوە و گوتتان، «ئەوەی گوتت باشە، با بیکەین.» 
\p  
\v 15 جا پیاوە گەورەکانی هۆزەکانی ئێوەم برد، پیاوانی دانا و ڕێزدار، ئەوانم کرد بە سەرۆک بەسەرتانەوە، کاربەدەست بەسەر هەزاران و سەدان و پەنجایان و دەیان و کوێخاکان بۆ هۆزەکانتان.  
\v 16 لەو کاتەشدا فەرمانم بە دادوەرەکانتان کرد و گوتم: «گوێ لە داوا و سکاڵای گەلەکەتان بگرن و بە ڕاستودروستی دادوەرییان بکەن، جا چ داواکە لەنێوان دوو ئیسرائیلیدا بێت یان لەنێوان ئیسرائیلییەک و نامۆیەکدا بێت.  
\v 17 لە دادوەریدا لایەنگری مەکەن، وەک یەک گوێ لە گەورە و بچووک بگرن، لە کەس مەترسن، دادوەریکردن هی خودایە و ئەو داوایانەی بۆتان زەحمەت بێت، ئەوا بۆ منی دەهێنن هەتا گوێم لێی بێت.»  
\v 18 لەو کاتەشدا فەرمانم پێکردن سەبارەت بە هەموو ئەو شتانەی کە دەیکەن. 
\s1 سیخوڕی خاکەکە 
\p  
\v 19 ئینجا لە حۆرێڤ کۆچمان کرد و ئەو چۆڵەوانییە مەزنە ترسناکەمان گرتەبەر کە لە ڕێگای ناوچە شاخاوییەکانی ئەمۆرییەکان بینیتان، هەروەک یەزدانی پەروەردگارمان فەرمانی پێ کردین و هاتین هەتا قادێش بەرنێعە.  
\v 20 پێم گوتن: «ئەوا هاتنە ناوچە شاخاوییەکانی ئەمۆرییەکان کە یەزدانی پەروەردگارمان پێمان دەدات.  
\v 21 بڕوانن! یەزدانی پەروەردگارتان خاکەکەی لەبەردەمتان داناوە، سەربکەون و دەستی بەسەردا بگرن، هەروەک یەزدانی پەروەردگاری باوباپیرانتان پێی فەرموون. مەترسن و ورە بەرمەدەن.» 
\p  
\v 22 جا هەمووتان هاتنە لای من و گوتتان: «با چەند پیاوێک لەپێش خۆمان بنێرین بۆ ئەوەی سیخوڕیەتی خاکەکەمان بۆ بکەن و هەواڵی ئەو ڕێگایەمان بۆ بهێننەوە کە پێیدا دەڕۆین و ئەو شارۆچکانەی بۆی دەچین.» 
\p  
\v 23 ئەو قسەیەم بەلاوە باش بوو، دوازدە پیاوم لێ دەرهێنان، لە هەر هۆزێک پیاوێک.  
\v 24 جا چوون و سەرکەوتنە سەر ناوچە شاخاوییەکە و هاتنە دۆڵی ئەشکۆل و سیخوڕییان کرد و  
\v 25 لەگەڵ دەستیان لە بەروبوومی خاکەکەیان بۆ هێناینەوە و هەواڵیان پێ ڕاگەیاندینەوە و گوتیان: «ئەو خاکەی یەزدانی پەروەردگارمان پێمان دەدات، باشە.» 
\s1 یاخیبوون لە قسەی یەزدان 
\p  
\v 26 بەڵام ئێوە ڕازی نەبوون سەربکەون و لە فەرمانی یەزدانی پەروەردگارتان یاخی بوون و  
\v 27 لەناو چادرەکانتان کەوتنە بۆڵەبۆڵ و گوتتان: «یەزدان ڕقی لە ئێمەیە لەبەر ئەوە ئێمەی لە خاکی میسر دەرهێنا هەتا بمانداتە دەستی ئەمۆرییەکان و لەناومان ببەن.  
\v 28 بۆ کوێ سەردەکەوین؟ براکانمان ورەیان ڕووخاندین و گوتیان: ”گەلێکی لە ئێمە مەزنتر و باڵا بەرزترن، شارەکان مەزن و شوورادارن هەتا ئاسمان، هەروەها لەوێ نەوەی عەناقمان\f + \fr 1:28 \ft نەوەی عەناق: خەڵکێکی زەبەلاح بوون و لەبەر توانای جەستەییان لە جەنگدا ترسناک بوون. بڕوانە \xt سەرژمێری 13‏:22‏\ft ‏.‏\f* بینی.“» 
\p  
\v 29 منیش پێم گوتن: «مەتۆقن و لێیان مەترسن.  
\v 30 یەزدانی پەروەردگارتان کە لەپێشتانەوە دەڕوات، ئەو بۆتان دەجەنگێت، بەگوێرەی هەموو ئەوەی لەپێش چاوتان لە میسر بۆی کردن،  
\v 31 هەروەها لە دەشتودەر کە بینیتان چۆن یەزدانی پەروەردگارتان هەڵیگرتن هەروەک باوک کوڕەکەی هەڵدەگرێت، لە هەموو ئەو ڕێگایەی گرتتانەبەر هەتا هاتنە ئەم شوێنە.» 
\p  
\v 32 لەگەڵ ئەوەشدا بڕواتان بە یەزدانی پەروەردگارتان نەبوو،  
\v 33 ئەوەی لە ڕێگا لەپێشتانەوە چوو هەتا شوێنێکتان بۆ بدۆزێتەوە بۆ چادرهەڵدانتان، لە شەودا لەناو ئاگردا بۆ ئەوەی ئەو ڕێگایەتان پیشان بدات کە پێیدا دەڕۆن و لە ڕۆژیشدا لەناو هەور. 
\p  
\v 34 جا یەزدان گوێی لە دەنگی قسەکانتان بوو، تووڕە بوو و سوێندی خوارد و فەرمووی:  
\v 35 «هیچ کەسێک لەم خەڵکە لەم نەوە بەدکارە ئەو خاکە چاکە نابینێت کە سوێندم خوارد بیدەم بە باوباپیرانتان،  
\v 36 تەنها کالێبی کوڕی یەفونە نەبێت، ئەو دەیبینێت و ئەو خاکە دەدەمە ئەو کە پێی لێناوە و دەیدەمە کوڕەکانیشی، چونکە بە هەموو دڵییەوە بەدوای یەزدان کەوت.» 
\p  
\v 37 بەهۆی ئێوەوە یەزدان لە منیش تووڕە بوو و فەرمووی: «تۆش بۆ ئەوێ ناچیت.  
\v 38 یەشوعی کوڕی نون کە لەبەردەمت وەستاوە دەچێتە ئەوێ، هانی بدە، چونکە خاکەکە وەک میرات بۆ ئیسرائیل دابەش دەکات،  
\v 39 بەڵام منداڵەکانتان کە گوتتان دەبنە دیل و کوڕەکانتان ئەوانەی هەتا ئەمڕۆ چاکە و خراپەیان نەزانیوە، ئەوان دەچنە ئەوێ و دەیدەمە ئەوان و ئەوان دەستی بەسەردا دەگرن،  
\v 40 بەڵام ئێوە ڕووتان وەربگێڕن و کۆچ بکەن بۆ دەشتودەر، لەسەر ڕێگای دەریای سوور\f + \fr 1:40 \ft عیبری \+tl سوف‏\+tl* واتا (زەل). دەشێت مەبەست لە دەریای سوف بێت، ئەو دەریایە بێت کە دەکەوێتە سەرووی باکووری کەنداوی سوێسی ئەمڕۆ، بەڵام لە دەقی یۆنانی پەیمانی نوێ هەر بە دەریای سوور نووسراوە. بڕوانە \xt عیبرانییەکان 11‏:29‏\ft ‏.‏\f*.» 
\p  
\v 41 جا وەڵامتان دایەوە و بە منتان گوت: «گوناهمان سەبارەت بە یەزدان کرد، ئێمە دەچین و دەجەنگین هەروەک یەزدانی پەروەردگارمان فەرمانی بە ئێمە کردووە.» بۆیە هەریەکەتان خۆی بە چەک و تفاقی جەنگ بەست، واتانزانی سەرکەوتن بۆ ناوچەی شاخاوییەکە ئاسانە! 
\p  
\v 42 بەڵام یەزدان پێی فەرمووم، «پێیان بڵێ: ”مەڕۆن و مەجەنگن، چونکە من لەگەڵتان نابم، نەوەک لەبەردەم دوژمنتان ببەزن.“» 
\p  
\v 43 جا قسەم لەگەڵ کردن و گوێتان نەگرت، بەڵکو لە فەرمانی یەزدان یاخی بوون و لووت بەرز بوون و بۆ ناوچەی شاخاوییەکە سەرکەوتن.  
\v 44 جا ئەمۆرییەکانی دانیشتووی ئەو شاخانە پەلاماریان دان و دەریانپەڕاندن، هەروەک پوورە هەنگی کێوی دەیکات و لە سێعیرەوە تێکیان شکاندن هەتا حۆرما.  
\v 45 ئینجا گەڕانەوە و گریان لەبەردەم یەزدان، بەڵام یەزدان گوێی لە دەنگتان نەگرت و گوێی بۆ شل نەکردن.  
\v 46 ماوەیەکی درێژ لە قادێش دانیشتن بە قەد ئەو ڕۆژانەی تێیدا مانەوە. 
\c 2  
\s1 سووڕانەوە لە دەشتودەر و چۆڵەوانیدا 
\p  
\v 1 ئینجا ڕوومان وەرگێڕا و کۆچمان کرد بۆ دەشتودەر لەسەر ڕێگای دەریای سوور، هەروەک یەزدان پێی گوتم، ڕۆژانێکی زۆر بە دەوری ناوچە شاخاوییەکانی سێعیردا سووڕاینەوە. 
\p  
\v 2 ئینجا یەزدان پێی فەرمووم:  
\v 3 «بەسە ئیتر بەدەوری ئەم ناوچە شاخاوییانە مەسووڕێنەوە، بەرەو باکوور ڕووتان وەربگێڕن و  
\v 4 فەرمان بە گەل بدە و بڵێ: ”ئێوە خەریکن بە سنووری نەوەی عیسۆی برایانتان تێدەپەڕن کە لە سێعیر نیشتەجێن و لێتان دەترسن، بەڵام زۆر ئاگاداربن،  
\v 5 هێرشیان مەکەنە سەر، چونکە شوێن پێیەکتان لە خاکی ئەوان نادەمێ، چونکە ناوچە شاخاوییەکانی سێعیرم بە میرات بە عیسۆ داوە.  
\v 6 خۆراکیان بە زیو لێ دەکڕن هەتا بیخۆن و ئاویان بە زیو لێ وەردەگرن هەتا بیخۆنەوە.“» 
\p  
\v 7 یەزدانی پەروەردگارتان بەرەکەتداری کردوون لە هەموو کارێکی دەستەکانتان، ڕێ و شوێنتان دەزانێت لەم چۆڵەوانییە مەزنە، ئەم چل ساڵە یەزدانی پەروەردگارتان لەگەڵتاندا بووە و لە هیچ شتێکتان کەم نەبووە. 
\p  
\v 8 ئینجا بەسەر نەوەی عیسۆی برایانمان تێپەڕین کە لە چیای سێعیر نیشتەجێن. ڕێگای عەراڤامان بەجێهێشت کە لە ئێلەت و عەچیۆن گەڤەرەوە دێت، ئینجا سووڕاینەوە و بە ڕێگای چۆڵەوانی مۆئابدا ڕۆیشتین. 
\p  
\v 9 یەزدان پێی فەرمووم: «مۆئاب هەراسان مەکە و جەنگ لە دژیان بەرپا مەکە، چونکە هیچ بەشێک لە خاکەکەیان بە میرات بە تۆ نادەم، چونکە عارم بە میرات بە نەوەی لوت داوە.» 
\p  
\v 10 (پێشتر ئێمییەکان\f + \fr 2:10 \ft ئێمییەکان: بڕوانە \xt پەیدابوون 14‏:5‏\ft ‏.‏\f* تێیدا نیشتەجێ بوون، گەلێکی بەهێز و زۆر بوون، وەک عەناقییەکان باڵا بەرز بوون.  
\v 11 وەک عەناقییەکان، ئەوانیش بە ڕفائییەکان ناسراو بوون، بەڵام مۆئابییەکان هەر بە ئێمییەکان بانگیان دەکردن.  
\v 12 پێشتر حۆرییەکان لە سێعیر نیشتەجێ بوون، بەڵام نەوەی عیسۆ لەبەردەم خۆیان دەریانپەڕاندن و لەناویانبردن و لە شوێنیان نیشتەجێ بوون، وەک ئەوەی ئیسرائیل کردیان بە خاکی میراتیان کە یەزدان پێیدابوون.) 
\p  
\v 13 یەزدانیش پێی فەرمووم: «ئێستا هەستن و لە دۆڵی زەرەد بپەڕنەوە،» ئێمەش لە دۆڵی زەرەد پەڕینەوە. 
\p  
\v 14 لەو کاتەوە کە قادێش بەرنێعمان بەجێهێشت هەتا لە دۆڵی زەرەد پەڕینەوە سی و هەشت ساڵ بوو، هەتا هیچ لەو نەوەیە لە پیاوانی جەنگ لەناو ئۆردوگاکە نەمان، هەروەک یەزدان سوێندی بۆ خواردن،  
\v 15 یەزدانیش لە دژیان بوو، بۆ لەناوبردنیان لەناو ئۆردوگاکە هەتا لەناوچوون. 
\p  
\v 16 جا کاتێک هەموو پیاوانی جەنگ لەنێو گەل بە مردن لەناوچوون،  
\v 17 یەزدان پێی فەرمووم:  
\v 18 «تۆ ئەمڕۆ تێدەپەڕیت لە عار کە لە سنووری مۆئابە،  
\v 19 کاتێک لەلای عەمۆنییەکان نزیک کەوتیتەوە هەراسانیان مەکە و هێرشیان مەکە سەر، چونکە هیچت لە خاکی عەمۆنییەکان بە میرات نادەمێ، چونکە بە میرات بە نەوەی لوتم داوە.» 
\p  
\v 20 (ئەویش بە خاکی ڕفائییەکان دادەنرێت، پێشتر ڕفائییەکان تێیدا نیشتەجێ بوون، بەڵام عەمۆنییەکان بە زەمزومییەکان ناویان دەبردن،  
\v 21 گەلێکی بەهێز و زۆر بوون و وەک عەناقییەکان باڵا بەرز بوون، بەڵام یەزدان لەبەردەم عەمۆنییەکاندا لەناوی بردن، جا دەریانکردن و لە شوێنیان نیشتەجێ بوون.  
\v 22 یەزدان وەک ئەوەی بۆ نەوەی عیسۆی کرد کە لە سێعیردا نیشتەجێن، کاتێک حۆرییەکانی لە بەرامبەریان تێکشکاند، جا دەریانکردن و هەتا ئەمڕۆ لە شوێنیان نیشتەجێن.  
\v 23 هەروەها عەڤییەکان کە لە گوندەکان نیشتەجێ بوون هەتا غەزە، کەفتۆرییەکان کە لە کەفتۆرەوە\f + \fr 2:23 \ft کەفتۆر: واتا دوورگەی کریت، کە ئەمڕۆ بەشێک لە وڵاتی یۆنان.‏\f* هاتبوون لەناویانبردن و لە شوێنیان نیشتەجێ بوون.) 
\s1 شکاندنی سیحۆن پاشای حەشبۆن 
\p  
\v 24 «هەستن، کۆچ بکەن و لە دەربەندی ئەرنۆن بپەڕنەوە. بڕوانە، ئەوا سیحۆنی پاشای حەشبۆنی ئەمۆری و خاکەکەیم بە دەستتانەوە داوە، دەستی بەسەردا بگرن و لە دژی ئەو جەنگ بەرپا بکەن.  
\v 25 ئەمڕۆ دەستپێدەکەم، ترس و سامتان دەخەمە بەرچاوی ئەو گەلانەی لەژێر هەموو ئاسمانن، ئەوانە گوێیان لە هەواڵتان دەبێت لێتان دەترسن و لەبەر ئێوە دەلەرزن.» 
\p  
\v 26 جا نێردراوانم لە چۆڵەوانی قەدێمۆتەوە بۆ لای سیحۆنی پاشای حەشبۆن نارد بە وشەی ئاشتیەوە و گوتم:  
\v 27 «ڕێمان بدە بە خاکەکەتدا تێپەڕین و تەنها بە ڕێگای سەرەکیدا دەڕۆین، لانادەین نە بەلای ڕاست و نە بەلای چەپدا،  
\v 28 بە زیو خۆراکمان پێ دەفرۆشیت هەتا بیخۆین و بە زیو ئاومان دەدەیتێ هەتا بیخۆینەوە، تەنها بە پێیەکانمان تێدەپەڕین،  
\v 29 هەروەک ئەوەی نەوەی عیسۆ کە لە سێعیردا نیشتەجێن و مۆئابییەکان کە لە عاردا نیشتەجێن بۆیان کردووین، هەتا لە ڕووباری ئوردون دەپەڕینەوە بۆ ئەو خاکەی یەزدانی پەروەردگارمان پێی بەخشیوین.»  
\v 30 بەڵام سیحۆنی پاشای حەشبۆن ڕازی نەبوو ڕێگامان بدات پێیدا بڕۆین، چونکە یەزدانی پەروەردگارتان وای لێکرد کەللەڕەق بێت و دڵی توند کرد تاکو بیداتە دەستتان، هەروەک چۆن ئەمڕۆ بووە. 
\p  
\v 31 یەزدان پێی فەرمووم: «بڕوانە، ئەوا دەستم پێکرد سیحۆن و خاکەکەی بدەمە دەستت، ئێستا دەستپێبکە و دەست بەسەر خاکەکەیدا بگرە.» 
\p  
\v 32 کاتێک سیحۆن و هەموو سوپاکەی لە یەهەچ بۆ جەنگ لە دژمان هاتنە دەرەوە،  
\v 33 یەزدانی پەروەردگارمان ئەوانی دا بە دەستمان و ئێمەش لێمان دان لەگەڵ کوڕەکانی و هەموو سوپاکەی.  
\v 34 لەو کاتەدا هەموو شارۆچکەکانیمان گرت و لە هەموو شارۆچکەیەک پیاو و ژن و منداڵمان بە تەواوی قڕکرد\f + \fr 2:34 \ft لە زمانی عیبری ئەم زاراوەیە دەگەڕێتەوە بۆ شتێک یان کەسێک کە دەبەخشرێت بە یەزدان، زۆر جار بەخشینەکە بە تەواوی لە ناودەبردرێت.‏\f*، نەمانهێشت کەس دەرباز بێت،  
\v 35 بەڵام ئاژەڵە ماڵییەکانمان بۆ خۆمان تاڵان کرد و دەستکەوتی شارۆچکەکانمان برد.  
\v 36 لە عەرۆعێرەوە کە لەسەر لێواری دەربەندی ئەرنۆنە و ئەو شارۆچکەیەی لە دۆڵەکەیە هەتا گلعاد، هیچ شارێک نەبوو لەپێشمان بوەستێت، یەزدانی پەروەردگارمان هەمووی دا بە دەستمان،  
\v 37 بەڵام لە خاکی عەمۆنییەکان نزیک نەکەوتینەوە، هەموو لایەکی دۆڵی یەبۆق و شارۆچکەکانی ناوچە شاخاوییەکە و هەموو ئەوەی یەزدانی پەروەردگارمان فەرمانی پێدا. 
\c 3  
\s1 شکاندنی عۆگ پاشای باشان 
\p  
\v 1 ئینجا ڕوومان وەرگێڕا و بە ڕێگای باشاندا سەرکەوتین، جا عۆگی پاشای باشان لەگەڵ هەموو سوپاکەی هاتنە دەرەوە بۆ بەرەنگاربوونەوەمان لە ئەدرەعی.  
\v 2 یەزدانیش پێی فەرمووم، «لێی مەترسە، چونکە خۆی و هەموو سوپاکەی و خاکەکەیم داوەتە دەستت، ئەوەی پێ دەکەیت کە بە سیحۆنی پاشای ئەمۆرییەکانت کرد کە لە حەشبۆن فەرمانڕەوا بوو.» 
\p  
\v 3 جا یەزدانی پەروەردگارمان، عۆگی پاشای باشان و هەموو سوپاکەی دایە دەستمان و لێماندا و نەمانهێشت کەس دەرباز بێت.  
\v 4 لەو کاتەشدا دەستمان بەسەر هەموو شارەکانیدا گرت. هیچ شارێک لەو شەست شارە نەمایەوە کە لێیان نەستێنین، واتا هەموو هەرێمی ئەرگۆڤ شانشینی عۆگ لە باشان.  
\v 5 هەموو ئەو شارانە شوورابەند بوون بە شوورای بەرز و دەروازە و شمشیرەیان\f + \fr 3:5 \ft شمشیر، پارچە دارێک بووە لە جیاتی قوفڵ لە دواوەی دەرگا بە شێوەی ئاسۆیی دانراوە بۆ داخستنی دەرگا.‏\f* هەبوو، لەگەڵ ئەوەشدا چەند گوندێکی زۆر شوورایان نەبوو.  
\v 6 جا بە تەواوی قڕمان کرد\f + \fr 3:6 \ft لە زمانی عیبری ئەم زاراوەیە دەگەڕێتەوە بۆ شتێک یان کەسێک کە دەبەخشرێت بە یەزدان، زۆر جار بەخشینەکە بە تەواوی لە ناودەبردرێت.‏\f*، وەک ئەوەی بە سیحۆنی پاشای حەشبۆنمان کرد، لە هەموو شارێکدا پیاو و ژن و منداڵەکانمان بە تەواوی قڕکرد.  
\v 7 بەڵام هەموو ئاژەڵە ماڵییەکان و دەستکەوتی شارەکانیان بۆ خۆمان تاڵان کرد. 
\p  
\v 8 لەو کاتەدا ئەو خاکەی کە لە بەری ڕۆژهەڵاتی ڕووباری ئوردون لە دەربەندی ئەرنۆنەوە هەتا چیای حەرمۆنمان لە دەستی ئەم دوو پاشایەی ئەمۆرییەکان دەرهێنا.  
\v 9 (سەیدائییەکان بە حەرمۆن دەڵێن سیریۆن و ئەمۆرییەکانیش پێی دەڵێن سنیر.)  
\v 10 هەموو شارۆچکەکانی دەشت و هەموو گلعاد و هەموو باشان هەتا سەلخە و ئەدرەعی، دوو شارەکەی شانشینی عۆگ لە باشاندا دەستمان بەسەردا گرت.  
\v 11 (عۆگی پاشای باشان بە تەنها مابووەوە لە پاشماوەی ڕفائییەکان، قەرەوێڵەکەی لە ئاسن دروستکرابوو، هەتا ئێستا لە شاری ڕەبەی\f + \fr 3:11 \ft شاری ڕەبە: ئێستا بە عەمان ناودەبردرێت، پایتەختی وڵاتی ئوردونە.‏\f* عەمۆنییەکانە، درێژییەکەی نۆ باڵ\f + \fr 3:11 \ft نۆ باڵ: نزیکەی 4 مەتر.‏\f* و پانییەکەی چوار باڵە\f + \fr 3:11 \ft چوار باڵ: نزیکەی 1,8 مەتر.‏\f* بە باڵی پیاو.) 
\s1 دابەشکردنی خاکەکە 
\p  
\v 12 لەو کاتەی دەستمان بەسەر ئەو خاکەدا گرت، هەرێمێکم دایە ڕەئوبێنییەکان و گادییەکان، لە سەرووی عەرۆعێرەوە کە لەسەر دەربەندی ئەرنۆنە و نیوەی ناوچە شاخاوییەکانی گلعاد و شارۆچکەکانی لە هەرێمەکەدا بوو.  
\v 13 ئەوەشی لە گلعاد مایەوە و هەموو باشانی شانشینی عۆگ دامە نیوەی هۆزی مەنەشە\f + \fr 3:13 \ft هۆزی مەنەشە دابەش ببوون بۆ سەر دوو بەش، هەریەکەیان کەوتبووە لایەکی ڕووباری ئوردون.‏\f*. (هەموو هەرێمی ئەرگۆڤ لەگەڵ هەموو باشان بوو، کە بە خاکی ڕفائییەکان ناودەبردرا.  
\v 14 یائیری نەوەی مەنەشە دەستی بەسەر هەموو هەرێمی ئەرگۆڤدا گرت هەتا سنووری گەشوورییەکان و مەعکاتییەکان و بە ناوی خۆیەوە ناوی لێنا، هەتا ئەمڕۆش باشان بە حەڤۆت یائیر ناودەبردرێت.)  
\v 15 گلعادیشم دا بە ماکیر.  
\v 16 لە گلعادیشەوە هەتا دەربەندی ئەرنۆن، ناوەڕاستی دۆڵەکە سنوور بوو، هەتا ڕووباری یەبۆق سنووری عەمۆنییەکان دامە ڕەئوبێنییەکان و گادییەکان.  
\v 17 عەراڤا و ڕووباری ئوردونیش سنووری ڕۆژئاواییەکەی بوو، لە کینەرەتەوە هەتا دەریای عەراڤا، دەریای مردوو\f + \fr 3:17 \ft دەریای مردوو: عیبری: دەریای خوێ.‏\f*، لەژێر بنارەکانی پسگە. 
\p  
\v 18 ئەو کاتە فەرمانم پێکردن و گوتم، «یەزدانی پەروەردگارتان ئەم خاکەی پێداون بۆ ئەوەی دەستی بەسەردا بگرن. هەموو پاڵەوانەکان بە چەکەوە لەپێش نەوەی ئیسرائیلی برایانتان دەپەڕنەوە،  
\v 19 بەڵام ژن و منداڵ و ئاژەڵە ماڵییەکانتان، (زانیومە ئاژەڵی ماڵی زۆرتان هەیە،) ئەوا لە شارۆچکەکانتان دەمێننەوە کە پێم داون،  
\v 20 هەتا یەزدان براکانیشتان وەک ئێوە بحەسێنێتەوە، ئەوانیش دەست بەسەر ئەو خاکەی پشتی ڕووباری ئوردوندا بگرن کە یەزدانی پەروەردگارتان دەیانداتێ. ئینجا هەرکەسە دەگەڕێتەوە لای موڵکی خۆی کە پێم داوە.» 
\s1 ڕێنەدان بە پەڕینەوەی موسا 
\p  
\v 21 لەو کاتەشدا فەرمانم بە یەشوع کرد و گوتم، «چاوەکانت هەموو ئەوەیان بینی کە یەزدانی پەروەردگارتان بەم دوو پاشایەی کرد، یەزدان هەمان شت دەکات بە هەموو ئەو پاشایەتییانەی تۆ بۆیان دەپەڕیتەوە.  
\v 22 لێیان مەترسن، چونکە یەزدانی پەروەردگارتان بۆتان دەجەنگێت.» 
\p  
\v 23 لەو کاتەدا لە یەزدان پاڕامەوە و گوتم:  
\v 24 «ئەی یەزدانی باڵادەست، تۆ دەستت پێ کرد مەزنی و دەستی بەهێزت بە خزمەتکارەکەت پیشان بدەیت، چونکە چ خودایەک لە ئاسمان و لەسەر زەوی وەک کردەوەکان و تواناکانی تۆ دەکات؟  
\v 25 تکایە لێمگەڕێ با بپەڕمەوە و ئەو خاکە چاکەی لە بەری ڕۆژئاوای ڕووباری ئوردونە، ئەو ناوچە شاخاوییە جوانە و لوبنان، ببینم.» 
\p  
\v 26 بەڵام یەزدان بەهۆی ئێوەوە لێم هەڵچوو و گوێی لێ نەگرتم، بەڵکو یەزدان پێی فەرمووم: «بەسە! ئیتر لەبارەی ئەم بابەتەوە لەگەڵم مەدوێ.  
\v 27 سەربکەوە بۆ لووتکەی پسگە و بەرەو ڕۆژئاوا و باکوور و باشوور و ڕۆژهەڵات سەر بڵند بکە و بە چاوەکانت خاکەکە ببینە، بەڵام لەم ڕووباری ئوردونە مەپەڕەوە.  
\v 28 ئەرکی ڕابەرایەتی بە یەشوع بسپێرە و بەهێزی بکە و هانی بدە، چونکە ئەو لەپێش ئەم گەلە دەپەڕێتەوە و ئەو خاکەکەیان بۆ دابەش دەکات کە تۆ دەیبینیت.»  
\v 29 جا لە دۆڵەکە بەرامبەر بێت‌پەعۆر ماینەوە. 
\c 4  
\s1 فەرمانەکانی یەزدان بپارێزن 
\p  
\v 1 ئێستاش ئەی ئیسرائیل، گوێ لەم فەرز و یاسایانە بگرە کە من فێرتان دەکەم هەتا بەجێی بهێنن و بژین و بچنە ناو ئەو خاکە و دەستی بەسەردا بگرن کە یەزدانی پەروەردگاری باوباپیرانتان دەتانداتێ.  
\v 2 ئەو قسانەی من فەرمانتان پێ دەکەم هیچی لێ زیاد و کەم مەکەن، هەتا فەرمانەکانی یەزدانی پەروەردگارتان بپارێزن کە من فەرمانتان پێ دەکەم. 
\p  
\v 3 چاوەکانتان بینییان یەزدان چی لە بەعل‌پەعۆردا کرد، هەرچی دوای بەعلی پەعۆر\f + \fr 4:3 \ft بەعلی پەعۆر: ناوێکی مۆئابییە بۆ ئەو خوداوەندەی لە کێوی پەعۆر دەیانپەرست. بڕوانە \xt سەرژمێری 25‏:1‏-9.‏\ft ‏\f* کەوت یەزدانی پەروەردگارتان لەنێوتاندا بە تەواوی لەناوی برد،  
\v 4 بەڵام ئێوە کە خۆتان بە یەزدانی پەروەردگارتانەوە گرتووە ئەوا هەمووتان ئەمڕۆ زیندوون. 
\p  
\v 5 بڕوانە، فەرز و یاساکانم فێرکردن هەروەک یەزدانی پەروەردگارم فەرمانی پێ کردم بۆ ئەوەی ئاوا بکەن لەو خاکەی کە دەچنە ناوی هەتا دەستی بەسەردا بگرن،  
\v 6 ئیتر بیانپارێزن و جێبەجێیان بکەن، چونکە ئەوە دانایی و تێگەیشتوویی ئێوەیە لەبەرچاوی ئەو گەلانەی کە گوێیان لەو هەموو فەرزانە دەبێت و دەڵێن، «ئەم گەلە مەزنە گەلێکی دانا و تێگەیشتوون.»  
\v 7 چ گەلێکی مەزن هەیە، خوداوەندێکی نزیکی هەبێت وەک یەزدانی پەروەردگارمان لە هەموو داواکارییەکانمان؟  
\v 8 هەروەها چ گەلێک مەزنە و ئەو فەرز و یاسا ڕاستودروستانەی هەیە وەک ئەو هەموو فێرکردنەی من ئەمڕۆ لەبەردەمتان دایدەنێم؟ 
\p  
\v 9 بەڵام ئاگاداربە و باش خۆت بپارێزە هەتا ئەو شتانە لەبیر نەکەیت کە بە چاوەکانت بینیت، بۆ ئەوەی هەموو ڕۆژانی ژیانت لە دڵت دەرنەچێت و منداڵەکانت و منداڵی منداڵەکانتی پێ فێر بکە.  
\v 10 ئەو ڕۆژەت لە یاد بێت کە لە بەرامبەر یەزدانی پەروەردگارت ڕاوەستایت لە حۆرێڤ، کە یەزدان پێی فەرمووم: «گەلم بۆ کۆبکەرەوە و وشەکانی منیان بخەرە بەر گوێ، بۆ ئەوەی فێر بن هەموو ئەو ڕۆژانەی کە لەسەر زەوی زیندوون لێم بترسن و منداڵەکانیان فێر بکەن.»  
\v 11 ئێوەش هاتنە پێش و لە خوارەوەی کێوەکە ڕاوەستان و کێوەکە هەتا ناو جەرگەی ئاسمان بە ئاگر داگیرسا بوو، بە تاریکی و تەمی چڕ،  
\v 12 جا یەزدان لەنێو ئاگرەکەوە لەگەڵتاندا دوا و ئێوە گوێتان لە دەنگی وشەکان دەگرت، بەڵام هیچ شێوەیەکی ئەوتان نەبینی، تەنها دەنگ نەبێت.  
\v 13 ئەویش پەیمانەکەی خۆی پێ ڕاگەیاندن کە فەرمانی پێ کردن کاری پێ بکەن، دە ڕاسپاردەکە کە لەسەر دوو تەختەی بەردی نووسی.  
\v 14 لەو کاتەدا یەزدان فەرمانی بە منیش کرد، بۆ ئەوەی فەرز و یاساکانتان فێر بکەم هەتا لەو خاکەدا کاری پێ بکەن کە لە ڕووباری ئوردون بۆی دەپەڕنەوە هەتا دەستی بەسەردا بگرن. 
\s1 قەدەغەکردنی بتپەرستی 
\p  
\v 15 ئەو ڕۆژەی یەزدان لە حۆرێڤ لەنێو ئاگرەکەوە لەگەڵتاندا دوا، ئێوە هیچ وێنەیەکتان نەبینی، بۆیە باش خۆتان بپارێزن  
\v 16 نەوەک گەندەڵ بن و پەیکەرێکی تاشراو بۆ خۆتان دروستبکەن، وێنەی نموونەیەک لە شێوەی نێرینەیەک یان مێینەیەک،  
\v 17 یان لە شێوەی ئاژەڵێک لەوانەی لەسەر زەوین یان لە شێوەی باڵندەیەکی باڵدار لەوانەی لە ئاسمان دەفڕن،  
\v 18 یان لە شێوەی خشۆکێک لەوانەی لەسەر زەوییە، یان لە شێوەی ماسییەک لەوانەی لەناو ئاو لەژێر زەوی.\f + \fr 4:18 \ft لەژێر زەوی: بەپێی بیروبۆچوونی عیبری دەریایەکی مەزن لەبن زەوی هەبوو.‏\f* 
\v 19 هەروەها نەوەک چاو بۆ ئاسمان بەرز بکەیتەوە و تەماشای خۆر و مانگ و ئەستێرەکان و هەموو ئەو شتانەی کە لە ئاسماندا ڕێکخراون بکەیت، کە یەزدانی پەروەردگارت بە هەموو گەلانی داوە کە لەژێر هەموو ئاسمانن\f + \fr 4:19 \ft لەژێر هەموو ئاسمانن: واتا هەموو گەلانی جیهان.‏\f* و هەڵبخەڵەتێی و کڕنۆشی بۆ ببەیت و بیپەرستیت.  
\v 20 یەزدان ئێوەی برد و لە کوورەی ئاسنەوە لە میسرەوە دەریهێنان هەتا وەک ئەمڕۆ ببنە گەلی میراتی ئەو. 
\p  
\v 21 بەهۆی ئێوەشەوە یەزدان لێم تووڕە بوو و سوێندی خوارد کە من لە ڕووباری ئوردون ناپەڕمەوە و ناچمە ناو خاکە باشەکەی کە یەزدانی پەروەردگارتان وەک میرات پێتان دەدات،  
\v 22 جا من لەم خاکەدا دەمرم و لە ڕووباری ئوردون ناپەڕمەوە، بەڵام ئێوە دەپەڕنەوە و دەست بەسەر ئەو زەوییە باشەدا دەگرن.  
\v 23 ئاگاداربن، نەوەک پەیمانی یەزدانی پەروەردگارتان لەبیر بکەن کە لەگەڵ ئێوەی بەست و پەیکەرێکی تاشراو بۆ خۆتان دروستبکەن لە وێنەی هەر شتێک لەوانەی یەزدانی پەروەردگارتان لێی قەدەغە کردن،  
\v 24 چونکە یەزدانی پەروەردگارتان ئاگرێکی بەتینە، خودایەکی ئیرەدارە\f + \fr 4:24 \ft ئیرەدار: لێرەدا واتایەکی ئەرێنی لەخۆ دەگرێت، چونکە خودا مرۆڤی خۆشدەوێت و نایەوێت کەسێک پەیوەندی نێوانیان تێک بدات.‏\f*. 
\p  
\v 25 ئەگەر منداڵ و منداڵی منداڵتان بوو و کاتتان درێژەی کێشا لە خاکەکەدا و گەندەڵ بوون و پەیکەری تاشراوتان دروستکرد، وێنەی هەر شتێک و خراپەتان کرد لەبەرچاوی یەزدانی پەروەردگارتان و پەستتان کرد،  
\v 26 ئەمڕۆ ئاسمان و زەوی دەکەم بە شایەت بەسەرتانەوە کە ئێوە بە خێرایی لەناودەچن لەو خاکەی لە ڕووباری ئوردونەوە بۆی دەپەڕنەوە هەتا دەستی بەسەردا بگرن، درێژە بە ڕۆژانتان نادەن لەسەری و بێگومان لەناودەچن.  
\v 27 یەزدان پەرشوبڵاوتان دەکاتەوە لەنێو گەلاندا، جا ژمارەیەکی کەمتان لێ دەمێنێتەوە لەنێو ئەو نەتەوانەی یەزدان دەتانباتە ناویان،  
\v 28 لەوێ بت دەپەرستن دروستکراوی دەستی خەڵکە لە دار و لە بەرد کە نابینن و نابیستن و ناخۆن و بۆن ناکەن.  
\v 29 بەڵام ئەگەر لەوێوە ڕووتان لە یەزدان کرد، خودای خۆتان، ئەوا بۆتان دەردەکەوێت، ئەگەر بە هەموو دڵ و لە ناخەوە بەدوایدا گەڕان.  
\v 30 کاتێک تەنگانەتان هاتە سەر و لە ڕۆژانی دواتر کە هەموو ئەو شتانەتان بەسەرهات، ئەوا بۆ لای یەزدانی پەروەردگارتان دەگەڕێنەوە و گوێڕایەڵی ئەو دەبن،  
\v 31 چونکە یەزدانی پەروەردگارتان خودایەکی بە بەزەییە، بەجێتان ناهێڵێت و لەناوتان نابات و پەیمانی باوباپیرانتان لەبیر ناکات کە سوێندی بۆیان خوارد. 
\s1 یەزدان خۆی خودایە 
\p  
\v 32 جا سەبارەت بە ڕۆژانی پێشوو پرسیار بکە کە پێش تۆ بووە، لەو ڕۆژەوەی خودا مرۆڤی لەسەر زەوی بەدیهێنا و لەمپەڕی ئاسمان هەتا ئەوپەڕی، ئایا وەک ئەم شتە مەزنە یان هاوتای بیستراوە؟  
\v 33 ئایا هیچ گەلێک گوێیان لە دەنگی خودا بووە لەنێو ئاگرەوە قسە بکات، وەک تۆ گوێت لێ بوو و ژیابێت؟  
\v 34 ئایا هیچ خودایەک هەیە کە هەوڵی دابێت بە تاقیکردنەوە و بە نیشانە و پەرجوو\f + \fr 4:34 \ft پەرجوو: موعجیزە.‏\f*، بە جەنگ و دەستێکی پۆڵایین، بە بازووێکی بەهێز و بە کاری مەزن و سامناک، نەتەوەیەک لەنێو نەتەوەیەکی دیکەدا بۆ خۆی تەرخان بکات، وەک هەموو ئەوەی یەزدانی پەروەردگارتان لەبەرچاوتان لە میسر بۆ ئێوەی کرد؟ 
\p  
\v 35 ئەم شتانەت پیشان درا بۆ ئەوەی بزانیت کە یەزدان خۆی خودایە، بێجگە لەو یەکێکی دیکە نییە.  
\v 36 لە ئاسمانەوە بەم جۆرەی کرد گوێبیستی بن، تاکو تەمبێت بکات، لەسەر زەویش ئاگری مەزنی خۆی پیشان دایت و لەنێو ئاگرەوە گوێت لە وشەکانی بوو،  
\v 37 هەروەها لەبەر ئەوەی باوباپیرانی تۆی خۆشویست و نەوەی ئەوانی هەڵبژارد لە دوایان، بە ئامادەبوونی خۆی و بە هێزە مەزنەکەی خۆی تۆی لە میسرەوە دەرهێنا،  
\v 38 بۆ ئەوەی گەلی مەزنتر و بەهێزتر لە خۆت لەبەردەمت دەربکات و بتهێنێت و وەک ئەمڕۆ خاکەکەیانت وەک میرات بداتێ. 
\p  
\v 39 جا ئەمڕۆ بزانە و لە دڵەوە لێی وردببنەوە، یەزدان خۆی خودایە لە ئاسمان لە سەرەوە و لەسەر زەوی لە خوارەوە و هیچ خودایەکی دیکە نییە.  
\v 40 فەرزەکان و فەرمانەکانی بەجێبهێنە کە من ئەمڕۆ فەرمانت پێدەدەم، هەتا چاکە لەگەڵ خۆت و منداڵەکانت بکات لەدوای خۆت و تەمەن درێژ بیت لەسەر ئەو خاکەی یەزدانی پەروەردگارت بۆ هەتاهەتایە پێت دەدات. 
\s1 شارە پەناگاکان 
\p  
\v 41 ئیتر موسا لە بەری ڕۆژهەڵاتی ڕووباری ئوردون سێ شاری جیا کردەوە،  
\v 42 بۆ ئەوەی ئەو کەسەی کە بەبێ ئەنقەست دراوسێکەی خۆی دەکوژێت بۆ ئەوێ ڕابکات، کە پێشتر ڕقی لێی نەبووەتەوە، جا بۆ یەکێک لەو شارانە هەڵدێت و دەژیێت.  
\v 43 ئەمە ئەو شارانە بوون: شاری بەچەر لە دەشتودەر لە زەوی دەشتایی بۆ ڕەئوبێنییەکان و ڕامۆت لە گلعاد بۆ گادییەکان و گۆلان لە باشان بۆ مەنەشەییەکان. 
\s1 پێشەکی فێرکردنەکان 
\p  
\v 44 ئەمەش ئەو فێرکردنەیە کە موسا لەبەردەم نەوەی ئیسرائیلدا داینا.  
\v 45 ئەمە ئەو یاسا و فەرز و حوکمانەیە کە موسا بە نەوەی ئیسرائیلی گوت کاتێک لە میسر هاتنە دەرەوە،  
\v 46 لە بەری ڕۆژهەڵاتی ڕووباری ئوردون لە دۆڵەکە بەرامبەر بێت‌پەعۆر لە خاکی سیحۆنی پاشای ئەمۆرییەکان کە لە حەشبۆن فەرمانڕەوا بوو، ئەوەی موسا و نەوەی ئیسرائیل شکاندیان لە کاتی هاتنەدەرەوەیان لە میسر.  
\v 47 دەستیان بەسەر خاکەکەیدا گرت لەگەڵ خاکی عۆگی پاشای باشان، هەردوو پاشاکەی ئەمۆرییەکان کە لە بەری ڕۆژهەڵاتی ڕووباری ئوردون بوون.  
\v 48 لە عەرۆعێرەوە کە لەسەر لێواری دەربەندی ئەرنۆنە هەتا چیای سیریۆن\f + \fr 4:48 \ft چیای سیریۆن: چیای حەرمۆنە، نەک کێوی سییۆن ئەوەی دواتر تەرخان کرابووەوە بۆ پەرستنی یەزدان. بڕوانە 12‏:5 و \xt دووەم ساموئێل 5‏:7‏\ft ‏.‏\f* کە حەرمۆنە،  
\v 49 هەروەها هەموو عەراڤا لە بەری ڕۆژهەڵاتی ڕووباری ئوردونەوە هەتا دەریای مردوو\f + \fr 4:49 \ft دەریای مردوو: عیبری: دەریای عەراڤا.‏\f* لەژێر بنارەکانی پسگە. 
\c 5  
\s1 دە ڕاسپاردەکە 
\p  
\v 1 موسا هەموو ئیسرائیلی بانگکرد و پێی گوتن: 
\p ئەی نەوەی ئیسرائیل، گوێ لەو فەرز و یاسایانە بگرن کە ئەمڕۆ دەیخوێنمەوە و گوێتان لێیە و فێری بن و ئاگاداربن هەتا کاری پێ بکەن.  
\v 2 یەزدانی پەروەردگارمان پەیمانێکی لە حۆرێڤ لەگەڵ بەستین،  
\v 3 ئەو پەیمانەی لەگەڵ باوباپیرانمان نەبەست، بەڵکو لەگەڵ ئێمە کە ئەمڕۆ لێرەین و هەموومان زیندووین.  
\v 4 یەزدان ڕووبەڕوو لە کێوەکە لەنێو ئاگرەوە لەگەڵتاندا دوا،  
\v 5 لەو کاتەدا من لەنێوان یەزدان و ئێوەدا ڕاوەستا بووم هەتا فەرمایشتی یەزدانتان پێ ڕابگەیەنم، چونکە لەبەر ئاگرەکە ترسان و سەرنەکەوتن بۆ کێوەکە. 
\p فەرمووی: 
\b  
\li4  
\v 6 «من یەزدانی پەروەردگارتانم کە لە خاکی میسرەوە دەرمهێنان، لە خاکی کۆیلایەتییەوە. 
\b  
\li1  
\v 7 «هیچ کەسێکتان خودای دیکەی بێجگە لە منتان نەبێت. 
\li1  
\v 8 پەیکەر\f + \fr 5:8 \ft تاشینی پەیکەر، بە مەبەستی پەرستن وەک بت، بڕوانە بەشی 7‏:5، 25.‏\f* بۆ خۆتان دروستمەکەن، نە لە هیچ شێوەیەکی ئەوانەی لە ئاسمانن لە سەرەوە، نە ئەوانەی لەسەر زەوین لە خوارەوە، نە ئەوانەی لەناو ئاون لەژێر زەوییەوە.  
\v 9 کڕنۆشیان بۆ مەبەن و مەیانپەرستن، چونکە منی یەزدانی پەروەردگارتان خودایەکی ئیرەدارم، سزای گوناهی باوکان لەسەر نەوەکانیشان جێبەجێ دەکەم هەتا نەوەی سێیەم و چوارەمی ناحەزەکانم،  
\v 10 بەڵام خۆشەویستی نەگۆڕ بۆ هەزاران لە خۆشەویستانم دەردەخەم، ئەوانەی گوێڕایەڵی ڕاسپاردەکانم دەبن. 
\li1  
\v 11 ناوی یەزدانی پەروەردگارتان بۆ شتی پووچ مەهێنن، چونکە ئەو کەسانە لەلای یەزدان ئەستۆپاک نابن کە بۆ شتی پوچەڵ ناوی دەهێنن. 
\li1  
\v 12 ڕۆژی شەممە\f + \fr 5:12 \ft بڕوانە \xt دەرچوون 16‏:23‏\ft ‏.‏\f* بپارێزن، تاکو بە پیرۆزی ڕایبگرن، هەروەک یەزدانی پەروەردگارتان فەرمانی پێ کردن.  
\v 13 شەش ڕۆژ ئیش دەکەن و هەموو کارەکەتان دەکەن،  
\v 14 بەڵام ڕۆژی حەوتەم شەممەیە بۆ یەزدانی پەروەردگارتان، هیچ کارێک مەکەن، خۆتان و کوڕ و کچ و خزمەتکار و کارەکەر و گا و مانگا و گوێدرێژ و هەر ئاژەڵێکتان و ئەو نامۆیەی لەناو دەروازەی شارەکەتانە هیچ کارێک مەکەن، بۆ ئەوەی خزمەتکار و کارەکەرەکەشتان وەک ئێوە بحەسێنەوە.  
\v 15 لە یادتان بێت کە ئێوەش کۆیلە بوون لە خاکی میسر و یەزدانی پەروەردگارتان بە دەستێکی پۆڵایین و بازووێکی بەهێز لەوێ دەریهێنان، لەبەر ئەوە یەزدانی پەروەردگارتان فەرمانی پێ کردن ڕۆژی شەممە بپارێزن. 
\li1  
\v 16 ڕێزی دایک و باوکتان بگرن هەروەک یەزدانی پەروەردگارتان فەرمانی پێ کردن، بۆ ئەوەی تەمەن درێژ بن و چاکە بێتە ڕێتان لەو خاکەی یەزدانی پەروەردگارتان پێتان دەدات. 
\li1  
\v 17 مەکوژن\f + \fr 5:17 \ft مەکوژن: مەبەست بە ئەنقەست یان بە تووڕەیی.‏\f*. 
\li1  
\v 18 داوێنپیسی مەکەن. 
\li1  
\v 19 دزی مەکەن. 
\li1  
\v 20 بە درۆ شایەتی لەسەر کەس مەدەن. 
\li1  
\v 21 چاو مەبڕنە ژنی کەس. چاو مەبڕنە ماڵ و کێڵگە و خزمەتکار و کارەکەر و گا و مانگا و گوێدرێژی هیچ کەسێک و هەر شتێک کە هی کەسێکی دیکە بێت.» 
\b  
\p  
\v 22 یەزدان بەم ڕاسپاردانە لەگەڵ هەموو کۆمەڵەکەتاندا دوا، لە کێوەکە لەناو ئاگر و هەور و تاریکی چڕ و دەنگێکی بەزر، هیچی زیاد نەکرد و لەسەر دوو تەختەی بەرد نووسی و پێیدام. 
\p  
\v 23 کاتێک گوێتان لە دەنگەکە بوو لەناو تاریکییەوە و کێوەکە بە ئاگر گڕی گرتبوو، هەموو سەرۆک هۆزەکانتان و پیرەکانتان هاتن بۆ لام. لێم هاتنە پێش و  
\v 24 گوتتان، «ئەوەتا یەزدانی پەروەردگارمان شکۆمەندی و مەزنی خۆی پیشان داین و گوێمان لە دەنگی بوو لەناو ئاگرەوە، ئەمڕۆ بینیمان خودا لەگەڵ مرۆڤ دەدوێت و مرۆڤەکەش دەژیێت،  
\v 25 بەڵام ئێستا بۆچی بمرین؟ ئەو ئاگرە مەزنە دەمانخوات. ئەگەر لەوە زیاتر گوێمان لە دەنگی یەزدانی پەروەردگارمان بوو ئەوا دەمرین،  
\v 26 چونکە کێ وەک ئێمە لە هەموو ئادەمیزاد گوێی لە دەنگی خودای زیندوو بووە لەناو ئاگرەوە بدوێت و ژیابێت؟  
\v 27 تۆ بڕۆ پێشەوە و گوێ لە هەموو ئەوە بگرە کە یەزدانی پەروەردگارمان دەیڵێت و هەموو ئەوەی یەزدانی پەروەردگارمان پێت دەڵێت، پێمانی بڵێ، جا گوێ دەگرین و کاری پێدەکەین.» 
\p  
\v 28 یەزدانیش گوێی لە قسەکانتان بوو کاتێک قسەتان لەگەڵ کردم و یەزدان پێی فەرمووم، «گوێم لە دەنگی قسەی ئەم گەلە بوو کە لەگەڵتدا دوان. لە هەموو ئەوەی گوتیان باش بوو،  
\v 29 خۆزگە هەمیشە دڵیان ئاوا دەبوو هەتا لێم بترسن و هەموو فەرمانەکانم بپارێزن، تاکو بۆ هەتاهەتایە چاکە بێتە سەر ڕێگای خۆیان و کوڕەکانیان. 
\p  
\v 30 «بڕۆ پێیان بڵێ: ”بگەڕێنەوە چادرەکانی خۆتان،“  
\v 31 بەڵام تۆ لێرە لەگەڵم بوەستە، باسی هەموو فەرمان و فەرز و یاساکانت بۆ دەکەم کە فێریان دەکەیت و ئەوان لەو خاکەدا پەیڕەوی دەکەن کە من پێیان دەدەم هەتا دەستی بەسەردا بگرن.» 
\p  
\v 32 ئیتر ئاگاداربن بۆ ئەوەی هەموو ئەوە بکەن هەروەک یەزدانی پەروەردگارتان فەرمانی پێ کردن، بەلای ڕاست و چەپدا لامەدەن،  
\v 33 هەموو ئەو ڕێگایەی یەزدانی پەروەردگارتان فەرمانی پێ کردن دەیگرنەبەر، هەتا بژین و چاکە بێتە ڕێگاتان و درێژە بە ڕۆژانتان بدەن لەو خاکەی دەستی بەسەردا دەگرن. 
\c 6  
\s1 یەزدانی پەروەردگارت خۆشبوێت 
\p  
\v 1 ئەمە ئەو فەرمان و فەرز و یاسایانەیە کە یەزدانی پەروەردگارتان فەرمانی دا فێرتانی بکەم، هەتا لەو خاکەدا پەیڕەوی بکەن کە لە ڕووباری ئوردونەوە بۆی دەپەڕنەوە هەتا دەستی بەسەردا بگرن،  
\v 2 هەتا لە یەزدانی پەروەردگارتان بترسن و هەموو فەرز و فەرمانەکانی بەجێبهێنن کە من بە ئێوە و منداڵ و نەوەکانتان فەرمانیان پێدەدەم هەموو ڕۆژانی ژیانتان، هەتا ڕۆژانتان درێژ بێت.  
\v 3 جا ئەی ئیسرائیل، گوێ بگرن و ئاگاداربن بە گوێڕایەڵیتان، هەتا چاکە بێتە ڕێگاتان و زۆر زۆرتر ببن، هەروەک یەزدانی پەروەردگاری باوباپیرانتان بەڵێنی پێدان لەو خاکەی شیر و هەنگوینی لێ دەڕژێت. 
\p  
\v 4 ئەی ئیسرائیل گوێ بگرن، یەزدانی پەروەردگارمان یەک یەزدانە،  
\v 5 جا بە هەموو دڵ و بە هەموو گیان و بە هەموو تواناتانەوە یەزدانی پەروەردگارتان خۆشبوێ.  
\v 6 با ئەم ڕاسپاردانەی من ئەمڕۆ فەرمانتان پێ دەکەم لەسەر دڵتان بێت و  
\v 7 بۆ منداڵەکانتانی بگێڕنەوە و باسی بکەن کاتێک لە ماڵ دادەنیشن و کاتێک بە ڕێگادا دەڕۆن و کاتێک دەخەون و کاتێک هەڵدەستن،  
\v 8 وەک نیشانەیەکیش لەسەر دەستتان بیبەستن و با گوڵنگ بێت بە ناوچەوانتانەوە و  
\v 9 لەسەر چوارچێوەی دەرگای ماڵ و حەوشەکانتان بینووسن. 
\p  
\v 10 کاتێکیش یەزدانی پەروەردگارتان ئێوەی هێنا بۆ ئەو خاکەی کە سوێندی بۆ ئیبراهیم و ئیسحاق و یاقوبی باوباپیرانتان خوارد کە بتانداتێ، بۆ شاری مەزن و چاک کە ئێوە بنیادتان نەناوە،  
\v 11 ماڵی پڕ لە خێروبێر کە ئێوە پڕتان نەکردووە، بیری لێدراو کە ئێوە لێتان نەداوە، مێو و زەیتوون کە ئێوە نەتانڕواندووە، کە کاتێک خواردتان تێر بوون،  
\v 12 جا ئاگاداربن نەوەک یەزدان لەبیر بکەن کە لە خاکی میسر لە ماڵی کۆیلەیی دەریهێنان. 
\p  
\v 13 لە یەزدانی پەروەردگارتان دەترسن و تەنها ئەو دەپەرستن و بە ناوی ئەوەوە سوێند دەخۆن.  
\v 14 بەدوای خودای دیکەدا مەڕۆن، لە خوداوەندەکانی ئەو نەتەوانەی لە دەوروبەرتانن،  
\v 15 چونکە یەزدانی پەروەردگارتان کە لەنێوتاندایە، خودایەکی ئیرەدارە، نەوەک تووڕەیی یەزدانی پەروەردگارتان بجۆشێت بەسەرتان و لەسەر ڕووی ئەم خاکە لەناوتان ببات.  
\v 16 یەزدانی پەروەردگارتان تاقی مەکەنەوە وەک لە مەسا تاقیتان کردەوە.  
\v 17 بە تەواوی فەرمان و یاسا و فەرزەکانی یەزدانی پەروەردگارتان بەجێبهێنن کە فەرمانی پێ کردوون.  
\v 18 ئەوەی ڕاستە و باشە لەبەرچاوی یەزدانی پەروەردگارتان بیکەن، هەتا چاکە بێتە ڕێگاتان و بچنە ناوەوە و دەست بەسەر ئەو خاکە چاکەدا بگرن کە یەزدان سوێندی بۆ باوباپیرانتان خوارد،  
\v 19 کە هەموو دوژمنانتان لەبەردەم ڕابماڵێت، وەک یەزدان فەرمووی. 
\p  
\v 20 لە داهاتوودا، کاتێک منداڵەکانتان لێیان پرسین و گوتیان: «ئەو یاسا و فەرز و حوکمانە چین کە یەزدانی پەروەردگارمان فەرمانی پێ کردن؟»  
\v 21 بە منداڵەکانتان دەڵێن: «لە میسر کۆیلەی فیرعەون بووین و یەزدان بە دەستێکی بەهێز لە میسرەوە دەریهێناین و  
\v 22 یەزدان لەبەرچاومان نیشانە و پەرجووی مەزن و سامناکی بەسەر میسر و فیرعەون و هەموو ماڵەکەی نارد و  
\v 23 لەوێوە دەریهێناین هەتا بمانهێنێت و ئەو خاکەمان بداتێ کە بۆ باوباپیرانمان سوێندی خواردبوو.  
\v 24 جا یەزدان فەرمانی پێ کردین هەموو ئەو فەرزانە بەجێبهێنین و لە یەزدانی پەروەردگارمان بترسین، هەتا هەموو ڕۆژان چاکەمان بێتە ڕێ و بمانهێڵێتەوە وەک ئەمڕۆ،  
\v 25 ڕاستودروستیشمان بۆ دەبێت ئەگەر هەموو ئەو فەرمانانەمان پاراست هەتا لەبەردەم یەزدانی پەروەردگارمان بیکەین، هەروەک فەرمانی پێ کردین.» 
\c 7  
\s1 دەرکردنی نەتەوەکان 
\p  
\v 1 کاتێک یەزدانی پەروەردگارتان ئێوەی هێنایە ئەو خاکەی کە دەچنە ناوی هەتا دەستی بەسەردا بگرن و گەلانی زۆری لەبەردەمتان دەرکرد، حیتی و گرگاشی و ئەمۆری و کەنعانی و پریزی و حیڤی و یەبوسییەکان، حەوت گەلی لە خۆتان مەزنتر و بەهێزتر،  
\v 2 کاتێک یەزدانی پەروەردگارتان ئەوانی دایە دەستتان و ئێوەش لێتان دان، دەبێت بە تەواوی قڕیان بکەن\f + \fr 7:2 \ft بە تەواوی قڕیان بکەن: لە زمانی عیبریدا ئەم زاراوەیە دەگەڕێتەوە بۆ شتێک یان کەسێک کە دەبەخشرێت بە یەزدان، زۆر جار بەخشینەکە بە تەواوی لە ناودەبردرێت.‏\f*، پەیمانیان لەگەڵ مەبەستن و بەزەییتان پێیاندا نەیەتەوە.  
\v 3 ژن و ژنخوازییان لەگەڵ مەکەن، کچتان مەدەنە کوڕیان و کچیان بۆ کوڕتان مەهێنن،  
\v 4 چونکە کوڕەکانتان لە من هەڵدەگێڕنەوە و خودای دیکە دەپەرستن، جا تووڕەیی یەزدان لێتان دەجۆشێت و خێرا لەناوتان دەبات.  
\v 5 بەڵام دەبێت ئاوایان پێ بکەن، قوربانگاکانیان بڕووخێنن و بەردە تەرخانکراوەکانیان\f + \fr 7:5 \ft بەردی بە ستوونی دانراو بۆ پەرستن. بڕوانە دواوتار 16‏:21‏-22.‏\f* بشکێنن و ستوونە ئەشێراکانیان\f + \fr 7:5 \ft ستوونە ئەشێرا: هێمای خواژنە. بڕوانە \xt یەکەم پاشایان 11‏:5‏\ft ‏.‏\f* ببڕنەوە و بتەکانیان بە ئاگر بسووتێنن،  
\v 6 چونکە ئێوە گەلێکی پیرۆزن بۆ یەزدانی پەروەردگارتان. لەنێو هەموو گەلانی سەر ڕووی زەوی یەزدانی پەروەردگارتان ئێوەی هەڵبژارد تاکو بۆی ببن بە گەلی ئەو، ببنە گەنجینەیەکی تایبەت. 
\p  
\v 7 یەزدان دڵی پێتانەوە بەند بوو و هەڵیبژاردن، نەک لەبەر ئەوەی لە هەموو گەلان زۆرترن، چونکە لە ڕاستیدا ئێوە لە هەموو گەلان کەمترن.  
\v 8 بەڵام لە خۆشەویستی یەزدان بوو بۆتان و پاراستنی ئەو سوێندەی بۆ باوباپیرانی ئێوەی خوارد، یەزدان بە دەستێکی بەهێز دەریهێنان و ئێوەی لە خاکی کۆیلایەتی کڕییەوە، لە دەستی فیرعەونی پاشای میسر.  
\v 9 جا بزانن کە یەزدانی پەروەردگارتان خۆی خودایە، خودای وەفادارییە، ئەوەی پەیمانی خۆشەویستییەکەی هەتا هەزار نەوە دەباتەسەر، بۆ ئەوانەی خۆشیان دەوێت و فەرمانەکانی دەپارێزن. 
\q1  
\v 10 بەڵام سزای ئەوانە دەدات کە ڕقیان لێی دەبێتەوە و دەستبەجێ لەناویان دەبات، 
\q2 ئەوەی ڕقی لێی بێتەوە لەسەری ناوەستێت و تۆڵەی لێ دەکاتەوە. 
\m  
\v 11 جا فەرمان و فەرز و یاساکان بەجێبهێنن کە من ئەمڕۆ فەرمانتان پێدەدەم بۆ ئەوەی جێبەجێی بکەن. 
\p  
\v 12 ئەگەر ئێوە گوێ لەو یاسایانە بگرن و بیپارێزن و جێبەجێ بکەن، ئەوا یەزدانی پەروەردگارتان پەیمانی خۆشەویستییەکەی بۆ ئێوە دەباتەسەر، وەک چۆن سوێندی بۆ باوباپیرانتان خوارد.  
\v 13 ئێوەی خۆشدەوێت، بەرەکەتدارتان دەکات و زۆرتان دەکات و بەروبوومی سکتان و بەروبوومی زەوییەکەتان، دانەوێڵە و شەرابی نوێ و زەیتتان، بەروبوومی گوێرەکەی گاگەلەکەتان و مەڕ و بزنەکانتان بەرەکەتدار دەکات لەسەر ئەو خاکەی کە سوێندی بۆ باوباپیرانتان خوارد کە بە ئێوەی دەدات.  
\v 14 ئێوە بەرەکەتدار دەبن لە سەرووی هەموو گەلان، وەجاخکوێر و نەزۆک نە لە ئێوە و نە لەناو ئاژەڵە ماڵییەکانتاندا نابێت،  
\v 15 یەزدان هەموو نەخۆشییەکتان لێ دوور دەخاتەوە و هەموو دەردە خراپەکانی میسر کە ئێوە زانیتان نایخاتە سەرتان، بەڵکو دەیخاتە سەر هەموو ناحەزانتان،  
\v 16 هەموو ئەو گەلانەش لەناودەبەن کە یەزدانی پەروەردگارتان دەیانداتە دەستتان، بەزەییتان پێیان نایەتەوە و خوداوەندەکەیان ناپەرستن، چونکە ئەوە تەڵەیە بۆ ئێوە. 
\p  
\v 17 ئەگەر لە دڵی خۆتاندا گوتتان، «ئەو گەلانە لە ئێمە بەهێزترن، چۆن دەتوانین دەریانبکەین؟»  
\v 18 لێیان مەترسن، ئەوەتان بەبیر بێتەوە یەزدانی پەروەردگارتان چی بە فیرعەون و بە هەموو میسرییەکان کرد،  
\v 19 ئەو ئەزموونە مەزنانەی چاوەکانتان بینییان و ئەو نیشانە و پەرجووانە، هەروەها ئەو دەستە پۆڵایین و بازووە بەهێزەی کە یەزدانی پەروەردگارتان ئێوەی پێ دەرهێنا. یەزدانی پەروەردگارتان ئاوا لە هەموو ئەو گەلانە دەکات کە ئێوە لێیان دەترسن.  
\v 20 هەروەها یەزدانی پەروەردگارتان زەردەواڵە دەنێرێتە سەر ئەو گەلانە تاوەکو تەنانەت ئەو بەجێماوانەش لەناو ببات کە خۆیان لە ئێوە شاردووەتەوە.  
\v 21 لێیان مەترسن، چونکە یەزدانی پەروەردگارتان لەنێوتانە و خودایەکی مەزن و سامناکە.  
\v 22 یەزدانی پەروەردگارتان کەمە کەمە ئەو گەلانە لەبەردەمتان دەردەکات، ناتوانن دەستبەجێ لەناویان ببەن نەوەک دڕندەی کێویتان بەسەرەوە زۆر بێت.  
\v 23 بەڵام یەزدانی پەروەردگارتان دەیانداتە دەست و سەرلێشێوانێکی مەزنیان دەکەوێتە ناو، هەتا لەناودەچن.  
\v 24 پاشاکانیشیان دەخاتە ناو دەستتان، جا لەژێر ئاسمان ناویان دەسڕنەوە، کەس نابێت بتوانێت لە دژتان بوەستێت هەتا لەناویان دەبەن.  
\v 25 وێنەی خوداوەندەکانیان بە ئاگر دەسووتێنن، چاو مەبڕنە ئەو زێڕ و زیوەی کە لەسەریانە هەتا بۆ خۆتانی ببەن، نەوەک پێی بکەونە داوەوە، چونکە لەلای یەزدانی پەروەردگارتان قێزەونە.  
\v 26 هیچ قێزەونێکیش مەهێننە ناو ماڵەکانتانەوە نەوەک ئێوەش وەک ئەو بۆ قڕکردن تەرخان بکرێن، بەڵکو وەکو شتێکی قێزەون تەماشای بکەن و ڕقتان لێ ببێتەوە، چونکە بۆ قڕکردن تەرخان کراوە\f + \fr 7:26 \ft لە زمانی عیبری ئەم زاراوەیە دەگەڕێتەوە بۆ شتێک یان کەسێک کە دەبەخشرێت بە یەزدان، زۆر جار بەخشینەکە بە تەواوی لە ناودەبردرێت.‏\f*. 
\c 8  
\s1 یەزدانی پەروەردگارتان لەبیر مەکەن 
\p  
\v 1 ئاگاداربن بە جێبەجێکردنی هەموو ئەو فەرمانانەی من ئەمڕۆ فەرمانتان پێ دەکەم هەتا بژین و زۆر بن و ئەو خاکەی یەزدان سوێندی خواردووە بۆ باوباپیرانتان بچنە ناوی و دەستی بەسەردا بگرن.  
\v 2 هەموو ئەو ڕێگایانەشتان لە یاد بێت، کە یەزدانی پەروەردگارتان لە ماوەی ئەم چل ساڵە لە چۆڵەوانیدا ئێوەی پێدا برد هەتا بێفیزتان بکات و هەڵتانبسەنگێنێت تاکو ئەوەی لەناو دڵتانە بیزانێت، ئاخۆ فەرمانەکانی پەیڕەو دەکەن یان نا.  
\v 3 جا بێفیزی کردن و برسی کردن و مەنی دەرخوارد دان، کە پێشتر نەتاندەزانی و باوباپیرانتیشتان نەیاندەزانی\f + \fr 8:3 \ft مەنی: ناوی ئەو نانەیە کە دیاری خودا بوو و وەک تۆوی گژنیژ سپی بوو و تامیشی وەک ناسکە نانی (ناوەشکێنە) بە هەنگوین بوو. بە زمانی عیبری \+tl مەن‏\+tl* واتا «ئەمە چییە؟» بڕوانە \xt دەرچوون 16‏:14‏-31.‏\ft ‏\f* تاکو فێرتان بکات کە مرۆڤ تەنها بە نان ناژیێت، بەڵکو بە هەر وشەیەک کە لە دەمی یەزدانەوە دێتە دەرەوە.  
\v 4 جلەکانتان بەبەرتانەوە کۆن نەبوون و پێتان نەئاوسا لەم چل ساڵەدا،  
\v 5 جا لە دڵتانەوە بزانن وەک چۆن مرۆڤ کوڕەکەی تەمبێ دەکات، ئاوا یەزدانی پەروەردگارتان تەمبێی کردن. 
\p  
\v 6 فەرمانەکانی یەزدانی پەروەردگاریشتان پەیڕەو بکەن هەتا ڕێگاکانی بگرنەبەر و لێی بترسن،  
\v 7 چونکە یەزدانی پەروەردگارتان دەتانهێنێتە خاکێکی باش، خاکێک کە جۆگەکان و گۆماوەکان و سەرچاوەی کانیاوەکان هەڵدەقوڵێنە نێو دۆڵ و چیاکان،  
\v 8 خاکی گەنم و جۆ و مێو و هەنجیر و هەنار، خاکی زەیتی زەیتوون و هەنگوین.  
\v 9 خاکێکە نانی کەمی تێدا ناخۆن و تێیدا پێویستیتان بە هیچ شتێک نابێت، خاکێک بەردەکانی ئاسنە و لە چیاکانی مس هەڵدەکۆڵن. 
\p  
\v 10 جا کاتێک خواردتان و تێر بوون، ستایشی یەزدانی پەروەردگارتان دەکەن لەبەر ئەو خاکە باشەی پێیدان.  
\v 11 ئاگاداربن نەوەک یەزدانی پەروەردگارتان لەبیر بکەن و فەرمان و یاسا و فەرزەکانی بەجێنەهێنن، ئەوەی من ئەمڕۆ فەرمانتان پێدەدەم،  
\v 12 نەوەک کاتێک خواردتان و تێر بوون و خانووی خۆشتان دروستکرد و نیشتەجێ بوون و  
\v 13 مانگا و مەڕتان زیادی کرد و زێڕ و زیوتان بۆ زیاد بوو، هەموو ئەوەی هەتانە زیاد بوو،  
\v 14 لووتتان بەرز بێت و یەزدانی پەروەردگارتان لەبیر بچێت کە لە خاکی میسر لە ماڵی کۆیلەیی دەریهێنان.  
\v 15 ئەوەی بە چۆڵەوانی مەزن و ترسناکدا ئێوەی برد، شوێنی ماری ژەهراوی و دووپشک و خاکی تینووێتی و بێ ئاو، ئەوەی لە بەردەئەستێ ئاوی بۆ دەرهێنان.  
\v 16 ئەوەی لە چۆڵەوانی مەنی دەرخوارد دان کە باوباپیرانتان نەیاندەزانی، هەتا بێفیزتان بکات و هەڵتانبسەنگێنێت بۆ ئەوەی لە کۆتاییدا چاکەتان لەگەڵدا بکات.  
\v 17 هەروەها نەوەک لە دڵی خۆتاندا بڵێن، «هێزی خۆمان و توانای دەستمان ئەم سامانەی بۆ دروستکردین،»  
\v 18 بەڵکو یەزدانی پەروەردگارتان لە یاد بێت، ئەو هێزتان دەداتێ بۆ سامان دروستکردن، هەتا ئەو پەیمانەی خۆی بەجێبگەیەنێت کە سوێندی بۆ باوباپیرانتان خوارد وەک ئەمڕۆ. 
\p  
\v 19 ئەگەر یەزدانی پەروەردگارتان لەبیر کرد و بەدوای خوداوەندانی دیکە کەوتن و پەرستتان و کڕنۆشتان بۆ بردن، ئەوا ئەمڕۆ شایەتیتان لەسەر دەدەم کە بێگومان لەناودەچن،  
\v 20 وەک ئەو گەلانەی یەزدان لەبەردەمتان لەناویان دەبات، ئێوەش لەناو دەبردرێن لەبەر ئەوەی ئێوە گوێڕایەڵی یەزدانی پەروەردگارتان نەبوون. 
\c 9  
\s1 نەک لەبەر ڕاستودروستی ئیسرائیل 
\p  
\v 1 ئەی ئیسرائیل گوێ بگرن، ئەمڕۆ ئێوە خەریکن لە ڕووباری ئوردون دەپەڕنەوە هەتا بچنە ناوەوە و گەلەکانی ناوی دەربکەن، ئەوان لە ئێوە مەزنتر و بەهێزترن، شارەکانیان گەورە و شوورادارن هەتا ئاسمان.  
\v 2 نەتەوەیەکی مەزن و باڵا بەرز، نەوەی عەناق، کە بەوانتان زانیوە و بیستووتانە کە گوتراوە: «کێ لە ڕووی نەوەی عەناق دەوەستێت؟»  
\v 3 جا ئەمڕۆ بزانن کە یەزدانی پەروەردگارتان لەپێشتانەوە دەپەڕێتەوە وەک ئاگرێکی سووتێنەر، ئەو لەبەردەمتاندا لەناویان دەبات و زەلیلیان دەکات و ئێوەش دەریاندەکەن و بە خێرایی لەناویان دەبەن، هەروەک یەزدان بەڵێنی پێدان. 
\p  
\v 4 کاتێک یەزدانی پەروەردگارتان لەبەردەمتاندا لایان دەبات، لە دڵی خۆتاندا مەڵێن، «لەبەر ڕاستودروستیمان یەزدان ئێمەی هێنایە ئێرە هەتا دەست بەسەر ئەم خاکەدا بگرین،» بەڵکو لەبەر بەدکاری ئەو گەلانەیە، یەزدان لەبەردەمتاندا دەریاندەکات.  
\v 5 لەبەر ڕاستودروستی و دڵپاکیتان نییە کە دەچنە ناوەوە تاکو دەست بەسەر زەوییەکەیاندا بگرن، بەڵکو لەبەر بەدکاری ئەو گەلانەیە کە یەزدانی پەروەردگارتان لەبەردەمتان دەریاندەکات و هەتا ئەو بەڵێنەش جێبەجێ بکات کە یەزدان سوێندی لەسەر خوارد بۆ باوباپیرانتان، ئیبراهیم و ئیسحاق و یاقوب.  
\v 6 جا بزانن لەبەر ڕاستودروستیتان نییە یەزدانی پەروەردگارتان ئەو خاکە باشەتان پێدەدات هەتا دەستی بەسەردا بگرن، چونکە ئێوە گەلێکی کەللەڕەقن. 
\s1 گوێرەکە زێڕینە لەقاڵبدراوەکە 
\p  
\v 7 لە یادتان بێت و لەبیری مەکەن چۆن لە دەشتودەر یەزدانی پەروەردگارتان تووڕە کرد. لەو ڕۆژەوەی لە خاکی میسرەوە هاتنە دەرەوە و هەتا هاتنە ئەم شوێنە ئێوە لە یەزدان یاخین.  
\v 8 تەنانەت لە حۆرێڤیش یەزدانتان تووڕە کرد و جا یەزدان لێتان تووڕە بوو هەتا ڕادەیەک ئامادە بوو لەناوتان ببات.  
\v 9 کاتێک بۆ کێوەکە سەرکەوتم بۆ ئەوەی دوو تەختە بەردەکە، دوو تەختەکەی پەیمان کە یەزدان لەگەڵتانی بەست وەربگرم، چل شەو و چل ڕۆژ لە کێوەکە مامەوە و نانم نەخوارد و ئاوم نەخواردەوە.  
\v 10 یەزدانیش دوو تەختە بەردەکەی پێدام کە بە پەنجەی خودا نووسرا بوون و هەموو ئەو ڕاسپاردانەی لەسەر بوو کە یەزدان لە کێوەکە لەناو ئاگرەوە لە ڕۆژی کۆبوونەوەکە لەگەڵتاندا پێی دوا. 
\p  
\v 11 لە کۆتایی چل شەو و چل ڕۆژەکە، یەزدان دوو تەختە بەردەکە، دوو تەختەکەی پەیمانی دامێ.  
\v 12 پاشان یەزدان پێی فەرمووم: «هەستە بە خێرایی لێرە بڕۆ خوارەوە، چونکە گەلەکەت ئەوەی تۆ لە میسرەوە دەرتهێنان گەندەڵ بوون، بە زوویی لەو ڕێگایە لایاندا کە فەرمانم پێکردن، بتێکی لەقاڵبدراویان بۆ خۆیان دروستکرد.» 
\p  
\v 13 هەروەها یەزدان پێی فەرمووم: «ئەم گەلەم بینی، بە ڕاستی گەلێکی کەللەڕەقن،  
\v 14 لێمگەڕێ لەناویان دەبەم و ناویان لەژێر ئاسمان دەسڕمەوە و دەتکەمە گەلێکی بەهێزتر و زۆرتر لەوان.» 
\p  
\v 15 منیش ڕووم وەرگێڕا و لە کێوەکە هاتمە خوارەوە، کێوەکە بە ئاگر گڕی گرتبوو، دوو تەختەکەی پەیمانیشم بەدەستەوە بوو.  
\v 16 جا ڕوانیم ئێوە سەبارەت بە یەزدانی پەروەردگارتان گوناهتان کردبوو، بتێکی داڕێژراوتان\f + \fr 9:16 \ft بڕوانە \xt دەرچوون 32‏\ft ‏.‏\f* لە شێوەی گوێرەکەیەک بۆ خۆتان دروستکردبوو، بە زوویی لەو ڕێگایە لاتان دابوو کە یەزدان فەرمانی پێ کردبوون.  
\v 17 منیش دوو تەختەکەم گرت و لە دەستم فڕێمدان و لەبەرچاوتان شکاندم. 
\p  
\v 18 پاشان وەک یەکەم جار چل شەو و چل ڕۆژ لەبەردەم یەزدان کەوتم و نانم نەخوارد و ئاوم نەخواردەوە لەبەر هەموو ئەو گوناهانەی ئەنجامتان داوە، بەوەی لەبەردەم یەزدان خراپەتان کرد و پەستتان کرد.  
\v 19 لەو تووڕەیی و جۆشانە ترسام کە یەزدان لێتان پەست ببوو بە ڕادەیەک کە ئامادە بوو لەناوتان ببات، بەڵام یەزدان ئەو جارەش گوێی لێ گرتم.  
\v 20 یەزدان لە هارونیش زۆر تووڕە بوو هەتا لەناوی ببات، جا لەو کاتەدا لە پێناوی هارونیش نزام کرد.  
\v 21 هەروەها گوناهەکەتان، واتا ئەو گوێرەکەیەی کە دروستتان کردبوو، من بردم و سووتاندم و کوتام و باش هاڕیم هەتا وەک تۆز نەرم بوو، ئینجا تۆزەکەیم هەڵدایە ناو ئەو جۆگەیەی لە کێوەکەوە دێتە خوارەوە. 
\p  
\v 22 هەروەها لە تەبعیرە و مەسا و قیبرۆت هەتەڤا یەزدانتان تووڕە کرد. 
\p  
\v 23 کاتێکیش یەزدان لە قادێش بەرنێعەوە ئێوەی نارد، فەرمووی: «سەربکەون و دەست بەسەر ئەو خاکەدا بگرن کە پێم داون.» بەڵام ئێوە لە فەرمانی یەزدانی پەروەردگارتان یاخی بوون و بڕواتان پێی نەکرد و گوێڕایەڵی ئەو نەبوون،  
\v 24 لەو ڕۆژەوەی ئێوەم ناسیوە، ئێوە لە دژی یەزدان یاخین. 
\p  
\v 25 ئەو چل شەو و چل ڕۆژە لەبەردەم یەزدان کەوتم، چونکە یەزدان فەرمووبووی لەناوتان دەبات.  
\v 26 نوێژم بۆ یەزدان کرد و گوتم، «ئەی یەزدانی باڵادەست، گەلەکەت و میراتەکەت لەناو مەبە کە بە توانای خۆت کڕیتەوە، ئەوەی بە دەستێکی بەهێز لە میسر دەرتهێنا.  
\v 27 خزمەتکارەکانت بەبیر بێتەوە، ئیبراهیم و ئیسحاق و یاقوب، ئاوڕ لە کەللەڕەقی ئەم گەلە مەدەوە یان لە بەدکارییەکەیان یان لە گوناهەکەیان،  
\v 28 نەوەک خەڵکی ئەو وڵاتەی لێت دەرهێناین بڵێت: ”لەبەر ئەوەی یەزدان نەیتوانی بیانباتە ناو ئەو خاکەی کە بەڵێنی پێدابوون و لەبەر ئەوەی ڕقی لێیان بوو، دەریهێنان هەتا لە چۆڵەوانیدا بیانمرێنێت.“  
\v 29 بەڵام ئەوان گەلی تۆن و میراتی تۆن کە بە توانا مەزنەکەت و دەستە بەهێزەکەت دەرتهێنان.» 
\c 10  
\s1 دوو تەختە وەک ئەوانەی یەکەم جار 
\p  
\v 1 لەو کاتەدا یەزدان پێی فەرمووم: «دوو تەختە بەردی وەک ئەوانەی یەکەم بۆ خۆت بتاشە و سەربکەوە سەر کێوەکە بۆ لای من، سندوقێکیش لە دار بۆ خۆت دروستبکە،  
\v 2 جا لەسەر دوو تەختەکە ئەو وشانە دەنووسمەوە کە لەسەر دوو تەختەکەی یەکەم جار بوون و تۆ شکاندت و بیانخە ناو سندوقەکە.» 
\p  
\v 3 منیش سندوقێکم لە داری ئەکاسیا\f + \fr 10:3 \ft داری شەتیم.‏\f* دروستکرد، دوو تەختە بەردی وەک ئەوانەی یەکەم جارم تاشی و بۆ شاخەکە سەرکەوتم و دوو تەختەکەشم لە دەست بوو.  
\v 4 ئەویش لەسەر دوو تەختەکە وەک نووسراوی یەکەم جاری نووسییەوە، دە ڕاسپاردەکە کە یەزدان لەگەڵتاندا پێی دوا لە کێوەکە لەناو ئاگرەوە لە ڕۆژی کۆبوونەوەکە و ئینجا پێیدام.  
\v 5 ئیتر گەڕامەوە و لە کێوەکە هاتمە خوارەوە و دوو تەختە بەردەکەم لەناو سندوقەکە دانا کە دروستم کردبوو، جا هێشتا لەوێن وەک یەزدان فەرمانی پێ کردم. 
\p  
\v 6 (نەوەی ئیسرائیلیش لە بیرەکانی نەوەی یەعقانەوە کۆچیان کرد بۆ مۆسێرە. لەوێ هارون مرد و هەر لەوێش نێژرا. ئیتر ئەلعازاری کوڕی لە جێی ئەو بوو بە کاهین.  
\v 7 لەوێشەوە کۆچیان کرد بۆ گودگۆدە، لە گودگۆدەشەوە بۆ یۆتباتە کە خاکی جۆگە ئاوەکانە.  
\v 8 لەو کاتەدا یەزدان هۆزی نەوەی لێڤی جیا کردەوە\f + \fr 10:8 \ft جیا کردەوە: بڕوانە \xt سەرژمێری 3‏:5‏-13.‏\ft ‏\f* بۆ ئەوەی سندوقی پەیمانی یەزدان هەڵبگرن و لەبەردەم یەزدان بوەستن بۆ ئەوەی خزمەتی بکەن و بە ناوی ئەوەوە داوای بەرەکەت بکەن هەتا ئەمڕۆ،  
\v 9 لەبەر ئەوە لێڤییەکان لەگەڵ براکانیان بەش و میراتیان نەبوو، یەزدان میراتی ئەوانە، هەروەک یەزدانی پەروەردگارتان لەگەڵیاندا دوا.) 
\p  
\v 10 منیش وەک ڕۆژانی یەکەم جار چل شەو و چل ڕۆژ لە کێوەکە مامەوە و یەزدان ئەو جارەش گوێی لێ گرتم و یەزدان نەیویست لەناوتان ببات.  
\v 11 دواتر یەزدان پێی فەرمووم، «هەستە بڕۆ پێشڕەوی گەل بکە، جا دەچنە ناو ئەو خاکەی دەست بەسەریدا دەگرن کە سوێندم بۆ باوباپیرانیان خوارد بیاندەمێ.» 
\s1 لە یەزدان بترسە 
\p  
\v 12 ئێستاش ئەی ئیسرائیل یەزدانی پەروەردگارتان چی لێتان دەوێت، تەنها ئەوەندە کە لە یەزدانی پەروەردگارتان بترسن تاکو هەموو ڕێگاکانی بگرنەبەر و خۆشتان بوێ، پڕ بە دڵ و لە ناخەوە یەزدانی پەروەردگارتان بپەرستن،  
\v 13 فەرمانەکانی یەزدان و فەرزەکانی بەجێبهێنن کە من ئەمڕۆ بۆ باشی خۆتان فەرمانتان پێ دەکەم. 
\p  
\v 14 ئەوەتا ئاسمان و ئاسمانی ئاسمانەکان و زەوی و هەرچی تێیدایە بۆ یەزدانی پەروەردگارتانە،  
\v 15 لەگەڵ ئەوەشدا یەزدان دڵی بە باوباپیرانتانەوە بەند بوو و خۆشیویستن، جا لەپاش خۆیان نەوەکەی ئەوانی هەڵبژارد کە ئێوەن، لە سەرووی هەموو گەلانەوە وەک ئەمڕۆ.  
\v 16 کەواتە دڵتان خەتەنە بکەن و ئیتر کەللەڕەق مەبن،  
\v 17 چونکە یەزدانی پەروەردگارتان خۆی خودای خودایانە و گەورەی گەورەیانە، ئەو خودا مەزنە بە توانا بە سامەی لایەنگری ناکات و بەرتیل وەرناگرێت،  
\v 18 دادپەروەری هەتیو و بێوەژن دەکات و دۆستی نامۆیە هەتا خۆراک و بەرگی بداتێ.  
\v 19 جا نامۆتان خۆشبوێت، چونکە لە خاکی میسردا نامۆ بوون.  
\v 20 لە یەزدانی پەروەردگارتان دەترسن، ئەو دەپەرستن و دەست بەوەوە دەگرن و بە ناوی ئەوەوە سوێند دەخۆن،  
\v 21 ئەو ستایشتانە و ئەو خوداتانە کە ئەو هەموو کارە مەزن و ترسناکەی بۆ کردن کە چاوەکانتان بینییان.  
\v 22 باوباپیرانتان حەفتا کەس بوون کە چوونە میسر و ئێستاش یەزدانی پەروەردگارتان لە زۆریدا وەک ئەستێرەی ئاسمانی لێکردوون. 
\c 11  
\s1 خۆشویستن و پاراستنی فەرمانەکانی یەزدان 
\p  
\v 1 یەزدانی پەروەردگارتان خۆشبوێت و داواکاری و فەرز و یاسا و فەرمانەکانی هەمیشە بەجێبهێنن.  
\v 2 بزانن کە پەیامەکەم بۆ ئێوەیە، نەک بۆ منداڵەکانتان کە ئەزموونی تەمبێکردنی یەزدانی پەروەردگاریان نییە. ئێوە کە مەزنێتی و دەستی پۆڵایین و بازووە بەهێزەکەی ئەوتان بینیوە؛  
\v 3 نیشانە و کارەکانی کە لە میسر بە فیرعەونی پاشای میسر و بە هەموو خاکەکەی کرد،  
\v 4 ئەوەی بە ئەسپ و گالیسکەکانی سوپای میسری کرد کاتێک بەدواتان کەوتن، بە شەپۆلەکانی دەریای سووری پێچایەوە و بە تەواوی لەناوی بردن.  
\v 5 هەروەها منداڵەکانی ئێوە نەبوون، بەڵکو ئێوە بوون کە بە چاوی خۆتان ئەوەتان بینی کە لە دەشتودەر بۆی کردن هەتا هاتنە ئەم شوێنە و  
\v 6 ئەوەی بە داتان و ئەبیرامی کرد، دوو کوڕەکەی ئەلیابی ڕەئوبێنی، کاتێک لەناوەندی هەموو ئیسرائیلدا زەوی دەمی کردەوە و بە ماڵەکانیان و چادرەکانیان و هەموو ئەو شتە زیندووانەی هی ئەوان بوون هەڵیلووشی.  
\v 7 ئێوە بە چاوی خۆتان هەموو کردارە مەزنەکانی یەزدانتان بینی کە کردی. 
\p  
\v 8 هەموو ئەو فەرمانانە بپارێزن کە ئەمڕۆ فەرمانتان پێ دەکەم، بۆ ئەوەی بەهێز بن و بچنە ناوەوە و دەست بەسەر ئەو خاکەدا بگرن کە ئێوە لە ڕووباری ئوردونەوە بۆی دەپەڕنەوە هەتا ببنە خاوەنی،  
\v 9 هەروەها بۆ ئەوەی تەمەن درێژ بن لەسەر ئەو خاکەی یەزدان سوێندی بۆ باوباپیرانتان خوارد بیانداتێ، بۆ خۆیان و نەوەکانیان، خاکێک شیر و هەنگوینی لێ دەڕژێت.  
\v 10 ئەو خاکەی کە ئێوە دەچنە ناوی هەتا دەستی بەسەردا بگرن، وەک خاکی میسر نییە کەوا بەجێتان هێشت، ئەو شوێنەی تۆوتان لێ دەچاند و بە پێیەکانتان ئاوتان دەدا\f + \fr 11:10 \ft لە میسردا بۆ ئاودێری زەوی و زار، لە جۆگەکانەوە یان کەنداوەکانەوە بەهۆی زنجیرەیەک جەنجەڕی ئاو هەڵێنجانەوە بووە، کە بەهۆی پێیەکانیانەوە دەیانسووڕاندەوە.‏\f* وەک باخی سەوزەوات.  
\v 11 بەڵکو ئەو خاکەی ئێوە لە ڕووباری ئوردونەوە بۆی دەپەڕنەوە هەتا دەستی بەسەردا بگرن، خاکی چیا و دۆڵە، لە بارانی ئاسمان ئاو دەخواتەوە.  
\v 12 خاکێک یەزدانی پەروەردگارتان بایەخی پێدەدات؛ چاوەکانی یەزدانی پەروەردگارتان لە سەرەتای ساڵ هەتا کۆتایی بە بەردەوامی لەسەریەتی. 
\p  
\v 13 جا ئەگەر گوێڕایەڵی فەرمانەکانم بوون کە من ئەمڕۆ فەرمانتان پێ دەکەم هەتا یەزدانی پەروەردگارتان خۆشبوێت، پڕ بە دڵ و لە ناخەوە بیپەرستن،  
\v 14 ئەوا بارانی زەوییەکەتان، پاییزە باران و بەهارە باران لە وەرزی خۆیدا دەدەم، ئێوەش دانەوێڵە و شەرابی نوێ و زەیتەکەتان کۆدەکەنەوە.  
\v 15 لە کێڵگەکانتان گیا بۆ ئاژەڵەکانتان دابین دەکەم، ئێوەش هەمیشە خۆراکی پێویستتان دەبێت و تێر دەبن. 
\p  
\v 16 بۆیە ئاگاداربن نەوەک دڵتان بخەڵەتێت و لابدەن و خودای دیکە بپەرستن و کڕنۆشی بۆ ببەن.  
\v 17 جا تووڕەیی یەزدان لێتان دەجۆشێت و ئاسمان دادەخرێت و باران نابارێت و زەوی بەروبووم نادات، ئێوەش بە خێرایی لەو خاکە چاکەی یەزدان پێتانی دەدات لەناودەچن.  
\v 18 جا ئەم وشانەم لەسەر دڵ و گیانتان دابنێن و وەک نیشانە لەسەر دەستتانی ببەستن و با گوڵنگ بن بە ناوچەوانتانەوە.  
\v 19 منداڵەکانیشتان فێر بکەن و پێی بدوێن کاتێک لە ماڵەکانتان دادەنیشن و کاتێک بە ڕێگادا دەڕۆن و کاتێک دەخەون و کاتێک هەڵدەستن،  
\v 20 لەسەر چوارچێوەی دەرگاکانی ماڵەکەت و لەسەر دەرگاکانی حەوشەکەت بینووسە،  
\v 21 بۆ ئەوەی ڕۆژانی خۆت و منداڵەکانت زیاد بکات لەسەر ئەو خاکەی یەزدان سوێندی بۆ باوباپیرانت خوارد بیانداتێ هەروەک بەردەوامی ئاسمان بەسەر ڕووی زەویدا. 
\p  
\v 22 ئەگەر هۆشیار بوون و هەموو ئەو فەرمانانە بپارێزن کە من فەرمانتان پێ دەکەم هەتا بیکەن، بۆ ئەوەی یەزدانی پەروەردگارتان خۆشبوێت و هەموو ڕێگاکانی بگرنەبەر و دەستی پێوە بگرن،  
\v 23 ئەوا یەزدان هەموو ئەو گەلانە لەبەردەمتان دەردەکات و ئێوە دەبنە میراتگری گەلانی لە خۆتان گەورەتر و بەهێزتر.  
\v 24 هەر شوێنێک لەپی پێتان لێ دانا دەبێتە هی ئێوە، سنوورتان لە دەشتودەر و لوبنانەوە، لە ڕووبارەکەوە، ڕووباری فورات هەتا دەریای ڕۆژئاوا دەبێت.  
\v 25 هیچ کەس ناتوانێت لە دژتان بوەستێت، یەزدانی پەروەردگارتان ترس و سامتان دەخاتە سەر هەموو ئەو زەوییەی پێی لێ دەنێن، هەروەک بەڵێنی پێدان. 
\p  
\v 26 بڕوانە، من ئەمڕۆ بەرەکەت و نەفرەت لەبەردەمتان دادەنێم:  
\v 27 بەرەکەتە، ئەگەر گوێڕایەڵی فەرمانەکانی یەزدانی پەروەردگاری خۆتان بن کە من ئەمڕۆ فەرمانتان پێ دەکەم؛  
\v 28 نەفرەتە، ئەگەر گوێڕایەڵی فەرمانەکانی یەزدانی پەروەردگاری خۆتان نەبن و لەو ڕێگایەی کە من ئەمڕۆ فەرمانتان پێ دەکەم لاتان دا هەتا بەدوای خودای دیکە بکەون کە نەتانناسیوە.  
\v 29 جا کاتێک یەزدانی پەروەردگارت تۆی هێنایە ئەو خاکەی کە تۆ دەچیتە ناوی هەتا دەستی بەسەردا بگریت، ئەوا بەرەکەتەکان لەسەر کێوی گەریزیم ڕابگەیەنە و نەفرەتەکانیش لەسەر کێوی عێبال.  
\v 30 وەک دەزانن ئەم کێوانە لەوبەری ڕووباری ئوردونەوەن، لە ڕۆژئاوای ڕێگاکە بەرەو خۆرئاوابوون، لە خاکی کەنعانییەکانی کە لە عەراڤادا نیشتەجێن، بەرامبەر گلگال لەتەنیشت دار بەڕووەکانی مۆرە،  
\v 31 چونکە ئێوە خەریکن لە ڕووباری ئوردون دەپەڕنەوە هەتا بچنە ناو ئەو خاکەی یەزدانی پەروەردگارتان پێتان دەدات و دەستی بەسەردا بگرن. کاتێک دەستتان بەسەردا گرت و تێیدا نیشتەجێ بوون،  
\v 32 ملکەچی هەموو ئەو فەرز و یاسایانە بن کە من ئەمڕۆ لەبەردەمتانی دادەنێم هەتا بیکەن. 
\c 12  
\s1 تەنها لە شوێنی هەڵبژێردراو خودا بپەرستن 
\p  
\v 1 ئەمە ئەو فەرز و یاسایانەیە کە بەجێی دەهێنن هەتا لەو خاکەدا بیکەن کە یەزدانی پەروەردگاری باوباپیرانتان پێیداون هەتا دەستی بەسەردا بگرن بە درێژایی ڕۆژانی ژیانتان لەسەر زەوی.  
\v 2 هەموو ئەو شوێنانە بە تەواوی تێکدەدەن، کە تێیدا ئەو نەتەوانەی ئێوە دەریاندەکەن، خوداوەندەکانیان دەپەرست لەسەر چیا سەرکەشەکان و لەسەر گردەکان و لەژێر هەموو دارێکی سەوز،  
\v 3 قوربانگاکانیشیان تێکدەدەن، بەردە تەرخانکراوەکانیان دەشکێنن، ستوونە ئەشێراکانیان بە ئاگر دەسووتێنن، پەیکەرەکانی خوداوەندەکانیان دەبڕنەوە و لەو شوێنانەدا ناویان دەسڕنەوە. 
\p  
\v 4 بەو شێوەیەی ئەوان یەزدانی پەروەردگارتان ناپەرستن،  
\v 5 بەڵکو ئەو شوێنەی یەزدانی پەروەردگارتان هەڵیدەبژێرێت لەنێو هەموو هۆزەکانتان هەتا ناوی خۆی تێدا دابنێت بۆ نیشتەجێبوونی\f + \fr 12:5 \ft هەتا سەردەمی حەزرەتی سلێمان، پەرستگایەک بۆ یەزدان دروستنەکرابوو. بڕوانە \xt یەکەم پوختەی مێژوو 17‏:5‏\ft ‏.‏\f*، ڕووتان لەو شوێنە دەکەن و بۆ ئەوێ دەچن.  
\v 6 بۆ ئەوێ قوربانی سووتاندن و سەربڕاو و دەیەکەکان و بەخشینی بەرزکراوە و نەزر\f + \fr 12:6 \ft نەزر: داوا لە خودا دەکرێت بۆ ئەنجامدانی کارێک و پابەند دەکرێت بە مەرجێکەوە. ئەگەر خودا ئەو کارە بکات، ئەوا دەرئەنجام ئەمیش ئەو کارە ئەنجام دەدات کە پێیەوە پابەندی کردووە. بڕوانە \xt سەرژمێری 21‏:2‏\ft ‏.‏\f* و بەخشینی ئازاد\f + \fr 12:6 \ft بەخشینی ئازاد: بڕوانە \xt دەرچوون 35‏:29 و 36‏:3.‏\ft ‏\f* و نۆبەرەی مانگا و مەڕەکانتان پێشکەش دەکەن.  
\v 7 لەوێ لەبەردەم یەزدانی پەروەردگارتان ئێوە و خێزانەکانتان دەخۆن و دڵخۆش دەبن بە هەموو ئەوانەی دەستتان پێی دەگات، وەک یەزدانی پەروەردگارتان بەرەکەتداری کردن. 
\p  
\v 8 ئێوە ئاوا مەکەن، وەک ئەوەی ئێمە ئەمڕۆ لێرە دەیکەین، کە هەرکەسە بەو شێوەیەی خۆی دەکات کە ڕاستە لەپێش چاوی،  
\v 9 چونکە هێشتا نەچوونەتە ناو شوێنی حەسانەوە و میرات کە یەزدانی پەروەردگارتان دەتانداتێ.  
\v 10 بەڵام لە ڕووباری ئوردون دەپەڕنەوە و لەو خاکە نیشتەجێ دەبن کە یەزدانی پەروەردگارتان دەتانداتێ بە میرات و ئێوە دەحەسێنێتەوە لە هەموو دوژمنەکانتان کە لە دەوروبەرتانن و ئینجا بە ئاسوودەیی نیشتەجێ دەبن،  
\v 11 ئەوا ئەو شوێنەی خوداتان هەڵیدەبژێرێت هەتا ناوی لەوێ بێت، بۆ ئەوێ هەموو ئەو شتانە هەڵدەگرن کە من فەرمانتان پێ دەکەم، قوربانی سووتاندن و سەربڕاو و دەیەکەکان و بەخشینی بەرزکراوە و هەموو هەڵبژێردراوی نەزرەکانتان کە بۆ یەزدانی دەکەن.  
\v 12 لەوێ لەبەردەم یەزدانی پەروەردگارتان دڵخۆش دەبن، ئێوە و کوڕ و کچ و خزمەتکار و کارەکەرەکانتان، هەروەها ئەو لێڤییانەش کە لە دەروازەی شارۆچکەکانتانن، چونکە نە بەش و نە میراتیان لەگەڵتاندا نییە.  
\v 13 ئاگاداربن قوربانی سووتاندنەکانتان پێشکەش مەکەن لە هەر شوێنێک کە دەیبینن،  
\v 14 بەڵکو لەو شوێنەی یەزدان هەڵیدەبژێرێت لە یەکێک لە هۆزەکانتان، لەوێ قوربانی سووتاندنەکانتان پێشکەش دەکەن و لەوێ هەموو ئەوانە دەکەن کە من فەرمانتان پێدەدەم. 
\p  
\v 15 بەڵام لە هەموو ئەوانەی حەزتان بۆی دەچێت سەردەبڕن و گۆشت دەخۆن لە هەموو شارۆچکەکانتان بەگوێرەی ئەو بەرەکەتەی یەزدانی پەروەردگارتان کە پێیداون، کەسی گڵاو و پاک بەپێی ڕێوڕەسم لێی دەخۆن وەک مامز و ئاسک.  
\v 16 بەڵام خوێن ناخۆن، وەک ئاو دەیڕێژنە سەر زەوی.  
\v 17 بۆتان نییە لە شارۆچکەکانتاندا دەیەکی دانەوێڵە و شەرابی نوێ و زەیتەکەتان بخۆن، هەروەها لە نۆبەرەی مانگا و مەڕتان و نە هیچ شتێک لە نەزرەکانتان کە نەزریان دەکەن و لە بەخشینە ئازاد و بەرزکراوەکانتان،  
\v 18 بەڵکو لەبەردەم یەزدانی پەروەردگارتان دەیخۆن لەو شوێنەی یەزدانی پەروەردگارتان هەڵیدەبژێرێت، خۆتان و کوڕ و کچ و خزمەتکار و کارەکەرەکانتان، هەروەها لێڤییەکانی شارۆچکەکانتان، لەبەردەم یەزدانی پەروەردگاریشتان بە هەموو ئەوانەی دەستتان پێی دەگات دڵخۆش دەبن.  
\v 19 ئاگاداربن لەوەی لێڤی پشت گوێ بخەن بە درێژایی ڕۆژانی ژیانتان لەسەر خاکەکەتان. 
\p  
\v 20 کاتێک یەزدانی پەروەردگاری خۆتان سنووری فراوان کردن وەک لەگەڵتاندا دوا و ئێوەش گوتتان «گۆشت دەخۆین،» چونکە حەزتان بۆ گۆشت خواردن چوو، ئەوا چەند حەزتان بۆی دەچێت لە گۆشت دەخۆن.  
\v 21 ئەگەر ئەو شوێنەی یەزدانی پەروەردگارتان هەڵیدەبژێرێت هەتا ناوی خۆی لێ دابنێت لێتانەوە دوور بوو، ئەوە لەو مانگا و مەڕانەی یەزدان پێتانی داوە سەری ببڕن وەک فەرمانم پێکردن و لە شارۆچکەکانتاندا لە هەموو ئەوانەی حەزتان بۆی چوو بخۆن.  
\v 22 وەک چۆن مامز و ئاسک دەخورێت ئاوا دەیخۆن، کەسی گڵاو و پاک بەپێی ڕێوڕەسم وەک یەک لێی دەخۆن،  
\v 23 بەڵام ئاگاداربن خوێن نەخۆن، چونکە خوێن ژیانەکەیە، جا ژیانەکە لەگەڵ گۆشتەکە مەخۆن،  
\v 24 نایخۆن، وەک ئاو لەسەر زەوی دەیڕێژن،  
\v 25 نایخۆن هەتا چاکە بێتە ڕێی خۆتان و منداڵەکانتان لەدوای خۆتان، چونکە ئەوەی لەبەرچاوی یەزدان ڕاستە، ئەوە دەکەن. 
\p  
\v 26 بەڵام شتە تەرخانکراوەکانتان کە هی ئێوەن و نەزرەکانتان هەڵدەگرن و دەچنە ئەو شوێنەی یەزدان هەڵیدەبژێرێت،  
\v 27 جا قوربانی سووتاندنەکانتان، گۆشتەکە و خوێنەکە لەسەر قوربانگای یەزدانی پەروەردگارتان دەکەن، بەڵام قوربانییە سەربڕدراوەکانتان، خوێنەکەی لەتەنیشتی قوربانگای یەزدانی پەروەردگارتان دەڕژێنرێن و گۆشتەکەش دەخۆن،  
\v 28 هۆشیار بن هەموو ئەو وشانەی من فەرمانتان پێدەدەم گوێڕایەڵی بن، هەتا بۆ خۆتان و منداڵەکانتان لەدوای خۆتان چاکە بێتە ڕێتان هەتاهەتایە، کاتێک ئەوەی لەبەرچاوی یەزدانی پەروەردگارتان چاکە و ڕاستە دەیکەن. 
\p  
\v 29 یەزدانی پەروەردگارتان لەبەردەمتاندا ئەو نەتەوانە لەناو دەبات کە ئێوە خەریکن بۆیان دەچن هەتا دەریانبکەن. بەڵام کاتێک ئێوە دەریاندەکەن و لە خاکەکەیان نیشتەجێ دەبن،  
\v 30 دوای ئەوەی لەبەردەمتان لەناودەبردرێن، ئاگاداربن لەوەی نەکەونە داوەوە و سەبارەت بە خوداوەندەکانیان پرسیار مەکەن: «ئەو نەتەوانە چۆن خوداوەندەکانیان دەپەرست؟ ئێمەش ئاوا دەکەین.»  
\v 31 بۆ یەزدانی پەروەردگارتان ئاوا مەکەن، چونکە ئەوان هەموو ئەو شتانەی قێزەونە لەلای یەزدان لەوەی ڕقی لێیەتی بۆ خوداوەندەکانیان کردووە، چونکە تەنانەت کوڕان و کچانی خۆشیان بە ئاگر سووتاندووە بۆ خوداوەندەکانیان. 
\p  
\v 32 هەموو ئەو قسانەی کە فەرمانم پێکردن، ئاگاداربن بیکەن، نە بۆی زیاد بکەن و نە لێی کەم بکەنەوە. 
\c 13  
\s1 پەرستنی خودای دیکە 
\p  
\v 1 ئەگەر لەنێوتاندا پێغەمبەرێک یان خەونبینێک کە خەونێکی بینیبێت دەرکەوت و نیشانەیەک یان پەرجووێکی پێدان،  
\v 2 جا ئەگەر ئەو نیشانەیە یان ئەو پەرجووە کە بۆ ئێوەی باسکرد ڕوویدا و گوتی، «با بەدوای خودای دیکە بکەوین و بیانپەرستین،» ئەو خوداوەندانەی کە نەتانناسیوە،  
\v 3 ئەوا گوێ لە قسەی ئەو پێغەمبەرە یان ئەو خەونبینە مەگرە کە ئەو خەونەی بینیوە، چونکە یەزدانی پەروەردگارتان تاقیتان دەکاتەوە تاکو بزانێت ئایا ئێوە پڕ بە دڵ و لە ناخەوە یەزدانی پەروەردگاری خۆتان خۆشدەوێت یان نا.  
\v 4 بەدوای یەزدانی پەروەردگارتان دەڕۆن و لەو دەترسن و فەرمانەکانی دەپارێزن و گوێڕایەڵی دەبن و ئەو دەپەرستن و دەستی پێوە دەگرن.  
\v 5 ئەو پێغەمبەرەش یان ئەو خەونبینەی ئەو خەونەی بینیوە دەکوژرێت، چونکە بە چەواشەکاری قسەی کرد لە دژی یەزدانی پەروەردگارتانەوە کە لە خاکی میسرەوە دەریهێنان و لە ماڵی کۆیلەیی کڕینیەوە، بۆ ئەوەی لەو ڕێگایە لات بدات کە یەزدانی پەروەردگارتان فەرمانی پێ کردوون لەسەری بڕۆن. جا خراپەکە لەنێو خۆتان دادەماڵن. 
\p  
\v 6 ئەگەر براکەت، کوڕی دایکت، یان کوڕەکەت یان کچەکەت، یان ژنەکەی باوەشت، یان هاوڕێکەت کە وەک خۆتە بە نهێنی لەبن گوێت خوێندی و گوتی، «دەڕۆین و خودای دیکە دەپەرستین،» ئەو خوداوەندانەی کە نە تۆ و نە باوباپیرانت نەیانناسیوە،  
\v 7 لە خوداوەندەکانی ئەو گەلانەی دەوروبەرت، ئەوانەی لێتەوە نزیکن یاخود دوورن، لەمپەڕی زەوی هەتا ئەوپەڕی،  
\v 8 لەگەڵی ڕەزامەند مەبە و گوێی لێ مەگرە. دڵت پێی نەسووتێت و دەستی لێ مەپارێزە و بۆی دامەپۆشە،  
\v 9 بەڵکو بە دڵنیاییەوە بیکوژە، یەکەم جار دەستی تۆ لەسەری بێت بۆ کوشتنی ئینجا لە کۆتاییدا دەستی هەموو گەل.  
\v 10 بەردبارانی دەکەیت هەتا دەمرێت، چونکە ویستی لە یەزدانی پەروەردگارت تۆ لابدات کە لە خاکی میسر لە ماڵی کۆیلەیی دەریهێنایت.  
\v 11 ئەوسا هەموو ئیسرائیل دەیبیستن و دەترسن و جارێکی دیکە هیچ کەسێک لەنێوتان وەک ئەم بەدکارییە ئەنجام نادات. 
\p  
\v 12 ئەگەر سەبارەت بە یەکێک لەو شارۆچکانەی یەزدانی پەروەردگارتان پێتان دەدات هەتا تێیدا نیشتەجێ بن وتەیەکتان بیست،  
\v 13 کە خەڵکانێکی بەدکار لەنێوتاندا سەریان هەڵداوە و دانیشتووانی شارۆچکەیان گومڕا کردووە و دەڵێن، «دەچین و خودای دیکە دەپەرستین،» ئەو خوداوەندانەی کە نەتانناسیون،  
\v 14 ئێوە لێی بکۆڵنەوە و بگەڕێن و باش پرسیار بکەن. ئەگەر زانیتان بابەتەکە ڕاستە و بێگومانە کە ئەو کارە قێزەونە لەنێوتاندا کراوە،  
\v 15 ئەوا بە شمشێر تەواوی دانیشتووانی ئەو شارۆچکەیە بکوژن و قڕیان بکەن،\f + \fr 13:15 \ft لە زمانی عیبری ئەم زاراوەیە دەگەڕێتەوە بۆ شتێک یان کەسێک کە دەبەخشرێت بە یەزدان، زۆر جار بەخشینەکە بە تەواوی لە ناودەبردرێت.‏\f* بە هەموو ئەو شتانەوەش کە تێیدایە و بە ئاژەڵە ماڵییەکانیشییەوە.  
\v 16 هەموو شتومەکەکانی لە گۆڕەپانی شارۆچکەکەدا کۆدەکەنەوە و هەموو شارۆچکەکە و شتومەکەکانی وەک قوربانی سووتاندنێکی تەواو بۆ یەزدانی پەروەردگارتان دەسووتێنن، جا بۆ هەتاهەتایە دەبێتە گردێکی وێران و جارێکی دیکە بنیاد نانرێتەوە.  
\v 17 نابێت هیچ شتێکی تەرخانکراو بۆ قڕکردن لەلای ئێوە ببینرێتەوە، هەتا گڕی تووڕەییەکەی یەزدان دابمرکێتەوە، بەزەیی پێتان دێتەوە و لەگەڵتان میهرەبان دەبێت و زۆرتان دەکات هەروەک سوێندی بۆ باوباپیرانتان خوارد،  
\v 18 ئەگەر گوێڕایەڵی دەنگی یەزدانی پەروەردگارتان بوون بۆ پاراستنی هەموو فەرمانەکانی کە من ئەمڕۆ فەرمانتان پێدەدەم هەتا ئەوەی لەبەرچاوی یەزدانی پەروەردگارتان ڕاستە بیکەن. 
\c 14  
\s1 خواردنی پاک و گڵاو 
\p  
\v 1 ئێوە ڕۆڵەی یەزدانی پەروەردگارتانن، لەشی خۆتان بریندار مەکەن و ناوچەوانتان مەتاشن لەبەر مردوو،  
\v 2 چونکە ئێوە گەلێکی پیرۆزن بۆ یەزدانی پەروەردگارتان و یەزدانیش ئێوەی هەڵبژارد بۆ ئەوەی ببنە گەنجینەیەکی تایبەت بۆ ئەو لە سەرووی هەموو ئەو گەلانەی لەسەر ڕووی زەویدان. 
\p  
\v 3 هیچ شتێکی قێزەون مەخۆن.  
\v 4 ئەمە ئەو ئاژەڵانەن کە دەیخۆن: گا و مەڕ و بزن،  
\v 5 ئاسک، مامز، ئاسکە سوورە، بزنەکێوی، کەڵەکێوی، ئاسکەکێوی و مەڕەکێوی.  
\v 6 هەر ئاژەڵێک کە سمی دوو کەرتە و کاوێژ دەکات، ئەوە دەخۆن.  
\v 7 بەڵام لەوانەی کاوێژ دەکەن یان سمیان دوو کەرتە، ئەمانە مەخۆن: وشتر و کەروێشک و گۆڕهەڵکەنە، چونکە کاوێژ دەکەن، بەڵام سمیان کەرت نییە، لەبەر ئەوە بۆتان گڵاوە.  
\v 8 هەروەها بەرازیش بۆتان گڵاوە، چونکە سمی کەرت کراوە، بەڵام کاوێژ ناکات، لەبەر ئەوە نە گۆشتیان بخۆن و نە دەست لە کەلاکیان\f + \fr 14:8 \ft کەلاکیان: واتا لاشەی مردوو یان سەربڕاو.‏\f* بدەن. 
\p  
\v 9 لە هەموو ئەوانەی لە ئاوەکاندا دەژین، ئەوانە بخۆن کە باڵ و پوولەکەیان هەیە،  
\v 10 بەڵام هەموو ئەوەی باڵ و پوولەکەی نەبێت نەیخۆن، بۆ ئێوە گڵاوە. 
\p  
\v 11 هەموو باڵندەیەکی پاک دەخۆن،  
\v 12 بەڵام ئەمانەیان لێ ناخۆن، هەڵۆ و سیسارکە کەچەڵ و داڵاش،  
\v 13 واشەی سوور و واشەی ڕەش، هەموو جۆرەکانی شاهین و شمقاڕ،  
\v 14 هەموو جۆرەکانی قەلەڕەش،  
\v 15 کوندەپەپووی شاخدار و بایەقووش، مەلی دەریا، هەموو جۆرەکانی باز،  
\v 16 کوندەپەپووی بچووک و کوندەپەپووی گەورە و کوندەپەپووی سپی و  
\v 17 کوندەپەپووی بیابان، واشەی ماسیگر، مەلی ماسیگرە،  
\v 18 لەقلەق و هەموو جۆرەکانی شاهۆ و پەپوسڵێمانکە و شەمشەمەکوێرە. 
\p  
\v 19 هەموو مێرووێکی باڵدار بۆ ئێوە گڵاوە و ناخورێت.  
\v 20 هەموو باڵندەیەکی پاک دەخۆن. 
\p  
\v 21 هیچ ئاژەڵێکی مرداربووەوە مەخۆن، بیدەن بەو نامۆیانەی لە شارۆچکەکانتان دەژیێن، ئەوان دەیخۆن، یان بیفرۆشنە بیانییەکان، چونکە ئێوە گەلێکی پیرۆزن بۆ یەزدانی پەروەردگارتان. 
\p هیچ کاریلەیەک بە شیری دایکی لێمەنێن. 
\s1 دەیەکەکان 
\p  
\v 22 هەموو بەروبوومی کشتوکاڵتان کە ساڵ بە ساڵ لە کێڵگەکانتان وەبەردێت، بە تەواوی دەیەکی لێ دەخەنەلاوە.  
\v 23 لەبەردەم یەزدانی پەروەردگارتان لەو شوێنەی هەڵیدەبژێرێت بۆ ئەوەی ناوی لەوێ بێت، دەیەکی دانەوێڵە و شەرابی نوێ و زەیتەکەتان و نۆبەرەکانی مانگا و مەڕەکانتان دەخۆن، تاکو فێر بن هەردەم لە یەزدانی پەروەردگارتان بترسن\f + \fr 14:23 \ft مەبەست لە پەرستنە.‏\f*.  
\v 24 بەڵام ئەگەر ڕێگاکە بۆتان دوور بوو و یەزدانی پەروەردگارتان بەرەکەتداری کردبوون و نەتانتوانی دەیەکەکەتان بهێنن، چونکە ئەو شوێنەی یەزدانی پەروەردگارتان هەڵیدەبژێرێت بۆ ئەوەی ناوی لەوێ بێت لێتان دوور بوو،  
\v 25 ئەوا بە زیو بیفرۆشن و زیوەکە بپێچنەوە لە دەستتان و بڕۆن بۆ ئەو شوێنەی یەزدانی پەروەردگارتان هەڵیدەبژێرێت.  
\v 26 جا زیوەکە خەرج بکەن لە هەموو ئەوەی حەزتان بۆی دەچێت، لە مانگا و مەڕ و شەراب و مەی و هەموو ئەوەی گیانتان لێتان داوا دەکات و لەوێ لەبەردەم یەزدانی پەروەردگارتان بیخۆن و ئێوە و ماڵەکانتان دڵخۆش بن.  
\v 27 ئەو لێڤییانەش کە لە شارۆچکەکانتانن بەجێیان مەهێڵن، چونکە بەش و میراتیان لەگەڵ ئێوەدا نییە. 
\p  
\v 28 لە کۆتایی هەر سێ ساڵێکدا هەموو دەیەکی بەروبوومی ئەو ساڵەتان دەربهێنن و لەناو شارۆچکەکانتان دایبنێن،  
\v 29 لێڤییەکانیش کە هیچ بەش و میراتیان لەگەڵ ئێوەدا نییە، لەگەڵ ئەو نامۆ و هەتیو و بێوەژنانەی کە لە شارۆچکەکانتانن بێن و بخۆن و تێر ببن، بۆ ئەوەی یەزدانی پەروەردگارتان لە هەموو کردارێکی دەستتان کە دەیکەن بەرەکەتدارتان بکات. 
\c 15  
\s1 ساڵی بەتاڵکردنەوەی قەرزەکان 
\p  
\v 1 هەر حەوت ساڵ جارێک، لە قەرزەکانتان خۆش بن.  
\v 2 ئەمەش چۆنیەتی بەتاڵکردنەوەیە، هەموو خاوەن قەرزەکان پێویستە لەو قەرزەی بە نزیکەکەی داوە بەتاڵی بکاتەوە. لە نزیکەکەی یان براکەی داوا ناکاتەوە، چونکە کاتی یەزدان بۆ بەتاڵکردنەوەی قەرزەکان بانگەواز کراوە.  
\v 3 لە بیانی داوا دەکرێت، بەڵام ئەو قەرزەی لەلای براکەت هەتبوو، ئەوا پێویستە بەتاڵی بکەیتەوە.  
\v 4 هەرچەندە پێویستە لەنێوتان کەس هەژار نەبێت، چونکە بێگومان یەزدان بەرەکەتدارتان دەکات لەو خاکەی یەزدانی پەروەردگارتان پێتانی دەدات هەتا وەک میرات دەستی بەسەردا بگرن،  
\v 5 ئەگەر گوێڕایەڵی یەزدانی پەروەردگارتان بوون، هەتا هەموو ئەو فەرمانانەی من ئەمڕۆ فەرمانتان پێ دەکەم، بپارێزن و کاریان پێ بکەن.  
\v 6 یەزدانی پەروەردگارتان بەرەکەتدارتان دەکات وەک بەڵێنی پێدان، جا قەرز بە زۆربەی نەتەوەکان دەدەن و ئێوە قەرز ناکەن، بەسەر زۆربەی نەتەوەکاندا دەسەڵاتتان دەبێت و ئەوان بەسەرتانەوە دەسەڵاتدار نابن. 
\p  
\v 7 ئەگەر هەژارێک لەنێوتان بوو، یەکێک لە برایانتان لە شارۆچکەیەکی خاکەکەتان کە یەزدانی پەروەردگارتان پێتانی دەدات، ئەوا دڵتان ڕەق مەکەن و لە ئاست برا هەژارەکانتان دەستتان دامەخەن،  
\v 8 بەڵکو دەستتانی بۆ بکەنەوە و ئەوەی پێویستی بە قەرزە بیدەنێ.  
\v 9 ئاگاداربن لەوەی بیرێکی خراپتان لە دڵدا بێت و بڵێن، «ئەوا ساڵی حەوتەم نزیک بووەتەوە، ساڵی بەتاڵکردنەوەی قەرزەکانە،» ئیتر بە خراپی ڕەفتار لەگەڵ هەژار بکەن و نەیدەنێ، جا ئەویش بۆ یەزدان هاوار دەکات سەبارەت بە ئێوە و دەبێتە گوناه بەسەرتانەوە.  
\v 10 بە دڵفراوانییەوە پێی ببەخشن و با بە نابەدڵی نەبێت کاتێک دەیدەنێ، چونکە بەهۆی ئەم شتەوە یەزدانی پەروەردگارتان بەرەکەتدارتان دەکات لە هەموو کارەکانتان و لە هەموو ئەوەی دەستی بۆ دەبەن.  
\v 11 لەبەر ئەوەی هەژار لە خاکەکەدا کۆتایی نایەت، بۆیە من فەرمانتان پێدەدەم و دەڵێم: «دەستی یارمەتیتان بکەنەوە بۆ برای نەدارتان و بۆ هەژاران لە خاکەکەتان.» 
\s1 ئازادکردنی خزمەتکار 
\p  
\v 12 ئەگەر برایەک یان خوشکێکی عیبرانیت پێ فرۆشرا و شەش ساڵ خزمەتی کردیت، ئەوا لە ساڵی حەوتەم لەلای خۆت ئازادی دەکەیت.  
\v 13 کاتێک ئازادیشی دەکەیت، بە دەستبەتاڵی ئازادی ناکەیت.  
\v 14 بەڵکو بە دڵفراوانییەوە لە مێگەلەکەت و جۆخینەکەت\f + \fr 15:14 \ft جۆخین یان سەرخەرمان ئەو زەوییە تەرخانکراوەیە کە لەلایەن وەرزێر و جوتیارەوە بەکارهێنراوە بۆ کوتانی دانەوێڵە لەسەری لەدوای کۆکردنەوەی لە کێڵگە.‏\f* و گوشەرەکەتی\f + \fr 15:14 \ft گوشەرەکەتی: بەرهەمەکەی ئاوی ترێیە، بڕوانە \xt سەرژمێری 18‏:27‏\ft ‏.‏\f* پێدەدەیت، بەو شێوەیەی یەزدانی پەروەردگارت بەرەکەتداری کردوویت، پێی دەدەیت.  
\v 15 لە یادت بێت تۆش لە خاکی میسر کۆیلە بوویت، جا یەزدانی پەروەردگارت تۆی کڕییەوە، بۆیە من ئەمڕۆ فەرمانی ئەمەت پێ دەکەم. 
\p  
\v 16 بەڵام ئەگەر گوتی، «واز لە تۆ ناهێنم،» چونکە خۆت و ماڵەکەتی خۆشدەوێت، لەبەر ئەوەی لەلای تۆ لە خۆشیدا بووە،  
\v 17 ئەوا درێشە ببە و لەلای دەرگاکە گوێی کون بکە، جا بۆ هەتاهەتایە دەبێتە کۆیلەت، ئاواش بۆ کارەکەرەکەت دەکەیت. 
\p  
\v 18 بە لاتەوە گران نەبێت خزمەتکارەکەت ئازاد بکەیت، چونکە شەش ساڵ خزمەتی کردوویت، دوو هێندەی کرێگرتەیەک، جا یەزدانی پەروەردگارت بەرەکەتدارت دەکات لە هەموو ئەوەی کە دەیکەیت. 
\s1 نۆبەرە ئاژەڵەکان 
\p  
\v 19 هەموو نۆبەرەیەکی نێرینەی مانگا و مەڕەکانت بۆ یەزدانی پەروەردگارت تەرخان دەکەیت، کار بە نۆبەرەی مانگاکەت مەکە و خوری نۆبەرەی مەڕەکانت مەبڕەوە.  
\v 20 ساڵ بە ساڵ لەبەردەم یەزدانی پەروەردگارت دەیخۆیت لەو شوێنەی یەزدان هەڵیدەبژێرێت، خۆت و ماڵەکەت.  
\v 21 بەڵام ئەگەر ئاژەڵێک کەموکوڕییەکی تێدابێت، وەک شەلی یان کوێری، هەر کەموکوڕییەکی خراپ، ئەوا بۆ یەزدانی پەروەردگارت سەری مەبڕە،  
\v 22 لە شارۆچکەی خۆتدا دەیخۆیت، کەسی گڵاو و پاک بەپێی ڕێوڕەسم وەک یەک، وەک چۆن مامز و ئاسک دەخۆن.  
\v 23 بەڵام خوێنەکەی نەخۆیت، وەک ئاو دەیڕێژیتە سەر زەوی. 
\c 16  
\s1 جەژنی پەسخە 
\p  
\v 1 مانگی ئاڤیڤ بپارێزن و جەژنی پەسخە بۆ یەزدانی پەروەردگارتان بکەن، چونکە لە مانگی ئاڤیڤدا یەزدانی پەروەردگارتان بە شەو لە میسر دەریهێنان.  
\v 2 جا لە جەژنی پەسخە مانگا و مەڕ بۆ یەزدانی پەروەردگارتان سەردەبڕن، لەو شوێنەی یەزدان هەڵیدەبژێرێت بۆ ئەوەی ناوی لەوێ بێت.  
\v 3 هیچ نانێکی بە هەویرترشی\f + \fr 16:3 \ft هەویرترش: لە جیاتی خومرە بۆ هەوێن بەکارهاتووە.‏\f* لەگەڵ نەخۆن، حەوت ڕۆژ نانی فەتیرە دەخۆن، نانی تەنگانە، چونکە بە پەلە لە خاکی میسر هاتنە دەرەوە، هەتا هەموو ڕۆژانی ژیانتان، ڕۆژی هاتنەدەرەوەتان لە خاکی میسر لە یاد بێت.  
\v 4 لە هەموو سنوورەکانتان نابێت هەویرترش ببینرێت بۆ حەوت ڕۆژ و نابێت هیچ لەو گۆشتەی ئێوارە کە ڕۆژی یەکەم سەری دەبڕن بۆ بەیانی بمێنێتەوە. 
\p  
\v 5 بۆتان نییە قوربانی جەژنی پەسخە لە یەکێک لە شارۆچکەکانتان سەرببڕن کە یەزدانی پەروەردگارتان دەتانداتێ،  
\v 6 بەڵکو لەو شوێنەی یەزدانی پەروەردگارتان هەڵیدەبژێرێت هەتا ناوی لەوێ بێت، لەوێ قوربانی پەسخە سەردەبڕن لە ئێوارە، دەمەو خۆر ئاوابوون، لە کاتی یادکردنەوەی ساڵانەی هاتنەدەرەوەتان لە میسر.  
\v 7 لەو شوێنەی یەزدانی پەروەردگارتان هەڵیدەبژێرێت، لێی دەنێن و دەیخۆن و ئینجا بۆ بەیانی دەگەڕێنەوە چادرەکانتان.  
\v 8 شەش ڕۆژ نانی فەتیرە دەخۆن و ڕۆژی حەوتەمیش ئاهەنگی کۆتایی دەگێڕن بۆ یەزدانی پەروەردگارتان، هیچ کارێکی تێدا ناکەن. 
\s1 جەژنی هەفتەکان 
\p  
\v 9 حەوت هەفتە دەژمێرن بۆ خۆتان، لە دەستپێکردنی دروێنەی دەغڵ دەستپێدەکەن.  
\v 10 جەژنی هەفتەکان\f + \fr 16:10 \ft جەژنی هەفتەکان، هەروەها وەک جەژنی دروێنەش ناسراوە (بڕوانە \xt دەرچوون 23‏:16‏\ft ‏)، 50 ڕۆژ دوای جەژنی فەتیرە بووە، کە دەکاتە حەوت هەفتە.‏\f* بۆ یەزدانی پەروەردگارتان دەگێڕن، بەگوێرەی ئەوەی لە دەستتان دێتەدەر بەخشینێکی ئازاد دەبەخشن، وەک ئەوەندەی یەزدانی پەروەردگارتان بەرەکەتداری کردوون.  
\v 11 جا خۆتان و کوڕ و کچ و خزمەتکار و کارەکەرەکانتان، هەروەها ئەو لێڤییانەی کە لە شارۆچکەکانتانن و ئەو نامۆ و هەتیو و بێوەژنانەی کە لەنێوتانن لەبەردەم یەزدانی پەروەردگارتان دڵخۆش دەبن، لەو شوێنەی یەزدانی پەروەردگارتان هەڵیدەبژێرێت هەتا ناوی لەوێ بێت.  
\v 12 لە یادتان بێت ئێوەش لە میسر کۆیلە بوون، بۆیە ئەو فەرزانە بەجێدەهێنن و پەیڕەویان دەکەن. 
\s1 جەژنی کەپرەشینە 
\p  
\v 13 حەوت ڕۆژان جەژنی کەپرەشینە بۆ خۆتان دەکەن، کاتێک بەرهەم لە جۆخین و گوشەرەکەتان\f + \fr 16:13 \ft گوشەرەکەتان: بەرهەمەکەی ئاوی ترێیە، بڕوانە \xt سەرژمێری 18‏:27‏\ft ‏.‏\f* کۆدەکەنەوە.  
\v 14 جا بە جەژنەکەتان خۆتان و کوڕ و کچ و خزمەتکار و کارەکەرەکانتان، هەروەها ئەو لێڤی و نامۆ و هەتیو و بێوەژنانەی لە شارۆچکەکانتاندان دڵخۆش دەبن.  
\v 15 حەوت ڕۆژان بۆ یەزدانی پەروەردگارتان جەژن دەگێڕن لەو شوێنەی یەزدان هەڵیدەبژێرێت، چونکە یەزدانی پەروەردگارتان بەرەکەتدارتان دەکات لە هەموو بەروبوومێک و لە هەموو کردارێکی دەستتان، جا بێگومان دڵخۆش دەبن. 
\p  
\v 16 سێ جار لە ساڵێکدا هەموو نێرینەکانتان لەبەردەم یەزدانی پەروەردگارتان ئامادە دەبن، لەو شوێنەی کە خۆی هەڵیدەبژێرێت: لە جەژنی فەتیرە و جەژنی هەفتەکان و جەژنی کەپرەشینە. نابێت بە دەستبەتاڵی لەبەردەم یەزدان ئامادە بن،  
\v 17 بەپێی ئەو بەرەکەتەی یەزدانی پەروەردگارت پێت دەبەخشێت، هەریەکە بەگوێرەی ئەوەی لە دەستی دێتەدەر. 
\s1 دادوەران 
\p  
\v 18 دادوەران و کوێخاکان بۆ خۆتان دادەنێن لە هەموو شارۆچکەکانتان کە یەزدانی پەروەردگارتان پێتانی دەدات بەگوێرەی هۆزەکانتان، جا ئەوانیش دادوەرییەکی ڕاستودروست بۆ گەل دەکەن.  
\v 19 دادوەری خوار مەکەنەوە و لایەنگری کەس مەکەن و بەرتیل وەرمەگرن، چونکە بەرتیل چاوی داناکان کوێر دەکات و قسەی ڕاستودروستان خوار دەکات.  
\v 20 دادوەری پەیڕەو دەکەن و تەنها دادوەری، هەتا بژین و دەست بەسەر ئەو خاکەدا بگرن کە یەزدانی پەروەردگارتان پێتانی دەدات. 
\s1 پەرستنی خودایەکی دیکە 
\p  
\v 21 هیچ ستوونە ئەشێرایەک لە هیچ دارێک بۆ خۆتان ناچێنن لەتەنیشت قوربانگاکەی یەزدانی پەروەردگارتانەوە کە بۆ خۆتان دروستی دەکەن،  
\v 22 هیچ بەردێکی تەرخانکراو بۆ خۆتان ڕامەگرن، ئەوەی یەزدانی پەروەردگارتان ڕقی لێیەتی. 
\c 17  
\p  
\v 1 بۆ یەزدانی پەروەردگارتان گایەک یان بەرخێک سەرمەبڕن کە کەموکوڕییەک یان شتێکی خراپی تێدابێت، چونکە ئەوە قێزەونە لەلای یەزدانی پەروەردگارتان. 
\p  
\v 2 ئەگەر لەنێوتان، لە یەکێک لە شارۆچکەکانتان کە یەزدانی پەروەردگارتان پێتانی دەدات، پیاوێک یان ئافرەتێک بینرا کارێک دەکات کە لەلای یەزدانی پەروەردگارتان خراپە و پەیمانەکەی دەشکێنێت و  
\v 3 بە پێچەوانەی فەرمانی منەوە، خوداوەندی دیکە، خۆر، مانگ یان هەر یەکێک لە ئەستێرەکانی ئاسمان دەپەرستێت و کڕنۆشی بۆ دەبات،  
\v 4 جا پێتان ڕاگەیەنرا و بیستتان، دەبێت ئێوە باش لێی بکۆڵنەوە. ئەگەر تاوانبارکردنەکە ڕاست بوو و بێگومان ئەو کارە قێزەونە لە ئیسرائیل کرابوو،  
\v 5 ئەوا ئەو پیاوە یان ئەو ئافرەتەی ئەو بەدکارییەی کردووە، دەریبکەن بۆ لای دەروازەی شارەکەتان و بەردبارانی بکەن هەتا دەمرێت.  
\v 6 ئەوەی بکوژرێت لەسەر زاری دوو شایەت یان سێ شایەت دەکوژرێت، نابێت لەسەر زاری یەک شایەت بکوژرێت.  
\v 7 یەکەم جار دەستی شایەتەکانی بەسەرەوە دەبێت بۆ کوشتنی پاشان دەستی هەموو گەل، جا خراپەکە لەنێو خۆتان دادەماڵن. 
\s1 دادگا 
\p  
\v 8 ئەگەر داوایەکتان بەلاوە سەخت بوو لە بڕیاردان، چ لە تاوانی ڕووداوی کوشتن یان داواکاری ماف یان پەلاماردان، لە کاروباری ناکۆکی لە دادگاکانتان، ئەوا هەستن و بڕۆن بۆ ئەو شوێنەی یەزدانی پەروەردگارتان هەڵیدەبژێرێت.  
\v 9 بڕۆنە لای کاهینە لێڤییەکان و لای ئەو دادوەرەی لەو ڕۆژانەدایە و بپرسن، جا حوکمی بڕیارەکەتان پێ ڕادەگەیەنن.  
\v 10 دەبێت ئەو بڕیارەی کە پێتانی ڕادەگەیەنن جێبەجێی بکەن، لەو شوێنەی یەزدان هەڵیدەبژێرێت. ئاگاداربن لەوەی ڕێک ئەوە بکەن کە فێرتان دەکەن.  
\v 11 بەپێی ئەو ڕێنماییە فێرتان دەکەن و ئەو حوکمەی پێتانی دەڵێن، وا دەکەن، لەو شتانە لامەدەن کە پێتانی ڕادەگەیەنن، نە بەلای ڕاست و نە بەلای چەپ.  
\v 12 هەرکەسێکیش کە بە لووتبەرزییەوە دەجوڵێتەوە و گوێ لەو کاهینە ناگرێت کە لەوێ ڕاوەستاوە بۆ ئەوەی یەزدانی پەروەردگارتان بپەرستێت، یان گوێ لە دادوەرەکە ناگرێت، ئەوا دەبێت بکوژرێت و ئەو خراپەیە لە ئیسرائیلدا دابماڵرێت.  
\v 13 جا هەموو گەل دەبیستن و دەترسن و لەپاش ئەوە لووتبەرزانە ناجوڵێنەوە. 
\s1 پاشاکە 
\p  
\v 14 کاتێک هاتنە ئەو خاکەی کە یەزدانی پەروەردگارتان دەتانداتێ و دەستتان بەسەردا گرت و تێیدا نیشتەجێ بوون، جا ئەگەر بڵێن، «پاشایەک بۆ خۆمان دادەنێین وەک هەموو ئەو نەتەوانەی دەوروبەرمان،»  
\v 15 ئەوا ئەو پاشایە بۆ خۆتان دادەنێن کە یەزدانی پەروەردگارتان هەڵیدەبژێرێت، یەکێک لە براکانتان بۆ خۆتان دەکەنە پاشا، بۆتان نییە یەکێکی بێگانە دابنێن کە ئیسرائیلییەکی براتان نییە.  
\v 16 بەڵام با ئەو پاشایە ئەسپ بۆ خۆی زۆر نەکات و گەل نەنێرێتەوە بۆ میسر، بۆ ئەوەی ئەسپی زۆرتر بەدەستبهێنێت، چونکە یەزدان پێی فەرموون: «نەکەن جارێکی دیکە بەو ڕێگایەدا بگەڕێنەوە.»  
\v 17 هەروەها با ژن بۆ خۆی زۆر نەکات، نەوەک دڵی لابدات. با زێڕ و زیویش بۆ خۆی گەلێک زۆر نەکات. 
\p  
\v 18 کاتێک لەسەر تەختی پاشایەتییەکەشی دادەنیشێت، با وێنەیەک لەم فێرکردنە لە پەڕتووکێک لەلای کاهینە لێڤییەکان بۆ خۆی بنووسێتەوە.  
\v 19 جا بە درێژایی ژیانی لەلای دەبێت و لێی دەخوێنێتەوە، بۆ ئەوەی فێر بێت لە یەزدانی پەروەردگاری خۆی بترسێت و هەموو وشەکانی ئەم فێرکردنە و ئەم فەرزانە بەجێبهێنێت هەتا پەیڕەویان بکات.  
\v 20 نەوەک بەسەر براکانیدا لووتبەرز بێت، نەوەک لە فەرمانەکان بەلای ڕاست یان بەلای چەپدا لابدات، بۆ ئەوەی درێژە بە ماوەی پاشایەتییەکەی بدات، خۆی و نەوەکانی لەنێو ئیسرائیل. 
\c 18  
\s1 پێشکەشکراوەکان بۆ کاهینان و لێڤییەکان 
\p  
\v 1 کاهینە لێڤییەکان و هەموو هۆزی لێڤی بەش و میراتیان لەگەڵ ئیسرائیل نابێت، بەڵکو قوربانییە بە ئاگرەکان بۆ یەزدان بەشی ئەوانە، چونکە ئەمە میراتە بۆیان.  
\v 2 جا لەناو براکانیان میراتیان نابێت، یەزدان میراتی ئەوانە وەک بەڵێنی پێدان. 
\p  
\v 3 ئەمەش مافی کاهین دەبێت لەسەر گەل، لەوانەی قوربانی سەردەبڕن، جا گا بێت یان مەڕ\f + \fr 18:3 \ft مەبەستی لە هەر ئاژەڵێکی بچووکە کە لە مێگەل بێت وەک مەڕ، بزن، گوێرەکە… هتد.‏\f*، شان و شەویلاکی خوارەوە و گۆشتی لاملی و ناوسکەکەی بە کاهین دەدرێن.  
\v 4 هەروەها یەکەمین بەرهەمی دانەوێڵە و شەرابی تازە و زەیت و یەکەم بڕینەوەی خوری مەڕەکانتانی پێدەدەن،  
\v 5 چونکە یەزدانی پەروەردگارتان لەناو هەموو هۆزەکانتان هەڵیبژاردن هەتا بوەستن بۆ خزمەتکردن بە ناوی یەزدانەوە، خۆیان و کوڕەکانیان هەتاهەتایە. 
\p  
\v 6 ئەگەر لێڤییەک لە هەر یەکێک لە شارۆچکەکانی ئیسرائیل، لەو شوێنەی دەژیێت و پڕ بە دڵی خۆی هات بۆ ئەو شوێنەی کە یەزدان هەڵیدەبژێرێت و  
\v 7 بە ناوی یەزدانی پەروەردگارییەوە خزمەتی کرد، وەک هەموو برا لێڤییەکانی کە لەوێ لەبەردەم یەزدان وەستاون،  
\v 8 ئەوا بەشیان یەکسان دەبێت لە خواردن، بێجگە لەوەی لە میراتی خێزانەکەی دەفرۆشرێت. 
\s1 نەریتە قێزەونەکان 
\p  
\v 9 کاتێک چوونە ناو ئەو خاکەی کە یەزدانی پەروەردگارتان پێتان دەدات، فێر مەبن وەک نەریتە قێزەونەکانی ئەو نەتەوانە بکەن.  
\v 10 ئەوانەتان تێدا نەبێت کە کوڕەکەی یان کچەکەی وەک قوربانی بسووتێنێت، هەروەها نە ئەوانەی فاڵگرتنەوە دەکەن و نە بەخت خوێندنەوە و نە جادووگەری و نە سیحربازی،  
\v 11 نە ئەوانەی نوشتە دەکەن و نە ئەوانەی نێوانگرن\f + \fr 18:11 \ft نێوانگرن: لێرە بەو واتایە دێت، کەسێکە کە گوایە هۆی پەیوەندی ڕێکخەرە لەنێوان خەڵکی مردوو و زیندوودا. بڕوانە \xt لێڤییەکان 19‏:31‏\ft ‏.‏\f* و نە ئەوانەی ڕۆح ئامادەکارن\f + \fr 18:11 \ft ڕۆح ئامادەکارن: بەو کەسانە دەگوترێت کە ڕۆح ئامادە دەکەن. بڕوانە \xt یەکەم ساموئێل 28‏:3 و 8‏–9‏\ft ‏.‏\f* و نە ئەوانەی ڕاوێژ بە مردووان دەکەن،  
\v 12 چونکە هەرکەسێک ئەم نەریتانە پەیڕەو بکات لەلای یەزدان قێزەونە، هەر بەهۆی ئەم نەریتە قێزەونانەیە یەزدانی پەروەردگارتان نەتەوەکان لەبەردەمتان ڕاو دەنێت.  
\v 13 لەلای یەزدانی پەروەردگارتان بێ کەموکوڕی دەبن. 
\s1 پێغەمبەرەکە 
\p  
\v 14 ئەو نەتەوانەی ئێوە جێیان دەگرنەوە گوێ لە بەخت خوێنەر و فاڵگرەوان دەگرن، بەڵام بۆ ئێوە یەزدانی پەروەردگارتان بەم شێوەیە ڕێی نەداوە.  
\v 15 یەزدانی پەروەردگارتان لەنێوتان لە براکانتان پێغەمبەرێکی وەک منتان بۆ دەستنیشان دەکات، دەبێت گوێی لێ بگرن.  
\v 16 بەگوێرەی هەموو ئەو شتانەی لە یەزدانی پەروەردگارتان داوا کرد لە حۆرێڤ لە ڕۆژی کۆبوونەوە و گوتتان: «با ئیتر گوێمان لە دەنگی یەزدانی پەروەردگارمان نەبێت و ئەم ئاگرە مەزنەش نەبینینەوە، نەوەک بمرین.» 
\p  
\v 17 یەزدانیش پێی فەرمووم: «چاکیان کرد لەوەی گوتیان،  
\v 18 لەنێو براکانیان پێغەمبەرێکی وەک تۆیان بۆ دادەنێم و وتەکانم دەخەمە دەمی و ئەوەی فەرمانی پێدەدەم ئەو بۆیان پێی دەدوێت.  
\v 19 جا ئەو کەسەی گوێ لە وشەکانم نەگرێت کە ئەو پێغەمبەرە بە ناوی منەوە دەیڵێت، ئەوا لێپرسینەوەی لەگەڵ دەکەم.  
\v 20 بەڵام ئەو پێغەمبەرەی لووتبەرز دەبێت و بە ناوی منەوە قسەیەک دەکات کە من فەرمانم پێی نەکردووە بیکات، یان ئەوەی بە ناوی خودای دیکەوە قسە بکات، ئەو پێغەمبەرە دەبێت بمرێت.» 
\p  
\v 21 ئەگەر لە دڵتانەوە بڵێن، «چۆن ئەو قسەیە بزانین کە یەزدان نەیفەرمووە؟»  
\v 22 ئەوا ئەوەی پێغەمبەرێک بە ناوی یەزدانەوە قسەی پێکردووە و ڕووی نەدا و نەبوو، ئەوە ئەو قسەیەیە کە یەزدان نەیفەرمووە، بەڵکو ئەو پێغەمبەرە بە لووتبەرزییەوە گوتوویەتی، جا لێی مەترسن. 
\c 19  
\s1 شارەکانی پەناگا 
\p  
\v 1 کاتێک یەزدانی پەروەردگارتان ئەو نەتەوانەی قڕکرد کە یەزدانی پەروەردگارتان خاکەکەیانتان دەداتێ و کاتێک دەرتانکردن و لە شار و ماڵەکانیان نیشتەجێ بوون،  
\v 2 سێ شار لە ناوەڕاستی خاکەکەتان بۆ خۆتان جیا دەکەنەوە کە یەزدانی پەروەردگارتان دەتانداتێ هەتا دەستی بەسەردا بگرن.  
\v 3 ڕێگا دروستدەکەن و ئەو خاکەی کە یەزدانی پەروەردگارتان بە میرات دەتانداتێ، دەیکەن بە سێ بەشی سنووردار، تاکو ئەو کەسەی کەسێک بکوژێت بۆ ئەوێ هەڵبێت. 
\p  
\v 4 ئەم یاسایە بۆ ئەوەیە، ئەگەر کەسێک بەبێ ئەنقەست لە هاوڕێکەی دا کە پێشتر ناحەزی ئەو نەبووە، بۆ ئەوێ هەڵدێت، ئیتر دەژیێت.  
\v 5 بۆ نموونە، یەکێک لەگەڵ هاوڕێکەی بچێتە ناو دارستان بۆ داربڕین و لە کاتی تەور وەشاندن ئاسنەکە لە داردەستەکە دەرپەڕێت و لە هاوڕێکەی بدات و بمرێت. ئەو کەسە بۆ یەکێک لەو شارانە هەڵدێت و دەژیێت.  
\v 6 ئەگینا خوێنگرەکە لە تووڕەییدا بەدوای تۆمەتبارکراوەکە دەکەوێت و بەهۆی دووری ڕێگاکە بۆ شاری پەناگا، لە ڕێگا پێی دەگات و دەیکوژێت، لە کاتێکدا ئەو شایانی مردن نییە، چونکە پێشتر ئەو ناحەزی هاوڕێکەی نەبووە.  
\v 7 بۆیە من فەرمانتان پێدەدەم کە سێ شار بۆ خۆتان جیا بکەنەوە. 
\p  
\v 8 ئەگەر یەزدانی پەروەردگارتان سنووری فراوان کردن وەک سوێندی بۆ باوباپیرانتان خوارد و هەموو ئەو خاکەی پێدان کە بەڵێنی بە باوباپیرانتان دا بیانداتێ،  
\v 9 چونکە هەموو ئەم فەرمانانەتان پاراست هەتا جێبەجێی بکەن وەک ئەوەی من ئەمڕۆ فەرمانتان پێدەدەم، هەتا یەزدانی پەروەردگارتان خۆشبوێت و هەموو ڕۆژان ڕێگاکانی بگرنەبەر، ئەوا سێ شاری دیکەش بۆ خۆتان زیاد بکەن لەسەر ئەم سێیە.  
\v 10 ئەوە بکەن بۆ ئەوەی خوێنی بێتاوانێک لەناو خاکەکەتان نەڕژێت کە یەزدانی پەروەردگارتان بە میرات دەتانداتێ، جا تاوانی خوێنڕشتنتان لەسەر دەبێت. 
\p  
\v 11 بەڵام ئەگەر کەسێک ڕقی لە دراوسێکەی بێت و بۆسەی بۆ نایەوە و لێی هەستا و لێدانێکی کوشندەی لێدا و مرد و ئینجا بکوژەکە بۆ یەکێک لەو شارانە هەڵات،  
\v 12 ئەوا پیرانی شارۆچکەکەی خۆی دەنێرن و لەوێ دەیهێننەوە و دەیدەنە دەست خوێنگری تۆڵەسێنەر و دەکوژرێت.  
\v 13 بەزەییتان پێیدا نەیەتەوە، جا تاوانی ڕشتنی خوێنە بێتاوانەکە لە ئیسرائیلدا دادەماڵی و چاکەتان بۆ دەبێت. 
\p  
\v 14 سنووری بەردڕێژکراوی زەوی دراوسێکەت مەگوێزەوە کە ئەوانەی یەکەم جار دایانناوە، لەو میراتەی بەرت دەکەوێت لەو زەوییەی یەزدانی پەروەردگارت پێت دەدات هەتا ببیتە خاوەنی. 
\s1 شایەتی 
\p  
\v 15 یەک شایەت بەس نییە بۆ تاوانبارکردنی کەسێک بە ئەنجامدانی تاوانێک یان هەڵەیەک، لە هەر تاوانێک کە دەیکات. هەر تاوانێک لەسەر زاری دوو یان سێ شایەت ڕاستییەکەی دەسەلمێنرێت. 
\p  
\v 16 ئەگەر شایەتێکی درۆ دەرکەوت بۆ ئەوەی بە چەوتی شایەتی لەسەر کەسێک بدات،  
\v 17 ئەوا هەردوو پیاوەکەی ناکۆکییان لەنێوانە، لەبەردەم یەزدان، لەبەردەم کاهینەکان و ئەو دادوەرانەی لەو ڕۆژانەدان ڕادەوەستن،  
\v 18 جا ئەگەر دادوەران باش لێیان کۆڵییەوە و زانییان شایەتەکە شایەتێکی درۆزنە و بە درۆ شایەتی لەسەر براکەی داوە،  
\v 19 ئەوا ئەوەی پێ بکەن کە دەیویست بە براکەی بکات، جا خراپەکە لەنێو خۆتان دادەماڵن و  
\v 20 ئەوانی دیکە دەبیستن و دەترسن و ئەو کارە خراپە لەنێوتاندا دووبارە ناکرێتەوە.  
\v 21 بەزەییتان نەبێت، گیان بە گیان، چاو بە چاو، ددان بە ددان، دەست بە دەست، پێ بە پێ. 
\c 20  
\s1 چوون بۆ جەنگ 
\p  
\v 1 کاتێک دەچن بۆ ئەوەی لە دژی دوژمنەکانتان بجەنگن، ئەسپ و گالیسکە و سوپایەکی لە خۆتان زۆرترتان بینی، لێیان مەترسن، چونکە یەزدانی پەروەردگارتان لەگەڵتانە، ئەوەی کە لە خاکی میسر دەریهێنان.  
\v 2 کاتێک لە جەنگ نزیک دەکەونەوە کاهینەکە دێتە پێش و وتار بۆ گەل دەدات،  
\v 3 پێیان دەڵێت: «ئەی ئیسرائیل گوێ بگرە، ئێوە ئەمڕۆ لە جەنگ لە دژی دوژمنەکانتان نزیک بوونەتەوە، ورەتان نەڕووخێت، لێیان مەترسن و مەتۆقن و سام نەتانگرێت،  
\v 4 چونکە یەزدانی پەروەردگارتان لەگەڵتان دەڕوات، هەتا بۆ ئێوە لە دژی دوژمنەکانتان بجەنگێت و سەرکەوتووتان بکات.» 
\p  
\v 5 ئینجا سەرکردەکان قسە بۆ سوپا دەکەن و دەڵێن: «کێ خانووێکی نوێی بنیاد ناوە و نەیکردووەتەوە، با بڕوات و بگەڕێتەوە بۆ ماڵەکەی، نەوەک لە جەنگەکەدا بکوژرێت و پیاوێکی دیکە بیکاتەوە.  
\v 6 کێ ڕەزەمێوێکی چاندووە و لە یەکەم بەری نەخواردووە؟ با بڕوات و بگەڕێتەوە ماڵەکەی، نەوەک لە جەنگەکەدا بکوژرێت و پیاوێکی دیکە یەکەم بەری بخوات.  
\v 7 کێ ژنێکی مارە کردووە و نەیگواستووەتەوە، با بڕوات و بگەڕێتەوە ماڵەکەی، نەوەک لە جەنگەکەدا بکوژرێت و پیاوێکی دیکە بیگوازێتەوە.»  
\v 8 ئینجا دووبارە سەرکردەکان قسە بۆ گەل دەکەن و دەڵێن: «کێ دەترسێت و ورەی ڕووخاوە؟ با بڕوات و بگەڕێتەوە بۆ ماڵەکەی، نەوەک دڵی براکانیشی بتۆقێت وەک خۆی.»  
\v 9 کاتێک سەرکردەکان لە قسەکردن لەگەڵ گەل تەواو دەبن، فەرماندەکان بۆ سوپا دادەنێن. 
\p  
\v 10 کاتێک لە شارێک نزیک دەبنەوە بۆ ئەوەی لەگەڵیدا بجەنگن، بانگی بکەن بۆ ڕێککەوتن.  
\v 11 جا ئەگەر بۆ ئاشتبوونەوە وەڵامی دانەوە و دەرگای بۆ کردنەوە، ئەوا هەموو ئەو گەلەی تێیدان بۆ ئێوە بێگاری\f + \fr 20:11 \ft بێگاری: واتا بە زۆرەملێ.‏\f* و کارت بۆ دەکەن.  
\v 12 بەڵام ئەگەر ئاشتییان نەویست و لە دژتان جەنگان ئەوا ئابڵوقەی بدەن.  
\v 13 کاتێک یەزدانی پەروەردگارتان ئەوی دایە دەستتان، ئەوا بە شمشێر لە هەموو پیاوەکانی بدەن،  
\v 14 بەڵام ئافرەت و منداڵ و ئاژەڵی ماڵی و هەموو شتێکی دیکە کە لەناو شارەکەیە، هەموو تاڵانییەکە دەبێتە دەستکەوتتان، ئەو دەستکەوتانەی دوژمنانتان بەکاردەهێنن کە یەزدانی پەروەردگارتان پێتانی دا.  
\v 15 ئاوا دەکەن بە هەموو ئەو شارانەی زۆر لە ئێوە دوورن، ئەوانەی لە شارەکانی ئەم گەلانەی ئێرە نین. 
\p  
\v 16 بەڵام شارەکانی ئەم گەلانەی کە یەزدانی پەروەردگارتان بە میرات دەتانداتێ، هیچ هەناسەیەکی لێ مەهێڵنەوە.  
\v 17 بەڵکو بە تەواوی لەناویان ببەن\f + \fr 20:17 \ft بە تەواوی لەناویان دەبەن: لە زمانی عیبری ئەم زاراوەیە دەگەڕێتەوە بۆ شتێک یان کەسێک کە دەبەخشرێت بە یەزدان، زۆر جار بەخشینەکە بە تەواوی لە ناودەبردرێت.‏\f*، حیتی و ئەمۆری و کەنعانی و پریزی و حیڤی و یەبوسییەکان، هەروەک یەزدانی پەروەردگارتان فەرمانی پێ کردن،  
\v 18 نەوەک فێرتان بکەن وەک هەموو نەریتە قێزەونەکانیان بکەن کە ئەوان بۆ خوداوەندەکانیان دەیکەن، ئێوەش سەبارەت بە یەزدانی پەروەردگارتان تووشی گوناه دەبن. 
\p  
\v 19 ئەگەر بۆ چەندین ڕۆژ ئابڵوقەی شارێکتان دا، جەنگتان لە دژی بەرپا کرد هەتا بیگرن، دارەکان بە تەور لەناو مەبەن و مەیانبڕنەوە، چونکە دەتوانن لە بەروبوومیان بخۆن. ئایا داری ڕەز مرۆڤە تاکو ئابڵوقەی بدەیت؟  
\v 20 بەڵام ئەو دارانەی کە دەزانن لێیان ناخورێن، ئەوا دەتوانن ئەوانە تێکبدەن و بیانبڕنەوە بۆ دروستکردنی سەنگەر لە دژی ئەو شارەی کە جەنگتان لەگەڵ دەکات هەتا دەکەوێت. 
\c 21  
\s1 کەفارەت بۆ نەدۆزینەوەی بکوژ 
\p  
\v 1 ئەگەر کوژراوێک لەو خاکە دۆزرایەوە کە یەزدانی پەروەردگارتان پێتان دەدات هەتا دەستی بەسەردا بگرن، لە کێڵگەیەک کەوتبوو و نەزانرا کێ کوشتوویەتی،  
\v 2 ئەوا پیران و دادوەرانتان دەچن و دووری نێوان کوژراوەکە و ئەو شارۆچکانەی دەوروبەری دەپێون.  
\v 3 جا پیرانی نزیکترین شارۆچکە لە کوژراوەکە گوێرەکەیەکی مێینەی سێ ساڵە دەبەن کە هێشتا جووتی پێ نەکرابێت، نیری لەسەر دانەنرابێت.  
\v 4 پاشان پیرانی ئەو شارۆچکەیە گوێرەکەکە بۆ دۆڵێک دەبەنە خوارەوە کە جۆگەیەکی ئاوی لەبەرڕۆیشتووی تێدابێت و نەکێڵرابێت و نەچێنرابێت و لە دۆڵەکە ملی دەشکێنن\f + \fr 21:4 \ft ملی نوێنگینەکە دەشکێنن: ئەمە قوربانیدان بۆ گوناه نییە. بڕوانە \xt دەرچوون 13‏:13 و 34‏:20.‏\ft ‏\f*.  
\v 5 دواتر کاهینەکان، نەوەی لێڤی دێنە پێشەوە، چونکە یەزدانی پەروەردگارتان ئەوانی هەڵبژاردووە هەتا خزمەتی بکەن و بە ناوی یەزدانەوە داوای بەرەکەت بکەن، جا هەموو ناکۆکی و پەلاماردانێک بەگوێرەی قسەی ئەوان یەکلا دەکرێتەوە.  
\v 6 ئینجا هەموو پیرانی ئەو شارۆچکەیەی کە لە کوژراوەکە نزیکە لە دۆڵەکە دەستیان دەشۆن، لەو شوێنەی کە گوێرەکە ملشکاوەکەی لێیە و  
\v 7 ڕایدەگەیەنن: «دەستەکانمان ئەم خوێنەیان نەڕشتووە و چاوەکانمان نەیانبینیوە.  
\v 8 ئەی یەزدان، کەفارەتی ئیسرائیلی گەلی خۆت بکە کە کڕیتەوە و خوێنێکی بێتاوان مەخەرە ملی ئیسرائیلی گەلەکەت.» جا کەفارەتی ئەو خوێنەیان بۆ دەبێت.  
\v 9 تاوانی ڕشتنی خوێنە بێتاوانەکەش لەنێوتان دادەماڵن، چونکە ئەوەی لەبەرچاوی یەزدان ڕاست بوو، ئێوە کردتان. 
\s1 هێنانی ژنێکی دیل 
\p  
\v 10 ئەگەر لە دژی دوژمنەکانت بۆ جەنگ چوویت و یەزدانی پەروەردگارت ئەوانی دا بە دەستت و دیلت لێ گرتن،  
\v 11 لەنێو دیلەکان ئافرەتێکی ڕوخسار جوانت بینی و چووە دڵتەوە و کردتە ژنی خۆت،  
\v 12 کاتێک دەیهێنیتە ماڵەکەت، سەری دەتاشێت و نینۆکەکانی دەکات،  
\v 13 جلەکانی دیلیێتی لەبەر دادەکەنێت و بۆ ماوەی مانگێک لە ماڵەکەت دەبێت و شیوەن بۆ دایک و باوکی دەگێرێت، پاش ئەوە دەیگوازیتەوە و بەزاوا دەبیت و دەبێتە ژنت.  
\v 14 ئەگەر پێی دڵخۆش نەبوویت، بەڕەڵای بکە، بە پارە مەیفرۆشە و هەڵسوکەوتی وەک کۆیلە لەگەڵدا مەکە، چونکە تۆ ئابڕووت بردووە. 
\s1 مافی نۆبەرەکە 
\p  
\v 15 ئەگەر پیاوێک دوو ژنی هەبێت، یەکێکیانی خۆشویست و ئەوی دیکەیانی خۆشنەویست، جا کە هەردووکیان کوڕیان بۆی بوو و نۆبەرەکە هی خۆشەویستەکە نەبوو،  
\v 16 ئەوا ئەو ڕۆژەی ئەوەی هەیەتی بۆ کوڕەکانی بەش دەکات، بۆی نییە کوڕی خۆشەویستەکە بکات بە نۆبەرە لە جیاتی کوڕە نۆبەرەکە،  
\v 17 بەڵکو کوڕەکەی لەو ژنەی کە خۆشی ناوێت وەک نۆبەرە دەیناسێت، هەتا دوو بەشی پێبدات لە هەموو ئەوەی هەیەتی، چونکە ئەو کوڕە یەکەم نیشانەی توانای باوکیەتی، مافی نۆبەرایەتی هەیە. 
\s1 کوڕێکی یاخی 
\p  
\v 18 ئەگەر پیاوێک کوڕێکی کەللەڕەق و یاخی هەبوو، گوێڕایەڵی قسەی دایک و باوکی نەبێت و گوێیان لێ نەگرێت کاتێک تەمبێی دەکەن،  
\v 19 دایک و باوکی دەیگرن و دەیهێننە لای پیرانی شارۆچکەکەی، بۆ لای دەروازەی شارۆچکەکەی و  
\v 20 بە پیرانی شارەکەی دەڵێن، «ئەم کوڕەمان کەللەڕەق و یاخییە، گوێڕایەڵمان نییە و دەست بڵاو و سەرخۆشە.»  
\v 21 ئینجا هەموو پیاوانی شارۆچکەکەی بەردبارانی دەکەن هەتا دەمرێت، ئیتر بەمە خراپەکە لەنێو خۆتان دادەماڵن و هەموو ئیسرائیل دەبیستن و دەترسن. 
\s1 کوژراوی لەسەر دار هەڵواسراو 
\p  
\v 22 ئەگەر کەسێک تاوانێکی لەسەر بوو کە سزاکەی مردنە، جا کە کوژرا و لەسەر دار هەڵتانواسی،\f + \fr 21:22 \ft ئەو کەسەی کە بڕیاری سزای مردنی لەسەر بوو، دوای کوشتنی، تەرمەکەی لەسەر دارێک هەڵدەواسرا، ئەمەش ئاگادارکردنەوەیەک بوو بۆ خەڵکی، کە ئەنجامی شکاندنی ئەم یاسایە کوشتنە.‏\f* 
\v 23 شەو تەرمەکەی لەسەر دارەکە مەهێڵنەوە، بەڵکو لە هەمان ڕۆژدا دەینێژن، چونکە هەڵواسراو لەسەر دار لەلایەن خوداوە نەفرەت لێکراوە\f + \fr 21:23 \ft نەفرەت لێکراوە: سەبارەت بە هەڵواسینی مەسیح لەسەر خاچ (دار)، بڕوانە \xt گەلاتیا 3‏:13‏\ft ‏.‏\f*، جا خاکەکەتان گڵاو مەکەن کە یەزدانی پەروەردگارتان بە میرات دەتانداتێ. 
\c 22  
\s1 گرنگیدان بە بەرژەوەندی کەسانی دیکە 
\p  
\v 1 ئەگەر گا یان مەڕی هەر هاوڵاتییەکت بینی وێڵ بووە، خۆتی لێ گێل مەکە، بەڵکو پێویستە لەسەرت بۆ براکەتی بگەڕێنیتەوە،  
\v 2 جا ئەگەر براکەت لێتەوە نزیک نەبوو یان نەتدەناسی، ئەوا بیخەرە ماڵەکەتەوە و لەلات دەبێت هەتا براکەت داوای دەکاتەوە، ئەوسا بۆی دەگەڕێنیتەوە.  
\v 3 هەمان شت دەکەیت بۆ گوێدرێژەکەی و بۆ کەواکەی و بۆ هەر شتێکی ون بوو لە براکەت کە لێی ون دەبێت و تۆ دەیدۆزیتەوە، بۆت نییە خۆتی لێ گێل بکەیت. 
\p  
\v 4 کە گوێدرێژ یان گای براکەت دەبینیت لە ڕێگادا کەوتووە، خۆتی لێ گێل مەکە، بەڵکو پێویستە لەسەرت لەگەڵی هەڵیبستێنیتەوە. 
\p  
\v 5 شتومەکی پیاو نابێت بەبەر ژنەوە بێت و نابێت پیاو جلی ژن لەبەر بکات، چونکە هەرکەسێک ئەمە بکات، قێزەونە لەلای یەزدانی پەروەردگارت. 
\p  
\v 6 ئەگەر ڕێککەوت هێلانەی باڵندەیەک لە ڕێگا لەپێشت بوو، لەناو دارێک یان لەسەر زەوی و بێچوو یان هێلکەی تێدابوو و دایکەکەشی تێدابوو بە کڕی لەسەر بێچووەکان یان هێلکەکان هەڵنیشتبوو، ئەوا دایکەکە و بێچووەکان پێکەوە مەبە،  
\v 7 دایکەکە ئازاد بکە و بێچووەکان بۆ خۆت ببە، بۆ ئەوەی چاکەت بۆ ببێت و درێژە بە ڕۆژانت بدەیت. 
\p  
\v 8 ئەگەر خانووێکی نوێت بنیاد نا، ستارە بۆ سەربانەکەت بکە، نەوەک خوێنێک بهێنیتە سەر ماڵەکەت ئەگەر یەکێکی لێ کەوتە خوارەوە. 
\p  
\v 9 لە ڕەزەکەت دوو جۆر تۆو مەچێنە\f + \fr 22:9 \ft بڕوانە \xt لێڤییەکان 19‏:19‏\ft ‏.‏\f*، ئەگەر ئەمە بکەیت، نەک تەنها ئەوەی دەیچێنیت، بەڵکو بەری ڕەزە مێوەکەشت بۆ پیرۆزگا تەرخان دەکرێت. 
\p  
\v 10 کێڵان بە گا و گوێدرێژ پێکەوە مەکە. 
\p  
\v 11 جلوبەرگی تێکەڵاو لەبەر مەکە، خوری و کەتان پێکەوە لەبەر مەکە. 
\p  
\v 12 لە لچکەکانی\f + \fr 22:12 \ft لاولوێچ یان لچک مەبەست لە سەرگۆشەی قوماشە یان جل و بەرگ.‏\f* کەواکەت کە خۆتی پێ دەپۆشیت، گوڵینگ بۆ خۆت بکە.\f + \fr 22:12 \ft مەبەست لەم یاسایە یادکردنەوەی ڕاسپاردەکانی خودایە. بڕوانە \xt سەرژمێری 15‏:37‏-41.‏\ft ‏\f* 
\s1 شکاندنی پەیمانی ژن و مێردایەتی 
\p  
\v 13 ئەگەر پیاوێک ژنێکی هێنا و کاتێک چوو بۆ لای ڕقی لێی بووەوە و  
\v 14 قسەی بۆ هەڵبەست و ناوێکی خراپی بەدواوە نا و گوتی، «ئەم ژنەم هێنا و کە چوومە لای پەردەی کچێنی نەبوو.»  
\v 15 دایک و باوکی کچەکە بەڵگەی کچێنییەکەی دەبەن و لەلای دەروازەی شارۆچکەکە بۆ پیرانی شارۆچکەکەی دەسەلمێنن.  
\v 16 باوکی کچەکە بە پیران دەڵێت، «کچەکەی خۆمم بەم پیاوە دا ببێتە ژنی و ڕقی لێی بووەوە.  
\v 17 وا قسەشی بۆ هەڵبەستووە و دەڵێت: ”کچەکەت پەردەی کچێنی نەبوو،“ ئەمەش بەڵگەی کچێنی کچەکەمە،» جلەکەش لەبەردەم پیرانی شارۆچکەکە دەخەنە ڕوو،  
\v 18 ئیتر پیرانی ئەو شارە پیاوەکە دەبەن و تەمبێی دەکەن.  
\v 19 سزای دەدەن بە سەد شاقلی\f + \fr 22:19 \ft نزیکەی یەک کیلۆگرام.‏\f* زیو بۆ باوکی کچەکە، چونکە ناوێکی خراپی خستە دوای پاکیزەیەک لە ئیسرائیل، جا دەبێتە ژنی و بە درێژایی ژیانی ناتوانێت تەڵاقی بدات. 
\p  
\v 20 بەڵام ئەگەر تۆمەتبارکردنەکە ڕاست بوو و کچەکە بەڵگەی پاکیزەیی نەبوو،  
\v 21 ئەوا کچەکە دەبەنە بەردەرگای ماڵی باوکی و پیاوانی شارەکەی بەردبارانی دەکەن هەتا دەمرێت، چونکە کارێکی ناشیرینی لە ئیسرائیلدا کردووە بە بەدڕەوشتییەکەی کە لە ماڵی باوکی کردوویەتی، جا خراپەکە لەنێو خۆتان دادەماڵن. 
\p  
\v 22 ئەگەر بینرا پیاوێک لەگەڵ ژنێکی بەمێرد جووت بووە، ئەوا هەردووکیان دەکوژرێن، ئەو پیاوەی لەگەڵ ژنەکە جووت بووە و ژنەکەش، جا خراپەکاری لە ئیسرائیلدا دادەماڵن. 
\p  
\v 23 ئەگەر کچێک مارەبڕاو بێت بۆ پیاوێک و پیاوێکی دیکە لەناو شار بینی و لەگەڵی جووت بوو،  
\v 24 ئەوا هەردووکیان ببەنە دەرەوە بۆ لای دەروازەی ئەو شارۆچکەیە و بەردبارانیان بکەن هەتا دەمرن، لەبەر ئەوەی کچەکە لەناو شار هاواری نەکرد بۆ فریاکەوتن و هەروەها پیاوەکەش ئابڕووی دەستگیرانی پیاوێکی دیکەی برد، جا خراپەکە لەنێو خۆتان دادەماڵن. 
\p  
\v 25 بەڵام ئەگەر پیاوێک کچێکی مارەبڕاوی لە کێڵگەدا بینی و لاقەی کرد، ئەوا تەنها پیاوەکە کە لاقەی کردووە دەمرێت،  
\v 26 بەڵام کچەکە هیچی لێ ناکرێت، کچەکە گوناهێکی لەسەر نییە شایانی سزای مردن بێت، بەڵکو چۆن پیاوێک پەلاماری دراوسێکەی بدات و بیکوژێت، ئەو ڕووداوەش ئاوایە،  
\v 27 کچەکەی لە کێڵگەدا بینیوە و کچە مارەبڕاوەکە هاواری کردووە و کەس نەبووە ڕزگاری بکات. 
\p  
\v 28 ئەگەر پیاوێک کچێکی نیشان نەکراوی بینی و لاقەی کرد و هەردووکیان ئاشکرا بوون،  
\v 29 ئەوا پیاوەکەی ئابڕووی بردووە، پەنجا شاقل زیو\f + \fr 22:29 \ft نزیکەی 0,6 کیلۆگرام.‏\f* دەداتە باوکی کچە و ئەویش دەبێتە ژنی، لەبەر ئەوەی دەستدرێژی کردووەتە سەری، بە درێژایی ژیانیشی ناتوانێت تەڵاقی بدات. 
\p  
\v 30 نابێت پیاوێک ژنی باوکی خۆی بهێنێت و ناموسی باوکی ببات. 
\c 23  
\s1 دەرکردن لە کۆمەڵی یەزدانەوە 
\p  
\v 1 نابێت خەساو یان قۆڕ یان کەسێک ئەندامی نێرینەی بڕابێتەوە بێتە ناو کۆمەڵی یەزدان. 
\p  
\v 2 نابێت زۆڵ بێتە ناو کۆمەڵی یەزدانەوە، هەتا نەوەی دەیەم کەسی نایەتە ناو کۆمەڵی یەزدان. 
\p  
\v 3 هەرگیز نابێت عەمۆنی یان مۆئابی بێتە ناو کۆمەڵی یەزدانەوە، تەنانەت لە نەوەی دەیەمیش کەس نایەتە ناو کۆمەڵی یەزدانەوە،  
\v 4 چونکە کاتێک ئێوە لە میسر هاتنە دەرەوە، لە ڕێگا بە نان و ئاوەوە پێشوازییان لێ نەکردن، هەروەها لەبەر ئەوەی بەلعامی کوڕی بەعۆری خەڵکی پەتوری میسۆپۆتامیایان\f + \fr 23:4 \ft میسۆپۆتامیا: عیبری (ئارامی دوو ڕووبار) بە واتای وڵاتی ئارام کە دەکەوێتە نێوان دجلە و فورات. بڕوانە \xt سەرژمێری 22‏:5‏\ft ‏.‏\f* لە دژی ئێوە بەکرێ گرت هەتا نەفرەتتان لێ بکات.  
\v 5 بەڵام یەزدانی پەروەردگارتان نەیویست گوێ لە بەلعام بگرێت، جا لە پێناوی ئێوە یەزدانی پەروەردگارتان نەفرەتەکەی گۆڕی بۆ بەرەکەت، چونکە یەزدانی پەروەردگارتان خۆشیویستوون.  
\v 6 بە درێژایی ژیانتان هەرگیز پەیمانی ئاشتییان لەگەڵ مەبەستن. 
\p  
\v 7 ڕقت لە هیچ ئەدۆمییەک نەبێتەوە، چونکە براتە، ڕقت لە هیچ میسرییەک نەبێتەوە، چونکە لە خاکی ئەو نامۆ بوویت،  
\v 8 ئەو منداڵانەی لەوان لەدایک دەبن لە نەوەی سێیەمەوە دێنە ناو کۆمەڵی یەزدانەوە. 
\s1 گڵاوی لە ئۆردوگادا 
\p  
\v 9 کاتێک لە دژی دوژمنەکانتان ئۆردوگا دادەمەزرێنن، لە هەموو شتێکی گڵاو خۆتان بەدوور بگرن.  
\v 10 ئەگەر پیاوێکتان تێدابوو، گڵاو بوو لەبەر ئەوەی بە شەو تۆوی لێ هاتە دەرەوە، ئەوا دەچێتە دەرەوەی ئۆردوگاکە و ناگەڕێتەوە ناو ئۆردوگاکە.  
\v 11 دەمەو ئێوارە بە ئاو خۆی دەشوات و لە ئاوابوونی خۆر دێتەوە ناو ئۆردوگاکە. 
\p  
\v 12 دەبێت شوێنێکیشتان هەبێت لە دەرەوەی ئۆردوگاکە بۆ پیساییکردن،  
\v 13 لەگەڵ شتومەکەکەشتان خاکەنازێکتان هەبێت، بۆ ئەوەی چاڵی پێ هەڵبکەنن بۆ پیساییکردن و پاشان پیساییەکەتان داپۆشن.  
\v 14 لەبەر ئەوەی یەزدانی پەروەردگارتان لەناو ئۆردوگاکەتان هاتوچۆ دەکات بۆ ئەوەی فریاتان بکەوێت و دوژمنەکانتان بەدەستەوە بدات، جا با ئۆردوگاکەتان پیرۆز بێت نەوەک شتێکی پیستان تێدا ببینێت و ڕووتان لێ وەربگێڕێت. 
\s1 فێرکردن بۆ وریابوونەوەی ویژدان 
\p  
\v 15 ئەگەر کۆیلەیەک پەنای بۆتان هێنا، مەیدەنەوە دەست گەورەکەی،  
\v 16 لەلای ئێوە نیشتەجێ دەبێت لەنێوتاندا لەو شوێنەی هەڵیدەبژێرێت لە یەکێک لە شارۆچکەکانتان، لە هەرکوێ پێی خۆشە و ستەمی لێ مەکەن. 
\p  
\v 17 کچانی ئیسرائیل بۆیان نییە ببنە لەشفرۆشی نزرگەکان و کوڕانی ئیسرائیلیش بۆیان نییە هەمان ئەم کارە بکەن\f + \fr 23:17 \ft بەپێی بیروباوەڕی ئایینی کەنعانی جووتبوون لەگەڵ ئافرەت یان پیاوی لەشفرۆش لە نزرگە، دەبێتە مایەی بەپیت بوونی کێڵگەکان و ئاژەڵەکان. هەندێک لە نەوەی ئیسرائیل ئەم بیروباوەڕی کەنعانییان پەیڕەو کرد. بڕوانە \xt یەکەم پاشایان 14‏:24 و هۆشەع 4‏:14 و ئامۆس 2‏:7‏\ft ‏.‏\f*.  
\v 18 کرێی لەشفرۆشیی ژنان و پیاوان مەخەنە ناو ماڵی یەزدانی پەروەردگارتان لە نەزرکردن، چونکە ئەم کارە لەلای یەزدانی پەروەردگارتان قێزەونە. 
\p  
\v 19 قەرز بە سوو بە براکەت مەدە، نە سووی زیو و نە سووی خۆراک و نە سووی هەر شتێک کە بە سوو بە قەرز دەدرێت.  
\v 20 دەتوانیت قەرز بە سوو بدەیتە بێگانە، بەڵام قەرز بە سوو مەدە براکەت، بۆ ئەوەی یەزدانی پەروەردگارت بەرەکەتدارت بکات لە هەموو شتێک کە دەستی بۆ دەبەیت لەو خاکەی دەچیتە ناوی هەتا دەستی بەسەردا بگریت. 
\p  
\v 21 ئەگەر نەزرێکت بۆ یەزدانی پەروەردگارت کرد بەجێهێنانی دوا مەخە، چونکە یەزدانی پەروەردگارت لێت داوا دەکات، جا بەسەرتەوە دەبێتە گوناه.  
\v 22 بەڵام ئەگەر نەزرت نەکرد ئەوا گوناه نییە بەسەرتەوە.  
\v 23 ئەوەی لە دەمت هاتە دەرەوە بیپارێزە و بیکە، چونکە ئازادانە بە دەمی خۆت نەزرت بۆ یەزدانی پەروەردگارت کرد. 
\p  
\v 24 ئەگەر چوویتە ناو ڕەزەمێوی دراوسێکەت پڕ بە حەزی دڵت ترێ بخۆ هەتا تێر دەبیت، بەڵام هیچ مەکە ناو توورەکەکەتەوە.  
\v 25 ئەگەر چوویتە ناو دەغڵی دراوسێکەت دەتوانیت بە دەستت گوڵەگەنم لێ بکەیتەوە، بەڵام داس لە دەغڵی دراوسێکەت بەرز مەکەرەوە. 
\c 24  
\s1 هاوسەرگیری و کاروباری کۆمەڵایەتی 
\p  
\v 1 ئەگەر پیاوێک ژنێکی هێنا و پەسەند نەبوو لەبەرچاوی، چونکە بێ ئابڕووییەکی تێدا بینی و تەڵاقنامەی بۆ نووسی و دایە دەستی، لە ماڵەکەی خۆی بەڕێی کرد،  
\v 2 ئەویش کە لە ماڵەکەی چووە دەرەوە، بووە ژنی پیاوێکی دیکە،  
\v 3 جا ئەگەر پیاوەکەی دووەم ڕقی لێی بووەوە و تەڵاقنامەی بۆ نووسی و دایە دەستی و لە ماڵەکەی خۆی بەڕێی کرد، یان ئەگەر پیاوەکەی دووەم کە هێنابووی مرد،  
\v 4 ئەوا مێردەکەی یەکەمی کە تەڵاقی دابوو ناتوانێت بیهێنێتەوە بۆ ئەوەی ببێتە ژنی دوای ئەوەی گڵاو بووە. ئەوە شتێکی قێزەونە لەلای یەزدان، جا گوناه مەهێنە سەر ئەو خاکەی یەزدانی پەروەردگارت بە میرات دەتداتێ. 
\p  
\v 5 ئەگەر پیاوێک ژنی هێنا ئەوا هەتا ساڵێک بۆ سەربازی ناچێت و هیچ لێپرسراویەتییەکی لەسەر شان نابێت، ئەو ساڵە لە ماڵەکەی ئازاد دەبێت و ژنەکەی دڵخۆش دەکات. 
\p  
\v 6 نابێت کەس دەستاڕ، تەنانەت بەرداشێکی بکاتە بارمتە، چونکە سەرچاوەی بژێوییە. 
\p  
\v 7 ئەگەر پیاوێک لە کاتی ڕفاندنی یەکێک لە براکانی لە نەوەی ئیسرائیل بگیردرێت و وەک کۆیلە هەڵسوکەوتی لەگەڵ کرد یان فرۆشتی، ئەوا کابرای ڕفێنەر دەبێت بمرێت، جا خراپەکە لەنێو خۆتان دادەماڵن. 
\p  
\v 8 لە کاتی نەخۆشی گولی\f + \fr 24:8 \ft گولی: لە زمانی عیبری بە واتای گەڕوگولی و چەند نەخۆشییەکی دیکەی پێست دێت.‏\f* زۆر ئاگاداربن و بەگوێرەی هەموو ئەوەی کاهینە لێڤییەکان فێرتان دەکەن ئاوا بکەن، ئەوەی من فەرمانم بەوان کردووە ئێوە بیکەن.  
\v 9 لە یادتان بێت یەزدانی پەروەردگارتان لە ڕێگا چی بە مریەم کرد، پاش ئەوەی لە میسر هاتنە دەرەوە. 
\p  
\v 10 ئەگەر قەرزت بە دراوسێکەت دا، مەچۆ ماڵەکەی هەتا شتێکی ماڵەکەی بکەیتە بارمتە\f + \fr 24:10 \ft لێرەدا مەبەست لە وەرگرتنی جل و بەرگ بووە بە بارمتە. بڕوانە ئایەتی 13.‏\f*،  
\v 11 لە دەرەوە دەوەستیت و ئەو پیاوەی قەرزی پێدەدەیت بارمتەکەت بۆ دەهێنێتە دەرەوە.  
\v 12 ئەگەر کابرا هەژار بوو با بارمتەکە بۆ شەو لەلات نەمێنێتەوە،  
\v 13 لەگەڵ ئاوابوونی خۆر بارمتەکەی بۆ بگەڕێنەوە هەتا لەناو جلوبەرگەکەی بنووێت و داوای بەرەکەتت بۆ بکات و بۆت ببێتە کارێکی ڕاست لەلای یەزدانی پەروەردگارت. 
\p  
\v 14 ستەم لە کرێگرتەیەکی هەژار و نەدار مەکە، کە لە براکانت بێت یان لەو نامۆیانەی لە یەکێک لە شارۆچکەکانی خاکەکەتن.  
\v 15 لە ڕۆژی خۆی کرێیەکەی دەدەیتێ، پێش ئاوابوونی خۆر، چونکە هەژارە و بۆ ئەمە خۆی هەڵگرتووە، نەوەک لەسەر تۆ هاوار بۆ یەزدان بکات، جا دەبێت بە گوناه بەسەرتەوە. 
\p  
\v 16 باوک لە جیاتی کوڕ ناکوژرێت و کوڕ لە جیاتی باوک ناکوژرێت، هەر یەکێک لەسەر گوناهی خۆی دەکوژرێت. 
\p  
\v 17 نامۆ و هەتیو لە دادپەروەری بێبەش مەکە، جلوبەرگی بێوەژن مەکە بارمتە،  
\v 18 لە یادت نەچێت کە تۆش لە میسر کۆیلە بوویت و یەزدانی پەروەردگارت لەوێ تۆی کڕییەوە، بۆیە من فەرمانت پێدەدەم ئەم کارە بکەیت. 
\p  
\v 19 کاتێک لە کێڵگەکەت خەریکی دروێنەکردنیت و دەسکێکت لە کێڵگە لەبیر چوو، مەگەڕێوە بۆ ئەوەی بیبەیتەوە، ئەوە بۆ نامۆ و هەتیو و بێوەژن دەبێت، تاکو یەزدانی پەروەردگارت لە هەموو کاری دەستت بەرەکەتدارت بکات.  
\v 20 لە کاتی ڕاتەکاندنی دار زەیتوونەکەت، بەدوای ئەوانەدا مەچووەوە کە لە لقەکاندا ماوەتەوە، ئەوە بۆ نامۆ و هەتیو و بێوەژن دەبێت.  
\v 21 کاتێک ترێی ڕەزە مێوەکەت دەڕنیت، پاشماوەکەی هەڵمەگرەوە، ئەوە بۆ نامۆ و هەتیو و بێوەژن دەبێت.  
\v 22 لە یادت نەچێت تۆش لە خاکی میسر کۆیلە بوویت، بۆیە من فەرمانت پێدەدەم ئەم کارە بکەیت. 
\c 25  
\p  
\v 1 ئەگەر ناکۆکییەک هەبوو لەنێوان خەڵکی، دەبێت بیبەنە دادگا بۆ ئەوەی دادوەری لەنێوانیان بکرێت و بێتاوانەکە بێتاوان بکرێت و حوکم بەسەر تاوانبارەکەدا بدرێت.  
\v 2 جا ئەگەر ڕەوا بوو لە تاوانبارەکە بدرێت، ئەوا دادوەر چۆکی پێ دادەدات و لەبەردەمی بە ژمارە بەگوێرەی تاوانەکەی قامچی لێدەدرێت.  
\v 3 نابێت لە چل قامچی زیاتر بێت، نەوەک براکەت لەبەرچاوت سووک بێت، ئەگەر لێدانەکە زیاد بێت. 
\p  
\v 4 لە کاتی گێرەکردن دەمی گا مەگرە. 
\p  
\v 5 ئەگەر چەند برایەک پێکەوە ژیان و یەکێکیان مرد و کوڕی نەبوو، ئەوا ژنەکەی نابێت بۆ پیاوێکی لە خێڵێکی دیکەی دەرەوە بێت، برای مێردەکەی دەیخوازێت و دەیکاتە ژنی خۆی و بە ئەرکی شووبرایەتی هەڵدەستێت بۆی،  
\v 6 ئەو کوڕە نۆبەرەیەشی کە بۆی لەدایک دەبێت، بە ناوی برا مردووەکەی ناودەبردرێت، نەوەک ناوی لە ئیسرائیلدا بسڕێتەوە. 
\p  
\v 7 ئەگەر پیاوەکە ڕازی نەبوو براژنەکەی بخوازێت، ئەوا براژنەکەی دەچێتە لای دەروازەی شارۆچکەکە بۆ لای پیران و دەڵێت: «شووبرایەکەم ڕازی نەبوو ناوێک بۆ براکەی لە ئیسرائیلدا درێژە پێبدات، نەیویست بە ئەرکی شووبرایەتی هەستێت بۆم.»  
\v 8 جا پیرانی شارۆچکەکەی بانگی دەکەن و لەگەڵی دەدوێن، ئەگەر سوور بوو و گوتی، «ڕازی نیم بیخوازم،»  
\v 9 ئەوا براژنەکەی لەبەرچاوی پیران لێی دەچێتە پێش و یەکێک لە پێڵاوەکانی کابرا لە پێی دادەکەنێت و تف لە دەموچاوی دەکات و ڕایدەگەیەنێت و دەڵێت: «ئاوا لە پیاوێک دەکرێت کە ماڵی براکەی بنیاد نەنێتەوە.»  
\v 10 جا لە ئیسرائیل ناوی لێ دەنرێت، خێڵی پێڵاو داکەنراو. 
\p  
\v 11 ئەگەر دوو پیاو لەگەڵ یەکتری کردیان بە شەڕ، ژنی یەکێکیان هات بۆ ئەوەی فریای پیاوەکەی بکەوێت لە دەست ئەوەی لێی دەدات، جا دەستی درێژکرد و گونی گرت،  
\v 12 دەستی ببڕنەوە و بەزەییتان پێی نەیەتەوە. 
\p  
\v 13 با لە توورەکەکەت کێشی جیاواز نەبێت، قورس و سووک.  
\v 14 با لە ماڵەکەت پێوانەی جیاواز نەبێت، گەورە و بچووک.  
\v 15 کێشی تەواو و ڕاستت دەبێت، پێوانەی تەواو و ڕاستت دەبێت، بۆ ئەوەی تەمەن درێژ بیت لەسەر ئەو خاکەی یەزدانی پەروەردگارت پێت دەدات،  
\v 16 چونکە هەر یەکێک ئەوە بکات، هەر یەکێک ساختەکاری بکات، یەزدانی پەروەردگارت قێزی لێ دەبێتەوە. 
\p  
\v 17 لە یادتان بێت ئەوەی عەمالێقییەکان لە ڕێگا لە کاتی هاتنە دەرەوەتان لە میسر پێیان کردن،  
\v 18 کە چۆن لە ڕێگا بەرەو ڕووتان هاتن و لە پشتتانەوە هەموو لاوازەکانی دواوەی ئێوەیان بڕییەوە، ئێوەش پەککەوتە و ماندوو بوون و ئەوانیش لە خودا نەترسان.  
\v 19 جا کاتێک یەزدانی پەروەردگارتان ئێوەی حەساندەوە لە هەموو دوژمنەکانتان کە لە چواردەورتانن لەو خاکەی یەزدانی پەروەردگارتان پێتانی دەدات هەتا دەستی بەسەردا بگرن وەک میرات، ئەوا ناوی عەمالێق لەژێر ئاسمان دەسڕنەوە، لەبیری نەکەن! 
\c 26  
\s1 یەکەمین بەرهەم و دەیەکەکان 
\p  
\v 1 کاتێک هاتنە ناو ئەو خاکەی کە یەزدانی پەروەردگارتان بە میرات پێتانی دەدات و دەستتان بەسەردا گرت و تێیدا نیشتەجێ بوون،  
\v 2 ئەوا هەرکەسێک یەکەمین بەرهەمی هەموو بەروبوومی زەوییەکە کە دەستی دەکەوێت لە خاکەکەتان کە یەزدانی پەروەردگارتان پێتانی دەدات دەیکاتە ناو سەبەتەیەک و دەچێتە ئەو شوێنەی کە یەزدانی پەروەردگارتان هەڵیدەبژێرێت بۆ ئەوەی ناوی لەوێ بێت.  
\v 3 ئینجا دێتە لای ئەو کاهینەی کە لەو کاتەدایە و پێی دەڵێت: «ئەمڕۆ بە یەزدانی پەروەردگارت ڕادەگەیەنم کە من چوومە ناو ئەو خاکەی یەزدان سوێندی بۆ باوباپیرانمان خوارد کە پێمانی بدات.»  
\v 4 جا کاهینەکەش سەبەتەکە لە دەستی وەردەگرێت و لەبەردەم قوربانگاکەی یەزدانی پەروەردگارتان دایدەنێت،  
\v 5 ئینجا کەسەکە لە بەرامبەر یەزدانی پەروەردگارتان ڕایدەگەیەنێت و دەڵێت: «باوکم ئارامییەکی گەڕۆک بوو، چوو بۆ میسر و لەوێ ئاوارە بوو، چەند کەسێکی کەم بوون، جا لەوێ بوو بە نەتەوەیەکی مەزن و بەهێز و زۆر.  
\v 6 ئینجا میسرییەکان خراپەیان دەرهەق کردین و ئازاریان داین و کۆیلایەتییەکی سەختیان بەسەرماندا سەپاند.  
\v 7 ئیتر کاتێک هاوارمان بۆ یەزدانی پەروەردگاری باوباپیرانمان کرد، یەزدان گوێی لە دەنگمان بوو و ناخۆشی و ماندووبوونی و چەوساندنەوەی ئێمەی بینی.  
\v 8 جا یەزدان بە دەستێکی پۆڵایین و بازووێکی بەهێز و ترسی مەزن و نیشانە و پەرجووەوە لە میسر دەریهێناین،  
\v 9 ئێمەی هێنایە ناو ئەم شوێنە و ئەم خاکەی پێداین، خاکێک شیر و هەنگوینی لێ دەڕژێت.  
\v 10 ئێستاش ئەی یەزدان، ئەوەتا یەکەمین بەرهەمی ئەو زەوییەم هێناوە کە تۆ بە منت داوە.» ئینجا لەبەردەم یەزدانی پەروەردگارتان دایدەنێت و لەبەردەم یەزدانی پەروەردگارتان کڕنۆش دەبات و  
\v 11 بە هەموو ئەو خێروبێرە دڵخۆش دەبن کە یەزدانی پەروەردگارتان بە خۆتان و ماڵەکەتانی داوە، ئێوە و لێڤییەکان و ئەو نامۆیانەی لەنێوتاندان. 
\p  
\v 12 کاتێک لە دەرهێنانی دەیەکی هەموو داهاتەکەتان تەواو بوون لە ساڵی سێیەم کە ساڵی دەیەکە، داتانە لێڤی و نامۆ و هەتیو و بێوەژنان، لە شارۆچکەکانتاندا خواردیان و تێر بوون،  
\v 13 لەبەردەم یەزدانی پەروەردگارتان دەڵێن: «بەشی تەرخانکراوی خودام لە ماڵەکەم دەرهێنا و هەروەها بە لێڤی و نامۆ و هەتیو و بێوەژنم دا، بەگوێرەی هەموو فەرمانەکەت کە فەرمانت پێکردم، لە فەرمانەکانت دەرنەچووم و لە یادم نەکرد.  
\v 14 لە ماتەمداریمدا لە بەشە تەرخانکراوەکەم نەخوارد و لە گڵاویمدا لێم نەبرد و هیچم لێی نەداوە بۆ مردوو، بەڵکو گوێڕایەڵی یەزدانی پەروەردگارم بووم و بەگوێرەی هەموو ئەوەم کرد کە فەرمانت پێکردم.  
\v 15 لە نشینگەی پیرۆزی خۆتەوە، لە ئاسمانەوە بڕوانە و گەلی خۆت ئیسرائیل و ئەو خاکە بەرەکەتدار بکە کە بە ئێمەت داوە، وەک سوێندت بۆ باوباپیرانمان خوارد، خاکێک شیر و هەنگوینی لێ دەڕژێت.» 
\s1 فەرمانی یەزدان بپارێزن 
\p  
\v 16 ئەمڕۆ یەزدانی پەروەردگارتان فەرمانی پێ کردن کە کار بەم فەرز و یاسایانە بکەن، جا پڕ بە دڵ و لە ناختانەوە بەجێی بهێنن و پەیڕەوی بکەن،  
\v 17 ئەمڕۆ ڕاتانگەیاند بۆ یەزدان کە ببێت بە خوداتان و ڕێگاکانی ئەو بگرنەبەر و فەرز و فەرمانەکان و یاساکانی بەجێبهێنن و گوێڕایەڵی دەنگی ببن،  
\v 18 یەزدانیش ئەمڕۆ ڕایگەیاند، کە ئێوە گەلی ئەون، گەنجینەیەکی تایبەتی ئەو، وەک بەڵێنی پێدان و هەموو فەرمانەکانی بپارێزن.  
\v 19 لە سەرووی هەموو ئەو نەتەوانەی دروستی کردوون داتان دەنێت، لە ستایش و ناوبانگ و ڕێزدا، ببنە گەلێکی پیرۆز بۆ یەزدانی پەروەردگارتان وەک بەڵێنی دا. 
\c 27  
\s1 قوربانگای کێوی عێبال 
\p  
\v 1 موسا و پیرانی ئیسرائیل فەرمانیان بە گەل دا و گوتیان: «هەموو ئەو فەرمانانە بپارێزن کە من ئەمڕۆ فەرمانتان پێ دەکەم.  
\v 2 کاتێک لە ڕووباری ئوردون دەپەڕنەوە بۆ ئەو خاکەی یەزدانی پەروەردگارتان پێتان دەدات، چینێک بەردی گەورە بۆ خۆتان ڕاگیر بکەن و بە گەچ سواغیان بدەن.  
\v 3 هەموو وشەکانی ئەم فێرکردنەی لەسەر بنووسن کاتێک دەپەڕنەوە هەتا بچنە ناو ئەو خاکەی یەزدانی پەروەردگارتان پێتان دەدات، خاکێک شیر و هەنگوینی لێ دەڕژێت، وەک یەزدانی پەروەردگاری باوباپیرانتان بەڵێنی پێدان.  
\v 4 کاتێک لە ڕووباری ئوردون دەپەڕنەوە، ئەم بەردانە ڕاگیر بکەن کە من ئەمڕۆ فەرمانتان پێ دەکەم، لە کێوی عێبال و بە گەچ سواغیان بدەن.  
\v 5 لەوێ قوربانگایەک بۆ یەزدانی پەروەردگارتان بنیاد بنێن، قوربانگایەک لە بەرد بێت و ئامێری ئاسنی لێ بەکارمەهێنن.\f + \fr 27:5 \ft مەبەست لێی ئەوە بووە کە قوربانگای یەزدان نابێت هاوشێوەی قوربانگای کەنعانییەکان بێت و بە بەردی تاشراو دروستبکرێت.‏\f* 
\v 6 لە بەردی نەتاشراو قوربانگاکەی یەزدانی پەروەردگارتان بنیاد بنێن و قوربانی سووتاندن سەربخەنە سەری بۆ یەزدانی پەروەردگارتان،  
\v 7 هەروەها قوربانی هاوبەشی\f + \fr 27:7 \ft قوربانی هاوبەشی: ئەم قوربانییە هاودەمی قوربانی سووتاندن بوو. تەنها یەک کەس هەڵدەستا بە دابینکردنی ئەم قوربانییە، بەڵام لەگەڵ خەڵکی دیکە بەشی زۆری ئەم قوربانییەیان لەبەردەم خودا دەخوارد وەک هێمایەک بۆ پێکەوە ژیان. بڕوانە \xt لێڤییەکان 7‏:11‏-15‏\ft ‏.‏\f* سەرببڕن و لەوێ بیخۆن و لەبەردەم یەزدانی پەروەردگارتان دڵخۆش بن.  
\v 8 هەموو وشەکانی ئەم فێرکردنەش زۆر بە ڕوونی لەسەر بەردەکان بنووسن.» 
\s1 نەفرەت لە کێوی عێبالەوە 
\p  
\v 9 ئینجا موسا و کاهینە لێڤییەکان لەگەڵ هەموو ئیسرائیلدا دوان و گوتیان: «ئەی ئیسرائیل بێدەنگ بن و گوێتان لێ بێت، ئەمڕۆ بوونە گەل بۆ یەزدانی پەروەردگارتان،  
\v 10 جا گوێڕایەڵی یەزدانی پەروەردگارتان بن، کار بەو فەرمان و فەرزانەی بکەن کە من ئەمڕۆ فەرمانتان پێ دەکەم.» 
\p  
\v 11 جا لەو ڕۆژەدا موسا فەرمانی بە گەل کرد و گوتی: 
\p  
\v 12 ئەم هۆزانە لەسەر کێوی گەریزیم دەوەستن هەتا داوای بەرەکەت بۆ گەل بکەن کاتێک لە ڕووباری ئوردون دەپەڕنەوە، شیمۆن و لێڤی و یەهودا و یەساخار و یوسف و بنیامین.  
\v 13 ئەم هۆزانەش لەسەر کێوی عێبال دەوەستن بۆ نەفرەت، ڕەئوبێن و گاد و ئاشێر و زەبولون و دان و نەفتالی. 
\p  
\v 14 جا لێڤییەکان ڕایدەگەیەنن و بە دەنگی بەرز بە هەموو گەلی ئیسرائیل دەڵێن: 
\p  
\v 15 «نەفرەت لێکراوە ئەو کەسەی پەیکەرێکی داتاشراو یان بتێکی لەقاڵبدراو بە دەستی پەیکەرتاش دروستدەکات و لە شوێنێکی شاردراوەی دادەنێت، ئەوە قێزەونە لەلای یەزدان.» 
\pr هەموو گەلیش وەڵام دەدەنەوە و دەڵێن، «ئامین!» 
\p  
\v 16 «نەفرەت لێکراوە ئەوەی ڕێز لە دایک و باوک ناگرێت.» 
\pr هەموو گەلیش دەڵێن، «ئامین!» 
\p  
\v 17 «نەفرەت لێکراوە ئەوەی سنووری زەوی بەردینی دراوسێکەی دەگوێزێتەوە.» 
\pr هەموو گەلیش دەڵێن، «ئامین!» 
\p  
\v 18 «نەفرەت لێکراوە ئەوەی نابینا لە ڕێگا وێڵ دەکات.» 
\pr هەموو گەلیش دەڵێن، «ئامین!» 
\p  
\v 19 «نەفرەت لێکراوە ئەوەی دادپەروەری بۆ نامۆ و هەتیو و بێوەژن ناکات.» 
\pr هەموو گەلیش دەڵێن، «ئامین!» 
\p  
\v 20 «نەفرەت لێکراوە ئەوەی لەگەڵ باوەژنی خۆی جووت دەبێت، چونکە ناموسی باوکی بردووە.» 
\pr هەموو گەلیش دەڵێن، «ئامین!» 
\p  
\v 21 «نەفرەت لێکراوە ئەوەی لەگەڵ ئاژەڵێک جووت دەبێت.» 
\pr هەموو گەلیش دەڵێن، «ئامین.» 
\p  
\v 22 «نەفرەت لێکراوە ئەوەی لەگەڵ خوشکی خۆی جووت دەبێت، کچی باوکی یان کچی دایکی.» 
\pr هەموو گەلیش دەڵێن، «ئامین!» 
\p  
\v 23 «نەفرەت لێکراوە ئەوەی لەگەڵ خەسووی خۆی جووت دەبێت.» 
\pr هەموو گەلیش دەڵێن، «ئامین!» 
\p  
\v 24 «نەفرەت لێکراوە ئەوەی بە نهێنی دراوسێکەی خۆی دەکوژێت.» 
\pr هەموو گەلیش دەڵێن، «ئامین!» 
\p  
\v 25 «نەفرەت لێکراوە ئەوەی بەرتیل وەردەگرێت بۆ ئەوەی یەکێکی بێتاوان بکوژێت.» 
\pr هەموو گەلیش دەڵێن، «ئامین!» 
\p  
\v 26 «نەفرەت لێکراوە ئەوەی پاڵپشتی وشەکانی ئەم فێرکردنە ناکات بۆ ئەوەی کاریان پێ بکات.» 
\pr هەموو گەلیش دەڵێن، «ئامین!» 
\c 28  
\s1 بەرەکەت بۆ گوێڕایەڵی 
\p  
\v 1 ئەگەر گوێڕایەڵی یەزدانی پەروەردگارتان بن و بە وریاییەوە کار بە هەموو ئەو فەرمانانەی بکەن کە من ئەمڕۆ پێتان دەدەم، ئەوا یەزدانی پەروەردگارتان لە سەرووی هەموو نەتەوەکانی سەر زەویتان دادەنێت.  
\v 2 هەموو ئەم بەرەکەتانەتان دێتە سەر و پێتان دەگات، ئەگەر گوێڕایەڵی یەزدانی پەروەردگارتان بوون: 
\pm  
\v 3 لە شار بەرەکەتدار دەبن و لە دەشتودەریش بەرەکەتدار دەبن. 
\pm  
\v 4 بەری سکتان و بەروبوومی زەوییەکەتان بەرەکەتدار دەبن، بەری ئاژەڵە ماڵییەکانیشتان، گوێرەکەی گاگەلەکەتان و کاریلە و بەرخی مێگەلەکەتان. 
\pm  
\v 5 سەبەتە و تەشتی هەویرتان بەرەکەتدار دەبێت. 
\pm  
\v 6 لە چوونە ژوورەوەتان بەرەکەتدار دەبن و لە هاتنەدەرەوەشتان بەرەکەتدار دەبن. 
\p  
\v 7 یەزدان وا دەکات ئەو دوژمنانەتان کە سەرهەڵدەدەن لەبەردەمتان ببەزن، لە یەک ڕێگا بۆتان دێنە دەرەوە و لە حەوت ڕێگا لەبەردەمتان هەڵدێن. 
\p  
\v 8 یەزدان فەرمانی بەرەکەتتان بۆ دەدات لە هەموو شتە ئەمبارکراوەکانتان و لە هەموو شتێک کە دەستی بۆ دەبەن و بەرەکەتدارتان دەکات لەو خاکەی یەزدانی پەروەردگارتان پێتان دەدات. 
\p  
\v 9 ئەگەر فەرمانەکانی یەزدانی پەروەردگارتان پاراست و ڕێگاکانی ئەوتان گرتەبەر، ئەوا یەزدان بە گەلێکی پیرۆزتان دادەنێت بۆ خۆی، وەک سوێندی بۆ خواردن.  
\v 10 جا هەموو گەلانی زەوی دەبینن کە ناوی یەزدان بە ئێوەوە نراوە، ئیتر لێتان دەترسن.  
\v 11 یەزدانیش سەروەت و سامانتان زیاتر دەکات لە بەری سکتان و بەری ئاژەڵە ماڵییەکانتان و بەروبوومی زەوییەکەتان، لەسەر ئەو خاکەی کە سوێندی بۆ باوباپیرانتان خوارد بتانداتێ. 
\p  
\v 12 یەزدان ئەمبارە باشەکەی ئاسمانتان بۆ دەکاتەوە، هەتا بارانی خاکەکەتان لە کاتی خۆیدا بداتێ و هەموو کاری دەستتان بەرەکەتدار بکات، ئینجا قەرز بە زۆر نەتەوە دەدەن و خۆتان قەرز ناکەن.  
\v 13 یەزدانیش دەتانکات بە سەر نەک بە کلک و تەنها لە بەرزبوونەوە دەبن نەک لە نزمبوونەوە، ئەگەر گوێڕایەڵی فەرمانەکانی یەزدانی پەروەردگارتان بوون، کە من ئەمڕۆ فەرمانتان پێ دەکەم، هەتا بیپارێزن و کاری پێ بکەن.  
\v 14 لە هەموو ئەو وشانەش کە من ئەمڕۆ فەرمانتان پێ دەکەم، بەلای چەپ یان ڕاستدا لا نەدەن، بۆ ئەوەی بەدوای خودای دیکە بکەون هەتا بیپەرستن. 
\s1 نەفرەت بۆ یاخیبوون 
\p  
\v 15 بەڵام ئەگەر گوێڕایەڵی یەزدانی پەروەردگارتان نەبوون، بۆ ئەوەی ئاگاداربن کە کار بە هەموو فەرمانەکانی و فەرزەکانی بکەن کە من ئەمڕۆ فەرمانتان پێ دەکەم، هەموو ئەم نەفرەتانەتان دێتە سەر و پێتان دەگات. 
\pm  
\v 16 لە شار نەفرەت لێکراو دەبن و لە کێڵگەش نەفرەت لێکراو دەبن. 
\pm  
\v 17 سەبەتە و تەشتی هەویرتان نەفرەت لێکراو دەبێت. 
\pm  
\v 18 بەری سکتان و بەروبوومی زەوییەکەتان، گوێرەکەی گاگەلەکەشتان و کاریلە و بەرخی مێگەلەکەتان، نەفرەت لێکراو دەبن. 
\pm  
\v 19 کە دێنە ژوورەوە نەفرەتتان لێ دەکرێت و کە دەچنە دەرەوە نەفرەتتان لێ دەکرێت. 
\p  
\v 20 لەبەر ئەوەی پشتم تێ دەکەن و کاری خراپە ئەنجام دەدەن، هەر کارێک کە دەتانەوێت بیکەن، یەزدان نەفرەت و سەرلێشێوان و سەرزەنشتتان دەنێرێتە سەر هەتا ئەو کاتەی دەفەوتێن و بە خێرایی لەناودەچن.  
\v 21 یەزدان دەردتان پێوە دەنووسێنێت، هەتا لەو خاکە لەناوتان ببات کە ئێوە دەچنە ناوی هەتا دەستی بەسەردا بگرن.  
\v 22 یەزدان تووشی سیل و گرانەتا و هەوکردن، گەرما و وشکەساڵی، بای گەرمەسێر و کەڕووتان دەکات، جا بەدواتانەوە دەبێت هەتا لەناوتان دەبات.  
\v 23 ئاسمانیش کە لەسەر سەرتانە دەبێتە بڕۆنز و ئەو خاکەی ژێریشتان دەبێتە ئاسن.  
\v 24 یەزدانیش بارانی خاکەکەتان دەکاتە تۆز و خۆڵ و لە ئاسمانەوە بۆتان دێتە خوارەوە هەتا لەناودەچن. 
\p  
\v 25 یەزدان لەبەردەم دوژمنەکانتان دەتانشکێنێت، لە یەک ڕێگا بۆیان دەچن و لە حەوت ڕێگا لەبەردەمیان هەڵدێن و هەموو شانشینەکانی زەوی دەتۆقن کاتێک ئەو ڕووداوە دەبینن کە بەسەر ئێوە هاتووە.  
\v 26 تەرمیشتان دەبێتە خۆراکی هەموو باڵندەکانی ئاسمان و دڕندەکانی زەوی و کەسیش نابێت هەڵیانبفڕێنێ.  
\v 27 یەزدان تووشی دومەڵی میسر و ئاوسان و گەڕی و خورشتتان دەکات کە نەتوانن چاک ببنەوە.  
\v 28 یەزدان تووشی شێتی و کوێری و سەرلێشێواویتان دەکات.  
\v 29 لە نیوەڕۆدا بە پەلکوتان دەڕۆن وەک نابینایان لە تاریکیدا و لە ڕێگاکانتان سەرکەوتوو نابن، بەڵکو هەموو ڕۆژانتان زۆرلێکراو و تاڵانکراو دەبن و کەسیش نابێت ڕزگارتان بکات. 
\p  
\v 30 ژنێک مارە دەکەن بەڵام پیاوێکی دیکە دەیبات و لەگەڵی دەنوێت. خانووێک بنیاد دەنێن بەڵام تێیدا دانانیشن. ڕەزە مێوێک دەڕوێنن بەڵام لە بەرەکەی ناخۆن.  
\v 31 گایەکەتان لەبەرچاوتان سەردەبڕدرێت بەڵام لێی ناخۆن. لەبەرچاوتان دەست بەسەر گوێدرێژەکەتاندا دەگرن بەڵام بۆتان ناگەڕێتەوە. مەڕەکانتان دەدرێنە دەست دوژمنەکانتان و ڕزگارکەریشتان نییە.  
\v 32 کوڕان و کچانتان دەدرێنە دەست گەلێکی دیکە و بە درێژایی ڕۆژ چاوەکانتان تەماشایان دەکەن هەتا ماندوو دەبن و هیچیشتان لەدەست نایەت.  
\v 33 بەروبوومی خاکەکەتان و هەموو ماندووبوونتان، گەلێک دەیخوات کە نایناسن، جا هەموو ڕۆژانتان تەنها زۆرلێکراو و پێشێلکراو دەبن.  
\v 34 لەبەر سەرسامی ئەوەی کە دەیبینن شێت دەبن.  
\v 35 یەزدان تووشی دومەڵی پیستان دەکات، لەسەر ئەژنۆکانتان و قاچەکانتان، کە نەتوانن چاک ببنەوە، لە بنی پێتانەوە هەتا تەپڵی سەرتان. 
\p  
\v 36 یەزدان بە خۆتان و پاشاکەتانەوە کە بۆ خۆتانی دادەنێن، دەتانبات بۆ لای نەتەوەیەک کە نە ئێوە و نە باوباپیرانتان ناسیویانە و لەوێ خودای دیکە دەپەرستن، واتا ئەو بتانەی کە لە دار و لە بەردن.  
\v 37 هەموو ئەو گەلانەی یەزدان ئێوە بۆ ناو ئەوان ڕادەپێچێت دەتۆقن لەوەی بەسەر ئێوە هاتووە و دەبنە پەند و گاڵتەجاڕی بۆیان. 
\p  
\v 38 تۆوێکی زۆر دەکەن بە کێڵگەوە، بەڵام کەم کۆدەکەنەوە، چونکە کوللە دەیخوات،  
\v 39 ڕەزەمێو دەچێنن و خزمەتی دەکەن، بەڵام شەراب ناخۆنەوە و ترێ لێ ناکەنەوە، چونکە کرم دەیخوات.  
\v 40 لەناو هەموو سنوورەکەتان زەیتوونتان دەبێت، بەڵام خۆتان بە زەیت چەور ناکەن، چونکە زەیتوونەکەتان دەوەرێت.  
\v 41 کوڕ و کچتان بۆ لەدایک دەبێت، بەڵام بۆ ئێوە نابن، چونکە بە دڵنیاییەوە ڕاپێچ دەکرێن.  
\v 42 پۆلە کوللەی باڵدار دەست دەگرن بەسەر هەموو دار و بەروبوومی زەوییەکەتانەوە. 
\p  
\v 43 ئەو نامۆیانەی لەنێوتاندان پلە بە پلە پایەبەرزتر دەبن، بەڵام ئێوە پلە بە پلە پایەنزم دەبن.  
\v 44 ئەوان قەرزتان پێدەدەن، بەڵام ئێوە قەرزیان پێ نادەن، ئەوان سەر دەبن، بەڵام ئێوە کلک. 
\p  
\v 45 هەموو ئەم نەفرەتانەتان دێتە سەر و دواتان دەکەوێت و پێتان دەگات هەتا لەناودەچن، چونکە ئێوە گوێڕایەڵی یەزدانی پەروەردگارتان نەبوون هەتا فەرمانەکان و فەرزەکانی بەجێبهێنن کە فەرمانی پێ کردن.  
\v 46 ئیتر بۆ هەتاهەتایە لەنێو ئێوە و لەنێو نەوەکەتان دەبنە پەند و نیشانە.  
\v 47 لەبەر ئەوەی یەزدانی پەروەردگاری خۆتان بە دڵخۆشی و دڵسافییەوە نەپەرست، کاتێک هەموو شتێک زۆر بوو،  
\v 48 کەواتە لە برسیێتی و تینووێتی و ڕووتی و نەداری لە هەموو شتێک، دەبنە کۆیلەی دوژمنەکانتان، کە یەزدان بۆ سەر ئێوەی دەنێرێت. ئەویش نیری\f + \fr 28:48 \ft مەبەستی لە بارگرانییە.‏\f* ئاسن دەخاتە سەر ملتان هەتا لەناودەچن. 
\p  
\v 49 یەزدان نەتەوەیەکتان دەهێنێتە سەر لە دوورەوە لەوپەڕی زەوییەوە وەک شاڵاوی هەڵۆ، نەتەوەیەک لە زمانی ناگەن،  
\v 50 نەتەوەیەکی ڕووگرژ، نە ڕێز بۆ پیر دادەنێت و نە سۆزی بۆ منداڵ دەجوڵێت.  
\v 51 بەری ئاژەڵی ماڵی و بەروبوومی زەویتان دەخوات هەتا لەناودەچن و هیچ دانەوێڵە و شەرابی نوێ و زەیت و گوێرەکەی گاگەل و کاریلە و بەرخی مێگەلتان بۆ ناهێڵێتەوە هەتا لەناوتان دەبات.  
\v 52 لە هەموو شارەکان گەمارۆتان دەدات، هەتا شوورا بەرزە قاییمەکان کە ئێوە پشتی پێ دەبەستن دەڕمێت، لە هەموو خاکەکەتان کە یەزدانی پەروەردگارتان پێتان دەدات گەمارۆتان دەدات. 
\p  
\v 53 جا بەری سکتان، گۆشتی کوڕ و کچەکانتان کە یەزدانی پەروەردگارتان پێیداون دەخۆن، لەو گەمارۆ و تەنگانەیەی کە دوژمنەکانتان تەنگتان پێ هەڵدەچنن.  
\v 54 پیاوی دڵناسک و زۆر هەستیار لەنێوتان بەرچاوتەنگ دەبێت، سەبارەت بە براکەی خۆی و بە ژنە خۆشەویستەکەی و بە پاشماوەی منداڵەکانی کە ماونەتەوە،  
\v 55 هەتا لە گۆشتی منداڵەکەی کە دەیخوات بە کەسیان نادات، چونکە هیچی بۆ نەماوەتەوە لەو گەمارۆ و تەنگانەیەی کە دوژمنەکانتان تەنگتان پێ هەڵدەچنن لە هەموو شارەکانتاندا.  
\v 56 ئەو ژنەی دڵناسک و هەستیارە لەنێوتان کە لەبەر دڵناسکی و هەستیارییەکەی دڵی نایەت بنی پێی بە زەویدا بنێت، بەرچاوتەنگ دەبێت سەبارەت بە پیاوە خۆشەویستەکەی و کوڕ و کچەکەی،  
\v 57 لەو یۆڵداشەی لەنێو هەردوو قاچی دێتەدەر و لە منداڵەکانی کە دەیبێت، چونکە بە نهێنی لە نەداری دەیانخوات، لەو گەمارۆ و تەنگانەیەی کە دوژمنەکانتان لە شارەکانتاندا تەنگتان پێ هەڵدەچنن. 
\p  
\v 58 ئەگەر ئاگادار نەبن بۆ ئەوەی کار بە هەموو وشەکانی ئەم فێرکردنە بکەن کە لەم پەڕتووکە نووسراون، بۆ ئەوەی لەم ناوە شکۆدارە سامناکە بترسن، لە یەزدانی پەروەردگارتان،  
\v 59 ئەوا یەزدان وا دەکات لێدانەکانتان و لێدانەکانی نەوەکەتان سەرسوڕهێنەر بێت، لێدانی سەخت و بەردەوام، نەخۆشی بە ئازار و هەمیشەیی.  
\v 60 هەموو دەردەکانی میسریش کە لێی تۆقین، بەسەرتاندا دێتەوە و پێتانەوە دەنووسێن.  
\v 61 هەروەها هەر نەخۆشییەک و هەر لێدانێک کە لەم پەڕتووکەی تەورات نەنووسراوە، یەزدان بەسەرتاندا دەدات هەتا لەناودەچن.  
\v 62 چەند کەسێکی کەم دەمێنن لە جێی ئەوەی وەک ئەستێرەی ئاسمان بوون لە زۆریدا، چونکە گوێڕایەڵی یەزدانی پەروەردگارتان نەبوون.  
\v 63 هەروەک چۆن یەزدان پێتان دڵخۆش بوو کە چاکەتان لەگەڵ بکات و زۆرتان بکات، هەروەها پێشتان دڵخۆش دەبێت هەتا بتانفەوتێنێت و لەناوتان ببات. لەو خاکە ڕیشەکێش دەکرێن کە دەچنە ناوی هەتا دەستی بەسەردا بگرن. 
\p  
\v 64 ئینجا یەزدان لەنێو هەموو گەلان پەرشوبڵاوتان دەکاتەوە، لەوپەڕی زەوی هەتا ئەوپەڕی، لەوێ خودای دیکە دەپەرستن لە دار و بەرد کە نە ئێوە و نە باوباپیرانتان نەیانناسیوە.  
\v 65 لەنێو ئەو نەتەوانەدا ناحەوێنەوە و پێیەکانتان جێگیر نابن، بەڵکو یەزدان لەوێ دڵێکی لەرزۆک و چاوێکی ماندوو و گیانێکی لاوازتان دەداتێ.  
\v 66 ژیانیشتان هەڵواسراو دەبێت لەبەردەمتان و شەو و ڕۆژ دەترسن و لە ژیانتان دڵنیا نابن.  
\v 67 لە ترسی دڵتان کە دەترسن و لە تێڕوانینی چاوەکانتان کە تێدەڕوانن، بە ڕۆژ دەڵێن، «خۆزگە شەو بێت،» بە شەویش دەڵێن، «خۆزگە ڕۆژ بێت.»  
\v 68 یەزدان بە کەشتی بەو ڕێگایەدا دەتانگەڕێنێتەوە بۆ میسر کە پێم گوتن، کە ئیتر نایبیننەوە، جا لەوێ وەک کۆیلە و کەنیزە بە دوژمنەکانتان دەفرۆشرێن و کەسیش ناتانکڕێت. 
\c 29  
\s1 تازەکردنەوەی پەیمانەکە 
\p  
\v 1 ئەمانە بەندەکانی ئەو پەیمانەن کە یەزدان فەرمانی بە موسا کرد کە لەگەڵ نەوەی ئیسرائیلدا بیبەستێت، لە خاکی مۆئاب بێجگە لەو پەیمانەی لە حۆرێڤ لەگەڵی بەستن. 
\p  
\v 2 ئینجا موسا هەموو ئیسرائیلی بانگکرد و پێی گوتن: 
\b  
\p «ئێوە بینیتان یەزدان لە خاکی میسر لەبەرچاوتان چی بە فیرعەون و هەموو خزمەتکارەکانی و هەموو خاکەکەی کرد،  
\v 3 ئەو تاقیکردنەوە مەزنانەی چاوەکانتان بینییان و نیشانە و پەرجووە مەزنەکانی.  
\v 4 بەڵام یەزدان هەتا ئەمڕۆش دڵێکی\f + \fr 29:4 \ft بەپێی کەلتوری عیبرانییەکان دڵ لێپرسراوە لە بیرکردنەوە.‏\f* پێنەداون بۆ ئەوەی تێبگەن و چاوێک بۆ ئەوەی ببینن و گوێیەک بۆ ئەوەی ببیستن.  
\v 5 بەڵام یەزدان دەفەرموێت: ”چل ساڵ لە چۆڵەوانیدا ئێوەم بەڕێوە برد، جلەکانتان لەبەرتان کۆن نەبوون و پێڵاوەکانتان\f + \fr 29:5 \ft عیبری: \+tl نەعەل‏\+tl*.‏\f* لە پێتان کۆن نەبوون،  
\v 6 نە نانتان خوارد و نە شەرابتان خواردەوە و نە مەی، هەتا ئێوە بزانن کە من یەزدانی پەروەردگارتانم.“ 
\p  
\v 7 «کاتێکیش هاتنە ئەم شوێنە سیحۆنی پاشای حەشبۆن و عۆگی پاشای باشان هاتن بۆ جەنگ لە دژی ئێمە، بەڵام ئەوانمان شکاند و  
\v 8 دەستمان بەسەر خاکەکەیاندا گرت و بە میرات دامانە ڕەئوبێن و گاد و نیوەی هۆزی مەنەشە\f + \fr 29:8 \ft هۆزی مەنەشە دابەش ببوون بۆ سەر دوو بەش، هەریەکەیان کەوتبووە لایەکی ڕووباری ئوردونەوە.‏\f*. 
\p  
\v 9 «بەندەکانی ئەم پەیمانە بپارێزن و کاری پێ بکەن، هەتا لە هەموو ئەوەی دەیکەن سەرکەوتوو بن.  
\v 10 ئێوە ئەمڕۆ هەمووتان بە سەرۆک هۆز و پیر و کوێخا و هەموو پیاوەکانی ئیسرائیل لەبەردەم یەزدانی پەروەردگارتان وەستاون،  
\v 11 هەروەها ژن و منداڵ و ئەو نامۆیانەی کە لەناو ئۆردگاکانتانە، لەوەی کە دارتان بۆ دەبڕێتەوە و ئاوتان بۆ لە بیر هەڵدەکێشێت،  
\v 12 بۆ ئەوەی بچنە ناو پەیمانی یەزدانی پەروەردگارتان و سوێندەکەی کە یەزدانی پەروەردگارتان ئەمڕۆ لەگەڵتانی دەبەستێت،  
\v 13 هەتا ئەمڕۆ بە گەلی خۆی داتانبنێت، ئەویش ببێتە خوداتان وەک پێی فەرموون و وەک سوێندی بۆ ئیبراهیم و ئیسحاق و یاقوبی باوباپیرانتان خوارد.  
\v 14 ئەم پەیمان و سوێندەش تەنها لەگەڵ ئێوەی نابەستم،  
\v 15 بەڵکو لەگەڵ ئەوەی کە لێرە ئەمڕۆ لەگەڵماندا لەبەردەم یەزدانی پەروەردگارمان وەستاوە و ئەوەش کە ئەمڕۆ لێرە لەگەڵماندا نییە. 
\p  
\v 16 «ئێوە زانیتان چۆن لە خاکی میسر نیشتەجێ بووین و چۆن هەتا ئێرە بەناو ئەو گەلانەدا تێپەڕین.  
\v 17 وێنە قێزەون و بتەکانی ئەوانتان بینی کە لە دار و بەرد و زێڕ و زیون.  
\v 18 نەوەک لەنێوتاندا پیاوێک یان ئافرەتێک یان هۆزێک یان خێڵێک هەبێت کە ئەمڕۆ دڵی لەسەر یەزدانی پەروەردگارمان لاچووبێت، بۆ ئەوەی بچێت و خوداوەندەکانی ئەو نەتەوانە بپەرستێت، نەوەک لەنێوتان ڕەگێک هەبێت ژەهراوی و زەقنەبووت بگرێت. 
\p  
\v 19 «کاتێک ئەم جۆرە کەسە گوێی لە سوێندی ئەم پەیمانە دەبێت، لە دڵیدا داوای بەرەکەت بۆ خۆی دەکات و دەڵێت: ”من سەلامەت دەبم، تەنانەت بە کەللەڕەقی خۆشم هەڵسوکەوت بکەم،“ ئەمە زەوی تەڕ و وشک لەناودەبات.  
\v 20 یەزدان هەرگیز ڕازی نابێت لێی خۆشبێت، بەڵکو ئەو کاتە تووڕەیی و دڵگەرمی یەزدان بەسەر ئەو پیاوە هەڵدەچێت، هەموو ئەو نەفرەتانەی لەم پەڕتووکەدا نووسراون دێنە سەری، یەزدان ناوی لەژێر ئاسماندا دەسڕێتەوە.  
\v 21 یەزدان لە هەموو هۆزەکانی ئیسرائیل ئەو بۆ لێقەومان جیا دەکاتەوە، بەپێی هەموو نەفرەتەکانی پەیمانەکە کە لەم پەڕتووکی تەوراتەدا نووسراون. 
\p  
\v 22 «جا دوا نەوە لە منداڵەکانتان کە لەدوای ئێوە دێن و هەروەها ئەو بیانییانەی لە خاکێکی دوورەوە دێن، ئەو گورزوەشاندن و نەخۆشییانە دەبینن کە یەزدان تووشی کردوون.  
\v 23 هەموو زەوییەکە بە گۆگرد و خوێ دەسووتێنێت، نە دەچێنرێت و نە دەڕوێت و نە هیچ گیایەکی لێ دەردەکەوێت، وەک سەرەوژێرکردنی سەدۆم و عەمۆرا و ئەدما و چەبۆئیم کە یەزدان بە تووڕەیی و هەڵچوونی خۆی سەرەوژێری کردن.  
\v 24 جا هەموو نەتەوەکان دەڵێن: ”بۆچی یەزدان وای بەم خاکە کرد، جۆشانی ئەم تووڕەییە بەتینە بۆچی؟“ 
\p  
\v 25 «وەڵامەکەیان ئەمەیە: ”لەبەر ئەوەی وازیان لە پەیمانی یەزدانی پەروەردگاری باوباپیرانیان هێنا، کە لەگەڵی بەستن کاتێک لە خاکی میسر دەریهێنان.  
\v 26 چوون خوداوەندی دیکەیان پەرست و کڕنۆشیان بۆ برد، کە نە ناسیبوویان و نە خوداش پێیدابوون.  
\v 27 لەبەر ئەوە تووڕەیی یەزدان بەسەر ئەم خاکەدا جۆشا، هەتا هەموو ئەو نەفرەتانەی لەم پەڕتووکی فێرکردنەدا نووسراون بەسەریدا هێنای.  
\v 28 یەزدان لە خاکەکەیاندا بە تووڕەیی و زەبر و ڕقێکی زۆرەوە ڕیشەکێشی کردن و وەک ئەمڕۆ فڕێیدانە خاکێکی دیکە.“ 
\p  
\v 29 «نهێنییەکان بۆ یەزدانی پەروەردگارمانە و ئەو شتانەی کە خودا بۆی ئاشکرا کردین بۆ ئێمە و نەوەکانمانە هەتاهەتایە، هەتا کار بە هەموو وشەکانی ئەم فێرکردنە بکەین. 
\c 30  
\s1 سەرکەوتن دوای گەڕانەوە بۆ لای یەزدان 
\p  
\v 1 «کاتێک هەموو ئەم بەرەکەت و نەفرەتەی کە خستوومەتە بەردەمتان بەسەرتان دێت، یەزدانی پەروەردگارتان لەنێو هەموو ئەو نەتەوانەی بۆ لایان دەرتاندەکات، ئینجا بەخۆتاندا دەچنەوە،  
\v 2 وە کاتێک خۆتان و منداڵەکانتان پڕ بە دڵ و لە ناختانەوە دەگەڕێنەوە لای یەزدانی پەروەردگارتان و گوێڕایەڵی دەبن، بەگوێرەی هەموو ئەوەی من ئەمڕۆ فەرمانتان پێ دەکەم،  
\v 3 ئەوا یەزدانی پەروەردگارتان لە ڕاپێچکراوی دەتانگەڕێنێتەوە\f + \fr 30:3 \ft گەڕاندنەوە لە ڕاپێچکراوی هێمایەک بووە بۆ نوێکردنەوەی بەختەوەری.‏\f* و بەزەیی پێتاندا دێتەوە، دووبارە کۆتان دەکاتەوە لەنێو هەموو ئەو گەلانەی یەزدانی پەروەردگارتان بەناویاندا پەرشوبڵاوی کردنەوە.  
\v 4 ئەگەر بۆ ئەوپەڕی ئاسمان پەرشوبڵاو کرابنەوە، ئەوا یەزدانی پەروەردگارتان لەوێوە کۆتان دەکاتەوە و لەوێوە دەتانگەڕێنێتەوە و  
\v 5 یەزدانی پەروەردگارتان دەتانهێنێتە ئەو خاکەی کە باوباپیرانتان خاوەنی بوون، جا ئێوە دەستی بەسەردا دەگرن و سەرکەوتووتان دەکات و لە باوباپیرانتان زۆرترتان دەکات.  
\v 6 یەزدانی پەروەردگارتان دڵی خۆتان و دڵی نەوەکەتان خەتەنە دەکات، تاکو یەزدانی پەروەردگارتان پڕ بە دڵ و لە ناختانەوە خۆشبوێت بۆ ئەوەی بژین.  
\v 7 هەروەها یەزدانی پەروەردگارتان هەموو ئەم نەفرەتانە دەخاتە سەر دوژمنەکانتان و ئەوانەی ڕقیان لێتانە و دەتانچەوسێننەوە،  
\v 8 بەڵام ئێوە دەگەڕێنەوە و گوێڕایەڵی یەزدان دەبن و کار بە هەموو فەرمانەکانی دەکەن کە من ئەمڕۆ فەرمانتان پێ دەکەم.  
\v 9 ئینجا یەزدانی پەروەردگارتان لە هەموو کارەکانی دەستتان سەروەت و سامانتان زۆر دەکات، لە بەری سک و ئاژەڵی ماڵی و بەروبوومی خاک، چونکە یەزدان سەرلەنوێ پێتان دڵخۆش دەبێت و سەرکەوتووتان دەکات، وەک بە باوباپیرانتان دڵخۆش بوو،  
\v 10 ئەگەر گوێڕایەڵی یەزدانی پەروەردگارتان بوون، فەرمان و فەرزەکانی بەجێبهێنن کە لەم پەڕتووکی تەوراتەدا نووسراون، ئەگەر پڕ بە دڵتان و لە ناختانەوە بۆ یەزدانی پەروەردگارتان گەڕانەوە. 
\s1 دانانی ژیان و مردن 
\p  
\v 11 «ئەم فەرمانەی من ئەمڕۆ فەرمانتان پێ دەکەم، لەسەرتان قورس نییە و لێتانەوە دوور نییە.  
\v 12 لە ئاسمان نییە هەتا بڵێن: ”کێ بۆمان سەردەکەوێتە ئاسمان و بۆمان دەهێنێت و بە گوێمانیدا دەدات هەتا کاری پێ بکەین؟“  
\v 13 هەروەها لە پشتی دەریا نییە هەتا بڵێن: ”کێ بۆمان لە دەریا دەپەڕێتەوە و بۆمان دەهێنێت و بە گوێمانیدا دەدات هەتا کاری پێ بکەین؟“  
\v 14 بەڵکو پەیامەکە زۆر لێتان نزیکە، لەسەر زمانتانە و لە دڵتاندایە، هەتا کاری پێ بکەن. 
\p  
\v 15 «بڕوانن، من ئەمڕۆ ژیان و چاکە، مردن و خراپەم خستووەتە بەردەمتان،  
\v 16 لەبەر ئەوەی من ئەمڕۆ فەرمانم پێکردن کە یەزدانی پەروەردگارتان خۆشبوێت و ڕێگاکانی بگرنەبەر و فەرمان و فەرزەکانی بەجێبهێنن و یاساکانی پەیڕەو بکەن، بۆ ئەوەی ئێوە بژین و گەشە بکەن و یەزدانی پەروەردگارتان لەو خاکەی ئێوە دەچنە ناوی هەتا دەستی بەسەردا بگرن، بەرەکەتدارتان بکات. 
\p  
\v 17 «بەڵام ئەگەر دڵتان لاچوو و گوێتان نەگرت، بەڵکو گومڕا بوون و بۆ خودای دیکە کڕنۆشتان برد و خزمەتتان کردن،  
\v 18 ئەوا من ئەمڕۆ پێتان ڕادەگەیەنم کە ئێوە بێگومان لەناودەچن، تەمەن درێژ نابن لەسەر ئەو خاکەی لە ڕووباری ئوردون بۆی دەپەڕنەوە هەتا بچنە ناوی و دەستی بەسەردا بگرن. 
\p  
\v 19 «من ئەمڕۆ ئاسمان و زەویتان لێ دەکەمە شایەت، کە من ژیان و مردن، بەرەکەت و نەفرەتم لەبەردەمتان داناوە، جا ژیان هەڵبژێرن هەتا خۆتان و نەوەکانتان بژین،  
\v 20 هەروەها یەزدانی پەروەردگارتان خۆشبوێت و گوێ لە دەنگی بگرن و دەستی پێوە بگرن. لەبەر ئەوەی ئەو ژیانتانە و درێژە بە تەمەنتان دەدات هەتا لەو خاکە نیشتەجێ بن کە یەزدان بۆ باوباپیرانتان ئیبراهیم و ئیسحاق و یاقوب سوێندی خوارد کە بیانداتێ.» 
\c 31  
\s1 یەشوع جێگەی موسا دەگرێتەوە 
\p  
\v 1 جا موسا چوو بەم وشانە لەگەڵ هەموو نەوەی ئیسرائیل قسەی کرد و  
\v 2 پێی گوتن: «ئێستا من تەمەنم سەد و بیست ساڵە، ئیتر ناتوانم ڕابەرایەتیتان بکەم و یەزدانیش پێی فەرمووم: ”لەم ڕووباری ئوردونە مەپەڕەوە.“  
\v 3 یەزدانی پەروەردگارتان لەپێشتانەوە دەپەڕێتەوە، خۆی ئەو نەتەوانە لەپێشتانەوە لەناودەبات و ئێوەش دەبنە میراتگریان. یەشوع لەپێشتانەوە دەپەڕێتەوە وەک یەزدان فەرمووی.  
\v 4 هەروەها یەزدان چی بە سیحۆن و عۆگ و بە خاکەکەیان کرد، دوو پاشاکەی ئەمۆرییەکان، کە لەناوی بردن ئاواش بەوان دەکات.  
\v 5 جا کاتێک یەزدان ئەوانی خستە دەستتان بەگوێرەی هەموو ئەو فەرمانانەی فەرمانم پێتان کرد، ئاوایان لێ دەکەن.  
\v 6 بەهێزبن و ئازابن، لێیان مەترسن و مەتۆقن، چونکە یەزدانی پەروەردگارتان لەگەڵتان دەڕوات، هەرگیز پشتگوێتان ناخات و وازتان لێ ناهێنێ.» 
\p  
\v 7 جا موسا یەشوعی بانگکرد و لەبەرچاوی هەموو ئیسرائیل پێی گوت: «بەهێز و ئازابە، چونکە تۆ لەگەڵ ئەم گەلە دەچیتە ناو ئەو خاکەی یەزدان سوێندی بۆ باوباپیرانیان خوارد کە بیانداتێ و تۆش بۆیانی دابەش دەکەیت وەک میراتیان،  
\v 8 یەزدانیش خۆی لەپێشتەوە دەڕوات، ئەو لەگەڵت دەبێت، هەرگیز پشتگوێت ناخات و وازت لێ ناهێنێ، مەترسە و ورە بەرمەدە.» 
\s1 خوێندنەوەی تەورات 
\p  
\v 9 ئینجا موسا ئەم فێرکردنەی نووسی و دایە دەستی کاهینەکان، کە نەوەی لێڤین و هەڵگری سندوقی پەیمانی یەزدانن، لەگەڵ هەموو پیرانی ئیسرائیل.  
\v 10 موسا فەرمانیشی پێکردن و گوتی: «هەر حەوت ساڵ جارێک، لە ساڵی لێخۆشبوونی قەرزەکان\f + \fr 31:10 \ft بەتاڵکردنەوەی قەرزەکان: بڕوانە 15‏:1‏-10.‏\f*، لە جەژنی کەپرەشینەدا\f + \fr 31:10 \ft جەژنی کەپرەشینە: بڕوانە 16‏:13‏-17، لێڤییەکان23‏:33‏-43، \xt سەرژمێری 29‏:12‏-38.‏\ft ‏\f*،  
\v 11 کاتێک هەموو ئیسرائیل دێن هەتا لەبەردەم یەزدانی پەروەردگارت دەربکەون لەو شوێنەی کە هەڵیدەبژێرێت، لە بەرامبەر هەموو ئیسرائیلدا ئەم فێرکردنە بە دەنگێکی بەرز دەخوێنیتەوە کە گوێیان لێ بێت.  
\v 12 گەل کۆبکەنەوە، پیاو و ئافرەت و منداڵ و ئەو نامۆیانەش کە لە شارۆچکەکانتانە بۆ ئەوەی گوێ بگرن و فێر بن لە یەزدانی پەروەردگارتان بترسن و هەموو وشەکانی ئەم فێرکردنە پەیڕەو بکەن و کاری پێ بکەن.  
\v 13 هەروەها نەوەکانیشتان کە ئەم فێرکردنەیان نەزانیوە، دەبێت گوێی لێ بگرن و فێر ببن کەوا لە یەزدانی پەروەردگارتان بترسن، بە درێژایی ئەو ڕۆژانەی لەسەر ئەو زەوییە دەژین کە ئێوە لە ڕووباری ئوردون بۆی دەپەڕنەوە هەتا دەستی بەسەردا بگرن.» 
\s1 پێشبینی یاخیبوونی ئیسرائیل 
\p  
\v 14 یەزدان بە موسای فەرموو: «وا تەمەنت لە مردن نزیک بووەتەوە، یەشوع بانگ بکە و لەناو چادری چاوپێکەوتن بوەستن بۆ ئەوەی ئەرکی پێ بسپێرم.» ئیتر موسا و یەشوع چوون و لەناو چادری چاوپێکەوتن ڕاوەستان. 
\p  
\v 15 ئینجا یەزدان لە ستوونی هەورێک دەرکەوت و ستوونی هەورەکە لە دەروازەی چادرەکە وەستا.  
\v 16 یەزدان بە موسای فەرموو: «ئەوەتا تۆ لەگەڵ باوباپیرانت سەردەنێیتەوە، جا ئەم گەلە هەڵدەستن و لەشفرۆشی\f + \fr 31:16 \ft بە واتای لەشفرۆشی جەستەیی و ڕۆحیش دێت. بەو کەسە دەگوترێت کە لاف لێدەدات بەوەفایە بۆ یەزدان، بەڵام لە هەمان کاتدا ستایش و قوربانی بۆ خودایەکی دیکە دەکات. واتا لە بنەڕەتدا کەسەکە بێوەفایە لەگەڵ یەزدان، هەروەک چۆن پیاوێک بێوەفا بێت بەرامبەر بە ژنەکەی.‏\f* لەگەڵ خوداوەندە بێگانەکانی ئەو خاکە دەکەن کە دەچنە ناوی و وازم لێ دەهێنن و ئەو پەیمانەم دەشکێنن کە لەگەڵیان بەستوومە.  
\v 17 ئیتر لەو ڕۆژەدا تووڕەییم بەسەریاندا گڕ دەگرێت و وازیان لێ دەهێنم و ڕووی خۆم لێیان دەشارمەوە و دەبنە نێچیر و تووشی زۆر ناخۆشی و بەڵا دەبن، هەتا ئەوەی لەو ڕۆژەدا دەڵێن: ”ئایا لەبەر ئەوە تووشی ئەو بەڵایانە بووین چونکە خودا لەگەڵمان نییە؟“  
\v 18 منیش لەو ڕۆژەدا ڕووی خۆم دەشارمەوە لەبەر هەموو ئەو خراپەیەی کە کردیان و کە دوای خودای دیکە کەوتن. 
\p  
\v 19 «ئێستاش ئەم سروودە بۆ خۆتان بنووسن و نەوەی ئیسرائیلیشی پێ فێر بکەن، بیخەنە دەمیانەوە هەتا بۆ من ببێتە شایەت بەسەر نەوەی ئیسرائیلەوە،  
\v 20 چونکە من دەیانبەمە ناو ئەو خاکەی سوێندم بۆ باوباپیرانیان خوارد، ئەوەی شیر و هەنگوینی لێ دەڕژێت، جا دەخۆن و تێر دەبن و قەڵەو دەبن و ئینجا دوای خودای دیکە دەکەون و دەیپەرستن و پشتم لێ دەکەن و پەیمانەکەم دەشکێنن.  
\v 21 جا کاتێک تووشی بەڵا و ناخۆشی دەبن، ئەم سروودە وەک شایەت وەڵامیان دەداتەوە، چونکە لە دەمی نەوەکەیان لەبیر ناکرێت، من دەزانم ئەوان ئەمڕۆ بیر لە چی دەکەنەوە، بەر لەوەی بیانبەمە ناو ئەو خاکەوە وەک سوێندم بۆ خواردن.»  
\v 22 جا موسا لەو ڕۆژەدا ئەم سروودەی نووسی و نەوەی ئیسرائیلیشی پێ فێرکرد. 
\p  
\v 23 ئینجا یەزدان فەرمانی بە یەشوعی کوڕی نون کرد و فەرمووی: «بەهێزبە و ئازابە، چونکە تۆ نەوەی ئیسرائیل دەبەیتە ناو ئەو خاکەی لەسەری سوێندم بۆیان خوارد و منیش لەگەڵت دەبم.» 
\p  
\v 24 لەدوای ئەوەی موسا بە تەواوی لە نووسینی وشەکانی ئەم فێرکردنە بووەوە لە پەڕتووکێک،  
\v 25 فەرمانی بە لێڤییەکانی هەڵگرانی سندوقی پەیمانی یەزدان کرد و گوتی:  
\v 26 «ئەم پەڕتووکەی تەورات ببەن و لەتەنیشت سندوقی پەیمانی یەزدانی پەروەردگارتان دایبنێن، هەتا وەک شایەتی بەسەرتانەوە لەوێ بێت،  
\v 27 چونکە من یاخیبوون و کەللەڕەقیتان دەزانم. من وا هێشتا زیندووم و ئەمڕۆ لەگەڵتانم، ئێوە بەو شێوەیە بەربەرەکانێی یەزدان دەکەن، ئەی باشە لەدوای مردنم چی دەکەن؟!  
\v 28 هەموو پیرانی هۆزەکان و کوێخاکانتانم بۆ کۆبکەنەوە، هەتا ئەم وشانەیان بەگوێدا بدەم، ئاسمان و زەوی بکەم بە شایەت بەسەریانەوە،  
\v 29 چونکە دەزانم ئێوە دوای مردنم بە تەواوی گەندەڵ دەبن و لەو ڕێگایە لادەدەن کە فەرمانم پێ کردوون. لە ڕۆژانی ئاییندە تووشی خراپە دەبن، چونکە لە بەرامبەر یەزدان خراپە دەکەن، بەو بتانە پەستی دەکەن کە بەدەستی خۆتان دروستی دەکەن.» 
\s1 سروودەکەی موسا 
\p  
\v 30 جا موسا تەواوی وشەکانی ئەم سروودەی خستە بەر گوێی هەموو کۆمەڵی ئیسرائیل: 
\c 32  
\q1  
\v 1 گوێ شل بکە ئەی ئاسمان، وا قسە دەکەم، 
\q2 با زەویش گوێ بگرێت لە وشەی دەمم. 
\q1  
\v 2 فێرکردنم وەک باران دەبارێت، 
\q2 وشەم وەک شەونم دەتکێت، 
\q1 وەک نمە باران بەسەر سەوزایی 
\q2 وەک ڕەهێڵ بەسەر گیا. 
\b  
\q1  
\v 3 ناوی یەزدان ڕادەگەیەنم، 
\q2 مەزنایەتی بە خودامان ببەخشن. 
\q1  
\v 4 خودا تاشەبەردە، کردارەکانی تەواوە، 
\q2 چونکە هەموو ڕێگاکانی دادپەروەرییە، 
\q1 خودایەکی دڵسۆزە، ستەمکاریی تێدا نییە، 
\q2 ئەو ڕاستودروست و دادپەروەرە. 
\b  
\q1  
\v 5 لە ڕەفتاردا گەندەڵ بوون لە بەرامبەر ئەو 
\q2 چونکە لەکەدارن، کچ و کوڕی ئەو نین، کەموکوڕییان ئەوەیە، 
\q2 نەوەیەکی چەوت و خوارن. 
\q1  
\v 6 ئایا بەم شێوەیە پاداشتی یەزدان دەدەنەوە، 
\q2 ئەی گەلی گێل و نادانا؟ 
\q1 ئایا ئەو باوک و دروستکەرتان نییە، 
\q2 ئەوەی دروستی کردن و پێکی هێنان؟ 
\b  
\q1  
\v 7 یادی ڕۆژانی دێرین بکەنەوە، 
\q2 لە ساڵانی نەوەکانی پێشوو وردبنەوە، 
\q1 لە باوکتان بپرسن پێتان ڕادەگەیەنێت، 
\q2 لە پیرانتان بپرسن پێتان دەڵێن. 
\q1  
\v 8 کاتێک خودای هەرەبەرز نەتەوەکانی بەش بەش کرد، 
\q2 کاتێک نەوەی ئادەمی دابەش کرد، 
\q1 سنووری بۆ گەلان دانا، 
\q2 بەگوێرەی ژمارەی نەوەی ئیسرائیل. 
\q1  
\v 9 بەشی یەزدان گەلەکەیەتی، 
\q2 یاقوب بەشی میراتەکەیەتی. 
\b  
\q1  
\v 10 لە خاکێکی چۆڵ دۆزییەوە، 
\q2 لە چۆڵەوانییەکی ترسناک و وێراندا، 
\q1 دەوری دا و بایەخی پێیدا، 
\q2 وەک گلێنەی چاوی پاراستی. 
\q1  
\v 11 وەک هەڵۆ هێلانەی خۆی دەهەژێنێت، 
\q2 لەسەر بێچووەکانی باڵەفڕکێ دەکات، 
\q1 باڵەکانی لێک دەکاتەوە و دەیبات، 
\q2 لەسەر شاپەڕەکانی هەڵیدەگرێت. 
\q1  
\v 12 ئاوا یەزدان بە تەنها ڕابەرایەتی کرد، 
\q2 هیچ خوداوەندێکی بێگانەی لەگەڵ نەبوو. 
\b  
\q1  
\v 13 سواری بەرزاییەکانی زەوی کرد، 
\q2 لە بەروبوومی دەشتودەری خوارد، 
\q1 لە تاشەبەردەوە هەنگوینی دەرخوارد دا، 
\q2 زەیتیش لە بەردەئەستێوە. 
\q1  
\v 14 دەڵەمە\f + \fr 32:14 \ft یان دەرەمە، قۆناغی پێش دروستبوونی پەنیر.‏\f* و شیری مەڕوماڵات، 
\q2 لەگەڵ دوگی\f + \fr 32:14 \ft دوگ یان دونگ.‏\f* بەرخ و 
\q1 بەرانی باشان و تەگە\f + \fr 32:14 \ft نێری، سابرێن.‏\f*، 
\q2 لەگەڵ چەوری ناوکی گەنم. 
\q1 تۆ لە خوێنی ترێ شەرابت خواردەوە. 
\b  
\q1  
\v 15 یەشوروون\f + \fr 32:15 \ft یەشوروون بە واتای سەرڕاست یان دادپەروەر دێت، وەکو نازناوێک بۆ گەلی ئیسرائیل بەکارهاتووە.‏\f* قەڵەو بوون و جووتەیان وەشاند، 
\q2 قەڵەو بوون و پڕ بوون و بە پیو\f + \fr 32:15 \ft پیو: واتا بەز، لێرە و لە ئایەتی 38.‏\f* داپۆشران. 
\q1 ئیتر پشتیان کردە ئەو خودایەی کە دروستی کردبوون، 
\q2 تاشەبەردی ڕزگارییەکەیان ڕەتکردەوە. 
\q1  
\v 16 ئیرەییان\f + \fr 32:16 \ft ئیرەیی: واتای هەڵوێستی توندی خودا بەرامبەر بە بتپەرستی، چونکە خودا دەیەوێت تەنها ئەو بپەرسترێت.‏\f* وروژاند بە پەرستنی خودا بێگانەکانیان و 
\q2 بە بتە قێزەونەکان پەستیان کرد. 
\q1  
\v 17 بۆ بتەکان\f + \fr 32:17 \ft بتەکان: بە واتای ڕۆحە پیسەکان.‏\f* کە خودا نین قوربانییان سەربڕی، 
\q2 چەند خودایەک نەیانناسیون، 
\q2 تازەن و بەم زووانە دەرکەوتوون، 
\q2 کە باوکانتان لێیان نەترساون. 
\q1  
\v 18 ئەو تاشەبەردەی ئێوەی بوو وازتان لێ هێنا، 
\q2 ئەو خودایەی لەدایکبوونی پێداین لەبیرتان کرد. 
\b  
\q1  
\v 19 جا یەزدان بینی و ڕەتی کردنەوە، 
\q2 لەبەر ئەوە تووڕە بوو بەهۆی کچەکانی و کوڕەکانی. 
\q1  
\v 20 فەرمووی، «ڕووی خۆم لێیان دەشارمەوە، 
\q2 سەیر دەکەم کۆتاییان چی دەبێت، 
\q1 ئەوانە نەوەیەکی هەڵگەڕاوەن، 
\q2 ئەو کوڕانە دەستپاکیان تێدا نییە. 
\q1  
\v 21 ئەوان بەوانەی خودا نین ئیرەییان وروژاندم، 
\q2 بە بتە پووچەکانیان پەستیان کردم، 
\q1 منیش وایان لێدەکەم ئیرەیی بەوانە ببەن کە گەل نین، 
\q2 بە نەتەوەیەکی گێل پەستیان دەکەم. 
\q1  
\v 22 بە تووڕەییم ئاگرێک داگیرساوە، 
\q2 گڕ دەگرێت هەتا جیهانی مردووانی ژێرەوە، 
\q1 زەوی و خەرمانەکەی دەخوات، 
\q2 بناغەکانی چیاکان دەسووتێنێت. 
\b  
\q1  
\v 23 «کارەساتیان بەسەردا کۆدەکەمەوە، 
\q2 تیرەکانم لەواندا دەچەقێنم. 
\q1  
\v 24 کاتێک لە برسان کەوتوون، 
\q2 پەکیان کەوتووە لەبەر تا و پەتای فەوتێنەر، 
\q1 ددانی دڕندە دەنێرمە سەریان، 
\q2 لەگەڵ ژەهری مارە خشۆکەکان. 
\q1  
\v 25 لە دەرەوە شمشێر جەرگیان دەسووتێنێت و 
\q2 لەناو ماڵەوەشیان تۆقین، 
\q1 کوڕی گەنج و پاکیزە لەناودەچن، 
\q2 منداڵی شیرەخۆر لەگەڵ پیاوی پیر. 
\q1  
\v 26 فەرمووم: ”پەرتەوازەیان دەکەم، 
\q2 یادیان لەنێو خەڵکی دەسڕمەوە.“ 
\q1  
\v 27 بەڵام لەوە ترسام کە دوژمن پەستم بکات، 
\q2 کە لەوانەیە دوژمنانیان تێنەگەن، 
\q1 نەوەک بڵێن: ”خۆمان باڵادەست بووین، 
\q2 یەزدان هەموو ئەمانەی نەکردووە.“» 
\b  
\q1  
\v 28 ئەوان نەتەوەیەکن ڕاوێژ لێ بڕاون، 
\q2 کوا تێگەیشتنیش لەناویان؟ 
\q1  
\v 29 خۆزگە دانا دەبوون و لەمە تێدەگەیشتن و 
\q2 کۆتاییەکەیان لەبەرچاو دەگرت. 
\q1  
\v 30 چۆن یەکێک هەزار ڕاو دەنێت و 
\q2 دووان دە هەزار تێکدەشکێنن، 
\q1 ئەگەر تاشەبەردەکەیان\f + \fr 32:30 \ft تاشەبەردەکەیان: ڕەوانبێژی لێکچواندنە، مەبەستی یەزدانە. بڕوانە ئایەتی 4.‏\f* ئەوانی نەفرۆشتبێت\f + \fr 32:30 \ft نەفرۆشتبێت: مەبەستی سزادانیانە لەبەر شکاندنی پەیمانەکەیان. بڕوانە ئایەتەکانی 18 و 19.‏\f*، 
\q2 یەزدان بەدەستەوەی نەدابن. 
\q1  
\v 31 لەبەر ئەوەی تاشەبەردیان وەک تاشەبەردی ئێمە\f + \fr 32:31 \ft تاشەبەردی ئێمە: مەبەستی لە یەزدانە.‏\f* نییە، 
\q2 تەنانەت دوژمنانیشمان دانی پێدا دەنێن. 
\q1  
\v 32 مێویان لە مێوی سەدۆمە و 
\q1 ترێیان هی باخەکانی عەمۆرایە، 
\q2 ترێیەکەیان ژەهرە و هێشووەکانیان تاڵن. 
\q1  
\v 33 شەرابەکەیان ژەهری مارەکان و 
\q2 تاڵاوی ماری کۆبرا کوشندەکانە. 
\b  
\q1  
\v 34 «ئایا ئەمە لەلای من هەڵنەگیراوە، 
\q2 لەناو گەنجینەکانم مۆری لێ نەدراوە؟ 
\q1  
\v 35 تۆڵەسەندنەوە هی منە، منم سزا دەدەم، 
\q2 لە کاتێکدا پێیان دەخلیسکێت، 
\q1 چونکە ڕۆژی بەڵایان نزیک بووەتەوە و 
\q2 چارەنووسیان بۆیان خێرایە.» 
\b  
\q1  
\v 36 یەزدان ئەستۆپاکی گەلەکەی دەسەلمێنێت و 
\q2 لەگەڵ خزمەتکارەکانی میهرەبان دەبێت، 
\q1 کە دەبینێت هێزیان بەسەرچووە و 
\q2 نە کۆیلە و نە ئازاد کەس نەماوە. 
\q1  
\v 37 خودا دەفەرموێت: «کوا خوداوەندەکانیان، 
\q2 ئەو تاشەبەردەی پەنایان بۆ برد، 
\q1  
\v 38 ئەو خوداوەندانەی کە پیوی قوربانییەکانیان دەخواردن، 
\q2 شەرابی خواردنەوە پێشکەشکراوەکانیان دەخواردنەوە؟ 
\q1 با بێن و یارمەتیتان بدەن، 
\q2 با پارێزگاریتان لێ بکەن! 
\b  
\q1  
\v 39 «ئێستا ببینن، من، من ئەوم، 
\q2 هیچ خودایەکی دیکە نییە لە پاڵم. 
\q1 من دەمرێنم و دەژیێنم، 
\q2 بریندار دەکەم و من چاک دەکەمەوە، 
\q2 کەس نییە کەسێک لە دەستی من دەرباز بکات. 
\q1  
\v 40 من دەستم بۆ ئاسمان بەرز دەکەمەوە و سوێند دەخۆم: 
\q2 بە دڵنیاییەوە هەتاهەتایە من زیندووم، 
\q1  
\v 41 کاتێک شمشێرە درەوشاوەکەم تیژ بکەمەوە و 
\q2 بۆ دادوەریکردن بە دەستەوەی بگرم، 
\q1 تۆڵە لە دوژمنانم دەکەمەوە و 
\q2 ناحەزانم سزا دەدەم. 
\q1  
\v 42 تیرەکانم بە خوێن مەست دەکەم و 
\q2 شمشێرەکەم گۆشت دەخوات، 
\q1 لە خوێنی کوژراوان و بەدیلگیراوان، 
\q2 لە کەللەسەری ڕابەرانی دوژمن.» 
\b  
\q1  
\v 43 ئەی نەتەوەکان، لەگەڵ گەلی خودا دڵخۆش بن، 
\q2 چونکە تۆڵەی خوێنی خزمەتکارانی دەکاتەوە، 
\q1 لە دوژمنانی تۆڵە دەکاتەوە، 
\q2 کەفارەتی خاک و گەلەکەی خۆی دەکات. 
\p  
\v 44 جا موسا خۆی و یەشوعی کوڕی نون هاتن و هەموو وشەکانی ئەم سروودەیان بۆ گەل خوێندەوە.  
\v 45 کاتێک موسا لە وتارەکە تەواو بوو، بە هەموو ئەم وشانە بۆ هەموو ئیسرائیل،  
\v 46 پێی گوتن: «لە دڵەوە لە هەموو ئەو وشانە وردببنەوە کە من ئەمڕۆ شایەتی پێدەدەم لەسەرتان، هەتا فەرمان بە منداڵەکانتان بکەن کە ئاگاداربن کار بە هەموو وشەکانی ئەم فێرکردنە بکەن.  
\v 47 تەنها وشەی بێ نرخ نییە بۆتان، بەڵکو ژیانتانە، بەهۆی ئەمانەوە تەمەن درێژ دەبن لەسەر ئەو خاکەی لە ڕووباری ئوردون بۆی دەپەڕنەوە هەتا دەستی بەسەردا بگرن.» 
\s1 موسا لەسەر چیای نیبۆ دەمرێت 
\p  
\v 48 یەزدانیش لە هەمان ڕۆژدا بە موسای فەرموو:  
\v 49 «سەربکەوە بۆ سەر زنجیرە چیای عەڤاریم، بۆ چیای نیبۆ کە لە خاکی مۆئابە و بەرامبەر بە ئەریحایە و لەوێوە تەماشای خاکی کەنعان بکە کە من وەک موڵک بە نەوەی ئیسرائیلی دەدەم.  
\v 50 لەو کێوەدا کە بۆی سەردەکەویت دەمریت و دەچیتە پاڵ گەلەکەتەوە، وەک چۆن هارونی برات لە کێوی هۆردا مرد و چووە پاڵ گەلەکەی،  
\v 51 لەبەر ئەوەی ئێوە ناپاک بوون لەگەڵم لەنێو نەوەی ئیسرائیلدا لەلای مێرگی مەریبای قادێش لە چۆڵەوانی چن، چونکە پیرۆزی منتان لەنێو نەوەی ئیسرائیلدا ڕانەگرت.  
\v 52 لەبەر ئەوە تۆ ناچیتە ناو ئەو خاکەی کە بە گەلی ئیسرائیلی دەدەم، بەڵکو تەنها لە دوورەوە دەیبینیت.» 
\c 33  
\s1 موسا داوای بەرەکەت دەکات بۆ هۆزەکان 
\p  
\v 1 ئەوەش ئەو بەرەکەتەیە کە موسای پیاوی خودا بۆ نەوەی ئیسرائیل\f + \fr 33:1 \ft نەوەی ئیسرائیلی: لێرەدا موسا بە ناوی وەچەکانی یاقوبەوە داوای بەرەکەت بۆ نەوەکانی ئەم هۆزانە دەکات، کە ئەم وەچانە نزیکەی 400 ساڵ لەمەوپێش لە خاکی میسردا مردبوون. بڕوانە \xt پەیدابوون 15‏:13 و دەرچوون 1‏:1‏-7 و کردار 7‏:6.‏\ft ‏\f* داوای کرد، بەر لە مردنی،  
\v 2 گوتی: 
\q1 «یەزدان لە سیناوە هات و 
\q2 لە سێعیرەوە بەسەریاندا هەڵهات، 
\q2 لە کێوی پارانەوە درەوشایەوە و 
\q1 هەزاران هەزار فریشتەی پیرۆزی لەگەڵ بوو، 
\q2 لە بنارەکانی باشوورەوە. 
\q1  
\v 3 بێگومان ئەوە تۆی کە هەموو گەلانت خۆشدەوێت، 
\q2 هەموو پیرۆزەکان لەنێو دەستی تۆدان، 
\q1 ئەوان لەلای پێت کڕنۆش دەبەن، 
\q2 ڕێنمایی لە تۆ وەردەگرن. 
\q1  
\v 4 موسا فەرمانی فێرکردنی پێداین، 
\q2 میراتە بۆ کۆمەڵی یاقوب. 
\q1  
\v 5 لەنێو یەشوروون\f + \fr 33:5 \ft ناوی (یەشوروون) واتا (ئەو کەسەی کە سەرڕاستە)، لێرە مەبەست لە نەوەی ئیسرائیلە.‏\f* بوو بە پاشا، 
\q2 بە کۆبوونەوەی ڕابەرەکانی گەل، 
\q2 هۆزەکانی ئیسرائیل پێکەوە. 
\b  
\q1  
\v 6 «با نەوەی ڕەئوبێن بژیێت و نەمرێت، 
\q2 با پیاوەکانی کەم نەبن.» 
\p  
\v 7 سەبارەت بە نەوەی یەهودا ئەمەی گوت: 
\q1 «ئەی یەزدان، گوێ لە دەنگی یەهودا بگرە و 
\q2 بۆ لای گەلەکەی بیهێنە، 
\q1 دەستەکانی بەسە بۆی، 
\q2 ببە بە یارمەتیدەر لە دژی دوژمنانی!» 
\p  
\v 8 سەبارەت بە نەوەی لێڤی گوتی: 
\q1 «تومیم و ئوریمی\f + \fr 33:8 \ft تومیم و ئوریم: دوو بەردی گرانبەها بوون، لە کاتی بڕیاردان بۆ زانینی خواستی خودا بەکارهێنراون، بڕوانە \xt دەرچوون 28‏:30 و یەکەم ساموئێل 23‏:9‏-12.‏\ft ‏\f* تۆ 
\q2 بۆ پیاوە خۆشەویستەکەتە، 
\q1 ئەوەی لە مەسا تاقیت کردەوە و 
\q2 لە مێرگی مەریبا خەباتت لەگەڵدا کرد. 
\q1  
\v 9 ئەوەی\f + \fr 33:9 \ft مەبەست لە هۆزی لێڤییە.‏\f* سەبارەت بە دایک و باوکی گوتی، 
\q2 ”ڕەچاوم نەکردوون،“ 
\q1 دانی بە براکانیشیدا نەنا و 
\q2 منداڵەکانیشی نەناسی، 
\q1 بەڵام چاودێری فەرمایشتەکانی تۆی کرد و 
\q2 پەیمانەکەی تۆی پاراست. 
\q1  
\v 10 نەوەی یاقوب، فێری ڕاسپاردەکانت و 
\q2 نەوەی ئیسرائیلیش فێری تەوراتی تۆ دەکات، 
\q1 بۆنی بخوور دەخاتە بەردەمت و 
\q2 قوربانی سووتاندنی تەواو دەخاتە سەر قوربانگاکەت. 
\q1  
\v 11 ئەی یەزدان، توانای شارەزایی بەرەکەتدار بکە و 
\q2 بە کرداری دەستی ڕازی بە، 
\q1 لە کەمەری بەرهەڵستکاران و ناحەزانی بدە، 
\q2 هەتا هەڵنەستنەوە.» 
\p  
\v 12 سەبارەت بە نەوەی بنیامین گوتی: 
\q1 «ئەو خۆشەویستی یەزدانە، بە ئاسوودەیی لەلای نیشتەجێ دەبێت، 
\q2 بە درێژایی ڕۆژ داڵدەی دەدات و 
\q2 یەزدان لەنێو هەردوو شانیدا نیشتەجێی دەکات.» 
\p  
\v 13 سەبارەت بە نەوەی یوسف گوتی: 
\q1 «با خاکەکەی لەلایەن یەزدانەوە بەرەکەتدار بێت 
\q2 بە شەونمی گرانبەهای ئاسمان، 
\q2 بە ئاوە قەتیسکراوەکانی خوارەوە، 
\q1  
\v 14 بە بەهادارترین دیارییەکانی خۆر و 
\q2 بەهادارترین دیارییەکانی بەروبوومی مانگ، 
\q1  
\v 15 بە بەهادارترین دیارییەکانی چیا دێرینەکان، 
\q2 بە بەسوودترین گردە هەتاهەتاییەکان، 
\q1  
\v 16 بە بەهادارترین دیارییەکانی زەوی و پڕییەکەی، 
\q2 لەگەڵ ڕەزامەندی نیشتەجێی ناو دەوەنەکە\f + \fr 33:16 \ft مەبەستی لە دەرکەوتنی خودایە بۆ موسا لەناو دەوەنەکە، بڕوانە \xt دەرچوون 3‏:1‏-6.‏\ft ‏\f*، 
\q1 با بەسەر سەری یوسفەوە بن، 
\q2 بەسەر تەپڵی سەری لە براکانی جیا کرایەوە.\f + \fr 33:16 \ft بڕوانە \xt پەیدابوون 37‏:11‏-15؛ 44‏:14.‏\ft ‏\f* 
\q1  
\v 17 نۆبەرەی گایەکەی شکۆمەندییە بۆی، 
\q2 قۆچەکانی قۆچی گای کێوین، 
\q1 بەوان قۆچ لە گەلان دەدات، 
\q2 پێکەوە هەتا ئەوپەڕی زەوی، 
\q1 ئەوان هەزاران هەزاری ئەفرایم و 
\q2 هەزارانی مەنەشەن.» 
\p  
\v 18 سەبارەت بە نەوەی زەبولون گوتی: 
\q1 «ئەی زەبولون بە کۆچکردنت دڵخۆش بە و 
\q2 تۆش ئەی یەساخار بە چادرەکانت، 
\q1  
\v 19 گەلان بۆ چیا بانگ دەکەن، 
\q2 لەوێ قوربانی ڕاستودروستی سەردەبڕن، 
\q1 هەتا لە پڕی دەریا بمژن و 
\q2 لەو گەنجینەیەی لەژێر لم شاردراوەتەوە.» 
\p  
\v 20 سەبارەت بە نەوەی گاد گوتی: 
\q1 «بەرەکەتدارە ئەوەی سنووری خاکی گادی فراوان کرد! 
\q2 وەک شێرە مێ نیشتەجێ بوو، 
\q2 قۆڵی پارچەپارچە کرد لەگەڵ تەپڵی سەر، 
\q1  
\v 21 باشترین خاکی بۆ خۆی دانا، 
\q2 بەشی فەرماندەی بۆ خۆی هەڵگرت، 
\q1 کاتێک سەرکردەکانی گەل کۆبوونەوە، 
\q2 دادوەری یەزدانی جێبەجێ کرد و 
\q2 حوکمەکانیشی سەبارەت بە ئیسرائیل.» 
\p  
\v 22 سەبارەت بە نەوەی دان گوتی: 
\q1 «دان بەچکە شێرە، 
\q2 لە باشان قەڵەمباز بەرەو پێش دەدات.» 
\p  
\v 23 سەبارەت بە نەوەی نەفتالی گوتی: 
\q1 «ئەی نەفتالی، تێر بە لە ڕەزامەندی و 
\q2 پڕ بە لە بەرەکەتی یەزدان، 
\q2 دەست بەسەر ڕۆژئاوا و باشووری خاکەکەتدا بگرە.» 
\p  
\v 24 سەبارەت بە نەوەی ئاشێر گوتی: 
\q1 «با ئاشێر لەنێو کوڕان بەرەکەتدار بێت، 
\q2 با لەلای براکانی پەسەند بێت، 
\q2 با پێی بکاتە ناو زەیت، 
\q1  
\v 25 دەروازەکانت لە ئاسن و بڕۆنزن، 
\q2 بەگوێرەی درێژی تەمەنت هێزت پێ دەبەخشێت.» 
\b  
\q1  
\v 26 «خودای یەشوروون هاوتای نییە، 
\q2 سواری ئاسمان دەبێت بۆ یارمەتیدانت، 
\q2 هەروەها هەورەکان لە شکۆی خۆیدا. 
\q1  
\v 27 خودای هەتاهەتایی پەناگاتە و 
\q2 باڵە هەمیشەییەکانیشی لە ژێرەوە. 
\q1 دوژمنی لەبەردەمت دەرکرد و 
\q2 فەرمووی: ”لەناو ببە!“ 
\q1  
\v 28 جا ئیسرائیل بە تەنها و بە ئاسوودەیی نیشتەجێ دەبێت، 
\q2 جێنشینی یاقوب گیروگرفتی نابێت، 
\q1 لە خاکی دانەوێڵە و شەرابی نوێ دەبێت، 
\q2 ئاسمانەکەشی شەونم دەتکێنێت. 
\q1  
\v 29 ئەی ئیسرائیل، خۆزگەت پێ دەخوازرێت، 
\q2 کێ وەک تۆیە، 
\q2 گەلێکی ڕزگار بوو لەلایەن یەزدانەوە؟ 
\q1 قەڵغانی یارمەتی و 
\q2 شمشێری شکۆمەندیتە، 
\q1 جا دوژمنانت ملکەچیت بۆ دەنوێنن، 
\q2 تۆش نزرگەکانی سەر بەرزاییان\f + \fr 33:29 \ft مەبەست لەو شوێنە بەرزانەیە کە بۆ قوربانیکردن و ڕێوڕەسمی پەرستنی بتەکان بووە، بڕوانە \xt سەرژمێری 33‏:52‏\ft ‏.‏\f* پێشێل دەکەیت.» 
\c 34  
\s1 مردنی موسا 
\p  
\v 1 ئینجا موسا لە دەشتەکانی مۆئابەوە بۆ چیای نیبۆ سەرکەوت بۆ سەری پسگە، کە بەرامبەر ئەریحایە، جا یەزدان هەموو خاکەکەی پیشان دا، لە گلعادەوە هەتا دان و  
\v 2 هەموو نەفتالی و خاکی ئەفرایم و مەنەشە و هەموو خاکی یەهودا هەتا دەریای ڕۆژئاوا و  
\v 3 نەقەب و هەموو ناوچەکە، لە دۆڵی ئەریحاوە «شاری دار خورما» هەتا زۆعەر،  
\v 4 یەزدان پێی فەرموو: «ئەوە ئەو خاکەیە کە سوێندم بۆ ئیبراهیم و ئیسحاق و یاقوب خوارد و فەرمووم: ”دەیدەمە نەوەکەت.“ وا بە چاوەکانی خۆت پێم پیشان دایت، بەڵام تۆ بۆ ئەوێ ناپەڕیتەوە.» 
\p  
\v 5 جا موسای بەندەی یەزدان لەوێ مرد، لە خاکی مۆئاب بەگوێرەی فەرمانی یەزدان.  
\v 6 یەزدان لە خاکی مۆئاب لە دۆڵەکە بەرامبەر بێت‌پەعۆر ناشتی، هەتا ئەمڕۆش کەس گۆڕەکەی پێ نازانێت.  
\v 7 موسا تەمەنی سەد و بیست ساڵ بوو کاتێک مرد، هێشتا چاوەکانی کز نەببوون و هێزی لەبەر نەبڕابوو.  
\v 8 جا نەوەی ئیسرائیل لە دەشتەکانی مۆئاب سی ڕۆژ ماتەمیان بۆ گێڕا، ئینجا ڕۆژانی گریان و شیوەنی موسا تەواو بوو. 
\p  
\v 9 یەشوعی کوڕی نونیش پڕ بوو لە ڕۆحی دانایی، چونکە موسا دەستی لەسەر دانابوو. ئیتر نەوەی ئیسرائیل گوێیان لێ گرت و ئاوایان کرد وەک ئەوەی یەزدان فەرمانی بە موسا کردبوو. 
\p  
\v 10 جا هیچ پێغەمبەرێک لە ئیسرائیل پەیدا نەبوو وەک موسا کە یەزدانی ڕوو بە ڕوو ناسی،  
\v 11 لە هەموو ئەو نیشانە و پەرجووانەی یەزدان ناردی هەتا لە خاکی میسر بە فیرعەون و هەموو خزمەتکارەکانی و هەموو خاکەکەی بکات.  
\v 12 هەرگیز کەس ئەو توانا مەزنەی پیشان نەداوە و ئەو کارە مەزن و سامناکانەی لەبەرچاوی هەموو ئیسرائیل نەکردووە کە موسا کردی.