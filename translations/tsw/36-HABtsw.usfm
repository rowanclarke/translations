\id HAB - Tsishingini (tsw)
\h Haba̱ku
\toc3 Hab
\toc2 Haba̱ku
\toc1 Haba̱ku
\mt2 Aatagada a vumava̱sula̱
\mt1 Haba̱ku
\is1 Ucuɗuwu wa aatagada a nda
\ip Babu za na revei mantsa ma na a ɗanai aatagada a nda. Haba̱ku yuwan ta̱ alajiya a a'wan ukpakucindere (700) kafu a matsan Yesu, a rana vu ukosu u tsugono tsa Yahuda babu na u riya̱i e ekere o mogono ma Babila.
\ip Mantsa suru a ama a̱ ta̱ yeci nye i zuwai A̱sula̱ a lyawusa ama a vama a lyuwa aci ama a̱ɓula̱. Ili'i u ɓa̱la̱ ta̱ Haba̱ku lon, hali we ece A̱sulazuva adama a̱ nye ɗa tsugono tsi iwuya ya Babila a lyuwusa elime, hali o kototosu aza a na a la'a nle a̱ɓula̱. U dama ta̱ lon adama wu uwwa usuwu u yeci'i. Agba A̱sulazuva a̱ usu yi ta̱ u damma, n ta̱ ge'eto za suru, amma a̱za̱ a̱ a̱ɓula̱ a ta la'a o una̱ wu ucawu wo okolo e le. U'usuwu u nda u kamba ta̱ Haba̱ku o una̱ wa amayun a na u ri na̱ yi e ifoɓi i na A̱sulazuva a yuwain adama a rana vi iwuya na we enei lo a̱ ta̱wa̱.
\ip Akapi adanshi e ikaka i na i ri pe a̱tsuma̱ a aatagada'a u ta̱ adama o uge'etosu wa̱ a̱za̱ o ulambu wa̱ a̱ɓula̱. O ukosu vumava̱sula̱ Haba̱ku ca ta̱ usuwu wa amayun a̱ yi adanshi A̱sulazuva a̱tsuma̱ e ishipa yi ica ya̱ A̱sula̱.
\io1 Ili i na i ri pe:
\io1 Adanshawuya a Haba̱ku nu usuwu wa adanshi A̱sulazuva 1:1-2:4
\io1 Uge'etosu wa̱ a̱za̱ o ulambu wa̱ a̱ɓula̱ 2:5-20
\io1 Avasa Haba̱ku 3:1-19
\ib
\c 1
\p 
\v 1 Apa ikaka i na Haba̱ku vumava̱sula̱ e enei a̱tsuma̱ alavu alavu.
\s1 Mesun ma Haba̱ku
\q1 
\v 2 A̱sulazuva, hali mantsa ma̱ ne ma ɗa,
\q2 mee showen wu adama e ikambishi,
\q2 agba vaa zuwaa mu atsuvu shi?
\q1 N yuwusan ta̱ mesun kuci
\q2 adama o u'ya̱susa̱n wu ugbozu,
\q2 agba vu wawa shi?
\q1 
\v 3 Nye i zuwai vu lyawa numu
\q2 eneshe ulambu wa̱ a̱ɓula̱?
\q1 Nye i zuwai vu ri a̱ a̱ka̱nla̱ e iwuya?
\q1 Ukototosu nu u'ya̱susa̱n wu ugbozu n ta̱ elime a̱ va̱.
\q2 Mawasan na̱ nronuloi n 'yon ta̱.
\q1 
\v 4 Adama o ndolo wila̱ u ri nu ucira shi,
\q2 waru amayun a buwa o ulinga shi.
\q1 A̱za̱ e iwuya a̱ ka̱nda̱ruwa̱ ta̱ a̱za̱ a̱ a̱ɓula̱,
\q2 adama a vadala amayun.
\s1 U'ususu wa̱ A̱sulazuva
\q1 
\v 5 Reve A̱sulazuva a damma,<<Ka̱lyuwa̱ nɗa vee e ene,
\q2 vu ta yuwan asalama lon,
\q1 adama a na n ta yuwan ili i ro
\q2 a rana wuma wa̱ wu,
\q2 zana ko na̱ shi a damma wu
\q2 va̱a̱ usu shi.\x - \xo 1:5 \xt Ajy 13:41.\x*
\q1 
\v 6 N ta̱ 'ya̱susa̱n aza a Babila,
\q2 iɗa yu usuɗuwu nu ujaru fo,
\q1 aza a na a̱ ri a mmalu
\q2 uba̱ta̱ suru a̱tsuma̱ o uvaɗi
\q2 a ususa ba̱ta̱ vu nden n na ri a̱za̱ e le shi.\x - \xo 1:6 \xt 2 Ngo 24:2.\x*
\q1 
\v 7 Ele ili i wovon i ɗa ni ili yi ilaɗi,
\q2 a ta yuwusaan aciyele uge'etosu cine a cigai.
\q1 
\v 8 Ido i le i la'a ta̱ ta̱su ilaɗi,
\q2 asuvu usuɗuwu u le u la'a ta̱ nkerenkesu n na n ri na ambulu,
\q1 akumbi e ido e le a̱ tsu ta̱wa̱ ta̱ na afalu.
\q2 Akumbi e ido e le a̱ tsu ta̱wa̱ ta̱ diga uba̱ta̱ wa alanga,
\q2 a̱ tsu zura̱ ta̱ tsa̱ a̱a̱kuru a na a cigai a̱ ka̱ɗa̱.
\q1 
\v 9 Suru nle a̱ tsu ta̱wa̱ ta̱ adama o u'ya̱susa̱n wu ugbozu.
\q2 A ta uwwusa wovon u le babu na a rawai.
\q2 O tsu ɓoloto ta̱ agbashi cine vu revei wuyun.
\q1 
\v 10 A tsu lamaa ta̱ ngono,
\q2 reve o zo'oso azagbain.
\q1 O tsu zo'oso ta̱ fo
\q2 ilyuci i na i ri nu ukari wu ucira suru,
\q2 a tsu ɓoloto ta̱ ma̱bula̱ reve a kumba a lyuwa yi.
\q1 
\v 11 A̱ tsu ka̱ra̱ ta̱ tsu upepu,
\q2 a lyuwa elime,
\q1 ozo o unusu a ɗa,
\q2 aza a na ma̱sula̱ ma̱ le a̱yi ɗa ucira u le.>>
\s1 Haba̱ku da̱shi ta̱ showen A̱sulazuva
\q1 
\v 12 A̱sulazuva, a̱vu ɗaɗa vu ri hali hali!
\q2 A̱sula̱ a̱ va̱, za va akiza, tsa̱ kuwa̱ shi.
\q1 A̱sulazuva,
\q2 a̱vu ɗa vu zuwa nle e ge'etosu.
\q2 A̱vu Aatali, a̱vu ɗa vu zuwa nle a ca tsu a̱tsuma̱lima̱.
\q1 
\v 13 Esu a̱ wu a̱ ta̱ na akiza lon
\q2 vaa gura ka̱lyuwa̱ iwuya shi,
\q2 vu tsu ciga vu ka̱lyuwa̱ unusu shi.
\q1 Cine tsa ɗa va̱a̱ ka̱lyuwusa̱ aza a na aa yuwusan iwuya?
\q2 Cine tsa ɗa vu rungwa̱i a̱za̱ e iwuya kpaku
\q2 o soɗusu aza a na a la'a nle a̱ɓula̱?
\q1 
\v 14 Vu yuwan ta̱ ama
\q2 tsa mugula a̱tsuma̱ a mala,
\q1 tsi ili i wuma i mala
\q2 i na i ri na̱ zagbain shi.
\q1 
\v 15 N'yuwatan n tsu reme le ta̱ na̱ gon,
\q2 reve o uta̱a̱ le alanga ni igolo,
\q1 o tsu ɓoloto le ta̱ a̱ agaso e le,
\q2 a̱vu a yuwan mere na̱ ma̱za̱nga̱.
\q1 
\v 16 Adama o ndolo a tsu yuwaan ta̱ igolo i le kucci,
\q2 reve a yuwaan agaso e le a̱tsuka̱ a̱ ma̱guru.
\q1 Adama a na e le ɗa a̱ ta̱wa̱a̱ nle nu utsuru
\q2 ni ilyalya ya̱ a̱bunda̱.
\q1 
\v 17 A ta lyuwa elime a̱ za̱la̱sa̱ igolo i le?
\q2 O kototosu nɗa babu ene iliyali hali hali?
\c 2
\q1 
\v 1 N ta kumba atsura a̱ va̱
\q2 mi isawan tsa za vi ipiri,
\q2 n puro mu uwwa ili i na waa damma mu,
\q2 nu usuwu u na wa ca adama e mesun ma̱ va̱.
\b
\s1 U'ususu wa̱ A̱sulazuva wa̱ ire
\q1 
\v 2 Reve A̱sulazuva a damma mu,
\q2 <<Vu ɗana alavu alavu'u
\q2 vu ɗana yi a alanga e eteshe aɓaci a atali,
\q1 tsa̱ra̱ za vu ɗesununa̱
\q2 u ɗe yi babu usa̱n.
\q1 
\v 3 Adama a na alavu alavu'u
\q2 u ta pura mantsa ma na a zuwai,
\q1 u ta yuwusan adanshi o ukosu
\q2 waru wo o'wo epen shi.
\q1 vu puro yi, ko nu jima,
\q2 na amayun u ta̱ ta̱wa̱, waa tara mantsa shi.\x - \xo 2:3 \xt M.Ib 10:37.\x*
\q1 
\v 4 Uwwai, za na okolo a̱ yi a̱ ri mejege shi u ta̱ riya̱,
\q2 amma za va̱ a̱ɓula̱ ta yuwan wuma,
\q2 adama o ucawu wo okolo a̱yi.>>
\q1 
\v 5 Na̱ ne suru, masayan ma̱ ina̱bi\f + \fr 2:5 \fq masayan ma̱ ina̱bi \ft Yiɗanishi i ro a yuwan ta̱ ulinga nu <<utsuru>> pa nda.\f*
\q2 ma̱ tsu pusa̱n ta̱ za vu uvaɗu ugbozu,
\q2 adama o ndolo u tsu da̱nu o u'wa shi.
\q1 Utsa̱n wa̱ yi u ta̱ a̱bunda̱ tso ason,
\q2 waru u ta̱ tsu ukwa̱, u tsu cuwa̱n shi.
\q1 U tsu ɓolotowo ta̱ aciya̱yi nɗa suru,
\q2 a̱vu u pura̱a̱ aciya̱yi ama suru.
\q1 
\v 6 Ama'a suru a ta yuwan tsushu'un na̱ a̱yi,
\q2 o zo'osuso yi a yuwusan yi ulamu a dansa,
\q1 <<A̱tsuma̱lima̱ a ta cina za na o ɓolotosoo aciya̱yi itana i wivu!
\q2 Hali a̱ tyo a mantsa ma̱ ne
\q2 voo ɓolotowo aciya̱wu
\q2 utsuru a̱tsuma̱ o ure wu ule'e?>>
\q1 
\v 7 Babu usa̱n, aza a na o tono wu utan a ta zuwa wu elime,
\q2 a̱ ta̱ ta̱wa̱ a zuwa wu meje'en ma̱ lipu.
\q1 Vu to o'wo le itana
\q2 i na a̱ pura̱i uba̱ta̱ o uvon.
\q1 
\v 8 Ana wo o'woi vu usa ta̱ nɗa na̱ a̱bunda̱,
\q2 akapi a ama a nɗa nna n buwai a ta usa a̱za̱ a̱ wu.
\q1 Adama a na vo oco ta̱ mpasa ma ama,
\q2 vu lungusa̱ nɗa ni ilyuci,
\q2 na ama a na a̱ ri a̱tsuma̱ e le suru.
\q1 
\v 9 <<A̱tsuma̱lima̱ a ta cina
\q2 za na a lyuwusa melen ma̱ yi shi adama o u'wa wa̱ yi!
\q1 A̱vu na vu suwai u'wa zuva va aagaɗi
\q2 adama vu la'a a addama!
\q1 
\v 10 Vu ronoo ta̱ u'wa wa̱ wu wono.
\q2 Adama a na vu una ta̱ ama na̱ a̱bunda̱,
\q2 vu kototo ta̱ aciya̱wu.
\q1 
\v 11 Atali o ukari a̱ ta̱ shon,
\q2 atsura akpata a̱ ta̱ usu.
\q1 
\v 12 A̱tsuma̱lima̱ a ta cina,
\q2 za na suwai lyuci na̱ mpasa,
\q2 za na suwai lyuci gbain ni iwuya!
\q1 
\v 13 Ashe A̱sulazuva o oɓolo a̱ a̱soja a zuva ɗa zuwai ama o uvaɗi
\q2 a yuwan a̱tsuma̱lima̱ reve akina o soɗu le shi?
\q2 Waru a yuwan ulinga we pere shi?
\q1 
\v 14 Adama a na uvaɗi u ta̱ da̱na̱ tapu
\q2 nu urevu u tsugbain tsa̱ A̱sulazuva,
\q2 cine vu revei mini mo tsu shiton mala.\x - \xo 2:14 \xt Ish 11:9.\x*
\q1 
\v 15 A̱tsuma̱lima̱ a ta cina za na tsura̱to yi nron mu nden ma̱ yi,
\q2 a̱ zuɗa̱sa̱ yi diga a̱ tsa̱n vu ukwan hali she no o'wo usowu,
\q2 tsa̱ra̱ we ene e le aataɓu!
\q1 
\v 16 Wono u ta̱ kpa̱to wu o una̱ u tsugbain.
\q2 Gogo mantsa ma̱ wu ma ɗa!
\q2 Vu to sowo vo o'wo ataɓu!
\q1 Mokkoto ma na ma̱ ri o ukere u sa'ani wa̱ A̱sulazuva ma̱ ta̱ riya̱ wu,
\q2 ili i wono i kpa̱to tsugbain tsa̱ wu.
\q1 
\v 17 Ulungusu u na vu yuwain a aci a Lebanon
\q2 u ta̱ ka̱mba̱ a aci ya̱ wu,
\q1 mona me inama ya̱ yi i na vu yuwain
\q2 u ta ca wu wovon.
\q1 Adama a na vo oco ta̱ mpasa ma ama,
\q2 a̱vu vu lungusa̱ nɗa ni ilyuci,
\q2 na ama a na a̱ ri suru a̱tsuma̱ e le na̱ nden.
\q1 
\v 18 Ucira u ne u ɗa a̱a̱ma̱li a̱ ri na̱ a̱yi
\q2 ana wo o'woi vuma ɗa she'en niyi?
\q2 Uruma u ɗa u na woo ritosu epen.
\q1 Adama a na vuma na yuwan niyi
\q2 u ta zuwusa ucira e ili i na u yuwain,
\q2 u yuwan ta̱ a̱ma̱li a na a tsu yuwan adanshi shi.
\q1 
\v 19 A̱tsuma̱lima̱ a ta cina za na dammai akpata, <Ka̱mba̱ wuma>
\q2 Ko aatali a na a̱ ri ukwa̱, <'Yon!>
\q2 U ta gura yuwan uritosu?
\q1 Agba a̱yi ɗa nda a pala yi ta̱
\q2 na̱ zinariya oɓolo na̱ azurufa,
\q2 agba u ri wuma shi.
\q1 
\v 20 Amma A̱sulazuva a̱ ta̱ pe a̱tsuma̱ a̱ A̱a̱'isa̱ a Akiza a̱ yi,
\q2 lyawa uvaɗi ma̱ɓula̱ u rungwa̱ kpen
\q2 a̱ ma̱ka̱ka̱n ma̱ yi.>>
\c 3
\s1 Avasa a Haba̱ku
\p 
\v 1 Avasa a Haba̱ku vumava̱sula̱, aci a Shigiyonotu\f + \fr 3:1 \fq Shigiyonotu \ft Na̱ Tsuyahuda a̱ ta̱ na̱ <<Shigiyonotu,>> danshi na urevu wa̱ yi wu uta̱ alanga e eteshe shi.\f*.
\b
\q1 
\v 2 A̱sulazuva, mu uwwa ta̱ aɗa o ulinga wa̱ wu,
\q2 reve wovon u guza̱ mu.
\q1 Vu yuwisan a̱ba̱jini a linga va̱ wu a mantsa ma̱ tsu,
\q2 vu lyawa e reve le.
\q1 A̱tsuma̱ o upan wa̱ wu
\q2 vee ene iliyali i tsu.
\q1 
\v 3 A̱sula̱ a̱ ta̱wa̱ ta̱ diga Teman,
\q2 Za va Akiza ta̱ ta̱wa̱ diga a Masasan ma Faran.
\q1 Zuva va zuva ta shiwan na̱ tsugbain tsa̱ yi,
\q2 uvaɗi ma̱ɓula̱ u ta shiwan ni ica ya̱ yi.
\q1 
\v 4 Imaɗatsu ya̱ yi i ta̱ tse ekan yu urana,
\q2 eka'an u ta̱ e ikanasa diga o ukere wa̱ yi,
\q2 uba̱ta̱ u na ucira wa̱ yi u ri usokowu.
\q1 
\v 5 U lyungu ta̱ mɓa̱la̱ elime a̱ yi,
\q2 waru u zuwa ta̱ ukwa̱ wu usuɗuwu u kuru a̱ca̱pa̱ a̱ yi.
\q1 
\v 6 Wi isawan ta̱, reve u jinga̱ɗa̱ uvaɗi.
\q2 A̱vu u ka̱lyuwa̱, reve u zuwa nɗa n je'en.
\q1 Akuci a nsasan a̱ ra̱mo ta̱,
\q2 a̱vu akuci a agaɗi o oco.
\q2 Re va̱ yi a̱ ta̱ lo hali hali.
\q1 
\v 7 Me ene ta̱ ogodo a̱ Kushan a̱tsuma̱lima̱,
\q2 ama e iɗa ya Midiya e meje'en ma̱ lipu.
\q1 
\v 8 A̱sulazuva, vu yuwan ta̱ upan na̱ ɗolu?
\q2 A̱tsumola̱ngu a̱ wu a̱ ta̱ aci o ɗolu?
\q2 Upan wu usuɗuwu wa̱ wu u ta aci a mala?
\q1 A mantsa ma na vu kumbai ido ya̱ wu,
\q2 ni ikeke yi ido yu ulyuwu wa aci ya̱ wu?
\q1 
\v 9 Vu uta̱ ta̱ utan wa̱ wu alanga e eteshe,
\q2 vu zuwa ta̱ aya a̱ wu a'yin. \qs Wivuwun\qs*
\q2 A̱vu vu ne'eshen uvaɗi na̱ mini.
\q1 
\v 10 Nsasan me ene wu ta̱,
\q2 a̱vu o oɓoro.
\q1 A jara ta̱ mini ma̱ a̱bunda̱,
\q2 hali mala ma̱ a̱ru'un ma̱gugwa̱,
\q2 hali ikeɗu i mala'a i 'yon zuva.
\q1 
\v 11 A̱vu urana na̱ woto e isawan kpen
\q2 uba̱ta̱ u na a̱ ri na̱ nde,
\q1 adama e ekan ya aya a̱ wu na a̱ ka̱ra̱i,
\q2 oɓolo ne ekan e ibata ya̱ wu.
\q1 
\v 12 A̱tsuma̱ asuvu usuɗuwu a̱ wu a ɗa vu dasai uvaɗi,
\q2 a̱tsuma̱ o upan u ɗa vu dasai nɗa.
\q1 
\v 13 Vu uta̱ ta̱ tsa̱ra̱ vu wawa ama a̱ wu,
\q2 adama vu wawa aza a na vu tawai.
\q1 Vu kototo ta̱ za vi iwuya,
\q2 reve vu voton yi ataɓu.
\q1 
\v 14 Vu sapa yi ta̱
\q2 aaci ni ibata ya̱ yi,
\q1 ana a̱soja a̱yi na a gurai uvon a̱ ta̱wa̱i tsa̱ lipa̱
\q2 tsa̱ra̱ e bete'we tsu,
\q1 ma̱za̱nga̱ ma̱ le a̱ yi ɗa o soɗu
\q2 alambi a na a̱ ri usokowu.
\q1 
\v 15 Vu dasa ta̱ mala ni ido ya̱ wu,
\q2 vu ta̱ lukuta̱sa̱ mini mo ucira.
\q1 
\v 16 Na mu uwwai ne, a̱vu okolo a̱ va̱ a̱ riya̱,
\q2 a̱vu una̱ u va̱ u je'en adama e ilama,
\q1 etele a̱ va̱ a̱ kuwa̱ ta̱,
\q2 a̱mu a mmalu ana a̱ va̱ e meje'en.
\q1 Suru na̱ ne n ta kaɓa asuvu,
\q2 n puro urana wa̱ a̱tsuma̱lima̱ u ta̱wa̱ a aci e iɗa
\q2 i na ya̱a̱ ta̱wusa̱a̱ tsu nu uvon.
\q1 
\v 17 Ko na̱ shi uɗanga wu ubiri u ɓoso yipa̱lu shi,
\q2 ko na̱ shi a̱ tsura̱ muwun n ina̱bi a ataci shi,
\q2 ko na̱ shi ɗanga zetun matsan shi,
\q2 ko iɗa i kuɗa̱ a̱ ta̱wa̱a̱ ni ilyalya,
\q1 ko na̱ shi babu ikyon o uva̱la̱ta̱
\q2 ko na̱ shi babu inan uba̱ta̱ u na a̱a̱ gutsusu le,
\q1 
\v 18 suru na̱ ne n ta yuwan ma̱za̱nga̱ a̱ ma̱ka̱ka̱n ma̱ A̱sulazuva.
\q2 N ta yuwan mere e ekere a̱ A̱sula̱ za vi iwawi i va̱.
\q1 
\v 19 A̱sulazuva zagbain ɗa ucira u va̱,
\q2 u zuwa ta̱ ana a̱ va̱ e reme iɗa tsa mere'on,
\q2 n yuwan mmalu zuva va atali.\x - \xo 3:19 \xt 2 Sam 22:34; Ica 18:33.\x*
\b
\q1 Udammu a̱ tyo a̱ ma̱dobiya. Za vi itana i tsuwe'e i na i ri na a'yin.
