\id 1TH Mazatec of Jalapa de Díaz
\h Xu̱ju̱n xi tjun kin'ekjíhi̱ xu̱ta̱ ni̱nku̱ Tesaloni̱ka̱
\toc1 Xu̱ju̱n xi tjun kits'ínkjihi̱ nda̱ postru̱ Pablo̱ xu̱ta̱ ni̱nku̱ Tesaloni̱ka̱
\toc2 Xu̱ju̱n xi tjun kin'ekjíhi̱ xu̱ta̱ ni̱nku̱ Tesaloni̱ka̱
\toc3 1 Ts.
\mt1 Xu̱ju̱n xi tjun kits'ínkjihi̱ nda̱ postru̱ Pablo̱ xu̱ta̱ ni̱nku̱ Tesaloni̱ka̱
\c 1
\s1 B'i̱ ts'ín kikjaniñaha̱ Pablo̱ xu̱ta̱ ni̱nku̱ xi tjín nanki Tesaloni̱ka̱
\p 
\v 1 An Pablo̱, Silbano̱ ko̱ Timoteo̱ tísuniñai̱hi̱, jun xu̱ta̱ ni̱nku̱ nanki Tesaloni̱ka̱, xi kikj'áts'e̱nu̱u Nti̱a̱ Na̱'miná ko̱ Nda̱ Nti̱a̱ná Jesucristo̱.
\p Kas'enu̱u kju̱a̱nda ko̱ kju̱a̱jyu.
\s1 B'i̱ ts'ín títs'ínkj'áítsjen Pablo̱ xi nkú ts'ín kits'ínkjáíhi̱n xu̱ta̱ ni̱nku̱ nanki Tesaloni̱ka̱ én nda tsuhu̱ Jesucristo̱
\p 
\v 2 Tehe̱nte nk'ie nga chubako̱i̱ Nti̱a̱ná chubantjái̱hi̱ ko̱ 'ba̱i̱hi̱ máb'a̱chjíhi̱ Nti̱a̱ná a̱t'aha̱ kichubó éhe̱n.
\v 3 Nginku̱n Nti̱a̱ Na̱'miná f'áítsjen tehe̱nteni̱ xi nkú ts'ín s'ejinnu̱u Nti̱a̱ná ko̱ tín'o xá xi mjehe̱, xi nkú ts'ín tjonu̱u ko̱ tíbisinko̱o xinki̱u, ko̱ xi nkú ts'ín tín'echjúkjo̱o kju̱a̱ni̱ma̱ xi tíbitjajíún nga tíchuyóho̱o nga kj'u̱a̱í ngáha Nda̱ Nti̱a̱ná Jesucristo̱.
\p 
\v 4 Jun já nts'e, tjoho̱ Nti̱a̱ná jun ko̱ yai̱ nga j'ájinnu̱u.
\v 5 A̱t'aha̱ nk'ie nga kik'ieni̱jmíi̱ én nda tsuhu̱ Jesucristo̱ a̱jinnu̱u, najmi tu̱ suba én kichubai̱. Kis'ejña chji ní nga'yúhu̱n Nti̱a̱ná. Espiri̱tu̱hu̱ Nti̱a̱ná kits'ínxá ko̱ ndaha̱chí najmi jo jan kamani̱ nga kichubai̱. Yo xi nkú n'e tintsu̱ba̱i̱ a̱jinnu̱u nga ngandanu̱u ni xi kin'ei̱.
\p 
\v 6 Nk'ie nga kichaseni̱ ta̱ kichasoo̱hó Nda̱ Nti̱a̱ná, b'a̱ ts'ín tsinchiyó xi nkú ts'ín ku̱i̱ntsu̱bo̱o. A̱t'aha̱ nk'ie nga ja kin'ekjóho̱on éhe̱n Nti̱a̱ná, ta̱ kisakúnu̱u nkjin tíkjá kju̱a̱ni̱ma̱, tu̱nga Espiri̱tu̱hu̱ ní Nti̱a̱ná kitsjánu̱u kju̱a̱tsjo.
\v 7 B'a̱ ts'ín y'ejña chjihi̱ ru̱u ngatentee̱ xu̱ta̱ xi s'ejihi̱n Nti̱a̱ná xi tjín nga ngúsuhu̱n a̱nte Macedoni̱a̱ ko̱ a̱nte Akaya̱ xi nkú ts'ín tsjenkíaá Nda̱ Nti̱a̱ná.
\p 
\v 8 A̱t'aha̱ jun tjun kichjubó éhe̱n Nti̱a̱ná ko̱ tífindju ée̱n najmi tu̱ suba a̱nte Macedoni̱a̱ ko̱ a̱nte Akaya̱. Tu̱ má níhi tíya xi nkú ts'ín tís'ejinnu̱u Nti̱a̱ná. Kui nga najmi ta̱ machjéhe̱n ra̱ tsa nkú ku̱i̱xín saha̱ni̱ ji̱n.
\v 9 A̱t'aha̱ xu̱ta̱ tíi̱ncha nchja̱ni̱jmíyaha xi nkú ts'ín jun kin'ekjáínni̱ nk'ie nga tsichusei̱hi̱, ko̱ xi nkú ts'ín kin'ekjí t'axíún nti̱a̱ xi ntsja xu̱ta̱ ts'ínndaha nga kin'ekjóho̱on Nti̱a̱ná. Nd'a̱i̱ yjankiu Nti̱a̱ xi tíjña tík'uu̱n. Kju̱axi̱ nga kui xi Nti̱a̱ná.
\v 10 Nd'a̱i̱ tíchuyóho̱o Ntíhi̱ Nti̱a̱ná xi nibá ngáha ndji̱o̱jmi ján. Kui xi Jesu xi Nti̱a̱ná kits'ínkj'áíya ngáha̱ ra̱ ngabayoo̱ ko̱ xi ts'i̱ínk'ankiná ni̱stjin nga nibánehe̱ kju̱a̱kjaha̱n Nti̱a̱ná a̱sunntee̱.
\c 2
\s1 B'i̱ ts'ín títs'ínkj'áítsjen Pablo̱ xi nkú ts'ín kits'ínxá a̱jihi̱n xu̱ta̱ ni̱nku̱ nanki Tesaloni̱ka̱
\p 
\v 1 A̱t'aha̱ ja yo jun, já nts'e, nk'ie nga najmi xá tiya kama nk'ie nga tsichii̱ a̱jinnu̱u.
\v 2 Yo nga un kikieni̱ ko̱ ch'on kamat'ai̱n nanki Filipo̱ kintehe̱ ni nga tsichii̱ a̱jinnu̱u. Tu̱nga Nti̱a̱náhá kitsjá nga'yúnni̱, kui nga ndjá kin'esjehe̱ni̱ yjoni̱ nga y'eni̱jmíi̱ én nda tsuhu̱ Nti̱a̱ná a̱jinnu̱u. B'a̱ kin'ei̱ ndaha tsa nkjin maha xi ngji kontra̱ni̱.
\p 
\v 3 Najmi ni xi ngasten ko̱ tsa ni xi ch'onk'un nibáha̱ ra̱ ni xi b'eni̱jmíi̱ ko̱ ta̱ ndaha najmi ch'ana̱cha̱i̱hi̱ xu̱ta̱.
\v 4 Nda ní tsaseni̱ Nti̱a̱ná ko̱ kin'ekjas'enni̱ nga k'úéni̱jmíi̱ én nda tsuhu̱, ko̱ b'a̱ n'e tíchubai̱. Najmi xu̱ta̱ tí'ba̱i̱hi̱ kju̱a̱tsjo. Nti̱a̱ níná tí'ba̱i̱hi̱ kju̱a̱tsjo, kui xi be xi nkú ts'ín tjíntuyáni̱.
\p 
\v 5 Xi nkú n'e ja yo, najmi kichuba un ui̱n ko̱ ta̱ ndaha najmi kich'ana̱cha̱i̱hi̱, tsa tu̱ xi b'a̱ ts'ín kju̱a̱i̱hi̱ni̱ to̱on. Nti̱a̱ná be nga b'a̱ tjín ni xi tíxian.
\v 6 Najmi tsinchisjái̱ tsa kju̱a̱chánka sa̱kúni̱ a̱jinnu̱u ko̱ ta̱ ndaha a̱jihi̱n xu̱ta̱ xingisoo̱,
\v 7 ndaha tsa ji̱n xi já postru̱hu̱ Cristo̱ kama kai tsinchii̱hi̱ ni xi machjénni̱. Kichase sisii̱hi̱n. B'a̱ kin'ei̱ xi nkú ts'ín nku ta̱chju̱ún xi basehe̱ ntíhi̱.
\p 
\v 8 'Yún ṉkjún tjoni̱ jun, kui nga santaha najmi tu̱ nku én nda tsuhu̱ Nti̱a̱ná kin'ekjas'ehe̱n ri̱. Tsa ni xi ku̱a̱yántjaihi̱ ri̱ kai, tsayantjáíhi̱ ri̱. 'Yún ṉkjún kisasíni̱ jun.
\v 9 ¿A f'áítsjennu̱u, já nts'e, xi nkú ts'ín kin'exái̱ ko̱ kiyai̱ kju̱a̱ni̱ma̱ a̱jinnu̱u? Ni̱stjin ni̱stje̱n kin'exái̱ tu̱ xi najmi ch'á ka̱maha̱ni̱ nk'ie nga y'eni̱jmíi̱hi̱ én nda tsuhu̱ Nti̱a̱ná.
\p 
\v 10 Jun ko̱ Nti̱a̱ná be xi nkú ts'ín je ko̱ na̱xu̱ tintsu̱ba̱i̱ a̱jinnu̱u jun xi s'ejinnu̱u Nti̱a̱ná, ko̱ nga najmi tjín xi kja̱níneni̱ tsa mí nihi.
\v 11 Yo xi nkú ts'ín kichii̱hi̱n nga nkúnkú jun, xi nkú ts'ín kuhu̱n xi tí'mi na̱'mi ntíhi̱.
\v 12 Kik'a̱i̱ ni̱yái̱hi̱ ko̱ kik'a̱i̱ nga'yíi̱hi̱n. Kik'inyai̱hi̱ nga ku̱i̱ntsu̱bo̱o xi nkú ts'ín tjíhin nga k'úéntu xu̱ta̱ xi ts'e̱ Nti̱a̱ná. A̱t'aha̱ jun j'ájinnu̱u Nti̱a̱ná nga ku̱i̱tjás'e̱njiun nga Nti̱a̱ná ku̱a̱téxumanu̱u ko̱ nga sa̱kúnu̱u kju̱a̱chánkaha̱.
\p 
\v 13 Kui kju̱a̱ha nga najmi n'ekj'áíyai̱ nga tehe̱nte 'ba̱i̱hi̱ máb'a̱chjíhi̱ Nti̱a̱ná, a̱t'aha̱ kichjubó éhe̱n Nti̱a̱ná xi kik'ieni̱jmíi̱. Najmi kin'ekjóho̱on xi nkúhu tsa éhe̱n xu̱ta̱. Kju̱axi̱ kjáíhin nga kui xi éhe̱n Nti̱a̱ná ko̱ títs'ínxájinnu̱u nd'a̱i̱ jun xi s'ejinnu̱u Nti̱a̱ná.
\v 14 Jun já nts'e, b'a̱ ta̱ kamat'on xi nkú kamat'ain xu̱ta̱ ni̱nku̱hu̱ Nti̱a̱ná xi tjín a̱nte Judea̱ xi ta̱ s'ejihi̱n Cristo̱ Jesu. Un kikienu̱u a̱ya ntsja xu̱ta̱ nankinu̱u xi nkú ts'ín ta̱ un kikiehe̱ xu̱ta̱ ni̱nku̱ xu'bo̱ a̱ya ntsja xu̱ta̱ judio̱ xinkjín.
\p 
\v 15 Kui xi ta̱ i̱ncha kits'ínk'ien Nda̱ Nti̱a̱ná Jesu ko̱ já profeta̱, ko̱ ji̱n i̱ncha kikatje̱nnkini̱. Najmi maha̱ i̱ncha ts'ín ni xi sasíhi̱n Nti̱a̱ná ko̱ fi kontra̱ha̱ ngatentee̱ xu̱ta̱.
\v 16 B'éch'oni̱ nga b'eni̱jmíi̱hi̱ xu̱ta̱ xi najmi ntje̱ judio̱ tje̱he̱n ra̱ én xi ts'ínk'ankihi̱ xu̱ta̱. Tehe̱nte títs'íntsené jé yjoho̱ nga b'a̱ tíi̱ncha ts'ín, tu̱nga nd'a̱i̱ ja j'aik'úhu̱n xu̱ta̱ xu'bo̱ kju̱a̱kjaha̱n Nti̱a̱ná.
\s1 B'i̱ ts'ín kitsúya Pablo̱ nk'ie nga ta̱ mjehé ngáha̱ ra̱ ngju̱a̱i̱sehe̱ xu̱ta̱ ni̱nku̱ Tesaloni̱ka̱
\p 
\v 17 Jun já nts'e, kama mje ṉkjúnni̱ ko̱ tu̱ ni xí tsinchisjáí ni̱yá níi̱ nga kuankíi̱nse̱ ngáha̱ ri̱ nk'ie nga ja j'a chuba ni̱stjin nga tsankin t'axíi̱n má nga tintsu̱bo̱o, ndaha tsa najmi ngji t'axíhi̱n xinkjín ani̱ma̱ná.
\v 18 Kui nga kama mjehe̱ni̱ nga kuankíi̱nse̱ ngáha̱ ri̱. An Pablo̱ nku jo ni̱yá kama mjena nga kfínse ngáha̱nu̱u kai, tu̱nga nda̱nindoo̱hó y'échjani̱.
\v 19 A̱t'aha̱, ¿mí nihi xi tíchuyái̱hi̱ ko̱ mí nihi xi ka̱ma kju̱a̱tsjoni̱ ko̱ mí nihi xi ka̱ma chánka n'e̱sjeko̱ho̱ni̱ yjoni̱ nginku̱n Nda̱ Nti̱a̱ná Jesucristo̱ nk'ie nga kj'u̱a̱í ngáha? ¿A najmi juhún?
\v 20 Kju̱axi̱ nga jun xi kju̱a̱chánkani̱ ko̱ kju̱a̱tsjoni̱.
\c 3
\s1 B'i̱ ts'ín kitsúya Pablo̱ mí kju̱a̱ha nga y'éxáha Timoteo̱
\p 
\v 1 Kui b'a̱ maha nk'ie nga najmi ta̱ kama 'yún saha̱ni̱, tu̱ xi b'a̱ ts'ín cha̱ha̱ni̱ ni xi tímat'on y'endai̱ nga ku̱i̱ntsu̱ba̱ su̱ba̱i̱ nanki Atena̱
\v 2 ko̱ kin'ekjíi̱ nda̱ nts'eé Timoteo̱, nga kui xi ngju̱a̱i̱senu̱u. Kui xi ta̱ títs'ínxát'aha̱ Nti̱a̱ná nga tíb'éni̱jmí én nda tsuhu̱ Cristo̱. Kin'ekjíi̱ tu̱ xi tsjá nga'yúhu̱nnu̱u nga ku̱a̱si̱nko̱ho̱nu̱u ko̱ ndjá ku̱i̱nchajiun xi s'ejinná.
\v 3 Najmi mjeni̱ tsa tjín xi tjín a̱jinnu̱u kfe̱he̱ k'un tu̱ nga̱t'aha̱ ni xi tíf'ajin. Ja yo nga tjíhin nga b'a̱ ka̱mat'aán.
\p 
\v 4 A̱t'aha̱ nk'ie nga tintsu̱ba̱ sai̱ a̱jinnu̱u, tsixínya títjui̱hi̱n nga sa̱kúná kju̱a̱'un, xi nkú nga ja kama ko̱ yo.
\v 5 Kui kju̱a̱ha tu̱ xí kis'enta̱hána. Kui nga kits'inkjísehe̱nu̱u Timoteo̱ tu̱ xi skuehena tsa tu̱ b'a̱ ts'ín ndjáhá s'ejin sanu̱u. Najmi mjena tsa nda̱nindoo̱ kjút'ayák'unnu̱u, tsa b'a̱ ts'ínndyja̱ha xá xi kin'ei̱ a̱jinnu̱u.
\p 
\v 6 Ja kik'óya ngáha Timoteo̱ nga ngjisenu̱u. Én nda tsu j'aiko̱ni̱. B'a̱ títsu nga tu̱ nkú b'a̱há ts'ín s'ejinnu̱u Nti̱a̱ná ko̱ nga tu̱ b'a̱ ts'ín tjíhínnu̱u kju̱a̱tjo. Kitsúyani̱ nga tsjo ma tehe̱ntenu̱u nga f'áítsjennu̱u ji̱n ko̱ nga tu̱ xí mjehénu̱u cha̱ ngáha̱ni̱ xi nkú ta̱ ts'ín ji̱n 'yún mjeni̱ nga cha̱i̱hi̱ jun.
\p 
\v 7 Kui kju̱a̱ha, já nts'e, a̱jihi̱n kju̱a̱nusin xi tjínni̱ ko̱ kju̱a̱'un xi tíbeni̱, tísakú nga'yúnni̱ nga tínu'yái̱ nga tu̱ nku b'a̱há ts'ín ndjá s'ejinnu̱u Nti̱a̱ná.
\v 8 Títsjá nga'yúnni̱ nga yai̱ nga ndjá tinchajiun Nda̱ Nti̱a̱ná.
\v 9 Najmi tísakújinni̱ én xi nkú ts'ín k'u̱a̱i̱hi̱ ri̱ máb'a̱chjíhi̱ Nti̱a̱ná a̱t'aha̱ ndjá tinchajihu̱un Nda̱ Nti̱a̱ná ko̱ tí'ba̱i̱ni̱ kju̱a̱tsjo nginku̱n Nti̱a̱ná.
\v 10 Ni̱stjin ni̱stje̱n 'yún ṉkjún binchii̱hi̱ Nti̱a̱ná tu̱ xi katsjántehe̱ni̱ nga cha̱se̱'a ngáhaná xinki̱á ko̱ nga n'e̱ndju̱út'ai̱ ni xi s'ejinnu̱u, tsa tu̱ aha tjín ni xi ndyjat'a sa.
\p 
\v 11 Katsjáni̱yáni̱ Nti̱a̱ Na̱'miná ko̱ Nda̱ Nti̱a̱ná Jesu tu̱ xi ka̱ma kuankíhi̱nse̱ ngáha̱ ri̱.
\v 12 Ko̱ 'yún katsjá sanu̱u kju̱a̱tjo Nda̱ Nti̱a̱ná tu̱ xi b'i̱ ngján n'etjóhonu xinki̱u ko̱ xu̱ta̱ xingisoo̱ xi nkú ts'ín tjoni̱ jun.
\v 13 Katsjá nga'yúhu̱n ani̱ma̱nu̱u tu̱ xi najmi chumi ni sa̱kújihi̱nnu̱u ko̱ je s'e̱yaha̱nu̱u nginku̱n Nti̱a̱ Na̱'miná ni̱stjin nga kj'u̱a̱íko̱ Nda̱ Nti̱a̱ná Jesu ngayjee̱ xu̱ta̱ xi kikj'áts'e̱.
\c 4
\s1 B'i̱ ts'ín tsakúya Pablo̱ xi nkú ts'ín tjíhin nga ku̱i̱ntsu̱ba̱á nginku̱n Nti̱a̱ná
\p 
\v 1 Nd'a̱i̱ já nts'e, ngajoho̱ Nda̱ Nti̱a̱ná Jesu tíbinchii̱hi̱ ko̱ tí'ba̱i̱ ni̱yái̱hi̱ nga n'e̱henu xi nkú ts'ín kisakúyanu̱u ko̱ xi nkú tín'o tu̱ nkú b'a̱há n'e̱ so. A̱t'aha̱ ja y'ejña chjii̱hi̱ xi nkú ts'ín tjíhin nga ku̱i̱ntsu̱bo̱o ko̱ nga k'u̱o̱ho̱o kju̱a̱tsjo Nti̱a̱ná.
\v 2 Yo kju̱a̱téxuma xi kin'ekjas'ei̱hi̱n, kui kju̱a̱téxumaha xi y'éjña Nda̱ Nti̱a̱ná Jesu.
\p 
\v 3 Ni xi mjehe̱ Nti̱a̱ná, mjehe̱ nga xu̱ta̱ je ka̱mo nginku̱n. N'e̱ t'axíhu̱un yjonu̱u nga chu̱ba̱ súntuko̱nú xinki̱u.
\v 4 Nga nkúnkú xi tjín a̱jinnu̱u katumankjihi̱n xi nkú ts'ín je ko̱ kixi̱ ts'i̱ínchjén yjonintehe̱.
\v 5 Najmi tu̱ nku ni xi fásihi̱n yjonintenu̱u n'esihu̱un, xi nkú nga ts'ín xu̱ta̱ xi tjín a̱sunntee̱ xi najmi be Nti̱a̱ná.
\p 
\v 6 Ndaha nku najmi tu̱ ch'a xi ku̱a̱nkikju̱a̱ha̱ nda̱ nts'e̱ ko̱ tsa k'u̱a̱na̱cha̱ha̱. Xi nkú ts'ín kik'inyai̱hi̱ ko̱ y'ejña chjii̱hi̱, Nti̱a̱ná ts'i̱ínnijéhe̱ ra̱ xu̱ta̱ xi ts'i̱ín kui nii̱.
\v 7 A̱t'aha̱ najmi j'ájinná Nti̱a̱ná tsa tu̱ xi ni xi chu̱ntí ku̱i̱ntsu̱ba̱jihinná. J'ájin níná tu̱ xi ni xi je ku̱i̱ntsu̱ba̱jihinná nginku̱n.
\v 8 Kui b'a̱ maha, xi ts'i̱ín t'axíhin kju̱a̱téxuma xu'bi̱, kui xi najmi ku̱a̱téxumaha̱ xu̱ta̱ títs'ín t'axín. Kju̱a̱téxumaha̱ ní Nti̱a̱ná xi kitsjánu̱u Espiri̱tu̱ Santo̱ títs'ín t'axín.
\p 
\v 9 Nga̱t'a ts'e̱ kju̱a̱tjo xi tíjñajinná ñá xi nts'eé mahaná, najmi machjén tsa k'uet'á xu̱ju̱nnu̱u. A̱t'aha̱ Nti̱a̱ná ja tsakúyanu̱u nga b'i̱ ngján tjíhin nga n'e̱tjó xinki̱u.
\v 10 B'a̱ ts'ín kjáíhin tín'etjó ngayjee̱ já nts'eé xi tjín nga ngúsuhu̱n a̱nte Macedoni̱a̱. Tu̱nga ji̱n tíbinchii̱hi̱, já nts'e, nga 'yún ṉkjún kas'e sanu̱u kju̱a̱tjo.
\v 11 Ti̱nchísjo nga kas'enu̱u ku̱a̱jyu nga ti̱ntsu̱bo̱o, ko̱ n'o̱o ni xi ts'a̱jun, ko̱ ntso̱o n'e̱xáko̱honu. B'a̱ n'o̱ xi nkú tsixíi̱n nga n'o̱o,
\v 12 tu̱ xi nda ts'ín ku̱i̱nimahanu a̱jihi̱n xu̱ta̱ xi najmi s'ejihi̱n Nti̱a̱ná ko̱ tu̱ xi najmi chumi nihi xi ndyja̱t'aha̱nu̱u.
\s1 B'i̱ ts'ín tsakúya Pablo̱ xi nkú ts'ín kj'u̱a̱íkj'áná Nda̱ Nti̱a̱ná Jesu
\p 
\v 13 Jun já nts'e, mjeni̱ nga cho̱o ni xi ka̱maha̱ xu̱ta̱ xi ja k'ien, tu̱ xi najmi k'úé babaha̱ ra̱ yjonu̱u xi nkú ts'ín 'be babaha̱ xu̱ta̱ xingisoo̱, xu̱ta̱ xi najmi chumi nihi xi tíkuyáha̱.
\v 14 Xi nkú ts'ín s'ejinná nga k'ien Jesu ko̱ j'áíya ngáha̱ ra̱ ngabayoo̱, b'a̱ ta̱ ts'ín s'ejinná nga Nti̱a̱ná ts'i̱ínkj'áíyako̱ ngáha̱ ra̱ Jesu xu̱ta̱ k'ie̱n, kui xu̱ta̱ xi kis'ejihi̱n Jesu.
\p 
\v 15 Éhe̱n Nda̱ Nti̱a̱ná ni xi tíbixínyai̱ nga ñá xi tintsu̱ba̱á ni̱stjin nga kj'u̱a̱í ngáha Nda̱ Nti̱a̱ná najmi ku̱i̱tjá títjuhu̱ún xu̱ta̱ xi ja k'ie̱n.
\v 16 A̱t'aha̱ nk'a ján ni̱baha Nda̱ Nti̱a̱ná. Ku̱i̱nú'yá nku nta̱ xi k'u̱éxá ngajoho̱ Nti̱a̱ná, kui xi nta̱ha̱ ntítsje k'aku̱, ko̱ kju̱a̱ne̱ tjioho̱ Nti̱a̱ná. Tjun xu̱ta̱ xi kis'ejihi̱n Cristo̱ kintehe̱ ni nga ku̱a̱yá kj'u̱a̱íyaha̱ ngabayo.
\v 17 Ko̱ a̱skahan ñá xi tintsu̱ba̱ tík'un saá kui ni̱stjiu̱n n'e̱kjínjiko̱ná xu̱ta̱ xu'bo̱ a̱jin ni̱nti̱u̱ xi má nga n'e̱kjáíhi̱ín Nda̱ Nti̱a̱ná nk'a ján. Yo̱hó ni̱ ma ku̱i̱ntsu̱ba̱ka̱ síha̱án Nda̱ Nti̱a̱ná.
\v 18 Kui én xu'bi̱ tjen nga'yúnko̱ho̱ ru̱u xinki̱u.
\c 5
\s1 B'i̱ ts'ín kitsúya Pablo̱ xi nkú chun nk'ie nga kj'u̱a̱í Nda̱ Nti̱a̱ná
\p 
\v 1 Jun já nts'e, nga̱t'a ts'e̱ ni̱stjin xi nibá ko̱ nkjé ku̱i̱tjusun niu̱, najmi machjéhe̱n tsa k'uet'á xu̱ju̱nnu̱u.
\v 2 A̱t'aha̱ jun ja ya sisiun ni̱stjin nga kj'u̱a̱í ngáha Nda̱ Nti̱a̱ná, kj'u̱a̱í ni̱stjin nga najmi ch'a xi tíkuyáha̱, xi nkú ts'ín f'ai nku nda̱ ndyjé nga jyuu̱n.
\v 3 Nk'ie nga: “Tjínná kju̱a̱jyu nd'a̱i̱ ko̱ ja nda n'e tintsu̱ba̱á”, ku̱i̱tsu̱ xu̱ta̱, nk'ie tje̱n'yún ni̱banehé ra̱ ni xi ts'i̱ínkjehe̱ xi nkú ts'ín nibánehe̱ chji̱nti̱ nku ta̱chju̱ún xi ja tsíhi̱n ntí. Najmi s'e̱ má ku̱a̱nka 'ma xu̱ta̱ kui ni̱stjin xu'bo̱.
\p 
\v 4 Tu̱nga máha jun, já nts'e, najmi má jyuu̱n tintsu̱bo̱o, tsa tu̱ ndyjahánu̱u nga kj'u̱a̱í ni̱stjin xu'bo̱ xi nkú joyaha nku nda̱ ndyjé.
\v 5 Ngatentoo̱ tintsu̱bo̱o má ndzjee̱n ko̱ má ni̱stjiu̱n. Najmi má ni̱stje̱n ko̱ tsa má jyuu̱n ts'e̱ná.
\v 6 Kui nga najmi tu̱ sufehená xi nkúhu xu̱ta̱ xingisoo̱. Ti̱ntsu̱ba̱ tík'un nínáá ko̱ cha̱se̱éhe̱ ni xi n'e̱é.
\p 
\v 7 A̱t'aha̱ xi fantufé, nga jyuu̱n fantufé, ko̱ xi ma ch'i̱, nga jyuu̱n ma ch'i̱.
\v 8 Tu̱nga ñá xi má ndzjee̱n ts'e̱ná tjíhin nga n'e̱nkjín sisihi̱ín tak'aán ko̱ k'úéndaá yjoná xi nkú joyaha já jun xi kja̱án. N'e̱ s'ejián Nti̱a̱ná, kas'ená kju̱a̱tjo, ko̱ chúyaha̱á nga k'u̱a̱nkiá. B'a̱ ts'ín chjúhu̱n ra̱á yjoná xi nkú ts'ín kuhu̱n yjoho̱ já jun xi kján.
\p 
\v 9 A̱t'aha̱ najmi b'a̱ ts'ín y'énda Nti̱a̱ná tsa ñá sa̱kúná kju̱a̱kjaha̱n. Y'éjña ní nga Nda̱ Nti̱a̱ná Jesucristo̱ ts'i̱ínk'ankiná.
\v 10 Kui xi k'ienntjáíhiná tu̱ xi ku̱i̱ntsu̱ba̱ tík'unko̱honá, ndaha tsa ja tsayaá ko̱ ndaha tsa tintsu̱ba̱ tík'un saá e̱i̱ a̱sunntei̱.
\v 11 Kui b'a̱ maha, b'i̱ ngján tjen nga'yúhu̱nru̱ú xinki̱u ko̱ ti̱si̱nko̱o tu̱ xi ndjá ku̱i̱nchunjíhinnu xi s'ejinná. B'a̱ n'o̱o xi nkú nga tín'o santaha ni̱stjin nd'a̱i̱.
\s1 B'i̱ ts'ín tsakúya Pablo̱ ni xi i̱ncha ts'i̱ín xu̱ta̱ ni̱nku̱
\p 
\v 12 Jun já nts'e, tíbinchii̱hi̱ nga katumankjinnu̱u nga Nda̱ Nti̱a̱ná títs'ínxát'aha̱ já xi tíi̱ncha ts'ínxájinnu̱u, já xi yja títjunnu̱u ko̱ títsjáni̱yánu̱u.
\v 13 'Yún cha̱nkjún ko̱ n'e̱tjó jóo̱ tu̱ nga̱t'aha̱ xá xi tíi̱ncha ts'ín. Ko̱ b'i̱ ngján kas'enu̱u kju̱a̱jyu nga tintsu̱ba̱ko̱o xinki̱u.
\p 
\v 14 Jun já nts'e̱, ta̱ tíbinchii̱hi̱ ni xu'bi̱. Tjen ni̱yóho̱o xi najmi mjehe̱ ts'i̱ínxá. Tjen nga'yúhu̱un xi tífehe̱ k'un. Ti̱si̱nko̱o xi najmi ndjá tíi̱nchajin xi s'ejinná. N'e̱'yún tak'uhu̱un ngatentee̱ xu̱ta̱.
\v 15 Tsa tjín a̱jinnu̱u xi ch'on kin'ehe̱, cha̱so̱o nga najmi tu̱ ts'i̱ín ngajoya ngáha ni xi kin'ehe̱. B'i̱ ngján nda n'e̱ tehe̱ntoho̱o xinki̱u ko̱ ngayjee̱ xu̱ta̱ xingisoo̱.
\p 
\v 16 Tehe̱nte tsjo kat'enu̱u.
\v 17 Tu̱ nkú chu̱bako̱nú Nti̱a̱ná.
\v 18 Tu̱ mí nihí ni xi ka̱mat'on, tjoho̱on máb'a̱chjíhi̱ Nti̱a̱ná. A̱t'aha̱ kui niu̱ xi mjehe̱ Nti̱a̱ná nga n'o̱o jun xi s'ejinnu̱u Cristo̱ Jesu.
\p 
\v 19 Najmi tu̱ n'ek'ienyo nd'í xi títs'ínkat'ai Espiri̱tu̱hu̱ Nti̱a̱ná a̱jinnu̱u.
\v 20 Najmi tu̱ tohón manu̱u xi nchja̱ én xi tsjá Nti̱a̱ná.
\v 21 Cha̱so̱ho̱o ngayjee̱ tu̱ mí nihí ni nga ti̱nchísjaijiun ni xi nda ko̱ kui xi n'o̱o.
\v 22 T'ech'óho̱o yjonu̱u ngayje tíkjá ni xi najmi nda.
\p 
\v 23 Nti̱a̱ná xi tsjáná kju̱a̱jyu, kui xi kats'ín jeyjenu̱u nginku̱n ko̱ kakunnu̱u, tu̱ xi ndaha̱chí najmi s'e̱he jé a̱jin kju̱a̱nkjintak'unnu̱u ko̱ tsa a̱jin ani̱ma̱nu̱u ko̱ tsa a̱jin yjonintenu̱u ni̱stjin nga kj'u̱a̱í ngáha Nda̱ Nti̱a̱ná Jesucristo̱.
\v 24 Nti̱a̱ná xi kixi̱ ts'íntjusun ni xi nchja̱, kui xi j'ájinnu̱u ko̱ ts'i̱íntjusun nii̱.
\s1 B'i̱ ts'ín kits'ínkje Pablo̱ xu̱ju̱i̱n
\p 
\v 25 Jun já nts'e, nk'ie nga chu̱bako̱o Nti̱a̱ná, chu̱bantjáíni̱.
\p 
\v 26 Ngajoni̱ súniñaha̱ ru̱u ngatentee̱ já nts'eé.
\p 
\v 27 Ngajoho̱ Nda̱ Nti̱a̱ná tíbankihi̱nu̱u nga kan'eya xu̱ju̱i̱n nginku̱n ngatentee̱ já nts'eé.
\p 
\v 28 Kas'enu̱u kju̱a̱ndaha̱ Nda̱ Nti̱a̱ná Jesucristo̱.
