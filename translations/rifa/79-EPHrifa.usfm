\id EPH
\h إِفَاسُوسِييّنْ
\toc1 إِفَاسُوسِييّنْ
\toc2 إِفَاسُوسِييّنْ
\toc3 أَفا.
\mt1 إِفَاسُوسِييّنْ
\c 1
\s1 أَسدْجمْ غَارْ ؤُمزْوَارُو
\m 
\v 1 بُولُوسْ، رَّاسُولْ ن يَاسُوع لْمَاسِيحْ عْلَاحْسَابْ ڒْخَاضَارْ ن أَربِّي، إِ يِينِّي إِدْجَانْ ذِي أَفَاسُوسْ، \add إِ\add* إِمْقدَّاسنْ ذ يِينِّي يُومْننْ ذِي يَاسُوع لْمَاسِيحْ \f ◼ \fr 1:‏1 \ft \bd ’رَّاسُولْ‘\bd* - نِيغْ ’أَمَازَانْ‘.\f*  \x ◘ \xo 1:‏1 \xt رُوم. 1‏:‏7؛ 1 كُور. 1‏:‏2؛ 2 كُور. 1‏:‏1. \x*
\v 2 أَرْضَا ذ ڒهْنَا أَذْ كِيذْومْ إِڒِينْ زِي أَربِّي، بَابَاثْنغْ، ؤُ زِي سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ. \x ◘ \xo 1:‏2 \xt ڭال. 1‏:‏3؛ 1 بُط. 1‏:‏2. \x*
\b
\m 
\v 3 أَذْ إِتّْوَابَاركْ أَربِّي، بَابَاسْ ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ، ونِّي ذ أَنغْ إِبَارْكنْ س مَارَّا لْبَارَاكَاثْ ن أَرُّوحْ إِ إِدْجَانْ ذڭْ إِجنْوَانْ ذِي لْمَاسِيحْ، \x ◘ \xo 1:‏3 \xt 2 كُور. 1‏:‏3؛ 1 بُط. 1‏:‏3. \x*
\v 4 أَمْ مَامّشْ إِخْضَارْ أَنغْ ذَايسْ، ذڭْ ؤُمزْوَارُو قْبڒْ مَا أَذْ إِتّْوَاڭّْ ذْسَاسْ ن دُّونشْثْ، حِيمَا أَذْ نِيڒِي ذ إِمْقدَّاسنْ بْڒَا ڒْعِيبْ قِيبَاتْشْ نّسْ. \x ◘ \xo 1:‏4 \xt لك. 1‏:‏75؛ يُوح. 15‏:‏16؛ أَفا. 5‏:‏27؛ كُول. 1‏:‏22؛ 2 تِيم. 1‏:‏9؛ ثِيث. 2‏:‏12. \x*
\m 
\v 5 ذِي ثَايْرِي إِزْوَارْ أَذْ أَنغْ يَارْشمْ إِ يِيخفْ نّسْ ؤُشَا أَقَا إِڭَّا أَنغْ ذ أَرَّاونْ ذِي يَاسُوع لْمَاسِيحْ أَمْ مَامّشْ ث إِخْسْ ڒْخَاضَارْ نّسْ،
\v 6 إِ ؤُسمْغَارْ ن ؤُعُودْجِي ن أَرْضَا نّسْ إِ خَانغْ إِفَارّغْ ذڭْ ؤُمْعِيزّْ نّسْ. \x ◘ \xo 1:‏6 \xt مت. 3‏:‏17. \x*
\m 
\v 7 ذَايسْ غَارْنغْ أَسنْجمْ ذ وغْفَارْ ن دّْنُوبْ س إِذَامّنْ نّسْ عْلَاحْسَابْ أَڭْڒَا ن أَرْضَا نّسْ \x ◘ \xo 1:‏7 \xt ڒخ. 20‏:‏28؛ كُول. 1‏:‏14؛ عبر. 9‏:‏12؛ 1 بُط. 1‏:‏18. \x*
\v 8 إِ ذَايْنغْ إِدْجَانْ س ؤُفيّضْ، ذِي مَارَّا ثِيغِيثْ ذ مَارَّا ڒفْهَامثْ.
\v 9 أَقَا إِسَّارْڭبْ أَنغْ خْ سِّيرّْ ن ڒْخَاضَارْ نّسْ، إِ ثُوغَا إِزْعمْ قْبڒْ مَاحنْذْ أَذْ ث إِكمّڒْ ذڭْ يِيخفْ نّسْ، \x ◘ \xo 1:‏9 \xt رُوم. 16‏:‏25؛ أَفا. 3‏:‏9؛ كُول. 1‏:‏26؛ 2 تِيم. 1‏:‏9؛ ثِيث. 1‏:‏2؛ 1 بُط. 1‏:‏20. \x*
\v 10 حِيمَا، إِ ڒحْكَامثْ ن ؤُعمَّارْ ن زّْمَانَاثْ، أَذْ د-إِخْڒقْ مَارَّا \add مِينْ إِدْجَانْ\add* ذڭْ إِجنْوَانْ ؤُ خْ ثمُّورْثْ ذ جْذِيذْ زڭْ ؤُزدْجِيفْ س لْمَاسِيحْ. \x ◘ \xo 1:‏10 \xt أَمز. 49‏:‏10؛ دَان. 9‏:‏24؛ ڭال. 4‏:‏4. \x*
\m 
\v 11 أَقَا نتّْوَاخْضَارْ ذَايسْ، أَمْ مَامّشْ إِ إِزْوَارْ أَذْ إِمَّارْسْ إِ نشِّينْ ؤُ ثُوغَا إِخْسْ أَذْ \add زَّايْنغْ\add* إِڭّْ، نتَّا ذ ونِّي إِتّڭّنْ مَارَّا عْلَاحْسَابْ لْقَارَارْ ن أَرَّايْ نّسْ، \x ◘ \xo 1:‏11 \xt رُوم. 8‏:‏17. \x*
\v 12 حِيمَا نشِّينْ أَذْ نِيڒِي ذ إِمزْوُورَا إِ غَا إِسِّيثِيمنْ ذِي لْمَاسِيحْ إِ ؤُسمْغَارْ ن ؤُعُودْجِي نّسْ.
\m 
\v 13 ذَايسْ أَقَا ثسْڒِيمْ أَوَاڒْ ن ثِيذتّْ، ڒخْبَارْ أَصبْحَانْ ن ؤُسنْجمْ نْومْ، \add خنِّي\add* ثُومْنمْ ذَايسْ ؤُشَا ثكْسِيمْ أَشمِّيعْ ن أَرُّوحْ إِقدّْسنْ إِ ذ \add أَنغْ\add* إِوَاعْذْ، \x ◘ \xo 1:‏13 \xt رُوم. 8‏:‏15؛ 2 كُور. 1‏:‏22؛ 5‏:‏5؛ أَفا. 4‏:‏30. \x*
\v 14 ونِّي ذ ڒْعَارْبُونْ ن ڒْوَارْثْ نّغْ إِ ؤُسنْجمْ ن يِينِّي إِدَّارنْ ؤُ إِ ؤُسمْغَارْ ن ؤُعُودْجِي نّسْ. \x ◘ \xo 1:‏14 \xt ؤُف. 19‏:‏5؛ أَعَوذ. 7‏:‏6؛ 14‏:‏2؛ 26‏:‏18؛ رُوم. 8‏:‏23؛ 1 بُط. 2‏:‏9. \x*
\b
\s1 أَقَاذِي ذ ثْژَادْجِيثْ ن بُولُوسْ
\m 
\v 15 خْزَارْ، س ؤُينِّي نشّْ، ڒَامِي سْڒِيغْ خْ لْ-إِيمَانْ نْومْ ذِي سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ ؤُ خْ ثَايْرِي نْومْ إِ مَارَّا إِمْقدَّاسنْ، \x ◘ \xo 1:‏15 \xt فِيل. 1‏:‏3؛ كُول. 1‏:‏3؛ 1 تس. 1‏:‏2؛ 2 تس. 1‏:‏3. \x*
\v 16 وَارْ بدّغْ شَا أَذْ قَاذِيغْ إِ كنِّيوْ نِيغْ أَذْ ذَايْومْ فكَّارغْ ذِي ثْژِيدْجَاثِينْ إِنُو،
\v 17 حِيمَا أَربِّي ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ، بَابَاسْ ن ؤُعُودْجِي، أَذْ أَومْ إِوْشْ أَرُّوحْ ن ثِيغِيثْ ذ ؤُسَارْڭبْ حِيمَا أَذْ ث ثسّْنمْ،
\v 18 ؤُشَا أَذْ أَومْ إِوْشْ ثِيفَاوْثْ ذِي ثِيطَّاوِينْ ن وُوڒَاونْ نْومْ، حِيمَا أَذْ ثسّْنمْ مَانْ أَسِيثمْ ن ثْڒَاغِيثْ نّسْ ذ مَامّشْ \add إِمْغَارْ\add* أَڭْڒَا ن ؤُعُودْجِي ن ڒْوَارْثْ نّسْ ذِي مَارَّا إِمْقدَّاسنْ،
\v 19 ؤُ مَامّشْ إِمْغَارْ أَطَّاسْ إِ يدْجَا جّهْذْ نّسْ ذَايْنغْ، ذڭْ إِنِّي يُومْننْ عْلَاحْسَابْ أَقَارُّو ن جّهْذْ ن صُّولْطَا نّسْ \x ◘ \xo 1:‏19 \xt كُول. 2‏:‏12. \x*
\v 20 إِ إِخدّْمنْ ذِي لْمَاسِيحْ ؤُمِي ث-إِ-د-إِسّْنكَّارْ زِي ثَادَّارْثْ ن إِمتِّيننْ ؤُشَا إِڭَّا إِ-ث غَارْ ؤُغزْذِيسْ أَفُوسِي نّسْ ذڭْ إِجنْوَانْ، \x ◘ \xo 1:‏20 \xt إِزهد. 110‏:‏1؛ ڒخ. 2‏:‏34؛ 1 كُور. 15‏:‏25؛ كُول. 3‏:‏1؛ عبر. 1‏:‏3؛ 10‏:‏12؛ 1 بُط. 3‏:‏22. \x*
\v 21 سنّجْ إِ كُوڒْ أَزدْجِيفْ ذ صُّولْطَا ذ جّهْذْ ذ ڒحْكَامثْ ذ مَارَّا إِسمْ إِتّْوَاسمَّانْ، وَارْ إِدْجِي ذِي دُّونشْثْ-أَ وَاهَا، مَاشَا عَاوذْ ذِي ثنِّي إِ د غَا يَاسنْ.
\v 22 أَقَا نتَّا يَارَّا أَسْ-د مَارَّا سَاذُو إِضَارنْ نّسْ ؤُ ونِّي إِدْجَانْ سنّجْ إِ مَارَّا، أَقَا إِڭَّا إِ-ث ذ أَزدْجِيفْ إِ ثْمسْمُونْثْ، \x ◘ \xo 1:‏22 \xt إِزهد. 8‏:‏7؛ مت. 28‏:‏18؛ 1 كُور. 15‏:‏27؛ عبر. 2‏:‏8. \x*
\v 23 ثنِّي ذ أَرِّيمثْ نّسْ ؤُڒَا ذ أَعمَّارْ ن ونِّي إِتّْعمَّارنْ كُوڒْشِي ذِي مَارَّا. \f ◼ \fr 1:‏23 \ft \bd ’أَعمَّارْ‘\bd* -نِيغْ ’ثَاشُورّثْ‘. \bd ’إِتّْعمَّارنْ‘\bd* -نِيغْ ’إِتّْشُورَّانْ‘.\f*  \x ◘ \xo 1:‏23 \xt رُوم. 12‏:‏5؛ 1 كُور. 12‏:‏27؛ أَفا. 4‏:‏16؛ 5‏:‏23. \x*
\b
\b
\c 2
\s1 أَسنْجمْ س أَرْضَا ن أَربِّي، س لْ-إِيمَانْ
\m 
\v 1 ؤُڒَا ذ كنِّيوْ ثُوغَا ثمُّوثمْ س دّْنُوبْ نْومْ ؤُ س ثُوبُّوهڒْيَا نْومْ \x ◘ \xo 2:‏1 \xt رُوم. 5‏:‏6؛ كُول. 2‏:‏13. \x*
\v 2 مِينْ ذِي ثُوغَا ثُويُورمْ عْلَاحْسَابْ ثُوذَارْثْ ن كُوڒْ أَسّْ ن دُّونشْثْ-أَ، عْلَاحْسَابْ ڒْخَاضَارْ ن ؤُزدْجِيفْ ن صُّولْطَا خْ وَازَّايْ ن ڒعْوِينْ، ؤُ \add عْلَاحْسَابْ ڒْخَاضَارْ\add* ن أَرُّوحْ نِّي إِخدّْمنْ ذِي ثَارْوَا ن ڒْمُوعْصِييّثْ. \x ◘ \xo 2:‏2 \xt يُوح. 12‏:‏31؛ 14‏:‏30؛ 16‏:‏11؛ 1 كُور. 6‏:‏11؛ أَفا. 6‏:‏12؛ كُول. 3‏:‏7؛ ثِيث. 3‏:‏3. \x*
\v 3 ؤُڒَا ذ نشِّينْ ثُوغَا نْرُوحْ قْبڒْ ذِي شّْغُوڒَاثْ نِّي، ؤُمِي نضْفَارْ نّشْوَاثْ ن ويْسُومْ نّغْ، نڭَّا مِينْ إِخْسْ ويْسُومْ نّغْ ذ نّيّثْ نّغْ، ؤُ ثُوغَا أَنغْ ذ ثَارْوَا ن وغْضَابْ قَاعْ أَمْ إِنّغْنِي.
\m 
\v 4 مَاشَا أَربِّي إِشُّورْ س أَرّحْمثْ س ثَايْرِي نّسْ ثَامقّْرَانْثْ إِ زِي خَانغْ إِعِيزّْ.
\v 5 ڒَامِي ثُوغَا أَنغْ \add عَاذْ\add* ذ إِمتِّيننْ ذِي دّْنُوبْ نّغْ، أَقَا يَارّْ أَنغْ-د غَارْ ثُوذَارْثْ أَكْ-ذ لْمَاسِيحْ، ؤُ س أَرْضَا نّسْ إِسّنْجمْ أَنغْ \x ◘ \xo 2:‏5 \xt ڒخ. 15‏:‏11؛ رُوم. 6‏:‏8؛ 8‏:‏11؛ كُول. 3‏:‏1، 3؛ ثِيث. 3‏:‏5. \x*
\v 6 ؤُ إِسّْنكَّارْ أَنغْ-د أَكِيذسْ ؤُشَا إِسّْغِيمَا أَنغْ أَكِيذسْ ذڭْ إِجنْوَانْ ذِي يَاسُوع لْمَاسِيحْ،
\v 7 حِيمَا أَذْ إِسّْشنْ أَفيّضْ ن وَاڭْڒَا ن أَرْضَا نّسْ ذ ثْشُونِي نّسْ ذِي زّْمَانَاثْ إِ د غَا يَاسنْ، ونِّي خَانغْ د-يُوسِينْ س يَاسُوع لْمَاسِيحْ.
\v 8 مِينْزِي س أَرْضَا نّسْ نتّْوَاسّنْجمْ، س لْ-إِيمَانْ، وَارْ إِدْجِي زَّايْومْ، أَقَا-ت ذ ثَاوْهِيبْثْ ن أَربِّي، \x ◘ \xo 2:‏8 \xt مت. 16‏:‏17؛ أَفا. 1‏:‏19. \x*
\v 9 وَارْ ثدْجِي س ڒْخذْمثْ، مَاحنْذْ وَارْ إِتُّوفّْ ؤُڒَا ذ إِجّْ. \x ◘ \xo 2:‏9 \xt رُوم. 3‏:‏27؛ 1 كُور. 1‏:‏29. \x*
\v 10 مَاغَارْ نشِّينْ ذ أَخڒْقِي نّسْ، نتّْوَاخْڒقْ-د ذِي يَاسُوع لْمَاسِيحْ حِيمَا أَذْ نڭّْ ڒخْذَايمْ ثِيصبْحَانِينْ نِّي ذ أَنغْ إِسّوْجذْ أَربِّي قْبڒْ، مَاحنْذْ أَذْ نُويُورْ ذَايْسنْثْ. \x ◘ \xo 2:‏10 \xt 2 كُور. 5‏:‏17؛ أَفا. 1‏:‏4؛ 4‏:‏24؛ ثِيث. 2‏:‏14. \x*
\b
\s1 لْمَاسِيحْ أَقَا-ث ڒهْنَا نّغْ
\m 
\v 11 س ؤُينِّيعقْڒمْ، أَقَا زِيشْ ثُوغَا كنِّيوْ ذ ڒڭْنُوسْ عْلَاحْسَابْ \add جَّاذِيرَا\add* ن أَرِّيمثْ، ثتّْوَاسمَّامْ ’نْبْڒَا أَخْثَانْ‘ زڭْ إِنِّي ثُوغَا س وخْثَانْ نِّي إِدْجَانْ ذ ڒْخذْمثْ ن إِفَاسّنْ ذڭْ ويْسُومْ.
\v 12 ذِي ڒْوقْثْ نِّي ثُوغَا كنِّيوْ بْڒَا لْمَاسِيحْ، ذ إِغْرِيبنْ زِي جِّيهثْ ن ڒحْكَامثْ ن إِسْرَائِيل، أَقَا ثِيڭّْوْجمْ أَمْ إِبَارَّانِييّنْ خْ ڒْعَاهْذْ ن لْوَاعْذْ. ثُوغَا كنِّيوْ بْڒَا أَسِيثمْ ؤُ بْڒَا أَربِّي ذِي دُّونشْثْ. \x ◘ \xo 2:‏12 \xt رُوم. 9‏:‏4. \x*
\v 13 مَاشَا ڒخُّو، ذِي يَاسُوع لْمَاسِيحْ، أَقَا كنِّيوْ إِنِّي ثُوغَا إِڭّْوجنْ، أَقَا \add ڒخُّو\add* ثُوذْسمْ-د س إِذَامّنْ ن لْمَاسِيحْ.
\m 
\v 14 مَاغَارْ نتَّا ذ ڒهْنَا نّغْ أَمْ ذ يَارَّا ثْنَاينْ نِّي غَارْ يِيجّْ، أَقَا نتَّا إِهْذمْ أَغْبَارْ ن ڒقْوَارْ ونِّي ثُوغَا ثنْ إِبْضَانْ. \x ◘ \xo 2:‏14 \xt إِشا. 9‏:‏5؛ مِيخَا 5‏:‏4؛ يُوح. 16‏:‏33؛ ڒخ. 10‏:‏36؛ رُوم. 5‏:‏1؛ كُول. 1‏:‏20. \x*
\v 15 ذڭْ ويْسُومْ \add ن أَرِّيمثْ\add* نّسْ إِبْضڒْ نتَّا ڒعْذَاوثْ ذ شَّارِيعَا ن ثْوصَّا أَكْ-ذ ثْوصَّا إِ-د-إِضْفَارنْ، حِيمَا أَذْ د-إِخْڒقْ ذِي طّْبِيعثْ ن يِيخفْ نّسْ ثْنَاينْ نِّي غَارْ إِجّْ ن بْنَاذمْ ن جْذِيذْ أَمْ إِتّڭّْ ڒهْنَا.
\v 16 أَقَا نتَّا إِسّصْڒحْ ثْنَاينْ نِّي أَكْ-ذ أَربِّي ذڭْ إِشْثْ ن أَرِّيمثْ ؤُ إِنْغَا ڒعْذَاوثْ س صَّالِيبْ نّسْ.
\v 17 يُوسَا-د حِيمَا أَذْ إِبَارّحْ س ڒخْبَارْ أَصبْحَانْ ن ڒهْنَا \add نِّي\add*، إِ يِينِّي ثُوغَا إِڭّْوجنْ ؤُ إِ يِينِّي ثُوغَا يُوذْسنْ، \x ◘ \xo 2:‏17 \xt إِشا. 57‏:‏19؛ أَفا. 3‏:‏12. \x*
\v 18 مِينْزِي زَّايسْ نْزمَّارْ أَذْ نَاذفْ س ثْنَاينْ إِذْنغْ س يِيجّْ ن أَرُّوحْ غَارْ بَابَاثْنغْ. \x ◘ \xo 2:‏18 \xt يُوح. 10‏:‏9؛ 14‏:‏6؛ رُوم. 5‏:‏2؛ أَفا. 3‏:‏12؛ عبر. 10‏:‏19. \x*
\v 19 س ؤُيَا كنِّيوْ وَارْ ثدْجِيمْ ذ إِبَارَّانِييّنْ ؤُڒَا ذ إِمعْزَابْ، مَاشَا كنِّيوْ ذ إِمزْذَاغْ ن ثنْذِينْثْ ن إِمْقدَّاسنْ ذ ثَارْوَا ن ثَادَّارْثْ ن أَربِّي. \x ◘ \xo 2:‏19 \xt ڭال. 6‏:‏10؛ 1 تِيم. 3‏:‏1؛ عبر. 10‏:‏21؛ 1 بُط. 4‏:‏17\x*
\v 20 ثتّْوَابْنَامْ خْ ذْسَاسْ ن رُّوسُولْ ذ إِنَابِييّنْ، ؤُشَا نتَّا ذ \add أَژْرُو\add* أَزدْجِيفْ ن ثغْمَارْثْ، أَقَا-ث ذ يَاسُوع لْمَاسِيحْ. \f ◼ \fr 2:‏20 \ft \bd ’رُّوسُولْ‘\bd* - نِيغْ ’إِمَازَاننْ‘.\f*  \x ◘ \xo 2:‏20 \xt إِشا. 28‏:‏16؛ مت. 16‏:‏18؛ 1 كُور. 3‏:‏9، 10؛ 1 بُط. 2‏:‏4؛ أَسَا. 21‏:‏14\x*
\v 21 زَّايسْ إِ غَا إِتّْوَابْنَا ڒبْنِي مَارَّا، أَذْ إِيْمَا ؤُشَا أَذْ إِذْوڒْ ذ إِشْثْ ن زَّاوشْثْ ثَامقّْرَانْثْ إِقدّْسنْ ذِي سِيذِي، \x ◘ \xo 2:‏21 \xt 1 كُور. 6‏:‏19؛ 2 كُور. 6‏:‏16؛ أَفا. 4‏:‏16. \x*
\v 22 أَمْ زَّايسْ إِ غَا ثتّْوَابْنَامْ ؤُڒَا ذ كنِّيوْ، أَذْ ثِيڒِيمْ ذ ثَازذِّيغْثْ ن أَربِّي ذِي أَرُّوحْ.
\b
\b
\c 3
\s1 سِّيرّْ ن لْمَاسِيحْ
\m 
\v 1 خْ ؤُينِّي نشّْ، بُولُوسْ، أَقَا أَيِي ذ أَمحْبُوسْ ن يَاسُوع لْمَاسِيحْ، إِ كنِّيوْ \add إِنِّي إِدْجَانْ زِي\add* ڒڭْنُوسْ، \x ◘ \xo 3:‏1 \xt ڒخ. 21‏:‏33؛ أَفا. 4‏:‏1؛ فِيل. 1‏:‏7، 13، 14، 16؛ كُول. 4‏:‏3؛ 2 تِيم. 1‏:‏8؛ فلمن. 1. \x*
\v 2 مَاڒَا \add زعْمَا\add* أَقَا ثسْڒَامْ خْ ثْسخَّارْثْ ن أَرْضَا ن أَربِّي إِ ذ أَيِي إِمّوْشنْ جَارْ أَومْ، \x ◘ \xo 3:‏2 \xt ڒخ. 13‏:‏2؛ رُوم. 1‏:‏5؛ أَفا. 3‏:‏8. \x*
\v 3 بلِّي إِتّْوَاسَّارْڭبْ أَيِي-د سِّيرّْ، أَمْ إِزَّارغْ ؤُرِيغْ أَومْ-د س ذْرُوسْ. \x ◘ \xo 3:‏3 \xt ڒخ. 22‏:‏17، 21؛ 26‏:‏16، 17؛ رُوم. 16‏:‏25؛ ڭال. 1‏:‏11، 12. \x*
\v 4 خْمِي غَا ثْغَارمْ مَانْ أَيَا، ثْزمَّارمْ أَذْ ثْفهْممْ ڒفْهَامثْ إِنُو ن سِّيرّْ ن لْمَاسِيحْ،
\v 5 ونِّي وَارْ إِتّْوَاسَّارْڭبْ شَا ذِي ثَارْوَا ن بْنَاذمْ ذِي ڒجْيُوڒْ نّغْنِي، أَمْ مَامّشْ إِتّْوَاعَارَّا خَاسْ ڒخُّو س أَرُّوحْ إِ رُّوسُولْ إِمْقدَّاسنْ نّسْ ؤُ إِ إِنَابِييّنْ نّسْ، \x ◘ \xo 3:‏5 \xt ڒخ. 10‏:‏28. \x*
\v 6 \add أَحقَّا\add* إِنِّي زِي ڒڭْنُوسْ أَذْ إِڒِينْ ذ إِوْرِيثنْ أَكِيذْسنْ ذ إِغزْذِيسنْ أَكِيذْسنْ ن أَرِّيمثْ نّسْ ؤُڒَا \add ذ إِشْرِيشنْ\add* ن لْوَاعْذْ نِّي ذَايسْ إِمّوْشنْ س لْ-إِنْجِيلْ، \f ◼ \fr 3:‏6 \ft \bd ’أَكِيذْسنْ‘\bd* - إِخْسْ أَذْ يِينِي أَكْ-ذ ينِّي ن إِسْرَائِيل إِ يُومْننْ ذِي لْمَاسِيحْ، س مِينْزِي نِيثْنِي ذ إِسْرَائِيل ذ ثِيذتّْ (هُوشْ. 1:2، 12، 2:22). \bd ’ذَايسْ‘\bd* - إِخْسْ أَذْ يِينِي ’ذِي لْمَاسِيحْ‘.\f*
\v 7 إِ زِي ذوْڒغْ ذ أَمْسخَّارْ عْلَاحْسَابْ ثَاوْهِيبْثْ ن أَرْضَا ن أَربِّي إِ ذ أَيِي إِمّوْشنْ عْلَاحْسَابْ جّهْذْ نّسْ إِ \add ذَايِي\add* إِخدّْمنْ. \x ◘ \xo 3:‏7 \xt أَفا. 1‏:‏19؛ كُول. 2‏:‏12. \x*
\v 8 أَقَا إِمّوْشْ أَيِي أَرْضَا-يَا، إِ نشّْ ذ أَمُوقْڒِيڒْ قَاعْ جَارْ مَارَّا إِمْقدَّاسنْ، حِيمَا أَذْ بَارّْحغْ س ڒخْبَارْ أَصبْحَانْ، \add إِوَا\add* أَڭْڒَا ن لْمَاسِيحْ إِ وَارْ نْزمَّارْ أَذْ نفْهمْ، \x ◘ \xo 3:‏8 \xt ڒخ. 9‏:‏15؛ 13‏:‏2؛ 22‏:‏21؛ 1 كُور. 15‏:‏9؛ ڭال. 1‏:‏16؛ 2‏:‏8؛ 1 تِيم. 2‏:‏7؛ 2 تِيم. 1‏:‏11، 15. \x*
\v 9 ؤُ حِيمَا أَذْ سُّوفّْغغْ غَارْ ثْفَاوْثْ إِ مَارَّا، مِينْ إِخْسْ أَذْ يِينِي ؤُوكّڒْ ن سِّيرّْ إِ ثُوغَا إِنُوفَّارنْ ذِي زّْمَانَاثْ ن زِيشْ ذِي أَربِّي، ونِّي إِ د-إِخڒْقنْ كُوڒْشِي، \x ◘ \xo 3:‏9 \xt أَمز. 1‏:‏3؛ إِزهد. 33‏:‏6؛ يُوح. 1‏:‏3؛ رُوم. 16‏:‏25؛ أَفا. 1‏:‏9؛ كُول. 1‏:‏16، 26؛ 2 تِيم. 1‏:‏10؛ ثِيث. 1‏:‏2؛ عبر. 1‏:‏2؛ 1 بُط. 1‏:‏20. \x*
\v 10 حِيمَا ثِيغِيثْ ن أَربِّي أَكْ-ذ وَاطَّاسْ ن إِغزْذِيسنْ نّسْ أَذْ ثِيڒِي ثتّْوَاسّْننْ س ثْمسْمُونْثْ غَارْ ڒحْكَامَاثْ ذ صُّولَاطَاثْ ذڭْ إِجنْوَانْ، \x ◘ \xo 3:‏10 \xt 1 بُط. 1‏:‏12. \x*
\v 11 \add ثِيغِيثْ\add* إِ ثُوغَا إِسّوْجذْ نتَّا زِي زّْمَانْ ؤُشَا إِكمّڒْ إِ-ت ذِي سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ،
\v 12 ونِّي ذَايسْ أَقَا غَارْنغْ ثَارْيَاسْثْ ذ وَاذَافْ أَكْ-ذ تِّيقثْ س لْ-إِيمَانْ زَّايسْ. \x ◘ \xo 3:‏12 \xt يُوح. 10‏:‏9؛ 14‏:‏6؛ رُوم. 5‏:‏2؛ أَفا. 2‏:‏18؛ عبر. 10‏:‏19. \x*
\v 13 س ؤُينِّي تّْزَاوَاڭغْ كنِّيوْ، مَاحنْذْ وَارْ تِّيحْڒمْ شَا س ڒمْحَايمْ إِنُو ذِي طّْوعْ نْومْ. أَقَا مَانْ أَيَا إِ ؤُعُودْجِي إِ كنِّيوْ. \x ◘ \xo 3:‏13 \xt فِيل. 1‏:‏14؛ كُول. 1‏:‏24؛ 1 تس. 3‏:‏3. \x*
\b
\s1 ثَاژَادْجِيثْ ن بُولُوسْ خْ إِفَاسُوسِييّنْ
\m 
\v 14 أَذْ أَذَارغْ س إِفَادّنْ إِنُو زَّاثْ إِ بَابَاسْ ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ،
\v 15 إِ ونِّي ؤُمِي سمَّانْ \add كُوڒْ إِجّْ ن\add* ثْبَابَاثْ إِ إِدْجَانْ ذڭْ إِجنْوَانْ ذ ثمُّورْثْ،
\v 16 حِيمَا أَذْ أَومْ إِوْشْ عْلَاحْسَابْ أَڭْڒَا ن ؤُعُودْجِي نّسْ ؤُ حِيمَا أَذْ ثتّْوَاسّْجهْذمْ س جّهْذْ س أَرُّوحْ نّسْ ذِي بْنَاذمْ نْومْ ن ذَاخڒْ. \x ◘ \xo 3:‏16 \xt أَفا. 6‏:‏10. \x*
\v 17 حِيمَا لْمَاسِيحْ أَذْ إِزْذغْ ذڭْ وُوڒَاونْ نْومْ س لْ-إِيمَانْ، س ثَايْرِي، خْ مِينِّي ثشَّاثمْ إِژوْرَانْ ؤُ ذْسَاسْ نْومْ أَذْ يِيڒِي إِمْثنْ، \x ◘ \xo 3:‏17 \xt كُول. 2‏:‏7. \x*
\v 18 حِيمَا أَذْ ثْزمَّارمْ أَذْ ثْفهْممْ أَكْ-ذ مَارَّا إِمْقدَّاسنْ مِينْ ثعْنَا ثِيرُو ذ ثُوزّڭَّارْثْ ذ ڒُوعْڒَا ذ ڒَادْجَاغْ،
\v 19 ؤُ أَذْ ثسّْنمْ \add عَاوذْ\add* ڒمْغَارثْ ن ثُوسّْنَا ن ثَايْرِي ن لْمَاسِيحْ، ؤُشَا أَذْ ثِيڒِيمْ ثْعمَّارمْ س مَارَّا أَعمَّارْ ن أَربِّي.
\m 
\v 20 مَاشَا إِ نتَّا ؤُمِي غَارسْ ثِيزمَّارْ إِفيّْضنْ حِيمَا أَذْ إِڭّْ ذِي طّْوعْ نّغْ سنّجْ إِ مِينْ نتّتَّارْ نِيغْ نتّْخَارّصْ، عْلَاحْسَابْ جّهْذْ نّسْ إِ إِخدّْمنْ ذَايْنغْ، \x ◘ \xo 3:‏20 \xt رُوم. 16‏:‏25. \x*
\v 21 إِ نتَّا إِكَّارْ أَسْ-د ؤُعُودْجِي ذِي ثْمسْمُونْثْ نّسْ، ذِي يَاسُوع لْمَاسِيحْ، ذِي مَارَّا ڒجْيُوڒْ إِ ڒبْذَا قَاعْ. أَمِينْ. \f ◼ \fr 3:‏21 \ft \bd ’إِ ڒبْذَا قَاعْ‘\bd* - نِيغْ: ’إِ ڒبْذَا ن ڒبْذَاثْ‘.\f*
\b
\b
\c 4
\s1 إِشْثْ ن أَرِّيمثْ ذ إِجّْ ن أَرُّوحْ س لْمَاسِيحْ
\m 
\v 1 أَمْ ؤُمحْبُوسْ ذِي سِيذِيثْنغْ، زِييَّارغْ خَاومْ، حِيمَا أَذْ ثُويُورمْ أَمْ مَامّشْ د-ثُوسَا أَكْ-ذ ثْڒَاغِيثْ إِ زِي ثتّْوَاڒَاغَامْ، \x ◘ \xo 4:‏1 \xt أَمز. 17‏:‏1؛ 1 كُور. 7‏:‏20؛ فِيل. 1‏:‏27؛ كُول. 1‏:‏10؛ 1 تس. 2‏:‏12. \x*
\v 2 س مَارَّا أَوَاضعْ ن بُوحْبڒْ، س ثمْهِينْثْ ؤُ س تَّاسِيعْ ن ڒْخَاضَارْ، أَقَا أَذْ ثْقبّْڒمْ إِجّْ ونّغْنِي ذِي ثَايْرِي، \x ◘ \xo 4:‏2 \xt كُول. 1‏:‏11؛ 3‏:‏12؛ 1 تس. 5‏:‏14. \x*
\v 3 أَذْ ثشْضَارمْ مَاحنْذْ أَذْ ثقِّيممْ ثْمُونمْ ذ إِجّْ ذِي أَرُّوحْ س ثْسغْوِينْ ن ڒهْنَا،
\v 4 مَاحنْذْ أَذْ ثِيڒِيمْ ذڭْ إِشْثْ ن أَرِّيمثْ ؤُ ذڭْ إِجّْ ن أَرُّوحْ أَمْ مَامّشْ ؤُمِي ثتّْوَاڒَاغَامْ ذڭْ ؤُسِيثمْ ن ثْڒَاغِيثْ نْومْ ذ إِجّنْ.
\v 5 مَاغَارْ سِيذِي ذ إِجّنْ، ذ لْ-إِيمَانْ ذ إِجّنْ ؤُڒَا ذ أَسغْضصْ ذ إِجّنْ، \x ◘ \xo 4:‏5 \xt أَعَوذ. 4‏:‏39؛ مـَال. 2‏:‏10؛ 1 كُور. 8‏:‏4، 6. \x*
\v 6 ؤُ أَربِّي ذ إِجّنْ، بَابَاثْنغْ مَارَّا ؤُ خْ مَارَّا ؤُ س مَارَّا ؤُ ذَايْنغْ مَارَّا.
\v 7 مَاشَا أَرْضَا إِمّوْشْ أَنغْ مَارَّا إِذْنغْ عْلَاحْسَابْ ڒْمِيجَاڒْ ن مِينْ ذ أَنغْ إِوْشَا لْمَاسِيحْ. \x ◘ \xo 4:‏7 \xt رُوم. 12‏:‏6؛ 1 كُور. 12‏:‏11؛ 2 كُور. 10‏:‏13؛ 1 بُط. 4‏:‏10. \x*
\v 8 س ؤُينِّي قَّارنْ:
\b
\m \qt ”إِڭعّذْ غَارْ ڒُوعْڒَا،\qt*
\m \qt يِيوْيِي \tl أَكِيذسْ\tl* إِمحْبَاسْ ذِي ثْمحْبَاسْثْ،\qt*
\m \qt إِوْشَا ثِيرْزِيفِينْ إِ إِوْذَانْ.“\qt* \x ◘ \xo 4:‏8 \xt إِزهد. 68‏:‏19. \x*
\b
\m 
\v 9 مَاشَا مِينْ إِعْنَا عَاوذْ \add وَاوَاڒْ-أَ\add*، أَقَا نتَّا إِڭعّذْ سنّجْ، مْغِيرْ أَقَا نتَّا غَارْ ؤُمزْوَارْ عَاوذْ ثُوغَا إِهْوَا-د غَارْ طّْرُوفَا ن ثمُّورْثْ ن وَادَّايْ قَاعْ؟! \x ◘ \xo 4:‏9 \xt يُوح. 3‏:‏13؛ 6‏:‏62؛ 1 بُط. 3‏:‏18‏-‏19\x*
\v 10 ونِّي ثُوغَا د-إِهْوَانْ، نتَّا عَاوذْ ذ ونِّي ثُوغَا إِڭعّْذنْ سنّجْ إِ مَارَّا إِجنْوَانْ، حِيمَا أَذْ إِسِّيوضْ مَارَّا غَارْ ڒكْمَاڒثْ. \x ◘ \xo 4:‏10 \xt عبر. 1‏:‏1‏-‏3\x*
\m 
\v 11 نتَّا يَارَّا شَا ذ رُّوسُولْ، شَا ذ إِنَابِييّنْ، شَا ذ إِمْبشَّارنْ، شَا ذ إِمكْسَاونْ ؤُ شَا ذ إِمْسڒْمَاذنْ، \x ◘ \xo 4:‏11 \xt 1 كُور. 12‏:‏28. \x*
\v 12 حِيمَا أَذْ \add زَّايْسنْ\add* تّْوَاكمّْڒنْ إِمْقدَّاسنْ إِ ڒْخذْمثْ ن ثْسخَّارْثْ، إِ ڒبْنِي ن أَرِّيمثْ ن لْمَاسِيحْ، \x ◘ \xo 4:‏12 \xt رُوم. 12‏:‏5؛ 1 كُور. 12‏:‏27؛ أَفا. 1‏:‏23؛ 5‏:‏23؛ كُول. 1‏:‏24. \x*
\v 13 أَڒْ إِ غَا نَاوضْ مَارَّا غَارْ ؤُمُونِي ذ إِجّنْ ذِي لْ-إِيمَانْ ؤُ ذِي ثُوسّْنَا ن مِّيسْ ن أَربِّي، أَذْ نِيڒِي ذ إِجّْ ن بْنَاذمْ إِكْمڒْ س ڒعْبَارْ ن صِّيفثْ ثْمُونْ ن لْمَاسِيحْ.
\v 14 إِتّْخصَّا وَارْ نتِّيڒِي أَمْ إِحنْجِيرنْ إِنِّي إِتّْوَاعَارَّانْ زِي طَّارْفْ غَارْ ونّغْنِي ؤُشَا ذوْڒنْ إِڭّْوْجنْ زِي كُوڒْ أَسمِّيضْ ن ؤُسڒْمذْ ذ أَحْرَايْمِي زڭْ إِوْذَانْ نِّي يَارزُّونْ أَذْ \add أَنغْ\add* غَارّنْ س ثحْرَايْمشْثْ نْسنْ، \x ◘ \xo 4:‏14 \xt مت. 11‏:‏7؛ 1 كُور. 14‏:‏2. \x*
\v 15 مَاشَا إِتّْخصَّا أَذْ نْبدّْ نِيشَانْ ذِي ثَايْرِي نّغْ، مَاحنْذْ مَارَّا مِينْ غَارْنغْ إِدْجَانْ أَذْ إِڭْمَا ذِي لْمَاسِيحْ ونِّي ذ أَزدْجِيفْ. \x ◘ \xo 4:‏15 \xt أَفا. 5‏:‏23؛ كُول. 1‏:‏18. \x*
\v 16 زَّايسْ ثنّجْرُو ؤُ ثتّْوَاسّْمُونْ أَرِّيمثْ مَارَّا س مَارَّا ڒمْفَاصڒْ، عْلَاحْسَابْ مِينْ إِمّوْشنْ س ڒعْبَارْ إِ مْكُوڒْ أَغزْذِيسْ إِ ثْيُومِي ن أَرِّيمثْ، أَڒْ غَا إِتّْوَاكمّڒْ ڒبْنِي نّسْ ذِي ثَايْرِي. \x ◘ \xo 4:‏16 \xt رُوم. 12‏:‏5؛ 1 كُور. 12‏:‏27؛ أَفا. 2‏:‏21. \x*
\b
\s1 بْنَاذمْ ن جْذِيذْ
\m 
\v 17 مَاشَا نشّْ قَّارغْ ؤُ شهّْذغْ مَانْ أَيَا ذِي سِيذِي، حِيمَا وَارْ ثڭُّورمْ عَاذْ أَمْ مَامّشْ ؤُيُورنْ ڒڭْنُوسْ إِنّغْنِي، إِنِّي إِدَّارنْ ذِي ڒْبَاطڒْ ن إِخَارِّيصنْ نْسنْ، \x ◘ \xo 4:‏17 \xt رُوم. 1‏:‏9، 18؛ 1 بُط. 4‏:‏3. \x*
\v 18 بَارْشْننْ ذِي ڒعْقڒْ نْسنْ ؤُ أَڭّْوجنْ خْ ثُوذَارْثْ ن أَربِّي، مِينْزِي وَارْ ذَايْسنْ بُو ثُوسّْنَا، ؤُ خْ سِّيبّثْ ن ثْقُوبَّانشْثْ إِ ذَايْسنْ إِدْجَانْ، ؤُ خْ سِّيبّثْ ن ڒقْسَاحثْ ن وُوڒْ نْسنْ. \x ◘ \xo 4:‏18 \xt 1 تس. 4‏:‏5. \x*
\v 19 نِيثْنِي قضْعنْ إِخفْ نْسنْ زڭْ ؤُسِيثمْ، سلّْمنْ إِخفْ نْسنْ إِ ؤُفُوشّحْ ؤُ إِ وضْفَارْ ن مَارَّا مَارْكَاثْ ن ڒخْمجْ عْلَاحْصَابْ مژْرِي نْسنْ.
\v 20 مَاشَا وَارْ إِدْجِي أَمُّو إِ ثسّْنمْ لْمَاسِيحْ،
\v 21 ڒَامِي زعْمَا كنِّيوْ ثُوغَا ثسْڒَامْ غَارسْ نِيشَانْ ؤُشَا ثْڒمْذمْ زَّايسْ عْلَاحْسَابْ ثِيذتّْ إِ إِدْجَانْ ذِي يَاسُوع.
\v 22 مَاشَا س ڒْعكْسْ إِتّْخصَّا كنِّيوْ أَذْ ثنْضَارمْ ثِيشْڒِي نْومْ ن زِيشْ، أَذْ ثجّمْ بْنَاذمْ أَقْذِيمْ إِ إِتّْوَاسّخْسَارنْ س نّشْوَاثْ إِغشّنْ. \x ◘ \xo 4:‏22 \xt كُول. 3‏:‏9؛ عبر. 12‏:‏1؛ 1 بُط. 2‏:‏1. \x*
\v 23 تّْوَاعذْڒمْ زِي جْذِيذْ س نّيّثْ ن ڒعْقڒْ نْومْ.
\v 24 أَرْضمْ بْنَاذمْ ن جْذِيذْ إِ د-إِتّْوَاخڒْقنْ ذِي أَربِّي ذِي ثْسڭْذَا ؤُ ذِي ثَاقدَّاسْثْ ذ ثِيذتّْ. \x ◘ \xo 4:‏24 \xt رُوم. 6‏:‏4؛ كُول. 3‏:‏10؛ 1 بُط. 4‏:‏2. \x*
\m 
\v 25 س ؤُينِّي جّمْ إِخَارِّيقنْ، سِيوْڒمْ ثِيذتّْ كُوڒْ إِجّْ أَكْ-ذ جَّارْ نّسْ، مِينْزِي نشِّينْ ذ إِخْفَاونْ إِجّنْ إِ ونّغْنِي. \x ◘ \xo 4:‏25 \xt زَاك. 8‏:‏16. \x*
\v 26 خيّْقمْ، \add مَاشَا\add* وَارْ تّڭّمْ شَا دّْنُوبْ، وَارْ تّجِّي أَذْ ثغْرِي ثْفُوشْثْ خْ \add إِجّْ ن ؤُذُوقّزْ ن\add* ؤُخيّقْ نْومْ. \x ◘ \xo 4:‏26 \xt إِزهد. 4‏:‏5. \x*
\v 27 وَارْ تِّيشمْ شَا أَمْشَانْ إِ إِبْڒِيسْ. \x ◘ \xo 4:‏27 \xt يَاع. 4‏:‏7؛ 1 بُط. 5‏:‏9. \x*
\v 28 وَارْ ثجِّي ونِّي إِتَّاشَارنْ أَذْ يَاشَارْ عَاذْ، مَاشَا حْسنْ أَذْ يَارْبرْ س إِفَاسّنْ نّسْ مَاحنْذْ أَذْ إِسُّوفّغْ إِشْثْ ذ ڒْحَاجّثْ ذ ثَاصبْحَانْثْ، مَاحنْذْ أَذْ ت إِوْشْ إِ يِينِّي إِحْذَاجنْ. \x ◘ \xo 4:‏28 \xt ڒخ. 20‏:‏35؛ 1 تس. 4‏:‏11؛ 2 تس. 3‏:‏8، 12. \x*
\v 29 وَارْ د-إِتّكّْ شَا وَاوَاڒْ ن وشْرَاهْ زڭْ ؤُقمُّومْ نْومْ، مَاشَا مِينْ إِصبْحنْ ؤُ مِينْ إِنفّْعنْ إِ ڒبْنِي، حِيمَا أَذْ ثسِّيوْضمْ أَرْضَا إِ يِينِّي إِ غَا إِسْڒَانْ. \x ◘ \xo 4:‏29 \xt مت. 12‏:‏36؛ أَفا. 5‏:‏3، 4. \x*
\v 30 وَارْ تّسّْفُّوڭْممْ شَا أَرُّوحْ إِقدّْسنْ ن أَربِّي إِ زِي ثتّْوَاشمّْعمْ أَڒْ أَسّْ ن ؤُسنْجمْ. \x ◘ \xo 4:‏30 \xt لك. 21‏:‏28؛ رُوم. 8‏:‏16، 23؛ 2 كُور. 1‏:‏22؛ 5‏:‏5؛ أَفا. 1‏:‏13، 14. \x*
\v 31 جّمْ أَذْ زَّايْومْ ثتّْوَاكّسْ مَارَّا ثَارْزُوڭِي ذ ثفْقحْثْ ذ وغْضَابْ ذ ؤُصدّعْ ذ ؤُشقّفْ أَكْ-ذ مَارَّا ثُوعفّْنَا \add إِ د-إِتَّاسنْ أَكْ-ذ مَانْ أَيَا\add*. \x ◘ \xo 4:‏31 \xt كُول. 3‏:‏19. \x*
\v 32 إِڒِيمْ ثْضَارْفمْ ؤُ ڭّمْ ڒحْنُونشْثْ ذڭْ وَايَاوَا. سَامْحمْ إِ وَايَاوْيَا أَمْ أَربِّي عَاوذْ أَقَا إِغْفَارْ أَنغْ ذِي لْمَاسِيحْ. \x ◘ \xo 4:‏32 \xt مت. 6‏:‏14؛ مك. 11‏:‏25؛ فِيل. 2‏:‏1؛ كُول. 3‏:‏12، 13. \x*
\b
\b
\c 5
\m 
\v 1 س ؤُيَا إِڒِيمْ ذ إِمضْفَارنْ ن أَربِّي أَمْ إِحنْجِيرنْ إِعِيزّنْ،
\v 2 ؤُيُورمْ ذِي ثَايْرِي أَمْ مَامّشْ ؤُڒَا ذ لْمَاسِيحْ ثُوغَا إِتّخْسْ أَنغْ، إِوْشَا إِخفْ نّسْ خَانغْ ذ ثَاوْهِيبْثْ ذ ثْغَارْصْثْ إِ أَربِّي، أَقَا-ت ذ إِشْثْ ن ڒفْوَاحثْ ثَاصبْحَانْثْ. \x ◘ \xo 5:‏2 \xt يُوح. 13‏:‏34؛ 15‏:‏12؛ ڭال. 2‏:‏20؛ 1 تس. 4‏:‏9؛ ثِيث. 2‏:‏14؛ 1 بُط. 3‏:‏18؛ عبر. 8‏:‏3؛ 9‏:‏14؛ 1 يُوح. 3‏:‏23؛ 4‏:‏21\x*
\m 
\v 3 مَاشَا خْ فَارْقْ-شّْغڒْ ذ مَارَّا ڒخْمجْ ذ طّْمعْ، وَارْ خَاسْ إِتِّيڒِي بُو وَاوَاڒْ جَارْ أَومْ أَمْ مَامّشْ إِشُووَّارْ إِ إِمْقدَّاسنْ، \x ◘ \xo 5:‏3 \xt مك. 7‏:‏21؛ أَفا. 4‏:‏29؛ كُول. 3‏:‏5. \x*
\v 4 ؤُڒَا خْ ڒْهَارْذْ إِسّْبهْذْڒنْ نِيغْ خْ وَاوَاڒنْ إِخْوَانْ نِيغْ خْ ثْقصَّارْثْ نِيغْ خْ ڒفْضِيحثْ، ثِيمسْڒَايِينْ إِ وَارْ نفّْعنْثْ \add ذِي وَالُو\add*، مَاشَا مَامّشْ نّغْنِي إِتّْخصَّا أَقَاذِي.
\v 5 مِينْزِي ثسّْنمْ أَقَا كُوڒْ إِجّْ ونِّي إِتّڭّنْ فَارْقْ-شّْغڒْ، نِيغْ ونِّي ذَايسْ ڒخْمجْ نِيغْ طّْمعْ، أَقَا وَانِيثَا إِعبّذْ لْ-أَصْنَامْ، وَارْ غَارسْ بُو ثسْغَارْثْ ذِي ثْڭلْذِيثْ ن لْمَاسِيحْ ؤُ ن أَربِّي. \x ◘ \xo 5:‏5 \xt 1 كُور. 6‏:‏10؛ ڭال. 5‏:‏19؛ كُول. 3‏:‏5؛ أَسَا. 22‏:‏15. \x*
\m 
\v 6 وَارْ تّجِّيمْ ؤُڒَا ذ إِجّنْ أَذْ كنِّيوْ إِغكّْوِي س وَاوَاڒنْ إِخْوَانْ، أَقَا زِي مَانْ أَيَا د-إِهكّْوَا وغْضَابْ ن أَربِّي خْ ثَارْوَا ن ڒْمُوعْصِييّثْ. \x ◘ \xo 5:‏6 \xt إِرْم. 29‏:‏8؛ مت. 24‏:‏4؛ مك. 13‏:‏5؛ لك. 21‏:‏8؛ كُول. 2‏:‏4، 18؛ 2 تس. 2‏:‏3؛ 1 يُوح. 4‏:‏1. \x*
\v 7 وَارْ شَارّْشمْ شَا أَكِيذْسنْ!
\v 8 مِينْزِي زِيشْ ثُوغَا كنِّيوْ ذ ثَادْجسْثْ، مَاشَا أَقَا ڒخُّو كنِّيوْ ذ ثَافَاوْثْ ذِي سِيذِيثْنغْ. س ؤُينِّي ؤُيُورمْ أَمْ ثَارْوَا ن ثْفَاوْثْ، \x ◘ \xo 5:‏8 \xt 1 تس. 5‏:‏4. \x*
\v 9 مِينْزِي ڒْغِيدْجثْ ن ثْفَاوْثْ ثتِّيڒِي ذِي مَارَّا ثْشُونِي ذ ثْسڭْذَا ذ ثِيذتّْ. \x ◘ \xo 5:‏9 \xt ڭال. 5‏:‏22. \x*
\v 10 فَارْزمْ مِينْ غَا يَارْضَانْ سِيذِيثْنغْ.
\v 11 وَارْ شَارّْشمْ شَا ذِي ڒخْذَايمْ ثِيبَارْشَانِينْ إِ وَارْ د-إِتِّيوْينْ ڒْغِيدْجثْ، مَاشَا وبّْخمْ ثنْثْ. \x ◘ \xo 5:‏11 \xt مت. 18‏:‏17؛ 1 كُور. 5‏:‏8؛ 10‏:‏20؛ 2 كُور. 6‏:‏14؛ 2 تس. 3‏:‏14. \x*
\v 12 مِينْزِي مِينْ تّڭّنْ ذِي ثْنُوفّْرَا، أَقَا-ث ذ نّْعِي إِ وَارْ ثْزمَّارذْ ؤُڒَا أَذْ ث ثْعَاوْذذْ.
\v 13 مِينْزِي مَارَّا أَذْ إِتّْوَاسڭّذْ س ثْفَاوْثْ ؤُ أَذْ إِتّْوَاسَّارْڭبْ س ثْفَاوْثْ ؤُ مَارَّا مِينْ إِسَّارْڭَابنْ ذ ثِيفَاوْثْ إِ يدْجَا. \x ◘ \xo 5:‏13 \xt يُوح. 3‏:‏20، 21. \x*
\v 14 س ؤُينِّي قَّارنْ:
\b
\m \qt ”فَاقْ شكْ، أَ بُو يِيضصْ.\qt*
\m \qt كَّارْ-د زِي ثَادَّارْثْ ن إِمتِّيننْ،\qt*
\m \qt ؤُشَا أَذْ خَاكْ إِڭّْ لْمَاسِيحْ ثَافَاوْثْ.“\qt* \x ◘ \xo 5:‏14 \xt رُوم. 13‏:‏11؛ 1 تس. 5‏:‏6. \x*
\b
\m 
\v 15 حْضَامْ أَذْ ثُويُورمْ س ؤُوقَّارْ، وَارْ إِدْجِي أَمْ إِبُوهَاڒِييّنْ، مَاشَا أَمْ إِمِيغِيسنْ، \x ◘ \xo 5:‏15 \xt كُول. 4‏:‏5. \x*
\v 16 إِنِّي إِ غَا يَاوْينْ أَرِيقِّي إِ ڒْوقْثْ نْسنْ، مِينْزِي ؤُسَّانْ-أَ ذ إِعفَّاننْ. \x ◘ \xo 5:‏16 \xt رُوم. 13‏:‏11. \x*
\v 17 خْ ؤُينِّي وَارْ تِّيڒِيمْ ذ إِبُوهَاڒِييّنْ، مَاشَا فهْممْ مِينْ إِخْسْ أَربِّي. \x ◘ \xo 5:‏17 \xt رُوم. 12‏:‏2؛ 1 تس. 4‏:‏3. \x*
\v 18 وَارْ سشَّارَامْ شَا س بِينُو إِ إِتَّاوْينْ غَارْ ڒقْجَاحثْ، مَاشَا إِڒِيمْ ثْعمَّارمْ س أَرُّوحْ. \x ◘ \xo 5:‏18 \xt أَوڒن. 23‏:‏29؛ إِشا. 5‏:‏11، 22؛ لك. 21‏:‏34. \x*
\v 19 سِيوْڒمْ ذِي ڒعْمُورْ نْومْ س إِزهِّيذنْ ذ إِزْڒَانْ ن ؤُصبّحْ ذ إِزْڒَانْ ن أَرُّوحْ،غنّْجمْ ذڭْ وُوڒَاونْ نْومْ إِ سِيذِي. \x ◘ \xo 5:‏19 \xt كُول. 3‏:‏16. \x*
\v 20 قَاذَامْ ڒبْذَا أَربِّي بَابَاثْنغْ خْ كُوڒْ  إِجّنْ ذڭْ يِيسمْ ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ. \x ◘ \xo 5:‏20 \xt كُول. 3‏:‏17؛ 1 تس. 5‏:‏18. \x*
\v 21 وَاضْضْعمْ إِخفْ نْومْ إِ وَايَاوْيَا ذِي ثَايْرِي ن لْمَاسِيحْ.
\b
\s1 ڒمْڒَاشْ ذ صِّيفثْ ن لْمَاسِيحْ ذ ثْمسْمُونْثْ
\m 
\v 22 \add أَ\add* ثِيمْغَارِينْ، وَاضْضْعنْثْ إِ يرْيَازنْ نْكنْثْ أَمْ ثتّْوَاضْضْعنْثْ إِ سِيذِيثْنغْ، \x ◘ \xo 5:‏22 \xt أَمز. 3‏:‏16؛ 1 كُور. 14‏:‏34؛ كُول. 3‏:‏18؛ ثِيث. 2‏:‏5؛ 1 بُط. 3‏:‏1. \x*
\v 23 مِينْزِي أَرْيَازْ أَقَا ذ أَزدْجِيفْ ن ثمْغَارْثْ أَمْ ؤُڒَا ذ لْمَاسِيحْ إِ يدْجَانْ ذ أَزدْجِيفْ ن ثْمسْمُونْثْ ذ ونِّي إِتِّيشنْ ثُوذَارْثْ إِ أَرِّيمثْ. \x ◘ \xo 5:‏23 \xt رُوم. 12‏:‏5؛ 1 كُور. 11‏:‏3؛ 12‏:‏27؛ أَفا. 1‏:‏22، 23؛ 4‏:‏12، 15؛ كُول. 1‏:‏18، 24. \x*
\v 24 أَمْ ثْمسْمُونْثْ ثتّْوَاضّعْ إِخفْ نّسْ إِ لْمَاسِيحْ، أَمنِّي عَاوذْ ثِيمْغَارِينْ أَذْ وَاضْضْعنْثْ إِخفْ نْسنْثْ إِ يرْيَازنْ نْسنْثْ ذِي مَارَّا.
\m 
\v 25 \add أَ\add* إِرْيَازنْ، خْسمْ ثِيمْغَارِينْ نْومْ أَمْ مَامّشْ ثُوغَا إِخْسْ لْمَاسِيحْ ثَامسْمُونْثْ ؤُشَا إِسلّمْ إِخفْ نّسْ ذِي طّْوعْ نّسْ، \x ◘ \xo 5:‏25 \xt ڭال. 1‏:‏4؛ أَفا. 5‏:‏2؛ كُول. 3‏:‏19. \x*
\v 26 حِيمَا أَذْ ت يَارّْ ذ ثَامْقدَّاسْثْ ؤُ أَذْ أَسْ إِسِّيزْذڭْ س ؤُسِيرْذْ \add ن وَامَانْ إِدَّارنْ\add* ؤُ س وَاوَاڒْ. \x ◘ \xo 5:‏26 \xt ثِيث. 3‏:‏5؛ 1 بُط. 3‏:‏21. \x*
\v 27 نتَّا أَذْ إِڭّْ ثَامسْمُونْثْ قِيبَاتْشْ إِ يِيخفْ نّسْ س ؤُعُودْجِي، بْڒَا أَبقِّيضْ نِيغْ أَشبْرِيقْ، بْڒَا ؤُڒَا ذ إِشْثْ ن ڒْحَاجّثْ زِي مَارَّا مَانْ أَيَا، مَاشَا أَذْ ثِيڒِي ذ ثَامْقدَّاسْثْ ؤُ بْڒَا ڒْعِيبْ. \x ◘ \xo 5:‏27 \xt كُول. 1‏:‏22. \x*
\m 
\v 28 أَمُّو إِتّْخصَّا أَذْ خْسنْ يرْيَازنْ ثِيمْغَارِينْ نْسنْ أَمْ أَرِّيمثْ نْسنْ. أَقَا ونِّي إِتّخْسنْ ثَامْغَارْثْ نّسْ، أَقَا إِتّخْسْ إِخفْ نّسْ.
\v 29 ؤُڒَا ذ إِجّْ وَارْ إِشَارْهْعمَّارْصْ أَرِّيمثْ نّسْ، مَاشَا إِسّشَّا إِ-ث، إِتّْحَاوَاڒْ خَاسْ أَمْ مَامّشْ \add إِتّْحَاوَاڒْ\add* عَاوذْ لْمَاسِيحْ خْ ثْمسْمُونْثْ،
\v 30 مِينْزِي نشِّينْ ذ إِخْفَاونْ ن أَرِّيمثْ نّسْ، ن ويْسُومْ نّسْ ؤُ ن إِغْسَانْ نّسْ. \x ◘ \xo 5:‏30 \xt رُوم. 12‏:‏5؛ 1 كُور. 12‏:‏27. \x*
\m 
\v 31 س ؤُينِّي أَرْيَازْ أَذْ يجّْ بَابَاسْ ذ يمَّاسْ مَاحنْذْ أَذْ إِقّنْ غَارْ ثمْغَارْثْ نّسْ، أَذْ إِڒِينْ س ثْنَاينْ إِذْسنْ ذ إِجّْ ن ويْسُومْ. \x ◘ \xo 5:‏31 \xt أَمز. 2‏:‏24؛ مت. 19‏:‏5، 6؛ مك. 10‏:‏8؛ 1 كُور. 6‏:‏16. \x*
\v 32 سِّيرّْ-أَ ذ أَمقّْرَانْ، مَاشَا نشّْ قَّارغْ ث زِي جِّيهثْ ن لْمَاسِيحْ ذ ثْمسْمُونْثْ.
\v 33 مَاشَا إِتّْخصَّا عَاوذْ إِ كُوڒْ إِجّْ زَّايْومْ مَاحنْذْ أَذْ إِخْسْ أَمنِّي ثَامْغَارْثْ نّسْ أَمْ يِيخفْ نّسْ، مَاشَا ثَامْغَارْثْ أَذْ ثْوقَّارْ أَرْيَازْ.
\b
\b
\c 6
\s1 لْوَالِيذِينْ ذ إِحنْجِيرنْ نْسنْ، إِمْسخَّارنْ ذ أَيْثْبَابْ نْسنْ
\m 
\v 1 \add أَ\add* إِحنْجِيرنْ، طَاعمْ إِ لْوَالِيذِينْ نْومْ ذِي سِيذِيثْنغْ، مِينْزِي مَانْ أَيَا نِيشَانْ إِ يدْجَا. \x ◘ \xo 6:‏1 \xt كُول. 3‏:‏20. \x*
\v 2 ثَا ذ ثَاوْصيّثْ ثَامزْوَارُوثْ س يِيجّْ ن لْوَاعْذْ: ’وقَّارْ بَابَاشْ ذ يمَّاشْ، \x ◘ \xo 6:‏2 \xt ؤُف. 20‏:‏12؛ أَعَوذ. 5‏:‏16؛ 27‏:‏16؛ مت. 15‏:‏4؛ مك. 7‏:‏10. \x*
\v 3 حِيمَا أَذْ ثِيڒِيذْ مْلِيحْ ؤُ أَذْ ثدَّارذْ أَطَّاسْ ذِي ثمُّورْثْ.“
\m 
\v 4 \add أَ\add* إِبَابَاثنْ، وَارْ سْعَارمْ شَا إِحنْجِيرنْ نْومْ، مَاشَا أَربَّامْ ثنْ س ؤُستّفْ ؤُ ذِي ثْغُورِي ن سِيذِيثْنغْ. \x ◘ \xo 6:‏4 \xt أَعَوذ. 6‏:‏7، 20؛ إِزهد. 78‏:‏4؛ أَوڒن. 19‏:‏8؛ 29‏:‏17. \x*
\b
\m 
\v 5 \add أَ\add* إِمْسخَّارنْ، طَاعمْ أَيْثْبَابْ نْومْ ذِي دُّونشْثْ-أَ س ثِيڭّْوُوذِي ذ ثَارْجِيجِيثْ، ؤُ س ڒصْفَايثْ ن وُوڒْ أَخْمِي إِ لْمَاسِيحْ. \x ◘ \xo 6:‏5 \xt كُول. 3‏:‏22؛ 1 تِيم. 6‏:‏1؛ ثِيث. 2‏:‏9؛ 1 بُط. 2‏:‏18. \x*
\v 6 وَارْ إِدْجِي قِيبَاتْشْ إِ ثِيطَّاوِينْ، أَخْمِي ثتّخْسمْ أَذْ ثَارْضَامْ إِوْذَانْ، مَاشَا أَمْ يِيمْسخَّارنْ ن لْمَاسِيحْ إِنِّي إِتّڭّنْ مِينْ يَارطَّانْ أَربِّي.
\v 7 خذْممْ أَسنْ س مَارَّا ؤُڒْ نْومْ ذِي ثَايْرِي، أَمْ إِ سِيذِيثْنغْ، وَارْ إِدْجِي إِ إِوْذَانْ.
\v 8 أَقَا ثسّْنمْ مَاڒَا ذِينْ حذْ، إِسْمغْ نِيغْ ذ أَحُورِّي، ونِّي إِ غَا إِڭِّنْ شَا ذ ثَاصبْحَانْثْ، سِيذِيثْنغْ أَذْ غَارسْ يَارّْ.
\v 9 عَاوذْ كنِّيوْ، \add أَ\add* أَيْثْبَابْ، ڭّمْ أَمنِّي أَكْ-ذ إِمْسخَّارنْ نْومْ. سَامْحمْ أَسنْ إِعذِّيينْ نْسنْ، مَاغَارْ ثسّْنمْ، أَقَا سِيذِيثْومْ ذڭْ إِجنْوَانْ إِ يدْجَا، ؤُ نتَّا وَارْ إِتّڭّْ شَا س وُوذْمَاونْ. \x ◘ \xo 6:‏9 \xt أَعَوذ. 10‏:‏17؛ 2 إِم. 19‏:‏7؛ أَيُوبْ 34‏:‏19؛ ڒخ. 10‏:‏34؛ رُوم. 2‏:‏11؛ ڭال. 2‏:‏6؛ كُول. 3‏:‏25؛ 4‏:‏1؛ 1 بُط. 1‏:‏17. \x*
\b
\s1 أَمنْغِي أَرُّوحَانِي ذ أَرُّوضْ ن ڒسْنَاحْ ن أَربِّي
\m 
\v 10 س ؤُينِّي، \add أَ\add* وَاوْمَاثنْ إِنُو، محْضمْ ذِي سِيذِيثْنغْ ؤُ ذِي جّهْذْ ن ثْزمَّارْ نّسْ.
\v 11 أَرْضمْ س مَارَّا ڒسْنَاحْ ن أَربِّي، حِيمَا أَذْ ثسّْبدّمْ إِبْرِيذنْ ن ثْحْرَايْمشْثْ ن إِبْڒِيسْ. \x ◘ \xo 6:‏11 \xt كُول. 3‏:‏12؛ 1 تس. 5‏:‏8. \x*
\v 12 أَقَا وَارْ نتّْمنْغِي شَا أَكْ-ذ ويْسُومْ ذ إِذَامّنْ، مَاشَا أَكْ-ذ ڒحْكَامَاثْ، أَكْ-ذ ڒْحُوكَّامْ ذ صُّولَاطَاثْ ن دُّونشْثْ-أَ ثَابَارْشَانْثْ ؤُ أَكْ-ذ ڒَارْيَاحْ إِعفَّاننْ إِنِّي إِدْجَانْ سَاذُو إِجنْوَانْ. \x ◘ \xo 6:‏12 \xt أَفا. 2‏:‏2. \x*
\v 13 س ؤُينِّي أَرْضمْ س مَارَّا ڒسْنَاحْ ن أَربِّي مَاحنْذْ أَذْ ثمّْعَاڒَامْ أَكْ-ذ ؤُمْعفَّانْ. خْمِي غَا ثِيڒِيمْ ثْوجْذمْ كُوڒْشِي، أَذْ ثقِّيممْ ثْبدّمْ. \x ◘ \xo 6:‏13 \xt 2 كُور. 10‏:‏4. \x*
\v 14 س ؤُينِّي بدّمْ، ثْبيْسمْ س ثِيذتّْ ؤُ سْذُورْيمْ إِذْمَارنْ نْومْ س ثْسڭْذَا، \x ◘ \xo 6:‏14 \xt إِشا. 59‏:‏17؛ لك. 12‏:‏35؛ 2 كُور. 6‏:‏7؛ 1 بُط. 1‏:‏13. \x*
\v 15 أَذْ إِڒِينْ إِضَارنْ نْومْ تّْوَاقّْننْ س ڒْخَاضَارْ ن لْ-إِنْجِيلْ ن ڒهْنَا.
\v 16 أَكْ-ذ مَانْ أَيَا مَارَّا، كْسِيمْ ثَاسدَّارْثْ ن لْ-إِيمَانْ \add ذڭْ ؤُفُوسْ نْومْ\add*، مَاحنْذْ أَذْ ثسّْخسْيمْ مَارَّا فْڒِيثْشَاثْ إِتّحْذُوذُوقنْ س ثْمسِّي ن ؤُمْعفَّانْ.
\v 17 ڭّمْ لْكَاسْكْ ن ؤُسنْجمْ \add خْ ؤُزدْجِيفْ نْومْ\add* ؤُشَا طّْفمْ سِّيفْ ن أَرُّوحْ إِ إِدْجَانْ ذ أَوَاڒْ ن أَربِّي. \x ◘ \xo 6:‏17 \xt إِشا. 59‏:‏17؛ 1 تس. 5‏:‏8؛ عبر. 4‏:‏12؛ أَسَا. 2‏:‏16. \x*
\v 18 ژَّادْجَامْ ذِي مَارَّا ثِيژَادْجْ ذ ثُوثْرَا \add نْومْ\add* ڒبْذَا ذِي أَرُّوحْ، ؤُ حْضَامْ بْڒَا قطُّو ذِي ثْژَادْجِيثْ، أَمْ ثتّْژَادْجَامْ ؤُ ثْكسِّيمْ س ڒْمعْرُوفْ ڒبْذَا ذِي طّْوعْ ن مَارَّا إِمْقدَّاسنْ، \x ◘ \xo 6:‏18 \xt لك. 18‏:‏1؛ رُوم. 12‏:‏12؛ كُول. 4‏:‏2؛ 1 تس. 5‏:‏17. \x*
\v 19 ؤُڒَا ذِي طّْوعْ إِنُو، حِيمَا أَذْ أَيِي إِمّوْشْ أَوَاڒْ خْمِي غَا أَرْزْمغْ أَقمُّومْ إِنُو، مَاحنْذْ أَذْ بَارّْحغْ سِّيرّْ ن ڒخْبَارْ أَصبْحَانْ س ثرْيَاسْثْ، \x ◘ \xo 6:‏19 \xt ڒخ. 4‏:‏29؛ 2 تس. 3‏:‏1. \x*
\v 20 إِ زِي نشّْ ذ أَمْسكِّي س سّْنَاسڒْ، حِيمَا أَذْ خَاسْ سِّيوْڒغْ س ثرْيَاسْثْ أَمْ مَامّشْ إِشُووَّارْ أَذْ سِّيوْڒغْ. \x ◘ \xo 6:‏20 \xt 2 كُور. 5‏:‏20. \x*
\b
\s1 أَسدْجمْ غَارْ ؤُنڭَّارُو
\m 
\v 21 حِيمَا أَذْ ثسّْنمْ مَامّشْ غَا يِيڒِي ؤُمدُّورْ إِنُو ؤُ مِينْ تّڭّغْ، خْزَارْ، ثِيشِيكُوسْ، إِجّْ ن ؤُمَاثْنغْ إِعِيزّنْ ذ أَمْسخَّارْ أَمْثِيقِّي ن سِيذِيثْنغْ، أَذْ كنِّيوْ إِخبَّارْ. \x ◘ \xo 6:‏21 \xt ڒخ. 20‏:‏4؛ كُول. 4‏:‏7؛ ثِيث. 3‏:‏12. \x*
\v 22 أَقَا سّكّغْ ث-إِ-د إِ مَانْ أَيَا سِيمَانْثْ نّسْ، حِيمَا أَذْ ثسّْنمْ أَمدُّورْ إِنُو، ؤُشَا حِيمَا أَذْ ذَايْومْ يڭّْ ؤُڒْ. \x ◘ \xo 6:‏22 \xt 2 تِيم. 4‏:‏12. \x*
\m 
\v 23 ڒهْنَا أَذْ يِيڒِي أَكْ-ذ ثَاوْمَاثْ نّغْ ؤُڒَا ذ ثَايْرِي أَكْ-ذ لْ-إِيمَانْ، زِي أَربِّي، بَابَاثْنغْ، ؤُ زِي سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ.
\v 24 أَذْ يِيڒِي أَرْضَا أَكْ-ذ مَارَّا إِنِّي إِتّخْسنْ سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ بْڒَا ڒْغشّْ. أَمِينْ. 
