\v 9 ¿Tienes tú \w brazo|strong="H2220"\w* \w como|strong="H3644"\w* Dios? ¿y tronarás tú con \w voz|strong="H6963"\w* \w como|strong="H3644"\w* él?
\m 
\v 10 Atavíate \w ahora|strong="H4994"\w* \w de|strong="H3847"\w* majestad y \w de|strong="H3847"\w* alteza: y \w vístete|strong="H3847"\w* \w de|strong="H3847"\w* \w honra|strong="H1935"\w* y \w de|strong="H3847"\w* \w hermosura|strong="H1926"\w*.
\m 
\v 11 \w Esparce|strong="H6327"\w* furores de tu ira: y \w mira|strong="H7200"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w soberbio|strong="H1343"\w*, y abátelo.
\m 
\v 12 \w Mira|strong="H7200"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w soberbio|strong="H1343"\w*, y humí­llalo, y quebranta \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w impíos|strong="H7563"\w* \w en|strong="H8478"\w* su asiento.
\m 
\v 13 \w Encúbrelos|strong="H2934"\w* \w a|strong="H3068"\w* \w todos|strong="H3162"\w* en el \w polvo|strong="H6083"\w*, venda sus \w rostros|strong="H6440"\w* en la oscuridad;
\m 
\v 14 \w Y|strong="H3068"\w* \w yo|strong="H3588"\w* \w también|strong="H1571"\w* \w te|strong="H3588"\w* \w confesaré|strong="H3034"\w* \w que|strong="H3588"\w* podrá salvarte tu \w diestra|strong="H3225"\w*.
\m 
\v 15 He \w aquí|strong="H2009"\w* \w ahora|strong="H4994"\w* behemot, al \w cual|strong="H5973"\w* \w yo|strong="H2009"\w* \w hice|strong="H6213"\w* \w contigo|strong="H5973"\w*; \w hierba|strong="H2682"\w* come \w como|strong="H5973"\w* buey.
\m 
\v 16 He \w aquí|strong="H2009"\w* \w ahora|strong="H4994"\w* \w que|strong="H4994"\w* su \w fuerza|strong="H3581"\w* está en sus \w lomos|strong="H4975"\w*, y su \w fortaleza|strong="H3581"\w* en el ombligo de su vientre.
\m 
\v 17 Su \w cola|strong="H2180"\w* \w mueve|strong="H2654"\w* \w como|strong="H3644"\w* un cedro, y los nervios de sus geni­tales son entretejidos.
\m 
\v 18 Sus \w huesos|strong="H6106"\w* son fuertes c\add omo\add* latón, y sus miembros como barras de \w hierro|strong="H1270"\w*.
\m 
\v 19 \w Él|strong="H1931"\w* \w es|strong="H1931"\w* \w la|strong="H1931"\w* \w cabeza|strong="H7225"\w* de \w los|strong="H1931"\w* \w caminos|strong="H1870"\w* de Dios: \w el|strong="H1931"\w* \w que|strong="H1931"\w* \w lo|strong="H1931"\w* \w hizo|strong="H6213"\w*, puede \w hacer|strong="H6213"\w* \w que|strong="H1931"\w* \w su|strong="H1931"\w* \w espada|strong="H2719"\w* \w a|strong="H3068"\w* \w él|strong="H1931"\w* \w se|strong="H1931"\w* acer­\w que|strong="H1931"\w*.
\m 
\v 20 \w Ciertamente|strong="H3588"\w* \w los|strong="H3605"\w* \w montes|strong="H2022"\w* pro­ducen hierba \w para|strong="H3588"\w* \w él|strong="H3588"\w*: \w y|strong="H3588"\w* \w toda|strong="H3605"\w* bes­tia del \w campo|strong="H7704"\w* \w retoza|strong="H7832"\w* \w allá|strong="H8033"\w*.
\m 
\v 21 \w Echaráse|strong="H7901"\w* \w debajo|strong="H8478"\w* \w de|strong="H8478"\w* las som­bras, \w en|strong="H8478"\w* lo oculto \w de|strong="H8478"\w* las \w cañas|strong="H7070"\w*, y \w de|strong="H8478"\w* los lugares húmedos.
