\v 18 \wj \+w Pero|strong="G1161"\+w* \+w las|strong="G3588"\+w* cosas \+w que|strong="G3588"\+w* \+w salen|strong="G1831"\+w* \+w de|strong="G1537"\+w* \+w la|strong="G3588"\+w* \+w boca|strong="G4750"\+w* provienen \+w del|strong="G3588"\+w* \+w corazón|strong="G2588"\+w* \+w y|strong="G1161"\+w* \+w contaminan|strong="G2840"\+w* \+w al|strong="G3588"\+w* hombre.\wj*   
\p
