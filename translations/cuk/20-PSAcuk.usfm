\id PSA - Kuna, San Blas - Bible -Panama 2014 (DBL -2014) 
\h Salmos 
\toc1 Bab-Dummadga-Namakleged-Garda 
\toc2 Salmos 
\toc3 Sal 
\mt1 BAB-DUMMADGA-NAMAKLEGED-GARDA 
\mt2 SALMOS 
\imt2 GEBE-SOGLENAID 
\imt1 Garda-nug 
\ip \it Bab-Dummadga-Namakleged-Garda.\it* Hebreo-gayabali, \it Tejilimʼye\it* bileged. A sogleged, “Bab-Dummad-nug-odummolegedye.” Wag-gayabardina, “Salmosʼye” bileged. 
\is1 Gardagi-sunmaklenaid 
\ip We-namaklemaladi, Babiloniaʼgi-galesbukwa-Jerusalénʼse-nonigusmaladgi welesnanaed. Judío-dulemarga, we-garda, namaked-gardaga gusad. Gannar-Bab-Dummadse-goled-neg-soblenaigusgu, we-namaklemaladgi namaksamalad. 
\ip We-garda akar-akar narmaklesad: Bab-nug-odummolegedgi, dule-abonolegedgi, wile-itolegedgi, isgued-barsogedgi, degi, igar-baigangi narmaklesbalid. 
\ip We-namakleged-garda David bur bulesaar narmaksad. Salomón we-garda narmaksamogad, degi, dule-baigan narmaksamogad. 
\ip We-namakleged-garda, garda-sogatar ilemakar naid: 
\io1 1. Garda-soggwen (Salmos 1:1–41:13) 
\io1 2. Garda-sogbogwad (Salmos 42:1–72:20) 
\io1 3. Garda-sogbaagwad (Salmos 73:1–89:52) 
\io1 4. Garda-sogbakegwad (Salmos 90:1–106:48) 
\io1 5. Garda-sogataled (Salmos 107:1–150:6) 
\ip Be itogua. 
\c 1  
\ms1 1. GARDA-SOGGWEN 
\mr (Salmos 1:1–41:13) 
\s1 Dule-nuegan, dule-isganamar 
\q1  
\v 1 Dule, dule-binsaed-isganaba nanadisulile, dule-isgudimaladba akadisulile, dule-Bab-Dummadgi-dododimalad-abargi gudisulile, 
\q2 we-dulegi, Bab-Jehová nued binsadiid. 
\q1  
\v 2 We-dule, Bab-Jehová-Igar-Maidgi bur wergudisunnad. 
\q2 A-igargi, mutikidbali, ibginedbali, egi binsadisunnad. 
\q1  
\v 3 We-dule, igi sapi diwar-naba aramakgwisdae, 
\q2 e-iba-sogedba sanmakdedae, deyobi gued. 
\q1 Bela na e-ibmar-imaked ega nueganbi naddaed. 
\b  
\q1  
\v 4 Dule-isganamardi, degisulid. 
\q2 Igi oros-uka burwaba mileddae, deyobi, dule-isganamardi guoed. 
\q1  
\v 5 A-dule-isganamarga igar-itolealile, gwen san-onogosurmalad. 
\q2 Degisoggu, dule-isganamar dule-nuegan-abargisii guosurmalad. 
\b  
\q1  
\v 6 Bab-Jehová dule-nued-damalad nue-bendakmaid. 
\q2 Dule-isganamardi, degi-bergudmaloed.\fig Dule-nue-daed, sapi diwar-naba aramakgwichiyob gued. (Salmo 1) |src="HK00339B.TIF" size="col" ref="Salmos 1:6" \fig* 
\c 2  
\s1 Bab-Jehová, rey-nug-imaksad 
\q1  
\v 1 ¿Ibiga dulemar-yar-baid-baidgi-bukwamalad, Bab-Jehováʼgi binsarsunna urwebukwa? 
\q2 ¿Ibiga dulemar Bab-Jehováʼgi-aibinedgi binsarsunna binsabukwa? 
\q1  
\v 2 Reymar-negsemamaid, Bab-Jehováʼgi aibitemalad. 
\q2 Dulemar-nuga-nikamalad, Bab-Jehováʼgi isdar-binsadmalad. 
\q2 Bab-Jehová-na-nug-imaksadgi aibitemarbalid. 
\q1  
\v 3 We-dulemar, weyob sogdemalad: “Anmar e-gangued obeloge, 
\q2 e-negsemaidgi anmar ollorgumala.” 
\b  
\q1  
\v 4 Bab-Jehová-Niba-Neg-Dakmaid ega alled, 
\q2 Bab-Dummad amargi dodoged. 
\q1  
\v 5 Bab-Jehová a-dulemarse urwed. 
\q2 A-dulemar, Bab-Dummad-urwedba abin gwakidmalad. 
\q1  
\v 6 Bab-Jehová weyob ega sogded: 
\q2 “Ani an-yar-islidikid-Siónʼye-nugadgi, an-rey an mesisad.” 
\b  
\q1  
\v 7 Bab-Jehová-Igar-Mesisad an soggwelo. 
\q2 Bab-Dummad weyob anga sogsad: 
\q1 “Be an-machi gued, 
\q2 emi-ibagi, an be-babga gunonikid. 
\q1  
\v 8 Anse be ibmar egise, 
\q2 ar bela dulemar-yar-baid-baidgi-bukwamalad an bega ukoed, 
\q2 yarmar-nanaid bela ugakaase an bega ukbaloed. 
\q1  
\v 9 Sabsur-gandikidba be negseoed, 
\q2 sianar-irgwensur-mamariddaedyobi, be a-dulemar-imakoed.” 
\b  
\q1  
\v 10 Reymar, degisoggu, wisigarmar, 
\q2 nue-binsaed-nikaa damalo. 
\q1 Dulemar-negsemamaid, ¡nue salakarmar! 
\q2 Bab-Jehová bega ibmar-sognaidba be damar. 
\q1  
\v 11 Bemar, Bab-Jehová-e-nug nue-itoakwaa odummomalo, 
\q2 ise-itoakwaa Bab-Jehová-mag-dakedgi be wergudii gumalo. 
\q1  
\v 12 Bab-Jehová-mer-urwega, E-Machi-urbalikwaa be nanamarsun. 
\q2 Ar Bab-Jehová bemarse-uludele, bemar sunna ese oburgwilemalad. 
\b  
\q1 ¡Bab-Jehová dule-egi-bensuli-nanamaladgi, nued binsadaed! 
\c 3  
\s1 Bab-Dummadse bensulidgi goled 
\d David e-machi-Absalón-idu-wakindigu, we-namaked narmaksad. 
\q1  
\v 1 ¡Bab-Jehová, an-isdarmalad dogdar mergued! 
\q2 ¡An-isdarmalad bukidar angi aibitemalad! 
\q1  
\v 2 An-isdarmalad bukidar an-annik sogmalad: 
\q2 “Bab-Dummad bendakosulid.” 
\b  
\q1  
\v 3 Bab-Jehová, bedi an-isdarmalad-idu, sigu-abgaedyob be an-irwa gwisguedid. 
\q2 Be, an-ganguedid. Be, an-niga-ogannogedid. 
\q1  
\v 4 Bab-Jehováʼse binnasur an goled. 
\q2 Na e-neg-islidikid-akale, an-abin-imaked. 
\b  
\q1  
\v 5 Ar Bab-Jehová an-edarbedsoggu, an dobsuli meged, nue an gabed. 
\q2 Neg-oibosale, bogidikidgi an gwisgued. 
\q1  
\v 6 Degisoggu, an-isdarmalad miliambe (10,000) an-ebiris-bukwamalad, an dobsulid. 
\q2 ¡Bab-Jehováʼye, wis be an-itoge! 
\b  
\q1  
\v 7 ¡Bab-Jehováʼye, be an-bendakdage! 
\q2 ¡Bab-Dummadye, an-isdarmaladgi be an-ollor-imakdage! 
\q1 An-isdarmalad-e-akugar be sarsodage, 
\q2 we-dule-isganamar-e-nugar be obatedage. 
\b  
\q1  
\v 8 Bab-Jehová, beginbi abonoleged danikid. 
\q2 ¡Be-sordamargi be nued-binsao! 
\c 4  
\s1 Bab-Dummadse wilesiid 
\d David we-namaked narmaksad. Namakmalad-e-iduedga soglenaid: 
\d We-namakleged, Neginotʼba namaklegoye. 
\q1  
\v 1 Bab-Dummad, igar-bulegan-idu be an-irwa-gwisguedid. 
\q2 An bese gotele, bitigi be an-itosana gadin. 
\q1 Bab-Dummadye, an suli-suli itoged, 
\q2 wis be an-bendake. 
\q1 Wile be an-dake. 
\q2 An bese-goled be an-itoge. 
\b  
\q1  
\v 2 Emide, ¿sanagwadse bemar, an-nug-oichodiidi, iemaloye be soge? 
\q2 ¿Sana be ibmar-igarga-gwen-guosulidgi-alamakdimaladi, be iemaloye soge? 
\q2 ¿Sana be gakan-igarba-nanamalad, be iemaloye soge? 
\b  
\q1  
\v 3 Be itomar, dule-Bab-Jehováʼba nue-nanadiile, Bab-Dummad, a-dulebina itogerba daed. 
\q2 A-ular, Bab-Jehováʼse an gotele, an-itodaed. 
\b  
\q1  
\v 4 Be sae-itoalile, nue salakarmar. Melle Bab-Dummadgi isgumalo. 
\q2 Mutik be gabesokalir, bogidik be-ulubgi, be ibmar-imaksadgi nue-binsamai samalo. 
\b  
\q1  
\v 5 Bab-Dummad-bese-ibmar-napiragwad-egismaidba Bab-Dummadga be ukmalo. 
\q2 Melle Bab-Jehováʼgi be bengumalo. 
\b  
\q1  
\v 6 Bukidar dulemar sogdidinanaed: 
\q2 “¿Wede doa anmarga ibmar-nued wis oyogoe?” 
\q1 Bab-Jehováʼye, wis be anmarga ibmar-nued oyoge, 
\q2 be-sabgued be anmarse-oyoge. 
\b  
\q1  
\v 7 Dulemar bukidar-masgunned-nikale, gobed-nikale, na weligwar itodidamalad. 
\q2 Bab-Dummad, bedi a-dulemarba bur bule weligwar-itogega be an-imaked. 
\b  
\q1  
\v 8 Bab-Jehová, ar bebi unnila an-edarbedisoggu, dobsulidgi an megidoed, 
\q2 bogidikidgi an gabidoed. 
\c 5  
\s1 Bab-Dummadse-goled, an-bendakye 
\d Namakmalad-e-iduedga soglenaid: Gar-gammuba namaklegoye. 
\d David we-namaked narmaksad. 
\q1  
\v 1 Bab-Jehováʼye, an bega ibmar-sogedi, be an-itoge. 
\q2 Nunmakedgi an bega ibmar-biedi, nue be an-itoge. 
\q1  
\v 2 Bab-Jehová, be an-Bab-Dummad gued, be an-rey gued. 
\q2 Ar an bese gornaisoggu, an bese wilenaidi, nue be itosunna. 
\b  
\q1  
\v 3 Bab-Jehová, wakudaryalaba an bese-goledi be an-itodaed, 
\q2 wakudaryalaba an-wile-naidi, an bega sognonidaed. 
\q2 Be-an-abin-imakedi, an edarbedidaed. 
\b  
\q1  
\v 4 Bab-Dummad, ar bedi ibmar-isgana abesulid, 
\q2 Dule-isgana be-walikaa gudii guosulid. 
\q1  
\v 5 Dule-san-dummarba-imakmalad, bese gwen dogosulid. 
\q2 Dule-ibmar-isgana-imakmalad, nue-sae be dakdaed. 
\q1  
\v 6 Dule-gakansamalad be obelogoed. 
\q2 Bab-Jehová, bedi dule-gindakmalad, dule-yardakmalad, nue-sae dakdaed. 
\b  
\q1  
\v 7 Bab-Dummad, ar bedi nue-wile-an-daksoggu, 
\q2 andi nabir bese-goled-negse dogsunnad. 
\q1 Nabir an be-neg-islidikidsik sindigar-ataksii 
\q2 an be-nug odummosunnad. 
\b  
\q1  
\v 8 Bab-Jehováʼye, an-isdarmalad an bukidar-nikadba be-igar-innikigwadba be an-nie. 
\q2 Be-Igar-Maid magar-dakega be an-imake. 
\b  
\q1  
\v 9 Dule-isganamar innikigwadba sunmaksurmalad, 
\q2 e-ulubgi ibmar-isgana-imakedginbi binsadimalad. 
\q1 Yamo dule-nug-odummogar sunmakmalad, 
\q2 yardakar emar-obelogega, guagwar bukwamalad. 
\b  
\q1  
\v 10 ¡Bab-Dummadye, a-dule-isganamar be sabsur-odurdake! 
\q2 Dule-isganamar yamo dule-yardaked-igar mesismalad. 
\q1 A-igar na dukin egi aibinega be imake. 
\q2 We-dulemar gannar-gannar ibmar-isgana-imakdimalad-ular, be obane. 
\q2 Ar ade, begi nue-gwisgusmalad. 
\b  
\q1  
\v 11 Dule-begi-bendakleged-amidimaladi, wergumarsun, 
\q2 degisadegu weligwar namakmarsun. 
\q1 Bab-Dummad, be amar-bendakdaed. 
\q2 Dule-be-sabgudimaladi, begi wergumarsun. 
\q1  
\v 12 Bab-Jehová, dule-ibmar-innikii-imakedgi be nued binsaoed. 
\q2 Bab-Jehová, be-sabedi dulega sigu-abgaedyob guoed. 
\c 6  
\s1 Bonigan-abalagi Bab-Dummadse goled 
\d David we-namaked narmaksad. Namakmalad-e-iduedga soglenaid: Neginotʼba-namakoye. 
\d We-namaked, Seminitʼye nugad. 
\q1  
\v 1 Bab-Jehováʼye, melle ise-urwaledgi be sabsur-an-odurdake, 
\q2 melle sae-itogedgi be sabsur-an-imake. 
\q1  
\v 2 Bab-Jehováʼye, wis be wile-an-dake, 
\q2 ar an boniganba nue negoebied. 
\q1 Bab-Dummadye, be an-bendake, 
\q2 ar an-abagan nue-bibichis itoleged. 
\q1  
\v 3 Bab-Jehováʼye, ¿sanase be an-bendaknonikoe? 
\q2 Emide, an nue-naibid-dummad itonaid. 
\b  
\q1  
\v 4 Bab-Jehováʼye, be sabed-nikarbadbali, wis be an-bendakdage, 
\q2 mer baisur be an-dake. 
\q1  
\v 5 Ar dule-burgwarmaladdi, bar begi binsamamaisulid. 
\q2 Ar neg-urbardi, ¿doa be-nug odummogoe? Gwen dule be-nug odummogosulid. 
\b  
\q1  
\v 6 Bela-bela an bodiidbali, gege an sagusad. 
\q2 Bane-bane mutikidbali gachiyala, an ise-ogormakar maidaed. 
\q2 An-ibyanisbali, an-gas-megedi dinnasurgus naidaed. 
\q1  
\v 7 An-isdarmalad-nukad, an-ibya an-ibe mommoleded. 
\q2 An-ibya, nunmakedbali, nue bar ataksurgusad. 
\b  
\q1  
\v 8 ¡Dule-isganamar! Be angi bangumala. 
\q2 Ar Bab-Jehová, an-bodiid itononikid. 
\q1  
\v 9 Bab-Jehová an ese wilesakwaa-gornaid an-itononikid. 
\q2 An-ese-gornaid an-itosad. 
\q1  
\v 10 Ar bela an-isdarmaladi, surbinsa-itodmaloed, 
\q2 an-isdarmaladi, bingegudmaloed. 
\q2 Bingegudedba wakitemaloed. 
\c 7  
\s1 Ega igar-nabogega Bab-Dummadse goled 
\d David, Benjamín-wagwa-Cus-ibmar-imaksadgi 
\d Bab-Jehováʼga Sigaiónʼgi namaksad. 
\q1  
\v 1 An-Bab-Dummad-Jehováʼye, be an-bendake, 
\q2 ar an begi bendakleged amied. 
\q1 ¡Dulemar-an-balegindimaladgi be an-bendake! 
\q2 ¡Amargi be an-ollor-imake! 
\q1  
\v 2 Ar be an-bendaksulile, ¿doa bar an-bendakosunna? 
\q2 Dule-baid an-bendaked sated. 
\q1 Ar igi achumigur dule-ichimake, 
\q2 deyobi, an-isdarmalad an-imakmaloed. 
\q1 Ar igi achumigur dule-gunne, 
\q2 deyobi, an-obelomaloed. 
\b  
\q1  
\v 3 An-Bab-Dummad-Jehováʼye, we-ibmar-soggwengi nosa be an-dakdibe: 
\q2 An ibmar-isgana imaksadibe, 
\q1  
\v 4 an-aigi an nue-yolesdibe, 
\q2 an-isdarad-ibe an yogasaar ibmar-susdibe, 
\q1  
\v 5 adi, an-isdarmalad an-baleginner, akarsurdo, 
\q2 an-isdarmalad an-bargado, 
\q1 dii-dii napagi an-oburgwedse angi annamardo. 
\q2 An-nug-dummad-nikad obelomalar, akarsurdo. 
\b  
\q1  
\v 6 Bab-Jehováʼye, be sae-itogedba an-isdarmalad-anse-urwebukwadgi be gwisgudage. 
\q2 Anga be igar nabodage. 
\q1 An-Bab-Dummadye, anba be nague, 
\q2 igar-innikigwadba be anga igar naboge. 
\q1  
\v 7 Bab-Jehováʼye, dulemar-baid-baid be-asabin-ambikuega be imake. 
\q2 Nibnega-akar a-dulemar-e-saila-dummadga be gue. 
\q1  
\v 8 Bab-Jehováʼye, be dulemarga igar itosoggu, 
\q2 an-ibmar-inniki-imakdiidba be anga igar itoge, 
\q2 an-nossulidba be anga igar naboge. 
\q1  
\v 9 Bab-Jehová, bedi Bab-Dummad-innikigwadid, 
\q2 bedi dule-binsaed bela baramied. 
\q1 Degisoggu, dule-isganamar-e-ibmar-isgana-imakdimalad be obeloge. 
\q2 Dule-nuegandi, melle be osikirmakega imake. 
\b  
\q1  
\v 10 Bab-Dummad, sigu-abgaedyob an-irwa-gwisguedid, 
\q2 Bab-Dummad, na dule-gwage-ulubgi-inniki-binsadimalad bendakedid. 
\q1  
\v 11 Bab-Dummad, dulega igar-itogedgine, innikigwadba ega igar nabiroged, 
\q2 bane-bane dule-isganamar sabsur-odurdaked. 
\b  
\q1  
\v 12 Ar dule-isganamar, na e-isguedga bukib-binsasulile, amar-idu, Bab-Dummad es-suid-e-nugar ebinoed, 
\q2 amar-idu e-warsi guagwar dakbaloed. 
\q1  
\v 13 Ar deyopira, Bab-Dummad ibmar-dule-gindakmalad guagwar urbisbalid, 
\q2 sigu-sooba-gamalad sobsabalid. 
\b  
\q1  
\v 14 Dule-isgana, igar-isganaginbi binsadaed, 
\q2 ibmar-isgana-imakega igar amidaed, 
\q2 geb igar-isgana imaknonidaed. 
\q1  
\v 15 Dule-isgana, yaa-matusur akwisad. 
\q2 A-yaa-matusulidgi na dukin argwanoed. 
\q1  
\v 16 Dule-isgana, na e-igar-isgana-imaked egi aibinoed, 
\q2 e-sabsur-urwed egi aibinoed. 
\b  
\q1  
\v 17 Bab-Jehová anga igar-inniki-nabosadba, an e-nug odummogoed. 
\q2 Bab-Dummad-Bur-Birigined-Jehováʼga, an namaked. 
\c 8  
\s1 Bab-Dummad-e-gangued, degi, dulemar-e-gangued 
\d David namaked narmaksad. Namakmalad-e-iduedga soglenaid: 
\d Igi uva-nis-egurelealir gar-ogorledae, deyob ogoloye. 
\q1  
\v 1 Bab-Jehová, be anmar-Dummad gued. 
\q2 Ibiyobi bela we-napneggine, be-nugdi dummarba gue. 
\q1 Bela be-ganguedi nibnegse-bakale, 
\q2 magar-yeerdaklege be nasiksad. 
\b  
\q1  
\v 2 Be-isdarmalad-begi-yolesad-ular, burwigan-namakedgi, mimmigan-namakedgi, be-nug-odummoged-igar be mesisad. 
\q2 Adi, be-isdarmalad, dule-begi-gwisgudimalad, be-abin gaya-maklegar sigegar. 
\b  
\q1  
\v 3 Bab-Dummad, mogir-billigi be-ibmar-nasiksad an nue dakdele, 
\q2 nii-naid an nue dakdele, 
\q2 niisgwamar-naid an nue-dakdebalile, 
\q1  
\v 4 Bab-Dummad, an binsaddaed: 
\q2 “¿Wede, dule ibusunna, egi be binsanonigu? 
\q2 ¿Wede, dule ibusunna, be akwenonigu?” 
\b  
\q1  
\v 5 Ar dule baliwiturmarba wis yaisaale be imaksad. 
\q2 Napneggi, dummadga-guega, gangued-yeerdakleged bela-bela-nikuega be nug-imaksad. 
\q2 Degi, nug-dummarba-nikuega be imaksabalid. 
\q1  
\v 6 Bela be ibmar-obinnisadgi gangued-nika-guega be dule-imaksad. 
\q2 Bela e-argan-yaurgi we-ibdurgan ega be uksad: 
\q1  
\v 7 Bela sibad-wawaadmar, bela moli-bebe-nikamalad, 
\q2 bela ibdurganmar-sapurba-bukwamalad. 
\q1  
\v 8 Bela nuumar, bela demar-wilaganba uamar-iirmakbukmalad, 
\q2 degi, muu-billigi, bela ibdurganmar-bukwamalad. 
\q2 Bela we-ibdurgangi gangued-nika-guega, be dule-imaksad. 
\b  
\q1  
\v 9 Bab-Jehová, be anmar-Dummad gued. 
\q2 Ibiyobi bela we-napneggine, be-nugdi dummarba gue. 
\c 9  
\s1 Bab-Dummadga dog-nuedye sogsad 
\d David we-namaked narmaksad. Namakmalad-e-iduedga-soglenaid: 
\d Gar-goledba namakoye. 
\q1  
\v 1 Bab-Jehováʼye, bela-belad an be-nug odummogoed. 
\q2 Bela be-ibmar-gegerdaklemalad-imakdiidgi an sunmakoed. 
\q1  
\v 2 Bab-Dummadye, begi an werguoed, begi an yeer itogoed. 
\q2 Bab-Dummad-Bur-Biriginedye, be-nuggi an namakoed. 
\b  
\q1  
\v 3 An-isdarmalad be-abin wakitemalad, 
\q2 amar yoledapmalad, amar be-abin bela burgwismalad. 
\q1  
\v 4 Be-ologanagi be sigisad, 
\q2 dulemarga innikigwadba be igar naboged. 
\q1 A-ulale, innikigwadba be anga igar nabosad, 
\q2 be anba nagunonikid. 
\b  
\q1  
\v 5 Bab-Dummad, dule-yar-baid-baidgi-bukwamaladse be sabsur-ulusad, 
\q2 dule-isganamar be obelosad. 
\q2 A-dule-isganamargi dulemar bipisaale bar binsaega be imakosulid. 
\q1  
\v 6 An-isdarmalad bela bergusmalad, 
\q2 dule-wargwensaale gwen gudii gussulid. 
\q1 E-neggweburmar bela napabi nagusad, 
\q2 bipisaale gwen bar egi binsalegosulid. 
\b  
\q1  
\v 7 Bab-Jehováʼdi dulemarga igar-itogega e-ologanagi sigisad. 
\q2 Bab-Jehováʼdi degisadegu maigu guoed. 
\q1  
\v 8 Bab-Jehová dulemarga innikigwadba igar naboged, 
\q2 degi, dulemarga igar-innikigwadba negseed. 
\b  
\q1  
\v 9 Bab-Jehováʼye, be neg-dukuedyob dule-mesagwar-imakledimaladga gued. 
\q2 Ibagan-suli-suli-itolegedgi, Bab-Jehováʼye, a-dulemarga be galu-gandikidyob gued. 
\q1  
\v 10 Bab-Jehováʼye, dulemar-be-amimaladi be wargwen bipisaale metedisulid. 
\q2 A-ular, dule-magar-be-dakmalad begi bensurmalad. 
\b  
\q1  
\v 11 Bab-Jehová, Sión-neggweburgi negdakmaid. 
\q2 A-Bab-Jehováʼga namakmar. 
\q2 E-ibmar-dummagan-imakedgi, dule-yar-baid-baidgi-bukmaladga be sunmakmar. 
\q1  
\v 12 Bab-Dummad, be dule-gindakmalad buged-mai-imakosurdeeye sogsulid, 
\q2 Bab-Jehová dule-wiledimalad-ese-gornaid nue itodaed. 
\q2 Amar-iegodeeye sogsulid. 
\b  
\q1  
\v 13 Bab-Jehováʼye, wile be an-dake. 
\q2 Nue be dakena, 
\q1 isdar-an-dakmalad nue an-wionanaid. 
\q2 Melle dulemar an-oburgwega be imake, 
\q1  
\v 14 adi, Jerusalén-neggwebur-dogedgi, dulemarga an be-nug-odummogega, 
\q2 degine, be an-bendakedgi an weligwar-itogegar. 
\b  
\q1  
\v 15 Dule-aku-be-dakmalad na dukin yardaklesmalad. 
\q2 Emar-gaega, saki-odukuar-nasismaladgi, na dukin e-nag galesmalad. 
\q1  
\v 16 Bab-Jehová-igar-innikigwadbi-imaked, bela nue-magar daksamalad. 
\q2 Dule-isganamardi, dukin e-ibmar-isgana-imaksadgi yardakledimalad. 
\q1  
\v 17 Dule-isganamar, bela burgwed-negse seledmaloed. 
\q2 Dule-yar-baid-baidgi-bukmalad Bab-Dummad-ieddamalad, 
\q2 amar neg-urba burgwed-negse seledmaloed. 
\b  
\q1  
\v 18 Ar dule-wiledimaladdi, be degisadegu iegosulid, 
\q2 dule-baidse-sabsur-wiledimalad be-ibmar-edarbedimalad, berguus be imakosulid. 
\b  
\q1  
\v 19 ¡Bab-Jehováʼye, nue be atake! 
\q2 ¡Dulemar melle begi-nakwed be imake! 
\q1 Dule-yar-baid-baidgi-bukmaladga be igar-itoge. 
\q2 A-dulemar be sabsur-odurdake. 
\q1  
\v 20 Bab-Jehováʼye, dulemar-e-niga be egwane. 
\q2 Dule-yar-baid-baidgi-bukmalad wisgued be imake, 
\q2 emarde, Bab-Dummadsurmarye, unnila dule-gumarye. 
\c 10  
\s1 Bab-Dummadse bendaklegega goled 
\q1  
\v 1 Bab-Jehováʼye, ¿ibiga be angi yoggus gudii? ¿Ibiga be an-idu dukue? 
\q2 An bonigan-abalagi-gunaidgi, aisaar an bebina bela-bela gudidaenad. 
\b  
\q1  
\v 2 Dule-isgana na-san-bule-bule-imakedgi, sabsur dule-wileged-baregindaed. 
\q2 Degi-inigwele, we-dule-isgana, na dukin e-ibmar-isgana-imakedgi yoleged. 
\q1  
\v 3 Dule-isgana, sulibinsa-ibmarbina-sogedgi na san-ogannodiid. 
\q2 Dule-isgana, dule-ibmarbina-suli-suli-itodimalad-e-nug ogannoged, 
\q2 Dule-isganadi, isdar be-daked. 
\q1  
\v 4 Bab-Dummadye, dule-isgana bule-bule-san-imakedbali, be-amisulid. 
\q2 Bipisaale begi binsasulid. 
\q1  
\v 5 Bela-ibmar-imakdele, ega ibmar-nueganbi naddaed. 
\q2 Bab-Dummad, we-dule-isgana, Be-Igar-Mamaidgi gwen binsadisulid, 
\q1 ar akusunna daked. 
\q2 Ar dule-isgana, mesagwar e-isdarmalad-imakdaed. 
\q1  
\v 6 E-gwagegi weyob binsadaed: 
\q2 “Dulemar gwen-an-oakalogosurye, 
\q1 bipisaale an boni nikuosurye, 
\q2 unnila, an weligwar gudii guoye.” 
\q1  
\v 7 E-sunmakedi, unnila dule-ukabsaedginbi sunmaked, 
\q2 gakansaedginbi sunmaked, 
\q1 dulemar-sabsur-imakedginbi sunmaked. 
\q2 E-gayaburba unnila emar-oakalogedginbi sunmaked. 
\q1  
\v 8 Dule-isgana emar-naibi-imakega, galimbaba gudidaed. 
\q2 Arbakee dulemar-argadidaed, emar-idu dukusidaed, 
\q2 adi, ukiar emar-oburgwegar. 
\q1  
\v 9 We-dule, igi achumigur dule-baisur-binsadiidgi-ichomakegala, e-dukued-yaba-dukusidae, 
\q2 dule-ganonikir, ebipiddae, 
\q2 deyobi, we-dule-isgana, emar-naibi-imakega gudiid.\fig Achumigur, dule-ichimaked. (Salmo 10:9) |src="CO00923B.TIF" size="col" ref="Salmos 10:9" \fig* 
\q1  
\v 10 Ar deyobi, dule-e-bendakedsuli-gudiidi, dule-isganase-galenonikile, ese nue sabsur-ibitoged. 
\q2  
\v 11 We-dule-isgana ulubgi binsaed: 
\q1 “Bab-Dummad we-ibmargi gwen binsamaisurye. 
\q2 We-ibmar-mer-dakegala, e-wagar biir imakdaye. 
\q2 Ar Bab-Dummad neg-gunaid gwen dakmaisurye.” 
\b  
\q1  
\v 12 ¡Bab-Jehováʼye, be dake! 
\q2 ¡Bab-Dummadye, be-gangued be oyoge! 
\q1 ¡Melle be dule-wilediid iege! 
\q2  
\v 13 ¿Ibiga we-dule-isganade, e-sunmakedgi mesagwar be-imakosunna? 
\q1 ¿Ibiga we-dule-isganade, ulubgi binsaosunna: 
\q2 “Bab-Dummad gwen anga akar sogosurye?” 
\b  
\q1  
\v 14 Bab-Jehováʼye, ar bedi bato neg-gunaid daksad, 
\q2 sabsur-ibitonanaid bato be daksad, 
\q2 nunmakedba-galitonanaid be daksad. 
\q1 Ar bedi, sogedba be we-ibmar nudakoed. 
\q2 Dule-ibmar-suli-gudimaladi, begi bensur gudimalad. 
\q2 Ar be, dule-sergan-sated-bendakedid. 
\b  
\q1  
\v 15 ¡Bab-Dummadye, dule-isgana-ibe be e-gangued-osuloge! 
\q2 ¡Dule-isgana e-isgued-imakedba be sabsur odurdake! 
\q2 ¡We-dulemar we-napneggi-obelogedse be imake! 
\q1  
\v 16 Bab-Jehováʼye, be degisadegu Reyga maid. 
\q2 Dulemar-aku-be-dakmaladdina, be-yargi bela obelolemaloed. 
\b  
\q1  
\v 17 Bab-Jehováʼye, dule-wilegana-bese-goled be itodaed. 
\q2 Dule-wilegana-e-niga be ogannodaed. 
\q2 Bese ibmar-egisder ega be ukdaed. 
\q1  
\v 18 Bab-Jehová dule-sergan-satedga, degi, dule-wiledimaladga, igar-innikigwad imakdaed, 
\q2 adi, dule-we-napnegginmaladi, melle bar emar-wiodii gumalagar. 
\c 11  
\s1 Dule-nued, Bab-Dummadgi bensulid 
\d David we-namaked narmaksad. Namakmalad-e-iduedga soglenaid. 
\q1  
\v 1 Bab-Jehováʼgi, an bendakleged amied. 
\q2 Degisoggu, ¿ibiga anga sogmalosunna, 
\q2 sikwiyob yalaganba be wakinye? 
\q1  
\v 2 Be dakmala, dule-isganamar e-warsi guagwar ganimalad, e-sigu guagwar warsigi-yoi ganimalad. 
\q2 Dule-gwage-innikii-gudimaladgi sigu-miega, negsichigi dukuar gwichimalad. 
\q1  
\v 3 Ar we-napneggi, igar-innikii-selemaid-bergudele, 
\q2 dule-innikidaed, geg bar ibmar imaked. 
\b  
\q1  
\v 4 Bab-Jehová, e-neg-islidikidgi maid. 
\q2 Bab-Jehová, nibneggi ologanagi siid, 
\q2 e-ibyagwar dulemar-ibmar-imaked nue-dakmaid. 
\q1  
\v 5 Bab-Jehová, dule-innikidaed, degi, dule-isganadaed bela baramied. 
\q2 Bab-Jehová, dule-sabsur-emar-imakdiidgi-wergudiid isdardaked. 
\q1  
\v 6 Bab-Jehová, dule-isganamargi, soo azufreʼba-mesa odegoed. 
\q2 Dule-isganamar bela burwa-ueregedba burgwemaloed. 
\q1  
\v 7 Bab-Jehová, dule-innikigwadid, igar-inniki-maid-sabedid. 
\q2 A-ulale, dule-inniki-nanadiiddi, Bab-Jehová-e-wagar dakoed. 
\c 12  
\s1 Bab-Dummadse bendakleged-egised 
\d David we-namaked narmaksad. Namakmalad-e-iduedga soglenaid: 
\d We-namakleged, Seminitʼba namaklegoye. 
\q1  
\v 1 Bab-Jehováʼye, be anmar-bendake. 
\q2 Dule-be-sogedba-nanamalad bergusad. 
\q2 We-napneggine, dule-napiragwad bar-daklesulid. 
\q1  
\v 2 Dulemar na muchub-muchub gakangi sunmakmalad, 
\q2 nue-nabiridyob sunmakmalad. 
\q1 Asginbi nued sunmakmalad, 
\q2 ulubgindi, emar-yardakedgi binsamalad. 
\b  
\q1  
\v 3 Bab-Jehováʼye, dule-nue-nabiridyob-sunmakmalad, bela be obeloge. 
\q2 Dule-san-dummarba-sunmakmalad, bela be osuloge. 
\q1  
\v 4 We-dulemar sogdimalad: 
\q2 “Sunmakedgi anmar dulemargi obinoed. 
\q1 Aga anmar gwabin-duku nikasursi. 
\q2 Anmar-gwabin-duku dule-baidgadsulid. 
\q1 ¿Degite, doa anmargi obinosunna? 
\q2 Dule anmargi-obined sate.” 
\b  
\q1  
\v 5 Emide, Bab-Jehová, bede soged: 
\q2 “Dule-e-bendaked-satemalad mesagwar-imaklediid-ular, an gwisguoye. 
\q1 Dule ibmar-sate-gudimaladba bela-belad-bodimalad, 
\q2 an bendakoye.” 
\b  
\q1  
\v 6 Bab-Jehová-gayaburba isedar-swilimakaledid. 
\q2 Igi mani swilimakar-imaklegega, soo-yagi gannar-gannar ilagugle (7) dulege, 
\q2 aba bur bule Bab-Dummad-gayaburba swilidik gued. 
\b  
\q1  
\v 7 Bab-Jehováʼye, bebi-unnila dule-isganamar-idu, be anmar-edarboed. 
\q2 We-dule-isganamar-idu, degisadegu, be anmar-irwa gwisguoed. 
\q1  
\v 8 Dule-isganamar anmar-ebirdiile, bee be anmar-edarboed. 
\q2 We-napneggi igar-isganamar bur yeerdaklealile, bee be anmar-bendakoed. 
\c 13  
\s1 Bab-Dummadga wilesakwaa namaked 
\d David we-namaked narmaksad. Namakmalad-e-iduedga soglenaid. 
\q1  
\v 1 Bab-Jehováʼye, ¿sana be angi wis binsanonikoe? 
\q2 ¿Sana be anse wis wagar oyononikoe? 
\q1  
\v 2 ¿Sana an bane-bane-surbinsa-itodiid anga berguoe? 
\q2 ¿Sana an ulubgi-nunmak-itodiid anga berguoe? 
\q2 ¿Sanadse an-isdarad angi obindii guoe? 
\b  
\q1  
\v 3 Bab-Jehováʼye, be an-Bab-Dummadid, wis be an-dake, 
\q2 wis be an-abin-imake, be anga niga-ogannoge. 
\q2 Deyob be imakele, an bar burgosulid. 
\q1  
\v 4 An-isdarad angi weligwar-itogosulid. 
\q2 Weyob sogosulid: “Anse galakusye.” 
\b  
\q1  
\v 5 Ar andi, be-sabgued-dummarba-nikadgi bensulid. 
\q2 Be-an-abonogedgi an weligwar itoged. 
\q1  
\v 6 Bab-Jehováʼye, an bega namaked, 
\q2 Be nued-angi-binsamaidba, an bega namaked. 
\c 14  
\s1 Dule-isganamar Bab-Dummad-obaned 
\d David we-namaked narmaksad. Namakmalad-e-iduedga soglenaid. 
\q1  
\v 1 Dule-binsaedsulidaed, weyob e-gwagegi sogdiid: 
\q2 “Bab-Dummad maisulid.” 
\q1 Dulemar nue-isgus gudimalad, unnila ibmar-isganabi imakdimalad. 
\q2 Dule-wargwensaale, ibmar-nued-imaked gudisulid. 
\b  
\q1  
\v 2 Bab-Jehová nibneg-akale, dulemar-napneggi-gudimalad dakmaid, 
\q2 abakale, dule-gwensak magar-neg-itoged gudiile, 
\q2 abakale, dule-gwensak magar-Bab-Dummad-dakbied gudiile. 
\q1  
\v 3 Degi-inigwele, dulemar Bab-Dummadgi bela bangus gudimalad, 
\q2 dule ibmar-nued-imaked gwen wargwensaale, gudisulid, 
\q2 bela nue isgus gudimalad. 
\b  
\q1  
\v 4 ¿Ar dule-isganamar na ibmar-isgana-imakdimalad, nue wismalansursi? 
\q2 Ar nue wismalanad. 
\q1 Emide, igi dulemar madu-gunmala, deyob an-dulemar ese dolediid. 
\q2 We-dule-isganamar, gwen bipisaagwar Bab-Jehováʼse gordisurmarbalid. 
\q1  
\v 5 Emisgindi, be dakmalana, emide, wawanmakbukwad. 
\q2 Ar Bab-Dummaddi dule-innikidamaladba gudisoggu, dule-isganamardi, dobgubukwad. 
\q1  
\v 6 Dule-isganamar dule-wilemalad-e-igar obured, 
\q2 degi-inigwele, dule-wilemaladdi Bab-Jehováʼgi bendaklegoed. 
\b  
\q1  
\v 7 Bitigi Bab-Jehová, Israel-dulemarga abonoleged-igar, Sión-yala-akale, barmialina gadin. 
\q2 Bab-Jehová na e-dulamar-galesbukwad, 
\q1 gannar na e-yarse-senonikile, Jacob-e-wagan wergudmaloed, 
\q2 Israel-dulemar weligwar itodmaloed. 
\c 15  
\s1 Bab-Dummadse-goled-neggi-gudimaloed 
\d David we-namaked narmaksad. 
\q1  
\v 1 Bab-Jehováʼye, ¿doa bese-goled-neg-selegedgi nabir mai guoe? 
\q2 ¿Doa be-yar-islidikidgi nabir gudii guoe? 
\q1  
\v 2 Unnila weyob-damaladbi gudii guoed: 
\q2 Dule-inniki-nanadiid, 
\q2 dule-igar-innikigwad-imakdiid, 
\q2 dule-napiragwadba-ibmar-soged. 
\q2  
\v 3 Dule-baidgi-wissur-gakansaed, 
\q2 dule-aimar-naibi-imakdisulid, 
\q2 dule-emar-mesagwar-imakdisulid. 
\q2  
\v 4 Dule, dule-Bab-Jehováʼse-obanlesad obanmogad. 
\q2 A-dule, Bab-Jehová-dobekwaa-nanadiid-e-nugdi ogannoged. 
\q2 Dule, ibmar-imakoye-sogsad, 
\q2 ega nuedga-guosur-inigwele, imakedse-daed. 
\q2  
\v 5 Dule, dule-baidga mani-uksale, 
\q2 e-gaka egi-onosulid. 
\q2 Dule, dule-ibmar-oakalossulidgi-aibinega 
\q2 dule-baiganse manigi-bakledisulid. 
\q3 Ar dule weyob-daedi, bipisaale gwen galakuosulid. 
\c 16  
\s1 Bab-Dummadgi an bensulid 
\d David namaked-Mictam narmaksad. 
\q1  
\v 1 Bab-Dummadye, be an-bendake, 
\q2 an begi dukued amidiid. 
\b  
\q1  
\v 2 Bab-Jehováʼga an sogsad: 
\q2 “Bebi unnila be an-Dummadga-guye, 
\q1 dule-baidgi ibnued an amisurye, 
\q2 unnila beginbi ibnued an amiye.” 
\q1  
\v 3 Dule-gwage-swilidikmalad we-yargi-bukmaladgi an yeer-itoged. 
\q2 Dule-gwage-inniki-gudimaladgi an yeer-itoged. 
\q1  
\v 4 Dulemar ibmar-bab-dummadyob-imaklemaladga nue-alamakdimaladdi, dukin nunmaked-onasguega imakdimalad. 
\q2 Andi, ibmar-bab-dummadyob-imaklemaladga ablis-uklegedi, bipisaale gwen ukosulid. 
\q2 An-gwabindukubela, gwen e-nug biosulid. 
\b  
\q1  
\v 5 Bab-Jehová, bela ibmar-nueganba 
\q2 be anga ibmar-biriginedga gued. 
\q1 Be angi doggus ise-nued-binsamaid. 
\q2 An-san-burba, bela be-argan-yaurgi siid. 
\q1  
\v 6 Napa-nuegan be anga uknonikid, 
\q2 napadar-nued be anga daksad. 
\b  
\q1  
\v 7 Bab-Jehová-anga-binsaed-ukmaid-nug an odummogoed. 
\q2 E-binsaedi, mutikidba an-ulubgi, anga ibmar-soge an itodaed. 
\q1  
\v 8 Gusgu Bab-Jehováʼse an idaked, ar anba-gudiguad. 
\q2 Ar an-yalaba gwichigusoggu, dule gwen an-oakalogosulid. 
\b  
\q1  
\v 9 A-ulale, an-gwagegi an yeer-itoged. 
\q2 Bela an-ulubgi an weligwar itoged. 
\q2 Bela an-san-burba begi-bensuli gudii guoed. 
\q1  
\v 10 Gwen be an-san-burba neg-uangi oyogsaosulid, 
\q2 ar be-mai-gwage-swilidikid-e-mui gwen neg-uangi onunsaega be imakosulid. 
\q1  
\v 11 Igar-nuedba-gudigued be anga oyosad, 
\q2 be-asabinni bela-belad weligwar-gudii be an-imaked. 
\q2 Be-yalaba degisadegu-gudiid an yeer-itoged. 
\c 17  
\s1 Bab-Dummadse goled, an-bendakye 
\d David, Bab-Dummadse goled. 
\q1  
\v 1 Bab-Jehováʼye, an bese napiragwadgi wilesagwa-goledi, wis be an-itoge. 
\q2 An bese-binnasuli-goledi, be an-itoge. 
\q1 An bese-goledi, nue be itoge, 
\q2 yamo an be-yardaknaisulid. 
\q1  
\v 2 Bab-Dummadye, be ibmar-innikigwad-magar-daked-ular, 
\q2 bee be an-bendakedga gue. 
\b  
\q1  
\v 3 Be an-binsaed nue-dakdaed. 
\q2 Mutikidba an nue-ulubgi-binsamaid be baramidaed. 
\q1 Nue be an-wilubdaksad, ibmar-isgana be angi amissurgusad. 
\q2 An na sogsad, an-sunmakedgi an begi isguosurye. 
\q1  
\v 4 Be-igar-nued-mesisad-ular, dulemar-baigan-daedyobi an dasulid, 
\q2 ibmar-isgana-imakedgi an nanadisulid. 
\q1  
\v 5 Be-Igar-Maidba bur an nanadiid, 
\q2 a-igargi gwen an bangudisulid. 
\b  
\q1  
\v 6 Bab-Dummad, ar be an-abin-imakdasoggu, a-ular, an bese binnasuli goled. 
\q2 Wis be an-itoge, an bese-goled nue be itoge. 
\q1  
\v 7 ¡Be-sabed-sunsoged be anga oyoge! 
\q2 Dulemar begi-bendakleged-amididamaladi, 
\q1 dulemar-isganamarse baregilledidamaladi, 
\q2 a-dulemar, be-ganguedgi be bendakdaed. 
\q1  
\v 8 Ar dule-isganamar angi dummad-yolenanaisoggu, 
\q2 igi be-ibyagwag na be akwe, deyobi, be an-akwemoga. 
\b  
\q1  
\v 9 Ar dule-an-oburgwebimalad bato an-walik guakwaa gudimarsoggu, 
\q2 igi gannir e-sakan-urba na e-mimmigan odukue, deyobi, be an-odukumoga. 
\b  
\q1  
\v 10 A-dulemar, dule-wiledaked satemalad, 
\q2 unnila na san-dummarba-imakedgi sunmakmalad. 
\q1  
\v 11 An-isdarmalad-an-baregindimalad an-walikagusad, 
\q2 angi ukiar sabsur-yolemalaga, guakwaa gudimalad. 
\q1  
\v 12 Achumigur mas-gabiedyobi, an-isdarmaladde anbina gudimalad. 
\q2 Achumigur e-mas-gaega balidakagwar maidaedyobi, anbina gudimalad. 
\b  
\q1  
\v 13 Bab-Jehováʼye, ginebinne, an-isdarmalad-abin be nodage, 
\q2 an-isdarmalad be obelodage. 
\q1 Bab-Dummadye, be an-abonogega, 
\q2 be-es-suidgi an-isdarmalad be oburgwedage. 
\q1  
\v 14 Bab-Jehováʼye, be-gangued-nikadba, an-isdarmaladgi be an-onoge. 
\q2 We-dulemar unnila we-napnegginbi ibmar-nika gudimalad. 
\b  
\q1 We-dule-isganamar, be-ibmar-nuegan nue-nika gudimalad. 
\q2 E-mimmigan, e-babgan-sorba, a-ibmar-nuegan abingadimarmogad. 
\q2 Degine, e-wagangarmoga bela ibmar-nuegan obine abingadimarmogad. 
\q1  
\v 15 Bab-Jehováʼye, andi, ibmar-oakalossurye be angi-sogsadba, an be-wagar dakoed. 
\q2 Sikwas an be-wagar-daksale, bato gusbin an itogoed. 
\c 18  
\s1 Bab-Jehováʼga dog-nuedye sogleged 
\r (2 Samuel 22:1-51) 
\d Bab-Dummad-e-mai-David, Bab-Jehováʼga we-namaked narmaksad. 
\d Deunni, Bab-Jehová Saúlʼgi David-bendaknonigu, degi, e-isdarmaladgi bendaksabargu. 
\d David weyob Bab-Jehováʼga sogded: 
\q1  
\v 1 Bab-Jehováʼye, nue an be-sabed, 
\q2 be an-niga-ogannoged maid. 
\b  
\q1  
\v 2 Bab-Jehováʼye, be an-akwasailaga gued. 
\q2 Be an-garganguedsoggu, an begi bensulid. 
\q1 Bab-Jehováʼye, be an-neggandikidid. 
\q2 Sigu-abgaedyob be an-idu bonigan-irwa gwisgued. 
\q1 Be-garganguedgi be an-bendaked. 
\q2 Bebi unnila bonigan-idu an-odukued-birigined maid. 
\q1 Bab-Jehováʼye, be an-ollor-imakedid. 
\q2 Bonigangi be an-ollor-imakdiid. 
\q1 Ar an bese gotele, 
\q2 an-isdarmaladgi-nakwega be an-imaked. 
\q1  
\v 3 Bab-Jehováʼye, be-nug an ogannoged, 
\q2 ar be-nug innikigwadba odummoleged maid. 
\q2 Bab-Jehováʼye, an-isdarmaladgi an bendaklegoed. 
\b  
\q1  
\v 4 Burgwed-igar nue an-ebiris gunaid. 
\q2 Diwar-dummad-nomaiyobi, burgwed angi gwisgunonikid. 
\q1  
\v 5 Bato an gachiyala megis-itoged, 
\q2 gwillo angi-biles-maiyob an itoged, 
\q1 gwen bar san-onoged an itosulid. 
\q2 Burgwed-igar, an-idu saki-milesnaiyob naid. 
\b  
\q1  
\v 6 An surbinsa-itodiidgi Bab-Jehováʼse an gote gusad, 
\q2 Bab-Dummadse ise-gollar an imaksad. 
\q1 Agine, e-neg-akale, an-itononikid. 
\q2 Bab-Jehováʼse-an-gornaidi, e-uayagwar an-itosad. 
\b  
\q1  
\v 7 Bab-Jehová-uludgua, neg giglimakded, 
\q2 yar-sailagan-mamaidse-bakale, giglimakded. 
\q1  
\v 8 Bab-Jehová-bunnodedbali waa bupurmakded, 
\q2 e-gaya-yaba soo-gwabunyeded, ginnitibi soo-mialid. 
\b  
\q1  
\v 9 Bab-Jehová mee mogir-egasad, 
\q2 geb abali aidealid, mogir-gudureged-birgi aidealid. 
\q1  
\v 10 Bab-Jehová baliwitur-querubinʼye-nugad-birgi-sii, mogir-imbaba nadapid. 
\q2 Burwa-gandik-gormaidba gukumai gualid. 
\q1  
\v 11 Bab-Dummad neg-gudureged-abargi nadapid. 
\q2 E-irwa mor-dummad-naiyob mogir nagusad. 
\q2 We-mogir dii-dummad-widanikiyob dakle sigisad. 
\q1  
\v 12 Bab-Jehová-sabsur-gadedbali, mogirmar aisakided, 
\q2 mogirmar dii-akwamaryob mileded, 
\q2 sogunmar ginnitibi mileded. 
\q1  
\v 13 Bab-Jehová nibneg-akale, mogirmar-dii-akwamaryob-milemaid-abalagine, 
\q2 sogunmar-ginnitibi milemaid-abalagine, mala-gollomakmaiyob binnasuli sunmakded. 
\q1 Bab-Jehová-Bur-Birigined-e-sunmaked bela neg-gaded. 
\q2  
\v 14 Bab-Jehová sigu-milegeyob e-isdarmaladgi mar-odealid. 
\q1 Bab-Dummad e-isdarmalad-oduurmaksad, 
\q2 e-isdarmalad-oabarmakega imaksad. 
\b  
\q1  
\v 15 Bab-Jehová, be-uludedbali demar-urba-napa-naid mag-dakle gunonikid. 
\q2 Bab-Jehová, be-bunnodedbali, napasaila daled gunonikid. 
\b  
\q1  
\v 16 Bab-Jehová nibneg-akale, anse e-argan oyononikid. 
\q2 An demar-wilagi-gundilenai an-ononnonikid. 
\q1  
\v 17 Bab-Jehová an-isdarad-buledgi an-bendaksad. 
\q2 Bab-Jehová isdar-an-dakdimaladgi, an-ollor-imaknonikid. 
\q2 An-isdarmalad-angi-obinmaladgi an-abonononikid. 
\q1  
\v 18 Boniganba-an-galitonaidgi an-isdarmalad angi gwisgunonikid. 
\q2 Agine, Bab-Jehová an-bendaknonikid. 
\q1  
\v 19 Bab-Jehová wile-an-dakedbali, an-bendaknonikid, 
\q2 neg-nuedgi an-ogwisgunonikid. 
\b  
\q1  
\v 20 Bab-Jehová an ibmar-nued-imakedba anga ibmar-nued uked. 
\q2 Ibmar-isgana-imakdisulidba nued angi binsaed. 
\q1  
\v 21 Ar Bab-Jehová-Igar-Maidba an gudiid, 
\q2 ibmar-isgana an imakdisulid, 
\q2 Bab-Dummadgi an bangudisulid. 
\q1  
\v 22 Ade, bela e-igar-uksad an nue-gasa gudiid, 
\q2 e-Igar-Maidgi an bangudisulid. 
\q1  
\v 23 Bab-Jehováʼga sogedba an gudiid, 
\q2 ibmar-isgana-imaklegedgi an na san-bargas gudiid. 
\q1  
\v 24 Bab-Jehová an ibmar-nued-imakedba anga ibmar-nued uked. 
\q2 Ibmar-isgana-imakdisulidba nued angi binsamaid. 
\b  
\q1  
\v 25 Bab-Jehová, dule-beba-bane-bane-inniki-nanadiidgine, egi be bane-bane inniki damogad. 
\q2 Bab-Jehová, dule-igar-innikigwadba-nanadiidga, ega be inniki ibmar-imaked. 
\q1  
\v 26 Bab-Jehová, dule-bega-gakansasulidga, be gakansasurmogad. 
\q2 Be dule-emar-yardakedgardi, e-igar e-ibe be obured. 
\q1  
\v 27 Bab-Jehová, dulemar na-san-bipi-imakdimalad, bonigangi-obinega be imaked. 
\q2 Dule-na-san-dummarba-imakdimaladdina, be sabsur-wioged. 
\q1  
\v 28 Bab-Dummad-Jehová, be dula-gudii an-imaked. 
\q2 Bab-Jehová, an bonigan-abalagi-gudiidgi, san-burba-dula-gudii be an-imaked. 
\q1  
\v 29 Bab-Jehová, be-an-bendakedbali, sordamar-danar-bila-onomalad an ogilogoed. 
\q2 An-Bab-Dummad, be-an-bendakedbali, neggweburmar-galu-matusulid-nikad an obelogoed. 
\b  
\q1  
\v 30 Bab-Dummad-e-ibmar-imakedi innikigwad imaked, e-gayaburba sunsogedid. 
\q2 Bab-Jehová dule-egi-dukumaladga sigu-abgaedyob gued. 
\q1  
\v 31 ¿Doa Bab-Jehováʼyob Bab-Dummadga mai? Dule sate. Unnila Bab-Jehováʼbi maid. 
\q2 ¿Doa Bab-Dummadyob-gangued mai? Dule sate. Unnila Bab-Jehováʼbi maid. 
\q1  
\v 32 Bab-Jehováʼbi unnila anga gargangued ukmaid, 
\q2 Bab-Dummadbi dobsuligudii an-imaked. 
\q1  
\v 33 Bab-Dummad goe-sapur-abarmakedyob an-oabarmaked, 
\q2 yar-billiganaba geg baparmakega an-imaked.\fig Goe-sapur (Salmo 18:33) |src="LB00034B.TIF" size="col" ref="Salmos 18:33" \fig* 
\q1  
\v 34 Bab-Jehová an-surgan ogannoged, 
\q2 adi, an nabir bila-onogegar. 
\q1 Bab-Jehová an-swidamar ogannoged, 
\q2 adi, nabir warsi-esgoro-gordikidbiid an dopee imakegar. 
\q1  
\v 35 Sigu-abgaedyob be an-irwa gwisgued, 
\q2 be-garganguedgi be an-bendaked. 
\q1 Be nued-angi-binsaedba nasguega be an-imaked. 
\q2  
\v 36 Bab-Jehová, an nabir nanaega, melle an aimukuega, anga be neg-ollor-dummad nasiksad. 
\b  
\q1  
\v 37 An an-isdarmalad-baregitegusgua, an indaksasulid, an bargadapid. 
\q2 Bela an-isdarmalad-obelogedse an imaksad. 
\q1  
\v 38 Bela-bela an an-isdarmalad naibi-imaksad, 
\q2 degisoggu, gege bar angi gwisgu gusmalad. 
\q2 An-isdarmalad anse nue-galakusmalad. 
\q1  
\v 39 Bab-Jehová, bila-onogega be an-ogannosad, 
\q2 an-isdarmalad anse-ibitogega be imaksad. 
\q1  
\v 40 An-isdarmalad anse-galakudedba, wakinnega be imaksad. 
\q2 Deyob isdar-an-dakdimalad an obelosad. 
\q1  
\v 41 An-isdarmalad aisaar dule-e-bendakegala, emarse gornanai gusmalanad, 
\q2 dule-e-bendaked sate gusmalad. 
\q1 Bab-Jehováʼse gochamalanad, 
\q2 Bab-Jehováʼdi abin-imaksasulid. 
\q1  
\v 42 An-isdarmalad anse sanyob ichi-ichi gusad. 
\q2 Amar ukub burwa-abin-mileddaedyob anse gusmalad, 
\q2 sabsur-enalenai anse gusmalad. 
\b  
\q1  
\v 43 Bab-Jehová, dule-angi-urwedimaladgi be an-bendaksad, 
\q2 dule-yar-baid-baidgi-bukwamalad-e-dummadga be an-imaksad. 
\q2 Dulemar-aku-an-dakmalad an-maiga gunonimalad. 
\q1  
\v 44 Ibmar-imakoye an sogsale, a-dulemar, yog anba ibmar-imakar damalad. 
\q2 Wemar-Israel-dulesurmaladi, an-nug odummodimalad. 
\q1  
\v 45 We-Israel-dulesurmaladi, an-gaya-itosale, nig-argwate damalad, 
\q2 e-dukued-yaba-bukwa-noarmalale, wawanmakdani noardamalad. 
\b  
\q1  
\v 46 ¡Bab-Jehová dula-mai! 
\q2 ¡Bab-Jehová, unnila bebi an-bendaked maid! 
\q2 ¡Be-nug an odummosun! 
\q1 Bab-Jehová, be an-abonogedid. 
\q2 Be-nug bela-bela odummolesun. 
\q1  
\v 47 Bab-Dummad anga an-isdarmalad-buged-mai imaksad, 
\q2 Bab-Dummad, dule-yar-baid-baidgi-bukmalad an-maiga-gumalaga anga imaksad. 
\b  
\q1  
\v 48 Bab-Dummadye, an-isdarmalad-angi-gwisguargua, be an-abonononikid. 
\q2 An-isdarmaladgi-obinega be an-imaksad, 
\q2 dule-ursilimaladgi be an-ollor-imaksad. 
\b  
\q1  
\v 49 Degisoggu, Bab-Jehová, Israel-dulesurmalad-abargi an be-nug ogannoged, 
\q2 Be-nug-odummogegala an namaked. 
\b  
\q1  
\v 50 Bab-Jehová, e-rey bela-bela e-isdarmaladgi-obinega na imaked. 
\q2 Na nug-imaksa-gudiidga, e-sabgued oyoged. 
\q1 Davidʼga, degi, e-waganga, e-sabgued oyoged. 
\q2 Degisadegu, e-sabgued ega oyodii guoed. 
\c 19  
\s1 Bab-Dummad-neg-obinnisad 
\d David we-namaked narmaksad. Namakmalad-e-iduedga soglenaid. 
\q1  
\v 1 Mogir-naidi, Bab-Dummad-e-gangued-yeerdaklegedgi sunmaknaid. 
\q2 Mogir-billi-aradgi bela-ibmar-naidi, Bab-Dummad-e-ibmar-obinnisad oyonaid. 
\b  
\q1  
\v 2 Bela-ibmar-naidi, bane-bane ibginedbali, Bab-Dummad-e-gangued-yeerdaklegedgi na sunmaknanaid, 
\q2 Bela-ibmar-naidi, bane-bane mutikidbali, Bab-Dummad-e-gangued-yeerdakleged na barsognanaid. 
\q1  
\v 3 We-ibmarmar duleyob-sunmaksur-inigwele, 
\q2 ibmar-bisurmar-inigwele, e-gaya-goled-itolesur-inigwele, 
\q1  
\v 4 we-ibmarmar-naid-e-sunmakedi, napneggi bela itoleged, 
\q2 bela napneg-dirbir-naid-ugakaase warmaked. 
\b  
\q1  
\v 5 Bab-Dummad dad-ibelerga mogir-billigi neg-nasiksad. 
\q2 Ar igi machered-ome-nikusad neg-oibosale, e-gabedneggi weligwar-noardae, 
\q2 deyobi, dad-ibeler wakudaryalaba noardaed. 
\q1 Ar Igi dule-abarmaked abarmaksokalir, yeer-itodae, 
\q2 deyobi, dad-ibeler nakwiardaed. 
\q1  
\v 6 Dad-ibeler mogir-billi-nagagi nakwidagogu, mogir-billi-bergunaidse argwandapdaed. 
\q2 Dad-ibeler-e-ueregedgi ibdula gwen dukuosulid. 
\b  
\q1  
\v 7 Bab-Jehová-Igar-Maidi, napiragwadid, 
\q2 dule-burba-ogannogedid. 
\q1 Bab-Jehová-Igar-Maidi, sunsogedid, 
\q2 egi geg benguleged. 
\q1 Bab-Jehová-Igar-Maidi, 
\q2 dule-binsaedsulidaed binsaed-ibedga imaked. 
\q1  
\v 8 Bab-Jehová-Islidik-Igar-Mesisad innikigwadid, 
\q2 gwage-weligwar dule-saed. 
\q1 Bab-Jehová-e-Igar swilidikidid, 
\q2 magar-ibmar-itoge dule-imaked. 
\q1  
\v 9 Bab-Jehová-dobee-nanaed-igar swilidikidid, 
\q2 degisadegu mai guoed. 
\q1 Bab-Jehová-igar-naboged, napiragwadid, 
\q2 bela innikigwadbiid. 
\q1  
\v 10 Bab-Jehová-e-Igar orba bur bule nuedid, 
\q2 or-nuedba bur bule e-bina sogleged. 
\q1 Bab-Dummad-e-Igar achanisba bur bule ochigwad, 
\q2 achanis-aryomaidba bur bule osidikid. 
\q1  
\v 11 Be-Gayaburba anga iduakwaa ibmar-soged: 
\q2 “Nue salakarye.” 
\q1 Ar dule a-Gayaburbaba ibmar-imakele, 
\q2 bukidar ibmar-nuegan nikuoed. 
\b  
\q1  
\v 12 ¿Doa e-nodiid na magar-itoge? 
\q2 Bab-Jehováʼye, ibugi an begi nodidibe, an na wissulid. 
\q2 Agi be an-ollorsae. 
\q1  
\v 13 Deginbali, an yamo-begi-yoledaedgi, be an-ollorsabali. 
\q2 We-isgued mer angi obined be sae. 
\q1 Adi, dulemar bar angi sunmakosulid, 
\q2 bar an isgued-dummad imakosulid. 
\b  
\q1  
\v 14 Bab-Jehová, be an-edarbedid, 
\q2 be an-odukuedid. 
\q1 Degisoggu, an-sunmaked be yeer-itosana gadin, 
\q2 ulubgi-an-binsaed be yeerdaksana gadin. 
\c 20  
\s1 Boni-dummagangi-obinega Bab-Dummadse goled 
\d David we-namaked narmaksad. Namakmalad-e-iduedga soglenaid. 
\q1  
\v 1 Dobedba be suli-suli itogele, Bab-Jehová be-itogena gadin. 
\q2 Jacob-e-Bab-Dummad-nuggi, be bendaklegena gadin. 
\q1  
\v 2 Bab-Jehová e-neg-islidikid-akale, bega bendakleged barmidagena gadin. 
\q2 Bab-Dummad Sión-yar-akale, be-bendakena gadin. 
\q1  
\v 3 Ega be ibmar-ukedi, Bab-Dummad bela insaena gadin, 
\q2 ega be ibmar-ogumakar-ukedi, be-abin nuedgi abingaena gadin. 
\b  
\q1  
\v 4 Be ibmar-abediidbali, Bab-Dummad bega ukena gadin. 
\q2 Be ibmar-imakedgi-binsaedi, bega bela nueganbi guena gadin. 
\q1  
\v 5 Boni-dummagangi be obichale, anmar weligwar-itogedba oimakdemaloed. 
\q2 Anmar-Bab-Dummad-nuggi, olo-bander omemmermakdemaloed. 
\q2 Bab-Jehováʼse be ibmar-egichisadi, bela bega sogedba imakena gadin. 
\b  
\q1  
\v 6 Ar emigindi an wisdo, Bab-Jehová, e-nuggi-rey-nugsalegaled bendakoed. 
\q2 Bab-Jehová e-ganguedgi, bila-onolegedgi, rey-nakwemai-guega imakoed. 
\q2 Bab-Jehová e-nibneg-islidikid-akale, rey-abinsaoed. 
\q1  
\v 7 Dulemar gwenna-gwenna unnila moli-ur-bila-onomaladginbi bensurmalad, 
\q2 baigandi e-molimarginbi bensurmarmogad. 
\q2 Anmardina, unnila anmar-Bab-Dummad-Jehováʼgi bensurmalad. 
\q1  
\v 8 We-dulemardi nue geg gugus galakudmalad. 
\q2 Anmardina, amba Bab-Jehováʼgi-bensulidba ganna gudimalad. 
\b  
\q1  
\v 9 Bab-Jehováʼye, sorda-bila-onomaladgi, rey-nakwega be imako. 
\q2 Bab-Jehováʼye, anmar bese gotele, be anmar-abinsao. 
\c 21  
\s1 Bab-Dummad Rey-David-nakwega imaksad 
\d David we-namaked narmaksad. Namakmalad-e-iduedga soglenaid. 
\q1  
\v 1 Bab-Jehová, be-ganguedgi rey weligwar itoged. 
\q2 E-isdarmaladgi-nakwega be imaksadba, rey nue-weligwar itoged. 
\q1  
\v 2 Bab-Jehová, e-ulubgi ibmar-abediid ega be uksad. 
\q2 Ibmar-bese-egichisadi, mer an ega gwen ukodeeye be sogsasulid. 
\q1  
\v 3 Bab-Jehová, reygi be nued binsasad. 
\q2 E-nonogi, gurgin-olobiid ega be sisad. 
\q1  
\v 4 We-reyde, san-burba-dula-gudigued bese egichisad. 
\q2 Suitii degisadegu dula-gudiguega be imaksad. 
\q1  
\v 5 Bab-Jehová, be rey-bendakedba, rey bila-ononanaidgi-nakwega be imaksad. 
\q2 Be-bendakedba, e-gangued dummarba naded. 
\q1 Be-bendakedba, e-nug nue be odungusad. 
\q2 Bela-bela e-gangued-yeerdakleged reyga be uksabalid. 
\q1  
\v 6 Bab-Dummad, reygi nuedbi degisadegu be binsamaid. 
\q2 Eba be gudiidbali, rey weligwar itodaed. 
\b  
\q1  
\v 7 Bab-Jehová-Bur-Birigined-e-sabgued geg bergusoggu, 
\q2 rey a-Bab-Jehováʼgi bensulidbali, gandik megoed, onolegosulid. 
\b  
\q1  
\v 8 Bab-Jehová, be-ganguedgi bela be-isdarmalad bese galegoed, 
\q2 bela begi gwisgudidimalad bese galebaloed. 
\b  
\q1  
\v 9 Bab-Jehová, be nonikile, be-isdarmalad sooga be obinyoed. 
\q2 Bab-Jehová, be ulude-sogele, igi soo bela ibmar-obelodae, 
\q1 deyobi, bela be-isdarmalad bese bergumaloed, 
\q2 bela bese girgumaloed. 
\q1  
\v 10 Bab-Dummad, bela we-napneggi be-isdarmalad-e-mimmigan be osulogoed, 
\q2 dulemar-abargi bela e-anagan be sate imakoed. 
\q1  
\v 11 Amba akar be-imakbimalandibe, amba gwen be-oakalogosurmalad. 
\q2 Ibmar-isgana-imakega igar-amimardibe, gwen imakosurmalad. 
\q1  
\v 12 Be-warsi be-isdarmaladgi be oyodogu, 
\q2 be-abin yogasaar duurmakdemaloed. 
\b  
\q1  
\v 13 ¡Bab-Jehováʼye, be-nug-odummolegega be-gangued be oyoge! 
\q2 ¡Be-ganguedgi namakar anmar be-nug odummomaloed! 
\c 22  
\s1 Nunmaked-abalagi Bab-Dummad-nug odummoged 
\d David we-namaked narmaksad. Namakmalad-e-iduedga soglesad: 
\d We-namaked Ajelet-Saharʼye-nugadba namaklegoye. 
\q1  
\v 1 Bab-Dummadye, ¿ibiga be an-obacha? 
\q2 Be an-bendakegala, ¿ibiga be angi dikasur-gunai? 
\q2 ¿Ibiga an-gormaknaid gwen be itosuli? 
\q1  
\v 2 Bab-Dummadye, ibginedba an bese gornadaenad, 
\q2 gwen be an-abin-imakdasulid. 
\q1 Mutikidba an bese gornadabalinad, 
\q2 gwen be an-abin-imakdasurbalid. 
\q2 An obunnodisulidba nue-geggus itolegusad. 
\b  
\q1  
\v 3 Be dule-islidikidid, 
\q2 Israel-dulemar bega namakmalad. 
\q1  
\v 4 Anmar-dadgan begi bensurgusmalad. 
\q2 Begi-bensurgusmaladba be bendaknonikid. 
\q1  
\v 5 Bese-gochamaladba be bendaknonikid. 
\q2 Begi-bensurgunonimargu, be obinge-imaksasulid. 
\b  
\q1  
\v 6 An dulesuliyob itoleged, 
\q2 napa-nus-musgimakdiidyob itoleged. 
\q1 Dulemar ibmar-dodogedga an-imaknanaid, 
\q2 bela dulemar isdarsun an-dakmalad. 
\q1  
\v 7 An-dakarmalale, anga alliardamalad. 
\q2 Anga akar-akar gunanai damarbalid, 
\q2 nono ege-ege gunanai damarbalid. 
\q1 Weyob sogmalad: 
\q1  
\v 8 “Bab-Jehováʼgi bensurye-sogdiid, 
\q2 degite, Bab-Dummad e-bendakdado. 
\q1 Bab-Dummadgi-wergudiiye-sogdiid, 
\q2 degite, Bab-Dummad-e-sunnagwad we-ibmargi e-ollor-imakdado.” 
\b  
\q1  
\v 9 Bab-Dummadye, sapidukugi-an-maigu, bee be an-odenonikid. 
\q2 An-nan-nukugi nue-obunnogega be an-imaksabalid. 
\q1  
\v 10 Bab-Dummadye, sapidukugi-an-maigu, be nue an-akwisad. 
\q2 Amba sapidukugi-an-maigu, bato be an-Bab-Dummadid. 
\q1  
\v 11 Bab-Dummadye, mer wargwen be an-mete, 
\q2 ar an surbinsa itoged, 
\q2 ar dule-an-bendaked gwen nikasulid. 
\b  
\q1  
\v 12 An-isdarmalad an-ebiris gudimalad, 
\q2 Basán-moli-bebe-nikad-ursirmaladyobi an-ebiris gudimalad. 
\q1  
\v 13 Igi-achumigur masbina uurmaknagusdae, 
\q2 igi-san-gasale, ichimaknagusdae, 
\q2 deyob, an-isdarmalad angi gwisgunonimalad. 
\q1  
\v 14 Dii-napagi-eolenaiyob bela an-san na itoged, 
\q2 bela an-garmar nue-gwatiris itolebalid. 
\q1 Igi-baka-gwallu soo-abin daluddae, 
\q2 deyob, an-ulubgi an-gwage nade an itoged. 
\q1  
\v 15 Dobedba bela an-gaya dinguded. 
\q2 An-gwabinse-bakale, gege bar banamakgusad. 
\q2 Napa-urba bato ber an megisayob na itoged. 
\q1  
\v 16 Dule-isganamar achu-soemaladyob an-ebiris gunanaid. 
\q2 Bela an-argan, an-nag-matarse-bakale, uudu imaksamalad. 
\q1  
\v 17 An-garmar daled daklegusad. 
\q2 An-isdarmaladi an-indaknanaisulid, 
\q2 an-ebiris an-dakbukwad. 
\q1  
\v 18 An-mormar mimismarsunnad, 
\q2 an-mor-suega, egi wilubdaknanai gusmalad. 
\b  
\q1  
\v 19 Bab-Jehováʼye, be an-niga-ogannogedid. 
\q2 ¡Mer be angi bangue! ¡Gwae be an-bendakdage! 
\q1  
\v 20 Mer es-suidse-oburgwilegega be an-imake. 
\q2 Dule-achumaryob-gudimaladgi be an-bendake. 
\q1  
\v 21 Achumigur-nono-wawaadyob-gudimaladgi be an-bendake. 
\q2 Moli-bebe-nikad-ursirmaladyob-gudimaladgi be an-ollor-imake. 
\b  
\q1  
\v 22 Bab-Jehováʼye, an-gwenadganga an begi sunmakoed. 
\q2 Dulemar-onmaked-abargi an be-nug-odummogoed. 
\q1  
\v 23 Bemar, Bab-Jehová-dobekwaa-gudimalad, Bab-Jehová-e-nug odummomar. 
\q2 ¡Jacob-e-wagan! Bab-Jehová-magar-dakdii nanamar. 
\q2 ¡Israel-e-wagan! Bab-Jehová-e-nug odummomar. 
\q1  
\v 24 Bab-Jehová, dule-wileged-e-naibi-itodiid baisur-daksulid, wagar-biria daksulid. 
\q2 We-dule-ese-gollalile, abin-imaked. 
\q1  
\v 25 Bab-Jehová, be-dulamar-onmaked-abargine, 
\q2 be-nug-odummogega be an-imaked. 
\q1 An bega ibmar-imakoye-sogsadi, 
\q2 dulemar-be-nug-odummodimalad-asabin an bega imakoed. 
\q1  
\v 26 Dule-wilemalad nue immeledmaloed. 
\q2 Dule-Bab-Jehová-amidimalad, Bab-Jehová-e-nug-odummodimalad, e-ulubgi weligwar-itodmaloed, 
\q2 deyob sadegu gudmaloed. 
\q1  
\v 27 Bela we-napneggi-dulemar-yar-baid-baidgi-bukwamalad, dulemar-ablis-akar-akar-bukwamalad-ugakaasega, Bab-Jehová-ebinsadmaloed, 
\q2 Bab-Jehováʼse gannar aibirnonimaloed, sindigar abin ambikunonimaloed. 
\q1  
\v 28 Ar Bab-Jehová bela we-napneg ganikid, 
\q2 bela dulemar-bukwad, e-argan-yaurgi gudidiid. 
\b  
\q1  
\v 29 Dule burgwesuli geg gued. 
\q2 Degisoggu, bela we-napneggi ibmar-bukidar-nikagudimalad, dulemar-burgwedani-gudimalad, 
\q1 Bab-Jehová-asabin sindigar sigmaloed, 
\q2 e-nuggi iba onomaloed. 
\q1  
\v 30 Bela mimmigan-danimalad, Bab-Jehová-e-nug odummomaloed. 
\q2 Yoedse-danimalad, Bab-Jehová-e-nug-odummodii gumaloed. 
\q1  
\v 31 Amba-yoo-dulemar-gwalulemaladga soglemogoed, 
\q2 Bab-Jehová ibmar-innikigwad imakmaiye, 
\q2 degi, ibmar-dummagan oyomaiye. 
\c 23  
\s1 Bab-Jehová an-edarbedid 
\d David we-namaked narmaksad. 
\q1  
\v 1 Dule-sibad-wawaad-edarbedyobi, Bab-Jehová, an-edarbed gued. 
\q2 Unniguar ibmar-nika an-imaked.\fig Dule-sibad-wawaad-edarbed. (Salmo 23:1-3) |src="LB00001B.TIF" size="col" ref="Salmos 23:1" \fig* 
\q1  
\v 2 Igi sibad-wawaad gagan-ara-aradgi obunnomegisdae, 
\q2 deyobi, Bab-Jehová egi-obunnogega an-imaked. 
\q1 Degi, igi dule dii-boo-naidse sibad-wawaad-niddae, 
\q2 deyobi, Bab-Jehová neg-bogidikidse an-niddaed. 
\q1  
\v 3 Bab-Jehová an-san-burba anga ogannodaed. 
\q2 Igar-innikimaladba an-seddaed. 
\q2 Mer e-nug-isguega, deyob an-imakdaed. 
\b  
\q1  
\v 4 Ar neg-gudureged-sunnasulid-imbaba an nadapile, amba an dobguosulid. 
\q2 Bab-Jehová, ar be anba gudisoggu, an akar-guosulid. 
\q1 Be-suar-gaapoled an-niga-ogannoged, 
\q2 dobsuli an-imaked. 
\b  
\q1  
\v 5 Bab-Jehová, be an-isdarmalad-asabin, mas-bur-nued be anga ukdaed. 
\q2 Be-nonikidi nued-an-be-dakye be anga-sogega, gwallu-wawad an-nonogi be eodaed. 
\q1 Degi, igi gobed noggi-engudele, aryomaidae, 
\q2 deyobi, an-ulubgi ise-weligwar an itodaed. 
\b  
\q1  
\v 6 Bab-Jehová, nue-napira bane-bane an-burgwedse wile be an-dakdii guoed, 
\q2 an-burgwedse be angi nued-binsadii gubaloed. 
\q2 Geb Bab-Jehová-neggine, degisadegu an maiguoed. 
\c 24  
\s1 Bab-Dummad napneg-naid-e-ibedid 
\d David we-namaked narmaksad. 
\q1  
\v 1 Bela we-napneg-naidi, bela egi ibmarmar-bukwadi, Bab-Jehováʼgadid. 
\q2 Bela yalagan-nanaidi, dulemar-egi-bukwadi, bela Bab-Dummadgadbiid. 
\q1  
\v 2 Bab-Jehová, demar-naidgi napaneg onakwisad, 
\q2 dii-wilagangi napaneg nasiksad. 
\b  
\q1  
\v 3 ¿Doa Bab-Jehová-yarse nakoe? 
\q2 ¿Doa Bab-Jehováʼse-goled-neg-islidikidgi gudiguoe? 
\q1 Unnila weyob-gudimaladbi gudii guoed: 
\q2  
\v 4 Dule-ibmar-nueganbi-imaked, 
\q2 dule-gwage-swilidikid, 
\q2 dule-ibmar-bab-dummadyob-imaklemaladse-gordisulid, 
\q2 yamo-ibmar-ise-sogar-imakdisulid, 
\q3 amarbi unnila, Bab-Jehováʼse-goled-negse dogoed. 
\b  
\q1  
\v 5 Dule-deyob-daedgi, Bab-Jehová ise-nued-binsaoed, 
\q2 Bab-Jehová-e-abonogedid ega nuedgi igar-nabogoed. 
\q1  
\v 6 Bab-Dummad, dule-be-amidimaladi, weyob damalargebed, 
\q2 dulemar Jacob-e-Bab-Dummad-dakbi-gudimaladi, weyob nanamalargebed. 
\b  
\q1  
\v 7 Yawagak-dummagan, be argamarsun, 
\q2 yawagak-degisadegu-gwichimalad, be argamarsun, 
\q2 we-yawagakgi, Rey Gandikidba-Yeerdakleged dogesokalid. 
\b  
\q1  
\v 8 ¿We doawa, Rey Gandikidba-Yeerdakleged? 
\q2 We-Rey, Bab-Jehová-Dule-Gandikidid, dule-buledid. 
\q2 Bab-Jehová bila-onogedgi dule-buledid. 
\b  
\q1  
\v 9 Yawagak-dummagan, be argamarsun, 
\q2 yawagak-degisadegu-gwichimalad, be argamarsun, 
\q2 we-yawagakgi Rey Gandikidba-Yeerdakleged dogesokalid. 
\b  
\q1  
\v 10 ¿We doawa, Rey Gandikidba-Yeerdakleged? 
\q2 We-Rey, Bab-Jehová-Bela-Gangued-Nika-Maidid. 
\q2 We, Rey Gandikidba-Yeerdaklegedid. 
\c 25  
\s1 Bab-Dummad be an-bendake 
\d David we-namaked narmaksad. 
\q1  
\v 1 Bab-Jehováʼye, an be-bensuli 
\q2 an bese goled. 
\q1  
\v 2 An-Bab-Dummadye, an begi bendakleged amied, 
\q2 mer bingeguega be an-imake. 
\q2 ¡An-isdarmalad mer angi-dodoged be imake! 
\q1  
\v 3 Ar begi-bendakleged-amimalad bipisaar bingeguosulid, 
\q2 dulemar igarsuli emargi-gwisgudimaladdi bingegumaloed. 
\b  
\q1  
\v 4 Bab-Jehová, Be-Igarmar be anga oyoge, 
\q2 Be-Igarmargi be an-odurdake. 
\q1  
\v 5 Be-Igar-innikigwadba be an-nide, 
\q2 a-Igargi be an-odurdake. 
\q1 Bedi, an-Bab-Dummad-an-abonogedid, 
\q2 andi, gusgu beginbi bendakleged amied. 
\b  
\q1  
\v 6 Bab-Jehová, be-ebinsao, be wile-dule-dakedid, be dule-sabguedid. 
\q2 Weyob be-daedi, anga be oyodiguad. 
\q1  
\v 7 An sapingwaun isgudigusaddi, an begi-yolesaddi, mer be ebinsao. 
\q2 Bab-Jehová, be-wile-dule-dakedba, wile be an-dako. 
\q2 Bab-Jehová, ar bedi dule-nuedid. 
\b  
\q1  
\v 8 Bab-Jehová dule-nuedid, dule-innikigwadid, 
\q2 a-ular, dule-isganamarga igar-maid-imakega oyoged. 
\q1  
\v 9 Bab-Jehová igar-innikigwadba dulemar-san-bipi-imakdimalad nied, 
\q2 Bab-Dummad e-igargi dulemar-san-dummarba-imakdisurmalad odurdakbalid. 
\q1  
\v 10 Bab-Jehová-Igar-Mesisadba-ibsadimaladga, Bab-Jehová-Igar-Islidikid-Mesisadba-nanadimaladga, 
\q2 bela Bab-Jehová-e-Igarmar, sabgued-igalad, napiragwad-igalad. 
\b  
\q1  
\v 11 Bab-Jehová, na be-nug-sabedba, 
\q2 an-nue-isgusadi, be anga osuloge. 
\q1  
\v 12 Bab-Jehová, dule-e-dobee-nanadiidga oyogoed, 
\q2 biti-igarba nanaoe. 
\q1  
\v 13 A-dule, nued-gudii guoed, 
\q2 e-wagandi nainumar gamaloed. 
\q1  
\v 14 Bab-Jehová dulemar-e-nug-odummodimaladbo walikaa gued, 
\q2 amarga e-igar-mesisad sogbalid. 
\q1  
\v 15 Ar Bab-Dummaddi emar-yamoged-igargi an-ollorsaed. 
\q2 A-ular, Bab-Jehováʼginbi an ataked. 
\b  
\q1  
\v 16 Bab-Jehováʼye, be wile-an-dake, 
\q2 andi walagwen gudiid, an wile itodiid. 
\q1  
\v 17 Bab-Jehováʼye, an-suli-suli-itoged bur bule gangumaid. 
\q2 An-bukib-binsadiid, be anga osuloge. 
\q1  
\v 18 Bab-Jehováʼye, an-ulubgi-naibi-itoged be dake, 
\q2 an boniganba-galitodiid be dake. 
\q2 Bela an-isgued be anga elie. 
\q1  
\v 19 Bab-Jehováʼye, be dake, ibiyobi an-isdarmalad mergusa, 
\q2 bela-bela nue-isdar an-dakmalad. 
\q1  
\v 20 ¡We-dulemar-idu be an-odukue! 
\q2 ¡We-dulemargi be an-ollorsae! 
\q1 Mer bingegued be an-imake, 
\q2 ar andi begi bensulid. 
\q1  
\v 21 An-ibmar-oakalossulid, an-inniki-daedi, 
\q2 an-bendakedga gued. Ar andi begi bensulid. 
\b  
\q1  
\v 22 ¡Bab-Dummadye, Israel-dulemar suli-suli-itogedgi, be bendake! 
\c 26  
\s1 Innikidaedgi-sunmaklenaid 
\d David we-namaked narmaksad. 
\q1  
\v 1 Bab-Jehováʼye, an-akar-akar-gudisulid be oyoge. 
\q2 Begi an bengussulid, 
\q2 begi gwen an bangussulid. 
\q1  
\v 2 Bab-Jehováʼye, be an-wilubdake, 
\q2 an-ulubse be an-dake, 
\q1 bela an-binsanaid be dake, 
\q2 an-gwage-naid bela ulubse be dake. 
\q1  
\v 3 Be-sabed an nue wisid, 
\q2 an be-igar-napiragwadba nanadiid. 
\b  
\q1  
\v 4 Dule-galagwensurdamaladbali an nanadisulid, 
\q2 wagar-darbodamaladbali an sigdisurbalid. 
\q1  
\v 5 Dule-galagwensurdamalad an isdarsun-daked, 
\q2 dule-isganamar an-aiga an imakdisulid. 
\b  
\q1  
\v 6 An ibmar-isganase-achadisulidba, an-argan swilidik gued. 
\q2 Agala, an sunna nabir be-ibmar-ogumakleged-aila-ebirdii gued. 
\q1  
\v 7 Bab-Jehová, agi be-nug-odummogegala, an binnasur namakdii guoed, 
\q2 be-ibmar-dakledisulid-imaksad-barsogegala, an binnasur gordii guoed. 
\b  
\q1  
\v 8 Bab-Jehová, bese-gorleged-neggi-be-maidbina an nue-soged, 
\q2 be-gargangued-oyomaid-negbina an nue-soged. 
\q1  
\v 9 An burgwisale, dule-galagwensulid-abargi, dule-gindakmalad-abargi, 
\q2 mer megega be an-imako. 
\q1  
\v 10 Ar unnila, we-dulemar ibmar-isganabi imakdimalad, 
\q2 emar-yardakedginbi binsadimalad, 
\q2 manigi emar-binsaed-gaed gudimalad. 
\b  
\q1  
\v 11 Bab-Jehováʼye, andi innikigwadba gudiid. 
\q2 Be an-bendake, wile be an-dake, 
\q2  
\v 12 ar an inniki nanadiid. 
\q1 Bab-Jehová, dulemar-onmakmalad-abargi, 
\q2 an be-nug-odummodii an guoed. 
\c 27  
\s1 Bab-Jehová an-gwallu-meegwadid, an-abonogedid 
\d David we-namaked narmaksad. 
\q1  
\v 1 Bab-Jehová anga burba-dulad ukedid, an-abonogedid. 
\q2 ¿An doa dobguosunna? 
\q1 Bab-Jehová an-gandikidga gued. 
\q2 ¿An doase gwayosunna? 
\q1  
\v 2 Dule-isganamar an-obelogega angi gwisguarmargu, an-isdarmalad an-oburgwega angi gwisguarmargu, 
\q2 aka bur amar burgwismalad. 
\q1  
\v 3 Ar amba sordamar-bila-onoged, an-ebiris-bukwa-inigwele, andi an dobguosulid. 
\q2 Amba angi bila-onolealile, andi an bukib-binsaosulid. 
\b  
\q1  
\v 4 Bab-Jehováʼse unni ibmar-soggwen an egichisad, 
\q2 abi an abeged: 
\q1 E-neggi-degisadegu-gudigued an abeged. 
\q2 Adi, an Bab-Jehová-e-yeerdakleged dakega, 
\q2 e-neggi ese gordii gubaligar. 
\b  
\q1  
\v 5 Ar Bab-Jehová, ibagan-bulegangi na ese-goled-neggi an-odukuoed, 
\q2 na e-neg-megedgi an-odukuoed, 
\q2 akwasaila-birgi an-ogwichoed. 
\b  
\q1  
\v 6 A-sorbali, an-isdarmalad-an-ebiris-bukwamaladgi-nakwega an-imakoed. 
\q2 Ese-goled-neggi, an e-nug odummogoed, 
\q2 Bab-Jehováʼga andi namakoed. 
\b  
\q1  
\v 7 ¡Bab-Jehováʼye, an bese-goled, be itoge! 
\q2 ¡Be wile-an-dake, be an-abinsae! 
\q1  
\v 8 An-gwage anga-soge an itoged: “Be Bab-Jehová-amie.” 
\q2 Bab-Jehová, an be-amied. 
\q1  
\v 9 ¡Bab-Jehováʼye mer be angi dukue! 
\q2 ¡Mer be isdar-itogedgi be an-obane! Ar be an-bendakedid. 
\q1 Bab-Jehová an-abonogedye, mer be walagwen an-obege, 
\q2 mer be an-mete. 
\b  
\q1  
\v 10 Ar amba an-bab, degi, an-nan an-obachale, 
\q2 Bab-Jehováʼdi an-suoed. 
\b  
\q1  
\v 11 Bab-Jehová, an-oburgwebimalad-ulale, be-igarba be an-nide, 
\q2 igar-nueganba be an-idue. 
\q1  
\v 12 Bab-Jehová, an-isdarmaladga mer be an-urmake, 
\q2 ar gakansaar-emar-barsogmalad, emar-sabsur-imakmalad, angi gwisgunanaid. 
\b  
\q1  
\v 13 Degisoggu, an nue-wisimakaled, 
\q2 an we-napneggi-gudiidgi Bab-Jehová-dulemargi-nued-binsamaid an dakoed. 
\b  
\q1  
\v 14 ¡Bab-Jehováʼgi mer be bengue! 
\q2 ¡Be gangue! ¡Be niga-gandik sae! 
\q2 ¡Eye, Bab-Jehováʼgi mer be bengue! 
\c 28  
\s1 Bab-Dummad ese wilesakwaa-goled itoged 
\d David we-namaked narmaksad. 
\q1  
\v 1 Bab-Jehováʼye, an bese gole, 
\q2 ar bedi an-bendakedga gued. 
\q1 Bab-Dummadye, melle be an-itosuli gue. 
\q2 Be an-itosulile, bato dule-burgwarmaladba, e-galuse-nadapiyob an guoed. 
\q1  
\v 2 Bab-Jehováʼye, an bese wilesakwaa-gotele, 
\q2 bitigine, be an-itosana gadin. 
\q1 Bab-Dummadye, an-bendakega an bese-gotele, 
\q2 an bese-golega be-Neg-Ise-Islidikidsik argan onakwidele, bitigine, be an-daksana gadin. 
\b  
\q1  
\v 3 Bab-Jehováʼye, dule-isgudimaladba melle be sabsur-an-wiogo, 
\q2 dule-ibmar-isgana-imakdimaladba, melle be sabsur-an-imako. 
\q1 We-dulemar, unnila asgi dule-baiganga nueganbi sunmakdidamalad. 
\q2 E-gwage-ulubgindina, egi isdar-binsadidamalad. 
\q1  
\v 4 Dule-isgudimalad e-ibmar-isgana-imakedba, e-galagwensuli-nanaedba, be buged imake. 
\q2 Dule-isgudimalad e-ibmar-galagwensuli-imakedba, be buged sae. 
\q1  
\v 5 Ar Bab-Jehová-ibmar-imaksadgi bar binsasurgusmarsoggu, 
\q2 Bab-Jehová-ibmar-imaksad baisur-dakarmarsoggu, 
\q1 Bab-Jehová bela a-dulemar obelogoed, 
\q2 baligannarse imakosulid. 
\b  
\q1  
\v 6 Bab-Jehová-nug odummolesun, 
\q2 an ese wilesakwaa-goled an-itosad. 
\q1  
\v 7 Bab-Jehová, an-ogannogedid, 
\q2 sigu-abgaedyob an-irwa-gwisguedid. 
\q1 Bela-belad gwage-ulubgi an egi bensulid, 
\q2 Bab-Jehováʼgi an bendaklesad. 
\q1 An-gwage-ulubgi, bela-belad-weligwale an itoged, 
\q2 an-namakedgi dog-nuedye an ega soged. 
\b  
\q1  
\v 8 Bab-Jehová, na e-mimmiganga dule-gandikidga gued, 
\q2 Bab-Jehová, na e-nuggi rey-nugsalegaledga abonoged-gandikidga gued. 
\q1  
\v 9 Bab-Jehováʼye, be-dula be abonoge, 
\q2 be-mimmigangi be ise-nued binsae. 
\q1 Sibad-wawaad-edarbed e-sibad-edarbedyobi, be-mimmigan be edarbe, 
\q2 degisadegu bendakdii be gusun. 
\c 29  
\s1 Bab-Jehová-e-gangued-yeerdakleged 
\d David we-namaked narmaksad. 
\q1  
\v 1 Bemar baliwiturmar, Bab-Jehová-e-nug odummomar, 
\q2 Bab-Jehová-e-ganguedgi, e-yeerdaklegedgi be sunmakmar. 
\q1  
\v 2 Bab-Jehová, Bab-Dummad-gued-ulale, e-nug be odummomar, 
\q2 Bab-Jehová-e-neg-islidikidgi, be Bab-Dummad-nug ogannomar. 
\b  
\q1  
\v 3 Bab-Jehová-sunmakedi muu-billigi gollomakemaid. 
\q2 Bab-Dummad-Bela-Gangued-Nikad gollomakemaid. 
\q2 ¡Bab-Jehová muu-billi-dummad-birgi negsemaid! 
\b  
\q1  
\v 4 Bab-Jehová-sunmaked dutusur sunmaked, 
\q2 Bab-Jehová-sunmaked dutusur goled. 
\q1  
\v 5 Bab-Jehová-sunmaked iksiwar-bibisged. 
\q2 ¡Líbano-Yar-e-iksiwarmar Bab-Jehová-sunmakedba bibisged! 
\q1  
\v 6 Bab-Jehová, Líbano-yar, Sirión-yar ogiglimaked. 
\q2 Moli-bebe-nikad-sapingana-ichomakeyob Bab-Jehová we-yarmar-oichomaked. 
\q1 Moli-bebe-nikad-sapurbarmalad-ichomakeyob Bab-Jehová we-yarmar-oichomaked. 
\q2  
\v 7 Bab-Jehová-sunmaked ginnitibi milemaid. 
\q1  
\v 8 Bab-Jehová-sunmaked nega-dulesulidgan ogiglimaked, 
\q2 ¡Bab-Jehová nega-dulesulidgan-Cadesʼye-nugad ogiglimaked! 
\q1  
\v 9 Bab-Jehová-sunmaked sapi-encinaʼmar bibisged, sapurmar swanga nasiked. 
\q2 Bab-Jehováʼse-goled-neggi bela-dulemar Bab-Dummad-nug odummomalad. 
\b  
\q1  
\v 10 Bab-Jehová dii-barigan-e-sailaga gued, 
\q2 Bab-Jehová bela negsemai degisadeguoed. 
\q1  
\v 11 Bab-Jehová na e-dulemarga gangued ukoed, 
\q2 Bab-Jehová e-dulemarga bela neg-bogidikid nasiked. 
\c 30  
\s1 An-wile-itoged, weligwaledga be imaksad 
\d David, Bab-Dummadse-goled-neg-nugsalegega namaked narmaksad. 
\q1  
\v 1 Bab-Jehová, an be-nug ogannoged, 
\q2 ar be an-bendaksad. 
\q2 An-isdarmalad mer angi wergumalaga be imaksad. 
\q1  
\v 2 An-Bab-Dummad-Jehová, an bese gochagu, 
\q2 be an-nudaknonikid. 
\q1  
\v 3 Bab-Jehová, an burgwedani-maigu, 
\q2 be an-bendaknonikid. 
\q1 Burba-dulad be anga uksad. 
\q2 Mer burgwarmalad-abargi-megega, be gannar an-ogwisgusad. 
\b  
\q1  
\v 4 Bemar Bab-Dummad-e-sordagan, Bab-Jehováʼga be namakmar, 
\q2 e-nug-islidikid be ogannomar. 
\q1  
\v 5 Bab-Dummad uludele, unnila sikwas-urwed. 
\q2 Ar nued-emargi-binsaeddina, degisadeguad. 
\q1 Ar mutikidba, boed nagunonidibe, 
\q2 neg-oibosardi, wergued nagunonikoed. 
\b  
\q1  
\v 6 Anga ibmar-nasgumaigu, an weyob sogsagusad: 
\q2 “Bipisaale dule an-osikirmakosurye.” 
\q1  
\v 7 Bab-Jehová, ar be-nued-angi-binsaedba, yar-dummad-siidyobi, ganna be an-osisad. 
\q2 Be angi aibategua, suli-suli an itonaded. 
\b  
\q1  
\v 8 Bab-Jehová, an bese goled, 
\q2 Bab-Dummadye, an bese ise-wilegar goled. 
\q1  
\v 9 Ar an burgwisale, 
\q2 ¿ibu-ibmar-nued egi amilegoe? 
\q1 An neg-uanse diglenader, 
\q2 ¿ibu-ibmar-nued egi amilegoe? 
\q1 ¿Ar dule-burgwaledde be-nug odummogoe? 
\q2 ¿Ar dule-burgwaledde be-igar-innikigwad barsogoe? 
\q1  
\v 10 Bab-Jehováʼye, be an-itoge, wile be an-dake. 
\q2 Bab-Jehováʼye, ¡be an-bendake! 
\b  
\q1  
\v 11 Bab-Dummad, an-gwage-naibi-itonaid, 
\q2 be weligwar imaknonikid. 
\q1 An nunmaked-mor-yoid be anga ungenonikid, 
\q2 weligwaled-mor be anga yononikid. 
\q1  
\v 12 Bab-Dummad, degisoggu, an bega namaked, 
\q2 be-nug-odummoged bar an galegosulid, 
\q2 Bab-Dummad-Jehová, degisadegu, an bega dog-nuedye sogdii guoed. 
\c 31  
\s1 Bab-Jehováʼgi bengusulid 
\d David we-namaked narmaksad. Namakmalad-e-iduedga soglenaid. 
\q1  
\v 1 Bab-Jehová, an begi bensulid. 
\q2 Mer bingeguega be an-imake. 
\q2 ¡Be-igar-innikigwadgi, be an-bendake! 
\q1  
\v 2 Bab-Jehováʼye, be an-itoge, 
\q2 gwae be an-bendakdage. 
\q1 ¡Be an-akwasaila-gandikidyob gued, 
\q2 be an-abonoged-gandikidyob gued! 
\b  
\q1  
\v 3 Bab-Jehová, be an-akwasaila-gandikid-dukuedid, 
\q2 an-abonoged-neggandikidid. 
\q1 Degisoggu, be-nug-sabed-ular, 
\q2 be an-idue, be an-nide. 
\q1  
\v 4 Bab-Jehováʼye, an-isdarmaladi emar-yamoged-igar-an-idu-mesismaladgi be an-ollor-imake, 
\q2 ar bedi an-dukuedid. 
\q1  
\v 5 Bab-Dummad, be-argangi an-san-burba an uksun. 
\q2 Bab-Dummad-Jehová-napiragwad, bee be an-abonosad. 
\b  
\q1  
\v 6 Dule-ibmar-babyob-imakleged-e-nug-odummodimalad an isdar-daked. 
\q2 Ar andi, Bab-Jehováʼgi bensulid. 
\q1  
\v 7 Bab-Jehová, an be-sabguedgi yeer itoged, 
\q2 an egi wergubalid. 
\q1 Ar bedi an-ulubgi-naibi-itoged daksad, 
\q2 an-ulubgi-surbinsa-itoged be wisid. 
\q1  
\v 8 Bab-Jehová an-isdarmaladga be an-uksasulid, 
\q2 be an-ollor-imaksad. 
\b  
\q1  
\v 9 Bab-Jehováʼye, wile be an-dake, 
\q2 ar andi surbinsa-itoged. 
\q1 An wile-itogedba an-ibya mommoleded, 
\q2 an-abagan, an-ulub bela nunmaked. 
\q1  
\v 10 An-naibi-itogedba bela an-abagan nollomakded, 
\q2 an bukib-binsaedbi birgamar onamaid. 
\q1 An-isgued-ular, an-gangued bela berguded, 
\q2 an-garmar bela nollomakded. 
\b  
\q1  
\v 11 Bela an-isdarmaladga an ibmar-dodogedga gued, 
\q2 an-neg-dikarba-mamaid bur bule angi dodomalad. 
\q1 Dulemar-magar-an-dakmalad an-dakalile, an-dobguddamalad, 
\q2 ¡Dulemar igarba an-abingualile, angi gwakiddamalad! 
\q1  
\v 12 Burgwisayobi dulemar bar angi binsasulid, 
\q2 nog-mamarisayobi an gunonikid. 
\q1  
\v 13 Dulemar-bukidar emargi-gakansaar-sunmakmar an itoged. 
\q2 An bia naddibe, an dobee itoged. 
\q1 Ar dulemar angi-aibinega na atosmalad, 
\q2 an-oburgwedgi binsamalad. 
\b  
\q1  
\v 14 Bab-Jehová, ar andi begi bensulid. 
\q2 Andi soged: “¡Be an-Bab-Dummadye. 
\q1  
\v 15 An be-nugginbi gudiiye!” 
\q2 An-isdarmaladgi, an-balegindimaladgi, be an-ollor-imake. 
\q1  
\v 16 Bab-Jehováʼye, angi be nued binsae, 
\q2 ¡Be-sabgued-dummad-nikadba be an-abonoge! 
\q1  
\v 17 Bab-Jehováʼye, ar an bese gochasoggu, 
\q2 mer bingeguega be an-imake. 
\q1 Dule-isganamardi bingeguega be imake, 
\q2 gaya-bogidiki burgwarmalad-meged-galugi be mese. 
\q1  
\v 18 Dule-gakansilimar-e-gaya bogidik be imake. 
\q2 Na san-dummarba-imakedba, dule-mesagwar-imakedba, dule-nuedgi ibmar-sabsur-sogdimalad. 
\b  
\q1  
\v 19 Bab-Jehová, be-sabgued ibiyobi dungue. 
\q2 Dule-be-nug-odummodimaladga, be-sabed be oyoged. 
\q2 Dulemar-wagab, dule-begi-bengusurmaladga, be-sabgued be oyoged. 
\q1  
\v 20 Bab-Jehová, dule-nued dule-egi-isdar-binsaedgi, be-walik be odukued. 
\q2 Dule-nued dule-urwedginbi-sunmakmaladgi, bese-goled-neg-sunna-selegedgi be odukued. 
\b  
\q1  
\v 21 Bab-Jehová-nug an odummosun. 
\q2 Ar sordamar neggwebur-ebiris an-oburgwega bukwagusmargu, e-sabgued-dummad anga oyosad. 
\q1  
\v 22 An surbinsa-itogedba an sogde gusad: “Be-asabin bar be an-ogwisguosurye.” 
\q2 Degi-inigwele, Bab-Jehová, an bese gochagua, bedi an-wilesakwaa-gornaid itosad. 
\b  
\q1  
\v 23 Bela-bemar-Bab-Jehováʼba-nanaid, Bab-Jehová-sabgumala. 
\q2 Bab-Jehová, dule-ega-galakudisurmalad na edarbed. 
\q1 Ar Bab-Jehová dule-na-san-dummarba-imakdimaladdi, sabsur-odurdaked. 
\q2  
\v 24 Bela Bab-Jehováʼgi-bensurmalad gangumala, niga-ogannomala. 
\c 32  
\s1 Bab-Dummad isgued elied 
\d David namaked narmaksad. We-namaked Masquilʼye nugad. 
\q1  
\v 1 Bab-Jehová, dulega e-galagwensuli-gudigusad elisale, e-isgusad ega osulosale, 
\q2 Bab-Jehová egi nued binsanonidaed. 
\q1  
\v 2 Bab-Jehová, dulega e-isgudigusad bar insasuli gunonikile, egi-isgued-naid ega osulononikile, 
\q2 Bab-Jehová egi nued binsanonidaed. 
\q1  
\v 3 Bab-Jehováʼga, an-isgued an sogsulidbali, bane-bane an akigindiidbali, 
\q2 an-abagan galalemai guded. 
\q1  
\v 4 Mutikidbali, ibginedbali, sabsur be an-imaked. 
\q2 Igi yorgi dutu dad-ibeler-abin dinguddae, 
\q2 deyobi, an na itoged. 
\b  
\q1  
\v 5 Geb degi, an-isgued na bega barsognonikid, 
\q2 gwen an begi an-isgued odukussulid. 
\q1 Weyob an sogsad: “Emi, Bab-Jehováʼga an-isgued an barsogoye.” 
\q2 Agine, an-galagwensuli-gudigusad be elinonikid, 
\q2 an-isgudi-gudigusad be anga osulononikid. 
\b  
\q1  
\v 6 A-ulale, dule-be-sogedba-nanadimaladi, suli-suli-itogedgi, bese gormalad. 
\q2 Boni-dummagan-ainialile, ese warmakosulid. 
\q1  
\v 7 Bee be an-odukuedid, 
\q2 nega-bulegangi bee be an-edarbedid, 
\q2 bendakleged-igarmargi-namakega, be an-imaked. 
\b  
\q1  
\v 8 Bab-Jehová soged: “Ani an be-odurdakoed, 
\q2 ani an bega sogoed, ibu-igarba be nanaoe, 
\q1 ani an bega binsaed ukoed, 
\q2 ani an begi nakuledii guoed. 
\q1  
\v 9 Igi moli, degi, moli-uayasuid, ibmar-akusunna itodamala, deyob melle be dao. 
\q2 Ar wemardi, bese warmakmalaga, e-dukargi, dub-nasiklegergebed, 
\q1 e-gayagi, e-gaya-bargaed nasiklegergebed. 
\q2 Degisulile, bese warmakosurmalad.” 
\b  
\q1  
\v 10 Dule-galagwensuli-nanadimaladi, ega gwage-nunmaked-dummad danikid. 
\q2 Dule Bab-Jehová-abdakakwaa-gudimaladdi, Bab-Jehová ise-wile dakoed. 
\b  
\q1  
\v 11 Bemar, dule-innikidamaladi, be weligwar-itomarsun, 
\q2 Bab-Jehováʼgi be wergumarsun. 
\q2 Bemar, dule-gwage-nuegan-gumaladi, bela yeer-itogedgi namakmarsun. 
\c 33  
\s1 Bab-Jehová-napneg-nasiksad-nug odummoged 
\q1  
\v 1 Bemar, dule-ibmar-inniki-imakmalad, Bab-Jehováʼgi be wergumar. 
\q2 Dule-nuegan, Bab-Jehová-e-nug-odummomalar, yeer itoledaed. 
\q1  
\v 2 Bab-Jehová-nug gar-arpa-ogoledba be odummomar, 
\q2 Bab-Jehová-nug gar-arpa-dub-giambe-nikadba (10) be odummomar.\fig Dule, gar-arpa-ogoledba Bab-Jehová-nug odummomar. (Salmo 33:2) |src="CO01006B.TIF" size="col" ref="Salmos 33:2" \fig* 
\q1  
\v 3 Namaked-binid Bab-Jehováʼga be namakmar, 
\q2 Nue ega weligwaledgi gar be ogormar. 
\b  
\q1  
\v 4 Ar Bab-Jehová-sunmaked, napiragwadid, 
\q2 bela na e-ibmar-imakedi, napiragwadbiid. 
\q1  
\v 5 Bab-Jehová, igar-innikigwad, igar-napiragwad nue-sabed. 
\q2 Bab-Jehová-sabguedi, bela we-napneg-gasa naid. 
\b  
\q1  
\v 6 Bab-Jehová na e-sunmakedginbi nibneg nasiksad, 
\q2 na e-bunnogedginbi bela niisgwamar nasiksad. 
\q1  
\v 7 Bab-Dummadi demar-dummagan danar nasiksad, 
\q2 ibmar-sabolegedyobi demar danar urbisad. 
\b  
\q1  
\v 8 Bela we-napneggi-bukmalad Bab-Jehová-nug ogannomar. 
\q2 Bela bemar-we-napneggi-bukmalad Bab-Jehová-nug odummomar. 
\q1  
\v 9 Ar Bab-Jehová sunmaksagu, bela ibmar gunonikid. 
\q2 Bab-Dummad igar-ukdegu, bela deyob gunonikid. 
\b  
\q1  
\v 10 Bab-Jehová, dule-yar-baid-baidgi-bukmalad-igar-amimalad-ibe ei igar bisged. 
\q2 Dule-yar-baid-baidgi-bukmalad-igar-amimalad-ibe ei igar obured. 
\q1  
\v 11 Bab-Jehová-ibmar-imakbieddi, degisadegu mai guoed. 
\q2 Bab-Dummad-binsaed, degisadegu mai guoed. 
\q1  
\v 12 Dule-yar-baid-baidgi-bukmalad Bab-Jehová e-Bab-Dummadga imakmaladi, we-dulemargi nued binsalesad. 
\q2 Bab-Jehová we-dulemar-egadga-imakegala na susad. 
\b  
\q1  
\v 13 Bab-Jehová nibneg-akale atakmaid, 
\q2 Bab-Dummad bela dulemar-dakmaid. 
\q1  
\v 14 Bab-Jehová na e-maidgi atakmaid, 
\q2 Bela we-napneggi-dule-bukmalad dakmaid. 
\q1  
\v 15 Bab-Dummad bela dulemarga gwage nasiksad, 
\q2 degisoggu, ulubgi-be-binsanaid be-wisid. 
\b  
\q1  
\v 16 Rey, na e-sordamar-ichesur-nikadba bendaklegosulid, 
\q2 dule-dutusulid, na e-gangued-nikadba wakinnosulid. 
\q1  
\v 17 Moli, dutusur-inigwele, 
\q2 bila-onogedgi e-ganguedba geg-dule-bendaked. 
\b  
\q1  
\v 18 Bab-Jehová dule-e-dobee-nanadimaladgi nue nakuledaed, 
\q2 dule-e-sabgued-edarbedimaladgi nue nakuledaed. 
\q1  
\v 19 Bab-Jehová melle we-dulemar-burgwega bendakmaid, 
\q2 ukud-dummad-nagunonikile, we-dulemar-bendakmaid. 
\b  
\q1  
\v 20 Bab-Jehová, anmar begi bensulidgi be-edarbebukwad. 
\q2 Bedi anmar-bendakedid. 
\q1 Bedi sigu-abgaedyob be anmar-irwa gwisgudiid, 
\q2 a-ulale, anmar begi bensulid. 
\q1  
\v 21 Degisoggu, Bab-Dummad, begi anmar wergusunnad, 
\q2 ar ade, anmar be-nug-islidikidgi bengussulid. 
\q1  
\v 22 Bab-Jehová, be-wile-anmar-daked, 
\q2 anmar begi edarbediid. 
\q2 Ar anmar begi bensulid. 
\c 34  
\s1 Bab-Dummad emar-bendakmaid 
\d David yamo iwileyob na imaksagu, Abimelecʼse ononnolesgusad. 
\d A-ulale, David we-namaked narmaksad. 
\q1  
\v 1 An bane-bane Bab-Jehová-e-nug-odummodii an guoed, 
\q2 an ega namakdii guoed. 
\q1  
\v 2 Bab-Jehováʼba an nug-dummarba itoged. 
\q2 Deyob dule-na-san-dummarba-imakdisurmalad itononimaloed, 
\q2 agi Bab-Jehováʼgi wergudmarmogoed. 
\q1  
\v 3 Bemar an-balikwaa Bab-Jehová-e-nug odummomar, 
\q2 anmar bela danakwaa e-nug odummomar. 
\b  
\q1  
\v 4 An Bab-Jehová-amidigua, an-abin-imaknonikid. 
\q2 An ibmar-dobgudiidgi, an-ollor-imaknonikid. 
\q1  
\v 5 Dulemar Bab-Jehováʼse-idaksamaladi, egi gangunonimalad, 
\q2 bipisaale bingeguosurmalad. 
\q1  
\v 6 Ani, an dule-wileged, an Bab-Jehováʼse-gochagu, an-itononikid, 
\q2 agine, bela bonigangi an-ollor-imaknonikid. 
\q1  
\v 7 Bab-Jehová-e-baliwitur dule-e-nug-odummodiid-bendakegala, 
\q2 ese nonidaed. 
\b  
\q1  
\v 8 Bemar-sunnagwad be dakdamala, 
\q2 Bab-Jehová-ibidar-nuedid be dakmala. 
\q1 Dule, Bab-Jehováʼgi-bensurgudiid, 
\q2 egi nued binsalediid. 
\q1  
\v 9 Bemar Bab-Jehová-sordamar, Bab-Jehová-dobekwaa nanamar. 
\q2 Dule-Bab-Jehová-dobekwaa-nanadimaladi, ibmarsuli-gudii guosurmalad. 
\q1  
\v 10 Dule-mani-ibmala, dule-wilegedga nadmaloed, ukud-itodii gudmaloed. 
\q2 Dule-Bab-Jehováʼgi-bensur-gudimaladdina, ibmarsuli-gudii guosurmalad. 
\b  
\q1  
\v 11 Mimmigan, dagmala, an-itodamala: 
\q2 Bab-Jehová-dobekwaa-nanaedgi an be-odurdakmaloed. 
\q1  
\v 12 Ar dule na wergudii gubiele, 
\q2 iba-nuegangi weligwar nanadii gubiele, 
\q1  
\v 13 ibmar-isganagi-sunmaked na bargaergebed, 
\q2 gakansaar-sunmaked iegergebed. 
\q1  
\v 14 Ibmar-isgana-imaked iegergebbalid, 
\q2 ibmar-nuedbi imakergebed. 
\q1 Neg-bogidikidbina gudiguergebed, 
\q2 neg-bogidik-imakdii gubalirgebed. 
\b  
\q1  
\v 15 Bab-Jehová dule-inniki-gudimalad akwediid, 
\q2 wemar-ese-goled nue-itodaed. 
\q1  
\v 16 Dule-ibmar-isgana-imakmaladgindina, egi yoleged. 
\q2 Bab-Jehová a-dulemargi yoleged, 
\q2 adi, we-napneggi mer bar egi binsalegegar. 
\q1  
\v 17 Dule-inniki-gudimalad Bab-Jehováʼse-gotele, Bab-Jehová abin-imaked. 
\q2 Bab-Jehová bonigangi dule-inniki-gudimalad nue-bendaked. 
\q1  
\v 18 Bab-Jehová dule-naibi-itodimaladba gudiid, 
\q2 dule-bukib-binsadimalad nue-bendakbalid. 
\b  
\q1  
\v 19 Dule-inniki-gudiid, bonigan-bukidar nikued, 
\q2 degi-inigwele, Bab-Jehováʼdina, bela a-bonigangi ollor-imakoed. 
\q1  
\v 20 We-dule-e-garmar akarguega imakosulid, 
\q2 gwen wargwensaale e-ibe-bibislegega imakosulid. 
\q1  
\v 21 Dule-isganamar ibmar-isgana-imakdimaladba na dukin wioged. 
\q2 Ar dulemar dule-innikidamalad-isdardakdimaladi, odurdaklegedsemalad. 
\q1  
\v 22 Bab-Jehová dule-ega-arbadimalad nue bendaked, 
\q2 Bab-Jehováʼgi-bengudisurmalad, sabsur-odurdaklegosurmalad. 
\c 35  
\s1 Bendaklegega, Bab-Dummadse-goled 
\d David we-namaked narmaksad. 
\q1  
\v 1 Bab-Jehováʼye, angi-gwisgudimaladgi be gwichigue. 
\q2 Angi-bila-onodimaladgi be bila-onoge. 
\q1  
\v 2 Bab-Jehová, be-sigu-abgaed-suid be sue, 
\q2 an-bendakega be dage. 
\q1  
\v 3 An-balegindimalad-abin eswar be gae, akan be gae. 
\q2 Ani an be-abonogedye be anga soge. 
\b  
\q1  
\v 4 An-oburgwebimalad, bingegumarsun, neg-aku-ito gumarsun. 
\q2 An-oakalobimalad, gannar sorsik namarsun, bingegus namarsun. 
\q1  
\v 5 Amala, oros-e-uka burwa-abin-mileddaedyob gumarsun, 
\q2 Bab-Jehová-e-baliwitur amar-baleginne. 
\q1  
\v 6 E-igar-nanaedi, ega negsichidyob gusun, 
\q2 e-igar-nanaedi, ega gware-gwareyob gusun. 
\q2 Bab-Jehová-e-baliwitur amar-baleginne. 
\q1  
\v 7 Gwen an ibmar-oakalossuli, 
\q2 an-oburgwega, an-idu yaa akwismalad, 
\q2 an-idu saki nasiksamalad. 
\q1  
\v 8 Boni egi ukiagwar yolesunna, 
\q2 na emar-yardakdiidgi, na dukin yardaklege. 
\q2 Na yaa-akwismaladgi, na dukin argwanmala. 
\b  
\q1  
\v 9 Degidbali, Bab-Jehováʼgi an yeer itogoed, 
\q2 an e-abonogedgi weligwar itogoed. 
\q1  
\v 10 Weyobi, binnasur an gotoed: 
\q2 “Bab-Jehováʼye, ¿doa beyobi, dule-nollogwad dule-dutusulidgi bendake? 
\q1 ¿Doa beyobi, dule-wileged dule-e-ibe-ibmar-suedgi bendake? 
\q2 ¿Doa beyobi, dule-ibmar-abediid, dule-e-ibe-ibmar-suedgi bendake? Dule beyobid sated.” 
\b  
\q1  
\v 11 Dule-barsogmalad-isganamar angi gwisguarmalad, 
\q2 an-ibmar-wissulid anse egismalad. 
\q1  
\v 12 Andi wemargi nueddaed, 
\q2 emardi, angi ichakwadamalad. 
\q2 Weyob-damalad ulubgi nunmak an-imaked. 
\q1  
\v 13 Ar wemar uellemaigusgu, andi nue-bukib eba itodii gusad, 
\q2 andi wile-itoged-mor-yoi gudii gusad. 
\q1 Ulubgi-naibi-itogedba an mas guchasulid, 
\q2 an ega Babse-goled gwen bogigussulid. 
\q1  
\v 14 An-ai-burgwisayobi, an-gargwenad-burgwisayobi, 
\q2 an bukib-itodii gusad. 
\q1 An-nan-burgwisayobi, an bodii gusad. 
\q2 An ulubgi-naibi-itogedba, an bukib-binsadii gusad. 
\b  
\q1  
\v 15 An sabsur-wilesgu, emardi yeer-itosmalad, na atosmarbalid. 
\q2 Dule-isganamar aku-an-dakmaladyobi, angi aibinmalaga na atosmalad, 
\q2 an-san goa-goa imaknaidbi gusmalad. 
\q1  
\v 16 Sabsur-an-imaknanai gusmalad, 
\q2 angi dodonanai gusmalad, 
\q2 isdar-an-dakmaladba anse uludmalad. 
\q1  
\v 17 Bab-Jehová, ¿sanagwadse be we-dulemar yeerdakoe? 
\q2 Dulemar-an-gindakbiedgi be an-bendake, 
\q2 dulemar achumigur-nono-wawaadyob an-obelobiedgi be an-bendake. 
\q1  
\v 18 Dulemar-bukidarad-abargi, an bega dog-nuedye sogoed. 
\q2 Dulemar-bukidarad-abargi, an be-nug odummogoed. 
\b  
\q1  
\v 19 An-isdarmalad-angi-aibindimaladi, mer angi wergumala. 
\q2 Binsa-isdar-an-dakdimaladi, mer angi dodomala. 
\q1  
\v 20 Ar wemar neg-bogidik-nasikedgi sunmaksurmalad, 
\q2 unnila dulemar-gwage-eikwaa-damaladgi gakansaar sunmakmalad. 
\q1  
\v 21 Anga ise-allar allemalad, sogmalad: 
\q2 “¡Anmar-sunnad anmar e-isgusad daksamarye!” 
\b  
\q1  
\v 22 ¡Bab-Jehová, bela be daksad! 
\q2 ¡Mer be gayamaklege! 
\q2 ¡Mer be angi bangue! 
\q1  
\v 23 An-Bab-Dummad-Jehováʼye, anga igar-innikigwad-imakega be dage, 
\q2 an-arsogega be dage. 
\q1  
\v 24 An-Bab-Dummad-Jehováʼye, 
\q1 be-igar-innikigwadba be anga igar naboge. 
\q2 ¡We-dulemar mer angi dodomalaga be imake! 
\q1  
\v 25 Mer weyob binsamalaga be imake: 
\q2 “¡Anmar weyopira dakbigusye!” 
\q1 Mer weyob sogmalaga be imake: 
\q2 “¡Anmar we-dule obelosye!” 
\q1  
\v 26 An-sabsur-wilesadgi bela yeer-itodimaladi, bingegumala, 
\q2 neg-aku-itodii gumala. 
\q1 Dulemar angi bur san-dummarba-itodimaladi, bela-bela bingegumala, 
\q2 nug-bipii gumala. 
\b  
\q1  
\v 27 Anba-nanaimalad, binnasur namakmar, wergumar. 
\q2 Sogdii gumarsun: “Bab-Jehová-e-nug odummolesunye, 
\q2 Bab-Jehová e-mai-gwage-bogidikid yeerdakye.” 
\q1  
\v 28 Be-igar-innikigwadgi an sunmakoed, 
\q2 bane-bane an be-nug-odummodii gudoed. 
\c 36  
\s1 Bab-Dummad-dule-wiledaked 
\d Bab-Dummad-e-mai-David we-namaked narmaksad. Namakmalad-e-iduedga soglenaid. 
\q1  
\v 1 Dule-Bab-Dummadgi-isgudiid weyob soged: “Isgudiid an yeer-itoged.” 
\q2 Bab-Dummad-dobe-nanaodeeye gwen binsasulid. 
\q1  
\v 2 Dule-isgana e-nug-odummolegoye binsaed, 
\q2 e-isgued akudaklegoye binsaed. 
\q2 Bab-Dummad ega akar-sogosurye binsaed. 
\q1  
\v 3 E-sunmaked, galagwensuli sunmaked, 
\q2 gakansaale sunmaked. 
\q1 Dule-binsaedsulidga naded, 
\q2 ibmar-nued-imaked ieded. 
\q1  
\v 4 Megidele, isgued-imakedginbi binsamegisdaed. 
\q2 Igar-nued-imakedgi gwen binsadasulid. 
\q2 Isguedgi bangugwelodeeye gwen binsadasulid. 
\b  
\q1  
\v 5 Bab-Jehová, be-sabguedi bela nibnegse warmaked, 
\q2 be-innikidaedi, bela mogir-billise warmaked. 
\q1  
\v 6 Be-igar-innikimaladi, yala-dummagan-gandik-bukwadyob gued. 
\q2 Muu-billi-wilasaila-naibayobi, be-igar-nabomalad mamaid. 
\b  
\q1 Bab-Jehová, bela be dulemar-akwemaid, 
\q2 bela be ibdurgan-bukwadi, akwemaibalid. 
\q1  
\v 7 Bab-Dummad, ibibayobi bedi bela-belad wile dule-dakmai. 
\q2 Gannir e-mimmigan e-sakan-urba-odukueyob, 
\q2 dulemar begi bendakleged amied. 
\q1  
\v 8 Be-neggi ega be mas-obineba-ukmaidgi, nue immelebukwad, 
\q2 be-dii-nued-ariomaidgi nue-immelebukwa be imaked. 
\q1  
\v 9 Ar beginbi, san-burba-geg-bergued danikid. 
\q2 Anmar unnila beginbi, san-burba-dula-gued amied. 
\b  
\q1  
\v 10 Bab-Dummad, dule-beba-ibmar-imakdimaladi be wiledaksun. 
\q2 Dule-gwage-nuegan, be-igar-innikigwadba be bendaksun. 
\q1  
\v 11 Dule-san-dummarba-imakdimaladi, melle an-ogalakuega be sao. 
\q2 Dule-isgudimaladse, melle galakuega be an-imako. 
\b  
\q1  
\v 12 Nue be dakmar, dule-isgudimaladi, igarga gudasulid. 
\q2 Galakuddamalad, gege bar igarga gudamalad. 
\c 37  
\s1 Dule-isganamar bergumaloed 
\d David we-namaked narmaksad. 
\q1  
\v 1 Dule-isganamar-nasgumaidba mer be sae itoge, 
\q2 Dule-isganamargi mer be nobgue. 
\q1  
\v 2 Ar we-dulemar gaganyobi emiskwaa bergudmaloed, 
\q2 gagan-dinguddaedyobi emiskwaa surgudmaloed. 
\q1  
\v 3 Bab-Jehováʼgi mer be bengu, ibmar-nuegan be imake. 
\q2 We-napneggi galakusuli be gudii guoed. 
\q1  
\v 4 Bab-Jehováʼgi be nue-wergudii sae. 
\q2 Ar be ibmarbina-sogdiid, Bab-Dummad bega ukoed. 
\q1  
\v 5 Be-ibmar-imakbied, Bab-Jehováʼga be uke. 
\q2 Mer be Bab-Jehováʼgi bengue, 
\q2 ar Bab-Jehová bega ibmar imakoed. 
\q1  
\v 6 Igar-maidba be-ibmar-imakedi, Bab-Dummad bega dad-ibeleryob odalogoed. 
\q2 Deyobi dule bela magar daknonikoed, 
\q1 bede, dule-napiragwadid, 
\q2 bede, igar-maidba ibmar-imakedid. 
\b  
\q1  
\v 7 Bab-Dummad-asabin bogidik-gudii be imake. 
\q2 E-bega-ibmar-imakedse edarbedii be sae. 
\q1 We-dule-ibmar-isgana-imaked nasgumai be dakele, 
\q2 mer be sae-itogo. 
\b  
\q1  
\v 8 Be-isdar-itoged na be bargae, 
\q2 be-sae-itoged be iege. 
\q1 Melle be urwe, 
\q2 abakalegi be neg-oichoalile. 
\q1  
\v 9 Ar dule-isganamar burgwemaloed. 
\q2 Dule-Bab-Jehováʼgi-ibmar-edarbedimaladdi, neg-nued-bonisulid ega uklegoed. 
\b  
\q1  
\v 10 Dule-isganamar napi-ichee gudidimalad. 
\q2 Ar a-dulemardi be-amidigumaloen-inigwele, gwen be-amiosurmalad. 
\q1  
\v 11 Ar dule-san-dummarba-imaksurmalad neg-nued-bonisulid egadga guoed, 
\q2 amala bela nue-nasgumaidbali, weligwar itomaloed. 
\b  
\q1  
\v 12 Dule-isgana dule-nuedgi sunnasur binsadaed. 
\q2 Dule-isgana dule-nued-dakdele, bela-bela nue-sae dakdaed. 
\q1  
\v 13 Degi-inigwele, Bab-Jehováʼdi dule-isganaga alloed, 
\q2 ar wisid, we-dulemar-bergued bato ese warmaksad. 
\b  
\q1  
\v 14 Dule-isganamar, dule-wilegana-oburgwega, dule-nued-nanamalad-ogilogega, e-es-suid ononanaid, 
\q2 e-sigumar guagwar ebisbukwamalad. 
\q1  
\v 15 Degi-inigwele, e-es-suid e-gwagegi yolegoed, 
\q2 e-warsimardi ei bibislegoed. 
\b  
\q1  
\v 16 Dule-nued ibmar-ichee-nikale, 
\q2 dule-isgana-ibmar-bukidar-nikadba, bur nuedid. 
\q1  
\v 17 Ar Bab-Jehová, we-dule-isganamar-e-gangued ei osulogoed. 
\q2 Dule-igar-inniki-imakmaladdi bendakoed. 
\b  
\q1  
\v 18 Bab-Jehová, dule-inniki-nanadimalad-edarbediid. 
\q2 A-dulemarga ibmar-uklegoedi, degisadegu egadga guoed. 
\q1  
\v 19 Dule-inniki-nanadimaladga ibagan-bulegan-noni-sogele, akar-guosulid. 
\q2 Ukud-dummad nagunonikile, mas-nika guoed. 
\b  
\q1  
\v 20 Dule-isganamardi, bergudmaloed. 
\q2 Bab-Jehová-isdarmaladdi, gagan-burgweyobi burgwidmarmogoed. 
\q2 Waayob bergudmaloed. 
\q1  
\v 21 Dule-isganamar aimargi mani-gasale, bar bennukdasulid. 
\q2 Dule-nueddi dule-wiledakedba aimarga ibmar ukdedaed. 
\q1  
\v 22 Dulemar Bab-Jehováʼse-nabir-binsalesmaladi, neg-nued egadga guoed. 
\q2 Dulemar Bab-Jehováʼse-ukabsalesmaladdi, girgumaloed. 
\b  
\q1  
\v 23 Dule-wargwen e-daedgi Bab-Jehová-yeer-ito imakele, 
\q2 Bab-Dummad we-dule-nued-nanadii imaked. 
\q1  
\v 24 Dule-nued gwatirnoni-sogele, deyob degisadegu gudii guosulid, 
\q2 ar Bab-Jehová we-dule-bendakoed. 
\b  
\q1  
\v 25 An sapingwa-danikid-akale, an seredgusadse, an dakdisulid, dule-nuedi nue-dummad-wiledii, 
\q2 e-mimmigan mas-egisdii an dakdisulid. 
\q1  
\v 26 Dule-nuedi aimarga ibmar-ukalile, nuedgi yeer-itogedba ukdedaed. 
\q2 E-mimmigan ega ibnuedga gued. 
\b  
\q1  
\v 27 Ibmar-isganagi be bangu, 
\q2 ibmar-nueganbi be imakdii gue. 
\q1 Ar deyob be imakele, 
\q2 Bab-Dummad bega-yar-ukoye-sogsadgi degisadegu be gudii guoed. 
\q1  
\v 28 Ar Bab-Jehová igar-inniki-imakleged yeer dakdaed, 
\q2 dule-eba-nue-nanadiidgi, bangusulid, 
\q1 Bab-Jehová amar-nue-edarbedidaed. 
\q2 Dule-isganamardi, bergumaloed, 
\q2 gwen wagan-nikuosurmalad. 
\q1  
\v 29 Dule-nuegan-damaladdi, Bab-Dummad ega yar-ukoye-sogsadgi 
\q2 degisadegu mai gumaloed. 
\b  
\q1  
\v 30 Dule-nued sunmakdele, nue-binsaed-nikaa sunmakdedaed, 
\q2 Dule-nued sunmakdele, igar-inniki-maidba sunmakdedaed. 
\q1  
\v 31 E-Bab-Dummad-igar-maid e-gwagegi sedidaed. 
\q2 A-ulale, isgusurdaed. 
\b  
\q1  
\v 32 Dule-isgana dule-nued-oburgwega 
\q2 arbakee dule-nued-argadidaed, 
\q1  
\v 33 Degi-inigwele, Bab-Jehováʼdi dule-isganaga dule-nued-urmakosulid. 
\q2 Dule-nuedga igar-itolear-sogele, egi isgusye-sogega imakosulid. 
\b  
\q1  
\v 34 Bab-Jehová-abdakdii be gue, 
\q2 a-sogedba be nanadii gue. 
\q1 Bab-Jehová be-nug-odummogoed, 
\q2 neg-nued begadga-guegala, bega ukoed. 
\q2 Dule-isgana-bergumaloedi, be-sunnad be dakoed. 
\b  
\q1  
\v 35 An dule-isgana daksad, 
\q2 urwar-sapi-dummad-neg-ganikidyob, na san dummarba imaked. 
\q1  
\v 36 Degi-inigwele, we-dulemar emiskwaa bergudoed. 
\q2 We-dulemar bato sulibinne dakledagoed. 
\q2 Be amialile, be dakosurguoed. 
\b  
\q1  
\v 37 Dule-nuegan-damalad be dake, 
\q2 dulemar igar-maidba-damalad be dake. 
\q2 We-dulemar-nueddamaladga igar-nued ega maid. 
\q1  
\v 38 Ar dulemar igar-maidgi-yoledimaladdi, bela burgwemaloed, 
\q2 Dule-sunnasur-damaladdi, bela bergudmaloed. 
\b  
\q1  
\v 39 Dule-nuegan-damalad-e-bendakleged Bab-Jehováʼgi danikid. 
\q2 Ibagan-suli-suli-itogedgi, Bab-Jehová dule-nuegan-bendakedga gued. 
\q1  
\v 40 Bab-Jehová bonigangi dule-nued-bendakoed, 
\q2 ar Bab-Jehováʼgi bensuli-gudii gusad. 
\q1 Bab-Jehová dulemar-isganagi we-dule-onogoed, 
\q2 dulemar-isganagi bendakoed. 
\c 38  
\s1 Dule-isgusad Bab-Dummadse-gornaid 
\d Ibmar-ukleged-ebinsalegega, David we-namaked narmaksad. 
\q1  
\v 1 Bab-Jehováʼye, mer be anse urwe. 
\q2 Be sae-itogedgi, mer be sabsur an-imake. 
\q1  
\v 2 Be sabsur-angi-uludedba an naibigunonikid, 
\q2 be angi sabsur-gwisgunonikid. 
\b  
\q1  
\v 3 An-isgusad-ular, be anse uludedbali, an-san bar nuedsulid, 
\q2 an-garmar bar nuedsulid. 
\q1  
\v 4 An-isgued bela an-nonogagas naid, 
\q2 ibmar-aidikidyob angi signonikid. 
\b  
\q1  
\v 5 An binsaedsuli gudigusad-ulale, an-sanse-bakale, nunusar yapangusad, 
\q2 bela sibudik-sibudikgusad. 
\q1  
\v 6 Nue-ibitos itoleged, 
\q2 bela-bela an oitolesad, 
\q2 nue-wiles itoleged. 
\q1  
\v 7 Bela-bela an uedik itoged, 
\q2 an-san bela ibitosad. 
\q1  
\v 8 Nue geggus itoleged, nunumakesar itolegusad. 
\q2 An gwage-nunmaked-dummad nue-itonaid. 
\b  
\q1  
\v 9 Bab-Dummad, an-ibmar-abeged bela be wisid, 
\q2 an-ibmarbina-gudiid begi dukunaisulid. 
\q1  
\v 10 An-gwage sabesur dik-dik-naid, 
\q2 an-niga argwated, 
\q2 nue an ataksurgusad. 
\q1  
\v 11 An bonigan-nikadba, an-aimar, an-sordamar, angi bangudmalad. 
\q2 An-gwenadgan angi deyob bangudmarmogad. 
\b  
\q1  
\v 12 An-oburgwebi-gudimaladi, an-yardakega angi arbananaid. 
\q2 An-oitomaloye-sogdimaladi, an-yardakega arbakee bane-bane igar-aminanaid. 
\b  
\q1  
\v 13 Degi-inigwele, uayasuliyob an imaksad, 
\q2 yamo amar-itonaisuliyob an imaksad. 
\q1 Amar-abin an sunmaksasulid, 
\q2 wissur-sunmakeyob an imaksad. 
\q1  
\v 14 Degisoggu, dule-uayasulidyob an gued, 
\q2 wissur-emar-abinsaedyob an gued. 
\b  
\q1  
\v 15 Bab-Jehová, unnila an beginbi ibmar-edarbediid. 
\q2 An-Bab-Dummad-Jehová, bebi unnila wemar-abin-imakoed. 
\q1  
\v 16 Unnila ibmar-soggwen an egised: 
\q2 An ailanonikile, mer anga allemalaga be imako, 
\q2 mer angi burgumalaga be sao. 
\b  
\q1  
\v 17 Nue an galakue itoged, 
\q2 ibmar-nunmaked gwen-an-indakbisulid. 
\q1  
\v 18 Degisoggu, an-isgusad an na barsogergebed, 
\q2 an isgusadba nue-wiles an itoged. 
\q1  
\v 19 An-isdarmaladdina nue baligannosmalad, 
\q2 yogasaar-isdar-an-dakdimaladi nue mergusmalad. 
\q1  
\v 20 An ibmar-nued-imaked-ular, dulemar angi yolenanaid. 
\q2 An ibmar-nued-imaked-ular, dulemar angi gwisgunanaid. 
\b  
\q1  
\v 21 Bab-Jehováʼye, mer be an-barmete, 
\q2 an-Bab-Dummadye, mer be angi bangue. 
\q1  
\v 22 Gwae be an-bendakdage, 
\q2 Bab-Dummad, be an-abonogedid. 
\c 39  
\s1 Unnila-sikwas-gudigued 
\d David we-namaked narmaksad. Namakmalad-e-idued-Jedutúnʼga soglenaid. 
\q1  
\v 1 An na dukin sogsad: “An itoakwaa nanadii imakoye, 
\q2 adi, an-sunmakedgi mer an isguegar. 
\q2 Ar dule-isgana an-asabin gwichile, andi ibmar-sogosulid.” 
\q1  
\v 2 Degisoggu, an sunmaksasulid, ar ibmar-nuedse-bakale, bar an bissulid. 
\q2 Degi-inigwele, nunmakeddi anga ulubgi nasgumai gusad. 
\q1  
\v 3 An-gwagedi uelleded. 
\q2 An we-ibmargi-binsasiidgi an isdar itoded, geb an sogdesunnad: 
\b  
\q1  
\v 4 “Bab-Jehová, an-ibagan-berguoed be anga soge, 
\q2 birgabigwa an napi-dulagudiguoed be anga soge, 
\q2 adi, an sikwas-gudiguoed magar itogegar. 
\q1  
\v 5 Bab-Jehová, wis-ichee-dulagudigued be anga uksad, 
\q2 an-birga-nikaddi be-asabinni birgamar-nassuliyob be daked. 
\q1 We gakansulid, bela-dulemar-gudidiid 
\q2 sikwas-bunnogedyob gudidimalad. 
\b  
\q1  
\v 6 ”Ar napiragwad, anmar we-napneggi unnila sikwas gudimalad. 
\q2 Dule binsarsunna sulibinsa itodiid. 
\q1 Ar binsa na ibmar-nuegan saboged, 
\q2 ar wissulid, doa we-ibmar sunonikoe. 
\b  
\q1  
\v 7 ”Bab-Jehováʼye, degisoggu, ¿bia an bendakleged amiosunna? 
\q2 Unnila an beginbi bendakleged amied. 
\q1  
\v 8 Bab-Jehováʼye, bela an-isguedgi be an-ollorsae, 
\q2 mer dule-binsaed-nikasurmalad angi-dodomalaga be imake. 
\b  
\q1  
\v 9 ”An bar sunmaksasulid, an bar ibmar-sogsasulid, 
\q2 ar bee be deyob ibmar imaked. 
\b  
\q1  
\v 10 ”Bab-Jehováʼye, mer bar be sabsur-an-odurdake, 
\q2 ar be an-oburgwednaga an-imaknaid. 
\q1  
\v 11 Be dule-isgued-sabsur-odurdakedba dule-nudaked, 
\q2 na bur e-ibmar-binasoged uduyob be e-ibe obeloged. 
\q1 We gakansulid, bela-dulemar-gudidiid, 
\q2 sikwas-bunnogedyob gudidimalad. 
\b  
\q1  
\v 12 ”Bab-Jehováʼye, an bese-goled be itoge, 
\q2 an bega-ibmar-soged be itoge, 
\q2 an-boed mer be itosuli gue. 
\q1 Andi bega dule-ainebalid gued, 
\q2 bela an-dadgan-nanadigusadyobi an yar-obak-obak gudiid. 
\q1  
\v 13 Mer isdar be an-dake. 
\q2 An we-napneggi-naed-iduar, an gannar weligwar itogoed.” 
\c 40  
\s1 Bab-Dummad isguedgi an-ollor-imakedid 
\r (Salmo 70:1-5) 
\d David we-namaked narmaksad. Namakmalad-e-iduedga soglenaid. 
\q1  
\v 1 Ulubgi-abitoakwaa, Bab-Jehová-abdakdii an gusad. 
\q2 Ansik aibilisad, an ese-goledi, magar an-itosad. 
\q1  
\v 2 San-burba-bergued-galu-yagi an-onosad, 
\q2 nega-matagangi an-onosad. 
\q1 Akwasaila-birgi an-ogwisgusad, 
\q2 nega-nuedgi an-ogwisgusad. 
\q1  
\v 3 Bab-Jehová an-gwabindukugi namaked-gwapid nasiksad, 
\q2 e-nug-ogannoedgi-namakega an-imaksad. 
\q1 Deyob an-dakarmargua, bukidar dobe itodmalad, 
\q2 Bab-Jehováʼgi bensuli gudmalad. 
\b  
\q1  
\v 4 Dule, Bab-Jehováʼgi-bensuliguedi, Bab-Jehová egi nued binsadiid. 
\q2 Dule, san-dummarba-samalad-barwisodisulidi, 
\q1 bab-dummad-baidse-gormalad-barwisodisulidi, 
\q2 Bab-Jehová egi nued binsadiid. 
\q1  
\v 5 An-Bab-Dummad-Jehováʼye, ibibayobi ibmar-dakledisurmaladi be imaksa. 
\q2 Ibibayobi be anmargi nued binsasa. 
\q1 ¡Dule beyobid sulid! Aisaar an bega bela be-ibmar-imaksad sogbienad. 
\q2 Igi an bega sogergebele, ar gege bela bega sogleged. 
\b  
\q1  
\v 6 Bega-ibdula-uklemalad gwen be abessulid, 
\q2 bega-ibmar-gwag-gullemalad-ukleged gwen be abessurbalid. 
\q1 Unnila beba-ibsaega be an-imaksad. 
\q2 Bega-ibdula-ogumakar-uklegedi, 
\q1 isgued-eliega ibdula-uklegedi, 
\q2 gwen be egichissulid. 
\q1  
\v 7 A-ulale, an sogdesunnad: 
\q2 “Bab-Dummad, be-gardagi angi-narmakar-maiyob an danisun. 
\q1  
\v 8 Bab-Dummad, an be-sogedba ibmar-imakedi ibiyobi an yeer-itodae. 
\q2 Be-Igar-Mesisadi an-gwage-ulubgi an sediid.” 
\b  
\q1  
\v 9 Dule-bukidarmalad-abargi an be-igar-napiragwadgi sunmakdiid. 
\q2 Bab-Jehová, bedi nue an-wisid 
\q2 be-igarba-sunmakedi an gwen boggudisulid. 
\q1  
\v 10 Be-igar-napiragwadi dulemarga an gwen odukudisulid. 
\q2 Be-innikidaedgi, be-abonoleged-igargi, an obinmakdiid. 
\q1 Bipisaale, dule-bukidarmalad-abargi be-sabguedi, 
\q2 be-igar-napiragwadi, an gwen odukudisulid. 
\q1  
\v 11 Bab-Jehováʼye, melle be-sabguedi be angi obano. 
\q2 Be nue-an-sabedgi, be-igar-napiragwadba, be an-sedii guo. 
\q1  
\v 12 Isguedi bukidar an-ebiris naid, 
\q2 isgued bukidarsoggu, gege na bega bela bied. 
\q1 Isgued angi dar nue obined, 
\q2 an akusunna-itogusad. 
\q1 Isgued an-sailagiaganba bur bule mergued, 
\q2 bar-gannarbaa an itosurgusad. 
\b  
\q1  
\v 13 Bab-Jehováʼye, we-isguedgi wis be an-onodage. 
\q2 Bab-Dummadye, gwae be an-bendakdage. 
\q1  
\v 14 Dule-an-obelobimaladi be obingegsae, 
\q2 akusunna ibmar-itogega be imake. 
\q1 Dule-an-oichobigudimaladi, binged-abargi duurmakemai be sae. 
\q2  
\v 15 Dule-an-wagar-daksuli an-dikarba-sunmakdimaladi, bingedar-itogwichi be imake. 
\q1  
\v 16 Dule-be-amidimaladi, begi wergumarsun, 
\q2 begi yeer-itomarsun. 
\q1 Dule-abonoleged-igarbina-nue-sogdimaladi, weyob sogdii gumarsun: 
\q2 “¡Ibiyobi Bab-Jehováʼdi dule-gandikid guye!” 
\b  
\q1  
\v 17 Bab-Jehováʼye, melle be an-iego, 
\q2 andi dule-wilesa gudiid, 
\q2 ibmar-abesa garmakdiid. 
\b  
\q1 Bab-Dummad, bee be an-bendakedid, igar-bulegangi bee be an-onogedid. 
\q2 Bab-Dummadye, melle be undar-yogguo. 
\c 41  
\s1 Nailikgued-anga-osuloye Bab-Dummadga soged 
\d David, namakmalad-e-iduedga we-namaked narmaksad. 
\q1  
\v 1 Dule, dule-wileged-bendakedgi binsaele, Bab-Jehová, a-dulegi nued-binsaed. 
\q2 Ar ade, ibagan-isgana ega nagunonikile, Bab-Jehová we-dule-bendakoed. 
\q1  
\v 2 Bab-Jehová we-dule-edarboed, 
\q2 we-napneggi dula-gudii imakoed, 
\q1 we-napneggi we-dulegi nued-binsalegoed. 
\q2 E-isdarmaladga we-dule-urmakosulid. 
\q1  
\v 3 We-dule nailikgumaile, Bab-Jehová bendakoed. 
\q2 Bab-Jehová we-dulega nailikgued osulogoed. 
\b  
\q1  
\v 4 Bab-Dummadga, an sogsad: 
\q2 Bab-Jehováʼye, wile be an-dake. 
\q1 Ar an begi nos-inigwele, 
\q2 an-nailikgumaid be anga osuloge. 
\q1  
\v 5 An-isdarmalad angi isdar sunmakmalad, sogmalad: 
\q2 “¿Wede sana burgoe? ¿Wede sana berguoe?” 
\q1  
\v 6 Anse atakdanimalale, gakansaar anga sunmakmalad. 
\q2 Geb nadmalogua, angi sunmakdedamalad. 
\b  
\q1  
\v 7 Dule-isdar-an-dakmalad danar ambikunonimalogu, 
\q2 angi urwebukdamalad. 
\q1 Angi isdar binsabukdamalad, sogbukdamalad: 
\q2  
\v 8 “We-dule-nailikgumaidi gwisguosulid, burgoed. Boni-dummad egi naid.” 
\q1  
\v 9 Ar an-ai-nued-anba-masgundiid, an-egi-bensur-gudiid, 
\q2 a-bela angi aibitemogad. 
\q1  
\v 10 Bab-Jehováʼye, wile be an-dake. 
\q2 An-nailikgumaidi, be anga nudake, 
\q2 adi, an-isdarmaladgi an gwisguegar. 
\b  
\q1  
\v 11 An-isdarmalad-angi-nakosulidba an magar dakoed, 
\q2 yeer-ito an be-imaksad. 
\q1  
\v 12 Bab-Dummad, an isgussulidba, be an-ogannodii guoed, 
\q2 be-asabin-gudigu be an-imakoed. 
\b  
\q1  
\v 13 ¡Israel-e-Bab-Dummad-Jehová, be-nug odummolesun! 
\q2 Birga-birgaba degisadegu be-nug odummoledii gusun. 
\q2 ¡Deyob gusunno! 
\c 42  
\ms1 2. GARDA-SOGBOGWAD 
\mr (Salmos 42:1–72:20) 
\s1 Bab-Dummadbina an nue-soged 
\d Coré-e-wagan we-namaked narmaksad. 
\d We-namaked Masquilʼye-nugad. Namakmalad-e-iduedga soglenaid. 
\q1  
\v 1 Bab-Dummad, igi goe-bebe-nikad diibina ogormakdidae, 
\q2 an deyob bebina sogdiid.\fig Goe-sapur diibina ogormakdidae. (Salmo 42:1) |src="HK00031B.TIF" size="col" ref="Salmos 42:1" \fig* 
\q1  
\v 2 Bab-Dummadbina an nue-soged, 
\q2 Bab-Dummad-san-burba-ukmaidbina an nue-soged. 
\q1 ¿Ar sana Bab-Dummad-asabin an gwisgunonikoe? 
\q1  
\v 3 Bane-bane an bodiid, 
\q2 ar an-boed an-masgunnedga anga gunonikid. 
\q1 An-isdarmalad bane-bane anga sogdimalad: 
\q2 “Emisgindi, ¿bia be-Bab-Dummadde nade?” 
\b  
\q1  
\v 4 An ebinsaddaed, igi an dulemar-abalagi an nadapdae, 
\q2 igi an Bab-Dummadse-goled-negse dulemar-semaidae. 
\q1 An ebinsaddaed, iba-dummad-onolealile, weligwaledgi an dulemar-semaidae, 
\q2 bela-belad namakagwale an nadapdamalad. 
\q1 An we-ibmar ebinsadele, 
\q2 naibid-dummad angi nonidaed. 
\b  
\q1  
\v 5 ¿Ibiga an suli-suli-itogoe? ¿Ibiga an bukib-itogoe? 
\q2 ¡Gwen an deyob itogewilubsulinad! 
\q1 Bab-Dummad-abitodii an guoed, 
\q2 Bab-Dummad-e-nug-odummodii amba an guoed. 
\q1 Ar Bab-Dummad, an-abonogedid. 
\q2 Bab-Jehová, an-Bab-Dummadid. 
\b  
\q1  
\v 6 Bab-Dummadye, nue an suli-suli-itoged. 
\q2 A-ulale, an begi Jordán-diwar-akale binsadiid, 
\q1 Hermón-yar-dummagan-akale, an begi binsadiid, 
\q2 Mizar-yalagan-akale, an begi binsadiid. 
\q1  
\v 7 Igi ibe-sailagi diwar-dummad-aryomaidae, 
\q2 dii sukamakmaidae, 
\q1 sabsur uurmakmaidae, 
\q2 deyobi, wile-itolegedi be angi-gwisguega imaksad. 
\q1  
\v 8 Bab-Dummad, an bese weyob goled: 
\q2 Bitigi be-sabgued be anga ibginedba oyogena gadin, 
\q2 neg-mutikidba an-bega-namakeddi berguosulid. 
\b  
\q1  
\v 9 Bab-Dummadga an sogoed: 
\q2 “Be an-Bab-Dummadid, be an-bendakdiidid. 
\q1 ¿Ibiga be an-ies-gudii? 
\q2 ¿Ibiga wilesakwaa an-isdarmalad-nukad an itodii guoe?” 
\q1  
\v 10 An-isdarmalad-angi-allenanaid, 
\q2 nue-nunmak an-imaked, bela-bela ulubse an-ebuged. 
\q1 An-isdarmalad weyob anga sokardamalad: 
\q2 “¿Bia be-Bab-Dummadde nade?” 
\b  
\q1  
\v 11 ¿Ibiga an suli-suli-itogoe? ¿Ibiga an bukib-itogoe? 
\q2 ¡Gwen an deyob itogewilubsulinad! 
\q1 Bab-Dummad-abitodii, an guoed, 
\q2 Bab-Dummad-e-nug-odummodii amba an guoed. 
\q1 Ar Bab-Dummad, an-abonogedid. 
\q2 Bab-Jehová, an-Bab-Dummadid. 
\c 43  
\s1 Igar-innikigwad-imakega Babse-goled 
\q1  
\v 1 Bab-Dummad, anga be igar-naboge, 
\q2 dule-beba-naisurmalad-abin be an-idu gwisgue, 
\q2 dule-isganamargi, dule-gakansilimargi be an-ollorsae. 
\q1  
\v 2 Bedi an-Bab-Dummadid, 
\q2 be an-ganguedid. 
\q1 ¿Ar ibiga be an-obacha? 
\q2 ¿Ar ibiga an-isdarad an-sabsur-imaked-ular, an wile-itodioe? 
\b  
\q1  
\v 3 Be-magar-ito-ibmar-imakedi, be-igar-napiragwadi, be anga udage. 
\q2 Adi, igar-nuedba an-idugega, 
\q2 be-yar-islidikidse an-nidega, 
\q2 be-maidse an-sedegar. 
\q1  
\v 4 Bab-Dummad, be-ibmar-ukleged-ailase an warmakoed. 
\q2 Agi, an gar-arpaʼba bega namakoed. 
\q1 Ar be, an-Bab-Dummadid, 
\q2 weligwar be an-imakedid. 
\b  
\q1  
\v 5 ¿Ibiga an suli-suli-itogoe? ¿Ibiga an bukib-itogoe? 
\q2 ¡Gwen an deyob itogewilubsulinad! 
\q1 Bab-Dummad-abitodii an guoed, 
\q2 Bab-Dummad-e-nug-odummodii amba an guoed. 
\q1 Ar Bab-Dummad, an-abonogedid. 
\q2 Bab-Dummad, an-Bab-Dummadid. 
\c 44  
\s1 Bab-Dummadse bendakleged egised 
\d Coré-wagan namakmalad-e-iduedga we-namaked-Masquilʼye-nugad narmaksad. 
\q1  
\v 1 Bab-Dummad, epenne ibmar-dakledisurmalad be imaksadi, anmar-sunnagwad uayagwar itosad. 
\q2 Epenne-ibmar-gusadi, anmar-dadgan anmarga sogsad. 
\q1  
\v 2 Be-sunnagwadi, dule-be-wissurmalad be onisad. 
\q2 A-muchubbi, anmar-dadgan be urbisad. 
\q1 Dule-be-wissurmaladi be sabsur-odurdaksad, 
\q2 anmar-dadgandi nasgumai be imaksad. 
\q1  
\v 3 Dadgan gwen e-es-suidgine yar sussurmalad, 
\q2 gwen e-surgangine dulemargi obichasurmalad. 
\q1 Unnila be-ganguedgi, be-surgangi, be anmar-dadgan-bendaksad. 
\q2 Eba-be-gudigusadgi be amar-bendaksad. 
\q2 Ar bede, dadgan-nue-sabedbali, deyob imaksad. 
\b  
\q1  
\v 4 Bebi unnila be an-Bab-Dummadid, bebi be, an-reyd. 
\q2 ¡Be-igar-ukedba dulemargi-nakwega be anmar-imaksad! 
\q1  
\v 5 Be-ganguedgi anmar-isdarmaladgi anmar nakwisad. 
\q2 Be-nuggi anmargi-gwichigudimaladi anmar obelosad. 
\q1  
\v 6 An-warsigi bendakleged an amiosulid, 
\q2 an-es-suid dulemargi-nakwega gwen an-imakosulid. 
\q1  
\v 7 Be anmar-isdarmaladgi-nakwega be anmar-imaksad. 
\q2 Bebi, dule-anmargi-gwisgudimalad-obingegsaega be imaksad. 
\q1  
\v 8 ¡Bab-Dummad, anmar beginbi nug-dummarba-itodii gumaloed! 
\q2 ¡Anmar be-nug-odummodii gumaloed! 
\b  
\q1  
\v 9 Emisgindi, be anmar-obachad, be anmar-obinge-imaksad. 
\q2 Bar be anmar-sorda-bila-onomaladba nanasurgusad. 
\q1  
\v 10 Dule-isdarmalad-abin sikirmakega be anmar-imaksad. 
\q2 Dule-sae-anmar-dakdimalad, anmar-ibe ibmar-atur-imaksamalad. 
\q1  
\v 11 Sibad-wawaadyob be anmar-oburgwega anmar-urmaksad. 
\q2 Dulamar-bamalad-imbagi be anmar-oaisakisad. 
\q1  
\v 12 Be-dulamar mani-bipii be uksad, 
\q2 egi be ibmar-nued gwen-amissulid. 
\b  
\q1  
\v 13 Dule-anmar-neg-dikarba-mamaid-abin, dule-gegegwaga be anmar-imaksad. 
\q2 Dulemarga anmar dodogedga guded, 
\q2 dulemarga anmar alledga guded. 
\q1  
\v 14 Neggweburmar-oallega be anmar-imaksad. 
\q2 Anmar-dakalir, yamo-yamo anmarga guardamalad. 
\q1  
\v 15 Bane-bane bingedar an itodigussunnad. 
\q2 An akusunna-itogedba bingeguarsunnad. 
\q1  
\v 16 An-isdarmalad-buged-an-imakbi-gudimaladse, 
\q2 an-isdarmalad-sae-an-dakdimaladse, 
\q1 an-isdarmalad-an-dikarba-urwedimaladse, 
\q2 an bingedar-itoged. 
\b  
\q1  
\v 17 Bela we-ibmar anmargi gusad. Degi-inigwele, anmar be-iessulid. 
\q2 Dadgan-Ebo-Be-Igar-Mesisadi anmar gwen-bichissulid. 
\q1  
\v 18 Anmar bega uayasuli gussulid, 
\q2 be-Igargi anmar gwen bangussurbalid. 
\q1  
\v 19 Ar bedi achusapur-bunnu-wawaad-e-gubya-yaba be an-balimetemalad, 
\q2 negasichidbi be anmar-idu nasiksad. 
\b  
\q1  
\v 20 Bab-Dummad, ar anmar be-iesana, 
\q2 be-muchub anmar bab-dummad-baidse gochana, 
\q1  
\v 21 ¿ar be wisguosulin be insae? 
\q2 Ar bede bela ulubgi dulemar-binsaed mag-daked. 
\q1  
\v 22 Be-ular, anmar bane-bane oburgwilediid. 
\q2 Sibad-wawaad-oburgwelegedyob anmar imaklediid. 
\b  
\q1  
\v 23 ¡Bab-Dummad, atake! ¡Mer gabe! 
\q2 ¡Gwisgue! Mer be anmargi bangudii gue. 
\q1  
\v 24 ¿Ibiga be anmar-idu dukue? 
\q2 ¿Ibiga be anmar-wilediid be iege? 
\q2 ¿Ibiga be anmar-sabsur-imaklediid be iege? 
\q1  
\v 25 Anmar napa-nukuse yasulemamaigus-naed. 
\q2 Napayala baparmakdigusmalad. 
\q1  
\v 26 Bab-Dummadye, be dage. 
\q2 Be anmar-bendakdage. 
\q2 Be-sabguedgi be anmar-bendakdasun. 
\c 45  
\s1 Rey-ome-nikunaidgi namakleged 
\d Namakmalad-e-iduedga sogleged: “Dutu-lirioʼga-namaklegedyob we-namaked namaklegoed.” 
\d Coré-wagan we-namaked narmaksad. 
\q1  
\v 1 An-ulubgi ibmar-nued sogbie an itoged. 
\q2 An reyga an-namaked-narmaksad soged. 
\q2 An-gwabin garda-suar-yeer-narmakeyobi gued. 
\b  
\q1  
\v 2 Rey, be bur dulemar-baiganba yeerdakleged, 
\q2 be bur yeer-sunmaked, 
\q2 ar Bab-Dummad degisadegu begi ise-nued binsasad. 
\q1  
\v 3 Rey, be-ganguedgi, be-yeerdaklegedgi, be-es-suid be-saderba be nasike. 
\q2  
\v 4 Be-gangued-yeerdaklegedgi nakwemai be imake. 
\q2 Igar-napiragwadbina urwedii be sae. 
\q1 Dule-wileganaga ibmar-innikigwad-imakdii be gue. 
\q2 ¡Rey, be-ganguedgi ibmar-dummagan-imakdii be nanae! 
\q1  
\v 5 Be-sigu-swiswidikmaladgi, be-isdarmalad-bese-galakudii be imake. 
\q2 A-sigumar, rey-e-isdarmalad-gwagegi yoledapoed. 
\b  
\q1  
\v 6 Bab-Dummad, be-negsemaid degisadeguoed. 
\q2 Be-negsemaid, igar-maidba be imaked. 
\q1  
\v 7 Igar-innikigwad-imaked be yeer-itodaed, 
\q2 ibmar-isganadi, be isdar-daked. 
\q1 A-ulale, Bab-Dummad-be-Bab-Dummadi, be-aimar-baiganba be-susad. 
\q2 Be-Bab-Dummad, ina-wawadikidgi be-wawamaksad, 
\q2 weligwar-ito be-imaksad. 
\q1  
\v 8 Be-mola, we-ina-wawadikmaladbi yapanned: 
\q2 Mirraʼye-nugadbi, áloeʼye-nugadbi, canelaʼye-nugadbi yapanned. 
\q1 Reyneg-marfilʼgi-ise-nudakaled-akale, 
\q2 gar-bega-ogorlenaidi weligwar be-imaked. 
\q1  
\v 9 Yagana-be-ebilidmaladi, reymar-sisgan nanaed. 
\q2 Be-ologana-argan-nuedsik rey-ome siid. 
\q2 We-rey-omede, Ofir-or-nuedgi ise-nudakar siid. 
\b  
\q1  
\v 10 Bunagwa, an bega-ibmar-sogoedi, nue be an-itogo. 
\q2 Be-dulemar be iege, 
\q2 be-gwenadgangi mer be bar binsae. 
\q1  
\v 11 Be-yeerdaklegedba rey nue-be-abeged. 
\q2 Rey be-dummadid, degisoggu, eba be ibsae. 
\q1  
\v 12 Tiro-dorgan binsa-ibmar-uklemalad bega sedagoed. 
\q2 Dule-mani-ibgan ega-ibmar-nued-imakbi be-abemaloed. 
\b  
\q1  
\v 13 Rey-e-sisgwa e-gabedyaba nue-nudakar maid. 
\q2 E-mor ber olobi dakleged. 
\q1  
\v 14 E-mor-ise-nue-sobaled-yoi reyse seledoed. 
\q2 E-aimar-yagana e-sorba-nai nadapmaloed. 
\q1  
\v 15 Weligwar itonadapmaloed, 
\q2 Rey-e-negse weligwaledgi dogdapmaloed. 
\b  
\q1  
\v 16 Rey, be-masmala be-dadgan-negsemai-gusad-ganagi sigmaloed. 
\q2 Amar bela bemar-yala-semamai gumaloed. 
\q1  
\v 17 An bega we-namaknaidgi, dulemar-be-iegega an imakosulid. 
\q2 Bela neggwebur-baiganginmalad be-ebinsadiguega an imakoed. 
\c 46  
\s1 Bab-Dummad anmarba gudiguad 
\d Coré-wagan we-namaked narmaksad. Namakmalad-e-iduedga soglenaid: 
\d “We-namaked-Alamotʼgi-namaklegoye.” 
\q1  
\v 1 Bab-Dummad anmar-niga-ogannogedid. 
\q2 Bab-Dummad anmar-irwa-gwisguedid. 
\q2 Bab-Dummad wilubdaklegedgi, anmar-bendaked-sunsogedid. 
\q1  
\v 2 Degisoggu, ar neg giglimakde-sogele, anmar dobguosulid. 
\q2 Yala-dummagan demar-wilagangi-dogdedibe, amba anmar dobguosulid. 
\q1  
\v 3 Demar-dummagan-urwedbali, yala-dummagan giglimakdedibe, 
\q2 amba anmar dobguosulid. 
\b  
\q1  
\v 4 Diwar-iirmakemaidi, weligwar Bab-Dummad-e-neggwebur imaked. 
\q2 Weligwar Bab-Dummad-Bur-Birigined-e-neg-Islidikid imaked. 
\q1  
\v 5 Bab-Dummad e-neggwebur-abargi gudiid, degisoggu, e-neggwebur akar-guosulid. 
\q2 Bab-Dummad, neg-oibosale, na e-neggwebur-bendakoed. 
\q1  
\v 6 Bab-Dummad-sunmakdele, dulemar-yar-baid-baidgi-bukwamalad dobguddamalad, 
\q2 neggweburmar-bubukwad giglimakdedaed. 
\q1  
\v 7 Bab-Jehová-Bela-Gangued-Nikad anmarba gudiid, 
\q2 Jacob-e-Bab-Dummad an-dukuedga gued. 
\b  
\q1  
\v 8 ¡Dagmala! Bab-Jehová-e-ibmar-imaksad be dakdamala. 
\q2 We-napneggi-ibmar-dakledisulid-imaksad be dakdamala. 
\q1  
\v 9 Bab-Dummad we-napneg-ugakaase bela bila-onoleged obelosad. 
\q2 Warsimar bibisgisad, eswarmar bibisgisbalid, 
\q2 moli-urmar soogi ogumaksabalid.\fig Warsimar, degi, eswarmar bila-onolegedgi ebuleged. (Salmo 46:9) |src="HK00199B.TIF" size="col" ref="Salmos 46:9" \fig* 
\q1  
\v 10 “Boo be ambikumalo, magar be an-dakmalo, ani an Bab-Dummadid. 
\q2 Dulemar-yar-baid-baidgi-bukwamalad-abargi an-nug odummolegoed, 
\q2 we-napneggi an-nug odummolegoed.” 
\q1  
\v 11 Bab-Jehová-Bela-Gangued-Nikad anmarba gudiid, 
\q2 Jacob-e-Bab-Dummad an-dukuedga gued. 
\c 47  
\s1 Bab-Dummad bela napneg-naid-e-reyd 
\d Coré-wagan we-namaked narmaksad. Namakmalad-e-iduedga soglenaid. 
\q1  
\v 1 ¡Bela-dulamar, argan ogormala! 
\q2 ¡Weligwaledgi binnasuli Bab-Dummad-nug odummomala! 
\q1  
\v 2 Ar Bab-Jehová-Bur-Birigined, dule-buledid, 
\q2 bela napneg-e-rey-dummadid. 
\q1  
\v 3 Neggweburmargi-obinega anmar-imaksad, 
\q2 dule-yar-baid-baidgi-bukmaladgi-nakwega anmar-imaksad. 
\q1  
\v 4 Bab-Jehová, anmarga we-yar susad, 
\q2 we-yar, Jacob-nug-dummarba-imakedid. 
\q2 Bab-Jehová na we-Jacob-wagan-sabgusadid. 
\b  
\q1  
\v 5 Bab-Dummad dulemar-weligwar-oimakmalad-abargi, gar-trompeta-goled-abargi, 
\q2 e-ologanase nakwemai gusad. 
\q1  
\v 6 ¡Namakmala! Bab-Dummadga namakmala. 
\q2 ¡Namakmala! Anmar-reyga namakmala. 
\q1  
\v 7 Ar Bab-Dummad bela napneg-e-reyd. 
\q2 ¡Ise-itoagwar namakmala! 
\b  
\q1  
\v 8 Bab-Dummad dulemar-yar-baid-baidgi-bukmalad-e-reyga maid, 
\q2 Bab-Dummad e-ologan-islidikidgi siid. 
\q1  
\v 9 Dule-dummagan-neggwebur-dakmamaidi, 
\q2 Abraham-e-Bab-Dummad-e-dulamarbo onmaksamalad. 
\q1 Ar dule-dummagan-negdakmamaidi, Bab-Dummadgadid. 
\q2 ¡Bab-Dummad bela-bela odummoleged! 
\c 48  
\s1 Sión-yala, Bab-Dummad-neggwebur-gandikidid 
\d Coré-wagan we-namaked narmaksad. 
\q1  
\v 1 Bab-Jehová, duledar-dummadid. 
\q2 E-neggweburgi, e-yala-isligwaledgi, e-nug-birigined innikigwadba odummoleged maid. 
\q1  
\v 2 Ibiyob Sión-yala yeerdaklege, 
\q2 bela napneg-naid weligwar imaked. 
\q1 Sión-yala, dad-nakwed-argan-sapiledsik-siid, 
\q2 Bab-Dummad-e-neggweburga gued. 
\q1  
\v 3 Bab-Dummadi, Sión-neg-suid-gandikmaladgi, 
\q2 dulemar-edarbedga gued. 
\b  
\q1  
\v 4 Reymar na atosmalad, 
\q2 geb Jerusalénʼgi gwisguargusmalad. 
\q1  
\v 5 Reymar a-neggwebur-dakargu, geger-dakarmalad, abin gwakidmalad, 
\q2 itosur-gwae duurmakdemalad. 
\q1  
\v 6 Emargi bela-belad dobed nagusad, 
\q2 igi sior ugakgunair, e-boniba galitonaidae, 
\q2 debayobi, a-dulemargi dobed nagusad. 
\q1  
\v 7 Dii-burwa-dummadba Tarsis-ulu-dummagan-aibinebayobi, 
\q2 dulemargi dobed nagusad. 
\q1  
\v 8 Igi-anmar-sunnagwad uayagwar epenne na ibmar itosmala, 
\q2 emide, deyob Bab-Dummad-Bela-Gangued-Nikad-e-neggweburgi, anmar na ibyagwar daksamalad. 
\q2 Anmar-Bab-Dummad, na e-neggwebur, degisadegu-sii imakoed. 
\b  
\q1  
\v 9 Bab-Dummad, anmar bese-goled-neggi, 
\q2 be-ise-wile-anmar-dakmaidgi binsabukwadamalad. 
\q1  
\v 10 Bab-Dummad, bela napneg-ugakaase be-nug odummoleged. 
\q2 Be-nuggi nued sunmaklediid. 
\q2 Igar-innikigwadba be negsemaid. 
\q1  
\v 11 Be-igar-innikii-imakedba Sión-yala yeer-itoged, 
\q2 Judá-neggwebur-burwigana weligwar itomarmogad. 
\b  
\q1  
\v 12 Sión-yala be ebirnamalo, 
\q2 binnalee be namalo. 
\q1 E-neg-suigan-bukwad be ebismalo. 
\q2  
\v 13 E-galu-matusurmalad nue be dakmalo, 
\q1 e-neg-gandikmalad nue be argamalo. 
\q2 Adi, yoo be-wagan-danikoedga be we-ibmar sogmalagar. 
\q1  
\v 14 We-Bab-Dummadi, anmar-Bab-Dummad-degisadeguadid. 
\q2 Bab-Dummadi, anmar-idudii sadeguoed. 
\c 49  
\d Coré-wagan we-namaked narmaksad. Namakmalad-e-iduedga soglenaid. 
\q1  
\v 1 Bela bemar, nue an-itomar. 
\q2 Bela bemar, we-napneggi-bukmalad, nue be an-itomar. 
\q1  
\v 2 Dule-dummagan, dule-binsarmalad, 
\q2 dule-mani-nikamalad, dule-wilegana, nue be an-itomar. 
\q1  
\v 3 An sunmakoedi, nue-binsaed-nikaa an sunmakoed. 
\q2 An-ulubgi-binsaedi, nue-magar-itole an sogoed. 
\q1  
\v 4 Ibmar-binsaed-nikaa-soglemalad nue-itoakwaa an sogoed. 
\q2 Gar-arpa-ogorsiidgi we-ibmar-soglegoed-e-obared an bega odulogoed. 
\b  
\q1  
\v 5 Ar bonigan dani-sogele, ¿ibiga dobee an itogoe? 
\q2 Dule-isganamar an-ebilis ambikunonimalale, ¿ibiga an dobguoe? 
\q1  
\v 6 Dule-mani-nikadba-dobsuli-itodimalad, na e-ibmar-nikadba san-dummarba-imakdimalad, 
\q2 ¿a-dulemarde an dobguode? Suli, an dobguosuli. 
\q1  
\v 7 Dule wargwensaale na dukin bendakosulid. 
\q2 Na dukin burgwedgi san-onogegala, 
\q2 geg Bab-Dummad-bennuked. 
\q1  
\v 8 San-onolegedi gargesailad. 
\q2 San-onolegegala, mani unniguarsulid. 
\q1  
\v 9 Dule degisadegu dula-gudii guosulid. 
\q2 Dule burgosurdeeye sogsulid, burgwedsegad. 
\q1  
\v 10 Bela dulemar burgwedbiid, 
\q2 dule-binsaed-ibedi, dule-binsaedsulidi, bela burgwedsemalad. 
\q2 E-ibmar-nikadi dulemar-baiganga beoed. 
\q1  
\v 11 Ar nainu ichesur-nikus-inigwele, 
\q2 neg-uangi degisadegu mai guoed. 
\q1  
\v 12 Ar dule mani-ibed-inigwele, degisadegu dula-gudiguodeeye sogsulid. 
\q2 Ibdurganyobi burgwemarmogoed. 
\b  
\q1  
\v 13 Weyobi, dulemar e-manigi-alakwaa-gudimaladi, berguddamalad. 
\q2 Na dukin san-dummarba-imakmaladi, weyobi, berguddamarmogad. 
\q1  
\v 14 Igi sibad-iduged e-sibad-wawaad-semaidae, 
\q2 deyobi, burgwed we-dulemar-semai gumogoed. 
\q1 E-neg-dummagan-nuegan-daklemaladgi, dikasuli e-mui neg-uangi nungumai guoed. 
\q2 Yoedsega dule-nuegan negsemamai gumaloed. 
\q1  
\v 15 Ar Bab-Dummaddi burgwedgi an-ollorsaoed, 
\q2 Bab-Dummad eba an-sedoed. 
\b  
\q1  
\v 16 Dule-wargwen mani-ibedga-gudele, mer bai be dako, 
\q2 e-neg yeerdakle nadele, mer geg be dako. 
\q1  
\v 17 Ar we-dule burgwidele, na e-ibmar sedosulid, 
\q2 e-ibmar-yeerdaklemalad eba naosulid. 
\q1  
\v 18 Ar we-napneggi dula-gudigua, weligwar itodigus-inigwele, 
\q2 dulemar e-nug-odummodigusmar-inigwele, 
\q1  
\v 19 we-dule, e-babgan-burgwismogayobi, burgwemogoed, 
\q2 we-napneggi bar gudii guosulid. 
\b  
\q1  
\v 20 Ar dule mani-ibed-inigwele, na aku itoged, 
\q2 ede ibdurgan-burgweyobi, burgwemogoed. 
\c 50  
\s1 Bab-Dummad igar-nabononikoed 
\d Asaf, we-namaked narmaksad. 
\q1  
\v 1 Bab-Jehová, Bab-Dummadbi-maidi, goled: 
\q2 Dulemar-dad-nakwedsik-bukmaladse goled, 
\q2 dulemar-dad-argwanedsik-bukmaladse, onmakega goled. 
\q1  
\v 2 Bab-Dummad, Sión-neggwebur-yeerdaklegedba, 
\q2 dad-ibeler-gaeyob, e-maid oyomaid. 
\b  
\q1  
\v 3 Anmar-Bab-Dummad-danikidi boo danisulid, 
\q2 e-iduale, soo-dummadi gadanikid, 
\q1 bela ibmar-ogumakdanikid. 
\q2 Burwa-oored bela Bab-Dummad-ebiris danikid. 
\q1  
\v 4 Bab-Dummad nibnegse gochad, napnegse gochabalid, 
\q2 e-dulamarga-igar-nabolesokalid dakdamalagar. 
\q1 Bab-Dummad weyob soged: 
\q2  
\v 5 “Anga dule-islidik-gudimalad onmakmalo, 
\q2 dulemar ibmar-ogumakar-uklegedgi anbo-igar-mesismalad, anga onmakmalo.” 
\q1  
\v 6 Nibneg soged: 
\q2 Bab-Dummad dulega igar-naboged-innikigwad maiye. 
\b  
\q1  
\v 7 “Israel-dulemar, an-itomala, 
\q2 an-sunmaksokalid nue-itomala. 
\q2 An-dulamar, an begi sunmaksokalid: 
\q1 Ani an be-Bab-Dummadid, 
\q2 unnila, anbi Bab-Dummad maid. 
\q1  
\v 8 Bemar anga ibmar-ogumakar-ukdamaladgi an yolesulid. 
\q2 Bemar anga gusgu ibmar-nued-ukdamaladgi an yolesulid. 
\q1  
\v 9 Be-moli-bebe-nikad-sapingana e-galugi-bukwadbina an sogsulid. 
\q2 Be-sibad-machergan e-galugi-bukwadbina an sogsulid. 
\q1  
\v 10 Ar bela ibmar-durgan-sapurba-bukwad, angadbiid, 
\q2 bela molimar-yalaganba-bukwad, angadbiid. 
\q1  
\v 11 Bela nuumar-sapurba-bukwad angi yoggusisulid, 
\q2 bela ibmar-durgan-yalaganba-gudinanaed, angadbiid. 
\q1  
\v 12 Degisoggu, an mas-gunbiele, an bese gochasuliled. 
\q2 Ar bela we-napneg, angadbiid, 
\q2 bela ibmar-we-napneggi-bukwad, angadbiid. 
\q1  
\v 13 ¿Ar moli-bebe-nikad-e-san-gunnedgi an gudisi? 
\q2 ¿Ar sibad-machered-e-ablis-gobedgi an gudisi? 
\q1  
\v 14 Anga weligwaledgi dog-nuedye be sogdage. 
\q2 Anga, Bab-Dummad-Bur-Biriginedga be ibmar-imakoye-sogsad, be imakdage. 
\q1  
\v 15 Bonigan-abalagi be gunaidgi, anse be gole, 
\q2 an be-bendaknonikoed. 
\q2 Bedi be an-nug-odummogoed.” 
\b  
\q1  
\v 16 Bab-Dummad dule-isganagardina, weyob soged: 
\q2 “¿Doa bega soge, An-Igar-Maid be absogoye? 
\q2 ¿Doa bega soge, An-Igar-Maidgi be sunmakoye? 
\q1  
\v 17 Ar be durdakleged-igar abesulid. 
\q2 An-gayaburba be isdarsun-daked. 
\q1  
\v 18 Ar be atursamalad-dakardibe, eba be naddaed, 
\q2 dule-gambasamalad nabir be daked. 
\q1  
\v 19 Be-gayadina ibmar-isganagi sulibinsa sunmaked, 
\q2 be-gwabindukudina, unnila, gakansaedginbi sunmaked. 
\q1  
\v 20 Ar be-gwenadgi gusgu be yolegar sunmaked, 
\q2 amba be-gargwenadgine be gakansabalid. 
\q1  
\v 21 Bela be we-ibmar-imaksadba, an bese gochasulid. 
\q2 Ande beyobye, ¿be binsasunde? 
\q1 Emisgindi, an bese urwoed. 
\q2 Bega an bakar ibmar sogoed. 
\q1  
\v 22 Bemar an-ieddamalad, 
\q2 an bega ibmar-sogsad nue egi be binsamalo. 
\q1 Degisulile, anse be ibitomaloed, 
\q2 dule-wargwensaale be-bendakosurmalad. 
\q1  
\v 23 Dule anga dog-nuedye-sogega, ibmar-nued-ukedi, an-nug odummoged. 
\q2 Dule na e-daed ogwaele, an ega abonoleged-igar oyononikoed.” 
\c 51  
\s1 Bab-Dummadse isgusad-ular wilenaid 
\d David Betsabéʼbo galagwensuli-gusad-sorba, 
\d Bab-Dummad-gayaburba-barsoged-Natán Davidʼse arbid. 
\d A-sorbali, David we-namaked narmaksad. Namakmalad-e-iduedga soglenaid. 
\q1  
\v 1 Bab-Dummadye, be dule-wiledakedba, be wile-an-dake. 
\q2 Be bela-bela-dule-sabedba, an-isgued be anga elie. 
\q1  
\v 2 Bela an-ibmar-isgana-imaksad be anga obeloge. 
\q2 Bela an-isgued be anga osuloge. 
\b  
\q1  
\v 3 An ibmar-noar-imaksadi an magar itoged, 
\q2 an-isgusad an nue wisid. 
\q1  
\v 4 Bab-Jehová, beginbi, unnila beginbi an isgusad. 
\q2 Be-asabin an ibmar-isgana imaksad. 
\q1 Agala, be-igar-nabogedgi be-igar-mesedi innikigwadid. 
\q2 Be-igar-naboged dule geg egi akarsoged. 
\q1  
\v 5 An gwalulesad-akale, an dule-isgana gued, 
\q2 an sapibeneggi-maigusad-akale, bato an dule-isguedid. 
\q1  
\v 6 An nue-wisid, be dule-inniki-gudiid nue-sabed. 
\q2 Burbale, nue-binsaed-nikadaed be an-odurdaksad. 
\b  
\q1  
\v 7 An swilidik-guega, hisopo-gagangi be an-nudake. 
\q2 An boo-sibudikidba bur bule sipuu guega, swilidik be an-imake.\fig Hisopo-gagan (Salmo 51:7) |src="HK00114B.TIF" size="col" ref="Salmos 51:7" \fig* 
\q1  
\v 8 Weligwar be an-imake, yeer-ito be an-imake, 
\q2 be an-san-sabsur-odurdaksad gannar yeer-itoge be imake. 
\q1  
\v 9 An-isgued mer be bar ebinsae, 
\q2 an-ibmar-isgana-imaksad bela be osuloge. 
\b  
\q1  
\v 10 Bab-Dummadye, gwage-swilidikid be anga nasike. 
\q2 Burba-swilidikid be anga uke. 
\q1  
\v 11 An be-walik-gudiidgi mer be an-ononnoge. 
\q2 Be-Burba-Isligwaled mer be angi obane. 
\q1  
\v 12 Be-abonolegedgi-weligwar-itolegedi, gannar be anga udage. 
\q2 Uaya-nikadae be an-imake. 
\b  
\q1  
\v 13 Geb deyobi, be-igar-maidgi-yoledimalad an be-igargi odurdakoed, 
\q2 geb dule-isgudimalad gannar bese nonimaloed. 
\q1  
\v 14 An-Bab-Dummad-an-abonogedye, an dule-ibe-ablis-eosadgi be an-ollorsae, 
\q2 adi, an be-igar-innikigwadgi namakdii guegar. 
\b  
\q1  
\v 15 Bab-Dummadye, an be-nug odummogega, 
\q2 ibmar-biega be an-imake. 
\q1  
\v 16 Ibmar-ukleged an bega-ukele, be yeerdakosulid. 
\q2 Ibmar-durgan-ogumakar-ukleged an bega-ukele, be abingaosulid. 
\q1  
\v 17 Ar begardi, dule-na-e-isguedga-wile-itogedi, ibmar-uklegedba bur-nued gued. 
\q2 Bab-Dummad, dule-na-e-isguedga-bukib-itogedi, bedi isdar daksulid. 
\b  
\q1  
\v 18 Be-nued-binsaedbali, Sión-neggwebur-nasgumai be imake. 
\q2 A-Jerusalén-neggwebur-e-galu-dummagan be gannar ogwiche. 
\q1  
\v 19 Geb be-igar-mesisadba-ibmar-bega-ukleged be abingaoed. 
\q2 Ibdurgan-bela-gwagwar-ogumakar-bega-uklegedi be yeer dakoed. 
\q2 Geb moli-bebe-nikad-sapingan bega-ibmar-ogumakar-ukleged-ailagi ukledoed. 
\c 52  
\s1 Dule-isgudiid, binsa san-odummodiid 
\d David we-namaked-Masquilʼye nugad. 
\d Deunni, Edomʼgined-Doeg Saúl-owisonadgu: 
\d David Ahimelec-negse nadye. Namakmalad-e-iduedga soglenaid. 
\q1  
\v 1 Be, na-san-buled-imaked, ¿ibiga be-isguedgi be san-dummarbaa imake? 
\q2 ¡Bab-Dummaddi dule-sabgumaiguad! 
\q1  
\v 2 Be-gwabin-duku, esbipi-nugar-datarmakaledyobid, emar-obelogedginbi binsaed, 
\q2 gakanginbi sunmaked. 
\q1  
\v 3 Igar-nuedba bur bule, igar-isganabina be soged. 
\q2 Igar-nabiridba bur bule, gakansaedbina be itoged. 
\b  
\q1  
\v 4 Gakansaed-gwabin-duku be sediid. 
\q2 Be-sunmakedgi emargi-urwed be yeer itodaed. 
\q1  
\v 5 Bab-Dummaddi, ilagwen-be-obelogar imakoed. 
\q2 Be-negyaurgi be-onogoed, we-napneggi be-obelogoed. 
\b  
\q1  
\v 6 Dule-nuegan, we-ibmar dakmaloed, 
\q2 nue-dobee itodmaloed. 
\q1 Weyob be-annik dodoakwaa sunmakdemaloed: 
\q2  
\v 7 “We-dule-isgana, Bab-Dummadgi-bendakleged-amissulid, be dakmala. 
\q1 Unnila ibmar-nue-nikadba na yeer itosad, 
\q2 e-ibmar-isgana-imakedgi gwen bangussulid.” 
\b  
\q1  
\v 8 Andi, Bab-Dummadse-goled-neggi olivo-sapi-durbamakar-daedyob gued. 
\q2 Andi, degisadegu, Bab-Dummad-e-sabguedgi bensulid. 
\b  
\q1  
\v 9 Bab-Dummad, andi be-ibmar-imaksadba be-nug-odummodii guoed. 
\q2 Bede dar dule-nuedsoggu, begine an bensuli gudioed. 
\q2 Dule-nuegan-abargi an bese gordii guoed. 
\c 53  
\s1 Dule-ibmar-isgana-imakmalad 
\r (Salmo 14:1-7) 
\d David namakmalad-e-iduedga we-namaked narmaksad. 
\q1  
\v 1 Dule-binsaedsulidaed, e-gwagegi sogdiid: 
\q2 “Bab-Dummad maisurye.” 
\q1 We-dulemar nue-isgusgudidimalad, unnila ibmar-isganabi imakdidimalad. 
\q2 ¡Bipisaale dule ibmar-nued-imaked sated! 
\b  
\q1  
\v 2 Bab-Dummad, nibneg-akale dulemar-napneggi-bukmalad dakded, 
\q2 abakalegi, dule-wargwen binsaed-nikadaed gudiile, 
\q2 abakalegi, wis dule-wargwensaar Bab-Dummad-amibied gudiile. 
\q1  
\v 3 Bab-Dummad dakalid, 
\q2 bela dulemar egi bangus gudidimala, 
\q2 bela nue-isgus gudidimala. 
\q1 Wargwensaale ibmar-nued-imaked suli, 
\q2 bipisaale wargwengiid ibmar-nued-imaked, sate. 
\b  
\q1  
\v 4 Dule-ibmar-isgana-imakdimalad akusunna itomalad, 
\q2 amarde, madu-gunneyob an-dulamar-imakdimalad, 
\q2 Bab-Dummadse gordisurmarbalid. 
\q1  
\v 5 Dule-isganamar dobguewilubsurmalanad, 
\q2 degite, bela-bela dobedba wawanmakdemaloed. 
\q1 Bab-Dummad we-dulemar-obachadbali, be-isdarmalad-e-garmar oaisakioed. 
\q2 Bab-Dummad dule-isgana obingesaoed. 
\b  
\q1  
\v 6 Bitigi Israel-neggwebur-bendakleged Sión-yar-akar danikina gadin. 
\q2 Bab-Dummad na e-dulamar gannar e-yarse senonikile, Jacob-e-wagan wergudmaloed, 
\q2 Israel-dulemar weligwar itodmaloed. 
\c 54  
\s1 Bab-Dummadse bendakleged egisnaid 
\d David we-namaked-Masquilʼye-nugad narmaksad. 
\d Namakmalad-e-iduedga soglesad: Neginotʼba-namakoye. 
\d Deun Zif-dulemar Saúlʼga sognonimargu: 
\d David anmar-abargi dukudiiye. 
\q1  
\v 1 Bab-Dummadye, be an-bendake, 
\q2 be-nug-dummarba-maidba be an-bendakdage. 
\q2 Be-ganguedgi be an-bendakdage. 
\q1  
\v 2 Bab-Dummadye, an-gornaid be an-itoge, 
\q2 an bega-ibmar-sognaid wis be an-itoge. 
\q1  
\v 3 Ar dule-galagwensurdamaladi, angi gwisgunanaid. 
\q2 Ar dule-sabesulidamaladi, an-oburgwega anbina gudimalad. 
\q2 Ar we-dulemar, bipisaagwar begi binsadisurmalad. 
\b  
\q1  
\v 4 Bab-Dummadbi unnila an-bendakedid, 
\q2 Bab-Dummadbi unnila an-sediid. 
\q1  
\v 5 Bab-Dummad an-isdarmaladgi bonigan-yolegega imakoed. 
\q2 Bab-Dummadye be inniki-ibmar-imakmaidba, bela be an-isdarmalad oburgwe. 
\b  
\q1  
\v 6 Bab-Dummad, an bebina-sogedba ibmar-nued an bega ukoed. 
\q2 Bab-Jehová, an be-nug odummogoed, ar deyob-imaked ibnuedid. 
\q1  
\v 7 Bab-Dummad, bela bonigangine be an-ollor-imaksad. 
\q2 An-isdarmalad-galakued-dakega be an-imaksabalid. 
\c 55  
\s1 Balegillediidba-Babse-goled 
\d David we-namaked-Masquilʼye-nugad. 
\d Namakmalad-e-iduedga soglesad: Neginotʼba namakoye. 
\q1  
\v 1 Bab-Dummadye, an bese-goled be an-itoge, 
\q2 an bese-wilenaid mer be an-itosuli gue. 
\q1  
\v 2 Be an-itoge, be an-abin-imake. 
\q2 Ar an-surbinsa-itogedi, anga gwage-bogidikid uksulid. 
\q1  
\v 3 Dule-isdarmalad-sabsur-ibmar-soged an dobe itoged, 
\q2 dule-isganamar-e-sabsur-dule-imaked wile-ito an-imaked, 
\q2 ar gakansaar angi sunmakmalad, nue-urwedgi an-baleginmalad. 
\b  
\q1  
\v 4 Ulubgi gwage nunmak an itoged, 
\q2 angi bela-bela dobe-burgwed nagunonikid. 
\q1  
\v 5 Dobedbali an wawanmakgwichid, 
\q2 bela-bela an dobe itoged. 
\q1  
\v 6 Geb an-sogsad: “¡Nuuyobi an sakan-nikana gadin! 
\q2 Adi, an gukusaled. Obunnoged-neg an aminadeled. 
\q1  
\v 7 An wegine dikasur wakiteled, 
\q2 nega-dulesulidgangi an megisaled. 
\b  
\q1  
\v 8 ”Burwa-dummad-idu-wakinnega, 
\q2 dukued-negse an gwae wakiteled.” 
\b  
\q1  
\v 9 Bab-Dummadye, we-dulemar be obeloge, 
\q2 e-sunmakmalad aku-ito be imake. 
\q1 Ar unnila neggweburgine sabsur-imakmaladbi, 
\q2 abin-abin-imakmaladbi an daked. 
\q1  
\v 10 Mutiki, ibgine, e-galu-matusulid-ebirdii damalad, 
\q2 e-galu-matusulid-yabali ibmar-isganabi, yamo-dulemar-yardakedbi neg naid. 
\q1  
\v 11 E-galu-matusulidgindi dule-obelogedbi neg naid, 
\q2 e-igar-imbaganbardi dule-wiogedbi, dule-yardakedbi neg naid. 
\b  
\q1  
\v 12 Ar an-isdarad an-obinge-imaksana, an na san bargasanad. 
\q2 Ar dule-isdar-an-daked mesagwar an-imaksana, an e-idu dukusanad. 
\q1  
\v 13 Ar emigindi, bee be weyob an-imaksad. 
\q2 Be an-ai-nuedid. Be anyob dule gumogad. 
\q1 Be an-sordad, be an-ai-bur-walikagwadid. 
\q2  
\v 14 Be nuedgi anbo-walikaa gudidaenad, 
\q1 ai-nuedgi be anbo Bab-Dummadse-goled-neggi gudidaenad. 
\q2 Emigindi, bee be angi weyob yolesad. 
\q1  
\v 15 Burgwed ukiagwar an-isdarmaladgi yolesunna, 
\q2 neg-uangi napa-yaba dula odelesunna, 
\q2 ar e-neg-yaurgi ibmar-isganabi nikad. 
\b  
\q1  
\v 16 Ar andi Bab-Dummadse goloed, 
\q2 Bab-Jehová an-bendakoed. 
\q1  
\v 17 Wakdaradba, yorukudba, mutikidba an surbinsa-itogedgi Bab-Dummadse goloed, 
\q2 edi an-itogoed. 
\q1  
\v 18 Ar dulemar bukidar angi aibinmar-inigwele, 
\q2 Bab-Dummaddi bogidikidgi angi-bila-ononanaidgi an-onogoed. 
\q1  
\v 19 Bab-Dummad-gusgu-dummadga-maiguad an-itogoed. 
\q2 Bab-Dummad an-isdarmalad ibgwensur-imakoed. 
\q1 Ar wemar na e-daed ogwasurmalad, 
\q2 gwen Bab-Dummad dobsurmarbalid. 
\b  
\q1  
\v 20 Dule-isgana dule-ebo-nued-gudiidgi aibined, 
\q2 e-igar-mesisadgine annaed. 
\q1  
\v 21 Na e-ibmar-sogedi ochii ibmar-nueganbi soged. 
\q2 E-gwagegindi bila-onogedginbi binsanaid. 
\q1 Na e-sunmakedi, innikii sunmak itolegenad. 
\q2 Degi-inigwele, esyobi dule-naibi-imaked. 
\b  
\q1  
\v 22 Bab-Jehováʼga, be-bukib-binsaed be soge, na e be-bendakoed. 
\q2 Ar Bab-Dummad, dule-nued degisadegu-galakudii imakosulid. 
\b  
\q1  
\v 23 Bab-Dummad, bedi dule-isganamar oburgoed, 
\q2 napa-gullu-yaa be barmetoed. 
\q1 Dule-ablis-eodimaladi, dule-emar-yardakdimaladi, undar-dikasur dula-gudii guosurmalad. 
\q2 Ar andi begi bensulid. 
\c 56  
\s1 Bensulidgi Bab-Dummadse-goled 
\d Namakmalad-e-iduedga soglesad: 
\d Sapur-nuu surgar-war-birgi namaksidaedba namakoye. 
\d Deunni, Filistea-dulemar Gat-neggweburgi David-gasgusmalad. 
\d Agi David Mictam-narmaksad. 
\q1  
\v 1 Bab-Dummadye, wile be an-dake, 
\q2 dulemar an-balegindii nanaed. 
\q2 Bane-bane sae-an-dakmaladi, an-wiodimalad. 
\q1  
\v 2 Bane-bane an-isdarmaladi, an-balegindii nanaed. 
\q2 Dule-san-dummarba-imakdimaladi, bukidar angi gwisgudimalad. 
\b  
\q1  
\v 3 An dobe-itoalile, 
\q2 begi an benguosulid. 
\q1  
\v 4 Bab-Dummad, an begi bensulid, 
\q2 an be-gayaburba odummoged. 
\q1 Bab-Dummad, an begi bensulid, 
\q2 an dobe-itosulid. 
\q1 Degisoggu, ¿ar igi dule an-imakosunna? 
\q2 Dule akar an-imakosulid. 
\b  
\q1  
\v 5 Bane-bane an-sunmaked oakaloddamalad, 
\q2 gusgu an-oakalogedgi binsadamalad. 
\q1  
\v 6 Danakwaa ambikusdamalad, 
\q2 na dukusdamalad. 
\q1 An-oburgwed na yeer-itomalad. 
\q2 Yamo arbakee an-ibmar-imaked dakdimalad. 
\q1  
\v 7 Bab-Dummad, we-dulemar be sabsur-odurdaksun. 
\q2 Melle begi wakinnega be imako. 
\b  
\q1  
\v 8 An-bukib-binsadiid be nue-wisid. 
\q2 An-ibyanis-aryodiid be daksabalid 
\q1 ¿Ar we-ibmar be-gardagi narmakar maisursi? 
\q2  
\v 9 An-bendakega na bese gotele, an-isdarmalad duurmakdoed. 
\q1 Ibmar-soggwen an wisid: 
\q2 Bab-Dummad, nue anba naid. 
\q1  
\v 10 Bab-Dummad, an begi bensulid, 
\q2 be-gayaburba an odummoged. 
\q1 Bab-Jehová, an begi bensulid, 
\q2 be-gayaburba an odummoged. 
\q1  
\v 11 Bab-Dummad, an begi bensulid, 
\q2 an dobe-itosulid. 
\q1 Degisoggu, ¿ar igi dule an-imakosunna? 
\q2 Dule akar an-imakosuli. 
\b  
\q1  
\v 12 Bab-Dummad, an be-asabinni ibmar-saoye-an-sogsadi, angi siid. 
\q2 Ibmar-uklegedi, an bega ukoed. 
\q1  
\v 13 Bab-Dummad, burgwedgi be an-ollorsasad. 
\q2 Igar-bulegangi be an ollor-imaksad. 
\q2 Adi, be-asabinni, neg-meegwadgi dula-nanadii guegar. 
\c 57  
\s1 Dule-an-baregindimaladgi be an-ollorsae 
\r (Salmo 108:1-5) 
\d David, Saúl-idu akwasaila-ollo-yaba dukudigusgu, we-namaked narmaksad. Namakmalad-e-iduedga soglesad: 
\d We-namaked, Melle-obelogoye-nugad-namaklegeyobi, namakoye. 
\q1  
\v 1 Bab-Dummadye, wile be an-dake, 
\q2 Bab-Dummadye, wile be an-dake, ar begi an bensulid. 
\q1 Igi gannir e-sakan-urba na e-mimmigan odukue, 
\q2 deyobi, bonigan-berguedse, be an-odukue. 
\b  
\q1  
\v 2 Bab-Dummad-Bur-Biriginedse an binnasuli goled. 
\q2 We-Bab-Dummad angi nued binsamaidaed. 
\q1  
\v 3 Bab-Dummad, dule-an-isdarad-an-baregindiidgi-an-bendakega, e-gangued, nibneg-akar anse oyogoed. 
\q2 Bab-Dummad e-sabgued, e-igar-napiragwad anga oyomaid. 
\b  
\q1  
\v 4 Achumiguryobi, dulemar an-ebiris bukwamalad, 
\q2 dulemar an-obelobimalad. 
\q1 E-nugarmar, sigumaryobi, warsimaryobi, nanaed. 
\q2 E-gwabin, es-suid-datarmakaleyobi gued. 
\b  
\q1  
\v 5 Degi-inigwele, Bab-Dummad, bedi nibneggi maid. 
\q2 Be-gangued-yeerdakleged bela we-napneg-gani naid. 
\b  
\q1  
\v 6 An-iduar saki nasiksamalad. 
\q2 An-iduar yaa gwichamalad. 
\q1 Naibid-dummad anga uksamalad. 
\q2 Degi-inigwele, emar agi na dukin argwachamalad. 
\q1  
\v 7 Bab-Dummad, bega namakmalad-namakega, 
\q2 an-gwage guagwar naid. 
\q1  
\v 8 An wakudaryalaba gwisgudagoed. 
\q2 An atakalile, gar-arpa, gar-lira, an ogoloed. 
\q1  
\v 9 Bab-Dummad, neggweburmar-baigan-abargi be-nug an odummogoed, 
\q2 dulemar-baigan-abargi bega an namakoed. 
\q1  
\v 10 Ar be-sabgued dummarbasoggu, nibnegse warmaked. 
\q2 Be-ibmar-napira-soged nibnegse warmaked. 
\b  
\q1  
\v 11 Bab-Dummad, bedi nibneggi maid. 
\q2 Be-gangued-yeerdakleged bela we-napneg-gani naid. 
\c 58  
\s1 Dule-isganamar-sabsur-odurdakega Babse goled 
\d David we-namaked-Mictam narmaksad. Namakmalad-e-iduedga soglesad: 
\d We-namaked, Melle-obelogoye-nugad-namaklegeyobi, namakoye. 
\q1  
\v 1 Bemar, dule-bulegan-negsedidimalad, ¿ar innikigwadba be negsemamai? 
\q2 ¿Ar innikigwadba be dulemarga igar-nabomamai? Suli. 
\q1  
\v 2 Aka bemar na be-gwagegi, unnila ibmar-isgana-imakedgi binsadidimalad. 
\q2 Ar bemar, we-napneggi unnila sabsur-ibmar-isgana-imakdidimalad. 
\q1  
\v 3 Dule-isganamar amba sapibeneggi-maid-akale, bato isgus danimalad. 
\q2 Dule-gakansilimar amba yoo-gwaluleged-akale, bato gakansaar sunmakmalad. 
\q1  
\v 4 E-sunmaked boni-dummad sediid 
\q2 naibe-boni-nikadyobi gudiid. 
\q1  
\v 5 Dule-naibe-gaed, naibega sunmaknaigusale, igi-we-naibe, yamo uayasulidaeyob na imake, 
\q2 deyobi, dule-isgana, uayasulidaedba ibmar-isgana imaked. 
\b  
\q1  
\v 6 Bab-Dummad, dule-isgana-e-nugarmar be bibisge, 
\q2 achumigur-ibe e-nugarmar-ungeyob be imake, 
\q2 dule-isgana-e-gargangued be obeloge. 
\q1  
\v 7 Igi dii napagi-mileder, yogguddae, 
\q2 deyob geg gumargina. 
\q1 E-warsi-dopee-imakdemalale, 
\q2 bitigi e-sigu geg bisgegina. 
\q1  
\v 8 Igi gole-masi-masid baisursunna berguddae, 
\q2 dule-isgana deyob geg gumargina. 
\q1 Igi goe-burgwar-aidenonikid, gwen neg dakdasuli, 
\q2 deyob dule-isgana geg gumargina. 
\q1  
\v 9 Igi gagan-ikobiid-dinnagana sabsur-gummakdedae, 
\q2 deyobi, dule-isganamar baisur-binsadiidgi gummakena gadin. 
\q2 Dule-isganamar dula-gudimaladgi, bitigi burwa-dummadba selemalana gadin. 
\b  
\q1  
\v 10 Dule-inniki-gudiidi, dule-isgana-sabsur-odurdaklenai dakalile, weligwar itodoed. 
\q2 Dule-isganamar-e-ablisgi dii-dii annanai guoed. 
\q1  
\v 11 Agine, dulemar sogdemaloed: “Napirado. Dule-inniki-gudimaladga ibmar-nued ega ukleged. 
\q2 Bab-Dummad nue-mai dakledo, ar we-napneggi bela dulemarga igar innikii nabomaid.” 
\c 59  
\s1 E-isdarmaladgi e-ollorsaega Babse-goled 
\d David we-Mictam-namaked narmaksad. Namakmalad-e-iduedga soglesad: 
\d We-namakedi, ar igi namaked “Melle-obeloged” namaklege, deyobi namaklegoye. 
\d Deunni, Saúl, David-oburgwega e-sordamar David-negse barmisgu. 
\q1  
\v 1 Bab-Dummadye, an-isdarmaladgi be an-ollorsae, 
\q2 angi aibinmaladgi be an-bendake. 
\q1  
\v 2 Dule-ibmar-isgana-imakmaladgi be an-ollorsae, 
\q2 dule-gindakmaladgi be an-bendake, 
\q2  
\v 3 ar an-oburgwebimalad. 
\q1 Bab-Jehová, an nossulinad, an isgussurbalinad, 
\q2 degite, dule-isganamar angi-aibinmalaga na atosmalad. 
\q1  
\v 4 An ibmar-isgana imaksasur-inigwele, degite, an-oburgwebimalad. 
\q2 Bab-Jehováʼye, be gwae-dage, be an-bendakdage. 
\q2 Be dake, igi an be-asabin gwichi. 
\q1  
\v 5 Bab-Jehová, be, Bab-Dummad-Bur-Gangued-Nika-Maid. 
\q2 Be, Israel-e-Bab-Dummadid. 
\q1 Dule-yar-baid-baidgi-bukwamalad-sabsur-odurdakega gwae be dage, 
\q2 dule-isgana-emargi-aibinmalad, mer be wiledake. 
\b  
\q1  
\v 6 Dule-isganamar, mutikidbali achumar-urwedidaedyobi gannar nonidamalad, 
\q2 geb neggweburgi bipirmakdidamalad. 
\q1  
\v 7 Yogasaar sunmakmalad, emargi yolegar sunmakmalad. 
\q2 An-itogosurmaladdeeye sogdedamalad. 
\q1  
\v 8 Bab-Jehová, ar bedi we-dulemarga be alled, 
\q2 bela dule-yar-baid-baidgi-bukwamaladgi be dodoged. 
\q1  
\v 9 Ar be an-ganguedsoggu, an begi bensulid. 
\q2 Ar be an-odukuedid. 
\q1  
\v 10 Be, Bab-Dummad-wile-an-daked an-iduoed. 
\q2 Bab-Dummad an-isdarmalad-galakued anga oyogoed. 
\q1  
\v 11 An-dulemar mer a-dule-isganamar-iegega, 
\q2 mer ilagwen-obelogar be imako. 
\q1 Be, Bab-Jehová, sigu-abgaedyob an-irwa-gwisguedid. 
\q2 Be-ganguedgi be oaisakie, 
\q2 be-garganguedgi be irgwensur-imake. 
\q1  
\v 12 Na e-ibmar-isgana-sogedba, e-sunmakedba, emar-ukabsaedba, e-gakansaedba, san-dummarba-imakdimaladba, 
\q2 na dukin yardaklemarsun. 
\q1  
\v 13 Bab-Dummad, urwedgi be amar-obeloge, 
\q2 mer bar dulagudigumalaga be obeloge. 
\q1 Deyobi, bela Israel-yargine wisgumaloed, 
\q2 Bab-Dummad bela we-napneg-ugakaase, negdakmaiye. 
\b  
\q1  
\v 14 Dule-isganamar, mutikidbali achumar-urwedidaedyobi gannar nonidamalad, 
\q2 geb neggweburgi bipirmakdidamalad. 
\q1  
\v 15 Masgunned-amiega gaamakdidamalad, 
\q2 immelessurmalale, mutikidba urwedidamalad. 
\b  
\q1  
\v 16 Bab-Dummad, ar andi be-ganguedgi an namakoed. 
\q2 Wakudaryalaba be-dula-wiledakedgi an namakoed, 
\q1 ar bedi an-bendakedid. 
\q2 An-surbinsa-itoged-ibagi bedi an-dukuedid. 
\q1  
\v 17 Be, an-ganguedid, an bega namakoed, ar bedi, Bab-Dummad, an-dukuedid. 
\q2 Bab-Dummad, be an-sabedid. 
\c 60  
\s1 Bab-Dummadse bendakleged-egised 
\r (Salmo 108:6-13) 
\d Namakmalad-e-iduedga soglesad: 
\d Bab-Dummad-Dulemarbo-Igar-Mesisad-e-dutu-lirio-nugadba namaklegoye. 
\d Deunni, Aram-Naharimʼgi, degi, Aram-Sobaʼgi bila-ononaidgi, 
\d Joab gannar nonigu, Balu-Nebagi miliambe-gakabo (12,000) Edomʼginmalad ogilosad. 
\d Agi, David dulemar-odurdakega namaked-Mictam narmaksad. 
\q1  
\v 1 Bab-Dummad, bedi anmarse ulusad, 
\q2 be anmar-obachad, 
\q1 be anmar-wiosad. 
\q2 ¡Bab-Dummadye, be anmar-bendakdage! 
\q1  
\v 2 Napneg-naid yeer be ogiglimaksad, 
\q2 yeer napamar argas-nanaed. 
\q1 E-yaa-argasmaladi be nudake, 
\q2 ar binna-binna babatemaigusad. 
\q1  
\v 3 Yeer-gangu be-dulamar be wilubdaksad, 
\q2 vino-gagbid-gobega be anmar-imaksad. 
\b  
\q1  
\v 4 Dule-sigu-miemaladgi san-onogega, 
\q2 beba-inniki-nanadimaladgala, igar-inniki-maid be oyosad. 
\q1  
\v 5 Be-dulamar-be-nue-sabedi, nabir bendaklegega, 
\q2 be-ganguedgi be anmar-bendake, 
\q2 be anmar-abinsae. 
\b  
\q1  
\v 6 Bab-Dummad, be-neg-islidikidgi be weyob sogsad: “An Siquem-neggwebur-mimioedgi, weligwale an itoged. 
\q2 An Sucot-neba-naid-ilemakoedgi, weligwale an itoged. 
\q1  
\v 7 Galaad, angadga gued, 
\q2 Manasés, angadga gued. 
\q1 Efraín, an-bormo-gurginga gued. 
\q2 Judá, an-gaapoledga gued. 
\q1  
\v 8 Moab, an-argan-enukedga gued. 
\q2 Edomʼgi, an-sapat bikiin an metoed. 
\q2 Filistea-neggweburgi, gandikidba an gormakoed.” 
\b  
\q1  
\v 9 ¿Doa, neggwebur-gandikidse an-nidoe? 
\q2 ¿Doa anga, Edom-yalase-aibillemaid oyogoe? 
\q1  
\v 10 Bab-Dummad, ¿bee be anmar-obachagussursi? 
\q2 Bab-Dummad, bar be anmarga sorda-bila-onomalad-bendakdisurgusad. 
\q1  
\v 11 Dule-isdarmaladgi-nakwega be anmar-imake. 
\q2 Ar dulemar anmar-bendakele, anmar gwen igarga guosulid. 
\q1  
\v 12 Bab-Dummad, anmar bebali unnila anmar-isdarmaladgi nakoed. 
\q2 Be anmarga, anmar-isdarmalad obelogoed. 
\c 61  
\s1 Bab-Dummad-egi-nakulediidgi bensulid 
\d David we-namaked narmaksad. Namakmalad-e-iduedga soged: We-namaked Neginotʼba namaklegoye. 
\q1  
\v 1 Bab-Dummadye ise-gollar an bese-goled, wis be an-itoge, 
\q2 an bese-ibmar-egised, wis be an-itoge. 
\b  
\q1  
\v 2 An-yargi yeer-bangu an gudiidba, surbinsa-an-itogedba, an bese goled. 
\q2 Akwasaila-matusulidse be an-sede. 
\q1  
\v 3 Bab-Dummad, bee be an-odukuedid. 
\q2 Bee be, neg-gandikidyob an-isdarmaladgi be an-bendakedid. 
\b  
\q1  
\v 4 Bab-Dummad, be-dordoneggi degisadegu an gudii gubied, 
\q2 be an-edarbedigu an be-abeged. 
\q1  
\v 5 Bab-Dummad, an bega ibmar-imakoye-ise-sogar-sogsad be itosad. 
\q2 Be-nug-odummodimaladga-yar-be-uksadi, be anga uksamogad. 
\b  
\q1  
\v 6 Rey-suiti-gudii-guega be imake. 
\q2 We-napneggi degisadegu-gudiguega be imake. 
\q1  
\v 7 Be-sogedba negsemaigu be imake. 
\q2 Be-sabgued-nikadba, be-igar-napiragwadba, egi nakuledii be imake. 
\q1  
\v 8 Weyob be-nuggi namakdii an guoed, 
\q2 ibmar-an-bega-imakoye-sogsad bane-bane an bega imakdii guoed. 
\c 62  
\s1 Bab-Dummadginbi unnila obunnoleged 
\d David namakmalad-e-iduedga namaked narmaksad. Jedutúnʼye-nugadga narmaksad. 
\q1  
\v 1 Bab-Dummadginbi an neg-bogidik amied, 
\q2 Bab-Dummadgi an-bendakleged danikid. 
\q1  
\v 2 Bab-Dummadbi anga akwasailaga gued, 
\q2 Bab-Dummadbi bela-bela-an-bendakedid. 
\q1 An egi dukued amied, 
\q2 agala, gege an galakued. 
\b  
\q1  
\v 3 ¿Ar sanadse bemar dule-gwensakgi yolenanai gumaloe? 
\q2 Galu-aimukudani-gwichiyobi, olaegala, egemaknanaiyobi, 
\q2 emide, bemar dule-gwensak imaknanaid. 
\q1  
\v 4 Unnila a-dule-wiogega gunanaid, 
\q2 e-nug-dummarba-nikad-oichogega gunanaid. 
\q1 Surbinsa gakansaedbina itomalad, 
\q2 ar e-sunmakeddi ibmar-nuedbi sogmalad, 
\q2 e-gwagegindina, emar-ukabsaedginbi binsadimalad. 
\b  
\q1  
\v 5 An-gwage Bab-Dummadginbi neg-bogidikid amied, 
\q2 Bab-Dummadginbi unnila an bensulid nikad. 
\q1  
\v 6 Bab-Dummadbi anga akwasailaga gued, 
\q2 Bab-Dummadbi bela-bela-an-bendakedid. 
\q1 An egi dukued amied, 
\q2 agala, gege an galakued. 
\q1  
\v 7 Bab-Dummad bela-bela-an-bendakedid, egi an wergudiid. 
\q2 Unnila Bab-Dummadgi an-gangued siid, an-odukuedbalid. 
\q1  
\v 8 ¡Unnila Bab-Dummadginbi be bensuli gumalo! 
\q2 ¡Bab-Dummad-asabin be nadele, bela be-boni-nikad ega be sogo! 
\q2 ¡Ar Bab-Dummad, anmar-akwediidid! 
\b  
\q1  
\v 9 Dule-wilemalad baisursunna bergued, 
\q2 dule-mani-nikamalad baisursunna bergumogad. 
\q2 Ebogwad nibirgi oaidiksaele, amba ukugwaled. 
\q1  
\v 10 Ibmar-isganagi-mani-amilegedgi melle be binsaed galemalo, 
\q2 ibmar-atursalegedgi mer be binsamala. 
\q1 Amba ibmar-nue-bukidar-bega-mergude be dakele, 
\q2 mer we-ibmarginbi be binsadii gumalo. 
\b  
\q1  
\v 11 Bab-Dummad weyob-ilagwen-sunmaksagusadi, ilabo an itosgusad: 
\q2 Bab-Dummadgi gangued daniye. 
\q1  
\v 12 Bab-Dummad, bede bela-bela emar-wile dakmaiye, 
\q2 bede dule-e-ibmar-imakedba, sogedba be naboye. 
\c 63  
\s1 Bab-Dummad dule-yeer-ito-imakedid 
\d David Judá-nega-dulesulidganba-gudigusgu, we-namaked narmaksad. 
\q1  
\v 1 ¡Bab-Dummad, be an-Bab-Dummadid! 
\q2 ¡Bolegoedba an be-amioed! 
\q1 An uku-uku-itogeyob an bebina soged, 
\q2 an-sana bela bebina soged. 
\q1 Ar igi dule nega-dulesulidganba dii-satedgi dii-amididae, 
\q2 deyobi, an be-amied. 
\b  
\q1  
\v 2 Bab-Dummad, an be-gangued-yeerdakleged-dakega, 
\q2 bese-goled-neggi an be-dakbied. 
\q1  
\v 3 Dula-gudiguedba be-sabgued bur-nuedid. 
\q2 A-ulale, an bega namakoed. 
\q1  
\v 4 Dula-gudiidgi an be-nug odummodii guoed. 
\q2 An be-nug-odummogega an-argan an onakoed. 
\b  
\q1  
\v 5 Mas-nued-immerba-guchayobi an yeer-itogoed. 
\q2 An yeer-itogedgi bega namakoed. 
\q1  
\v 6 An megidele, an begi binsamaidaed, 
\q2 bela mutikidbali, an begi binsamaidaed. 
\q1  
\v 7 Ar be an-bendaksad, 
\q2 deyobi, be-an-bendaksadgi an yeer-itoged. 
\q1  
\v 8 Andi begi alakwaa naid, 
\q2 ar be-gargangued an-bendaked. 
\b  
\q1  
\v 9 Ar dule-an-oburgwebimaladdi bergumaloed, 
\q2 nega-urbali argwanmaloed. 
\q1  
\v 10 Es-suidgi oburgwilemaloed, 
\q2 achu-sapur-masga gumaloed. 
\q1  
\v 11 Ar reydi, Bab-Dummadgi weligwar-itogoed. 
\q2 Dule Bab-Dummad-nuggi-ibmar-ise-sogar-soged 
\q1 weligwaledgi Baba-Dummadga namakmaloed. 
\q2 Ar dule-gakansilimardi gaya-maklemaloed. 
\c 64  
\s1 Babse-goled, dule-isganamargi an-bendakye 
\d David namakmalad-e-iduedga we-namaked narmaksad. 
\q1  
\v 1 Bab-Dummadye, an-ibmar-isdar-itogedi, an bega sognaidi, wis be itoge. 
\q2 Bab-Dummadye, be an-bendake, 
\q2 an-isdarmalad dobe an itodiid. 
\q1  
\v 2 Dule-isganamar-anbina-itosgudimalad-idu, be an-odukue. 
\q2 Dule-ibmar-isgana-imakmaladgi, be an-onoge. 
\q1  
\v 3 Es-suid-nugar-datarmakle-daebayobi e-gwabin-duku imakmalad. 
\q2 Igi sigu-milege, debayobi, e-gwabin-duku gayaburba-isganagan dulegi mied. 
\q1  
\v 4 Dule-gwen-neg-oakalossulidgi, yamo arbakee gwichiguddamalad, 
\q2 wile-gwen-daksuli, dulegi aibitedamalad. 
\b  
\q1  
\v 5 Dule-isganamar, na muchub-muchub e-igar-isganagi ogannobukwadamalad. 
\q2 Idu igar-amibukwadamalad, igi imakmalodibeye. 
\q1 Sogdedamarbalid: 
\q2 “¿Ar doa anmar-dakosunna?” 
\q1  
\v 6 Dule-isganamar igar-isgana-nue-amibukwadamalad, sogdamalad: “Anmar igar-napiragwad amibukwamalad.” 
\q2 Dule-binsaedi ibiyobi, nue-akusunna itolege. 
\b  
\q1  
\v 7 Bab-Dummaddi a-dulemargi e-sigu midoed. 
\q2 Wissuli-bukwadgi galedamaloed. 
\q1  
\v 8 Dukin na e-gwabin-sunmakedgi sabsur-odurdaklemaloed. 
\q2 Doa deyob dakdagoe, egi dodoar sunmakdoed. 
\b  
\q1  
\v 9 Bela dulemar-bukwadgi dobed nagunonikoed. 
\q2 Degidgine, Bab-Dummad-ibmar-dummagan-imaksadgi sunmakdemaloed. 
\q2 Agine, magar Bab-Dummad-ibmar-imaksadgi binsadmaloed. 
\q1  
\v 10 Dule-nuegan, Bab-Jehováʼgi wergudmaloed, 
\q2 egi bensuli gudmaloed. 
\q2 Dule-gwage-nuegan yeer itodmaloed. 
\c 65  
\s1 Bab-Dummad-nug odummolegergebed 
\d David we-namaked narmaksad. Namakmalad-e-iduedga soglenaid. 
\q1  
\v 1 Bab-Dummad-Sión-yargi-maid, be-nug odummolesun. 
\q2 Ibmar-imakmaloye-sogsamalad bega imakmalargebed. 
\q1  
\v 2 Bab-Dummad, dule-bese-goled be itodaed, 
\q2 degisoggu, bese bela dulemar nonimaloed. 
\q1  
\v 3 Anmar-ibmar-isgana-imaked anmargi obined, 
\q2 degi-inigwele, anmar-isgued be anmarga osulodaed. 
\q1  
\v 4 Dule-wargwen be susale, we-dulegi nued binsalesad. 
\q2 We-dule, be-neggi-gudiguega, bese be senonidaed. 
\b  
\q1  
\v 5 Bab-Dummad, be anmar-Abonogedid. 
\q2 Ibmar-innikigwadba be anmar-abin-imakdaed. 
\q1 Dulemar we-napneg-naid-ugakaase-bukmaladi bela begi bensurmalad. 
\q2 Dule-demar-obakar-dikasur-bukmaladi begi bensurmarmogad. 
\q1  
\v 6 Bab-Dummad, bee, be-ganguedgi yalamar be nasiksad, 
\q2 agi be-gangued be oyomaid. 
\q1  
\v 7 Bee, muu-billi-uurmakmaid obogileged, 
\q2 muu-billi-welegan-uurmakmaid bogidik be imaked, 
\q2 dulemar-oimakbukwad be osuloged. 
\q1  
\v 8 Degisoggu, dulemar dikasuli-bukmalad be-ibmar-dakledisulid-imaked dobdamarsunnad. 
\q2 Dulemar-dad-nakwedsik-bukmalad, dad-argwanedsik-bukmalad be weligwar-ito imaked. 
\b  
\q1  
\v 9 Bee be, napa nue-akwed. 
\q2 Napagi gatik ibmar sanmakega egi be dii owied. 
\q1 Dian-dummad-Babagadi gege-dinguedi, 
\q2 bela ibmar-sanmakega imaked. 
\q1  
\v 10 Napa-guremaladgi dii be owied, 
\q2 agi dii be osurmaked, 
\q2 diigi napa be odutumaked. 
\q1 Napagi ibmar sanmakega be imaked. 
\q2 Weyobi, be-dulamarga-be-mas-ukega, napa guakwaa be-dulamarga be nasiked. 
\b  
\q1  
\v 11 Be birga-nued nasikmaid, 
\q2 be ibmar unniguar-nika imakmaid. 
\q1  
\v 12 Nega-dulesulidgangi gaganmar aradikid, yar-mullugan ber weligwaled. 
\q2  
\v 13 Nebagangi sibadmar, sibad-wawaadmar, obiryamakded, 
\q2 orosgi-dakleged agi nue naibalid. 
\q1 ¡Bela agine ibmar-durgan oimakded! 
\q2 ¡Bela namakedibimalad! 
\c 66  
\s1 Be-ibmar-imaksadi, gegerdaklemaladid 
\d Namakmalad-e-iduedga namaked narmaklesad. 
\q1  
\v 1 Bela-dule-we-napneggi-bukwamalad, weligwaledgi Bab-Dummad-e-nug odummomar. 
\q2  
\v 2 E-nug-dummarbaadga namakmar, 
\q2 gandikidgi e-nug odummomar. 
\q1  
\v 3 Bab-Dummadga sogmar: 
\q2 “¡Be-ibmar-imakedi, geger-dakleged! 
\q1 Be gandik-maisoggua, 
\q2 be-isdarmalad be-urbaligwa gudimalad. 
\q1  
\v 4 Bela-dule-we-napneggi-bukwad be-nug odummomaloed, 
\q2 bega namakmaloed, be-nuggi namakmaloed.” 
\b  
\q1  
\v 5 ¡Dagmala! Bab-Dummad-ibmar-imaksad dakdamala. 
\q2 Anmarga-ibmar-gegerdaklemalad-imaksad be dakdamala. 
\q1  
\v 6 Bab-Dummad demar dinnaa imaksad, 
\q2 diwar dinnaa imaksabalid. 
\q1 Degidbali, dulemar neg-dinnagwadgi nabir-obaksamalad. 
\q2 Degisoggu, anmar Bab-Dummadgi wergumarsunna. 
\q1  
\v 7 Bab-Dummad gargandikidba degisadegu negsemaid, 
\q2 bela-dule-gudimaladgi nakulediid. 
\q2 Dulemar-eba-dasurmalad, gwen-abin gwisguosurmalad. 
\b  
\q1  
\v 8 Bela dulemar, Bab-Dummad-nug odummomarsun. 
\q2 Bab-Dummadga-namaklenaid, bela itomalaga imakmarsun. 
\q1  
\v 9 Ar Bab-Dummad anmar-san bendaksad, 
\q2 mer-galakuega anmar-imaksad. 
\b  
\q1  
\v 10 Bab-Dummad, bee be, anmar-wilubdaksad, 
\q2 mani-swilidik-imaklegeyob be anmar-imaksad, 
\q1  
\v 11 sakigi-galegega be anmar-imaksad, 
\q2 nunmaked-dummad be anmargi ogwisnonikid. 
\q1  
\v 12 Dulemar anmar-nonogi-annaega be imaksad, 
\q2 soo-buleganba-ibitogega be anmar-imaksad, 
\q1 dii-buleganba-ibitogega be anmar-imaksad. 
\q2 Emisgindi be, neg-nuedse anmar-ogwisgunonikid. 
\b  
\q1  
\v 13 An bese-goled-negse ibmar-ogumakar-ukega an nonikoed, 
\q2 an bega ise-sogar ibmar-imakoye-sogsad-imakega an nonikoed. 
\q1  
\v 14 An bonigan-abalagi-gunaidgi, 
\q2 an bega ise-sogar ibmar-imakoye sogsa gusad. 
\q1  
\v 15 An bega ibmar-ogumakegala, we-ibdurgan-waladummagan ukoed: 
\q2 Sibad-wawaad-machergan, moli-bebe-nikad-machergan, sibad-machergan, an bega ukoed. 
\b  
\q1  
\v 16 Bab-Dummad-dobekwaa-gudimalad, ¡dagmala! ¡Itodamala! 
\q2 Bela Bab-Dummad-anga-ibmar-imaksad, an bemarga sogoed. 
\q1  
\v 17 Bela-belad gandikidbali Bab-Dummadse an gocha gusad, 
\q2 an e-nug-odummonai gusad. 
\q1  
\v 18 Ar an-gwagegi an isdar binsasana, 
\q2 Bab-Jehová an-itossulinad. 
\q1  
\v 19 Emidi, Bab-Dummad an-itononikid, 
\q2 an-wilesakwaa-gornaid itosad. 
\b  
\q1  
\v 20 ¡Bab-Dummad-e-nug odummolesun! 
\q2 An-ese-gornaid nue an-itosad, 
\q2 e-sabgued gwen angi obachasurgusad. 
\c 67  
\s1 Bela-dule-bukwamalad Bab-nug odummomar 
\d Namakmalad-e-iduedga soglesad, we-namakedi Neginotʼba namakoye. 
\q1  
\v 1 Bab-Dummadye, wile be anmar-dake, 
\q2 be anmargi nued-binsae, 
\q2 bela-bela be-sabgued be anmarga oyoge, 
\q1  
\v 2 adi, we-napneggi be-igar wisgumalagar, 
\q2 bela dule-yar-baid-baidgi-bukwamalad be-abonoged wisgumalagar. 
\b  
\q1  
\v 3 Bab-Dummad, dulemar be-nug odummomala, 
\q2 bela dulemar be-nug odummomala. 
\q1  
\v 4 Dule-yar-baid-baidgi-bukwamalad wergumala, 
\q2 weligwaledgi namakmala. 
\q1 Bedi, dulemarga innikigwadgi igar naboged. 
\q2 Napneggi dule-yar-baid-baidgi-bukwamalad-e-iduedga be gued. 
\b  
\q1  
\v 5 Bab-Dummad, dulemar be-nug odummomala, 
\q2 bela dulemar be-nug odummomala. 
\b  
\q1  
\v 6 Napneggi bela ibmar-durba sanmakoed, 
\q2 Bab-Dummad, anmar-Bab-Dummad, anmargi nued-binsaoed. 
\q1  
\v 7 Bab-Dummad, be anmargi nued-binsaoed, 
\q2 bela we-napneggi-yarmar-nanaid-ugakaase Bab-Dummad-dobgumaloed. 
\c 68  
\s1 Bab-Dummad, Sinaí-yala-e-ibedid, Neg-Islidikid-e-ibedid 
\d David we-namaked namakmalad-e-iduedga narmaksad. 
\q1  
\v 1 Bab-Dummad, dakebinne. Be-isdarmalad bela be oaisakisun. 
\q2 Dule-be-isdardakdimalad bela be-idu be oduurmaksun. 
\q1  
\v 2 Igi waa burwaba yogguddae, 
\q2 debayobi, Bab-Dummadi dule-isganamar-imakoed. 
\q1 Igi baka-gwallu soo-abin daluddae, 
\q2 debayobi, dule-isganamar Bab-Dummad-abin bergudoed. 
\q1  
\v 3 Dule-innikidamaladdi weligwale itomaloed, 
\q2 Bab-Dummad-asabin yeer itomaloed, 
\q2 weligwaledbali oichomakdemaloed. 
\b  
\q1  
\v 4 Bab-Dummadga be namakmar, 
\q2 E-nuggi-namaklegedgi be namakmar, 
\q1 mogir-billigangi-sii-nanaed-e-nug be odummomar, 
\q2 ¡Bab-Jehováʼgi wergumala! 
\q2 ¡E-asabin be namakmala! 
\q1  
\v 5 Bab-Dummad-e-neg-islidikidgi-maidi, dulemar-sergan-sated-e-babad, 
\q2 ome-ei-sui-burgwismalad-e-bendakedid. 
\q1  
\v 6 Bab-Dummad, dule-wilesakwaa-walagwen-gudimalad, neguya-nikuega imaked, 
\q2 dule-galesbukwamalad-onogedid. 
\q2 Dule Bab-Dummadba-ibsadisurmaladdi, napa-isganagi ambikuoed. 
\b  
\q1  
\v 7 Bab-Dummad, be Israel-dulemar-abargi-noargua, 
\q2 nega-dulesulidganba be idu-nadapgua, 
\q1  
\v 8 napnega giglimakdegusad, mogir dii-owidegusad, 
\q2 Sinaí-yala, be-abin giglimakdegusad. 
\q1 Deyobi, Sinaí-yala Bab-Dummad-abin gusad, 
\q2 deyobi, Sinaí-yala Israel-e-Bab-Dummad-abin giglimaksad. 
\q1  
\v 9 Bab-Dummad, bedi bela-belad dii-owisagusad, 
\q2 be-dulamar geggus-danimargua, be e-niga-ogannosad. 
\q1  
\v 10 Bab-Dummad, a-napagine, be-dulamar ambikusad, 
\q2 dule-wilegedgi be nued-binsaedgi ega napa-nued be nasiksad. 
\b  
\q1  
\v 11 Bab-Jehová, e-gayaburba uksad, 
\q2 omegana mili-milibali (1,000-1,000), a-gayaburba-nued weyob sogmalad: 
\q1  
\v 12 “Reymar duurmakdemalad, 
\q2 sorda-bila-onomalad duurmakdemalad. 
\q1 E-isdarmalad-ibe-ibmar-sulesmaladi, omegan e-neggine mimidmalad: 
\q2  
\v 13 Ibmar manigi-sobarmalad, orgi-sobarmalad, mimidmalad. 
\q2 Ar bemardi unnila sibad-wawaad-abargi meremai gusmalad.” 
\q1  
\v 14 Bab-Dummad-Bela-Gangued-Nikadi, reymar-oakinnaigua, 
\q2 Salmón-yala-birgi dambed-sibudik-sibudik-batemaibayobi reymar-imaksad. 
\b  
\q1  
\v 15 Basán-yalagan, yalagan-dummagan nanaed. 
\q2 Basán-yalagan-e-billigan matusuli nanaed. 
\q1  
\v 16 Yala-dummagan, ¿ibiga be Bab-Dummad-yala-nug-imaksadgi be nobe itomala? 
\q2 Ar Bab-Jehová degisadegu agi mai guoed. 
\q1  
\v 17 Bab-Dummad-e-moli-ur-bila-onomaladi, mili-miliba mergued (1,000-1,000). 
\q2 A-abalagine, Bab-Jehová Sinaí-yalase nonikid, 
\q2 e-neg-islidikid-yaba dogenonikid. 
\q1  
\v 18 Bab-Dummad-Jehová, niba be nakwisgua, dule-galesmalad beba be sesa gusad. 
\q2 Dulemar-ibmar-bega-binsa-uksad be susad, 
\q1 dule-uayasulidamalad-e-ibmar be susad. 
\q2 Adi, be be-dulamar-abargi gudii guegar. 
\b  
\q1  
\v 19 ¡Bab-Jehová-nug odummolesun! 
\q2 Bab-Dummad-anmar-abonogedi, iba-irbali anmar-bendakmaiguad. 
\q1  
\v 20 Anmar-Bab-Dummadi, dule-bendakmaidid. 
\q2 Bab-Jehová-Bur-Dule-Dummad burgwed-igargi anmar-onogedid. 
\b  
\q1  
\v 21 Bab-Dummad, dule-e-isdarmalad-nonogi annaoed, 
\q2 e-nono-binsaed-isganabi-sediid ei sagamakoed. 
\q1  
\v 22 Bab-Jehová anmarga sogsad: “Basán-akale, gannar an be-barmidagoed. 
\q2 Demar-mata-wilaganba gannar-naega an be-imakoed. 
\q1  
\v 23 Be-naga, be-isdarmalad-e-ablisbi-moodo-guega an imakoed. 
\q2 Be-achumar we-ablis elomaloed.” 
\b  
\q1  
\v 24 Bab-Dummad, be-Neg-Islidikidgi dulemar-yaryarmakmamaidi, magar dakleged. 
\q2 Dule-duurmakmaidi, an-Bab-Dummadgadid, an-Reygad gued. 
\q1  
\v 25 Dule-namakmaladi idumamaid, 
\q2 a-yalabali, yagana gar-panderetaʼmar ogornadapid, 
\q2 solaba dule-gar-ogormalad nadapmogad. 
\q1  
\v 26 Danar-bukwadgi Bab-Dummad-nug be odummomalo, 
\q2 Israel-wagan, Bab-Jehová-nug be ogannomalo. 
\q1  
\v 27 Benjamín-wagan we-dulemar-iduedga nadapid, 
\q2 amar-yalabali, Judá-dulemar-e-dummagan bukidar nadapmogad, 
\q1 solanapi, Zabulón-dulemar-e-dummagan, 
\q2 Neftalí-dulemar-e-dummagan nadapmarmogad. 
\b  
\q1  
\v 28 Bab-Dummad, be-gargangued be oyoge, 
\q2 Bab-Dummad, be anmar-bendakegala be-gangued-oyosgusadi, be oyobali. 
\q1  
\v 29 Bese-goled-neg Jerusalén-neggweburgi-siid-ulale, 
\q2 reymar bega ibmar ukmaloed. 
\q1  
\v 30 Bab-Dummad, we-ibdula-masarganbalidga sabsuli be ibmar-soge. 
\q2 Moli-bebe-nikad-machergan-ursilimaladga, ise-sabsuli ega be ibmar soge. 
\q1 Yarmar-baiganbali, moli-bebe-nikad-sapinganayob-damaladga, ise-sabsuli ega be ibmar soge. 
\q2 Ibmar-bela-bela-nikubiedba dulemar-sabsuli-imakdiidga, sabsuli be ibmar soge. 
\q2 ¡Dule-bila-onogedgi-binsadimalad be oaisakisun! 
\q1  
\v 31 Egipto-akale, dule-sapin-dummagan danimaloed, 
\q2 Etiopía-dorgandi, gwae-gwae Bab-Dummadse wilenonimaloed. 
\b  
\q1  
\v 32 Napneggi-dule-bukmalad, Bab-Jehováʼga be namakmala. 
\q2 Namaklegedgi Bab-Dummadga be namakmala. 
\q1  
\v 33 Mogir-negasailaun-nagusmalad-birgi-sii-nanaedga, be namakmala. 
\q2 E-sunmaked-itogega-dule-imakedga, be namakmala. 
\q2 E-sunmaked mala-gollomakeyob-goledga, be namakmala. 
\q1  
\v 34 Bab-Dummad-e-gargangued magar be dakmala. 
\q2 E-ganguedi, Israel-neggweburgi maid. 
\q2 E-garganguedi, nibneg-akale oyonaid. 
\q1  
\v 35 Bab-Dummad, be-Neg-Islidikidgi, bedi, dule-geger-dakleged maid. 
\q2 Israel-e-Bab-Dummad, e-neggweburga, gargangued ukedid, niga-gangued ukedid. 
\b  
\q1 ¡Bab-Dummad-nug odummolesun! 
\c 69  
\s1 Nunmak-itogedba Bab-Dummadse-binnasur-goled 
\d Namakmalad-e-iduedga soged: Igi dutu-lirioʼga-namaklege, deyob namaklemogoye. 
\d David we-namaked narmaksad. 
\q1  
\v 1 Bab-Dummad be an-bendake, 
\q2 ar dii an-gammu-nagagus-naid, 
\q2 ar an didulenaid. 
\q1  
\v 2 Olli-mata-yaagi an dogmaid, 
\q2 gwisguega annaed an sated. 
\q1 Dii-wilasailad-abargi an naid, 
\q2 e-dukeba an selemaid. 
\q1  
\v 3 Dule-baidse-bendakleged an budar egisgusad. An gammu dinnagusad. 
\q2 An-Bab-Dummadse an-bendakleged-edarbediidba, ataked an yegusad. 
\q1  
\v 4 Dule-isdar-an-dakmalad, an-sailagiaba bur bule mergued. 
\q2 Bukidar binsarsunna isdar an-dakmalad. 
\q1 Isdar-an-dakmalad nue-gangued-nika gudmalad, 
\q2 binsarsunna an-oburgwebimalad. 
\q1 Ar an ei ibmar atursassulite, 
\q2 ¿ibu gannar ega an ukosunna? 
\b  
\q1  
\v 5 Bab-Dummad, an binsaedsuligudigusad be wisid, 
\q2 an-isgued geg begi an odukued. 
\q1  
\v 6 Bab-Dummad-Jehová-Bela-Gangued-Nikad, dule-begi-bensurmaladi, melle an-nukad bingegued be imako. 
\q2 Israel-e-Bab-Dummad, dule-be-amidimaladi melle an-nukad suli-suli-itoged be imako. 
\q1  
\v 7 Ar be-nug-ulale, dulemar sunnasur-angi sunmaksamalad. 
\q2 An bingedba an-wagar gisii naded. 
\q1  
\v 8 An-gwenadgan dule-baidyobi an-daked, 
\q2 an-nan-mimmigana akusunna an-dakmalad. 
\q1  
\v 9 An bese-goled-negbina-nue-soged-ular, egi nue-nobe an itoged. 
\q2 Dulemar-begi-isdar-sunmaknanaid angi yolenonimogad. 
\b  
\q1  
\v 10 An bodele, mas-gunsuli an gudele, 
\q2 angi dododedamalad. 
\q1  
\v 11 Bukib-itoged-mola an yosale, 
\q2 angi dodoardamalad. 
\q1  
\v 12 Dulemar neggwebur-doged-yawagakgi-bukudamaladi, angi sunmakedibidamalad. 
\q2 Mummugana angi namakedibidamalad. 
\b  
\q1  
\v 13 Bab-Jehová, andi an bese goledi, be-itolegedba be an-abin-imakdaed. 
\q2 Sabed-dummarba-be-nikadba be an-abinsadaed. 
\q1 Be sunna an-abonogedba be an-bendaked. 
\q2 Bab-Dummadye, ¡emiskwaa be an-bendake! 
\q1  
\v 14 Olli-mata-dummadgi be an-onoge. 
\q2 Melle olli-matagi-doged be an-imake. 
\q1 Dule-isdar-an-dakmaladgi be an-onoge, 
\q2 dii-wilasailadgi be an-onoge. 
\q1  
\v 15 Melle diiba-seleged be an-imake, 
\q2 melle biryaba-bipirmakega be an-sae, 
\q2 melle napa angi mured be imake. 
\b  
\q1  
\v 16 Bab-Jehová, be an-abin-imake, 
\q2 ar bedi dule-nuedid, be-sabgued dummarba be nikad. 
\q2 Be bela-bela dule-wiledakmaidba, gannar be anse dage. 
\q1  
\v 17 Bab-Dummad, be-mai-idu melle be dukue, 
\q2 be an-abin-imake, ar an boni-abargi naid. 
\q1  
\v 18 Bab-Dummadye an-walikaa be dage, be an-bendakdage. 
\q2 ¡An-isdarmaladgi be an-onoge! 
\b  
\q1  
\v 19 Bab-Dummad, nue be wisid dulemar angi yoledimalad, 
\q2 dulemar an-obingegsadimalad, 
\q1 dulemar angi dododimalad. 
\q2 Bab-Dummad, bela be wisid, doamar an-isdarmalad gumala. 
\b  
\q1  
\v 20 Dule-angi-dododimalad nue-nunmak an-imaksamalad. 
\q2 Emide geg an barsagusad, an bendakleged sated. 
\q1 Dule-wile-an-daked an amidiinad, gwen an amissurgusad. 
\q2 Dule-wile-an-dakmalad satemalad. 
\q1  
\v 21 An-masgi ina-nusu obatismalad. 
\q2 An uku-uku-itonaigua, ina-gagbid anga uksamalad. 
\b  
\q1  
\v 22 E-iba-onobukwadgi, e-masi egi-aibinega be imake. 
\q2 E-nasgumaidi, egi-aibinega be imake. 
\q1  
\v 23 Melle-atakmalaga, amar-e-ibya mommoo be imake. 
\q2 Nolloo namalaga, e-gangued ei be sue. 
\q1  
\v 24 Be-urwed egi gwichigued be imake. 
\q2 Be-urwed amargi yoleged be imake. 
\q1  
\v 25 E-negmar ollo-ollo-siged be sae. 
\q2 Amargi dulemar megsuli be imake. 
\q1  
\v 26 Ar be dule-naibi-imaksad balegichamalad, 
\q2 ar be dule-naibi-imaksad-e-nunmakedgi dododmalad. 
\q1  
\v 27 Wemar ibmar-isgana-imaksadyob be imakmoga. 
\q2 We-dulemar melle be wiledako. 
\q1  
\v 28 We-dulemar garda-burba-duladgi-e-nug-narmakar-naid be elie. 
\q2 Melle dulemar-nueganba e-nug-narmakar be meso. 
\b  
\q1  
\v 29 Bab-Dummad, ar andi an uellediid, an nunmak-itodiid, 
\q2 be an-ogwiche, be an-bendake. 
\b  
\q1  
\v 30 Bab-Dummad, namakedgi an be-nug ogannogoed, 
\q2 dog-nuedye-sogedgi be-nug an odummogoed. 
\q1  
\v 31 We-ibmar-uklegedi, Bab-Jehováʼga moli-bebe-nikad-ukedba, moli-sapingwagwad-bebe-nikad-ukedba, 
\q2 Bab-Jehová bur-yeer itodaed. 
\q1  
\v 32 Dule-wilegana weyob-dakdagogua, nue-yeer itodmaloed, 
\q2 Bab-Dummad-amidimalad-e-gwage gannaledmaloed. 
\q1  
\v 33 Ar Bab-Jehová dule-wilegana-ese-goledi itodaed. 
\q2 E-dulemar-galebukwad mesagwar daksulid. 
\b  
\q1  
\v 34 Nibnega, napnega, muu-billigan, bela-agi-ibmar-bukmalad, 
\q2 Bab-Dummad-nug odummosun. 
\q1  
\v 35 Ar Bab-Dummad Sión-yala bendakoed, 
\q2 Judá-neggweburmar gannar soboed. 
\q2 Agine na e-dulemar degisadegu ambikuega imakoed. 
\q1  
\v 36 Be-dulamar-e-wagan, a-yala degisadegu egadga guoed. 
\q2 Dule-be-sabmalad, a-yalagi bukwa gumaloed. 
\c 70  
\s1 David bendaklegegala Bab-Dummadse goled 
\r (Salmo 40:13-17) 
\d David na egi-binsamalaga namaked narmaksad. 
\d We-namaked namakmalad-e-iduedga narmaklesad. 
\q1  
\v 1 Bab-Dummadye, gwae be an-bendakdage, 
\q2 Bab-Jehováʼye, gwae be an-irwa gwisgudage. 
\q1  
\v 2 Dule-an-oburgwebigudimalad bela surbinsa be imake. 
\q2 Dule-angi-isdar-binsadimalad bela be obingegsae, 
\q1 gannar osikirmakega be imake. 
\q2  
\v 3 Dule-angi-dododimalad, bingedba gannar osikirmakega be imake. 
\b  
\q1  
\v 4 Bab-Dummad, dulemar-bebina-gudimalad, begi-wergumala, begi-yeer-itomala. 
\q2 Dulemar-be-abonoged-igar-sabgudimalad weyob degisadegu sogdii gumala: 
\q2 “¡Bab-Dummad, nue-Bab-Dummad-Bur-Biriginedid!” 
\b  
\q1  
\v 5 An dule-wilegedid, ibmarbina an sogdiid. 
\q2 Degisoggu, Bab-Dummadye, gwae be anse dage, 
\q1 ar be an-bendakedga gued, 
\q2 ar be an-ollor-imakedid. 
\q1 ¡Bab-Jehováʼye, mer be edarbe! 
\q2 Gwae be dage. 
\b  
\c 71  
\s1 Dador-Babse-goled 
\r (Salmo 31:1-4; 71:1-3) 
\q1  
\v 1 Bab-Jehová, an begi bensulid, 
\q2 mer bipisaar bingeguega be an-imake. 
\q1  
\v 2 Be-igar-innikigwadba be an-bendake, be an-ollorsae, 
\q2 wis be an-itoge, be an-bendake. 
\q1  
\v 3 Bee be, an-akwasaila-dukuedga gue, 
\q2 adi, an ase bali-bali dukudii guegar. 
\q1 Bedi an-bendakega be igar uksad. 
\q2 Be an-akwasailaga gued, bedi an-ganguedid. 
\q1  
\v 4 An-Bab-Dummad, dulemar-isgana-e-ganguedgi be an-ollorsae. 
\q2 Dule-isgudimalad-e-ganguedgi, be an-ollor-imake. 
\q2 Emar-sabsur-imakmalad-e-ganguedgi be an-ollorsae. 
\b  
\q1  
\v 5 Ar bedi, Bab-Dummad-Jehová, an-bendakedid. 
\q2 Sapingwagwad-akale, an begi bengudisulid. 
\q1  
\v 6 An sapidukugi-mai, be an-akwide gusad. 
\q2 Bee be, muu-neggi-mai we-napnegse be an-odesad. 
\q2 A-ulale, degisadegu an be-nug-odummodii guoed. 
\q1  
\v 7 Dulemarga an ibmar-gegerdaklegedyob gued, 
\q2 ar bedi an-odukued-gandikidid. 
\q1  
\v 8 Bab-Dummad, bali-bali an be-nug odummoged, 
\q2 be-ganguedgi, be-yeerdaklegedgi an sunmakdii osedoddaed. 
\b  
\q1  
\v 9 Bab-Dummadye, an seredgusale, mer be an-obano, 
\q2 an-gangued bergudele, mer be an-obano. 
\q1  
\v 10 Ar an-isdarmalad angi sunmakmalad, 
\q2 an-oburgwebimalad na muchub-muchub angi sunmakmalad, 
\q1  
\v 11 weyob sogmalad: “Bab-Dummad we-dulegi bar binsamaisurye. 
\q2 Anmar baleginmala, ganamala, ar dule-e-bendaked sated.” 
\q1  
\v 12 Bab-Dummadye, mer be angi bangue, 
\q2 an-Bab-Dummad, gwae be an-bendakdage. 
\q1  
\v 13 An-isdarmalad bingegumarsun, burgwemarsun. 
\q2 An-oakalobimalad, bela-bela bingegumarsun, 
\q2 bela-bela oesgudii gumarsun. 
\b  
\q1  
\v 14 Ar andi begi degisadegu benguosulid, 
\q2 bur bule an be-nug-odummodii guoed. 
\q1  
\v 15 Be-Igar-innikigwad, be-abonoleged-igar, amba an wissuli-inigwele, 
\q2 an egi sunmakdii osedodoed. 
\q1  
\v 16 Bab-Dummad-Jehová, be-ganguedba-be-ibmar-imaksad an sogoed, 
\q2 be-igar-innikigwad an ebinsaoed, 
\q2 unnila abi an ebinsaoed. 
\q1  
\v 17 Bab-Dummad, sapingwagwad-akale, be an-odurdaksad, 
\q2 amba emise-bakale, an be-ibmar-gegerdaklemalad-imaksadgi an sunmakdiid. 
\q1  
\v 18 Bab-Dummad, an-seredgusale, an nono-dableargusale, mer be angi banguo. 
\q2 Amba dulemar-danimaloedga be-ganguedgi an sunmakbied, 
\q2 amba yoo-gwalulemaladga be-garganguedgi an sunmakbied. 
\b  
\q1  
\v 19 Bab-Dummad, be ibmar-dummagan imaksad, 
\q2 be-igar-innikigwad nibnegse warmakmaid. 
\q2 Bab-Dummad, dule beyobid sulid. 
\q1  
\v 20 Bedi, surbinsa-itolegedba galitonai an-imaksad, 
\q2 wile-itolegedba galitonai an-imaksad. 
\q1 Degi-inigwele, gannar be an-ogannogoed, 
\q2 napa-urba-mai gannar be an-odurguoed. 
\q1  
\v 21 An-nug-dummarba be imakoed, 
\q2 gannar be baisur-itoge an-imakoed. 
\b  
\q1  
\v 22 Deyobi, an bega gar-salterioʼba doggus-nuedye sogoed, 
\q2 An-Bab-Dummad, innikigwadba-be-ibmar-imakedgi gar-arpaʼba an bega namakoed, 
\q2 Israel-Bab-Dummad, an bega gar-liraʼba namakoed. 
\q1  
\v 23 An bega namakdele, an weligwaledgi bega namakoed, 
\q2 ar ade, be an-abonosad. 
\q1  
\v 24 Deginbali, be-igar-inniki-imaksadgi an sunmakdii guoed. 
\q2 An-oakalobimalad nue-bingegusmalad, nug-bipii gusmalad. 
\c 72  
\s1 Reyga-Bab-Dummadse-golleged 
\d Salomón we-namaked narmaksad. 
\q1  
\v 1 Bab-Dummad, be-naboged-igar reyga be uke. 
\q2 Be-Igar-innikigwadba-be-ibmar-saedi rey-machiga be uke. 
\q1  
\v 2 Adi, rey, innikigwadba be-dulamarga igar nabogoed, 
\q2 wile-itodimaladga innikigwadba igar nudakoed. 
\q1  
\v 3 Yalamar, dulemarga neg-bogidikid nasiknonikoed, 
\q2 yala-mullugan, dulemarga igar-innikigwad ukoed. 
\q1  
\v 4 Rey, dule-bukib-binsadimaladga igar nabogoed. 
\q2 Rey, dule-ibmar-nue-abedimalad-e-mimmigana abonogoed, 
\q2 mesagwar-dule-imakdimaladdi, obelogoed. 
\b  
\q1  
\v 5 ¡Rey-nug odummolesun! 
\q2 Birga-birgaba rey yar-semai guoed. Igi-dad-ibeler birgabargus-naiyob, nii-ibeler birgabargus-naiyob guoed. 
\q1  
\v 6 Igi-nainugi ibmar-digar-naidgi dii wiardae, deyob guoed. 
\q2 Igi dii-wied napa-dutuu imakdae, deyob guoed. 
\q1  
\v 7 Rey-ibagangi igar-innikigwad dutu-achunnedyob guoed, 
\q2 rey-ibagangi ibmar nasgumai guoed, 
\q2 nii-naid-berguedse ibmarmar nasgumai guoed. 
\b  
\q1  
\v 8 Rey demar-naid-ugakaase yar-semai guoed, 
\q2 Éufrates-diwar-maid-akale, bela napaneg-naid-ugakaase, rey yar-semai guoed. 
\q1  
\v 9 Dulemar-nega-dulesulidganba-mamaid yokorgi-sindigale, rey-asabin dulluu imakmaloed, 
\q2 e-isdarmalad, rey-asabin napa-nagase dulluu imakmaloed. 
\q1  
\v 10 Tarsis-e-reymar, dulemar-demar-gakagi-bukmaladi, neggweburgi-mani-galeged reyga ukmaloed. 
\q2 Sabá-e-reymar, Seba-e-reymar, ibmar-nuegan-binsa-ukleged reyga ukmaloed. 
\q1  
\v 11 Bela reymar yokorgi-sindigale, e-asabin dulluu imakmaloed. 
\q2 Dulemar-yar-baid-baidgi-bukmaladi, bela ega-arbamaloed. 
\b  
\q1  
\v 12 Rey, dule-ibmar-nue-abediidba wilesagwa-gordiidi bendakoed. 
\q2 Dule-wile-itodiid, dule-e-bendakoyob-binsadiid, rey bendakbaloed. 
\q1  
\v 13 Rey, dule-wileged nue-wile dakbaloed, 
\q2 dule-ibmar-nue-abediid nue-wile dakbaloed, 
\q2 dule-wilegana-abonogoed. 
\q1  
\v 14 Mesagwar-imaklediidgi dule-onogoed, 
\q2 sabsur-imaklediidgi dule-onogoed, 
\q2 ar dule ega bela-bela ibnuedga gued. 
\b  
\q1  
\v 15 ¡Rey-nug odummolesun! 
\q2 Sabá-ormar ega uklesun. 
\q1 Bali-bali ega Babse-gorlesun. 
\q2 Bane-bane egi ise-nued-binsalesun. 
\q1  
\v 16 Bela-napamargi, ibmar-gwag-gullemalad bukidar nikusun. 
\q2 Bela yalamar-birgi, Líbano-yargi-ibmar-gwag-gullemalad-nikayobi nikusun. 
\q2 Dulemar, gagan-nainugi-ainieyobi, neggweburgi mergusun. 
\b  
\q1  
\v 17 Degisadegu rey-nug biledii gusun, 
\q2 dad-ibeler-naiyob e-nug naguoed. 
\q1 Bela dule-yar-baid-baidgi-bukmaladi rey-nuggine, dule-baigangi ise-nued-binsadii gumarsun, 
\q2 Bab-Dummad-egi-nued-binsasye sogmarsun. 
\b  
\q1  
\v 18 Israel-e-Bab-Dummad-Jehová-nug odummolesun, 
\q2 unnila abi ibmar-gegerdaklemalad-imaked maid. 
\q1  
\v 19 ¡Degisadegu, e-nug-gandikid odummoledii gusun! 
\q2 ¡Bela napneggi e-yeerdakleged neg-ganai gusun! 
\b  
\qc ¡Deyob-gusun! 
\b  
\m  
\v 20 Isaí-machi-David, Bab-Dummadse-goled-narmaksadi, wese bergunaid. 
\c 73  
\ms1 3. GARDA-SOGBAAGWAD 
\mr (Salmos 73:1–89:52) 
\s1 Dule-isganamar igi berguoe 
\d Asaf we-namaked narmaksad. 
\q1  
\v 1 Ibibayobi, Bab-Dummad Israel-dulemargi nued-binsae, 
\q2 ibibayob dule-gwage-swilidikmaladgi nueddae. 
\b  
\q1  
\v 2 An iche-napinad isguednaganad, 
\q2 an iche-napinad nue-dummad-noenad. 
\q1  
\v 3 Dule-san-dummarba-imakmaladgi an nobguded, 
\q2 we-dule-isganamar nasgumai an dakargua, an egi nobguded. 
\q1  
\v 4 We-dulemar gwen boni nikasurmalad, 
\q2 na san-swilidik gudidimalad. 
\q1  
\v 5 Dulemar-ibmarbina-sogeyob ibmarbina-sogdisurmalad, 
\q2 dule-baigan-wiledimaladyob, wiledisurmalad. 
\b  
\q1  
\v 6 We-dulemar, e-san-dummarba-imaked, wingwa-dukargi-naiyob ise-daklegaled. 
\q2 E-sabsur-dule-imaked, mor-yoeyobi ise-oyogar damalad. 
\q1  
\v 7 Ibmar-isgana-ulubgi-sediid ise-oyogar damalad, 
\q2 ibmar-isgana-imaked bakar-buud oyomalad. 
\q1  
\v 8 Dulemar-baigangi sunnasur sunmakdamalad. 
\q2 Gadi dule-baigangi dododamalad. 
\q2 Na san-dummarba-imakmaladba aimar-ibgwensur imakmalad. 
\q1  
\v 9 E-sunmakedgi Bab-Dummadgi isdar sunmakdamalad, 
\q2 e-sunmakedba bela dulemar eba selediid. 
\q1  
\v 10 A-ulale, dulemar ese idaknaddamalad, 
\q2 ega ibmar-soged bela nabiridbiiye binsadamalad. 
\q1  
\v 11 We-dule-isganamar sogdedamalad: ¿Ar wede, Bab-Dummad wisguosi? 
\q2 ¿Ar wede, Bab-Dummad-Bur-Birigined mag-itogosi? 
\b  
\q1  
\v 12 We-dule-isganamar dogdar-alamaknai dasurmalad, 
\q2 degite, baisursunna mani-ibedga guddamalad. 
\q1  
\v 13 Binsarsunna, an gwage-swilidik gudiid, 
\q2 binsarsunna, an ibmar-nued imakdiid. 
\q1  
\v 14 Ar emide, sabsur-an-imakdigumalad, 
\q2 wakudaryalaba an-sarsoardamalad. 
\b  
\q1  
\v 15 An weyob sogsana: “We-dule-isganamaryob an sunmakoye.” 
\q2 An be-mimmigangi aibichanad. 
\q1  
\v 16 An we-ibmarmala magar-itobi gusanad, 
\q2 suli-suli-itogega an-imaksad, aku an itogusad. 
\q1  
\v 17 Bab-Dummadse-goled-negse an dogsagua, 
\q2 geb an magar-itosad, igi-dule-isganamar bergumaloe. 
\q1  
\v 18 Bab-Dummad, be we-dulemar bonimar-abargi ogwichisad, 
\q2 we-dulemar na san-berguedse nadapmalad. 
\q1  
\v 19 ¡Wemar ukiagwar bergudmaloed! 
\q2 Wemar dobedba bergudmaloed. 
\q1  
\v 20 Bab-Jehová, bedi, igi dule e-gabdaksad napiragwadsulidba baisursunna daknonidae, 
\q2 deyobi, be gwisgualile, we-dule-isganamar-baisursunna dakoed, 
\q2 be we-dulemar-obelogoed. 
\b  
\q1  
\v 21 Bab-Dummad, suli-suli an itodigua, 
\q2 an-ulubgi nue-sae an itodii gusad. 
\q1  
\v 22 Ar an ibmar-wissulidbali, gannar-gannar an imaksad, 
\q2 ibmar-durganyob an gusad. 
\q1  
\v 23 Degi-inigwele, an begi bangussulid, 
\q2 bee be nue-an-nidii gusad. 
\q1  
\v 24 Be anga binsaed-ukedba an nanadiid. 
\q2 We-napneg-bergusale, ise-nuedgi be an-abingaoed. 
\q1  
\v 25 ¿Ar doa nibneggi an-edarbemaisunna? Unnila bebi an-edarbemaid. 
\q2 Ar an beba gudiile, we-napneggi ibmar-baid an abesulid. 
\q1  
\v 26 An-gangued bar nika an itosulid, 
\q2 degi-inigwele, Bab-Dummad, be an-ganguedid. 
\q2 Beginbi gudigu an sadeguoed. 
\b  
\q1  
\v 27 Dulemar-begi-banguddamaladdi bese berguoed. 
\q2 Dule-be-sogedba-nanadisurmaladdi bese burgwemaloed. 
\q1  
\v 28 Ar andina, Bab-Dummad-walikaa-gudigued bur nued an itoged. 
\q2 Be, an-Bab-Jehová gued, 
\q2 be, an-odukuedid. 
\q1 Degisoggu, bela be-ibmar-imaksad, 
\q2 dulemar-baiganga an sogoed. 
\c 74  
\s1 E-isdarmaladgi-bendaklegega Bab-Dummadse gornaid 
\d Asaf, we-namaked-Masquilʼye-nugad narmaksad. 
\q1  
\v 1 Bab-Dummad, ¿ibiga be degisadegu anmar-obacha? 
\q2 ¿Ibiga be anmarse nue-urwe? 
\q2 Ar be-sibad-wawaadyob-danar-bukwadse, ¿ibiga be nue-urwe? 
\q1  
\v 2 Be-dulamar negasailaun be susadi, mer be iego. 
\q2 Be-dulamar begadga-guega be bendaksagusadi, mer be iego. 
\q1 We-Sión-yar-siid be-negga be imaksadi, mer be iebalo. 
\q1  
\v 3 We-neg bela-bibichis-bukwadse be dage, 
\q2 ar dule-be-isdarmalad, bese-goled-neg bela-bibichismalad. 
\b  
\q1  
\v 4 Bab-Dummad, be-isdarmalad be-onmakedneggi oimakbukwad, 
\q2 nakwis-itomaladba e-bandermar digsamalad. 
\q1  
\v 5 Dule sapurba-sapi-sikmaladyob, ibmar-olananai gusmalad. 
\q2  
\v 6 Bela ibmar-urgogi-sobarmalad, e-akangi bibichismalad. 
\q2 Mardomargi bela bibichismarbalid. 
\q1  
\v 7 Be-neg-siid soogi ogumaksamalad, 
\q2 bela swiri imaksamalad. 
\q1  
\v 8 Dule-isdarmalad na e-gwagegi sogsamalad: 
\q2 “¡Bela anmar we-dulemar-obelogo!” 
\q2 ¡Geb we-yargi bese-goled-negmar-bukwad bela ogumaksamalad! 
\b  
\q1  
\v 9 Anmar, anmar-bander gwen memermaknai bar-daksulid, 
\q2 dule-Bab-Dummad-e-gayaburba-barsogedbela bergusbalid. 
\q2 Anmar we-ibmargunaid-e-ibagan-bergudapoed gwen wissurbalid. 
\q1  
\v 10 Bab-Dummad, ¿sanadse dule-isdarmalad begi dododii guoe? 
\q2 ¿Sanadse dule-isdarmalad be-nug oichodii guoe? 
\q1  
\v 11 ¿Ibiga be sabsur-odurdaksuli? 
\q2 ¿Ibiga be bai-gwen-daksuli? 
\b  
\q1  
\v 12 Bab-Dummad, bedina bato-sailanagi an-reyga be maid. 
\q2 We-napneggi bendakleged-igar be oyomaid. 
\q1  
\v 13 Be-garganguedgi be demar egasbalid, 
\q2 be ibdulamar-dummagan-diakinmalad-e-nono marisad. 
\q1  
\v 14 Be ibdula-dummad-diakined Leviatánʼye-nugad-e-nono ubigwar be imaksad. 
\q2 Ibdurgan-negsulidganba-gudimalad Leviatán-e-san-gunmalaga be imaksad. 
\q1  
\v 15 Dii-sailagan-ariogega be imaksad, 
\q2 dianmar-megega be imaksad, 
\q2 diwar-dummagan-mamaid-dinguega be imaksabalid. 
\q1  
\v 16 Be neg-meegwad nasiksad, mutikid be nasiksabalid. 
\q2 Be nii nasiksad, dad-ibeler be nasiksabalid. 
\q1  
\v 17 Napneg-naid-e-abingunanaid be mesisad, 
\q2 Be dii-wied-iba nasiksad, 
\q2 yolagued-iba be nasiksad. 
\b  
\q1  
\v 18 Bab-Jehová, nue be ebinsao: Be-isdarad begi ulusad. 
\q2 Dule-galagwensurdamalad be-nug isdar-daksamalad. 
\q1  
\v 19 Be-dula-belagwa-gudimalad mer be ibdurganga urmake. 
\q2 ¡Be-dula-wiledimalad mer be iego! 
\b  
\q1  
\v 20 Bab-Dummad, be-dulaga-be-igar-mesisad be ebinsao, mer be iego. 
\q2 Ar we-napneggi bela neg isgusnaid, bela neg-urwed naid. 
\q1  
\v 21 Dule-boniganba-galitodiid, melle be obingegsao. 
\q2 Dule-boniganba-galitodiid, 
\q2 dule-ibmar-abediid, be-nug-odummogega be imake. 
\b  
\q1  
\v 22 ¡Bab-Dummad, be-gargangued be oyoge! 
\q2 Be, dule-binsaedsuligudimalad bane-bane begi-urwedimalad, mer be baisurdake. 
\q1  
\v 23 Be-isdarmalad-begi-oimaknanaid, mer be baisurdake. 
\q2 Ar begi-yoledimalad nue-mergumamaid. 
\c 75  
\s1 Bab-Dummadbi igar-naboged-duled 
\d Asaf, namakmalad-e-iduedga we-namaked narmaksad. 
\d We-namakedi, “Mer neg-obergued” namaklegeyobi namaklegergebed. 
\q1  
\v 1 Bab-Dummad, anmar doggus-nuedye bega soged, anmar bese goled. 
\q2 Dulemar be-ibmar-gegerdaklemalad-imaksadgi sunmakmalad. 
\b  
\q1  
\v 2 Bab-Dummadye, be soged: “An igar-nabogoye-sokalile, 
\q2 innikigwadgi an igar nabogoed. 
\q1  
\v 3 Napaneg-giglimakdele, bela egi-bukwamalad giglimakdele, 
\q2 ar ani an napneg-e-sailamar-ganikid ogannoged.” 
\b  
\q1  
\v 4 Nug-dummarba-imakdimaladga an soged: “¡Mer be na nug-dummarba imakmar!” 
\q2 Dule-isganamarga an soged: “¡Mer be na san-dummarba imakmar! 
\q1  
\v 5 ¡Mer be na gangued-nikadba yamo san-gannarba imakmar! 
\q2 ¡Mer be na bule-bule sunmakmar!” 
\b  
\q1  
\v 6 Ar nug-dummarba-guedi, dad-nakwedsik danikosulid, dad-argwanedsik danikosulid, 
\q2 nega-dulesulidganba danikosulid. 
\q1  
\v 7 Ar unnila Bab-Dummadbi igar-nabogedid. 
\q2 Bab-Dummad belallaa dulemar-nug odummosulid. 
\q1 Abala e-nug-bipii imaked, 
\q2 abala e-nug-dummarba imaked. 
\q1  
\v 8 Bab-Jehová sabsur-dule-isganamar-odurdakega e-argangi nog-enamakar vino-gagbid-ibmar-baiganba-oburaled siid. 
\q2 A-vino-gagbid-eodele, bela dule-isganamar-we-napneggi-gudidiid, vino-gagbid-e-asase-bakale, gobmaloed. 
\b  
\q1  
\v 9 Ar andi, Jacob-e-Bab-Dummadgi degisadegu sunmakdii guoed, 
\q2 Jacob-e-Bab-Dummadga an namakdii guoed. 
\q1  
\v 10 Ar Bab-Dummad, dule-isganamar-e-gangued bela obelogoed, 
\q2 dule-nued-e-gangueddi, ogannogoed. 
\c 76  
\s1 Bab-Dummad gege-galakued 
\d Asaf, we-namaked narmaksad. Namakmalad-e-iduedga-sogleged: 
\d We-namakleged, Neginotʼba namaklegoye. 
\q1  
\v 1 Judá-yalagine, bela Bab-Dummad magar-dakmalad, 
\q2 Israel-yalagi, e-nuga dummarba gued. 
\q1  
\v 2 Ese-goled-neg Salemʼgi siid, 
\q2 e-meged-neg Sión-yalagi siid. 
\q1  
\v 3 A-yalagine, Bab-Dummad warsi-e-sigumar bibichisad, 
\q2 sigu-abgamalad bibichisad, 
\q1 es-suidmar bibichisad, 
\q2 bila-onolegedgi-ibmar-ebulemalad, bela obelosad. 
\b  
\q1  
\v 4 Bab-Dummad, bedi dule-gandikidid, 
\q2 bedi yalamar-degisadegu-bukwadba bur gandikidid. 
\q1  
\v 5 Dule-bulegan omilede gusmalad, burgwismalad. 
\q2 We-dule-bulegan gannale bar gwisguosurmalad. 
\q1  
\v 6 Be, Jacob-e-Bab-Dummad, egi be gwichigusgua, 
\q2 e-moli-urmar, e-molimar geg bar nanae gusad. 
\q1  
\v 7 ¡Bebi, unnila be-dobmalad! 
\q2 Be uludegwale, ¿doa be-asabin gwisguoe? Suli, dule gwen gwisguosuli. 
\q1  
\v 8 Bab-Dummad, be nibneg-akale igar-nabosad. 
\q2 Bab-Dummad, napneggi san-bipi-imakdimalad-abonogega, 
\q1  
\v 9 be gwichiguargusgu, napnega dobee itosad, 
\q2 napnega bogi nagusad. 
\b  
\q1  
\v 10 Dule-begi-urwedimalad aka be-nug-ogannogoed. 
\q2 Dule-begi-urwedimalad-besmaladi aka bega iba-dummad onomaloed. 
\q1  
\v 11 Be-Bab-Dummad-Jehováʼba, ise-ibmar-sogar be imakmar, 
\q2 ega sogedba be ibmar imakmarbalo. 
\q2 Bela yarmar-anmar-neggwebur-dikarba-bukwadi, Bab-Dummad-gandikidga ibmar-ukleged sedamalo. 
\q1  
\v 12 Ar Bab-Dummadi, dule-dummagan-negdakmamaid obelogedid, 
\q2 napneggi reymar-mamaid-odobguedid. 
\c 77  
\s1 Bab-Dummad-ibmar-dummagan-imaksadgi binsaed 
\d Asaf, we-namaked narmaksad. Namaked-idued-Jedutúnʼga soglenaid. 
\q1  
\v 1 Bab-Dummad an-itogega, an ese binnasuli goled. 
\q2 Suli-suli an itodiidgine, Bab-Dummadse an goted. 
\q1  
\v 2 Bab-Dummadse mutikidba bogigusuli an argan-onakgwar gormai daed, 
\q2 degite, amba an-gwage naibi-itodaed. 
\q1  
\v 3 Bab-Dummadgi an binsadele, nue-bukib an itodaed. 
\q2 An egi nue-binsadele, an boddaed, 
\q2 an binsaddaed bar an bendaklegosurye. 
\b  
\q1  
\v 4 Bab-Dummad, gabsuli be an-imaked. 
\q2 Suli-suli an-itosoggu, geg sunmak an naddaed. 
\q1  
\v 5 Ibagan-epenne-nasmalad an insaddaed, 
\q2 birgamar-epenne-nasmalad an insaddaed. 
\q1  
\v 6 An mutikidba-namakmaidaed an ebinsaddaed, 
\q2 ulubgi an binsamaidaed, an egismaidaed: 
\q1  
\v 7 “¿Ar Bab-Jehová degisadegu anmar-obandiguode? 
\q2 ¿Ar anmargi nued-binsadii bar guosurde? 
\q1  
\v 8 ¿Bab-Dummad degisadegu-anmar-sabgudiid bergussi? 
\q2 ¿Bab-Dummad anmarga-ibmar-imakoye-sogsad degisadegu bergussi? 
\q1  
\v 9 ¿Bab-Dummad dule-wiledaked iessi? 
\q2 ¿Bela-bela urwemaidba, bar anmar-sabguosurde?” 
\b  
\q1  
\v 10 Geb an sogdesunnad: Bab-Dummad-Bur-Birigined bar epennegii anmarga ibmar imaksulid. 
\q2 We, nue-nunmak an-imaked. 
\q1  
\v 11 Epenne Bab-Jehová-ibmar-dakledisurmalad-imaksad an ebinsaoed. 
\q2 Epenne Bab-Jehová ibmar-gegerdakleged-imaksad an ebinsaoed 
\q1  
\v 12 Bab-Dummad-ibmar-dummagan-imaksad an egi binsaoed, 
\q2 be-ibmar-dummagan-imaklesadgi an sunmakoed. 
\q1  
\v 13 Bab-Dummad, be-ibmar-imaked islidikidbiid. 
\q2 ¡Bab-dummagan-baigan anmar-Bab-Dummadyobid sulid! 
\q1  
\v 14 Bab-Dummad, be ibmar-dakledisulid-imakedid. 
\q2 Be-gangued dulemar-yar-baid-baidgi-bukmaladse be oyomaid. 
\q1  
\v 15 Be-ganguedgi, be-dulamar be ollor-imaksad, 
\q2 Jacob-wagan be ollor-imaksad, 
\q2 José-wagan be ollor-imaksad. 
\q1  
\v 16 Bab-Dummad, demar be-daksagua, be-dobguded, 
\q2 muu-wilasailad be-daksagua, binnasuli giglimakded. 
\q1  
\v 17 Mogirmar, dii-dummad owialid, 
\q2 nibneggi, malamar gollomakded, 
\q2 nibneggi, malamar ibyeded. 
\q1  
\v 18 Burwa-bipirmakaled-imbaba be-goled malayobi binnasuli gollomakded, 
\q2 be-mala-ibyemamaid napaneg ibegwar-imakded, 
\q2 napaneg wawanmakded, bela giglimakded. 
\q1  
\v 19 Demar-abargi, igar be mesisad, 
\q2 Muu-billi be egasad, 
\q2 a-abargi be nasad, 
\q1 degite, be-gannar daksasurmalad. 
\q2  
\v 20 Sibad-wawaadyobi be-dulamar Moisésʼba, Aarónʼba be semai gusad. 
\c 78  
\s1 Bab-Dummad e-dulamarga ibmar-imaked 
\d Asaf, we-namaked-Masquilʼye-nugad narmaksad. 
\q1  
\v 1 An-dulamar, an-ibmar-odurdaked be nue itomala, 
\q2 an-ibmar-soged be nue itomala. 
\q1  
\v 2 An ibmar-burbarmaladba sunmakoed, 
\q2 dikasurgus negasailaunni ibmar-dukuar-mamaidi, an osanalogoed. 
\q1  
\v 3 Anmar bato we-ibmar itodiid, bato anmar wisid. 
\q2 We-ibmar anmar-babgan anmarga sogsadid. 
\q1  
\v 4 Anmar anmar-mimmigangi we-ibmar odukuosulid. 
\q2 Anmar anmar-wagan-danimaloedga Bab-Jehová-e-ganguedgi sunmakoed, 
\q1 e-ibmar-dummagan-imaksadgi sunmakoed, 
\q2 e-ibmar-dakledisurmalad-imaksadgi sunmakoed. 
\q1  
\v 5 Bab-Dummad, Jacob-waganga Igar mesisad, 
\q2 Israel-dulemarga Igar mesisad. 
\q1 Anmar-dadganga-Igar-uksagusad, 
\q2 be-wagan be odurdakoye, 
\q1  
\v 6 adi, yoedse-be-wagan-danimaloedi, bela we-Igar wisgumalagarye, 
\q2 degi, yoedse-mimmigan-gwalulemaloedi, bela we-Igar wisgumarmogagarye, 
\q2 we-mimmiganmoga, we-Igargi na e-mimmigan-odurdakmogoed. 
\q1  
\v 7 Deyobi, wemala, Bab-Dummadgi bensuli gumaloed, 
\q2 Bab-Dummad-e-ibmar-dummagan-imaksad iegosurmalad. 
\q2 Bab-Dummad-Igar-Maidba ibsamaloed. 
\q1  
\v 8 E-dadganyobi guosurmalad. 
\q2 E-dadgandi, binsaed-sate, uayasuli gusmalad, 
\q1 e-gwagegi innikigwadba nanassurmalad, 
\q2 e-ulubgi Bab-Dummad-sogedba gudii gussurmalad. 
\q1  
\v 9 Efraín-wagan, sigu-miemalad-buleganad, 
\q2 degi-inigwele, bila-onolenaid-ibagi wakite gusmalad. 
\b  
\q1  
\v 10 Israel-dulemar Bab-Dummadbo-Igar-Mesisadba ibmar imaksasurmalad, 
\q2 Bab-Dummad-Igar-Maidba ibsassurmalad. 
\q1  
\v 11 Bab-Dummad-ibmar-dummagan-imaksadi, 
\q2 ega ibmar-gegerdaklemalad-oyosadi, bela iesmalad. 
\q1  
\v 12 Bab-Dummad Egipto-yargi, Zoán-nebagi, e-dadganga ibmar-dakledisurmalad-oyosgusadi, bela iesmalad. 
\q2  
\v 13 Bab-Dummad, Israel-dulemar nabir-obakmalagala demar-dinnaa imaksad, 
\q2 demar gasdibiryob ganna mesisad. 
\q1  
\v 14 Bab-Dummad, ibginedba mogirbali Israel-dulemar-idu-nadapi gusad, 
\q2 mutikidba soo-gaedbali idunadapi gusad. 
\q1  
\v 15 Bab-Dummad, nega-dulesulidganba akwasaila marisad. 
\q2 A-akwagi dii-aryomai imaksad, 
\q2 geb a-dii-gobmalaga imaksad. 
\q1  
\v 16 Bab-Dummad, akwagi dii-aryogega imaksad, 
\q2 diwaryobi dii-aryomai imaksad. 
\b  
\q1  
\v 17 Degi-inigwele, Israel-dulemar gannar Bab-Dummadgi-isgunai gusmalad, 
\q2 nega-dulesulidganba Bab-Dummad-Bur-Biriginedgi gwisgunai gusmalad. 
\q1  
\v 18 Israel-dulemar, yamo Bab-Dummad-wilubdakbi gusmalad, 
\q2 agala, e-abegedba Bab-Dummadse masgunned-egicha gusmalad. 
\q1  
\v 19 Bab-Dummadgi sunmaksa gusmalad, sogsagusmalad: 
\q2 “¿Bab-Dummad, sunna anmarga nega-dulesulidganba mas-ukoe? Suli. Anmarga geg uke. 
\q1  
\v 20 Ar napiragwa, Bab-Dummad akwasaila-sarsosgua, dii binnasuli aryoargusad. 
\q2 Ar anmarga-mas-ukegala, ¿deyob imakbalo be ebinsae? 
\q2 E-dulamarga, ¿sunna san ukbalo be ebinsae?” 
\q1  
\v 21 Bab-Jehová, Israel-dulemar weyob-soge-itosgua, bela-belad uluded. 
\q2 Jacob-wagangi sae-itoded, 
\q2 Israel-dulemargi sabsur-uluded. 
\q1  
\v 22 Ar Israel-dulemar Bab-Dummadgi bengusmalad, 
\q2 Bab-Dummad e-bendakosurye binsasmalad. 
\q1  
\v 23 Bab-Dummad, nibneg-akale, mogirmarga igar-uksad, 
\q2 degidba, mogirmar argaded. 
\q1  
\v 24 Bab-Dummad, Israel-dulemar mas-gunmalagala, mas-manáʼye-nugad ega obatisad, 
\q2 madu-nibneggined-gunmalaga imaksad. 
\q1  
\v 25 Bela Israel-dulemar baliwitur-e-madu guchamalad. 
\q2 Nue-immelegedse-gunmalagala, Bab-Dummad ega mas barmialid. 
\q1  
\v 26 Bab-Dummad, dad-nakwedsikid-burwa barmiar gusad. 
\q2 E-gangued-nikadba dad-nakwed-argan-nuedsikid-burwa barmiar gusad. 
\q1  
\v 27 Bab-Dummad, ukub-mileddaedyobi ega san obatisad, 
\q2 demar-gakaba ukub-mergunaiyob ega nuumar obatisad. 
\q1  
\v 28 Bab-Dummad, dulemar-danar-danar-bukwamaladgi, nuumar-babatega imaksad, 
\q2 Israel-dulemar-e-neg-gabmalad-dikarba nuumar-obatisad. 
\q1  
\v 29 Israel-dulemar bela-bela-immelegedse mas-guchamalad. 
\q2 Deyobi, Bab-Dummad, ibmar-egichamaladi ega uksad. 
\q1  
\v 30 Ar undar-immerba-gudii gussurmalad, 
\q2 ar amba e-gaya-yaba mas-sigua, 
\q2  
\v 31 Bab-Dummad-e-urwed egi gwisgunonikid. 
\q1 Bab-Dummad, e-ibe bur-dule-dutusurmalad oburgwisad, 
\q2 Israel-dulemar-bur-nuga-nikamalad ogilosad. 
\b  
\q1  
\v 32 Degi-inigwele, Israel-dulemar amba isgudii gusmalad, 
\q2 Bab-Dummad-geger-ibmar-daklemalad-imaksadgi bengusmalad. 
\q1  
\v 33 A-ulale, Bab-Dummad, Israel-dulemar-e-ibagan sikwas-bunnogedyobi, berguega imaksad, 
\q2 e-birgamar dobed-dummad-abalagi, berguega imaksad. 
\q1  
\v 34 Ar Bab-Dummad Israel-dulemar-abar-oburgwisale, geb Israel-dulemar-baigan gannar Bab-Dummad-amiddamalad, 
\q2 gwae-gwae gannar Bab-Dummadse nonidamalad. 
\q1  
\v 35 Geb ebinsaddamalad, Bab-Dummad ega akwasailayob guye, 
\q2 Bab-Dummad-Bur-Birigined e-bendaked guye. 
\q1  
\v 36 Ar Israel-dulemar e-gayaginbi, e-gwabin-dukuginbi, 
\q2 gakansaar Bab-Dummad-nug-odummodii damalad, 
\q1  
\v 37 ar e-ulubgindi ega gakansadii damalad. 
\q2 Bab-Dummadbo-Igar-Mesisadba, sogedba imaksasurmalad. 
\q1  
\v 38 Degi-inigwele, Bab-Dummaddi wemar-wiledaksad, 
\q2 e-isgusad ega elisad, wemar-obelossurgusad. 
\q1 Bab-Dummad, gannar-gannar na e-urwed-barganai gusad, 
\q2 e-urwedba ibmar-imaknai gussulid. 
\q1  
\v 39 Bab-Dummad ebinsasgusad, wemarde unnila dulemar-guye, 
\q2 unnila burwa-goleyob guye, gwen bar daklegosurye. 
\b  
\q1  
\v 40 Israel-dulemar, nega-dulesulidgangi, bukidargus Bab-Dummadgi-yoledanigusmalad. 
\q2 Nega-dulesulidgangi Bab-Dummad-wile-itogega imaksamalad. 
\q1  
\v 41 Gannar-gannar Bab-Dummad-wilubdaknai gusmalad, 
\q2 Israel-e-Bab-Dummad-Isligwaled-ourwenai gusmalad. 
\q1  
\v 42 Bab-Dummad-e-gangued bipisaar ebinsassurmalad, 
\q2 e-isdarmaladse-wilebukwa-onolesgusadi, ebinsassurmalad. 
\q1  
\v 43 Egipto-yargi, Bab-Dummad ibmar-dakledisurmalad-oyosad iesmalad, 
\q2 neba-Zoánʼye-nugadgi ibmar-dummagan-imaksad iesmarbalid, 
\q1  
\v 44 Bab-Dummad, Egipto-yar-e-diwarmar abega obinnisad, 
\q2 Egipto-dulemar, a-diwar geg gobe gusmalad. 
\q1  
\v 45 Bab-Dummad, Egipto-dulemargi, gukurmar-bela-ibmar-biin-imakmalad barmiar gusad. 
\q2 Noomar-ibmar-obelomalad barmiar gusbalid. 
\q1  
\v 46 Bab-Dummad, Egipto-dulemar-e-ibmar-gwag-wesmaladi, sese-burwigana-omaega imaksad, 
\q2 e-ibmar-gwag-gullemalad-digarmaladi, sesega urmaksabalid. 
\q1  
\v 47 Bab-Dummad, Egipto-dulemar-e-uvaʼdub-digarnanaid, dii-gwamakaled-obatisadgi obelosad, 
\q2 e-higo-sapimar, boo-gwamakarmaladgi obelosad. 
\q1  
\v 48 Bab-Dummad, Egipto-dulemar-e-moli-bebe-nikamalad, dii-gwamakaled-obatisadgi oburgwisad. 
\q2 E-sibad-wawaadmar mar-egi-odesadgi obelosad. 
\q1  
\v 49 Bab-Dummad, Egipto-dulemargi bela-bela-e-urwed, e-sae-itoged, e-isdar-itoged, e-sae-daked barmiar gusad. 
\q2 Baliwitur-ibmar-obelomalad danagwen barmiar gusad. 
\q1  
\v 50 Bab-Dummad na e-urwed bar bargassur gusad. 
\q2 Burgwedgi, Egipto-dulemar bar ollor-imaksasulid, 
\q2 boni-dummaganga urmaksagusad. 
\q1  
\v 51 Bab-Dummad, bela Egipto-dulemar-e-machi-sailaginmalad oburgwisad, 
\q2 Cam-dulemar-e-machi-sailaginmalad ogilosad. 
\q1  
\v 52 Bab-Dummad, sibad-wawaad-danar-bukwadyobi, Israel-dulamar-idunadapi gusad, 
\q2 nega-dulesulidganba senadapi gusad. 
\q1  
\v 53 Bab-Dummad, Israel-dulamar-mer-dobee-itomalaga, igar-nueganba semai gusad. 
\q2 E-isdarmaladdi demargi-gundilegega imaksad. 
\b  
\q1  
\v 54 Bab-Dummad, na e-yar-islidikidse Israel-dulamar-senoni gusad, 
\q2 na e-garganguedgi we-yarmar-susadse senonikid. 
\q1  
\v 55 Bab-Dummad, Israel-dulemar-nadapid-idu dule-baigan-bukwad onosgusad, 
\q2 we-dulemar-e-napamar, Israel-dulemargadga-guega ega uksad. 
\q1 Deyobi, Bab-Dummad, a-napamargi, 
\q2 Israel-dadgan-dummagan-wagan urbisad. 
\b  
\q1  
\v 56 Degi-inigwele, Israel-dulemar Bab-Dummad-wilubdaknai gusmalad, 
\q2 Bab-Dummad-Bur-Biriginedgi aibitemalad, 
\q2 e-Igar-Maidba ibsassurmalad. 
\q1  
\v 57 E-babganyobi Bab-Dummadgi aibatemalad, egi yolenai gusmalad. 
\q2 Israel-dulemar, warsi-binsaledyob dopere gusmalad. 
\q1  
\v 58 E-bab-dummadse-goled-neg-sobsamaladba, Bab-Dummad-oulusmalad, 
\q2 ibmar-e-bab-dummadga-imakdimalad-e-wilub-sobsamaladba, Bab-Dummad-nobguega imaksamalad. 
\q1  
\v 59 Bab-Dummad, weyob ibmar-daksagua, uluded, 
\q2 degidbali, bela Israel-dulemar-obachad. 
\q1  
\v 60 Silo-neggweburgi e-neg-meged-siidgi aibated. 
\q2 Agi, Bab-Dummad dulemar-abargi maidaenad. 
\q1  
\v 61 Bab-Dummad, na e-Ulu, e-gangued-yeerdakleged-e-wilubga guedi, 
\q2 e-isdarmaladse-galegega imaksad. 
\q1  
\v 62 Bab-Dummad bela-bela e-dulamargi urwemaisoggu, 
\q2 es-suidgi e-dulamar-oburgwilegega imaksad. 
\q1  
\v 63 E-dula-sapingan soogi gummaksamalad, 
\q2 e-yaganga sui-nikued-ibagi-namakleged namaklessulid. 
\q1  
\v 64 E-dule-irwa-Bab-Dummadse-gormalad es-suidgi oburgwilesmalad, 
\q2 E-omegan-e-ibe-sui-burgwismaladi, e-suimarga gwen bonai gussurmalad. 
\b  
\q1  
\v 65 Geb Bab-Dummad, igi-dule-gabmair atakardae, 
\q2 deyobi atakalid. 
\q1 Igi-dule-bila-onoged-buled vino-gobnair binnasuli gormakdedae, 
\q2 deyobi Bab-Dummad uludedba binnasuli goted. 
\q1  
\v 66 Bab-Dummad, e-isdarmalad-sikirmakega imaksad, 
\q2 degisadegu bingeguega imaksad. 
\q1  
\v 67 Bab-Dummad, José-wagan-obachad, 
\q2 Efraín-wagan-sussulid. 
\q1  
\v 68 Bab-Dummad, aka bur Judá-wagan-sunonikid, 
\q2 na e-yar-bur-sabed-Sión sunonikid. 
\q1  
\v 69 Bab-Dummad, ese-goled-nega nibnegyobi matusuli sobsad, 
\q2 Bab-Dummad, igi-napneg degisadegu-gangu-nasiksa, 
\q2 deyobi na e-neg gangu sisad. 
\q1  
\v 70 Bab-Dummad, e-mai-David-sunonikid, 
\q2 sibad-wawaad-edarbedgi-arbadiidgi David-onosad. 
\q1  
\v 71 Sibad-wawaad-baregindidaedgi, Davidʼse gochad. 
\q2 Bab-Dummad, ega e-dulamar-Jacob-wagan-akwega, 
\q2 Israel-dulemar-egad-gued-akwega, Davidʼse gochad. 
\q1  
\v 72 David na e-gwage-innikigwadba Israel-dulemar-akwisad, 
\q2 e-binsaed-nue-nikadba dulemar-idudii gusad. 
\c 79  
\s1 Jerusalén-neggwebur-bergusadba nunmak-itoleged 
\d Asaf, we-namaked narmaksad. 
\q1  
\v 1 Bab-Dummad, dulemar-aku-be-dakmalad be-yargi ubosmalad. 
\q2 Bese-goled-neg-islidikid oichosmalad. 
\q2 Jerusalén-neggwebur akwabi-dunnumakbukwa imaksamalad. 
\q1  
\v 2 We-dulemar, be-maimar-e-mui, mulamarga masga uksamalad. 
\q2 Dule-bega-inniki-nanadiid-e-sanmar, ibdurgan-ursilimarga masga uksamarbalid. 
\q1  
\v 3 Be-maimar-e-ablis, bela Jerusalén-neggweburgi diiyobi eosmalad. 
\q2 Burgwismalad-digega dule sate gusad. 
\q1  
\v 4 Dulemar-anmar-yar-dikarba-bukmaladi, anmargi dodomalad, 
\q2 dulemar-anmar-yar-dikarba-bukmaladga anmar e-dodoedga gued. 
\b  
\q1  
\v 5 Bab-Jehováʼye, ¿sanagwadse be-urwed berguoe? 
\q2 ¿Sanagwadse degisadegu be urwemai guoe? 
\q2 ¿Sanagwadse be-nobgued sooyob gamai guoe? 
\q1  
\v 6 Dulemar-aku-be-dakmaladse be urwe, 
\q2 dulemar-bese-gordisurmaladse be urwe. 
\q1  
\v 7 Ar we-dulemar, Jacob-wagan obelosmalad. 
\q2 Jacob-wagan-e-yar akwabi-dunnumakbukwa imaksamarbalid. 
\q1  
\v 8 Bab-Jehováʼye, anmar-epenne-isgusad, mer be bar ebinsae. 
\q2 Be-wiledaked gwae be anmarga oyoge, 
\q2 ar anmar bela-bela oitoles bukwad. 
\b  
\q1  
\v 9 Bab-Dummad-anmar-abonoged, be-nug-dummarba-gued-ular, be anmar-bendake. 
\q2 Be-nug-sabed-ular, be anmar-ollorsae, anmar-isgusad be elie. 
\b  
\q1  
\v 10 Ar ibiga dulemar-yar-baigangi-bukwad sogmaloe: “¿Bia e-Bab-Dummad nade?” 
\q2 Be anmarga oyoge, igi-be, be-dulamar-e-ablis-aryosad be buged-mai imake. 
\q1 Bela dulemar-yar-baid-baidgi-bukwamaladga oyobali, 
\q2 igi-be, be-maimar-e-ablis-aryosad be buged-mai imake. 
\b  
\q1  
\v 11 Dule-galesbukmalad-e-boed be itoge, 
\q2 dule-oburgwilesokarmaladi, be-garganguedba be bendake. 
\q1  
\v 12 Bab-Jehová, dulemar-anmar-yar-dikarba-bukwamalad begi dummad-dododigusmaladi, 
\q2 ilagugle (7) deyob-egi-dodomarmogaga be imake. 
\q1  
\v 13 Anmardi, be-dulamar-gumalad, 
\q2 be-sibad-wawaadmaryob-gumalad. 
\q1 Degisadegu, anmar dog-nuedye bega sogmaloed. 
\q2 Degisadegu, anmar bega namakmaloed. 
\c 80  
\s1 Bab-Dummadse-goled, Israel-yar gannar nudakye 
\d Namakmalad-e-iduedga-sogleged: 
\d We-namaked, Dutu-Lirioʼgi-namaklegedyob namaklegoye. 
\d Asaf e-gudiidba we-namaked narmaksad. 
\q1  
\v 1 Bab-Dummad, Israel-dulemar-edarbed, be anmar-itoge. 
\q2 Be, sibad-wawaad-edarbedyobi José-wagan-e-iduedid, 
\q2 be, baliwiturmar-querubinʼye-nugad-abargi negsemaidid. 
\q1  
\v 2 Efraín-waganse, Benjamín-waganse, Manasés-waganse, be magar gue. 
\q2 Be-gangued be oyoge, be bela-bela anmar-bendakdage. 
\b  
\q1  
\v 3 Bab-Dummad, igi-anmar epenne bukwagusa, deyobi, be gannar anmar-imake. 
\q2 Bab-Jehováʼye, be anmargi ise-nued-binsae, 
\q2 be bela-bela anmar-bendake. 
\b  
\q1  
\v 4 Bab-Dummad-Jehová-Bela-Gangued-Nikad, be-urwe-maid-ulale, ¿sanagwadse be-dulamar-bese-goled be itogosuli? 
\q2  
\v 5 Boed-dummad e-masgunnedyob ega be uksad, 
\q2 ibyanis-obinebaka e-gobedyob ega be imaksad. 
\q1  
\v 6 Dulemar-anmar-yar-dikarba-bukwamaladi, anmarga allega be imaksad, 
\q2 anmar-isdarmalad anmargi dodomalad. 
\b  
\q1  
\v 7 Bab-Dummad-Bela-Gangued-Nikad, igi-anmar epenne bukwagusa, deyobi be gannar anmar-imake. 
\q2 Bab-Jehováʼye, be anmargi ise-nued-binsae, be anmar-abonoge. 
\b  
\q1  
\v 8 Bab-Dummad, Egipto-yalagi be uva-dub seargusad, 
\q2 Canaán-yargi dulemar-Bab-Dummad-akudakmalad be ononnosgusad, 
\q2 geb we-uva-dub be digsagusad. 
\q1  
\v 9 Ega be neg-emisad, 
\q2 uva-dub-e-maligan gatik-diglemai be imaksad, 
\q2 bela-yar-gasa nagusad. 
\q1  
\v 10 Bela uva-dub-gagan-urba negsichigwadgi yarmar bukusad, 
\q2 e-dubagan, urwar-sapi-matusur-gwigwichidgi bipirmakde gusad. 
\q1  
\v 11 E-anamar, demar-Mediterráneoʼse warmaksad, 
\q2 e-muugan, Éufrates-diwarse nasgumai gusad. 
\b  
\q1  
\v 12 Bab-Dummad, ¿ibiga uva-nainu-e-galu-emakaled be earisa? 
\q2 Bela-dulemar-e-dikarba-nasdamaladi, e-ibe san gwandamalad. 
\q1  
\v 13 Wedarmala bela-bela wionaid, 
\q2 ibdurgan-ursirmar gundamalad. 
\q1  
\v 14 Bab-Dummad-Bela-Gangued-Nikad, be anmarse gannar dage, 
\q2 nibneg-akale be atake, 
\q2 we-uva-dub be bendakdage. 
\q1  
\v 15 Be-sunnad we-uva-dub be digsagusad. 
\q2 Begadga-guega e-ana be odummosad. 
\b  
\q1  
\v 16 Be-uva-dub aimukus maid, soogi ogumaklesad. 
\q2 Be-urwedbali be-dulamar burgwemamaid. 
\q1  
\v 17 Dule na be susagusadi, be bendake, 
\q2 dule-begadga-guega na be odungusgusadi, be bendake. 
\q1  
\v 18 Ar deyob be imakele, anmala begi aibanosurmalad. 
\q2 Gannar-dula-gudii be anmar-imake, anmar unnila besebi gordii gumaloed. 
\b  
\q1  
\v 19 Bab-Dummad-Jehová-Bela-Gangued-Nikad, igi-anmar epenne bukwagusa, deyobi be gannar anmar-imake. 
\q2 Bab-Jehováʼye, be anmargi ise-nued-binsae, 
\q2 be bela-bela anmar-bendake. 
\c 81  
\s1 Bab-Dummad e-dulamargi nueddaed 
\d Namakmalad-e-iduedga sogleged: 
\d Igi uva-nis-egurelealir gar-ogorledae, abali, namaklegoye. 
\d Asaf, we-namaked narmaksad. 
\q1  
\v 1 Bab-Dummadga weligwaledgi namakmala, e anmar-ogannogedid. 
\q2 Jacob-e-Bab-Dummadga binnasuli weligwaledgi namakmala. 
\q1  
\v 2 Namakmala, gar-pandero ogormala, 
\q2 gar-lira ogormala, gar-arpa ogormala. 
\b  
\q1  
\v 3 Nii-binid-gwisgunonikidgi, gar-trompeta ogormala. 
\q2 Nii-dalu-naidgi anmar-iba-dummad-guedgi, gar-trompeta ogormala. 
\q1  
\v 4 Ar weyob-imakoye Bab-Jehová Israel-dulemarga igar uksad, 
\q2 weyob Jacob-e-Bab-Dummad igar mesisad. 
\q1  
\v 5 José-wagan Egipto-yargi noargu, 
\q2 Bab-Dummad José-waganbo igar mesisad. 
\b  
\q1  
\v 6 Dule-sunmaked an itosad, an wissulid, doa anga sunmake. 
\q2 Anga weyob soged: 
\q1 “Be-gukingi be ibmar-ukusulid-semaid an bega osulosad. 
\q2 Arbaed-dummad be imakdiidi an bega obelosad. 
\q1  
\v 7 Bemar suli-suli-itoarmargua, be anse gochamalad, 
\q2 agine, an be-bendaksamalad. 
\q1 Mogir-gudureged-imbaba, an be-abin-imaksamalad. 
\q2 Mar-gollomakmaid-abargi, an be-abin-imaksamalad. 
\q2 Meriba-dii-naba an bemar-wilubdaksad. 
\b  
\q1  
\v 8 ”An-dulamar, an be-owisogega bega ibmar-sogedi, be itomala. 
\q2 Israel-dulemar, bitigi be an-itosmalana gadin. 
\q1  
\v 9 Bab-dummagan-bamalad be-Bab-Dummadga be imakosurmalad, 
\q2 bab-dummagan-bamalad-asabin, be yokorgi sindigar sigosurmalad. 
\q1  
\v 10 Ani, an be-Bab-Dummad-Jehová gued. 
\q2 Ani an Egipto-yargi bemar-onosad. 
\q1 Guagwar be bukumala, 
\q2 an bemarga mas-obinebaka ukoed. 
\b  
\q1  
\v 11 ”Degi-inigwele, an-dulamar an-itossurmalad, 
\q2 Israel-dulemar anba ibsabisur gusad. 
\q1  
\v 12 A-ulale, na e-itolegedba-ibmar-imakega an imaksad. 
\q2 Na e-itolegedba-nanadii gusmarsunnad. 
\b  
\q1  
\v 13 ”Ar an-dulamar an-itosana, 
\q2 ar Israel-dulemar an-igar-mamaidba nanasmalana, 
\q1  
\v 14 an ega e-isdarmalad irgwensuli osulosanad, 
\q2 an e-isdarmalad sabsur-odurdaksanad. 
\q1  
\v 15 Dulemar-Bab-Jehová-isdar-dakmalad, Bab-Jehová-e-nug bela-bela odummodmaloenad. 
\q2 Degi-inigwele, an a-dulemar degisadegu sabsur-odurdakoed. 
\q1  
\v 16 An-dulemardi trigo-gwag-bur-nuedgi an oguchaled, 
\q2 akwamargi-achanis-nanaidgi, immerba-itomalaga an imaksaled.” 
\c 82  
\s1 Bab-Dummad dule-igar-naboged-e-dummadid 
\d Asaf, we-namakleged narmaksad. 
\q1  
\v 1 Bab-Dummad, bab-dummagan-onmakbukwad-e-dummadga siid, 
\q2 amarga igar-nabogedga siid. 
\b  
\q1  
\v 2 “¿Ar sanagwadse, bemar yogasaar igar-nabodii gumaloe? 
\q2 ¿Ar sanagwadse, bemar dule-isganamargarbi igar-nudakdii gumaloe? 
\b  
\q1  
\v 3 ”Be dule-e-sergan-sate-gudimalad, be bendakmala, 
\q2 be dule-bendaked-sate-gudimalad, be bendakmala. 
\q1 Dule-wilemaladga, be innikigwadgi igar-nabomala, 
\q2 dule-sabsur-imakledimaladga, be innikigwadgi igar-nabomala. 
\q1  
\v 4 Dule-e-bendaked-satemalad be dule-isganamargi bendakmala, 
\q2 dule-ibmar-abedimalad be dule-isganamargi bendakmala. 
\b  
\q1  
\v 5 ”We-dule-isganamar ibmar wissurmalad, ibmar aku-itomalad, 
\q2 negsichidgi gaamakdimalad, 
\q2 weyob gudimaladba bela napneg-saila-giglimakega imakmalad. 
\b  
\q1  
\v 6 ”An bemarga sogsa gusad: ‘Bemar bab-dummagan gumarye, 
\q2 bela-bemar Bab-Dummad-Bur-Birigined-e-mimmigan gumarye.’ 
\q1  
\v 7 Degi-inigwele, bemar dulemaryobi burgwemaloye, 
\q2 dummagan-negsemamaidyobi burgwemaloye.” 
\b  
\q1  
\v 8 ¡Bab-Dummad! We-napnegga be igar itodage, 
\q2 ar bela-dule-napneggi-bukwamalad begadid. 
\c 83  
\s1 E-isdarmalad-obelogega Babse-goled 
\d Asaf, we-namaked narmaksad. 
\q1  
\v 1 Bab-Dummad, melle be gaya-bogidik mege. 
\q2 Bab-Dummad, melle be sunmaksuli gue, 
\q2 melle be ibmar-imaksuli gue. 
\q1  
\v 2 Bab-Jehová, be dake, ibibayobi be-isdarmalad uurmakbukwa, 
\q2 ibibayobi isdar-be-dakmalad begi gwisgunanai. 
\q1  
\v 3 Be-dulamargi-aibinega yardakar igar-amismalad. 
\q2 Be-dulamar-na-be-sabgumaidgi-gwisgumalaga, yardakar bular igar-amismalad. 
\b  
\q1  
\v 4 We-dulemar sogmalad: “Dagmala, anmar bela e-dulamar obelonae. 
\q2 Deyobi, Israel-e-nug bar bipisaar ebinsalegosulid.” 
\b  
\q1  
\v 5 Dule-wargwennayob na igar-aminanaid, 
\q2 begi bila-onomalaga, we-dulemar na atosmalad: 
\q2  
\v 6 Edom-dorgan, Ismael-dorgan, 
\q2 Moab-dorgan, Agar-dorgan, 
\q2  
\v 7 Gebal-dorgan, Amón-dorgan, Amalec-dorgan, 
\q2 Filistea-dorgan, degi, Tiro-dorgan, bela wemar na atosmalad. 
\q2  
\v 8 Asiria-dorganse-bakale, bela wemarba atosad. 
\q3 Lot-wagan-bendakega atosmalad. 
\b  
\q1  
\v 9 Ar igi be Madián-dulemar-obelosgusa, 
\q2 deyobi be we-dulemar obelomoga. 
\q1 Ar igi be Sísara, degi, Jabín, Cisón-diangi-obelosgusa, 
\q2 deyobi be we-dulemar obelomoga. 
\q1  
\v 10 We-dulemar Endorʼgi burgwismalad, 
\q2 ibmar-isganayob napagi miled gusmalad. 
\q1  
\v 11 Ar igi be Oreb, degi, Zeeb, imaksagusa, 
\q2 deyobi be e-sordamar-dummagan imakmoga. 
\q1 Ar igi be Zeba, degi, Zalmuna, imaksagusa, 
\q2 deyobi be bela e-dummagan-nuga-nikamalad be imakmoga. 
\q1  
\v 12 Wemar sogsagusad: 
\q2 “Bab-Dummad-e-yar-naidi, anmar e-ibe sumala.” 
\b  
\q1  
\v 13 Bab-Dummad, we-dulemar burwaba-selegega be imake. 
\q2 Gaganmar burwaba-gukuddaeyobi be we-dulemar-imake. 
\q1  
\v 14 Ar igi soo sapur-ogumakdae, 
\q2 degi, igi soo-gwabunyemaid yarmar-ogumakdae, 
\q1  
\v 15 deyobi be we-dulemar, be-burwa-dummadgi be baleginne, 
\q2 be-burwa-ooredgi, be ogwaye. 
\q1  
\v 16 Bab-Jehová, we-dulemar be obingegsae, 
\q2 adi, magar-be-dakmalaga, be Bab-Dummad gued. 
\b  
\q1  
\v 17 We-dulemar, degisadegu bingegudii gumala, 
\q2 na bingegudii burgwemala. 
\q1  
\v 18 Na wisgumala, bebi Bab-Jehová gued, weyobi be nugad. 
\q2 Na wisgumala, napneggine, bebi unnila Bab-Dummad-Bur-Birigined gued. 
\c 84  
\s1 Bab-Dummadse-goled-negbina nue-soged 
\d Coré-e-wagan, we-namaked narmaksad. 
\d Namakmalad-e-iduedga soglesad: 
\d We-namakedi igi uva-nis-egurelealir gar-ogorledae, aba namaklegoye. 
\q1  
\v 1 Bab-Jehová-Bela-Gangued-Nikad, ibibayobi be-meged-negmala yeerdaklege. 
\q2  
\v 2 Bab-Jehováʼse-goled-neg-imbabina, an bela-bela ulubgi itoged, 
\q1 agi an gudiguega an surbinsa itoged. 
\q2 Bela-belad an-ulubgine, an-gwagegine, Bab-Dummad-Dula-Maidga an weligwaledgi namaked. 
\b  
\q1  
\v 3 Bab-Jehová-Bela-Gangued-Nikad, an-e-rey, an-Bab-Dummad, 
\q2 amba gig-sikwibela, bese-goled-neggi neg-amied, 
\q2 amba wirsobbela, na e-mimmigan-urbega, bese-goled-neggi e-uu sobed. 
\b  
\q1  
\v 4 Be-itoged-neggi-gudimaladi, egi nued-binsalesmaladid, 
\q2 ar degisadegu be-nug-odummodimalad. 
\q1  
\v 5 Dule-begi-gangued-amiedi, egi nued-binsalesmaladid, 
\q2 unnila bese-goled-negse-dagedginbi binsadiid. 
\q1  
\v 6 Ibyanis-aryoged-nebaba-nadapile, dii-sailagan-ariomaid-negga imaked. 
\q2 Gebe-dii-argwanedi, neba-naidgi nabir-binsadaed. 
\q1  
\v 7 Dulemar, nanadapidbali e-ganguedi gangumai gued, 
\q2 Sión-yalagi Bab-Dummad-dakmaloed. 
\b  
\q1  
\v 8 Bab-Jehová-Bela-Gangued-Nikad, an bese-goled be itoge, 
\q2 Jacob-e-Bab-Dummad, be an-itoge. 
\q1  
\v 9 Bab-Dummad, be anmar-irwa sigu-abgaedyob gued. 
\q2 Be-dule-nug-imaksadgi be nued binsae. 
\b  
\q1  
\v 10 Magaba iba-miliba-gudiguedba, bur-nuedid, bese-goled-neg-imbagi ibagwen gudii gued. 
\q2 Dule-isganamar-abargi-gudiguedba, bur an an-Bab-Dummadse-goled-neg-yawagak edarbebied. 
\b  
\q1  
\v 11 Bab-Jehová, dad-ibeleryob gued, 
\q2 sigu-abgaedyob gued. 
\q1 Bab-Dummad, anmar-nug dummarba imaked, anmarga gangued uked. 
\q2 Bab-Jehová, dule-galagwensuli-gudisurmaladga, e-ibmar-nikadi obinagwar uked. 
\b  
\q1  
\v 12 ¡Bab-Jehová-Bela-Gangued-Nikad, dule-begi-bensur-gudiid, 
\q2 egi nued-binsalesadid! 
\c 85  
\s1 Babse goled, be wile-an-dakye 
\d Coré-wagan, we-namaked narmaksad. Namakmalad-e-iduedga narmaklesad. 
\q1  
\v 1 Bab-Jehová, be-dulamargi be ise-nued binsasad. 
\q2 Jacob-e-wagan-yar-baidgi-galebukmalad, be gannar e-yarse senonikid. 
\q1  
\v 2 Be-dulamar-e-ibmar-isgana-imaksad ega be osulosad, 
\q2 bela e-isgusad begi nossuliyob be daksad. 
\b  
\q1  
\v 3 Bab-Jehová, be-sae-itoged bela be osulosad, 
\q2 be-urwed na be bargasad. 
\b  
\q1  
\v 4 Bab-Dummad-anmar-abonoged, gannar be anmar-nudake. 
\q2 Be-anmarse-urwemaid be obeloge. 
\q1  
\v 5 ¿Ar be degisadegu anmarbo sae-itodii guoe? 
\q2 ¿Be degisadegu urwemai guoe? 
\q1  
\v 6 Ar anmar burgwaleyob-gusoggu, gannar be anmar-odulodage. 
\q2 Adi, anmar be-dulamar-guedi, begi weligwar itomaloed. 
\q1  
\v 7 Bab-Jehováʼye, be-sabgued be anmarse oyoge, 
\q2 be anmar-abonoge. 
\b  
\q1  
\v 8 Bab-Dummad-Jehová-ibmar-soged an itogoed, 
\q2 ar e-dulamarga, ega-inniki-nanadimaladga, bogidikidgi sunmakoed, 
\q2 adi, melle bar gannar Bab-Dummadgi bangumalagar. 
\q1  
\v 9 E-nug-odummodimalad-bendakega, Bab-Dummad anmar-walikaa gudiid. 
\q2 E-gangued-yeerdakleged anmar-napneggi nai guoed. 
\b  
\q1  
\v 10 Sabgued, na napiragwadbo abingunonimaloed. 
\q2 Igar-innikigwad-imaked, na bogidikidbo, angaagwar akanonimaloed. 
\q1  
\v 11 Napiragwad napneggi nai guoed, 
\q2 Igar-innikigwad-imaked, nibneg-akale aidedani guoed. 
\q1  
\v 12 Bab-Jehová-sunnad anmargi nued-binsaoed. 
\q2 Anmar-napaneg, nue-ibmar-sanmake guoed. 
\q1  
\v 13 Igar-innikigwad-imaked, e-gayaburba-barsogedga guoed, 
\q2 Bab-Dummad-idu igar-mayoed. 
\c 86  
\s1 Wile-e-dakega Bab-Dummadse goled 
\d David Bab-Dummadse gornaid. 
\q1  
\v 1 Bab-Jehováʼye, wis be an-itoge, 
\q2 be an-abin-imake. 
\q1 Ar ande, dule-wilegedid, 
\q2 ibmarbina an bela-bela soged. 
\q1  
\v 2 Bab-Dummadye, be an-bendake, 
\q2 ar ande begala sogedba nanadiid. 
\q1 Be, an-Bab-Dummadid. An begi bensulid. 
\q2 Be-mai be bendake. 
\q1  
\v 3 Bab-Jehováʼye, wile-be-an-dake, 
\q2 ar an bese gordii osedoddaed. 
\q1  
\v 4 Be-nug-odummodiid weligwar be imake, 
\q2 adi, Bab-Jehová, an bese golegar. 
\b  
\q1  
\v 5 Bab-Dummad, be dule-nued gued, isgudsuliyob be emar-dakedid. 
\q2 Dulemar-bese-gormalad be bela-bela sabed. 
\q1  
\v 6 Bab-Jehováʼye, an bese-gornaid be itoge, 
\q2 an-wilesagwar-gornaid be itoge. 
\q1  
\v 7 An suli-suli-itogedgi an bese goled, 
\q2 ar be an-abin-imakdaed. 
\b  
\q1  
\v 8 Bab-Jehová, bab-dummagan-beyobid sated, 
\q2 be-ibmar-imaksadyobi gege ibmar imakmalad. 
\q1  
\v 9 Bela be dulemar-obinnisadi, be-asabin sindigar signonimaloed, 
\q2 be-nug odummomaloed. 
\q1  
\v 10 Bab-Dummad, ar bebi dummarba-maid, 
\q2 ar bebi ibmar-gegerdakleged imaked. 
\q2 ¡Ar bebi unnila Bab-Dummad gued! 
\b  
\q1  
\v 11 Bab-Jehová, an be-igar-innikigwadba nanadii guega, Be-Igar-Maid be anga oyoge. 
\q2 Bab-Dummad, an be-nug-odummodii nanaega, be an-gwage ogannoge. 
\q1  
\v 12 An-Bab-Dummad-Jehová, bela-bela an napiragwadgi be-nug odummogoed, 
\q2 degisadegu, an be-nug odummodii guoed. 
\q1  
\v 13 Ar bela-belad be an-sabed, 
\q2 degisoggu, burgwega be an-imaksasulid. 
\b  
\q1  
\v 14 Bab-Dummad, dulemar-na-san-buled-imakmalad angi gwisgunanaid, 
\q2 dule-gindakmalad an-oburgwebied. 
\q2 We-dulemar gwen begi binsasurmalad. 
\q1  
\v 15 Bab-Jehová, bedi dule-nuedid, emar-wiledakedid. 
\q2 Bedi, baisursunna urwesulidid, 
\q1 sabgued-dummad-nikadid, 
\q2 dule-innikigwadbalidid. 
\q1  
\v 16 Bab-Dummad, be an-dake, 
\q2 wile-be-an-dake. 
\q1 Be-nug-odummodiidga be-gargangued be uke. 
\q2 Ome-be-nug-odummodiid-e-machi be bendake. 
\q1  
\v 17 Bab-Dummad, an-isdarmalad dakmalaga, 
\q2 an-isdarmalad bingegumalaga, be-sabgued be angi oyoge. 
\q2 Ar be Bab-Jehová, be an-bendakedid, be an-gwage-armakedid. 
\c 87  
\s1 Bab-Dummad-e-neggweburga namakleged 
\d Coré-wagan, we-namaked narmaksad. 
\q1  
\v 1 Bab-Dummad-e-neggwebur-e-negsailamar yar-islidikidgi mamaid. 
\q2  
\v 2 Bab-Jehová Jacob-wagan-e-negmarba bur bule Sión-yawagakmar sabed. 
\q2  
\v 3 Bab-Dummad-neggwebur, ibiyobi be-yeerdaklegedginbi sunmakmalad. 
\b  
\q1  
\v 4 Bab-Jehová soged: 
\q2 “Neggweburmar-magar-an-dakmalad-abargi sunna an we-neggweburmar bie-bie saed: 
\q2 Rahab, Babilonia. 
\q2 Filistea, Tiro, Etiopía. 
\q3 We-neggwebur-e-dulemar-annik sogleged: ‘Sión-neggweburgi Bab-Dummad-magar-daksamarye.’ ” 
\b  
\q1  
\v 5 Sión-neggweburnik soglegoed: “We-dule, degi, wemoga, Siónʼgi gwalulesmarye.” 
\q2 Bab-Dummad-Bur-Birigined na e-sunnad Sión-neggwebur sisad. 
\q1  
\v 6 Bab-Jehová neggweburmar-nug-mamaid-gardagi narmakoed: 
\q2 “We, Sión-neggweburgi gwalulesye.” 
\b  
\q1  
\v 7 Namaknanaidgi, degi, gwirnanaidgi, sognanaid: 
\q2 “Anmar begi bela-danikid.” 
\c 88  
\s1 Burgwedgi-bendaklegega Babse-goled 
\d Ezraí-dule-Hemán Coré-wagwa, we-namaked-Masquilʼye-nugad narmaksad. 
\d Namakmalad-e-iduedga soglesad: We-namakleged Mahalatʼyob namaklegoye. 
\q1  
\v 1 Bab-Jehová, Bab-Dummad-an-bendaked, an bese ibginedba, mutikidba gordiid. 
\q2  
\v 2 An bese-gornaidi be itoge. 
\q2 An bese wilesakwaa-goledi be nue itoge. 
\b  
\q1  
\v 3 Bela-bela angi bonigan yolenaid, 
\q2 an burgwedani maid. 
\q1  
\v 4 Dulemar bato burgwisayob angi binsamalad. 
\q2 An ganguedsulidyob dakleged. 
\q1  
\v 5 Burgwarmalad-abargine an-metemalad, 
\q2 napa-urba mui-mellemaiyobi an gued. 
\q1 We-muimargi-bar-be-binsalesulidyob an gued, 
\q2 ar be wemar bar-bendaksasulid. 
\b  
\q1  
\v 6 Yaa-bur-matusulidgi be an-balimeted, 
\q2 nega-sichiganba, napa-urba-solanaga be an-balimeted. 
\q1  
\v 7 Be-sae-itogedi bela angine yolenonikid, 
\q2 be-urwed demargi-gundilenaiyobi an-imaksad. 
\q1  
\v 8 An-aimar angi banguega be imaksad, 
\q2 an-aimar ima-an-dakega be imaksad. 
\q1 An dule-esgaryagi-mellesiidyob geg wakinned, 
\q2  
\v 9 An bela-bela-boedbali an-dalamar momommakded. 
\b  
\q1 Bab-Jehová, bane-bane an bese gordiid, 
\q2 an bese argan onakdiid. 
\q1  
\v 10 ¿Ar dule-burgwarmalad-abargi ibmar-gegerdaklemalad be imake? 
\q2 ¿Dule-burgwarmalad be-nug-odummogega sunna durgudagosi? 
\q1  
\v 11 ¿Dule-burgwarmamaidgi sunna be-sabguedgi sunmaklesi? 
\q2 ¿Dule-burgwarmalad-neggi sunna be-innikidaedgi sunmaklesi? 
\q1  
\v 12 ¿Ar nega-sichigangi, be-ibmar-gegerdaklemalad wismarsi? 
\q2 ¿Ar napneg-ieleged-neggi, be-igar-inniki-imakleged wismarsi? 
\b  
\q1  
\v 13 Bab-Jehová, an bese goled, be an-bendakye. 
\q2 Wakudaryalaba an bese-goledgi, an be-amied. 
\q1  
\v 14 Bab-Jehová, ¿ibiga be an-obane? 
\q2 ¿Ibiga be angi be-wagar odukue? 
\b  
\q1  
\v 15 An sapingwagwad-akale ibitodiid, 
\q2 an burgwed-naga gudidaed. 
\q1 Bab-Jehová, be angine gwage-nunmaked-dummagan barmialid, 
\q2 geg an bar gugusad. 
\q1  
\v 16 Be-urwedbali an galitosad, 
\q2 be-ise-sabsur-an-imaksadi, an-obelosad. 
\q1  
\v 17 Be-emargi-gwisguedi, demaryobi bane-bane an-ebirnaid, 
\q2 bela an-ebilis naid. 
\q1  
\v 18 Be angine an-aimar obachad, 
\q2 be an-gwenadgan angi obachabalid. 
\q2 Emigindi, unnila negsichidbi an-aiyob gued. 
\c 89  
\s1 Bab-Dummad Davidʼbo-igar-mesisad 
\d Ezraí-dule-Etán, we-namaked-Masquilʼye-nugad narmaksad. 
\q1  
\v 1 Bab-Jehováʼye, an degisadegu be-sabguedgi namakdii guoed. 
\q2 An degisadegu bela dulemarga, be-innikidaedgi sunmakdii guoed. 
\q1  
\v 2 An sogdii guoed: Be-sabguedi degisadegu gege berguye. 
\q2 Be-innikidaedi nibneg-naiyob degisadeguye. 
\b  
\q1  
\v 3 Bab-Jehová, be sogsa gusad: “An-dule-susadbo an igar mesisye. 
\q2 An-mai-Davidʼga an ise-sogar sogsagusye: 
\q1  
\v 4 ‘Be-sorbali, be-wagan degisadegu reyga-megmalaga an imakoye, 
\q2 be-wagan degisadegu negsemamai an imakoye.’ ” 
\b  
\q1  
\v 5 Bab-Jehová, be ibmar-gegerdaklemalad-imaksadba nibnegginmaladi be-nug odummomalad. 
\q2 Dule-gwage-swilidikmalad-onmakbukwadgi be-innikidaedgi sunmakmalad. 
\q1  
\v 6 Nibneggine, ¿doa Bab-Jehováʼyopira gue? Dule deyobid sate. 
\q2 Nibnegginmalad-abargi, ¿doa Bab-Jehováʼyob gue? Dule deyobid sate. 
\q1  
\v 7 Dule-gwage-swilidikmalad onmakbukwale, Bab-Dummad-dobee itodamalad. 
\q2 Bab-Dummad na e-ebiris-bukmaladba bur-dummadid, bur-dutusurbalid. 
\q1  
\v 8 Bab-Dummad-Bela-Gangued-Nika-Maid, ¿doa beyob gue? Dule beyobid sate. 
\q2 Bab-Jehová, bedi gandikidid, bedi innikidaedid. 
\b  
\q1  
\v 9 Bab-Dummad, demar-dagumakmaid be bargaed. 
\q2 Demar-dummagan-arwemaid be obogileged. 
\q1  
\v 10 Be ibdula-dummad-Rahabʼye-nugad, maataa be oburgwisad. 
\q2 Bela-bela be gangued-nikadba be-isdarmaladgi be nakwisad. 
\q1  
\v 11 Bab-Jehová, nibneg begadid, napneg begadid. 
\q2 Be we-napneg-naidi obinnisad, bela egi-ibmar-bukwadi be urbisad. 
\q1  
\v 12 Be dad-nakwed-argan-sapiledsik-yar-bukwad obinnisad, 
\q2 dad-nakwed-argan-nuedsik-yar-bukwad be obinnisbalid. 
\q1 Tabor-yar weligwar be-nugga namaked, 
\q2 Hermón-yar weligwar be-nugga namaked. 
\q1  
\v 13 Bab-Jehová, bela-bela be gangued-nikadba be ibmar-dummagan imaked. 
\q2 Be-argan-nued be onakwed, ar be emargi obichad. 
\b  
\q1  
\v 14 Bab-Jehová, igar-maidba, igar-innikigwadba be negsemaid. 
\q2 Dule-wiledaked be oyoged, 
\q2 igar-innikigwad be oyobalid. 
\q1  
\v 15 Bab-Jehová, dulemar weligwaledgi-be-nug-odummomaladgi, nued binsalesad. 
\q2 Wemar be-sogedba nanadimalad. 
\q1  
\v 16 Be-nuggi wergudii osedoddamalad, 
\q2 be-igar-innikii-imakedgi wergudimalad. 
\q1  
\v 17 Ar be we-dulemar-e-gangued-e-yeerdakleged gued. 
\q2 Nued be anmargi-binsaedbali, be anmar-gangued ogannoged. 
\q1  
\v 18 Be, Bab-Jehová, be anmar-sigu-abgaedga gued. 
\q2 Be, Israel-dulemar-e-reyd, Gwage-Isligwaledid. 
\b  
\q1  
\v 19 Ibagwengine, be-dula-gwage-swilidikmaladga be negburgan oyosad, 
\q2 aba ega be sunmaksad. 
\q1 Be-dulamar-bega-nued-nanadimaladga be sogsagusad: “An dule-wargwen-buled bendaksad. 
\q2 Dulemar-abargi dule-bur-emargi-obindiid-e-nug an odummosad. 
\q1  
\v 20 An-mai-David an sunonikid, 
\q2 reyga-guega an-gwallu-wawad, an e-nonogi eosad. 
\q1  
\v 21 An bendakdii guoed. 
\q2 An-ganguedgine ogannodii an imakoed. 
\q1  
\v 22 E-isdarmalad egi nakosulid, 
\q2 dule-isganamar sabsur-imakosulid. 
\q1  
\v 23 An e-isdarmalad obelogoed, 
\q2 dule-e-isdardakdimaladi an osulogoed. 
\q1  
\v 24 An degisadegu David-sabgudii guoed. 
\q2 An-nuggine e-gangued dungumai guoed. 
\q1  
\v 25 David, demar-Mediterráneoʼye-nugad-naid-akar, 
\q2 Éufrates-diwar-maidse neg-gani guoed. 
\q1  
\v 26 Anga sogoed: ‘Be an-baba, 
\q2 be an-Bab-Dummad-an-abonogedid, be an-edarbedid.’ 
\q1  
\v 27 Machi-sailaginedga an imakoed, 
\q2 bela reymar-baiganba bur dummadga-megega an imakoed. 
\q1  
\v 28 An degisadegu sabgudii guoed, 
\q2 an-ebo-igar-mesisadi degisadegu-mai guoed. 
\q1  
\v 29 E-wagan e-sorba negsemamai gumaloed, 
\q2 Igi nibneg degisadegu nai, 
\q2 deyobi e-wagan degisadegu negsemamai gumaloed. 
\b  
\q1  
\v 30 ”Ar e-wagan an-igar-maidgi bangudmalale, 
\q2 an-igar-maidba nanasurmalale, 
\q1  
\v 31 An-igar-maidgi annadmalale, 
\q2 an-igar-uksadba ibsasurmalale, 
\q1  
\v 32 e-uayasulidaed-ulale, an sabsur-odurdakoed, 
\q2 e-isgusad-ulale, an bibyogoed. 
\q1  
\v 33 Degi-inigwele, an David-sabguosuli bipisaale guosulid, 
\q2 an egi innikidaedi oberguosurbalid. 
\q1  
\v 34 An Davidʼbo-igar-mesisadi an bisgosulid, 
\q2 an-ibmar-sogsadi an osulogosurbalid. 
\q1  
\v 35 An-nug-islidikid-ular, an unnila irgwennaa ise-sogar imaksad, 
\q2 an Davidʼga gakansaosulid: 
\q1  
\v 36 David-sorba, e-wagan degisadegu negsemamai gumaloed. 
\q2 An-asabin, igi dad-ibeler degisadegu-nai, 
\q2 deyobi, e-wagan degisadegu negsemai gumaloed. 
\q1  
\v 37 Igi nii nibneggi degisadegu-nai, 
\q2 deyobi, David-e-wagan degisadegu negsemai gumaloed.” 
\b  
\q1  
\v 38 Degi-inigwele, Bab-Dummad, be Reyga-guega-dule-susadi, be meted, be obachad, 
\q2 a-dulegi bela-bela be uluded. 
\q1  
\v 39 Be-maibo be igar-mesisadi be bichisad, 
\q2 e-wagan-degisadegu-negsemai-guoed e-ibe be obelosad. 
\q1  
\v 40 Bela e-galu-dikar-matusulid e-ibe be omukusad, 
\q2 e-neg-gandikbukmalad e-ibe be obelosad. 
\q1  
\v 41 Bela dulemar-a-igargi-nasdamaladi, e-ibe ibmar atursadamalad. 
\q2 Neggweburmar-e-dikarba-bukmalad egi dodomalad. 
\q1  
\v 42 David-e-isdarmalad-e-gangued be ogannosad, 
\q2 e-isdarmalad weligwar-itogega be imaksad. 
\q1  
\v 43 David-e-es-suid-nugar sate be imaksad, 
\q2 bila-onogedgine gwen be bendaksasulid. 
\q1  
\v 44 E-gangued-yeerdakleged e-ibe be osulosad, 
\q2 e-ologana napase e-ibe be meted. 
\q1  
\v 45 E-birga-dulagudigued e-ibe be osikirmaksad, 
\q2 binged-dummad ega be uksad. 
\q1  
\v 46 Bab-Jehová, ¿wede degisadegu be dukumai guoe? 
\q2 ¿Wede sooyobi be-urwed degisadegu guoe? 
\q1  
\v 47 Bab-Jehová, be insao, an-dula-gudiguedi unnila sikwas gued. 
\q2 Degisoggu, ¿ibiga be dule-obinnisa? 
\q1  
\v 48 ¿Ar doa burgosuli degisadegu dula gudiguoe? 
\q2 ¿Ar doa burgwedgine wakinnoe? 
\q1  
\v 49 Bab-Jehová, be sabguedsailagined, 
\q2 be Davidʼga be-innikidaedba ise-sogar-sogsa-gusadi, ¿bia nade? 
\q1  
\v 50 Bab-Jehová, be-maimargi-dodolediid, be ebinsao, 
\q2 dulemar-bukidar-angi-dodogedi an ulubgi sediid. 
\q1  
\v 51 Bab-Jehová, be-isdarmalad anmargi dodomalad. 
\q2 Na be dule-susadgi dodomalad. 
\b  
\q1  
\v 52 ¡Bab-Jehová-e-nug degisadegu odummolesun! 
\q2 ¡Degisadegu odummolesun! 
\c 90  
\ms1 4. GARDA-SOGBAKEGWAD 
\mr (Salmos 90:1–106:48) 
\s1 Bab-Dummad degisadegu-maid 
\d Bab-Dummad-e-dule-Moisés Babse goled. 
\q1  
\v 1 Bab-Jehová, be anmarga degisadegu, anmar-dukuedga gudiguad. 
\q2  
\v 2 Bab-Jehová, amba yoo yarmar be urbegua, 
\q2 amba yoo napa be obinyegua, 
\q2 amba yoo napneg be obinyegua, 
\q1 degisadegu dikasurgus, emi-ibadse, 
\q2 bato bedi Bab-Dummad gued. 
\b  
\q1  
\v 3 Bab-Jehová, be sogdele: “¡Dulemar, gannar napaga-binyemarye!” 
\q2 Be-sogedbali dulemar gannar napaga binyiddaed. 
\q1  
\v 4 Bab-Jehová, birga-miligwenadi (1,000) bega sae-iba-nasadyob gued, 
\q2 bega sikwas-neg-mutikid-nasadyob gued. 
\q1  
\v 5 Bab-Jehová, igi diwar-noder ibmar-seddae, 
\q2 deyobi, be dulemar-seddaed. 
\q1 Dulemar, unnila sikwas-gabdakedyobi dulagudigued. 
\q2 Dulemar, wakdaradba gaganmar-ainiar-daedyobi gued. 
\q1  
\v 6 Wakdara e-dutumar achundagoed. 
\q2 Sedogusale, bato dingudoed, degi-burgwidoed. 
\b  
\q1  
\v 7 Bab-Jehová, be-urwedi anmar-obeloged, 
\q2 be-sae-itoged anmar-dobe imaked. 
\q1  
\v 8 Anmar-ibmar-isgana-imaked bela be wisid, 
\q2 anmar-isgued-ulubgi-naidi begi dukusulid. 
\q1  
\v 9 Bab-Jehová, be-urwed-ular, anmar-san bergumaid, 
\q2 anmar-ibagan sikwas-bunnolegeyob gued. 
\q1  
\v 10 Anmar birga-dulapaa-gakambese (70) dulagudigued. 
\q2 Anmar-bur-dutusur-gumaladdi, sunna birga-dulabakese (80) warmaked. 
\q1 Degi-inigwele, suiti-dulagudiguedi, unnila arbaed-dummad anmarga uked, 
\q2 wile-itoged anmarga uked. 
\q1 Igi anmar sikwas-dula-gudigue, 
\q2 deyobi, birgamar nasmogoed. 
\b  
\q1  
\v 11 Bab-Jehová, ¿doa be-urwed-gangued magar-itoge? 
\q2 Be-urwed bela-bela-gangusoggu, anmarga dobed-dummad uked. 
\q1  
\v 12 Bab-Jehováʼye, anmar sikwas dula-gudisoggu, be anmarga binsaed-nikagued uke, 
\q2 adi, anmar nued nanadii guegar. 
\b  
\q1  
\v 13 Bab-Jehová, gwae be anmarse dage. 
\q2 Ar anmar be-dulamar gued. 
\q2 ¡Be-maimar be wile dake! 
\q1  
\v 14 Wakudaradba, be-sabgued be anmarga oyoge, 
\q2 anmar bane-bane bega weligwaledgi namakdii guoed. 
\q1  
\v 15 Igi birgabargus suli-suli-itogega, degi, wile-itogega be anmar-imaksa, 
\q2 emigindi, ibagan debayobi-mergue be anmar-weligwar imake. 
\q1  
\v 16 Be-maimarga be-ibmar-imaked be oyoge, 
\q2 e-waganga be-gangued-dummarbad be oyoge. 
\b  
\q1  
\v 17 Bitigi anmar-Bab-Dummad-Jehová-nued-binsaedi, anmargi oyolenonikina gadin. 
\q2 Bab-Dummadye, anmar-ibmar-imakedgi be nued-binsae, 
\q2 anmar-ibmar-imaked be onasgumai imake. 
\c 91  
\s1 Bab-Jehová anmar-dukuedid 
\q1  
\v 1 Dule, Bab-Dummad-Bur-Biriginedgi-dukued-amiedi, Bab-Dummad-Bela-Gangued-Nika-Maid e-edarbedga guoed. 
\q1  
\v 2 An Bab-Jehováʼga soged: “Be an-dukuedid, be an-garganguedid, 
\q2 an-Bab-Dummad, an begi bensulidid.” 
\b  
\q1  
\v 3 Bab-Jehováʼbi bonigan-dukuar-bukwadgi be-ollor-imaked, 
\q2 boni-bulegangi be-ollorsaed. 
\q1  
\v 4 Igi gannir e-sakan-urba e-mimmigan-odukue, 
\q2 deyobi Bab-Jehová be-edarbedga guoed. 
\q1 Bab-Jehováʼgi be dukued amioed. 
\q2 E-gayaburba be-sigu-abgaedyob guoed, 
\q2 be-edarbedga guoed.\fig Gannir e-sakan-urba e-mimmigan odukue. (Salmo 91:4) |src="LB00061B.TIF" size="col" ref="Salmos 91:4" \fig* 
\q1  
\v 5 Mutikidba boni-noed be dobguosulid, 
\q2 ibginedba sigu-mileged be dobguosulid, 
\q1  
\v 6 negsichidgi boni-gudiid be dobguosulid, 
\q2 yoruku boni-dule-ogiloged be dobguosurbalid. 
\b  
\q1  
\v 7 Be-argan-sapiledsiki, miligwen (1,000) dulemar burgwemai guoed, 
\q2 be-argan-nuedsiki, miliambe (10,000) dulemar burgwemai guoed. 
\q2 Bedi akar-guosulid. 
\q1  
\v 8 Dule-isganamar sabsur-odurdaklegoed, be-sunnad be dakoed. 
\q2 Bedi sabsur-odurdaklegosulid. 
\b  
\q1  
\v 9 Ar bedi Bab-Jehová be-odukuedga imaksasoggu, 
\q2 Bab-Dummad-Bur-Birigined be-edarbedga imaksasoggu, 
\q1  
\v 10 ibmar-isgana gwen be-ebugosulid, 
\q2 boni-dummagan gwen be-neguyase warmakosulid. 
\q1  
\v 11 Ar Bab-Jehová, e-baliwiturmarga igar-ukoed, 
\q2 bia be nadesogele, adi, be-edarbemalagar. 
\q2  
\v 12 Mer be akwagi-gowarmakega baliwiturmar nakwaa be-semai guoed. 
\q1  
\v 13 Achumigur-nono-wawaadgi be obinoed. 
\q2 Naibe-nuedgi be dii-dii annaoed. 
\q1 Be achumigur-nono-wawaad-sapingwagwad naibi-imakoed. 
\q2 Be naibe-bulegan oburgoed. 
\b  
\q1  
\v 14 Bab-Dummad soged: “Ar an-sabsoggu, ani an ollor-imakoed, 
\q2 ar magar-an-daksoggu, bonigangi an bendakoed. 
\q1  
\v 15 Ar anse-gollalile, an abinsaoed, 
\q2 na surbinsa-itogedgi an eba gudiguoed, 
\q1 an ollor-imakoed, 
\q2 an e-nug odummogoed. 
\q1  
\v 16 An ega birga-ichesur-dula-gudigued ukoed, 
\q2 an-abonolegedgi weligwar-itodii an imakoed.” 
\c 92  
\s1 Bab-Dummad-nued-daed-ular, ega namakleged 
\d We-namaked obunnoged-ibagi namakleged. 
\q1  
\v 1 Bab-Jehová, bega-doggus-nuedye-soglegedi, ibiyobi dog-nuedi. 
\q2 Bab-Dummad-Bur-Birigined, be-nuggi-namakedi, ibiyobi dog-nuedi. 
\q1  
\v 2 Wakudaryalaba be-sabgued-dummadgi-namakedi, ibiyobi dog-nuedi. 
\q2 Mutikidba be-innikidaedgi-namakedi, ibiyobi dog-nuedi. 
\q1  
\v 3 Gar-oimakar-goledba-namaked, gar-lira-goledba-namaked, ibiyobi dog-nuedi. 
\q2 Gar-arpa-goledba-namaked, gar-salterio-goledba-namaked, ibiyobi dog-nuedi. 
\b  
\q1  
\v 4 Bab-Jehová, be be-ibmar-gegerdaklemalad-imakedba, weligwar be an-imaked. 
\q2 A-ulale, be-ibmar-imaksadba, an weligwar-itoge an bega binnasur namakoed. 
\q1  
\v 5 ¡Bab-Jehová, ibibayobi be-ibmar-imaksad dummarba-gue! 
\q2 Bab-Jehová, be-binsaed bela-bela yeer-gangusoggu, 
\q1  
\v 6 dule-binsaedsulidaed, magar itosulid, 
\q2 dule-ibmar-wissulid, aku itoged. 
\q1  
\v 7 Amba dule-isganamar gaganyobi ainialile, dule-galagwensulidamalad dutuyob achunnalile, 
\q2 unnila degisadegu-berguega gumaloed. 
\q1  
\v 8 Bab-Jehová, bebi unnila degisadegu bur-gandikidga maid. 
\b  
\q1  
\v 9 Bab-Jehová, napiragwa, be-isdarmalad berguoed, 
\q2 bela dule-galagwensulidamaladi oaisakilegoed. 
\b  
\q1  
\v 10 Bedi moli-bebe-nikad-ursilid-gangued-nikadyobi anga gargangued uked, 
\q2 gwallu-wawad-bur-nuedgi be an-nono wawamaksad. 
\q1  
\v 11 An-isdarmalad-galakusad-dakega, be an-imaksad, 
\q2 an-isdarmalad-obelolesad-itogega, be an-imaksad. 
\b  
\q1  
\v 12 Dule-nuegan, ogob-sanmakedyobi gumalad, 
\q2 Líbano-yargi urwarmar-dungumaiyobi gumalad. 
\q1  
\v 13 Dule-nuegan, Bab-Jehováʼse-goled-neggi sapi-digar-gwichiyobi gumalad, 
\q2 anmar-Bab-Dummadse-goled-neg-imbagi dutuyobi achutemalad. 
\q1  
\v 14 Dule-nuegan, amba sered-ugakine, sanmakgwichi gumaloed, 
\q2 san-nued-gudii, dutusur-gudii gumaloed, 
\q1  
\v 15 adi, sogmalaga: “Bab-Jehová dule-innikigwadye. 
\q2 Bab-Jehová an-gandikidye, 
\q2 egine igar-isgana-imaked naisurye.” 
\c 93  
\s1 Bab-Jehová, Rey-gued 
\q1  
\v 1 ¡Bab-Jehová, gangued-yeerdakle-nika negsemaid! 
\q2 Bab-Jehová, dummarba-gued oyosad, e-gangued oyosad. 
\q1 Innikigwadba napneg nasiksad, 
\q2 napneg bar bipisaar onirilegosulid. 
\q1  
\v 2 Bab-Jehová, bedi gebe-negasaila-akale, bato negsemaid. 
\q2 ¡Bedi degisadegu maiguad! 
\b  
\q1  
\v 3 Bab-Jehová, diwarmar dutusuli nomamaid, 
\q2 diwarmar binnasuli uurmakmaid, 
\q2 diwarmar binnasuli sukamakmaid, 
\q1  
\v 4 Bab-Jehová, ar bedi demar-uurmakedba bur be dutusur gued, 
\q2 ar bedi muu-billigan-arwedba bur be dutusur gued, 
\q2 ar bedi nibneggi bur dutusur maid. 
\b  
\q1  
\v 5 Bab-Jehová, Be-Igar-Mamaidgi dutusuli mamaid, gege bisged. 
\q2 Islidik-gued degisadegu bese-goled-neg-yeerdakle imaked. 
\c 94  
\s1 Bab-Jehová-igar-naboged innikigwadid 
\q1  
\v 1 Bab-Jehová-dule-buged-mai-imakedye, 
\q2 Bab-Dummad-dule-buged-mai-imakedye, be magarodage, 
\q2 dule-sabsur-imaklediid be buged-mai imakdage. 
\q1  
\v 2 Bab-Jehová, be igar-naboged-dulesoggu, be-gangued be oyodage, 
\q2 dule-na-san-buled-imakdimalad, be sabsur-odurdakdage. 
\q1  
\v 3 Bab-Jehová, ¿sanagwadse dule-isganamar yeer-itodii gumaloe? 
\b  
\q2  
\v 4 Ar bela we-dule-isganamar, dule-ibmar-sabsur-sogmaladid, 
\q2 na san-dummarbaa imakmaladid. 
\q1  
\v 5 Bab-Jehová, dule-isganamar be-dulamar-sabsur imakdimalad. 
\q2 Be-dulamar-mesagwar imakdimalad. 
\q1  
\v 6 We-dule-isganamar, omegan-ei-sui-burgwismalad oburgwemalad. 
\q2 Wemar, dule-yar-baidsikid ogilomalad. 
\q2 Wemar, dule-babsuli-gudimalad gindakmalad. 
\q1  
\v 7 Dule-isganamar sogmalad: “Bab-Jehová we-ibmar daksulid, 
\q2 Jacob-e-Bab-Dummad, we-ibmar wissulid.” 
\b  
\q1  
\v 8 ¡Dule-ibmar-aku-itomalad, be magar itomala! 
\q2 Bemar binsaed-satemaladi, ¿sanagwadse be binsaed-nika gumaloe? 
\q1  
\v 9 Ar dule-anmarga-uaya-nasiksadi, ¿itogosuli? 
\q2 Ar dule-anmarga-ibya-sisadi, ¿dakosuli? 
\q1  
\v 10 Ar dulemar-ibmar-noar-imaksad-onudakedi, ¿sabsur-odurdakosur be ebinsae? 
\q2 Ar dule-ibmargi-odurdakedi, ¿ibmar-wisguosur be ebinsae? 
\q1  
\v 11 Bab-Jehová dulemar-binsaed bela wisid, 
\q2 Bab-Jehová wisid, dulemar unnila yogasaar binsamalad. 
\b  
\q1  
\v 12 Bab-Jehová, dule-ibmar-noar-imaksad be nudakedi, we-dulegi be ise-nued binsasad. 
\q2 Be, be-igar-maidgi-dule-odurdakedi, we-dulegi be ise-nued binsasad. 
\q1  
\v 13 We-dule, ibagan-bulegangi gwage-bogidiki gudiguoed. 
\q2 Dule-isganagardi, diglegega napa gwislegoed. 
\q1  
\v 14 Bab-Jehová e-dulamar obanosulid. 
\q2 Bab-Dummad, e-dulamar-egadga-imaksad wargwen metosulid. 
\q1  
\v 15 Igar-nabolegedi igar-innikigwadba imaklegoed, 
\q2 bela dule-gwage-inniki-gudimalad, igar-maidba damaloed. 
\b  
\q1  
\v 16 ¿Doa, dule-isganamar-abin an-irwa gwisgusa? 
\q2 ¿Doa, dule-isganamar-abin anba nagusa? 
\q1  
\v 17 Ar Bab-Jehová an-bendaksasulina, 
\q2 bato an napa-uluba bergus mellemainad. 
\q1  
\v 18 Bab-Jehová, an sogsagusgu, “an bergudaniye,” 
\q2 be-sabgued-nikadba yog be an-bendaknoni gusad. 
\q1  
\v 19 An bela-bela suli-suli-itogedgine, baisur-itogega be an-imaksad, 
\q2 weligwaled be anga uksad. 
\b  
\q1  
\v 20 Bab-Jehová, reymar-isganamar-e-aiga geg be gued. 
\q2 Ar we-reymar ibmar-isgana-imakega igar-mesmalad, 
\q1  
\v 21 dule-nuegangi-aibinega igar-amimalad, 
\q2 dule-ibmar-akar-imaksasulid-oburgwega imakmalad. 
\q1  
\v 22 Ar Bab-Jehová an-edarbedid, 
\q2 an-Bab-Dummadid, akwasaila-an-odukuedyob gued. 
\q1  
\v 23 Bab-Jehová dule-isganamar-e-isguedi, dule-isganamargi-aibinega imakoed. 
\q2 Bab-Jehováʼse e-isgusad-ulale, dule-isgana berguoed. 
\q2 ¡Anmar-Bab-Dummad-Jehová we-dulemar-obelogoed! 
\c 95  
\s1 Bab-Jehováʼga weligwaledgi namakmala 
\q1  
\v 1 ¡Dagmala, anmar weligwaledgi Bab-Jehováʼga namakmala! 
\q2 ¡Anmar weligwaledgi Bab-Dummad-anmar-abonogedga namakmala! 
\q1  
\v 2 Anmar Bab-Jehováʼga doggus-nuedye-sogedgi e-negse doge. 
\q2 ¡Anmar Bab-Jehováʼga namake! 
\b  
\q1  
\v 3 Ar Bab-Jehová, bur Bab-Dummadid, 
\q2 bela ibmar-bab-dummadyob-imaklemalad-birgi, bur Rey-dummadid. 
\q1  
\v 4 Bab-Jehová, na e-argan-yaurgi napa-billigan ganikid, 
\q2 yala-dummagan-matusurmalad na egadid. 
\q1  
\v 5 Muu-billi-maidi, egadid, ar na e obinnisad, 
\q2 neg-dinnagwad-naidi na e obinnisbalid. 
\b  
\q1  
\v 6 Dagmala, anmar Bab-Jehová-nug-odummogega napase wagar dulluu imakmala. 
\q2 Anmar Bab-Jehová-anmar-obinnisad-abin yokorgi sindigar sigmala. 
\q1  
\v 7 Ar e anmar-Bab-Dummadid. 
\q2 Anmardi e-dulamar gumalad, 
\q2 e anmar-edarbedid. 
\q1 Anmardi e-sibad-wawaadyob gumalad, 
\q2 e anmar-akwediid. 
\b  
\q1 Ar emi bemar Bab-Jehová-gayaburba itogele, 
\q1  
\v 8 melle be Meribaʼgi-gusmalayob, bur bule burgumalo. 
\q2 Ar igi deun nega-dulesulidganba Masahʼye-neg-nugadgi bur bule burgusgusmala, melle be deyob burgumalo. 
\q1  
\v 9 Deun agine, be-dadgan amba an-ibmar-imaksad-daksamar-inigwele, an-wilubdaksa gusmalad, 
\q2 urwega an-imaksa gusmalad. 
\q1  
\v 10 Birga-dulabo (40) an be-dadgan-ebo sae-itodii gusad. 
\q2 An sogsa gusad: 
\q1 “We-dulemar noar nanadimalad, 
\q2 an-igar-maidba ibsadisurmalad.” 
\q1  
\v 11 Degisoggu, an sae-itogedgine, an weyob ise-sogar sogsa gusad: 
\q2 “Ega-yar-ukoye-an-sogsadgine, dogosurmalad, 
\q2 agine, an ega obunnoged ukoenad.” 
\c 96  
\s1 Bab-Dummad, anmar-Reyd 
\r (1 Crónicas 16:23-33) 
\q1  
\v 1 Bab-Jehováʼga, namakleged-binidgine, be namakmala. 
\q2 Bela napneggi-dulemar-bukwad, Bab-Jehováʼga namakmala. 
\q1  
\v 2 Bab-Jehováʼga namakmala, e-nug odummomala, 
\q2 e-isdarmaladgi-nakwisad bane-bane obarmala. 
\q1  
\v 3 Dulemar-yar-baid-baidgi-bukmalad-abargi, e-gandikid-yeerdakleged sogmala, 
\q2 bela neggweburmar-abargi, e-ibmar-gegerdaklemalad-imaked obarmala. 
\b  
\q1  
\v 4 Ar Bab-Jehová, dule-dummadid. 
\q2 Bela-belad e-nug odummolegergebed. 
\q2 Bab-Jehová ibmar-bab-dummadyob-imaklemaladba bur bule dobguleged. 
\q1  
\v 5 Neggweburmar-baigan-e-bab-dummaganga-imaklemaladi, Bab-Dummadsulid, unnila ibmargi sobarmaladid, 
\q2 ar Bab-Jehováʼdi nibneg obinnisad. 
\q1  
\v 6 ¡Bab-Jehová-walikaa neg-ibegwaled naid, dummarba-gued naid! 
\q2 E-neggine gangued oyolenaid, yeerdakleged oyolenaid. 
\b  
\q1  
\v 7 Bela-dulemar-napneggi-bukwamalad, Bab-Jehová-nug odummomala, 
\q2 Bab-Jehová e-gandikid-yeerdakleged be obarmala. 
\q1  
\v 8 Bab-Jehová-e-nug-gandikid-yeerdaklegedi be ogannomala. 
\q2 Ese-goled-neg-imbase be dogdamala, 
\q2 ega ibmar-ukleged be sedamala. 
\q1  
\v 9 Bab-Jehová-e-nug, e-neg-yeerdaklegedgi be odummomala. 
\q2 Bab-Jehová-asabin bela-napneggi-dulemar-bukwad bela-belad dobekwaa ambikumarsun. 
\b  
\q1  
\v 10 Dulemar-yar-baid-baidgi-bukmaladga weyob be sogmala: 
\q2 “¡Bab-Jehová, Rey gued!” 
\q1 Innikigwadba napneg nasiksad, napneg bar bipisaale onirilegosulid. 
\q2 Bab-Jehová igar-innikigwadba dulemarga igar-naboged. 
\q1  
\v 11 ¡Nibnegmar weligue, napneg yeer-itoge! 
\q2 Muu-billi uurmake, bela egi ibmar-bukwad weligumala. 
\q1  
\v 12 Sapurmar, weligwar namakmala. 
\q2 Bela sapurgi ibdurgan-bukwad, weligwar namakmala. 
\q2 Bela sapurgi sapimar-bubukwad, weligwar namakmala. 
\q1  
\v 13 ¡Bab-Jehová-asabin namakmala, bato danikid! 
\q2 Igar-innikigwadba dulemarga-igar-nabogega bato danikid. 
\q1 Bab-Jehová igar-innikigwadba dulemarga igar-nabogoed. 
\q2 Napiragwadgi dulemarga igar-nudakoed. 
\c 97  
\s1 Bab-Jehová, Rey gued 
\q1  
\v 1 ¡Bab-Jehová, Rey gued! 
\q2 ¡Napneg, wergumala! 
\q2 ¡Dupugan-dikasur-nanaid, wergumala! 
\q1  
\v 2 Mogir-guduremalad Bab-Jehová-ebilis naid. 
\q2 Bab-Jehová igar-inniki-imakedba negsemaid, 
\q2 igar-innikigwadba negsemaid. 
\q1  
\v 3 Soo, Bab-Jehová-idu nadapid, 
\q2 we-soo, Bab-Jehová-e-isdarmalad Bab-Jehová-ebiris-bukwad obeloged. 
\q1  
\v 4 E-mala-ibyedi napneg-mee imaked. 
\q2 Napneg mala-ibyed-dakdegu, wawanmakded. 
\q1  
\v 5 Yarmala baka-gwalluyob Bab-Jehová-abin daluded. 
\q2 Bab-Jehováʼde bela we-napneg-e-ibedid. 
\q1  
\v 6 Mogirmar, Bab-Jehová-e-igar-innikigwad-imaked barsogmalad. 
\q2 Bela-dulemar, Bab-Jehová-gangued dakmalad. 
\b  
\q1  
\v 7 Dule-bab-dummadyob-ibmar-imakdimalad, bingegumala. 
\q2 Dule, bab-dummadyob-ibmar-imakdimaladgi na san-dummarba-imakmalad, bingegumala. 
\q1 Bela bab-dummadyob-ibmar-imaklemalad, 
\q2 Bab-Dummad-asabin dulluu sigmala. 
\q1  
\v 8 Bab-Jehová, be igar-innikigwad-imaked-ular, Sión-neggwebur, weligwar itoged, 
\q2 Judá-neggweburmar, yeer itomalad. 
\q1  
\v 9 ¡Ar be, Bab-Jehová-Bur-Birigined gued! 
\q2 ¡Be we-napnegba bur dummad gued! 
\q2 ¡Be, bab-dummadyob-ibmar-imaklemaladba bur dummad gued! 
\b  
\q1  
\v 10 Bab-Jehová, dule-ibmar-isgana-isdar-dakmalad, sabed. 
\q2 Bab-Jehová, e-dulamar-inniki-nanadimalad, edarbed. 
\q2 E-isdarmaladgi wakinnega imakbalid. 
\q1  
\v 11 Dule-nuegan, nue-binsaed-nikaa imaked, 
\q2 Bab-Jehová, dule-inniki-gudidimaladga weligwaled uked. 
\q1  
\v 12 Bemar dule-nuegan, Bab-Jehováʼgi be wergumala, 
\q2 Bab-Jehová-nug-isligwaled be odummomala. 
\c 98  
\s1 Bab-Dummad-Igar-inniki-imakedga namakleged 
\d Namakleged. 
\q1  
\v 1 Bab-Jehováʼga namakleged-binidgi be namakmala, 
\q2 ar ibmar-dakledisurmalad imaksad. 
\q1 E-ganguedgi, e-swida-gandikidgi, 
\q2 e-isdarmaladgi nakwisad. 
\q1  
\v 2 Bab-Jehová, na e-nakwisad bela magar-dakmalaga imaksad. 
\q2 Bela-dulemar-yar-baid-baidgi-bukmaladga e-igar-inniki-imaked oyosad. 
\q1  
\v 3 Bab-Jehová Israel-dulemar-sabesaila maid. 
\q2 Ega ibmar-imakedseye-sogsa-gusad ebinsanonikid. 
\q1 Bela dulemar-napneggi-bukmalad, 
\q2 anmar-Bab-Dummad-bela-bela-e-bendaked daksamalad. 
\b  
\q1  
\v 4 Bela-dulemar-napneggi-bukmalad, Bab-Jehováʼga weligwaledgi namakmala. 
\q2 Binnasuli weligwar-namaklegedgi ega namakmala. 
\q1  
\v 5 Bab-Jehováʼga gar-arpaʼba namakmala, 
\q2 gar-liraʼba ega namakmala, 
\q2 yeer-namaklegedgi ega namakmala. 
\q1  
\v 6 Bab-Jehová-Rey-guedga, weligwaledgi namakmala, 
\q2 gar-trompetaʼba ega namakmala, 
\q2 garmarba ega namakmala. 
\b  
\q1  
\v 7 Demar-naid, bela egi ibmar-bukmalad namakmala, 
\q2 Napneg-naid, bela egi dulemar-bukmalad namakmala. 
\q1  
\v 8 Diwarmar-mamaid, argan ogormala, 
\q2 bela yarmar-bubukwad, weligwaledgi namakmala. 
\q1  
\v 9 Bab-Jehová-asabin weligwaledgi namakmala, 
\q2 ar Bab-Jehová napneg-seega danikid. 
\q1 Dulemar-bukwadga igar-innikigwad-imakedba igar nabogoed, 
\q2 dulemar-bukwadga emarbi igar nabogoed. 
\c 99  
\s1 Bab-Jehová, Rey-Dummadid 
\q1  
\v 1 ¡Bab-Jehová, Reyga maid! 
\q2 Bab-Jehová e-ologanagi baliwitur-querubinʼye-nugmalad-abargi siid. 
\q1 Neggweburmar wawanmakmala. 
\q2 Bela napneg giglimake. 
\q1  
\v 2 Bab-Jehová Sión-neggweburgi bur dule-dummadid, 
\q2 bela neggweburmargi bur dule-dummadid. 
\q1  
\v 3 ¡E-nug-dummad, e-nug-buled odummomala! 
\q2 ¡Bab-Jehová, dule-isligwaledid! 
\b  
\q1  
\v 4 Bab-Jehováʼye, be, Rey-gandikidid. 
\q2 Igar-innikigwad-imaked be sabed. 
\q1 Be, dulemarga yobi-gumalad-igar mesisad. 
\q2 Be, Israel-neggweburgi igar-innikigwadba, ibmar-imaksad, 
\q2 inniki-sogedba be ibmar-imaksad. 
\b  
\q1  
\v 5 Anmar-Bab-Dummad-Jehová-nug odummomala, 
\q2 Bab-Jehová-asabin, napase-dulluu Bab-Jehová-nug odummomala. 
\q2 ¡Bab-Jehová, dule-isligwaledid! 
\b  
\q1  
\v 6 Moisés, Aarónʼbo dule-irwa-Babse-gormaladga gusmarmogad, 
\q2 Samuel, Bab-Jehová-nug-odummodii gusmogad. 
\q1 Wemala, Bab-Jehováʼse gordii gusmalad, 
\q2 geb Bab-Jehová abin-imaksadaed. 
\q1  
\v 7 Wemarga mogir-bubawarba sunmaksad. 
\q2 Wemala, Bab-Jehová-Igar-Mesisadba nanadii gusmalad, 
\q2 Bab-Jehová-Igar-Uksadba gudii gusmalad. 
\b  
\q1  
\v 8 Anmar-Bab-Dummad-Jehová, wemar-bese-gochagu, be abin-imaksagusad. 
\q2 Amba e-ibmar-isgana-imaksamalad-ular, be sabsur-odurdaksa-inigwele, bedi, wemargala, 
\q2 Bab-Dummad-dule-isgussuliyob-dakedga gusad. 
\b  
\q1  
\v 9 Anmar-Bab-Dummad-Jehová-nug odummomala, 
\q2 e-yar-islidikidgi, e-nug odummomala. 
\q2 ¡Anmar-Bab-Dummad-Jehová, dule-isligwaledid! 
\c 100  
\s1 Bab-Dummadga doggus-nuedye soged 
\d Bab-Dummadse-goled-negse-dognadapidgi, we-namaked-doggus-nuedye-sogleged namakleged. 
\q1  
\v 1 Bela-napneggi-dulemar-bukmalad, weligwaledgi, be Bab-Dummadga namakmala. 
\q1  
\v 2 Weligwaledgi, Bab-Jehová-nug be odummomala. 
\q2 Yeer-itogedgi, e-asabinni be namakdamala. 
\q1  
\v 3 Bab-Jehová-Bab-Dummad-gued be magar-dakmala. 
\q2 E anmar-obinnisad. Anmar, egadid. 
\q1 Anmar e-dulamalad. 
\q2 Anmar, e-sibad-wawaadyob gumalad. 
\b  
\q1  
\v 4 Doggus-nuedye-sognai, ese-goled-negyaba be dogmala, 
\q2 Namakar e-nug-odummonai, 
\q2 e-neg-imbase be dagmala. 
\q1 ¡Ega be doggus-nuedye sogmala! 
\q2 ¡E-nug be odummomala! 
\q1  
\v 5 Ar Bab-Jehová dule-nuedid, e-sabguedi degisadeguad. 
\q2 E-innikidaedi gege bergued. 
\c 101  
\s1 Bab-Dummadga-innikii-nanaoye-soged 
\d David we-namaked narmaksad. 
\q1  
\v 1 Bab-Jehová, namaklegedgi an bega namakoed. 
\q2 Sabguedgi, an namakoed, 
\q2 igar-innikii-imaklegedgi an namakoed. 
\q1  
\v 2 Nued nanadii an gubied. 
\q2 ¿Wede sana be anse ataknonikoe? 
\q2 An-neggi gwage-napiragwadgi an nanadii gubied. 
\q1  
\v 3 Ibmar-isganagi an atakbisulid. 
\q2 Igar-isgana an imakbisulid. 
\q1 Dule-Bab-Dummad-Igargi-banguddamalad an sae-daked. 
\q2 Amala anse-warmaked an imakosulid. 
\q1  
\v 4 Binsaed-isganamargi an banguoed. 
\q2 Ibmar-isgana an imakbisulid. 
\b  
\q1  
\v 5 Dule dule-baidgi-arbak-sunmaked an obelogoed. 
\q2 Dule-san-dummarba-saed, anse-warmaked an imakosulid. 
\q2 Dule-baigangi-obinye-soged, anse-warmaked an imakosulid. 
\b  
\q1  
\v 6 We-yargi dule-be-igarba-nanamalad, anba-gudigumalaga an amioed. 
\q2 Dule-be-igar-maidba-nanadimaladbi, anga arbamaloed. 
\b  
\q1  
\v 7 Dule, dule-yardakmaladgi-arbamaladi, an-negyagi gudii guosulid. 
\q2 Dule gakansaar-sunmakedi an-asabin gudii guosulid. 
\q1  
\v 8 Bane-bane we-yargi dule-isganamar-gudimalad obelomai an imakoed. 
\q2 Bela dule-ibmar-isgana-imakmalad, Bab-Jehová-neggweburgi an onogoed. 
\c 102  
\s1 Dule-naibi-itodiid Bab-Dummadse-goled 
\d Dule-naibi-itodiid, gege-bar-gugusadgi Bab-Jehováʼse ise-boar gornaid. 
\q1  
\v 1 Bab-Jehováʼye, an bese-gornaid be itoge, 
\q2 wilesagwar-an bese-gornaid bese mosana gadin. 
\q1  
\v 2 Bonigan angi-yolenonikile, mer be an-idu dukuo, nue be an-itogo. 
\q2 An bese-gornaile, gwae be an-abin-imako. 
\b  
\q1  
\v 3 An-ibagande, waayob bergudedaed. 
\q2 An-garmardina, soogi-gummaknaiyob itoleged. 
\q1  
\v 4 An-gwage ber nollomakded, 
\q2 gaganyob dinguded, 
\q1 ukuddi bar an itosurgusad. 
\q2  
\v 5 An binnasuli-akiginnedbali, an-garmardi daledgusad. 
\q1  
\v 6 Noo-negsulidganba-gukudiidyobi, an wargwen itoged. 
\q2 Irmon-neg-ayaraledgangi-gudiidyobi, an wargwen garmakdiid.\fig Irmon, neg-ayaraledgangi gudiid. (Salmo 102:6) |src="BK00069B.TIF" size="col" loc="Salmo 102:6" ref="Salmos 102:6" \fig* 
\q1  
\v 7 Bar an gabdisulid, 
\q2 sikwi-walagwen-uas-birgi-gudidaedyobi, an gudiid. 
\b  
\q1  
\v 8 An-isdarmalad bane-bane mesagwar an-imakdimalad, 
\q2 yogasaar an-nug-oichogega an-nug-gadimalad. 
\q1  
\v 9 Degisoggu, sooburu an madisunnad. 
\q2 An-ibyanisde, an-gobedba-mesa an gobdisunnad. 
\q1  
\v 10 Bab-Dummad, be sabsur-uludedbali, sabsur-an-imaksa gusad. 
\q2 Sabsur-nakwaa be an-imaksagu, be an-barmeted. 
\q2 Deyob be an-wiosad. 
\q1  
\v 11 An-ibagande, negsichiledanikiyobi, bato bergudanikid. 
\q2 Gagan-dinguddaedyobi, an guded. 
\b  
\q1  
\v 12 Bab-Jehová, ar bedina, degisadegu be negsemai guoed. 
\q2 Be-nugdina berguosulid, degisadeguoed. 
\q1  
\v 13 Be, Sión-dulemar bendaknonikoed, 
\q2 be-sabgued ega be oyononikoed. 
\q2 Ar a-ibagan bato nagunonikid. 
\q1  
\v 14 Anmar-be-maimar, Jerusalén-neggweburbina nue-sogmalad. 
\q2 E-negmar-ayarar-bukwadi, nunmaked-dummad anmarga uked. 
\q1  
\v 15 Bela dulemar-yar-baid-baidgi-bukwamaladi, Bab-Jehová-nug-dobe-nanadii gumaloed. 
\q2 Bela-yar-baid-baidgi-reyga-mamaid, Bab-Jehová-e-gangued-yeerdakleged magar-dakmaloed. 
\q1  
\v 16 Ar Bab-Jehová, Sión-neg-ayarar-siid gannar soboed, 
\q2 e-gangued-nikad oyononikoed. 
\q1  
\v 17 Dule-ibmar-suli-gudimalad-ese-goledi itogoed, 
\q2 dule-ese-wilesagwar-gornaidi itogoed. 
\b  
\q1  
\v 18 Wagan-danimalad wisgumalaga, we-ibmar narmaklego. 
\q2 Dulemar-gwalulemaloed, Bab-Jehová-nug-odummomalaga, we-ibmar narmaklego. 
\q1  
\v 19 Ar Bab-Jehová, dulemar-gales-gorbukwad-itogega, e-neg-islidikid-akale, napneg-naid nue-dakded. 
\q2  
\v 20 Bab-Jehová, dulemar-oburgwilegega-galesbukwad-onogegala, napneg-naid nue-dakded. 
\q1  
\v 21 Bab-Jehová, dulemar Sión-yargi-e-nug-barsogmalagala, napneg-naid nue-dakded. 
\q2 Jerusalén-neggweburgi e-nug-odummomalagala, napneg-naid nue-dakded. 
\q1  
\v 22 Bab-Jehová-nug-odummomalagala, bela we-dulemala danakwaa ambikudmaloed, 
\q2 reymar-negsemamaidi, bela ambikudmaloed. 
\b  
\q1  
\v 23 An gudiidgine, Bab-Dummad, an-ibe an-niga onollomaksad, 
\q2 an-ibagan osikirmaksad. 
\q1  
\v 24 Agala, an ise-wilegar ega sogded: “An-Bab-Dummadye, mer be an-ibe an-ibagan osikirmakye. 
\q2 Bab-Dummad, ar begardina ibagan geg bergued. 
\q1  
\v 25 Gebesailaunni, napneg be nasiksad, 
\q2 degi, nibneg-naid be-argangi be nasiksabalid. 
\q1  
\v 26 We-napnegdina, berguoed, nibnegmoga bergumogoed. 
\q2 Bedina berguosulid. 
\q1 Igi mormar serguddae, deyobi, bela nibneg, degi, napneg, sergudoed. 
\q2 Mormar-ogwalegeyob be ogwaoed. 
\q2 Mormar-milegeyob be imakoed. 
\q1  
\v 27 Bab-Dummad, bedina amba gannar maid, 
\q2 be-ibagan gwen berguosulid. 
\q1  
\v 28 Be-nug-odummodimalad-e-mimmigandina, nued-gudii gumaloed. 
\q2 E-waganmala, be-asabinni gudii gumarmogoed.” 
\c 103  
\s1 Bab-Dummad-nug odummoleged 
\d David we-namaked narmaksad. 
\q1  
\v 1 Bab-Jehová-nug, an odummoged, 
\q2 Bab-Jehová-nug-isligwaledi, bela an-ganguedbali an odummoged. 
\q1  
\v 2 Bab-Jehová-nug, an odummoged. 
\q2 Anga ibmar-nuegan-uksad an iegosulid. 
\q1  
\v 3 Bab-Jehová, bela an-isgusad isgussuliyob daked. 
\q2 Bela bonigangi an-nudaked, 
\q1  
\v 4 burgwedgi an-ollorsaed. 
\q2 Nue-an-sabed, 
\q2 nue-wile an-daked, 
\q1  
\v 5 Bab-Dummad bela ibmar-nueganbi anga uked, 
\q2 sulubagi-gannar-ganguddaedyobi an-imaked. 
\b  
\q1  
\v 6 Bab-Jehová, igar-innikigwad-imakedid, 
\q2 dule-baidse-wiledimaladbina urwedid. 
\q1  
\v 7 Moisésʼga e-igarmar oyosad, 
\q2 Israel-dulemarga e-ibmar-imaksad oyosad. 
\q1  
\v 8 Bab-Jehová dule-wiledakedid, dule-nuedid, 
\q2 irgwensuli urwesulid, e-sabguedi dummarbad. 
\q1  
\v 9 Degisadegu urwemai guosulid. 
\q2 Dule-egi-nosale, degisadegu ebinsabalosulid. 
\q1  
\v 10 Bab-Jehová anmar-isguedba anmar-sabsur-odurdaksulid, 
\q2 anmar-ibmar-isgana-imakedba anmar-sabsur-odurdaksulid. 
\q1  
\v 11 Ar igi mogir napneggi matusur-nai, 
\q2 debayobi, e-sabgued dulemar-e-nug-odummodimaladgi dummarba nikad. 
\q1  
\v 12 Ar igi dad-ibeler-nakwed, dad-ibeler-argwanedgi dikasur nai, 
\q2 debayobi, anmar-isgued anmargi obachad. 
\q1  
\v 13 Ar igi bab na e-mimmigan sabe, 
\q2 debayobi, Bab-Jehová na dulemar-e-nug-odummodidimaladi sabgued. 
\q1  
\v 14 Ar Bab-Jehová anmar-wisid, anmar ibu gue. 
\q2 Nue wisid, anmardi unnila napa gued. 
\b  
\q1  
\v 15 Dule-dula-gudiguedi gaganyob gued, yog-berguar naddaed. 
\q2 E-ibagan, dutu-achutedaedyob gued. 
\q1  
\v 16 Ar burwa gornaisale, dutu yoga babatiar naddaed, 
\q2 e-nagusad bar dakledasulid. 
\q1  
\v 17 Ar Bab-Jehová-e-sabgueddi, degisadeguad. 
\q2 E-nug-odummodimaladgardi, e-sabgued-oyoged berguosulid. 
\q1 Wemar-e-wagangardi, Bab-Dummad-e-igar-innikigwad degisadeguad. 
\q2  
\v 18 Ebo-Igar-Mesisadba-nanadimaladga, 
\q2 e-Igar-Islidikid-Mesisad-ebinsadimaladga, 
\q1 eba-ibmar-imakdimaladga, 
\q2 Bab-Dummad-e-Igar-innikigwad degisadeguad. 
\b  
\q1  
\v 19 Bab-Jehová e-ologan nibneggi sisad. 
\q2 Bab-Jehová bela neg-dirbir-naidgi dummadga negdakmaid. 
\b  
\q1  
\v 20 Bemar, Bab-Dummad-e-baliwiturmar-dule-bulegan, 
\q1 bemar, Bab-Dummad-sogedba-ibmar-imakmaladi, 
\q1 bemar, e-igar-uksadba-nanadimaladi, 
\q2 Bab-Jehová-nug odummomar. 
\q1  
\v 21 Bemar, bela e-sordamar, 
\q2 ega-arbamalad, 
\q1 e-sogedba-ibmar-imakmalad, 
\q2 Bab-Jehová-nug odummomala. 
\q1  
\v 22 Bemar, bela ibmar-obinnilesmaladi, bela dummadga-negdakmaidgi, 
\q2 Bab-Jehová-nug odummomala. 
\b  
\q1 Bab-Jehová-nug an odummoged. 
\c 104  
\s1 Bab-Dummad e-ibmar-obinnisad akwemaid 
\q1  
\v 1 Bab-Jehová-nug an odummoged. 
\b  
\q1 An-Bab-Dummad-Jehová, duledar-gandikid be gued, 
\q2 gandikidba yeerdakleged-mola be yosad, 
\q2 ibiyobi-mola-yeerdakle be yosa. 
\q1  
\v 2 Mola-dummad-yoiyobi nega-ibegwaledi begi ebirnaid, 
\q2 mola-dummad-nallaa-imaklegeyobi mogir-billi be imaked. 
\q1  
\v 3 Diigine, be-nega-dummagan-urbega be imaked, 
\q2 mogirmala, be-moli-ur-bila-onomaladga be saed. 
\q2 Bedi burwa-ooreged-birgi-sii nanaed. 
\q1  
\v 4 Burwamala, be-gayaburba-berbegedga be imaked, 
\q2 soo-gwabunyemaladi, be-maiganga be saed. 
\b  
\q1  
\v 5 Napanega, e-saila-birgi be sisad, 
\q2 e-siidgi, bipisaale gwen bar ainirosulid. 
\q1  
\v 6 Napanegga e-mor-dummad-naiyobi, muu-billi egi be nasiksad. 
\q2 Diimala, yalamar-birise nagusad. 
\q1  
\v 7 Diimarse be uludedbali, diimala ilided. 
\q2 Be-dolewala-gollomakedbali, diimala uboded. 
\q1  
\v 8 Diimala, yalamar-birise engusad, 
\q2 nebagansega diimala ilisbalid. 
\q1 Bia be ega neg-amisa, 
\q2 agi be diimala oambikusbalid. 
\q1  
\v 9 Dii melle bar napneg-odogega, 
\q2 ega be igar mesisad, adi, a-igarse galegegar. 
\b  
\q1  
\v 10 Bedi, ibe-diimar-ariogwichidi, dianganbali, oiirmakega be saed. 
\q2 Yalaganbali, suurmakega be imaked. 
\q1  
\v 11 Ibdurgan-sapurbarmaladi, a-dii gobmalad. 
\q2 A-diigine, moli-uayasuid-sapurmar immelemalad. 
\q1  
\v 12 A-dii-gakabali, sikwimala e-uu urbe damalad. 
\q2 Sapi-anagan-imbabali, nuumala namakbukwa damalad. 
\q1  
\v 13 Be-nega-akale, yalamar be ogmaid. 
\q2 Be-ibmar-saedbali, napaneg yeer itoged. 
\q1  
\v 14 Molimarga gagan-ara-aramalad-oniega be imaked, 
\q2 dulega ibmar-durgan-sanmakega be saed. 
\q1 Adi, agi we-masgunned amiega: 
\q2  
\v 15 Vino-weligwar-emar-saed-amiega, 
\q2 olivo-gwallu-wagar-daarmakar-imaked-amiega, 
\q2 mas-burba-dula-uked-amiega be imakbalid. 
\b  
\q1  
\v 16 Bab-Jehová e-sapimala-urbisadi, sapi-urwarmala Líbano-yargi urbisadi 
\q2 nue-obagwale gwigwichid. 
\q1  
\v 17 A-sapimargine, nuumala e-uu sobbukwad, 
\q2 e-anagangine, dabgalamar ambikubukwad. 
\q1  
\v 18 Yala-dummaganbali, sibad-sapurbarmalad bukwad. 
\q2 Akwa-olloganbali, nubimar dukubukwad.\fig Nubiyobid. (Salmo 104:18) |src="HK00055B.TIF" size="col" ref="Salmos 104:18" \fig* 
\b  
\q1  
\v 19 Bab-Jehováʼye, yolamar-nagumaid-magar-daklegega, bee be nii nasiksad. 
\q2 Bee be dad-ibeler e-doged-wisguega be imaksad. 
\q1  
\v 20 Neg-mutik-imakegala, be negsichidi nasikdaed. 
\q2 Agine, ibmar-durgan sapurba ainiardaed. 
\q1  
\v 21 Achumigur-nono-wawaamalad e-masbina uurmakdidaed. 
\q2 Bab-Dummadse na e-masgunned egisdidaed. 
\q1  
\v 22 Dad-ibeler-nakwialile, 
\q2 geb e-neg-olloledyaba gannar dogdedaed. 
\q1  
\v 23 Geb dulemala, arbaega gwisguardamarmogad, 
\q2 neg-gutulegedse e-arbaed gadapdamalad. 
\b  
\q1  
\v 24 Bab-Jehová, ibiyobi be ibmarmar-imaksadi, ichesur mergue. 
\q2 Be ibmar-wisidbali, bela we-ibmarmar be imaksad. 
\q2 Be ibmar-obinnisadi, bela napneggi nanaid. 
\q1  
\v 25 Agine muu-billi-dummadi naid, a-yagine ibmar-durgan-bukidar bukwad. 
\q2 Ibmar-durgan-dummagan, ibmar-durgan-bipigana bukwananaed. 
\q1  
\v 26 Muu-billigine, ulu-dummagan iirmakbukwad, 
\q2 agine, be, baka-dummaganyobid-obinnisadi gudiid, 
\q2 ulu-dummagangi dodogega be obinnisad. 
\b  
\q1  
\v 27 Bela we-ibmar-durgana begi gudidiid, 
\q2 ega be sogedba e-masgunned ukmaid. 
\q1  
\v 28 Ega be masgunned ukmaid, emardi be-abin gundidiid. 
\q2 Ega be-argan be oyomaid, nue-immeledidiid. 
\q1  
\v 29 Be wagar-biriar-dakdele, be-abin gwayiddamalad. 
\q2 Be e-annik-mas-susale, burgwiddamalad, 
\q2 gannar napaga binniddamalad. 
\q1  
\v 30 Be-Burba be barmialile, bela gannarse napneg obinoleddaed. 
\q2 Deyob gannarse napneg naguddaed. 
\b  
\q1  
\v 31 Bab-Jehová-e-gangued-yeerdakleged degisadegusun. 
\q2 Bab-Jehová, e-ibmar-imaksadgi wergusun. 
\q1  
\v 32 Bab-Dummadi napneg-dakdele, ese napneg wawanmakdedaed. 
\q2 Yalamar-ebudele, waa daasa sigisdaed. 
\b  
\q1  
\v 33 An dula-gudiidgine, Bab-Jehováʼga an namakoed. 
\q2 Amba an dula-gudiidgine, namaklemaladgi an-Bab-Dummadga an namakoed. 
\q1  
\v 34 Ulubgi-an-egi-binsaedi, Bab-Dummad yeer-itogoed, 
\q2 Bab-Jehováʼgi an weligwar itoged. 
\q1  
\v 35 Dule-isgudimalad napneggi bergumarsun. 
\q2 Napneggi, dule-isgudimalad bar daklesuli gusun. 
\b  
\q1 ¡Bab-Jehová-nug an odummoged! 
\b  
\q2 ¡Bab-Jehová-nug odummolesun! 
\c 105  
\s1 Bab-Jehová Israel-dulemarga ibmar-dakledisurmalad imaksad 
\r (1 Crónicas 16:7-22) 
\q1  
\v 1 Bab-Jehováʼga dog-nuedye be soge, e-nug be odummomala. 
\q2 Bab-Jehová-ibmar-imaksad be dulemar-yar-baid-baidgi-bukwamaladga soge. 
\q1  
\v 2 Be namakmala, Bab-Jehová-e-nug-odummogega be namakmala. 
\q2 Bela e-ibmar-dakledisurmalad-imaksadgi be sunmakmala. 
\q1  
\v 3 Bab-Jehová-nug-isligwaledgi be san-dummarba itomala. 
\q2 Dulemar-Bab-Jehová-amidimalad ulubgi wergumala. 
\q1  
\v 4 Bab-Jehová be amimala, e-gangued be amimala. 
\q2 Bab-Jehová-amidigu be imakmala. 
\q1  
\v 5 Bab-Jehová-ibmar-gegerdaklemalad-imaksad be insamalo. 
\q2 E-ibmar-dummagan-imaksad be insamalo. 
\q2 E-igarmar-sogsad be insamalo. 
\q1  
\v 6 Bemar, Bab-Jehová-mai-Abraham-e-wagan gumalad. 
\q2 Bemar, Jacob-e-wagan gumalad. 
\q2 Bab-Jehová e-dulemarga bemar-imaksad. 
\b  
\q1  
\v 7 Bab-Jehová anmar-Bab-Dummad gued. 
\q2 Bela we-napneggine, Bab-Dummad-e-igarmar oyolemamaid. 
\q1  
\v 8 Wagan miliba-gwago-inigwele, Bab-Dummad Israel-Dulemarbo-Igar-Mesisadi gwen iegosulid. 
\q2  
\v 9 Bab-Jehová Abraham-ebo igar-mesisgusad, 
\q1 Isaacʼga ise-sogar-imaksad, 
\q2 an bega a-igar imakedseye. 
\q1  
\v 10 Bab-Jehová, Jacobʼga igar-mesisgua, 
\q2 Israelʼbo degisadegu igar mesisgua, 
\q1  
\v 11 ega sogsagusad: 
\q2 “Canaán-yala begadga-guega an bega ukoed.” 
\b  
\q1  
\v 12 Anmar ichee-guen-inigwele, 
\q2 anmar yar-sate gudigusmar-inigwele, 
\q1  
\v 13 anmar yar-baid-baidgi-gudigusmaladgi, 
\q2 neggwebur-baid-baidgi gudigusmaladgi, 
\q1  
\v 14 Bab-Jehová, sabsur-anmar-imaklegega gwen imaksasulid. 
\q2 Anmar-ulale, reymarga sabsur-ibmar-sogsad. 
\q1  
\v 15 Weyob sogsa gusad: “Melle an-dulamar-nugsalegarmaladse achao, 
\q2 melle an-gayaburba-barsogmalad naibi-imako.” 
\b  
\q1  
\v 16 Bab-Jehová, Canaán-yalagi ukud-dummad nasiksad, 
\q2 agi masgunned sate imaksad. 
\q1  
\v 17 Degi-inigwele, Bab-Jehová, dule-wargwen-Joséʼye-nugad emar-idu Egipto-yalase barmisgusad. 
\q2 José maiga manigi ukles gusad. 
\q1  
\v 18 Egipto-dulemar José-e-nag esgoro-dubgi edichagusmalad, 
\q2 geb esgaryagi metegusmalad. 
\q1  
\v 19 José-ibmar-sogsa-gusadba neg-gunonigua, Bab-Dummad agi oyosad, 
\q2 ede idu-ibmar-sogsad, we napiraye. 
\q1  
\v 20 Geb Egipto-rey sognonigusad, José esgaryagi-siid onomarye. 
\q2 A-rey, deunni, dule-bukidaradga negsemaid. 
\q1  
\v 21 Rey, José bela e-neggi ega ibmar-dakega onugsanonigusad, 
\q2 bela e-dulemar-e-dummadga-guega imaksad. 
\q1  
\v 22 Adi, José reyga-arbamalad-dummagan-odurdakega imaksad, 
\q2 e-girmar-selegan-binsaed-nikagued-odurdakega imaksad. 
\b  
\q1  
\v 23 Geb a-sorbali, Israel, Egipto-yalase nonigusad. 
\q2 We-Jacobʼde, Cam-yalagi, e-yarsulidgi maigusad. 
\q1  
\v 24 Agine, Bab-Jehová, e-dulamar-bukidar-merguega imaksad, 
\q2 e-isdarmaladba bur-dutusuli imaksabalid. 
\q1  
\v 25 Bab-Jehová, Egipto-dulemar-e-binsaed ogwasad, 
\q2 isdar anmar-dakega imaksad, 
\q2 degisoggu, anmar-wioar gussunnad. 
\b  
\q1  
\v 26 Agine, Bab-Dummad, e-mai-Moisés-susagusadi, Aarón-susagusadi, Egipto-yarse barmiargusad. 
\q2  
\v 27 Agine, Bab-Dummad, wemar-ebogwad, Cam-yalagi ibmar-dakledisulid-imakega imaksad. 
\q1  
\v 28 Bab-Jehová, Egiptoʼgi negsichid nasiksagusad, bela neg-gudure imaksagusad, 
\q2 degite, Egipto-dulemar Bab-Dummad-gayaburba itosurgusmalad. 
\q1  
\v 29 Egipto-diwarmar abega obinnisgusad, 
\q2 e-uamala ogilosgusad. 
\q1  
\v 30 Bela Egipto-yala ammanoo yaisur-nika imaksad, 
\q2 rey-e-negyaginse-bakar, ammanoomar-nika imaksad. 
\q1  
\v 31 Bab-Dummad-sunmaksagu, gukurmar-bukidar ainiargusad, 
\q2 bela Egipto-yalagangi, guumar yaisur-nika imaksad. 
\q1  
\v 32 Dii-wied-anar, dii-gwamakaled-wiega imaksad. 
\q2 Egipto-yalagi mar-dakarmakmai imaksabalid. 
\q1  
\v 33 Uvaʼmar-digar-bukwadi, higueraʼmar-bukwadi ei obelosgusad. 
\q2 E-yalagangi sapimar-bukwad ei bibichisgusad. 
\q1  
\v 34 Bab-Dummad sunmakdegua, ses-dummagan onisad. 
\q2 We-sesmarde, bela-bela-mergu batisad. 
\q1  
\v 35 Sesmar, bela Egipto-yargi gagan-obelosad. 
\q2 Ibmar-durba-e-sanmar, bela obelosbalid. 
\q1  
\v 36 Bab-Jehová, Egipto-yalagi bela machi-sailaginmalad oburgwisgusad, 
\q2 bela gebesailagi-gwalulesmalad ogilosgusad. 
\b  
\q1  
\v 37 Bab-Jehová, Israel-dulemar or-bukidar-semamai, mani-bukidar-semamai onosgusad. 
\q2 E-dulemar-wargwensaale, gwen-burgwissurgusad. 
\q1  
\v 38 Egipto-dulemala nue-dobe itomarsoggu, 
\q2 Israel-dulemar ainide-daksamargua, yeer itosgusmalad. 
\q1  
\v 39 Bab-Jehová Israel-dulemarga mogir nasiksad, 
\q2 adi, a-urba ambikumalagar. 
\q2 Neg-mutik ega neg-mee imakega ega soo ogasad. 
\b  
\q1  
\v 40 Bab-Dummadse mas-egichismargu, nuu-codornizʼye-nugad ega uksagusad. 
\q2 Madu-nibnegginedgi immeles gusmalad. 
\q1  
\v 41 Ega akwasaila egasgusad, agi dii aryoargusad. 
\q2 Nega-dulesulidganba ega dii aryomai imaksad. 
\q1  
\v 42 Bab-Dummad deyob imaksadi, 
\q2 e-mai-Abrahamʼga gayaburba-ise-sogar-sogsad gwen iessulid. 
\b  
\q1  
\v 43 Bab-Dummad e-dulamar weligwaledgi onosgusad, 
\q2 ber yeer-itogedgi e-dulamar-susadi onosgusad. 
\q1  
\v 44 Dulemar-baigan-yala na e-dulamarga uksad. 
\q2 Dulemar-baigan-arbasad-e-ibmar-sanmaksamalad na e-dulamarga uksabalid. 
\q1  
\v 45 Bab-Jehová, na e-dulamar e-igar-uksadba binsaed-nika-gudi-imakmalaga imaksad, 
\q2 eba nanamalaga imaksabalid. 
\b  
\q1 ¡Degisoggu, Bab-Jehová-nuggi wergumarsun! 
\c 106  
\s1 Israel-dulemar Bab-Dummadba dasurmalad 
\q1  
\v 1 ¡Aleluya! ¡Bab-Dummad-e-nug odummomar! 
\q2 Bab-Jehová-nug dummarba imakmarsun. 
\b  
\q1 Bab-Jehováʼga dog-nuedye sogmar. 
\q2 Ar Bab-Dummad, dule-nuedid, 
\q2 e-sabgued, degisadeguad. 
\q1  
\v 2 ¿Doa, Bab-Jehová-e-ibmar-bulegan-imaksad sogedba nabir barsogoe? 
\q2 ¿Doa, Bab-Jehováʼga-namaklegedgi sogedba sunmakoe? Dule barsoged sate. 
\q1  
\v 3 Dule-igar-inniki-imakdimaladgi, 
\q2 igar-maidba gusgu ibmar-imakdimaladgi nued-binsalesad. 
\b  
\q1  
\v 4 Bab-Jehová, wile be-dulamar be dakalile, wis be angi binsao. 
\q2 Be, be-dulamar-bendakdanikile, mer be an-iemogo. 
\q1  
\v 5 Adi an, be-dulamar-susa-gudiidba, e-wergudimaladba wergumogoed. 
\q2 Be-dulamar-na-be-nug-imaksa-gudiid-abargi namakmogagala, be an-bendakdage. 
\b  
\q1  
\v 6 Anmar, anmar-dadganyob isgusad, 
\q2 anmar, ibmar-isgana imaksad, 
\q2 anmar, galagwensuli-gudii gusad. 
\q1  
\v 7 Anmar-dadgan Egipto-yargi-bukwagu, bela aku be-ibmar-gegerdaklemalad-imaksad daksamalad. 
\q2 Degi, be-sabgued-dummarbadgi gwen binsassurmarbalid. 
\q2 Aka Demar-Ginnidye-nugad-dikarba begi-yolenai gusmalad. 
\q1  
\v 8 Degi-inigwele, Bab-Jehová na e-nug-sabed-maidba bendaknonikid, 
\q2 na e-gangued-dummarbad-oyogega deyob imaksad. 
\q1  
\v 9 Bab-Dummad Demar-Ginnidye-nugadse gotegua, demar argaas naded, geb dinnaa megisad. 
\q2 Bab-Dummad demar-wilasaila-maigusadba, e-dulamar-semai gusad. 
\q2 Neg-dulesulidganba-nadapiyob, e-dulamar-semai gusad. 
\q1  
\v 10 Bab-Dummad anmar-dadgan-bendaksad, 
\q2 e-isdarmalad-argan-yaurgi-bukwa bendaknonikid. 
\q1  
\v 11 E-isdarmalad-birgi demar gannar-arwega imaksad, 
\q2 degisoggu, wargwensaale durgussulid, bela burgwismalad. 
\q1  
\v 12 Geb anmar-dadgan Bab-Dummad-ibmar-imakoye-sogsadgine, bar bengussurgusmalad, 
\q2 agi, Bab-Dummadga namakde gusmalad. 
\b  
\q1  
\v 13 Sikwas ibagan-nasgua, Bab-Dummad-ibmar-imaksad ienonimarbalid. 
\q2 Bab-Dummad-e-igar-imakbied edarbissurmalad. 
\q1  
\v 14 Anmar-dadgan negsulidganba-gudigua, e-itolegedba ibmar imaksamalad. 
\q2 Wargwen-gudimaladbali, Bab-Dummad-wilubdaksamalad. 
\q1  
\v 15 Degisoggu, Bab-Dummad, ese-ibmar-egisnanaidba ega ukdesunnad, 
\q2 Bab-Dummad, boni-buled-emar-ogiloged ega barmiarsunnad. 
\b  
\q1  
\v 16 Deunni, negsulidganba gudidimargua, Moisésʼgi nobguargusmalad, 
\q2 Bab-Jehová-nug-imaksad-Aarónʼgi nobguargusmalad. 
\q1  
\v 17 Geb agine, napa argadgusad, degidbali, Datán napase dolesgusad. 
\q2 Abiramʼye-nugad, degi, e-sordamarse-bakale, napa-yaba barmellede gusmarmogad. 
\q1  
\v 18 We-dulemardi, soose bergus gusmalad. 
\q2 Bela-we-dule-isganamar soose gummaksa gusmalad. 
\b  
\q1  
\v 19 Anmar-dadgan, Horeb-yargi, moli-bebe-nikad-sapingwagwad e-bab-dummadga-imakegala, sobsagusmalad. 
\q2 Bormo-sobaled-asabin dulluu imaknanai gusmalad. 
\q1  
\v 20 Bab-Dummad-e-nug-odummoleged-anar, 
\q2 moli-bebe-nikad-gagan-maed-sobaled-e-nug odummodmalad. 
\q1  
\v 21 E-Bab-Dummad-e-abonosaddi iedemalad, 
\q2 Egipto-yargi ega ibmar-gegerdakleged-imaksad bela iedemalad. 
\q1  
\v 22 Cam-yar-naidgi, Bab-Dummad ega ibmar-dakledisulid-imaksad bela iedemalad. 
\q2 Demar-Ginnidye-nugad-dikarba, ega ibmar-bulegan-imaksad, iedemarbalid. 
\q1  
\v 23 Ar Bab-Dummad Israel-dulemar-oburgwedgi binsasanad. 
\q2 Degi-inigwele, Moisés, Bab-Dummadgadga-nug-imaklesadi, wemar-irwa Bab-Dummad-asabin gwisgusad. 
\q1 Agala, Moisés wis Bab-Dummad-barganonikid, 
\q2 adi, Israel-dulemar, mer Bab-Dummadse ibitomalagar. 
\b  
\q1  
\v 24 Deginbali, napneg-nued-ega-uklesadi, isdar-daksamarbalid. 
\q2 Bab-Dummad-ega-ibmar-imakoye-sogsadgi, bengusmarbalid. 
\q1  
\v 25 Ar Bab-Jehová-ega-ibmar-sogsadba ibsassurmalad, 
\q2 aka e-dordonegyaba uurmakbukwa gusmalad. 
\q1  
\v 26 Degisoggu, Bab-Dummad amargi yolenonisunnad. 
\q2 Adi, negasulidganba sabsur-odurdaklemalagar. 
\q1  
\v 27 Adi, e-wagan dule-bamaladse sabsur-wilemalagar. 
\q2 Degi, yar-akar-akar-bukwadba mimilemalaga imaksad. 
\b  
\q1  
\v 28 Baal-Peorʼye-nugad na-e-bab-dummadga imaksamarbalid. 
\q2 Bab-dummagan-burbasulidga ibmar-ukleged guchamarbalid. 
\q1  
\v 29 E-ibmar-isgana-imakedbali, Bab-Jehová-nue-oulusmalad. 
\q2 Degisoggu, boni-dummad ega nagunonisunnad. 
\q1  
\v 30 Agine, Finees igar-innikigwad imaknonikid, 
\q2 geb bonigan bargalenonikid. 
\q1  
\v 31 Finees we-ibmar-nued-imaksadbali, 
\q2 degisadegu, egi nued-binsalemai gulesunnoed. 
\b  
\q1  
\v 32 Meriba-dii-naid-dikarba, Bab-Jehová-oulusmarbalid. 
\q2 We-dulemar-nukad Moisésʼga neg isgunonikid. 
\q1  
\v 33 Moisés-surbinsa-itogega imaksamalad, 
\q2 abali, Moisés bar-nue-binsassuli ibmar-soge-soge sunmaknai gusad. 
\b  
\q1  
\v 34 Bab-Jehová ega sogsa gusanad, dulemar-bamalad-bukwad oburgwemaloye. 
\q2 Degi-inigwele, eba ibsassurmalad, oburgwissurmalad. 
\q1  
\v 35 Aka e-dulesurmaladba apurudmalad, 
\q2 a-ibmar-imakmaladba akadmalad. 
\q1  
\v 36 Dule-baigan-e-bab-dummagan-e-nug odummodmalad. 
\q2 Degisoggu, we-ibmar egi aibinnonisunnad. 
\q1  
\v 37 Niamarga e-bunamala, e-masmala, 
\q2 oburgwenanai guarmalad. 
\q1  
\v 38 Dule-ibmar-okalodisulid-e-ablis eosmalad, 
\q2 a-e-masmala-e-ablis eosmalad, 
\q2 a-e-bunamala-e-ablis eosmarbalid. 
\q1 Canaán-dulemar-e-bab-dummaganga amar-oburgwenanai guarmalad. 
\q2 Degidbali, ablis-aryosad-ular, napneg isgunonikid. 
\q1  
\v 39 Weyob neg-imaksamaladbali, neg isgunonikid, 
\q2 bela isgunonimarsunnad. 
\b  
\q1  
\v 40 Degisoggu, Bab-Jehová e-dulemargi nue-uluded, 
\q2 isdar e-dulemar-sunonikid-dakdesunnad. 
\q1  
\v 41 Agala, Israel-dulesurmaladga urmaknonikid, 
\q2 e-isdarmaladse nilebukwa gusmarsunnad. 
\q1  
\v 42 E-isdarmaladse sabsur-imaklebukwa guarmalad, 
\q2 amarse apor-imakledii gusmarsunnad. 
\q1  
\v 43 Bab-Jehová bukidargus Israel-dulemar-bendakdii gusanad. 
\q2 Degi-inigwele, emardi, Bab-Dummadgi bur bule yoledgusmalad. 
\q2 Degidbali, isguedgi bur bule nanadmarsunnad. 
\q1  
\v 44 Bab-Dummad e-dulamar-surbinsa-itonanai-dakdegua, 
\q2 gormaknanaid-itononigua, 
\q1  
\v 45 e-dulamarbo-igar-mesisad ebinsaded. 
\q2 Sabbarsoggua, wile dakded. 
\q1  
\v 46 Bab-Dummad, Israel-dulemar-e-isdarmalad 
\q2 Israel-dulemar-wiledakega imaksabalid. 
\b  
\q1  
\v 47 Anmar-Bab-Jehováʼye, anmar-bendakdage, 
\q2 anmar-yar-baid-baidgi-mimiles-bukwadgi gannar be anmar-yarse be anmar-barmide, 
\q1 adi, anmar be-nug-isligwaled odummogega, 
\q2 weligwaledgi bega namakegar. 
\b  
\q1  
\v 48 Israel-e-Bab-Dummad-Jehová-nug dummarba gusun. 
\q2 ¡Degisadegu, e-nug odummolesun! 
\q1 Bela dulemar weyob sogmar: “¡Napira deyob gusun!” 
\q2 ¡Bab-Jehová-nug odummomar! 
\c 107  
\ms1 5. GARDA-SOGATALED 
\mr (Salmos 107:1–150:6) 
\s1 Bab-Dummad wile-itolegedgi dule-ollorsaoed 
\q1  
\v 1 Bab-Jehováʼga dog-nuedye sogmala, 
\q2 ar edi, dule-nuedid. E-sabgued, degisadeguad. 
\q1  
\v 2 Bab-Jehováʼse-abonolesmalad, 
\q2 Bab-Jehováʼse-e-isdarmalad-ganguedgi-bela-bela-bendaklesmalad, 
\q1  
\v 3 Bab-Jehová bela-Israel-dulemar-yar-baid-baidgi-bukwad senonikid: 
\q2 Dad-nakwedsikmalad, dad-argwanedsikmalad, 
\q2 dad-nakwed-argan-sapiledsikmalad, dad-nakwed-argan-nuedsikmalad. 
\q1 Amar Bab-Jehováʼga dog-nuedye sogmala, 
\q2 ar edi, dule-nuedid. E-sabgued, degisadeguad. 
\b  
\q1  
\v 4 Dulemar-abala nega-dulesulidganba yoggus gaamakdii gusmalad. 
\q2 Neggwebur-megdapmaloedse-momalaga, gwen igar-amisuli-gudii gusmalad. 
\q1  
\v 5 Na mas-gunbigudii gusmalad, uku-uku-itodii gusmarbalid, 
\q2 gwen san-bar-onoged itossurmalad. 
\q1  
\v 6 Geb surbinsa-itogusmaladba Bab-Jehováʼse gochamalad, 
\q2 geb Bab-Jehová e-wiledimaladgi bendaknonikid. 
\q1  
\v 7 Bab-Jehová neggwebur-megdapmaloedse-momalaga, 
\q2 igar-innikigwadba idumai gusad. 
\q1  
\v 8 Dule-nue-wiledakmaid-ulale, Bab-Jehováʼga doggus-nuedye be sogmala. 
\q2 Dulemarga-ibmar-gegerdaklemalad-imakdiid-ulale, Bab-Jehováʼga doggus-nuedye be sogmala. 
\b  
\q1  
\v 9 Bab-Jehová dule-uku-uku-itodimaladga ukud obeloged. 
\q2 Dule-ukudmaad-itodimaladga bur mas-nued uked. 
\q1  
\v 10 Abala nue-wile-itobukwa, emar-maiga-bukwa gusmalad. 
\q2 Negasichidgi, burgwednaga-bukwa gusmalad. 
\q1  
\v 11 Ar Bab-Jehová-Bur-Birigined-igar-sogsadba ibsassurmalad. 
\q2 Ar Bab-Jehová-binsaed-uked isdar itosmalad. 
\q1  
\v 12 A-ulale, Bab-Jehová arbaed-dummad ega urmaksad, 
\q2 aimukumai gusmalad, dule gwen bendaksasulid. 
\q1  
\v 13 Geb surbinsa-itogusmaladba Bab-Jehováʼse gochamalad. 
\q2 Geb Bab-Jehová, e-wiledimaladgi bendaknonikid. 
\q1  
\v 14 Negasichidgi-burgwednaga-bukwamaladgi onosad, 
\q2 emar-maiga-gudidiidgi onosad. 
\q1  
\v 15 Dule-nue-wiledaked-ulale, Bab-Jehováʼga doggus-nuedye be sogmala. 
\q2 Dulemarga-ibmar-gegerdaklemalad-imakdiid-ulale, Bab-Jehováʼga doggus-nuedye be sogmala. 
\q1  
\v 16 Ar yawagakmar-esgoro-gordikidgi-sobaled bibichisad, 
\q2 yawagak-edimalad-esgorobiid ubi-ubi imaksad. 
\b  
\q1  
\v 17 Anmar-dadgan Bab-Jehová-Igar-Sogsadba gwen ibmar-imaksasurmarsoggu, binsaed-satedyob gusmalad. 
\q2 Ibmar-isgana-imaked-ulale, wiledii gusmalad. 
\q1  
\v 18 Bela ibmar-gullemaladi ega aged ukdaed. 
\q2 Bato e-bergued-ibagan ese warmaksa itosgusad. 
\q1  
\v 19 Geb surbinsa-itogusmaladba Bab-Jehováʼse gochamalad. 
\q2 Geb Bab-Jehová, e-wiledimaladgi bendaknonikid. 
\q1  
\v 20 Bab-Dummad na e-sunmakedba dulemar-nudaksad, 
\q2 deyobi, burgwedgi bendaksad. 
\q1  
\v 21 Dule-nue-wiledaked-ulale, Bab-Jehováʼga doggus-nuedye be sogmala. 
\q2 Dulemarga-ibmar-gegerdaklemalad-imakdiid-ulale, Bab-Jehováʼga doggus-nuedye be sogmala. 
\b  
\q1  
\v 22 Bab-Jehováʼga doggus-nuedye-sogleged-ibmar-ukleged be ukmala, 
\q2 weligwaledgi e-ibmar-imaksad be sogmala. 
\q1  
\v 23 Dulemar muu-billi-dummaganba mani-amiegala, 
\q2 muu-billiba urgi nanadimalad. 
\q1  
\v 24 Wemala, Bab-Jehová-e-ibmar-imaksad daksamalad. 
\q2 Muu-billi-wilasailadgi e-ibmar-gegerdaklemalad-imaksad daksamalad. 
\q1  
\v 25 Bab-Dummad e-sunmakedba burwa binnasur ogochad, 
\q2 demardi bela-bela dunguded. 
\q1  
\v 26 Urdi mogirmar-naidse nakwiddaed, 
\q2 muu-billi-wilaganse gannar aidenonidabalid. 
\q2 Ar dulemardi burgwe-itomaladba niga-argwatemalad. 
\q1  
\v 27 Mummuyobi banamakdidii guarmalad. 
\q2 Aimukumamai guarmalad. 
\q1 E-ibmar-wisidi binsa-wismalad, 
\q2 gwen e-bendaksasulid. 
\q1  
\v 28 Geb surbinsa-itogusmaladba Bab-Jehováʼse gochamalad, 
\q2 geb Bab-Jehová e-wile-itomaladgi bendaknonikid. 
\q1  
\v 29 Bab-Dummad burwa-dummad bogidik imaksad, 
\q2 demar bipii imaksabalid. 
\q1  
\v 30 Ar burwa-bogiledgua, dulemar yeer itosmalad. 
\q2 Deyobi, Bab-Jehová ur-naguedse dulemar-sesad. 
\q1  
\v 31 Dule-nue-wiledaked-ulale, Bab-Jehováʼga doggus-nuedye be sogmala. 
\q2 Dulemarga-ibmar-gegerdaklemalad-imakdiid-ulale, Bab-Jehováʼga doggus-nuedye be sogmala. 
\b  
\q1  
\v 32 Bemar, dulemar-onmakbukwad-abargi, Bab-Jehová-e-nug odummomala. 
\q2 Girmar-dummagan-danar-bukwad-abargi, e-nug odummomala. 
\b  
\q1  
\v 33 Bab-Dummadi, e-dulamar-ichakwadamalad-ular, diwarmar nega-dulesulidganga obinnisad, 
\q2 dianmar neg-dinnaganaga obinnisbalid. 
\q1  
\v 34 Bab-Dummadi, e-dulamar-ichakwadamalad-ular, 
\q2 napa-gadi-ibmar-sanmakedi, napa-ichakwaga imaksad. 
\b  
\q1  
\v 35 Bab-Dummad nega-dulesulidgan diimarga obinnisad, 
\q2 neg-dinnagwad dianmarga obinnisad. 
\q1  
\v 36 Agi dulemar-uku-uku-itodimalad urbisad, 
\q2 geb we-dulemar megmalaga negmar sobsamalad. 
\q1  
\v 37 Nainumargi ibmar-gwag digsamalad, uva-dubmar digsamarbalid. 
\q2 A-ibmardi ega bela-bela sanmaksad. 
\q1  
\v 38 Bab-Dummad we-dulemargi nued-binsasad, 
\q2 e-dulamar mergudmalad, 
\q2 e-molimar merguega imaksabalid. 
\b  
\q1  
\v 39 Ar e-dulemar icheleddibe, ibgwensur-imakleddibe, mesagwar-imaklebukwad-ular, deyob guoed. 
\q2 Sabsur-imaklebukwad-ular, nue-wilebukwad-ular, deyob guoed. 
\q1  
\v 40 Bab-Dummad dulemar-nue-nug-nikamalad ibgwensur-daked, 
\q2 nega-dulesulidganba gaamakdii imaked. 
\q1  
\v 41 Ar Bab-Dummad, dule-wilegeddi na e-wilediidgi onoged. 
\q2 E-gwenadgan, sibad-wawaad-mergueyobi, bukidar-nika imaked. 
\q1  
\v 42 Dule-nuegan weyob-ibmar-dakoedba weligwar itomaloed. 
\q2 Ar dule-isganamardi, bar-sunmakosurmalad. 
\q1  
\v 43 Ar dule, binsaed-ibedile, we-ibmar gwagegi sedii guoed, 
\q2 Bab-Jehová-e-sabgued magar itogoed. 
\c 108  
\s1 Dule-isgudimaladgi an-bendakye Bab-Dummadga soged 
\r (Salmo 57:7-11; 60:5-12) 
\d We-Namaked, David narmaksad. 
\q1  
\v 1 Bab-Dummad, an-gwage guagwar-naid, 
\q2 an bega namaklemaladgi an namakoed, 
\q2 ar we, an-gandikidga gued. 
\q1  
\v 2 ¡Gar-arpa, gar-salterio be atakmala! 
\q2 Iba-gwapid-onodedga ogolega an imakoed. 
\q1  
\v 3 Bab-Jehová, an be-nug neggweburmar-abargi odummogoed. 
\q2 Dulemar-yar-baid-baidgi-bukwad-abargi an bega namaklemaladgi namakoed. 
\q1  
\v 4 Be-sabgued nibneg-naidba bur-dummarba gued. 
\q2 Be-innikidaed nibnegse warmaknaid. 
\q1  
\v 5 Bab-Dummad, bedi nibneggi maid. 
\q2 Gandikidba-be-yeerdakleged bela napneg-ebilis naid. 
\q1  
\v 6 Bab-Dummad, be-neggwebur-be-nue-sabed-bendakega, be anmar-bendake, 
\q2 be anmar-abinsae. 
\b  
\q1  
\v 7 Bab-Dummad e-neg-islidikid-akale sogsad: “Weligwaledgi an Siquem-neggwebur mimioed, 
\q2 weligwaledgi an Sucot-neba-naid ilemakoed. 
\q1  
\v 8 Galaad-yala, angadi gued, 
\q2 Manasés-yala, angadi gued, 
\q1 Efraín-yala, an-bormo-gurginga gued, 
\q2 Judá-yala, an-gaapoledga gued. 
\q1  
\v 9 Moab-yala, an-argan-enukedga gued, 
\q2 Edom-yargi, an-sapat bikiin an metoed, 
\q2 Filistea-sordamargi-nakwisadba, gandikidba an gormakoed.” 
\b  
\q1  
\v 10 ¿Doa, neggwebur-gandikidse an-idugoe? 
\q2 ¿Doa, anga Edom-yarse-aibillemaid oyogoe? 
\q1  
\v 11 Bab-Dummad, ¿bee be anmar-obachagussursi? 
\q2 Bab-Dummad, bar be anmarga sorda-bila-onomalad-bendakdisurgusad. 
\q1  
\v 12 Dule-isdarmaladgi-nakwega be anmar-imake. 
\q2 Ar dulemar anmar-bendakele, gwen anmarga igarga guosulid. 
\q1  
\v 13 Unnila, Bab-Dummadbali, anmar, anmar-isdarmaladgi nakoed. 
\q2 E anmarga, anmar-isdarmalad obelogoed. 
\c 109  
\s1 Bab-Dummad an-bendake 
\d David, we-namaked narmaksad. Namakmalad-e-iduedga soglenaid. 
\q1  
\v 1 Bab-Dummad, an be-nug ogannoged. 
\q2 Melle be an-abin-imaksuli gue. 
\q1  
\v 2 Dule-isganamar, dule-gakansamalad, angi gakansaar sunmakdimalad. 
\q2 Gakansaedgi an-nug oichodimalad. 
\b  
\q1  
\v 3 Sae-an-dakmaladbali, sunnasur angi sunmakdimalad. 
\q2 Binsarsunna angi yolenanaid. 
\q1  
\v 4 Andi, we-dulemar-nue-sabed, 
\q2 degite, emardi angi yolenanaid. 
\q2 Bab-Dummad, andi emarga bese gorsii daed. 
\q1  
\v 5 Andi, ibmar-nued ega imaked, 
\q2 emardi, ibmar-isgana anga imaked. 
\q1 Andi, wemar-sabed, 
\q2 emardi, sae-an-daked. 
\b  
\q1  
\v 6 Bab-Dummad, we-dulemarga-igar-nabogega, dule-isgana ega be ogwiche, 
\q2 dule-e-bendaknaid egi aibined be imake. 
\q1  
\v 7 Ega igar-nabolealir, we-dulegi isgusye-sogleged be imake, 
\q2 bese-goledse-bakar, ega isguedga-guega be imake. 
\q1  
\v 8 Gwae be oburgwe. 
\q2 Dule-baid ei arbaed-sued be imake. 
\q1  
\v 9 E-mimmigan, bab-sate be imake. 
\q2 E-ome, suisuli be imake. 
\q1  
\v 10 E-mimmigan, neg-sate be imake. 
\q2 Dule-baiganse mani-egisdii be imake. 
\q2 E-neg-bibisgar-siidgi ononnoged be imake. 
\q1  
\v 11 Dule-ega-idu-mani-ukdidaed, 
\q2 bela ei ibmar-seled be imake. 
\q1 Na e-ibmargi-arbasad, 
\q2 ei dule-baigan-suega be imake. 
\q1  
\v 12 Dule-baigan we-dule-wiledaksuli be imake. 
\q2 Dule-baid bipisaale e-mimmigan-sergan-sated, melle wiledaked be imake. 
\q1  
\v 13 E-wagan bela be ogiloge. 
\q2 Dulemar we-dulemar-bela-ieged be imake. 
\q1  
\v 14 Bab-Jehová, e-bab-ibmar-isgana-imakdigusad, mer be iego, 
\q2 e-nan-isgudigusad, melle be iebalo. 
\q1  
\v 15 Bab-Jehová, melle e-isgued be iego. 
\q2 We-napneggi, dulemar we-dule-ieged be imake. 
\q1  
\v 16 Ar we-dulede, dule-baigan-baisur-daksa gusad. 
\q2 Dule-wilegana-baregindii gusad, 
\q2 dule-ibmarbina-sogdimalad-baregindii gusad. 
\q1 Dule-gwage-naibi-itodiid-baregindii gusad. 
\q2 We-dulemar-oburgwedse baregindii gusad. 
\q1  
\v 17 Ar aimar-ukabsaed yeer itodasoggu, 
\q1 dulemar-baigan e-ukabsamosun. 
\q2 Ar egi nued-binsaed abessursoggu, melle egi nued binsamarsun. 
\q1  
\v 18 Dule, emar-ukabsaedi na e-mor-dummadyob ega gusun. 
\q2 Emar-ukabsaedi, dii-goblegeyob egi ubosun. 
\q2 Emar-ukabsaedi, ina-abagalaganse-ubogeyob ega gusun. 
\q1  
\v 19 We-ukabsaedi, e-mor-dummadyobi gusun. 
\q2 Sadergi-molidub-guur-naiyob egi nagubarsun. 
\q1  
\v 20 Weyobi, Bab-Jehová an-isdarmalad imaksun, 
\q2 weyobi, dulemar-sunnasur-angi-sunmakdimalad imaksun. 
\b  
\q1  
\v 21 Bab-Jehová, bee be an-Dummadid, 
\q2 Be-nug-dummarba-nikadba wile be an-dake, 
\q1 dule-angi-sunmakdimaladgi be an-onoge, 
\q2 ar be-sabgued dummarba gued. 
\q1  
\v 22 An wilegedid, an ibmar-sate gudiid, 
\q2 ulubgi ise-nue-naibi an itoged. 
\q1  
\v 23 Binna-binna neg-gutulemaiyobi, an nolloo gumaid, 
\q2 ses burwa-goledba-seled-daedyobi, an selemaid. 
\q1  
\v 24 An mas-gunsulidba an gaaragusad. 
\q2 An mas-gunsulidba an-yokor nue-nollogusad. 
\q1  
\v 25 Dulemar an-dakalile, 
\q2 angi dodoardamalad, anga alliardamalad. 
\b  
\q1  
\v 26 An-Bab-Dummad-Jehováʼye, be an-bendake. 
\q2 Sabgued-dummarba-nikadba be an-bendake. 
\q1  
\v 27 Bab-Jehováʼye, magar-itogega be dulemar-imake, 
\q2 ar bee be we-ibmar imaksad. 
\q1  
\v 28 Be angi ise-nued binsae. 
\q2 Ar emardi an-ukabsaele, akarsulid. 
\q1 An-isdarmaladdi be obingegsae, 
\q2 andi be-maiga-guedi, weligwar-itoge be an-imake. 
\q1  
\v 29 ¡An-isdarmaladdi be dummad-obingegsae! 
\q2 ¡Bela-belad-bingeguega be imake! 
\b  
\q1  
\v 30 Bab-Jehová-e-nug an-gayagi an odummogoed. 
\q2 Dule-bukidar-abargi be-nug an ogannogoed. 
\q1  
\v 31 Ar dule-isgana dule-wilegana-oburgweye-sokalile, bee be dulemar-wilegana bendakdaed. 
\q2 A-ulale, be-nug an odummogoed. 
\c 110  
\s1 Bab-Jehová reyga gargangued uknonikid 
\d David, we-namaked narmaksad. 
\q1  
\v 1 Bab-Jehová an-Dummadga sogsad: “An-argan-nuedsik be sige, 
\q2 be-isdarmalad an bela ogalakuedse be sige.” 
\b  
\q1  
\v 2 Bab-Jehová Sión-yar-akale, bega be-negsemaid-e-gargangued oyononikoed: 
\q2 Be-isdarmalad-be-urbalikwaa-nanaega, be imako. 
\q1  
\v 3 Be-sordamala bila-onoleged-ibagi, sogedbali guakwaa bukumaloed, 
\q2 ilekwaa yeerdakle ambikumaloed. 
\q1 Bolegoedba boo-bateyobi, 
\q2 be-niga bega gannolemai-gannolemai guoed. 
\q1  
\v 4 Bab-Jehová ise-sogar-imaksad 
\q2 e-sogsad bar ogwaosulid: 
\q1 “Be, Bab-Dummad-asabin Dule-Irwa-Gwisgued-Dummad-Degisadeguadid. 
\q2 Igi Melquisedec maigusa, deyob be gumogad.” 
\b  
\q1  
\v 5 Bab-Jehová, Dule-Dummad be-argan-nuedsik siid. 
\q2 Sabsur-urwenonikoed-e-ibagi reymar-mamaid ese ibitomaloed. 
\q1  
\v 6 Dulemar-yar-baid-baidgi-bukwamalad ese odurdaklemaloed. 
\q2 Muimar bukidar-omiledmaloed. 
\q2 Napneggi-dulemar-bukwad bela ese ibitolemaloed. 
\q1  
\v 7 Igarbali, rey, dian-aryomaid goboed, 
\q2 degidba, e-niga gangunonikoed. 
\c 111  
\s1 Bab-Dummad e-dulamar-bendaked 
\d ¡Bab-Dummad-nug odummolesun! 
\q1  
\v 1 Dulemar-abargi, dule-nueganbo 
\q2 an bela-bela gwagegi Bab-Jehová-nug odummogoed. 
\q1  
\v 2 Bab-Jehová-e-ibmarmar-imaksad doggus dungued, 
\q2 we-ibmarbina-itogerbamaladi, egi nergumalad. 
\q1  
\v 3 Na e-ibmar-imaksad doggus gangu-dakleged, doggus yeerdakleged, 
\q2 na e-Igar-innikigwad degisadegu-maigu guoed. 
\q1  
\v 4 Bab-Dummad, e-ibmar-gegerdaklemalad-imaksad, degisadegu ebinsamalaga imaked. 
\q2 Bab-Jehová nued-binsaedgi-dulemar-bendakedid, dule-wiledakedid. 
\q1  
\v 5 Bab-Dummad dulemar-e-nug-odummodimaladga mas uked, 
\q2 na Ebo-Igar-Mesisad degisadegu ebinsaed. 
\q1  
\v 6 Na e-dulamarga e-ibmar-imaksadgi e-gangued oyosad. 
\q2 Dulemar-yar-baid-baidgi-bukwamalad-e-yar ega uksadba, e-gangued oyosad. 
\q1  
\v 7 Na e-ibmar-imaksad, napiragwadid, innikigwadid. 
\q2 Bela e-Igar-Islidikid-Mesisad egi bengulesulid. 
\q1  
\v 8 E-Igar-Mesisad degisadegu gangu maid, gege gwaged, 
\q2 napiragwadgi, innikigwadgi mesisad. 
\q1  
\v 9 Bab-Dummad na e-dulemar-galebukwad ollor-imaksad. 
\q2 Degisadegu na ebo Igar mesisad. 
\q2 ¡E-nug-isligwaled, bur gannarbadid! 
\b  
\q1  
\v 10 Bab-Jehová-dobee-nanaedgi binsaed-ibed-guedi danikid. 
\q2 Bab-Jehová-Igar-Mesisadba-ibmar-imakdimalad nue-ibmar-wisi gumalad. 
\q2 ¡Bab-Jehová-nug degisadegu odummoledii guoed! 
\c 112  
\s1 Dule-Bab-Jehová-dobee-nanadiid ibmar-bukidar nikued 
\q1  
\v 1 ¡Aleluya! ¡Bab-Jehová-nug odummolesun! 
\b  
\q1 Dule Bab-Jehová-dobee-nanadiidgi, Bab-Jehová nued binsasad. 
\q2 Dule Bab-Igar-Mesisadba bela-belad yeer-itodiidgi, Bab-Jehová nued binsasad. 
\q1  
\v 2 Napneggi e-wagan dule-gandikidga guoed, 
\q2 dule-gwage-innikimalad-e-anagangi ise-nued-binsalegoed. 
\q1  
\v 3 E-neggi ibmar-nuegan-bukidar-nika guoed, 
\q2 e-Igar-Inniki-Imaked degisadeguoed. 
\q1  
\v 4 We-dulede, dule-innikidaedsoggu, wile-dule-dakdaedsoggu, itoakwaa-ibmar-imakedsoggu, 
\q2 dule-nueganga negasichidgi neg-meegwadyob gued. 
\q1  
\v 5 Dule-nued-daedi, emarga obinagwar ibmar-ukedid. 
\q2 Igar-innikigwadba e-ibmar-baklemaid semaid. 
\q1  
\v 6 Bipisaale gwen-galakuosulid 
\q2 dule-nued-daedi, degisadegu ebinsalegoed. 
\q1  
\v 7 Garda-isganamar-itoalile, dobee itogosulid. E-gwagegi baisur-itogoed, 
\q2 Bab-Dummadgi bensuli guoed. 
\q1  
\v 8 Na e-ulubgi gandik itogoed, dobee itogosulid. 
\q2 E-isdarmalad ese galakusad na dakoed. 
\q1  
\v 9 E-ibmar-nikadi, dule-wilemaladga mimied. 
\q2 E-Igar-Inniki-Imaked degisadegu maigu guoed. 
\q2 E-ganguedi, gandikidba-yeerdakle ogannolegoed. 
\q1  
\v 10 Deyob dule-isgudiid we-ibmar dakoed, 
\q2 na sae-itodoed, 
\q1 nugar-gormai na bergudoed. 
\q2 Dule-isgudiid-e-ibmar-abegedi bela bergudoed. 
\c 113  
\s1 Bab-Dummad-nued-daed-nug odummoged 
\q1  
\v 1 ¡Aleluya! ¡Bab-Jehová-nug odummolesun! 
\b  
\q1 Bab-Dummad-Jehová-e-maimar, Bab-Jehováʼse be gormar, 
\q2 Bab-Jehová-nug be odummomar. 
\q1  
\v 2 Emi-iba-akale, Bab-Jehová-nuggi 
\q2 degisadegu nued-binsalesun. 
\q1  
\v 3 Dad-nakwed-akar, dad-argwanedse, 
\q2 Bab-Jehová-nugdi dummarba gusun. 
\q1  
\v 4 Bab-Jehová bela dulemar-yar-baid-baidgi-bukwad semaid, 
\q2 Nibneggi e-gangued-yeerdakleged bur dummarba gued. 
\b  
\q1  
\v 5 Anmar-Bab-Dummad-Jehová-nibneggi-maidyobi, dule sated. 
\q2  
\v 6 Bab-Jehová, e-maid-akale, nibneg dakmaid, 
\q2 napneg dakmaibalid. 
\q1  
\v 7 Bab-Jehová, dule-wileged e-wilediidgi bendakdaed, 
\q2 Bab-Dummad, dule-ibmar-abesa-gudiid e-ibmar-abediidgi bendakdaed. 
\q1  
\v 8 Adi, neggwebur-e-dummagan-abargi siegar. 
\q2 Dule-nuga-nikamalad-abargi siegar. 
\q1  
\v 9 Ome geg mimmi-bakedi, nabir mimmi-bake imaked, 
\q2 nabir neguya-nika imaked. 
\b  
\q1 ¡Aleluya! ¡Bab-Jehová-nug odummolesun! 
\c 114  
\s1 Egipto-yargi ibmar-gegerdaklemalad-oyolesad 
\q1  
\v 1 Israel-dulemar Egipto-yargi nosmargua, 
\q2 Judá-yar Babse-goled-negga gunonikid. 
\q1  
\v 2 Jacob-wagan dule-baigan-yargi-bukwa nosmargua, 
\q2 Israel-yar-naid bela Bab-Dummadgadga gunonikid. 
\b  
\q1  
\v 3 Demar-naid Israel-dulemar-dakdegua, Israel-dulemar-abin argaded. 
\q2 Jordán-diwar-ariomaid 
\q2 e-abin gales megisad, bar aryossulid. 
\q1  
\v 4 Sibad-wawaad-macheredyob yar-dummagan ichomakded, 
\q2 sibad-wawaad-mimmiganyob yar-senigana ichomakdemalad. 
\b  
\q1  
\v 5 Demar, ¿ibiga be argade? 
\q2 Jordán-diwar, ¿ibiga be gales-megismoga? 
\q1  
\v 6 Bemar yar-bukwamaladi, ¿ibiga bemar sibad-wawaad-macheredyob ichomakdemala? 
\q2 Bemar yar-senigana, ¿ibiga bemar sibad-wawaad-mimmiganyob ichomakdemarmoga? 
\b  
\q1  
\v 7 Napneg-naid, Bab-Jehová-asabin be giglimake, 
\q2 Jacob-e-Bab-Dummad-asabin be giglimake. 
\q1  
\v 8 Ar Bab-Jehová akwasaila dii-siedga imaksad, 
\q2 akwasailagi dii-aryomai imaksad. 
\c 115  
\s1 Anmar-Bab-Dummad-nibneggi-maid 
\q1  
\v 1 Bab-Jehová, be-nug-odummolegega bega namakleged. 
\q2 Anmar-nug-odummolegega namaklesulid. 
\q1 Be dule-wiledakedba, be ibmar-innikigwad-sogedba, 
\q2 a-ular, bega namakleged. 
\q1  
\v 2 Ar ibiga dulemar-yar-baid-baidgi-bukwamalad anmarga sogoe: 
\q2 “¿Bia be-Bab-Dummad nadsunna?” 
\q1  
\v 3 Anmar-Bab-Dummad nibneggi maid, 
\q2 ar ibi na imakbigusa, bela imaksad. 
\b  
\q1  
\v 4 Dule-baigan ibmarmar-e-bab-dummadga-imakbukwadi, manigi sobaled, orgi sobaled, 
\q2 dulemar e-argangi sobsananaed. 
\q2  
\v 5 We-ibmardi, gaya nikamalanad, degite, sunmaksurmalad. 
\q2 Ibya nikamalanad, degite, aku-atakmalad. 
\q2  
\v 6 Uaya nikamalanad, degite, itosurmalad. 
\q2 Asu nikamalanad, degite, ibmar-yapanned usurmalad. 
\q2  
\v 7 Argan nikamalanad, degite, ibmar ebusurmalad. 
\q2 Nag nikamalanad, degite, nanasurmalad. 
\q2 E-dolewar nikamalanad, degite, ibmar-soggwensaar bisurmalad. 
\q1  
\v 8 E-sobmalad, deyobi gumarmogad, 
\q2 bela-egi-bengusurmalad, deyobi gumarmogad. 
\b  
\q1  
\v 9 Israel-dulemar, ¡mer Bab-Jehováʼgi bengumala! 
\q2 Na e be-bendaked gued, 
\q2 be-sigu-abgaedga gued. 
\q1  
\v 10 Aarón-wagan, dule-irwa-Bab-Dummadse-gormalad, ¡mer Bab-Jehováʼgi bengumala! 
\q2 Na e be-bendaked gued, 
\q2 be-sigu-abgaedga gued. 
\q1  
\v 11 Bab-Jehová-urbali-gudimalad, ¡mer Bab-Jehováʼgi bengumala! 
\q2 Na e be-bendaked gued, 
\q2 be-sigu-abgaedga gued. 
\b  
\q1  
\v 12 Bab-Jehová anmar-ebinsaed, 
\q2 anmargi nued binsaed, 
\q1 Israel-dulemargi nued binsaed, 
\q2 Aarón-wagangi nued binsaed. 
\q1  
\v 13 Bab-Jehová, e-urbali-gudimaladgi nued binsaed, 
\q2 dule-nuga-nikamaladgi nued binsaed, 
\q2 dule-binsarmaladgi nued binsabalid. 
\b  
\q1  
\v 14 Bab-Jehová bemarga bur bule mimmigan-mergumai imaksun, 
\q2 be-waganga mimmigan-mergumai imakbarsun. 
\q1  
\v 15 Bab-Jehová-nibneg-obinnisadi, bemargi nued-binsaena gadin. 
\q2 Bab-Jehová-napneg-obinnisadi, bemargi nued-binsaena gadin. 
\b  
\q1  
\v 16 Nibneg, Bab-Jehováʼgadid. 
\q2 Napnegdi, Bab-Jehová dulemarga uksad. 
\q1  
\v 17 Dule-burgwarmalad Bab-Jehová-nug odummosurmalad. 
\q2 Dulemar-neg-urba-diglesmamaidi, Bab-Jehová-nug odummosurmalad. 
\q1  
\v 18 Ar anmardi, emi-akale, Bab-Jehová-nug 
\q2 degisadegu odummodii gumaloed. 
\b  
\q1 ¡Aleluya! ¡Bab-Jehová-nug odummolesun! 
\c 116  
\s1 Bab-Dummadga-doggus-nuedye-soged 
\q1  
\v 1 Bab-Jehováʼbina, an bela-belad soged. 
\q2 An-ese-wilesakwaa-goledi an-itoged. 
\q1  
\v 2 Ar Bab-Dummad an-itodasoggu, 
\q2 bane-bane an burgwedse ese gordii guoed. 
\b  
\q1  
\v 3 Burgwed-igar nue an-ebiris nagusad. 
\q2 Burgwarmalad-meged-galu anbina nue-itos naid. 
\q1 Degidbali, surbinsa an itoded, 
\q2 gwage-nunmak an itonaded. 
\q1  
\v 4 Degidgine, Bab-Jehováʼse an goted: 
\q2 “Bab-Jehováʼye, wis be an-bendakye.” 
\b  
\q1  
\v 5 Bab-Jehová, wile-dule-dakedid, 
\q2 dule-innikidaedid. 
\q2 Anmar-Bab-Dummad, ise-wile-dule-dakedid. 
\q1  
\v 6 Bab-Jehová, dule-belagwadamalad akwemaid. 
\q2 An nue-bela-maidgi, an-abonosad. 
\b  
\q1  
\v 7 Emigindi, an bar bukib-binsaosulid, gwage-bogidik-gudii guoed. 
\q2 Ar Bab-Jehová angi nued binsasad. 
\b  
\q1  
\v 8 Bab-Jehová, bee be burgwedgi an-san-burba-onosad, 
\q2 an-ibyanis be elisad, 
\q2 galagwensuli-gudiidgi be an-onosad. 
\q1  
\v 9 Degisoggu, dule-bukwamalad-abargi, 
\q2 Bab-Jehová-asabin an gudii guoed. 
\q1  
\v 10 An nue-bukib-itodiiye an sog-inigwele, 
\q2 amba an Bab-Dummadgi bensulid. 
\q1  
\v 11 An sulibinsa-itogedgi an sogsad: 
\q2 Bela dulemar gakansaedbiiye. 
\b  
\q1  
\v 12 Bab-Jehová bela-belad angi nued-binsasadi, 
\q2 ¿ibugi an bennukoe? 
\q1  
\v 13 Unnila abonolesad-ular, Bab-Jehováʼga dog-nuedye-sogega, noggi an vino ukoed. 
\q2 Unnila Bab-Jehová-nuggi an goloed. 
\q1  
\v 14 Unnila Bab-Jehováʼga an ibmar-imakoye ise-sogar-sogsadi, 
\q2 bela dulemar-asabin an imakoed. 
\b  
\q1  
\v 15 Bab-Jehová dule-eba-nanaimalad-burgwedi 
\q2 bela-bela yeer daked, ega ibnuedid. 
\q1  
\v 16 Bab-Jehová, ani an be-maiga gued. 
\q2 An be-machi-innikigwadid, 
\q1 an be-maiga gudiid. 
\q2 Galessiidgi be an-ollor-imaksad. 
\b  
\q1  
\v 17 Bab-Jehová, an bega doggus-nuedye-sogega, ibmar-ogumakar-ukleged ukoed. 
\q2 Bab-Jehová, be-nuggi an goloed. 
\q1  
\v 18 Bab-Jehováʼga an ibmar-imakoye ise-sogar-sogsadi, 
\q2 bela e-dulamar-asabin an imakoed. 
\q1  
\v 19 Bab-Jehováʼse-goled-neg-imbagi an imakoed, 
\q2 Jerusalén-neggwebur-abargi an imakoed. 
\b  
\q1 Aleluya, ¡Bab-Dummad-nug odummolesun! 
\c 117  
\s1 Bab-Jehová-nug ogannomar 
\q1  
\v 1 Bela dulemar-yar-baid-baidgi-bukwad, Bab-Jehová-nug odummomar. 
\q2 Bela dulemar-baid-baid-danar-danar-bukwamalad, Bab-Jehová-nug ogannomar. 
\q1  
\v 2 Ar Bab-Jehová bela-bela anmar-sabed. 
\q2 Ar Bab-Jehová-ibmar-soged, guedsegad. 
\b  
\q1 ¡Aleluya! ¡Bab-Jehová-nug odummolesun! 
\c 118  
\s1 Bab-Jehováʼga dog-nuedye sogleged 
\q1  
\v 1 Bab-Jehová-e-nug odummomar. 
\q2 Ar Bab-Jehová dule-nuedid. 
\q2 Ar Bab-Jehová-e-sabgued, degisadeguad. 
\b  
\q1  
\v 2 Israel-dulemar, emisgi be sogmala: 
\q2 “Bab-Dummad-e-sabgued, degisadeguye.” 
\q1  
\v 3 Aarón-e-wagan, emisgi be sogmala: 
\q2 “Bab-Dummad-e-sabgued, degisadeguye.” 
\q1  
\v 4 Bab-Jehová-dobekwaa-gudimalad, emisgi be sogmala: 
\q2 “Bab-Dummad-e-sabgued, degisadeguye.” 
\b  
\q1  
\v 5 An bonigan-abalagi-gudiidgi, Bab-Jehováʼse an gochagusad. 
\q2 An gochagua, an-abin-imaksad, neg-olloledgi an-ogwisgunonikid. 
\q1  
\v 6 Bab-Jehová anba gudiid, degisoggu, an ibmar dobsulid, 
\q2 ar dule akar an-imakosulid. 
\q1  
\v 7 Bab-Jehová anba gudiid, ar nue-an-bendakdiid. 
\q2 Degisoggu, isdar-an-dakdimalad, napayala-baparmakdii an dakoed. 
\q1  
\v 8 Dulemargi-bensuliguedba bur Bab-Jehováʼgi-bengusuligued abeleged. 
\q2  
\v 9 Dule-nug-nika-gudimaladgi-bensuliguedba bur Bab-Jehováʼgi-bengusuligued abeleged. 
\b  
\q1  
\v 10 Dulemar-yar-baid-baidginmalad an-ebiris gusmalanad, 
\q2 degi-inigwele, Bab-Jehová-nuggi anse ogilolesmalad. 
\q1  
\v 11 Bela an-ebirismalanad, 
\q2 degi-inigwele, Bab-Jehová-nuggi anse ogilolesmalad. 
\q1  
\v 12 Burmaryobi an-ebirismalanad, 
\q2 degi-inigwele, gagan-soogi-gummakeyob anse gusmalad. 
\q2 Bab-Jehová-nuggi anse ogilolesmalad. 
\q1  
\v 13 An-egwanmalagala, sabesuli an-barmete gusmalanad, 
\q2 degi-inigwele, Bab-Jehová an-bendaknonikid. 
\q1  
\v 14 Ar Bab-Jehová an-niga-gandikidga gued, an-namakedga gued. 
\q2 Ar Bab-Jehová an-abonogedid. 
\b  
\q1  
\v 15 Dule-inniki-gudimalad, weligwaledgi oimakdemalad, 
\q2 bendaklenonimaladba e-neg-e-neggi weyob binnasur-gotemalad: 
\q2 “Bab-Jehová e-garganguedgi ibmar-bulegan imaked. 
\q1  
\v 16 Bab-Jehová-e-gargangued, biriginedid. 
\q2 Bab-Jehová-e-gargangued ibmar-bulegan imaked.” 
\q1  
\v 17 An burgosulid, an dula-gudii guoed. 
\q2 Bab-Jehová-ibmar-imaksad-barsogega an dula-gudii guoed. 
\q1  
\v 18 Bab-Jehová undar-naibi an-imaksad, 
\q2 degi-inigwele, an-oburgwissurgusad. 
\b  
\q1  
\v 19 Anga yawagak egamar, 
\q2 Bab-Dummadse-goled-neg-e-yawagak anga egamar, 
\q2 Bab-Jehová-nug-odummogegala, agi an dogoed. 
\q1  
\v 20 We, Bab-Jehová-e-yawagak gued, 
\q2 agi dule-inniki-gudimaladbi dogmaloed. 
\b  
\q1  
\v 21 Bab-Jehová, be an-abin-imaksasoggu, 
\q2 an bega dog-nuedye soged, ar be an-abonosad. 
\q1  
\v 22 Akwa dule-neg-sobmaladse-oballesadi, 
\q2 neg-sobleged-e-akwasailaga gunonikid. 
\q1  
\v 23 Bab-Jehová deyob we-ibmar imaknonikid, 
\q2 anmarga geger-dakle gunonikid. 
\q1  
\v 24 We-ibagi Bab-Jehová anmarga ibmar imaksad, 
\q2 ¡anmar egi wergumarsun, yeer-itomarsun! 
\b  
\q1  
\v 25 Bab-Jehováʼye, wilesakwaa an bese gornaid, be anmar-abonoge. 
\q2 Bab-Jehová, anmar-onasguega be anmar-imake. 
\q1  
\v 26 Bab-Jehová-nuggi-dule-danikid, Bab-Jehová egi nued-binsasun. 
\q2 Bab-Jehová-e-neg-akale, anmar ega sogsun: “Bab-Jehová begi nued-binsasunye.” 
\q1  
\v 27 Bab-Jehová, Bab-Dummadid. 
\q2 Anmarga gwallu-meegwadyobi gued. 
\q1 Igarba bipirmaknamalo, sapi-e-anagan semamai gumalo, 
\q2 Bab-Jehováʼga-ibmar-ogumakar-ukleged-ailagi moli-bebeyob-nonaidse sedmalo. 
\b  
\q1  
\v 28 Bab-Jehová, ar be an-Bab-Dummadid, 
\q2 agala, an bega dog-nuedye soged. 
\q1 Bab-Jehová, ar be an-Bab-Dummadid, 
\q2 agala, an be-nug-odummoged. 
\b  
\q1  
\v 29 Bab-Jehová-e-nug odummomar, 
\q2 ar Bab-Jehová, dule-nuedid, 
\q2 ar Bab-Jehová-e-sabgued, degisadeguad. 
\c 119  
\s1 Bab-Dummad-Igar-Nued-Maidgi namaked 
\qa Alef 
\q1  
\v 1 Dulemar-inniki-nanadimalad, Bab-Jehová-Igar-Maidba nanadimalad. 
\q2 Amargi, Bab-Jehová, ise-nued binsaed.\fig Bab-Dummad-Igar-Nued-Maid. (Salmo 119) |src="CO01230B.TIF" size="col" ref="Salmos 119:1" \fig* 
\q1  
\v 2 Dulemar-Bab-Dummad-Igar-Maidba-gudimaladi, bela-bela-ulubgi-be-amidimaladi, 
\q2 amargi, Bab-Jehová, be ise-nued binsaed. 
\q1  
\v 3 We-dulemar, bipisaale ibmar-isgana imakdisurmalad, 
\q2 unnila, Bab-Dummad-Igarbarbi nanadimalad. 
\b  
\q1  
\v 4 Bee be Be-Igar-Islidik-Mamaid mesisad, 
\q2 adi, a-sogedba nanamalagar. 
\q1  
\v 5 Be-Igar-Mamaidba an nanadiguega, 
\q2 bitigi bela-bela eba an innikii nanadii gusana gadin. 
\q1  
\v 6 Bela Be-Igar-Islidik-Mesisadba an nanaele, 
\q2 an binge-itogosulid. 
\q1  
\v 7 Be-Igar-Inniki-Nabolemalad-Mamaid an durdaksale, 
\q2 an innikigwadbali ulubgi be-ogannogoed. 
\q1  
\v 8 ¡Be-Igar-Mamaid-Sogedba, an nanaoed! 
\q2 ¡Bipisaale melle be an-iego! 
\b  
\qa Bet 
\q1  
\v 9 ¿Igi-sapingwa melle-isguega, na nuekwaa nanadii guergebe? 
\q2 Unnila, Be-Gayaburba-Maidbarbi nanadii guergebed. 
\q1  
\v 10 An gwage-ulubgi bela-belad, an be-amidiid. 
\q2 Be-Igar-Islidik-Mamaidgi, melle aibanega be an-imako. 
\q1  
\v 11 Melle begi-isguegala, 
\q2 Be-Gayaburba an-gwage-ulubgi an na sediid. 
\q1  
\v 12 ¡Bab-Jehová, be-nug-odummolesun! 
\q2 ¡Be-Igar-Mamaidgi be an-odurdake! 
\q1  
\v 13 Igar-Megisadba bela be ibmar-sogsadi, 
\q2 dulemarga an sogsad. 
\q1  
\v 14 Bela ibmar-nikadba bur bule Be-Igar-Mamaidba-nanadiidgi 
\q2 an weligwar itodiid. 
\q1  
\v 15 Be-Igar-Islidik-Mamaidgi an binsaoed, 
\q2 Be-Igarbarbi an nue-nanadii guoed. 
\q1  
\v 16 Be-Igar-Mamaidgi an weligwar itogoed. 
\q2 Bipisaale, an Be-Gayaburba gwen iegosulid. 
\b  
\qa Guímel 
\q1  
\v 17 An be-mai-guedi, nue-wile be dakdii guo, 
\q2 deyobi, an nabir gudii guoed, 
\q2 be-Gayaburba-sogedba an nanadii guoed. 
\q1  
\v 18 Be-Igar-Biriginmalad-Mamaid, 
\q2 magar-itogega be an-imake. 
\q1  
\v 19 We-napneggine, an dule-baid gued, 
\q2 melle angi Be-Igar-Islidik-Mamaid be odukue. 
\q1  
\v 20 Bane-bane an Be-Igar-Nabolemalad bei-durdakbiedbali, 
\q2 an yaisur-itoged. 
\q1  
\v 21 Dule-san-dummarba-imakmaladse be urwemaid. 
\q2 Dule-isganamar, Be-Igar-Islidik-Mamaidgi-banguder, ega be sabsur-ibmar soged. 
\q1  
\v 22 Melle we-dulemar isdar-an-dakmalaga, be imako. 
\q2 Melle ibgwensur-an-samalaga be imako, 
\q2 Ar an Be-Igar-Mamaidba an nanadiid. 
\q1  
\v 23 Dule-gandikmalad angi ichakwa-sunmakmar-inigwele, 
\q2 andi be-mai-guedi, Be-Igar-Mamaidginbi binsadii guoed. 
\q1  
\v 24 Be-Igar-Mamaid, weligwar an-imaked, 
\q2 anga binsaed-ukedid. 
\b  
\qa Dálet 
\q1  
\v 25 An san bela-itoged, 
\q2 Be-Anga-Ibmar-Sogsadba be an-ogannoge. 
\q1  
\v 26 An-gudiidgi an bega sunmaksagua, be an-abin-imaksad. 
\q2 ¡Be-Igar-Mamaidgi be an-odurdake! 
\q1  
\v 27 Be-Igar-Islidik-Mamaidi, magar-itogega be an-imake, 
\q2 adi, be-ibmar-gegerdaklemaladgi an binsaegar. 
\q1  
\v 28 An ulubgi wile-itogedba bodiid, 
\q2 degisoggu, Be-Gayaburbagi baisur-itogega be an-imake. 
\q1  
\v 29 Gakan-igarmargi mer-nanaega be an-imake. 
\q2 Be-wile-dule-dakmaidba Be-Igar-Nuegan-Maidgi be an-odurdake. 
\q1  
\v 30 Igar-Napiragwad-Maid an susad. 
\q2 Be-Igar-Mamaid angadga an imaksad. 
\q1  
\v 31 Bab-Jehová, Be-Igar-Sogsadgi an alamaknaid, 
\q2 melle bingeguega be an-imako. 
\q1  
\v 32 Be-Igar-Islidik-Mamaidba an gwae ibsaoed, 
\q2 ar gwage-weligwar an-imakdaed. 
\b  
\qa He 
\q1  
\v 33 Bab-Jehová, Be-Igar-Mamaidgi be an-odurdake, 
\q2 an eba nanadii guoed. 
\q1  
\v 34 Be-Igar-Maidba-nanaegala, Be-Igar-Maid magar-itogega be an-imake. 
\q2 Geb gwage-ulubgi bela-belad eba an nanadii guoed. 
\q1  
\v 35 Be-Igar-Islidik-Mamaidba be an-iduge, 
\q2 ar agi an wergued amied. 
\q1  
\v 36 Unnila Be-Igar-Mamaidbarbi-binsaega be an-imake. 
\q2 Melle ibmar-baiganbina-surbinsa-itoged be an-imake. 
\q1  
\v 37 Melle ibmar-binsarmaladbina-sogega be an-imake. 
\q2 Be-Igar-Maidba-nanaega be an-imake. 
\q1  
\v 38 Igi be dule-be-dobee-nanadimaladga be ibmar imaksa, 
\q2 deyobi, an-be-mai-guedga be Ibmar-Imakoye-Sogsad, be imake. 
\q1  
\v 39 Mesagwar-imaklegedgi an dobe-itodiidgi be an-onoge, 
\q2 ar Be-Igar-Nabogedi, we, ibnuedid. 
\q1  
\v 40 Be-Igar-Islidik-Mamaidbina an nue-soged. 
\q2 Be-igar-innikii-imakedba dula-gudii be an-imake. 
\b  
\qa Vau 
\q1  
\v 41 Bab-Jehová, igi na be Sogsa-Gusa, 
\q2 deyob be-sabgued be anse oyoge, 
\q2 deyob dule-bendaked be anse oyoge. 
\q1  
\v 42 Deyobi, dule-isdar-an-dakmaladga an sogoed. 
\q2 Ar Be-Ibmar-Sogsadgi an bensulid. 
\q1  
\v 43 An-gwabinduku, ibmar-inniki-soged be imake. 
\q2 Ar Be-Igar-Mamaidgi an bensulid. 
\q1  
\v 44 Be-Igar-Mamaidba an degisadegu ibsadii guoed, 
\q2 Deyob degisadegu an imakoed. 
\q1  
\v 45 An bonisuli nanadii guoed, 
\q2 ar an Be-Igar-Islidik-Mamaid amisad. 
\q1  
\v 46 Be-Igar-Mamaidgi reymar-asabin an sunmakoed, 
\q2 gwen an bingeguosulid. 
\q1  
\v 47 Be-Igar-Islidik-Mamaidbina an nue-soged, 
\q2 an egi wergued. 
\q1  
\v 48 Be-Igar-Islidik-Mamaid an nue-sabedbali, an-argan an onakoed, 
\q2 Be-Igar-Maidgi an binsaoed. 
\b  
\qa Zain 
\q1  
\v 49 An-be-mai-guedga be Ibmar-Sogsa-Gusadi be ebinsao, 
\q2 a-Gayaburba-abdakagwar-gudiguega, be an-imaksad. 
\q1  
\v 50 An bukib-binsaedba-wile-itodiidgi, a-Gayaburba baisur-itogega an-imaked, 
\q2 Be-Ibmar-Sogedi, an-ogannodaed. 
\q1  
\v 51 Dule-san-dummarba-imakmalad angi nue-isdar sunmakdimalad, 
\q2 degi-inigwele, andi Be-Igargi bangudisulid. 
\q1  
\v 52 Bab-Jehová, be epenne Be-Igar-Nabosadi an ebinsaed. 
\q2 A-Igarmala, an-gwage-baisur-itogega imaked. 
\q1  
\v 53 Dule-isganamar Be-Igar-metemaladi, 
\q2 sae-itogega an-imaked. 
\q1  
\v 54 An we-napneggi sikwas-gudiidgi, 
\q2 Be-Igar-Mamaid, an-namakedga gusad. 
\q1  
\v 55 Bab-Jehová, mutikgusale, an be-ebinsaardaed. 
\q2 Be-Igar-Sogedba an nanabied. 
\q1  
\v 56 Be-Igar-Islidik-Mamaid-sogedba-nanadiguedi, angi siid, 
\q2 an imakedsegad. 
\b  
\qa Chet 
\q1  
\v 57 Bab-Jehová, bebi angadga gued, 
\q2 Be-Gayaburbaba-nanaoye an sogsad. 
\q1  
\v 58 Bela-bela gwagegi an be-amidiid. 
\q2 Be-Ibmar-Sogsadba ise-wile be an-dake. 
\q1  
\v 59 An-daedgi an binsaargua, 
\q2 Be-Igar-Mamaidba an gannar nanaded. 
\q1  
\v 60 Be-Igar-Islidik-Mamaid-sogedba nanaegala, 
\q2 an undar-binsadii gussulid. 
\q1  
\v 61 Dule-isganamar an-gaegala, an-ebirdimalad. 
\q2 Degi-inigwele, Be-Igar-Maidi an gwen-iessulid. 
\q1  
\v 62 Be-Igar-Inniki-Maid-nukad, an bega dog-nuedye-sogegala, 
\q2 nega-gabigwenbali an gwichiguardaed. 
\q1  
\v 63 Ani an, dulemar-be-dobekwaa-nanadimalad-e-aid. 
\q2 Ani an, Be-Igar-Islidik-Mamaidba-nanadimalad-e-aid. 
\q1  
\v 64 Bab-Jehová, ¡Be-Igar-Mamaidgi be an-odurdake! 
\q2 We-napneg-naidgi bela be-sabgued-nikadi oyolenaid. 
\b  
\qa Tet 
\q1  
\v 65 Bab-Jehová, bee be, Be-Ibmar-Sogsadbali, 
\q2 be nued an-nidii gusad. 
\q1  
\v 66 An Be-Igar-Islidik-Mamaidgi an bensulid. 
\q2 Agala, gatik-ibmar-wisgued be an-imake, 
\q2 ibmar-mag-itoged be an-imake. 
\q1  
\v 67 An sabsur-odurdakleged-iduale, an-itolegedba galagwensuli an gudii daed. 
\q2 Emigindi, Be-Gayaburba-Sogedba an nanadiid. 
\q1  
\v 68 Bab-Dummad, bedi dule-nuedid. 
\q2 Be, ibmar-nuegan-imakedid. 
\q2 ¡Be-Igar-Mamaidgi be an-odurdake! 
\q1  
\v 69 Dule-san-dummarba-imakmaladi angi isdar-sunmakmalad. 
\q2 Degi-inigwele, andi gwagegi bela-belad Be-Igar-Islidik-Mamaid-sogedba an nanaed. 
\q1  
\v 70 We-dulemar, gwage-dutusurmaladid. 
\q2 Andina, Be-Igar-Maidgi wergudiid. 
\q1  
\v 71 Bur-nueddo, an sabsur-odurdaklesgu. 
\q2 Abali, an Be-Igar-Mamaid durdaknonikid. 
\q1  
\v 72 Be-Igar-Maidi, olo-mili-milibalidba bur bule ibnuedid. 
\q2 Be-Igar-Maidi, mani-mili-milibalidba bur bule anga ibidar-nuedga gued. 
\b  
\qa Yod 
\q1  
\v 73 Bee be, we-napnegse an-barmialid, bee be, anga burba uksad. 
\q2 Be-Igar-Mamaid-durdakegala, nono-nued be anga udage. 
\q1  
\v 74 Dulemar-be-nug-ogannodimalad an-dakalile, weligwar-itodmaloed, 
\q2 ar an, Be-Gayaburbagi, bensuli gudiid. 
\q1  
\v 75 Bab-Jehová, an wisid, Be-Igar-Mamaidi innikigwadbiid. 
\q2 Degisoggu, nabiridba sabsur-be-an-odurdaksado. 
\q1  
\v 76 Be-sabguedi, an-gwage-baisur-itoge imaked. 
\q2 Ar Be-Anga-Sogsagusadba be imaksad. 
\q1  
\v 77 Be-wile-dule-dakedi, anse be oyodage. 
\q2 Dula-gudii be an-imakdage. 
\q2 Ar Be-Igala, weligwar an-imakedid. 
\q1  
\v 78 Dule-san-dummarba-imakmalad, obingegsalesun, 
\q2 ar binsarsunna an-ogakansadimalad. 
\q2 Andi Be-Igar-Islidik-Mamaidgi bur binsaoed. 
\q1  
\v 79 Dulemar-be-nug-ogannodimalad, gannar anbo-atogega be imaksun. 
\q2 Dulemar-Be-Igar-Mamaid-wismalad, gannar anbo-atogega be imaksun. 
\q1  
\v 80 An-gwage Be-Igar-Mamaidba innikii nanasun, 
\q2 adi, an melle bingeguegar. 
\b  
\qa Caf 
\q1  
\v 81 Bab-Jehováʼye, bela-belad be-an-bendaked an abdakdiid, 
\q2 Be-Ibmar-Sogsadgi an bensulid. 
\q1  
\v 82 Be Anga-Ibmar-Sogsad-abdakdiidbali, an-dala galakuded. 
\q2 An weyob soged: “¿Sana wede gwage-baisur-itogega be an-imaknonikoe?” 
\q1  
\v 83 Bato an seredgus-inigwele, wagar-bapigwargus-inigwele, 
\q2 amba Be-Igar-Mamaid gwen an iedisulid. 
\q1  
\v 84 ¿Bule napi an dula gudii guoe? 
\q2 ¿Sana be, dule-an-balegindimalad-sabsur-odurdakoe? 
\q1  
\v 85 Dule-san-dummarba-imakdimaladi, an-yardakega igar amismalad. 
\q2 Be-Igar-Sogedba-nanadisurmaladi, an-yardakega igar amismalad. 
\q1  
\v 86 Bela Be-Igar-Mamaidi innikigwadbiid. 
\q2 ¡Bab-Dummadye, be an-bendake! 
\q2 Binsarsunna an-balegindimalad. 
\q1  
\v 87 Napneggi an-oburgwednaga gusmalad. 
\q2 Degi-inigwele, andi Be-Igar-Mamaidgi gwen bangussulid. 
\q1  
\v 88 Be-sabed-dummarba-nikadbali, be anga burba-ogannosun. 
\q2 Be-Igar-Mamaid-sogedba an nanaoed. 
\b  
\qa Lámed 
\q1  
\v 89 Bab-Jehová, Be-Gayaburbadi degisadeguad, 
\q2 nibneggi, Be-Gayaburbadi gwen gwagmaisulid. 
\q1  
\v 90 Be-innikidaedi, degisadeguad. 
\q2 Napneg be nasiksad, innikigwadba nagusad. 
\q1  
\v 91 Be-Igar-Uksadbali, emi-iba-akale, we-ibmarmar amba bukwad. 
\q2 Bela we-ibmarmala be-sogedba ibmar-imakbukwad. 
\q1  
\v 92 Be-Igar-Maid, weligwar an-imaksasulina, 
\q2 bukib-binsaedba an bato bergusbinnenad. 
\q1  
\v 93 Bipisaale, Be-Igar-Mamaid an gwen iegosulid, 
\q2 ar we-igarbali, be an-san-burba dula imaksad. 
\q1  
\v 94 Bab-Jehováʼye, be an-bendake, 
\q2 andi, begadga-gued. 
\q2 Andi, Be-Igar-Islidik-Mamaid ulubse baramidiid. 
\q1  
\v 95 Dule-isganamar an-obelobigudimalad. 
\q2 Andi, Be-Igar-Mamaid-magar-itogega alamakdiid. 
\q1  
\v 96 Bela ibmarmar e-bergued-nika an dakdiid. 
\q2 Unnila, Be-Igar-Islidik-Mamaidbi gege bergued. 
\b  
\qa Mem 
\q1  
\v 97 ¡Be-Igar-Maidbina an nue soged! 
\q2 Bane-bane an egi binsadaed. 
\q1  
\v 98 Be-Igar-Mamaidi, an-isdarmaladbali bur bule binsaed-nika an-imaked. 
\q2 Ar Be-Igar angadga an imaksad. 
\q1  
\v 99 Bela an-odurdakmaladba bur bule an ibmar magar-itoged. 
\q2 Ar an Be-Igar-Mamaidgi binsadigu daed. 
\q1  
\v 100 Girmarba bur bule an ibmar magar-itoged. 
\q2 Ar an Be-Igar-Mamaid-sogedba nanadiid. 
\q1  
\v 101 Be-Gayaburba-Sogedba-nanaegala, 
\q2 bela igar-isganagi an bangusad. 
\q1  
\v 102 Be-Igar-Mamaidgi an bangussulid, 
\q2 ar bee be an-odurdaksad. 
\q1  
\v 103 Ibibayobi Be-Gayaburba anga ochii gue. 
\q2 Achanis-maedba bur bule anga ochii gued. 
\q1  
\v 104 Be-Igar-Mamaidbali, an binsaed-nuegan amidiid. 
\q2 A-ulale, bela gakan-igarmar an isdar daked. 
\b  
\qa Nun 
\q1  
\v 105 Be-Gayaburba gwallu-meegwadyobi an-iduedga gued. 
\q2 Neg-ibegwalebayobi anga igar oyoged.\fig Bab-gayaburba gwallu-meegwadyobi gued. (Salmo 119:105) |src="HK00151B.TIF" size="col" ref="Salmos 119:105" \fig* 
\q1  
\v 106 An bega ibmar-ise-sogar-sogsadi, an imakedsegad. 
\q2 Be-Igar-Mamaid-sogedba an nanadii guoed. 
\q1  
\v 107 Bab-Jehová, an bela-bela bato nue dummad-wilediid. 
\q2 ¡Be-Gayaburba-sogedba be an-ogannoge! 
\q1  
\v 108 Bab-Jehová, an bega ibmar-sogedi be abingasana gadin. 
\q2 Be-Igar-Mamaidgi be an-odurdake. 
\q1  
\v 109 Bonigan-abargi an-sandi gudiid, 
\q2 degi-inigwele, Be-Igar-Maiddi an iedisulid. 
\q1  
\v 110 Dule-isganamar an-yardakbimalad, 
\q2 degi-inigwele, Be-Igar-Mamaidgi andi bangudisulid. 
\q1  
\v 111 Be-Igar-Mamaidi, degisadegu angadga-guega an susad, 
\q2 ar an-gwage-weligwar imakdaed. 
\q1  
\v 112 Degisadegu, an-burgwedsega 
\q2 gwage-ulubgi Be-Igar-Mamaid-sogedba nanadioye an sogsad. 
\b  
\qa Sámec 
\q1  
\v 113 Dule-wagar-darbo-damaladi, an isdar daked. 
\q2 Be-Igar-Islidikiddi, an nue-sabed. 
\q1  
\v 114 Bab-Dummad, bedi an-odukuega gued, 
\q2 bedi an-sigu-abgaedibayobi anga gued, 
\q2 Be-Ibmar-Sogsadi, an edarbediid. 
\q1  
\v 115 “¡Dule-isganamar, be angi bangue! 
\q2 An-Bab-Dummad-Igar-Mamaidba an nanabied.” 
\q1  
\v 116 Be-Gayaburba-Maidbali, be an-ogannoge, agi an dula gudiguoed. 
\q2 An-ibmar-edarbediidgine, melle bingeguega be an-imake. 
\q1  
\v 117 Be an-bendake, adi, an bendaklegoed. 
\q2 Be-Igar-Mamaidgi, an weligwar itodiguoed. 
\q1  
\v 118 Dulemar-Be-Igar-Mamaidgi-nodimaladi, be isdar dakdaed. 
\q2 Ar gakansaedginbi binsadidamalad. 
\q1  
\v 119 Napneggi dule-isganamar-bukwadi, ibmar-isgana-milediidyob be daked. 
\q2 A-ulale, an Be-Igar-Mamaidbina nue-soged. 
\q1  
\v 120 An be-dobedbali, be-asabin an wawanmakgwichid, 
\q2 Be-Igar-Nabolemalad-dobee an itoged. 
\b  
\qa Ayin 
\q1  
\v 121 Igar-inniki-imaklemalad an imakdiid. 
\q2 Melle dule-mesagwar-an-imakdimaladga be an-urmako. 
\q1  
\v 122 An-be-mai-guedga, igar-nueganbi-guega be imako. 
\q2 Melle dule-san-dummarba-imakmaladi mesagwar-an-imakega be imako. 
\q1  
\v 123 Be an-abonogega, an be-abdakdiidba an-dala mommoleded. 
\q2 Be-Igar-Sogsad anga-guedi, an edarbediid. 
\q1  
\v 124 Sabed-dummarba be nikadbali, be-mai be sabguo. 
\q2 Be-Igar-Mamaid be an-odurdake. 
\q1  
\v 125 Andi be-mai gued. 
\q2 An Be-Igar-Mamaid-durdakega, Be-Igar-Mamaid mag-itoge be an-imake. 
\q1  
\v 126 Bab-Jehová, ar Be-Igar-Mamaidba nanasurmarsoggu, 
\q2 be-ibmar-imakbied be imaksunna. 
\q1  
\v 127 Bela ibmarmar-baiganba bur bule Be-Igar-Mamaid bur an sabed. 
\q2 Be-Igar-Mamaidbina olobali bur bule an bina soged. 
\q2 Olo-sunnadbali bur bule an bina itoged. 
\q1  
\v 128 A-ulale, Be-Igar-Mamaidbali an nanaed. 
\q2 Bela Be-Igar ibmar-baiganbali nueganbi an daked. 
\q2 Bela gakan-igarmardi an isdar daked. 
\b  
\qa Pe 
\q1  
\v 129 Be-Igar-Mamaidi doggus-ibnuedid. 
\q2 A-ulale, an e-sogedba nanadiid. 
\q1  
\v 130 Be-Gayaburbagi sunmakledele, magar ibmar-itogega anmar-imaked. 
\q2 Dule-ibmar-wissulid magar-ibmar-itogega imakbalid. 
\q1  
\v 131 An bela-bela Be-Igar-Mamaid-durdakbiedbali, 
\q2 Be-Gayaburbabina an nue soged. 
\q1  
\v 132 Bab-Dummad, wile-be-an-dake. 
\q2 Igi be gusgu dule-be-nug-odummodimaladi wile be dakdae, 
\q2 deyobi, be an-dakmoga. 
\q1  
\v 133 Be-Igar-Sogsadba-nanaega be an-imake. 
\q2 Melle igar-isgana angi obinega be imake. 
\q1  
\v 134 Dule-ibmar-sabsur-imakedgi be an-ollor-imake, 
\q2 ar an Be-Igar-Mamaidba an nanabied. 
\q1  
\v 135 Be-ise-nued-binsaedi be-maiga be oyoge. 
\q2 ¡Be-Igar-Mamaidgi be an-odurdake! 
\q1  
\v 136 Be-Igar-Mamaidba bar nanasurgusmalad-ulale, 
\q2 an-ibyanis suurmakemaid. 
\b  
\qa Tsade 
\q1  
\v 137 Bab-Jehová, bedi dule-innikigwadid, 
\q2 innikigwadba bedi igarmar nabogedid. 
\q1  
\v 138 Be-Igar-Mamaid-be-uksadi, bela innikigwadbiid. 
\q2 Be-Igar-Mamaidgi bengulesulid. 
\q1  
\v 139 An-isdarmalad Be-Gayaburba-Maid-iedmaladbali, 
\q2 an bela-bela nue sae-itoged. 
\q1  
\v 140 Be-Gayaburba isedar-swilidikidid, 
\q2 a-ulale, an Be-Gayaburba nue-sabed. 
\q1  
\v 141 Andi san-bipi-imakdiidbali, ibgwensur daklediid, 
\q2 degi-inigwele, Be-Igar-Mamaidi, an iedisulid. 
\q1  
\v 142 Be Igar-Inniki-Imakedi, degisadegu innikigwadbiid. 
\q2 Be-Igar-Mamaidi, napiragwadid. 
\q1  
\v 143 Surbinsa an itononikile, Be-Igar-Mamaiddi weligwar an-imaked. 
\q2 Suli-suli an itononikile, Be-Igar-Mamaiddi weligwar an-imaked. 
\q1  
\v 144 Be-Igar-Mamaiddi, gusgu innikigwadbiid. 
\q2 A-igarba nabir gudiguega, a-igar-magar-itoge be an-imake. 
\b  
\qa Cof 
\q1  
\v 145 Bab-Jehová, bela-bela gwagegine an bese goled. Be an-abinsae. 
\q2 Be-Igar-Mamaid-sogedba an nanabied. 
\q1  
\v 146 An-bendakye an bese goled. 
\q2 Ar Be-Igar-Mesisad-sogedba an nanabied. 
\q1  
\v 147 Bese bendakleged egisegala, wakudaryalaba an gwisguardaed. 
\q2 An Be-Gayaburbagi bensulid. 
\q1  
\v 148 Be-Igar-Mamaidgi-binsaedba, 
\q2 mutikidbali, an gabdasulid. 
\q1  
\v 149 Be dule-wile-nue-dakdasoggu, be an-itoge. 
\q2 Bab-Jehová, Be-Igar-Innikigwadba be an-ogannoge. 
\q1  
\v 150 Dule-isganamar-an-balegindimaladi, an-walikgudanikid. 
\q2 Amar, Be-Igar-Mamaidgi bangus gudimalad. 
\q1  
\v 151 Bab-Jehová, be an-walikaa gudiid. 
\q2 Be-Igar-Mamaidi, belagwable napiragwadbiid. 
\q1  
\v 152 Dikasurgus, an Be-Igar-Mamaid wisi gudiid, 
\q2 ar gusgu be a-Igar omesisad. 
\b  
\qa Resh 
\q1  
\v 153 An-wile-itodiidi be dake, 
\q2 bonigangi be an-ollor-imake, 
\q2 ar an Be-Igar-Mamaidi gwen an iedisulid. 
\q1  
\v 154 Be an-irwa gwisgue, be an-bendake. 
\q2 Be-Gayaburba-sogsadba be an-ogannoge. 
\q1  
\v 155 Dule-isganamargi, burbar-bendakleged-igar dikasur naid, 
\q2 ar Be-Igar-Mamaidi gwen-amisurmalad. 
\q1  
\v 156 Bab-Jehová, be-dule-wiledakedi dummarbaa gued. 
\q2 Be Igar-Nabomaidba, burba-dulad be anga uke. 
\q1  
\v 157 Dule-an-balegindimalad bukidarad, an-isdardakmalad bukidarad, 
\q2 degi-inigwele, Be-Igar-Mamaidgi an bangudisulid. 
\q1  
\v 158 An dule-yardakdimalad-dakalile, an sae-dakdaed, 
\q2 ar Be-Gayaburba-sogedba gwen nanadisurmalad. 
\q1  
\v 159 ¡Bab-Jehová, be dake! Ibiyobi Be-Igar-Mamaid an sabe. 
\q2 Be sabgued-dummarba-nikadbali, burba-dulad wis be anga uke. 
\q1  
\v 160 Bela Be-Gayaburba-Mamaidi napiragwadid, 
\q2 Be-Igar-Maidi bela innikigwadba degisadegu maid. 
\b  
\qa Sin 
\q1  
\v 161 Ar binsarsunna dule-gandikmaladi an-balegindiid, 
\q2 an-gwage-ulubgine an Be-Gayaburba-dobekwaa nanadiid. 
\q1  
\v 162 Be-Gayaburbagi an weligwar-itoged, 
\q2 dule-ibmar-nuegan-gargerbamalad-amisadyobi, an egi wergued. 
\q1  
\v 163 Gakan-igar an sae-daked, an nue-isdarsunna-dakdaed. 
\q2 Degi-inigwele, Be-Igar-Maiddi an nue-sabed. 
\q1  
\v 164 Be-Igarmar nue-napiragwad-guedbali, 
\q2 an bali-bali be-nug odummoged. 
\q1  
\v 165 Dule-Be-Igar-Mamaid-sabgudimaladi, gwagegi bogidik itodimalad. 
\q2 Wemar igar-isganaba gege selemalad. 
\q1  
\v 166 Bab-Jehováʼye, wis be an-bendakena gadin. 
\q2 Ar Be-Igar-Mamaidbali an ibmar imakdiid. 
\q1  
\v 167 Bela-belad an Be-Igar-Mamaid-sogedba nanadiid, 
\q2 ar an Be-Igar nue-sabed. 
\q1  
\v 168 Bela Be-Igarmar-Mamaidba an nanadiid, 
\q2 ar bela be an-ibmar-saedi wisid. 
\b  
\qa Tau 
\q1  
\v 169 Bab-Jehováʼye, gandikidba an bese-goledi, bese warmaksun. 
\q2 Be-Gayaburba-Maidba magar-ibmar-itogega be an-imake. 
\q1  
\v 170 An bese ise-wilesakwaa-goledi bese warmaksun. 
\q2 Be-Ibmar-Sogsadba be an-bendake. 
\q1  
\v 171 Be-Igarmar-Mamaidgi be an-odurdaksad. 
\q2 A-ulale, an-gwabinduku be-nug ogannoged. 
\q1  
\v 172 Ar bela Be-Igar-Mamaid innikigwadbisoggu, 
\q2 Be-Ibmar-Sogsadgi an namaked. 
\q1  
\v 173 Bab-Jehováʼye, Be-Igar-Mamaidi angadga an imaksasoggu, 
\q2 gwae be an-bendakdage. 
\q1  
\v 174 Bab-Jehováʼye, wis be an-bendaked an be-abeged. 
\q2 Be-Igar-Maidi weligwar an-imakedid. 
\q1  
\v 175 Be-nug-odummogega, dula-gudii be an-imake, 
\q2 Be-Igar-Nabolemaladi, an-bendakega gusun. 
\q1  
\v 176 Sibad-wawaad-yoggus-gudibayobi, an gudiid. 
\q2 An-be-maiga-gudiid be amidage, 
\q2 ar Be-Igar-Mamaidi an gwen iedisulid. 
\c 120  
\s1 Dule-gakansilimargi e-ollor-imakega Babse-goled 
\d We-namaked, Jerusalénʼse-nakwe-nadapir, namakleged. 
\q1  
\v 1 Bab-Jehováʼse an surbinsa-itogedgi gochad, 
\q2 Bab-Jehová an-abin-imaksad. 
\q1  
\v 2 Bab-Jehová, dule-gakansilimargi be an-ollorsae, 
\q2 dule-emar-yardakmaladgi be an-ollorsae. 
\b  
\q1  
\v 3 Dule-yardakmalad, ¡be dule-wilesmar! 
\q2 ¿Ar ibu bemarga uklegoe? 
\q2 ¿Ar ibu egi bemar nikuoe? 
\q1  
\v 4 Bila-onomalad-e-sigu-swiswidikid-ginnitibi-aramakmaidi, 
\q2 begi mioed. 
\b  
\q1  
\v 5 ¡Andi, duledar-wiles! Andi dule-ibmar-wissurmalad-abargi gudiid. 
\q2 An Mesec-neggweburgi-maiyobi gudiid, 
\q2 an Cedar-dulemar-abargi-maiyobi gudiid. 
\q1  
\v 6 Dule-neg-bogidikid-abesurmalad-abargi 
\q2 bato an dikasurgus maid. 
\q1  
\v 7 Andi, dule-belagwadaedid. 
\q2 Ar an neg-bogidikid-nasikedgi sunmakele, emardi bila-onomaladgi sunmakmalad. 
\c 121  
\s1 Bab-Jehová be-edarbedid 
\d We-namaked, Jerusalénʼse-nakwe-nadapir, namakleged. 
\q1  
\v 1 Yalagansik an atakdele, an egisdaed, 
\q2 ¿bia an-bendakleged danikoe? 
\q1  
\v 2 Bab-Jehováʼgi an-bendakleged danikid. 
\q2 Bab-Jehová-napneg-nasiksadgi, an-bendakleged danikid 
\q2 Bab-Jehová-nibneg-nasiksadgi, an-bendakleged danikid. 
\b  
\q1  
\v 3 Bab-Jehová aimukuega be-imakosulid, 
\q2 Bab-Dummad-be-edarbediid gwen gabosulid. 
\q1  
\v 4 Ar nue-napiragwad, 
\q2 Israel-dulemar-edarbed gwen gabosulid. 
\b  
\q1  
\v 5 Bab-Jehová be-edarbedid, 
\q2 Bab-Jehová be-dikarba gudiguad. 
\q1  
\v 6 Ibgine, dad-ibeler be-oakalogosulid, 
\q2 mutikidba, nii gwen be-oakalogosurbalid. 
\b  
\q1  
\v 7 Bab-Jehová bonigan-bese-warmakega imakosulid, 
\q2 Bab-Jehová be-edarboed. 
\q1  
\v 8 Bia be nadesogele, 
\q2 Bab-Jehová, degisadegu beba gudii guoed. 
\c 122  
\s1 Jerusalén-neggwebur-bogidik-sigega, Bab-Dummadse gorlenaid 
\d We-namaked, Jerusalénʼse-nakwe-nadapir, namakleged. 
\q1  
\v 1 Dule anga sogdemalale: “¡Bab-Jehová-e-negse anmar namarye!” 
\q2 An weligwar-itoddaed. 
\q1  
\v 2 Jerusalén-neggwebur, 
\q2 be-neg-e-yawagak-asabin bato anmar gwichid. 
\b  
\q1  
\v 3 Jerusalén neggwebur-gandikidid, 
\q2 be-soblesadi, nuekwaa soblesad. 
\q2 Begi nabir ambikumalaga be soblesad. 
\q1  
\v 4 Jerusalén-neggwebursega dadgan-warambe-gakabogwad-e-wagan (12) Bab-Jehová-e-nug-odummogegala, ese nakwemai damalad. 
\q2 Igi Bab-Jehová Israel-dulemarga igar-uksagusa, deyobi, gunonikid. 
\b  
\q1  
\v 5 Jerusalén-neggweburgine igar-naboged-e-ganmar siid, 
\q2 agi David-e-wagan-igar-naboged-e-ganmar siid. 
\b  
\q1  
\v 6 Jerusalén-neggweburga anmar neg-bogidikid ega egise. 
\q2 Be-sabgudimaladga ibmar nasgumaigusun. 
\q1  
\v 7 Be-galu-matusulidga, neg-bogidik nagusun. 
\q2 Be-neg-dummagan-bukwadga, neg-bogidik nagusun. 
\q1  
\v 8 An-gwenadgan-sabed-nuggi, an-aimar-sabed-nuggi, an soged: 
\q2 “¡Neg bogidikid bega gusun!” 
\q1  
\v 9 Anmar-Bab-Dummad-Jehová-e-neg-sabedba, 
\q2 bega nueganbi-ibmar-guega an imakoed. 
\c 123  
\s1 Babse-goled e-wiledakega 
\d We-namaked, Jerusalénʼse-nakwe-nadapir, namakleged. 
\q1  
\v 1 Bab-Jehová an besik ataked, 
\q2 bedi nibneggi neg-dakmaid. 
\q1  
\v 2 Ar igi maigan ibmarbina-sogedba e-dummagangi gudidimala, 
\q2 ar igi omegan-maiga-gudidimalad ibmarbina-sogedba e-dummad-omegi gudidimala, 
\q1 deyobi, anmar, anmar-Bab-Dummad-Jehováʼgi gudidimogad, 
\q2 anmar-wiledaked anmar abediid. 
\b  
\q1  
\v 3 Bab-Jehová, be wile-anmar-dake. Be wile-anmar-dake. 
\q2 Dulemar ibgwensur-anmar-imaked, anmar budar-itogusmalad. 
\q1  
\v 4 Dule-mani-ibgan anmargi-dodomalad, anmar budar-itogusmalad. 
\q2 Dulemar-san-dummarba-imakdimalad, ibgwensur-anmar-imakmalad, anmar budar-itogusmalad. 
\c 124  
\s1 E-isdarmaladgi-ollorgusadba, Bab-Dummad-nug ogannoged 
\d We-namaked, Jerusalénʼse-nakwe-nadapir-namakleged. David narmaksad. 
\q1  
\v 1 Israel-dulemar, be sogmar, 
\q2 Bab-Jehová anmar-bendaksasulina, igi anmar guoendibe. 
\q1  
\v 2 Bab-Jehová anmar-bendaksasulina, 
\q2 bela dulemar, anmargi gwichigudmargu, 
\q1  
\v 3 anmargi uludgu, 
\q2 dula anmar-dosanad. 
\q1  
\v 4 Diwar-noeyobi anmar ese berguoenad, 
\q2 dii-nollosuliyob anmargi nasoenad. 
\q1  
\v 5 Degisoggu, dii-nollosurmaladyobi 
\q2 anmar-sedoenad. 
\b  
\q1  
\v 6 Bab-Jehová-nug odummomarsun, 
\q2 we-dule-isganamarse berguega anmar-imaksasulid. 
\q1  
\v 7 Nuuyobi, anmar wakichamalad. 
\q2 Dule nuu-gaega-galu-sobmaladyobidgi, anmar wakichamalad. 
\q2 E-galu-ayarmaksa-siiyobidgi, anmar wakichamalad. 
\q1  
\v 8 Bab-Jehová-napneg-obinnisadid-nuggi, Bab-Dummad-nibneg-obinnisadid-nuggi, 
\q2 anmar-bendakleged danikid. 
\c 125  
\s1 Bab-Dummad e-dulemargi nakulediid 
\d We-namaked, Jerusalénʼse-nakwe-nadapir, namakleged. 
\q1  
\v 1 Dulemar Bab-Jehováʼgi-bensurmalad Sión-yalayobi gued. 
\q2 Sión-yala degisadegu sii guoed, bipisaale ainirosulid. 
\q1  
\v 2 Igi yarmar Jerusalén-ebirbukwananae, 
\q2 deyobi, Bab-Jehová e-dulemar-edarbedii degisadegu gumogoed.\fig Yarmar Jerusalén-ebirbukwananaed. (Salmo 125:2) |src="LB00352B.TIF" size="col" ref="Salmos 125:2" \fig* 
\q1  
\v 3 Dulemar-isgana, dule-nueganga degisadegu negsemai guosulid, 
\q2 adi, melle dule-nuegan ibmar-isganamarse binsaed galemalagar. 
\b  
\q1  
\v 4 Bab-Jehováʼye, dule-nueganga ibmar-nuegan be imake. 
\q2 Dule-gwage-swilidikmaladga ibmar-nuegan be imake. 
\q1  
\v 5 Bab-Jehováʼye, dule igar-isganaba-naddamaladdi, 
\q2 dule-isganamarba bergued be imakmoga. 
\b  
\q1 ¡Israel-yargi neg-bogidikid nai be imaksun! 
\c 126  
\s1 Neg-nugunonikidba weligwaled nagunonikid 
\d We-namaked, Jerusalénʼse-nakwe-nadapir, namakleged. 
\q1  
\v 1 Bab-Jehová dule-galesbukwamalad Sión-yarse gannar senonigusgua, 
\q2 anmar gabdakmaiye bismalanad. 
\q1  
\v 2 Anmar nue-alledii gusmalad. 
\q2 Anmar weligwaledba onamakde gusmarbalid. 
\q1 Dule-Bab-wissurmaladi sunmakdemalad: 
\q2 “Bab-Jehová we-dulemarga ibmar-dummagan-nuegan imaksaye.” 
\q1  
\v 3 Napiragwa, Bab-Jehová anmarga ibmar-dummagan-nuegan imaksad, 
\q2 agala, anmar weligwar itoged. 
\b  
\q1  
\v 4 Emisgine, Bab-Jehová, anmar-dulemar-galesbukwad gannar be sedage. 
\q2 Igi be nega-dulesulidganba yar-Neguevʼye-nugad-e-dianmar gannar-dii-nikuega be imakdae, 
\q2 deyobi, be anmar-dulemar-galesbukwad, gannar be sedage. 
\q1  
\v 5 Dule boed-abalagi ibmar-gwag-digedi, 
\q2 weligwaledgi e-sanmardi weed. 
\q1  
\v 6 Ibmar-gwag-digegala, boed-abalagi alamaknai-damalad, 
\q2 ibmar-sanmar-wesmalale, weligwaledba namakdaniki damalad. 
\c 127  
\s1 Bab-Jehováʼgi ibmar-nasguleged danikid 
\d Jerusalénʼse-nakwe-nadapir-namaklegega, Salomón, we-namaked narmaksad. 
\q1  
\v 1 Ar Bab-Jehová neg-sobsulile, binsarsunna neg-sobmalad arbananaid. 
\q2 Ar Bab-Jehová neggweburgi nakulesulile, binsarsunna neggweburgi-nakulemalad nakulebukmalad. 
\q1  
\v 2 Bemar mas-gunnega binsarsunna arbaed-dummad-imakega, 
\q2 bolegoedba gwisgumalad, mutiksaila be gabmalad. 
\q1 Ar Bab-Jehová, e-dule-sabeddi 
\q2 bukib-binsasuli nue-gabdii imaked. 
\b  
\q1  
\v 3 Anmar mimmigan-nikadi, Bab-Jehová anmarga uksad, 
\q2 Bab-Jehová anmargi doggus-nued-binsaedbali, mimmigan anmarga gwalulemaid. 
\q1  
\v 4 Igi-dule bila-onogedgi sigu-bukidar-ganikile, dobsuli-itoge, 
\q2 debayobi, sapingwagwadgi dule mimmigan-bukidar-nikale, dobsuli gued. 
\q1  
\v 5 Dule, mimmigan-bukidar-nikale, we-dulegi, nued binsalesad. 
\q2 We-dule, dulemar-abargi na e-isdarmaladbo abin-abin-imakalile, e-isdarmalad-abin suli-suli itogosulid. 
\c 128  
\s1 Bab-Jehová-dobee-nanadimaladgi nued-binsalesad 
\d We-namaked, Jerusalénʼse-nakwe-nadapir, namakleged. 
\q1  
\v 1 Dule-Bab-Jehová-dobee-nanadimalad, we-dulegi nued binsalesad. 
\q2 Bab-Dummad-igarba-nanadimalad, we-dulegi nued binsalesad. 
\q1  
\v 2 Be-arbadiidgi na be mas gunnoed, 
\q2 dule-weligwaledga be guoed, 
\q2 nueganbi bega igarmar naoed. 
\q1  
\v 3 Be-neguyagi, be-ome, uva-dub-san-nikuedyobi guoed. 
\q2 Olivo-sapi-e-muugan, e-saila-ebilideyobi, be-mimmigan be-mese-ebilidmogoed. 
\q1  
\v 4 Weyob, dule-Bab-Jehová-dobee-nanadiidgi 
\q2 ise-nued binsalegoed. 
\b  
\q1  
\v 5 Bab-Jehová, Sión-yar-akale, begi ise-nued-binsasun. 
\q2 Be dula-gudiidgi, bane-bane Jerusalén-nasgumaid-dakdii be gusun. 
\q1  
\v 6 Be-wagan-dakedse be dula-gudii gusun. 
\b  
\q1 ¡Israel-yargi neg-bogidikid nagusun! 
\c 129  
\s1 Bab-Dummadse egised, Sión-isdarmalad obeloye 
\d We-namaked, Jerusalénʼse-nakwe-nadapir, namakleged. 
\q1  
\v 1 Sapingwagwad-akar, nue-an-wiodimalad, 
\q2 degi-inigwele, gwen an-oakalossurgusmalad. 
\q2 Israel-dulemar weyob be sogmarmosun. 
\q1  
\v 2 Sapingwagwad-akar, nue an-wiodimalad, 
\q2 degi-inigwele, gwen an-oakalossurgusmalad. 
\q1  
\v 3 An-isdarmalad yargangi an-bibyosmalad, yargangi an-naibi-imaksamalad. 
\q2 Igi dule napa-akwie, debayobi, an-naibi-imaksad. 
\q1  
\v 4 Ar Bab-Jehováʼdi ibmar-napiragwad imaksoggu, 
\q2 an-isdarmaladse-wilediidgi an-onosad. 
\b  
\q1  
\v 5 Bela Sión-yar-isdar-dakmalad, sabsur-mesagwar-gusadba 
\q2 gannar sorsik be oduurmake. 
\q1  
\v 6 Wemala, uas-birgi gagan-ainiedyobi gumalad. 
\q2 Ainidagogu, baisursunna dingued. 
\q1  
\v 7 Dule-ibmar-gwag-wemalad we-gagan sikosurmalad, 
\q2 weosurmarbalid. 
\q1  
\v 8 Dulemar ibmar-gwag-wenanaid begi nasmalogu, bega sogosurmalad: “Bab-Jehová begi nued-binsaena gadin.” 
\q2 Ega be sogosurmarmogad: “Bab-Jehová begi nued-binsamogana gadin.” 
\c 130  
\s1 Bab-Jehová Israel-dulemar-bendaknonikoed 
\d We-namaked, Jerusalénʼse-nakwe-nadapir, namakleged. 
\q1  
\v 1 Bab-Jehováʼye, an bese wilesagwar goled. 
\q2 Ulubgi nunmaked-dummad-itonaidgi an bese goled. 
\q1  
\v 2 Bab-Jehováʼye, be an-itoge, 
\q2 an-sabsuli-gornaid wis be itoge, 
\q2 ise-wilesagwar an bese gornaid. 
\b  
\q1  
\v 3 Bab-Jehová, be dule-e-isguedgi atakdele, 
\q2 ¿doa be-asabin sogosunna, an isgudisurye? 
\q1  
\v 4 Ar bedi isgussuliyob dule-daknonidaed, 
\q2 degisoggu, dobekwaa be-asabinni nanamalargebed. 
\b  
\q1  
\v 5 Bab-Jehová an-bendakega an edarbed, 
\q2 an-gwagegi an Bab-Jehová edarbed. 
\q2 Bab-Jehová-ibmar-imakoye-sogsadgi an bensulid. 
\q1  
\v 6 An Bab-Jehová edarbed. 
\q2 Igi dule-mutik-nakuleged neg-ibgued-edarbesidae, 
\q2 aba bur bule an Bab-Jehová edarbed. 
\q1  
\v 7 Deyobi, Israel-dulemar, 
\q2 Bab-Jehová be edarbemala. 
\b  
\q1 Ar bela-bela Bab-Jehová anmar-sabgumaid, 
\q2 bela isguedgi emar-ollor-imakbalid. 
\q1  
\v 8 Bab-Dummad-sunnagwad isguedgi 
\q2 Israel-dulemar-ollor-imaknonikoed. 
\c 131  
\s1 Burwiganayob Bab-Dummadgi bensulid 
\d We-namaked, Jerusalénʼse-nakwe-nadapir, namakleged. David we-namaked narmaksad. 
\q1  
\v 1 Bab-Jehová, andi na san-dummarba imaksulid, 
\q2 andi, dulemar-ibgwensur daksurbalid, 
\q1 andi, nug-dummarba imakdisulid, 
\q2 andi, ibmar-gegerdaklemalad-dummagan imakdisurbalid. 
\q1  
\v 2 Andi bur, igi goe mam-nusale e-nan-nukugi-bogidik megisdae, 
\q2 debayobi, an bogidik megisad, an yakirgus-megisad. 
\q2 ¡Andi goe-mam-nusar-bogidik-megisdaedyob gued! 
\b  
\q1  
\v 3 Israel-dulemar, Bab-Jehováʼgi emi-ibad-akale, degisadegu bensuli be gumala. 
\c 132  
\s1 Bab-Dummad Davidʼga ibmar-imakoye sogsad 
\d We-namaked, Jerusalénʼse-nakwe-nadapir, namakleged. 
\q1  
\v 1 Bab-Jehová, David be ebinsao, 
\q2 e-bukib-binsaedba-wile-itoged bela be ebinsao. 
\q1  
\v 2 Bab-Jehová, David bega-ibmar-ise-sogar-imaksad be ebinsae, 
\q2 Jacob-e-Bab-Dummad-Bur-Birigined bega ibmar-imakoye-sogsad be ebinsae, 
\q2 deun, David weyob sogsad: 
\q1  
\v 3 “An-negse an nag-obiosulid, 
\q2 bipisaale an gasgi obunnogosulid, 
\q1  
\v 4 gabemai an saosulid, 
\q2 wis-ibya-muruu an imakosulid. 
\q1  
\v 5 Bab-Jehováʼga-neg-amiedse, an deyob guoed. 
\q2 Jacob-wagan-e-Bab-Dummadga-neg-amiedse, an deyob guoed.” 
\b  
\q1  
\v 6 Anmar Efrata-neggweburgi-gudigu, Bab-Dummad-Dulemarbo-Igar-Mesisad-Ulugi dulemar-sunmake an itosmalad. 
\q2 Geb anmar Quiriat-Yearimʼgi Ulu-amismalad. 
\q1  
\v 7 Geb anmar sogdemalad: “Anmar Babse-goled-negse namar, 
\q2 e-asabin sindigale anmar signamar.” 
\b  
\q1  
\v 8 Bab-Jehová, be-obunnoged-negse be dage, 
\q2 be-Ulu-gandikidmala be asega dage. 
\q1  
\v 9 Be-dule-irwa-bese-gormalad, e-mor-yomalayobi, igar-innikigwad imakmar. 
\q2 Bega-innikigwadba-nanadimalad, weligwaledba namakmar. 
\q1  
\v 10 Be, be-mai-David-sabedbali, 
\q2 be-nuggi-nugsalegaled, melle wagar-biriar be dako. 
\b  
\q1  
\v 11 Bab-Jehová Davidʼga ibmar-ise-sogar-sogsa-gusadi, bar osulogosulid. 
\q2 Weyob ega sogsad: “Be-wagan-gwensak beyob reyga an omesoye. 
\q1  
\v 12 An bemarbo-igar-mesisad-sogedba be-wagan nanaele, an-igar-mamaidgi-an-e-odurdakoedba nanaele, 
\q2 e-mimmigan reyga degibi megmarmogoed.” 
\b  
\q1  
\v 13 Ar Bab-Jehová, Sión-yala-nug-imaksad, 
\q2 egi-megega abesad. 
\q1  
\v 14 Weyob sogsad: “We, an-obunnoged-negga degisadegu gudii guoed. 
\q2 Wegi an-ologana an sioed, ar an deyob abeged. 
\q1  
\v 15 E-mas gatik-obinebaka-merguega an imakoed, 
\q2 e-dule-wilegana masgi an oimmogoed. 
\q1  
\v 16 Amba deyob, e-dule-irwa-Bab-Dummadse-gormaladga bendakleged-mola an ega yooed, 
\q2 e-dule-nuegan, weligwaledba namakmaloed. 
\b  
\q1  
\v 17 ”Wegine, David-e-gangued-gannar-nikuega an imakoed. 
\q2 An-nuggi-nugsalegaled gwallu-meegwadyob negsemai-guega an imakoed. 
\q1  
\v 18 E-isdarmalad, binged-dummad-nikuega an imakoed. 
\q2 Davidʼdina e-ologurgin-dakarmakaled yooed.” 
\c 133  
\s1 Gwenatigwar-nanamalad 
\d We-namaked, Jerusalénʼse-nakwe-nadapir, namakleged. David we-namaked narmaksad. 
\q1  
\v 1 ¡Ibibayobi, gwenatigwale-ambikued nuedi! 
\q2 Ibibayobi, gwenatigwale-bulakwa-ambikued yeer-itolege. 
\q1  
\v 2 Olivo-gwallu-nuedyobi gued, 
\q2 Aarón-nonogi eolesale, e-sigase aryoddaed, 
\q2 geb e-mor-naga-dukuse aryoddaed. 
\q1  
\v 3 Hermón-yalagi-dii-bomieyobi gued. 
\q2 We-dii Sión-yalase bomied. 
\q1 Bab-Jehová weyob dulemar-gwenatigwale-bukwadgi, nued binsadaed, 
\q2 suitii we-napneggi-gudii imaked. 
\c 134  
\s1 Bab-Dummadse-goled-neggi-arbamaladga sunmaklenaid 
\d We-namaked, Jerusalénʼse-nakwe-nadapir, namakleged. 
\q1  
\v 1 Bab-Jehová-e-nug bela bemar odummomar, 
\q2 Bab-Jehováʼga-arbadimalad, Bab-Jehová-nug be odummomar. 
\q2 Bemar mutikidba Bab-Jehová-neggi-bukwamalad, bemar Bab-Jehová-e-nug be odummomar. 
\q1  
\v 2 Bab-Dummadse-golesokalile, Bab-Dummadse-goled-negsik be-argan onakmar, 
\q2 Bab-Jehová-e-nug odummomar. 
\b  
\q1  
\v 3 Bab-Jehová-napneg-nasiksad, Bab-Jehová-nibneg-nasiksad. 
\q2 Sión-yar-akale, begi nued binsamarsun. 
\c 135  
\s1 Bab-Dummad-e-ibmar-dummagan-imaksad 
\q1  
\v 1 ¡Aleluya! ¡Bab-Jehová-nug odummolesun! 
\b  
\q1 ¡Bab-Jehová-e-nug odummomala! 
\q2 Bab-Jehová-e-maimar, Bab-Jehová-nug odummomala. 
\q1  
\v 2 Bab-Jehová-e-neggi-gudidimalad, ¡Bab-Jehová-e-nug odummomala! 
\q2 Anmar-Bab-Dummad-neg-imbagi-gudidimalad, Bab-Jehová-nug odummomala. 
\q1  
\v 3 Bab-Jehová-nug odummomala, 
\q2 ar Bab-Jehováʼdi, dule-nuedid. 
\q1 E-nuggi-namaklegedgi namakmala, 
\q2 ar Bab-Jehováʼdi nued-binsaedgi dulemar-bendakedid. 
\q1  
\v 4 Ar Bab-Jehová Jacob-wagan-egadga-guega susad. 
\q2 Israel-dulemar na egadga imaksad. 
\b  
\q1  
\v 5 Nue an wisid, Bab-Jehová, dule-dummadid. 
\q2 Ibmar-bab-dummadyob-imaklemaladba anmar-Bab-Dummad bur bule dule-dummadid. 
\q1  
\v 6 Bab-Jehová bela nibneggi, napneggi, muu-billigangi, degi, muu-billigan-wila-dummagangi 
\q2 e-ibmar-abeged imaked. 
\q1  
\v 7 Bab-Jehová neg-oagnakwiardaed, 
\q2 dii-owiegala mar-odakarmakardaed, 
\q2 burwa e-galugi-bukwadgi barmiardaed. 
\b  
\q1  
\v 8 Bab-Dummad Egipto-dulemar-e-machi-sailaginmalad oburgwisadid. 
\q2 Dulemarse-bakale, ibmar-durganse-bakale, oburgwisadid. 
\q1  
\v 9 Egipto-dulemar, Bab-Dummad be-abargi Faraónʼga, bela e-maimarga oyosad, 
\q2 ibmar-wilubgan-dummagan, ibmar-dakledisurmalad oyosad. 
\q1  
\v 10 Bab-Jehová dulemar-yar-baid-baidgi-bukwad bukidar obelosad. 
\q2 We-reymar-gandik-mamaid-oburgwisbalid: 
\q1  
\v 11 Amorreo-e-rey-Sehónʼye-nugad, 
\q2 Basán-e-rey-Ogʼye-nugad, 
\q2 bela reymar-Canaán-yargi-mamaid obelosad. 
\q1  
\v 12 Bab-Dummad we-reymar-e-yarmar mimisad, 
\q2 e-Israel-dulamarga mimisad. 
\b  
\q1  
\v 13 Bab-Jehová, be-nug degisadeguad. 
\q2 Bab-Jehová, dulemar degisadegu be-ebinsadii gumaloed. 
\q1  
\v 14 Bab-Jehová na e-dulamarga igar nabogoed, 
\q2 e-maimar-wiledakoed. 
\b  
\q1  
\v 15 Dulemar-yar-baid-baidgi-bukwamalad na e-bab-dummadyob-ibmar-imakbukwadi, orgi sobaled, manigi sobaled. 
\q2 Dulemar na e-argangi sobsa nanaed. 
\q1  
\v 16 We-ibmarmar gaya-nikamalanad, 
\q2 degite, geg sunmakmalad. 
\q1 Ibya-nikamalanad, 
\q2 degite, ibmar-daksurmalad. 
\q1  
\v 17 Uaya-nikamalanad, 
\q2 degite, ibmar-itosurmalad, 
\q2 deginbali, bunnosurmarbalid. 
\q1  
\v 18 E-sobmalad, deyob gumarmogad, 
\q2 bela a-ibmargi-bengusurmalad deyob gumarmogad. 
\b  
\q1  
\v 19 Israel-dulemar, ¡Bab-Jehová-nug odummomala! 
\q2 Aarón-wagan, ¡Bab-Jehová-nug odummomala! 
\q1  
\v 20 Leví-wagan, ¡Bab-Jehová-nug odummomala! 
\q2 Bab-Jehová-dobee-nanadimalad, ¡Bab-Jehová-nug odummomala! 
\q1  
\v 21 Sión-akale, Bab-Jehová-nug odummomala. 
\q2 Bab-Jehová, Jerusalénʼgi maid. 
\b  
\q1 ¡Aleluya! ¡Bab-Jehová-nug odummolesun! 
\c 136  
\s1 Bab-Jehová dule-sabgumaiguad 
\q1  
\v 1 Bab-Jehová-e-nug odummomar, 
\q2 ar Bab-Jehová, dule-nuedid. 
\q2 Ar e-sabguedi, degisadeguad. 
\q1  
\v 2 Bab-Dummadbi-wargwenna-maid-e-nug odummomar. 
\q2 Ar e-sabguedi, degisadeguad. 
\q1  
\v 3 Bab-Dummad-Bela-Gangued-Nikad-e-nug odummomar. 
\q2 Ar e-sabguedi, degisadeguad. 
\q1  
\v 4 Bab-Dummadbi ibmar-gegerdaklemalad imaked. 
\q2 A-e-nug odummomar. 
\q2 Ar e-sabguedi, degisadeguad. 
\q1  
\v 5 Bab-Dummad e-ibmar-wisidbali, nibneg-nasiksad. 
\q2 A-e-nug odummomar. 
\q2 Ar e-sabguedi, degisadeguad. 
\q1  
\v 6 Bab-Dummad diigine napneg nasiksad. 
\q2 A-e-nug odummomar. 
\q2 Ar e-sabguedi, degisadeguad. 
\q1  
\v 7 Bab-Dummad gwallu-dummagan nasiksad. 
\q2 A-e-nug odummomar. 
\q2 Ar e-sabguedi, degisadeguad. 
\q1  
\v 8 Bab-Dummad dad-ibeler-neg-ibgi-gaega imaksad. 
\q2 A-e-nug odummomar. 
\q2 Ar e-sabguedi, degisadeguad. 
\q1  
\v 9 Bab-Dummad nii-mutik-gaega nasiksad, niisgwamar neg-mutikid-gaega imaksad. 
\q2 A-e-nug odummomar. 
\q2 Ar e-sabguedi, degisadeguad. 
\q1  
\v 10 Bab-Dummad, Egipto-dulemar-e-masmala-sailaginmalad oburgwisad. 
\q2 A-e-nug odummomar. 
\q2 Ar e-sabguedi, degisadeguad. 
\q1  
\v 11 Bab-Dummad, Egipto-yargi Israel-dulemar onosad. 
\q2 A-e-nug odummomar. 
\q2 Ar e-sabguedi, degisadeguad. 
\q1  
\v 12 Bab-Dummad gangued-nikadba e-sakwa oyogwichigusad, 
\q1 e-surgan oyogwichigusad. 
\q2 A-e-nug odummomar. 
\q2 Ar e-sabguedi, degisadeguad. 
\q1  
\v 13 Bab-Dummad, Demar-Ginnidye-nugad egasad. 
\q2 A-e-nug odummomar. 
\q2 Ar e-sabguedi, degisadeguad. 
\q1  
\v 14 Bab-Dummad, Israel-dulemar-demargi-obakega imaksad. 
\q2 A-e-nug odummomar. 
\q2 Ar e-sabguedi, degisadeguad. 
\q1  
\v 15 Bab-Dummad, Demar-Ginnidye-nugadgi we-Faraón, e-sorda-bila-onomaladmala, ogundisad. 
\q2 A-e-nug odummomar. 
\q2 Ar e-sabguedi, degisadeguad. 
\q1  
\v 16 Bab-Dummad, e-dulamar-nega-dulesulidganba niargusad. 
\q2 A-e-nug odummomar. 
\q2 Ar e-sabguedi, degisadeguad. 
\q1  
\v 17 Bab-Dummad, rey-nuga-nikamalad oburgwisad. 
\q2 A-e-nug odummomar. 
\q2 Ar e-sabguedi, degisadeguad. 
\q1  
\v 18 Bab-Dummad, rey-gandikmalad ogilosad. 
\q2 A-e-nug odummomar. 
\q2 Ar e-sabguedi, degisadeguad. 
\q1  
\v 19 Bab-Dummad, Amorreo-e-rey-Sehón oburgwisad. 
\q2 A-e-nug odummomar. 
\q2 Ar e-sabguedi, degisadeguad. 
\q1  
\v 20 Bab-Dummad, Basán-e-rey-Og oburgwisad. 
\q2 A-e-nug odummomar. 
\q2 Ar e-sabguedi, degisadeguad. 
\q1  
\v 21 Bab-Dummad, we-reymar-e-yarmar e-dulamarga uksad. 
\q2 A-e-nug odummomar. 
\q2 Ar e-sabguedi, degisadeguad. 
\q1  
\v 22 Bab-Dummad, e-mai-Israel-dulemarga yar uksad. 
\q2 A-e-nug odummomar. 
\q2 Ar e-sabguedi, degisadeguad. 
\q1  
\v 23 Bab-Dummad, anmar-nue-yegus-gunanaidgi anmar-iedsulid. 
\q2 A-e-nug odummomar. 
\q2 Ar e-sabguedi, degisadeguad. 
\q1  
\v 24 Bab-Dummad, anmar-isdarmaladgi anmar-ollor-imaksad. 
\q2 A-e-nug odummomar. 
\q2 Ar e-sabguedi, degisadeguad. 
\q1  
\v 25 Bab-Dummad, bela ibmar-durganga mas-ukmaid. 
\q2 A-e-nug odummomar. 
\q2 Ar e-sabguedi, degisadeguad. 
\q1  
\v 26 ¡Bab-Dummad-Nibneggi-Maid-e-nug odummomar! 
\q2 Ar e-sabguedi, degisadeguad. 
\c 137  
\s1 Babilonia-diwar-naba bobukdamalad 
\q1  
\v 1 Babilonia-diwar-naba anmar ambakudapdaed. 
\q2 Agi, anmar Siónʼgi-binsabukwadba, bobukwadaed. 
\q1  
\v 2 Anmar, anmar-gar-arpa sapi-Sauceʼye-nugadgi, 
\q2 an nasikdamalad. 
\q1  
\v 3 Dule-anmar-gasa-sesmaladi, anmarga sokardaed, namakmarye. 
\q2 Dule-anmar-ibe-ibmar-susmaladi, anmarga sokardaed, anmarde wergumarye. 
\q1 Anmarga sokardaed: 
\q2 “Be-Sión-yargi-namaklemaladi, be anmarga namakye.” 
\b  
\q1  
\v 4 ¿Wede igi anmar yar-baidgi Bab-Jehováʼga namakosunna? 
\q2  
\v 5 Jerusalén-neggwebur, an be-iedele, an argan mer bar gar-ogolega gusun. 
\q1  
\v 6 Jerusalén-neggwebur, an be-iedele, an-wergudiidba bar begi an binsasulile, 
\q2 geg bar namake an gusun. 
\b  
\q1  
\v 7 Bab-Jehová, Babilonia-dulemar Jerusalénʼgi-nakwisgu, Edom-dulemar-sognanai-gusad, be insao: 
\q2 “¡Jerusalén-neggwebur bela be obelomarye! 
\q2 ¡Swanga be nasikmarye!” 
\b  
\q1  
\v 8 Babilonia-neggwebur, ibagwengi be bibisgelemogoed. 
\q2 Bemar anmar-imaksayob be imaklemarmogoed. 
\q2 Dule-deyob-bemar-imakoedi, egi nued binsalegoed. 
\q1  
\v 9 Dule be-mimmigan-gani akwagi-sabsur-omukuoed. 
\q2 Dule-deyob-be-mimmigan-imakoedi, egi nued binsalegoed. 
\c 138  
\s1 Bab-Jehová-egi-nued-binsasadba dog-nuedye-soged 
\d David namakleged narmaksad. 
\q1  
\v 1 Bab-Jehová bela-bela an-ulubgi an be-nug odummoged. 
\q2 Baliwiturmar-asabin an bega namakoed. 
\q1  
\v 2 Bese-gorleged-neg-islidikid-siidsiki an dulluu napagi sigoed. 
\q2 Be-sabed-dummarba-maidbali, sogedba be ibmar-imakmaidbali, an be-nug odummogoed. 
\q1 Bab-Dummad, be ibmar-imakoye-sogsad, bela ibmar-birgi, sogedba be imaksad. 
\q2 Degidba be-nug na be ogannosad. 
\q1  
\v 3 Bab-Dummad, an bese gochagua, be an-abin-imaksad, 
\q2 be an-niga ogannononikid. 
\b  
\q1  
\v 4 Bab-Jehová, bela-reymar-we-napneggi-mamaid, bela be-sunmaked-itomaloedba, 
\q2 be-nug odummodmaloed. 
\q1  
\v 5 Bab-Jehová-Igar-Mamaidgi namakdemaloed. 
\q2 Ar Bab-Jehová-e-gargangued dummarba gued. 
\b  
\q1  
\v 6 Bab-Jehová, dule-biriginedid. 
\q2 Bab-Dummad, dule-na-san-dummarba-imaksulidgi, nued binsaed. 
\q2 Bab-Dummad, dule-na-san-dummarba-imakdiiddina, obaned. 
\q1  
\v 7 Amba an bonigan-abalagi-gudidibe, 
\q2 amba dula-gudii be an-imakoed. 
\q1 Bab-Jehová, an-isdarmalad-urwedgi, be an-bendakoed. 
\q2 Be-ganguedba be an-bendakoed. 
\q1  
\v 8 Bab-Jehová, angine bela ibmar-imakoye-sogsad imakedsegad. 
\q2 Bab-Jehová, be-sabgued gege gwaged, degisadeguad. 
\q1 Bab-Dummad, be an-obinnissoggu, 
\q2 mer wargwen be an-meto. 
\c 139  
\s1 Bab-Dummad bela-neg-ugakaase-gudiid 
\d Namakmalad-e-iduedga narmaklesad. David we-namaked narmaksad. 
\q1  
\v 1 Bab-Jehová, be an-baramied. 
\q2 An-gudiid bela be wisid. 
\q1  
\v 2 Sana an sigoe, sana an gwisguoe, 
\q2 be nue-wisimakaled. 
\q1 An begi dikasur-gudi-inigwele, 
\q2 bedi an-binsaed nue-wisimakaled. 
\q1  
\v 3 An-nanaed, an-obunnoged, be nue-wisimakaled, 
\q2 bela an-igarmar be nue-wisid. 
\q1  
\v 4 Bab-Jehová, ar amba yoo an ibmar-soge, 
\q2 bato bedi bela wisdaed. 
\q1  
\v 5 Bela-belad be an-irwa gwisgudiguad. 
\q2 Be-argan-yaurgi be an-sediid. 
\q1  
\v 6 Weyob be ibmar-wisidi, an bela-bela geger-itoged, 
\q2 ¡Bela-bela be ibmar-wisidi, an aku-itoged! 
\b  
\q1  
\v 7 Bab-Dummad, ¿Ar bia be-Burbagi an banguoe? 
\q2 ¿An bia begi wakinnoe? 
\q1  
\v 8 Ar an nibnegse naele, bedi agi maid. 
\q2 Ar an burgwarmalad-meged-galuse an naele, bedi agi gudibalid. 
\q1  
\v 9 Ar an dad-nakwedsik naeyesogele, 
\q2 ar an magatiba naeyesogele, 
\q1  
\v 10 amba be agine an-idu gudiid, 
\q2 be-ganguedgi be an-sedii guoed. 
\q1  
\v 11 An sogdibe: Negsichid an-odukuoye, 
\q2 neg-meegwad anga neg-mutikidga guoye, an binsa-sogsaled. 
\q1  
\v 12 Ar begardi negasichid negsichidga gusulid, 
\q2 begardi neg-mutikid neg-ibginedyob gued. 
\q1 Begardi negasichidi, neg-meegwadi, emarbi gued. 
\b  
\q1  
\v 13 Bab-Dummad, bee be bela an-abagangi-ibmar-bukwad obinnisad. 
\q2 Bee be, sapidukugi an-mesisad. 
\q1  
\v 14 Doggus-nuedye an bega soged, 
\q2 be-ibmar-obinnisadi, andi geger-daked. 
\q1 Be ibmarmar-imaksadi, geger-dakleged, 
\q2 ar we-ibmar an nue-wisid. 
\q1  
\v 15 Ise-dukuale, an-abagangi arbalenaigu, an-garmardi begi odukulessulid. 
\q2 Ise-dukuale, an sapidukugi-mai angi-arbalenaigu, anga abgan-dubagan gwadilenai gusad. 
\q1  
\v 16 An sapidukugi-maigua, bedi an-daksad. 
\q2 Amba yoo an we-napnegse aidedage, 
\q1 birgabigwa an dula-gudii guoe, 
\q2 bela bato be-gardagi narmakar maid. 
\q1  
\v 17 Bab-Dummad, be-binsaed ibiyobi anga doggus-nued gue. 
\q2 ¡Be-binsaedi, ibiyobi mergue! 
\q1  
\v 18 Ar be-binsaed an ebisye-sogele, bur bule ukubba mergueled. 
\q2 Ar an be-binsaed-ebised an obelo-sogele, amba be an-walik gudiiled. 
\b  
\q1  
\v 19 Bab-Dummad, dule-isganamar be oburgwe. 
\q2 Dule-ablis-eomalad, angi be obangue. 
\q1  
\v 20 Wemar-begi-dodoar-sunmakdimaladi, 
\q2 binsarsunna begi gwisgumalad. 
\q1  
\v 21 Bab-Dummad, dulemar-isdar-be-daked, 
\q2 ¿an isdar-daksurmo be insae? 
\q1 Dulemar-be-abingasulid, 
\q2 ¿an sae-daksurmo be insae? 
\q1  
\v 22 An bela-bela isdar-daked, 
\q2 an-isdarmaladga gunonimalad. 
\q1  
\v 23 Bab-Dummad, be an-baramie, 
\q2 an-gwage-ulub be dake, 
\q1 be an-wilubdake, 
\q2 be an-binsaed dake. 
\q1  
\v 24 An igar-isganaba nadapi be an-dakele, 
\q2 geg-igar-berguedba be an-sede. 
\c 140  
\s1 An-bendakye, Bab-Dummadse-goled 
\d David namakmalad-e-iduedga namaked narmaksad. 
\q1  
\v 1 Bab-Jehová, dule-isganamargi be an-ollor-imake. 
\q2 Sabesur-dule-imakmalad-idu be an-odukue. 
\q1  
\v 2 Ar unnila e-gwagegi, ibmar-isgana-imakedginbi binsadii daed. 
\q2 Bane-bane urwed-onodii daed. 
\q1  
\v 3 Naibe-nued-gangueyobi, e-gwabin-duku gued. 
\q2 Naibe-nued-e-gichi-boniyobi, e-sunmaked sedimalad. 
\b  
\q1  
\v 4 Bab-Jehová, dule-isganamar-e-gangued-idu be an-odukue. 
\q2 Sabesur-dule-imakmaladgi be an-ollor-imake, 
\q2 ar an-ogalakuedgi binsadidamalad. 
\q1  
\v 5 Dule-san-dummarba-imakmalad, an-yardakmalaga, an-idu dub nasiksamalad. 
\q2 An-idu igargi saki nasiksamalad. 
\q2 An-nanaedgi an-idu yardakleged-galu osismalad. 
\b  
\q1  
\v 6 An Bab-Jehováʼga sogsad: “Be an-Bab-Dummadid. 
\q2 Bab-Jehová, wilesakwaa an bese-goledi be an-itoge.” 
\q1  
\v 7 Bab-Jehová-Dule-Dummad, be an-Bab-Dummad-bur-gandikidid. 
\q2 Bila-onolegedgi be an-bendakedid. 
\q1  
\v 8 Bab-Jehová, dule-isganamar e-ibmar-imakbiedi, melle imakega be imake. 
\q2 Melle na san-dummarba-itomalaga be imake, 
\q2 melle e-igarmar-nasgumai be imake. 
\b  
\q1  
\v 9 Bab-Dummad, dule-an-balegindimalad, an-wiogega-igar-isgana-amismalad 
\q2 egi dukin-aibinega be imake. 
\q1  
\v 10 Wemargine, sogun-ginnitibiid babatega be imaksun. 
\q2 Soo-yagine balimelledega be imaksun. 
\q2 Melle bar noega yaa-matusulidgi-argwanega be imaksun. 
\q1  
\v 11 Dule-geg-gwabin-duku-bargaed, napneggi gudigu guosulid. 
\q2 Sabsur-dule-imakmalad, boni-dummaganse obelolesun. 
\q1  
\v 12 An wisid, Bab-Jehová, dule-wile-itodiidga igar naboged, 
\q2 dule-ibmarbina-sogdimalad, Bab-Dummad bendaked. 
\q1  
\v 13 Dule-nuegan, be-nug-odummomaloed. 
\q2 Dule-innikimalad be-walik-gudii gumaloed. 
\c 141  
\s1 Bab-Dummadse-goled ibmar-isganagi be an-onoye 
\d David, we-namaked narmaksad. 
\q1  
\v 1 Bab-Jehová, sabsuli an bese goled: ¡Gwae be an-bendakdage! 
\q2 An bese gotele, be an-itoge. 
\q1  
\v 2 An-bese-goledi, ina-wawadikid-nakwemaidaeyob bese nakwemai gusun. 
\q2 An-argan-bese-onakwedi, sedo-ibmar-ogumakar-ukledaeyob be dake. 
\b  
\q1  
\v 3 Bab-Jehová an-gwabinduku-bargaed be an-imake. 
\q2 Bab-Jehová, mer ibmar-yogasaar-sunmaked be an-imake. 
\q1  
\v 4 Melle an-gwage ibmar-isganagi-binsaega be imake, 
\q2 dulemar-ibmar-isgana-imakbiedba melle akaed be an-imake. 
\q1 Dulemar-ibmar-isgana-imaked-abargi, 
\q2 melle ibagi-masgulleged-gunnega be an-imake. 
\b  
\q1  
\v 5 Dule-ibmar-innikii-imaked an-bibyoye-sogele, sabsur ibmar anga sogele, 
\q2 we, ibmar-nued anga imaknaid. 
\q1 Dulemar-isgana-e-gwallu-wawamar, an-nonogi, mer eolegega be imako. 
\q2 Bab-Dummad, mer an dule-isgana-e-ibmar-isgana-imakedgi-yolegega, an bese gornai guoed. 
\q1  
\v 6 E-dummagan-negsemamaid akwasaila-birgi-gwichi gulluse barmelledmalale, agi geb itomaloed, 
\q2 an-ibmar-sogsadi, napiragwad. 
\q1  
\v 7 Geb sogdemaloed: 
\q2 Anmar-garmar, napa-imules-argaarmaiyobi, anmar-garmar neg-uangi omiledoed. 
\b  
\q1  
\v 8 Bab-Jehová-Dule-Dummad, bebi an-bendakedid. 
\q2 Bendakleged beginbi an amied. 
\q2 ¡Melle dulemar an-oburgwed be imako! 
\q1  
\v 9 Dulemar an-idu dub-nasiksamaladgi mer aimukued be an-imako. 
\q2 Dule-isganamar yamo dule-yardakega-ibmar-imakmaladgi, melle yardakleged be an-imako. 
\q1  
\v 10 Dule-isganamar na dukin e-sakigi-argwaned be imake. 
\q2 Bab-Dummadye, be an-bendake. 
\q2 Mer ese galegega be an-imako. 
\c 142  
\s1 David Bab-Dummadse bendakleged-egisnaid 
\d David we-namaked-Masquilʼye-nugad narmaksad. David akwasailayaba-dukusigu, Bab-Dummadse gornai gusad. 
\q1  
\v 1 Bab-Jehováʼse ise-gollar bendakleged an egised, 
\q2 Bab-Jehováʼse ise-wilegar an e-sabgued egisnaid. 
\q1  
\v 2 Bab-Dummadga naibi-itodiid, an sogoed, 
\q2 an-sulibinsa-itodiid, an ega sogoed. 
\b  
\q1  
\v 3 Bab-Dummad, an geggus-itogele, bato be an-daksabinnedaed. 
\q2 An bia nadele, abala dulemar an-yardakega, an-iduar ibmar-sisadamalad. 
\q1  
\v 4 An-argan-nuedsik an atakdele, dule-an-bendaked wargwensaale gwen daklesurdaed. 
\q2 Neg-dukued an sulid, 
\q2 dule-wargwensaale angi binsasulid. 
\b  
\q1  
\v 5 Bab-Jehová, be-an-bendakegala, an bese gochad. 
\q2 An bega sogsad: “Bebi unnila an-bendaked maid. 
\q2 We-napneggi dulemar-bukwad-abargi bebi unnila anga gudiid.” 
\q1  
\v 6 Bab-Dummadye, an-gornaid be itoge, 
\q2 an sulibinsa itoged. 
\q1 An-bareginnanamaladgi be an-bendake, 
\q2 ar anba bur bule gangumalad. 
\q1  
\v 7 An be-nug-odummogega, wegi-an-galessiidgi be an-onodage. 
\q2 Ar be-sabed be anga oyononikile, dule-inniki-gudimalad weligwar an-ebiris ambikunonimaloed. 
\c 143  
\s1 E-bendakega, degi, e-iduega Babse-goled 
\d David, we-namaked narmaksad. 
\q1  
\v 1 Bab-Jehováʼye, an bese-goled be itoge, 
\q2 an-wilesakwaa-goled, be itoge. 
\q1 Be-ibmar-soged-imakedba, be an-abinsae. 
\q2 Be-Igar-innikigwadba, be an-abinsae. 
\q1  
\v 2 Dummad, mer be anga igar-itoge. 
\q2 Ar be-asabindi, dule-wargwensaale na nuedye sogosulid. 
\b  
\q1  
\v 3 An-isdarmalad an-oburgwebied, 
\q2 napayala bikiin an-metemalad. 
\q1 Dule-dikasurgus-burgwismaladyob 
\q2 negasichidgi-megega an-imaksamalad. 
\q1  
\v 4 Bar an nue-bunnosurgusad, 
\q2 an-gwage bogiled an-itoged. 
\b  
\q1  
\v 5 Epenne ibagan-nasmalad an ebinsaded. 
\q2 Belagwable be-ibmar-dummagan-imaksadgi an binsaded. 
\q2 Be-ibmarmar-imaksad, nue an ebinsaded. 
\q1  
\v 6 An-argan an besik oyoged, 
\q2 ar igi napa-dinnagwad dii-abedae, 
\q2 deyobi, an bebina soged. 
\b  
\q1  
\v 7 Bab-Jehová, gwae be an-abinsae, 
\q2 ar an geg-sagusad. 
\q1 Be-wagar mer be angi odukue, 
\q2 ar degiile, dule-napa-yaba-digarmaidyobi, an guoed. 
\q1  
\v 8 Wakudaryalaba be-sabgued be anga oyoge, 
\q2 ar andi begi bensulid. 
\q1 Ar andi bese goled, 
\q2 be anga oyoye, ibu-igarba an naoe. 
\q1  
\v 9 Bab-Jehová, an-isdarmaladgi be an-ollorsae, 
\q2 ar andi begi dukued amied. 
\q1  
\v 10 Be-sogedba-ibmar-imakedgi be an-odurdake, 
\q2 ar be an-Bab-Dummadid. 
\q2 Be-Burba-nued neg-bonigan-satedba an-idue. 
\b  
\q1  
\v 11 Bab-Jehová, be-nug-ular, dula-gudii be an-imake. 
\q2 Be-Igar-innikigwad-ular, surbinsa-itogedgi be an-onoge. 
\q1  
\v 12 Be-dule-wiledaked-ular, an-isdarmalad be ogiloge. 
\q2 Bela an-balengindimalad be obeloge, ar andi be-mai gued. 
\c 144  
\s1 Yar-onasguye, Bab-Dummadse-goled 
\d David, we-namaked narmaksad. 
\q1  
\v 1 Bab-Jehová-nug odummolesun, 
\q2 an-akwasailaga guedid. 
\q1 Bila-onoged-idu, an-surgan-ogannogedid, 
\q2 urwed-idu, an-arganmar-ogannogedid. 
\q1  
\v 2 Bab-Jehová, an-sabguedid, an-edarbedid, 
\q2 bonigan-idu an-odukuedid, 
\q1 bonigangi an-ollor-imakedid, 
\q2 an-sigu-abgaedyob an egi dukuedid, 
\q1 an egi bensulid-nikadid, 
\q2 an-urbaligwa-nanaega dulamar-imakedid. 
\b  
\q1  
\v 3 Bab-Jehová, ¿wede, dule ibusunna, egi be binsanonigu? 
\q2 ¿Wede, dule ibusunna, be akwenonigu? 
\q1  
\v 4 Ar dule unnila gayagi buu-imaklegaledid. 
\q2 Ar e-ibagan unnila negsichigwad-ukiar-nasdaeyobid. 
\b  
\q1  
\v 5 Bab-Jehová, be-mogir be egae, be aidedage. 
\q2 Yalamar be ebuge, waa-obupurmake. 
\q1  
\v 6 Mala-ibyemakale be odege, 
\q2 dule-isdardakmalad be oaisakie, 
\q1 be-sigumala egi be mie, 
\q2 dule-isdarmalad-oduurmakega be imake. 
\q1  
\v 7 Nibneg-akale, be-gangued be anse oyoge, 
\q2 dii-wiladgine be an-onoge, 
\q2 dule-isganamargi be an-ollor-imake. 
\q1  
\v 8 Ar sunmakdemalale, gakansaddamalad, 
\q2 argan-onakwidmalale, nabiridyob ibmar-ise-sogar imakdamalad. 
\b  
\q1  
\v 9 Bab-Dummad, na begala namaked-gwapidgi an namakoed. 
\q2 Gar-arpa-dub-giambe-nikadba (10) an bega namakoed. 
\q1  
\v 10 Bila-onolegedgi be reymar-onakwemaidid. 
\q2 Be-mai-David-melle-es-suidgi-burgwega be imakedid. 
\q1  
\v 11 Be an-bendake, 
\q2 dule-isganamargi be an-ollorsae. 
\q1 Ar sunmakdemalale, gakansaddamalad, 
\q2 argan-onakwidmalale, nabiridyob ibmar-ise-sogar imakdamalad. 
\b  
\q1  
\v 12 Anmar-mimmigan, e-dungumaidba sapimar-binnasuli-dungumaiyob be imako. 
\q2 Anmar-bunamala, reyneg-e-buarmar-sobarmaladyob, yeerdaklege be imako. 
\q1  
\v 13 Anmar-ibmar-gwag-sabomaladgi bukidar masmar-akar-akar ena-ena bukuega be imake. 
\q2 Anmar-sibad-wawaadmar, mili-miliba-omelomai (1,000-1,000) be imake. 
\q2 Anmar-nainugi, mili-miliba-bukuega be imake. 
\q1  
\v 14 Anmar-moli-bebe-nikad-omegan, obargudiguega be imake. 
\q2 Mileged-ibagan-iduar, melle milegega be imako. 
\q1 Melle anmar-neg-imbabali, 
\q2 bar dule, suli-suli-itogedba-gordiguega be imako. 
\q1  
\v 15 Neggwebur we-ibmarmar bela nikale, egi-nued-binsalesdo. 
\q2 Neggwebur, Bab-Jehová e-Bab-Dummadga-imakdiile, egi-nued-binsalesdo. 
\c 145  
\s1 Bela dulemar Bab-Dummad-nug-odummomar 
\d Bab-Dummad-nug odummomar. David, we-namaked narmaksad. 
\q1  
\v 1 An-Bab-Dummad, an-Rey, be-nug an odummogoed. 
\q2 Degisadegu, be-nuggi nued sunmakdigu an guoed. 
\q1  
\v 2 Bane-bane degisadegu, 
\q2 be-nug-odummodii an guoed. 
\q1  
\v 3 Bab-Jehová, Dule-Dummadid. 
\q2 E-nug nue-odummolegergebed. 
\q2 E-nug-dungued dule magar itogosurguoed. 
\q1  
\v 4 Bab-Dummad, babgan be-ibmar-imaksamaladi, e-mimmiganga sogoed. 
\q2 Be-ibmar-dummagan-imaksamaladi, e-mimmiganga sogoed. 
\q1  
\v 5 Be-ganguedgi, be-yeerdaklegedgi, an sunmakdii guoe. 
\q2 Be-ibmar-dummagan-imaksamaladgi, an binsadii guoe. 
\q1  
\v 6 Be-ibmar-dummagan-imakedgi dulemar, sunmakmaloed, 
\q2 be dule-dummad-guedgi, an sunmakoe. 
\q1  
\v 7 Be-sabgued-dummarba-nikadgi, sunmakmaloed, 
\q2 be-ibmar-inniki-imakedgi, namakmaloed. 
\b  
\q1  
\v 8 Bab-Jehová wile dulemar-dakdaed, 
\q2 nue dulemar-sabdaed. 
\q1 Bab-Jehová wissur gwae-gwae urwed, 
\q2 nue dulemar-sabgumaid. 
\q1  
\v 9 Bab-Jehová bela dulemargi nueddaed. 
\q2 Bela na e-ibmar-imaksad nue-sabed. 
\b  
\q1  
\v 10 Bab-Jehová, bela be-ibmar-obinnisadi, be-nug odummosunna. 
\q2 Be-sordamar-napiramalad be-nug odummomarmosunna. 
\q1  
\v 11 Be gannarba-negsemaidgi, sunmakmarsunna. 
\q2 Be-ganguedgi sunmakmala. 
\q1  
\v 12 Adi, dulemar be-ibmar-dummagan-imaksad wisgumalaga, 
\q2 be-yeerdakleged, be-gangued wisgumarbaligar. 
\q1  
\v 13 Be-negsemaidi, degisadeguoed, 
\q2 be-neg-ganikidi, berguosulid. 
\b  
\q1  
\v 14 Bab-Jehová dule-wis-gwatirisdibe, dule-ogwisdaed, 
\q2 dule-nollo-itomalad ogannodaed. 
\q1  
\v 15 Bab-Jehová bela ibmarmala ega be mas ukega bese atakbubuk-naed. 
\q2 Ega be iba-sekalaa masgunned ukmaid. 
\q1  
\v 16 Nalledginsuli ega be mas ukmaid. 
\q2 Bela ibmar-dulaga mas unnitibali be ukmaid. 
\q1  
\v 17 Bab-Jehová, bela-be-ibmar-imakedi, innikigwadbi imaked. 
\q2 Bela nue-sabedgi be ibmar imaked. 
\q1  
\v 18 Bab-Jehová, dule-ese-napiragwadgi-gordimalad-bendakega 
\q2 egi walikaa gudidaed. 
\q1  
\v 19 Bab-Jehová, dule-e-sabee-gudimaladga ibmar-abemalad ukdaed. 
\q2 Amar-ese-ibmar-egisedi ega ukdaed. 
\q1  
\v 20 Bab-Jehová, dule-e-sabgudimalad-edarbedii daed. 
\q2 Ar dule-isganadi bela obelogoed. 
\b  
\q1  
\v 21 Bab-Jehová, an be-nugdi ogannosunna. 
\q2 Bela ibmarmar be-nug ogannomarmosunna. 
\q2 Degisadegu, be-nug ogannodii gumarsunna. 
\c 146  
\s1 Bab-Dummad-Igar-inniki-nabogedga namakleged 
\q1  
\v 1 ¡Aleluya! ¡Bab-Dummad-e-nug-odummomarsun! 
\q2 Bab-Jehová, an-gwagegi an be-nug odummoged. 
\q1  
\v 2 An dula-gudiidgi Bab-Jehová-nug an odummogoed. 
\q2 Bab-Dummadga-namaklegedgi an Bab-Dummadga namakoed. 
\b  
\q1  
\v 3 Mer girmar-dummagangi be bensulid-nika guo, 
\q2 bipisaale mer dule-gwensakgi be bensulid-nika gubalo, 
\q2 ar wemargi bendakleged-igar maisulid. 
\q1  
\v 4 Ar we-dulemar bergunonikile, gannar napaga binnidmaloed. 
\q2 Bela na ibmar-imako-sogsamalad, a-ibagi berguus ega naoed. 
\b  
\q1  
\v 5 Dule Jacob-e-Bab-Dummadgi bendaklediile, we-dulegi nued-binsalesad. 
\q2 E-Bab-Dummad-Jehováʼginbi bensuli gudiid. 
\q1  
\v 6 Ar Bab-Dummad napneg-nasiksadid, nibneg-nasiksabalidid. 
\q2 Demar-naidi, bela-egi-ibmar-bubukwadi urbisbalid. 
\q1 Bab-Dummad ibmar-imakoye-sogsad, 
\q2 sogedba imaked, gakansamaisulid. 
\q1  
\v 7 Bab-Jehová dule-sabsur-imakledimaladga sogedba ega igar naboged. 
\q2 Dule-ukud-itodimaladga masgunned uked. 
\q2 Dule-gales-bubukwad onobalid. 
\q1  
\v 8 Bab-Jehová dulemar-ibyasulid nabir-atakega imaked. 
\q2 Dule-yore-nanamalad inniki-nanaega imaked. 
\q2 Bab-Jehová dule-innikidamalad nue-sabed. 
\q1  
\v 9 Bab-Jehová Israel-dulesurmalad nue-akwed. 
\q2 Dule-babgansuli-gudimalad nue-bendakbalid. 
\q1 Ome-ei-sui-burgwisgudiid nue-bendakbalid. 
\q2 Bab-Dummad dule-isganamarga igar obured. 
\b  
\q1  
\v 10 Sión-dulemar, be-Bab-Jehová degisadegu, negsemai gusun. 
\q2 ¡Aleluya! ¡Bab-Dummad-nug odummomarsun! 
\c 147  
\s1 Bab-Dummad-nug-odummolesun 
\q1  
\v 1 ¡Aleluya! Bab-Jehová-nug odummolesun. 
\b  
\q1 Ar anmar, anmar-Bab-Dummadga-namaked ibnuedid. 
\q2 E-nug-odummoleged yeer-itolegedid. 
\b  
\q1  
\v 2 Bab-Jehová Jerusalén-neggwebur gannar sobed, 
\q2 Israel-dulemar-e-yargi-onolesmalad gannar senonikoed. 
\q1  
\v 3 Bab-Dummad, dule-gwage-nunmak-itodimalad nudaked. 
\q2 E-wile-itodiid baisur-itoge imaked. 
\b  
\q1  
\v 4 Bab-Jehová bela wisid igi mergu niisgwamar nai, 
\q2 bela ega nug nasiksad. 
\q1  
\v 5 Anmar-Bab-Jehová, dule-dummadid, 
\q2 e-gangued bipisurbalid, 
\q2 e-ibmar-wisid degisadeguad. 
\q1  
\v 6 Bab-Jehová dule-wilegana bendaked. 
\q2 Dule-isgana-e-nugdi bipii imaked. 
\b  
\q1  
\v 7 Bab-Jehováʼga yeer-itogedgi namakmala. 
\q2 Anmar-Bab-Dummadga gar-arpaʼba namakmala. 
\q1  
\v 8 Bab-Dummad, nibneggi mogirmar nasiked, 
\q2 napaneggi dii owied, 
\q2 sapurgi gaganmar onied. 
\q1  
\v 9 Bab-Dummad, ibmar-durganga mas uked. 
\q2 Sikwisichii-mimmigan mas-abealile, ega mas ukbalid. 
\b  
\q1  
\v 10 Bab-Jehová moli-e-ganguedgi yeer-itosulid, 
\q2 dule-ibmar-bursur-imakedgi yeer-itosurbalid. 
\q1  
\v 11 Bab-Jehová, e-nug-odummomaladgi yeer-itoged, 
\q2 e-sabgued-bensurmaladgi yeer-itobalid. 
\b  
\q1  
\v 12 Jerusalén-neggwebur, Bab-Jehová-nug odummoge. 
\q2 Sión-yar, be Bab-Dummad-nug odummoge. 
\q1  
\v 13 Bab-Jehová be-yawagak-bargamalad-e-suarmar bega ogannosad. 
\q2 Dule-be-yargi-gudidimaladgi nued-binsalesad. 
\q1  
\v 14 Bab-Dummad be-yargi neg-bogidikid nasiked, 
\q2 orosgi-dakleged-trigo-bur-nuedgi immerba be-imaked. 
\q1  
\v 15 Bab-Dummad napnegga ibmar-soged, 
\q2 e-ibmar-soged yog-imakar imakledaed. 
\q1  
\v 16 Bab-Dummad ubsan-daklegedyob boo-sibudiki obated. 
\q2 Buru-bateyob boo-gwamakaled obated. 
\q1  
\v 17 Bab-Dummad dii-gwamakaled akwanyob obated. 
\q2 Dii-gwamakaled-e-dambed, ¿doa baisur-itogoe? 
\q1  
\v 18 Bab-Dummad-e-ibmar-sogedba dii-gwamakaled diree imaked. 
\q2 Burwa-golega imaked, geb dii gannar suurmakega imaked. 
\q1  
\v 19 Bab-Dummad Jacob-waganga e-gayaburba uksad, 
\q2 Israel-dulemarga na E-Igar-Maid, E-Igar-Inniki-imaklemalad, uksad. 
\q1  
\v 20 Bab-Dummad dulemar-yar-baid-baidgi-bukwamaladdi, deyob imaksasulid. 
\q2 Amardi, bipisaale E-Igar-Mesisad wisgussurmalad. 
\b  
\q1 ¡Aleluya! ¡Bab-Jehová-nug odummolesun! 
\c 148  
\s1 Bela-ibmar-obinnilesadi, Bab-Jehová-nug-odummoged 
\q1  
\v 1 ¡Aleluya! ¡Bab-Jehová-nug odummolesun! 
\q2 Nibneg-akar, Bab-Jehová-nug be odummomar. 
\b  
\q1 Nibneg-matusulid-akar, 
\q2 Bab-Jehová-nug be odummomar. 
\q1  
\v 2 Bela Bab-Jehová-baliwiturmar, Bab-Jehová-nug odummomar. 
\q2 Bela Bab-Jehová-sorda-bilagi-urwemalad, Bab-Jehová-nug odummomar. 
\q1  
\v 3 Dad-ibeler, Bab-Jehová-nug odummosun. 
\q2 Nii, Bab-Jehová-nug odummosun. 
\q2 Niisgwamar, Bab-Jehová-nug odummomar. 
\q1  
\v 4 Bela mogirmar-ugakaase-nanaid, Bab-Jehová-nug odummomar. 
\q2 Diimar-mogirmar-niba-nanaid, Bab-Jehová-nug odummomar. 
\q1  
\v 5 Bab-Jehová-nug odummomarsun, 
\q2 ar e-ibmar-sogsadba, ibmarmar obinnilesad. 
\q1  
\v 6 Degisadegu ibmarmar innikii urbilesad. 
\q2 E-igar-omesisadi, bar egi annalegegarsulid. 
\b  
\q1  
\v 7 Napneg-akale, Bab-Jehová-nug odummomar: 
\q2 Demargi ibdula-dummagan-bukwad, Bab-Jehová-nug odummomar. 
\q2 Demar-wilagana, Bab-Jehová-nug odummomar. 
\q1  
\v 8 Mala-ibyemalad, dii-gwamakarmalad, Bab-Jehová-nug odummomar. 
\q2 Boo-gwamakaled, boo-batemalad, Bab-Jehová-nug odummomar. 
\q2 Burwa-dummagan-be-sogedba-ibmar-imakedi, Bab-Jehová-nug odummomar. 
\q1  
\v 9 Yalamar, bela yala-mullugan, Bab-Jehová-nug odummomar. 
\q2 Sapi-san-nikamalad, bela urwarmar, Bab-Jehová-nug odummomar. 
\q1  
\v 10 Ibmar-dula-sapurbarmalad, ibmar-durgan-negginmalad, Bab-Jehová-nug odummomar. 
\q2 Ibdula-unimalad, nuumar, Bab-Jehová-nug odummomar. 
\q1  
\v 11 Reymar-napneggi-mamaid, Bab-Jehová-nug odummomar. 
\q2 Bela dulemar-yar-baid-baidgi-bukmalad, Bab-Jehová-nug odummomar. 
\q2 Dule-nuga-nikamalad, dule-dummagan-yar-semamaid, Bab-Jehová-nug odummomar. 
\q1  
\v 12 Sapingana, yagana, Bab-Jehová-nug odummomar. 
\q2 Dadormar, mimmigan, Bab-Jehová-nug odummomar. 
\b  
\q1  
\v 13 Bab-Jehová-nug odummomar, ar a-nugbi unnila dummarba gued. 
\q2 E-gandik-yeerdakleged, napnegba, nibnegba, bur-gandik dakleged. 
\q1  
\v 14 Bab-Jehová, e-neggweburga gangued uksad. 
\b  
\q1 Israel-wagan-bela-Bab-Jehováʼba-nanadimalad, e-dulamar-walikagwadga-gubalid, 
\q2 Bab-Jehová-nug odummomar. 
\b  
\q1 ¡Aleluya! ¡Bab-Jehová-nug odummolesun! 
\c 149  
\s1 Bab-Jehová-nug ogannomar 
\q1  
\v 1 ¡Aleluya! ¡Bab-Jehová-nug odummolesun! 
\b  
\q1 Bab-Jehováʼga namaked-binid namakmala. 
\q2 Bab-Jehová-sordamar-abargi Bab-Jehová-nug odummomala. 
\b  
\q1  
\v 2 Israel-dulemar, dule-bega-burba-uksadgi be wergumala, 
\q2 Israel-dulemar Sión-yargi-bukmalad, be-e-Reygi be wergumala. 
\q1  
\v 3 Nue-weligwaledgi-dodonai, 
\q2 Bab-Dummad-e-nug ogannomala. 
\q1 Gar-pandero-ogornai ega be namakmala. 
\q2 Gar-arpa-ogornai ega be namakmala. 
\q1  
\v 4 Ar Bab-Jehová e-dulemargi yeer itodaed. 
\q2 Dule-wiledimaladi e-isdarmaladgi-nakwega imakdaed. 
\q1  
\v 5 Bab-Dummad-sordagan na be emargi-obichamaladgi, wergumala. 
\q2 Gachigi amba be maile, namakmai be imakmala. 
\b  
\q1  
\v 6 Be-gammu-galagi Bab-Dummad-nug odummomala. 
\q2 Be-argangi es-suid-nugar-darbogwad-gani Bab-Dummad-nug odummomala: 
\q1  
\v 7 Adi, dulemar-baigan buged-mai be imakmalaga, 
\q2 dulamar-baigan sabsur-odurdakega, 
\q1  
\v 8 esgoro-dubgi e-reymar-edinnega, 
\q2 esgoro-dubgi e-dummagan-edinnegar. 
\q1  
\v 9 Adi, Bab-Dummad, dulemar-sabsur-odurdakoye-sogsadba imaklegegar. 
\q2 Weyob gunonikile, bela bemar Bab-Dummad-sorda-gumaladi egi be wergumaloed. 
\b  
\q1 ¡Aleluya! ¡Anmar-Bab-Jehová-nug ogannomar! 
\c 150  
\s1 Bab-Dummad-nug gar-ogorlegedgi odummomar 
\q1  
\v 1 ¡Aleluya! Bab-Jehová-nug odummolesun. 
\b  
\q1 Bab-Dummadse-goled-neggi, Bab-Jehová-nug odummomar. 
\q2 Bab-Dummad-nibneg-geger-dakle-nasiksadba, Bab-Dummad-nug odummomar.\fig Bemar gar-akar-akar-ogoledba Bab-Dummad-nug odummomalargebe. (Salmo 150) |src="HK00188B.TIF" size="col" ref="Salmos 150:1" \fig* 
\q1  
\v 2 E-ibmar-dummagan-imaksadba, Bab-Dummad-nug odummomar. 
\q2 E-gangued-dummarba-nikadba, Bab-Dummad-nug odummomar. 
\q1  
\v 3 Gar-trompeta-goledba, Bab-Dummad-nug odummomar. 
\q2 Gar-arpa-goledba, Bab-Dummad-nug odummomar. 
\q2 Gar-lira-goledba, Bab-Dummad-nug odummomar. 
\q1  
\v 4 Gar-pandero-goledba, Bab-Dummad-nug odummomar. 
\q2 Gwirnanai, Bab-Dummad-nug odummomar. 
\q1 Gar-dub-nikad-goledba, Bab-Dummad-nug odummomar. 
\q2 Gammu-goledba, Bab-Dummad-nug odummomar. 
\q1  
\v 5 Gar-címbalo-binnasur-goledba, Bab-Dummad-nug odummomar. 
\q2 Gar-címbalo-yeer-goledba, Bab-Dummad-nug odummomar. 
\b  
\q1  
\v 6 ¡Bela dula-gudidiid, 
\q2 Bab-Jehová-e-nug odummomar! 
\b  
\q1 ¡Aleluya! ¡Bab-Jehová-e-nug odummomarsun!