\p 
\v 1 \w In|strong="H5922"\w* \w the|strong="H5922"\w* \w first|strong="H2298"\w* \w year|strong="H8140"\w* \w of|strong="H4430"\w* \w Belshazzar|strong="H1113"\w*'s \w reign|strong="H4430"\w* as \w king|strong="H4430"\w* \w of|strong="H4430"\w* Babylon, \w Daniel|strong="H1841"\w* \w had|strong="H4430"\w* \w a|strong="H3068"\w* \w dream|strong="H2493"\w* \w in|strong="H5922"\w* which \w visions|strong="H2376"\w* passed through \w his|strong="H5922"\w* \w mind|strong="H7217"\w* as \w he|strong="H1841"\w* lay \w in|strong="H5922"\w* \w bed|strong="H4903"\w*. Afterwards \w he|strong="H1841"\w* \w wrote|strong="H3790"\w* \w down|strong="H3790"\w* \w the|strong="H5922"\w* \w dream|strong="H2493"\w*, describing \w it|strong="H5922"\w* \w in|strong="H5922"\w* \w summary|strong="H7217"\w* form.
