\v 31 \wj Âż\+w O|strong="G2228"\+w* \+w cuĂĄl|strong="G5101"\+w* rey \+w que|strong="G3588"\+w* marcha \+w a|strong="G1519"\+w* enfrentar \+w en|strong="G1722"\+w* \+w batalla|strong="G4171"\+w* \+w a|strong="G1519"\+w* \+w otro|strong="G2087"\+w* rey, \+w no|strong="G3780"\+w* se sienta \+w primero|strong="G4413"\+w* \+w a|strong="G1519"\+w* planificar \+w si|strong="G1487"\+w* \+w es|strong="G1487"\+w* capaz \+w de|strong="G1722"\+w* enfrentar \+w con|strong="G3326"\+w* 10.000 \+w al|strong="G3588"\+w* \+w que|strong="G3588"\+w* \+w viene|strong="G2064"\+w* \+w contra|strong="G1909"\+w* \+w ĂŠl|strong="G3588"\+w* \+w con|strong="G3326"\+w* 20.000?\wj*  
