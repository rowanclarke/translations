\v 32 Luego \w Samuel|strong="H8050"\w* dijo: Tráiganme \w a|strong="H3068"\w* Agag, \w rey|strong="H4428"\w* de \w Amalec|strong="H6002"\w*. \w Y|strong="H3068"\w* aunque Agag \w iba|strong="H3212"\w* \w a|strong="H3068"\w* \w él|strong="H5066"\w* encadenado, Agag se decía: Ciertamente ya pasó la \w amargura|strong="H4751"\w* de la \w muerte|strong="H4194"\w*.
\p 
\v 33 Pero \w Samuel|strong="H8050"\w* dijo: \w Como|strong="H3651"\w* tu \w espada|strong="H2719"\w* dejó \w a|strong="H3068"\w* mujeres sin hijos, \w así|strong="H3651"\w* tu madre estará sin hijo entre las mujeres.
\p \w Y|strong="H3068"\w* \w Samuel|strong="H8050"\w* descuartizó \w a|strong="H3068"\w* Agag en \w presencia|strong="H6440"\w* \w de|strong="H6440"\w* \nd \w Yavé|strong="H3068"\w*\nd* en \w Gilgal|strong="H1537"\w*.
\p 
\v 34 \w Luego|strong="H5927"\w* \w Samuel|strong="H8050"\w* \w fue|strong="H3212"\w* \w a|strong="H3068"\w* \w Ramá|strong="H7414"\w*, y \w Saúl|strong="H7586"\w* \w subió|strong="H5927"\w* \w a|strong="H3068"\w* su \w casa|strong="H1004"\w* \w en|strong="H3212"\w* \w Gabaa|strong="H1390"\w* de \w Saúl|strong="H7586"\w*.
\v 35 \w Hasta|strong="H5704"\w* \w el|strong="H5921"\w* \w día|strong="H3117"\w* \w de|strong="H5921"\w* \w su|strong="H3588"\w* \w muerte|strong="H4194"\w*, \w Samuel|strong="H8050"\w* \w nunca|strong="H3808"\w* \w más|strong="H3588"\w* \w vio|strong="H7200"\w* \w a|strong="H3068"\w* \w Saúl|strong="H7586"\w*. \w Pero|strong="H3588"\w* \w Samuel|strong="H8050"\w* lamentaba \w a|strong="H3068"\w* \w Saúl|strong="H7586"\w*, \w y|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* sentía pesar \w porque|strong="H3588"\w* designó \w a|strong="H3068"\w* \w Saúl|strong="H7586"\w* \w como|strong="H3588"\w* \w rey|strong="H4427"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.
\c 16
\s1 Unción de David como rey
\p 
\v 1 \nd \w Yavé|strong="H3068"\w*\nd* dijo \w a|strong="H3068"\w* \w Samuel|strong="H8050"\w*: \wj ¿\w Hasta|strong="H5704"\w* \w cuándo|strong="H3588"\w* \w te|strong="H5921"\w* afligirás \w por|strong="H5921"\w* \w Saúl|strong="H7586"\w*, \w si|strong="H3588"\w* \w Yo|strong="H3588"\w* \w lo|strong="H5921"\w* rechacé \w como|strong="H3588"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*? \w Llena|strong="H4390"\w* tu \w cuerno|strong="H7161"\w* \w de|strong="H5921"\w* \w aceite|strong="H8081"\w*, \w y|strong="H3588"\w* \w ven|strong="H3212"\w*, \w porque|strong="H3588"\w* \w Yo|strong="H3588"\w* \w te|strong="H5921"\w* \w enviaré|strong="H7971"\w* \w a|strong="H3068"\w* \w Isaí|strong="H3448"\w* \w de|strong="H5921"\w* Belén, \w porque|strong="H3588"\w* \w de|strong="H5921"\w* \w entre|strong="H5921"\w* sus \w hijos|strong="H1121"\w* \w me|strong="H5921"\w* seleccioné un \w rey|strong="H4428"\w*.\wj*
\p 
\v 2 \w Samuel|strong="H8050"\w* dijo: ¿Cómo \w iré|strong="H3212"\w*? ¡Si \w Saúl|strong="H7586"\w* se entera me \w matará|strong="H2026"\w*!
\p Pero \nd \w Yavé|strong="H3068"\w*\nd* dijo: \wj \w Toma|strong="H3947"\w* contigo una \w becerra|strong="H5697"\w* de la manada vacuna, \w y|strong="H1241"\w* dí: Vine \w a|strong="H3068"\w* sacrificar \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*.\nd* \wj*
\v 3 \wj Invitarás \w a|strong="H3068"\w* \w Isaí|strong="H3448"\w* al \w sacrificio|strong="H2077"\w*, y \w Yo|strong="H6213"\w* te informaré \w lo|strong="H6213"\w* \w que|strong="H3045"\w* vas \w a|strong="H3068"\w* \w hacer|strong="H6213"\w*. \w Ungirás|strong="H4886"\w* \w a|strong="H3068"\w* \w quien|strong="H6213"\w* \w Yo|strong="H6213"\w* te diga.\wj*
\p 
\v 4 \w Samuel|strong="H8050"\w* \w hizo|strong="H6213"\w* \w lo|strong="H6213"\w* que le \w habló|strong="H1696"\w* \nd \w Yavé|strong="H3068"\w*\nd*. Cuando llegó \w a|strong="H3068"\w* Belén los \w ancianos|strong="H2205"\w* de la \w ciudad|strong="H5892"\w* salieron temblorosos \w a|strong="H3068"\w* recibirlo y preguntaron: ¿Es pacífica \w tu|strong="H6213"\w* venida?
\p 
\v 5 \w Y|strong="H3068"\w* \w él|strong="H1121"\w* contestó: ¡Pacífica! Vine \w a|strong="H3068"\w* ofrecer \w sacrificio|strong="H2077"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*. Purifíquense ustedes y vengan conmigo al \w sacrificio|strong="H2077"\w*. Después purificó \w a|strong="H3068"\w* \w Isaí|strong="H3448"\w* con sus \w hijos|strong="H1121"\w* y \w los|strong="H1121"\w* invitó al \w sacrificio|strong="H2077"\w*.
\p 
\v 6 \w Sucedió|strong="H1961"\w* \w que|strong="H1961"\w* \w cuando|strong="H1961"\w* ellos llegaron, él \w vio|strong="H7200"\w* \w a|strong="H3068"\w* Eliab, y \w se|strong="H1961"\w* dijo: ¡Ciertamente su \w ungido|strong="H4899"\w* \w está|strong="H1961"\w* \w delante|strong="H5048"\w* \w de|strong="H5048"\w* \nd \w Yavé|strong="H3068"\w*\nd*!
\p 
\v 7 \w Pero|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* dijo \w a|strong="H3068"\w* \w Samuel|strong="H8050"\w*: \wj \w No|strong="H3808"\w* \w mires|strong="H5027"\w* \w su|strong="H3588"\w* \w apariencia|strong="H4758"\w*, \w ni|strong="H3808"\w* \w a|strong="H3068"\w* \w lo|strong="H3808"\w* \w grande|strong="H6967"\w* \w de|strong="H3588"\w* \w su|strong="H3588"\w* \w estatura|strong="H4758"\w*, \w pues|strong="H3588"\w* \w Yo|strong="H3588"\w* \w lo|strong="H3808"\w* \w desecho|strong="H3988"\w*, \w porque|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w no|strong="H3808"\w* \w mira|strong="H7200"\w* \w lo|strong="H3808"\w* \w que|strong="H3588"\w* \w mira|strong="H7200"\w* \w el|strong="H3588"\w* hombre. \w El|strong="H3588"\w* hombre \w mira|strong="H7200"\w* \w lo|strong="H3808"\w* \w que|strong="H3588"\w* está \w delante|strong="H5869"\w* \w de|strong="H3588"\w* sus \w ojos|strong="H5869"\w*, \w pero|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w mira|strong="H7200"\w* \w el|strong="H3588"\w* \w corazón|strong="H3824"\w*.\wj*
\p 
\v 8 \w Entonces|strong="H1571"\w* \w Isaí|strong="H3448"\w* \w llamó|strong="H7121"\w* \w a|strong="H3068"\w* Abinadab, \w y|strong="H1571"\w* \w lo|strong="H2088"\w* hizo \w pasar|strong="H5674"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w Samuel|strong="H8050"\w*, quien dijo: \nd \w Yavé|strong="H3068"\w*\nd* \w tampoco|strong="H1571"\w* eligió \w a|strong="H3068"\w* \w éste|strong="H2088"\w*.
\p 
\v 9 \w Luego|strong="H5674"\w* \w Isaí|strong="H3448"\w* hizo \w pasar|strong="H5674"\w* \w a|strong="H3068"\w* Samá. \w Y|strong="H3068"\w* \w él|strong="H5674"\w* dijo: \nd \w Yavé|strong="H3068"\w*\nd* \w tampoco|strong="H1571"\w* eligió \w a|strong="H3068"\w* \w éste|strong="H2088"\w*.
\v 10 Así \w Isaí|strong="H3448"\w* hizo \w pasar|strong="H5674"\w* \w a|strong="H3068"\w* sus \w siete|strong="H7651"\w* \w hijos|strong="H1121"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w Samuel|strong="H8050"\w*, pero \w Samuel|strong="H8050"\w* dijo \w a|strong="H3068"\w* \w Isaí|strong="H3448"\w*: \nd \w Yavé|strong="H3068"\w*\nd* \w no|strong="H3808"\w* eligió \w a|strong="H3068"\w* éstos.
\v 11 \w Samuel|strong="H8050"\w* preguntó \w a|strong="H3068"\w* \w Isaí|strong="H3448"\w*: ¿\w Son|strong="H3588"\w* éstos todos tus hijos?
\p \w Y|strong="H3068"\w* \w él|strong="H3588"\w* respondió: \w Queda|strong="H7604"\w* \w aún|strong="H5750"\w* \w el|strong="H3588"\w* \w menor|strong="H6996"\w*. \w Ciertamente|strong="H3588"\w*, pastorea \w el|strong="H3588"\w* \w rebaño|strong="H6629"\w*.
\p \w Entonces|strong="H3588"\w* \w Samuel|strong="H8050"\w* dijo \w a|strong="H3068"\w* \w Isaí|strong="H3448"\w*: \w Envía|strong="H7971"\w* \w por|strong="H3588"\w* \w él|strong="H3588"\w* \w y|strong="H3588"\w* tráelo, \w porque|strong="H3588"\w* \w no|strong="H3808"\w* nos reclinaremos \w hasta|strong="H5704"\w* \w que|strong="H3588"\w* \w él|strong="H3588"\w* venga \w aquí|strong="H6311"\w*.
\p 
\v 12 Isaí \w envió|strong="H7971"\w* \w por|strong="H3588"\w* \w él|strong="H1931"\w* \w y|strong="H3588"\w* \w lo|strong="H1931"\w* presentó. \w Él|strong="H1931"\w* \w era|strong="H1931"\w* rubio, \w de|strong="H3588"\w* \w ojos|strong="H5869"\w* vivaces \w y|strong="H3588"\w* \w buen|strong="H2896"\w* \w parecer|strong="H5869"\w*. \w Entonces|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* dijo: \wj ¡\w Levántate|strong="H6965"\w* \w y|strong="H3588"\w* úngelo, \w porque|strong="H3588"\w* \w éste|strong="H2088"\w* \w es|strong="H1931"\w*!\wj*
\v 13 \w Entonces|strong="H3117"\w* \w Samuel|strong="H8050"\w* \w tomó|strong="H3947"\w* \w el|strong="H1931"\w* \w cuerno|strong="H7161"\w* de \w aceite|strong="H8081"\w* y \w lo|strong="H1931"\w* \w ungió|strong="H4886"\w* \w en|strong="H3212"\w* \w medio|strong="H7130"\w* de \w sus|strong="H1931"\w* hermanos, y \w el|strong="H1931"\w* \w Espíritu|strong="H7307"\w* de \nd \w Yavé|strong="H3068"\w*\nd* \w se|strong="H1931"\w* apoderó de \w David|strong="H1732"\w* desde \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w en|strong="H3212"\w* adelante. \w Luego|strong="H1931"\w* \w Samuel|strong="H8050"\w* \w se|strong="H1931"\w* \w levantó|strong="H6965"\w* y regresó \w a|strong="H3068"\w* \w Ramá|strong="H7414"\w*.
\s1 Saúl atormentado por un espíritu malo
\p 
\v 14 \w El|strong="H5973"\w* \w Espíritu|strong="H7307"\w* \w de|strong="H5973"\w* \nd \w Yavé|strong="H3068"\w*\nd* se apartó \w de|strong="H5973"\w* \w Saúl|strong="H7586"\w*, y un \w espíritu|strong="H7307"\w* \w malo|strong="H7451"\w* \w de|strong="H5973"\w* parte \w de|strong="H5973"\w* \nd \w Yavé|strong="H3068"\w*\nd* lo atormentaba.
\p 
\v 15 Los esclavos \w de|strong="H7451"\w* \w Saúl|strong="H7586"\w* le dijeron: \w Mira|strong="H2009"\w*, un \w espíritu|strong="H7307"\w* \w malo|strong="H7451"\w* \w de|strong="H7451"\w* parte \w de|strong="H7451"\w* \nd \w Yavé|strong="H3068"\w*\nd* te atormenta.
\v 16 Ordene nuestro \tl ʼadón\tl* \w a|strong="H3068"\w* sus esclavos \w que|strong="H4994"\w* \w están|strong="H1961"\w* \w ante|strong="H6440"\w* \w ti|strong="H5921"\w*, \w que|strong="H4994"\w* \w busquen|strong="H1245"\w* un varón \w que|strong="H4994"\w* \w sepa|strong="H3045"\w* tañer \w el|strong="H5921"\w* \w arpa|strong="H3658"\w*. \w Acontecerá|strong="H1961"\w* \w que|strong="H4994"\w* \w cuando|strong="H1961"\w* \w te|strong="H5921"\w* acometa \w el|strong="H5921"\w* \w espíritu|strong="H7307"\w* \w malo|strong="H7451"\w* \w de|strong="H5921"\w* parte \w de|strong="H5921"\w* \nd ʼElohim\nd*, \w él|strong="H5921"\w* tañerá \w con|strong="H5921"\w* su \w mano|strong="H3027"\w* \w y|strong="H5921"\w* tú \w estarás|strong="H1961"\w* \w bien|strong="H2895"\w*.
\p 
\v 17 \w Saúl|strong="H7586"\w* respondió \w a|strong="H3068"\w* sus esclavos: Búsquenme alguno \w que|strong="H4994"\w* taña \w bien|strong="H3190"\w* y tráiganlo.
\p 
\v 18 Entonces uno \w de|strong="H5973"\w* \w los|strong="H1121"\w* esclavos tomó la \w palabra|strong="H1697"\w* y dijo: Miren, \w vi|strong="H7200"\w* \w a|strong="H3068"\w* un \w hijo|strong="H1121"\w* \w de|strong="H5973"\w* \w Isaí|strong="H3448"\w* \w de|strong="H5973"\w* Belén \w que|strong="H3045"\w* \w sabe|strong="H3045"\w* tañer. \w Es|strong="H1697"\w* \w poderoso|strong="H1368"\w* y \w valiente|strong="H1368"\w*, guerrero, discreto \w en|strong="H5973"\w* \w el|strong="H5973"\w* \w hablar|strong="H1697"\w* y \w de|strong="H5973"\w* buen \w parecer|strong="H1697"\w*, y \nd \w Yavé|strong="H3068"\w*\nd* está \w con|strong="H5973"\w* \w él|strong="H5973"\w*.
\p 
\v 19 \w Saúl|strong="H7586"\w* \w envió|strong="H7971"\w* \w mensajeros|strong="H4397"\w* \w a|strong="H3068"\w* \w Isaí|strong="H3448"\w* para decirle: \w Envíame|strong="H7971"\w* \w a|strong="H3068"\w* tu \w hijo|strong="H1121"\w* \w David|strong="H1732"\w*, \w el|strong="H1121"\w* \w que|strong="H1121"\w* está con \w el|strong="H1121"\w* \w rebaño|strong="H6629"\w*.
\v 20 \w Isaí|strong="H3448"\w* \w tomó|strong="H3947"\w* un \w asno|strong="H2543"\w* cargado \w de|strong="H1121"\w* \w pan|strong="H3899"\w*, un odre \w de|strong="H1121"\w* \w vino|strong="H3196"\w* y un \w cabrito|strong="H1423"\w* del rebaño, y \w los|strong="H1121"\w* \w envió|strong="H7971"\w* \w a|strong="H3068"\w* \w Saúl|strong="H7586"\w* \w por|strong="H3027"\w* \w medio|strong="H3027"\w* \w de|strong="H1121"\w* su \w hijo|strong="H1121"\w* \w David|strong="H1732"\w*.
\s1 David en casa de Saúl
\p 
\v 21 \w David|strong="H1732"\w* \w fue|strong="H1961"\w* \w a|strong="H3068"\w* \w Saúl|strong="H7586"\w* y \w se|strong="H1961"\w* \w quedó|strong="H5975"\w* con él. Lo estimó muchísimo, y lo nombró portador \w de|strong="H6440"\w* sus \w armas|strong="H3627"\w*.
\v 22 \w Saúl|strong="H7586"\w* \w envió|strong="H7971"\w* \w a|strong="H3068"\w* decir \w a|strong="H3068"\w* \w Isaí|strong="H3448"\w*: \w Te|strong="H5869"\w* \w ruego|strong="H4994"\w* \w que|strong="H3588"\w* \w David|strong="H1732"\w* se quede \w delante|strong="H6440"\w* \w de|strong="H3588"\w* \w mí|strong="H4994"\w*, \w pues|strong="H3588"\w* \w halló|strong="H4672"\w* \w gracia|strong="H2580"\w* \w ante|strong="H6440"\w* mis \w ojos|strong="H5869"\w*.
\p 
\v 23 \w De|strong="H5921"\w* modo \w que|strong="H5921"\w* \w cuando|strong="H1961"\w* \w el|strong="H5921"\w* \w espíritu|strong="H7307"\w* \w malo|strong="H7451"\w* \w de|strong="H5921"\w* parte \w de|strong="H5921"\w* \nd ʼElohim\nd* acometía \w a|strong="H3068"\w* \w Saúl|strong="H7586"\w*, \w David|strong="H1732"\w* \w tomaba|strong="H3947"\w* \w el|strong="H5921"\w* \w arpa|strong="H3658"\w* \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w tañía|strong="H5059"\w* \w con|strong="H5921"\w* su \w mano|strong="H3027"\w*. \w Saúl|strong="H7586"\w* hallaba alivio \w y|strong="H5921"\w* \w se|strong="H1961"\w* sentía \w mejor|strong="H2895"\w*, \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w espíritu|strong="H7307"\w* \w malo|strong="H7451"\w* \w se|strong="H1961"\w* apartaba \w de|strong="H5921"\w* \w él|strong="H5921"\w*.
\c 17
\s1 David y el gigante Goliat
\p 
\v 1 Entonces los \w filisteos|strong="H6430"\w* reunieron sus \w ejércitos|strong="H4264"\w* para la \w guerra|strong="H4421"\w* y se concentraron en Soco, que pertenece \w a|strong="H3068"\w* \w Judá|strong="H3063"\w*. Acamparon en Efes-damim entre Soco y \w Azeca|strong="H5825"\w*.
\v 2 \w Saúl|strong="H7586"\w* y los hombres de \w Israel|strong="H3478"\w* se reunieron y acamparon en el \w valle|strong="H6010"\w* de Ela. Dispusieron la \w batalla|strong="H4421"\w* \w contra|strong="H3478"\w* los \w filisteos|strong="H6430"\w*.
\v 3 Los \w filisteos|strong="H6430"\w* \w estaban|strong="H5975"\w* \w a|strong="H3068"\w* un lado sobre una colina y los de \w Israel|strong="H3478"\w* al frente de ellos sobre otra colina. El \w valle|strong="H1516"\w* \w estaba|strong="H5975"\w* entre ellos.
\p 
\v 4 De entre \w el|strong="H4264"\w* \w campamento|strong="H4264"\w* de los \w filisteos|strong="H6430"\w* \w salió|strong="H3318"\w* un retador \w llamado|strong="H8034"\w* Goliat, de Gat, cuya \w altura|strong="H1363"\w* era de 2,9 metros.
\v 5 Llevaba un casco \w de|strong="H5921"\w* bronce \w en|strong="H5921"\w* \w la|strong="H1931"\w* \w cabeza|strong="H7218"\w*, \w e|strong="H3068"\w* iba \w vestido|strong="H3847"\w* \w con|strong="H5921"\w* una cota \w de|strong="H5921"\w* malla \w de|strong="H5921"\w* bronce \w que|strong="H1931"\w* pesaba \w cinco|strong="H2568"\w* kilogramos.
\v 6 \w Sobre|strong="H5921"\w* sus piernas llevaba grebas \w de|strong="H5921"\w* hierro \w y|strong="H5921"\w* una lanza \w de|strong="H5921"\w* bronce \w sobre|strong="H5921"\w* sus \w hombros|strong="H3802"\w*.
\v 7 El asta \w de|strong="H6440"\w* su \w lanza|strong="H2595"\w* era como un rodillo \w de|strong="H6440"\w* tejedores, y su punta pesaba 6,6 kilogramos. Su \w escudero|strong="H5375"\w* \w iba|strong="H1980"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* él.
\p 
\v 8 \w Se|strong="H3808"\w* paró y \w gritó|strong="H7121"\w* \w a|strong="H3068"\w* los ejércitos de \w Israel|strong="H3478"\w*: ¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* \w salieron|strong="H3318"\w* \w a|strong="H3068"\w* alinearse \w en|strong="H3318"\w* orden de \w batalla|strong="H4421"\w*? ¿\w No|strong="H3808"\w* soy yo un \w filisteo|strong="H6430"\w* y ustedes \w son|strong="H3808"\w* esclavos de \w Saúl|strong="H7586"\w*? ¡Escójanse un hombre \w que|strong="H4100"\w* baje \w contra|strong="H3478"\w* mí!
\v 9 \w Si|strong="H1961"\w* él \w puede|strong="H3201"\w* \w pelear|strong="H3201"\w* conmigo y me mata, entonces \w seremos|strong="H1961"\w* sus esclavos. Pero \w si|strong="H1961"\w* yo prevalezco \w contra|strong="H1961"\w* él y lo \w mato|strong="H5221"\w*, entonces ustedes \w serán|strong="H1961"\w* nuestros esclavos y nos \w servirán|strong="H5647"\w*.
\v 10 \w Y|strong="H3068"\w* añadió el \w filisteo|strong="H6430"\w*: \w Hoy|strong="H3117"\w* yo desafío al ejército \w de|strong="H5414"\w* \w Israel|strong="H3478"\w*. ¡Denme \w un|strong="H3162"\w* hombre \w para|strong="H5414"\w* \w que|strong="H3117"\w* luchemos!
\v 11 Cuando \w Saúl|strong="H7586"\w* y \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* \w oyeron|strong="H8085"\w* estas \w palabras|strong="H1697"\w* del \w filisteo|strong="H6430"\w*, se turbaron y tuvieron \w mucho|strong="H3966"\w* \w temor|strong="H3372"\w*.
\s1 La nueva condición de David
\p 
\v 12 \w Ahora|strong="H3117"\w* bien, \w David|strong="H1732"\w* \w era|strong="H1121"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* un \w hombre|strong="H1121"\w* efrateo \w de|strong="H1121"\w* Belén \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*, \w llamado|strong="H8034"\w* \w Isaí|strong="H3448"\w*, quien tenía \w ocho|strong="H8083"\w* \w hijos|strong="H1121"\w*. En \w los|strong="H1121"\w* \w días|strong="H3117"\w* \w de|strong="H1121"\w* \w Saúl|strong="H7586"\w*, \w ese|strong="H2088"\w* anciano tenía \w edad|strong="H3117"\w* muy avanzada.
\v 13 \w Los|strong="H1121"\w* \w tres|strong="H7969"\w* \w hijos|strong="H1121"\w* \w mayores|strong="H1419"\w* \w de|strong="H1121"\w* \w Isaí|strong="H3448"\w* habían \w ido|strong="H3212"\w* \w a|strong="H3068"\w* la \w guerra|strong="H4421"\w* con \w Saúl|strong="H7586"\w*. \w Los|strong="H1121"\w* \w nombres|strong="H8034"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w tres|strong="H7969"\w* \w hijos|strong="H1121"\w* \w que|strong="H1121"\w* \w fueron|strong="H3212"\w* \w a|strong="H3068"\w* la \w guerra|strong="H4421"\w* eran: Eliab, \w el|strong="H1121"\w* \w primogénito|strong="H1060"\w*, Abinadab, \w el|strong="H1121"\w* \w segundo|strong="H4932"\w*, y Samá, \w el|strong="H1121"\w* \w tercero|strong="H7992"\w*.
\v 14 \w David|strong="H1732"\w* \w era|strong="H1931"\w* \w el|strong="H1931"\w* \w menor|strong="H6996"\w*. \w Fueron|strong="H1980"\w* \w los|strong="H1931"\w* \w tres|strong="H7969"\w* \w mayores|strong="H1419"\w* tras \w Saúl|strong="H7586"\w*,
\v 15 pero \w David|strong="H1732"\w* \w se|strong="H5921"\w* apartó \w de|strong="H5921"\w* \w Saúl|strong="H7586"\w* \w y|strong="H5921"\w* \w volvió|strong="H7725"\w* \w a|strong="H3068"\w* apacentar \w el|strong="H5921"\w* \w rebaño|strong="H6629"\w* \w de|strong="H5921"\w* su padre \w en|strong="H5921"\w* Belén.
\p 
\v 16 \w El|strong="H5066"\w* \w filisteo|strong="H6430"\w* salía por la mañana y por la tarde. Así lo hizo durante 40 \w días|strong="H3117"\w*.
\p 
\v 17 \w Isaí|strong="H3448"\w* dijo \w a|strong="H3068"\w* su \w hijo|strong="H1121"\w* \w David|strong="H1732"\w*: \w Toma|strong="H3947"\w* \w ahora|strong="H4994"\w* una medida\f + \fr 17:17 \ft Medida de 22 litros.\f* \w de|strong="H1121"\w* \w este|strong="H2088"\w* grano \w tostado|strong="H7039"\w* y \w estos|strong="H2088"\w* \w diez|strong="H6235"\w* \w panes|strong="H3899"\w* para tus hermanos. Llévalos pronto al \w campamento|strong="H4264"\w* \w a|strong="H3068"\w* tus hermanos.
\v 18 Lleva también estos \w diez|strong="H6235"\w* \w quesos|strong="H2757"\w* para el \w jefe|strong="H8269"\w* \w de|strong="H8269"\w* 1.000, y mira si tus hermanos están \w bien|strong="H7965"\w*. Trae noticias \w de|strong="H8269"\w* ellos,
\v 19 pues \w Saúl|strong="H7586"\w* y \w ellos|strong="H1992"\w*, y \w todos|strong="H3605"\w* \w los|strong="H1992"\w* hombres \w de|strong="H5973"\w* \w Israel|strong="H3478"\w* luchan \w contra|strong="H5973"\w* \w los|strong="H1992"\w* \w filisteos|strong="H6430"\w* \w en|strong="H5973"\w* \w el|strong="H5973"\w* \w valle|strong="H6010"\w* \w de|strong="H5973"\w* Ela.
\p 
\v 20 \w Por|strong="H5921"\w* \w la|strong="H5921"\w* \w mañana|strong="H1242"\w*, \w David|strong="H1732"\w* \w se|strong="H5921"\w* \w levantó|strong="H5375"\w* temprano, \w y|strong="H5921"\w* \w dejó|strong="H5203"\w* \w el|strong="H5921"\w* \w rebaño|strong="H6629"\w* \w al|strong="H5921"\w* cuidado \w de|strong="H5921"\w* un \w guarda|strong="H8104"\w*. \w Tomó|strong="H5375"\w* \add las provisiones\add* \w y|strong="H5921"\w* \w fue|strong="H3212"\w* \w como|strong="H5921"\w* \w Isaí|strong="H3448"\w* \w le|strong="H5921"\w* \w mandó|strong="H6680"\w*. \w Y|strong="H3068"\w* \w llegó|strong="H3212"\w* \w al|strong="H5921"\w* campamento cuando \w el|strong="H5921"\w* \w ejército|strong="H2428"\w* \w salía|strong="H3318"\w* \w en|strong="H5921"\w* \w orden|strong="H6680"\w* \w de|strong="H5921"\w* \w batalla|strong="H4421"\w* \w y|strong="H5921"\w* daba \w el|strong="H5921"\w* grito \w de|strong="H5921"\w* \w guerra|strong="H4421"\w*.
\v 21 Se dispusieron en orden de batalla, tanto \w Israel|strong="H3478"\w* como los \w filisteos|strong="H6430"\w*, ejército \w contra|strong="H3478"\w* ejército.
