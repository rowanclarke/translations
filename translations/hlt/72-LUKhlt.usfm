\s1 Khoboei Cadong  
\p
\v 18 \w Jesuh|strong="G2424"\w* te \w boei|strong="G0758"\w* \w pakhat|strong="G5100"\w* loh a \w dawt|strong="G1905"\w* tih, “\w Saya|strong="G1320"\w* \w then|strong="G0018"\w*, \w mebang|strong="G5101"\w* ka \w saii|strong="G4160"\w* nen lae \w dungyan|strong="G0166"\w* \w hingnah|strong="G2222"\w* ka \w pang|strong="G2816"\w* eh?” a \w ti|strong="G3004"\w* nah.   
\p
\v 19 Te \w dongah|strong="G1161"\w* \w anih|strong="G0846"\w* te \w Jesuh|strong="G2424"\w* \w loh|strong="G3588"\w*, \wj “ \+w Balae|strong="G5101"\+w* tih \+w kai|strong="G3165"\+w* he \+w then|strong="G0018"\+w* na \+w ti|strong="G3004"\+w*? \+w Pathen|strong="G2316"\+w* amah \+w bueng|strong="G1520"\+w* \+w pawt|strong="G3361"\+w* \+w atah|strong="G1487"\+w* aka \+w then|strong="G0018"\+w* a om \+w moenih|strong="G3762"\+w*\wj*.  
