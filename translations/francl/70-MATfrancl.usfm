\v 24 \w Jésus|strong="G2424"\w* \w leur|strong="G3739"\w* \w répondit|strong="G3004"\w* : « \w Je|strong="G1473"\w* \w vous|strong="G5210"\w* \w ferai|strong="G4160"\w*, \w moi|strong="G1473"\w* \w aussi|strong="G2504"\w*, \w une|strong="G1722"\w* \w question|strong="G3004"\w*, \w et|strong="G1161"\w*, \w si|strong="G1437"\w* \w vous|strong="G5210"\w* \w y|strong="G1161"\w* répondez, \w je|strong="G1473"\w* \w vous|strong="G5210"\w* \w dirai|strong="G2046"\w* \w de|strong="G1722"\w* \w quel|strong="G4169"\w* \w droit|strong="G1849"\w* \w je|strong="G1473"\w* \w fais|strong="G4160"\w* \w ces|strong="G3778"\w* \w choses|strong="G3588"\w* :
\v 25 \w Le|strong="G1722"\w* \w baptême|strong="G1722"\w* \w de|strong="G1537"\w* \w Jean|strong="G2491"\w*, \w d|strong="G1537"\w*’\w où|strong="G2228"\w* était-il ? \w du|strong="G1537"\w* \w ciel|strong="G3772"\w*, \w ou|strong="G2228"\w* \w des|strong="G1537"\w* \w hommes|strong="G1722"\w* ? « \w Mais|strong="G1161"\w* \w ils|strong="G1161"\w* faisaient \w en|strong="G1722"\w* \w eux-mêmes|strong="G3004"\w* \w cette|strong="G1722"\w* réflexion :
