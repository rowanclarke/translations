\id HOS - Tarok
\h Nlir aHoziya
\toc3 aHoz
\toc2 aHoziya
\toc1 Nlir aHoziya
\mt2 Nlir
\mt1 AHosheya
\mt2 Unəm uga nlà ìchu Inan
\c 1
\s1 ALár áHosheya
\p 
\v 1 Nnap nlà àYawe ɓa atak áHosheya uya àBeri ka̱ ashe nra iponzhi áUza̱ya, áYotam, áAzariya, áAhaz ká̱ ija áHizekiya, oponzhi oga aYahudi, kang ka̱ ashe nra iponzhi áYerobwam uponzhi oga aIsa̱rila, uya àYowash.
\s1 UChar àHosheya ká̱ ovan wò
\p 
\v 2 Nva̱ uYawe là nnàp ûHosheya nggəshi te, uza̱ là á na pa̱, <<Ga ɓu ka̱m uchar uga nnəm mmai na u mar ovan ka̱ ashe mmai, ka̱kul mbin nəm mmai chit ka̱ atak ǹyang ká̱ uYawe.>>
\v 3 Te uza̱ ga ka̱m uGoma uya àDiblayim. UGoma yar anyám mar uyennunggwan á na.
\p 
\v 4 Te uYawe là á na pa̱, <<Wor aɗiɗin pa̱ <UYizərel> ka̱kul i gbà̱ng nva̱ng ka̱t te, mi tar nzhi àYehu ká̱ mpyát iya̱m iɓá̱ngɓa̱ng ka̱kul nchə̀r va uza̱ tar ka̱ aYizərel. Te mi nak iponzhi iga nzhi àIsa̱rila i kùr.
\v 5 Kà̱ ilum va̱ ta te, mi ɓəkchi ìjang oIsa̱rila kà̱ mba̱nda̱m aYizərel.>>
\p 
\v 6 Uza̱ yar anyám kà̱ɗi mar uyenchar. Te uYawe là ûHosheya pa̱, <<Wor aɗiɗin pa̱ <UƊorka̱t,> ka̱kul mi yà ká̱ aɗor ka̱ apal nzhi àIsa̱rila ka̱t. Mi yar mpat óza̱ ka̱t, nkpak pa̱ ń fa ká̱ oza̱ a ga izwal.
\v 7 Te mi yà ka̱ aɗor ka̱ apal nzhi àYahudi. Mi ka̱mshi óza̱ ka̱ atak áYawe Inan oza̱. Mi fa ká̱ oza̱ ka̱ atak ìjang ká̱ ndokchi ka̱t. Ka̱ atak ìkum ká̱ ipəri, ka̱t te onəm oga ipəri ka̱t.
\p 
\v 8 <<Nva̱ngva̱ uchar va̱ ta pətar uƊorka̱t kà̱ mbyal te, uza̱ yar anyám mar uyennunggwan.
\v 9 Te uYawe là pa̱, wór aɗiɗin pa̱, <ONəmmika̱t,> ka̱kul pa̱ oIsa̱rila onəm mi ka̱t, kang mmami uYawe oza̱ ka̱t.>>
\s1 NSar nnap-nlà Inan óvan oga aIsa̱rila
\p 
\v 10 Káp ká̱ nnà te, ìyə̀l oIsa̱rila i ga ǹyà wa ashishiri aga ìwá va mí məma ka̱t te mí kukung ka̱t. Kang ka̱ atak va̱ mmá là óza̱ pa̱, <<Mmawo onəm mi ka̱t,>> te mí là óza̱ pa̱, <<Ovan Inan iga irirì.>>
\v 11 Te onəm oYahudi ká̱ onəm oIsa̱rila oza̱ i gwang ka̱ anung azəngtəng. Oza̱ i kyer unəm uga mpyal íshi oza̱ pa̱ uzəng. Oza̱ i fa i re mbin va̱ ta kang i myak i ga mpyal kà̱ mbin oza̱. ILum aYizərel va̱ ta i yà ìchumchum.
\c 2
\p 
\v 1 Wor ogənnang wo onunggwan pa̱, <<Onəm mi.>> Kang ogənnang wo ovan ochar pa̱, <<UYaɗor.>>
\s1 NNyám ntàn ká̱ nka̱mshi aIsa̱rila
\q1 
\v 2 O ra̱n ká̱ unang wo, o ra̱n ká̱ na
\q2 ka̱kul uza̱ uchar mi lap ka̱t,
\q2 kang mmami uɓəɓar lap ka̱t kpa.
\q1 Re uza̱ á tur ndər atak aga mmai ka̱ asa̱l awu wò,
\q2 kang ì kap ká̱ onəm oga nfəkchi mbibyal.
\q1 
\v 3 A yà pa ka̱t te, mi zəp na mi re ugunggur
\q2 kang mi re na umaləng wa nva mmá mar na.
\q1 Mi nak na uza̱ i kú ká̱ ndəng ngbà̱l,
\q2 wa ánəm va ka̱ ashe anyin,
\q2 kang mi ga̱ɓa̱n na i yà wa ǹzam nkpələng.
\q1 
\v 4 Mi nəm aɗor ovəvan ka̱t,
\q2 ka̱kul oza̱ ovan ova mmá mar ka̱ ashe mmai.
\q1 
\v 5 Ka̱kul unang oza̱ nəm mmai chit.
\q2 Uza̱ va̱ yar anyám oza̱ te á yà ká̱ ìwuswa ka̱t.
\q1 Ka̱kul uza̱ là pa̱, <<Mi yar nva̱ng ama̱nma̱n mi ovəngva̱ kà̱
\q2 nná iya̱m-nrì á mi ká̱ ndəng, ká̱ awulu ká̱ ìlukwan alinin,
\q2 ká̱ mmì ká̱ iya̱m ngwà.>>
\q1 
\v 6 Ka̱kul nva̱ ta te, mi ga nká asəsa̱l ká̱ izú, kang mi gún na ká̱ akamsəlang
\q2 uza̱ i ya asa̱l nfa ka̱t.
\q1 
\v 7 Uza̱ i wà nva̱ng oma̱nma̱n wò,
\q2 kang uza̱ i kpán oza̱ ka̱t.
\q1 Uza̱ i mwo oza̱, uza̱ i ya oza̱ ka̱t. Te uza̱ i là pa̱,
\q2 <<Mi le atak á ɓar mi ugəshi
\q2 ka̱kul á kàpkàp ntəm mmatmat á mi,
\q2 ká̱ ǹyangmata̱.>>
\q1 
\v 8 Te uza̱ nyi pa̱ mmami na kà̱ nná ìpirkur
\q2 ká̱ ndəng ìba̱ngba̱ng ǹsámsàm ká̱ mmì mpipye á na ka̱t.
\q1 Kang n tá aazurfa ká̱ azənariya á na
\q2 avəngva̱ oza̱ i nəm aBaal ká̱ ka̱t.
\q1 
\v 9 Ka̱kul nva̱ ta te, mi le mi yar ìpirkur
\q2 ká̱ ndəng ìba̱ngba̱ng mi ka̱ awalangwalang.
\q1 Te mi yar awulu ká̱ ìlukwan alinin,
\q2 va̱ pa̱ ká̱ ń gún imaləng á na ká̱ a.
\q1 
\v 10 Ǹyangmata̱ te, mi bol imaləngmaləng kà̱ ìwu oma̱nma̱nma̱nma̱n,
\q2 kang unəm uro yà i fa ká̱ na ka̱ awo mi ka̱t.
\q1 
\v 11 Mi nak nkpaktak nnəm nchang izər áIsa̱rila i kùr,
\q2 nchang izəzər ngga nfa apye apipye, ká̱ ìlum njul,
\q2 ká̱ nkpaktak oga nra nnaknak.
\q1 
\v 12 Mi lak ìba̱ngba̱ngba̱ngba̱ng ká̱ oga ikun ìpipyanpipyan
\q2 ivəngva uza̱ kà̱ nlà pa̱ oma ta amwa wò
\q1 va̱ oma̱nma̱n wò na wò.
\q2 Mi nak i təm ikun ikpá̱rkpà̱r,
\q1 izhé iga anyin i ri oza̱ pa̱ kpaktak.
\q1 
\v 13 Mi pyát á na ka̱kul oga nra ngga nnəm mɓut ngga nnəm nchang izər ìchər aBaal va̱ ta.
\q2 Ka̱ ashe oga nra va̱ ta te, uza̱ i shì oza̱,
\q1 uza̱ i mwak iya̱m ìsham, uza̱ i fa i yar nva̱ng oma̱nma̱n wò ká̱.
\q2 Mmami te uza̱ ka̱ng ká̱ mi. UYawe à là.
\q1 
\v 14 Ka̱kul nva̱ ta te, mi ga ntàng na mi ga ká̱ na ka̱ ashe ǹzam nkpələng.
\q2 Mi là nnàp á na ka̱ ashe nrwa ìgwak.
\q1 
\v 15 Ka̱ cho te, mi le ká̱ ìram ìba̱ngba̱ngba̱ngba̱ng á na,
\q2 mi nak mba̱nda̱m ndaktak i sat anung asa̱l aga nnak ìgwak.
\q1 Ka̱ cho nà uza̱ i ná ishi wò á mi wa nva̱ uza̱ ka̱ nəm ka̱ ashe nza̱m wò,
\q2 nnà ka̱ ashe nra va̱ uza̱ fa ka̱ ashe mbin aMasar á.
\q1 
\v 16 UYawe là pa̱, <<Ka̱ ashe nra va̱ ta te,
\q2 ɓu wór mi pa̱ <Áɓar mi,> ɓu yà ká̱ ngwór mi lap
\q2 pa̱, <ÁBaal mi> ka̱t.>>
\q1 
\v 17 Mi zəp oga aɗin aBaal ka̱ anunung,
\q2 mí wór oza̱ ká̱ aɗin oza̱ lap ka̱t.
\q1 
\v 18 Ka̱ ashe nra va̱ ta te, mi yar nsar nnap-nlà óza̱
\q2 ká̱ izhé iga anyin, ká̱ inyil,
\q1 ká̱ oga iya̱m iga nkpàng kà̱ mbin.
\q2 Kang mi chwan ìjang ká̱ ndokchi,
\q1 te ìkum i kùr kà̱ mbin,
\q2 te mi nak oza̱ i təm ká̱ ikángkáng.
\q1 
\v 19 Mi ka̱m ɓu, ɓu yà uchar mi mbyet mbyet,
\q2 mi ka̱m ɓu, ɓu yà uchar mi ka̱ ashe inəna̱n ká̱ nnandər,
\q2 ka̱ ashe mma̱n ngga nnandər ká̱ aɗor.
\q1 
\v 20 Mi ka̱m ɓu, ɓu yà uchar mi ka̱ ashe nnandər,
\q2 te ɓu nyi mi pa̱ uYawe.
\q1 
\v 21 UYawe là pa̱, <<Ka̱ ashe nra va̱ ta te,
\q2 mi ma̱n ápal aɓuɓur i nak ìva̱r i pəng ka̱ apambin.
\q1 
\v 22 Apal mbin i ná ìpirkur ká̱ ndəng ìba̱ngba̱ng,
\q2 ká̱ mmì, i yà kà̱ mbin aYizərel.
\q1 
\v 23 Te mi suk na kà̱ mbin va̱ ta ka̱kul ishi mi,
\q2 kang mi yà ká̱ aɗor ka̱ apal <AƊorka̱t.>
\q1 Mi là ónəm va̱ ka̱ n wór pa̱, <ONəmmika̱t> pa̱, <ONəmmi.>
\q2 Te oza̱ i là pa̱, <Mmaɓu Inan yi.> >>
\c 3
\s1 UHosheya le ká̱ uchar wò uga nnəm mmai.
\p 
\v 1 UYawe là á mi pa̱, <<Ga kà̱ɗi nyám mma̱n uchar ɓu va̱ unəm uro ma̱n na chit, uchar uva̱ umaimai. Ma̱n na wa nva̱ uYawe ma̱n oga aIsa̱rila káp ká̱ nva̱ oza̱ le ga atak inan iro kang oza̱ ɗom nzənkəng awar ìba̱ngba̱ng nva̱ mmá ná ìchər chit a.>>
\p 
\v 2 Te n yáp na ká̱ aazurfa pa̱ gba̱pchi ama̱n pa̱ tukun ká̱ ijiga pa̱ ìparəm iga ìbəshi.
\v 3 Te n là á na pa̱, <<Nkpak ɓu təm ká̱ mi nra pa̱ makmak. Kang wa nəm mmai, ka̱t te wa ga atak ánəm uro lap ka̱t, te mi nəm a ɓu wa nnà ta kpa.>>\fig Ìbəshi|alt="Barley" src="lb00102c.tif" size="chol" ref="3.2"\fig*
\p 
\v 4 Ka̱kul oIsa̱rila i təm nra pa̱ makmak i yà ká̱ uponzhi , ka̱t te unəm uchumchum ka̱t, i yà ká̱ nləfər iya̱m ipápà ka̱t te ìpang iyə́ryər ka̱t, i yà ká̱ ìlukwan ìkwoksok, ka̱t te ìchər iga ashe nzhi ka̱t.
\v 5 Kà̱ nva̱ng nva̱ ta te, onəm oIsa̱rila i le i mwo uYawe Inan oza̱ ká̱ uDawuda uponzhi oza̱. Oza̱ i ɓa ká̱ ntán izər ka̱ atak áYawe ka̱ ashe oga nra ngga nkùr anung ka̱kul nnap nnəna̱nnəna̱n.
\c 4
\s1 UYawe ya oIsa̱rila ká̱ mpat
\q1 
\v 1 O fe nnap-nlà àYawe, ónəm oga aIsa̱rila,
\q2 ka̱kul uYawe uwa yà ká̱ nnap-nlà ka̱ apal onəm oga mbin va̱ ta̱.
\q1 Ka̱kul nnandər, ká̱ mma̱n ngga nnandər yà ka̱t,
\q2 kang ǹnyi Inan á yà kà̱ mbin ta̱ ka̱t.
\q1 
\v 2 Nsóng anung, akwam, ngba̱l unəm,
\q2 ayi ká̱ mmai gang atak,
\q2 kang ntar nchə̀r ka̱ anung ka̱ anung.
\q1 
\v 3 Ka̱kul nva̱ ta te mbin vyap,
\q2 nkpaktak onəm va̱ ka̱ ashishe i kwarman.
\q1 Izhé iga anyin ká̱ oga inyil iga apaɓur,
\q2 ká̱ oga igwali ka̱ ashe ìwá i kú.
\q1 
\v 4 Káp ká̱ nnà te, kang unəm uro á ná mpat ûwanwò ka̱t,
\q2 kang uza̱ a pyen ka̱t.
\q1 Ka̱kul nnap-nlà va̱ ta̱ ka̱ apal ɓu,
\q2 ánəm uga mpyal awop.
\q1 
\v 5 Ó lə̀p ìfang ìzwam ká̱ alum,
\q2 unəm uga nlà ìchu Inan i lə̀p ìfang kpa nzəng ká̱ wo.
\q1 Kang mi zhì unang wo.
\q2 
\v 6 Onəm mi zhì chit ka̱ atak nlàng ǹnyi.
\q1 Ka̱kul pa̱ o yang ká̱ ǹnyi,
\q2 te n yang ká̱ wo kà̱ ǹyà onəm oga mpyal awop mi.
\q1 Ka̱kul o kong ká̱ nnap mpakpak Inan wo chit,
\q2 te mi kong ká̱ ovan wo kpa.
\q1 
\v 7 Wa nva̱ onəm oga mpyal awop kà̱ ǹyə́l te,
\q2 wa nnà ta nnap mɓá̱ngɓa̱ng kà̱ ngga mpyal.
\q2 Mi ga̱ɓa̱n ìzhàn oza̱ i təm iya̱m ìwuswa.
\q1 
\v 8 Oza̱ kà̱ nrì ká̱ ishi oza̱ ka̱ atak
\q2 nnap mɓá̱ngɓa̱ng onəm mi,
\q1 kang oza̱ i ná nkam irəng óza̱ pa̱
\q2 a ga mpyal ká̱ nnəm mpat.
\q1 
\v 9 Wa nva onəm kà̱ nnəm te, wa nnà ta kpa onəm oga mpyal awop,
\q2 mi ga nnyám ntàn oza̱, kang mi pyát nnap nnəm óza̱.
\q1 
\v 10 Oza̱ i ri iya̱m-nrì, ká̱ nnà te afu i yə́l oza̱ ka̱t.
\q2 Oza̱ nəm mmai, ká̱ nnà te oza̱ myak ka̱t.
\q2 Oza̱ kap ká̱ uYawe
\q1 
\v 11 ka̱kul ngwop ichər.
\q1 Ncè ká̱ ndəng ìba̱ngba̱ng ǹsámsàm,
\q2 yar nnap nnəm oza̱.
\q1 
\v 12 Onəm mí ram ichən ka̱ atak ìchər ìva̱ mmá nəm ká̱ akún,
\q2 kang idari iva̱k oza̱ i là iya̱m iva̱ óza̱ kà̱ ngga nfa.
\q1 ARuhu aga mmai á nak oza̱ kà̱ nlar,
\q2 oza̱ kap ká̱ Inan oza̱ chit ka̱kul mmai.
\q1 
\v 13 Oza̱ i ná nləfər ka̱ apal ìtə́ngtə́ng aɓam,
\q2 kang oza̱ i dung nggù ka̱ apal aɗuktum,
\q1 ká̱ akum ìkun ichir, ká̱ agwakchi, ká̱ iswáng va̱ ayì oza̱ chəchàng.
\q2 Ka̱kul nva̱ ta te, ovan wo ochar kà̱ nnəm mmai, kang oka wo i ram onunggwan.
\q1 
\v 14 Mi yà ká̱ nnyám ntàn ovan ochar wo,
\q2 nva̱ oza̱ nəm mmai ka̱t,
\q2 ka̱t te oka wo nva̱ oza̱ i ram onunggwan ka̱t.
\q1 Ka̱kul onunggwan ká̱ ishi oza̱ táng mmai,
\q2 kang i ná nləfər nzəng ká̱ ochar oga nnəm mmai kà̱ nzhi ìchər.
\q1 Onəm oga nlàng nkpán ìpir nnàp , i zhì.
\q1 
\v 15 áIsa̱rila, káp ká̱ mmai ɓu,
\q2 kang wa nak uYahudi a pat ka̱t.
\q1 Kang o ga aGilgal, ka̱t te aBet-avən ka̱t.
\q2 Kang o sóng anung ká̱ uYawe uga irirì ka̱t.
\q1 
\v 16 Ka̱kul oIsa̱rila kák ishi wa nkak ishi ìya ìna,
\q2 Te ǹyangmata̱, uYawe i kpak oza̱ kpak
\q2 wa ivan itam ka̱ atak nrì nnəna̱n ɗò?
\q1 
\v 17 UEfərayim gwang ishi ká̱ ìchər,
\q2 re na pa.
\q1 
\v 18 Nva̱ngva̱ oza̱ i gba̱l ká̱ ngwa iya̱m iwawa te,
\q2 oza̱ i ga mpyal ká̱ nnəm mmai.
\q2 Oza̱ ma̱n nnap nnəm ngga ìwuswa na ji.
\q1 
\v 19 Ǹyə̀r i wur oza̱ ka̱ ashe abasəm wò,
\q2 te oza̱ i yar ìwuswa ka̱ atak nná nləfər iya̱m ipápà oza̱.
\c 5
\s1 AKwali ka̱ apal oIsa̱rila.
\q1 
\v 1 O fe nva̱ ta̱ ónəm oga mpyal awop,
\q2 o gwong achwang á nzhi àIsa̱rila, ká̱ nzhi iponzhi .
\q1 Akwali nna yà ka̱ apal wo,
\q2 ka̱kul o təm ajəp chit ka̱ aMizpa,
\q2 o tong wa ìcha ìva mmá rwak ka̱ apal aɓam aTabor.
\q1 
\v 2 O fa iya̱mkak , kang o gbà̱ng chit ka̱ ashe ngbá̱ng onəm,
\q2 mi ga nnyám ntàn nkpaktak wo.
\q1 
\v 3 N nyi uEfərayim nyi, kang uIsa̱rila bwam á mi ka̱t,
\q2 ǹyangmata̱, aEfrayim, u mai byet,
\q2 uIsa̱rila vyap chit.
\q1 
\v 4 Nnap nnəm oza̱ re oza̱ pa̱ oza̱ a le atak Inan oza̱ ka̱t,
\q2 ka̱kul aruhu mmai nna yà ka̱ ashe oza̱,
\q2 oza̱ nyi uYawe oza̱ ka̱t.
\q1 
\v 5 Ǹrup ká̱ ishi oIsa̱rila kà̱ nnyám nnàp ka̱ apal ishi oza̱,
\q2 uIsa̱rila ká̱ uEfərayim lə̀p ìfang ka̱kul mpat oza̱,
\q2 kang uYahudi kpa, i ru nzəng ká̱ oza̱.
\q1 
\v 6 Oza̱ i ga ká̱ iya̱m nkang ká̱ ina na ó mwo uYawe,
\q2 ká̱ nnà te, oza̱ i ya na ka̱t.
\q2 Ka̱kul uza̱ kap ká̱ oza̱ chit.
\q1 
\v 7 Oza̱ nəm nnandər ûYawe ka̱t,
\q2 oza̱ mar ovan mmai.
\q1 Ǹyangmata̱, ngwop apye apipye oza̱, i zhì oza̱ ká̱ ìram oza̱.
\s1 IKùm kà̱ ishimshe oIsa̱rila ká̱ oYahudi
\q1 
\v 8 O ɓur agbəshi ka̱ ashe aGibiyà, o ɓur nggapak ka̱ ashe aRama,
\q2 o wór awór ìkum ka̱ ashe aBet Ava̱n
\q2 ləp mpyal aBenjamin.
\q1 
\v 9 UEfərayim i təm agún kà̱ ìlum ìga nnyám ntàn.
\q2 N shet ká̱ iya̱m va̱ inandər ka̱ ashe akum ìjili àIsa̱rila.
\q1 
\v 10 Onəm oga mpyal oYahudi təm wa onəm oga ǹsəng aswari mbin.
\q2 Mi zuk mmən ìkum mi ka̱ apal oza̱ wa ndəng nnángnáng.
\q1 
\v 11 Mmá kà̱r uEfərayim, akwali dungshi na chit.
\q2 Ka̱kul uza̱ nak ìgwak kəkam kà̱ ngwop ìchər.
\q1 
\v 12 Ka̱kul nva̱ ta te, n təm wa ìgəmək ûEfərayim,
\q2 wa iya̱m imwanmwan n̂zhi aYahudi.
\q1 
\v 13 Kà̱ nva̱ngva̱ uEfərayim ya arwa wò,
\q2 kang uYahudi ya aɓang wò te,
\q1 uEfərayim ga aAshur kang a re ǹre ka̱ atak aponzhi uchumchum oga aAshur,
\q2 ká̱ nnà te, uza̱ i yà ká̱ mbyáp kang i tàn aɓəɓang ka̱t.
\q1 
\v 14 Ka̱kul mmami wa ìlir ka̱ atak aEfrayim,
\q2 kang wa ìyen nza̱m ìlir kà̱ nzhi àYahudi.
\q1 Mmami na ká̱ ishi mi, mi kan oza̱ te mi ga,
\q2 Mi yar oza̱ mi fa ká̱, unəm uro yà i vyat oza̱ ka̱t.
\q1 
\v 15 Mi le mi ga atak mi,
\q2 ya oza̱ i ma̱n ká̱ mpat oza̱ kang.
\q1 Te oza̱ i ram mi ka̱ ashe mɓək anung,
\q2 oza̱ i mwo mi ká̱ mɓa̱ng ìwu.
\c 6
\s1 IYa̱m va̱ onəm là
\q1 
\v 1 <<Ɓa, re í le atak áYawe,
\q1 ka̱kul uza̱ kan yi pa̱ nyimənnyimən,
\q2 kang uwa i tàn yi.
\q1 Uwa nak aɓang á yi,
\q2 kang uwa i sar á yi.
\q1 
\v 2 Kà̱ nva̱ng nra pa̱ mparəm te, uza̱ i fələk yi
\q2 ka̱ apal nra ngga nshatɗing te, uza̱ i wong ká̱ yi,
\q2 kang í təm kà̱ mpipyal.
\q1 
\v 3 Re í zhat na í nyi uYawe,
\q2 ka̱kul mɓəɓa nnandər wa ntàn atak.
\q1 Uza̱ i ɓa atak yi wa ìva̱r,
\q2 wa ìva̱r ìga amə́ng va i shim mbin.>>
\s1 IYa̱m va̱ Inan là
\q1 
\v 4 Iza̱ mi nəm ká̱ ɓu yà aEfrayim?
\q2 Iza̱ mi nəm ká̱ ɓu yà áYahudi?
\q1 Mma̱n nva̱ o ma̱n mi te, wa ìnanəng,
\q2 ká̱ ìmimyang ìva i lyangshin pa̱ kəlak.
\q1 
\v 5 Ka̱kul nva̱ ta te, mi kan wo ka̱ atak onəm oga nlà ìchu Inan,
\q2 te mi gbá̱ng wo ka̱ atak nnap-nlà ngga anung mi,
\q2 kang akwali wo i watar pa̱ vələm wa aməlam.
\q1 
\v 6 Ka̱kul n ɗom mma̱n, nná nləfər iya̱m ipápà ka̱t,
\q2 kang ǹnyi Inan ji iya̱m inana iga nshì ji.
\q1 
\v 7 Oza̱ ɓəkchi nsar nnap-nlà wa aAdamu,
\q2 kang oza̱ nəm nnandər á mi ka̱t.
\q1 
\v 8 AGileyat ìtong onəm onga,
\q2 awuwo ká̱ nchə̀r onəm va uza̱ gbá̱ng.
\q1 
\v 9 Wa nva onəm oga ayi ra anyimnyal onəm te,
\q2 wa nnà ta idonka̱ng onəm oga mpyal awop.
\q1 Oza̱ gbá̱ng onəm ka̱ asa̱l aShekem,
\q2 oza̱ i nəm inga iva ɓyen nlà ka̱t.
\q1 
\v 10 N ya iya̱m iga nnəm ajan
\q2 ka̱ ashe nzhi àIsa̱rila.
\q1 UEfərayim ná ishi wò kà̱ ngwop ìchər,
\q2 uIsa̱rila vyap ishi wò chit.
\q1 
\v 11 Mmawo kpa áYahudi, n nak ìlum mɓən iya̱m chit ka̱kul ɓu,
\q2 nva̱ngva̱ mi le ká̱ onəm mi ka̱ atak izwal.
\c 7
\q1 
\v 1 Awalang va kpaktak mmá ɗom ntàn arwa áIsa̱rila te,
\q2 mpat aEfrayim ká̱ nnap mɓá̱ngɓa̱ng oga aSamariya i pwa,
\q1 Ka̱kul nnandər oza̱ yə́l awo ka̱t,
\q2 unəm uga ayi i chwan atak,
\q2 kang onəm oga nra anyimnyal i vyat onəm ka̱ asa̱l.
\q1 
\v 2 Ká̱ nnà te, oza̱ nak ishi ká̱ pa̱,
\q2 mi rəng nkpaktak nnap mɓá̱ngɓa̱ng oza̱ rəng ka̱t.
\q1 Ǹyangmata̱ te, nnap nnəm oza̱ gáng oza̱
\q2 mmami kà̱ ǹyəya.
\q1 
\v 3 Oza̱ i nak ìgwak i chàng uponzhi ká̱ nnap mɓá̱ngɓa̱ng oza̱,
\q2 kang onəm oga mpyal ká̱ akwam oza̱.
\q1 
\v 4 Nkpaktak oza̱ onəm oga nnəm mmai,
\q2 Nɗom mmai oza̱ wa ìgəng iga ngwàng iya̱m ìva á sur pa̱ gənggəng,
\q1 ìva onəm oga ngwàng iya̱m re nɗa̱mshi apəpər,
\q2 kà̱ mɓan nkal mma̱k á ga chu nfifyil.
\q1 
\v 5 Kà̱ ìlum àponzhi te,
\q2 ncè gbá̱ng onəm oga mpyal,
\q2 uza̱ gwang awo ká̱ onəm lákchilàkchi.
\q1 
\v 6 Ka̱kul ìgwak oza̱ sur wa ìgəng ìga ngwàng iya̱m,
\q2 oza̱ i ra anyimnyal ka̱ ashe ìgwak.
\q1 Nlak ìgwak oza̱ i ri pa̱ shìriri nkpaktak ìzwam,
\q2 ká̱ anung ìpin te, i ri wa aməlam apər.
\q1 
\v 7 Nkpaktak oza̱ sur wa ìgəng ìga ngwàng iya̱m,
\q2 Oza̱ i zhì onəm ochumchum oza̱.
\q1 Nkpaktak oponzhi oza̱ tàk chit,
\q2 unəm uro yə́ng á mi ka̱t.
\s1 AIsa̱rila gwang ishi ká̱ oɗyanəm
\q1 
\v 8 UEfərayim gwang ishi wò ká̱ onəm,
\q2 uza̱ yà chit wa nzənkəng nva mmá ga̱ɓa̱n ka̱t.
\q1 
\v 9 Oɗyanəm ri nkəkam chit uza̱ nyi ka̱t,
\q2 kang izwál fa á na kpa uza̱ nyi ka̱t.
\q1 
\v 10 Ǹrup ká̱ ishi oIsa̱rila nyám nnàp ka̱ apal ishi oza̱,
\q2 káp ká̱ nnà te oza̱ yang ká̱ nle atak áYawe, Inan oza̱,
\q2 kang ka̱ ashe nkpaktak iya̱m va̱ ta̱ te, oza̱ mwo na ka̱t kpa.
\q1 
\v 11 Te uEfərayim wa ìləkpar ìpərəkpərək, i rəng nnap ka̱t,
\q2 oza̱ wór aMasar, kang oza̱ ga aAshur.
\q1 
\v 12 Nva̱ oza̱ i yà kà̱ ngga te, mi màng ìcha mi ka̱ apal oza̱,
\q2 mi dapchi oza̱ i vàng wa ìnyil ìga apaɓur,
\q2 Mi nyám ntàn oza̱ ka̱kul iya̱m iɓá̱ngɓa̱ng iva̱ oza̱ nəm.
\q1 
\v 13 Álak ká̱ oza̱ chit, ka̱kul oza̱ chəng atak mi,
\q2 nzhì nà nji oza̱ ka̱kul oza̱ fa iya̱mkak ká̱ mi.
\q1 N ɗom pa̱ ń fa ká̱ oza̱, ká̱ nnà te oza̱ náp akwam ka̱ apal mi.
\q1 
\v 14 Oza̱ yə́ng á mi ká̱ ìgwak pa̱ ìzəng ka̱t,
\q2 nva̱ oza̱ i yə́ng ka̱ apal alyer oza̱ á.
\q1 Oza̱ i chal ìchər oza̱, ka̱kul ìpirkur ká̱ ndəng ìba̱ngba̱ng ǹsámsàm ,
\q2 oza̱ ɓut ishi oza̱ le re atak mi.
\q1 
\v 15 Mmami nà n ɗyang iya̱m óza̱ kang n kam ìgwal óza̱,
\q2 ká̱ nnà te, oza̱ ran iya̱m iɓá̱ngɓa̱ng ka̱ apal ishi mi.
\q1 
\v 16 Oza̱ ga̱ɓa̱n asəm á mi,
\q2 oza̱ yà chit wa ìjang ìga nlàm atak.
\q1 Onəm oga mpyal oza̱ i tàk ka̱ atak ndokchi,
\q2 ka̱kul nvyap ngga aɓələm oza̱.
\q1 Oza̱ i təm iya̱m iga nnáp avyal,
\q2 kà̱ mbin aMasar.
\c 8
\s1 MMa ra̱n ká̱ oIsa̱rila ka̱kul iya̱m ngwop
\q1 
\v 1 Ɓur agbəshi na u won onəm ká̱,
\q2 okpa ìkum kà̱ nvàng ka̱ apal nzhi àYawe wa nkumà ngga̱p .
\q1 Ka̱kul oza̱ fən nsar nnap nla mi,
\q2 kang oza̱ fa iya̱mkak ká̱ nnap mpakpak mi.
\q1 
\v 2 AIsa̱rila yə́ng á mi pa̱,
\q2 <<Á Inan, í nyi ɓu nyi.>>
\q1 
\v 3 uIsa̱rila yang ká̱ iya̱m inəna̱n á nak te,
\q2 ukpa ìkum i ɓàk na.
\q1 
\v 4 Oza̱ kyep oponzhi nzəng ká̱ nram ichən ka̱ atak mi ka̱t,
\q2 oza̱ kyep onəm oga mpyal ká̱ ǹnyi mi ka̱t.
\q1 Oza̱ la ìchər ká̱ aazurfa ká̱ azənariya,
\q2 ka̱kul nva̱ ta te oza̱ i ga nzhì.
\q1 
\v 5 Ónəm oga aSamariya, n yang ká̱ ìya ìna wo chit.
\q2 Mmami ká̱ nlak ìgwak pa̱ makmak ka̱ apal wo.
\q2 Te azəmwo ó yà ká̱ mpat ka̱t yà?
\q1 
\v 6 Ka̱kul ìchər va̱ ta̱ fa ka̱ atak áIsa̱rila,
\q2 unəm uga inok awo à nəm, Inan ka̱t.
\q1 Iya ìna oga aSamariya va̱ ta,
\q2 mí chwan pa̱ nyimənnyimən.
\q1 
\v 7 Ka̱kul oza̱ suk ayə́r,
\q2 kang oza̱ i ɓən ǹvivyil.
\q1 Azang ikur mar ishi ka̱t,
\q2 ivəngva̱ fa ká̱ ishi te, nəm apir ka̱t,
\q2 kang oza̱ a məmar te, oɗyanəm i ri.
\q1 
\v 8 Mma ma̱ka̱n uIsa̱rila chit,
\q2 ǹyangmata̱ oza̱ kà̱ ishimshe oga mbin
\q2 wa iya̱m mme iswangswang,
\q1 
\v 9 ka̱kul oza̱ ɓa ga aAshur chit,
\q2 wa ìɗongya ìva ká̱ nkùkwa,
\q2 uEfərayim ná ishi wò oga mbin ka̱kul nram nka̱mshi.
\q1 
\v 10 Káp ka̱ nva̱ oza̱ yáp ká̱ ishi oza̱ ka̱ ashe oga mbin te,
\q2 ǹyangmata̱ mi ga mɓut oza̱ ka̱kul akwali.
\q1 Mɓək anung oza̱ i yen ká̱ ìyə̀l oza̱
\q2 ka̱ avəng áponzhi uchumchum uga aAshur.
\q1 
\v 11 Nva̱ uEfərayim nak atak nshì iya̱m awop yə́l te,
\q2 oga atak va̱ ta ga̱ɓa̱n yà atak nnəm nnap mɓá̱ngɓa̱ng.
\q1 
\v 12 N lir nnap mpakpak mi óza̱ pa̱ nkyak,
\q2 te oza̱ yar pa̱ nnap nro nggafak.
\q1 
\v 13 Oza̱ ná nləfər iya̱m ipápà á mi ka̱kul nrì izhìzhe,
\q2 uYawe fe nchang oza̱ ka̱t.
\q1 Ǹyangmata̱ uza̱ i rəng nnap mɓá̱ngɓa̱ng oza̱,
\q2 kang i nyám ntàn óza̱ ka̱kukul,
\q2 oza̱ i le aMasar.
\q1 
\v 14 uIsa̱rila ka̱ng ká̱ unəm uga nnəm wò chit,
\q2 kang à me oga n̂zhi nchumchum.
\q1 UYahudi te, á me ìtong iga akamsəlang yə́l.
\q2 Te mi re ǹre ká̱ apər ka̱ apal ìtong oza̱,
\q2 i zhì oga akamsəlang oza̱ kpa.
\c 9
\s1 MPyát nva mí nəm oIsa̱rila ka̱kul nnandər oza̱ yə́l awo ka̱t
\q1 
\v 1 óIsa̱rila, kang o lan wa nva̱ mbín nro i lan ka̱t,
\q2 ka̱kul o nəm mmai chit o kap ká̱ Inan wo.
\q2 O ma̱n nnap amwa achar umaimai kà̱ nza̱ atak mpək ìpirkur nggo.
\q1 
\v 2 Atak mpək ìpirkur ká̱ atak nkáng ndəng ìba̱ngba̱ng ǹsámsàm i ri ká̱ oza̱ ka̱t,
\q2 kang ndəng ìba̱ngba̱ng ncángchàng i yen oza̱.
\q1 
\v 3 Oza̱ i təm kà̱ mbin àYawe ka̱t.
\q2 Ka̱ɗor nva̱ ta te, uEfərayim i le aMasar,
\q2 kang oza̱ i ri iya̱m-nrì ivyapvyap ka̱ aAshur.
\q1 
\v 4 Oza̱ i ná imwa ndəng ìba̱ngba̱ng ǹsámsàm ûYawe ka̱t,
\q2 kang nləfər iya̱m ipápà oza̱ i ná nchang ìgwak á na ka̱t.
\q1 Nləfər oza̱ i yà wa nzənkəng onəm oga ǹyə́ng ikú,
\q2 nkpaktak onəm va̱ i ri te, i nak oza̱ i vyap.
\q1 Nzənkəng oza̱ i yà ka̱kul ayang afu oza̱,
\q2 i tar ashe nzhi àYawe ka̱t.
\q1 
\v 5 Iza̱ o nəm kà̱ ìlum ìnaknak ìga nnəm nchang izər,
\q2 kà̱ ìlum ìga nri ká̱ ngwa àYawe yà?
\q1 
\v 6 Kang a yà pa̱ oza̱ a chəng ka̱ atak nzhì te,
\q2 aMasar i ɓut oza̱, kang aMop\f + \fr 9.6 \ft ìtong va̱ ka̱ atak nli awap achumchum.\f* i li oza̱.
\q1 Mí wur iya̱m akúp ká̱ aazurfa oza̱,
\q2 izú i fa ka̱ ashe aghal oza̱.
\q1 
\v 7 Ìlum iga nnyám ntàn ɓa chit,
\q2 ìlum ìga mmumwa ɓa chit. Re oIsa̱rila a nyi.
\q1 O là pa̱, <<Unəm uga nlà ìchu Inan mpərək,
\q2 kang unəm uga aruhu á swa nggatswa nggat,>>
\q2 ka̱kul mmák mpat ká̱ ǹyang nva̱ o yang mi.
\q1 
\v 8 Unəm uga nlà ìchu Inan ka̱ atak nka̱mshi Inan,
\q2 uwa unəm uga mpángchí uEfərayim,
\q1 káp ká̱ nnà te ajəp ánəm uga ngba̱l ìzhe gáng na,
\q2 mí yang na kpa ka̱ ashe nzhi ìNənan.
\q1 
\v 9 Oza̱ gbà̱ng chit ka̱ ashe nlàng nnəm nnandər
\q2 wa nva ka̱ ashe nra aGibiyà.\f + \fr 9.9 \ft Nnap onəm oga akwali 19.\f*
\q1 UYawe i rəng nnap mɓá̱ngɓa̱ng oza̱,
\q2 kang i nyám ntàn óza̱.
\q1 
\v 10 Nva̱ ka̱ n yak uIsa̱rila te, uza̱ wa awar ìba̱ngba̱ng ka̱ ashe anyin.
\q1 N ya okəka wo wa awar aga nggəshi ka̱ izər ìpipyan ka̱ ashe nrəra.
\q1 Oza̱ ɓa aBaal Piyo te,
\q2 oza̱ gar ishi oza̱ îchə̀r.
\q1 Kang oza̱ təm iya̱m iga nnəm ajan wa ìchər va oza̱ ma̱n.
\q1 
\v 11 Ìzhàn aEfrayim i wong i ga wa ìnyil,
\q2 amar, ntəm ká̱ anyám, ká̱ ǹyar anyám i yà ka̱t.
\q1 
\v 12 Kang a yà pa̱ oza̱ a kang ovan oza̱ te,
\q2 mi nak oza̱ i lang nza̱ uzəngtəng nggo.
\q1 Álak ká̱ oza̱ chit, nva̱ngva̱ mi re oza̱ ká̱ nkùkwa á.
\q1 
\v 13 N ya uEfərayim wa aTaya,
\q2 mmá suk ka̱ ashe atak anəna̱n.
\q1 Te uEfərayim i fa ká̱ ovan wò ka̱kul nzhì.
\q1 
\v 14 Ná óza̱ áYawe, iza̱ màl pa̱ ú ná yà?
\q2 Ná afu aga ǹwak ká̱ mbyal ngga ǹyà ká̱ ndəng ka̱t.
\q1 
\v 15 Nkpaktak inga oza̱ nyám ka̱ aGilgal,
\q2 n yang oza̱ ka̱ ta ka̱kul nnap nnəm oza̱ ǹngha.
\q1 Mi ɓàk oza̱ i fa ka̱ ashe nzhi mi,
\q2 mi ma̱n oza̱ lap ka̱t.
\q1 Nkpaktak onəm oga mpyal oza̱,
\q2 onəm oga nfa iya̱mkak .
\q1 
\v 16 Mmá tul uEfərayim chit, alə̀ng oza̱ wom,
\q2 oza̱ i mar ovan lap ka̱t.
\q1 Kang a yà pa̱ oza̱ a mar te mi gbá̱ng,
\q2 iya̱m inəna̱n iga afu oza̱ áta.
\q1 
\v 17 Inan mi yang oza̱,
\q2 ka̱kul oza̱ gwong achwang kà̱ na ka̱t,
\q2 te oza̱ i yà onəm rá nggangra nggang ka̱ ashe oga mbin.
\c 10
\s1 Inan i nyám ntàn ûIsa̱rila
\q1 
\v 1 uIsa̱rila ìba̱ngba̱ng va á ɓyen pa̱ shat,
\q2 uza̱ i ná awar ishi wò pa̱ makmak.
\q1 Ka̱kul mmak awuwar te,
\q2 uza̱ myak atak nshì iya̱m awop.
\q1 Ka̱kul mɓyen iya̱m iga mbibin te,
\q2 uza̱ sham ìsham oga ala̱ka̱n ayə́ryər wò.
\q1 
\v 2 Ìgwak oza̱ i lam atak ǹyangmata̱,
\q2 nkpak pa̱ oza̱ á yar mpəpat.
\q1 UYawe i chwan atak nshì iya̱m ngwop
\q2 kang uza̱ i shin oga ala̱ka̱n oza̱ ayə́ryər.
\q1 
\v 3 Oza̱ kà̱ nlà pa̱, <<Í yà ká̱ uponzhi ka̱t,
\q2 ka̱kul i nəm ayər áYawe ka̱t.
\q1 Ká̱ í yà ká̱ uponzhi te,
\q2 iza̱ uza̱ ká̱ nəm á yi yà?>>
\q1 
\v 4 Oza̱ là oga nnap-nlà na pa mwang.
\q2 Oza̱ sóng anung ká̱ ǹyar nsar nnap-nlà ngga akwam,
\q1 te akwali fa wa ipəpà ìga akàl
\q2 ka̱ ashe ìram ìwapwap.
\q1 
\v 5 Ayər i nəm onəm oga ntəm ka̱ ashe aSamariya,
\q2 ka̱kul ìchər ivan ina iga aBet Ava̱n.
\q1 Onənəm ká̱ onəm oga mpyal awop i təm ká̱ aɗor ka̱kukul,
\q2 oza̱ i tán ka̱kul ìzhəzhan kap ká̱ oza̱ chit.
\q1 
\v 6 Mí yar mí ná imwa,
\q2 ûponzhi uchumchum uga aAshur ká̱.
\q1 Ìwuswa i yar uEfərayim,
\q2 ìwuswa i nəm uIsa̱rila ka̱kul ichəchen.
\q1 
\v 7 IPonzhi oga aSamariya i zhì,
\q2 wa akún ka̱ apal ndəng.
\q1 
\v 8 Mi zhì atak awop aga apal oga aɗuktum va̱ ka̱ aAva̱n,
\q2 atak va oIsa̱rila i nəm inga ka̱ á,
\q1 izú ká̱ nkpakshi, i rup ka̱ atak nshì iya̱m awop oza̱,
\q2 oza̱ i là ipáng ichumchum pa̱, <<Gún yi.>>
\q1 Oza̱ i là oga aɗuktum pa̱ <<Ó tàk ka̱ apal ishi yi.>>
\q1 
\v 9 <<óIsa̱rila, á ɓan ka̱ ashe oga nra aGibiyà
\q2 nnà o nəm nnap mɓá̱ngɓa̱ng.
\q1 Á ɓàn matmat kang mmawó kà̱ ngga mpyal ka̱ ashishe,
\q2 te ìkum mul oza̱ ka̱ aGibiyà ka̱t ɗò?
\q1 
\v 10 ÌLum i rwam te, mi nyám ntàn óza̱,
\q2 oga mbin i gwang ishi i lung oza̱,
\q2 ka̱kul mpyát oga nnap mɓá̱ngɓa̱ng oza̱.
\q1 
\v 11 UEfərayim wa ìya ìna ìva mmá ɗyang ntàn á na,
\q2 ìva fe nchang mpək ìpirkur,
\q2 kang n ná nfe nchang á na.
\q1 Te mi nak ayok aɗəkɗək kà̱ ishishak,
\q2 mi nak uYahudi pa̱ a dap ashan,
\q2 uYakup nnyi te, i dap ashan aga mbəbək.
\q1 
\v 12 Ó suk nnap nnəna̱n íshi wo
\q2 te ó ɓən mma̱n nva i kùr ka̱t.
\q1 O kà̱p oga mpom wo,
\q2 ka̱kul awalang aga nram uYawe nəm chit.
\q1 Na uza̱ a pəng,
\q2 nnap nnəna̱n ka̱ apal wo.
\q1 
\v 13 O shàng iya̱m inga
\q2 o ɓən mɓək anung.
\q2 O ri imwa nnáp akwam.>>
\q1 Ka̱kul o təp asəm kà̱ nkàm wo,
\q2 ká̱ ìyə̀l onəm ìkum ova̱ mmawó ká̱.
\q1 
\v 14 Ka̱kul nva̱ ta te, achu ìkum i ga ngwong
\q2 kà̱ ishimshe onəm wo.
\q1 Mí shin nkpaktak akamsəlang wo,
\q2 wa nva uShalman zhì aBet Arbel ka̱ alum ìkum,
\q2 kang onang ká̱ ovan tàk kà̱ mbin kú á.
\q1 
\v 15 Wa nnà ta mí nəm awo ónəm oga aBetel,
\q2 ka̱kul mmak inga wo.
\q1 Ká̱ iɓotak na byet te,
\q1 mí gba̱l uponzhi oga aIsa̱rila.
\c 11
\s1 MMa̱n Inan ka̱kul áIsa̱rila
\q1 
\v 1 Kà̱ ìlum va̱ uIsa̱rila ka̱ yà uyen te, m ma̱n na,
\q2 kang ka̱ ashe mbin aMasar nà n wór uyen mi fa.
\q1 
\v 2 Mi yà kà̱ ngwór oza̱ te,
\q2 i dong oza̱ kà̱ nchəng atak mi.
\q1 Oza̱ ga mpyal ká̱ nná nləfər oga ìchər aBaal,
\q2 kang oza̱ i dung oga îchə̀r.
\q1 
\v 3 Mmami na kà̱ nɗyang achen uEfərayim
\q2 n kpán oza̱ ká̱ awo mi.
\q1 Ká̱ nnà te, oza̱ nyi pa̱
\q2 mmami na n tàn oza̱ ka̱t.
\q1 
\v 4 N kpak oza̱ ká̱ nrwa ìgwak
\q2 ká̱ asang aga mma̱n.
\q1 Mmami wa ánəm ùva̱ yar ayok kà̱ ishak oza̱,
\q2 kang n kúchi n ná iya̱m-nrì óza̱.
\q1 
\v 5 Oza̱ i le mbin aMasar,
\q2 kang aAshur i təm uponzhi oza̱,
\q2 ka̱kul oza̱ yang ká̱ ngga̱ɓa̱n asəm n̂nap mɓá̱ngɓa̱ng.
\q1 
\v 6 Ǹdokchi i kandar kà̱ ìtong oza̱,
\q2 i chwan oga anung asa̱l ìtong oza̱,
\q2 kang i ri oza̱ ka̱kul ichən oza̱ inga.
\q1 
\v 7 Onəm mi yar pa̱ o ga̱ɓa̱n o re mi.
\q2 Oza̱ kà̱ ngwór atak achumchum,
\q2 kang i yà ká̱ ǹrup ká̱ oza̱ ka̱t.
\q1 
\v 8 Wa ǹsang mi kap ká̱ ɓu yà, aEfrayim?
\q2 Wa ǹsang mi na ɓu ka̱ atak ro yà, áIsa̱rila?
\q1 Wa ǹsang mi na ɓu wa aAdima yà?
\q2 Wa ǹsang mi nak ɓu wa aZeboyim yà?
\q1 Ìgwak mi ga̱ɓa̱n chit,
\q2 kang ǹrusok afu mi chi izər.
\q1 
\v 9 Mi yà ká̱ nnəm inok ká̱ nlak ìgwak mi ka̱t,
\q2 mi zhì uEfərayim lap ka̱t,
\q1 Ka̱kul mmami Inan, unəm ka̱t,
\q2 uNəna̱n, kà̱ ishimshe wo
\q2 mi ɓa ka̱ ashe ǹfə́l ìgwak ka̱t.
\q1 
\v 10 Oza̱ i yar nva̱ng àYawe,
\q2 uza̱ i ɗum wa ìlir.
\q1 Kà̱ nva̱ngva̱ uza̱ i ɗum te,
\q2 ovəvan i ɓa ká̱ nchəng ka̱ asa̱l ntar alum.
\q1 
\v 11 Ká̱ ngha̱n oza̱ i ɓa wa ìnyil ka̱ aMasar,
\q2 kang wa ìləkpar kà̱ mbin aAshur.
\q1 Te mi nak oza̱ i təm kà̱ nzhi oza̱,
\q2 uYawe à là.
\q1 
\v 12 UEfərayim gáng mi ká̱ akwam,
\q2 kang nzhi àIsa̱rila ká̱ nlàm atak.
\q1 UYahudi te, kà̱ nránggang ká̱ Inan,
\q2 kang uza̱ ká̱ nnandər ûNəna̱n.
\c 12
\q1 
\v 1 UEfərayim i kpak ayə́r,
\q2 uza̱ i wà ayə́r nvàngváng nza̱ nra nggo
\q2 kang i ga mpyal ká̱ mmar akwam ká̱ ìfan.
\q1 Uza̱ yar nsar nnap-nlà ká̱ aAshur,
\q2 kang i ga ká̱ mmì ka̱ aMasar.
\q1 
\v 2 UYawe uwa yà ká̱ nnap-nlà ka̱ apal áYahudi,
\q2 uza̱ i nyám ntàn ûYakup ka̱ apal achəchən,
\q2 kang uza̱ i mwa na i ma ká̱ nnap nnənəm.
\q1 
\v 3 Ka̱ ashe afu uza̱ kpán ndong ashar á gənang wò,
\q2 kang uza̱ chu unəm te, á ma nggwak ká̱ Inan.
\q1 
\v 4 Uza̱ ma nggwak ká̱ uma̱leka, á ga nəm igwan,
\q2 uza̱ yə́ng kang à chal nnap nnəna̱nnəna̱n.
\q1 Uza̱ gwang ká̱ Inan ka̱ aBetel,
\q2 kang Inan là nnàp ká̱ na.
\q1 
\v 5 UYawe, Inan uga nggatək,
\q2 aɗiɗin uYawe, a va mí rəng na ká̱.
\q1 
\v 6 Te o le atak Inan wo,
\q2 o nyám mma̱n ká̱ nnandər,
\q2 o təm ká̱ nlok Inan pa̱ ɗəkər.
\q1 
\v 7 Uza̱ ɗom nnap mmwar atak ká̱ asikel
\q2 aga mmwap onəm wa oga aKanana.
\q1 
\v 8 UEfərayim là pa̱, <<N təm unəm uga ndur chit,
\q2 m ɓut ìdur chit ka̱kul ishi mi
\q2 ka̱ ashe nkpaktak nlə̀m mi, mmá ya mpat kà̱ mi ka̱t.>>
\q1 
\v 9 Mmami uYawe, Inan wo,
\q2 uva̱ fa ká̱ wo kà̱ mbin aMasar.
\q1 Mi nak o təm ka̱ ashe aghal kà̱ɗi ,
\q2 wa kà̱ ìlum ìnaknak ìga nchang izər.
\q1 
\v 10 N là nnàp ká̱ onəm oga nlà ìchu Inan,
\q2 te n nyám oga alár pa̱ makmak
\q2 kang n gba oga nnàp ka̱ atak oza̱.
\q1 
\v 11 A yà pa̱ inga nna yà ka̱ aGileyat te,
\q2 nnandər uza̱ i yà iya̱m ro ka̱t.
\q1 Oza̱ ná nləfər ká̱ ina ka̱ aGilgal,
\q2 ká̱ nnà te, atak nshì iya̱m awop oza̱
\q2 i yà wa ipáng iɓutɓut ka̱ anung ìram.
\q1 
\v 12 UYakup chər ga mbin aAram,
\q2 ka̱ ta na uIsa̱rila nəm inok ka̱kul achar,
\q2 ka̱kul achar uza̱ kpak iya̱m nkang.
\q1 
\v 13 Ka̱ atak ánəm uga nlà ìchu Inan, uYawe fa ká̱ uIsa̱rila ka̱ ashe aMasar,
\q2 kang ka̱ atak ánəm uga nlà ìchu Inan mmá kpak na.
\q1 
\v 14 UEfərayim bəshi nlak ìgwak,
\q2 te uPonzhinənan i re nchəchər ka̱ apal ishishi,
\q2 kang i mwa nnap nnəm ngga ìwuswawuswa á na.
\c 13
\s1 Mí ga nzhì onəm aEfrayim.
\q1 
\v 1 Kà̱ nva̱ngva̱ uEfərayim là nnap te, izər tán ká̱ onəm,
\q2 mmá shep na ka̱ ashe aIsa̱rila,
\q2 ka̱kul uza̱ nəm mpat kà̱ ngwop aBaal, te nkpak uza̱ i kú.
\q1 
\v 2 Ǹyangmata̱, oza̱ ga mpyal ká̱ nnəm nnap mɓá̱ngɓa̱ng,
\q2 oza̱ nəm ìchər ka̱ atak aghan oza̱ ká̱ aazurfa îshi oza̱.
\q1 Nkpaktak oga ìchər va̱ ta te, iya̱m nnəm onəm oga inok awo,
\q2 onəm oga aIsa̱rila i là pa̱,
\q2 <<Onəm va̱ i ná nləfər te, oza̱ i má njàng ala̱ka̱n ìna.>>
\q1 
\v 3 Ka̱kul nva̱ ta te, oza̱ i yà wa ìnanəng iga ìpin,
\q2 kang wa ìmimyang ìva̱ i lyangshin ká̱ iɓotak.
\q1 I ga wa adùng va ayə́r i dà̱n ka̱ atak mpək ìpirkur,
\q2 kang wa nggù nva i fa kà̱ mɓol ayə́r nzhi.
\q1 
\v 4 Mmami uYawe, Inan wo,
\q2 ùva̱ fa ká̱ wo kà̱ mbin aMasar,
\q1 Inan iro yà o nyi ka̱t mmami,
\q2 unəm uga nka̱mshi uro yà ka̱t mmami na byet.
\q1 
\v 5 N ɗak ká̱ wo ka̱ ashe ǹzam nkpələng,
\q2 kà̱ mbin nva ìva̱r i pəng kà̱ ka̱t á.
\q1 
\v 6 Kà̱ nva̱ngva̱ n ri ká̱ oza̱ te afu yə́l oza̱,
\q2 afu yə́l oza̱ te, oza̱ nəm nkak ishi,
\q2 oza̱ ka̱ng ká̱ mi.
\q1 
\v 7 Te mi ru oza̱ wa ìlir,
\q2 wa ìdaməng mi ra anyimnyal oza̱ ka̱ asa̱l.
\q1 
\v 8 Mi fa óza̱ wa ìdəshìli ìva mmá wur ivəvan,
\q2 mi kan ìkwoksok oza̱.
\q1 Mi zhì oza̱ ka̱ ta wa ìlir,
\q2 mi kan oza̱ wa ìzhe ìga anyin.
\q1 
\v 9 Mi zhì ɓu, áIsa̱rila,
\q2 uda i ka̱mshi ɓu yà?
\q1 
\v 10 UPonzhi ɓu ka̱ chè ǹyangmata̱ pa̱ á ka̱mshi ɓu yà?
\q2 Onəm oga mpyal ɓu ka̱ chè ka̱ ashe nkpaktak itong ɓu,
\q2 ova̱ u là pa̱, <<Ná uponzhi ká̱ onəm oga mpyal á mi yà?>>
\q1 
\v 11 N ná uponzhi a ɓu ka̱ ashe nlak ìgwak mi,
\q2 kang n tur na le ka̱ ashe ǹfə́l ìgwak mi.
\q1 
\v 12 Mmá lur mpat aEfrayim chit,
\q2 nnap mɓá̱ngɓa̱ngɓa̱ngɓa̱ng ɓut chit ra.
\q1 
\v 13 Nrwa afu amar ɓàn na chit,
\q2 kang uza̱ uyen upərəkpərək.
\q1 Ka̱ awalang amar te,
\q2 uza̱ ma̱n pa̱ ó fa ka̱ ashe atak amar ka̱t.
\q1 
\v 14 Mi mwa ishi oza̱ ka̱ ashe awo aShəwol ɗò?
\q2 Mi fa ká̱ oza̱ ka̱ atak ikú ɗò?
\q1 Á ikú, arwa ɓu ka̱ chè yà?
\q2 Á aShəwol, nzhì ɓu ka̱ chè yà?
\q1 Ǹrusok afu i bubwam kà̱ ìwu mi.
\q1 
\v 15 Káp ka̱ nva̱ uza̱ i myak i ji ka̱ ashe ogənnang wò,
\q2 ayə́r nvàngváng ka̱ atak áYawe, kà̱ mɓa ka̱ ashe ǹzam nkpələng.
\q1 Atak mɓəl ndədəng ká̱ ìwu ndədəng mɓokɓok i wom,
\q2 i lak nza̱ atak nnak iya̱m inəna̱n nggo,
\q2 kang ìwuswa i nəm na.
\q1 
\v 16 Nkpak pa̱ aSamariya á yar iɗək mpat wò,
\q2 ka̱kul uza̱ fa iya̱mkak ká̱ Inan wò.
\q1 Mí gbá̱ng oza̱ ká̱ ndokchi, mí kyen ovan oza̱,
\q2 kang ochəchar oga anyám mí cha afu oza̱.
\c 14
\s1 Mmá kà̱ nchal oIsa̱rila pa̱ // oza̱ a le atak áYawe
\q1 
\v 1 áIsa̱rila, le atak áYawe, Inan ɓu,
\q2 ka̱kul mpat ɓu nak chit u lə̀p ìfang.
\q1 
\v 2 Le atak áYawe ká̱ nnap-nlà,
\q2 là á na pa̱,
\q1 <<Yar nkpaktak mpat á yi,
\q2 ka̱m yi ká̱ nrwa ìgwak,
\q2 na í shep ɓu ka̱ anung ina yi.
\q1 
\v 3 AAshur i ka̱mshi yi ka̱t,
\q2 í kwak ipəri ìkum ka̱t.
\q1 Í yà ká̱ nlà iya̱m nnəm awo yi pa̱,
\q2 <Inan yi> ka̱t.
\q2 Ka̱ atak ɓu uyenkpələng i ya nrwa ìgwak.>>
\q1 
\v 4 <<Mi tàn ngga̱ɓa̱n nre nna nnandər oza̱,
\q2 kang mi ma̱n oza̱ wa nva̱ n ɗom,
\q2 ka̱kul á ga̱ɓa̱n nlak ìgwak mi chit ka̱ atak oza̱.
\q1 
\v 5 Mi yà wa ìmimyang ûIsa̱rila,
\q2 uza̱ i bà̱l wa nggwanggwang ìzhəpndəng,
\q1 kang i rwak alə̀ng wa aLebanon.
\q2 
\v 6 Ntə́təp i bol, kang iɓiɓyen i yà wa ikún mpyet,
\q1 te mməmməm wa ikún asida iga aLebanon.
\q1 
\v 7 Onəm i təm ka̱ avəng ayiyi kà̱ɗi ,
\q2 oza̱ i myak wa ìpirkur.
\q1 Oza̱ i tə́p wa ikún ìba̱ngba̱ng,
\q2 ìdaɓardaɓar i yà wa ndəng ìba̱ngba̱ng ǹsámsàm iga aLebanon.
\q1 
\v 8 aEfrayim, iza̱ mi nəm ká̱ oga ìchər yà?
\q2 Mmami na mi ná ama̱n a ɓu kang mi nak ishi ká̱ ɓu.
\q1 Mmami wa ìkun ìsa̱l,
\q2 ka̱ atak mi na ó ya awar anəna̱n.>>
\q1 
\v 9 Unəm va̱ ká̱ aghan te, re uza̱ á kpán ìpir oga iya̱m va̱ ta̱,
\q2 unəm va̱ ká̱ nkpán ìpir nnap te,
\q2 re uza̱ á nyi ìpipir.
\q1 Ka̱kul asa̱l áYawe anəna̱n,
\q2 onəm onəna̱n i chen ka̱ ashishe,
\q2 onəm oga nfa iya̱mkak i lə̀p ìfang ka̱ apəpal.
