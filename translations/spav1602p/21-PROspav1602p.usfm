\v 26 \w Abre|strong="H6605"\w* su \w boca|strong="H6310"\w* \w con|strong="H5921"\w* \w sabiduría|strong="H2451"\w*: \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w ley|strong="H8451"\w* \w de|strong="H5921"\w* clemencia \add está\add* \w en|strong="H5921"\w* su \w lengua|strong="H3956"\w*.   
