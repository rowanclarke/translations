\id PHM - Biblica® Open Finnish Living News New Testament 
\h Filemonille 
\toc1 Paavalin kirje Filemonille 
\toc2 Kirje Filemonille 
\toc3 Filem. 
\mt1 Paavalin Kirje Filemonille 
\c 1  
\p  
\v 1 \add Lähettäjät:\add* Paavali, joka on vankilassa siksi, että levitti hyvää uutista Jeesuksesta, sekä hänen uskonveljensä Timoteus. 
\p  
\v 2 \add Vastaanottajat:\add* Rakas työtoverimme Filemon ja hänen kotonaan kokoontuva seurakunta sekä Appia-sisaremme ja Arkippus, Herran sotilas niin kuin mekin. 
\p  
\v 3 Toivotamme teille Isän Jumalan ja Herran Jeesuksen Kristuksen siunausta ja rauhaa. 
\s1 Paavali pyytää palvelusta 
\p  
\v 4 Kiitän Jumalaa aina kun rukoilen puolestasi, rakas Filemon.  
\v 5 Saan jatkuvasti kuulla, kuinka uskot Herraan Jeesukseen ja rakastat häntä ja hänen omiaan.  
\v 6 Rukoilen, että uskosi tarttuisi muihinkin, kun kerrot heille Kristuksesta ja he huomaavat, miten rikkaaksi hän on tehnyt elämäsi.  
\v 7 Rakkautesi on tuottanut minulle suurta iloa; olethan hyvin usein ystävällisyydelläsi virkistänyt uskovien mieltä. 
\p  
\v 8-9 Tahtoisin nyt pyytää sinulta jotain. Voisin suorastaan vaatia, että sinun on Kristuksen tähden tehtävä, mitä käsken. Mutta koska rakastan sinua ja olen jo vanha mies ja sitä paitsi vankilassa Herran vuoksi,  
\v 10 esitän vain pyynnön: ole hyvä Onesimukselle! Hän on lapseni, jonka voitin Kristukselle täällä vankilassa.  
\v 11 Onesimuksesta ei juuri ole viime aikoina ollut sinulle hyötyä\f + \fr 1:11 \ft Onesimus-nimi merkitsee »hyödyllinen».\f*, mutta tästedes hänestä on apua meille molemmille  
\v 12 Kun nyt lähetän hänet luoksesi takaisin, tuntuu kuin lähettäisin oman sydämeni. 
\p  
\v 13 Olisin kovin mielelläni pitänyt hänet täällä. Minuthan on vangittu siksi, että levitin hyvää uutista Jeesuksesta, ja Onesimus olisi voinut auttaa minua sinun sijastasi.  
\v 14 En kuitenkaan halunnut pitää häntä ilman suostumustasi, ettet tekisi hyvää pakosta vaan omasta vapaasta tahdostasi.  
\v 15 Hän karkasi, ja sinä menetit hänet vähäksi aikaa ehkä sen tähden, että nyt saisit hänet lopullisesti takaisin.  
\v 16 Mutta enää hän ei ole orja, vaan paljon enemmän: rakas veli jopa minulle. Varmasti hän merkitsee sinullekin nyt enemmän kuin ennen, sillä hän ei ole vain palvelijasi, vaan myös uskonveljesi. 
\p  
\v 17 Jos todella pidät minua ystävänäsi, ota hänet vastaan yhtä lämpimästi kuin ottaisit minut.  
\v 18 Jos hän on tuottanut sinulle vahinkoa tai varastanut sinulta jotakin, lähetä vain lasku tänne niin maksan sen sinulle.  
\v 19 Kirjoitan tähän vakuudeksi omakätisesti: minä maksan. Tosin sinäkin olet minulle hyvin paljon velkaa – jopa sielusi.  
\v 20 Rakas veli, teethän niin kuin pyysin! Sellainen rakkaudenosoitus virkistäisi väsynyttä mieltäni, ja kiittäisin siitä Herraa. 
\p  
\v 21 Olen kirjoittanut sinulle tämän kirjeen, koska uskon, että teet kuten pyysin ja paljon enemmänkin. 
\p  
\v 22 Pidäthän vierashuoneesi minulle varattuna, sillä toivon, että Jumala vastaa rukouksiimme ja pääsen pian sinne. 
\p  
\v 23 Epafras, joka on vankilassa samasta syystä kuin minäkin, lähettää sinulle terveisiä,  
\v 24 samoin työtoverini Markus, Aristarkus, Deemas ja Luukas. 
\p  
\v 25 Herran Jeesuksen Kristuksen hyvyys olkoon kanssasi!