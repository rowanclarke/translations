\id HOS - Biblica® Open Kurdi Sorani Standard Version 
\h هۆشەع 
\toc1 هۆشەع 
\toc2 هۆشەع 
\toc3 هۆشەع 
\mt1 هۆشەع 
\c 1  
\p  
\v 1 ئەمە ئەو پەیامەی یەزدانە کە لە سەردەمەکانی پاشایەتی عوزیا و یۆتام و ئاحاز و حەزقیای پاشایانی یەهودا بۆ هۆشەعی کوڕی بئێری هات، کە هاوسەردەمی یارۆڤعامی کوڕی یەهۆئاشی پاشای ئیسرائیل بوو. 
\b  
\s1 ژن و منداڵی هۆشەع 
\p  
\v 2 سەرەتا یەزدان لە ڕێگەی هۆشەعەوە پەیامی خۆی ڕاگەیاند، ئینجا بە هۆشەعی فەرموو: «بڕۆ ژنێکی سۆزانی بهێنە و با منداڵی زۆڵت\f + \fr 1:2 \ft زۆڵ: بیژی.‏\f* ببێت، چونکە خەڵکی خاکەکە وەک ژنێکی داوێنپیس ناپاکی بەرامبەر بە یەزدان کردووە.»  
\v 3 ئەویش گۆمەری کچی دیڤلایمی هێنا، سکی پڕ بوو، کوڕێکی لێ بوو. 
\p  
\v 4 یەزدان بە هۆشەعی فەرموو: «ناوی بنێ یەزرەعیل، چونکە پاش کەمێکی دیکە بنەماڵەی یێهو سزا دەدەم، لەسەر ئەو خوێنەی کە لە یەزرەعیل ڕشتیان، پاشایەتی ئیسرائیلیش لەناودەبەم.  
\v 5 لەو ڕۆژەدا کەوانی ئیسرائیل لە دۆڵی یەزرەعیلدا دەشکێنم.» 
\p  
\v 6 دیسان گۆمەر سکی پڕ بوو، کچێکی بوو. یەزدان بە هۆشەعی فەرموو: «ناوی لێ بنێ لۆڕوحامە\f + \fr 1:6 \ft واتای ناوەکەی (بەزەیی پێیدا نایەتەوە).‏\f*، چونکە چیتر بەزەییم بە بنەماڵەی ئیسرائیلدا نایەتەوە، لێیان خۆشنابم.  
\v 7 بەڵام بەزەییم بە بنەماڵەی یەهودا دێتەوە، بە کەوان، شمشێر یان جەنگ، ئەسپ و سوار ڕزگاریان ناکەم، بەڵکو بە یەزدانی پەروەردگاریان ڕزگاریان دەکەم.» 
\p  
\v 8 لەدوای ئەوەی گۆمەر لۆڕوحامەی لە شیر بڕییەوە، دیسان سکی پڕ بوو و کوڕێکی بوو.  
\v 9 یەزدان فەرمووی: «ناوی لێ بنێ لۆعامی\f + \fr 1:9 \ft واتای ناوەکەی (گەلی من نییە).‏\f*، چونکە ئێوە گەلی من نین و منیش بۆ ئێوە نابم. 
\p  
\v 10 «بەڵام لە داهاتوودا ژمارەی نەوەکانی ئیسرائیل وەک لمی دەریا دەبێت کە ناپێورێن و ناژمێردرێن، لەو شوێنەی پێیان گوترا، ”ئێوە گەلی من نین،“ بە ”ڕۆڵەکانی خودای زیندوو“ ناودەبردرێن.  
\v 11 لەو کاتەدا نەوەی یەهودا و نەوەی ئیسرائیل یەکدەگرنەوە و یەک سەرۆک بۆ خۆیان دادەنێن، لەو خاکەی بۆی ڕاپێچ کراون سەردەکەون و دێنە دەرەوە، چونکە ڕۆژی یەزرەعیل گەورە دەبێت.» 
\c 2  
\p  
\v 1 «بە براکانتان بڵێن: ”گەلی من،“ و بە خوشکەکانتان: ”بەر بەزەیی کەوتوو.“ 
\s1 سزادان و چاککردنەوەی ئیسرائیل 
\p  
\v 2 «سەرزەنشتی دایکتان بکەن، سەرزەنشتی بکەن، 
\q2 چونکە ئەو ژنی من نییە و 
\q2 منیش مێردی ئەو نیم. 
\q1 بەدڕەوشتی لە ڕوخساری و 
\q2 ناپاکی لەنێوان مەمکەکانی داماڵێت. 
\q1  
\v 3 ئەگینا ڕووتوقووتی دەکەمەوە، 
\q2 وەک ئەو ڕۆژە ڕایدەگرم کە تێیدا لەدایک بووە؛ 
\q1 وەک چۆڵەوانی لێ دەکەم، 
\q2 وەک خاکی وشکی لێ دەکەم، 
\q2 بە تینووێتی دەیمرێنم. 
\q1  
\v 4 بەزەییم بە منداڵەکانیدا نایەتەوە، 
\q2 چونکە زۆڵن. 
\q1  
\v 5 بێگومان دایکیان داوێنپیسی کردووە و 
\q2 بە بێ ئابڕوویی سکی پێیان پڕ بووە. 
\q1 ئەو گوتی: ”دوای دۆستەکانم دەکەوم، 
\q2 ئەوانەی نان و ئاو، 
\q2 خوری و کەتان، زەیت و خواردنەوەم پێدەدەن.“ 
\q1  
\v 6 لەبەر ئەوە ڕێگاکەی بە دڕک پەرژین دەکەم، 
\q2 دیوارێک بە دەوریدا دروستدەکەم بۆ ئەوەی ڕێڕەوەکانی نەدۆزێتەوە. 
\q1  
\v 7 دوای دۆستەکانی دەکەوێت و پێیان ناگات، 
\q2 بەدوایاندا دەگەڕێت و نایاندۆزێتەوە. 
\q1 ئینجا دەڵێت: 
\q2 ”دەچم و وەک جاران دەگەڕێمەوە بۆ لای مێردەکەم، 
\q2 چونکە ئەو کاتم لە ئێستام باشتر بوو.“ 
\q1  
\v 8 ئەو دانی پێدا نەناوە ئەوە من بووم کە 
\q2 دانەوێڵە و شەرابی نوێ و زەیتم پێیداوە، 
\q1 زێڕ و زیوم بۆی زیاد کردووە، 
\q2 بەڵام ئەوان بۆ بەعل بەکاریانهێنا. 
\b  
\q1  
\v 9 «لەبەر ئەوە دەگەڕێمەوە و دانەوێڵەکەم لە کاتی خۆیدا دەبەمەوە، 
\q2 شەرابە تازەکەشم لە کاتی خۆیدا. 
\q1 خوری و کەتانەکەم کە ڕووتییەکەی دادەپۆشن 
\q2 لەبەری دادەکەنم. 
\q1  
\v 10 ئێستا شوێنی شەرمی 
\q2 لەبەرچاوی خۆشەویستەکانیدا دەردەخەم، 
\q2 کەسیش لە دەستم فریای ناکەوێت. 
\q1  
\v 11 هەموو خۆشییەکانی ڕادەگرم: 
\q2 جەژن و سەرەمانگەکانی، 
\q2 شەممە و جەژنە دیاریکراوەکانی. 
\q1  
\v 12 ڕەزەمێو و هەنجیرەکانی تێکدەدەم، 
\q2 کە گوتی: ”ئەوانە کرێیەکەی منن، خۆشەویستانم پێیان داوم.“ 
\q1 دەیانکەم بە دارستان و 
\q2 ئاژەڵی کێوی دەیانخوات. 
\q1  
\v 13 لەسەر ئەو ڕۆژانەی سزای دەدەم 
\q2 کە بخووری بۆ بەعلەکان دەسووتاند، 
\q1 بە خەزێم و خشڵەکانی خۆی دەڕازاندەوە، 
\q2 دوای خۆشەویستانی کەوت، 
\q2 بەڵام منی لەیاد کرد.» 
\q4 ئەوە فەرمایشتی یەزدانە. 
\b  
\q1  
\v 14 «لەبەر ئەوە بە زمانی شیرین 
\q2 دەیبەمە چۆڵەوانی و 
\q2 بە نەرمی قسەی لەگەڵدا دەکەم. 
\q1  
\v 15 لەوێ ڕەزەمێوەکانی دەدەمەوە، 
\q2 دۆڵی عاخۆر\f + \fr 2:15 \ft (عاخۆر) وشەیەکی عیبرییە بە واتای تێکدان. بڕوانە یەشوع بەشی 7.‏\f* دەکەم بە دەرگای هیوا. 
\q1 لەوێ وەک ڕۆژانی هەرزەکاری گۆرانی دەڵێت، 
\q2 وەک ڕۆژی سەرکەوتنی لە خاکی میسرەوە.» 
\b  
\q1  
\v 16 یەزدان دەفەرموێت: «لەو ڕۆژەدا دەبێت، 
\q2 پێم دەڵێیت: ”مێردەکەم“ و 
\q2 چیتر پێم ناڵێیت: ”گەورەم.“ 
\q1  
\v 17 ناوی بەعلەکان لە دەمی دادەماڵم و 
\q2 ئیتر ناویان ناهێنێت. 
\q1  
\v 18 لەو ڕۆژەدا پەیمانێکیان بۆ دەبەستم 
\q2 لەگەڵ ئاژەڵی کێوی و باڵندەکانی ئاسمان و 
\q2 خشۆکەکانی زەوی. 
\q1 کەوان و شمشێر و جەنگ 
\q2 لە خاکەکەدا بنبڕ دەکەم و 
\q2 وایان لێ دەکەم بە ئاسوودەیی پاڵ بکەون. 
\q1  
\v 19 بۆ هەتاهەتایە بۆ خۆم نیشانت دەکەم و 
\q2 بە ڕاستودروستی و دادوەری، 
\q2 بە خۆشەویستی نەگۆڕ و بەزەیی بۆ خۆمت نیشان دەکەم. 
\q1  
\v 20 بە دڵسۆزییەوە بۆ خۆم نیشانت دەکەم و 
\q2 دان بە یەزداندا دەنێیت. 
\b  
\q1  
\v 21 «یەزدان دەفەرموێت: 
\q2 لەو ڕۆژەدا من کاردانەوەم دەبێت، 
\q1 من کاردانەوەم بەرامبەر بە ئاسمان دەبێت و 
\q2 ئەوانیش کاردانەوەیان بەرامبەر بە زەوی دەبێت، 
\q1  
\v 22 زەویش کاردانەوەی بەرامبەر بە دانەوێڵە و 
\q2 شەرابی نوێ و زەیت دەبێت، 
\q2 ئەوانیش کاردانەوەیان بەرامبەر بە یەزرەعیل\f + \fr 2:22 \ft یەزرەعیل: ناوێکی عیبری واتا (خودا دەیچێنێت).‏\f* دەبێت. 
\q1  
\v 23 لە خاکەکەدا بۆ خۆم دەیچێنم، 
\q2 بەزەییم دێتەوە بەوانەی کە فەرمووم ”بەزەییم پێیاندا نایەتەوە.“ 
\q1 ئەوانەی کە پێیان دەگوترا ”گەلی من نین“ پێیان دەڵێم: ”ئێوە گەلی منن.“ 
\q2 ئەوانیش دەڵێن: ”تۆ خودای ئێمەیت.“» 
\c 3  
\s1 ئاشتبوونەوەی هۆشەع لەگەڵ ژنەکەی 
\p  
\v 1 یەزدان پێی فەرمووم: «دیسان بڕۆ ژنەکەت خۆشبوێتەوە، هەرچەندە خاوەنی دۆستە و داوێنپیسە، وەک خۆشەویستی یەزدان بۆ نەوەی ئیسرائیل، ئەوانیش ڕوویان لە خوداکانی دیکە کردووە و نانی کشمیشیان\f + \fr 3:1 \ft نانی کشمیش بۆ بەعل پێشکەش دەکرا وەک سوپاسگوزاری بۆ دروێنە و خەرمان.‏\f* خۆشدەوێت.» 
\p  
\v 2 منیش دیسان بە پازدە شاقل زیو و بارێک و دوو قەزناخ\f + \fr 3:2 \ft نزیکەی 330 کیلۆگرام.‏\f* جۆ کڕیمەوە،  
\v 3 پێم گوت: «ماوەیەکی درێژ لەگەڵ من دەژیت، بێ ئەوەی داوێنپیسی بکەیت و بۆ هیچ پیاوێک بیت، هەروەها منیش بە هەمان شێوە دەبم بۆت.» 
\p  
\v 4 ئەمەش لەبەر ئەوەی ماوەیەکی درێژ نەوەی ئیسرائیل بەبێ پاشا یان میر، بەبێ قوربانی و بەردە تەرخانکراوەکان\f + \fr 3:4 \ft بەردی بە ستوونی دانراو بۆ پەرستن. بڕوانە دواوتار 16‏:21‏-22.‏\f*، بەبێ ئێفۆد و تەرافیم\f + \fr 3:4 \ft ئێفۆد، لە \xt دەرچوون 28‏:12‏\ft ‏دا ئەم جلوبەرگە هێمای نوێنەرایەتی کاهین بوو بۆ گەلی خودا، بەڵام \+tl تەرافیم‏\+tl* جۆرێک بت بووە لەناو ماڵەوە، لە شێوەی مرۆڤ بووە. دەشێت لەو سەردەمەدا گەلی ئیسرائیل لە نەریتی ئایینەکانی دیکەوە وەریانگرتبێ.‏\f* دەمێننەوە.  
\v 5 پاش ئەوە نەوەی ئیسرائیل دەگەڕێنەوە و ڕوو لە یەزدانی پەروەردگاریان و داودی پاشایان دەکەن، لە ڕۆژانی کۆتاییدا بە لەرزەوە ڕوو لە یەزدان و چاکەکەی دەکەن. 
\c 4  
\s1 سکاڵا لە دژی ئیسرائیل 
\q1  
\v 1 ئەی نەوەی ئیسرائیل، گوێ لە فەرمایشتی یەزدان بگرن، 
\q2 چونکە یەزدان سکاڵای هەیە 
\q2 لە دانیشتووانی خاکەکە: 
\q1 «نە وەفاداری، نە خۆشەویستی نەگۆڕ، 
\q2 نە خواناسی لە خاکەکەدا هەیە. 
\q1  
\v 2 نەفرەتکردن و درۆ و کوشتن، 
\q2 دزی و داوێنپیسی، 
\q1 پەرەی سەندووە و 
\q2 خوێنڕشتن، خوێنڕشتنی بەدوادا دێت. 
\q1  
\v 3 لەبەر ئەوە خاکەکە شین دەگێڕێت و 
\q2 ئەوەی تێیدا نیشتەجێیە بەرەو نەمان دەچێت، 
\q1 بە ئاژەڵی کێوی و باڵندەی ئاسمانیشەوە، 
\q2 تەنانەت ماسی دەریاش لەناودەچێت. 
\b  
\q1  
\v 4 «بەڵام با کەس سکاڵا نەکات و 
\q2 کەسیش تاوانبار نەکرێت، 
\q1 چونکە گەلەکەی تۆ وەک ئەوانەن کە 
\q2 سکاڵا لە کاهین دەکەن. 
\q1  
\v 5 تۆش بە ڕۆژ تێکدەشکێیت و 
\q2 بە شەویش پێغەمبەر لەگەڵت تێکدەشکێت، 
\q1 منیش دایکت لەناودەبەم. 
\q2  
\v 6 گەلەکەم بەهۆی نەزانینەوە لەناوچووە. 
\b  
\q1 «لەبەر ئەوەی تۆ زانینت ڕەتکردەوە، 
\q2 منیش ڕەتت دەکەمەوە لەوەی کاهینیێتیم بۆ بکەیت. 
\q1 لەبەر ئەوەی فێرکردنەکانی خودای خۆتت لەیاد کرد، 
\q2 منیش نەوەکانت لەیاد دەکەم. 
\q1  
\v 7 ئەوەندەی کاهینەکان زیاد بوون، 
\q2 ئەوەندەش گوناهیان لە دژی من کرد، 
\q2 منیش شکۆیان دەگۆڕم بۆ شەرمەزاری. 
\q1  
\v 8 قوربانی گوناهی گەلەکەم دەخۆن و 
\q2 ئاواتەخوازن کە تاوان بکات. 
\q1  
\v 9 جا کاهین وەک گەل دەبێت، 
\q2 بەپێی ڕەفتارەکەی سزای دەدەم، 
\q2 کردەوەکانی بەسەر خۆیدا دەدەمەوە. 
\b  
\q1  
\v 10 «دەخۆن و تێر نابن، 
\q2 لەشفرۆشی دەکەن و زیاد نابن، 
\q1 چونکە وازیان لە یەزدان هێنا 
\q2 بۆ ئەوەی خۆیان تەرخان بکەن  
\v 11 بۆ لەشفرۆشی و 
\q1 بۆ شەرابی کۆن و شەرابی نوێ 
\q2 کە هزر و هۆشی گەلەکەی منی بردووە. 
\q1  
\v 12 گەلەکەم پرس بە بتە دارینەکەیان دەکەن، 
\q2 وەڵام لە گۆچانەکەی دەستی وەردەگرن، 
\q1 چونکە ڕۆحی لەشفرۆشی گومڕای کردوون و 
\q2 دڵسۆزی خودای خۆیان نین. 
\q1  
\v 13 لەسەر لووتکەی چیاکان قوربانی سەردەبڕن و 
\q2 لەسەر گردەکان بخوور دەسووتێنن، 
\q1 لەژێر دار بەڕوو و ئەسپیندار و دارەبەن، 
\q2 چونکە سێبەری باشە! 
\q1 لەبەر ئەوە کچەکانتان لەشفرۆشی دەکەن و 
\q2 بووکەکانیشتان داوێنپیسی. 
\b  
\q1  
\v 14 «کچەکانتان سزا نادەم 
\q2 کە لەشفرۆشی دەکەن و 
\q1 بووکەکانیشتان 
\q2 کە داوێنپیسی دەکەن، 
\q1 چونکە پیاوەکان خۆیان دەچنە پاڵ لەشفرۆشەکان و 
\q2 لەگەڵ لەشفرۆشەکان دەچنە نزرگەکان و قوربانی سەردەبڕن. 
\q2 گەلێک تێگەیشتنی نەبێت لەناودەچێت! 
\b  
\q1  
\v 15 «ئەی ئیسرائیل، ئەگەر تۆش داوێنپیسیت، 
\q2 بەڵام با یەهودا تاوان نەکات. 
\b  
\q1 «مەچن بۆ گلگال و 
\q2 سەرمەکەون بۆ بێت‌ئاڤن\f + \fr 4:15 \ft بێت‌ئاڤن: واتا (ماڵی بەدکاری) کە ناوێکی خراپە و ئەوان لەسەر بێت‌ئێلیان دانابوو. بێت‌ئێلیش واتا (ماڵی خودا).‏\f* و 
\q2 سوێند مەخۆن: ”بە یەزدانی زیندوو!“ 
\q1  
\v 16 وەک نوێنگینێکی\f + \fr 4:16 \ft بە گوێرەکە مێینەیەک دەگوترێت کاتێک کە لە شیر دەبڕدرێتەوە، کە تەمەنی لە یەک ساڵ تێبپەڕێت.‏\f* کەللەڕەق 
\q2 ئیسرائیلیش کەللەڕەق بووە، 
\q1 ئیتر یەزدان چۆن بیانلەوەڕێنێت 
\q2 وەک بەرخ لە شوێنێکی پانوبەریندا؟ 
\q1  
\v 17 ئەفرایم بە بتەکانەوە بەستراوەتەوە، 
\q2 وازی لێ بهێنن! 
\q1  
\v 18 تەنانەت خواردنەوەشیان تەواوبێت، 
\q2 هەر نوقومی لەشفرۆشییەکەیان دەبن، 
\q2 گەورەکانیان بە تەواوی حەزیان لە شەرمەزارییە نەک لە ڕێز. 
\q1  
\v 19 با لەژێر باڵەکانی خۆیدا دەیپێچێتەوە، 
\q2 بە قوربانییەکانیان شەرمەزار دەبن. 
\c 5  
\s1 حوکمی سەر ئیسرائیل 
\q1  
\v 1 «ئەی کاهینەکان، گوێتان لەمە بێت! 
\q2 ئەی بنەماڵەی ئیسرائیل، سەرنج بدەن! 
\q1 ئەی ماڵی پاشا گوێ بگرن! 
\q2 حوکمەکە لە دژی ئێوەیە، 
\q1 چونکە ئێوە لە میچپا بوونە تەڵە، 
\q2 هەروەها تۆڕێکی ڕاخراویش بوون بەسەر تاڤۆر. 
\q1  
\v 2 یاخیبووان لە کوشتن قووڵبوونەوە، 
\q2 منیش هەموویان تەمبێ دەکەم. 
\q1  
\v 3 من ئەفرایم دەناسم و 
\q2 ئیسرائیلیش لە من شاردراوە نییە. 
\q1 ئەی ئەفرایم، ئێستا ڕێگای لەشفرۆشیت گرتووەتەبەر، 
\q2 ئیسرائیل گڵاو بووە. 
\b  
\q1  
\v 4 «کارەکانیان ڕێیان نادات 
\q2 بۆ لای خودای خۆیان بگەڕێنەوە، 
\q1 چونکە ڕۆحی لەشفرۆشی لە ناخیاندایە و 
\q2 ئەوان دان بە یەزداندا نانێن. 
\q1  
\v 5 لووتبەرزی ئیسرائیل بەرەوڕوو شایەتی لەسەر دەدات و 
\q2 ئیسرائیل و ئەفرایم بە تاوانەکانیان تێکدەشکێن، 
\q2 یەهوداش لەگەڵیاندا تێکدەشکێت. 
\q1  
\v 6 بە مەڕ و مانگاکانیانەوە دەڕۆن 
\q2 بۆ ئەوەی ڕوو لە یەزدان بکەن، 
\q1 بەڵام بۆیان دەرناکەوێت، 
\q2 چونکە لێیان دوور کەوتووەتەوە. 
\q1  
\v 7 ناپاکییان لە یەزدان کرد، 
\q2 چونکە منداڵی زۆڵیان\f + \fr 5:7 \ft زۆڵ: بیژی‏\f* بوو. 
\q1 ئێستا جەژنی سەرەمانگەکانیان 
\q2 خۆیان و کێڵگەکانیشیان دەخوات. 
\b  
\q1  
\v 8 «لە گیڤعادا کەڕەنا لێ بدەن و 
\q2 لە ڕامەش زوڕنا. 
\q1 لە بێت‌ئاڤن\f + \fr 5:8 \ft بێت‌ئاڤن: واتا ماڵی بەدکاری.‏\f* نەعرەتەی جەنگ بکێشن؛ 
\q2 ”ئەی بنیامین، ئێمە لەدوای تۆین.“ 
\q1  
\v 9 ئەفرایم وێران دەبێت 
\q2 لە ڕۆژی تەمبێکردندا. 
\q1 لەنێو هۆزەکانی ئیسرائیلدا 
\q2 ڕاستی ڕادەگەیەنم. 
\q1  
\v 10 میرانی یەهودا وەک ئەوانەن 
\q2 کە سنوور دەگوازنەوە، 
\q1 منیش تووڕەیی خۆم وەک باران 
\q2 بەسەریاندا هەڵدەڕێژم. 
\q1  
\v 11 ئەفرایم زۆرلێکراوە، 
\q2 بە حوکم تێکشکێنراوە، 
\q2 چونکە بڕیاری دا دوای بت بکەوێت. 
\q1  
\v 12 من بۆ ئەفرایم وەک مۆرانەم و 
\q2 وەک کلۆربوونیش بۆ بنەماڵەی یەهودا. 
\b  
\q1  
\v 13 «کاتێک ئەفرایم نەخۆشییەکەی خۆی بینی و 
\q2 یەهوداش ناسۆرەکەی خۆی، 
\q1 ئینجا ئەفرایم چووە لای ئاشور و 
\q2 بەدوای پاشا گەورەکەدا\f + \fr 5:13 \ft مەبەستی لە پاشای ئاشورە.‏\f* ناردی. 
\q1 بەڵام ناتوانێت چارەسەرتان بکات و 
\q2 برینەکەتان لەسەر لاببات. 
\q1  
\v 14 من بۆ ئەفرایم وەک شێرم و 
\q2 بۆ بنەماڵەی یەهوداش وەک بەچکە شێر، 
\q1 چونکە من پارچەپارچەیان دەکەم و دەڕۆم، 
\q2 دەبەم و فریادڕەسیش نییە، 
\q1  
\v 15 دەڕۆم و دەگەڕێمەوە بۆ شوێنەکەی خۆم 
\q2 هەتا دان بە تاوانەکەیان دەنێن و 
\q1 ڕوویان لە من دەکەن، 
\q2 لە تەنگانەیاندا بە پەرۆشەوە ڕوویان لە من دەکەن.» 
\c 6  
\s1 تۆبەنەکردنی ئیسرائیل 
\q1  
\v 1 «وەرن، با بگەڕێینەوە لای یەزدان، 
\q2 چونکە ئەو پارچەپارچەی کردووین و 
\q2 هەر ئەویش چارەسەرمان دەکات. 
\q1 ئەو برینداری کردووین و 
\q2 هەر ئەویش برینەکانمان ساڕێژ دەکات. 
\q1  
\v 2 دوای دوو ڕۆژ دەمانژیێنێتەوە، 
\q2 لە ڕۆژی سێیەمدا هەڵماندەستێنێتەوە 
\q2 بۆ ئەوەی ئێمە لەبەردەمیدا بژین. 
\q1  
\v 3 با دان بە یەزداندا بنێین، 
\q2 با تێبکۆشین بۆ ئەوەی دانی پێدا بنێین. 
\q1 بێگومان وەک چۆن ڕۆژ هەڵدێت 
\q2 ئاواش یەزدان دەردەکەوێت، 
\q1 وەک بارانی زستان دێتە لامان، 
\q2 وەک بەهارە باران کە زەوی ئاو دەدات.» 
\b  
\q1  
\v 4 «ئەی ئەفرایم، چیت لێ بکەم؟ 
\q2 ئەی یەهودا، چیت لێ بکەم؟ 
\q1 خۆشویستنی ئێوە وەک هەوری بەیانییان وایە، 
\q2 وەک ئەو شەونمەی بە زوویی دەڕوات. 
\q1  
\v 5 لەبەر ئەوە بە پێغەمبەران پارچەپارچەم کردن، 
\q2 بە وشەکانی دەمم ئێوەم کوشت، 
\q2 حوکمەکەشم وەک ڕووناکی دەرکەوت، 
\q1  
\v 6 چونکە میهرەبانیم دەوێ نەک قوربانی، 
\q2 لەلای من خواناسی لە قوربانی سووتاندن گرنگترە. 
\q1  
\v 7 بەڵام ئەوان وەک ئادەم سەرپێچی پەیمانیان کرد، 
\q2 لەوێدا ناپاکییان لە من کرد. 
\q1  
\v 8 گلعاد شاری خراپەکارانە و 
\q2 بە خوێن پێپەستە. 
\q1  
\v 9 وەک چۆن جەردە بۆسە بۆ کەسێک دەنێنەوە، 
\q2 ئاواش دەستەی کاهینەکان، 
\q1 لە ڕێگادا ڕووەو شەخەم خەڵک دەکوژن، 
\q2 بەدڕەوشتی ئەنجام دەدەن. 
\q1  
\v 10 لە بنەماڵەی ئیسرائیلدا کارێکی تۆقێنەر دەبینم، 
\q2 لەوێدا ئەفرایم لەشفرۆشی دەکات، 
\q2 ئیسرائیل گڵاوە. 
\b  
\q1  
\v 11 «تۆش ئەی یەهودا، 
\q2 ڕۆژی لێپێچینەوەت بۆ دیاریکراوە. 
\b  
\q1 «هەر کاتێک بمەوێت ڕاپێچکراوانی گەلەکەم دەگەڕێنمەوە\f + \fr 6:11 \ft گەڕاندنەوە لە ڕاپێچکراوی هێمایەک بووە بۆ نوێکردنەوەی بەختەوەری.‏\f*، 
\c 7  
\q1  
\v 1 کاتێک ئیسرائیلم چارەسەر دەکرد، 
\q1 تاوانی ئەفرایم ئاشکرا بوون، 
\q2 هەروەها خراپەی سامیرە. 
\q1 فێڵیان کرد، 
\q2 دز چووە ژوورەوە و 
\q2 جەردەکانیش لە دەرەوە تاڵانیان کرد، 
\q1  
\v 2 بەڵام لە دڵی خۆیاندا بیر لەوە ناکەنەوە 
\q2 کە من هەموو خراپەکەی ئەوانم لەبیرە. 
\q1 ئێستا کردەوەکانیان دەوریان دەدات، 
\q2 لە بەرچاومدان. 
\b  
\q1  
\v 3 «بە خراپەکەیان پاشا دڵخۆش دەکەن و 
\q2 بە درۆکانیشیان میر. 
\q1  
\v 4 هەموو داوێنپیسن 
\q2 وەک تەنوورێکی گەرمکراون 
\q1 کە نانەواکە ئاگرەکەی گڕ نادات، 
\q2 لە کاتی هەویر شێلانەوە هەتا کاتی هەڵهاتنی. 
\q1  
\v 5 لە ڕۆژی جەژنی پاشاماندا، 
\q2 میر نەخۆش دەکەون، لەبەر شەراب تایان لێ دێت، 
\q2 پاشا لەگەڵ گاڵتەجاڕان دەست تێکەڵ دەکات. 
\q1  
\v 6 دڵیان وەک ناخی تەنوورە، 
\q2 بە فرتوفێڵ لە پاشا نزیک دەبنەوە. 
\q1 قینیان بە درێژایی شەو کپ دەبێت و 
\q2 بۆ بەیانی وەک ئاگرێکی گڕ گرتوو گەرمە. 
\q1  
\v 7 هەموویان وەک تەنوور گەرمن، 
\q2 دادوەرەکانی خۆیان دەخۆن، 
\q1 هەموو پاشاکانیان دەکەون، 
\q2 کەسیان تێدا نییە نزا بۆ من بکات. 
\b  
\q1  
\v 8 «ئەفرایم تێکەڵ بە گەلان دەبێت. 
\q2 ئەفرایم بووە بە کولێرەیەکی هەڵنەگەڕاوە. 
\q1  
\v 9 بێگانەکان هێزەکەی دەخۆن و 
\q2 ئەویش پێی نازانێت. 
\q1 قژی ماشوبرنج بووە و 
\q2 ئەویش پێی نازانێت. 
\q1  
\v 10 لووتبەرزی ئیسرائیل بەرەوڕوو شایەتی لەسەر دەدات، 
\q2 لەگەڵ هەموو ئەوەشدا 
\q1 ناگەڕێنەوە بۆ لای یەزدانی پەروەردگاری خۆیان و 
\q2 بەدوایدا ناگەڕێن. 
\b  
\q1  
\v 11 «ئەفرایم وەک کۆترێکی لێهاتووە، 
\q2 گێل و بێ مێشک، 
\q1 بانگی میسر دەکەن و 
\q2 بۆ لای ئاشور دەچن. 
\q1  
\v 12 کاتێک دەڕۆن، تۆڕەکەم بەسەریاندا هەڵدەدەم، 
\q2 وەک باڵندەی ئاسمان دایاندەگرم. 
\q1 کاتێک کۆدەبنەوە تەمبێیان دەکەم 
\q2 بەگوێرەی ئەوەی دەیبیستم. 
\q1  
\v 13 قوڕبەسەریان، چونکە لە من هەڵاتن! 
\q2 ماڵوێرانی بۆیان، چونکە لێم یاخی بوون! 
\q1 من دەیانکڕمەوە، 
\q2 بەڵام ئەوان درۆم بۆ هەڵدەبەستن. 
\q1  
\v 14 کاتێک لەسەر جێگاکانیان دەناڵێنن 
\q2 لە دڵەوە هاوارم بۆ ناکەن. 
\q1 بۆ دانەوێڵە و شەراب کۆدەبنەوە، 
\q2 لە من هەڵدەگەڕێنەوە. 
\q1  
\v 15 من فێرم کردن و بازووی ئەوانم بەهێز کرد، 
\q2 بەڵام ئەوان لە دژی من بیر لە خراپە دەکەنەوە. 
\q1  
\v 16 دەگەڕێنەوە، بەڵام نەک بۆ لای خودای هەرەبەرز، 
\q2 وەک کەوانێکی ناڕێکیان لێدێت. 
\q1 لەبەر قینی زمانیان ڕابەرانیان بە شمشێر دەکوژرێن. 
\q2 لەبەر ئەمە لە میسر دەبنە گاڵتەجاڕ. 
\c 8  
\s1 دورینەوەی گەردەلوول 
\q1  
\v 1 «کەڕەنا ببە بۆ دەمت! 
\q2 هەڵۆیەک هاتە سەر ماڵی یەزدان، 
\q1 لەبەر ئەوەی پەیمانەکەی منیان شکاند و 
\q2 لە فێرکردنەکانم یاخی بوون. 
\q1  
\v 2 هاوار بۆ من دەکەن: 
\q1 ”ئەی خودای ئێمە، ئێمەی ئیسرائیل دانت پێدا دەنێین!“ 
\q1  
\v 3 بەڵام ئیسرائیل بێزی لە چاکە بووەوە، 
\q2 لەبەر ئەوە دوژمن ڕاوی دەنێت. 
\q1  
\v 4 ئەوان پاشایان دانا، بەڵام لە منەوە نەبوو، 
\q2 میریان دانا، کە من نایانناسم. 
\q1 لە زێڕ و زیوەکانیان بتیان بۆ خۆیان دروستکرد، 
\q2 بۆ لەناوچوونیان. 
\q1  
\v 5 ئەی سامیرە، بتە گوێرەکەکەت بەلاوە بنێ! 
\q2 تووڕەییم بەسەریاندا دەجۆشێت. 
\q1 هەتا کەی ناتوانن خۆیان بێگەرد ڕابگرن؟ 
\q2  
\v 6 هەروەها ئەوانیش هەر لە ئیسرائیلن! 
\q1 وەستایەک ئەم بتەی دروستکردووە، نابێتە خودا. 
\q2 گوێرەکەکەی سامیرە پارچەپارچە دەبێت. 
\b  
\q1  
\v 7 «ئەوان با دەچێنن و 
\q2 گەردەلوول دەدورنەوە. 
\q1 چێنراوێک کە بەروبوومی نییە و 
\q2 ئاردی لێ دروستناکرێت و 
\q1 ئەگەر دروستیش کرا 
\q2 بێگانەکان هەڵیدەلووشن. 
\q1  
\v 8 ئیسرائیل هەڵلووشرا! 
\q2 ئێستا لەنێو نەتەوەکاندا 
\q2 وەک قاپێکیان لێ هاتووە کە هیچ سوودی نییە. 
\q1  
\v 9 وەک کەرەکێوییەکی تاک و تەنها 
\q2 چوونە ئاشور. 
\q2 ئەفرایم خۆی بە چەند دۆستێک فرۆشتووە. 
\q1  
\v 10 هەرچەندە ئەوان لەنێو نەتەوەکان خۆیان فرۆشتووە، 
\q2 بەڵام ئێستا من کۆیان دەکەمەوە، 
\q2 ئینجا ئەوان لەژێر باری پاشای توانادار\f + \fr 8:10 \ft مەبەست لە پاشای ئاشورە.‏\f* دەفەوتێن. 
\b  
\q1  
\v 11 «هەرچەندە ئەفرایم قوربانگاکانی قوربانی گوناهی زۆر کرد، 
\q2 بۆی بوونە قوربانگای گوناهکردن. 
\q1  
\v 12 شتی زۆری بۆ دەنووسم کە پەیوەستە بە فێرکردنەکانم، 
\q2 بەڵام ئەو بە نامۆیان دادەنێت. 
\q1  
\v 13 قوربانیم پێشکەش دەکەن و 
\q2 خۆیان گۆشتەکەی دەخۆن، 
\q2 بەڵام یەزدان پێیان ڕازی نییە. 
\q1 ئێستا تاوانەکەیان دەهێنێتەوە یاد و 
\q2 سزای گوناهەکانیان دەدات: 
\q2 ئەوان دەگەڕێنەوە میسر. 
\q1  
\v 14 ئیسرائیل دروستکەری خۆی لە یاد کرد و 
\q2 چەندین کۆشکی بنیاد نا، 
\q2 یەهوداش شارە قەڵابەندەکان. 
\q1 بەڵام من ئاگر دەنێرمە سەر شارەکانی 
\q2 ئینجا قەڵاکانی دەخوات.» 
\c 9  
\s1 سزای ئیسرائیل 
\q1  
\v 1 ئەی ئیسرائیل، وەک گەلان 
\q2 دڵخۆش و شاد مەبە، 
\q1 چونکە ناپاکیت لە خودای خۆت کرد، 
\q2 حەزت لە کرێی لەشفرۆشی کرد 
\q2 لەسەر هەموو جۆخینەکان\f + \fr 9:1 \ft جۆخین یان سەرخەرمان ئەو زەوییە تەرخانکراوەیە کە لەلایەن وەرزێر و جوتیارەوە بەکارهێنراوە بۆ کوتانی دانەوێڵە لەسەری لەدوای کۆکردنەوەی لە کێڵگە.‏\f*. 
\q1  
\v 2 جۆخین و گوشەرەکانیان بەشیان ناکات، 
\q2 شەرابی نوێش بەشیان ناکات. 
\q1  
\v 3 لە خاکی یەزدان نیشتەجێ نابن، 
\q2 بەڵکو ئەفرایم بۆ میسر دەگەڕێتەوە و 
\q2 لە ئاشوردا خواردنی گڵاو دەخۆن. 
\q1  
\v 4 شەرابی پێشکەشکراو بۆ یەزدان ناڕژێنن و 
\q2 قوربانییەکانیان دڵی خۆش ناکەن. 
\q1 ئەو قوربانییانە بۆ ئەوان وەک نانی ماتەمە و 
\q2 هەرکەسێک لێی بخوات گڵاو دەبێت. 
\q1 نانەکەیان بۆ خۆیانە و 
\q2 ناچێتە ناو ماڵی یەزدانەوە. 
\b  
\q1  
\v 5 لە ڕۆژی دیاریکراودا چی دەکەن، 
\q2 لە ڕۆژی جەژنی یەزدان؟ 
\q1  
\v 6 تەنانەت ئەوەی لە وێرانی هەڵدێت، 
\q2 میسر کۆیان دەکاتەوە و 
\q2 مەمفیس لە گۆڕیان دەنێت. 
\q1 دڕکوداڵ گەنجینە زیوەکانیان بە میرات دەگرێت و 
\q2 وشترالووک لە ماڵەکەیاندا دەبێت. 
\q1  
\v 7 ڕۆژانی لێپرسینەوە بەڕێوەن، 
\q2 ڕۆژانی سزا بەڕێوەن. 
\q2 با ئیسرائیل ئەمە بزانێت. 
\q1 لەبەر زۆری تاوانەکەت و 
\q2 زۆری کێشمەکێشت، 
\q1 پێغەمبەر بە گێل سەیر دەکەیت و 
\q2 مرۆڤی ڕۆحیش بە شێت. 
\q1  
\v 8 پێغەمبەرەکە لەگەڵ خوداکەم چاودێری ئەفرایمە، 
\q2 بەڵام لە هەموو ڕێڕەوەکانی تەڵەیان نایەوە، 
\q2 کێشمەکێشیش لە ماڵی خوداکەیەتی. 
\q1  
\v 9 ئەوان نوقوم بوون، 
\q2 وەک ڕۆژانی گیڤعا گەندەڵ بوون، 
\q1 خودا تاوانەکەیان دەهێنێتەوە بیری خۆی و 
\q2 لەسەر گوناهەکانیان سزایان دەدات. 
\b  
\q1  
\v 10 «ئیسرائیلم دۆزییەوە 
\q2 وەک ترێ لە چۆڵەوانی، 
\q1 لە سەرەتادا باوباپیرانتانم بینی 
\q2 وەک نۆبەرەی بەری دار هەنجیرێک. 
\q1 بەڵام ئەوان هاتن بۆ بەعل‌پەعۆر و 
\q2 خۆیان بۆ خوداوەندی شەرمەزاری تەرخان کرد، 
\q2 ئەوان وەک ئەو خوداوەندەی کە خۆشیان دەویست قێزەون بوون. 
\q1  
\v 11 ئەفرایمیش شکۆمەندییەکەی وەک باڵندە دەفڕێت، 
\q2 نە لەدایکبوون و نە سکپڕی و نە دروستبوونی کۆرپەلە. 
\q1  
\v 12 تەنانەت ئەگەر منداڵەکانیشیان پەروەردە بکەن، 
\q2 جەرگسووتاویان دەکەم بۆ ئەوەی هیچ مرۆڤێک نەبێت. 
\q1 قوڕبەسەریان 
\q2 کاتێک پشتیان تێدەکەم. 
\q1  
\v 13 ئەفرایم دەبینم، وەک شاری سورە 
\q1 لە لەوەڕگا ڕواوە، 
\q1 بەڵام ئەفرایم منداڵەکانی 
\q2 بۆ بکوژ دەهێنێتە دەرەوە.» 
\b  
\q1  
\v 14 ئەی یەزدان، بیاندەرێ، 
\q2 چییان پێدەدەیت؟ 
\q1 منداڵدانێکی لەباربردە و 
\q2 دوو مەمکی وشک. 
\b  
\q1  
\v 15 «لەبەر هەموو خراپەکانیان لە گلگال 
\q2 من لەوێدا قێزم لێیان بووەوە. 
\q1 لەبەر کردەوە خراپەکانیان 
\q2 لە ماڵی خۆم دەریاندەکەم. 
\q1 ئیتر خۆشم ناوێن، 
\q1 هەموو میرەکانیان یاخین. 
\q1  
\v 16 ئەفرایم هەڵپڕووکاوە، 
\q2 ڕەگیان وشک بوو، 
\q2 بەر ناگرن. 
\q1 ئەگەر منداڵیشیان ببێت، 
\q2 منداڵە خۆشەویستەکانی سکیان دەمرێنم.» 
\b  
\q1  
\v 17 خوداکەم ڕەتیان دەکاتەوە، 
\q2 چونکە گوێیان لێی نەگرت، 
\q2 لەبەر ئەوە لەنێو نەتەوەکاندا وێڵ دەبن. 
\b  
\c 10  
\q1  
\v 1 ئیسرائیل دار مێوێکی پەل بڵاو بوو، 
\q2 بۆ خۆی بەری دەگرت. 
\q1 بەپێی زۆری بەروبوومەکەی، 
\q2 قوربانگای زۆر کرد. 
\q1 بەپێی باشی خاکەکەی، 
\q2 بەردە تەرخانکراوەکانی جوانتر کرد. 
\q1  
\v 2 دڵیان فریودەر بوو، 
\q2 ئێستا سزا دەدرێن. 
\q1 یەزدان قوربانگاکانیان تێکدەشکێنێت، 
\q2 بەردە تەرخانکراوەکانیان تێکدەدات. 
\b  
\q1  
\v 3 لەو کاتەدا دەڵێن: «ئێمە پاشامان نییە، 
\q2 چونکە لە یەزدان نەترساین، 
\q1 ئەگەر پاشاشمان هەبێت، 
\q2 چیمان بۆ دەکات؟» 
\q1  
\v 4 بە سوێندی درۆ قسە دەکەن، 
\q2 پەیمان دەبەستن، 
\q1 ئینجا سکاڵا زیاد دەبێت 
\q2 وەک گیایەکی ژەهراوی نێو زەوییەکی کێڵدراو دەڕوێت. 
\q1  
\v 5 خەڵکی سامیرە ترسیان هەیە 
\q2 لەو بتە گوێرەکەیەی کە لە شاری بێت‌ئاڤنە\f + \fr 10:5 \ft واتا (ماڵی بەدکاری)، هەروەها بێت‌ئێل واتا (ماڵی خودا).‏\f*. 
\q1 گەلەکەی و کاهینە بتپەرستەکانیشی 
\q2 لەبەر شکۆمەندییەکەی ئاهەنگیان دەگێڕا، 
\q1 بەڵام لە داهاتوودا شینی بۆ دەگێڕن، 
\q2 چونکە بۆ ڕاپێچ لێیان وەرگیراوە. 
\q1  
\v 6 ئەویش بۆ ئاشور دەبردرێت، 
\q2 وەک سەرانە بۆ پاشای شەڕانگێز. 
\q1 ئەفرایم سەرشۆڕی وەردەگرێت و 
\q2 ئیسرائیلیش لەسەر بتە دارینەکانی شەرمەزار دەبێت. 
\q1  
\v 7 سامیرە و پاشاکەی لەناودەچن، 
\q2 وەک چیلکە دار بەسەر ڕووی ئاوەوە دوور دەکەونەوە. 
\q1  
\v 8 نزرگەکانی سەر بەرزاییەکانی بەدکاری\f + \fr 10:8 \ft بەدکاری: عیبری \+tl ئاڤن‏\+tl*، مەبەست لە بێت‌ئاڤنە، کە ناوێکی سووکە بۆ بێت‌ئێل.‏\f* وێران دەبن، 
\q2 کە گوناهی ئیسرائیلن، 
\q1 دڕکوداڵ لەسەر قوربانگاکانیان دەڕوێن. 
\q2 ئەو کاتە بە چیاکان دەڵێن، «دامانپۆشن!» و 
\q2 بە گردەکانیش دەڵێن، «بەسەرماندا بڕووخێن!» 
\b  
\q1  
\v 9 «ئەی ئیسرائیل، لە سەردەمی گیڤعاوە گوناهت کرد، 
\q2 لەوێدا وەستان، 
\q2 لە گیڤعادا شەڕ نەوەی بەدکارانی نەگرتەوە؟ 
\q1  
\v 10 کەی بمەوێت تەمبێیان دەکەم، 
\q2 گەلان گەلەکۆمەیان لێ دەکەن، 
\q2 کاتێک بە دوو تاوانەکەیانەوە بەندن. 
\q1  
\v 11 ئەفرایم گوێرەکەیەکی\f + \fr 10:11 \ft گوێرەکەیەک: واتا عیبرییەکەی گوێرەکەیەکی مێینەی سێ ساڵە.‏\f* ڕاهێنراوە 
\q2 حەز لە گێرەکردن دەکات. 
\q1 لەبەر ئەوە من نیر دەخەمە سەر ملە جوانەکەی، 
\q2 سوار دەخەمە سەر ئەفرایم، 
\q1 یەهودا دەیکێڵێت، 
\q2 یاقوبیش خەرتەی دەکات. 
\q1  
\v 12 ڕاستودروستی بۆ خۆتان بچێنن و 
\q2 بەروبوومی خۆشەویستی نەگۆڕ بدوورنەوە. 
\q1 بۆ خۆتان بەیارێک بکێڵن، 
\q2 چونکە کاتی ئەوەیە ڕوو لە یەزدان بکەن، 
\q2 هەتا بێت و ڕاستودروستیتان بەسەردا ببارێنێت. 
\q1  
\v 13 بەڵام ئێوە خراپەتان چاند و 
\q2 بەدڕەفتاریتان دوورییەوە، 
\q2 بەروبوومی درۆتان خوارد، 
\q1 چونکە پشتت بە هێزی خۆت و 
\q2 بە زۆری پاڵەوانەکانت بەست، 
\q1  
\v 14 چەخماخەی جەنگ لە دژی گەلەکەت بەرز دەبێتەوە. 
\q2 هەموو قەڵاکانت تێکدەدرێن، 
\q1 وەک چۆن شەلمەن لە ڕۆژی جەنگدا بێت‌ئەربێلی\f + \fr 10:14 \ft هەولێر.‏\f* تێکدا، 
\q2 دایک لەگەڵ منداڵەکانیدا بەزەویدا کێشران. 
\q1  
\v 15 ئەی بێت‌ئێل، ئاواتان پێ دەکرێت، 
\q2 لەبەر ئەوەی خراپەکەتان گەورەیە. 
\q1 لە بەرەبەیاندا، 
\q2 پاشای ئیسرائیل بە تەواوی لەناودەچێت. 
\c 11  
\s1 خۆشەویستی خودا بۆ ئیسرائیل 
\q1  
\v 1 «کە ئیسرائیل منداڵ بوو، خۆشم ویست و 
\q2 من کوڕی خۆمم لە میسر بانگ کرد. 
\q1  
\v 2 بەڵام هەرچەندەی بانگم دەکردن، 
\q2 ئەوەندە منیان لە خۆیان دوورخستەوە، 
\q1 قوربانییان بۆ بەعلەکان سەردەبڕی و 
\q2 بخووریان بۆ وێنەی خوداوەندەکان دەسووتاند. 
\q1  
\v 3 من بووم ئەفرایمم فێری ڕۆیشتن کرد، 
\q2 دەستم بە باڵیانەوە گرت، 
\q2 بەڵام نەیانزانی من چاکم کردنەوە. 
\q1  
\v 4 بە گوریسی نەرمونیانی مرۆڤانە ڕایاندەکێشم، 
\q2 بە بەستنی خۆشەویستی، 
\q1 من بۆیان بووم بەوەی کە نیر لەسەر ملیان هەڵدەگرێت، 
\q2 چەمامەوە بۆ ئەوەی نانیان بدەمێ. 
\b  
\q1  
\v 5 «ئایا ناگەڕێنەوە بۆ خاکی میسر و 
\q2 ئاشور نابێتە پاشایان، 
\q2 چونکە ڕەتیان کردەوە بگەڕێنەوە لام؟ 
\q1  
\v 6 شمشێر دەکەوێتە شارەکانیان و 
\q2 شەوبەندی دەروازەکانیان تێکدەشکێنێت، 
\q2 کۆتایی بە تەگبیرەکانیان دەهێنێت. 
\q1  
\v 7 گەلەکەم مکوڕن لەسەر هەڵگەڕانەوە لە من. 
\q2 تەنانەت ئەگەر هاوار بۆ خودای هەرەبەرزەکەش بکەن، 
\q2 ئەو پایەبەرزیان ناکات. 
\b  
\q1  
\v 8 «ئەی ئەفرایم، چۆن وازت لێ بهێنم؟ 
\q2 ئەی ئیسرائیل، چۆن بە دەستتەوە بدەم؟ 
\q1 چۆن وەک ئەدما هەڵسوکەوتت لەگەڵدا بکەم؟ 
\q2 چۆن وەک چەبۆئیمت لێبکەم؟ 
\q1 دڵم لێم هەڵگەڕاوەتەوە و 
\q2 هەموو میهرەبانیم گڕی گرتووە. 
\q1  
\v 9 گڕی تووڕەییم ناخەمەگەڕ و 
\q2 ناگەڕێمەوە ئەفرایم وێران بکەم، 
\q1 چونکە من خودام نەک مرۆڤ، 
\q2 من خودا پیرۆزەکەم، لە ناوەڕاستی ئێوەدام، 
\q2 بە قینەوە نایەم. 
\q1  
\v 10 لەدوای یەزدانەوە دەڕۆن، 
\q2 وەک شێرێک دەنەڕێنێت. 
\q1 کاتێک دەنەڕێنێت، 
\q2 منداڵەکان لە ڕۆژئاواوە بە لەرزەوە دێن. 
\q1  
\v 11 وەک چۆلەکە لە میسرەوە بە لەرزەوە دێن، 
\q2 وەک کۆتر لە خاکی ئاشورەوە. 
\q1 ئینجا لە ماڵەکانیاندا نیشتەجێیان دەکەم.» 
\q3 ئەوە فەرمایشتی یەزدانە. 
\s1 گوناهی ئیسرائیل 
\q1  
\v 12 ئەفرایم بە درۆ دەوری لێدام و 
\q2 بنەماڵەی ئیسرائیلیش بە فێڵەوە، 
\q1 یەهوداش هێشتا سەرسەختە بەرامبەر بە خودا، 
\q2 لە پیرۆزە دڵسۆزەکە. 
\c 12  
\q1  
\v 1 ئەفرایم لەسەر با دەلەوەڕێت، 
\q2 دوای بای ڕۆژهەڵات کەوتووە، 
\q2 هەموو ڕۆژێک درۆ و توندوتیژی زیاد دەکات. 
\q1 لەگەڵ ئاشوردا پەیمان دەبەستن و 
\q2 زەیتی زەیتوون بۆ میسر دەنێرێت. 
\q1  
\v 2 یەزدان لە دژی یەهودا سکاڵای هەیە، 
\q2 سزای یاقوب بەپێی ڕەفتارەکەی دەدات، 
\q2 کردەوەکانی بەسەر خۆیدا دەداتەوە. 
\q1  
\v 3 لەناو سکدا پاژنەی براکەی گرت و 
\q2 بە هێزی خۆی لەگەڵ خودا کەوتە زۆرانێ. 
\q1  
\v 4 لەگەڵ فریشتەکە زۆرانێی کرد و سەرکەوت، 
\q2 گریا و پاڕایەوە، بۆ ئەوەی لەگەڵی میهرەبان بێت. 
\q1 لە بێت‌ئێل تووشی بوو، 
\q2 لەوێ قسەی لەگەڵی کرد\f + \fr 12:4 \ft قسەی لەگەڵیدا کرد: بڕوانە، بۆ نموونە، \xt پەیدابوون 32‏:30‏\ft ‏.‏\f*. 
\q1  
\v 5 یەزدانی پەروەردگاری سوپاسالار، 
\q2 ناوبانگی یەزدانە! 
\q1  
\v 6 تۆش بۆ لای خودات بگەڕێوە، 
\q2 خۆشەویستی نەگۆڕ و دادپەروەری پەیڕەو بکە و 
\q2 هەمیشە چاوەڕوانی خودای خۆت بە. 
\b  
\q1  
\v 7 بازرگان تەرازووی ساختەی لە دەستدایە، 
\q2 حەز دەکات ستەم بکات. 
\q1  
\v 8 ئەفرایم گوتی: 
\q2 «من دەوڵەمەند بووم و سامانم بۆ خۆم پێکەوەنا، 
\q1 لە هەموو سامانەکەم خراپەیەکم تێدا نابیننەوە 
\q2 کە گوناه بێت.» 
\b  
\q1  
\v 9 «من یەزدانی پەروەردگاری ئێوەم، 
\q2 ئەوەی لە خاکی میسرەوە تۆی دەرهێنا، 
\q1 دووبارە لەناو چادرەکان نیشتەجێت دەکەم، 
\q2 وەک ڕۆژانی جەژن. 
\q1  
\v 10 قسەم لەگەڵ پێغەمبەرەکاندا کرد و 
\q2 بینینی زۆرم بۆ ئاشکرا کردن، 
\q2 هەروەها لە ڕێگەی پێغەمبەرانەوە نموونەم هێنایەوە.» 
\b  
\q1  
\v 11 ئایا خراپەکاری لە گلعاد هەیە؟ 
\q2 بێگومان دانیشتووانەکەی پووچن! 
\q1 لە گلگال گا دەکەن بە قوربانی، 
\q2 بەڵێ، بەڵام قوربانگاکانیان وەک کۆمەڵە بەرد دەبن 
\q2 لەسەر هێڵەکانی جووتی کێڵگەدا. 
\q1  
\v 12 یاقوب بۆ دەشتودەری ئارام\f + \fr 12:12 \ft میسۆپۆتامیا، وڵاتی نێوان دجلە و فورات. بڕوانە \xt پەیدابوون 28‏:2‏\ft ‏.‏\f* هەڵات و 
\q2 ئیسرائیل لە پێناوی ژنێکدا خزمەتی کرد، 
\q2 لە پێناوی ژنێکدا شوانایەتی کرد. 
\q1  
\v 13 یەزدان لە ڕێگەی پێغەمبەرێکەوە ئیسرائیلی لە میسر دەرهێنا و 
\q2 لە ڕێگەی پێغەمبەرێکیشەوە چاودێری کرد. 
\q1  
\v 14 بەڵام ئەفرایم زۆر بە خراپی یەزدانی پەست کرد، 
\q2 پەروەردگارەکەشی تاوانی ئەو خوێنەی لەسەریەتی دەیهێڵێتەوە و 
\q2 سووکایەتییەکەی بەسەر خۆیدا دەداتەوە. 
\c 13  
\s1 تووڕەیی یەزدان لەسەر ئیسرائیل 
\q1  
\v 1 کاتێک ئەفرایم قسەی کرد، لەرزین پەیدابوو، 
\q2 ئەویش لە ئیسرائیلدا پایەدار بوو، 
\q2 بەڵام خۆی تاوانبار کرد بە پەرستنی بەعل و مرد. 
\q1  
\v 2 ئێستا گوناهیان زیاتر و زیاتر دەکەن، 
\q2 لە زیوەکانیان بتی لەقاڵبدراو بۆ خۆیان دروستدەکەن، 
\q1 بتی دروستکراو بەپێی تێگەیشتنی خۆیان، 
\q2 هەمووی دەستکردی وەستایە. 
\q1 دەربارەیان دەڵێن: 
\q2 «ئەوانە مرۆڤ دەکەنە قوربانی، 
\q2 بتە گوێرەکەکان ماچ دەکەن!» 
\q1  
\v 3 لەبەر ئەوە وەک هەوری بەیانییان دەبن و 
\q2 وەک ئەو شەونمەی بە زوویی دەڕوات، 
\q1 وەک پووشی جۆخین کە دەدرێت بەدەم باوە، 
\q2 وەک دووکەڵ لە کڵاوڕۆژنەوە\f + \fr 13:3 \ft وەک پەنجەرەیە، دەلاقەیەکە بۆ هاتوچۆی هەوا و گێڕانەوەی تیشکی خۆر.‏\f*. 
\b  
\q1  
\v 4 «بەڵام من یەزدانی پەروەردگارتم، 
\q2 ئەوەی لە خاکی میسر دەریهێنایت. 
\q1 جگە لە من دان بە هیچ خودایەکی دیکەدا نانێیت، 
\q2 جگە لە منیش هیچ خودایەک ڕزگارکەر نییە. 
\q1  
\v 5 من لە چۆڵەوانیدا چاودێری تۆم کرد، 
\q2 لە زەوی تینووێتی. 
\q1  
\v 6 کاتێک لە لەوەڕ تێربوون، 
\q2 کە تێربوون دڵیان بەفیز بوو، 
\q2 لەبەر ئەوە منیان لەیاد کرد. 
\q1  
\v 7 جا وەک شێر دەبم بۆیان، 
\q2 وەک پڵنگ لەسەر ڕێگا خۆم مات دەکەم. 
\q1  
\v 8 وەک ورچێکی جەرگسووتاو پەلاماریان دەدەم و 
\q2 پەردەی دڵیان دەدڕێنم. 
\q1 وەک شێرە مێ لەوێ دەیانخۆم، 
\q2 ئاژەڵی کێوی پارچەپارچەیان دەکەن. 
\b  
\q1  
\v 9 «ئەی ئیسرائیل، تۆ لەناوچوویت، 
\q2 چونکە تۆ لە دژی منیت، لە دژی یارمەتیدەری خۆتیت. 
\q1  
\v 10 ئێستا کوا پاشاکەت؟ 
\q2 تاکو لە هەموو شارۆچکەکانت ڕزگارت بکات، 
\q1 کوا ئەو فەرمانڕەوایانەی کە سەبارەت بەوان گوتت: 
\q2 ”پاشا و میرم بدەرێ“؟ 
\q1  
\v 11 لە تووڕەییمدا پاشایەکم پێت دا و 
\q2 لە هەڵچوونمدا بردمەوە. 
\q1  
\v 12 تاوانەکانی ئەفرایم ئەمبار کراون، 
\q2 گوناهەکانیشی تۆمارکراون. 
\q1  
\v 13 ژانی منداڵبوون بەسەریدا دێت، 
\q2 بەڵام منداڵێکی نەفامە، 
\q1 چونکە لە کاتی خۆیدا نایەت و 
\q2 لە منداڵدان ناترازێتە خوارەوە. 
\b  
\q1  
\v 14 «لە دەست جیهانی مردووان خۆمیان بۆ بەخت دەکەم، 
\q2 لە مردن دەیانکڕمەوە. 
\q1 ئەی مردن، کوا دەردەکانت؟ 
\q2 ئەی جیهانی مردووان، کوا وێرانکاریت؟ 
\b  
\q1 «میهرەبانی لە چاوەکانم شاردراونەتەوە، 
\q2  
\v 15 هەرچەندە لەناو براکانیدا بە بەروبووم بوو. 
\q1 بایەکی ڕۆژهەڵات دێت، 
\q2 بای یەزدان لە چۆڵەوانی هەڵدەکات، 
\q1 ئینجا کانییەکەی کوێردەبێتەوە و 
\q2 سەرچاوەکەی بێ ئاو دەبێت. 
\q1 گەنجینەی هەموو کەلوپەلە بەنرخەکانی 
\q2 تاڵان دەکرێت. 
\q1  
\v 16 خەڵکی سامیرە تاوانبار دەکرێن، 
\q2 چونکە لە خودای خۆیان یاخی بوون، 
\q1 بە شمشێر دەکوژرێن و 
\q2 منداڵەکانیان تێکدەشکێنرێن، 
\q2 سکی سکپڕان هەڵدەدڕێت.» 
\c 14  
\s1 تۆبەکردن بۆ وەرگرتنی بەرەکەت 
\q1  
\v 1 ئەی ئیسرائیل، بۆ لای یەزدانی پەروەردگاری خۆتان بگەڕێنەوە، 
\q2 چونکە بە تاوانی خۆتان تێکشکان! 
\q1  
\v 2 ئەم قسانە لەگەڵ خۆتان ببەن و 
\q2 بگەڕێنەوە لای یەزدان، 
\q1 پێی بڵێن: 
\q2 «لە هەموو تاوانێک خۆشبە و 
\q1 بە چاکەی خۆت وەرمانبگرە، 
\q2 بەروبوومی لێوەکانمان سوپاسکردنی تۆ دەبێت.\f + \fr 14:2 \ft لێوەکانمان ستایشی تۆ دەکەن، بڕوانە \xt عیبرانییەکان 13‏:15‏\ft ‏.‏\f* 
\q1  
\v 3 ئاشور ڕزگارمان ناکات. 
\q2 سواری ئەسپ نابین، 
\q1 جارێکی دیکە بە دەستکردەکانمان ناڵێین، 
\q2 ”خوداوەندەکانمان،“ 
\q2 چونکە لەلایەن تۆ هەتیو بەر بەزەیی دەکەوێت.» 
\b  
\q1  
\v 4 «من هەڵگەڕانەوەیان چاک دەکەمەوە، 
\q2 بە دڵفراوانییەوە ئەوانم خۆشدەوێت، 
\q2 چونکە تووڕەییم لەوان دامرکایەوە. 
\q1  
\v 5 بۆ ئیسرائیل وەک شەونم دەبم، 
\q2 ئەویش وەک سەوسەن گوڵ دەکات و 
\q2 وەک دار ئورزی لوبنان ڕەگ دادەکوتێت، 
\q2  
\v 6 چڵەکانی درێژ دەبنەوە، 
\q1 جوانییەکەی وەک دار زەیتوون دەبێت و 
\q2 وەکو دار ئورزی لوبنان بۆندار دەبێت. 
\q1  
\v 7 نیشتەجێبووان لە سایەی سێبەرەکەی دەگەڕێنەوە. 
\q2 وەک دانەوێڵە دەژیێتەوە و 
\q1 وەک مێو دەگەشێتەوە. 
\q2 ناوبانگی وەک شەرابی لوبنان دەبێت. 
\q1  
\v 8 ئەی ئەفرایم، لەمەولا چ پەیوەندییەکم بە بتەوە هەیە؟ 
\q2 من وەڵام دەدەمەوە و چاودێریت دەکەم، 
\q1 من وەک دار سنەوبەرێکی سەوزم، 
\q2 بەروبوومەکەت لەلایەن منەوەیە.» 
\b  
\q1  
\v 9 کێ دانایە و لە ئەمانە تێدەگات؟ 
\q2 کێ تێگەیشتووە و دەیانزانێت؟ 
\q1 چونکە ڕێگاکانی یەزدان ڕاستن و 
\q2 ڕاستودروستان پێیدا دەڕۆن، 
\q2 بەڵام یاخیبووەکان ساتمەی تێدا دەکەن و دەکەون.