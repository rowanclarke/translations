\id EXO
\h ؤُفُّوغْ
\toc1 ؤُفُّوغْ
\toc2 ؤُفُّوغْ
\toc3 ؤُف.
\mt1 ؤُفُّوغْ
\c 1
\s1 بدُّو ن ثسْمُوغِي ن إِسْرَائِيل
\m 
\v 1 إِنَا ذ إِسْمَاونْ ن أَيْثْ ن إِسْرَائِيل إِ د-يِيوْضنْ أَكْ-ذ يَاعْقُوبْ غَارْ مِيصْرَا. يُوسَا-د كُوڒْ إِجّْ \add زَّايْسنْ\add* أَكْ-ذ \add أَيْثْبَابْ\add* ن ثَادَّارْثْ نّسْ: \f ◼ \fr 1:‏1 \ft \bd ’إِسْرَائِيل‘\bd* - وَانِيثَا ذ إِسمْ ن جْذِيذْ إِ يَاعْقُوبْ. خْزَارْ أَمز. 32:29.\f*  \x ◘ \xo 1:‏1 \xt أَمز. 46‏:‏8؛ ؤُف. 6‏:‏14. \x*
\v 2 رُوبِينْ، شِيمْعُونْ، لَاوِي ذ يَاهُوذَا، \f ◼ \fr 1:‏2 \ft \bd أَفسَّارْ ن ڒْمعْنَا ن إِسْمَاونْ ن أَيْثْ ن إِسْرَائِيل‘\bd* - خْزَارْ أَمز. 49.\f*
\v 3 إِسَّاكَارْ، زابُولُونْ ذ بِينْيَامِينْ،
\v 4 ذَانْ ذ نَافْثَالِي، جَاذْ ذ أَشِيرْ.
\v 5 مَارَّا ڒعْمُورْ نِّي د-إِفّْغنْ زِي ثْمصَّاضْثْ ن يَاعْقُوبْ، \add ثُوغَا أَثنْ\add* ذِي سبْعِينْ. يُوسُوفْ ثُوغَا-ث ذِي مِيصْرَا. \x ◘ \xo 1:‏5 \xt أَمز. 46‏:‏27؛ أَعَوذ. 10‏:‏22؛ ڒخ. 7‏:‏14. \x*
\v 6 إِمُّوثْ يُوسُوفْ ذ مَارَّا أَيْثْمَاسْ، ذ جِّيڒْ نِّي مَارَّا.
\v 7 مَّارنْينْ أَيْثْ ن إِسْرَائِيل ؤُ جِّينْ-د ڒْغِيدْجثْ \add أَڒَامِي\add* زَّايْسنْ ثسْفُوفِّي \add ثمُّورْثْ\add* ؤُشَا تّْوَاكْثَارنْ ؤُشَا ذوْڒنْ جهْذنْ أَطَّاسْ، \add مِينْزِي\add* ثشُّورْ زَّايْسنْ ثمُّورْثْ. \x ◘ \xo 1:‏7 \xt أَعَوذ. 26‏:‏5؛ ڒخ. 7‏:‏17\x*
\m 
\v 8 إِفّغْ-د خنِّي إِجّْ ن ؤُجدْجِيذْ ذ جْذِيذْ \add إِحكّمْ\add* خْ مِيصْرَا، ونِّي ثُوغَا وَارْ إِسِّينْ يُوسُوفْ. \x ◘ \xo 1:‏8 \xt ڒخ. 7‏:‏18\x*
\v 9 إِنَّا إِ ڒْڭنْسْ نّسْ: ”خْزَارْ، ڒْڭنْسْ ن أَيْثْ ن إِسْرَائِيل إِمْغَارْ ؤُ إِجْهذْ خَانغْ.
\v 10 ڒخُّو، أَقَا أَذْ خَاسْ نحْكمْ س ڒعْقڒْ، حِيمَا وَارْ إِتّْمَارْنِي \add ڒْڭنْسْ كْثَارْ،\add* ؤُشَا، مَاڒَا إِمْسَارْ إِكَّارْ شَا ن ڒْبَارُوضْ، أَذْ إِذْوڒْ أَكْ-ذ ڒْعذْيَانْ نّغْ، أَذْ يڭّْ ڒْحَارْبْ أَكِيذْنغْ ؤُشَا \add خنِّي\add* أَذْ إِفّغْ زِي ثمُّورْثْ.“ \x ◘ \xo 1:‏10 \xt ڒخ. 7‏:‏19\x*
\v 11 نِيثْنِي ڭِّينْ خَاسنْ إِمحْضَاينْ خْ وَارْبَارْ ن ثسْمُوغِي، حِيمَا أَذْ سّْذدْجنْ ڒْڭنْسْ س دّْقُوڒَاثْ إِ خَاسنْ سَّاربُّونْ. بْنَانْ إِ فِيرْعُونْ، \add أَجدْجِيذْ\add*، ثِيندَّامْ ن ڒخْزنْ: فِيثُومْ ذ رَاعَامْسِيسْ.
\v 12 \add مَاشَا\add* مشْحَاڒْ مَا ذدْجنْ نِيثْنِي ڒْڭنْسْ، أَمنِّي إِ إِڭْمَا ؤُ إِبزّعْ \add ڒْڭنْسْ\add*، أَڒَامِي إِوْضنْ نِيثْنِي أَذْ شَارْهنْ أَيْثْ ن إِسْرَائِيل أَطَّاسْ. \x ◘ \xo 1:‏12 \xt إِزهد. 105‏:‏24\x*
\v 13 ؤُشَا أَرِّينْ إِمِيصْرِييّنْ أَيْثْ ن إِسْرَائِيل ذ إِسمْغَانْ س ؤُغِيڒْ
\v 14 ؤُشَا سَّارزْڭنْ ثُوذَارْثْ نْسنْ س ثسْمُوغِي إِقسْحنْ ذڭْ ؤُبدْجَاعْ ذ لَّاجُورْ ؤُڒَا ذِي مَارَّا ثسْمُوغِي ذڭْ إِيَّارنْ. مَارَّا ثَاسْمُوغِي إِ ڭِّينْ نِيثْنِي ذِي \add ڒْْوسْثْ\add* نْسنْ، ثُوغَا ت س ؤُغِيڒْ. \f ◼ \fr 1:‏14 \ft \bd ’ثَاسْمُوغِي‘\bd* - ’ڒْْخذْمثْ ن إِسمْغَانْ‘.\f*
\m 
\v 15 إِسِّيوڒْ ؤُجدْجِيضْ ن مِيصْرَا أَكْ-ذ ڒْقَابْڒَاثْ ثِيعِيبْرَانِييِّينْ، إِشْثنْ زَّايْسنْثْ قَّارنْ أَسْ سِيفْرَا، ؤُ ثنّغْنِي قَّارنْ أَسْ فُوعَاثْ.
\v 16 إِنَّا: ”خْمِي غَا ثْعَاوْننْثْ ثِيمْغَارِينْ ثِيعِيبْرَانِييِّينْ أَذْ أَرْونْثْ، ؤُشَا أَذْ ثخْزَارنْثْ خْمِي تّْغِيمَانْثْ خْ إِژْرَا \add مَاحنْذْ أَذْ أَرْونْثْ\add*، إِتّْخصَّا كنِّينْثْ أَذْ نْغنْثْ \add أَحنْجِيرْ\add* مَاڒَا ذ مِّيسْ، \add مَاشَا\add* مَاڒَا ذ يدْجِيسْ، جّنْثْ ت أَذْ ثدَّارْ!“
\v 17 \add مَاشَا\add* ڒْقَابْڒَاثْ ثُوغَا تّڭّْوذنْثْ أَربِّي، وَارْ ڭِّينْثْ مُوخَاسْ ثنْثْ يُومُورْ ؤُجدْجِيذْ ن مِيصْرَا، \add مَاشَا\add* حْضَانْثْ ثُوذَارْثْ ن إِحنْجِيرنْ.
\v 18 \add خنِّي\add* إِڒَاغَا ؤُجدْجِيذْ ن مِيصْرَا إِ ڒْقَابْڒَاثْ، إِنَّا أَسنْثْ: ”مَاغَارْ ثڭِّينْثْ أَيَا، أَقَا ثحْضَانْثْ ثُوذَارْثْ ن إِحنْجِيرنْ؟“
\v 19 ڒْقَابْڒَاثْ أَرِّينْثْ خْ فِيرْعُونْ: ”ثِيعِيبْرَانِييِّينْ وَارْ دْجِينْثْ أَمْ ثِيمِيصْرِييِّينْ، مِينْزِي نِيثنْثِي جهْذنْثْ، تَّارْونْثْ قْبڒْ مَا أَذْ غَارْسنْثْ د-ثَاسْ ڒْقَابْڒَا.“
\v 20 ؤُشَا أَربِّي إِڭَّا مْلِيحْ إِ ڒْقَابْڒَاثْ ؤُشَا إِمَّارْنِي ڒْڭنْسْ، ذوْڒنْ جهْذنْ س وَاطَّاسْ.
\v 21 مِينْزِي ڒْقَابْڒَاثْ ڭّْوذنْثْ أَربِّي، إِمْسَارْ، أَقَا يَارْزقْ إِ-ثنْثْ-إِ-د س ثُوذْرِينْ \add أَكْ-ذ ڒْوَاشُونْ\add*. \f ◼ \fr 1:‏21 \ft \bd ’يَارْزقْ‘\bd* - س ثْعِيبْرَانِيثْ ’يڭَّا‘.\f*
\m 
\v 22 \add ڒخْذنِّي\add* يُومُورْ فِيرْعُونْ مَارَّا ڒْڭنْسْ نّسْ، إِنَّا: ”كُوڒْ أَحنْجِيرْ إِ د غَا إِخڒْقنْ أَذْ ث ثنْضَارمْ ذڭْ إِغْزَارْ ؤُ مَارَّا ثَاحنْجِيرْثْ \add إِ د غَا إِخڒْقنْ\add* أَذْ ت ثجّمْ أَذْ ثدَّارْ.“ \x ◘ \xo 1:‏22 \xt ڒخ. 7‏:‏19\x*  *
\b
\b
\c 2
\s1 أَخْڒَاقْ ن مُوسَا ذ ثَاروْڒَا نّسْ
\m 
\v 1 ؤُشَا إِفّغْ إِجّْ ن ورْيَازْ زِي \add رَادْجْ ن\add* ثَادَّارْثْ ن لَاوِي، يِيوِي إِشْثْ ن ثْحنْجِيرْثْ ن لَاوِي \add ذ ثَامْغَارْثْ\add*. \x ◘ \xo 2:‏1 \xt ؤُف. 6‏:‏20؛ ڒخْڒ. 26‏:‏59\x*
\v 2 ثكْسِي ثمْغَارْثْ س دّيْسثْ ؤُشَا ثُورُووْ-د أَحنْجِيرْ. \add ؤُمِي\add* ثژْرَا بلِّي إِصْبحْ \add ؤُحنْجِيرْ\add*، ثفَّارْ إِ-ث ثْڒَاثَا ن إِيُورنْ. \f ◼ \fr 2:‏2 \ft \bd ’إِيُورنْ‘\bd* - نِيغْ ’شّْهُورْ‘.\f*  \x ◘ \xo 2:‏2 \xt 1 إِم. 23‏:‏13؛ ڒخ. 7‏:‏20؛ عبر. 11‏:‏23\x*
\v 3 \add ؤُمِي\add* وَارْ ثزْمَارْ عَاذْ أَذْ ث ثفَّارْ، ثكْسِي أَسْ-د إِشْثْ ن ثْسنْذُوقْثْ ن ؤُغَانِيمْ، ثبْرَا إِ-ت س ؤُشَارْمُوضْ ذ ثِيزفْثْ ؤُشَا ثسَّارْسْ ذَايسْ أَحنْجِيرْ، ثڭَّا \add ثَاسنْذُوقْثْ نِّي\add* جَارْ ؤُغَانِيمْ خْ ثْمَا ن إِغْزَارْ.
\v 4 ثْبدّْ وُوتْشْمَاسْ غَارْ ڒَاڭّْوَاجْ، مَاحنْذْ أَذْ ثْژَارْ مِينْ زَّايسْ غَا ڭّنْ.
\m 
\v 5 ؤُ \add خْزَارْ\add*، ثهْوَا يدْجِيسْ ن فِيرْعُونْ، مَاحنْذْ أَذْ ثسِّيرْذْ إِخفْ نّسْ ذڭْ إِغْزَارْ. ثُوغَا ثِيمْسخَّارِينْ ثِيبْڒِيغِينْ نّسْ ڭُّورنْثْ خْ ثْمَا ن إِغْزَارْ. نتَّاثْ ثژْرَا ثَاسنْذُوقْثْ ذڭْ ؤُغَانِيمْ ؤُشَا ثسّكّْ ثِيسْمغْثْ نّسْ ؤُشَا ثكْسِي ت-إِ-د. \x ◘ \xo 2:‏5 \xt ڒخ. 7‏:‏21؛ عبر. 11‏:‏23\x*
\v 6 أَڒَامِي ت ثَارْزمْ، ثژْرَا أَحنْجِيرْ نِّي، ؤُشَا خْزَارْ، أَحنْجِيرْ ثُوغَا إِتّْرُو. يُوذفْ إِ-ت ؤُزِيدْجزْ، ثنَّا: ”وَا ذ \add إِجّْ\add* زڭْ إِحنْجِيرنْ ن إِعِيبْرَانِييّنْ!“
\v 7 \add ڒخْذنِّي\add* ثنَّا ؤُتْشْمَاسْ إِ يدْجِيسْ ن فِيرْعُونْ: ”مَا أَذْ رَاحغْ أَذْ ڒَاغِيغْ خْ إِشْثْ ن ثمْسُوضضْثْ زِي ثْعِيبْرَانِييِّينْ مَاحنْذْ أَذْ أَمْ ثسُّوطّضْ أَحنْجِيرْ؟“
\v 8 ثنَّا أَسْ يدْجِيسْ ن فِيرْعُونْ: ”رُوحْ!“ ثْرُوحْ ثعْزَارشْثْ، ثْڒَاغَا إِ يمَّاسْ ن ؤُحنْجِيرْ.
\v 9 \add ڒخْذنِّي\add* ثنَّا أَسْ يدْجِيسْ ن فِيرْعُونْ: ”أَوِي-د أَحنْجِيرْ-أَ، ثسُّوطّضْ إِ-ث إِ نشّْ ؤُ نشّْ أَذْ شمْ خدْجْصغْ.“ ثكْسِي ثمْغَارْثْ أَحنْجِيرْ ؤُشَا ثسُّوطّضْ إِ-ث.
\v 10 \add ؤُمِي\add* إِڭْمَا ؤُحنْجِيرْ، ثِيوْيِي إِ-ث غَارْ يدْجِيسْ ن فِيرْعُونْ، إِذْوڒْ أَسْ أَمْ مِّيسْ ؤُشَا ثڭَّا أَسْ مُوسَا، ثنَّا: ”أَقَا جبْذغْ ث-إِ-د زڭْ وَامَانْ.“
\b
\m 
\v 11 ذڭْ وُوسَّانْ نِّي إِمْسَارْ، ؤُمِي إِڭْمَا مُوسَا، أَقَا إِفّغْ-د غَارْ أَيْثْمَاسْ، ؤُشَا إِژْرَا دّْقُوڒَاثْ إِ خَاسنْ \add سَّاربُّونْ\add*. إِژْرَا إِجّْ ن ؤُمِيصْرِي إِشَّاثْ إِجّْ ن ؤُعِيبْرَانِي، \add إِجّنْ\add* زڭْ أَيْثْمَاسْ. \x ◘ \xo 2:‏11 \xt ڒخ. 7‏:‏23؛ عبر. 11‏:‏24، 25\x*
\v 12 إِخْزَارْ ذَا ذ ذِيهَا، إِژْرَا بلِّي وَارْ ذِينْ حذْ، \add خنِّي\add* إِنْغَا أَمِيصْرِي نِّي ؤُشَا إِسّْنُوفَّارْ إِ-ث ذڭْ إِجْذِي.
\v 13 ؤُمِي د-إِفّغْ ثِيوشَّا نّسْ، إِژْرَا ثْنَاينْ ن يرْيَازنْ إِعِيبْرَانِييّنْ تّْمنْغَانْ. إِنَّا \add مُوسَا\add* إِ ؤُعفَّانْ نِّي إِتّْعدَّانْ: ”مَاغَارْ ثشَّاثذْ جَّارْ نّشْ؟“
\v 14 إِنَّا نتَّا: ”وِي إِ شكْ إِڭِّينْ ذ ڒْحَاكمْ ذ ڒْقَاضِي خَانغْ؟ مَا شكْ ثقَّارذْ أَيَا ؤُمِي شكْ ثنْوِيذْ أَذْ أَيِي ثنْغذْ أَمْ مَامّشْ ثنْغِيذْ أَمِيصْرِي؟“ \add ڒخْذنِّي\add* إِڭّْوذْ مُوسَا، إِنَّا: ”س ثِيذتّْ ثَامسْڒَاشْثْ ثتّْوَاسّنْ!“ \x ◘ \xo 2:‏14 \xt ڒخ. 7‏:‏27\x*
\m 
\v 15 ؤُمِي إِسْڒَا فِيرْعُونْ مَانْ أَيَا، يَارْزُو أَذْ إِنغْ مُوسَا. \add مَاشَا\add* مُوسَا يَارْوڒْ زِي فِيرْعُونْ ؤُشَا إِزْذغْ ذِي ثمُّورْثْ ن مِيذْيَانْ ؤُشَا إِقِّيمْ \add ذِينْ\add* غَارْ إِجّْ ن وَانُو. \x ◘ \xo 2:‏15 \xt ڒخ. 7‏:‏29\x*
\m 
\v 16 أَكهَّانْ ن مِيذْيَانْ ثُوغَا غَارسْ سبْعَا ن يسِّيسْ، ثِينِّي إِ د-يُوسِينْ أَذْ أَيْمنْثْ أَمَانْ \add ذِينْ\add* ؤُشَا شُّورنْثْ سّْوَارجْ، حِيمَا أَذْ وَارْذنْثْ ؤُدْجِي ن بَابَاثْسنْثْ.
\v 17 ؤُسِينْ-د إِمكْسَاونْ ؤُشَا ؤُژّْڒنْ خَاسنْثْ. إِكَّارْ مُوسَا \add ڒخْذنِّي\add*، إِفكّْ إِ-ثنْثْ، إِوَارْذْ ؤُدْجِي نْسنْثْ. \f ◼ \fr 2:‏17 \ft \bd ’إِمكْسَاونْ‘\bd* - نِيغْ ’إِنِيتْشَانْ‘.\f*
\v 18 \add ؤُمِي\add* ذوْڒنْثْ غَارْ بَابَاثْسنْثْ \add ؤُمِي قَّارنْ\add* رَاعُويِيلْ، إِنَّا \add أَسنْثْ\add*: ”مَايمِّي د-تّْعقْبنْثْ أَسّْ-أَ ذغْيَا؟“ \f ◼ \fr 2:‏18 \ft \bd ’رَاعُويِيلْ‘\bd* - غَارسْ ؤُڒَا ذ إِسمْ نّغْنِي، أَقَا-ث يِيثْرُو. خْزَارْ ؤُفُوغْ 3:1. إِسمْ-أَ إِخْسْ أَذْ يِينِي ’أَمدُّوكَّاڒْ ن أَربِّي‘.\f*
\v 19 نِيثنْثِي أَرِّينْثْ-إِ-د خَاسْ: ”إِجّْ ن ورْيَازْ ذ أَمِيصْرِي إِفكّْ أَنغْ زڭْ إِفَاسّنْ ن إِمكْسَاونْ ؤُشَا \add عَاوذْ\add* يُويمْ أَنغْ-د أَطَّاسْ ن وَامَانْ ؤُشَا إِوَارْذْ ؤُدْجِي.“ \f ◼ \fr 2:‏19 \ft \bd ’إِمكْسَاونْ‘\bd* - نِيغْ ’إِنِيتْشَانْ‘.\f*
\v 20 إِنَّا إِ يسِّيسْ: ”إِ مَانِي يدْجَا؟ مَايمِّي ثجِّينْثْ أَرْيَازْ \add نِّي ذِينْ\add*؟ رُوحنْثْ ڒَاغَانْثْ-إِ-د خَاسْ حِيمَا أَذْ إِشّْ أَغْرُومْ!“
\v 21 ؤُشَا إِقْبڒْ مُوسَا أَذْ إِزْذغْ أَكْ-ذ ورْيَازْ نِّي ؤُشَا نتَّا إِوْشَا أَسْ إِ مُوسَا يدْجِيسْ صَافُّورَا \add ذ ثَامْغَارْثْ\add*.
\v 22 ثجَّا أَسْ-د أَحنْجِيرْ، إِڭَّا أَسْ جَارْشُومْ، مِينْزِي إِنَّا: ”نشّْ ثُوغَا أَيِي ذ أَغْرِيبْ ذڭْ إِشْثْ ن ثمُّورْثْ ذ ثَاغْرِيبْثْ خَافِي.“ \f ◼ \fr 2:‏22 \ft \bd ’جَارْشُومْ‘\bd* - إِسمْ-أَ وَانِيثَا إِخْسْ أَذْ يِينِي ’إِجّْ ن ؤُبَارَّانِي (دْجِيغْ) ذَانِيثَا‘.\f*  \x ◘ \xo 2:‏22 \xt ؤُف. 18‏:‏2، 3\x*
\m 
\v 23 ڒَامِي ثعْذُو وَاطَّاسْ ن ڒْوقْثْ، إِمُّوثْ ؤُجدْجِيذْ ن مِيصْرَا ؤُشَا وحْوحنْ أَيْثْ ن إِسْرَائِيل ذِي ثسْمُوغِي \add إِ ذِي ثُوغَا دَّارنْ\add*، سّْغُوينْ ؤُشَا إِغُويَّانْ نْسنْ ڭعّْذنْ غَارْ أَربِّي زِي ثسْمُوغِي \add نْسنْ\add*.
\v 24 ؤُشَا إِسّْحسّْ أَربِّي إِ ثْغُويِّيثْ نْسنْ ؤُشَا إِخَارّصْ أَربِّي ذِي ڒْعَاهْذْ نّسْ أَكْ-ذ إِبْرَاهِيمْ ؤُ أَكْ-ذ إِسْحَاقْ ؤُ أَكْ-ذ يَاعْقُوبْ. \x ◘ \xo 2:‏24 \xt أَمز. 15‏:‏14\x*
\v 25 إِخْزَارْ أَربِّي غَارْ أَيْثْ ن إِسْرَائِيل ؤُشَا يَارْڭبْ أَربِّي \add خْ ڒغْبنْ نْسنْ\add*.
\b
\b
\c 3
\s1 ثَاڒَاغِيثْ ن أَربِّي خْ مُوسَا
\m 
\v 1 يَارْوسْ مُوسَا ؤُدْجِي ن يِيثْرُو، أَضڭّْوَاڒْ نّسْ، أَكهَّانْ ن مِيذْيَانْ. إِنْذهْ ؤُدْجِي أَوَارْنِي إِ ڒخْڒَا ؤُشَا يِيوِيضْ-د غَارْ وذْرَارْ ن أَربِّي، غَارْ حُورِيبْ.
\v 2 إِبَانْ أَسْ-د لْمَالَاكْ ن سِيذِي ذڭْ إِجّْ ن ؤُشعُّوڒْ ذِي ڒْوسْطْ ن إِجّْ ن شْبَارْقْ أَكْ-ذ إِسنَّاننْ، ؤُ خْزَارْ، نتَّا إِژْرَا بلِّي شْبَارْقْ أَكْ-ذ إِسنَّاننْ ثُوغَا ثكَّارْ ذَايسْ ثْمسِّي، \add مَاشَا\add* شْبَارْقْ وَارْ إِتّْوَاشْمضْ شَا.
\v 3 إِنَّا مُوسَا: ”أجّْ أَيِي أَذْ قوْسغْ \add شْوَايْثْ\add*، مَاحنْذْ أَذْ ژَترغْ ثَامژْرِيوْثْ نِّي ثَامقّْرَانْثْ، مَايمِّي شْبَارْقْ أَكْ-ذ إِسنَّاننْ وَارْ إِشمّضْ شَا.“
\v 4 \add ڒَْامِي\add* إِژْرَا أَربِّي بلِّي إِجَّا أَبْرِيذْ، مَاحنْذْ أَذْ إِژَارْ \add مَانْ أَيَا\add*، إِڒَاغَا-د خَاسْ أَربِّي زِي ڒْوسْطْ ن شْبَارْقْ أَكْ-ذ إِسنَّاننْ، إِنَّا: ”مُوسَا، مُوسَا!“ نتَّا يَارَّا: ”أَقَا أَيِي ذَا!“
\v 5 \add خنِّي\add* إِنَّا نتَّا: ”وَارْ د-تّْقَارَّابْ شَا ذَانِيثَا! كّسْ ثِيسِيڒَا نّشْ زڭْ إِضَارنْ نّشْ، مِينْزِي أَمْشَانْ إِ خفْ ثْبدّذْ، أَقَا-ث ذ ثَامُّورْثْ ثْقدّسْ.“ \x ◘ \xo 3:‏5 \xt ياش. 5‏:‏15\x*
\v 6 إِنَّا \add عَاوذْ:\add* ”نشّْ ذ أَربِّي ن بَابَاشْ، أَربِّي ن إِبْرَاهِيمْ، أَربِّي ن إِسْحَاقْ ذ أَربِّي ن يَاعْقُوبْ.“ \add ڒخْذنِّي\add* إِسّْذُورِييْ مُوسَا أَغمْبُوبْ نّسْ، مِينْزِي إِڭّْوذْ أَذْ إِسْوضْ ذِي أَربِّي. \x ◘ \xo 3:‏6 \xt مت. 22‏:‏32؛ مك. 12‏:‏26؛ لك. 20‏:‏37؛ ڒخ. 7‏:‏32\x*
\m 
\v 7 إِنَّا سِيذِي: ”أَقَا ژْرِيغْ ڒْمحْنثْ \add إِ ذِي إِدَّارْ\add* ڒْڭنْسْ إِنُو إِ إِدْجَانْ ذِي مِيصْرَا ؤُشَا سْڒِيغْ إِغُويَّانْ نْسنْ زَّاثْ إِ إِمْزيَّارنْ نْسنْ، أَقَا سّْنغْ ثَامَارَا نْسنْ. \x ◘ \xo 3:‏7 \xt ڒخ. 7‏:‏34\x*
\v 8 هْوِيغْ-د حِيمَا أَذْ فكّغْ \add ڒْْڭنْسْ\add* زڭْ إِفَاسّنْ ن إِمِيصْرِييّنْ، أَذْ ث سُّوفّْغغْ زِي ثمُّورْثْ نِّي غَارْ إِشْثْ ن ثمُّورْثْ ثصْبحْ ذ ثْمِيرِيوْثْ، غَارْ إِشْثْ ن ثمُّورْثْ إِفيّْضنْ س ؤُغِي ذ ثَامّنْثْ، غَارْ ومْشَانْ ن أَيْثْ ن كنْعَانْ ذ إِحِيتِّييّنْ ذ إِمُورِييّنْ ذ إِفِيرِيزِييّنْ ذ إِحِيوِييّنْ ذ إِيِيبُوسِييّنْ.
\v 9 خْزَارْ ڒخُّو، أَقَا ثِيوضْ-د غَارِي ثْغُويِّيثْ ن أَيْثْ ن إِسْرَائِيل ؤُشَا عَاوذْ ژْرِيغْ دّدْجْ نْسنْ إِ زِي ثنْ ذدْجنْ إِمِيصْرِييّنْ.
\v 10 ڒخُّو \add خنِّي\add*، رُوحْ، نشّْ أَذْ شكْ سّكّغْ غَارْ فِيرْعُونْ ؤُ شكْ أَذْ ثْسُوفّْغذْ ڒْڭنْسْ إِنُو، أَيْثْ ن إِسْرَائِيل، زِي مِيصْرَا.“ \x ◘ \xo 3:‏10 \xt إِزهد. 105‏:‏26؛ حُوش. 12‏:‏14؛ مِيخَا 6‏:‏4؛ ڒخ. 7‏:‏35\x*
\m 
\v 11 \add خنِّي\add* إِنَّا مُوسَا إِ أَربِّي: ”مِينْ عْنِيغْ نشّْ أَڒَامِي غَا رَاحغْ غَارْ فِيرْعُونْ، أَذْ سُّوفّْغغْ أَيْثْ ن إِسْرَائِيل زِي مِيسْرَا؟“
\v 12 نتَّا إِنَّا أَسْ: ”نشّْ أَذْ كِيكْ إِڒِيغْ ؤُ ثَانِيثَا أَذْ أَشْ ثِيڒِي ذ ڒعْڒَامثْ، بلِّي نشّْ سّكّغْ-د شكْ: خْ مِينِّي إِ غَا ثسُّوفّْغذْ ڒْڭنْسْ-أَ زِي مِيصْرَا، أَذْ ثْعبْذمْ أَربِّي خْ وذْرَارْ-أَ.“ \x ◘ \xo 3:‏12 \xt ياش. 1‏:‏5\x*
\v 13 \add خنِّي\add* إِنَّا مُوسَا إِ أَربِّي: ”خْزَارْ، خْمِي د غَا أَوْضغْ نشّْ غَارْ أَيْثْ ن إِسْرَائِيل، أَذْ أَسنْ إِنِيغْ: ’أَربِّي ن ڒجْذُوذْ نْومْ إِسّكّْ أَيِي-د غَارْومْ!‘، \add ؤُشَا\add* نِيثْنِي أَذْ أَيِي سّقْسَانْ: ’مَامّشْ ذ أَسْ قَّارنْ؟‘، مِينْ ذ أَسنْ غَا إِنِيغْ \add خنِّي\add*؟“
\v 14 إِنَّا أَربِّي إِ مُوسَا: \bd ”نشّْ ذ نشّْ إِ دْجِيغْ“\bd*. ؤُشَا إِنَّا \add عَاوذْ\add*: ”أَمُّو إِ غَا ثِينِيذْ إِ أَيْثْ ن إِسْرَائِيل: \bd نشّْ ذ نشّْ \bdit إِ دْجِيغْ\bdit*!\bd* أَقَا نتَّا ذ ونِّي ذ أَيِي د-إِسّكّنْ غَارْومْ.“
\v 15 إِنَّا أَربِّي عَاوذْ إِ مُوسَا: ”أَمُّو إِ غَا ثِينِيذْ إِ أَيْثْ ن إِسْرَائِيل: ’سِيذِي، أَربِّي ن ڒجْذُوذْ نْومْ، أَربِّي ن إِبْرَاهِيمْ ذ أَربِّي ن إِسْحَاقْ ذ أَربِّي ن يَاعْقُوبْ، إِسّكّْ أَيِي-د غَارْومْ. ذ وَا ذ إِسمْ إِنُو إِ ڒبْذَا ؤُ \add يِيسمْ\add* وَانِيثَا \add أَذْ يِيڒِي\add* إِ ڒِيذَارثْ ذَايِي زِي جِّيڒْ أَڒْ جِّيڒْ.‘
\v 16 رُوحْ، ثسّْمُونذْ إِمْغَارنْ ن إِسْرَائِيل، إِنِي أَسنْ: ’سِيذِي، أَربِّي ن ڒجْذُوذْ نْومْ، أَربِّي ن إِبْرَاهِيمْ ذ إِسْحَاقْ ذ يَاعْقُوبْ إِبَانْ أَيِي-د، إِنَّا: ’أَقَا خَاومْ حِينّغْ ؤُشَا \add ژْرِيغْ\add* مِينْ خَاومْ سّعْذُونْ ذِي مِيصْرَا.
\v 17 نِّيغْ: نشّْ أَذْ كنِّيوْ سُّوفّْغغْ زِي ڒْمحْنثْ ذِي مِيصْرَا غَارْ ثمُّورْثْ ن أَيْثْ ن كنْعَانْ ذ إِحِيتِّييّنْ ذ إِمُورِييّنْ ذ إِفِيرِيزِييّنْ ذ إِحِيوِييّنْ ذ إِيِيبُوسِييّنْ، غَارْ إِشْثْ ن ثمُّورْثْ إِفيّْضنْ س ؤُغِي ذ ثَامّنْثْ.‘
\v 18 أَذْ سْڒنْ إِ ثْمِيجَّا نّشْ، ؤُشَا أَذْ ثْرَاحذْ، شكْ ذ إِمْغَارنْ ن إِسْرَائِيل، غَارْ ؤُجدْجِيذْ ن مِيصْرَا، أَذْ أَسْ ثِينِيمْ: ’سِيذِي، أَربِّي ن إِعِيبْرَانِييّنْ، إِمْسَاڭَارْ أَكِيذْنغْ. خنِّي ڒخُّو، أجّْ أَنغْ أَذْ نطّفْ أَبْرِيذْ ثِيشْڒِي ن ثْڒَاثَا ن وُوسَّانْ ذِي ڒخْڒَا، حِيمَا أَذْ نْقدّمْ ثِيغَارْصَا إِ سِيذِي، أَربِّي نّغْ.‘ \f ◼ \fr 3:‏18 \ft \bd ’ثَاغَارْصْثْ - ثِيغَارْصَا‘\bd* - نِيغْ ’دّبِيحثْ‘، ’دّْبَايحْ‘.\f*
\v 19 \add مَاشَا\add* نشّْ سّْنغْ بلِّي أَجدْجِيذْ ن مِيصْرَا وَارْ كنِّيوْ إِتّجِّي أَذْ ثْرَاحمْ ؤُڒَا س ؤُفُوسْ إِجهْذنْ.
\v 20 خنِّي أَذْ سّْوِيژّْضغْ أَفُوسْ إِنُو، أَذْ وْثغْ مِيصْرَا س مَارَّا لْمُوعْجِيزَاثْ إِنُو إِ ذَايسْ إِ غَا ڭّغْ ذِي ڒْوسْطْ نّسْ، ؤُشَا أَوَارْنِي إِ مَانْ أَيَا، نتَّا أَذْ كنِّيوْ يجّْ أَذْ ثْرَاحمْ.
\v 21 أَذْ حِينّغْ خْ ڒْڭنْسْ-أَ زَّاثْ إِ ثِيطَّاوِينْ ن إِمِيصْرِييّنْ ؤُشَا أَذْ إِمْسَارْ، خْمِي غَا ثْرَاحمْ، وَارْ ثتّفّْغمْ شَا س إِفَاسّنْ خْوَانْ.
\v 22 أَذْ ثتَّارْ كُوڒْ ثَامْغَارْثْ زِي ثَاجَّارْثْ نّسْ ؤُ زِي ثْبَارَّانِيثْ نِّي أَكِيذسْ إِزدّْغنْ ذِي ثَادَّارْثْ، ڒقْشُوعْ ن نُّوقَارْثْ ذ وُورغْ ذ وَارُّوضْ، ؤُشَا كنِّيوْ أَذْ ثنْ ثڭّمْ خْ إِحنْجِيرنْ ذ ثْحنْجِيرِينْ نْومْ، ؤُشَا \add أَمُّو إِ\add* غَا ثْكشّْضمْ مِيصْرَا.“ \x ◘ \xo 3:‏22 \xt ؤُف. 11‏:‏2؛ 12‏:‏35؛ حِز. 39‏:‏10\x*
\b
\b
\c 4
\s1 أَربِّي إِسّكّْ مُوسَا غَارْ مِيصْرَا
\m 
\v 1 \add خنِّي\add* يَارَّا-د مُوسَا، إِنَّا: ”خْزَارْ، نِيثْنِي وَارْ ذَايِي تِّيمْننْ شَا ؤُشَا وَارْ تّسْڒِينْ شَا إِ وَاوَاڒْ إِنُو، مِينْزِي أَذْ إِنِينْ: ’سِيذِي وَارْ ذ أَشْ د-إِبَانْ شَا!‘ “ \f ◼ \fr 4:‏1 \ft \bd ’إِ وَاوَاڒْ إِنُو‘\bd* - س ثْعِيبْرَانِيثْ ’إِ ثْمِيجَّا إِنُو‘.\f*
\v 2 \add خنِّي\add* إِنَّا أَسْ سِيذِي: ”مِينْ غَاركْ ذڭْ ؤُفُوسْ نّشْ؟“ ؤُشَا يَارَّا-د: ”ذ ثَاغَّارْشْثْ.“
\v 3 إِنَّا: ”نْضَارْ إِ-ت خْ ثمُّورْثْ!“ إِنْضَارْ إِ-ت خْ ثمُّورْثْ، ثذْوڒْ ذ إِجّْ ؤُفِيغَارْ ؤُشَا يَارْوڒْ مُوسَا زَّايسْ.
\v 4 \add ڒخْذنِّي\add* إِنَّا سِيذِي إِ مُوسَا: ”سْوِيژّضْ أَفُوسْ نّشْ، طّفْ إِ-ت زڭْ ؤُنوَّارْ نّسْ ...“ - ؤُشَا إِسّْوِيژّضْ \add مُوسَا\add* أَفُوسْ نّسْ، إِطّفْ إِ-ت ؤُشَا ثذْوڒْ \add عَاوذْ\add* ذ ثَاغَّارْشْثْ ذڭْ ؤُفُوسْ نّسْ -
\v 5 ”... حِيمَا أَذْ أَمْننْ بلِّي أَقَا إِبَانْ أَشْ-د سِيذِي، أَربِّي ن ڒجْذُوذْ نْسنْ، أَربِّي ن إِبْرَاهِيمْ، أَربِّي ن إِسْحَاقْ ذ أَربِّي ن يَاعْقُوبْ.“
\m 
\v 6 إِنَّا أَسْ سِيذِي عَاوذْ: ”سِيذفْ أَفُوسْ نّشْ ذڭْ وحْسِينْ نّشْ.“ ؤُشَا إِسِّيذفْ أَفُوسْ نّسْ ذڭْ وحْسِينْ ؤُشَا ؤُمِي ث-إِ-د-إِكّسْ، خْزَارْ، أَفُوسْ نّسْ إِبَارْصْ أَمْ وذْفڒْ. \f ◼ \fr 4:‏6 \ft \bd ’أَحْسِينْ‘\bd* - نِيغْ ’أَبحْرُورْ‘.\f*
\v 7 ؤُشَا إِنَّا: ”أَرّْ أَفُوسْ نّشْ \add عَاوذْ\add* ذڭْ وحْسِينْ!“ يَارَّا أَفُوسْ نّسْ ذڭْ وحْسِينْ ؤُشَا إِعْقبْ إِسُّوفّغْ إِ-ث-إِ-د \add عَاوذْ\add* زڭْ وحْسِينْ، ؤُشَا خْزَارْ، إِذْوڒْ \add عَاوذْ\add* أَمْ \add مِينْ إِقِّيمنْ ن\add* أَرِّيمثْ نّسْ.
\v 8 ”مَاڒَا وَارْ زَّايكْ ؤُمِيننْ شَا ؤُ وَارْ غَاركْ د-تّسْڒِينْ إِ مِينْ ذ أَسنْ إِ غَا ثِينِي ڒعْڒَامثْ ثَامزْوَارُوثْ، \add خنِّي\add* أَذْ أَمْننْ ذِي مِينْ ذ أَسنْ غَا ثِينِي ڒعْڒَامثْ ثَانڭَّارُوثْ.
\v 9 مَاڒَا نِيثْنِي وَارْ ؤُمِيننْ شَا ذِي ثْنَاينْ ن ڒعْڒَامَاثْ-أَ ؤُ وَارْ ذ أَشْ سْڒِينْ شَا، خنِّي كْسِي أَمَانْ ن إِغْزَارْ ؤُشَا فَارّغْ إِ-ثنْ خْ ڒَاژَاغْ ؤُ أَمَانْ نِّي ثكْسِيذْ زڭْ إِغْزَارْ أَذْ ذوْڒنْ ذ إِذَامّنْ خْ ڒَاژَاغْ.“ \x ◘ \xo 4:‏9 \xt ؤُف. 7‏:‏19\x*
\m 
\v 10 \add ڒخْذنِّي\add* إِنَّا مُوسَا إِ سِيذِي: ”أَ سِيذِي إِنُو!، نشّْ وَارْ \add دْجِيغْ شَا\add* ذ أَرْيَازْ ن بُو-ثَاوَاڒِينْ، إِضنَّاضْ لَّا، \add ؤُڒَا ذ\add* فَارِيضنَّاضْ لَّا ؤُ زڭْ وَامِي ثبْذِيذْ أَذْ ثسِّيوْڒذْ أَكْ-ذ ؤُمْسخَّارْ نّشْ لَّا، مِينْزِي نشّْ غَارِي أَقمُّومْ إِذقْڒنْ ذ إِڒسْ إِذقْڒنْ.“
\v 11 إِنَّا أَسْ سِيذِي: ”وِي إِوْشِينْ أَقمُّومْ إِ بْنَاذمْ؟ نِيغْ وِي إِڭِّينْ حذْ ذ أَزِييْنُونْ نِيغْ ذ أَذهْشُورْ نِيغْ ذ ونِّي إِتّْوَاڒَانْ نِيغْ ذ أَذَارْغَاڒْ؟ مَا وَارْ \add إِدْجِي\add* ذ نشّْ، سِيذِي؟
\v 12 ڒخُّو، رُوحْ \add ذِينْ\add*، أَذْ إِڒِيغْ أَكْ-ذ ؤُقمُّومْ نّشْ، أَذْ أَشْ سّشْنغْ مْلِيحْ مِينْ غَا ثِينِيذْ.“ \x ◘ \xo 4:‏12 \xt مت. 10‏:‏19؛ مك. 13‏:‏11؛ لك. 12‏:‏12\x*
\v 13 \add مَاشَا\add* نتَّا إِنَّا: ”أَ سِيذِي إِنُو، سكّْ س ؤُفُوسْ نّشْ \add مَانْ ونْ إِ ثخْسذْ\add* أَذْ ثسّكّذْ.“
\v 14 \add ڒخْذنِّي\add* إِتّْوَاسَّارْغْ وغْضَابْ ن سِيذِي خْ مُوسَا، إِنَّا: ”مَا وَارْ إِدْجِي هَارُونْ، أَلَاوِي، ذ ؤُمَاشْ؟ نشّْ سّْنغْ، أَقَا نتَّا إِسّنْ أَذْ إِسِّيوڒْ. خْزَارْ، أَقَا أَذْ كِيشْ إِمْسَاڭَارْ ؤُ خْمِي شكْ غَا إِژَارْ، أَذْ إِفَارْحْ وُوڒْ نّسْ.
\v 15 ؤُشَا شكْ أَذْ كِيسْ ثسِّيوْڒذْ، أَذْ أَسْ ثڭّذْ أَوَاڒنْ ذڭْ ؤُقمُّومْ \add نّسْ\add*. ڭُّورْ أَذْ إِڒِيغْ أَكْ-ذ ؤُقمُّومْ نّشْ ذ ؤُقمُّومْ نّسْ، أَذْ أَومْ سّْغَارغْ مِينْ غَا ثِينِيمْ. \x ◘ \xo 4:‏15 \xt ؤُف. 7‏:‏2\x*
\v 16 نتَّا أَذْ إِسِّيوڒْ أَكْ-ذ ڒْڭنْسْ ذڭْ ومْشَانْ نّشْ. أَذْ إِمْسَارْ أَمُّو: نتَّا أَذْ أَشْ يِيڒِي \add أَمشْنَاوْ\add* أَقمُّومْ نّشْ ؤُ شكْ أَذْ ثِيڒِيذْ إِ نتَّا \add أَمشْنَاوْ\add* أَربِّي.
\v 17 أَذْ ثكْسِيذْ ثَاغَّارْشْثْ-أَ إِ زِي غَا ثڭّذْ ڒعْڒَامَاثْ ذڭْ ؤُفُوسْ نّشْ.“
\m 
\v 18 إِرُوحْ مُوسَا ؤُشَا إِذْوڒْ غَارْ ؤُضڭّْوَاڒْ نّسْ يِيثْرُو، إِنَّا أَسْ: ”أجّْ أَيِي أَذْ رَاحغْ، أَذْعقْبغْ غَارْ أَيْثْمَا نِّي إِدْجَانْ ذِي مِيصْرَا، حِيمَا أَذْ ژَترغْ، مَا عَاذْ دَّارنْ.“ إِنَّا يِيثْرُو إِ مُوسَا: ”رُوحْ ذِي ڒهْنَا.“
\v 19 إِنَّا سِيذِي عَاوذْ إِ مُوسَا ذِي مِيذْيَانْ: ”ڒُْوحْ، ثْذوْڒذْ غَارْ مِيصْرَا، مِينْزِي أَقَا مُّوثنْ مَارَّا إِنِّي ثُوغَا يَارزُّونْ ڒْموْثْ نّشْ.“
\m 
\v 20 إِكْسِي مُوسَا ثَامْغَارْثْ نّسْ ذ إِحنْجِيرنْ نّسْ ؤُشَا إِسّنْيَا إِ-ثنْ خْ وغْيُوڒْ، إِذْوڒْ-د غَارْ ثمُّورْثْ ن مِيصْرَا ؤُشَا إِكْسِي مُوسَا ثَاغَّارْشْثْ ن أَربِّي ذڭْ ؤُفُوسْ نّسْ.
\v 21 إِنَّا سِيذِي إِ مُوسَا: ”خْمِي غَا ثْرَاحذْ، أَذْ د-ثْذوْڒذْ عَاوذْ غَارْ مِيصْرَا، خْزَارْ أَذْ ثڭّذْ إِ فِيرْعُونْ مَارَّا لْمُوعْجِيزَاثْ نِّي ذ أَشْ ڭِّيغْ ذڭْ ؤُفُوسْ نّشْ. \add مَاشَا\add* نشّْ أَذْ سّْقسْحغْ ؤُڒْ نّسْ، ڒَامِي وَارْ إِخْسْ أَذْ إِضْڒقْ إِ ڒْڭنْسْ.
\v 22 \add خنِّي\add* أَذْ ثِينِيذْ إِ فِيرْعُونْ: ’أَمُّو إِ إِقَّارْ سِيذِي: إِسْرَائِيل ذ مِّي ذ أَمنْزُو إِنُو. \x ◘ \xo 4:‏22 \xt حُوش. 11‏:‏1؛ مت. 2‏:‏15\x*
\v 23 أَقَا نِّيغْ أَشْ: أجّْ أَذْ إِفّغْ مِّي أَذْ أَيِي إِعْبذْ! \add مَاشَا\add* شكْ ثُوڭِيذْ أَذْ ث ثجّذْ. خْزَارْ، نشّْ أَذْ نْغغْ مِّيشْ، أَمنْزُو نّشْ.‘ “
\b
\m 
\v 24 إِمْسَارْ ذڭْ وبْرِيذْ، ذڭْ إِجّْ ن ومْشَانْ مَانِي غَا سّنْسنْ، إِمّڒْقَا سِيذِي أَكِيذسْ ؤُ نتَّا ثُوغَا إِخْسْ أَذْ ث إِنغْ.
\v 25 \add ڒخْذنِّي\add* ثكْسِي صَافُّورَا إِشْثْ ن ثْخذْمشْثْ ن وژْرُو، ثخْثنْ ڒعْذَاڒْيثْ ن مِّيسْ ؤُشَا ثڒْقفْ أَسْ إِضَارنْ نّسْ، ثنَّا: ”س ثِيذتّْ شكْ \add ثدْجِيذْ\add* أَمْ يِيجّْ ن يسْڒِي ن إِذَامّنْ إِ نشّْ“
\v 26 إِجَّا إِ-ث خنِّي. ڒخْضنِّي ثنَّا: \bd ”\bdit شكْ\bdit* ذ إِسْڒِي ن إِذَامّنْ \bdit إِ ثدْجِيذْ\bdit*!“\bd*، ذِي سِّيبّثْ ن إِخْثَاننْ.
\m 
\v 27 إِنَّا سِيذِي إِ هَارُونْ: ”رُوحْ أَذْ ثڒْقِيذْ مُوسَا ذِي ڒخْڒَا!“ ؤُشَا إِرُوحْ، إِمْسَاڭَارْ أَكِيذسْ غَارْ وذْرَارْ ن أَربِّي، إِسُّوذمْ إِ-ث.
\v 28 إِخبَّارْ مُوسَا هَارُونْ خْ مَارَّا أَوَاڒنْ \add إِ ذ أَسْ إِنَّا\add* سِيذِي ونِّي إِ-ث-إِ-د-إِسّكّنْ ؤُڒَا خْ مَارَّا ڒعْڒَامَاثْ إِ ذ أَسْ يُومُورْ \add أَذْ إِڭّْ\add*.
\m 
\v 29 \add خنِّي\add* إِرُوحْ مُوسَا ذ هَارُونْ، سّْمُوننْ مَارَّا إِمْغَارنْ ن أَيْثْ ن إِسْرَائِيل،
\v 30 ؤُشَا إِسِّيوڒْ هَارُونْ س مَارَّا أَوَاڒنْ إِ ثُوغَا إِنَّا سِيذِي إِ مُوسَا ؤُشَا إِڭَّا ڒعْڒَامَاثْ قِيبَاتْشْ إِ ثِيطَّاوِينْ ن ڒْڭنْسْ.
\v 31 ؤُشَا يُومنْ زَّايْسنْ ڒْڭنْسْ، سْڒِينْ بلِّي سِيذِي إِزِّيدْجزْ أَسْ أَيْثْ ن إِسْرَائِيل ؤُمِي إِژْرَا ڒْمحْنثْ \add إِ ذِي دْجَانْ\add*، ؤُضَارنْ ؤُشَا بنْذْقنْ \add أَسْ\add*.
\b
\b
\c 5
\s1 مُوسَا ذ هَارُونْ زَّاثْ إِ فِيرْعُونْ
\m 
\v 1 أَوَارْنِي مَانْ أَيَا يُوذفْ مُوسَا ذ هَارُونْ غَارْ فِيرْعُونْ، نَّانْ أَسْ: ”أَمُّو إِ إِقَّارْ سِيذِي، أَربِّي ن إِسْرَائِيل: ’أجّْ أَذْ إِرَاحْ ڒْڭنْسْ إِنُو، حِيمَا أَذْ أَيِي إِعيّذْ ذِي ڒخْڒَا!‘ “
\v 2 \add مَاشَا\add* فِيرْعُونْ إِنَّا: ”مِينْ إِعْنَا سِيذِي ؤُمِي غَا سْڒغْ إِ وَاوَاڒْ نّسْ ؤُشَا أَذْ جّغْ إِسْرَائِيل أَذْ إِفّغْ. نشّْ وَارْ سِّينغْ سِيذِي ؤُ وَارْ تّجِّيغْ أَذْ إِرَاحْ إِسْرَائِيل.“ \f ◼ \fr 5:‏2 \ft \bd ’إِ وَاوَاڒْ نّسْ‘\bd* - س ثْعِيبْرَانِيثْ ’إِ ثْمِيجَّا نّسْ‘.\f*  \x ◘ \xo 5:‏2 \xt ؤُف. 3‏:‏19؛ أَيُوبْ 21‏:‏15\x*
\v 3 نِيثْنِي نَّانْ: ”أَربِّي ن إِعِيبْرَانِييّنْ إِمْسَاڭَارْ أَكِيذْنغْ، أجّْ أَنغْ خنِّي أَذْ نْرَاحْ ثِيشْڒِي ن ثْڒَاثَا ن وُوسَّانْ ذِي ڒخْڒَا، أَذْ نْقدّمْ ثَاغَارْصْثْ إِ سِيذِي، أَربِّي نّغْ، حِيمَا وَارْ ذ أَنغْ إِڒقّفْ س طَّاعُونْ نِيغْ س سِّيفْ.“ \x ◘ \xo 5:‏3 \xt ؤُف. 3‏:‏18\x*
\v 4 \add ڒخْذنِّي\add* إِنَّا أَسنْ ؤُجدْجِيذْ ن مِيصْرَا: ”مَايمِّي، \add أَ كنِّيوْ،\add* مُوسَا ذ هَارُونْ، ثسّْبدّمْ ڒْڭنْسْ خْ ڒْخذْمثْ نّسْ؟ رُوحمْ كنِّيوْ، ذوْڒمْ غَارْ دّْقُوڒَاثْ إِ خَاومْ إِدْجَانْ!“
\v 5 إِنَّا فِيرْعُونْ: ”خْزَارْ، أَقَا ڒخُّو ڒْڭنْسْ ن ثمُّورْثْ ذ أَطَّاسْ ؤُ كنِّيوْ ثخْسمْ أَذْ ثنْ ثسّْبدّمْ خْ وَارْبَارْ ن دّْقُوڒَاثْ إِ خَاسنْ تّْوَاڭّنْثْ.“
\m 
\v 6 يُومُورْ فِيرْعُونْ ذڭْ وَاسّْ نِّي إِ إِمْزيَّارنْ ن ڒْڭنْسْ ؤُ إِ إِوقَّافنْ نْسنْ، إِنَّا:
\v 7 ”زِي سَّا ذ ثْسَاونْثْ وَارْ تِّيشمْ عَاذْ ڒُومْ إِ ڒْڭنْسْ مَاحنْذْ أَذْ زَّايسْ ڭّنْ لَّاجُورْ أَمْ يِيضنَّاضْ ذ فَارِيضنَّاضْ. جّمْ ثنْ أَذْ رَاحنْ نِيثْنِي، أَذْ يْرُونْ ڒُومْ إِ يِيخفْ نْسنْ.
\v 8 ڒْقدّْ ن لَّاجُورْ إِ ڭِّينْ إِضنَّاضْ ذ فَارِيضنَّاضْ أَذْ خَاسنْ ث ثڭّمْ \add عَاوذْ\add*، وَارْ زَّايسْ ثسّْنقِّيسمْ وَالُو، مِينْزِي نِيثْنِي ذ إِفِينْيَاننْ. خْ ؤُيَا سْغُويُّونْ \add أَمُّو\add*، قَّارنْ: ’أجّْ أَنغْ أَذْ نْرَاحْ أَذْ نْقدّمْ ثَاغَارْصْثْ إِ أَربِّي نّغْ.‘
\v 9 إِتّْخصَّا ڒْخذْمثْ أَذْ ثِيڒِي ثذْقڒْ خْ إِرْيَازنْ-أَ، حِيمَا أَذْ ذَايسْ ڒْهَانْ أَمُّو ؤُشَا وَارْ تِّيشنْ \add عَاذْ\add* ثَايْنِيثْ إِ وَاوَاڒنْ إِخَارِّيقنْ.“
\m 
\v 10 \add ڒخْذنِّي\add* رُوحنْ إِمْزيَّارنْ ن ڒْڭنْسْ ذ إِوقَّافنْ نْسنْ \add ڭّْوجنْ خْ فِيرْعُونْ\add* ؤُشَا سِّيوْڒنْ أَكْ-ذ ڒْڭنْسْ، نَّانْ: ”أَمُّو إِ إِقَّارْ فِيرْعُونْ: ’نشّْ وَارْ ذ أَومْ تِّيشغْ شَا عَاذْ ڒُومْ.‘
\v 11 رُوحمْ كنِّيوْ أَذْ ثْيَارْومْ ڒُومْ مَانِي ث غَا ثَافمْ، مَاغَارْ وَارْ خَاومْ ثتّْوَاكّسْ وَالُو زِي ڒْخذْمثْ نْومْ.“
\v 12 \add ڒخْذنِّي\add* إِمْبزّعْ ڒْڭنْسْ خْ مَارَّا ثَامُّورْثْ ن مِيصْرَا، حِيمَا أَذْ يْرُونْ إِغدْجْ ذڭْ ومْشَانْ ن ؤُڒُومْ.
\v 13 إِمْزيَّارنْ زِييَّارنْ خَاسنْ، نَّانْ: ”كمّْڒمْ ڒْخذْمثْ نْومْ، كُوڒْ أَسّْ مِينْ د-إِتَّاسنْ إِ كُوڒْ أَسّْ، أَمْ مَامّشْ ثُوغَا ذِينْ ڒخْذنِّي ڒُومْ.“
\v 14 تّْوَافَارْشنْ إِوقَّافنْ ن أَيْثْ ن إِسْرَائِيل، إِنِّي خَاسنْ ڭِّينْ إِمْزيَّارنْ ن فِيرْعُونْ، نَّانْ \add أَسنْ\add*: ”مَايمِّي وَارْ ثْكمّْڒمْ ثَاسْغَارْثْ نْومْ ن لَّاجُورْ أَمْ ڒبْذَا، إِضنَّاضْ لَّا ؤُ عَاوذْ أَسّْ-أَ لَّا؟“
\v 15 \add ڒخْذنِّي\add* ؤُسِينْ-د إِوقَّافنْ ن أَيْثْ ن إِسْرَائِيل، سْغُوينْ غَارْ فِيرْعُونْ، نَّانْ: ”مَايمِّي ثتّڭّذْ أَمُّو أَكْ-ذ إِسمْغَانْ نّشْ؟
\v 16 وَارْ إِتّْموْشِي بُو ؤُڒُومْ إِ إِسمْغَانْ نّشْ، \add وَاخَّا\add* قَّارنْ أَنغْ: ’ڭّمْ لَّاجُورْ!‘ ؤُ خْزَارْ، أَقَا إِسمْغَانْ نّشْ تّتّنْ أَعْمُوذْ، وَاخَّا ڒْعِيبْ أَقَا-ث ذِي ڒْڭنْسْ نّشْ!“
\v 17 نتَّا يَارَّا-د: ”كنِّيوْ ذ إِفِينْيَاننْ، ذ إِفِينْيَاننْ \add أَطَّاسْ\add*. خْ ؤُيَا ثقَّارمْ: ’جّمْ أَنغْ أَذْ نْرَاحْ مَاحنْذْ أَذْ نْقدّمْ ثَاغَارْصْثْ إِ سِيذِي.‘
\v 18 رُوحمْ ڒخُّو أَذْ ثْخذْممْ. وَارْ ذ أَومْ تِّيشنْ عَاذْ \add أَ\add*ڒُْومْ، \add وَاخَّا\add* إِتّْخصَّا كنِّيوْ أَذْ ثقِّيممْ ثْسبّْڒمْ ڒعْبَارْ ن لَّاجُورْ!“
\m 
\v 19 \add ڒخْذنِّي\add* ژْرِينْ إِوقَّافنْ ن أَيْثْ ن إِسْرَائِيل، أَقَا-ثنْ حَاڒَا، مِينْزِي إِتّْوَانَّا: ”كنِّيوْ وَارْ سّْنقْصمْ وَالُو زِي لَّاجُورْ إِ د-إِتَّاسنْ إِ كُوڒْ أَسّْ.“
\m 
\v 20 \add ؤُمِي\add* د-فّْغنْ خْ فِيرْعُونْ، مّْصَاذَافنْ أَكْ-ذ مُوسَا ذ هَارُونْ، إِنِّي ثُوغَا ذِينْ إِبدّنْ حِيمَا أَذْ ثنْ رَاجَانْ.
\v 21 نَّانْ أَسنْ: ”ذ سِيذِي، ذ ونِّي كنِّيوْ إِتّْوَاڒَانْ، ذ ونِّي خَاومْ إِ غَا إِحكْمنْ، مِينْزِي كنِّيوْ أَقَا ثسَّارْزْڭمْ أَنغْ غَارْ فِيرْعُونْ ذ إِمْسخَّارنْ نّسْ ؤُمِي ذ أَسنْ ثڭِّيمْ سِّيفْ ذڭْ إِفَاسّنْ نْسنْ مَاحنْذْ أَذْ أَنغْ نْغنْ.“
\m 
\v 22 \add ڒخْذنِّي\add* إِذْوڒْ مُوسَا غَارْ سِيذِي، إِنَّا: ”\add أَ\add* سِيذِي إِنُو، مَايمِّي ثڭّذْ ڒْغَارْ ذِي ڒْڭنْسْ-أَ، مَايمِّي ذ أَيِي ثسّْقَاذذْ خنِّي؟
\v 23 زڭْ وَامِي ؤُذْفغْ غَارْ فِيرْعُونْ حِيمَا أَذْ سِّيوْڒغْ س يِيسمْ نّشْ، إِذدْجْ \add فِيرْعُونْ\add* ڒْڭنْسْ-أَ ؤُ شكْ قَاعْ وَارْ ثْفكِّيذْ شَا ڒْڭنْسْ نّشْ.“
\b
\b
\c 6
\s1 سِيذِي إِسِّيوڒْ أَكْ-ذ مُوسَا
\m 
\v 1 \add ڒخْذنِّي\add* إِنَّا سِيذِي إِ مُوسَا: ”ڒخُّو أَذْ ثْژَارذْ مِينْ غَا ڭّغْ إِ فِيرْعُونْ، مِينْزِي س ؤُفُوسْ إِجهْذنْ أَذْ ثنْ يجّْ أَذْ رَاحنْ، \add وَاهْ،\add* س ؤُفُوسْ إِجهْذنْ أَذْ خَاسنْ يَاژّڒْ زِي ثمُّورْثْ نّسْ.“
\v 2 إِسِّيوڒْ أَربِّي غَارْ مُوسَا، إِنَّا أَسْ: ”نشّْ ذ سِيذِي،
\v 3 نشّْ بَانغْ-د إِ إِبْرَاهِيمْ، ذ إِسْحَاقْ ذ يَاعْقُوبْ أَمْ أَربِّي، أَمْزمَّارْ خْ كُوڒْشِي، \add مَاشَا\add* س يِيسمْ إِنُو ’سِيذِي‘، ثُوغَا وَارْ غَارْسنْ تّْوَاسّْنغْ شَا.
\v 4 عَاوذْ سّْڭعّْذغْ ڒْعَاهْذْ إِنُو أَكِيذْسنْ أَقَا أَذْ أَسنْ وْشغْ ثَامُّورْثْ ن كنْعَانْ، ثَامُّورْثْ ن ؤُنوْجِي نْسنْ مَانِي ثنْ ثُوغَا أَمْ يِيبَارَّانِييّنْ.
\v 5 عَاوذْ نشّْ سْڒِيغْ أَنِيخْسسْ ن أَيْثْ ن إِسْرَائِيل، إِنِّي إِتّْوَاڭّنْ ذ إِسمْغَانْ زڭْ إِمِيصْرِييّنْ، أَقَا خَارّْصغْ ذِي ڒْعَاهْذْ إِنُو.
\v 6 س ؤُيَا أَذْ ثِينِيذْ إِ أَيْثْ ن إِسْرَائِيل: نشّْ أَقَا أَيِي ذ سِيذِي ؤُ نشّْ أَذْ كنِّيوْ سُّوفّْغغْ زِي سَاذُو زَايْڒُو ن إِمِيصْرِييّنْ. نشّْ أَذْ كنِّيوْ فكّغْ زِي ثسْمُوغِي نْسنْ، أَذْ كنِّيوْ فْذِيغْ س ؤُغِيڒْ إِسّْوِيژّْضنْ ذ ڒحْكَامَاثْ إِمْغَارنْ.
\v 7 أَذْ كنِّيوْ قبْڒغْ ذ ڒْڭنْسْ إِنُو ؤُشَا أَذْ أَومْ إِڒِيغْ ذ أَربِّي ؤُ كنِّيوْ أَذْ ثسّْنمْ بلِّي نشّْ ذ سِيذِي، أَربِّي نْومْ، ذ ونِّي ثُوغَا كنِّيوْ إِسُّوفُّوغنْ زِي سَاذُو زَايْڒُو ن إِمِيصْرِييّنْ.
\v 8 أَذْ كنِّيوْ سِّيذْفغْ غَارْ ثمُّورْثْ مِيخفْ سّْڭعّْذغْ أَفُوسْ إِنُو مَاحنْذْ أَذْ ت وْشغْ إِ إِبْرَاهِيمْ ذ إِسْحَاقْ ذ يَاعْقُوبْ ؤُ نشّْ أَذْ أَومْ ت وْشغْ ذ ڒْوَارْثْ، نشّْ ذ سِيذِي!“ \f ◼ \fr 6:‏8 \ft \bd ’سّْڭعّْذغْ أَفُوسْ إِنُو‘\bd* - مَانْ أَيَا إِخْسْ أَذْ يِينِي بلِّي أَربِّي ثُوغَا إِجِّيدْجْ أَذْ أَسنْ إِوْشْ ثَامُّورْثْ. خْزَارْ عَاوذْ عبر. 6:13-18.\f*
\v 9 أَمُّو إِ إِسِّيوڒْ مُوسَا أَكْ-ذ أَيْثْ ن إِسْرَائِيل، مَاشَا نِيثْنِي وَارْ سْڒِينْ شَا غَارْ مُوسَا زِي سِّيبّثْ ن ڒحْصَارثْ ن ثْنفْسشْثْ ذ ثَاسْمُوغِي إِقسْحنْ.
\m 
\v 10 ؤُشَا إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:
\v 11 ”أَذفْ غَارْ فِيرْعُونْ، أَجدْجِيذْ ن مِيصْرَا، ثِينِيذْ أَسْ أَذْ إِضْڒقْ إِ أَيْثْ ن إِسْرَائِيل مَاحنْذْ أَذْ فّْغنْ زِي ثمُّورْثْ نّسْ.“
\v 12 \add مَاشَا\add* مُوسَا إِسِّيوڒْ زَّاثْ إِ سِيذِي، إِنَّا: ”خْزَارْ، أَيْثْ ن إِسْرَائِيل وَارْ غَارِي د-سْڒِينْ، مَامّشْ إِ ذ أَيِي غَا إِسڒْ فِيرْعُونْ ؤُ نشّْ \add أَقَا\add* غَارِي إِينْشِيشنْ وَارْ إِتّْوَاخثْننْ.“ \f ◼ \fr 6:‏12 \ft \bd ’نشّْ ... غَارِي إِينْشِيشنْ وَارْ إِتّْوَاخثْننْ‘\bd* - مَانْ أَيَا إِخْسْ أَذْ يِينِي: نشّْ وَارْ زمَّارغْ خْ وَاوَاڒْ ذڭْ ومْشَانْ ن أَربِّي زَّاثْ إِ فِيرْعُونْ.\f*
\v 13 \add ڒخْذنِّي\add* إِسِّيوڒْ سِيذِي غَارْ مُوسَا ذ هَارُونْ ؤُشَا يُومُورْ إِ-ثنْ أَذْ ؤُيُورنْ غَارْ أَيْثْ ن إِسْرَائِيل ذ فِيرْعُونْ، أَجدْجِيذْ ن مِيصْرَا، حِيمَا أَذْ إِسُّوفّغْ أَيْثْ ن إِسْرَائِيل زِي ثمُّورْثْ ن مِيصْرَا.
\b
\s1 ثَارْوَا ن رُوبِينْ، شِيمْعُونْ ذ لَاوِي
\m 
\v 14 \bd إِنَا ذ إِزدْجِيفنْ \bdit خْ ڒَادْجَاثْ\bdit* زِي ثُوذْرِينْ ن إِبَابَاثنْ نْسنْ.\bd*
\m \bd أَيْثْ ن رُوبِينْ\bd*، أَمنْزُو ن إِسْرَائِيل، \add نِيثْنِي ذ\add* هَانُوكْ ذ فَالُّو، حَاصْرُونْ ذ كَارْمِي. ذ يِينَا ذ ڒَادْجَاثْ ن رُوبِينْ. \x ◘ \xo 6:‏14 \xt أَمز. 46‏:‏9؛ ڒخْڒ. 26‏:‏5؛ 1 إِم. 5‏:‏3\x*
\m 
\v 15 \bd أَيْثْ ن شِيمْعُونْ\bd* ثُوغَا أَثنْ ذ يَامُويِيلْ ذ يَامِينْ ذ ؤُهَاذْ ذ يَاكِينْ ذ صُوحَارْ ذ شَاوُولْ، مِّي ن إِشْثْ ن ثمْغَارْثْ ثَاكنْعَانِيثْ. إِنَا ذ ڒَادْجَاثْ ن شِيمْعُونْ. \x ◘ \xo 6:‏15 \xt أَمز. 46‏:‏10؛ ڒخْڒ. 26‏:‏12؛ 1 إِم. 4‏:‏24\x*
\m 
\v 16 إِنَا ذ إِسْمَاونْ ن \bd أَيْثْ ن لَاوِي\bd* عْلَاحْسَابْ أَستّفْ ن وخْڒَاقْ نْسنْ: جَارْشُومْ ذ قَاهَاثْ ذ مَارَارِي. ثُوغَا \add ڒْْمِيجَاڒْ ن\add* ثُوذَارْثْ ن لَاوِي مْيَا ؤُ-سبْعَا ؤُ-ثْڒَاثِينْ ن إِسڭّْوُوسَا. \x ◘ \xo 6:‏16 \xt أَمز. 46‏:‏11؛ ڒخْڒ. 3‏:‏17؛ 26‏:‏57؛ 1 إِم. 5‏:‏25، 1؛ 23‏:‏6\x*
\b
\m 
\v 17 \bd أَيْثْ ن جَارْشُومْ\bd* ثُوغَا أَثنْ ذ لِيبْنَا ذ شِيمْعِي عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ. \x ◘ \xo 6:‏17 \xt 1 إِم. 6‏:‏2؛ 23‏:‏7\x*
\m 
\v 18 \bd أَيْثْ ن قَاهَاثْ\bd* ثُوغَا أَثنْ ذ عَامْرَامْ ذ يِيصْهَارْ ذ حَابْرُونْ ذ عُوزِّييِيلْ. ثُوغَا \add ڒْْمِيجَاڒْ ن\add* ثُوذَارْثْ ن قَاهَاثْ مْيَا ؤُ-ثْڒَاثَا ؤُ-ثْڒَاثِينْ ن إِسڭّْوُوسَا. \x ◘ \xo 6:‏18 \xt 1 إِم. 6‏:‏3؛ 23‏:‏12\x*
\m 
\v 19 \bd أَيْثْ ن مَارَارِي\bd* ثُوغَا أَثنْ ذ مَاحْلِي ذ مُوشِي. إِنَا ذ ڒَادْجَاثْ ن لَاوِي عْلَاحْسَابْ \add أَستّفْ ن\add* وخْڒَاقْ نْسنْ. \x ◘ \xo 6:‏19 \xt 1 إِم. 6‏:‏4؛ 23‏:‏21\x*
\b
\m 
\v 20 ؤُشَا \bd عَامْرَامْ\bd* إِكْسِي يُوكَابَاذْ،عنْثِيسْ، ذ ثَامْغَارْثْ إِ يِيخفْ نّسْ ؤُ نتَّاثْ ثُورُووْ أَسْ-د هَارُونْ ذ مُوسَا. ثُوغَا \add ڒْْمِيجَاڒْ\add* ن ثُوذَارْثْ ن عَامْرَامْ مْيَا ؤُ-سبْعَا ؤُ-ثْڒَاثِينْ ن إِسڭّْوُوسَا. \x ◘ \xo 6:‏20 \xt ؤُف. 2‏:‏1؛ ڒخْڒ. 26‏:‏59\x*
\m 
\v 21 \bd أَيْثْ ن يِيصْهَارْ\bd* ثُوغَا أَثنْ ذ قُورَاحْ ذ نَافَاجْ ذ ذِيكْرِي.
\m 
\v 22 \bd أَيْثْ ن عُوزِّييِيلْ\bd* ثُوغَا أَثنْ ذ مِيشَايِيلْ ذ أَلْصَافَانْ ذ سِيثْرِي.
\m 
\v 23 ؤُشَا إِكْسِي \bd هَارُونْ\bd* إِلِيشَابَاعْ، يدْجِيسْ ن عَامِّينَاذَابْ، ؤُتْشْمَاسْ ن نَاحْشُونْ، ذ ثَامْغَارْثْ إِ يِيخفْ نّسْ ؤُ نتَّاثْ ثُورُووْ أَسْ-د نَاذَابْ ذ أَبِيهُو ذ أَلِيعَازَارْ ذ إِثَامَارْ. \x ◘ \xo 6:‏23 \xt ڒخْڒ. 3‏:‏2؛ 26‏:‏60؛ 1 إِم. 5‏:‏29؛ 24‏:‏1\x*
\m 
\v 24 \bd أَيْثْ ن قُورَاحْ\bd* \add ثُوغَا أَثنْ ذ\add* أَسِّيرْ ذ أَلْقَانَا ذ أَبِييَاسَافْ. إِنَا ذ ڒَادْجَاثْ ن إِقُورَاحِييّنْ.
\b
\m 
\v 25 ؤُشَا \bd أَلِيعَازَارْ\bd*، مِّيسْ ن هَارُونْ، إِكْسِي إِشْثنْ زڭْ يسِّيسْ ن فُوثِييِيلْ ذ ثَامْغَارْثْ إِ يِيخفْ نّسْ ؤُشَا نتَّاثْ ثُورُووْ أَسْ-د \bd فِينَاحَاسْ\bd*. إِنَا ذ إِزدْجِيفنْ \add ن ثُوذْرِينْ\add* ن إِبَابَاثنْ ن إِلَاوِييّنْ عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ.
\b
\m 
\v 26 أَقَا وَا ذ هَارُونْ ذ مُوسَا إِ ؤُمِي إِنَّا سِيذِي: ”سُوفّْغمْ أَيْثْ ن إِسْرَائِيل زِي ثمُّورْثْ ن مِيصْرَا \add أَمْ تّْوَاستّْفنْ نِيثْنِي\add* عْلَاحْسَابْ إِسذِّييّنْ ن ڒْعسْكَارْ نْسنْ.“
\v 27 إِنَا ذ إِنِّي إِسِّيوْڒنْ أَكْ-ذ فِيرْعُونْ، أَجدْجِيذْ ن مِيصْرَا، حِيمَا أَذْ سُّوفّْغنْ أَيْثْ ن إِسْرَائِيل زِي مِيصْرَا، مُوسَا ذ هَارُونْ، \add نِيثْنِي\add* ذ إِنَا.
\v 28 إِمْسَارْ ذڭْ وَاسّْ إِ إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا ذِي ثمُّورْثْ ن مِيصْرَا،
\v 29 أَقَا إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا: ”نشّْ ذ سِيذِي إِ دْجِيغْ! مَارَّا مِينْ ذ أَشْ قَّارغْ، إِنِي ث إِ فِيرْعُونْ، أَجدْجِيذْ ن مِيصْرَا.“
\v 30 \add خنِّي\add* إِنَّا مُوسَا زَّاثْ إِ سِيذِي: ”أَقَا غَارِي نشّْ إِينْشِيشنْ وَارْ إِتّْوَاخثْننْ، مَامّشْ غَا يڭّْ \add خنِّي\add* أَذْ غَارِي إِسدْجْ فِيرْعُونْ؟“ \f ◼ \fr 6:‏30 \ft \bd ’أَقَا غَارِي إِينْشِيشنْ وَارْ إِتّْوَاخثْننْ‘\bd* - خْزَارْ أَفسَّارْ غَارْ ؤُف. 6:12.\f*  \x ◘ \xo 6:‏30 \xt ؤُف. 6‏:‏12؛ ؤُف. 4‏:‏10\x*
\b
\b
\c 7
\s1 مُوسَا ذ هَارُونْ رُوحنْ غَارْ فِيرْعُونْ ثْوَاڒَا نّغْنِي
\m 
\v 1 إِنَّا سِيذِي إِ مُوسَا: ”خْزَارْ، نشّْ أَقَا ڭِّيغْ شكْ ذ أَربِّي إِ فِيرْعُونْ ذ ؤُمَاشْ هَارُونْ أَذْ أَشْ يِيڒِي ذ أَنَابِي إِ شكْ.
\v 2 شكْ أَذْ ثِينِيذْ مَارَّا مِينْ زِي شكْ غَا ؤُمُورغْ ؤُشَا هَارُونْ، ؤُمَاشْ، أَذْ إِسِّيوڒْ أَكْ-ذ فِيرْعُونْ، حِيمَا أَذْ يجّْ أَذْ فّْغنْ أَيْثْ ن إِسْرَائِيل زِي ثمُّورْثْ نّسْ. \x ◘ \xo 7:‏2 \xt ؤُف. 4‏:‏14\x*
\v 3 \add مَاشَا\add* نشّْ أَذْ سّْقسْحغْ ؤُڒْ ن فِيرْعُونْ ؤُشَا أَذْ كتَّارغْ ڒعْڒَامَاثْ ذ لْمُوعْجِيزَاثْ إِنُو ذِي ثمُّورْثْ ن مِيصْرَا.
\v 4 \add مَاشَا\add* فِيرْعُونْ وَارْ غَارْومْ-د إِسّْحسِّي ؤُ نشّْ أَذْ ڭّغْ أَفُوسْ إِنُو خْ مِيصْرَا ؤُشَا أَذْ سُّوفّْغغْ ڒْعسْكَارَاثْ إِنُو، ڒْڭنْسْ إِنُو، أَيْثْ ن إِسْرَائِيل، زِي ثمُّورْثْ ن مِيصْرَا س ڒحْكَامَاثْ إِمْغَارنْ.
\v 5 \add ڒخْذنِّي\add* أَذْ سّْننْ إِمِيصْرِييّنْ بلِّي نشّْ ذ سِيذِي إِ دْجِيغْ خْمِي غَا سّْوِيژّْضغْ أَفُوسْ إِنُو خْ مِيصْرَا ؤُشَا أَذْ سُّوفّْغغْ أَيْثْ ن إِسْرَائِيل زِي ڒْوسْطْ نْسنْ.“
\m 
\v 6 ؤُشَا ڭِّينْ مُوسَا ذ هَارُونْ أَمْ مَامّشْ ثنْ يُومُورْ سِيذِي، \add وَاهْ،\add* أَمنِّي إِ ڭِّينْ.
\v 7 ثُوغَا مُوسَا ذ إِجّْ ن بْنَاذمْ ن ثْمنْيِينْ ن إِسڭّْوُوسَا ؤُ ثُوغَا هَارُونْ \add ذ إِجّْ ن بْنَاذمْ\add* ن ثْڒَاثَا ؤُ-ثْمنْيِينْ ن إِسڭّْوُوسَا، ڒَامِي سِّيوْڒنْ أَكْ-ذ فِيرْعُونْ.
\m 
\v 8 ؤُشَا إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا ذ هَارُونْ، إِنَّا:
\v 9 ”مَاڒَا إِسِّيوڒْ أَكِيذْومْ فِيرْعُونْ، أَذْ يِينِي: ’سشْنمْ، أَقَا كنِّيوْ ثْزمَّارمْ أَذْ ثڭّمْ إِشْثْ ن لْمُوعْجِيزَا!‘، خنِّي أَذْ ثِينِيذْ إِ هَارُونْ: ’طّفْ ثَاغَّارْشْثْ نّشْ ؤُشَا نْضَارْ إِ-ت زَّاثْ إِ فِيرْعُونْ!‘، \add خنِّي\add* أَذْ ثذْوڒْ ذ إِشْثْ ن ڒْهَايْشثْ.“
\v 10 ؤُذْفنْ \add خنِّي\add* مُوسَا ذ هَارُونْ غَارْ فِيرْعُونْ ؤُشَا ڭِّينْ مَامّشْ \add إِ ذ أَسنْ\add* يُومُورْ سِيذِي. إِنْضَارْ هَارُونْ ثَاغَّارْشْثْ نّسْ زَّاثْ إِ فِيرْعُونْ ذ إِمْسخَّارنْ نّسْ ؤُشَا ثذْوڒْ ذ إِشْثْ ن ڒْهَايْشثْ.
\v 11 \add ڒخْذنِّي\add* إِڒَاغَا-د عَاوذْ فِيرْعُونْ خْ إِمِيغِيسنْ ذ إِسحَّارنْ، ؤُشَا ثَارْوَا ن ثْسحَّارْثْ ن مِيصْرَا ڭِّينْ عَاوذْ أَمنِّي س ثْمڭَّا نْسنْ ن سْوَادَّايْ سْوَادَّايْ ذ إِشْثْ.
\v 12 إِنْضَارْ كُوڒْ إِجّنْ ثَاغَّارْشْثْ نّسْ ؤُشَا ذوْڒنْثْ \add ثِيغَّارْينْ نِّي\add* ذ ڒْهَايْشَاثْ. \add مَاشَا\add* ثَاغَّارْشْثْ ن هَارُونْ ثْسَارْضْ ثِيغَّارْينْ نْسنْ.
\v 13 ؤُڒْ ن فِيرْعُونْ إِذْوڒْ إِقْسحْ ؤُشَا وَارْ غَارْسنْ إِسْڒِي شَا، أَمْ مَامّشْ ثُوغَا إِ ذ أَسنْ إِنَّا سِيذِي \add قْبڒْ\add*.
\b
\s1 ثسْعَا ن جّْرَايحْ ثِيمزْوُورَا
\m 
\v 14 \add ڒخْذنِّي\add* إِنَّا سِيذِي إِ مُوسَا: ”ؤُڒْ ن فِيرْعُونْ إِذْوڒْ إِقْسحْ. وَارْ إِخْسْ أَذْ يجّْ أَذْ إِفّغْ ڒْڭنْسْ.
\v 15 رُوحْ ثِيوشَّا غَارْ صّْبحْ غَارْ فِيرْعُونْ. خْزَارْ، نتَّا أَذْ إِفّغْ غَارْ وَامَانْ. شكْ رَاجَا ذِينْ غَارْ ثْمَا ن يِيغْزَارْ ؤُشَا كْسِي-د ثَاغَّارْشْثْ نِّي إِذوْڒنْ ذ أَفِيغَارْ ذڭْ ؤُفُوسْ نّشْ.
\v 16 أَذْ أَسْ ثِينِيذْ: ’سِيذِي، أَربِّي ن إِعِيبْرَانِييّنْ إِسّكّْ أَيِي-د غَاركْ، إِنَّا: أجّْ أَذْ إِرَاحْ ڒْڭنْسْ إِنُو، حِيمَا أَذْ أَيِي إِعْبذْ ذِي ڒخْڒَا! خْزَارْ، أَڒْ ڒخُّو وَارْ ثخْسذْ أَذْ ثْسدْجذْ.
\v 17 أَمُّو إِ إِقَّارْ سِيذِي: ’س مَانْ أَيَا أَذْ ثسّْنذْ بلِّي نشّْ ذ سِيذِي!‘ خْزَارْ، نشّْ أَذْ وْثغْ أَمَانْ إِ إِدْجَانْ ذڭْ إِغْزَارْ س ثغَّارْشْثْ إِ غَارِي ذڭْ ؤُفُوسْ إِنُو ؤُشَا أَذْ ذوْڒنْ ذ إِذَامّنْ.
\v 18 إِسڒْمَانْ إِ إِدْجَانْ ذڭْ إِغْزَارْ أَذْ مّْثنْ \add أَڒْ غَا\add* يُورْصُوضْ إِغْزَارْ \add ن نِيلْ\add*، أَذْ عِيفّنْ إِمِيصْرِييّنْ أَذْ سْونْ أَمَانْ ن إِغْزَارْ \add ن نِيلْ\add*.‘ “
\v 19 إِنَّا سِيذِي \add عَاوذْ\add* إِ مُوسَا: ”إِنِي إِ هَارُونْ: ’كْسِي ثَاغَّارْشْثْ نّشْ، سْوِيژّضْ أَفُوسْ نّشْ خْ وَامَانْ ن مِيصْرَا، خْ إِغزْرَانْ نْسنْ، خْ ثْغزْرَاثِينْ نْسنْ، خْ إِيڒْمَامنْ نْسنْ خْ مَارَّا إِمُوشَانْ مَانِيسْ تّْمُونَانْ وَامَانْ ؤُشَا أَذْ ذوْڒنْ ذ إِذَامّنْ. أَذْ ذوْڒنْ ذ إِذَامّنْ خْ مَارَّا ثَامُّورْثْ ن مِيصْرَا، \add ؤُڒَا\add* ذِي \add ڒقْشُوعْ\add* ن ؤُكشُّوضْ ذ وژْرُو.‘ “
\m 
\v 20 مُوسَا ذ هَارُونْ ڭِّينْ أَمْ مَامّشْ \add إِ ذ أَسنْ\add* يُومُورْ سِيذِي. إِسّْڭعّذْ هَارُونْ ثَاغَّارْشْثْ، إِوْثَا أَمَانْ نِّي ثُوغَا ذڭْ إِغْزَارْ قِيبَاتْشْ إِ ثِيطَّاوِينْ ن فِيرْعُونْ ذ إِمْسخَّارنْ نّسْ ؤُشَا \bd مَارَّا أَمَانْ نِّي ثُوغَا ذڭْ إِغْزَارْ ذوْڒنْ ذ إِذَامّنْ.\bd* \x ◘ \xo 7:‏20 \xt ؤُف. 17‏:‏5؛ إِزهد. 78‏:‏44؛ 105‏:‏29\x*
\v 21 مُّوثنْ إِسڒْمَانْ إِنِّي ثُوغَا ذڭْ إِغْزَارْ ؤُشَا يُورْصُوضْ يغْزَارْ أَڒَامِي ذوْڒنْ إِمِيصْرِييّنْ وَارْ زمَّارنْ أَذْ زَّايسْ سْونْ أَمَانْ ؤُشَا ذوْڒنْ \add وَامَانْ\add* ذ إِذَامّنْ ذِي مَارَّا ثَامُّورْثْ ن مِيصْرَا.
\v 22 \add مَاشَا\add* ثَارْوَا ن ثْسحَّارْثْ ن مِيصْرَا ڭِّينْ أَمنِّي س ثْمڭَّا نْسنْ ن سْوَادَّايْ سْوَادَّايْ \add أَڒَامِي\add* ؤُڒْ ن فِيرْعُونْ إِذْوڒْ إِقْسحْ، ؤُ نتَّا وَارْ غَارْسنْ إِسّْحسّْ شَا، أَمْ مَامّشْ ذ أَسنْ ثُوغَا إِنَّا سِيذِي.
\v 23 إِنّقْڒبْ فِيرْعُونْ ؤُشَا يُوذفْ غَارْ ثَادَّارْثْ نّسْ ؤُشَا وَارْ إِڭِّي ؤُڒْ نّسْ عَاذْ ذِي مَانْ أَيَا.
\m 
\v 24 مَارَّا إِمِيصْرِييّنْ غْزَانْ خْ ثْمَا ن إِغْزَارْ \add ن نِيلْ\add* مَاحنْذْ أَذْ أَفنْ أَمَانْ ن ثسِّيثْ، مِينْزِي وَارْ زمَّارنْ أَذْ سْونْ أَمَانْ ن إِغْزَارْ \add ن نِيلْ\add*.
\v 25 \add أَمُّو إِ\add* عْذُونْ سبْعَا ؤُسَّانْ أَوَارْنِي ڒَامِي إِوْثَا سِيذِي إِغْزَارْ \add ن نِيلْ\add*.
\m 
\v 26 \add خنِّي\add* إِنَّا سِيذِي إِ مُوسَا: ”أَذفْ غَارْ فِيرْعُونْ، إِنِي أَسْ: ’أَمُّو إِ إِقَّارْ سِيذِي: أجّْ أَذْ إِفّغْ ڒْڭنْسْ إِنُو حِيمَا أَذْ أَيِي إِعْبذْ.
\v 27 مَاڒَا ثُوڭِيذْ أَذْ \add ثنْ\add* ثجّذْ أَذْ رَاحنْ، أَقَا أَذْ وْثغْ مَارَّا ثَامُّورْثْ نّشْ س إِقَارْقْرِيونْ
\v 28 ؤُشَا إِغْزَارْ \add ن نِيلْ\add* أَذْ د-إِسفِّييْ خْ إِقَارْقْرِيونْ، أَذْ \add زَّايسْ-د\add* ڭعّْذنْ، أَذْ أَذْفنْ غَارْ ثَادَّارْثْ نّشْ ؤُ غَارْ وخَّامْ نّشْ ن يِيضصْ، \add أَذْ د-أَسنْ\add* خْ قَامَا نّشْ ؤُڒَا ذِي ثَادَّارْثْ ن إِمْسخَّارنْ نّشْ ؤُ جَارْ ڒْڭنْسْ نّشْ، ؤُ \add عَاذْ\add* ذڭْ إِفَارَّاننْ نّشْ ؤُ ذِي ثْبقْيِينْ نّشْ.
\v 29 أَذْ خَاكْ د-ڭعّْذنْ إِقَارْقْرِيونْ ؤُڒَا خْ ڒْڭنْسْ نّشْ ؤُ خْ مَارَّا إِمْسخَّارنْ نّشْ.‘ “
\b
\b
\c 8
\m 
\v 1 إِنَّا سِيذِي \add عَاوذْ\add* إِ مُوسَا: ”إِنِي إِ هَارُونْ: ’سْوِيژّضْ أَفُوسْ نّشْ س ثغَّارْشْثْ نّشْ خْ إِغزْرَانْ، خْ ثْغزْرَاثِينْ ؤُڒَا خْ إِيڒْمَامنْ، سْڭعّذْ \bd إِقَارْقْرِيونْ\bd* خْ ثمُّورْثْ ن مِيصْرَا.‘ “
\v 2 ؤُشَا إِسّْوِيژّضْ هَارُونْ أَفُوسْ نّسْ خْ وَامَانْ ن مِيصْرَا ؤُشَا ڭعّْذنْ-د إِقَارْقْرِيونْ ؤُشَا ذْڒِينْ ثَامُّورْثْ ن مِيصْرَا.
\v 3 ؤُشَا ؤُڒَا ذ ثَارْوَا ن ثْسحَّارْثْ ڭِّينْ أَمنِّي س ثْمڭَّا نْسنْ ن سْوَادَّايْ سْوَادَّايْ ذ إِشْثْ، ؤُشَا سّْڭعّْذنْ-د \add عَاوذْ\add* إِقَارْقْرِيونْ خْ ثمُّورْثْ ن مِيصْرَا.
\v 4 إِڒَاغَا-د فِيرْعُونْ خْ مُوسَا ذ هَارُونْ، إِنَّا أَسنْ: ”ژَتدْجمْ س ڒَادْجَاغْ إِ سِيذِي حِيمَا أَذْ خَافِي إِكْسِي إِقَارْقْرِيونْ ؤُ خْ ڒْڭنْسْ إِنُو، ؤُشَا خنِّي أَذْ جّغْ أَذْ إِفّغْ ڒْڭنْسْ، مَاحنْذْ أَذْ قدّْمنْ ثِيغَارْصَا إِ سِيذِي.“
\v 5 إِنَّا مُوسَا إِ فِيرْعُونْ: ”طّفْ خَافِي ڒْحُورْمثْ مڒْمِي ذ أَيِي غَا ثِينِيذْ أَذْ خَاكْ ژَّادْجغْ ؤُ خْ إِمْسخَّارنْ نّشْ ؤُ خْ ڒْڭنْسْ نّشْ، مَاحنْذْ أَذْ خَاكْ قضْعغْ إِقَارْقْرِيونْ ؤُ خْ ثُوذْرِينْ نّشْ، أَذْ قِّيمنْ ذڭْ إِغْزَارْ وَاهَا.“
\v 6 يَارَّا-د خَاسْ: ”ثِيوشَّا!“ إِنَّا \add مُوسَا\add*: ”أَذْ يِيڒِي أَمْ مَامّشْ ثنِّيذْ حِيمَا أَذْ ثسّْنذْ بلِّي وَارْ \add ذِينْ\add* إِدْجِي حذْ أَمْ سِيذِي، أَربِّي نّغْ.
\v 7 ؤُشَا إِقَارْقْرِيونْ أَذْ مّكْسِينْ خَاكْ ؤُ خْ ثُوذْرِينْ نّشْ ؤُڒَا خْ إِمْسخَّارنْ نّشْ ؤُ خْ ڒْڭنْسْ نّشْ، أَذْ قِّيمنْ ذڭْ إِغْزَارْ وَاهَا.“
\v 8 \add ڒخْذنِّي\add* إِفّغْ مُوسَا ذ هَارُونْ خْ فِيرْعُونْ ؤُشَا إِڒَاغَا مُوسَا إِ سِيذِي ذِي سِّيبّثْ \add ن جّْرِيحشْثْ\add* ن إِقَارْقْرِيونْ نِّي ثُوغَا إِڭَّا خْ فِيرْعُونْ.
\v 9 ؤُشَا إِڭَّا سِيذِي أَمْ مَامّشْ د-إِتَّاسْ أَكْ-ذ وَاوَاڒْ ن مُوسَا ؤُشَا مُّوثنْ إِقَارْقْرِيونْ \add ؤُشَا ودَّارنْ\add* زِي ثُوذْرِينْ، زِي ڒمْرَاحَاثْ ؤُ زڭْ إِيَّارنْ.
\v 10 ؤُشَا سّْمُوننْ ثنْ ذ إِعُورَّاشْ ؤُشَا ثُورْصُوضْ \add زَّايْسنْ\add* ثمُّورْثْ.
\v 11 \add ڒَْامِي\add* إِژْرَا فِيرْعُونْ بلِّي أَقَا بْنَاذمْ إِزمَّارْ أَذْ يَارّْ نّفْسْ، إِسّقْسحْ ؤُڒْ نّسْ ؤُشَا وَارْ غَارْسنْ إِسّْحسّْ، أَمْ مَامّشْ ثُوغَا إِنَّا سِيذِي. \x ◘ \xo 8:‏11 \xt ؤُف. 7‏:‏14\x*
\b
\m 
\v 12 \add ڒخْذنِّي\add* إِنَّا سِيذِي إِ مُوسَا: ”إِنِي إِ هَارُونْ: ’سْوِيژّضْ ثَاغَّارْشْثْ نّشْ، ثوْثذْ \add زَّايسْ\add* أَشَاڒْ ن ثمُّورْثْ. \add خنِّي\add* أَذْ إِذْوڒْ ذ نَّامُوسْ خْ مَارَّا ثَامُّورْثْ ن مِيصْرَا.‘ “
\v 13 ؤُشَا أَمُّو إِ ڭِّينْ نِيثْنِي. إِسّْوِيژّضْ هَارُونْ أَفُوسْ نّسْ س ثغَّارْشْثْ نّسْ إِ ذَايسْ، إِوْثَا أَشَاڒْ ن ثمُّورْثْ. ؤُشَا يُوسَا-د نَّامُوسْ أَمْ خْ إِوْذَانْ أَمْ خْ ڒْمَاڒْ. \bd مَارَّا أَشَاڒْ ن ثمُّورْثْ إِذْوڒْ ذ نَّامُوسْ\bd* ذِي مَارَّا ثَامُّورْثْ ن مِيصْرَا. \x ◘ \xo 8:‏13 \xt إِزهد. 105‏:‏31\x*
\v 14 ثَارْوَا ن ثْسحَّارْثْ ڭِّينْ ثِيزمَّارْ نْسنْ أَمنِّي \add عَاوذْ\add* س ثْمڭَّا نْسنْ ن سْوَادَّايْ سْوَادَّايْ، مَاحنْذْ أَذْ سُّوفّْغنْ نَّامُوسْ، مَاشَا وَارْ زمَّارنْ. ؤُشَا ثُوغَا نَّامُوسْ خْ إِوْذَانْ ذ ڒْمَاڒْ.
\v 15 \add ڒخْذنِّي\add* نَّانْ ثَارْوَا ن ثْسحَّارْثْ إِ فِيرْعُونْ: ”مَانْ أَيَا ذ أَضَاضْ ن أَربِّي!“ \add مَاشَا\add* إِسّقْسحْ ؤُڒْ ن فِيرْعُونْ ؤُشَا وَارْ د غَارْسنْ إِسدْجْ شَا، أَمْ مَامّشْ ثُوغَا إِنَّا سِيذِي.
\b
\m 
\v 16 ؤُشَا إِنَّا سِيذِي إِ مُوسَا: ”ثِيوشَّا كَّارْ زِيشْ، أَذْ ثْبدّذْ زَّاثْ إِ فِيرْعُونْ. خْزَارْ، نتَّا أَذْ إِفّغْ غَارْ ثْمَا ن وَامَانْ، أَذْ أَسْ ثِينِيذْ: ’أَمُّو إِ إِقَّارْ سِيذِي: أجّْ أَذْ إِرَاحْ ڒْڭنْسْ إِنُو، حِيمَا أَذْ أَيِي إِعْبذْ!
\v 17 مِينْزِي مَاڒَا وَارْ ثجِّيذْ ڒْڭنْسْ إِنُو أَذْ إِرَاحْ، خْزَارْ، نشّْ أَذْ خَاكْ سّكّغْ \bd إِيْڒَافنْ ن إِبعَّاشْ\bd*، خْ إِمْسخَّارنْ نّشْ، خْ ڒْڭنْسْ نّشْ، خْ ثُوذْرِينْ نّشْ، أَڒْ غَا تّْوَاشُّورنْثْ ثُوذْرِينْ ن إِمِيصْرِييّنْ س إِيْڒَافنْ ن إِبعَّاشْ ؤُشَا أَمنِّي ؤُڒَا ذ ثَامُّورْثْ مَانِي \add زدّْغنْ\add*.
\v 18 ذڭْ وَاسّْ نِّي أَذْ سّْحُوزغْ ثَامُّورْثْ ن جُوشَانْ مَانِي إِزدّغْ ڒْڭنْسْ إِنُو، حِيمَا وَارْ ذِينْ تِّيڒِينْ ويْڒَافنْ ن إِبعَّاشْ حِيمَا أَذْ ثسّْنذْ بلِّي نشّْ ذ سِيذِي ذِي ڒْوسْطْ ن ثمُّورْثْ.
\v 19 ؤُشَا أَذْ ڭّغْ \bd إِجّْ ن \bdit تَّامَانْ ن\bdit* وصْڒَاحْ\bd* جَارْ ڒْڭنْسْ إِنُو ذ ونِّي نّشْ. ثِيوشَّا أَذْ ثِيڒِي ڒعْڒَامثْ-أَ.‘ “
\v 20 ؤُشَا أَمُّو إِ إِڭَّا سِيذِي. ؤُسِينْ-د إِيْڒَافنْ إِمقّْرَاننْ ن إِبعَّاشْ خْ ثَادَّارْثْ ن فِيرْعُونْ، خْ ثُوذْرِينْ ن إِمْسخَّارنْ نّسْ ؤُ خْ مَارَّا ثَامُّورْثْ ن مِيصْرَا ؤُشَا ثتّْوَاخَارّبْ ثمُّورْثْ س إِيْڒَافنْ ن إِبعَّاشْ. \x ◘ \xo 8:‏20 \xt إِزهد. 78‏:‏45؛ 105‏:‏31\x*
\v 21 \add ڒخْذنِّي\add* إِڒَاغَا فِيرْعُونْ إِ مُوسَا ذ هَارُونْ، إِنَّا أَسنْ: ”رُوحمْ، ثْقدّْممْ ثَاغَارْصْثْ إِ أَربِّي نْومْ ذِي ثمُّورْثْ-أَ.“
\v 22 إِنَّا مُوسَا: ”وَارْ د-يُوسِي أَذْ نڭّْ أَمُّو، مِينْزِي أَذْ نْقدّمْ ثَاغَارْصْثْ إِ سِيذِي، أَربِّي نّغْ، مِينْ إِدْجَانْ ذ إِشْثْ ن جّْعِيفشْثْ غَارْ إِمِيصْرِييّنْ. خْزَارْ، مَاڒَا نْقدّمْ ذ ثَاغَارْصْثْ زَّاثْ إِ ثِيطَّاوِينْ ن إِمِيصْرِييّنْ \add مِينْ ذ أَسنْ إِتّْغِيڒْ ذْ\add* جّْعِيفشْثْ، مَا وَارْ ذ أَنغْ ثَارجّْمنْ شَا؟ \x ◘ \xo 8:‏22 \xt أَمز. 43‏:‏32؛ 46‏:‏34\x*
\v 23 أجّْ أَنغْ أَذْ نْرَاحْ ثِيشْڒِي ن ثْڒَاثَا ن وُوسَّانْ ذِي ڒخْڒَا، حِيمَا أَذْ نْقدّمْ ثَاغَارْصْثْ إِ سِيذِي، أَربِّي نّغْ، أَمْ مَامّشْ ذ أَنغْ يُومُورْ نتَّا.“
\v 24 \add خنِّي\add* إِنَّا فِيرْعُونْ: ”نشّْ أَذْ كنِّيوْ جّغْ أَذْ ثْرَاحمْ ؤُشَا أَذْ ثْقدّْممْ ثَاغَارْصْثْ إِ سِيذِي، أَربِّي نْومْ، ذِي ڒخْڒَا، مَاشَا وَارْ إِعدّڒْ أَذْ ثِيڭّْوِيجمْ أَطَّاسْ. ژَتدْجمْ \add ؤُڒَا\add* خَافِي.“
\v 25 مُوسَا إِنَّا: ”أَقَا أَذْ خَاكْ فّْغغْ، أَذْ ژَّادْجغْ إِ سِيذِي، حِيمَا أَذْ إِكّسْ ثِيوشَّا إِيْڒَافنْ ن إِبعَّاشْ خْ فِيرْعُونْ، خْ إِمْسخَّارنْ نّسْ ؤُڒَا خْ ڒْڭنْسْ نّسْ. مَاشَا إِتّْخصَّا فِيرْعُونْ وَارْ إِخدّعْ ثْوَاڒَا نّغْنِي، وَارْ إِتّجِّي أَذْ إِرَاحْ ڒْڭنْسْ، مَاحنْذْ أَذْ إِقدّمْ ثَاغَارْصْثْ إِ سِيذِي.“
\v 26 \add ڒخْذنِّي\add* إِفّغْ مُوسَا خْ فِيرْعُونْ ؤُشَا إِژُّودْجْ إِ سِيذِي.
\v 27 إِڭَّا سِيذِي عْلَاحْسَابْ أَوَاڒْ \add إِ إِنَّا\add* مُوسَا ؤُشَا إِكّسْ إِيْڒَافنْ ن إِبعَّاشْ خْ فِيرْعُونْ، خْ إِمْسخَّارنْ نّسْ، ؤُڒَا خْ ڒْڭنْسْ نّسْ. وَارْ إِقِّيمْ ؤُڒَا ذ إِجّْ \add ن ؤُبعُّوشْ\add*.
\v 28 \add مَاشَا\add* فِيرْعُونْ إِسّقْسحْ ؤُڒْ نّسْ ثْوَاڒَا-يَا عَاوذْ، وَارْ إِجِّي أَذْ إِرَاحْ ڒْڭنْسْ. \x ◘ \xo 8:‏28 \xt ؤُف. 8‏:‏11\x*
\b
\b
\c 9
\m 
\v 1 \add ڒخْذنِّي\add* إِنَّا سِيذِي إِ مُوسَا: ”أَذفْ غَارْ فِيرْعُونْ، إِنِي أَسْ: ’سِيذِي، أَربِّي ن إِعِيبْرَانِييّنْ إِقَّارْ أَمُّو: أجّْ أَذْ إِرَاحْ ڒْڭنْسْ إِنُو، مَاحنْذْ أَذْ أَيِي إِعْبذْ.
\v 2 مِينْزِي مَاڒَا ثُوڭِيذْ أَذْ \add ثنْ\add* ثجّذْ أَذْ رَاحنْ ؤُشَا أَذْ ثنْ ثطّْفذْ عَاذْ كْثَارْ،
\v 3 خْزَارْ، أَفُوسْ ن سِيذِي أَذْ يِيڒِي خْ ڒْمَاڒْ نّشْ نِّي إِدْجَانْ ذڭْ إِيَّارْ، خْ إِيْسَانْ ذ يغْيَاڒْ ذ يِيڒغْمَانْ ذ إِفُونَاسنْ ذ ثْفُونَاسِينْ ؤُڒَا خْ وُودْجِي س يِيجّْ ن \bd طَّاعُونْ إِقسْحنْ أَطَّاسْ\bd*.
\v 4 أَذْ إِفَارْزْ سِيذِي جَارْ ڒبْهَايمْ ن أَيْثْ ن إِسْرَائِيل ذ ڒبْهَايمْ ن إِمِيصْرِييّنْ، حِيمَا وَارْ إِتّْمتِّي وَالُو زِي مَارَّا مِينْ إِدْجَانْ ن أَيْثْ ن إِسْرَائِيل.‘ “
\v 5 ؤُشَا إِنيّشْ سِيذِي إِشْثْ ن ڒْوقْثْ ؤُمِي إِنَّا: ”ثِيوشَّا أَذْ يڭّْ سِيذِي مَانْ أَيَا ذِي ثمُّورْثْ.“
\v 6 ثِيوشَّا نّسْ إِڭَّا سِيذِي دّقّْ نِّي ؤُشَا مُّوثنْ مَارَّا ڒبْهَايمْ ن مِيصْرَا، مَاشَا زِي ڒبْهَايمْ ن أَيْثْ ن إِسْرَائِيل وَارْ ثمُّوثْ ؤُڒَا ذ إِشْثْ \add زَّايْسنْثْ\add*.
\v 7 ؤُشَا إِسّكّْ فِيرْعُونْ \add إِجّنْ\add*، ؤُشَا أَقَا ذَا، وَارْ ثمُّوثْ ؤُڒَا ذ إِشْثْ زِي ڒبْهَايمْ ن أَيْثْ ن إِسْرَائِيل. \add مَاشَا\add* ؤُڒْ ن فِيرْعُونْ إِذْوڒْ إِقْسحْ ؤُشَا وَارْ يجِّي أَذْ إِفّغْ ڒْڭنْسْ.
\b
\m 
\v 8 \add ڒخْذنِّي\add* إِنَّا سِيذِي إِ مُوسَا ذ هَارُونْ: ”عمَّارْ ؤُرُو \add ن إِفَاسّنْ\add* نْومْ س إِغّضْ زِي ثفْقُونْثْ ؤُشَا أجّْ مُوسَا أَذْ ث إِزُّوزَارْ ذڭْ ؤُجنَّا قِيبَاتْشْ إِ ثِيطَّاوِينْ ن فِيرْعُونْ.
\v 9 أَذْ إِذْوڒْ \add إِغّضْ\add* ذ ثَاعجَّاجْثْ إِفْسُوسنْ خْ مَارَّا ثَامُّورْثْ ن مِيصْرَا ؤُشَا \add ثَاعجَّاشْثْ\add* أَذْ ثذْوڒْ ذ ثِيحبَّا س ڒوْعِي خْ بْنَاذمْ ؤُ خْ ڒْمَاڒْ ذِي مَارَّا ثَامُّورْثْ ن مِيصْرَا.“
\v 10 ؤُشَا كْسِينْ إِغّضْ زِي ثفْقُونْثْ \add أَمْ\add* ثُوغَا بدّنْ زَّاثْ إِ فِيرْعُونْ ؤُشَا إِزُّوزَارْ إِ-ث مُوسَا ذڭْ ؤُجنَّا ؤُشَا إِذْوڒْ ذ \bd ثِيحبَّا س ڒوْعِي\bd* أَمْ ذڭْ إِوْذَانْ أَمْ ذِي ڒْمَاڒْ،
\v 11 \add أَڒَامِي\add* ثَارْوَا ن ثْسحَّارْثْ وَارْ زمَّارنْ أَذْ قِّيمنْ بدّنْ زَّاثْ إِ مُوسَا ذِي سِّيبّثْ ن ثْحبَّا، مِينْزِي \add ثِيحبَّا\add* حكْمنْثْ إِسحَّارنْ ذ مَارَّا إِمِيصْرِييّنْ.
\v 12 \add مَاشَا\add* سِيذِي إِسّقْسحْ ؤُڒْ ن فِيرْعُونْ، \add أَڒَامِي\add* وَارْ ذ أَسنْ إِسدْجْ شَا، أَمْ مَامّشْ ثُوغَا إِنَّا سِيذِي إِ مُوسَا.
\b
\m 
\v 13 \add ڒخْذنِّي\add* إِنَّا سِيذِي إِ مُوسَا: ”ثِيوشَّا كَّارْ زِيشْ، ثْبدّذْ زَّاثْ إِ وُوذمْ ن فِيرْعُونْ ؤُشَا إِنِي أَسْ: ’أَمُّو إِ إِقَّارْ سِيذِي، أَربِّي ن إِعِيبْرَانِييّنْ: أجّْ أَذْ إِرَاحْ ڒْڭنْسْ إِنُو، مَاحنْذْ أَذْ أَيِي إِعْبذْ.
\v 14 مِينْزِي ثْوَاڒَا-يَا نشّْ أَذْ شكْ ڒقْفغْ ذڭْ وُوڒْ س مَارَّا جّْرَايحْ إِنُو ؤُشَا ؤُڒَا ذ إِمْسخَّارنْ نّشْ ذ ڒْڭنْسْ نّشْ، حِيمَا أَذْ ثسّْنذْ بلِّي وَارْ إِدْجِي حذْ أَمْ نشّْ ذِي مَارَّا ثَامُّورْثْ.
\v 15 مِينْزِي \add عَاذْ\add* ڒخُّو ثُوغَا زمَّارغْ أَذْ سّْوِيژّْضغْ أَفُوسْ إِنُو، حِيمَا أَذْ شكْ وْثغْ ؤُڒَا ذ ڒْڭنْسْ نّشْ س طَّاعُونْ ؤُشَا ثُوغَا إِزمَّارْ أَذْ ثتّْوَاثحِّيذْ زِي ثمُّورْثْ.
\v 16 \add مَاشَا\add* س ثِيذتّْ نشّْ سّْبدّغْ شكْ حِيمَا أَذْ أَشْ سّشْنغْ جّهْذْ إِنُو ؤُ حِيمَا أَذْ إِتّْوَاشنّعْ إِسمْ إِنُو ذِي مَارَّا ثَامُّورْثْ. \x ◘ \xo 9:‏16 \xt رُوم. 9‏:‏17\x*
\v 17 مَا ثتّڭّذْ عَاذْ ثِيعِينْكْرِيفِينْ ضِيدّْ إِ ڒْڭنْسْ إِنُو، حِيمَا وَارْ ثنْ ثجِّيذْ أَذْ رَاحنْ؟
\v 18 خْزَارْ، ثِيوشَّا غَارْ ثْسَاعّثْ-أَ نشّْ أَذْ أَرّغْ \bd ثَابْرُورِّي إِدّقْڒنْ\bd* أَذْ ثوّثْ، \add ثَابْرُورِّي\add* إِ وَارْ ثُوغِيعمَّارْصْ ذِي مِيصْرَا زڭْ وَاسّْ إِ ذِي ثتّْوَابْنَا أَڒْ إِ ڒخُّو. \f ◼ \fr 9:‏18 \ft \bd ’غَارْ ثْسَاعّثْ-أَ‘\bd* - س ثْعِيبْرَانِيثْ ’غَارْ ڒْوقْثْ-أَ‘.\f*
\v 19 \add خنِّي\add* سكّْ ڒخُّو \add إِمْسخَّارنْ نّكْ\add*، مَاحنْذْ أَذْ سِّيذْفنْ ڒبْهَايمْ ذ مَارَّا مِينْ غَاركْ ذڭْ إِيَّارْ غَارْ ذَاخڒْ. كُوڒْ بْنَاذمْ نِيغْ ذ ڒْمَاڒْ نِّي إِ غَا إِتّْوَافنْ ذڭْ إِيَّارْ، وَارْ ث سِّيذْفنْ غَارْ \add ذَاخڒْ ن\add* ثَادَّارْثْ، أَذْ خَاسْ د-ثوْضَا ثبْرُورِّي ؤُشَا نِيثْنِي أَذْ مّْثنْ.‘ “
\v 20 ونِّي إِڭّْوذنْ أَوَاڒْ ن سِيذِي زڭْ إِمْسخَّارنْ ن فِيرْعُونْ، إِجَّا إِمْسخَّارنْ نْسنْ ذ ڒبْهَايمْ نْسنْ أَروْڒنْ غَارْ ذَاخڒْ ذِي ثُوذْرِينْ.
\v 21 \add مَاشَا\add* ونِّي وَارْ إِتِّيقّنْ أَوَاڒْ ن سِيذِي س وُوڒْ نّسْ، أَقَا إِجَّا إِمْسخَّارنْ نّسْ ذ ڒبْهَايمْ نّسْ ذڭْ إِيَّارْ.
\v 22 \add خنِّي\add* إِنَّا سِيذِي إِ مُوسَا: ”سْوِيژّضْ أَفُوسْ نّشْ غَارْ ؤُجنَّا ؤُشَا أَذْ ثِيڒِي ثبْرُورِّي خْ مَارَّا ثَامُّورْثْ ن مِيصْرَا، خْ إِوْذَانْ، خْ ڒْمَاڒْ ؤُ خْ مَارَّا أَفْسُو ذڭْ إِيَّارنْ ذِي ثمُّورْثْ ن مِيصْرَا.“
\v 23 \add خنِّي\add* إِسّْوِيژّضْ مُوسَا ثَاغَّارْشْثْ نّسْ غَارْ ؤُجنَّا ؤُشَا سِيذِي إِڭَّا أَجَّاجْ ذ ثبْرُورِّي ؤُشَا ثسّْوِيژّضْ ثْمسِّي غَارْ ثمُّورْثْ. \add أَمُّو\add* إِ إِڭَّا سِيذِي مَاحنْذْ أَذْ ثوّثْ ثبْرُورِّي خْ ثمُّورْثْ ن مِيصْرَا.
\v 24 ثُوغَا \add ذِينْ\add* ثَابْرُورِّي ذ ثْمسِّي إِخدْجْضنْ أَكْ-ذ ثبْرُورِّي. ثُوغَا ثجْهذْ أَطَّاسْ، وَارْ ت ثُوغِيعمَّارْصْ ذِي مَارَّا ثَامُّورْثْ ن مِيصْرَا زڭْ وَامِي ثُوغَا ثذْوڒْ ذ إِجّْ ن ڒْڭنْسْ. \x ◘ \xo 9:‏24 \xt حِز. 1‏:‏4\x*
\v 25 ؤُشَا ثوْثَا ثبْرُورِّي خْ مَارَّا ثَامُّورْثْ ن مِيصْرَا، خْ مَارَّا مِينْ ثُوغَا ذڭْ إِيَّارْ، خْ إِوْذَانْ ذ ڒْمَاڒْ. ثوْثَا ثبْرُورِّي \add عَاوذْ\add* خْ مَارَّا أَفْسُو ذڭْ إِيَّارْ ؤُشَا تّْوَارْژنْثْ مَارَّا ثْشجُّورَا ن ڒخْڒَا.
\v 26 مْغِيرْ ذِي ثَامُّورْثْ ن جُوشَانْ، مَانِي دْجَانْ أَيْثْ ن إِسْرَائِيل، وَارْ ثوْثِي ثبْرُورِّي.
\m 
\v 27 \add ڒخْذنِّي\add* إِسّكّْ فِيرْعُونْ أَذْ ڒَاغَانْ إِ مُوسَا ذ هَارُونْ ؤُشَا إِنَّا أَسنْ: ”نشّْ خْضِيغْ ثْوَاڒَا-يَا. سِيذِي، أَقَا-ث ذ أَمْسڭّذْ ؤُشَا نشّْ ذ ڒْڭنْسْ إِنُو ذ إِعفَّاننْ!
\v 28 ژَتدْجمْ س ڒَادْجَاغْ إِ سِيذِي، مِينْزِي شْفَا، أَقَا أَجَّاجنْ ن أَربِّي ذ أَطَّاسْ ؤُڒَا ذ ثَابْرُورِّي. نشّْ أَذْ كنِّيوْ جّغْ أَذْ ثْرَاحمْ، وَارْ كنِّيوْ تّطّْفغْ شَا عَاذْ \add ذَانِيثَا\add*.“
\v 29 \add خنِّي\add* إِنَّا أَسْ مُوسَا: ”مڒْمِي غَا فّْغغْ زِي ثنْذِينْثْ أَذْ سّْوِيژّْضغْ إِفَاسّنْ إِنُو غَارْ سِيذِي ؤُشَا أَذْ بدّنْ وَاجَّاجنْ، وَارْ ثتِّيڒِي عَاذْ ثبْرُورِّي، مَاحنْذْ أَذْ ثسّْنذْ بلِّي ثَامُّورْثْ أَقَا-ت ن سِيذِي.
\v 30 \add مَاشَا\add* خَاكْ ذ خْ إِمْسخَّارنْ نّشْ، أَقَا سّْنغْ \add مَازَالْ\add* وَارْ ثڭّْوذمْ شَا زِي سِيذِي أَربِّي.“
\m 
\v 31 ثِيفّسْثْ ذ إِمنْذِي ثُوغَا تّْوَاڒقْفنْ، مِينْزِي إِمنْذِي ثُوغَا-ث س ثِيذْرِينْ ذ ثِيفّسْثْ ثْنوَّارْ.
\v 32 \add مَاشَا\add* إِرْذنْ ذ كَارْصَانَا وَارْ تّْوَاڒقْفنْ شَا، مِينْزِي ثُوغَا أَثنْ وَارْ د-فِّيغنْ \add عَاذْ\add*. \f ◼ \fr 9:‏32 \ft \bd ’كَارْصَانَا‘\bd* - نِيغْ ’دُّوخْنْ‘ نِيغْ ’جَاوَارْسْ‘.\f*
\v 33 \add خنِّي\add* يُويُورْ مُوسَا زِي فِيرْعُونْ، إِفّغْ زِي ثنْذِينْثْ ؤُشَا إِكْسِي إِفَاسّنْ نّسْ غَارْ سِيذِي. \add ڒخْذنِّي\add* بدّنْ وَاجَّاجنْ ذ ثبْرُورِّي ؤُڒَا ذ إِبُوذَا ن ونْژَارْ خْ ثمُّورْثْ.
\v 34 \add ؤُمِي\add* إِژْرَا فِيرْعُونْ بلِّي أَنْژَارْ ذ ثبْرُورِّي ذ وَاجَّاجنْ بدّنْ، إِخْضَا عَاذْ كْثَارْ ؤُشَا إِسّقْسحْ ؤُڒْ نّسْ، نتَّا ذ إِمْسخَّارنْ نّسْ.
\v 35 ؤُڒْ ن فِيرْعُونْ يَارْنِي ذِي ڒقْسَاحثْ، وَارْ إِجِّي أَذْ إِرَاحْ أَيْثْ ن إِسْرَائِيل، أَمْ مَامّشْ ثُوغَا إِنَّا سِيذِي س ثْسخَّارْثْ ن مُوسَا. \x ◘ \xo 9:‏35 \xt ؤُف. 4‏:‏21؛ 7‏:‏3\x*
\b
\b
\c 10
\m 
\v 1 \add خنِّي\add* إِنَّا سِيذِي إِ مُوسَا: ”أَذفْ غَارْ فِيرْعُونْ، مِينْزِي نشّْ سّْقسْحغْ ؤُڒْ نّسْ ذ وُوڒْ ن إِمْسخَّارنْ نّسْ، حِيمَا أَذْ سّشْنغْ ڒعْڒَامَاثْ \add إِنُو\add* ذِي ڒْوسْطْ \add ن ثمُّورْثْ\add* نّسْ، \x ◘ \xo 10:‏1 \xt ؤُف. 4‏:‏21؛ 9‏:‏34\x*
\v 2 ؤُ حِيمَا أَذْ ثْعَاوْذذْ ذڭْ إِمزُّوغنْ ن مِّيشْ ذ مِّيسْ ن مِّيشْ مِينْ ڭِّيغْ أَكْ-ذ مِيصْرَا، ؤُ \add أَذْ ثْعَاوْذذْ خْ\add* ڒعْڒَامَاثْ إِ ڭِّيغْ جَارْ أَسنْ، \add مَاحنْذْ\add* أَذْ ثسّْنمْ بلِّي نشّْ ذ سِيذِي.“
\v 3 \add ڒخْذنِّي\add* يُوذفْ مُوسَا ذ هَارُونْ غَارْ فِيرْعُونْ، نَّانْ أَسْ: ”سِيذِي، أَربِّي ن إِعِيبْرَانِييّنْ إِنَّا: ’مشْحَاڒْ غَا ثكّذْ ثُوڭِيذْ أَذْ ثهْوِيذْ غَارْ وُوذمْ إِنُو؟ أجّْ أَذْ إِرَاحْ ڒْڭنْسْ إِنُو حِيمَا أَذْ أَيِي إِعْبذْ.
\v 4 مِينْزِي مَاڒَا ثُوڭِيذْ أَذْ ثجّذْ أَذْ إِرَاحْ ڒْڭنْسْ إِنُو، أَقَا أَذْ سِّيوْضغْ ثِيوشَّا \bd ثْمُورْغِي\bd* خْ ثمُّورْثْ نّشْ.
\v 5 أَذْ ذْڒنْ ؤُذمْ ن ثمُّورْثْ أَڒْ وَارْ إِزمَّارْ حذْ أَذْ إِثْوَاڒَا ثَامُّورْثْ \add عَاذْ\add* ؤُشَا أَذْ شّنْ مِينْ إِقِّيمنْ إِ إِتّْوَانجْمنْ، مِينْ ذ أَومْ إِقِّيمنْ عَاذْ أَوَارْنِي إِ ثبْرُورِّي. أَذْ ثشّْ \add ثْمُوغْرِي\add* \add عَاوذْ\add* مَارَّا ثِيشجُّورَا إِ ذ أَومْ د-إِغمّْينْ ذڭْ إِيَّارْ.
\v 6 ؤُشَا أَذْ شُّورنْثْ ثُوذْرِينْ نّشْ ذ ثُوذْرِينْ ن إِمْسخَّارنْ نّشْ ذ ثُوذْرِينْ ن مَارَّا إِمِيصْرِييّنْ. أَمُّو وَارْ ت ژْرِينْعمَّارْصْ إِبَابَاثنْ نّشْ ذ ڒجْذُوذْ ن إِبَابَاثنْ نّشْ زڭْ وَامِي ثنْ ثُوغَا خْ ثمُّورْثْ غَارْ وَاسّْ-أَ.‘ “ ؤُشَا إِذْوڒْ-د نتَّا، إِسْمحْ ذِي فِيرْعُونْ.
\v 7 نَّانْ أَسْ إِمْسخَّارنْ ن فِيرْعُونْ: ”أَڒْ مڒْمِي إِ ذ أَنغْ غَا يِيڒِي وَانِيثَا ذ ڒْفخْ؟ أجّْ أَذْ رَاحنْ إِرْيَازنْ نِّي، مَاحنْذْ أَذْعبْذنْ سِيذِي أَربِّي نْسنْ! مَا وَارْ ثسِّينذْ عَاذْ بلِّي مِيصْرَا أَقَا ثتّْوَاخَارّبْ؟“
\v 8 \add ڒخْذنِّي\add* سِّيوْضنْ \add إِمْسخَّارنْ ن فِيرْعُونْ\add* مُوسَا ذ هَارُونْ عَاوذْ غَارْ فِيرْعُونْ. نتَّا إِنَّا أَسنْ: ”رُوحمْ،عبْذمْ سِيذِي، أَربِّي نْومْ! \add إِنِي أَيِي\add*، مِينْ عْنَانْ إِنِّي إِخْسنْ أَذْ رَاحنْ؟“
\v 9 إِنَّا مُوسَا: ”أَذْ نْرَاحْ \add أَكْ-ذ\add* إِحْرَامنْ نّغْ ذ إِوسُّورَا نّغْ، س إِحنْجِيرنْ نّغْ ذ ثْحنْجِيرِينْ نّغْ، س وُودْجِي نّغْ ذ إِفُونَاسنْ ذ ثْفُونَاسِينْ نّغْ، مِينْزِي غَارْنغْ إِجّْ ن ڒْعِيذْ إِ سِيذِي.“
\v 10 \add خنِّي\add* يَارَّا-د خَاسنْ: ”\add خنِّي\add* إِتّْخصَّا أَذْ يِيڒِي سِيذِي \add أَطَّاصْ\add* أَكِيذْومْ مَاڒَا أَذْ جّغْ أَذْ ثْرَاحمْ كنِّيوْ ذ إِحنْجِيرنْ إِمژْيَاننْ نْومْ. خْزَارمْ، أَقَا كنِّيوْ ثنْوِيمْ ڒْغَارْ!
\v 11 وَارْ إِتِّيڒِي أَمنِّي. جّمْ أَذْعبْذنْ إِرْيَازنْ إِجهْذنْ إِ سِيذِي، مِينْزِي ذ مَانْ أَيَا إِ ثتّخْسمْ.“ ؤُشَا ؤُژّْڒنْ خَاسنْ زِي قِيبَاتْشْ ن وُوذمْ ن فِيرْعُونْ.
\m 
\v 12 \add خنِّي\add* إِنَّا سِيذِي إِ مُوسَا: ”سْوِيژّضْ أَفُوسْ نّشْ خْ ثمُّورْثْ ن مِيصْرَا، حِيمَا ثَامُورْغِي أَذْ ثْڭعّذْ خْ ثمُّورْثْ ن مِيصْرَا، مَاحنْذْ أَذْ ثشّْ مَارَّا أَفْسُو \add أَزِيزَا\add* ن ثمُّورْثْ، مَارَّا مِينْ إِشطّنْ خْ ثبْرُورِّي.“
\m 
\v 13 إِسّْوِيژّضْ مُوسَا غَارْ ثغَّارْشْثْ نّسْ خْ ثمُّورْثْ ن مِيصْرَا ؤُشَا إِڭَّا سِيذِي أَذْ د-إِسُوضْ إِجّْ ن ؤُسمِّيضْ إِ د-يُوسِينْ زِي شَّارْقْ خْ ثمُّورْثْ وَارْ إِقطِّينْ مَارَّا أَسّْ نِّي ذ مَارَّا دْجِيڒثْ نِّي. غَارْ صّْبحْ يِيوِي-د ؤُسمِّيضْ ثَامُورْغِي. \x ◘ \xo 10:‏13 \xt إِزهد. 78‏:‏46؛ 105‏:‏34، 35\x*
\v 14 ثْڭعّذْ-د \bd ثْمُورْغِي\bd* خْ مَارَّا ثَامُّورْثْ ن مِيصْرَا، ثْصيّحْ خْ مَارَّا جّْوَايهْ ن مِيصْرَا. أَقَا ثُوغَا ڒْحَاڒْ يوْعَارْ أَطَّاسْ. ثَامُورْغِي أَمْ ثَانِيثَا وَارْ ت ثُوغِي قْبڒْ ؤُشَا وَارْ ثتِّيڒِيعمَّارْصْ زِي سَّا غَارْ زَّاثْ.
\v 15 أَقَا ذْڒِينْثْ ؤُذمْ ن مَارَّا ثَامُّورْثْ أَڒَامِي ثسُّوثمْ ثمُّورْثْ. نِيثنْثِي شِّينْثْ مَارَّا أَفْسُو ن ثمُّورْثْ ذ مَارَّا ڒْغِيدْجثْ ن ثْشجُّورَا إِ ثُوغَا إِقِّيمنْ زِي ثبْرُورِّي. ذِي مَارَّا ثَامُّورْثْ ن مِيصْرَا وَارْ إِقِّيمْ وَالُو زِي مَارَّا ثُوزِّيزوْثْ ذِي ثْشجُّورَا نِيغْ ذڭْ وفْسُو ن إِيَّارْ.
\v 16 \add ڒخْذنِّي\add* إِڒَاغَا فِيرْعُونْ ذغْيَا إِ مُوسَا ذ هَارُونْ، إِنَّا: ”أَقَا خْضِيغْ أَكْ-ذ سِيذِي، أَربِّي نْومْ، ؤُڒَا أَكِيذْومْ.
\v 17 تّْزَاوْڭغْ ڒخُّو أَذْ أَيِي ثْسَامْحمْ خْ ؤُخطُّو إِنُو ثْوَاڒَا-يَا. ژَتدْجمْ س ڒَادْجَاغْ إِ سِيذِي، أَربِّي نْومْ، حِيمَا أَذْ خَافِي إِكّسْ ڒْموْثْ-أَ وَاهَا.“
\v 18 ؤُشَا إِفّغْ خْ فِيرْعُونْ ؤُشَا إِژُّودْجْ س ڒَادْجَاغْ غَارْ سِيذِي.
\v 19 \add خنِّي\add* إِجَّا سِيذِي أَذْ د-إِعْقبْ ؤُسمِّيضْ إِ د-يُوسِينْ زِي شَّارْقْ غَارْ ڒْغَارْبْ، \add إِسّْجهْذْ إِ-ث\add* أَطَّاسْ، ؤُشَا إِكّسْ \add ؤُسمِّيضْ\add* ثَامُورْغِي، إِنْضَارْ إِ-ت ذِي ڒبْحَارْ ن ثلْڭَا. وَارْ ثقِّيمْ ؤُڒَا ذ إِشْثْ ن ثْمُورْغِي ذِي مَارَّا جّْوَايهْ ن مِيصْرَا. \f ◼ \fr 10:‏19 \ft \bd ’إِنْضَارْ إِتّْ‘\bd* - س ثْعِيبْرَانِيثْ ’إِوّثْ إِ-ت‘. \bd ’ڒبْحَارْ ن ثلْڭَا‘\bd* - نِيغْ ’ڒبْحَارْ ن ثڒْڭَا‘.\f*
\v 20 \add مَاشَا\add* إِسّقْسحْ سِيذِي ؤُڒْ ن فِيرْعُونْ \add ؤُمِي\add* وَارْ إِجِّي أَيْثْ ن إِسْرَائِيل أَذْ رَاحنْ.
\b
\m 
\v 21 \add خنِّي\add* إِنَّا سِيذِي إِ مُوسَا: ”سْوِيژّضْ أَفُوسْ نّشْ غَارْ ؤُجنَّا، \add خنِّي\add* أَذْ ثِيڒِي \bd ثَادْجسْثْ\bd* خْ ثمُّورْثْ ن مِيصْرَا أَڒْ غَا ثَافذْ ثْزمَّارذْ أَذْ ثْحَاذِيذْ ثَادْجسْثْ.“
\v 22 إِسّْوِيژّضْ مُوسَا أَفُوسْ نّسْ غَارْ ؤُجنَّا ؤُشَا ثهْوَا-د \bd ثَادْجسْثْ ثجْهذْ خْ مَارَّا ثَامُّورْثْ ن مِيصْرَا، ثْڒَاثَا ن وُوسَّانْ\bd*. \f ◼ \fr 10:‏22 \ft \bd ’ثْڒَاثَا ن وُوسَّانْ‘\bd* - نِيغْ ’ثڒْثْيَامْ‘.\f*  \x ◘ \xo 10:‏22 \xt ڒقض. 16‏:‏27؛ إِزهد. 105‏:‏27، 28؛ إِزهد. 115‏:‏7\x*
\v 23 ؤُڒَا ذ إِجّْ وَارْ إِثْوِيڒِي ونّغْنِي. ؤُڒَا ذ إِجّْ وَارْ إِكَّارْ زڭْ ومْشَانْ نّسْ ثْڒَاثَا ن وُوسَّانْ. \add مَاشَا\add* مَارَّا أَيْثْ ن إِسْرَائِيل ثُوغَا غَارْسنْ ثَافَاوْثْ ذڭْ إِمُوشَانْ مَانِي ثُوغَا زدّْغنْ.
\v 24 \add ڒخْذنِّي\add* إِڒَاغَا فِيرْعُونْ إِ مُوسَا، إِنَّا: ”رُوحمْ، ثْعبْذمْ سِيذِي! جّمْ وَاهَا أَذْ إِقِّيمْ وُودْجِي نْومْ ذ إِفُونَاسنْ ذ ثْفُونَاسِينْ نْومْ. \add مَاشَا\add* ثْزمَّارمْ أَذْ د-ثَاوْيمْ إِحنْجِيرنْ إِمژْيَاننْ أَكِيذْومْ.“
\v 25 يَارَّا-د \add خَاسْ\add* مُوسَا: ”إِتّْخصَّا شكْ عَاوذْ أَذْ أَنغْ ثوْشذْ ذڭْ ؤُفُوسْ ثِيغَارْصَا ؤُڒَا ذ ثِيغَارْصَا ن وشْمَاضْ. أَذْ ثنْثْ نسّوْجذْ \add ذ ثْغَارْصْطْ\add* إِ سِيذِي، أَربِّي نّغْ.
\v 26 ؤُڒَا ذ ڒبْهَايمْ نّغْ إِتّْخصَّا أَذْ كِيذْنغْ رَاحنْثْ، وَارْ إِتّْغِيمِي ؤُڒَا ذ إِجّْ ن ؤُشكْرُوذْ، مِينْزِي زَّايْسنْثْ إِ غَا نكْسِي، حِيمَا أَذْ نعْبذْ سِيذِي، أَربِّي نّغْ، مِينْزِي وَارْ نسِّينْ س مِينْزِي غَا نعْبذْ سِيذِي، أَربِّي نّغْ، أَڒْ ذِينْ غَا نَاوضْ.“
\v 27 \add مَاشَا\add* سِيذِي إِسّقْسحْ ؤُڒْ ن فِيرْعُونْ ؤُشَا يُوڭِي أَذْ ثنْ يجّْ أَذْ رَاحنْ.
\v 28 إِنَّا أَسْ فِيرْعُونْ: ”أَڭّْوجْ خَافِي! حْضَا، حِيمَا وَارْ ثْژَارّذْ \add عَاذْ\add* ؤُذمْ إِنُو، مِينْزِي أَسّْ إِ ذِي غَا ثْژَارذْ ؤُذمْ إِنُو، أَذْ ثمّْثذْ!“
\v 29 إِنَّا مُوسَا: ”\add أَذْ يِيڒِي\add* أَمْ مَامّشْ إِ ثنِّيذْ: وَارْ ژَترّغْ عَاذْ ؤُذمْ نّشْ!“ \x ◘ \xo 10:‏29 \xt عبر. 11‏:‏27\x*
\b
\b
\c 11
\s1 أَبَارّحْ س جّْرِيحشْثْ وِيسّْعشْرَا
\m 
\v 1 إِنَّا سِيذِي إِ مُوسَا: ”أَذْ ڒقْفغْ عَاذْ \add مْغِيرْ\add* س يِيشْثنْ جّْرِيحشْثْ خْ فِيرْعُونْ ذ مِيصْرَا. أَوَارْنِي ثَا أَذْ كنِّيوْ إِسّكّْ سَّا. غَارْ ؤُنڭَّارْ خْمِي كنِّيوْ غَا يجّْ أَذْ ثْرُوحمْ مَارَّا، أَذْ خَاومْ يَاژّڒْ سَّا س ثِيذتّْ.
\v 2 سِيوڒْ خنِّي ذڭْ إِمزُّوغنْ ن ڒْڭنْسْ مَاحنْذْ أَذْ إِتَّارْ كُوڒْ أَرْيَازْ زڭْ وَاجَّارْ نّسْ ؤُ كُوڒْ ثَامْغَارْثْ زِي ثَاجَّارْثْ نّسْ ڒقْشُوعْ ن نُّوقَارْثْ ذ وُورغْ.“ \x ◘ \xo 11:‏2 \xt ؤُف. 3‏:‏22؛ 12‏:‏35\x*
\v 3 سِيذِي إِوْشَا أَسْ إِ ڒْڭنْسْ أَرْضَا ذِي ثِيطَّاوِينْ ن إِمِيصْرِييّنْ. عَاوذْ ثُوغَا مُوسَا ذ إِجّْ ورْيَازْ س شَّانْ أَمقّْرَانْ ذِي ثمُّورْثْ ن مِيصْرَا ذِي ثِيطَّاوِينْ ن ڒْڭنْسْ ؤُ ذِي ثِيطَّاوِينْ ن إِمْسخَّارنْ ن فِيرْعُونْ. \x ◘ \xo 11:‏3 \xt ؤُف. 12‏:‏36\x*
\v 4 إِنَّا مُوسَا: ”أَمُّو إِ إِنَّا سِيذِي: ’غَارْ وزْينْ ن دْجِيڒثْ نشّْ أَذْ عْذُوغْ ذِي ڒْوسْطْ ن مِيصْرَا \x ◘ \xo 11:‏4 \xt ؤُف. 12‏:‏29\x*
\v 5 ؤُشَا \bd أَذْ إِمّثْ كُوڒْ أَمنْزُو ذِي ثمُّورْثْ ن مِيصْرَا\bd*، زڭْ ؤُمنْزُو ن فِيرْعُونْ، ونِّي إِقِّيمنْ خْ ڒْعَارْشْ ن ثْڭلْذِيثْ، أَڒْ أَمنْزُو ن ثَايَّا، ثنِّي إِقِّيمنْ أَوَارْنِي إِ ثْسِيرْثْ \add ثْحَارِّي إِمنْذِي\add*، ؤُڒَا ذ كُوڒْ أَمنْزُو زِي ڒبْهَايمْ. \x ◘ \xo 11:‏5 \xt ؤُف. 12‏:‏12\x*
\v 6 أَذْ ذِينْ ثِيڒِي إِشْثْ ن ثْغُويِّيثْ ذ ثَامقّْرَانْثْ خْ مَارَّا ثَامُّورْثْ ن مِيصْرَا إِ وَارْ ثُوغِيعمَّارْصْ نِيغْعمَّارْصْ عَاذْ أَذْ ثِيڒِي.
\v 7 \add مَاشَا\add* غَارْ مَارَّا أَيْثْ ن إِسْرَائِيل، وَارْ إِتّْژُو ؤُڒَا ذ إِجّْ ن وقْزِينْ خْ إِوْذَانْ ؤُڒَا خْ ڒْمَاڒْ، مَاحنْذْ أَذْ ثسّْنمْ، بلِّي سِيذِي إِتّڭّْ ڒْفَارْزْ جَارْ إِمِيصْرِييّنْ ذ إِسْرَائِيل.‘
\v 8 \add خنِّي\add* أَذْ غَارِي د-هْوَانْ مَارَّا إِمْسخَّارنْ نّشْ، أَذْ أَيِي بنْذْقنْ، أَذْ إِنِينْ: ’فّغْ شكْ ذ مَارَّا ڒْڭنْسْ إِ شكْ إِضفَّارنْ ذڭْ إِصُورَافْ نّشْ!‘ أَوَارْنِي مَانْ أَيَا نشّْ أَذْ فّْغغْ.‘ “ ؤُشَا إِفّغْ خْ فِيرْعُونْ، ثكَّارْ ذَايسْ ثْمسِّي س ؤُخيّقْ. \x ◘ \xo 11:‏8 \xt ؤُف. 12‏:‏30\x*
\m 
\v 9 \add أَقَا\add* إِنَّا سِيذِي إِ مُوسَا: ”فِيرْعُونْ وَارْ ذ أَومْ إِتّسْڒِي شَا، حِيمَا أَذْ مْغَارنْثْ ڒعْڒَامَاثْ إِنُو ذِي ثمُّورْثْ ن مِيصْرَا.“
\v 10 أَقَا مُوسَا ذ هَارُونْ ڭِّينْ مَارَّا ڒعْڒَامَاثْ-أَ زَّاثْ إِ وُوذمْ ن فِيرْعُونْ، مَاشَا سِيذِي ثُوغَا إِسّقْسحْ ؤُڒْ ن فِيرْعُونْ أَڒَامِي وَارْ إِجِّي أَذْ فّْغنْ أَيْثْ ن إِسْرَائِيل زِي ثمُّورْثْ نّسْ. \x ◘ \xo 11:‏10 \xt ؤُف. 9‏:‏16؛ رُوم. 9‏:‏17\x*
\b
\b
\c 12
\s1 أَڒقّمْ ن ثْغَارْصْثْ ن ؤُسعْذُو نِيغْ ’بَاسْخَا‘
\m 
\v 1 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا ذ هَارُونْ ذِي ثمُّورْثْ ن مِيصْرَا، إِنَّا:
\m 
\v 2 ”أَيُورْ-أَ أَذْ أَومْ يِيڒِي ذ أَزدْجِيفْ ن إِيُورنْ. أَذْ أَومْ يِيڒِي وَا إِ كنِّيوْ ذ أَمزْوَارُو ن إِيُورنْ ن ؤُسڭّْوَاسْ.
\v 3 سِيوڒْ غَارْ مَارَّا ثَامسْمُونْثْ ن إِسْرَائِيل، إِنِي: ’ذڭْ وَاسّْ وِيسّْعشْرَا أَذْ إِكْسِي كُوڒْ إِجّْ إِ يِيخفْ نّسْ إِجّْ ن يزْمَارْ خْ \add مَارَّا\add* \add ڒَْادْجْ ن\add* ثَادَّارْثْ \add إِ د-إِقَّارْصنْ زڭْ\add* إِبَابَاثنْ، \add إِجّْ ن\add* يزْمَارْ خْ \add إِشْثْ ن\add* ثَادَّارْثْ. \f ◼ \fr 12:‏3 \ft \bd ’ثَامسْمُونْثْ‘\bd* - نِيغْ ’جْمَاعْثْ‘. \bd ’إِزْمَارْ‘\bd* - نِيغْ ’إِغِيضْ‘. \bd ’\bdit ڒَْادْجْ ن\bdit* ثَادَّارْثْ‘\bd* - أَقَا ذِينْ نِيشَانْ ذِي ثِيرَا ‘ثَادَّارْثْ ن إِبَابَاثنْ‘، أَقَا-ث ذ إِجّْ ن وَاوَاڒْ أَعِيبْرَانِي نِّي إِخْسْ أَذْ يِينِي ’ڒَْادْجْ إِ إِدْجَانْ غَارْ ونِّي إِدْجَانْ ذ بَابَاثْسنْ‘.\f*
\v 4 \add مَاشَا\add* مَاڒَا \add رَادْجْ ن\add* ثَادَّارْثْ ثُوغَا إِمْژِي إِ يزْمَارْ، \add خنِّي\add* إِتّْخصَّا أَذْ إِكْسِي أَكْ-ذ وَاجَّارْ نّسْ يُوذْسنْ غَارْ ثَادَّارْثْ نّسْ عْلَاحْسَابْ \add ڒْْقدّْ ن\add* إِوْذَانْ. زِي جِّيهثْ ن يزْمَارْ أَذْ ثوْثمْ ڒحْسَابْ إِ مِينْ غَا يشّْ كُوڒْ إِجّنْ.
\v 5 أَذْ يِيڒِي ذ إِزْمَارْ إِشْنَانْ قَاعْ، أَوْثمْ ن إِجّْ ن ؤُسڭّْوَاسْ. أَذْ \add ث\add* ثكْسِيمْ زڭْ إِحُوڒِييّنْ نِيغْ زڭْ إِغَايْضنْ. \x ◘ \xo 12:‏5 \xt لَاوِي 1‏:‏3؛ 22‏:‏21؛ مـَال. 1‏:‏8؛ 1 بُط. 1‏:‏19\x*
\v 6 أَذْ ث ثْخمّْڒمْ أَڒْ أَسّْ أَرْبعْطَاشْ زڭْ ؤُيُورْ-أَ ؤُشَا أَذْ أَسْ إِغَارْصْ مَارَّا أَڭْرَاوْ ن ثْمسْمُونْثْ ن إِسْرَائِيل جَارْ بدُّو ن وزْينْ ن وَاسّْ أَڒْ د-ثوْضَا ثْمذِّيثْ.
\v 7 أَذْ كْسِينْ شَا زڭْ إِذَامّنْ ؤُشَا أَذْ ث ڭّنْ خْ ثْنَاينْ ن ڒضْرُوفْ \add إِ إِدْجَانْ غَارْ ؤُغزْذِيسْ ن ثوَّارْثْ\add* ؤُ خْ ثْنبْذَاثْ سنّجْ \add إِ ثوَّارْثْ\add* ن ثُوذْرِينْ مَانِي ث غَا شّنْ.
\v 8 أَذْ شّنْ أَيْسُومْ ذِي دْجِيڒثْ نِّي، \add أَيْسُومْ\add* إِشنّْفنْ غَارْ ثْمسِّي أَكْ-ذ وغْرُومْ بْڒَا أَنْثُونْ. أَذْ ث شّنْ س ڒبْزَارْ \add يَارْزڭْ\add*. \x ◘ \xo 12:‏8 \xt ڒخْڒ. 9‏:‏11؛ 1 كُور. 5‏:‏8\x*
\v 9 وَارْ ث تّتّمْ شَا ذ أَزِيزَا نِيغْ ينْوَانْ ذڭْ وَامَانْ، مَاشَا مْغِيرْ مَاڒَا إِتّْوَاشنّفْ ذِي ثْمسِّي، أَكْ-ذ ؤُزدْجِيفْ نّسْ ذ إِضَارنْ نّسْ ذ وَاذَانْ نّسْ.
\v 10 وَارْ زَّايسْ تّجِّيمْ وَالُو غَارْ صّْبحْ، مَاشَا مِينْ زَّايسْ غَا إِقِّيمنْ غَارْ صّْبحْ، إِتّْخصَّا كنِّيوْ أَذْ ث ثْشمْضمْ ذِي ثْمسِّي.
\v 11 أَمُّو إِ ذ أَومْ إِتّْخصَّا أَذْ ث ثشّمْ: ثَاجْعِينَّا نْومْ أَذْ ثِيڒِي ثبْيسْ، سَانْذَالِييَاثْ نْومْ ذڭْ إِضَارنْ نْومْ ؤُ ثَاغَّارْشْثْ نْومْ ذڭْ ؤُفُوسْ نْومْ ؤُشَا أَذْ ث ثشّمْ ذغْيَا. أَقَا-ث ذ \bd \bdit ثَاغَارْصْثْ ن\bdit* ؤُسعْذُو ن سِيذِي\bd*.
\v 12 \add مِينْزِي\add* ذِي دْجِيڒثْ-أَ، نشّْ أَذْ عْذُوغْ خْ ثمُّورْثْ ن مِيصْرَا ؤُشَا أَذْ وْثغْ كُوڒْ أَمنْزُو ذِي ثمُّورْثْ ن مِيصْرَا، أَمُّو ذڭْ إِوْذَانْ ؤُڒَا ذِي ڒْمَاڒْ، ؤُشَا أَذْ سِّيوْضغْ ڒحْكَامَاثْ إِنُو خْ مَارَّا إِربِّيثنْ ن مِيصْرَا، نشّْ ذ سِيذِي!
\v 13 ؤُشَا إِذَامّنْ أَذْ أَومْ إِڒِينْ ذ إِشْثْ ن ڒعْڒَامثْ خْ ثُوذْرِينْ مَانِي \add ثْزدّْغمْ\add* كنِّيوْ. \add مَاڒَا\add* ژْرِيغْ إِذَامّنْ، \bd أَذْ خَاومْ عْذُوغْ\bd*. وَارْ ثتِّيڒِي جّْرِيحشْثْ إِنقّنْ جَارْ أَومْ، خْمِي غَا وْثغْ ثَامُّورْثْ ن مِيصْرَا.
\v 14 أَسّْ-أَ أَذْ أَومْ يِيڒِي ذ إِجّْ ن وَاسّْ إِ ڒِيذَارثْ ؤُشَا أَذْ زَّايسْ ثْعيّْذمْ إِ سِيذِي. أَقَا-ت ذ إِشْثْ ن ثوْصيّثْ إِ ڒبْذَا إِ \add مَارَّا\add* جِّيڒَاثْ نْومْ، حِيمَا أَذْ زَّايسْ ثْعيّْذمْ. \x ◘ \xo 12:‏14 \xt ؤُف. 5‏:‏1\x*
\v 15 سبْعَا ن وُوسَّانْ أَذْ ثشّمْ أَغْرُومْ بْڒَا أَنْثُونْ. نِيشَانْ ذڭْ وَاسّْ أَمزْوَارُو أَذْ ثسُّوفّْغمْ أَنْثُونْ زِي ثُوذْرِينْ نْومْ، مِينْزِي مَانْ ونْ إِ غَا إِشّنْ شَا س ونْثُونْ، زڭْ وَاسّْ أَمزْوَارُو أَڒْ أَسّْ وِيسّْ سبْعَا، بْنَاذمْ نِّي أَذْ إِتّْوَاقسّْ زِي إِسْرَائِيل. \f ◼ \fr 12:‏15 \ft \bd ’بْنَاذمْ‘\bd* - ذِي ثِيرَا ثْعِيبْرَانِيثْ نِيشَانْ ’ڒعْمَارْ‘.\f*
\v 16 ذڭْ وَاسّْ أَمزْوَارُو أَذْ يِيڒِي إِجّْ ن ؤُمُونِي إِقدّْسنْ ؤُشَا \add عَاوذْ\add* ذڭْ وَاسّْ وِيسّْ سبْعَا أَذْ ذِينْ يِيڒِي إِجّْ ن ؤُمُونِي إِقدّْسنْ. ؤُڒَا ذ إِشْثْ ن ڒْخذْمثْ وَارْ ثتّْوَاڭّْ شَا ذڭْ \add وُوسَّانْ\add* نِّي. مْغِيرْ مِينْ غَا يشّْ كُوڒْ إِجّْ، ذ مَانْ أَيَا وَاهَا إِعدّڒْ أَذْ زَّايْومْ إِتّْوَاسّوْجذْ.
\v 17 أَذْ ثحْضَامْ \add ڒْْعِيذْ ن\add* وغْرُومْ بْڒَا أَنْثُونْ، مِينْزِي ذڭْ وَاسّْ نِّي أَقَا سُّوفّْغغْ-د كنِّيوْ زِي ثمُّورْثْ ن مِيصْرَا. أَذْ ثحْضَامْ أَسّْ-أَ ذِي \add مَارَّا\add* جِّيڒَاثْ نْومْ، أَقَا-ت ذ إِشْثْ ن ثوْصيّثْ إِ ڒبْذَا.
\v 18 ذڭْ \add ؤُيُورْ\add* أَمزْوَارُو، ذڭْ وَاسّْ وِيسّْ أَرْبعْطَاشْ ن ؤُيُورْ، ذِي دْجِيڒثْ، أَذْ ثشّمْ أَغْرُومْ بْڒَا أَنْثُونْ أَڒْ دْجِيڒثْ ن وَاسّْ وَاحِيثْ ؤُ-عِيشْرِينْ زڭْ ؤُيُورْ. \x ◘ \xo 12:‏18 \xt لَاوِي 23‏:‏5؛ ڒخْڒ. 28‏:‏16\x*
\v 19 سبْعَا ن وُوسَّانْ وَارْ إِتّْوِيفِّي ونْثُونْ ذِي ثُوذْرِينْ نْومْ، مِينْزِي مَانْ ونْ إِ غَا إِشّنْ زِي مِينْ إِدْجَانْ س ونْثُونْ، مَا ذ أَبَارَّانِي نِيغْ ذ مِّيسْ ن ثمُّورْثْ، بْنَاذمْ نِّي أَذْ إِتّْوَاقسّْ زِي ثْمسْمُونْثْ ن إِسْرَائِيل.
\v 20 وَارْ تّتّمْ وَالُو زِي مِينْ إِدْجَانْ س ونْثُونْ. ذِي مَارَّا ثِيزدَّاغْ نْومْ أَذْ ثشّمْ أَغْرُومْ بْڒَا أَنْثُونْ.‘ “ \x ◘ \xo 12:‏20 \xt أَعَوذ. 16‏:‏3\x*
\m 
\v 21 إِڒَاغَا مُوسَا إِ مَارَّا إِمْغَارنْ ن إِسْرَائِيل، إِنَّا أَسنْ: ”طّْفمْ، كْسِيمْ \add إِجّنْ زڭْ\add* وُودْجِي إِ يِيخفْ نْومْ، إِ ڒَادْجَاثْ نْومْ ؤُ غَارْصمْ ث إِ \add ثْغَارْصْثْ ن\add* ؤُسعْذُو. \x ◘ \xo 12:‏21 \xt عبر. 11‏:‏28\x*
\v 22 طّْفمْ إِشْثْ ن ثْقبِّيضْثْ ن ثْعلْدْجثْ، سْغضْسمْ \add ت\add* ذڭْ إِذَامّنْ نِّي إِدْجَانْ ذِي طّبْصِي،غمْسنْ خنِّي زڭْ إِذَامّنْ إِ إِدْجَانْ ذِي طّبْصِي خْ ثْنبْذَاثْ سنّجْ \add إِ ثوَّارْثْ\add* ؤُ خْ ثْنَاينْ ن ڒضْرُوفْ \add غَارْ ؤُغزْذِيسْ ن ثوَّارْثْ\add*. أَڒْ صّْبحْ وَارْ إِتّفّغْ ؤُڒَا ذ إِجّنْ زَّايْومْ زِي ثوَّارْثْ ن ثَادَّارْثْ نّسْ. \f ◼ \fr 12:‏22 \ft \bd ’ثَاعلْدْجثْ‘\bd* - س ثعْرَابْثْ: زُوفَا.\f*
\v 23 سِيذِي أَذْ إِژْوَا \add خْ ثمُّورْثْ\add*، مَاحنْذْ أَذْ إِوّثْ إِمِيصْرِييّنْ، \add مَاشَا خْمِي\add* غَا إِژَارْ إِذَامّنْ خْ ثْنبْذَاثْ ن نّجْ ؤُ خْ ثْنَاينْ ن ڒضْرُوفْ \add غَارْ ؤُغزْذِيسْ ن ثوَّارْثْ\add*، خنِّي أَذْ إِعْذُو سِيذِي ثَاوَّارْثْ نِّي، وَارْ إِتّجِّي أَمْثحَّايْ أَذْ يَاذفْ غَارْ ثُوذْرِينْ نْومْ، حِيمَا أَذْ إِوّثْ. \x ◘ \xo 12:‏23 \xt عبر. 11‏:‏28\x*
\v 24 حْضَامْ أَوَاڒْ-أَ \add إِ نِّيغْ\add*، أَقَا ذ ثوْصيّثْ إِ شكْ ؤُ إِ إِحنْجِيرنْ نّشْ إِ ڒبْذَا.
\v 25 أَذْ يِيڒِي، خْمِي غَا ثَاذْفمْ غَارْ ثمُّورْثْ ثنِّي ذ أَومْ غَا يوْشْ سِيذِي، أَمْ مَامّشْ إِنَّا نتَّا، أَذْ ثحْضَامْ أَعْبَاذْ-أَ \add ن ڒِيذَارثْ\add*.
\v 26 ؤُشَا خْ مِينِّي ذ أَومْ غَا إِنِينْ إِحنْجِيرنْ نْومْ: ’مِينْ إِخْسْ أَذْ يِينِي وعْبَاذْ-أَ \add ن ڒِيذَارثْ\add* إِ كنِّيوْ؟‘، \x ◘ \xo 12:‏26 \xt ياش. 4‏:‏6\x*
\v 27 \add خنِّي\add* أَذْ ثِينِيمْ: ’أَقَا ذ ثَاغَارْصْثْ ن ؤُسعْذُو إِ سِيذِي ونِّي إِعْذُونْ خْ ثُوذْرِينْ ن أَيْثْ ن إِسْرَائِيل ذِي مِيصْرَا، ؤُمِي إِوْثَا إِمِيصْرِييّنْ ؤُشَا إِفكّْ ثُوذْرِينْ نّغْ.‘ “ ڒخْذنِّي يُوضَارْ ڒْڭنْسْ ؤُشَا بنْذْقنْ نِيثْنِي.
\v 28 رُوحنْ أَيْثْ ن إِسْرَائِيل ؤُشَا ڭِّينْ أَمْ مَامّشْ ثنْ يُومُورْ سِيذِي إِ مُوسَا ذ هَارُونْ ؤُ أَمُّو إِ ت ڭِّينْ. \x ◘ \xo 12:‏28 \xt عبر. 11‏:‏28\x*
\b
\s1 جّْرِيحشْثْ وِيسّْعشْرَا
\m 
\v 29 \bd ثُوغَا غَارْ وزْينْ ن دْجِيڒثْ \bdit ؤُمِي\bdit* إِوْثَا سِيذِي مَارَّا إِمنْزَا ذِي ثمُّورْثْ ن مِيصْرَا \bdit س ڒْموْثْ\bdit*،\bd* زڭْ ؤُمنْزُو ن فِيرْعُونْ، ونِّي إِقِّيمنْ خْ ڒْعَارْشْ نّسْ، أَڒْ أَمنْزُو ن ؤُمحْبُوسْ إِ إِدْجَانْ ذِي ڒحْبسْ، ؤُڒَا ذ مَارَّا إِمنْزَا ن ڒبْهَايمْ. \f ◼ \fr 12:‏29 \ft \bd ’ڒحْبسْ‘\bd* - س ثْعِيبْرَانِيثْ ’ثَادَّارْثْ ن وَانُو‘. أَذْ ثَاغْ حبّْسنْ إِمِيصْرِييّنْ إِمحْبَاسْ ذڭْ إِجّْ ن وَانُو حِيمَا وَارْ زمَّارنْ أَذْ أَروْڒنْ.\f*  \x ◘ \xo 12:‏29 \xt إِزهد. 78‏:‏51؛ 105‏:‏36؛ 135‏:‏8؛ 136‏:‏10\x*
\m 
\v 30 إِكَّارْ فِيرْعُونْ ذِي دْجِيڒثْ نِّي، نتَّا ذ مَارَّا إِمْسخَّارنْ نّسْ ذ مَارَّا إِمِيصْرِييّنْ ؤُشَا ثُوغَا ذِينْ إِشْثْ ن ثْغُويِّيثْ ثمْغَارْ مِينْزِي وَارْ ثُوغِي ؤُڒَا ذ إِشْثْ ن ثَادَّارْثْ مَانِي وَارْ إِدْجِي ؤُمتِّينْ. \x ◘ \xo 12:‏30 \xt إِزهد. 105‏:‏38\x*
\v 31 ؤُشَا إِڒَاغَا-د إِ مُوسَا ذ هَارُونْ س دْجِيڒثْ، إِنَّا: ”كَّارمْ، ثفّْغمْ زِي ڒْوسْطْ ن ڒْڭنْسْ إِنُو، كنِّيوْ \add جْمِيعْ\add* أَكْ-ذ أَيْثْ ن إِسْرَائِيل، رُوحمْ، ثْعبْذمْ سِيذِي، أَمْ مَامّشْ ثنَّامْ كنِّيوْ.
\v 32 أَوْيمْ ؤُدْجِي نْومْ ذ إِفُونَاسنْ ذ ثْفُونَاسِينْ نْومْ، أَمْ مَامّشْ ثنَّامْ. رُوحمْ، \add مَاشَا تّْزَاوْڭغْ كنِّيوْ،\add* بَارْكمْ أَيِي نشّْ عَاوذْ!“
\v 33 زيَّارنْ إِمِيصْرِييّنْ أَطَّاسْ خْ ڒْڭنْسْ، مَاحنْذْ نِيثْنِي أَذْ فّْغنْ س ؤُقدْجقْ زِي ثمُّورْثْ، مِينْزِي \add إِمِيصْرِييّنْ\add* نَّانْ: ”أَقَا نشِّينْ مَارَّا ذ إِمتَّانْ!“
\v 34 ؤُشَا يِيوِي ڒْڭنْسْ أَرشْثِي نّسْ قْبڒْ مَا غَا إِنْضُو ؤُشَا ثِيبقْيِينْ نّْضنْ ثنْثْ جَارْ وَارُّوضْ نْسنْ خْ طْغَارْضِينْ نْسنْ. \f ◼ \fr 12:‏34 \ft \bd ’أَرشْثِي نّسْ‘\bd* - س ثْعِيبْرَانِيثْ ’أَرشْثِي نْسنْ‘.\f*
\v 35 أَيْثْ ن إِسْرَائِيل ڭِّينْ عْلَاحْسَابْ أَوَاڒْ \add إِ ذ أَسنْ إِنَّا\add* مُوسَا، تَّارنْ ڒقْشُوعْ ن نُّوقَارْثْ ذ وُورغْ ذ وَارُّوضْ زڭْ إِمِيصْرِييّنْ. \x ◘ \xo 12:‏35 \xt ؤُف. 3‏:‏21؛ 11‏:‏2؛ إِزهد. 105‏:‏37\x*
\v 36 سِيذِي إِوْشَا ڒْڭنْسْ أَرْضَا ذِي ثِيطَّاوِينْ ن إِمِيصْرِييّنْ، وْشِينْ أَسنْ مِينْ تَّارنْ، ؤُ \add أَمُّو إِ\add* كشّْضنْ نِيثْنِي إِمِيصْرِييّنْ. \f ◼ \fr 12:‏36 \ft \bd ’إِمِيصْرِييّنْ‘\bd* - س ثْعِيبْرَانِيثْ ’مِيصْرَا‘.\f*
\m 
\v 37 فسْينْ أَيْثْ ن إِسْرَائِيل إِقِيضَانْ نْسنْ، \add ؤُيُورنْ\add* زِي رَاعَامْسِيسْ غَارْ سُوكُّوثْ، \add ثُوغَا أَثنْ\add* عْڒَاحَاڒْ ذِي ستَّا-مْيَاثْ-أَڒفْ خْ إِضَارنْ، تّْوَاحسْبنْ إِرْيَازنْ وَاهَا، بْڒَا إِحنْجِيرنْ.
\v 38 إِڭعّذْ أَكِيذْسنْ إِجّْ ن ؤُبَارُّو ذ أَمقّْرَانْ ن عْڒَامْ كُوڒْ إِوْذَانْ، \add خنِّي عَاوذْ\add* ؤُدْجِي ذ إِفُونَاسنْ ذ ثْفُونَاسِينْ، أَقَا-ت ذ إِشْثْ ن ثْحِيمَارْثْ ثمْغَارْ أَطَّاسْ.
\v 39 س وَارشْثِي إِ كِيذْسنْ د-إِوْينْ زِي مِيصْرَا ڭّْوِينْ ثِيفْضِيرِينْ بْڒَا أَنْثُونْ، مِينْزِي ثُوغَا \add عَاذْ\add* وَارْ إِسْمِيمْ، مِينْزِي ؤُژّْڒنْ خَاسنْ-د زِي مِيصْرَا ؤُ وَارْ زمَّارنْ أَذْ بدّنْ مَاحنْذْ أَذْ أَريّْحنْ ؤُ وَارْ سّْوجْذنْ مَاشَّا إِ وبْرِيذْ إِ يِيخفْ نْسنْ.
\b
\m 
\v 40 ثُوغَا \add ڒْْمِيجَاڒْ ن\add* ثْزذِّيغْثْ ن أَيْثْ ن إِسْرَائِيل ذِي مِيصْرَا، \add ڒْْمِيجَارْ\add* إِ \add ذِينْ\add* إِزذْغنْ، أَربْعَا-مْيَا ؤُ-ثْڒَاثِينْ ن إِسڭّْوُوسَا. \x ◘ \xo 12:‏40 \xt أَمز. 15‏:‏13؛ ڒخ. 7‏:‏6؛ ڭال. 3‏:‏17\x*
\v 41 غَارْ ؤُنڭَّارْ ن أَربْعَا-مْيَا ؤُ-ثْڒَاثِينْ ن إِسڭّْوُوسَا، ذڭْ وَاسّْ نِّي سِيمَانْثْ نّسْ، فّْغنْ مَارَّا ڒْعسْكَارْ ن سِيذِي زِي ثمُّورْثْ ن مِيصْرَا.
\v 42 ثَانِيثَا أَقَا-ت ذ إِشْثْ ن دْجِيرثْ إِتّْخصَّا أَذْ ثتّْوَاحْضَا \add إِ ڒوْقَارْ\add* إِ سِيذِي، مَاغَارْ نتَّا إِنْذهْ إِ-ثنْ زِي ثمُّورْثْ ن مِيصْرَا. دْجِيڒثْ-أَ ثَانِيثَا، أَقَا-ت إِ سِيذِي. إِتّْخصَّا أَذْ ثتّْوَاحْذَا زِي مَارَّا أَيْثْ ن إِسْرَائِيل، ذِي \add مَارَّا\add* جِّيڒَاثْ نْسنْ.
\b
\s1 ثَاغَارْصْثْ ن ؤُسعْذُو ذ ؤُبَارَّانِي
\m 
\v 43 إِنَّا سِيذِي إِ مُوسَا ذ هَارُونْ: ”ذ ثَا ذ ثَاوْصيّثْ خْ \add ثْغَارْصْثْ ن\add* ؤُسعْذُو: وَارْ زَّايسْ إِتّتّْ مِّيسْ ن ؤُبَارَّانِي،
\v 44 \add مَاشَا\add* كُوڒْ إِسْمغْ إِمّسْغنْ زڭْ إِجّْ ن ورْيَازْ س نُّوقَارْثْ، إِزمَّارْ أَذْ زَّايسْ يشّْ، مَاڒَا ثْخثْنذْ أَسْ.
\v 45 أَمْعزّبْ ذ ؤُشوَّاڒْ وَارْ زَّايسْ تّتّنْ شَا.
\v 46 أَذْ إِتّْوَاشّْ ذِي ثَادَّارْثْ ذ إِشْثْ ؤُ وَارْ إِتّفّغْ وَالُو زڭْ ويْسُومْ نِّي غَارْ بَارَّا ن ثَادَّارْثْ ؤُشَا وَارْ زَّايسْ إِتَّارژِّي ؤُڒَا ذ إِجّْ ن يِيغسْ. \x ◘ \xo 12:‏46 \xt ڒخْڒ. 9‏:‏12؛ يُوح. 19‏:‏36\x*
\v 47 مَارَّا ثَامسْمُونْثْ ن إِسْرَائِيل أَذْ ثڭّْ \add أَمنِّي\add*.
\v 48 مَاڒَا شَا ن ؤُبَارَّانِي إِنّوْجوْ-د غَاركْ ؤُشَا إِخْسْ أَذْ إِسّوْجذْ \add ثَاغَارْصْثْ ن\add* ؤُسعْذُو إِ سِيذِي، إِتّْخصَّا أَذْ إِتّْوَاخْثنْ كُوڒْ أَرْيَازْ نِّي غَارسْ إِدْجَانْ. ڒخْذنِّي أَذْ د-إِقَارّبْ، أَذْ ت إِسّوْجذْ، ؤُشَا أَذْ يِيڒِي أَمْ ونِّي د-إِخڒْقنْ ذِي ثمُّورْثْ. مَاشَا ؤُڒَا ذ إِجّْ زڭْ إِنِّي وَارْ إِخْثِيننْ وَارْ إِزمَّارْ أَذْ زَّايسْ يشّْ. \x ◘ \xo 12:‏48 \xt ياش. 5‏:‏5\x*
\v 49 أَذْ ذِينْ يِيڒِي إِجّْ ن ؤُزرْفْ إِ ونِّي د-إِخڒْقنْ \add ذِي ثمُّورْثْ\add* ؤُ إِ ؤُبَارَّانْ إِ إِزدّْغنْ جَارْ أَومْ أَمْ ؤُبَارَّانِي.“
\v 50 ؤُشَا مَارَّا أَيْثْ ن إِسْرَائِيل ڭِّينْ أَمْ مَامّشْ ذ أَسنْ يُومُورْ مُوسَا ذ هَارُونْ، أَمُّو إِ ت ڭِّينْ.
\v 51 ؤُشَا إِمْسَارْ ذڭْ وَاسّْ نِّي سِيمَانْثْ نّسْ إِسُّوفُّوغْ سِيذِي أَيْثْ ن إِسْرَائِيل زِي ثمُّورْثْ ن مِيصْرَا \add أَمْ تّْوَاستّْفنْ نِيثْنِي\add* عْلَاحْسَابْ \add إِسذِّييّنْ ن\add* ڒْعسْكَارْ نْسنْ.
\b
\b
\c 13
\s1 أَزرْفْ إِ إِمنْزَا
\m 
\v 1 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:
\v 2 ”سْقدّسْ أَيِي كُوڒْ أَمنْزُو، ونِّي زِي جَارْ أَيْثْ ن إِسْرَائِيل يَارزْمنْ ڒمْڒَاوثْ \add ذ أَمزْوَارُو\add*، أَمْ زڭْ إِوْذَانْ أَمْ زِي ڒبْهَايمْ. نتَّا أَقَا إِنُو.“ \x ◘ \xo 13:‏2 \xt ؤُف. 22‏:‏29؛ 34‏:‏19؛ لَاوِي 27‏:‏26؛ ڒخْڒ. 3‏:‏13؛ 8‏:‏17؛ لك. 2‏:‏23\x*
\v 3 إِنَّا مُوسَا إِ ڒْڭنْسْ: ”إِذَارمْ أَسّْ-أَ مِينْ ذِي ثفّْغمْ زِي مِيصْرَا، زِي ثَادَّارْثْ ن ثسْمُوغِي، مِينْزِي سِيذِي إِسُّوفّغْ-د كنِّيوْ زَّايسْ س ؤُفُوسْ إِجهْذنْ. \add ذڭْ وَاسّْ-أَ\add* وَارْ ثتّتّمْ وَالُو مِينْ ذِي إِدْجَا ونْثُونْ. \f ◼ \fr 13:‏3 \ft \bd ’ثَاسْمُوغِي‘\bd* - أَقَا إِسمْغَانْ دَّارنْ ذِي ثسْمُوغِي مِينْزِي وَارْ غَارْسنْ بُو ثِيڒلِّي.\f*
\v 4 أَسّْ-أَ أَذْ ثفّْغمْ، ذڭْ ؤُيُورْ ن أَبِيبْ. \x ◘ \xo 13:‏4 \xt ؤُف. 23‏:‏15\x*
\v 5 مَاڒَا سِيذِي إِسِّيذفْ إِ شكْ غَارْ ثمُّورْثْ ن أَيْثْ ن كنْعَانْ ذ إِحِيتِّييّنْ ذ إِمُورِييّنْ ذ إِحِيوِييّنْ ذ إِيابُوسِييّنْ، خْ ثنِّي إِجُّودْجْ إِ ڒجْذُوذْ نْومْ أَذْ أَشْ ت إِوْشْ، ثَامُّورْثْ إِفيّْضنْ س ؤُغِي ذ ثَامّنْثْ، \add خنِّي\add* أَذْ ثحْضَامْ أَعْبَاذْ-أَ \add ن ڒِيذَارثْ\add* ذڭْ ؤُيُورْ-أَ.
\v 6 سبْعَا ن وُوسَّانْ أَذْ ثشّذْ أَغْرُومْ بْڒَا أَنْثُونْ ؤُشَا ذڭْ وَاسّْ وِيسّْ سبْعَا \add أَذْ ذِينْ يِيڒِي\add* إِجّْ ن ڒْعِيذْ إِ سِيذِي.
\v 7 سبْعَا ن وُوسَّانْ أَذْ إِتّْوَاشّْ وغْرُومْ بْڒَا أَنْثُونْ ؤُشَا وَارْ غَاركْ إِتّْوِيفِّي مِينْ إِخمّْرنْ. ذِي مَارَّا جّْوَايهْ نّشْ وَارْ إِتّْوِيفِي ونْثُونْ غَاركْ.
\v 8 ذڭْ وَاسّْ نِّي أَذْ ثْحَاجِيذْ إِ مِّيشْ، أَذْ أَسْ ثِينِيذْ: مَانْ أَيَا ذِي طّْوعْ ن مِينْ ذ أَيِي إِڭَّا سِيذِي ؤُمِي د-فّْغغْ زِي مِيصْرَا.
\v 9 أَذْ أَشْ يِيڒِي أَمْ يِيجّْ ن ؤُشيَّارْ خْ ؤُفُوسْ نّشْ ؤُ إِ ڒِيذَارثْ جَارْ ثِيطَّاوِينْ نّشْ، مَاحنْذْ شَّارِيعَا ن سِيذِي أَذْ ثِيڒِي ذڭْ ؤُقمُّومْ نّشْ، مِينْزِي س ؤُفُوسْ إِجهْذنْ إِسُّوفّغْ سِيذِي إِ كنِّيوْ زِي مِيصْرَا.
\v 10 س ؤُيَا إِ غَا ثحْضِيذْ ثَاوْسِييّثْ-أَ ذِي ڒْوقْثْ نّسْ إِ ذ أَسْ إِتّْوَاڭّنْ، زڭْ ؤُسڭّْوَاسْ غَارْ ؤُسڭّْوَاسْ.
\m 
\v 11 أَذْ يِيڒِي خْمِي شكْ غَا إِسِّيذفْ سِيذِي ذِي ثمُّورْثْ ن أَيْثْ ن كنْعَانْ، أَمْ مَامّشْ إِ ذ أَشْ إِجُّودْجْ ؤُڒَا إِ ڒجْذُوذْ نّشْ، ؤُشَا إِوْشَا أَشْ ت،
\v 12 \add خنِّي\add* أَذْ ثسّعْذُوذْ غَارْ سِيذِي كُوڒْ \add أَمنْزُو\add* إِ يَارزْمنْ ڒمْڒَاوثْ \add ذ أَمزْوَارُو\add* ؤُڒَا ذ كُوڒْ أَمنْزُو ن ڒبْهَايمْ إِ يَارزْمنْ ڒمْڒَاوثْ \add ذ أَمزْوَارُو\add*: إِوثْمَانْ أَذْ إِڒِينْ إِ سِيذِي. \x ◘ \xo 13:‏12 \xt ؤُف. 22‏:‏30؛ 34‏:‏19؛ لَاوِي 27‏:‏26؛ ڒخْڒ. 8‏:‏17؛ حِز. 44‏:‏30\x*
\v 13 مَاشَا كُوڒْ \add أَمنْزُو\add* إِ يَارزْمنْ ڒمْڒَاوْڒثْ ن وغْيُوڒْ \add ذ أَمزْوَارُو\add*، أَذْ ث ثفْذِيذْ س يِيجّْ زڭْ وُودْجِي. مَاڒَا وَارْ ث ثفْذِيذْ، أَذْ أَسْ ثَارْژذْ إِرِي. كُوڒْ أَمنْزُو ن بْنَاذمْ زڭْ إِحنْجِيرنْ نّشْ أَذْ ث ثفْذِيذْ.
\v 14 ؤُشَا أَذْ إِمْسَارْ، خْمِي شكْ غَا إِسّقْسَا مِّيشْ ثِيوشَّا، أَذْ يِينِي: ’مَانَاوْيَا؟‘، أَذْ أَسْ ثِينِيذْ: ’أَقَا إِسُّوفُّوغْ أَنغْ-د سِيذِي زِي مِيصْرَا س ؤُفُوسْ إِجهْذنْ، زِي ثَادَّارْثْ ن ثسْمُوغِي.
\v 15 \add ڒَْامِي\add* ذ أَنغْ إِبدّْ فِيرْعُونْ ذڭْ وبْرِيذْ إِ وُوفُّوغْ نّغْ، إِمْسَارْ أَقَا سِيذِي إِنْغَا مَارَّا إِمنْزَا ذِي ثمُّورْثْ ن مِيصْرَا، زڭْ ؤُمنْزُو ن بْنَاذمْ أَڒْ أَمنْزُو ن ڒبْهِيمثْ. خْ ؤُيَا قدّْمغْ كُوڒْ أَمنْزُو إِ يَارزْمنْ ڒمْڒَاوثْ \add ذ أَمزْوَارُو\add* ذ ثَاغْرَاصْثْ إِ سِيذِي، \add مَاشَا\add* كُوڒْ أَمنْزُو جَارْ إِحنْجِيرنْ إِنُو، أَذْ ث فْذِيغْ.
\v 16 أَذْ يِيڒِي ذ أَشيَّارْ خْ ؤُفُوسْ نّشْ ذ إِجّْ ن ؤُفِيڒُو ن ؤُسڭّمْ جَارْ ثِيطَّاوِينْ نّشْ، مِينْزِي سِيذِي أَقَا إِسُّوفّغْ أَنغْ-د زِي مِيصْرَا س ؤُفُوسْ إِجهْذنْ.‘ “ \x ◘ \xo 13:‏16 \xt ؤُف. 13‏:‏9، أَعَوذ. 6‏:‏8، أَوڒن. 3‏:‏3 \x*
\b
\m 
\v 17 \add ؤُمِي\add* إِجَّا فِيرْعُونْ ڒْڭنْسْ أَذْ إِرَاحْ، وَارْ ثنْ إِنْذِيهْ أَربِّي غَارْ وبْرِيذْ ن ثمُّورْثْ ن إِفِيلِيسْطِينِييّنْ، وَاخَّا نتَّاثْ ثُوذسْ، مِينْزِي أَربِّي إِنَّا: ”مَاحنْذْ وَارْ إِتّنْذمِّي ڒْڭنْسْ خْمِي غَا إِژَارْ ڒْبَارُوضْ ؤُشَا أَذْ د-إِذْوڒْ غَارْ مِيصْرَا.“
\v 18 إِنْذهْ أَربِّي ڒْڭنْسْ، مَاحنْذْ أَذْ إِكّْ خْ وبْرِيذْ ن ڒخْڒَا غَارْ ڒبْحَارْ ن ثلْڭَا. ؤُشَا ڭعّْذنْ أَيْثْ ن إِسْرَائِيل زِي مِيصْرَا وجْذنْ إِ ؤُمنْغِي.
\v 19 إِكْسِي مُوسَا أَكِيذسْ إِغْسَانْ ن يُوسُوفْ، مِينْزِي نتَّا إِسّْجُودْجْ أَيْثْ ن إِسْرَائِيل س إِشْثْ ن ثْژَادْجِيثْ، إِنَّا: ”س ثِيذتّْ أَذْ غَارْومْ د-يَارْزفْ أَربِّي، ؤُشَا أَذْ ثسّْڭعّْذمْ إِغْسَانْ إِنُو سَّا أَكِيذْومْ!“ \x ◘ \xo 13:‏19 \xt أَمز. 50‏:‏25؛ ياش. 24‏:‏32\x*
\v 20 ؤُشَا فسْينْ إِقِيضَانْ نْسنْ، \add ڭّْوجنْ\add* خْ سُوكُّوثْ ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ ذِي إِثَامْ، غَارْ طَّارْفْ ن ڒخْڒَا.
\v 21 سِيذِي إِزْوَارْ إِ ثِيطَّاوِينْ نْسنْ ذڭْ ؤُژِيڒْ ذڭْ إِجّْ ن ؤُقلِّيجْ ن ؤُسيْنُو، مَاحنْذْ أَذْ ثنْ إِڭوّذْ ذڭْ وبْرِيذْ، ؤُ ذِي دْجِيڒثْ ذڭْ إِجّْ ن ؤُقلِّيجْ ن ثْمسِّي، حِيمَا أَذْ غَارْسنْ إِڭّْ ثَافَاوْثْ، حِيمَا \add أَذْ ثَافْ زمَّارنْ\add* أَذْ ؤُيُورنْ أَسّْ ذ دْجِيڒثْ.
\v 22 ذڭْ وَاسّْ وَارْ د-إِكِّيسْ أَقلِّيجْ ن ؤُسيْنُو زَّاثْ إِ ؤُغمْبُوبْ ن ڒْڭنْسْ ؤُڒَا ذِي دْجِيڒثْ \add وَارْ د-إِكِّيسْ\add* أَقلِّيجْ ن ثْمسِّي.
\b
\b
\c 14
\s1 مُوسَا ذ ڒْڭنْسْ ژْوَانْ ڒبْحَارْ ن ثلْڭَا
\m 
\v 1 \add خنِّي\add* إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:
\v 2 ”سِيوڒْ أَكْ-ذ أَيْثْ ن إِسْرَائِيل، \add مَاحنْذْ\add* أَذْ د-ذوْڒنْ ؤُشَا أَذْ وْثنْ إِقِيضَانْ نْسنْ زَّاثْ إِ فِي-هَاخِيرُوثْ، جَارْ مِيڭْذُولْ ذ ڒبْحَارْ، قِيبَاتْشْ إِ بَاعَالْ-صَافُونْ. أَرنْذَاذْ نّسْ أَذْ ثوْثمْ إِقِيضَانْ نْومْ خْ ثْمَا ن ڒبْحَارْ. \x ◘ \xo 14:‏2 \xt ڒخْڒ. 33‏:‏7\x*
\v 3 \add خنِّي\add* أَذْ يِينِي فِيرْعُونْ خْ أَيْثْ ن إِسْرَائِيل: ’أَقَا نِيثْنِي ودَّارنْ ذِي ثمُّورْثْ، أَقَا ڒخْڒَا إِحْصَارْ إِ-ثنْ.‘
\v 4 ؤُشَا نشّْ أَذْ سّْقسْحغْ ؤُڒْ ن فِيرْعُونْ، \add حِيمَا\add* أَذْ ثنْ إِضْفَارْ ؤُ نشّْ أَذْ تّْوَاسّْعُودْجِيغْ خْ فِيرْعُونْ ؤُ خْ مَارَّا ڒْعسْكَارْ نّسْ ؤُشَا أَذْ سّْننْ إِمِيصْرِييّنْ بلِّي نشّْ ذ سِيذِي.“ ؤُشَا أَمُّو إِ ت ڭِّينْ نِيثْنِي. \x ◘ \xo 14:‏4 \xt ؤُف. 4‏:‏21؛ 10‏:‏20\x*
\m 
\v 5 ؤُشَا خبَّارنْ إِ ؤُجدْجِيضْ ن مِيصْرَا بلِّي ڒْڭنْسْ يَارْوڒْ. \add خنِّي\add* إِبدّڒْ وُوڒْ ن فِيرْعُونْ ذ إِمْسخَّارنْ نّسْ خْ ڒْڭنْسْ ؤُشَا نَّانْ: ”مَامّشْ إِ نڭَّا أَيَا، نسّكّْ إِسْرَائِيل زِي ثسْمُوغِي إِ إِڭِّينْ إِ نشِّينْ؟“
\v 6 ؤُشَا إِحزّمْ \add فِيرْعُونْ\add* أَكَارُّو نّسْ، إِكْسِي أَكِيذسْ ڒْڭنْسْ نّسْ.
\v 7 إِكْسِي أَكِيذسْ ستَّا-مْيَا ن إِكَارُّوثنْ إِشوَّارنْ ذ مَارَّا إِكَارُّوثنْ ن مِيصْرَا ؤُشَا \add إِڭَّا\add* أَشوَّارْ ن إِنغْرَافنْ \add زِي ڒْعسْكَارْ\add* نّسْ خْ كُوڒْ \add إِجّْ زَّايْسنْ\add*.
\v 8 أَقَا إِسّقْسحْ سِيذِي ؤُڒْ ن فِيرْعُونْ، أَجدْجِيذْ ن مِيصْرَا، ؤُشَا يَارْذفْ نتَّا أَيْثْ ن إِسْرَائِيل، مَاشَا أَيْثْ ن إِسْرَائِيل ثُوغَا فّْغنْ س يِيجّْ ن ؤُفُوسْ إِتّْوَاسّْڭعّْذنْ.
\v 9 أَرذْفنْ ثنْ إِمِيصْرِييّنْ ؤُشَا إِوْضنْ غَارْسنْ س مَارَّا إِيْسَانْ ذ إِكَارُّوثنْ ن فِيرْعُونْ ذ إِمْنَاينْ نّسْ ذ ڒْعسْكَارْ نّسْ، غَارْ فِي-هَاخَارُوثْ، غَارْ ؤُجمَّاضْ ن بَاعَالْ-صَافُونْ، مَانِي وْثِينْ إِقِيضَانْ نْسنْ غَارْ ڒبْحَارْ. \x ◘ \xo 14:‏9 \xt ياش. 24‏:‏6\x*
\v 10 \add ڒَْامِي\add* ثنْ د-يُوذسْ فِيرْعُونْ، سّْڭعّْذنْ أَيْثْ ن إِسْرَائِيل ثَامُوغْڒِي نْسنْ، ژْرِينْ بلِّي إِمِيصْرِييّنْ ضْفَارنْ ثنْ-د ؤُشَا نِيثْنِي ڭّْوذنْ أَطَّاسْ. \add خنِّي\add* سْغُوينْ أَيْثْ ن إِسْرَائِيل غَارْ سِيذِي.
\v 11 نَّانْ إِ مُوسَا: ”مَا وَارْ دْجِينْ \add عَاذْ\add* إِمضْڒَانْ ذِي مِيصْرَا أَڒْ ذ أَنغْ د-ثَاوْيذْ، مَاحنْذْ أَذْ نمّثْ ذِي ڒخْڒَا-يَا؟ مَاغَارْ ثڭِّيذْ أَمُّو، ثسُّوفّْغذْ أَنغْ-د زِي مِيصْرَا؟
\v 12 مَا وَارْ كِيذكْ نسِّيوڒْ مَارَّا أَوَاڒنْ-أَ ذِي مِيصْرَا، ننَّا: ’أجّْ أَنغْ أَذْ نخْذمْ إِ إِمِيصْرِييّنْ‘؟ خَارْ مَاڒَا \add ثُوغَا نقِّيمْ\add* نخْذمْ إِ إِمِيصْرِييّنْ خْ مَاڒَا نمُّوثْ ذِي ڒخْڒَا.“ \x ◘ \xo 14:‏12 \xt ؤُف. 6‏:‏9\x*
\v 13 \add خنِّي\add* إِنَّا مُوسَا إِ ڒْڭنْسْ: ”وَارْ تّڭّْوذمْ، بدّمْ، ثخْزَارمْ أَسنْجمْ ن سِيذِي إِ ذ أَومْ غَا يوْشْ أَسّْ-أَ، مِينْزِي إِمِيصْرِييّنْ نِّي ثتّْوَاڒَامْ أَسّْ-أَ،عمَّارْصْ أَذْ ثنْ ثْژَارمْ عَاذْ إِ ڒبْذَا.
\v 14 سِيذِي أَذْ خَاومْ إِمّْنغْ ؤُشَا كنِّيوْ أَذْ ثْسغْذمْ \add وَاهَا\add*.“
\m 
\v 15 إِنَّا سِيذِي إِ مُوسَا: ”مَايمِّي غَارِي ثتّْڒَاغِيذْ؟ إِنِي إِ أَيْثْ ن إِسْرَائِيل \add حِيمَا\add* أَذْ فسْينْ إِقِيضَانْ نْسنْ.
\v 16 سْڭعّذْ ثَاغَّارْشْثْ نّشْ، سْوِيژّضْ أَفُوسْ نّشْ خْ ڒبْحَارْ ؤُشَا فَارْقْ إِ-ث، حِيمَا أَذْ إِژْوَا أَيْثْ ن إِسْرَائِيل خْ ڒْبَارّْ ذِي ڒْوسْطْ ن ڒبْحَارْ.
\v 17 خْزَارْ، نشّْ أَذْ سّْقسْحغْ ؤُڒْ ن إِمِيصْرِييّنْ، مَاحنْذْ أَذْ ثنْ أَرذْفنْ \add ذِي ڒبْحَارْ\add* ؤُ نشّْ أَذْ سّْعُودْجِيغْ إِخفْ إِنُو س فِيرْعُونْ ؤُ س مَارَّا ڒْعسْكَارْ نّسْ، إِكَارُّوثنْ نّسْ ذ إِمْنَاينْ نّسْ \add ن إِيْسَانْ\add*.
\v 18 أَذْ سّْننْ إِمِيصْرِييّنْ بلِّي نشّْ ذ سِيذِي، خْمِي غَا تّْوَاسّْعُودْجِيغْ س فِيرْعُونْ، س إِكَارُّوثنْ نّسْ ذ إِمْنَاينْ نّسْ \add ن إِيْسَانْ\add*.“
\m 
\v 19 \add خنِّي\add* إِمُّوطِّي لْمَالَاكْ ن أَربِّي نِّي يُويُورنْ زَّاثْ إِ ڒْعسْكَارْ ن إِسْرَائِيل ؤُشَا إِذْوڒْ غَارْ ضفَّارْ \add نْسنْ\add*: أَقلِّيجْ ن ؤُسيْنُو إِمُّوطِّي زِي زَّاثْ إِ وُوذمْ نْسنْ ؤُشَا إِبدّْ غَارْ ضفَّارْ نْسنْ.
\v 20 يُوذفْ \add ؤُقلِّيجْ\add* جَارْ ڒْعسْكَارْ ن إِمِيصْرِييّنْ ذ ڒْعسْكَارْ ن إِسْرَائِيل. ثُوغَا أَسيْنُو ذ ثَادْجسْثْ \add غَارْ ؤُغزْذِيسْ-أَ\add* ؤُ إِسِّيغْ \add إِ ؤُغزْذِيسْ نّغْنِي\add* س دْجِيڒثْ ؤُ وَارْ د-إِقَارّبْ إِجّنْ غَارْ ونّغْنِي دْجِيڒثْ ثكْمڒْ.
\v 21 ؤُشَا إِسّْوِيژّضْ مُوسَا أَفُوسْ نّسْ خْ ڒبْحَارْ ؤُشَا إِعَارْنْ سِيذِي خنِّي ڒبْحَارْ غَارْ ؤُغزْذِيسْ س يِيجّْ ن ؤُسمِّيضْ ذ أَشَارْقِي إِجْهذْ، مَارَّا دْجِيڒثْ \add نِّي\add*، ؤُشَا يَارَّا ڒبْحَارْ أَذْ إِجفّفْ. \add أَمُّو\add* إِ تّْوَامّْسبْضَانْ وَامَانْ. \x ◘ \xo 14:‏21 \xt ياش. 4‏:‏23؛ إِزهد. 78‏:‏13؛ 106‏:‏9؛ 114‏:‏3\x*
\v 22 ؤُيُورنْ أَيْثْ ن إِسْرَائِيل خْ مِينْ يُوژْغنْ ذِي ڒْوسْطْ ن ڒبْحَارْ ؤُشَا أَمَانْ ڭِّينْ أَمشْنَاوْ ڒْحِيضْ خْ يفُوسْ نْسنْ ذ ؤُزڒْمَاضْ نْسنْ. \x ◘ \xo 14:‏22 \xt 1 كُور. 10‏:‏1؛ عبر. 11‏:‏29\x*
\v 23 أَرذْفنْ ثنْ إِمِيصْرِييّنْ، رُوحنْ أَوَارْنِي أَسنْ ذِي ڒْوسْطْ ن ڒبْحَارْ س مَارَّا إِيْسَانْ ن فِيرْعُونْ ذ إِكَارُّوثنْ نّسْ ذ إِمْنَاينْ نّسْ \add ن يِييْسَانْ\add*.
\v 24 ڒَامِي ذ يفُّو ڒْحَاڒْ، إِمْسَارْ بلِّي سِيذِي إِصْوضْ غَارْ ڒْعسْكَارْ ن إِمِيصْرِييّنْ زڭْ ؤُقلِّيجْ ن ثْمسِّي ذ إِسيْنُوثنْ ؤُشَا إِسّْخَارْوضْ ڒْعسْكَارْ ن مِيصْرَا.
\v 25 إِجَّا ثِيجَارَّارِينْ ن إِكَارُّوثنْ نْسنْ أَذْ فسْخنْثْ، أَڒَامِي إِذْوڒْ إِوْعَارْ خَاسنْ أَذْ ؤُيُورنْ غَارْ زَّاثْ. \add ڒخْذنِّي\add* نَّانْ إِمِيصْرِييّنْ، \add كُوڒْ إِجّنْ زَّايْسنْ إِ يِيخفْ نّسْ\add*: ”إِتّْخصَّا أَيِي أَذْ أَروْڒغْ زِي زَّاثْ ن ثِيطَّاوِينْ ن إِسْرَائِيل، مِينْزِي سِيذِي إِمّْنغْ ذِي طّْوعْ نْسنْ ضِيدّْ إِ إِمِيصْرِييّنْ.“
\v 26 إِنَّا سِيذِي إِ مُوسَا: ”سْوِيژّضْ أَفُوسْ نّشْ خْ ڒبْحَارْ، حِيمَا أَذْ ذوْڒنْ وَامَانْ خْ إِمِيصْرِييّنْ، خْ إِكَارُّوثنْ نْسنْ ؤُ خْ إِمْنَاينْ نْسنْ \add ن إِيْسَانْ\add*.“
\v 27 \add خنِّي\add* إِسّْوِيژّضْ مُوسَا أَفُوسْ نّسْ خْ ڒبْحَارْ ؤُ غَارْ ڒفْجَارْ ن صّْبحْ إِذْوڒْ ڒبْحَارْ غَارْ مَانِي ث ثُوغَا قْبڒْ ؤُشَا أَروْڒنْ إِمِيصْرِييّنْ نِيشَانْ ضِيدّْ نّسْ ؤُشَا إِغْضڒْ سِيذِي إِمِيصْرِييّنْ ذِي ڒْوسْطْ ن ڒبْحَارْ.
\v 28 ذوْڒنْ-د وَامَانْ ؤُشَا تّْوَانضْڒنْ إِكَارُّوثنْ ذ إِمْنَاينْ \add ن إِيْسَانْ\add* ن مَارَّا ڒْعسْكَارْ ن فِيرْعُونْ إِ ثُوغَا يُوذفْ أَوَارْنِي أَسنْ غَارْ ڒبْحَارْ. وَارْ زَّايْسنْ إِقِّيمْ ؤُڒَا ذ إِجّنْ. \x ◘ \xo 14:‏28 \xt إِزهد. 78‏:‏53؛ 106‏:‏11\x*
\v 29 \add مَاشَا\add* أَيْثْ ن إِسْرَائِيل ؤُيُورنْ خْ مِينْ يُوژْغنْ ذِي ڒْوسْطْ ن ڒبْحَارْ ؤُ أَمَانْ ثُوغَا ڭِّينْ أَمشْنَاوْ ڒْحِيضْ غَارْ يفُوسْ نْسنْ ذ ؤُزڒْمَاضْ نْسنْ. \x ◘ \xo 14:‏29 \xt إِزهد. 77‏:‏20\x*
\v 30 \add أَمُّو\add* إِ إِسّنْجمْ سِيذِي إِسْرَائِيل ذڭْ وَاسّْ نِّي زڭْ ؤُفُوسْ ن إِمِيصْرِييّنْ ؤُشَا إِسْرَائِيل إِژْرَا إِمِيصْرِييّنْ إِ إِمُّوثنْ خْ ثْمَا ن ڒبْحَارْ.
\v 31 إِژْرَا إِسْرَائِيل أَفُوسْ إِمْغَارنْ إِ إِڭَّا سِيذِي ذڭْ إِمِيصْرِييّنْ ؤُشَا إِڭّْوذْ ڒْڭنْسْ زِي سِيذِي، ؤُشَا ؤُمْننْ نِيثْنِي ذِي سِيذِي ؤُ ذِي مُوسَا، أَمْسخَّارْ نّسْ.
\b
\b
\c 15
\s1 إِزْڒِي ن ؤُغلّبْ ن مُوسَا
\m 
\v 1 ڒخْذنِّي إِزهّذْ مُوسَا جْمِيعْ أَكْ-ذ أَيْثْ ن إِسْرَائِيل زْهِيذْ-أَ إِ سِيذِي، نَّانْ:
\b
\m \qt ”أَذْ زهّْذغْ إِ سِيذِي،\qt*
\m \qt مِينْزِي نتَّا يُوعْڒَا ذِي ڒُوعْڒَا!\qt*
\m \qt أَيِيسْ ذ ونِّي خَاسْ ينْيِينْ\qt*
\m \qt إِنْضَارْ إِ-ثنْ ذِي ڒبْحَارْ.\qt* \x ◘ \xo 15:‏1 \xt إِزهد. 106‏:‏12؛ أَسَا. 15‏:‏3\x*
\m 
\v 2 \qt سِيذِي ذ جّهْذْ إِنُو ذ أَزهّذْ إِنُو.\qt*
\m \qt نتَّا إِذْوڒْ ذ أَسنْجمْ إِنُو.\qt*
\m \qt وَا ذ أَربِّي إِنُو،\qt*
\m \qt نشّْ أَذْ ث سّمْغَارغْ.\qt*
\m \qt نتَّا ذ أَربِّي ن بَابَا،\qt*
\m \qt نشّْ أَذْ ث سّْعُودْجغْ!\qt* \x ◘ \xo 15:‏2 \xt إِزهد. 18‏:‏2؛ إِزهد. 118‏:‏14؛ إِشا. 12‏:‏2\x*
\m 
\v 3 \qt سِيذِي ذ أَرْيَازْ ن ؤُمنْغِي،\qt*
\m \qt سِيذِي ذ إِسمْ نّسْ!\qt*
\m 
\v 4 \qt إِكَارُّوثنْ ن فِيرْعُونْ ذ ڒْعسْكَارْ نّسْ\qt*
\m \qt إِنْضَارْ إِ-ثنْ ذِي ڒبْحَارْ\qt*
\m \qt ؤُ أَشوَّارْ ن إِنغْرَافنْ نّسْ \tl ن ڒْعسْكَارْ\tl*\qt*
\m \qt غَارْقنْ ذِي ڒبْحَارْ ن ثلْڭَا.\qt*
\m 
\v 5 \qt \tl أَمَانْ\tl* إِهوْڒنْ ذْڒِينْ إِ-ثنْ.\qt*
\m \qt أَمشْنَاوْ أَژْرُو، هْوَانْ غَارْ ڒَادْجَاغْ.\qt* \x ◘ \xo 15:‏5 \xt نَاح. 9‏:‏11\x*
\m 
\v 6 \qt \tl أَ\tl* سِيذِي، أَفُوسْ أَفُوسِي نّشْ\qt*
\m \qt إِتّْوَاعزّْ س جّهْذْ،\qt*
\m \qt أَفُوسْ أَفُوسِي نّشْ،\qt*
\m \qt \tl أَ\tl* سِيذِي، أَقَا إِڒْبزْ ڒعْذُو.\qt* \x ◘ \xo 15:‏6 \xt إِزهد. 118‏:‏15، 16\x*
\m 
\v 7 \qt س ڒمْغَارثْ ن ؤُعُودْجِي نّشْ ثثحِّيذْ\qt*
\m \qt إِنِّي كِيكْ إِتّمْعَاڒَانْ.\qt*
\m \qt مَاڒَا ثسّكّذْ ڒْحَاذُوقْ \tl ن وغْضَابْ\tl* نّشْ،\qt*
\m \qt أَذْ ثنْ يشّْ وَانِيثَا أَمشْنَاوْ إِغدْجْ.\qt*
\m 
\v 8 \qt س ؤُسُوضِي ن ونْزَارنْ نّشْ\qt*
\m \qt عُورّْشنْ وَامَانْ،\qt*
\m \qt تّْوَاسّْبدّنْ ثْسدْجْيَا أَمْ وغْبَارْ،\qt*
\m \qt أَمَانْ إِهوْڒنْ جمْذنْ\qt*
\m \qt ذِي ڒْوسْطْ ن ڒبْحَارْ.\qt* \x ◘ \xo 15:‏8 \xt إِشا. 63‏:‏12، 13؛ حَاب. 3‏:‏10\x*
\m 
\v 9 \qt إِنَّا ڒعْذُو: ’أَذْ ثنْ أَرذْفغْ،\qt*
\m \qt أَذْ \tl ثنْ\tl* عْذُوغْ،\qt*
\m \qt أَذْ بْضِيغْ ڒْمُورْ،\qt*
\m \qt ڒعْمَارْ إِنُو أَذْ زَّايْسنْ إِجِّيونْ،\qt*
\m \qt أَذْ د-جبْذغْ سِّيفْ إِنُو،\qt*
\m \qt أَفُوسْ إِنُو أَذْ زَّايْسنْ إِكّسْ ڒْوَارْثْ نْسنْ.‘\qt*
\m 
\v 10 \qt ثْسُوضذْ س نّفْسْ نّشْ\qt*
\m \qt ؤُشَا إِذڒْ إِ-ثنْ ڒبْحَارْ.\qt*
\m \qt نِيثْنِي هْوَانْ-د أَمْ ڒخْفِيفْ\qt*
\m \qt ذڭْ وَامَانْ إِمْغَارنْ.\qt* \x ◘ \xo 15:‏10 \xt إِزهد. 74‏:‏13؛ 106‏:‏11\x*
\m 
\v 11 \qt \tl أَ\tl* سِيذِي، مَانْ ونْ إِ إِدْجَانْ\qt*
\m \qt أَمْ شكْ جَارْ إِربِّيثنْ؟\qt*
\m \qt وِي إِدْجَانْ أَمْ شكْ،\qt*
\m \qt ذ ونِّي إِتّْوَاسّْعُودْجنْ ذِي ثْقدَّاسْثْ،\qt*
\m \qt أَمْوقَّارْ ذڭْ إِزْڒَانْ ن ؤُصبّحْ،\qt*
\m \qt مَانْ ونْ إِتّڭّنْ ڒعْجَايبْ \tl أَمْ شكْ\tl*؟\qt*
\m 
\v 12 \qt ثسّْوِيژّْضذْ أَفُوسْ أَفُوسِي نّشْ،\qt*
\m \qt ثْسَارْضْ إِ-ثنْ ثمُّورْثْ.\qt*
\m 
\v 13 \qt شكْ ثْڭوّْذذْ ڒْڭنْسْ-أَ\qt*
\m \qt س ثْمخْسِيوْثْ نّشْ إِشُووَّارنْ،\qt*
\m \qt أَقَا ثفْذِيذْ \tl ث\tl*\qt*،
\m \qt س جّهْذْ نّشْ ثْنذْهذْ \tl ثنْ\tl*\qt*
\m \qt غَارْ ثْزذِّيغْثْ إِقدّْسنْ نّشْ.\qt*
\m 
\v 14 \qt ڒڭْنُوسْ سْڒِينْ \tl خْ ؤُيَا\tl* ؤُشَا أَرْجِيجنْ.\qt*
\m \qt ثطّفْ ثڭّْوُوذِي ذڭْ إِمزْذَاغْ ن فِيلِيشِيثْ.\qt*
\m 
\v 15 \qt ڒخْذنِّي إِمقّْرَاننْ ن ثْقبَّاڒْ\qt*
\m \qt ن إِذُومْ تّْبهْثنْ،\qt*
\m \qt إِنِّي غَارْ ثدْجَا صُّولْطَا ذِي مُوآبَ\qt*
\m \qt تَّارْجِيجنْ،\qt*
\m \qt ؤُ مَارَّا إِمزْذَاغْ ن كنْعَانْ أَقَا فسْينْ!\qt* \x ◘ \xo 15:‏15 \xt أَعَوذ. 2‏:‏4\x*
\m 
\v 16 \qt ثوْضَا خَاسنْ ڒْعُورّثْ ذ ثِيڭّْوُوذِي.\qt*
\m \qt س ڒمْغَارثْ ن ؤُغِيڒْ نّشْ\qt*
\m \qt سغْذنْ أَمْ وژْرُو،\qt*
\m \qt أَڒَامِي إِژْوَا ڒْڭنْسْ نّشْ، \tl أَ\tl* سِيذِي،\qt*
\m \qt أَڒَامِي إِژْوَا ڒْڭنْسْ-أَ\qt*
\m \qt إِ ثْكسْبذْ إِ يِيخفْ نّشْ.\qt*\x ◘ \xo 15:‏16 \xt أَعَوذ. 2‏:‏25؛ 11‏:‏25؛ ياش. 2‏:‏9\x*
\m 
\v 17 \qt شكْ أَذْ ثنْ ثْنذْهذْ\qt*
\m \qt ؤُشَا أَذْ ثنْ ثژُّوذْ\qt*
\m \qt خْ وذْرَارْ ن ڒْوَارْثْ نّشْ،\qt*
\m \qt أَمْشَانْ إِ ثڭِّيذْ ذ ثَازذِّيغْثْ نّشْ،\qt*
\m \qt \tl أَ\tl* سِيذِي، زَّاوشْثْ إِقدّْسنْ\qt*
\m \qt إِ إِڭِّينْ إِفَاسّنْ نّشْ، \tl أَ\tl* سِيذِي إِنُو.\qt*
\m 
\v 18 \qt سِيذِي أَذْ إِحْكمْ إِ ڒبْذَا قَاعْ!\qt*
\m 
\v 19 \qt مِينْزِي أَيِيسْ ن فِيرْعُونْ يُوذفْ غَارْ ڒبْحَارْ\qt*
\m \qt س إِكَارُّوثنْ نّسْ ذ إِمْنَاينْ نّسْ\qt*
\m \qt ؤُشَا إِقْڒبْ خَاسنْ سِيذِي عَاوذْ\qt*
\m \qt أَمَانْ ن ڒبْحَارْ.\qt*
\m \qt \tl مَاشَا\tl* أَيْثْ ن إِسْرَائِيل ژْوَانْ خْ ڒَاژَاغْ\qt*
\m \qt ذِي ڒْوسْطْ ن ڒبْحَارْ.“\qt*
\b
\m 
\v 20 ؤُ مَارْيَامْ، ثَانَابِيثْ، ؤُتْشْمَاسْ ن هَارُونْ، ثكْسِي أَدْجُونْ ذڭْ ؤُفُوسْ نّسْ ؤُ مَارَّا ثِيمطَّا فّْغنْثْ أَوَارْنِي أَسْ س إِبنْذِيرنْ ذ شّْضِيحْ \add س نُّوبْثَاثْ\add*. \x ◘ \xo 15:‏20 \xt 1 صم. 18‏:‏6\x*
\v 21 \add خنِّي\add* ثَارَّا-د خَاسنْ مَارْيَامْ سْنُّوبثْ نّسْ: ”غنّْجمْ إِ سِيذِي، مِينْزِي أَقَا نتَّا يُوعْڒَانْ أَطَّاسْ! إِنْضَارْ أَيِيسْ أَكْ-ذ ونِّي خَاسْ ينْيِينْ ذِي ڒبْحَارْ.“
\b
\m 
\v 22 \add خنِّي\add* إِجَّا مُوسَا \add ڒْْڭنْسْ ن\add* إِسْرَائِيل أَذْ إِفْسِي إِقِيضَانْ نْسنْ، إِنِّي إِدْجَانْ خْ ثْمَا ن ڒبْحَارْ ن ثلْڭَا، ؤُشَا رُوحنْ ذِي ڒخْڒَا ن شُورْ، ؤُيُورنْ ثْڒَاثَا ن وُوسَّانْ ذِي ڒخْڒَا بْڒَا أَذْ أَفنْ أَمَانْ.
\v 23 ؤُشَا إِوْضنْ غَارْ \bd مَارَا\bd*، \add مَاشَا\add* وَارْ زمَّارنْ أَذْ سْونْ أَمَانْ ن مَارَا، مِينْزِي ثُوغَا أَثنْ ذ إِمرْزَاڭنْ. خْ ؤُيَا ڭِّينْ أَسْ إِ ومْشَانْ نِّي ’مَارَا‘. \x ◘ \xo 15:‏23 \xt ڒخْڒ. 33‏:‏8\x*
\v 24 إِنّذْقمْ ڒْڭنْسْ خْ مُوسَا، إِنَّا: ”مِينْ غَا نْسُو؟“ \f ◼ \fr 15:‏24 \ft \bd ’إِنّذْقمْ‘\bd* - نِيغْ ’إِعكّسْ‘.\f*
\v 25 نتَّا إِڒَاغَا إِ سِيذِي ؤُشَا سِيذِي إِمّڒْ أَسْ إِجّْ ن ؤُكشُّوضْ ؤُشَا إِنْضَارْ إِ-ث ذَاخڒْ ذڭْ وَامَانْ ؤُشَا ذوْڒنْ وَامَانْ ذ إِمِيژِيذنْ. ذِينْ إِ ذ أَسْ إِڭَّا \add إِ ڒْڭنْسْ\add* إِشْثْ ن ثوْصيّثْ ذ إِشْثْ ن لْفَارِيضَا ؤُ ذِينِّي إِ-ثنْ إِقدْجبْ.
\v 26 إِنَّا: ”مَاڒَا ثسْڒِيذْ مْلِيحْ إِ وَاوَاڒْ ن سِيذِي، أَربِّي نّشْ، ثڭِّيذْ مِينْ إِدْجَانْ نِيشَانْ ذِي ثِيطَّاوِينْ نّسْ، أَذْ ثسْڒذْ إِ ڒُومَارَاثْ نّسْ، أَذْ ثحْضِيذْ مَارَّا ثِيوصَّا نّسْ، \add خنِّي\add* نشّْ وَارْ ذ أَومْ-د سّكِّيغْ ڒهْڒَاشْ إِ د-سّكّغْ خْ مِيصْرَا، مِينْزِي نشّْ ذ سِيذِي، أَمسْڭنْفِي نّشْ!“
\v 27 \add ڒخْذنِّي\add* إِوْضنْ غَارْ \bd إِلِيمْ\bd*، مَانِي ثُوغَا ثنْعَاشْ ن ڒْعُونْصَارَاثْ ن وَامَانْ، ذ سبْعِينْ ن ثْشجُّورَا ن ثِينِي ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ ذِينِّي زَّاثْ إِ وَامَانْ.
\b
\b
\c 16
\s1 أَغْرُومْ زڭْ ؤُجنَّا
\m 
\v 1 ؤُشَا فسْينْ إِقِيضَانْ نْسنْ، \add ؤُيُورنْ\add* زِي إِلِيمْ، ؤُ مَارَّا ثَامسْمُونْثْ ن أَيْثْ ن إِسْرَائِيل ثِيوضْ غَارْ ڒخْڒَا ن سِينْ إِ إِدْجَانْ جَارْ إِلِيمْ ذ سِينَا. ثُوغَا \add مَانْ أَيَا\add* ذڭْ وَاسّْ خمّسْطَاشْ ن ؤُيُورْ وِيسّْ ثْنَاينْ أَوَارْنِي ڒَامِي د-فّْغنْ زِي ثمُّورْثْ ن مِيصْرَا. \x ◘ \xo 16:‏1 \xt ڒخْڒ. 33‏:‏5‏-‏49\x*
\v 2 مَارَّا ثَامسْمُونْثْ ن أَيْثْ ن إِسْرَائِيل ثنّذْقمْ زِي مُوسَا ذ هَارُونْ ذِي ڒخْڒَا.
\v 3 نَّانْ أَسنْ أَيْثْ ن إِسْرَائِيل: ”مْڒِي نمُّوثْ س ؤُفُوسْ ن سِيذِي ذِي ثمُّورْثْ ن مِيصْرَا ؤُمِي ثُوغَا نقِّيمْ غَارْ طّْبَاصِي ن ويْسُومْ، نشَّا أَغْرُومْ أَڒَامِي نجِّيونْ! مِينْزِي كنِّيوْ ثسُّوفّْغمْ أَنغْ-د غَارْ ڒخْڒَا-يَا مَاحنْذْ أَذْ ثنْغمْ مَارَّا أَڭْرَاوْ أَيَا س ڒَاژْ.“ \x ◘ \xo 16:‏3 \xt ڒخْڒ. 11‏:‏4؛ 1 كُور. 10‏:‏10\x*
\v 4 \add خنِّي\add* إِنَّا سِيذِي إِ مُوسَا: ”خْزَارْ، أَذْ جّغْ أَغْرُومْ أَذْ خَاومْ د-إِوْضَا زڭْ ؤُجنَّا أَمْ ونْژَارْ. \add خنِّي\add* أَذْ إِفّغْ ڒْڭنْسْ، أَذْ كْسِينْ مِينْ حْذَاجنْ إِ وَاسّْ ذڭْ وَاسّْ نِّي، حِيمَا أَذْ ثنْ قدْجْبغْ، مَا ڭُّورنْ ذِي \add ثْغُورِي ن\add* شَّارِيعَا إِنُو، نِيغْ لَّا. \x ◘ \xo 16:‏4 \xt إِزهد. 78‏:‏24؛ 105‏:‏40\x*
\v 5 أَذْ يِيڒِي ذڭْ وَاسّْ وِيسّْ ستَّا، أَذْ سّْوجْذنْ مِينْ د-إِوْينْ غَارْ ذَاخڒْ. مَانْ أَيَا أَذْ يِيڒِي ذ ثْنَاينْ ن ثْسقَّارْ خْ مِينْ غَا سّْمُوننْ كُوڒْ أَسّْ.“
\m 
\v 6 \add ڒخْذنِّي\add* إِنَّا مُوسَا ذ هَارُونْ إِ مَارَّا أَيْثْ ن إِسْرَائِيل: ”غَارْ ؤُعشِّي أَذْ ثسّْنمْ بلِّي سِيذِي إِ كنِّيوْ د-إِسُّوفّْغنْ زِي ثمُّورْثْ ن مِيصْرَا،
\v 7 ؤُ غَارْ صّْبحْ أَذْ ثْژَارمْ أَعُودْجِي ن سِيذِي، مِينْزِي أَقَا نتَّا إِسْڒَا أَنذْقمْ نْومْ خْ سِيذِي. مَا نشِّينْ، \add مِينْ نعْنَا\add*، حِيمَا كنِّيوْ أَذْ خَانغْ ثنّْذقْممْ؟“ \f ◼ \fr 16:‏7 \ft \bd ’أَنذْقمْ‘\bd* - نِيغْ ’ڒعْكَاسثْ‘.\f*
\v 8 إِنَّا مُوسَا: ”ڒَْامِي ذ أَومْ إِوْشَا سِيذِي أَيْسُومْ إِ مَاشَّا ذڭْ ؤُعشِّي ؤُ أَغْرُومْ ذِي ثْيَاوَانْثْ ذِي صّْبحْ، أَقَا إِسْڒَا سِيذِي أَنذْقمْ نْومْ إِ زِي خَاسْ ثتّْنذْقَاممْ. إِ نشِّينْ، \add مِينْ نعْنَا\add*؟ كنِّيوْ وَارْ خَانغْ ثتّْنذْقَاممْ، مَاشَا خْ سِيذِي.“
\v 9 إِنَّا مُوسَا إِ هَارُونْ: ”إِنِي إِ ثْمسْمُونْثْ ن أَيْثْ ن إِسْرَائِيل مَارَّا: ’رحّْڭمْ-د غَارْ زَّاثْ إِ وُوذمْ ن سِيذِي، مِينْزِي أَقَا إِسْڒَا إِ ؤُنذْقمْ نْومْ.‘ “
\v 10 \add أَمْ\add* إِسِّيوڒْ هَارُونْ أَكْ-ذ ثْمسْمُونْثْ ن أَيْثْ ن إِسْرَائِيل مَارَّا، ثُوغَا خزَّارنْ غَارْ ڒخْڒَا ؤُشَا خْزَارْ، أَعُودْجِي ن سِيذِي إِضْهَارْ-د ذڭْ ؤُسيْنُو. \x ◘ \xo 16:‏10 \xt ؤُف. 13‏:‏21\x*
\m 
\v 11 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:
\m 
\v 12 ”نشّْ سْڒِيغْ إِ ؤُنذْقمْ ن أَيْثْ ن إِسْرَائِيل. سِيوڒْ أَكِيذْسنْ ؤُشَا إِنِي: جَارْ بدُّو ن وزْينْ ن وَاسّْ أَڒْ د-ثوْضَا ثْمذِّيثْ أَذْ ثشّمْ \bd أَيْسُومْ\bd*، غَارْ صّْبحْ أَذْ ثجِّيوْنمْ س \bd وغْرُومْ\bd* ؤُشَا أَذْ ثسّْنمْ بلِّي نشّْ ذ سِيذِي، أَربِّي نْومْ.“ \x ◘ \xo 16:‏12 \xt يُوح. 6‏:‏49،58\x*
\m 
\v 13 غَارْ ؤُعشِّي ؤُڒْينْثْ إِ-د إِجْضَاضْ قَّارنْ أَسْ ’ثْسَالْوَا‘ ؤُشَا ذْڒِينْثْ ڒْمَارْڭحْ ن ڒْعسْكَارْ ؤُ غَارْ صّْبحْ ثُوغَا نّْذَا إِنّضْ-د إِ ڒْمَارْڭحْ. \x ◘ \xo 16:‏13 \xt ڒخْڒ. 11‏:‏31؛ إِزهد. 105‏:‏40\x*
\v 14 ڒَامِي د-إِڭعّذْ نّْذَا، أَقَا ذَا، إِشْثْ ن ڒْحَاجّثْ ذ ثَازْذَاثْ أَمْ ثقْشُورْثْ، ذ ثَازْذَاثْ أَمْ نّْذَا إِڭَارْسنْ، \add ثتّْوَافْ\add* خْ وُوذمْ ن ڒخْڒَا، خْ ثمُّورْثْ. \x ◘ \xo 16:‏14 \xt ڒخْڒ. 11‏:‏7؛ نَاح. 9‏:‏15؛ إِزهد. 78‏:‏24؛ 105‏:‏40\x*
\v 15 ژْرِينْ ت أَيْثْ ن إِسْرَائِيل، نَّانْ إِجّنْ إِ ونّغْنِي: ”مَانَاوْيَا؟“، مِينْزِي وَارْ سِّيننْ مِينْ إِعْنَا. \add ڒخْذنِّي\add* إِنَّا أَسنْ مُوسَا: ”وَا ذ أَغْرُومْ نِّي ذ أَومْ إِوْشَا سِيذِي، حِيمَا أَذْ ثشّمْ. \x ◘ \xo 16:‏15 \xt يُوح. 6‏:‏31؛ 1 كُور. 10‏:‏3\x*
\v 16 وَا ذ أَوَاڒْ إِ \add ذ أَومْ\add* يُومُورْ سِيذِي: ’أجّْ أَذْ زَّايسْ إِكْسِي كُوڒْ إِجّْ عْلَاحْسَابْ مِينْ إِحْذَاجْ، \add ڒقْيَاسْ ن\add* إِجّْ ن ؤُعُومِيرْ، \add عْڒَاحَاڒْ ثْنَاينْ لِيثْرُو\add*، إِ \add إِجّنْ\add* بْنَاذمْ. \add كُوڒْ\add* أَرْيَازْ أَذْ إِكْسِي عْلَاحْسَابْ ڒْقدّْ ن إِوْذَانْ إِ غَارسْ ذڭْ ؤُقِيضُونْ.‘ “ \f ◼ \fr 16:‏16 \ft \bd ’أَعُومِيرْ‘\bd* - (ڒقْيَاسْ ن) يِيجّْ ن ’ؤُعُومِيرْ‘ ذ ثَاعشَّارْثْ ن يِيجّْ ن ’إِفَا‘. خْزَارْ ؤُف. 16:36\f*
\v 17 ؤُشَا أَمُّو إِ ڭِّينْ أَيْثْ ن إِسْرَائِيل. يْرُونْ \add زَّايسْ\add*، \add إِجّنْ\add* أَطَّاسْ، \add ونّغْنِي\add* ذْرُوسْ.
\v 18 وزْننْ أَيَا س \add ڒقْيَاسْ ن\add* ؤُعُومِيرْ. ونِّي يْرُونْ أَطَّاسْ وَارْ غَارسْ زّْيَاذَا ذ ونِّي يْرُونْ ذْرُوسْ، وَارْ ذ أَسْ إِتّْخصِّي عَاذْ. كُوڒْ إِجّْ إِيْرُو مَاشَّا نّسْ عْلَاحْسَابْ مِينْ إِحْذَاجْ. \x ◘ \xo 16:‏18 \xt 2 كُور. 8‏:‏15\x*
\v 19 إِنَّا أَسنْ مُوسَا: ”ؤُڒَا ذ إِجّْ أَذْ زَّايسْ يجّْ أَڒْ صّْبحْ.“
\v 20 \add مَاشَا\add* نِيثْنِي وَارْ سْڒِينْ شَا إِ مُوسَا ؤُ شَا ن يرْيَازنْ خمّْڒنْ \add شَا\add* زَّايسْ أَڒْ صّْبحْ. \add خنِّي\add* ؤُذْفنْ ذَايسْ إِكشَّاونْ ؤُشَا إِبْذَا أَذْ إِڭّْ شُّومْ. ؤُشَا إِفُّوڭمْ خَاسنْ مُوسَا أَطَّاسْ.
\m 
\v 21 كُوڒْ صّْبحْ يْرُونْ ث، كُوڒْ إِجّْ عْلَاحْسَابْ إِزمَّارْ أَذْ إِشّْ نتَّا، مِينْزِي مَاڒَا ثحْمَا ثْفُوشْثْ، ثُوغَا إِتّْفسِّي.
\m 
\v 22 ذڭْ وَاسّْ وِيسّْ ستَّا يْرُونْ ثْنَاينْ ن ثْسقَّارْ ن وغْرُومْ، \add ڒقْيَاسْ ن\add* ثْنَاينْ ن إِعُومِيرنْ إِ كُوڒْ أَزدْجِيفْ. ؤُشَا ؤُسِينْ-د مَارَّا ڒْحُوكَّامْ ن ثْمسْمُونْثْ ؤُشَا خبَّارنْ مُوسَا.
\v 23 نتَّا إِنَّا أَسنْ: ”ذ مَانْ أَيَا مِينْ خفْ إِسِّيوڒْ سِيذِي: ’ثِيوشَّا ذ إِجّْ ن \add وَاسّْ ن\add* أَرَّاحثْ، إِجّْ \add ن وَاسّْ\add* ن سّبْثْ ذ أَمْقدَّاسْ إِ سِيذِي. سنْڭْومْ مِينْ ثخْسمْ أَذْ ثسّنْڭْومْ، سْننَّامْ مِينْ ثخْسمْ أَذْ ثسّنَّامْ ؤُشَا مَارَّا مِينْ غَا إِقِّيمنْ، خمّْڒمْ ث أَڒْ صّْبحْ.‘ “
\v 24 نِيثْنِي خمّْڒنْ ث أَڒْ صّْبحْ أَمْ مَامّشْ ثنْ يُومُورْ مُوسَا ؤُشَا وَارْ يَارْصُوضْ ؤُ وَارْ ذَايسْ ثُوغِي ثْكشَّا.
\v 25 \add خنِّي\add* إِنَّا مُوسَا: ”شّمْ أَيَا أَسّْ-أَ، مِينْزِي أَسّْ-أَ ذ أَسّْ ن سّبْثْ ن سِيذِي. أَسّْ-أَ وَارْ ث ثتِّيفمْ ذڭْ إِيَّارْ.
\v 26 ستَّا ن وُوسَّانْ أَذْ ثيْرُومْ، مَاشَا ذڭْ وَاسّْ وِيسّْ سبْعَا أَقَا ذ سّبْثْ، وَارْ إِتِّيڒِي وَالُو.“
\m 
\v 27 ذڭْ وَاسّْ وِيسّْ سبْعَا إِمْسَارْ بلِّي فّْغنْ شَا زِي ڒْڭنْسْ، مَاحنْذْ أَذْ يْرُونْ \add شَا\add*، مَاشَا وَارْ ؤُفِينْ وَالُو.
\v 28 إِنَّا سِيذِي إِ مُوسَا: ”أَڒْ مڒْمِي ثُوڭِيمْ أَذْ ثحْضَامْ ڒُومُورَاثْ إِنُو ذ إِزرْفَانْ إِنُو؟
\v 29 خْزَارمْ، مِينْزِي سِيذِي إِوْشَا أَومْ \add أَسّْ ن\add* سّبْثْ، خْ ؤُيَا إِوْشَا أَومْ ذڭْ وَاسّْ وِيسّْ ستَّا أَغْرُومْ إِ ثْنَاينْ ن وُوسَّانْ. كُوڒْ إِجّْ زَّايْومْ أَذْ إِقِّيمْ ذڭْ ومْشَانْ نّسْ! ذڭْ وَاسّْ وِيسّْ سبْعَا وَارْ د-إِتّفِّيغْ ؤُڒَا ذ إِجّْ زڭْ ومْشَانْ نّسْ!“
\v 30 ؤُشَا يَاريّحْ ڒْڭنْسْ ذڭْ وَاسّْ ن سّبْثْ.
\m 
\v 31 ثَادَّارْثْ ن إِسْرَائِيل ثْڒَاغَا أَسْ ’مَانَّا‘. ثُوغَا-ت ذ ثَاشمْڒَاڒْثْ أَمْ زَّارِيعثْ ن ڒْقصْبُورْ ؤُشَا أَڒذِّي نّسْ أَمشْنَاوْ ثِيفْضِيرِينْ ن ثَامّنْثْ. \x ◘ \xo 16:‏31 \xt ڒخْڒ. 11‏:‏7\x*
\v 32 \add خنِّي\add* إِنَّا مُوسَا: ”دّڭَّا ذ أَوَاڒْ إِ زِي يُومُورْ سِيذِي: ’شُّورمْ زَّايسْ \add ڒقْيَاسْ ن\add* يِيجّْ ن ؤُعُومِيرْ ؤُشَا خمّڒْ إِ-ث إِ \add مَارَّا\add* جِّيڒَاثْ نْومْ \add إِ د غَا يَاسنْ\add*، حِيمَا أَذْ ژَترنْ أَغْرُومْ مِينْ زِي كنِّيوْ سّشّغْ ذِي ڒخْڒَا، ؤُمِي كنِّيوْ سُّوفّْغغْ زِي ثمُّورْثْ ن مِيصْرَا.“
\v 33 إِنَّا مُوسَا إِ هَارُونْ: ”كْسِي إِجّْ ن ؤُزنْبِيڒْ ؤُشَاعمَّارْ إِ-ث س يِيجّْ ن ؤُعُومِيرْ ن ’مَانَّا‘ ؤُشَا أڭّْ إِ-ث زَّاثْ إِ وُوذمْ ن سِيذِي، حِيمَا أَذْ إِتّْوَاخمّڒ إِ \add مَارَّا\add* جِّيڒَاثْ نْومْ.“\x ◘ \xo 16:‏33 \xt عبر. 9‏:‏4\x*
\v 34 ؤُشَا إِڭَّا إِ-ت هَارُونْ زَّاثْ إِ شّْهَاذثْ، حِيمَا أَذْ ثتّْوَاخمّڒْ أَمْ مَامّشْ ذ أَسْ يُومُورْ سِيذِي إِ مُوسَا.
\v 35 أَمُّو إِ شِّينْ أَيْثْ ن إِسْرَائِيل ’مَانَّا‘ أَربْعِينْ ن إِسڭّْوُوسَا، أَڒَامِي إِوْضنْ غَارْ ثمُّورْثْ مَانِي غَا رَاحنْ أَذْ زذْغنْ. شِّينْ مَانَّا أَڒَامِي إِوْضنْ غَارْ ويْمِيرْ ن ثمُّورْثْ ن كنْعَانْ. \x ◘ \xo 16:‏35 \xt ياش. 5‏:‏12؛ نَاح. 9‏:‏15\x*
\v 36 إِجّْ ن ؤُعُومِيرْ ذعشْرَا ذِي ثسْغَارْثْ ن إِجّْ ن إِفَا. \f ◼ \fr 16:‏36 \ft \bd ’إِجّْ ن ؤُعُومِيرْ‘\bd* - خْزَارْ ؤُفُوغْ 16:16. \bd ’إِجّْ ن إِفَا‘\bd* - عْڒَاينْ 22 لِيثْرُو. أَقَا-ث ذ إِجّْ ن ڒقْيَاسْ ن إِمنْذِي ذ إِرْذنْ. أَبَاثُو ؤُڒَا ذ إِجّْ ن ڒقْيَاسْ ن 22 لِيثْرُو مَاشَا إِ وَامَانْ ذ بِينُو ذ زّشْثْ. أَقَا ذِينْ إِنِّي قَّارنْ بلِّي إِجّْ ن إِفَا كْثَارْ زِي 22 لِيثْرُو، أَذْ ثَاغْ 35 لِيثْرُو نِيغْ كْثَارْ. إِجّْ ن إِفَا ذعشْرَا ذِي ثسْغَارْثْ ن يِيجّْ ن ؤُهُومِيرْ ؤُشَا أَهُومِيرْ ذَايسْ 220 لِيثْرُو.\f*
\b
\b
\c 17
\s1 مَاسَّا ذ مَارِيبَا
\m 
\v 1 ؤُشَا فسْينْ مَارَّا ثَامسْمُونْثْ ن أَيْثْ ن إِسْرَائِيل إِقِيضَانْ نْسنْ، \add ؤُيُورنْ\add* زِي ڒخْڒَا ن سِينْ، أَمْ مَامّشْ ذ أَسنْ يُومُورْ سِيذِي ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ ذِي رَافِيذِيمْ. وَارْ ذِينْ ثُوغِي أَمَانْ، حِيمَا أَذْ إِسُّو ڒْڭنْسْ.
\v 2 \add خنِّي\add* إِمْشُوبّشْ ڒْڭنْسْ أَكْ-ذ مُوسَا، نِيثْنِي نَّانْ: ”أوْشْ أَنغْ أَمَانْ، حِيمَا أَذْ نْسُو!“ مُوسَا إِنَّا أَسنْ: ”مَايمِّي ثتّخْسمْ أَذْ كِيذِي ثمْشُوبُّوشمْ؟ مَايمِّي ثتّْقدْجَابمْ سِيذِي؟“ \x ◘ \xo 17:‏2 \xt ڒخْڒ. 20‏:‏3، 4\x*
\v 3 ثُوغَا ڒْڭنْسْ إِفُّوذْ أَطَّاسْ غَارْ وَامَانْ ؤُشَا نّْذقْمنْ زِي مُوسَا، نَّانْ: ”مَاغَارْ ذ أَنغْ ثسّْڭعّْذذْ زِي مِيصْرَا؟ مَا حِيمَا أَذْ أَيِي ثْهلّْكذْ س ؤُفَاذِي ؤُڒَا ذ ثَارْوَا إِنُو ذ ڒبْهَايمْ إِنُو؟“
\v 4 \add ڒخْذنِّي\add* إِسْغُويْ مُوسَا غَارْ سِيذِي، إِنَّا: ”مِينْ غَا ڭّغْ أَكْ-ذ ڒْڭنْسْ-أَ؟ مْغِيرْ شْوَايْثْ ؤُشَا أَذْ أَيِي أَرجْمنْ.“
\v 5 إِنَّا سِيذِي إِ مُوسَا: ”أكّْ زَّاثْ إِ ڒْڭنْسْ ؤُشَا كْسِي أَكِيذكْ شَا زڭْ إِمْغَارنْ ن إِسْرَائِيل ؤُشَا كْسِي عَاوذْ ذڭْ ؤُفُوسْ نّشْ ثَاغَّارْشْثْ نِّي زِي ثوْثِيذْ إِغْزَارْ ؤُشَا رُوحْ. \x ◘ \xo 17:‏5 \xt ؤُف. 7‏:‏20\x*
\v 6 خْزَارْ، نشّْ أَذْ بدّغْ ذِينْ زَّاثكْ خْ ثصْضَارْثْ غَارْ حُورِيبْ، أَذْ ثوْثذْ ثَاصْضَارْثْ، أَذْ زَّايسْ د-فّْغنْ وَامَانْ ؤُشَا أَذْ إِسُّو ڒْڭنْسْ.“ إِڭَّا مُوسَا أَمنِّي زَّاثْ إِ ثِيطَّاوِينْ ن إِمْغَارنْ ن إِسْرَائِيل. \x ◘ \xo 17:‏6 \xt ڒخْڒ. 20‏:‏9؛ إِزهد. 78‏:‏15؛ 114‏:‏8؛ 1 كُور. 10‏:‏4\x*
\v 7 ؤُشَا إِڒَاغَا إِسمْ ن ومْشَانْ نِّي مَاسَّا ذ مَارِيبَا، مِينْزِي أَيْثْ ن إِسْرَائِيل مّْشُوبّْشنْ \add ذِينْ\add* ؤُ مِينْزِي نِيثْنِي قدْجْبنْ سِيذِي، نَّانْ: ”مَا سِيذِي أَقَا-ث ڒخُّو ذِي ڒْوسْطْ نّغْ نِيغْ لَّا؟“
\b
\s1 أَمنْغِي أَكْ-ذ أَمَالِيكْ
\m 
\v 8 \add خنِّي\add* يُوسَا-د عَامَالِيقْ ؤُشَا إِمّْنغْ أَكْ-ذ إِسْرَائِيل ذِي رَافِيذِيمْ. \x ◘ \xo 17:‏8 \xt أَعَوذ. 25‏:‏17، 18\x*
\v 9 إِنَّا مُوسَا إِ يَاشُووَا: ”أجّْ أَنغْ أَذْ نِيخْضَارْ إِرْيَازنْ ؤُشَا أَذْ نفّغْ، مَاحنْذْ أَذْ نمّْنغْ أَكْ-ذ عَامَالِيقْ. ثِيوشَّا أَذْ بدّغْ سنّجْ خْ ثْقِيشَّاثْ ن ثوْرِيرْثْ ؤُشَا ثَاغَّارْشْثْ ن أَربِّي أَذْ ثِيڒِي ذڭْ ؤُفُوسْ إِنُو.“
\v 10 إِڭَّا يَاشُووَا أَمْ مَامّشْ ذ أَسْ إِنَّا مُوسَا، إِمّْنغْ أَكْ-ذ عَامَالِيقْ، مَاشَا مُوسَا ذ هَارُونْ ذ حُورْ ؤُڒْينْ غَارْ ثْقِيشَّاثْ ن ثوْرِيرْثْ.
\v 11 ؤُشَا إِمْسَارْ ڒَامِي إِسّْڭعّذْ مُوسَا أَفُوسْ نّسْ، \add ڒخْذنِّي\add* ثُوغَا إِسْرَائِيل ثْغدْجبْ، مَاشَا خْمِي إِتّجَّا أَفُوسْ نّسْ أَذْ إِهْوَا، \add ڒخْذنِّي\add*غدْجْبنْ \add أَيْثْ ن\add* عَامَالِيقْ.
\v 12 إِفَاسّنْ ن مُوسَا ذوْڒنْ دّقْڒنْ. \add خنِّي\add* كْسِينْ إِجّْ ن وژْرُو ؤُشَا ڭِّينْ ث سَاذُو مُوسَا ؤُشَا إِقِّيمْ خَاسْ ؤُشَا هَارُونْ ذ حُورْ سنّْذنْ إِفَاسّنْ نّسْ، إِجّْ زڭْ ؤُغزْذِيسْ-أَ، ونّغْنِي زڭْ \add ؤُغزْذِيسْ\add* نّغْنِي. أَمُّو إِ إِقِّيمنْ إِفَاسّنْ نّسْ ڭعّْذنْ أَڒَامِي ثغْڒِي ثْفُوشْثْ.
\v 13 ؤُشَا إِغْڒبْ يَاشُووَا خْ عَامَالِيقْ ذ ڒْڭنْسْ نّسْ س ڒقْضعْ ن سِّيفْ. \f ◼ \fr 17:‏13 \ft \bd ’س ڒقْضعْ‘\bd* - س ثْعِيبْرَانِيثْ ’س ؤُقمُّومْ‘.\f*
\v 14 \add خنِّي\add* إِنَّا سِيذِي إِ مُوسَا: ”أَرِي أَيَا ذڭْ إِجّْ ن وذْلِيسْ إِتّْوَانّْضنْ إِ ڒِيذَارثْ \add ذَايسْ\add* ؤُشَا أڭّْ إِ-ث ذڭْ إِمجَّانْ ن يَاشُووَا، بلِّي أَقَا نشّْ أَذْ مْحِيغْ قَاعْ ڒِيذَارثْ ذِي عَامَالِيقْ سَاذُو ؤُجنَّا.“ \x ◘ \xo 17:‏14 \xt ڒخْڒ. 24‏:‏20؛ أَعَوذ. 25‏:‏17، 18، 19؛ 1 صم. 15‏:‏2، 3\x*
\v 15 إِبْنَا مُوسَا إِجّْ ن ؤُعَالْطَارْ ؤُشَا إِڒَاغَا أَسْ س يِيسمْ: ”سِيذِي ذ ثَاعدْجَانْثْ إِنُو!“
\v 16 ؤُشَا إِنَّا: ”أَفُوسْ ثُوغَا خْ ڒْعَارْشْ ن سِيذِي. سِيذِي أَذْ يڭّْ ڭَارَّا خْ عَامَالِيقْ زِي جِّيڒْ أَڒْ جِّيڒْ.“ \x ◘ \xo 17:‏16 \xt 1 صم. 15‏:‏2\x*
\b
\b
\c 18
\s1 أَرْزفْ ن يِيثْرُونْ
\m 
\v 1 إِسْڒَا يِيثْرُونْ، أَكهَّانْ ن مِيذْيَانْ، أَضڭّْوَاڒْ ن مُوسَا، مَارَّا مِينْ إِڭَّا أَربِّي أَكْ-ذ مُوسَا ؤُ أَكْ-ذ ڒْڭنْسْ نّسْ إِسْرَائِيل، أَقَا إِسُّوفّغْ-د سِيذِي إِسْرَائِيل زِي مِيصْرَا. \x ◘ \xo 18:‏1 \xt ؤُف. 2‏:‏16؛ 3‏:‏1\x*
\v 2 إِطّفْ يِيثْرُونْ، أَضڭّْوَاڒْ ن مُوسَا، صَافُّورَا، ثَامْغَارْثْ ن مُوسَا، أَوَارْنِي ڒَامِي ذ أَسْ إِوْشَا ثِيرْزِيفِينْ نّسْ ن ثسْڒِيثْ،
\v 3 ؤُڒَا ذ ثْنَاينْ ن إِحنْجِيرنْ نّسْ، إِجّنْ قَّارنْ أَسْ جَارْشُومْ، مِينْزِي ثُوغَا إِنَّا: ”ثُوغَا أَيِي ذ أَبَارَّانِي ذِي ثمُّورْثْ ذ ثَابَارَّانشْثْ!“، \x ◘ \xo 18:‏3 \xt ؤُف. 2‏:‏22\x*
\v 4 ؤُ ونّغْنِي قَّارنْ أَسْ أَلِيعَازِيرْ، \add مِينْزِي ثُوغَا إِنَّا:\add* ”أَربِّي ن بَابَا إِعَاونْ أَيِي ؤُشَا إِفكّْ أَيِي زِي سِّيفْ ن فِيرْعُونْ.“
\v 5 يِيثْرُونْ أَضڭّْوَاڒْ ن مُوسَا، أَكْ-ذ إِحنْجِيرنْ نّسْ ذ ثْمطُّوثْ نّسْ، إِوْضنْ غَارْ مُوسَا ذِي ڒخْڒَا، غَارْ مَانِي إِوْثَا إِقِيضَانْ، غَارْ وذْرَارْ ن أَربِّي.
\v 6 ؤُشَا نتَّا إِجَّا أَذْ إِنِينْ إِ مُوسَا: ”نشّْ، أَضڭّْوَاڒْ نّشْ يِيثْرُونْ، ؤُسِيغْ-د غَاركْ س ثمْغَارْثْ نّشْ ذ ثْنَاينْ ن إِحنْجِيرنْ نّسْ أَكِيذسْ.“
\v 7 \add خنِّي\add* إِفّغْ مُوسَا أَذْ إِڒْقَا أَضڭّْوَاڒْ نّسْ، إِبنْذقْ ؤُشَا إِسُّوذمْ إِ-ث. إِجّنْ إِسّقْسَا ونّغْنِي خْ ؤُمدُّورْ نّسْ ؤُشَا ؤُذْفنْ غَارْ ؤُقِيضُونْ.
\v 8 مُوسَا إِحَاجَا إِ ؤُضڭّْوَاڒْ نّسْ مَارَّا مِينْ إِڭَّا سِيذِي أَكْ-ذ فِيرْعُونْ ؤُ أَكْ-ذ إِمِيصْرِييّنْ ذِي طّْوعْ ن إِسْرَائِيل ؤُ خْ مَارَّا ثَامَارَا نِّي خَاسنْ إِكِّينْ ذڭْ وبْرِيذْ ذ مَامّشْ ثنْ إِفكّْ سِيذِي.
\v 9 إِفَارْحْ يِيثْرُونْ زِي مَارَّا ڒْخِيرْ نِّي إِڭَّا سِيذِي إِ إِسْرَائِيل، ؤُمِي ث إِفكّْ زڭْ ؤُفُوسْ ن إِمِيصْرِييّنْ.
\v 10 إِنَّا يِيثْرُونْ: ”أَذْ إِتّْوَابَاركْ سِيذِي ذ ونِّي كنِّيوْ إِفكّنْ زڭْ ؤُفُوسْ ن إِمِيصْرِييّنْ ؤُ زڭْ ؤُفُوسْ ن فِيرْعُونْ، ذ ونِّي إِفكّنْ ڒْڭنْسْ زڭْ ؤُفُوسْ ن إِمِيصْرِييّنْ!
\v 11 ڒخُّو سّْنغْ بلِّي سِيذِي إِمْغَارْ أَطَّاسْ خْ مَارَّا إِربِّيثنْ، أَقَا ذِي ثْمسْڒَاشْثْ نِّي ذسَّارنْ خَاسنْ.“ \x ◘ \xo 18:‏11 \xt ؤُف. 1‏:‏10، 16، 22؛ 5‏:‏7؛ 14‏:‏18\x*
\v 12 \add خنِّي\add* إِكْسِي يِيثْرُونْ، أَضڭّْوَاڒْ ن مُوسَا، ثَاغَارْصْثْ ن وشْمَاضْ ذ ثِيغَارْصَا إِ أَربِّي ؤُشَا يُوسَا-د هَارُونْ جْمِيعْ أَكْ-ذ مَارَّا إِمْغَارنْ ن أَيْثْ ن إِسْرَائِيل، مَاحنْذْ أَذْ يشّْ أَغْرُومْ \add جْمِيعْ\add* أَكْ-ذ ؤُضڭّْوَاڒْ ن مُوسَا زَّاثْ إِ وُوذمْ ن أَربِّي.
\b
\m 
\v 13 ثِيوشَّا نّسْ ثُوغَا مُوسَا إِتّْغِيمَا \add خْ ڒْكُورْسِي\add*، مَاحنْذْ أَذْ إِحْكمْ ڒْڭنْسْ. ثُوغَا ڒْڭنْسْ إِبدّْ زَّاثْ إِ مُوسَا زِي صّْبحْ \add زِيشْ\add* أَڒْ دْجِيڒثْ.
\v 14 إِژْرَا ؤُضڭّْوَاڒْ ن مُوسَا مَارَّا مِينْ ثُوغَا إِتّڭّْ \add مُوسَا\add* إِ ڒْڭنْسْ، إِنَّا: ”مَانَاوَايَا إِ ثڭِّيذْ شكْ إِ ڒْڭنْسْ؟ مَايمِّي ثتّْغِيمِيذْ شكْ وحّْذكْ ؤُ مَارَّا ڒْڭنْسْ إِبدّْ زَّاثكْ زِي ضّْبحْ \add زِيشْ\add* أَڒْ دْجِيڒثْ؟“
\v 15 يَارَّا-د مُوسَا خْ ؤُضڭّْوَاڒْ نّسْ: ”مِينْزِي ڒْڭنْسْ إِتَّاسْ-د غَارِي حِيمَا أَذْ إِتَّارْ \add شّْوَارْ\add* ن أَربِّي.
\v 16 خْ مِينِّي غَارْسنْ ثتِّيڒِي شَا ن ثْمسْڒَاشْثْ، تَّاسنْ-د غَارِي \add س مَانْ أَيَا\add* ؤُشَا نشّْ أَذْ شَارّْعغْ جَارْ إِجّْ ذ ونّغْنِي، سّشَانغْ أَسنْ ثِيوصَّا ذ إِزرْفَانْ ن أَربِّي.“
\v 17 \add ڒخْذنِّي\add* إِنَّا أَسْ ؤُضڭّْوَاڒْ ن مُوسَا: ”مِينْ ثڭِّيذْ وَارْ إِدْجِي شَا مْلِيحْ.
\v 18 أَمُّو إِ غَا ثَاحْڒذْ أَطَّاسْ، شكْ ذ ڒْڭنْسْ-أَ إِ كِيكْ إِدْجَانْ، مِينْزِي مَانْ أَيَا إِذْقڒْ خَاكْ أَطَّاسْ، وَارْ ذ أَسْ ثْزمَّارذْ أَذْ ث ثڭّذْ وحّْذكْ.
\v 19 سڒْ ڒخُّو إِ وَاوَاڒْ إِنُو، نشّْ أَذْ شكْ نصْحغْ ؤُشَا أَربِّي أَذْ كِيكْ يِيڒِي. إِڒِي شكْ ذ أَوصَّايْ خْ ڒْڭنْسْ زَّاثْ إِ أَربِّي ؤُشَا قدّمْ دّْعَاوِي زَّاثْ إِ أَربِّي.
\v 20 سْشنْ أَسنْ ثِيوصَّا ذ إِزرْفَانْ ؤُشَا سْشنْ أَسنْ أَبْرِيذْ إِ ثنْ إِتّْخصَّانْ أَذْ ؤُيُورنْ ؤُ ڒْخذْمثْ إِ ذ أَسنْ إِتّْخصَّانْ أَذْ ت ڭّنْ.
\v 21 عَاوذْ خْزَارْ شكْ، أَذْ ثَارْزُوذْ جَارْ مَارَّا ڒْڭنْسْ خْ إِرْيَازنْ إِزعَّامنْ، إِنِّي إِتّڭّْوذنْ أَربِّي، إِرْيَازنْ إِصْذِيقنْ، إِنِّي إِشَارّْهنْ ثَارزُّوثْ خْ أَرْبحْ. أڭّْ إِ-ثنْ ذ إِمقّْرَاننْ خْ وَاڒفْ، ذ إِمقّْرَاننْ خْ مْيَا، ذ إِمقّْرَاننْ خْ خمْسِينْ ذ إِمقّْرَاننْ خْعشْرَا.
\v 22 أجّْ إِ-ثنْ أَذْ شَارّْعنْ جَارْ ڒْڭنْسْ ڒبْذَا. أجّْ إِ-ثنْ أَذْ قدّْمنْ مَارَّا دّْعَاوِي إِوْعَارنْ زَّاثكْ، \add مَاشَا\add* مَارَّا دّْعَاوِي ثِيمژْيَانِينْ أَذْ خَاسنْثْ شَارّْعنْ س يِيخفْ نْسنْ. أڭّْ إِ-ث ثفْسُوسْ خْ يِيخفْ نّشْ ؤُشَا أجّْ إِ-ثنْ أَذْ ت أَرْبُونْ أَكِيذكْ.
\v 23 مَاڒَا ثڭِّيذْ أَيَا، ؤُ أَربِّي إِ شكْ يُومُورنْ، ثْزمَّارذْ أَذْ ثقِّيمذْ ثْبدّذْ ؤُشَا مَارَّا ڒْڭنْسْ أَيَا أَذْ يَاوضْ عَاوذْ ذِي ڒهْنَا غَارْ ومْشَانْ إِ ذ أَسنْ إِتّْوَاڭّْ.“
\m 
\v 24 إِسْڒَا مُوسَا غَارْ وَاوَاڒْ ن ؤُضڭّْوَاڒْ نّسْ، إِڭَّا مَارَّا مِينْ \add ذ أَسْ\add* إِنَّا. \x ◘ \xo 18:‏24 \xt أَعَوذ. 1‏:‏9\x*
\v 25 إِخْضَارْ مُوسَا إِرْيَازنْ إِزعَّامنْ زِي مَارَّا إِسْرَائِيل ؤُشَا إِڭَّا إِ-ثنْ ذ إِزدْجِيفنْ خْ ڒْڭنْسْ: إِمقّْرَاننْ خْ وَاڒفْ، إِمقّْرَاننْ خْ مْيَا، إِمقّْرَاننْ خْ خمْسِينْ ذ إِمقّْرَاننْ خْعشْرَا.
\v 26 ؤُشَا نِيثْنِي ثُوغَا تّْشَارّْعنْ ڒْڭنْسْ ڒبْذَا ؤُشَا دّْعَاوِي إِوْعَارنْ قذْمنْ ثنْثْ غَارْ مُوسَا، \add مَاشَا\add* مَارَّا دّْعَاوِي ثِيمژْيَانِينْ شَارّْعنْ ثنْثْ س يِيخفْ نْسنْ.
\v 27 إِقبّضْ مُوسَا أَضڭّْوَاڒْ نّسْ ؤُشَا إِعْقبْ نتَّا غَارْ ثمُّورْثْ نّسْ.
\b
\b
\c 19
\s1 سِيذِي خْ وذْرَارْ ن سِينَا
\m 
\v 1 ذڭْ ؤُيُورْ وِيسّْ ثْڒَاثَا أَوَارْنِي إِ وُوفُّوغْ ن أَيْثْ ن إِسْرَائِيل زِي ثمُّورْثْ ن مِيصْرَا، ذڭْ وَاسّْ نِّي نِّيثْ، إِوْضنْ-د غَارْ ڒخْڒَا ن سِينَا.
\v 2 أَقَا فسْينْ إِقِيضَانْ نْسنْ، \add ؤُيُورنْ\add* زِي رَافِيذِيمْ ؤُشَا إِوْضنْ غَارْ ڒخْڒَا ن سِينَا ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ ذِي ڒخْڒَا. إِوْثَا إِسْرَائِيل إِقِيضَانْ نّسْ قِيبَاتْشْ إِ وذْرَارْ.
\v 3 يُوڒِي مُوسَا غَارْ أَربِّي ؤُشَا إِڒَاغَا أَسْ-د سِيذِي زڭْ وذْرَارْ، إِنَّا أَسْ: ”أَمُّو إِ غَا ثسِّيوْڒذْ أَكْ-ذ ثَادَّارْثْ ن يَاعْقُوبْ ؤُ \add أَمُّو إِ\add* غَا ثِينِيذْ إِ أَيْثْ ن إِسْرَائِيل: \x ◘ \xo 19:‏3 \xt ڒخ. 7‏:‏38\x*
\v 4 ’كنِّيوْ ثژْرِيمْ مِينْ ڭِّيغْ أَكْ-ذ إِمِيصْرِييّنْ ؤُ \add مَامّشْ\add* كنِّيوْ كْسِيغْ خْ وَافْرِيونْ ن ؤُڭِيذرْ ؤُشَا إِوْيغْ-د كنِّيوْ غَارِي. \f ◼ \fr 19:‏4 \ft \bd ’أَڭِيذرْ‘\bd* - نِيغْ ’أَسِيوَانْ‘.\f*  \x ◘ \xo 19:‏4 \xt أَعَوذ. 29‏:‏1؛ 32‏:‏11\x*
\v 5 \add خنِّي\add* ڒخُّو، مَاڒَا ثسْڒِيمْ مْلِيحْ غَارْ وَاوَاڒْ إِنُو ؤُ أَذْ ثحْضَامْ ڒْعَاهْذْ إِنُو، أَذْ غَارِي ثِيڒِيمْ كنِّيوْ ثِيغْڒَامْ خْ مَارَّا ڒڭْنُوسْ، مِينْزِي مَارَّا ثَامُّورْثْ أَقَا-ت إِنُو. \x ◘ \xo 19:‏5 \xt أَعَوذ. 7‏:‏6؛ 10‏:‏14، 15؛ 14‏:‏2؛ 26‏:‏18؛ إِزهد. 135‏:‏4؛ إِشا. 41‏:‏8؛ ثِيث. 2‏:‏14\x*
\v 6 كنِّيوْ أَذْ أَيِي ثِيڒِيمْ ذ إِشْثْ ن ثْڭلْذِيثْ ن إِكهَّاننْ ذ إِجّْ ن ڒْڭنْسْ أَمْقدَّاسْ.‘ إِنَا ذ أَوَاڒنْ نِّي ذ أَشْ إِتّْخصَّانْ أَذْ ثنْ ثِينِيذْ إِ أَيْثْ ن إِسْرَائِيل.“ \x ◘ \xo 19:‏6 \xt 1 بُط. 2‏:‏9\x*
\m 
\v 7 إِهْوَا-د مُوسَا ؤُشَا إِڒَاغَا-د خْ إِمْغَارنْ ن ڒْڭنْسْ ؤُشَا إِبَارّحْ أَسنْ مَارَّا أَوَاڒنْ-أَ إِ ذ أَسْ يُومُورْ سِيذِي.
\v 8 ؤُشَا يَارَّا-د مَارَّا ڒْڭنْسْ، نَّانْ: ”مَارَّا مِينْ إِسِّيوڒْ سِيذِي، أَذْ ث نڭّْ!“ ؤُشَا إِسِّيوضْ مُوسَا أَوَاڒنْ ن ڒْڭنْسْ عَاوذْ إِ سِيذِي. \x ◘ \xo 19:‏8 \xt ؤُف. 24‏:‏3\x*
\m 
\v 9 إِنَّا سِيذِي إِ مُوسَا: ”خْزَارْ، نشّْ أَذْ غَاركْ د-أَسغْ ذڭْ إِجّْ ن ؤُسيْنُو ذ أَبَارْشَانْ، حِيمَا أَذْ إِسڒْ ڒْڭنْسْ خْمِي نشّْ كِيكْ غَا سِّيوْڒغْ ؤُشَا عَاوذْ أَذْ زَّايكْ أَمْننْ إِ ڒبْذَا.“ \add مِينْزِي\add* مُوسَا إِخبَّارْ أَوَاڒنْ ن سِيذِي إِ ڒْڭنْسْ.
\v 10 سِيذِي إِنَّا إِ مُوسَا: ”رُوحْ غَارْ ڒْڭنْسْ ؤُشَا سْقدّسْ إِ-ثنْ أَسّْ-أَ ذ ثِيوشَّا، أجّْ إِ-ثنْ أَذْ سِّيرْذنْ أَرُّوضْ نْسنْ
\v 11 ؤُشَا أَذْ إِڒِينْ وجْذنْ إِ وَاسّْ وِيسّْ ثْڒَاثَا، مِينْزِي ذڭْ وَاسّْ وِيسّْ ثْڒَاثَا أَذْ د-إِهْوَا سِيذِي غَارْ وذْرَارْ ن سِينَا زَّاثْ إِ ثِيطَّاوِينْ ن مَارَّا ڒْڭنْسْ.
\v 12 أڭّْ إِيْمِيرنْ إِ ڒْڭنْسْ ذڭْ ونّضْ ن وذْرَارْ، إِنِي: ’غَارْومْ، وَارْ ثِيڒْيمْ غَارْ وذْرَارْ نِيغْ أَذْ ثْحَاذَامْ طَّارْفْ نّسْ. مَانْ ونْ إِ غَا إِحَاذَانْ أَذْرَارْ، أَذْ إِتّْوَانغْ نِيشَانْ. \x ◘ \xo 19:‏12 \xt عبر. 12‏:‏18\x*
\v 13 وَارْ ث إِتّْحِيذِي \add حذْ س\add* ؤُفُوسْ، مِينْزِي \add خنِّي\add* أَذْ إِتّْوَارْجمْ نِيغْ أَذْ إِتّْوَاوّثْ نِيشَانْ \add س فْڒِيثْشَاثْ\add* مِينْ مَا إِعْنَا، ڒبْهِيمثْ نِيغْ ذ بْنَاذمْ، وَارْ إِتّْغِيمِي إِدَّارْ. مَاڒَا أَذْ ذِينْ يِيڒِي إِجّْ ن ؤُسُوضِي \add ذڭْ ؤُيِيشّْ ن ؤُسْڒِيوْڒوْ\add* ذ أَزِيرَارْ، زمَّارنْ نِيثْنِي أَذْ أَڒْينْ أَذْرَارْ.‘ “
\m 
\v 14 \add خنِّي\add* إِهْوَا-د مُوسَا زڭْ وذْرَارْ غَارْ ڒْڭنْسْ، إِسّْقدّسْ ڒْڭنْسْ ؤُشَا سِّيرْذنْ أَرُّوضْ نْسنْ.
\v 15 إِنَّا إِ ڒْڭنْسْ: ”إِڒِيمْ تّْوجْذمْ إِ وَاسّْ وِيسّْ ثْڒَاثَا، وَارْ د-تّْقَارَّابمْ غَارْ ثمْغَارْثْ.“ \x ◘ \xo 19:‏15 \xt 1 صم. 21‏:‏4؛ 1 كُور. 7‏:‏5\x*
\v 16 ذِي صّْبحْ ن وَاسّْ وِيسّْ ثْڒَاثَا ؤُسِينْ-د وَاجَّاجنْ ذ وَاسَّامنْ. أَقَا يَارْسَا إِجّْ ن ؤُسيْنُو إِدّقْڒنْ خْ وذْرَارْ ؤُ ڒْحسّْ \add ن ؤُسُوضِي\add* ذڭْ ؤُيِيشّْ ن إِشَارِّي إِذْوڒْ إِجْهذْ أَطَّاسْ. مَارَّا ڒْڭنْسْ ذِي ڒْمَارْڭحْ ن ڒْعسْكَارْ يَارْجِيجْ.\x ◘ \xo 19:‏16 \xt ؤُف. 20‏:‏18؛ عبر. 12‏:‏18؛ أَسَا. 4‏:‏5\x*
\v 17 مُوسَا إِنْذهْ ڒْڭنْسْ زِي ڒْمَارْڭحْ ن ڒْعسْكَارْ، مَاحنْذْ أَذْ إِڒْقَا أَربِّي ؤُشَا بدّنْ نِيثْنِي سْوَادَّايْ إِ وذْرَارْ. \x ◘ \xo 19:‏17 \xt أَعَوذ. 4‏:‏10، 11\x*
\v 18 مَارَّا أَذْرَارْ ن سِينَا إِدّخّنْ، مِينْزِي سِيذِي ثُوغَا إِهْوَا-د خَاسْ ذِي ثْمسِّي. دّخَّانْ نّسْ يُوڒِي-د أَمْ دّخَّانْ ن ؤُفَارَّانْ ؤُشَا مَارَّا أَذْرَارْ إِنْهزّْ أَطَّاسْ. \x ◘ \xo 19:‏18 \xt ڒقض. 5‏:‏4؛ إِزهد. 68‏:‏9؛ 114‏:‏4؛ حَاب. 3‏:‏10\x*
\v 19 أَمْ إِذْوڒْ ؤُسُوضِي ذڭْ ؤُيِيشّْ ن إِشَارِّي إِجْهذْ \add أَطَّاسْ\add*، إِسِّيوڒْ مُوسَا ؤُشَا يَارَّا-د خَاسْ أَربِّي س يِيجّْ ن ڒْحسّْ \add إِجْهذْ\add*.
\v 20 ؤُشَا إِهْوَا-د سِيذِي خْ وذْرَارْ ن سِينَا، خْ ثْقِيشّثْ ن وذْرَارْ، ؤُشَا إِڒَاغَا سِيذِي إِ مُوسَا غَارْ ثْقِيشّثْ ن وذْرَارْ. \add خنِّي\add* إِڭعّذْ مُوسَا.
\v 21 إِنَّا سِيذِي إِ مُوسَا: ”هْوَا-د، عْڒمْ إِ ڒْڭنْسْ، مَاحنْذْ وَارْ تّْشُوقِينْ ذِي سِيذِي، مَاحنْذْ أَذْ ث ژَترنْ ؤُشَا \add خنِّي\add* بَالَاكْ أَذْ تّْوَاهلّْكنْ أَطَّاسْ زَّايْسنْ.
\v 22 أجّْ عَاوذْ إِكهَّاننْ، إِنِّي إِ د غَا إِقَارّْبنْ غَارْ سِيذِي، أَذْ سّْقدّْسنْ إِخفْ نْسنْ، حِيمَا سِيذِي وَارْ خَاسنْ إِسعَّارْ شَا.“
\v 23 إِنَّا مُوسَا إِ سِيذِي: ”ڒْْڭنْسْ وَارْ إِزمَّارْ أَذْ إِڭعّذْ أَذْرَارْ ن سِينَا، مِينْزِي شكْ ثْعڒْمذْ أَنغْ ثنِّيذْ: ’أڭّْ إِيْمِيرنْ خْ وذْرَارْ ؤُشَا سْقدّسْ إِ-ث.‘ “
\v 24 إِنَّا أَسْ سِيذِي: ”رُوحْ، هْوَا! أَذْ ثْڭعّْذذْ شكْ ذ هَارُونْ أَكِيذكْ، \add مَاشَا\add* إِكهَّاننْ ذ ڒْڭنْسْ وَارْ زمَّارنْ أَذْ شُوقنْ، حِيمَا أَذْ ڭعّْذنْ غَارْ سِيذِي، حِيمَا نتَّا وَارْ خَاسنْ إِسعَّارْ شَا.“
\v 25 \add ڒخْذنِّي\add* إِهْوَا-د مُوسَا غَارْ ڒْڭنْسْ ؤُشَا إِنَّا أَسنْ \add مَارَّا\add* أَيَا.
\b
\b
\c 20
\s1 عشْرَا ن ثْوصَّا
\m 
\v 1 إِسِّيوڒْ أَربِّي مَارَّا أَوَاڒنْ-أَ، إِنَّا:
\m 
\v 2 \bd ”نشّْ ذ سِيذِي، أَربِّي نّشْ\bd*، ونِّي شكْ د-إِسُّوفّْغنْ زِي ثمُّورْثْ ن مِيصْرَا، زِي ثَادَّارْثْ ن ثسْمُوغِي. \x ◘ \xo 20:‏2 \xt ؤُف. 13‏:‏3؛ أَعَوذ. 5‏:‏6؛ إِزهد. 81‏:‏11\x*
\m 
\v 3 \bd وَارْ غَاركْ تِّيڒِينْ إِربِّيثنْ نّغْنِي\bd* زَّاثْ إِ وُوذمْ إِنُو.
\m 
\v 4 \bd وَارْ تّڭّْ إِ يِيخفْ نّشْ ڒخْيَاڒْ إِنقْشنْ\bd* نِيغْ شَا ن ڒْحَاجّثْ ثَارْوسْ ذِي مِينْ \add إِدْجَانْ\add* سنّجْ ذڭْ ؤُجنَّا نِيغْ ذِي شَا \add ذَا\add* سْوَادَّايْ ذِي ثمُّورْثْ نِيغْ ذِي شَا ذڭْ وَامَانْ \add إِ إِدْجَانْ\add* سَاذُو ثمُّورْثْ. \x ◘ \xo 20:‏4 \xt لَاوِي 26‏:‏1؛ إِزهد. 97‏:‏7\x*
\v 5 وَارْ ذ أَسنْ تّْبنْذِيقْ ؤُڒَا أَذْ خَاسنْ ثْسخَّارذْ، مِينْزِي نشّْ، سِيذِي، أَربِّي نّشْ، ذ إِجّْ ن أَربِّي إِتَّاسْمنْ، ونِّي د-يَارزْفنْ ڒْمُوعْصِييّثْ ن إِبَابَاثنْ ذِي ثَارْوَا أَڒْ \add جِّيڒْ\add* وِيسّْ ثْڒَاثَا ذ وِيسّْ أَربْعَا ن يِينِّي ذ أَيِي إِشَارّْهنْ،
\v 6 ذ ونِّي إِسّْشَاننْ ثَامخْسِيوْثْ نّسْ إِشوَّارنْ إِ ڒُوڒُوفْ ن يِينِّي ذ أَيِي إِتّخْسنْ ؤُ حطَّانْ ڒُومُورَاثْ إِنُو.
\m 
\v 7 \bd وَارْ نطّقْ س يِيسمْ ن سِيذِي، أَربِّي نّشْ، ذِي ڒْبَاطڒْ\bd*، مِينْزِي وَارْ إِتّْبَارِّي سِيذِي إِ ونِّي إِ غَا إِنطْقنْ س يِيسمْ نّسْ ذِي ڒْبَاطڒْ. \x ◘ \xo 20:‏7 \xt لَاوِي 9‏:‏12؛ إِزهد. 139‏:‏20؛ مت. 5‏:‏33؛ \x*
\m 
\v 8 \bd إِذَارْ أَسّْ ن سّبْثْ، حِيمَا أَذْ ث ثسّْقدّْسذْ.\bd* \x ◘ \xo 20:‏8 \xt حِز. 20‏:‏12\x*
\v 9 ستَّا ن وُوسَّانْ إِ غَا ثْخذْمذْ، أَذْ ثڭّذْ مَارَّا ڒْخذْمثْ نّشْ. \x ◘ \xo 20:‏9 \xt ؤُف. 23‏:‏12؛ 34‏:‏21؛ لك. 13‏:‏14\x*
\v 10 أَسّْ وِيسّْ سبْعَا ذ وَاسّْ ن سّبْثْ ن سِيذِي، أَربِّي نّشْ. وَارْ \add ذَايسْ\add* تّڭّْ ؤُڒَا ذ إِشْثْ ن ڒْخذْمثْ، شكْ لَّا، ؤُڒَا ذ مِّيشْ لَّا، ذ يدْجِيشْ لَّا، ذ إِسْمغْ نّشْ لَّا، ذ ثَايَّا نّشْ لَّا، ذ ڒبْهِيمثْ نّشْ لَّا، ؤُڒَا ذ أَبَارَّانِي نِّي أَكِيذكْ إِدْجَانْ ذَاخڒْ إِ ثوُّورَا نّشْ لَّا.
\v 11 مِينْزِي ذِي ستَّا ن وُوسَّانْ إِڭَّا سِيذِي إِجنْوَانْ ذ ثمُّورْثْ، ڒبْحَارْ ذ مَارَّا مِينْ ذَايسْ ؤُشَا يَاريّحْ ذڭْ وَاسّْ وِيسّْ سبْعَا. خْ ؤُيَا إِبَاركْ سِيذِي أَسّْ ن سّبْثْ ؤُشَا إِسّْقدّسْ إِ-ث. \x ◘ \xo 20:‏11 \xt أَمز. 2‏:‏2\x*
\m 
\v 12 \bd وقَّارْ بَابَاشْ ذ يمَّاشْ\bd*، مَاحنْذْ ؤُسَّانْ \add ن ثُوذَارْثْ\add* نّشْ \add زمَّارنْ\add* أَذْ زُّوڭَّارْثنْ ذِي ثمُّورْثْ إِ ذ أَشْ غَا يوْشْ سِيذِي، أَربِّي نّشْ. \x ◘ \xo 20:‏12 \xt مت. 15‏:‏4؛ أَفا. 6‏:‏2\x*
\m 
\v 13 \bd وَارْ نقّْ.\bd* \x ◘ \xo 20:‏13 \xt مت. 5‏:‏21\x*
\m 
\v 14 \bd وَارْ زنَّا.\bd* \x ◘ \xo 20:‏14 \xt مت. 5‏:‏27\x*
\m 
\v 15 \bd وَارْ تَّاشَارْ.\bd*
\m 
\v 16 \bd وَارْ شهّذْ س ژُورْ\bd* ضِيدّْ إِ جَّارْ نّشْ.
\m 
\v 17 \bd وَارْ مژْرِي ذِي شَا\bd*، ثَادَّارْثْ ن جَّارْ نّشْ \add وَارْ ذَايسْ مژْرِي\add*. وَارْ مژْرِي ذِي ثَامْغَارْثْ ن جَّارْ نّشْ، نِيغْ ذڭْ يِيسْمغْ نّسْ، نِيغْ ذِي ثَايَّا نّسْ، نِيغْ ذڭْ ؤُفُونَاسْ نّسْ، نِيغْ ذڭْ وغْيُوڒْ نّسْ ؤُڒَا ذڭْ إِشْثْ ن ڒْحَاجّثْ إِ إِدْجَانْ ن جَّارْ نّشْ.“ \x ◘ \xo 20:‏17 \xt رُوم. 7‏:‏7\x*
\b
\m 
\v 18 مَارَّا ڒْڭنْسْ إِژْرَا \add ؤُ إِسْڒَا\add* إِ وَاجَّاجنْ ذ وَاسَّامنْ ذ دّْرِيزْ ن ؤُسُوضِي ذڭْ ؤُيِيشّْ ن إِشَارِّي ذ وذْرَارْ إِدُّوخُّوننْ. \add ؤُمِي\add* إِژْرَا ڒْڭنْسْ مَانْ أَيَا، \add خنِّي\add* أَرْجِيجنْ ؤُشَا بعّْذنْ \add نِيثْنِي\add* غَارْ ڒَاڭّْوَاجْ. \x ◘ \xo 20:‏18 \xt ؤُف. 19‏:‏16؛ أَسَا. 4‏:‏5\x*
\v 19 نَّانْ إِ مُوسَا: ”سِيوڒْ شكْ أَكِيذْنغْ ؤُشَا أَذْ نْسڒْ. \add مَاشَا\add* إِتّْخصَّا أَربِّي وَارْ كِيذْنغْ إِسِّيوِيڒْ، حِيمَا وَارْ نتّْمتِّي!“ \x ◘ \xo 20:‏19 \xt أَعَوذ. 5‏:‏25؛ عبر. 12‏:‏19\x*
\v 20 إِنَّا مُوسَا إِ ڒْڭنْسْ: ”وَارْ ثڭّْوذمْ شَا، أَقَا يُوسَا-د أَربِّي، حِيمَا أَذْ كنِّيوْ إِقدْجبْ ؤُ حِيمَا أَذْ زَّايسْ ثڭّْوذمْ مَاحنْذْ وَارْ ثْخطِّيمْ شَا.“
\v 21 إِبدّْ ڒْڭنْسْ زِي ڒَاڭّْوَاجْ، مَاشَا مُوسَا إِقَارّبْ-د غَارْ ؤُسيْنُو إِبُّومْبْسنْ مَانِي \add ثُوغَا\add* أَربِّي. \x ◘ \xo 20:‏21 \xt ؤُف. 19‏:‏17؛ عبر. 12‏:‏18\x*
\m 
\v 22 إِنَّا سِيذِي إِ مُوسَا: ”أَمُّو إِتّْخصَّا أَذْ ثِينِيذْ إِ أَيْثْ ن إِسْرَائِيل: ’كنِّيوْ ثژْرِيمْ بلِّي سِّيوْڒغْ-د أَكِيذْومْ زڭْ ؤُجنَّا.
\v 23 وَارْ كِيذِي تّڭّمْ إِربِّيثنْ ن نُّوقَارْثْ ؤُ وَارْ تّڭّمْ إِربِّيثنْ ن وُورغْ إِ يِيخفْ نْومْ.
\v 24 \bd أڭّْ أَيِي إِجّْ ن ؤُعَالْطَارْ س ؤُشَاڒْ\bd*، قدّمْ خَاسْ ثِيغَارْصَا نّشْ ن وشْمَاضْ ذ ثِيغَارْصَا نّشْ ن ڒهْنَا، ؤُدْجِي نّشْ ذ إِفُونَاسنْ ذ ثْفُونَاسِينْ نّشْ. ذِي كُوڒْ أَمْشَانْ مَانِي غَا ڭّغْ ڒِيذَارثْ ن يِيسمْ إِنُو، أَذْ غَاركْ د-أَسغْ ؤُشَا أَذْ أَشْ بَارْكغْ. \x ◘ \xo 20:‏24 \xt ؤُف. 27‏:‏1؛ 38‏:‏1\x*
\v 25 مَاڒَا ثڭِّيذْ أَيِي إِجّْ ن ؤُعَالْطَارْ ن إِژْرَا، وَارْ ث ثْبنِّيذْ س ثْصُوضَارْ إِتّْوَاسُّويْذَانْ، مِينْزِي مَاڒَا ثدّْزذْ س ؤُڒيْزِيمْ نّشْ، \add إِڒِي\add* أَذْ ث ثسّْعِيدْجْثذْ. \x ◘ \xo 20:‏25 \xt أَعَوذ. 27‏:‏5؛ ياش. 8‏:‏30، 31\x*
\v 26 وَارْ تّْڭِيعِّيذْ غَارْ ؤُعَالْطَارْ إِنُو س يِيجّْ ن دّْرُوجْ، حِيمَا وَارْ إِتّْبِينْ ؤُسضْحِي نّشْ.“
\b
\b
\c 21
\s1 ثِيوصَّا زِي جِّيهثْ جَّارْ نّكْ
\m 
\v 1 ”ثِينَا \add إِ إِدْجَانْ\add* ذ لْفَارَايِيضْ نِّي ذ أَسنْ غَا ثسِّيوْضذْ.
\v 2 مَاڒَا ثسْغِيذْ إِسْمغْ ذ أَعِيبْرَانِي، \add خنِّي\add* نتَّا أَذْ أَشْ إِسخَّارْ ستَّا ن إِسڭّْوُوسَا، مَاشَا ذڭْ \add ؤُسڭّْوَاسْ\add* وِيسّْ سبْعَا أَذْ إِفّغْ ذ أَحُورِّي بَاطڒْ. \x ◘ \xo 21:‏2 \xt أَعَوذ. 15‏:‏12؛ إِرْم. 34‏:‏14\x*
\v 3 مَاڒَا يُوذفْ وحّْذسْ، وحّْذسْ إِ غَا إِفّغْ، مَاڒَا غَارسْ ثَامْغَارْثْ، أَذْ إِفّغْ نتَّا ذ ثمْغَارْثْ نّسْ.
\v 4 مَاڒَا سِيذِيسْ إِوْشَا أَسْ ثَامْغَارْثْ ؤُشَا نتَّاثْ ثجَّا أَسْ-د إِحنْجِيرنْ ذ ثْحنْجِيرِينْ، \add خنِّي\add* ثَامْغَارْثْ ذ ثَارْوَا نّسْ أَذْ إِڒِينْ ن سِيذِيسْ، ؤُ خنِّي نتَّا أَذْ إِفّغْ س إِمَانْ نّسْ.
\v 5 \add مَاشَا\add* مَاڒَا إِسْمغْ إِنَّا نِيشَانْ: ’نشّْ خْسغْ سِيذِي إِنُو ذ ثمْغَارْثْ إِنُو ذ ثَارْوَا إِنُو، وَارْ خْسغْ أَذْ فّْغغْ ذ أَحُورِّي!‘، \x ◘ \xo 21:‏5 \xt أَعَوذ. 15‏:‏16\x*
\v 6 \add ڒخْذنِّي\add* سِيذِيسْ أَذْ ث إِسّْبدّْ زَّاثْ إِ أَربِّي. أَذْ ث يَاوِي غَارْ ثوَّارْثْ نِيغْ غَارْ ثفْڒَاوْثْ \add غَارْ ؤُغزْذِيسْ ن ثوَّارْثْ\add* ؤُشَا سِيذِيسْ أَذْ أَسْ إِسّْنُوقّبْ أَمجِّينْ نّسْ س يِيشْثْ ن ثْسِينفْثْ ؤُشَا نتَّا أَذْ أَسْ إِسخَّارْ إِ ڒبْذَا. \x ◘ \xo 21:‏6 \xt أَعَوذ. 15‏:‏17\x*
\v 7 مَاڒَا إِزّنْزْ حذْ يدْجِيسْ ذ ثَايَّا، وَارْ إِتّفِّيغْ أَمْ مُوخَاسْ تّفّْغنْ إِسمْغَانْ.
\v 8 مَاڒَا وَارْ ثعْجِيبْ إِ ثِيطَّاوِينْ ن سِيذِيسْ ؤُ نتَّا ثُوغَا إِخْضبْ إِ-ت، أَذْ ت يجّْ أَذْ ثتّْوَافْذِي. وَارْ إِزمَّارْ أَذْ ت إِزّنْزْ إِ يِيجّْ ن ڒْڭنْسْ ن بَارَّا مِينْزِي نتَّا إِغْذَارْ زَّايسْ س \add مِينْ إِڭَّا\add*.
\v 9 مَاڒَا إِخْضبْ إِ-ت إِ مِّيسْ، أَذْ كِيذسْ يڭّْ عْلَاحْسَابْ لْفَارِيضَا زِي جّْهثْ ن يدْجِيسْ.
\v 10 مَاڒَا إِكْسِي \add ثَامْغَارْثْ\add* نّغْنِي إِ يِيخفْ نّسْ، وَارْ إِنقّصْ \add ڒْعُوتْشْ ن\add* ويْسُومْ نّسْ، نِيغْ أَرُّوضْ نّسْ، نِيغْ ڒْعَاشَارْثْ نّسْ.
\v 11 مَاڒَا نتَّا وَارْ ذ أَسْ إِڭِّي ثْڒَاثَا-يَا، \add خنِّي\add* نتَّاثْ أَذْ ثفّغْ بَاطڒْ، بْڒَا ڒخْرَاصْ.“
\b
\m 
\v 12 ”ونِّي إِ غَا إِوْثنْ حذْ أَڒْ غَا إِمّثْ، أَذْ ث نْغنْ نِيشَانْ. \x ◘ \xo 21:‏12 \xt لَاوِي 24‏:‏17\x*
\v 13 مَاڒَا وَارْ ث إِڭِّي نعْمَاذَا، \add مَاشَا\add* أَربِّي إِڭَّا أَسْ-د ذڭْ ؤُفُوسْ نّسْ، \add ڒخْذنِّي\add* نشّْ أَذْ أَشْ سّشْنغْ أَمْشَانْ مَانِي إِزمَّارْ أَذْ يَارْوڒْ.
\v 14 \add مَاشَا\add* مَاڒَا يُوفّْ حذْ خْ وَاجَّارْ نّسْ ؤُشَا إِنْغَا إِ-ث س ڒغْذَارثْ، \add خنِّي\add* أَذْ ث ثكْسِيذْ غَارْ ؤُعَالْطَارْ إِنُو، مَاحنْذْ أَذْ ث نْغنْ.
\m 
\v 15 ونِّي إِوْثِينْ بَابَاسْ نِيغْ يمَّاسْ، أَذْ إِتّْوَانغْ نِيشَانْ. \x ◘ \xo 21:‏15 \xt مت. 15‏:‏4\x*
\m 
\v 16 ونِّي يُوشَارنْ بْنَاذمْ ؤُشَا إِزّنْزْ إِ-ث، نِيغْ إِتّْوَافْ \add عَاذْ\add* غَارسْ، أَذْ إِتّْوَانغْ نِيشَانْ.
\m 
\v 17 ونِّي إِ غَا إِنعْڒنْ بَابَاسْ نِيغْ يمَّاسْ، أَذْ إِتّْوَانغْ نِيشَانْ. \x ◘ \xo 21:‏17 \xt لَاوِي 20‏:‏9؛ أَوڒن. 20‏:‏20؛ مت. 15‏:‏4؛ مك. 7‏:‏10\x*
\m 
\v 18 مَاڒَا إِرْيَازنْ مّْشُوبّْشنْ ؤُشَا إِجّنْ إِوْثَا ونّغْنِي س وژْرُو نِيغْ س ڒْپُونِييّثْ، ؤُشَا وَانِيثَا وَارْ إِمُّوثْ، \add مَاشَا\add* إِوْضَا ذِي ثَاسُّوثْ،
\v 19 \add خنِّي\add*، مَاڒَا وَانِيثَا إِكَّارْ عَاوذْ ؤُشَا يُويُورْ غَارْ بَارَّا خْ ثغَّارْشْثْ، أَذْ يِيڒِي ونِّي ث إِوْثِينْ ذ أَمزْذَاڭْ. أَذْ أَسْ إِخدْجصْ مْغِيرْ مِينْ يَاريّحْ ؤُشَا أَذْ ث يجّْ أَذْ إِڭّنْفَا مْلِيحْ.
\m 
\v 20 مَاڒَا إِوْثَا حذْ إِسْمغْ نّسْ نِيغْ ثَايَّا نّسْ س وعْمُوذْ ؤُشَا إِمُّوثْ سَاذُو ؤُفُوسْ نّسْ، \add خنِّي\add* إِتّْخصَّا أَذْ أَسْ يَاغْ خْ ثسْغَارْثْ نّسْ نِيشَانْ.
\v 21 مَاشَا مَاڒَا إِقِّيمْ إِبدّْ إِجّْ نِيغْ ثْنَاينْ ن وُوسَّانْ، وَارْ ذ أَسْ يُوغِي ثَاسْغَارْثْ، مِينْزِي نتَّا ذ \add ثَامنْيَاثْ ن\add* نُّوقَارْثْ نّسْ إِ يدْجَا.
\m 
\v 22 مَاڒَا إِرْيَازنْ مّنْغنْ ؤُشَا وْثِينْ إِشْثْ ن ثمْغَارْثْ س دّيْسثْ ؤُشَا إِوْضَا أَسْ-د ؤُعذِّيسْ نّسْ، مَاشَا وَارْ إِدْجِي شَا ذ أَيزِّيمْ، \add خنِّي\add* نتَّا أَذْ إِخدْجصْ نِيشَانْ إِجّْ ن مُولْثَا عْلَاحْسَابْ مِينْ ذ أَسْ غَا إِتَّارْ ورْيَازْ ن ثمْغَارْثْ ؤُشَا أَذْ ت إِوْشْ إِ ڒْقُوضَاثْ. \f ◼ \fr 21:‏22 \ft \bd ’ڒْْقُوضَاثْ‘\bd* - نِيغْ ’إِمزُورْفَا‘، أَقَا-ثنْ ذ إِوْذَانْ نِّي غَارْ إِدْجْ ثُوسّْنَا ن إِزرْفَانْ (شَّارِيعَا) ؤُشَا سْڒِينْ إِ دّْعَاوِي ن إِوْذَانْ مَاحنْذْ أَذْ خَاسنْ حكّْمنْ.\f*
\v 23 مَاڒَا إِمْسَارْ شَا ن ؤُيزِّيمْ ذ أَعفَّانْ، \add ڒخْذنِّي\add* أَذْ ثوْشذْ ثُوذَارْثْ س ثُوذَارْثْ،
\v 24 ثِيطّْ س ثِيطّْ، ثِيغْمسْثْ س ثغْمسْثْ، أَفُوسْ س ؤُفُوسْ، أَضَارْ س ؤُضَارْ، \x ◘ \xo 21:‏24 \xt لَاوِي 24‏:‏20؛ أَعَوذ. 19‏:‏21؛ مت. 5‏:‏38\x*
\v 25 أَشْمَاضْ س وشْمَاضْ، أَيزِّيمْ س ؤُيزِّيمْ، ثِيشْثِي س ثشْثِي.
\m 
\v 26 مَاڒَا إِڒْقفْ حذْ ثِيطّْ ن إِسْمغْ نّسْ نِيغْ ثِيطّْ ن ثَايَّا نّسْ، إِضيّعْ إِ-ت، \add خنِّي\add* أَذْ ث يجّْ أَذْ يُويُورْ أَمنِّي زِي سِّيبّثْ ن ثِيطّْ نّسْ.
\v 27 مَاڒَا س ثشْثِي إِتّكّسْ ثِيغْمسْثْ ن إِسْمغْ نّسْ، نِيغْ ثِيغْمسْثْ ن ثَايَّا نّسْ، \add خنِّي\add* أَذْ أَسْ يجّْ أَذْ يُويُورْ أَمنِّي زِي سِّيبّثْ ن ثغْمسْثْ نّسْ.
\m 
\v 28 مَاڒَا أَفُونَاسْ إِبَارّزْ أَرْيَازْ نِيغْ ثَامْغَارْثْ، ؤُ وَانِيثَا إِمُّوثْ، \add خنِّي\add* أَذْ أَرْجْمنْ أَفُونَاسْ ؤُ أَيْسُومْ نّسْ وَارْ زَّايسْ تّتّنْ. بَابْ ن ؤُفُونَاسْ أَذْ يِيڒِي ذ أَفُورِّي. \x ◘ \xo 21:‏28 \xt أَمز. 9‏:‏5\x*
\v 29 \add مَاشَا\add* مَاڒَا أَفُونَاسْ ثُوغَا ذ أَبَارّزْ إِضنَّاضْ ذ فَارِيضنَّاضْ ؤُشَا بَابْ نّسْ ثُوغَا إِسّنْ ؤُشَا وَارْ ث إِحْضِي ؤُشَا إِنْغَا أَرْيَازْ نِيغْ ثَامْغَارْثْ، \add خنِّي\add* أَذْ أَرْجْمنْ أَفُونَاسْ ؤُشَا عَاوذْ أَذْ نْغنْ بَابْ نّسْ.
\v 30 مَاڒَا ڭِّينْ خَاسْ دّيّثْ، \add ڒخْذنِّي\add* أَذْ إِوْشْ مَارَّا مِينْ خَاسْ ڭِّينْ ذ تَّامَانْ ن ؤُفكِّي إِ ثُوذَارْثْ نّسْ، \f ◼ \fr 21:‏30 \ft \bd ’ثُوذَارْثْ‘\bd* - س ثْعِيبْرَانِيثْ ’ڒعْمَارْ‘.\f*
\v 31 نِيغْ مَاڒَا \add أَفُونَاسْ\add* إِبَارّزْ أَحنْجِيرْ نِيغْ ثَاحنْجِيرْثْ. أَذْ أَسْ ڭّنْ عْلَاحْسَابْ لْفَارِيضَا-يَا.
\v 32 مَاڒَا أَفُونَاسْ إِبَارّزْ إِسْمغْ نِيغْ ثَايَّا، أَذْ وْشنْ ثْڒَاثِينْ شِيقْلُو ن نُّوقَارْثْ إِ سِيذِيسْ، ؤُشَا أَفُونَاسْ أَذْ ث أَرْجْمنْ.
\m 
\v 33 مَاڒَا يَارْزمْ حذْ أَنُو نِيغْ مَاڒَا إِغْزَا حذْ أَنُو ؤُشَا وَارْ ث إِذْڒِي، ؤُشَا إِوْضَا ذَايسْ ؤُفُونَاسْ نِيغْ أَغْيُوڒْ،
\v 34 \add خنِّي\add* بَابْ ن وَانُو أَذْ إِخدْجصْ. أَذْ يَارّْ نُّوقَارْثْ إِ بَابْ نّسْ ؤُشَا \add ڒبْهِيمثْ\add* إِمُّوثنْ أَذْ ثِيڒِي نّسْ.
\m 
\v 35 مَاڒَا أَفُونَاسْ إِيْزمْ أَفُونَاسْ ن وَاجَّارْ نّسْ أَڒَامِي إِمُّوثْ، \add ڒخْذنِّي\add* أَذْ زّنْزنْ أَفُونَاسْ إِدَّارنْ، أَذْ بْضَانْ ثَامنْيَاثْ-أَ \add جَارْ أَسنْ\add* ؤُشَا أَذْ بْضَانْ عَاوذْ \add أَفُونَاسْ\add* أَمتِّينْ.
\v 36 \add مَاشَا مَاڒَا\add* إِسّنْ بلِّي أَفُونَاسْ إِبَارّزْ إِضنَّاضْ ذ فَارِيضنَّاضْ، ؤُشَا بَابْ نّسْ وَارْ ث إِحْضِي، أَذْ إِخدْجصْ أَفُونَاسْ س ؤُفُونَاسْ ؤُشَا \add أَفُونَاسْ\add* أَمتِّينْ أَذْ يِيڒِي نّسْ.
\v 37 مَاڒَا يُوشَارْ حذْ أَفُونَاسْ نِيغْ إِجّنْ زڭْ وُودْجِي ؤُشَا إِغَارْصْ أَسْ نِيغْ إِزّنْزْ إِ-ث، \add خنِّي\add* أَذْ إِخدْجصْ خمْسَا ن إِفُونَاسنْ خْ يِيجّْ ن ؤُفُونَاسْ ؤُ أَربْعَا ن وُودْجِي خْ يِيجّنْ ن وُودْجِي.“ \x ◘ \xo 21:‏37 \xt 2 صم. 12‏:‏6\x*
\b
\b
\c 22
\s1 ثِيوصَّا زِي جِّيهثْ ن وَاڭْڒَا ن ؤُمْقَارّبْ
\m 
\v 1 ”مَاڒَا إِتّْوَافْ ؤُشفَّارْ \add عَاذْ\add* أَمْ إِتَّاشَارْ، ؤُشَا إِوْثَا إِ-ث ؤُشَا إِمُّوثْ، وَارْ \add تِّيڒِينْ\add* إِذَامّنْ خْ ونِّي ث يُوفِينْ.
\v 2 مَاڒَا ثنْقَارْ-د خَاسْ ثْفُوشْثْ، \add أَذْ\add* خَاسْ \add إِڒِينْ\add* إِذَامّنْ ذِي سِّيبّثْ-أَ. أَذْ أَسْ إِخدْجصْ ؤُشفَّارْ مَارَّا. مَاڒَا وَارْ غَارسْ شَا، أَذْ إِمّنْزْ ذِي سِّيبّثْ ن ثُوشّفّْرَا نّسْ.
\v 3 مَاڒَا ثتّْوَافْ ثُوشّفَّارْثْ ثدَّارْ ذڭْ ؤُفُوسْ نّسْ، مَا ذ أَفُونَاسْ \add إِ ت ثُوغَا\add* نِيغْ ذ أَغْيُوڒْ نِيغْ ذ إِجّنْ زڭْ وُودْجِي، إِتّْخصَّا أَسْ أَذْ إِخدْجصْ ثْنَاينْ ن ثْسقَّارْ.
\m 
\v 4 مَاڒَا إِجَّا حذْ أَذْ هدَّانْ \add ڒْْمَاڒْ\add* إِيَّارْ نِيغْ أَمَارْجعْ ن ؤُضِيڒْ ؤُشَا يَارْوسْ ذَايسْ ثَاحِيمَارْثْ نّسْ ؤُشَا أَذْ أَسنْ إِضْڒقْ أَڒَامِي أَذْ هدَّانْ ذِي ثمُّورْثْ ن ونّغْنِي، \add خنِّي\add* أَذْ \add ت\add* إِخدْجصْ زِي ڒمْخيّرْ ن ييَّارْ نّسْ ؤُ زِي ڒمْخيّرْ ن ؤُمَارْجعْ ن ؤُضِيڒْ نّسْ.
\m 
\v 5 مَاڒَا ثفّغْ-د ثْمسِّي ؤُشَا ثڒْقفْ أَسنَّانْ ؤُشَا ثشَّا ثِيقبِّيضِينْ \add ن إِمنْذِي\add* نِيغْ إِمنْذِي إِبدّنْ نِيغْ إِيَّارْ، \add خنِّي\add* ونِّي إِقّْذنْ ثِيمسِّي أَذْ إِخدْجصْ مَارَّا مِينْ إِتّْوَاشمْضنْ.
\m 
\v 6 مَاڒَا إِحْضَا حذْ إِ وَاجَّارْ نّسْ نُّوقَارْثْ نِيغْ ڒقْشُوعْ ؤُ مَانْ أَيَا إِتّْوَاشَارْ أَسْ زِي ثَادَّارْثْ ن ورْيَازْ \add نِّي\add*، \add خنِّي\add* أَشفَّارْ، مَاڒَا ؤُفِينْ ث، أَذْ إِخدْجصْ ثْنَاينْ ن ثْسقَّارْ.
\v 7 مَاڒَا وَارْ إِتّْوِيفْ ؤُشفَّارْ، \add ڒخْذنِّي\add* أَذْ سّْقَارّْبنْ بَابْ ن ثَادَّارْثْ غَارْ أَربِّي \add مَاحنْذْ أَذْ سّْننْ\add* مَا \add وَارْ\add* إِسّْوِيژّضْ ؤُفُوسْ نّسْ غَارْ وَاڭْڒَا ن وَاجَّارْ نّسْ.
\m 
\v 8 كُوڒْ أَعذِّي زِي جِّيهثْ ن ؤُفُونَاسْ نِيغْ ن وغْيُوڒْ نِيغْ ن إِجّْ زڭْ وُودْجِي نِيغْ ن وَارُّوضْ نِيغْ ن مِينْ إِودَّارنْ إِ زَّايسْ إِنَّا \add حذْ:\add* ’أَقَا-ث ذ وَا!‘، أَذْ د-ثَاسْ ثْمسْڒَاشْثْ إِ إِدْجَانْ جَارْ أَسنْ س ثْنَاينْ زَّاثْ إِ ڒْقُوضَاثْ ؤُشَا ونِّي أَذْ خَاسْ حكْمنْ ڒْقُوضَاثْ أَذْ إِخدْجصْ إِ وَاجَّارْ نّسْ ثْنَاينْ ن ثْسقَّارْ.
\m 
\v 9 مَاڒَا إِوْشَا حذْ إِ وَاجَّارْ نّسْ أَغْيُوڒْ نِيغْ أَفُونَاسْ نِيغْ إِجّْ ن زڭْ وُودْجِي، نِيغْ مَامّشْ مَا ثڭَّا ڒبْهِيمثْ، حِيمَا أَذْ ث إِحْضَا ؤُشَا إِمُّوثْ نِيغْ يَارّژْ نِيغْ ؤُشَارنْ ث، أَمْ وَارْ إِژْرِي حذْ،
\v 10 \add خنِّي\add* أَذْ ثِيڒِي ثْجَادْجِيثْ غَارْ سِيذِي جَارْ أَسنْ س ثْنَاينْ بلِّي وَارْ إِسّْوِيژّضْ أَفُوسْ نّسْ غَارْ وَاڭْڒَا ن وَاجَّارْ نّسْ. بَابْ نّسْ أَذْ إِقْبڒْ \add ثَاجَادْجِيثْ نّسْ\add* ؤُشَا أَذْ ثَافْ بْڒَا مَا أَذْ \add ث\add* إِتّْخدْجصْ ونّغْنِي.
\v 11 \add مَاشَا\add* مَاڒَا إِتّْوَاشَارْ نِيشَانْ زَّايسْ، \add ذِي لْحَالَا-يَا\add* أَذْ إِخدْجصْ إِ بَابْ نّسْ.
\v 12 مَاڒَا إِبَانْ أَقَا إِتّْوَامزّقْ نِيشَانْ، أَذْ ث يَاوِي ذ بُورْهَانْ ؤُشَا وَارْ إِتّْخدْجِيصْ مِينْ إِتّْوَامزّْقنْ.
\m 
\v 13 مَاڒَا يَارْضڒْ حذْ شَا خْ وَاجَّارْ نّسْ ؤُشَا ثَارّژْ نِيغْ ثمُّوثْ ذِي ڒْغَايبْ ن بَابْ نّسْ، إِتّْخصَّا أَسْ أَذْ ت إِخدْجصْ مَارَّا.
\v 14 مَاشَا مَاڒَا بَابْ نّسْ ثُوغَا إِحْضَارْ، وَارْ ت إِتّْخِيدْجَاصْ. مَاڒَا ثُوغَا إِشْرَا ت \add خَاسْ\add*، أَذْ د-يَاسْ خْ ڒخْڒَاصْ نّسْ.“
\b
\s1 خْ ؤُسفْسَاذْ ن أَرُّوحْ ذ أَرِّيمثْ، خْ يِينِّي إِضعْفنْ ؤُ خْ ؤُشقّفْ ذِي أَربِّي
\m 
\v 15 ”ؤُشَا مَاڒَا إِمَّارْضنْ حذْ خْ شَا ن ثعْزَاڒشْثْ، ثُوغَا وَارْ ت إِخْضِيبْ حذْ عَاذْ، ؤُشَا إِطّصْ أَكِيذسْ، إِتّْخصَّا أَسْ أَذْ أَسْ إِوْشْ صَّاذَاقْ إِمُونْ \add مَاحنْذْ\add* أَذْ ت يَاوِي ذ ثَامْغَارْثْ.
\v 16 مَاڒَا بَابَاسْ وَارْ إِخْسْ أَذْ أَسْ ت إِوْشْ، أَذْ \add أَسْ\add* إِوْزنْ عَاذْ صَّاذَاقْ ن ثعْزُورَايْ س نُّوقَارْثْ.
\m 
\v 17 وَارْ تّجِّي ثَاسحَّارْثْ أَذْ ثدَّارْ. \x ◘ \xo 22:‏17 \xt أَعَوذ. 18‏:‏10، 11\x*
\m 
\v 18 مَانْ ونْ إِ غَا إِطّْصنْ أَكْ-ذ إِجّْ ن ڒْمَاڒْ، أَذْ ث نْغنْ نِيشَانْ. \x ◘ \xo 22:‏18 \xt لَاوِي 18‏:‏23؛ 20‏:‏15\x*
\m 
\v 19 ونِّي إِ غَا إِوهّْبنْ شَا ن ثْغَارْصْثْ إِ إِربِّيثنْ، وَارْ إِدْجِي مْغِيرْ إِ سِيذِي وَاهَا، إِتّْخصَّا أَذْ إِتّْوَاحَارّمْ \add إِ ؤُثحِّي\add*. \x ◘ \xo 22:‏19 \xt أَعَوذ. 17‏:‏2، 3، 4، 5\x*
\m 
\v 20 وَارْ دّدْجمْ أَبَارَّانِي ؤُ وَارْ خَاسْ تّْزيَّارمْ، مِينْزِي ثُوغَا ؤُڒَا ذ كنِّيوْ ذ إِبَارَّانِييّنْ ذِي ثمُّورْثْ ن مِيصْرَا. \x ◘ \xo 22:‏20 \xt لَاوِي 19‏:‏34\x*
\m 
\v 21 وَارْ تّْذدْجِي شَا إِشْثْ ن ثَاجَّاتْشْ نِيغْ إِجّْ ن ؤُيُوجِيڒْ. \x ◘ \xo 22:‏21 \xt زَاك. 7‏:‏10\x*
\v 22 مَاڒَا ثِيوْضذْ أَذْ ث ثسّحْقَارذْ أَطَّاسْ ؤُشَا نتَّا إِسْغُويْ-د غَارِي، أَقَا نشّْ س ؤُغِيڒْ أَذْ سْڒغْ إِ ثْغُويِّيثْ نّسْ.
\v 23 أَذْ يَارغْ وغْضَابْ إِنُو ؤُشَا نشّْ أَذْ كنِّيوْ نْغغْ س سِّيفْ، ثِيمطَّا نْومْ أَذْ ذوْڒنْثْ ذ ثِيجَّاڒْ ذ ثَارَّاوْثْ نْومْ ذ إِيُوجِيڒنْ.
\m 
\v 24 مَاڒَا ثَارضْڒذْ نُّوقَارْثْ إِ ڒْڭنْسْ إِنُو، إِ ؤُمزْڒُوضْ إِ \add ذِينْ\add* غَاركْ، \add خنِّي\add* وَارْ كِيذسْ تّڭّذْ أَمْ إِتّڭّْ بَابْ ن ؤُمَارْوَاسْ: وَارْ خَاسْ تّڭّْ شَا أَرِّيبَا. \x ◘ \xo 22:‏24 \xt لَاوِي 25‏:‏36، 37؛ أَعَوذ. 23‏:‏18، 19؛ إِزهد. 15‏:‏5؛ أَوڒن. 28‏:‏8؛ حِز. 18‏:‏8\x*
\m 
\v 25 مَاڒَا ثكْسِيذْ أَرُّوضْ ن وَاجَّارْ نّشْ ذ أَضْمَانْ، أَرّْ أَسْ ث قْبڒْ مَا أَذْ ثغْڒِي ثْفُوشْثْ. \x ◘ \xo 22:‏25 \xt أَعَوذ. 24‏:‏12، 13\x*
\v 26 مِينْزِي وَارْ غَارسْ مْغِيرْ أَڒحَّافْ وَانِيثَا، أَقَا-ث ذ أَرُّوضْ خْ ثڒْمشْثْ نّسْ. مِينْ ذِي غَا إِطّصْ \add خنِّي\add*؟ خْمِي غَارِي د غَا إِسْغُويْ، ڒخْذنِّي أَذْ أَسْ سْڒغْ، مِينْزِي نشّْ أَقَا ذ أَحْنِينْ!
\m 
\v 27 وَارْ تّْشقِّيفْ ذِي أَربِّي ؤُ وَارْ تّكّْوَارْ ڒْحَاكمْ ن ڒْڭنْسْ نّشْ. \x ◘ \xo 22:‏27 \xt ؤُف. 21‏:‏6، 8؛ ڒخ. 23‏:‏3، 4، 5\x*
\m 
\v 28 وَارْ سْعطَّاڒَا ثَاشُّورثْ \add ن ثْميْرَا\add* نّشْ نِيغْ أَحْڒَايْ \add ن ثيْسَارْثْ\add* نّشْ. أَذْ أَيِي ثوْشذْ \add ؤُڒَا\add* ذ أَمنْزُو ن إِحنْجِيرنْ نّشْ. \x ◘ \xo 22:‏28 \xt ؤُف. 13‏:‏2، 12\x*
\v 29 أَمُّو إِ غَا ثڭّذْ \add عَاوذْ\add* س إِفُونَاسنْ نّشْ ذ وُودْجِي نّشْ. سبْعَا ن وُوسَّانْ أَذْ إِڒِينْ أَكْ-ذ يمَّاثْسنْ ؤُشَا غَارْ وَاسّْ وِيسّْ ثْمنْيَا أَذْ أَيِي ثنْ ثوْشذْ. \x ◘ \xo 22:‏29 \xt ؤُف. 23‏:‏19؛ لَاوِي 22‏:‏27؛ حِز. 44‏:‏30\x*
\m 
\v 30 أَذْ أَيِي ثِيڒِيمْ ذ إِمْقدَّاسنْ ؤُ وَارْ تّتّمْ أَيْسُومْ إِ إِتّْوَامزّْقنْ ذِي ڒخْڒَا. أَذْ ث ثنْضَارمْ إِ يِيطَانْ.“ \f ◼ \fr 22:‏30 \ft \bd ’إِمْقدَّاسنْ‘\bd* - س ثْعِيبْرَانِيثْ ’إِوْذَانْ إِمْقدَّاسنْ‘ نِيغْ ’إِرْيَازنْ إِمْقدَّاسنْ‘.\f*  \x ◘ \xo 22:‏30 \xt لَاوِي 22‏:‏8؛ حِز. 44‏:‏31\x*
\b
\b
\c 23
\s1 ثِيوصَّا زِي جِّيهثْ ن مَامّشْ إِ غَا نمْصُورُّوفْ أَكْ-ذ ؤُمْقَارّبْ
\m 
\v 1 ”وَارْ سُّوفُّوغْ ڒخْبَارْ إِسّْخَارِّيقنْ. وَارْ تِّيشْ أَفُوسْ نّشْ إِ ؤُعفَّانْ، مَاحنْذْ أَذْ ثِيڒِيذْ ذ أَشهَّاذْ ن دّدْجْ.
\m 
\v 2 وَارْ أَردّفْ أَزْينْ أَمقّْرَانْ ذِي ڒْغَارْ ؤُ وَارْ د-تَّارِّي ذِي دّعْوثْ أَڒْ غَا ثْميّْڒذْ \add ثڭّْوجذْ خْ ڒْحقّْ\add* أَوَارْنِي إِ وَاطَّاسْ، أَذْ ثْفَارْغذْ \add ڒْحقّْ\add*.
\m 
\v 3 ذِي دّعْوثْ نّسْ وَارْ تّْرِيحْ شَا أَكْ-ذ ڒْمسْكِينْ. \x ◘ \xo 23:‏3 \xt لَاوِي 19‏:‏15\x*
\m 
\v 4 مَاڒَا ثڒْقِيذْ أَفُونَاسْ نِيغْ أَغْيُوڒْ إِودَّارْ ن ڒعْذُو نّشْ، إِتّْخصَّا أَذْ أَسْ ث ثَارّذْ نِيشَانْ. \x ◘ \xo 23:‏4 \xt أَعَوذ. 22‏:‏1، 2؛ لك. 6‏:‏27؛ فِيل. 2‏:‏4\x*
\v 5 مَاڒَا ثژْرِيذْ أَغْيُوڒْ ن ونِّي ثْشَارّْهذْ إِوْضَا س دّْقڒْ نّسْ، إِتّْخصَّا شكْ أَذْ ثحْضِيذْ إِخفْ نّشْ أَذْ ثجّذْ \add ثَامسْڒَاشْثْ\add* إِ نتَّا وَاهَا، \add مَاشَا\add* شكْ ذ نتَّا جْمِيعْ أَذْ ثْفكّمْ \add أَغْيُوڒْ\add* قَاعْ. \x ◘ \xo 23:‏5 \xt أَعَوذ. 22‏:‏4\x*
\m 
\v 6 وَارْ سْفَارَّاغْ ثَاسْغَارْثْ ن ؤُمزْڒُوضْ إِ \add ذِينْ\add* غَاركْ ذِي دّعْوثْ نّسْ. \x ◘ \xo 23:‏6 \xt أَعَوذ. 27‏:‏19\x*
\m 
\v 7 بعّذْ خْ ثْمسْڒَاشْثْ إِغشّنْ. وَارْ نقّْ أَفُورِّي نِيغْ أَمْسڭّذْ، مِينْزِي نشّْ وَارْ تّْبَارِّيغْ أَعفَّانْ.
\v 8 وَارْ كسِّي ثَارْزفْثْ، مِينْزِي ثَارْزفْثْ ثسّْذَارْغَاڒْ ثِيطَّاوِينْ يَارزْمنْ ؤُ ثسّْفَارَّاغْ أَوَاڒنْ ن إِمْسڭّْذنْ. \x ◘ \xo 23:‏8 \xt أَعَوذ. 16‏:‏19؛ 1 صم. 8‏:‏3؛ أَوڒن. 19‏:‏6؛ أَمب. 7‏:‏7\x*
\m 
\v 9 وَارْ ثْزيَّارمْ خْ ؤُبَارَّانِي. أَقَا كنِّيوْ ثسّْنمْ نّفْسْ ن ؤُبَارَّانِي، مِينْزِي ثُوغَا كنِّيوْ ذ إِبَارَّانِييّنْ ذِي ثمُّورْثْ ن مِيصْرَا. \x ◘ \xo 23:‏9 \xt ؤُف. 22‏:‏21؛ لَاوِي 19‏:‏33؛ أَعَوذ. 24‏:‏17\x*
\m 
\v 10 ستَّا ن إِسڭّْوُوسَا أَذْ ثْزَارْعذْ ثَامُّورْثْ نّشْ ؤُشَا أَذْ ثسّْمُونذْ ڒْغِيدْجثْ نّسْ.
\v 11 ذڭْ \add ؤُسڭّْوَاسْ\add* وِيسّْ سبْعَا أَذْ ت ثجّذْ أَذْ ثَاريّْحذْ ؤُشَا أَذْ أَسْ ثَارْخُوذْ، حِيمَا أَذْ \add زَّايسْ\add* شّنْ إِمزْڒَاضْ ن ڒْڭنْسْ نّشْ. ؤُشَا مِينْ غَا جّنْ نِيثْنِي أَذْ \add زَّايسْ\add* شّنْ ڒْمَاڒْ ن ڒخْڒَا. أَمُّو إِ غَا ثڭّذْ عَاوذْ س ؤُمَارْجعْ ن ؤُضِيڒْ نّشْ ذ زِّيثُونْ نّشْ. \x ◘ \xo 23:‏11 \xt لَاوِي 25‏:‏4، 5\x*
\m 
\v 12 ذِي ستَّا ن وُوسَّانْ أَذْ ثڭّذْ ڒْخذْمثْ نّشْ ؤُ ذڭْ وَاسّْ وِيسّْ سبْعَا أَذْ ثَاريّْحذْ، مَاحنْذْ أَذْ يَاريّحْ ؤُفُونَاسْ نّشْ ذ وغْيُوڒْ نّشْ ؤُ أَذْ يَارّْ نّفْسْ مِّيسْ ن ثَايَّا نّشْ ذ ؤُبَارَّانِي.“\x ◘ \xo 23:‏12 \xt ؤُف. 20‏:‏8؛ 31‏:‏13‏-‏17.\x*
\b
\s1 ثِيوصَّا زِي جِّيهثْ ن ؤُوقَّارْ إِ سِيذِي أَربِّي
\m 
\v 13 ذِي مَارَّا مِينْ ذ أَومْ نِّيغْ، حْضَامْ ث. وَارْ تِّيذَارمْ إِسمْ ن إِربِّيثنْ نّغْنِي. وَارْ تّسْڒَانْ \add إِسمْ نّسْ\add* زڭْ ؤُقمُّومْ نّشْ. \x ◘ \xo 23:‏13 \xt ڒخْڒ. 32‏:‏38؛ ياش. 23‏:‏7؛ إِزهد. 16‏:‏4؛ حُوش. 2‏:‏19؛ زَاك. 13‏:‏2\x*
\m 
\v 14 ثْڒَاثَا ن ثْوَاڒَاوِينْ ذڭْ ؤُسڭّْوَاسْ أَذْ أَيِي ثْعيّْذمْ إِجّْ ن ڒْعِيذْ.
\v 15 ڒْعِيذْ ن وغْرُومْ بْڒَا أَنْثُونْ أَذْ ث ثحْضَامْ. سبْعَا ن وُوسَّانْ أَذْ ثشّذْ أَغْرُومْ بْڒَا أَنْثُونْ، أَمْ مَامّشْ كنِّيوْ ؤُمُورغْ نشّْ، ذِي ڒْوقْثْ إِتّْوَاڭّنْ ذڭْ ؤُيُورْ أَبِيبْ، مِينْزِي ذَايسْ إِ د-ثفّْغذْ زِي مِيصْرَا. وَارْ د-تُّوسِيمْ \add س إِفَاسّنْ\add* خْوَانْ زَّاثْ إِ وُوذمْ إِنُو. \x ◘ \xo 23:‏15 \xt ؤُف. 12‏:‏14، 15؛ 13‏:‏3؛ 34‏:‏20؛ أَعَوذ. 16‏:‏16\x*
\v 16 \add حْضَامْ عَاوذْ\add* ڒْعِيذْ ن ثْميْرَا، \add ڒْعِيذْ ن\add* ثْمنْزُوثْ ن ڒْخذْمثْ نّشْ إِ ثْزَارْعذْ ذڭْ إِيَّارْ، ؤُ ڒْعِيذْ ن ؤُسْمُونِي \add ن صَّابثْ\add* ذڭْ ؤُنڭَّارْ ن ؤُسڭّْوَاسْ، خْمِي غَا ثسّْمُونذْ \add ڒْغِيدْجثْ ن\add* ڒْخذْمثْ نّشْ زڭْ إِيَّارْ. \x ◘ \xo 23:‏16 \xt ؤُف. 34‏:‏22\x*
\v 17 ثْڒَاثَا ن ثْوَاڒَاوِينْ ذڭْ ؤُسڭّْوَاسْ أَذْ ضْهَارنْ مَارَّا إِرْيَازنْ \add ن ڒْڭنْسْ نّشْ\add* إِ وُوذمْ ن سِيذِي، سِيذِي.
\m 
\v 18 وَارْ تّْقدَّامْ إِذَامّنْ ن ثْغَارْصْثْ إِنُو أَكْ-ذ مِينْ إِخمَّارنْ، ؤُ ثَاذُونْثْ ن \add ثْغَارْصْثْ ن\add* ڒْعِيذْ إِنُو وَارْ تّْنُوسِي دْجِيڒثْ \add ثكْمڒْ\add* أَڒْ صّْبحْ.
\m 
\v 19 ثَامزْوَارُوثْ ن ثْمنْزُوثْ زڭْ وُوذمْ ن ثمُّورْثْ نّشْ أَذْ \add ت\add* ثَاوْيذْ غَارْ ثَادَّارْثْ ن سِيذِي، أَربِّي نّشْ. وَارْ سْننِّي إِغَايْضْ ذ أَمژْيَانْ س ؤُغِي ن يمَّاسْ. \x ◘ \xo 23:‏19 \xt ؤُف. 34‏:‏26\x*
\m 
\v 20 خْزَارْ، أَذْ سّكّغْ إِجّْ ن لْمَالَاكْ زَّاثْ إِ وُوذمْ نّشْ، حِيمَا أَذْ شكْ إِحْضَا ذڭْ وبْرِيذْ ؤُشَا أَذْ شكْ يَاوِي غَارْ ومْشَانْ نِّي سّْوجْذغْ. \x ◘ \xo 23:‏20 \xt ؤُف. 33‏:‏2\x*
\v 21 حْضَا أَرنْذَاذْ إِ وُوذمْ نّسْ ؤُشَا سڒْ إِ وَاوَاڒْ نّسْ، وَارْ خَاسْ سَّارْزِيڭْ شَا \add ڒعْمَارْ\add*، مِينْزِي نتَّا وَارْ إِتّكّسْ إِعذِّيينْ نْومْ، مِينْزِي إِسمْ إِنُو أَقَا-ث ذَايسْ.
\v 22 مَاشَا مَاڒَا س ثِيذتّْ أَذْ ثسْڒذْ إِ وَاوَاڒْ نّسْ، أَذْ ثڭّذْ مَارَّا مِينْ ذ أَشْ غَا إِنِيغْ، أَذْ إِڒِيغْ ذ ڒعْذُو إِ ڒْعذْيَانْ نّشْ ؤُشَا أَذْ حْصَارغْ إِنِّي شكْ إِحصَّارنْ.\x ◘ \xo 23:‏22 \xt أَمز. 12‏:‏3\x*
\v 23 مِينْزِي لْمَالَاكْ إِنُو أَذْ يِيڒِي زَّاثكْ، أَذْ شكْ سِّيذْفغْ ذِي \add ثمُّورْثْ ن\add* إِمُورِييّنْ ذ إِحِيتِّييّنْ ذ إِفِيرِيزِييّنْ ذ أَيْثْ ن كنْعَانْ ذ إِحِيوِييّنْ ذ إِيابُوسِييّنْ، ؤُ نشّْ أَذْ ثنْ ثحِّيغْ.
\v 24 وَارْ تّْبنْذِيقْ إِ إِربِّيثنْ نْسنْ نِيغْ أَذْ ثنْ ثْعبْذذْ نِيغْ أَذْ ثڭّذْ أَمْ تّڭّنْ نِيثْنِي، مَاشَا أَذْ ثنْ ثثحِّيذْ قَاعْ ؤُشَا أَذْ ثَارْژذْ مَارَّا إِمَايْضُوثنْ نْسنْ \add إِقدّْسنْ\add*.
\v 25 أَذْ ثْعبْذمْ سِيذِي، أَربِّي نْومْ، ؤُ نتَّا أَذْ إِبَاركْ أَغْرُومْ نّشْ ذ وَامَانْ نّشْ. نشّْ أَذْ كّْسغْ ڒهْڒَاشَاثْ زِي ڒْوسْطْ نّشْ. \x ◘ \xo 23:‏25 \xt ؤُف. 15‏:‏26؛ أَعَوذ. 7‏:‏15\x*
\v 26 وَارْ تِّيڒِي \add ثمْغَارْثْ\add* نِّي ؤُمِي إِوْضَا ؤُعذِّيسْ نِيغْ وَارْ إِتِّيرْونْ ذِي ثمُّورْثْ نّشْ. نشّْ أَذْ كمّْڒغْ ڒْقدّْ ن وُوسَّانْ نّشْ. \x ◘ \xo 23:‏26 \xt أَعَوذ. 7‏:‏14\x*
\v 27 أَذْ سّكّغْ أَنخْڒِيعْ زَّاثْ إِ ؤُغمْبُوبْ نّشْ، أَذْ سّْخَاروْضغْ مَارَّا ڒْڭنْسْ إِ غَا ثَافذْ \add ذڭْ وبْرِيذْ نّشْ\add* ؤُشَا أَذْ أَرّغْ مَارَّا ڒْعذْيَانْ نّشْ أَذْ خَاكْ أَروْڒنْ. \x ◘ \xo 23:‏27 \xt ؤُف. 14‏:‏24؛ ياش. 10‏:‏10\x*
\v 28 نشّْ أَذْ سّكّغْ إِرزَّانْ زَّاثْ إِ ؤُغمْبُوبْ نّشْ، إِنِّي غَا يَاژّْڒنْ خْ إِحِيوِييّنْ ذ أَيْثْ ن كنْعَانْ ذ إِحِيتِّييّنْ زَّاثْ إِ وُوذمْ نّشْ. \x ◘ \xo 23:‏28 \xt أَعَوذ. 7‏:‏20؛ ياش. 24‏:‏12\x*
\v 29 وَارْ خَاسنْ تَّاژّْڒغْ زِي زَّاثْ نْومْ ذڭْ إِجّْ ن ؤُسڭّْوَاسْ، مَاحنْذْ وَارْ ثتّْغِيمِي ثمُّورْثْ ذ ڒخْڒَا ؤُ ڒْمَاڒْ \add ن ڒخْڒَا\add* وَارْ خَاكْ تّْمَارْنِينْ أَطَّاسْ.
\v 30 س شْوَايْ شْوَايْ أَذْ خَاسنْ أَژّْڒغْ زِي زَّاثْ نشّْ، أَڒْ غَا ثمَّارنْيذْ \add ذڭْ وَاطَّاسْ\add* ؤُشَا \add أَذْ ثْزمَّارذْ\add* أَذْ ثكْسِيذْ ثَامُّورْثْ ذ ڒْوَارْثْ.
\v 31 نشّْ أَذْ ڭّغْ إِيْمِيرنْ زِي ڒبْحَارْ ن ثلْڭَا أَڒْ ڒبْحَارْ ن إِفِيلِيسْطِينِييّنْ ؤُ زِي ڒخْڒَا أَڒْ إِغْزَارْ \add ن لْفُورَاطْ\add*، مِينْزِي أَذْ أَرّغْ إِمزْذَاغْ ن ثمُّورْثْ ذڭْ ؤُفُوسْ نّشْ ؤُشَا \add أَذْ شكْ أَرّغْ\add* أَذْ خَاسنْ ثَاژّْڒذْ زِي زَّاثْ نّشْ. \x ◘ \xo 23:‏31 \xt ڒخْڒ. 34‏:‏3، 4\x*
\v 32 وَارْ كِيذْسنْ تّڭّْ ڒْعَاهْذْ نِيغْ أَكْ-ذ إِربِّيثنْ نْسنْ. \x ◘ \xo 23:‏32 \xt ؤُف. 34‏:‏12، 15؛ أَعَوذ. 7‏:‏2\x*
\v 33 وَارْ إِعدّڒْ أَذْ زذْغنْ ذِي ثمُّورْثْ نّشْ، حِيمَا وَارْ شكْ تَّارِّينْ أَذْ أَكِيذِي ثخْضِيذْ. مَاڒَا ثْعبْذذْ إِ إِربِّيثنْ نْسنْ، أَذْ أَشْ يِيڒِي مَانْ أَيَا ذ ڒْفخْ إِ شكْ.“ \x ◘ \xo 23:‏33 \xt ياش. 23‏:‏13؛ ڒقض. 2‏:‏3\x*
\b
\b
\c 24
\s1 ڒْعَاهْذْ ن أَربِّي أَكْ-ذ ڒْڭنْسْ
\m 
\v 1 ؤُشَا إِنَّا نتَّا إِ مُوسَا:
\m ”ڭعّذْ غَارْ سِيذِي، شكْ ذ هَارُونْ ذ نَاذَابْ ذ أَبِيهُو، ذ سبْعِينْ ن إِمْغَارنْ ن إِسْرَائِيل، ؤُشَا بنْذْقمْ زِي ڒَاڭّْوَاجْ.
\v 2 مُوسَا وحّْذسْ أَذْ د-إِقَارّبْ غَارْ سِيذِي، \add مَاشَا\add* وَارْ إِعدّڒْ أَذْ قَارّْبنْ نِيثْنِي. ؤُڒَا ذ ڒْڭنْسْ وَارْ كِيذسْ إِتّْڭِيعِّيذْ شَا.“
\v 3 مُوسَا إِعْقبْ-د ؤُشَا إِخبَّارْ ڒْڭنْسْ خْ مَارَّا أَوَاڒنْ ن سِيذِي ؤُ خْ مَارَّا لْفَارَايِيضْ. مَارَّا ڒْڭنْسْ يَارَّا-د س يِيجّْ ن وَاوَاڒْ، نَّانْ: ”مَارَّا أَوَاڒنْ إِ إِنَّا سِيذِي أَذْ زَّايْسنْ نڭّْ.“ \f ◼ \fr 24:‏3 \ft \bd ’س يِيجّْ ن وَاوَاڒْ‘\bd* - س ثْعِيبْرَانِيثْ ’س يِيجّْ ن ؤُقمُّومْ‘.\f*  \x ◘ \xo 24:‏3 \xt ؤُف. 19‏:‏8؛ 24‏:‏7؛ أَعَوذ. 5‏:‏27\x*
\v 4 مُوسَا يُورَا مَارَّا أَوَاڒنْ ن سِيذِي. غَارْ صّْبحْ زِيشْ إِكَّارْ ؤُشَا إِبْنَا إِجّْ ن ؤُعَالْطَارْ غَارْ إِضَارنْ ن وذْرَارْ ؤُشَا \add إِڭَّا\add* ثنْعَاشْ ن إِمَايْضُوثنْ ن وژْرُو، عْلَاحْسَابْ \add ڒْْقدّْ ن\add* ثنْعَاشْ ن ثْقبَّاڒْ ن إِسْرَائِيل.
\v 5 إِسّكّْ إِحُوذْرِييّنْ زڭْ أَيْثْ ن إِسْرَائِيل، إِنِّي إِسّْبخَّارنْ ثِيغَارْصِي ن وشْمَاضْ ؤُ قدّْمنْ ثِيغَارْصِي ن ڒهْنَا زڭْ إِفُونَاسنْ إِمژْيَاننْ إِ سِيذِي.
\v 6 إِكْسِي مُوسَا أَزْينْ ن إِذَامّنْ، إِڭَّا \add إِ-ث\add* ذِي طّْبَاصِي ؤُشَا أَزْينْ \add نّغْنِي\add* ن إِذَامّنْ إِزدْجعْ إِ-ثنْ خْ ؤُعَالْطَارْ.
\v 7 إِكْسِي أَذْلِيسْ إِتّْوَانّْضنْ ن ڒْعَاهْذْ، إِغْرَا إِ-ث خْ إِمزُّوغنْ ن ڒْڭنْسْ ؤُشَا نِيثْنِي نَّانْ: ”مَارَّا مِينْ \add ذ أَنغْ\add* إِنَّا سِيذِي، أَذْ \add ث\add* نڭّْ، أَذْ \add ث\add* نْطَاعْ.“
\v 8 إِكْسِي مُوسَا إِذَامّنْ، إِرُوشّْ إِ-ثنْ خْ ڒْڭنْسْ، إِنَّا: ”خْزَارْ، إِنَا ذ إِذَامّنْ ن ڒْعَاهْذْ نِّي إِڭَّا سِيذِي أَكِيذْومْ خْ مَارَّا أَوَاڒنْ-أَ.“ \x ◘ \xo 24:‏8 \xt عبر. 9‏:‏20؛ 1 بُط. 1‏:‏2\x*
\m 
\v 9 إِڭعّذْ مُوسَا أَكْ-ذ هَارُونْ ذ نَاذَابْ ذ أَبِيهُو ذ سبْعِينْ ن إِمْغَارنْ ن إِسْرَائِيل.
\v 10 ژْرِينْ أَربِّي ن إِسْرَائِيل. ثُوغَا سَاذُو إِضَارنْ نّسْ أَمْ ثِيسِي ن زّلِّيجْ إِ إِتّْوَاڭّنْ ن صَافِّيرْ أَزِيزَا، إِصْفَا أَمْ ؤُجنَّا سِيمَانْثْ نّسْ. \x ◘ \xo 24:‏10 \xt أَسَا. 4‏:‏6\x*
\v 11 وَارْ إِسّْوِيژّضْ أَفُوسْ نّسْ خْ إِمْشنّْعنْ ن أَيْثْ ن إِسْرَائِيل ؤُشَا نِيثْنِي خْزَارنْ غَارْ أَربِّي، شِّينْ، سْوِينْ.
\m 
\v 12 إِنَّا سِيذِي إِ مُوسَا: ”ڭعّذْ-د غَارِي غَارْ وذْرَارْ ؤُشَا قِّيمْ ذِينْ ؤُشَا نشّْ أَذْ أَشْ وْشغْ ثِيڒْوِيحِينْ ن وژْرُو، شَّارِيعَا ذ ڒُومَارَاثْ ثِينِّي ؤُرِيغْ خْ ثڒْوِيحِينْ، حِيمَا أَذْ أَسنْ \add ثنْثْ\add* ثسّْڒمْذذْ.“
\v 13 إِكَّارْ مُوسَا أَكْ-ذ يَاشُووَا، أَمْسخَّارْ نّسْ، ؤُشَا إِڭعّذْ مُوسَا غَارْ وذْرَارْ ن أَربِّي.
\v 14 إِنَّا إِ إِمْغَارنْ: ”رَاجَامْ أَنغْ ذَانِيثَا أَڒْ د غَارْومْ إِ غَا نذْوڒْ. خْزَارْ، هَارُونْ ذ حُورْ أَكِيذْومْ. مَاڒَا ذِينْ حذْ غَارسْ دّْعَاوِي، إِتّْخصَّا أَسْ أَذْ غَارْسنْ إِرَاحْ.“
\m 
\v 15 \add خنِّي\add* إِڭعّذْ مُوسَا غَارْ وذْرَارْ، ؤُشَا إِجّْ ن ؤُسيْنُو إِذْڒَا أَذْرَارْ.
\v 16 أَعُودْجِي ن سِيذِي ثُوغَا إِزدّغْ ذڭْ وذْرَارْ ن سِينَا ؤُ أَسيْنُو إِذْڒَا إِ-ث ستَّا ن وُوسَّانْ ؤُشَا ذڭْ وَاسّْ وِيسّْ سبْعَا إِڒَاغَا-د نتَّا خْ مُوسَا زِي ڒْوسْطْ ن ؤُسيْنُو.
\v 17 أَسْشَانْ ن ؤُعُودْجِي ن سِيذِي ثُوغَا-ث ذِي ثِيطَّاوِينْ ن أَيْثْ ن إِسْرَائِيل أَمْ ثْمسِّي إِتّتّنْ خْ ثْقِيشَّاثْ ن وذْرَارْ. \x ◘ \xo 24:‏17 \xt عبر. 12‏:‏29\x*
\v 18 يُوذفْ مُوسَا غَارْ ڒْوسْطْ ن ؤُسيْنُو ؤُشَا إِڭعّذْ أَذْرَارْ. ثُوغَا مُوسَا إِقِّيمْ أَربْعِينْ ن وُوسَّانْ ذ أَربْعِينْ ن دْجْيَاڒِي ذڭْ وذْرَارْ.
\b
\b
\c 25
\s1 ثِيوصَّا زِي جِّيهثْ ن ڒبْنِي ن ثْزذِّيغْثْ ن سِيذِي أَربِّي
\m 
\v 1 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:
\m 
\v 2 ”إِنِي إِ أَيْثْ ن إِسْرَائِيل أَذْ أَيِي د-سّْڭَاعّْذنْ ثَاوْهِيبْثْ. زِي كُوڒْ أَرْيَازْ نِّي ذ أَسْ إِعَارّنْ وُوڒْ نّسْ، أَذْ زَّايسْ ثكْسِيمْ \bd ثَاوْهِيبْثْ ن ؤُسْڭَاعّذْ\bd* إِ نشّْ. \x ◘ \xo 25:‏2 \xt ؤُف. 35‏:‏5؛ 1 إِم. 29‏:‏3، 5، 9، 14؛ عِز. 2‏:‏68؛ 3‏:‏5؛ نَاح. 11‏:‏2\x*
\v 3 ثَا ذ \bd ثَاوْهِيبْثْ ن ؤُسْڭعّذْ\bd*، ثنِّي إِ غَا ثكْسِيذْ زَّايْسنْ: ؤُرغْ ذ نُّوقَارْثْ ذ نّْحَاسْ،
\v 4 ذ \add ؤُفِيڒُو\add* أَذحْمِي ذ ؤُرْجُووَانِي ذ ؤُزڭّْوَاغْ إِحذْقنْ ذ ڒقْطنْ أَزْذَاذْ ذ شّْعَارْ ن إِغَايْضنْ، \f ◼ \fr 25:‏4 \ft \bd ’أَزڭّْوَاغْ إِحذْقنْ‘\bd* - نِيغْ ’قِيرْمِيزْ‘.\f*
\v 5 ذ إِڒْمَاونْ إِزڭّْوَاغنْ ن إِشَارِّييّنْ، ذ إِڒْمَاونْ ن دّنْفِيڒَاثْ، ذ ؤُكشُّوضْ ن \add ثْشجَّارْثْ ن\add* ؤُكَاسِييَا، \f ◼ \fr 25:‏5 \ft \bd ’أَكَاسِييَا‘\bd* - إِشْثْ ن ثْشجَّارْثْ س ؤُكشُّوضْ إِقسْحنْ أَطَّاسْ. ثتّْوَافْ ثْشجَّارْثْ-أَ أَطَّاسْ ذِي ڒخْڒَا ن سِينَايِي. س ثعْرَابْثْ قَّارنْ أَسْ ’سَنْط‘.\f*
\v 6 زّشْثْ إِ ثْفَاوْثْ ن ڒْقنْذِيڒْ، ڒعْطُورْ إِ زّشْثْ ن وذْهَانْ ؤُ إِ ڒبْخُورْ إِتّْفُوحنْ،
\v 7 إِژْرَا ن ؤُنِيكْسْ ذ إِژْرَا \add إِغْڒَانْ نّغْنِي\add*، مَاحنْذْ أَذْ ثنْ ڭّنْ خْ ؤُپَالْطُو ؤُ خْ ثَاجْمشْثْ. \x ◘ \xo 25:‏7 \xt ؤُف. 28‏:‏4‏-‏14\x*
\m 
\v 8 أَذْ أَيِي ڭّنْ \bd إِشْثْ ن زَّاوشْثْ إِقدّْسنْ\bd*، حِيمَا أَذْ زذْغغْ ذِي ڒْوسْطْ نْسنْ.
\v 9 أَذْ \add ث\add* ثڭّذْ أَمْ مَارَّا مِينْ ذ أَشْ غَا سّشْنغْ، \add عْلَاحْسَابْ\add* أَمذْيَا ن ثْزذِّيغْثْ ؤُ \add عْلَاحْسَابْ\add* أَمذْيَا ن مَارَّا ڒقْشُوعْ إِ ذَايسْ إِدْجَانْ.
\m 
\v 10 أَذْ ڭّنْ عَاوذْ إِشْثْ ن \bd تَّابُوثْ\bd* ن ؤُكشُّوضْ ن \add ثْشجَّارْثْ ن\add* ؤُكَاسِييَا. أَذْ ثِيڒِي ثُوزّڭَّارْثْ \add نّسْ\add* ثْنَاينْ ن إِغَادْجنْ ذ وزْينْ ؤُ ثِيرُو \add نّسْ\add* إِجّْ ن ؤُغِيڒْ ذ وزْينْ ؤُ ڒُوعْڒَا \add نّسْ\add* إِجّْ ن ؤُغِيڒْ ذ وزْينْ. \x ◘ \xo 25:‏10 \xt ؤُف. 37‏:‏1؛ عبر. 9‏:‏1\x*
\v 11 أَذْ ث تّْشلّذْ س وُورغْ إِصْفَانْ، زِي ذَاخڒْ ؤُ زِي بَارَّا أَذْ ت ثْشلّذْ، ؤُشَا غَارْ سنّجْ أَذْ أَسْ ثنّْضذْ إِجّْ ن زّْوَاقْ ن وُورغْ.
\v 12 أَذْ أَسْ ثسّْفسْيذْ أَربْعَا ن ثخْرَازِينْ ن وُورغْ. أَذْ ثنْثْ ثْشدّذْ غَارْ أَربْعَا ن ثْيَارْسَاوِينْ نّسْ. ثْنَاينْ ن ثخْرَازِينْ أَذْ إِڒِينْثْ غَارْ يِيجّْ ن ؤُغزْذِيسْ ؤُ ثْنَاينْ ن ثخْرَازِينْ إِ ؤُغزْذِيسْ نّغْنِي.
\v 13 أَذْ ثڭّذْ إِعُومَاذْ \add إِ ثْربُّوثْ\add* زڭْ ؤُكشُّوضْ ن \add ثْشجَّارْثْ ن\add* ؤُكَاسِييَا ؤُشَا أَذْ ثنْ ثذْڒذْ س وُورغْ.
\v 14 سِيذْفمْ إِعُومَاذْ ذِي ثخْرَازِينْ نِّي إِدْجَانْ غَارْ إِغزْذِيسنْ ن تَّابُوثْ، حِيمَا أَذْ زَّايْسنْ أَرْبُونْ تَّابُوثْ.
\v 15 إِعُومَاذْ أَذْ إِڒِينْ ذِي ثخْرَازِينْ ن تَّابُوثْ، وَارْ زَّايْسنْثْ ثنْ تّكّْسنْ شَا. \x ◘ \xo 25:‏15 \xt 1 إِج. 8‏:‏8\x*
\v 16 أَذْ ثسَّارْسذْ شّْهَاذثْ، ثنِّي إِ ذ أَشْ غَا وْشغْ، ذِي تَّابُوثْ. \x ◘ \xo 25:‏16 \xt عبر. 9‏:‏4\x*
\v 17 أَذْ ثڭّذْ عَاوذْ إِشْثْ ن \bd ثْقبَّارْثْ ن وصْڒَاحْ\bd* ن وُورغْ إِصْفَانْ س يِيشْثْ ن ثُوزّڭَّارْثْ ن ثْنَاينْ ن إِغَادْجنْ ذ وزْينْ ؤُ س إِشْثْ ن ثِيرُو ن إِجّْ ن ؤُغِيڒْ ذ وزْينْ. \f ◼ \fr 25:‏17 \ft \bd ’ثَاقبَّارْثْ ن وصْڒَاحْ‘\bd* - حِيمَا أَذْ ثْفهْمذْ كْثَارْ مِينْ إِخْسْ أَذْ يِينِي أَوَاڒْ-أَ، خْزَارْ لَاوِي 16:14، 15 ؤُڒَا ذِي ڒخْڒَا 7:89.\f*  \x ◘ \xo 25:‏17 \xt ؤُف. 37‏:‏6\x*
\v 18 أَذْ ثڭّذْ عَاوذْ \bd ثْنَاينْ ن إِكِيرُوبنْ\bd* ن وُورغْ إِعْذڒْ س وفْضِيسْ، أَڒَامِي إِ غَا فّْغنْ \add إِكِيرُوبنْ\add* زِي ثْنَاينْ ن إِخْفَاونْ ن ثْقبَّارْثْ ن وصْڒَاحْ. \f ◼ \fr 25:‏18 \ft \bd ’إِكِيرُوبنْ‘\bd* - إِشْثْ ن مَارْكَا ن لْمَالَاكَاثْ.\f*  \x ◘ \xo 25:‏18 \xt عبر. 9‏:‏5\x*
\v 19 أَذْ ثڭّذْ إِجّْ ن ؤُكِيرُوبْ غَارْ إِجّْ ن يِيخفْ ؤُ إِجّْ ن ؤُكِيرُوبْ نّغْنِي غَارْ يِيخفْ نّغْنِي. أَذْ ثڭّمْ إِكِيرُوبنْ زِي ثْقبَّارْثْ ن وصْڒَاحْ غَارْ ثْنَاينْ ن إِخْفَاونْ نّسْ.
\v 20 أَذْ بزّْعنْ إِكِيرُوبنْ أَفْرِيونْ نْسنْ سنّجْ نْسنْ ؤُشَا أَذْ ذْڒنْ ثَاقبَّارْثْ ن وصْڒَاحْ س وَافْرِيونْ نْسنْ. ؤُذْمَاونْ نْسنْ أَذْ إِڒِينْ إِجّْ قِيبَاتْشْ إِ ونّغْنِي ؤُشَا أَذْ ژَترنْ ؤُذْمَاونْ ن إِكِيرُوبنْ غَارْ ثْقبَّارْثْ ن وصْڒَاحْ. \x ◘ \xo 25:‏20 \xt عبر. 9‏:‏5\x*
\v 21 أَذْ ثڭّذْ ثَاقبَّارْثْ ن وصْڒَاحْ خْ تَّابُوثْ ؤُشَا أَذْ ثسَّارْسذْ شّْهَاذثْ إِ ذ أَشْ غَا وْشغْ ذِي تَّابُوثْ. \x ◘ \xo 25:‏21 \xt عبر. 9‏:‏4، 5\x*
\v 22 ذِينِّي إِ كِيشْ غَا مّڒْقِيغْ ؤُشَا أَذْ كِيكْ سِّيوْڒغْ زِي سنّجْ إِ ثْقبَّارْثْ ن وصْڒَاحْ، زِي جَارْ ثْنَاينْ ن إِكِيرُوبنْ نِّي إِدْجَانْ سنّجْ إِ تَّابُوثْ ن شّْهَاذثْ، خْ مَارَّا مِينْ ذ أَشْ غَا ؤُمُورغْ إِ أَيْثْ ن إِسْرَائِيل. \x ◘ \xo 25:‏22 \xt ڒخْڒ. 7‏:‏89\x*
\m 
\v 23 أَذْ ثڭّذْ إِشْثْ ن \bd ثْزوْضَا\bd* ن ؤُكشُّوضْ ن \add ثْشجَّارْثْ ن\add* ؤُكَاسِييَا، أَذْ غَارسْ ثِيڒِي إِشْثْ ن ثُوزّڭَّارْثْ ن ثْنَاينْ ن إِغَادْجنْ ذ إِشْثْ ن ثِيرُو ن إِجّنْ ؤُغِيڒْ ذ إِجّْ ن ڒُوعْڒَا ن إِجّنْ ؤُغِيڒْ ذ وزْينْ.
\v 24 أَذْ ت ثذْڒذْ س وُورغْ إِصْفَانْ ؤُشَا أَذْ أَسْ ثڭّذْ غَارْ ثْمَا نّسْ إِجّْ زّْوَاقْ ن وُورغْ.
\v 25 أَذْ ثڭّذْ إِشْثْ ن ثْمَا إِ ذ أَسْ د-إِنّْضنْ ن إِجّنْ شْبَارْ ن ؤُفُوسْ ؤُ غَارْ ثْمَا إِ ذ أَسْ د-إِنّْضنْ أَذْ ثڭّذْ إِجّْ ن زّْوَاقْ ن وُورغْ.
\v 26 أَذْ ثڭّذْ أَربْعَا ن ثخْرَازِينْ ن وُورغْ ؤُشَا أَذْ ثنْثْ ثْشدّذْ غَارْ أَربْعَا ن ثْغمُّورَا نِّي إِدْجَانْ غَارْ أَربْعَا ن إِضَارنْ نْسنْ.
\v 27 ثِيخْرَازِينْ أَذْ إِڒِينْثْ ؤُذْسنْثْ إِ ثْمَا، مَاحنْذْ أَذْ \add ذَايْسنْثْ\add* تّْوَاطّْفنْ إِعُومَاذْ إِ ثَاربُّوثْ ن ثْزوْضَا.
\v 28 أَذْ ثڭّذْ إِعُومَاذْ \add إِ ثَاربُّوثْ\add* زڭْ ؤُكشُّوضْ ن \add ثْشجَّارْثْ ن\add* ؤُكَاسِييَا، أَذْ ثنْ ثْغدْجْفذْ س وُورغْ ؤُشَا أَذْ زَّايْسنْ أَرْبُونْ ثَازوْضَا.
\v 29 أَذْ ثڭّذْ عَاوذْ طّْبَاصِي نّسْ ذ ثْغنْجَايِينْ نّسْ ذ إِغَارَّافنْ نّسْ ذ ڒْكِيسَانْ نّسْ إِ زِي غَا فَارّْغنْ. أَذْ ثنْ ثڭّذْ س وُورغْ إِصْفَانْ.
\m 
\v 30 خْ ثْزوْضَا أَذْ ثڭّذْ \bd أَغْرُومْ ن وسْشَانْ\bd* ڒبْذَا زَّاثْ إِ وُوذمْ إِنُو.
\m 
\v 31 أَذْ ثڭّذْ \bd ڒْقنْذِيڒْ\bd* س وُورغْ إِصْفَانْ. أَذْ ثڭّذْ ڒْقنْذِيڒْ س وفْضِيسْ ن ومْزِيڒْ. أَفُوذْ أَكْ-ذ ؤُضَارْ نّسْ ذ إِغَادْجنْ نّسْ ؤُڒَا ذ ڒْكِيسَانْ نّسْ ذ ثْعبُّوزِينْ نّسْ إِ د-إِتَّاسنْ أَكْ-ذ نُّووَّارَاثْ نّسْ أَذْ إِڒِينْ ذ أَغزْذِيسْ ذ إِجّْ. \x ◘ \xo 25:‏31 \xt ؤُف. 37‏:‏17\x*
\v 32 ستَّا ن إِغَادْجنْ أَذْ د-فّْغنْ زڭْ إِغزْذِيسنْ نّسْ، ثْڒَاثَا ن إِغَادْجنْ زڭْ إِجّْ ن ؤُغزْذِيسْ نْ ڒْقنْذِيڒْ ذ ثْڒَاثَا ن إِغَادْجنْ زڭْ ؤُغزْذِيسْ نّغْنِي ن ڒْقنْذِيڒْ.
\v 33 ثْڒَاثَا ن ڒْكِيسَانْ \add أَذْ إِڒِينْ\add* ذڭْ إِجّْ ن ؤُغِيڒْ ذِي فُورْمَا ن نُّووَّارَاثْ ن دْجوْزْ \add أَكْ-ذ\add* ثْعبُّوزْثْ ذ نّوَّاشْ، ؤُشَا \add عَاوذْ\add* غَارْ ؤُغِيڒْ نّغْنِي ثْڒَاثَا ن ڒْكِيسَانْ ذِي فُورْمَا ن نُّووَّارَاثْ ن دْجوْزْ \add أَكْ-ذ\add* ثْعبُّوزْثْ ذ نّوَّاشْ. أَمُّو \add إِ غَا ڭّنْ\add* مَارَّا ستَّا ن إِغَادْجنْ نِّي د-إِفّْغنْ زِي ڒْقنْذِيڒْ.
\v 34 غَارْ ڒْقنْذِيڒْ \add سِيمَانْثْ نّسْ أَذْ ذِينْ إِڒِينْ\add* أَربْعَا ن ڒْكِيسَانْ ذِي فُورْمَا ن نُّووَّارَاثْ ن دْجوْزْ، \add أَكْ-ذ\add* ثْعبُّوزِينْ نْسنْ إِ د-إِتَّاسنْ أَكْ-ذ نُّووَّارَاثْ نْسنْ.
\v 35 أَذْ \add ذِينْ\add* ثِيڒِي إِشْثْ ن ثْعبُّوزْثْ سَاذُو ثْيُويَا ن إِغَادْجنْ إِ زَّايسْ د-إِفّْغنْ ؤُ إِشْثْ ن ثْعبُّوزْثْ سَاذُو ثْيُويَا ن إِغَادْجنْ إِ زَّايسْ د-إِفّْغنْ \add أَوَارْنِي أَسْ\add*، ؤُ \add عَاوذْ\add* إِشْثْ ن ثْعبُّوزْثْ سَاذُو ثْيُويَا ن إِغَادْجنْ إِ زَّايسْ د-إِفّْغنْ \add أَوَارْنِي أَسْ\add*. \add أَمُّو إِ غَا يِيڒِي\add* إِ ستَّا ن إِغَادْجنْ إِ د-إِفّْغنْ زِي ڒْقنْذِيڒْ.
\v 36 ثِيعبُّوزِينْ \add نْسنْ\add* ذ إِغَادْجنْ نْسنْ أَذْ زَّايسْ-د فّْغنْ ؤُشَا مَارَّا أَيَا أَذْ يِيڒِي ذ إِشْثْ ن ڒْقشْعثْ ثتّْوَاعْذڒْ س وفْضِيسْ ن ومْزِيڒْ س وُورغْ إِصْفَانْ.
\v 37 أَذْ ثڭّذْ ستَّا ن ڒفْنَارَاثْ نّسْ ؤُشَا أَذْ سَّارْسنْ ڒفْنَارَاثْ نّسْ خْ ڒْقنْذِيڒْ، مَاحنْذْ أَذْ وْشنْثْ ثْفَاوْثْ غَارْ طَّارْفْ ن ؤُجمَّاضْ.
\v 38 ثِيجقَّاضِينْ \add ن ثفْثِيتْشْ\add* نّسْ ذ ثْمجْمَارِينْ نّسْ \add أَذْ إِڒِينْثْ\add* س وُورغْ إِصْفَانْ. \f ◼ \fr 25:‏38 \ft \bd ’ثِيجقَّاضِينْ‘\bd* - نِيغْ ’ثِينقَّاضِينْ‘.\f*
\v 39 أَذْ إِتّْوَاڭّْ \add ڒْْقنْذِيڒْ\add* زڭْ إِشْثْ ن ثَالِينْثْ ن وُورغْ إِصْفَانْ س مَارَّا ڒقْشُوعْ-أَ \add أَكِيذسْ\add*.
\v 40 ؤُشَا خْزَارْ، أَذْ ث ثڭّذْ أَمْ ؤُمذْيَا نّسْ، ونِّي إِ ذ أَشْ إِتّْوَامْڒنْ ذڭْ وذْرَارْ.“ \x ◘ \xo 25:‏40 \xt ڒخ. 7‏:‏44؛ عبر. 8‏:‏5\x*  *
\b
\b
\c 26
\m 
\v 1 ”أَذْ ثڭّذْ \bd ثَازذِّيغْثْ سعشْرَا ن ثْجَارْثِيڒِينْ س ڒقْطنْ أَزْذَاذْ إِمُوذنْ ؤُ س \bdit ؤُفِيڒُو\bdit* أَذحْمِي ذ ؤُرْجُووَانِي ذ ؤُزڭّْوَاغْ إِحذْقنْ، \bdit أَكْ-ذ\bdit* إِكِيرُوبنْ\bd*. أَذْ ثنْ ثڭّذْ \add أَمْ\add* ڒْخذْمثْ ن ؤُفنَّانْ. \x ◘ \xo 26:‏1 \xt ؤُف. 36‏:‏8\x*
\v 2 ثُوزّڭَّارْثْ ن يِيشْثْ ن ثْجَارْثِيڒْثْ أَذْ ثِيڒِي ثْمنْيَا ؤُ-عِيشْرِينْ ن إِغَادْجنْ ؤُ ثِيرُو ن يِيشْثْ ن ثْجَارْثِيڒْثْ أَربْعَا ن إِغَادْجنْ. مَارَّا ثِيجَارْثِيڒِينْ \add أَذْ غَارْسنْثْ يِيڒِي\add* ڒعْبَارْ ذ إِجّْ.
\v 3 خمْسَا ن ثْجَارْثِيڒِينْ أَذْ ثنْثْ سّْمُوننْ إِشْثْ أَكْ-ذ ثنّغْنِي ؤُ \add عَاوذْ\add* خمْسَا ن ثْجَارْثِيڒِينْ أَذْ ثنْثْ سّْمُوننْ إِشْثْ أَكْ-ذ ثنّغْنِي.
\v 4 غَارْ ثْمَا ن يِيشْثْ ن ثْجَارْثِيڒْثْ غَارْ طَّارْفْ مَانِي ت غَا سّْمُوننْ، أَذْ ثڭّذْ ثِيسَارَاوِينْ ثِيذحْمَانِينْ. أَمُّو إِ ثنْثْ غَا ثڭّذْ \add عَاوذْ\add* غَارْ ثْمَا ن ثْجَارْثِيڒْثْ \add نّغْنِي\add* غَارْ طَّارْفْ إِ غَارْ إِدْجَا ؤُسڒْقِي نّغْنِي.
\v 5 خمْسِينْ ن ثْسَارَاوِينْ إِ غَا ثڭّذْ ذڭْ إِشْثْ ن ثْجَارْثِيڒْثْ ؤُ خمْسِينْ ن ثْسَارَاوِينْ غَارْ طَّارْفْ ن ثْجَارْثِيڒْثْ نِّي غَارْ إِدْجَا ؤُسڒْقِي نّغْنِي، مَاحنْذْ ثِيسَارَاوِينْ أَذْ مّڒْقَانْثْ إِشْثْ أَكْ-ذ ثنّغْنِي.
\v 6 أَذْ ثڭّذْ عَاوذْ خمْسِينْ ن ثْسنَّارِينْ ن وُورغْ ؤُشَا أَذْ ثسّْمُونذْ ثِيجَارْثِيڒِينْ إِشْثْ أَكْ-ذ ثنّغْنِي س ثْسنَّارِينْ، مَاحنْذْ أَذْ ثذْوڒْ ذ إِشْثْ ن ثْزذِّيغْثْ.
\m 
\v 7 أَذْ ثڭّذْ عَاوذْ \bd ثِيجَاڒْثِيڒِينْ س شّْعَارْ ن إِغَايْضنْ\bd*، مَاحنْذْ أَذْ إِڒِينْثْ ذ إِجّْ ن ؤُقِيضُونْ خْ ثْزذِّيغْثْ. أَذْ ثڭّذْ \bd حِيطَاشْ ن ثْجَارْثِيڒِينْ\bd*. \x ◘ \xo 26:‏7 \xt ؤُف. 36‏:‏14\x*
\v 8 ثُوزّڭَّارْثْ ن إِشْثْ ن ثْجَارْثِيڒْثْ \add أَذْ ثِيڒِي\add* ثْڒَاثِينْ ن إِغَادْجنْ ؤُ ثِيرُو ن إِشْثْ ن ثْجَارْثِيڒْثْ \add أَذْ ثِيڒِي\add* أَربْعَا ن إِغَادْجنْ. حِيطْعَاشْ ن ثْجَارْثِيڒِينْ \add أَذْ غَارْسنْثْ يِيڒِي\add* ڒعْبَارْ ذ إِجّْ.
\v 9 أَذْ ثسّْمُونذْ خمْسَا ن ثْجَارْثِيڒِينْ وحّذْسنْثْ ذ ستَّا ن ثْجَارْثِيڒِينْ \add عَاوذْ\add* وحّذْسنْثْ. ثَاجَارْثِيڒْثْ وِيسّْ ستَّا أَذْ ت ثْضفْصذْ زَّاثْ إِ وُوذمْ ن ؤُقِيضُونْ.
\v 10 أَذْ ثڭّذْ خمْسِينْ ن ثْسَارَاوِينْ غَارْ ثْمَا ن يِيشْثْ ن ثْجَارْثِيڒْثْ غَارْ طَّارْفْ غَارْ ؤُسڒْقِي، ؤُشَا خمْسِينْ ن ثْسَارَاوِينْ خْ ثْمَا ن ثْجَارْثِيڒْثْ غَارْ ؤُسڒْقِي نّغْنِي.
\v 11 أَذْ ثڭّذْ خمْسِينْ ن ثْسنَّارِينْ ن نّْحَاسْ ؤُشَا أَذْ ثنْثْ ثسِّيذْفذْ ذِي ثْسَارَاوِينْ ؤُشَا أَذْ ثسّْمُونذْ أَقِيضُونْ، مَاحنْذْ أَذْ يِيڒِي ذ إِجّنْ.
\v 12 مِينْ إِشطّنْ ن ثْجَارْثِيڒِينْ ن ؤُقِيضُونْ، أَزْينْ ن ثْجَارْثِيڒْثْ نِّي إِشطّنْ أَذْ يَايڒْ غَارْ ضفَّارْ ن ثْزذِّيغْثْ.
\v 13 زِي مِينْ إِشطّنْ ذِي ثُوزّڭَّارْثْ ن ثْجَارْثِيڒِينْ، إِجّْ ن ؤُغِيڒْ أَذْ يَايڒْ غَارْ يِيجّْ ن طَّارْفْ ذ إِجّْ ن ؤُغِيڒْ غَارْ طَّارْفْ نّغْنِي، غَارْ ثْنَاينْ ن إِغزْذِيسنْ ن ثْزذِّيغْثْ، مَاحنْذْ أَذْ أَسْ إِڒحّفْ إِ يِيجّْ \add ن ؤُغزْذِيسْ\add* ؤُ إِ \add ؤُغزْذِيسْ\add* نّغْنِي.
\m 
\v 14 أَذْ ثڭّذْ إِ ؤُقِيضُونْ \add عَاوذْ\add* \bd إِشْثْ ن ثْسقَّافْثْ ن إِڒْمَاونْ إِزڭّْوَاغنْ ن إِشَارِّييّنْ\bd* ؤُ سنّجْ إِ مَانْ أَيَا \bd إِشْثْ ن ثْسقَّافْثْ ن إِڒْمَاونْ ن دّنْفِيڒَاثْ.\bd*
\m 
\v 15 أَذْ ثڭّذْ إِ ثْزذِّيغْثْ \bd ثِيفڒْوِينْ ن ؤُكشُّوضْ\bd* ن \add ثْشجَّارْثْ ن\add* ؤُكَاسِييَا نِّي إِبدّنْ نِيشَانْ.
\v 16 ڒعْبَارْ ن ثُوزّڭَّارْثْ ن إِشْثْ ن ثفْڒَاوْثْ ذَايسْعشْرَا ن إِغَادْجنْ ؤُ ڒعْبَارْ ن ثِيرُو ن إِشْثْ ن ثفْڒَاوْثْ ذَايسْ إِجّْ ن ؤُغِيڒْ ذ وزْينْ.
\v 17 إِ كُوڒْ ثَافْڒَاوْثْ أَذْ غَارسْ إِڒِينْ ثْنَاينْ ن إِضَارنْ، إِنِّي إِسّْمڒْقَانْ ثْوتْشْمَاثِينْ إِشْثْ أَكْ-ذ ثنّغْنِيثْ، أَمُّو إِ غَا ثڭّذْ إِ مَارَّا ثِيفڒْوِينْ ن ثْزذِّيغْثْ.
\v 18 أَذْ ثڭّذْ إِ ثْزذِّيغْثْ \bd ثِيفڒْوِينْ\bd*، عِيشْرِينْ ن ثْفڒْوِينْ غَارْ جِّيهثْ ن لْجَانُوبْ، غَارْ يفُوسْ.
\v 19 أَذْ ثڭّذْ أَربْعِينْ ن \bd ثْيَارْسَاوِينْ ن نُّوقَارْثْ\bd* \add مَاحنْذْ أَذْ ثنْثْ سَّارْسنْ\add* سَاذُو عِيشْرِينْ ن ثْفڒْوِينْ، ثْنَاينْ ن ثْيَارْسَاوِينْ سَاذُو إِشْثْ ن ثفْڒَاوْثْ إِ ثْنَاينْ ن إِضَارنْ نّسْ، ذ ثْنَاينْ ن ثْيَارْسَاوِينْ سَاذُو ثَافْڒَاوْثْ نّغْنِي إِ ثْنَاينْ ن إِضَارنْ نّسْ.
\v 20 \add عَاوذْ أَذْ ثڭّذْ\add* عِيشْرِينْ ن ثْفڒْوِينْ إِ ؤُغزْذِيسْ نّغْنِي ن ثْزذِّيغْثْ، غَارْ جِّيهثْ ن شَّامَالْ،
\v 21 س أَربْعِينْ ن ثْيَارْسَاوِينْ نْسنْ ن نُّوقَارْثْ: ثْنَاينْ ن ثْيَارْسَاوِينْ إِ كُوڒْ ثَافْڒَاوْثْ ذ ثْنَاينْ ن ثْيَارْسَاوِينْ سَاذُو ثَافْڒَاوْثْ نّغْنِي.
\v 22 ؤُ غَارْ ؤُغزْذِيسْ ن ڒْغَارْبْ ن ثْزذِّيغْثْ أَذْ أَسْ ثڭّذْ ستَّا ن ثْفڒْوِينْ.
\v 23 أَذْ ثڭّذْ ثْنَاينْ ن ثْفڒْوِينْ إِ ثْغمُّورَا ن ثْزذِّيغْثْ إِ إِدْجَانْ غَارْ ثْنَاينْ ن إِغزْذِيسنْ ن ضفَّارْ.
\v 24 زِي سْوَادَّايْ أَذْ إِڒِينْثْ صْقنْثْ أَمْ وَاشْنِيونْ ؤُشَا أَمُّو إِ غَا إِڒِينْثْ نِيشَانْ ذ إِشْثنْ أَڒْ غَا أَوْضنْثْ سنّجْ ذڭْ إِشْثْ ن ثخْرَازْثْ. أَمُّو إِ غَا يِيڒِي إِ ثْنَاينْ \add ن ثْفڒْوِينْ\add* غَارْ ثْنَاينْ ن ثْغمُّورَا.
\v 25 أَذْ \add ذِينْ\add* إِڒِينْثْ ثْمنْيَا ن ثْفڒْوِينْ أَكْ-ذ ثْيَارْسَاوِينْ نْسنْثْ ن نُّوقَارْثْ. \add خنِّي\add* سطَّاشْ ن ثْيَارْسَاوِينْ، ثْنَاينْ ن ثْيَارْسَاوِينْ سَاذُو إِشْثْ ن ثفْڒَاوْثْ ذ ثْنَاينْ ن ثْيَارْسَاوِينْ سَاذُو ثَافْڒَاوْثْ نّغْنِي.
\m 
\v 26 أَذْ ثڭّذْ \bd ثِيحنْيَا ن ؤُعَارّضْ\bd* زڭْ ؤُكشُّوضْ ن \add ثْشجَّارْثْ ن\add* ؤُكَاسِييَا، \add إِنِّي غَا إِعْذُونْ خْ ثْفڒْوِينْ\add*، خمْسَا إِ ثْفڒْوِينْ ن إِجّْ ن ؤُغزْذِيسْ ن ثْزذِّيغْثْ
\v 27 ؤُ خمْسَا ن ثْحنْيَا ن ؤُعَارّضْ إِ ثْفڒْوِينْ غَارْ ؤُغزْذِيسْ نّغْنِي ن ثْزذِّيغْثْ ؤُ خمْسَا ن ثْحنْيَا ن ؤُعَارّضْ إِ ثْفڒْوِينْ ن ؤُغزْذِيسْ ن ثْزذِّيغْثْ غَارْ ؤُغزْذِيسْ ن ڒْغَارْبْ غَارْ ثْنَاينْ ن إِغزْذِيسنْ ن ضفَّارْ.
\v 28 ثَاحْنَاشْثْ ن ؤُعَارّضْ ذِي ڒْوسْطْ أَذْ ثعْذُو خْ ثْفڒْوِينْ ذِي ڒْوسْطْ، زڭْ إِجّْ ن يِيخفْ غَارْ ونّغْنِي.
\v 29 أَذْ ثْغدْجْفذْ ثِيفڒْوِينْ س وُورغْ ؤُشَا أَذْ ثڭّذْ ثِيخْرَازِينْ نْسنْ ن وُورغْ، مَاحنْذْ أَذْ ذَايْسنْثْ سِّيذْفنْ ثِيحنْيَا ن ؤُعَارّضْ. أَذْ ثذْڒذْ \add عَاوذْ\add* ثِيحنْيَا ن ؤُعَارّضْ س وُورغْ.
\v 30 أَذْ ثسّْڭعّْذذْ ثَازذِّيغْثْ عْلَاحْسَابْ أَمذْيَا \add ن ڒبْنِي\add* نِّي ذ أَشْ إِتّْوَامْڒنْ خْ وذْرَارْ. \x ◘ \xo 26:‏30 \xt ؤُف. 25‏:‏9،40؛ ڒخ. 7‏:‏44؛ عبر. 8‏:‏5\x*
\m 
\v 31 أَذْ ثڭّضْ إِجّْ ن \bd ؤُڒحَّافْ\bd* س \add ؤُفِيڒُو\add* أَذحْمِي ذ ؤُرْجُووَانِي ذ ؤُزڭّْوَاغْ إِحذْقنْ ؤُ س ڒقْطنْ أَزْذَاذْ إِمُوذنْ، أَذْ ث ڭّنْ \add أَمْ\add* ڒْخذْمثْ ن ؤُفنَّانْ، ؤُشَا إِكِيرُوبنْ \add أَذْ خَاسْ إِڒِينْ\add*. \x ◘ \xo 26:‏31 \xt ؤُف. 36‏:‏35\x*
\v 32 أَذْ ث ثَايْڒذْ خْ أَربْعَا ن إِپِيلَارنْ ن ؤُكشُّوضْ ن \add ثْشجَّارْثْ ن\add* ؤُكَاسِييَا إِ إِذْڒِينْ س وُورغْ. ثِيسنَّارِينْ نْسنْ \add أَذْ إِڒِينْثْ\add* ن وُورغْ ؤُشَا \add إِپِيلَارنْ نِّي\add* \add أَذْ بدّنْ\add* خْ أَربْعَا ن ثْيَارْسَاوِينْ ن نُّوقَارْثْ.
\v 33 أَذْ ثَايْڒذْ أَڒحَّافْ غَارْ وَادَّايْ ن ثْسنَّارِينْ ؤُشَا أَذْ ثسِّيذْفذْ تَّابُوثْ ن شّْهَاذثْ ذَاخڒْ إِ ؤُڒحَّافْ ؤُشَا أَڒحَّافْ أَذْ إِبْضَا جَارْ ؤُقدَّاسْ ذ وقْذَاسْ خْ ؤُقدَّاسْ.
\m 
\v 34 أَذْ ثسَّارْسذْ ثَاقبَّارْثْ ن وصْڒَاحْ خْ تَّابُوثْ ن شّْهَاذثْ ذڭْ وقْذَاسْ خْ ؤُقدَّاسْ.
\m 
\v 35 أَذْ ثڭّذْ ثَازوْضَا بَارَّا إِ ؤُڒحَّافْ ؤُشَا أَذْ ثسَّارْسذْ ڒْقنْذِيڒْ قِيبَاتْشْ إِ ثْزوْضَا غَارْ ؤُغزْذِيسْ ن ثْزذِّيغْثْ غَارْ جِّيهثْ ن لْجَانُوبْ ؤُ أَذْ ثڭّذْ ثَازوْضَا غَارْ ؤُغزْذِيسْ غَارْ جِّيهثْ ن شَّامَالْ.
\m 
\v 36 أَذْ ثڭّذْ \bd أَرْوَاقْ\bd* س \add ؤُفِيڒُو\add* أَذحْمِي ذ ؤُرْجُووَانِي ذ ؤُزڭّْوَاغْ إِحذْقنْ ؤُ س ڒقْطنْ أَزْذَاذْ إِمُوذنْ إِ وَاذَافْ ن ؤُقِيضُونْ، \add أَمْ\add* إِجّْ ن ؤُمُوذِي ن ؤُخيَّاضْ. \x ◘ \xo 26:‏36 \xt ؤُف. 36‏:‏37\x*
\v 37 ؤُشَا أَذْ ثڭّذْ إِ أَرْوَاقْ خمْسَا ن إِپِيلَارنْ ن ؤُكشُّوضْ ن \add ثْشجَّارْثْ ن\add* ؤُكَاسِييَا ؤُشَا أَذْ ثنْ ثْشلّذْ س وُورغْ. ثِيسنَّارِينْ نْسنْ أَذْ إِڒِينْثْ ن وُورغْ ؤُ \add إِ إِپِيلَارنْ نِّي\add* أَذْ أَسنْ ثْفسْيذْ خمْسَا ن ثْيَارْسَاوِينْ ن نّْحَاسْ.“ *
\b
\b
\c 27
\m 
\v 1 ”أَذْ ثڭّذْ \bd أَعَالْطَارْ\bd* ن ؤُكشُّوضْ ن ؤُكَاسِييَا ن خمْسَا ن إِغَادْجنْ ذِي ثُوزّڭَّارْثْ ذ خمْسَا ن إِغَادْجنْ ذِي ثِيرُو. أَذْ يِيڒِي س أَربْعَا ن ثْغمُّورَا ؤُ ڒُوعْڒَا نّسْ \add أَذْ يِيڒِي\add* ثْڒَاثَا ن إِغَادْجنْ. \x ◘ \xo 27:‏1 \xt ؤُف. 38‏:‏1\x*
\v 2 غَارْ أَربْعَا ن ثْغمُّورَا أَذْ ثڭّذْ أَشَّاونْ نّسْ. أَشَّاونْ نّسْ أَذْ ذوْڒنْ ذ إِجّنْ أَكِيذسْ ؤُشَا أَذْ ث ثْڒحّْفذْ س نّْحَاسْ. \f ◼ \fr 27:‏2 \ft \bd ’أَشَّاونْ‘\bd* - نِيغْ ’إِقِيشَّاونْ‘.\f*
\v 3 أَذْ ثڭّذْ ثِييْذُورِينْ نّسْ، حِيمَا أَذْ ذَايْسنْثْ ثنْضَارذْ إِغّضْ ن مِينْ إِقِّيمنْ ن ثَاذُونْثْ نّسْ إِتّْوَاشمْضنْ ؤُشَا \add أَذْ ثڭّذْ\add* عَاوذْ إِغنْجَاينْ نّسْ ذ طَّاوْيَاثْ نّسْ إِ ؤُرُوشِّي ذ فُورْشَايَاثْ نّسْ ذ ثْمجْمَارِينْ نّسْ. أَذْ ثڭّذْ مَارَّا ڒقْشُوعْ نّسْ س نّْحَاسْ.
\v 4 أَذْ ثڭّذْ إِشْثْ ن ثْرَاشَّا، إِشْثْ ن ؤُمُوذِي ن نّْحَاسْ، ؤُشَا أَذْ ثڭّذْ أَربْعَا ن ثخْرَازِينْ ن نّْحَاسْ إِ ؤُمُوذِي نِّي، غَارْ أَربْعَا ن ثْغمُّورَا نّسْ.
\v 5 أَذْ ث ثْزيَّارذْ سَاذُو إِ ثْمَا ن ؤُعَالْطَارْ، سْوَادَّايْ، \add مَاحنْذْ\add* أَذْ يِيڒِي ؤُمُوذِي \add ن نّْحَاسْ نِّي\add* غَارْ وزْينْ ن ؤُعَالْطَارْ.
\v 6 أَذْ ثڭّذْ إِعُومَاذْ \add إِ ثَاربُّوثْ\add* إِ ؤُعَالْطَارْ، إِعُومَاذْ ن ؤُكشُّوضْ ن ؤُكَاسِييَا ؤُشَا أَذْ ثنْ ثْڒحّْفذْ س نّْحَاسْ.
\v 7 إِعُومَاذْ نّسْ أَذْ تّْوَاسِّيذْفنْ ذِي ثخْرَازِينْ. أَذْ إِڒِينْ إِعُومَاذْ \add إِ ثَاربُّوثْ\add* غَارْ ثْنَاينْ ن إِغزْذِيسنْ ن ؤُعَالْطَارْ خْمِي \add ث\add* غَا أَرْبُونْ.
\v 8 أَذْ ثڭّذْ إِجّْ ن ڒْخَاوِي \add غَارْ ذَاخڒْ\add* ن ثْفڒْوِينْ. أَمْ مَامّشْ إِ ذ أَشْ إِمْڒَا خْ وذْرَارْ، أَمُّو إِ \add ث\add* غَا ڭّنْ نِيثْنِي.
\m 
\v 9 أَذْ ثڭّذْ \bd ڒمْرَاحْ\bd* ن ثْزذِّيغْثْ. غَارْ جِّيهثْ ن لْجَانُوبْ، غَارْ يفُوسْ، أَذْ ثڭّذْ ڒِيزَارَاثْ س ڒقْطنْ أَزْذَاذْ إِمُوذنْ، \add كُوڒْ إِشْثْ زَّايْسنْثْ\add* ن مْيَا ن إِغَادْجنْ ذِي ثُوزّڭَّارْثْ إِ يِيجّْ ن ؤُغزْذِيسْ. \x ◘ \xo 27:‏9 \xt ؤُف. 38‏:‏9\x*
\v 10 عِيشْرِينْ ن إِپِيلَارنْ نّسْ ذ عِيشْرِينْ ن ثْيَارْسَاوِينْ نّسْ \add أَذْ إِڒِينْ\add* ن نّْحَاسْ. ثِيسنَّارِينْ ن إِپِيلَارنْ ذ إِقضْبَانْ نْسنْ إِ ؤُسڒْقِي \add أَذْ إِڒِينْ\add* ن نُّوقَارْثْ.
\v 11 أَمُّو غَارْ جِّيهثْ ن شَّامَالْ، ذِي ثُوزّڭَّارْثْ، \add أَذْ ذِينْ إِڒِينْثْ\add* ڒِيزَارَاثْ ن مْيَا \add إِغَادْجنْ\add*. أَذْ إِڒِينْ عِيشْرِينْ ن إِپِيلَارنْ نْسنْثْ ذ عِيشْرِينْ ن ثْيَارْسَاوِينْ نْسنْ ن نّْحَاسْ. ثِيسنَّارِينْ ن إِپِيلَارنْ ذ إِقضْبَانْ نْسنْ إِ ؤُسڒْقِي \add أَذْ إِڒِينْ\add* ن نُّوقَارْثْ.
\v 12 ذِي ثِيرُو ن ڒمْرَاهْ، غَارْ ؤُغزْذِيسْ ن ڒْغَارْبْ، \add أَذْ ذِينْ إِڒِينْثْ\add* ڒِيزَارَاثْ ن خمْسِينْ ن إِغَادْجنْ \add ذِي ثُوزّڭَّارْثْ\add* أَكْ-ذعشْرَا ن إِپِيلَارنْ نْسنْثْ ذعشْرَا ن ثْيَارْسَاوِينْ نْسنْ.
\v 13 ثِيرُو ن ڒمْرَاحْ غَارْ ؤُغزْذِيسْ ن شَّارْقْ، زِي مَانِيسْ د-ثْنقَّارْ ثْفُوشْثْ، \add أَذْ ثِيڒِي\add* خمْسِينْ \add إِغَادْجنْ\add*.
\v 14 ڒِيزَارَاثْ غَارْ \add يِيجّْ\add* ن ؤُغزْذِيسْ ن زَّاثْ \add أَذْ إِڒِينْثْ\add* خمّسْطَاشْ ن إِغَادْجنْ \add ذِي ثُوزّڭَّارْثْ\add*، أَكْ-ذ ثْڒَاثَا ن إِپِيلَارنْ نْسنْثْ ذ ثْڒَاثَا ن ثْيَارْسَاوِينْ نْسنْ.
\v 15 غَارْ ؤُغزْذِيسْ ن زَّاثْ نّغْنِي \add أَذْ ذِينْ إِڒِينْثْ عَاوذْ\add* ڒِيزَارَاثْ ن خمّسْطَاشْ ن إِغَادْجنْ \add ذِي ثُوزّڭَّارْثْ\add* أَكْ-ذ ثْڒَاثَا ن إِپِيلَارنْ نْسنْثْ ذ ثْڒَاثَا ن ثْيَارْسَاوِينْ نْسنْ.
\v 16 غَارْ وَاذَافْ ن ڒمْرَاحْ \add أَذْ ذِينْ يِيڒِي\add* إِجّْ ن أَرْوَاقْ ن عِيشْرِينْ ن إِغَادْجنْ، \add ڭِّينْ ث\add* س \add ؤُفِيڒُو\add* أَذحْمِي ذ ؤُرْجُووَانِي ذ ؤُزڭّْوَاغْ إِحذْقنْ ؤُ س ڒقْطنْ أَزْذَاذْ إِمُوذنْ، إِجّْ ن ؤُمُوذِي ن ؤُخيَّاضْ، أَكْ-ذ أَربْعَا ن إِپِيلَارنْ نّسْ ذ أَربْعَا ن ثْيَارْسَاوِينْ نْسنْ.
\v 17 مَارَّا إِپِيلَارنْ إِ ذ أَسْ د-إِنّْضنْ إِ ڒمْرَاحْ \add أَذْ إِڒِينْ\add* س إِقضْبَانْ ن نُّوقَارْثْ إِ ؤُسڒْقِي ؤُشَا ثِيسنَّارِينْ نْسنْ \add أَذْ إِڒِينْثْ\add* ن نُّوقَارْثْ ذ ثْيَارْسَاوِينْ نْسنْ ن نّْحَاسْ.
\v 18 ثُوزّڭَّارْثْ ن ڒمْرَاحْ \add أَذْ ثِيڒِي\add* مْيَا ن إِغَادْجنْ ؤُ ثِيرُو \add أَذْ ثِيڒِي\add* خمْسِينْ ن إِغَادْجنْ ذ خمْسِينْ \add عَاوذْ\add* ؤُشَا ڒُوعْڒَا \add أَذْ يِيڒِي\add* خمْسَا ن إِغَادْجنْ، \add مَارَّا\add* س ڒقْطنْ أَزْذَاذْ إِمُوذنْ ؤُشَا ثْيَارْسَاوِينْ نْسنْ \add أَذْ إِڒِينْثْ\add* ن نّْحَاسْ.
\m 
\v 19 مَارَّا \bd ڒقْشُوعْ ن ثْزذِّيغْثْ\bd* إِ إِدْجَانْ إِ مَارَّا ثَاسخَّارْثْ نّسْ ؤُڒَا ذ مَارَّا ڒوْثَاذْ نّسْ ذ مَارَّا ڒوْثَاذْ ن ڒمْرَاحْ \add أَذْ إِڒِينْ\add* ن نّْحَاسْ. *
\b
\m 
\v 20 أَذْ ثُومُورذْ أَيْثْ ن إِسْرَائِيل، حِيمَا أَذْ أَشْ د-أَوْينْ \bd زّشْثْ ثصْفَا ثدّزْ زِي زِّيثُونْ إِ ثْفَاوْثْ\bd*، حِيمَا أَذْ ثَارغْ ثْفَاوْثْ ڒبْذَا. \x ◘ \xo 27:‏20 \xt لَاوِي 24‏:‏2\x*
\v 21 هَارُونْ ذ وَارَّاوْ نّسْ أَذْ حْضَانْ مَانْ أَيَا زِي دْجِيڒثْ أَڒْ صّْبحْ زَّاثْ إِ وُوذمْ ن سِيذِي ذڭْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ زَّاثْ إِ ؤُڒحَّافْ إِ إِدْجَانْ زَّاثْ إِ شّْهَاذثْ. ذ مَانْ أَيَا أَذْ يِيڒِي ذ إِشْثْ ن ثوْصيّثْ إِ ڒبْذَا \add نِّي إِتّْخصَّا أَذْ ثتّْوَاحْضَا\add* زِي جِّيهثْ ن أَيْثْ ن إِسْرَائِيل ذِي \add مَارَّا\add* جِّيڒَاثْ نْسنْ.“
\b
\b
\c 28
\m 
\v 1 ”ؤُشَا شكْ أَذْ غَاركْ د-ثسّْقَارّْبذْ \bd هَارُونْ، ؤُمَاشْ، ذ وَارَّاوْ نّسْ أَكِيذسْ\bd* زِي ڒْوسْطْ ن أَيْثْ ن إِسْرَائِيل، حِيمَا \bd أَذْ أَيِيعبْذنْ أَمْ يِيكهَّاننْ\bd*، هَارُونْ، نَاذَابْ، أَبِيهُو، أَلِيعَازَارْ ذ إِثَامَارْ، زڭْ وَارَّاوْ ن هَارُونْ. \x ◘ \xo 28:‏1 \xt عبر. 5‏:‏4\x*
\m 
\v 2 أَذْ ثڭّذْ \bd أَرُّوضْ إِقدّْسنْ إِ هَارُونْ، ؤُمَاشْ\bd*، أَذْ \add أَسْ\add* يِيڒِي إِ ؤُعُودْجِي ذ ثلْوِيزْثْ.
\v 3 أَذْ ثسِّيوْڒذْ غَارْ مَارَّا إِنِّي إِدْجَانْ ذ إِمِيغِيسنْ ن وُوڒْ، إِنِّي شُّورغْ س أَرُّوحْ ن ثِيغِيثْ، \add مَاحنْذْ\add* أَذْ ڭّنْ أَرُّوضْ إِ هَارُونْ، حِيمَا أَذْ أَسْ سّْقدّْسنْ ذ أَكهَّانْ إِ نشّْ.
\v 4 إِنَا ذ أَرُّوضْ إِ غَا ڭّنْ: \bd إِشْثْ ن ثجْمشْثْ ذ إِجّْ ن ؤُپَالْطُو ذ إِجّْ ن ؤُسڒْهَامْ ذ إِشْثْ ثْشَامِيرْ إِمُوذنْ \bdit أَمْ\bdit* إِجّْ ن ؤُرقَّامْ ن ؤُفنَّانْ، ذ إِشْثْ ن أَرژّثْ ذ إِشْثْ ن ثْحزَّامْثْ\bd*. أَذْ ڭّنْ أَرُّوضْ إِقدّْسنْ إِ هَارُونْ، ؤُمَاشْ، ؤُ إِ وَارَّاوْ نّسْ، حِيمَا أَذْ أَيِي سخَّارنْ أَمْ ؤُكهَّانْ.
\v 5 نِيثْنِي أَذْ كْسِينْ \add إِفِيڒَانْ ن\add* وُورغْ ذ \add أَفِيڒُو\add* أَذحْمِي ذ ؤُرْجُووَانِي ذ ؤُزڭّْوَاغْ إِحذْقنْ ذ ڒقْطنْ أَزْذَاذْ،
\v 6 ؤُشَا أَذْ ڭّنْ أَپَالْطُو س \add إِفِيڒَانْ ن\add* وُورغْ ؤُ س \add ؤُفِيڒُو\add* أَذحْمِي ذ ؤُرْجُووَانِي ذ ؤُزڭّْوَاغْ إِحذْقنْ ؤُ س ڒقْطنْ أَزْذَاذْ إِمُوذنْ، \add أَذْ يِيڒِي\add* \add أَمْ\add* ڒْخذْمثْ ن ؤُفنَّانْ. \x ◘ \xo 28:‏6 \xt ؤُف. 39‏:‏2\x*
\v 7 أَذْ غَارسْ يِيڒِي ثْنَاينْ ن ثْغَارْضِينْ إِمّْسڒْسَاقنْ غَارْ ثْنَاينْ ن طّْرُوفَا نّسْ إِ زِي غَا إِتّْوَاسّْمُونْ \add ؤُپَالْطُو\add*.
\v 8 ثَاحزَّامْثْ إِزوّْقنْ، ونِّي إِدْجَانْ خْ ؤُپَالْطُو نّسْ ن ؤُكهَّانْ، أَذْ زَّايسْ ثتّْوَاڭّْ ذ إِشْثنْ أَكِيذسْ، س \add إِفِيڒَانْ ن\add* وُورغْ ؤُ س \add ؤُفِيڒُو\add* أَذحْمِي ذ ؤُرْجُووَانِي ذ ؤُزڭّْوَاغْ إِحذْقنْ ؤُ س ڒقْطنْ أَزْذَاذْ إِمُوذنْ.
\v 9 أَذْ ثكْسِيذْ ثْنَاينْ ن إِژْرَا ن ؤُنِيكْسْ ؤُشَا أَذْ خَاسنْ ثْنقْشذْ إِسْمَاونْ ن أَيْثْ ن إِسْرَائِيل.
\v 10 ستَّا ن إِسْمَاونْ خْ يِيجّْ ن وژْرُو ذ ستَّا ن إِسْمَاونْ نّغْنِي خْ وژْرُو نّغْنِي عْلَاحْسَابْ \add أَستّفْ ن\add* وخْڒَاقْ نْسنْ.
\v 11 \add ذ مَانْ أَيَا\add* ذ إِشْثْ ن صّنْعثْ ن ؤُنقَّاشْ ن وژْرُو \add إِغْڒَانْ\add*. أَمْ إِشْثْ ن ثْخَاذنْثْ ن ؤُشمِّيعْ، \add أَمُّو إِ\add* غَا تّْوَانقْشنْ ثْنَاينْ ن يژْرَا س إِسْمَاونْ ن أَيْثْ ن إِسْرَائِيل. أَذْ أَسنْ ثڭّذْ ثِيشُويَارْ ن وُورغْ إِ ذ أَسْ د-إِنّْضنْ.
\v 12 أَذْ ثڭّذْ إِژْرَا نِّي خْ ثْغَارْضِينْ ن ؤُپَالْطُو، \add أَقَا أَثنْ ذ\add* إِژْرَا ن ڒِيذَارثْ إِ أَيْثْ ن إِسْرَائِيل. هَارُونْ أَذْ يَارْبُو إِسْمَاونْ نْسنْ إِ ڒِيذَارثْ زَّاثْ إِ وُوذمْ ن سِيذِي خْ ثْنَاينْ ثْغَارْضِينْ نّسْ.
\v 13 أَذْ ثڭّذْ ثِيشُويَارْ ن وُورغْ
\v 14 ؤُشَا \add عَاوذْ\add* ثْنَاينْ ن سّْنَاسڒْ ن وُورغْ إِصْفَانْ. أَذْ ثنْ ثڭّذْ \add أَمشْنَاوْ\add* إِفِيڒَانْ، \add أَمشْنَاوْ\add* إِشْثْ ن ڒْخذْمثْ ن ؤُمُوذِي. أَذْ ثْشدّذْ سّْنَاسڒْ إِمُوذنْ غَارْ ثْشُويَارْ.
\m 
\v 15 أَذْ ثڭّذْ \bd ثَاجْمشْثْ\bd* إِ ڒحْكَامْ. أَذْ ت ثڭّذْ \add أَمْ\add* ڒْخذْمثْ ن ؤُفنَّانْ، أَمْ ؤُپَالْطُو \add ن ؤُكهَّانْ\add*. أَذْ ت ثڭّذْ س \add إِفِيڒَانْ ن\add* وُورغْ ؤُ س \add ؤُفِيڒُو\add* أَذحْمِي ذ ؤُرْجُووَانِي ذ ؤُزڭّْوَاغْ إِحذْقنْ ؤُ س ڒقْطنْ أَزْذَاذْ إِمُوذنْ. \x ◘ \xo 28:‏15 \xt ؤُف. 39‏:‏8\x*
\v 16 \add ثَاجْمشْثْ\add* أَذْ \add ثِيڒِي\add* س أَربْعَا ن ثْغمُّورَا، ثتّْوَاضْفصْ. ثُوزّڭَّارْثْ نّسْ أَذْ ثِيڒِي ذ إِجّْ ن وزْينْ ن ؤُغِيڒْ، ؤُ ثِيرُو نّسْ ذ إِجّْ ن وزْينْ ن ؤُغِيڒْ.
\v 17 أَذْ خَاسْ ثڭّذْ إِژْرَا، أَربْعَا ن ڒصْفُوفْ ن إِژْرَا. إِجّْ ن صّفْ \add أَذْ يِيڒِي س\add* يِيجّْ ن ڒعْقِيقْ ذ أَزڭّْوَاغْ ذ إِشْثْ ن ثْيَاقُوثْ ذ إِشْثْ ن سْمَارَاخْثْ. \add وَا\add* ذ صّفْ أَمزْوَارُو.
\v 18 صّفْ وِيسّْ ثْنَاينْ \add أَذْ يِيڒِي س\add* يِيجّْ ن كَارْبُونْكلْ ذ يِيجّْ ن صَافِّيرْ أَزِيزَا ذ يِيجّْ ن ذِيأَمَانْثِي.
\v 19 صّفْ وِيسّْ ثْڒَاثَا \add أَذْ يِيڒِي س\add* يِيجّْ ن \add وژْرُو ن\add* يَاسِينْثُو ذ يِيجّْ ن أَخَاثْ ذ يِيجّْ ن ؤُمَاثِيسْثْ.
\v 20 ؤُ صّفْ وِيسّْ أَربْعَا \add أَذْ يِيڒِي س\add* يِيشْثْ ن ثخْرِيسُولِيثْ ذ يِيجّْ ن ؤُنِيكْسْ ذ يِيجّْ ن يَاسْبِيسْ. إِنَا أَذْ تّْوَاطّْفنْ ذڭْ وُورغْ ذِي ثْشُويَارْ نْسنْ.
\v 21 إِژْرَا أَذْ خَاسنْ إِڒِينْ إِسْمَاونْ ن أَيْثْ ن إِسْرَائِيل، ثنْعَاشْ \add ن يژْرَا\add* عْلَاحْسَابْ إِسْمَاونْ نْسنْ، س إِنقَّاشنْ ن ثْخَاذنْثْ ن ؤُشمِّيعْ، كُوڒْ \add أَنقِّيشْ\add* عْلَاحْسَابْ إِسمْ نّسْ إِ ذ أَسْ د-يُوسِينْ. أَقَا أَثنْ إِ ثنْعَاشْ ن ثْقبَّاڒْ.
\v 22 أَذْ ثڭّذْ سّْنَاسڒْ خْ ثجْمشْثْ، إِفِيڒَانْ إِمُوذنْ ن وُورغْ إِصْفَانْ.
\v 23 أَذْ ثڭّذْ ثْنَاينْ ن ثخْرَازِينْ ن وُورغْ غَارْ ثجْمشْثْ ؤُشَا أَذْ ثْشدّذْ ثْنَاينْ ن ثخْرَازِينْ نِّي غَارْ ثْنَاينْ ن طّْرُوفَا ن ثجْمشْثْ.
\v 24 أَذْ ثْشدّذْ ثْنَاينْ ن سّْنَاسڒْ ن وُورغْ إِمُوذنْ غَارْ ثْنَاينْ ن ثخْرَازِينْ غَارْ ڒضْرُوفْ ن ثجْمشْثْ.
\v 25 أَذْ ثْشدّذْ ثْنَاينْ ن إِخْفَاونْ ن ثْنَاينْ ن \add سّْنَاسڒْ\add* إِمُوذنْ غَارْ ثْنَاينْ ن ثْشُويَارْ ؤُشَا أَذْ ثنْثْ ثْشدّذْ غَارْ ثْغَارْضِينْ \add إِ إِدْجَانْ\add* غَارْ ؤُغزْذِيسْ ن زَّاثْ ن ؤُپَالْطُو \add ن ؤُكهَّانْ\add*.
\v 26 أَذْ ثڭّذْ \add عَاوذْ\add* ثْنَاينْ ن ثخْرَازِينْ ن وُورغْ ؤُشَا أَذْ ثنْثْ ثڭّذْ غَارْ ثْنَاينْ ن إِخْفَاونْ ن ثجْمشْثْ \add غَارْ سْوَادَّايْ\add*، خْ ثْمَا نْسنْ \add نِّي إِدْجَانْ\add* غَارْ ؤُپَالْطُو، غَارْ ذَاخڒْ.
\v 27 أَذْ ثڭّذْ ثْنَاينْ ن ثخْرَازِينْ ن وُورغْ، ثِينِّي إِ غَا ثْشذْنذْ خْ ثْنَاينْ ن ثْغَارْضِينْ ن ؤُپَالْطُو \add ن ؤُكهَّانْ\add*، سْوَادَّايْ، غَارْ زَّاثْ، قِيبَاتْشْ إِ ؤُسڒْقِي نّسْ غَارْ سنّجْ إِ ثْحزَّامْثْ إِزوّْقنْ ن ؤُپَالْطُو.
\v 28 أَذْ ثسّْمُونذْ ثَاجْمشْثْ س ثخْرَازِينْ نّسْ غَارْ ثخْرَازِينْ ن ؤُپَالْطُو أَكْ-ذ إِجّْ ن ؤُفِيڒُو إِمُوذنْ أَذحْمِي، مَاحنْذْ أَذْ ثِيڒِي \add ثجْمشْثْ\add* سنّجْ إِ ثْحزَّامْثْ إِزوّْقنْ ن ؤُپَالْطُو ؤُشَا وَارْ ثتّْبطِّي ثجْمشْثْ خْ ؤُپَالْطُو.
\v 29 \add أَمُّو\add* إِ غَا يَاوِي هَارُونْ إِسْمَاونْ ن أَيْثْ ن إِسْرَائِيل ذِي ثجْمشْثْ ن ڒحْكَامْ خْ وُوڒْ نّسْ خْ مِينِّي إِ غَا يَاذفْ غَارْ ؤُقدَّاسْ، \add أَڒَامِي إِ غَا قِّيمنْ\add* إِ ڒِيذَارثْ زَّاثْ إِ وُوذمْ ن سِيذِي إِ ڒبْذَا.
\v 30 أَذْ ثسَّارْسذْ \add إِژْرَا ن\add* ’ؤُرِيمْ‘ ذ ’ثُومِّيمْ‘ ذِي ثجْمشْثْ ن ڒحْكَامْ، \add مَاحنْذْ\add* أَذْ إِڒِينْ خْ وُوڒْ ن هَارُونْ خْ مِينِّي إِ غَا يَاذفْ زَّاثْ إِ وُوذمْ ن سِيذِي. \add أَمُّو\add* إِ غَا يَارْبُو هَارُونْ ڒبْذَا ڒحْكَامْ ن أَيْثْ ن إِسْرَائِيل خْ وُوڒْ نّسْ زَّاثْ إِ وُوذمْ ن سِيذِي.
\m 
\v 31 أَذْ ثڭّذْ \bd أَسڒْهَامْ\bd* ن ؤُپَالْطُو \add ن ؤُكهَّانْ\add* مَارَّا زڭْ \add ؤُفِيڒُو\add* أَذحْمِي. \x ◘ \xo 28:‏31 \xt ؤُف. 39‏:‏22\x*
\v 32 أَذْ يِيڒِي وَارْزَامْ إِ ؤُزدْجِيفْ نّسْ ذِي ڒْوسْطْ نّسْ. غَارْ ثْمَا ن وَارْزَامْ أَذْ ذِينْ ثِيڒِي إِشْثْ ن ثْمَا إِمُوذنْ، ثنِّي إِ غَا يِيڒِينْ أَمْ وَارْزَامْ \add إِ يِيرِي\add* ذڭْ إِجّْ ن وَارُّوضْ ن وُوزَّاڒْ ن ؤُعسْكَارِي، وَارْ ثتّْشَارِّيڭْ. \f ◼ \fr 28:‏32 \ft \bd ’أَرْزَامْ‘\bd* - س ثْعِيبْرَانِيثْ ’أَقمُّومْ‘.\f*
\v 33 غَارْ ثْمُووَّا نّسْ أَذْ ثڭّذْ ثِيرمَّانِينْ ن \add إِفِيڒَانْ\add* أَذحْمِي ذ ؤُرْجُووَانِي ذ ؤُزڭّْوَاغْ إِحذْقنْ، غَارْ ثْمُووَّا نّسْ إِ ذ أَسْ د-إِنّْضنْ، ؤُ جَارْ أَسنْثْ \add أَذْ ثڭّذْ\add* نّْوَاقسْ ن وُورغْ إِ ذ أَسْ د-إِنّْضنْ.
\v 34 إِجّْ أَوَارْنِي إِ ونّغْنِي، إِجّْ ن نَّاقُوسْ ن وُورغْ ذ إِشْثْ ن ثْرمَّانْثْ، ؤُشَا \add عَاوذْ\add* إِجّْ أَوَارْنِي إِ ونّغْنِي، إِجّْ ن نَّاقُوسْ ن وُورغْ ذ إِشْثْ ن ثْرمَّانْثْ، \add أَمُّو إِ غَا إِڒِينْ\add* غَارْ ثْمُووَّا ن ؤُسڒْهَامْ ؤُ ذڭْ ونّضْ نّسْ.
\v 35 هَارُونْ أَذْ ث يَارْضْ خْمِي إِتّْسّخَّارْ نتَّا، \add أَڒَامِي\add* إِ غَا إِتّْوَاسڒْ دّْرِيزْ نّسْ خْ مِينِّي إِ غَا يَاذفْ غَارْ زَّاوشْثْ إِقدّْسنْ زَّاثْ إِ وُوذمْ ن سِيذِي ؤُ خْمِي غَا إِفّغْ \add عَاوذْ\add*، \add حِيمَا\add* وَارْ إِتّْمتِّي.
\m 
\v 36 أَذْ ثڭّذْ إِشْثْ ن \bd \bdit ثڒْوِيحْثْ س\bdit* نُّووَّارْ\bd* ن وُورغْ إِصْفَانْ ؤُشَا أَذْ خَاسْ ثْنقْشذْ \add أَوَاڒنْ-أَ\add* أَمْ مَامّشْ نقّْشنْ ثَاخَاذنْثْ ن ؤُشمِّيعْ: ”أَمْقدَّاسْ إِ سِيذِي.“ \x ◘ \xo 28:‏36 \xt ؤُف. 39‏:‏30\x*
\v 37 أَذْ ت ثْشدّذْ غَارْ يِيجّْ ن ؤُفِيڒُو أَذحْمِي خْ أَرژّثْ. أَذْ ثِيڒِي \add ثڒْوِيحْثْ\add* غَارْ زَّاثْ ن ؤُرژّثْ.
\v 38 أَذْ ثِيڒِي \add ثڒْوِيحْثْ\add* خْ ثنْيَارْثْ ن هَارُونْ، \add حِيمَا\add* هَارُونْ أَذْ يَارْبُو ڒْمُوعْصِييّثْ إِ إِدْجَانْ ذِي ثْمسْڒَايِينْ إِقدّْسنْ نِّي إِ غَا سّْقدّْسنْ أَيْثْ ن إِسْرَائِيل أَكْ-ذ مَارَّا ثِيوْهِيبِينْ ن ثْمسْڒَايِينْ نْسنْ إِقدّْسنْ. أَذْ ثِيڒِي ڒبْذَا خْ ثنْيَارْثْ نّسْ، حِيمَا أَذْ إِڒِينْثْ \add ثْمسْڒَايِينْ نِّي\add* أَرْضَانْثْ زَّاثْ إِ وُوذمْ ن سِيذِي.
\m 
\v 39 أَذْ ثڭّذْ \bd ثْشَامِيرْ\bd* س ڒقْطنْ أَزْذَاذْ. أَذْ ثڭّذْ \bd أَرژّثْ\bd* \add عَاوذْ\add* س ڒقْطنْ أَزْذَاذْ. \bd ثَاحزَّامْثْ\bd* أَذْ ت ثڭّذْ \add أَمْ\add* إِجّْ ن ؤُمُوذِي ن ؤُخيَّاضْ.“*
\b
\m 
\v 40 ”\bd إِ وَارَّاوْ ن هَارُونْ\bd* أَذْ ثڭّذْ \bd ثْشَامِيرْ\bd* ؤُ أَذْ أَسنْ ثڭّذْ \bd ثِيحزَّامِينْ\bd* ؤُ أَذْ أَسنْ ثڭّذْ \bd ثِيشُوشَّايْ\bd*، مَاحنْذْ أَذْ \add أَسنْ\add* إِڒِينْ إِ ؤُعُودْجِي ذ ثلْوِيزْثْ.
\v 41 أَذْ ثسّْيَارْضذْ هَارُونْ، ؤُمَاشْ، ذ وَارَّاوْ نّسْ إِ كِيذسْ إِدْجَانْ، ؤُشَا شكْ أَذْ ثنْ ثْذهْنذْ، أَذْ ثنْ ثْڒقّْمذْ ؤُ أَذْ ثنْ ثسّْقدّْسذْ، حِيمَا أَذْ أَيِي خذْمنْ أَمْ يِيكهَّاننْ.
\v 42 أڭّْ أَسنْ \bd سّْرَاوڒْ ن ڒقْطنْ\bd*، حِيمَا أَذْ ذْڒنْ أَيْسُومْ ن ؤُسضْحِي نْسنْ. أَذْ إِڒِينْ زِي ثجْعِينَّا ؤُشَا أَذْ أَوْضنْ غَارْ إِفَادّنْ.
\v 43 \add سّْڒَاوڒْ نِّي\add* أَذْ إِڒِينْ خْ \add أَرِّيمثْ\add* ن هَارُونْ ذ وَارَّاوْ نّسْ خْمِي غَا يَاذْفنْ غَارْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ نِيغْ خْمِي د غَا قَارّْبنْ غَارْ ؤُعَالْطَارْ مَاحنْذْ أَذْ سخَّارنْ ذِي زَّاوشْثْ إِقدّْسنْ، \add حِيمَا\add* وَارْ د-تِّيوْينْ ڒْمُوعْصِييّثْ ؤُشَا أَذْ مّْثنْ. ثَا أَذْ ثِيڒِي ذ إِشْثْ ن ثوْصيّثْ إِ ڒبْذَا إِ نتَّا ؤُ إِ زَّارِيعثْ نّسْ أَوَارْنِي أَسْ.“
\b
\b
\c 29
\m 
\v 1 ”ذ مَانْ أَيَا إِ ذ أَسنْ غَا ثڭّذْ، حِيمَا أَذْ ثنْ ثسّْقدّْسذْ، مَاحنْذْ أَذْ أَيِي إِڒِينْ ذ إِكهَّاننْ. كْسِي إِجّْ ن ؤُفُونَاسْ - أَمژْيَانْ ن ؤُفُونَاسْ - ذ ثْنَاينْ ن وَاشْرَارنْ إِشْنَانْ قَاعْ، \x ◘ \xo 29:‏1 \xt لَاوِي 8‏:‏2؛ 9‏:‏2\x*
\v 2 ؤُ \add عَاوذْ\add* أَغْرُومْ بْڒَا أَنْثُونْ ذ ڒمْسمْنَاثْ بْڒَا أَنْثُونْ إِخدْجْضنْ س زّشْثْ ذ ثڒْفَافْ بْڒَا أَنْثُونْ تّْوَاذهْننْثْ س زّشْثْ، ثِينِّي إِ غَا ثڭّذْ \add مَارَّا\add* س وَارنْ أَزْذَاذْ ن يِيرْذنْ.
\v 3 أَذْ ثنْثْ ثڭّذْ ذڭْ إِشْثْ ن ثْسُودْجثْ ؤُشَا أَذْ ثنْثْ ثَاوْيذْ ذِي ثْسُودْجثْ \add جْمِيعْ\add* أَكْ-ذ ؤُفُونَاسْ أَمژْيَانْ ذ ثْنَاينْ ن إِشَارِّييّنْ.
\v 4 أَذْ د-ثسّْقَارّْبذْ هَارُونْ ذ وَارَّاوْ نّسْ غَارْ وَاذَافْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ ؤُشَا أَذْ ثنْ ثسِّيرْذذْ س وَامَانْ.
\v 5 أَذْ ثكْسِيذْ أَرُّوضْ، أَذْ ثْيَارْضذْ هَارُونْ ثْشَامِيرْ ذ ؤُسڒْحَامْ إِ ؤُپَالْطُو ذ ؤُپَالْطُو \add سِيمَانْثْ نّسْ\add* ذ ثجْمشْثْ ؤُشَا أَذْ أَسْ ثْبيْسذْ س ثْحزَّامْثْ إِزوّْقنْ ن ؤُپَالْطُو.
\v 6 أَذْ ثسَّارْسذْ أَرژّثْ خْ ؤُزدْجِيفْ نّسْ ؤُ خْ أَرژّثْ أَذْ ثڭّذْ تَّاجْ إِقدّْسنْ \add ن وعْزَاڒْ\add*.
\v 7 أَذْ ثكْسِيذْ زّشْثْ إِ وذْهَانْ ؤُشَا أَذْ ت ثْزدْجْعذْ خْ ؤُزدْجِيفْ نّسْ ؤُشَا أَذْ ث ثْذهْنذْ. \x ◘ \xo 29:‏7 \xt ؤُف. 30‏:‏25\x*
\v 8 \add خنِّي\add* أَذْ ثَاوْيذْ إِحنْجِيرنْ نّسْ، أَذْ أَسنْ ثْيَارْضذْ ثْشَامِيرَاثْ.
\v 9 أَذْ أَسنْ ثْبيْسذْ س ثْحزَّامْثْ، إِ هَارُونْ ذ وَارَّاوْ نّسْ، ؤُشَا أَذْ أَسنْ ثَاركّْبذْ ثِيشُوشَّايْ. أَذْ غَارْسنْ ثِيڒِي ثُوكهَّانْثْ عْلَاحْسَابْ إِشْثْ ن ثوْصيّثْ إِ ڒبْذَا. أَذْ ثَاڒقّْمذْ هَارُونْ ذ وَارَّاوْ نّسْ. \f ◼ \fr 29:‏9 \ft \bd ’ثُوكهَّانْثْ‘\bd* - أَوَاڒْ-أَ إِخْسْ أَذْ يِينِي ’ڒْْخذْمثْ ن ؤُكهَّانْ‘. \bd ’أَذْ ثَاڒقّْمذْ هَارُونْ ذ ثَارْوَا نّسْ.‘\bd* - س ثْعِيبْرَانِيثْ ’أَذْ ثشُّورذْ إِفَاسّنْ ن هَارُونْ ذ ثَارْوَا نّسْ.‘\f*
\m 
\v 10 \add خنِّي\add* أَذْ ثَاوْيذْ أَفُونَاسْ أَمژْيَانْ زَّاثْ إِ \bd ؤُقِيضُونْ ن ؤُمْسَاڭَارْ\bd* ؤُ هَارُونْ ذ وَارَّاوْ نّسْ أَذْ سَّارْسنْ إِفَاسّنْ نْسنْ خْ ؤُزدْجِيفْ ن ؤُفُونَاسْ أَمژْيَانْ. \x ◘ \xo 29:‏10 \xt لَاوِي 1‏:‏3\x*
\v 11 أَذْ ثْغَارْصذْ إِ ؤُفُونَاسْ أَمژْيَانْ زَّاثْ إِ وُوذمْ ن سِيذِي، غَارْ وَاذَافْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ.
\v 12 \add خنِّي\add* أَذْ ثكْسِيذْ إِذَامّنْ ن ؤُفُونَاسْ أَمژْيَانْ ؤُشَا أَذْ ثنْ ثڭّذْ س ؤُضَاضْ نّشْ خْ وَاشَّاونْ ن ؤُعَالْطَارْ ؤُشَا أَذْ ثْزدْجْعذْ مَارَّا إِذَامّنْ \add إِقِّيمنْ\add* غَارْ إِضَارنْ ن ؤُعَالْطَارْ. \f ◼ \fr 29:‏12 \ft \bd ’أَشَّاونْ‘\bd* - نِيغْ ’إِقِيشَّاونْ‘.\f*
\v 13 أَذْ ثكْسِيذْ \add عَاوذْ\add* مَارَّا ثَاذُونْثْ نِّي إِذْڒِينْ أَذَانْ ذ مِينْ يُويْڒنْ غَارْ ثْسَا، ذ ثْنَاينْ ن ثِيژَّاڒْ أَكْ-ذ ثَاذُونْثْ إِ خَاسنْثْ \add إِدْجَانْ\add* ؤُشَا أَذْ ثسّْبخَّارذْ أَيَا خْ ؤُعَالْطَارْ. \f ◼ \fr 29:‏13 \ft \bd ’ثِيژَّاڒْ‘\bd* - نِيغْ ’ثِيڭژْڒِينْ‘. ؤُڒَا ذِي أَيثْ 22.\f*
\v 14 \add مَاشَا\add* أَيْسُومْ ن ؤُفُونَاسْ أَمژْيَانْ ذ يِيڒمْ نّسْ ذ ؤُمسَّاڒْ نّسْ أَذْ ثنْ ثسّْشمْضذْ س ثْمسِّي بَارَّا إِ ڒْمَارْڭحْ ن ڒْعسْكَارْ، أَقَا ذ ثَاغَارْصْثْ ن دّنْبْ. \x ◘ \xo 29:‏14 \xt لَاوِي 4‏:‏12؛ عبر. 13‏:‏11\x*
\m 
\v 15 \add خنِّي\add* أَذْ ثكْسِيذْ إِجّْ ن ؤُشَارِّي ؤُشَا هَارُونْ ذ وَارَّاوْ نّسْ أَذْ سَّارْسنْ إِفَاسّنْ نْسنْ خْ ؤُزدْجِيفْ ن إِشَارِّي.
\v 16 أَذْ ثْغَارْصذْ إِ إِشَارِّي ؤُشَا أَذْ ثكْسِيذْ إِذَامّنْ نّسْ، أَذْ \add ثنْ\add* ثْزدْجْعذْ خْ ؤُعَالْطَارْ زِي مَارَّا إِغزْذِيسنْ نّسْ. \x ◘ \xo 29:‏16 \xt عبر. 9‏:‏12، 19\x*
\v 17 أَذْ ثبْضِيذْ إِشَارِّي ذ إِشدْجِيقنْ، أَذْ ثسِّيرْذذْ أَذَانْ نّسْ ذ إِشكْرَاذْ نّسْ ؤُشَا أَذْ ثنْ ثڭّذْ خْ إِشدْجِيقنْ نّسْ ؤُ خْ ؤُزدْجِيفْ نّسْ.
\v 18 أَذْ ثسِّيغذْ إِ إِشَارِّي أَمْ إِكْمڒْ خْ ؤُعَالْطَارْ، أَقَا ذ ثَاغَارْصْثْ ن وشْمَاضْ إِ سِيذِي، إِشْثْ ن ڒفْوَاحثْ إِتّْفُوحنْ، أَقَا ذ إِشْثْ ن ثوْهِيبْثْ ن ثْمسِّي إِ سِيذِي.
\v 19 \add خنِّي\add* أَذْ ثكْسِيذْ إِشَارِّي نّغْنِي ؤُشَا هَارُونْ ذ وَارَّاوْ نّسْ أَذْ سَّارْسنْ إِفَاسّنْ نْسنْ خْ ؤُزدْجِيفْ ن إِشَارِّي.
\m 
\v 20 أَذْ ثْغَارْصذْ إِ إِشَارِّي ؤُشَا أَذْ ثكْسِيذْ زڭْ إِذَامّنْ نّسْ ؤُشَا أَذْ ثڭّذْ مَانْ أَيَا خْ إِغسْ ن ؤُمزُّوغْ أَفُوسِي ن هَارُونْ ؤُ خْ إِغسْ ن ؤُمزُّوغْ أَفُوسِي ن وَارَّاوْ نّسْ ؤُ \add عَاوذْ\add* خْ ؤُضَاضْ ن يِيمزْ ن ؤُفُوسْ نْسنْ أَفُوسِي ؤُ خْ ؤُضَاضْ ن يِيمزْ ن ؤُضَارْ نْسنْ أَفُوسِي ؤُشَا أَذْ ثْزدْجْعذْ إِضَامّنْ \add إِقِّيمنْ\add* خْ ؤُعَالْطَارْ زِي كُوڒْ جِّيهثْ.
\v 21 \add خنِّي\add* أَذْ ثكْسِيذْ زڭْ إِذَامّنْ نِّي إِدْجَانْ خْ ؤُعَالْطَارْ ؤُ زِي زّشْثْ إِ وذْهَانْ ؤُشَا أَذْ زَّايْسنْ ثْرُوشّذْ هَارُونْ ذ وَارُّوضْ نّسْ ؤُشَا \add أَذْ ثْرُوشّذْ عَاوذْ\add* أَرَّاوْ نّسْ ذ أَرُّوضْ ن وَارَّاوْ نّسْ أَكِيذسْ، حِيمَا أَذْ يِيڒِي إِتّْوَاقدّسْ، نتَّا ذ أَرُّوضْ نّسْ، ؤُڒَا ذ ثَارْوَا نّسْ ذ أَرُّوضْ ن ثَارْوَا نّسْ أَكِيذسْ.
\v 22 أَذْ ثكْسِيذْ ثَاذُونْثْ ن إِشَارِّي ڒَا ذ ثَاذُونْثْ غَارْ ؤُنوَّارْ ڒَا ثَاذُونْثْ نِّي إِذْڒِينْ أَذَانْ، ؤُڒَا مِينْ يُويْڒنْ غَارْ ثْسَا ذ ثْنَاينْ ن ثِيژَّاڒْ س ثَاذُونْثْ إِ خَاسنْثْ إِدْجَانْ ذ أَشكْرُوذْ أَفُوسِي، مِينْزِي وَا ذ إِشَارِّي إِ ؤُذشّنْ \add ن إِكهَّاننْ\add*.
\v 23 كْسِي \add عَاوذْ\add* إِشْثْ ن ثشْنِيفْثْ ن وغْرُومْ ذ إِشْثْ ن ثمْسمّنْثْ ن وغْرُومْ \add إِتّْوَاسّْوجْذنْ\add* س زّشْثْ ذ إِشْثْ ن ثڒْففْثْ زِي ثْسُودْجثْ ن وغْرُومْ بْڒَا أَنْثُونْ \add إِ إِدْجَانْ\add* زَّاثْ إِ وُوذمْ ن سِيذِي.
\v 24 سَارْسْ مَانْ أَيَا مَارَّا خْ إِفَاسّنْ ن هَارُونْ ؤُ خْ إِفَاسّنْ ن وَارَّاوْ نّسْ ؤُشَا أَذْ ثنْ ثسّنْهزّذْ زِي سَّا غَارْ ذَا \add أَمْ\add* إِشْثْ ن ثوْهِيبْثْ ن ونْهزِّي زَّاثْ إِ وُوذمْ ن سِيذِي.
\v 25 \add أَوَارْنِي أَسْ\add* أَذْ ت ثكْسِيذْ زڭْ إِفَاسّنْ نْسنْ ؤُشَا أَذْ ت ثسّْبخَّارذْ خْ ؤُعَالْطَارْ، خْ ثْغَارْصْثْ ن وشْمَاضْ، \add أَذْ ثِيڒِي\add* ذ إِشْثْ ن ڒفْوَاحثْ إِتّْفُوحنْ زَّاثْ إِ وُوذمْ ن سِيذِي. \add أَقَا-ت\add* ذ إِشْثْ ن ثوْهِيبْثْ ن ثْمسِّي إِ سِيذِي.
\v 26 أَذْ ثكْسِيذْ إِذْمَارنْ ن إِشَارِّي إِ ؤُذشّنْ ن هَارُونْ ؤُشَا أَذْ ثنْ ثسّنْهزّذْ زِي سَّا غَارْ ذَا \add أَمْ\add* إِشْثْ ن ثوْهِيبْثْ ن ونْهزِّي زَّاثْ إِ وُوذمْ ن سِيذِي. ثَانِيثَا أَذْ ثِيڒِي ذ ثَاسْغَارْثْ نّشْ.
\v 27 أَذْ ثسّْقدّْسذْ إِذْمَارنْ ن ثوْهِيبْثْ ن ونْهزِّي إِ إِتّْوَانْهزّنْ زِي سَّا غَارْ ذَا، ؤُڒَا ذ ؤُشكْرُوذْ إِ إِتّْوَانْهزّنْ زِي سَّا غَارْ ذَا ذ ونِّي إِتّْوَاسّْڭعّْذنْ. أَقَا-ثنْ زڭْ إِشَارِّي ن ؤُذشّنْ، أَمْ زڭْ ونِّي إِ يدْجَانْ إِ هَارُونْ أَمْ زڭْ ونِّي إِ يدْجَانْ إِ وَارَّاوْ نّسْ.
\v 28 أَيَا أَذْ يِيڒِي إِ هَارُونْ ذ وَارَّاوْ نّسْ ذ إِشْثْ ن ثوْصيّثْ إِ ڒبْذَا زِي جِّيهثْ ن أَيْثْ ن إِسْرَائِيل، مِينْزِي ذ ثَاوْهِيبْثْ ن ؤُسْڭعّذْ إِ ثدْجَا. أَذْ ثِيڒِي ذ إِشْثْ ن ثوْهِيبْثْ إِ غَا سّْڭعّْذنْ أَيْثْ ن إِسْرَائِيل زِي ثْغَارْصَا نْسنْ ن ڒهْنَا. أَقَا ذ ثَاوْهِيبْثْ نْسنْ ن ؤُسْڭعّذْ إِ سِيذِي. \x ◘ \xo 29:‏28 \xt لَاوِي 7‏:‏31، 34؛ 10‏:‏14\x*
\m 
\v 29 أَرُّوضْ إِقدّْسنْ ن هَارُونْ أَذْ يِيڒِي إِ وَارَّاوْ نّسْ أَوَارْنِي أَسْ، مَاحنْذْ أَذْ ثنْ ذهْننْ ؤُ أَذْ ثنْ أَڒقْمنْ ذَايسْ.
\v 30 مَانْ ونْ زڭْ إِحنْجِيرنْ نّسْ \add إِ غَا يِيڒِينْ\add* ذ أَكهَّانْ ذڭْ ومْشَانْ نّسْ ؤُشَا أَذْ يَاذفْ غَارْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ، مَاحنْذْ أَذْ إِسخَّارْ ذِي زَّاوشْثْ إِقدّْسنْ، أَذْ ث يَارْضْ سبْعَا ن وُوسَّانْ.
\m 
\v 31 أَذْ ثكْسِيذْ إِشَارِّي إِ ؤُذشّنْ ؤُشَا أَذْ ثسّنْڭْوذْ أَيْسُومْ نّسْ ذڭْ إِجّْ ن ومْشَانْ إِقدّْسنْ.
\v 32 هَارُونْ ذ وَارَّاوْ نّسْ أَذْ شّنْ أَيْسُومْ ن إِشَارِّي ذ وغْرُومْ إِ إِدْجَانْ ذِي ثْسُودْجثْ غَارْ وَاذَافْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ. \x ◘ \xo 29:‏32 \xt لَاوِي 8‏:‏31؛ 24‏:‏9\x*
\v 33 أَذْ شّنْ زِي مِينْ زِي إِتّْوَاڭّْ وسْڒَاحْ، حِيمَا أَذْ ثنْ ڒقّْمنْ ؤُ أَذْ ثنْ سّْقدّْسنْ. \add مَاشَا\add* إِجّْ ن ؤُبَارَّانِي وَارْ زَّايسْ إِتّتّْ، مِينْزِي أَقَا ذ إِشْثْ ن ڒْحَاجّثْ ذ ثَامْقدّسْثْ. \x ◘ \xo 29:‏33 \xt لَاوِي 10‏:‏14؛ مت. 12‏:‏4\x*
\v 34 مَاڒَا إِشطّْ شَا زڭْ ويْسُومْ \add ن ثْغَارْصَا\add* إِ ؤُذشّنْ نِيغْ زڭْ وغْرُومْ أَڒْ صّْبحْ، أَذْ ثسّْشمْضذْ مِينْ إِشطّنْ ذِي ثْمسِّي. إِتّْخصَّا وَارْ ث إِتّتّْ حذْ، مِينْزِي ذ إِشْثْ ن ڒْحَاجّثْ إِقدّْسنْ \add إِ يدْجَا\add*.
\m 
\v 35 أَمُّو إِ غَا ثڭّذْ أَكْ-ذ هَارُونْ ؤُ أَكْ-ذ وَارَّاوْ نّسْ، \add أَذْ ثڭّذْ\add* عْلَاحْسَابْ مَارَّا مِينْ ذ أَشْ وصِّيغْ. أَذْ ثنْ ثَاڒقّْمذْ سبْعَا ن وُوسَّانْ.
\v 36 كُوڒْ أَسّْ أَذْ ثسّْوجْذذْ أَفُونَاسْ أَمژْيَانْ ذ ثَاغَارْصْثْ ن دّنْبْ إِ وصْڒَاحْ ؤُشَا أَذْ ثكّْسذْ دّنْبْ خْ ؤُعَالْطَارْ ؤُمِي خَاسْ غَا ثسِّيوْضذْ أَصْڒَاحْ، ؤُشَا \add خنِّي\add* أَذْ ث ثْذهْنذْ، مَاحنْذْ أَذْ ث ثسّْقدّْسذْ.
\v 37 سبْعَا ن وُوسَّانْ أَذْ ثڭّذْ أَصْڒَاحْ خْ ؤُعَالْطَارْ ؤُشَا أَذْ ث ثسّْقدّْسذْ، \add خنِّي\add* أَذْ يِيڒِي ذ أَمْقدَّاسْ قَاعْ. ونِّي إِ غَا إِحَاذَانْ أَعَالْطَارْ، أَذْ يِيڒِي ذ أَمْقدَّاسْ.
\v 38 ذ مَانْ أَيَا إِ غَا ثسّْوجْذذْ خْ ؤُعَالْطَارْ: ثْنَاينْ ن إِزْمَارنْ ن إِجّْ ن ؤُسڭّْوَاسْ، كُوڒْ أَسّْ ڒبْذَا. \x ◘ \xo 29:‏38 \xt ڒخْڒ. 28‏:‏3\x*
\v 39 أَذْ ثسّْوجْذذْ إِجّْ ن يزْمَارْ ذِي صّْبحْ ؤُ إِزْمَارْ نّغْنِي أَذْ ث ثسّْوجْذذْ جَارْ بدُّو ن وزْينْ ن وَاسّْ أَڒْ د-ثوْضَا ثْمذِّيثْ.
\v 40 إِ يِيجّْ ن يزْمَارْ \add أَذْ ثكْسِيذْ\add*عشْرَا ذِي ثسْغَارْثْ ن إِجّْ ن إِفَا ن وَارنْ أَزْذَاذْ إِخدْجْضنْ س زّشْثْ دّْزنْ ت-إِ-د \add زِي زِّيثُونْ\add*، ؤُ أَربْعَا ذِي ثسْغَارْثْ ن إِجّْ ن ؤُهِينُو ن بِينُو ذ ثَاوْهِيبْثْ ن ؤُسيّبْ. \f ◼ \fr 29:‏40 \ft \bd ’أَهِينُو‘\bd* - إِجّْ ن ’ؤُهِينُو‘ ذَايسْ 6 ½ لِيثْرُو ن وَامَانْ نِيغْ ن ؤُشفَّايْ ؤُ ن ڒحْوَايجْ نّغْنِي، ؤُ 6،5 لِيثْرُو إِتَّاوِي-د 1/6 ’بَاثْهْ‘. إِجّْ ن ’بَاثْهْ‘ إِمُونْ ذَايسْ خنِّي 6 ن ’ؤُهِينُو‘، إِخْسْ أَذْ يِينِي عْڒَاينْ 40 لِيثْرُو.\f*
\v 41 أَذْ ثْغَارْصذْ إِ يزْمَارْ نّغْنِي جَارْ بدُّو ن وزْينْ ن وَاسّْ أَڒْ د-ثوْضَا ثْمذِّيثْ. أَذْ غَارسْ ثَارْنِيذْ ثَاوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* أَمْ مَامّشْ ثنِّي ن صّْبحْ ؤُ \add عَاوذْ\add* ثَاوْهِيبْثْ نّسْ ن ؤُسيّبْ. أَقَا ذ ڒفْوَاحثْ إِتّْفُوحنْ. \add أَقَا\add* ذ ثَاوْهِيبْثْ ن ثْمسِّي إِ سِيذِي.
\v 42 \add أَذْ ثِيڒِي\add* ذ ثَاغَارْصْثْ ن وشْمَاضْ ڒبْذَا ذِي \add مَارَّا\add* جِّيڒَاثْ نْومْ غَارْ وَاذَافْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ زَّاثْ إِ وُوذمْ ن سِيذِي، مَانِي غَا سّْمُونغْ أَكِيذْومْ، مَاحنْذْ أَذْ كِيذكْ سِّيوْڒغْ ذِينْ.
\v 43 أَذْ مّْسَاڭَارغْ ذِينْ أَكْ-ذ أَيْثْ ن إِسْرَائِيل، ؤُ \add أَقِيضُونْ\add* أَذْ إِتّْوَاقدّسْ س ؤُعُودْجِي إِنُو.
\v 44 أَذْ سّْقدّْسغْ أَقِيضُونْ ن ؤُمْسَاڭَارْ ذ ؤُعَالْطَارْ. أَذْ سّْقدّْسغْ \add عَاوذْ\add* هَارُونْ ذ وَارَّاوْ نّسْ، حِيمَا أَذْ أَيِي إِڒِينْ ذ إِكهَّاننْ.
\v 45 أَذْ زذْغغْ ذِي ڒْوسْطْ ن أَيْثْ ن إِسْرَائِيل، أَذْ أَسنْ إِڒِيغْ ذ أَربِّي \x ◘ \xo 29:‏45 \xt ؤُف. 25‏:‏8؛ لَاوِي 26‏:‏12؛ إِزهد. 78‏:‏60؛ زَاك. 2‏:‏14؛ 2 كُور. 6‏:‏16؛ أَسَا. 21‏:‏3\x*
\v 46 ؤُشَا أَذْ سّْننْ بلِّي نشّْ ذ سِيذِي، أَربِّي نْسنْ، ونِّي ثنْ إِسُّوفّْغنْ زِي ثمُّورْثْ ن مِيصْرَا، مَاحنْذْ أَذْ زذْغغْ ذِي ڒْوسْطْ نْسنْ. نشّْ ذ سِيذِي، أَربِّي نْسنْ.“
\b
\b
\c 30
\m 
\v 1 ”أَذْ ثڭّذْ \add عَاوذْ\add* \bd أَعَالْطَارْ ن ڒبْخُورْ\bd*. أَذْ ث ثڭّذْ زڭْ ؤُكشُّوضْ ن \add ثْشجَّارْثْ ن\add* ؤُكَاسِييَا. \x ◘ \xo 30:‏1 \xt ؤُف. 37‏:‏25\x*
\v 2 ثُوزّڭَّارْثْ أَذْ ثِيڒِي ذ إِجّنْ ؤُغِيڒْ، ؤُ ثِيرُو \add عَاوذْ\add* ذ إِجّنْ ؤُغِيڒْ. أَذْ يِيڒِي \add ؤُعَالْطَارْ\add* س أَربْعَا ن ثْغمُّورَا. ڒُْوعْڒَا نّسْ أَذْ يِيڒِي ذ ثْنَاينْ ن إِغَادْجنْ ؤُ أَشَّاونْ نّسْ أَذْ إِڒِينْ ذ إِجّنْ أَكِيذسْ. \f ◼ \fr 30:‏2 \ft \bd ’أَشَّاونْ‘\bd* - نِيغْ ’إِقِيشَّاونْ‘. ؤُڒَا ذِي أَيثْ 3 ذ 10.\f*
\v 3 أَذْ ث ثْغدْجْفذْ س وُورغْ إِصْفَانْ، ؤُذمْ نّسْ ن سنّجْ ذ إِغزْذِيسنْ نّسْ إِ ذ أَسْ د-إِنّْضنْ ذ وَاشَّاونْ نّسْ. أَذْ أَسْ ثڭّذْ إِجّْ ن زّْوَاقْ ن وُورغْ إِ ذ أَسْ د-إِنّْضنْ.
\v 4 أَذْ أَسْ ثڭّذْ ثْنَاينْ ن ثخْرَازِينْ ن وُورغْ سَاذُو زّْوَاقْ نّسْ. أَذْ ثنْثْ ثڭّذْ غَارْ ثْنَاينْ ن إِغزْذِيسنْ نّسْ، غَارْ ثْنَاينْ ن ثْغمَّارْ نّسْ. أَذْ إِڒِينْثْ إِ إِعُومَاذْ، حِيمَا أَذْ زَّايْسنْ أَرْبُونْ \add أَعَالْطَارْ ن ڒبْخُورْ\add*.
\v 5 أَذْ ثڭّذْ ثْنَاينْ ن إِعُومَاذْ \add إِ ثَاربُّوثْ\add* زڭْ ؤُكشُّوضْ ن ؤُكَاسِييَا ؤُشَا أَذْ ثنْ ثْغدْجْفذْ س وُورغْ.
\v 6 أَذْ ث ثسَّارْسذْ زَّاثْ إِ ؤُڒحَّافْ إِ إِدْجَانْ زَّاثْ إِ تَّابُوثْ ن شّْهَاذثْ، زَّاثْ إِ ثْقبَّارْثْ ن وصْڒَاحْ ثنِّي إِدْجَانْ خْ شّْهَاذثْ، مَانِي كِيكْ إِ غَا مّْسَاڭَارغْ.
\v 7 أَذْ إِسّْبخَّارْ هَارُونْ ڒبْخُورْ إِتّْفُوحنْ كُوڒْ صّْبحْ. \add أَوَارْنِي ڒَامِي\add* إِعْذڒْ ثِيفْثِيڒِينْ، أَذْ إِسّْبخَّارْ. \x ◘ \xo 30:‏7 \xt 1 صم. 3‏:‏3\x*
\v 8 مڒْمِي إِ غَا إِسِّيرغْ هَارُونْ ثِيفْثِيڒِينْ جَارْ بدُّو ن وزْينْ ن وَاسّْ أَڒْ د-ثوْضَا ثْمذِّيثْ، أَذْ يجّْ ڒبْخُورْ أَذْ إِبخَّارْ. \add أَذْ يِيڒِي\add* ذ إِجّْ ن ڒبْخُورْ إِ ڒبْذَا زَّاثْ إِ وُوذمْ ن سِيذِي إِ \add مَارَّا\add* جِّيڒَاثْ نْومْ.
\v 9 كنِّيوْ وَارْ خَاسْ ثسّْڭعّْذمْ شَا ڒبْخُورْ ذ أَغْرِيبْ، نِيغْ ثَاغَارْصْثْ ن وشْمَاضْ نِيغْ ثَاوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* ؤُ وَارْ خَاسْ تّْزدْجَاعمْ ثَاوْهِيبْثْ ن ؤُسيّبْ.
\v 10 هَارُونْ أَذْ إِڭّْ أَصْڒَاحْ خْ وَاشَّاونْ نّسْ إِشْثْ ن ثْوَاڒَا ذڭْ ؤُسڭّْوَاسْ س إِذَامّنْ ن ثْغَارْصَا ن دّنْبْ إِ وصْڒَاحْ. أَذْ ث إِسّصْڒحْ إِشْثْ ن ثْوَاڒَا ذڭْ ؤُسڭّْوَاسْ إِ \add مَارَّا\add* جِّيڒَاثْ نْومْ. \add أَقَا-ث\add* ذ أَمْقدَّاسْ قَاعْ إِ سِيذِي.“
\m 
\v 11 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:
\m 
\v 12 ”خْمِي غَا ثكْسِيذْ ڒْقدّْ ن أَيْثْ ن إِسْرَائِيل، \add ڒْقدّْ ن\add* يِينِّي إِتّْوَاحسْبنْ، \add خنِّي\add* نِيثْنِي أَذْ وْشنْ، كُوڒْ إِجّْ إِ يِيخفْ نّسْ، \bd تَّامَانْ ن وصْڒَاحْ\bd* إِ سِيذِي غَارْ ؤُسذِّي نْسنْ، \add حِيمَا\add* وَارْ ثتِّيڒِي جّْرِيحشْثْ جَارْ أَسنْ خْ مِينِّي ثنْ غَا ثْحسْبذْ. \x ◘ \xo 30:‏12 \xt ڒخْڒ. 1‏:‏2\x*
\v 13 ذ مَانْ أَيَا إِ غَا وْشنْ نِيثْنِي، كُوڒْ إِجّْ زڭْ إِنِّي غَا إِژْوَانْ غَارْ يِينِّي إِتّْوَاحسْبنْ: أَزْينْ شِيقْلُو عْلَاحْسَابْ شِيقْلُو ن زَّاوشْثْ إِقدّْسنْ - شِيقْلُو-يَا ذ عِيشْرِينْ جِيرَا - أَزْينْ شِيقْلُو-يَا أَذْ يِيڒِي ذ ثَاوْهِيبْثْ ن ؤُسْڭعّذْ إِ سِيذِي. \x ◘ \xo 30:‏13 \xt لَاوِي 27‏:‏25؛ ڒخْڒ. 3‏:‏47؛ حِز. 45‏:‏12\x*
\v 14 كُوڒْ إِجّْ زڭْ إِنِّي غَا إِژْوَانْ غَارْ يِينِّي إِتّْوَاحسْبنْ، زِي عِيشْرِينْ إِسڭّْوُوسَا سنّجْ، أَذْ إِسّْڭعّذْ ثَاوْهِيبْثْ إِ سِيذِي.
\v 15 بُو-وَاڭْڒَا وَارْ إِتِّيشْ كْثَارْ ؤُ أَمزْڒُوضْ وَارْ إِسّنْقِيسْ زڭْ وزْينْ شِيقْلُو، خْمِي غَا ثسّْڭعّْذمْ ثَاوْهِيبْثْ ن سِيذِي إِ وصْڒَاحْ ن ڒعْمُورْ نْومْ.
\v 16 أَذْ ثكْسِيذْ نُّوقَارْثْ إِ وصْڒَاحْ ن أَيْثْ ن إِسْرَائِيل ؤُشَا أَذْ ت ثْفَارْزذْ إِ ثْسخَّارْثْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ. أَذْ ثِيڒِي ذ ڒِيذَارثْ إِ أَيْثْ ن إِسْرَائِيل زَّاثْ إِ وُوذمْ ن سِيذِي إِ وصْڒَاحْ ن ڒعْمُورْ نْومْ.“ \x ◘ \xo 30:‏16 \xt ؤُف. 38‏:‏25\x*
\m 
\v 17 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:
\m 
\v 18 ”أَذْ ثڭّذْ عَاوذْ \bd ثْبَانْيُوثْ ن نّْحَاسْ\bd* إِ ؤُسِيرْذْ، أَكْ-ذ ؤُضَارْ ن نُّوقَارْثْ نّسْ إِ خْ ت غَا سَّارْسنْ، مَاحنْذْ أَذْ سِّيرْذنْ \add إِخفْ نْسنْ\add*. أَذْ ت ثسَّارْسذْ جَارْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ ذ ؤُعَالْطَارْ ؤُشَا أَذْ ذَايسْ ثڭّذْ أَمَانْ،
\v 19 مَاحنْذْ هَارُونْ ذ وَارَّاوْ نّسْ أَذْ زَّايسْ سِّيرْذنْ إِفَاسّنْ نْسنْ ذ إِضَارنْ نْسنْ.
\v 20 خْمِي غَا يَاذْفنْ غَارْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ أَذْ سِّيرْذنْ س وَامَانْ \add حِيمَا\add* وَارْ تّْمتِّينْ شَا، ؤُڒَا خْمِي د غَا قَارّْبنْ غَارْ ؤُعَالْطَارْ، مَاحنْذْ أَذْ سخَّارنْ خْمِي غَا سّْبخَّارنْ ثَاوْهِيبْثْ ن ثْمسِّي إِ سِيذِي.
\v 21 \add خنِّي\add* أَذْ سِّيرْذنْ إِفَاسّنْ نْسنْ ذ إِضَارنْ نْسنْ حِيمَا وَارْ تّْمتِّينْ شَا. مَانْ أَيَا أَذْ أَسنْ يِيڒِي ذ إِشْثْ ن ثوْصيّثْ إِ ڒبْذَا، إِ نتَّا ؤُ إِ زَّارِيعثْ نّسْ، إِ \add مَارَّا\add* جِّيڒَاثْ نْسنْ.“
\m 
\v 22 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:
\m 
\v 23 ”شكْ، كْسِي ڒخُّو غَاركْ ڒعْطُورْ إِشْنَانْ أَطَّاسْ: خمْسْ-مْيَا \add شِيقْلُو\add* ن مِيرُّو يُوزّْڒنْ أَكْ-ذ ڒْقدّْ ن وزْينْ ن مَانَاونِّي، أَقَا-ث ذ مِيثَاينْ ؤُ-خمْسِينْ \add شِيقْلُو\add* زِي ڒْقَارْفَا إِتّْفُوحنْ ؤُ مِيثَاينْ ؤُ-خمْسِينْ \add شِيقْلُو\add* زڭْ ؤُغَانِيمْ ؤُحمُّومْ إِتّْفُوحنْ،
\v 24 خمْسَا-مْيَا \add شِيقْلُو\add* ن قَاسِّييَا \add إِوزّْننْ\add* عْلَاحْسَابْ شِيقْلُو ن زَّاوشْثْ إِقدّْسنْ، ذ إِجّْ ن ؤُهِينُو ن زّشْثْ ن زِّيثُونْ.
\v 25 أڭّْ زَّايْسنْ إِشْثْ ن \bd زّشْثْ ثَامْقدَّاسْثْ إِ وذْهَانْ\bd*، إِجّْ ن ڒعْطُورْ إِخدْجْضنْ عْلَاحْسَابْ صّنْعثْ ن ؤُعطَّارْ. أَيَا أَذْ يِيڒِي ذ إِشْثْ ن زّشْثْ ثَامْقدّسْثْ إِ وذْهَانْ.
\v 26 س مَانْ أَيَا أَذْ ثْذهْنذْ أَقِيضُونْ ن ؤُمْسَاڭَارْ، تَّابُوثْ ن شّْهَاذثْ،
\v 27 ثَازوْضَا أَكْ-ذ مَارَّا ڒقْشُوعْ نّسْ ذ ڒْقنْذِيڒْ أَكْ-ذ مَارَّا ڒقْشُوعْ نّسْ ذ ؤُعَالْطَارْ ن ڒبْخُورْ،
\v 28 ذ ؤُعَالْطَارْ ن وشْمَاضْ أَكْ-ذ مَارَّا ڒقْشُوعْ نّسْ ذ ثْبَانْيُوثْ أَكْ-ذ ؤُضَارْ نّسْ.
\v 29 أَذْ ثسّْقدّْسذْ مَارَّا أَيَا، حِيمَا أَذْ يِيڒِي ذ أَمْقدَّاسْ قَاعْ. مَارَّا وِي غَا إِحَاذَانْ زِي مَانْ أَيَا، أَذْ إِتّْوَاقدّسْ.
\v 30 أَذْ ثْذهْنذْ هَارُونْ ذ وَارَّاوْ نّسْ ؤُشَا أَذْ ثنْ ثسّْقدّْسذْ، حِيمَا \add أَذْ\add* أَيِي \add إِڒِينْ\add* ذ إِكهَّاننْ.
\v 31 أَذْ ثسِّيوْڒذْ أَكْ-ذ أَيْثْ ن إِسْرَائِيل ؤُشَا أَذْ ثِينِيذْ: ’ثَا أَذْ ثِيڒِي ذ إِشْثْ ن زّشْثْ ثَامْقدَّاسْثْ إِ وذْهَانْ إِ نشّْ ذِي \add مَارَّا\add* جِّيڒَاثْ نْومْ. \f ◼ \fr 30:‏31 \ft \bd ’إِ نشّْ‘\bd* - مَانْ أَيَا إِخْسْ أَذْ يِينِي ’إِ أَربِّي‘.\f*
\v 32 وَارْ إِعدّڒْ أَذْ ت فَارّْغنْ خْ أَرِّيمثْ ن بْنَاذمْ، ؤُ مَامّشْ ثدْجَا وَارْ زَّايسْ تّڭّمْ ؤُتْشْمَاسْ. ثَامْقدَّاسْثْ إِ ثدْجَا ؤُشَا أَذْ ثِيڒِي ذ ثَامْقدَّاسْثْ إِ كنِّيوْ.
\v 33 ونِّي إِ غَا إِسّْوجْذنْ س ڒبْزَارْ \add إِشْثْ ن زّشْثْ ن وذْهَانْ\add* أَمْ ثَانِيثَا ؤُشَا أَذْ زَّايسْ ثْمسْحذْ خْ يِيجّْ ن ؤُبَارَّانِي، أَذْ إِتّْوَاقسّْ زِي ڒْڭنْسْ نّسْ.‘ “
\b
\m 
\v 34 إِنَّا سِيذِي إِ مُوسَا:
\m ”كْسِي إِ يِيخفْ نّشْ ڒبْزَارْ إِتّْفُوحنْ: ثُوذِّيمِينْ ن ؤُسرْغَاغْ ذ وقْشُورْ ن ثْشجَّارْثْ ن ڒْقَارْفَا ذ غَالْبَا، ڒبْزَارْ إِتّْفُوحنْ ذ جَّاوِي إِصْفَانْ. \add أَذْ يِيڒِي\add* ڒْقدّْ نّسْ أَمْ ڒْقدّْ ن ونّغْنِي.
\v 35 أڭّْ زَّايسْ إِجّْ ن \bd ڒعْطُورْ\bd*، إِجّْ ن ؤُخدْجضْ أَمْ ثنِّي إِڭَّا ؤُعطَّارْ: إِتّْوَامدْجذْ، إِصْفَا، إِقدّسْ.
\v 36 حْرِي-د زَّايسْ ثَانغْذَا ثَازْذَاذْثْ ؤُشَا سَارْسْ \add شَا\add* زَّايسْ زَّاثْ إِ شّْهَاذثْ ذڭْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ مَانِي أَكِيذكْ غَا مْسَاڭَارغْ. أَذْ أَومْ ثِيڒِي ذ ثَامْقدَّاسْثْ قَاعْ.
\v 37 ڒعْثُورْ نِّي إِ غَا ثڭّذْ، وَارْ ث تّڭّمْ س ؤُخدْجضْ ذ إِجّنْ أَكِيذسْ إِ يِيخفْ نْومْ. أَذْ يِيڒِي ذ أَمْقدَّاسْ إِ شكْ، \add أَذْ يِيڒِي\add* إِ سِيذِي.
\v 38 ونِّي إِ إِڭِّنْ شَا أَمْ وَانِيثَا ؤُشَا أَذْ ث إِشمّْ، أَذْ إِتّْوَاقسّْ زِي ڒْڭنْسْ نّسْ.“
\b
\b
\c 31
\m 
\v 1 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:
\m 
\v 2 ”خْزَارْ، نشّْ ڒَاغِيغْ-د خْ بَاصَالِييِيلْ، مِّيسْ ن ؤُرِي، مِّيسْ ن حُورْ، زِي ثقْبِيتْشْ ن يَاهُوذَا س يِيسمْ نّسْ. \x ◘ \xo 31:‏2 \xt ؤُف. 35‏:‏30؛ 1 إِم. 2‏:‏20\x*
\v 3 شُّورغْ ث س أَرُّوحْ ن أَربِّي، س ثِيغِيثْ، س ڒعْقڒْ، س ثُوسّْنَا ؤُ س مَارَّا \add مِينْ إِتّْخصَّانْ ن\add* ثْزمَّارْ ن صّْنَايعْ، \x ◘ \xo 31:‏3 \xt ؤُف. 35‏:‏13؛ إِشا. 11‏:‏2؛ 1 كُور. 12‏:‏8؛ كُول. 1‏:‏9\x*
\v 4 حِيمَا أَذْ إِخمّمْ إِرقَّامنْ س لْفنّْ، مَاحنْذْ أَذْ \add ثنْ\add* تّڭّنْ س وُورغْ ذ نُّوقَارْثْ ذ نّْحَاسْ،
\v 5 ؤُ حِيمَا أَذْ نقْشنْ إِژْرَا \add إِغْڒَانْ\add* مَاحنْذْ أَذْ ثنْ ڭّنْ \add ذِي ثْشُويَارْ نْسنْ\add*، ؤُ حِيمَا أَذْ نقْشنْ أَكشُّوضْ، حِيمَا \add أَمُّو\add* إِ غَا ڭّنْ مَارَّا ڒْخذْمثْ.
\v 6 أَقَا نشّْ ڭِّيغْ أَكِيذسْ أَهُولِييَابْ، مِّيسْ ن أَخِيسَامَاكْ، زِي ڒَادْجْ ن دَان. ذڭْ وُوڒْ ن مَارَّا \add إِنِّي غَارْ إِدْجَا\add* وُوڒْ ذ أَمِيغِيسْ، ڭِّيغْ ثِيغِيثْ. نِيثْنِي أَذْ ڭّنْ مَارَّا مِينْ خفْ وصِّيغْ:
\v 7 أَقِيضُونْ ن ؤُمْسَاڭَارْ، تَّابُوثْ ن شّْهَاذثْ، ثَاقبَّارْثْ ن وصْڒَاحْ نِّي خَاسْ إِدْجَانْ، ؤُ مَارَّا ڒقْشُوعْ ن ؤُقِيضُونْ:
\v 8 ثَازوْضَا أَكْ-ذ مَارَّا ڒقْشُوعْ نّسْ، ذ ڒْقنْذِيڒْ إِصْفَانْ س مَارَّا ڒقْشُوعْ نّسْ ذ ؤُعَالْطَارْ ن ڒبْخُورْ،
\v 9 أَعَالْطَارْ ن وشْمَاضْ أَكْ-ذ مَارَّا ڒقْشُوعْ نّسْ ذ ثْبَانْيُوثْ س ؤُضَارْ نّسْ،
\v 10 أَرُّوضْ ن ثْسخَّارْثْ ذ وَارُّوضْ إِقدّْسنْ ن هَارُونْ، أَكهَّانْ، ذ وَارُّوضْ ن وَارَّاوْ نّسْ، مَاحنْذْ أَذْ سخَّارنْ أَمْ ؤُكهَّانْ،
\v 11 ذ زّشْثْ إِ وذْهَانْ، ذ ڒبْخُورْ إِتّْفُوحنْ إِ زَّاوشْثْ إِقدّْسنْ. عْلَاحْسَابْ مَارَّا مِينْزِي شكْ ؤُمُورغْ أَذْ ڭّنْ \add مَارَّا\add* أَيَا.“
\b
\m 
\v 12 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:
\m 
\v 13 ”شكْ، سِيوڒْ أَكْ-ذ أَيْثْ ن إِسْرَائِيل، إِنِي: ’أَذْ ثحْضَامْ \add ؤُسَّانْ ن\add* سّبْثْ إِنُو، مِينْزِي \add سّبْثْ\add* ذ ڒعْڒَامثْ جَارْ أَيِي ذ كنِّيوْ، إِ \add مَارَّا\add* جِّيڒَاثْ نْومْ، حِيمَا أَذْ ثسّْنمْ بلِّي نشّْ ذ سِيذِي، ونِّي كنِّيوْ إِسّْقدّْسنْ.
\v 14 حْضَامْ \add أَسّْ ن\add* سّبْثْ، مِينْزِي إِقدّسْ \add إِ إِدْجَا\add* إِ كنِّيوْ! ونِّي ث غَا إِسّْفسْذنْ، أَذْ ث نْغنْ نِيشَانْ، مِينْزِي مَانْ ونْ إِ ذَايسْ غَا إِڭّنْ شَا ن ڒْخذْمثْ، أَذْ إِتّْوَاقْضعْ زِي ڒْوسْطْ ن ڒْڭنْسْ نّسْ. \f ◼ \fr 31:‏14 \ft \bd ’مَانْ ونْ‘\bd* - س ثْعِيبْرَانِيثْ ’ڒعْمَارْ نِّي‘.\f*  \x ◘ \xo 31:‏14 \xt ؤُف. 20‏:‏8؛ أَعَوذ. 5‏:‏12؛ حِز. 20‏:‏12\x*
\v 15 ستَّا ن وُوسَّانْ أَذْ ثڭّذْ ڒْخذْمثْ ؤُشَا ذڭْ وَاسّْ وِيسّْ سبْعَا أَذْ يِيڒِي ذ سّبْثْ، أَرَّاحثْ ثْمُونْ، ثْقدّسْ إِ ثدْجَا إِ سِيذِي! كُوڒْ إِجّْ، ونِّي إِڭِّنْ \add شَا ن\add* ڒْخذْمثْ ذڭْ وَاسّْ ن سّبْثْ، أَذْ ث نْغنْ نِيشَانْ.
\v 16 أَيْثْ ن إِسْرَائِيل أَذْ حْضَانْ \add أَسّْ ن\add* سّبْثْ، أَذْ حْضَانْ سّبْثْ ذِي \add مَارَّا\add* جِّيڒَاثْ نْسنْ \add أَمْ\add* إِجّْ ن ڒْعَاهْذْ إِ ڒبْذَا.
\v 17 \add أَذْ ثِيڒِي\add* ذ إِشْثْ ن ڒعْڒَامثْ جَارْ أَيِي ذ أَيْثْ ن إِسْرَائِيل، مِينْزِي ذِي ستَّا ن وُوسَّانْ إِڭَّا سِيذِي أَجنَّا ذ ثمُّورْثْ ؤُ ذڭْ وَاسّْ وِيسّْ سبْعَا يَاريّحْ، يَارَّا نّفْسْ.“ \x ◘ \xo 31:‏17 \xt أَمز. 1‏:‏31؛ 2‏:‏2، 3؛ ؤُف. 20‏:‏11\x*
\v 18 \add ڒَْامِي\add* إِكمّڒْ \add سِيذِي\add* أَوَاڒْ إِ كِيذسْ إِسِّيوْڒنْ خْ وذْرَارْ ن سِينَا، إِوْشَا إِ مُوسَا ثْنَاينْ ن ثڒْوِيحِينْ ن شّْهَاذثْ. \add ثُوغَا\add* ثِيڒْوِيحِينْ نِّي زڭْ وژْرُو، تّْوَارِينْثْ س ؤُضَاضْ ن أَربِّي. \x ◘ \xo 31:‏18 \xt ؤُف. 32‏:‏16\x*
\b
\b
\c 32
\s1 أَعجْمِي ن وُورغْ
\m 
\v 1 \add ڒَْامِي\add* إِژْرَا ڒْڭنْسْ بلِّي مُوسَا إِعطَّاڒْ، وَارْ د-إِهْوِي عَاذْ زڭْ وذْرَارْ، إِنّيْرُو-د ڒْڭنْسْ غَارْ هَارُونْ، نَّانْ أَسْ: ”كَّارْ، أڭّْ أَنغْ إِربِّيثنْ، إِنِّي إِ غَا يُويُورنْ زَّاثْنغْ، مِينْزِي مُوسَا أَيَا، أَرْيَازْ نِّي ذ أَنغْ د-إِسُّوفّْغنْ زِي مِيصْرَا، وَارْ نسِّينْ مِينْ ث يُوغِينْ.“ \x ◘ \xo 32:‏1 \xt ڒخ. 7‏:‏40\x*
\v 2 هَارُونْ إِنَّا أَسنْ: ”قڒْعمْ ثِيخْرَازِينْ ن وُورغْ نِّي إِدْجَانْ ذڭْ إِمجَّانْ ن ثمْغَارِينْ نْومْ ؤُ ن إِحنْجِيرنْ نْومْ ؤُڒَا ن يسِّيثْومْ، أَوْيمْ \add ثنْثْ-إِ-د\add* غَارِي.“
\v 3 إِكّسْ مَارَّا ڒْڭنْسْ ثِيخْرَازِينْ ن وُورغْ نِّي إِدْجَانْ ذڭْ إِمجَّانْ نْسنْ ؤُشَا إِوْينْ أَسْ ثنْثْ-إِ-د غَارْ هَارُونْ.
\v 4 نتَّا إِكْسِي \add ثنْثْ\add* زڭْ إِفَاسّنْ نْسنْ ؤُشَا إِشكّڒْ إِ-ثنْثْ س إِميْذِي، إِڭَّا زَّايْسنْثْ إِجّْ ن ؤُعجْمِي ن ؤُفسِّي. \add ڒخْذنِّي\add* نَّانْ: ”\add أَ\add* إِسْرَائِيل، وَا ذ أَربِّي نّشْ، ونِّي شكْ د-إِسُّوفّْغنْ زِي ثمُّورْثْ ن مِيصْرَا.“ \f ◼ \fr 32:‏4 \ft \bd ’أَعجْمِي‘\bd* - نِيغْ ’أَينْذُوزْ‘ نِيغْ ’يُوڭُّو‘.\f*
\v 5 \add ڒَْامِي\add* إِژْرَا هَارُونْ أَيَا، إِبْنَا إِجّْ ن ؤُعَالْطَارْ زَّاثْ إِ \add ؤُعجْمِي\add* ؤُشَا إِڒَاغَا هَارُونْ، إِنَّا: ”ثِيوشَّا \add أَذْ يِيڒِي\add* ذ ڒْعِيذْ إِ سِيذِي.“
\v 6 ثِيوشَّا نّسْ كَّارنْ زِيشْ ؤُشَا سّْبخَّارنْ ثِيغَارْصَا ن وشْمَاضْ ؤُشَا قدّْمنْ \add أَكِيذْسنْثْ\add* \add عَاوذْ\add* ثِيغَارْصَا ن ڒهْنَا. \add خنِّي\add* إِقِّيمْ ڒْڭنْسْ، إِشَّا، إِسْوَا، إِكَّارْ، مَاحنْذْ أَذْ يڭّْ ڒفْرَايجْ. \x ◘ \xo 32:‏6 \xt 1 كُور. 10‏:‏7\x*
\m 
\v 7 \add خَاسْ ؤُشَا\add* إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا: ”ؤُيُورْ، هْوَا، مِينْزِي ڒْڭنْسْ نّشْ، ونِّي د-ثسُّوفّْغذْ زِي ثمُّورْثْ ن مِيصْرَا، أَقَا إِڭَّا مِينْ وَارْ إِحْڒِينْ. \x ◘ \xo 32:‏7 \xt أَعَوذ. 32‏:‏5\x*
\v 8 أَقَا فّْغنْ ذغْيَا خْ وبْرِيذْ نِّي خْ ثنْ وصِّيغْ. ڭِّينْ إِجّْ ن ؤُعجْمِي ن ؤُفسِّي إِ يِيخفْ نْسنْ ؤُشَا بنْذْقنْ أَسْ، قدّْمنْ أَسْ ثِيغَارْصَا ؤُشَا نَّانْ: ’أَ إِسْرَائِيل، وَانِيثَا ذ أَربِّي نّشْ، ونِّي شكْ د-إِسُّوفّْغنْ زِي ثمُّورْثْ ن مِيصْرَا.‘ “ \x ◘ \xo 32:‏8 \xt 1 إِج. 12‏:‏28\x*
\v 9 إِنَّا سِيذِي إِ مُوسَا: ”نشّْ ژْرِيغْ ڒْڭنْسْ-أَ، خْزَارْ، أَقَا-ث ذ إِجّْ ن ڒْڭنْسْ إِقْسحْ! \x ◘ \xo 32:‏9 \xt ؤُف. 33‏:‏3؛ أَعَوذ. 9‏:‏6، 13؛ إِشا. 48‏:‏4؛ إِرْم. 5‏:‏3؛ حُوش. 4‏:‏16\x*
\v 10 ڒخُّو أجّْ أَيِي أَذْ رَاحغْ، أَذْ أَرغْ أَغْضَابْ إِنُو خَاسنْ ؤُشَا أَذْ ثنْ ثحِّيغْ، ؤُ نشّْ أَذْ شكْ أَرّغْ ذ إِجّْ ن ڒْڭنْسْ إِمْغَارْ.“
\m 
\v 11 \add مَاشَا\add* مُوسَا إِزَاوْڭْ زَّاثْ إِ وُوذمْ ن سِيذِي، أَربِّي نّسْ، إِنَّا: ”\add أَ\add* سِيذِي، مَايمِّي غَا يَارغْ وغْضَابْ نّشْ خْ ڒْڭنْسْ نّشْ، ونِّي د-ثسُّوفّْغذْ زِي ثمُّورْثْ ن مِيصْرَا س يِيجّْ ن جّهْذْ إِمْغَارْ ؤُ س ؤُفُوسْ إِجهْذنْ؟ \x ◘ \xo 32:‏11 \xt إِزهد. 106‏:‏21\x*
\v 12 مَايمِّي سَّاوَاڒنْ إِمِيصْرِييّنْ جَارْ أَسنْ، قَّارنْ: ’نتَّا إِسُّوفّغْ إِ-ثنْ س نّيّثْ ثَاعفَّانْثْ، مَاحنْذْ أَذْ ثنْ إِنغْ خْ إِذُورَارْ ؤُ مَاحنْذْ أَذْ ثنْ إِثحَّا زڭْ وُوذمْ ن ثمُّورْثْ؟‘ ذْوڒْ خْ ڒْحَاذُوقْ ن وغْضَابْ نّشْ ؤُشَا نْذمْ خْ ثُوعفّْنَا \add إِ ثخْسذْ أَذْ ثَارّذْ\add* خْ ڒْڭنْسْ نّشْ. \x ◘ \xo 32:‏12 \xt ڒخْڒ. 14‏:‏13‏-‏19. \x*
\v 13 فكَّارْ ذِي إِبْرَاهِيمْ ذ إِسْحَاقْ ذ إِسْرَائِيل، إِمْسخَّارنْ نّشْ، إِنِّي ؤُمِي ثجُّودْجذْ س يِيخفْ نّشْ ؤُ ثسِّيوْڒذْ أَكِيذْسنْ: ’نشّْ أَذْ أَرْنِيغْ زَّارِيعثْ نْومْ أَمْ يِيثْرَانْ ن ؤُجنَّا ؤُشَا أَذْ وْشغْ مَارَّا ثَامُّورْثْ-أَ إِ خفْ سِّيوْڒغْ إِ زَّارِيعثْ نّشْ ؤُشَا نِيثْنِي أَذْ ت طّْفنْ ذ إِشْثْ ن ڒْوَارْثْ إِ ڒبْذَا.“ \x ◘ \xo 32:‏13 \xt أَمز. 12‏:‏7؛ 13‏:‏15؛ 15‏:‏18؛ 26‏:‏4؛ 28‏:‏13؛ أَعَوذ. 34‏:‏4\x*
\m 
\v 14 \add خنِّي\add* إِنْذمْ سِيذِي خْ ثُوعفّْنَا إِ ثُوغَا إِنَّا أَذْ ت يڭّْ خْ ڒْڭنْسْ نّسْ.
\v 15 ؤُشَا إِذْوڒْ-د مُوسَا، إِهْوَا-د زڭْ وذْرَارْ س ثْنَاينْ ن ثڒْوِيحِينْ ن شّْهَاذثْ ذڭْ ؤُفُوسْ نّسْ. ثِيڒْوِيحِينْ-أَ تّْوَارِينْثْ خْ ثْنَاينْ ن إِغزْذِيسنْ نْسنْثْ: تّْوَارِينْثْ خْ يِيجّْ ن ؤُغزْذِيسْ ؤُ خْ ؤُغزْذِيسْ نّغْنِي.
\v 16 ثِيڒْوِيحِينْ ثُوغَا أَثنْثْ ذ ڒْخذْمثْ ن أَربِّي ؤُشَا ثِيرَا نِّي إِنقْشنْ ذِي ثڒْوِيحِينْ ذ ثِيرَا ن أَربِّي. \x ◘ \xo 32:‏16 \xt ؤُف. 31‏:‏18؛ أَعَوذ. 9‏:‏10\x*
\v 17 إِسْڒَا يَاشُووَا إِ ڒْحسّْ ن ڒْڭنْسْ إِسْغُويُّو ؤُشَا إِنَّا إِ مُوسَا: ”\add أَقَا ذَا\add*، ڒْحسّْ ن ؤُمنْغِي ذِي ڒْمَارْڭحْ ن ڒْعسْكَارْ.“
\v 18 \add مَاشَا\add* نتَّا إِنَّا: ”وَارْ إِدْجِي ذ ڒْحسّْ ن ؤُسْڒوْڒِيوْ غَارْ ڒغْڒبْ نِيغْ ذ ڒْحسّْ ن ؤُسْغُويِّي غَارْ ثْخسَّارْثْ، مَاشَا مِينْ تّسْڒِيغْ ذ ڒْحسّْ ن إِغُويَّانْ وَارْ إِحْڒِينْ.“
\v 19 ؤُشَا إِمْسَارْ، أَمْ د-إِرحّڭْ غَارْ ڒْمَارْڭحْ ن ڒْعسْكَارْ ؤُشَا إِژْرَا أَعجْمِي ذ شّْضِيحْ \add س نُّوبْثَاثْ\add*، يَارْغَا وغْضَابْ ن مُوسَا ؤُشَا إِنْضَارْ ثِيڒْوِيحِينْ زڭْ إِفَاسّنْ نّسْ، يَارْژَا إِ-ثنْثْ غَارْ إِضَارنْ ن وذْرَارْ. \x ◘ \xo 32:‏19 \xt أَعَوذ. 9‏:‏17\x*
\v 20 إِطّفْ ؤُعجْمِي نِّي ڭِّينْ، إِسّْشمْضْ إِ-ث ذِي ثْمسِّي، أَڒَامِي إِذْوڒْ ذ إِغّضْ ؤُشَا إِزُّوزَارْ إِ-ث خْ وُوذمْ ن وَامَانْ ؤُشَا يَارَّا أَيْثْ ن إِسْرَائِيل أَذْ \add ث\add* سْونْ. \x ◘ \xo 32:‏20 \xt أَعَوذ. 9‏:‏21\x*
\v 21 إِنَّا مُوسَا إِ هَارُونْ: ”مِينْ زَّايكْ إِڭَّا ڒْڭنْسْ-أَ أَڒَامِي ذ أَسْ د-ثِيوْيذْ إِجّْ ن دّنْبْ ذ أَمقّْرَانْ أَطَّاسْ؟“
\v 22 هَارُونْ إِنَّا: ”وَارْ يَارقّْ وغْضَابْ ن سِيذِي إِنُو! شكْ ثسّْنذْ ڒْڭنْسْ-أَ، أَقَا-ث ذِي ڒْغَارْ. \x ◘ \xo 32:‏22 \xt 1 يُوح. 5‏:‏19\x*
\v 23 نَّانْ أَيِي: ’أڭّْ أَنغْ إِربِّيثنْ نِّي غَا يُويُورنْ زَّاثْ إِ ؤُغمْبُوبْ نّغْ، مِينْزِي مُوسَا وَانِيثَا، أَرْيَازْ ونِّي ذ أَنغْ د-إِسُّوفّْغنْ زِي ثمُّورْثْ ن مِيصْرَا، وَارْ نسِّينْ مِينْ ث يُوغِينْ.‘
\v 24 \add خنِّي\add* نِّيغْ أَسنْ: ’وِي غَارْ إِدْجَا ؤُرغْ، أَذْ \add ث-إِ-د-\add*إِكّسْ، ؤُشَا أَذْ أَيِي ث يوْشْ!‘ ؤُشَا نْضَارغْ ث ذِي ثْمسِّي ؤُشَا إِفّغْ-د ؤُعجْمِي-يَا.“
\m 
\v 25 \add ؤُمِي\add* إِژْرَا مُوسَا، أَقَا ڒْڭنْسْ إِذْوڒْ ذ إِمْفلّسْ، مِينْزِي هَارُونْ إِجَّا أَفلّسْ \add نْسنْ\add* أَذْ إِذْوڒْ ذ ثَاضحَّاشْثْ جَارْ ڒْعذْيَانْ نْسنْ،
\v 26 إِبدّْ مُوسَا غَارْ وَاذَافْ ن ڒْمَارْڭحْ، إِنَّا: ”مَانْ ونْ إِ إِدْجَانْ إِ سِيذِي، \add أَسْ-د ذَا\add* غَارِي!“ ؤُشَا مُوننْ-د غَارسْ مَارَّا إِحنْجِيرنْ ن لَاوِي.
\v 27 إِنَّا أَسنْ: ”أَمُّو إِ إِقَّارْ سِيذِي، أَربِّي ن إِسْرَائِيل! سَارْسمْ كُوڒْ إِجّْ سِّيفْ نّسْ خْ ثْمصَّاضْثْ نّسْ، عْذُومْ ؤُشَاعقْبمْ خْ ڒْمَارْڭحْ زڭْ وَاذَافْ غَارْ وَاذَافْ \add نّغْنِي\add* ؤُشَا أَذْ إِنغْ كُوڒْ إِجّْ ؤُمَاسْ ذ كُوڒْ إِجّْ ؤُمدُّوكّڒْ نّسْ ذ كُوڒْ إِجّْ جَّارْ نّسْ!“
\v 28 ثَارْوَا ن لَاوِي ڭِّينْ عْلَاحْسَابْ أَوَاڒْ ن مُوسَا. ذڭْ وَاسّْ نِّي وْضَانْ عْڒَاحَاڒْ ثڒْثْ-أَڒَافْ ن يرْيَازنْ ن ڒْڭنْسْ.
\v 29 مُوسَا إِنَّا: ”كْسِيمْ إِفَاسّنْ نْومْ أَسّْ-أَ غَارْ سِيذِي، كُوڒْ إِجّْ خْ مِّيسْ ؤُ خْ ؤُمَاسْ. معْلِيكْ ؤُفِيغْ نتَّا أَذْ إِبَاركْ إِ كنِّيوْ \add أَمُّو\add* أَسّْ-أَ!“
\m 
\v 30 ثِيوشَّا نّسْ إِنَّا مُوسَا إِ ڒْڭنْسْ: ”كنِّيوْ ثڭِّيمْ إِجّْ ن دّنْبْ إِمْغَارْ. \add عَاذْ\add* نشّْ أَذْ أَڒْيغْ ڒخُّو غَارْ سِيذِي، بَالَاكْ أَذْ ؤُفِيغْ أَصْڒَاحْ خْ دّنْبْ نْومْ.“
\v 31 إِذْوڒْ-د مُوسَا غَارْ سِيذِي ؤُشَا إِنَّا \add أَسْ\add*: ”\add وَايَّاوْ\add*، ڒْڭنْسْ-أَ إِڭَّا إِجّْ ن دّنْبْ إِمْغَارْ، مِينْزِي ڭِّينْ إِجّْ ن أَربِّي ن وُورغْ إِ يِيخفْ نْسنْ.
\v 32 ڒخُّو، غْفَارْ \add أَسنْ\add* إِ دّنْبْ نْسنْ! نِيغْ مْحَا أَيِي زڭْ وذْلِيسْ نّشْ إِتّْوَانّْضنْ نِّي ثُورِيذْ.“
\v 33 إِنَّا سِيذِي إِ مُوسَا: ”ونِّي خَافِي إِخْضَانْ، ذ وَا إِ غَا مْحِيغْ زڭْ وذْلِيسْ إِنُو إِتّْوَانّْضنْ.
\v 34 رُوحْ ڒخُّو، أَوِي ڒْڭنْسْ-أَ غَارْ مَانِي ذ أَشْ نِّيغْ. أَقَا لْمَالَاكْ إِنُو أَذْ إِرَاحْ زَّاثْ نّشْ! ذڭْ وَاسّْ ن ؤُخدْجصْ إِنُو أَذْ أَسنْ خدْجْصغْ دّْنُوبْ نْسنْ!“
\v 35 \add أَمُّو إِ\add* إِوْثَا سِيذِي ڒْڭنْسْ، مِينْزِي ڭِّينْ أَعجْمِي نِّي إِڭَّا هَارُونْ.
\b
\b
\c 33
\m 
\v 1 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا: ”رُوحْ، ڭعّذْ سَّا، شكْ ذ ڒْڭنْسْ نِّي د-ثسُّوفّْغذْ زِي ثمُّورْثْ ن مِيصْرَا، غَارْ ثمُّورْثْ نِّي خْ جُّودْجغْ إِ إِبْرَاهِيمْ ذ إِسْحَاقْ ذ يَاعْقُوبْ، نِّيغْ: ’إِ زَّارِيعثْ نّشْ أَذْ ت وْشغْ!‘ \x ◘ \xo 33:‏1 \xt أَمز. 12‏:‏7؛ 26‏:‏4؛ 28‏:‏13\x*
\v 2 نشّْ أَذْ سّكّغْ زَّاثْ إِ ؤُغمْبُوبْ نّشْ لْمَالَاكْ، ؤُشَا أَذْ أَژّْڒغْ خْ أَيْثْ ن كنْعَانْ ذ إِمُورِييّنْ ذ إِحِيتِّييّنْ ذ إِفِيرِيزِييّنْ ذ إِحِيوِييّنْ ذ إِيِيبُوسِييّنْ
\v 3 \add ذڭْ وبْرِيذْ نْومْ\add* غَارْ إِشْثْ ن ثمُّورْثْ إِفيّْضنْ س ؤُغِي ذ ثَامّنْثْ. نشّْ \add س إِمَانْثْ إِنُو\add* وَارْ تّْڭِيعِّيذغْ أَكِيذْومْ، حِيمَا وَارْ كنِّيوْ ثتّحِّيغْ ذڭْ وبْرِيذْ، مِينْزِي كنِّيوْ ذ إِجّْ ن ڒْڭنْسْ إِقْسحْ.“ \x ◘ \xo 33:‏3 \xt ؤُف. 32‏:‏9؛ أَعَوذ. 9‏:‏13\x*
\v 4 ؤُمِي إِسْڒَا ڒْڭنْسْ أَوَاڒْ-أَ أَعفَّانْ، شضْننْ ؤُشَا ؤُڒَا ذ إِجّْ إِڭَّا \add عَاذْ\add* ڒهْزُوطْ نّسْ.
\v 5 أَقَا إِنَّا سِيذِي إِ مُوسَا: ”إِنِي إِ أَيْثْ ن إِسْرَائِيل: ’كنِّيوْ ذ إِجّْ ن ڒْڭنْسْ إِقْسحْ. مَاڒَا ڭعّْذغْ جَارْ أَومْ مْغِيرْ إِجّْ ن ورْمَاشْ، أَذْ كنِّيوْ ثحِّيغْ. \add خنِّي\add* ڒخُّو كّْسمْ ڒهْزُوطْ نْومْ، أَقَا نشّْ أَذْ سّْنغْ مِينْ ذ أَشْ غَا ڭّغْ.‘ “
\v 6 كّْسنْ أَيْثْ ن إِسْرَائِيل ڒهْزُوطْ نْسنْ زڭْ وذْرَارْ ن هُورِيبْ.
\m 
\v 7 إِكْسِي مُوسَا أَقِيضُونْ ؤُشَا إِوْثَا \add أَقِيضُونْ\add* بَارَّا إِ ڒْمَارْڭحْ ن ڒْعسْكَارْ، إِڭّْوجْ أَطَّاسْ خْ ڒْمَارْڭحْ، ؤُشَا إِڒَاغَا أَسْ ’أَقِيضُونْ ن ؤُمْسَاڭَارْ‘. كُوڒْ إِجّْ ونِّي ثُوغَا يَارزُّونْ سِيذِي، إِفّغْ غَارْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ، ونِّي إِدْجَانْ بَارَّا إِ ڒْمَارْڭحْ.
\v 8 ؤُمِي إِفّغْ مُوسَا غَارْ ؤُقِيضُونْ، إِكَّارْ مَارَّا ڒْڭنْسْ، بدّنْ بَارَّا، كُوڒْ إِجّْ غَارْ وَاذَافْ ن ؤُقِيضُونْ نّسْ، ؤُشَا نِيثْنِي خْزَارنْ غَارسْ أَمْ ثِيطَّاوِينْ نْسنْ ضفَّارنْ مُوسَا أَڒَامِي يُوذفْ غَارْ ؤُقِيضُونْ.
\v 9 ؤُمِي يُوذفْ مُوسَا غَارْ ؤُقِيضُونْ، أَقَا أَقلِّيجْ ن ؤُسيْنُو إِهْوَا، إِبدّْ غَارْ وَاذَافْ ن ؤُقِيضُونْ ؤُشَا نتَّا إِسِّيوڒْ أَكْ-ذ مُوسَا.
\v 10 ؤُشَا مَارَّا ڒْڭنْسْ إِژْرَا أَقلِّيجْ ن ؤُسيْنُو إِبدّْ غَارْ وَاذَافْ ن ؤُقِيضُونْ، \add خنِّي\add* إِكَّارْ مَارَّا ڒْڭنْسْ ؤُشَا إِبنْذقْ كُوڒْ إِجّْ غَارْ وَاذَافْ ن ؤُقِيضُونْ نّسْ.
\m 
\v 11 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا أَغمْبُوبْ ذڭْ ؤُغمْبُوبْ، أَمْ مَامّشْ إِسِّيوڒْ بْنَاذمْ أَكْ-ذ ؤُمدُّوكّڒْ نّسْ. خنِّي إِعْقبْ-د غَارْ ڒْمَارْڭحْ ن ڒْعسْكَارْ، \add مَاشَا\add* أَمْسخَّارْ نّسْ يَاشُووَا، مِّيسْ ن نُونْ، \add ونِّي عَاذْ ذ\add* أَحُوذْرِي،عمَّارْصْ وَارْ إِبعّذْ خْ ڒْوسْطْ ن ؤُقِيضُونْ.
\b
\s1 أَعُودْجِي ن سِيذِي
\m 
\v 12 إِنَّا مُوسَا إِ سِيذِي: ”خْزَارْ، شكْ ثنِّيذْ أَيِي: ’نْذهْ ڒْڭنْسْ-أَ!‘، مَاشَا شكْ وَارْ ذ أَيِي ثسّشْنذْ وِي كِيذِي إِ غَا ثسّكّذْ. شكْ ثنِّيذْ: ’نشّْ سّْنغْ شكْ س يِيسمْ نّشْ!‘ ؤُڒَا: ’ثُوفِيذْ أَرْضَا ذِي ثِيطَّاوِينْ إِنُو!‘
\v 13 ڒخُّو خنِّي، مَاڒَا ؤُفِيغْ أَرْضَا ذِي ثِيطَّاوِينْ نّشْ، زَاوْڭغْ شكْ أَذْ أَيِي ثسّشْنذْ أَبْرِيذْ نّشْ، حِيمَا أَذْ شكْ سّْنغْ، مَاحنْذْ أَذْ أَفغْ أَرْضَا ذِي ثِيطَّاوِينْ نّشْ. خْزَارْ، شّعْبْ-أَ ذ ڒْڭنْسْ نّشْ!“
\v 14 إِنَّا: ”\add لْمَالَاكْ ن\add* وُوذمْ إِنُو أَذْ يُويُورْ \add أَكِيذكْ\add* ؤُ نشّْ أَذْ شكْ سَّاريّْحغْ.“
\v 15 \add خنِّي\add* يَارَّا-د خَاسْ: ”مَاڒَا ؤُذمْ نّشْ وَارْ \add كِيذْنغْ\add* إِتّْرِيحْ، وَارْ تّجِّي \add خنِّي\add* أَذْ نْڭعّذْ سَّا!
\v 16 مَامّشْ غَا سّْننْ بلِّي أَقَا ؤُفِيغْ أَرْضَا ذِي ثِيطَّاوِينْ نّشْ، نشّْ ذ ڒْڭنْسْ نّشْ؟ مَا وَارْ إِدْجِي مِينْزِي شكْ ثْرُوحذْ أَكِيذْنغْ، أَقَا نشِّينْ، نشّْ ذ ڒْڭنْسْ نّشْ، نْفَارّزْ خْ كُوڒْ ڒْڭنْسْ إِ إِدْجَانْ خْ وُوذمْ ن ثمُّورْثْ؟“ \x ◘ \xo 33:‏16 \xt أَعَوذ. 4‏:‏7\x*
\v 17 إِنَّا سِيذِي إِ مُوسَا: ”\add عَاوذْ\add* أَذْ ڭّغْ أَوَاڒْ-أَ إِ ثنِّيذْ ؤُمِي ثُوفِيذْ أَرْضَا ذِي ثِيطَّاوِينْ إِنُو ؤُشَا سّْنغْ شكْ س يِيسمْ \add نّشْ\add*.“
\m 
\v 18 \add خَاسْ ؤُشَا\add* إِنَّا \add مُوسَا\add*: ”زَاوْڭغْ شكْ، سْشنْ أَيِي أَعُودْجِي نّشْ!“
\v 19 إِنَّا: ”نشّْ أَذْ سّعْذُوغْ مَارَّا ثْشُونِي إِنُو زَّاثكْ ؤُشَا أَذْعيّْذغْ إِسمْ ن سِيذِي زَّاثْ إِ ؤُغمْبُوبْ نّشْ ؤُشَا أَذْ حِينّغْ خْ وِي غَا حِينّغْ، أَذْ أَرحْمغْ خْ وِي غَا أَرحْمغْ.“ \x ◘ \xo 33:‏19 \xt رُوم. 9‏:‏15\x*
\v 20 إِنَّا \add عَاوذْ\add*: ”شكْ وَارْ ثْزمَّارذْ أَذْ ثْژَارذْ ؤُذمْ إِنُو، مِينْزِي وَارْ ذ أَيِي إِژَارّْ بْنَاذمْ ؤُشَا أَذْ إِقِّيمْ إِدَّارْ.“
\v 21 \add خَاسْ ؤُشَا\add* إِنَّا سِيذِي: ”خْزَارْ، زَّاثْ إِنُو أَمْشَانْ \add مَانِي\add* غَا ثْبدّذْ خْ ثصْضَارْثْ.
\v 22 خْمِي غَا إِعْذُو ؤُعُودْجِي إِنُو، أَذْ شكْ ڭّغْ ذڭْ إِجّْ ن ؤُفدْجِيقْ ن ثصْضَارْثْ ؤُشَا أَذْ شكْ ذْڒغْ س ثْڒقَّا ن ؤُفُوسْ إِنُو أَڒْ د-ژْوِيغْ.
\v 23 ؤُ خْمِي غَا كّْسغْ أَفُوسْ إِنُو، \add خنِّي\add* أَذْ أَيِي ثْژَارذْ زِي ضفَّارْ، \add مَاشَا\add* وَارْ ثْژَارّذْ ؤُذمْ إِنُو!“
\b
\b
\c 34
\s1 ثْنَاينْ ن ثڒْوِيحِينْ ن جْذِيذْ ن وژْرُو
\m 
\v 1 سِيذِي إِنَّا إِ مُوسَا: ”قسّْ إِ يِيخفْ نّشْ ثْنَاينْ ن ثڒْوِيحِينْ ن وژْرُو أَمْ ثْمزْوُورَا، ؤُشَا نشّْ أَذْ أَرِيغْ خْ ثڒْوِيحِينْ نِّي أَوَاڒنْ \add ذ إِجّنْ\add* إِ ثُوغَا ذِي ثڒْوِيحِينْ ثِيمزْوُورَا إِ ثَارْژِيذْ. \x ◘ \xo 34:‏1 \xt أَعَوذ. 10‏:‏1\x*
\v 2 سوْجذْ إِ صّْبحْ ؤُشَا ڭعّذْ ذِي صّْبحْ غَارْ وذْرَارْ ن سِينَا ؤُشَا بدّْ ذِينْ زَّاثِي خْ ثْقِيشّثْ ن وذْرَارْ.
\v 3 وَارْ إِعدّڒْ أَذْ إِڭعّذْ ؤُڒَا ذ إِجّْ ن بْنَاذمْ أَكِيذكْ، نِيغْ أَذْ إِبَانْ حذْ ذڭْ وذْرَارْ أَمْ إِكْمڒْ. ؤُڒَا ذ ؤُدْجِي ذ إِفُونَاسنْ ذ ثْفُونَاسِينْ وَارْ زمَّارنْ أَذْ أَروْسنْ طَّارْفْ إِ وذْرَارْ.“ \f ◼ \fr 34:‏3 \ft \bd ’بْنَاذمْ‘\bd* - س ثْعِيبْرَانِيثْ ’أَرْيَازْ‘.\f*  \x ◘ \xo 34:‏3 \xt ؤُف. 19‏:‏12، 13\x*
\m 
\v 4 \add خنِّي\add* إِقسّْ ثْنَاينْ ن ثڒْوِيحِينْ ن وژْرُو أَمْ ثْمزْوُورَا، ؤُشَا إِكَّارْ مُوسَا ذِي صّْبحْ زِيشْ ؤُشَا إِڭعّذْ غَارْ وذْرَارْ ن سِينَا أَمْ مَامّشْ ث إِوصَّا سِيذِي ؤُشَا يِيوِي \add أَكِيسْ\add* ذڭْ ؤُفُوسْ نّسْ ثْنَاينْ ن ثڒْوِيحِينْ ن وژْرُو.
\m 
\v 5 إِهْوَا-د سِيذِي ذڭْ ؤُسيْنُو، إِبدّْ أَكِيذسْ ذِينْ ؤُشَا إِڒَاغَا س يِيسمْ ن ’سِيذِي‘.
\v 6 إِژْوَا سِيذِي زَّاثْ إِ ؤُغمْبُوبْ نّسْ ؤُشَا إِعيّذْ: ”سِيذِي، سِيذِي، أَربِّي، ذ ونِّي إِشُّورنْ س أَرّحْمثْ ذ ثحْنُونشْثْ، غَارسْ تَّاسِيعْ ن ڒْخَاضَارْ، ذَايسْ أَطَّاسْ ن ثْمخْسِيوْثْ إِشوَّارنْ ذ ڒَامَانْ، \x ◘ \xo 34:‏6 \xt ؤُف. 33‏:‏19\x*
\v 7 ذ ونِّي إِحطَّانْ ثَامخْسِيوْثْ \add نّسْ\add* إِشوَّارنْ إِ ڒُوڒُوفْ، ذ ونِّي إِغفَّارنْ ڒْمُوعْصِييّثْ ذ خطُّو ذ دّْنُوبْ، ذ ونِّي وَارْ إِتّْبَارِّينْ ونِّي إِتّڭّنْ دّنْبْ، ذ ونِّي د-يَارزْفنْ ڒْمُوعْصِييّثْ ن إِبَابَاثنْ ذڭْ إِحنْجِيرنْ ؤُ ذڭْ إِحنْجِيرنْ ن إِحنْجِيرنْ نْسنْ أَڒْ \add جِّيڒْ\add* وِيسّْ ثْڒَاثَا ذ وِيسّْ أَربْعَا.“ \x ◘ \xo 34:‏7 \xt ؤُف. 20‏:‏6؛ ڒخْڒ. 14‏:‏18؛ أَعَوذ. 5‏:‏10؛ إِزهد. 86‏:‏15؛ 103‏:‏8؛ 145‏:‏8؛ إِرْم. 32‏:‏18\x*
\m 
\v 8 مُوسَا يُوضَارْ \add س وُوذمْ نّسْ\add* غَارْ ثمُّورْثْ ؤُشَا إِبنْذقْ.
\v 9 إِنَّا: ”\add أَ\add* سِيذِي إِنُو، مَاڒَا ؤُفِيغْ خنِّي أَرْضَا ذِي ثِيطَّاوِينْ نّشْ، أَذْ يُويُورْ خنِّي سِيذِي إِنُو ذِي ڒْوسْطْ نّغْ، مِينْزِي ڒْڭنْسْ إِقْسحْ. غْفَارْ أَنغْ ڒْمُوعْصِييّثْ نّغْ ؤُ قْبڒْ أَنغْ ذ ڒْوَارْثْ نّشْ!“ \x ◘ \xo 34:‏9 \xt لَاوِي 25‏:‏38؛ إِزهد. 28‏:‏9؛ 33‏:‏12؛ زَاك. 2‏:‏16\x*
\v 10 نتَّا إِنَّا: ”خْزَارْ، نشّْ أَذْ ڭّغْ ڒْعَاهْذْ. زَّاثْ إِ مَارَّا ڒْڭنْسْ نّكْ، أَذْ ڭّغْ ڒعْجَايبْ وَارْ إِتّْوَاڭّنْ شَا ذِي مَارَّا ثَامُّورْثْ ؤُ جَارْ مَارَّا ڒڭْنُوسْ، أَڒَامِي مَارَّا ڒْڭنْسْ ذِي ڒْوسْطْ نّسْ إِ زِي ثدْجِيذْ، أَذْ إِژَارْ مِينْ إِڭَّا سِيذِي، مِينْزِي مِينْ غَا ڭّغْ أَكِيذكْ أَذْ إِسّڭّْوذْ أَطَّاسْ. \x ◘ \xo 34:‏10 \xt أَعَوذ. 5‏:‏2؛ ياش. 10‏:‏12، 13\x*
\v 11 حْضَا مِينْ خْ شكْ وصِّيغْ أَسّْ-أَ! خْزَارْ، أَذْ أَژّْڒغْ زَّاثْ إِ ؤُغمْبُوبْ نّشْ خْ إِمُورِييّنْ ذ أَيْثْ ن كنْعَانْ ذ إِحِيتِّييّنْ ذ إِفِيرِيزِييّنْ ذ إِحِيوِييّنْ ذ إِيِيبُوسِييّنْ.
\v 12 غَاركْ أَذْ ثڭّذْ ڒْعَاهْذْ أَكْ-ذ ؤُمزْذُوغْ ن ثمُّورْثْ مَانِي غَا ثَاذْفذْ، حِيمَا نتَّا وَارْ ذ أَشْ إِتِّيڒِي ذ ڒْفخْ ذِي ڒْوسْطْ نّشْ. \x ◘ \xo 34:‏12 \xt ؤُف. 23‏:‏32؛ ڒخْڒ. 33‏:‏51؛ أَعَوذ. 7‏:‏2\x*
\v 13 إِتّْخصَّا أَومْ أَذْ ثْغضْڒمْ إِعَالْطَارنْ نْسنْ ؤُ أَذْ ثَارْژَامْ إِمَايْضُوثنْ نْسنْ \add إِقدّْسنْ\add* ؤُ أَذْ ثْهذْممْ ثِيربِّينْ نْسنْ ن شْوَارْثِي.
\v 14 وَارْ تّْبنْذِيقْ إِ أَربِّي نّغْنِي، مِينْزِي سِيذِي، ونِّي ؤُمِي قَّارنْ ’أَنسَّامْ‘، أَقَا-ث ذ إِجّْ ن أَربِّي إِتَّاسْمنْ. \f ◼ \fr 34:‏14 \ft \bd ’أَنسَّامْ‘\bd* - أَربِّي إِخْسْ أَقَا إِوْذَانْ أَذْعبْذنْ نتَّا وَاهَا، مِينْزِي وَارْ ذِينِّي أَربِّي يُوعْڒَانْ خْ مَارَّا مِينْ إِدْجَانْ أَمْ نتَّا. س ؤُينِّي نْزمَّارْ أَذْ نِينِي أَقَا نتَّا إِتَّاسمْ، نتَّا وَارْ إِتّخْسْ أَذْ ث نغْذَارْ، أَذْ نُويُورْ أَوَارْنِي إِ إِربِّيثنْ نّغْنِي. أَوَاڒْ ’أَنسَّامْ‘ إِخْسْ أَذْ يِينِي ’ونِّي إِتَّاسْمنْ‘.\f*  \x ◘ \xo 34:‏14 \xt ؤُف. 20‏:‏5\x*
\v 15 غَاركْ أَذْ ثڭّذْ ڒْعَاهْذْ أَكْ-ذ إِمزْذَاغْ ن ثمُّورْثْ، ؤُشَا \add خنِّي\add* أَذْ سّْفسْذنْ نِيثْنِي إِخفْ نْسنْ ؤُمِي غَا ذوْڒنْ أَوَارْنِي إِ إِربِّيثنْ نْسنْ، أَذْ قدّْمنْ ثِيغَارْصَا إِ إِربِّيثنْ نْسنْ، ؤُشَا أَذْ شكْ عَارْضنْ إِ مَاشَّا ن ثْغَارْصَا نْسنْ.
\v 16 أَذْ ثكْسِيذْ ثِيحنْجِيرِينْ نْسنْ \add ذ ثِيمْغَارِينْ\add* إِ إِحنْجِيرنْ نّشْ، \add مَاشَا\add* أَذْ سّْفسْذنْثْ ثْحنْجِيرِينْ نْسنْ إِخفْ نْسنْثْ ؤُمِي غَا ذوْڒنْ أَوَارْنِي إِ إِربِّيثنْ نْسنْثْ ؤُشَا أَذْ أَرّنْثْ إِحنْجِيرنْ نّشْ أَذْ ذوْڒنْ أَوَارْنِي إِ إِربِّيثنْ نْسنْثْ. \x ◘ \xo 34:‏16 \xt 1 إِج. 11‏:‏2\x*
\m 
\v 17 وَارْ تّڭّْ إِ يِيخفْ نّشْ إِربِّيتّنْ ن ؤُفسَّايْ. \f ◼ \fr 34:‏17 \ft \bd ’إِربِّيثنْ ن ؤُفسَّايْ‘\bd* - إِخْسْ أَذْ يِينِي ’ڒخْيَارَاثْ إِفسْينْ ن إِربِّيثنْ نْسنْ‘.\f*
\m 
\v 18 أَذْ ثحْضِيضْ ڒْعِيذْ ن وغْرُومْ بْڒَا أَنْثُونْ: سبْعَا ن وُوسَّانْ أَذْ ثشّذْ أَغْرُومْ بْڒَا أَنْثُونْ، ذِي ڒْوقْثْ إِتّْوَاڭّنْ ذڭْ ؤُيُورْ أَبِيبْ، أَمْ مَامّشْ شكْ وصِّيغْ، مِينْزِي ذڭْ ؤُيُورْ أَبِيبْ إِ د-ثفّْغذْ زِي مِيصْرَا. \x ◘ \xo 34:‏18 \xt ؤُف. 12‏:‏15؛ 23‏:‏15\x*
\m 
\v 19 مَارَّا مِينْ يَارزّْمنْ ڒمْڒَاوثْ \add ذ أَمزْوَارُو\add* إِنُو، مَارَّا إِوثْمَانْ ن ڒبْهَايمْ نّشْ إِ غَا يَارْزّْمنْ \add ڒمْڒَاوثْ ذ أَمزْوَارُو\add*، أَمْ ونِّي ن ؤُفُونَاسْ، أَمْ ونِّي ن وُودْجِي. \x ◘ \xo 34:‏19 \xt ؤُف. 13‏:‏2؛ 22‏:‏29؛ حِز. 44‏:‏30\x*
\v 20 \add مَاڒَا\add* أَمنْزُو ن وغْيُوڒْ يَارْزمْ \add ڒمْڒَاوْرَاثْ ذ أَمزْوَارُو\add*، أَذْ ث ثفْذِيذْ س يِيجّْ زڭْ وُودْجِي. مَاڒَا وَارْ ث ثفْذِيذْ، أَذْ أَسْ ثَارْژذْ إِرِي. أَذْ ثفْذِيذْ مَارَّا إِمنْزَا ن إِحنْجِيرنْ نّشْ.
\m وَارْ إِعدّڒْ أَذْ ضْهَارنْ س إِفَاسّنْ خْوَانْ زَّاثْ إِ وُوذمْ إِنُو. \x ◘ \xo 34:‏20 \xt ؤُف. 13‏:‏13؛ 23‏:‏15؛ أَعَوذ. 16‏:‏16\x*
\m 
\v 21 ستَّا ن وُوسَّانْ أَذْ ثْخذْمذْ، \add مَاشَا\add* ذڭْ وَاسّْ وِيسّْ سبْعَا أَذْ ثَاريّْحذْ. ؤُڒَا ذِي \add ڒْْوقْثْ ن\add* ثْيَارْزَا ذ ثْميْرَا أَذْ ثَاريّْحذْ. \x ◘ \xo 34:‏21 \xt ؤُف. 20‏:‏9\x*
\m 
\v 22 أَذْ ثڭّذْ ڒْعِيذْ ن سِيمَانَاثْ، أَقَا-ث ذ \add ڒْعِيذْ ن\add* ثْمنْزُوثْ ن ثْميْرَا ن يِيرْذنْ، ؤُڒَا ذ ڒْعِيذْ ن ؤُسْمُونِي غَارْ ؤُنڭَّارْ ن ؤُسڭّْوَاسْ. \x ◘ \xo 34:‏22 \xt ؤُف. 23‏:‏16\x*
\m 
\v 23 كُوڒْ أَرْيَازْ أَذْ د-إِبَانْ ثْڒَاثَا ن ثْوَاڒَاوِينْ ذڭْ ؤُسڭّْوَاسْ زَّاثْ إِ وُوذمْ ن سِيذِي، سِيذِي، أَربِّي ن إِسْرَائِيل، \x ◘ \xo 34:‏23 \xt ؤُف. 23‏:‏17؛ أَعَوذ. 16‏:‏16\x*
\v 24 مِينْزِي زَّاثْ إِ ؤُغمْبُوبْ نّشْ أَذْ كّْسغْ ثَاسْغَارْثْ ن ڒْوَارْثْ خْ ڒڭْنُوسْ ؤُشَا أَذْ سّْوسْعغْ إِيْمِيرنْ نّشْ ؤُشَا ؤُڒَا ذ إِجّنْ أَذْ إِمّژْرِي \add أَذْ يَاشَارْ\add* ثَامُّورْثْ نّشْ، خْمِي غَا ثْڭعّْذذْ ثْڒَاثَا ن ثْوَاڒَاوِينْ ذڭْ ؤُسڭّْوَاسْ، حِيمَا أَذْ ثْبَانذْ زَّاثْ إِ وُوذمْ ن سِيذِي، أَربِّي نّشْ.
\m 
\v 25 وَارْ تّْقدّمْ إِذَامّنْ ن ثْغَارْصْثْ إِنُو أَكْ-ذ مِينْ إِخمَّارنْ. ثَاغَارْصْثْ ن ڒْعِيذْ \add ن ثْغَارْصْثْ\add* ن ؤُسعْذُو وَارْ تّْنُوسِي دْجِيڒثْ أَڒْ صّْبحْ. \x ◘ \xo 34:‏25 \xt ؤُف. 23‏:‏18\x*
\m 
\v 26 ثَامزْوَارُوثْ ن ثْمنْزُوثْ ن وُوذمْ ن ثمُّورْثْ نّشْ أَذْ \add ت\add*-إِ-د-ثَاوْيذْ غَارْ ثَادَّارْثْ ن سِيذِي، أَربِّي نّشْ.
\m وَارْ سْننِّي إِغَايْضْ ذ أَمژْيَانْ س ؤُغِي ن يمَّاسْ.“ \x ◘ \xo 34:‏26 \xt ؤُف. 23‏:‏19؛ لَاوِي 22‏:‏27؛ أَعَوذ. 14‏:‏21\x*
\b
\m 
\v 27 إِنَّا سِيذِي إِ مُوسَا: ”أَرِي أَوَاڒنْ-أَ إِ يِيخفْ نّشْ، مِينْزِي أَمْ مَامّشْ قَّارنْ وَاوَاڒنْ-أَ، أَقَا ڭِّيغْ ڒْعَاهْذْ أَكِيذكْ ؤُ أَكْ-ذ إِسْرَائِيل.“
\v 28 ؤُشَا \add مُوسَا\add* ثُوغَا ذِينْ أَكْ-ذ سِيذِي أَربْعِينْ ن وُوسَّانْ ذ أَربْعِينْ ن دْجْيَاڒِي. وَارْ إِشِّي أَغْرُومْ نِيغْ إِسْوَا أَمَانْ. ؤُشَا يُورَا ذِي ثڒْوِيحِينْ أَوَاڒنْ ن ڒْعَاهْذْ،عشْرَا ن وَاوَاڒنْ. \x ◘ \xo 34:‏28 \xt ؤُف. 24‏:‏1، 18؛ 31‏:‏18؛ 34‏:‏1؛ أَعَوذ. 4‏:‏13؛ 9‏:‏9، 18؛ 10‏:‏2\x*
\m 
\v 29 \add ڒَْامِي\add* د-إِهْوَا مُوسَا زڭْ وذْرَارْ ن سِينَا، أَمْ ثُوغَا ثْنَاينْ ن ثڒْوِيحِينْ ن شّْهَاذثْ ذڭْ إِفَاسّنْ ن مُوسَا أَمْ د-إِهْوَا زڭْ وذْرَارْ، إِمْسَارْ أَقَا وَارْ إِسِّينْ مُوسَا بلِّي ثِيڒْمشْثْ ن ؤُغمْبُوبْ نّسْ ثَارقّْ مِينْزِي ثُوغَا أَكِيذسْ إِسَّاوَاڒْ. \x ◘ \xo 34:‏29 \xt 2 كُور. 3‏:‏7\x*
\v 30 هَارُونْ ذ مَارَّا أَيْثْ ن إِسْرَائِيل صوْضنْ غَارْ مُوسَا، ؤُ خْزَارْ، ثِيڒْمشْثْ ن وُوذمْ نّسْ ثُوغَا ثَارقّْ، ڭّْوذنْ أَذْ غَارسْ د-قَارّْبنْ.
\v 31 إِڒَاغَا-د خَاسنْ مُوسَا ؤُشَا إِذْوڒْ-د هَارُونْ ذ مَارَّا ڒْحُوكَّامْ ن ثْمسْمُونْثْ غَارسْ ؤُشَا إِسِّيوڒْ مُوسَا أَكِيذْسنْ.
\v 32 أَوَارْنِي أَسْ قَارّْبنْ-د مَارَّا أَيْثْ ن إِسْرَائِيل ؤُشَا نتَّا يُومُورْ إِ-ثنْ مَارَّا مِينْ خفْ إِسِّيوڒْ سِيذِي أَكِيذسْ ذڭْ وذْرَارْ ن سِينَا.
\v 33 \add ڒَْامِي\add* إِكمّڒْ مُوسَا أَوَاڒْ نّسْ أَكِيذْسنْ، إِڭَّا أَڒحَّافْ خْ وُوذمْ نّسْ. \x ◘ \xo 34:‏33 \xt 2 كُور. 3‏:‏7، 13\x*
\v 34 \add خْمِي\add* إِ غَا يِيڒِي مُوسَا زَّاثْ إِ وُوذمْ ن سِيذِي حِيمَا أَذْ كِيذسْ إِسِّيوڒْ، إِكّسْ أَڒحَّافْ، أَڒْ د-إِفّغْ \add عَاوذْ\add*. ؤُ ڒَامِي د-إِفّغْ غَارْ بَارَّا، إِسِّيوڒْ أَكْ-ذ أَيْثْ ن إِسْرَائِيل مِينْ ذ أَسْ يُومُورْ \add سِيذِي\add*.
\v 35 ؤُشَا ژْرِينْ أَيْثْ ن إِسْرَائِيل أَغمْبُوبْ ن مُوسَا، أَقَا ثِيڒْمشْثْ ن وُوذمْ نّسْ ثَارقّْ، \add خنِّي\add* يَارَّا مُوسَا أَڒحَّافْ خْ وُوذمْ نّسْ، أَڒْ د-يُوذفْ \add عَاوذْ\add*، حِيمَا أَكِيذسْ إِسِّيوڒْ.
\b
\b
\c 35
\s1 أَسوْجذْ ن ڒبْنِي ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ
\m 
\v 1 مُوسَا إِسّْمُونْ مَارَّا ثَامسْمُونْثْ ن أَيْثْ ن إِسْرَائِيل ؤُشَا إِنَّا أَسنْ: ”إِنَا ذ أَوَاڒنْ نِّي يُومُورْ سِيذِي، حِيمَا أَذْ ثنْ ثڭّمْ. \x ◘ \xo 35:‏1 \xt 34‏:‏32\x*
\v 2 ستَّا ن وُوسَّانْ أَذْ ثڭّذْ ڒْخذْمثْ ؤُ أَسّْ وِيسّْ سبْعَا أَذْ أَومْ يِيڒِي إِقدّسْ، أَقَا ذ سّبْثْ، أَرَّاحثْ ثْمُونْ إِ سِيذِي. كُوڒْ إِجّْ، ونِّي ذَايسْ إِڭِّنْ \add شَا ن\add* ڒْخذْمثْ، أَذْ إِتّْوَانغْ. \x ◘ \xo 35:‏2 \xt ؤُف. 20‏:‏8؛ 31‏:‏15؛ لَاوِي 23‏:‏3؛ أَعَوذ. 5‏:‏12؛ لك. 13‏:‏14\x*
\v 3 وَارْ ثسّْرُوغِيمْ كنِّيوْ ثِيمسِّي ذِي مَارَّا ثِيزذِّيغِينْ نْومْ ذڭْ وَاسّْ ن سّبْثْ.“ \x ◘ \xo 35:‏3 \xt ؤُف. 16‏:‏23\x*
\b
\m 
\v 4 إِسِّيوڒْ مُوسَا أَكْ-ذ مَارَّا ثَامسْمُونْثْ ن أَيْثْ ن إِسْرَائِيل، إِنَّا: ”ذ وَا ذ مِينْ إِوصَّا سِيذِي، \add ؤُمِي\add* إِنَّا: \f ◼ \fr 35:‏4 \ft \bd ’ذ وَا ذ مِينْ إِوصَّا سِيذِي‘\bd* - س ثْعِيبْرَانِيثْ ’ذ وَا ذ أَوَاڒْ إِ يُومُورنْ سِيذِي‘.\f*
\v 5 ’كْسِيمْ زِي مِينْ غَارْومْ إِشْثْ ن ثوْهِيبْثْ ن ؤُسْڭعّذْ إِ سِيذِي. كُوڒْ إِجّْ، ونِّي ؤُمِي ينُّورْزمْ وُوڒْ نّسْ، أَذْ ت يَاوِي، أَقَا-ت ذ \bd ثَاوْهِيبْثْ ن ؤُسْڭعّذْ\bd* إِ سِيذِي: ؤُرغْ ذ نُّوقَارْثْ ذ نّْحَاسْ، \x ◘ \xo 35:‏5 \xt ؤُف. 25‏:‏2\x*
\v 6 \add أَفِيڒُو\add* أَذحْمِي ذ ؤُرْجُووَانِي ذ ؤُزڭّْوَاغْ إِحذْقنْ ذ ڒقْطنْ أَزْذَاذْ ذ شّْعَارْ ن إِغَايْضنْ، \x ◘ \xo 35:‏6 \xt ؤُف. 25‏:‏4\x*
\v 7 إِڒْمَاونْ إِزڭّْوَاغنْ ن إِشَارِّييّنْ ذ إِڒْمَاونْ ن دّنْفِيڒَاثْ ذ ؤُكشُّوضْ ن ؤُكَاسِييَا، \x ◘ \xo 35:‏7 \xt ؤُف. 25‏:‏5\x*
\v 8 زّشْثْ إِ ثْفَاوْثْ، ڒعْطُورْ إِ زّشْثْ ن وذْهَانْ ؤُ إِ ڒبْخُورْ إِتّْفُوحنْ، \x ◘ \xo 35:‏8 \xt ؤُف. 25‏:‏6\x*
\v 9 إِژْرَا ن ؤُنِيكْسْ ذ إِژْرَا \add إِغْڒَانْ نّغْنِي\add*، مَاحنْذْ أَذْ ثنْ ڭّنْ خْ ؤُپَالْطُو ؤُ خْ ثجْمشْثْ. \x ◘ \xo 35:‏9 \xt ؤُف. 25‏:‏7؛ 28‏:‏17، 20\x*
\v 10 مَارَّا إِنِّي \add إِدْجَانْ\add* جَارْ أَومْ س وُوڒْ ذ أَمِيغِيسْ، أَذْ د-أَسنْ أَذْ ڭّنْ مَارَّا مِينْ يُومُورْ سِيذِي:
\v 11 ثَازذِّيغْثْ، أَقِيضُونْ نّسْ ذ ثْسقَّافْثْ نّسْ ذ ثْسنَّارِينْ نّسْ ذ ثْفڒْوِينْ نّسْ ذ ثْحنْيَا نّسْ ن ؤُعَارّضْ ذ إِپِيلَارنْ نّسْ ذ ثْيَارْسَاوِينْ نّسْ، \x ◘ \xo 35:‏11 \xt ؤُف. 26‏:‏26\x*
\v 12 ذ تَّابُوثْ أَكْ-ذ إِعُومَاذْ نّسْ \add إِ ثَاربُّوثْ\add* ذ ثْقبَّارْثْ ن وصْڒَاحْ ذ ؤُڒحَّافْ إِ دُّورِي،
\v 13 ذ ثْزوْضَا أَكْ-ذ إِعُومَاذْ نّسْ \add إِ ثَاربُّوثْ\add* ذ مَارَّا ڒقْشُوعْ نّسْ ذ وغْرُومْ ن وسْشَانْ، \x ◘ \xo 35:‏13 \xt ؤُف. 25‏:‏23، 30\x*
\v 14 ذ ڒْقنْذِيڒْ إِ ثْفَاوْثْ ذ ڒقْشُوعْ نّسْ ذ ثفْثِيڒِينْ نّسْ ذ زّشْثْ إِ ثْفَاوْثْ
\v 15 ذ ؤُعَالْطَارْ ن ڒبْخُورْ أَكْ-ذ إِعُومَاذْ نّسْ \add إِ ثَاربُّوثْ\add* ذ زّشْثْ إِ وذْهَانْ ذ ڒبْخُورْ إِتّْفُوحنْ ذ أَرْوَاقْ ن وَاذَافْ غَارْ وَاذَافْ ن ثْزذِّيغْثْ، \x ◘ \xo 35:‏15 \xt ؤُف. 26‏:‏36؛ 30‏:‏1؛ 31‏:‏11\x*
\v 16 ذ ؤُعَالْطَارْ ن وشْمَاضْ ذ ثْرَاشَّا نّسْ ن نّْحَاسْ ذ إِعُومَاذْ نّسْ \add إِ ثَاربُّوثْ\add* ذ مَارَّا ڒقْشُوعْ نّسْ ذ ثْبَانْيُوثْ س ؤُضَارْ نّسْ، \x ◘ \xo 35:‏16 \xt ؤُف. 27‏:‏4؛ 30‏:‏18\x*
\v 17 ذ ڒِيزَارَاثْ ن ڒمْرَاحْ، إِپِيلَارنْ نّسْ أَكْ-ذ ثْيَارْسَاوِينْ نْسنْ ذ أَرْوَاقْ إِ وَاذَافْ ن ڒمْرَاحْ، \x ◘ \xo 35:‏17 \xt ؤُف. 27‏:‏9، 16\x*
\v 18 ذ ڒوْثَاذْ ن ثْزذِّيغْثْ ذ ڒوْثَاذْ ن ڒمْرَاحْ ذ إِفِيڒَانْ نْسنْ، \x ◘ \xo 35:‏18 \xt ؤُف. 27‏:‏19\x*
\v 19 أَرُّوضْ إِ ڒْخذْمثْ ذڭْ ؤُقدَّاسْ، أَرُّوضْ إِقدّْسنْ ن ؤُكهَّانْ هَارُونْ ذ وَارُّوضْ ن وَارَّاوْ نّسْ، مَاحنْذْ أَذْ خذْمنْ أَمْ يِيكهَّاننْ.‘ “\x ◘ \xo 35:‏19 \xt ؤُف. 28؛ 31‏:‏10\x*
\v 20 \add خنِّي\add* فّْغنْ نِيثْنِي، مَارَّا ثَامسْمُونْثْ ن أَيْثْ ن إِسْرَائِيل، \add ڭّْوجنْ\add* زِي زَّاثْ ن ؤُغمْبُوبْ ن مُوسَا.
\m 
\v 21 \add خنِّي\add* يُوسَا-د كُوڒْ إِجّْ، ونِّي ؤُمِي إِنْهزّْ وُوڒْ نّسْ، ؤُ مَارَّا ونِّي ؤُمِي إِنُّورْزمْ بُوحْبڒْ نّسْ، ؤُشَا إِوْينْ-د نِيثْنِي ثَاوْهِيبْثْ ن ؤُسْڭعّذْ، \add ثنِّي سّْڭعّْذنْ نِيثْنِي غَارْ\add* سِيذِي، ذ ثنِّي إِ غَا يِيڒِينْ إِ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ ؤُ إِ ثْسخَّارْثْ إِ ذَايسْ ؤُ إِ وَارُّوضْ إِقدّْسنْ.
\v 22 \add أَمُّو\add* د-ؤُسِينْ إِرْيَازنْ جْمِيعْ أَكْ-ذ ثمْغَارِينْ، مَارَّا إِنِّي ؤُمِي إِنُّورْزمْ وُوڒْ \add نْسنْ\add* ؤُشَا إِوْينْ-د ثِيمسَّاكِينْ ذ ثخْرَازِينْ ن ؤُمزُّوغْ ذ ثِينْزَارْ ذ ثْخُوذَانْ \add ن ؤُشمِّيعْ\add* ذ ثْسذِّييِينْ س وذْمَامْ ن وُورغْ ذ مَارَّا ڒقْشُوعْ ن وُورغْ، \add وَاهْ،\add* كُوڒْ  إِجّنْ يِيوِي إِشْثْ ن ثوْهِيبْثْ ن ونْهزِّي ن وُورغْ إِ سِيذِي.
\v 23 مَارَّا وِي غَارْ إِتّْوَافْ \add أَفِيڒُو\add* أَذحْمِي ذ ؤُرْجُووَانِي ذ ؤُزڭّْوَاغْ إِحذْقنْ نِيغْ ڒقْطنْ أَزْذَاذْ نِيغْ شّْعَارْ ن إِغَايْضنْ نِيغْ إِڒْمَاونْ إِزڭّْوَاغنْ ن إِشَارِّييّنْ نِيغْ إِڒْمَاونْ ن دّنْفِيڒَاثْ، إِوْينْ-د \add مَانْ أَيَا\add*.
\v 24 مَارَّا وِي إِسّْڭعّْذنْ ثَاوْهِيبْثْ ن نُّوقَارْثْ نِيغْ ن نّْحَاسْ، إِوْينْ ثَاوْهِيبْثْ-أَ ن ؤُسْڭعّذْ غَارْ سِيذِي، ذ مَارَّا وِي غَارْ إِتّْوَافْ ؤُكشُّوضْ ن ؤُكَاسِييَا إِ مَارَّا ڒْخذْمثْ ن ثْسخَّارْثْ، إِوْينْ \add مَانْ أَيَا\add*.
\m 
\v 25 مَارَّا ثِيمْغَارِينْ س وُوڒْ أَمِيغِيسْ تّْقَارْضْشنْثْ س إِفَاسّنْ نْسنْثْ ؤُشَا نِيثنْثِي إِوْينْثْ-إِ-د مِينْ قَارضْشنْثْ: \add أَفِيڒُو\add* أَذحْمِي ذ ؤُرْجُووَانِي ذ ؤُزڭّْوَاغْ إِحذْقنْ ذ ڒقْطنْ أَزْذَاذْ. \f ◼ \fr 35:‏25 \ft \bd ’س وُوڒْ أَمِيغِيسْ‘\bd* - س ثْعِيبْرَانِيثْ ’أَمِيغِيسْ ن وُوڒْ‘.\f*  \x ◘ \xo 35:‏25 \xt أَوڒن. 31‏:‏19\x*
\v 26 مَارَّا ثِيمْغَارِينْ نِّي ؤُمِي إِنْهزّْ وُوڒْ نْسنْثْ س ثِيغِيثْ، قَارضْشنْثْ شّْعَارْ ن إِغَايْضنْ.
\m 
\v 27 ڒْحُوكَّامْ إِوْينْ-د إِژْرَا ن ؤُنِيكْسْ ذ إِژْرَا \add إِغْڒَانْ نّغْنِي\add*، حِيمَا أَذْ ثنْ ڭّنْ خْ ؤُپَالْطُو ؤُ خْ ثجْمشْثْ،
\v 28 ڒعْطُورْ ذ زّشْثْ إِ ثْفَاوْثْ ذ زّشْثْ إِ وذْهَانْ ؤُ إِ ڒبْخُورْ إِتّْفُوحنْ. \x ◘ \xo 35:‏28 \xt ؤُف. 25‏:‏6\x*
\m 
\v 29 أَيْثْ ن إِسْرَائِيل وْشِينْ س ڒْخَاضَارْ إِ سِيذِي، مَارَّا إِرْيَازنْ ذ ثمْغَارِينْ، إِنِّي ؤُمِي إِنْهزّْ وُوڒْ نْسنْ، مَاحنْذْ أَذْ وْشنْ س ڒْخَاضَارْ إِ مَارَّا ڒْخذْمثْ نِّي يُومُورْ سِيذِي، حِيمَا أَذْ ثتّْوَاڭّْ س ثْسخَّارْثْ ن مُوسَا.
\m 
\v 30 \add خنِّي\add* إِنَّا مُوسَا إِ أَيْثْ ن إِسْرَائِيل: ”خْزَارمْ، سِيذِي إِڒَاغَا-د إِ \bd بَاصَالِييِيلْ\bd*، مِّيسْ ن ؤُرِي، مِّيسْ ن حُورْ، زِي ڒَادْجْ ن يَاهُوذَا، س يِيسمْ \add نّسْ\add*. \x ◘ \xo 35:‏30 \xt ؤُف. 31‏:‏2\x*
\v 31 إِشُّورْ إِ-ث أَرُّوحْ ن أَربِّي س ثِيغِيثْ ذ ڒعْقڒْ ذ ثُوسّْنَا ؤُ س مَارَّا \add مِينْ إِتّْخصَّانْ ن\add* ثْزمَّارْ ن صّْنَايعْ \x ◘ \xo 35:‏31 \xt ؤُف. 31‏:‏3؛ إِشا. 11‏:‏2؛ 1 كُور. 12‏:‏8؛ كُول. 1‏:‏9\x*
\v 32 إِ ؤُخمّمْ ن \add عْڒَامْ كُوڒْ\add* إِرقَّامنْ، حِيمَا أَذْ ثنْ يڭّْ س وُورغْ ذ نُّوقَارْثْ ذ نّْحَاسْ، \x ◘ \xo 35:‏32 \xt ؤُف. 31‏:‏4\x*
\v 33 ؤُ إِ ؤُنقَّاشْ ن إِژْرَا \add إِغْڒَانْ\add* ذ ؤُسَارْسِي نْسنْ، ؤُ إِ ؤُنقَّاشْ ن ؤُكشُّوضْ ؤُ حِيمَا أَذْ إِڭّْ مَارَّا إِرقَّامنْ س لْفنّْ. \x ◘ \xo 35:‏33 \xt ؤُف. 31‏:‏5\x*
\v 34 إِڭَّا \add أَربِّي\add* ذڭْ وُوڒْ نّسْ ثَاونْڭِيثْ إِ ؤُسڒْمذْ، \add ذڭْ وُوڒْ\add* نّسْ ؤُ \add ذڭْ وُوڒْ ن\add* \bd أَهُولِييَابْ\bd*، مِّيسْ ن أَخِيسَامَاكْ، زِي ڒَادْجْ ن دَان.
\v 35 إِشُّورْ إِ-ثنْ س ثِيغِيثْ ن وُوڒْ، مَاحنْذْ أَذْ ڭّنْ مَارَّا ڒْخذْمثْ: \add ڒْخذْمثْ ن\add* ثَانقَّاشْثْ ذ وَارْشَامْ ذ ؤُمُوذِي س \add ؤُفِيڒُو\add* أَذحْمِي ذ ؤُرْجُووَانِي ذ ؤُزڭّْوَاغْ إِحذْقنْ ذ ڒقْطنْ أَزْذَاذْ ؤُڒَا ذ \add ڒْخذْمثْ ن\add* ؤُخيَّاضْ.“ نِيثْنِي ڭِّينْ كُوڒْ ڒْخذْمثْ ؤُ تّْسَاقَارنْ أَرْشَامنْ س لْفنّْ. \x ◘ \xo 35:‏35 \xt ؤُف. 26‏:‏1\x*
\b
\b
\c 36
\m 
\v 1 بَاصَالِييِيلْ ذ أَهُولِييَابْ ذ كُوڒْ أَرْيَازْ س وُوڒْ أَمِيغِيسْ إِ ؤُمِي إِوْشَا سِيذِي ثِيغِيثْ ذ ڒعْقڒْ، مَاحنْذْ أَذْ سّْننْ مَامّشْ غَا ڭّنْ مَارَّا ڒْخذْمثْ إِ ثْسخَّارْثْ ن زَّاوشْثْ إِقدّْسنْ، ڭِّينْ مَارَّا أَمْ مَامّشْ ثنْ يُومُورْ سِيذِي.
\v 2 مُوسَا إِڒَاغَا-د إِ بَاصَالِييِيلْ ذ أَهُولِييَابْ ذ كُوڒْ أَرْيَازْ س وُوڒْ أَمِيغِيسْ، ؤُمِي إِڭَّا سِيذِي ثِيغِيثْ ذڭْ وُوڒْ نّسْ، ؤُڒَا مَارَّا ونِّي ؤُمِي إِنْهزّْ وُوڒْ نّسْ، مَاحنْذْ أَذْ د-يَاسْ غَارْ ڒْخذْمثْ ؤُشَا أَذْ ت إِڭّْ.
\m 
\v 3 نِيثْنِي كْسِينْ زِي زَّاثْ ن وُوذمْ ن مُوسَا مَارَّا ثَاوْهِيبْثْ نِّي سّْڭعّْذنْ أَيْثْ ن إِسْرَائِيل إِ ڒْخذْمثْ ذِي طّْوعْ نِي ثْسخَّارْثْ ن زَّاوشْثْ إِقدّْسنْ، مَاحنْذْ أَذْ ڭّنْ ڒْخذْمثْ نِّي. ؤُشَا \add أَقَا\add* عَاذْ ڭِّينْ أَذْ أَسْ د-أَوْينْ كُوڒْ صّْبحْ ثِيوْهِيبِينْ س ڒْخَاضَارْ.
\v 4 \add خنِّي\add* ؤُسِينْ-د مَارَّا إِرْيَازنْ إِمِيغِيسنْ، إِنِّي ثُوغَا إِشغْڒنْ خْ مَارَّا ڒْخذْمثْ ن زَّاوشْثْ إِقدّْسنْ، إِجّْ إِجّْ ذوْڒنْ-د زِي ڒْخذْمثْ نِّي ڭِّينْ نِيثْنِي، \f ◼ \fr 36:‏4 \ft \bd ’إِجّْ إِجّْ‘\bd* - س ثْعِيبْرَانِيثْ ’أَرْيَازْ أَرْيَازْ‘.\f*
\v 5 ؤُشَا سِّيوْڒنْ أَكْ-ذ مُوسَا، نَّانْ: ”ڒْْڭنْسْ يِيوِي-د كْثَارْ زِي مِينْ إِتّْخصَّانْ ذِي طّْوعْ نْ ڒْخذْمثْ نِّي إِ \add ذ أَنغْ\add* يُومُورْ سِيذِي، حِيمَا أَذْ ت نڭّْ.“
\v 6 \add خَاسْ ؤُشَا\add* يُومُورْ مُوسَا، حِيمَا أَذْ بَارّْحنْ ذِي ڒْمَارْڭحْ ن ڒْعسْكَارْ، أَذْ إِنِينْ: ”وَارْ تّجِّي أَرْيَازْ نِيغْ ثَامْغَارْثْ عَاذْ أَذْ يڭّْ شَا ن ڒْخذْمثْ نِّي إِ غَا إِسّْڭعّذْ ذ ثَاوْهِيبْثْ إِ زَّاوشْثْ إِقدّْسنْ!“ أَمُّو إِ إِسّْبدّْ \add مُوسَا\add* ڒْڭنْسْ أَذْ يَاوِي \add عَاذْ كْثَارْ\add*،
\v 7 مِينْزِي شْفَا ثِيمسْڒَايِينْ نِّي ذ إِوْينْ إِ مَارَّا ڒْخذْمثْ إِ غَا ڭّنْ، أَقَا ثْشطّْ \add عَاذْ\add* كْثَارْ.
\m 
\v 8 جَارْ يِينِّي غَارْ ثُوغَا ڒْخذْمثْ، أَقَا مَارَّا إِمِيغِيسنْ ن وُوڒْ ڭِّينْ \bd ثَازذِّيغْثْ\bd* زِي \bd عشْرَا ن ثْجَارْثِيڒِينْ ن ڒقْطنْ أَزْذَاذْ إِمُوذنْ ؤُ س \bdit ؤُفِيڒُو\bdit* أَذحْمِي ذ ؤُرْجُووَانِي ذ ؤُزڭّْوَاغْ إِحذْقنْ أَكْ-ذ إِكِيرُوبنْ\bd* نِّي \add خَاسنْثْ\add* إِڭَّا أَمْ يِيجّْ ن وَارْشَامْ ن ؤُفنَّانْ. \f ◼ \fr 36:‏8 \ft \bd ’إِكِيرُوبنْ‘\bd* - إِشْثْ ن مَارْكَا ن لْمَالَاكَاثْ.\f*
\v 9 ثُوزّڭَّارْثْ ن إِشْثْ ن ثْجَارْثِيڒْثْ ثُوغَا-ت ثْمنْيَا ؤُ -عشْرِينْ ن إِغَادْجنْ ؤُ ثِيرُو ن إِشْثْ ن ثْجَارْثِيڒْثْ ثُوغَا-ث أَربْعَا ن إِغَادْجنْ ؤُ مَارَّا ثِيجَارْثِيڒِينْ غَارْسنْثْ ذ ڒعْبَارْ ذ إِجّْ. \x ◘ \xo 36:‏9 \xt ؤُف. 26‏:‏2\x*
\v 10 إِسّْمُونْ خمْسَا ن ثْجَارْثِيڒِينْ إِشْثْ أَكْ-ذ ثنّغْنِي ؤُشَا خمْسَا ن ثْجَارْثِيڒِينْ إِسّْمُونْ إِ-ثنْثْ \add عَاوذْ\add* إِشْثْ أَكْ-ذ ثنّغْنِيثْ. \f ◼ \fr 36:‏10 \ft \bd ’إِشْثْ أَكْ-ذ ثنّغْنِيثْ‘\bd* - س ثْعِيبْرَانِيثْ ’إِشْثْ غَارْ يِيشْثْ‘.\f*
\v 11 \add خنِّي\add* إِڭَّا ثِيسَارَاوِينْ إِذحْمَانِييّنْ ذِي ثْمَا ن يِيشْثْ ن ثْجَارْثِيڒْثْ غَارْ طَّارْفْ غَارْ ؤُسڒْقِي ؤُشَا أَمنِّي إِ ثنْثْ إِڭَّا \add عَاوذْ\add* ذِي ثْمَا ن ثْجَارْثِيڒْثْ نّغْنِي غَارْ طَّارْفْ، غَارْ \add مَانِي إِدْجَا\add* ؤُسڒْقِي نّغْنِي. \x ◘ \xo 36:‏11 \xt ؤُف. 26‏:‏4\x*
\v 12 إِڭَّا خمْسِينْ ن ثْسَارَاوِينْ خْ ثْمَا ن يِيشْثْ ن ثْجَارْثِيڒْثْ ذ خمْسِينْ ن ثْسَارَاوِينْ غَارْ طَّارْفْ ن ثْجَارْثِيڒْثْ \add نّغْنِي\add* غَارْ ؤُسڒْقِي نّغْنِي. ثِيسَارَاوِينْ طّْفنْثْ \add نِيشَانْ\add* إِشْثْ ذِي ثنّغْنِيثْ. \x ◘ \xo 36:‏12 \xt ؤُف. 26‏:‏5، 10\x*
\v 13 إِڭَّا \add عَاوذْ\add* خمْسِينْ ن ثْسنَّارِينْ ن وُورغْ ؤُشَا إِسّْمُونْ ثِيجَارْثِيڒِينْ إِشْثْ إِ ثنّغْنِي س ثْسنَّارِينْ ؤُشَا \add أَمُّو\add* ثذْوڒْ ثْزذِّيغْثْ ذ إِشْثْ. \x ◘ \xo 36:‏13 \xt ؤُف. 26‏:‏6\x*
\m 
\v 14 إِڭَّا \add عَاوذْ\add* \bd ثِيجَاڒْثِيڒِينْ ن شّْعَارْ ن إِغَايْضنْ\bd*، أَذْ إِڒِينْثْ ذ أَقِيضُونْ خْ ثْزذِّيغْثْ. إِڭَّا حِيطَاشْ ن ثْجَارْثِيڒِينْ.
\v 15 ثُوزّڭَّارْثْ ن إِشْثْ ن ثْجَارْثِيڒْثْ ثُوغَا-ت ثْڒَاثِينْ ن إِغَادْجنْ ؤُ ثِيرُو ن إِشْثْ ن ثْجَارْثِيڒْثْ ذ أَربْعَا ن إِغَادْجنْ. حِيطْعَاشْ ن ثْجَارْثِيڒِينْ غَارْسنْثْ ڒعْبَارْ ذ إِجّْ.
\v 16 نتَّا إِسّْمُونْ خمْسَا ن ثْجَارْثِيڒِينْ وحّذْسنْثْ ؤُ \add عَاوذْ\add* ستَّا ن ثْجَارْثِيڒِينْ وحّذْسنْثْ.
\v 17 إِڭَّا خمْسِينْ ن ثْسَارَاوِينْ خْ ثْمَا ن ثْجَارْثِيڒْثْ ثَانڭَّارُوثْ غَارْ \add طَّارْفْ ن\add* ؤُسڒْقِي \add أَكْ-ذ ثنّغْنِي\add* ؤُشَا إِڭَّا \add عَاوذْ\add* خمْسِينْ ن ثْسَارَاوِينْ خْ ثْمَا ن ثْجَارْثِيڒْثْ غَارْ \add طَّارْفْ ن\add* ؤُسڒْقِي نّغْنِي.
\v 18 إِڭَّا \add عَاوذْ\add* خمْسِينْ ن ثْسنَّارِينْ ن نّْحَاسْ، حِيمَا أَذْ إِسّْمُونْ أَقِيضُونْ مَاحنْذْ أَذْ ث يَارّْ ذ إِجّنْ. \x ◘ \xo 36:‏18 \xt ؤُف. 26‏:‏11\x*
\m 
\v 19 إِڭَّا \add عَاوذْ\add* \bd إِشْثْ ن ثْسقَّافْثْ ن إِڒْمَاونْ إِزڭّْوَاغنْ ن إِشَارِّييّنْ إِ ؤُقِيضُونْ\bd* ؤُشَا سنّجْ إِ مَانْ أَيَا \bd إِشْثْ ن ثْسقَّافْثْ ن إِڒْمَاونْ ن دّنْفِيڒَاثْ\bd*. \x ◘ \xo 36:‏19 \xt ؤُف. 26‏:‏14\x*
\m 
\v 20 إِڭَّا \bd ثِيفڒْوِينْ\bd* إِ ثْزذِّيغْثْ س ؤُكشُّوضْ ن ؤُكَاسِييَا نِّي إِبدّنْ \add نِيشَانْ\add*. \x ◘ \xo 36:‏20 \xt ؤُف. 26‏:‏15\x*
\v 21 ثُوزّڭَّارْثْ ن \add إِشْثْ ن\add* ثفْڒَاوْثْ ثُوغَا-تعشْرَا ن إِغَادْجنْ ؤُ ثِيرُو ن يِيشْثْ ن ثفْڒَاوْثْ ذ إِجّْ ن ؤُغِيڒْ ذ وزْينْ. \x ◘ \xo 36:‏21 \xt ؤُف. 26‏:‏16\x*
\v 22 كُوڒْ ثَافْڒوْثْ غَارسْ ثْنَاينْ ن إِضَارنْ، إِنِّي إِسّْمڒْقَانْ إِشْثْ أَكْ-ذ ثنّغْنِيثْ أَمْ ثْوتْشْمَاثِينْ أَمُّو إِ إِڭَّا س مَارَّا ثِيفڒْوِينْ ن ثْزذِّيغْثْ. \x ◘ \xo 36:‏22 \xt ؤُف. 26‏:‏17\x*
\v 23 إِڭَّا ثِيفڒْوِينْ إِ ثْزذِّيغْثْ، عِيشْرِينْ ن ثْفڒْوِينْ غَارْ جِّيهثْ ن لْجَانُوبْ، غَارْ يفُوسْ. \x ◘ \xo 36:‏23 \xt ؤُف. 26‏:‏18\x*
\v 24 إِڭَّا عَاوذْ أَربْعِينْ ن \bd ثْيَارْسَاوِينْ ن نُّوقَارْثْ\bd* سَاذُو عِيشْرِينْ ن ثْفڒْوِينْ، ثْنَاينْ ن ثْيَارْسَاوِينْ سَاذُو إِشْثْ ن ثفْڒَاوْثْ إِ ثْنَاينْ ن إِضَارنْ نّسْ، ؤُڒَا ذ ثْنَاينْ ن ثْيَارْسَاوِينْ سَاذُو ثَافْڒَاوْثْ نّغْنِي إِ ثْنَاينْ ن إِضَارنْ نّسْ. \x ◘ \xo 36:‏24 \xt ؤُف. 26‏:‏19\x*
\v 25 إِڭَّا \add عَاوذْ\add* عِيشْرِينْ ن ثْفڒْوِينْ إِ ؤُغزْذِيسْ نّغْنِي ن ثْزذِّيغْثْ، غَارْ ؤُغزْذِيسْ ن شَّامَالْ، \x ◘ \xo 36:‏25 \xt ؤُف. 26‏:‏20\x*
\v 26 س أَربْعِينْ ن ثْيَارْسَاوِينْ نّسْ ن نُّوقَارْثْ: ثْنَاينْ ن ثْيَارْسَاوِينْ سَاذُو إِشْثْ ن ثفْڒَاوْثْ ذ ثْنَاينْ ن ثْيَارْسَاوِينْ سَاذُو ثَافْڒَاوْثْ نّغْنِي. \x ◘ \xo 36:‏26 \xt ؤُف. 26‏:‏21\x*
\v 27 إِ إِغزْذِيسنْ ن ضفَّارْ ن ثْزذِّيغْثْ، غَارْ ؤُغزْذِيسْ ن ڒْغَارْبْ، إِڭَّا ستَّا ن ثْفڒْوِينْ. \x ◘ \xo 36:‏27 \xt ؤُف. 26‏:‏22\x*
\v 28 إِڭَّا ثْنَاينْ ن ثْفڒْوِينْ \add ذ ثِيفڒْوِينْ\add* إِ ثْغمُّورَا ن ثْزذِّيغْثْ غَارْ ثْنَاينْ ن إِغزْذِيسنْ غَارْ ضفَّارْ. \x ◘ \xo 36:‏28 \xt ؤُف. 26‏:‏23\x*
\v 29 زِي سْوَادَّايْ ثُوغَا ڒصْقنْثْ أَمْ وَاشْنِيونْ ؤُشَا أَمُّو إِ ثنْثْ ثُوغَا ذ إِشْثنْ أَڒْ د-أَوْضنْثْ سنّجْ ذڭْ إِشْثْ ن ثخْرَازْثْ. أَمُّو إِ إِڭَّا س ثْنَاينْ \add ن ثْفڒْوِينْ\add* إِ ثْنَاينْ ن ثْغمُّورَا. \x ◘ \xo 36:‏29 \xt ؤُف. 26‏:‏24\x*
\v 30 \add أَمُّو\add* إِ ذِينْ ثُوغَا ثْمنْيَا ن ثْفڒْوِينْ س ثْيَارْسَاوِينْ نْسنْثْ ن نُّوقَارْثْ، \add أَقَا أَثنْثْ\add* ذ سطَّاشْ ن ثْيَارْسَاوِينْ، ثْنَاينْ ن ثْيَارْسَاوِينْ سَاذُو كُوڒْ ثَافْڒوْثْ. \x ◘ \xo 36:‏30 \xt ؤُف. 26‏:‏25\x*
\v 31 إِڭَّا عَاوذْ \bd ثِيحنْيَا \bdit ن ؤُعَارّضْ\bdit*\bd* زڭْ ؤُكشُّوضْ ن ؤُكَاسِييَا، خمْسَا ن ثْفڒْوِينْ غَارْ إِجّْ ن ؤُغزْذِيسْ ن ثْزذِّيغْثْ، \x ◘ \xo 36:‏31 \xt ؤُف. 26‏:‏26\x*
\v 32 ؤُ خمْسَا ن ثْحنْيَا ن ؤُعَارّضْ إِ ثْفڒْوِينْ غَارْ ؤُغزْذِيسْ نّغْنِي ن ثْزذِّيغْثْ ذ خمْسَا ن ثْحنْيَا ن ؤُعَارّضْ إِ ثْفڒْوِينْ ن ثْزذِّيغْثْ غَارْ ثْنَاينْ ن ثْغمُّورَا نْ ضفَّارْ غَارْ ڒْغَارْبْ. \x ◘ \xo 36:‏32 \xt ؤُف. 26‏:‏27\x*
\v 33 ثَاحْنَاشْثْ ن ؤُعَارّضْ ذِي ڒْوسْطْ إِڭَّا إِ-ت أَذْ ثژْوَا زِي ڒْوسْطْ ن ثْفڒْوِينْ زڭْ إِخفْ أَڒْ ونّغْنِي. \x ◘ \xo 36:‏33 \xt ؤُف. 26‏:‏28\x*
\v 34 إِغدْجفْ ثِيفڒْوِينْ س وُورغْ ؤُشَا إِڭَّا ثِيخْرَازِينْ نْسنْثْ ن وُورغْ، مَاحنْذْ أَذْ ذَايْسنْثْ سِّيذْفنْ ثِيحنْيَا ن ؤُعَارّضْ ؤُشَا \add ؤُڒَا ذ\add* ثِيحنْيَا ن ؤُعَارّضْ إِشلّلْ إِ-ثنْثْ س وُورغْ. \x ◘ \xo 36:‏34 \xt ؤُف. 26‏:‏29\x*
\m 
\v 35 إِڭَّا إِجّْ ن \bd ؤُڒحَّافْ\bd* س \add ؤُفِيڒُو\add* أَذحْمِي ذ ؤُرْجُووَانِي ذ ؤُزڭّْوَاغْ إِحذْقنْ ؤُ س ڒقْطنْ أَزْذَاذْ إِمُوذنْ، إِڭَّا إِ-ث ذ إِجّْ ن وَارْشَامْ ن ؤُفنَّانْ أَكْ-ذ إِكِيرُوبنْ \add خَاسْ\add*. \x ◘ \xo 36:‏35 \xt ؤُف. 26‏:‏31\x*
\v 36 إِڭَّا أَسْ أَربْعَا ن إِپِيلَارنْ ن ؤُكشُّوضْ ن ؤُكَاسِييَا ؤُشَا إِغدْجفْ إِ-ثنْ س وُورغْ. \bd ثِيسنَّارِينْ\bd* نْسنْ ثُوغَا أَثنْثْ ن وُورغْ. إِسّفْسِي \add إِ إِپِيلَارنْ\add* أَربْعَا ن ثْيَارْسَاوِينْ نْسنْثْ ن نُّوقَارْثْ. \x ◘ \xo 36:‏36 \xt ؤُف. 26‏:‏32\x*
\m 
\v 37 إِڭَّا إِجّْ ن \bd أَرْوَاقْ\bd* إِ وَاذَافْ ن ؤُقِيضُونْ س \add ؤُفِيڒُو\add* أَذحْمِي ذ ؤُرْجُووَانِي ذ ؤُزڭّْوَاغْ إِحذْقنْ ؤُ س ڒقْطنْ أَزْذَاذْ إِمُوذنْ، \add إِڭَّا إِ-ث\add* ذ إِجّْ ن ؤُمُوذِي ن ؤُخيَّاضْ، \x ◘ \xo 36:‏37 \xt ؤُف. 26‏:‏36\x*
\v 38 س خمْسَا ن إِپِيلَارنْ نّسْ ذ ثْسنَّارِينْ نّسْ. إِغدْجفْ ثِيزدْجِيفِينْ نْسنْ ذ إِقضْبَانْ نْسنْ إِ ؤُسڒْقِي س وُورغْ. ثِييَارْسَاوِينْ نْسنْ ثُوغَا أَثنْثْ ن نّْحَاسْ. \x ◘ \xo 36:‏38 \xt ؤُف. 26‏:‏37\x*
\b
\b
\c 37
\m 
\v 1 إِڭَّا بَاصَالِييِيلْ \bd تَّابُوثْ\bd* ن ؤُكشُّوضْ ن \add ثْشجَّارْثْ ن\add* ؤُكَاسِييَا. ثُوزّڭَّارْثْ نّسْ ثُوغَا-ت ثْنَاينْ ن إِغَادْجنْ ذ وزْينْ ؤُ ثِيرُو نّسْ إِجّْ ن ؤُغِيڒْ ذ وزْينْ ؤُشَا ڒُوعْڒَا نّسْ إِجّْ ن ؤُغِيڒْ ذ وزْينْ. \x ◘ \xo 37:‏1 \xt ؤُف. 25‏:‏10\x*
\v 2 إِغدْجفْ إِ-ث زِي ذَاخڒْ ذ بَارَّا س وُورغْ إِصْفَانْ ؤُشَا إِڭَّا أَسْ إِجّْ ن زّْوَاقْ ن وُورغْ إِ ذ أَسْ د-إِنّْضنْ.
\v 3 إِسّفْسِي أَسْ أَربْعَا ن ثخْرَازِينْ إِ أَربْعَا ن ثْغمُّورَا نّسْ: ثْنَاينْ ن ثخْرَازِينْ غَارْ يِيجّْ ن ؤُغزْذِيسْ ذ ثْنَاينْ ن ثخْرَازِينْ غَارْ ؤُغزْذِيسْ نّغْنِي.
\v 4 إِڭَّا إِعُومَاذْ \add إِ ثَاربُّوثْ\add* زڭْ ؤُكشُّوضْ ن ؤُكَاسِييَا ؤُشَا إِغدْجفْ إِ-ثنْ س وُورغْ.
\v 5 إِڭَّا إِعُومَاذْ \add إِ ثَاربُّوثْ\add* ذِي ثخْرَازِينْ غَارْ ثْنَاينْ ن إِغزْذِيسنْ ن تَّابُوثْ، مَاحنْذْ أَذْ \add زَّايْسنْ\add* أَرْبُونْ تَّابُوثْ.
\v 6 إِڭَّا \bd ثَاقبَّارْثْ ن وصْڒَاحْ\bd* ن وُورغْ إِصْفَانْ س ثُوزّڭَّارْثْ نّسْ ن ثْنَاينْ ن إِغَادْجنْ ذ وزْينْ ؤُ ثِيرُو نّسْ ن إِجّْ ن ؤُغِيڒْ ذ وزْينْ.
\v 7 إِڭَّا \bd ثْنَاينْ ن إِكِيرُوبنْ\bd* ن وُورغْ. إِعْذڒْ إِ-ثنْ \add أَمْ\add* ڒْخذْمثْ ن ومْزِيڒْ \add إِ د-إِتّفّْغنْ\add* زِي ثْنَاينْ ن إِخْفَاونْ ن ثْقبَّارْثْ ن وصْڒَاحْ.
\v 8 إِجّْ ن ؤُكِيرُوبْ \add إِفّغْ\add* زڭْ إِجّْ ن إِخفْ غَارْ ؤُغزْذِيسْ-أَ ؤُ أَكِيرُوبْ نّغْنِي زڭْ إِخفْ نّغْنِي غَارْ ؤُغزْذِيسْ نّغْنِي. إِڭَّا إِكِيرُوبنْ زِي ثْنَاينْ ن إِخْفَاونْ ن ثْقبَّارْثْ ن وصْڒَاحْ. \x ◘ \xo 37:‏8 \xt ؤُف. 25‏:‏19\x*
\v 9 إِكِيرُوبنْ سّْوِيژّْضنْ أَفْرِيونْ نْسنْ سنّجْ ؤُشَا س وَافْرِيونْ نْسنْ ذْڒِينْ ثَاقبَّارْثْ ن وصْڒَاحْ. إِغمْبَابْ نْسنْ ثُوغَا إِجّنْ قِيبَاتْشْ إِ ونّغْنِي ؤُشَا \add ذِي ڒْوقْثْ ذ إِشْثنْ ثُوغَا\add* إِغمْبَابْ ن إِكِيرُوبنْ غَارْ ثْقبَّارْثْ ن وصْڒَاحْ. \x ◘ \xo 37:‏9 \xt ؤُف. 25‏:‏20\x*
\m 
\v 10 إِڭَّا \bd ثَازوْضَا\bd* ن ؤُكشُّوضْ ن \add ثْشجَّارْثْ ن\add* ؤُكَاسِييَا. ثُوغَا ثُوزّڭَّارْثْ نّسْ ثْنَاينْ ن إِغَادْجنْ ؤُ ثِيرُو نّسْ إِجّْ ن ؤُغِيڒْ ذ ڒُوعْڒَا نّسْ إِجّْ ن ؤُغِيڒْ ذ وزْينْ. \x ◘ \xo 37:‏10 \xt ؤُف. 25‏:‏23\x*
\v 11 إِغدْجفْ إِ-ت س وُورغْ إِصْفَانْ ؤُشَا إِڭَّا أَسْ إِجّْ ن زّْوَاقْ ن وُورغْ إِ ذ أَسْ د-إِنّْضنْ. \x ◘ \xo 37:‏11 \xt ؤُف. 25‏:‏24\x*
\v 12 إِڭَّا \add عَاوذْ\add* إِشْثْ ن ثْمَا إِ ذ أَسْ د-إِنّْضنْ ن إِجّْ ن شْبَارْ ن ؤُفُوسْ ؤُشَا إِڭَّا إِجّْ ن زّْوَاقْ ن وُورغْ غَارْ ثْموَّا نّسْ إِ ذ أَسْ د-إِنّْضنْ. \x ◘ \xo 37:‏12 \xt ؤُف. 25‏:‏25\x*
\v 13 إِسّفْسِي أَسْ أَربْعَا ن ثخْرَازِينْ ن وُورغْ ؤُشَا إِڭَّا ثِيخْرَازِينْ غَارْ أَربْعَا ن ثْغمُّورَا نِّي إِدْجَانْ غَارْ أَربْعَا ن إِضَارنْ نّسْ. \x ◘ \xo 37:‏13 \xt ؤُف. 25‏:‏26\x*
\v 14 ثُوغَا ثِيخْرَازِينْ زَّاثْ ن ثْمَا، مَاحنْذْ أَذْ \add ذَايْسنْثْ\add* سِّيذْفنْ إِعُومَاذْ \add إِ ثَاربُّوثْ\add*، حِيمَا أَذْ \add زَّايْسنْ\add* أَرْبُونْ ثَازوْضَا. \x ◘ \xo 37:‏14 \xt ؤُف. 25‏:‏27\x*
\v 15 إِڭَّا إِعُومَاذْ \add إِ ثَاربُّوثْ\add* زڭْ ؤُكشُّوضْ ن ؤُكَاسِييَا ؤُشَا إِغدْجفْ إِ-ثنْ س وُورغْ، مَاحنْذْ أَذْ \add زَّايْسنْ\add* أَرْبُونْ ثَازوْضَا.
\v 16 إِڭَّا ڒقْشُوعْ إِ غَا يِيڒِينْ خْ ثْزوْضَا س وُورغْ إِصْفَانْ: طّْبَاصِي نّسْ ذ ثْغنْجَايِينْ نّسْ ذ ڒْكِيسَانْ نّسْ ذ إِغَارَّافنْ، مَاحنْذْ أَذْ زَّايْسنْ كبّنْ. \x ◘ \xo 37:‏16 \xt ؤُف. 25‏:‏29\x*
\m 
\v 17 إِڭَّا \bd ڒْقنْذِيڒْ\bd* ن وُورغْ إِصْفَانْ. إِعْذڒْ ڒْقنْذِيڒْ س وفْضِيسْ ن ومْزِيڒْ: أَفُوذْ خْ ؤُضَارْ نّسْ ذ إِغَادْجنْ نّسْ ذ ڒْكِيسَانْ نّسْ ذ ثْعبُّوزِينْ نّسْ إِ د-إِتَّاسنْ أَكْ-ذ نُّووَارَاثْ نّسْ، أَقَا-ثنْ \add مَارَّا\add* ثُوغَا زَّايسْ \add د-إِتّفّْغنْ\add*. \x ◘ \xo 37:‏17 \xt ؤُف. 25‏:‏31\x*
\v 18 زڭْ إِغزْذِيسنْ نّسْ فّْغنْ-د ستَّا ن إِغَادْجنْ، ثْڒَاثَا ن إِغَادْجنْ ن ڒْقنْذِيڒْ زڭْ إِجّْ ن ؤُغزْذِيسْ ذ ثْڒَاثَا ن إِغَادْجنْ ن ڒْقنْذِيڒْ زڭْ ؤُغزْذِيسْ نّغْنِي. \x ◘ \xo 37:‏18 \xt ؤُف. 25‏:‏32\x*
\v 19 غَارْ إِجّْ ن ؤُغِيڒْ \add ثُوغَا\add* ذِينْ ثْڒَاثَا ن ڒْكِيسَانْ أَمْ \add نّوَّاشْ ن\add* دْجوْزْ س ثْعبُّوزْثْ ذ نّوَّاشْ ؤُشَا خْ ؤُغِيڒْ نّغْنِي \add عَاوذْ\add* ثْڒَاثَا ن ڒْكِيسَانْ أَمْ \add نّوَّاشْ ن\add* دْجوْزْ س \add إِشْثْ ن\add* ثْعبُّوزْثْ إِ د-إِتَّاسنْ أَكْ-ذ \add إِجّْ ن\add* نّوَّاشْ. أَمُّو \add إِ يدْجَانْ مَارَّا\add* ستَّا ن إِغَادْجنْ نِّي د-إِتّفّْغنْ زِي ڒْقنْذِيڒْ. \x ◘ \xo 37:‏19 \xt ؤُف. 25‏:‏33\x*
\v 20 غَارْ ڒْقنْذِيڒْ \add سِيمَانْثْ نّسْ\add* ثُوغَا ذِينْ أَربْعَا ن ڒْكِيسَانْ أَمْ \add نُّووَارَاثْ ن\add* دْجوْزْ أَكْ-ذ ثْعبُّوزِينْ نْسنْ إِ د-إِتَّاسنْ أَكْ-ذ نُّووَارَاثْ نْسنْ. \x ◘ \xo 37:‏20 \xt ؤُف. 25‏:‏34\x*
\v 21 سَاذُو ثْيُويَا ن إِغَادْجنْ إِ زَّايسْ \add د-إِفّْغنْ ذ أَمزْوَارُو\add* أَقَا ذِينْ إِشْثْ ن ثْعبُّوزْثْ ؤُشَا \add أَمنِّي\add* إِ ذِينْ إِشْثْ ن ثْعبُّوزْثْ سَاذُو ثْيُويَا ن إِغَادْجنْ إِ زَّايسْ \add د-إِفّْغنْ أَوَارْنِي أَسْ\add* ؤُشَا عَاوذْ ذِينْ إِشْثْ ن ثْعبُّوزْثْ سَاذُو ثْيُويَا ن إِغَادْجنْ إِ زَّايسْ \add د-إِفّْغنْ ذ أَنڭَّارُو\add*. \add مَانْ أَيَا إِدْجَا أَمنِّي\add* إِ ستَّا ن إِغَادْجنْ إِ زَّايسْ د-إِفّْغنْ.
\v 22 ثُوغَا ثِيعبُّوزِينْ نْسنْ ذ إِغَادْجنْ نْسنْ فّْغنْ-د زَّايسْ. مَارَّا أَيَا \add ثُوغَا\add* ذ إِشْثْ ن ڒْخذْمثْ ن ومْزِيڒْ س وُورغْ إِصْفَانْ. \x ◘ \xo 37:‏22 \xt ؤُف. 25‏:‏36\x*
\v 23 إِڭَّا ستَّا ن ڒفْنَارَاثْ نّسْ أَكْ-ذ ثْجقَّاضِينْ \add ن ثفْثِيتْشْ\add* نّسْ ذ ثْمجْمَارِينْ نّسْ، \add مَارَّا\add* س وُورغْ إِصْفَانْ. \f ◼ \fr 37:‏23 \ft \bd ’ثِيجقَّاضِينْ‘\bd* - نِيغْ ’ثِينقَّاضِينْ‘.\f*  \x ◘ \xo 37:‏23 \xt ؤُف. 25‏:‏37، 38\x*
\v 24 إِڭَّا \add ڒْْقنْذِيڒْ\add* أَكْ-ذ مَارَّا ڒقْشُوعْ نّسْ زڭْ إِشْثْ ن ثَالِينْثْ ن وُورغْ إِصْفَانْ. \x ◘ \xo 37:‏24 \xt ؤُف. 25‏:‏39\x*
\m 
\v 25 إِڭَّا \bd أَعَالْطَارْ ن ڒبْخُورْ\bd* زڭْ ؤُكشُّوضْ ن \add ثْشجَّارْثْ ن\add* ؤُكَاسِييَا س ثُوزّڭَّارْثْ نّسْ ن إِجّْ ؤُغِيڒْ ؤُ ثِيرُو نّسْ ن إِجّْ ن ؤُغِيڒْ. ثُوغَا-ث س أَربْعَا ن ثْغمُّورَا. ڒُْوعْڒَا نّسْ ثُوغَا-ث ثْنَاينْ ن إِغَادْجنْ. زَّايسْ ثُوغَا أَشَّاونْ نّسْ \add ذ إِجّْ أَكِيذسْ\add*. \f ◼ \fr 37:‏25 \ft \bd ’أَشَّاونْ‘\bd* - نِيغْ ’إِقِيشَّاونْ‘.\f*  \x ◘ \xo 37:‏25 \xt ؤُف. 30‏:‏1، 2\x*
\v 26 إِغدْجفْ إِ-ث س وُورغْ إِصْفَانْ، ؤُذمْ نّسْ ن سنّجْ ذ إِغزْذِيسنْ نّسْ إِ ذ أَسْ د-إِنّْضنْ ؤُ عَاوذْ أَشَّاونْ نّسْ. إِڭَّا أَسْ إِجّْ ن زّْوَاقْ ن وُورغْ إِ ذ أَسْ د-إِنّْضنْ. \x ◘ \xo 37:‏26 \xt ؤُف. 30‏:‏3\x*
\v 27 إِڭَّا أَسْ ثْنَاينْ ن ثخْرَازِينْ ن وُورغْ سَاذُو زّْوَاقْ نّسْ إِ ثْنَاينْ ن ثْغمُّورَا نّسْ، غَارْ ثْنَاينْ ن إِغزْذِيسنْ نّسْ، حِيمَا أَذْ ذَايْسنْثْ سِّيذْفنْ إِعُومَاذْ، مَاحنْذْ أَذْ زَّايْسنْ أَرْبُونْ أَعَالْطَارْ ن ڒبْخُورْ. \x ◘ \xo 37:‏27 \xt ؤُف. 30‏:‏4\x*
\v 28 إِڭَّا إِعُومَاذْ \add إِ ثَاربُّوثْ\add* زڭْ ؤُكشُّوضْ ن ؤُكَاسِييَا ؤُشَا إِغدْجفْ إِ-ثنْ س وُورغْ. \x ◘ \xo 37:‏28 \xt ؤُف. 30‏:‏5\x*
\m 
\v 29 إِڭَّا عَاوذْ \bd زّشْثْ ثَامْقدّسْثْ إِ وذْهَانْ\bd* ذ \bd ڒبْخُورْ إِصْفَانْ إِتّْفُوحنْ\bd*، \add عْلَاحْسَابْ\add* صّنْعثْ ن ؤُعطَّاڒْ. \x ◘ \xo 37:‏29 \xt ؤُف. 30‏:‏22، 34\x*
\b
\b
\c 38
\m 
\v 1 إِڭَّا \bd أَعَالْطَارْ ن وشْمَاضْ\bd* س ؤُكشُّوضْ ن ؤُكَاسِييَا. ثُوزّڭَّارْثْ نّسْ ثُوغَا-ت خمْسَا ن إِغَادْجنْ ؤُ ثِيرُو نّسْ خمْسَا ن إِغَادْجنْ، ثُوغَا-ث س أَربْعَا ن ثْغمُّورَا، ؤُ ڒُوعْڒَا نّسْ ثُوغَا-ث ثْڒَاثَا ن إِغَادْجنْ. \x ◘ \xo 38:‏1 \xt ؤُف. 27‏:‏1\x*
\v 2 غَارْ أَربْعَا ن ثْغمُّورَا إِڭَّا أَشَّاونْ نّسْ. أَشَّاونْ نّسْ ثُوغَا أَثنْ ذ إِجّنْ أَكِيذسْ. إِغدْجفْ إِ-ث س نّْحَاسْ. \f ◼ \fr 38:‏2 \ft \bd ’أَشَّاونْ‘\bd* - نِيغْ ’إِقِيشَّاونْ‘.\f*  \x ◘ \xo 38:‏2 \xt ؤُف. 27‏:‏2\x*
\v 3 إِڭَّا مَارَّا ڒقْشُوعْ إِ ؤُعَالْطَارْ: ثِييْذُورِينْ ذ إِغنْجَاينْ ذ طَّاوْيَاثْ إِ ؤُرُوشِّي ذ فُورْشَايَاثْ ذ ثْمجْمَارِينْ، مَارَّا ڒقْشُوعْ-أَ إِڭَّا إِ-ثنْ س نّْحَاسْ. \x ◘ \xo 38:‏3 \xt ؤُف. 27‏:‏3\x*
\v 4 إِڭَّا إِشْثْ ن ثْرَاشَّا إِ ؤُعَالْطَارْ، إِجّْ ن ؤُمُوذِي ن نّْحَاسْ سَاذُو ثْمَا نّسْ، سْوَادَّايْ غَارْ وزْينْ \add ن ؤُعَالْطَارْ\add*. \x ◘ \xo 38:‏4 \xt ؤُف. 27‏:‏4، 5\x*
\v 5 إِسّفْسِي أَربْعَا ن ثخْرَازِينْ إِ أَربْعَا ن إِخْفَاونْ ن ثْرَاشَّا ن نّْحَاسْ مَاحنْذْ أَذْ ذَايْسنْثْ سِّيذْفنْ إِعُومَاذْ \add إِ ثَاربُّوثْ\add*.
\v 6 إِڭَّا إِعُومَاذْ \add إِ ثَاربُّوثْ\add* زڭْ ؤُكشُّوضْ ن ؤُكَاسِييَا ؤُشَا إِغدْجفْ إِ-ثنْ س نّْحَاسْ.
\v 7 إِڭَّا إِعُومَاذْ \add إِ ثَاربُّوثْ\add* ذِي ثخْرَازِينْ غَارْ إِغزْذِيسنْ ن ؤُعَالْطَارْ، مَاحنْذْ أَذْ زَّايْسنْ ث أَرْبُونْ. إِڭَّا إِ-ث س ثْفڒْوِينْ \add أَكْ-ذ\add* ڒْخَاوِي \add ذِي ذَاخڒْ نْسنْثْ\add*. \x ◘ \xo 38:‏7 \xt ؤُف. 27‏:‏8\x*
\m 
\v 8 إِڭَّا \bd ثَابَانْيُوثْ ن نّْحَاسْ\bd* س ؤُضَارْ نّسْ ن نّْحَاسْ زِي ثِيسِيثِينْ ن ثرْبِيعِينْ ن ثمْغَارِينْ نِّي خذْمنْثْ غَارْ وَاذَافْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ. \x ◘ \xo 38:‏8 \xt ؤُف. 30‏:‏18\x*
\m 
\v 9 إِڭَّا \bd ڒمْرَاحْ.\bd* غَارْ جِّيهثْ ن لْجَانُوبْ، غَارْ يفُوسْ، ثُوغَا ثُوزّڭَّارْثْ ن \bd ڒِْيزَارَاثْ ن ڒمْرَاحْ\bd* مْيَا ن إِغَادْجنْ ن ڒقْطنْ أَزْذَاذْ إِمُوذنْ. \x ◘ \xo 38:‏9 \xt ؤُف. 27‏:‏9\x*
\v 10 عِيشْرِينْ ن \bd إِپِيلَارنْ\bd* نّسْ ذ عِيشْرِينْ ن \bd ثْيَارْسَاوِينْ\bd* نْسنْ \add ثُوغَا أَثنْ\add* ن نّْحَاسْ. \bd ثِيسنَّارِينْ\bd* ن إِپِيلَارنْ ذ \bd إِقضْبَانْ نْسنْ إِ ؤُسڒْقِي\bd* \add ثُوغَا أَثنْ\add* ن نُّوقَارْثْ.
\v 11 غَارْ ؤُغزْذِيسْ ن شَّامَالْ \add ثُوغَا ذِينْ ڒِيزَارَاثْ س إِشْثْ ن ثُوزّڭَّارْثْ ن\add* مْيَا ن إِغَادْجنْ أَكْ-ذ عِيشْرِينْ ن إِپِيلَارنْ نْسنْثْ ؤُ أَكْ-ذ عِيشْرِينْ ن ثْيَارْسَاوِينْ نْسنْ ن نّْحَاسْ. ثِيسنَّارِينْ ن إِپِيلَارنْ ذ إِقضْبَانْ نْسنْ إِ ؤُسڒْقِي \add ثُوغَا أَثنْ\add* ن نُّوقَارْثْ.
\v 12 غَارْ ؤُغزْذِيسْ ن ڒْغَارْبْ \add ثُوغَا ذِينْ\add* ڒِيزَارَاثْ ن خمْسِينْ ن إِغَادْجنْ أَكْ-ذعشْرَا ن إِپِيلَارنْ نْسنْثْ ذعشْرَا ن ثْيَارْسَاوِينْ نْسنْ. ثِيسنَّارِينْ ن إِپِيلَارنْ ذ إِقضْبَانْ نْسنْ إِ ؤُسڒْقِي \add ثُوغَا أَثنْ\add* ن نُّوقَارْثْ.
\v 13 غَارْ ؤُغزْذِيسْ ن شَّارْقْ، غَارْ جِّيهثْ ن ونْقَارْ ن ثْفُوشْثْ، \add ثُوغَا ذِينْ ڒِيزَارَاثْ ن\add* خمْسِينْ ن إِغَادْجنْ.
\v 14 ثُوغَا ڒِيزَارَاثْ غَارْ إِجّْ ن ؤُغزْذِيسْ ن زَّاثْ خمّسْطَاشْ ن إِغَادْجنْ \add ذِي ثُوزّڭَّارْثْ\add* أَكْ-ذ ثْڒَاثَا ن إِپِيلَارنْ نْسنْثْ ذ ثْڒَاثَا ن ثْيَارْسَاوِينْ نْسنْ.
\v 15 غَارْ ؤُغزْذِيسْ ن زَّاثْ نّغْنِي ن وَاذَافْ ن ڒمْرَاحْ، غَارْ ؤُغزْذِيسْ-أَ ذ ؤُغزْذِيسْ نِّي، \add ثُوغَا\add* ڒِيزَارَاثْ ذَايْسنْثْ خمّسْطَاشْ ن إِغَادْجنْ ذِي ثُوزّڭَّارْثْ، أَكْ-ذ ثْڒَاثَا ن إِپِيلَارنْ نْسنْثْ ذ ثْڒَاثَا ن ثْيَارْسَاوِينْ نْسنْ.
\v 16 مَارَّا ڒِيزَارَاثْ نِّي ذ أَسْ د-إِنّْضنْ إِ ڒمْرَاحْ ثُوغَا أَثنْثْ ن ڒقْطنْ أَزْذَاذْ إِمُوذنْ.
\v 17 ثِييَارْسَاوِينْ ن إِپِيلَارنْ \add ثُوغَا أَثنْثْ\add* ن نّْحَاسْ ذ ثْسنَّارِينْ ن إِپِيلَارنْ ذ إِقضْبَانْ نْسنْ إِ ؤُسڒْقِي \add ثُوغَا أَثنْ\add* س نُّوقَارْثْ ؤُشَا ثَاكُورْسِيثْ خْ ثْزدْجِيفِينْ نْسنْ \add ثُوغَا-ت\add* زِي نُّوقَارْثْ ذ مَارَّا إِپِيلَارنْ ن ڒمْرَاحْ \add ثُوغَا غَارْسنْ\add* إِقضْبَانْ ن نُّوقَارْثْ إِ ؤُسڒْقِي.
\v 18 أَرْوَاقْ غَارْ وَاذَافْ ن ڒمْرَاحْ ڭِّينْ ث ذ إِجّْ ن ؤُمُوذِي ن ؤُخيَّاضْ س \add ؤُفِيڒُو\add* أَذحْمِي ذ ؤُرْجُووَانِي ذ ؤُزڭّْوَاغْ إِحذْقنْ ؤُ س ڒقْطنْ أَزْذَاذْ إِمُوذنْ. ثُوزّڭَّارْثْ \add نّسْ\add* ثُوغَا عِيشْرِينْ ن إِغَادْجنْ ؤُ ڒُوعْڒَا خْ \add مَارَّا\add* ثِيرُو \add ن ڒمْرَاحْ\add* خمْسَا ن إِغَادْجنْ، أَمْ ڒِيزَارَاثْ ن ڒمْرَاحْ.
\v 19 أَربْعَا ن إِپِيلَارنْ ذ أَربْعَا ن ثْيَارْسَاوِينْ نْسنْ ثُوغَا أَثنْ س نّْحَاسْ ذ ثْسنَّارِينْ نْسنْ س نُّوقَارْثْ ؤُشَا ثَاكُورْسِيثْ خْ ثْزدْجِيفِينْ نْسنْ ؤُڒَا ذ إِقضْبَانْ نْسنْ إِ ؤُسڒْقِي \add ثُوغَا أَثنْ\add* س نُّوقَارْثْ.
\v 20 مَارَّا ڒوْثَاذْ ن ثْزذِّيغْثْ ذ ڒمْرَاحْ إِ ذ أَسْ د-إِنّْضنْ \add ثُوغَا أَثنْ\add* س نّْحَاسْ.
\m 
\v 21 \bd مَانْ أَيَا ذ مِينْ سُّوفّْغنْ نِيثْنِي إِ ثْزذِّيغْثْ\bd*، ثَازذِّيغْثْ ن شّْهَاذثْ، ؤُشَا زمّنْ ث س ڒُومُورْ ن مُوسَا سْ ثْسخَّارْثْ ن إِلَاوِييّنْ، س ؤُفُوسْ ن إِثَامَارْ، مِّيسْ ن هَارُونْ، أَكهَّانْ.
\v 22 بَاصَالِييِيلْ مِّيسْ ن ؤُرِي، مِّيسْ ن حُورْ، زِي ثقْبِيتْشْ ن يَاهُوذَا، إِڭَّا مَارَّا مِينْ ذ أَسْ يُومُورْ سِيذِي إِ مُوسَا.
\v 23 \add ثُوغَا\add* أَكِيذسْ أَهُولِييَابْ، مِّيسْ ن أَخِيسَامَاكْ، زِي ثقْبِيتْشْ ن دَان. \add ثُوغَا-ث\add* ذ أَنقَّاشْ ذ بُو-صّنْعثْ، أَخيَّاضْ ن \add ؤُفِيڒُو\add* أَذحْمِي ذ ؤُرْجُووَانِي ذ ؤُزڭّْوَاغْ إِحذْقنْ ذ ڒقْطنْ أَزْذَاذْ.
\m 
\v 24 \bd مَارَّا ؤُرغْ إِ سّْخذْمنْ نِيثْنِي إِ ڒْخذْمثْ\bd* غَارْ مَارَّا ڒْخذْمثْ \add إِ إِڭِّينْ\add* ذِي زَّاوشْثْ إِقدّْسنْ، \add إِخْسْ أَذْ يِينِي\add* ؤُرغْ ن ثوْهِيبِينْ ن ونْهزِّي، ثُوغَا: ثسْعَا ؤُ-عِيشْرِينْ ثَالِينْثْ ؤُ سبْعَا-مْيَا ؤُ-ثْڒَاثِينْ شِيقْلُو عْلَاحْسَابْ شِيقْلُو إِقدّْسنْ.
\m 
\v 25 \bd نُّوقَارْثْ ن يِينِّي إِتّْوَاحسْبنْ\bd* ن ثْمسْمُونْثْ ثُوغَا-ت مْيَا ثَالِينْثْ ذ أَڒفْ ؤُ-سبْعَا-مْيَا ؤُ-خمْسَا ؤُ-سبْعِينْ شِيقْلُو، عْلَاحْسَابْ شِيقْلُو إِقدّْسنْ.
\v 26 إِجّْ ن وزْينْ إِ يِيجّْ ن بْنَاذمْ، أَقَا-ث ذ أَزْينْ شِيقْلُو عْلَاحْسَابْ مِينْ د-إِتَّاوِي شِيقْلُو إِقدّْسنْ، زِي مَارَّا وِي إِعْذُونْ غَارْ يِينِّي إِتّْوَاحسْبنْ زِي عِيشْرِينْ ن إِسڭّْوُوسَا سنّجْ، \add ذ مَانْ أَيَا\add* إِ ستَّا-مْيَا ؤُ-ثڒْثْ-أَڒَافْ ؤُ-خمْسَا-مْيَا ؤُ-خمْسِينْ \add ن يرْيَازنْ\add*.
\v 27 مْيَا ثَالِينْثْ ن نُّوقَارْثْ نِّي ثُوغَا أَثنْثْ حِيمَا أَذْ \add زَّايْسنْثْ\add* سّْفسْينْ ثْيَارْسَاوِينْ ن زَّاوشْثْ إِقدّْسنْ ذ ثْيَارْسَاوِينْ ن ؤُڒحَّافْ: مْيَا ن ثْيَارْسَاوِينْ زِي مْيَا ثَالِينْثْ، \add إِخْسْ أَذْ يِينِي\add* إِشْثْ ن ثَالِينْثْ إِ يِيشْثْ ن ثْيَارْسَا.
\v 28 زڭْ وَاڒفْ ؤُ-سبْعَا-مْيَا ؤُ-خمْسَا ؤُ-سبْعِينْ \add شِيقْلُو\add* إِڭَّا ثِيسنَّارِينْ إِ إِپِيلَارنْ. إِغدْجفْ ثِيزدْجِيفِينْ نْسنْ ؤُشَا إِشدّْ \add غَارْسنْ\add* إِقضْبَانْ إِ ؤُسڒْقِي.
\m 
\v 29 \bd نّْحَاسْ ن ثوْهِيبِينْ ن ونْهزِّي\bd* \add ثُوغَا-ث\add* سبْعِينْ ثَالِينْثْ ذ أَڒْفَاينْ ؤُ-أَربْعَا-مْيَا شِيقْلُو.
\v 30 س مَانْ أَيَا إِڭَّا ثْيَارْسَاوِينْ إِ وَاذَافْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ ذ ؤُعَالْطَارْ ن نّْحَاسْ ذ ثْرَاشَّا نّسْ ن نّْحَاسْ ذ مَارَّا ڒقْشُوعْ ن ؤُعَالْطَارْ
\v 31 ذ ثْيَارْسَاوِينْ \add ن إِپِيلَارنْ\add* ن ڒمْرَاحْ إِ ذ أَسْ د-إِنّْضنْ ذ ثْيَارْسَاوِينْ ن وَاذَافْ ن ڒمْرَاحْ ذ مَارَّا ڒوْثَاذْ ن ثْزذِّيغْثْ ذ مَارَّا ڒوْثَاذْ ن \add إِپِيلَارنْ\add* إِ ذ أَسْ د-إِنّْضنْ إِ ڒمْرَاحْ.
\b
\b
\c 39
\s1 مُوسَا إِقدْجبْ مَارَّا ڒْخذْمثْ ؤُشَا إِبَاركْ ڒْڭنْسْ
\m 
\v 1 ڭِّينْ \add عَاوذْ\add* أَرُّوضْ إِ ثْسخَّارْثْ س \add ؤُفِيڒِي\add* أَذحْمِي ذ ؤُرْجُووَانِي ذ ؤُزڭّْوَاغْ إِحذْقنْ، حِيمَا أَذْ \add زَّايسْ\add* سخَّارنْ \add إِكهَّاننْ\add* ذِي زَّاوشْثْ إِقدّْسنْ. \add عَاوذْ\add* ڭِّينْ \bd أَرُّوضْ إِقدّْسنْ إِ هَارُونْ\bd*، أَمْ مَامّشْ ذ أَسْ يُومُورْ سِيذِي إِ مُوسَا. \x ◘ \xo 39:‏1 \xt ؤُف. 31‏:‏10؛ 35‏:‏19\x*
\m 
\v 2 إِڭَّا \bd أَپَالْطُو \bdit ن ؤُكهَّانْ\bdit*\bd* س \add إِفِيڒَانْ ن\add* وُورغْ ؤُ س \add ؤُفِيڒُو\add* أَذحْمِي ذ ؤُرْجُووَانِي ذ ؤُزڭّْوَاغْ إِحذْقنْ ؤُ س ڒقْطنْ أَزْذَاذْ إِمُوذنْ. \x ◘ \xo 39:‏2 \xt ؤُف. 28‏:‏6\x*
\v 3 نِيثْنِي بزّْعنْ ثِيڒْوِيحِينْ ن وُورغْ ؤُشَا قسّنْ زَّايْسنْثْ إِفِيڒَانْ، حِيمَا أَذْ ثنْ خيّْضنْ جَارْ \add ؤُفِيڒُو\add* أَذحْمِي ذ ؤُرْجُووَانِي ذ ؤُزڭّْوَاغْ إِحذْقنْ ؤُ جَارْ ڒقْطنْ أَزْذَاذْ، \add ذ مَانْ أَيَا ثُوغَا\add* ذ إِشْثْ ن ڒْخذْمثْ \add أَمْ\add* ت إِتّڭّْ ؤُفنَّانْ. \x ◘ \xo 39:‏3 \xt ؤُف. 28‏:‏6\x*
\v 4 ڭِّينْ أَسْ ثِيغَارْضِينْ إِمْسڒْسَاقنْ ؤُشَا سّْمُوننْ \add أَپَالْطُو\add* غَارْ ثْنَاينْ ن إِخْفَاونْ نّسْ.
\v 5 ثَاحزَّامْثْ إِزوّْقنْ إِ ثُوغَا غَارْ ؤُپَالْطُو نّسْ، ثُوغَا ثڒْسقْ ذَايسْ، ثذْوڒْ ذ إِشْثْ أَكِيذسْ. ثتّْوَاڭّْ ثْحزَّامْثْ س وبْرِيذْ ذ إِجّنْ \add أَكْ-ذ ؤُپَالْطُو\add* س \add إِفِيڒَانْ ن\add* وُورغْ ؤُ س \add ؤُفِيڒُو\add* أَذحْمِي ذ ؤُرْجُووَانِي ذ ؤُزڭّْوَاغْ إِحذْقنْ ؤُ س ڒقْطنْ أَزْذَاذْ إِمُوذنْ، أَمْ مَامّشْ يُومُورْ سِيذِي إِ مُوسَا. \x ◘ \xo 39:‏5 \xt ؤُف. 28‏:‏8\x*
\v 6 نِيثْنِي ڭِّينْ عَاوذْ إِژْرَا ن ؤُنِيكْسْ، إِنِّي إِتّْوَاطّْفنْ ذِي ثْشُويَارْ ن وُورغْ، نقْشنْ ثنْ أَمْ يِيجّْ ن ونْقَاشْ ن ثْخَاذنْثْ ن ؤُشمِّيعْ س إِسْمَاونْ ن أَيْثْ ن إِسْرَائِيل. \x ◘ \xo 39:‏6 \xt ؤُف. 28‏:‏9، 10، 11\x*
\v 7 إِڭَّا إِ-ثنْ خْ ثْغَارْضِينْ ن ؤُپَالْطُو، \add أَمْ\add* إِژْرَا ن ڒِيذَارثْ إِ أَيْثْ ن إِسْرَائِيل، أَمْ مَامّشْ يُومُورْ سِيذِي إِ مُوسَا. \x ◘ \xo 39:‏7 \xt ؤُف. 28‏:‏12\x*
\m 
\v 8 إِڭَّا \bd ثَاجْمشْثْ\bd*، إِشْثْ ن ڒْخذْمثْ \add أَمْ\add* ت إِتّڭّْ ؤُفنَّانْ، \add أَمْ مَامّشْ إِڭَّا\add* أَپَالْطُو، س \add إِفِيڒَانْ ن\add* وُورغْ ؤُ س \add ؤُفِيڒُو\add* أَذحْمِي ذ ؤُرْجُووَانِي ذ ؤُزڭّْوَاغْ إِحذْقنْ ؤُ س ڒقْطنْ أَزْذَاذْ إِمُوذنْ.
\v 9 \add ثُوغَا-ت\add* س أَربْعَا ن ثْغمُّورَا. ضفْسنْ ثَاجْمشْثْ. \add ثُوغَا\add* ثُوزّڭَّارْثْ نّسْ ذ إِجّْ ن وزْينْ ن ؤُغِيڒْ ؤُشَا ؤُڒَا ذ ثِيرُو نّسْ ذ إِجّْ ن وزْينْ ن ؤُغِيڒْ. ثُوغَا إِضْفسْ خْ ثْنَاينْ. \x ◘ \xo 39:‏9 \xt ؤُف. 28‏:‏16\x*
\v 10 ستّْفنْ ذَايسْ أَربْعَا ن ڒصْفُوفْ ن يژْرَا: إِجّْ ن صّفْ \add س\add* يِيجّْ ن ڒعْقِيقْ ذ أَزڭّْوَاغْ ذ إِشْثْ ن ثْيَاقُوثْ ذ يِيشْثْ ن سْمَارَاخْثْ. ذ وَا ذ صّفْ أَمزْوَارْ. \x ◘ \xo 39:‏10 \xt ؤُف. 28‏:‏17\x*
\v 11 صّفْ وِيسّْ ثْنَاينْ س يِيجّْ ن كَارْبُونْكلْ ذ يِيجّْ ن صَافِّيرْ أَزِيزَا ذ يِيجّْ ن ذِيأَمَانْثِي. \x ◘ \xo 39:‏11 \xt ؤُف. 28‏:‏18\x*
\v 12 صّفْ وِيسّْ ثْڒَاثَا س يِيجّْ \add ن وژْرُو\add* ن يَاسِينْثُو ذ يِيجّْ ن أَخَاثْ ذ يِيجّْ ؤُمَاثِيسْثْ.
\v 13 صّفْ وِيسّْ أَربْعَا س يِيشْثْ ن ثخْرِيسُولِيثْ ذ يِيجّْ ن ؤُنِيكْسْ ذ يِيجّْ ن يَاسْبِيسْ. ثُوغَا تّْوَاطّْفنْ ذِي ثْشُويَارْ نْسنْ ن وُورغْ.
\v 14 إِژْرَا ثُوغَا خَاسنْ إِسْمَاونْ ن أَيْثْ ن إِسْرَائِيل، ثنْعَاشْ \add ن يژْرَا\add* عْلَاحْسَابْ إِسْمَاونْ نْسنْ، س إِنقَّاشنْ ن إِجّْ ن ؤُشمِّيعْ، كُوڒْ \add أَنقَّاشْ\add* أَكْ-ذ يِيسمْ نّسْ إِ ذ أَسْ د-يُوسِينْ. أَقَا أَثنْ إِ ثنْعَاشْ ن ثْقبَّاڒْ.
\v 15 غَارْ إِخْفَاونْ ن ثجْمشْثْ ڭِّينْ ثِيسدّْيِينْ س وُورغْ إِصْفَانْ، \add ثِينِّي\add* إِمُوذنْ أَمْ يِيجّْ ن ؤُفِيڒُو.
\v 16 ڭِّينْ ثْنَاينْ ن ثْشُويَارْ ن وُورغْ ذ ثْنَاينْ ن ثخْرَازِينْ ن وُورغْ ؤُشَا شدّنْ ثْنَاينْ ن ثخْرَازِينْ غَارْ ثْنَاينْ ن إِخْفَاونْ ن ثجْمشْثْ.
\v 17 شدّنْ ثْنَاينْ ن سّْنَاسڒْ إِمُوذنْ ن وُورغْ غَارْ ثْنَاينْ ن ثخْرَازِينْ غَارْ إِخْفَاونْ ن ثجْمشْثْ.
\v 18 ثْنَاينْ ن إِخْفَاونْ نّغْنِي ن ثْنَاينْ ن سّْنَاسڒْ إِمُوذنْ، شدّنْ ثنْ غَارْ ثْنَاينْ ن ثْشُويَارْ ؤُشَا وْشِينْ ثنْ خْ طْغَارْضِينْ ن ؤُپَالْطُو، ذڭْ وُوذمْ ن زَّاثْ.
\v 19 ڭِّينْ \add عَاوذْ\add* ثْنَاينْ ن ثخْرَازِينْ ن وُورغْ، شدّنْ ثنْثْ غَارْ ثْنَاينْ ن إِخْفَاونْ نّغْنِي ن ثجْمشْثْ، ذِي ثْمَا نّسْ نِّي قِيبَاتْشْ إِ ؤُپَالْطُو، غَارْ ذَاخڒْ.
\v 20 ڭِّينْ \add عَاوذْ\add* ثْنَاينْ ن ثخْرَازِينْ ن وُورغْ، شدّنْ ثنْثْ خْ ثْنَاينْ ن ثْغَارْضِينْ ن ؤُپَالْطُو \add ن ؤُكهَّانْ\add*، سْوَادَّايْ، غَارْ زَّاثْ، قِيبَاتْشْ إِ ؤُسڒْقِي نّسْ غَارْ سنّجْ إِ ثْحزَّامْثْ إِزوّْقنْ ن ؤُپَالْطُو.
\v 21 ؤُشَا شدّنْ ثَاجْمشْثْ س ثخْرَازِينْ نّسْ غَارْ ثخْرَازِينْ ن ؤُپَالْطُو \add ن ؤُكهَّانْ\add* أَكْ-ذ إِجّْ ن ؤُفِيڒُو أَذحْمِي أَڒَامِي إِذْوڒْ سنّجْ إِ ثْحزَّامْثْ إِزوّْقنْ ن ؤُپَالْطُو، ؤُشَا \add خنِّي\add* وَارْ ثْبطِّي ثجْمشْثْ خْ ؤُپَالْطُو، أَمْ مَامّشْ يُومُورْ سِيذِي إِ مُوسَا.
\m 
\v 22 إِڭَّا عَاوذْ \bd أَسڒْهَامْ\bd* ن ؤُپَالْطُو \add ن ؤُكهَّانْ\add* \add أَمْ مَامّشْ ث\add* إِتّڭّْ ؤُخيَّاضْ، \add ثُوغَا-ث ذ\add* أَذحْمِي مَارَّا.
\v 23 أَرْزَامْ ن ؤُسڒْهَامْ \add ثُوغَا-ث\add* ذِي ڒْوسْطْ نّسْ \add أَمْ مَامّشْ ڭِّينْ\add* أَرْزَامْ ن يِيرِي ن وَارُّوضْ ن وُوزَّاڒْ ن ؤُعسْكَارِي. ذڭْ ونّضْ ن وَارْزَامْ ثُوغَا ذِينْ إِشْثْ ن ثْمَا، \add حِيمَا\add* وَارْ إِتّْشَارِّيڭْ.
\v 24 غَارْ ثْمُووَّا \add ن وَادَّايْ\add* ن ؤُسڒْهَامْ ڭِّينْ ثِيرمَّانِينْ س \add ؤُفِيڒُو\add* أَذحْمِي ذ ؤُرْجُووَانِي ذ ؤُزڭّْوَاغْ إِحذْقنْ \add زڭْ إِفِيڒَانْ\add* إِمُوذنْ.
\v 25 ڭِّينْ عَاوذْ نّْوَاقسْ ن وُورغْ إِصْفَانْ ؤُشَا سَّارْسنْ نّْوَاقسْ نِّي جَارْ ثْرمَّانِينْ غَارْ ثْمُووَّا \add ن وَادَّايْ\add* ن ؤُسڒْهَامْ، ذڭْ ونّضْ جَارْ ثْرمَّانِينْ.
\v 26 إِجّْ ن نَّاقُوسْ ذ إِشْثْ ن ثْرمَّانْثْ، \add خنِّي عَاوذْ\add* إِجّْ ن نَّاقُوسْ ذ إِشْثْ ن ثْرمَّانْثْ غَارْ ثْمُووَّا \add ن وَادَّايْ\add* ن ؤُسڒْهَامْ ذڭْ ونّضْ، مَاحنْذْ أَذْ ذَايسْ ڭّنْ ثَاسخَّارْثْ نْسنْ، أَمْ مَامّشْ يُومُورْ سِيذِي إِ مُوسَا.
\m 
\v 27 ڭِّينْ \bd ثْشَامِيرْ\bd* إِ هَارُونْ ذ وَارَّاوْ نّسْ س ڒقْطنْ أَزْذَاذْ، \add أَمْ مَامّشْ ث\add* إِتّڭّْ ؤُخيَّاضْ، \x ◘ \xo 39:‏27 \xt ؤُف. 28‏:‏39\x*
\v 28 \bd أَرژّثْ\bd* ن ڒقْطنْ أَزْذَاذْ ذ \bd ثْشُوشَّايْ إِزوّْقنْ\bd* ن ڒقْطنْ أَزْذَاذْ ذ \bd سّْرَاوڒْ ن ڒقْطنْ\bd* س ڒقْطنْ أَزْذَاذْ إِمُوذنْ
\v 29 ؤُ ثُوغَا \bd ثَاحزَّامْثْ\bd* ن ڒقْطنْ أَزْذَاذْ إِمُوذنْ ؤُ ن \add ؤُفِيڒُو\add* أَذحْمِي ذ ؤُرْجُووَانِي ذ ؤُزڭّْوَاغْ إِحذْقنْ، أَقَا-ت ذ إِجّْ ن ؤُمُوذِي ن ؤُخيَّاضْ، أَمْ مَامّشْ يُومُورْ سِيذِي إِ مُوسَا.
\m 
\v 30 ڭِّينْ \bd \bdit ثَاڒْوِيحْثْ س\bdit* نُّووَارْ ن تَّاجْ إِقدّْسنْ \bdit ن وعْزَاڒْ\bdit*\bd* س وُورغْ إِصْفَانْ ؤُشَا نقْشنْ ذَايسْ ثِيرَا-يَا: ”أَمْقدَّاسْ إِ سِيذِي!“، أَمْ مَامّشْ نقْشنْ ثَاخَاذنْثْ ن ؤُشمِّيعْ. \x ◘ \xo 39:‏30 \xt ؤُف. 28‏:‏36؛ 29‏:‏6\x*
\v 31 ؤُشَا شدّنْ أَسْ إِجّْ ن ؤُفِيڒُو إِمُوذنْ أَذحْمِي، حِيمَا أَذْ ت أَيْڒنْ سنّجْ إِ أَرژّثْ، أَمْ مَامّشْ يُومُورْ سِيذِي إِ مُوسَا. \x ◘ \xo 39:‏31 \xt ؤُف. 28‏:‏37\x*
\b
\m 
\v 32 أَمُّو إِ ثْكمّڒْ مَارَّا ڒْخذْمثْ ن ثْزذِّيغْثْ، أَقِيضُونْ ن ؤُمْسَاڭَارْ. أَيْثْ ن إِسْرَائِيل أَقَا ڭِّينْ ت أَمْ مَامّشْ يُومُورْ سِيذِي إِ مُوسَا، أَمُّو إِ ت ڭِّينْ.
\m 
\v 33 كْسِينْ ثَازذِّيغْثْ غَارْ مُوسَا، أَقِيضُونْ ذ مَارَّا ڒقْشُوعْ نّسْ ذ ثْسنَّارِينْ نّسْ ذ ثْفڒْوِينْ نّسْ ذ ثْحنْيَا نّسْ ن ؤُعَارّضْ ذ إِپِيلَارنْ نّسْ ذ ثْيَارْسَاوِينْ نّسْ \x ◘ \xo 39:‏33 \xt ؤُف. 35‏:‏11\x*
\v 34 ذ ثْسقَّافْثْ ن إِڒْمَاونْ إِزڭّْوَاغنْ ن إِشَارِّييّنْ ذ ثْسقَّافْثْ ن إِڒْمَاونْ ن دّنْفِيڒَاثْ ذ ؤُڒحَّافْ إِ دُّورِي،
\v 35 تَّابُوثْ ن شّْهَاذثْ ذ إِعُومَاذْ نّسْ \add إِ ثَاربُّوثْ\add* ذ ثْقبَّارْثْ ن وصْڒَاحْ
\v 36 ذ ثَازوْضَا أَكْ-ذ مَارَّا ڒقْشُوعْ نّسْ ذ وغْرُومْ ن وسْشَانْ \x ◘ \xo 39:‏36 \xt ؤُف. 31‏:‏8\x*
\v 37 ذ ڒْقنْذِيڒْ \add ن وُورغْ\add* إِصْفَانْ ذ ڒفْنَارَاثْ نّسْ - ڒفْنَارَاثْ نِّي ثُوغَا إِتّْخصَّا أَذْ تّْوَاسّْوجْذنْثْ، ذ مَارَّا ڒقْشُوعْ نّسْ ذ زّشْثْ إِ ثْفَاوْثْ -
\v 38 ذ ؤُعَالْطَارْ ن وُورغْ ذ زّشْثْ إِ وذْهَانْ ذ ڒبْخُورْ إِتّْفُوحنْ ذ أَرْوَاقْ إِ وَاذَافْ ن ؤُقِيضُونْ
\v 39 ذ ؤُعَالْطَارْ ن نّْحَاسْ س ثْرَاشَّا ن نّْحَاسْ ذ إِعُومَاذْ نّسْ \add إِ ثَاربُّوثْ\add* ذ مَارَّا ڒقْشُوعْ نّسْ ذ ثْبَانْيُوثْ أَكْ-ذ ؤُضَارْ نّسْ
\v 40 ذ ڒِيزَارَاثْ ن ڒمْرَاحْ أَكْ-ذ إِپِيلَارنْ نْسنْثْ ذ ثْيَارْسَاوِينْ نْسنْ، ؤُڒَا ذ أَرْوَاقْ ن وَاذَافْ ن ڒمْرَاحْ ذ إِفِيڒَانْ نّسْ ذ ڒوْثَاذْ نّسْ ذ مَارَّا ڒقْشُوعْ إِ ثْسخَّارْثْ ن ثْزذِّيغْثْ، إِ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ
\v 41 ؤُڒَا ذ أَرُّوضْ إِ ثْسخَّارْثْ، حِيمَا أَذْ \add زَّايسْ\add* سخَّارنْ \add إِكهَّاننْ\add* ذِي زَّاوشْثْ إِقدّْسنْ، أَرُّوضْ إِقدّْسنْ إِ ؤُكهَّانْ هَارُونْ ذ أَرُّوضْ إِ وَارَّاوْ نّسْ، حِيمَا \add أَذْ سخَّارنْ ذ\add* إِكهَّاننْ. \x ◘ \xo 39:‏41 \xt ؤُف. 31‏:‏10\x*
\v 42 ڭِّينْ أَيْثْ ن إِسْرَائِيل مَارَّا ڒْخذْمثْ أَمْ مَامّشْ مَارَّا إِ يُومُورْ سِيذِي إِ مُوسَا.
\v 43 إِخْزَارْ مُوسَا غَارْ مَارَّا ڒْخذْمثْ ؤُشَا إِژْرَا بلِّي ثتّْوَاڭّْ أَمْ مَامّشْ يُومُورْ سِيذِي، \add وَاهْ،\add* أَمُّو إِ-ت ڭِّينْ. ؤُشَا إِبَارْكْ إِ-ثنْ مُوسَا.
\b
\b
\c 40
\s1 مُوسَا إِسّْڭعّذْ أَقِيضُونْ ن ؤُمْسَاڭَارْ
\m 
\v 1 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:
\m 
\v 2 ”ذڭْ وَاسّْ أَمزْوَارُو ن ؤُيُورْ أَمزْوَارُو أَذْ ثسّْڭعّْذذْ ثَازذِّيغْثْ، أَقِيضُونْ ن ؤُمْسَاڭَارْ.
\v 3 أَذْ ذَايسْ ثڭّذْ تَّابُوثْ ن شّْهَاذثْ ؤُشَا أَذْ ثذْڒذْ تَّابُوثْ س ؤُڒحَّافْ.
\v 4 أَذْ ثسِّيذْفذْ ثَازوْضَا ؤُشَا أَذْ ت ثْستّْفذْ أَستّفْ نّسْ. أَذْ ثسِّيذْفذْ ڒْقنْذِيڒْ ؤُشَا أَذْ ثسِّيغذْ ڒفْنَارَاثْ نّسْ. \x ◘ \xo 40:‏4 \xt ؤُف. 26‏:‏35؛ 27‏:‏20\x*
\v 5 أَذْ ثسَّارْسذْ أَعَالْطَارْ ن وُورغْ إِ ڒبْخُورْ زَّاثْ إِ تَّابُوثْ ن شّْهَاذثْ ؤُشَا أَذْ ثڭّذْ أَرْوَاقْ ن وَاذَافْ زَّاثْ ن ثْزذِّيغْثْ. \x ◘ \xo 40:‏5 \xt ؤُف. 26‏:‏36\x*
\v 6 أَذْ ثسَّارْسذْ أَعَالْطَارْ ن وشْمَاضْ زَّاثْ إِ وَاذَافْ ن ثْزذِّيغْثْ، أَقِيضُونْ ن ؤُمْسَاڭَارْ.
\v 7 أَذْ ثسَّارْسذْ ثَابَانْيُوثْ جَارْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ ذ ؤُعَالْطَارْ ؤُشَا أَذْ ذَايسْ ثڭّذْ أَمَانْ.
\v 8 أَذْ ثسّْبدّذْ ڒمْرَاحْ غَارْ مَارَّا إِغزْذِيسنْ نّسْ ؤُشَا أَذْ ثَايْڒذْ أَرْوَاقْ ن وَاذَافْ ن ڒمْرَاحْ. \x ◘ \xo 40:‏8 \xt ؤُف. 27‏:‏16\x*
\v 9 أَذْ ثكْسِيذْ زّشْثْ إِ وذْهَانْ ؤُشَا أَذْ ثْذهْنذْ ثَازذِّيغْثْ ذ مَارَّا مِينْ ذَايسْ \add إِدْجَانْ\add*. أَذْ ت ثسّْقدّْسذْ أَكْ-ذ مَارَّا ڒقْشُوعْ نّسْ. أَذْ ثِيڒِي نتَّاثْ ذ ثَامْقدَّاسْثْ.
\v 10 أَذْ ثْذهْنذْ أَعَالْطَارْ ن وشْمَاضْ س مَارَّا ڒقْشُوعْ نّسْ. أَذْ ثسّْقدّْسذْ أَعَالْطَارْ. أَعَالْطَارْ \add أَذْ يِيڒِي\add* ذ أَمْقدَّاسْ قَاعْ. \x ◘ \xo 40:‏10 \xt ؤُف. 29‏:‏37\x*
\v 11 أَذْ ثْذهْنذْ ثَابَانْيُوثْ ذ ؤُضَارْ نّسْ ؤُشَا أَذْ ت ثسّْقدّْسذْ.
\v 12 أَذْ د-ثسّْقَارّْبذْ هَارُونْ ذ وَارَّاوْ نّسْ غَارْ وَاذَافْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ ؤُشَا أَذْ ثنْ ثسِّيرْذذْ س وَامَانْ.
\v 13 أَذْ ثسّْيَارْضذْ إِ هَارُونْ أَرُّوضْ إِقدّْسنْ ؤُشَا أَذْ ث ثْذهْنذْ ؤُشَا أَذْ ث ثسّْقدّْسذْ، مَاحنْذْ أَذْ أَيِي يِيڒِي ذ أَكهَّانْ إِ نشّْ.
\v 14 خنِّي أَذْ د-ثسّْقَارّْبذْ إِحنْجِيرنْ نّسْ ؤُشَا أَذْ أَسنْ ثْيَارْضذْ ثْشَامِيرَاثْ.
\v 15 أَذْ ثنْ ثْذهْنذْ أَمْ مَامّشْ ثْذهْنذْ بَابَاثْسنْ، مَاحنْذْ أَذْ أَيِي سخَّارنْ أَمْ يِيكهَّاننْ. أَذْ يِيڒِي وذْهَانْ نْسنْ إِ نِيثْنِي ذ إِشْثْ ن ثُوكهَّانْثْ إِ ڒبْذَا إِ \add مَارَّا\add* جِّيڒَاثْ نْسنْ.“
\b
\m 
\v 16 إِڭَّا مُوسَا مَارَّا أَمْ مَامّشْ يُومُورْ سِيذِي، \add وَاهْ،\add* أَمُّو إِ ث إِڭَّا.
\b
\m 
\v 17 \bd إِمْسَارْ ذڭْ ؤُيُورْ أَمزْوَارُو ن ؤُسڭّْوَاسْ وِيسّْ ثْنَاينْ، ذڭْ وَاسّْ أَمزْوَارُو ن ؤُيُورْ، أَقَا سّْڭعّْذنْ ثَازذِّيغْثْ.\bd* \x ◘ \xo 40:‏17 \xt ڒخْڒ. 7‏:‏1\x*
\v 18 مُوسَا إِسّْڭعّذْ ثَازذِّيغْثْ، إِسَّارْسْ ثِييَارْسَاوِينْ نّسْ، إِڭَّا ذَايْسنْثْ ثِيفڒْوِينْ، إِڭَّا خَاسنْثْ ثِيحنْيَا ن ؤُعَارّضْ \add ثِينِّي خَاسنْثْ إِژْوَانْ\add*، ؤُشَا إِسّْبدّْ إِپِيلَارنْ نّسْ.
\v 19 إِبزّعْ أَقِيضُونْ خْ ثْزذِّيغْثْ ؤُشَا إِسَّارْسْ خَاسْ ثَاسقَّافْثْ ن ؤُقِيضُونْ أَمْ مَامّشْ يُومُورْ سِيذِي إِ مُوسَا.
\v 20 إِكْسِي شّْهَاذثْ ؤُشَا إِسَّارْسْ إِ-ت ذَاخڒْ ذِي تَّابُوثْ ؤُشَا إِشدّْ إِعُومَاذْ \add إِ ثَاربُّوثْ\add* غَارْ تَّابُوثْ ؤُشَا إِسَّارْسْ ثَاقبَّارْثْ ن وصْڒَاحْ خْ تَّابُوثْ.
\v 21 إِسِّيذفْ تَّابُوثْ ذِي ثْزذِّيغْثْ ؤُشَا يُويڒْ أَڒحَّافْ أَمْ دُّورِي ؤُشَا إِسّْذُورِييْ تَّابُوثْ ن شّْهَاذثْ أَمْ مَامّشْ يُومُورْ سِيذِي إِ مُوسَا. \x ◘ \xo 40:‏21 \xt ؤُف. 35‏:‏12\x*
\v 22 إِسَّارْسْ ثَازوْضَا ذڭْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ، غَارْ ؤُغزْذِيسْ ن شَّامَالْ ن ثْزذِّيغْثْ، غَارْ بَارَّا ن ؤُڒحَّافْ.
\v 23 إِستّفْ خَاسْ أَغْرُومْ زَّاثْ إِ وُوذمْ ن سِيذِي، أَمْ مَامّشْ يُومُورْ سِيذِي إِ مُوسَا. \x ◘ \xo 40:‏23 \xt ؤُف. 25‏:‏30\x*
\v 24 إِسَّارْسْ ڒْقنْذِيڒْ ذڭْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ، نِيشَانْ ذڭْ ؤُرنْذَاذْ ن ثْزوْضَا، غَارْ جِّيهثْ ن لْجَانُوبْ ن ثْزذِّيغْثْ.
\v 25 إِسَّارْسْ خَاسْ ثِيفْثِيڒِينْ زَّاثْ إِ وُوذمْ ن سِيذِي، أَمْ مَامّشْ يُومُورْ سِيذِي إِ مُوسَا.
\v 26 إِوْشَا أَمْشَانْ إِ ؤُعَالْطَارْ ن وُورغْ ذڭْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ زَّاثْ إِ ؤُڒحَّافْ.
\v 27 إِسّْبخَّارْ خَاسْ ڒبْخُورْ إِتّْفُوحنْ أَمْ مَامّشْ يُومُورْ سِيذِي إِ مُوسَا.
\v 28 يُويڒْ أَرْوَاقْ غَارْ وَاذَافْ ن ثْزذِّيغْثْ.
\v 29 إِوْشَا أَمْشَانْ إِ ؤُعَالْطَارْ ن وشْمَاضْ غَارْ وَاذَافْ ن ثْزذِّيغْثْ، أَقِيضُونْ ن ؤُمْسَاڭَارْ. إِسّْبخَّارْ خَاسْ ثَاغَارْصْثْ ن وشْمَاضْ ذ ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add*، أَمْ مَامّشْ يُومُورْ سِيذِي إِ مُوسَا.
\v 30 إِسَّارْسْ ثَابَانْيُوثْ جَارْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ ذ ؤُعَالْطَارْ. إِڭَّا ذَايسْ أَمَانْ إِ ؤُسِيرْذْ.
\v 31 مُوسَا ذ هَارُونْ ذ وَارَّاوْ نّسْ سِّيرْذنْ زَّايسْ إِفَاسّنْ ذ إِضَارنْ نْسنْ.
\v 32 ڒَامِي ثُوغَا تَّاذْفنْ غَارْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ ؤُ ڒَامِي د-تّْقَارَّابنْ غَارْ ؤُعَالْطَارْ، سِّيرْذنْ إِخفْ نْسنْ أَمْ مَامّشْ يُومُورْ سِيذِي إِ مُوسَا.
\v 33 غَارْ مَارَّا إِغزْذِيسنْ ن ثْزذِّيغْثْ ذ ؤُعَالْطَارْ إِتّْوَاڭّْ أَسْ-د ڒمْرَاحْ ؤُشَا يُويڒْ نتَّا أَرْوَاقْ ن وَاذَافْ ن ڒمْرَاحْ. \add أَمُّو\add* إِ إِكمّڒْ مُوسَا ڒْخذْمثْ.
\m 
\v 34 \add خنِّي\add* إِذْڒَا ؤُسيْنُو أَقِيضُونْ ن ؤُمْسَاڭَارْ ؤُشَا أَعُودْجِي ن سِيذِي إِشُّورْ ثَازذِّيغْثْ. \x ◘ \xo 40:‏34 \xt ڒخْڒ. 9‏:‏15؛ 1 إِج. 8‏:‏10\x*
\v 35 وَارْ إِزمَّارْ مُوسَا أَذْ يَاذفْ غَارْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ، مِينْزِي أَسيْنُو يَارْسَا خَاسْ ؤُ أَعُودْجِي ن سِيذِي إِشُّورْ ثَازذِّيغْثْ.
\v 36 ڒَامِي د-إِڭعّذْ ؤُسيْنُو زِي سنّجْ ن ثْزذِّيغْثْ، فسْينْ أَيْثْ ن إِسْرَائِيل إِقِيضَانْ نْسنْ ؤُشَا \add أَمُّو\add* مُوطّْينْ \add زڭْ ومْشَانْ غَارْ ومْشَانْ\add*.
\v 37 مَاڒَا وَارْ د-إِڭعّذْ ؤُسيْنُو، وَارْ فسْينْ إِقِيضَانْ نْسنْ أَڒْ أَسّْ إِ ذِي ثُوغَا إِتّْڭعّذْ.
\v 38 مِينْزِي أَسيْنُو ن سِيذِي ثُوغَا يَارْسَا خْ ثْزذِّيغْثْ س ؤُزِيڒْ ؤُشَا ذِي دْجِيڒثْ ثُوغَا ثِيمسِّي زَّاثْ إِ ثِيطَّاوِينْ ن مَارَّا ثَادَّارْثْ ن إِسْرَائِيل ذڭْ إِمُوطُّوينْ نْسنْ \add زڭْ ومْشَانْ غَارْ ومْشَانْ\add*. \x ◘ \xo 40:‏38 \xt ؤُف. 13‏:‏21؛ ڒخْڒ. 14‏:‏14؛ أَعَوذ. 1‏:‏33؛ نَاح. 9‏:‏19؛ إِزهد. 78‏:‏14؛ 105‏:‏39؛ 1 كُور. 10‏:‏1\x* 
