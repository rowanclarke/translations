\v 20 \w Luego|strong="G3767"\w* les \w mostró|strong="G1166"\w* \w las|strong="G3588"\w* \w manos|strong="G5495"\w* \w y|strong="G2532"\w* \w el|strong="G3588"\w* \w costado|strong="G4125"\w*. \w Al|strong="G3588"\w* ver \w al|strong="G3588"\w* \w Señor|strong="G2962"\w*, \w los|strong="G3588"\w* \w discípulos|strong="G3101"\w* \w se|strong="G2532"\w* regocijaron.   
\p
