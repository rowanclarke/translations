\v 3 \w Then|strong="H1961"\w* \w we|strong="H3068"\w* \w will|strong="H1961"\w* \w bring|strong="H7725"\w* \w back|strong="H7725"\w* \w all|strong="H3605"\w* \w his|strong="H3605"\w* \w soldiers|strong="H5971"\w* \w to|strong="H7725"\w* \w you|strong="H3605"\w*, \w like|strong="H1961"\w* [SIM] \w a|strong="H3068"\w* ◄bride/woman \w comes|strong="H1961"\w* \w to|strong="H7725"\w* \w her|strong="H3605"\w* husband \w when|strong="H1961"\w* she \w is|strong="H3605"\w* married►. \w You|strong="H3605"\w* \w are|strong="H5971"\w* wanting \w to|strong="H7725"\w* kill \w only|strong="H1245"\w* \w one|strong="H3605"\w* \w man|strong="H3605"\w*; \w so|strong="H1961"\w* \w the|strong="H3605"\w* \w other|strong="H3605"\w* \w people|strong="H5971"\w* \w will|strong="H1961"\w* \w not|strong="H1961"\w* \w be|strong="H1961"\w* harmed.”
\v 4 Absalom \w and|strong="H3478"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* Israeli \w leaders|strong="H2205"\w* \add who were with him\add* \w thought|strong="H5869"\w* \w that|strong="H3605"\w* \w what|strong="H1697"\w* Ahithophel \w said|strong="H1697"\w* \w would|strong="H3478"\w* \w be|strong="H1697"\w* \w good|strong="H3474"\w* \w to|strong="H3478"\w* \w do|strong="H5869"\w*.
