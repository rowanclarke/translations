\id HAB  
\h Knjiga proroka Avakuma 
\toc1 Knjiga proroka Avakuma 
\toc2 Avakum 
\toc3 Av 
\mt1 Knjiga proroka Avakuma  
\c 1  
\s1 Judini grehovi. Kazna zbog njih preko Haldejaca. Prorokova molitva i jadikovanje.  
\p
\v 1 Breme koje vide prorok Avakum.   
\b  
\q1
\v 2 Dokle ću, Gospode, vapiti  
\q2 a Ti nećeš da čuješ?  
\q1 Dokle ću Ti vikati: Nasilje!  
\q2 A Ti nećeš da izbaviš?   
\q1
\v 3 Zašto puštaš da vidim bezakonje,  
\q2 i da gledam muku i grabež i nasilje pred sobom,  
\q2 i kako podižu svađu i raspru?   
\q1
\v 4 Zato se ostavlja zakon,  
\q2 i sud ne izlazi nikada,  
\q1 jer bezbožnik opteče pravednika,  
\q2 zato sud izlazi izopačen.   
\b  
\q1
\v 5 Pogledajte po narodima i vidite,  
\q2 i čudite se i divite se,  
\q1 jer ću učiniti delo u vaše dane  
\q2 kog nećete verovati kad se stane pripovedati.   
\q1
\v 6 Jer, evo, ja ću podignuti Haldejce,  
\q2 narod ljut i nagao,  
\q1 koji će ići po zemlji širom  
\q2 da osvoji naselja koja nisu njegova.   
\q1
\v 7 Žestok je i strašan,  
\q2 sud njegov i vlast njegova od njega izlazi.   
\q1
\v 8 Konji će mu biti brži od risova  
\q2 i ljući od vukova uveče,  
\q1 veliko će mnoštvo biti konjika njegovih,  
\q2 i idući izdaleka konjici njegovi  
\q2 doleteće kao orao kad hiti na lov.   
\q1
\v 9 Svi će doći na grabež,  
\q2 s lica će biti kao istočni vetar,  
\q2 pokupiće roblje kao pesak.   
\q1
\v 10 I carevima će se rugati  
\q2 i knezovi će im biti podsmeh,  
\q1 smejaće se svakom gradu,  
\q2 nasuće zemlje, i uzeće ga.   
\q1
\v 11 Tada će mu se promeniti duh,  
\q2 proći će i skriviće;  
\q2 ta će mu sila njegova biti od Boga njegovog.   
\b  
\q1
\v 12 Nisi li Ti od veka,  
\q2 Gospode Bože moj, Sveče moj?  
\q2 Nećemo umreti;  
\q1 Ti si ga, Gospode, odredio za sud;  
\q2 i utvrdio si ga, Steno, za karanje.   
\q1
\v 13 Čiste su oči tvoje da ne možeš gledati zlo,  
\q2 i bezakonje ne možeš gledati;  
\q1 zašto gledaš bezakonike?  
\q2 Ćutiš, kad bezbožnik proždire pravijeg od sebe?   
\q1
\v 14 I hoćeš li ostaviti ljude kao ribe morske,  
\q2 kao bubine, koje nemaju gospodara?   
\q1
\v 15 Izvlači ih sve udicom,  
\q2 hvata ih u mrežu svoju,  
\q1 i zgrće ih pređom svojom,  
\q2 zato se veseli i raduje.   
\q1
\v 16 Zato prinosi žrtvu svojoj mreži,  
\q2 i kadi svojoj pređi;  
\q1 jer je time deo njegov pretio  
\q2 i hrana mu izabrana.   
\q1
\v 17 Hoće li zato izvlačiti mrežu svoju  
\q2 i jednako ubijati narode nemilice?   
\c 2  
\s1 Uteha za veru. Grehovi Haldejaca. Proricanje o propasti oholih.  
\q1
\v 1 Na straži svojoj stadoh,  
\q2 i stajah na kuli,  
\q1 i motrah da vidim šta će mi reći  
\q2 i šta bih odgovorio onome koji me koraše.   
\b  
\p
\v 2 I odgovori mi Gospod i reče:  
\b  
\q1 Piši utvaru,  
\q2 i da bude razgovetno na pločama  
\q2 da se lako čita.   
\q1
\v 3 Jer će još biti utvara do određenog vremena,  
\q2 i govoriće šta će biti do kraja  
\q2 i neće slagati;  
\q1 ako okleva, čekaj je,  
\q2 jer će zacelo doći,  
\q2 i neće odocniti.   
\b  
\q1
\v 4 Gle, ko se ponosi, njegova duša nije prava u njemu;  
\q2 a pravednik će od vere svoje živ biti.   
\b  
\q1
\v 5 A kako vino vara,  
\q2 takav je čovek ohol,  
\q2 niti ostaje u stanu;  
\q1 jer raširuje duh svoj kao grob,  
\q2 i kao smrt je,  
\q2 koja se ne može nasititi  
\q1 i zbira k sebi sve narode  
\q2 i skuplja k sebi sva plemena.   
\b  
\p
\v 6 Neće li ga svi oni uzeti u priču i u zagonetke, i reći:  
\b  
\q1 Teško onom koji umnožava šta nije njegovo!  
\q2 Dokle će?  
\q2 I koji trpa na se gusto blato.   
\q1
\v 7 Neće li najedanput ustati oni koji će te gristi?  
\q2 I neće li se probuditi oni koji će te rastrzati,  
\q2 i kojima ćeš biti grabež?   
\q1
\v 8 Što si ti oplenio mnoge narode,  
\q2 tebe će opleniti sav ostatak od naroda,  
\q1 za krv ljudsku  
\q2 i za nasilje učinjeno zemlji, gradu i svima koji žive u njemu.   
\b  
\q1
\v 9 Teško onome koji se lakomi na gadan dobitak kući svojoj,  
\q2 da postavi gnezdo svoje na visokom mestu  
\q2 i sačuva se oda zla.   
\q1
\v 10 Smislio si sramotu kući svojoj  
\q2 da zatreš mnoge narode,  
\q2 i ogrešio si se o svoju dušu.   
\q1
\v 11 Jer će kamen iz zida vikati,  
\q2 i čvor iz drveta svedočiće.   
\b  
\q1
\v 12 Teško onome koji gradi grad krvlju  
\q2 i osniva grad nepravdom.   
\q1
\v 13 Gle, nije li od Gospoda nad vojskama  
\q2 da ljudi rade za oganj  
\q2 i narodi se trude nizašta?   
\q1
\v 14 Jer će se zemlja napuniti poznanja slave Gospodnje  
\q2 kao što je more puno vode.   
\b  
\q1
\v 15 Teško onome koji poji bližnjeg svog,  
\q2 dodaje meh svoj da bi ga opojio  
\q2 i gledao mu golotinju.   
\q1
\v 16 Nasitićeš se sramote mesto slave,  
\q2 pij i ti, i otkrij golotinju svoju;  
\q1 doći će k tebi čaša u desnici Gospodnjoj,  
\q2 i bljuvotina će sramna biti na slavi tvojoj.   
\q1
\v 17 Jer nasilje učinjeno Livanu pokriće te  
\q2 i pustoš među zverjem koja ga je plašila,  
\q1 za krv ljudsku  
\q2 i nasilje učinjeno zemlji, gradu i svima koji žive u njemu.   
\b  
\q1
\v 18 Šta pomaže rezan lik što ga izreza umetnik njegov?  
\q2 Šta liven lik i učitelj laži,  
\q2 te se umetnik uzda u delo svoje gradeći neme idole?   
\q1
\v 19 Teško onome koji govori drvetu: Preni se!  
\q2 I nemom kamenu: Probudi se!  
\q1 Hoće li on učiti?  
\q2 Eto, obložen je zlatom i srebrom,  
\q2 a nema duha u njemu.   
\q1
\v 20 A Gospod je u svetoj crkvi svojoj;  
\q2 ćuti pred Njim sva zemljo!   
\c 3  
\s1 Prorokova molitva puna radosnog pouzdanja.  
\p
\v 1 Molitva proroka Avakuma; za pevanje.   
\b  
\q1
\v 2 Gospode, čuh reč Tvoju,  
\q2 i uplaših se;  
\q1 Gospode, delo svoje usred godina sačuvaj u životu,  
\q2 usred godina objavi ga,  
\q2 u gnevu seti se milosti.   
\q1
\v 3 Bog dođe od Temana  
\q2 i Svetac s gore Farana;  
\q1 slava Njegova pokri nebesa  
\q2 i zemlja se napuni hvale Njegove.   
\q1
\v 4 Svetlost Mu beše kao sunce,  
\q2 zraci izlažahu Mu iz ruku,  
\q2 i onde beše sakrivena sila Njegova.   
\q1
\v 5 Pred Njim iđaše pomor,  
\q2 i živo ugljevlje iđaše ispod nogu Njegovih.   
\q1
\v 6 Stade, i izmeri zemlju,  
\q2 pogleda i razmetnu narode,  
\q1 raspadoše se večne gore,  
\q2 slegoše se humovi večni;  
\q2 putevi su Mu večni.   
\q1
\v 7 Videh šatore etiopske u muci,  
\q2 ustreptaše zavesi zemlji madijanskoj.   
\q1
\v 8 Eda li se na reke razgnevi Gospod?  
\q2 Eda li se na reke raspali gnev Tvoj?  
\q2 Na more jarost Tvoja,  
\q1 kad si pojezdio na konjima svojim  
\q2 i na kolima svojim za spasenje?   
\q1
\v 9 Pomoli se luk Tvoj  
\q2 kao što si se zakleo plemenima;  
\q2 razdro si zemlju za reke.   
\q1
\v 10 Videše Te gore i uzdrhtaše,  
\q2 povodanj navali;  
\q1 bezdana pusti glas svoj,  
\q2 uvis podiže ruke svoje.   
\q1
\v 11 Sunce i mesec stadoše u stanu svom,  
\q2 idoše prema svetlosti Tvoje strele,  
\q2 prema sevanju sjajnog koplja Tvog.   
\q1
\v 12 Srdito si išao po zemlji,  
\q2 gnevno si gazio narode.   
\q1
\v 13 Izašao si na spasenje narodu svom,  
\q2 na spasenje s pomazanikom svojim;  
\q1 razmrskao si glavu kući bezbožničkoj  
\q2 do vrata otkrivši temelj.   
\q1
\v 14 Njegovim kopljima probio si glavu selima njegovim  
\q2 kad navaljivahu kao vihor da me razaspu,  
\q1 radovahu se  
\q2 kao da će proždreti siromaha u potaji.   
\q1
\v 15 Išao si po moru na konjima svojim,  
\q2 po gomili mnoge vode.   
\b  
\q1
\v 16 Čuh, i utroba se moja uskoleba,  
\q2 usne mi uzdrhtaše na glas,  
\q1 u kosti mi uđe trulež,  
\q2 i ustresoh se na mestu svom;  
\q1 kako ću počivati u dan nevolje,  
\q2 kad dođe na narod koji će ga opustošiti.   
\b  
\q1
\v 17 Jer smokva neće cvasti,  
\q2 niti će biti roda na lozi vinovoj;  
\q1 rod će maslinov prevariti,  
\q2 i njive neće dati hrane,  
\q1 ovaca će nestati iz tora,  
\q2 i goveda neće biti u oboru.   
\q1
\v 18 Ali ću se ja radovati u Gospodu,  
\q2 veseliću se u Bogu spasenja svog.   
\q1
\v 19 Gospod je Gospod sila moja,  
\q2 i daće mi noge kao u košute,  
\q2 i vodiće me po visinama mojim.  
\b  
\p Načelniku pevačkom uz žice moje.   