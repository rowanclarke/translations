\p 
\v 21 \w Jesus|strong="G2424"\w* \w answered|strong="G3004"\w* \w and|strong="G2532"\w* \w said|strong="G3004"\w* \w to|strong="G2532"\w* \w them|strong="G4160"\w*: “\w I|strong="G2532"\w* \w did|strong="G4160"\w* \w one|strong="G1520"\w* \w work|strong="G2041"\w*, \w and|strong="G2532"\w* \w you|strong="G3004"\w* \w all|strong="G3956"\w* \w marvel|strong="G2296"\w*.
