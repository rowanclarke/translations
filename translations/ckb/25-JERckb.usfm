\id JER - Biblica® Open Kurdi Sorani Standard Version
\h یەرمیا
\toc1 یەرمیا
\toc2 یەرمیا
\toc3 یەرمیا
\mt1 یەرمیا
\c 1
\p 
\v 1 پەیامی یەرمیای کوڕی حیلقیا، یەکێک لە کاهینانی شارۆچکەی عەناتۆت لە خاکی بنیامین.
\v 2 فەرمایشتی یەزدانی بۆ دەهات، لە ساڵی سێزدەیەمینی پاشایەتی یۆشیای کوڕی ئامۆنی پاشای یەهودا،
\v 3 هەروەها لە ماوەی پاشایەتی یەهۆیاقیمی کوڕی یۆشیای پاشای یەهودا، هەتا مانگی پێنجی ساڵی یازدەیەمینی سدقیای کوڕی یۆشیای پاشای یەهودا، کاتی ڕاپێچانەکەی خەڵکی ئۆرشەلیم.
\s1 بانگکردنی یەرمیا
\p 
\v 4 فەرمایشتی یەزدانم بۆ هات:
\q1 
\v 5 «پێش ئەوەی لەناو سکی دایکت شێوەت بکێشم، تۆم ناسی،
\q2 پێش ئەوەی لە منداڵدان بێیتە دەرەوە، تەرخانم کردیت،
\q2 تۆم کردە پێغەمبەری نەتەوەکان.»
\p 
\v 6 بەڵام من گوتم: «ئای، ئەی یەزدانی باڵادەست، وتەبێژی لە توانامدا نییە، چونکە تەمەنم بچووکە.»
\p 
\v 7 ئینجا یەزدان پێی فەرمووم: «مەڵێ: ”تەمەنم بچووکە.“ بۆ لای هەرکەسێک بتنێرم دەچیت و هەموو ئەوەی فەرمانت پێ بکەم ڕایدەگەیەنیت.
\v 8 لێیان مەترسە، چونکە من لەگەڵتدام بۆ ئەوەی فریات بکەوم.» ئەوە فەرمایشتی یەزدانە.
\p 
\v 9 ئینجا یەزدان دەستی درێژکرد و دەستی لە دەمم دا و پێی فەرمووم: «دڵنیابە، من وتەکانم دەخەمە دەمی تۆوە.
\v 10 ببینە، ئەمڕۆ تۆم کرد بە پێغەمبەر بۆ نەتەوە و شانشینەکان، بۆ ڕیشەکێشکردن و شکاندن، بۆ لەناوبردن و ڕووخاندن، بۆ بنیادنان و چاندن.»
\p 
\v 11 ئینجا فەرمایشتی یەزدانم بۆ هات، پێی فەرمووم: «ئەی یەرمیا، چی دەبینیت؟»
\p منیش گوتم: «چڵە بادەمێک دەبینم.»
\p 
\v 12 یەزدانیش پێی فەرمووم: «چاکت بینی، چونکە من لەسەر فەرمایشتەکەم چاودێر\f + \fr 1:12 \ft لە زمانی عیبری دەنگی وشەی چاودێر، \tl شۆقێد‏\tl*، نزیکە لە دەنگی وشەی داری بادەم، \tl شاقێد‏\tl*.‏\f* دەبم بۆ ئەنجامدانی.»
\p 
\v 13 دووبارە فەرمایشتی یەزدانم بۆ هات: «چی دەبینیت؟»
\p منیش گوتم: «مەنجەڵێک دەبینم هەڵمی لێ هەڵدەستێت و ڕووی بەرەو باشوورە.»
\p 
\v 14 یەزدانیش پێی فەرمووم: «لە باکوورەوە بەڵا بۆ هەموو دانیشتووانی خاکەکە دەبارێت.
\v 15 خەریکم بانگەواز دەکەم بۆ هەموو نەتەوەکانی شانشینەکانی باکوور.» ئەوە فەرمایشتی یەزدانە.
\q1 «جا پاشاکانیان دێن و
\q2 هەریەکە و تەختی خۆی لە داڵانی دەروازەی ئۆرشەلیم دادەنێت،
\q1 هێرش دەبەن بۆ سەر هەموو شووراکانی چواردەوری ئۆرشەلیم و
\q2 بۆ هەموو شارۆچکەکانی یەهودا.
\q1 
\v 16 منیش حوکمەکانم بەسەریان ڕادەگەیەنم،
\q2 لەسەر هەموو خراپەکانیان کە وازیان لێ هێنام و
\q1 بۆ خوداکانی دیکە بخووریان سووتاند و
\q2 بۆ دەستکردەکانی دەستی خۆیان کڕنۆشیان برد.
\p 
\v 17 «تۆش بازووی خۆتی لێ هەڵبکە! هەستە و قسەیان لەگەڵ بکە سەبارەت بە هەموو ئەوەی من فەرمانت پێدەدەم. لێیان مەتۆقە، نەوەک لەبەردەمیان بتتۆقێنم.
\v 18 من ئەمڕۆ تۆم کردووەتە شارێکی قەڵابەند و کۆڵەکەی ئاسن و دیواری بڕۆنز، لە دژی هەموو خاکەکە، پاشاکانی یەهودا، پیاوە گەورەکانی، کاهینەکانی و گەلی خاکەکە.
\v 19 لە دژت دەجەنگن و دەرەقەتت نایێن، چونکە من لەگەڵتدام بۆ ئەوەی فریات بکەوم.» ئەوە فەرمایشتی یەزدانە.
\c 2
\s1 وازهێنانی ئیسرائیل لە خودا
\p 
\v 1 فەرمایشتی یەزدانم بۆ هات، پێی فەرمووم:
\v 2 «بڕۆ و بە ئۆرشەلیمی ڕابگەیەنە با خەڵکەکە بیبیستن، بڵێ:
\b
\p «یەزدان ئەمە دەفەرموێت:
\q1 «”بە یادی خۆمم هێنایەوە، دڵسۆزی کاتی مێردمنداڵیت و
\q2 خۆشەویستی کاتی بووکێنیت،
\q1 بەدوای مندا ڕۆیشتیت لە چۆڵەوانی،
\q2 بە خاکێکدا کە کشتوکاڵی تێدا نەبوو.
\q1 
\v 3 ئیسرائیل بۆ یەزدان پیرۆز بوو،
\q2 یەکەمین بەرهەمی بەروبوومەکەیەتی.
\q1 هەموو ئەوانەی خواردیان تاوانیان کرد،
\q2 بەڵایان بەسەردا هات.“»
\q4 ئەوە فەرمایشتی یەزدانە.
\b
\q1 
\v 4 گوێ لە فەرمایشتی یەزدان بگرن، ئەی بنەماڵەی یاقوب،
\q2 ئەی هەموو خێڵەکانی بنەماڵەی ئیسرائیل،
\q1 
\v 5 یەزدان ئەمە دەفەرموێت:
\q1 «باوباپیرانتان چ کەموکوڕییەکیان لە مندا بینی
\q2 کە لێم دوور کەوتنەوە؟
\q1 چوون دوای بتی پووچ کەوتن و
\q2 خۆیان پووچ کرد.
\q1 
\v 6 پرسیاریان نەکرد: ”کوا یەزدان،
\q2 ئەوەی لە خاکی میسرەوە دەریهێناین،
\q1 ئەوەی ئێمەی بەناو چۆڵەوانیدا برد،
\q2 بە خاکێکی ڕووتەن و چاڵوچۆڵدا،
\q1 بە خاکێکی وشک و سێبەری مەرگ،
\q2 بە خاکێکدا کە کەسی پێدا تێنەپەڕیبوو،
\q2 کەس لەوێ نیشتەجێ نەببوو؟“
\q1 
\v 7 ئێوەم هێنایە ناو خاکێکی بەپیت
\q2 بۆ ئەوەی بەروبووم و بەرهەمە چاکەکانی بخۆن.
\q1 بەڵام هاتن و زەوییەکەی منتان گڵاو کرد،
\q2 میراتەکەی منتان قێزەون کرد.
\q1 
\v 8 کاهینەکان پرسیاریان نەکرد:
\q2 ”کوا یەزدان؟“
\q1 ئەوانەی مامۆستای تەوراتن نەیانناسیم،
\q2 ڕابەرەکان لێم یاخی بوون،
\q1 پێغەمبەرەکان بەهۆی بەعلەوە پێشبینییان کرد،
\q2 دوای بتی پووچ کەوتن.»
\b
\q1 
\v 9 یەزدان دەفەرموێت: «لەبەر ئەوە دیسان دادگاییتان دەکەم،
\q2 منداڵی منداڵیشتان پەلکێشی دادگا دەکەم.
\q1 
\v 10 لە کەنارەکانی کیتیم\f + \fr 2:10 \ft قوبرس و کەنارەکانی ڕۆژئاوای.‏\f* بپەڕنەوە و ببینن،
\q2 بنێرن بۆ قێدار\f + \fr 2:10 \ft ناوچەی هۆزەکانی بەدوو لە بیابانی عەرەبستان و سوریا.‏\f* و بە وردی سەرنج بدەن،
\q2 ببینن ئاخۆ شتی وەک ئەمە بووە؟
\q1 
\v 11 ئایا هیچ نەتەوەیەک خوداوەندەکانی خۆی گۆڕیوە؟
\q2 هەرچەندە خودا نین.
\q1 بەڵام گەلەکەی من خودای شکۆمەندیان گۆڕییەوە
\q2 بە بتی پووچ.
\q1 
\v 12 ئەی ئاسمان، لەبەر ئەمە واقت وڕبمێنێت،
\q2 موچڕکەت پێدابێت و زۆر سەرسام بە.»
\q4 ئەوە فەرمایشتی یەزدانە.
\q1 
\v 13 «گەلەکەم دوو خراپەی کردووە:
\q1 وازیان لە من هێنا،
\q2 من کە کانی ئاوی ژیانم،
\q1 هەروەها ئەمباراویان بۆ خۆیان هەڵکەند،
\q2 ئەمباراوی شکاو کە ئاو ڕاناگرێت.
\q1 
\v 14 ئایا ئیسرائیل کۆیلەیە؟ یان کوڕی کۆیلەی لەدایک بووی ماڵە؟
\q2 بۆچی بوو بە تاڵانی؟
\q1 
\v 15 بەچکە شێران بەسەریدا نەڕاندیان،
\q2 دەنگیان هات،
\q1 خاکەکەیان وێران کردووە،
\q2 شارۆچکەکانی سووتاون، بێ دانیشتووانن.
\q1 
\v 16 هەروەها نەوەی مەمفیس و تەحپەنحێس
\q2 تەپڵی سەری تۆیان تراشیووە.
\q1 
\v 17 ئایا تۆ ئەمەت بە خۆت نەکرد،
\q2 کە وازت لە یەزدانی پەروەردگارت هێنا
\q2 کاتێک بە ڕێگادا دەیبردیت؟
\q1 
\v 18 ئێستا بۆچی دەچیتە میسر
\q2 بۆ خواردنەوەی ئاوی نیل؟
\q1 ئێستا بۆچی دەچیتە ئاشور
\q2 بۆ خواردنەوەی ئاوی ڕووباری فورات؟
\q1 
\v 19 خراپەی خۆت تەمبێت دەکات و
\q2 هەڵگەڕانەوەت سەرزەنشتت دەکات.
\q1 جا بزانە و ببینە کە بۆتان خراپ و تاڵە،
\q2 کاتێک واز لە یەزدانی پەروەردگارت دەهێنیت و
\q2 ترسی منت لە دڵدا نییە،»
\q4 ئەوە فەرمایشتی یەزدانە، پەروەردگاری سوپاسالار.
\b
\q1 
\v 20 «تۆ لە کۆنەوە نیری\f + \fr 2:20 \ft مەبەستی لە ڕەتکردنەوەی ڕێنمایی و دەسەڵاتی خودایە.‏\f* خۆتت شکاندووە،
\q2 کۆتەکانت پساندووە،
\q2 گوتت: ”تۆ ناپەرستم!“
\q1 تۆ بە ڕاستی لەسەر هەموو گردێکی بەرز و
\q2 لەژێر هەموو دارێکی سەوزدا
\q2 وەک لەشفرۆشێک ڕاکشایت.
\q1 
\v 21 من وەک شامێوێک
\q2 لە نایابترین جۆر تۆم چاند،
\q1 ئیتر چۆن لێم گۆڕایت،
\q2 گۆڕایت بۆ زڕمێو؟
\q1 
\v 22 هەرچەندە بە سۆدەش خۆت بشۆیت،
\q2 زیاد سابوونیش لە خۆت بدەیت،
\q2 هێشتا لەکەی تاوانەکەت لەبەردەممە.»
\q4 ئەمە فەرمایشتی یەزدانی باڵادەستە.
\q1 
\v 23 «ئیتر چۆن دەڵێیت: ”گڵاو نەبووم،
\q2 دوای بەعلەکان نەکەوتووم؟“
\q1 تەماشای ڕێگاکەی خۆت بکە لە دۆڵەکە،
\q2 بزانە چیت کردووە.
\q2 تۆ وەک وشترە سووکەکەی کە لە ڕۆیشتندا بەلادادێی،
\q1 
\v 24 وەک کەرەکێوییەکەی کە فێری چۆڵەوانیت،
\q2 لەتاو هەوەسی با هەڵدەمژێت،
\q2 لە کاتی بەتەڵەب هاتنی کێ دەیگێڕێتەوە؟
\q1 هەموو ئەوانەی داوای دەکەن
\q2 بەبێ ماندووبوون لە کاتی زاوزێ دەیدۆزنەوە.
\q1 
\v 25 ئەوەندە مەگەڕێ تاوەکو ئەوەی پێیەکانت ڕووت بێتەوە و
\q2 گەرووت وشک بێت.
\q1 بەڵام گوتت: ”بێهوودەیە!
\q2 نا! چونکە خوداوەندە بێگانەکانم خۆشویستووە،
\q2 دوای ئەوان دەکەوم.“
\b
\q1 
\v 26 «وەک شەرمەزاری دز کە دەگیرێت،
\q2 ئاوا بنەماڵەی ئیسرائیل شەرمەزاربوون،
\q1 خۆیان و پاشا و میر و
\q2 کاهین و پێغەمبەرەکانیان.
\q1 
\v 27 هەریەکەیان بە دار دەڵێت: ”تۆ باوکی منیت“ و
\q2 بە بەرد: ”تۆ منت بووە.“
\q1 پشتیان تێ کردم
\q2 نەک ڕوو،
\q1 بەڵام لە کاتی بەڵایاندا دەڵێن:
\q2 ”هەستە و ڕزگارمان بکە!“
\q1 
\v 28 ئیتر کوا خوداوەندەکانت کە بۆ خۆت دروستت کردن؟
\q2 با هەستن، ئەگەر لە کاتی بەڵادا دەتوانن ڕزگارت بکەن!
\q1 ئەی یەهودا،
\q2 خوداوەندەکانت بەقەد ژمارەی شارۆچکەکانتن.»
\b
\q1 
\v 29 یەزدان دەفەرموێت: «بۆچی سکاڵام لێ دەکەن؟
\q2 هەمووتان لێم یاخی بوون،
\q1 
\v 30 بەخۆڕایی سزای منداڵەکانتانم دا،
\q2 تەمبێکردنیان وەرنەگرت،
\q1 شمشێرەکانتان پێغەمبەرەکانتانی خوارد،
\q2 وەک شێرێکی لەناوبەر.
\p 
\v 31 «ئەی نەوە، ئێوە ئاگاداری فەرمایشتی یەزدان بن:
\q1 «ئایا بۆ ئیسرائیل بووم بە چۆڵەوانی،
\q2 یان خاکی تاریک و تنۆک؟
\q1 بۆچی گەلەکەم دەڵێن: ”بەڕەڵا بووین،
\q2 ئیتر بۆ لات نایەینەوە؟“
\q1 
\v 32 ئایا کچ خشڵی خۆی لەبیر دەکات،
\q2 یان بووک جلی بووکێنی؟
\q1 بەڵام گەلەکەی خۆم ڕۆژانێکی بێشومار
\q2 منیان لەبیر کرد.
\q1 
\v 33 تۆ چەند لێزانیت لە گەڕان بەدوای خۆشەویستیدا!
\q1 تەنانەت سۆزانییەکانیشت فێری ڕێگای خۆت کرد.
\q1 
\v 34 هەروەها بە جلەکانتەوە دەبینرێت،
\q2 خوێنی گیانی نەدارە بێتاوانەکان،
\q1 هەرچەندە ئەوانت لە کاتی دیواربڕیندا نەگرت.
\q2 بەڵام لە سەرووی هەموو ئەمانەشەوە
\q1 
\v 35 دەڵێیت: ”من بێتاوانم،
\q2 خودا لە من تووڕە نییە.“
\q1 بەڵام دادگاییت دەکەم،
\q2 چونکە گوتت: ”گوناهم نەکرد.“
\q1 
\v 36 بۆچی زۆر دەگەڕێیت
\q2 بۆ گۆڕینی ڕێگاکانت؟
\q1 هەروەها لە میسریش شەرمەزار دەبیت،
\q2 وەک چۆن لە ئاشور شەرمەزار بوویت.
\q1 
\v 37 هەروەها میسر بەجێدەهێڵیت و
\q2 وەک دیل دەستەکانت بەسەر سەرتەوە\f + \fr 2:37 \ft نیشانەی شەرمەزاری.‏\f* دەبن،
\q1 چونکە ئەوانەی تۆ پشتیان پێ دەبەستیت یەزدان ڕەتیکردنەوە،
\q2 بەوان سەرکەوتوو نابیت.»
\b
\b
\c 3
\q1 
\v 1 «ئەگەر پیاو ژنی خۆی تەڵاق بدات و
\q2 ژنەکەی لەلای بڕوات و شوو بە پیاوێکی دیکە بکات،
\q1 ئایا کابرا جارێکی دیکە دەگەڕێتەوە لای ئەو ژنە؟
\q2 ئایا ئەو خاکە بە تەواوی گڵاو نابێت؟
\q1 بەڵام تۆ لەشی خۆتت بە زۆر دۆست فرۆشت،
\q2 ئایا ئێستا دەگەڕێیتەوە لام؟»
\q4 ئەوە فەرمایشتی یەزدانە.
\q1 
\v 2 «چاو هەڵبڕە بۆ گردۆڵکەکان و ببینە!
\q2 بزانە جێی ژووانێک هەیە کە لێی زەلیل نەکرابیت؟
\q1 وەک کۆچەر لە چۆڵەوانی
\q2 لەسەر ڕێگاکان بۆ خۆشەویستان دانیشتیت.
\q1 بە لەشفرۆشیت و بە خراپەت
\q2 خاکەکەت گڵاو کرد.
\q1 
\v 3 جا لێزمە باران ڕاوەستا و
\q2 بەهارە بارانیش نەبوو،
\q1 کەچی تۆ ناوچەوانی ژنە لەشفرۆشێکت هەبوو،
\q2 شەرم لەخۆکردنەوەت ڕەتکردەوە.
\q1 
\v 4 ئایا هەر ئێستا بانگت نەکردم،
\q2 ”باوکە! تۆ هاوڕێی گەنجیێتی منیت!
\q1 
\v 5 ئایا هەتاهەتایە تووڕە دەبیت؟
\q2 ئایا هەتا کۆتایی هەڵدەچیت؟“
\q1 بەم شێوەیە قسەت کرد،
\q2 بەڵام تۆ ئەو هەموو خراپەیەت کرد کە توانیت.»
\s1 ئیسرائیلی هەڵگەڕاوە
\p 
\v 6 لە سەردەمی پاشایەتی یۆشیای پاشادا یەزدان پێی فەرمووم: «ئایا بینیت ئیسرائیلی هەڵگەڕاوە چی کرد؟ چووە سەر هەموو گردێکی بەرز و ژێر هەموو دارێکی سەوز، لەوێ داوێنپیسی\f + \fr 3:6 \ft لێرەدا بە واتای داوێنپیسی جەستەیی و ڕۆحیش دێت. بەو کەسە دەگوترێت کە لاف لێدەدات بەوەفایە بۆ یەزدان، بەڵام لە هەمان کاتدا ستایش و قوربانی بۆ خودایەکی دیکە دەکات. واتا لە بنەڕەتدا کەسەکە بێوەفایە لەگەڵ یەزدان، هەروەک چۆن پیاوێک بێوەفا بێت لەگەڵ ژنەکەیدا.‏\f* کرد.
\v 7 بیرم کردەوە لەپاش ئەوەی هەموو ئەمەی کرد، بۆ لای من دەگەڕێتەوە، بەڵام نەگەڕایەوە. جا یەهودای خوشکی ناپاکی ئەمەی بینی.
\v 8 تەڵاقنامەم دا بە ئیسرائیلی هەڵگەڕاوە و ناردمەوە، لەبەر هەموو داوێنپیسییەکانی. کەچی بینیم یەهودای خوشکی ناپاکی نەترسا، جا ئەویش چوو و داوێنپیسی کرد.
\v 9 لەبەر ئەوەی بە سووکی سەیری لەشفرۆشییەکەی کرد، زەوی گڵاو کرد و داوێنپیسی لەگەڵ دار و بەردا کرد.
\v 10 لەگەڵ هەموو ئەوەشدا، یەهودای ناپاکی خوشکی بە هەموو دڵییەوە نەگەڕایەوە لام، بەڵکو تەنها بە ڕواڵەت.» ئەوە فەرمایشتی یەزدانە.
\p 
\v 11 ئینجا یەزدان پێی فەرمووم: «ئیسرائیلی هەڵگەڕاوە لە یەهودای ناپاک ڕاستودروستترە.
\v 12 بڕۆ، ئەو پەیامە بۆ باکوور ڕابگەیەنە، بڵێ:
\q1 «یەزدان دەفەرموێت: ”ئەی ئیسرائیلی هەڵگەڕاوە، بگەڕێوە،
\q2 ناوچەوانم لێتان گرژ ناکەم،
\q1 چونکە خۆشەویستییەکەم ناگۆڕێت.“ ئەوە فەرمایشتی یەزدانە.
\q2 ”تووڕەییم هەتاهەتایی نییە.
\q1 
\v 13 تەنها دان بە تاوانەکەتدا بنێی،
\q2 چونکە لە یەزدانی پەروەردگارت یاخی بوویت و
\q1 خۆشەویستیت بۆ خوداوەندە بێگانەکان بڵاوکردەوە
\q2 لەژێر هەموو دارێکی سەوز.
\q2 ئێوە گوێڕایەڵی من نەبوون.“»
\q4 ئەوە فەرمایشتی یەزدانە.
\p 
\v 14 یەزدان دەفەرموێت: «ئەی ڕۆڵە هەڵگەڕاوەکان، بگەڕێنەوە، چونکە من مێردی ئێوەم\f + \fr 3:14 \ft پەیوەندی نێوان خودا و گەلەکەی بە پەیوەندی نێوان ژن و مێرد دەچووێنرێت، لە ڕووی ئەرک و وەفا و گوێڕایەڵییەوە.‏\f*، دەتانبەم، یەکێک لە شارۆچکەیەک و دووان لە خێڵێک، دەتانهێنمە سییۆن.
\v 15 شوانتان بۆ دادەنێم بە دڵی خۆم بێت، بە زانین و وریاییەوە بتانلەوەڕێنن.»
\v 16 یەزدان دەفەرموێت: «لەو ڕۆژانەدا، کە لە خاکەکە زۆر دەبن و بەروبوومتان دەبێت، ئیتر ناڵێن: ”سندوقی پەیمانی یەزدان.“ بە مێشکیاندا نایەت و بەبیریان نایەتەوە، بەسەری ناکەنەوە و جارێکی دیکە دروستناکرێتەوە.
\v 17 لەو کاتەدا بە ئۆرشەلیم دەڵێن، ”تەختی یەزدان“ و هەموو نەتەوەکان لە ئۆرشەلیم کۆدەبنەوە بۆ ئەوەی ڕێز لە ناوی یەزدان بگرن. ئیتر بەدوای کەللەڕەقییە خراپەکەیان ناکەون.
\v 18 لەو ڕۆژانەدا بنەماڵەی یەهودا لەگەڵ بنەماڵەی ئیسرائیل دەڕۆن، بەیەکەوە لە خاکی باکوورەوە دێن بۆ ئەو خاکەی کە کردمە میرات بۆ باوباپیرانتان.
\p 
\v 19 «بەڵام من، یەزدانم، دەفەرمووم:
\q1 «”چەند دەمەوێ وەک کوڕانی خۆمتان دابنێم و
\q2 زەوییەکی ئارەزووبەخشتان بدەمێ،
\q2 جوانترین میراتی نەتەوەکان!“
\q1 وامدەزانی ئێوە بە ”باوکە“ بانگم دەکەن و
\q2 لە شوێنکەوتنی من لانادەن.
\q1 
\v 20 بەڵام وەک چۆن ژن ناپاکی لە هاوسەری خۆی دەکات،
\q2 ئەی بنەماڵەی ئیسرائیل، ئاوا ناپاکیتان لێکردم،»
\q4 ئەوە فەرمایشتی یەزدانە.
\b
\q1 
\v 21 دەنگێک لە گردۆڵکەکانەوە دەبیسترێت،
\q2 گریان و پاڕانەوەکانی نەوەی ئیسرائیلە،
\q1 چونکە ڕێگاکانی خۆیان خوارکردووە و
\q2 یەزدانی پەروەردگاریان لەبیر کردووە.
\b
\q1 
\v 22 «ئەی ڕۆڵە هەڵگەڕاوەکان، بگەڕێنەوە،
\q2 هەڵگەڕانەوەکانتان چاک دەکەمەوە.»
\b
\q1 «بەڵێ، دەگەڕێینەوە لات،
\q2 چونکە تۆ یەزدانیت، خودای ئێمەیت.
\q1 
\v 23 بێگومان بتپەرستی بە غەڵبەغەڵبەوە لەسەر چیا و گردەکان خۆهەڵخەڵەتاندنە،
\q2 بێگومان بە یەزدانی پەروەردگارمان ئیسرائیل ڕزگار دەبێت.
\q1 
\v 24 لە هەرزەکاریمانەوە بەعلی خوداوەندی شەرمەزاری
\q2 ڕەنجی باوباپیرانی ئێمەی خواردووە،
\q1 لە مەڕ و مانگا و
\q2 کوڕ و کچ.
\q1 
\v 25 با لەناو شورەیی خۆمان ڕابکشێین،
\q2 با شەرمەزاریمان دامانبپۆشێت،
\q1 چونکە ئێمە و باوباپیرانمان گوناهمان کرد
\q2 لە دژی یەزدانی پەروەردگارمان،
\q1 لە هەرزەکاریمانەوە هەتا ئەمڕۆش،
\q2 گوێڕایەڵی یەزدانی پەروەردگارمان نەبووین.»
\b
\c 4
\q1 
\v 1 یەزدان دەفەرموێت: «ئەی ئیسرائیل، ئەگەر گەڕایتەوە،
\q2 بگەڕێوە لای من.
\q1 ئەگەر بتە قێزەونەکانت لەبەردەمم لابدەی،
\q2 گومڕا نابیت،
\q1 
\v 2 ئەگەر بە ڕاستی و دادپەروەری و ڕاستودروستییەوە
\q2 سوێند بخۆیت: ”بە یەزدانی زیندوو،“
\q1 ئەوسا نەتەوەکان بەو بەرەکەتدار دەبن و
\q2 شانازی بەوەوە دەکەن.»
\p 
\v 3 یەزدان ئەمە بە پیاوەکانی یەهودا و ئۆرشەلیم دەفەرموێت:
\q1 «زەوی بەیارتان بکێڵن و
\q2 لەناو دڕکوداڵدا مەچێنن.
\q1 
\v 4 ئەی پیاوانی یەهودا و دانیشتووانی ئۆرشەلیم،
\q2 خۆتان بۆ یەزدان خەتەنە\f + \fr 4:4 \ft ‏مەبەستی لە تەرخانکردنی دڵە بۆ دڵسۆزی بەرامبەر بە یەزدان.‏\f* بکەن،
\q2 دڵتان خەتەنە بکەن،
\q1 نەوەک تووڕەییم بجۆشێت و وەک ئاگر بسووتێنێت،
\q2 لەبەر خراپی کردەوەکانتان،
\q2 بسووتێنێت و کەس ناتوانێت بیکوژێنێتەوە.»
\s1 بەڵایەک لە باکوورەوە
\q1 
\v 5 «لە یەهودا ڕایبگەیەنن، لە ئۆرشەلیم دەنگتان ببیسترێت، بڵێن:
\q2 ”لە خاکەکە فوو بە کەڕەنادا بکەن!“
\q1 بە دەنگی بەرز بانگەواز بکەن و بڵێن: ”کۆببنەوە!
\q2 با هەڵبێین بۆ شارە قەڵابەندەکان!“
\q1 
\v 6 ئاڵا بەرز بکەنەوە بۆ چوونە سییۆن!
\q2 خۆتان بدەنە پەنا! ڕامەوەستن!
\q1 چونکە من لە باکوورەوە بەڵا دەهێنم،
\q2 تێکشکانێکی گەورە.»
\b
\q1 
\v 7 شێر لە لانەکەیەوە هاتە دەرەوە،
\q2 تێکشکێنەری نەتەوەکان بەڕێکەوت.
\q1 لە شوێنەکەی خۆی هاتە دەرەوە
\q2 بۆ ئەوەی خاکەکەت وێران بکات.
\q1 شارۆچکەکانت کاول دەبن
\q2 بێ ئاوەدانی دەبن.
\q1 
\v 8 لەبەر ئەمە جلوبەرگی گوش\f + \fr 4:8 \ft لە کاتی ماتەمگێڕان و تۆبەکردندا جلوبەرگی لە گوش دروستکراویان لەبەرکردووە کە ئەزیەتی پێستیانی داوە.‏\f* لەبەر بکەن،
\q2 لە خۆتان بدەن و واوەیلا بکەن،
\q1 چونکە گڕی تووڕەیی یەزدان
\q2 هێشتا دانەمرکاوەتەوە.
\b
\q1 
\v 9 یەزدان دەفەرموێت: «جا ئەوە دەبێت لەو ڕۆژەدا،
\q2 پاشا و پیاوە گەورەکان جەرگبڕاو دەبن،
\q1 کاهینەکان دەحەپەسێن و
\q2 پێغەمبەرەکان واقیان وڕدەمێنێت.»
\p 
\v 10 جا گوتم: «ئای، ئەی یەزدانی باڵادەست، بێگومان ئەم گەلە و ئۆرشەلیمت بە تەواوی فریودا، فەرمووت: ”ئاشتیتان بۆ دەبێت،“ کەچی شمشێر گەیشتە گیانمان.»
\p 
\v 11 لەو کاتەدا بەم گەلە و بە ئۆرشەلیم دەگوترێت: «بای سووتێنەر لە گردۆڵکەکانی چۆڵەوانییەوە بەرەو گەلەکەم هەڵدەکات، نە بۆ شەن و نە بۆ جیاکردنەوە،
\v 12 بایەکی لەوە بەگوڕترە، لە منەوە دێت. ئێستاش من حوکمی خۆم بەسەریاندا ڕادەگەیەنم.»
\q1 
\v 13 تەماشا بکەن! وەک هەورەکان سەردەکەوێت،
\q2 گالیسکەکانی وەک گەردەلوولە،
\q1 ئەسپەکانی لە هەڵۆ تیژڕەوترن.
\q2 قوڕبەسەرمان، وێران کراین!
\q1 
\v 14 ئەی ئۆرشەلیم، دڵت لە خراپە بشۆوە بۆ ئەوەی ڕزگارت بێت.
\q2 هەتا کەی بیروڕا خراپەکانت لە ناوەڕاستت دەمێنێتەوە؟
\q1 
\v 15 دەنگێک لە دانەوە ڕادەگەیەنێت،
\q2 کارەسات لە شاخەکانی ئەفرایمەوە دەبیسترێت.
\q1 
\v 16 «نەتەوەکان ئاگادار بکەنەوە،
\q2 با خەڵکی ئۆرشەلیم بیبیستن:
\q1 ”ئابڵوقەدەران لە خاکێکی دوورەوە دێن،
\q2 بەسەر شارەکانی یەهودا دەنگیان بەرز دەکەنەوە.
\q1 
\v 17 لە چواردەوری وەک پاسەوانانی کێڵگەیان لێهاتووە،
\q2 چونکە لە من یاخی بوون.“»
\q4 ئەوە فەرمایشتی یەزدانە.
\q1 
\v 18 «ڕەفتار و کردەوەکانت
\q2 ئەمەیان پێکردیت،
\q1 ئەمە سزاکەتە،
\q2 چەند تاڵە!
\q2 چونکە گەیشتە دڵت.»
\b
\q1 
\v 19 ئەی ئازارم، ئەی ئازارم!
\q2 من لەتاو ئێشم دەتوێمەوە.
\q1 دڵم ژان دەکات!
\q2 دڵەکوتێمە، بێدەنگ نابم،
\q2 چونکە گوێم لە دەنگی کەڕەنا و نەعرەتەی جەنگ بوو.
\q1 
\v 20 کارەسات لەدوای کارەسات دێت،
\q2 هەموو خاکەکە وێران بوو.
\q1 لەپڕ خێوەتەکانم وێران بوون،
\q2 لە چرکەیەکدا پەناگاکانم.
\q1 
\v 21 هەتا کەی ئاڵای جەنگ دەبینم و
\q2 گوێم لە دەنگی کەڕەنا دەبێت؟
\b
\q1 
\v 22 «گەلەکەم گێلە و
\q2 من ناناسێت.
\q1 ئەوان کوڕی دەبەنگن،
\q2 ئەوان تێنەگەیشتوون،
\q1 ئەوان دانان بۆ کاری خراپە،
\q2 بەڵام نازانن چۆن چاکە بکەن.»
\b
\q1 
\v 23 تەماشای زەویم کرد،
\q2 بێ شێوە و بەتاڵ بوو،
\q1 بەرەو ئاسمانیش،
\q2 ڕووناکییەکەی نەمابوو.
\q1 
\v 24 تەماشای چیاکانم کرد دەهەژان،
\q2 هەموو گردەکانیش لەق بوون.
\q1 
\v 25 تەماشام کرد، هیچ کەسێک دیار نەبوو،
\q2 باڵندەکانی ئاسمانیش هەموو هەڵاتبوون،
\q1 
\v 26 تەماشام کرد، باخەکان چۆڵەوانین و
\q2 هەموو شارۆچکەکانی کاول بوون
\q2 لەبەردەم یەزدان، لە ڕووی گڕی تووڕەییەکەی.
\p 
\v 27 سەبارەت بەمەش یەزدان بەم جۆرە دەفەرموێت:
\q1 «هەموو زەوی وێران دەبێت،
\q2 بەڵام بە تەواوی کۆتایی پێ ناهێنم.
\q1 
\v 28 لەبەر ئەمە زەوی شیوەن دەگێڕێت،
\q2 ئاسمانیش لە سەرەوە تاریک دادێت،
\q1 لەبەر ئەوەی من قسەم کرد و پاشگەز نەبوومەوە،
\q2 بڕیارم دا و بڕیارەکەم ناگۆڕم.»
\b
\q1 
\v 29 لە دەنگی سوار و تیرهاوێژ
\q2 هەموو شارۆچکەکان ڕایانکرد.
\q1 هەندێک چوونە ناو دارستانەکان،
\q2 هەندێک سەرکەوتنە سەر بەردەکان.
\q1 هەموو شارۆچکەکان بەجێهێڵراون،
\q2 هیچ کەسێک تێیاندا نیشتەجێ نییە.
\b
\q1 
\v 30 تۆش ئەی نەتەوە وێرانەکە، چی دەکەیت؟
\q2 بۆچی بەرگی ئاڵ لەبەر دەکەیت و
\q2 خشڵی زێڕ بە خۆتەوە دەکەیت؟
\q1 بۆچی بە کل چاوەکانت ڕەش دەکەیت؟
\q2 بێهوودە خۆت جوان دەکەیت،
\q1 لەبەرچاوی ئەوینداران کەوتووی،
\q2 ئەوان داوای گیانت دەکەن.
\b
\q1 
\v 31 هاوارێکم بیست وەک هاواری ژنێکی ژانگرتوو بوو،
\q2 لە ناخۆشیدا وەک یەکەم منداڵی بێت.
\q1 دەنگی سییۆنی کچ\f + \fr 4:31 \ft دەربڕینێکی خوازەیە بۆ پایتەخت، مەبەست لە هەموو دانیشتووانی شارەکەیە.‏\f* هەنسک دەدات،
\q2 دەست پان دەکاتەوە، دەڵێت:
\q1 «وەی لە من! دەبوورێمەوە،
\q2 گیانم لەبەر بکوژان دەردەچێت!»
\c 5
\s1 کەس ڕاستودروست نییە
\q1 
\v 1 «بەناو شەقامەکانی ئۆرشەلیمدا هاتوچۆ بکەن،
\q2 ئێستا تەماشا بکەن و بزانن،
\q2 لەناو گۆڕەپانەکانی بگەڕێن.
\q1 ئەگەر یەکێکتان بینییەوە
\q2 دادپەروەر بێت و بەدوای ڕاستیدا بگەڕێت،
\q2 ئەوا من لەم شارە خۆشدەبم.
\q1 
\v 2 هەرچەندە دەڵێن: ”بە یەزدانی زیندوو،“
\q2 هێشتا بە درۆ سوێند دەخۆن.»
\b
\q1 
\v 3 ئەی یەزدان، ئایا چاوت بەدوای ڕاستیدا ناگەڕێت؟
\q2 لێت دان بەڵام ئازاریان پێ نەگەیشت،
\q2 تێکت شکاندن بەڵام ڕەتیانکردەوە تەمبێ بکرێن.
\q1 ڕووی خۆیان لە بەرد ڕەقتر کرد،
\q2 تۆبەکردنیان ڕەتکردەوە.
\q1 
\v 4 بەڵام من گوتم: «ئەوانە هەژارن،
\q2 نەزان بوون،
\q1 چونکە ڕێگای یەزدان ناناسن و
\q2 نازانن خودا داوای چییان لێ دەکات.
\q1 
\v 5 کەواتە دەچمە لای گەورە پیاوان و
\q2 قسەیان لەگەڵ دەکەم،
\q1 بێگومان ئەوان ڕێگای یەزدان دەناسن و
\q2 دەزانن خودا داوای چییان لێ دەکات.»
\q1 بەڵام ئەوان پێکەوە نیریان شکاند،
\q2 بەندیان پساند.
\q1 
\v 6 لەبەر ئەوە لە دارستان شێر هێرشیان دەکاتە سەر،
\q2 گورگی بیابان دەیانفەوتێنێت،
\q1 پڵنگ لە دەوری شارۆچکەکانیان خۆی مات دەدات،
\q2 تاکو ئەوەی لێی بێتە دەرەوە پارچەپارچەی بکات،
\q1 چونکە یاخیبوونەکانیان زۆربوون،
\q2 هەڵگەڕانەوەکانیان گەورە بوون.
\b
\q1 
\v 7 «بۆچی دەبێت لێت خۆشبم؟
\q2 کوڕەکانت وازیان لێ هێنام و
\q2 سوێند بەوە دەخۆن کە خودا نییە.
\q1 کە تێرم کردن، داوێنپیسییان کرد،
\q2 پاڵەپەستۆیانە بۆ ماڵی لەشفرۆش.
\q1 
\v 8 بوون بە ئەسپی خورت و بە عیتە،
\q2 هەریەکە بەسەر ژنی برادەرەکەیدا دەحیلێنێت.
\q1 
\v 9 ئایا لەسەر ئەمە سزایان نەدەم؟
\q2 ئایا من تۆڵە لە نەتەوەیەکی وەک ئەمە نەستێنمەوە؟»
\q4 ئەوە فەرمایشتی یەزدانە.
\b
\q1 
\v 10 «سەربکەونە سەر پەرژینی ڕەزەمێوەکان و تێکیان بدەن،
\q2 بەڵام بە تەواوی مەیفەوتێنن.
\q1 لقەکانی لێ بکەنەوە،
\q2 چونکە هی یەزدان نین.
\q1 
\v 11 بنەماڵەی ئیسرائیل و بنەماڵەی یەهودا
\q2 بە تەواوی ناپاکییان لێکردم.»
\q4 ئەوە فەرمایشتی یەزدانە.
\b
\q1 
\v 12 درۆیان بە دەمی یەزدانەوە کرد،
\q2 گوتیان، «ئەو هیچ ناکات!
\q1 بەڵامان بەسەرنایەت،
\q2 شمشێر و قاتوقڕی نابینین.
\q1 
\v 13 پێغەمبەرەکان بوون بە هاژەی با،
\q2 وشەکە لەواندا نییە،
\q2 ئەوەی گوتیان بەسەریان دەهێنرێت.»
\p 
\v 14 لەبەر ئەوە یەزدانی پەروەردگاری سوپاسالار، ئەمە دەفەرموێت:
\q1 «لەبەر ئەوەی ئەم گەلە ئەو قسانەیان کرد،
\q2 ئەوەتا من وتەکانم لە دەمی تۆدا دەکەمە ئاگر،
\q2 ئەم گەلەش دەکەم بە دار و دەیانخوات.»
\q1 
\v 15 یەزدان دەفەرموێت: «ئەی بنەماڵەی ئیسرائیل،
\q2 ئەوەتا من نەتەوەیەک لە دوورەوە دەهێنمە سەرتان،
\q2 نەتەوەیەکی پتەو و دێرینە،
\q1 نەتەوەیەکە زمانەکەیان نازانن،
\q2 لە قسەکردنیان تێناگەن.
\q1 
\v 16 تیردانەکەی وەک گۆڕی دەم کراوەیە،
\q2 هەموو پاڵەوانن.
\q1 
\v 17 دروێنە و نانت دەخوات،
\q2 کوڕ و کچت دەخوات،
\q1 مەڕ و مانگات دەخوات،
\q2 مێو و هەنجیرت دەخوات.
\q1 شارە قەڵابەندەکانت کە تۆ پشتت پێ بەستوون،
\q2 بە شمشێر دەفەوتێنێت.»
\p 
\v 18 یەزدان دەفەرموێت: «هەروەها لەو ڕۆژانەدا، کۆتاییتان پێ ناهێنم.
\v 19 جا کە دەڵێن: ”لەبەر چی یەزدانی پەروەردگارمان هەموو ئەمەی پێکردین؟“ پێیان دەڵێیت: ”لەبەر ئەوەی وازتان لێ هێنام و لە خاکەکەتان خوداوەندە بێگانەکانتان پەرست، ئاوا دەبێت بێگانە پەرستی بکەن لە خاکێک کە هی ئێوە نییە.\f + \fr 5:19 \ft وەک سزایەک خزمەتی بێگانەکان دەکەن و خوداوەندەکانی ئەوان دەپەرستن.‏\f*“
\q1 
\v 20 «ئەمە بە بنەماڵەی یاقوب ڕابگەیەنن و
\q2 با لەناو یەهودا ببیسترێت، بڵێن:
\q1 
\v 21 ئەی گەلی گێل و بێ مێشک، ئێستا گوێ لەمە بگرن،
\q2 ئەی ئەوانەی چاوتان هەیە و نابینن،
\q2 گوێتان هەیە و نابیستن:
\q2 
\v 22 ئایا لە من ناترسن؟»
\q1 هەروەها یەزدان دەفەرموێت:
\q2 «ئایا لەبەردەمی من نالەرزن؟
\q1 من کە لمم بۆ دەریا کرد بە سنوور،
\q2 بەربەستێکی هەتاهەتاییە و لێی تێناپەڕێت.
\q1 شەپۆل خۆی پێدا دەدات و سەرکەوتوو نابێت،
\q2 هاژەی دێت و تێناپەڕێت.
\q1 
\v 23 بەڵام ئەم گەلە دڵێکی منجڕ و یاخی هەیە،
\q2 لەڕێ لایاندا و ڕۆیشتن.
\q1 
\v 24 لە دڵی خۆیاندا ناڵێن،
\q2 ”ئێستا با لە یەزدانی پەروەردگارمان بترسین،
\q1 ئەوەی باران دەبارێنێت، یەکەم باران و دوا باران لە وەرزی خۆی،
\q2 لە هەفتە دیاریکراوەکانی دروێنە دڵنیامان دەکاتەوە.“
\q1 
\v 25 تاوانەکانتان ڕێگرییان لەم بەرەکەتانە کرد،
\q2 گوناهەکانتان لە چاکە بێبەشی کردن.
\b
\q1 
\v 26 «بەدکاران لەنێو گەلەکەمدا دەبینرێنەوە،
\q2 وەک ڕاوچی خۆیان ماتداوە و چاو دەگێڕن،
\q2 تەڵە دەنێنەوە و مرۆڤ دەگرن.
\q1 
\v 27 وەک قەفەزی پڕ لە باڵدار،
\q2 ماڵەکانیان پڕە لە فێڵ،
\q1 لەبەر ئەمە گەورە و دەوڵەمەند بوون،
\q2 
\v 28 قەڵەو و تێر بوون.
\q1 هەروەها لە خراپەکاریدا بێ سنوورن،
\q2 پارێزەرایەتییان بۆ سکاڵای هەتیو نەکرد هەتا سەرکەوتوو بن،
\q2 بەرگرییان لە مافی هەژاران نەکرد.
\q1 
\v 29 ئایا لەسەر ئەمە سزایان نەدەم؟
\q2 ئایا من تۆڵە لە نەتەوەیەکی وەک ئەمە نەستێنمەوە؟»
\q4 ئەوە فەرمایشتی یەزدانە.
\b
\q1 
\v 30 «تۆقین و سەرسوڕماویێک
\q2 لە خاکەکەدا ڕوویدا:
\q1 
\v 31 پێغەمبەرەکان بە درۆ پێشبینی دەکەن،
\q2 کاهینەکانیش بە ویستی خۆیان فەرمانڕەوایەتی دەکەن،
\q1 گەلەکەشم حەزیان لەم دۆخەیە.
\q2 بەڵام لە کۆتاییەکەیدا ئێوە چی دەکەن؟
\c 6
\s1 گەمارۆی ئۆرشەلیم
\q1 
\v 1 «ئەی نەوەی بنیامین،
\q2 لە ئۆرشەلیم هەڵبێن!
\q1 لە تەقۆعە فوو بە کەڕەنادا بکەن!
\q2 لەسەر بێت‌هاکارەم ئاگر وەک نیشانە هەڵبکەن!
\q1 چونکە بەڵا و شکستێکی گەورە
\q2 لە باکوورەوە دەرکەوتووە.
\q1 
\v 2 من سییۆنی کچ\f + \fr 6:2 \ft ئۆرشەلیم.‏\f* لەناو دەبەم،
\q2 کچە جوان و نازدارەکە.
\q1 
\v 3 شوانەکان بە مێگەلەکانیانەوە\f + \fr 6:3 \ft مەبەستی لە پاشا و لەشکرەکانیانە.‏\f* بۆ لای ئەو دێن،
\q2 ڕەشماڵەکان لە دەوری هەڵدەدەن و
\q2 هەرکەسە لە بەشی خۆی دەلەوەڕێنێ.»
\b
\q1 
\v 4 «جەنگێک لە دژی سییۆن ئامادە بکەن!
\q2 هەستن بە نیوەڕۆ هێرش ببەین!
\q1 بەڵام بە داخەوە، ڕۆژ ئاوا بوو،
\q2 سێبەرەکانی ئێوارە درێژبوونەوە.
\q1 
\v 5 کەواتە هەستن بە شەو هێرش ببەین،
\q2 قەڵاکانی وێران بکەین!»
\p 
\v 6 یەزدانی سوپاسالار ئەمە دەفەرموێت:
\q1 «دار ببڕنەوە و
\q2 مەتەرێز لە دەوری ئۆرشەلیمەوە دابڕێژن.
\q1 دەبێت ئەو شارە سزا بدرێت،
\q2 چونکە سەراپای پڕ ستەمە.
\q1 
\v 7 وەک کانییەک ئاوەکەی هەڵبقوڵێت،
\q2 ئاوا خراپییەکەی هەڵدەقوڵێت.
\q1 توندوتیژی و ڕفاندنی تێدا دەبیسترێت،
\q2 هەمیشە لەبەردەمم نەخۆشی و برینداری هەیە.
\q1 
\v 8 ئەی ئۆرشەلیم، ئاگاداربە،
\q2 نەوەک پشتم لە تۆ بکەم،
\q1 نەوەک بتکەمە خاکێکی وێران،
\q2 ئیتر کەسی تێدا نیشتەجێ نەبێ.»
\p 
\v 9 یەزدانی سوپاسالار ئەمە دەفەرموێت:
\q1 «با پاشماوەی ئیسرائیل بە تەواوی بچنرێنەوە،
\q2 بە تەواوی وەک ڕەزەمێو،
\q1 با دەستت بەسەر لقەکاندا بگێڕیت،
\q2 وەک کەسێک ترێ دەچنێتەوە.»
\b
\q1 
\v 10 بۆ کێ قسە بکەم؟ کێ ئاگادار بکەمەوە؟
\q2 کێ گوێم لێ دەگرێت؟
\q1 ئەوەتا گوێیان داخراوە
\q2 بۆ ئەوەی نەتوانن گوێ شل بکەن.
\q1 فەرمایشتی یەزدان بۆیان بووە بە ڕیسوایی،
\q2 دڵیان پێی خۆش نییە.
\q1 
\v 11 لەبەر ئەوە پڕبووم لە تووڕەیی یەزدان،
\q2 بێزاربووم لە دەستپێوەگرتنی.
\b
\q1 ئینجا یەزدان پێی فەرمووم:
\q1 «تووڕەییەکەم بەسەر منداڵانی کۆڵاندا هەڵبڕێژە
\q2 بەسەر تێکڕای کۆڕی گەنجان،
\q1 ژن لەگەڵ مێرد دەبردرێت،
\q2 پیر لەگەڵ بەساڵاچووان.
\q1 
\v 12 ماڵەکانیان بۆ خەڵکی دیکە دەبن،
\q2 کێڵگە و ژنەکانیان پێکەوە،
\q1 چونکە دەستم بۆ سەر دانیشتووانی خاکەکە
\q2 درێژ دەکەم.»
\q4 ئەوە فەرمایشتی یەزدانە.
\q1 
\v 13 «لە بچووکیان هەتا گەورەیان،
\q2 هەموویان پەرۆشی قازانجن،
\q1 لە پێغەمبەرەوە هەتا کاهین،
\q2 هەموو ساختە دەکەن.
\q1 
\v 14 برینی گەلەکەم بە سووکیەوە چاک دەکەنەوە و
\q2 دەڵێن: ”ئاشتی، ئاشتی!“
\q2 بەڵام ئاشتی نییە.
\q1 
\v 15 ئایا شەرمەزار بوون کاتێک کاری قێزەونیان کرد؟
\q2 نەخێر! شەرمەزار نەبوون،
\q2 هەروەها نەیانزانی شەرمەزاری چییە.
\q1 لەبەر ئەوە دەکەونە ناو کوژراوان،
\q2 لە کاتی سزادانیان تێکدەشکێن.»
\q4 ئەوە فەرمایشتی یەزدانە.
\p 
\v 16 یەزدان ئەمە دەفەرموێت:
\q1 «لەسەر ڕێگاکان بوەستن و تەماشا بکەن،
\q2 پرسیاری ڕێچکە کۆنەکان بکەن،
\q1 ڕێگا چاکەکە لەکوێیە، پێیدا بڕۆن،
\q2 حەسانەوە بۆ دەروونتان دەدۆزنەوە.
\q2 بەڵام گوتتان: ”پێیدا ناڕۆین.“
\q1 
\v 17 چاودێرم بەسەرتانەوە دانا، گوتم:
\q2 ”گوێ بۆ دەنگی کەڕەنا شل بکەن!“
\q2 بەڵام گوتتان: ”گوێ شل ناکەین.“
\q1 
\v 18 لەبەر ئەوە ئەی نەتەوەکان، گوێ بگرن،
\q2 ئەی شایەتەکان، بزانن چییان بەسەردێت.
\q1 
\v 19 ئەی زەوی، گوێ بگرە:
\q1 ئەوەتا من بەڵا بەسەر ئەم گەلەدا دەهێنم،
\q2 بەروبوومی بیرکردنەوەکانیانە،
\q1 چونکە گوێیان بۆ وشەکانم شل نەکرد و
\q1 فێرکردنی منیان ڕەتکردەوە.
\q1 
\v 20 بەلامەوە گرنگ نییە، بخوور لە شەباوە بێت و
\q2 قامیشی بۆنخۆش لە خاکێکی دوورەوە؟
\q1 قوربانی سووتاندنەکانتان قبوڵ نین و
\q2 قوربانییە سەربڕدراوەکانتان لەلای من خۆش نین.»
\p 
\v 21 لەبەر ئەوە یەزدان ئەمە دەفەرموێت:
\q1 «من کۆسپ بۆ ئەم گەلە دادەنێم،
\q2 باوکان و کوڕان پێکەوە ساتمەی لێ دەکەن،
\q2 دراوسێ و هاوڕێ لەناودەچن.»
\p 
\v 22 یەزدان ئەمە دەفەرموێت:
\q1 «ئەوەتا! سوپایەک لە خاکی باکوورەوە دێت،
\q2 نەتەوەیەکی مەزن لەوپەڕی زەوییەوە هەڵدەستێنرێت.
\q1 
\v 23 کەوان و ڕمیان بە دەستەوەیە،
\q2 دڵڕەقن و بەزەییان نییە،
\q1 دەنگیان وەک دەریا هاژەی دێت و
\q2 سواری ئەسپ دەبن،
\q1 وەک یەک پیاو ڕیز دەبەستن
\q2 بۆ هێرشکردنە سەر تۆ، ئەی سییۆنی کچ.»
\b
\q1 
\v 24 هەواڵی ئەوانمان بیست،
\q2 ورەمان ڕووخا،
\q1 تووشی تەنگانە بووین،
\q2 تووشی ئازار بووین وەک ئازاری ژنی ژانگرتوو.
\q1 
\v 25 دەرمەچن بۆ کێڵگە!
\q2 بە ڕێگادا مەڕۆن!
\q1 چونکە دوژمن شمشێری پێیە،
\q2 لە هەموو لایەکەوە ترس و تۆقین هەیە.
\q1 
\v 26 ئەی گەلەکەم، جلوبەرگی گوش بپۆشە،
\q2 خۆت لە خۆڵەمێش بگەوزێنە،
\q1 شینی تاقانەیەک بۆ خۆت بگێڕە، بە لاوانەوەیەکی تاڵ،
\q2 چونکە لەناکاو تێکدەر بەسەرماندا دەدات.
\b
\q1 
\v 27 «ئەی یەرمیا، تۆم لەنێو گەلەکەم دانا،
\q2 وەک تاقیکەرەوە و سەنگی مەحەک،
\q1 بۆ ئەوەی ڕەفتاریان بزانیت و
\q2 تاقییان بکەیتەوە.
\q1 
\v 28 هەموو یاخی و کەللەڕەقن،
\q2 بە پەلەن بۆ بوختانکردن،
\q1 ئەوان بڕۆنز و ئاسنن،
\q2 هەموو تێکدەرن.
\q1 
\v 29 مووشەی دێت مووشەدەمە\f + \fr 6:29 \ft ئامرازێکە بۆ فووکردنی هەوا بۆ گەرمکردنی ئاگر بەکاردێت.‏\f*
\q2 بۆ ئەوەی بە ئاگر قورقوشم بفەوتێنێت،
\q1 بەڵام بێهوودە زێڕنگەر بێگەردی دەکات،
\q2 بەدکاران بێگەرد نابن.
\q1 
\v 30 پێیان دەگوترێت زیوی ناپەسەند،
\q2 چونکە یەزدان پەسەندی نەکردوون.»
\c 7
\s1 پشتبەستن بە قسەی هەڵخەڵەتێنەر
\p 
\v 1 ئەمە ئەو پەیامەیە کە لەلایەن یەزدانەوە بۆ یەرمیا هات:
\v 2 «لەناو دەروازەی ماڵی یەزدان بوەستە و لەوێ ئەم پەیامە ڕابگەیەنە و بڵێ:
\p «”گوێ لە فەرمایشتی یەزدان بگرن، ئەی هەموو گەلی یەهودا، ئەوانەی لەم دەرگایە بۆ کڕنۆش بردن بۆ یەزدان دێنە ژوورەوە.
\v 3 یەزدانی سوپاسالار، خودای ئیسرائیل ئەمە دەفەرموێت: ڕێگا و کردەوەکانتان چاک بکەنەوە و منیش لەم شوێنەدا نیشتەجێتان دەکەم.
\v 4 پشت بەم قسە هەڵخەڵەتێنەرە مەبەستن، بڵێن: ’ئەمە پەرستگای یەزدانە، پەرستگای یەزدانە، پەرستگای یەزدانە!‘
\v 5 چونکە ئەگەر بە تەواوی ڕێگا و کردەوەکانی خۆتان چاککردەوە، ئەگەر لەنێو خۆتان بە تەواوی دادپەروەری پەیڕەو بکەن،
\v 6 ئەگەر ستەم لە نامۆ و هەتیو و بێوەژن نەکەن، لەم شوێنەدا خوێنی بێتاوان نەڕێژن، ئەگەر دوای خوداکانی دیکە نەکەون کە بۆ خراپەی خۆتانە،
\v 7 ئەوا من لەم شوێنەدا نیشتەجێتان دەکەم، لەو خاکەی لە ئەزەلەوە و بۆ هەتاهەتایە بە باوباپیرانتانم داوە.
\v 8 بەڵام ئێوە پشتتان بە قسەی هەڵخەڵەتێنەر بەستووە کە بێ سوودە.
\p 
\v 9 «”ئایا وا دەزانن دەتوانن بدزن، بکوژن، داوێنپیسی بکەن، سوێند بە درۆ بخۆن، بخوور بۆ بەعل بسووتێنن و دوای خوداکانی دیکە بکەون کە نایانناسن،
\v 10 ئینجا بێن و لەبەردەمم لەم ماڵە بوەستن کە ناوی منی هەڵگرتووە و بڵێن: ’ئێمە پارێزراوین.‘ ئایا پارێزراون بۆ ئەوەی بەردەوام بن لە ئەنجامدانی ئەم هەموو کارە قێزەونانە؟
\v 11 ئایا ئەم ماڵەی ناوی منی هەڵگرتووە، لەبەرچاوی ئێوە بووە بە ئەشکەوتی دزان؟ ئەوەتا خۆم بینیومە.“ ئەوە فەرمایشتی یەزدانە.
\p 
\v 12 «یەزدان دەفەرموێت: ”ئێستا بڕۆنە شوێنەکەم کە لە شیلۆیە، ئەوەی سەرەتا ناوی خۆمم لەوێ نیشتەجێ کرد، ببینن لەبەر خراپەی ئیسرائیلی گەلی خۆم چیم لێکردووە.
\v 13 ئێستاش لەبەر ئەوەی ئێوە ئەم کردەوانەتان کردووە، من پێشوەخت چەند جارێک قسەم لەگەڵتان کرد، بەڵام گوێتان نەگرت. بانگم کردن، بەڵام وەڵامتان نەدایەوە.
\v 14 لەبەر ئەوە، چیم بە شیلۆم کرد،\f + \fr 7:14 \ft ئاسەوارناسان ئاشکرایان کردووە کە شیلۆ نزیکەی لە ساڵی 1050 پ. ز. بە دەستی فەلەستییەکان وێران کراوە. بڕوانە \xt زەبوورەکان 78‏:60‏-61.‏\xt*\ft ‏\f* ئاوا بەو پەرستگایە دەکەم کە ناوی منی هەڵگرتووە کە ئێوە پشتتان پێی بەستووە، ئەو شوێنەی دامە ئێوە و باوباپیرانتان.
\v 15 لەبەردەمم دەرتاندەکەم، وەک چۆن براکانتانم دەرکرد، هەموو نەوەی ئەفرایم.“
\p 
\v 16 «تۆش نزا بۆ ئەم گەلە مەکە، لەبەر ئەوان نوێژ و نزا بەرز مەکەوە و لێم مەپاڕێوە، چونکە گوێت لێ ناگرم.
\v 17 ئایا نابینیت لە شارۆچکەکانی یەهودا و لە شەقامەکانی ئۆرشەلیم چی دەکەن؟
\v 18 منداڵان دار کۆدەکەنەوە، باوکان ئاگر دەکەنەوە و ژنان هەویر دەشێلن، بۆ ئەوەی کولێرە بۆ شاژنی\f + \fr 7:18 \ft ئەمە ناوە بابلییەکەی عەشتارە.‏\f* ئاسمان دروست بکەن. شەرابی پێشکەشکراو بۆ خوداکانی دیکە دەڕێژن بۆ ئەوەی پەستم بکەن.
\v 19 بەڵام ئایا ئەم پەستکردنە لە دژی منە؟ ئایا زیان بە خۆیان ناگەیەنن، بۆ شەرمەزاری ڕووی خۆیان؟ ئەوە فەرمایشتی یەزدانە.
\p 
\v 20 «”لەبەر ئەوە یەزدانی باڵادەست ئەمە دەفەرموێت: ئەوەتا تووڕەیی و هەڵچوونی من بەسەر ئەم شوێنەدا هەڵدەڕژێت، بەسەر مرۆڤ و ئاژەڵ و درەختی کێڵگە و بەروبوومی زەوی، گڕ دەگرێت و ناکوژێتەوە.
\p 
\v 21 «”یەزدانی سوپاسالار، خودای ئیسرائیل ئەمە دەفەرموێت: قوربانی سووتاندنەکانتان بخەنە سەر قوربانییە سەربڕدراوەکانتان و فەرموون گۆشت بخۆن،
\v 22 چونکە کاتێک لە خاکی میسرەوە باوباپیرانی ئێوەم دەرهێنا لەگەڵیان دوام، تەنها سەبارەت بە قوربانی سووتاندن و سەربڕاو فەرمانم پێ نەکردن،
\v 23 بەڵکو فەرمانی ئەم شتەم پێ کردن و فەرمووم: ’گوێم لێ بگرن، من دەبم بە خودای ئێوە و ئێوەش دەبن بە گەلی من، بە هەموو ئەو ڕێگایەدا دەڕۆن کە فەرمانتان پێ دەکەم بۆ ئەوەی بۆتان چاک بێت.‘
\v 24 بەڵام گوێیان نەگرت و گوێیان شل نەکرد، بەڵکو بە ڕاوێژ و کەللەڕەقییە خراپەکەی خۆیان ڕێگایان گرتەبەر، جا دواکەوتن و پێش نەکەوتن.
\v 25 لەو ڕۆژەوە کە باوباپیرانتان خاکی میسریان بەجێهێشت هەتا ئەمڕۆ، من بەردەوام یەک لەدوای یەک بەندە پێغەمبەرەکانی خۆمم بۆ ناردوون.
\v 26 بەڵام گوێیان لێ نەگرتم و گوێیان شل نەکرد و کەللەڕەقییان کرد، لە باوباپیرانیان زیاتر خراپەیان کرد.“
\p 
\v 27 «جا تۆش بە هەموو ئەم پەیامە لەگەڵیان دەدوێیت، گوێت لێ ناگرن، بانگیان دەکەیت، وەڵامت نادەنەوە.
\v 28 لەبەر ئەوە پێیان دەڵێیت: ”ئەمە ئەو نەتەوەیەیە کە گوێیان لە یەزدانی پەروەردگاریان نەگرت و تەمبێ نەبوون، ڕاستی نەماوە، لە دەمیان بڕاوەتەوە.
\v 29 قژت ببڕە و فڕێیبدە، لەسەر گردۆڵکەکان شیوەن بگێڕە، چونکە یەزدان ڕەتی کردووەتەوە و وازی لەم نەوەیە هێناوە کە تووڕەییەکەی لەسەریەتی.“
\s1 دۆڵی کوشتن
\p 
\v 30 «یەزدان دەفەرموێت: ”نەوەی یەهودا لەبەرچاوم خراپەیان کردووە، بتە قێزەونەکانیان لەناو ئەو ماڵە دانا کە ناوی منی هەڵگرتووە، بەمە گڵاوییان کرد.
\v 31 هەروەها نزرگەکانیان لەسەر بەرزاییەکانی تۆفەت بنیاد ناوە، ئەوەی لە دۆڵی بەن‌هینۆمە بۆ سووتاندنی کوڕەکانیان و کچەکانیان بە ئاگر کە من نە فەرمانم پێکردووە و نە بەخەیاڵمدا هاتبوو.
\v 32 یەزدان دەفەرموێت: لەبەر ئەوە، ئاگاداربن! سەردەمێک دێت ئیتر پێی ناگوترێ تۆفەت یان دۆڵی بەن‌هینۆم، بەڵکو دۆڵی کوشتن، چونکە لە تۆفەت دەنێژرێن هەتا شوێنی نامێنێت.
\v 33 تەرمی ئەم گەلە دەبێتە خۆراکی باڵندە و ئاژەڵی کێوی، کەسیش نییە بیانڕەوێنێتەوە.
\v 34 دەنگی شادی و دەنگی خۆشی، دەنگی زاوا و دەنگی بووک، لە شارۆچکەکانی یەهودا و لە شەقامەکانی ئۆرشەلیم ناهێڵم، چونکە خاکەکە وێران دەبێت.“
\c 8
\p 
\v 1 «یەزدان دەفەرموێت: ”لەو کاتەدا، ئێسکی پاشا و پیاوە گەورەکانی یەهودا، ئێسکی کاهین و پێغەمبەران، ئێسکی دانیشتووانی ئۆرشەلیم لە گۆڕەکانیان دەردەهێنن.
\v 2 بۆ خۆر و مانگ و هەموو ئەستێرەکانی ئاسمان دەریدەخەن، ئەوانەی خۆشیان ویستن و ئەوانەی پەرستنیان و دوایان کەوتن و ڕاوێژیان پێ کردن و کڕنۆشیان بۆ بردن. کۆناکرێنەوە و نانێژرێن، بەڵکو دەبنە زبڵ بەسەر ڕووی خاکەکەوە.
\v 3 هەموو ئەوانەی لەم نەتەوە بەدکارە ماونەتەوە، لە هەر شوێنێک کە دەرمکردن بۆی، مردنیان پێ لە ژیان چاکتر دەبێت. ئەمە فەرمایشتی یەزدانی سوپاسالارە.“
\s1 گوناه و سزا
\p 
\v 4 «پێیان بڵێ: ”یەزدان ئەمە دەفەرموێت:
\q1 «”ئایا کەسێک بکەوێت هەڵناستێتەوە؟
\q2 یان کەسێک هەڵبگەڕێتەوە، ناگەڕێتەوە؟
\q1 
\v 5 بۆچی ئەم گەلە هەڵگەڕایەوە؟
\q2 بۆچی خەڵکی ئۆرشەلیم بە بەردەوامی هەڵدەگەڕێنەوە؟
\q1 دەستیان بە فرتوفێڵ گرتووە،
\q2 ڕەتیانکردەوە بگەڕێنەوە.
\q1 
\v 6 بە ئاگاییەوە گوێم شل کرد،
\q2 بەڵام ڕاستی ناڵێن.
\q1 کەس نییە لە خراپەی خۆی پەشیمان بێتەوە و
\q2 بڵێت: ’چیم کرد؟‘
\q1 هەریەکە و گەڕاوەتەوە سەر ڕێڕەوەکەی خۆی،
\q2 وەک ئەسپێکی بە تاو بۆ ناو جەنگ.
\q1 
\v 7 تەنانەت لەقلەق لە ئاسمان
\q2 کاتی خۆی دەزانێت،
\q1 کۆتر و پەڕەسێلکە و ڕیشۆڵەش
\q2 کاتی هاتنی خۆیان ڕەچاو دەکەن،
\q1 بەڵام گەلەکەی من نازانن
\q2 یەزدان داوای چییان لێ دەکات.
\b
\q1 
\v 8 «”ئێوە چۆن دەڵێن: ’ئێمە داناین،
\q2 چونکە فێرکردنی یەزدانمان لەلایە،‘
\q1 لە کاتێکدا پێنووسی درۆی مامۆستایانی تەورات
\q2 بۆ درۆ دەستبەکار بوو؟
\q1 
\v 9 داناکان ڕیسوا دەبن،
\q2 دەتۆقن و پێوە دەبن.
\q1 ئەوەتا فەرمایشتی یەزدانیان ڕەتکردەوە،
\q2 ئیتر چ داناییەکیان هەیە؟
\q1 
\v 10 لەبەر ئەوە ژنەکانیان دەدەمە خەڵکی دیکە،
\q2 کێڵگەکانیان بەوانەی میراتگریانن،
\q1 چونکە لە بچووکەوە هەتا گەورە
\q2 هەموو پەرۆشی قازانجن،
\q1 لە پێغەمبەرەوە هەتا کاهین
\q2 هەموو ساختە دەکەن.
\q1 
\v 11 برینی گەلەکەم بە سووکیەوە چاک دەکەنەوە و
\q2 دەڵێن، ’ئاشتی، ئاشتی!‘
\q2 بەڵام ئاشتی نییە.
\q1 
\v 12 ئایا شەرمەزار بوون کاتێک کاری قێزەونیان کرد؟
\q2 نەخێر! شەرمەزار نەبوون،
\q2 هەروەها نەیانزانی شەرمەزاری چییە.
\q1 لەبەر ئەوە دەکەونە ناو کوژراوان،
\q2 لە کاتی سزادانیان تێکدەشکێن.“»
\q4 ئەوە فەرمایشتی یەزدانە.
\b
\q1 
\v 13 یەزدان دەفەرموێت: «”دروێنەکەیان لێ دەبەم،
\q2 نە ترێ بە مێوەوە دەمێنێت،
\q2 نە هەنجیر بە دار هەنجیرەوە،
\q1 گەڵاکانیش سیس دەبن.
\q2 ئەوەی دەیاندەمێ لەلایان نامێنێت.“»
\b
\q1 
\v 14 «ئێمە بۆچی دانیشتووین؟
\q2 با کۆببینەوە!
\q1 با هەڵبێین بۆ شارە قەڵابەندەکان و
\q2 لەوێ لەناوبچین!
\q1 یەزدانی پەروەردگارمان بڕیاری لەناوچوونی ئێمەی داوە،
\q2 ئاوی ژەهراویمان دەرخوارد دەدات،
\q2 لەبەر ئەوەی لە دژی یەزدان گوناهمان کرد.
\q1 
\v 15 چاوەڕێی ئاشتی بووین،
\q2 بەڵام چاکە نەبوو.
\q1 چاوەڕێی کاتی چاکبوونەوە بووین،
\q2 بەڵام ئەوەتا تۆقین.
\q1 
\v 16 پڕمەی ئەسپەکانی ئەو
\q2 لە دانەوە دەبیسترێت،
\q1 لە دەنگی حیلەی ئەسپە بەهێزەکانی
\q2 هەموو زەوی دەلەرزێت،
\q1 جا هاتن بۆ ئەوەی بخۆن،
\q2 زەوی و هەرچی تێیدایە،
\q2 شار و دانیشتووانەکەی.»
\b
\q1 
\v 17 «ئاگاداربن، ماری ژەهراوی دەنێرمە سەرتان،
\q2 کە نوشتەیان لێ ناکرێت،
\q2 ئینجا پێتانەوە دەدەن.»
\q4 ئەوە فەرمایشتی یەزدانە.
\b
\q1 
\v 18 ئەی خودایە، تۆ دڵنەوایی خەمی منیت،
\q2 دڵم دەردەدارە.
\q1 
\v 19 ئەوەتا دەنگی هانای گەلەکەم
\q2 لە خاکێکی دوورەوە دێت:
\q1 «ئایا یەزدان لە سییۆن نییە؟
\q2 یان پاشاکەی تێیدا نییە؟»
\b
\q1 «بۆچی بە پەیکەرە داتاشراوەکانیان پەستیان کردم،
\q2 بە بتە هیچوپووچە بێگانەکان؟»\f + \fr 8:19 \ft ئەمە بەشێکە لە فەرمایشتی خودا.‏\f*
\b
\q1 
\v 20 «دروێنە تێپەڕی،
\q2 هاوین تەواو بوو،
\q2 ئێمەش ڕزگارمان نەبوو.»\f + \fr 8:20 \ft ئەمە قسەی گەلی خودایە.‏\f*
\b
\q1 
\v 21 لەبەر وردوخاشبوونی گەلەکەم وردوخاش بووم،
\q2 خەمبارم، تۆقین دەستی بەسەردا گرتووم.
\q1 
\v 22 ئایا لە گلعاد هەتووان\f + \fr 8:22 \ft مەرهەم بۆ ساڕێژبوونی برین.‏\f* نییە؟
\q2 ئایا پزیشک لەوێ نییە؟
\q1 ئیتر بۆچی برینی گەلەکەم
\q2 ساڕێژ نابێت؟
\c 9
\q1 
\v 1 خۆزگە سەرم گۆمی ئاو بووایە و
\q2 چاوەکانم جۆگەی فرمێسک،
\q1 جا شەو و ڕۆژ دەگریام
\q2 بۆ کوژراوەکانی گەلەکەم.
\q1 
\v 2 خۆزگە دیوەخانێکم لە چۆڵەوانی هەبووایە،
\q2 جا وازم لە گەلەکەم دەهێنا و لەلای دەڕۆیشتم،
\q1 چونکە ئەوان هەموو داوێنپیسن و
\q2 کۆمەڵی ناپاکانن.
\b
\q1 
\v 3 «زمانیان ئامادە دەکەن
\q2 وەک کەوانێک بۆ هاویشتنی درۆ،
\q1 بەسەر خاکەکەدا زاڵ بوون،
\q2 بەڵام بە ڕێگای ڕاستی نەبوو،
\q1 چونکە لە خراپەیەکەوە دەچنە خراپەیەکی دیکە،
\q2 بەڵام دان بە مندا نانێن.»
\q4 ئەوە فەرمایشتی یەزدانە.
\q1 
\v 4 «با هەریەکە وریای خۆی بێت لە برادەرەکەی،
\q2 پشت بە هیچ برایەک مەبەستن،
\q1 چونکە هەموو برایەک وەک یاقوب هەڵخەڵەتێنەرە\f + \fr 9:4 \ft بڕوانە چیرۆکی یاقوب لە \xt پەیدابوون 27‏:36‏\xt*\ft ‏.‏\f* و
\q2 هەموو برادەرێک بوختانکەرە.
\q1 
\v 5 هەرکەسە و برادەری خۆی فریودەدات،
\q2 کەس بە ڕاستی نادوێت.
\q1 زمانی خۆیان بە درۆ ڕاهێناوە،
\q2 خۆیان لە خراپە ماندوو بوون.
\q1 
\v 6 تۆ لەناو فرتوفێڵ دادەنیشیت،
\q2 بە فرتوفێڵ ڕەتیان کردەوە دان بە مندا بنێن.»
\q4 ئەوە فەرمایشتی یەزدانە.
\p 
\v 7 لەبەر ئەوە یەزدانی سوپاسالار ئەمە دەفەرموێت:
\q1 «ئەوەتا من دەیانپاڵێوم و تاقییان دەکەمەوە،
\q2 لەبەر گوناهەکانیان چارەسەرێکی دیکە نییە بۆ گەلەکەی من.
\q1 
\v 8 زمانیان تیری کوشندەیە و
\q2 بە دەمیان فێڵ دەکەن.
\q1 هەرکەسە بە هاوڕێکەی دەڵێت، ”ئاشتی“،
\q2 بەڵام لە ناخییەوە بۆسەی بۆ دەنێتەوە.
\q1 
\v 9 ئایا لەسەر ئەمە سزایان نەدەم؟
\q2 ئایا من تۆڵە لە نەتەوەیەکی وەک ئەمە نەستێنمەوە؟»
\q4 ئەوە فەرمایشتی یەزدانە.
\b
\q1 
\v 10 بۆ چیاکان گریان و شیوەن دەگێڕم،
\q2 بەسەر لەوەڕگاکانی چۆڵەوانیدا دەلاوێنمەوە،
\q1 چونکە ئەوان وێران بوون و کەس پێیدا تێناپەڕێت،
\q2 دەنگی مێگەل نابیسترێت،
\q1 باڵندەکانی ئاسمان ڕایانکرد،
\q2 ئاژەڵەکان ڕۆیشتن.
\b
\q1 
\v 11 «ئۆرشەلیم وێران دەکەم،
\q2 دەیکەمە داڵدەی چەقەڵ،
\q1 شارۆچکەکانی یەهودا دەکەمە کاولگە
\q2 بەبێ دانیشتووان.»
\p 
\v 12 کێ کەسێکی دانایە و ئەمە تێدەگات؟ کێ ئەوەی یەزدان فێری کرد دەتوانێت ڕوونی بکاتەوە؟ بۆچی زەوی لەناوچوو، چۆڵەوانی وێران بوو، کەس ناتوانێت لێی بپەڕێتەوە؟
\p 
\v 13 یەزدان فەرمووی: «لەبەر ئەوەی وازیان لە فێرکردنەکەم هێنا، ئەوەی خستمە پێشیان پەیڕەویان نەکرد، گوێڕایەڵی من نەبوون.
\v 14 لەبری ئەوە، بەدوای کەللەڕەقی خۆیان کەوتن، بەدوای بەعلەکان کەوتن، کە باوباپیرانیان فێریان کردن.»
\v 15 لەبەر ئەوە یەزدانی سوپاسالار، خودای ئیسرائیل، ئاوا دەفەرموێت: «ئەوەتا من زەقنەبووت دەرخواردی ئەم گەلە دەدەم و ئاوی ژەهراوییان پێ دەنۆشم.
\v 16 بەناو چەندین نەتەوەدا پەرتیان دەکەم کە نە خۆیان و نە باوباپیرانیان نەیانناسیون، بە شمشێریش ڕاویان دەنێم هەتا لەناویان دەبەم.»
\p 
\v 17 یەزدانی سوپاسالار ئەمە دەفەرموێت:
\q1 «سەرنج بدەن! بانگی ژنە ماتەمگێڕەکان بکەن هەتا بێن،
\q2 بنێرن بەدوای ژنە شارەزاکان.
\q1 
\v 18 با خێرا بێن و دەنگی شیوەن بەسەرماندا هەڵبڕن،
\q2 چاوەکانمان فرمێسک بڕێژێت و
\q2 پێڵووەکانمان ئاویان لێ هەڵبقوڵێت.
\q1 
\v 19 دەنگی شیوەن لە سییۆنەوە بیسترا،
\q2 ”چۆن تێکدراین!
\q2 چەند شەرمەزار بووین!
\q1 چونکە زەوییەکەمان بەجێهێشت،
\q2 چونکە ماڵەکانمان کاول کران.“»
\b
\q1 
\v 20 ئەی ژنان، گوێ لە فەرمایشتی یەزدان بگرن،
\q2 گوێ لە فەرمایشتی دەمی ئەو بگرن.
\q1 کچەکانتان فێری شیوەن بکەن،
\q2 هەر ژنێکیش دەستەخوشکەکەی فێری ماتەم گێڕان بکات.
\q1 
\v 21 مردن بە پەنجەرەکانمان هەڵگەڕا،
\q2 هاتە ناو قەڵاکانمانەوە،
\q1 بۆ قڕکردنی منداڵان لە کۆڵان و
\q2 لاوان لە گۆڕەپانەکان.
\p 
\v 22 بڵێ: «یەزدان ئەمە دەفەرموێت:
\q1 «”تەرمی مرۆڤ دەکەوێت،
\q2 وەک زبڵ بەسەر ڕووی کێڵگەوە،
\q1 وەک چەپکی دوای دروێنەکەر،
\q2 کەس نییە کۆی بکاتەوە.“»
\p 
\v 23 یەزدان ئەمە دەفەرموێت:
\q1 «با دانا شانازی بە دانایی خۆی نەکات،
\q2 با پاڵەوان شانازی بە پاڵەوانیێتی خۆی نەکات،
\q2 با دەوڵەمەند شانازی بە دەوڵەمەندیێتی خۆی نەکات،
\q1 
\v 24 بەڵکو ئەوەی شانازی دەکات، با شانازی بەمە بکات:
\q2 کە لە من تێدەگات و دەمناسێت،
\q1 کە من یەزدانم، ئەوەی خۆشەویستی نەگۆڕ و
\q2 دادوەری و ڕاستودروستی لەسەر زەوی دەهێنمە دی،
\q2 چونکە خۆشی لەمانە دەبینم.»
\q4 ئەوە فەرمایشتی یەزدانە.
\p 
\v 25 یەزدان دەفەرموێت: «سەردەمێک دێت، سزای هەموو ئەوانە دەدەم کە تەنها بە لەش خەتەنە کراون،
\v 26 خەڵکی میسر و یەهودا و ئەدۆم و عەمۆن و مۆئاب و قژبڕاوەکانی\f + \fr 9:26 \ft خەڵکێک بوون وەک نەریتێکی بتپەرستی پرچیان بڕیوە.‏\f* دانیشتووی چۆڵەوانی. هەموو نەتەوەکان خەتەنە نەکراون و هەموو بنەماڵەی ئیسرائیلیش دڵیان خەتەنە نەکراوە\f + \fr 9:26 \ft هەرچەندە بنەماڵەی ئیسرائیل جەستەیان خەتەنەکراوە، بەڵام ڕۆحیان تەرخان نەکراوە بۆ یەزدان.‏\f*.»
\c 10
\s1 خودا و بتەکان
\p 
\v 1 ئەی بنەماڵەی ئیسرائیل، گوێ بگرن یەزدان چی بە ئێوە دەفەرموێت.
\v 2 یەزدان ئەمە دەفەرموێت:
\q1 «ئێوە نەریتی نەتەوەکان فێر مەبن و
\q2 لە نیشانەکانی ئاسمان مەتۆقن،
\q2 هەرچەندە نەتەوەکان لەم شتانە دەتۆقن.
\q1 
\v 3 نەریتی نەتەوەکان مایەپووچە:
\q2 درەختی بڕاوەی دارستانن،
\q2 دارتاش بە ئەسکەنە دروستیان دەکات،
\q1 
\v 4 بە زێڕ و زیو دەیڕازێننەوە و
\q2 بە مێخ و چەکوش توندیان دەکەن
\q2 بۆ ئەوەی نەلەقن.
\q1 
\v 5 وەک داوەڵی\f + \fr 10:5 \ft لە دار و پەڕۆ لە شێوەی مرۆڤ دروستدەکرێت بۆ ڕەوینەوەی پەلەوەر، بۆ ئەوەی زیان بە کێڵگە نەگەیەنن.‏\f* لە بێستانی خەیاردان،
\q2 بتەکانیان قسە ناکەن،
\q1 بە هەڵگرتن هەڵدەگیرێن،
\q2 چونکە هەنگاو نانێن،
\q1 لێیان مەترسن، چونکە زیانبەخش نین،
\q2 هەروەها ناتوانن هیچ سوودێک بگەیەنن.»
\b
\q1 
\v 6 ئەی یەزدان، کەس وەک تۆ نییە،
\q2 تۆ مەزنیت،
\q2 لە پاڵەوانیێتی ناوت گەورەیە.
\q1 
\v 7 کێ لێت ناترسێت،
\q2 ئەی پاشای نەتەوەکان؟
\q2 چونکە لە تۆ دەوەشێتەوە.
\q1 لەناو هەموو دانایانی نەتەوەکان و
\q2 لە هەموو شانشینەکانیان،
\q2 کەس هاوتای تۆ نییە.
\b
\q1 
\v 8 تێکڕا دەبەنگ و گێل بوون،
\q2 شتی پووچ لە بتی دارین فێر دەبن.
\q1 
\v 9 زیوی کوتراوە لە تەرشیشەوە دەهێنن و
\q2 زێڕ لە ئوفازەوە.
\q1 دەستکردی پیشەوەرە و دەستی زێڕنگەرە،
\q2 بەرگیان مۆر و ئەرخەوانییە،
\q2 هەمووی دەستکردی وەستایانن.
\q1 
\v 10 بەڵام تەنها یەزدان پەروەردگاری ڕاستییە،
\q2 ئەو خودای زیندوو و پاشای هەتاهەتاییە،
\q1 زەوی لەبەر تووڕەیی ئەو دەلەرزێت و
\q2 نەتەوەکان بەرگەی هەڵچوونی ئەو ناگرن.
\p 
\v 11 «ئاوایان پێ دەڵێن: ”ئەو خوداوەندانەی ئاسمان و زەوییان دروستنەکردووە، لەسەر زەوی و لەژێر ئەم ئاسمانە لەناودەچن.“»
\q1 
\v 12 بەڵام یەزدان بە هێزی خۆی زەوی دروستکردووە،
\q2 بە دانایی خۆی جیهانی دامەزراندووە،
\q2 بە تێگەیشتنی خۆی ئاسمانی ڕاخستووە.
\q1 
\v 13 کاتێک دەنگ هەڵدەبڕێت، ئاوەکانی ئاسمان هاژەیان دێت،
\q2 هەڵمەکان لەوپەڕی زەوییەوە بەرز دەکاتەوە،
\q1 بروسکە بۆ باران دروستدەکات،
\q2 با لە ئەمباری خۆی دەردەهێنێت.
\b
\q1 
\v 14 هەموو کەسێک بێ زانیارییە و دەبەنگە،
\q2 هەموو زێڕنگەرێک بە پەیکەرەکەی\f + \fr 10:14 \ft تاشینی پەیکەر، بە مەبەستی پەرستن وەک بت.‏\f* شەرمەزارە،
\q1 چونکە داڕێژراوی درۆن و
\q2 ڕۆحیان تێدا نییە.
\q1 
\v 15 ئەوان پووچن، مایەی گاڵتەجاڕین،
\q2 لە کاتی سزادانیان لەناودەچن.
\q1 
\v 16 بەڵام خودا، ئەوەی بەشی یاقوبە وەک ئەمانە نییە،
\q2 چونکە ئەو دروستکەری هەموو شتێکە،
\q1 ئیسرائیل هۆزی میراتی ئەویشی داناوە،
\q2 یەزدانی سوپاسالار، ئەمە ناوی ئەوە.
\s1 هاتنی وێرانی
\q1 
\v 17 لەم خاکە بوخچەکەت بپێچەوە،
\q2 ئەی دانیشتووی ژێر ئابڵوقە!
\q1 
\v 18 لەبەر ئەوەی یەزدان ئەمە دەفەرموێت:
\q2 «ئەم جارە دانیشتووانی ئەم خاکە
\q1 دەردەکەمە دەرەوە،
\q2 تەنگیان پێ هەڵدەچنم هەتا ئەوەی هەستی پێدەکەن.»
\b
\q1 
\v 19 وەی لە حاڵم لەبەر وردوخاشبوونم!
\q2 برینەکەم بێ چارەیە!
\q1 بەڵام بە خۆمم گوت: «بێگومان ئەمە دەردی منە و
\q2 دەبێ بەرگەی بگرم.»
\q1 
\v 20 چادرەکەم تێکدراوە،
\q2 هەموو گوریسەکانی پساون.
\q1 کوڕەکانم بەجێیان هێشتووم و نەماون،
\q2 ئیتر کەس نییە بۆ ئەوەی چادرەکەم هەڵبدات و
\q2 پڵاسەکانی چادرەکەم ڕابگرێت.
\q1 
\v 21 شوانەکان دەبەنگ بوون و
\q2 داوای یەزدانیان نەکرد،
\q1 لەبەر ئەوە سەرنەکەوتن و
\q2 هەموو مێگەلەکەیان پەرتەوازە بوو.
\q1 
\v 22 گوێ بگرن! دەنگی هەواڵ دێت،
\q2 هەراوهۆریای گەورە لە خاکی باکوورەوە،
\q1 تاوەکو شارۆچکەکانی یەهودا وێران بکرێن،
\q2 بکرێنە داڵدەی چەقەڵ.
\s1 نزاکردنی یەرمیا
\q1 
\v 23 ئەی یەزدان، زانیم کە مرۆڤ خاوەنی ڕێگای خۆی نییە،
\q2 کەس ناتوانێت ڕێڕەوەکانی خۆی ئاراستە بکات.
\q1 
\v 24 ئەی یەزدان، تەمبێم بکە،
\q2 بەڵام بە دادپەروەری، نەک بە تووڕەییت،
\q2 نەوەک لەناوم ببەیت.
\q1 
\v 25 تووڕەییت بەسەر ئەو نەتەوانەدا ببارێنە
\q2 کە دانت پێدا نانێن و
\q2 بەسەر ئەو گەلانەی کە بە ناوی تۆوە نزا ناکەن،
\q1 چونکە یاقوبیان خوارد،
\q2 بە تەواوی خواردیان و
\q2 نشینگەکەیان وێران کرد.
\c 11
\s1 شکاندنی پەیمانەکە
\p 
\v 1 ئەمە ئەو پەیامەیە کە لەلایەن یەزدانەوە بۆ یەرمیا هات:
\v 2 «گوێ لە بەندەکانی ئەو پەیمانە بگرن و لەگەڵ پیاوانی یەهودا و دانیشتووانی ئۆرشەلیم پێی بدوێن.
\v 3 پێیان دەڵێیت کە یەزدانی پەروەردگاری ئیسرائیل ئەمە دەفەرموێت: ”نەفرەت لێکراوە ئەو کەسەی گوێڕایەڵی بەندەکانی ئەو پەیمانە نابێت،
\v 4 کە من فەرمانم بە باوباپیرانتان کرد، لەو ڕۆژەی لە خاکی میسر، لەناو کوورەی ئاسن دەرمهێنان.“ فەرمووم: ”گوێم لێ بگرن و کاریان پێ بکەن بەپێی هەموو ئەوەی فەرمانتان پێ دەکەم. جا دەبن بە گەلی من و منیش دەبم بە خودای ئێوە،
\v 5 بۆ ئەوەی ئەو سوێندە بەجێبهێنم کە بۆ باوباپیرانتان خواردم کە خاکێکیان بدەمێ شیر و هەنگوینی لێ بڕژێتەوە،“ هەروەک ئەو خاکەی ئەمڕۆ تێیدان.»
\p منیش وەڵامم دایەوە: «ئامین، ئەی یەزدان!»
\p 
\v 6 ئینجا یەزدان پێی فەرمووم: «تەواوی ئەم پەیامە لەناو شارۆچکەکانی یەهودا و لە شەقامەکانی ئۆرشەلیم ڕابگەیەنە و بڵێ: ”گوێ لە بەندەکانی ئەم پەیمانە بگرن و کاریان پێ بکەن،
\v 7 چونکە لەو ڕۆژەوە کە باوباپیرانی ئێوەم لە خاکی میسرەوە هێنایە دەرەوە هەتا ئەمڕۆ، بە تەواوی و بەردەوام ئاگادارم کردوونەتەوە و بە ڕوونی فەرموومە: ’گوێم لێ بگرن.‘
\v 8 نە گوێیان گرت و نە گوێیان شل کرد، هەریەکە بەدوای کەللەڕەقییە خراپەکەی خۆی کەوت، جا منیش هەموو نەفرەتەکانی ئەم پەیمانەم بەسەریاندا هێنا، ئەوەی فەرمانم پێکردن کە کاری پێ بکەن، بەڵام نەیانکرد.“»
\p 
\v 9 ئینجا یەزدان پێی فەرمووم: «بە پیلانگێڕیم زانیوە لەنێو پیاوانی یەهودا و دانیشتووانی ئۆرشەلیم.
\v 10 گەڕانەوە سەر تاوانی باوباپیرانی پێشوویان، کە ڕەتیان کردەوە گوێ لە پەیامەکەم بگرن، کەوتنە دوای خوداوەندەکانی دیکە بۆ ئەوەی بیانپەرستن. بنەماڵەی ئیسرائیل و بنەماڵەی یەهودا ئەو پەیمانەیان شکاند کە لەگەڵ باوباپیرانیان بەستم.
\v 11 لەبەر ئەوە یەزدان ئەمە دەفەرموێت: ”ئەوەتا من بەڵایەکیان بەسەردا دەهێنم کە نەتوانن لێی دەرباز بن، جا هاوارم بۆ دەکەن و منیش گوێیان لێ ناگرم.
\v 12 شارۆچکەکانی یەهودا و دانیشتووانی ئۆرشەلیم دەچن و هاوار دەبەن بۆ ئەو خوداوەندانەی بخووریان بۆ دەسووتێنن، بەڵام ئەوان لە کاتی بەڵایان ڕزگاریان ناکەن.
\v 13 ئەی یەهودا، خوداوەندەکانت هێندەی ژمارەی شارۆچکەکانت بوون، قوربانگاتان هێندەی ژمارەی شەقامەکانی ئۆرشەلیم بوون بۆ بخوور سووتاندن بۆ خوداوەندی بەعلی شەرمەزاری.“
\p 
\v 14 «تۆش لە پێناوی ئەم گەلە نوێژ مەکە و لە پێناویان پاڕانەوە و نزا بەرز مەکەرەوە، چونکە لە کاتی هاوارکردنیان بۆم لەبەر بەڵاکەیان گوێیان لێ ناگرم.
\q1 
\v 15 «ئەی ئەویندارەکەم، لە پەرستگاکەم چی دەکەیت،
\q2 پلانگێڕیت لەگەڵ زۆر لایەن داڕشتووە،
\q2 ئایا گۆشتی قوربانی پیرۆزکراو سزات لەسەر لادەبات؟
\q1 کاتێک خراپە دەکەیت،
\q2 ئینجا دڵخۆش دەبیت.»
\b
\q1 
\v 16 یەزدان ناوی لێنایت زەیتوونی سەوز
\q2 لەگەڵ بەروبووم بە شێوەی جوان،
\q1 بەڵام بە دەنگی هاتوهەرایەکی گەورە
\q2 ئاگری لەسەر کردەوە
\q2 جا لقەکانی دەشکێنرێن.
\m 
\v 17 یەزدانی سوپاسالار، ئەوەی تۆی چاند، بڕیاری دا تووشی بەڵاتان بکات، لەبەر خراپەکەی بنەماڵەی ئیسرائیل و بنەماڵەی یەهودا، کە بخووریان بۆ بەعل سووتاند، بەو خراپەیە پەستیان کردم.
\s1 پیلان لە دژی یەرمیا
\p 
\v 18 یەزدان پیلانی ئەوانی بۆ من ئاشکرا کرد، جا زانیم، لەم کاتەدا کردارەکانی ئەوانی پیشاندام.
\v 19 منیش وەک بەرخێکی دەستەمۆ بۆ سەربڕین ببردرێت، نەمزانی پیلانیان لە دژی من گێڕاوە و دەڵێن:
\q1 «با دارەکە بە بەرەکەیەوە لەناو ببەین،
\q2 با لە خاکی زیندووان بیبڕینەوە،
\q2 ئیتر یادی ناوی ناکرێتەوە.»
\q1 
\v 20 بەڵام تۆ، ئەی یەزدانی سوپاسالار، دادوەری ڕاستودروست،
\q2 تاقیکەرەوەی مێشک و دڵ،
\q1 با تۆڵەسەندنەوەت لەوان ببینم،
\q2 چونکە کێشەی خۆمم بە تۆ سپارد.
\p 
\v 21 «لەبەر ئەوە فەرمایشتی یەزدان ئەمەیە سەبارەت بە پیاوانی عەناتۆت، ئەوانەی داوای گیانی تۆ دەکەن و دەڵێن: ”بە ناوی یەزدانەوە پەیام ڕامەگەیەنە، با بە دەستی خۆمان نەتکوژین.“
\v 22 لەبەر ئەوە یەزدانی سوپاسالار ئەمە دەفەرموێت: ”من سزایان دەدەم، لاوان بە شمشێر دەمرن و کوڕ و کچیشیان بە قاتوقڕی دەمرن.
\v 23 پاشماوەشیان بۆ نامێنێتەوە، چونکە لە ساڵی سزادانیان بەڵا بەسەر پیاوانی عەناتۆتدا دەهێنم.“»
\c 12
\s1 سکاڵانامەی یەرمیا
\q1 
\v 1 ئەی یەزدان، تۆ ڕاستودروستیت
\q2 کاتێک سکاڵای خۆم بۆ تۆ دەهێنم.
\q1 لەگەڵ ئەوەشدا سەبارەت بە حوکمەکانی تۆ دەدوێم:
\q2 بۆچی ڕێگای بەدکاران سەرکەوتووە؟
\q2 بۆچی هەموو ناپاکەکان ئاسوودەن؟
\q1 
\v 2 ئەوانت چاند و ڕەگیان داکوتا،
\q2 گەشەیان کرد و بەریان دا.
\q1 تۆ هەردەم لەسەر زاری ئەوانیت
\q2 بەڵام لە دڵیان دووریت.
\q1 
\v 3 بەڵام ئەی یەزدان، تۆ دەمناسیت،
\q2 دەمبینیت و لەلای خۆت دڵی من تاقی دەکەیتەوە.
\q1 وەک مەڕ بۆ سەربڕین جیایان بکەوە!
\q2 بۆ ڕۆژی کوشتن تەرخانیان بکە!
\q1 
\v 4 هەتا کەی زەوی بگریێ و
\q2 گیای هەموو کێڵگەکان وشک بێت؟
\q1 لەبەر خراپەی دانیشتووانەکەی
\q2 ئاژەڵ و باڵندە لەناوچوون،
\q2 چونکە گوتیان: «خودا کۆتایی ئێمە نابینێت.»
\s1 وەڵامی خودا
\q1 
\v 5 «ئەگەر لە ڕاکردن لەگەڵ پیادەکان ماندوو بیت،
\q2 ئەی چۆن پێشبڕکێ لەگەڵ ئەسپەکان دەکەیت؟
\q1 ئەگەر لەسەر خاکێکی سەلامەت ساتمە دەکەیت و دەکەویت،
\q2 ئەی لە دەوەنەکانی ڕووباری ئوردون چی دەکەیت؟
\q1 
\v 6 براکانت و بنەماڵەکەشت،
\q2 ئەوانیش ناپاکییان لەگەڵ کردیت،
\q1 ئەوانیش پڕ بەدەم بەدواتدا هاواریان کرد.
\q2 لێیان دڵنیا مەبە، هەرچەندە باسی چاکەشیان بۆ کردیت.
\b
\q1 
\v 7 «واز لە ماڵی خۆم دەهێنم،
\q2 میراتی خۆم ڕەت دەکەمەوە،
\q1 ئەویندارەکەی خۆم
\q2 دەخەمە چنگی دوژمەنەکانیەوە.
\q1 
\v 8 میراتەکەم لێم دەبێتە
\q2 شێرێک لە دارستان،
\q1 بەسەرمدا دەنەڕێنێت،
\q2 لەبەر ئەوە دژایەتی دەکەم.
\q1 
\v 9 ئایا میراتەکەم مەلی گۆشتخۆری خاڵدارە،
\q2 کە مەلە گۆشتخۆرەکانی دیکە چواردەوریان داوە و هێرشیان کردووەتە سەری؟
\q1 بڕۆن هەموو ئاژەڵە کێوییەکان کۆبکەنەوە،
\q2 بیانهێنن بۆ خواردن.
\q1 
\v 10 زۆر شوان ڕەزەمێوەکەی من تێکدەدەن،
\q2 کێڵگەکەی من پێپەست دەکەن.
\q1 کێڵگە ئارەزووبەخشەکەی من
\q2 دەکەنە چۆڵەوانییەکی کاول.
\q1 
\v 11 دەیکەنە کاولگە،
\q2 کاولگە شیوەن بۆ من دەگێڕێت.
\q1 هەموو زەوی کاول دەبێت،
\q2 چونکە کەس نییە گرنگی پێبدات.
\q1 
\v 12 لەسەر هەموو گردۆڵکەکانی چۆڵەوانی
\q2 تاڵانکەران دێن،
\q1 چونکە شمشێری یەزدان
\q2 لەوپەڕی زەوییەوە هەتا ئەم پەڕی دەخوات،
\q2 ئاشتی بۆ هیچ کەسێک نابێت.
\q1 
\v 13 گەنم دەچێنن و دڕک دەدورنەوە،
\q2 ماندوو دەبن و قازانج ناکەن.
\q1 ئیتر شەرمەزار دەبن لە بەروبوومەکەتان،
\q2 لە گڕی تووڕەیی یەزدان.»
\p 
\v 14 یەزدان ئەمە دەفەرموێت: «ئەو نەتەوە بەدکارانەی دراوسێم کە دەستیان لە میراتەکەم دا کە دامە ئیسرائیلی گەلەکەم، ئەوەتا لە خاکەکەدا ڕیشەکێشیان دەکەم و بنەماڵەی یەهوداش لە ناوەڕاستیان ڕیشەکێش دەکەم.
\v 15 لەدوای ئەوەی ڕیشەکێشیان دەکەم، دەگەڕێمەوە بەزەییم پێیاندا دێتەوە، هەریەکە بۆ میراتەکەی خۆی و بۆ خاکەکەی خۆی دەگەڕێنمەوە.
\v 16 لە ڕابردوو گەلەکەی منیان فێرکرد سوێند بە ناوی بەعل بخۆن، بەڵام ئەگەر ئێستا بە تەواوی فێری نەریتی گەلەکەی من ببن، ئەگەر سوێندیان بە ناوی من خوارد و گوتیان: ”بە یەزدانی زیندوو،“ ئەوا لەنێو گەلەکەم بنیاد دەنرێن.
\v 17 بەڵام هەر نەتەوەیەک ئەگەر گوێ نەگرێت، من لە ڕەگەوە ڕیشەکێشی دەکەم و لەناوی دەبەم.» ئەوە فەرمایشتی یەزدانە.
\c 13
\s1 پشتێنێکی کەتان
\p 
\v 1 یەزدان ئەمەی پێ فەرمووم: «بڕۆ پشتێنێکی کەتان بۆ خۆت بکڕە و لە ناوقەدی خۆتی ببەستە، بەڵام مەیخەرە ناو ئاوەوە.»
\v 2 منیش پشتێنم کڕی، بەپێی فەرمانی یەزدان، لە ناوقەدی خۆمم بەست.
\p 
\v 3 ئینجا دووبارە فەرمایشتی یەزدانم بۆ هات:
\v 4 «ئەو پشتێنەی کە کڕیت، کە لە ناوقەدت بەستووە، هەستە و بڕۆ بیبە پەرات\f + \fr 13:4 \ft پەرات: یان دەشێت ڕووباری فورات بێت.‏\f* و لەوێ لە کەلێنی بەردێک بیشارەوە.»
\v 5 منیش بەپێی ئەوەی یەزدان فەرمانی پێ کردم چووم و لە پەرات شاردمەوە.
\p 
\v 6 دوای ماوەیەکی درێژ، یەزدان پێی فەرمووم: «هەستە، بڕۆ بۆ پەرات و لەوێ ئەو پشتێنە هەڵبگرە کە فەرمانم پێکردیت لەوێ بیشاریتەوە.»
\v 7 منیش چووم بۆ پەرات، هەڵمکۆڵی و پشتێنەکەم لەو شوێنە هەڵگرتەوە کە تێیدا شاردبوومەوە، ئەوەتا ڕزیوە و بە کەڵکی هیچ نایەت.
\p 
\v 8 ئینجا فەرمایشتی یەزدانم بۆ هات:
\v 9 «یەزدان ئەمە دەفەرموێت: ”ئاوا شانازی یەهودا و شانازییە مەزنەکەی ئۆرشەلیم دەڕزێنم.
\v 10 ئەم گەلە بەدکارەی نایەوێت گوێ لە قسەی من بگرێت و بەدوای کەللەڕەقی خۆی کەوتووە، بەدوای خوداوەندەکانی دیکە دەکەوێت بۆ ئەوەی بیانپەرستێت و کڕنۆشیان بۆ ببات، وەک ئەم پشتێنەی لێدێت کە بە کەڵکی هیچ نایەت.
\v 11 وەک چۆن پشتێن لە پشتی مرۆڤ دەبەسرتێت، ئاوا هەموو بنەماڵەی ئیسرائیل و هەموو بنەماڵەی یەهودام لە پشتی خۆم بەست، هەتا ببنە گەلی من و ناو و شانازی و شکۆمەندی، بەڵام گوێیان نەگرت.“» ئەوە فەرمایشتی یەزدانە.
\s1 نموونەی گۆزەی شەراب
\p 
\v 12 «جا ئەم فەرمایشتەیان پێ ڕابگەیەنە: ”یەزدانی پەروەردگاری ئیسرائیل ئەمە دەفەرموێت: هەموو گۆزەیەکی شەراب پڕ شەراب دەبێت.“ جا پێت دەڵێن: ”بۆ ئێمە نازانین هەموو گۆزەیەکی شەراب پڕ شەراب دەبێت؟“
\v 13 تۆش پێیان دەڵێیت: ”یەزدان دەفەرموێت: ئەوەتا من هەموو دانیشتووانی ئەم خاکە پڕ دەکەم لە سەرخۆشی، ئەو پاشایانەی لە داودن، لەسەر تەختەکەی دانیشتوون، کاهین و پێغەمبەران و هەموو دانیشتووانی ئۆرشەلیم.
\v 14 بە یەکتری وردوخاش دەکەم، باوک و کوڕ پێکەوە، دڵم ناسووتێت و دەست ناپارێزم و بەزەییم نایەتەوە لە لەناوبردنیان.“» ئەوە فەرمایشتی یەزدانە.
\s1 مەترسی ڕاپێچکراوان
\q1 
\v 15 گوێ بگرن و گوێ شل بکەن،
\q2 لووتبەرز مەبن،
\q2 چونکە یەزدان فەرموویەتی.
\q1 
\v 16 شکۆ بدەنە یەزدانی پەروەردگارتان
\q2 بەر لەوەی تاریکی دابێنێت،
\q1 بەر لەوەی پەل بکوتن
\q2 لەسەر چیا بەر لە تاریکایی شەو.
\q1 ئێوە خوازیاری ڕووناکین
\q2 بەڵام ئەو دەیکاتە سێبەری مەرگ،
\q2 دەیکاتە ئەنگوستەچاو.
\q1 
\v 17 بەڵام ئەگەر گوێ نەگرن،
\q2 بە نهێنی دەگریێم
\q2 لەبەر لووتبەرزیتان،
\q1 چاوەکانم بەکوڵ دەگریێن و
\q2 فرمێسک دەڕێژێت،
\q2 چونکە مێگەلی یەزدان ڕاپێچ کرا.
\b
\q1 
\v 18 بە پاشا و بە شاژنی دایک بڵێ:
\q2 «لەسەر تەختەکان وەرنە خوارەوە،
\q1 چونکە تاجی شکۆمەندیتان
\q2 لەسەرتان دێتە خوارەوە.»
\q1 
\v 19 شارەکانی نەقەب دادەخرێن و
\q2 کەس نییە بیانکاتەوە.
\q1 هەموو یەهودا ڕاپێچ دەکرێ،
\q2 سەراپای ڕاپێچ دەکرێن.
\b
\q1 
\v 20 چاوت هەڵبڕە\f + \fr 13:20 \ft مەبەستی لە شاری ئۆرشەلیمە.‏\f* و
\q2 ئەوانە ببینە کە لە باکوورەوە دێن!
\q1 کوا ئەو مێگەلەی پێت درا،
\q2 ئەو مەڕانەی شانازیت پێوە دەکردن؟
\q1 
\v 21 چی دەڵێی کاتێک یەزدان ئەوانەت لەسەر دادەنێت
\q2 کە فێری هاوپەیمانیت کردن؟
\q1 ئایا ژان ناتگرێت
\q2 وەک ئەو ژنەی منداڵی دەبێت؟
\q1 
\v 22 ئەگەر لە دڵی خۆتدا بڵێی،
\q2 «بۆچی ئەمانەم بەسەرهات؟»
\q1 لەبەر زۆری تاوانت، دامێنت هەڵکرا
\q2 دەستدرێژییان کردە سەرت.
\q1 
\v 23 ئایا حەبەشی دەتوانێت پێستی خۆی بگۆڕێت،
\q2 یان پڵنگ بەڵەکەکانی؟
\q1 ئێوەش ناتوانن چاکە بکەن،
\q2 کە لە خراپە ڕاهاتوون!
\b
\q1 
\v 24 «وەک پووش پەرتیان دەکەم
\q2 کە بای چۆڵەوانی هەڵیدەگرێت.»
\q1 
\v 25 یەزدان دەفەرموێت: «ئەمە بەختی تۆیە،
\q2 ئەو بەشەی لەلایەن منەوە پێتدراوە،
\q2 لەبەر ئەوەی منت لەبیر کرد و
\q2 پشتت بە خوداوەندی درۆیین بەست.
\q1 
\v 26 منیش دامێنت بەسەر ڕووتدا هەڵدەدەمەوە،
\q2 ئینجا دەستدریژیت دەکرێتە سەر!
\q1 
\v 27 داوێنپیسی و حیلاندنت،
\q2 بێڕوویی لەشفرۆشیت!
\q1 لەسەر گردەکان و کێڵگەکان
\q2 قێزەونییەکانی تۆم بینی.
\q1 ئەی ئۆرشەلیم، قوڕبەسەرت!
\q2 هەتا کەی پاک نابیتەوە؟»
\c 14
\s1 وشکەساڵی و برسیێتی و شمشێر
\p 
\v 1 ئەمە فەرمایشتی یەزدانە بۆ یەرمیا سەبارەت بە وشکەساڵییەکە:
\q1 
\v 2 «یەهودا شیوەن دەگێڕێت و
\q2 شارەکانی دادەڕزێن،
\q1 بۆ خاکەکە ماتەم دەگێڕن،
\q2 هاواری ئۆرشەلیمیش بەرزبووەوە.
\q1 
\v 3 گەورەکان خزمەتکارەکانی خۆیان بۆ ئاو نارد،
\q2 هاتنە سەر ئەمباراوەکان،
\q2 بەڵام ئاویان نەدۆزییەوە.
\q1 بە گۆزەی بەتاڵەوە گەڕانەوە،
\q2 شەرمەزار و ڕیسوا بوون،
\q2 سەری خۆیان شۆڕکرد.
\q1 
\v 4 لەبەر ئەوەی خاکەکە شەقار شەقار بووە،
\q2 چونکە باران لە زەوییەکە نەباری،
\q1 جوتیاران شەرمەزاربوون،
\q2 سەری خۆیان شۆڕکرد.
\q1 
\v 5 تەنانەت مامزیش لە کێڵگەدا
\q2 بەچکەی بوو و وازی لێی هێنا،
\q2 چونکە گیا نەبوو.
\q1 
\v 6 کەرەکێوییەکان لەسەر گردۆڵکەکان ڕاوەستان،
\q2 وەک چەقەڵ بایان هەڵمژی،
\q1 چاویان شل بوو،
\q2 چونکە گیاوگۆڵ نییە.»
\b
\q1 
\v 7 لەگەڵ ئەوەی تاوانەکانمان شایەتیمان لەسەر دەدەن،
\q2 ئەی یەزدان، لەبەر خاتری ناوی خۆت شتێک بکە،
\q1 چونکە هەڵگەڕانەوەکانمان زۆر بوون،
\q2 دەرهەق بە تۆ گوناهمان کرد.
\q1 
\v 8 ئەی هیوای ئیسرائیل،
\q2 ئەی ڕزگارکەرەکەی کاتی تەنگانە،
\q1 بۆچی لە خاکەکە وەک نامۆ دەبیت،
\q2 وەک ڕێبوارێک بۆ تەنها شەوێک بمێنێتەوە؟
\q1 
\v 9 بۆچی وەک پیاوێکی حەپەساو دەبیت،
\q2 وەک پاڵەوانێک توانای ڕزگارکردنی نەبێت؟
\q1 ئەی یەزدان، تۆ لە ناوەڕاستمانی و
\q2 ئێمە ناوی تۆ هەڵدەگرین،
\q2 بەجێمان مەهێڵە!
\p 
\v 10 یەزدان ئاوا بەم گەلە دەفەرموێت:
\q1 «بەڕاستی حەزیان لە گەڕان کرد،
\q2 خۆیان لێ نەپاراست.
\q1 جا یەزدانیش پەسەندی نەکردن،
\q2 ئێستا تاوانەکانیان بەبیر خۆی دەهێنێتەوە و
\q2 لەسەر گوناهەکانیان سزایان دەدات.»
\p 
\v 11 هەروەها یەزدان پێی فەرمووم: «نوێژ بۆ چاکەی ئەم گەلە مەکە.
\v 12 هەرچەندە بەڕۆژووش بن گوێ لە هاواریان ناگرم، کاتێک قوربانی سووتاندن و پێشکەشکراوی دانەوێڵە پێشکەش بکەن قبوڵی ناکەم، بەڵکو من بە شمشێر و قاتوقڕی و دەرد کۆتاییان پێ دەهێنم.»
\p 
\v 13 منیش گوتم: «ئای، ئەی یەزدانی باڵادەست، ئەوەتا پێغەمبەرەکان پێیان دەڵێن: ”تووشی شمشێر و قاتوقڕی نابن، بەڵکو لەم شوێنەدا ئاشتی چەسپاوتان دەدەمێ.“»
\p 
\v 14 یەزدانیش پێی فەرمووم: «ئەو پێغەمبەرانە بە درۆ بە ناوی منەوە پێشبینی دەکەن. من نەمناردوون و دەستنیشانم نەکردوون و قسەم لەگەڵ نەکردوون. ئەوان بە بینینی درۆ و فاڵگرتنەوە و پڕوپووچی و خەیاڵی بیری خۆیان پێشبینیتان بۆ دەکەن.»
\v 15 لەبەر ئەوە یەزدان لەبارەی ئەو پێغەمبەرانەوە دەفەرموێت: «بە ناوی منەوە پێشبینی دەکەن و منیش نەمناردوون، ئەوان دەڵێن: ”شمشێر و قاتوقڕی لەم خاکە نابێت.“ ئەو پێغەمبەرانە خۆیان بە شمشێر و قاتوقڕی لەناودەچن.
\v 16 ئەو گەلەش کە ئەوان پێشبینی بۆ دەکەن، لەبەر قاتوقڕی و شمشێر لە شەقامەکانی ئۆرشەلیم فڕێدەدرێن. کەسیش نییە بیاننێژێت، خۆیان و ژن و کوڕ و کچیان. خراپەی شایستەی خۆیان بەسەر سەریاندا دەڕێژم.
\p 
\v 17 «ئەم قسەیەیان پێ دەڵێیت:
\q1 «”با چاوەکانم فرمێسک بڕێژن
\q2 بە شەو و بە ڕۆژ بەبێ وەستان،
\q1 چونکە گەلەکەم، کچە پاکیزەکەم،
\q2 برینێکی ترسناکی هەیە،
\q2 لێدانێکی جەرگبڕ.
\q1 
\v 18 ئەگەر بچمە دەرەوە بۆ کێڵگە،
\q2 بە شمشێر کوژراوان دەبینم.
\q1 ئەگەر بێمە ناو شار،
\q2 نەخۆشەکانی قاتوقڕی دەبینم،
\q1 چونکە پێغەمبەر و کاهینیش
\q2 بەناو زەوییەکدا دەگەڕێن و نازانن چی دەکەن.“»
\b
\q1 
\v 19 «ئایا بە تەواوی یەهودات ڕەتکردووەتەوە؟
\q2 ئایا بێزت لە سییۆن دەبێتەوە؟
\q1 بۆچی وا تووشی بەڵات کردین
\q2 کە چاکبوونەوەمان نەبێت؟
\q1 چاوەڕێی ئاشتی بووین،
\q2 بەڵام چاکە نەهات،
\q1 هەروەها کاتی چاکبوونەوە،
\q2 بەڵام ئەوەتا ترس.
\q1 
\v 20 ئەی یەزدان، دان دەنێین بە یاخیبوونی خۆمان و
\q2 تاوانی باوباپیرانمان،
\q2 گوناهمان دەرهەق بە تۆ کرد.
\q1 
\v 21 لە پێناوی ناوی خۆت، ڕەتمان مەکەوە،
\q2 تەختی شکۆی خۆت ڕیسوا مەکە،
\q1 پەیمانەکەی خۆت لەگەڵ ئێمە بەبیر بێتەوە،
\q2 مەیشکێنە.
\q1 
\v 22 ئایا لەناو بتە پووچەکانی نەتەوەکان هەیە باران ببارێنێت؟
\q2 یان ئایا ئاسمان خۆی ڕەهێڵ دەبارێنێت؟
\q1 ئەی تۆ یەزدانی پەروەردگارمان نیت؟
\q2 جا هیوامان بە تۆیە،
\q2 چونکە تۆ ئەوەی کە هەموو ئەمانەت کردووە.»
\c 15
\p 
\v 1 ئینجا یەزدان پێی فەرمووم: «تەنانەت ئەگەر موسا و ساموئێلیش لەبەردەمم ڕاوەستن داکۆکیتان لێ بکەن، دڵم ناچێتە سەر ئەم گەلە. لەبەرچاوی من دەریانبکە! با بڕۆن!
\v 2 جا کاتێک پێت دەڵێن: ”بۆ کوێ بچین؟“ تۆش پێیان دەڵێیت: ”یەزدان ئەمە دەفەرموێت:
\q1 «”ئەوانەی بۆ مردنن، بۆ مردن،
\q1 ئەوانەی بۆ شمشێرن، بۆ شمشێر،
\q1 ئەوانەی بۆ برسیێتین، بۆ برسیێتی،
\q1 ئەوانەی بۆ ڕاپێچن، بۆ ڕاپێچ.“»
\p 
\v 3 یەزدان دەفەرموێت: «چوار جۆریان بەسەرەوە دادەنێم، شمشێر بۆ کوشتن، سەگەکان بۆ ڕاکێشان، باڵندە و ئاژەڵە کێوییەکانیش بۆ خواردن و لەناوبردن.
\v 4 هەموو شانشینەکانی زەوی لێتان دەتۆقن، لەسەر ئەوەی مەنەشەی کوڕی حەزقیای پاشای یەهودا لە ئۆرشەلیم کردی.
\q1 
\v 5 «ئەی ئۆرشەلیم، کێ دڵی پێت دەسووتێت؟
\q2 کێ بۆت خەمبار دەبێت؟
\q2 کێ ئاوڕ دەداتەوە بۆ ئەوەی لە سەلامەتیت بپرسێت؟
\q1 
\v 6 تۆ وازت لە من هێنا،
\q2 لێم یاخی دەبی،
\q1 لەبەر ئەوە دەست درێژدەکەمە سەرت و لەناوت دەبەم،
\q2 لە لێبوردنت بێزار بووم.»
\q4 ئەوە فەرمایشتی یەزدانە.
\q1 
\v 7 «بە شەن شەنیان دەکەم،
\q2 لە دەروازەی شارەکانی خاکەکە.
\q1 جەرگسووتاوم کرد، گەلی خۆمم لەناوبرد،
\q2 ڕەفتاری خۆیان نەگۆڕی.
\q1 
\v 8 بێوەژنەکانیان زۆر زیاتر دەکەم،
\q2 زیاتر لە لمی دەریا.
\q1 لە نیوەڕۆدا وێرانکەری بۆ دەهێنم
\q2 بۆ سەر دایکی گەنجان.
\q1 لەناکاو
\q2 ترس و تۆقاندنی بەسەردا دەدەم.
\q1 
\v 9 دایکی حەوت منداڵ سیس بوو،
\q2 گیانی سپارد.
\q1 هێشتا ڕۆژ بوو خۆری ئاوابوو،
\q2 شەرمەزار و ڕیسوا بوو.
\q1 پاشماوەکەشیان دەدەمە بەر شمشێر
\q2 لە بەرچاوی دوژمنانیان.»
\q4 ئەوە فەرمایشتی یەزدانە.
\b
\q1 
\v 10 قوڕبەسەرم دایکە، چونکە منت بوو،
\q2 پیاوێک کە دەمەقاڵێ و ململانێی لەگەڵ سەراپای خاکەکە هەیە!
\q1 نە قەرزم کردووە و نە قەرزیان داومەتێ،
\q2 کەچی هەمووان نەفرەتم لێ دەکەن.
\p 
\v 11 یەزدان فەرمووی:
\q1 «بێگومان بۆ مەبەستی چاک دەربازت دەکەم،
\q2 بێگومان وا دەکەم دوژمن
\q2 لە کاتی بەڵا و لە کاتی تەنگانەدا لێت بپاڕێنەوە!
\b
\q1 
\v 12 «کەس دەتوانێت ئاسن بشکێنێت،
\q2 ئاسنی باکوور و بڕۆنز؟
\b
\q1 
\v 13 «سامان و گەنجینەکانت
\q2 دەکەم بە تاڵانی، بەبێ نرخ،
\q1 لەبەر هەموو گوناهەکانت،
\q2 لە سەراپای خاکەکەت.
\q1 
\v 14 دەتکەمە کۆیلەی دوژمنەکانت،
\q2 لە خاکێک نەتناسیبێت،
\q1 چونکە تووڕەییم گڕی گرتووە
\q2 وەک ئاگرێک دەتانسووتێنێت.»
\b
\q1 
\v 15 «ئەی یەزدان، تۆ دەزانیت،
\q2 بەبیری خۆتم بهێنەرەوە و گرنگیم پێبدە،
\q2 تۆڵەم بستێنەوە لە چەوسێنەرانم.
\q1 وا مەکە بەهۆی پشوودرێژی تۆ لەناوبچم،
\q2 بزانە کە لەبەر تۆ بەرگەی ڕیسواییم گرت.
\q1 
\v 16 کاتێک فەرموودەکانی تۆ هات، خواردم
\q2 بۆم بووە مایەی شادی و خۆشحاڵی دڵم،
\q1 چونکە من ناوی تۆم هەڵگرتووە،
\q2 ئەی یەزدان، خودای سوپاسالار.
\q1 
\v 17 قەت لە کۆڕی گاڵتەجاڕان دانەنیشتووم،
\q2 لەگەڵیشیان دڵخۆش نەبووم.
\q1 بە تەنها دانیشتم، چونکە دەستی تۆم لەسەر بوو،
\q2 پڕت کردم لە تووڕەیی.
\q1 
\v 18 بۆچی ژانم کۆتایی نایەت،
\q2 برینەکەم بێ چارەیە و نایەوێت چاک بێتەوە؟
\q1 ئایا وەک کەندێکی فریودەر دەبیت بۆم،
\q2 وەک کانییەک جێی متمانە نەبێت؟»
\p 
\v 19 لەبەر ئەوە یەزدان ئەمە دەفەرموێت:
\q1 «ئەگەر تۆبە بکەیت، دەتگەڕێنمەوە لای خۆم
\q2 تاکو وەک بەندەی خۆم لەبەردەستم ڕاوەستیت.
\q1 ئەگەر قسەی بە نرخ بکەیت، نەک بێبەها،
\q2 دەتکەمە وتەبێژی خۆم.
\q1 با ئەو گەلە بگەڕێتەوە لای تۆ،
\q2 بەڵام تۆ نەگەڕێیتەوە لای ئەوان.
\q1 
\v 20 دەتکەمە شوورا بۆ ئەو گەلە،
\q2 شوورایەکی بڕۆنزی پتەو،
\q1 لەگەڵت دەجەنگن
\q2 بەڵام دەرەقەتت نایەن،
\q1 چونکە من لەگەڵتدام،
\q2 بۆ ڕزگارکردن و بۆ فریاکەوتنت.»
\q4 ئەوە فەرمایشتی یەزدانە.
\q1 
\v 21 «لە دەستی خراپەکاران فریات دەکەوم و
\q2 لە چنگی زۆرداران دەتکڕمەوە.»
\c 16
\s1 ڕۆژی لێقەومان
\p 
\v 1 ئینجا فەرمایشتی یەزدانم بۆ هات، پێی فەرمووم:
\v 2 «ژن مەهێنە و لەم شوێنەدا کوڕ و کچت نەبێت.»
\v 3 یەزدان سەبارەت بەو کوڕ و کچانەی لەم شوێنەدا لەدایک بوون و سەبارەت بە دایکانیان کە ئەوانیان بووە و سەبارەت بە باوکانیان کە لەم خاکەدا ئەوانیان خستووەتەوە ئەمە دەفەرموێت:
\v 4 «بە نەخۆشی کوشندە دەمرن، شینیان بۆ ناگێڕدرێت و نانێژرێن، بەڵکو دەبن بە زبڵ لەسەر ڕووی خاکەکە. ئەوانە بە شمشێر و قاتوقڕی لەناودەچن، تەرمیان دەبێتە خۆراکی باڵندە و ئاژەڵە کێوییەکان.»
\p 
\v 5 یەزدان ئەمەش دەفەرموێت: «مەچۆ بۆ ماڵی پرسەگێڕ و مەڕۆ بۆ شینگێڕان و سەرەخۆشییان لێ مەکە، چونکە ئاشتی خۆم، خۆشەویستی نەگۆڕ و بەزەییم لەم گەلە داماڵیوە.
\v 6 گەورە و بچووک لەم خاکە دەمرن، نانێژرێن و شینیان بۆ ناگێڕدرێت و کەس لە خەمی ئەوان لە خۆی نادات و قژی ناڕنێتەوە.
\v 7 لە ماتەم کەس شیوەغەریبەیان بۆ نابات بۆ ئەوەی سەرەخۆشییان لێ بکات، سەبارەت بە نەریتی مردوو کەس جامی سەرەخۆشی پێشکەش ناکات، تەنانەت لەبەر دایک و باوکیشیان.» ئەوە فەرمایشتی یەزدانە.
\p 
\v 8 «هەروەها مەچووە ماڵێک داوەتی هەبێت، بۆ ئەوەی لەگەڵیان دابنیشیت و بخۆیت و بخۆیتەوە،
\v 9 چونکە یەزدانی سوپاسالار، خودای ئیسرائیل ئەمە دەفەرموێت: ئەوەتا من لەم شوێنەدا و لە سەردەمی ئێوە و لەبەرچاوی ئێوە دەنگی شادی و دەنگی خۆشی و دەنگی زاوا و دەنگی بووک ڕادەگرم.
\p 
\v 10 «جا کاتێک هەموو ئەم قسانەت بەم گەلە ڕاگەیاند لێت دەپرسن: ”بۆچی یەزدان هەموو ئەم بەڵا گەورەیەی سەبارەت بە ئێمە فەرمووە؟ تاوانمان چییە و گوناهمان چییە کە دەرهەق بە یەزدانی پەروەردگارمان ئەنجاممان داوە؟“
\v 11 تۆش پێیان دەڵێیت، یەزدان دەفەرموێت: ”لەسەر ئەوەی باوباپیرانتان وازیان لە من هێنا، دوای خوداکانی دیکە کەوتن و ئەوانیان پەرست و کڕنۆشیان بۆ بردن. وازیان لە من هێنا و گوێڕایەڵی فێرکردنەکانی من نەبوون.
\v 12 ئێوەش لە باوباپیرانتان زیاتر خراپەتان کرد، ئەوەتا هەریەکە بەدوای کەللەڕەقییە خراپەکەی خۆی کەوتووە، لە جیاتی ئەوەی گوێڕایەڵی من بن.
\v 13 لەبەر ئەوە لەم خاکە فڕێتاندەدەمە دەرەوە بۆ خاکێک کە نە ئێوە و نە باوباپیرانتان نەتانناسیوە. لەوێ بە شەو و ڕۆژ خوداکانی دیکە دەپەرستن، چونکە من لەگەڵتان میهرەبان نابم.“»
\p 
\v 14 هەروەها یەزدان دەفەرموێت: «لەبەر ئەوە سەردەمێک دێت، چیتر ناڵێن: ”بە یەزدانی زیندوو، ئەوەی نەوەی ئیسرائیلی لە خاکی میسرەوە دەرهێنا،“
\v 15 بەڵکو دەڵێن: ”بە یەزدانی زیندوو، ئەوەی نەوەی ئیسرائیلی لە خاکی باکوورەوە دەرهێنا و هەروەها لە هەموو ئەو خاکانەی بۆ ئەوێ دەریکردن.“ لەبەر ئەوەی دەیانگەڕێنمەوە بۆ خاکەکەیان، ئەوەی دام بە باوباپیرانیان.»
\p 
\v 16 یەزدان دەفەرموێت: «بەڵام ئێستا دەنێرم بەدوای زۆرێک لە ماسیگران، جا وەک ماسی دەیانگرن. پاش ئەمە دەنێرم بەدوای زۆرێک لە ڕاوچییان و لەسەر هەموو کێوێک و هەموو گردێک و لە کون و کەلەبەری بەردەکان ڕاویان دەکەن،
\v 17 چونکە چاوم لە هەموو ڕێگاکانیانە، ڕێگاکانیان لەبەردەم من شاردراوە نین و تاوانەکەیان لەبەرچاوم بزر نەبووە.
\v 18 دوو ئەوەندە سزایان دەدەم لەسەر تاوان و گوناهەکانیان، لەسەر ئەوەی خاکی منیان بە کەلاکی بتەکانیان گڵاو کردووە و میراتەکەی منیان پڕکردووە لە قێزەونەکانیان.»
\q1 
\v 19 ئەی یەزدان، ئەی هێز و قەڵای من،
\q2 ئەی پەناگای من لە ڕۆژی تەنگانە،
\q1 نەتەوەکان لەوپەڕی زەوییەوە
\q2 بۆ لای تۆ دێن و دەڵێن:
\q1 «باوباپیرانمان تەنها خوداوەندی درۆیینیان بە میرات بۆ مایەوە،
\q2 بتی پووچی بێ کەڵک.
\q1 
\v 20 ئایا مرۆڤ خوداوەند بۆ خۆی دروستدەکات؟
\q2 بەڵێ، بەڵام خودا نین!»
\b
\q1 
\v 21 «لەبەر ئەوە ئەوەتا پێیان دەناسێنم،
\q2 ئەم جارە دەسەڵات و هێزی خۆمیان
\q2 پێ دەناسێنم.
\q1 ئینجا ئەوان دەزانن
\q2 کە ناوم یەزدانە.
\b
\c 17
\q1 
\v 1 «گوناهەکانی یەهودا بە قەڵەمی ئاسن نووسراوە،
\q2 بە نووکی ئەڵماس هەڵکۆڵراوە،
\q1 لەسەر پەڕەی دڵیان و
\q2 لەسەر قۆچی قوربانگاکانیان.
\q1 
\v 2 تەنانەت منداڵەکانیشیان ئەوانەیان بەبیر دێتەوە،
\q2 قوربانگا و ستوونە ئەشێراکانیان\f + \fr 17:2 \ft ستوونە ئەشێرا: هێمای خواژنە. بڕوانە \xt یەکەم پاشایان 11‏:5‏\xt*\ft ‏.‏\f*
\q1 کە لەلای دارە سەوزەکان و
\q2 لەسەر کێوە بەرزەکان بوون.
\q1 
\v 3 چیاکەی خۆم لە دەشتودەر و
\q2 سامان و هەموو گەنجینەکانی تۆ
\q1 دەکەم بە تاڵانی،
\q2 لەگەڵ نزرگەکانی سەر بەرزاییەکانت،
\q2 چونکە لەنێو خاکەکەت گوناهت کرد.
\q1 
\v 4 بەخۆت دەستبەردار دەبیت لەو میراتەی
\q2 کە بە تۆم بەخشی،
\q1 دەتکەمە کۆیلەی دوژمنەکانت
\q2 لە خاکێک کە نەتناسیبێت،
\q1 چونکە ئاگرتان بەردایە تووڕەییم
\q2 هەتاهەتایە گڕدەگرێت.»
\p 
\v 5 یەزدان ئەمە دەفەرموێت:
\q1 «نەفرەت لێکراوە ئەو کەسەی پشت بە ئادەمیزاد دەبەستێت،
\q2 متمانەی بە هێزی مرۆڤانە هەیە و
\q2 دڵی لەسەر یەزدان لادەبات.
\q1 
\v 6 وەک بنچکێک لە بیابان دەبێت،
\q2 چاکە نابینێت کاتێک دێت،
\q1 لە گەرمەسێر نیشتەجێ دەبێت لە چۆڵەوانی،
\q2 لە زەوییەکی خوێیین کە کەسی تێدا ناژیێت.
\b
\q1 
\v 7 «بەڵام بەرەکەتدارە ئەو کەسەی پشت بە یەزدان دەبەستێت و
\q2 متمانەی پێی هەیە.
\q1 
\v 8 وەک دارێک دەبێت، شەتڵکراو لەدەم ئاو،
\q2 لەدەم جۆگە ڕەگ دادەکوتێت،
\q1 لە گەرما ناترسێت،
\q2 گەڵاکانی سەوزن،
\q1 گوێ بە وشکەساڵی نادات،
\q2 لە بەروبووم دان ناوەستێت.»
\b
\q1 
\v 9 دڵ لە هەموو شتێک فریودەرترە و
\q2 دەرمانی نییە،
\q2 کێ دەیناسێت؟
\b
\q1 
\v 10 «من یەزدانم، دڵ دەپشکنم،
\q2 دەروون تاقی دەکەمەوە،
\q1 بۆ ئەوەی هەریەکە بەگوێرەی ڕەفتارەکەی پێی بدەم،
\q2 بەگوێرەی شایستەیی کردارەکانی.»
\b
\q1 
\v 11 وەک کەوێک کڕکەوتبێت بەسەر ئەو هێلکانەی خۆی نەیکردبێت،
\q2 دەوڵەمەندێک بە ناڕەوایی دەوڵەمەند بووبێت،
\q1 لە نیوەی تەمەنی وازی لێ دەهێنێت،
\q2 لە کۆتاییشدا دەبێتە گێل.
\b
\q1 
\v 12 تەختی شکۆمەندییە، هەر لە سەرەتاوە بەرزە،
\q2 شوێنی پیرۆزگاکەمان.
\q1 
\v 13 ئەی یەزدان، هیوای ئیسرائیل!
\q2 هەموو ئەوانەی وازت لێ دێنن، شەرمەزار دەبن،
\q1 ئەوانەی لە تۆ لادەدەن، لەسەر خۆڵ دەنووسرێن،\f + \fr 17:13 \ft چارەنووسیان مردنە.‏\f*
\q2 چونکە وازیان لە یەزدان هێنا،
\q2 لە کانی ئاوی ژیان.
\b
\q1 
\v 14 ئەی یەزدان، چاکم بکەرەوە، چاک دەبمەوە،
\q2 ڕزگارم بکە، ڕزگار دەبم،
\q2 چونکە ستایشی من هەر بۆ تۆیە.
\q1 
\v 15 ئەوەتا ناحەزانم پێم دەڵێن:
\q2 «کوا فەرمایشتی یەزدان؟
\q2 با ئێستا بێتە دی!»
\q1 
\v 16 منیش هەرگیز لەوە لام نەدا شوان بم لەلای تۆ،
\q2 تۆ دەزانیت کە خوازیاری ڕۆژی کوشندە نەبووم.
\q2 چی لە دەمم هاتووەتە دەرەوە لەبەردەمی خۆت بووە.
\q1 
\v 17 ئەی یەزدان، مەمتۆقێنە،
\q2 تۆ پەناگای منی لە ڕۆژی لەناوچوون.
\q1 
\v 18 با ڕاونەرانم شەرمەزار بن
\q2 بەڵام من شەرمەزار نەبم،
\q1 با ئەوان بتۆقن
\q2 بەڵام من نەتۆقم.
\q1 ڕۆژی لەناوچوونیان بەسەردا بهێنە،
\q2 دوو ئەوەندە وردوخاشیان بکە.
\s1 تەرخانکردنی ڕۆژی شەممە
\p 
\v 19 یەزدان ئاوای پێ فەرمووم: «بڕۆ و لەلای دەروازەی نەوەی گەل بوەستە، ئەوەی پاشاکانی یەهودا پێیدا دێنە ژوورەوە و دەچنە دەرەوە، هەروەها لە هەموو دەروازەکانی دیکەی ئۆرشەلیم بوەستە.
\v 20 پێیان بڵێ: ”گوێ لە فەرمایشتی یەزدان بگرن، ئەی پاشاکانی یەهودا و هەموو یەهودا و هەموو دانیشتووانی ئۆرشەلیم، ئەوانەی لەم دەروازانەوە دێنە ژوورەوە.
\v 21 یەزدان ئەمە دەفەرموێت: ئاگاداری خۆتان بن و لە ڕۆژی شەممەدا هیچ بارێک هەڵمەگرن و بەناو دەروازەکانی ئۆرشەلیمدا بیهێننە ژوورەوە.
\v 22 هیچ بارێکیش لە ڕۆژی شەممەدا لە ماڵەکانتانەوە مەهێننە دەرەوە و هیچ کارێک مەکەن، ڕۆژی شەممە تەرخان بکەن، وەک ئەوەی فەرمانم بە باوباپیرانتان کرد.
\v 23 بەڵام گوێیان نەگرت و گوێیان پێی نەدا و کەللەڕەقییان کرد، نەیانبیست و تەمبێ نەبوون.
\v 24 بەڵام ئەگەر بە تەواوی گوێم لێ بگرن، لە ڕۆژی شەممە هیچ بارێک نەهێننە ناو دەروازەکانی ئەم شارە و ڕۆژی شەممەتان تەرخان کرد، بۆ ئەوەی هیچ کارێکی تێدا نەکەن،
\v 25 ئەوا پاشایانی سەر تەختی داود لەگەڵ پیاوە گەورەکان بە دەروازەکانی ئەم شارەدا دێنە ژوورەوە، لەگەڵ پیاوە گەورەکان بە سواری گالیسکە و ئەسپەوە، لەگەڵ پیاوانی یەهودا و دانیشتووانی ئۆرشەلیم دێن، ئەم شارەش هەتاهەتایە ئاوەدان دەبێت.
\v 26 ئینجا لە شارۆچکەکانی یەهودا، لە دەوروبەری ئۆرشەلیم، لە خاکی بنیامین، لە زوورگەکانی\f + \fr 17:26 \ft زوورگ: لە تەپۆڵکە بەرزترە، هەروەک بەرزاییەکانی زوورگەزراو لە کوردستان.‏\f* خۆرئاوا، لە ناوچە شاخاوییەکان و لە نەقەبەوە دێن. قوربانی سووتاندن و قوربانی سەربڕاو، پێشکەشکراوی دانەوێڵە، بخوور و قوربانی سوپاسگوزاری دەهێننە ناو ماڵی یەزدانەوە.
\v 27 خۆ ئەگەر گوێ لە من نەگرن بۆ تەرخانکردنی ڕۆژی شەممە، بەردەوام بوون لەوەی بە بارەوە بێنە ناو دەروازەکانی ئۆرشەلیم، ئەوا من ئاگرێکی نەکوژاوە بەردەدەمە دەروازەکانی ئۆرشەلیم کە قەڵاکانی لەناودەبات.“» ئەوە فەرمایشتی یەزدانە.
\c 18
\s1 لە ماڵی گۆزەکەر
\p 
\v 1 ئەمە ئەو پەیامەیە کە لەلایەن یەزدانەوە بۆ یەرمیا هات:
\v 2 «هەستە و بەرەو خوارەوە بڕۆ بۆ ماڵی گۆزەکەرەکە، لەوێ پەیامی خۆمت پێ ڕادەگەیەنم.»
\v 3 منیش بەرەو خوارەوە چووم بۆ ماڵی گۆزەکەرەکە، بینیم لەسەر چەرخەکە کار دەکات.
\v 4 بەڵام ئەو دەفرەی گۆزەکەرەکە لە گڵ دروستی دەکرد، تێکچوو، جا دووبارە کردییەوە بە دەفرێکی دیکە، بەو شێوەیەی گۆزەکەرەکە پێی باش بوو.
\p 
\v 5 ئینجا فەرمایشتی یەزدانم بۆ هات:
\v 6 «ئەی بنەماڵەی ئیسرائیل، ئایا من ناتوانم وەک ئەم گۆزەکەرەتان لەگەڵ بکەم؟ ئەی بنەماڵەی ئیسرائیل، ئێوە لەناو دەستی منن هەروەک گڵ لەناو دەستی گۆزەکەر.
\v 7 ئەگەر هەر کاتێک لەبارەی نەتەوەیەک و شانشینێکەوە باسی ڕیشەکێشکردن و بەزەوی دادان و لەناوبردنم کردبێت،
\v 8 ئەو نەتەوەیەی کە لەبارەیەوە دواوم، لە خراپەکەی تۆبە دەکات، ئینجا منیش پاشگەز دەبمەوە لەو بەڵایەی بەتەمابووم تووشی بکەم.
\v 9 ئەگەر هەر کاتێکیش لەبارەی نەتەوەیەک و شانشینێکەوە باسی بنیادنان و چاندن بکەم،
\v 10 بەڵام لەبەرچاوم خراپە بکات و گوێڕایەڵی من نەبێت، ئەوا منیش پاشگەز دەبمەوە لەو چاکەیەی کە فەرمووم بۆی بکەم.» ئەوە فەرمایشتی یەزدانە.
\p 
\v 11 «ئێستاش بە پیاوانی یەهودا و دانیشتووانی ئۆرشەلیم بڵێ: ”یەزدان ئەمە دەفەرموێت: ئاگاداربن! من بەڵایەکتان بۆ ئامادە دەکەم و پیلانێک لە دژی ئێوە دادەڕێژم. جا لەبەر ئەوە بگەڕێنەوە، هەرکەسە و لە ڕێگا خراپەکانی، ڕێگا و کردەوەکانی خۆتان چاک بکەنەوە.“
\v 12 بەڵام گوتیان: ”بێ سوودە، چونکە ئێمە دوای بیروڕای خۆمان دەکەوین، هەریەکەمان بەپێی کەللەڕەقییە خراپەکەی خۆی دەکات.“»
\p 
\v 13 لەبەر ئەوە یەزدان ئەمە دەفەرموێت:
\q1 «لەنێو نەتەوەکان بپرسن:
\q2 کێ وەک ئەمەی بیستووە؟
\q1 بێ تامترین خراپە
\q2 ئیسرائیلی پاکیزە کردوویەتی.
\q1 
\v 14 ئایا بەفری لوبنان
\q2 لە لووتکە بەردینەکانی دەبڕێتەوە؟
\q1 ئایا ئاوی سازگاری لەبەرڕۆیشتووی
\q2 وشک دەبێت؟
\q1 
\v 15 بەڵام گەلەکەم منی لەیاد کردووە،
\q2 بخووری بۆ بتی پووچ سووتاندووە،
\q1 کۆسپ و تەگەرەیان خستە بەردەم ڕێگاکانیان و
\q2 ڕێچکە کۆنەکان،
\q1 تاکو بە لاڕێکان و
\q2 ڕێگا خۆش نەکراوەکاندا بڕۆن.
\q1 
\v 16 بۆ ئەوەی خاکەکەیان وێران بێت،
\q2 بۆ هەتاهەتایە ببێتە جێگای تانە و تەشەر،
\q1 هەرکەسێک پێیدا تێبپەڕێت سەرسام بێت و
\q2 سەر بلەقێنێت.
\q1 
\v 17 وەک بای ڕۆژهەڵات
\q2 لەبەردەم دوژمن پەرتیان دەکەم،
\q1 لە ڕۆژی کارەساتیان
\q2 پشتیان تێدەکەم، نەک ڕوو.»
\p 
\v 18 ئینجا ناحەزانم گوتیان: «وەرن، با پیلانێک لە یەرمیا بگێڕین، چونکە فێرکردن لە کاهین و ڕاوێژ لە دانا و پەیام لە پێغەمبەر نابڕێتەوە. وەرن با بە زمانمان لێی بدەین و گوێ لە هیچ وشەیەکی نەگرین.»
\q1 
\v 19 ئەی یەزدان، گوێم لێ بگرە،
\q2 گوێ لە دەنگی ناحەزانم بگرە.
\q1 
\v 20 ئایا پاداشتی چاکە بە خراپە دەدرێتەوە؟
\q2 بەڵام چاڵێکیان بۆم هەڵکەندووە.
\q1 بەبیرت بێتەوە وەستانم لەبەردەمت،
\q2 بۆ ئەوەی لە پێناوی ئەوان بپاڕێمەوە،
\q2 تاکو تووڕەییت لێیان بگێڕمەوە.
\q1 
\v 21 لەبەر ئەوە کوڕەکانیان بدە دەست قاتوقڕی،
\q2 بیاندە دەست شمشێر،
\q1 با ژنەکانیان جەرگسووتاو و بێوەژن بن،
\q2 پیاوەکانیشیان بمرن،
\q2 گەنجەکانیان لە جەنگ بە شمشێر بکوژرێن.
\q1 
\v 22 با هاوار لە ماڵەکانیانەوە ببیسترێت،
\q2 کاتێک لەپڕ چەتەیان بەسەردا دەدەیت،
\q1 چونکە چاڵیان هەڵکەند بۆ گرتنم،
\q2 تەڵەیان بۆ پێم نایەوە.
\q1 
\v 23 بەڵام ئەی یەزدان،
\q2 تۆ لە هەموو تەگبیرەکانیان بۆ کوشتنی من ئاگاداربووی.
\q1 لە تاوانیان خۆش مەبە و
\q2 گوناهەکەیان لەبەرچاوت مەسڕەوە.
\q1 با لەبەردەمت تێکبشکێن،
\q2 لە کاتی تووڕەبوونت سزایان بدە.
\c 19
\p 
\v 1 یەزدان ئەمە دەفەرموێت: «بڕۆ لای گۆزەکەر، گۆزەیەکی گڵ بکڕە. هەندێک لە پیرانی گەل و کاهینی پیر ببە،
\v 2 بڕۆ دەرەوە بۆ دۆڵی بەن‌هینۆم کە لەلای داڵانی دەروازەی زبڵدانە\f + \fr 19:2 \ft شوێنی فڕێدانی پارچە گۆزەی شکاو بووە.‏\f*، لەوێ ئەو پەیامە جاڕبدە کە پێتی دەڵێم.
\v 3 بڵێ: ”ئەی پاشایانی یەهودا و ئەی دانیشتووانی ئۆرشەلیم، گوێ لە فەرمایشتی یەزدان بگرن. یەزدانی سوپاسالار، خودای ئیسرائیل ئەمە دەفەرموێت: ئاگاداربن! بەڵایەک بەسەر ئەم شوێنەدا دەهێنم کە هەرکەسێک بیبیستێت، گوێی بزرنگێتەوە.
\v 4 لەبەر ئەوەی وازیان لێ هێنام، ئەم شوێنەیان پیس کرد و تێیدا بخووریان بۆ خوداوەندەکانی دیکە سووتاند کە نەیان دەناسین، نە خۆیان و نە باوباپیرانیان و نە پاشایانی یەهودا، ئەم شوێنەیان پڕکرد لە خوێنی بێتاوانان.
\v 5 نزرگەی بەعلیان لەسەر بەرزاییەکان بنیاد نا، تاکو کوڕەکانیان بە ئاگر بسووتێنن و بیکەنە قوربانی سووتاندن بۆ بەعل، کە من نە فەرمانم پێکردبوو و نە فەرمووبووم و نە بەخەیاڵمدا هاتبوو.
\v 6 لەبەر ئەوە ئاگاداربن، سەردەمێک دێت، چیتر ئەم شوێنە پێی ناگوترێت تۆفەت یان دۆڵی بەن‌هینۆم، بەڵکو پێی دەگوترێت دۆڵی کوشتن. ئەوە فەرمایشتی یەزدانە.
\p 
\v 7 «”جا لەم شوێنەدا پیلانی یەهودا و ئۆرشەلیم پووچ دەکەمەوە، وا دەکەم لەبەردەم دوژمنەکانیان بە شمشێر بکوژرێن، بە دەستی ئەوانەی دەیانەوێت لەناویان ببەن، تەرمەکانیان دەکەمە خۆراکی باڵندە و ئاژەڵی کێوی.
\v 8 ئەم شارە وێران دەکەم و دەیکەمە جێگای تانە و تەشەری خەڵک، هەرکەسێک پێیدا تێبپەڕێت سەرسام دەبێت، گاڵتەی پێ دەکات لەسەر هەموو ئەوەی بەسەری هاتووە.
\v 9 وایان لێ دەکەم گۆشتی کوڕ و کچەکانی خۆیان بخۆن، هەریەکە گۆشتی هاوڕێکەی خۆی دەخوات، لەبەر گەمارۆ و ئەو تەنگانەیەی تێی دەکەون بەدەستی دوژمنانیان کە بەدوای ئەوانەوەن بۆ کوشتنیان.“
\p 
\v 10 «ئینجا گۆزەکە لەبەرچاوی ئەو پیاوانە بشکێنە کە لەگەڵتدان،
\v 11 پێیان بڵێ: ”یەزدانی سوپاسالار ئەمە دەفەرموێت: ئاوا ئەم گەلە و ئەم شارە دەشکێنم، وەک چۆن دەفرە گۆزەکە کە نەتوانرێت جارێکی دیکە چاک بکرێتەوە. لە تۆفەت دەنێژرێن، هەتا ئەوەی جێی ناشتن نەمێنێت.“
\v 12 یەزدان دەفەرموێت: ”ئاوا لەم شوێنە و دانیشتووانەکەی دەکەم، ئەم شارە وەک تۆفەت لێ دەکەم.
\v 13 جا ماڵەکانی ئۆرشەلیم و کۆشکەکانی پاشایانی یەهودا وەک شوێنی تۆفەت گڵاو دەبن، هەموو ئەو ماڵانەی لە سەربانەکانیان بخووریان سووتاند بۆ هەموو ئەستێرەکانی ئاسمان و شەرابی پێشکەشکراویان بۆ خوداوەندەکانی دیکە پێشکەش کرد.“»
\p 
\v 14 ئینجا یەرمیا لە تۆفەت هاتەوە کە یەزدان بۆ پێشبینیکردن ناردبوویە ئەوێ، لە حەوشەکەی پەرستگای یەزدان ڕاوەستا و بە هەموو گەلی گوت:
\v 15 «یەزدانی سوپاسالار، خودای ئیسرائیل ئەمە دەفەرموێت: ”گوێ بگرن! من هەموو ئەو بەڵایە بەسەر ئەم شارە و بەسەر هەموو گوندەکانی دەوروبەریدا دەهێنم، ئەوەی سەبارەت بەو فەرمووم، چونکە کەللەڕەقییان کرد و گوێیان لە قسەی من نەگرت.“»
\c 20
\s1 یەرمیا و پەشحوری کاهین
\p 
\v 1 کاتێک پەشحوری کوڕی ئیمێری کاهین لێپرسراوی پەرستگای یەزدان گوێی لە یەرمیا بوو پێشبینی ئەو شتانەی دەکرد،
\v 2 لە یەرمیای پێغەمبەری دا و لەو کۆتەی کرد کە لەلای دەروازەی بنیامینی سەرەوەیە، ئەوەی لە پەرستگای یەزدانە.
\v 3 بۆ بەیانی پەشحور یەرمیای لە کۆتەکە دەرهێنا، یەرمیاش پێی گوت: «یەزدان تۆ بە پەشحور ناو نابات، بەڵکو مەگۆر میسەڤیڤ\f + \fr 20:3 \ft واتا (مایەی ترس و تۆقین لە هەموو لایەکەوە).‏\f*،
\v 4 چونکە یەزدان ئەمە دەفەرموێت: ”ئەوەتا دەتکەمە ترس و تۆقین بۆ خۆت و بۆ هەموو دۆستانت، بە چاوی خۆت دەبینی کە بە شمشێری دوژمنەکانیان دەکوژرێن. هەموو یەهوداش دەدەمە دەست پاشای بابل، بۆ بابل ڕاپێچیان دەکات یان دەیانداتە بەر شمشێر.
\v 5 هەموو سامانی ئەم شارە، هەموو بەرهەم و هەموو شتە بەنرخەکانی و هەموو گەنجینەکانی پاشاکانی یەهودا دەدەمە دەست دوژمنەکانیان. جا تاڵانیان دەکەن و دەستی بەسەردا دەگرن و دەیانبەنە بابل.
\v 6 تۆش ئەی پەشحور، لەگەڵ هەموو ئەندامانی ماڵەکەت بۆ بابل ڕاپێچ دەکرێن، لەوێ دەمرن و لەوێ دەنێژرێن، تۆ و هەموو دۆستانت کە بە درۆ پێشبینیت بۆیان کردبوو.“»
\s1 سکاڵانامەی یەرمیا
\q1 
\v 7 ئەی یەزدان، فریوتدام و فریودرام،
\q2 تۆ لە من بەتواناتری و دەرەقەتم هاتی.
\q1 بە درێژایی ڕۆژ پێم پێدەکەنن،
\q2 هەموو گاڵتەم پێ دەکەن.
\q1 
\v 8 هەر کاتێک بدوێم هاوار دەکەم،
\q2 جاڕی توندوتیژی و وێرانی دەدەم،
\q1 چونکە فەرمایشتی یەزدان ڕیسوایی بۆ هێنام،
\q2 گاڵتە پێکردن بە درێژایی ڕۆژ.
\q1 
\v 9 بەڵام ئەگەر بڵێم: «باسی ناکەم،
\q2 ئیتر بە ناوی ئەوەوە نادوێم،»
\q1 جا وشەکەی لە دڵمدا وەک ئاگرێکی داگیرساو دەبێت،
\q2 وەک ئاگرێکی پەنگخواردوو لەناو ئێسقانەکانم،
\q1 بێزار دەبم لە دامرکاندنەوەی و
\q2 ناتوانم بێدەنگ بم.
\q1 
\v 10 گوێم لە چپەچپی زۆر کەس بووە:
\q2 «لە هەموو لایەکەوە ترس و تۆقین هەیە!
\q2 خەبەری لێ بدەن! با خەبەری لێ بدەین!»
\q1 هەموو هاوڕێیەکانم
\q2 چاوەڕێی شکستی من دەکەن، دەڵێن:
\q1 «بەڵکو فریوبخوات،
\q2 ئینجا دەرەقەتی دێین و
\q2 تۆڵەی خۆمانی لێ دەکەینەوە.»
\b
\q1 
\v 11 بەڵام یەزدان وەک پاڵەوانێکی بە توانا لەگەڵمدایە،
\q2 لەبەر ئەوە ئەوانەی دەمچەوسێننەوە دەکەون و دەرەقەتم نایەن،
\q1 سەرناکەون و بە تەواوی ڕیسوا دەبن،
\q2 شەرمەزارییەکەیان هەرگیز لەبیر ناکرێت.
\q1 
\v 12 ئەی یەزدانی سوپاسالار، ئەوەی ڕاستودروست تاقی دەکەیتەوە و
\q2 ناخ و دڵ دەپشکنیت،
\q1 با تۆڵەسەندنەوەت لەوان ببینم،
\q2 چونکە کێشەی خۆمم بە تۆ سپارد.
\b
\q1 
\v 13 گۆرانی بۆ یەزدان بڵێن!
\q2 ستایشی یەزدان بکەن!
\q1 چونکە هەژار ڕزگار دەکات
\q2 لە دەستی بەدکاران.
\b
\q1 
\v 14 نەفرەت لێکراوە ئەو ڕۆژەی تێیدا لەدایک بووم!
\q2 با بەرەکەتدار نەبێت ئەو ڕۆژەی دایکم منی بوو!
\q1 
\v 15 نەفرەت لێکراوە ئەو کەسەی مژدەی دایە باوکم،
\q2 زۆر دڵخۆشی کرد و گوتی:
\q2 «کوڕێکت بوو!»
\q1 
\v 16 با ئەو کەسە وەک ئەو شارۆچکانەی لێ بێت
\q2 کە یەزدان بەبێ پەشیمانبوونەوە سەرەوژێری کرد.
\q1 با بەیانییان دەنگی هاوار ببیستێت،
\q2 نەعرەتە کێشانی جەنگیش لە کاتی نیوەڕۆ،
\q1 
\v 17 چونکە لەناو سکی دایکمەوە نەیکوشتم،
\q2 جا دایکم دەبوو بە گۆڕم و
\q2 سکی هەمیشە هەر پڕ دەبوو.
\q1 
\v 18 بۆچی لە سکی دایکم هاتمە دەرەوە؟
\q2 ئایا بۆ بینینی ماندووبوون و خەم؟
\q2 ئایا بۆ کۆتایی هاتنی ڕۆژگارم بە ڕیسوایی؟
\c 21
\s1 خودا داوای سدقیا ڕەت دەکاتەوە
\p 
\v 1 ئەو پەیامەی لەلایەن یەزدانەوە بۆ یەرمیا هات، کاتێک سدقیای پاشا پەشحوری کوڕی مەلکیا و سەفەنیای کوڕی مەعسێیاهوی کاهینی ناردە لای و گوتی:
\v 2 «تکایە لە پێناوی ئێمە داوا لە یەزدان بکە، چونکە نەبوخودنەسری پاشای بابل هێرشمان دەکاتە سەر، بەڵکو یەزدان وەک ڕابردوو کاری سەرسوڕهێنەرمان لەگەڵ دەکات هەتا نەبوخودنەسر لەلای ئێمە بکشێتەوە.»
\p 
\v 3 بەڵام یەرمیا وەڵامی دانەوە: «بە سدقیا بڵێن،
\v 4 ”یەزدانی پەروەردگاری ئیسرائیل ئەمە دەفەرموێت: من خەریکم ئەو چەکانە لە دژتان بەکاردەهێنم کە لە دەستتاندایە و لەگەڵ پاشای بابل و بابلییەکان شەڕی پێ دەکەن، کە لە دەرەوەی شوورای شارەکان گەمارۆیان داون. لە ناوەڕاستی شار کۆیان دەکەمەوە.
\v 5 من خۆم بە دەستێکی پۆڵایین و بازووێکی بەهێز، بە تووڕەیی و هەڵچوونێکی بە جۆشی گەورەوە لە دژتان دەجەنگم.
\v 6 دانیشتووانی ئەو شارە دەکوژم، مرۆڤ و ئاژەڵ پێکەوە، بە دەردێکی گەورەوە دەمرن.
\v 7 پاش ئەمەش، سدقیای پاشای یەهودا و خزمەتکارەکانی و ئەوەی لەم گەلە لە شارەکەدا ماونەتەوە، لەدوای دەرد و شمشێر و قاتوقڕییەکە، دەیاندەمە دەست نەبوخودنەسری پاشای بابل و دوژمنەکانیان و ئەوانەی دەیانەوێت لەناویان ببەن. ئەوانیش دەیاندەنە بەر شمشێر و لەگەڵیان میهرەبان نابن و دڵیان پێیان ناسووتێت و بەزەییان پێیاندا نایەتەوە.“» ئەوە فەرمایشتی یەزدانە.
\p 
\v 8 «بەم گەلەش دەڵێیت: ”یەزدان ئەمە دەفەرموێت: ئێستا من ڕێگای ژیان و ڕێگای مردنتان لەپێش دادەنێم.
\v 9 ئەوەی لەم شارەدا بمێنێتەوە بە شمشێر و قاتوقڕی و دەرد لەناودەچێت، ئەوەش بچێتە دەرەوە و ڕوو لە بابلییەکان بکات، ئەوانەی گەمارۆیان داون، دەژیێت و ژیانی خۆی دەرباز دەکات.
\v 10 لەبەر ئەوەی مکوڕم لەسەر ئەوەی خراپە بەسەر ئەو شارە بهێنم نەک باشە. دەدرێتە دەست پاشای بابل و بە ئاگر دەیسووتێنێت.“» ئەوە فەرمایشتی یەزدانە.
\p 
\v 11 «بە بنەماڵەی پاشای یەهودا بڵێ: ”گوێ لە فەرمایشتی یەزدان بگرن.
\v 12 ئەی بنەماڵەی داود، یەزدان ئەمە دەفەرموێت:
\q1 «”هەموو بەیانییەک بە دادپەروەری حوکم بدەن،
\q2 تاڵانکراو لە دەستی زۆردار ڕزگار بکەن،
\q1 نەوەک تووڕەییم وەک ئاگر بتەقێتەوە،
\q2 لەبەر ئەو خراپانەی کردووتانە،
\q2 جا بسووتێنێت و کەس نەبێت بکوژێنێتەوە.
\q1 
\v 13 ئەی ئۆرشەلیم، ئەوەی نیشتەجێی لەسەر دۆڵەکە،
\q2 بەسەر دەشتی بەردەڵانی بەرز،
\q2 ئەوەتا من لە دژی تۆم.
\q4 ئەوە فەرمایشتی یەزدانە.
\q2 ئێوە دەڵێن: ’کێ بەسەرماندا دەدات؟
\q2 کێ دێتە ناو نشینگەکانمانەوە؟‘
\q1 
\v 14 بەڵام من سزای شایستەی کردارەکانتان دەدەم،
\q1 ئاگر بەردەدەمە دارستانەکەی و
\q2 هەموو دەوروبەرەکەی دەخوات.“»
\q4 ئەوە فەرمایشتی یەزدانە.
\c 22
\s1 حوکمدان لەسەر پاشا خراپەکارەکان
\p 
\v 1 یەزدان ئەمە دەفەرموێت: «دابەزە بۆ کۆشکی پاشای یەهودا و لەوێ ئەو پەیامە ڕابگەیەنە،
\v 2 بڵێ: ”ئەی پاشای یەهودا، ئەوەی لەسەر تەختی داود دانیشتووی، گوێ لە فەرمایشتی یەزدان بگرە؛ تۆ و خزمەتکارەکانت و گەلەکەت، ئەوانەی لەم دەروازانەوە دێنە ژوورەوە.
\v 3 یەزدان ئەمە دەفەرموێت: ’ڕاستودروستی و دادپەروەری پەیڕەو بکەن. تاڵانکراو لە دەستی زۆردار دەرباز بکەن. نامۆ و هەتیو و بێوەژن مەچەوسێننەوە، ستەم مەکەن، لەم شوێنەدا خوێنی بێتاوان مەڕێژن.‘
\v 4 ئەگەر بە گرنگییەوە ئەم فەرمانە پەیڕەو بکەن، ئەوا ئەو پاشایانەی لەسەر تەختی داود دانیشتوون لە دەروازەکانی ئەم کۆشکەوە دێنە ژوورەوە، بە سواری گالیسکە و ئەسپەوە لەگەڵ خزمەتکاران و گەلەکەی.
\v 5 بەڵام ئەگەر گوێ لەم فەرمانە نەگرن، سوێند بە گیانی خۆم دەخۆم، کە ئەم کۆشکە وێران دەبێت.“» ئەوە فەرمایشتی یەزدانە.
\p 
\v 6 یەزدان سەبارەت بە کۆشکی پاشای یەهودا ئەمەش دەفەرموێت:
\q1 «هەرچەندە تۆ بۆ من وەک گلعادی،
\q2 وەک لووتکەی لوبنانی،
\q1 بەڵام وەک چۆڵەوانیت لێ دەکەم،
\q2 وەک شاری بێ دانیشتووان.
\q1 
\v 7 تێکدەرانت بۆ تەرخان دەکەم،
\q2 هەریەکە و بە ئامێرەکەیەوە،
\q1 جا باشترین داری ئورزت دەبڕنەوە و
\q2 فڕێیدەدەنە ناو ئاگرەوە.
\p 
\v 8 «خەڵکی زۆر نەتەوە بە کەناری ئەم شارەدا تێدەپەڕن و لە یەکتری دەپرسن: ”لەسەر چی یەزدان وای لەم شارە گەورەیە کرد؟“
\v 9 جا دەڵێن: ”لەسەر ئەوەی وازیان لە پەیمانی یەزدانی پەروەردگاریان هێنا و خوداوەندەکانی دیکەیان پەرست و کڕنۆشیان بۆ بردن.“»
\q1 
\v 10 بۆ پاشا مردووەکە\f + \fr 22:10 \ft مەبەستی لە یۆشیا پاشایە.‏\f* مەگریێن و شینی بۆ مەگێڕن،
\q2 بەڵکو بەکوڵ بگریێن بۆ ئەوەی بە دیل دەبردرێت،
\q1 چونکە جارێکی دیکە ناگەڕێتەوە
\q2 بۆ ئەوەی ئەو خاکە ببینێت کە لێی لەدایک بووە.
\m 
\v 11 سەبارەت بە شەلومی\f + \fr 22:11 \ft شەلوم: بە یەهۆئاحازیش ناودەبردرێت.‏\f* کوڕی یۆشیای پاشای یەهودا، ئەوەی لە جێی باوکی بوو بە پاشا، ئەوەی لەم شوێنە ڕۆیشت، یەزدان دەفەرموێت: «جارێکی دیکە ناگەڕێتەوە ئێرە،
\v 12 بەڵکو لەو شوێنەی ڕاپێچیان کردووە بۆی هەر لەوێ دەمرێت، جارێکی دیکە ئەم خاکە نابینێتەوە.»
\q1 
\v 13 «قوڕبەسەر ئەوەی کۆشکەکەی بە ناڕەوایی بنیاد دەنێت و
\q2 ژوورەکانی سەرەوەشی بە ستەمکاری،
\q1 ئەوەی بێگاری بە هاوڵاتییان دەکات،
\q2 هەقی ماندووبوونەکەیان ناداتێ.
\q1 
\v 14 دەڵێت: ”کۆشکێکی فراوان بۆ خۆم بنیاد دەنێم،
\q2 ژوورەکانی سەرەوەی پانوبەرین.“
\q1 پەنجەرەی گەورەی بۆ دەکاتەوە،
\q2 دیوارەکانی بە تەختەی دار ئورز دادەپۆشێت،
\q2 بە ڕەنگی سوور بۆیاخی دەکات.
\b
\q1 
\v 15 «ئایا ئەوە دەتکاتە پاشا،
\q2 کە دار ئورزی زۆرت هەبێت؟
\q1 ئایا باوکت نەیخوارد و نەیخواردەوە؟
\q2 ڕاستودروستی و دادپەروەری پەیڕەو کرد،
\q2 جا سەرکەوتوو بوو.
\q1 
\v 16 بە تەواوی پاڵپشتی لە مافی هەژار و نەدار کرد،
\q2 جا سەرکەوتوو بوو.
\q1 ئایا ئەمە واتای ئەوە نییە من دەناسێت؟»
\q4 ئەوە فەرمایشتی یەزدانە.
\q1 
\v 17 «بەڵام چاو و دڵی تۆ تەنها
\q2 لەسەر دەستکەوتی ناڕەوایە،
\q1 لەسەر ڕشتنی خوێنی بێتاوانە،
\q2 لەسەر ستەم و دەستدرێژییە.»
\m 
\v 18 لەبەر ئەوە یەزدان لەبارەی یەهۆیاقیمی کوڕی یۆشیای پاشای یەهوداوە ئەمە دەفەرموێت:
\q1 «بۆی نالاوێننەوە،
\q2 ”براڕۆ! خوشکەڕۆ!“
\q1 بۆی نالاوێننەوە،
\q2 ”گەورەڕۆ! شکۆی ڕۆ!“
\q1 
\v 19 بەڵکو وەک گوێدرێژ دەنێژرێت،
\q2 ڕادەکێشرێت و فڕێدەدرێت
\q2 دوور لە دەروازەکانی ئۆرشەلیم.»
\b
\q1 
\v 20 «ئەی ئۆرشەلیم، بڕۆ سەر لوبنان و هاوار بکە،
\q2 با لە باشان دەنگت ببیسترێت،
\q1 لە عەڤاریمەوە هاوار بکە،
\q2 چونکە هەموو هاوپەیمانەکانت وردوخاش کران.
\q1 
\v 21 لە ئاسوودەییت ئاگادارم کردیتەوە،
\q2 بەڵام گوتت: ”گوێ ناگرم.“
\q1 لە گەنجییەوە لەمە لێڕاهاتوویت،
\q2 کە گوێڕایەڵی من نابیت.
\q1 
\v 22 هەموو شوانەکانت\f + \fr 22:22 \ft شوانەکانت مەبەست لە ڕابەرەکانە.‏\f* با بەڕێوەیان دەبات و
\q2 هاوپەیمانەکانت ڕاپێچ دەکرێن،
\q1 ئەوسا ڕیسوا و شەرمەزار دەبیت
\q2 لەبەر هەموو خراپەکانت.
\q1 
\v 23 ئەی نیشتەجێی ”لوبنان“\f + \fr 22:23 \ft مەبەستی لە کۆشکی شاهانەی ئۆرشەلیمە. بڕوانە ئایەتی 6، 7، 15، هەروەها \xt یەکەم پاشایان 7‏:2‏\xt*\ft ‏.‏\f*،
\q2 ئەی ئەوەی لەناو دار ئورزەکان هێلانەت کردووە،
\q1 چەند دەناڵێنیت کە ژان دەتگرێت،
\q2 وەک ژنێک کە منداڵی دەبێت!»
\p 
\v 24 یەزدان دەفەرموێت: «بە گیانی خۆم، ئەی یەهۆیاکینی کوڕی یەهۆیاقیمی پاشای یەهودا، تەنانەت ئەگەر ئەنگوستیلەیەک بیت لە دەستی ڕاستم، لە پەنجەی خۆمت دەکەمەوە و
\v 25 دەتدەمە دەستی ئەوانەی دەیانەوێ لەناوت ببەن، دەستی ئەوانەی تۆ لێیان دەترسیت، نەبوخودنەسری پاشای بابل و بابلییەکان.
\v 26 خۆت و دایکت، ئەوەی تۆی بووە فڕێتاندەدەمە سەر خاکێکی دیکە، کە لەوێ لەدایک نەبوونە، جا لەوێ دەمرن.
\v 27 هەرگیز ناگەڕێنەوە ئەو خاکەی بۆی پەرۆشن.»
\q1 
\v 28 ئایا ئەم پیاوە، یەهۆیاکین، قاپێکی ڕیسوا و شکاوە؟
\q2 ئایا شتێکە کەس نایەوێت؟
\q1 بۆچی خۆی و نەوەکانی فڕێدران،
\q2 تێهەڵدرانە خاکێک کە نایناسن؟
\q1 
\v 29 ئەی خاک! ئەی خاک! ئەی خاک!
\q2 گوێ لە فەرمایشتی یەزدان بگرە!
\q1 
\v 30 یەزدان ئەمە دەفەرموێت:
\q1 «ئەم پیاوە بە وەجاخکوێر بنووسن،
\q2 پیاوێک کە لە ماوەی ژیانی خۆی سەرکەوتوو نابێت،
\q1 کەس لە نەوەی ئەو سەرکەوتوو نابێت،
\q2 کەسیان لەسەر تەختی داود دانانیشن و
\q2 جارێکی دیکە فەرمانڕەوایەتی یەهودا ناکەن.»
\c 23
\s1 لقە ڕاستودروستەکە
\p 
\v 1 یەزدان دەفەرموێت: «قوڕبەسەر ئەو شوانانەی مەڕی مێگەلەکەم دەفەوتێنن و پەرتوبڵاوی دەکەنەوە!»
\v 2 لەبەر ئەوە یەزدانی پەروەردگاری ئیسرائیل لەبارەی ئەو شوانانەی کە شوانایەتی گەلەکەی من دەکەن، ئەمە دەفەرموێت: «ئێوە مەڕەکانی منتان پەرتوبڵاوکردەوە و دەرتانکرد و گرنگیتان پێنەدا، لەبەر ئەوە منیش لەسەر خراپی کردەوەکانتان سزاتان دەدەم.» ئەوە فەرمایشتی یەزدانە.
\v 3 «بەڵام من پاشماوەی مێگەلەکەی خۆم لە هەموو ئەو خاکانە کۆدەکەمەوە کە دەرمکردن بۆی، دەیانگەڕێنمەوە بۆ لەوەڕگاکانیان و زاوزێ دەکەن و زۆر دەبن.
\v 4 ئینجا شوانیان بۆ دادەنێم و شوانایەتییان دەکەن، ئیتر ناترسن و ناتۆقن و ون نابن.» ئەوە فەرمایشتی یەزدانە.
\q1 
\v 5 یەزدان دەفەرموێت: «ئەوەتا سەردەمێک دێت،
\q2 لقێکی ڕاستودروست لە داودەوە هەڵدەستێنم،
\q1 پاشایەک بە دانایی پاشایەتی دەکات،
\q2 ڕاستودروستی و دادپەروەری لە زەویدا پەیڕەو دەکات.
\q1 
\v 6 لە سەردەمی ئەودا یەهودا ڕزگاری دەبێت و
\q2 ئیسرائیل بە ئاسوودەیی نیشتەجێ دەبێت.
\q1 ئەو ناوەی کە پێی دەناسرێت:
\q2 ”یەزدان ڕاستودروستیمانە.“»
\m 
\v 7 یەزدان دەفەرموێت: «لەبەر ئەوە ئەوەتا سەردەمێک دێت، چیتر ناڵێن: ”بە یەزدانی زیندوو، ئەوەی نەوەی ئیسرائیلی لە خاکی میسرەوە دەرهێنا،“
\v 8 بەڵکو دەڵێن: ”بە یەزدانی زیندوو، ئەوەی ڕەچەڵەکی بنەماڵەی ئیسرائیلی لە خاکی باکوورەوە دەرهێنا و لە هەموو ئەو خاکانەوە بۆ ئەوێ دەریکردن.“ ئەوانیش لەسەر خاکەکەی خۆیان نیشتەجێ دەبن.»
\s1 پێغەمبەرە درۆزنەکان
\p 
\v 9 سەبارەت بە پێغەمبەرەکان:
\q1 دڵم لە ناخمدا وردوخاش بووە،
\q2 هەموو ئێسکەکانم دەلەرزن.
\q1 من وەک کەسێکی سەرخۆشم لێهات،
\q2 وەک پیاوێک شەراب بەسەریدا زاڵ بووبێت،
\q1 لەبەر یەزدان و
\q2 لەبەر فەرموودە پیرۆزەکانی.
\q1 
\v 10 خاکەکە پڕ بووە لە داوێنپیسان،
\q2 خاکەکە لەبەر نەفرەت دەناڵێنێت،
\q2 لەوەڕگاکانی چۆڵەوانی وشک بوون.
\q1 پێغەمبەران لەسەر ڕێڕەوی خراپە دەڕۆن و
\q2 دەسەڵاتیان بۆ ستەم بەکاردەهێنن.
\b
\q1 
\v 11 «پێغەمبەر و کاهین هەردووکیان گڵاوبوون،
\q2 تەنانەت لە پەرستگاکەشم خراپەی ئەوانم بەرچاوکەوت.»
\q4 ئەوە فەرمایشتی یەزدانە.
\q1 
\v 12 «لەبەر ئەوە ڕێگاکانیان خلیسکە بۆیان،
\q2 بۆ ناو تاریکی دەردەکرێن و
\q2 لەوێ دەخزێن،
\q1 چونکە بەڵایان بەسەردا دەهێنم
\q2 لە ساڵی سزادانیان.»
\q4 ئەوە فەرمایشتی یەزدانە.
\b
\q1 
\v 13 «لەنێو پێغەمبەرەکانی سامیرەدا
\q2 قێزەونییەکەم بینی،
\q1 بەهۆی بەعلەوە پێشبینی دەکەن و
\q2 ئیسرائیلی گەلی من گومڕا دەکەن.
\q1 
\v 14 لەنێو پێغەمبەرەکانی ئۆرشەلیمیش
\q2 ئەوەی بینیم موچڕکە بە لەشدا دەهێنێت:
\q2 داوێنپیسی و ڕێی درۆیان گرتووەتەبەر،
\q1 خراپەکاران هاندەدەن
\q2 بۆ ئەوەی کەس لە خراپەکەی نەگەڕێتەوە.
\q1 ئەوان بۆ من وەک سەدۆمیان لێهاتووە،
\q2 خەڵکی ئۆرشەلیمیش وەک عەمۆرا.»
\p 
\v 15 لەبەر ئەوە یەزدانی سوپاسالار سەبارەت بە پێغەمبەرەکان ئەمە دەفەرموێت:
\q1 «ئەوەتا من زەقنەبووتیان دەرخوارد دەدەم و
\q2 ئاوی ژەهراوییان پێ دەنۆشم،
\q1 چونکە لەلای پێغەمبەرەکانی ئۆرشەلیمەوە
\q2 گڵاوی بۆ هەموو زەوی بڵاو بووەوە.»
\p 
\v 16 یەزدانی سوپاسالار ئەمە دەفەرموێت:
\q1 «گوێ لە قسەی ئەو پێغەمبەرانە مەگرن کە پێشبینیتان بۆ دەکەن،
\q2 چونکە ئەوان تەفرەتان دەدەن.
\q1 لە خەیاڵی بیری خۆیانەوە دەدوێن،
\q2 نەک لەسەر زمانی یەزدانەوە.
\q1 
\v 17 ئەوانەی سووکایەتی بە من دەکەن، دەڵێن،
\q2 ”یەزدان دەفەرموێت، ئاشتیتان بۆ دەبێت.“
\q1 هەروەها هەموو ئەوانەی بەدوای کەللەڕەقی خۆیان کەوتوون، دەڵێن،
\q2 ”خراپەتان بەسەرنایەت.“
\q1 
\v 18 بەڵام کامیان لە ئەنجومەنی یەزدان\f + \fr 23:18 \ft یەرمیا لەو باوەڕەدا بوو، کە پێغەمبەرێکی ڕاستەقینە بانگهێشت دەکرێت بۆ ئەنجومەنی ئاسمان بۆ ئەوەی پەیامی یەزدان وەربگرێت.‏\f* ڕاوەستا و
\q2 بینی و گوێی لە فەرموودەکانی بوو؟
\q2 کامیان فەرموودەکانی بیست و گوێی لێ گرت؟
\q1 
\v 19 ئەوەتا ڕەشەبای یەزدان
\q2 لە تووڕەییدا هەڵدەچێت،
\q1 گەردەلوولێکی ڕاماڵە
\q2 لەسەر سەری بەدکاران هەڵدەکات.
\q1 
\v 20 تووڕەیی یەزدان دانامرکێتەوە
\q2 هەتا نیازەکانی دڵی خۆی
\q2 بە تەواوی جێبەجێ نەکات.
\q1 لە داهاتوودا
\q2 بە ڕوونی تێی دەگەن.
\q1 
\v 21 من ئەو پێغەمبەرانەم نەنارد،
\q2 بە پەلە پەیامیان ڕاگەیاند،
\q1 من قسەم لەگەڵیان نەکرد،
\q2 کەچی خۆیان پێشبینییان کرد.
\q1 
\v 22 بەڵام ئەگەر لە ئەنجومەنی مندا بووەستابان،
\q2 فەرموودەکانی منیان بە گەلەکەم ڕادەگەیاند و
\q1 لە ڕێگا خراپەکانیان و
\q2 لە خراپەی کردەوەکانیان دەیانگێڕانەوە.
\b
\q1 
\v 23 «ئایا من تەنها لە نزیکەوە خودام و
\q2 لە دوورەوە خودا نیم؟»
\q4 ئەوە فەرمایشتی یەزدانە.
\q1 
\v 24 «یان کەس هەیە لە پەناگا خۆی بشارێتەوە و
\q2 من نەیبینم؟
\q2 ئایا من ئاسمان و زەوی پڕناکەمەوە؟»
\q4 ئەوە فەرمایشتی یەزدانە.
\p 
\v 25 «گوێم لە قسەی ئەو پێغەمبەرانە بوو کە بە درۆ بە ناوی منەوە پێشبینی دەکەن، دەڵێن: ”خەونم بینی! خەونم بینی!“
\v 26 هەتا کەی ئەمە لە دڵی ئەو پێغەمبەرە درۆزنانە دەبێت کە بە خەیاڵی بیری خۆیان پێشبینی بکەن؟
\v 27 بەو خەونانەی بۆ یەکتری دەگێڕنەوە وای لێک دەدەنەوە ناوی من لەبیری گەلەکەم ببەنەوە، وەک چۆن باوباپیرانیان لەبەر پەرستنی بەعل ناوی منیان لەبیرچوو.
\v 28 با ئەو پێغەمبەرەی خەونی هەیە خەونەکەی بگێڕێتەوە، بەڵام با ئەوەی فەرموودەی منی لەلایە بە دڵسۆزییەوە فەرموودەی من ڕابگەیەنێت! گەنم و کا زۆر لە یەکتری جیاوازن.» ئەوە فەرمایشتی یەزدانە.
\v 29 «ئایا فەرموودەکانم وەک ئاگر نین؟ وەک چەکوش بەرد وردوخاش ناکەن؟» ئەوە فەرمایشتی یەزدانە.
\p 
\v 30 یەزدان دەفەرموێت: «لەبەر ئەوە ئەوەتا من لە دژی ئەو پێغەمبەرانەم، ئەوانەی فەرموودەکان لە یەکتری دەدزن، جا دەڵێن کە لە منەوە هاتووە.
\v 31 ئەوەتا من لە دژی ئەو پێغەمبەرانەم، ئەوانەی زمانیان دەخەنەگەڕ و ڕایدەگەیەنن: ”ئەوە فەرمایشتی یەزدانە.“
\v 32 ئەوەتا من لە دژی ئەو پێغەمبەرانەم کە بە خەونی درۆوە پێشبینی دەکەن، ئەوانەی بە شانازییەوە درۆکانیان دەگێڕنەوە و گەلەکەم گومڕا دەکەن، بەڵام من نە ناردوومن و نە فەرمانم پێکردوون. هیچ سوودێکیش بەم گەلە ناگەیەنن.» ئەوە فەرمایشتی یەزدانە.
\s1 پەیام و پێغەمبەرایەتی درۆزن
\p 
\v 33 «کاتێک ئەم گەلە یان پێغەمبەر یان کاهینێک لێت دەپرسێت: ”سروشی یەزدان چییە؟“ پێیان بڵێ: ”سروشی چی؟ یەزدان دەفەرموێت: من لە کۆڵ خۆمتان دەکەمەوە.“
\v 34 هەرکەسێک، پێغەمبەر یان کاهین یان لە گەل، ئەگەر وا بڵێت: ”ئەمە سروشی یەزدانە،“ خۆی و ماڵەکەی سزا دەدەم.
\v 35 ئاوا بە یەکتری دەڵێن، هەریەکە بە برادەرەکەی و هەریەکە بە براکەی: ”وەڵامی یەزدان چی بوو؟ یەزدان چی فەرموو؟“
\v 36 بەڵام چیتر باسی ”سروشی یەزدان“ ناکەن، چونکە هەرکەسە و قسەکەی خۆی دەبێت بە سروشەکەی، ئێوە دەستکاری فەرموودەکانی خودای زیندووتان کرد، فەرموودەکانی خودامان، یەزدانی سوپاسالار.
\v 37 ئاوا بە هەر پێغەمبەرێک دەڵێیت: ”وەڵامی یەزدان چی بوو؟ یەزدان چی فەرموو؟“
\v 38 هەرچەندە وا بڵێن: ”ئەمە سروشی یەزدانە،“ یەزدان ئەمە دەفەرموێت: لەبەر ئەوەی ئەم قسەیە دەکەن: ”ئەمە سروشی یەزدانە،“ هەرچەندە من بۆم ناردوون کە وا نەڵێن: ”ئەمە سروشی یەزدانە،“
\v 39 لەبەر ئەوە بە تەواوی لەبەردەمی خۆم هەڵتاندەگرم و لە کۆڵ خۆمتان دەکەمەوە، خۆتان و ئەم شارەش کە بە خۆتان و باوباپیرانتانم داوە.
\v 40 ڕیسواییەکی هەتاهەتایی و سەرشۆڕییەکی هەتاهەتاییتان لەسەر دادەنێم کە هەرگیز لەیاد نەچێت.»
\c 24
\s1 دوو سەبەتە هەنجیر
\p 
\v 1 پاش ئەوەی نەبوخودنەسری پاشای بابل، یەهۆیاکینی کوڕی یەهۆیاقیمی پاشای یەهودا و پیاوە گەورەکانی یەهودا و پیشەوەر و ئاسنگەرەکانی لە ئۆرشەلیمەوە ڕاپێچ کرد و هەموویانی هێنایە بابل، یەزدان دوو سەبەتە هەنجیری پیشاندام کە لەبەردەم پەرستگای یەزدان دانراون.
\v 2 یەکێک لە سەبەتەکان هەنجیرەکەی زۆر باش بوو وەک هەنجیری یەکەم بەر، لە سەبەتەکەی دیکەشدا هەنجیرێکی زۆر خراپ، لە خراپیدا نەدەخورا.
\p 
\v 3 جا یەزدان پێی گوتم: «یەرمیا، چی دەبینیت؟»
\p منیش گوتم: «هەنجیر. هەنجیرە باشەکە زۆر باشە، هەنجیرە خراپەکەش زۆر خراپە، لە خراپیدا ناخورێت.»
\p 
\v 4 ئینجا فەرمایشتی یەزدانم بۆ هات:
\v 5 «یەزدانی پەروەردگاری ئیسرائیل ئەمە دەفەرموێت: ”وەک ئەو هەنجیرە باشە، من ڕاپێچکراوەکانی یەهودا بە باش دادەنێم، ئەوەی لەم شوێنەوە ناردم بۆ خاکی بابلییەکان.
\v 6 چاوم دەخەمە سەریان بۆ چاکە و دەیانگەڕێنمەوە بۆ ئەم خاکە و بنیادیان دەنێم و نایانڕووخێنم، دەیانچێنم و ڕیشەکێشیان ناکەم.
\v 7 دڵێکیان دەدەمێ بۆ ناسینم، کە من یەزدانم و ئەوان دەبن بە گەلی من و منیش دەبم بە خودای ئەوان، چونکە بە هەموو دڵیانەوە دەگەڕێنەوە لام.“»
\p 
\v 8 یەزدان ئەمە دەفەرموێت: «”وەک ئەو هەنجیرە خراپەش کە لە خراپیدا ناخورێت، ئاوا هەڵسوکەوت لەگەڵ سدقیای پاشای یەهودا و پیاوە گەورەکانی و پاشماوەی ئۆرشەلیمدا دەکەم، ئەوانەی لەم خاکەدا ماونەتەوە و ئەوانەی لە خاکی میسر نیشتەجێن.
\v 9 هەموو شانشینەکانی زەوی لێیان دەتۆقن و دەیانکەمە بەڵا و ڕیسوایی و پەند و گاڵتەجاڕی و نەفرەت لە هەموو ئەو شوێنانەی دەریاندەکەم بۆی.
\v 10 شمشێر و قاتوقڕی و دەرد دەنێرمە سەریان، هەتا بە تەواوی لەناودەچن لەسەر ئەو خاکەی دامە خۆیان و باوباپیرانیان.“»
\c 25
\s1 ڕاپێچکردنی گەلی خودا بۆ ماوەی حەفتا ساڵ
\p 
\v 1 ئەو پەیامەی لە ساڵی چوارەمی یەهۆیاقیمی کوڕی یۆشیای پاشای یەهودا، کە دەکاتە ساڵی یەکەمی نەبوخودنەسری پاشای بابل، سەبارەت بە هەموو گەلی یەهودا بۆ یەرمیا هات.
\v 2 ئەوەی یەرمیای پێغەمبەر سەبارەت بە هەموو گەلی یەهودا و بۆ هەموو دانیشتووانی ئۆرشەلیم ڕایگەیاند:
\v 3 «لە ساڵی سێزدەیەمینی یۆشیای کوڕی ئامۆنی پاشای یەهوداوە هەتا ئەمڕۆ، ئەم بیست و سێ ساڵە، فەرمایشتی یەزدانم بۆ دەهات و منیش بەردەوام قسەم لەگەڵ کردن، بەڵام ئێوە گوێتان نەگرت.
\p 
\v 4 «یەزدانیش بەردەوام هەموو بەندە پێغەمبەرەکانی خۆی بۆ ناردن، بەڵام ئێوە گوێتان نەگرت و گرنگیتان پێنەدا.
\v 5 پێیان گوتن: ”لە ڕەفتارە ناشیرین و کردەوە خراپەکانتان بگەڕێنەوە، بۆ ئەوەی نیشتەجێ بن لەسەر ئەو خاکەی کە یەزدان داویەتییە ئێوە و باوباپیرانتان، لە ئەزەلەوە و بۆ هەتاهەتایە.
\v 6 شوێنی خوداوەندەکانی دیکە مەکەون بۆ ئەوەی بیانپەرستن و کڕنۆشیان بۆ ببەن. بە دروستکراوەکانی دەستتان پەستم مەکەن و منیش سزاتان نادەم.“»
\p 
\v 7 یەزدان دەفەرموێت: «بەڵام گوێتان لێم نەگرت، بۆ ئەوەی بە دروستکراوەکانی دەستتان پەستم بکەن، بەخۆتان سزاتان بۆ سەر خۆتان هێنا.»
\p 
\v 8 لەبەر ئەوە یەزدانی سوپاسالار ئەمە دەفەرموێت: «لەبەر ئەوەی ئێوە گوێتان لە قسەی من نەگرت،
\v 9 ئەوەتا دەنێرم و هەموو خێڵەکانی باکوور کۆدەکەمەوە، هەروەها نەبوخودنەسری خزمەتکارم، پاشای بابل، جا دەیانهێنمە سەر ئەم خاکە و سەر دانیشتووانەکەی و سەر هەموو ئەو نەتەوانەی دەوروبەری. بە تەواوی قڕیان دەکەم\f + \fr 25:9 \ft قڕیان دەکەم: لە زمانی عیبری ئەم زاراوەیە دەگەڕێتەوە بۆ شتێک یان کەسێک کە دەبەخشرێت بە یەزدان، زۆر جار بەخشینەکە بە تەواوی لە ناودەبردرێت.‏\f*، دەیانکەمە پەند و تانە و تەشەر و وێرانییەکی هەتاهەتایی.
\v 10 دەنگی بەزم و شادی، دەنگی بووک و زاوا، دەنگی دەستاڕ و ڕووناکی چرایان ناهێڵم.
\v 11 هەموو ئەم خاکە دەبێتە وێرانەیەکی چۆڵ، ئەم نەتەوانەش حەفتا ساڵ خزمەتی پاشای بابل دەکەن.» ئەوە فەرمایشتی یەزدانە.
\p 
\v 12 یەزدان دەفەرموێت: «کە حەفتا ساڵەکە تەواو بوو، سزای پاشای بابل و ئەو نەتەوەیە دەدەم، لەسەر تاوانەکانیان، سزای خاکی بابلییەکانیش دەدەم و دەیکەمە چۆڵەوانییەکی هەتاهەتایی.
\v 13 هەموو ئەوەی لەم پەڕتووکەدا نووسراوە، ئەوەی یەرمیا سەبارەت بە هەموو ئەم نەتەوانە پێشبینیی کرد، هەموو ئاگادارکردنەوەیەکی تێدا هاتووە کە سەبارەت بەو خاکە فەرموومە پەیڕەوی دەکەم،
\v 14 چونکە ئەوانیش دەبنە کۆیلەی زۆر نەتەوە و پاشای گەورە، بەگوێرەی کردەوە و کارەکانی خۆیان سزایان دەدەمەوە.»
\s1 جامی تووڕەیی خودا
\p 
\v 15 یەزدانی پەروەردگاری ئیسرائیل ئاوای بە من فەرموو: «جامی شەرابی ئەم تووڕەییە لە دەستم وەربگرە و دەرخواردی هەموو ئەو نەتەوانەی بدە کە من دەتنێرم بۆ لایان.
\v 16 کاتێک دەیخۆنەوە، بەلادادێن و شێت دەبن لەبەر ئەو شمشێرەی کە من دەینێرمە ناویان.»
\v 17 منیش جامەکەم لە دەستی یەزدان وەرگرت، دەرخواردی هەموو ئەو نەتەوانەم دا کە یەزدان ناردمی بۆیان:
\b
\li1 
\v 18 بۆ ئۆرشەلیم و شارۆچکەکانی یەهودا و پاشا و پیاوە گەورەکانی، تاکو وێران بن و ببنە پەند و مایەی تانە و تەشەر و نەفرەت لێکردن، هەروەک ئێستا؛
\li1 
\v 19 بۆ فیرعەونی پاشای میسر و خزمەتکار و پیاوە گەورەکانی و هەموو گەلەکەی
\v 20 و هەموو بێگانەکانی ئەوێ؛
\li1 بۆ هەموو پاشاکانی خاکی عوچ؛
\li1 بۆ هەموو پاشاکانی خاکی فەلەستییەکان؛ ئەسقەلان و غەزە و عەقرۆن و پاشماوەی ئەشدۆد؛
\li1 
\v 21 بۆ ئەدۆم و مۆئاب و عەمۆنییەکان؛
\li1 
\v 22 بۆ هەموو پاشاکانی سور و هەموو پاشاکانی سەیدا؛
\li1 بۆ پاشاکانی کەنارەکان، ئەوانەی لەوبەری دەریان؛
\li1 
\v 23 بۆ دیدان و تێما و بووز و هەموو قژبڕاوەکان\f + \fr 25:23 \ft خەڵکێک بوونە وەک نەریتێکی بتپەرستی پرچیان بڕیوە.‏\f*؛
\li1 
\v 24 بۆ هەموو پاشاکانی عەرەبستان و سەرکردەی هەموو هۆزەکانی نیشتەجێی بیابان؛
\li1 
\v 25 بۆ هەموو پاشاکانی زیمری و ئیلام و میدیا؛
\li1 
\v 26 بۆ هەموو پاشاکانی باکوور، نزیک و دووریان، یەک لەدوای یەک؛ بۆ هەموو شانشینەکانی جیهان لەسەر ڕووی زەوی.
\li1 لەدوای هەموویانەوە، هەروەها پاشای شێشەخ\f + \fr 25:26 \ft ناوی نهێنی بابل بووە.‏\f* ئەو جامە دەخواتەوە.
\b
\p 
\v 27 «پێیان دەڵێیت: ”یەزدانی سوپاسالار، خودای ئیسرائیل ئەمە دەفەرموێت: بخۆنەوە و سەرخۆش بن و بڕشێنەوە، بکەون و هەڵمەستنەوە لەبەر ئەو شمشێرەی من دەینێرمە ناوتان.“
\v 28 ئەگەر ڕازی نەبوون جامەکە لە دەستت وەربگرن بۆ ئەوەی بیخۆنەوە، پێیان بڵێ: ”یەزدانی سوپاسالار ئەمە دەفەرموێت: دەبێت بیخۆنەوە!
\v 29 ئەوەتا ئەو شارەی ناوی منی هەڵگرتووە، من دەستم پێکردووە بەڵای بەسەردا بهێنم، ئیتر ئایا ئێوە بێ سزا دەبن؟ نەخێر بێ سزا نابن! چونکە من شمشێر دەهێنمە سەر هەموو دانیشتووانی زەوییەکە.“ ئەمە فەرمایشتی یەزدانی سوپاسالارە.
\p 
\v 30 «تۆش هەموو ئەو پەیامەی من لە دژی ئەوان ڕابگەیەنە و پێیان بڵێ:
\q1 «”یەزدان لە ئاسمان دەنەڕێنێت،
\q2 لە نشینگەی پیرۆزیەوە دەنگ هەڵدەبڕێت و
\q2 بەهێز بەسەر خاکی خۆیدا دەنەڕێنێت.
\q1 وەک ئەوانەی ترێ پێپەست دەکەن بە هوتافەوە هاوار دەکات
\q2 بەسەر هەموو دانیشتووانی زەوی.
\q1 
\v 31 هاتوهاوار گەیشتە ئەوپەڕی زەوی،
\q2 چونکە یەزدان سکاڵا لە نەتەوەکان دەکات،
\q1 دادوەری هەموو ئادەمیزاد دەدات و
\q2 بەدکارەکان دەداتە بەر شمشێر.“»
\q4 ئەوە فەرمایشتی یەزدانە.
\p 
\v 32 یەزدانی سوپاسالار ئەمە دەفەرموێت:
\q1 «ئاگاداربن! بەڵا بڵاو دەبێتەوە
\q2 لە نەتەوەیەکەوە بۆ نەتەوەیەک،
\q1 گەردەلوولێکی گەورە هەڵدەکات
\q2 لەوپەڕی زەوییەوە.»
\m 
\v 33 لەو ڕۆژەدا، ئەوانەی بە دەستی یەزدان دەکوژرێن لەمپەڕی زەوییەوە هەتا ئەوپەڕی زەوی دەبن، شیوەنیان بۆ ناگێڕدرێت و کۆناکرێنەوە و نانێژرێن، بەڵکو دەبنە زبڵ بەسەر ڕووی خاکەکەوە.
\q1 
\v 34 ئەی شوانەکان، واوەیلا و هاوار بکەن!
\q2 ئەی سەرپەرشتیارانی مێگەل، خۆتان بگەوزێنن،
\q1 چونکە کاتتان هاتووە بۆ سەربڕین،
\q2 وەک گۆزەیەکی بە نرخ دەکەون و تێکدەشکێنرێن.
\q1 
\v 35 پەناگا بۆ شوانەکان نامێنێت،
\q2 دەربازبوونیش بۆ سەرپەرشتیارانی مێگەل.
\q1 
\v 36 گوێ بگرە لە هاواری شوانەکان و
\q2 واوەیلای سەرپەرشتیارانی مێگەل،
\q2 چونکە یەزدان لەوەڕگاکانیان تێکدەدات.
\q1 
\v 37 مێرگەکانی ئاشتی لەناودەچن
\q2 لەبەر جۆشی تووڕەیی یەزدان.
\q1 
\v 38 ئەو وەک بەچکە شێر لانەی خۆی بەجێدەهێڵێت،
\q2 چونکە خاکەکە وێران دەبێت
\q1 لەبەر شمشێری ستەمکار و
\q2 لەبەر جۆشی تووڕەیی یەزدان.
\c 26
\s1 مەترسی یەرمیا
\p 
\v 1 لە سەرەتای پاشایەتی یەهۆیاقیمی کوڕی یۆشیای پاشای یەهودا، ئەو پەیامەم لەلایەن یەزدانەوە بۆ هات:
\v 2 «یەزدان ئەمە دەفەرموێت: لە حەسارەکەی ماڵی یەزدان بوەستە و ئەو پەیامە بۆ هەموو شارۆچکەکانی یەهودا ڕابگەیەنە، کاتێک دێنە ماڵی یەزدان بۆ کڕنۆش بردن. ئەو پەیامەی کە فەرمانم پێ کردیت یەک وشەی لێ کەم نەکەیتەوە.
\v 3 بەڵکو گوێیان لێ بێت و بگەڕێنەوە، هەریەکە و لە ڕێگا خراپەکانی، منیش پاشگەز دەبمەوە لەو بەڵایەی بە نیاز بووم لەبەر خراپی کردەوەکانیان بەسەریان بهێنم.
\v 4 پێیان بڵێ: ”یەزدان ئەمە دەفەرموێت: ئەگەر گوێ لە من نەگرن و فێرکردنەکەم پەیڕەو نەکەن کە لەبەردەمی ئێوە دامناوە،
\v 5 هەروەها ئەگەر گوێ لە قسەی بەندە پێغەمبەرەکانم نەگرن، ئەوانەی من بە بەردەوامی بۆم دەناردن، بەڵام ئێوە گوێتان نەگرت،
\v 6 ئەوا ئەم ماڵە وەک شیلۆ لێ دەکەم و ئەم شارەش دەکەم بە مایەی نەفرەت بۆ هەموو نەتەوەکانی سەر زەوی.“»
\p 
\v 7 جا کاهینەکان و پێغەمبەرەکان و هەموو گەل گوێیان لێ بوو یەرمیا لە ماڵی یەزدان ئەم پەیامەی ڕاگەیاند.
\v 8 کاتێک یەرمیا لە قسەکردن بووەوە، لە هەموو ئەوەی یەزدان فەرمانی پێکردبوو بە هەموو گەلی ڕابگەیەنێت، کاهین و پێغەمبەر و هەموو گەل گرتییان و گوتیان: «دەبێ بمریت!
\v 9 بۆچی بە ناوی یەزدانەوە پێشبینیت کرد و گوتت کە ئەم ماڵە وەک شیلۆی لێدێت، ئەم شارەش وێران دەبێت و ئاوەدانی تێدا نابێت؟» ئینجا هەموو گەل لە ماڵی یەزدان لە یەرمیا کۆبوونەوە.
\p 
\v 10 کاتێک پیاوە گەورەکانی یەهودا گوێیان لەم قسانە بوو، لە کۆشکی پاشاوە سەرکەوتن بۆ ماڵی یەزدان، لەلای داڵانی دەروازە نوێیەکەی ماڵی یەزدان دانیشتن.
\v 11 ئینجا کاهین و پێغەمبەرەکان بە پیاوە گەورەکان و بە هەموو گەلیان گوت: «ئەم پیاوەیە شایانی حوکمی مردنە، چونکە پێشبینی خراپی لەسەر ئەم شارە کردووە، هەروەک بە گوێی خۆتان گوێتان لێ بوو!»
\p 
\v 12 یەرمیاش بە پیاوە گەورەکان و هەموو گەلی گوت: «یەزدان منی نارد بۆ ئەوەی لەسەر ئەم ماڵە و ئەم شارە پێشبینی بکەم، بە هەموو ئەو وشانەی گوێتان لێ بوو.
\v 13 ئێستاش ڕەفتار و کردەوەکانتان چاک بکەنەوە و گوێڕایەڵی یەزدانی پەروەردگارتان بن، ئەویش پاشگەز دەبێتەوە لەو بەڵایەی سەبارەت بە ئێوە فەرموویەتی.
\v 14 بەڵام من لەبەردەستتانم، ئەوەی پێتان باشە و ڕاستە بە منی بکەن.
\v 15 بەڵام باش بزانن ئەگەر من بکوژن، ئەوا خوێنێکی بێتاوان دەخەنە ئەستۆی خۆتان و ئەم شارە و دانیشتووانەکەی، چونکە بەڕاستی یەزدان منی بۆ ئێوە ناردووە تاکو هەموو ئەم قسانە بەبەر گوێتاندا بدەم.»
\p 
\v 16 ئینجا پیاوە گەورەکان و هەموو گەل بە کاهین و پێغەمبەرەکانیان گوت: «ئەم پیاوە شایانی حوکمی مردنی نییە، چونکە بە ناوی یەزدانی پەروەردگارمانەوە قسەی لەگەڵ کردووین.»
\p 
\v 17 ئینجا هەندێک لە پیرانی یەهودا\f + \fr 26:17 \ft عیبری: خاکەکە.‏\f* هەستان و بە هەموو کۆمەڵی خەڵکەکەیان گوت:
\v 18 «میخای پێغەمبەر لە شاری مۆرەشەت لە سەردەمی حەزقیای پاشای یەهودا پێشبینیی کرد و بە هەموو گەلی یەهودای گوت: ”یەزدانی سوپاسالار ئەمە دەفەرموێت:
\q1 «”سییۆن وەک کێڵگە دەکێڵدرێت،
\q2 ئۆرشەلیم کاول دەبێت،
\q2 گردەکەی پەرستگاش دەبێتە دارستانێکی بێ کەڵک.“\f + \fr 26:18 \ft بڕوانە \xt میخا 3‏:12‏\xt*\ft ‏.‏\f*
\m 
\v 19 ئایا حەزقیای پاشای یەهودا یان کەسێکی دیکە لە یەهودا کوشتیان؟ ئایا لە یەزدان نەترسا و بەدوای ڕەزامەندی ئەوەوە نەبوو؟ ئایا یەزدان پاشگەز نەبووەوە لەو بەڵایەی فەرمووبووی بەسەریان دەهێنێت؟ وا بەڵایەکی گەورە بەسەر خۆمان دەهێنین!»
\p 
\v 20 هەروەها پیاوێکی دیکەش هەبوو بە ناوی یەزدانەوە پێشبینی دەکرد، ئوریای کوڕی شەمەعیا، خەڵکی قیریەت یەعاریم بوو. ئەویش لە دژی ئەو شارە و ئەو خاکە پەیامێکی ڕاگەیاند، وەک پەیامەکەی یەرمیا.
\v 21 جا یەهۆیاقیمی پاشا و هەموو پاڵەوانەکانی و هەموو پیاوە گەورەکان گوێیان لە قسەکانی بوو، پاشا داوای کرد بیکوژن. بەڵام ئوریا ئەمەی بیست، لە ترسان بەرەو میسر هەڵات.
\v 22 یەهۆیاقیمی پاشاش ئەلناتانی کوڕی عەکبۆری لەگەڵ چەند پیاوێک ناردە میسر.
\v 23 ئوریایان لە میسر دەرهێنا و هێنایانە لای یەهۆیاقیمی پاشا، بە شمشێر لێیدا و تەرمەکەی فڕێدایە ناو گۆڕی خەڵکی ئاسایی.
\p 
\v 24 جگە لەوەش، ئەحیقامی کوڕی شافان پشتگیری یەرمیای کرد بۆ ئەوەی نەدرێتە دەست گەل و بیکوژن.
\c 27
\s1 یەهودا خزمەتی نەبوخودنەسر دەکات
\p 
\v 1 لە سەرەتای پاشایەتی سدقیای کوڕی یۆشیای پاشای یەهودا، ئەم پەیامە لەلایەن یەزدانەوە بۆ یەرمیا هات:
\v 2 یەزدان ئەمەی بە من فەرموو: «گوریس و دار ببە و بۆ خۆت نیرێکی لێ دروستبکە و بیخە سەر ملت.
\v 3 ئینجا پەیامێک بنێرە بۆ پاشاکانی ئەدۆم و مۆئاب و عەمۆن و سور و سەیدا، بەدەستی ئەو پەیامبەرانەی بۆ ئۆرشەلیم هاتوون بۆ لای سدقیای پاشای یەهودا.
\v 4 ڕایانبسپێرە بە گەورەکانیان بڵێن: ”یەزدانی سوپاسالار، خودای ئیسرائیل ئەمە دەفەرموێت: ’ئەمە بە گەورەکانتان بڵێن:
\v 5 من بە توانای مەزنی خۆم و بە دەستی بەهێزم زەویم دروستکردووە، هەروەها مرۆڤ و ئاژەڵیش کە لەسەرین، ئەوەی بمەوێ دەیدەمێ.
\v 6 ئێستاش من هەموو ئەم خاکانە دەدەمە دەستی خزمەتکارەکەم، نەبوخودنەسری پاشای بابل، هەروەها ئاژەڵە کێوییەکانیشی دەدەمێ تاکو خزمەتی بکەن.
\v 7 هەموو نەتەوەکانیش خزمەتی خۆی و کوڕ و نەوەکەی دەکەن، هەتا کاتی خاکەکەی ئەویش دێت، جا زۆر لە نەتەوەکان و پاشا مەزنەکان دەیخەنە ژێردەستی خۆیان.‘
\p 
\v 8 «”یەزدان دەفەرموێت: ’هەر نەتەوەیەک و شانشینێک خزمەتی نەبوخودنەسری پاشای بابل نەکات و مل نەخاتە ژێر نیری پاشای بابلەوە، بە شمشێر و قاتوقڕی و دەرد سزای ئەو نەتەوەیە دەدەم، هەتا بە دەستی ئەو لەناویان دەبەم.
\v 9 ئێوەش گوێ مەگرن لە پێغەمبەر و فاڵگرەوە و خەونبین و بەخت خوێنەر و جادووگەرەکانتان، ئەوانەی پێتان دەڵێن: ”خزمەتی پاشای بابل ناکەن.“
\v 10 ئەوان بە درۆ پێشبینیتان بۆ دەکەن، ئەمەش دەبێتە هۆکاری دوورخستنەوەتان، جا دەرتاندەکەم و لەناودەچن.
\v 11 بەڵام ئەگەر هەر نەتەوەیەک ملی بخاتە ژێر نیری پاشای بابل و خزمەتی بکات، من لە خاکی خۆیدا دەیهێڵمەوە، جا دەیکێڵێت و تێیدا نیشتەجێ دەبێت.‘ ئەوە فەرمایشتی یەزدانە.“»
\p 
\v 12 هەمان پەیامم بە سدقیای پاشای یەهوداش ڕاگەیاند\f + \fr 27:12 \ft یەرمیای پێغەمبەر پەیامی خودای گەیاندووەتە سدقیای پاشا.‏\f*: «ملتان بخەنە ژێر نیری پاشای بابل و خزمەتی خۆی و گەلەکەی بکەن، ئینجا ئێوە دەژین.
\v 13 بۆچی خۆت و گەلەکەت بە شمشێر و قاتوقڕی و دەرد لەناوبچن، وەک ئەوەی یەزدان سەبارەت بەو گەلە فەرمووی کە خزمەتی پاشای بابل نەکات؟
\v 14 گوێ لە پەیامی ئەو پێغەمبەرانە مەگرن کە پێتان دەڵێن: ”خزمەتی پاشای بابل ناکەن،“ چونکە ئەوان بە درۆ پێشبینیتان بۆ دەکەن.
\v 15 ”من نەمناردوون، ئەوان بە درۆ بە ناوی منەوە پێشبینی دەکەن، لەبەر ئەوە دەرتاندەکەم و لەناودەچن، خۆتان و ئەو پێغەمبەرانەش کە پێشبینیتان بۆ دەکەن.“» ئەوە فەرمایشتی یەزدانە.
\p 
\v 16 بە کاهینەکان و بە هەموو ئەم گەلەشم گوت: «یەزدان ئەمە دەفەرموێت: گوێ لە قسەی پێغەمبەرەکانتان مەگرن، ئەوانەی پێشبینیتان بۆ دەکەن و دەڵێن: ”ئەوەتا قاپوقاچاغەکانی ماڵی یەزدان بەم زووانە لە بابلەوە دەگەڕێنرێنەوە.“ ئەوان بە درۆ پێشبینیتان بۆ دەکەن.
\v 17 گوێیان لێ مەگرن. خزمەتی پاشای بابل بکەن، ئینجا ئێوە دەژین. بۆچی ئەم شارە وێران بێت؟
\v 18 ئەگەر ئەمانە پێغەمبەرن و فەرمایشتی یەزدانیان لەلایە، کەواتە با بۆمان لە یەزدانی سوپاسالار بپاڕێنەوە، بۆ ئەوەی ئەو قاپوقاچاغەی ماوەتەوە لە ماڵی یەزدان و لە کۆشکی پاشای یەهودا و لە ئۆرشەلیم نەبردرێنە بابل،
\v 19 چونکە یەزدانی سوپاسالار ئەمە دەفەرموێت سەبارەت بە کۆڵەکەکان و حەوزە بڕۆنزییەکە\f + \fr 27:19 \ft کۆگای ئاو بووە، هەروەها پێی گوتراوە دەریا، بڕوانە \xt دەرچوون 30‏:17‏-21.‏\xt*\ft ‏\f* و عەرەبانەکانی ئاوگواستنەوە و پاشماوەی ئەو قاپوقاچاغانەی کە لەم شارەدا ماونەتەوە،
\v 20 ئەوانەی نەبوخودنەسری پاشای بابل نەیبردن، کاتێک یەهۆیاکینی کوڕی یەهۆیاقیمی پاشای یەهودای لە ئۆرشەلیمەوە بۆ بابل ڕاپێچ کرد، لەگەڵ هەموو پیاوماقوڵانی یەهودا و ئۆرشەلیم.
\v 21 بەڵێ، یەزدانی سوپاسالار، خودای ئیسرائیل ئەمە دەفەرموێت سەبارەت بەو قاپوقاچاغەی مابووەوە، لە ماڵی یەزدان و لە کۆشکی پاشای یەهودا و لە ئۆرشەلیم:
\v 22 ”بۆ بابل دەبردرێن و لەوێ دەمێننەوە هەتا ئەو ڕۆژەی بەدوایاندا دەنێرم، جا دەیانهێنمەوە و دەیانگەڕێنمەوە ئەم شوێنە.“» ئەوە فەرمایشتی یەزدانە.
\c 28
\s1 حەنەنیای پێغەمبەری درۆزن
\p 
\v 1 ئەوە بوو لە هەمان ساڵ، لە مانگی پێنجی ساڵی چوارەمی سەرەتای پاشایەتی سدقیای پاشای یەهودا، حەنەنیای پێغەمبەر کوڕی عازوور کە خەڵکی گبعۆنە، لە ماڵی یەزدان لەبەرچاوی کاهینەکان و هەموو گەل پێی گوتم:
\v 2 «یەزدانی سوپاسالار، خودای ئیسرائیل ئەمە دەفەرموێت: ”نیری پاشای بابل دەشکێنم.
\v 3 لە ماوەی دوو ساڵدا من هەموو قاپوقاچاغەکانی ماڵی یەزدان دەگەڕێنمەوە، ئەوانەی نەبوخودنەسری پاشای بابل لەم شوێنەوە بردییە بابل.
\v 4 یەهۆیاکینی کوڕی یەهۆیاقیمی پاشای یەهودا دەگەڕێنمەوە ئەم شوێنە، هەروەها هەموو ئەوانەش کە لەگەڵی بۆ بابل ڕاپێچ کرابوون، چونکە نیری پاشای بابل دەشکێنم.“ ئەوە فەرمایشتی یەزدانە.»
\p 
\v 5 یەرمیای پێغەمبەریش لەبەردەمی کاهینەکان و هەموو گەل ئەوانەی لە ماڵی یەزدان وەستابوون وەڵامی حەنەنیای پێغەمبەری دایەوە،
\v 6 گوتی: «ئامین! با یەزدان ئاوا بکات! با یەزدان قسەکانت بهێنێتە دی کە پێشبینیت کرد، قاپوقاچاغەکەی ماڵی یەزدان و هەموو ئەو کەسانەی ڕاپێچ کرابوون لە بابلەوە بگەڕێنێتەوە بۆ ئێرە.
\v 7 بەڵام گوێ لەم قسەیە بگرە کە من بە تۆ و بە هەموو گەلی دەڵێم:
\v 8 لە کۆنەوە، لەپێش من و تۆوە پێغەمبەران سەبارەت بە زۆر گەلان و پاشایەتییە گەورەکان پێشبینی جەنگ و بەڵا و دەردیان کردووە.
\v 9 بەڵام ئەو پێغەمبەرەی پێشبینی ئاشتی بکات، بە هاتنە دی پێشبینییەکەی، دەزانرێت کە بەڕاستی یەزدان ئەو پێغەمبەرەی ناردووە.»
\p 
\v 10 حەنەنیای پێغەمبەریش نیرەکەی لەسەر ملی یەرمیا هەڵگرت و شکاندی.
\v 11 حەنەنیا لەبەردەمی هەموو گەل گوتی: «یەزدان ئەمە دەفەرموێت: ”لە ماوەی دوو ساڵدا، ئاوا نیری نەبوخودنەسری پاشای بابل لە ملی هەموو نەتەوەکان دەشکێنم.“» یەرمیای پێغەمبەریش بە ڕێگای خۆیدا ڕۆیشت.
\p 
\v 12 دوای ئەوەی حەنەنیای پێغەمبەر نیرەکەی سەر ملی یەرمیای شکاند، فەرمایشتی یەزدان بۆ یەرمیا هات:
\v 13 «بڕۆ و بە حەنەنیا بڵێ: ”یەزدان ئەمە دەفەرموێت: تۆ نیرێکی دارینت شکاند، بەڵام تۆ لەجێی ئەوە نیرێکی ئاسنینت دەخرێتە سەر،
\v 14 چونکە یەزدانی سوپاسالار، خودای ئیسرائیل ئەمە دەفەرموێت: نیری ئاسنین دەخەمە سەر ملی هەموو ئەم نەتەوانە بۆ ئەوەی خزمەتی نەبوخودنەسری پاشای بابل بکەن، دەبنە کۆیلەی ئەو. تەنانەت دەسەڵاتم بەسەر ئاژەڵە کێوییەکانیش داوەتێ.“»
\p 
\v 15 ئینجا یەرمیا پێغەمبەر بە حەنەنیا پێغەمبەری گوت: «حەنەنیا گوێ بگرە! یەزدان تۆی نەناردووە، تۆش وات کردووە ئەم گەلە پشت بە درۆ ببەستێت.
\v 16 لەبەر ئەوە یەزدان ئەمە دەفەرموێت: ”خەریکم لەسەر ڕووی زەوی دەرتدەکەم، تۆ ئەم ساڵ دەمریت، چونکە تۆ جاڕی یاخیبوونت دا لە دژی یەزدان.“»
\p 
\v 17 جا حەنەنیای پێغەمبەر لە مانگی حەوتی ئەو ساڵەدا\f + \fr 28:17 \ft بە دوو مانگ لەدوای پێشبینییەکەی یەرمیا.‏\f* مرد.
\c 29
\s1 نامەیەک بۆ ڕاپێچکراوان
\p 
\v 1 ئەمە دەقی ئەو نامەیەیە کە یەرمیای پێغەمبەر لە ئۆرشەلیمەوە بۆ پاشماوەکانی نارد، پیر و کاهین و پێغەمبەر و هەموو گەل، هەموو ئەوانەی نەبوخودنەسر لە ئۆرشەلیمەوە بۆ بابل ڕاپێچی کردبوون،
\v 2 لەدوای ڕاپێچکردنی یەهۆیاکینی پاشا و شاژنی دایکی و دەستوپێوەندەکانی و پیاوە گەورەکانی یەهودا و ئۆرشەلیم، هەروەها پیشەوەر و ئاسنگەرەکانی ئۆرشەلیم.
\v 3 سدقیای پاشای یەهودا ئەلعاسای کوڕی شافان و گەمەریای کوڕی حیلقیای ناردە لای نەبوخودنەسری پاشای بابل. یەرمیاش نامەیەکی پێدا ناردن بۆ بابل و تێیدا گوتی:
\pm 
\v 4 یەزدانی سوپاسالار، خودای ئیسرائیل بە هەموو ئەوانە دەفەرموێت کە لە ئۆرشەلیمەوە بۆ بابل ڕاپێچی کردن:
\v 5 «خانوو بنیاد بنێن و نیشتەجێ بن؛ باخ بچێنن و بەروبوومی بخۆن.
\v 6 ژن بهێنن با کوڕ و کچتان ببێت؛ ژن بۆ کوڕتان بهێنن و کچتان بە مێرد بدەن، با ئەوانیش کوڕ و کچیان ببێت و لەوێ زۆر بن و کەم مەکەن.
\v 7 کار بکەن بۆ ئاشتی و گەشەسەندنی ئەو شارەی ئێوەم بۆ ئەوێ ڕاپێچ کردووە؛ نوێژ بکەن بۆ یەزدان لە پێناوی، چونکە بە گەشەسەندنی ئەو ئێوەش گەشە دەکەن.»
\v 8 یەزدانی سوپاسالار، خودای ئیسرائیل ئەمە دەفەرموێت: «با پێغەمبەر و فاڵگرەوەکان کە لەنێوتانن هەڵتاننەخەڵەتێنن و گوێ لە خەونەکانیان مەگرن کە بۆ ئێوەی دەبینن.
\v 9 ئەوان بە درۆ بە ناوی منەوە پێشبینیتان بۆ دەکەن. من ئەوانم نەناردووە.» ئەوە فەرمایشتی یەزدانە.
\pm 
\v 10 «یەزدان ئەمە دەفەرموێت: کاتێک حەفتا ساڵ لە بابل تەواو دەبێت، بەسەرتان دەکەمەوە و بەڵێنە باشەکەم سەبارەت بە ئێوە دەهێنمە دی، دەتانگەڕێنمەوە بۆ ئەم شوێنە.
\v 11 خۆم ئەو پلانە دەزانم کە بۆ ئێوەم داڕشتووە، پلان بۆ ئاشتی و گەشەسەندنی ئێوە نەک بۆ زیانتان، بۆ ئەوەی دواڕۆژ و هیواتان بدەمێ.» ئەوە فەرمایشتی یەزدانە.
\v 12 «جا لێم دەپاڕێنەوە و دێن و نوێژم بۆ دەکەن، منیش گوێتان لێ دەگرم.
\v 13 ڕووتان لە من دەکەن و بۆتان دەردەکەوم، کاتێک بە هەموو دڵتانەوە ڕووتان لێم دەکەن.
\v 14 کاتێک بۆتان دەردەکەوم، ڕاپێچکراوەکانتان دەگەڕێنمەوە و بەختیاریتان نوێ دەکەمەوە. لەناو هەموو ئەو نەتەوانە و ئەو شوێنانە کۆتان دەکەمەوە کە بۆ ئەوێ دەرمکردبوون. دەتانگەڕێنمەوە بۆ ئەو شوێنەی کە لێیەوە ڕاپێچم کردن.» ئەوە فەرمایشتی یەزدانە.
\pm 
\v 15 گوتتان: «یەزدان لە بابل پێغەمبەرانی بۆ هەستاندینەوە.»
\v 16 بەڵام یەزدان ئاوا دەفەرموێت سەبارەت بەو پاشایەی لەسەر تەختەکەی داود دانیشتووە و هەموو ئەو گەلەی لەم شارەدا ماونەتەوە، ئەو هاوڵاتییانەی ڕاپێچ نەکراون،
\v 17 بەڵێ، یەزدانی سوپاسالار ئاوا دەفەرموێت: «ئەوەتا من شمشێر و قاتوقڕی و دەرد دەنێرمە ناویان و دەیانکەمە هەنجیری خراپ کە لە خراپیدا نەخورێت.
\v 18 بە شمشێر و قاتوقڕی و دەرد ڕاویان دەنێم، لەبەردەم هەموو شانشینەکانی زەوی قێزەونیان دەکەم، نەفرەتیان لێ دەکرێت و دەبنە پەند و مایەی گاڵتەجاڕی و ڕیسوایی، لەنێو هەموو ئەو نەتەوانەی بۆ ئەوێ دەریاندەکەم.
\v 19 لەبەر ئەوەی گوێیان لە فەرمایشتی من نەگرت، ئەوەی بە بەردەوامی بەدەستی بەندە پێغەمبەرەکانم بۆم ناردن. هەروەک ئێوەی ڕاپێچکراویش گوێتان لێ نەگرت.» ئەوە فەرمایشتی یەزدانە.
\pm 
\v 20 لەبەر ئەوە، ئەی هەموو ڕاپێچکراوەکان، ئەی ئەوانەی لە ئۆرشەلیمەوە بۆ بابلم ناردن، گوێ لە فەرمایشتی یەزدان بگرن.
\v 21 ئەمە فەرموودەی یەزدانی سوپاسالارە، خودای ئیسرائیل، سەبارەت بە ئەحاڤی کوڕی قولایا و سدقیای کوڕی مەعسێیاهو، ئەوانەی بە درۆ بە ناوی منەوە پێشبینیتان بۆ دەکەن: «دەیاندەمە دەست نەبوخودنەسری پاشای بابل، ئەویش لەبەرچاوتان دەیانکوژێت.
\v 22 لەبەر ئەوە هەموو ڕاپێچکراوەکانی یەهودا لە بابل، ناوی ئەوان وەک نەفرەت بەکاردەهێنن و دەڵێن: ”یەزدان وەک سدقیا و ئەحاڤت لێ بکات، ئەوانەی پاشای بابل بە ئاگر برژاندنی،“
\v 23 چونکە لەناو ئیسرائیلدا کارێکی قێزەونیان کرد، داوێنپیسییان لەگەڵ ژنی برادەرەکانیان کرد، بە ناوی منەوە بە درۆ قسەیان کرد کە من فەرمانم پێ نەکردبوون. من خۆم دەزانم و شایەتی ئەوەم.» ئەوە فەرمایشتی یەزدانە.
\s1 پەیامێک بۆ شەمەعیا
\p 
\v 24 بە شەمەعیای نەحەلامی بڵێ:
\v 25 «یەزدانی سوپاسالار، خودای ئیسرائیل ئەمە دەفەرموێت: تۆ بە ناوی خۆتەوە نامەت نارد بۆ هەموو ئەو گەلەی لە ئۆرشەلیمە و بۆ سەفەنیای کوڕی مەعسێیاهوی کاهین و بۆ هەموو کاهینەکان. بە سەفەنیات گوت:
\v 26 ”یەزدان تۆی لە جێگای یەهۆیاداعی کاهین کردووە بە کاهین، بۆ ئەوەی ببیتە سەرپەرشتیار بەسەر ماڵی یەزدانەوە، هەر پیاوێکی شێت کە خۆی وەک پێغەمبەر بنوێنێ بیخەیتە ناو کۆت و بەندەوە.
\v 27 ئەی بۆچی سەرزەنشتی یەرمیای عەناتۆتی ناکەیت کە خۆی وەک پێغەمبەر دەنوێنێ؟
\v 28 پەیامێکی بۆ بابل بۆ ناردووین و دەڵێت: مانەوەتان درێژە دەکێشێت. جا بۆ خۆتان خانوو بنیاد بنێن و نیشتەجێ بن؛ باخ بچێنن و لە بەروبوومەکەی بخۆن.“»
\p 
\v 29 سەفەنیای کاهینیش ئەم نامەیەی بۆ یەرمیای پێغەمبەر خوێندەوە.
\v 30 ئینجا فەرمایشتی یەزدان بۆ یەرمیا هات:
\v 31 «پەیامێک بۆ هەموو ڕاپێچکراوان بنێرە و بڵێ: ”یەزدان لەبارەی شەمەعیای نەحەلامییەوە ئەمە دەفەرموێت: لەبەر ئەوەی شمەعیا پێشبینیی بۆ کردن، منیش نەمناردووە، وای لێکردوون پشت بە درۆ ببەستن،
\v 32 یەزدان ئەمە دەفەرموێت: ئەوەتا من سزای شەمەعیای نەحەلامی و وەچەکەی دەدەم. کەسی بۆ نامێنێتەوە لەناو ئەم گەلەدا دانیشێت، ئەو شتە باشانە نابینێت کە من بۆ گەلەکەی خۆمی دەکەم، چونکە جاڕی یاخیبوونی دا لە دژی من.“» ئەوە فەرمایشتی یەزدانە.
\c 30
\s1 گەڕاندنەوەی ئیسرائیل
\p 
\v 1 ئەمە ئەو پەیامەیە کە لەلایەن یەزدانەوە بۆ یەرمیا هات:
\v 2 «یەزدانی پەروەردگاری ئیسرائیل ئەمە دەفەرموێت: ”هەموو ئەو وشانەی کە پێم فەرموویت، لە پەڕتووکێکدا بیاننووسە.“
\v 3 یەزدان دەفەرموێت: ”سەردەمێک دێت، ئیسرائیل و یەهودای گەلەکەم لە ڕاپێچکراوی دەگەڕێنمەوە، دەیانهێنمەوە ئەو خاکەی بە باوباپیرانی ئەوانم دابوو، بۆ ئەوەی خاوەنداریێتی بکەن.“» ئەوە فەرمایشتی یەزدانە.
\p 
\v 4 ئەمانەش ئەو وشانەن کە یەزدان سەبارەت بە ئیسرائیل و یەهودا فەرمووی:
\v 5 «یەزدان ئەمە دەفەرموێت:
\q1 «”هاواری ترسمان بیست،
\q2 تۆقین نەک ئاشتی.
\q1 
\v 6 بپرسن و ببینن:
\q2 ئایا نێر سکی دەبێت؟
\q1 ئەی بۆچی هەر پیاوێک دەبینم
\q2 وەک ژنی ژانگرتوو دەستی بە کەمەرییەوەیە و
\q2 هەموو ڕووشی زەرد هەڵگەڕاوە؟
\q1 
\v 7 ئای! لەو ڕۆژە سامناکە!
\q2 ڕۆژی ئاوا نابێت.
\q1 ئەمە کاتی تەنگانەیە بۆ یاقوب،
\q2 بەڵام لێی ڕزگار دەبێت.“
\b
\q1 
\v 8 «یەزدانی سوپاسالار دەفەرموێت،
\q2 ”لەو ڕۆژەدا، ئەو نیرە دەشکێنم کە لە ملیانە،
\q1 پێبەندیان دەپسێنم و
\q2 چیتر بێگانە نایانکەن بە کۆیلە.
\q1 
\v 9 بەڵکو یەزدانی پەروەردگاریان دەپەرستن و
\q2 خزمەتی داودی پاشایان دەکەن،\f + \fr 30:9 \ft مەبەستی لە یەکێکە لە نەوەکانی داود.‏\f*
\q2 ئەوەی کە بۆیان دایدەنێم.“»
\b
\q1 
\v 10 یەزدان دەفەرموێت: «”ئەی یاقوبی بەندەم، مەترسە،
\q2 ئەی ئیسرائیل، مەتۆقە.
\q1 بە دڵنیاییەوە من لەم شوێنە دوورە ڕزگارت دەکەم،
\q2 نەوەکەشت لەو خاکەوەی بۆی ڕاپێچ کراوە.
\q1 یاقوب دەگەڕێتەوە و ئاسوودە دەبێت،
\q2 دڵنیا دەبێت و کەس نایتۆقێنێت.
\q1 
\v 11 من لەگەڵتدام و ڕزگارت دەکەم.“
\q2 یەزدان دەفەرموێت:
\q1 ”ئەگەر کۆتایی بە هەموو ئەو نەتەوانە بهێنم
\q2 کە لەنێویاندا پەرتەوازەم کردیت،
\q2 کۆتایی بە تۆ ناهێنم.
\q1 تەمبێت دەکەم، بەڵام بە دادپەروەری،
\q2 بێ سزا بەڕەڵات ناکەم.“
\p 
\v 12 «یەزدان ئەمە دەفەرموێت:
\q1 «”شکاوییەکەت بێ چارەیە،
\q2 برینەکەت سەختە.
\q1 
\v 13 کەس نییە داکۆکی لە کێشەی تۆ بکات،
\q2 دەرمان نییە بۆ برینەکەی تۆ،
\q2 تۆ چاک نابیتەوە.
\q1 
\v 14 هەموو هاوپەیمانەکانت لەبیریان کردوویت،
\q2 هیچ گرنگی بە تۆ نادەن.
\q1 وەک لێدان لە دوژمن لە تۆم دا،
\q2 بە سەختی تەمبێم کردی
\q1 لەسەر زۆری تاوانەکانت،
\q2 لەسەر گەورەیی گوناهەکانت.
\q1 
\v 15 بۆچی لەبەر شکانەکەت هاوار دەکەیت،
\q2 لەبەر ئازارەکەت کە چارەسەر ناکرێت؟
\q1 بەهۆی زۆری تاوانەکانت و گەورەیی گوناهەکانت،
\q2 منیش ئەمەم پێکردیت.
\b
\q1 
\v 16 «”بەڵام هەموو ئەوانەی تۆیان خوارد دەخورێن،
\q2 هەموو دوژمنەکانت ڕاپێچ دەکرێن.
\q1 ڕاووڕووتکەرانت ڕاووڕووت دەکرێن و
\q2 هەموو تاڵانکەرانت دەکەم بە تاڵانی.
\q1 
\v 17 بەڵام تەندروستیت دەگەڕێنمەوە،
\q2 برینەکانت چاک دەکەمەوە،
\q1 چونکە ناویان لێنایت دوورخراوەکە،
\q2 سییۆن، ئەوەی کەس گرنگی پێ نادات.“
\q4 ئەوە فەرمایشتی یەزدانە.
\p 
\v 18 «یەزدان ئەمە دەفەرموێت:
\q1 «”من ڕاپێچکراوانی چادرەکانی یاقوب دەگەڕێنمەوە،
\q2 بەزەییم بە نشینگەکانی دێتەوە.
\q1 شار لەسەر گردەکەی خۆی بنیاد دەنرێتەوە،
\q2 کۆشک لە شوێنی خۆی بنیاد دەنرێتەوە.
\q1 
\v 19 دەنگی گۆرانی سوپاسگوزاری و
\q2 بەزمیان لێ بەرز دەبێتەوە.
\q1 ژمارەیان زۆر دەکەم و
\q2 کەم نابن،
\q1 ڕێزیان لێ دەنێم و
\q2 بچووک نابن.
\q1 
\v 20 کوڕەکانی وەک جاری جاران دەبن،
\q2 کۆمەڵەکەی لەبەردەمم دەچەسپێت،
\q2 سزای هەموو ئەوانە دەدەم کە ستەمی لێ دەکەن.
\q1 
\v 21 میرەکەیان یەکێک دەبێت لەنێو خۆیان،
\q2 فەرمانڕەواکەیان لە خۆیان هەڵدەکەوێت.
\q1 لە خۆمی نزیک دەکەمەوە و لێم نزیک دەبێتەوە،
\q2 چونکە کەس ناوێرێت بەبێ ویستی من لێم نزیک بێتەوە.“»
\q4 ئەوە فەرمایشتی یەزدانە.
\q1 
\v 22 «”ئێوە دەبن بە گەلی من و
\q2 منیش دەبم بە خودای ئێوە.“»
\b
\q1 
\v 23 ئەوەتا گەردەلوولی یەزدان
\q2 تووڕەییە هەڵدەچێت،
\q1 گەردەلوولێکی ڕاماڵە،
\q2 لەسەر سەری بەدکاران هەڵدەکات.
\q1 
\v 24 گڕی تووڕەیی یەزدان دانامرکێتەوە
\q2 هەتا نیازەکانی دڵی خۆی
\q2 بە تەواوی بەجێنەگەیەنێت.
\q1 لە ڕۆژانی داهاتوودا
\q2 لەمە تێ دەگەن.
\c 31
\p 
\v 1 یەزدان دەفەرموێت: «لەو کاتەدا، دەبم بە خودای هەموو خێڵەکانی ئیسرائیل، ئەوانیش دەبن بە گەلی من.»
\p 
\v 2 یەزدان ئەمە دەفەرموێت:
\q1 «ئەو گەلەی لە دەمی شمشێر دەربازبوون
\q2 لە چۆڵەوانی میهرەبانییان دەستکەوت،
\q2 کاتێک هاتم ئیسرائیل بحەوێنمەوە.»
\p 
\v 3 لە دێرزەمانەوە یەزدانمان بۆ دەرکەوتووە و دەفەرموێت:
\q1 «بە خۆشویستنێکی هەتاهەتایی ئێوەم خۆشدەوێت،
\q2 لەبەر ئەوە بەردەوامیم دا بە خۆشەویستی نەگۆڕم بۆ ئێوە.
\q1 
\v 4 ئەی ئیسرائیلی پاکیزە، بنیادت دەنێمەوە،
\q2 بنیاد دەنرێیتەوە.
\q1 دووبارە دەفەکانت هەڵدەگریتەوە
\q2 بۆ ناو سەمای بەزمگێڕان دەچیت.
\q1 
\v 5 دووبارە ڕەزەمێو دەچێنیت
\q2 لە چیاکانی سامیرە،
\q1 ڕەزەوانەکان دەچێنن و
\q2 بەرەکەی دەخۆن\f + \fr 31:5 \ft واتا یەزدان نیشتەجێیان دەکاتەوە بۆ ماوەیەکی دوورودرێژ کە بتوانن بەری دارەکانیان بخۆن، چونکە دروست نەبوو بەری هیچ دارێک بخۆن هەتا ساڵی پێنجەم.‏\f*.
\q1 
\v 6 ڕۆژێک دێت
\q2 چاودێران لە شاخەکانی ئەفرایم بانگەواز دەکەن:
\q1 ”وەرن، با بۆ سییۆن سەربکەوین،
\q2 بۆ لای یەزدانی پەروەردگارمان.“»
\p 
\v 7 یەزدان ئەمە دەفەرموێت:
\q1 «بە شادییەوە گۆرانی بۆ یاقوب بڵێن،
\q2 هاواری خۆشی بکەن بۆ سەر باشترین نەتەوە.
\q1 با ستایشتان ببیسترێت و بڵێن:
\q2 ”ئەی یەزدان، گەلی خۆت ڕزگار بکە،
\q2 پاشماوەکەی ئیسرائیل!“
\q1 
\v 8 ئەوەتا من لە خاکی باکوورەوە دەیانهێنمەوە،
\q2 لە هەموو لایەکی زەوی کۆیان دەکەمەوە،
\q1 لەنێویان شەل و نابینا دەبێت
\q2 ژنی سکپڕ و ژانگرتوو پێکەوە،
\q2 کۆمەڵێکی گەورە دەگەڕێنەوە بۆ ئێرە.
\q1 
\v 9 بە گریانەوە دێن،
\q2 لەو کاتەی دەیانگەڕێنمەوە دەپاڕێنەوە،
\q1 بەلای ڕووبارە ئاوەکاندا دەیانبەم،
\q2 بە ڕێگایەکی ڕاست، تێیدا ساتمە ناکەن و ناکەون،
\q1 چونکە من باوکی ئیسرائیلم،
\q2 ئەفرایم نۆبەرەمە.
\b
\q1 
\v 10 «ئەی نەتەوەکان، گوێ لە فەرمایشتی یەزدان بگرن،
\q2 لە کەنارە دوورەکان ڕابگەیەنن:
\q1 ”ئەوەی ئیسرائیلی پەرتەوازە کرد، کۆیان دەکاتەوە،
\q2 وەک شوان مێگەلی خۆی دەپارێزێت،“
\q1 
\v 11 چونکە یەزدان نرخی ئازادبوونی یاقوبی دا،
\q2 لە دەست ئەوەی لەو\f + \fr 31:11 \ft مەبەست لە فیرعەونی میسرە کە لە گەلی ئیسرائیل بەهێزتر بوو.‏\f* بەهێزتر بوو کڕییەوە.
\q1 
\v 12 جا دێن و لە بەرزاییەکانی سییۆن هاواری خۆشی دەکەن.
\q2 لەبەر خێروبێری یەزدان دەگەشێنەوە،
\q1 بەسەر دانەوێڵە و شەرابی نوێ و زەیتەوە،
\q2 بەسەر بەرخ و گوێرەکەوە.
\q1 وەک باخچەیەکی تێر ئاو دەبن،
\q2 جارێکی دیکە سیس نابن.
\q1 
\v 13 ئەوسا پاکیزەکان سەما دەکەن و دڵشاد دەبن،
\q2 گەنجان و پیران پێکەوە.
\q1 شینیان دەگۆڕم بە شادی،
\q2 دڵنەواییان دەکەم و لەدوای پەژارەییان دڵخۆشیان دەکەم.
\q1 
\v 14 کاهینەکان تێر دەکەم لە چەوری،
\q2 گەلەکەم لە خێروبێرم تێر دەبن.»
\q4 ئەوە فەرمایشتی یەزدانە.
\p 
\v 15 یەزدان ئەمە دەفەرموێت:
\q1 «دەنگێک لە ڕامەوە بیسترا،
\q2 گریان و شیوەنێکی گەورە،
\q1 ڕاحێل بۆ منداڵەکانی دەگریێت،
\q2 ڕازی نییە دڵنەوایی بکرێت،
\q2 چونکە نەماون.»
\p 
\v 16 یەزدان ئەمە دەفەرموێت:
\q1 «واز لە گریان بهێنە و
\q2 چاوت فرمێسک هەڵنەڕێژێ،
\q1 چونکە کردەوەکەت پاداشتی هەیە.»
\q4 ئەوە فەرمایشتی یەزدانە.
\q2 «لە خاکی دوژمن دەگەڕێنەوە.
\q1 
\v 17 کەواتە هیوا بە دواڕۆژت هەیە.
\q2 منداڵەکانت دەگەڕێنەوە خاکی خۆیان.»
\q4 ئەوە فەرمایشتی یەزدانە.
\b
\q1 
\v 18 «بە دڵنیاییەوە گوێم لێ بوو ئەفرایم ئاخی هەڵدەکێشا:
\q2 ”وەک گوێرەکەیەکی دەستەمۆنەکراو تەمبێت کردم،
\q2 من تەمبێ بووم.
\q1 بمگەڕێنەوە لای خۆت، دەگەڕێمەوە،
\q2 چونکە تۆ یەزدانی پەروەردگاری منی.
\q1 
\v 19 لەدوای گومڕابوونم،
\q2 پەشیمان بوومەوە،
\q1 لەدوای تێگەیشتنم،
\q2 لە سنگی خۆمم دا.
\q1 شەرمەزار بووم و گاڵتەم پێ کرا،
\q2 چونکە ڕیسوایی کاتی مێردمنداڵیم بە کۆڵمەوە بوو.“
\q1 
\v 20 ئایا ئەفرایم کوڕی ئازیزم نییە،
\q2 ئەو منداڵەی دڵم پێی خۆشە؟
\q1 لەبەر ئەوەی هەر کاتێک لە دژی ئەو دەدوێم،
\q2 دووبارە دێتەوە یادم.
\q1 لەبەر ئەوە هەناوم بۆی دەسووتێت،
\q2 بە تەواوی بەزەییم پێیدا دێتەوە.»
\q4 ئەوە فەرمایشتی یەزدانە.
\b
\q1 
\v 21 «نیشانە بۆ خۆت بچەقێنە و
\q2 ڕێوشوێن دابنێ.
\q1 بە وردی بڕوانە ڕێگاکە،
\q2 ئەو ڕێگایەی پێیدا دەڕۆن.
\q1 ئەی ئیسرائیلی پاکیزە، بگەڕێوە،
\q2 بگەڕێوە بۆ شارۆچکەکانت.
\q1 
\v 22 هەتا کەی بەم لاو بەو لادا دەڕۆیت،
\q2 ئەی کچی هەڵگەڕاوە؟
\q1 چونکە یەزدان شتێکی نوێی لەسەر زەوی بەدیهێناوە:
\q2 ژن پیاو دەپارێزێت.»
\p 
\v 23 یەزدانی سوپاسالار، خودای ئیسرائیل ئەمە دەفەرموێت: «کاتێک ڕاپێچکراوەکانیان دەگەڕێنمەوە، جارێکی دیکە ئەم وشانە لە خاکی یەهودا و لە شارۆچکەکانی دەڵێنەوە: ”ئەی نشینگەی ڕاستودروستی، ئەی کێوی پیرۆز! یەزدان بەرەکەتدارت بکات.“
\v 24 جا خەڵکەکە لە یەهودا و هەموو شارۆچکەکانی نیشتەجێ دەبن، جوتیار و ڕەوەندەکان لەگەڵیان دەبن.
\v 25 ماندوو دەبووژێنمەوە، هەموو سیسێک تێر دەکەم.»
\p 
\v 26 لێرەدا بەئاگاهاتم و تەماشای دەوروبەرم کرد. خەوەکەم خۆش بوو.
\p 
\v 27 یەزدان دەفەرموێت: «ئەوەتا سەردەمێک دێت، ژمارەی خەڵک و ژمارەی ئاژەڵ لە ئیسرائیل و یەهودا زۆر زیاد دەکەم.
\v 28 جا چۆن چاودێر بووم بۆ ڕیشەکێشکردن و ڕووخاندن، بۆ کاولکاری، بۆ لەناوبردن و بەڵا بەسەرهێنان، ئاواش چاودێر دەبم بۆ بنیادنانەوە و چاندن.» ئەوە فەرمایشتی یەزدانە.
\v 29 «لەو ڕۆژانەدا ئیتر ناڵێن:
\q1 «”باوکان بەرسیلەیان خوارد،
\q2 ددانی منداڵەکان ئاڵ دەبێت.“
\m 
\v 30 بەڵکو هەرکەسە و بە تاوانی خۆیەوە دەمرێت، هەرکەسێک بەرسیلە بخوات ددانی خۆی ئاڵ دەبێت.»
\q1 
\v 31 یەزدان دەفەرموێت: «ئەوەتا سەردەمێک دێت،
\q2 پەیمانێکی نوێ\f + \fr 31:31 \ft بڕوانە \xt مەتا 26‏:28 و عیبرانییەکان 8‏:13‏\xt*\ft ‏.‏\f* لەگەڵ بنەماڵەی ئیسرائیل و
\q2 بنەماڵەی یەهودا دەبەستم.
\q1 
\v 32 وەک ئەو پەیمانە نابێت
\q2 کە لەگەڵ باوباپیرانیاندا بەستم،
\q1 ئەو ڕۆژەی دەستی ئەوانم گرت
\q2 بۆ ئەوەی لە خاکی میسر دەریانبهێنم،
\q1 چونکە ئەوان پەیمانەکەی منیان شکاند،
\q2 هەرچەندە من مێردی\f + \fr 31:32 \ft پەیوەندی نێوان خودا و گەلەکەی بە پەیوەندی نێوان ژن و مێرد دەچووێنرێت، لە ڕووی ئەرک و وەفا و گوێڕایەڵییەوە.‏\f* ئەوان بووم.»
\q4 ئەوە فەرمایشتی یەزدانە.
\q1 
\v 33 یەزدان دەفەرموێت: «ئەمە ئەو پەیمانەیە کە لەدوای ئەو ڕۆژانە
\q2 لەگەڵ بنەماڵەی ئیسرائیلدا دەیبەستم،
\q1 فێرکردنەکانم دەخەمە ناو مێشکیان و
\q2 لەسەر دڵیان دەینووسم.
\q1 من دەبم بە خودای ئەوان و
\q2 ئەوانیش دەبن بە گەلی من.
\q1 
\v 34 لەمەودوا کەس هاوڕێکەی خۆی
\q2 یان براکەی خۆی فێرناکات و بڵێت: ”یەزدان بناسە،“
\q1 چونکە هەموویان دەمناسن،
\q2 لە بچووکیانەوە هەتا گەورەیان،
\q1 چونکە لە تاوانەکانیان خۆشدەبم،
\q2 چیتر گوناهەکانیان بەبیری خۆم ناهێنمەوە.»
\q4 ئەوە فەرمایشتی یەزدانە.
\p 
\v 35 یەزدان ئەمە دەفەرموێت،
\q1 ئەوەی خۆری داناوە
\q2 بۆ درەوشانەوە لە ڕۆژ،
\q1 فەرزی مانگ و ئەستێرەکانیش
\q2 بۆ درەوشانەوە لە شەو،
\q1 ئەوەی دەریا دەوروژێنێت،
\q2 شەپۆلەکانی هاژەیان دێت،
\q2 ناوی یەزدانی سوپاسالارە،
\q1 
\v 36 یەزدان دەفەرموێت:
\q2 «ئەگەر ئەم فەرزانە لەبەرچاوم نەمێنن،
\q1 ئەوسا ڕەچەڵەکی ئیسرائیلیش کپ دەبن
\q2 لەوەی بە درێژایی ڕۆژگار لەبەردەمم ببن بە نەتەوە.»
\p 
\v 37 یەزدان ئەمە دەفەرموێت:
\q1 «ئەگەر ئاسمان لە سەرەوە بپێورێت،
\q2 ئەگەر بناغەکانی زەوی لە ژێرەوە بپشکنرێن،
\q1 ئەوسا منیش هەموو ڕەچەڵەکی ئیسرائیل ڕەت دەکەمەوە،
\q2 لەبەر هەموو ئەوەی کردیان.»
\q4 ئەوە فەرمایشتی یەزدانە.
\p 
\v 38 یەزدان دەفەرموێت: «سەردەمێک دێت، شارەکە بۆ یەزدان بنیاد دەنرێت، لە قوللەی حەنەنێلەوە هەتا دەروازەی گۆشەکە.
\v 39 لەوێوە گوریسی پێوانە بەسەر گردی گارێڤ درێژ دەکرێت و دەسووڕێتەوە بۆ گۆعە.
\v 40 تەواوی ئەو دۆڵەی لاشە و خۆڵەمێشی تێدا فڕێدەدرێت، هەروەها هەموو کێڵگەکان بۆ دۆڵی قدرۆن لە ڕۆژهەڵات تاوەکو دەروازەی ئەسپ پیرۆز دەبێت بۆ یەزدان، هەتاهەتایە ڕیشەکێش ناکرێت و جارێکی دیکە کاول ناکرێتەوە.»
\c 32
\s1 یەرمیا کێڵگەیەک دەکڕێت
\p 
\v 1 ئەمە ئەو پەیامەیە کە لەلایەن یەزدانەوە بۆ یەرمیا هات، لە ساڵی دەیەمی سدقیای پاشای یەهودا کە دەکاتە ساڵی هەژدەمینی نەبوخودنەسر.
\v 2 ئەو کاتە لەشکری پاشای بابل گەمارۆی ئۆرشەلیمی دابوو، یەرمیای پێغەمبەریش لە حەوشەی پاسەوانەکانی کۆشکی پاشای یەهودا بەند کرابوو.
\p 
\v 3 سدقیای پاشای یەهودا یەرمیای بەند کردبوو، پێی گوت: «بۆچی بەم پەیامە پێشبینیت کرد؟ گوتت: ”یەزدان ئەمە دەفەرموێت: خەریکم ئەم شارە دەدەمە دەست پاشای بابل و دەیگرێت.
\v 4 سدقیای پاشای یەهوداش لە دەست بابلییەکان دەرباز نابێت، بەڵکو دەدرێتە دەست پاشای بابلەوە، ڕووبەڕوو قسەی لەگەڵ دەکات، چاوەکانی ئەو دەبینێت.
\v 5 سدقیا دەباتە بابل، لەوێ دەمێنێتەوە هەتا سزاکەی تەواو وەردەگرێت. ئەگەر لەگەڵ بابلییەکان بجەنگن سەر ناکەون. ئەوە فەرمایشتی یەزدانە.“»
\p 
\v 6 ئینجا یەرمیا گوتی: «فەرمایشتی یەزدانم بۆ هات:
\v 7 حەنەمێلی کوڕی شەلومی مامت دێتە لات و پێت دەڵێت: ”ئەو کێڵگەیەی لە عەناتۆت هەمە بۆ خۆتی بکڕە، چونکە ماف و ئەرکی تۆیە بیکڕیتەوە\f + \fr 32:7 \ft لە سەردەمی پەیمانی کۆن کەسێک کە پارچە زەوییەکی دەفرۆشت، ئەوا نزیکترین کەسی بنەماڵە و تیرەکەی خۆی مافی لە پێشینەیی هەبوو بۆ کڕینی، بڕوانە \xt لێڤییەکان 25‏:25 و ڕائووس 4‏:3‏،4‏\xt*\ft ‏.‏\f*.“
\p 
\v 8 «جا بەپێی فەرمایشتی یەزدان حەنەمێلی کوڕی مامم هاتە لام بۆ حەوشەی پاسەوانەکان و پێی گوتم: ”کێڵگەکەم بکڕە، ئەوەی لە عەناتۆتە لە خاکی بنیامین، چونکە مافی کڕینەوە و خاوەنداریێتیت هەیە، بۆ خۆت بیکڕە.“
\p «جا زانیم ئەوە فەرمایشتی یەزدانە.
\v 9 منیش کێڵگەکەم لە حەنەمێلی کوڕی مامم کڕی، ئەوەی لە عەناتۆتە، زیوەکەشم بۆی کێشا، حەڤدە شاقل زیو.
\v 10 گرێبەستم لە کاغەزێک نووسی و مۆرم کرد و چەند کەسێکم لێکرد بە شایەت، زیوەکەشم بە تەرازوو کێشا.
\v 11 گرێبەستی کڕینەکەم لە دوو وێنەدا برد، وێنەیەکی داخراو کە مەرج و بەندەکانی تێدابوو، لەگەڵ وێنەیەکی کراوە،
\v 12 گرێبەستی کڕینەکەم دایە باروخی کوڕی نێرییا کوڕی مەحسێیا، لەبەرچاوی حەنەمێلی ئامۆزام و ئەو شایەتانەی لە گرێبەستی کڕینەکە نووسرابوون، هەروەها لەبەرچاوی هەموو ئەو جولەکانەی لە حەوشەی پاسەوانەکان دانیشتبوون.
\p 
\v 13 «لەبەرچاویان باروخم ڕاسپارد و گوتم:
\v 14 ”یەزدانی سوپاسالار، خودای ئیسرائیل دەفەرموێت: ئەم گرێبەستانە هەڵبگرە، گرێبەستە مۆرکراوەکەی کڕین و ئەم لەبەرگیراوەیەی گرێبەستەکە لەناو گۆزەیەکی گڵین دابنێ، تاوەکو بۆ ماوەیەکی درێژ بمێنێتەوە،
\v 15 چونکە یەزدانی سوپاسالار، خودای ئیسرائیل ئەمە دەفەرموێت: جارێکی دیکە دیسان لەم خاکەدا خانوو و کێڵگە و ڕەز دەکڕدرێتەوە.“
\p 
\v 16 «دوای ئەوەی گرێبەستەکەی کڕینم دایە باروخی کوڕی نێرییا، نوێژم بۆ یەزدان کرد و گوتم:
\pm 
\v 17 «ئای، ئەی یەزدانی باڵادەست، ئەوەتا تۆ بە توانای مەزن و دەستی بەهێزەوە ئاسمان و زەویت دروستکردووە و هیچ شتێک لەلای تۆ قورس نییە.
\v 18 خۆشەویستی نەگۆڕ بۆ هەزاران بەدەردەخەیت، بەڵام تۆ سزای کوڕ دەدەیت لەسەر ئەو تاوانەی باوکی لەپێش ئەو کردوویەتی. ئەی خودای گەورە و پاڵەوان، ئەوەی ناوت یەزدانی سوپاسالارە،
\v 19 لە پلاندانان مەزنی، لە کارکردندا بە توانای، چاوەکانت لەسەر هەموو ڕەفتارەکانی ئادەمیزاد کراوەن، هەتا هەریەکە و پاداشتی شایستەی ڕەفتار و کردەوەکانی بدەیتەوە.
\v 20 تۆ نیشانە و پەرجووەکانت\f + \fr 32:20 \ft پەرجوو: موعجیزە.‏\f* لە خاکی میسردا نواند، بەردەوام هەتا ئەمڕۆش لە ئیسرائیل و لەنێو هەموو مرۆڤایەتیدا دەیاننوێنیت، بەمەش ناوێکت بەدەستهێناوە کە هێشتا ماوە.
\v 21 بە نیشانە و پەرجوو، بە دەستێکی پۆڵایین و بازووێکی بەهێز، بە ترسێکی گەورەوە، ئیسرائیلی گەلی خۆتت لە خاکی میسر دەرهێنا.
\v 22 ئەم خاکەت پێدان کە سوێندت خواردبوو بیدەیتە باوباپیرانیان، خاکێک شیر و هەنگوینی لێ دەڕژێت.
\v 23 جا هاتن و بوونە خاوەنی، بەڵام گوێیان لە تۆ نەگرت، فێرکردنی تۆیان پەیڕەو نەکرد، ئەوانەیان نەکرد کە تۆ فەرمانت پێکردن بیانکەن. جا هەموو ئەم خراپەیەت بەسەریاندا هێنا.
\pm 
\v 24 «ئەوەتا مەتەرێز بۆ دەست بەسەرداگرتنی شارەکە لێدراوە. شارەکە بەهۆی شمشێر و قاتوقڕی و دەردەوە ڕادەستی بابلییەکان دەکرێت کە لە دژی دەجەنگن. هەروەک دەیبینیت، ئەوەی تۆ فەرمووت ڕوویدا.
\v 25 ئەی یەزدانی باڵادەست، تۆ خۆت پێت فەرمووم: ”بە شایەتی چەند شایەتێک کێڵگەکە بە زیو بۆ خۆت بکڕە،“ کەچی شارەکەت داوەتە دەست بابلییەکان.»
\p 
\v 26 ئینجا فەرمایشتی یەزدان بۆ یەرمیا هات:
\v 27 «من یەزدانم، خودای هەموو ئادەمیزاد، ئایا هیچ شتێک هەیە بۆ من قورس بێت؟
\v 28 لەبەر ئەوە یەزدان ئەمە دەفەرموێت: من خەریکم ئەم شارە بدەمە دەست بابلییەکان و دەست نەبوخودنەسری پاشای بابل و بیگرێت.
\v 29 جا بابلییەکان کە لە دژی ئەو شارە دەجەنگن، دێنە ناوی بە ئاگر گڕی تێبەردەدەن، ئەو ماڵانەش دەسووتێنن کە لە سەربانەکانیان بخووریان بۆ بەعل سووتاند و شەرابی پێشکەشکراویان پێشکەشی خوداوەندەکانی دیکە کرد بۆ ئەوەی پەستم بکەن.»
\p 
\v 30 یەزدان دەفەرموێت: «نەوەی ئیسرائیل و نەوەی یەهودا هەر لە گەنجیێتییانەوە تەنها خراپەیان لەبەرچاوم کردووە، چونکە نەوەی ئیسرائیل بە دروستکراوەکانی دەستیان تەنها پەستیان کردم.
\v 31 لەو ڕۆژەوەی ئەم شارەیان بنیاد ناوە هەتا ئەمڕۆ، بۆ من بووەتە مایەی تووڕەبوون و هەڵچوونم، کە دەبێت لەبەردەمم ڕایماڵم.
\v 32 نەوەی ئیسرائیل و نەوەی یەهودا پەستیان کردم، بە هەموو ئەو خراپانەی کردیان، ئەوان و پاشا و سەرکردە و کاهین و پێغەمبەرەکانیان، پیاوانی یەهودا و خەڵکی ئۆرشەلیم.
\v 33 جا پشتیان تێکردم نەک ڕوو، لە کاتێکدا من بەردەوام فێرم دەکردن، بەڵام نە گوێیانگرت و نە تەمبێ بوون.
\v 34 بەڵکو بتە قێزەونەکانیان لەو ماڵە دانا کە ناوی منی هەڵگرتووە و گڵاویان کرد.
\v 35 هەروەها نزرگەی بەعلیان لەسەر بەرزاییەکان بنیاد نا، کە لە دۆڵی بەن‌هینۆمە، تاوەکو کوڕ و کچەکانیان وەک قوربانی بۆ مۆلەخ\f + \fr 32:35 \ft خوداوەندێکی کەنعانییە بتپەرستەکان بووە، بۆ پەرستنی هەستاون بە تێپەڕاندنی منداڵەکانیان بەناو ئاگردا. بڕوانە \xt دووەم پوختەی مێژوو 28‏:3‏\xt*\ft .‏\f* بسووتێنن، ئەو شتە قێزەونانەیان کرد و وایانکرد یەهودا گوناه بکات، کە من نە فەرمانم پێکردووە و نە بە خەیاڵیشمدا هاتووە.
\p 
\v 36 «ئێوە دەربارەی ئەو شارە دەڵێن: ”بە شمشێر و قاتوقڕی و دەرد دراوەتە دەست پاشای بابل.“ بەڵام یەزدانی پەروەردگاری ئیسرائیل دەفەرموێت:
\v 37 ئەوەتا من کۆیان دەکەمەوە، لە هەموو ئەو خاکانەی کە بە تووڕەیی و هەڵچوونمەوە و بە پەستییەکی مەزنەوە دەرمکردن بۆیان، دەیانگەڕێنمەوە ئەم شوێنە و بە ئاسوودەیی نیشتەجێیان دەکەم.
\v 38 ئەوان دەبن بە گەلی من و منیش دەبم بە خودای ئەوان.
\v 39 یەک دڵ و یەک ڕێبازیان پێدەدەم، بۆ ئەوەی هەردەم لێم بترسن، بۆ چاکەی خۆیان و چاکەی کوڕەکانیان لەپاش خۆیان.
\v 40 پەیمانێکی هەتاهەتاییان لەگەڵدا دەبەستم، کە خۆمیان لێ نەکێشمەوە و بەردەوام چاکەیان لەگەڵدا بکەم، ترسی خۆم بخەمە دڵیان، بۆ ئەوەی لێم لانەدەن.
\v 41 پێیان شاد دەبم کە چاکەیان لەگەڵدا بکەم، بە دڵنیاییەوە، بە هەموو دڵم و لە ناخمەوە، لەم خاکەدا دەیانڕوێنم.
\p 
\v 42 «یەزدان ئەمە دەفەرموێت: هەروەک هەموو ئەم خراپە گەورانەم بەسەر ئەم گەلەدا هێنا، ئاواش من هەموو ئەو چاکەیەیان بەسەردا دەهێنم کە بەڵێنم پێیان دا.
\v 43 جا کێڵگە دەکڕدرێتەوە لەم خاکەی کە دەڵێن: ”وێرانە، نە مرۆڤ و نە ئاژەڵی تێدا نییە، دراوەتە دەست بابلییەکان.“
\v 44 بە شایەتی چەند شایەتێک بە زیو کێڵگە دەکڕن، گرێبەست لە کاغەزێک دەنووسن و مۆری دەکەن، لە خاکی بنیامین و دەوروبەری ئۆرشەلیم، لە شارۆچکەکانی یەهودا، لە شارۆچکەکانی ناوچە شاخاوییەکان، لە زوورگەکانی خۆرئاوا و نەقەب، چونکە من ڕاپێچکراوەکانیان دەگەڕێنمەوە.» ئەوە فەرمایشتی یەزدانە.
\c 33
\s1 بەڵێنی گەڕانەوە
\p 
\v 1 یەرمیا کە هێشتا لە حەوشەی پاسەوانەکان بەند کرابوو، دووبارە فەرمایشتی یەزدانی بۆ هاتەوە:
\v 2 «یەزدانی دروستکەری زەوی کە شێوەی کێشاوە هەتا بیچەسپێنێت، ناوی یەزدانە، ئەمە دەفەرموێت:
\v 3 ”بانگم بکە، وەڵامت دەدەمەوە و شتە مەزنەکانت پێ ڕادەگەیەنم، شتە پەی پێ نەبراوەکان کە نایانزانیت.“
\v 4 یەزدانی پەروەردگاری ئیسرائیل سەبارەت بە خانووەکانی ئەم شارە و کۆشکەکانی پاشاکانی یەهودا، ئەوانەی تێکدران بۆ بەرەنگاربوونەوەی مەتەرێز و شمشێر
\v 5 لە جەنگی دژی بابلییەکان، یەزدان ئەمە دەفەرموێت: ”پڕ بکرێن لە لاشەی ئەو کەسانەی بە تووڕەیی و بە جۆشی خۆم لێم دان، ئەوانەی لەبەر هەموو خراپەکانی ئەوان ڕووی خۆم لەم شارە وەرگێڕا.
\p 
\v 6 «”لەگەڵ ئەوەشدا من تەندروستی و چاکبوونەوەی بۆ دێنم، گەلەکەم چاک دەکەمەوە، ئاشتی و ئارامییەکی فراوانیان بۆ فەراهەم دەکەم.
\v 7 یەهودا و ئیسرائیل لە ڕاپێچکراوی دەهێنمەوە و وەک پێشوویان بنیادیان دەنێمەوە.
\v 8 پاکیان دەکەمەوە لە هەموو گوناهەکانیان کە لە دژی من کردوویانە، لە هەموو گوناه و یاخیبوونەکانیان خۆشدەبم کە لە دژی من کردوویانە.
\v 9 جا ئەم شارە بۆم دەبێتە ناوبانگ و شادی، ستایشکردن و شانازی، لەلای هەموو نەتەوەکانی سەر زەوی کە ئەم هەموو چاکەیە دەبیستنەوە من بۆی دەکەم. جا دەترسن و لەرز دەیانگرێت، لەبەر هەموو ئەو چاکەیە و هەموو ئەو ئاشتییەی کە من بۆی فەراهەم دەکەم.“
\p 
\v 10 «یەزدان ئەمە دەفەرموێت: ”ئێوە سەبارەت بەم شوێنەی دەڵێن، ’وێرانە، بێ مرۆڤ و بێ ئاژەڵە.‘ هەرچەندە شارۆچکەکانی یەهودا و شەقامەکانی ئۆرشەلیم وێرانن، بێ مرۆڤ و بێ دانیشتووان و بێ ئاژەڵن،
\v 11 بەڵام لەوێ دەنگی شادی و دەنگی خۆشی دەبیسترێت، دەنگی زاوا و دەنگی بووک، دەنگی ئەوانەی قوربانی سوپاسگوزاری دەهێننە ناو ماڵی یەزدان، کە دەڵێن:
\q1 «” ’ستایشی یەزدانی سوپاسالار بکەن،
\q2 چونکە یەزدان چاکە،
\q2 خۆشەویستییە نەگۆڕەکەی هەتاهەتاییە.‘
\m یەزدان دەفەرموێت، ڕاپێچکراوی خاکەکە دەگەڕێنمەوە و وەک پێشتریان لێدەکەمەوە.“
\p 
\v 12 «یەزدانی سوپاسالار ئەمە دەفەرموێت: ”لەم شوێنە وێرانەدا کە بێ مرۆڤ و بێ ئاژەڵە، جارێکی دیکە لە هەموو شارۆچکەکانی جێی شەوینی شوانەکان و مانەوەی مەڕەکانی لێ دەبێت.
\v 13 لە شارۆچکەکانی ناوچە شاخاوییەکان و زوورگەکانی خۆرئاوا و نەقەب و خاکی بنیامین، دەوروبەری ئۆرشەلیم و شارۆچکەکانی یەهودا، جارێکی دیکە مەڕ بەژێر دەستی ئەوەدا تێدەپەڕێت کە دەیانژمێرێت.\f + \fr 33:13 \ft نیشانەیە بۆ هەبوونی ئاشتی و گەشەسەندنی خاکەکە.‏\f*“ ئەوە فەرمایشتی یەزدانە.»
\p 
\v 14 یەزدان دەفەرموێت: «”ڕۆژێک دێت، ئەو بەڵێنە چاکە دەهێنمە دی کە سەبارەت بە بنەماڵەی ئیسرائیل و بنەماڵەی یەهودا فەرمووبووم.
\q1 
\v 15 «”لەو سەردەمەدا و لەو کاتەدا
\q2 لقێکی ڕاستودروست بۆ داود دەردەکەم،
\q2 جا ڕاستودروستی و دادپەروەری لەسەر زەوی پەیڕەو دەکات.
\q1 
\v 16 لە سەردەمی ئەودا یەهودا ڕزگاری دەبێت و
\q2 ئۆرشەلیم بە ئاسوودەیی نیشتەجێ دەبێت.
\q1 ئەو ناوەی کە پێی دەناسرێت:
\q2 یەزدان ڕاستودروستیمانە.“
\m 
\v 17 یەزدان ئەمە دەفەرموێت: ”پیاو لە داود نابڕێت بۆ دانیشتن لەسەر تەختی بنەماڵەی ئیسرائیل.
\v 18 لە کاهینە لێڤییەکانیش پیاو نابڕێت لەبەردەمم بۆ بەردەوامیدان بە پێشکەشکردنی قوربانی سووتاندن، سووتاندنی پێشکەشکراوی دانەوێڵە و ئامادەکردنی قوربانی سەربڕاو.“»
\p 
\v 19 هەروەها فەرمایشتی یەزدان بۆ یەرمیا هات:
\v 20 «یەزدان ئەمە دەفەرموێت: ”ئەگەر بتوانن پەیمانەکەم لەگەڵ ڕۆژ و لەگەڵ شەودا بشکێنن، تاکو ئیتر ڕۆژ و شەو لە کاتی خۆیاندا نەبن،
\v 21 ئەوسا دەکرێ پەیمانەکەم لەگەڵ داودی بەندەم بشکێنرێت و کوڕی نەبێت بۆ ئەوەی لەسەر تەختەکەی ببێتە پاشا، هەروەها لەگەڵ لێڤییە کاهینەکانی خزمەتکارانم.
\v 22 هەروەک چۆن ئەستێرەکانی ئاسمان ناژمێردرێن و لمی دەریا ئامار ناکرێت، ئاوا نەوەی داودی بەندەم و لێڤییە خزمەتکارەکانم زیاد دەکەم.“»
\p 
\v 23 ئینجا فەرمایشتی یەزدان بۆ یەرمیا هات:
\v 24 «نەتبینیوە ئەم گەلە باسی چی دەکەن و دەڵێن: ”ئەو دوو خێڵەی\f + \fr 33:24 \ft مەبەستی لە نەوەکانی یاقوب و داودە، بڕوانە ئایەتی 26.‏\f* یەزدان هەڵیبژاردن، ڕەتی کردنەوە.“ ئینجا سووکایەتییان بە گەلەکەم کرد، وەک ئەوەی ئیتر نەتەوە نەبێت لەبەردەمیان.
\v 25 یەزدان ئەمە دەفەرموێت: ”ئەگەر پەیمانی خۆمم لەگەڵ ڕۆژ و شەو و فەرزەکانی ئاسمان و زەوی نەبەست،
\v 26 ئەوسا نەوەی یاقوب و داودی بەندەم ڕەت دەکەمەوە و لە نەوەکەی ئەو فەرمانڕەوایان بەسەر نەوەی ئیبراهیم و ئیسحاق و یاقوبەوە دانانێم، چونکە من ڕاپێچکراوەکانیان دەگەڕێنمەوە و بەزەییم پێیاندا دێتەوە.“»
\c 34
\s1 ئاگاداری بۆ سدقیا
\p 
\v 1 کاتێک نەبوخودنەسری پاشای بابل و هەموو سوپاکەی و هەموو شانشینەکانی ئەو خاکانەی لەژێر دەستی فەرمانڕەوایەتی ئەودا بوون و هەموو گەلان لە دژی ئۆرشەلیم و هەموو شارۆچکەکانی دەجەنگین، یەزدان پەیامی بۆ یەرمیا نارد، فەرمووی:
\v 2 «یەزدانی پەروەردگاری ئیسرائیل ئەمە دەفەرموێت: بڕۆ قسە لەگەڵ سدقیای پاشای یەهودا بکە و پێی بڵێ: ”یەزدان ئەمە دەفەرموێت: من خەریکم ئەم شارە دەدەمە دەست پاشای بابلەوە و بە ئاگر دەیسووتێنێت.
\v 3 تۆش لە دەستی دەرباز نابیت، بەڵکو بەگرتن دەگیرێیت و دەدرێیتە دەستی ئەوەوە، چاوەکانت چاوەکانی پاشای بابل دەبینێت، ڕووبەڕوو قسەت لەگەڵ دەکات. پاشان دەچیتە بابل.
\p 
\v 4 «”ئەی سدقیای پاشای یەهودا، گوێ لە بەڵێنی یەزدان بگرە، یەزدان ئەمە دەفەرموێت سەبارەت بە تۆ: بە شمشێر نامریت،
\v 5 بە ئاشتی دەمریت. وەک چۆن خەڵکی بۆ ڕێزگرتن لە باوباپیرانی پاشاکانی پێش تۆ بخووریان دەسووتاند، ئاوا بۆ ڕێزگرتن لە تۆ بخوور دەسووتێنن، بە ’گەورە ڕۆ!‘ بۆت دەلاوێنەوە. یەزدان دەفەرموێت: من ئەو بەڵێنە دەدەم.“»
\p 
\v 6 جا یەرمیای پێغەمبەر لە ئۆرشەلیم هەموو ئەم قسانەی بە سدقیای پاشای یەهودا گوت،
\v 7 لەو کاتەی سوپاکەی پاشای بابل کەوتە جەنگەوە لە دژی ئۆرشەلیم و ئەو شارانەی دیکەی یەهودا کە مابوونەوە، لە دژی لاخیش و عەزێقا، لە شارە قەڵابەندەکانی یەهودا تەنها ئەمانە مابوونەوە.
\s1 ئازادکردنی کۆیلەکان
\p 
\v 8 ئەو پەیامەی لەلایەن یەزدانەوە بۆ یەرمیا هات، دوای ئەوەی سدقیای پاشا پەیمانی لەگەڵ هەموو گەل بەست کە لە ئۆرشەلیم بوون بۆ ڕاگەیاندنی ئازادکردنی کۆیلە.
\v 9 هەرکەسە کۆیلە عیبرانییەکەی و کەنیزە عیبرانییەکەی خۆی ئازاد بکات، بۆ ئەوەی کەس ئەو برا و خوشکە جولەکەیەی نەکات بە کۆیلە.
\v 10 پیاوە گەورەکان و هەموو گەل هاتنە ناو پەیمانەکەوە و ڕازی بوون بەوەی هەرکەسە و دەبێت کۆیلە و کەنیزەکەی خۆی ئازاد بکات و ئیتر کەس نەیانکات بە کۆیلە، گوێڕایەڵ بوون و بەڕەڵایان کردن.
\v 11 بەڵام پاشان گەڕانەوە، ئەو کۆیلە و کەنیزانەی ئازادیان کردبوون جارێکی دیکە کردیاننەوە بە کۆیلە و کەنیزە.
\p 
\v 12 ئینجا فەرمایشتی یەزدان بۆ یەرمیا هات:
\v 13 «یەزدانی پەروەردگاری ئیسرائیل ئەمە دەفەرموێت: من لەگەڵ باوباپیرانتان پەیمانم بەست، ئەو ڕۆژەی لە خاکی میسرەوە دەرمهێنان لە خاکی کۆیلایەتییەوە، فەرمووم:
\v 14 ”لە کۆتایی حەوت ساڵدا هەرکەسە و دەبێت ئەو عیبرانییە ئازاد بکات و بەڕەڵا بکات کە خۆی بە ئێوە فرۆشتووە و شەش ساڵ خزمەتی کردوون.“\f + \fr 34:14 \ft بڕوانە \xt دواوتار 15‏:12‏\xt*\ft ‏\f* بەڵام باوکانتان گوێیان لێ نەگرتم و گوێیان شل نەکرد.
\v 15 ئەمڕۆ ئێوە تۆبەتان کرد و ئەوەی لەبەرچاوی من ڕاست بوو کردتان، هەرکەسە و ئازادکردنی بۆ هاونیشتیمانییەکەی ڕاگەیاند، لەو ماڵەی ناوی منی هەڵگرتووە پەیمانتان بەست.
\v 16 بەڵام پاشان هەڵگەڕانەوە و ناوی منتان زڕاند، هەریەکەتان کۆیلە و کەنیزەکەی گەڕاندەوە، ئەوانەی ئازادتان کردبوون چییان بوێ بۆ خۆیان بیکەن، ناچارتان کردن ببنەوە کۆیلە و کەنیزەتان.
\p 
\v 17 «لەبەر ئەوە یەزدان ئەمە دەفەرموێت: ئێوە گوێڕایەڵی من نەبوون بۆ ئەوەی هەرکەسە و ئازادکردنی هاونیشتیمانییەکەی ڕابگەیەنێت، من ”ئازادی“ بۆ ئێوە ڕادەگەیەنم، ”ئازادی“ بۆ ئەوەی بە شمشێر و قاتوقڕی و دەرد لەناوبچن. وا دەکەم هەموو شانشینەکانی زەوی لێتان بتۆقن. ئەوە فەرمایشتی یەزدانە.
\v 18 ئەو کەسانەی کە پەیمانەکەی منیان شکاند، ئەوانەی بەندەکانی ئەو پەیمانەیان جێبەجێ نەکرد کە لەبەردەمی من بەستیان، وەک ئەو گوێرەکەیەیان لێدەکەم کە دوو لەتیان کرد و بەناو دوو لەتەکەیدا تێپەڕین.\f + \fr 34:18 \ft وەک نیشانەی بەستنی پەیمان گوێرەکەیەک پارچە کراوە بۆ دوو بەش و جیا کراوەتەوە، هەروەها ئەو کەسەی پەیمانەکە دەبەستێت بە نێوان دوو بەشەکەدا تێدەپەڕێت و دەڵێت ئەگەر دڵسۆز نەبم بۆ پەیمانەکە منیش وەک ئەوەم لێبێت. بڕوانە \xt پەیدابوون 15‏:9‏-19.‏\xt*\ft ‏\f*
\v 19 پیاوە گەورەکانی یەهودا و پیاوە گەورەکانی ئۆرشەلیم و کاربەدەستان و کاهینان و هەموو گەلی خاکەکە، ئەوانەی بەناو دوو لەتی جوانەگادا تێپەڕین،
\v 20 دەیاندەمە دەست دوژمنەکانیان کە دەیانەوێ بیانکوژن. تەرمەکانیان دەبێت بە خۆراکی باڵندە و ئاژەڵی کێوی.
\p 
\v 21 «سدقیای پاشای یەهودا و پیاوە گەورەکانیشی دەدەمە دەست دوژمنەکانیان کە دەیانەوێ بیانکوژن، دەیاندەمە دەست سوپاکەی پاشای بابل، ئەوانەی لە کۆڵتان بوونەتەوە.
\v 22 من فەرمان دەدەم بابلییەکان بگەڕێنەوە ئەم شارە و لە دژی بجەنگن. ئەم شارە دەگرن و بە ئاگر دەیسووتێنن، شارۆچکەکانی یەهوداش وێران دەکەم و ئاوەدانی تێدا نامێنێت.»
\q4 ئەوە فەرمایشتی یەزدانە.
\c 35
\s1 ڕێکابییەکان
\p 
\v 1 ئەمە ئەو پەیامەیە کە لەلایەن یەزدانەوە بۆ یەرمیا هات، لە سەردەمی پاشایەتی یەهۆیاقیمی کوڕی یۆشیای پاشای یەهودا:
\v 2 «بڕۆ بۆ ماڵی ڕێکابییەکان و قسەیان لەگەڵ بکە، بیانهێنە بۆ ماڵی یەزدان، بیانبە ژوورەوە بۆ یەکێک لە ژوورە لاتەنیشتەکان و شەرابیان دەرخوارد بدە.»
\p 
\v 3 منیش یازەنیاهوی کوڕی یەرمیای کوڕی حەڤەچینیا و براکانی و هەموو کوڕەکانی و هەموو بنەماڵەی ڕێکابییەکانم برد.
\v 4 ئەوانم بردە ماڵی یەزدان، بۆ ژوورەکەی نەوەکانی حانانی کوڕی یەگدەلیاهوی پیاوی خودا، ئەوەی لەتەنیشت ژووری پیاوە گەورەکانە، لەسەر ژوورەکەی مەعسێیاهوی کوڕی شەلوم کە پاسەوانی دەرگاکەیە.
\v 5 جامی پڕ شەراب و پەرداخم لەپێش کوڕانی بنەماڵەی ڕێکابییەکان دانا و پێم گوتن: «شەراب بخۆنەوە!»
\p 
\v 6 بەڵام ئەوان گوتیان: «ئێمە شەراب ناخۆینەوە، چونکە یۆنادابی کوڕی ڕێکابی باپیرە گەورەمان، فەرمانی پێ کردووین و گوتوویەتی: ”نە خۆتان و نە کوڕەکانتان بۆ هەتاهەتایە شەراب مەخۆنەوە.
\v 7 هەروەها خانوو بنیاد مەنێن، کشتوکاڵ مەکەن، ڕەزیش مەچێنن و نەتانبێت، بەڵکو بە درێژایی ژیانتان چادرنشین بن، بۆ ئەوەی تەمەنێکی درێژ لەسەر ڕووی ئەم خاکە بژین کە ئێوە تێیدا نامۆن.“
\v 8 ئێمەش گوێڕایەڵی قسەکەی یۆنادابی کوڕی ڕێکابی باپیرە گەورەمان دەبین. لە هەموو ئەوەی فەرمانی پێ کردووین، بە درێژایی ژیانمان نە خۆمان و نە ژنەکانمان و نە کوڕ و کچەکانمان شەراب ناخۆینەوە،
\v 9 خانوو بنیاد نانێن بۆ نیشتەجێبوونمان، ڕەز و کێڵگە و کشتوکاڵیشمان نابێت.
\v 10 چادرنشین بووین، بە تەواوی گوێڕایەڵی هەموو ئەوە بووین کە یۆنادابی باپیرە گەورەمان فەرمانی پێ کردووین.
\v 11 بەڵام کاتێک نەبوخودنەسری پاشای بابل هەڵیکوتایە سەر ئەو خاکە، ئێمەش گوتمان: ”دەبێ بچینە ئۆرشەلیم بۆ هەڵاتن لە دەستی سوپای بابلی و سوپای ئارامییەکان.“ جا لە ئۆرشەلیم نیشتەجێ بووین.»
\p 
\v 12 ئینجا فەرمایشتی یەزدان بۆ یەرمیا هات، یەزدان بە یەرمیای فەرموو:
\v 13 «یەزدانی سوپاسالار، خودای ئیسرائیل ئەمە دەفەرموێت: بڕۆ بە پیاوانی یەهودا و دانیشتووانی ئۆرشەلیم بڵێ یەزدان پێتان دەفەرموێت: ”ئایا ئێوە تەمبێ نابن، بۆ ئەوەی گوێڕایەڵی فەرمایشتەکانم بن؟
\v 14 یۆنادابی کوڕی ڕێکاب فەرمانی بە کوڕەکانی کرد شەراب نەخۆنەوە، فەرمانەکەی جێبەجێ کرا. هەتا ئەمڕۆش شەرابیان نەخواردووەتەوە، چونکە گوێڕایەڵی فەرمانی باپیرە گەورەیان بوون. بەڵام من بەردەوام قسەم لەگەڵ ئێوە کردووە، ئێوە گوێڕایەڵی من نەبوون.
\v 15 من بە بەردەوامی هەموو بەندە پێغەمبەرەکانی خۆمم بۆ ئێوە ناردووە، بۆ ئەوەی پێتان بڵێن: ’هەریەکە و لە ڕەفتارە خراپەکانتان بگەڕێنەوە و کردەوەکانتان چاک بکەنەوە، دوای خودای دیکە مەکەون بۆ پەرستنیان، بگەڕێنەوە بۆ ئەو خاکەی داومەتە خۆتان و باوباپیرانتان.‘ بەڵام ئێوە گوێتان پێنەدام و گوێتان لێ نەگرتم.
\v 16 کوڕەکانی یۆنادابی کوڕی ڕێکاب فەرمانەکەی باپیرە گەورەیان بەجێگەیاند کە فەرمانی پێ کردن، بەڵام ئەم گەلە گوێڕایەڵی من نەبوون.“
\p 
\v 17 «لەبەر ئەوە یەزدانی پەروەردگاری سوپاسالار، خودای ئیسرائیل ئەمە دەفەرموێت: ”ئەوەتا من هەموو ئەو خراپەیە بەسەر یەهودا و دانیشتووانی ئۆرشەلیمدا دەهێنم کە سەبارەت بەوان فەرمووبووم. لەبەر ئەوەی قسەم لەگەڵ کردن، بەڵام گوێیان لێ نەگرتم، بانگم کردن بەڵام وەڵامیان نەدامەوە.“»
\p 
\v 18 یەرمیا بە بنەماڵەی ڕێکابییەکانی گوت: «یەزدانی سوپاسالار، خودای ئیسرائیل ئەمە دەفەرموێت: ”ئێوە گوێڕایەڵی فەرمانەکەی یۆنادابی باپیرە گەورەتان بوون، هەروەها هەموو فەرمانەکانی ئەوتان پاراست و هەموو ئەوەتان کرد کە فەرمانی پێ کردبوون.“
\v 19 لەبەر ئەوە یەزدانی سوپاسالار، خودای ئیسرائیل ئەمە دەفەرموێت: ”بە درێژایی ڕۆژگار پیاو نابڕێت لە یۆنادابی کوڕی ڕێکاب بۆ خزمەتکردنم.“»
\c 36
\s1 سووتاندنی تۆمارەکەی یەرمیا
\p 
\v 1 لە ساڵی چوارەمی یەهۆیاقیمی کوڕی یۆشیای پاشای یەهودا، ئەم پەیامە لەلایەن یەزدانەوە بۆ یەرمیا هات:
\v 2 «تۆمارێک بۆ خۆت بهێنە و هەموو ئەو وشانەی کە پێم فەرموویت سەبارەت بە ئیسرائیل و یەهودا و هەموو گەلان، لە ماوەی پاشایەتی یۆشیاوە هەتا ئەمڕۆ، هەمووی تێدا تۆمار بکە.
\v 3 بەڵکو بنەماڵەی یەهودا گوێیان لە هەموو ئەو بەڵایە دەبێت کە بە نیازم بەسەریان بهێنم، بۆ ئەوەی هەریەکە و لە ڕێگا خراپەکانی خۆیەوە بگەڕێتەوە، منیش لە تاوان و گوناهەکانیان خۆشدەبم.»
\p 
\v 4 یەرمیاش باروخی کوڕی نێرییای بانگکرد، لە کاتێکدا یەرمیا هەموو وشەکانی یەزدانی دەگوتەوە کە پێی گوترابوو، باروخیش لە تۆمارێکدا نووسییەوە.
\v 5 یەرمیا فەرمانی بە باروخ کرد و گوتی: «من بەندم و ناتوانم بچمە ناو پەرستگای یەزدانەوە.
\v 6 جا تۆ لە ڕۆژی ڕۆژووگرتن بڕۆ ناو پەرستگای یەزدان و وشەکانی یەزدان ئەوەی لەبەردەمم لە تۆمارەکەدا نووسیتەوە بیخوێنەوە. بۆ گەلی یەهودای بخوێنەوە، ئەوانەی لە شارۆچکەکانی خۆیانەوە دێن.
\v 7 بەڵکو لەبەردەم یەزدان دەپاڕێنەوە، هەریەکە لە ڕێگا خراپەکانی خۆیان بگەڕێنەوە، لەبەر ئەوەی ئەو تووڕەیی و هەڵچوونەی کە یەزدان سەبارەت بەم گەلە فەرموویەتی، گەورەیە.»
\p 
\v 8 باروخی کوڕی نێرییاش هەموو ئەوەی کرد کە یەرمیای پێغەمبەر ڕایسپارد. بەوەی لە پەرستگای یەزداندا وشەکانی یەزدانی لەنێو تۆمارەکە خوێندەوە.
\v 9 لە مانگی نۆی ساڵی پێنجەمی یەهۆیاقیمی کوڕی یۆشیای پاشای یەهودا، بانگەوازی ڕۆژووگرتنیان ڕاگەیاند بۆ هەموو گەل لە ئۆرشەلیم، لەگەڵ هەموو ئەوانەی لە شارۆچکەکانی یەهوداوە هاتبوونە ئۆرشەلیم.
\v 10 لە ژوورەکەی گەمەریای کوڕی شافانی خامەی نهێنی\f + \fr 36:10 \ft ڕازپۆش.‏\f*، لە حەوشەکەی سەرەوە، لەلای داڵانی دەروازە نوێیەکەی پەرستگای یەزدان، باروخ وشەکانی نێو تۆمارەکەی یەرمیای بۆ هەموو گەل خوێندەوە.
\p 
\v 11 کاتێک میخایوی کوڕی گەمەریای کوڕی شافان هەموو وشەکانی یەزدانی لەنێو تۆمارەکە بیست،
\v 12 دابەزی بۆ ژوورەکەی خامەی نهێنی لە کۆشکی پاشا، کە هەموو پیاوە گەورەکان لەوێ دانیشتبوون، ئەلیشاماعی خامەی نهێنی، دەلایای کوڕی شەمەعیا، ئەلناتانی کوڕی عەکبۆر، گەمەریای کوڕی شافان، سدقیای کوڕی حەنەنیا، هەروەها هەموو پیاوە گەورەکانی دیکە.
\v 13 میخایوش هەموو ئەو قسانەی پێ ڕاگەیاندن کە بیستبووی، لە کاتێک کە باروخ تۆمارەکەی بۆ گەل دەخوێندەوە.
\v 14 جا هەموو پیاوە گەورەکان یەهودی کوڕی نەتەنیاهۆی کوڕی شەلەمیاهوی کوڕی کووشیان نارد بۆ ئەوەی بە باروخ بڵێت: «ئەو تۆمارەی لێیەوە بۆ ئەم گەلە خوێندتەوە، لەگەڵ دەستت هەڵیبگرە و وەرە.» ئینجا باروخی کوڕی نێرییاش تۆمارەکەی لەگەڵ دەستی هەڵگرت و چوو بۆ لایان.
\v 15 پێیان گوت: «فەرموو دابنیشە، گوێمان لێبێت بیخوێنەوە.»
\p باروخیش بۆی خوێندنەوە.
\v 16 کاتێک گوێیان لە هەموو ئەو وشانە بوو، بە ترسەوە تەماشای یەکتریان کرد و بە باروخیان گوت: «دەبێ تەواوی ئەم وشانە بە پاشا ڕابگەیەنین.»
\v 17 ئینجا لە باروخیان پرسی: «تکایە پێمان بڵێ چۆن هەموو ئەم وشانەت نووسی؟ ئایا لە دەمی یەرمیا بیستت؟»
\p 
\v 18 باروخیش وەڵامی دانەوە: «بەڵێ، بە دەمی خۆی هەموو ئەم وشانەی بۆ دەگوتم، منیش بە مەرەکەب لە تۆمارەکەدا دەمنووسییەوە.»
\p 
\v 19 ئینجا پیاوە گەورەکان بە باروخیان گوت: «بڕۆ خۆت و یەرمیا خۆتان بشارنەوە، با کەس نەزانێت ئێوە لەکوێن.»
\p 
\v 20 دوای ئەوەی تۆمارەکەیان لە ژوورەکەی ئەلیشاماعی خامەی نهێنی دانا، چوونە هەیوانەکە بۆ لای پاشا، هەموو ئەو شتانەیان بە پاشا ڕاگەیاند.
\v 21 پاشا یەهودی نارد بۆ ئەوەی تۆمارەکە بهێنێت، ئەویش لە ژوورەکەی ئەلیشاماعی خامەی نهێنییەوە تۆمارەکەی هێنا. یەهودی بۆ پاشا و بۆ هەموو ئەو پیاوە گەورانەی لای پاشا وەستابوون خوێندییەوە.
\v 22 ئەوە لە مانگی نۆ بوو، پاشا لە ماڵی زستانە دانیشتبوو، ئاگردانێکیش لەبەردەمی داگیرسابوو.
\v 23 کاتێک یەهودی سێ چوار ستوونی لە تۆمارەکە خوێندەوە، پاشا بە قەڵەمبڕی نووسەرەکە پارچەپارچەی کرد و فڕێیدایە ناو ئاگردانەکەوە هەتا هەموو تۆمارەکە لەناو ئاگرەکە بە تەواوی فەوتا.
\v 24 جا نە پاشا و نە هیچ یەکێک لە خزمەتکارەکانی کە گوێیان لە هەموو ئەو وشانە بوو نەترسان، جلەکانی بەریان دانە دڕی.
\v 25 هەرچەندە ئەلناتان و دەلایا و گەمەریا تکایان لە پاشا کرد تۆمارەکە نەسووتێنێت، بەڵام ئەو گوێی لێ نەگرتن.
\v 26 بەڵکو پاشا فەرمانی دا بە میر یەرەحمێل و سەرایای کوڕی عەزریێل و شەلەمیاهوی کوڕی عەبدئێل بۆ گرتنی باروخی سەرقەڵەم و یەرمیای پێغەمبەر، بەڵام یەزدان ئەوانی شاردەوە.
\p 
\v 27 دوای ئەوەی پاشا تۆمارەکەی سووتاند کە ئەو وشانەی تێدابوو باروخ لە دەمی یەرمیاوە نووسیبووی، فەرمایشتی یەزدان بۆ یەرمیا هات:
\v 28 «بگەڕێوە و تۆمارێکی دیکە ببە و هەموو ئەو وشانەی تێدا بنووسەوە کە لەناو تۆمارەکەی یەکەم جار بوو، ئەوەی یەهۆیاقیمی پاشای یەهودا سووتاندی.
\v 29 بە یەهۆیاقیمی پاشای یەهوداش بڵێ: ”یەزدان ئەمە دەفەرموێت: تۆ ئەو تۆمارەت سووتاند و گوتت: ’بۆچی تێیدا نووسیت و گوتت، بێگومان پاشای بابل دێت و ئەم خاکە دەفەوتێنێت و مرۆڤ و ئاژەڵی تێدا قڕ دەکات؟‘
\v 30 لەبەر ئەوە یەزدان لەبارەی یەهۆیاقیمی پاشای یەهوداوە ئەمە دەفەرموێت: کەس لە ڕەچەڵەکی ئەو لەسەر تەختی داود دانانیشێت، تەرمەکەی فڕێدەدرێتە بەر گەرمای ڕۆژ و سەرمای شەو.
\v 31 سزای خۆی و منداڵ و خزمەتکارەکانی دەدەم لەسەر تاوانەکانیان، هەموو ئەو بەڵایەی پێیانم گوت، بەسەر خۆیان و دانیشتووانی ئۆرشەلیم و پیاوانی یەهودای دەهێنم، چونکە گوێیان نەگرت.“»
\p 
\v 32 ئینجا یەرمیا تۆمارێکی دیکەی برد و دایە باروخی کوڕی نێرییای سەرقەڵەم، ئەویش لە دەمی یەرمیاوە هەموو وشەکانی ئەو تۆمارەی نووسییەوە کە یەهۆیاقیمی پاشای یەهودا لەناو ئاگردانەکە سووتاندی، هەروەها زۆر وشەی لەو جۆرەشی بۆ زیاد کرد.
\c 37
\s1 یەرمیا لە بەندیخانە
\p 
\v 1 ئینجا نەبوخودنەسری پاشای بابل سدقیا کوڕی یۆشیای لە خاکی یەهودا کردە پاشا، لە جێی یەهۆیاکینی کوڕی یەهۆیاقیم.
\v 2 بەڵام نە خۆی و نە خزمەتکارەکانی و نە گەلی خاکەکە گوێیان لە پەیامەکەی یەزدان نەگرت کە لە ڕێگەی یەرمیای پێغەمبەرەوە فەرمووی.
\p 
\v 3 جا سدقیای پاشا یەهوخەلی کوڕی شەلەمیاهو و سەفەنیای کوڕی مەعسێیاهوی کاهینی بۆ لای یەرمیای پێغەمبەر نارد و گوتی: «تکایە لە پێناوی ئێمە لە یەزدانی پەروەردگارمان بپاڕێوە.»
\p 
\v 4 لەو کاتەدا یەرمیا بە ئازادی هاتوچۆی ناو خەڵکی دەکرد، چونکە هێشتا نەیانخسبووە بەندیخانەوە.
\v 5 سوپاکەی فیرعەونیش لە میسرەوە بەڕێکەوتبوون، کاتێک ئەو بابلییانەی کە گەمارۆی ئۆرشەلیمیان دابوو هەواڵی ئەوانیان بیست، لە ئۆرشەلیم کشانەوە.
\p 
\v 6 ئینجا فەرمایشتی یەزدان بۆ یەرمیای پێغەمبەر هات، پێی فەرموو:
\v 7 «یەزدانی پەروەردگاری ئیسرائیل ئەمە دەفەرموێت: پاشای یەهودا کە ئێوەی ناردووە بۆ لام تاکو لێم بپرسێت، پێی بڵێن: ”ئەوەتا سوپاکەی فیرعەون کە بۆ یارمەتیتان بەڕێکەوتوون، دەگەڕێتەوە خاکەکەی خۆی، میسر.
\v 8 بابلییەکانیش دەگەڕێنەوە و شەڕ لەگەڵ ئەم شارە دەکەن، دەیگرن و بە ئاگر دەیسووتێنن.“
\p 
\v 9 «یەزدان ئەمە دەفەرموێت: خۆتان مەخەڵەتێنن و بڵێن: ”بابلییەکان بە تەواوی لە کۆڵمان دەبنەوە.“ لە کۆڵتان نابنەوە!
\v 10 تەنانەت ئەگەر هەموو سوپای بابلییەکانیش ببەزێنن کە لە دژتان دەجەنگن، تەنها چەند پیاوێکی برینداریان لێ بمێنێتەوە، ئەوا هەریەکە لە چادرەکەی خۆیانەوە هەڵدەستنەوە و ئەم شارە بە ئاگر دەسووتێنن.»
\p 
\v 11 دوای ئەوەی سوپای بابلییەکان لە ئۆرشەلیم بەرامبەر بە سوپاکەی فیرعەون کشانەوە،
\v 12 یەرمیاش دەستبەجێ ئۆرشەلیمی بەجێهێشت بۆ ئەوەی بچێتە خاکی بنیامین، تاکو لەوێ لەنێو گەل بەشی خۆی لە زەوی وەربگرێت.
\v 13 بەڵام کە گەیشتە ناو دەروازەی بنیامین، سەرکارێکی پاسەوانان لەوێ هەبوو، ناوی یرئیا ی کوڕی شەلەمیاهوی کوڕی حەنەنیا بوو، یەرمیای پێغەمبەری گرت و پێی گوت: «تۆ دەچیتە پاڵ بابلییەکان!»
\p 
\v 14 یەرمیاش گوتی: «درۆیە! من ناچمە پاڵ بابلییەکان.» بەڵام یرئیا گوێی لێ نەگرت، ئینجا یەرمیای گرت و هێنایە لای پیاوە گەورەکان.
\v 15 پیاوە گەورەکانیش لە یەرمیا تووڕە بوون، لێیاندا و لە ماڵی یۆناتانی خامەی نهێنی بەندیان کرد، چونکە ئەوێیان کردبووە بەندیخانە.
\p 
\v 16 یەرمیایان خستە کونجی زیندانەوە لە بەندیخانەکە، ماوەیەکی زۆر لەوێ مایەوە.
\v 17 ئینجا سدقیا پاشا ناردی و لەوێ دەریانهێنا، پاشا لە ماڵەکەی خۆی بەدزییەوە پرسیاری لێکرد و گوتی: «ئایا هیچ پەیامێک لەلایەن یەزدانەوە هەیە؟»
\p یەرمیاش وەڵامی دایەوە: «بەڵێ، هەیە. تۆ دەکەویتە دەست پاشای بابلەوە.»
\p 
\v 18 ئینجا یەرمیا بە سدقیا پاشای گوت: «تاوانی من دەرهەق بە تۆ و خزمەتکارەکانت و ئەم گەلە چییە، هەتا بمخەنە بەندیخانەوە؟
\v 19 ئەی کوا پێغەمبەرەکانتان، ئەوانەی پێشبینییان بۆ کردیت و گوتیان: ”پاشای بابل نایەتە سەر ئێوە و ئەم خاکە“؟
\v 20 ئێستاش، ئەی پاشای گەورەم، تکایە گوێ بگرە. تکایە با لەبەردەمت بپاڕێمەوە: مەمگەڕێنەوە بۆ ماڵەکەی یۆناتانی خامەی نهێنی، با لەوێ نەمرم.»
\p 
\v 21 سدقیای پاشاش فەرمانی دا کە یەرمیا بخرێتە حەوشەی پاسەوانەکان، ڕۆژانە یەک نانی لە بازاڕی نانەوایانەوە پێبدرێت، هەتا بە تەواوی نان لە شارەکە دەبڕدرێتەوە. یەرمیا لە حەوشەی پاسەوانەکان مایەوە.
\c 38
\s1 یەرمیا فڕێدرایە ناو ئەمباراوێک
\p 
\v 1 ئینجا شەفەتیای کوڕی مەتان، گەدەلیاهوی کوڕی پەشحور، یەهوخەلی کوڕی شەلەمیاهو و پەشحوری کوڕی مەلکیا گوێیان لەو قسانە بوو کە یەرمیا لەگەڵ گەل دەیکرد و دەیگوت:
\v 2 «یەزدان ئەمە دەفەرموێت: ”ئەوەی لەم شارەدا بمێنێتەوە بە شمشێر و قاتوقڕی و دەرد لەناودەچێت، بەڵام ئەوەی بچێتە دەرەوە بۆ ناو بابلییەکان دەژیێت. ژیانی خۆی دەرباز دەکات و دەژیێت.“
\v 3 یەزدان ئەمە دەفەرموێت: ”بە دڵنیاییەوە ئەم شارە دەدرێتە دەست سوپاکەی پاشای بابل، دەستی بەسەردا دەگرێت.“»
\p 
\v 4 جا پیاوە گەورەکان بە پاشایان گوت: «دەبێت ئەم پیاوە بکوژرێت. لەبەر ئەوەی بەو قسانەی ورەی ئەو سەربازانە دەڕووخێنێ کە لە شارەکەدا ماونەتەوە، هەروەها ورەی هەموو خەڵکیش دەرووخێنێ. ئەم پیاوە داوای چاکە بۆ ئەم گەلە ناکات، بەڵکو خراپە.»
\p 
\v 5 سدقیای پاشا گوتی: «ئەوەتا لەبەردەستتانە، پاشا توانای هیچی نییە بەرامبەر بە ئێوە.»
\p 
\v 6 ئەوانیش یەرمیایان برد و فڕێیان دایە ناو ئەمباراوەکەی مەلکیای کوڕی پاشا، ئەوەی لە حەوشەی پاسەوانەکانە. یەرمیایان بە گوریس شۆڕکردە خوارەوە، ئەمباراوەکەش ئاوی تێدا نەبوو، بەڵکو قوڕ. جا یەرمیا لەناو قوڕەکە چەقی.
\p 
\v 7 بەڵام عەبەدمەلەخ، کە کاربەدەستێکی کوشی\f + \fr 38:7 \ft کوش: وڵاتێکە لە سەرووی ڕووباری نیل.‏\f* بوو لە کۆشکی پاشا، بیستی کە یەرمیایان فڕێداوەتە ناو ئەمباراوەکە. پاشاش لە دەروازەی بنیامین دانیشتبوو،
\v 8 عەبەدمەلەخ لە کۆشکی پاشاوە چوو و بە پاشای گوت:
\v 9 «پاشای گەورەم، ئەم پیاوانە خراپیان کرد لە هەموو ئەوەی بە یەرمیای پێغەمبەریان کرد. ئەوان فڕێیان داوەتە ناو ئەمباراوەکەوە، ئەو لە شوێنەکەی خۆی لە برسان دەمرێت، چونکە نان لە شار نەماوە.»
\p 
\v 10 پاشاش فەرمانی بە عەبەدمەلەخی کوشی کرد و گوتی: «لێرەوە سی پیاو لەگەڵ خۆت ببە، یەرمیای پێغەمبەر لە ئەمباراوەکەوە دەربێنە، هەتا نەمردووە.»
\p 
\v 11 عەبەدمەلەخیش پیاوەکانی لەگەڵ خۆی برد، چووە ژوورێک لەژێر گەنجینەی کۆشکی پاشا. لەوێ هەندێک پەڕۆوپاتاڵ و جلی کۆنی هەڵگرت و بە گوریس بۆ یەرمیای شۆڕی کردەوە ناو ئەمباراوەکە.
\v 12 عەبەدمەلەخی کوشی بە یەرمیای گوت: «پەڕۆوپاتاڵ و جلە کۆنەکان لەبن هەنگڵت لەژێر گوریسەکەوە دابنێ.» یەرمیاش ئاوای کرد.
\v 13 ئینجا بە گوریس یەرمیایان هەڵکێشا، لە ئەمباراوەکە دەریانهێنا. جا یەرمیا لە حەوشەی پاسەوانەکان مایەوە.
\s1 پرسیاری سدقیا لە یەرمیا
\p 
\v 14 پاشان سدقیا پاشا بەدوای یەرمیای پێغەمبەردا ناردی، لە دەروازەی سێیەمی پەرستگای یەزدان هێنایە لای خۆی. ئینجا پاشا بە یەرمیای گوت: «دەمەوێت شتێکت لێ بپرسم، هیچم لێ مەشارەوە.»
\p 
\v 15 یەرمیاش بە سدقیای گوت: «ئەگەر پێت بڵێم، ئایا نامکوژیت؟ تەنانەت ئەگەر ئامۆژگاریشت بکەم، گوێم لێ ناگریت.»
\p 
\v 16 سدقیای پاشاش بەدزییەوە سوێندی بۆ یەرمیا خوارد و گوتی: «بە یەزدانی زیندوو کە ژیانی بە ئێمە بەخشیوە، نە دەتکوژم و نە دەتدەمە دەست ئەوانەی دەیانەوێ بتکوژن.»
\p 
\v 17 ئینجا یەرمیا بە سدقیای گوت: «یەزدان، خودای سوپاسالار، خودای ئیسرائیل ئەمە دەفەرموێت: ”ئەگەر خۆت ڕادەستی سەرکردەکانی پاشای بابل بکەیت، ئەوا گیانت بە زیندووێتی دەمێنێتەوە و ئەم شارەش بە ئاگر ناسووتێت، خۆت و خێزانەکەشت بە زیندووێتی دەمێننەوە.
\v 18 بەڵام ئەگەر خۆت ڕادەستی سەرکردەکانی پاشای بابل نەکەیت، ئەوا ئەم شارە دەکەوێتە دەست بابلییەکان و بە ئاگر دەیسووتێنن، تۆش لە دەستیان دەرباز نابیت.“»
\p 
\v 19 سدقیای پاشا بە یەرمیای گوت: «من لەو جولەکانە دەترسم کە چوونەتە پاڵ بابلییەکانەوە، نەوەک بابلییەکان بمدەنە دەست ئەوان، ئەوانیش سووکایەتیم پێ بکەن.»
\p 
\v 20 یەرمیاش گوتی: «ناتدەنە دەست ئەوان. گوێڕایەڵی فەرموودەی یەزدان بە کە من پێت ڕادەگەیەنم. ئینجا چاکەت بۆ دەبێت و ژیانت دەرباز دەبێت.
\v 21 ئەگەر ڕازیش نیت خۆت ڕادەست بکەیت، ئەوا ئەمە ئەو پەیامەیە کە یەزدان پیشانی دام.
\v 22 ئەوەتا هەموو ئەو ژنانەی لە کۆشکی پاشای یەهودا ماونەتەوە، بۆ سەرکردەکانی پاشای بابل دەبردرێن. ئەو ژنانە پێت دەڵێن:
\q1 «”ئەوانەی دۆستی تۆ بوون
\q2 فریویان دایت و زاڵ بوون بەسەرت.
\q1 کاتێک پێیەکانت لەناو زەلکاو چەقین
\q2 بەجێیان هێشتیت.“
\p 
\v 23 «هەموو ژنەکانت و منداڵەکانیشت بۆ بابلییەکان دەبردرێن. تۆش لە دەستیان دەرباز نابیت، بەڵکو بە دەستی پاشای بابل دەگیرێیت، ئەم شارەش بە ئاگر دەسووتێت.»
\p 
\v 24 سدقیاش بە یەرمیای گوت: «با کەس ئەم قسانە نەزانێت، نەوەک بمریت.
\v 25 ئەگەر پیاوە گەورەکان بیستیان من قسەم لەگەڵ تۆ کردووە، هاتنە لات و گوتیان: ”پێمان بڵێ چیت بە پاشا گوت و پاشا چی بە تۆ گوت، لێمان مەشارەوە، ئەگەر نا دەتکوژین،“
\v 26 تۆش پێیان بڵێ: ”لە پاشا پاڕامەوە تاوەکو نەمگەڕێنێتەوە بۆ ماڵی یۆناتان و لەوێ نەمرم.“»
\p 
\v 27 جا هەموو پیاوە گەورەکان بۆ لای یەرمیا هاتن و لێیان پرسی، ئەویش بەگوێرەی هەموو ئەو قسانەی پاشا فەرمانی پێی کرد، وەڵامی دانەوە. ئیتر ئەوانیش لێی بێدەنگ بوون، چونکە کەس قسەکردنی ئەوی لەگەڵ پاشا نەبیست.
\p 
\v 28 ئیتر یەرمیا هەتا ئەو ڕۆژەی ئۆرشەلیم گیرا لە حەوشەی پاسەوانەکان مایەوە.
\c 39
\s1 داگیرکردنی ئۆرشەلیم
\p 
\v 1 لە مانگی دەی ساڵی نۆیەمی سدقیای پاشای یەهودا، نەبوخودنەسری پاشای بابل هەموو سوپاکەی بەرەو ئۆرشەلیم جوڵاند و گەمارۆی دا.
\v 2 لە نۆی مانگی چواری ساڵی یازدەیەمی سدقیا شوورای شارەکە شکێنرا.
\v 3 جا هەموو سەرکردەکانی پاشای بابل هاتن و لە دەروازەکەی ناوەڕاست دانیشتن: نێرگەل‌سەرئەچەری سمەگەری، نەبۆسەرسەخیم کە سەرۆکی دیوان بوو، نێرگەل‌سەرئەچەر کە سەرۆکی مۆغەکان بوو، لەگەڵ پاشماوەی سەرکردەکانی پاشای بابل.
\v 4 کاتێک کە سدقیای پاشای یەهودا و هەموو جەنگاوەرەکان ئەوانیان بینی، هەڵاتن و بە شەو بە ڕێگای باخچەی پاشادا بە دەروازەکەی نێوان دوو شووراکەدا شارەکەیان بەجێهێشت، بەرەو دەشتایی عەراڤا\f + \fr 39:4 \ft عەراڤا شیوێک بووە لە دەریاچەی جەلیلەوە هەتا دەریای مردوو.‏\f* ڕۆیشتن.
\p 
\v 5 بەڵام سوپای بابلییەکان بەدوایان کەوتن، لە دەشتی ئەریحا گەیشتنە سدقیا. گرتیان و هێنایان بۆ لای نەبوخودنەسری پاشای بابل لە ڕیڤلە، لە خاکی حەمات، ئەویش دادگایی کرد.
\v 6 هەر لە ڕیڤلە پاشای بابل کوڕەکانی سدقیای لەبەرچاوی باوکیان کوشت، ئینجا هەموو پیاوماقوڵانی یەهوداشی لەناوبرد.
\v 7 پاشان هەردوو چاوی سدقیای دەرهێنا، بە زنجیری بڕۆنز کۆتی کرد بۆ ئەوەی بیباتە بابل.
\p 
\v 8 هەروەها بابلییەکان کۆشکی پاشا و ماڵەکانی خەڵکیان سووتاند، شووراکانی ئۆرشەلیمیان ڕووخاند.
\v 9 ئەو پاشماوەیەی خەڵکی کە لە شارەکە مابوونەوە و ئەوانەی چووبوونە پاڵی و پەنایان بردبووە بەر پاشای بابل، نەبوزەرەدانی فەرماندەی پاسەوانانی پاشا ڕاپێچی کردن بۆ بابل.
\v 10 بەڵام هەندێک لەو خەڵکە هەژارەی هیچیان نەبوو، نەبوزەرەدانی فەرماندەی پاسەوانانی پاشا لە خاکی یەهودا بەجێی هێشتن، هەر لەو کاتەدا ڕەز و کێڵگەی پێدان.
\p 
\v 11 نەبوخودنەسری پاشای بابل لەبارەی یەرمیاوە فەرمانی بە نەبوزەرەدانی فەرماندەی پاسەوانانی پاشا کرد:
\v 12 «بیبە و با چاوت لەسەری بێت، زیانی پێ مەگەیەنە، بەڵکو ئەوەی داوای دەکات بۆی بکە.»
\v 13 نەبوزەرەدانی فەرماندەی پاسەوانانی پاشا، نەبوشەزبانی سەرۆکی دیوان، نێرگەل‌سەرئەچەری سەرۆکی مۆغەکان، لەگەڵ هەموو سەرکردەکانی پاشای بابل
\v 14 ناردیان و یەرمیایان لە حەوشەی پاسەوانەکان دەرهێنا، دایانە دەست گەدەلیاهوی کوڕی ئەحیقامی کوڕی شافان، بۆ ئەوەی بیباتە ماڵەوە، ئیتر لەنێو خەڵکەکەی مایەوە.
\p 
\v 15 کاتێک یەرمیا لە حەوشەی پاسەوانەکان گیرابوو، فەرمایشتی یەزدانی بۆ هات، پێی فەرموو:
\v 16 «بڕۆ و بە عەبەدمەلەخی کوشی بڵێ: ”یەزدانی سوپاسالار، خودای ئیسرائیل، ئەمە دەفەرموێت: هەموو ئەوەی سەبارەت بەو شارە فەرمووم خەریکم پەیڕەوی دەکەم، بۆ خراپە نەک چاکەی، لەو کاتەدا لەبەرچاوت جێبەجێ دەکرێت.
\v 17 بەڵام لەو ڕۆژەدا تۆ ڕزگار دەکەم و نادرێیتە دەست ئەوانەی لێیان دەترسیت. ئەوە فەرمایشتی یەزدانە.
\v 18 بێگومان دەربازت دەکەم، بە شمشێر ناکوژرێیت و ژیانت ڕزگار دەبێت، چونکە پشتت بە من بەست. ئەوە فەرمایشتی یەزدانە.“»
\c 40
\s1 بەڕەڵاکردنی یەرمیا
\p 
\v 1 ئەو پەیامەی لەلایەن یەزدانەوە بۆ یەرمیا هات، پاش ئەوەی نەبوزەرەدانی فەرماندەی پاسەوانانی پاشا لە ڕامە یەرمیای بەڕەڵا کرد، کە بینیبووی یەرمیا بە زنجیر بەند کراوە و لەنێو هەموو ڕاپێچکراوەکانی ئۆرشەلیم و یەهودایە کە بۆ بابل ڕاپێچ کراون.
\v 2 فەرماندەی پاسەوانانی پاشا یەرمیای برد و پێی گوت: «یەزدانی پەروەردگارت سەبارەت بەم شوێنە ئەم بەڵایەی فەرموو.
\v 3 ئێستاش یەزدان ئەنجامی دا، هەروەک فەرمووی کردی. هەموو ئەو شتانەتان لەبەر ئەوە بەسەرهات گوناهتان کرد لە دژی یەزدان و گوێڕایەڵی نەبوون.
\v 4 ئەمڕۆ من ئازادت دەکەم لەو سندمانەی بەدەستتەوەیە. جا ئەگەر پێت باشە لەگەڵم بێیتە بابل، وەرە و منیش چاوم لێت دەبێت. بەڵام ئەگەر حەز ناکەیت، مەیێ. تەماشا بکە، هەموو خاکەکە لەبەردەمتە، جا کوێت پێ باشە و بۆت دەگونجێ، بڕۆ ئەوێ.»
\v 5 بەڵام بەر لە گەڕانەوەی یەرمیا، نەبوزەرەدان گوتی: «بگەڕێوە لای گەدەلیاهوی کوڕی ئەحیقامی کوڕی شافان، ئەوەی پاشای بابل بەسەر شارۆچکەکانی یەهوداوە دایناوە، لەنێو خەڵکەکە لەلای ئەو بمێنەوە، یانیش هەرکوێیەک پێت باشە و بۆت دەگونجێ بڕۆ ئەوێ.»
\p پاشان فەرماندەی پاسەوانانی پاشا توێشو و دیارییەکی پێیدا و بەڕەڵای کرد.
\v 6 یەرمیاش هاتە لای گەدەلیاهوی کوڕی ئەحیقام لە میچپا و لەلای ئەو مایەوە، لەناو ئەو خەڵکەی لە خاکەکەدا مابوونەوە.
\s1 کوشتنی گەدەلیاهو
\p 
\v 7 کاتێک هەموو سەرلەشکرەکان، ئەوانەی لەناو کێڵگەکان بوون، خۆیان و پیاوەکانیان بیستیان کە پاشای بابل گەدەلیاهوی کوڕی ئەحیقامی کردووە بە فەرمانڕەوای خاکەکە و سەرپەرشتیاری ژن و پیاو و منداڵان، ئەو هەژارانەی خاکەکە کە بۆ بابل ڕاپێچ نەکراون،
\v 8 هاتنە میچپا بۆ لای گەدەلیاهو. ئیسماعیلی کوڕی نەتەنیاهۆ، یۆحانان و یۆناتانی کوڕانی قارێیەح، سەرایای کوڕی تەنحومەت، کوڕەکانی عێفەیی نەتۆفایی و یازەنیاهوی کوڕی مەعکاتی، خۆیان و پیاوەکانیان.
\v 9 گەدەلیاهوی کوڕی ئەحیقامی کوڕی شافانیش سوێندی بۆ ئەوان و پیاوەکانیان خوارد، پێی گوتن: «مەترسن لەوەی خزمەتی بابلییەکان بکەن. لە خاکەکە نیشتەجێ بن و خزمەتی پاشای بابل بکەن، ئەوەی باشە بۆتان دەبێت.
\v 10 منیش لە میچپا دادەنیشم، بۆ ئەوەی لەبەردەم ئەو بابلییانە نوێنەرایەتی ئێوە بکەم کە دێنە لامان. بەڵام ئێوە شەراب و هەنجیر و زەیت کۆبکەنەوە، بیخەنە ناو کۆڵەبارەکانتانەوە، لەو شارۆچکانەی گرتووتانە نیشتەجێ بن.»
\p 
\v 11 کاتێک هەموو ئەو جولەکانەی لە مۆئاب و لەنێو عەمۆنییەکان و لە ئەدۆم و ئەوانەی لە هەموو خاکەکانی دیکە بوون، بیستیان کە پاشای بابل پاشماوەی بۆ یەهودا هێشتووەتەوە، گەدەلیاهوی کوڕی ئەحیقامی کوڕی شافانی کردووە بە فەرمانڕەوایان،
\v 12 هەموو جولەکەکان لە هەموو ئەو شوێنانەی پەرتەوازە بوون بۆی گەڕانەوە، هاتنەوە خاکی یەهودا، بۆ لای گەدەلیاهو لە میچپا. شەراب و هەنجیرێکی گەلێک زۆریان کۆکردەوە.
\p 
\v 13 ئینجا یۆحانانی کوڕی قارێیەح و هەموو سەرلەشکرەکان کە لە کێڵگەکان بوون هاتنە میچپا بۆ لای گەدەلیاهو،
\v 14 پێیان گوت: «ئایا تۆ نازانیت کە بەعلیسی پاشای عەمۆنییەکان، ئیسماعیلی کوڕی نەتەنیاهۆی ناردووە تۆ بکوژێت؟» بەڵام گەدەلیاهوی کوڕی ئەحیقام باوەڕی پێ نەکردن.
\p 
\v 15 ئینجا یۆحانانی کوڕی قارێیەح بەدزییەوە لە میچپا قسەی لەگەڵ گەدەلیاهو کرد و گوتی: «ڕێم بدە بچم ئیسماعیلی کوڕی نەتەنیاهۆ بکوژم، بێ ئەوەی هیچ کەس پێی بزانێت. بۆچی ئەو تۆ بکوژێت، هەموو ئەو جولەکانەی لە دەوری تۆ کۆبوونەتەوە پەرتەوازە بن و پاشماوەی یەهودا لەناوبچێت؟»
\p 
\v 16 بەڵام گەدەلیاهوی کوڕی ئەحیقام بە یۆحانانی کوڕی قارێیەحی گوت: «ئەم شتە مەکە، چونکە ئەوەی تۆ سەبارەت بە ئیسماعیل دەیڵێیت ڕاست نییە.»
\c 41
\p 
\v 1 لە مانگی حەوت ئیسماعیلی کوڕی نەتەنیاهۆی کوڕی ئەلیشاماع کە لە ڕەچەڵەکی شاهانە بوو، یەکێک بوو لە گەورە پیاوانی پاشا، لەگەڵ دە پیاو هاتنە میچپا بۆ لای گەدەلیاهوی کوڕی ئەحیقام. کاتێک پێکەوە نانیان دەخوارد،
\v 2 ئیسماعیلی کوڕی نەتەنیاهۆ لەگەڵ ئەو دە پیاوەی لەگەڵی بوون، هەستان و بە شمشێر لە گەدەلیاهوی کوڕی ئەحیقامی کوڕی شافانیان دا و کوشتیان، ئەوەی پاشای بابل کردبووی بە فەرمانڕەوای خاکەکە.
\v 3 هەروەها ئیسماعیل هەموو ئەو جولەکانەشی کوشت کە لە میچپا لەگەڵ گەدەلیاهو بوون، هەروەها ئەو سەربازە بابلییانەشی کوشت کە لەو ناوە بوون.
\p 
\v 4 لە ڕۆژی پاش کوشتنی گەدەلیاهو، بەر لەوەی کەس پێی بزانێت،
\v 5 هەندێک پیاو لە شەخەم و شیلۆ و سامیرەوە هاتن، هەشتا پیاوی ڕیش تاشراو و جل دادڕاو، لەشی خۆیان بریندار کردبوو، هاتن و پێشکەشکراوی دانەوێڵە و بخووری سادەیان بەدەستەوە بوو بۆ ئەوەی بیبەنە ناو ماڵی یەزدان.
\v 6 ئیسماعیلی کوڕی نەتەنیاهۆش لە میچپا هاتە دەرەوە تاکو پێشوازییان لێ بکات، دەڕۆیشت و دەگریا. کە پێیان گەیشت پێی گوتن: «وەرن بۆ لای گەدەلیاهوی کوڕی ئەحیقام.»
\v 7 کاتێک گەیشتنە ناوەڕاستی شارەکە، ئیسماعیلی کوڕی نەتەنیاهۆ لەگەڵ ئەو پیاوانەی کە لەگەڵی بوون، ئەوانیان کوشت و فڕێیان دانە ناو ئەمباراوێک.
\v 8 بەڵام دە پیاویان تێدابوو گوتیان: «مەمانکوژە، گەنم و جۆ و زەیت و هەنگوینمان هەیە و لە کێڵگەدا شاردراوەتەوە.» جا ئیسماعیل دەستی گێڕایەوە و لەگەڵ براکانیان نەیکوشتن.
\v 9 ئەو ئەمباراوەی ئیسماعیل لاشەی هەموو ئەو پیاوانەی فڕێدا ناوی کە بەهۆی گەدەلیاهوەوە کوشتبوونی، ئەو ئەمباراوە بوو کە ئاسا پاشا بۆ بەرگری لە دژی بەعشای پاشای ئیسرائیل دروستی کردبوو، جا ئیسماعیلی کوڕی نەتەنیاهۆ بە کوژراوان پڕی کردەوە.
\p 
\v 10 پاشان ئیسماعیل، هەموو پاشماوەی گەل کە لە میچپا بوون ڕاپێچی کردن، کچەکانی پاشا و هەموو ئەو خەڵکەی لەوێ مانەوە، ئەوانەی نەبوزەرەدانی فەرماندەی پاسەوانانی پاشا، گەدەلیاهوی کوڕی ئەحیقامی بە سەرپەرشتیار بەسەریانەوە دانابوو. ئیسماعیلی کوڕی نەتەنیاهۆ ڕاپێچی کردن و ڕۆیشت، هەتا بۆ لای عەمۆنییەکان بپەڕێتەوە.
\p 
\v 11 کاتێک یۆحانانی کوڕی قارێیەح و هەموو ئەو سەرلەشکرانەی لەگەڵی بوون، ئەو خراپانەیان بیستەوە کە ئیسماعیلی کوڕی نەتەنیاهۆ کردبووی،
\v 12 هەموو پیاوەکانیان برد و چوون بۆ شەڕکردن لەگەڵ ئیسماعیلی کوڕی نەتەنیاهۆ، لەلای گۆمەکەی گبعۆن تووشی بوون.
\v 13 ئەو ڕاپێچکراوانەی لەگەڵ ئیسماعیل بوون دڵشاد بوون کاتێک یۆحانانی کوڕی قارێیەحیان لەگەڵ هەموو سەرلەشکرەکان بینی کە لەگەڵی بوون،
\v 14 جا هەموو ئەو گەلەی ئیسماعیل لە میچپاوە ڕاپێچی کردبوون گەڕانەوە و چوون بۆ لای یۆحانانی کوڕی قارێیەح.
\v 15 بەڵام ئیسماعیلی کوڕی نەتەنیاهۆ، بە هەشت پیاوەوە لە یۆحانان دەرباز بوون و چوونە لای عەمۆنییەکان.
\s1 هەڵاتن بۆ میسر
\p 
\v 16 ئینجا یۆحانانی کوڕی قارێیەح و هەموو سەرلەشکرەکان کە لەگەڵی بوون، هەموو پاشماوەی گەلیان لە میچپا بردەوە، ئەوانەی لە ئیسماعیلی کوڕی نەتەنیاهۆ وەریانگرتنەوە، دوای ئەوەی ئیسماعیل گەدەلیاهوی کوڕی ئەحیقامی کوشتبوو، جەنگاوەرە بەتواناکان و ژن و منداڵ و کاربەدەستان بوون کە لەلای گبعۆن وەریانگرتبوونەوە.
\v 17 جا چوون و لە گێروت کیمهام، ئەوەی لەتەنیشت بێت‌لەحمە، نیشتەجێ بوون، بۆ ئەوەی بڕۆن و بچنە ناو میسرەوە،
\v 18 دوور لە بابلییەکان. لێیان دەترسان لەبەر ئەوەی ئیسماعیلی کوڕی نەتەنیاهۆ، گەدەلیاهوی کوڕی ئەحیقامی کوشتبوو، ئەوەی پاشای بابل کردبووی بە فەرمانڕەوای خاکەکە.
\c 42
\p 
\v 1 ئینجا هەموو سەرلەشکرەکان و یۆحانانی کوڕی قارێیەح و یەزەنیای کوڕی هۆشەعیا و هەموو گەل لە بچووکەوە هەتا گەورە هاتنە پێش و
\v 2 بە یەرمیای پێغەمبەریان گوت: «تکایە! گوێ لە پاڕانەوەمان بگرە و نوێژمان بۆ بکە بۆ یەزدانی پەروەردگارت لە پێناو هەموو ئەمانەی ماونەتەوە. هەروەک دەبینی، چونکە پێشتر زۆر بووین و ئێستا کەم ماوینەتەوە.
\v 3 بەڵکو یەزدانی پەروەردگارت پێمان بڵێت، بە کام ڕێگادا بڕۆین و چی بکەین.»
\p 
\v 4 یەرمیای پێغەمبەریش وەڵامی دانەوە: «گوێم لێتان بوو، من وەک قسەکەی خۆتان داوا لە یەزدانی پەروەردگارتان دەکەم، جا یەزدان هەرچی فەرموو پێتانی ڕادەگەیەنم، هیچتان لێ ناشارمەوە.»
\p 
\v 5 ئەوانیش بە یەرمیایان گوت: «با یەزدان لەنێوانمان شایەتێکی ڕاست و دڵسۆز بێت، ئەگەر ئێمە هەموو فەرمایشتەکەی یەزدانی پەروەردگارت کە بە تۆدا بۆمان دەنێرێت، ئاوا نەکەین.
\v 6 چاک بێت یان خراپ، ئێمە گوێ لە یەزدانی پەروەردگارمان دەگرین، ئەوەی ئێمە دەتنێرین بۆ لای، چونکە ئەگەر گوێ لە یەزدانی پەروەردگارمان بگرین، چاکەمان لەگەڵ دەکات.»
\p 
\v 7 ئەوە بوو دوای دە ڕۆژ، فەرمایشتی یەزدان بۆ یەرمیا هات.
\v 8 ئەویش یۆحانانی کوڕی قارێیەح و هەموو ئەو سەرلەشکرانەی کە لەگەڵی بوون و هەموو گەل لە بچووکەوە هەتا گەورەی بانگکرد،
\v 9 پێی گوتن: «یەزدانی پەروەردگاری ئیسرائیل ئەوەی ئێوە منتان بۆ لای نارد بۆ ئەوەی پاڕانەوەکەتان بخەمە بەردەمی، ئەمە دەفەرموێت:
\v 10 ”ئەگەر لەم خاکە نیشتەجێ بن، من بنیادتان دەنێم و ناتانڕووخێنم، دەتانچێنم و ڕیشەکێشتان ناکەم، چونکە پاشگەز بوومەوە لەو بەڵایەی بەسەرم هێنان.
\v 11 هەروەها یەزدان دەفەرموێت: لە پاشای بابل مەترسن، ئەوەی ئێستا لێی دەترسن. لێی مەترسن، چونکە من لەگەڵتانم بۆ ئەوەی ڕزگارتان بکەم و لە دەستی ئەو فریاتان بکەوم.
\v 12 جا بەزەییم پێتاندا دێتەوە، بۆ ئەوەی پاشای بابل بەزەیی پێتاندا بێتەوە و بۆ خاکەکەی خۆتان بتانگەڕێنێتەوە.“
\p 
\v 13 «بەڵام ئەگەر ئێوە بڵێن: ”لەم خاکە نیشتەجێ نابین“ و گوێڕایەڵی یەزدانی پەروەردگارتان نەبن،
\v 14 بەڵکو بڵێن: ”نا! ئێمە دەچینە خاکی میسر و لەوێ نیشتەجێ دەبین، لەوێ شەڕ نابینین و دەنگی کەڕەنا نابیستین و برسی نان نابین،“
\v 15 ئەی پاشماوەی یەهودا، ئێستا گوێ لە فەرمایشتی یەزدان بگرن. یەزدانی سوپاسالار، خودای ئیسرائیل ئەمە دەفەرموێت: ”ئەگەر مکوڕ بن لەسەر ئەوەی بچنە میسر و چوون و لەوێ نیشتەجێ بوون،
\v 16 ئەوا ئەو شمشێرەی ئێوە لێی دەترسن لەوێ پێتان دەگات، ئەو قاتوقڕییەی ئێوە لێی دەترسن بۆ میسر دواتان دەکەوێت، لەوێ دەمرن.
\v 17 جا هەموو ئەو پیاوانەی سوورن لەسەر چوونیان بۆ میسر بۆ ئەوەی لەوێ نیشتەجێ بن، لەوێ بە شمشێر و قاتوقڕی و دەرد لەناودەچن، کەسیان نامێنێتەوە و دەرباز نابن لەو بەڵایەی من بەسەریان دەهێنم.“
\v 18 یەزدانی سوپاسالار، خودای ئیسرائیل ئەمە دەفەرموێت: ”وەک چۆن تووڕەیی و هەڵچوونم بەسەر دانیشتووانی ئۆرشەلیمدا ڕژا، ئاواش هەڵچوونم بەسەرتاندا دەڕژێت کاتێک بچن بۆ میسر، جا دەبنە مایەی نەفرەت لێکردن و تۆقین، سووکایەتی و ڕیسوایی، هەرگیز ئەم شوێنە نابیننەوە.“
\p 
\v 19 «ئەی پاشماوەی یەهودا، یەزدان سەبارەت بە ئێوە فەرمووی: ”مەچنە ناو میسرەوە.“ باش بزانن کە من ئەمڕۆ ئاگادارم کردنەوە،
\v 20 چونکە ئێوە هەڵەیەکی ترسناکتان کرد کاتێک منتان بۆ لای یەزدانی پەروەردگارتان نارد و گوتتان: ”نوێژمان بۆ بکە بۆ یەزدانی پەروەردگارمان؛ هەرچی بفەرموێت، ئەوەمان پێ ڕابگەیەنەوە و دەیکەین.“
\v 21 ئەوا من ئەمڕۆ بە ئێوەم ڕاگەیاند، بەڵام ئێوە گوێڕایەڵی یەزدانی پەروەردگارتان نەبوون لە هەموو ئەوەی منی پێ ڕاسپارد پێتان بڵێم.
\v 22 جا ئێستا باش بزانن کە لەو شوێنەی دەتانەوێ بۆی بچن و لێی نیشتەجێ بن لەوێ بە شمشێر و قاتوقڕی و دەرد لەناودەچن.»
\c 43
\p 
\v 1 یەرمیا هەموو فەرمایشتەکانی یەزدانی پەروەردگاریانی بە هەموو گەل ڕاگەیاند کە یەزدان پێی ڕایسپاردبوو. کاتێک تەواو بوو،
\v 2 عەزەریای کوڕی هۆشەعیا و یۆحانانی کوڕی قارێیەح و هەموو پیاوە لووتبەرزەکان قسەیان لەگەڵ یەرمیا کرد و گوتیان: «تۆ درۆ دەکەیت! یەزدانی پەروەردگارمان تۆی نەناردووە هەتا بڵێت: ”مەچنە میسر بۆ ئەوەی لەوێ نیشتەجێ بن.“
\v 3 بەڵکو باروخی کوڕی نێرییا تۆی لە ئێمە هانداوە تاوەکو بماندەیتە دەست بابلییەکان، بۆ ئەوەی بمانکوژن یان بۆ بابل ڕاپێچمان بکەن.»
\p 
\v 4 ئیتر یۆحانانی کوڕی قارێیەح و هەموو سەرلەشکرەکان و هەموو گەل کەسیان گوێڕایەڵی یەزدان نەبوون هەتا لە خاکی یەهودا ئۆقرە بگرن.
\v 5 بەڵکو یۆحانانی کوڕی قارێیەح و هەموو سەرلەشکرەکان، هەموو پاشماوەی یەهودایان برد، ئەوانەی لەناو ئەو نەتەوانەوە گەڕابوونەوە کە پەرتەوازە ببوون بۆ لایان، بۆ ئەوەی لە خاکی یەهودا بژین.
\v 6 پیاو و ژن و منداڵ و کچەکانی پاشا و هەموو ئەوانەیان برد کە نەبوزەرەدانی فەرماندەی پاسەوانانی پاشا لەلای گەدەلیاهوی کوڕی ئەحیقام کوڕی شافان بەجێی هێشتبوون. هەروەها یەرمیای پێغەمبەر و باروخی کوڕی نێرییاش لەگەڵیان بوون.
\v 7 جا چوونە ناو خاکی میسر، گوێڕایەڵی یەزدان نەبوون و هەتا تەحپەنحێس چوون.
\p 
\v 8 ئینجا لە تەحپەنحێس فەرمایشتی یەزدان بۆ یەرمیا هات، پێی فەرموو:
\v 9 «لەگەڵ دەستت هەندێک بەردی گەورە ببە و لەبەرچاوی پیاوانی یەهودا، بیانخە ژێر قوڕەوە، لەو بەردڕێژەی لە بەردەرگای کۆشکی فیرعەونە لە تەحپەنحێس.
\v 10 پێیان بڵێ: ”یەزدانی سوپاسالار، خودای ئیسرائیل ئەمە دەفەرموێت: من دەنێرم و نەبوخودنەسری پاشای بابل، خزمەتکارەکەم، دەهێنم و تەختەکەی لەسەر ئەم بەردانە دادەنێم کە چەقاندم، ئەویش چەتری تەختەکەی بەسەردا هەڵدەدات.
\v 11 جا دێت و لە خاکی میسر دەدات، ئەوەی بۆ مردنە بۆ مردن، ئەوەی بۆ دیلیێتیە بۆ دیلیێتی، ئەوەی بۆ شمشێرە بۆ شمشێر.
\v 12 ئینجا ئاگر بەردەداتە پەرستگاکانی خوداوەندەکانی میسر، پەرستگاکان دەسووتێنێت و خوداوەندەکانیان ڕاپێچ دەکات. خاکی میسر لە خۆی دەپێچێتەوە، وەک چۆن شوان کەواکەی لە خۆی دەپێچێتەوە، ئینجا لەوێوە بە سەلامەتی دەردەچێت.
\v 13 کۆڵەکەکانی پەرستگای خۆر لە خاکی میسر دەشکێنێت، پەرستگاکانی خوداوەندەکانی میسر بە ئاگر دەسووتێنێت.“»
\c 44
\s1 لێقەومان بەهۆی بتپەرستی
\p 
\v 1 ئەو پەیامەی بۆ یەرمیا هات سەبارەت بە هەموو ئەو جولەکانەی لە خاکی میسر نیشتەجێ بوون، لە مگدۆل و لە تەحپەنحێس و لە مەمفیس و لە پاشایەتی باشووری میسر:
\v 2 «یەزدانی سوپاسالار، خودای ئیسرائیل ئەمە دەفەرموێت: ئێوە هەموو ئەو بەڵایەتان بینی کە بەسەر ئۆرشەلیم و هەموو شارۆچکەکانی یەهودام هێنا. ئەمڕۆ وێرانە و ئاوەدانی تێدا نییە،
\v 3 لەبەر ئەو خراپانەی کردیان. پەستیان کردم بە بخوور سووتاندن و پەرستنیان بۆ خوداکانی دیکە، ئەو خودایانەی نە ئەوان ناسیویانن و نە ئێوە و نە باوباپیرانتان.
\v 4 منیش بە بەردەوامی هەموو بەندە پێغەمبەرەکانی خۆمم بۆ ناردن، فەرمووم: ”تکایە! ئەم کارە قێزەونە مەکەن کە من ڕقم لێیەتی.“
\v 5 بەڵام نە گوێیان گرت و نە گوێیان شل کرد بۆ ئەوەی لە خراپەکەیان بگەڕێنەوە یان لە بخوور سووتاندن بۆ خوداکانی دیکە بوەستن.
\v 6 جا هەڵچوون و تووڕەییم ڕژا، لە شارۆچکەکانی یەهودا و لە شەقامەکانی ئۆرشەلیمدا گڕی گرت، وەک ئەمڕۆ وێران بوو و بووە چۆڵەوانی.
\p 
\v 7 «ئێستاش یەزدانی پەروەردگاری سوپاسالار، خودای ئیسرائیل ئەمە دەفەرموێت: بۆچی ئێوە بەڵایەکی گەورە بەسەر خۆتان دەهێنن، بە قڕبوونتان لە ناوەڕاستی یەهودا بە پیاو و ژن، بە منداڵ و شیرەخۆرەوە، ئیتر هیچ پاشماوەیەکتان لێ نامێنێتەوە؟
\v 8 بۆچی بە کردەوەکانی دەستتان پەستم دەکەن کاتێک لە خاکی میسر بخوور بۆ خوداکانی دیکە دەسووتێنن، کە ئێوە بۆی هاتوون تاوەکو لەوێ ئاوارە بن؟ خۆتان قڕ دەکەن و دەبنە نەفرەت و ڕیسوایی لەنێو هەموو نەتەوەکانی سەر زەوی.
\v 9 ئایا خراپەکانی باوباپیرانتان و خراپەکانی پاشاکان و شاژنەکانی یەهودا و خراپەکانی خۆتان و ژنەکانتان لەیادچوو، ئەوەی لە خاکی یەهودا و شەقامەکانی ئۆرشەلیم کران؟
\v 10 هەتا ئەمڕۆش نە زەلیل بوون و نە لە من ترسان و نە ڕێگای فێرکردن و فەرزەکانی منتان گرتەبەر، ئەوەی لەبەردەم ئێوە و لەبەردەم باوباپیرانتان دامناوە.
\p 
\v 11 «لەبەر ئەوە یەزدانی سوپاسالار، خودای ئیسرائیل ئەمە دەفەرموێت: ئەوەتا من مکوڕ دەبم لەسەر ئەوەی بەڵاتان بەسەربهێنم و هەموو یەهودا قڕ بکەم.
\v 12 پاشماوەی یەهوداش دەبەم، ئەوانەی سوور بوون بچنە خاکی میسر هەتا لەوێ نیشتەجێ بن. هەموویان لە خاکی میسر لەناودەچن، بە شمشێر دەکوژرێن و بە قاتوقڕی دەمرن. لە بچووکەوە هەتا گەورە بە شمشێر و قاتوقڕی لەناودەچن و دەبنە مایەی نەفرەت لێکردن و تۆقین، سووکایەتی و ڕیسوایی.
\v 13 هەروەها سزای ئەوانەش دەدەم کە لە خاکی میسر نیشتەجێن، وەک چۆن بە شمشێر و قاتوقڕی و دەرد سزای ئۆرشەلیمم دا.
\v 14 پاشماوەکەی یەهودا، ئەوانەی هاتوون بۆ ئەوەی لە خاکی میسر لە ئاوارەیی بکەون، ئەوانەی تامەزرۆی گەڕانەوەن بۆ نیشتەجێبوون تێیدا، نە پاشماوە و نە دەربازبوویان نابێت بۆ ئەوەی بگەڕێنەوە بۆ خاکی یەهودا. کەسیان لێ ناگەڕێتەوە، جگە لە کەمینەیەکی دەربازبوو.»
\p 
\v 15 ئینجا هەموو ئەو پیاوانەی کە دەیانزانی ژنەکانیان بخوور بۆ خوداکانی دیکە دەسووتێنن، هەروەها هەموو ئەو ژنانەی ڕاوەستابوون، کۆمەڵێکی گەورە بوون، هەموو ئەو خەڵکەی لە پاشایەتی باکوور و پاشایەتی باشووری میسر نیشتەجێن، وەڵامی یەرمیایان دایەوە و گوتیان:
\v 16 «ئێمە گوێ لەم پەیامە ناگرین کە بە ناوی یەزدانەوە بە ئێمەت گوت.
\v 17 بەڵکو هەر شتێک لە دەمی خۆمانەوە هاتووەتە دەرەوە، ئەوە دەکەین: بخوور بۆ شاژنی ئاسمان دەسووتێنین و شەرابی پێشکەشکراو پێشکەش دەکەین، وەک چۆن خۆمان و باوباپیرانمان و پاشاکانمان و پیاوە گەورەکانمان لە شارۆچکەکانی یەهودا و شەقامەکانی ئۆرشەلیم ئەنجاممان داوە. ئەو کاتە تێر نان بووین و لە خۆشیدا بووین و خراپەمان نەبینی.
\v 18 بەڵام لەو کاتەوەی وازمان لە بخوور سووتاندن هێناوە بۆ شاژنی ئاسمان و پێشکەشکردنی شەرابی پێشکەشکراو بۆی، پێویستمان بە هەموو شتێکە و بە شمشێر و قاتوقڕی لەناوچووین.»
\p 
\v 19 ژنەکانیش گوتیان: «ئێمە کاتێک کە بخوورمان بۆ شاژنی ئاسمان دەسووتاند و شەرابی پێشکەشکراومان پێشکەشی دەکرد، ئایا بەبێ ئاگاداری پیاوەکانمان کولێرەمان بۆ دەکرد لەسەر وێنەی ئەو و شەرابی پێشکەشکراومان پێشکەش دەکرد؟»
\p 
\v 20 ئینجا یەرمیا بە هەموو خەڵکەکەی گوت، پیاو و ژنەکان، بە هەموو ئەو خەڵکەی بەم قسەیە وەڵامیان دایەوە:
\v 21 «ئایا یەزدان بیری لەو بخوورە نەکردەوە و بەیادیدا نەهات کە لە شارۆچکەکانی یەهودا و لە شەقامەکانی ئۆرشەلیم سووتاندتان، ئێوە و باوباپیر و پاشا و میر و هەموو گەلی خاکەکە؟
\v 22 ئیتر یەزدان لەبەر کردەوە خراپەکان و شتە قێزەونەکانتان کە ئەنجامتان داوە زیاتر بەرگەی نەگرت، جا خاکەکەتان بووە ڕووخاوی و وێرانە و نەفرەت و بێ ئاوەدانی، وەک ئەمڕۆ.
\v 23 لەبەر ئەوەی بخوورتان سووتاند و گوناهتان کرد لە دژی یەزدان، گوێڕایەڵی یەزدان نەبوون و ڕێگای فێرکردن و فەرز و یاساکانی ئەوتان نەگرتەبەر، لەبەر ئەوە تووشی ئەم بەڵایە بوون، وەک ئەمڕۆ.»
\p 
\v 24 ئینجا یەرمیا بە هەموو گەل و بە تایبەتیش بە هەموو ژنەکانی گوت: «ئەی هەموو خەڵکی یەهودا، ئەوانەی کە لە خاکی میسرن، گوێ لە فەرمایشتی یەزدان بگرن:
\v 25 یەزدانی سوپاسالار، خودای ئیسرائیل ئەمە دەفەرموێت: ئێوە و ژنەکانتان بە قسە بەڵێنتان دا و بە ئەنجامتان گەیاند، گوتتان ”بێگومان ئێمە ئەو نەزرانەمان\f + \fr 44:25 \ft نەزر: داوا لە خودا دەکرێت بۆ ئەنجامدانی کارێک و پابەند دەکرێت بە مەرجێکەوە. ئەگەر خودا ئەو کارە بکات، ئەوا دەرئەنجام ئەمیش ئەو کارە ئەنجام دەدات کە پێیەوە پابەندی کردووە. بڕوانە \xt سەرژمێری 21‏:2‏\xt*\ft ‏.‏\f* جێبەجێ دەکەین کە نەزرمان کردبوو بۆ شاژنی ئاسمان، بخوور دەسووتێنین و شەرابی پێشکەشکراوی پێشکەش دەکەین.“
\p «کەواتە فەرموون، بەڵێنەکانتان بهێننە دی و نەزرەکانتان بپارێزن!
\v 26 بەڵام ئەی هەموو ئەو خەڵکەی یەهودا کە لە میسر نیشتەجێن، گوێ لە فەرمایشتی یەزدان بگرن: ”من بە ناوی مەزنی خۆم سوێند دەخۆم، لەمەودوا کەس لە خەڵکی یەهودا لە هەموو خاکی میسر ناوی من بەسەر زاریدا نایەت، کە بڵێت: ’بە یەزدانی زیندووی باڵادەست.‘
\v 27 ئەوەتا من بۆ خراپە نەک بۆ چاکە چاودێرییان دەکەم، جا هەموو پیاوانی یەهودا، ئەوانەی لە خاکی میسرن، بە شمشێر دەکوژرێن و بە قاتوقڕی دەمرن، هەتا ئەوەی کەسیان لێ نامێنێتەوە.
\v 28 ئەوانەش کە لە شمشێر دەرباز دەبن لە خاکی میسرەوە دەگەڕێنەوە بۆ خاکی یەهودا، خەڵکانێکی کەم دەبن. ئینجا هەموو پاشماوەی یەهودا ئەوانەی هاتنە میسر تاکو لەوێ بژین، دەزانن قسەی کێ سەردەگرێت، هی من یان هی ئەوان.“»
\p 
\v 29 یەزدان دەفەرموێت: «”ئەمەش نیشانەیە بۆ ئێوە، من لەم شوێنە سزاتان دەدەم، بۆ ئەوەی بزانن هەر دەبێت قسەی من سەربگرێت کە لە دژی ئێوەیە و بۆ خراپەیە.“
\v 30 یەزدان ئەمە دەفەرموێت: ”ئەوەتا من حۆفرەعی فیرعەونی میسر دەدەمە دەست دوژمنەکانی کە دەیانەوێ بیکوژن، وەک چۆن سدقیای پاشای یەهودام دایە دەست نەبوخودنەسری پاشای بابل، ئەو دوژمنەی دەیویست بیکوژێت.“»
\c 45
\s1 پەیامێک بۆ باروخ
\p 
\v 1 ئەو پەیامەی یەرمیای پێغەمبەر بە باروخی کوڕی نێرییای گوت، لە ساڵی چوارەمی یەهۆیاقیمی کوڕی یۆشیای پاشای یەهودا، کاتێک ئەم وشانەی لە دەمی یەرمیاوە لە تۆمارێکدا دەنووسییەوە:
\v 2 «ئەی باروخ! یەزدانی پەروەردگاری ئیسرائیل سەبارەت بە تۆ ئەمە دەفەرموێت:
\v 3 تۆ گوتت: ”قوڕبەسەرم! چونکە یەزدان سەرەڕای ئازارم خەمیشی بۆ زیاد کردووم، لەناو ناڵاندنم لە هۆش خۆم چووم و حەوانەوەم نەبوو.“»
\p 
\v 4 یەزدان ئەمە دەفەرموێت: «ئەوەی پێ بڵێ: ”ئەوەتا من لە هەموو ئەم خاکەدا ئەوەی بنیادم ناوە دەیڕووخێنم و ئەوەی چاندوومە ڕیشەکێشی دەکەم.
\v 5 ئایا ئیتر تۆ داوای شتی گەورە بۆ خۆت دەکەیت؟ داوا مەکە، چونکە ئەوەتا من خراپە بەسەر هەموو خەڵکێکدا دەهێنم، بەڵام بۆ تۆ، ژیانت دەرباز دەبێت لە هەموو ئەو شوێنانەی بۆی دەچیت.“» ئەوە فەرمایشتی یەزدانە.
\c 46
\s1 پەیامێک سەبارەت بە میسر
\p 
\v 1 ئەمە فەرمایشتی یەزدانە بۆ یەرمیای پێغەمبەر سەبارەت بە نەتەوەکان:
\b
\p 
\v 2 بۆ میسر:
\b
\p سەبارەت بە سوپاکەی نێخۆ فیرعەون، پاشای میسر، ئەوەی لەسەر ڕووباری فورات بوو لە کەرکەمیش، کە نەبوخودنەسری پاشای بابل لە ساڵی چوارەمی یەهۆیاقیمی کوڕی یۆشیای پاشای یەهودا لێیدا:
\q1 
\v 3 «سپەر و قەڵغان ئامادە بکەن،
\q2 پێشکەون بۆ جەنگ!
\q1 
\v 4 ئەسپ زین بکەن،
\q2 ئەی سوارەکان، سەربکەون!
\q1 بە کڵاوی ئاسنینەوە لە ئامادەباشیدا بن!
\q2 ڕمەکان تیژ بکەن،
\q2 زرێیەکان\f + \fr 46:4 \ft زرێ: بەڕگێکی کانزاییە کە لە کاتی شەڕ دەپۆشرێت.‏\f* بپۆشن!
\q1 
\v 5 چی دەبینم؟
\q2 ئەوان تۆقیون،
\q1 بەرەو پاش دەکشێنەوە،
\q2 پاڵەوانەکانیان بەزین.
\q1 بە پەلە هەڵاتن و
\q2 ئاوڕیشیان نەدایەوە،
\q2 لە هەموو لایەکەوە ترس و تۆقین هەیە.»
\q4 ئەوە فەرمایشتی یەزدانە.
\q1 
\v 6 «ئەوەی تیژڕەوە هەڵنایەت و
\q2 پاڵەوان دەرباز نابێت.
\q1 لە باکوور لەلای ڕووباری فورات
\q2 ساتمەیان کرد و کەوتن.
\b
\q1 
\v 7 «ئەمە کێیە وەک ڕووباری نیل هەڵدەستێتەوە،
\q2 وەک ئەو ڕووبارانەی ئاوەکەیان شەپۆل دەدات؟
\q1 
\v 8 میسرە وەک ڕووباری نیل هەڵدەستێتەوە،
\q2 وەک ئەو ڕووبارانەی ئاوەکەیان شەپۆل دەدات.
\q1 دەڵێت: ”هەڵدەستم و زەوی دادەپۆشم،
\q2 شار و دانیشتووانەکەی لەناو دەبم.“
\q1 
\v 9 ئەی ئەسپەکان، سەربکەون!
\q2 ئەی گالیسکەکان، سەرەڕۆ بن!
\q1 با پاڵەوانان بەرەو پێش بچن،
\q2 کوش و پووت قەڵغان بەدەستن،
\q2 لوودییەکان تیرەکانیان لە کەوانەکانیان ڕادەکێشن.
\q1 
\v 10 بەڵام ئەمڕۆ ڕۆژی یەزدانە\f + \fr 46:10 \ft ڕۆژی سزادانی گوناهباران و ڕزگارکردنی گەلی خودا.‏\f*، پەروەردگاری سوپاسالار،
\q2 ڕۆژی تۆڵەیە، تۆڵەسەندنەوە لە دوژمنانی.
\q1 جا شمشێر دەخوات و تێر دەبێت،
\q2 لە خوێنیان تێر دەخواتەوە،
\q1 چونکە یەزدان، پەروەردگاری سوپاسالار، قوربانی سەربڕاو پێشکەش دەکات
\q2 لە خاکی باکوور لەلای ڕووباری فورات.
\b
\q1 
\v 11 «سەربکەوە بۆ گلعاد و هەتووان بهێنە،
\q2 ئەی میسری کچە پاکیزە.
\q1 بەڵام بێهوودە داوودەرمان زۆر دەکەیت،
\q2 چاکبوونەوەت نییە.
\q1 
\v 12 نەتەوەکان سووکایەتی تۆیان بیستووە،
\q2 قیژەت دنیای پڕکردووە،
\q1 چونکە پاڵەوانێک ساتمە لە پاڵەوانێک دەکات،
\q2 هەردووکیان پێکەوە دەکەون.»
\p 
\v 13 ئەمە ئەو پەیامەیە کە یەزدان بە یەرمیای پێغەمبەری ڕاگەیاند، لەبارەی هێرشکردنی نەبوخودنەسری پاشای بابل بۆ سەر خاکی میسر:
\q1 
\v 14 «ئەمە لە میسر ڕابگەیەنن، لە شاری مگدۆل جاڕبدەن،
\q2 هەروەها لە مەمفیس و تەحپەنحێس، بڵێن:
\q1 ”وریابە و لە ئامادەباشیدا بە،
\q2 چونکە شمشێر دەوروبەرت دەخوات.“
\q1 
\v 15 بۆچی توانادارەکانت بە زەویدا دران؟
\q2 نەوەستان، چونکە یەزدان ئەوانی خست.
\q1 
\v 16 بەردەوام ساتمە دەکەن،
\q2 بەسەر یەکتریدا دەکەون.
\q1 دەڵێن: ”هەستن با بگەڕێینەوە،
\q2 بۆ ناو گەلەکەمان و خاکی لەدایکبوونمان،
\q2 دوور لە شمشێری ستەمکاری.“
\q1 
\v 17 لەوێ هاواریان دەکرد:
\q2 ”فیرعەونی پاشای میسر تەنها هاتوهەرای هەیە،
\q2 دەرفەتی ئەو بەسەرچوو!“»
\b
\q1 
\v 18 پاشا کە ناوی یەزدانی سوپاسالارە
\q2 دەفەرموێت: «بە گیانی خۆم،
\q1 کەسێک دێت وەک تاڤۆرە لەنێو چیاکان،
\q2 وەک کارمەلە لەلای دەریاوە دێت.
\q1 
\v 19 ئەی دانیشتووانی میسر،
\q2 کەلوپەلەکانتان بۆ ڕاپێچ کۆبکەنەوە،
\q1 چونکە مەمفیس وێران دەبێت،
\q2 دەبێتە چۆڵەوانییەکی بێ ئاوەدانی.
\b
\q1 
\v 20 «میسر مانگایەکی زێدە جوانە،
\q2 بەڵام مێشومەگەز لە باکوورە بۆی دێت.
\q1 
\v 21 هەروەها سەربازە بەکرێگیراوەکانت لە ڕیزەکانی جەنگ،
\q2 وەک جوانەگای قەڵەون،
\q1 چونکە ئەوانیش ڕوو وەردەگێڕن،
\q2 تێکڕا هەڵدێن و ناوەستن،
\q1 چونکە ڕۆژی کارەسات گەیشتە سەریان،
\q2 کاتی سزادانیان.
\q1 
\v 22 میسر وەک ماری هەڵاتوو فیشک دەدات،
\q2 چونکە دوژمنەکانی بە سوپاوە دێنە پێش،
\q1 هەروەک داربڕەکان
\q2 بە تەورەوە بۆی هاتن.
\q1 
\v 23 دارستانەکەی دەبڕنەوە،
\q2 هەرچەندە زۆر چڕە،
\q1 چونکە لە کوللە زۆرترن،
\q2 لە ژمارە نایەن.»
\q4 ئەوە فەرمایشتی یەزدانە.
\q1 
\v 24 «دانیشتووانی میسر شەرمەزار دەبن،
\q2 درانە دەست گەلی باکوور.»
\p 
\v 25 یەزدانی سوپاسالار، خودای ئیسرائیل فەرمووی: «من خەریکم سزا دەسەپێنم، لەسەر ئامۆنی خودای شاری تیب و فیرعەون، لەسەر میسر و خوداوەندەکان و پاشاکانی، هەروەها لەسەر ئەوانەش کە پشتیان بە فیرعەون بەستووە.
\v 26 دەیاندەمە دەست ئەوانەی دەیانەوێت بیانکوژن، دەست نەبوخودنەسری پاشای بابل و دەست خزمەتکارەکانی. پاش ئەمە میسر وەک ڕۆژانی پێشتری ئاوەدان دەبێتەوە.» ئەمە فەرمایشتی یەزدانە.
\q1 
\v 27 «ئەی یاقوبی بەندەم، مەترسە،
\q2 ئەی ئیسرائیل، مەتۆقە.
\q1 بە دڵنیاییەوە من لەم شوێنە دوورە ڕزگارت دەکەم،
\q2 نەوەکەشت لەو خاکەوەی بۆی ڕاپێچ کراوە.
\q1 یاقوب دەگەڕێتەوە و ئاسوودە دەبێت،
\q2 دڵنیا دەبێت و کەس نایتۆقێنێت.
\q1 
\v 28 ئەی یاقوبی بەندەم، مەترسە،
\q2 چونکە من لەگەڵتدام.
\q1 هەرچەندە کۆتایی دەهێنم بە هەموو ئەو نەتەوانەی
\q2 کە بۆ ناویان پەرتەوازەم کردیت،
\q2 بەڵام تۆ بە تەواوی لەناو نابەم.
\q1 لە سزا ناتبوورم،
\q2 بە دادپەروەری تەمبێت دەکەم.» ئەمە فەرمایشتی یەزدانە.
\c 47
\s1 پەیامێک سەبارەت بە فەلەستییەکان
\p 
\v 1 ئەمە فەرمایشتی یەزدانە بۆ یەرمیای پێغەمبەر سەبارەت بە فەلەستییەکان، بەر لەوەی فیرعەون پەلاماری غەزە بدات:
\b
\p 
\v 2 یەزدان ئەمە دەفەرموێت:
\q1 «ئەوەتا ئاو لە باکوورەوە هەڵدەستێت و
\q2 دەبێتە لافاوێکی ڕاماڵ،
\q1 زەوی و هەرچی لەسەریەتی ڕایدەماڵێت،
\q2 شار و دانیشتووانەکەی.
\q1 خەڵکی هاوار دەکەن،
\q2 هەموو دانیشتووانی خاکەکە واوەیلا دەکەن
\q1 
\v 3 لە دەنگی تەقەی سمی ئەسپە بە تواناکانی،
\q2 لە خڕەی گالیسکەکانی و
\q2 جیڕەی چەرخەکانی.
\q1 باوک ئاوڕ لە کوڕ ناداتەوە
\q2 لەبەر شلبوونی دەستەکانی.
\q1 
\v 4 لەبەر ئەوەی ئەو ڕۆژە هاتووە
\q2 بۆ تەفروتوناکردنی فەلەستییەکان و
\q1 بۆ بڕینەوەی هەموو پاشماوەیەک
\q2 کە بتوانن پشتگیری پاشایەتی سور و سەیدا بکەن.
\q1 یەزدان خەریکە فەلەستییەکان تەفروتونا دەکات،
\q2 پاشماوەی کەناری کەفتۆر.
\q1 
\v 5 خەڵکی غەزە لەبەر ماتەم سەریان دەتاشن،
\q2 ئەسقەلان کپ دەبێت.
\q1 ئەی پاشماوەی خەڵکی دۆڵەکان،
\q2 هەتا کەی لەشی خۆتان بریندار دەکەن؟
\b
\q1 
\v 6 «”ئای ئەی شمشێری یەزدان،
\q2 هەتا کەی پشوو نادەیت؟
\q1 بڕۆ ناو کێلانەکەتەوە\f + \fr 47:6 \ft کالانەکەتەوە.‏\f* و
\q2 هێدی بە و کپ بە.“
\q1 
\v 7 بەڵام چۆن پشوو دەدات
\q2 کە یەزدان فەرمانی پێکردبێت،
\q1 لە دژی ئەسقەلان و لە دژی کەناری دەریا،
\q2 لەوێ ئەرکی پێ سپارد؟»
\c 48
\s1 پەیامێک سەبارەت بە مۆئاب
\p 
\v 1 بۆ مۆئاب:
\b
\p یەزدانی سوپاسالار، خودای ئیسرائیل ئەمە دەفەرموێت:
\q1 «قوڕبەسەر نیبۆ، چونکە وێران دەبێت،
\q2 قیریاتەیم شەرمەزار دەبێت و دەگیرێت،
\q2 قەڵاکە شەرمەزار دەبێت و دەڕووخێت.
\q1 
\v 2 شانازی مۆئاب نامێنێت،
\q2 لە حەشبۆن پیلانی خراپەیان لە دژی گێڕا،
\q2 ”وەرن، با کۆتایی بەو نەتەوەیە بهێنین.“
\q1 هەروەها تۆش ئەی مەدمێن\f + \fr 48:2 \ft ناوی شارۆچکەیەک بوو لە خاکی مۆئاب. لە زمانی عیبری وشەی \tl مەدمێن‏\tl* لە ڕووی دەنگەوە لەگەڵ وشەی (کپ بە)ی عیبری نزیکە.‏\f* کپ دەبیت،
\q2 شمشێر دوات دەکەوێت.
\q1 
\v 3 گوێ لە دەنگی هاوار بگرن لە حۆرۆنایمەوە دێت،
\q2 هاواری لەناوچوون و وێرانبوونێکی گەورە.
\q1 
\v 4 مۆئاب تێکدەشکێت،
\q2 بچووکەکانی هاواریان لێ بەرز دەبێتەوە.
\q1 
\v 5 سەردەکەون بۆ هەورازەکەی ڕێگای لوحیت،
\q2 بەدەم ڕێگاوە بەکوڵ دەگریێن،
\q1 لە ڕێگا نشێوەکەی بەرەو حۆرۆنایم
\q2 هاواری شکست دەبیسترێت.
\q1 
\v 6 هەڵێن و خۆتان دەرباز بکەن!
\q2 ببن بە سەرو لە چۆڵەوانی.
\q1 
\v 7 لەبەر پشتبەستنت بە کردار و گەنجینەکانت،
\q2 تۆش دەگیرێیت،
\q1 کەمۆش\f + \fr 48:7 \ft خوداوەندی هەرە گەورەی مۆئابییەکان بوو. بڕوانە \xt سەرژمێری 21‏:29‏\xt*\ft ‏.‏\f* ڕاپێچ دەکرێت،
\q2 کاهین و پیاوە گەورەکانی پێکەوە.
\q1 
\v 8 وێرانکەر بۆ هەموو شارۆچکەکان دێت،
\q2 هیچ شارۆچکەیەک دەرباز نابێت.
\q1 دۆڵ لەناودەچێت،
\q2 دەشت وێران دەبێت،
\q2 وەک ئەوەی یەزدان فەرمووی.
\q1 
\v 9 خوێ بەسەر خاکی مۆئابدا بکەن،
\q2 چونکە دەبێتە چۆڵەوانی.\f + \fr 48:9 \ft یان: باڵ بدەن بە مۆئاب، بۆ ئەوەی هەڵفڕێت.‏\f*
\q1 شارۆچکەکانی وێران دەبن،
\q2 بەبێ ئاوەدانی دەبن.
\b
\q1 
\v 10 «نەفرەت لێکراوە ئەوەی بە تەوەزەلی کاری یەزدان دەکات!
\q2 نەفرەت لێکراوە ئەوەی شمشێرەکەی لە خوێنڕشتن ڕادەگرێت!
\b
\q1 
\v 11 «مۆئاب لە هەڕەتی گەنجییەوە دڵنیایە،
\q2 ڕاپێچیش نەکراوە،
\q1 وەک مەی بەسەر خڵتەکەیەوە مەنگە،
\q2 لە دەفرێکەوە بۆ دەفرێکی دیکە نەشڵەقاوە،
\q1 لەبەر ئەوە تامەکەی هەر ماوە و
\q2 بۆنیشی نەگۆڕاوە.
\q1 
\v 12 یەزدان دەفەرموێت:
\q2 لەبەر ئەوە ڕۆژێک دێت،
\q1 بۆ تێکدانی ئەو کەسانەی بۆ دەنێرم کە لە ئەمباری مەی ئیش دەکەن،
\q2 ئەوان دەیڕێژن و
\q1 دەفرەکانی بەتاڵ دەکەن و
\q2 گۆزەکانی وردوخاش دەکەن.
\q1 
\v 13 جا مۆئاب شەرمەزاری کەمۆش دەبێت،
\q2 هەروەک بنەماڵەی ئیسرائیل شەرمەزاری بێت‌ئێل بوون
\q2 کە پشتیان پێی بەستبوو.
\b
\q1 
\v 14 «چۆن دەڵێن: ”ئێمە پاڵەوانین و
\q2 پیاوی بەهێزین بۆ جەنگ“؟
\q1 
\v 15 مۆئاب تەفروتونا دەبێت، شارۆچکەکانی داگیر دەکرێت،
\q2 باشترین لاوەکانی بۆ سەربڕین دادەبەزن.»
\q2 ئەمە فەرمایشتی پاشایە، ئەوەی ناوی یەزدانی سوپاسالارە.
\q1 
\v 16 «لەناوچوونی مۆئاب نزیک بووەتەوە،
\q2 بەڵاکەی زۆر بە خێرایی دێت.
\q1 
\v 17 ئەی هەموو ئەوانەی لە دەوروبەری ئەون، بۆی بلاوێننەوە،
\q2 ئەی هەموو ئەوانەی ناوبانگی دەزانن،
\q1 بڵێن: ”چۆن داردەستی بەهێز شکا،
\q2 شکۆ و دەسەڵاتی نەما!“
\b
\q1 
\v 18 «لە شکۆمەندی خۆت وەرە خوارەوە و
\q2 لەسەر زەوی وشک دابنیشە،
\q2 ئەی دانیشتووانی شاری دیڤۆن،
\q1 چونکە تەفروتوناکەرەکەی مۆئاب
\q2 دێتە سەر ئێوە،
\q2 شارە قەڵابەندەکانی ئێوە کاول دەکات.
\q1 
\v 19 ئەی دانیشتووانی شاری عەرۆعێر،
\q2 لەسەر ڕێگا بوەستن و بڕوانن.
\q1 لە پیاوی هەڵاتوو و ژنی دەربازبوو بپرسن،
\q2 بڵێن: ”چی ڕوویدا؟“
\q1 
\v 20 مۆئاب ئابڕووی چوو، چونکە شکێنرا.
\q2 واوەیلا بکە و هاوار بکە!
\q1 لەلای ڕووباری ئەرنۆنەوە ڕایبگەیەنن
\q2 کە مۆئاب تەفروتونا بووە.
\q1 
\v 21 حوکمدان بەسەر زەوی دەشتەکەدا هات،
\q2 بەسەر حۆلۆن و یەهچا و مێفەعەت،
\q2 
\v 22 بەسەر دیڤۆن و نیبۆ و بێت‌دیڤلاتایم،
\q2 
\v 23 بەسەر قیریاتەیم و بێت‌گاموول و بێت‌مەعۆن،
\q2 
\v 24 بەسەر قەریۆت و بۆزرا،
\q2 بەسەر هەموو شارۆچکەکانی خاکی مۆئاب، دوور و نزیکەکان.
\q1 
\v 25 هێزی مۆئاب بڕایەوە،
\q2 بازووی شکا.»
\q4 ئەوە فەرمایشتی یەزدانە.
\b
\q1 
\v 26 «سەرخۆشی بکەن،
\q2 چونکە بەرامبەر بە یەزدان خۆی بە زل زانی.
\q1 با مۆئاب لەناو ڕشانەوەکەی خۆی بگەوزێت،
\q2 ببێتە مایەی گاڵتەجاڕی.
\q1 
\v 27 ئەی تۆ بە ئیسرائیل پێنەکەنیت؟
\q2 ئایا ئەو لەنێو دزان گیرا،
\q1 هەر کاتێک باست دەکرد،
\q2 سەرت دەلەقاند؟
\q1 
\v 28 ئەی دانیشتووانی مۆئاب،
\q2 شارۆچکەکان بەجێبهێڵن و لەناو بەردەکاندا نیشتەجێ بن.
\q1 وەک کۆتر بن کە هێلانەکەی
\q2 لەدەم ئەشکەوتدا دروست دەکات.
\b
\q1 
\v 29 «لووتبەرزی مۆئابمان بیستووە،
\q2 زۆر لووتبەرزە،
\q1 خۆبەزلزانی و لووتبەرزی و
\q2 فیز و شانازییەکەی لە دڵەوە.
\q1 
\v 30 یەزدان دەفەرموێت: من بێ شەرمی ئەوم زانیوە، بەڵام قسەی پووچە.
\q2 کردارە پووچەکانی بێ سوودن.
\q1 
\v 31 لەبەر ئەوە واوەیلا بۆ مۆئاب دەکەم،
\q2 بۆ سەراپای مۆئاب هاوار دەکەم،
\q2 بۆ پیاوانی قییر حەراسەت دەنووزێمەوە.
\q1 
\v 32 ئەی مێوی سیڤما،
\q2 وەک گریانی یەعزێر بۆت دەگریێم.
\q1 لقەکانت لە دەریا پەڕینەوە،
\q2 گەیشتنە دەریای یەعزێر.
\q1 تەفروتوناکەر کەوتە سەر
\q2 میوە پێگەیشتوو و هێشووە ترێیەکانت.
\q1 
\v 33 خۆشی و دڵشادی داماڵران
\q2 لە ڕەزەکان و لە خاکی مۆئاب.
\q1 شەرابم لە گوشەر ڕاگرت،
\q2 بە هاواری خۆشییەوە پێپەست ناکرێت،
\q1 ئەگەر هاوارکردن هەبێت،
\q2 لە خۆشیدا هاوار ناکەن.
\b
\q1 
\v 34 «دەنگی هاواریان بەرزبووەوە،
\q2 لە حەشبۆنەوە هەتا ئەلعالێ و هەتا یەهەچ،
\q1 لە زۆعەرەوە هەتا حۆرۆنایم و عەگلەت شەلیشیا،
\q2 چونکە هەروەها ئاوی نیمریمیش وشک دەبێت.
\q1 
\v 35 لە مۆئاب کۆتایی دەهێنم
\q2 بەوانەی لە نزرگەکانی سەر بەرزایی قوربانی پێشکەش دەکەن و
\q2 بخوور بۆ خوداوەندەکانی دادەگیرسێنن.»
\q4 ئەوە فەرمایشتی یەزدانە.
\q1 
\v 36 «لەبەر ئەوە دڵم بۆ مۆئاب وەک شمشاڵ ناڵەی دێت،
\q2 دڵم بۆ پیاوانی قییر حەراسەت وەک شمشاڵ دەناڵێنێت،
\q2 چونکە ئەو سامانەی بەدەستیان هێنا لەناوچوو.
\q1 
\v 37 هەموو سەرێک تاشراوە و
\q2 هەموو ڕیشێک کورت کراوەتەوە،
\q1 هەموو دەستێک بریندار کراوە و
\q2 هەموو ناوقەدێک بە جلوبەرگی گوش داپۆشراوە.
\q1 
\v 38 لەسەر هەموو سەربانەکانی مۆئاب و
\q2 لە هەموو شەقامەکانی
\q1 جگە لە گریان هیچی دیکە نییە،
\q2 چونکە مۆئابم شکاند،
\q2 وەک گۆزەیەک کەس نەیەوێت.»
\q4 ئەوە فەرمایشتی یەزدانە.
\q1 
\v 39 «چۆن شکا! چۆن واوەیلا دەکەن!
\q2 چۆن مۆئاب لە شەرمان ڕووی وەرگێڕا!
\q1 مۆئاب بووە مایەی گاڵتەجاڕی و
\q2 ترسناکی بۆ هەموو ئەوانەی دەوروبەری.»
\p 
\v 40 یەزدان ئەمە دەفەرموێت:
\q1 «تەماشا بکەن! دوژمن وەک هەڵۆ بەرز دەفڕێت،
\q2 بەسەر مۆئابدا باڵەکانی لێک دەکاتەوە.
\q1 
\v 41 قەریۆت دەگیرێت و
\q2 قەڵاکان دەستیان بەسەردا دەگیرێت.
\q1 لەو ڕۆژەدا دڵی پاڵەوانەکانی مۆئاب
\q2 وەک دڵی ژنی ژانگرتووی لێدێت.
\q1 
\v 42 مۆئاب لەوە دەکەوێت کە ببێتە گەل،
\q2 چونکە بەرامبەر بە یەزدان خۆی بە زل زانی.
\q1 
\v 43 ئەی دانیشتووی مۆئاب،
\q2 ترس و چاڵ و تەڵە چاوەڕێت دەکات.»
\q4 ئەوە فەرمایشتی یەزدانە.
\q1 
\v 44 «ئەوەی لە ترس هەڵدێت
\q2 دەکەوێتە ناو چاڵەکەوە،
\q1 ئەوەی لە چاڵەکە دێتە دەرەوە
\q2 بە تەڵەکەوە دەبێت،
\q1 چونکە ساڵی سزادان
\q2 بەسەر مۆئابدا دەهێنم.»
\q4 ئەوە فەرمایشتی یەزدانە.
\b
\q1 
\v 45 «لە سێبەری حەشبۆن
\q2 هەڵاتووەکان بە بێهێزی وەستاون،
\q1 چونکە لە حەشبۆنەوە ئاگرێک دەرچوو،
\q2 گڕێکیش لەنێو سیحۆنەوە،
\q1 ناوچەوانی مۆئاب و
\q2 کەللەسەری گەلی بە هاتوهاوار دەخوات.
\q1 
\v 46 قوڕبەسەرت مۆئاب!
\q2 خەڵکی کەمۆش لەناوچوو،
\q1 کوڕەکانی تۆیان ڕاپێچ کرد و
\q2 کچەکانت بە دیل بردران.
\b
\q1 
\v 47 «بەڵام لە ئاییندەدا،
\q2 ڕاپێچکراوەکانی مۆئاب دەگەڕێنمەوە.»
\q4 ئەوە فەرمایشتی یەزدانە.
\p ئێرە کۆتایی حوکم بەسەردادانی مۆئابە.
\c 49
\s1 پەیامێک سەبارەت بە عەمۆن
\p 
\v 1 بۆ عەمۆنییەکان:
\b
\p یەزدان ئەمە دەفەرموێت:
\q1 «ئایا ئیسرائیل کوڕی نییە،
\q2 یان میراتگری نییە؟
\q1 بۆچی مۆلەخ گاد داگیر بکات و
\q2 گەلەکەشی لەناو شارۆچکەکانی ئەودا نیشتەجێ بن؟»
\q1 
\v 2 یەزدان دەفەرموێت: «لەبەر ئەوە ئەوەتا ڕۆژێک دێت،
\q1 وا دەکەم لە شاری ڕەبەی عەمۆنییەکان،
\q2 نەعرەتەی جەنگ ببیسترێت،
\q1 جا دەبێتە گردێکی وێران و
\q2 شارۆچکەکانیشی بە ئاگر دەسووتێن،
\q1 ئیسرائیلیش داگیرکەرانی خۆی داگیر دەکات.»
\q4 ئەوە فەرمایشتی یەزدانە.
\q1 
\v 3 «ئەی حەشبۆن واوەیلا بکە، چونکە عای تەفروتونا بوو!
\q2 ئەی دانیشتووانی ڕەبە هاوار بکەن!
\q1 بەرگی لە گوش دروستکراو لەبەر بکەن و شین بگێڕن،
\q2 بەناو شووراکانیدا بسووڕێنەوە،
\q1 چونکە مۆلەخ ڕاپێچ دەکرێت،
\q2 خۆی و کاهین و پیاوە گەورەکانی.
\q1 
\v 4 بۆ شانازی بە دۆڵەکانتەوە دەکەیت؟
\q2 بۆ شانازی بە دۆڵە پڕ بەروبوومەکانتەوە دەکەیت؟
\q1 ئەی کچی هەڵگەڕاوە،
\q2 ئەوەی پشت بە گەنجینەکانت دەبەستیت و دەڵێیت،
\q2 ”کێ پەلامارم دەدات؟“»
\q1 
\v 5 یەزدان، پەروەردگاری سوپاسالار، دەفەرموێت:
\q2 «ئەوەتا من ترست دەهێنمە سەر
\q2 لە هەموو ئەوانەی دەوروبەرت.
\q1 جا هەریەکە لە ئێوە دەردەکرێت و
\q2 کەس نابێت ونبووان کۆبکاتەوە.
\b
\q1 
\v 6 «پاش ئەمە ڕاپێچکراوانی عەمۆنییەکان دەگەڕێنمەوە.»
\q4 ئەوە فەرمایشتی یەزدانە.
\s1 پەیامێک سەبارەت بە ئەدۆم
\p 
\v 7 بۆ ئەدۆم:
\b
\p یەزدانی سوپاسالار ئەمە دەفەرموێت:
\q1 «ئایا ئیتر دانایی لە تێمان نییە؟
\q2 ئایا ڕاوێژ لەلای تێگەیشتووان نەماوە؟
\q2 ئایا داناییەکەیان پووچەڵ بووەتەوە؟
\q1 
\v 8 ئەی دانیشتووانی دیدان، بکشێنەوە و هەڵێن،
\q2 بڕۆن لە ئەشکەوتە قووڵەکان خۆتان بشارنەوە،
\q1 چونکە بەڵاکەی عیسۆی بەسەردەهێنم
\q2 لەو کاتەی سزای دەدەم.
\q1 
\v 9 ئەگەر ڕەزبڕت\f + \fr 49:9 \ft ڕەزبڕ: ئەوەی بەرهەمی ڕەزی دەبڕێتەوە.‏\f* بۆ بێت،
\q2 ئایا هەندێک ترێ بەجێناهێڵن؟
\q1 ئەگەر بە شەو دزت بۆ بێت،
\q2 ئایا تەنها ئەوەی پێویستیان بێت نایدزن؟
\q1 
\v 10 بەڵام من عیسۆ ڕووت دەکەمەوە،
\q2 شوێنە نهێنییەکانی دەردەخەم،
\q2 ناتوانێت خۆی بشارێتەوە،
\q1 منداڵ و برا و دراوسێکانی تەفروتونا دەکرێت،
\q2 ئیتر کەس بە زیندوویی نامێنێتەوە بۆ ئەوی بڵێت:
\q1 
\v 11 ”هەتیوەکانت جێبهێڵە، من دەیانپارێزم،
\q2 با بێوەژنەکانت پشت بە من ببەستن.“»
\p 
\v 12 سەبارەت بەمە یەزدان دەفەرموێت: «ئەگەر ئەوانەی شایانی ئەوە نین لە جامەکە بخۆنەوە، بەڵام بە تەواوی خواردیانەوە، ئایا تۆ بە تەواوی بێ سزا دەبیت؟ بێ سزا نابیت، بەڵکو دەبێت بیخۆیتەوە.
\v 13 یەزدان دەفەرموێت: سوێندم بە خۆم خواردووە، کە بۆزرا وێران بێت، ڕیسوا بێت، بڕووخێت و نەفرەتبار بێت و هەموو شارۆچکەکانیشی هەتاهەتایە بە ڕووخاوی بمێنێتەوە.»
\q1 
\v 14 هەواڵێکم لەلایەن یەزدانەوە بیست،
\q2 نێردراوێک بۆ نەتەوەکان نێردراوە تاکو پێیان بڵێت:
\q1 «کۆببنەوە و پەلاماری بدەن،
\q2 هەستن بۆ جەنگ.»
\b
\q1 
\v 15 «ئێستا لەنێو گەلاندا بچووکت دەکەمەوە،
\q2 لەنێو مرۆڤدا ڕیسوا دەبیت.
\q1 
\v 16 تۆ سامت لەسەر خەڵک هەبوو،
\q2 فیزی دڵت هەڵیخەڵەتاندی،
\q1 ئەی نیشتەجێی نێو کەلێنی تاشەبەرد،
\q2 ئەوەی لەسەر بەرزایی گردیت،
\q1 تەنانەت ئەگەر وەک هەڵۆ هێلانەکەت لە بەرزایی دانێیت،
\q2 لەوێوە دەتهێنمە خوارەوە.»
\q4 ئەوە فەرمایشتی یەزدانە.
\q1 
\v 17 «ئەدۆم دەبێتە وێرانە،
\q2 هەرکەسێک پێیدا تێبپەڕێت سەرسام دەبێت،
\q2 گاڵتەی پێ دەکات لەسەر هەموو ئەوەی بەسەری هاتووە.
\q1 
\v 18 وەک سەرەوژێربوونی سەدۆم و عەمۆرا
\q2 و شارۆچکەکانی دەوروبەری،
\q1 هیچ مرۆڤێک لەوێدا نیشتەجێ نابێت،
\q2 هیچ ئادەمیزادێک بۆ ئەوێ ئاوارە نابێت.»
\q4 ئەوە فەرمایشتی یەزدانە.
\b
\q1 
\v 19 «ئەوەتا وەک شێرێک لە دەوەنەکانی ڕووباری ئوردونەوە سەردەکەوێت،
\q2 بەرەو لەوەڕگا دەوڵەمەندەکان،
\q1 ئاوا لە چاوتروکانێکدا لەوێ ئەدۆمییەکان ڕاودەنێم.
\q2 کێ هەڵبژێردراوە کە بیکەم بە سەرپەرشتیاری؟
\q1 چونکە کێ وەک منە و کێ کێشمەکێشم لەگەڵ دەکات؟
\q2 ئەو شوانە کێیە کە دەتوانێ لە ڕووی من بوەستێتەوە؟»
\b
\q1 
\v 20 لەبەر ئەوە ببیستن خودا چ پلانێکی لە دژی ئەدۆم داڕشتووە،
\q2 مەبەستی چی بووە لە دژی دانیشتووانی تێمان بیکات:
\q1 بچووکەکانی مێگەلەکە ڕادەکێشرێن،
\q2 بەهۆی ئەوان بە تەواوی لەوەڕگاکانیان وێران دەکات.
\q1 
\v 21 لە دەنگی کەوتنیان زەوی دەلەرزێت،
\q2 قیژەیان دەگاتە دەریای سوور\f + \fr 49:21 \ft عیبری \tl سوف‏\tl* واتا (زەل). دەشێت مەبەست لە دەریای سوف بێت، ئەو دەریایە بێت کە دەکەوێتە سەرووی باکووری کەنداوی سوێسی ئەمڕۆ، بەڵام لە دەقی یۆنانی پەیمانی نوێ هەر بە دەریای سوور نووسراوە. بڕوانە \xt عیبرانییەکان 11‏:29‏\xt*\ft ‏.‏\f*.
\q1 
\v 22 تەماشا بکەن! دوژمن وەک هەڵۆ بەرز دەبێتەوە و دەفڕێت،
\q2 بەسەر بۆزرادا باڵەکانی لێک دەکاتەوە.
\q1 لەو ڕۆژەدا دڵی پاڵەوانانی ئەدۆم
\q2 وەک دڵی ژنی ژانگرتووی لێدێت.
\s1 پەیامێک سەبارەت بە دیمەشق
\p 
\v 23 بۆ دیمەشق:
\q1 «حەمات و ئەرپاد شەرمەزار بوون،
\q2 چونکە هەواڵێکی خراپیان بیست،
\q1 لە ترسان توانەوە،
\q2 وەک دەریا شڵەژاون و ئارام نابنەوە.
\q1 
\v 24 دیمەشق هێزی لەبەر بڕا،
\q2 ڕووی وەرگێڕا بۆ هەڵاتن،
\q2 شڵەژا و تانگەتاو بوو
\q1 وەک ژنی ژانگرتوو.
\q1 
\v 25 چۆن واز لە شارە بەناوبانگەکە نەهێنرا،
\q2 ئەو شارۆچکەیەی کە شوێنی شادی من بوو!
\q1 
\v 26 بێگومان لەو ڕۆژەدا، لاوەکانی لەناو شەقامەکان دەکوژرێن،
\q2 هەموو جەنگاوەرەکانی لەناودەچن.»
\q4 ئەمە فەرمایشتی یەزدانی سوپاسالارە.
\q1 
\v 27 «ئاگرێک لە دیواری دیمەشق بەردەدەم،
\q2 قەڵاکانی بەن‌هەدەد دەخوات.»
\s1 پەیامێک سەبارەت بە قێدار و حاچۆر
\p 
\v 28 بۆ قێدار و شانشینەکانی حاچۆر، ئەوەی نەبوخودنەسری پاشای بابل لێیدا:
\b
\p یەزدان ئەمە دەفەرموێت:
\q1 «ئەی بابلییەکان، هەستن هێرش ببەن بۆ قێدار،
\q2 خەڵکی ڕۆژهەڵات تەفروتونا بکەن.
\q1 
\v 29 ڕەشماڵ و مەڕەکانیان دەبردرێن،
\q2 خێوەت و هەموو قاپوقاچاغەکانیان و
\q2 وشترەکانیان دەهێنرێن.
\q1 بانگیان بکەن:
\q2 ”لە هەموو لایەکەوە ترس و تۆقین هەیە!“»
\b
\q1 
\v 30 یەزدان دەفەرموێت: «ڕابکەن و دوور هەڵێن!
\q2 ئەی دانیشتووانی حاچۆر، لە ئەشکەوتە قووڵەکان نیشتەجێ بن.
\q1 نەبوخودنەسری پاشای بابل لە دژی ئێوە ڕاوێژی کردووە،
\q2 لە دژی ئێوە پیلانی داناوە.
\b
\q1 
\v 31 «هەستن هێرش ببەنە سەر نەتەوەیەکی ئاسوودە،
\q2 بە پشت ئەستوورییەوە نیشتەجێیە.
\q4 ئەوە فەرمایشتی یەزدانە.
\q1 نە دەرگا و نە شمشیرەی\f + \fr 49:31 \ft شمشیر، پارچە دارێک بووە لە جیاتی قوفڵ لە دواوەی دەرگا بە شێوەی ئاسۆیی دانراوە بۆ داخستنی دەرگا.‏\f* هەیە،
\q2 بە تەنهایی نیشتەجێیە.
\q1 
\v 32 وشترەکانیان بە تاڵان دەبردرێن و
\q2 ماڵاتی زۆریان دەبێتە دەستکەوت.
\q1 بە هەموو بایەک
\q2 قژبڕاوەکان\f + \fr 49:32 \ft بڕوانە \xt یەرمیا 9‏:26‏\xt*\ft ‏\f* شەن دەکەم،
\q1 لە هەموو لایەکەوە کارەساتیان بەسەردەهێنم.»
\q4 ئەوە فەرمایشتی یەزدانە.
\q1 
\v 33 «حاچۆر بۆ هەتاهەتایە
\q2 دەبێتە داڵدەی چەقەڵ و چۆڵەوانی.
\q1 هیچ مرۆڤێک لەوێ نیشتەجێ نابێت،
\q2 هیچ ئادەمیزادێک ئاوارەی ئەوێ نابێت.»
\s1 پەیامێک سەبارەت بە ئیلام
\p 
\v 34 ئەو فەرمایشتەی یەزدان کە لە سەرەتای پاشایەتییەکەی سدقیای پاشای یەهودا بۆ یەرمیای پێغەمبەر هات، سەبارەت بە ئیلام، پێی فەرموو:
\b
\p 
\v 35 یەزدانی سوپاسالار ئەمە دەفەرموێت:
\q1 «ئەوەتا من کەوانی ئیلام دەشکێنم،
\q2 کە سەرچاوەی هێزیانە.
\q1 
\v 36 چوار با لە هەر چوار لای ئاسمانەوە،
\q2 بەسەر ئیلامدا دەهێنم،
\q1 بەم چوار بایە شەنیان دەکەم،
\q2 هەتا نەتەوە نەبێت
\q2 کە دوورخراوەکانی ئیلامی بۆ نەچوو بێت.
\q1 
\v 37 ئیلامییەکان لەبەردەم دوژمنانیان دەتۆقێنم،
\q2 لەبەردەم ئەوانەی دەیانەوێ بیانکوژن،
\q1 بەڵایان بەسەردەهێنم،
\q2 گڕی تووڕەییم.»
\q4 ئەوە فەرمایشتی یەزدانە.
\q1 «بە شمشێر ڕاویان دەنێم
\q2 هەتا کۆتاییان دەهێنم.
\q1 
\v 38 تەختی خۆم لە ئیلام دادەنێم و
\q2 لەوێ پاشا و پیاوە گەورەکانی لەناودەبەم.»
\q4 ئەوە فەرمایشتی یەزدانە.
\b
\q1 
\v 39 «بەڵام لە ئاییندەدا،
\q2 ڕاپێچکراوەکانی ئیلام دەگەڕێنمەوە.»
\q4 ئەوە فەرمایشتی یەزدانە.
\c 50
\s1 پەیامێک سەبارەت بە بابل
\p 
\v 1 ئەمە ئەو فەرمایشتەیە کە یەزدان سەبارەت بە بابل و خاکی بابلییەکان لە ڕێگەی یەرمیای پێغەمبەرەوە فەرمووی:
\q1 
\v 2 «لەنێو نەتەوەکان جاڕبدەن و ڕایبگەیەنن،
\q2 ئاڵا بەرز بکەنەوە و ڕابگەیەنن،
\q2 هیچ مەشارنەوە، بڵێن،
\q1 ”بابل دەگیرێت،
\q2 بێل\f + \fr 50:2 \ft بێل یەکێکە لە خوداوەند و بتە ناودارەکانی سەردەمی شانشینی بابل.‏ بڕوانە \xt ئیشایا 46‏:1\xt*\ft .\f* شەرمەزار دەبێت،
\q2 مەرۆداخ\f + \fr 50:2 \ft بێل یان مەرۆداخ یان مەردوخ، هەمان سەرۆکی خوداوەندەکانی بابلییەکان بوو.‏ بڕوانە \xt ئیشایا 46‏:1\xt*\ft .\f* وردوخاش دەبێت.
\q1 پەیکەرەکانی شەرمەزار و
\q2 بتەکانی وردوخاش دەبن!“
\q1 
\v 3 نەتەوەیەک لە باکوورەوە دێتە سەری،
\q2 خاکەکەی وێران دەکات،
\q1 ئاوەدانی تێدا نابێت،
\q2 لە مرۆڤەوە هەتا ئاژەڵ هەڵدێن.»
\b
\q1 
\v 4 یەزدان دەفەرموێت:
\q2 «لەو ڕۆژانە و لەو سەردەمە،
\q1 نەوەی ئیسرائیل و نەوەی یەهودا پێکەوە دێن،
\q2 بەدەم ڕێگاوە دەگریێن و ڕوو لە یەزدان دەکەن، خودای خۆیان.
\q1 
\v 5 پرسیاری ڕێگای سییۆن دەکەن و
\q2 ڕووی تێ دەکەن.
\q1 دێنەوە و بە پەیمانێکی هەتاهەتایی کە لەبیر نەکرێت،
\q2 دەچنە پاڵ یەزدانی خۆیان.
\b
\q1 
\v 6 «گەلەکەم مەڕی ونبوو بوون،
\q2 شوانەکانیان گومڕایان کردن،
\q2 وێڵی ناو چیاکانیان کردن.
\q1 لەنێو چیا و گردەکان دەگەڕان،
\q2 جێی حەوانەوەی خۆیان لەبیر کرد.
\q1 
\v 7 هەموو ئەوانەی تووشیان دەبوون لووشیان دەدان،
\q2 دوژمنانیان گوتیان: ”ئێمە تاوانبار نین،
\q1 لەبەر ئەوەی گوناهیان لە دژی یەزدان کرد،
\q2 کە شوێنی حەوانەوەی ڕاستەقینەیانە،
\q2 لە دژی یەزدان کە ئومێدی باوباپیرانیانە.“
\b
\q1 
\v 8 «لە بابل ڕابکەن،
\q2 خاکی بابلییەکان بەجێبهێڵن،
\q2 وەک نێرییەکانی پێش مێگەل بن،
\q1 
\v 9 چونکە ئەوەتا من کۆمەڵە نەتەوەیەکی گەورە
\q2 لە خاکی باکوورەوە ڕادەپەڕێنم.
\q1 ئەوان لە دژی بابل ڕیز دەبەستن،
\q2 لە باکوور دەیگرن.
\q1 تیرەکانیان وەک پاڵەوانی شارەزایە،
\q2 بە دەستبەتاڵی ناگەڕێنەوە.
\q1 
\v 10 خاکی بابل دەبێتە دەستکەوت،
\q2 ئەوەی دەستی بکەوێت لێی تێر دەبێت.»
\q4 ئەوە فەرمایشتی یەزدانە.
\b
\q1 
\v 11 «ئەی تاڵانکەرانی میراتەکەم،
\q2 لەبەر ئەوەی دڵخۆش و شادمان بوون،
\q1 وەک مانگایەک گەنم بکوتێت هەڵدەبەزنەوە و
\q2 وەک ئەسپ حیلاندتان،
\q1 
\v 12 دایکتان زۆر شەرمەزار دەبێت،
\q2 ئەوەی ئێوەی بووە ڕیسوا دەبێت.
\q1 دەبێتە دوایین نەتەوە،
\q2 دەبێتە چۆڵەوانی و بیابان و دەشتی ڕووت.
\q1 
\v 13 لەبەر تووڕەیی یەزدان ئاوەدان نابێتەوە و
\q2 هەمووی دەبێتە چۆڵەوانی.
\q1 هەرکەسێک بە بابلدا تێبپەڕێت سەرسام دەبێت و فیکە لێدەدات،
\q2 لەبەر هەموو ئەوەی بەسەری هاتووە.
\b
\q1 
\v 14 «ئەی هەموو کەوان ڕاکێشان،
\q2 لە چواردەوری بابل ڕیز ببەستن.
\q1 تیربارانی بکەن! دەست مەپارێزن،
\q2 چونکە لە دژی یەزدان گوناهی کرد.
\q1 
\v 15 لە هەموو لایەکەوە نەعرەتەی بەسەردا بکێشن!
\q2 خۆی بەدەستەوە دەدا، قوللەکانی دەکەون،
\q2 شووراکانی دەڕووخێن.
\q1 لەبەر ئەوەی ئەمە تۆڵەی یەزدانە،
\q2 تۆڵەی لێ بکەنەوە،
\q2 چی کرد، ئەوەی پێ بکەنەوە.
\q1 
\v 16 وەرزێر لە بابل ببڕنەوە و
\q2 داس بەدەست لە کاتی دروێنە.
\q1 لە ڕووی شمشێری ستەمکار،
\q2 با هەریەکە بەرەو گەلەکەی خۆی بگەڕێتەوە،
\q2 با هەریەکە بەرەو خاکی خۆی هەڵبێت.
\b
\q1 
\v 17 «ئیسرائیل مێگەلێکی پەرتەوازەیە،
\q2 شێرەکان ڕاویان ناوە.
\q1 سەرەتا پاشای ئاشور لووشی دا،
\q2 ئینجا ئەمەی دوایی،
\q1 نەبوخودنەسری پاشای بابل،
\q2 ئێسکەکانی هاڕی.»
\p 
\v 18 لەبەر ئەوە یەزدانی سوپاسالار، خودای ئیسرائیل ئەمە دەفەرموێت:
\q1 «من پاشای بابل و خاکەکەی سزا دەدەم،
\q2 وەک چۆن پاشای ئاشورم سزا دا.
\q1 
\v 19 بەڵام ئیسرائیل دەگەڕێنمەوە ناو پاوانەکەی خۆی،
\q2 جا لە کارمەل و باشان دەلەوەڕێت،
\q1 لە شاخەکانی ئەفرایم و گلعادیش
\q2 تێر دەخوات.»
\q1 
\v 20 یەزدان دەفەرموێت:
\q2 «لەو ڕۆژانەدا و لەو سەردەمەدا،
\q1 بەدوای تاوانی ئیسرائیلدا دەگەڕێن،
\q2 بەڵام نییەتی،
\q1 هەروەها بەدوای گوناهی یەهودا دەگەڕێن،
\q2 بەڵام هیچ نادۆزنەوە،
\q2 چونکە ئەوانەی کە دەیانهێڵمەوە لێیان خۆشدەبم.»
\b
\q1 
\v 21 یەزدان دەفەرموێت: «پەلاماری خاکی میراتەیم\f + \fr 50:21 \ft بە واتای دوو هێندە یاخیبوون.‏\f* و
\q2 دانیشتووانی پەقۆد\f + \fr 50:21 \ft بە واتای سزادان.‏\f* بدە.
\q1 ڕایانماڵە و بیانکوژە و بە تەواوی بیانبڕەوە\f + \fr 50:21 \ft وشەی لە زمانی عیبری ئەم زاراوەیە دەگەڕێتەوە بۆ شتێک یان کەسێک کە دەبەخشرێت بە یەزدان، زۆر جار بەخشینەکە بە تەواوی لە ناودەبردرێت.‏\f*،
\q2 هەموو ئەوەی فەرمانم پێکردیت بیکە.
\q1 
\v 22 لە خاکەکە دەنگی جەنگە،
\q2 دەنگی تێکشکانێکی مەزن!
\q1 
\v 23 چۆن تێکشکا و تەفروتونا بوو،
\q2 چەکوشی هەموو زەوی!
\q1 بابل چۆن وێران بوو
\q2 لەنێو نەتەوەکان!
\q1 
\v 24 ئەی بابل، تەڵەم بۆت نایەوە،
\q2 بەبێ ئەوەی بزانی پێوەبوویت.
\q1 دۆزرایتەوە و گیرایت،
\q2 چونکە دژایەتی یەزدانت کرد.
\q1 
\v 25 یەزدان جبەخانەکەی خۆی کردەوە و
\q2 چەکەکانی تووڕەیی خۆی دەرهێنا،
\q1 چونکە یەزدان، پەروەردگاری سوپاسالار،
\q2 کارێکی هەیە لە خاکی بابلییەکان.
\q1 
\v 26 لەوپەڕەوە وەرنە سەری!
\q2 ئەمبارەکانی بکەنەوە،
\q2 وەک کۆمەی دەغڵودان کەڵەکەی بکەن.
\q1 بە تەواوی قڕی بکەن،
\q2 پاشماوەی نەمێنێتەوە!
\q1 
\v 27 هەموو جوانەگاکانی\f + \fr 50:27 \ft لەو کاتەوە گوێرەکەی نێر لە شیر دەبڕدرێتەوە پێ دەڵێن (نۆبەن) یان (جوانەگا).‏\f* بکوژن،
\q2 با بۆ سەربڕین ببردرێن!
\q1 قوڕبەسەریان! چونکە ڕۆژیان هات،
\q2 کاتی سزادانیان.
\q1 
\v 28 لە خاکی بابلەوە گوێ لە دەنگی هەڵاتووان و دەربازبووان بگرن
\q2 لە سییۆن ڕایبگەیەنن
\q1 چۆن یەزدانی پەروەردگارمان تۆڵەی سەندەوە،
\q2 تۆڵەی پەرستگاکەی.
\b
\q1 
\v 29 «تیرهاوێژەکان بانگ بکەن لە دژی بابل،
\q2 هەموو کەوان بەدەستەکان.
\q1 لە هەموو لایەکەوە دابەزنە سەری،
\q2 با کەس دەرباز نەبێت.
\q1 بەگوێرەی کردەوەکەی سزای بدەن،
\q2 هەموو ئەوەی کردی پێی بکەنەوە،
\q1 چونکە لە ڕووی یەزدان وەستایەوە،
\q2 لە ڕووی خودا پیرۆزەکەی ئیسرائیل.
\q1 
\v 30 لەبەر ئەوە لاوەکانی لە گۆڕەپانەکاندا دەکوژرێن و
\q2 لەو ڕۆژەدا هەموو جەنگاوەرەکانی لەناودەچن.»
\q4 ئەوە فەرمایشتی یەزدانە.
\q1 
\v 31 «ئەی بێ چاوەڕوو، ئەوەتا من لە دژی تۆم،
\q1 چونکە ڕۆژت هات،
\q2 کاتی سزادانت.»
\q2 ئەوە فەرمایشتی یەزدانە، پەروەردگاری سوپاسالار.
\q1 
\v 32 «جا بێ چاوەڕووەکە ساتمە دەکات و دەکەوێت،
\q2 کەس هەڵیناستێنێتەوە،
\q1 منیش ئاگر بەردەدەمە شارۆچکەکانی و
\q2 هەموو دەوروبەرەکەی دەخوات.»
\p 
\v 33 یەزدانی سوپاسالار ئەمە دەفەرموێت:
\q1 «نەوەی ئیسرائیل چەوسێنراوەن،
\q2 هەروەها نەوەی یەهوداش.
\q1 هەموو ئەوانەی ڕاپێچیان کردن ئەوانیان گرت،
\q2 ڕازی نەبوون بەڕەڵایان بکەن.
\q1 
\v 34 بەڵام ئەوەی دەیانکڕێتەوە بەهێزە،
\q2 ناوی یەزدانی سوپاسالارە.
\q1 بە چالاکی داکۆکی لە کێشەکەیان دەکات،
\q2 هەتا خاکەکە دەحەسێنێتەوە،
\q2 بەڵام دانیشتووانی بابل هەراسان دەکات.»
\b
\q1 
\v 35 یەزدان دەفەرموێت: «شمشێر لە دژی بابلییەکانە!
\q1 لە دژی دانیشتووانی بابلە و
\q2 لە دژی میر و پیاوە داناکانییەتی!
\q1 
\v 36 شمشێر لە دژی قسە پووچەکانە!\f + \fr 50:36 \ft مەبەستی لەوانە کە بە درۆ بانگەشەی پێغەمبەرایەتییان دەکرد.‏\f*
\q2 جا گێل دەبن.
\q1 شمشێر لە دژی پاڵەوانەکانییەتی!
\q2 جا دەتۆقن.
\q1 
\v 37 شمشێر لە دژی ئەسپ و گالیسکەکانییەتی،
\q2 لە دژی هەموو سەربازە بێگانەکان لە ڕیزەکانی ئەو!
\q2 جا دەبن بە ژن.
\q1 شمشێر لە دژی گەنجینەکانییەتی!
\q2 جا تاڵان دەکرێن.
\q1 
\v 38 وشکەساڵی لە دژی ئاوەکانییەتی!
\q2 جا وشک دەبن،
\q1 چونکە خاکی بتەکانە،
\q2 ئەو بتانەی شێتی و تۆقین دەهێنن.
\b
\q1 
\v 39 «لەبەر ئەوە دڕندە بیابانییەکان و کەمتیار تێیدا دەژین،
\q2 کوندەپەپووی تێدا دەژیێت.
\q1 ئیتر هەرگیز کەسی تێدا نیشتەجێ نابێت،
\q2 نەوە دوای نەوە ئاوەدان نابێتەوە.
\q1 
\v 40 وەک چۆن خودا سەدۆم و عەمۆرای سەرەوژێر کرد
\q2 لەگەڵ شارۆچکەکانی دەوروبەری،
\q1 هیچ مرۆڤێک لەوێدا نیشتەجێ نابێت،
\q2 هیچ ئادەمیزادێک بۆ ئەوێ ئاوارە نابێت.»
\q4 ئەوە فەرمایشتی یەزدانە.
\b
\q1 
\v 41 «ئەوەتا! سوپایەک لە باکوورەوە دێت،
\q2 نەتەوەیەکی مەزن و چەندین پاشا،
\q2 لەوپەڕی زەوییەوە هەڵدەستێنرێن.
\q1 
\v 42 کەوان و ڕمیان بە دەستەوەیە،
\q2 دڵڕەقن و بەزەییان نییە.
\q1 دەنگیان وەک دەریا هاژەی دێت و
\q2 سواری ئەسپ دەبن،
\q1 وەک یەک پیاو ڕیز دەبەستن
\q2 بۆ هێرشکردنە سەر تۆ، ئەی شاری بابل.
\q1 
\v 43 پاشای بابل هەواڵی ئەوانی بیست،
\q2 ورەی ڕووخا،
\q1 تووشی تەنگانە بوو،
\q2 تووشی ئازار بوو وەک ئازاری ژنی ژانگرتوو.
\q1 
\v 44 ئەوەتا وەک شێرێک لە دەوەنەکانی ڕووباری ئوردونەوە سەردەکەوێت،
\q2 بەرەو لەوەڕگا دەوڵەمەندەکان،
\q1 ئاوا لە چاوتروکانێکدا لەوێ بابلییەکان ڕاودەنێم.
\q2 کێ هەڵبژێردراوە کە بیکەم بە سەرپەرشتیاری؟
\q1 کێ وەک منە و کێ کێشمەکێشم لەگەڵ دەکات؟
\q2 ئەو شوانە کێیە کە دەتوانێ لە ڕووی من بوەستێتەوە؟»
\b
\q1 
\v 45 لەبەر ئەوە ببیستن خودا چ پلانێکی لە دژی بابل داڕشتووە،
\q2 مەبەستی چی بووە لە دژی خاکی بابلییەکان بیکات:
\q1 بچووکەکانی مێگەلەکە ڕادەکێشرێن،
\q2 بەهۆی ئەوان بە تەواوی لەوەڕگاکانیان وێران دەکات.
\q1 
\v 46 لە دەنگی گرتنی بابل زەوی دەلەرزێت،
\q2 قیژەیان دەگاتە ناو نەتەوەکان.
\c 51
\p 
\v 1 یەزدان ئەمە دەفەرموێت:
\q1 «ئەوەتا من ڕۆحی لەناوبەر\f + \fr 51:1 \ft با یان ئامرازێک بۆ لەناوبردنیان.‏\f* دەوروژێنم
\q2 لە دژی بابل و دانیشتووانی لێڤ قامای\f + \fr 51:1 \ft واتا خاکی کلدانییەکان، مەبەستی لە بابلە.‏\f*.
\q1 
\v 2 بێگانەکان دەنێرمە بابل
\q2 بۆ شەنکردنیان و ڕووتکردنەوەی خاکەکەی،
\q1 لە هەموو لایەکەوە دەوری دەدەن
\q2 لە ڕۆژی بەڵای ئەودا.
\q1 
\v 3 ڕێ مەدە تیرهاوێژ ژێی کەوانەکەی ڕابکێشێت،
\q2 ڕێ مەدە سەرباز زرێیەکەی بپۆشێت.
\q1 دەستتان لە گەنجەکانی مەپارێزن،
\q2 بەڵکو سوپاکەی بە تەواوی لەناوببەن\f + \fr 51:3 \ft لەناو دەبن: لە زمانی عیبری ئەم زاراوەیە دەگەڕێتەوە بۆ شتێک یان کەسێک کە دەبەخشرێت بە یەزدان، زۆر جار بەخشینەکە بە تەواوی لە ناودەبردرێت.‏\f*.
\q1 
\v 4 کوژراوان لە بابل دەکەون،
\q2 بریندارەکان بە سەختی لە شەقامەکانی،
\q1 
\v 5 چونکە ئیسرائیل و یەهودا بەجێنەهێڵدراون
\q2 لەلایەن خودایانەوە، لەلایەن یەزدانی سوپاسالارەوە،
\q1 هەرچەندە خاکی بابلییەکان پڕ لە تاوانە
\q2 لە دژی خودا پیرۆزەکەی ئیسرائیل.
\b
\q1 
\v 6 «لە بابلەوە هەڵێن!
\q2 هەرکەسێک با خۆی دەرباز بکات!
\q2 بە تاوانی ئەو لەناونەچن،
\q1 چونکە کاتی تۆڵەسەندنەوەیە بۆ یەزدان،
\q2 ئەو سزای شایستەی دەدات.
\q1 
\v 7 بابل جامێکی زێڕ بوو بە دەستی یەزدانەوە،
\q2 هەموو زەوی سەرخۆش کرد.
\q1 نەتەوەکان لە شەرابی ئەویان خواردەوە،
\q2 لەبەر ئەوە نەتەوەکان شێت بوون.
\q1 
\v 8 لەپڕ بابل دەکەوێت و وردوخاش دەبێت.
\q2 واوەیلای بۆ بکەن!
\q1 هەتووانێک بۆ برینەکەی بهێنن،
\q2 بەڵکو چاک بێتەوە.
\b
\q1 
\v 9 «”بابلمان تیمار کرد،
\q2 بەڵام ناتوانێت چاک بێتەوە.
\q1 وازی لێ بهێنن و با هەریەکەمان بچینەوە خاکەکەی خۆمان،
\q2 چونکە کاتێک حوکمی بەسەردا درا هاواری گەیشتە ئاسمان،
\q2 هەتا هەورەکان بەرز بووەتەوە.“
\b
\q1 
\v 10 «”یەزدان ئەستۆپاکی ئێمەی دەرخست،
\q2 وەرن با لە سییۆن
\q2 باسی کردەوەکەی یەزدانی پەروەردگارمان بکەین.“
\b
\q1 
\v 11 «تیرەکان تیژ بکەن،
\q2 قەڵغانەکان هەڵبگرن!
\q1 یەزدان ڕۆحی پاشایانی مادی وروژاندووە،
\q2 چونکە پلانی وێرانکردنی بابل دادەنێت.
\q1 یەزدان تۆڵە دەستێنێتەوە،
\q2 تۆڵەی پەرستگاکەی.
\q1 
\v 12 لە دژی شووراکانی بابل ئاڵا هەڵبکەن!
\q2 پاسەوانیێتی توند بکەن،
\q1 چاودێر دابنێن،
\q2 بۆسە بنێنەوە!
\q1 خودا مەبەستی خۆی دەهێنێتە دی،
\q2 بڕیارەکەی لە دژی خەڵکی بابل.
\q1 
\v 13 ئەی نیشتەجێی دەم ئاوە زۆرەکان،
\q2 خاوەن گەنجینەی زۆر،
\q1 کۆتاییت هات،
\q2 کاتی لەناوچوونت.»
\q1 
\v 14 یەزدانی سوپاسالار بە گیانی خۆی سوێندی خوارد:
\q2 «بە دڵنیاییەوە پڕت دەکەم لە سەرباز، وەک ڕەوە کوللە،
\q2 هاواری سەرکەوتنت بەسەردا دەکێشن.»
\b
\q1 
\v 15 «خودا بە هێزی خۆی زەوی دروستکردووە،
\q2 بە دانایی خۆی جیهانی دامەزراندووە،
\q2 بە تێگەیشتنی خۆی ئاسمانی ڕاخستووە.
\q1 
\v 16 کاتێک دەنگ هەڵدەبڕێت، ئاوەکانی ئاسمان هاژەیان دێت،
\q2 هەڵمەکان لەوپەڕی زەوییەوە بەرز دەکاتەوە،
\q1 بروسکە بۆ باران دروستدەکات،
\q2 با لە ئەمباری خۆی دەردەهێنێت.
\b
\q1 
\v 17 «هەموو کەسێک بێ زانیارییە و دەبەنگە،
\q2 هەموو زێڕنگەرێک بە پەیکەرەکەی شەرمەزارە،
\q1 چونکە داڕێژراوی درۆن و
\q2 ڕۆحیان تێدا نییە.
\q1 
\v 18 ئەوان پووچن، مایەی گاڵتەجاڕین،
\q2 لە کاتی سزادانیان لەناودەچن.
\q1 
\v 19 بەڵام خودا، ئەوەی بەشی یاقوبە وەک ئەمانە نییە،
\q2 چونکە ئەو دروستکەری هەموو شتێکە،
\q1 هۆزی\f + \fr 51:19 \ft بڕوانە 10‏:12‏-16.‏\f* میراتی ئەویشی داناوە،
\q2 یەزدانی سوپاسالار، ئەمە ناوی ئەوە.
\b
\q1 
\v 20 «تۆ گورزی منی،
\q2 چەکەکانی جەنگی منی،
\q1 بە تۆ نەتەوەکان تێکدەشکێنم،
\q2 بە تۆ شانشینەکان لەناودەبەم،
\q1 
\v 21 بە تۆ ئەسپ و سوارەکەی تێکدەشکێنم،
\q2 بە تۆ گالیسکە و سوارەکەی تێکدەشکێنم،
\q1 
\v 22 بە تۆ ژن و پیاو تێکدەشکێنم،
\q2 بە تۆ پیر و گەنج تێکدەشکێنم،
\q2 بە تۆ گەنج و لاو تێکدەشکێنم،
\q1 
\v 23 بە تۆ شوان و مێگەلەکەی تێکدەشکێنم،
\q2 بە تۆ جوتیار و گاجووتەکەی تێکدەشکێنم،
\q2 بە تۆ پارێزگار و فەرمانڕەواکان تێکدەشکێنم.
\p 
\v 24 «لەبەرچاوی خۆتان سزای بابل و هەموو دانیشتووانی خاکی بابل دەدەم بەرامبەر بە هەموو ئەو خراپانەی لە سییۆن کردیان.» ئەوە فەرمایشتی یەزدانە.
\q1 
\v 25 «ئەی کێوی لەناوبەر، ئەوەتا من لە دژی تۆم،
\q2 تۆ ئەی لەناوبەری هەموو زەوی.»
\q4 ئەوە فەرمایشتی یەزدانە.
\q1 «دەست درێژ دەکەمە سەرت،
\q2 لەسەر بەردەکان گلۆرت دەکەمەوە،
\q2 دەتکەمە کێوێکی سووتاو.
\q1 
\v 26 ئیتر نە بەردت لێ دەبەن بۆ بەردی قولینچک\f + \fr 51:26 \ft بەردی قولینچک: بەردێکی گەورە لە گۆشەی دیوار دادەنرێت لەو بەردانە بەهێزترە کە لە دیوارەکە بەکاردێت و دەبێتە هۆی بەهێزکردنی دیوارەکە.‏\f*،
\q2 نە هیچ بەردێک بۆ بناغەکان،
\q2 چونکە بۆ هەتاهەتایە دەبیتە چۆڵەوانی.»
\q4 ئەوە فەرمایشتی یەزدانە.
\b
\q1 
\v 27 «ئاڵا لەسەر خاکەکە بەرز بکەنەوە،
\q2 لەنێو نەتەوەکان فوو بە کەڕەنادا بکەن.
\q1 نەتەوەکان لە دژی بابل ئامادە بکەن،
\q2 ئەم شانشینانە لە دژی ئەو بانگ بکەن:
\q2 ئارارات و مینی و ئەشکەنەز،
\q1 ڕابەرێک لە دژی دابنێن،
\q2 وەک ڕەوە کوللە ئەسپ بنێرن.
\q1 
\v 28 نەتەوەکان لە دژی ئەو ئامادە بکەن،
\q2 پاشاکانی ماد،
\q1 پارێزگار و هەموو فەرمانڕەواکان و
\q2 هەموو خاکی ژێر دەسەڵاتیان.
\q1 
\v 29 ئینجا زەوی دەلەرزێت و ژان دەیگرێت،
\q2 چونکە مەبەستی یەزدان لە بابل دێتە دی،
\q1 بۆ ئەوەی خاکی بابل وێران بکات،
\q2 ئیتر ئاوەدانی تێدا نابێت.
\q1 
\v 30 پاڵەوانەکانی بابل وازیان لە جەنگ هێنا،
\q2 لە قەڵاکان دانیشتن.
\q1 هێزیان لەبەر بڕا،
\q2 وەک ژنیان لێهات.
\q1 نشینگەکانیان سووتێنرا،
\q2 شمشیرەی دەرگاکانیان شکێنرا.
\q1 
\v 31 نێردراوێک بەدوای یەکێکی دیکە دەکەوێت و
\q2 پەیامنێرێک بەدوای پەیامنێرێکی دیکە،
\q1 بۆ ئەوەی بە پاشای بابل ڕابگەیەنن
\q2 کە سەرتاسەری شارەکانی گیراون،
\q1 
\v 32 ڕووبارەکان\f + \fr 51:32 \ft مەبەستی لە پرد و شوێنی پەڕینەوەیە لە ڕووبارەکان.‏\f* دەستیان بەسەردا گیرا،
\q2 زۆنگاوەکان بە ئاگر سووتێنران،
\q2 جەنگاوەرەکان تۆقین.»
\p 
\v 33 یەزدانی سوپاسالار، خودای ئیسرائیل، ئەمە دەفەرموێت:
\q1 «شاری بابل وەک جۆخینێکە
\q2 کاتی گێرەیەتی،
\q2 پاش کەمێک کاتی بەرهەم دێت.»
\b
\q1 
\v 34 «نەبوخودنەسری پاشای بابل ئێمەی خوارد،
\q2 ئومێدبڕی کردین،
\q2 ئێمەی کردە گۆزەیەکی بەتاڵ.
\q1 وەک ئەژدیها هەڵیلووشین،
\q2 سکی خۆی پڕکرد لە چێژی ئێمە،
\q2 ئینجا ئێمەی ڕشاندەوە.»
\q1 
\v 35 دانیشتووانەکەی سییۆن دەڵێن:
\q2 «ئەو ستەمەی لە ئێمە کرا بەسەر بابل بێت.»
\q1 ئۆرشەلیم دەڵێت:
\q2 «خوێنم لە ملی دانیشتووانی خاکی بابلە.»
\p 
\v 36 لەبەر ئەوە یەزدان ئەمە دەفەرموێت:
\q1 «ئەوەتا من داکۆکی لە کێشەکەت دەکەم،
\q2 تۆڵەی تۆ دەکەمەوە،
\q1 دەریاکەی\f + \fr 51:36 \ft خەڵک لەو باوەڕەدا بوون کە لەبن زەوی دەریایەک هەبوو وەکو سەرچاوەی ئاو.‏\f* وشک دەکەم،
\q2 کانییەکانی کوێر دەکەمەوە.
\q1 
\v 37 بابل دەبێتە تەپۆڵکە و
\q2 داڵدەی چەقەڵ،
\q1 پەند و مایەی تانە و تەشەر،
\q2 شوێنێک ئاوەدانی تێدا نییە.
\q1 
\v 38 پێکەوە وەک جوانە شێر دەنەڕێنن،
\q2 وەک بەچکە شێرەکان دەمڕێنن.
\q1 
\v 39 کاتێک گەرم دەبن،
\q2 داوەتیان دەکەم و
\q2 سەرخۆشیان دەکەم،
\q1 بۆ ئەوەی دڵخۆش بن،
\q2 ئینجا هەتاهەتایە خەویان لێ دەکەوێت و بەئاگا نایەن.»
\q4 ئەوە فەرمایشتی یەزدانە.
\q1 
\v 40 «وەک بەرخ دەیانبەم بۆ سەربڕین
\q2 وەک بەران و نێری.
\b
\q1 
\v 41 «شێشەخ\f + \fr 51:41 \ft ناوی نهێنی بابل بووە.‏\f* چۆن دەگیرێت،
\q2 شانازی هەموو زەوی چۆن دەستبەسەر دەکرێت!
\q1 چۆن وێران بوو،
\q2 بابل لەنێو نەتەوەکان!
\q1 
\v 42 دەریا بەسەر بابلدا هەڵدەچێت،
\q2 بە هەڵچوونی شەپۆلەکانی دایدەپۆشێت.
\q1 
\v 43 شارۆچکەکانی وێران بوون،
\q2 بوونە بیابان و دەشتی ڕووت،
\q1 خاکێک کە نە کەس تێیدا نیشتەجێ دەبێت و
\q2 نە ئادەمیزاد پێیدا تێدەپەڕێت.
\q1 
\v 44 لە بابل سزای بێل دەدەم و
\q2 ئەوەی قووتی داوە لە دەمی دەهێنمە دەرەوە.
\q1 ئیتر نەتەوەکان بەرەو لای ئەو ڕێچکە ناگرن،
\q2 هەروەها شووراکانی بابل دەکەوێت.
\b
\q1 
\v 45 «ئەی گەلی من لەناویدا وەرنە دەرەوە!
\q2 هەرکەسێک خۆی لە گڕی تووڕەیی یەزدان دەرباز بکات!
\q1 
\v 46 ورە بەرمەدەن و مەترسن،
\q2 کاتێک هەواڵی ئەو خاکە دەبیستن،
\q1 هەواڵێک ئەم ساڵ دێت، ئینجا لە ساڵی پاشتر هەواڵێکی دیکە،
\q2 هەواڵی ستەم لە خاکەکەدا و
\q2 فەرمانڕەوا لە دژی فەرمانڕەوا.
\q1 
\v 47 لەبەر ئەوە بێگومان ڕۆژێک دێت
\q2 سزای بتەکانی بابل دەدەم،
\q1 هەموو خاکەکەی شەرمەزار دەبێت و
\q2 کوژراوەکانی لە ناوەڕاستی دەکەون.
\q1 
\v 48 ئینجا ئاسمان و زەوی و هەرچی تێیاندایە
\q2 هاواری خۆشی بەسەر بابلدا دەکەن،
\q1 چونکە لە باکوورەوە بۆی دێن،
\q2 تەفروتوناکەرەکان.»
\q4 ئەوە فەرمایشتی یەزدانە.
\b
\q1 
\v 49 «دەبێت بابلیش لەبەر کوژراوەکانی ئیسرائیل بڕووخێت،
\q2 وەک چۆن کوژراوەکانی هەموو زەوی
\q2 بەهۆی بابلەوە کەوتن.
\q1 
\v 50 ئەی دەربازبووان لە شمشێر،
\q2 بڕۆن و مەوەستن!
\q1 لە دوورەوە یادی یەزدان بکەنەوە،
\q2 بیر لە ئۆرشەلیم بکەنەوە.»
\b
\q1 
\v 51 «شەرمەزار بووین،
\q2 چونکە ڕیسوا بووین و
\q2 شەرم ڕووی داپۆشین،
\q1 چونکە بێگانەکان هاتنە ناو
\q2 پیرۆزگاکانی ماڵی یەزدان.»
\b
\q1 
\v 52 یەزدان دەفەرموێت: «لەبەر ئەوە ڕۆژێک دێت،
\q2 بتەکانی سزا دەدەم،
\q1 لە هەموو خاکەکەیدا
\q2 بریندارەکان دەناڵێنن.
\q1 
\v 53 تەنانەت ئەگەر بابل بگاتە ئاسمانیش،
\q2 ئەگەر قەڵای خۆشی قاییم بکات،
\q2 تەفروتوناکەر لە دژی ئەو دەنێرم.»
\q4 ئەوە فەرمایشتی یەزدانە.
\b
\q1 
\v 54 «دەنگی هاوار دێت لە بابل،
\q2 دەنگی شکستێکی گەورە
\q2 لە خاکی بابلییەکان.
\q1 
\v 55 یەزدان بابل تەفروتونا دەکات،
\q2 کۆتایی بە دەنگە مەزنەکەی دەهێنێت.
\q1 شەپۆلی دوژمنەکانیان وەک ئاوێکی زۆر هەڵدەچێت،
\q2 دەنگیان هاژەی دێت.
\q1 
\v 56 تەفروتوناکەر دێتە سەر بابل،
\q2 پاڵەوانەکانی دەگیرێن،
\q2 کەوانەکانیان دەشکێنرێت،
\q1 چونکە یەزدان خودای سزادانە،
\q2 بە تەواوی سزا دەدات.
\q1 
\v 57 میر و دانا و پارێزگار و
\q2 فەرمانڕەوا و پاڵەوانەکانی سەرخۆش دەکەم،
\q1 هەتاهەتایە خەویان لێ دەکەوێت و بەئاگا نایەن.»
\q2 ئەوە فەرمایشتی ئەو پاشایەیە کە ناوی یەزدانی سوپاسالارە.
\p 
\v 58 یەزدانی سوپاسالار ئەمە دەفەرموێت:
\q1 «شوورا پانەکانی بابل بە تەواوی دەڕووخێنرێن،
\q2 دەروازە بەرزەکانیشی بە ئاگر دەسووتێنرێن.
\q1 گەلان بەخۆڕایی خۆیان ماندوو دەکەن و
\q2 ڕەنجی نەتەوەکانیش تەنها بۆ ئاگر دەبێت.»
\p 
\v 59 ئەمە ئەو پەیامەیە کە یەرمیای پێغەمبەر دایە سەرایای کوڕی نێرییا کوڕی مەحسێیا، سەرۆکی ئۆردوگا، کاتێک لە ساڵی چوارەمی پاشایەتییەکەی لەگەڵ سدقیای پاشای یەهودا چوو بۆ بابل.
\v 60 هەموو ئەوەی لەسەر بابل تۆمار کرابوو، لەگەڵ هەموو ئەو بەڵایەی بەسەری دێت یەرمیا نووسیبووی و کردبووی بە تۆمارێک،
\v 61 بە سەرایای گوت: «کاتێک گەیشتییە بابل، دڵنیابە لە خوێندنەوەی تەواوی ئەم پەیامە بۆ خەڵکەکە،
\v 62 ئینجا بڵێ: ”ئەی یەزدان، تۆ فەرمووت ئەم شوێنە لەناودەبەیت، تاکو ئەوەی مرۆڤ و ئاژەڵی تێدا نامێنێت، هەتاهەتایە دەبێتە چۆڵەوانی.“
\v 63 کاتێک لە خوێندنەوەی ئەم تۆمارە بوویتەوە، بەردێکی پێوە ببەستە و فڕێیبدە ناو فورات.
\v 64 ئینجا بڵێ: ”بابل ئاوا نوقوم دەبێت و لەژێر ئەو بەڵایە ڕاست نابێتەوە کە من بەسەری دەهێنم، خەڵکەکەی شەکەت دەبن.“»
\p هەتا ئێرە وشەکانی یەرمیایە.
\c 52
\s1 ڕووخاندنی ئۆرشەلیم
\p 
\v 1 سدقیا گەنجێکی بیست و یەک ساڵان بوو کە بوو بە پاشا، یازدە ساڵ لە ئۆرشەلیم پاشایەتی کرد. دایکی ناوی حەموتەلی کچی یەرمیای خەڵکی لیڤنا بوو.
\v 2 ئەمیش لەبەرچاوی یەزدان خراپەکاری کرد، وەک هەموو ئەوەی یەهۆیاقیم کردی.
\v 3 لەبەر تووڕەیی یەزدان بوو کە ئەمانە لە ئۆرشەلیم و لە یەهودا ڕوویدا، هەتا ئەوەی لەبەردەم خۆیدا دەریکردن.
\p ئەوە بوو سدقیا لە پاشای بابل یاخی بوو.
\p 
\v 4 ئیتر لە دەی مانگی دەی ساڵی نۆیەمی پاشایەتی سدقیا، نەبوخودنەسری پاشای بابل هەموو سوپاکەی بەرەو ئۆرشەلیم جوڵاند و لەوێ ئۆردوگای دامەزراند، لە چواردەوری قوللەی بنیاد نا.
\v 5 هەتا ساڵی یازدەیەمی پاشایەتی سدقیا شارەکە لەژێر گەمارۆدا بوو.
\p 
\v 6 لە نۆی مانگی چواردا قاتوقڕی لە شارەکە هێندە سەخت بوو کە نان نەبوو گەلی خاکەکە بیخۆن.
\v 7 ئینجا شوورای شارەکە شکێنرا و هەموو جەنگاوەرەکان بە شەو بە ڕێگای دەروازەکەی نێوان دوو شووراکەی بەرامبەر باخچەی پاشادا هەڵاتن، هەرچەندە بابلییەکان لە چواردەوری شارەکە بوون. بە ڕێگای عەراڤادا\f + \fr 52:7 \ft عەراڤا: واتا دۆڵی ڕووباری ئوردون.‏\f* هەڵاتن،
\v 8 بەڵام سوپای بابلییەکان بەدوای سدقیای پاشا کەوتن، لە دەشتی ئەریحا پێی گەیشتن، هەموو سوپاکەی پەرتەوازە بوو،
\v 9 جا پاشایان بە دیل گرت.
\p بردیانە لای پاشای بابل لە ڕیڤلە، لە خاکی حەمات، ئەویش دادگایی کرد.
\v 10 هەر لە ڕیڤلە پاشای بابل کوڕەکانی سدقیای لەبەرچاوی باوکیان کوشت، ئینجا هەموو پیاوماقوڵانی یەهوداشی لەناوبرد.
\v 11 پاشان هەردوو چاوی سدقیای دەرهێنا، بە زنجیری بڕۆنز کۆتی کرد، بردی بۆ بابل و هەتا ڕۆژی مردنی لە بەندیخانە بەندی کرد.
\p 
\v 12 لە دەی مانگی پێنجی ساڵی نۆزدەیەمی نەبوخودنەسری پاشای بابل، نەبوزەرەدانی فەرماندەی پاسەوانانی پاشا، ئەوەی خزمەتی پاشای بابلی دەکرد، هاتە ئۆرشەلیم.
\v 13 پەرستگای یەزدان و کۆشکی پاشا و هەموو ماڵەکانی ئۆرشەلیم و هەموو تەلارە گرنگەکانی سووتاند.
\v 14 شووراکانی چواردەوری ئۆرشەلیمیش لەلایەن سوپای بابلییەکانەوە ڕووخێنران، ئەوانەی لەگەڵ فەرماندەی پاسەوانانی پاشا بوون.
\v 15 جا لە ڕەشوڕووتی گەل و پاشماوەی گەلیش ئەوانەی لە شارەکەدا مابوونەوە و ئەوانەی بۆ لای پاشای بابل هەڵاتبوون لەگەڵ پاشماوەی وەستاکان، نەبوزەرەدانی فەرماندەی پاسەوانانی پاشا ڕاپێچی کردن.
\v 16 بەڵام نەبوزەرەدانی فەرماندەی پاسەوانانی پاشا هەندێک لە خەڵکی ڕەشوڕووتی لە خاکەکە هێشتەوە بۆ کارکردن لە ڕەزەمێو و کێڵگەکان.
\p 
\v 17 کۆڵەکە بڕۆنزییەکان و عەرەبانەکانی ئاوگواستنەوە و حەوزە بڕۆنزییەکە کە لە پەرستگای یەزدان بوون، بابلییەکان پارچەپارچەیان کردن، هەموو بڕۆنزەکەشیان بۆ بابل بارکرد،
\v 18 هەروەها مەنجەڵ و خاکەناز، مەقەست، تاس\f + \fr 52:18 \ft کاهین ئەم تاسانەی بۆ پرژاندنی خوێنی قوربانی بەکاردەهێنا، وەک هێمایەک بۆ کەفارەتی گوناهەکانی خەڵک. بڕوانە \xt دەرچوون 29‏:20 و زەکەریا 9‏:15؛ 14‏:20 و عیبرانییەکان 9‏:13‏\xt*\ft ‏.‏\f*، قاپەکان و هەموو ئەو قاپوقاچاغە بڕۆنزانەی لە خزمەتی پەرستگا بەکاردەهات.
\v 19 فەرماندەی پاسەوانانی پاشا تەشت و بخووردان، تاس، مەنجەڵ، چرادان، چەمچە و پەرداخەکانی برد. هەموو ئەوەی کە بە زێڕ و زیو دروستکرابوو بردی.
\p 
\v 20 بڕۆنزی دوو کۆڵەکەکە و حەوزەکە و دوازدە گاکان کە لەژێر عەرەبانەکانی ئاو گواستنەوەدا بوون، ئەوەی سلێمانی پاشا بۆ پەرستگای یەزدان دروستی کردبوون، لە کێش نەدەهات.
\v 21 هەر کۆڵەکەیەک هەژدە باڵ\f + \fr 52:21 \ft هەژدە باڵ: نزیکەی 8,1 مەتر.‏\f* درێژییەکەی بوو، چێوەکەی دوازدە باڵ\f + \fr 52:21 \ft دوازدە باڵ: نزیکەی 5,4 مەتر.‏\f* بوو، ئەستووریشی چوار پەنجە بوو، کلۆر بوو.
\v 22 تاجێکی بڕۆنز لەسەر کۆڵەکەکە بوو، بەرزی تاجەکە پێنج باڵ\f + \fr 52:22 \ft پێنج باڵ: نزیکەی 2,3 مەتر.‏\f* بوو، کەتیبە و هەنارەکانیش لەسەر تاجەکە و لە چواردەوری هەمووی لە بڕۆنز بوون. بۆ هەر یەکێک لە کۆڵەکەکان هەمان شت هەبوو لەگەڵ هەنارەکان.
\v 23 نەوەد و شەش دانە هەنار لە دەوری هەر ستوونێک هەبوو، سەرجەمی هەنارەکان لەسەر هەر کەتیبەیەک لە چواردەوریدا سەد دانە بوون.
\p 
\v 24 فەرماندەکەی پاسەوانانی پاشا سەرایای سەرۆک کاهین و سەفەنیای کاهینی دووەم و سێ دەرگاوانەکەی گرت.
\v 25 لە شارەکەش ئەو ئەفسەرەی گرت کە لێپرسراوی جەنگاوەرەکان بوو، حەوت ڕاوێژکاری پاشاشی گرت. هەروەها خامەی نهێنی\f + \fr 52:25 \ft ڕازپۆشێکی تایبەت بوو بە ناونووسینی پیاوانی ئیسرائیل بۆ سەربازی.‏\f* سوپاسالاری گرت ئەوەی بەرپرسی بە سەربازکردن بوو، لەگەڵ شەست پیاو کە لە شارەکە بەرچاو کەوتن.
\v 26 نەبوزەرەدانی فەرماندەی پاسەوانانی پاشا ئەوانەی بردە ڕیڤلە بۆ لای پاشای بابل.
\v 27 پاشای بابلیش لە ڕیڤلە لە خاکی حەمات کوشتنی.
\p ئینجا یەهودا لە خاکەکەی خۆی ڕاپێچ کرا.
\v 28 ئەمانە ئەو خەڵکە بوون کە نەبوخودنەسر ڕاپێچی کرد:
\b
\li1 لە ساڵی حەوتەم،
\li2 سێ هەزار و بیست و سێ جولەکە؛
\li1 
\v 29 لە ساڵی هەژدەمینی نەبوخودنەسریش،
\li2 هەشت سەد و سی و دوو کەس لە ئۆرشەلیم ڕاپێچ کران؛
\li1 
\v 30 ئینجا لە ساڵی بیست و سێیەمی نەبوخودنەسر،
\li2 نەبوزەرەدانی فەرماندەی پاسەوانانی پاشا حەوت سەد و چل و پێنج جولەکەی ڕاپێچ کرد.
\li2 سەرجەمیان چوار هەزار و شەش سەد کەس بوون.
\s1 بەڕەڵاکردنی یەهۆیاکین
\p 
\v 31 لە ساڵی سی و حەوتەمینی ڕاپێچکردنی یەهۆیاکین، ئەڤیل مەرۆدەخ بوو بە پاشای بابل. هەر لەو ساڵە لە بیست و پێنجی مانگی دوازدە یەهۆیاکینی پاشای یەهودای لە زیندان ئازاد کرد و هێنایە دەرەوە.
\v 32 بە باشی قسەی لەگەڵ کرد و کورسییەکەی لە سەرووی کورسی ئەو پاشایانەوە دانا کە لە بابل لەگەڵی بوون.
\v 33 ئیتر یەهۆیاکین بەرگی زیندانییەکەی گۆڕی و بە درێژایی ماوەی ژیانی بەردەوام لەسەر خوانی پاشا نانی دەخوارد.
\v 34 بە درێژایی ئەو ماوەیەی ژیانی ڕۆژ بە ڕۆژ بژێوی ڕۆژانەی لەلایەن پاشای بابلەوە پێدەدرا، هەتا ڕۆژی مردنی.
