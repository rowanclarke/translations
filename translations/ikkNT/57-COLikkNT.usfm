\id COL Ika New Testament 2009 
\h Ndị Kolosi 
\toc1 Ẹkụkwọ-Ozi Pọlụ Dejẹnni Ndị Kolosi 
\toc2 Ndị Kolosi 
\toc3 Kolo 
\mt2 Ẹkụkwọ-Ozi Pọlụ Dejẹnni 
\mt1 Ndị Kolosi 
\c 1  
\cl Isi Nke Ohu 
\p  
\v 1 Mmẹ wụ Pọlụ de ẹhụhụọ-ozini. M wụ onyẹ-ozi pụ-ichẹn Jesu Kristi, makẹni uche Osolobuẹ rọ. Mmẹ lẹ Timoti nwẹnẹ ẹnyi gba de ẹ. 
\p  
\v 2 Ndị nke Osolobuẹ rị Kolosi, umunẹ furu wẹ gi e dọn ẹnya imẹ Kraịstị, kẹ ẹnyi dejẹnni ẹ. Osolobuẹ wụ Nẹdi ẹnyi ya mẹ ni ụnụ ẹfọma, ya ye ụnụ udọn. 
\s1 Pọlụ E Kele Osolobuẹ Makẹ Okukwe Wẹ 
\p  
\v 3 Ogẹn ile kẹ ẹnyi gi a kpanmịn Osolobuẹ wụ Nẹdi Onyẹ-nwọnni-ẹnyi wụ Jesu Kristi, ẹnyi gha e mẹ ni ụnụ ekpere.  
\v 4 Ẹghẹẹ, makẹni, ẹnyi a nụgụọ oku okukwe ụnụ nwẹ imẹ Kraịstị wụ Jizọsị lẹ ihiẹn-ọsụsụọ ụnụ nwọn ebe ndị nke Osolobuẹ ile rị—  
\v 5 makẹni ụnụ rị e lee ẹnya ihiẹn hụ Osolobuẹ dọnmẹ ni ụnụ elu-igwee. Ụnụ a nụgụọ banyeni ihiẹnni rị elu-igwee lẹ olile-ẹnyanị wẹ gi e sọn ẹ. Ụnụ nụ a ogẹn wẹ gi gwa ụnụ oku hụ wụ ezioku ụnụ nụ—hụn wụ oziọma.  
\v 6 Ya wụ oziọma e rugụọ ụnụ ẹka. Oziọmanị hụ a mị mkpụrụ, e sue, a ghagbarị ụwa ile. Ẹrịra k'o gizi nwan rị a mị mkpụrụ imẹ ụnụ lẹ enwẹn ụnụ kete ụhụọhịn hụ ụnụ nụ a, ụhụọhịn hụ ụnụ ghọta ẹfọma Osolobuẹ mẹ nke-esi. 
\p  
\v 7 Ẹpafrasị hụn wụ ezi igbọn-Kraịstị ibe ẹnyi wụ onyẹ hụn zi ụnụ oziọmanị. Onyẹ-ọrụn furu wẹ gi e dọn ẹnya k'ọ wụ imẹ Kraịstị. Ọ n'a rụn n'ọ rịnị ụnụ mma, ọ n'a nọkin ẹnya ẹnyi ebe ụnụ rị.  
\v 8 Ọ gwagụọ ẹnyi kẹ ụnụ nwẹhan ihiẹn-ọsụsụọ hụn rị imẹ Mmọn-nsọ. 
\p  
\v 9 Kete ẹnyi a nụl'a, ẹnyi eke mẹbehikwọ nị nwan ụnụ ekpere, ẹnyi eke rịọbehikwọ Chuku n'o mẹ ụnụ marịn uche ẹ ọhụnma-ọhụnma, nwẹ amamihiẹn lẹ nghọta imẹ-mmọn, nwẹ wẹ mmagi-mmagi.  
\v 10 Ya dodo mẹ ẹ kẹni ụnụ e bi obibi furu Di-nwọnni-ẹnyi, obibi hụn a sụọ n'a, e junchanrịn a ẹfọ ụzọ ile—a mịpụha mkpụrụ hụn wụ ọrụn ọma ile rị ichẹn-ichẹn, a marịn Osolobuẹ, a marịnwaye. 
\p  
\v 11 Ya gi ikẹn ẹ hi-ogbe, hụn o gi nwẹ ọghọ, mẹ ụnụ wụrụ ndị zeni; ya kwademẹ ụnụ kẹni ụnụ saẹka gi agụngụn rị mma lẹ ịghọghọ dingbuchanrịn ihiẹn ile.  
\v 12 Ya mẹzi ụnụ a sa ẹka a kpanmịn Nẹdi-ẹnyi, hụn mẹ nwan ụnụ rị ndị nwọn ihiẹn ọ kwademẹni ndị nke ẹ, ndị-nsọ a, makẹni wẹ rị imẹ ukpẹ. 
\p  
\v 13 Ọ rị ẹrịra makẹni ọ zụọpụhagụọ ẹnyi okpuru ikẹn ishi, we ẹnyi che Alị-eze ezi Nwa a,  
\v 14 ezi Nwa a, hụn o gigụụ nwan ẹdeke ẹ gbafụha ẹnyi, gbagharị ẹnyi njọ—makẹni ẹnyi rị imẹ ya wụ Nwa a. 
\s1 Onyẹ Kristi Wụ 
\p  
\v 15 Ẹnya hụn Nwa a nị wụ Kraịst' a hụngụọ Osolobuẹ wẹ ghalẹni e legha; ịya wụzịkwọ Ibuzọ, Onyẹ-isi hụn ihiẹn ile wẹ ke eke rị okpuru ẹ.  
\v 16 Makẹni, ẹka a kẹ Osolobuẹ ghaha ke ihiẹn ile rị elu-igwee lẹ ụwa—kẹ ndị w'e legha kẹ ndị wẹ ghalẹni e legha; kẹ ukpo ile kẹ ọkịkị ile; kẹ ndị-isi eje-mmọn kẹ ndị-ọkịkị wẹ. Osolobuẹ ke ihiẹn ile ghaha n'a; ịya k'o ke ni wẹ ile. 
\p  
\v 17 Ọ rị arị nị ihiẹn ọwụlẹ d'e bidọn; ịya gi ihiẹn ile.  
\v 18 Ịya wụ isi ụka hụn wụ ẹhụ a. Ịya wụzị isi-mbidọn; ịya wụ onyẹ-ibuzọ lihini imẹ ndị nwụnnị—wẹ ile k'o gi wụrụ onyẹ-ibuzọ lẹ onyẹ-isi ihiẹn ile.  
\v 19 Makẹni, ọ sụọ Osolobuẹ ụsụọ n'o mẹ nị ihiẹn ile o gi wụrụ Osolobuẹ rị imẹ ya wụ Kraịstị.  
\v 20 Ọ sụọzịkwọ Osolobuẹ n'ọ ghaha ẹka a wekinhẹn ni enwẹn ẹ ihiẹn ile o ke—kẹ wẹ rị elu-ụwa kẹ wẹ rị elu-igwee—ghahanị ẹdeke ọ gba elu-obe ẹ, ndụn a hụn o ye, hụn o gi mẹ ni udọn rị. 
\p  
\v 21 Mgbe mbụ, ẹgbata ụnụ lẹ Osolobuẹ arị mma; iroro ụnụ lẹ ịya adangbamanị—ụnụ e bisọnmẹ eje-obibi.  
\v 22 Kanị o gigụọ nwan ẹhụ o gi bi elu-ụwanị dọnzi ẹgbata ụnụ lẹ Osolobuẹ, ghahanị ọnwụn ọ nwụn. O mẹ ẹrịra kẹni ụnụ wụrụ ndị o jẹnkọ d'e wepụha ihun ẹ—ndị nwẹlẹni ntụpọ lẹ nkọrịanị.  
\v 23 Ọnwan k'e mẹ—omẹni ụnụ e wuzoghọ ọhụnma, omẹni ụnụ e turukẹnmẹ imẹ okukwe, omẹni ụnụ aghanị imẹ olile-ẹnya hụ rị oziọma ụnụ nụ pụ—oziọma hụn wẹ zigụụ ndị ile rị okpuru elu-igwee\f + \fr 1:23 \ft Ebeni rị e ku oku hụn mẹgụnị, ẹlẹ hụn kelẹni mẹ ogẹn ahụn.\f*. Ọrụn Oziọmanị kẹ wẹ tumẹ mmẹ wụ Pọlụ d'a rụn. 
\s1 Ọrụn Pọlụ Nọkẹ Onyẹ-ọrụn Ụka Kraịstị 
\p  
\v 24 Ọghọghọ kẹ m'a ghọghọ makẹ afụnfụn m rị ta nị ụnụ—m gi nwan ẹhụ m a tapụ nị Kristi afụnfụn họdụnị wẹ k'a tanị ẹhụ a wụ ụka.  
\v 25 Osolobuẹ wụ onyẹ hụn gi m hẹnrin onyẹ-ọrụn ụka; o tumẹ m d'a rụn n'ọ rịnị ụnụ mma. Ọrụn hụ wụ ịgwachanrịn ịhịan ile oku Osolobuẹ k'o dọn ku ẹ—  
\v 26 mẹ wẹ marịn ihiẹn hụ Osolobuẹ zuemẹ ketekete, hụn agbọ ile ghanị marịnlẹni—kanị o kpupụgụọ a nwan ghọsị ndị nke ẹ. 
\p  
\v 27 Chuku mẹ ẹ makẹni ọ chọ n'o mẹ ndị nke ẹ marịn kẹ ya wụ ihiẹn-mini mẹhan okẹn ihiẹn-ọghọ, mẹ wẹ marịn nị ndị wụlẹni ndị Ju rịzị ndị ọ kwademẹ n'ẹ. Ihiẹn ahụn mini wụ nị: omẹni Kraịstị rị imẹ ụnụ, lemẹ ni ẹnya nị ụnụ jẹnkọ d'e nwẹ ọghọ ahụn lalanị. 
\p  
\v 28 Oku Kraịstịnị kẹ ẹnyi rị nwan a ghahunmẹ e kusọnmẹ; ẹnyi rị e gi amamihiẹn ile Osolobuẹ ye ẹnyi a dọ onyẹ ọwụlẹ ẹka-ntịn, a kuzi onyẹ ọwụlẹ. Ẹnyi rị e mẹ ihiẹn ndịnị nị ẹnyi mẹ onyẹ ọwụlẹ wụrụ onyẹ ka-ẹhụ imẹ Kristi—kẹni ẹnyi hụn ụzọ wepụha wẹ ihun Osolobuẹ.  
\v 29 Ọnwan kẹ m gi rị a rụngbu enwẹn m, e shi ọnwụn, ghahanị ikẹn hụ ile hi-ogbe hụn Kraịstị gi rị ọrụn imẹ m. 
\c 2  
\cl Isi Nke Ẹbụọ 
\p  
\v 1 M chọ nị ụnụ marịn kẹ m dọn rị a lụnị ụnụ lẹ ndị alị Laodishia lẹ ndị ile kelẹni hụntu m elee-m, elee-i.  
\v 2 M rị a lụ nị m kasị wẹ obi; nị wẹ gi ihiẹn-ọsụsụọ wụrụ obi ohu, a hụn wẹ ụzọ ghọtachanrịn ihiẹn Osolobuẹ—obi e ruchanrịn wẹ alị; a marịn wẹ ihiẹn ahụn mini banyeni Osolobuẹ. Ihiẹn ahụn mini wụ Kraịstị lẹ enwẹn ẹ.  
\v 3 Imẹ Kraịstị kẹ Osolobuẹ zuemẹ amamihiẹn lẹ nghọta ile. 
\p  
\v 4 M rị e ku ọnwan amamgbe wẹ e gi oku rịgbu enwẹn ẹ mma dufie ụnụ.  
\v 5 Makẹni, m hụ a hụn kẹ ụnụ dọn rị e gi usọnrọn-usọnrọn e bi, a hụnzị kẹ ụnụ dọn turukẹnmẹ imẹ okukwe ụnụ imẹ Kristi—ọ hụ e mẹ m a ghọghọ; m hụ a hụn a makẹni, ọsụọn'a nị arị m ebe ụnụ rị elee-m elee-i, m hụ ebẹhụ imẹ-mmọn. 
\s1 Igi Kraịstị Zu Oke 
\p  
\v 6 Ebe o mẹ ni ụnụ a nabanhangụọ Jesu Kristi nọkẹ Di-nwẹni-ụnụ, e bisọnmẹ ni nwan obibi ụnụ imẹ ẹ;  
\v 7 gba nị nwan nkpọgụn imẹ ẹ, ụnụ a tụn ndụn ụnụ imẹ ẹ kẹ wẹ dọn a tụn ụlọ, e wuzo ọhụnma imẹ okukwe—kẹ wẹ dọn kuzi ụnụ ya—a kpanmịn Osolobuẹ ọhụnma-ọhụnma ogẹn ile. 
\p  
\v 8 Hụn n'a nwan n'o nwọnni onyẹ gi okẹn imarịn-ihiẹn nwọnlẹni-isi dufie ụnụ, nwụndọn ụnụ, dọfụ ụnụ imẹ okukwe. Makẹni, o nwẹghọ ndị rị a kuzi ihiẹn nọ ẹrịra. Nkuzi ịhịan lẹ usọnrọn mmọn lẹ iwu ichẹn-ichẹn gi a han ihiẹn e mẹ k'o mẹ elu ụwanị kẹ wẹ rị a kuzi. Ẹlẹ ẹnya Kristi gi e lee ihiẹn kẹ wẹ rị a kuzi.  
\v 9 Kanị, ẹhụ Kraịstị kẹ ihiẹn ile Osolobuẹ gi wụrụ Osolobuẹ rịchanrịn.  
\v 10 Ifiri ọnwan, ụnụ a wụrụgụọ nwan ndị zu oke, hụnnị ụnụ rị imẹ Kraịstị—makẹni ụnụ rị imẹ onyẹ hụ ndị-ọkịkị ile lẹ ọkịkị ile rị okpuru ẹ. 
\p  
\v 11 Imẹ Kristi, a kwagụọ wẹ ụnụ ugun imẹ-mmọn—hụn wụ nke ezigbo ẹ. Ẹlẹ hụn wẹ gi ẹka kwa, kama, hụn Kraịstị lẹ enwẹn ẹ a kwa, hụn wụ ibepụ onyẹ hụ ẹnyi te wụ.  
\v 12 Makẹni ogẹn wẹ gi mẹ ụnụ mirin-Chuku, wẹ gi ẹ ligbama ụnụ lẹ Kristi. Ogẹn wẹ gi wefụha ụnụ imẹ mirin, wẹ gizi ẹ weligbama ụnụ lẹ Kraịstị. Ọnwan mẹ ghahanị okukwe ụnụ nwọn hụn ụnụ gi gi ikẹn Osolobuẹ, onyẹ hụn gha ọnwụn weli Kraịstị, dọn ẹnya. 
\p  
\v 13 Ụnụ te wụ ndị nwụnnị; ụnụ te bi imẹ mmẹfie; ụnụ te wụ ndị wẹ kwalẹni ezigbo ugun wepụ onyẹ njọ wẹ wụ. Kanị, Osolobuẹ nọ mẹ ụnụ sọn Kraịstị rị ndụn—ogẹn o gi gbagharị ẹnyi njọ ile ẹnyi mẹ.  
\v 14 Ọ nọ kagbu Iwu ahụn wẹ de ede hụn wẹ gi a ghọsị nị ẹnyi gi ụgwọ lẹzi ụmụ-iwu hụ ile rịn'a rị a ma ẹnyi ikpe, kpọma a elu-obe Kraịstị, gi ẹrịra bu ẹ che ụsụọ.  
\v 15 Ọ nọ napụ ihiẹn ile rị a kịnị lẹ ọkịkị ile ikẹn wẹ, gbe ifẹnrẹn kpu wẹ ihun id'ẹnya ịhịan ile, gi ihiẹn o mẹ elu obe hụ mẹrichanrịn wẹ. 
\p  
\v 16 Ya wụ, anịkwọlẹ ni nwan onyẹ ọwụlẹ gi oku ihiẹn-oriri lẹ ihiẹn-ọrịra ma ụnụ ikpe, mọbụ oku mmẹmmẹ ọwụlẹ mọbụ Mmẹmmẹ ifọn-ọhụn mọbụ ụdị Ụhụọhịn-nsọ rị ichẹn-ichẹn wẹ gizi e zu ikẹn.  
\v 17 Ihiẹn ndịnị ile wụhụ onyinyọn ihiẹn lalanị—ezigbo ẹ wụ Kristi. 
\p  
\v 18 Anịkwọlẹ ni onyẹ ọwụlẹ hụn e mẹghafe oku imẹshi ẹhụ ikẹn okẹn mọbụ onyẹ e mẹ oku ife ndị mmọn-ozi gi ẹ ma ụnụ ikpe. O mẹkẹnmẹ oku ọhụn ọ hụn lẹ ihiẹn ọ marịn—kanị ihiẹn nwẹlẹni erere ọ ban ọ rị e ro rị e bu ẹ hụ isi makẹni Mmọn-nsọ arị a kị iroro ẹ.  
\v 19 O kwọndọnzini Kristi, hụn wụ isi ẹhụ—hụn e ye ẹhụ ile ihiẹn-oriri, a zụn a, e gi akwanran rịn'a e kwọndọnsọnmẹ mkpamkpa ile rịn'a; e mẹ ẹ n'ọ hụn ụzọ e sue ụdị usue hụn gha ẹka Osolobuẹ a bịa. 
\s1 Idu Kristi A Nwụn Lẹ Idu Ẹ E Bi 
\p  
\v 20 O mẹ nwan nị ụnụ e sọngụọ Kraịstị nwụnhụn, ụnụ a nwụnnahịngụọ mmọn lẹ iwu a han ihiẹn e mẹ k'o mẹ elu ụwanị. Kị haịn nwan ụnụ gi e bi nọkẹ sị ụnụ wụ nke ụwanị? Kẹ ụnụ a gbayeni omẹnalị ndịnị wẹ?  
\v 21 “Ekwọndọnlẹ!” “Adamịnlẹ!” “Emẹtụlẹ ẹka!”?  
\v 22 Omẹnalị ndịnị nwẹ ebe w'a rụnru a rụnbehi wẹ, makẹni wẹ wụhụ iwu lẹ nkuzi ịhịan-mmaka.  
\v 23 Ezioku-ezioku, ị hụn ndị e sọn iwu lẹ usọnrọn ndịnị, ọ nọ kẹ sị a marịnka wẹ ihiẹn—tụmadụ kẹ wẹ dọn a wa omẹnalị rị ofufe e ye enwẹn wẹ olu, e welụa enwẹn wẹ alị hụn wụlẹni nke ezigbo ẹ, e mẹshi ẹhụ wẹ ikẹn. Kanị, ihiẹn ndịnị wụ ihiẹn la iwi, makẹni, w'a ra yeni ịhịan ẹka e kwọndọn enwẹn ẹ amamgbe o mẹsọnmẹ eje-ihiẹn a gụn n'a. 
\c 3  
\cl Isi Nke Ẹtọ 
\p  
\v 1 O mẹ nwan nị ụnụ e sọngụọ Kraịstị gha ọnwụn lihi, chọma ni nwan ihiẹn ndị hụn rị elu—ebẹhụ Kristi nọdị alị azụụn ẹka-nni Osolobuẹ.  
\v 2 Bu ni obi ụnụ che ihiẹn ndị rị elu, ẹlẹ ihiẹn ndị rị ụwa.  
\v 3 Makẹni, ụnụ a nwụngụọ; e bugụọ wẹ ndụn ụnụ che imẹ Kraịstị zuemẹ imẹ Osolobuẹ.  
\v 4 Ogẹn Kraịstị hụn wụ ndụn ụnụ jẹnkọ d'e gi pụha, ụnụ nwẹn k'e sọnzi ẹ gi ọghọ pụha. 
\s1 Ndụn Akan Lẹ Ndụn Ọhụn 
\p  
\v 5 Gbu ni nwan ẹgụn ihiẹn-ụwa hụn rị imẹ ụnụ a rụn ọrụn—kẹ ughẹrẹ kẹ obibi ru unyin kẹ ihiẹn-ọnịna-ẹnya kẹ ẹgụn ihiẹn rịlẹni mma kẹ ẹnya-uku (hụn wụzịkwọ ifee-mmọn.)  
\v 6 Ifiri ihiẹn ndịnị wẹ kẹ iwe-lẹ-ọnụma Chuku gi lalanị nị ndị e nupụ nị oziọma isi.  
\v 7 Ụnụ e te sọn wẹ e bi ẹrịra ogẹn mbụ ahụn ụnụ lẹ wẹ gi wụ ohu. 
\p  
\v 8 Kanị, ụnụ sikọ nwan d'e wepụrịrị ihiẹn ile nọ ẹrịra—olulu, ọnụma, iwe, nkutọ lẹ igi ọnụ ụnụ e ku oku ọwụlẹ ru unyin.  
\v 9 Atụkwọlẹ ni ibe ụnụ ntụ, makẹni ụnụ a gbụpụgụọ ndụn-akan lẹ obibi ẹ lẹkẹ ẹwuru.  
\v 10 Ụnụ e yirigụọ ndụn ọhụn—ndụn ọhụn hụn rị a marịnwaye Onyẹ hụn ken'ẹ, a rịwaye kẹ ịya.  
\v 11 Imẹ ndụn ọhụnnị, w'a ra tu onyẹ ịhịan wụ: o nwọnzini ihiẹn nọkẹ ndị Ju lẹ ndị wụlẹni ndị Ju; mọbụ ndị kwa ugun lẹ ndị kwalẹni ugun mọbụ ndị rị imẹ ọfịa lẹ ndị walẹni ẹnya mọbụ igbọn lẹ onyẹ nwẹ enwẹn ẹ. Kraịstị sụọ—ya wụ ihiẹn ile; Kraịstị ya rị imẹ wẹ ile. 
\p  
\v 12 Rịkẹ ndị Chuku họrị, ndị rị nsọ, ndị rị a obi, yiri ni nwan omikẹn, ẹfọma, iwelụa-enwẹn-ịhịan-alị, imẹ-jụụ lẹ ndidi.  
\v 13 E gi ni ndidi e sọn ibe ụnụ; onyẹ nwẹnẹ ẹ mẹja ya gbagharị a: ụnụ k'a gbagharịrịrị ibe ụnụ kẹ Di-nwọnni-ẹnyi wụ Kraịstị dọn gbagharị ụnụ. 
\p  
\v 14 Hụn kadẹni, yiri ni ihiẹn-ọsụsụọ, makẹni ịya e kẹngbama ihiẹn ndịnị ile, a rụngbama wẹ hụn a na ẹnya.  
\v 15 E gi ni udọn ahụn Kraịstị e ye a marịn imẹ obi ụnụ ihiẹn ụnụ jẹnkọ e mẹ imẹ igunrun ụnụ—makẹni, ezioku-ezioku, ịya kẹ Osolobuẹ kpọ ụnụ d'e nwọn nọkẹ ndị rị ẹhụ ohu. A kpanmịn nị Osolobuẹ.  
\v 16 Nị nị oku Kristi biri imẹ ụnụ, nịn'a junchanrịn imẹ ụnụ. E gi ni amamihiẹn lẹ akọ-lẹ-uche ile ụnụ nwọn a kuzi ibe ụnụ, a gwa wẹ nị wẹ e mẹ ihiẹn rị mma. E gi ni obi ekele a bụsọnmẹ ni Osolobuẹ ẹbụ rị imẹ ẹkụkwọ Ẹbụ-ọma lẹ ẹbụ-ofufe lẹ ẹbụ ndị ọzọ rị nsọ.  
\v 17 E gi ni ẹfan Di-nwọnni-ẹnyi wụ Jesu e mẹ ihiẹn ọwụlẹ—kẹ omumẹ kẹ oku-ọnụ—e ye Chuku Nẹdi ekele ghahanị Di-nwọnni-ẹnyi wụ Jesu. 
\s1 Obibi Furu Ndị Rị Ichẹn-ichẹn 
\p  
\v 18 Nwunyẹ, e bu enwẹn i e che okpuru di i, makẹni ẹrịra k'o furu n'i bi—nọkẹ onyẹ nke Di-nwọnni-ẹnyi. 
\p  
\v 19 Di, nwẹ ihiẹn-ọsụsụọ nwunyẹ i; egilẹ iwe e sọn ẹ. 
\p  
\v 20 Ụmụ, e humẹ ni ni ndị mụnị ụnụ isi imẹ ihiẹn ile, makẹni ya kẹ Di-nwọnni-ẹnyi chọ nị ụnụ e mẹ nọkẹ ndị nke ẹ. 
\p  
\v 21 Ndị nẹdi, ahanlẹ ni ụmụ ụnụ ẹnya, amamgbe ndụn a gụụ wẹ. 
\p  
\v 22 Ndị-idibo lẹ igbọn, a gbaye ni ndị ụnụ rị okpuru wẹ imẹ ọnọdị ọwụlẹ. Ẹlẹ wẹ rịhụ ebẹhụ e lee ụnụ, ụnụ e mẹmẹ nị wẹ ja ụnụ mma. Ka gi ni akpakalị obi ụnụ e mẹ ẹ, makẹ egun Di-nwọnni-ẹnyi.  
\v 23 Ihiẹn ọwụlẹ wẹ sị ụnụ rụn, gi ni obi ụnụ ile rụn a, nọkẹ sị ụnụ rị a rụnnị Di-nwọnni-ẹnyi ya, ẹlẹ ịhịan.  
\v 24 Nyanhankwọ nị nị Di-nwọnni-ẹnyi gjẹnkọ d'e ye ụnụ ihiẹn hụ o dọnmẹ ni ndị nke ẹ nọkẹ ụgwọ-ọrụn. Kristi wụ Di-nwọnni-ẹnyi kẹ ụnụ wụ igbọn ẹ—ịya kẹ ụnụ rị a rụnnị.  
\v 25 Ndị rị e mẹ eje-ihiẹn k'a narịn ụgwọ eje-ihiẹn wẹ mẹ—o nwọnni onyẹ k'a pụn'a. 
\c 4  
\cl Isi Nke Ẹnọ 
\p  
\v 1 Ndị ịhịan rị okpuru wẹ, e gi ni ẹka rị mma e sọn wẹ, emẹgbulẹ ni wẹ. Nyanhankwọ nị nị ụnụ lẹ enwẹn ụnụ nwọnzi Nna ụnụ rị okpuru ẹ hụn rị elu-igwee. 
\s1 Ndụnmọdụn 
\p  
\v 2 E mẹ ni ekpere ogẹn ile; e we ni ẹnya e ru alị ebe ekpere rị; e gi ni ekele e mẹ ẹ. 
\p  
\v 3 E mẹzikwọ nị nị ẹnyi ekpere, kẹni Chuku kpọpụ nị ẹnyi ụzọ ẹnyi e gi ku oku-Chuku, nị ẹnyi hụn ụzọ e kusọnmẹ oku ihiẹn ahụn mini banyeni Kristi—hụn wẹ gi ifiri ẹ we m che imẹ ngannị m rị.  
\v 4 E mẹ ni ni m nwan ekpere, kẹni m saẹka a kọwa a hụn w'a ghọta—k'o furu ni m e mẹ. 
\p  
\v 5 E gi ni uche e sọn ndị kwerilẹni; anịlẹ ni oghere ọwụlẹ ụnụ nwọn nahịn ụnụ.  
\v 6 Oku-ọnụ ụnụ ya wụrụ hụn e ye ẹka, a sụọ kẹ nnu, kẹni ụnụ sa ẹka a shịarị onyẹ ọwụlẹ oku ọhụnma. 
\s1 Ekele Ịkpazụụn 
\p  
\v 7 Ezi nwẹnẹ ẹnyi wụ Taịkịkọsị hụn furu wẹ gi e dọn ẹnya jẹnkọ d'a gwachanrịn ụnụ kẹ m rị—odibo ibe ẹnyi imẹ Onyẹ-nwọnni-ẹnyi k'ọ wụ.  
\v 8 Ya haịn m gi zila nị ụnụ ya, kẹni ọ gwa ụnụ kẹ ẹnyi nọ, gba ụnụ umẹ.  
\v 9 Ịya lẹ ezi nwẹnẹ ẹnyi wụ Onesimọsị hụn furu wẹ gi e dọn ẹnya, hụn wụzị onyẹ alị ụnụ, wị lala. Wẹ k'a gwachanrịn ụnụ kẹ ihiẹn ile nọ ebeni. 
\p  
\v 10 Arịstakọsị onyẹ-ngan ibe m e kele ụnụ. Makị nwa-nwẹnẹ Banabasị e kelezi ụnụ. (Ẹnyi a gwatọgụọ ụnụ nabanhan Makị—omẹni ọ bịa ebẹhụ.)  
\v 11 Jizọsị, hụn w'a kpọzị Jọstusu, e kelezi ụnụ. Madụ ẹtọnị sụọ wụ ndị Ju, ndị kwa ugun, imẹ ndị mmẹ lẹ wẹ wị a rụn ọrụn Alị-eze Osolobuẹ—wẹ e mẹ ndụn a ban m. 
\p  
\v 12 Ẹpafrasị hụn gha obodo ụnụ bịa, hụn wụzị odibo Jesu Kristi, e kele ụnụ. Ẹpafrasị e shi ọnwụn ọda ọ gha e mẹ ni ụnụ ekpere. Ọ rịọsọnmẹ Osolobuẹ n'ọ mẹ ụnụ wuzo nọkẹ ndị ka-ẹhụ, ndị marịn ihiẹn wẹ rị e mẹ ebe ihiẹn ọwụlẹ wụ uche Osolobuẹ rị.  
\v 13 M k'a saẹka shịan'a ẹri n'ọ lụka nị ụnụ—ụnụ lẹ ndị rị Laodishia lẹ Hịrapolisi.  
\v 14 Dọkịta wụ Luku hụn ihiẹn ẹ a sụọ ẹnyi e zi ekele; Dẹmasị e zizikwọ ekele. 
\p  
\v 15 Kele ni ni m umunẹ ẹnyi imẹ Kraịstị hụn rị Laodishia, ụnụ e kele nwẹnẹ ẹnyi okpoho wụ Nimfa lẹ ụka hụn e zu iwe ẹ. 
\p  
\v 16 Wẹ gụngụụ nị ụnụ ẹhụhụọ-ozini imẹ ụka ụnụ, hụn n'a nị wẹ gụnzị nị ndị ụka rị Laodishia ya. Hụnzịkwọ n'a nị ụnụ gụn nke ndị ụka Laodishia imẹ igunrun ụnụ. 
\p  
\v 17 Sị nị Akịpọsị, “Hụnkwọ a n'ị rụnchanrịn ogbo wẹ keye i imẹ ọrụn Di-nwọnni-ẹnyi.” 
\p  
\v 18 Nị m gi ẹka m de nwan ekele m: Mmẹ wụ Pọlụ e kele. 
\p Azọkwọlẹ ni nị m rị ngan! 
\p Ọhụnma Osolobuẹ mẹ ya nọyeni ụnụ.