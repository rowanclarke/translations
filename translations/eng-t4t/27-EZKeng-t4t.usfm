\v 11 \w I|strong="H3588"\w* \w will|strong="H3068"\w* \w also|strong="H3068"\w* \w punish|strong="H6213"\w* \add the people of \add* \w Moab|strong="H4124"\w*. \w When|strong="H3588"\w* \w that|strong="H3588"\w* \w happens|strong="H6213"\w*, \w they|strong="H3588"\w* \w will|strong="H3068"\w* \w know|strong="H3045"\w* \w that|strong="H3588"\w* \w I|strong="H3588"\w*, \w Yahweh|strong="H3068"\w*, \add have the power to do what I say that I will do\add*.”   
\s1 A prophecy about the people of Edom  
\p
\v 12 \w This|strong="H6213"\w* \w is|strong="H1004"\w* \add also\add* \w what|strong="H6213"\w* \w Yahweh|strong="H3068"\w* \w the|strong="H3069"\w* \w Lord|strong="H3069"\w* \w says|strong="H3541"\w*: “\add You people of\add* Edom \w are|strong="H1004"\w* guilty \w of|strong="H1004"\w* getting \w revenge|strong="H5358"\w* \w on|strong="H1004"\w* \w the|strong="H3069"\w* people [MTY] \w of|strong="H1004"\w* \w Judah|strong="H3063"\w*.  
\v 13 \w Therefore|strong="H3651"\w* \w this|strong="H3651"\w* \w is|strong="H3027"\w* \w what|strong="H3541"\w* \add I\add*, \w Yahweh|strong="H3068"\w* \w the|strong="H5921"\w* \w Lord|strong="H3069"\w*, say: '\w I|strong="H5414"\w* \w will|strong="H2719"\w* use \w my|strong="H5414"\w* \w power|strong="H3027"\w* \w against|strong="H5921"\w* \add the people of\add* Edom \w and|strong="H3027"\w* \w will|strong="H2719"\w* \w get|strong="H3027"\w* rid \w of|strong="H3027"\w* \w their|strong="H5414"\w* \w men|strong="H3772"\w* \w and|strong="H3027"\w* \w their|strong="H5414"\w* animals. \w I|strong="H5414"\w* \w will|strong="H2719"\w* \w ruin|strong="H2723"\w* \w the|strong="H5921"\w* land \w from|strong="H4480"\w* \w Teman|strong="H8487"\w* \add region in central Edom\add* \w to|strong="H5921"\w* \w Dedan|strong="H1719"\w* \add region in the south of Edom\add*, \w and|strong="H3027"\w* many \w of|strong="H3027"\w* \w their|strong="H5414"\w* \w men|strong="H3772"\w* \w will|strong="H2719"\w* \w be|strong="H3027"\w* \w killed|strong="H2719"\w* \w by|strong="H3027"\w*\add their enemies\add* \w swords|strong="H2719"\w*.'  
\v 14 \w The|strong="H5002"\w* Israeli \w people|strong="H5971"\w* \w will|strong="H5971"\w* \w use|strong="H6213"\w* \w their|strong="H5414"\w* \w power|strong="H3027"\w* [MTY] \w to|strong="H3478"\w* \w get|strong="H3027"\w* \w revenge|strong="H5360"\w* \w on|strong="H3027"\w* \add the people of\add* Edom. \w They|strong="H5971"\w* \w will|strong="H5971"\w* \w show|strong="H6213"\w* \add the people of\add* Edom \w that|strong="H3045"\w* \w I|strong="H5414"\w* \w have|strong="H5971"\w* \w been|strong="H5971"\w* \w angry|strong="H2534"\w* \w with|strong="H6213"\w* \w them|strong="H5414"\w*, \w and|strong="H3478"\w* \w I|strong="H5414"\w* \w will|strong="H5971"\w* \w punish|strong="H6213"\w* [MTY] \w them|strong="H5414"\w*. \w The|strong="H5002"\w* \w people|strong="H5971"\w* \w of|strong="H3027"\w* Edom \w will|strong="H5971"\w* \w experience|strong="H3045"\w* \w my|strong="H5414"\w* getting \w revenge|strong="H5360"\w* \w on|strong="H3027"\w* \w them|strong="H5414"\w*. \w Then|strong="H5414"\w* \w they|strong="H5971"\w* \w will|strong="H5971"\w* \w know|strong="H3045"\w* \w that|strong="H3045"\w* \w I|strong="H5414"\w*, \w Yahweh|strong="H3068"\w* \w the|strong="H5002"\w* \w Lord|strong="H3069"\w*, \add have the power to do what I say that I will do\add*.”   
\s1 A prophecy about the people of Philistia  
\p
\v 15 \w This|strong="H6213"\w* \w is|strong="H5315"\w* \add also\add* \w what|strong="H6213"\w* \w Yahweh|strong="H3068"\w* \w the|strong="H3069"\w* \w Lord|strong="H3069"\w* \w says|strong="H3541"\w*: “\w The|strong="H3069"\w* Philistia people-group wanted \w very|strong="H6213"\w* \w much|strong="H6213"\w* \w to|strong="H6213"\w* \w get|strong="H6213"\w* \w revenge|strong="H5360"\w* \add on the people of Judah\add*. \w They|strong="H3282"\w* \w very|strong="H6213"\w* maliciously wanted \w to|strong="H6213"\w* \w destroy|strong="H4889"\w* \add Judah\add*.  
\v 16 \w Therefore|strong="H3651"\w* \w this|strong="H3651"\w* \w is|strong="H3027"\w* \w what|strong="H3541"\w* \w I|strong="H2005"\w*, \w Yahweh|strong="H3068"\w* \w the|strong="H5921"\w* \w Lord|strong="H3069"\w*, say: \w I|strong="H2005"\w* \w am|strong="H2005"\w* \w about|strong="H5921"\w* \w to|strong="H5921"\w* use \w my|strong="H5921"\w* \w power|strong="H3027"\w* [MTY] \w against|strong="H5921"\w* \w the|strong="H5921"\w* Philistia people. \w I|strong="H2005"\w* \w will|strong="H3027"\w* \w get|strong="H3027"\w* rid \w of|strong="H3027"\w* \w the|strong="H5921"\w* Kereth people-group \w and|strong="H3027"\w* \w all|strong="H3772"\w* \add those who live along\add* \w the|strong="H5921"\w* \w coast|strong="H3027"\w* \w of|strong="H3027"\w* \w the|strong="H5921"\w* \add Mediterranean\add* \w Sea|strong="H3220"\w*.  
\v 17 \w By|strong="H3068"\w* \w the|strong="H3588"\w* way \w I|strong="H3588"\w* \w punish|strong="H6213"\w* \w them|strong="H5414"\w*, \w I|strong="H3588"\w* \w will|strong="H3068"\w* \w get|strong="H6213"\w* \w great|strong="H1419"\w* \w revenge|strong="H5360"\w* \w on|strong="H3068"\w* \w them|strong="H5414"\w* \w and|strong="H3068"\w* \w show|strong="H6213"\w* \w that|strong="H3588"\w* \w I|strong="H3588"\w* \w am|strong="H3068"\w* \w angry|strong="H2534"\w* \w with|strong="H3068"\w* \w them|strong="H5414"\w*. \w And|strong="H3068"\w* \w when|strong="H3588"\w* \w I|strong="H3588"\w* \w get|strong="H6213"\w* \w revenge|strong="H5360"\w* \w on|strong="H3068"\w* \w them|strong="H5414"\w*, \w they|strong="H3588"\w* \w will|strong="H3068"\w* \w know|strong="H3045"\w* \w that|strong="H3588"\w* \w I|strong="H3588"\w*, \w Yahweh|strong="H3068"\w* \w the|strong="H3588"\w* \w Lord|strong="H3068"\w*, \add have the power to do what I say that I will do\add*.' ”   
\c 26  
\s1 A prophecy about the people of Tyre  
\p
\v 1 Almost \w twelve|strong="H6240"\w* \w years|strong="H8141"\w*\add after we had been taken to Babylonia\add*, \w on|strong="H3068"\w* \w the|strong="H3068"\w* first \w day|strong="H2320"\w* \w of|strong="H3068"\w* \w the|strong="H3068"\w* \w month|strong="H2320"\w*, \w Yahweh|strong="H3068"\w* \w gave|strong="H1961"\w* \w me|strong="H1697"\w* \w another|strong="H2320"\w* \w message|strong="H1697"\w*. \w He|strong="H3068"\w* \w said|strong="H1697"\w* \w to|strong="H3068"\w* \w me|strong="H1697"\w*,  
\v 2 “\w You|strong="H5921"\w* human, \add the people of\add* \w Tyre|strong="H6865"\w* \add city\add* shouted joyfully \w and|strong="H1121"\w* said \w about|strong="H5437"\w* \w Jerusalem|strong="H3389"\w*, ‘\add Jerusalem,\add* \w the|strong="H5921"\w* city \w from|strong="H5921"\w* \w which|strong="H5971"\w* many traders/merchants \w went|strong="H5971"\w* \w to|strong="H5921"\w* many \w nations|strong="H5971"\w*, \w is|strong="H1121"\w* \w now|strong="H5921"\w* \w destroyed|strong="H7665"\w*. \w And|strong="H1121"\w* \w now|strong="H5921"\w* \w people|strong="H5971"\w* \w from|strong="H5921"\w* \w all|strong="H5921"\w* \w over|strong="H5921"\w* \w the|strong="H5921"\w* world \w will|strong="H5971"\w* \w come|strong="H5971"\w* \w to|strong="H5921"\w* \w us|strong="H5921"\w* \w to|strong="H5921"\w* buy \w and|strong="H1121"\w* sell things. \w Because|strong="H5921"\w* \w Jerusalem|strong="H3389"\w* \w has|strong="H3389"\w* \w now|strong="H5921"\w* \w been|strong="H5971"\w* \w ruined|strong="H2717"\w*, \w we|strong="H3068"\w* \w will|strong="H5971"\w* prosper!’  
\v 3 \w Therefore|strong="H3651"\w*, \w this|strong="H3651"\w* \w is|strong="H3651"\w* \w what|strong="H3541"\w* \add I,\add* \w Yahweh|strong="H3068"\w* \w the|strong="H5921"\w* \w Lord|strong="H3069"\w*, say: ‘\w I|strong="H2005"\w* \w am|strong="H2005"\w* \w now|strong="H2005"\w* \w the|strong="H5921"\w* enemy \w of|strong="H5921"\w* \add you people of\add* \w Tyre|strong="H6865"\w*. \w I|strong="H2005"\w* \w will|strong="H1471"\w* \w cause|strong="H3651"\w*\add the armies of\add* \w many|strong="H7227"\w* \w nations|strong="H1471"\w* \w to|strong="H5927"\w* \w come|strong="H5927"\w* \w and|strong="H1471"\w* \w attack|strong="H5927"\w* \w your|strong="H5921"\w* \add city\add*, \w like|strong="H3651"\w* \w the|strong="H5921"\w* \w waves|strong="H1530"\w* \w of|strong="H5921"\w* \w the|strong="H5921"\w* \w sea|strong="H3220"\w* beat \w against|strong="H5921"\w* \w the|strong="H5921"\w* shores.  
\v 4 \w Their|strong="H5414"\w* soldiers \w will|strong="H5414"\w* \w destroy|strong="H7843"\w* \w the|strong="H5414"\w* \w walls|strong="H2346"\w* around \w Tyre|strong="H6865"\w* \w and|strong="H6083"\w* \w tear|strong="H2040"\w* \w down|strong="H2040"\w* \w its|strong="H5414"\w* \w towers|strong="H4026"\w*. \w Tyre|strong="H6865"\w* \w will|strong="H5414"\w* become \w a|strong="H3068"\w* \w place|strong="H5414"\w* \w where|strong="H4480"\w* people \w from|strong="H4480"\w* many nations steal valuable things, \add and then the city will be completely destroyed\add*. \w Then|strong="H5414"\w* \w they|strong="H5414"\w* \w will|strong="H5414"\w* \w scrape|strong="H5500"\w* \w away|strong="H4480"\w* \w the|strong="H5414"\w* \w rubble|strong="H6083"\w* \w and|strong="H6083"\w* \w cause|strong="H5414"\w* \w the|strong="H5414"\w* city \w to|strong="H5414"\w* become \w a|strong="H3068"\w* \w bare|strong="H6706"\w* \w rock|strong="H5553"\w*.  
\v 5 \w Out|strong="H8432"\w* \w in|strong="H8432"\w* \w the|strong="H5002"\w* \w sea|strong="H3220"\w*, Tyre \w will|strong="H1961"\w* \w become|strong="H1961"\w* \w an|strong="H1961"\w* island where \w men|strong="H3220"\w* \w spread|strong="H4894"\w* \add their fishing\add* \w nets|strong="H2764"\w* \w to|strong="H1696"\w* dry \w them|strong="H8432"\w*. \add That will surely happen because\add* \w I|strong="H3588"\w*, \w Yahweh|strong="H3068"\w* \w the|strong="H5002"\w* \w Lord|strong="H3069"\w*, \w have|strong="H1961"\w* \w predicted|strong="H1696"\w* \w it|strong="H3588"\w*.  
\v 6 \w The|strong="H3588"\w* \w people|strong="H3045"\w* \w in|strong="H3068"\w* small \w villages|strong="H1323"\w* \w on|strong="H3068"\w* \w the|strong="H3588"\w* coast near Tyre \w will|strong="H3068"\w* \w be|strong="H3068"\w* \w killed|strong="H2026"\w* \w by|strong="H3068"\w*\add their enemies’\add* \w swords|strong="H2719"\w*. \w Then|strong="H3045"\w* \w people|strong="H3045"\w* \w will|strong="H3068"\w* \w know|strong="H3045"\w* \w that|strong="H3588"\w* \w I|strong="H3588"\w*, \w Yahweh|strong="H3068"\w*, \add have the power to do what I say that I will do\add*.’   
\p
\v 7 \w This|strong="H3541"\w* \w is|strong="H4428"\w* \w what|strong="H3541"\w* \w I|strong="H3588"\w*, \w Yahweh|strong="H3068"\w* \w the|strong="H3588"\w* \w Lord|strong="H3069"\w*, say\add is going to happen\add*: ‘\w From|strong="H5971"\w* \w the|strong="H3588"\w* \w north|strong="H6828"\w*, \w I|strong="H3588"\w* \w am|strong="H2005"\w* \w going|strong="H2005"\w* \w to|strong="H4428"\w* bring \w the|strong="H3588"\w* \w most|strong="H4428"\w* \w powerful|strong="H7227"\w* \w king|strong="H4428"\w* \add in the world\add*, \w King|strong="H4428"\w* \w Nebuchadnezzar|strong="H5019"\w* \w of|strong="H4428"\w* Babylon, \add with his army\add* \w to|strong="H4428"\w* attack \w Tyre|strong="H6865"\w*. \w They|strong="H3588"\w* \w will|strong="H4428"\w* bring \w horses|strong="H5483"\w* \w and|strong="H4428"\w* \w chariots|strong="H7393"\w*, \w and|strong="H4428"\w* \w men|strong="H5971"\w* \w who|strong="H5971"\w* ride \w the|strong="H3588"\w* \w horses|strong="H5483"\w* \add and men who drive the chariots\add*; \w it|strong="H3588"\w* \w will|strong="H4428"\w* \w be|strong="H4428"\w* \w a|strong="H3068"\w* \w huge|strong="H7227"\w* \w army|strong="H5971"\w*.  
\v 8  \add In the battles in the small villages\add* \w on|strong="H5921"\w* \w the|strong="H5921"\w* coast, \w their|strong="H5414"\w* soldiers \w will|strong="H2719"\w* \w kill|strong="H2026"\w* \add many\add* people \w with|strong="H5921"\w* \w their|strong="H5414"\w* \w swords|strong="H2719"\w*. \add Then\add* \w they|strong="H5921"\w* \w will|strong="H2719"\w* \w set|strong="H5414"\w* \w up|strong="H6965"\w* devices \w to|strong="H5921"\w* batter \w the|strong="H5921"\w* \w wall|strong="H1785"\w* \w around|strong="H5921"\w* \w the|strong="H5921"\w* city \w of|strong="H1323"\w* Tyre, \w and|strong="H6965"\w* \w they|strong="H5921"\w* \w will|strong="H2719"\w* \w build|strong="H6965"\w* \w a|strong="H3068"\w* dirt \w ramp|strong="H5550"\w* \w up|strong="H6965"\w* \w to|strong="H5921"\w* \w the|strong="H5921"\w* \w top|strong="H5921"\w* \w of|strong="H1323"\w* \w the|strong="H5921"\w* \w wall|strong="H1785"\w*, \w and|strong="H6965"\w* \w they|strong="H5921"\w* \w will|strong="H2719"\w* \w all|strong="H5414"\w* \w hold|strong="H6965"\w* \w up|strong="H6965"\w* \w shields|strong="H6793"\w* \add to protect themselves from arrows being shot from the ground\add*.  
\v 9 \w The|strong="H5414"\w* king \w will|strong="H2719"\w* \w direct|strong="H5414"\w* \w the|strong="H5414"\w* soldiers who operate \w the|strong="H5414"\w* ◄\w rams|strong="H6904"\w*/things► \w to|strong="H5414"\w* batter \w the|strong="H5414"\w* \w walls|strong="H2346"\w*, \w and|strong="H2719"\w* who \w will|strong="H2719"\w* use \w their|strong="H5414"\w* iron bars \w to|strong="H5414"\w* \w tear|strong="H5422"\w* \w down|strong="H5422"\w* \w the|strong="H5414"\w* \w towers|strong="H4026"\w* \w in|strong="H5414"\w* \w the|strong="H5414"\w* \w wall|strong="H2346"\w*.  
\v 10 \w The|strong="H3680"\w* king \w will|strong="H5892"\w* \w have|strong="H5892"\w* \w a|strong="H3068"\w* huge number \w of|strong="H5892"\w* \w horses|strong="H5483"\w*, \w and|strong="H6963"\w*\add the stamping of their hooves will result in\add* \w the|strong="H3680"\w* \w city|strong="H5892"\w* being \w covered|strong="H3680"\w* \w with|strong="H5892"\w* \w dust|strong="H1534"\w*. \add It will be as though\add* \w the|strong="H3680"\w* \w walls|strong="H2346"\w* \w will|strong="H5892"\w* \w tremble|strong="H7493"\w* because \w of|strong="H5892"\w* \w the|strong="H3680"\w* \w noise|strong="H6963"\w* \w made|strong="H3680"\w* \w by|strong="H5892"\w* \w the|strong="H3680"\w* \w horses|strong="H5483"\w*, \w the|strong="H3680"\w* \add supply\add* \w wagons|strong="H1534"\w*, \w and|strong="H6963"\w* \w the|strong="H3680"\w* \w chariots|strong="H7393"\w* \w when|strong="H6963"\w* \w they|strong="H8179"\w* \w enter|strong="H3996"\w* \w the|strong="H3680"\w* \w city|strong="H5892"\w* where \w the|strong="H3680"\w* \w walls|strong="H2346"\w* \w have|strong="H5892"\w* been \w broken|strong="H1234"\w* \w down|strong="H3996"\w*.  
\v 11 \w The|strong="H3605"\w* \w horses|strong="H5483"\w* \w will|strong="H5971"\w* \w trample|strong="H7429"\w* \w all|strong="H3605"\w* \w of|strong="H5971"\w* \w the|strong="H3605"\w* \w streets|strong="H2351"\w*\add of the city\add* \w with|strong="H3381"\w* \w their|strong="H3605"\w* \w hooves|strong="H6541"\w*. \w The|strong="H3605"\w* \w soldiers|strong="H5971"\w* \w will|strong="H5971"\w* \w kill|strong="H2026"\w* \w the|strong="H3605"\w* \w people|strong="H5971"\w* \w with|strong="H3381"\w* \w their|strong="H3605"\w* \w swords|strong="H2719"\w*; \w and|strong="H5971"\w* \w they|strong="H5971"\w* \w will|strong="H5971"\w* \w cause|strong="H5971"\w* \w your|strong="H3605"\w* \w strong|strong="H5797"\w* \w pillars|strong="H4676"\w* \w to|strong="H3381"\w* ◄\w collapse|strong="H3381"\w*/\w fall|strong="H3381"\w* \w to|strong="H3381"\w* \w the|strong="H3605"\w* ground►.  
\v 12 \w They|strong="H7997"\w* \w will|strong="H1004"\w* \w take|strong="H7760"\w* away all \w the|strong="H8432"\w* people’s \w valuable|strong="H2532"\w* \w possessions|strong="H2532"\w* \w and|strong="H1004"\w* steal \w the|strong="H8432"\w* \w things|strong="H2532"\w* \w that|strong="H4325"\w* \w the|strong="H8432"\w* merchants sell. \w They|strong="H7997"\w* \w will|strong="H1004"\w* \w tear|strong="H2040"\w* \w down|strong="H5422"\w* \w the|strong="H8432"\w* \w walls|strong="H2346"\w* \w of|strong="H1004"\w* \w the|strong="H8432"\w* \w houses|strong="H1004"\w* \w and|strong="H1004"\w* \w destroy|strong="H5422"\w* \w their|strong="H7760"\w* fine \w houses|strong="H1004"\w*. \w Then|strong="H7760"\w* \w they|strong="H7997"\w* \w will|strong="H1004"\w* \w throw|strong="H7760"\w* \w into|strong="H8432"\w* \w the|strong="H8432"\w* sea \w the|strong="H8432"\w* stones \add from the walls\add* \w of|strong="H1004"\w* those \w houses|strong="H1004"\w* \w and|strong="H1004"\w* \w the|strong="H8432"\w* \w timber|strong="H6086"\w* \w and|strong="H1004"\w* \w the|strong="H8432"\w* \w rubble|strong="H6083"\w*.  
\v 13 \w No|strong="H3808"\w* \w longer|strong="H5750"\w* \w will|strong="H3808"\w* \w you|strong="H3808"\w* \w sing|strong="H7892"\w* \w noisy|strong="H1995"\w* \w songs|strong="H7892"\w*, \w and|strong="H6963"\w* \w people|strong="H1995"\w* \w will|strong="H3808"\w* \w not|strong="H3808"\w* play \w their|strong="H8085"\w* \w harps|strong="H3658"\w* \w any|strong="H5750"\w* \w more|strong="H5750"\w*.  
\v 14 \w The|strong="H5002"\w* enemy \w soldiers|strong="H5750"\w* \w will|strong="H3068"\w* \w cause|strong="H5414"\w* \w the|strong="H5002"\w* city \w to|strong="H1696"\w* \w become|strong="H1961"\w* \w a|strong="H3068"\w* \w bare|strong="H6706"\w* \w rock|strong="H5553"\w* \w and|strong="H3068"\w* \add only\add* \w a|strong="H3068"\w* \w place|strong="H5414"\w* \w where|strong="H3808"\w* men \w spread|strong="H5414"\w* \add their fishing\add* \w nets|strong="H2764"\w*. \w And|strong="H3068"\w* \w the|strong="H5002"\w* city \w will|strong="H3068"\w* \w never|strong="H3808"\w* \w be|strong="H1961"\w* \w rebuilt|strong="H1129"\w*. \add Those things will surely happen\add* \w because|strong="H3588"\w* \add I\add*, \w Yahweh|strong="H3068"\w* \w the|strong="H5002"\w* \w Lord|strong="H3068"\w*, \w have|strong="H1961"\w* \w declared|strong="H1696"\w*\add that they will happen\add*.’   
