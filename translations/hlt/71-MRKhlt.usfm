\v 6 \w Tedae|strong="G1161"\w* \w cadaek|strong="G1122"\w* \w khuikah|strong="G3588"\w* \w hlangvang|strong="G5100"\w* \w aka \w*\w om|strong="G2258"\w* \w rhoek \w* \w tah\w* \w pahoi|strong="G1563"\w* \w ngol|strong="G2521"\w* \w uh \w* \w tih|strong="G2532"\w* \w a|strong="G0846"\w* \w thinko|strong="G2588"\w* \w khuikah|strong="G1722"\w*,  
\v 7 “ \w Balae|strong="G5101"\w* \w tih \w* \w anih|strong="G3778"\w* \w hetla|strong="G3779"\w* \w a\w* \w cal|strong="G2980"\w*, \w a\w* \w soehsal|strong="G0987"\w* \w coeng\w* \w he \w*\w ta. \w*\w Pathen|strong="G2316"\w* \w pakhat|strong="G1520"\w* \w long|strong="G3588"\w* \w pawt|strong="G3361"\w* \w atah|strong="G1487"\w* \w tholhnah|strong="G0266"\w* \w aka \w*\w hlah|strong="G0863"\w* \w thai|strong="G1410"\w* \w te \w* \w unim|strong="G5101"\w*\w ?\w*” \w tila \w* \w a\w* \w poek|strong="G1260"\w* \w uh\w*.  
\v 8 \w A|strong="G1438"\w* \w khuiah|strong="G1722"\w* te \w tla|strong="G3779"\w* \w a \w*\w poek|strong="G1260"\w* \w uh \w* \w te|strong="G3754"\w* \w Jesuh|strong="G2424"\w* \w loh|strong="G3588"\w* \w a|strong="G0846"\w* \w mueihla|strong="G4151"\w* \w neh|strong="G3588"\w* \w tlek|strong="G2117"\w* a \w ming|strong="G1921"\w*. Te dongah \w amih|strong="G0846"\w* te, \wj “ \+w Balae|strong="G5101"\+w* tih \+w na|strong="G5216"\+w* \+w thinko|strong="G2588"\+w* \+w ah|strong="G1722"\+w* \+w he|strong="G5023"\+w* \+w he\+w* \+w na \+w* \+w poek|strong="G1260"\+w* uh?\wj*”  
\v 9 \wj \+w Aka\+w* \+w khawn|strong="G3885"\+w* \+w te|strong="G3588"\+w*\wj*, ‘\wj \+w Tholhnah|strong="G0266"\+w* \+w loh|strong="G3588"\+w* \+w nang|strong="G4675"\+w* \+w n'hlah\+w* \+w coeng\+w* \wj*, ‘\wj \+w ti|strong="G2036"\+w* nah ham \+w neh|strong="G2228"\+w*\wj*, ‘\wj \+w Thoo|strong="G1453"\+w* \+w lamtah|strong="G2532"\+w* \+w na|strong="G4675"\+w* \+w phakdoeng|strong="G2895"\+w* \+w te|strong="G3588"\+w* \+w kawt|strong="G0142"\+w* \+w lamtah|strong="G2532"\+w* \+w cet|strong="G4043"\+w*\wj*, ‘\wj \+w ti|strong="G2036"\+w* nah ham te \+w melae|strong="G5101"\+w* \+w yoeikoek|strong="G2123"\+w*la aka \+w om|strong="G2076"\+w*?\wj*  
