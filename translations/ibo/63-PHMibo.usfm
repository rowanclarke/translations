\id PHM - Biblica® Open Igbo Contemporary Bible 2020 
\h Fịlịmọn 
\toc1 Fịlịmọn 
\toc2 Fịlịmọn 
\toc3 Fịl 
\mt1 Fịlịmọn 
\c 1  
\p  
\v 1 Pọl, onye e tinyere nʼụlọ mkpọrọ nʼihi Kraịst Jisọs na site nʼaka nwanna anyị Timoti, 
\b  
\p Anyị na-edetara gị ya ezi enyi anyị na onye anyị na ya na-arụkọ ọrụ, Fịlịmọn.  
\v 2 Anyị na-edetakwara ya nzukọ Kraịst dị nʼụlọ gị, na nwanna anyị nwanyị Afịa, na Akipos onye anyị na ya so na-alụ agha a. 
\b  
\p  
\v 3 Ka amara na udo nke sitere na Chineke bụ Nna, na Kraịst Jisọs Onyenwe anyị dịrị unu. 
\b  
\s1 Ekele na ekpere 
\p  
\v 4 Ana m ekele Chineke ekele mgbe ọbụla m na-echeta gị nʼekpere niile m na-ekpe.  
\v 5 Nʼihi na ana m anụ ihe banyere okwukwe i nwere nʼime Onyenwe anyị Jisọs, na ịhụnanya i na-egosi ndị nsọ niile.  
\v 6 Ekpere m na-ekpe banyere gị bụ ka mmekọrịta anyị na gị dịka ndị kwere ekwe, mee ka ị matazuo ihe ọma niile anyị nwere nʼime Kraịst.  
\v 7 Ịhụnanya gị na-enye m oke ọṅụ na ịgbaume, ezi nwanna m, nʼihi na emeela ka ndị nsọ nwee ume ọhụrụ site nʼinyeaka gị. 
\s1 Arịrịọ Pọl nʼisi Onisimọs 
\p  
\v 8 Ọ bụ ezie na-enwere m ike nʼime Kraịst inye gị iwu banyere ihe kwesiri ka i mee, ma agaghị m eme otu a.  
\v 9 Kama, ọ kaara m mma site na ndabere nke ịhụnanya, ịrịọ gị ya dị ka arịrịọ. Ee, ọ bụ mụ Pọl, agadi nwoke ahụ na onye mkpọrọ nʼihi Kraịst Jisọs na-arịọ gị arịrịọ a.  
\v 10 Biko, arịọ m gị nʼisi Onisimọs, onye e mere ka ọ bụrụ nwa m oge m nọ nʼụlọ mkpọrọ.  
\v 11 Na mbụ, o nweghị uru ọbụla ọ baara gị, ma ugbu a, ọ baara mụ na gị uru. 
\p  
\v 12 Ana m ezighachiri gị ya ugbu a, ya bụ, onye bụ obi\f + \fr 1:12 \ft Maọbụ, \fqa onye m weere ka onwe m\f* m ka m na-ezitere gị.  
\v 13 Ọ gụsịrị m agụụ ike ime ka mụ na ya nọdụ nʼebe a, ka o were ọnọdụ gị na-ejere m ozi ọ bụladị dị ka m nọ na mkpọrọ nʼihi oziọma.  
\v 14 Ma, a chọghị m ime ihe ọbụla na-enwetaghị nkwenye gị, ka ọ ghara ịdị ka i mere obiọma gị na mmanye. Kama, achọrọ m ka i mee ihe si gị nʼobi pụta.  
\v 15 Ma eleghị anya, ọ bụ nʼihi nke a ka eji kewapụ ya nwa oge nta site nʼebe ị nọ, bụ ka i mesịa nweghachi ya ebighị ebi.  
\v 16 Ọ bụghịkwa ohu ọzọ, kama ọ karịrị ohu, maka ọ dịka nwanna a hụrụ nʼanya, ọkachasị nʼebe mụ onwe m nọ, ma ọ ga-abụkwara gị karịchasịa, ma nʼanụ ahụ nakwa nʼime Onyenwe anyị. 
\p  
\v 17 Nʼihi nke a, ọ bụrụ na ị gụrụ m dị ka onye nnwekọ ihe, nabata ya dị ka ị ga-esi nabata m.  
\v 18 Biko, ọ bụrụ na o mejọrọ gị nʼụzọ ọbụla, ọ bụrụkwa na o ji ụgwọ ọbụla, gụọ ya dị ka ụgwọ m ji gị.  
\v 19 Mụ bụ Pọl ji aka m dee nke a; aga m akwụghachi gị. Ọ bakwaghị uru ichetara gị ụgwọ i ji m. Nʼihi na ụgwọ i ji m bụ gị onwe gị.  
\v 20 Nwanna m, mere m ihe a m na-arịọ gị nʼihi Onyenwe anyị. Mekwa ka obi m dị ọhụrụ nʼime Kraịst.  
\v 21 Olileanya m siri m ike na ị ga-aṅa m ntị, ana m edere gị akwụkwọ a, na ị ga-eme, ma karịakwa ka m rịọrọ. 
\p  
\v 22 Ihe ọzọkwa, bụ na m chọrọ ka ị kwadoro m ọnụụlọ ebe m ga-anọ dị ka ọbịa ma m bịa, maka enwere m olileanya na a ga-aza ekpere unu ime ka m si nʼebe a pụta bịakwute unu. 
\b  
\b  
\p  
\v 23 Epafras, onye mụ na ya nọ nʼụlọ mkpọrọ nʼihi Kraịst Jisọs na-ekele gị. 
\p  
\v 24 Mak, na Arịstakọs, na Dimas, na Luk, ndị mụ na ha na-arụkọ ọrụ na-ekelekwa unu. 
\b  
\p  
\v 25 Ka amara Onyenwe anyị Jisọs Kraịst dịnyere mmụọ unu.