\id LAM
\h إِزْڒَانْ س إِڭجْذُورنْ
\toc1 إِزْڒَانْ س إِڭجْذُورنْ
\toc2 إِزْڒَانْ س إِڭجْذُورنْ
\toc3 إِڭجذ.
\mt1 إِزْڒَانْ س إِڭجْذُورنْ
\c 1
\s1 إِزْڒِي أَمزْوَارُو - خْ ؤُرْشَالِيمْ
\m 
\v 1 \bd أَلِيفْ.\bd* مَامّشْ ثقِّيمْ \add ذِيهَا\add*
\m ثنْذِينْثْ وحّْذسْ!
\m ثُوغَا ڒبْذَا ثشُّورْ س ڒْغَاشِي،
\m ثذْوڒْ أَمْ يِيشْثْ ن ثَاجَّاتْشْ،
\m ثُوغَا-ت ذ ثَامقّْرَانْثْ جَارْ ڒڭْنُوسْ،
\m إِدْجِيسْ ن ؤُجدْجِيذْ جَارْ لْعَامَالَاثْ،
\m ثذْوڒْ غَارْ ثسْمُوغِي.
\b
\m 
\v 2 \bd بِيثْ.\bd* ثتّْرُو إِمطَّاونْ إِمرْزَاڭنْ س دْجِيڒثْ،
\m إِمطَّاونْ نّسْ خْ إِمڭِّيزنْ نّسْ.
\m وَارْ غَارسْ وِي ت غَا إِعزَّانْ
\m زِي مَارَّا إِنِّي ت إِتّخْسنْ،
\m مَارَّا إِمدُّوكَّاڒْ نّسْ غْذَارنْ-ت،
\m ذوْڒنْ أَسْ ذ ڒْعذْيَانْ. \x ◘ \xo 1:‏2 \xt إِزهد. 6‏:‏7\x*
\b
\m 
\v 3 \bd ڭِيملْ.\bd* ثتّْوَاحبّسْ \add ثمُّورْثْ ن\add* يَاهُوذَا زِي سِّيبّثْ ن ڒغْبنْ،
\m ؤُ زِي سِّيبّثْ ن ڒْقدّْ
\m ن ثْخمَّاسْثْ نّسْ إِقسْحنْ.
\m ثتّْغِيمَا جَارْ ڒڭْنُوسْ، وَارْ ثُوفِي أَرَّاحثْ،
\m مَارَّا إِنِّي ت إِضَافَّارنْ حَارّْثنْ خَاسْ
\m ذِي ڒْوسْطْ ن ڒحْصَارَاثْ نّسْ.
\b
\m 
\v 4 \bd ذَالِيثْ.\bd* إِبْرِيذنْ غَارْ صِيهْيُونْ شضْننْ،
\m مِينْزِي ؤُڒَا ذ إِجّْ وَارْ إِڭُّورْ \add عَاذْ\add* غَارْ ڒْعِيذْ.
\m مَارَّا ثِيوُّورَا نّسْ خْڒَانْثْ،
\m إِكهَّاننْ نّسْ زهَّارنْ،
\m ثِيعْزَارِييِّينْ نّسْ شضْننْثْ،
\m ؤُشَا نتَّاثْ سِيمَانْثْ نّسْ ثشُّورْ س ثَارْزُوڭِي.
\b
\m 
\v 5 \bd هِي.\bd* إِغْرِيمنْ نّسْ ذوْڒنْ حكّْمنْ \add خَاسْ\add*،
\m ڒْعذْيَانْ نّسْ فَارّْحنْ،
\m مَاغَارْ سِيذِي إِسّشْضنْ إِ-ت
\m زِي سِّيبّثْ ن ڒْقدّْ ن ڒْمُوعْصِييّثْ نّسْ.
\m إِحنْجِيرنْ نّسْ إِمژْيَاننْ ؤُيُورنْ ذِي ثْمحْبَاسْثْ
\m زَّاثْ إِ ثِيطَّاوِينْ ن إِغْرِيمنْ نْسنْ.
\b
\m 
\v 6 \bd وَاوْ.\bd* أَشوَّارْ ن يدْجِيسْ ن صِيهْيُونْ
\m إِنْڭزْ زَّايسْ،
\m مَارَّا ڒْحُوكَّامْ نّسْ ڭِّينْ أَمْ ؤُذَاذنْ
\m إِنِّي وَارْ إِتِّيفنْ دّمْنثْ ن ثَاروْسَا.
\m ڭُّورنْ نِيثْنِي بْڒَا جّهْذْ
\m زَّاثْ إِ ثِيطَّاوِينْ ن ونِّي ثنْ إِضَافَّارنْ.
\b
\m 
\v 7 \bd زَايِينْ.\bd* ذڭْ وُوسَّانْ ن ڒغْبنْ نّسْ
\m ؤُ ذڭْ وَاطَّاسْ ن وثْلَاعْ نّسْ
\m أَذْ ثعْقڒْ ؤُرْشَالِيمْ خْ مَارَّا مِينْ ذَايسْ إِغْڒَانْ،
\m مِينْ غَارسْ ثُوغَا زِيشْ.
\m ڒَْامِي إِوْضَا ڒْڭنْسْ نّسْ س ؤُفُوسْ ن وغْرِيمْ،
\m ثُوغَا وَارْ ذِينْ وِي ذ أَسْ إِ غَا إِوْشنْ أَفُوسْ.
\m إِغْرِيمنْ نّسْ ژْرِينْ ت،
\m سْثهْزَانْ زڭْ ؤُردّدْجْ نّسْ.
\b
\m 
\v 8 \bd خِيثْ.\bd* ؤُرْشَالِيمْ ثُوغَا ثْخطَّا أَطَّاسْ.
\m خْ ؤُيَا ثذْوڒْ أَمْ يِيشْثْ ن ثمْغَارْثْ
\m ذڭْ \add وُوسَّانْ ن\add* وعْزَاڒْ نّسْ.
\m مَارَّا إِنِّي ثُوغَا ت إِتّْوقَّارنْ،
\m سّحْقَارَانْ ت،
\m مِينْزِي ژْرِينْ ڒحْيَا نّسْ.
\m ؤُڒَا نتَّاثْ سِيمَانْثْ نّسْ ثْزهَّارْ،
\m ثذْوڒْ غَارْ ضفَّارْ. \x ◘ \xo 1:‏8 \xt إِشا. 47‏:‏3\x*
\b
\m 
\v 9 \bd ثِيث.\bd* ثَاخْمُوجِي نّسْ \add ثڒْصقْ\add*
\m غَارْ ثْمُووَّا \add ن ؤُبحْرُورْ\add* نّسْ،
\m أَنڭَّارُو نّسْ وَارْ ذَايسْ ثْخمّْ.
\m أَقَا ثهْوَا-د غَارْ ڒَادْجَاغْ
\m س إِجّْ ن وبْرِيذْ إِسّْثبْهْثنْ،
\m ؤُڒَا ذ إِجّْ وَارْ ت إِعزِّي.
\m خْزَارْ مَاشَا ڒغْبنْ إِنُو، \add أَ\add* سِيذِي،
\m مَاغَارْ ڒعْذُو إِسّْمقَّارْ إِخفْ نّسْ. \x ◘ \xo 1:‏9 \xt أَعَوذ. 32‏:‏29\x*
\b
\m 
\v 10 \bd يُوذْ.\bd* أَغْرِيمْ إِسّْوِيژّضْ أَفُوسْ نّسْ
\m غَارْ مَارَّا مِينْ ذَايسْ إِغْڒَانْ.
\m إِوَا ثژْرَا نتَّاثْ مَامّشْ ؤُذْفنْ ڒڭْنُوسْ
\m غَارْ زَّاوشْثْ نّسْ إِقدّْسنْ،
\m \add ڒڭْنُوسْ\add* مِينْ خفْ ثُومُورذْ،
\m وَارْ إِعدّڒْ أَذْ د-أَذْفنْ
\m غَارْ وڭْرَاوْ \add ن ڒْڭنْسْ\add* نّشْ.
\b
\m 
\v 11 \bd كَافْ.\bd* قَاعْ إِمزْذَاغْ نّسْ زهَّارنْ،
\m أَرزُّونْ أَغْرُومْ.
\m نِيثْنِي وْشِينْ ڒقْشُوعْ إِغْڒَانْ نْسنْ
\m ذِي طّْوعْ ن مَاشَّا،
\m مَاحنْذْ أَذْ د-أَرّنْ أَسفْسِي غَارْ ڒعْمَارْ نْسنْ.
\m خْزَارْ، \add أَ\add* سِيذِي، وَاڒَا
\m مَامّشْ ذوْڒغْ تّْوَاسّحْقَارغْ. \x ◘ \xo 1:‏11 \xt إِرْم. 52‏:‏6\x*
\b
\m 
\v 12 \bd لَامِيذْ.\bd* مَا وَارْ ذَايْومْ إِشْقِي،
\m كنِّيوْ إِنِّي إِعدُّونْ خْ وبْرِيذْ؟
\m وَاڒَامْ ؤُ خْزَارمْ،
\m مَا \add ذِينْ\add* شَا ن ڒحْرِيقْ أَمْ ڒحْرِيقْ إِ ذ أَيِي إِتّْوَاڭّنْ،
\m إِ زِي ذ أَيِي إِسّْخيّقْ سِيذِي،
\m ذڭْ وَاسّْ ن ڒْحَاذُوقْ ن وغْضَابْ نّسْ.
\b
\m 
\v 13 \bd مِيمْ.\bd* زِي سنّجْ إِ د-إِسّكّْ نتَّا ثِيمسِّي
\m ذڭْ إِغْسَانْ إِنُو،
\m ثْشبَّارْ ذَايْسنْ.
\m نتَّا إِنْضَارْ-د ثْرَاشَّا غَارْ إِضَارنْ إِنُو،
\m يَارَّا أَيِي أَذْ ذوْڒغْ غَارْ ضفَّارْ،
\m أَقَا يَاردّدْجْ أَيِي،
\m إِسّهْڒشْ \add أَيِي\add* أَسّْ أَمْ إِكْمڒْ.
\b
\m 
\v 14 \bd نُونْ.\bd* إِتّْوَاشدّْ ؤُزَايْڒُو ن إِعذِييّنْ إِنُو س
\m ؤُفُوسْ نّسْ،
\m أَقَا تّْوَامُوذنْ، ڭعّْذنْ-د خْ يِيرِي إِنُو.
\m نتَّا يَارَّا جّهْذْ إِنُو أَذْ إِفْشڒْ.
\m إِوْشَا أَيِي سِيذِي إِنُو ذڭْ إِفَاسّنْ نْسنْ،
\m نشّْ وَارْ زمَّارغْ أَذْ بدّغْ \add عَاذْ\add*.
\b
\m 
\v 15 \bd سَامِيخْ.\bd* إِنْضَارْ سِيذِي إِنُو
\m مَارَّا أَيْثْ ن بُو-صُّولْطَا إِنُو ذِي ڒْوسْثْ إِنُو،
\m أَمْ مَامّشْ إِبَارّحْ
\m س إِجّْ ن ؤُمُونِي إِفَارْزنْ ضِيدّْ إِنُو،
\m مَاحنْذْ أَذْ يَارْژْ إِحُوذْرِييّنْ إِنُو،
\m سِيذِي إِنُو أَقَا إِعْفسْ ذِي ثْسِيرْثْ ن ؤُضِيڒْ،
\m ن ثعْزَارشْثْ، ن يدْجِيسْ ن يَاهُوذَا. \x ◘ \xo 1:‏15 \xt إِرْم. 14‏:‏17\x*
\b
\m 
\v 16 \bd عَايِينْ.\bd* س مَانْ أَيَا تّْرُوغْ،
\m \add أَ\add* ثِيطّْ إِنُو، \add أَ\add* ثِيطّْ إِنُو إِسَّازَّاڒنْ إِمطَّاونْ،
\m مِينْزِي أَمسْفوّجْ نِّي إِزمَّارنْ
\m أَذْ د-يَارّْ ڒعْمَارْ إِنُو،
\m إِڭّْوجْ خَافِي.
\m تّْوَاثحَّانْ إِحنْجِيرنْ إِنُو،
\m مِينْزِي ڒعْذُو إِجْهذْ \add خَاسنْ\add*.\x ◘ \xo 1:‏16 \xt إِرْم. 13‏:‏17\x*
\b
\m 
\v 17 \bd بِي.\bd* ثسّْوِيژّضْ صِيهْيُونْ إِفَاسّنْ نّسْ،
\m \add مَاشَا\add* نتَّاثْ وَارْ غَارسْ وِي ت غَا إِسّْفوّْجنْ.
\m يُومُورْ سِيذِي خْ يَاعْقُوبْ،
\m أَقَا إِغْرِيمنْ نّسْ أَذْ أَسْ د-نّْضنْ.
\m ؤُرْشَالِيمْ ثذْوڒْ جَارْ أَسنْ أَمْ يِيشْثْ ن ثمْغَارْثْ
\m \add ذڭْ وُوسَّانْ ن\add* وعْزَاڒْ نّسْ.
\b
\m 
\v 18 \bd ثْسَاذِي.\bd* سِيذِي ذ أَمْسڭّذْ،
\m مَاغَارْ نشّْ ثُوغَاغوّْغغْ خْ ڒُومُورَاثْ نّسْ.
\m سْڒمْ خنِّي، مَارَّا ڒڭْنُوسْ،
\m خْزَارمْ غَارْ ڒهْڒِيقْ إِنُو.
\m ثِيعْزَارِييِّينْ إِنُو ذ إِحُوذْرِييّنْ إِنُو
\m ؤُيُورنْ ذِي ثْمحْبَاسْثْ.\f ◼ \fr 1:‏18 \ft \bd ’خْ ڒُومُورَاثْ نّسْ‘\bd* - س ثْعِيبْرَانِيثْ ’خْ ؤُقمُّومْ نّسْ‘.\f*
\b
\m 
\v 19 \bd قُوفْ.\bd* نشّْ ڒَاغِيغْ خْ يِينِّي ذ أَيِي إِتّخْسنْ،
\m مَاشَا نِيثْنِي شمْثنْ أَيِي.
\m إِكهَّاننْ إِنُو ذ إِمْغَارنْ إِنُو
\m ضڒْقنْ إِ بُوحْبڒْ ذِي ثنْذِينْثْ،
\m ؤُمِي ثُوغَا أَرزُّونْ مَاشَّا إِ يِيخفْ نْسنْ،
\m حِيمَا أَذْ سّْمحْضنْ ڒعْمَارْ نْسنْ. \x ◘ \xo 1:‏19 \xt إِرْم. 30‏:‏14\x*
\b
\m 
\v 20 \bd رِيخْ.\bd* خْزَارْ، \add أَ\add* سِيذِي،
\m مَاغَارْ نشّْ ذِي ڒحْصَارثْ،
\m ثَاكْرِيشْثْ إِنُو ثنّحْوڒْ،
\m ؤُڒْ  إِنُو إِنّقْڒبْ-د زِي ذَاخڒْ إِنُو،
\m مَاغَارْ ثُوغَاغوّْغغْ أَطَّاسْ.
\m ذِي بَارَّا إِ ذ أَيِي يُوشَارْ سِّيفْ إِحنْجِيرنْ إِنُو،
\m ذَاخڒْ \add إِحكّمْ\add* ڒْموْثْ. \x ◘ \xo 1:‏20 \xt إِشا. 16‏:‏11؛ إِرْم. 48‏:‏36\x*
\b
\m 
\v 21 \bd شِينْ.\bd* سْڒِينْ مَامّشْ زهَّارغْ،
\m \add مَاشَا\add* نشّْ وَارْ غَارِي ؤُڒَا ذ إِجّْ ن ؤُمسْفوّجْ،
\m مَارَّا ڒْعذْيَانْ إِنُو سْڒِينْ خْ أَرْژِييّثْ إِنُو.
\m فَارْحنْ أَقَا شكْ إِ ت إِڭِّينْ.
\m خْمِي د غَا ثسِّيوْضذْ أَسّْ إِ زِي د-ثْعڒْمذْ،
\m \add خنِّي\add* أَذْ إِڒِينْ أَمْ مَامّشْ دْجِيغْ نشّْ.
\b
\m 
\v 22 \bd ثَافْ.\bd* أجّْ أَذْ د-يَاسْ مَارَّا ڒْغَارْ نْسنْ زَّاثكْ،
\m أڭّْ زَّايْسنْ أَمْ مَامّشْ زَّايِي ثڭِّيذْ
\m زِي سِّيبّثْ ن مَارَّا إِعذِّيينْ إِنُو،
\m مِينْزِي إِزهَّارنْ إِنُو ذ أَطَّاسْ،
\m ؤُڒْ إِنُو يُوحڒْ أَطَّاسْ.
\b
\b
\c 2
\s1 إِزْڒِي وِيسّْ ثْنَاينْ - لْغَاضَابْ ن سِيذِي
\m 
\v 1 \bd أَلِيفْ.\bd* مَامّشْ إِذْڒَا سِيذِي إِنُو
\m يدْجِيسْ ن صِيهْيُونْ
\m س إِسيْنُوثنْ \add إِبَارْشَاننْ\add*؟
\m أَقَا أَعُودْجِي ن إِسْرَائِيل إِنْضَارْ إِ-ث
\m زڭْ ؤُجنَّا غَارْ ثمُّورْثْ،
\m نتَّا وَارْ إِخَارّصْ ذِي ثْنبْذَاثْ ن إِضَارنْ نّسْ
\m ذڭْ وَاسّْ ن وغْضَابْ نّسْ.
\b
\m 
\v 2 \bd بِيثْ.\bd* إِقْضَا سِيذِي إِنُو
\m خْ مَارَّا ثِيزدَّاغْ ن يَاعْقُوبْ،
\m وَارْ ثنْثْ إِجِّي أَذْ نجْمنْثْ.
\m ذڭْ ؤُذُوقّزْ نّسْ \add ن ؤُفُوڭمْ\add*
\m إِهْذمْ لْقلْعَاثْ ن يدْجِيسْ ن يَاهُوذَا،
\m إِبقّضْ إِ-ثنْثْ خْ ثمُّورْثْ،
\m إِسّْعَارَّا ثَاڭلْذِيثْ ذ ڒْحُوكَّامْ نّسْ.
\b
\m 
\v 3 \bd ڭِيملْ.\bd* ذِي ڒْحَاذُوقْ ن وغْضَابْ نّسْ
\m إِقسّْ قَاعْ إِشّْ ن إِسْرَائِيل.
\m يَارَّا أَفُوسْ أَفُوسِي نّسْ غَارْ ضفَّارْ
\m زَّاثْ إِ ڒعْذُو،
\m ؤُ نتَّا يَارْغَا ضِيدّْ إِ يَاعْقُوبْ
\m أَمْ ثْمسِّي إِتّحْذُوذُوقنْ،
\m ثتّتّْ مَارَّا مِينْ إِ ذ أَسْ د-إِنّْضنْ.
\b
\m 
\v 4 \bd ذَالِيثْ.\bd* نتَّا إِمْحضْ ڒْقوْسْ نّسْ أَمْ ڒعْذُو،
\m إِسّْڭعّذْ أَفُوسِي نّسْ أَمْ ڒعْذُو،
\m ونِّي إِوْثِينْ مَارَّا مِينْ ثمّژْرِي ثِيطّْ.
\m ذڭْ ؤُقِيضُونْ ن يدْجِيسْ ن صِيهْيُونْ
\m إِفَارّغْ أَسْعَارْ نّسْ أَمْ ثْمسِّي.
\b
\m 
\v 5 \bd هِي.\bd* سِيذِي إِنُو إِذْوڒْ أَمْ ڒعْذُو،
\m إِصَارْضْ إِسْرَائِيل،
\m إِصَارْضْ مَارَّا ڒقْصُورْ نّسْ،
\m إِهْذمْ لْقلْعَاثْ نّسْ،
\m ؤُ يَارْنِي \add عَاذْ\add* ذڭْ وشْضَانْ ذ إِغُويَّانْ
\m غَارْ يدْجِيسْ ن يَاهُوذَا.
\b
\m 
\v 6 \bd وَاوْ.\bd* نتَّا إِقْڒعْ س لْعُونْفْ أَعِيشُّو نّسْ،
\m أَمْ إِجّْ ن وحْوِيشْ.
\m يَاريّبْ أَمْشَانْ ن ؤُمْسَاڭَارْ.
\m إِسّتُّو سِيذِي ذِي صِيهْيُونْ
\m أَسّْ ن ڒْعِيذْ ذ أَسّْ ن سّبْثْ،
\m ؤُ ذڭْ وسْخضْ نّسْ
\m إِنْضَارْ أَجدْجِيذْ ذ ؤُكهَّانْ.
\b
\m 
\v 7 \bd زَايِينْ.\bd* إِذْوڒْ سِيذِي إِنُو إِشَارّهْ
\m أَعَالْطَارْ نّسْ،
\m إِنْضَارْ زَّاوشْثْ إِقدّْسنْ نّسْ،
\m إِوْشَا ڒحْيُوضْ ن يخَّامنْ ن ڒقْصَارْ
\m ذڭْ ؤُفُوسْ ن ڒعْذُو.
\m نِيثْنِي ڭِّينْ أَذْ سْڒنْ إِ ثْمِيجَّا نْسنْ
\m ذِي ثَادَّارْثْ ن سِيذِي،
\m أَمْ ذڭْ إِجّْ ن وَاسّْ ن ڒْعِيذْ.
\b
\m 
\v 8 \bd خِيثْ.\bd* سِيذِي إِخَارّصْ أَذْ إِهْذمْ
\m ڒْحِيضْ ن يدْجِيسْ ن صِيهْيُونْ،
\m إِسَارّحْ \add خَاسْ\add* فِيڒُو ن ڒعْبَارْ،
\m وَارْ د-إِجْبِيذْ غَارسْ أَفُوسْ نّسْ زڭْ ؤُصَارْضْ.
\m إِجَّا أَشْبَارْ ن زَّاثْ ذ ڒْحِيضْ أَذْ شضْننْ،
\m أَقَا تّْوَاغضْڒنْ \add جْمِيعْ\add* غَارْ ثمُّورْثْ.
\b
\m 
\v 9 \bd ثِيث.\bd* ثِيوُّورَا نّسْ غَارْقنْثْ ذڭْ ؤُشَاڒْ،
\m إِعُومَاذْ نّسْ ن ؤُبلّعْ يَاردّدْجْ إِ-ثنْ،
\m يَارْژَا إِ-ثنْ.
\m أَجدْجِيذْ نّسْ ذ ڒْحُوكَّامْ نّسْ \add أَقَا أَثنْ\add* جَارْ ڒڭْنُوسْ،
\m وَارْ ذِينْ \add بُو ؤُسڒْمذْ ن\add* شَّارِيعَا،
\m إِنَابِييّنْ نّسْ وَارْ تّطِّيفنْ شَا ڒوْحِييْ ن سِيذِي.
\b
\m 
\v 10 \bd يُوذْ.\bd* إِمْغَارنْ ن يدْجِيسْ ن صِيهْيُونْ
\m قِّيمنْ خْ ثمُّورْثْ، بكْمنْ،
\m زُوزَّارَانْ ؤُشَاڒْ خْ ؤُزدْجِيفْ نْسنْ،
\m بيْسنْ إِخفْ نْسنْ س ثْخُونْشَايْ \add ن وشْضَانْ\add*.
\m ثِيعْزَارِييِّينْ ن ؤُرْشَالِيمْ سَّاضَارنْثْ
\m أَزدْجِيفْ نْسنْثْ غَارْ ثمُّورْثْ.
\b
\m 
\v 11 \bd كَافْ.\bd* ثِيطَّاوِينْ إِنُو ؤُهْڒنْثْ زڭْ إِمطَّاونْ،
\m ثَاكْرِيشْثْ إِنُو ثتّنْهزَّا،
\m ثتّْوَازدْجعْ ثْسَا إِنُو خْ ثمُّورْثْ،
\m خْ ثْرژِّيثْ ن يدْجِيسْ ن ڒْڭنْسْ إِنُو،
\m مِينْزِي أَحنْجِيرْ ذ ؤُسيْمِي
\m تّْغَاشَانْ خْ وَازَّاينْ ن ثنْذِينْثْ.
\b
\m 
\v 12 \bd لَامِيذْ.\bd* نِيثْنِي قَّارنْ إِ يمَّاثْسنْ:
\m ”مَانِي إِدْجَا \add عَاذْ\add* إِمنْذِي ذ بِينُو؟“،
\m خْمِي وطَّانْ خْ وَازَّاينْ ن ثنْذِينْثْ
\m أَمْ يِينِّي إِتّْوَانْغنْ،
\m خْمِي تّْوَاكّْسنْ زِي ثُوذَارْثْ نْسنْ
\m خْ إِفَادّنْ ن يمَّاثْسنْ.
\b
\m 
\v 13 \bd مِيمْ.\bd* مِينْ ذ أَمْ إِ غَا إِنِيغْ،
\m مِينْ غَارْ شمْ إِ غَا سّمْقُوذِّيغْ،
\m \add أَ\add* يدْجِيسْ ن ؤُرْشَالِيمْ؟
\m مِينْ غَارْ شمْ إِ غَا سّمْقُوذِّيغْ،
\m أَڒَامِي شمْ إِ غَا سّْفوّْجغْ،
\m \add أَ شمْ\add* ثَاعْزَارشْثْ، يدْجِيسْ ن صِيهْيُونْ،
\m مَاغَارْ ثَارژِّيثْ نّمْ ذ ثَامقّْرَانْثْ أَمْ ڒبْحَارْ،
\m وِي إِزمَّارنْ أَذْ شمْ إِسّْڭنْفَا؟
\b
\m 
\v 14 \bd نُونْ.\bd* إِنَابِييّنْ نّمْ ژْرِينْ
\m \add إِوحَّانْ\add* إِخَارِّيقنْ ذ إِبُوحَاڒِييّنْ،
\m وَارْ سّْعَارَّانْ شَا خْ ڒْمُوعْصِييّثْ نّمْ
\m أَڒَامِي إِ غَا سّنْقڒْبنْ ثَامحْبَاسْثْ نّمْ.
\m ذِي طّْوعْ نّمْ ژْرِينْ نِيثْنِي
\m \add مْغِيرْ\add* ڒحْكَامَاثْ إِخَارِّيقنْ ذ ثْحُوجَا ن ؤُغَارِّي.
\b
\m 
\v 15 \bd سَامِيخْ.\bd* مَارَّا إِنِّي \add خَامْ\add* د-إِتّكّنْ
\m شَّاثنْ ذڭْ إِفَاسّنْ \add س ؤُنخْڒِيعْ\add* زِي سِّيبّثْ نّمْ.
\m نِيثْنِي تّْصفَّارنْ ؤُ سّنْهزَّانْ أَزدْجِيفْ نْسنْ
\m خْ يدْجِيسْ ن ؤُرْشَالِيمْ،
\m قَّارنْ: ’مَا ذ ثَا ذ ثَانْذِينْثْ نِّي ؤُمِي نَّانْ:
\m ”مَا وَارْ إِدْجِي أَژْرِي نّسْ إِكْمڒْ،
\m ذ \add ڒْْعُونْصَارْ\add* ن ڒفْرَاحثْ إِ مَارَّا دُّونشْثْ!“؟
\b
\m 
\v 16 \bd بِي\bd* مَارَّا ڒْعذْيَانْ نّمْ أَرزْمنْ-د غَارْومْ
\m إِقمُّومنْ نْسنْ،
\m تّْصفَّارنْ ؤُ تّْغزَّانْ ثِيغْمَاسْ،
\m قَّارنْ: ”نشِّينْ نْصَارْضْ إِ-ت.
\m وَا ذ أَسّْ إِ ثُوغَا نتّْرَاجَا،
\m ڒخُّو نُوفَا إِ-ث، نتّْوَاڒَا إِ-ث!“
\b
\m 
\v 17 \bd عَايِينْ.\bd* إِڭَّا سِيذِي مِينْ إِخَارّصْ،
\m إِكمّڒْ أَوَاڒْ نّسْ
\m ونِّي يُومُورْ زِي مشْحَاڒْ ؤُيَا.
\m إِهْذمْ إِ \add شمْ\add*، وَارْ \add خَامْ\add* إِحِيوڒْ.
\m ڒعْذُو إِجَّا إِ-ث إِفَارْحْ زَّايمْ،
\m إِسّْڭعّذْ إِشّْ ن إِغْرِيمنْ نّمْ.
\b
\m 
\v 18 \bd ثْسَاذِي.\bd* ؤُڒْ نْسنْ إِسْغُويُّو غَارْ سِيذِي إِنُو،
\m ”\add أَ\add* ڒْحِيضْ ن يدْجِيسْ ن صِيهْيُونْ،
\m أجّْ أَذْ أَزّْڒنْ إِمطَّاونْ \add نّمْ\add* أَمْ ثغْزَارْثْ،
\m أَسّْ ذ دْجِيڒثْ بْڒَا مَا أَذْ نقْصنْ،
\m وَارْ تّجِّي مُومُّو ن ثِيطَّاوِينْ نّمْ أَذْ إِبدّْ!“ \x ◘ \xo 2:‏18 \xt إِرْم. 14‏:‏17؛ إِڭجذ. 1‏:‏16\x*
\b
\m 
\v 19 \bd قُوفْ.\bd* كَّارْ، سْغُويّْ ذِي دْجِيڒثْ،
\m غَارْ ؤُمزْوَارُو ن ثْعسَّاسْثْ ن دْجِيڒثْ،
\m زدْجعْ ؤُڒْ نّمْ أَمْ وَامَانْ
\m زَّاثْ إِ وُوذمْ ن سِيذِي إِنُو.
\m سْڭعّذْ غَارسْ إِفَاسّنْ نّمْ
\m إِ ثُوذَارْثْ ن إِحنْجِيرنْ نّمْ إِمژْيَانِينْ،
\m إِنِّي إِوْضَانْ غَارْ ثمُّورْثْ س ڒَاژْ،
\m غَارْ ثْغمَّارْ ن مَارَّا إِبْرِيذنْ.
\b
\m 
\v 20 \bd رِيخْ.\bd* خْزَارْ، \add أَ\add* سِيذِي، وَاڒَا \add مْلِيحْ\add*
\m ؤُمِي ثڭِّيذْ مَانْ أَيَا؟
\m مَا إِتّْخصَّا \add خنِّي\add* أَذْ شّنْثْ ثمْغَارِينْ
\m ڒْْغِيدْجثْ ن ؤُعذِّيسْ نْسنْثْ،
\m إِحنْجِيرنْ نْسنْثْ إِ ذِي تّْهِيلَّانْثْ نِيثنْثِي؟
\m مَا إِتّْخصَّا أَذْ إِتّْوَانغْ ؤُنَابِي ذ ؤُكهَّانْ
\m ذِي زَّاوشْثْ إِقدّْسنْ ن سِيذِي؟ \x ◘ \xo 2:‏20 \xt إِڭجذ. 4‏:‏10\x*
\b
\m 
\v 21 \bd شِينْ.\bd* إِحُوذْرِييّنْ ذ إِوسُّورَا بُوزّْڒنْ
\m خْ ثمُّورْثْ ذڭْ إِبْرِيذنْ.
\m ثِيعْزَارِييِّينْ إِنُو ذ إِحُوذْرِييّنْ إِنُو وْضَانْ س سِّيفْ.
\m ثنْغِيذْ \add ثنْ\add* ذڭْ وَاسّْ ن وغْضَابْ نّشْ،
\m ثْغَارْصضْ \add أَسنْ\add*، وَارْ \add خَاسنْ\add* ثْحِيوْڒذْ شَا.
\b
\m 
\v 22 \bd ثَافْ.\bd* ثْعَارّْنذْ-د غَارِي مِينْ إِسَّاڭّْوَاذنْ
\m زِي مَارَّا إِغزْذِيسنْ،
\m أَمْ مَامّشْ إِبَارّحْ س إِجّْ ن ؤُمُونِي إِفَارْزنْ.
\m وَارْ إِنجِّيمْ نِيغْ إِتَّاركّْوَاڒْ ؤُڒَا ذ إِجّْ
\m ذڭْ وَاسّْ ن وغْضَابْ ن سِيذِي.
\m إِنِّي إِ ذِي تّْهِيلِّيغْ ؤُ أَربِّيغْ
\m إِقْضَا إِ-ثنْ ڒعْذُو إِنُو.
\b
\b
\c 3
\s1 إِزْڒِي وِيسّْ ثْڒَاثَا - أَودّبْ ذ ؤُفوّجْ ن ؤُنَابِي
\m 
\v 1 \bd أَلِيفْ.\bd* نشّْ ذ أَرْيَازْ نِّي إِژْرِينْ ڒغْبنْ
\m س وعْمُوذْ ن ؤُذُوقّزْ نّسْ \add ن ؤُفُوڭمْ\add*.
\m 
\v 2 \bd أَلِيفْ.\bd* نتَّا إِنْذهْ أَيِي
\m ؤُشَا إِجَّا أَيِي أَذْ ؤُيُورغْ ذِي ثَادْجسْثْ،
\m وَارْ إِدْجِي ذِي ثْفَاوْثْ.
\m 
\v 3 \bd أَلِيفْ.\bd* س ثِيذتّْ،
\m نتَّا يَارَّا ڒبْذَا أَفُوسْ نّسْ ضِيدّْ إِنُو،
\m أَسّْ إِكْمڒْ.
\b
\m 
\v 4 \bd بِيثْ.\bd* نتَّا إِضيّعْ أَيْسُومْ إِنُو ذ ثڒْمشْثْ إِنُو،
\m يَارْژَا إِغْسَانْ إِنُو.
\m 
\v 5 \bd بِيثْ.\bd* نتَّا بْنَا إِشْثْ ن ڒبْنِييّثْ خَافِي
\m ؤُ إِقُووَّارْ أَيِي
\m س أَرّْهَاجْ ذ ثَامَارَا.
\m 
\v 6 \bd بِيثْ.\bd* ذِي طّْڒَامْ إِجَّا أَيِي زدّْغغْ،
\m أَمْ إِمتَّانْ ن وَاطَّاسْ زڭْ وَامِي.
\b
\m 
\v 7 \bd ڭِيملْ.\bd* نتَّا إِبلّعْ أَيِي جَارْ ڒحْيُوضْ،
\m وَارْ زمَّارغْ أَذْ نجْمغْ.
\m إِسّذْقڒْ خَافِي سّْنَاسڒْ إِنُو ن نّْحَاسْ.
\m 
\v 8 \bd ڭِيملْ.\bd* عَاذْ مڒْمِي تّْڒَاغِيغْ ؤُ سْغُويُّوغْ،
\m نتَّا إِقِّيمْ إِبْكمْ غَارْ ثْژَادْجِيثْ إِنُو.
\m 
\v 9 \bd ڭِيملْ.\bd* س ثْصُوضَارْ إِنْجَارنْ
\m إِبلّعْ خَافِي أَبْرِيذْ،
\m إِسّْفَارْغْ إِمسْرَاقْ إِنُو.
\b
\m 
\v 10 \bd ذَالِيثْ.\bd* ثُوغَا نتَّا إِ نشّْ \add أَمْ\add* دُّوبْ إِتّْحَامَانْ،
\m \add أَمْ\add* وَايْرَاذْ ذڭْ إِمُوشَانْ إِنُّوفَارنْ.
\m 
\v 11 \bd ذَالِيثْ.\bd* نتَّا يُوژّڒْ خَافِي زڭْ وبْرِيذْ،
\m إِمزّقْ أَيِي،
\m وَارْ ذ أَيِي إِجِّي شَا.
\m 
\v 12 \bd ذَالِيثْ.\bd* نتَّا إِسّمْحضْ ڒْقوْسْ نّسْ
\m ؤُشَا إِجَّا أَيِي أَذْ إِڒِيغْ ذ أَوَاضْ إِ فْڒِيثْشَا \add نّسْ\add*.
\b
\m 
\v 13 \bd هِي.\bd* فْڒِيثْشَاثْ زڭْ وقْرَابْ نّسْ
\m إِجَّا إِ-ثنْثْ أَذْ أَذْفنْثْ ذِي ثِيژَّاڒْ إِنُو.
\m 
\v 14 \bd هِي.\bd* ذوْڒغْ ذ ثَاسضْهَاشْثْ إِ مَارَّا ڒْڭنْسْ إِنُو،
\m ذ إِزْڒِي نْسنْ ن ؤُزَاوَارْ أَسّْ إِمُونْ.
\m 
\v 15 \bd هِي.\bd* نتَّا إِسّْجِّيونْ أَيِي س ثَارْزُوڭِي،
\m إِسّسُّو أَيِي س شِّيحْ.
\b
\m 
\v 16 \bd وَاوْ.\bd* ثِيغْمَاسْ إِنُو إِجَّا إِ-ثنْثْ زعّْفنْثْ
\m ذڭْ ؤُقَايَاسْ أَڒَامِي أَرْژِينْثْ،
\m إِذْڒَا أَيِي س يِيغّذْ.
\m 
\v 17 \bd وَاوْ.\bd* شكْ ثسِّيڭّْوجذْ ڒعْمَارْ إِنُو خْ ڒهْنَا،
\m نشّْ تُّوغْ \add مَارَّا\add* ثْشُونِي.
\m 
\v 18 \bd وَاوْ.\bd* نشّْ نِّيغْ: ”جّهْذْ إِنُو إِقْضَا،
\m ؤُڒَا ذ أَسِيثمْ إِنُو ذِي سِيذِي.“
\b
\m 
\v 19 \bd زَايِينْ.\bd* عْقڒْ خْ ڒغْبنْ إِنُو ذ ثْمحْبَاسْثْ إِنُو،
\m خْ شِّيحْ ذ أَرّْهَاجْ.
\m 
\v 20 \bd زَايِينْ.\bd* ڒعْمَارْ إِنُو إِتّْخَارّصْ نِيشَانْ ذِي مَانْ أَيَا،
\m أَقَا إِشْضنْ ذَايِي.
\m 
\v 21 \bd زَايِينْ.\bd* أَيَا خْسغْ أَذْ ث أَرّغْ غَارْ وُوڒْ،
\m خْ ؤُيَا أَذْ قِّيمغْ سِّيثِيمغْ عَاذْ.
\b
\m 
\v 22 \bd خِيثْ.\bd* س ثْمڭَّا ن ثْمخْسِيوْثْ ن سِيذِي،
\m أَقَا وَارْ نتّْوَاهلّكْ شَا،
\m مِينْزِي أَرّحْمثْ نّسْ \add عمَّارْصْ\add* وَارْ ثتّْبذِّي.\x ◘ \xo 3:‏22 \xt إِشا. 1‏:‏9؛ حَاب. 3‏:‏13\x*
\m 
\v 23 \bd خِيثْ.\bd* أَقَا-ت ذ جْذِيذْ كُوڒْ صّْبحْ،
\m ڒَْامَانْ نّشْ ذ أَمقّْرَانْ. \x ◘ \xo 3:‏23 \xt إِزهد. 30‏:‏6\x*
\m 
\v 24 \bd خِيثْ.\bd* ثَاسْغَارْثْ إِنُو ذ سِيذِي،
\m \add أَمُّو إِ\add* إِقَّارْ ڒعْمَارْ إِنُو،
\m خْ ؤُيَا تّْغِيمِيغْ سِّيثِيمغْ ذَايسْ. \x ◘ \xo 3:‏24 \xt حَاب. 2‏:‏3\x*
\b
\m 
\v 25 \bd ثِيث.\bd* إِصْبحْ سِيذِي إِ يِينِّي ذَايسْ إِسِّيثِيمنْ،
\m إِ ڒعْمَارْ نِّي خَاسْ يَارزُّونْ.
\m 
\v 26 \bd ثِيث.\bd* أَقَا مْلِيحْ أَرَاجِي س ؤُسِيثمْ غَارْ زَّاثْ،
\m \add أَرَاجِي\add* ذِي ڒْهُوذْنثْ غَارْ ؤُسنْجمْ زِي سِيذِي.
\m 
\v 27 \bd ثِيث.\bd* مْلِيحْ إِ ورْيَازْ أَذْ يَارْبُو أَزَايْڒُو
\m ذِي ثمْژِي نّسْ.
\b
\m 
\v 28 \bd يُوذْ.\bd* أجّْ إِ-ث أَذْ إِقِّيمْ حَافِي، أَذْ إِسّغْذْ،
\m مَاغَارْ سِيذِي إِڭَّا إِ-ت خَاسْ.
\m 
\v 29 \bd يُوذْ.\bd* أجّْ إِ-ث أَذْ إِڭّْ أَقمُّومْ نّسْ ذِي ثْعجَّاجْثْ،
\m \add أَذْ يِينِي:\add* ”أَذْ ثَاغْ إِدْجَا ڒَايَاسْ!“ \x ◘ \xo 3:‏29 \xt ڒخ. 8‏:‏22\x*
\m 
\v 30 \bd يُوذْ.\bd* أجّْ إِ-ث أَذْ إِوْشْ أَمڭِّيزْ إِ ونِّي ث إِشَّاثنْ،
\m أجّْ إِ-ث أَذْ إِتّْوَاجِّيونْ س ؤُسحْقَارْ.
\b
\m 
\v 31 \bd كَافْ.\bd* مِينْزِي سِيذِي إِنُو وَارْ إِنطَّارْ \add حذْ\add* إِ ڒبْذَا،
\m 
\v 32 \bd كَافْ.\bd* مَاشَا مَاڒَا نتَّا إِسّشْضنْ \add حذْ\add*،
\m أَذْ \add خَاسْ\add* إِحِينّْ عَاوذْ
\m عْلَاحْسَابْ ڒمْغَارثْ ن ثْمخْسِيوْثْ نّسْ إِشُووَّارنْ،
\m 
\v 33 \bd كَافْ.\bd* مَاغَارْ نتَّا وَارْ إِحصَّارْ
\m نِيغْ إِسّشْضِينْ ثَارْوَا ن ورْيَازْ س وُوڒْ.
\b
\m 
\v 34 \bd لَامِيذْ.\bd* خْمِي غَا ڒبْزنْ سَاذُو إِضَارنْ
\m مَارَّا إِمحْبَاسْ ن ثمُّورْثْ،
\m 
\v 35 \bd لَامِيذْ.\bd* خْمِي غَا حَارّْفنْ ثَاسْغَارْثْ ن ورْيَازْ
\m زَّاثْ إِ وُوذمْ ن ؤُمْعُودْجِي خْ كُوڒْشِي،
\m 
\v 36 \bd لَامِيذْ.\bd* خْمِي غَا قڒْبنْ دّعْوثْ ن بْنَاذمْ،
\m مَا زعْمَا سِيذِي إِنُو وَارْ إِتّْوِيڒِي \add مَانْ أَيَا\add*؟
\b
\m 
\v 37 \bd مِيمْ.\bd* مَانْ ونْ إِ إِقَّارنْ \add شَا ن ڒْحَاجّثْ\add*
\m ؤُشَا \add خنِّي\add* ثمْسَارْ،
\m \add مَاڒَا\add* وَارْ ت يُومُورْ سِيذِي إِنُو؟ \x ◘ \xo 3:‏37 \xt إِزهد. 33‏:‏9\x*
\m 
\v 38 \bd مِيمْ.\bd* مَا وَارْ د-إِتِّيسْ
\m زڭْ ؤُقمُّومْ ن ؤُمْعُودْجِي خْ كُوڒْشِي
\m \add مَارَّا\add* مِينْ وَارْ إِحْڒِينْ ؤُڒَا ذ \add مَارَّا\add* مِينْ إِصبْحنْ؟ \x ◘ \xo 3:‏38 \xt إِشا. 45‏:‏7؛ عَام. 3‏:‏6\x*
\m 
\v 39 \bd مِيمْ.\bd* مَامّشْ إِتّْشثْشَا بْنَاذمْ إِدَّارنْ \add عَاذْ\add*؟
\m \add أجّْ\add* ورْيَازْ \add أَذْ إِشثْشَا\add* زِي سِّيبّثْ ن دّْنُوبْ نّسْ.
\b
\m 
\v 40 \bd نُونْ.\bd* أجّْ أَنغْ أَذْ نخْزَارْ إِبْرِيذنْ نّغْ،
\m أَذْ ذَايْسنْ نَارْزُو،
\m أجّْ أَنغْ أَذْ د-نذْوڒْ غَارْ سِيذِي.
\m 
\v 41 \bd نُونْ.\bd* أجّْ أَنغْ أَذْ نسّْڭعّذْ أَكْ-ذ إِفَاسّنْ نّغْ
\m ؤُڒَا ذ وُوڒَاونْ نّغْ،
\m غَارْ أَربِّي ذڭْ ؤُجنَّا.
\m 
\v 42 \bd نُونْ.\bd* نشِّينْ نْعدَّا ؤُ نْغوّغْ،
\m شكْ وَارْ ثغْفَارذْ شَا إِ \add ؤُيَا\add*.
\b
\m 
\v 43 \bd سَامِيخْ.\bd* شكْ ثْڒحّْفذْ أَنغْ س وغْضَابْ،
\m ثضْفَارضْ أَنغْ،
\m ثنْغِيذْ، وَارْ \add خَانغْ\add* ثْحِيوْڒذْ شَا.
\m 
\v 44 \bd سَامِيخْ.\bd* ثْڒحّْفذْ إِخفْ نّشْ ذڭْ ؤُسيْنُو،
\m مَاحنْذْ أَذْ ثَافْ ثَاژَادْجِيثْ وَارْ ثْزمَّارْ أَذْ ثعْذُو.
\m 
\v 45 \bd سَامِيخْ.\bd* شكْ ثَارِّيذْ-د أَنغْ
\m ذ ثَاخْمُوجِي ذ وفْرَاضْ
\m ذِي ڒْوسْطْ ن ڒڭْنُوسْ.
\b
\m 
\v 46 \bd بِي.\bd* مَارَّا ڒْعذْيَانْ نّغْ
\m أَرْزْمنْ-د غَارْنغْ أَقمُّومْ نْسنْ.
\m 
\v 47 \bd بِي.\bd* ثِيڭّْوُوذَا ذ ڒْفخْ ذوْڒنْ \add ذ أَزْينْ\add* زَّايْنغْ،
\m أَخَارّبْ ذ أَرْژِييّثْ.
\m 
\v 48 \bd بِي.\bd* زِي ثِيطَّاوِينْ إِنُو تَّازّْڒنْثْ إِمطَّاونْ
\m خْ ثَارژِّيثْ ن يدْجِيسْ ن ڒْڭنْسْ إِنُو.
\b
\m 
\v 49 \bd عَايِينْ.\bd* ثِيطّْ إِنُو ثقِّيمْ ثتَّازّڒْ \add س إِمطَّاونْ\add*،
\m وَارْ ثتَّاريِّيحْ، وَارْ ثسّْبذِّي،
\m 
\v 50 \bd عَايِينْ.\bd* أَڒْ ذ إِ غَا إِسِّيجّْ سِيذِي زڭْ ؤُجنَّا،
\m ؤُشَا أَذْ إِتّْوَاڒَا.
\m 
\v 51 \bd عَايِينْ.\bd* ثِيطّْ إِنُو ثتّڭّْ أَيِي ڒحْرِيقْ
\m ذِي ڒعْمَارْ إِنُو،
\m زِي سِّيبّثْ ن مَارَّا يسِّيسْ ن ثنْذِينْثْ إِنُو.
\b
\m 
\v 52 \bd ثْسَاذِي.\bd* أَردّْفنْ أَيِي-د ڒْعذْيَانْ إِنُو بْڒَا قطُّو،
\m أَمْ يِيجّْ ن وجْضِيضْ، \add مَاشَا\add* بْڒَا سِّيبّثْ.
\m 
\v 53 \bd ثْسَاذِي.\bd* نِيثْنِي سّْبكْمنْ ثُوذَارْثْ إِنُو ذڭْ وَانُو،
\m ؤُشَا نْضَارنْ أَژْرُو خَافِي.
\m 
\v 54 \bd ثْسَاذِي.\bd* أَمَانْ حمْڒنْ-د خْ ؤُزدْجِيفْ إِنُو،
\m نِّيغْ: ”أَقَا وَارْ قِّيمغْ دْجِيغْ!“
\b
\m 
\v 55 \bd قُوفْ.\bd* \add أَ\add* سِيذِي، نشّْ ڒَاغِيغْ خْ يِيسمْ نّشْ،
\m زِي ڒَادْجَاغْ ن وَانُو.
\m 
\v 56 \bd قُوفْ.\bd* شكْ ثسْڒِيذْ إِ ثْمِيجَّا إِنُو،
\m وَارْ تّقّنْ أَمزُّوغْ نّشْ زَّاثْ إِ ؤُزهَّارْ إِنُو،
\m زَّاثْ إِ إِغُويَّانْ إِنُو!
\m 
\v 57 \bd قُوفْ.\bd* شكْ ثُوسِيذْ-د غَارِي
\m ذڭْ وَاسّْ إِ ذ أَشْ د-ڒَْاغِيغْ،
\m ثنِّيذْ: ”وَارْ تّڭّْوذْ شَا!“
\b
\m 
\v 58 \bd رِيخْ.\bd* شكْ، \add أَ\add* سِيذِي إِنُو،
\m ثَارفْعذْ دّْعَاوِي خْ ڒعْمَارْ إِنُو،
\m شكْ ثْفكّذْ ثُوذَارْثْ إِنُو.
\m 
\v 59 \bd رِيخْ.\bd* \add أَ\add* سِيذِي، ثژْرِيذْ دّدْجْ إِ ذَايِي إِڭِّينْ،
\m أَغْ أَيِي ثَاسْغَارْثْ إِنُو.
\m 
\v 60 \bd رِيخْ.\bd* شكْ ثژْرِيذْ مَارَّا أَخْڒَافْ نْسنْ،
\m مَارَّا مِينْ نْوَانْ ضِيدّْ إِنُو.
\b
\m 
\v 61 \bd شِينْ.\bd* شكْ ثسْڒِيذْ ڒْحڭْرَا نْسنْ، \add أَ\add* سِيذِي،
\m مَارَّا مِينْ نْوَانْ ضِيدّْ إِنُو،
\m 
\v 62 \bd شِينْ.\bd* \add أَوَاڒنْ نِّي د-إِتّفّْغنْ\add*
\m \add زِي جَارْ\add* إِينْشِيشنْ ن يِينِّي خَافِي إِكَّارنْ،
\m ؤُڒَا ذ ڒمْوَايَاڒْ نْسنْ ن ؤُخَارّصْ خَافِي أَسّْ إِمُونْ.
\m 
\v 63 \bd شِينْ.\bd* خْزَارْ غَارْ ؤُغِيمِي ذ ؤُبذِّي نْسنْ،
\m نشّْ ذ إِزْڒِي نْسنْ ن ؤُسْثهْزِي.
\b
\m 
\v 64 \bd ثَافْ.\bd* \add أَ\add* سِيذِي، خدْجصْ إِ-ثنْ ڒْمُونثْ نْسنْ
\m إِ إِسْذَاهدْجنْ،
\m عْلَاحْسَابْ ثِيمڭَّا ن إِفَاسّنْ نْسنْ.
\m 
\v 65 \bd ثَافْ.\bd* سْذَاغْرڒْ ؤُڒَاونْ نْسنْ،
\m أجّْ نّعْڒثْ نّشْ أَذْ د-خَاسنْ-\add ثوْضَا\add*.
\m 
\v 66 \bd ثَافْ.\bd* ضْفَارْ \add إِ-ثنْ\add* ذڭْ وغْضَابْ \add نّشْ\add*،
\m قْضَا خَاسنْ زِي سَاذُو ؤُجنَّا ن سِيذِي.
\b
\b
\c 4
\s1 إِزْڒِي وِيسّْ أَربْعَا - ڒْمُوعْصِييّثْ ن يدْجِيسْ ن ؤُرْشَالِيمْ
\m 
\v 1 \bd أَلِيفْ.\bd* مَامّشْ إِڭَّا إِبَّارْشنْ وُورغْ أَمُّو،
\m \add مَامّشْ\add* إِبدّڒْ وُورغْ إِشْنَا قَاعْ \add أَمُّو\add*!
\m مَامّشْ تّْوَابزّْعنْ إِژْرَا ن زَّاوشْثْ إِقدّْسنْ
\m خْ ثْغمُّورَا ن إِبْرِيذنْ!
\b
\m 
\v 2 \bd بِيثْ.\bd* إِحنْجِيرنْ إِغْڒَانْ ن صِيهْيُونْ
\m تّْوَاحسْبنْ أَمْ وُورغْ إِقُّورنْ.
\m مَامّشْ ذ أَسنْ تّڭّنْ \add ڒخُّو\add*
\m أَمْ يِيغَارَّافنْ ن ثْڒَاخْثْ،
\m \add أَمْ\add* ڒْخذْمثْ ن بُو-ثْڒَاخْثْ!
\b
\m 
\v 3 \bd ڭِيملْ.\bd* عَاذْ ثُوشَّانِينْ ن ڒخْڒَا
\m إِ د-إِسُّوفّْغنْ ثِيبِّيشِينْ،
\m سُّوطُّوضنْثْ إِمژْيَاننْ نْسنْثْ،
\m \add مَاشَا\add* يدْجِيسْ ن ڒْڭنْسْ إِنُو ثذْوڒْ ثوْعَارْ،
\m أَمْ نّْعَامَاثْ ذِي ڒخْڒَا.
\b
\m 
\v 4 \bd ذَالِيثْ.\bd* إِڒسْ ن وحْضِيضْ إِڒْصقْ
\m غَارْ وَانغْ نّسْ س ؤُفَاذِي،
\m إِحنْجِيرنْ إِمژْيَاننْ ثتَّارنْ أَغْرُومْ،
\m \add مَاشَا\add* ؤُڒَا ذ إِجّنْ وَارْ ذ أَسنْ ث يبْضِي.
\b
\m 
\v 5 \bd هِي.\bd* إِنِّي ثُوغَا إِتّتّنْ \add زِيشْ\add* مَاشَّا إِڒدّنْ،
\m غَاشَانْ ذڭْ إِبْرِيذنْ،
\m إِنِّي إِتّْوَاسّيْمنْ
\m \add ذڭْ وَارُّوضْ\add* أَزڭّْوَاغْ إِحذْقنْ،
\m حنّْضنْ ڒخُّو ذِي ڒغْبَارْ.
\b
\m 
\v 6 \bd وَاوْ.\bd* ڒْمُوعْصِييّثْ ن يدْجِيسْ ن ڒْڭنْسْ إِنُو
\m ذ ثَامقّْرَانْثْ خْ دّْنُوبْ ن \add ثنْذِينْثْ ن\add* سَاذُومْ،
\m ثنِّي إِنْقڒْبنْ ذڭْ إِجّْ ن ؤُمُورْ،
\m بْڒَا تّْسَاخُّورْ ن إِفَاسّنْ.
\b
\m 
\v 7 \bd زَايِينْ.\bd* ثُوغَا ثَارْوَا ن ثَاصِيڒثْ نّسْ
\m صْفَانْ خْ وذْفڒْ، ذ إِشمْڒَاڒنْ خْ ؤُغِي،
\m أَرِّيمَاثْ نْسنْ زوْغنْ خْ ڒْمَارْجَانْ،
\m أَدُّوذْ نْسنْ \add يَارقّْ\add* أَمْ صَافِّيرْ أَزِيزَا.
\b
\m 
\v 8 \bd خِيثْ.\bd* \add ڒخُّو\add* إِبدّڒْ وَادُّوذْ نْسنْ،
\m إِذْوڒْ ذ أَبَارْشَانْ خْ ثَادْجسْثْ،
\m وَارْ تّْوَاعْقِيڒنْ ذڭْ إِبْرِيذنْ \add عَاذْ\add*.
\m ثِيڒْمشْثْ نْسنْ ثڒْصقْ خْ يغْسَانْ نْسنْ،
\m ثُوژغْ، ثذْوڒْ أَمْ ؤُكشُّوضْ.
\b
\m 
\v 9 \bd ثِيث.\bd* إِحْڒَا إِنِّي إِتّْوَانْغنْ س سِّيفْ،
\m خْ يِينِّي إِتّْوَانْغنْ س ڒَاژْ،
\m مَاغَارْ نِيثْنِي أَذْ فسْينْ،
\m تّْوَاڒقْفنْ س \add ونْقَاسْ ن\add* صَّابثْ ن ييَّارْ.
\b
\m 
\v 10 \bd يُوذْ.\bd* إِفَاسّنْ ن ثمْغَارِينْ \add نِّي ثُوغَا\add* إِتّْحِينَّانْ \add قْبڒْ\add*،
\m سّْننَّانْ إِ إِحنْجِيرنْ نْسنْ.
\m نِيثْنِي ذوْڒنْ أَسنْثْ ذ مَاشَّا،
\m زِي سِّيبّثْ ن ثْرژِّيثْ ن يدْجِيسْ ن ڒْڭنْسْ إِنُو.
\b
\m 
\v 11 \bd كَافْ.\bd* سِيذِي يَارْخُو إِ وسْعَارْ نّسْ،
\m إِسّْفَارّغْ ڒْحَاذُوقْ ن وغْضَابْ نّسْ.
\m نتَّا إِسَّارْغْ ثِيمسِّي ذِي صِيهْيُونْ،
\m \add ثِيمسِّي\add* ثنِّي إِشّنْ ذْسُوسَا نّسْ.
\b
\m 
\v 12 \bd لَامِيذْ.\bd*عمَّارْصْ وَارْ ثتّْغِيڒْ
\m إِ إِجدْجِيذنْ ن ثمُّورْثْ
\m ذ إِمزْذَاغْ ن دُّونشْثْ،
\m أَقَا أَغْرِيمْ ذ ڒعْذُو أَذْ د-أَذْفنْ
\m غَارْ ثوُّورَا ن ؤُرْشَالِيمْ.
\b
\m 
\v 13 \bd مِيمْ.\bd* ذ مَانْ أَيَا ذِي سِّيبّثْ ن دّْنُوبْ
\m ن إِنَابِييّنْ نّسْ،
\m \add ذِي سِّيبّثْ\add* ن ڒْمُوعْصِييّثْ ن إِكهَّاننْ نّسْ،
\m إِنِّي إِسِّيزّْڒنْ إِذَامّنْ ن إِمْسڭَّاذنْ ذِي ڒْوسْطْ نّسْ.
\b
\m 
\v 14 \bd نُونْ.\bd* ثتّْلِيعنْ أَمشْنَاوْ إِذَارْغَاڒنْ ذڭْ إِبْرِيذنْ،
\m مسْڒنْ س إِذَامّنْ،
\m أَڒَامِي وَارْ إِزمَّارْ ؤُڒَا ذ إِجّنْ أَذْ إِحَاذَا أَرُّوضْ نْسنْ.
\b
\m 
\v 15 \bd سَامِيخْ.\bd* ”أَڭّْوجمْ، \add أَقَا إِذَامّنْ\add* خمْجنْ!“،
\m ڒَْاغَانْ أَسنْ:
\m ”أَڭّْوجمْ، أَڭّْوجمْ، وَارْ ث تّْحَاذَامْ!“
\m ؤُشَا خنِّي أَروْڒنْ، قِّيمنْ ودَّارنْ.
\m إِتّْوَانَّا جَارْ ڒڭْنُوسْ:
\m ”وَارْ إِعدّڒْ أَذْ قِّيمنْ \add ذِينْ\add* عَاذْ كْثَارْ
\m \add أَمْ إِبَارَّانِييّنْ\add*!“
\b
\m 
\v 16 \bd بِي.\bd* أَغمْبُوبْ ن سِيذِي يَاريّشْ إِ-ثنْ،
\m وَارْ إِقِّيمْ أَذْ ذَايْسنْ إِخْزَارْ عَاذْ.
\m ثُوغَا وَارْ غَارْسنْ أَوقَّارْ إِ إِكهَّاننْ،
\m إِوسُّورَا وَارْ ذ أَسنْ سّشْننْ أَحِينِّي.
\b
\m 
\v 17 \bd عَايِينْ.\bd* ڒبْذَا تّفْشِيڒنْثْ ثِيطَّاوِينْ نّغْ،
\m ؤُمِي خْزَارنْثْ غَارْ ثْوِيزَا.
\m ثُوغَا-ث بَاطڒْ!
\m غَارْ مَارَّا أَخزَّارْ نّغْ نتّْرَاجَا إِجّْ ن ڒْڭنْسْ
\m إِ وَارْ إِزمَّارنْ أَذْ إِسّنْجمْ. \x ◘ \xo 4:‏17 \xt حِز. 29‏:‏16\x*
\b
\m 
\v 18 \bd ثْسَاذِي.\bd* نِيثْنِي حْصَارنْ أَنغْ،
\m أَڒَامِي وَارْ نقِّيمْ نْزمَّارْ
\m أَذْ نُويُورْ خْ وَازَّاينْ نّغْ.
\m قطُّو نّغْ ثُوغَا يِيوضْ-د،
\m ؤُسَّانْ نّغْ قْضَانْ،
\m وَاهْ، قطُّو نّغْ يُوسَا-د. \x ◘ \xo 4:‏18 \xt إِزهد.49‏:‏6\x*
\b
\m 
\v 19 \bd قُوفْ.\bd* إِنِّي ذ أَنغْ إِضفَّارنْ
\m ثُوغَا فْسُوسنْ خْ إِڭِيذَارنْ ذڭْ ؤُجنَّا.
\m نِيثْنِي ؤُژّْڒنْ خَانغْ خْ إِذُورَارْ،
\m ڭِّينْ أَنغْ إِجّْ ن ڒْفخْ ذِي ڒخْڒَا.
\b
\m 
\v 20 \bd رِيخْ.\bd* نّفْسْ ن ونْزَارنْ نّغْ، لْمَاسِيحْ ن سِيذِي،
\m إِتّْوَاحبّسْ ذِي إِحُوفَارْ نْسنْ،
\m ونِّي خْ ننَّا:
\m ”أَذْ ندَّارْ جَارْ ڒڭْنُوسْ ذِي ثِيڒِي نّسْ!“
\b
\m 
\v 21 \bd شِينْ.\bd* سْڒِيوْڒوْ ؤُ فَارْحْ، \add أَ\add* يدْجِيسْ ن إِذُومْ،
\m ثنِّي إِزدّْغنْ ذِي ثمُّورْثْ ن عُوصْ!
\m \add مَاشَا\add* ؤُڒَا ذ شمْ أَذْ غَارمْ د-يَاسْ ڒْكَاسْ،
\m شمْ أَذْ زَّايسْ ثسْشَارذْ،
\m أَذْ ثتّْوَاعَارِّيذْ.
\b
\m 
\v 22 \bd ثَافْ.\bd* غَارْ ڒْمُوعْصِييّثْ نّمْ أَذْ يِيڒِي ؤُنڭَّارْ،
\m \add أَ\add* يدْجِيسْ ن صِيهْيُونْ!
\m نتَّا وَارْ إِ شمْ إِتّْحوِّيسْ عَاذْ.
\m \add مَاشَا\add* نتَّا أَذْ زَّايمْ إِخدْجصْ ڒْمُوعْصِييّثْ نّمْ،
\m \add أَ\add* يدْجِيسْ ن إِذُومْ!
\m نتَّا أَذْ إِعَارَّا خْ دّْنُوبْ نّمْ.
\b
\b
\c 5
\s1 إِزْڒِي وِيسّْ خمْسَا - ثَاژَادْجِيثْ إِ ؤُسنْجمْ
\m 
\v 1 عْقڒْ، \add أَ\add* سِيذِي، خْ مِينْ إِ ذ أَنغْ إِمْسَارنْ،
\m خْزَارْ-د ؤُ وَاڒَا ڒْحڭْرَا نّغْ.
\m 
\v 2 ثوْضَا ثسْغَارْثْ ن ڒْوَارْثْ نّغْ إِ إِبَارَّانِييّنْ،
\m ؤُڒَا ذ ثُوذْرِينْ نّغْ رُوحنْثْ ت غَارْ مِيدّنْ.
\m 
\v 3 نشِّينْ نذْوڒْ ذ إِيُوجِيڒنْ بْڒَا بَابَاثْنغْ،
\m ثِييمَّاثِينْ نّغْ ذوْڒنْثْ أَمْ ثِيجَّاڒْ.
\m 
\v 4 أَمَانْ نّغْ نْسسّْ إِ-ثنْ س ثْمنْيَاثْ،
\m أَكشُّوضْ نّغْ نتّْخدْجَاصْ خَاسْ.
\m 
\v 5 ضفَّارنْ أَنغْ خْ يِيرِي نّغْ،
\m نشِّينْ نمُّوثْ س ڒْوحْڒَانْ،
\m \add مَاشَا\add* وَارْ ذ أَنغْ جِّينْ أَرَّاحثْ.
\m 
\v 6 أَقَا نْسَارّحْ أَفُوسْ غَارْ مِيصْرَا، غَارْ أَشُّورْ،
\m مَاحنْذْ أَذْ نجِّيونْ أَغْرُومْ.
\m 
\v 7 إِبَابَاثنْ نّغْ خْضَانْ،
\m وَارْ دْجِينْ عَاذْ.
\m ؤُ نشِّينْ نَاربُّو ڒْمُوعْصِييّثْ نْسنْ.
\m 
\v 8 إِمْسخَّارنْ دّبَّارَانْ خَانغْ،
\m ؤُڒَا ذ إِجّْ وَارْ ذ أَنغْ إِسّنْفكِّي
\m زڭْ إِفَاسّنْ نْسنْ.
\m 
\v 9 نشِّينْ نْسبّڒْ ثُوذَارْثْ نّغْ
\m مَاحنْذْ أَذْ د-نَاوِي أَغْرُومْ نّغْ،
\m زِي سِّيبّثْ ن سِّيفْ ذِي ڒخْڒَا.
\m 
\v 10 ثِيڒْمشْثْ نّغْ ثتّحْذُوذُوقْ أَمْ ثفْقُونْثْ،
\m زِي ڒْحَاذُوقْ ن ثْمسِّي ن ڒَاژْ.
\m 
\v 11 سّْخَارْڭنْ ثِيمْغَارِينْ ذِي صِيهْيُونْ،
\m ؤُڒَا ذ ثِيعْزَارِييِّينْ ذِي ثْندَّامْ ن يَاهُوذَا.
\m 
\v 12 ڒْحُوكَّامْ يُويْڒنْ ثنْ س إِفَاسّنْ ن يِيخفْ نْسنْ،
\m إِوسُّورَا وَارْ ثنْ وقَّارنْ \add عَاذْ\add*.
\m 
\v 13 إِرْيَازنْ إِجهْذنْ قَاعْ أَربُّونْ \add إِژْرَا ن\add* ثْسِيرْثْ،
\m ؤُ إِحُوذْرِييّنْ تّْنقْرَاضنْ
\m سَاذُو \add ڒحْمڒْ ن\add* ؤُكشُّوضْ.
\m 
\v 14 إِمْغَارنْ سّْبدّنْ أَغِيمِي ذِي ثوُّورَا ن ثنْذِينْثْ،
\m إِحُوذْرِييّنْ \add سّْبدّنْ\add* زڭْ ؤُزنْزُونْ نْسنْ \add خْ إِفِيڒَانْ\add*.
\m 
\v 15 ثْودَّارْ ڒفْرَاحثْ ن وُوڒْ نّغْ،
\m شّْضِيحْ نّغْ س نُّوبْثَاثْ إِذْوڒْ ذ أَشْضَانْ.
\m 
\v 16 إِوْضَا أَنغْ ثَاجّْ خْ ؤُزدْجِيفْ نّغْ.
\m ؤُشْثْ خَانغْ، مَاغَارْ نشِّينْ نخْضَا.
\m 
\v 17 س ؤُينِّي إِهْڒشْ وُوڒْ نّغْ أَطَّاسْ،
\m س ؤُينِّي بَّارشْننْثْ ثِيطَّاوِينْ نّغْ،
\m 
\v 18 زِي سِّيبّثْ ن وذْرَارْ ن صِيهْيُونْ
\m نِّي إِتّْوَاخَارّْبنْ،
\m مَانِي تَّاوْينْ تَّارَّانْ إِشعْبَاونْ.
\m 
\v 19 شكْ، \add أَ\add* سِيذِي، أَذْ ثقِّيمذْ إِ ڒبْذَا،
\m ڒْْكُورْسِي إِڭلّْذنْ نّشْ أَقَا-ث زِي جِّيڒْ أَڒْ جِّيڒْ.
\m 
\v 20 مَايمِّي ثخْسذْ شكْ أَذْ أَنغْ ثتُّوذْ إِ ڒبْذَا؟
\m مَايمِّي إِ ذَايْنغْ ثْسمْحذْ قَاعْ أَنشْثْ ؤُيَا ن وُوسَّانْ؟
\m 
\v 21 \add أَ\add* سِيذِي، أَرّْ أَنغْ-د غَاركْ،
\m \add خنِّي\add* أَذْ غَاركْ د-نذْوڒْ.
\m أَرّْ أَنغْ-د ؤُسَّانْ نّغْ ذ جْذِيذْ أَمْ زِيشْ.
\m 
\v 22 مَاغَارْ مَا س ثِيذتّْ ثنْضَارذْ أَنغْ كُوڒْشِي؟
\m مَا ثفُّوڭْمذْ خَانغْ أَمُّو قَاعْ؟ 
