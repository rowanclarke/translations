\c 2  
\s1 Manghainu a Thai A Tlap  
\p
\v 1 \w He|strong="H0428"\w* \w ol|strong="H1697"\w* \w hnukah|strong="H0310"\w* tah \w manghai|strong="H4428"\w* \w Ahasuerus|strong="H0325"\w* kah \w kosi|strong="H2534"\w* tah \w daeh|strong="H7918"\w* tih \w Vashti|strong="H2060"\w* \w khaw|strong="H9999"\w*, anih kah a \w saii|strong="H6213"\w* \w te|strong="H0834"\w* \w khaw|strong="H9999"\w*, \w anih|strong="H9907"\w* \w sokah|strong="H5921"\w* a \w tuiphih|strong="H1504"\w* \w te|strong="H0834"\w* khaw, a \w poek|strong="H2142"\w*.  
