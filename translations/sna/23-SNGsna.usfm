\id SNG - Biblica® Open Shona Contemporary Bible 2017 
\h Rwiyo Rukuru rwaSoromoni 
\toc1 Rwiyo Rukuru rwaSoromoni 
\toc2 Rwiyo Rukuru rwaSoromoni 
\toc3 Rwiyo 
\mt1 RWIYO RUKURU RWASOROMONI 
\c 1  
\p  
\v 1 Rwiyo Rukuru rwaSoromoni: 
\sp Mukadzi 
\q1  
\v 2 Ngaanditsvode hake nokutsvoda kwomuromo wake. 
\q2 Nokuti rudo rwako runofadza kupfuura waini. 
\q1  
\v 3 Kunhuhwirira kwamafuta enyu kunofadza; 
\q2 zita renyu rakafanana namafuta anonhuwirira adururwa. 
\q2 Hazvishamisi kuti mhandara dzinokudai! 
\q1  
\v 4 Nditorei muende neni, ngatikurumidzei. 
\q2 Mambo ngaandipinze mudzimba dzake dzomukati. 
\sp Shamwari 
\q1 Tinokupembererai uye tinokufarirai; 
\q2 ticharumbidza rudo rwenyu kupfuura waini. 
\sp Mukadzi 
\q1 Regai zvenyu mhandara dzikudei! 
\b  
\q1  
\v 5 Kusviba ndakasviba zvangu, asi ndakanaka hangu, 
\q2 vanasikana veJerusarema, 
\q2 ndakasviba samatende eKedhari, 
\q2 sezvidzitiro zvetende raSoromoni. 
\q1  
\v 6 Musanditarisisa nokuda kwoutema hwangu, 
\q2 nokuti ndakasvibiswa nezuva. 
\q1 Vanakomana vamai vangu vakanditsamwira 
\q2 vakandiita kuti ndichengete minda yemizambiringa; 
\q2 munda wangu chaiwo wemizambiringa ndakaushayira nguva. 
\q1  
\v 7 Ndiudze, iwe mudiwa wangu, kwaunofudzira makwai ako 
\q2 nokwaunozorodzera makwai ako masikati. 
\q1 Ko, ndichaitirei somukadzi akafukidza chiso chake 
\q2 pedyo namakwai eshamwari dzako? 
\sp Shamwari 
\q1  
\v 8 Kana usingazivi, iwe mukadzi akanaka kukunda vamwe, 
\q2 chitevera makwara amakwai 
\q1 ugondofudzira mbudzana dzako 
\q2 pedyo namatende avafudzi. 
\sp Murume 
\q1  
\v 9 Ndinokufananidza, iwe mudiwa wangu, nebhiza rakasungwa 
\q2 pane imwe yengoro dzaFaro. 
\q1  
\v 10 Matama ako akashongedzwa zvakanaka nemhete, 
\q2 mutsipa wako nezvuma zvamatombo anokosha. 
\q1  
\v 11 Tichakugadzirira mhete 
\q2 dzenzeve dzegoridhe nesirivha. 
\sp Mukadzi 
\q1  
\v 12 Mambo paakanga agere patafura yake, 
\q2 munhuwi wamafuta andainge ndazora wakapararira. 
\q1  
\v 13 Mudiwa wangu, kwandiri akaita sakahomwe kemura 
\q2 kanogara pakati pamazamu angu. 
\q1  
\v 14 Mudiwa wangu, kwandiri akaita sesumbu ramaruva machena 
\q2 anobva mubindu remizambiringa yeEni Gedhi. 
\sp Murume 
\q1  
\v 15 Kunaka here kwawakaita uku, mudiwa wangu! 
\q2 A-a, wakazonaka! 
\q2 Meso ako injiva chaidzo! 
\sp Mukadzi 
\q1  
\v 16 Wakanaka sei, mudiwa wangu! 
\q2 A-a, unofadza! 
\q2 Uye mubhedha wedu wakasvibira. 
\sp Murume 
\q1  
\v 17 Nhungo dzeimba yedu ndedzomusidhari; 
\q2 mbariro dzacho ndedzomupaini. 
\c 2  
\sp Mukadzi 
\q1  
\v 1 Ndiri ruva reSharoni, 
\q2 ruva romumipata. 
\sp Murume 
\q1  
\v 2 Seruva riri pakati peminzwa, 
\q2 ndizvo zvakaita mudiwa wangu pakati pemhandara. 
\sp Mukadzi 
\q1  
\v 3 Somuti womuapuro pakati pemiti yesango, 
\q2 ndizvo zvawakaita mudiwa wangu pakati pamajaya. 
\q1 Ndinofarira kugara mumumvuri wake, 
\q2 uye muchero wake unondinakira kuudya. 
\q1  
\v 4 Akaenda neni kuimba yamabiko, 
\q2 uye mureza wake pamusoro pangu ndirwo rudo. 
\q1  
\v 5 Ndisimbise namazambiringa akaomeswa, 
\q2 ndisimbise namaapuro; 
\q2 nokuti ndoziya norudo. 
\q1  
\v 6 Ruoko rwake rworuboshwe rwuri pasi pomusoro wangu, 
\q2 uye ruoko rwake rworudyi rwakandimbundikira. 
\q1  
\v 7 Imi vanasikana veJerusarema ndinokupikirai 
\q2 nemhara uye nenondo dzesango: 
\q1 Musazunguza kana kumutsa rudo 
\q2 kusvikira irwo rwada rwoga. 
\b  
\q1  
\v 8 Inzwai! Inzwi romudiwa wangu! 
\q2 Tarirai! Hoyo 
\q1 ouya achiuruka nomumakomo, 
\q2 achikwakuka nomuzvikomo. 
\q1  
\v 9 Mudiwa wangu akafanana nemhara 
\q2 kana netsvana yenondo. 
\q1 Tarirai! Hoyo amira seri kworusvingo rwedu, 
\q2 akatarira napamawindo achidongorera napamaburi apamawindo. 
\q1  
\v 10 Mudiwa wangu akataura kwandiri akati, 
\q2 “Simuka, mudiwa wangu, 
\q2 iwe munakunaku wangu, uya tiende tose. 
\q1  
\v 11 Tarira! Nguva yechando yapera; 
\q2 mvura yapera; uye haichanayi. 
\q1  
\v 12 Maruva oonekwa panyika; 
\q2 nguva yokuimba yasvika, 
\q1 kurira kwenjiva 
\q2 kwonzwikwa munyika yedu. 
\q1  
\v 13 Muonde wobereka michero yawo yokutanga; 
\q2 uye mizambiringa yotunga maruva ayo anonhuhwira kwazvo. 
\q1 Simuka, uya, mudiwa wangu; 
\q2 munakunaku wangu, uya tiende tose.” 
\sp Murume 
\q1  
\v 14 Njiva yangu iri mumikaha yedombo, 
\q2 munzvimbo dzokuvanda mumativi egomo, 
\q1 ndiratidze chiso chako, 
\q2 ndinoda kunzwa inzwi rako; 
\q1 nokuti inzwi rako rinotapira, 
\q2 uye chiso chako chinoyevedza. 
\q1  
\v 15 Tibatirei makava, 
\q2 ivo vana vemakava 
\q1 anoparadza minda yemizambiringa, 
\q2 iyo mizambiringa yedu yotunga maruva. 
\sp Mudiwa 
\q1  
\v 16 Mudiwa wangu ndewangu uye ndiri wake; 
\q2 anofamba-famba pakati pamaruva omubani. 
\q1  
\v 17 Kusvikira zuva rabuda 
\q2 uye mimvuri yatiza, 
\q1 pinduka, mudiwa, 
\q2 ubve waita semhara 
\q1 kana tsvana 
\q2 pamusoro pezvikomo. 
\c 3  
\q1  
\v 1 Usiku hwose ndiri pamubhedha wangu 
\q2 ndakatsvaka uyo anodiwa nomwoyo wangu; 
\q2 ndakamutsvaka asi handina kumuwana. 
\q1  
\v 2 Ndichasimuka zvino ndinofamba-famba muguta, 
\q2 mumigwagwa yaro nomuzvivara zvaro; 
\q1 ndichatsvaka iye anodiwa nomwoyo wangu. 
\q2 Saka ndakamutsvaka asi handina kumuwana. 
\q1  
\v 3 Varindi vakandiona 
\q2 pavaiva pabasa ravo rokufamba-famba vachichengetedza guta. 
\q2 “Ko, mamboona here iye anodiwa nomwoyo wangu?” 
\q1  
\v 4 Ndichingopfuudzana navo 
\q2 ndakabva ndamuwana, iye anodiwa nomwoyo wangu. 
\q1 Ndakamubata ndikasamuregedza 
\q2 kusvikira ndaenda naye kumba kwamai vangu, 
\q2 kuimba yaavo vakandibereka. 
\q1  
\v 5 Vanasikana veJerusarema, ndinokurayirai 
\q2 nemhara kana nenondo dzesango kuti: 
\q1 Musazunguza kana kumutsa rudo 
\q2 kusvikira irwo rwada rwoga. 
\q1  
\v 6 Ndianiko uyo ari kuuya achibva nokurenje 
\q2 seshongwe youtsi 
\q1 ine munhuwi wemura, nezvimwe zvinonhuhwira 
\q2 zvakagadzirwa nezvikuyiwa zvinonhuhwira zvavashambadzi? 
\q1  
\v 7 Tarirai! Ndiyo ngoro yaSoromoni, 
\q2 yakachengetedzwa nemhare makumi matanhatu dzamachinda, 
\q2 apamusoro-soro omuIsraeri. 
\q1  
\v 8 Mumwe nomumwe wavo akabata munondo 
\q2 vose vakarwa hondo, 
\q1 mumwe nomumwe ane munondo parutivi rwake, 
\q2 vakagadzirira kutarisana nezvinotyisa usiku. 
\q1  
\v 9 Mambo Soromoni akazvigadzirira ngoro; 
\q2 akaigadzira nemiti yokuRebhanoni. 
\q1  
\v 10 Mbiru dzacho akadzigadzira nesirivha, 
\q2 pokuzembera musana pakagadzirwa negoridhe. 
\q1 Pokugara pakashongedzwa nejira repepuru, 
\q2 mukati mayo makashongedzwa norudo 
\q2 navanasikana veJerusarema. 
\q1  
\v 11 Budai imi vanasikana veZioni, 
\q2 muzoona Mambo Soromoni akapfeka korona, 
\q2 korona yaakapfekedzwa namai vake 
\q1 musi wesvitsa, 
\q2 zuva iro mwoyo wake wakafara. 
\c 4  
\sp Murume 
\q1  
\v 1 Wakanaka sei, mudiwa wangu! 
\q2 A, wakazonaka! 
\q2 Meso ako uri mumumbure injiva chaidzo. 
\q1 Bvudzi rako rakaita sedanga rembudzi 
\q2 riri kuburuka kubva muGomo reGireadhi. 
\q1  
\v 2 Meno ako akafanana neboka ramakwai achangobva mukuveurwa, 
\q2 ari kubva kundoshambidzwa. 
\q1 Rimwe nerimwe riine rarakafanana naro, 
\q2 pasina rimwe riri roga zvaro. 
\q1  
\v 3 Miromo yako yakafanana nomucheka mutsvuku; 
\q2 muromo wako wakaisvonaka. 
\q1 Zvavovo zvako zviri mumumbure wako 
\q2 zvakaita sezvikamu zviviri zvedamba. 
\q1  
\v 4 Mutsipa wako wakafanana neshongwe yaDhavhidhi 
\q2 yakavakwa zvinoyevedza. 
\q1 Mairi makaturikwa nhoo dzine chiuru, 
\q2 dzose dziri nhoo dzemhare. 
\q1  
\v 5 Mazamu ako ari maviri akafanana netsvana mbiri dzemhara, 
\q2 mapatya emhara 
\q2 dzinofura pamwe chete pakati pemaruva. 
\q1  
\v 6 Kusvikira zuva rabuda 
\q2 uye mimvuri yotiza, 
\q1 ndichaenda kugomo remura 
\q2 nokuchikomo chezvinonhuhwira. 
\q1  
\v 7 Wakaisvonaka iwe, mudiwa wangu; 
\q2 mauri hamuna kana chinongo. 
\b  
\q1  
\v 8 Ngatibvei tose kuRebhanoni, iwe mwenga wangu, 
\q2 ngatibvei tose kuRebhanoni. 
\q1 Buruka kubva pamusoro-soro peAmana, 
\q2 kubva pamusoro peSeniri, 
\q1 pamusoro-soro peHerimoni, 
\q2 kubva kumapako eshumba nokumakomo anofamba-famba mbada. 
\q1  
\v 9 Watora mwoyo wangu hanzvadzi yangu, mwenga wangu; 
\q2 wanditora mwoyo 
\q1 nokungondiringa kwawaita kamwe chete, 
\q2 uye nedombo rimwe rinokosha rechishongo chomutsipa wako. 
\q1  
\v 10 Rudo rwako kwandiri runondifadza sei, hanzvadzi yangu, mwenga wangu! 
\q2 Rudo rwako runofadza sei kukunda waini, 
\q2 uye kunhuhwira kwamafuta ako okuzora 
\q2 kunokunda zvose zvinonhuhwira. 
\q1  
\v 11 Miromo yako inodonhesa zvinotapira sezinga rouchi, mwenga wangu; 
\q2 uchi nomukaka zviri pasi porurimi rwako. 
\q2 Kunhuhwira kwenguo dzako kwakafanana nokweRebhanoni. 
\q1  
\v 12 Uri bindu rakapfigwa, hanzvadzi yangu, mwenga wangu. 
\q2 Uri tsime rakakomberedzwa, nechitubu chakavakirirwa. 
\q1  
\v 13 Miti yako ibindu ramatamba 
\q2 nemimwe michero yakaisvonaka, 
\q2 hena nenaridhi, 
\q2  
\v 14 naridhi nesafuroni, 
\q2 karamusi, nesinamoni, 
\q2 nemiti yose inogadziriswa zvinonhuhwira 
\q2 nemura negavakava, 
\q2 uye nezvose zvinonhuhwira zvakanakisisa. 
\q1  
\v 15 Uri chitubu chomubindu, 
\q2 tsime remvura inoerera, 
\q2 inoerera ichibva kuRebhanoni. 
\sp Mukadzi 
\q1  
\v 16 Muka, iwe mhepo yokumusoro, 
\q2 uye uya iwe mhepo yezasi! 
\q1 Vhuvhuta napabindu rangu 
\q2 kuti kunhuhwirira kwezvirimo kuparadzirwe kwose kwose. 
\q1 Rega mudiwa wangu apinde mubindu rake, 
\q2 agoravira michero yaro yakaisvonaka, sepaanodira. 
\c 5  
\sp Murume 
\q1  
\v 1 Ndauya zvangu mubindu rangu, hanzvadzi yangu, iwe mwenga wangu; 
\q2 ndaunganidza mura yangu pamwe chete nezvinonhuhwira zvangu. 
\q1 Ndadya zinga rangu rouchi nouchi hwangu; 
\q2 ndanwa waini yangu nomukaka wangu. 
\sp Shamwari 
\q1 Idyai, imi shamwari, uye munwe; 
\q2 inwai mugute, imi vanodanana. 
\sp Mukadzi 
\q1  
\v 2 Ndakavata asi mwoyo wangu wakanga wakasvinura. 
\q2 Inzwai! Mudiwa wangu ari kugogodza, achiti, 
\q1 “Ndizarurire, hanzvadzi yangu, mudiwa wangu, 
\q2 njiva yangu, wangu asina chinongo. 
\q1 Musoro wangu wanyorova nedova, 
\q2 bvudzi rangu ranyoroveswa nounyoro hweusiku.” 
\q1  
\v 3 Ndabvisa nguo yangu, 
\q2 ndoipfekazve here? 
\q1 Ndashambidza tsoka dzangu, 
\q2 ndodzisvibisazve here? 
\q1  
\v 4 Mudiwa wangu akapinza ruoko rwake nepahwangwadza yomukova; 
\q2 mwoyo wangu wakatanga kumudokwairira. 
\q1  
\v 5 Ndakasimuka kuti ndizarurire mudiwa wangu, 
\q2 maoko angu akadonha mura, 
\q1 mimwe yangu ichiyerera mura, 
\q2 pazvibato zvechizarira. 
\q1  
\v 6 Ndakazarurira mudiwa wangu, 
\q2 asi mudiwa wangu akanga abva; akanga atoenda. 
\q1 Mwoyo wangu wakarwadziwa nokuenda kwake. 
\q2 Ndakamutsvaka asi handina kumuwana. 
\q2 Ndakamudana asi haana kupindura. 
\q1  
\v 7 Varindi vakandiona 
\q2 pavaiva pabasa ravo rokufamba-famba vachichengetedza guta. 
\q1 Vakandirova, vakandikuvadza; 
\q2 vakanditorera jasi rangu, 
\q2 ivavo varindi vamasvingo! 
\q1  
\v 8 Imi vanasikana veJerusarema, ndinokurayirai, 
\q2 kana mukaona mudiwa wangu, 
\q1 muchamuudzeiko? 
\q2 Mumuudze kuti ndinorwara nerudo. 
\sp Shamwari 
\q1  
\v 9 Mudiwa wako akanaka kukunda vamwe pakudii, 
\q2 iwe zvako wakanaka kukunda vamwe vakadzi? 
\q1 Mudiwa wako akanaka kukunda vamwe pakudii, 
\q2 zvaunotirayira kudaro? 
\sp Mukadzi 
\q1  
\v 10 Mudiwa wangu akanaka uye mutsvuku, 
\q2 anokunda vanokwana zviuru gumi. 
\q1  
\v 11 Musoro wake igoridhe chairo; 
\q2 bvudzi rake rinoyevedza 
\q2 uye rakasviba segunguo. 
\q1  
\v 12 Meso ake akafanana nenjiva 
\q2 dziri pahova dzemvura, 
\q1 dzakashambidzwa mumukaka, 
\q2 akarongwa sezvishongo. 
\q1  
\v 13 Matama ake akaita semihomba yezvinonhuhwira 
\q2 inobereka zvinonhuhwira. 
\q1 Miromo yake yakaita samaruva amahapa 
\q2 anodonha mura. 
\q1  
\v 14 Maoko ake itsvimbo dzegoridhe 
\q2 dzakaiswa mabwe anokosha ekrisorite. 
\q1 Muviri wake wakaita senyanga dzenzou dzinobwinya 
\q2 dzakashongedzwa nesafire. 
\q1  
\v 15 Makumbo ake imbiru dzamabwe machena 
\q2 akamiswa pazvigadziko zvegoridhe rakanatswa. 
\q1 Chimiro chake chakaita seRebhanoni, 
\q2 chakanakisisa semisidhari yayo. 
\q1  
\v 16 Muromo wake inhapitapi pachayo; 
\q2 zvirokwazvo akaisvonaka. 
\q1 Uyu ndiye mudiwa wangu, ndiye shamwari yangu, 
\q2 imi vanasikana veJerusarema. 
\c 6  
\sp Shamwari 
\q1  
\v 1 Ko, mudiwa wako aendepiko, 
\q2 iwe zvako wakanaka kukunda vamwe vakadzi? 
\q1 Mudiwa wako aenda nokupiko, 
\q2 kuti tigomutsvaka pamwe chete newe? 
\sp Mukadzi 
\q1  
\v 2 Mudiwa wangu adzika kubindu rake, 
\q2 kumihomba yezvinonhuwirira, 
\q1 kuti andomema mumapindu 
\q2 uye agotanha maruva. 
\q1  
\v 3 Ini ndiri womudiwa wangu uye mudiwa wangu ndowangu; 
\q2 anomema pakati pamaruva. 
\sp Murume 
\q1  
\v 4 Wakanaka iwe mudiwa wangu, seTiriza, 
\q2 unoyevedza seJerusarema, 
\q2 unoremekedzeka samauto ane mireza. 
\q1  
\v 5 Bvisa meso ako pandiri; 
\q2 anondikunda. 
\q1 Bvudzi rako rakaita sedanga rembudzi 
\q2 riri kuburuka muGireadhi. 
\q1  
\v 6 Meno ako akafanana neboka ramakwai 
\q2 achangobva mukushambidzwa. 
\q1 Rimwe nerimwe rine rarakafanana naro, 
\q2 pasina riri roga zvaro. 
\q1  
\v 7 Zvavovo zvako zviri mumumbure wako 
\q2 zvakaita sezvikamu zviviri zvedamba. 
\q1  
\v 8 Kungava navanamambokadzi makumi matanhatu, 
\q2 navarongo makumi masere 
\q2 nemhandara dzisingaverengeki; 
\q1  
\v 9 Asi njiva yangu, iye akakwana wangu, 
\q2 ndiwe mumwe oga, mwanasikana mumwe oga wamai vake, 
\q2 iye woga anodikanwa naiye akamubereka. 
\q1 Mhandara dzakamuona dzikamuti akaropafadzwa. 
\q2 Vanamambokadzi navarongo vakamurumbidza. 
\sp Shamwari 
\q1  
\v 10 Ko, ndiani uyo anoratidzika samambakwedza, 
\q2 akanaka somwedzi, anopenya sezuva, 
\q2 akanaka senyeredzi dziri mumudungwe? 
\sp Murume 
\q1  
\v 11 Ndakadzika kusango remiti yemipfura 
\q2 kundoona zvitsva zvakamera mumupata, 
\q1 kundoona kana mizambiringa yainge yabukira, 
\q2 kana kuti mitamba yainge yava namaruva. 
\q1  
\v 12 Ndisati ndambodii, 
\q2 mwoyo wangu wakandiisa pakati pengoro dzoumambo dzavanhu vangu. 
\sp Shamwari 
\q1  
\v 13 Dzoka, dzoka iwe muShurami; 
\q2 dzoka, dzoka kuti timbokuona! 
\sp Mudiwa 
\q1 Ko, munodirei kuona muShurami 
\q2 sezvamunoita mutambo weMahanaimi? 
\c 7  
\q1  
\v 1 Dzakanaka sei tsoka dzako dzakapfekedzwa shangu, 
\q2 iwe mwanasikana womuchinda! 
\q1 Makumbo ako akanakisisa akaita sezvishongo, 
\q2 basa ramaoko emhizha. 
\q1  
\v 2 Guvhu rako rakatenderera somukombe 
\q2 unogara uine waini yakasanganiswa zvakanaka. 
\q1 Chiuno chako murwi wegorosi 
\q2 wakakomberedzwa namaruva. 
\q1  
\v 3 Mazamu ako akaita setsvana mbiri, 
\q2 mapatya emhara. 
\q1  
\v 4 Mutsipa wakaita seshongwe yakagadzirwa nenyanga dzenzou. 
\q1 Meso ako ndiwo madziva eHeshibhoni 
\q2 pasuo reBhati Rabhimi. 
\q1 Mhuno yako yakaita seshongwe yeRebhanoni 
\q2 yakatarisa kudivi reDhamasiko. 
\q1  
\v 5 Musoro wako unokushongedza nekorona seGomo reKarimeri. 
\q2 Bvudzi rako rakaita sezvirukwa zvomumba mamambo; 
\q2 mwoyo wamambo wakabatwa nokugadzirwa kwebvudzi rako. 
\q1  
\v 6 Wakanaka uye unofadza sei, 
\q2 iwe mudiwa nezvinofadza zvako! 
\q1  
\v 7 Chimiro chako chakaita somuti womuchindwe; 
\q2 uye mazamu ako samasumbu omuchero. 
\q1  
\v 8 Ndakati, “Ndichakwira muchindwi uyu, 
\q2 ndigobata muchero wawo.” 
\q1 Mazamu ako ngaaite samasumbu omuzambiringa, 
\q2 munhuwi wokufema kwako uite samaapuro, 
\q2  
\v 9 muromo wako ugoita sewaini yakanakisisa. 
\sp Mukadzi 
\q1 Waini ngaiendeswe kumudiwa wangu chaiko, 
\q2 igoyerera zvinyoronyoro, napamiromo yake nameno ake. 
\q1  
\v 10 Ini ndiri womudiwa wangu, 
\q2 uye iye anondishuva. 
\q1  
\v 11 Uya, mudiwa wangu, ngatiendei kumunda, 
\q2 tigozopedza usiku hwose kumaruwa. 
\q1  
\v 12 Ngatimukirei kuminda yemizambiringa 
\q2 tindoona kana mizambiringa yakabukira, 
\q1 uye kana maruva awo azaruka, 
\q2 uye kana mitamba yatumbuka yava namaruva, 
\q2 ikoko ndiko kwandichakupa rudo rwangu. 
\q1  
\v 13 Miti yemidiwadiwa inopa kunhuhwira kwayo, 
\q2 uye pamusuo pedu pane zvinonaka zvose, 
\q1 zvose zvitsva nezvitsaru, 
\q2 zvandakachengetera iwe, mudiwa wangu. 
\c 8  
\q1  
\v 1 Dai chete wakanga uri sehanzvadzi kwandiri, 
\q2 akanwa pamazamu amai vangu! 
\q1 Ipapo kana ndaikuwana panze, 
\q2 ndaikutsvoda 
\q2 uye hapana aizondishora. 
\q1  
\v 2 Ndaizokutora ndouya newe 
\q2 kumba kwamai vangu, 
\q2 ivo vakandidzidzisa. 
\q1 Ndaikupa waini yakaiswa zvinonhuhwira kuti unwe, 
\q2 nomukume wemitamba yangu. 
\q1  
\v 3 Ruoko rwake rworuboshwe rwuri pasi pomusoro wangu, 
\q2 uye ruoko rwake rworudyi rwakandimbundikira. 
\q1  
\v 4 Imi vanasikana veJerusarema ndinokurayirai: 
\q2 Musazunguza kana kumutsa rudo 
\q2 kusvikira irwo rwada rwoga. 
\sp Shamwari 
\q1  
\v 5 Ndianiko uyo ari kuuya achibva kurenje 
\q2 akazendamira pamudiwa wake? 
\sp Mukadzi 
\q1 Pasi pomuti womuapuro ndakakumutsa; 
\q2 ipapo mai vako vakakubereka, 
\q2 ipapo ivo vairwadziwa vakakubereka. 
\q1  
\v 6 Ndiise pamwoyo pako sechisimbiso, 
\q2 sechisimbiso paruoko rwako; 
\q1 nokuti rudo rwakasimba sorufu, 
\q2 godo rarwo seguva harishanduki. 
\q1 Runopisa serimi romoto, 
\q2 somurazvo mukuru kwazvo. 
\q1  
\v 7 Mvura zhinji haigoni kudzima rudo; 
\q2 nzizi hadzigoni kurukukura. 
\q1 Kunyange munhu akapa 
\q2 pfuma yose yemba yake kuti awane rudo, 
\q2 zvingazvidzwa chose. 
\sp Shamwari 
\q1  
\v 8 Tine hanzvadzi yedu duku 
\q2 uye mazamu ake haasati akura. 
\q1 Tichaitireiko hanzvadzi yedu 
\q2 pazuva rokukumbirwa kwayo kuti iwanikwe? 
\q1  
\v 9 Kana ari rusvingo, 
\q2 tichavaka shongwe dzesirivha paari. 
\q1 Kana ari musuo, 
\q2 tichamukomberedza namapuranga omusidhari. 
\sp Mukadzi 
\q1  
\v 10 Ndiri rusvingo, 
\q2 mazamu angu akaita seshongwe. 
\q1 Ndizvo zvandava pamberi pake, 
\q2 somunhu anouyisa kugutsikana. 
\q1  
\v 11 Soromoni aiva nomunda wemizambiringa muBhaari Hamoni; 
\q2 akapa munda wake wemizambiringa kuvanhu vairima vachimuripira. 
\q1 Mumwe nomumwe wavo pachibereko chawo 
\q2 aiuya namashekeri chiuru\f + \fr 8:11 \ft makirogiramu angaita 11.5 \f* esirivha. 
\q1  
\v 12 Asi munda wangu wemizambiringa ndewangu kuti ndiupe; 
\q2 chiuru chamashekeri esirivha ndechako, iwe Soromoni, 
\q2 asi mazana maviri\f + \fr 8:12 \ft makirogiramu angaita 2.3\f* ndeevanochengeta michero yawo. 
\sp Murume 
\q1  
\v 13 Iwe unogara mumapindu 
\q2 unoshandirwa neshamwari, 
\q2 rega ndinzwe inzwi rako! 
\sp Mukadzi 
\q1  
\v 14 Handei mudiwa wangu, 
\q2 uite semhara kana setsvana 
\q1 pamusoro pamakomo 
\q2 azere zvinonhuhwira.