\v 5 \w L|strong="H03068"\w*’\w ange|strong="H04397"\w* \w répondit|strong="H06030"\w* \w et|strong="H06030"\w* \w me|strong="H07307"\w* \w dit|strong="H06030"\w* : « \w Ce|strong="H03318"\w* \w sont|strong="H08064"\w* \w les|strong="H03318"\w* \w quatre|strong="H00702"\w* \w vents|strong="H07307"\w* \w du|strong="H03318"\w* \w ciel|strong="H08064"\w*\f + \fr 6:5 \ft \it Les quatre vents du ciel\it*, dont Dieu fait ses messagers et son char, et les exécuteurs de ses jugements.\f* \w qui|strong="H04397"\w* \w viennent|strong="H03318"\w* \w de|strong="H07307"\w* \w se|strong="H08064"\w* \w tenir|strong="H03320"\w* \w devant|strong="H04397"\w* \w le|strong="H03318"\w* \w Seigneur|strong="H00136"\w* \w de|strong="H07307"\w* \w toute|strong="H03605"\w* \w la|strong="H03318"\w* \w terre|strong="H00776"\w*. »
\v 6 \w Le|strong="H03318"\w* \w char|strong="H04818"\w* auquel \w il|strong="H01732"\w* \w y|strong="H08033"\w* \w a|strong="H03318"\w* \w des|strong="H03318"\w* \w chevaux|strong="H05483"\w* \w noirs|strong="H07838"\w* \w sortit|strong="H03318"\w* \w vers|strong="H03318"\w* \w le|strong="H03318"\w* \w pays|strong="H00776"\w* \w du|strong="H03318"\w* \w septentrion|strong="H06828"\w*\f + \fr 6:6 \ft \it Le pays du septentrion\it*, peut-être l’Assyrie et la Babylonie. — \it Le pays du midi\it*, peut-être l’Égypte, la plus ancienne ennemie du peuple de Dieu.\f* ; \w les|strong="H03318"\w* \w blancs|strong="H03836"\w* \w sortirent|strong="H03318"\w* \w après|strong="H00310"\w* \w eux|strong="H00310"\w*, \w et|strong="H03318"\w* \w les|strong="H03318"\w* \w tachetés|strong="H01261"\w* \w sortirent|strong="H03318"\w* \w vers|strong="H03318"\w* \w le|strong="H03318"\w* \w pays|strong="H00776"\w* \w du|strong="H03318"\w* \w midi|strong="H08486"\w*.
