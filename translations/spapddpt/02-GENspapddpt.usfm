\v 8 Oigan, \w les|strong="H5921"\w* \w ruego|strong="H4994"\w*, \w tengo|strong="H5921"\w* \w dos|strong="H8147"\w* \w hijas|strong="H1323"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* \w se|strong="H3045"\w* han unido \w a|strong="H3068"\w* varón. \w Las|strong="H5921"\w* sacaré \w a|strong="H3068"\w* ustedes \w ahora|strong="H4994"\w* \w y|strong="H3588"\w* \w hagan|strong="H6213"\w* \w con|strong="H5921"\w* \w ellas|strong="H5921"\w* \w como|strong="H3588"\w* \w les|strong="H5921"\w* parezca \w bien|strong="H2896"\w*, \w pero|strong="H3588"\w* \w nada|strong="H3808"\w* \w hagan|strong="H6213"\w* \w a|strong="H3068"\w* estos \w varones|strong="H3588"\w* \w que|strong="H3588"\w* vinieron \w a|strong="H3068"\w* cobijarse bajo \w mi|strong="H5921"\w* techo.   
