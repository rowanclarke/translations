\id LAM  
\h عَننَبِ يٍرٍ مِ قِرِن ندٍ 
\toc1 عَلَ شَ مَسٍنيِ قِرِن ندٍ عَننَبِ يٍرٍ مِ بّ 
\toc2 عَننَبِ يٍرٍ مِ قِرِن ندٍ 
\toc3 ٢يٍ 
\mt1 عَلَ شَ مَسٍنيِ قِرِن ندٍ عَننَبِ يٍرٍ مِ بّ 
\imt1 مَسٍنيِ ندٍ يِ كِتَابُي شَ قٍ رَ 
\ip عَننَبِ يٍرٍ مِ نَشَ كِتَابُي قِرِن سّبّ. كٍرٍن شِلِ «عَلَ شَ مَسٍنيِ عَننَبِ يٍرٍ مِ بّ.» بٌورٍ شِلِ، «عَلَ شَ مَسٍنيِ قِرِن ندٍ عَننَبِ يٍرٍ مِ بّ.» عٍ شَ مَسٍنيِ مَنِيَ. عٍ سّبّ وَشَتِ، عِسِرَيِلَ يَشُييٍ نُ نَ نْقٍ يُدَيَ نُن عَ شَ مَنفّ تَا دَرِ سَلَمُ رَ. عَلَتَلَ يَتِ نُ بَرَ نَ رَفِرِ عٍ شَ يُنُبِيٍ شَ قٍ رَ. نَ حَشَنكَتّ نُ شْرْشْ عَ فبٍ رَ بَرِ مَ عَ نُ قَتَنشِ عَلَ شَ شْنّ نَن نَ. 
\ip نَ كُي وٌن نْمَ سّرِيّ سَشَن تٌدٍ. عَ سِنفٍ، يُنُبِ مُ رَقَن عَلَ مَ. عَلَ تٌ سّنِيّنشِ، عَ مُ نْمَ لَندٍ سّنِيّنتَرٍحَ مَ. قٌ عَدَ مَ شَ عَ قَهَامُ عَ يُنُبِ رَحَاشُ عَلَ مَ، بَرِ مَ عَ مُ قِندِشِ عَ يُفٍ سّنِيّنشِ رَ. 
\ip عَ قِرِن ندٍ، عَلَ يُنُبِ سَرٍ رَفبِلٍنمَ نّ يُنُبِتْي مَ. عَلَ تٌ تِنشِنشِ، عَ مُ نْمَ عَ لُدٍ يُنُبِتْي مُ عَ شَ قٍ حَاشِ سَرٍ سْتْ. عَلَتَلَ شَ تِنشِنيِ عَ نِيَمَ نّ مِشِ شَ عٍ يُنُبِ سَرٍ سْتْ. عَلَ مُ نْمَ فبِلٍندٍ نَ تِنشِنيِ قْشْ رَ. 
\ip عَ سَشَن ندٍ، عَلَ وَ مَ يُنُبِتْي رَكِسِقٍ. عَلَ تٌ مِشِ شَنُشِ، عَ قٍ بِرِن نَبَمَ نّ عَلَكٌ عَ شَ عَدَ مَ مَتِنشِن، عَ شَ عَ شَ يُنُبِيٍ شَقَرِ، عَ شَ عَ رَكِسِ عَ شَ شَنُنتٍيَ سَابُي رَ. يِ مَسٍنيِ، نَشَن تٌمَ عَننَبِ يٍرٍ مِ شَ سّبّلِ تَفِ سٌرَ ٣‏؛٢١ ٬ ٣٢، عَ سّنبّ فبٌ. 
\ip عَلَ شَ وٌن مَلِ نَ سّرِيّ بِرِن قَهَامُدٍ. عَمِنَ. 
\mt1 عَلَ شَ مَسٍنيِ قِرِن ندٍ عَننَبِ يٍرٍ مِ بّ 
\c 1  
\s1 دَرِ سَلَمُ شَ حْنيِ بّيتِ 
\sp عَننَبِ يٍرٍ مِ شَ مَسٍنيِ 
\q1  
\v 1 مُنسٍ دَرِ سَلَمُ سْتْشِ؟ 
\q1 سِنفٍ مِشِ نُ وُيَ، 
\q1 كْنْ يَكْسِ عٍ مُ وُيَ. 
\q1 عَ بَرَ لُ عَلْ كَاحّ فِنّ. 
\q1 سِنفٍ عَ شِلِ نُ شُنفبٌ حَمَنّيٍ تَفِ، 
\q1 عَ قِندِ مَنفّ تَا نَن نَ عٍ يَ مَ، 
\q1 كْنْ يَكْسِ عَ نَ كٌنيِيَ كُي. 
\q1  
\v 2 كْي بِرِن عَ وَقٍ، 
\q1 عَ يَيٍ نُ عَ شّرّيٍ مَشَ. 
\q1 عَ شَنُنتٍنيِيٍ مُ نَ سْنْن نَشٍيٍ عَ مَدُندُ مَ. 
\q1 عَ بٌورٍيٍ بِرِن بَرَ عَ يَنقَ، عٍ قِندِ عَ يَشُييٍ رَ. 
\q1  
\v 3 عٍ بَرَ يُدَ بْنسْي شَنِن كٌنيِيَ كُي، 
\q1 عٍ عَ رَيَافِ. 
\q1 يَكْسِ عَ دْشْشِ سِيٍ تَفِ، مَلَبُي يٌ مُ نَ عَ بّ. 
\q1 عَ يَشُييٍ عَ تْورْ مَ. 
\q1  
\v 4 مِشِ يٌ مُ نَ سِيٌن كِرَيٍ شْن مَ سْنْن، سِفَقٍ سَلِدٍ. 
\q1 سِيٌن شَ نَادّيٍ بِرِن بَرَ كَنَ، 
\q1 عَ شَ سّرّشّدُبّيٍ تْورْقٍ، 
\q1 عَ شَ فِنّدِ مّدِيٍ سُننُنقٍ. 
\q1 سِيٌن نَ قٍ شْنّ نَن كُي. 
\q1  
\v 5 عَ يَشُييٍ بَرَ نْ عَ رَ، عٍ قَ لُ بْحّسَ كُي. 
\q1 عَلَتَلَ نَ رَفِرِشِ، سِيٌن شَ قٍ حَاشِيٍ نَن مَ قٍ رَ. 
\q1 عَ فٍرٍقَيٍ بَرَ عَ شَ دِيٍ شَنِن كٌنيِيَ كُي. 
\q1  
\v 6 سِيٌن سّنبّ بِرِن بَرَ كَنَ. 
\q1 عَ شَ كُنتِفِيٍ بَرَ لُ عَلْ شٍلِ، 
\q1 نَشٍيٍ مُ حٌوفٍ تٌمَ، 
\q1 نَشٍيٍ بَرَ تَفَن كٌيِنمَ يَ رَ. 
\q1  
\v 7 دَرِ سَلَمُ شَ يَافِ نُن عَ شَ كُي عِقُي كُي، 
\q1 عَ بَرَ عَ مَحْشُن عَ شَ سٍ قَنيِيٍ بِرِن شَ قٍ، 
\q1 نَشٍيٍ نُ نَ عَ يِ رَ تّمُي دَنفِشِ. 
\q1 عَ شَ حَمَ تٌ سَ عَ فٍرٍقَيٍ بّلّشّ، 
\q1 عَ مَلِمَ يٌ مُ نُ نَ. 
\q1 عَ يَشُييٍ نَشَ يٍلٍ عَ شَ كَسَرّ مَ. 
\q1  
\v 8 دَرِ سَلَمُ شَ يُنُبِ بَرَ فبٌ، 
\q1 عَ بَرَ قِندِ سّنِيّنتَرٍ رَ. 
\q1 نَشٍيٍ بِرِن نُ عَ مَتْشْمَ، 
\q1 عٍ نَ يٌقٍ عَ مَ يَكْسِ. 
\q1 عَ بَرَ لُ عَلْ مِشِ مَفٍلِ، 
\q1 عَ يَافِ، عَ قَ عَ يّتّ نْشُن. 
\q1  
\v 9 نْشْي نُ نَ عَ شَ دُفِ مَ، 
\q1 كْنْ عَ مُ عَ مَحْشُن عَ شَ قٍ رَحْنيِ مَ. 
\q1 كَسَرّ نَشَن عَ مَسْتْ، عَ مَفَاشُ. 
\q1 مِشِ يٌ مُ نَ، نَشَن عَ مَدُندُ مَ. 
\sp سِيٌن شَ مَسٍنيِ 
\q1 «عَلَتَلَ، ﭑ مَ مَرَيَافِ مَتٌ، 
\q1 بَرِ مَ ﭑ يَشُييٍ بَرَ شُننَكٍلِ سْتْ.» 
\sp عَننَبِ يٍرٍ مِ شَ مَسٍنيِ 
\q1  
\v 10 عَ يَشُييٍ بَرَ عَ شَ سٍ قَنيِ بِرِن تٌنفٌ. 
\q1 عَ سِ فبّتّيٍ تٌ نّ سٌ رَ عَ شَ سَلِدٍ كُي، 
\q1 نَشٍيٍ مُ دَشَ عٍ شَ سٌ نَا. 
\q1  
\v 11 عَ شَ حَمَ بِرِن بَرَ كْنتْقِلِ بَلٌي قٍندٍ. 
\q1 عٍ بَرَ عٍ شَ نَاقُلِ بِرِن مَسَرَ دٌنسٍ رَ، عَلَكٌ عٍ شَ بَلٌ. 
\sp سِيٌن شَ مَسٍنيِ 
\q1 «عَلَتَلَ، ﭑ مَ يَافِ مَتٌ. 
\q1  
\v 12 عَلَ شَ دَنفِ مِشِ رَتَنفَ نَ قٍ مْولِ مَ. 
\q1 وٌ عَ مَتٌ شَ ﭑ مَ تْورّ مَنِيّ نَ قٍ رَ، 
\q1 عَلَتَلَ نَشَن دْشْشِ ﭑ مَ عَ شَ شْنّ كُي. 
\q1  
\v 13 عَ بَرَ تّ رَفٌرٌ كٍلِقٍ كٌورٍ، نَشَن بَرَ ﭑ قَتٍ فَن. 
\q1 عَ بَرَ فَنتَنيِ تِ ﭑ بّ، عَ يّلّ عِتَلَ ﭑ سَنتِدٍ. 
\q1 عَ بَرَ ﭑ نَبِرَ بْشِ، عَ ﭑ هَلَكِشِ لُ نَا. 
\q1  
\v 14 عَ بَرَ ﭑ مَ يُنُبِيٍ سَرٍ سَ ﭑ كْن مَ عَلْ كَرَقٌي. 
\q1 عَ بَرَ ﭑ سّنبّ شُن نَكَنَ. 
\q1 عَلَتَلَ بَرَ ﭑ سَ ﭑ يَشُييٍ بّلّشّ، نَشٍيٍ سّنبّ فبٌ ﭑ بّ. 
\q1  
\v 15 عَ بَرَ ﭑ مَ فٍرٍ سٌي بِرِن مَتُتُن، نَشٍيٍ نُ نَ ﭑ بّ. 
\q1 عَ بَرَ ﭑ يَشُييٍ مَشِلِ، 
\q1 عَلَكٌ عٍ شَ ﭑ مَ قٌنِكٍيٍ سّنبّ كَنَ. 
\q1 عَلَتَلَ بَرَ يُدَ بْنسْي شَ دِ هَلَكِ عَ حَاشِ رَ. 
\q1  
\v 16 ﭑ نَ وَقٍ يِ تْورّ نَن مَ، ﭑ يَيٍ رَ مِنِمَ عٍ بّ. 
\q1 نَشَن ﭑ مَدُندُ مَ، عَ فبِلٍن لِمَنِيَ قِ رَ ﭑ مَ. 
\q1 نَ بَرَ مَكُيَ ﭑ نَ. 
\q1 ﭑ مَ دِيٍ بَرَ هَلَكِ، 
\q1 بَرِ مَ يَشُي سّنبّ نُ فبٌ ﭑ بّ. 
\q1  
\v 17 سِيٌن بَرَ عَ بّلّشّيٍ عِتَلَ، 
\q1 كْنْ مِشِ يٌ مُ نَ نَشَن عَ مَدُندُ مَ. 
\q1 عَلَتَلَ بَرَ يَامَرِ قِ يَشُبَ دْشْبٌورٍيٍ شَ قِندِ عَ فٍرٍقَيٍ رَ. 
\q1 دَرِ سَلَمُ بَرَ قِندِ سّنِيّنتَرٍ رَ عٍ تَفِ. 
\q1  
\v 18 عَلَتَلَ شَ مَرَفِرِ تِنشِن، 
\q1 بَرِ مَ ﭑ بَرَ عَ شَ يَامَرِيٍ مَتَندِ. 
\q1 وٌ تَن سِ بِرِن، وٌ وٌ تُلِ مَتِ، 
\q1 وٌ شَ ﭑ مَ تْورّ مَتٌ. 
\q1 ﭑ مَ فِنّدِ مّدِيٍ نُن ﭑ مَ قٌنِكٍ شّمّيٍ بِرِن بَرَ شَنِن كٌنيِيَ كُي. 
\q1  
\v 19 ﭑ بَرَ ﭑ شَنُنتٍنيِيٍ شِلِ، كْنْ عٍ بَرَ ﭑ يَنقَ. 
\q1 ﭑ مَ سّرّشّدُبّيٍ نُن ﭑ مَ قٌرِيٍ بَرَ قَشَ تَا كُي. 
\q1 عٍ قَشِ دٌنسٍ قٍندٍ نَشَن نْمَ سّنبّ دِ قِدٍ عٍ مَ. 
\q1  
\v 20 عَلَتَلَ، ﭑ مَ تْورّ مَتٌ. 
\q1 ﭑ بْحّ مُ رَقَنشِ ﭑ مَ، 
\q1 بَرِ مَ ﭑ عَ كٌلٌن ﭑ مّي نّ عِ شَ سّرِيّ رَ، 
\q1 ﭑ قِندِ مَتَندِلَ يَتِ نَن نَ. 
\q1 سَنتِدّفّمَ مِشِ سْنتْ تَا قَرِ مَ، 
\q1 قُرٍ حَاشِ مِشِ قَشَمَ تَا كُي. 
\q1  
\v 21 مِشِيٍ بَرَ ﭑ وَ شُي مّ، 
\q1 كْنْ مِشِ يٌ مُ نَ نَشَن ﭑ مَدُندُ مَ. 
\q1 ﭑ يَشُييٍ بِرِن بَرَ ﭑ مَ تْورّ شَ قٍ مّ، 
\q1 عٍ بَرَ حّلّشِن عِ بّلّشّ قْشِ رَ. 
\q1 عِ بَرَ قَ لْشْي رَ، عِ لْشْي نَشَن مَ قٍ قَلَ. 
\q1 عَ نِيَ ﭑ يَشُييٍ قَن شَ لُ عَلْ ﭑ تَن. 
\q1  
\v 22 عِ شَ عٍ شَ حَاشُحَ بِرِن مَتٌ. 
\q1 عِ شَ عَ نِيَ عٍ قَن نَ عَلْ عِ عَ نِيَشِ ﭑ نَ كِ نَشّ، 
\q1 ﭑ مَ قٍ كٌبِ رَبَشِ مَ. 
\q1 ﭑ مَ كْنتْقِلِ وُيَ، ﭑ بْحّ تْورْشِ عَ فبٍ رَ.» 
\c 2  
\s1 هْرْ مْبَنشِ شَ كَنّ 
\sp عَننَبِ يٍرٍ مِ شَ مَسٍنيِ 
\q1  
\v 1 عَلَتَلَ شَ شْنّ بَرَ عَ نِيَ 
\q1 كُيٍ شَ عِقْورْ دَرِ سَلَمُ شُن مَ. 
\q1 عَ بَرَ بَرَكّ بَ عِسِرَيِلَ مَ. 
\q1 عَ تٌ شْنْ، عَ نَشَ عِسِرَيِلَ رَبٌلٌ، 
\q1 عَ نُ حّرّ مَ حَمَ نَشَن يَ مَ. 
\q1  
\v 2 مَرِفِ مُ كِنِكِنِ عٍ مَ. 
\q1 عَ بَرَ يَشُبَ شَ بَنشِ بِرِن كَنَ، 
\q1 عَ بَرَ يُدَيَ تَا مَكَنتَشِيٍ رَبِرَ، 
\q1 عَ عٍ شَ مَنفّيَ مَسَرَ يَافِ رَ عَ شَ شْنّ كُي. 
\q1  
\v 3 عَ تٌ شْنْ عٍ مَ، عَ بَرَ عِسِرَيِلَ سّنبّ بِرِن كَنَ. 
\q1 عٍ يَشُييٍ تٌ نُ عٍ عِشّتّنقٍ، 
\q1 عَلَ بَرَ تٌندِ عِسِرَيِلَ مَلِدٍ. 
\q1 نَ شُننَكَنّ بَرَ لُ عَلْ تّ سٌشِ، 
\q1 عَ يَشُبَ شَ بْشِ بِرِن فَن. 
\q1  
\v 4 عَ بَرَ عَ شَ شَلِ سُشُ وٌن شِلِ مَ 
\q1 عَلْ وٌن يَشُي عَ رَبَمَ كِ نَشّ. 
\q1 عَ بَرَ وٌن بْنبْ سّنبّ رَ 
\q1 عَلْ عَ قِندِ وٌن فٍرٍقَ نَن نَ. 
\q1 عَ بَرَ وٌن مَ مِشِ بِرِن قَشَ، 
\q1 وٌن نُ حّلّشِنمَ نَشٍيٍ رَ. 
\q1 عَ شَ شْنّ بَرَ لُ عَلْ تّ 
\q1 نَشَن بَرَ سٌ دَرِ سَلَمُ هْرْ مْبَنشِ كُي. 
\q1  
\v 5 عَلَتَلَ بَرَ لُ عَلْ وٌن يَشُي. 
\q1 عَ بَرَ عِسِرَيِلَ نُن عَ شَ بَنشِ قَنيِيٍ بِرِن كَنَ. 
\q1 عَ بَرَ عَ شَ يِرٍ مَكَنتَشِيٍ رَبِرَ. 
\q1 عَ بَرَ يُدَيَ شَ كِنِكِنِ نُن سُننُنيِ شُنمَسَ. 
\q1  
\v 6 عَ بَرَ عَ سّنبّ رَ مِنِ نَ مَ، 
\q1 عَ عَ شَ مِشِيٍ مَلَندٍ كَنَ. 
\q1 عَلَتَلَ بَرَ عَ نِيَ 
\q1 سَلِ شُنفبٍ نُن مَلَبُي لْشْي سَلِ شَ نّيمُ سِيٌن نَ. 
\q1 عَ بَرَ مَنفّ نُن سّرّشّدُبّ رَيَافِ عَ شَ شْنّ كُي. 
\q1  
\v 7 عَلَتَلَ بَرَ مَكُيَ عَ شَ سّرّشّبَدٍ رَ، 
\q1 عَ مّي عَ شَ يِرٍ سّنِيّنشِ رَ. 
\q1 عَ بَرَ سِيٌن بَنشِ قَنيِيٍ سَ وٌن يَشُي بّلّشّ. 
\q1 وٌن يَشُييٍ بَرَ فٍرٍ سْنشْي رَتٍ عَلَتَلَ شَ بَنشِ كُي. 
\q1 نَ شُي نُ فبٌ عَلْ شُي نَشَن عِتٍمَ سَلِ لْشْي. 
\q1  
\v 8 عَلَتَلَ نَن عَ حَنِفٍ عَ شَ سِيٌن تّتّ رَبِرَ. 
\q1 عَ مُ سِيكّ عَ رَبَقٍ مَ. 
\q1 عَ بَرَ تّتّ قَرِ نُن عَ بُنيِ بِرِن نَبِرَ. 
\q1  
\v 9 عَ بَرَ تَا نَادّيٍ رَبِرَ بْشِ، 
\q1 عٍ بَلَندٍيٍ بِرِن بَرَ كَنَ. 
\q1 مَنفّيٍ نُن كُنتِفِيٍ بَرَ شَنِن حَمَنّ فبّتّ مَ. 
\q1 سّرِيّ رَبَتُقٍ مُ نَ، 
\q1 شّيرَيَ قَن مُ نَ نَمِحْنمّيٍ بّ. 
\q1  
\v 10 سِيٌن قٌرِيٍ دْشْشِ بْشِ، عٍ دّ بَرَ بٌبٌ، 
\q1 عٍ بَرَ شُبٍ مَسٌ عٍ شُنيِيٍ مَ سُننُنيِ شَ قٍ رَ، 
\q1 عٍ بَرَ سُننُن دٌنمَيٍ رَفٌرٌ عٍ مَ. 
\q1 دَرِ سَلَمُ فِنّدِ مّدِيٍ بَرَ عٍ شُن سِن بْشِ. 
\q1  
\v 11 ﭑ يَيٍ بَرَ مِنِ هَن، ﭑ بْحّ بَرَ ﭑ تْورْ، 
\q1 ﭑ سٌندٌنيِ بَرَ سُننُن ﭑ مَ حَمَ شَ فبَلٌي شَ قٍ رَ. 
\q1 دِ مّيٍ نُن دِيْرّيٍ نَ قَشَقٍ تَا كُي. 
\q1  
\v 12 دِ مّيٍ عَ قَلَمَ عٍ نفَيٍ بّ، 
\q1 «دٌنسٍ نُن مِنسٍ سْتْمَ مِندٍن؟» 
\q1 عٍ نُ سِفَ تُشُنسَن نَ عَلْ مِشِ مَشْنْشِيٍ، 
\q1 عٍ بِرَ تَا كُي كِرَيٍ رَ، 
\q1 عٍ حّنفِ بٌلٌن عٍ نفَيٍ بّلّشّ. 
\q1  
\v 13 ﭑ قَ مُنسٍ قَلَمَ عِ بّ كْرّ؟ 
\q1 سِيٌن، عِ مَنِيّ مُ نَ ﭑ بّ. 
\q1 ﭑ عِ مَدُندُ مَ دِ؟ 
\q1 عِ شَ حَشَنكَتّ بَرَ فبٌ دَنفِ بَا رَ. 
\q1 ندٍ نْمَ عِ رَيَلَندٍ؟ 
\q1  
\v 14 عِ شَ نَمِحْنمّيٍ بَرَ وُلٍ لَامَتُنيِيٍ مَسٍن، 
\q1 عٍ مُ عِ شَ يُنُبِ قِيشّ عِ بّ، 
\q1 عَلَكٌ عِ نَشَ قَ لُ كٌنيِيَ كُي. 
\q1 عٍ بَرَ وٌ مَدَشُ وُلٍ لَامَتُنيِيٍ رَ. 
\q1  
\v 15 دَنفِ مِشِ بِرِن عٍ بّلّشّ بْنبْمَ عِ مَ، 
\q1 عٍ كٌلِنمَ، عٍ عٍ شُنيِيٍ مَلِنتَنمَ دَرِ سَلَمُ شَ قٍ رَ. 
\q1 عٍ عَ قَلَمَ، «سِنفٍ يِ تَا تٌقَنيِ مَنِيّ مُ نُ نَ دُنِحَ، 
\q1 كْنْ يَكْسِ فٌ؟» 
\q1  
\v 16 عِ يَشُييٍ بِرِن نَ وٌ مَقَلَقٍ، 
\q1 عٍ كٌلِنمَ، عٍ عٍ حِنيِيٍ مَشِنمَ وٌ شَ قٍ رَ، 
\q1 عٍ نُ عَ قَلَ، «وٌن بَرَ عٍ شُن نَكَنَ 
\q1 عَلْ وٌن نُ وَ مَ عَ شْن مَ كِ نَشّ. 
\q1 نَ بَرَ سْونّيَ وٌن بّ.» 
\q1  
\v 17 عَلَتَلَ نَشَن حَنِفٍ، عَ نَ نَن نَبَشِ. 
\q1 عَ بَرَ عَ شَ وْيّنيِ رَكَمَلِ، 
\q1 عَ نَشَن مَسٍن تّمُي شْننَكُيٍ. 
\q1 عَ بَرَ كَنَرِ رَبَ، عَ مُ كِنِكِنِ. 
\q1 عَ بَرَ عَ نِيَ عِ يَشُييٍ شَ عِ مَيٍلٍ. 
\q1 عَ بَرَ عِ فٍرٍقَيٍ سّنبّ رَفبٌ يّ. 
\q1  
\v 18 مِشِيٍ نَ وَقٍ مَرِفِ رَ عٍ بْحّ بِرِن نَ. 
\q1 سِيٌن حَمَ، يَيٍ رَ مِنِ عَلْ شُرٍ. 
\q1 عِ نَشَ عِ مَلَبُ، عِ شَ وَ تُن. 
\q1  
\v 19 كٍلِ، سْنشْي رَتٍ كْي رَ. 
\q1 عِ بْحّ رَيٍنسٍن يّ عَلْ يٍ، مَرِفِ يَ تٌدٍ رَ. 
\q1 عِ بّلّشّ تِ عَ بّ عِ شَ دِيٍ شَ سِمَيَ شَ قٍ رَ، 
\q1 بَرِ مَ عٍ نَ هَلَكِقٍ كَامّ رَ تُنشُنيِيٍ بِرِن نَ. 
\q1  
\v 20 عَلَتَلَ، عِ يَ تِ عِ بَرَ يِ نِيَ نَشٍيٍ رَ. 
\q1 عَ لَن فِنّيٍ شَ عٍ شَ دِيٍ دٌن، عٍ نَشٍيٍ بَرِ؟ 
\q1 عَ لَن سّرّشّدُبّيٍ نُن نَمِحْنمّيٍ شَ قَشَ مَرِفِ شَ هْرْ مْبَنشِ كُي؟ 
\q1  
\v 21 قٌنِكٍيٍ نُن شّمْشِيٍ، عٍ بِرِن لَنتَنشِ بْشِ مَ تَا تُنشُنيِيٍ رَ. 
\q1 ﭑ مَ فِنّدِ مّدِيٍ نُن ﭑ مَ سّفّتَلَيٍ، سَنتِدّفّمَ بَرَ عٍ بِرِن قَشَ. 
\q1 عِ بَرَ قَشّ تِ عِ شْنْ لْشْي. 
\q1 عِ بَرَ عٍ كْن نَشَبَ، عِ مُ كِنِكِنِ. 
\q1  
\v 22 عِ بَرَ ﭑ يَشُييٍ مَلَن ﭑ شِلِ مَ، 
\q1 عَلْ مِشِيٍ مَلَنمَ كِ نَشّ سَلِ لْشْي. 
\q1 عَلَتَلَ شْنْ لْشْي، مِشِ يٌ مُ لُ، مِشِ قَن مُ عَ عِمِنِ. 
\q1 ﭑ نَشٍيٍ شَنُ، ﭑ نَشٍيٍ رَ مْ، 
\q1 ﭑ يَشُييٍ بَرَ عٍ بِرِن قَشَ. 
\c 3  
\s1 تْورّ نُن عَلَ شَ مَرَقَنيِ 
\sp عَننَبِ يٍرٍ مِ شَ مَسٍنيِ 
\q1  
\v 1 مِشِ نَن ﭑ نَ، نَشَن بَرَ تْورّ كٌلٌن عَلَ شَ شْنّ سَابُي رَ. 
\q1  
\v 2 عَ بَرَ ﭑ تٌنفٌ كُيٍ عِيَلَنشِ، 
\q1 عَ ﭑ نَحّرّ دِ مِ كُي. 
\q1  
\v 3 عَ ﭑ تْورْ مَ لْشْي بِرِن. 
\q1 دَنيِ يٌ مُ نَ ﭑ مَ تْورّ مَ 
\q1  
\v 4 عَ بَرَ ﭑ نَشْسِ كٍلِقٍ ﭑ شُنيِ مَ سَ دْشْقٍ ﭑ سَنيِيٍ رَ. 
\q1 عَ بَرَ ﭑ شْرِيٍ بِرِن مَفِرَ. 
\q1  
\v 5 عَ بَرَ ﭑ تْورْ، عَ ﭑ نَبِلِن حَشَنكَتّ رَ. 
\q1  
\v 6 عَ بَرَ ﭑ لُ دِ مِ كُي عَلْ سِنفٍ رَ مِشِ قَشَشِيٍ. 
\q1  
\v 7 عَ بَرَ ﭑ نَبِلِن سَنسَنيِ رَ، 
\q1 عَ يْلْنشْنيِ سَ ﭑ مَ، عَلَكٌ ﭑ نَشَ قَ مِنِ. 
\q1  
\v 8 ﭑ بَرَ فبٍلٍفبٍلٍ، ﭑ بَرَ شِلِ تِ دّ مّرِ رَ، 
\q1 كْنْ عَ بَرَ نَادّ بَلَن ﭑ مَ مَشَندِ مَ. 
\q1  
\v 9 عَ بَرَ كِرَ بَلَن ﭑ يَ رَ فّمّ بٍلٍبٍلٍيٍ رَ، 
\q1 عَ ﭑ تِ تْورّ كِرَ شْن مَ. 
\q1  
\v 10 عَ بَرَ لُ عَلْ سُبٍ شَاحّ نَشَن ﭑ مَمّقٍ بُرُنيِ، 
\q1 عَلْ يّتّ نَشَن عَ نْشُنشِ ﭑ يَ رَ. 
\q1  
\v 11 عَ بَرَ دُنِحَ عِشُتُ ﭑ مَ، عَ بَرَ ﭑ كَنَ. 
\q1  
\v 12 عَ بَرَ عَ شَ شَلِ عِتَلَ عَ عَ شَ تَنبّيٍ تِ ﭑ نَ. 
\q1  
\v 13 عَ تٌ عَ شَ تَنبّيٍ بّحِن، عٍ نَشَ ﭑ بْحّ سْشْ. 
\q1  
\v 14 ﭑ بَرَ قِندِ ﭑ مَ مِشِ بِرِن مَ مَيٍلٍ سٍ رَ، 
\q1 لْشْي بِرِن، عٍ ﭑ قِندِ مَ عٍ شَ سِفِيٍ رَ. 
\q1  
\v 15 عَ بَرَ ﭑ نَلُفَ حٌوفٍ شْنّ رَ، 
\q1 عَ بَرَ شْنّ قِندِ ﭑ مَ دٌنسٍ رَ. 
\q1  
\v 16 عَ بَرَ عَ نِيَ ﭑ شَ فّمّ شْرِيٍ مَشِن، 
\q1 هَن ﭑ حِنيِيٍ بِرِن بَرَ مَفِرَ. 
\q1 عَ بَرَ ﭑ مَبٌرٌن شُبٍ شْورَ. 
\q1  
\v 17 عَ بَرَ بْحّسَ مَكُيَ ﭑ نَ 
\q1 هَن قٍ قَنيِ مْولِ بِرِن بَرَ نّيمُ ﭑ نَ. 
\q1  
\v 18 نَ نَن عَ تٌشِ ﭑ بَرَ عَ قَلَ، 
\q1 «ﭑ مَ قٍ بَرَ كَنَ. 
\q1 عَلَتَلَ بَرَ ﭑ كُمَ سٍ بِرِن نَ ﭑ شَشِلِ نُ تِشِ نَشٍيٍ رَ.» 
\q1  
\v 19 ﭑ بَرَ ﭑ مَحْشُن ﭑ مَ مَرَيَافِ مَ، 
\q1 ﭑ بَرَ ﭑ مَحْشُن ﭑ مَ سِمَيَ نَشَسِشِ مَ. 
\q1  
\v 20 ﭑ مُ نْمَ نّيمُدٍ ﭑ مَ تْورّ مَ. 
\q1 عَ شُن بَرَ مَسَ هَن عَ بَرَ فّ ﭑ كُنتِندٍ. 
\b  
\q1  
\v 21 كْنْ نَ بِرِن كُي، ﭑ نَن ﭑ شَشِلِ تِمَ قٍ نَشَن نَ، عَ تَن نَن يَ؛ 
\q1  
\v 22 عَلَتَلَ شَ هِننّ مُ حْنمَ، 
\q1 دَنيِ يٌ مُ نَ عَ شَ شَنُنتٍيَ مَ. 
\q1  
\v 23 عَ فبِلٍنمَ عَ رَ فّيسّفّ يٌ فّيسّفّ. 
\q1 «عَلَتَلَ، عِ مُ مّيمَ عِ شَ مِشِيٍ رَ عَبَدَن!» 
\q1  
\v 24 ﭑ عَ كٌلٌن ﭑ بْحّ كُي، 
\q1 عَلَتَلَ نَن نَ ﭑ هَرِفٍ رَ. 
\q1 ﭑ شَشِلِ تِشِ عَ تَن نَن نَ. 
\b  
\q1  
\v 25 عَلَتَلَ قٍ قَنيِ رَبَمَ عَ قٍنمَ بّ، 
\q1 نَشَن شَشِلِ تِشِ عَ رَ. 
\q1  
\v 26 مِشِ لَن عَ شَ سَبَرِ عَلَتَلَ يَ عِ نَشَن قَمَ عَ رَكِسِدٍ. 
\q1  
\v 27 عَ لَنمَ عَدَ مَ شَ تْورّ كٌلٌن عَ قٌنِكٍ تّمُي. 
\q1  
\v 28 عَ شَ دُندُ، عَ شَ دْشْ عَ شَتِ مَ، 
\q1 بَرِ مَ عَلَتَلَ نَن عَ رَفِرِشِ عَ مَ. 
\q1  
\v 29 عَ شَ عَ شُن سِن بْشِ، تّمُندٍ عَلَ قَمَ نّ عَ شَ دُبّ سُشُدٍ. 
\q1  
\v 30 عَ شَ عَ شّرّ تِ مِشِ بّ، نَشَن عَ رَفَرِنمَ، 
\q1 عَ شَ تِن نَ يَافِ رَ. 
\q1  
\v 31 مَرِفِ مُ مِشِ رَتُتُنمَ عَبَدَن. 
\b  
\q1  
\v 32 عَ نَ مِشِ ندٍ تْورْ، عَ مَن قَمَ نّ هِننّدٍ عَ رَ عَ شَ قٌنِسِرٍيَ كُي. 
\q1  
\v 33 عَ وَشْنقٍ شَ مُ عَ رَ، 
\q1 عَ شَ مِشِ رَيَافِ، عَ شَ عِبُنَدَ مَ تْورْ. 
\q1  
\v 34 مِشِ نَ فٍيلِمَنِيٍ تْورْ عَ حَاشِ رَ بْشِ كُي، 
\q1  
\v 35 عٍ نَ تِنشِنتَرٍيَ رَبَ مِشِ رَ عَلَ شُنفبٍ يَ عِ، 
\q1  
\v 36 عٍ نَ مِشِ تْوحّفّ عَ مَكِيتِ تّمُي، 
\q1 عَلَتَلَ مُ عَ بِرِن تٌمَ شّ؟ 
\b  
\q1  
\v 37 ندٍ نْمَ قٍ رَ، شَ عَلَ شَ مُ عَ رَفِرِشِ؟ 
\q1  
\v 38 قٍ قَنيِ نُن قٍ حَاشِ، عَ بِرِن مُ كٍلِمَ عَلَ شُنفبٍ شُي شَ مَ؟ 
\q1  
\v 39 مُنقٍ رَ عِبُنَدَ مَ عَ مَوَ مَ، 
\q1 شَ عَ تْورّ سْتْ عَ يّتّ شَ يُنُبِ سَابُي رَ؟ 
\q1  
\v 40 وٌن شَ وٌن حّرّ كِ مَتٌ، وٌن شَ عَ عِفبّ، 
\q1 وٌن شَ فبِلٍن عَلَتَلَ مَ. 
\q1  
\v 41 وٌن شَ عَلَ مَشَندِ وٌن بْحّ بِرِن نَ، 
\q1 وٌن شَ وٌن بّلّشّ عِتٍ عَلَ بّ نَشَن نَ كٌورٍ مَ. 
\sp حَمَ شَ عَلَ مَشَندِ 
\q1  
\v 42 «مُشُ شَ يُنُبِ نُن مَتَندِ بَرَ فبٌ، 
\q1 عِ قَن مُ دِحّشِ مُشُ مَ. 
\q1  
\v 43 عِ شَ بْحّ شْنّ بَرَ لُ مُشُ قْشْ رَ، 
\q1 عِ بَرَ قَشّ تِ، عِ مُ كِنِكِنِ. 
\q1  
\v 44 عِ بَرَ نُشُي تِ وٌن تَفِ، 
\q1 عَلَكٌ مُشُ شَ مَشَندِ نَشَ عِ لِ. 
\q1  
\v 45 عِ بَرَ مُشُ قِندِ سُوتِ رَ حَمَنّيٍ تَفِ. 
\q1  
\v 46 مُشُ يَشُييٍ بِرِن بَرَ عٍ دّ عِبِ مُشُ شِلِ مَ. 
\q1  
\v 47 فَاشُي نُن بْحّ مِنِ بَرَ نْ مُشُ رَ، 
\q1 مُشُ شَ قٍ قِندِشِ كَنَرِ نُن فبَلٌي نَن تُن نَ. 
\q1  
\v 48 ﭑ يَ سُو سَمَ يَيٍ رَ، ﭑ مَ مِشِيٍ شَ فبَلٌي شَ قٍ رَ. 
\q1  
\v 49 دَنيِ يٌ مُ نَ ﭑ وَقٍ مَ، مَلَبُي يٌ مُ نَ ﭑ بّ، 
\q1  
\v 50 هَن بٍينُن عَلَتَلَ شَ عَ يَ رَفٌرٌ وٌن مَ. 
\q1  
\v 51 ﭑ بَرَ كِنِكِنِ فِنّدِ مّدِيٍ شَ تْورّ مَ.» 
\sp عَننَبِ يٍرٍ مِ شَ عَلَ مَشَندِ 
\b  
\q1  
\v 52 مِشِيٍ بَرَ ﭑ كٍرِ عَلْ شْنِ، 
\q1 هَلِ ﭑ مُ قٍ حَاشِ يٌ رَبَشِ عٍ رَ. 
\q1  
\v 53 عٍ بَرَ ﭑ نَفٌرٌ كْلْنيِ كُي، 
\q1 عٍ نُ قَ فّمّيٍ رَفٌرٌ ﭑ مَ. 
\q1  
\v 54 يٍ تٌ دِن ﭑ شُن نَ، 
\q1 ﭑ نَشَ عَ قَلَ، «ﭑ بَرَ لْي!» 
\q1  
\v 55 ﭑ نَشَ عِ تَن عَلَتَلَ شِلِ كْلْنيِ فبَاتَ مَ. 
\q1  
\v 56 عِ قَن نَشَ ﭑ شُي مّ ﭑ تٌ عَ قَلَ، 
\q1 «عِ نَشَ تٌندِ ﭑ شُي رَ مّدٍ. يَندِ، ﭑ مَلِ.» 
\q1  
\v 57 ﭑ تٌ عِ مَشَندِ، عِ نَشَ عِ مَسٌ ﭑ نَ، عِ عَ قَلَ ﭑ بّ، 
\q1 «عِ نَشَ فَاشُ.» 
\q1  
\v 58 عَلَتَلَ، عِ بَرَ ﭑ مَ قٍ سُشُ، عِ بَرَ ﭑ نِي رَكِسِ. 
\q1  
\v 59 عَلَتَلَ، عِ عَ تٌشِ عٍ قٍ نَشٍيٍ نِيَشِ ﭑ نَ. 
\q1 عِ شَ ﭑ مَ نْندِ مَكّنّن. 
\q1  
\v 60 عِ بَرَ عَ تٌ عٍ كْنكْشِ ﭑ مَ كِ نَشّ، 
\q1 عٍ يَنقَنتٍيَ نَشَن بِرِن شِرِ مَ ﭑ شُن مَ. 
\q1  
\v 61 عَلَتَلَ، عِ بَرَ عٍ شُي مّ كٌنبِ تِ رَ، 
\q1 عٍ يَنقَنتٍيَ نَشَن بِرِن شِرِ مَ ﭑ شُن مَ. 
\q1  
\v 62 ﭑ فٍرٍقَيٍ شَ وْيّنيِ نُن عٍ شَ مَحْشُنيِ نَ ﭑ تَن نَن قْشْ رَ لْشْي بِرِن. 
\q1  
\v 63 عَ مَتٌ، شَ عٍ دْشْشِ، شَ عٍ تِشِ، 
\q1 عٍ ﭑ تَن نَن قِندِشِ عٍ شَ سِفِيٍ رَ. 
\q1  
\v 64 عَلَتَلَ، عِ شَ ﭑ فبٍحْشْ عٍ مَ. 
\q1 عٍ نَشَن نِيَشِ ﭑ نَ، عِ شَ نَ رَفبِلٍن عٍ مَ. 
\q1  
\v 65 عِ شَ عٍ شَشِلِ دْنشُ، عِ عٍ دَنكَ، بَرَكَتَرٍحَ شَ بِرَ عٍ قْشْ رَ. 
\q1  
\v 66 عَلَتَلَ، عِ شَ بْحّ شْنّ شَ لُ عٍ قْشْ رَ، 
\q1 عِ شَ عٍ بَ دُنِحَ بّندّ قُحِ قَرِ. 
\c 4  
\s1 دَرِ سَلَمُ حَمَ شَ حَشَنكَتّ 
\q1  
\v 1 شّيمَ مُ يِلٍنمَ سْنْن، عَ مُ سّنِيّن. 
\q1 فّمّ تٌقَنيِيٍ بَرَ رَلَنتَن يّ تَا تُنشُنيِيٍ بِرِن نَ. 
\q1  
\v 2 سِيٌن دِيٍ تِدٍ نُ فبٌ عَلْ شّيمَ، 
\q1 كْنْ يَكْسِ عٍ تِدٍ بَرَ شُرُن 
\q1 عَلْ قّحّيٍ نَشٍيٍ يَءِلَنشِ بّندّ رَ. 
\q1  
\v 3 هَلِ وُلَبَرٍ فِنّ شِحّ قِمَ عَ شَ دِيٍ مَ، 
\q1 كْنْ ﭑ مَ حَمَ بَرَ لُ عَلْ دِنفّ نَشٍيٍ مُ مِشِحَ رَكَمَلِشِ. 
\q1 عٍ كٌبِ عَلْ سّفّ. 
\q1  
\v 4 كَامّ بَرَ عَ نِيَ، دِيْرّ نّنيِ بَرَ كَنكَن عَ نَشَرٍ. 
\q1 دِ مّيٍ تَامِ مَشْرِنمَ، كْنْ مِشِ يٌ مُ عٍ كِمَ. 
\q1  
\v 5 نَشٍيٍ نُ دٌنسٍ قَنيِ دٌنمَ، كَامّ بَرَ عٍ رَبِرَ تَا كُي. 
\q1 نَشٍيٍ رَ مْشِ قٍ قَنيِ كُي، 
\q1 عٍ قَ نَ حٌوفٍ نَن يٍفٍلٍنقٍ عٍ بّلّشّيٍ رَ. 
\q1  
\v 6 ﭑ مَ حَمَ شَ حَشَنكَتّ بَرَ فبٌ دَنفِقٍ سٌدٌ مَكَيٍ فبٍ رَ، 
\q1 نَشٍيٍ هَلَكِ يَ مَفِرّ كٍرٍن كُي، 
\q1 مِشِ كٍرٍن بّلّشّ مُ دِن عٍ رَ. 
\q1  
\v 7 عٍ شَ مَنفّدِيٍ نُ تٌقَن دَنفِ شّيمَ رَ، 
\q1 عٍ نُ قِيشّ دَنفِ شِحّ رَ. 
\q1 عٍ قَتٍ رَيَبُ عَلْ يٍ شْورَ سِنبٌنيِ، 
\q1 عٍ يَتَفِ نُ لُشِ نّ عَلْ دِيَمَن. 
\q1  
\v 8 كْنْ يَكْسِ عٍ قَتٍ بَرَ قْورْ دَنفِ تِفٍ رَ، 
\q1 عٍ مُ كٌلٌنمَ تَا كُي سْنْن. 
\q1 عٍ كِرِ قَتُشِ عٍ شْرِيٍ مَ، عَ بَرَ شَرَ عَلْ بٌلٍ. 
\q1  
\v 9 نَشٍيٍ قَشَ سَنتِدّفّمَ رَ، 
\q1 عٍ تَن نَن شُن نُ رَقَن دَنفِ مِشِ بِرِن نَ كَامّ نَشٍيٍ حَشَنكَتَقٍ. 
\q1 كَامّتْييٍ بَرَ شْسِ، عٍ تَفَنشِ، 
\q1 عٍ مُ دٌنسٍ يٌ سْتْمَ كْرّ. 
\q1  
\v 10 دِنفّيٍ، مَرَقَنيِ نُ نَ نَشٍيٍ بّ، 
\q1 عٍ بَرَ عٍ يّتّ شَ دِيٍ حِن، عٍ عٍ دٌن، 
\q1 عَلَكٌ عٍ شَ بَلٌ عَلِبَلَوِ كُي. 
\b  
\q1  
\v 11 عَلَتَلَ شَ شْنّ بَرَ كَمَلِ. 
\q1 عَ بَرَ عَ رَلَنتَن يّ، عَ تّ شُرُ سِيٌن، 
\q1 نَشَن بَرَ يِرٍ تِشِيٍ بِرِن فَن. 
\q1  
\v 12 بْشِ مَنفّيٍ مُ لَ عَ رَ، 
\q1 دُنِحَ مِشِيٍ سٍسٍ قَن مُ لَ عَ رَ، 
\q1 شَ يَشُييٍ نْمَ سٌدٍ دَرِ سَلَمُ نَادّيٍ رَ. 
\q1  
\v 13 يِ فبَلٌي كٍلِشِ عَ شَ نَمِحْنمّيٍ شَ يُنُبِيٍ نَن مَ، 
\q1 عَ نُن عَ شَ سّرّشّدُبّيٍ شَ قٍ كٌبِ رَبَشِيٍ مَ، 
\q1 عٍ تَن نَشٍيٍ تِنشِنتْييٍ نِي بَشِ. 
\q1  
\v 14 كْنْ يَكْسِ عٍ حّرّ مَ تَا كُي عَلْ دْنشُييٍ، 
\q1 مِشِ يٌ مُ عَ بّلّشّ دِنمَ عٍ رَ 
\q1 بَرِ مَ وُلِ نَشَن فٌرٌ مَ عٍ مَ، 
\q1 عَ بَرَ عٍ قِندِ سّنِيّنتَرٍيٍ رَ. 
\q1  
\v 15 مِشِيٍ لُمَ فبٍلٍفبٍلٍ رَ، 
\q1 «وٌ كٍلِ بٍ! وٌ تَن مِشِ سّنِيّنتَرٍيٍ! 
\q1 وٌ كٍلِ بٍ، وٌ كٍلِ بٍ! وٌ وٌ مَكُيَ مُشُ رَ!» 
\q1 نَ كُي عٍ نَشَ عٍ فِ سِفَقٍ رَ حَمَنّيٍ مَ. 
\q1 نَاكَيٍ قَن بَرَ عَ قَلَ، 
\q1 «عٍ مُ لُمَ مُشُ شْنيِ كْرّ!» 
\q1  
\v 16 عَلَتَلَ يّتّ يَتِ نَن عٍ رَيٍنسٍن يّ، 
\q1 عَ مُ قَ عَ حْشْ سَشِ عٍ شْن مَ سْنْن. 
\q1 عَ بَرَ بِنيّ بَ سّرّشّدُبّيٍ يِ، 
\q1 شُننَكٍلِ مُ نَ قٌرِيٍ بّ سْنْن. 
\q1  
\v 17 مُشُ بَرَ مَلِ ندٍ مَمّ، 
\q1 كْنْ مِشِ يٌ مُ قَ. 
\q1 مُشُ بَرَ مُشُ يَ تِ كِرَ رَ هَن مُشُ يَ بَرَ رَقْورْ، 
\q1 كْنْ سِ يٌ مُ قَ مُشُ رَتَنفَدٍ. 
\q1  
\v 18 مُشُ يَشُييٍ نُ مُشُ حّرّ كِ بِرِن تٌشِ، 
\q1 عَلَكٌ مُشُ نَشَ قَ مِنِ تَا كُي. 
\q1 مُشُ شَ قٍ دَنيِ نُ بَرَ مَكْرّ، 
\q1 لْشْي فبٍفبٍ مُ نُ لُشِ مُشُ بّ سْنْن، 
\q1 بَرِ مَ مُشُ شَ قٍ دَنيِ نُ بَرَ فّ عَ لِدٍ. 
\q1  
\v 19 مُشُ كٍرِ مَيٍ نُ شُلُن دَنفِ سّفّيٍ رَ، 
\q1 نَشٍيٍ نَ كٌورٍ مَ. 
\q1 عٍ نَشَ مُشُ كٍرِ هَن فٍيَيٍ قَرِ، 
\q1 عٍ عٍ نْشُن مُشُ يَ رَ، عٍ مُشُ مَمّ بُرُنيِ. 
\q1  
\v 20 عٍ نَشَ مُشُ رَكِسِمَ قَن سُشُ، عَلَ شَ مِشِ سُفَندِشِ. 
\q1 وٌن نُ بَرَ عَ قَلَ عَ شَ قٍ رَ، 
\q1 «مُشُ يِرِوَ مَ نّ عَ نِينِ بُن مَ حَمَنّيٍ تَفِ.» 
\b  
\q1  
\v 21 عِ تَن عٍدٌن حَمَ نَشَن سَبَتِشِ عُسُ بْشِ مَ حّلّشِن يِرٍ، 
\q1 يَكْسِ عِ نَ سّيوّ كُي، 
\q1 كْنْ عِ قَن شَ كِيتِ وَشَتِ نَ قَقٍ. 
\q1 عِ قَمَ نّ حَشَنكَتّ نُن يَافِ سْتْدٍ. 
\q1  
\v 22 سِيٌن حَمَ، عَ فبٍ مُ لُشِ عِ شَ حَشَنكَتّ شَ دَن. 
\q1 عَلَ مُ عِ شَ كٌنيِيَ رَبُمَ، 
\q1 كْنْ عِ تَن عٍدٌن حَمَ، 
\q1 عَلَتَلَ قَمَ نّ عِ مَكِيتِدٍ عِ شَ يُنُبِيٍ مَ، 
\q1 عَ شَ عِ حَشَنكَتَ نٍيٍ شَ قٍ رَ. 
\c 5  
\s1 حَمَ حَشَنكَتَشِ شَ سَلِ 
\sp حَمَ شَ عَلَ مَشَندِ 
\q1  
\v 1 عَلَتَلَ، مُشُ شَ تْورّ مَتٌ، مُشُ شَ يَافِ عِفبّ! 
\q1  
\v 2 شْحّيٍ بَرَ مُشُ كّ تٌنفٌ. 
\q1 مِشِيٍ بَرَ سَبَتِ مُشُ شَ بَنشِيٍ كُي، 
\q1 مُشُ كٌلٌنمَيٍ مُ نَشٍيٍ رَ. 
\q1  
\v 3 مُشُ بَرَ قِندِ مِسِكِينّ بَبَتَرٍيٍ رَ، 
\q1 مُشُ نفَيٍ بَرَ لُ عَلْ كَاحّ فِنّيٍ. 
\q1  
\v 4 مُشُ مُ نْمَ مُشُ شَ يٍ مِندٍ، 
\q1 قٌ مُشُ شَ عَ سَرَ كْبِرِ رَ. 
\q1 مُشُ مُ نْمَ مُشُ شَ يٍفٍ قَن فَندٍ، 
\q1 قٌ مُشُ شَ عَ سَرَ. 
\q1  
\v 5 مُشُ حَشَنكَتَمَيٍ دْشْشِ مُشُ قَرِ. 
\q1 مُشُ بَرَ تَفَن، مَلَبُي يٌ مُ نَ. 
\q1  
\v 6 مُشُ بَرَ مُشُ بّلّشّ عِتَلَ مِسِرَ نُن عَسِرِيَ بِرِ رَ، 
\q1 عَلَكٌ عٍ شَ مُشُ كِ تَامِ رَ. 
\q1  
\v 7 مُشُ بَبَيٍ بَرَ يُنُبِ رَبَ، 
\q1 كْنْ عٍ مُ نَ دُنِحَ سْنْن. 
\q1 مُشُ تَن نَن قَ عٍ شَ قٍ كٌبِيٍ تْرُحْي شَنِنقٍ. 
\q1  
\v 8 كٌنيِيٍ نَن قَ تِشِ مُشُ شُن مَ، 
\q1 مِشِ يٌ مُ نَ نَشَن مُشُ بَمَ عٍ يِ رَ. 
\q1  
\v 9 مُشُ بَلٌي قٍنمَ وُلَ عِ فَاشُي كُي، 
\q1 بَرِ مَ سَنتِدّفّمَ كَنيِيٍ نَ يِرٍ بِرِن. 
\q1  
\v 10 كَامّ بَرَ مُشُ سُشُ. 
\q1  
\v 11 مُشُ يَشُييٍ بَرَ عٍ وَشْنقٍ رَبَ سِيٌن نُن يُدَيَ فِنّدِ مّدِيٍ رَ. 
\q1  
\v 12 عٍ بَرَ كُنتِفِيٍ فبَكُ وُرِيٍ مَ، عٍ بِنيّ بَ قٌرِيٍ يِ. 
\q1  
\v 13 قٌنِكٍيٍ مّنفِ دِنمَ، 
\q1 عٍ يٍفٍ مَشَنِن هَن يٍفٍ كٌتٍ بَرَ بِرَ عٍ مَ. 
\q1  
\v 14 قٌرِيٍ بَرَ بَ عٍ مَلَنقٍ، 
\q1 قٌنِكٍيٍ قَن بَرَ بَ حَشَحَشَقٍ. 
\q1  
\v 15 مُشُ بْحّيٍ بَرَ بَ سّيوَقٍ، 
\q1 مُشُ شَ شُلُنيِ بَرَ مَسَرَ سُننُنيِ رَ. 
\q1  
\v 16 شُننَكٍلِ بَرَ بَ مُشُ يِ، 
\q1 مُشُ بَرَ مَكِنِكِنِ مُشُ شَ يُنُبِيٍ شَ قٍ رَ. 
\q1  
\v 17 نَ نَن عَ تٌشِ، مُشُ بْحّيٍ تْورْشِ، 
\q1 مُشُ يَ قَن بَرَ رَقْورْ. 
\q1  
\v 18 سِيٌن فٍيَ بَرَ قِندِ فبٍنفبٍرٍنيِ رَ، 
\q1 عَ بَرَ قِندِ شُلُمَسٍيٍ مَحّرّدٍ رَ. 
\q1  
\v 19 كْنْ عِ تَن، مَرِفِ عَلَتَلَ، عِ تَن نَن مَنفّ رَ تّمُي بِرِن. 
\q1 دَنيِ مُ نَ عِ شَ مَنفّيَ مَ، 
\q1 كٍلِ لَنقَنمَيٍ مَ، سَ دْشْ لَنقَنمَيٍ بِرِن نَ. 
\q1  
\v 20 مُنقٍ رَ، عِ قَ نّيمُشِ مُشُ مَ يِ مْولِ رَ، 
\q1 كَ عِ مُشُ رَبّحِنمَ نّ مُشُ شَ سِمَيَ بِرِن كُي؟ 
\q1  
\v 21 عَلَتَلَ، مُشُ رَفبِلٍن عِ مَ، 
\q1 مُشُ شَ قَ عِ مَ عَلْ عَ سِنفٍ. 
\q1  
\v 22 عِ مّيشِ نّ مُشُ رَ كٍرٍنيِ رَ؟ 
\q1 عِ شْنْمَ نّ مُشُ مَ عَبَدَن؟