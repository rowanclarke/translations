\c 25  
\s1 Organización de los cantores  
\p
\v 1 Asimismo \w David|strong="H1732"\w* y \w los|strong="H1121"\w* \w jefes|strong="H8269"\w* del \w ejército|strong="H6635"\w* apartaron \w para|strong="H1961"\w* \w el|strong="H1121"\w* \w ministerio|strong="H5656"\w* \w a|strong="H3068"\w* algunos \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Asaf, \w Hemán|strong="H1968"\w* y Jedutún, quienes cantaban salmos proféticos al \w son|strong="H1961"\w* \w de|strong="H1121"\w* \w arpas|strong="H3658"\w*, \w salterios|strong="H5035"\w* y \w címbalos|strong="H4700"\w*. \w El|strong="H1121"\w* \w número|strong="H4557"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hombres|strong="H1121"\w* idóneos \w para|strong="H1961"\w* la \w obra|strong="H4399"\w* \w de|strong="H1121"\w* su \w ministerio|strong="H5656"\w*, \w fue|strong="H1961"\w*:   
\p
\v 2 \w De|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* Asaf, Zacur, \w José|strong="H3130"\w*, Netanías \w y|strong="H5921"\w* Asarela, \w a|strong="H3068"\w* \w cargo|strong="H3027"\w* \w de|strong="H5921"\w* Asaf, quien cantaba salmos proféticos \w al|strong="H5921"\w* \w lado|strong="H3027"\w* \w del|strong="H5921"\w* \w rey|strong="H4428"\w*.   
\p
\v 3 \w De|strong="H5921"\w* Jedutún, \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* Jedutún, \w Gedalías|strong="H1436"\w*, Zeri, \w Jesaías|strong="H3470"\w*, Asabais \w y|strong="H5921"\w* Matatías, \w seis|strong="H8337"\w*, bajo \w la|strong="H5921"\w* dirección \w de|strong="H5921"\w* su padre Jedutún, \w el|strong="H5921"\w* cual también cantaba salmos proféticos \w al|strong="H5921"\w* son \w del|strong="H5921"\w* \w arpa|strong="H3658"\w* \w para|strong="H5921"\w* aclamar \w y|strong="H5921"\w* \w alabar|strong="H1984"\w* \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.   
\p
\v 4 \w De|strong="H1121"\w* \w Hemán|strong="H1968"\w*, \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Hemán|strong="H1968"\w*: Buquías, Matanías, Uziel, \w Sebuel|strong="H7619"\w*, Jeremot, \w Hananías|strong="H2608"\w*, \w Hanani|strong="H2607"\w*, Eliata, Gidalti, Romanti-ezer, \w Josbecasa|strong="H3436"\w*, Maloti, Hotir y Mahaziot.  
\v 5 \w Todos|strong="H3605"\w* \w éstos|strong="H3605"\w* eran \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Hemán|strong="H1968"\w*, \w vidente|strong="H2374"\w* del \w rey|strong="H4428"\w*, y tenían \w Palabras|strong="H1697"\w* \w de|strong="H1121"\w* \nd ʼElohim\nd* \w para|strong="H5414"\w* exaltar su poder, pues \nd ʼElohim\nd* \w dio|strong="H5414"\w* \w a|strong="H3068"\w* \w Hemán|strong="H1968"\w* 14 \w hijos|strong="H1121"\w* y \w tres|strong="H7969"\w* \w hijas|strong="H1323"\w*.   
\p
\v 6 \w Todos|strong="H3605"\w* \w ellos|strong="H3027"\w* estaban bajo \w la|strong="H5921"\w* dirección \w de|strong="H5921"\w* su padre, \w en|strong="H5921"\w* \w el|strong="H5921"\w* canto \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w Casa|strong="H1004"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \w con|strong="H5921"\w* acompañamiento \w de|strong="H5921"\w* \w címbalos|strong="H4700"\w*, \w salterios|strong="H5035"\w* \w y|strong="H5921"\w* \w arpas|strong="H3658"\w*, \w para|strong="H5921"\w* \w el|strong="H5921"\w* \w ministerio|strong="H5656"\w* \w del|strong="H5921"\w* Santuario \w de|strong="H5921"\w* \nd ʼElohim\nd*.  
\p Asaf, Jedutún \w y|strong="H5921"\w* \w Hemán|strong="H1968"\w* estaban bajo \w la|strong="H5921"\w* dirección \w del|strong="H5921"\w* \w rey|strong="H4428"\w*.   
\p
\v 7 \w El|strong="H5973"\w* \w número|strong="H4557"\w* \w de|strong="H5973"\w* \w ellos|strong="H3605"\w*, \w juntamente|strong="H5973"\w* \w con|strong="H5973"\w* sus hermanos \w instruidos|strong="H3925"\w* \w en|strong="H5973"\w* \w el|strong="H5973"\w* canto \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \w todos|strong="H3605"\w* aptos, \w era|strong="H1961"\w* 288.  
