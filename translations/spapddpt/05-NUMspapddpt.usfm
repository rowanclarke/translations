\p
\v 8 \w Moisés|strong="H4872"\w* dijo además \w a|strong="H3068"\w* \w Coré|strong="H7141"\w*: \w Oigan|strong="H8085"\w* \w ahora|strong="H4994"\w*, \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Leví|strong="H3878"\w*:  
\v 9 ¿Les \w es|strong="H3588"\w* \w poco|strong="H4592"\w* \w que|strong="H3588"\w* \w el|strong="H3588"\w* \nd ʼElohim\nd* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w* \w los|strong="H3588"\w* apartó \w de|strong="H4480"\w* \w la|strong="H3588"\w* congregación \w de|strong="H4480"\w* \w Israel|strong="H3478"\w*, \w los|strong="H3588"\w* acercó \w a|strong="H3068"\w* \w Él|strong="H3588"\w* \w para|strong="H3588"\w* \w que|strong="H3588"\w* ministren \w en|strong="H4480"\w* \w el|strong="H3588"\w* servicio \w del|strong="H4480"\w* \w Tabernáculo|strong="H4908"\w* \w de|strong="H4480"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \w y|strong="H3588"\w* estén \w delante|strong="H6440"\w* \w de|strong="H4480"\w* \w la|strong="H3588"\w* congregación \w para|strong="H3588"\w* ministrarles?  
\v 10 \w Que|strong="H1571"\w* \w a|strong="H3068"\w* ti te ha traído, \w y|strong="H1571"\w* contigo \w a|strong="H3068"\w* \w todos|strong="H3605"\w* tus hermanos, \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Leví|strong="H3878"\w*, ¿pero ahora pretenden \w también|strong="H1571"\w* \w el|strong="H3605"\w* \w sacerdocio|strong="H3550"\w*?  
\v 11 Tú \w y|strong="H3588"\w* \w todo|strong="H3605"\w* tu \w séquito|strong="H5712"\w* \w se|strong="H1931"\w* confabularon \w contra|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \w pues|strong="H3588"\w* ¿\w quién|strong="H4100"\w* \w es|strong="H1931"\w* Aarón \w para|strong="H5921"\w* \w que|strong="H3588"\w* \w murmuren|strong="H3885"\w* \w contra|strong="H5921"\w* \w él|strong="H1931"\w*?   
\p
\v 12 Entonces \w Moisés|strong="H4872"\w* \w mandó|strong="H7971"\w* \w a|strong="H3068"\w* \w llamar|strong="H7121"\w* \w a|strong="H3068"\w* Datán y Abirán, \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Eliab, pero ellos respondieron: \w No|strong="H3808"\w* \w subiremos|strong="H5927"\w*.  
\v 13 ¿\w Es|strong="H3588"\w* \w poco|strong="H4592"\w* \w que|strong="H3588"\w* \w nos|strong="H5921"\w* hiciste salir \w de|strong="H5921"\w* una tierra \w que|strong="H3588"\w* \w fluye|strong="H2100"\w* \w leche|strong="H2461"\w* \w y|strong="H1571"\w* \w miel|strong="H1706"\w* \w para|strong="H5921"\w* hacernos \w morir|strong="H4191"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w desierto|strong="H4057"\w*, \w y|strong="H1571"\w* \w que|strong="H3588"\w* \w además|strong="H5921"\w* insistas \w en|strong="H5921"\w* dominarnos \w de|strong="H5921"\w* manera absoluta?   
\p
\v 14 \w Tampoco|strong="H3808"\w* nos introdujiste en la tierra \w que|strong="H3808"\w* \w fluye|strong="H2100"\w* \w leche|strong="H2461"\w* y \w miel|strong="H1706"\w*, \w ni|strong="H3808"\w* nos \w diste|strong="H5414"\w* en \w heredad|strong="H5159"\w* \w campos|strong="H7704"\w* y vides. ¿Pretendes arrancar \w los|strong="H1992"\w* \w ojos|strong="H5869"\w* \w a|strong="H3068"\w* \w estos|strong="H1992"\w* hombres? ¡\w No|strong="H3808"\w* \w iremos|strong="H5927"\w*!  
\v 15 Entonces \w Moisés|strong="H4872"\w* \w se|strong="H3808"\w* enardeció muchísimo y dijo \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*: \w No|strong="H3808"\w* aceptes \w su|strong="H1992"\w* \w ofrenda|strong="H4503"\w*. \w No|strong="H3808"\w* \w tomé|strong="H5375"\w* de \w ellos|strong="H1992"\w* \w ni|strong="H3808"\w* un \w asno|strong="H2543"\w*. \w A|strong="H3068"\w* \w ninguno|strong="H3808"\w* de \w ellos|strong="H1992"\w* hice \w mal|strong="H7489"\w*.   
\p
\v 16 \w Después|strong="H1961"\w* dijo \w Moisés|strong="H4872"\w* \w a|strong="H3068"\w* \w Coré|strong="H7141"\w*: Tú y \w todo|strong="H3605"\w* tu \w séquito|strong="H5712"\w* preséntense \w mañana|strong="H4279"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, tú, \w ellos|strong="H1992"\w* y Aarón.  
\v 17 \w Tome|strong="H3947"\w* cada uno su incensario \w y|strong="H5921"\w* pongan incienso \w en|strong="H5921"\w* \w ellos|strong="H5921"\w*. Acérquense \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, cada uno \w con|strong="H5921"\w* su incensario. 250 \w incensarios|strong="H4289"\w*, tú \w y|strong="H5921"\w* Aarón, cada uno \w con|strong="H5921"\w* su incensario.  
\v 18 Entonces cada uno \w tomó|strong="H3947"\w* su incensario, echaron incienso \w en|strong="H5921"\w* \w ellos|strong="H5921"\w* \w y|strong="H5921"\w* \w pusieron|strong="H7760"\w* fuego \w en|strong="H5921"\w* \w ellos|strong="H5921"\w*. \w Se|strong="H5921"\w* mantuvieron \w en|strong="H5921"\w* \w la|strong="H5921"\w* entrada \w del|strong="H5921"\w* Tabernáculo \w de|strong="H5921"\w* Reunión \w con|strong="H5921"\w* \w Moisés|strong="H4872"\w* \w y|strong="H5921"\w* Aarón.  
\v 19 \w Coré|strong="H7141"\w* hizo reunir \w contra|strong="H5921"\w* \w ellos|strong="H5921"\w* \w a|strong="H3068"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* asamblea \w en|strong="H5921"\w* \w la|strong="H5921"\w* entrada \w al|strong="H5921"\w* Tabernáculo \w de|strong="H5921"\w* Reunión.  
\p Entonces \w la|strong="H5921"\w* \w gloria|strong="H3519"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w se|strong="H5921"\w* \w mostró|strong="H7200"\w* \w a|strong="H3068"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* asamblea.  
\v 20 \nd \+w Yavé|strong="H3068"\+w*\nd* \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w* y \w a|strong="H3068"\w* Aarón:  
\v 21 \wj Apártense de \+w en|strong="H8432"\+w* \+w medio|strong="H8432"\+w* de \+w esta|strong="H2063"\+w* congregación, y los consumiré \+w en|strong="H8432"\+w* un instante.\wj*   
\p
\v 22 Pero \w ellos|strong="H5921"\w* \w cayeron|strong="H5307"\w* \w sobre|strong="H5921"\w* sus \w rostros|strong="H6440"\w*, \w y|strong="H5921"\w* dijeron: ¡\nd ʼElohim\nd*, \nd ʼElohim\nd* \w del|strong="H5921"\w* \w espíritu|strong="H7307"\w* \w de|strong="H5921"\w* \w todo|strong="H3605"\w* ser humano! ¿\w No|strong="H5921"\w* es un solo hombre \w el|strong="H5921"\w* \w que|strong="H5921"\w* \w pecó|strong="H2398"\w*? ¿\w Por|strong="H5921"\w* \w qué|strong="H5921"\w* \w te|strong="H5921"\w* enojas \w contra|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* congregación?   
\p
\v 23 Entonces \nd \+w Yavé|strong="H3068"\+w*\nd* \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*:  
\v 24 \wj \+w Habla|strong="H1696"\+w* \+w a|strong="H3068"\+w* la asamblea: Apártense de \+w alrededor|strong="H5439"\+w* de las \+w tiendas|strong="H4908"\+w* de \+w Coré|strong="H7141"\+w*, Datán y Abirán.\wj*   
\p
\v 25 Entonces \w Moisés|strong="H4872"\w* se \w levantó|strong="H6965"\w* y \w fue|strong="H3212"\w* \w a|strong="H3068"\w* Datán y Abirán, y los \w ancianos|strong="H2205"\w* de \w Israel|strong="H3478"\w* lo siguieron.  
\v 26 \w Y|strong="H3068"\w* \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* asamblea: ¡Apártense \w ahora|strong="H4994"\w* \w de|strong="H5921"\w* \w las|strong="H5921"\w* tiendas \w de|strong="H5921"\w* \w estos|strong="H3605"\w* hombres perversos, \w y|strong="H5921"\w* \w no|strong="H6435"\w* \w toquen|strong="H5060"\w* \w nada|strong="H3605"\w* \w de|strong="H5921"\w* \w ellos|strong="H5921"\w* \w para|strong="H5921"\w* \w que|strong="H4994"\w* \w no|strong="H6435"\w* sean barridos \w con|strong="H5921"\w* \w todos|strong="H3605"\w* sus \w pecados|strong="H2403"\w*!  
\v 27 Entonces \w se|strong="H5921"\w* apartaron \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w alrededores|strong="H5439"\w* \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w tiendas|strong="H4908"\w* \w de|strong="H5921"\w* \w Coré|strong="H7141"\w*, Datán \w y|strong="H5921"\w* Abirán. Pero Datán \w y|strong="H5921"\w* Abirán \w salieron|strong="H3318"\w* erguidos \w en|strong="H5921"\w* \w la|strong="H5921"\w* entrada \w de|strong="H5921"\w* sus \w tiendas|strong="H4908"\w*, \w con|strong="H5921"\w* sus esposas, sus \w hijos|strong="H1121"\w* \w y|strong="H5921"\w* sus pequeños.   
\p
\v 28 \w Moisés|strong="H4872"\w* dijo: \w Por|strong="H3588"\w* medio \w de|strong="H3588"\w* \w esto|strong="H2063"\w* \w sabrán|strong="H3045"\w* \w que|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w me|strong="H3588"\w* \w envió|strong="H7971"\w* \w a|strong="H3068"\w* \w hacer|strong="H6213"\w* \w todas|strong="H3605"\w* \w estas|strong="H2063"\w* \w obras|strong="H4639"\w*, \w porque|strong="H3588"\w* \w esto|strong="H2063"\w* \w no|strong="H3808"\w* \w es|strong="H3588"\w* \w obra|strong="H4639"\w* mía:  
\v 29 \w Si|strong="H3808"\w* \w éstos|strong="H3605"\w* \w mueren|strong="H4191"\w* \w como|strong="H5921"\w* muere \w cualquier|strong="H3605"\w* hombre, \w y|strong="H5921"\w* \w si|strong="H3808"\w* \w son|strong="H3808"\w* sentenciados \w como|strong="H5921"\w* \w se|strong="H5921"\w* sentencia \w a|strong="H3068"\w* \w cualquier|strong="H3605"\w* hombre, entonces \nd \+w Yavé|strong="H3068"\+w*\nd* \w no|strong="H3808"\w* \w me|strong="H5921"\w* \w envió|strong="H7971"\w*.  
\v 30 \w Pero|strong="H3588"\w* \w si|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w crea|strong="H1254"\w* algo extraño, \w y|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w abre|strong="H6475"\w* \w su|strong="H3588"\w* \w boca|strong="H6310"\w* \w y|strong="H3588"\w* \w se|strong="H3045"\w* \w los|strong="H3605"\w* traga \w con|strong="H3588"\w* \w todas|strong="H3605"\w* sus \w cosas|strong="H3045"\w*, \w y|strong="H3588"\w* \w descienden|strong="H3381"\w* \w vivos|strong="H2416"\w* al Seol, \w entonces|strong="H3588"\w* entenderán \w que|strong="H3588"\w* \w estos|strong="H3605"\w* hombres despreciaron \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.   
\p
\v 31 \w Aconteció|strong="H1961"\w* \w que|strong="H1697"\w* \w al|strong="H8478"\w* terminar \w de|strong="H8478"\w* \w hablar|strong="H1696"\w* \w todas|strong="H3605"\w* estas \w palabras|strong="H1697"\w*, \w se|strong="H1961"\w* abrió \w la|strong="H3605"\w* tierra \w que|strong="H1697"\w* \w estaba|strong="H1961"\w* \w debajo|strong="H8478"\w* \w de|strong="H8478"\w* \w ellos|strong="H3605"\w*.  
\v 32 \w La|strong="H3605"\w* tierra \w abrió|strong="H6605"\w* su \w boca|strong="H6310"\w*, y se \w los|strong="H3605"\w* tragó \w a|strong="H3068"\w* \w ellos|strong="H3605"\w*, \w a|strong="H3068"\w* sus \w familias|strong="H1004"\w*, \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* hombres \w que|strong="H6310"\w* estaban con \w Coré|strong="H7141"\w* y \w todos|strong="H3605"\w* sus bienes.  
\v 33 \w Y|strong="H3068"\w* \w ellos|strong="H1992"\w*, \w con|strong="H5921"\w* \w todo|strong="H3605"\w* \w lo|strong="H5921"\w* \w que|strong="H5921"\w* poseían, \w descendieron|strong="H3381"\w* \w vivos|strong="H2416"\w* \w al|strong="H5921"\w* Seol. \w Los|strong="H1992"\w* tragó \w la|strong="H5921"\w* tierra \w y|strong="H5921"\w* desaparecieron \w de|strong="H5921"\w* \w en|strong="H5921"\w* \w medio|strong="H8432"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w congregación|strong="H6951"\w*.  
\v 34 \w Todos|strong="H3605"\w* \w los|strong="H3605"\w* israelitas \w que|strong="H3588"\w* estaban \w alrededor|strong="H5439"\w* \w de|strong="H3588"\w* \w ellos|strong="H3605"\w* \w huyeron|strong="H5127"\w* \w cuando|strong="H3588"\w* oyeron sus gritos, \w pues|strong="H3588"\w* decían: ¡\w No|strong="H6435"\w* \w sea|strong="H6435"\w* \w que|strong="H3588"\w* \w la|strong="H3605"\w* tierra nos \w trague|strong="H1104"\w* \w a|strong="H3068"\w* \w nosotros|strong="H3605"\w*!   
\p
\v 35 \w Salió|strong="H3318"\w* fuego de \nd \+w Yavé|strong="H3068"\+w*\nd* que consumió \w a|strong="H3068"\w* los 250 hombres que ofrecían el incienso.   
\p
\v 36 Entonces \nd \+w Yavé|strong="H3068"\+w*\nd* habló \w a|strong="H3068"\w* Moisés:  
\v 37 \wj Dí \+w a|strong="H3068"\+w* Eleazar, hijo del sacerdote Aarón, que recoja los incensarios de entre el incendio, porque están consagrados, y esparza allí las brasas.\wj*  
\v 38 \wj Con los incensarios de los que pecaron contra sus vidas, harán planchas martilladas para recubrir el altar, por cuanto los presentaron ante \+nd \+w Yavé|strong="H3068"\+w*\+nd* y están consagrados. Serán una señal para los hijos de Israel.\wj*   
\p
\v 39 Entonces el sacerdote Eleazar tomó los incensarios de bronce con los cuales se presentaron los que fueron quemados y los laminaron para recubrir el altar,  
\v 40 como recuerdo para los hijos de Israel con respecto \w a|strong="H3068"\w* que ningún extraño, que no sea de la descendencia de Aarón, puede ofrecer incienso \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, para que no sea como Coré y como su séquito, según \nd \+w Yavé|strong="H3068"\+w*\nd* habló por medio de Moisés.   
\p
\v 41 Al día siguiente, sin embargo, toda la congregación de los hijos de Israel murmuró contra Moisés y Aarón: ¡Ustedes son los que causaron la muerte del pueblo de \nd \+w Yavé|strong="H3068"\+w*\nd*!   
\p
\v 42 Aconteció que cuando se juntó la congregación contra Moisés y Aarón, miraron hacia el Tabernáculo de Reunión. Ahí estaba la nube que lo cubrió, y se manifestó la gloria de \nd \+w Yavé|strong="H3068"\+w*\nd*.  
\v 43 Entonces Moisés y Aarón fueron al frente del Tabernáculo de Reunión.   
\p
\v 44 \nd \+w Yavé|strong="H3068"\+w*\nd* habló \w a|strong="H3068"\w* Moisés:  
\v 45 \wj ¡Apártense de en medio de esta congregación porque voy \+w a|strong="H3068"\+w* consumirlos en un instante!\wj*  
\p Entonces cayeron sobre sus rostros,  
\v 46 y Moisés dijo \w a|strong="H3068"\w* Aarón: ¡Toma el incensario, pon en él fuego del altar y ponle incienso encima! ¡Apresúrate, \w vé|strong="H3068"\w* hacia la congregación y haz sacrificio que apacigua por ellos, porque la ira salió de la Presencia de \nd \+w Yavé|strong="H3068"\+w*\nd*, la mortandad comenzó!   
\p
\v 47 Entonces, tal como Moisés habló, Aarón tomó el incensario y corrió hacia el medio de la asamblea, y ¡ciertamente la mortandad había comenzado entre el pueblo! Pero él puso el incienso \w e|strong="H3068"\w* hizo sacrificio que apacigua \w a|strong="H3068"\w* favor del pueblo.  
\v 48 Se puso entre los muertos y los vivos, y la mortandad fue detenida.  
\v 49 Sin embargo, los que murieron en aquella mortandad fueron 14.700, además de los que murieron por causa de Coré.   
\p
\v 50 Aarón volvió \w a|strong="H3068"\w* la puerta del Tabernáculo de Reunión donde estaba Moisés, pues la mortandad fue detenida.   
\c 17  
\s1 La vara de Aarón  
\p
\v 1 Entonces \nd \+w Yavé|strong="H3068"\+w*\nd* \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*:  
\v 2 \wj Habla \+w a|strong="H3068"\+w* \+w los|strong="H1121"\+w* \+w hijos|strong="H1121"\+w* \+w de|strong="H3588"\+w* Israel. Toma \+w de|strong="H3588"\+w* ellos una vara \+w por|strong="H3588"\+w* cada casa paterna: 12 varas \+w de|strong="H3588"\+w* todos sus jefes conforme \+w a|strong="H3068"\+w* sus casas paternas. Escribirás \+w el|strong="H3588"\+w* nombre \+w de|strong="H3588"\+w* cada uno \+w en|strong="H3588"\+w* \+w su|strong="H3588"\+w* vara.\wj*  
\v 3 \wj \+w En|strong="H3588"\+w* \+w la|strong="H3588"\+w* vara \+w de|strong="H3588"\+w* Leví escribirás \+w el|strong="H3588"\+w* nombre \+w de|strong="H3588"\+w* Aarón, \+w pues|strong="H3588"\+w* cada jefe \+w de|strong="H3588"\+w* \+w su|strong="H3588"\+w* casa paterna \+w tendrá|strong="H1961"\+w* una vara.\wj*  
\v 4 \wj Luego las pondrás en el Tabernáculo de Reunión, delante \+w del|strong="H4196"\+w* Testimonio, donde Yo me encuentro con ustedes.\wj*   
\p
\v 5 \wj \+w Sucederá|strong="H1961"\+w* \+w que|strong="H1931"\+w* \+w la|strong="H1931"\+w* vara del varón \+w que|strong="H1931"\+w* Yo escoja, florecerá, y \+w así|strong="H1931"\+w* quitaré \+w de|strong="H6440"\+w* \+w sobre|strong="H1961"\+w* \+w Mí|strong="H1961"\+w* las murmuraciones con las cuales \+w los|strong="H1121"\+w* \+w hijos|strong="H1121"\+w* \+w de|strong="H6440"\+w* \+w Israel|strong="H3478"\+w* murmuran \+w contra|strong="H6440"\+w* ustedes.\wj*   
\p
\v 6 Entonces \w Moisés|strong="H4872"\w* habló \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*. \w Todos|strong="H3605"\w* sus jefes \w le|strong="H5921"\w* dieron varas, \w cada|strong="H3605"\w* jefe una vara \w por|strong="H5921"\w* \w cada|strong="H3605"\w* casa paterna, \w en|strong="H5921"\w* total 12 varas. \w La|strong="H5921"\w* vara \w de|strong="H5921"\w* Aarón estaba \w entre|strong="H5921"\w* \w las|strong="H5921"\w* varas \w de|strong="H5921"\w* \w ellos|strong="H5921"\w*.  
\v 7 \w Moisés|strong="H4872"\w* depositó \w las|strong="H5921"\w* varas \w en|strong="H5921"\w* \w la|strong="H5921"\w* Presencia \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w en|strong="H5921"\w* \w el|strong="H5921"\w* Tabernáculo \w del|strong="H5921"\w* Testimonio.   
\p
\v 8 Al día siguiente, aconteció que \w Moisés|strong="H4872"\w* fue al Tabernáculo del Testimonio. Vio que la vara \w de|strong="H6440"\w* Aarón, \w de|strong="H6440"\w* la casa \w de|strong="H6440"\w* Leví, reverdeció y echó flores. Echó ramas y produjo almendras.  
\v 9 Entonces \w Moisés|strong="H4872"\w* sacó de la Presencia de \nd \+w Yavé|strong="H3068"\+w*\nd* todas las varas ante todos los hijos de Israel, y ellos las vieron y cada uno tomó su vara.   
\p
\v 10 \nd \+w Yavé|strong="H3068"\+w*\nd* dijo \w a|strong="H3068"\w* Moisés: \wj Vuelve \+w a|strong="H3068"\+w* depositar \+w la|strong="H5921"\+w* vara \+w de|strong="H5921"\+w* Aarón \+w delante|strong="H6440"\+w* \+w del|strong="H5921"\+w* Testimonio \+w para|strong="H5921"\+w* \+w que|strong="H5921"\+w* \+w se|strong="H5921"\+w* guarde \+w como|strong="H5921"\+w* señal \+w a|strong="H3068"\+w* \+w los|strong="H5921"\+w* hijos rebeldes \+w para|strong="H5921"\+w* \+w que|strong="H5921"\+w* cesen sus murmuraciones \+w contra|strong="H5921"\+w* \+w Mí|strong="H5921"\+w*, \+w y|strong="H5921"\+w* \+w no|strong="H5921"\+w* mueran.\wj*   
