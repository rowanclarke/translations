\id LEV
\h  إِلَاوِييّنْ 
\toc1  إِلَاوِييّنْ 
\toc2  إِلَاوِييّنْ 
\toc3 لَاوِي 
\mt1 إِلَاوِييّنْ  
\c 1
\s1 ثِيغَارْصَا ن وشْمَاضْ  
\m
\v 1 إِڒَاغَا إِ مُوسَا ؤُشَا إِسِّيوڒْ سِيذِي أَكِيذسْ زڭْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ، إِنَّا:   
\m
\v 2 ”سِيوڒْ أَكْ-ذ أَيْثْ ن إِسْرَائِيل ؤُشَا إِنِي أَسنْ:  
\b  
\m ’مَاڒَا إِسّْقَارّبْ إِجّْ ن بْنَاذمْ زَّايْومْ ثَاوْهِيبْثْ إِ سِيذِي، \add خنِّي\add* أَذْ د-ثسّْقَارّْبمْ \bd ثَاوْهِيبْثْ نْومْ زِي ڒبْهَايمْ\bd*، زڭْ إِفُونَاسنْ ذ ثْفُونَاسِينْ نِيغْ زڭْ وُودْجِي. \f ◼ \fr 1:‏2 \ft \+bd ’نِيغْ‘\+bd* - س ثْعِيبْرَانِيثْ ’ؤُ‘.\f*   
\m
\v 3 مَاڒَا ثَاوْهِيبْثْ نّسْ ذ \bd ثَاغَارْصْثْ ن وشْمَاضْ زڭْ إِفُونَاسنْ ذ ثْفُونَاسِينْ\bd*، \add خنِّي\add* أَذْ د-إِسّْقَارّبْ إِجّْ ن ؤُوْثمْ إِشْنَانْ قَاعْ. أَذْ ث يِيوِي غَارْ وَاذَافْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ، مَاحنْذْ أَذْ يَافْ أَرْضَا زَّاثْ إِ وُوذمْ ن سِيذِي.  
\v 4 أَذْ يڭّْ أَفُوسْ نّسْ خْ ؤُزدْجِيفْ ن ثْغَارْصْثْ ن وشْمَاضْ ؤُشَا أَمُّو إِ غَا ثتّْوَاقْبڒْ \add ثْغَارْصْثْ\add* س أَرْضَا ذِي طّْوعْ نّسْ، مَاحنْذْ أَذْ يِيڒِي إِ وصْڒَاحْ نّسْ. \x ◘ \xo 1:‏4 \xt ؤُف. 29‏:‏10\x*  
\v 5 أَذْ إِغَارْصْ إِ ؤُمژْيَانْ ن ؤُفُونَاسْ زَّاثْ إِ وُوذمْ ن سِيذِي ؤُشَا أَرَّاوْ ن هَارُونْ، إِكهَّاننْ، أَذْ د-إِوْينْ إِذَامّنْ، أَذْ زدْجْعنْ إِذَامّنْ غَارْ مَارَّا إِغزْذِيسنْ خْ ؤُعَالْطَارْ نِّي إِدْجَانْ غَارْ وَاذَافْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ.  
\v 6 أَذْ إِكّسْ ثِيڒْمشْثْ ن ثْغَارْصْثْ ن وشْمَاضْ ؤُشَا أَذْ إِبْضَا \add أَفُونَاسْ\add* ذ إِشدْجِيقنْ.  
\v 7 أَرَّاوْ ن أَكهَّانْ هَارُونْ أَذْ سَّارْغنْ ثِيمسِّي خْ ؤُعَالْطَارْ ؤُشَا أَذْ ستّْفنْ أَكشُّوضْ خْ ثْمسِّي.  
\v 8 أَرَّاوْ ن هَارُونْ، إِكهَّاننْ، أَذْ ستّْفنْ إِشدْجِيقنْ ذ ؤُزدْجِيفْ ذ ثَاذُونْثْ خْ ؤُكشُّوضْ نِّي إِدْجَانْ خْ ثْمسِّي إِ إِدْجَانْ خْ ؤُعَالْطَارْ.  
\v 9 نتَّا أَذْ إِسِّيرْذْ أَذَانْ نّسْ ذ إِضَارنْ نّسْ س وَامَانْ. أَكهَّانْ أَذْ إِسّْبخَّارْ مَانْ أَيَا مَارَّا خْ ؤُعَالْطَارْ، أَقَا ذ ثَاغَارْصْثْ ن وشْمَاضْ، ذ ثَاوْهِيبْثْ ن ثْمسِّي، ذ إِشْثْ ن ڒفْوَاحثْ إِتّْفُوحنْ إِ سِيذِي.   
\m
\v 10 مَاڒَا ثَاوْهِيبْثْ نّسْ ذ \bd ثَاغَارْصْثْ ن وشْمَاضْ زڭْ وُودْجِي\bd*، زڭْ إِحُوڒِييّنْ نِيغْ زڭْ إِغَايْضنْ، \add خنِّي\add* إِتّْخصَّا أَذْ د-إِسّْقَارّبْ أَوْثمْ إِشْنَانْ قَاعْ.  
\v 11 أَذْ أَسْ إِغَارْصْ زَّاثْ إِ وُوذمْ ن سِيذِي غَارْ ؤُغزْذِيسْ ن شَّامَالْ ن ؤُعَالْطَارْ ؤُشَا أَرَّاوْ ن هَارُونْ، إِكهَّاننْ، أَذْ زدْجْعنْ إِذَامّنْ نّسْ خْ ؤُعَالْطَارْ غَارْ مَارَّا إِغزْذِيسنْ نّسْ.  
\v 12 أَذْ ث إِبْضَا ذ إِشدْجِيقنْ، أَكْ-ذ أَزدْجِيفْ نّسْ ذ ثَاذُونْثْ نّسْ، ؤُشَا أَكهَّانْ أَذْ ثنْ إِستّفْ خْ ؤُكشُّوضْ نِّي إِدْجَانْ خْ ثْمسِّي \add إِ إِدْجَانْ\add* خْ ؤُعَالْطَارْ.  
\v 13 أَذْ إِسِّيرْذْ أَذَانْ نّسْ ذ إِشكْرَاذنْ نّسْ س وَامَانْ. أَكهَّانْ أَذْ يَاوِي مَانْ أَيَا مَارَّا ؤُ أَذْ ث إِسّْبخَّارْ خْ ؤُعَالْطَارْ. \add أَقَا\add* ذ إِشْثْ ن ثْغَارْصْثْ ن وشْمَاضْ، إِشْثْ ن ثوْهِيبْثْ ن ثْمسِّي، إِشْثْ ن ڒفْوَاحثْ إِتّْفُوحنْ إِ سِيذِي.   
\m
\v 14 مَاڒَا ثَاوْهِيبْثْ نّسْ ذ \bd ثَاغَارْصْثْ ن وشْمَاضْ زڭْ إِجْضَاضْ\bd* إِ سِيذِي، \add خنِّي\add* أَذْ يَاوِي ثَاوْهِيبْثْ نّسْ زِي ثجْلِيلِّيحِينْ نِيغْ زڭْ إِذْبِيرنْ إِمژْيَاننْ.  
\v 15 أَكهَّانْ أَذْ ث يَاوِي غَارْ ؤُعَالْطَارْ، أَذْ أَسْ إِكّسْ أَزدْجِيفْ ؤُشَا أَذْ ث إِسّْبخَّارْ خْ ؤُعَالْطَارْ. أَذْ إِژمّْ إِذَامّنْ نّسْ خْ ؤُغزْذِيسْ ن ؤُعَالْطَارْ  
\v 16 ؤُشَا أَذْ أَسْ إِكّسْ أَسيْرُو أَكْ-ذ مِينْ ذَايسْ إِقِّيمنْ ؤُ أَذْ إِنْضَارْ أَيَا زَّاثْ إِ ؤُعَالْطَارْ غَارْ ؤُغزْذِيسْ ن شَّارْقْ خْ ومْشَانْ ن إِغّضْ ن مِينْ إِقِّيمنْ ن ثَاذُونْثْ  
\v 17 أَذْ ث إِشَارّڭْ غَارْ وفْرِيونْ، \add مَاشَا\add* وَارْ ث إِبطِّي شَا قَاعْ، ؤُشَا أَكهَّانْ أَذْ ث إِسّْبخَّارْ خْ ؤُعَالْطَارْ، خْ ؤُكشُّوضْ نِّي إِدْجَانْ خْ ثْمسِّي. أَقَا ذ إِشْثْ ن ثْغَارْصْثْ ن وشْمَاضْ، ذ إِشْثْ ن ثوْهِيبْثْ ن ثْمسِّي، ذ إِشْثْ ن ڒفْوَاحثْ إِتّْفُوحنْ إِ سِيذِي.‘ “   
\b  
\b  
\m  
\c 2
\s1 ثِيغَارْصَا ن ڒْغِيدْجثْ  
\m
\v 1 ”مَاڒَا إِقدّمْ حذْ \bd ثَاوْهِيبْثْ \+bdit ن ڒْغِيدْجثْ\+bdit*\bd* غَارْ سِيذِي، أَذْ ثِيڒِي ثوْهِيبْثْ نّسْ ن وَارنْ أَزْذَاذْ ؤُشَا أَذْ خَاسْ إِسيّبْ زّشْثْ ؤُشَا أَذْ خَاسْ إِسَّارْسْ جَّاوِي. \x ◘ \xo 2:‏1 \xt ؤُف. 6‏:‏15؛ 9‏:‏17؛ ڒخْڒ. 15‏:‏4\x*  
\v 2 أَذْ ت يَاوِي غَارْ وَارَّاوْ ن هَارُونْ، إِكهَّاننْ، ؤُشَا أَذْ زَّايسْ إِكْسِي ؤُكهَّانْ إِجّْ ن وُورُو إِشُّورْ زڭْ وَارنْ أَزْذَاذْ نِّي ؤُ زِي زّشْثْ نِّي أَكْ-ذ مَارَّا جَّاوِي، ؤُشَا أَكهَّانْ أَذْ إِسّْبخَّارْ أَيَا خْ ؤُعَالْطَارْ إِ ڒِيذَارثْ \add إِ ثوْهِيبْثْ نِّي\add*، أَقَا ذ إِشْثْ ن ثوْهِيبْثْ ن ثْمسِّي ذ إِشْثْ ن ڒفْوَاحثْ إِتّْفُوحنْ إِ سِيذِي. \x ◘ \xo 2:‏2 \xt لَاوِي 6‏:‏8\x*  
\v 3 مِينْ إِقِّيمنْ ن ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* \add أَذْ يِيڒِي\add* إِ هَارُونْ ؤُ إِ وَارَّاوْ نّسْ. \add أَقَا\add* ذ أَمْقدَّاسْ قَاعْ زِي مَارَّا ثِيوْهِيبِينْ ن ثْمسِّي ن سِيذِي. \x ◘ \xo 2:‏3 \xt لَاوِي 10‏:‏12\x*   
\m
\v 4 مَاڒَا ثْقدّْمذْ ثَاوْهِيبْثْ إِ إِدْجَانْ ذ \bd ثَاوْهِيبْثْ \+bdit ن ڒْغِيدْجثْ\+bdit* ذَارْحنْ ت ذِي ثفْقُونْثْ\bd*، \add خنِّي أَذْ ثِيڒِي\add* ذ ڒمْسمْنَاثْ بْڒَا أَنْثُونْ، إِخدْجْضنْ س زّشْثْ، ؤُڒَا ذ ثِيڒْفَافْ بْڒَا أَنْثُونْ تّْوَاذهْننْثْ س زّشْثْ، \add مَارَّا\add* زڭْ وَارنْ أَزْذَاذْ.   
\m
\v 5 مَاڒَا ثَاوْهِيبْثْ نّشْ ذ \bd ثَاوْهِيبْثْ \+bdit ن ڒْغِيدْجثْ\+bdit* ڭّْوِينْ ت خْ وخْذِيمْ\bd*، أَذْ ثِيڒِي ن وَارنْ أَزْذَاذْ إِخدْجْضنْ س زّشْثْ، وَارْذَايسْ بُو ونْثُونْ.   
\m
\v 6 أَذْ ثنْ ثَارْژذْ ذ إِفثْوِيثنْ ؤُشَا أَذْ خَاسْ ثْسيّْبذْ زّشْثْ. أَقَا-ت ذ إِشْثْ ن ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add*.   
\m
\v 7 مَاڒَا ثَاوْهِيبْثْ نّشْ ذ \bd ثَاوْهِيبْثْ \+bdit ن ڒْغِيدْجثْ\+bdit* ڭّْوِينْ ت ذِي طَّاجِّينْ\bd*، أَذْ ثِيڒِي ثوْجذْ س وَارنْ أَزْذَاذْ أَكْ-ذ زّشْثْ.  
\v 8 ثَاوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* إِ زَّايْسنْ إِوجْذنْ، أَذْ ت ثَاوْيذْ غَارْ سِيذِي. بْنَاذمْ أَذْ زَّايسْ د-إِقَارّبْ غَارْ ؤُكهَّانْ ؤُشَا وَانِيثَا أَذْ ت يَاوِي غَارْ ؤُعَالْطَارْ.  
\v 9 أَذْ إِكْسِي ؤُكهَّانْ زِي ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* إِشْثْ ن ڒِيذَارثْ ؤُشَا أَذْ \add ت\add* إِسّْبخَّارْ خْ ؤُعَالْطَارْ، \add أَقَا\add* ذ ثَاوْهِيبْثْ ن ثْمسِّي، ذ ڒفْوَاحثْ إِتّْفُوحنْ إِ سِيذِي.  
\v 10 مِينْ إِقِّيمنْ ن ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* أَذْ يِيڒِي إِ هَارُونْ ؤُ إِ وَارَّاوْ نّسْ. \add أَقَا-ث\add* ذ أَمْقدَّاسْ قَاعْ زِي ثوْهِيبِينْ ن ثْمسِّي ن سِيذِي.   
\m
\v 11 وَارْ إِعدّڒْ إِ ؤُڒَا ذ إِشْثْ ن ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* إِ غَا ثْقدّْممْ إِ سِيذِي أَذْ ثِيڒِي ثوْجذْ س ونْثُونْ. مَاغَارْ زِي مِينْ مَا ن ونْثُونْ ذ زِي مِينْ مَا ثَامّنْثْ وَارْ زَّايسْ ثسّْبخَّارَامْ شَا ؤُڒَا ذ إِشْثْ ن ثوْهِيبْثْ ن ثْمسِّي إِ سِيذِي.   
\m
\v 12 أَذْ ثِيوْيمْ \bd ثَاوْهِيبْثْ ن ؤُسُوفّغْ أَمزْوَارُو \+bdit ن صَّابثْ\+bdit*\bd* غَارْ سِيذِي، مَاشَا نِيثْنِي وَارْ زمَّارنْ أَذْ سّْبخَّارنْ \add ثَاوْهِيبْثْ-أَ\add* خْ ؤُعَالْطَارْ \add أَمْ\add* ڒفْوَاحثْ إِتّْفُوحنْ إِ سِيذِي. \x ◘ \xo 2:‏12 \xt ڒخْڒ. 18‏:‏12\x*   
\m
\v 13 كُوڒْ ثَاوْهِيبْثْ ن ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* نّشْ أَذْ ثِيڒِي ثْمدْجْحذْ س ثْمدْجَاحْطْ. ثَامدْجَاحْثْ ن ڒْعَاهْذْ ن أَربِّي نّشْ وَارْ ثْزمَّارْ أَذْ ثنْقصْ غَارْ ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* نّشْ. أَذْ ثْقدّْمذْ ثَامدْجَاحْثْ غَارْ كُوڒْ ثَاوْهِيبْثْ نّشْ. \x ◘ \xo 2:‏13 \xt مك. 9‏:‏49\x*   
\m
\v 14 مَاڒَا ثِيوْيذْ إِشْثْ ن ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* ن ثْمنْزُوثْ، أَذْ ثِيوْيذْ ثِيذْرِينْ يِيوْضنْ، ثِينِّي إِتّْوَافَارنْ خْ ثْمسِّي، أَكْ-ذ ڒْحبّْ أَزِيزَا إِبَارْينْ أَمْ ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* زِي ثْمنْزُوثْ نّشْ.  
\v 15 أَذْ خَاسْ ثْسيّْبذْ زّشْثْ ؤُ أَذْ خَاسْ ثسَّارْسذْ جَّاوِي، أَقَا ذ ثَاوْهِيبْثْ \add ن ڒْغِيدْجثْ\add*.  
\v 16 \add خنِّي\add* أَذْ إِسّْبخَّارْ ؤُكهَّانْ \add إِجّْ ن وزْينْ\add* زِي ڒْحبّْ إِبَارْينْ ؤُ زِي زّشْثْ نّسْ أَكْ-ذ مَارَّا جَّاوِي نّسْ إِ خَاسْ إِدْجَانْ أَمْ ثوْهِيبْثْ ن ڒِيذَارثْ ذِي مَانْ أَيَا. \add أَقَا\add* ذ ثَاوْهِيبْثْ ن ثْمسِّي إِ سِيذِي.“   
\b  
\b  
\m  
\c 3
\s1 ثِيغَارْصَا ن ڒحْنَا  
\m
\v 1 ”مَاڒَا ثَاوْهِيبْثْ نّسْ ذ \bd ثَاغَارْصْثْ ن ڒهْنَا\bd*، إِتّْخصَّا، مَاڒَا خنِّي إِسّْقَارّبْ-د \add أَمُودَّارْ\add*، أَذْ يِيڒِي ذ أَوْثمْ \add نِيغْ\add* ذ ثَاوْثمْثْ \bd ن إِفُونَاسنْ ذ ثْفُونَاسِينْ\bd*، أَذْ د-إِسّْقَارّبْ \add إِجّْ ن ؤُمُودَّارْ\add* إِشْنَانْ قَاعْ زَّاثْ إِ وُوذمْ ن سِيذِي.   
\m
\v 2 أَذْ إِسَّارْسْ أَفُوسْ نّسْ خْ ؤُزدْجِيفْ ن ثوْهِيبْثْ نّسْ ؤُشَا أَذْ أَسْ إِغَارْصْ قِيبَاتْشْ إِ وَاذَافْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ ؤُشَا أَرَّاوْ ن هَارُونْ، إِكهَّاننْ، أَذْ زدْجْعنْ إِذَامّنْ نّسْ خْ ؤُعَالْطَارْ غَارْ \add مَارَّا\add* إِغزْذِيسنْ \add نّسْ\add*.  
\v 3 زِي ثوْهِيبْثْ ن ڒهْنَا أَذْ إِقدّمْ إِشْثْ ثوْهِيبْثْ ن ثْمسِّي إِ سِيذِي، \add إِخْسْ أَذْ يِينِي\add* ثَاذُونْثْ إِ إِذْڒِينْ أَذَانْ ذ مَارَّا ثَاذُونْثْ \add إِ إِدْجَانْ\add* خْ وَاذَانْ. \x ◘ \xo 3:‏3 \xt ؤُف. 29‏:‏13، 22\x*  
\v 4 أَذْ إِكّسْ ثْنَاينْ ن ثِيژَّاڒْ أَكْ-ذ ثَاذُونْثْ إِ خَاسنْثْ \add إِدْجَانْ\add* غَارْ ثجْعِينَّا ؤُڒَا ذ مِينْ يُويْڒنْ غَارْ ثْسَا ؤُ \add يَارْسَا\add* خْ ثِيژَّاڒْ. \f ◼ \fr 3:‏4 \ft \+bd ’ثِيژَّاڒْ‘\+bd* - نِيغْ ’ثِيڭژْڒِينْ‘. ؤُڒَا ذِي أَيَاثْ 10 ذ 15.\f*  
\v 5 أَرَّاوْ ن هَارُونْ أَذْ سّْبخَّارنْ أَيَا خْ ؤُعَالْطَارْ خْ ثْغَارْصْثْ ن وشْمَاضْ إِ إِدْجَانْ خْ ؤُكشُّوضْ إِ ذِينْ إِدْجَانْ خْ ثْمسِّي. أَقَا-ث ذ ثَاوْهِيبْثْ ن ثْمسِّي، ذ إِشْثْ ن ڒفْوَاحثْ إِتّْفُوحنْ إِ سِيذِي. \x ◘ \xo 3:‏5 \xt ؤُف. 29‏:‏25؛ لَاوِي 6‏:‏5\x*   
\m
\v 6 مَاڒَا ثَاوْهِيبْثْ نّسْ ذ \bd ثَاغَارْصْثْ ن ڒهْنَا\bd* إِ سِيذِي، أَوْثمْ \add نِيغْ\add* ذ ثَاوْثمْثْ \bd ن وُودْجِي\bd*، \add خنِّي\add* أَذْ د-إِسّْقَارّبْ \add إِجّْ ن ؤُمُوذَارْ\add* إِشْنَانْ قَاعْ.   
\m
\v 7 مَاڒَا \bd ذ ؤُحُوڒِي\bd* إِ د-إِسّْقَارّبْ ذ ثَاغَارْصْثْ، \add خنِّي\add* أَذْ ث-إِ-د إِسّْقَارّبْ زَّاثْ إِ وُوذمْ ن سِيذِي.  
\v 8 نتَّا أَذْ إِسَّارْسْ أَفُوسْ نّسْ خْ ؤُزدْجِيفْ ن ثوْهِيبْثْ نّسْ ؤُشَا أَذْ أَسْ إِغَارْصْ زَّاثْ إِ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ، ؤُشَا أَرَّاوْ ن هَارُونْ أَذْ زدْجْعنْ إِذَامّنْ نّسْ خْ ؤُعَالْطَارْ غَارْ \add مَارَّا\add* إِغزْذِيسنْ \add نّسْ\add*.  
\v 9 أَذْ إِقدّمْ ثَاذُونْثْ ن ثْغَارْصْثْ نْ ڒهْنَا أَمْ يِيشْثْ ن ثوْهِيبْثْ ن ثْمسِّي إِ سِيذِي: مَارَّا ثَانوَّارْثْ \add ن ثَاذُونْثْ\add* نِّي يُوذْسنْ أَبعْصُوصْ أَذْ ت إِكّسْ، ؤُڒَا ذ ثَاذُونْثْ إِ إِذْڒِينْ أَذَانْ ذ مَارَّا ثَاذُونْثْ \add إِ إِدْجَانْ\add* خْ وَاذَانْ  
\v 10 ؤُشَا أَذْ إِكّسْ ؤُڒَا ذ ثْنَاينْ ن ثِيژَّاڒْ أَكْ-ذ ثَاذُونْثْ إِ خَاسنْثْ \add إِدْجَانْ\add* غَارْ ثجْعِينَّا ذ مِينْ يُويْڒنْ غَارْ ثْسَا ؤُ \add يَارْسَا\add* خْ ثِيژَّاڒْ.  
\v 11 أَكهَّانْ أَذْ إِسّْبخَّارْ أَيَا خْ ؤُعَالْطَارْ. \add أَقَا\add* ذ مَاشَّا، إِشْثْ ن ثوْهِيبْثْ ن ثْمسِّي إِ سِيذِي. \x ◘ \xo 3:‏11 \xt لَاوِي 21‏:‏6، 8، 17، 21، 22؛ 22‏:‏25؛ حِز. 44‏:‏7؛ مـَال. 1‏:‏12\x*   
\m
\v 12 مَاڒَا ثَاوْهِيبْثْ نّسْ ذ \bd إِغَايْضْ\bd*، \add خنِّي\add* أَذْ ث-إِ-د-إِسّْقَارّبْ زَّاثْ إِ وُوذمْ ن سِيذِي.  
\v 13 أَذْ إِسَّارْسْ أَفُوسْ نّسْ خْ ؤُزدْجِيفْ نّسْ ؤُشَا أَذْ أَسْ إِغَارْصْ زَّاثْ إِ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ، ؤُشَا أَرَّاوْ ن هَارُونْ أَذْ زدْجْعنْ \add شْوَايْثْ ن\add* إِذَامّنْ نّسْ خْ ؤُعَالْطَارْ غَارْ \add مَارَّا\add* إِغزْذِيسنْ \add نّسْ\add*.  
\v 14 أَذْ زَّايسْ إِقدّمْ ثَاوْهِيبْثْ نّسْ، \add إِخْسْ أَذْ يِينِي\add* ثَاذُونْثْ إِ إِذْڒِينْ أَذَانْ، ؤُ مَارَّا ثَاذُونْثْ إِ \add إِدْجَانْ\add* خْ وَاذَانْ، أَمْ ثوْهِيبْثْ ن ثْمسِّي إِ سِيذِي  
\v 15 ؤُشَا أَذْ إِكّسْ ؤُڒَا ذ ثْنَاينْ ن ثِيژَّاڒْ أَكْ-ذ ثَاذُونْثْ إِ خَاسنْثْ \add إِدْجَانْ\add* غَارْ ثجْعِينَّا ؤُڒَا ذ مِينْ يُويْڒنْ غَارْ ثْسَا ؤُ \add يَارْسَا\add* خْ ثِيژَّاڒْ.  
\v 16 أَكهَّانْ أَذْ إِسّْبخَّارْ أَيَا خْ ؤُعَالْطَارْ، \add أَقَا\add* ذ مَاشَّا ن ثوْهِيبْثْ ن ثْمسِّي س إِشْثْ ن ڒفْوَاحثْ إِتّْفُوحنْ. مَارَّا ثَاذُونْثْ \add أَذْ ثِيڒِي\add* إِ سِيذِي.  
\v 17 \add ثَا\add* ذ ثَاوْصيّثْ إِ ڒبْذَا إِ \add مَارَّا\add* جِّيڒَاثْ نْومْ، مَانِي مَا إِ غَا ثْزذْغمْ: مَارَّا ثَاذُونْثْ ذ مَارَّا إِذَامّنْ وَارْ ثنْ تّتّمْ.“ \x ◘ \xo 3:‏17 \xt أَمز. 9‏:‏4؛ لَاوِي 7‏:‏26؛ 17‏:‏10، 14\x*   
\b  
\b  
\m  
\c 4
\s1 ثِيغَارْصَا ن دّنْبْ  
\m
\v 1 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 2 ”سِيوڒْ أَكْ-ذ أَيْثْ ن إِسْرَائِيل، إِنِي:  
\m ’\bd مَاڒَا شَا ن يِيجّنْ إِخْضَا أَمْ إِودَّارْ\bd* خْ مَارَّا ثِيوصَّا ن سِيذِي، مِينْ وَارْ إِتّْخصِّي أَذْ إِتّْوَاڭّْ، ؤُ نتَّا إِخْضَا ذڭْ إِشْثْ زَّايْسنْثْ، \add خنِّي أَذْ ثِيڒِي ثْمسْڒَاشْثْ أَمُّو\add*:   
\m
\v 3 \bd مَاڒَا أَكهَّانْ أَمذْهُونْ إِخْضَا\bd*، أَڒَامِي إِذْوڒْ ڒْڭنْسْ إِخْضَا، أَذْ د-إِسّْقَارّبْ إِجّْ ن ؤُفُونَاسْ. - أَمژْيَانْ إِشْنَانْ قَاعْ ن إِشْثْ ن ثْفُونَاسْثْ - أَمْ ثْغَارْصْثْ ن دّنْبْ إِ سِيذِي ذِي طّْوعْ ن دّنْبْ نّسْ إِ إِڭَّا.  
\v 4 أَذْ يَاوِي أَفُونَاسْ \add نِّي\add* أَمژْيَانْ غَارْ وَاذَافْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ، زَّاثْ إِ وُوذمْ ن سِيذِي، ؤُشَا نتَّا أَذْ إِسَّارْسْ أَفُوسْ نّسْ خْ ؤُزدْجِيفْ ن ؤُفُونَاسْ أَمژْيَانْ ؤُشَا أَذْ أَسْ إِغَارْصْ إِ ؤُفُونَاسْ أَمژْيَانْ زَّاثْ إِ وُوذمْ ن سِيذِي.  
\v 5 \add خنِّي\add* أَكهَّانْ أَمذْهُونْ أَذْ إِكْسِي \add شَا\add* زڭْ إِذَامّنْ ن ؤُفُونَاسْ أَمژْيَانْ ؤُشَا أَذْ ث يَاوِي غَارْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ.  
\v 6 أَذْ إِسُّوفْ ؤُكهَّانْ أَضَاضْ نّسْ ذڭْ إِذَامّنْ ؤُشَا أَذْ إِرُوشّْ شَا زڭْ إِذَامّنْ نِّي سبْعَا ن ثْوَاڒَاوِينْ زَّاثْ إِ وُوذمْ ن سِيذِي، زَّاثْ إِ ؤُڒحَّافْ ن زَّاوشْثْ إِقدّْسنْ. \x ◘ \xo 4:‏6 \xt لَاوِي 16‏:‏14؛ ڒخْڒ. 19‏:‏4\x*  
\v 7 أَذْ إِڭّْ ؤُكهَّانْ \add شْوَايْثْ\add* ن إِذَامّنْ خْ وَاشَّاونْ ن ؤُعَالْطَارْ إِ ڒبْخُورْ إِتّْفُوحنْ إِ \add ذِينْ\add* زَّاثْ إِ وُوذمْ ن سِيذِي ذڭْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ. نتَّا أَذْ إِفَارّغْ مَارَّا إِذَامّنْ \add إِ إِقِّيمنْ\add* ن ؤُفُونَاسْ أَمژْيَانْ غَارْ ؤُضَارْ ن ؤُعَالْطَارْ ن وشْمَاضْ غَارْ وَاذَافْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ. \f ◼ \fr 4:‏7 \ft \+bd ’أَشَّاونْ‘\+bd* - نِيغْ ’إِقِيشَّاونْ‘. ؤُڒَا ذِي أَيَاثْ 18، 25، 30 ذ 34.\f*  \x ◘ \xo 4:‏7 \xt لَاوِي 9‏:‏9\x*  
\v 8 أَذْ إِكّسْ مَارَّا ثَاذُونْثْ ن ؤُفُونَاسْ أَمژْيَانْ ن ثْغَارْصْثْ: ثَاذُونْثْ إِ إِذْڒِينْ أَذَانْ ذ مَارَّا ثَاذُونْثْ \add إِ إِدْجَانْ\add* خْ وَاذَانْ \f ◼ \fr 4:‏8 \ft \+bd ’أَذْ إِكّسْ‘\+bd* - س ثْعِيبْرَانِيثْ‘ ’أَذْ إِسّْڭَاعّذْ‘.\f*  \x ◘ \xo 4:‏8 \xt لَاوِي 3‏:‏3، 4\x*  
\v 9 ؤُشَا أَذْ إِكّسْ ثْنَاينْ ن ثِيژَّاڒْ أَكْ-ذ ثَاذُونْثْ إِ خَاسنْثْ \add إِدْجَانْ\add* غَارْ ثجْعِينَّا ؤُڒَا ذ مِينْ يُويْڒنْ غَارْ ثْسَا ؤُ \add يَارْسَا\add* خْ ثِيژَّاڒْ، \f ◼ \fr 4:‏9 \ft \+bd ’ثِيژَّاڒْ‘\+bd* - نِيغْ ’ثِيڭژْڒِينْ‘.\f*  
\v 10 أَمْ مَامّشْ إِكّسْ مَانْ أَيَا خْ ؤُفُونَاسْ ن ثْغَارْصِي ن ڒهْنَا، ؤُشَا أَكهَّانْ أَذْ إِسّْبخَّارْ أَيَا خْ ؤُعَالْطَارْ ن وشْمَاضْ. \x ◘ \xo 4:‏10 \xt لَاوِي 3‏:‏5\x*  
\v 11 إِڒمْ ن ؤُفُونَاسْ أَمژْيَانْ ذ مَارَّا أَيْسُومْ نّسْ أَكْ-ذ ؤُزدْجِيفْ ذ إِشكْرَاذْ نّسْ ذ وَاذَانْ نّسْ ذ ؤُمسَّاڒْ نّسْ \add إِ ذَايسْ\add*، \x ◘ \xo 4:‏11 \xt ؤُف. 29‏:‏14؛ ڒخْڒ. 19‏:‏5\x*  
\v 12 أَقَا مَارَّا أَفُونَاسْ أَمژْيَانْ أَذْ ث إِسُّوفّغْ بَارَّا إِ ڒْمَارْڭحْ ن ڒْعسْكَارْ غَارْ إِجّْ ن ومْشَانْ إِصْفَا مَانِي تّڭّنْ إِغّضْ إِ إِقِّيمنْ ن ثَاذُونْثْ ؤُشَا أَذْ ث إِسّشْمضْ س ثْمسِّي خْ ؤُكشُّوضْ. أَذْ ث شمْضنْ مَانِي زدْجْعنْ إِغّضْ. \x ◘ \xo 4:‏12 \xt لَاوِي 16‏:‏27؛ ڒخْڒ. 19‏:‏3؛ عبر. 13‏:‏11\x*   
\m
\v 13 \bd مَاڒَا ثفّغْ ثْمسْمُونْثْ ن إِسْرَائِيل مَارَّا زڭْ وبْرِيذْ\bd* ؤُشَا ثفَّارْ ثْمسْڒَاشْثْ خْ ثِيطَّاوِينْ ن وڭْرَاوْ \add ن ڒْڭنْسْ\add*، ؤُشَا نِيثْنِي ڭِّينْ إِشْثْ \add ن ڒْحَاجّثْ\add* \add نِّي إِفّْغنْ\add* خْ مَارَّا ثِيوصَّا ن سِيذِي، \add زِي جِّيهثْ ن\add* مِينْ وَارْ إِتّْخصِّي أَذْ يڭّْ، ؤُشَا إِذْوڒْ ذَايْسنْ ؤُمَارْوَاسْ، \x ◘ \xo 4:‏13 \xt لَاوِي 9‏:‏15؛ ڒخْڒ. 15‏:‏24‏-‏31\x*  
\v 14 ؤُشَا إِبَانْ-د دّنْبْ إِ زِي إِفّْغنْ خْ وبْرِيذْ ن ڒُومُورَاثْ، \add خنِّي\add* أَذْ د-إِسّْقَارّبْ وڭْرَاوْ \add ن ڒْڭنْسْ\add* إِجّْ ن ؤُفُونَاسْ - أَمژْيَانْ ن ثْفُونَاسْثْ - ذ ثَاغَارْصْثْ إِ دّنْبْ، ؤُشَا أَذْ ث أَوْينْ زَّاثْ إِ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ.  
\v 15 إِمْغَارنْ ن ثْمسْمُونْثْ أَذْ سَّارْسنْ إِفَاسّنْ نْسنْ خْ ؤُزدْجِيفْ ن ؤُفُونَاسْ أَمژْيَانْ زَّاثْ إِ وُوذمْ ن سِيذِي ؤُشَا نتَّا أَذْ أَسْ إِغَارْصْ إِ ؤُفُونَاسْ \add نِّي\add* أَمژْيَانْ زَّاثْ إِ وُوذمْ ن سِيذِي.  
\v 16 أَكهَّانْ أَمذْهُونْ أَذْ يَاوِي \add شْوَايْثْ\add* زڭْ إِذَامّنْ ن ؤُفُونَاسْ أَمژْيَانْ غَارْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ،  
\v 17 ؤُشَا أَذْ إِسُّوفْ ؤُكهَّانْ أَضَاضْ نّسْ ذڭْ إِذَامّنْ ؤُشَا أَذْ إِرُوشّْ \add س إِذَامّنْ نِّي\add* سبْعَا ن ثْوَاڒَاوِينْ زَّاثْ إِ وُوذمْ ن سِيذِي، زَّاثْ إِ ؤُڒحَّافْ.  
\v 18 نتَّا أَذْ إِڭّْ \add شْوَايْثْ\add* زڭْ إِذَامّنْ \add نِّي\add* خْ وَاشَّاونْ ن ؤُعَالْطَارْ نِّي \add إِدْجَانْ\add* زَّاثْ إِ وُوذمْ ن سِيذِي ذڭْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ. \add خنِّي\add* أَذْ إِفَارّغْ مَارَّا إِذَامّنْ \add إِشطّنْ\add* غَارْ ؤُضَارْ ن ؤُعَالْطَارْ ن وشْمَاذْ إِ ذِينْ زَّاثْ إِ وَاذَافْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ.  
\v 19 أَذْ خَاسْ إِكّسْ مَارَّا ثَاذُونْثْ ؤُشَا أَذْ \add ت\add* إِسّْبخَّارْ خْ ؤُعَالْطَارْ.  
\v 20 ؤُشَا أَذْ إِڭّْ س ؤُفُونَاسْ أَمژْيَانْ أَمْ مَامّشْ إِڭَّا س ؤُفُونَاسْ أَمژْيَانْ ن ثْغَارْصْثْ ن دّنْبْ، أَمُّو إِ غَا يڭّْ. أَكهَّانْ أَذْ خَاسنْ إِڭّْ أَصْڒَاحْ ؤُشَا أَذْ أَسنْ إِتّْوَاغْفَارْ. \f ◼ \fr 4:‏20 \ft \+bd ’إِفْذِي‘\+bd* - خْزَارْ إِزهد. 78:35.\f*  
\v 21 \add خنِّي\add* أَذْ إِسُّوفّغْ أَفُونَاسْ أَمژْيَانْ بَارَّا إِ ڒْمَارْڭحْ ن ڒْعسْكَارْ ؤُشَا أَذْ ث إِسّشْمضْ أَمْ مَامّشْ إِسّشْمضْ أَفُونَاسْ أَمزْوَارُو. \add أَقَا-ت\add* ذ ثَاغَارْصْثْ ن دّنْبْ ن وڭْرَاوْ \add ن ڒْڭنْسْ\add*.   
\m
\v 22 \bd مَاڒَا إِجّْ ن ڒْحَاكمْ إِخْضَا،\bd* ؤُشَا س ؤُودَّارْ إِڭَّا إِشْثْ ن ڒْحَاجّثْ \add نِّي إِتّفّْغنْ خْ وبْرِيذْ\add* ن مَارَّا ثِيوصَّا ن سِيذِي، أَربِّي نّسْ، إِ وَارْ إِتّْشُووَّارنْ أَذْ إِتّْوَاڭّْ، ؤُشَا إِذْوڒْ ذَايسْ ؤُمَارْوَاسْ،  
\v 23 نِيغْ \add مَاڒَا\add* إِتّْوَاسَّارْڭبْ أَسْ ؤُخطُّو نّسْ إِ إِڭَّا ضِيدّْ إِ \add ڒُْومُورْ\add*، أَذْ ثِيڒِي ثوْهِيبْثْ نّسْ، ثنِّي إِ غَا إِقدّمْ، ذ إِجّْ ن ؤُمْيَانْ زڭْ إِغَايْضنْ، إِجّْ ن ووْثمْ إِشْنَانْ قَاعْ.  
\v 24 أَذْ إِسَّارْسْ أَفُوسْ نّسْ خْ ؤُزدْجِيفْ ن ؤُمْيَانْ ؤُشَا أَذْ أَسْ إِغَارْصْ ذڭْ ومْشَانْ مَانِي غَارْصنْ إِ ثَاغَارْصْثْ ن وشْمَاضْ زَّاثْ إِ وُوذمْ ن سِيذِي. \add أَقَا\add* ذ ثَاغَارْصْثْ ن دّنْبْ.  
\v 25 \add خنِّي\add* أَذْ إِكْسِي ؤُكهَّانْ س ؤُضَاضْ نّسْ \add شْوَايْثْ\add* زڭْ إِذَامّنْ ن ثْغَارْصْثْ ن دّنْبْ ؤُشَا أَذْ ثنْ إِڭّْ خْ وَاشَّاونْ ن ؤُعَالْطَارْ ن وشْمَاضْ ؤُشَا \add خنِّي\add* أَذْ إِفَارّغْ إِذَامّنْ \add إِشطّنْ\add* غَارْ ؤُضَارْ ن ؤُعَالْطَارْ ن وشْمَاضْ.  
\v 26 أَذْ إِسّْبخَّارْ مَارَّا ثَاذُونْثْ نّسْ خْ ؤُعَالْطَارْ، أَمْ مَامّشْ \add ذ أَسْ إِڭَّا إِ\add* ثَاذُونْثْ ن ثْغَارْصْثْ ن ڒهْنَا. أَكهَّانْ أَذْ خَاسْ إِڭّْ أَصْڒَاحْ ذِي طّْوعْ ن دّنْبْ نّسْ ؤُشَا أَذْ أَسْ إِتّْوَاغْفَارْ. \f ◼ \fr 4:‏26 \ft \+bd ’إِفْذِي‘\+bd* - خْزَارْ إِزهد. 78:35.\f*   
\m
\v 27 \bd مَاڒَا إِجّنْ بْنَاذمْ زِي ڒْڭنْسْ ن ثمُّورْثْ إِخْضَا س ؤُودَّارْ\bd* أَمْ إِڭَّا \add مْغِيرْ\add* إِشْثْ ن ڒْحَاجّثْ \add نِّي إِتّفّْغنْ\add* خْ إِشْثنْ ن ثْوصَّا ن سِيذِي، مِينْ وَارْ إِتّْشُووَّارْ أَذْ إِتّْوَاڭّْ، ؤُشَا إِذْوڒْ ذَايسْ ؤُمَارْوَاسْ، \x ◘ \xo 4:‏27 \xt ڒخْڒ. 15‏:‏27\x*  
\v 28 نِيغْ إِتّْوَاسَّارْڭبْ أَسْ ؤُخطُّو نّسْ إِ إِڭَّا، \add خنِّي\add* أَذْ ثِيڒِي ثوْهِيبْثْ نّسْ نِّي إِ غَا إِقدّمْ ذ \bd إِشْثْ ن ثْغَايْضثْ\bd*، إِشْثْ ن ثوْثمْثْ إِشْنَانْ قَاعْ، ذ ثَاغَارْصْثْ خْ دّنْبْ إِ إِڭَّا.  
\v 29 أَذْ إِسَّارْسْ أَفُوسْ نّسْ خْ ؤُزدْجِيفْ ن ثْغَارْصْثْ ن دّنْبْ ؤُشَا أَذْ أَسْ إِغَارْصْ إِ ثْغَارْصْثْ ن دّنْبْ ذڭْ ومْشَانْ ن ثْغَارْصْثْ ن وشْمَاضْ.  
\v 30 \add خنِّي\add* أَذْ إِكْسِي ؤُكهَّانْ س ؤُضَاضْ نّسْ \add شْوَايْثْ\add* زڭْ إِذَامّنْ ؤُشَا أَذْ ث إِڭّْ غَارْ وَاشَّاونْ ن ؤُعَالْطَارْ ن ثْغَارْصْثْ ن وشْمَاضْ ؤُشَا أَذْ إِفَارّغْ مَارَّا إِذَامّنْ \add إِشطّنْ\add* غَارْ ؤُضَارْ ن ؤُعَالْطَارْ.  
\v 31 أَذْ خَاسْ إِكّسْ مَارَّا ثَاذُونْثْ نّسْ أَمْ مَامّشْ كّْسنْ ثَاذُونْثْ ن ثْغَارْصْثْ ن ڒهْنَا ؤُشَا أَكهَّانْ أَذْ ت إِسّْبخَّارْ خْ ؤُعَالْطَارْ، أَذْ ثِيڒِي ذ إِشْثْ ن ڒفْوَاحثْ إِتّْفُوحنْ إِ سِيذِي. ؤُشَا أَكهَّانْ أَذْ خَاسْ إِڭّْ أَصْڒَاحْ ؤُشَا أَذْ أَسْ إِتّْوَاغْفَارْ. \x ◘ \xo 4:‏31 \xt ؤُف. 29‏:‏18؛ لَاوِي 3‏:‏3، 4 ،14\x*   
\m
\v 32 مَاڒَا إِقدّمْ \bd إِجّْ ن إِزْمَارْ\bd* ذ ثَاوْهِيبْثْ إِ ثْغَارْصْثْ ن دّنْبْ، \add خنِّي\add* أَذْ إِقدّمْ إِشْثْ ن ثَاوْثمْثْ إِشْنَانْ قَاعْ.  
\v 33 أَذْ إِسَّارْسْ أَفُوسْ نّسْ خْ ؤُزدْجِيفْ ن ثْغَارْصْثْ ن دّنْبْ ؤُشَا أَذْ أَسْ إِغَارْصْ إِ ثْغَارْصْثْ ن دّنْبْ ذڭْ ومْشَانْ مَانِي غَارْصنْ إِ ثْغَارْصْثْ ن وشْمَاضْ.  
\v 34 \add خنِّي\add* أَذْ إِكْسِي ؤُكهَّانْ س ؤُضَاضْ نّسْ \add شْوَايْثْ\add* زڭْ إِذَامّنْ ن ثْغَارْصْثْ ن دّنْبْ ؤُشَا أَذْ ث إِڭّْ خْ وَاشَّاونْ ن ؤُعَالْطَارْ ن وشْمَاضْ ؤُشَا أَذْ إِفَارّغْ مَارَّا إِذَامّنْ نّسْ \add إِشطّنْ\add* غَارْ ؤُضَارْ ن ؤُعَالْطَارْ.  
\v 35 أَذْ خَاسْ إِكّسْ مَارَّا ثَاذُونْثْ نّسْ، أَمْ مَامّشْ إِكّسْ ثَاذُونْثْ ن ؤُحُوڒِي ن ثْغَارْصْثْ ن ڒهْنَا، ؤُشَا أَكهَّانْ أَذْ ت إِسّْبخَّارْ خْ ؤُعَالْطَارْ، خْ ثوْهِيبِينْ ن ثْمسِّي إِ سِيذِي ؤُشَا أَكهَّانْ أَذْ خَاسْ إِڭّْ أَصْڒَاحْ خْ دّنْبْ إِ إِڭَّا، ؤُشَا أَذْ أَسْ إِتّْوَاغْفَارْ.‘ “   
\b  
\b  
\m  
\c 5
\m
\v 1 ”مَاڒَا إِخْضَا حذْ \add ؤُمِي\add* \bd إِسْڒَا أَهجِّي ن إِشْثْ ن نّعْڒثْ\bd* ؤُشَا نتَّا ذ أَشهَّاذْ خَاسْ، نِيغْ إِژْرَا \add إِ-ث\add* نِيغْ إِسّنْ \add إِ-ث\add*: مَاڒَا وَارْ \add خَاسْ\add* إِقَّارْ وَالُو، \add خنِّي\add* أَذْ يَارْبُو ڒْمُوعْصِييّثْ نّسْ. \f ◼ \fr 5:‏1 \ft \+bd ’أَهجِّي‘\+bd* - س ثْعِيبْرَانِيثْ ’ثْمِيجَّا‘.\f*   
\m
\v 2 نِيغْ مَاڒَا \bd إِحَاذَا حذْ مِينْ مَا زِي ثْمسْڒَاشْثْ إِخمْجنْ\bd*، ڒْخشْبثْ ن ڒْمَاڒْ إِخْمجْ، نِيغْ ڒْخشْبثْ ن ڒبْهِيمثْ إِخمْجنْ، نِيغْ ڒْخشْبثْ ن \add ؤُمُودَّارْ\add* إِخْمجْ إِتّْبُوعنْ، ؤُشَا نتَّا وَارْ إِسِّينْ \add أَيَا\add*، أَقَا إِخْمجْ ؤُ ذَايسْ أَمَارْوَاسْ. \x ◘ \xo 5:‏2 \xt حَاڭ. 2‏:‏13؛ 2 كُور. 6‏:‏17\x*   
\m
\v 3 نِيغْ مَاڒَا \bd إِحَاذَا \+bdit شَا ن\+bdit* ڒخْمجْ ن بْنَاذمْ\bd*، مِينْ مَا زِي ڒخْمجْ نّسْ إِ زِي إِذْوڒْ نتَّا إِخْمجْ، مَاڒَا ثنُّوفَّارْ خَاسْ ؤُشَا إِسّنْ إِثْ \add أَوَارْنِي أَسْ\add*، أَقَا ذَايسْ أَمَارْوَاسْ.   
\m
\v 4 نِيغْ \bd مَاڒَا إِژُّودْجْ حذْ س ثْشَارْفَايحْ نّسْ\bd*، مَاحنْذْ أَذْ إِڭّْ ڒْغَارْ نِيغْ أَذْ إِڭّْ ڒْخَارْ، \add نِيغْ\add* مِينْ مَا إِزمَّارْ بْنَاذمْ أَذْ إِنْطقْ أَمنِّي وَاهَا س إِشْثْ ن ثْجَادْجِيثْ، أَمْ وَارْ ت إِسِّينْ، \add مَاشَا\add* إِسّنْ إِ-ث \add أَوَارْنِي مَانْ أَيَا\add*، أَقَا ذَايسْ أَمَارْوَاسْ ذِي سِّيبّثْ ن إِشْثْ زِي ثْمسْڒَايِينْ-أَ.   
\m
\v 5 \add خنِّي\add* أَذْ إِمْسَارْ، مَاڒَا ذَايسْ أَمَارْوَاسْ ذِي سِّيبّثْ ن إِشْثنْ \add زِي ثْمسْڒَايِينْ-أَ\add*، أَذْ إِنْعمْ خْ مِينْ ثُوغَا إِخْضَا. \f ◼ \fr 5:‏5 \ft \+bd ’إِشْثنْ \+bdit زِي ثْمسْڒَايِينْ-أَ\+bdit*‘\+bd* - س ثْعِيبْرَانِيثْ ’إِشْثنْ زَّايْسنْثْ‘، ؤُڒَا ذِي أَيَاثْ 13.\f*  
\v 6 خْ دّنْبْ إِ إِڭَّا، إِتّْخصَّا أَسْ أَذْ إِقدّمْ إِشْثْ ن ثوْثمْثْ ن وُودْجِي ذ ثَاغَارْصْثْ ن ؤُمَارْوَاسْ، إِشْثْ ن ثخْسِي نِيغْ إِشْثْ ن ثْغَايْضثْ، ذ ثَاغَارْصْثْ ن دّنْبْ إِ سِيذِي، ؤُشَا أَكهَّانْ أَذْ خَاسْ إِڭّْ أَصْڒَاحْ ذِي سِّيبّثْ ن دّنْبْ نّسْ.\f ◼ \fr 5:‏6 \ft \+bd ’إِفْذِي‘\+bd* - خْزَارْ إِزهد. 78:35.\f*   
\m
\v 7 مَاشَا مَاڒَا أَفُوسْ نّسْ وَارْ \add غَارسْ مِينْ\add* إِقدّنْ إِ يِيجّْ زڭْ وُودْجِي، \add خنِّي\add* أَذْ يَاوِي إِ سِيذِي إِ ثْغَارْصْثْ ن ؤُمَارْوَاسْ خْ دّنْبْ إِ إِڭَّا، ثْنَاينْ ن ثجْلِيلِّيحِينْ نِيغْ ثْنَاينْ ن إِذْبِيرنْ إِمژْيَاننْ، إِجّنْ إِ ثْغَارْصْثْ ن دّنْبْ ؤُ إِجّنْ إِ ثْغَارْصْثْ ن وشْمَاضْ. \x ◘ \xo 5:‏7 \xt لَاوِي 12‏:‏8؛ لك. 2‏:‏24\x*  
\v 8 أَذْ ثنْ يَاوِي غَارْ ؤُكهَّانْ، ونِّي د غَا يَاوْينْ ذ أَمزْوَارُو \add ثَاجْلِيلِّيحْثْ نِيغْ أَضْبِيرْ\add* إِ \add إِدْجَانْ\add* إِ ثْغَارْصْثْ ن دّنْبْ ؤُشَا أَذْ إِكّسْ أَزدْجِيفْ نّسْ زِي شْوَايْثْ أَوَارْنِي يِيرِي نّسْ، \add مَاشَا\add* وَارْ ث إِبطِّي \add مَارَّا\add*. \x ◘ \xo 5:‏8 \xt لَاوِي 1‏:‏15\x*  
\v 9 أَذْ إِرُوشّْ \add شْوَايْثْ\add* ن إِذَامّنْ غَارْ ؤُغزْذِيسْ ن ؤُعَالْطَارْ ؤُشَا مِينْ إِشطّنْ زڭْ إِذَامّنْ، أَذْ \add ث\add* إِژمّْ غَارْ ؤُضَارْ ن ؤُعَالْطَارْ. \add أَقَا-ت\add* ذ ثَاغَارْصْثْ ن دّنْبْ.  
\v 10 أَذْ إِسّوْجذْ \add أَمدَّارْ\add* نّغْنِي أَمْ ثْغَارْصْثْ ن وشْمَاضْ عْلَاحْسَابْ لْفَارِيضَا ؤُشَا \add أَمُّو\add* إِ خَاسْ إِ غَا يڭّْ ؤُكهَّانْ أَصْڒَاحْ خْ دّنْبْ نّسْ إِ إِڭَّا ؤُشَا أَذْ أَسْ إِتّْوَاغْفَارْ.\x ◘ \xo 5:‏10 \xt لَاوِي 1‏:‏15\x*  
\v 11 مَاڒَا أَفُوسْ نّسْ وَارْ \add غَارسْ مِينْ\add* إِقدّنْ إِ ثْنَاينْ ن ثجْلِيلِّيحِينْ نِيغْ إِ ثْنَاينْ ن إِذْبِيرنْ إِمژْيَاننْ، \add خنِّي\add* ونِّي إِخْضَانْ، أَذْ يَاوِي أَمْ ثوْهِيبْثْ نّسْ ثَاعْشَارْثْ ن إِجّْ ن إِفَا ن وَارنْ أَزْذَاذْ ذ ثَاوْهِيبْثْ ن دّنْبْ. وَارْ خَاسْ إِتّڭّْ زّشْثْ ؤُڒَا وَارْ خَاسْ إِسّْرُوسِي جَّاوِي، مِينْزِي أَقَا-ت ذ ثَاغَارْصْثْ ن دّنْبْ.  
\v 12 أَذْ ت يَاوِي غَارْ ؤُكهَّانْ ؤُشَا أَكهَّانْ أَذْ زَّايسْ إِكْسِي إِجّْ ن وُورُو إِشُّورْ ؤُشَا أَذْ إِسّْبخَّارْ أَيَا أَمْ ڒِيذَارثْ ذَايسْ خْ ؤُعَالْطَارْ، خْ ثوْهِيبِينْ ن ثْمسِّي إِ سِيذِي. \add أَقَا-ت\add* ذ ثَاغَارْصْثْ ن دّنْبْ. \x ◘ \xo 5:‏12 \xt لَاوِي 2‏:‏2؛ 4‏:‏35\x*  
\v 13 \add أَمُّو إِ\add* خَاسْ غَا يڭّْ ؤُكهَّانْ أَصْڒَاحْ خْ دّنْبْ نّسْ نِّي إِڭَّا زِي جِّيهثْ ن إِشْثنْ زِي ثْمسْڒَايِينْ-أَ ؤُشَا أَذْ أَسْ إِتّْوَاغْفَارْ. مِينْ إِشطّنْ أَذْ يِيڒِي إِ إِكهَّاننْ أَمْ مَامّشْ \add إِ يدْجَانْ أَكْ-ذ\add* ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add*.“ \x ◘ \xo 5:‏13 \xt لَاوِي 2‏:‏3\x*   
\b  
\m  
\s1 ثِيغَارْصَا ن ؤُمَارْوَاسْ  
\m
\v 14 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 15 ”مَاڒَا إِڭَّا حذْ س ڒغْذَارْ ؤُشَا \bd إِخْضَا س ؤُودَّارْ ذِي ثْمسْڒَايِينْ إِقدّْسنْ ن سِيذِي\bd*، إِتّْخصَّا أَذْ يَاوِي إِشَارِّي إِشْنَانْ قَاعْ زڭْ وُودْجِي ذ ثَاغَارْصْثْ ن ؤُمَارْوَاسْ إِ سِيذِي. \add أَذْ ثِيڒِي ڒْقِيمثْ نّسْ\add* عْلَاحْسَابْ ڒْقِيمثْ إِ ثْقدَّارذْ شكْ ذڭْ إِشِيقْلُوثنْ ن نُّوقَارْثْ عْلَاحْسَابْ شِيقْلُو ن زَّاوشْثْ إِقدّْسنْ. \add أَقَا\add* ذ ثَاغَارْصْثْ ن ؤُمَارْوَاسْ. \x ◘ \xo 5:‏15 \xt ؤُف. 30‏:‏13؛ لَاوِي 27‏:‏2‏-‏27.\x*  
\v 16 زِي ثْمسْڒَايِينْ إِقدّْسنْ أَذْ يَارّْ ذِي مِينْ ذِي إِخْضَا قْبڒْ، ؤُشَا أَذْ ذَايسْ يَارْنِي ڒخْمُوسْ. ؤُشَا أَذْ إِوْشْ مَانْ أَيَا إِ ؤُكهَّانْ ؤُشَا أَكهَّانْ أَذْ ث إِسّصْڒحْ س إِشَارِّي ن ثْغَارْصْثْ ن ؤُمَارْوَاسْ ؤُشَا أَذْ أَسْ إِتّْوَاغْفَارْ.  
\v 17 مَاڒَا إِخْضَا حذْ ؤُشَا إِڭَّا إِشْثْ ن ثْمسْڒَاشْثْ إِ وَارْ ثتّْشُووَّارْ أَذْ ثتّْوَاڭّْ، \add أَمْ د-إِفّغْ\add* ذڭْ إِشْثْ ن ثْمسْڒَاشْثْ زِي ثْوصَّا ن سِيذِي، ؤُشَا ثُوغَا ثْنُوفَّارْ خَاسْ، أَذْ ذَايسْ يِيڒِي ؤُمَارْوَاسْ ؤُشَا أَذْ يَارْبُو ڒْمُوعْصِييّثْ نّسْ.  
\v 18 أَذْ يَاوِي إِجّْ ن إِشَارِّي إِشْنَانْ قَاعْ زڭْ وُودْجِي غَارْ ؤُكهَّانْ إِ ثْغَارْصْثْ ن ؤُمَارْوَاسْ، \add أَذْ ثِيڒِي ڒْقِيمثْ نّسْ\add* عْلَاحْسَابْ ڒْقِيمثْ إِ ثْقدَّارذْ شكْ ؤُشَا أَذْ ث إِسّصْڒحْ ؤُكهَّانْ خْ ؤُودَّارْ نّسْ إِ ذِي إِودَّارْ أَمْ وَارْ ث إِسِّينْ ؤُشَا أَذْ أَسْ إِتّْوَاغْفَارْ.  
\v 19 أَقَا ذ ثَاغَارْصْثْ ن ؤُمَارْوَاسْ. س ثِيذتّْ ثُوغَا ذَايسْ أَمَارْوَاسْ زَّاثْ إِ سِيذِي.“   
\b  
\m
\v 20 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 21 ”مَاڒَا إِخْضَا حذْ ؤُشَا إِغْذَارْ سِيذِي أَمْ إِسّْخَارِّيقْ خْ جَّارْ نّسْ خْ مِينْ \add ذ أَسْ\add* إِمّوْشنْ، مَاحنْذْ أَذْ ث إِحْضَا، نِيغْ خْ مِينْ إِجَّا ذڭْ ؤُفُوسْ نّسْ، نِيغْ خْ مِينْ \add خَاسْ\add* يُوشَارنْ، نِيغْ خْ شَا ن ؤُبعّجْ إِ إِڭَّا إِ جَّارْ نّسْ،  
\v 22 نِيغْ أَمْ إِسّْخَارِّيقْ خْ \add شَا\add* مِينْ إِودَّارنْ \add إِ شَا ن يِيجّنْ\add* ؤُ إِتّْوَافْ زَّايسْ ؤُشَا \add خنِّي\add* نتَّا إِجُّودْجْ ژُورْ، \add وَاهْ، أَمْ إِسّْخَارِّيقْ نتَّا\add* خْ إِشْثنْ زِي مَارَّا \add ثِيمسْڒَايِينْ نِّي\add* إِتّڭّْ بْنَاذمْ أَڒَامِي إِخطَّا س مَانْ أَيَا، \x ◘ \xo 5:‏22 \xt Num 5‏:‏6\x*  
\v 23 خنِّي إِتّْخصَّا، ؤُمِي إِخْضَا ؤُشَا إِذْوڒْ ذَايسْ ؤُمَارْوَاسْ، أَقَا نتَّا أَذْ د-يَارّْ ثُوشفَّارْثْ نِّي يُوشَارْ، نِيغْ مِينْ إِتّْوَاكّْسنْ نِّي إِكْسِي نتَّا س ؤُغِيڒْ، نِيغْ مِينْ ثُوغَا إِحْضَا نِّي ذ أَسْ إِمّوْشنْ مَاحنْذْ أَذْ ت إِحْضَا، نِيغْ مِينْ إِودَّارنْ نِّي يُوفَا.  
\v 24 ؤُشَا مَارَّا مِينْ خفْ إِجُّودْجْ ژُورْ، أَذْ د-يَارّْ ڒْقِيمثْ نّسْ ثْمُونْ ؤُشَا أَذْ يَارْنِي ڒخْمُوسْ. نتَّا أَذْ ث إِوْشْ إِ ونِّي ؤُمِي د-ثُوسَا ذڭْ وَاسّْ ن ثْغَارْصْثْ نّسْ ن ؤُمَارْوَاسْ.  
\v 25 نتَّا أَذْ يَاوِي ثَاغَارْصْثْ نّسْ ن ؤُمَارْوَاسْ غَارْ سِيذِي، إِجّْ ن إِشَارِّي إِشْنَانْ قَاعْ زڭْ وُودْجِي، \add ونِّي ڒْقِيمثْ نّسْ أَذْ ثِيڒِي\add* عْلَاحْسَابْ ڒْقِيمثْ إِ ثْقدَّارذْ شكْ، أَذْ ثِيڒِي ذ ثَاغَارْصْثْ ن ؤُمَارْوَاسْ، \add ؤُشَا أَذْ ث يَاوِي\add* غَارْ ؤُكهَّانْ.  
\v 26 \add خنِّي\add* أَكهَّانْ أَذْ خَاسْ إِڭّْ أَسْڒَاحْ زَّاثْ إِ وُوذمْ ن سِيذِي ؤُشَا أَذْ أَسْ إِتّْوَاغْفَارْ خْ مِينْ إِڭَّا، مَاڒَا إِذْوڒْ ذَايسْ أَمَارْوَاسْ س إِشْثْ ن ثْمسْڒَاشْثْ زِي مَارَّا ثِيمسْڒَايِينْ-أَ.“   
\b  
\b  
\m  
\c 6
\m
\v 1 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 2 ”ؤُمُورْ هَارُونْ ذ وَارَّاوْ نّسْ، إِنِي أَسنْ: ’وَا ذ \bd أَزرْفْ إِ ثْغَارْصْثْ ن وشْمَاضْ\bd*. ثَاغَارْصْثْ ن وشْمَاضْ خْ ؤُكشُّوضْ خْ ؤُعَالْطَارْ أَذْ ثقِّيمْ ثَارقّْ دْجِيڒثْ ثكْمڒْ أَڒْ صّْبحْ ؤُ إِتّْخصَّا ثِيمسِّي ن ؤُعَالْطَارْ أَذْ ثقِّيمْ أَذْ ثشْمضْ ذَايسْ.  
\v 3 أَكهَّانْ أَذْ يَارْضْ أَسڒْهَامْ نّسْ ن ڒقْطنْ، أَذْ إِبْيسْ سَّارْوَاڒْ نّسْ ن ڒقْطنْ خْ أَرِّيمثْ نّسْ، ؤُشَا أَذْ إِكْسِي إِغّضْ ن مِينْ إِقِّيمنْ ن ثَاذُونْثْ ن ثْغَارْصْثْ ن وشْمَاضْ، ثنِّي ثشَّا ثْمسِّي، ؤُشَا أَذْ ث إِسَّارْسْ زَّاثْ إِ ؤُعَالْطَارْ.  
\v 4 \add خنِّي\add* أَذْ إِكّسْ أَرُّوضْ نّسْ ؤُشَا أَذْ يَارْضْ أَرُّوضْ نّغْنِي، أَذْ يَاوِي إِغّضْ ن مِينْ إِقِّيمنْ ن ثَاذُونْثْ بَارَّا إِ ڒْمَارْڭحْ ن ڒْعسْكَارْ غَارْ يِيجّْ ن ومْشَانْ إِصْفَا.  
\v 5 إِتّْخصَّا أَذْ ثقِّيمْ ثْمسِّي ثَارقّْ خْ ؤُعَالْطَارْ، إِتّْخصَّا وَارْ ثْخسِّي شَا. أَكهَّانْ أَذْ خَاسْ إِسَّارْغْ أَكشُّوضْ كُوڒْ صّْبحْ ؤُشَا أَذْ خَاسْ إِستّفْ ثَاغَارْصْثْ ن وشْمَاضْ ؤُشَا أَذْ خَاسْ إِسّْبخَّارْ ثَاذُونْثْ ن ثْغَارْصَا ن ڒهْنَا.  
\v 6 ثِيمسِّي خْ ؤُعَالْطَارْ أَذْ ثقِّيمْ ثَارقّْ ڒبْذَا، وَارْ ثْخسِّي.‘ “   
\b  
\m
\v 7 ”وَا ذ \bd أَزرْفْ إِ ثوْهِيبْثْ \+bdit ن ڒْغِيدْجثْ\+bdit*\bd*. أَرَّاوْ ن هَارُونْ أَذْ ت أَوْينْ زَّاثْ إِ وُوذمْ ن سِيذِي زَّاثْ إِ ؤُعَالْطَارْ. \x ◘ \xo 6:‏7 \xt ڒخْڒ. 15‏:‏4‏-‏21.\x*  
\v 8 نتَّا أَذْ زَّايسْ إِكْسِي إِجّْ ن وُورُو زڭْ وَارنْ أَزْذَاذْ ن ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* أَكْ-ذ \add شَا ن\add* زّشْثْ نّسْ ذ مَارَّا جَّاوِي إِ إِدْجَانْ خْ ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add*. أَذْ إِسّْبخَّارْ \add أَيَا خْ\add* ؤُعَالْطَارْ. \add أَقَا\add* ذ إِشْثْ ن ڒفْوَاحثْ إِتّْفُوحنْ، إِشْثْ ن ڒِيذَارثْ ذَايسْ إِ سِيذِي. \x ◘ \xo 6:‏8 \xt لَاوِي 2‏:‏9\x*  
\v 9 هَارُونْ ذ وَارَّاوْ نّسْ أَذْ شّنْ مِينْ زَّايسْ إِشطّنْ. إِتّْخصَّا أَذْ ث شّنْ بْڒَا أَنْثُونْ ذڭْ ومْشَانْ أَمْقدَّاسْ. أَذْ ث شّنْ ذِي ڒمْرَاحْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ.  
\v 10 وَارْ إِعدّڒْ أَذْ ث ڭّْونْ س ونْثُونْ. ثَا ذ ثَاغَارْصْثْ نْسنْ نِّي وْشِيغْ نشّْ زِي ثوْهِيبِينْ إِنُو ن ثْمسِّي. أَقَا-ت ذ ثَامْقدَّاسْثْ قَاعْ أَمْ ثْغَارْصْثْ ن دّنْبْ ذ ثْغَارْصْثْ ن ؤُمَارْوَاسْ.  
\v 11 مَارَّا إِوثْمَانْ جَارْ وَارَّاوْ ن هَارُونْ أَذْ زَّايسْ شّنْ. أَقَا-ت ذ إِشْثْ ن ثوْصيّثْ إِ ڒبْذَا خْ ثوْهِيبِينْ ن ثْمسِّي ن سِيذِي إِ \add مَارَّا\add* جِّيڒَاثْ نْومْ. مَارَّا وِي ت غَا إِحَاذَانْ، أَذْ إِتّْوَاقدّسْ.“ \x ◘ \xo 6:‏11 \xt ؤُف. 29‏:‏37\x*   
\b  
\m
\v 12 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 13 ”ثَا ذ \bd ثَاوْهِيبْثْ ن هَارُونْ ذ وَارَّاوْ نّسْ\bd* إِ زِي د غَا قَارّْبنْ غَارْ سِيذِي \bd ذڭْ وَاسّْ مِينْ ذِي إِ غَا إِتّْوَاذْهنْ هَارُونْ\bd*: ثَاعْشَارْثْ ن إِجّْ ن إِفَا ن وَارنْ أَزْذَاذْ \add أَمْ\add* إِشْثْ ن ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* إِ ڒبْذَا، أَزْينْ نّسْ ذِي صّْبحْ ذ وزْينْ نّسْ \add نّغْنِي\add* غَارْ ؤُعشِّي.  
\v 14 ذڭْ إِجّْ ن ؤُخْذِيمْ أَذْ ثسّوْجذْ أَيَا س زّشْثْ \add ن زِّيثُونْ\add* ؤُشَا أَذْ ث ثَاوْيذْ \add ذ ثَاوْهِيبْثْ\add* أَوَارْنِي ث ثْخدْجْضذْ. أَذْ ثْقدّْمذْ إِڒقّْوَازْ تّْوَارْژَانْ ن ثوْهِيبْثْ \add ن ڒْغِيدْجثْ أَمْ\add* إِشْثْ ن ڒفْوَاحثْ إِتّْفُوحنْ إِ سِيذِي.  
\v 15 أَكهَّانْ نِّي غَا ذهْننْ ذڭْ ومْشَانْ نّسْ زڭْ إِحنْجِيرنْ نّسْ، أَذْ ت إِسّوْجذْ. أَقَا-ت ذ ثَاوْصيّثْ إِ ڒبْذَا. \add ثَاوْهِيبْثْ-أَ\add* أَذْ ثتّْوَابخَّارْ إِ سِيذِي مَارَّا.  
\v 16 مَارَّا ثَاوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* ن ؤُكهَّانْ أَذْ ثِيڒِي ثكْمڒْ. وَارْ زَّايسْ تّتّنْ شَا.“   
\b  
\m
\v 17 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 18 ”سِيوڒْ أَكْ-ذ هَارُونْ ذ وَارَّاوْ نّسْ، إِنِي أَسنْ: ’وَا ذ \bd أَزرْفْ إِ ثْغَارْصْثْ ن دّنْبْ\bd*: ذڭْ ومْشَانْ مَانِي ثتّْوَاغَارْصْ ثَاغَارْصْثْ ن وشْمَاضْ، أَذْ ثتّْوَاغَارْصْ \add عَاوذْ\add* ثَاغَارْصْثْ ن دّنْبْ زَّاثْ إِ وُوذمْ ن سِيذِي. أَقَا-ت ذ ثَامْقدَّاسْثْ قَاعْ.  
\v 19 أَكهَّانْ نِّي ت غَا إِقدّْمنْ ذ ثَاغَارْصْثْ أَذْ زَّايسْ يشّْ. إِتّْخصَّا أَذْ ثتّْوَاشّْ ذڭْ إِجّْ ن ومْشَانْ أَمْقدَّاسْ ذِي ڒمْرَاحْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ. \x ◘ \xo 6:‏19 \xt حُوش. 4‏:‏8 \x*  
\v 20 مَارَّا وِي غَا إِحَاذَانْ أَيْسُومْ نّسْ أَذْ \add زَّايسْ\add* إِتّْوَاقدّسْ. مَاڒَا إِنْڭزْ \add شْوَايْثْ\add* زڭْ إِذَامّنْ خْ يِيجّْ ن وَارُّوضْ، \add خنِّي\add* إِتّْخصَّا أَذْ ثسِّيرْذذْ مِينْ خَاسْ إِبقّْضنْ ذڭْ إِجّْ ن ومْشَانْ أَمْقدَّاسْ.  
\v 21 ؤُشَا ڒْقشْعثْ ن ثْڒَاخْثْ إِ ذِي ت سّْننَّانْ، أَذْ ثتّْوَارْژْ، \add مَاشَا\add* مَاڒَا سّنْونْ ت ذڭْ إِشْثْ ن ڒْقشْعثْ ن نّْحَاسْ، \add خنِّي\add* إِتّْخصَّا أَذْ حكّنْ ؤُ أَذْ سّْڒِيڒنْ \add ڒْقشْعثْ\add* س وَامَانْ.  
\v 22 مَارَّا وِي إِدْجَانْ ذ أَوْثمْ جَارْ إِكهَّاننْ أَذْ زَّايسْ يشّْ. أَقَا-ت ذ ثَامْقدَّاسْثْ قَاعْ.  
\v 23 \add مَاشَا\add* ؤُڒَا ذ إِشْثْ ن ثْغَارْصْثْ ن دّنْبْ إِ زِي تّْوَاقدّْمنْ إِذَامّنْ نّسْ ذڭْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ، مَاحنْذْ أَذْ إِڒِينْ إِ وصْڒَاحْ ذِي زَّاوشْثْ إِقدّْسنْ، وَارْ زَّايسْ إِتّْوَاشّْ شَا. أَذْ ثتّْوَاشْمضْ س ثْمسِّي.‘ “ \x ◘ \xo 6:‏23 \xt لَاوِي 4‏:‏5؛ عبر. 13‏:‏11\x*   
\b  
\b  
\m  
\c 7
\m
\v 1 ”وَا ذ \bd أَزرْفْ إِ ثْغَارْصْثْ ن ؤُمْوَارْوَاسْ\bd*. أَقَا ذ ثَامْقدَّاسْثْ قَاعْ.   
\m
\v 2 ذڭْ ومْشَانْ مَانِي غَارّْصنْ إِ ثْغَارْصْثْ ن وشْمَاضْ، أَذْ غَارْصنْ إِ ثْغَارْصْثْ ن ؤُمَارْوَاسْ. أَذْ إِزدْجعْ إِذَامّنْ نّسْ خْ ؤُعَالْطَارْ غَارْ \add مَارَّا\add* إِغزْذِيسنْ \add نّسْ\add*.  
\v 3 أَذْ يَاوِي مَارَّا ثَاذُونْثْ نّسْ: أَنوَّارْ ن ثَاذُونْثْ ذ ثَاذُونْثْ نِّي إِذْڒِينْ أَذَانْ،  
\v 4 ؤُشَا أَذْ إِكّسْ ثْنَاينْ ن ثِيژَّاڒْ أَكْ-ذ ثَاذُونْثْ إِ خَاسنْثْ إِدْجَانْ غَارْ ثجْعِينَّا، ؤُڒَا ذ مِينْ يُويْڒنْ غَارْ ثْسَا ؤُشَا \add يَارْسَا\add* خْ ثِيژَّاڒْ، \f ◼ \fr 7:‏4 \ft \+bd ’ثِيژَّاڒْ‘\+bd* - نِيغْ ’ثِيڭژْڒِينْ‘.\f*  
\v 5 ؤُشَا أَكهَّانْ أَذْ إِسّْبخَّارْ أَيَا خْ ؤُعَالْطَارْ أَمْ يِيشْثْ ن ثوْهِيبْثْ ن ثْمسِّي إِ سِيذِي. أَقَا-ت ذ ثَاغَارْصْثْ ن ؤُمَارْوَاسْ.  
\v 6 مَارَّا أَوْثمْ جَارْ إِكهَّاننْ أَذْ زَّايسْ يشّْ. أَذْ إِتّْوَاشّْ ذڭْ إِجّْ ن ومْشَانْ أَمْقدَّاسْ، أَقَا-ت ذ ثَامْقدَّاسْثْ قَاعْ.  
\v 7 أَذْ يِيڒِي إِجّْ ن ؤُزرْفْ أَمْ إِ ثْغَارْصْثْ ن دّنْبْ أَمْ إِ ثْغَارْصْثْ ن ؤُمْوَارْوَاسْ. أَذْ يِيڒِي \add ويْسُومْ ن ثْغَارْصْثْ\add* إِ ؤُكهَّانْ، ونِّي ثُوغَا زَّايسْ إِڭّْ أَصْڒَاحْ \add خْ شَا ن يِيجّنْ\add*. \f ◼ \fr 7:‏7 \ft \+bd ’إِفْذِي‘\+bd* - خْزَارْ إِزهد. 78:35.\f*  
\v 8 أَكهَّانْ نِّي إِ غَا إِقدّْمنْ ثَاغَارْصْثْ ن وشْمَاضْ ن شَا ن إِجّنْ، إِ ؤُكهَّانْ \add نِّي\add* \add أَذْ ثِيڒِي\add* ثڒْمشْثْ ن ثْغَارْصْثْ ن ثْمسِّي نِّي د-إِقدّمْ، \add ثِيڒْمشْثْ\add* أَذْ ثِيڒِي إِ نتَّا.  
\v 9 كُوڒْ ثَاوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* نِّي ضَارّْحنْ نِيثْنِي ذِي ثفْقُونْثْ ؤُڒَا ذ مَارَّا مِينْ إِتّْوَاسّْوجْذنْ ذِي طَّاجِّينْ نِيغْ ذڭْ وخْذِيمْ، ذ مَانْ أَيَا أَذْ يِيڒِي إِ ؤُكهَّانْ نِّي ث إِقدّْمنْ، أَذْ يِيڒِي إِ نتَّا.  
\v 10 كُوڒْ ثَاوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* إِ إِتّْوَاخدْجْضنْ س زّشْثْ \add ن زِّيثُونْ\add* نِيغْ يُوژْغنْ، أَذْ ثِيڒِي إِ مَارَّا أَرَّاوْ ن هَارُونْ، أَمْ إِ يِيجّْ أَمْ إِ ونّغْنِي.“   
\b  
\m
\v 11 ”وَا ذ \bd أَزرْفْ إِ ثْغَارْصْثْ ن ڒهْنَا\bd* ثنِّي إِ غَا إِقدّمْ \add بْنَاذمْ\add* إِ سِيذِي.   
\m
\v 12 مَاڒَا أَذْ ت إِقدّمْ \bd إِ ؤُقَاذِي\bd*، \add خنِّي\add* أَذْ إِقدّمْ أَكْ-ذ \add ثوْهِيبْثْ ن\add* ؤُقَاذِي ؤُڒَا ذ ڒمْسمْنَاثْ بْڒَا أَنْثُونْ إِخدْجْضنْ س زّشْثْ ذ ثڒْفَافْ بْڒَا أَنْثُونْ تّْوَاذهْننْثْ س زّشْثْ ذ ڒمْسمْنَاثْ ن وَارنْ أَزْذَاذْ تّْوَاخدْجْضنْثْ س زّشْثْ. \x ◘ \xo 7:‏12 \xt إِزهد. 116‏:‏17\x*  
\v 13 أَذْ إِقدّمْ ثَاوْهِيبْثْ نّسْ أَكْ-ذ ڒمْسمْنَاثْ ن وغْرُومْ س ونْثُونْ، \add جْمِيعْ\add* أَكْ-ذ \add ثوْهِيبْثْ ن\add* ؤُقَاذِي، \add ثنِّي إِدْجَانْ\add* زِي ثوْهِيبِينْ نّسْ ن ڒهْنَا.  
\v 14 زِي كُوڒْ \add دَّارْبْ ن\add* ثَاوْهِيبْثْ أَذْ إِقدّمْ إِشْثنْ زَّايسْ \add أَمْ\add* ثوْهِيبْثْ ن ؤُسْڭعّذْ إِ سِيذِي. \add أَذْ ثِيڒِي\add* إِ ؤُكهَّانْ نِّي إِ غَا إِزدْجْعنْ إِذَامّنْ ن ثْغَارْصَا ن ڒهْنَا خْ ؤُعَالْطَارْ \add غَارْ مَارَّا إِغزْذِيسنْ نّسْ\add*، أَذْ ثِيڒِي إِ نتَّا.  
\v 15 أَيْسُومْ ن ثوْهِيبْثْ ن ؤُقَاذِي، \add ثنِّي إِدْجَانْ زِي\add* ثوْهِيبِينْ نّسْ ن ڒهْنَا، أَذْ إِتّْوَاشّْ ذڭْ وَاسّْ \add إِ ذِي غَا إِقدّمْ\add* ثَاوْهِيبْثْ نّسْ. وَارْ إِتّجِّي زَّايسْ وَالُو أَڒْ صّْبحْ.   
\m
\v 16 مَاڒَا ثَاوْهِيبْثْ نّسْ \add ثُوسَا-د أَكْ-ذ\add* \bd إِجّْ ن لْوَاعْذْ\bd* نِيغْ \add ثدْجَا\add* ذ \bd إِشْثْ ن ثوْهِيبْثْ س ڒْخَاضَارْ\bd*، أَذْ ثتّْوَاشّْ ذڭْ وَاسّْ إِ ذِي إِ غَا إِقدّمْ ثَاغَارْصْثْ نّسْ ؤُشَا مِينْ زَّايسْ إِشطّنْ أَذْ إِتّْوَاشّْ ذڭْ وَاسّْ إِ-ث-إِ-د-إِضْفَارنْ. \x ◘ \xo 7:‏16 \xt لَاوِي 19‏:‏6\x*  
\v 17 مِينْ إِشطّنْ عَاذْ زڭْ ويْسُومْ ن ثْغَارْصْثْ أَذْ إِتّْوَاشْمضْ س ثْمسِّي ذڭْ وَاسّْ وِيسّْ ثْڒَاثَا.  
\v 18 مَاڒَا إِتّْوَاشّْ \add عَاذْ\add* زڭْ ويْسُومْ ن ثْغَارْصْثْ نّسْ ن ڒهْنَا ذڭْ وَاسّْ وِيسّْ ثْڒَاثَا، \add خنِّي\add* ونِّي ت إِقدّْمنْ وَارْ إِتِّيڒِي إِ أَرْضَا \add ن سِيذِي\add* ؤُ \add ثَاغَارْصْثْ نّسْ\add* وَارْ ذ أَسْ ثتّْوِيحْسِيبْ شَا \add ذ ثَاغَارْصْثْ ن ڒهْنَا\add*. أَذْ ثِيڒِي ذ إِشْثْ ن جّْعِيفشْثْ ؤُشَا ونِّي زَّايسْ غَا إِشّنْ أَذْ يَارْبُو ڒْمُوعْصِييّثْ نّسْ.  
\v 19 أَيْسُومْ نِّي إِحَاذَانْ شَا ن ثْمسْڒَاشْثْ إِخمْجنْ، وَارْ زَّايسْ تّتّمْ. أَذْ ث سّْشمْضنْ س ثْمسِّي. زِي \add مِينْ إِشطّنْ ن\add* ويْسُومْ، إِزمَّارْ أَذْ زَّايسْ يشّْ مَارَّا ونِّي إِزذْڭنْ.  
\v 20 ذ ونِّي إِ غَا إِشّنْ زڭْ ويْسُومْ ن ثْغَارْصْثْ ن ڒهْنَا، ثنِّي إِدْجَانْ إِ سِيذِي، أَمْ خَاسْ يَارْسَا ڒخْمجْ نّسْ، ڒعْمَارْ نِّي أَذْ إِتّْوَاقسّْ زِي ڒْڭنْسْ نّسْ. \x ◘ \xo 7:‏20 \xt لَاوِي 15‏:‏3\x*  
\v 21 مَاڒَا إِحَاذَا حذْ شَا ن ثْمسْڒَاشْثْ إِخْمجْ، \add أَمشْنَاوْ\add* ڒخْمجْ ن بْنَاذمْ نِيغْ \add ڒخْمجْ\add* ن يِيشْثْ ن ڒبْهِيمثْ إِخمْجنْ نِيغْ شَا ن ثْمسْڒَاشْثْ إِ إِدْجَانْ ذ نّْعِي ن ڒخْمجْ، ؤُشَا \add خنِّي\add* أَذْ يشّْ زڭْ ويْسُومْ ن ثْغَارْصِينْ ن ڒهْنَا إِ سِيذِي، ڒعْمَارْ نِّي أَذْ إِتّْوَاقسّْ زِي ڒْڭنْسْ نّسْ.“   
\b  
\m  
\s1 ثَاذُونْثْ ذ إِذَامّنْ أَقَا ذ ڒحْرَامْ إِ مَاشَّا  
\m
\v 22 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 23 ”سِيوڒْ أَكْ-ذ أَيْثْ ن إِسْرَائِيل، إِنِي: ’كنِّيوْ وَارْ تّتّمْ شَا قَاعْ ثَاذُونْثْ ن ؤُفُونَاسْ نِيغْ ن إِزْمَارْ نِيغْ ن إِغَايْضْ.  
\v 24 ثَاذُونْثْ ن إِشْثْ ن ڒْخشْبثْ ذ ثَاذُونْثْ ن \add إِجّْ ن ؤُمُودَّارْ\add* مزّْقنْ ث، ثْعدّڒْ أَذْ ثتّْوَاڭّْ إِ مَامّشْ مَا ثڭَّا ڒْخذْمثْ، مَاشَا كنِّيوْ وَارْ زَّايسْ تّتّمْ وَالُو.  
\v 25 مَانْ ونْ إِ غَا إِشّنْ ثَاذُونْثْ ن يِيشْثْ ن ڒبْهِيمثْ إِ زِي د غَا سّْقَارّْبنْ إِشْثْ ن ثوْهِيبْثْ ن ثْمسِّي إِ سِيذِي، ڒعْمَارْ نِّي زَّايسْ إِ غَا إِشّنْ، أَذْ إِتّْوَاقسّْ زِي ڒْڭنْسْ نّسْ. \f ◼ \fr 7:‏25 \ft \+bd ’بْنَاذمْ‘\+bd* - س ثْعِيبْرَانِيثْ ’ڒعْمَارْ‘.\f*  
\v 26 ذِي مَارَّا ثِيزذِّيغِينْ نْومْ وَارْ تّتّمْ ؤُڒَا ذ شَا زڭْ إِذَامّنْ، أَمْ زڭْ إِجْضَاضْ أَمْ زِي ڒبْهَايمْ. \x ◘ \xo 7:‏26 \xt أَمز. 9‏:‏4؛ لَاوِي 3‏:‏17؛ 17‏:‏14\x*  
\v 27 كُوڒْ إِجّْ ن ڒعْمَارْ نِّي إِ غَا إِشّنْ \add مْغِيرْ شَا\add* زڭْ إِذَامّنْ، ڒعْمَارْ نِّي أَذْ إِتّْوَاقسّْ زِي ڒْڭنْسْ نّسْ.‘ “   
\b  
\m  
\s1 ثَاسْغَارْثْ ن ثْغَارْصَا ن ڒهْنَا إِ إِكهَّاننْ  
\m
\v 28 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 29 ”سِيوڒْ أَكْ-ذ أَيْثْ ن إِسْرَائِيل، إِنِي: ’وِي إِ د غَا إِسّْقَارّْبنْ ثْغَارْصْثْ نّسْ ن ڒهْنَا إِ سِيذِي، أَذْ إِقدّمْ ثَاوْهِيبْثْ نّسْ إِ سِيذِي زِي ثْغَارْصْثْ ن ڒهْنَا نّسْ.  
\v 30 س إِفَاسّنْ نّسْ أَذْ يَاوِي ثِيوْهِيبِينْ ن ثْمسِّي زَّاثْ إِ سِيذِي. ثَاذُونْثْ \add إِ إِدْجَانْ\add* خْ إِذْمَارنْ أَذْ ت يَاوِي أَكْ-ذ إِذْمَارنْ نِّي، مَاحنْذْ أَذْ ت إِسّنْهزّْ زِي سَّا غَارْ ذَا أَمْ يِيشْثْ ن ثوْهِيبْثْ ن ونْهزِّي زَّاثْ إِ وُوذمْ ن سِيذِي. \x ◘ \xo 7:‏30 \xt ؤُف. 29‏:‏24\x*  
\v 31 أَكهَّانْ أَذْ إِسّْبخَّارْ ثَاذُونْثْ خْ ؤُعَالْطَارْ، \add مَاشَا\add* إِذْمَارنْ أَذْ إِڒِينْ إِ هَارُونْ ذ وَارَّاوْ نّسْ.  
\v 32 زِي ثْغَارْصَا نْومْ ن ڒهْنَا أَذْ ثْقدّْممْ إِ ؤُكهَّانْ \add عَاوذْ\add* أَشكْرُوذْ أَفُوسِي ذ ثَاوْهِيبْثْ ن ؤُسْڭعّذْ.  
\v 33 أَشكْرُوذْ أَفُوسِي أَذْ يِيڒِي ذ ثَاسْغَارْثْ ن ونِّي زڭْ وَارَّاوْ ن هَارُونْ إِ غَا إِقدّْمنْ إِذَامّنْ ن ثْغَارْصِي ن ڒهْنَا ذ ثَاذُونْثْ \add نْسنْثْ\add*.  
\v 34 مِينْزِي نشّْ كْسِيغْ إِذْمَارنْ ن ونْهزِّي ذ ؤُشكْرُوذْ إِ د-إِتّْوَاسّْڭعّْذنْ ذ ثَاوْهِيبْثْ زِي ثْغَارْصِي ن ڒهْنَا ن أَيْثْ ن إِسْرَائِيل ؤُ وْشِيغْ ثنْ إِ ؤُكهَّانْ هَارُونْ ؤُ إِ وَارَّاوْ نّسْ أَمْ يِيشْثْ ن لْفَارِيضَا إِ ڒبْذَا، زِي جِّيهثْ ن أَيْثْ ن إِسْرَائِيل.\x ◘ \xo 7:‏34 \xt ؤُف. 29‏:‏27؛ ڒخْڒ. 18‏:‏11\x*  
\v 35 ثَا ذ ثَاسْغَارْثْ إِتّْوَاسّْذهْننْ ن هَارُونْ ذ ثسْغَارْثْ إِتّْوَاسّْذهْننْ ن وَارَّاوْ نّسْ زِي ثوْهِيبِينْ ن ثْمسِّي ن سِيذِي ذڭْ وَاسّْ إِ ثنْ د-إِسّْقَارّبْ، مَاحنْذْ أَذْ إِڒِينْ ذ إِكهَّاننْ إِ سِيذِي،  
\v 36 \add ثَاسْغَارْثْ\add* نِّي إِوْشَا سِيذِي إِ أَيْثْ ن إِسْرَائِيل ذڭْ وَاسّْ إِ ثنْ إِذْهنْ. أَقَا ذ إِشْثْ ن ثوْصيّثْ إِ ڒبْذَا إِ \add مَارَّا\add* جِّيڒَاثْ نْسنْ.‘ “   
\b  
\m
\v 37 وَا ذ أَزرْفْ إِ ثْغَارْصْثْ ن وشْمَاضْ ذ ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* ذ ثْغَارْصْثْ ن دّنْبْ ذ ثْغَارْصْثْ ن ؤُمَارْوَاسْ ذ ثْغَارْصَا إِ ؤُذشّنْ ذ ثْغَارْصَا ن ڒهْنَا،  
\v 38 \add أَزرْفْ\add* إِ إِوصَّا سِيذِي إِ مُوسَا ذڭْ وذْرَارْ ن سِينَا، أَسّْ مِينْ ذِي إِوصَّا أَيْثْ ن إِسْرَائِيل أَذْ قدّْمنْ ثِيوْهِيبِينْ نْسنْ إِ سِيذِي ذِي ڒخْڒَا ن سِينَا.   
\b  
\b  
\m  
\c 8
\s1 أَڒقّمْ ن هَارُونْ ذ ثَارْوَا نّسْ  
\m
\v 1 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 2 ”كْسِي هَارُونْ جْمِيعْ أَكْ-ذ وَارَّاوْ نّسْ ذ وَارُّوضْ ذ زّشْثْ إِ وذْهَانْ ذ ؤُفُونَاسْ أَمژْيَانْ ن ثْغَارْصْثْ ن دّنْبْ ذ ثْنَاينْ ن إِشَارِّييّنْ ذ ثْسُودْجثْ س وغْرُومْ بْڒَا أَنْثُونْ، \x ◘ \xo 8:‏2 \xt ؤُف. 28‏:‏1، 2؛ 30‏:‏25\x*  
\v 3 ؤُ ڒَاغَا إِ مَارَّا ثَامسْمُونْثْ غَارْ وَاذَافْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ.“   
\m
\v 4 إِڭَّا مُوسَا أَمْ مَامّشْ ذ أَسْ إِوصَّا سِيذِي ؤُشَا ثْمُونْ ثْمسْمُونْثْ غَارْ وَاذَافْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ.  
\v 5 إِنَّا مُوسَا إِ ثْمسْمُونْثْ: ”وَا ذ مِينْ إِوصَّا سِيذِي أَذْ إِتّْوَاڭّْ.“ \x ◘ \xo 8:‏5 \xt ؤُف. 29‏:‏4\x*   
\m
\v 6 مُوسَا إِسّْقَارّبْ-د هَارُونْ ذ وَارَّاوْ نّسْ ؤُشَا إِسِّيرْذْ إِ-ثنْ س وَامَانْ.  
\v 7 إِسَّارْسْ خَاسْ ثْشَامِيرْ، إِبْيسْ أَسْ س ثْحزَّامْثْ، إِسّْيَارْضْ أَسْ أَسڒْهَامْ. إِڭَّا خَاسْ أَپَالْطُو ؤُشَا إِبْيسْ أَسْ س ثْحزَّامْثْ إِزوّْقنْ ن ؤُپَالْطُو ؤُشَا إِقّنْ أَسْ زَّايسْ \add أَبَالْثُو\add*. \x ◘ \xo 8:‏7 \xt ؤُف. 28‏:‏4\x*  
\v 8 إِسّمْثنْ خَاسْ ثَاجْمشْثْ ؤُشَا إِڭَّا \add إِژْرَا ن\add* ’ؤُرِيمْ‘ ذ ’ثُومِيمْ‘ ذِي ثَاجْمشْثْ. \x ◘ \xo 8:‏8 \xt ؤُف. 28‏:‏30\x*  
\v 9 إِڭَّا أَرژّثْ خْ ؤُزدْجِيفْ نّسْ ؤُشَا غَارْ زَّاثْ خْ أَرژّثْ إِڭَّا \add ثَاڒْوِيحْثْ س\add* نُّووَّارْ ن وُورغْ ن تَّاجْ إِقدّْسنْ \add ن وعْزَاڒْ\add*، أَمْ مَامّشْ يُومُورْ سِيذِي إِ مُوسَا. \x ◘ \xo 8:‏9 \xt ؤُف. 28‏:‏36؛ 29‏:‏6\x*   
\m
\v 10 \add خنِّي\add* إِكْسِي مُوسَا زّشْثْ إِ وذْهَانْ ؤُشَا إِذْهنْ ثَازذِّيغْثْ ذ مَارَّا مِينْ ذَايسْ إِدْجَانْ ؤُشَا إِسّْقدّسْ \add مَارَّا\add* أَيَا.  
\v 11 إِرُوشّْ زَّايسْ خْ ؤُعَالْطَارْ سبْعَا ن ثْوَاڒَاوِينْ ؤُشَا إِذْهنْ \add عَاوذْ\add* أَعَالْطَارْ ذ مَارَّا ڒقْشُوعْ نّسْ ؤُڒَا ذ ثَابَانْيُوثْ أَكْ-ذ ؤُضَارْ نّسْ مَاحنْذْ أَذْ ثنْ إِسّْقدّسْ.  
\v 12 إِسيّبْ زّشْثْ إِ وذْهَانْ خْ ؤُزدْجِيفْ ن هَارُونْ ؤُشَا إِذْهنْ إِ-ث، حِيمَا أَذْ ث إِسّْقدّسْ. \x ◘ \xo 8:‏12 \xt إِزهد. 133‏:‏2\x*  
\v 13 إِسّْقَارّبْ-د مُوسَا أَرَّاوْ ن هَارُونْ ؤُشَا يَارْضْ أَسنْ ثْشَامِيرَاثْ ؤُشَا إِبْيسْ أَسنْ س ثْحزَّامِينْ ؤُشَا إِنّضْ أَسنْ ثِيشُوشَّايْ أَمْ مَامّشْ يُومُورْ سِيذِي إِ مُوسَا. \x ◘ \xo 8:‏13 \xt ؤُف. 29‏:‏9\x*   
\m
\v 14 إِسّْقَارّبْ-د أَفُونَاسْ أَمژْيَانْ ن ثْغَارْصْثْ ن دّنْبْ ؤُشَا هَارُونْ ذ وَارَّاوْ نّسْ سَّارْسنْ إِفَاسّنْ نْسنْ خْ ؤُزدْجِيفْ ن ؤُفُونَاسْ أَمژْيَانْ ن ثْغَارْصْثْ ن دّنْبْ. \x ◘ \xo 8:‏14 \xt ؤُف. 29‏:‏1\x*  
\v 15 إِغَارْصْ \add أَسْ\add* ؤُشَا \add إِكْسِي\add* مُوسَا إِذَامّنْ ؤُشَا إِڭَّا \add شْوَايْثْ زَّايْسنْ\add* س ؤُضَاضْ نّسْ خْ وَاشَّاونْ ن ؤُعَالْطَارْ \add إِ إِدْجَانْ\add* غَارْ \add مَارَّا\add* إِغزْذِيسنْ نّسْ ؤُشَا \add أَمُّو إِ\add* إِسِّيزْذڭْ أَعَالْطَارْ. \add خنِّي\add* إِسيّبْ إِذَامّنْ غَارْ ؤُضَارْ ن ؤُعَالْطَارْ. \add أَمُّو إِ\add* إِسّْقدّسْ إِ-ث إِ وصْڒَاحْ خَاسْ. \f ◼ \fr 8:‏15 \ft \+bd ’أَشَّاونْ‘\+bd* - نِيغْ ’إِقِيشَّاونْ‘.\f*  
\v 16 إِكْسِي مَارَّا ثَاذُونْثْ نِّي إِدْجَانْ خْ وَاذَانْ ذ مِينْ يُويْڒنْ غَارْ ثْسَا ذ ثْنَاينْ ن ثِيژَّاڒْ ذ ثَاذُونْثْ نْسنْثْ ؤُشَا مُوسَا إِسّْبخَّارْ \add أَيَا\add* خْ ؤُعَالْطَارْ. \f ◼ \fr 8:‏16 \ft \+bd ’ثِيژَّاڒْ‘\+bd* - نِيغْ ’ثِيڭژْڒِينْ‘.\f*  
\v 17 \add مَاشَا\add* أَفُونَاسْ أَمژْيَانْ ذ يِيڒمْ نّسْ ذ ويْسُومْ نّسْ ذ أَمسَّاڒْ نّسْ، إِسَّارْغْ \add إِ-ثنْ\add* بَارَّا إِ ڒْمَارْڭحْ ن ڒْعسْكَارْ، أَمْ مَامّشْ يُومُورْ سِيذِي إِ مُوسَا. \x ◘ \xo 8:‏17 \xt ؤُف. 29‏:‏14؛ لَاوِي 4‏:‏11\x*   
\m
\v 18 إِسّْقَارّبْ-د \add مُوسَا\add* إِشَارِّي ن ثْغَارْصْثْ ن وشْمَاضْ ؤُشَا هَارُونْ ذ وَارَّاوْ نّسْ سَّارْسنْ إِفَاسّنْ نْسنْ خْ ؤُزدْجِيفْ ن إِشَارِّي.  
\v 19 إِغَارْصْ \add إِ إِشَارِّي\add* ؤُشَا إِزدْجعْ مُوسَا إِذَامّنْ خْ ؤُعَالْطَارْ غَارْ \add مَارَّا\add* إِغزْذِيسنْ نّسْ.  
\v 20 إِبْضَا إِشَارِّي ذ إِشدْجِيقنْ نّسْ ؤُشَا إِسّْبخَّارْ مُوسَا أَزدْجِيفْ ذ إِشدْجِيقنْ ذ ثَاذُونْثْ.  
\v 21 إِسِّيرْذْ أَذَانْ ذ إِضَارنْ س وَامَانْ ؤُشَا إِسّْبخَّارْ مُوسَا مَارَّا إِشَارِّي خْ ؤُعَالْطَارْ، أَقَا ذ ثَاغَارْصْثْ ن وشْمَاضْ س يِيشْثْ ن ڒفْوَاحثْ إِتّْفُوحنْ، أَقَا ذ ثَاوْهِيبْثْ ن ثْمسِّي إِ سِيذِي، أَمْ مَامّشْ يُومُورْ سِيذِي إِ مُوسَا. \x ◘ \xo 8:‏21 \xt ؤُف. 29‏:‏18\x*   
\m
\v 22 إِسّْقَارّبْ-د \add خنِّي\add* إِشَارِّي نّغْنِي، إِشَارِّي إِ ؤُذشّنْ، ؤُشَا هَارُونْ ذ وَارَّاوْ نّسْ سَّارْسنْ إِفَاسّنْ نْسنْ خْ ؤُزدْجِيفْ ن إِشَارِّي.  
\v 23 ؤُشَا إِغَارْصْ \add أَسْ\add* ؤُشَا إِكْسِي مُوسَا \add شْوَايْثْ\add* زڭْ إِذَامّنْ ؤُشَا إِڭَّا إِ-ثنْ خْ إِغسْ ن ؤُمزُّوغْ أَفُوسِي ن هَارُونْ ؤُ خْ ؤُضَاضْ ن يِيمزْ ن ؤُفُوسْ نّسْ أَفُوسِي ؤُ خْ ؤُضَاضْ ن يِيمزْ ن ؤُضَارْ نّسْ أَفُوسِي.  
\v 24 إِسّْقَارّبْ-د \add عَاوذْ\add* أَرَّاوْ ن هَارُونْ ؤُشَا إِڭَّا مُوسَا \add شْوَايْثْ\add* زڭْ إِذَامّنْ خْ إِغسْ ن ؤُمزُّوغْ نْسنْ أَفُوسِي ؤُ خْ ؤُضَاضْ ن يِيمزْ ن ؤُفُوسْ نْسنْ أَفُوسِي ؤُ خْ ؤُضَاضْ ن يِيمزْ ن ؤُضَارْ نْسنْ أَفُوسِي ؤُشَا إِزدْجعْ مُوسَا إِذَامّنْ \add إِقِّيمنْ\add* خْ ؤُعَالْطَارْ غَارْ \add مَارَّا\add* إِغزْذِيسنْ \add نّسْ\add*.  
\v 25 إِكْسِي ثَاذُونْثْ ذ ؤُنوَّارْ \add س ثَاذُونْثْ\add* ذ مَارَّا ثَاذُونْثْ ثنِّي إِدْجَانْ خْ وَاذَانْ ذ مِينْ يُويْڒنْ غَارْ ثْسَا ذ ثْنَاينْ ن ثِيژَّاڒْ أَكْ-ذ ثَاذُونْثْ نْسنْثْ ؤُڒَا ذ أَشكْرُوذْ أَفُوسِي. \x ◘ \xo 8:‏25 \xt ؤُف. 29‏:‏22\x*  
\v 26 زِي ثْسُودْجثْ س وغْرُومْ بْڒَا أَنْثُونْ، ثنِّي ثُوغَا زَّاثْ إِ وُوذمْ ن سِيذِي، إِكْسِي إِجّْ ن ڒمْسمّمْ بْڒَا أَنْثُونْ ذ يِيشْثْ ن ثمْسمّمْثْ \add إِسّْوجْذنْ\add* س زّشْثْ ذ إِشْثْ ن ثڒْففْثْ ؤُشَا إِسَّارْسْ إِ-ثنْ خْ ثَاذُونْثْ ؤُ خْ ؤُشكْرُوذْ أَفُوسِي.  
\v 27 إِڭَّا مَارَّا مَانْ أَيَا ذڭْ إِفَاسّنْ ن هَارُونْ ؤُ ذڭْ إِفَاسّنْ ن وَارَّاوْ نّسْ ؤُشَا إِسّنْهزّْ أَيَا أَمْ يِيشْثْ ن ثوْهِيبْثْ ن ونْهزِّي زَّاثْ إِ وُوذمْ ن سِيذِي. \x ◘ \xo 8:‏27 \xt ؤُف. 29‏:‏24\x*  
\v 28 \add أَوَارْنِي أَسْ\add* إِكْسِي ثنْ مُوسَا \add عَاوذْ\add* زڭْ إِفَاسّنْ نْسنْ ؤُشَا إِسّْبخَّارْ \add إِ-ثنْ\add* خْ ؤُعَالْطَارْ، خْ ثْغَارْصْثْ ن وشْمَاضْ. أَقَا ذ ثِيغَارْصَا إِ ؤُذشّنْ س يِيشْثْ ن ڒفْوَاحثْ إِتّْفُوحنْ، أَقَا ذ ثَاوْهِيبْثْ ن ثْمسِّي إِ سِيذِي.  
\v 29 إِكْسِي مُوسَا إِذْمَارنْ ؤُشَا إِسّنْهزّْ إِ-ثنْ أَمْ يِيشْثْ ن ثوْهِيبْثْ ن ونْهزِّي زَّاثْ إِ وُوذمْ ن سِيذِي. مَانْ أَيَا ذ ثَاسْغَارْثْ ن ؤُشَارِّي إِ ؤُذشّنْ، ثنِّي إِدْجَانْ إِ مُوسَا، أَمْ مَامّشْ يُومُورْ سِيذِي إِ مُوسَا. \x ◘ \xo 8:‏29 \xt ؤُف. 29‏:‏26؛ لَاوِي 7‏:‏33\x*   
\m
\v 30 إِكْسِي مُوسَا \add شْوَايْثْ\add* ن زّشْثْ إِ وذْهَانْ ؤُ ن إِذَامّنْ إِ إِدْجَانْ خْ ؤُعَالْطَارْ ؤُشَا إِرُوشّْ مَانْ أَيَا خْ هَارُونْ ؤُ خْ وَارُّوضْ نّسْ، خْ وَارَّاوْ نّسْ ؤُ خْ وَارُّوضْ ن وَارَّاوْ نّسْ، \add إِنِّي\add* أَكِيذسْ \add إِدْجَانْ\add*. \add أَمُّو إِ\add* إِسّْقدّسْ هَارُونْ ذ وَارُّوضْ نّسْ ذ وَارَّاوْ نّسْ ذ وَارُّوضْ ن وَارَّاوْ نّسْ أَكِيذسْ. \x ◘ \xo 8:‏30 \xt ؤُف. 29‏:‏21\x*   
\m
\v 31 إِنَّا مُوسَا إِ هَارُونْ ؤُ إِ وَارَّاوْ نّسْ: ”سنْومْ أَيْسُومْ نِّي غَارْ وَاذَافْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ ؤُشَا ثشّمْ ث ذِينِّي س وغْرُومْ نِّي إِدْجَانْ ذِي ثْسُودْجثْ ن ثْغَارْصَا إِ ؤُذشّنْ، أَمْ مَامّشْ وصِّيغْ نشّْ، نِّيغْ: ’هَارُونْ ذ وَارَّاوْ نّسْ أَذْ ث شّنْ.‘ \x ◘ \xo 8:‏31 \xt ؤُف. 29‏:‏32؛ لَاوِي 24‏:‏9\x*  
\v 32 مِينْ إِشطّنْ ن ويْسُومْ ذ وغْرُومْ، أَذْ ث ثسّْشمْضنْ س ثْمسِّي.  
\v 33 زڭْ وَاذَافْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ وَارْ زَّايسْ د-ثتّفّْغمْ شَا سبْعَا ن وُوسَّانْ، أَڒْ أَسّْ مِينْ ذِي إِ غَا كمّْڒنْ وُوسَّانْ ن ؤُڒقّمْ نْومْ، مِينْزِي نتَّا أَذْ كنِّيوْ يَاڒقّمْ سبْعَا ن وُوسَّانْ.  
\v 34 أَمْ مَامّشْ إِڭَّا \add مَارَّا\add* ذڭْ وَاسّْ-أَ، \add أَمُّو\add* إِ إِوصَّا سِيذِي، مَاحنْذْ أَذْ خَاومْ إِڭّْ أَصْڒَاحْ.  
\v 35 أَذْ ثقِّيممْ غَارْ وَاذَافْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ، أَسّْ ذ دْجِيڒثْ، سبْعَا ن وُوسَّانْ ؤُشَا أَذْ ثطّْفمْ \add أَ\add*حطُّو إِ سِيذِي، حِيمَا وَارْ ثتّْمتِّيمْ شَا، مِينْزِي أَمُّو إِ \add ث\add* تّْوصِّيغْ نشّْ.“  
\v 36 هَارُونْ ذ وَارَّاوْ نّسْ ڭِّينْ مَارَّا مِينْ ذ \add أَسنْ\add* إِوصَّا سِيذِي س ثْسخَّارْثْ ن مُوسَا.   
\b  
\b  
\m  
\c 9
\s1 ثِيغَارْصَا ثِيمزْوُورَا - أَعُودْجِي ن سِيذِي  
\m
\v 1 ذڭْ وَاسّْ وِيسّْ ثْمنْيَا إِمْسَارْ، أَقَا مُوسَا إِڒَاغَا إِ هَارُونْ ذ وَارَّاوْ نّسْ ذ إِمْغَارنْ ن إِسْرَائِيل  
\v 2 ؤُشَا إِنَّا إِ هَارُونْ: ”كْسِي غَاركْ إِجّْ ن ؤُعجْمِي، أَمژْيَانْ ن ؤُفُونَاسْ، \add أَمْ\add* ثْغَارْصْثْ ن دّنْبْ، ؤُڒَا ذ إِجّْ ن إِشَارِّي \add أَمْ\add* ثْغَارْصْثْ ن وشْمَاضْ، \add أَقَا أَذْ إِڒِينْ\add* شْنَانْ قَاعْ، ؤُشَا أجّْ إِ-ثنْ أَذْ د-قَارّْبنْ غَارْ وُوذمْ ن سِيذِي. \f ◼ \fr 9:‏2 \ft \+bd ’أَعجْمِي‘\+bd* - نِيغْ ’أَينْذُوزْ‘ نِيغْ ’يُوڭُّو‘. ؤُڒَا ذِي أَيَاثْ 3 ذ 8.\f*  \x ◘ \xo 9:‏2 \xt ؤُف. 29‏:‏1\x*  
\v 3 سِيوڒْ أَكْ-ذ أَيْثْ ن إِسْرَائِيل ؤُشَا إِنِي: ”كْسِيمْ إِجّْ ن ؤُمْيَانْ زڭْ إِغَايْضنْ أَمْ ثْغَارْصْثْ ن دّنْبْ ؤُ \add كْسِي\add* إِجّْ ن ؤُعجْمِي ذ إِجّْ ن يزْمَارْ، \add أَقَا أَذْ إِڒِينْ إِمُودَّارنْ\add* شْنَانْ قَاعْ ن إِجّْ ن ؤُسڭّْوَاسْ، إِ ثْغَارْصْثْ ن وشْمَاضْ،  
\v 4 ؤُشَا \add كْسِي عَاوذْ\add* إِجّْ ن ؤُفُونَاسْ ذ إِجّْ ن ؤُشَارِّي أَمْ ثْغَارْصَا ن ڒهْنَا، مَاحنْذْ أَذْ \add ثنْ\add* قدّْمنْ \add ذ دّْبِيحثْ\add* إِ سِيذِي، ؤُڒَا ذ إِشْثْ ن ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* إِخدْجْضنْ س زّشْثْ، مِينْزِي أَسّْ-أَ أَذْ أَومْ د-إِبَانْ سِيذِي.“   
\m
\v 5 \add خنِّي\add* أَوْينْ مِينْ خفْ إِوصَّا مُوسَا غَارْ زَّاثْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ ؤُشَا ثَامسْمُونْثْ ثْقَارّبْ-د ؤُشَا بدّنْ نِيثْنِي زَّاثْ إِ وُوذمْ ن سِيذِي.   
\m
\v 6 ؤُشَا مُوسَا إِنَّا: ”ذ مَانْ أَيَا مِينْ خفْ إِوصَّا سِيذِي مَاحنْذْ أَذْ \add ث\add* ثڭّمْ. ؤُشَا \add خنِّي\add* أَذْ أَومْ د-إِبَانْ ؤُعُودْجِي ن سِيذِي.“   
\m
\v 7 إِنَّا مُوسَا إِ هَارُونْ: ”قَارّبْ-د غَارْ ؤُعَالْطَارْ ؤُشَا سوْجذْ \bd ثَاغَارْصْثْ نّشْ ن دّنْبْ ذ ثْغَارْصْثْ نّشْ ن وشْمَاضْ\bd* ؤُشَا أڭّْ أَصْڒَاحْ خْ يِيخفْ نّشْ ؤُ خْ ڒْڭنْسْ. سوْجذْ \add عَاوذْ\add* ثَاوْهِيبْثْ ن ڒْڭنْسْ ؤُشَا أڭّْ خَاسنْ أَصْڒَاحْ أَمْ مَامّشْ \add ث\add* إِوصَّا سِيذِي.“ \x ◘ \xo 9:‏7 \xt لَاوِي 16‏:‏6؛ عبر. 7‏:‏27\x*  
\v 8 \add خنِّي\add* إِقَارّبْ-د هَارُونْ غَارْ ؤُعَالْطَارْ ؤُشَا إِغَارْصْ إِ ؤُعجْمِي ن ثْغَارْصْثْ ن دّنْبْ \add إِ إِدْجَانْ\add* إِ يِيخفْ نّسْ.  
\v 9 أَرَّاوْ ن هَارُونْ إِوْينْ أَسْ-د إِذَامّنْ ؤُشَا نتَّا إِسُّوفْ أَضَاضْ نّسْ ذڭْ إِذَامّنْ ؤُشَا إِڭَّا إِ-ثنْ خْ وَاشَّاونْ ن ؤُعَالْطَارْ. \add مِينْ إِشطّنْ ن\add* إِذَامّنْ إِسيّبْ إِ-ثنْ غَارْ ؤُضَارْ ن ؤُعَالْطَارْ.  
\v 10 إِسّْبخَّارْ ثَاذُونْثْ ذ ثِيژَّاڒْ ذ مِينْ يُويْڒنْ غَارْ ثْسَا ن ثْغَارْصْثْ ن دّنْبْ خْ ؤُعَالْطَارْ أَمْ مَامّشْ يُومُورْ سِيذِي إِ مُوسَا. \f ◼ \fr 9:‏10 \ft \+bd ’ثِيژَّاڒْ‘\+bd* - نِيغْ ’ثِيڭژْڒِينْ‘. ؤُڒَا ذِي أَيثْ 19.\f*  
\v 11 إِسّشْمضْ أَيْسُومْ ذ يِيڒمْ س ثْمسِّي بَارَّا إِ ڒْمَارْڭحْ ن ڒْعسْكَارْ.   
\m
\v 12 إِغَارْصْ ثَاغَارْصْثْ ن وشْمَاضْ ؤُشَا أَرَّاوْ نْ هَارُونْ قدّْمنْ أَسْ إِذَامّنْ ؤُشَا نتَّا إِزدْجعْ \add إِ-ثنْ\add* خْ ؤُعَالْطَارْ غَارْ \add مَارَّا\add* إِغزْذِيسنْ نّسْ.  
\v 13 \add خنِّي\add* قدّْمنْ أَسْ ثَاغَارْصْثْ ن وشْمَاضْ \add إِ تّْوَابْضَانْ\add* ذ إِشدْجِيقنْ، ؤُڒَا ذ أَزدْجِيفْ، ؤُشَا نتَّا إِسّْبخَّارْ إِ-ت خْ ؤُعَالْطَارْ.  
\v 14 إِسِّيرْذْ أَذَانْ ذ إِضَارنْ ؤُشَا إِسّْبخَّارْ \add إِ-ثنْ\add* خْ ثْغَارْصْثْ ن وشْمَاضْ إِ إِدْجَانْ خْ ؤُعَالْطَارْ.   
\m
\v 15 \add أَوَارْنِي أَسْ\add* إِسّْقَارّبْ-د \bd ثَاوْهِيبْثْ ن ڒْڭنْسْ\bd*. نتَّا إِكْسِي أَمْيَانْ ن ثْغَارْصْثْ ن دّنْبْ إِ ڒْڭنْسْ ؤُشَا إِغَارْصْ أَسْ ؤُشَا إِسّوْجذْ إِ-ث ذ ثَاغَارْصْثْ ن دّنْبْ أَمْ مَامّشْ \add إِسّوْجذْ إِشَارِّي\add* أَمزْوَارُو. \x ◘ \xo 9:‏15 \xt لَاوِي 4‏:‏13\x*   
\m
\v 16 إِسّْقَارّبْ-د ثَاغَارْصْثْ ن وشْمَاضْ ؤُشَا إِسّوْجذْ إِ-ت عْلَاحْسَابْ لْفَارِيضَا.  
\v 17 إِقدّمْ ثَاوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* ؤُشَا إِكْسِي زَّايسْ إِجّْ ن وُورُو إِشُّورْ ؤُشَا إِسّْبخَّارْ \add أَيَا\add* خْ ؤُعَالْطَارْ، زَّاثْ إِ ثْغَارْصْثْ ن وشْمَاضْ ن صّْبحْ. \x ◘ \xo 9:‏17 \xt ؤُف. 29‏:‏38؛ لَاوِي 2‏:‏1\x*   
\m
\v 18 إِغَارْصْ عَاوذْ إِ ؤُفُونَاسْ ؤُ إِ يِيشَارِّي ن ثْغَارْصْثْ ن ڒهْنَا ذِي طّْوعْ ن ڒْڭنْسْ، ؤُشَا أَرَّاوْ ن هَارُونْ قدّْمنْ أَسْ إِذَامّنْ ؤُشَا إِزدْجعْ إِ-ثنْ خْ ؤُعَالْطَارْ غَارْ \add مَارَّا\add* إِغزْذِيسنْ نّسْ.  
\v 19 خْ ثَاذُونْثْ ن ؤُفُونَاسْ ؤُ ن إِشَارِّي: أَنوَّارْ \add س ثَاذُونْثْ نّسْ\add* ذ مِينْ إِذْڒِينْ \add أَضَانْ\add* ذ ثِيژَّاڒْ ذ مِينْ يُويْڒنْ غَارْ ثْسَا،  
\v 20 أَقَا سَّارْسنْ ثَاذُونْثْ \add نِّي\add* خْ إِذْمَارنْ ؤُشَا نتَّا إِسّْبخَّارْ ثَاذُونْثْ خْ ؤُعَالْطَارْ.  
\v 21 \add مَاشَا\add* إِذْمَارنْ ذ ؤُشكْرُوذْ أَفُوسِي إِسّنْهزّْ إِ-ثنْ هَارُونْ \add أَمشْنَاوْ\add* إِشْثْ ن ثوْهِيبْثْ ن ونْهزِّي زَّاثْ إِ وُوذمْ ن سِيذِي، أَمْ مَامّشْ \add ث\add* إِوصَّا مُوسَا. \x ◘ \xo 9:‏21 \xt لَاوِي 7‏:‏32\x*   
\m
\v 22 \add خنِّي\add* إِسّْڭعّذْ هَارُونْ إِفَاسّنْ نّسْ غَارْ ڒْڭنْسْ ؤُشَا إِبَاركْ إِ-ثنْ ؤُشَا إِهْوَا أَوَارْنِي ڒَامِي إِقدّمْ ثَاغَارْصْثْ ن دّنْبْ ذ ثْغَارْصْثْ ن وشْمَاضْ ذ ثْغَارْصْثْ ن ڒهْنَا.  
\v 23 ؤُشَا يُوذفْ مُوسَا أَكْ-ذ هَارُونْ غَارْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ ؤُشَا نِيثْنِي فّْغنْ \add زَّايسْ عَاوذْ\add* ؤُشَا بَارْكنْ ڒْڭنْسْ ؤُشَا إِبَانْ ؤُعُودْجِي ن سِيذِي إِ مَارَّا ڒْڭنْسْ  
\v 24 ؤُشَا ثفّغْ-د ثْمسِّي زِي زَّاثْ إِ وُوذمْ ن سِيذِي، ثشَّا ثَاغَارْصْثْ ن وشْمَاضْ خْ ؤُعَالْطَارْ ؤُڒَا ذ ثَاذُونْثْ. \add ؤُمِي\add* إِژْرَا ڒْڭنْسْ \add مَانْ أَيَا\add*، سْڒِيوڒْونْ ؤُشَا وْضَانْ \add غَارْ ثمُّورْثْ\add* خْ ؤُغمْبُوبْ نْسنْ. \x ◘ \xo 9:‏24 \xt 1 إِج. 18‏:‏38؛ 2 إِم. 7‏:‏1\x*   
\b  
\b  
\m  
\c 10
\s1 ڒْموْثْ ن نَاذَابْ ذ أَبِيهُو  
\m
\v 1 نَاذَابْ ذ أَبِيهُو، أَرَّاوْ ن هَارُونْ، كْسِينْ كُوڒْ إِجّْ ڒْمجْمَارْ نّسْ ؤُشَا ڭِّينْ ذَايسْ ڒبْخُورْ ؤُشَا \add أَمُّو إِ\add* يِيوْينْ نِيثْنِي ثِيمسِّي ثغْرِيبْ زَّاثْ إِ وُوذمْ ن سِيذِي، مِينْ وَارْ ذ أَسنْ إِوصَّا نتَّا.  
\v 2 ثفّغْ-د ثْمسِّي زِي زَّاثْ إِ وُوذمْ ن سِيذِي، ثشّْ إِ-ثنْ ؤُشَا مُّوثنْ زَّاثْ إِ وُوذمْ ن سِيذِي. \x ◘ \xo 10:‏2 \xt ڒخْڒ. 3‏:‏4؛ 26‏:‏61؛ 1 إِم. 24‏:‏2\x*  
\v 3 إِنَّا مُوسَا إِ هَارُونْ: ”ذ مَانْ أَيَا خْ مِينْ خفْ إِسِّيوڒْ سِيذِي \add ؤُمِي\add* إِنَّا: ’س يِينِّي إِ غَارِي د غَا إِقَارّْبنْ أَذْ تّْوَاقدّْسغْ ؤُشَا زَّاثْ إِ وُوذمْ ن مَارَّا ڒْڭنْسْ أَذْ تّْوَاسّْعُودْجغْ.‘ “ ؤُشَا إِسْقَارْ هَارُونْ. \x ◘ \xo 10:‏3 \xt لَاوِي 8‏:‏35\x*  
\v 4 إِڒَاغَا مُوسَا إِ مِيشَايِيلْ ذ إِ إِلْصَافَانْ، أَرَّاوْ ن عُوزِّييِيلْ، عمِّيسْ ن هَارُونْ، ؤُشَا إِنَّا أَسنْ: ”قَارّْبمْ-د، ثَارْبُومْ أَيْثْمَاثْومْ زِي قِيبَاتْشْ ن زَّاوشْثْ إِقدّْسنْ، \add أَوْيِي ثنْ بَارَّا\add* إِ ڒْمَارْڭحْ ن ڒْعسْكَارْ.“  
\v 5 قَارّْبنْ-د نِيثْنِي ؤُشَا أَرْبُونْ ثنْ ذِي ثْشَامِيرَاثْ نْسنْ بَارَّا إِ ڒْمَارْڭحْ ن ڒْعسْكَارْ، أَمْ مَامّشْ \add ث\add* إِنَّا مُوسَا.  
\v 6 \add خنِّي\add* إِنَّا مُوسَا إِ هَارُونْ ؤُ إِ أَلِيعَازَارْ ذ إِثَامَارْ، أَرَّاوْ نّسْ: ”وَارْ ضدْجْقمْ إِ \add ؤُشُوَّافْ خْ\add* إِزدْجِيفنْ نْومْ نِيغْ تّْشَارّْڭمْ أَرُّوضْ نْومْ \add إِ وشْضَانْ\add*، حِيمَا وَارْ ثتّْمتِّيمْ ؤُشَا أَذْ يِيڒِي ؤُذُوقّزْ ن وغْضَابْ خْ مَارَّا ثَامسْمُونْثْ. \add مَاشَا\add* أَيْثْمَاثْومْ، مَارَّا ثَادَّارْثْ ن إِسْرَائِيل، أَذْ رُونْ خْ ثْمسِّي-يَا، ثنِّي إِسّشْمضْ سِيذِي.  
\v 7 وَارْ د-تّفّْغمْ شَا زِي وَاذَافْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ، حِيمَا وَارْ ثتّْمتِّيمْ شَا، مِينْزِي زّشْثْ ن وذْهَانْ ن سِيذِي أَقَا ت خَاومْ.“ ؤُشَا نِيثْنِي طَّاعنْ إِ وَاوَاڒْ ن مُوسَا. \x ◘ \xo 10:‏7 \xt لَاوِي 21‏:‏12\x*   
\b  
\m  
\s1 ثَاوْصيّثْ خْ بِينُو ذ شّْرَابْ  
\m
\v 8 إِسِّيوڒْ سِيذِي أَكْ-ذ هَارُونْ، إِنَّا:   
\m
\v 9 ”وَارْ إِعدّڒْ أَذْ ثْسسّذْ بِينُو نِيغْ شّْرَابْ إِجهْذنْ خْمِي غَا ثَاذْفمْ غَارْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ، شكْ \add لَّ\add* ؤُڒَا ذ إِحنْجِيرنْ نّشْ \add نِّي\add* أَكِيذكْ \add لَّ\add*، حِيمَا وَارْ ثتّْمتِّيمْ شَا. أَقَا-ت ذ إِشْثْ ن ثوْصيّثْ إِ ڒبْذَا إِ \add مَارَّا\add* جِّيڒَاثْ نْومْ،  
\v 10 حِيمَا أَذْ أَفْ ثْزمَّارمْ أَذْ ثْفَارْزمْ جَارْ مِينْ \add إِدْجَانْ\add* إِقدّْسنْ ذ مِينْ وَارْ \add إِدْجِينْ\add* إِقدّْسنْ ؤُ جَارْ مِينْ إِصْفَانْ ذ مِينْ وَارْ إِصْفِينْ،  
\v 11 ؤُ حِيمَا أَذْ ثسّْڒمْذمْ إِ أَيْثْ ن إِسْرَائِيل مَارَّا ثِيوصَّا نِّي غَارْسنْ إِسِّيوڒْ سِيذِي س ثْسخَّارْثْ ن مُوسَا.“   
\b  
\m  
\s1 أَلِيعَازَارْ ذ إِثَامَارْ  
\m
\v 12 ؤُشَا إِسِّيوڒْ مُوسَا أَكْ-ذ هَارُونْ ؤُ أَكْ-ذ أَلِيعَازَارْ ذ إِثَامَارْ، أَرَّاوْ نّسْ إِقِّيمنْ: ”كْسِيمْ ثَاوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* نِّي إِشطّنْ زِي ثوْهِيبِينْ ن ثْمسِّي إِ سِيذِي ؤُشَا شّمْ ت بْڒَا أَنْثُونْ زَّاثْ إِ ؤُعَالْطَارْ، مِينْزِي أَقَا-ت ذ ثَامْقدَّاسْثْ قَاعْ.  
\v 13 أَذْ ت ثشّمْ ذڭْ إِجّْ ن ومْشَامْ إِقدّْسنْ، مِينْزِي ثَا ذ ثَاغَارْصْثْ إِ شكْ ؤُ إِ إِحنْجِيرنْ نّشْ زِي ثوْهِيبِينْ ن ثْمسِّي ن سِيذِي، مِينْزِي أَمُّو إِ ذ أَيِي إِتّْوَاوصَّا. \x ◘ \xo 10:‏13 \xt لَاوِي 2‏:‏3؛ 6‏:‏16\x*  
\v 14 ذڭْ إِجّْ ن ومْشَانْ إِصْفَا أَذْ ثشّمْ \add عَاوذْ\add* إِذْمَارنْ ن ونْهزِّي ذ ؤُشكْرُوذْ ن ثوْهِيبْثْ إِ د-إِتّْوَاسّْڭعّْذنْ، شكْ ذ إِحنْجِيرنْ نّشْ ذ ثْحنْجِيرِينْ نّشْ أَكِيذكْ، مِينْزِي \add ذ مَانْ أَيَا\add* ذ ثَاسْغَارْثْ نّشْ ذ ثَاسْغَارْثْ ن ثَارْوَا نّشْ زِي ثْغَارْصَا نْ ڒهْنَا ن أَيْثْ ن إِسْرَائِيل.  
\v 15 أَذْ أَوْينْ أَشكْرُوذْ ن ثوْهِيبْثْ إِ د-إِتّْوَاسّْڭعّْذنْ ؤُڒَا ذ إِذْمَارنْ ن ونْهزِّي أَكْ-ذ ثوْهِيبِينْ ن ثْمسِّي ن ثَاذُونْثْ، مَاحنْذْ أَذْ ثنْ سّنْهزّنْ زَّاثْ إِ وُوذمْ ن سِيذِي أَمْ ثوْهِيبْثْ ن ونْهزِّي. أَقَا ذ إِشْثْ ن ثوْصيّثْ إِ ڒبْذَا إِ شكْ ؤُ إِ إِحنْجِيرنْ نّشْ أَكِيذكْ، أَمْ مَامّشْ \add ث\add* إِوصَّا سِيذِي.“   
\m
\v 16 ؤُشَا مُوسَا يَارْزُو س شْضَارثْ خْ ؤُمْيَانْ ن ثْغَارْصْثْ ن دّنْبْ، \add مَاشَا\add* خْزَارْ، إِشمْضْ. \add خنِّي\add* إِفُّوڭمْ خْ أَلِيعَازَارْ ذ إِثَامَارْ، أَرَّاوْ إِقِّيمنْ ن هَارُونْ، إِنَّا:  
\v 17 ”مَايمِّي وَارْ ثشِّيمْ ثَاغَارْصْثْ ن دّنْبْ ذڭْ ومْشَانْ إِقدّْسنْ؟ مِينْزِي أَقَا-ت ذ ثَامْقدَّاسْثْ قَاعْ ؤُشَا نتَّا إِوْشَا أَومْ ت-إِ-د حِيمَا كنِّيوْ أَذْ ثَارْبُومْ ڒْمُوعْصِييّثْ ن ثْمسْمُونْثْ، مَاحنْذْ أَذْ خَاسنْ ثڭّمْ أَصْڒَاحْ زَّاثْ إِ وُوذمْ ن سِيذِي.  
\v 18 خْزَارمْ، حْذَامْ وَارْ سِّيذْفنْ وَالُو زڭْ إِذَامّنْ ذَاخڒْ إِ زَّاوشْثْ إِقدّْسنْ. ثُوغَا إِتّْخصَّا كنِّيوْ أَذْ ت ثشّمْ ذِي زَّاوشْثْ إِقدّْسنْ أَمْ مَامّشْ ذ أَومْ وصِّيغْ نشّْ.“ \x ◘ \xo 10:‏18 \xt لَاوِي 4‏:‏5؛ 6‏:‏19؛ 16‏:‏27\x*  
\v 19 \add خنِّي\add* إِسِّيوڒْ هَارُونْ أَكْ-ذ مُوسَا: ”خْزَارْ، أَسّْ-أَ أَقَا قدّْمنْ ثَاغَارْصْثْ ن دّنْبْ ذ ثْغَارْصْثْ ن وشْمَاضْ زَّاثْ إِ وُوذمْ ن سِيذِي. \add مَاڒَا\add* نشّْ، أَوَارْنِي ڒَامِي خَافِي كّنْثْ ثْمسْڒَايِينْ-أَ، أَقَا شِّيغْ زِي ثْغَارْصْثْ ن دّنْبْ أَسّْ-أَ، مَا \add خنِّي\add* مَانْ أَيَا إِشْنَا ذِي ثِيطَّاوِينْ ن سِيذِي؟“  
\v 20 \add ؤُمِي\add* إِسْڒَا مُوسَا أَيَا، إِبَانْ أَسْ-د \add مَانْ أَيَا\add* ذ لمْلِيحْ ذِي ثِيطَّاوِينْ نّسْ.   
\b  
\b  
\m  
\c 11
\s1 إِمُودَّارنْ إِزذْڭنْ ذ إِنِّي إِخمْجنْ  
\m
\v 1 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا ذ هَارُونْ، إِنَّا أَسنْ:   
\m
\v 2 ”سِيوڒْ أَكْ-ذ أَيْثْ ن إِسْرَائِيل ؤُشَا إِنِيمْ: ’إِنَا أَقَا أَثنْ ذ \bd ڒْمَاڒْ، إِنِّي ؤُمِي إِعدّڒْ أَذْ ثشّمْ\bd* زِي جَارْ مَارَّا ڒْمَاڒْ نِّي ذِينْ خْ ثمُّورْثْ. \x ◘ \xo 11:‏2 \xt أَعَوذ. 14‏:‏4؛ ڒخ. 10‏:‏14\x*  
\v 3 إِعدّڒْ أَذْ ثشّمْ زِي مَارَّا ڒْمَاڒْ إِ غَارْ ثدْجَا \bd ثشْضشْثْ إِمّْسبْضَانْ\bd*، أَقَا فَارْقَا ن ثشْضشْثْ إِمْسّبْضَانْ \add قَاعْ\add*، \bd ؤُ\bd* \add سنّجْ إِ مَانْ أَيَا\add* \bd تَّارَّانْ إِفژْ\bd*.   
\m
\v 4 مَاشَا زڭْ إِنِّي إِتَّارَّانْ إِفژْ ذ يِينِّي غَارْ ثدْجَا ثشْضشْثْ إِمّْسبْضَانْ، \bd وَارْ تّتّمْ إِنَا\bd*: \bd أَڒْغمْ\bd*، مِينْزِي إِتّفّژْ، \add مَاشَا\add* وَارْ غَارسْ بُو ثشْضشْثْ إِمّْسبْضَانْ، \add س ؤُينِّي\add* أَقَا إِخْمجْ إِ كنِّيوْ،  
\v 5 \bd أَكَاوْكَا ن ثصْضَارْثْ\bd*، مِينْزِي إِتَّارَّا إِفژْ، \add مَاشَا\add* ثَاشْضشْثْ وَارْ ثمّْسبْضِي، ؤُ \add س ؤُينِّي\add* أَقَا إِخْمجْ إِ كنِّيوْ، \x ◘ \xo 11:‏5 \xt أَعَوذ. 14‏:‏7\x*  
\v 6 أَمنِّي \bd أَيَارْزِيزْ\bd*، مِينْزِي إِتَّارَّا إِفژْ، مَاشَا وَارْ غَارسْ ثَاشْضشْثْ إِمّْسبْضَانْ، \add س ؤُينِّي\add* أَقَا إِخْمجْ إِ كنِّيوْ، \x ◘ \xo 11:‏6 \xt أَعَوذ. 14‏:‏7\x*  
\v 7 عَاوضْ \bd إِڒفْ\bd*، مِينْزِي غَارسْ ثَاشْضشْثْ إِمّْسبْضَانْ ؤُشَا أَقَا فَارْقَا ن ثشْضشْثْ إِمّْسبْضَانْ \add قَاعْ\add*، مَاشَا وَارْ إِتَّارِّي إِفژْ، \add س ؤُينِّي\add* أَقَا إِخْمجْ إِ كنِّيوْ.  
\v 8 زڭْ ويْسُومْ نْسنْ وَارْ زَّايسْ تّتّمْ نِيغْ أَذْ ثْحَاذَامْ ڒْخشْبَاثْ نْسنْ، أَقَا خمْجنْ إِ كنِّيوْ.‘ “   
\b  
\m
\v 9 ”إِنَا إِعدّڒْ أَذْ ثنْ ثشّمْ زِي جَارْ مَارَّا \add إِمُودَّارنْ\add* نِّي \add إِدَّارنْ\add* ذڭْ وَامَانْ: \bd مَارَّا وِي غَارْ إِدْجَا وَافْرِيونْ ذ ثقْشُورْثْ\bd* ذڭْ وَامَانْ ؤُ ذِي ڒبْحُورْ ؤُ ذِي ثْغزْرَاثِينْ، إِنَا إِعدّڒْ أَذْ ثنْ ثشّمْ،  
\v 10 \add مَاشَا\add* مَارَّا وِي وَارْ غَارْ يدْجِي إِفْرِيونْ نِيغْ ثَاقْشُورْثْ ذِي ڒبْحُورْ ؤُ ذِي ثْغزْرَاثِينْ، زِي جَارْ مَارَّا إِ زِي سّفّْينْ أَمَانْ ؤُڒَا زِي جَارْ مَارَّا مِينْ إِدَّارنْ ذڭْ وَامَانْ، أَذْ أَومْ يِيڒِي ذ نّْعِي.  
\v 11 \add وَاهْ\add* أَذْ أَومْ يِيڒِي ذ نّْعِي. وَارْ إِعدّڒْ أَذْ ثشّمْ زڭْ ويْسُومْ نْسنْ ؤُ ڒْخشْبَاثْ نْسنْ أَذْ غَارْومْ إِڒِينْثْ ذ نّْعِي.  
\v 12 مَارَّا مِينْ إِدْجَانْ ذڭْ وَامَانْ بْڒَا إِفْرِيونْ ذ ثقْشُورْثْ، أَذْ غَارْومْ يِيڒِي ذ نّْعِي.“   
\b  
\m
\v 13 ”\bd زڭْ إِجْضَاضْ\bd* أَذْ غَارْومْ إِڒِينْ إِنَا ذ نّْعِي، \bd وَارْ زَّايْسنْ تّتّمْ شَا\bd*، أَقَا أَثنْ ذ نّْعِي: أَڭِيذرْ، إِسْغِي، أَڭِيذرْ ن ڒبْحَارْ، \x ◘ \xo 11:‏13 \xt أَعَوذ. 14‏:‏12\x*  
\v 14 \add أَشفَّارْ\add* إِطَّاونْ س ثَازْڒَا، أَمسّْغُويْ \add أَمُوقْضِيعْ ن ثِيطَّاوِينْ\add* أَكْ-ذ مَارَّا مَارْكَاثْ نّسْ، \x ◘ \xo 11:‏14 \xt أَعَوذ. 14‏:‏13\x*  
\v 15 مَارَّا مَارْكَاثْ ن ؤُبَاغڒْ، \x ◘ \xo 11:‏15 \xt أَعَوذ. 14‏:‏14\x*  
\v 16 يدْجِيسْ ن ثْغُويِّيثْ، أَعنَّافْ، أَجْضِيضْ ن ڒبْحَارْ، ڒْبَازْ أَكْ-ذ مَارْكَاثْ نّسْ، \x ◘ \xo 11:‏16 \xt أَعَوذ. 14‏:‏15\x*  
\v 17 \add أَحمَّاڒْ\add* ن ڒْكَاسْ، بُو-ثْشَارَارُّوثْ، بُو-ؤُسُوضِي \add ن ڒْموْثْ\add*،  
\v 18 بُو-يُونْثَاحْ، بُو-ؤُعُوقِّي، بُو-ؤُحَاوَارْ، \x ◘ \xo 11:‏18 \xt أَعَوذ. 14‏:‏16، 17\x*  
\v 19 أَبلَّارْجْ، بُو-ؤُسُوضِي إِعفّْننْ أَكْ-ذ مَارَّا مَارْكَاثْ نّسْ، ذُونْذُونْ ذ ڒْوضْوَاضْ.“ \x ◘ \xo 11:‏19 \xt أَعَوذ. 14‏:‏18\x*   
\b  
\m
\v 20 ”\bd مَارَّا وِي غَارْ إِدْجَا أَفْرِيونْ إِ إِتّْبُوعنْ ؤُ إِڭُّورنْ خْ أَربْعَا ن إِضَارنْ، أَذْ غَارْومْ يِيڒِي ذ نّْعِي.\bd*  
\v 21 \add مَاشَا\add* زِي مَارَّا إِنِّي إِتّْبُوعنْ أَمْ غَارْسنْ أَفْرِيونْ \add ؤُ\add* ڭُّورنْ خْ أَربْعَا ن إِضَارنْ، \bd إِعدّڒْ إِ كنِّيوْ أَذْ ثشّمْ إِنِّي غَارْ إِدْجَا إِضَارنْ \+bdit إِ ونْڭَازْ\+bdit* سنّجْ إِ إِضَارنْ نْسنْ \+bdit إِ ثشْڒِي\+bdit*\bd*، حِيمَا أَذْ زَّايْسنْ نڭْزنْ خْ ثمُّورْثْ.  
\v 22 إِنَا ثْزمَّارمْ أَذْ زَّايْسنْ ثشّمْ: ثَامُورْغِي ن ويْڒَافْ أَكْ-ذ مَارْكَاثْ نّسْ، ثَامُوغْرِي ن ثصْضَارْثْ أَكْ-ذ مَارْكَاثْ نّسْ، ثَامُوغْرِي إِنڭّْزنْ أَكْ-ذ مَارْكَاثْ نّسْ ذ ثَامُوغْرِي إِڒحّْفنْ أَكْ-ذ مَارْكَاثْ نّسْ.  
\v 23 مَارَّا وِي غَارْ إِدْجَا أَفْرِيونْ إِ إِتّْبُوعنْ ؤُ غَارسْ أَربْعَا ن إِضَارنْ، أَذْ غَارْومْ يِيڒِي ذ نّْعِي.“   
\b  
\m
\v 24 ”س \add إِمُودَّارنْ-أَ\add* إِ غَا ثتّْوَاخمْجمْ. مَارَّا وِي غَا إِحَاذَانْ ڒْخشْبَاثْ نْسنْ، أَذْ يِيڒِي إِخْمجْ أَڒْ ثَامذِّيثْ.  
\v 25 مَانْونْ يِيوْينْ شَا زِي ڒْخشْبَاثْ نْسنْ، أَذْ إِسِّيرْذْ أَرُّوضْ نّسْ ؤُشَا أَذْ يِيڒِي إِخْمجْ أَڒْ ثَامذِّيثْ.  
\v 26 مَارَّا ڒبْهَايمْ، إِنِّي غَارْ ثدْجَا ثشْضشْثْ إِمّْسبْضَانْ إِ زِي فَارْقَا \add ن ثشْضشْثْ\add* وَارْ ثْفَارْقْ قَاعْ، ؤُڒَا وَارْ تَّارَّانْ إِفژْ، أَذْ غَارْومْ إِڒِينْ خمْجنْ. مَارَّا وِي ثنْ إِ غَا إِحَاذَانْ، أَذْ يِيڒِي إِخْمجْ.  
\v 27 كُوڒْ \add أَمُودَّارْ\add* جَارْ إِمُودَّارنْ إِ إِڭُّورنْ خْ أَربْعَا ن ثْڒقَّا \add ن إِضَارنْ\add* نْسنْ، أَذْ غَارْومْ يِيڒِي إِخْمجْ. مَارَّا وِي غَا إِحَاذَانْ ڒْخشْبَاثْ نْسنْ، أَذْ يِيڒِي إِخْمجْ أَڒْ ثَامذِّيثْ.  
\v 28 وِي يِيوْينْ شَا ن ڒْخشْبَاثْ نْسنْ، أَذْ إِسِّيرْذْ أَرُّوضْ نّسْ ؤُشَا أَذْ يِيڒِي إِخْمجْ أَڒْ ثْمذِّيثْ. أَذْ أَومْ إِڒِينْ خمْجنْ.“   
\b  
\m
\v 29 ”\bd زِي جَارْ \+bdit إِمُودَّارنْ\+bdit* إِتّْبُوعنْ، إِنِّي إِتّْبُوعنْ خْ ثمُّورْثْ، ذ إِنَا أَذْ خَاومْ إِڒِينْ خمْجنْ\bd* إِ كنِّيوْ: أَجَارْبُوعْ، أَغرْذَا، إِشْفَارْ أَكْ-ذ مَارْكَاثْ نّسْ،  
\v 30 إِقّْلِي، ثَاكْنَاكَارْثْ، أَزرْمُومُّويْ، أَحْذِيضْ ذ ثَاثَا.\f ◼ \fr 11:‏30 \ft \+bd ’ثَاكْنَاكَارْثْ‘\+bd* - نِيغْ ’ثِيقّْلِيثْ‘.\f*  
\v 31 إِنَا أَذْ غَارْومْ إِڒِينْ خمْجنْ زِي جَارْ مَارَّا \add إِمُودَّارنْ\add* نِّي إِتّْبُوعنْ \add خْ ثمُّورْثْ\add*. مَارَّا وِي ثنْ إِ غَا إِحَاذَانْ أَوَارْنِي ڒْموْثْ نْسنْ، أَذْ يِيڒِي إِخْمجْ أَڒْ ثَامذِّيثْ.  
\v 32 مَارَّا مِينْ خفْ إِوْضَا شَا زِي ڒْخشْبَاثْ نْسنْ أَذْ يِيڒِي إِخْمجْ، نِيغْ إِشْثْ ن ڒْقشْعثْ ن ثفْڒَاوْثْ، نِيغْ أَرُّوضْ، نِيغْ ثِيڒْمشْثْ، نِيغْ ثَاخَانْشثْ، نِيغْ مِينْ مَا ڒْقشْعثْ إِ خفْ إِوْضَا شَا زَّايْسنْثْ، إِتّْخصَّا أَذْ إِتّْوَاسَّارْسْ ذڭْ وَامَانْ، أَذْ يِيڒِي إِخْمجْ أَڒْ ثَامذِّيثْ ؤُ \add أَوَارْنِي أَيَا\add* أَذْ يِيڒِي إِزْذِيڭْ. \x ◘ \xo 11:‏32 \xt لَاوِي 15‏:‏12\x*  
\v 33 مَارَّا ڒْقشْعثْ ن ثْڒَاخْثْ، ثنِّي ؤُمِي ذِي إِوْضَا \add شْوَايْثْ زَّايسْ\add*، أَقَا مَارَّا مِينْ ذَايسْ إِدْجَانْ أَذْ يِيڒِي إِخْمجْ ؤُشَا إِتّْخصَّا إِ كنِّيوْ أَذْ ثَارْژمْ طّبْصِي.  
\v 34 مَارَّا مَاشَّا نِّي تّْنُومَانْ \add إِوْذَانْ\add* أَذْ شّنْ، ثنِّي خْ وْضَانْ وَامَانْ نِّي، أَذْ ثِيڒِي ثخْمجْ، ؤُ مَارَّا ثِيسِّيثْ نِّي تّْنُومَانْ \add إِوْذَانْ\add* أَذْ سْونْ، مَامّشْ مَا ثڭَّا ڒْقشْعثْ إِ ذِي ثدْجَا \add مَاشَّا نِيغْ ثِيسِّيثْ\add*، أَذْ ثِيڒِي ثخْمجْ.  
\v 35 مَارَّا مِينْ خفْ إِوْضَا شَا ن ڒْخشْبَاثْ نْسنْ، أَذْ يِيڒِي إِخْمجْ. أَفَارْنُو ذ ثْزوْضَا أَذْ تّْوَارْژنْ، أَقَا خمْجنْ ؤُشَا أَذْ غَارْومْ إِڒِينْ خمْجنْ.  
\v 36 مَاشَا ڒْعُونْصَارْ نِيغْ ذ أَنُو مَانِي غَارْ سِّيزّْڒنْ أَمَانْ، أَذْ يِيڒِي إِزْذڭْ. \add مَاشَا\add* وِي غَا إِحَاذَانْ ڒْخشْبَاثْ نْسنْ، أَذْ يِيڒِي إِخْمجْ.   
\m
\v 37 ؤُشَا مَاڒَا إِوْضَا \add شَا\add* زِي ڒْخشْبَاثْ نْسنْ خْ شَا ن زَّارِيعثْ إِ ؤُزَارْعْ، ثنِّي إِتّْخصَّا عَاذْ أَذْ زَارْعنْ، \add خنِّي\add* أَذْ ثِيڒِي ثِيزْذڭْ.  
\v 38 \add مَاشَا\add* مَاڒَا سيّْبنْ أَمَانْ خْ زَّارِيعثْ ؤُشَا إِوْضَا خَاسْ \add شَا\add* زِي ڒْخشْبَاثْ نْسنْ، \add خنِّي\add* أَذْ غَارْومْ ثِيڒِي \add زَّارِيعثْ نِّي\add* ثخْمجْ.   
\m
\v 39 ؤُشَا مَاڒَا إِمُّوثْ \add إِجّْ\add* زِي جَارْ ڒْمَاڒْ نِّي ثشِّيمْ، \add خنِّي\add* وِي غَا إِحَاضَانْ ڒْخشْبثْ نّسْ، أَذْ يِيڒِي إِخْمجْ أَڒْ ثَامذِّيثْ.  
\v 40 ونِّي إِشّنْ زِي ڒْخشْبثْ نّسْ، أَذْ إِسِّيرْذْ أَرُّوضْ نّسْ ؤُشَا أَذْ يِيڒِي إِخْمجْ أَڒْ ثَامذِّيثْ. ونِّي يَارْبُونْ شَا زِي ڒْخشْبثْ نّسْ، أَذْ إِسِّيرْذْ أَرُّوضْ نّسْ ؤُشَا أَذْ يِيڒِي إِخْمجْ أَڒْ ثَامذِّيثْ.   
\m
\v 41 كُوڒْ \add أَمُودَّارْ\add* إِتّْبُوعنْ خْ ثمُّورْثْ، أَقَا-ث ذ نّْعِي. وَارْ إِعدّڒْ أَذْ إِتّْوَاشّْ.  
\v 42 زِي جَارْ مَارَّا \add إِمُودَّارنْ\add* إِتّْبُوعنْ، إِنِّي إِتّْبُوعنْ خْ \add وُوذمْ ن\add* ثمُّورْثْ، وَارْ تّتّمْ شَا مَارَّا مِينْ إِڭُّورنْ خْ ؤُعذِّيسْ نِيغْ مَارَّا مِينْ إِڭُّورنْ خْ أَربْعَا \add ن إِضَارنْ\add* أَڒْ مَارَّا مِينْ إِڭُّورنْ خْ وَاطَّاسْ ن إِضَارنْ، مِينْزِي أَقَا أَثنْ ذ نّْعِي.  
\v 43 وَارْ تّڭّمْ نّْعِي إِ ڒعْمُورْ نْومْ س مَارَّا إِمُودَّارنْ إِتّْبُوعنْ نِّي \add ذِينْ\add* إِتّْبُوعنْ \add خْ وُوذمْ ن ثمُّورْثْ\add*، وَارْ زَّايسْ سّْخمَّاجمْ إِخفْ نْومْ أَڒَامِي أَذْ زَّايْسنْ ثْخمْجمْ.  
\v 44 مِينْزِي نشّْ ذ سِيذِي، أَربِّي نْومْ. كنِّيوْ أَذْ ثسّْقذْسمْ إِخفْ نْومْ ؤُشَا أَذْ ثِيڒِيمْ ذ إِمْقدَّاسنْ، مِينْزِي نشّْ أَقَا ذ أَمْقدَّاسْ. وَارْ سّْخمَّاجمْ ڒعْمُورْ نْومْ س مَارَّا إِمُّوذَارنْ إِتّْبُوعنْ، إِنِّي إِتّْبُوعنْ خْ \add وُوذمْ ن\add* ثمُّورْثْ. \x ◘ \xo 11:‏44 \xt لَاوِي 19‏:‏2؛ 20‏:‏7؛ 1 بُط. 1‏:‏16\x*  
\v 45 مِينْزِي نشّْ ذ سِيذِي، ونِّي كنِّيوْ د-إِسّْڭعّْذنْ زِي ثمُّورْثْ ن مِيصْرَا، حِيمَا أَذْ إِڒِيغْ ذ أَربِّي نْومْ. إِڒِيمْ ذ إِمْقدَّاسنْ، مَاغَارْ أَقَا نشّْ ذ أَمْقدَّاسْ.“   
\m
\v 46 وَا ذ أَزرْفْ خْ ڒْمَاڒْ، خْ إِجْضَاضْ ؤُ خْ مَارَّا إِمُودَّارنْ نِّي زَّايْسنْ إِسّفْينْ وَامَانْ ؤُشَا خْ مَارَّا إِمُودَّارنْ نِّي إِتّْبُوعنْ خْ ثمُّورْثْ،  
\v 47 حِيمَا أَذْ إِتّْوَاڭّْ ڒْفَارْقْ جَارْ مِينْ إِخمْجنْ ذ مِينْ إِزْذِيڭنْ ؤُ جَارْ إِمُودَّارنْ إِنِّي إِعدّْڒنْ إِ مَاشَّا ذ إِمُودَّارنْ إِنِّي وَارْ إِعدّْڒنْ إِ مَاشَّا.   
\b  
\b  
\m  
\c 12
\s1 ثِيوصَّا ن ؤُسِيزْذڭْ غَارْ وخْڒَاقْ  
\m
\v 1 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 2 ”سِيوڒْ أَكْ-ذ أَيْثْ ن إِسْرَائِيل، إِنِي: ’مَاڒَا ثكْسِي إِشْثْ ن ثمْغَارْثْ دّيْسثْ ؤُشَا ثُورُووْ-د أَحنْجِيرْ، أَذْ ثِيڒِي ثخْمجْ سبْعَا ن وُوسَّانْ. أَذْ ثِيڒِي ثخْمجْ أَمْ \add ذڭْ\add* وُوسَّانْ ن وعْزَاڒْ خْمِي خَاسْ إِذَامّنْ.  
\v 3 ذڭْ وَاسّْ وِيسّْ ثْمنْيَا إِتّْخصَّا أَذْ إِتّْوَاخْثنْ أَيْسُومْ ن ڒعْذَاڒْيثْ نّسْ. \x ◘ \xo 12:‏3 \xt أَمز. 17‏:‏12؛ لك. 1‏:‏59؛ 2‏:‏21؛ يُوح. 7‏:‏22\x*  
\v 4 أَوَارْنِي مَانْ أَيَا أَذْ ثقِّيمْ ثْڒَاثَا ؤُ-ثْڒَاثِينْ ن وُوسَّانْ ذڭْ إِذَامّنْ ن ؤُسِيزْذڭْ نّسْ. وَارْ ثتّْحِيذِي وَالُو زِي مِينْ إِدْجَانْ إِقدّسْ ؤُ وَارْ ثتّْرَاحْ غَارْ زَّاوشْثْ إِقدّْسنْ أَڒْ غَا كمّْڒنْ وُوسَّانْ ن ؤُسِيزْذڭْ نّسْ.  
\v 5 مَاڒَا ثُورُووْ ذ ثَاحنْجِيرْثْ، أَذْ ثِيڒِي ثخْمجْ ثْنَاينْ ن سِّيمَانَاثْ، أَمْ ذڭْ وُوسَّانْ ن وعْزَاڒْ نّسْ. \add أَوَارْنِي مَانْ أَيَا\add* أَذْ ثقِّيمْ ستَّا ؤُ-ستِّينْ ن وُوسَّانْ ذڭْ إِذَامّنْ ن ؤُسِيزْذڭْ نّسْ. \f ◼ \fr 12:‏5 \ft \+bd ’سِّيمَانَاثْ‘\+bd* - نِيغْ ’إِمَالَاسنْ‘.\f*  
\v 6 خْمِي غَا كمّْڒنْ وُوسَّانْ ن ؤُسِيزْذڭْ ن مِّيسْ نِيغْ ن يدْجِيسْ، \add خنِّي\add* أَذْ ثَاوِي إِجّْ ن إِزْمَارْ ن إِجّْ ن ؤُسڭّْوَاسْ أَمْ ثْغَارْصْثْ ن وشْمَاضْ نِيغْ إِجّْ ن وذْبِيرْ ذ أَمژْيَانْ نِيغْ إِشْثْ ن ثجْلِيلِّيحْثْ أَمْ ثْغَارْصْثْ ن دّنْبْ غَارْ ؤُكهَّانْ غَارْ وَاذَافْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ.  
\v 7 ذ نتَّا أَذْ يَاوِي مَانْ أَيَا زَّاثْ إِ وُوذمْ ن سِيذِي ؤُشَا أَذْ خَاسْ إِڭّْ أَصْڒَاحْ. \add خنِّي\add* أَذْ ثِيڒِي ثِيزْذڭْ زِي ڒْعُونْصَارْ ن إِذَامّنْ نّسْ. وَا ذ أَزرْفْ إِ ثنِّي إِ غَا يَارْونْ إِجّْ ن مِّيسْ نِيغْ إِشْثْ ن يدْجِيسْ. \f ◼ \fr 12:‏7 \ft \+bd ’إِفْذِي‘\+bd* - خْزَارْ إِزهد. 78:35.\f*  
\v 8 مَاڒَا وَارْ ثِيوِيضْ أَذْ ثَاوِي إِجّْ زڭْ وُودْجِي، \add خنِّي\add* أَذْ ثطّفْ ثْنَاينْ ن ثجْلِيلِّيحِينْ نِيغْ ثْنَاينْ ن إِذْبِيرنْ إِمژْيَاننْ، إِجّْ إِ ثْغَارْصْثْ ن وشْمَاضْ ؤُ إِجّْ إِ ثْغَارْصْثْ ن دّنْبْ، ؤُشَا أَكهَّانْ أَذْ خَاسْ إِڭّْ أَصْڒَاحْ. \add خنِّي\add* أَذْ ثِيڒِي ثِيزْذڭْ.‘ “ \f ◼ \fr 12:‏8 \ft \+bd ’إِفْذِي‘\+bd* - خْزَارْ إِزهد. 78:35.\f*   
\b  
\b  
\m  
\c 13
\s1 ثِيوصَّا زِي جِّيهثْ ن ڒهْڒَاشْ ن ڒْبَارْصْ  
\m
\v 1 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا ذ هَارُونْ، إِنَّا:   
\m
\v 2 ”مَاڒَا إِجّْ ن بْنَاذمْ غَارسْ ذِي ثڒْمشْثْ ن أَرِّيمثْ نّسْ \bd أَعبُّوزْ نِيغْ إِشْثْ ن ثْحبُّوشْثْ نِيغْ إِجّْ ن ونْڭَازْ إِشّمْڒڒْ\bd*، ؤُشَا وَانِيثَا إِزمَّارْ أَذْ إِذْوڒْ ذ ؤُضُونْ ن ڒْبَارْصْ ذِي ثڒْمشْثْ ن أَرِّيمثْ نّسْ، أَذْ ث أَوْينْ غَارْ هَارُونْ، أَكهَّانْ، نِيغْ غَارْ يِيجّنْ زڭْ وَارَّاوْ نّسْ، غَارْ إِكهَّاننْ.  
\v 3 أَكهَّانْ أَذْ إِخْزَارْ غَارْ وُوضُونْ ذِي ثڒْمشْثْ ن أَرِّيمثْ نّسْ ؤُشَا مَاڒَا إِژْرَا أَقَا إِژُوطَّانْ ذڭْ \add ومْشَانْ ن\add* وُوضُونْ ذوْڒنْ ذ إِشمْڒَاڒنْ ؤُشَا إِبَانْ وُوضُونْ عَاذْ يُودْجغْ خْ ثڒْمشْثْ ن أَرِّيمثْ نّسْ، أَقَا \add خنِّي\add* ذ ؤُضُونْ ن ڒْبَارْصْ. خْمِي ث غَا إِژَارْ ؤُكهَّانْ، أَذْ \add ث\add* إِبَارّحْ ذ أَمخْمُوجْ.  
\v 4 مَاشَا مَاڒَا أَنْڭَازْ إِشّمْڒڒْ ذِي ثڒْمشْثْ ن أَرِّيمثْ نّسْ ذ أَشمْڒَاڒْ ؤُ وَارْ يُودْجِيغْ خْ ثڒْمشْثْ ؤُ إِژطَّانْ وَارْ ذْوِيڒنْ ذ إِشمْڒَاڒنْ، \add خنِّي\add* أَذْ إِبلّعْ ؤُكهَّانْ خْ ونِّي ذِي إِدْجَا ؤُضُونْ \add نِّي\add* سبْعَا ن وُوسَّانْ.  
\v 5 \add مَاڒَا\add* إِژْرَا إِ-ث ؤُكهَّانْ ذڭْ وَاسّْ وِيسّْ سبْعَا ؤُشَا إِژْرَا أَقَا ؤُضُونْ أَمنِّي إِقِّيمْ، وَارْ إِمْغِيرْ وُوضُونْ ذِي ثڒْمشْثْ، \add خنِّي\add* أَذْ ث إِبلّعْ ؤُكهَّانْ \add عَاوذْ\add* سبْعَا ن وُوسَّانْ نّغْنِي.  
\v 6 ذڭْ وَاسّْ وِيسّْ سبْعَا أَذْ ث إِژَارْ ؤُكهَّانْ عَاوذْ ؤُشَا \add مَاڒَا\add* إِبَانْ أَقَا ؤُضُونْ يَارْسَا ؤُشَا وَارْ إِمْغِيرْ \add عَاذْ كْثَارْ\add* خْ ثڒْمشْثْ، \add خنِّي\add* أَكهَّانْ أَذْ ث إِبَارّحْ ذ أَمزْذَاڭْ. ثُوغَا-ت ذ إِشْثْ ن ثْفُورِييْ. أَذْ إِسِّيرْذْ أَرُّوضْ نّسْ ؤُشَا أَذْ يِيڒِي إِزْذِيڭْ.  
\v 7 \add مَاشَا\add* مَاڒَا إِمْغَارْ وُوضُونْ أَطَّاسْ خْ ثڒْمشْثْ أَوَارْنِي ڒَامِي ث إِژْرَا ؤُكهَّانْ ذِي طّْوعْ ن ؤُسِيزْذڭْ نّسْ، إِتّْخصَّا أَذْ إِسّْشنْ \add إِخفْ نّسْ\add* إِ ؤُكهَّانْ ثْوَاڒَا نّغْنِي.  
\v 8 \add مَاڒَا\add* إِژْرَا ؤُكهَّانْ، أَقَا ڒهْڒَاشْ إِمْغَارْ خْ ثڒْمشْثْ، أَذْ ث إِبَارّحْ ذ أَمخْمُوجْ. أَقَا-ث ذ ڒهْڒَاشْ ن ڒْبَارْصْ \add إِ إِدْجَا\add*.   
\m
\v 9 خْمِي ؤُضُونْ نْ ڒْبَارْصْ أَقَا-ث ذڭْ إِجّْ ن بْنَاذمْ، أَذْ ث أَوْينْ غَارْ ؤُكهَّانْ.  
\v 10 \add مَاڒَا\add* إِژْرَا ؤُكهَّانْ، أَقَا إِبَانْ \bd إِجّْ ن ؤُعبُّوزْ ذ أَشمْڒَاڒْ\bd* ذِي ثڒْمشْثْ، ؤُ إِژطَّانْ ذوْڒنْ ذ إِشمْڒَاڒنْ ؤُ إِبَانْ-د ويْسُومْ إِدَّارْ ذڭْ ؤُعبُّوزْ،  
\v 11 أَقَا-ث ذ ڒْبَارْسْ أَقْذِيمْ ذِي ثڒْمشْثْ ن أَرِّيمثْ نّسْ ؤُشَا أَكهَّانْ أَذْ زَّايسْ إِبَارّحْ ذ أَمخْمُوجْ. وَارْ خَاسْ إِتّْبلِّيعْ شَا، مِينْزِي نتَّا أَقَا إِخْمجْ.  
\v 12 مَاڒَا يُويُورْ ڒْبَارْصْ خْ ثِيڒْمشْثْ مَارَّا ؤُشَا إِذْڒَا ڒْبَارْصْ مَارَّا ثِيڒْمشْثْ ن ونِّي غَارْ إِدْجَا ؤُضُونْ زڭْ ؤُزدْجِيفْ نّسْ أَڒْ إِضَارنْ نّسْ، أَڒْ مَانِي إِزمَّارْ أَذْ إِژَارْ ؤُكهَّانْ س ثِيطَّاوِينْ نّسْ،  
\v 13 ؤُشَا إِژْرَا \add إِ-ث\add* ؤُكهَّانْ، إِژْرَا ڒْبَارْسْ إِذْڒَا مَارَّا أَرِّيمثْ نّسْ، \add خنِّي\add* نتَّا أَذْ إِبَارّحْ ذ أَمزْذَاڭْ إِ ونِّي ذِي إِدْجَا وُوضُونْ. \add ثِيڒْمشْثْ\add* أَقَا-ت ذ ثَاشمْڒَاتْشْ قَاعْ. نتَّا أَقَا إِزْذِيڭْ.   
\m
\v 14 \add مَاشَا\add* ذڭْ وَاسّْ مَانِي ذَايسْ إِ غَا د-إِبَانْ ويْسُومْ إِدَّارْ، أَذْ يِيڒِي إِخْمجْ.  
\v 15 \add مَاڒَا\add* إِژْرَا ؤُكهَّانْ أَيْسُومْ \add نِّي\add* إِدَّارْ، أَذْ ث إِبَارّحْ ذ أَمخْمُوجْ. أَيْسُومْ إِدَّارنْ إِخْمجْ، أَقَا-ث ذ ڒهْڒَاشْ ن ڒْبَارْصْ.  
\v 16 \add مَاشَا\add* مَاڒَا إِبدّڒْ ويْسُومْ إِدَّارنْ ؤُ إِذْوڒْ ذ أَشمْڒَاڒْ، إِتّْخصَّا أَسْ أَذْ د-يَاسْ غَارْ ؤُكهَّانْ.  
\v 17 \add مَاڒَا\add* إِژْرَا إِ-ث ؤُكهَّانْ ؤُشَا أَقَا \add أَمْشَانْ ن\add* ؤُضُونْ إِذْوڒْ ذ أَشمْڒَاڒْ، أَذْ إِبَارّحْ ؤُكهَّانْ ونِّي ذِي إِدْجَا ڒهْڒَاشْ ذ أَمزْذَاڭْ. نتَّا أَقَا إِزْذِيڭْ.   
\m
\v 18 \add مَاڒَا\add* ذِينْ خْ ثڒْمشْثْ ن ويْسُومْ إِشْثْ ن ثْحبُّوشْثْ ؤُ ثتّْوَاسّْڭنْفَا ثَانِيثَا،  
\v 19 \add مَاشَا\add* \bd ذڭْ ومْشَانْ ن ثْحبُّوشْثْ إِذْوڒْ ذ إِجّْ ن ؤُعبُّوزْ إِمْڒڒْ نِيغْ ذ إِجّْ ن ونْڭَازْ إِشّمْڒڒْ، أَشمْڒَاڒْ إِرُوحْ غَارْ ثزْوغْ\bd*، \add خنِّي\add* أَذْ إِژَارْ ؤُكهَّانْ مَانْ أَيَا.  
\v 20 \add خْمِي\add* غَارسْ إِ غَا إِخْزَارْ ؤُكهَّانْ ؤُشَا إِژْرَا أَقَا-ث سَاذُو ثڒْمشْثْ ؤُشَا إِژطَّانْ نّسْ ذ إِشمْڒَاڒنْ، \add خنِّي\add* أَكهَّانْ أَذْ ث إِبَارّحْ ذ أَمخْمُوجْ، أَقَا-ث ذ ؤُضُونْ ن ڒْبَارْصْ ونِّي يُويُورنْ س ثْحبُّوشْثْ.  
\v 21 \add مَاشَا\add* مَاڒَا إِژْرَا إِ-ث ؤُكهَّانْ ؤُشَا وَارْ \add ذَايسْ\add* يُوفِي ؤُڒَا ذ إِجّْ ن ؤُژطُّو ذ أَشمْڒَاڒْ ؤُشَا وَارْ إِذْوِيڒْ يُودْجغْ خْ ثڒْمشْثْ، \add مَاشَا\add* إِذْوڒْ يَارْسَا، \add خنِّي\add* أَذْ خَاسْ إِبلّعْ ؤُكهَّانْ سبْعَا ن وُوسَّانْ.  
\v 22 مَاڒَا ثُويُورْ خْ ثڒْمشْثْ مَارَّا، \add خنِّي\add* أَكهَّانْ أَذْ ث إِبَارّحْ ذ أَمخْمُوجْ. أَقَا-ث ذ ؤُضُونْ \add ن ڒْبَارْصْ\add*.  
\v 23 \add مَاشَا\add* مَاڒَا أَنْڭَازْ إِشّمْڒڒْ ن ثڒْمشْثْ إِقِّيمْ ذڭْ ومْشَانْ نّسْ، وَارْ إِمْغِيرْ شَا، أَقَا-ث ذ شَّامثْ ن ثْحبُّوشْثْ ؤُشَا أَكهَّانْ أَذْ ث إِبَارّحْ ذ أَمزْذَاڭْ.   
\m
\v 24 نِيغْ مَاڒَا إِذْوڒْ ذِي ثڒْمشْثْ ن أَرِّيمثْ إِجّْ ن ؤُيزِّيمْ ن وشْمَاضْ ؤُشَا أَيْسُومْ إِدَّارنْ ن \bd ؤُيزِّيمْ ن وشْمَاضْ إِذْوڒْ ذ إِجّْ ن ونْڭَازْ إِشّمْڒڒْ، أَشمْڒَاڒْ إِرُوحْ غَارْ ثزْوغْ نِيغْ ذ أَشمْڒَاڒْ\bd*،  
\v 25 ؤُشَا إِژْرَا ؤُكهَّانْ مَانْ أَيَا، ؤُشَا خْزَارْ، إِژطَّانْ إِ إِدْجَانْ ذڭْ ونْڭَازْ إِشّمْڒڒْ أَقَا ذوْڒنْ ذ إِشمْڒَاڒنْ، ؤُشَا إِبَانْ \add أَقَا أَمْشَانْ ن ونْڭَازْ\add* يُودْجغْ ذِي ثڒْمشْثْ، أَقَا-ث ذ ڒْبَارْصْ نِّي د-إِفّْغنْ زڭْ ؤُيزِّيمْ ن وشْمَاضْ. أَكهَّانْ أَذْ ث إِبَارّحْ ذ أَمخْمُوجْ. أَقَا-ث ذ ؤُضُونْ ن ڒْبَارْصْ.  
\v 26 \add مَاشَا\add* مَاڒَا أَكهَّانْ إِژْرَا مَانْ أَيَا ؤُشَا وَارْ إِتّْوِيڒِي إِژطَّانْ إِشمْڒَاڒنْ ذڭْ ونْڭَازْ إِشّمْڒڒْ ؤُشَا \add إِژْرَا أَنْڭَازْ\add* وَارْ يُودْجِيغْ خْ ثڒْمشْثْ ؤُشَا يَارْسَا، \add خنِّي\add* أَذْ خَاسْ إِبلّعْ ؤُكهَّانْ سبْعَا ن وُوسَّانْ.  
\v 27 ذڭْ وَاسّْ وِيسّْ سبْعَا أَذْ ث إِژَارْ ؤُكهَّانْ ؤُشَا مَاڒَا إِمْغَارْ \add ونْڭَازْ\add* كْثَارْ خْ ثڒْمشْثْ، أَكهَّانْ أَذْ ث إِبَارّحْ ذ أَمخْمُوجْ. أَقَا-ث ذ ؤُضُونْ ن ڒْبَارْصْ.  
\v 28 \add مَاشَا\add* مَاڒَا أَنْڭَازْ إِشّمْڒڒْ إِقِّيمْ ذڭْ ومْشَانْ نّسْ، وَارْ إِمْغِيرْ خْ ثڒْمشْثْ ؤُشَا يَارْسَا، أَقَا-ث ذ أَعبُّوزْ ن وشْمَاضْ. أَكهَّانْ أَذْ ث إِبَارّحْ ذ أَمزْذَاڭْ، مِينْزِي أَقَا-ت ذ شَّامثْ ن وشْمَاضْ.   
\m
\v 29 مَاڒَا إِجّْ ن ورْيَازْ نِيغْ إِشْثْ ن ثمْغَارْثْ ذَايسْ \bd ؤُضُونْ ذڭْ ؤُزدْجِيفْ نِيغْ ذِي ثْمَارْثْ\bd*،  
\v 30 ؤُشَا إِخْزَارْ ؤُكهَّانْ غَارْ ؤُضُونْ، ؤُ خْزَارْ، أَقَا إِتّْبَانْ يُودْجغْ ذِي ثڒْمشْثْ ؤُشَا ذَايسْ إِژطَّانْ إِوَارْغنْ ذ إِزْذَاذنْ، \add خنِّي\add* أَكهَّانْ أَذْ ث إِبَارّحْ ذ أَمخْمُوجْ. أَقَا-ت ذ ثْفُورِي \add ن يِيڒمْ\add*، أَقَا-ث ذ ڒْبَارْصْ ن ؤُزدْجِيفْ نِيغْ ن ثْمَارْثْ.  
\v 31 \add مَاشَا\add* مَاڒَا إِژْرَا ؤُكهَّانْ ؤُضُونْ ن ثْفُورِي \add ن يِيڒمْ\add*، إِژْرَا أَقَا وَارْ يُودْجِيغْ ذِي ثڒْمشْثْ ؤُشَا وَارْ ذَايسْ إِژطَّانْ إِبَارْشَاننْ، \add خنِّي\add* أَذْ خَاسْ إِبلّعْ ؤُكهَّانْ خْ ونِّي ذِي إِدْجَا وُوضُونْ ن ثْفُورِي \add ن يِيڒمْ\add* إِ يِيجّْ ن ڒْمِيجَاڒْ ن سبْعَا ن وُوسَّانْ.  
\v 32 أَذْ إِژَارْ ؤُكهَّانْ ؤُضُونْ ذڭْ وَاسّْ وِيسّْ سبْعَا ؤُشَا مَاڒَا إِژْرَا، أَقَا ثْفُورِي \add ن يِيڒمْ\add* وَارْ ثمْغِيرْ، وَارْ ذَايسْ يُوفِي إِژطَّانْ إِوَارْغنْ ؤُشَا ثْفُورِي \add ن يِيڒمْ\add* وَارْ ثُودْجِيغْ خْ ثڒْمشْثْ،  
\v 33 \add خنِّي\add* نتَّا أَذْ إِحفّْ إِ يِيخفْ نّسْ، \add مَاشَا\add* \add أَمْشَانْ ن\add* ثْفُورِي \add ن يِيڒمْ\add* وَارْ ث إِتّْحفِّي شَا ؤُشَا أَكهَّانْ أَذْ إِبلّعْ خْ ونِّي ذِي إِدْجَا ثْفُورِي \add ن يِيڒمْ\add* عَاذْ إِشْثْ ن ثْوَاڒَا نّغْنِي إِ يِيجّْ ن ڒْمِيجَاڒْ ن سبْعَا ن وُوسَّانْ.  
\v 34 ذڭْ وَاسّْ وِيسّْ سبْعَا أَذْ إِژَارْ ؤُكهَّانْ \add أَمْشَانْ ن\add* ثْفُورِي \add ن يِيڒمْ\add*. \add مَاڒَا\add* إِژْرَا أَقَا ثْفُورِي \add ن يِيڒمْ\add* وَارْ ثمْغِيرْ شَا، وَارْ ثُودْجِيغْ خْ ثڒْمشْثْ، \add خنِّي\add* أَكهَّانْ أَذْ ث إِبَارّهْ ذ أَمزْذَاڭْ. أَذْ إِسِّيرْذْ أَرُّوضْ نّسْ ؤُشَا أَذْ يِيڒِي إِزْذِيڭْ.  
\v 35 مَاشَا مَاڒَا ثْفُورِي \add ن يِيڒمْ\add* ثمْغَارْ أَطَّاسْ خْ ثڒْمشْثْ أَوَارْنِي إِ ؤُسِيزْذڭْ نّسْ،  
\v 36 ؤُشَا إِژْرَا إِ-ث ؤُكهَّانْ ؤُشَا إِژْرَا ثْفُورِي \add ن يِيڒمْ\add* ثمْغَارْ خْ ثڒْمشْثْ، \add خنِّي\add* وَارْ يَارزُّو ؤُكهَّانْ خْ إِژطَّانْ إِوَارْغنْ عَاذْ، نتَّا أَقَا إِخْمجْ.  
\v 37 \add مَاشَا\add* مَاڒَا ثْفُورِي \add ن يِيڒمْ\add* أَقَا ثْبَانْ-د ثْبدّْ ذِي ثِيطَّاوِينْ نّسْ، ؤُشَا فّْغنْ-د زَّايسْ إِژطَّانْ إِبَارْشَاننْ، \add خنِّي\add* أَقَا ثڭّنْفَا ثْفُورِي \add ن يِيڒمْ\add* ؤُشَا نتَّا أَقَا إِزْذڭْ. أَكهَّانْ أَذْ ث إِبَارّحْ ذ أَمزْذَاڭْ.   
\m
\v 38 مَاڒَا بَاننْ-د \bd إِمُوشَانْ شّمْڒڒنْ\bd*، إِشّمْڒڒنْ ذ إِشمْڒَاڒنْ، ذِي ثڒْمشْثْ ن إِجّْ ن ورْيَازْ نِيغْ ن إِشْثْ ن ثمْغَارْثْ،  
\v 39 ؤُشَا إِژْرَا ؤُكهَّانْ مَانْ أَيَا ؤُشَا إِژْرَا أَقَا ذِي ثڒْمشْثْ ن أَرِّيمثْ بَاننْ-د إِمُوشَانْ أَرْسَانْ، إِشمْڒَاڒنْ، \add خنِّي\add* أَقَا-ت ذ إِشْثْ ن ثْفُورِي ن ثڒْمشْثْ، نتَّا أَقَا إِزْذڭْ.   
\m
\v 40 \add مَاڒَا\add* إِوْضَا ؤُشُوَّافْ ن ؤُزدْجِيفْ ن إِجّْ ن ورْيَازْ، أَقَا ذ \bd أَقشَّارْ\bd*، \add خنِّي\add* نتَّا أَقَا إِزْذِيڭْ.  
\v 41 مَاڒَا ثَانْيَارْثْ ن شَا ن يِيجّْ أَذْ ثذْوڒْ ثَاڒقَّاغْثْ، أَقَا ثَانْيَارْثْ نّسْ ثْقشَّارْ \add وَاهَا\add*، نتَّا أَقَا إِزْذِيڭْ.  
\v 42 \add مَاشَا\add* مَاڒَا \add ذِينْ\add* إِجّْ ن ؤُضُونْ إِمْڒڒْ إِرُوحْ غَارْ ثزْوغْ خْ ؤُزدْجِيفْ أَقشَّارْ نِيغْ خْ ثنْيَارْثْ ثَاقشَّارْثْ، أَقَا-ث ذ ڒْبَارْصْ نِّي د-إِفّْغنْ خْ ؤُزدْجِيفْ نّسْ أَقشَّارْ نِيغْ خْ ثنْيَارْثْ نّسْ ثَاقشَّارْثْ.  
\v 43 \add مَاڒَا\add* إِژْرَا إِ-ث ؤُكهَّانْ ؤُشَا إِژْرَا أَقَا أَعبُّوزْ ن وُوضُونْ إِمْڒڒْ، إِرُوحْ غَارْ ثزْوغْ خْ ؤُزدْجِيفْ نّسْ أَقشَّارْ نِيغْ خْ ثنْيَارْثْ نّسْ ثَاقشَّارْثْ، إِبَانْ-د أَمْ ڒْبَارْصْ ن ثڒْمشْثْ ن أَرِّيمثْ،  
\v 44 \add خنِّي\add* أَقَا أَرْيَازْ ذ بُو-ڒْْبَارْصْ إِ إِدْجَا، نتَّا أَقَا إِخْمجْ. أَكهَّانْ أَذْ ث إِبَارّحْ ذ أَمخْمُوجْ، ؤُضُونْ أَقَا-ث خْ ؤُزدْجِيفْ نّسْ.“   
\b  
\m
\v 45 ”إِتّْخصَّا أَذْ إِتّْوَاشَارّڭْ وَارُّوضْ ن بُو-ڒْْبَارْصْ إِ ذِي إِدْجَا وُوضُونْ ؤُشَا أَذْ إِضْڒقْ إِ \add ؤُشُوَّافْ خْ\add* ؤُزدْجِيفْ نّسْ، أَذْ إِڒحّفْ أَشْڒَاغمْ غَارْ ؤُينْشِيشْ، أَذْ إِڒَاغَا: ’أَمخْمُوجْ! أَمخْمُوجْ!‘ \x ◘ \xo 13:‏45 \xt إِڭجذ. 4‏:‏15\x*  
\v 46 مَارَّا ؤُسَّانْ إِ ذَايسْ إِ غَا يِيڒِي وُوضُونْ، أَذْ يِيڒِي إِخْمجْ. نتَّا ذ أَمخْمُوجْ. نتَّا أَذْ إِزْذغْ وحّْذسْ ؤُشَا ثْزذِّيغْثْ نّسْ أَذْ ثِيڒِي بَارَّا إِ ڒْمَارْڭحْ ن ڒْعسْكَارْ.“   
\b  
\m
\v 47 ”\add مَاڒَا\add* ؤُضُونْ ن \bd ڒْْبَارْصْ ذڭْ إِجّْ ن وَارُّوضْ\bd*، ذڭْ إِجّْ ن وَارُّوضْ ن ثَاضُوفْثْ نِيغْ ذڭْ إِجّْ ن وَارُّوضْ ن ڒقْطنْ،  
\v 48 نِيغْ \bd ذڭْ وشْضَاضْ إِخيّْضنْ نِيغْ ذڭْ ؤُفِيڒُو إِمُّوذنْ\bd*، \add نِيغْ\add* ن ڒقْطنْ نِيغْ ن ثَاضُوفْثْ، نِيغْ \bd غَارْ يِيڒمْ، نِيغْ غَارْ مَامّشْ مَا ڒْقشْعثْ ن يِيڒمْ\bd*،  
\v 49 ؤُ \add ثِيشْثِي\add* إِتّْوَاوْثنْ ذڭْ وَارُّوضْ نِيغْ ذڭْ يِيڒمْ، نِيغْ غَارْ وشْضَاضْ إِخيّْضنْ نِيغْ غَارْ ؤُفِيڒُو إِمُّوذنْ، نِيغْ ذِي مَامّشْ مَا ن ڒْقشْعثْ \add نِّي تّڭّنْ\add* س يِيڒمْ، ثزِّيزُو نِيغْ ثزْوغْ، أَقَا-ث ذ ؤُضُونْ ن ڒْبَارْصْ. أَذْ إِتّْوَاسّْشنْ أَيَا إِ ؤُكهَّانْ.  
\v 50 أَكهَّانْ أَذْ إِخْزَارْ \add غَارْ ومْشَانْ ن\add* ؤُضُونْ ؤُشَا مِينْ إِضْننْ أَذْ ث إِبلّعْ سبْعَا ن وُوسَّانْ.  
\v 51 ذڭْ وَاسّْ وِيسّْ سبْعَا أَذْ إِخْزَارْ غَارْ وُوضُونْ. مَاڒَا إِمْغَارْ ؤُضُونْ ذڭْ وَارُّوضْ، نِيغْ غَارْ وشْضَاضْ إِخيّْضنْ نِيغْ غَارْ ؤُفِيڒُو إِمُّوذنْ، نِيغْ ذڭْ يِيڒمْ ن مَامّشْ مَا ڒْقشْعثْ نِّي تّڭّنْ س يِيڒمْ، أَقَا ؤُضُونْ ذ ڒْبَارْسْ إِقسْحنْ إِ يدْجَا، أَقَا إِخْمجْ.  
\v 52 أَذْ إِسّشْمضْ أَرُّوضْ نِيغْ أَفِيڒُو ذ أَزِيرَارْ نِيغْ أَفِيڒُو إِمُّوذنْ، نِيغْ ن ثَاضُوفْثْ نِيغْ ن ڒقْطنْ \add إِ إِدْجَا\add*، نِيغْ مَامّشْ مَا ڒْقشْعثْ \add نِّي تّڭّنْ\add* س يِيڒمْ إِ ذَايسْ ثُوغَا ؤُضُونْ، مِينْزِي أَقَا-ث ذ ڒْبَارْصْ إِقسْحنْ. إِتّْخصَّا أَذْ إِتّْوَاسّشْمضْ س ثْمسِّي.  
\v 53 \add مَاشَا\add* مَاڒَا إِژْرَا ؤُكهَّانْ مَانْ أَيَا ؤُشَا أَقَا ؤُضُونْ وَارْ إِمْغِيرْ شَا ذڭْ وَارُّوضْ، نِيغْ ذڭْ وشْضَاضْ إِخيّْضنْ نِيغْ ذڭْ ؤُفِيڒُو إِمُّوذنْ، نِيغْ ذِي مَامّشْ مَا ڒْقشْعثْ \add نِّي تّڭّنْ\add* س يِيڒمْ،  
\v 54 \add خنِّي\add* أَذْ يُومُورْ ؤُكهَّانْ مَاحنْذْ أَذْ سِّيرْذنْ مِينْ ذِي يدْجَا وُوضُونْ، ؤُشَا \add أَوَارْنِي إِ مَانْ أَيَا\add* أَذْ خَاسْ إِبلّعْ ثْوَاڒَا نّغْنِي ڒْقدّْ ن سبْعَا ن وُوسَّانْ.  
\v 55 \add مَاڒَا\add* إِژْرَا ؤُكهَّانْ ؤُضُونْ أَوَارْنِي إِ ؤُسِيرْذْ، ؤُشَا إِژْرَا ؤُضُونْ وَارْ إِبذِّيڒْ شَا ؤُشَا ؤُضُونْ وَارْ إِمْغِيرْ، أَقَا \add أَرُّوضْ نِّي\add* إِخْمجْ. إِتّْخصَّا أَذْ ث ثسّشْمضذْ س ثْمسِّي. أَقَا \add ؤُضُونْ\add* إِذْوڒْ يُودْجغْ إِتّتّْ غَارْ ضفَّارْ نِيغْ غَارْ زَّاثْ.  
\v 56 \add مَاشَا\add* مَاڒَا إِژْرَا ؤُكهَّانْ مَانْ أَيَا ؤُشَا إِژْرَا بلِّي ؤُضُونْ يَارْسَا أَوَارْنِي إِ ؤُسِيرْذْ، \add خنِّي\add* أَذْ ث إِقسّْ زڭْ وَارُّوضْ، نِيغْ زڭْ يِيڒمْ، نِيغْ زڭْ وشْضَاضْ إِخيّْضنْ نِيغْ زڭْ ؤُفِيڒُو إِمُّوذنْ.  
\v 57 \add مَاشَا\add* مَاڒَا إِبَانْ \add وُوضُونْ\add* ثْوَاڒَا نّغْنِي ذڭْ وَارُّوضْ، نِيغْ غَارْ وشْضَاضْ إِخيّْضنْ نِيغْ غَارْ ؤُفِيڒُو إِمُّوذنْ، نِيغْ ذِي مَامّشْ مَا ڒْقشْعثْ \add نِّي تّڭّنْ\add* س يِيڒمْ، \add أَقَا\add* إِدُّوقّزْ \add ڒْبَارْصْ\add*. إِتّْخصَّا أَذْ ثسّشْمضْ س ثْمسِّي مِينْ ذَايسْ إِ إِدْجَانْ ؤُضُونْ.  
\v 58 أَرُّوضْ، نِيغْ أَفِيڒُو ذ أَزِيرَارْ نِيغْ أَفِيڒُو إِمُّوذنْ نِيغْ مَامّشْ مَا ڒْقشْعثْ \add نِّي تّڭّنْ\add* س يِيڒمْ، ونِّي ثسِّيرْذذْ ؤُشَا إِرُوحْ خَاسْ وُوضُونْ، أَذْ ث ثسِّيرْذذْ ثْوَاڒَا نّغْنِي ؤُشَا \add خنِّي\add* أَذْ يِيڒِي إِزْذِيڭْ.“  
\v 59 وَا ذ أَزرْفْ ن وُوضُونْ ن ڒْبَارْصْ ن وَارُّوضْ ن ثَاضُوفْثْ نِيغْ ن ڒقْطنْ، نِيغْ ن وشْضَاضْ إِخيّْضنْ نِيغْ ن ؤُفِيڒُو إِمُّوذنْ، نِيغْ ن مَامّشْ مَا ڒْقشْعثْ \add نِّي تّڭّنْ\add* س يِيڒمْ، مَاحنْذْ خنِّي أَذْ بَارّْحنْ س ثزْذڭْ \add نّسْ\add* نِيغْ س ڒخْمجْ \add نّسْ\add*.   
\b  
\b  
\m  
\c 14
\s1 أَسِيزْذڭْ ن ڒهْڒَاشْ ن ڒْبَارْصْ  
\m
\v 1 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 2 ”وَا ذ أَزرْفْ ن بُو-ڒْْبَارْصْ إِ وَاسّْ ن ؤُسِيزْذڭْ نّسْ. إِتّْخصَّا أَذْ ث نذْهنْ غَارْ ؤُكهَّانْ، \x ◘ \xo 14:‏2 \xt مت. 8‏:‏4؛ مك. 1‏:‏44؛ لك. 5‏:‏14؛ 17‏:‏14\x*  
\v 3 ؤُشَا أَذْ إِفّغْ ؤُكهَّانْ غَارْ بَارَّا إِ ڒْمَارْڭحْ ن ڒْعسْكَارْ. خْمِي غَارسْ إِ غَا إِخْزَارْ ؤُكهَّانْ ؤُشَا إِژْرَا أَقَا إِڭّنْفَا وُوضُونْ ن ڒْبَارْصْ ن بُو-ڒْبَارْصْ،  
\v 4 أَذْ يُومُورْ ؤُكهَّانْ، مَاحنْذْ أَذْ كْسِينْ إِ ونِّي إِ غَا إِتّْوَاسِّيزذْڭنْ ثْنَاينْ ن إِجْضَاضْ إِدَّارنْ إِزْذِيڭنْ، ؤُڒَا ذ أَكشُّوضْ ن \add ثْشجَّارْثْ ن\add* ثنْڭلْثْ، ذ ؤُزڭّْوَاغْ إِحذْقنْ، ذ ثْعلْدْجثْ. \f ◼ \fr 14:‏4 \ft \+bd ’ثْعلْدْجثْ‘\+bd* - نِيغْ ’هِيسُوبْ‘. ؤُڒَا ذِي أَيَاثْ 6، 49، 51 ذ 52.\f*  
\v 5 أَذْ يُومُورْ ؤُكهَّانْ مَاحنْذْ أَذْ غَارْصنْ إِ يِيجّْ ن وجْضِيضْ ذڭْ إِشْثْ ن ڒْقشْعثْ ن ثْڒَاخْثْ، سنّجْ إِ وَامَانْ إِتَّازّْڒنْ.  
\v 6 \add خنِّي\add* أَذْ إِكْسِي أَجْضِيضْ إِدَّارنْ ذ ؤُكشُّوضْ ن \add ثْشجَّارْثْ ن\add* ثنْڭلْثْ ذ ؤُزڭّْوَاغْ إِحذْقنْ ذ ثْعلْدْجثْ ؤُشَا أَذْ ثنْ إِسُّوفْ أَكْ-ذ وجْضِيضْ إِدَّارنْ ذڭْ إِذَامّنْ ن وجْضِيضْ إِ إِتّْوَاغَارْصنْ سنّجْ إِ وَامَانْ إِتَّازّْڒنْ.  
\v 7 أَذْ إِرُوشّْ سبْعَا ن ثْوَاڒَاوِينْ خْ ونِّي إِتّْوَاسِّيزذْڭنْ زِي ڒْبَارْصْ. \add خنِّي\add* أَذْ ث إِبَارّحْ ذ أَمزْذَاڭْ ؤُشَا أَذْ يَارْخُو إِ وجْضِيضْ إِدَّارنْ مَاحنْذْ أَذْ إِضوْ سنّجْ إِ وُوذمْ ن ييَّارْ.  
\v 8 ؤُشَا ونِّي إِتّْوَاسِّيزذْڭنْ أَذْ إِصبّنْ أَرُّوضْ نّسْ ؤُشَا أَذْ إِحفّْ مَارَّا أَشُوَّافْ نّسْ، أَذْ إِسِّيرْذْ إِخفْ نّسْ س وَامَانْ. \add خنِّي\add* أَذْ يِيڒِي إِزْذڭْ. أَوَارْنِي أَسْ أَذْ يَاذفْ غَارْ ڒْمَارْڭحْ ن ڒْعسْكَارْ ؤُشَا أَذْ إِزْذغْ بَارَّا إِ ؤُقِيضُونْ نّسْ عَاذْ سبْعَا ن وُوسَّانْ.   
\m
\v 9 ذڭْ وَاسّْ وِيسّْ سبْعَا أَذْ إِحفّْ مَارَّا أَشُوَّافْ ن ؤُزدْجِيفْ نّسْ ذ ثْمَارْثْ نّسْ ذ ثمِّيوِينْ ن ثِيطَّاوِينْ نّسْ، \add وَاهْ،\add* أَذْ إِحفّْ مَارَّا أَشُوَّافْ نّسْ، أَذْ إِصبّنْ أَرُّوضْ نّسْ ؤُشَا أَذْ إِسِّيرْذْ أَرِّيمثْ نّسْ س وَامَانْ، \add خنِّي\add* أَذْ يِيڒِي إِزْذڭْ.   
\m
\v 10 ذڭْ وَاسّْ وِيسّْ ثْمنْيَا أَذْ إِكْسِي ثْنَاينْ ن إِزْمَارنْ كمّْڒنْ ذ إِشْثنْ ثخْسِي إِشْنَانْ قَاعْ ن إِجّنْ ؤُسڭّْوَاسْ أَكْ-ذ ثْڒَاثَا زِيعشْرَا ن إِجّنْ إِفَا ن وَارنْ أَزْذَاذْ أَمْ ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* إِخدْجْضنْ س زّشْثْ، ؤُ \add عَاوذْ\add* إِجّنْ ؤُلُوخْ ن زّشْثْ.  
\v 11 أَكهَّانْ، ونِّي ث إِسِّيزذْڭنْ، أَذْ يَارّْ أَرْيَازْ نِّي إِتّْخصَّا أَذْ إِتّْوَاسِّيزْذڭْ، أَكْ-ذ مَارَّا أَيَا زَّاثْ إِ وُوذمْ ن سِيذِي غَارْ وَاذَافْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ.  
\v 12 أَذْ إِكْسِي ؤُكهَّانْ إِزْمَارْ نِّي ؤُشَا أَذْ ث-إِ-د-إِسّْقَارّبْ أَمْ ثْغَارْصْثْ ن ؤُمَارْوَاسْ أَكْ-ذ ؤُلُوخْ ن زّشْثْ، ؤُشَا أَذْ ث إِسّنْهزّْ أَمْ ثوْهِيبْثْ ن ونْهزِّي زَّاثْ إِ وُوذمْ ن سِيذِي.  
\v 13 \add خنِّي\add* أَذْ إِغَارْصْ إِ يزْمَارْ نِّي ذڭْ ومْشَانْ مَانِي غَارّْصنْ ثَاغَارْصْثْ ن دّنْبْ ذ ثْغَارْصْثْ ن وشْمَاضْ، ذڭْ ومْشَانْ أَمْقدَّاسْ. مِينْزِي ثَاغَارْصْثْ ن ؤُمَارْوَاسْ، أَمْ ثْغَارْصْثْ ن دّنْبْ، إِ ؤُكهَّانْ إِ ثدْجَا، أَقَا-ت ذ ثَامْقدَّاسْثْ قَاعْ. \x ◘ \xo 14:‏13 \xt لَاوِي 7‏:‏7\x*  
\v 14 أَذْ إِكْسِي ؤُكهَّانْ \add شْوَايْثْ\add* زڭْ إِذَامّنْ ن ثْغَارْصْثْ ن ؤُمَارْوَاسْ ؤُشَا أَكهَّانْ أَذْ ثنْ إِڭّْ خْ إِغسْ ن ؤُمزُّوغْ أَفُوسِي ن ونِّي إِ غَا إِتّْوَاسِّيزذْڭنْ ؤُڒَا خْ يِيمزْ ن ؤُفُوسْ نّسْ أَفُوسِي ؤُ خْ يِيمزْ ن ؤُضَارْ نّسْ أَفُوسِي.  
\v 15 أَمنِّي إِ غَا إِكْسِي ؤُكهَّانْ \add شَا\add* زڭْ ؤُلُوخْ ن زّشْثْ ؤُشَا أَذْ ت إِنْغڒْ خْ ثْڒقَّا ن ؤُفُوسْ نّسْ أَزڒْمَاضْ.  
\v 16 أَذْ إِسُّوفْ ؤُكهَّانْ أَضَاضْ نّسْ أَفُوسِي س زّشْثْ نِّي غَارسْ ذڭْ ؤُفُوسْ نّسْ أَزڒْمَاضْ ؤُشَا \add أَمُّو إِ\add* غَا إِرُوشّْ س ؤُضَاضْ نّسْ \add شْوَايْثْ\add* زِي زّشْثْ سبْعَا ن ثْوَاڒَاوِينْ زَّاثْ إِ وُوذمْ ن سِيذِي.  
\v 17 ؤُشَا مِينْ إِقِّيمنْ زِي زّشْثْ نِّي غَارسْ ذڭْ ؤُفُوسْ نّسْ، أَذْ ت إِڭّْ ؤُكهَّانْ خْ إِغسْ ن ؤُمزُّوغْ أَفُوسِي ن ونِّي إِ غَا إِتّْوَاسِّيزذْڭنْ، ؤُڒَا خْ يِيمزْ ن ؤُفُوسْ نّسْ أَفُوسِي ؤُ خْ يِيمزْ ن ؤُضَارْ نّسْ أَفُوسِي، ثِيوَا ن إِذَامّنْ ن ثْغَارْصْثْ ن ؤُمَارْوَاسْ \add إِ خَاسنْ إِڭَّا قْبڒْ\add*.  
\v 18 مِينْ إِقِّيمنْ ن زّشْثْ نِّي إِدْجَانْ غَارْ ؤُكهَّانْ ذِي ثْڒقَّا ن ؤُفُوسْ نّسْ، أَذْ ث إِنْغڒْ خْ ؤُزدْجِيفْ ن ونِّي إِ غَا إِتّْوَاسِّيزذْڭنْ ؤُشَا \add أَمُّو إِ\add* ث غَا إِسّصْڒحْ ؤُكهَّانْ زَّاثْ إِ وُوذمْ ن سِيذِي. \f ◼ \fr 14:‏18 \ft \+bd ’إِفْذِي‘\+bd* - خْزَارْ إِزهد. 78:35.\f*  
\v 19 أَذْ إِسّوْجذْ ؤُكهَّانْ \add خنِّي\add* ثَاغَارْصْثْ ن دّنْبْ ؤُشَا أَذْ إِسّصْڒحْ ونِّي إِتّْوَاسِّيزذْڭنْ زِي ڒخْمجْ نّسْ. أَوَارْنِي أَسْ أَذْ إِغَارْصْ إِ ثْغَارْصْثْ ن وشْمَاضْ.  
\v 20 أَذْ إِسّْبخَّارْ ؤُكهَّانْ ثَاغَارْصْثْ ن وشْمَاضْ ذ ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* خْ ؤُعَالْطَارْ. \add أَمُّو إِ\add* ث غَا إِسّصْڒحْ ؤُكهَّانْ ؤُشَا أَذْ يِيڒِي إِزْذڭْ.   
\m
\v 21 مَاڒَا نتَّا إِژْڒضْ ؤُشَا أَفُوسْ نّسْ وَارْ ث إِسِّيوضْ، \add خنِّي\add* أَذْ إِكْسِي إِجّْ ن يِيزْمَارْ أَمْ ثْغَارْصْثْ ن ؤُمَارْوَاسْ مَاحنْذْ أَذْ خَاسْ إِڭّْ أَصْڒَاحْ أَمْ إِڭَّا إِزْمَارْ ذ ثوْهِيبْثْ ن ونْهزِّي. أَذْ إِكْسِي ڒَا ذ إِشْثْ ن ثعْشَارْثْ ن \add إِجّْ ن إِفَا\add* ن وَارنْ أَزْذَاذْ إِخدْجْضنْ س زّشْثْ أَمْ ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add*، ؤُڒَا ذ إِجّْ ن ؤُلُوخْ ن زّشْثْ  
\v 22 ذ ثْنَاينْ ن ثجْلِيلِّيحِينْ نِيغْ ثْنَاينْ ن إِذْبِيرنْ إِمژْيَانِينْ، أَنشْثْ إِزمَّارْ ؤُفُوسْ نّسْ أَذْ إِسِّيوضْ. إِشْثْ أَذْ ثِيڒِي ذ ثَاغَارْصْثْ ن دّنْبْ ؤُ ثنّغْنِي أَذْ ثِيڒِي ذ ثَاغَارْصْثْ ن وشْمَاضْ.  
\v 23 ذڭْ وَاسّْ وِيسّْ ثْمنْيَا أَذْ ثنْ يَاوِي ذِي طّْوعْ ن ؤُسِيزْذڭْ نّسْ غَارْ ؤُكهَّانْ، غَارْ وَاذَافْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ، زَّاثْ إِ وُوذمْ ن سِيذِي.  
\v 24 أَذْ إِكْسِي ؤُكهَّانْ إِزْمَارْ ن ثْغَارْصْثْ ن ؤُمَارْوَاسْ ذ ؤُلُوخْ نِّي ن زّشْثْ ؤُشَا أَكهَّانْ أَذْ ثنْ إِسّنْهزّْ أَمْ ثوْهِيبْثْ ن ونْهزِّي زَّاثْ إِ وُوذمْ ن سِيذِي.  
\v 25 \add خنِّي\add* أَذْ إِغَارْصْ إِ إِزْمَارْ ن ثْغَارْصْثْ ن ؤُمَارْوَاسْ ؤُشَا أَكهَّانْ أَذْ إِكْسِي \add شْوَايْثْ\add* زڭْ إِذَامّنْ ن ثْغَارْصْثْ ن ؤُمَارْوَاسْ، أَذْ ثنْ يَارّْ خْ إِغسْ ن ؤُمزُّوغْ أَفُوسِي ن ونِّي إِتّْوَاسِّيزذْڭنْ ؤُڒَا خْ يِيمزْ ن ؤُفُوسْ نّسْ أَفُوسِي ؤُ خْ يِيمزْ ن ؤُضَارْ نّسْ أَفُوسِي.  
\v 26 أَذْ إِفَارّغْ ؤُكهَّانْ \add شَا\add* ن زّشْثْ خْ ثْڒقَّا ن ؤُفُوسْ أَژڒْمَاضْ ن يِيخفْ نّسْ.  
\v 27 س ؤُضَاضْ نّسْ أَفُوسِي أَذْ إِرُوشّْ ؤُكهَّانْ س زّشْثْ نِّي غَارسْ ذڭْ ؤُفُوسْ نّسْ أَژڒْمَاضْ سبْعَا ن ثْوَاڒَاوِينْ زَّاثْ إِ وُوذمْ ن سِيذِي.  
\v 28 أَكهَّانْ أَذْ إِڭّْ \add شْوَايْثْ\add* زِي زّشْثْ نِّي غَارسْ إِدْجَانْ ذڭْ ؤُفُوسْ نّسْ خْ إِغسْ ن ؤُمزُّوغْ أَفُوسِي ن ونِّي إِتّْوَاسِّيزذْڭنْ ؤُڒَا خْ يِيمزْ ن ؤُفُوسْ نّسْ أَفُوسِي ؤُ خْ يِيمزْ ن ؤُضَارْ نّسْ أَفُوسِي، ذڭْ ومْشَانْ \add نِّيثْ مَانِي\add* تّْوَاڭّنْ إِذَامّنْ ن ثْغَارْصْطْ ن ؤُمَارْوَاسْ \add قْبڒْ\add*.  
\v 29 مِينْ إِقِّيمنْ زِي زّشْثْ نِّي غَارْ ؤُكهَّانْ ذڭْ ؤُفُوسْ نّسْ، أَذْ ث إِڭّْ خْ ؤُزدْجِيفْ ن ونِّي إِتّْوَاسِّيزذْڭنْ، مَاحنْذْ أَذْ خَاسْ إِڭّْ أَصْڒَاحْ زَّاثْ إِ وُوذمْ ن سِيذِي.  
\v 30 \add خنِّي\add* أَذْ إِسّوْجذْ إِجّْ زِي ثْنَاينْ ن ثجْلِيلِّيحِينْ نِيغْ زڭْ إِذْبِيرنْ إِمژْيَاننْ، أَنشْثْ ؤُمِي إِزمَّارْ ؤُفُوسْ نّسْ أَذْ إِسِّيوضْ.  
\v 31 زِي مِينْ ذ أَسْ غَا إِسِّيوضْ ؤُفُوسْ نّسْ، أَذْ يِيڒِي إِجّْ إِ ثْغَارْصْثْ ن دّنْبْ ؤُ ونّغْنِي إِ ثْغَارْصْثْ ن وشْمَاضْ، سنّجْ إِ ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add*. أَكهَّانْ أَذْ إِڭّْ أَصْڒَاحْ خْ ونِّي إِتّْوَاسِّيزذْڭنْ زَّاثْ إِ وُوذمْ ن سِيذِي.  
\v 32 وَا ذ أَزرْفْ إِ ونِّي ذِي إِدْجَا وُوضُونْ ن ڒْبَارْصْ ؤُشَا أَفُوسْ نّسْ وَارْ إِزمَّارْ أَذْ إِسِّيوضْ إِ ؤُسِيزْذڭْ نّسْ.“   
\b  
\m
\v 33 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا ذ هَارُونْ، إِنَّا:   
\m
\v 34 ”خْمِي غَا ثَاذْفمْ غَارْ ثمُّورْثْ ن كنْعَانْ، ثنِّي ذ أَومْ غَا وْشغْ ذ أَڭْڒَا، ؤُشَا مَاڒَا ڭِّيغْ نشّْ ؤُضُونْ ن ڒْبَارْصْ خْ شَا ن ثَادَّارْثْ ن ثمُّورْثْ نِّي غَارْومْ ذ أَڭْڒَا،  
\v 35 أَذْ د-يَاسْ \add خنِّي\add* ونِّي غَارْ ثدْجَا ثَادَّارْثْ نِّي، أَذْ إِخبَّارْ أَكهَّانْ، أَذْ يِينِي: ’إِتّْغِيڒْ أَيِي-د أَخْمِي ذِينْ شَا ن وُوضُونْ ذِي ثَادَّارْثْ.‘  
\v 36 \add خنِّي\add* أَكهَّانْ أَذْ إِسّكّْ، مَاحنْذْ أَذْ سّخْوَانْ ثَادَّارْثْ قْبڒْ إِ د غَا يَاسْ ؤُكهَّانْ \add س يِيخفْ نّسْ\add*، حِيمَا أَذْ إِخمّْ ؤُضُونْ، حِيمَا وَارْ إِتّْوَاسّخْمِيجْ مَارَّا مِينْ إِدْجَانْ ذِي ثَادَّارْثْ. أَوَارْنِي أَسْ أَذْ د-يَاسْ ؤُكهَّانْ، مَاحنْذْ أَذْ إِخمّمْ ثَادَّارْثْ.  
\v 37 مَاڒَا إِخْزَارْ غَارْ ؤُضُونْ ؤُشَا إِژْرَا أَقَا ؤُضُونْ ن ڒحْيُوضْ ن ثَادَّارْثْ بَاننْ-د ذَايسْ إِحُوفَارْ زِّيزْونْ نِيغْ زوْغنْ، ؤُدْجْغنْ خْ \add وُوذمْ ن\add* ڒْحِيضْ،  
\v 38 \add خنِّي\add* أَذْ إِفّغْ ؤُكهَّانْ زِي ثَادَّارْثْ \add نِّي\add* زِي وَاذَافْ ن ثَادَّارْثْ ؤُشَا أَذْ إِقّنْ ثَادَّارْثْ سبْعَا ن وُوسَّانْ.  
\v 39 ذڭْ وَاسّْ وِيسّْ سبْعَا أَذْ د-إِذْوڒْ ؤُكهَّانْ ؤُشَا مَاڒَا إِژْرَا أَقَا ؤُضُونْ إِبزّعْ خْ ڒحْيُوضْ ن ثَادَّارْثْ،  
\v 40 \add خنِّي\add* أَذْ إِوصَّا ؤُكهَّانْ، مَاحنْذْ أَذْ كّْسنْ إِژْرَا مَانِي إِڒْسقْ وُوضُونْ ؤُ أَذْ ثنْ نْضَارنْ ذڭْ إِجّْ ن ومْشَانْ إِخمْجنْ بَارَّا إِ ثنْذِينْثْ.  
\v 41 أَذْ يجّْ أَذْ قشَّارنْ ذَاخڒْ ن ثَادَّارْثْ غَارْ \add مَارَّا\add* إِغزْذِيسنْ نّسْ، ؤُشَا أَذْ زدْجْعنْ أَبدْجَاعْ إِ قشَّارنْ بَارَّا إِ ثنْذِينْثْ ذڭْ إِجّْ ن ومْشَانْ ذ أَمخْمُوجْ.  
\v 42 \add خنِّي\add* أَذْ كْسِينْ إِژْرَا نّغْنِي، أَذْ ثنْ ڭّنْ ذڭْ ومْشَانْ ن إِژْرَا \add نِّي إِهڒْشنْ\add* ؤُشَا أَذْ كْسِينْ أَبدْجَاعْ نّغْنِي مَاحنْذْ أَذْ زَّايسْ حنّْشنْ ثَادَّارْثْ.  
\v 43 مَاڒَا ؤُضُونْ إِذْوڒْ-د ؤُشَا إِسّْفُوفِّي \add عَاوذْ\add* ذِي ثَادَّارْثْ أَوَارْنِي ڒَامِي كّْسنْ إِژْرَا ؤُ قشَّارنْ ثَادَّارْثْ أَوَارْنِي ڒَامِي ت حنّْشنْ،  
\v 44 \add خنِّي\add* أَذْ د-يَاسْ ؤُكهَّانْ أَذْ \add ت\add* إِقدْجبْ. مَاڒَا إِژْرَا، أَقَا ؤُضُونْ إِبزّعْ ذِي ثَادَّارْثْ، \add خنِّي\add* أَقَا ذِينْ إِجّْ ن ڒْبَارْصْ إِقسْحنْ ذِي ثَادَّارْثْ. أَقَا-ت ثخْمجْ.  
\v 45 أَذْ هذْمنْ ثَادَّارْثْ، إِژْرَا نّسْ ذ ثْحنْيَا نّسْ ذ مَارَّا ثَارِّيسْثْ ن ثَادَّارْثْ ؤُشَا أَذْ سِّيڭّْوجنْ أَيَا بَارَّا إِ ثنْذِينْثْ غَارْ إِجّْ ن ومْشَانْ ذ أَمخْمُوجْ.  
\v 46 وِي غَا يَاذْفنْ غَارْ ثَادَّارْثْ ذڭْ إِجّْ ن وَاسّْ زڭْ وُوسَّانْ أَوَارْنِي ڒَامِي بلّْعنْ \add ثَادَّارْثْ\add*، نتَّا أَذْ يِيڒِي إِخْمجْ أَڒْ ثَامذِّيثْ.  
\v 47 وِي غَا إِطّْصنْ ذِي ثَادَّارْثْ، أَذْ إِصبّنْ أَرُّوضْ نّسْ ؤُ وِي غَا إِشّنْ ذِي ثَادَّارْثْ، أَذْ إِسِّيرْذْ أَرُّوضْ نّسْ.  
\v 48 مَاڒَا يُوذفْ ؤُكهَّانْ، مَاحنْذْ أَذْ \add ت\add* إِقدْجبْ ؤُشَا إِژْرَا أَقَا ؤُضُونْ وَارْ إِمْغِيرْ ذِي ثَادَّارْثْ، أَوَارْنِي ڒَامِي حنّْشنْ ثَادَّارْثْ، \add خنِّي\add* أَذْ إِبَارّحْ ؤُكهَّانْ بلِّي ثَادَّارْثْ ثزْذڭْ، مِينْزِي ؤُضُونْ إِتّْوَاسّْڭنْفَا.  
\v 49 أَذْ إِكْسِي ثْنَاينْ ن إِجْضَاضْ ذ ؤُكشُّوضْ ن \add ثْشجَّارْثْ ن\add* ثنْڭلْثْ ذ ؤُزڭّْوَاغْ إِحذْقنْ ذ ثْعلْدْجثْ، مَاحنْذْ أَذْ زَّايْسنْ إِكّسْ دّنْبْ خْ ثَادَّارْثْ. \f ◼ \fr 14:‏49 \ft \+bd ’ثْعلْدْجثْ‘\+bd* - نِيغْ ’هِيسُوبْ‘\f*  
\v 50 أَذْ إِغَارْصْ إِ يِيجّْ ن وجْضِيضْ ذڭْ إِشْثْ ن ڒْقشْعثْ ن ثْڒَاخْثْ، سنّجْ إِ وَامَانْ إِدَّارنْ.  
\v 51 أَذْ إِكْسِي أَكشُّوضْ ن \add ثْشجَّارْثْ ن\add* ثنْڭلْثْ ذ ثْعلْدْجثْ ذ ؤُزڭّْوَاغْ إِحذْقنْ ؤُڒَا ذ أَجْضِيضْ إِدَّارنْ ؤُشَا أَذْ إِسُّوفْ \add مَارَّا\add* أَيَا ذڭْ إِذَامّنْ ن وجْضِيضْ إِتّْوَاغَارْصنْ ؤُ ذڭْ وَامَانْ إِدَّارنْ ؤُشَا أَذْ إِرُوشّْ ثَادَّارْثْ سبْعَا ن ثْوَاڒَاوِينْ.  
\v 52 \add أَمُّو\add* إِ غَا إِكّسْ دّنْبْ خْ ثَادَّارْثْ س إِذَامّنْ ن وجْضِيضْ، س وَامَانْ إِدَّارنْ ذ وجْضِيضْ إِدَّارنْ ذ ؤُكشُّوضْ ن \add ثْشجَّارْثْ ن\add* ثنْڭلْثْ ذ ثْعلْدْجثْ ذ ؤُزڭّْوَاغْ إِحذْقنْ.  
\v 53 أَذْ يجّْ أَجْضِيضْ إِدَّارنْ أَذْ إِضْوَا بَارَّا إِ ثنْذِينْثْ سنّجْ إِ وُوذمْ ن ييَّارْ. \add أَمُّو إِ\add* غَا إِڭّْ أَصْڒَاحْ خْ ثَادَّارْثْ \add نِّي\add* ؤُشَا أَذْ ثِيڒِي ثِيزْذِيڭْ.“   
\m
\v 54 ”وَا ذ أَزرْفْ خْ مَارَّا ڒهْڒَاشَاثْ ن ڒْبَارْصْ ؤُ خْ ثْفُورِي \add ن يِيڒمْ\add*،  
\v 55 خْ ڒْبَارْصْ ن أَرُّوضْ ؤُ ن ثَادَّارْثْ،  
\v 56 خْ إِجّْ ن ؤُعبُّوزْ، خْ إِشْثْ ن ثْحبُّوشْثْ ؤُ خْ إِجّْ ن ونْڭَازْ إِشّمْڒڒْ \add ن ثڒْمشْثْ\add*.  
\v 57 \add أَزرْفْ-أَ\add* أَقَا إِ ثْغُورِي ذڭْ وَاسّْ إِ ذِي غَا يِيڒِي حذْ إِخْمجْ نِيغْ ذڭْ وَاسّْ إِ ذِي غَا يِيڒِي حذْ إِزْذڭْ. وَا ذ أَزرْفْ ن ڒْبَارْصْ.“   
\b  
\b  
\m  
\c 15
\s1 أَسِيزّڒْ زِي أَرِّيمثْ ن يرْيَازنْ ذ ثمْغَارِينْ  
\m
\v 1 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا ذ هَارُونْ، إِنَّا:   
\m
\v 2 ”سِيوڒْ أَكْ-ذ أَيْثْ ن إِسْرَائِيل، إِنِيمْ أَسنْ: \bd ’مَاڒَا أَرْيَازْ غَارسْ إِجّْ ن ؤُسيّڒْ زِي أَرِّيمثْ نّسْ\bd*، \add خنِّي\add* أَذْ يِيڒِي إِخْمجْ زِي سِّيبّثْ ن ؤُسيّڒْ.  
\v 3 وَا أَذْ يِيڒِي ذ ڒخْمجْ نّسْ زِي سِّيبّثْ ن ؤُسيّڒْ نّسْ: \add مَاڒَا\add* أَرِّيمثْ نّسْ ثتّجَّا أَسيّڒْ نّسْ نِيغْ أَرِّيمثْ نّسْ ثسّْبدَّا أَسيّڒْ نّسْ، أَقَا-ث ذ ڒخْمجْ نّسْ.  
\v 4 كُوڒْ قَامَا مِينْ خفْ غَا إِطّصْ ونِّي ذِي إِدْجَا ؤُسيّڒْ، أَذْ يِيڒِي إِخْمجْ ؤُ كُوڒْ ڒْقشْعثْ إِ خفْ غَا إِقِّيمْ، أَذْ ثِيڒِي ثخْمجْ.  
\v 5 مَارَّا وِي غَا إِحَاذَانْ قَامَا نّسْ، أَذْ إِصبّنْ أَرُّوضْ نّسْ، أَذْ إِسِّيرْذْ إِخفْ نّسْ \add عَاوذْ\add* س وَامَانْ ؤُشَا أَذْ يِيڒِي إِخْمجْ أَڒْ ثَامذِّيثْ.  
\v 6 ونِّي إِ غَا إِقِّيمنْ خْ شَا خْ مِينْ خفْ ثُوغَا إِقِّيمْ ونِّي ذِي إِدْجَا ؤُسيّڒْ، أَذْ إِصبّنْ أَرُّوضْ نّسْ، أَذْ إِسِّيرْذْ إِخفْ نّسْ \add عَاوذْ\add* س وَامَانْ ؤُشَا أَذْ يِيڒِي إِخْمجْ أَڒْ ثَامذِّيثْ.  
\v 7 ونِّي إِ غَا إِحَاذَانْ أَرِّيمثْ ن ونِّي ذِي إِدْجَا ؤُسيّڒْ، أَذْ إِصبّنْ أَرُّوضْ نّسْ ؤُشَا نتَّا سِيمَانْثْ نّسْ أَذْ إِسِّيرْذْ س وَامَانْ، ؤُشَا أَذْ يِيڒِي إِخْمجْ أَڒْ ثَامذِّيثْ.  
\v 8 مَاڒَا وِي ذِي إِدْجَا ؤُسيّڒْ إِسُّوسفْ خْ إِجّْ ن ؤُمزْذَاڭْ، أَقَا \add وَا\add* أَذْ إِصبّنْ أَرُّوضْ نّسْ، أَذْ إِسِّيرْذْ إِخفْ نّسْ س وَامَانْ ؤُشَا أَذْ يِيڒِي إِخْمجْ أَڒْ ثَامذِّيثْ.  
\v 9 كُوڒْ ثْرِيشْثْ مِينْ خفْ إِقِّيمْ ونِّي ذِي إِدْجَا ؤُسيّڒْ، أَذْ ثِيڒِي ثخْمجْ.  
\v 10 مَارَّا وِي غَا إِحَاذَانْ \add مَامّشْ مَا\add* ڒْقشْعثْ نِّي إِدْجَانْ سَاذُو نّسْ، أَذْ يِيڒِي إِخْمجْ أَڒْ ثَامذِّيثْ ؤُشَا وِي ت غَا إِكْسِينْ، أَذْ إِصبّنْ أَرُّوضْ نّسْ، أَذْ إِسِّيرْذْ إِخفْ نّسْ س وَامَانْ ؤُشَا أَذْ يِيڒِي إِخْمجْ أَڒْ ثَامذِّيثْ.  
\v 11 مَارَّا وِي غَا إِتّْوَاحَاذَانْ زڭْ ونِّي ذِي إِدْجَا ؤُسيّڒْ بْڒَا مَا أَذْ إِسِّيرْذْ وَا إِفَاسّنْ نّسْ \add أَمزْوَارُو\add*، أَذْ إِصبّنْ أَرُّوضْ نّسْ، أَذْ إِسِّيرْذْ إِخفْ نّسْ س وَامَانْ ؤُشَا أَذْ يِيڒِي إِخْمجْ أَڒْ ثَامذِّيثْ.  
\v 12 طّبْصِي ن ثْڒَاخْثْ نِّي إِحَاذَا ونِّي ذِي إِدْجَا ؤُسيّڒْ، إِتّْخصَّا أَذْ إِتّْوَارْژْ، \add مَاشَا\add* مَارَّا ڒْقشْعثْ ن ثفْڒَاوْثْ أَذْ ت سِيرْذنْ س وَامَانْ. \x ◘ \xo 15:‏12 \xt لَاوِي 6‏:‏21؛ 11‏:‏33\x*   
\m
\v 13 خْمِي ونِّي ذِي إِدْجَا ؤُسيّڒْ أَذْ إِتّْوَاسِّيزْذڭْ زڭْ ؤُسيّڒْ نّسْ، إِتّْخصَّا أَسْ سِيمَانْثْ نّسْ أَذْ إِحْسبْ إِ سبْعَا ن وُوسَّانْ. \add خنِّي\add* أَذْ إِصبّنْ أَرُّوضْ نّسْ، أَذْ إِسِّيرْذْ أَرِّيمثْ نّسْ س وَامَانْ إِدَّارنْ ؤُشَا أَذْ يِيڒِي إِزْذِيڭْ.  
\v 14 ذڭْ وَاسّْ وِيسّْ ثْمنْيَا أَذْ إِكْسِي ثْنَاينْ ن ثجْلِيلِّيحِينْ نِيغْ ثْنَاينْ ن إِذْبِيرنْ إِمژْيَاننْ ؤُشَا أَذْ د-يَاسْ زَّاثْ إِ وُوذمْ ن سِيذِي غَارْ وَاذَافْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ ؤُشَا أَذْ ثنْ إِوْشْ إِ ؤُكهَّانْ.  
\v 15 أَكهَّانْ أَذْ إِسّوْجذْ إِشْثْ ن ثْغَارْصْثْ ن دّنْبْ ذ إِشْثْ ن ثْغَارْصْثْ ن وشْمَاضْ. أَكهَّانْ أَذْ خَاسْ إِڭّْ أَصْڒَاحْ زَّاثْ إِ وُوذمْ ن سِيذِي خْ ؤُسيّڒْ نّسْ.‘ “\f ◼ \fr 15:‏15 \ft \+bd ’إِفْذِي‘\+bd* - خْزَارْ إِزهد. 78:35.\f*   
\m
\v 16 ”\bd مَاڒَا إِفّغْ-د ؤُسيّڒْ ن وَادْجُو زڭْ ورْيَازْ\bd*، أَذْ إِسِّيرْذْ أَرِّيمثْ نّسْ مَارَّا س وَامَانْ ؤُشَا أَذْ يِيڒِي إِخْمجْ أَڒْ ثَامذِّيثْ.  
\v 17 كُوڒْ أَرُّوضْ ذ كُوڒْ إِڒمْ إِ خفْ إِدْجَا ؤُسيّڒْ ن وَادْجُو، إِتّْخصَّا أَذْ ث سِيرْذنْ س وَامَانْ ؤُشَا أَذْ يِيڒِي إِخْمجْ أَڒْ ثَامذِّيثْ.  
\v 18 \add مَاڒَا\add* إِطّصْ يِيجّْ ورْيَازْ أَكْ-ذ ثمْغَارْثْ ؤُشَا إِنْضَارْ \add ذَايسْ\add* نتَّا، \add خنِّي\add* أَذْ سِّيرْذنْ \add س ثْنَاينْ إِذْسنْ\add* س وَامَانْ ؤُشَا أَذْ إِڒِينْ خمْجنْ أَڒْ ثَامذِّيثْ.“   
\b  
\m
\v 19 ”\bd مَاڒَا ثَامْغَارْثْ ثُوغَا-ت ثْسيّڒْ\bd*، أَقَا خَاسْ إِذَامّنْ ذِي أَرِّيمثْ نّسْ، \add خنِّي\add* أَذْ ثعْزڒْ سبْعَا ن وُوسَّانْ. مَارَّا وِي ت غَا إِحَاذَانْ أَذْ يِيڒِي إِخْمجْ أَڒْ ثَامذِّيثْ. \f ◼ \fr 15:‏19 \ft \+bd ’ثعْزڒْ‘\+bd* - س ثْعِيبْرَانِيثْ ’أَذْ ثِيڒِي ذِي وعْزَاڒْ نّسْ‘.\f*  
\v 20 مَارَّا مِينْ خفْ ثُوغَا ثطّصْ ذڭْ وعْزَاڒْ نّسْ، أَذْ يِيڒِي إِخْمجْ ؤُشَا مَارَّا مِينْ خفْ ثُوغَا ثقِّيمْ، أَذْ يِيڒِي إِخْمجْ.  
\v 21 مَارَّا وِي غَا إِحَاذَانْ قَامَا نّسْ، أَذْ إِسِّيرْذْ أَرُّوضْ نّسْ، أَذْ إِسِّيرْذْ إِخفْ نّسْ س وَامَانْ ؤُشَا أَذْ يِيڒِي إِخْمجْ أَڒْ ثَامذِّيثْ.  
\v 22 مَارَّا وِي غَا إِحَاذَانْ شَا ن ڒْقشْعثْ مِينْ خفْ ثُوغَا ثتّْغِيمَا، أَذْ إِصبّنْ أَرُّوضْ نّسْ، أَذْ إِسِّيرْذْ إِخفْ نّسْ س وَامَانْ ؤُشَا أَذْ يِيڒِي إِخْمجْ أَڒْ ثَامذِّيثْ.  
\v 23 نِيغْ مَاڒَا إِقِّيمْ خْ قَامَا نِيغْ خْ ڒْقشْعثْ إِ خفْ ثُوغَا ثقِّيمْ نتَّاثْ، ؤُمِي إِحَاذَا أَيَا أَذْ يِيڒِي إِخْمجْ أَڒْ ثَامذِّيثْ.  
\v 24 مَاڒَا إِطّصْ أَكِيذسْ إِجّْ ن ورْيَازْ ؤُشَا يُوسَا-د خَاسْ وعْزَاڒْ نّسْ، \add خنِّي\add* أَذْ يِيڒِي إِخْمجْ سبْعَا ن وُوسَّانْ. كُوڒْ قَامَا إِ خْ ثُوغَا إِطّصْ، أَذْ ثِيڒِي ثخْمجْ.   
\m
\v 25 مَاڒَا ؤُسِينْ-د إِذَامّنْ خْ إِشْثْ ن ثمْغَارْثْ أَطَّاسْ ن وُوسَّانْ بَارَّا إِ ڒْمِيجَاڒْ ن وعْزَاڒْ نّسْ نِيغْ مَاڒَا ثُوغَا أَسيّڒْ كْثَارْ خْ ڒْمِيجَاڒْ ن وعْزَاڒْ نّسْ، \add خنِّي\add* أَذْ ثِيڒِي ثخْمجْ مَارَّا ؤُسَّانْ ن ؤُسيّڒْ إِ د-يُوسِينْ أَكْ-ذ ڒخْمجْ نّسْ، أَمْ ذڭْ وُوسَّانْ ن وعْزَاڒْ نّسْ. \x ◘ \xo 15:‏25 \xt مت. 9‏:‏20\x*  
\v 26 كُوڒْ قَامَا مِينْ خفْ ثطّصْ مَارَّا ؤُسَّانْ ن ؤُسيّڒْ نّسْ، أَذْ أَسْ ثِيڒِي أَمْ قَامَا ن وعْزَاڒْ نّسْ ؤُ مَارَّا ڒْقشْعثْ مِينْ خفْ ثقِّيمْ، أَذْ ثِيڒِي ثخْمجْ أَمشْنَاوْ ڒخْمجْ ن وعْزَاڒْ نّسْ.  
\v 27 مَارَّا وِي غَا إِحَاذَانْ ثِيمسْڒَايِينْ نِّي، أَذْ يِيڒِي إِخْمجْ. أَذْ إِصبّنْ أَرُّوضْ نّسْ ؤُشَا أَذْ إِسِّيرْذْ إِخفْ نّسْ س وَامَانْ ؤُشَا أَذْ يِيڒِي إِخْمجْ أَڒْ ثَامذِّيثْ.  
\v 28 مَاڒَا ثتّْوَاسِّيزْذڭْ زڭْ ؤُسيّڒْ نّسْ، إِتّْخصَّا أَذْ ثحْسبْ إِ يِيخفْ نّسْ سبْعَا ن وُوسَّانْ، أَوَارْنِي أَسْ أَذْ ثِيڒِي ثزْذڭْ.  
\v 29 ذڭْ وَاسّْ وِيسّْ ثْمنْيَا أَذْ ثكْسِي إِ يِيخفْ نّسْ ثْنَاينْ ن ثجْلِيلِّيحِينْ نِيغْ ثْنَاينْ ن إِذْبِيرنْ إِمژْيَاننْ ؤُشَا أَذْ ثنْ ثَاوِي غَارْ ؤُكهَّانْ غَارْ وَاذَافْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ.  
\v 30 أَكهَّانْ أَذْ إِسّوْجذْ إِشْثْ ن ثْغَارْصْثْ ن دّنْبْ ذ إِشْثْ ن ثْغَارْصْثْ ن وشْمَاضْ ؤُشَا أَكهَّانْ أَذْ خَاسْ إِڭّْ أَصْڒَاحْ \add ذِي ثْمسْڒَاشْثْ\add* ن ؤُسيّڒْ ن ڒخْمجْ نّسْ زَّاثْ إِ وُوذمْ ن سِيذِي.   
\m
\v 31 \add أَمُّو\add* إِ غَا ثْعزْڒذْ أَيْثْ ن إِسْرَائِيل خْ ڒخْمجْ نْسنْ، حِيمَا وَارْ تّمتِّينْ ذِي ڒخْمجْ نْسنْ، ؤُمِي سّْخمَّاجنْ ثَازذِّيغْثْ إِنُو نِّي \add إِدْجَانْ\add* ذِي ڒْوسْطْ نْسنْ.“   
\m
\v 32 وَا ذ أَزرْفْ إِ ونِّي غَارْ إِدْجَا ؤُسيّڒْ ؤُ إِ ونِّي زِي غَا إِفّغْ وَادْجُو نّسْ ؤُشَا \add خنِّي\add* أَذْ يِيڒِي إِخْمجْ  
\v 33 ؤُ \add عَاوذْ\add* إِ ثنِّي مِينْ خفْ إِدْجَا إِذَامّنْ ؤُشَا \add خنِّي\add* ثعْزڒْ إِخفْ نّسْ ؤُ \add عَاوذْ\add* إِ وِي ذِي ثُوغَا أَسيّڒْ، إِ ورْيَازْ ؤُڒَا إِ ثمْغَارْثْ، ؤُ \add عَاوذْ\add* إِ ورْيَازْ إِ ثُوغَا إِطّْصنْ أَكْ-ذ ثنِّي إِدْجَانْ ثخْمجْ.   
\b  
\b  
\m  
\c 16
\s1 أَسّْ ن وصْڒَاحْ  
\m
\v 1 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا أَوَارْنِي إِ ڒْموْثْ ن ثْنَاينْ ن وَارَّاوْ ن هَارُونْ، أَوَارْنِي ڒَامِي د-قَارّْبنْ نِيثْنِي زَّاثْ إِ وُوذمْ ن سِيذِي ؤُشَا مُّوثنْ. \x ◘ \xo 16:‏1 \xt لَاوِي 10‏:‏1، 2\x*  
\v 2 سِيذِي إِنَّا إِ مُوسَا: ”سِيوڒْ أَكْ-ذ هَارُونْ، ؤُمَاشْ، حِيمَا وَارْ إِتِّيذفْ ڒبْذَا غَارْ ؤُقدَّاسْ ذَاخڒْ إِ ؤُڒحَّافْ زَّاثْ إِ ثْقبَّارْثْ ن وصْڒَاحْ نِّي إِدْجَانْ خْ تَّابُوثْ، حِيمَا وَارْ إِتّْمتِّي شَا، مِينْزِي نشّْ تّْبَانغْ-د ذڭْ إِجّْ ن ؤُسيْنُو سنّجْ إِ ثْقبَّارْثْ ن وصْڒَاحْ. \x ◘ \xo 16:‏2 \xt ؤُف. 30‏:‏10؛ عبر. 9‏:‏7\x*  
\v 3 س ؤُيَا أَذْ يَاذفْ هَارُونْ غَارْ ؤُقدَّاسْ: س إِجّْ ن ؤُفُونَاسْ، أَمژْيَانْ ن ثْفُونَاسْثْ، إِ ثْغَارْصْثْ ن دّنْبْ، ؤُ \add س\add* يِيجّْ ن إِشَارِّي إِ ثْغَارْصْثْ ن وشْمَاضْ.  
\v 4 أَذْ يَارْضْ ثْشَامِيرْ إِقدّْسنْ ن ڒقْطنْ ؤُشَا سَّارْوَاڒْ نْ ڒقْطنْ أَذْ يِيڒِي خْ أَرِّيمثْ نّسْ. أَذْ إِبْيسْ ثَاحزَّامْثْ ن ڒقْطنْ ؤُشَا أَذْ يَاركّبْ أَرژّثْ ن ڒقْطنْ. أَقَا مَانْ أَيَا ذ أَرُّوضْ إِقدّْسنْ. مَاڒَا أَذْ ثنْ يَارْضْ، إِتّْخصَّا أَسْ أَذْ إِسِّيرْذْ أَرِّيمثْ نّسْ س وَامَانْ ذ أَمزْوَارُو.  
\v 5 أَذْ إِكْسِي زِي ثْمسْمُونْثْ ن أَيْثْ ن إِسْرَائِيل ثْنَاينْ ن إِمْيَاننْ زڭْ إِغَايْضنْ إِ ثْغَارْصْثْ ن دّنْبْ ذ إِجّْ ن إِشَارِّي إِ ثْغَارْصْثْ ن وشْمَاضْ.  
\v 6 أَذْ د-إِسّْقَارّبْ هَارُونْ أَفُونَاسْ أَمژْيَانْ ن ثْغَارْصْثْ ن وشْمَاضْ، ونِّي إِدْجَانْ إِ يِيخفْ نّسْ، ؤُشَا أَذْ إِڭّْ أَصْڒَاحْ إِ يِيخفْ نّسْ ؤُ إِ ثَادَّارْثْ نّسْ. \f ◼ \fr 16:‏6 \ft \+bd ’إِفْذِي‘\+bd* - خْزَارْ إِزهد. 78:35.\f*  \x ◘ \xo 16:‏6 \xt عبر. 7‏:‏27، 28\x*  
\v 7 أَذْ إِكْسِي ثْنَاينْ ن إِمْيَاننْ ؤُشَا أَذْ ثنْ إِڭّْ زَّاثْ إِ وُوذمْ ن سِيذِي غَارْ وَاذَافْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ.  
\v 8 أَذْ إِنْضَارْ هَارُونْ ثَاقدُّوحْثْ خْ ثْنَاينْ ن إِمْيَاننْ: إِشْثْ ن ثْقدُّوحْثْ خْ سِيذِي ؤُ إِشْثْ ن ثْقدُّوحْثْ خْ إِغَايْضْ إِنُّوفْسْڒنْ، \add قَّارنْ أَسْ ’عَازَازِيلْ‘\add*.  
\v 9 أَذْ د-إِسّْقَارّبْ هَارُونْ أَمْيَانْ نِّي خْ د-ثوْضَا ثَاقدُّوحْثْ إِ سِيذِي ؤُشَا أَذْ ث إِسّوْجذْ ذ ثْغَارْصْثْ ن دّنْبْ.  
\v 10 أَمْيَانْ إِ خْ د-ثوْضَا ثَاقدُّوحْثْ ن إِغَايْضْ إِنُّوفْسْڒنْ، أَذْ ث إِڭّْ إِدَّارْ زَّاثْ إِ وُوذمْ ن سِيذِي، مَاحنْذْ أَذْ زَّايسْ إِڭّْ أَصْڒَاحْ ؤُشَا \add خنِّي\add* أَذْ ث إِسّكّْ أَمْ يِيغَايْضْ إِنُّوفْسْڒنْ غَارْ ڒخْڒَا.   
\m
\v 11 أَذْ د-إِسّْقَارّبْ هَارُونْ أَفُونَاسْ أَمژْيَانْ ن ثْغَارْصْثْ ن دّنْبْ، ونِّي ثُوغَا إِ يِيخفْ نّسْ، ؤُشَا أَذْ إِڭّْ أَصْڒَاحْ إِ يِيخفْ نّسْ ؤُ إِ \add أَيْثْبَابْ ن\add* ثَادَّارْثْ نّسْ ؤُشَا أَذْ إِغَارْصْ إِ ؤُفُونَاسْ أَمژْيَانْ ن ثْغَارْصْثْ ن دّنْبْ، ونِّي \add إِدْجَانْ\add* إِ يِيخفْ نّسْ.  
\v 12 أَذْ إِكْسِي \add عَاوذْ\add* إِجّْ ن ڒْمجْمَارْ إِشُّورْ س ڒفْحمْ إِتّحْذُوذُوقنْ ن ؤُعَالْطَارْ زَّاثْ إِ وُوذمْ ن سِيذِي ؤُشَا أَذْ إِشُّورْ ثْنَاينْ ن إِفَاسّنْ نّسْ س ڒبْخُورْ أَزْذَاذْ إِتّْفُوحنْ، ؤُشَا أَذْ يَاوِي مَارَّا أَيَا ذَاخڒْ إِ ؤُڒحَّافْ.  
\v 13 أَذْ إِڭّْ ڒبْخُورْ خْ ثْمسِّي زَّاثْ إِ وُوذمْ ن سِيذِي، حِيمَا أَسيْنُو \add ن ڒفْوَارْ\add* ن ڒبْخُورْ أَذْ إِذڒْ ثَاقبَّارْثْ ن وصْڒَاحْ إِ إِدْجَانْ خْ شّْهَاذثْ، ؤُشَا وَارْ إِتّْمتِّي شَا.  
\v 14 أَذْ إِكْسِي \add شْوَايْثْ\add* زڭْ إِذَامّنْ ن ؤُفُونَاسْ أَمژْيَانْ ؤُشَا أَذْ ثنْ إِرُوشّْ س ؤُضَاضْ نّسْ خْ وُوذمْ ن ثْقبَّارْثْ ن وصْڒَاحْ غَارْ ؤُغزْذِيسْ ن شَّارْقْ ؤُشَا \add عَاوذْ\add* أَذْ إِرُوشّْ \add شْوَايْثْ\add* زڭْ إِذَامّنْ سبْعَا ن ثْوَاڒَاوِينْ س ؤُضَاضْ نّسْ زَّاثْ إِ ثْقبَّارْثْ ن وصْڒَاحْ. \x ◘ \xo 16:‏14 \xt لَاوِي 4‏:‏6؛ عبر. 9‏:‏25؛ 10‏:‏4\x*  
\v 15 \add خنِّي\add* أَذْ إِغَارْصْ إِ ؤُمْيَانْ ن ثْغَارْصْثْ ن دّنْبْ، ونِّي \add إِدْجَانْ\add* إِ ڒْڭنْسْ ؤُشَا أَذْ يَاوِي إِذَامّنْ غَارْ ذَاخڒْ إِ ؤُڒحَّافْ ؤُشَا أَذْ إِڭّْ س إِذَامّنْ نّسْ أَمْ مَامّشْ إِڭَّا س إِذَامّنْ ن ؤُفُونَاسْ أَمژْيَانْ: أَذْ ثنْ إِرُوشّْ خْ ثْقبَّارْثْ ن وصْڒَاحْ ؤُ زَّاثْ إِ ثْقبَّارْثْ ن وصْڒَاحْ.  
\v 16 \add أَمُّو إِ\add* إِ غَا إِڭّْ أَصْڒَاحْ خْ ؤُقدَّاسْ إِ ڒْحَاجَّاثْ إِخمْجنْ ن أَيْثْ ن إِسْرَائِيل ؤُ إِ إِخطَّانْ نْسنْ إِ د-إِتَّاسنْ أَكْ-ذ مَارَّا دّْنُوبْ نْسنْ. أَمُّو إِ غَا يڭّْ ذِي سِّيبّثْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ، ونِّي إِدْجَانْ أَكِيذْسنْ ذِي ڒْوسْطْ ن مَارَّا ثِيمسْڒَايِينْ إِخمْجنْ نْسنْ.   
\m
\v 17 ؤُڒَا ذ إِجّْ ن بْنَاذمْ أَذْ يِيڒِي عَاذْ ذڭْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ زڭْ وَامِي إِ غَا يَاذفْ مَاحنْذْ أَذْ إِڭّْ أَصْڒَاحْ ذڭْ ؤُقدَّاسْ أَڒْ غَا إِفّغْ \add عَاوذْ\add*. \add أَمُّو\add* إِ غَا إِڭّْ أَصْڒَاحْ إِ يِيخفْ نّسْ ؤُ إِ مَارَّا أَڭْرَاوْ \add ن ڒْڭنْسْ\add* ن إِسْرَائِيل.  
\v 18 أَذْ إِفّغْ أَڒْ ؤُعَالْطَارْ إِ إِدْجَانْ زَّاثْ إِ وُوذمْ ن سِيذِي ؤُشَا أَذْ إِڭّْ أَسْڒَاحْ خْ ؤُعَالْطَارْ. أَذْ إِكْسِي \add شْوَايْثْ\add* زڭْ إِذَامّنْ ن ؤُفُونَاسْ أَمژْيَانْ ؤُ \add شْوَايْثْ\add* زڭْ إِذَامّنْ ن ؤُمْيَانْ ؤُشَا أَذْ إِسَّارْسْ \add أَيَا\add* خْ وَاشَّاونْ ن ؤُعَالْطَارْ ذڭْ ونّضْ نّسْ.  
\v 19 سبْعَا ن ثْوَاڒَاوِينْ أَذْ خَاسْ إِرُوشّْ س ؤُضَاضْ نّسْ \add شْوَايْثْ\add* زڭْ إِذَامّنْ ؤُشَا أَذْ ث إِسِّيزْذڭْ ؤُ أَذْ ث إِسّْقدّسْ زِي ڒخْمجْ ن أَيْثْ ن إِسْرَائِيل.  
\v 20 \add أَوَارْنِي ڒَامِي\add* إِكمّڒْ أَصْڒَاحْ ن ؤُقدَّاسْ ذ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ ذ ؤُعَالْطَارْ، أَذْ د-إِسّْقَارّبْ \add خنِّي\add* أَمْيَانْ إِدَّارنْ.  
\v 21 أَذْ إِسَّارْسْ هَارُونْ ثْنَاينْ ن إِفَاسّنْ نّسْ خْ ؤُزدْجِيفْ ن ؤُمْيَانْ إِدَّارنْ ؤُشَا \add أَمُّو إِ\add* غَا إِنْعمْ هَارُونْ سنّجْ \add إِ ؤُزدْجِيفْ ن ؤُمْيَانْ\add* خْ مَارَّا ڒْمُوعْصِييّثْ ن أَيْثْ ن إِسْرَائِيل ذ مَارَّا إِخطَّانْ نْسنْ إِ د-يُوسِينْ أَكْ-ذ مَارَّا دّْنُوبْ نْسنْ ؤُشَا أَذْ ثنْ إِسَّارْسْ خْ ؤُزدْجِيفْ ن ؤُمْيَانْ ؤُشَا أَذْ ث إِسّكّْ غَارْ ڒخْڒَا س ؤُفُوسْ ن إِجّْ ن ورْيَازْ \add ونِّي إِسّْوجْذنْ\add* إِ دّڭَّا.  
\v 22 ؤُشَا إِغَايْضْ أَذْ يَاوِي أَكْ-ذ إِخفْ نّسْ مَارَّا ڒْمُوعْصِييّثْ نْسنْ غَارْ إِشْثْ ن جِّيهثْ ثخْڒَا. نتَّا أَذْ إِسّكّْ أَمْيَانْ غَارْ ڒخْڒَا.   
\m
\v 23 \add خنِّي\add* أَذْ يَاذفْ هَارُونْ غَارْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ ؤُشَا أَذْ إِكّسْ أَرُّوضْ ن ڒقْطنْ نِّي يَارْضْ، ؤُمِي يُوذفْ غَارْ ؤُقدَّاسْ ؤُشَا أَذْ ث يجّْ ذِينْ.  
\v 24 أَذْ إِسِّيرْذْ أَرِّيمثْ نّسْ س وَامَانْ ذڭْ ومْشَانْ أَمْقدَّاسْ ؤُشَا أَذْ يَارْضْ أَرُّوضْ نّسْ. \add خنِّي\add* أَذْ إِفّغْ، أَذْ إِسّوْجذْ ثَاغَارْصْثْ ن وشْمَاضْ نّسْ ذ ثْغَارْصْثْ ن ڒْڭنْسْ ؤُشَا أَذْ إِڭّْ أَصْڒَاحْ إِ يِيخفْ نّسْ ؤُ إِ ڒْڭنْسْ.  
\v 25 أَذْ إِسّْبخَّارْ ثَاذُونْثْ ن ثْغَارْصْثْ نْ دّنْبْ خْ ؤُعَالْطَارْ.   
\m
\v 26 وِي د-إِسكّنْ أَمْيَانْ أَمْ ؤُمْيَانْ إِنُّوفْسْڒنْ، أَذْ إِصبّنْ أَرُّوضْ نّسْ، أَذْ إِسِّيرْذْ أَرِّيمثْ نّسْ س وَامَانْ. أَوَارْنِي أَسْ أَذْ يَاذفْ غَارْ ڒْمَارْڭحْ ن ڒْعسْكَارْ.   
\m
\v 27 أَفُونَاسْ أَمژْيَانْ ن ثْغَارْصْثْ ن دّنْبْ ذ ؤُمْيَانْ ن طْغَارْصْثْ ن دّنْبْ إِ زِي تّْوَاسِّيذْفنْ إِذَامّنْ نْسنْ، مَاحنْذْ أَذْ زَّايْسنْ إِتّْوَاڭّْ أَصْڒَاحْ ذڭْ ؤُقدَّاسْ، أَذْ ثنْ سُّوفّْغنْ بَارَّا إِ ڒْمَارْڭحْ ن ڒْعسْكَارْ ؤُشَا أَذْ زَّايْسنْ سّْشمْضنْ إِڒْمَاونْ نْسنْ ذ ويْسُومْ نْسنْ ذ ؤُمسَّاڒْ نْسنْ س ثْمسِّي. \x ◘ \xo 16:‏27 \xt لَاوِي 6‏:‏23؛ عبر. 13‏:‏11\x*  
\v 28 وِي ثنْ غَا إِسّْشمْضنْ، أَذْ إِصبّنْ أَرُّوضْ نّسْ، أَذْ إِسِّيرْذْ أَرِّيمثْ نّسْ س وَامَانْ. أَوَارْنِي أَسْ أَذْ يَاذفْ غَارْ ڒْمَارْڭحْ ن ڒْعسْكَارْ.   
\m
\v 29 ثَا ذ إِشْثْ ن ثوْصيّثْ إِ ڒبْذَا إِ كنِّيوْ. ذڭْ ؤُيُورْ وِيسّْ سبْعَا، ذڭْ \add وَاسّْ\add* وِيسّْعشْرَا ن ؤُيُورْ، أَذْ ثسّْوَاضْعمْ إِخفْ نْومْ ؤُشَا وَارْ تّڭّمْ ؤُڒَا ذ إِشْثْ ن ڒْخذْمثْ، نِيغْ ونِّي د-إِخڒْقنْ ذِي ثمُّورْثْ نِيغْ ؤُبَارَّانِي نِّي إِزدّْغنْ ذِي ڒْوسْثْ نْومْ. \x ◘ \xo 16:‏29 \xt لَاوِي 23‏:‏27\x*  
\v 30 مِينْزِي ذڭْ وَاسّْ نِّي أَذْ إِتّْوَاڭّْ وصْڒَاحْ إِ كنِّيوْ، مَاحنْذْ أَذْ ثتّْوَاسِّيزذْڭمْ. كنِّيوْ مَارَّا أَذْ ثتّْوَاسِّيزذْڭمْ زَّاثْ إِ وُوذمْ ن سِيذِي.  
\v 31 \add أَسّْ نِّي\add* أَذْ يِيڒِي ذ إِجّْ وَاسّْ ن سّبْثْ، أَرَّاحثْ ثْمُونْ إِ كنِّيوْ. أَذْ ثسّْوَاضْعمْ إِخفْ نْومْ، أَقَا-ت ذ إِشْثْ ن ثوْصيّثْ إِ ڒبْذَا.  
\v 32 أَكهَّانْ، ونِّي ذهْننْ ؤُ ڒقّْمنْ نِيثْنِي ذڭْ ومْشَانْ ن بَابَاسْ، مَاحنْذْ أَذْ يِيڒِي ذ أَكهَّانْ، أَذْ إِڭّْ أَصْڒَاحْ ؤُشَا أَذْ يَارْضْ أَرُّوضْ ن ڒقْطنْ، أَرُّوضْ إِقدّْسنْ.  
\v 33 أَذْ إِڭّْ أَصْڒَاحْ خْ زَّاوشْثْ إِقدّْسنْ ؤُ خْ ثْقِيضُونْثْ ن ؤُمْسَاڭَارْ ؤُ خْ ؤُعَالْطَارْ. أَذْ إِڭّْ أَصْڒَاحْ \add عَاوذْ\add* خْ مَارَّا إِكهَّاننْ ؤُ خْ مَارَّا ڒْڭنْسْ ن وڭْرَاوْ.  
\v 34 ثَا ذ إِشْثْ ن ثوْصيّثْ إِ ڒبْذَا إِ كنِّيوْ، حِيمَا أَذْ إِتّْوَاڭّْ وصْڒَاحْ خْ مَارَّا أَيْثْ ن إِسْرَائِيل إِ مَارَّا دّْنُوبْ نْسنْ، إِشْثْ ن ثْوَاڒَا ذڭْ ؤُسڭّْوَاسْ.“ ؤُشَا إِڭَّا أَمْ مَامّشْ إِوصَّا سِيذِي إِ مُوسَا. \x ◘ \xo 16:‏34 \xt ؤُف. 30‏:‏10؛ عبر. 9‏:‏7\x*   
\b  
\b  
\m  
\c 17
\s1 إِتّْخصَّا أَذْ أَوْينْ ثِيغَارْصَا ذ ثْغَارْصَا ن وشْمَاضْ غَارْ وَاذَافْ ن ؤُقِيضُونْ  
\m
\v 1 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 2 ”سِيوڒْ أَكْ-ذ هَارُونْ ذ وَارَّاوْ نّسْ ؤُ أَكْ-ذ مَارَّا أَيْثْ ن إِسْرَائِيل، إِنِي أَسنْ: ’وَا ذ أَوَاڒْ إِ إِوصَّا سِيذِي، إِقَّارْ:  
\v 3 كُوڒْ أَرْيَازْ زِي ثَادَّارْثْ ن إِسْرَائِيل، ونِّي إِغَارْصنْ إِ ؤُفُونَاسْ نِيغْ إِ يزْمَارْ نِيغْ إِ إِغَايْضْ ذِي ڒْمَارْڭحْ نِيغْ ونِّي \add ث\add* إِغَارْصنْ بَارَّا إِ ڒْمَارْڭحْ،  
\v 4 \add مَاشَا\add* وَارْ ث يِيوِي ذ ثَاوْهِيبْثْ غَارْ وَاذَافْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ، مَاحنْذْ أَذْ ث-إِ-د-إِسّْقَارّبْ ذ ثَاوْهِيبْثْ غَارْ سِيذِي زَّاثْ ن ثْزذِّيغْثْ ن سِيذِي، أَذْ أَسْ د-إِتّْوَاحْسبْ إِذَامّنْ \add نِّي\add*. نتَّا إِسِّيزّڒْ إِذَامّنْ، \add س ؤُينِّي\add* أَذْ إِتّْوَاقسْ ورْيَازْ نِّي زِي ڒْڭنْسْ نّسْ،  
\v 5 مَاحنْذْ، خْمِي غَا قدّْمنْ أَيْثْ ن إِسْرَائِيل ثِيغَارْصَا نْسنْ، ثِينِّي \add نُّومنْ\add* غَارّْصنْ بَارَّا ذڭْ إِيَّارْ، نِيثْنِي أَذْ ثنْثْ أَوْينْ غَارْ سِيذِي، غَارْ ؤُكهَّانْ غَارْ وَاذَافْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ، مَاحنْذْ أَذْ ثنْثْ قدّْمنْ \add ذِينْ أَمْ\add* ثْغَارْصَا ن ڒهْنَا إِ سِيذِي.  
\v 6 أَكهَّانْ أَذْ إِزدْجعْ إِذَامّنْ خْ ؤُعَالْطَارْ ن سِيذِي غَارْ وَاذَافْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ ؤُ نتَّا أَذْ إِسّْبخَّارْ ثَاذُونْثْ أَمْ يِيشْثْ ن ڒفْوَاحثْ إِتّْفُوحنْ إِ سِيذِي. \x ◘ \xo 17:‏6 \xt ؤُف. 29‏:‏18؛ لَاوِي 4‏:‏31\x*  
\v 7 وَارْ تّْقدَّامنْ عَاذْ ثِيغَارْصَا نْسنْ إِ إِمُويَانْ \add إِجنِّينْ\add*، إِنِّي ضفَّارنْ نِيثْنِي أَمْ أَيْثْ ن فَارْقْ-شّْغڒْ. ثَا ذ إِشْثْ ن ثوْصيّثْ إِ ڒبْذَا إِ نِيثْنِي إِ \add مَارَّا\add* جِّيڒَاثْ نْسنْ.‘  
\v 8 أَذْ أَسنْ ثِينِيذْ عَاوذْ: ’كُوڒْ أَرْيَازْ ن أَيْثْ ن إِسْرَائِيل ؤُ ن إِبَارَّانِييّنْ، إِنِّي إِدْجَانْ ذِي ڒْوسْطْ نْسنْ، ونِّي إِخْسنْ أَذْ إِسّْبخَّارْ إِشْثْ ن ثْغَارْصْثْ ن وشْمَاضْ نِيغْ شَا ن طَاغَارْصْثْ \add إِ غَارسْ\add*،  
\v 9 \add مَاشَا\add* وَارْ ت-إِ-د-يِيوِي غَارْ وَاذَافْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ، حِيمَا أَذْ ت إِسّوْجذْ إِ سِيذِي، أَرْيَازْ نِّي أَذْ إِتّْوَاقسّْ زِي ڒْڭنْسْ نّسْ.‘ “   
\b  
\m  
\s1 ثَاوْصيّثْ حِيمَا وَارْ تّتّنْ إِذَامّنْ  
\m
\v 10 ”كُوڒْ إِجّْ زِي ثَادَّارْثْ ن إِسْرَائِيل نِيغْ زڭْ إِبَارَّانِييّنْ، إِنِّي إِزدّْغنْ ذِي ڒْوسْطْ نْسنْ، ونِّي إِ غَا إِشّنْ إِذَامّنْ مَامّشْ مَا ڭِّينْ، نشّْ أَذْ قڒْبغْ ؤُذمْ إِنُو خْ ڒعْمَارْ نِّي إِشّنْ إِذَامّنْ نِّي، ؤُشَا أَذْ ث قضْعغْ زِي ڒْوسْطْ نْ ڒْڭنْسْ نّسْ. \x ◘ \xo 17:‏10 \xt أَمز. 9‏:‏4؛ لَاوِي 3‏:‏17؛ 7‏:‏27؛ 19‏:‏26؛ أَعَوذ. 12‏:‏16، 23؛ 1 صم. 14‏:‏33\x*  
\v 11 مِينْزِي ڒعْمَارْ ن أَرِّيمثْ ذڭْ إِذَامّنْ ؤُشَا نشّْ وْشِيغْ أَومْ \add إِذَامّنْ\add* خْ ؤُعَالْطَارْ، مَاحنْذْ أَذْ زَّايْسنْ إِتّْوَاڭّْ وصْڒَاحْ إِ ڒعْمُورْ نْومْ، مِينْزِي إِذَامّنْ ذ إِنَا إِ غَا إِوْينْ أَصْڒَاحْ إِ ڒعْمَارْ.  
\v 12 خْ ؤُيَا أَقَا نِّيغْ إِ أَيْثْ ن إِسْرَائِيل: ؤُڒَا ذ إِجّْ زَّايْومْ وَارْ إِتّتّْ زڭْ إِذَامّنْ، ؤُڒَا ذ أَبَارَّانِي إِ إِزدّْغنْ ذِي ڒْوسْطْ نْومْ وَارْ إِتّتّْ إِذَامّنْ.  
\v 13 كُوڒْ  إِجّْ زڭْ أَيْثْ ن إِسْرَائِيل ؤُ زڭْ إِبَارَّانِييّنْ إِ إِزدّْغنْ ذِي ڒْوسْطْ نْومْ، ونِّي إِيْمَارنْ إِجّْ ن ؤُمُودَّارْ نِيغْ إِجّْ ن وجْضِيضْ نِّي إِزمَّارْ أَذْ إِتّْوَاشّْ، أَذْ إِسِّيزّڒْ إِذَامّنْ نّسْ ؤُشَا أَذْ ثنْ إِسّْذُورِييْ س ؤُشَاڒْ.  
\v 14 مِينْزِي ڒعْمَارْ ن كُوڒْ أَيْسُومْ ذ إِذَامّنْ نّسْ، أَقَا أَثنْ \add ذ إِجّنْ\add* أَكْ-ذ ڒعْمَارْ نّسْ. س ؤُينِّي نِّيغْ إِ أَيْثْ ن إِسْرَائِيل: ’وَارْ تّتّمْ زڭْ إِذَامّنْ ن مَامّشْ مَا إِڭَّا ويْسُومْ!‘، مِينْزِي ڒعْمَارْ ن مَارَّا أَيْسُومْ ذ إِذَامّنْ نّسْ. ونِّي زَّايْسنْ غَا إِشّنْ، أَذْ إِتّْوَاقسّْ \add زِي ڒْڭنْسْ نّسْ\add*. \x ◘ \xo 17:‏14 \xt أَمز. 9‏:‏4\x*  
\v 15 مَارَّا ونِّي إِ غَا إِشّنْ زڭْ إِشْثْ نْ ڒْخشْبثْ نِيغْ زڭْ إِجّْ ن \add ؤُمُودَّارْ\add* إِمزّْقنْ، مَا نتَّا زِي ثَارْوَا ن ثمُّورْثْ نِيغْ نتَّا ذ إِجّْ ن ؤُبَارَّانِي، أَذْ إِصبّنْ أَرُّوضْ نّسْ ؤُشَا أَذْ إِسِّيرْذْ إِخفْ نّسْ س وَامَانْ ؤُشَا أَذْ يِيڒِي إِخْمجْ أَڒْ ثَامذِّيثْ. \add أَوَارْنِي أَيَا\add* أَذْ يِيڒِي إِزْذڭْ. \x ◘ \xo 17:‏15 \xt ؤُف. 22‏:‏31؛ لَاوِي 11‏:‏40؛ حِز. 44‏:‏31\x*  
\v 16 مَاڒَا وَارْ إِسِّيرْذْ \add أَرُّوضْ\add* ؤُ وَارْ إِسِّيرْذْ أَرِّيمثْ نّسْ، \add خنِّي\add* أَذْ يَارْبُو ڒْمُوعْصِييّثْ نّسْ.“   
\b  
\b  
\m  
\c 18
\s1 إِزرْفَانْ ضِيدّْ إِ مِينْ إِدْجَانْ ذ ڒفْضِيحثْ ذِي ثْوَاشُونْثْ ؤُ ذِي فَامِيلِييَا  
\m
\v 1 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 2 ”سِيوڒْ أَكْ-ذ أَيْثْ ن إِسْرَائِيل ؤُشَا إِنِي أَسنْ: ’نشّْ ذ سِيذِي، أَربِّي نْومْ!  
\v 3 وَارْ تّڭّمْ أَمْ مَامّشْ تّڭّنْ ذِي ثمُّورْثْ ن مِيصْرَا مَانِي ثُوغَا ثْزدّْغمْ كنِّيوْ، ؤُ وَارْ ثتّڭّمْ أَمْ مَامّشْ تّڭّنْ ذِي ثمُّورْثْ ن كنْعَانْ مَانِي كنِّيوْ غَا نذْهغْ، ؤُ وَارْ ثتّڭّمْ عْلَاحْسَابْ ثِيوصَّا نْسنْ. \f ◼ \fr 18:‏3 \ft \+bd ’وَارْ ثتّڭّمْ‘\+bd* - س ثْعِيبْرَانِيثْ ’وَارْ ثڭُّورمْ‘.\f*  
\v 4 أَذْ ثڭّمْ لْفَارَايِيضْ إِنُو ؤُشَا أَذْ ثحْضَامْ ثِيوصَّا إِنُو، مَاحنْذْ أَذْ ذَايْسنْ ثُويُورمْ: نشّْ ذ سِيذِي، أَربِّي نْومْ!  
\v 5 أَذْ ثحْضَامْ ثِيوصَّا إِنُو ذ لْفَارَايِيضْ إِنُو: بْنَاذمْ نِّي ثنْثْ إِتّڭّنْ، أَذْ زَّايْسنْثْ إِدَّارْ، نشّْ ذ سِيذِي! \x ◘ \xo 18:‏5 \xt حِز. 20‏:‏11، 13؛ رُوم. 10‏:‏5؛ ڭال. 3‏:‏12\x*   
\m
\v 6 ؤُڒَا ذ إِجّْ أَذْ د-إِقَارّبْ غَارْ شَا ن يِيجّنْ زِي رَادْجْ نّسْ، حِيمَا أَذْ إِسّْعَارَّا ڒْعَارْ نّسْ: نشّْ ذ سِيذِي.   
\m
\v 7 وَارْ تّسّْعَارِّي شَا ڒْعَارْ ن بَابَاشْ ذ ڒْعَارْ ن يمَّاشْ. أَقَا-ت ذ يمَّاشْ، وَارْ تّسّْعَارِّي شَا ڒْعَارْ نّسْ.  
\v 8 ڒْعَارْ ن ثمْغَارْثْ ن بَابَاشْ وَارْ ث تّسّْعَارِّي شَا. أَقَا-ث ذ ڒْعَارْ ن بَابَاشْ. \x ◘ \xo 18:‏8 \xt لَاوِي 20‏:‏11؛ 1 كُور. 5‏:‏1\x*  
\v 9 \add خْ\add* ڒْعَارْ ن ؤُتْشْمَاشْ، يدْجِيسْ ن بَابَاشْ نِيغْ يدْجِيسْ ن يمَّاشْ، نِيغْ نتَّاثْ ثتّْوَاخْڒقْ-د ذِي ثَادَّارْثْ نِيغْ بَارَّا إِ ثَادَّارْثْ، أَقَا ڒْعَارْ نّسْ وَارْ ث ثسّْعَارِّي شَا.  
\v 10 \add خْ\add* ڒْعَارْ ن يدْجِيسْ ن مِّيشْ نِيغْ ن يدْجِيسْ ن يدْجِيشْ، وَارْ تّسّْعَارِّي شَا ڒْعَارْ نْسنْ مِينْزِي أَقَا ذ ڒْعَارْ نّشْ.  
\v 11 وَارْ تّسّْعَارِّي شَا ڒْعَارْ ن يدْجِيسْ ن ثمْغَارْثْ ن بَابَاشْ، ثنِّي د-إِتّْوَاخڒْقنْ إِ بَابَاشْ. أَقَا-ت ذ ؤُتْشْمَاشْ. \x ◘ \xo 18:‏11 \xt لَاوِي 20‏:‏17\x*  
\v 12 وَارْ تّسّْعَارِّي شَا ڒْعَارْ ن ؤُتْشْمَاسْ ن بَابَاشْ. أَقَا-ت ذ رَادْجْ ن بَابَاشْ. \x ◘ \xo 18:‏12 \xt لَاوِي 20‏:‏19\x*  
\v 13 وَارْ تّسّْعَارِّي شَا ڒْعَارْ ن ؤُتْشْمَاسْ ن يمَّاشْ، مِينْزِي نتَّاثْ ذ رَادْجْ ن يمَّاشْ.  
\v 14 وَارْ تّسّْعَارِّي شَا ڒْعَارْ ن ؤُمَاسْ ن بَابَاشْ ؤُ وَارْ د-تّْقَارَّابذْ غَارْ ثمْغَارْثْ نّسْ، أَقَا-ت ذعنْثِيشْ. \x ◘ \xo 18:‏14 \xt لَاوِي 20‏:‏20؛ حِز. 22‏:‏11\x*  
\v 15 وَارْ تّسّْعَارِّي شَا ڒْعَارْ ن ثمْغَارْثْ ن مِّيشْ، أَقَا-ت ذ ثَامْغَارْثْ ن مِّيشْ. وَارْ تّسّْعَارِّي شَا ڒْعَارْ نّسْ. \x ◘ \xo 18:‏15 \xt لَاوِي 20‏:‏12\x*  
\v 16 وَارْ تّسّْعَارِّي شَا ڒْعَارْ ن ثمْغَارْثْ ن ؤُمَاشْ، أَقَا-ث ذ ڒْعَارْ ن ؤُمَاشْ. \x ◘ \xo 18:‏16 \xt لَاوِي 20‏:‏21\x*  
\v 17 وَارْ ثسّْعَارِّي شَا ڒْعَارْ ن ثمْغَارْثْ ذ يدْجِيسْ. وَارْ د-تَّاوِي شَا يدْجِيسْ ن مِّيسْ نِيغْ يدْجِيسْ ن يدْجِيسْ، مَاحنْذْ أَذْ ثسّْعَارِّيذْ ڒْعَارْ نّسْ. أَقَا أَثنْثْ ذ رَادْجْ \add نّشْ\add*، أَقَا-ت ذ إِشْثْ ن ثْمعْمُوتْشْ \add إِفسْذنْ\add*. \x ◘ \xo 18:‏17 \xt لَاوِي 20‏:‏14\x*  
\v 18 وَارْ د-تَّاوِي ثَامْغَارْثْ \add ذ ثَاشْنَا\add* أَكْ-ذ ؤُتْشْمَاسْ مَاحنْذْ أَذْ ت ثْغنّذْ \add أَمُّو\add*، خْمِي غَا ثسّْعَارِّيذْ ڒْعَارْ نّسْ أَمْ عَاذْ ثدَّارْ.  
\v 19 وَارْ د-تّْقَارَّابْ شَا غَارْ إِشْثْ ن ثمْغَارْثْ خْمِي غَا ثعْزڒْ إِخفْ نّسْ زِي سِّيبّثْ ن ڒخْمجْ نّسْ حِيمَا أَذْ ثسّْعَارِّيذْ ڒْعَارْ نّسْ. \x ◘ \xo 18:‏19 \xt لَاوِي 20‏:‏18\x*  
\v 20 وَارْ تّطّصْ أَكْ-ذ ثمْغَارْثْ ن جَّارْ نّشْ، مَاغَارْ \add أَمُّو\add* إِ غَا ثْفسْذذْ إِخفْ نّشْ زَّايسْ. \x ◘ \xo 18:‏20 \xt لَاوِي 20‏:‏10؛ أَعَوذ. 22‏:‏22؛ يُوح. 9‏:‏5 \x*   
\m
\v 21 وَارْ تّجِّي أَرَّاوْ نّشْ أَذْ ژْوَانْ غَارْ مُولَاكْ، وَارْ سّخْسَارَا إِسمْ ن أَربِّي نّشْ، نشّْ ذ سِيذِي! \x ◘ \xo 18:‏21 \xt لَاوِي 20‏:‏2؛ أَعَوذ. 18‏:‏10؛ 2 إِج. 17‏:‏17؛ 23‏:‏10\x*  
\v 22 وَارْ تّطّصْ شَا أَكْ-ذ شَا ن ورْيَازْ أَمْ ثطّصذْ أَكْ-ذ ثمْغَارْثْ. أَقَا-ت ذ جّْعِيفشْثْ. \x ◘ \xo 18:‏22 \xt لَاوِي 20‏:‏13\x*  
\v 23 وَارْ فسّذْ شَا إِخفْ نّشْ أَكْ-ذ شَا ن ڒبْهِيمثْ أَمْ ثْفحّْڒذْ إِخفْ نّشْ أَكِيذسْ، ؤُ ثَامْغَارْثْ وَارْ ثتّْبذِّي زَّاثْ إِ ڒبْهِيمثْ مَاحنْذْ أَذْ ثْفسْذذْ إِخفْ نّسْ زَّايسْ. أَقَا ذ إِجّْ ن ؤُخدْجضْ \add إِفسْذنْ\add*. \x ◘ \xo 18:‏23 \xt لَاوِي 20‏:‏15، 16\x*  
\v 24 وَارْ فسّْذمْ شَا إِخفْ نْومْ س مَارَّا ثِيمسْڒَايِينْ-أَ، مِينْزِي ڒڭْنُوسْ نِّي إِ غَا سُّوفّْغغْ زَّاثْ إِ ؤُغمْبُوبْ نْومْ، ثُوغَا فسّْذنْ إِخفْ نْسنْ س مَارَّا ثِيمسْڒَايِينْ-أَ.  
\v 25 \add س ؤُينِّي\add* ثذْوڒْ ثمُّورْثْ ثفْسذْ ؤُشَا نشّْ أَذْ أَسْ خدْجْصغْ ڒْمُوعْصِييّثْ نّسْ، ؤُشَا أَذْ ثْعُوقّْ ثمُّورْثْ إِمزْذَاغْ نّسْ.  
\v 26 \add مَاشَا\add* كنِّيوْ أَذْ ثحْضَامْ ثِيوصَّا ذ لْفَارَايِيضْ إِنُو، وَارْ تّڭّمْ ؤُڒَا ذ إِشْثْ ن ڒْحَاجّثْ زِي مَارَّا جّْعَايفْ-أَ، نِيغْ ونِّي زِي ثَارْوَا ن ثمُّورْثْ ؤُڒَا ذ أَبَارَّانِي نِّي إِزدّْغنْ ذِي ڒْوسْطْ نْومْ. \x ◘ \xo 18:‏26 \xt لَاوِي 20‏:‏22\x*  
\v 27 مِينْزِي إِرْيَازنْ ن ثمُّورْثْ، \add إِنِّي ثُوغَا\add* قْبڒْ نْومْ، أَقَا ڭِّينْ مَارَّا جّْعَايفْ-أَ ؤُشَا \add أَمُّو إِ\add* ثذْوڒْ ثمُّورْثْ ثفْسذْ.  
\v 28 وَارْ تّجِّي ثَامُّورْثْ أَذْ كنِّيوْ ثْعُوقّْ ؤُمِي ت ثْفسّْذمْ، أَمْ مَامّشْ ثْعُوقّْ \add ثمُّورْثْ\add* ڒْڭنْسْ نِّي ثُوغَا \add ذِينْ\add* قْبڒْ نْومْ.  
\v 29 مِينْزِي مَارَّا إِنِّي إِڭِّينْ شَا زِي مَارَّا جّْعَايفْ-أَ، أَقَا ڒعْمُورْ إِ غَا إِڭِّينْ \add أَمُّو\add*، أَذْ تّْوَاقضْعنْ زِي ڒْڭنْسْ نْسنْ.  
\v 30 أَذْ ثحْضَامْ مِينْ ذ أَومْ ؤُمُورغْ، مَاحنْذْ وَارْ ثْضفَّارمْ ثِيوصَّا يُورْصُوضنْ أَمْ مَامّشْ ت ڭِّينْ \add ڒڭْنُوسْ\add* قْبڒْ نْومْ. وَارْ زَّايْسنْثْ ثْفسّْذمْ إِخفْ نْومْ، نشّْ ذ سِيذِي، أَربِّي نْومْ!‘ “   
\b  
\b  
\m  
\c 19
\s1 ثِيوصَّا خْ ؤُوقَّارْ ذِي ثُوذَارْثْ  
\m
\v 1 إِسِّيوڒْ سِيذِي غَارْ مُوسَا، إِنَّا:   
\m
\v 2 ”سِيوڒْ أَكْ-ذ مَارَّا ثَامسْمُونْثْ ن أَيْثْ ن إِسْرَائِيل ؤُشَا إِنِي أَسنْ: ’إِتّْخصَّا أَذْ ثِيڒِيمْ ذ إِمْقدَّاسنْ، مِينْزِي نشّْ ذ سِيذِي، أَربِّي نْومْ، أَقَا أَيِي ذ أَمْقدَّاسْ! \x ◘ \xo 19:‏2 \xt لَاوِي 11‏:‏44؛ 20‏:‏7، 26؛ 1 بُط. 1‏:‏16\x*  
\v 3 كُوڒْ إِجّْ أَذْ إِوقَّارْ يمَّاسْ ذ بَابَاسْ ؤُشَا ؤُسَّانْ إِنُو ن سّبْثْ أَذْ ثنْ ثحْضَامْ، نشّْ ذ سِيذِي، أَربِّي نْومْ!\x ◘ \xo 19:‏3 \xt ؤُف. 20‏:‏12؛ 31‏:‏13؛ لَاوِي 26‏:‏2\x*  
\v 4 وَارْ دِّيكّْوِيڒمْ غَارْ لْ-أَصْنَامْ ؤُ وَارْ تّڭّمْ إِ يِيخفْ نْومْ \add ڒخْيَاڒَاثْ\add* إِفسْينْ ذ إِربِّيثنْ. نشّْ ذ سِيذِي، أَربِّي نْومْ! \x ◘ \xo 19:‏4 \xt ؤُف. 34‏:‏17\x*  
\v 5 خْمِي غَا ثْقدّْمنْ ثَاغَارْصْثْ ن ڒهْنَا إِ سِيذِي، \add خنِّي\add* أَذْ ت ثْقدّْممْ س إِجّْ ن وبْرِيذْ إِ زِي غَا ثتّْوَاقبْڒمْ س أَرْضَا.  
\v 6 إِتّْخصَّا أَذْ ثتّْوَاشّْ ذڭْ وَاسّْ ن ثْغَارْصْثْ نْومْ ؤُڒَا ذِي ثِيوشَّا أَوَارْنِي أَسْ. مِينْ إِقِّيمنْ أَڒْ وَاسّْ وِيسّْ ثْڒَاثَا أَذْ إِتّْوَاسّشْمضْ س ثْمسِّي. \x ◘ \xo 19:‏6 \xt لَاوِي 7‏:‏16\x*  
\v 7 مَاڒَا ثتّْوَاشّْ عَاذْ ذڭْ وَاسّْ وِيسّْ ثْڒَاثَا، أَذْ ثِيڒِي ذ جّْعِيفشْثْ، وَارْ ثتّْوَاقبّڒْ س أَرْضَا.  
\v 8 وِي زَّايسْ غَا إِشّنْ أَذْ يَارْبُو ڒْمُوعْصِييّثْ نّسْ، مِينْزِي إِسّخْسَارَا مِينْ إِدْجَانْ ذ أَمْقدَّاسْ ن سِيذِي ؤُشَا \add خنِّي\add* أَذْ إِتّْوَاقسّْ بْنَاذمْ نِّي زِي ڒْڭنْسْ نّسْ.   
\m
\v 9 مَاڒَا ثمْجَارمْ صَّابثْ ن ثمُّورْثْ نْومْ، وَارْ مجَّارْ شكْ إِيَّارْ نّشْ أَڒْ أَغزْذِيسْ أَنڭَّارْ نِيغْ أَذْ ثْجمْعذْ مِينْ إِقِّيمنْ أَوَارْنِي ثَاميْرَا نّشْ. \x ◘ \xo 19:‏9 \xt لَاوِي 23‏:‏22؛ أَعَوذ. 24‏:‏19\x*  
\v 10 وَارْ ڒقّضْ ؤُضِيڒْ ن ؤُمَارْجعْ نّشْ كُوڒْشِي، وَارْ حْرُووْ مَارَّا مِينْ ذِينْ إِقِّيمنْ \add ذِي ثمُّورْثْ\add* ذڭْ ؤُمَارْجعْ نّشْ ن ؤُضِيڒْ. أَذْ ثجّذْ أَيَا إِ ؤُمزْڒُوضْ ؤُ إِ ؤُبَارَّانِي، نشّْ ذ سِيذِي، أَربِّي نْومْ!   
\m
\v 11 وَارْ تَّاشَارْ ؤُ وَارْ سّْخَارِّيقْ، ؤُڒَا ذ إِجّْ أَذْ إِشْمثْ جَّارْ نّسْ. \x ◘ \xo 19:‏11 \xt ؤُف. 20‏:‏15\x*  
\v 12 وَارْ تّْجَادْجَامْ ژُورْ س يِيسمْ إِنُو. وَارْ سّخْسَارَا إِسمْ ن أَربِّي نّشْ. نشّْ ذ سِيذِي.\x ◘ \xo 19:‏12 \xt ؤُف. 20‏:‏7؛ أَعَوذ. 5‏:‏11\x*   
\m
\v 13 وَارْ سّْحِيسِّيفْ جَّارْ نّشْ نِيغْ أَذْ \add ث\add* ثَاشَارذْ. وَارْ تّطّفْ ڒْمُونثْ ن إِشوَّاڒنْ زِي دْجِيڒثْ أَڒْ ثِيوشَّا. \f ◼ \fr 19:‏13 \ft \+bd ’وَارْ تّطّفْ‘\+bd* - نِيشَانْ زِي ثْعِيبْرَانِيثْ ’وَارْ تّْنُوسِي‘.\f*  \x ◘ \xo 19:‏13 \xt أَعَوذ. 24‏:‏14؛ يَاع. 5‏:‏4\x*  
\v 14 وَارْ تّكّْوَارْ أَذهْشُورْ ؤُ وَارْ تّڭّْ شَا مِينْ ذِي غَا إِنْقَارضْ ؤُذَارْغَاڒْ، مَاشَا إِتّْخصَّا أَذْ ثڭّْوذذْ أَربِّي، نشّْ ذ سِيذِي!   
\m
\v 15 غَارْ وحْكَامْ وَارْ تّْغشِّيمْ. وَارْ سْعِيزِّي أَمزْڒُوضْ ؤُ وَارْ سْعدُّو غَارْ بُو-ثْخُوبَا. إِتّْخصَّا أَذْ ثْحكْمذْ خْ جَّارْ نّشْ س ؤُسڭّذْ. \x ◘ \xo 19:‏15 \xt أَعَوذ. 1‏:‏17؛ 16‏:‏19؛ أَوڒن. 24‏:‏23\x*  
\v 16 وَارْ ڭُّورْ جَارْ ڒْڭنْسْ نّشْ س ؤُنمّمْ، وَارْ تّْبذِّي خْ إِذَامّنْ ن جَّارْ نّشْ، نشّْ ذ سِيذِي! \x ◘ \xo 19:‏16 \xt ؤُف. 23‏:‏1\x*   
\m
\v 17 وَارْ شَارّهْ ؤُمَاشْ ذڭْ وُوڒْ نّشْ. أَذْ ثْعڒْمذْ أَعْڒَامْ إِ جَّارْ نّشْ ؤُ وَارْ ثْكسِّيذْ دّنْبْ خَاكْ زِي سِّيبّثْ نّسْ. \x ◘ \xo 19:‏17 \xt مت. 18‏:‏15؛ لك. 17‏:‏3؛ 1 يُوح. 2‏:‏9، 11؛ 3‏:‏15\x*  
\v 18 وَارْ تّنْثِيقِيمْ نِيغْ أَذْ ثْخمّْڒذْ أَنْثَاقمْ خْ ثَارْوَا ن ڒْڭنْسْ نّشْ. أَذْ ثخْسذْ جَّارْ نّشْ أَمشْنَاوْ إِخفْ نّشْ، نشّْ ذ سِيذِي.\x ◘ \xo 19:‏18 \xt مت. 5‏:‏39،43،44؛ 22‏:‏39؛ لك. 6‏:‏27؛ رُوم. 12‏:‏19؛ 13‏:‏9؛ 1 كُور. 6‏:‏7؛ ڭال. 5‏:‏14؛ 1 تس. 5‏:‏15؛ 1 بُط. 3‏:‏9؛ يَاع. 2‏:‏8\x*   
\m
\v 19 أَذْ ثحْضَامْ ثِيوصَّا إِنُو. وَارْ تّْڒقَّامْ شَا ڒبْهِيمثْ نّشْ أَكْ-ذ إِجّْ ن مَارْكَا نّغْنِي. وَارْ زَارّعْ ثْنَاينْ ن مَارْكَاثْ ن زَّارِيعثْ ذڭْ إِيَّارْ نّشْ ؤُ وَارْ يَارّضْ أَرُّوضْ إِتّْوَاڭّنْ س ثْنَاينْ ن مَارْكَاثْ ن ؤُكتَّانْ. \x ◘ \xo 19:‏19 \xt أَعَوذ. 22‏:‏9، 11\x*   
\m
\v 20 مَاڒَا أَرْيَازْ إِطّصْ أَكْ-ذ إِشْثْ ن ثمْغَارْثْ، إِشْثْ ن ثَايَّا إِخْضبْ إِ-ت يِيجّْ ن ورْيَازْ \add نّغْنِي\add*، مَاشَا وَارْ إِتّْوَاخدْجصْ عَاذْ تَّامَانْ نّسْ ن ؤُفكِّي نِيغْ ثمّوْشْ أَسْ ثْڒلِّي، \add خنِّي\add* أَذْ يِيڒِي ڒحْسَابْ، \add مَاشَا\add* وَارْ تّْوَانقّنْ شَا، مِينْزِي نتَّاثْ ثُوغَا \add عَاذْ\add* وَارْ ثتّْوَاحَارْ شَا.  
\v 21 نتَّا أَذْ يَاوِي ثَاغَارْصْثْ ن ؤُمَارْوَاسْ نّسْ إِ سِيذِي غَارْ وَاذَافْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ، إِجّْ ن إِشَارِّي \add أَمْ\add* ثْغَارْصْثْ ن ؤُمَارْوَاسْ.  
\v 22 أَكهَّانْ أَذْ خَاسْ إِڭّْ أَصْڒَاحْ س إِشَارِّي ن ثْغَارْصْثْ ن ؤُمَارْوَاسْ زَّاثْ إِ وُوذمْ ن سِيذِي إِ دّنْبْ نّسْ إِ إِڭَّا ؤُشَا دّنْبْ نّسْ إِ إِڭَّا أَذْ أَسْ إِتّْوَاغْفَارْ. \f ◼ \fr 19:‏22 \ft \+bd ’إِفْذِي‘\+bd* - خْزَارْ إِزهد. 78:35.\f*   
\m
\v 23 خْمِي غَا ثَاوْضمْ ذِي ثمُّورْثْ ؤُشَا ثژُّومْ عْڒَامْ كُوڒْ ثِيشجُّورَا، مَاحنْذْ أَذْ زَّايْسنْثْ ثشّمْ، \add خنِّي\add* وَارْ ثْختّْنمْ ’ڒعْذَاڒْيثْ نّسْ‘، ثنِّي ذ ڒْغِيدْجثْ نّسْ. ثْڒَاثَا ن إِسڭّْوُوسَا وَارْ ثنْثْ ثْختّْنمْ، وَارْ زَّايْسنْثْ تّتّمْ شَا.  
\v 24 ذڭْ ؤُسڭّْوَاسْ وِيسّْ أَربْعَا أَذْ ثِيڒِي مَارَّا ڒْغِيدْجثْ نّسْ ثْقدّسْ، إِ ؤُسمْغَارْ إِ سِيذِي.  
\v 25 ذڭْ ؤُسڭّْوَاسْ وِيسّْ خمْسَا أَذْ ثشّمْ ڒْغِيدْجثْ نّسْ ؤُشَا صَّابثْ نّسْ أَذْ ت ثوْشمْ إِ يِيخفْ نْومْ. نشّْ ذ سِيذِي، أَربِّي نْومْ!   
\m
\v 26 وَارْ تّتّمْ شَا أَكْ-ذ إِذَامّنْ. وَارْ إِعدّڒْ أَذْ ثْڭزّْنمْ نِيغْ أَذْ ثْشغْڒمْ إِخفْ نْومْ س ثْبزْڭِيوْثْ.  
\v 27 وَارْ تّْحفِّيمْ أَشُوَّافْ ن ؤُزدْجِيفْ نْومْ ذڭْ ونّضْ نّسْ ؤُ وَارْ تّْضيِّيعمْ شَا ثْمَا ن ثْمَارْثْ نْومْ. \x ◘ \xo 19:‏27 \xt لَاوِي 21‏:‏5؛ إِرْم. 9‏:‏25؛ 25‏:‏23؛ 49‏:‏32\x*  
\v 28 وَارْ إِعدّڒْ أَذْ ثْشَارْضمْ أَرِّيمثْ نْومْ زِي سِّيبّثْ ن يِيجّْ ن ؤُمتِّينْ نِيغْ أَذْ ثَارشْممْ ثِيڭَّازْ ذِي \add أَرِّيمثْ\add* نْومْ. نشّْ ذ سِيذِي! \x ◘ \xo 19:‏28 \xt أَعَوذ. 14‏:‏1\x*   
\m
\v 29  وَارْ سْذدْجِي يدْجِيشْ، أَذْ ت ثَارّذْ ذ ثَامْغَارْثْ ن فَارْقْ-شّْغڒْ، حِيمَا وَارْ ثْوطِّي ثمُّورْثْ ذِي فَارْقْ-شّْغڒْ ؤُشَا \add خنِّي\add* أَذْ ثشُّورْ ثمُّورْثْ س ڒفْضِيحثْ.  
\v 30 أَذْ ثحْضَامْ ؤُسَّانْ إِنُو ن سّبْثْ ؤُشَا أَذْ ثْوقَّارمْ زَّاوشْثْ إِنُو إِقدّْسنْ. نشّْ ذ سِيذِي!  
\v 31 وَارْ تّْذِيكّْوِيڒمْ غَارْ يِينِّي إِسَّاوَاڒَانْ أَكْ-ذ إِمتَّانْ ؤُ غَارْ إِڭزَّاننْ، وَارْ غَارْسنْ أَرزّْفمْ، حِيمَا أَذْ زَّايْسنْ ثتّْوَاخمْجمْ. نشّْ ذ سِيذِي، أَربِّي نْومْ! \x ◘ \xo 19:‏31 \xt لَاوِي 20‏:‏6\x*   
\m
\v 32 أَذْ ثكَّارذْ إِ ونِّي غَارْ إِدْجَا ؤُشُوَّافْ إِشَابْ ؤُشَا أَذْ ثْوقَّارذْ ؤُذمْ ن إِوسُّورَا ؤُشَا أَذْ ثڭّْوذذْ أَربِّي نّشْ. نشّْ ذ سِيذِي!   
\m
\v 33 خْمِي كِيذكْ غَا إِزْذغْ إِجّْ ن ؤُبَارَّانِي ذِي ثمُّورْثْ نْومْ، وَارْ ث تّْضدْجْممْ. \x ◘ \xo 19:‏33 \xt ؤُف. 22‏:‏21\x*  
\v 34 أَبَارَّانِي، ونِّي غَارْومْ إِزدّْغنْ، أَذْ أَومْ يِيڒِي أَمْ يِيجّنْ زِي ثَارْوَا ن ثمُّورْثْ نْومْ. أَذْ ث ثخْسذْ أَمْ يِيخفْ نّشْ، مِينْزِي ثُوغَا كنِّيوْ ذ إِبَارَّانِييّنْ ذِي ثمُّورْثْ ن مِيصْرَا. نشّْ ذ سِيذِي، أَربِّي نْومْ!   
\m
\v 35 خْمِي غَا ثِيڒِيمْ غَارْ وحْكَامْ وَارْ تّْغشّمْ شَا س \add ڒعْبَارْ ن\add* ثُوزّڭَّارْثْ نِيغْ ن دّْقڒْ نِيغْ س \add ڒعْبَارْ\add* ن مِينْ ذَايسْ.  
\v 36 أَذْ غَارْومْ يِيڒِي ذ إِجّْ ن ڒْمِيزَانْ نِيشَانْ ذ إِژْرَا ن ڒْمِيزَانْ نِيشَانْ ؤُڒَا ذ إِجّْ ن إِفَا نِيشَانْ ذ إِجّْ ن ؤُهِينُو نِيشَانْ، نشّْ ذ سِيذِي، أَربِّي نْومْ، ونِّي كنِّيوْ د-إِسُّوفّْغنْ زِي ثمُّورْثْ ن مِيصْرَا. \x ◘ \xo 19:‏36 \xt أَوڒن. 11‏:‏1؛ 16‏:‏11؛ 20‏:‏10\x*  
\v 37 أَذْ ثحْضَامْ مَارَّا ثِيوصَّا ذ ڒُومُورْ إِنُو ؤُشَا أَذْ ثنْ ثڭّمْ. نشّْ ذ سِيذِي!‘ “   
\b  
\b  
\m  
\c 20
\s1 إِزرْفنْ خْ مَامّشْ إِ غَا يِيڒِي ڒْعِيقَابْ  
\m
\v 1 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 2 ”أَذْ ثِينِيذْ إِ أَيْثْ ن إِسْرَائِيل: ’كُوڒْ إِجّنْ زڭْ أَيْثْ ن إِسْرَائِيل نِيغْ زڭْ إِبَارَّانِييّنْ، ونِّي إِ غَا إِوْشِينْ زڭْ إِحنْجِيرنْ نّسْ إِ مُولَاكْ، أَذْ إِتّْوَانغْ نِيشَانْ. ڒْڭنْسْ ن ثمُّورْثْ أَذْ ث يَارْجمْ. \f ◼ \fr 20:‏2 \ft \+bd ’أَذْ ث يَارْجمْ‘\+bd* - س ثْعِيبْرَانِيثْ ’أَذْ ث يَارْجمْ س إِژْرَا‘.\f*  \x ◘ \xo 20:‏2 \xt لَاوِي 18‏:‏21\x*  
\v 3 نشّْ أَذْ قڒْبغْ ؤُذمْ إِنُو خْ ورْيَازْ نِّي ؤُشَا أَذْ ث قضْعغْ زِي ڒْڭنْسْ نّسْ، مِينْزِي نتَّا أَقَا إِوْشَا زِي زَّارِيعثْ نّسْ إِ مُولَاكْ. س ؤُينِّي ثُوغَا إِسّخْمجْ زَّاوشْثْ إِنُو إِقدّْسنْ ؤُشَا إِسّخْسَارْ إِسمْ أَمْقدَّاسْ إِنُو.  
\v 4 مَاڒَا ثَارْوَا ن ثمُّورْثْ قّْننْ ثِيطَّاوِينْ نْسنْ خْ ورْيَازْ نِّي، خْمِي غَا إِوْشْ نتَّا زِي زَّارِيعثْ نّسْ إِ مُولَاكْ، ؤُشَا نِيثْنِي وَارْ ث نقّنْ،  
\v 5 خنِّي نشّْ أَذْ قڒْبغْ ؤُذمْ إِنُو خْ ورْيَازْ نِّي ؤُ خْ ڒَادْجْ نّسْ ؤُشَا أَذْ ث قضْعغْ زِي جَارْ ڒْڭنْسْ نّسْ، نتَّا ذ مَارَّا إِنِّي إِسّفْسَاذنْ إِخفْ نْسنْ أَمْ دّكّْوَاڒنْ أَوَارْنِي أَسْ مَاحنْذْ أَذْ سّْفسْذنْ إِخفْ نْسنْ أَكْ-ذ مُولَاكْ.‘ “   
\m
\v 6 ”بْنَاذمْ نِّي إِ غَا إِقڒْبنْ إِخفْ نّسْ غَارْ يِينِّي إِسَّاوَاڒَانْ أَكْ-ذ إِمتَّانْ ذ إِڭزَّاننْ، مَاحنْذْ أَذْ ذوْڒنْ أَوَارْنِي أَسنْ أَمْ سّْفسْذنْ إِخفْ نْسنْ، نشّْ أَذْ قڒْبغْ ؤُذمْ إِنُو خْ بْنَاذمْ نِّي ؤُشَا أَذْ ث قضْعغْ زِي جَارْ ڒْڭنْسْ نّسْ.“\f ◼ \fr 20:‏6 \ft \+bd ’بْنَاذمْ‘\+bd* - س ثْعِيبْرَانِيثْ ’ڒعْمَارْ‘.\f*  \x ◘ \xo 20:‏6 \xt لَاوِي 19‏:‏31\x*   
\m
\v 7 ”سْقدّْسمْ إِخفْ نْومْ، إِڒِيمْ ذ إِمْقدَّاسنْ، مِينْزِي نشّْ ذ سِيذِي، أَربِّي نْومْ! \x ◘ \xo 20:‏7 \xt لَاوِي 11‏:‏44؛ 19‏:‏2؛ 1 بُط. 1‏:‏16\x*  
\v 8 حْضَامْ ثِيوصَّا إِنُو ؤُشَا ڭّمْ زَّايْسنْثْ. نشّْ ذ سِيذِي، ونِّي كنِّيوْ إِسّْقدّْسنْ.“   
\m
\v 9 ”مَاغَارْ كُوڒْ أَرْيَازْ نِّي إِ غَا إِنعْڒنْ خْ بَابَاسْ نِيغْ خْ يمَّاسْ، أَذْ إِتّْوَانغْ نِيشَانْ. إِنْعڒْ خْ بَابَاسْ نِيغْ خْ يمَّاسْ، إِذَامّنْ نّسْ \add أَقَا أَثنْ\add* خَاسْ. \x ◘ \xo 20:‏9 \xt ؤُف. 21‏:‏17؛ أَوڒن. 20‏:‏20؛ مت. 15‏:‏4\x*  
\v 10 \add مَاڒَا\add* إِجّْ ن ورْيَازْ إِزْنَا أَكْ-ذ ثمْغَارْثْ ن ورْيَازْ \add نّغْنِي\add*، \add خنِّي\add* ونِّي ثُوغَا إِزنَّانْ أَكْ-ذ ثمْغَارْثْ ن جَّارْ نّسْ أَذْ إِتّْوَانغْ نِيشَانْ، ونِّي إِزْنَانْ ذ ثنِّي إِزْنَانْ. \x ◘ \xo 20:‏10 \xt لَاوِي 18‏:‏20؛ أَعَوذ. 22‏:‏22؛ يُوح. 8‏:‏5\x*  
\v 11 \add مَاڒَا\add* إِجّْ ن ورْيَازْ، أَمْ إِطّصْ أَكْ-ذ ثمْغَارْثْ ن بَابَاسْ، أَقَا إِسّْعُورِّي ڒْعَارْ ن بَابَاسْ، \add خنِّي\add* نِيثْنِي س ثْنَاينْ أَذْ تّْوَانْغنْ نِيشَانْ. إِذَامّنْ نْسنْ أَقَا أَثنْ خَاسنْ. \f ◼ \fr 20:‏11 \ft \+bd ’أَقَا ڭِّينْثْ إِ يِيخفْ نْسنْ.‘\+bd* - س ثْعِيبْرَانِيثْ ’إِذَامّنْ نْسنْ أَقَا-ثنْ خَاسنْ‘.\f*  \x ◘ \xo 20:‏11 \xt لَاوِي 18‏:‏8\x*  
\v 12 \add مَاڒَا\add* إِجّْ ن ورْيَازْ إِطّصْ أَكْ-ذ ثمْغَارْثْ ن مِّيسْ، \add خنِّي\add* نِيثْنِي س ثْنَاينْ أَذْ تّْوَانْغنْ نِيشَانْ. أَقَا ڭِّينْ إِجّْ ن ؤُخدْجضْ إِفسْذنْ. إِذَامّنْ نْسنْ أَقَا أَثنْ خَاسنْ. \f ◼ \fr 20:‏12 \ft \+bd ’ثمْغَارْثْ ن مِّيسْ‘\+bd* - أَقَا-ت ذ ثَاسْڒِيثْ نّسْ.\f*  \x ◘ \xo 20:‏12 \xt لَاوِي 18‏:‏15\x*  
\v 13 \add مَاڒَا\add* إِجّْ ن ورْيَازْ إِطّصْ أَكْ-ذ إِجّْ ن ورْيَازْ نّغْنِي أَمْ مَامّشْ إِتّطّصْ \add ورْيَازْ\add* أَكْ-ذ إِشْثْ ن ثمْغَارْثْ، \add خنِّي\add* أَقَا نِيثْنِي س ثْنَاينْ إِذْسنْ ڭِّينْ إِشْثْ ن ڒفْضِيحثْ ثمْغَارْ. أَذْ تّْوَانْغنْ نِيشَانْ. إِذَامّنْ نْسنْ \add أَقَا أَثنْ\add* خَاسنْ. \x ◘ \xo 20:‏13 \xt لَاوِي 18‏:‏22\x*  
\v 14 \add مَاڒَا\add* إِمڒْشْ إِجّْ ن ورْيَازْ شَا ن ثمْغَارْثْ ؤُڒَا ذ يمَّاسْ، أَقَا-ت ذ ڒفْضِيحثْ. أَذْ ث سّْشمْضنْ س ثْمسِّي، نتَّا ذ نِيثنْثِي \add س ثْنَاينْ\add*، حِيمَا خنِّي وَارْ ثتِّيڒِي \add عَاذْ\add* ذ ڒفْضِيحثْ ذِي ڒْوسْطْ نْومْ. \x ◘ \xo 20:‏14 \xt لَاوِي 18‏:‏17\x*  
\v 15 \add مَاڒَا\add* إِجّْ ن ورْيَازْ إِصُّورْ إِخفْ نّسْ أَكْ-ذ إِشْثْ ن ڒبْهِيمثْ، \add خنِّي\add* إِتّْخصَّا أَذْ إِتّْوَانغْ نِيشَانْ. إِتّْخصَّا \add عَاوذْ\add* أَذْ ثنْغمْ ڒبْهِيمثْ. \x ◘ \xo 20:‏15 \xt لَاوِي 18‏:‏23\x*  
\v 16 \add مَاڒَا\add* شَا ن ثمْغَارْثْ ثْقَارّبْ-د غَارْ شَا ن ڒبْهِيمثْ مَامّشْ مَا ثڭَّا، مَاحنْذْ أَذْ كِيذسْ ثْفحّڒْ، \add خنِّي\add* أَذْ ثنْغذْ ثَامْغَارْثْ ذ ڒبْهِيمثْ. أَذْ تّْوَانْغنْ نِيشَانْ. إِذَامّنْ نْسنْ \add أَقَا أَثنْ\add* خَاسنْ.  
\v 17 \add مَاڒَا\add* إِجّْ ن ورْيَازْ إِطّفْ ؤُتْشْمَاسْ، يدْجِيسْ ن بَابَاسْ نِيغْ يدْجِيسْ ن يمَّاسْ، ؤُشَا إِژْرَا ڒْعَارْ نّسْ ؤُشَا نتَّاثْ ثژْرَا ڒْعَارْ نّسْ، أَقَا-ت ذ ڒفْضِيحثْ. أَذْ تّْوَانْغنْ \add س ثْنَاينْ\add* زَّاثْ إِ ثِيطَّاوِينْ ن ثَارْوَا ن ڒْڭنْسْ نْسنْ. أَقَا إِسّْعُورِّي ڒْعَارْ ن ؤُتْشْمَاسْ، أَذْ يَارْبُو ڒْمُوعْصِييّثْ نّسْ. \x ◘ \xo 20:‏17 \xt لَاوِي 18‏:‏9\x*  
\v 18 \add مَاڒَا\add* إِجّْ ن ورْيَازْ إِطّصْ أَكْ-ذ إِشْثْ ن ثمْغَارْثْ ثنِّي خْ إِدْجَا إِذَامّنْ ؤُشَا أَقَا إِسّْعُورِّي ڒْعَارْ نّسْ، إِسّْعُورِّي أَنُو \add ن إِذَامّنْ\add* نّسْ، ؤُشَا نتَّاثْ سِيمَانْثْ نّسْ ثسّْعُورِّي أَنُو ن إِذَامّنْ نّسْ، \add خنِّي\add* أَذْ تّْوَاقضْعنْ س ثْنَاينْ زِي ڒْوسْطْ ن ڒْڭنْسْ نْسنْ. \x ◘ \xo 20:‏18 \xt لَاوِي 18‏:‏19\x*  
\v 19 وَارْ سْعَارِّي شَا ؤُتْشْمَاسْ ن يمَّاشْ نِيغْ ؤُتْشْمَاسْ ن بَابَاشْ، مِينْزِي \add خنِّي\add* إِسّْفطَّاحْ \add بْنَاذمْ\add* ڒْعَارْ ن رَادْجْ نّسْ. نِيثْنِي أَذْ أَرْبُونْ ڒْمُوعْصِييّثْ نْسنْ. \x ◘ \xo 20:‏19 \xt لَاوِي 18‏:‏12، 13\x*  
\v 20 \add مَاڒَا\add* إِجّْ ن ورْيَازْ، ونِّي إِتّطّْصنْ أَكْ-ذعنْثِيسْ، أَقَا إِسّْعُورِّي ڒْعَارْ نعمِّيسْ، أَذْ أَرْبُونْ نِيثْنِي ڒْمُوعْصِييّثْ نْسنْ. أَذْ مّْثنْ بْڒَا ثَارْوَا. \f ◼ \fr 20:‏20 \ft \+bd  %عنْثِيسْ‘\+bd* - أَقَا-ت ذ ثَامْغَارْثْ ن ؤُمَاسْ ن بَابَاسْ.\f*  \x ◘ \xo 20:‏20 \xt لَاوِي 18‏:‏14\x*  
\v 21 \add مَاڒَا\add* إِجّْ ن ورْيَازْ يِيوِي ثَامْغَارْثْ ن ؤُمَاسْ، \add أَقَا\add* مَانْ أَيَا ذ \add أَعذِّي\add* خْ وعْزَاڒْ \add ن ثمْغَارْثْ\add*. أَقَا إِسّْعُورِّي ڒْعَارْ ن ؤُمَاسْ. أَذْ إِڒِينْ بْڒَا إِحنْجِيرنْ.‘ “ \x ◘ \xo 20:‏21 \xt لَاوِي 18‏:‏16\x*   
\b  
\m
\v 22 ”حْضَامْ مَارَّا ثِيوصَّا إِنُو ذ مَارَّا لْفَارَايِيضْ إِنُو ؤُشَا ڭّمْ ثنْثْ، مَاحنْذْ وَارْ كنِّيوْ ثتّْعُوقِّي ثمُّورْثْ مَانِي كنِّيوْ إِ غَا نذْهغْ، حِيمَا أَذْ ذَايسْ ثْزذْغمْ. \x ◘ \xo 20:‏22 \xt لَاوِي 18‏:‏26\x*  
\v 23 وَارْ ڭُّورمْ خْ ثبْرِيذْثْ ن ثْوصَّا ن ڒْڭنْسْ نِّي غَا سُّوفّْغغْ زَّاثْ إِ وُوذمْ نْومْ، مِينْزِي نِيثْنِي ڭِّينْ مَارَّا ثِيمسْڒَايِينْ-أَ ؤُ \add س ؤُيَا\add* شَارّْهغْ ثنْ. \x ◘ \xo 20:‏23 \xt لَاوِي 18‏:‏3، 30\x*  
\v 24 نشّْ نِّيغْ أَومْ: كنِّيوْ أَذْ ثْوَارْثمْ ثَامُّورْثْ نْسنْ ؤُشَا أَذْ أَومْ ت-إِ-د وْشغْ ذ ڒْوَارْثْ، إِشْثْ ن ثمُّورْثْ إِفيّْضنْ س ؤُغِي ذ ثَامّنْثْ. نشّْ ذ سِيذِي، أَربِّي نْومْ، ونِّي كنِّيوْ إِفَارْزنْ زِي جَارْ ڒڭْنُوسْ. \x ◘ \xo 20:‏24 \xt ؤُف. 3‏:‏8\x*   
\m
\v 25 \add خْ ؤُيَا\add* كنِّيوْ أَذْ ثْميّْزمْ جَارْ ڒبْهَايمْ ن ڒحْڒَاڒْ ذ يِينِّي إِخمْجنْ ؤُ جَارْ إِجْضَاضْ إِخمْجنْ ذ يِينِّي ن ڒحْڒَاڒْ. وَارْ سّخْسَارَامْ ڒعْمُوڒْ نْومْ أَكْ-ذ \add شَا\add* ن ڒبْهِيمثْ نِيغْ أَكْ-ذ \add شَا\add* ن وجْضِيضْ نِيغْ أَكْ-ذ \add شَا\add* زِي مَارَّا مِينْ إِتّْبُوعنْ خْ ثمُّورْثْ، \add مَارَّا\add* مِينْ ذ أَومْ حَارّْمغْ، حِيمَا أَذْ ث ثْحسْبمْ ذ ڒخْمجْ.“ \x ◘ \xo 20:‏25 \xt لَاوِي 11‏:‏2؛ أَعَوذ. 14‏:‏4\x*  
\v 26 ”أَقَا كنِّيوْ أَذْ أَيِي ثِيڒِيمْ ذ إِمْقدَّاسنْ، مِينْزِي نشّْ ذ سِيذِي ذ أَمْقدَّاسْ ؤُشَا نشّْ فَارْزغْ كنِّيوْ زِي ڒڭْنُوسْ، حِيمَا أَذْ ثِيڒِيمْ إِنُو.   
\m
\v 27 مَاڒَا إِجّْ ن ورْيَازْ نِيغْ إِشْثْ ن ثمْغَارْثْ غَارسْ بُوحْبڒْ ن ؤُعزّمْ ن إِمتَّانْ نِيغْ ن ثْڭزَّانْثْ، \add خنِّي\add* أَذْ تّْوَانْغنْ نِيشَانْ. أَذْ ثنْ أَرجْمنْ. إِذَامّنْ نْسنْ \add أَقَا أَثنْ\add* خَاسنْ.“ \x ◘ \xo 20:‏27 \xt أَعَوذ. 18‏:‏10؛ 1 صم. 28‏:‏7\x*   
\b  
\b  
\m  
\c 21
\s1 أَسِيزْذڭْ ن إِكهَّاننْ  
\m
\v 1 إِنَّا سِيذِي إِ مُوسَا: ”سِيوڒْ أَكْ-ذ إِكهَّاننْ، أَرَّاوْ ن هَارُونْ، ؤُشَا إِنِي أَسنْ: ’وَارْ إِعدّڒْ إِ ؤُڒَا ذ إِجّْ \add زَّايْومْ\add* أَذْ إِسّخْمجْ إِخفْ نّسْ س إِجّْ ن ؤُمتِّينْ جَارْ ڒْڭنْسْ نّسْ.  
\v 2 مْغِيرْ س رَادْجْ نّسْ يُوذْسنْ، س يمَّاسْ نِيغْ س بَابَاسْ نِيغْ س مِّيسْ نِيغْ س يدْجِيسْ نِيغْ س ؤُمَاسْ.  
\v 3 ؤُڒَا س ؤُتْشْمَاسْ نِّي ذ ثَاعْزَارْشْثْ، ثنِّي ذ ڒَادْجْ نّسْ يُوذْسنْ ؤُ وَارْ غَارسْ ثُوغِي ورْيَازْ، أَقَا إِعدّڒْ أَذْ زَّايسْ إِسّخْمجْ إِخفْ نّسْ.  
\v 4 بَابْ \add ن ثَادَّارْثْ\add* وَارْ إِسّْخمَّاجْ إِخفْ نّسْ جَارْ ڒْڭنْسْ نّسْ. س ؤُيَا إِتّْوَافْ إِسّخْسَارْ إِخفْ نّسْ.“   
\m
\v 5 ”وَارْ تّڭّنْ شَا ن ومْشَانْ إِقُوشَّارْ خْ إِزدْجِيفْ نْسنْ، ؤُ وَارْ تّْحفِّينْ طَّارْفْ ن ثْمَارْثْ نْسنْ ؤُ وَارْ شَارّْضنْ أَشَارّضْ ذڭْ ويْسُومْ نْسنْ. \x ◘ \xo 21:‏5 \xt لَاوِي 19‏:‏27؛ إِرْم. 9‏:‏25؛ 25‏:‏23؛ 49‏:‏32\x*  
\v 6 أَذْ إِڒِينْ ذ إِمْقدَّاسنْ إِ أَربِّي نْسنْ ؤُشَا وَارْ فطّْحنْ إِسمْ ن أَربِّي نْسنْ، مِينْزِي أَقَا ذ نِيثْنِي إِ إِتَّاوْينْ ثِيوْهِيبِينْ ن ثْمسِّي غَارْ أَربِّي، ثِينِّي ذ مَاشَّا ن أَربِّي نْسنْ. س ؤُيَا أَذْ إِڒِينْ ذ إِمْقدَّاسنْ.  
\v 7 وَارْ إِعدّڒْ أَذْ أَوْينْ ثَامْغَارْثْ نِّي إِدْجَانْ ذ لْفَاسْذَا نِيغْ إِشْثنْ ثتّْوَاغْصبْ. ؤُڒَا ذ إِشْثْ ن ثمْغَارْثْ نِّي إِتّْوَادْجْفنْ زڭْ ورْيَازْ نّسْ، وَارْ ت تِّيوْينْ، مِينْزِي \add أَكهَّانْ\add* ذ أَمْقدَّاسْ إِ أَربِّي نّسْ.  
\v 8 أَذْ ث ثْحسْبذْ ذ أَمْقدَّاسْ، مِينْزِي نتَّا إِتَّاوِي مَاشَّا ن أَربِّي نّشْ. أَذْ يِيڒِي ذ أَمْقدَّاسْ إِ شكْ، مِينْزِي نشّْ ذ أَمْقدَّاسْ، \add نشّْ ذ\add* سِيذِي ونِّي كنِّيوْ إِسّْقدّْسنْ.“   
\m
\v 9 ”مَاڒَا يدْجِيسْ ن إِجّْ ن ورْيَازْ \add نِّي إِدْجَانْ ذ\add* أَكهَّانْ ثسّفْضحْ إِخفْ نّسْ س فَارْقْ-شّْغڒْ \add نّسْ\add*، \add خنِّي\add* أَقَا ثسّفْضحْ بَابَاسْ ؤُشَا إِتّْخصَّا أَسْ أَذْ ثتّْوَاسّشْمضْ س ثْمسِّي.“   
\m
\v 10 ”أَرَّايْسْ ن إِكهَّاننْ جَارْ أَيْثْمَاسْ، ونِّي خْ ؤُزدْجِيفْ نّسْ ثتّْوَافَارّغْ زّشْثْ ن وذْهَانْ ؤُ ونِّي إِتّْوَاڒقّْمنْ، مَاحنْذْ أَذْ يَارْضْ أَرُّوضْ \add ن ؤُكهَّانْ\add*، نتَّا وَارْ إِزمَّارْ أَذْ إِضْڒقْ إِ \add ؤُشُوَّافْ خْ\add* ؤُزدْجِيفْ نّسْ نِيغْ أَذْ إِشَارّڭْ أَرُّوضْ نّسْ.  
\v 11 وَارْ إِعدّڒْ أَذْ د-إِقَارّبْ غَارْ إِجّْ ن ؤُمتِّينْ، \add عَاذْ\add* س بَابَاسْ ذ يمَّاسْ وَارْ إِعدّڒْ أَذْ إِسّخْمجْ إِخفْ نّسْ.  
\v 12 وَارْ إِتّفّغْ زِي زَّاوشْثْ إِقدّْسنْ، حِيمَا وَارْ إِسّخْسَارَا زَّاوشْثْ إِقدّْسنْ ن أَربِّي، مِينْزِي تَّاجْ \add ن وعْزَاڒْ\add* ن زّشْثْ ن وذْهَانْ ن أَربِّي نّسْ أَقَا-ث خَاسْ. نشّْ ذ سِيذِي!  
\v 13 أَذْ يَاوِي إِشْثْ ن ثعْزَارشْثْ ذ ثَامْغَارْثْ.  
\v 14 وَارْ إِتِّيوِي ثَاجَّاتْشْ نِيغْ ثَاندْجَافْثْ نِيغْ ثنِّي إِتّْوَاغصْبنْ \add ذ ثَامْغَارْثْ\add*، مَاشَا أَذْ يَاوِي إِشْثْ ن ثعْزَارشْثْ زِي ڒْڭنْسْ نّسْ ذ ثَامْغَارْثْ.  
\v 15 وَارْ إِسّخْسَارَا زَّارِيعثْ نّسْ جَارْ ڒْڭنْسْ نّسْ، مِينْزِي نشّْ ذ سِيذِي، ونِّي ث إِسّْقدّْسنْ.“   
\b  
\m
\v 16 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 17 ”سِيوڒْ أَكْ-ذ هَارُونْ، إِنِي: ’ؤُڒَا ذ إِجّْ زِي زَّارِيعثْ نّشْ ذِي \add مَارَّا\add* جِّيڒَاثْ نْسنْ إِ ذِي إِدْجَا شَا ن ؤُنعْضَابْ، أَذْ د-إِقَارّبْ، حِيمَا أَذْ يَاوِي مَاشَّا \add ن ثوْهِيبْثْ\add* ن أَربِّي نّسْ.  
\v 18 مِينْزِي ؤُڒَا ذ إِجّْ ن ورْيَازْ وَارْ د-إِتّْقَارِّيبْ شَا س يِيجّْ ن ڒْعِيبْ، مَا ذ أَذَارْغَاڒْ إِ إِدْجَا نِيغْ ذ أَقِيذَارْ نِيغْ س شَا وَارْ إِحْڒِي نِيغْ غَارسْ صِّيفثْ ثْفَارْغْ  
\v 19 نِيغْ إِجّْ ن ورْيَازْ يَارْژْ أَسْ ؤُضَارْ نِيغْ أَفُوسْ  
\v 20 نِيغْ بُو-ثعْرُورْثْ نِيغْ \add حذْ يَاڒْوسْ ذِي شَا ن\add* يِيجّْ ن تّجَّاڒْ نِيغْ س إِشْثْ ن ثِيطّْ ثُوفّْ نِيغْ س جْذَامْ نِيغْ س إِشْثْ ن شَّامثْ ثخْسَارْ نِيغْ س إِقدْجَاڒنْ إِذْڭذْڭنْ.  
\v 21 وَارْ إِعدّڒْ إِ ؤُڒَا ذ إِجّْ ن ورْيَازْ زِي زَّارِيعثْ ن ؤُكهَّانْ هَارُونْ، ونِّي ذِي إِدْجَا شَا ن ڒْعِيبْ، أَذْ إِرحّڭْ، مَاحنْذْ أَذْ إِقدّمْ ثِيوْهِيبِينْ ن ثْمسِّي ن سِيذِي. أَقَا ذَايسْ أَنعْضَابْ، وَارْ إِزمَّارْ أَذْ إِفّغْ مَاحنْذْ أَذْ إِقدّمْ مَاشَّا \add ن ثوْهِيبْثْ\add* ن أَربِّي نّسْ.  
\v 22 زِي مَاشَّا \add ن ثوْهِيبْثْ\add* ن أَربِّي نّسْ إِعدّڒْ أَذْ زَّايسْ يشّْ، أَمْ زِي مِينْ إِدْجَانْ إِقدّْسنْ قَاعْ أَمْ زِي مِينْ إِقدّْسنْ.  
\v 23 مَاشَا وَارْ إِعدّڒْ أَذْ د-إِقَارّبْ غَارْ ؤُڒحَّافْ ؤُڒَا غَارْ ؤُعَالْطَارْ، مِينْزِي ذَايسْ إِشْثْ ن ؤُنعْضَابْ، حِيمَا وَارْ إِسّخْسَارَا ثِيزَاوِييِّينْ إِقدّْسنْ إِنُو، مِينْزِي نشّْ ذ سِيذِي ونِّي ثنْ إِسّْقدّْسنْ.‘ “   
\m
\v 24 \add أَمُّو\add* إِ إِسِّيوڒْ مُوسَا أَكْ-ذ هَارُونْ ؤُ أَكْ-ذ وَارَّاوْ نّسْ ؤُ أَكْ-ذ مَارَّا أَيْثْ ن إِسْرَائِيل.   
\b  
\b  
\m  
\c 22
\m
\v 1 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 2 ”سِيوڒْ أَكْ-ذ هَارُونْ ؤُ أَكْ-ذ وَارَّاوْ نّسْ، مَاحنْذْ، \add مَاڒَا إِتّْخصَّا\add*، وَارْ تَّاكّْوَاضنْ غَارْ ثوْهِيبِينْ إِقدّْسنْ ن أَيْثْ ن إِسْرَائِيل ثِينِّي ذ أَيِي سّْقدّْسنْ، حِيمَا وَارْ سّخْسَارَانْ إِسمْ أَمْقدَّاسْ إِنُو. نشّْ ذ سِيذِي!   
\m
\v 3 إِنِي أَسنْ: ’مَارَّا أَرْيَازْ زِي زَّارِيعثْ نْومْ ذِي \add مَارَّا\add* جِّيڒَاثْ نْومْ، ونِّي د غَا إِقَارّْبنْ غَارْ ثوْهِيبِينْ إِقدّْسنْ، ثِينِّي سّْقدّْسنْ أَيْثْ ن إِسْرَائِيل إِ سِيذِي، أَمْ إِخْمجْ نتَّا، أَقَا أَذْ إِتّْوَاقسّْ ڒعْمَارْ نِّي زِي زَّاثْ إِ وُوذمْ إِنُو. نشّْ ذ سِيذِي.  
\v 4 ؤُڒَا ذ إِجّنْ زِي زَّارِيعثْ ن هَارُونْ نِّي ذِي إِدْجَا ڒْبَارْصْ نِيغْ ونِّي غَارْ إِدْجَا ؤُسيّڒْ، وَارْ إِتّتّْ زِي ثوْهِيبِينْ إِقدّْسنْ أَڒْ غَا يِيڒِي إِزْذِيڭْ. ونِّي إِحَاذَانْ شَا زِي مِينْ إِتّْوَاسّْخمْجنْ س إِجّْ ن ؤُمتِّينْ نِيغْ س إِجّْ ن ورْيَازْ نِّي ثُوغَا س ؤُسيّڒْ ن وَادْجُو، \x ◘ \xo 22:‏4 \xt لَاوِي 15‏:‏2\x*  
\v 5 نِيغْ س إِجّْ ن ورْيَازْ نِّي إِحَاذَانْ شَا مِينْ إِتّْبُوعنْ إِ زِي إِذْوڒْ إِخْمجْ، نِيغْ \add إِحَاذَا\add* إِجّْ ن بْنَاذمْ إِ زِي إِذْوڒْ إِخْمجْ س مَامّشْ مَا ثڭَّا ثخْمُوجِي نّسْ،  
\v 6 ڒعْمَارْ نِّي إِحَاذَانْ ثْمسْڒَاشْثْ نِيغْ بْنَاذمْ نِّي أَذْ يِيڒِي إِخْمجْ أَڒْ ثَامذِّيثْ، وَارْ إِتّتّْ زِي ثوْهِيبِينْ إِقدّْسنْ، مْغِيرْ أَوَارْنِي إِ غَا إِسِّيرْذْ أَرِّيمثْ نّسْ س وَامَانْ.  
\v 7 \add خْمِي\add* د غَا ثغْڒِي ثْفُوشْثْ، أَذْ يِيڒِي إِزْذِيڭْ. أَوَارْنِي أَيَا أَذْ يشّْ زِي ثوْهِيبِينْ إِقدّْسنْ، مِينْزِي أَقَا أَثنْثْ ذ مَاشَّا نّسْ.  
\v 8 وَارْ إِتّتّْ زڭْ إِشْثْ ن ڒْخشْبثْ نِيغْ زڭْ \add إِجّْ ن ؤُمُودَّارْ\add* إِمزّْقنْ، مِينْزِي زَّايسْ إِ غَا إِسّخْمجْ إِخفْ نّسْ، نشّْ ذ سِيذِي! \x ◘ \xo 22:‏8 \xt ؤُف. 22‏:‏31؛ لَاوِي 17‏:‏15؛ حِز. 44‏:‏31\x*  
\v 9 أَذْ حْضَانْ مِينْ خفْ ثنْ وصِّيغْ، حِيمَا وَارْ سَّاربُّونْ خْ يِيخفْ نْسنْ دّنْبْ ؤُ خنِّي أَذْ زَّايسْ مّْثنْ، خْمِي غَا سّْعِيدْجْثنْ أَيَا. نشّْ ذ سِيذِي ونِّي ثنْ إِسّْقدّْسنْ.   
\m
\v 10 ؤُڒَا ذ إِجّْ ن ؤُبَارَّانِي وَارْ إِتّتّْ زِي ثوْهِيبْثْ إِقدّْسنْ. أَمْعزّبْ \add إِ إِزدّْغنْ\add* جَارْ إِكهَّاننْ ؤُڒَا ذ أَشوَّاڒْ وَارْ تّتّنْ زِي ثوْهِيبْثْ إِقدّْسنْ.  
\v 11 \add مَاشَا\add* مَاڒَا أَكهَّانْ إِسْغَا إِجّْ ن بْنَاذمْ س نُّوقَارْثْ نّسْ، أَقَا إِعدّڒْ إِ وَا مَاحنْذْ أَذْ يشّْ زِي مَاشَّا \add ن ثوْهِيبْثْ\add* نّسْ، ؤُڒَا إِ يِينِّي د-إِتّْوَاخڒْقنْ ذِي ثَادَّارْثْ نّسْ.  
\v 12 مَاڒَا يدْجِيسْ ن ؤُكهَّانْ ثذْوڒْ ذ ثَامْغَارْثْ ن إِجّْ ن ؤُبَارَّانِي، وَارْ ثتّتّْ شَا زِي \add ثوْهِيبْثْ\add* إِ د-إِتّْوَاسّْڭعّْذنْ زِي ثوْهِيبِينْ إِقدّْسنْ.  
\v 13 \add مَاشَا\add* مَاڒَا يدْجِيسْ ن ؤُكهَّانْ أَقَا-ت ذ ثَاجَّاتْشْ نِيغْ ثتّْوَادْجفْ \add زڭْ ورْيَازْ نّسْ\add* ؤُشَا وَارْ غَارسْ أَحنْجِيرْ ؤُشَا ثذْوڒْ-د غَارْ ثَادَّارْثْ ن بَابَاسْ، أَمْ ذِي ثمْژِي نّسْ، \add خنِّي\add* أَذْ ثشّْ زِي مَاشَّا \add ن ثوْهِيبْثْ\add* ن بَابَاسْ، \add مَاشَا\add* ؤُڒَا ذ إِجّْ ن ؤُبَارَّانِي أَذْ زَّايسْ يشّْ. \x ◘ \xo 22:‏13 \xt لَاوِي 10‏:‏14\x*   
\m
\v 14 مَاڒَا شَا ن يِيجّنْ إِشَّا زِي ثوْهِيبْثْ إِقدّْسنْ س ؤُودَّارْ، \add خنِّي\add* أَذْ غَارسْ يَارْنِي ثَاسْغَارْثْ ن ثخْمُوسشْثْ ؤُشَا أَذْ يَارّْ ثَاوْهِيبْثْ إِقدّْسنْ غَارْ ؤُكهَّانْ.  
\v 15 وَارْ إِعدّڒْ أَذْ سّخْسَارنْ ثِيوْهِيبِينْ إِقدّْسنْ ن أَيْثْ ن إِسْرَائِيل، ثِينِّي سّْڭعّْذنْ نِيثْنِي غَارْ سِيذِي،  
\v 16 \add أَڒَامِي\add* إِ غَا سَّارْبُونْ أَمَارْوَاسْ ن ڒْمُوعْصِييّثْ \add خْ أَيْثْ ن إِسْرَايِيلْ\add*، ؤُمِي غَا شّنْ نِيثْنِي زِي ثوْهِيبِينْ نْسنْ إِقدّْسنْ \add إِ ذ يَاوْينْ نِيثْنِي س يِيخفْ نْسنْ\add*، مِينْزِي نشّْ ذ سِيذِي، ونِّي ثنْ إِسّْقدّْسنْ.‘ “   
\b  
\m  
\s1 ثِيغَارْصَا إِ إِطّوْعنْ أَيْثْ ن إِسْرَائِيل  
\m
\v 17 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا إِنَّا:   
\m
\v 18 ”سِيوڒْ أَكْ-ذ هَارُونْ ذ وَارَّاوْ نّسْ ؤُ أَكْ-ذ مَارَّا أَيْثْ ن إِسْرَائِيل ؤُشَا إِنِي أَسنْ: ’ذ مَانْ أَيَا إِڭُّورْ إِ كُوڒْ إِجّنْ زِي ثَادَّارْثْ ن إِسْرَائِيل ؤُ إِ إِبَارَّانِييّنْ ذِي إِسْرَائِيل، ونِّي إِ غَا يِيوْينْ ثَاوْهِيبْثْ نّسْ ثنِّي د-يُوسِينْ أَكْ-ذ مَارَّا ڒوْعُوذْ نْسنْ ذ مَارَّا ثِيوْهِيبِينْ نْسنْ نِّي وْشِينْ س ڒْخَاضَارْ، ثنِّي قدّْمنْ نِيثْنِي ذ ثَاغَارْصْثْ ن وشْمَاضْ إِ سِيذِي.  
\v 19 مَاحنْذْ أَذْ كنِّيوْ يَارّْ أَذْ ثِيڒِيمْ ثتّْوَاقبّْڒمْ إِتّْخصَّا أَذْ ثِيڒِي ثوْهِيبْثْ ذ إِجّْ ن ووْثمْ إِشْنَانْ قَاعْ زڭْ إِفُونَاسنْ نِيغْ زڭْ إِزْمَارنْ نِيغْ زڭْ إِشَارِّييّنْ.  
\v 20 وَارْ إِعدّڒْ أَذْ ثْقدّْممْ شَا \add ن ڒْمَاڒْ\add* ذَايسْ أَنعْضَابْ، مِينْزِي أَيَا وَارْ كنِّيوْ د-إِتَّارِّي أَذْ ذَايْومْ إِتّْوَافْ أَرْضَا.   
\m
\v 21 مَاڒَا إِجّْ ن ورْيَازْ إِقدّمْ إِشْثْ ن ثْغَارْصْثْ ن ڒهْنَا غَارْ سِيذِي، مَاحنْذْ أَذْ إِكمّڒْ إِجّْ ن لْوَاعْذْ نِيغْ أَمْ يِيشْثْ ن ثوْهِيبْثْ س ڒْخَاضَارْ، \add خنِّي أَذْ ثِيڒِي ثَاغَارْصْثْ ذ إِجّْ ن ؤُمُودَّارْ\add* إِشْنَانْ قَاعْ زِي ڒبْهَايمْ نِيغْ زڭْ وُودْجِي، حِيمَا أَذْ ذَايسْ إِتّْوَافْ أَرْضَا. وَارْ إِعدّڒْ أَذْ ذَايسْ يِيڒِي ؤُڒَا ذ إِجّْ ن ڒْعِيبْ. \x ◘ \xo 22:‏21 \xt أَعَوذ. 15‏:‏21؛ 17‏:‏1\x*  
\v 22 مِينْ إِدْجَانْ ذ أَذَارْغَاڒْ نِيغْ مِينْ إِتّْوَارْژنْ نِيغْ مِينْ ذِي إِدْجَانْ إِجّْ ن ؤُيزِّيمْ يَارزْمنْ نِيغْ مِينْ ذِي دْجَانْثْ ثْفِيضْڒِيوِينْ نِيغْ جْذَامْ نِيغْ شَّامثْ ثخْسَارْ وَارْ ث-إِ-د-ثسّْقَارَّابمْ شَا غَارْ سِيذِي ؤُشَا وَارْ زَّايسْ تِّيوْيمْ ثَاوْهِيبْثْ ن ثْمسِّي إِ سِيذِي خْ ؤُعَالْطَارْ.   
\m
\v 23 \add مَاشَا\add* إِجّْ ن ؤُفُونَاسْ نِيغْ إِجّنْ زڭْ وُودْجِي إِ إِقبْحنْ زِي سِّيبّثْ ن ثُوزّڭَّارْثْ نِيغْ ثُوقُوضضْثْ أَطَّاسْ، إِعدّڒْ أَذْ ث-إِ-د-ثسّْوجْذذْ أَمْ يِيشْثْ ن ثوْهِيبْثْ س ڒْخَاضَارْ، مَاشَا وَارْ ذَايسْ إِتّْوَافْ أَرْضَا إِ يِيجّْ ن لْوَاعْذْ.  
\v 24 مِينْ إِذْڭدّْڭنْ، مِينْ إِڒبْزنْ، مِينْ إِمزّْقنْ، مِينْ إِتّْوَاقسّنْ وَارْ ث تِّيوْيمْ غَارْ سِيذِي، وَارْ تّڭّمْ \add أَيَا\add* ذِي ثمُّورْثْ نْومْ.  
\v 25 زڭْ ؤُفُوسْ ن مِّيسْ ن ؤُبَارَّانِي وَارْ تّْقدَّاممْ شَا زِي مَارَّا مَانْ أَيَا ؤُڒَا ذ \add إِشْثْ ن ثوْهِيبْثْ ذ مَاشَّا\add* إِ أَربِّي، مِينْزِي ذَايسْ ڒْغشّْ نْسنْ ؤُڒَا ذ نّقْصَانْ نّسْ، \add مَانْ أَيَا\add* وَارْ إِتّْوَاقبِّيڒْ شَا ذِي طّْوعْ نْومْ.‘ “   
\m
\v 26 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 27 ”خْمِي د-إِخدْجقْ ؤُفُونَاسْ نِيغْ إِزْمَارْ نِيغْ إِغَايْضْ، \add خنِّي\add* أَذْ يِيڒِي سَاذُو \add حطُّو\add* ن يمَّاسْ سبْعَا ن وُوسَّانْ. زڭْ وَاسّْ وِيسّْ ثْمنْيَا ؤُ أَوَارْنِي أَسْ أَذْ إِصْڒحْ إِ يَارْضَا أَمْ ثوْهِيبْثْ ن ثْمسِّي إِ سِيذِي.  
\v 28 وَارْ إِعدّڒْ أَذْ ثْغَارْصذْ إِ ؤُفُونَاسْ نِيغْ إِ يِيجّنْ زڭْ وُودْجِي أَكْ-ذ مِّيسْ ذڭْ وَاسّْ ذ إِجّْ.  
\v 29 خْ مِينِّي ثخْسمْ أَذْ ثْقدّْممْ ثَاوْهِيبْثْ ن ؤُقَاذِي إِ سِيذِي، قدّمْ \add خنِّي\add* مِينْ إِصڒْحنْ إِ يَارْضَا نْومْ.  
\v 30 أَذْ ثتّْوَاشّْ ذڭْ وَاسّْ نِّي نِّيثْ. وَارْ زَّايسْ تّجِّيمْ شَا أَڒْ صّْبحْ. نشّْ ذ سِيذِي! \x ◘ \xo 22:‏30 \xt لَاوِي 7‏:‏15\x*   
\m
\v 31 أَذْ ثحْضَامْ ثِيوصَّا إِنُو ؤُشَا أَذْ زَّايْسنْثْ ثڭّمْ. نشّْ ذ سِيذِي!   
\m
\v 32 وَارْ سّخْسَارَامْ إِسمْ إِنُو إِقدّْسنْ، \add حِيمَا\add* نشّْ أَذْ تّْوَاقدّْسغْ ذِي ڒْوسْثْ ن أَيْثْ ن إِسْرَائِيل. نشّْ ذ سِيذِي، ونِّي كنِّيوْ إِسّْقدّْسنْ،  
\v 33 ذ ونِّي كنِّيوْ د-إِسُّوفّْغنْ زِي ثمُّورْثْ ن مِيصْرَا، حِيمَا أَذْ إِڒِيغْ ذ أَربِّي إِ كنِّيوْ. نشّْ ذ سِيذِي!‘ “   
\b  
\b  
\m  
\c 23
\s1 ڒعْيُوذَاثْ ن سِيذِي  
\m
\v 1 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 2 ”سِيوڒْ أَكْ-ذ أَيْثْ ن إِسْرَائِيل ؤُشَا إِنِي أَسنْ: ’ڒعْيُوذَاثْ إِتّْوَاڭّنْ ن سِيذِي، إِنِّي خْ غَا ثْبَارّْحمْ، أَذْ إِڒِينْ ذ إِمُونِيثنْ إِقدّْسنْ، أَقَا أَثنْثْ ذ ڒعْيُوذَاثْ إِنُو إِتّْوَاڭّنْ.  
\v 3 ستَّا ن وُوسَّانْ أَذْ ثْخذْممْ، مَاشَا ذڭْ \bd وَاسّْ وِيسّْ سبْعَا أَذْ يِيڒِي ذ سّبْثْ\bd*، أَرَّاحثْ إِمُونْ، إِجّْ ن ؤُمُونِي إِقدّْسنْ. إِتّْخصَّا وَارْ ذَايسْ ثْخدّْممْ. أَقَا ذ سّبْثْ إِ سِيذِي ذِي مَارَّا ثِيزذِّيغِينْ نْومْ. \x ◘ \xo 23:‏3 \xt ؤُف. 20‏:‏9؛ 23‏:‏12؛ أَعَوذ. 5‏:‏13؛ لك. 13‏:‏14\x*   
\m
\v 4 أَقَا ذ إِنَا ذ ڒعْيُوذَاثْ إِتّْوَاڭّنْ ن سِيذِي، إِمُونِيثنْ إِقدّْسنْ، إِنِّي إِ غَا ثْبَارّْحمْ ذڭْ وُوسَّانْ نْسنْ إِتّْوَاڭّنْ.   
\m
\v 5 ذڭْ ؤُيُورْ أَمزْوَارُو، ذڭْ \add وَاسّْ\add* وِيسّْ أَرْبعْطَاشْ ن ؤُيُورْ، جَارْ بدُّو ن وزْينْ ن وَاسّْ أَڒْ د-ثوْضَا ثْمذِّيثْ، أَذْ ثِيڒِي ذ \bd \+bdit ثْغَارْصْثْ ن\+bdit* ؤُسعْذُو ن سِيذِي\bd*. \x ◘ \xo 23:‏5 \xt ؤُف. 12‏:‏18؛ 23‏:‏15؛ ڒخْڒ. 28‏:‏16؛ أَعَوذ. 16‏:‏1\x*  
\v 6 ذڭْ وَاسّْ وِيسّْ خمّسْطَاشْ ن ؤُيُورْ نِّيثْ، \add أَذْ يِيڒِي\add* ذ \bd ڒْْعِيذْ ن وغْرُومْ بْڒَا أَنْثُونْ\bd* إِ سِيذِي. سبْعَا ن وُوسَّانْ أَذْ ثشّمْ أَغْرُومْ بْڒَا أَنْثُونْ.  
\v 7 أَسّْ أَمزْوَارْ أَذْ ثڭّمْ إِجّْ ن ؤُمُونِي إِقدّْسنْ. وَارْ تّڭّمْ ؤُڒَا ذ إِشْثْ ن ڒْخذْمثْ إِ إِتّْخصَّانْ أَذْ ثتّْوَاڭّْ.  
\v 8 سبْعَا ن وُوسَّانْ \add كمّْڒنْ\add* أَذْ ثَاوْيمْ إِشْثْ ن ثوْهِيبْثْ ن ثْمسِّي إِ سِيذِي ؤُشَا ذڭْ وَاسّْ وِيسّْ سبْعَا أَذْ ذِينْ يِيڒِي إِجّْ ن ؤُمُونِي إِقدّْسنْ. وَارْ تّڭّمْ ؤُڒَا ذ إِشْثْ ن ڒْخذْمثْ إِ إِتّْخصَّانْ أَذْ ثتّْوَاڭّْ.‘ “   
\m
\v 9 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 10 ”سِيوڒْ أَكْ-ذ أَيْثْ ن إِسْرَائِيل، إِنِي أَسنْ: ’مَاڒَا ثِيوْضمْ غَارْ ثمُّورْثْ نِّي ذ أَومْ غَا وْشغْ ؤُشَا أَذْ ثمْجَارمْ صَّابثْ نّسْ، خنِّي أَذْ ثَاوْيمْ \bd إِشْثْ ن ثْقبِّيضْثْ زِي ثْمزْوَارُوثْ ن صَّابثْ نْومْ\bd* غَارْ ؤُكهَّانْ.  
\v 11 ؤُشَا نتَّا أَذْ إِسّنْهزّْ ثَاقبِّيضْثْ \add نِّي\add* زِي سَّا غَارْ ذَا زَّاثْ إِ وُوذمْ ن سِيذِي، مَاحنْذْ أَذْ ثتّْوَاقبْڒمْ س أَرْضَا. ذِي ثُوفُّوثْ أَوَارْنِي سّبْثْ أَذْ ت إِسّنْهزّْ ؤُكهَّانْ.  
\v 12 ذڭْ وَاسّْ مِينْ ذِي إِ غَا ثنْهزّمْ ثَاقبِّيضْثْ، أَذْ ثسّْوجْذمْ \add عَاوذْ\add* إِجّْ ن إِزْمَارْ إِشْنَانْ قَاعْ ن إِجّْ ن ؤُسڭّْوَاسْ أَمْ يِيشْثْ ن ثْغَارْصْثْ ن وشْمَاضْ إِ سِيذِي.  
\v 13 أَذْ ثِيڒِي ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* زِي ثْنَاينْ ن ثعْشُورَايْ ن إِجّْ ن إِفَا ن وَارنْ أَزْذَاذْ إِخدْجْضنْ س زّشْثْ، أَقَا-ت ذ إِشْثْ ن ثوْهِيبْثْ ن ثْمسِّي س إِشْثْ ن ڒفْوَاحثْ إِتّْفُوحنْ إِ سِيذِي، ؤُ ثَاوْهِيبْثْ نّسْ ن ؤُسيّبْ أَذْ ثِيڒِي ذ بِينُو، إِجّْ ن أَرْبعْ زڭْ إِجّْ ن ؤُهِينُو.  
\v 14 وَارْ تّتّمْ أَغْرُومْ ؤُڒَا ذ ثِيذْرِينْ يُورْفنْ نِيغْ ثِيزِيزَاوِينْ أَڒْ أَسّْ مِينْ ذِي د-ثِيوْيمْ ثَاوْهِيبْثْ نْومْ غَارْ أَربِّي. أَقَا-ت ذ إِشْثْ ن ثوْصيّثْ إِ ڒبْذَا إِ \add مَارَّا\add* جِّيڒَاثْ نْومْ مَانِي مَا ثْزدّْغمْ.   
\m
\v 15 \add أَوَارْنِي أَسْ\add* أَذْ ثْحسْبمْ س ڒْمقْڒُوبْ إِ يِيخفْ نْومْ زِي صّْبحْ أَوَارْنِي إِ سّبْثْ، زڭْ وَاسّْ مِينْ ذِي د-ثِيوْيمْ ثَاقبِّيضْثْ ن ثوْهِيبْثْ ن ونْهزِّي: إِتّْخصَّا أَذْ إِڒِينْ \bd سبْعَا ن وُوسَّانْ ن سّبْثْ كمّْڒنْ\bd*. \x ◘ \xo 23:‏15 \xt أَعَوذ. 16‏:‏9، 10 \x*  
\v 16 أَذْ ثْحسّْبمْ \bd خمْسِينْ ن وُوسَّانْ\bd* أَڒْ ثُوفُّوثْ ن سّبْثْ وِيسّْ سبْعَا. خنِّي أَذْ ثَاوْيمْ إِشْثْ ن ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* ن جْذِيذْ إِ سِيذِي.  
\v 17 أَذْ د-ثَاوْيمْ ثْنَاينْ ن ثشْنِيفِينْ ن وغْرُومْ إِ ونْهزِّي زڭْ إِمُوشَانْ مَانِي ثْزدّْغمْ. أَذْ إِڒِينْثْ زِي ثْنَاينْ ن ثعْشُورَايْ \add ن يِيجّْ ن إِفَا\add* ن وَارنْ أَزْذَاذْ، ڭّْوِينْثْ س ونْثُونْ. أَقَا أَثنْثْ ذ ثِيمنْزَا إِ سِيذِي.  
\v 18 كنِّيوْ أَذْ د-ثسّْقَارّْبمْ أَكْ-ذ وغْرُومْ \add عَاوذْ\add* سبْعَا ن إِزْمَارنْ شْنَانْ قَاعْ ن إِجّْ ن ؤُسڭّْوَاسْ ذ إِجّْ ن ؤُفُونَاسْ - أَمژْيَانْ ن ثْفُونَاسْثْ - ذ ثْنَاينْ ن إِشَارِّييّنْ. أَذْ إِڒِينْ إِ ثْغَارْصْثْ ن وشْمَاضْ إِ سِيذِي أَكْ-ذ ثوْهِيبْثْ نْسنْ \add ن ڒْغِيدْجثْ\add* ذ ثوْهِيبِينْ نْسنْ ن ؤُسيّبْ، \add أَقَا\add* ذ إِشْثْ ن ثوْهِيبْثْ ن ثْمسِّي س إِشْثْ ن ڒفْوَاحثْ إِتّْفُوحنْ إِ سِيذِي.  
\v 19 أَذْ ثسّْوجْذمْ \add عَاوذْ\add* إِجّْ ن ؤُمْيَانْ زڭْ إِغَايْضنْ ذ ثَاغَارْصْثْ ن دّنْبْ ؤُ ثْنَاينْ ن إِزْمَارنْ ن إِجّْ ن ؤُسڭّْوَاسْ ذ ثْغَارْصْثْ نْ ڒهْنَا.  
\v 20 أَذْ ثنْ إِسّنْهزّْ ؤُكهَّانْ أَكْ-ذ وغْرُومْ ن ثَامنْزُوثْ زِي سَّا غَارْ ذَا أَمْ يِيشْثْ ن ثوْهِيبْثْ ن ونْهزِّي زَّاثْ إِ وُوذمْ ن سِيذِي، ؤُڒَا ذ ثْنَاينْ ن إِزْمَارنْ. أَذْ إِڒِينْ قدّْسنْ إِ سِيذِي، إِ ؤُكهَّانْ.  
\v 21 ذڭْ وَاسّْ نِّيثْ أَذْ ثْبَارّْحمْ إِ يِيجّْ ن ؤُمُونِي إِقدّْسنْ. وَارْ تّڭّمْ ؤُڒَا ذ إِشْثْ ن ڒْخذْمثْ إِ إِتّْخصَّانْ أَذْ ثتّْوَاڭّْ. \add أَقَا-ت\add* ذ إِشْثْ ن ثوْصيّثْ إِ ڒبْذَا مَانِي مَا إِ غَا ثْزذْغمْ إِ \add مَارَّا\add* جِّيڒَاثْ نْومْ.   
\m
\v 22 خْمِي غَا ثمْجَارمْ ڒْغِيدْجثْ ن ثمُّورْثْ نْومْ، وَارْ مجَّارْ أَڒْ أَنڭَّارْ ن طَّارْفْ ن ييَّارْ نّشْ، ؤُ مِينْ إِقِّيمنْ ن ڒْغِيدْجثْ نّشْ وَارْ ث ثْكسّذْ شَا. إِتّْخصَّا أَذْ ثجّمْ \add شْوَايْثْ\add* إِ ؤُمزْڒُوضْ ؤُ إِ ؤُبَارَّانِي. نشّْ ذ سِيذِي، أَربِّي نْومْ!‘ “ \x ◘ \xo 23:‏22 \xt لَاوِي 19‏:‏9؛ أَعَوذ. 24‏:‏19\x*   
\b  
\m
\v 23 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 24 ”سِيوڒْ أَكْ-ذ أَيْثْ ن إِسْرَائِيل، إِنِي أَسنْ: ’ذڭْ ؤُيُورْ وِيسّْ سبْعَا، ذڭْ \add وَاسّْ\add* أَمزْوَارُو ن ؤُيُورْ، أَذْ يِيڒِي ذ سّبْثْ إِ كنِّيوْ، \bd إِجّْ ن \+bdit وَاسّْ\+bdit* ن ڒِيذَارثْ أَكْ-ذ ؤُسُوضِي س وسْرُودّحْ \+bdit ذڭْ ؤُيِيشّْ ن إِشَارِّي\+bdit*\bd*، إِجّْ ن ؤُمُونِي إِقدّْسنْ. \x ◘ \xo 23:‏24 \xt ڒخْڒ. 29‏:‏1\x*  
\v 25 وَارْ تّڭّمْ ؤُڒَا ذ إِشْثْ ن ڒْخذْمثْ إِ إِتّْخصَّانْ أَذْ ثتّْوَاڭّْ. أَذْ د-ثسْقَارّْبمْ إِشْثْ ن ثوْهِيبْثْ ن ثْمسِّي إِ سِيذِي.‘ “   
\m
\v 26 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 27 ”ذڭْ \add وَاسّْ\add* وِيسّْعشْرَا ن ؤُيُورْ وِيسّْ سبْعَا أَذْ يِيڒِي ذ \bd أَسّْ ن وصْڒَاحْ\bd*. أَذْ ثڭّمْ إِجّْ ن ؤُمُونِي إِقدّْسنْ إِ كنِّيوْ. أَذْ ثسّْوَاضْعمْ إِخفْ نْومْ ؤُشَا أَذْ ثْقدّْممْ إِشْثْ ن ثوْهِيبْثْ ن ثْمسِّي إِ سِيذِي. \x ◘ \xo 23:‏27 \xt لَاوِي 16‏:‏29، 31؛ ڒخْڒ. 29‏:‏7\x*  
\v 28 وَارْ تّڭّمْ ؤُڒَا ذ إِشْثْ ن ڒْخذْمثْ ذڭْ وَاسّْ نِّي نِّيثْ، مِينْزِي أَقَا-ث ذ أَسّْ ن وصْڒَاحْ، مَاحنْذْ أَذْ إِتّْوَاڭّْ وصْڒَاحْ إِ كنِّيوْ زَّاثْ إِ وُوذمْ ن سِيذِي، أَربِّي نْومْ.  
\v 29 مِينْزِي مَارَّا بْنَاذمْ نِّي وَارْ إِسّْوَاضْعنْ إِخفْ نّسْ ذڭْ وَاسّْ نِّي نِّيثْ، أَذْ إِتّْوَاقسّْ زِي ڒْڭنْسْ نّسْ.  
\v 30 كُوڒْ بْنَاذمْ نِّي إِ غَا إِڭِّينْ شَا ن ڒْخذْمثْ ذڭْ وَاسّْ نِّي نِّيثْ، نشّْ أَذْ ثحِّيغْ بْنَاذمْ نِّي زِي ڒْوسْطْ ن ڒْڭنْسْ نّسْ. \f ◼ \fr 23:‏30 \ft \+bd ’بْنَاذمْ‘\+bd* - س ثْعِيبْرَانِيثْ ’ڒعْمَارْ‘.\f*  
\v 31 وَارْ تّڭّمْ ؤُڒَا ذ إِشْثْ نْ ڒْخذْمثْ. \add أَقَا-ت\add* ذ إِشْثْ ن ثوْصيّثْ إِ ڒبْذَا إِ \add مَارَّا\add* جِّيڒَاثْ نْومْ مَانِي مَا إِ غَا ثْزذْغمْ.  
\v 32 أَذْ يِيڒِي ذ إِجّْ ن سّبْثْ ن أَرَّاحثْ ثْمُونْ إِ كنِّيوْ. أَذْ إِڒِينْ ڒعْمُورْ نْومْ حْصَارنْ. ذڭْ \add وَاسّْ\add* وِيسّْ ثسْعَا ن ؤُيُورْ، ذِي دْجِيڒثْ، زڭْ ؤُعشِّي غَارْ ؤُعشِّي نّغْنِي أَذْ ثحْضَامْ أَرَّاحثْ نْومْ ن سّبْثْ.“   
\m
\v 33 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 34 ”سِيوڒْ أَكْ-ذ أَيْثْ ن إِسْرَائِيل ؤُشَا إِنِي: ’ذڭْ وَاسّْ وِيسّْ خمّسْطَاشْ ن ؤُيُورْ وِيسّْ سبْعَا \add أَذْ يِيڒِي\add* ذ \bd ڒْْعِيذْ ن إِعُوشُّوثنْ\bd* إِ سِيذِي، سبْعَا ن وُوسَّانْ. \x ◘ \xo 23:‏34 \xt ؤُف. 23‏:‏16؛ ڒخْڒ. 29‏:‏12؛ أَعَوذ. 16‏:‏15\x*  
\v 35 ذڭْ وَاسّْ أَمزْوَارُو أَذْ يِيڒِي يِيجّْ ن ؤُمُونِي إِقدّْسنْ. وَارْ تّڭّمْ ؤُڒَا ذ إِشْثْ ن ڒْخذْمثْ إِ إِتّْخصَّانْ أَذْ ثتّْوَاڭّْ.  
\v 36 سبْعَا ن وُوسَّانْ أَذْ ثْقدّْممْ ثِيوْهِيبِينْ ن ثْمسِّي غَارْ سِيذِي. ذڭْ وَاسّْ وِيسّْ ثْمنْيَا أَذْ ذِينْ يِيڒِي يِيجّْ ن ؤُمُونِي إِقدّْسنْ ؤُشَا أَذْ ثَاوْيمْ إِشْثْ ن ثوْهِيبْثْ ن ثْمسِّي إِ سِيذِي. أَقَا ذ إِجّْ ن ؤُمُونِي إِفَارْزنْ \add ذ أَمْقدّسْ\add*، وَارْ تّڭّمْ ؤُڒَا ذ إِشْثْ نْ ڒْخذْمثْ إِ إِتّْخصَّانْ أَذْ ثتّْوَاڭّْ. \x ◘ \xo 23:‏36 \xt يُوح. 7‏:‏37\x*   
\m
\v 37 ثِينَا ذ ڒعْيُوذَاثْ إِتّْوَاڭّنْ ن سِيذِي، ثِينِّي زِي غَا ثْبَارّْحمْ ذ إِمُونِيثنْ إِقدّْسنْ، مَاحنْذْ أَذْ ثْقدّْممْ إِشْثْ ن ثوْهِيبْثْ ن ثْمسِّي غَارْ سِيذِي، إِشْثْ ن ثْغَارْصْثْ ن وشْمَاضْ ذ إِشْثْ ن ثوْهِيبْثْ \add ن ڒْغِيدْجثْ،\add* إِشْثْ ن ثوْهِيبْثْ إِ ثْغَارْصْثْ ذ ثوْهِيبِينْ ن ؤُسيّبْ، كُوڒْ أَسّْ مِينْ إِتّْوَاڭّنْ إِ وَاسّْ نِّي،  
\v 38 بَارَّا إِ \add ثْغَارْصَا نْومْ ن\add* وُوسَّانْ ن سّبْثْ ن سِيذِي ذ ثوْهِيبِينْ نْومْ ن لْوُوعُوذْ نْومْ ذ ثوْهِيبِينْ نْومْ س ڒْخَاضَارْ، إِنِّي \add ثتّْنُوممْ\add* أَذْ ثنْثْ ثوْشمْ إِ سِيذِي.  
\v 39 مَاشَا ذڭْ وَاسّْ وِيسّْ خمّسْطَاشْ ن ؤُيُورْ وِيسّْ سبْعَا، خْمِي غَا ثسّْمُونمْ ڒْغِيدْجثْ ن ثمُّورْثْ، \add خنِّي\add* أَذْ ثْعيّْذمْ ڒْعِيذْ ن سِيذِي، سبْعَا ن وُوسَّانْ. ذڭْ وَاسّْ أَمزْوَارُو \add أَذْ يِيڒِي\add* يِيجّْ ن وَاسّْ ن سّبْثْ ؤُڒَا ذڭْ وَاسّْ وِيسّْ ثْمنْيَا \add أَذْ ذِينْ يِيڒِي\add* يِيجّْ ن وَاسّْ ن سّبْثْ.  
\v 40 ذڭْ وَاسّْ أَمزْوَارُو أَذْ ثكْسِيمْ ڒْغِيدْجثْ ن ثْشجُّورَا إِشوَّارنْ: ثِيسضْوِينْ ن ثِينِي ذ ثِيسضْوِينْ ن ثْشجُّورَا س ثفْرَايْ أَطَّاسْ ذ \add ثْسضْوِينْ\add* ن ثْشجَّارْثْ ن ثْنمْڒَاتْشْ ن ثْغزْرَاثِينْ. سبْعَا ن وُوسَّانْ أَذْ ثْفَارْحمْ زَّاثْ إِ وُوذمْ ن سِيذِي، أَربِّي نْومْ. \f ◼ \fr 23:‏40 \ft \+bd ’ثَاشجَّارْثْ ن ثْنمْڒَاتْشْ‘\+bd* - س ثْعِيبْرَانِيثْ ’ثَاشجَّارْثْ ن يغْزَارْ‘.\f*  
\v 41 أَذْ ثْعيّْذمْ ڒْعِيذْ \add ن إِعُوشُّوثنْ\add* سبْعَا ن وُوسَّانْ ذڭْ ؤُسڭّْوَاسْ إِ سِيذِي. \add أَقَا-ت\add* ذ إِشْثْ ن ثوْصيّثْ إِ ڒبْذَا إِ \add مَارَّا\add* جِّيڒَاثْ نْومْ. أَذْ ث ثْعيّْذمْ ذڭْ ؤُيُورْ وِيسّْ سبْعَا.  
\v 42 أَذْ ثْزذْغمْ سبْعَا ن وُوسَّانْ ذڭْ إِعُوشُّوثنْ. مَارَّا إِنِّي د-إِتّْوَاخڒْقنْ ذِي إِسْرَائِيل أَذْ زذْغنْ ذڭْ إِعُوشُّوثنْ،  
\v 43 حِيمَا أَذْ سّْننْ \add مَارَّا\add* جِّيڒَاثْ نْومْ، بلِّي نشّْ ڭِّيغْ أَذْ زذْغنْ أَيْثْ ن إِسْرَائِيل ذڭْ إِعُوشُّوثنْ، ؤُمِي ثنْ سُّوفّْغغْ زِي ثمُّورْثْ ن مِيصْرَا. نشّْ ذ سِيذِي، أَربِّي نْومْ!‘ “   
\m
\v 44 \add أَمُّو\add* إِ إِسِّيوڒْ مُوسَا أَكْ-ذ أَيْثْ ن إِسْرَائِيل خْ ڒعْيُوذَاثْ إِتّْوَاڭّنْ ن سِيذِي.   
\b  
\b  
\m  
\c 24
\s1 إِزرْفنْ إِ ڒْقنْذِيڒْ ذ وغْرُومْ ن وسّْشَانْ  
\m
\v 1 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 2 ”ؤُمُورْ أَيْثْ ن إِسْرَائِيل مَاحنْذْ أَذْ أَشْ د-أَوْينْ إِ ثْفَاوْثْ زّشْثْ إِصْفَانْ تّْوَادّْزنْ ت-إِ-د زِي زِّيثُونْ، حِيمَا أَذْ ثجّمْ ثَافَاوْثْ ثَارقّْ ڒبْذَا.  
\v 3 هَارُونْ أَذْ ت إِستّفْ ڒبْذَا زَّاثْ إِ وُوذمْ ن سِيذِي زِي دْجِيڒثْ أَڒْ صّْبحْ زَّاثْ ن ؤُڒحَّافْ ن شّْهَاذثْ ذڭْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ. \add أَقَا-ت\add* ذ إِشْثْ ن ثوْصيّثْ إِ ڒبْذَا إِ \add مَارَّا\add* جِّيڒَاثْ نْومْ.  
\v 4 إِتّْخصَّا أَسْ أَذْ إِستّفْ ڒبْذَا \add ثِيفْثِيڒِينْ ن\add* ثْفَاوِينْ إِ إِدْجَانْ خْ ڒْقنْذِيڒْ إِزْذِيڭنْ زَّاثْ إِ وُوذمْ ن سِيذِي.  
\v 5 أَذْ ثكْسِيذْ وَارنْ أَزْذَاذْ ؤُشَا أَذْ زَّايسْ ثسّنْڭّْوذْ ثنْعَاشْ ن ڒمْسمْنَاثْ. إِشْثْ ن ثمْسمّمْثْ أَذْ ثِيڒِي زِي ثْنَاينْ ن ثعْشُورِينْ \add ن يِيجّْ ن إِفَا ن وَارنْ أَزْذَاذْ\add*.  
\v 6 أَذْ ثنْثْ ثڭّذْ ذِي ثْنَاينْ ن إِستِّيفنْ، ستَّا ذڭْ إِجّْ ن ؤُستِّيفْ خْ ثْزوْضَا إِزْذِيڭنْ زَّاثْ إِ وُوذمْ ن سِيذِي.  
\v 7 أَذْ ثڭّذْ خْ \add كُوڒْ\add* أَستِّيفْ جَّاوِي إِصْفَانْ نِّي غَا يِيڒِي إِ ڒِيذَارثْ أَكْ-ذ وغْرُومْ. \add أَقَا-ت\add* ذ إِشْثْ ن ثوْهِيبْثْ ن ثْمسِّي إِ سِيذِي.  
\v 8 ذِي كُوڒْ أَسّْ ن سّبْثْ أَذْ إِستّفْ أَيَا ڒبْذَا زَّاثْ إِ وُوذمْ ن سِيذِي ذِي طّْوعْ ن أَيْثْ ن إِسْرَائِيل. \add أَقَا-ث\add* ذ إِجّْ ن ڒْعَاهْذْ إِ ڒبْذَا.  
\v 9 أَذْ يِيڒِي \add وغْرُومْ\add* إِ هَارُونْ ذ وَارَّاوْ نّسْ، إِنِّي ث غَا إِشّنْ ذڭْ ومْشَانْ أَمْقدَّاسْ، مِينْزِي إِ نتَّا إِ إِدْجَا ؤُيَا ذ أَمْقدَّاسْ قَاعْ زِي ثوْهِيبِينْ ن ثْمسِّي ن سِيذِي. \add أَقَا-ت\add* ذ إِشْثْ ن ثوْصيّثْ إِ ڒبْذَا.“ \x ◘ \xo 24:‏9 \xt ؤُف. 29‏:‏32؛ لَاوِي 8‏:‏31؛ 1 صم. 21‏:‏6؛ مت. 12‏:‏4\x*   
\b  
\m  
\s1 ڒْعِيقَابْ إِ ونِّي إِشقّْفنْ ذِي سِيذِي ؤُ إِ ونِّي إِڭِّينْ ثُوعفّْنَا  
\m
\v 10 مِّيسْ ن إِشْثْ ن ثمْغَارْثْ ثِيسْرَا‘إِلشْثْ ثفّغْ غَارْ بَارَّا. نتَّا ثُوغَا-ث ذ مِّيسْ ن إِجّْ ن ورْيَازْ ذ أَمِيصْرِي إِزدّْغنْ جَارْ أَيْثْ ن إِسْرَائِيل. مِّيسْ ن ثمْغَارْثْ-أَ ثِيسْرَا‘إِلشْثْ ؤُ إِجّْ ن ورْيَازْ إِسْرَايِيلِي مّنْغنْ أَكْ-ذ وَايَاوْيَا ذِي ڒْمَارْڭحْ ن ڒْعسْكَارْ.  
\v 11 مِّيسْ ن ثمْغَارْثْ ثِيسْرَا‘إِلشْثْ إِشقّفْ ذڭْ يِيسمْ ؤُشَا إِكّْوَارْ. \add خنِّي\add* إِوْينْ ث غَارْ مُوسَا. يمَّاسْ، قَّارنْ أَسْ شِيلُومِييَا، يدْجِيسْ ن ذِيبْرِي، زِي ثقْبِيتْشْ ن دَان.  
\v 12 ڭِّينْ أَذْ خَاسْ حْضَانْ أَڒَامِي ذ أَسنْ إِ غَا إِمّڒْ \add مِينْ إِ غَا ڭّنْ\add* زڭْ ؤُقمُّومْ ن سِيذِي.  
\v 13 ؤُشَا إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:  
\v 14 ”سُوفّغْ ونِّي إِنعْڒنْ بَارَّا إِ ڒْمَارْڭحْ ن ڒْعسْكَارْ ؤُشَا أجّْ مَارَّا إِنِّي ذ أَسْ إِسْڒِينْ أَذْ سَّارْسنْ إِفَاسّنْ نْسنْ خْ ؤُزدْجِيفْ نّسْ. \add خنِّي\add* أَذْ ث ثَارْجمْ ثْمسْمُونْثْ أَمْ ثكْمڒْ.  
\v 15 أَذْ ثسِّيوْڒذْ أَكْ-ذ مَارَّا أَيْثْ ن إِسْرَائِيل ؤُشَا أَذْ أَسنْ ثِينِيذْ: ’كُوڒْ أَرْيَازْ إِ غَا إِنعْڒنْ أَربِّي، أَذْ يَارْبُو دّنْبْ نّسْ.  
\v 16 ونِّي إِتّْشقَّافنْ ذڭْ يِيسمْ ن سِيذِي، أَذْ إِتّْوَانغْ نِيشَانْ!‘ مَارَّا ثَامسْمُونْثْ أَذْ ث ثَارْجمْ. أَذْ إِتّْوَانغْ ؤُبَارَّانِي ؤُڒَا ذ ونِّي د-إِتّْوَاخڒْقنْ ذِي ثمُّورْثْ مَاڒَا إِتّْشقّفْ ذڭْ يِيسمْ.“   
\b  
\m
\v 17 ”مَاڒَا إِجّْ ن ورْيَازْ إِنْغَا ڒعْمَارْ ن شَا ن بْنَاذمْ نّغْنِي، \add خنِّي\add* أَذْ إِتّْوَانغْ نِيشَانْ.  
\v 18 \add مَاشَا\add* ونِّي إِنْغِينْ ڒعْمَارْ ن إِشْثْ ن ڒبْهِيمثْ، أَذْ يَارّْ ڒعْمَارْ س ڒعْمَارْ.  
\v 19 مَاڒَا إِجّْ ن ورْيَازْ إِسّْيِيزمْ جَّارْ نّسْ، \add خنِّي\add* أَذْ زَّايسْ ڭّنْ أَمْ مَامّشْ إِڭَّا نتَّا:  
\v 20 ثَارژِّيثْ س ثَارژِّيثْ، ثِيطّْ س ثِيطّْ، ثِيغْمسْثْ س ثغْمسْثْ. أَنشْثْ إِسّْيِيزّمْ نتَّا إِجّْ ن بْنَاذمْ، \add أَمُّو\add* إِ ذ أَسْ غَا ڭّنْ \add عَاوذْ\add*. \x ◘ \xo 24:‏20 \xt ؤُف. 21‏:‏24؛ أَعَوذ. 19‏:‏21؛ مت. 5‏:‏38\x*  
\v 21 ونِّي إِنْغِينْ إِشْثْ ن ڒبْهِيمثْ، أَذْ ت يَارّْ، ؤُ ونِّي إِنْغِينْ إِجّْ ن بْنَاذمْ، أَذْ إِتّْوَانغْ \add سِيمَانْثْ نّسْ\add*.  
\v 22 أَذْ غَارْومْ يِيڒِي ذ إِجّْ ن ؤُزرْفْ إِ ؤُبَارَّانِي أَمْ إِ ونِّي د-إِخڒْقنْ ذِي ثمُّورْثْ، مِينْزِي نشّْ ذ سِيذِي، أَربِّي نْومْ!“   
\b  
\m
\v 23 \add خنِّي\add* إِنَّا مُوسَا إِ أَيْثْ ن إِسْرَائِيل أَذْ سُّوفّْغنْ ونِّي ثُوغَا إِنعّْڒنْ بَارَّا إِ ڒْمَارْڭحْ ن ڒْعسْكَارْ، حِيمَا أَذْ ث أَرجْمنْ. ؤُشَا أَيْثْ ن إِسْرَائِيل ڭِّينْ أَمْ مَامّشْ ذ أَسْ يُومُورْ سِيذِي إِ مُوسَا.   
\b  
\b  
\m  
\c 25
\s1 أَسڭّْوَاسْ ن سّبْثْ ذ ؤُسڭّْوَاسْ ن ؤُسْڒِيوْڒوْ  
\m
\v 1 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا خْ وذْرَارْ ن سِينَا، إِنَّا:   
\m
\v 2 ”سِيوڒْ أَكْ-ذ أَيْثْ ن إِسْرَائِيل ؤُشَا إِنِي أَسنْ: ’خْمِي غَا ثَاوْضمْ غَارْ ثمُّورْثْ نِّي ذ أَومْ غَا وْشغْ، خنِّي أَذْ ثَاريّحْ ثمُّورْثْ، إِجّْ ن وَاريّحْ ن سّبْثْ إِ سِيذِي. \x ◘ \xo 25:‏2 \xt ؤُف. 23‏:‏10\x*  
\v 3 ستَّا ن إِسڭّْوُوسَا أَذْ ثْزَارْعذْ إِيَّارْ نّشْ ؤُشَا ستَّا ن إِسڭّْوُوسَا أَذْ ثزْبَارذْ ثِيزَايَارِينْ ن ؤُمَارْجعْ نّشْ ؤُشَا أَذْ ثسّْمُونذْ ڒْغِيدْجثْ نّسْ،  
\v 4 مَاشَا \bd ذڭْ ؤُسڭّْوَاسْ وِيسّْ سبْعَا أَذْ ثِيڒِي إِشْثْ ن أَرَّاحثْ ن سّبْثْ إِ ثمُّورْثْ، إِجّْ ن سّبْثْ إِ سِيذِي\bd*. وَارْ ثْزَارّْعذْ شَا إِيَّارْ نّشْ ؤُ وَارْ ثْزبَّارذْ شَا ثِيزَايَارِينْ ن ؤُمَارْجعْ نّشْ.  
\v 5 مِينْ د-إِغمّْينْ أَمنِّي وَاهَا، وَارْ ث مجَّارمْ ؤُ أَضِيڒْ وَارْ ث زبَّارمْ زِي \add ثْزَايَارْثْ\add* نّشْ إِ وَارْ إِتّْوِيحِيذِينْ. أَذْ يِيڒِي ذ إِجّْ ن ؤُسڭّْوَاسْ ن سّبْثْ إِ ثمُّورْثْ.  
\v 6 صَّابثْ ن أَرَّاحثْ ن سّبْثْ ن ثمُّورْثْ نّشْ أَذْ أَومْ ثِيڒِي ذ مَاشَّا، إِ شكْ، إِ يِيسْمغْ نّشْ، إِ ثَايَّا نّشْ، إِ ؤُشوَّاڒْ نّشْ ؤُڒَا إِ ؤُمْعزّبْ نّشْ، إِنِّي أَكِيذكْ إِزدّْغنْ أَمْ يِيبَارَّانِييّنْ.  
\v 7 صَّابثْ نّسْ مَارَّا أَذْ ثِيڒِي ذ مَاشَّا إِ ڒبْهَايمْ ؤُ إِ ڒْمَاڒْ نِّي \add إِدْجَانْ\add* ذِي ثمُّورْثْ نّشْ.‘ “   
\m
\v 8 ”أَذْ ثْحسّْبمْ كنِّيوْ \add عَاوذْ\add* سبْعَا ن سِّيمَانَاثْ ن إِسڭّْوُوسَا، سبْعَا وّثْ إِ-ت ذِي سبْعَا ن إِسڭّْوُوسَا، مَاحنْذْ أَذْ أَوْضنْ وُوسَّانْ ن سبْعَا ن سِيمَانَاثْ ن إِسڭّْوُوسَا \add مُوننْ\add* غَارْ ثسْعَا ؤُ-ربْعِينْ ن إِسڭّْوُوسَا. \f ◼ \fr 25:‏8 \ft \+bd ’سِّيمَانَاثْ‘\+bd* - نِيغْ ’إِمَالَاسنْ‘.\f*  
\v 9 خنِّي ذڭْ ؤُيُورْ وِيسّْ سبْعَا، ذڭْ وَاسّْ وِيسّْعشْرَا ن ؤُيُورْ، أَذْ ثجّذْ أَسُوضِي ذڭْ ؤُيِيشّْ ن إِشَارِّي أَذْ إِتّكّْ \add خْ ثمُّورْثْ نْومْ\add* س وسْرُودّحْ. ذڭْ وَاسّْ ن وصْڒَاحْ أَذْ ثجّمْ أَذْ إِتّكّْ ؤُسُوضِي ذڭْ ؤُيِيشّْ ن إِشَارِّي خْ مَارَّا ثَامُّورْثْ نْومْ. \f ◼ \fr 25:‏9 \ft \+bd ’أَسّْ ن وصْڒَاحْ‘\+bd* - س ثْعِيبْرَانِيثْ ’أَسّْ ن ڒفْذِييَّاثْ‘.\f*  
\v 10 أَذْ ثسّْقدّْسمْ أَسڭّْوَاسْ ن ؤُسڭّْوَاسْ وِيسّْ خمْسِينْ. أَذْ ثْبَارّْحمْ س ثْڒلِّي إِ مَارَّا إِمزْذَاغْ ذِي \add مَارَّا\add* ثَامُّورْثْ. أَذْ يِيڒِي ذ \bd إِجّْ ن \+bdit ؤُسڭّْوَاسْ ن\+bdit* ؤُسْڒِيوْڒوْ\bd* إِ كنِّيوْ ؤُشَا أَذْ د-إِعْقبْ كُوڒْ أَرْيَازْ غَارْ وَاڭْڒَا نّسْ ؤُ غَارْ رَادْجْ نّسْ.  
\v 11 أَسڭّْوَاسْ ن ؤُسڭّْوَاسْ وِيسّْ خمْسِينْ أَذْ أَومْ يِيڒِي ذ إِجّْ ن \add ؤُسڭّْوَاسْ\add* ن ؤُسْڒِيوْڒوْ. وَارْ ثْزَارّْعمْ ؤُ وَارْ ثْمجَّارمْ مِينْ د-إِغمّْينْ أَمنِّي وَاهَا، ؤُ وَارْ ثْزبَّارمْ شَا زِي ثْزَايَارْثْ وَارْ إِتّْوِيحِيذِينْ،  
\v 12 مِينْزِي أَقَا ذ أَسڭّْوَاسْ ن ؤُسْڒِيوْڒوْ! أَقَا ثْزمَّارمْ أَذْ ثشّمْ ڒْغِيدْجثْ ن ييَّارْ.  
\v 13 ذڭْ ؤُسڭّْوَاسْ-أَ ن ؤُسْڒِيوْڒوْ أَذْ د-إِعْقبْ كُوڒْ  إِجّنْ غَارْ وَاڭْڒَا نّسْ.“   
\m
\v 14 ”مڒْمِي شكْ غَا ثزّنْزذْ شَا إِ جَّارْ نّشْ نِيغْ مَاڒَا ثسْغِيذْ شَا زڭْ ؤُفُوسْ ن جَّارْ نّشْ، وَارْ إِعدّڒْ ؤُڒَا ذ إِجّنْ أَذْ إِغبّنْ ونّغْنِي.  
\v 15 \add عْلَاحْسَابْ\add* ڒْقدّْ ن إِسڭّْوُوسَا زڭْ وَامِي إِدْجَا ؤُسڭّْوَاسْ ن ؤُسْڒِيوْڒوْ أَذْ ثسْغذْ \add ثَامُّورْثْ\add* زِي جَّارْ نّشْ ؤُ \add عْلَاحْسَابْ\add* ڒْقدّْ ن إِسڭّْوُوسَا ن صَّابثْ أَذْ كِيكْ يڭّْ ثَامنْزِيوْثْ.  
\v 16 مَا أَقَا ذِينِّي عَاذْ أَطَّاسْ ن إِسڭّْوُوسَا غَارْ زَّاثْ، خنِّي أَذْ ثَارْنِيذْ ذِي تَّامَانْ ن ثْمسْغِيوْثْ نّسْ ؤُ مَاڒَا أَقَا ذِينِّي عَاذْ ذْرُوسْ ن إِسڭّْوُوسَا غَارْ زَّاثْ، خنِّي أَذْ ثسّْنقْصمْ ذِي تَّامَانْ ن ثْمسْغِيوْثْ نّسْ، مِينْزِي نتَّا أَذْ أَشْ ت إِزّنْزْ عْلَاحْسَابْ ڒْقدّْ ن \add إِسڭّْوُوسَا ن\add* صَّابثْ.  
\v 17 وَارْ إِتّْغبِّي حذْ جَّارْ نّسْ. ڭّْوذْ أَربِّي نّشْ، مِينْزِي أَقَا نشّْ ذ سِيذِي، أَربِّي نْومْ!“   
\m
\v 18 ”ضْفَارمْ ثِيوصَّا إِنُو، حْضَامْ لْفَارَايِيضْ إِنُو ؤُشَا ڭّمْ زَّايْسنْثْ، أَذْ ثْزذْغمْ \add خنِّي\add* ذِي ثمُّورْثْ ذِي ڒَامَانْ.  
\v 19 ثَامُّورْثْ أَذْ ثوْشْ ڒْغِيدْجثْ نّسْ ؤُ كنِّيوْ أَذْ زَّايسْ ثشّمْ أَڒْ غَا ثجِّيوْنمْ ؤُشَا أَذْ ذِينْ ثْزذْغمْ ذِي ڒَامَانْ.  
\v 20 ؤُشَا مَاڒَا ثنِّيمْ: ’مِينْ غَا نشّْ ذڭْ ؤُسڭّْوَاسْ وِيسّْ سبْعَا؟ خْزَارْ، وَارْ نْزمَّارْ أَذْ نْزَارّعْ ؤُ وَارْ نْزمَّارْ أَذْ نسّْمُونِي صَّابثْ نّغْ!‘،  
\v 21 \add خنِّي\add* ذڭْ ؤُسڭّْوَاسْ وِيسّْ ستَّا نشّْ أَذْ أَومْ د-سّكّغْ لْبَارَاكَا إِنُو حِيمَا ثَامُّورْثْ أَذْ ثوْشْ رْغِيدْجثْ إِ ثْڒَاثَا ن إِسڭّْوُوسَا.  
\v 22 ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثْمنْيَا أَذْ ثْزَارْعمْ \add عَاوذْ\add*. ؤُشَا أَذْ ثشّمْ زِي صَّابثْ ثَاقْذِيمْثْ أَڒْ أَسڭّْوَاسْ وِيسّْ ثسْعَا. أَڒْ إِ غَا ثِيڒِي صَّابثْ نّسْ ن جْذِيذْ، أَذْ ثشّمْ \add عَاذْ\add* زِي \add صَّابثْ\add* ثَاقْذِيمْثْ.“   
\m
\v 23 ”ثَامُّورْثْ وَارْ ثتّْمنْزِي إِ ڒبْذَا، مِينْزِي ثَامُّورْثْ أَقَا-ت إِنُو ؤُشَا كنِّيوْ \add خنِّي\add* ذ إِبَارَّانِييّنْ ذ إِمعْزَابْ غَارِي.  
\v 24 س ؤُيَا إِتّْخصَّا كنِّيوْ أَذْ ثوْشمْ تّسْرِيحْ مَاحنْذْ أَذْ إِفْذِي ثَامُّورْثْ ذِي مَارَّا ثَامُّورْثْ إِ غَارْومْ إِدْجَانْ ذ وَاڭْڒَا. \f ◼ \fr 25:‏24 \ft \+bd ’إِفْذِي‘\+bd* - خْزَارْ إِزهد. 78:35.\f*  
\v 25 مَاڒَا ؤُمَاشْ إِژْڒضْ ؤُشَا إِزّنْزْ شَا زڭْ وَاڭْڒَا نّسْ، أَذْ د-يَاسْ ؤُمفْذِي نّسْ، ڒَادْجْ نّسْ يُوذْسنْ، مَاحنْذْ أَذْ إِفْذِي مِينْ إِزّنْزْ ؤُمَاسْ. \f ◼ \fr 25:‏25 \ft \+bd ’أَمفْذِي‘\+bd* - أَرْيَازْ ونِّي ث إِ غَا إِفْذِينْ. خْزَارْ إِزهد. 78:35.\f*  
\v 26 مَاڒَا أَرْيَازْ وَارْ غَارسْ بُو ؤُمفْذِي، \add مَاشَا\add* أَفُوسْ نّسْ إِزمَّارْ أَذْ يَافْ مِينْ إِشْفَانْ، مَاحنْذْ أَذْ ث إِفْذِي،  
\v 27 \add خنِّي\add* أَذْ إِحْسبْ إِسڭّْوُوسَا زڭْ وَامِي ثتّْوَامّنْزْ \add ثمُّورْثْ\add* ؤُشَا أَذْ إِخدْجصْ مِينْ إِقِّيمنْ إِ ورْيَازْ ؤُمِي ت إِزّنْزْ ؤُشَا أَذْ ت-إِ-د-يَارّْ غَارْ وَاڭْڒَا نّسْ.  
\v 28 مَاڒَا أَفُوسْ نّسْ وَارْ يُوفِي ڒْقدّْ، حِيمَا أَذْ أَسْ د-يَارّْ مِينْ ثُوغَا إِزّنْزْ، \add خنِّي\add* مِينْ ثُوغَا إِزّنْزْ أَذْ إِقِّيمْ ذڭْ ؤُفُوسْ ن ونِّي ث إِسْغِينْ أَڒْ \add أَسڭّْوَاسْ ن\add* ؤُسْڒِيوْڒوْ. \add مَاشَا\add* ذڭْ ؤُسڭّْوَاسْ ن ؤُسْڒِيوْڒوْ أَذْ إِتّْوَافكّْ مَانْ أَيَا ؤُشَا أَذْ ث-إِ-د-يَارّْ غَارْ وَاڭْڒَا نّسْ.“   
\b  
\m
\v 29 ”مَاڒَا شَا ن يِيجّنْ إِزّنْزْ ثَادَّارْثْ نّسْ ذڭْ إِشْثْ ن ثنْذِينْثْ ؤُمِي د-نّْضنْ س وغْبَارْ \add خنِّي\add* إِعدّڒْ أَذْ يِيڒِي ؤُفكِّي نّسْ أَڒْ ذ إِعْذُو إِجّْ ن ؤُسڭّْوَاسْ أَمْ إِكْمڒْ زِي ثْمنْزِيوْثْ نّسْ. \add مَارَّا\add* ؤُسَّانْ نِّي إِعدّڒْ أَذْ ت إِفْذِي.  
\v 30 \add مَاشَا\add* مَاڒَا وَارْ ثتّْوَافْذِي ذِي ڒْمِيجَاڒْ ن إِجّْ ن ؤُسڭّْوَاسْ، \add خنِّي\add* ثَادَّارْثْ ذِي ثنْذِينْثْ نِّي د-إِنّْضنْ س وغْبَارْ، أَذْ ثِيڒِي ڒبْذَا إِ ونِّي ت إِسْغِينْ، إِ \add مَارَّا\add* جِّيڒَاثْ نّسْ. وَارْ ثتّْوَافكّْ ذڭْ ؤُسڭّْوَاسْ ن ؤُسْڒِيوْڒوْ.  
\v 31 \add مَاشَا\add* ثُوذْرِينْ نِّي ن ڒذْشُورْ إِ ؤُمِي وَارْ د-إِنِّيضْ ڒغْبَارْ أَذْ تّْوَاحسْبنْثْ أَمْ يِيجّْ ن ييَّارْ ن ثمُّورْثْ. ذَانِيثَا إِزمَّارْ أَذْ يِيڒِي ڒْحقّْ ن ؤُفكِّي ؤُشَا أَذْ إِتّْوَافكّْ ييَّارْ ذڭْ ؤُسڭّْوَاسْ ن ؤُسْڒِيوْڒوْ.  
\v 32 \add خْ\add* ثْندَّامْ ن إِلَاوِييّنْ، ثُوذْرِينْ ذِي ثْندَّامْ ن وَاڭْڒَا نْسنْ، أَقَا إِلَاوِييّنْ غَارْسنْ ڒْحقّْ إِ ڒبْذَا حِيمَا أَذْ ثنْثْ فْذِينْ.  
\v 33 مَاڒَا شَا ن يِيجّنْ إِفْذَا \add إِ-ت\add* زڭْ \add ؤُفُوسْ ن\add* إِلَاوِييّنْ، خنِّي أَذْ ثتّْوَافكّْ ثَادَّارْثْ إِ إِمّنْزنْ \add إِ إِجّنْ إِ وَارْ إِدْجِينْ زڭْ إِلَاوِييّنْ\add*، \add ثنِّي إِدْجَانْ\add* ذِي ثنْذِينْثْ ن وَاڭْڒَا نّسْ، ذڭْ ؤُسڭّْوَاسْ ن ؤُسْڒِيوْڒوْ، مِينْزِي ثُوذْرِينْ ن ثْندَّامْ ن إِلَاوِييّنْ أَقَا أَثنْثْ ذ أَڭْڒَا نْسنْ ذِي ڒْوسْطْ ن أَيْثْ ن إِسْرَائِيل.  
\v 34 إِيَّارْ نِّي إِقّْننْ غَارْ ثْندَّامْ، وَارْ إِتّْمنْزِي، مِينْزِي \add أَقَا-ث\add* ذ أَڭْڒَا نْسنْ إِ ڒبْذَا.“   
\m
\v 35 ”مَاڒَا ؤُمَاشْ إِژْڒضْ ؤُشَا إِفَاسّنْ نّسْ بْذَانْ أَذْ أَرْجِيجنْ ذِينْ غَاركْ، \add خنِّي\add* إِتّْخصَّا أَذْ ث-إِ-د-ثْسنّْذذْ مَاحنْذْ أَذْ إِبدّْ، ؤُڒَا ذ أَبَارَّانِي نِيغْ ذ أَمْعزّبْ، مَاحنْذْ أَذْ إِقِّيمْ أَذْ غَاركْ إِدَّارْ.  
\v 36 وَارْ زَّايسْ ثْكسِّيذْ أَرِّيبَا ؤُڒَا ذ أَرْبحْ، مَاشَا أَذْ ثڭّْوْذذْ أَربِّي نّشْ، حِيمَا ؤُمَاشْ إِ ذِينْ غَاركْ أَذْ إِقِّيمْ إِدَّارْ. \f ◼ \fr 25:‏36 \ft \+bd ’أَرِّيبَا‘\+bd* - نِيغْ ’ڒْْفَايْذَا‘.\f*  \x ◘ \xo 25:‏36 \xt ؤُف. 22‏:‏25؛ أَعَوذ. 23‏:‏18؛ أَوڒن. 28‏:‏8؛ حِز. 18‏:‏8؛ 22‏:‏12\x*  
\v 37 وَارْ ذ أَسْ تِّيشْ \add ثْمنْيَاثْ ن\add* نُّوقَارْثْ س أَرِّيبَا ؤُ وَارْ ذ أَسْ تِّيشْ مَاشَّا س وَارْبحْ.  
\v 38 أَقَا نشّْ ذ سِيذِي، أَربِّي نْومْ، ونِّي كنِّيوْ د-إِسُّوفّْغنْ زِي ثمُّورْثْ ن مِيصْرَا، حِيمَا أَذْ أَومْ وْشغْ ثَامُّورْثْ ن كنْعَانْ ؤُ حِيمَا أَذْ إِڒِيغْ ذ أَربِّي إِ كنِّيوْ.“   
\m
\v 39 ”مَاڒَا ؤُمَاشْ إِژْڒضْ أَمْ كِيكْ إِدْجَا ؤُشَا إِمّنْزْ أَشْ إِ شكْ، وَارْ ث ثتَّارِّيذْ أَذْ إِخْذمْ أَمْ يِيسْمغْ. \x ◘ \xo 25:‏39 \xt ؤُف. 21‏:‏2؛ أَعَوذ. 15‏:‏12؛ إِرْم. 34‏:‏14\x*  
\v 40 أَذْ كِيكْ إِزْذغْ أَمشْنَاوْ أَشوَّاڒْ، أَمشْنَاوْ إِجّْ ن ؤُمْعزّبْ، ؤُشَا أَذْ غَاركْ إِخْذمْ أَڒْ أَسڭّْوَاسْ ن ؤُسْڒِيوْڒوْ.  
\v 41 \add خنِّي\add* أَذْ خَاكْ إِفّغْ، نتَّا \add سِيمَانْثْ نّسْ\add* أَكْ-ذ ثَارْوَا نّسْ، ؤُشَا أَذْ إِذْوڒْ غَارْ ڒَادْجْ نّسْ ؤُ أَذْ إِذْوڒْ غَارْ وَاڭْڒَا ن ڒجْذُوذْ نّسْ.  
\v 42 مِينْزِي أَقَا أَثنْ ذ إِمْسخَارّنْ إِنُو إِنِّي سُّوفّْغغْ نشّْ زِي ثمُّورْثْ ن مِيصْرَا. وَارْ تّْمنْزِينْ أَمْ مَامّشْ إِتّْمنْزَا إِجّْ ن إِسْمغْ.  
\v 43 وَارْ خَاسْ تّْصدْجضْ س ڒقْسَاحثْ، مَاشَا أَذْ ثڭّْوْذذْ أَربِّي نّشْ. \x ◘ \xo 25:‏43 \xt أَفا. 6‏:‏9؛ كُول. 4‏:‏1\x*  
\v 44 \add خْ\add* إِسْمغْ نّشْ نِيغْ خْ ثَايَّا نّشْ، إِنِّي غَاركْ غَا يِيڒِينْ، أَذْ إِڒِينْ زِي ڒڭْنُوسْ إِ ذ أَشْ د-إِنّْضنْ. زَّايْسنْ أَذْ ثسْغذْ إِسمْغَانْ ذ ثيَّاوِينْ.  
\v 45 ثْزمَّارمْ أَذْ ثنْ ثسْغمْ زڭْ إِحنْجِيرنْ ن إِمعْزَابْ نِّي إِزدّْغنْ جَارْ أَومْ أَمْ يِيبَارَّانِييّنْ ؤُ زِي ڒَادْجَاثْ نْسنْ، إِنِّي أَكِيذْومْ إِدْجَانْ، إِنِّي ثنْ د-إِجِّينْ ذِي ثمُّورْثْ نْومْ. نِيثْنِي أَذْ ذوْڒنْ ذ أَڭْڒَا نْومْ.  
\v 46 ؤُشَا أَذْ ثنْ ثجّذْ ذ ڒْوَارْثْ إِ إِحنْجِيرنْ نْومْ أَوَارْنِي أَومْ. ثْزمَّارمْ أَذْ ثنْ ثَارّمْ أَذْ أَومْ سخَّارنْ ڒبْذَا، \add مَاشَا\add* خْ أَيْثْمَاثْومْ، أَيْثْ ن إِسْرَائِيل، وَارْ تّْصلّْطمْ كُوڒْ إِجّْ خْ ونّغْنِي س ڒقْسَاحثْ.“   
\m
\v 47 ”مَاڒَا يِيوضْ ؤُفُوسْ ن إِجّْ ن ؤُبَارَّانِي نِيغْ ن إِجّْ ن ؤُمْعزّبْ \add إِ إِزدّْغنْ\add* جَارْ أَومْ، ؤُشَا ؤُمَاشْ إِ غَارسْ إِزدّْغنْ إِذْوڒْ إِژْڒضْ ؤُشَا أَذْ إِزّنْزْ إِخفْ نّسْ إِ ؤُبَارَّانِي نِّي إِزدّْغنْ غَاركْ نِيغْ إِ يِيجّنْ زِي جَّاذِيرَا ن ڒَادْجْ ن ؤُبَارَّانِي نِّي،  
\v 48 \add خنِّي\add* إِعدّڒْ، أَوَارْنِي مَا إِزّنْزْ إِخفْ نّسْ، أَذْ إِتّْوَافْذِي. إِجّنْ زڭْ أَيْثْمَاسْ أَذْ ث إِفْذِي.  
\v 49 إِعدّڒْ إِعمِّيسْ نِيغْ إِ مِّيسْ نعمِّيسْ أَذْ ث إِفْذِي نِيغْ إِجّنْ زِي رَادْجْ نّسْ إِ-ث-إِ-د-يُوذْسنْ، زِي ڒْوَاشُونْ نّسْ، أَذْ ث إِفْذِي، نِيغْ مَاڒَا غَارسْ س مِينْ زِي، \add خنِّي\add* إِعدّڒْ أَذْ إِفْذِي إِخفْ نّسْ.  
\v 50 أَذْ إِڭّْ ڒحْسَابْ أَكْ-ذ ونِّي ث إِسْغِينْ زڭْ ؤُسڭّْوَاسْ مِينْ ذِي إِزّنْزْ إِخفْ نّسْ أَڒْ أَسڭّْوَاسْ ن ؤُسْڒِيوْڒوْ ؤُ تَّامَانْ ن ثْمنْزِيوْثْ س نُّوقَارْثْ أَذْ يِيڒِي عْلَاحْسَابْ ڒْقدّْ ن إِسڭّْوُوسَا، \add إِنِّي إِ غَا إِتّْوَاحسْبنْ\add* أَمْ وُوسَّانْ ن إِجّْ ن ؤُشوَّاڒْ \add إِخدّْمنْ\add* أَكِيذسْ.  
\v 51 مَاڒَا أَقَا ذِينْ عَاذْ أَطَّاسْ ن إِسڭّْوُوسَا غَارْ زَّاثْ، أَذْ إِخدْجصْ مَاحنْذْ أَذْ إِتّْوَافْذِي أَنشْثْ ن ثسْغَارْثْ ن تَّامَانْ س \add ثْمنْيَاثْ ن\add* نُّوقَارْثْ إِ زِي إِتّْوَاسغْ.  
\v 52 مَاڒَا \add عَاذْ\add* ذْرُوسْ إِ إِقِّيمنْ ن إِسڭّْوُوسَا أَڒْ أَسڭّْوَاسْ ن ؤُسْڒِيوْڒوْ، \add خنِّي\add* أَذْ إِڭّْ إِ يِيخفْ نّسْ إِجّْ ن ڒحْسَابْ ؤُشَا أَذْ إِخدْجصْ تَّامَانْ ن ؤُفكِّي نّسْ عْلَاحْسَابْ إِسڭّْوُوسَا \add إِ ذِينْ إِقِّيمنْ\add*.  
\v 53 أَمْ يِيجّْ ن ؤُشوَّاڒْ أَذْ غَارسْ إِقِّيمْ زڭْ ؤُسڭّْوَاسْ أَڒْ أَسڭّْوَاسْ. وَارْ إِعدّڒْ أَذْ خَاسْ صلّْطنْ س ڒقْسَاحثْ زَّاثْ إِ ثِيطَّاوِينْ نّشْ.  
\v 54 مَاڒَا وَارْ إِتّْوَافْذِي س مَارَّا أَيَا، \add خنِّي\add* أَذْ إِفكّْ ذڭْ ؤُسڭّْوَاسْ ن ؤُسْڒِيوْڒوْ، نتَّا ذ ثَارْوَا نّسْ أَكِيذسْ.  
\v 55 مِينْزِي أَيْثْ ن إِسْرَائِيل أَقَا أَثنْ ذ إِمْسخَّارنْ إِنُو، إِنِّي سُّوفّْغغْ زِي ثمُّورْثْ ن مِيصْرَا. أَقَا نشّْ ذ سِيذِي، أَربِّي نْومْ.“   
\b  
\b  
\m  
\c 26
\s1 لْبَارَاكَا ذ نّعْڒثْ  
\m
\v 1 ”وَارْ تّڭّمْ إِ يِيخفْ نْومْ لْ-أَصْنَامْ، وَارْ سْبدَّامْ ڒخْيَاڒْ إِنقْشنْ ؤُڒَا ذ ؤُمَايْضُو \add إِقدّْسنْ\add*، وَارْ سّْرُوسَامْ ڒخْيَاڒْ ن وژْرُو ذِي ثمُّورْثْ نْومْ، حِيمَا أَذْ أَسْ ثْبنْذْقمْ، مِينْزِي نشّْ ذ سِيذِي، أَربِّي نْومْ! \x ◘ \xo 26:‏1 \xt ؤُف. 20‏:‏4؛ أَعَوذ. 5‏:‏8؛ 16‏:‏22؛ إِزهد. 97‏:‏7\x*   
\m
\v 2 أَذْ ثحْضَامْ ؤُسَّانْ ن سّبْثْ إِنُو ؤُشَا أَذْ أَومْ إِقَارّْ إِجّْ ن ؤُوقَّارْ يُودْجْغنْ إِ زَّاوشْثْ إِنُو إِقدّْسنْ، أَقَا نشّْ ذ سِيذِي!“ \x ◘ \xo 26:‏2 \xt لَاوِي 19‏:‏30\x*   
\m
\v 3 ”مَاڒَا أَذْ ثُويُورمْ ذِي ثْوصَّا إِنُو ؤُشَا أَذْ ثطّْفمْ ذِي ثْوصَّا إِنُو ؤُشَا أَذْ زَّايْسنْثْ ثڭّمْ، \x ◘ \xo 26:‏3 \xt أَعَوذ. 28\x*  
\v 4 \add خنِّي\add* نشّْ أَذْ أَومْ وْشغْ أَنْژَارْ ذِي ڒْوقْثْ نّسْ، ؤُشَا ثَامُّورْثْ أَذْ د-ثَاوِي صَّابثْ نّسْ، ؤُشَا ثِيشجُّورَا ن ييَّارْ أَذْ وْشنْثْ ڒْغِيدْجثْ نْسنْثْ.  
\v 5 أَذْ يِيڒِي ؤُسَارْوثْ أَڒْ أَڒْقَاضْ ن ؤُضِيڒْ ؤُشَا أَڒْقَاضْ ن ؤُضِيڒْ أَذْ يِيڒِي أَڒْ \add ڒْْوقْثْ ن\add* ؤُزَارّعْ ؤُشَا أَذْ ثشّمْ أَڒْ غَا ثجِّيوْنمْ ؤُشَا أَذْ ثْزذْغمْ ذِي ڒَامَانْ ذِي ثمُّورْثْ نْومْ. \x ◘ \xo 26:‏5 \xt لَاوِي 25‏:‏19\x*  
\v 6 نشّْ أَذْ ڭّغْ ڒهْنَا ذِي ثمُّورْثْ. \add مَاڒَا\add* ثطّْصمْ، وَارْ إِتِّيڒِي وِي \add كنِّيوْ\add* إِ غَا إِسِّيڭّْوْذنْ. نشّْ أَذْ مْحِيغْ ڒوْحُوشْ إِوْعَارنْ زِي ثمُّورْثْ ؤُشَا سِّيفْ وَارْ د-إِژكّْوِي خْ ثمُّورْثْ نْومْ. \x ◘ \xo 26:‏6 \xt أَيُوبْ 11‏:‏18، 19\x*  
\v 7 أَذْ ثضْفَارمْ ڒْعذْيَانْ نْومْ ؤُشَا نِيثْنِي أَذْ وْضَانْ س سِّيفْ نْومْ زَّاثْ إِ ثِيطَّاوِينْ نْومْ.  
\v 8 خمْسَا ن يرْيَازنْ زَّايْومْ أَذْ ضْفَارنْ مْيَا ؤُشَا مْيَا زَّايْومْ أَذْ ضْفَارنْعشْرَا-أَڒَافْ ؤُشَا ڒْعذْيَانْ نْومْ أَذْ وْضَانْ س \add ڒقْضعْ ن\add* سِّيفْ زَّاثْ إِ ثِيطَّاوِينْ نْومْ. \f ◼ \fr 26:‏8 \ft \+bd ’زَّاثْ إِ ثِيطَّاوِينْ نْومْ‘\+bd* - س ثْعِيبْرَانِيثْ ’زَّاثْ إِ وُوذْمَاونْ نْومْ‘.\f*  \x ◘ \xo 26:‏8 \xt ياش. 23‏:‏10\x*  
\v 9 مِينْزِي نشّْ أَذْ غَارْومْ د-ذوْڒغْ ؤُشَا أَذْ أَومْ د-جّغْ ڒْغِيدْجثْ ؤُشَا أَذْ كنِّيوْ أَرْنِيغْ ؤُشَا أَذْ سّْمثْنغْ ڒْعَاهْذْ إِنُو أَكِيذْومْ.  
\v 10 \add أَمْ\add* إِ غَا ثشّمْ \add عَاذْ\add* زِي زَّاذْ نِّي ثْخزْنمْ، أَذْ ثكّْسمْ ذغْيَا \add زَّاذْ\add* أَقْذِيمْ، \add مَاحنْذْ أَذْ ثجّمْ أَمْشَانْ\add* إِ جْذِيذْ.  
\v 11 نشّْ أَذْ ڭّغْ ثَازذِّيغْثْ إِنُو ذِي ڒْوسْثْ نْومْ ؤُشَا ڒعْمَارْ إِنُو وَارْ زَّايْومْ إِتّْعِيفِّي شَا \add عَاذْ\add*. \x ◘ \xo 26:‏11 \xt حِز. 37‏:‏26؛ 2 كُور. 6‏:‏16\x*  
\v 12 أَذْ ؤُيُورغْ جَارْ أَومْ، نشّْ أَذْ إِڒِيغْ ذ أَربِّي نْومْ ؤُشَا كنِّيوْ أَذْ أَيِي ثِيڒِيمْ ذ ڒْڭنْسْ إِنُو.  
\v 13 نشّْ ذ سِيذِي، أَربِّي نْومْ، ونِّي كنِّيوْ د-إِسُّوفّْغنْ زِي ثمُّورْثْ ن مِيصْرَا، حِيمَا وَارْ ثتِّيڒِيمْ \add عَاذْ\add* ذ إِسمْغَانْ نْسنْ. نشّْ أَرْژِيغْ إِمْقدْجَاضنْ ن ؤُزَايْڒُو نْومْ ؤُشَا نذْهغْ كنِّيوْ س وُوذمْ يُوڒِي.“   
\m
\v 14 ”\add مَاشَا\add* مَاڒَا وَارْ ذ أَيِي ثسْڒِيمْ نِيغْ وَارْ ثتّڭِّيمْ مَارَّا مِينْ زِي كنِّيوْ وصِّيغْ، \x ◘ \xo 26:‏14 \xt أَعَوذ. 28‏:‏15؛ إِڭجذ. 2‏:‏17؛ مـَال. 2‏:‏2\x*  
\v 15 ؤُشَا مَاڒَا ثسّحْقَارمْ ثِيوصَّا إِنُو ؤُ ڒعْمَارْ نْومْ أَذْ إِعِيفّْ زِي لْفَارَايِيضْ إِنُو، أَڒْ غَا ثَاوْضمْ وَارْ ثتّڭّمْ \add عَاذْ\add* مَارَّا ثِيوصَّا إِنُو، ؤُشَا \add أَمُّو إِ\add* غَا ثَارْژمْ ڒْعَاهْذْ إِنُو،  
\v 16 \add خنِّي\add* نشّْ أَذْ أَومْ ڭّغْ أَيَا: أَذْ خَاومْ د-سّهْوِيغْ أَرْجفْ ذ بُو-ذدْجِيسْ ذ ثْمسِّي ن أَرْوَاحْ نِّي إِ غَا إِثحَّانْ ثِيطَّاوِينْ ؤُشَا أَذْعدّْبنْ ڒعْمَارْ. أَذْ ثْزَارْعمْ زَّارِيعثْ نْومْ بَاطڒْ، \add مِينْزِي\add* ڒْعذْيَانْ نْومْ أَذْ ت شّنْ.  
\v 17 أَذْ ڭّغْ ؤُذمْ إِنُو ضِيدّْ نْومْ أَڒَامِي إِ غَا تّْوَاسّخْسَارمْ زَّاثْ إِ وُوذمْ ن ڒْعذْيَانْ نْومْ ؤُشَا إِنِّي كنِّيوْ إِشَارّْهنْ أَذْ خَاومْ صلّْطنْ ؤُشَا كنِّيوْ أَذْ ثَاروْڒمْ بْڒَا أَذْ يِيڒِي وِي كنِّيوْ إِرَارَانْ.“ \x ◘ \xo 26:‏17 \xt أَوڒن. 28‏:‏1\x*   
\m
\v 18 ”ؤُ مَاڒَا أَوَارْنِي مَانْ أَيَا عَاذْ وَارْ غَارِي ثسْڒِيمْ، نشّْ أَذْ غَارسْ أَرْنِيغْ سبْعَا ن ثْوَاڒَاوِينْ، مَاحنْذْ أَذْ كنِّيوْ وبّْخغْ خْ دّْنُوبْ نْومْ.  
\v 19 نشّْ أَذْ أَرْژغْ أَعفَّارْ ن جّهْذْ نْومْ، نشّْ أَذْ أَرّغْ أَجنَّا نْومْ أَمْ وُوزَّاڒْ ذ ثمُّورْثْ نْومْ أَمْ نّْحَاصْ.  
\v 20 أَذْ ثْضيّْعمْ جّهْذْ نْومْ بَاطڒْ، \add مِينْزِي\add* ثَامُّورْثْ نْومْ وَارْ ثتِّيشْ صَّابثْ نّسْ ؤُ ثِيشجُّورَا ن ثمُّورْثْ وَارْ تِّيشنْثْ ڒْغِيدْجثْ.  
\v 21 مَاڒَا ثمْعَاڒَامْ كِيذِي ؤُشَا وَارْ ثتّخْسمْ أَذْ أَيِي ثسْڒِيمْ، \add خنِّي\add* نشّْ أَذْ خَاومْ د-سّهْوِيغْ \add عَاذْ\add* سبْعَا ن جّْرَايحْ أَنشْثْ ن دّْنُوبْ نْومْ.  
\v 22 أَذْ غَارْومْ د-سّكّغْ ڒوْحُوشْ ن ڒخْڒَا، مَاحنْذْ أَذْ أَومْ خضْفنْ ثَارْوَا نْومْ، أَذْ سّْهلّْكنْ ڒبْهَايمْ نْومْ، ؤُشَا أَذْ سّْنقْصنْ \add لْعَاذَاذْ نْومْ\add*، \add أَڒَامِي\add* إِبْرِيذنْ نْومْ أَذْ ذوْڒنْ ذ دّْمَانِي.“   
\m
\v 23 ”مَاڒَا س مَانْ أَيَا كنِّيوْ وَارْ غَارِي د-تّسْڒِيمْ، مَاشَا \add ثقِّيممْ\add* ثتّمْعَاڒَامْ أَكِيذِي،  
\v 24 \add خنِّي\add* ؤُڒَا ذ نشّْ أَذْ قِّيمغْ تّمْعَاڒَاغْ أَكِيذْومْ ؤُشَا أَذْ خَاومْ د-سّهْوِيغْ \add عَاذْ\add* سبْعَا ن جّْرَايحْ خْ دّْنُوبْ نْومْ. \x ◘ \xo 26:‏24 \xt 2 صم. 22‏:‏27؛ إِزهد. 18‏:‏27\x*  
\v 25 أَذْ خَاومْ سّكّغْ إِجّْ ن سِّيفْ نِّي إِ غَا إِسّكَّارنْ أَنْثَاقمْ ن ڒْعَاهْذْ إِنُو أَڒْ غَا ثتّْوَاسّْمُونمْ ذِي ثْندَّامْ نْومْ. \add خنِّي\add* نشّْ أَذْ سّكّغْ طَّاعُونْ ذِي ڒْوسْطْ نْومْ ؤُشَا كنِّيوْ أَذْ ثتّْوَاسلّْممْ ذڭْ ؤُفُوسْ ن ڒعْذُو نْومْ.  
\v 26 خْمِي غَا أَرْژغْ ڒعْوتْشْ ن وغْرُومْ نْومْ، \add خنِّي\add*عشْرَا ن ثمْغَارِينْ أَذْ سّنْڭّْونْثْ أَغْرُومْ نْومْ ذِي ثفْقُونْثْ ذ إِشْثْ، ؤُشَا أَوَارْنِي إِ غَا وزْننْثْ أَغْرُومْ أَذْ ث إِ-د-أَرّنْثْ ؤُشَا كنِّيوْ أَذْ ث ثشّمْ، مَاشَا وَارْ ثتّْجِيوِينمْ. \f ◼ \fr 26:‏26 \ft \+bd ’ڒعْوتْشْ ن وغْرُومْ‘\+bd* - س حَارْفْ ’أَزدْجَاضْ ن وغْرُومْ‘.\f*  
\v 27 مَاڒَا \add عَاذْ\add* س مَانْ أَيَا وَارْ غَارِي د-ثتّسْڒِيمْ، \add مَاشَا أَذْ ثقِّيممْ\add* أَذْ ثمْعَاڒَامْ أَكِيذِي،  
\v 28 \add خنِّي\add* نشّْ أَذْ خَاومْ سْعَارغْ ؤُ أَذْ كنِّيوْ أَربِّيغْ، وَاهْ سبْعَا ن إِمُورنْ نشّْ \add أَذْ كنِّيوْ أَربِّيغْ\add* ذِي سِّيبّثْ ن دّْنُوبْ نْومْ.  
\v 29 أَذْ ثشّمْ أَيْسُومْ ن إِحنْجِيرنْ نْومْ ؤُڒَا ذ أَيْسُومْ ن ثْحنْجِيرِينْ نْومْ أَذْ ث ثشّمْ. \x ◘ \xo 26:‏29 \xt أَعَوذ. 28‏:‏53؛ 2 إِج. 6‏:‏28؛ إِڭجذ. 4‏:‏10\x*  
\v 30 أَذْ أَردّْدْجغْ ڒڭْعُوذِي \add مَانِي ثتّْوهَّابمْ دّْبَايحْ نْومْ\add*، أَذْ نْضَارغْ إِپِيلَارنْ نْومْ ن أَربِّي ن ثْفُوشْثْ، أَذْ أَرّغْ ڒْخشْبَاثْ نْومْ خْ ڒْخشْبَاثْ ن إِميْضَا \add ن لْ-أَصْنَامْ نْومْ\add* ؤُشَا ڒعْمَارْ إِنُو أَذْ زَّايْومْ إِعِيفّْ. \x ◘ \xo 26:‏30 \xt 2 إِم. 34‏:‏7\x*  
\v 31 أَذْ أَرّغْ ثِيندَّامْ نْومْ ذ ڒْخَارْبثْ ؤُشَا أَذْ أَردّْدْجغْ ثِيزَاوِييِّينْ إِقدّْسنْ نْومْ ؤُشَا وَارْ تّخْسغْ أَذْ شمّغْ \add عَاذْ\add* ڒفْوَاحثْ إِتّْفُوحنْ نْومْ.  
\v 32 وَاهْ، نشّْ أَذْ أَردّْدْجغْ ثَامُّورْثْ ؤُشَا ڒْعذْيَانْ نْومْ، إِنِّي ذَايسْ إِزدّْغنْ، أَذْ زَّايسْ نّْخڒْعنْ.“   
\m
\v 33 ”أَذْ كنِّيوْ زُوزَّارغْ جَارْ ڒڭْنُوسْ ؤُشَا أَذْ كْسغْ سِّيفْ أَوَارْنِي أَومْ ؤُشَا ثَامُّورْثْ نْومْ أَذْ ثذْوڒْ ذ ڒخْڒَا ؤُشَا ثِيندَّامْ نْومْ أَذْ إِڒِينْثْ ذ ڒْخَارْبثْ.  
\v 34 خنِّي ثَامُّورْثْ أَذْ خَاسْ أَرْضَانْ وُوسَّانْ ن سّبْثْ نّسْ، مَارَّا ؤُسَّانْ ن وَاردّدْجْ \add ن ثمُّورْثْ\add*، \add ؤُمِي\add* إِ غَا ثِيڒِيمْ ذِي ثمُّورْثْ ن ڒْعذْيَانْ نْومْ. خنِّي أَذْ ثَاريّحْ ثمُّورْثْ ؤُ أَذْ ثڭّْ ثْشُونِي خْ وُوسَّانْ ن سّبْثْ نّسْ. \x ◘ \xo 26:‏34 \xt لَاوِي 25‏:‏2\x*  
\v 35 مَاڒَا ؤُسَّانْ ن وَاردّدْجْ أَذْ غَارسْ يِيڒِي وَاريّحْ، مِينْزِي ثَامُّورْثْ وَارْ ثَاريِّيحْ شَا ذڭْ وُوسَّانْ ن سّبْثْ نْومْ ڒَامِي ثُوغَا كنِّيوْ ثْزدّْغمْ ذِينِّي.“   
\m
\v 36 ”أَذْ ڭّغْ ثِيڭّْوُوذِي ذڭْ وُوڒَاونْ ن يِينِّي زَّايْومْ إِ غَا إِقِّيمنْ ذِي ثمُّورَا ن ڒْعذْيَانْ نْسنْ، أَڒَامِي ڒْحسّْ ن إِشْثْ ن ثْفَارشْثْ إِ يِيوِي ؤُسمِّيضْ أَذْ خَاسنْ يَاژّڒْ ؤُ أَذْ ثنْ يَارّْ أَذْ أَروْڒنْ أَمْ مَامّشْ إِتَّاركّْوَاڒْ بْنَاذمْ زِي سِّيفْ. نِيثْنِي أَذْ وْضَانْ، وَاخَّا وَارْ خَاسنْ إِتِّيژّڒْ حذْ.  
\v 37 أَذْ نْقَارْضنْ إِجّنْ ذڭْ ونّغْنِي أَمْ خْمِي ژْرِينْ \add ڒقْذعْ ن\add* يِيجّْ ن سِّيفْ، وَاخَّا وَارْ خَاومْ إِتِّيژّڒْ حذْ. كنِّيوْ وَارْ ثْزمَّارنْ أَذْ ثقِّيممْ ثْبدّمْ زَّاثْ إِ ثِيطَّاوِينْ ن ڒْعذْيَانْ نْومْ،  
\v 38 \add مَاشَا\add* كنِّيوْ أَذْ ثتّْوَاهلّْكمْ جَارْ ڒڭْنُوسْ ؤُشَا ثَامُّورْثْ ن ڒْعذْيَانْ نْومْ أَذْ كنِّيوْ ثشّْ.“   
\m
\v 39 ”إِنِّي زَّايْومْ إِ غَا إِقِّيمنْ أَذْ إِسْڒَاونْ ذِي ثمُّورَا ن ڒْعذْيَانْ نْومْ ذِي سِّيبّثْ ن ڒْمُوعْصِييّثْ نْسنْ. ؤُڒَا ذِي سِّيبّثْ ن ڒْمُوعْصِييّثْ ن ڒجْذُوذْ نْسنْ أَذْ سْڒَاونْ نِيثْنِي \add جْمِيعْ\add* أَكِيذْسنْ.   
\m
\v 40 \add مَاشَا\add* مَاڒَا نعْمنْ خْ ڒْمُوعْصِييّثْ نْسنْ ذ ڒْمُوعْصِييّثْ ن إِبَابَاثنْ نْسنْ زِي سِّيبّثْ ن ڒغْذَارْ نْسنْ إِ زِي ذ أَيِي غْذَارنْ ؤُشَا عَاوذْ مّْعَاڒَانْ أَكِيذِي  
\v 41 - ؤُشَا \add خنِّي\add* ؤُڒَا ذ نشّْ مّْعَاڒِيغْ أَكِيذْسنْ ؤُ إِوْيغْ ثنْ غَارْ ثمُّورْثْ ن ڒْعذْيَانْ نْسنْ، مَاحنْذْ أَذْ ثَاغْ ؤُڒْ نْسنْ وَارْ إِخْثِيننْ أَذْ يَاضَارْ ؤُشَا أَذْ قبْڒنْ ڒخْڒَاصْ إِ ڒْمُوعْصِييّثْ نْسنْ -  
\v 42 \add خنِّي\add* نشّْ أَذْ خَارّْصغْ \add عَاوذْ\add* ذِي ڒْعَاهْذْ إِنُو أَكْ-ذ يَاعْقُوبْ ؤُشَا عَاوذْ ذِي ڒْعَاهْذْ إِنُو أَكْ-ذ إِسْحَاقْ ؤُشَا أَذْ خَارّْصغْ ذِي ڒْعَاهْذْ إِنُو أَكْ-ذ إِبْرَاهِيمْ ؤُشَا أَذْ خَارّْصغْ \add عَاوذْ\add* ذِي ثمُّورْثْ.  
\v 43 ثَامُّورْثْ أَذْ ثتّْوَاجّْ زَّايْسنْ ؤُشَا أَذْ خَاسْ أَرْضَانْ وُوسَّانْ ن سّبْثْ نّسْ ؤُمِي غَا ثقِّيمْ ذ إِشْثْ ن ڒْخَارْبثْ خْمِي وَارْ ذَايسْ زدّْغنْ عَاذْ، ؤُشَا نِيثْنِي \add أَذْ ڒمْذنْ\add* أَذْ قبْڒنْ لْعِيقَابْ ن ڒْمُوعْصِييّثْ نْسنْ، مِينْزِي نْضَارنْ لْفَارَايِيضْ إِنُو ؤُ مِينْزِي ڒعْمَارْ نْسنْ إِعِيفّْ زِي ثْوصَّا إِنُو.“   
\m
\v 44 ”سنّجْ إِ ؤُيَا، أَقَا ذ مَانْ أَيَا: مَاڒَا أَقَا أَثنْ ذِي ثمُّورْثْ نْ ڒعْذْيَانْ نْسنْ، نشّْ وَارْ ثنْ نطَّارغْ شَا ؤُ وَارْ ثنْ تّْعِيفِّيغْ أَڒْ ثنْ غَا ثحِّيغْ ؤُ أَذْ مْحِيغْ ڒْعَاهْذْ إِنُو أَكِيذْسنْ مِينْزِي نشّْ ذ سِيذِي، أَربِّي نْسنْ! \x ◘ \xo 26:‏44 \xt أَعَوذ. 4‏:‏31؛ رُوم. 11‏:‏1، 26\x*  
\v 45 \add مَاشَا\add* ذِي طّْوعْ نْسنْ أَذْعقْڒغْ خْ ڒْعَاهْذْ إِنُو أَكْ-ذ إِمزْوُورَا، إِنِّي نذْهغْ زِي ثمُّورْثْ ن مِيصْرَا زَّاثْ إِ ثِيطَّاوِينْ ن ڒڭْنُوسْ، مَاحنْذْ أَذْ إِڒِيغْ ذ أَربِّي إِ نِيثْنِي، نشّْ ذ سِيذِي!“   
\m
\v 46 ثِينَا ذ ثِيوصَّا ذ لْفَارَايِيضْ ذ إِزرْفَانْ نِّي إِڭَّا سِيذِي جَارْ أَسْ ذ جَارْ أَيْثْ ن إِسْرَائِيل ذڭْ وذْرَارْ ن سِينَا س ثْسخَّارْثْ ن مُوسَا.   
\b  
\b  
\m  
\c 27
\s1 لْوُوعُوذْ ذ ؤُفكِّي زَّايْسنْ  
\m
\v 1 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا، إِنَّا:   
\m
\v 2 ”سِيوڒْ أَكْ-ذ أَيْثْ ن إِسْرَائِيل ؤُشَا إِنِي أَسنْ، أَقَا مَاڒَا إِخْسْ حذْ أَذْ إِڭّْ إِجّْ ن لْوَاعْذْ إِ أَربِّي، أَذْ يِيڒِي تَّامَانْ ن ؤُفكِّي ن \bd ڒعْمُورْ\bd* \add إِتّْوَاسّْقدّْسنْ\add* إِ سِيذِي عْلَاحْسَابْ ڒْقِيمثْ إِ ثْقدَّارذْ شكْ.  
\v 3 مَاڒَا ڒْقِيمثْ إِ ثْقدَّارذْ شكْ أَقَا ذ ڒْقدّْ ن إِجّْ ن ورْيَازْ \bd زِي عِيشْرِينْ أَڒْ ستِّينْ ن إِسڭّْوُوسَا\bd*، \add خنِّي\add* أَذْ ثِيڒِي ڒْقِيمثْ إِ ثْقدَّارذْ خمْسِينْ شِيقْلُو ن نُّوقَارْثْ عْلَاحْسَابْ شِيقْلُو ن زَّاوشْثْ إِقدّْسنْ.  
\v 4 مَاڒَا ذ إِشْثْ ن ثمْغَارْثْ، \add خنِّي\add* أَذْ ثِيڒِي ڒْقِيمثْ إِ ثْقدَّارذْ ثْڒَاثِينْ شِيقْلُو.“   
\m
\v 5 ”ؤُشَا مَاڒَا ذ إِجّْ ن ؤُبْڒِيغْ \bd زِي خمْسَا أَڒْ عِيشْرِينْ ن إِسڭّْوُوسَا\bd*، \add خنِّي\add* أَذْ ثِيڒِي ڒْقِيمثْ إِ ثْقدَّارذْ إِ يِيجّْ ن ورْيَازْ عِيشْرِينْ شِيقْلُو ؤُ إِ يِيشْثْ ن ثمْغَارْثْعشْرَا شِيقْلُو.“   
\m
\v 6 ”مَاڒَا ذ إِجّْ ن ؤُحنْجِيرْ \bd زڭْ يِيجّْ ن ؤُيُورْ أَڒْ خمْسَا ن إِسڭّْوُوسَا\bd*، \add خنِّي\add* أَذْ ثِيڒِي ڒْقِيمثْ إِ ثْقدَّارذْ إِ يِيجّْ ن ورْيَازْ خمْسَا شِيقْلُو ن نُّوقَارْثْ ؤُ إِ يِيشْثْ ن ثمْغَارْثْ ثْڒَاثَا شِيقْلُو ن نُّوقَارْثْ.“   
\m
\v 7 ”مَاڒَا ذ إِجّْ ن مِّيسْ \add ن بْنَاذمْ\add* \bd زِي ستِّينْ إِسڭّْوُوسَا نِيغْ سنّجْ\bd*، \add خنِّي\add*، مَاڒَا نتَّا ذ أَرْيَازْ، أَذْ ثِيڒِي ڒْقِيمثْ إِ ثْقدَّارذْ خمّسْطَاشْ شِيقْلُو ؤُ مَاڒَا ذ ثَامْغَارْثْ \add أَذْ ثِيڒِي ڒْقِيمثْ إِ ثْقدَّارذْ\add*عشْرَا ن شِيقْلُو.“   
\m
\v 8 ”مَاڒَا ثُوغَا إِژْڒضْ أَطَّاسْ ؤُ وَارْ إِزمَّارْ \add أَذْ إِوْشْ\add* ڒْقِيمثْ \add إِ ثْقدَّارذْ\add* شكْ، \add خنِّي\add* أَذْ ث سّْبدّنْ زَّاثْ إِ وُوذمْ ن ؤُكهَّانْ ؤُشَا \add خنِّي\add* أَذْ إِقدَّارْ ؤُكهَّانْ ڒْقِيمثْ نّسْ. أَذْ ث إِقدَّارْ ؤُكهَّانْ عْلَاحْسَابْ مِينْ إِزمَّارْ أَذْ إِسّْمُونْ ؤُفُوسْ ن ونِّي إِوْشِينْ أَوَاڒْ، \add أَمُّو\add* إِ ث غَا إِقدَّارْ ؤُكهَّانْ.“   
\b  
\m
\v 9 ”مَاڒَا ذ \bd ڒبْهَايمْ\bd* إِ زِي غَا قدّْمنْ ثَاوْهِيبْثْ إِ سِيذِي، \add خنِّي\add* مَارَّا مِينْ زَّايْسنْ غَا إِوْشْ نتَّا إِ سِيذِي، أَذْ يِيڒِي إِقدّسْ.  
\v 10 وَارْ إِتّْبذِّيڒْ ؤُ وَارْ إِخدْجفْ \add أَمُودَّارْ\add* إِشْنَانْ خْ ونِّي إِقبْحنْ نِيغْ \add أَمُودَّارْ\add* إِقبْحنْ خْ ونِّي إِشْنَانْ. مَاڒَا إِبدّڒْ عَاذْ إِشْثْ ن ڒبْهِيمثْ س إِشْثْ ن ڒبْهِيمثْ نّغْنِي، \add خنِّي\add* ثَا ذ ثنِّي إِ خْ ت إِبدّڒْ أَذْ إِڒِينْثْ قدّْسنْثْ.  
\v 11 مَاڒَا ثدْجَا ذ إِشْثْ ن ڒبْهِيمثْ ثخْمجْ، وَارْ إِعدّڒْ أَذْ ت قدّْمنْ ذ ثَاوْهِيبْثْ إِ سِيذِي، \add خنِّي\add* أَذْ يَارّْ ڒبْهِيمثْ نِّي أَذْ ثْبدّْ زَّاثْ إِ وُوذمْ ن ؤُكهَّانْ.  
\v 12 أَكهَّانْ أَذْ إِقدَّارْ ڒْقِيمثْ نّسْ جَارْ مِينْ إِشْنَانْ ذ مِينْ وَارْ إِحْڒِينْ. ؤُشَا أَمْ مَامّشْ إِ ت غَا ثْقدَّارذْ شكْ، أَمْ ؤُكهَّانْ، أَمُّو إِ غَا ثِيڒِي.  
\v 13 مَاڒَا نتَّا إِخْسْ عَاذْ أَذْ ت إِفْذِي، أَذْ خَاسْ يَارْنِي إِشْثْ ن ثسْغَارْثْ ن ثخْمُوسشْثْ نْ ڒْقِيمثْ إِ ثْقدَّارذْ شكْ.“\f ◼ \fr 27:‏13 \ft \+bd ’إِفْذِي‘\+bd* - خْزَارْ إِزهد. 78:35.\f*   
\b  
\m
\v 14 ”مَاڒَا شَا ن يِيجّنْ إِسّْقدّسْ \bd ثَادَّارْثْ\bd* نّسْ، مَاحنْذْ أَذْ ثِيڒِي ثْقدّسْ إِ سِيذِي، \add خنِّي\add* أَذْ إِقدَّارْ ؤُكهَّانْ ڒْقِيمثْ نّسْ جَارْ مِينْ إِشْنَانْ ذ مِينْ إِقبْحنْ. أَمْ مَامّشْ إِقدَّارْ ؤُكهَّانْ ڒْقِيمثْ نّسْ، \add أَمُّو إِ\add* غَا ثِيڒِي.  
\v 15 مَاڒَا ونِّي ت إِسّْقدّْسنْ إِخْسْ أَذْ إِفْذِي ثَادَّارْثْ نّسْ، \add خنِّي\add* نتَّا أَذْ خَاسْ يَارْنِي إِشْثْ ن ثسْغَارْثْ ن ثخْمُوسشْثْ ن ڒْقِيمثْ إِتّْوَاڭّنْ س نُّوقَارْثْ ؤُشَا أَذْ ثِيڒِي نّسْ \add عَاوذْ\add*.“   
\b  
\m
\v 16 ”مَاڒَا شَا ن يِيجّنْ إِسّْقدّسْ إِ سِيذِي \add شَا ن ثسْغَارْثْ\add* ن \bd ييَّارْ\bd* نِّي غَارسْ إِدْجَانْ، \add خنِّي\add* أَذْ ثْقدَّارذْ ڒْقِيمثْ نّسْ عْلَاحْسَابْ زَّارِيعثْ نّسْ. زَّارِيعثْ ن إِجّْ ن ؤُحُومِيرْ ن إِمنْذِي \add أَذْ أَسْ ڭّنْ\add* خمْسِينْ شِيقْلُو. \f ◼ \fr 27:‏16 \ft \+bd ’أَحُومِيڒْ‘\+bd* - ’أَحُومِيرْ‘ ذ إِجّْ ن ’كُورْ‘ (حِز. 45:11، 14). إِجّْ ن ؤُحُومِيرْ نِيغْ إِجّْ ن كُورْ، أَقَا 222 لِيثْرْ.\f*  
\v 17 مَاڒَا ثُوغَا إِسّْقدّسْ إِيَّارْ نّسْ زڭْ ؤُسڭّْوَاسْ ن ؤُسْڒِيوْڒوْ، \add خنِّي\add* أَذْ ثذْوڒْ \add ڒْقِيمثْ ن ييَّارْ\add* ثْبدّْ عْلَاحْسَابْ ڒْقِيمثْ إِ ثْقدَّارذْ.  
\v 18 مَاڒَا ثُوغَا إِسّْقدّسْ إِيَّارْ نّسْ أَوَارْنِي إِ ؤُسڭّْوَاسْ ن ؤُسْڒِيوْڒوْ، \add خنِّي\add* أَكهَّانْ أَذْ أَسْ إِهْصبْ \add ڒْقِيمثْ س\add* نُّوقَارْثْ ن إِسڭّْوُوسَا إِقِّيمنْ أَڒْ أَسڭّْوَاسْ ن ؤُسْڒِيوْڒوْ \add إِ د غَا يَاسنْ\add* ؤُ \add خنِّي\add* أَذْ ثِيڒِي ڒْقِيمثْ قلّْ خْ ڒْقِيمثْ \add ثْمُونْ\add* إِ ثُوغَا ثْقدَّارذْ شكْ.  
\v 19 مَاڒَا ونِّي إِسّْقدّْسنْ إِيَّارْ، إِخْسْ أَذْ ث إِفْذِي نِيشَانْ، \add خنِّي\add* أَذْ يَارْنِي إِشْثْ ن ثسْغَارْثْ ن ثخْمُوسشْثْ ذِي نُّوقَارْثْ خْ ڒْقِيمثْ إِ ثْقدَّارذْ شكْ ؤُشَا \add خنِّي\add* أَذْ أَسْ يِيڒِي \add عَاوذْ\add*.“   
\m
\v 20 ”مَاڒَا وَارْ إِخْسْ أَذْ إِفْذِي إِيَّارْ \add نِّي\add* نِيغْ مَاڒَا إِزّنْزْ إِيَّارْ إِ يِيجّْ ن ورْيَازْ نّغْنِي، \add خنِّي\add* وَارْ إِزمَّارْ أَذْ إِتّْوَافْذِي عَاذْ \add ييَّارْ\add*.  
\v 21 أَوَارْنِي ڒَامِي د-إِفّغْ ذڭْ ؤُسڭّْوَاسْ ن ؤُسْڒِيوْڒوْ، أَذْ يِيڒِي إِيَّارْ إِقدّسْ إِ سِيذِي أَمْ يِيجّْ ن ييَّارْ إِتّْوَاحَارّْمنْ قَاعْ. أَذْ يِيڒِي ذ أَڭْڒَا ن ؤُكهَّانْ.“   
\m
\v 22 ”مَاڒَا شَا ن يِيجّنْ إِسّْقدّسْ إِجّْ ن ييَّارْ نِّي إِسْغَا إِ سِيذِي، \add مَاشَا\add* وَارْ إِدْجِي ييَّارْ ن وَاڭْڒَا نّسْ،  
\v 23 \add خنِّي\add* أَكهَّانْ أَذْ أَسْ إِحْسبْ تَّامَانْ ن ڒْقِيمثْ إِ ثْقدَّارذْ شكْ أَڒْ أَسڭّْوَاسْ ن ؤُسْڒِيوْڒوْ ؤُشَا نتَّا أَذْ إِخدْجصْ ڒْقِيمثْ إِ ثْقدَّارذْ ذڭْ وَاسّْ نِّي ذ إِجّْ \add أَمْ\add* إِشْثْ ن ثْمسْڒَاشْثْ ثْقدّسْ إِ سِيذِي.  
\v 24 ذڭْ ؤُسڭّْوَاسْ ن ؤُسْڒِيوْڒوْ أَذْ د-إِعْقبْ ييَّارْ عَاوذْ إِ ونِّي خْ ث إِسْغَا، إِ ونِّي ثُوغَا غَارْ ثدْجَا ثمُّورْثْ ذ أَڭْڒَا.  
\v 25 أَقدَّارْ أَذْ يِيڒِي عْلَاحْسَابْ شِيقْلُو ن زَّاوشْثْ إِقدّْسنْ. أَذْ يِيڒِي شِيقْلُو عِيشْرِينْ جِيرَا.“\x ◘ \xo 27:‏25 \xt ؤُف. 30‏:‏13؛ ڒخْڒ. 3‏:‏47؛ حِز. 45‏:‏12\x*   
\b  
\m
\v 26 ”مَاشَا \bd أَمنْزُو، ونِّي إِفَارْزنْ إِ سِيذِي زِي ڒبْهَايمْ\bd* أَمْ ؤُمنْزُو، وَارْ إِعدّڒْ أَذْ ث إِسّْقدّسْ ؤُڒَا ذ إِجّنْ، نِيغْ ذ أَفُونَاسْ \add إِ إِدْجَا\add* نِيغْ ذ إِجّنْ زڭْ وُودْجِي، أَقَا-ث إِ سِيذِي. \x ◘ \xo 27:‏26 \xt ؤُف. 13‏:‏2؛ 22‏:‏29؛ 34‏:‏19؛ ڒخْڒ. 3‏:‏13؛ 8‏:‏17\x*  
\v 27 \add مَاشَا\add* مَاڒَا ثُوغَا-ث زڭْ إِشْثْ ن ڒبْهِيمثْ إِخمْجنْ، إِزمَّارْ أَذْ ت إِفْذِي عْلَاحْصَابْ ڒْقِيمثْ إِ ثْقدَّارذْ شكْ ؤُشَا أَذْ خَاسْ يَارْنِي إِشْثْ ن ثسْغَارْثْ ن ثخْمُوسشْثْ. مَاڒَا وَارْ ثتّْوَافذِّي، \add خنِّي\add* أَذْ ثمّنْزْ عْلَاحْسَابْ ڒْقدّْ إِ ثْقدَّارذْ شكْ.“   
\b  
\m
\v 28 ”\add مَاشَا\add* ؤُڒَا ذ إِشْثْ ن ڒْحَاجّثْ نِّي إِتّْوَاحَارّْمنْ زڭْ إِجّْ ن ورْيَازْ إِ سِيذِي زِي مَارَّا مِينْ غَارسْ إِدْجَانْ ن إِوْذَانْ ذ ڒبْهَايمْ ذ إِيَّارنْ، وَارْ إِعدّڒْ أَذْ ثمّنْزْ نِيغْ أَذْ ثتّْوَافْذِي. \bd مَارَّا مِينْ إِتّْوَاحَارّْمنْ، أَذْ يِيڒِي ذ أَمْقدَّاسْ قَاعْ إِ سِيذِي.\bd* \x ◘ \xo 27:‏28 \xt ياش. 6‏:‏18؛ 7‏:‏13‏-‏26.\x*  
\v 29 مَارَّا مِينْ إِتّْوَاحَارّْمنْ قَاعْ \add إِ ؤُثحِّي\add*، مِينْ إِتّْوَاحَارّْمنْ زڭْ إِوْذَانْ، وَارْ إِعدّڒْ أَذْ إِتّْوَافْذِي، \add مَاشَا\add* إِتّْخصَّا أَذْ إِتّْوَانغْ نِيشَانْ.“   
\b  
\m
\v 30 ”\bd مَارَّا ثِيعْشُورَايْ ن ثمُّورْثْ\bd*، زِي زَّارِيعثْ ن ثمُّورْثْ ؤُ زِي ڒْغِيدْجثْ ن ثْشجُّورَا، \add أَذْ إِڒِينْثْ\add* إِ سِيذِي، أَقَا أَثنْثْ قدّْسنْثْ إِ سِيذِي.  
\v 31 مَاڒَا شَا ن يِيجّنْ إِخْسْ أَذْ إِفْذِي شَا زِي ڒعْشُورْ نّسْ، \add خنِّي\add* أَذْ خَاسْ يَارْنِي إِشْثْ ن ثسْغَارْثْ ذِي خمْسَا.  
\v 32 خْ مَارَّا ثِيعْشُورَايْ زڭْ إِفُونَاسنْ ذ ثْفُونَاسِينْ ذ وُودْجِي، زِي مَارَّا مِينْ إِكِّينْ سَاذُو ؤُزدْجَاضْ \add ن ؤُمكْسَاوْ\add*، أَذْ يِيڒِي \add ؤُمُودَّارْ\add* وِيسّْعشْرَا إِقدّسْ إِ سِيذِي.  
\v 33 وَارْ إِعدّڒْ أَذْ يَارْزُو مَامّشْ ثشْنَا نِيغْ مَامّشْ وَارْ ثحْڒِي \add إِ ثدْجَا\add*، ؤُڒَا وَارْ ث إِتّْبذِّيڒْ شَا، \add مَاشَا\add* مَاڒَا إِبدّڒْ إِ-ث، \add خنِّي\add* \add أَمُودَّارْ\add* نِّي ذ ونِّي زِي ث إِ غَا إِبدّڒْ أَذْ إِڒِينْ قدّْسنْ. وَارْ إِعدّڒْ أَذْ إِتّْوَافْذِي.“   
\m
\v 34 أَقَا ثِينَا ذ ثِيوصَّا نِّي إِ زِي إِوصَّا سِيذِي إِ مُوسَا ؤُ إِ أَيْثْ ن إِسْرَائِيل ذڭْ وذْرَارْ ن سِينَا.   