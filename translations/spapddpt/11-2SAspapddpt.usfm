\p 
\v 20 \w Su|strong="H1931"\w* padre Absalón \w le|strong="H1931"\w* preguntó: ¿\w Estuvo|strong="H1961"\w* \w contigo|strong="H5973"\w* tu hermano Amnón? \w Calla|strong="H2790"\w* \w ahora|strong="H6258"\w*, hija mía, \w pues|strong="H6258"\w* \w es|strong="H1931"\w* tu hermano. \w No|strong="H1961"\w* \w se|strong="H1961"\w* angustie tu \w corazón|strong="H3820"\w* \w por|strong="H1697"\w* \w este|strong="H2088"\w* \w asunto|strong="H1697"\w*. \w Y|strong="H3068"\w* Tamar \w quedó|strong="H1961"\w* \w desconsolada|strong="H8076"\w* \w en|strong="H5973"\w* \w casa|strong="H1004"\w* \w de|strong="H5973"\w* \w su|strong="H1931"\w* padre Absalón.
\p 
\v 21 Cuando \w el|strong="H3605"\w* \w rey|strong="H4428"\w* \w David|strong="H1732"\w* \w oyó|strong="H8085"\w* \w todo|strong="H3605"\w* \w esto|strong="H1697"\w* se enojó muchísimo.
\v 22 \w Y|strong="H3068"\w* Absalón \w no|strong="H3808"\w* \w habló|strong="H1696"\w* \w con|strong="H5973"\w* Amnón \w mal|strong="H7451"\w* \w ni|strong="H3808"\w* \w bien|strong="H2896"\w*, \w pero|strong="H3588"\w* \w lo|strong="H1697"\w* aborreció \w porque|strong="H3588"\w* violó \w a|strong="H3068"\w* \w su|strong="H3588"\w* hija Tamar.
\s1 Muerte de Amnón
\p 
\v 23 \w Dos|strong="H8141"\w* \w años|strong="H8141"\w* \w después|strong="H1961"\w*, \w aconteció|strong="H1961"\w* \w que|strong="H3117"\w* Absalón \w tenía|strong="H1961"\w* \w esquiladores|strong="H1494"\w* \w en|strong="H5973"\w* Baal-hazor, \w que|strong="H3117"\w* \w está|strong="H1961"\w* \w junto|strong="H5973"\w* \w a|strong="H3068"\w* Efraín. Absalón invitó \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w del|strong="H5973"\w* \w rey|strong="H4428"\w*.
\v 24 Absalón \w fue|strong="H3212"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w* y \w le|strong="H5973"\w* dijo: \w Mira|strong="H2009"\w*, tu esclavo tiene \w esquiladores|strong="H1494"\w*. \w Te|strong="H5973"\w* \w ruego|strong="H4994"\w* \w que|strong="H4994"\w* \w el|strong="H5973"\w* \w rey|strong="H4428"\w* y sus servidores \w vayan|strong="H3212"\w* \w con|strong="H5973"\w* tu esclavo.
\p 
\v 25 Pero \w el|strong="H5921"\w* \w rey|strong="H4428"\w* dijo \w a|strong="H3068"\w* Absalón: \w No|strong="H3808"\w*, \w hijo|strong="H1121"\w* \w mío|strong="H5921"\w*, \w no|strong="H3808"\w* \w vamos|strong="H3212"\w* \w todos|strong="H3605"\w* \w para|strong="H5921"\w* \w no|strong="H3808"\w* serte carga pesada. \w Y|strong="H3068"\w* \w aunque|strong="H3808"\w* \w le|strong="H5921"\w* insistió, \w él|strong="H5921"\w* \w no|strong="H3808"\w* quiso \w ir|strong="H3212"\w*, pero \w lo|strong="H3808"\w* \w bendijo|strong="H1288"\w*.
\p 
\v 26 Entonces Absalón dijo: \w Si|strong="H3808"\w* \w no|strong="H3808"\w* \w vas|strong="H3212"\w*, \w te|strong="H5973"\w* \w ruego|strong="H4994"\w* \w que|strong="H4100"\w* \w vaya|strong="H3212"\w* \w con|strong="H5973"\w* \w nosotros|strong="H5973"\w* \w mi|strong="H4994"\w* hermano Amnón.
\p \w Y|strong="H3068"\w* \w el|strong="H5973"\w* \w rey|strong="H4428"\w* \w le|strong="H5973"\w* preguntó: ¿\w Para|strong="H5973"\w* \w qué|strong="H4100"\w* debe \w ir|strong="H3212"\w* \w contigo|strong="H5973"\w*?
\p 
\v 27 Como Absalón le insistió, \w dejó|strong="H7971"\w* \w a|strong="H3068"\w* Amnón y \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* del \w rey|strong="H4428"\w* \w ir|strong="H7971"\w* con \w él|strong="H3605"\w*.
\p 
\v 28 Absalón \w ordenó|strong="H6680"\w* \w a|strong="H3068"\w* sus esclavos: Observen \w cuando|strong="H3588"\w* \w el|strong="H3588"\w* \w corazón|strong="H3820"\w* \w de|strong="H3588"\w* Amnón \w esté|strong="H1961"\w* \w alegre|strong="H2896"\w* \w por|strong="H3588"\w* causa del \w vino|strong="H3196"\w*. \w Cuando|strong="H3588"\w* \w yo|strong="H3588"\w* \w les|strong="H6680"\w* diga: Maten \w a|strong="H3068"\w* Amnón, \w entonces|strong="H3588"\w* \w lo|strong="H3808"\w* \w matarán|strong="H4191"\w*. \w No|strong="H3808"\w* \w teman|strong="H3372"\w*. ¿\w No|strong="H3808"\w* \w se|strong="H1961"\w* \w lo|strong="H3808"\w* \w ordeno|strong="H6680"\w* \w yo|strong="H3588"\w*? ¡\w Esfuércense|strong="H2388"\w* \w y|strong="H3588"\w* \w sean|strong="H1961"\w* \w valientes|strong="H2428"\w*!
\v 29 \w Los|strong="H1121"\w* esclavos \w de|strong="H5921"\w* Absalón mataron \w a|strong="H3068"\w* Amnón \w como|strong="H5921"\w* Absalón \w les|strong="H5921"\w* \w ordenó|strong="H6680"\w*. \w Y|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w del|strong="H5921"\w* \w rey|strong="H4428"\w* \w se|strong="H5921"\w* \w levantaron|strong="H6965"\w*, \w cada|strong="H3605"\w* uno montó \w en|strong="H5921"\w* su mula, \w y|strong="H5921"\w* \w huyeron|strong="H5127"\w*.
\p 
\v 30 \w Cuando|strong="H1961"\w* \w ellos|strong="H1992"\w* \w estaban|strong="H1961"\w* \w aún|strong="H3808"\w* \w en|strong="H5221"\w* \w el|strong="H3605"\w* \w camino|strong="H1870"\w*, un \w rumor|strong="H8052"\w* llegó \w a|strong="H3068"\w* \w David|strong="H1732"\w*: ¡Absalón \w mató|strong="H5221"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* del \w rey|strong="H4428"\w*, y \w no|strong="H3808"\w* \w quedó|strong="H3498"\w* \w alguno|strong="H3605"\w* \w de|strong="H1121"\w* \w ellos|strong="H1992"\w*!
