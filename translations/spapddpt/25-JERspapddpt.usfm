\s1 Conspiración contra Jeremías  
\p
\v 18 \nd \+w Yavé|strong="H3068"\+w*\nd* me lo informó y lo \w supe|strong="H3045"\w*. Entonces Tú me mostraste sus \w obras|strong="H4611"\w*.  
\v 19 \w Pero|strong="H3588"\w* \w yo|strong="H3588"\w* era \w como|strong="H3588"\w* un \w cordero|strong="H3532"\w* manso \w llevado|strong="H2986"\w* \w al|strong="H5921"\w* matadero. \w No|strong="H3808"\w* \w sabía|strong="H3045"\w* \w que|strong="H3588"\w* \w ellos|strong="H5921"\w* tramaban \w designios|strong="H4284"\w* \w contra|strong="H5921"\w* \w mí|strong="H5921"\w* \w y|strong="H3588"\w* decían: \w Destruyamos|strong="H7843"\w* \w el|strong="H5921"\w* \w árbol|strong="H6086"\w* \w con|strong="H5921"\w* \w su|strong="H3588"\w* fruto. Cortémoslo \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w vivientes|strong="H2416"\w* \w para|strong="H5921"\w* \w que|strong="H3588"\w* \w nadie|strong="H3808"\w* recuerde \w su|strong="H3588"\w* \w nombre|strong="H8034"\w*.  
\v 20 ¡Oh \nd \+w Yavé|strong="H3068"\+w*\nd* \w de|strong="H3588"\w* \w las|strong="H1992"\w* huestes! \w Tú|strong="H8199"\w*, Quien juzgas \w con|strong="H3588"\w* \w justicia|strong="H6664"\w* \w y|strong="H3588"\w* escudriñas \w la|strong="H3588"\w* mente \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w corazón|strong="H3820"\w*: \w Vea|strong="H7200"\w* \w yo|strong="H3588"\w* \w tu|strong="H8199"\w* \w venganza|strong="H5360"\w* \w de|strong="H3588"\w* \w ellos|strong="H1992"\w*, \w porque|strong="H3588"\w* ante Ti expongo mi \w causa|strong="H7379"\w*.   
\p
\v 21 \nd \+w Yavé|strong="H3068"\+w*\nd* declara \w con|strong="H5921"\w* respecto \w a|strong="H3068"\w* \w los|strong="H5921"\w* hombres \w de|strong="H5921"\w* Anatot, quienes \w buscan|strong="H1245"\w* \w mi|strong="H5921"\w* \w vida|strong="H5315"\w* \w y|strong="H5921"\w* dicen: \wj \+w No|strong="H3808"\+w* \+w profetices|strong="H5012"\+w* \+w en|strong="H5921"\+w* \+w Nombre|strong="H8034"\+w* \+w de|strong="H5921"\+w* \+nd \+w Yavé|strong="H3068"\+w*\+nd*, \+w no|strong="H3808"\+w* sea \+w que|strong="H3808"\+w* mueras \+w a|strong="H3068"\+w* \+w manos|strong="H3027"\+w* nuestras.\wj*  
