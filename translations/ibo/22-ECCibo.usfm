\id ECC - Biblica® Open Igbo Contemporary Bible 2020
\h Ekiliziastis
\toc1 Ekiliziastis
\toc2 Ekiliziastis
\toc3 Ekl
\mt1 Ekiliziastis
\c 1
\s1 Ọ nweghị ihe nwere isi
\p 
\v 1 Okwu onye ozizi, nwa Devid, onye bụ eze na Jerusalem.
\q1 
\v 2 Ihe efu, ihe niile bụ ihe efu
\q2 ka onye ozizi na-ekwu.
\q1 Ihe na-enweghị isi\f + \fr 1:2 \ft Maọbụ, \fqa ihe efu \xt Abụ 144:4.\xt*\f* ka ihe niile bụ.
\q2 Ihe niile bụ nnọọ ihe efu.
\b
\q1 
\v 3 Olee uru mmadụ na-enweta site na ndọgbu niile
\q2 ọ na-adọgbu onwe ya nʼọrụ nʼokpuru anyanwụ?
\q1 
\v 4 Otu ọgbọ laa, ọgbọ ọzọ abịa,
\q2 ma ụwa na-adịgide ruo ebighị ebi.
\q1 
\v 5 Anyanwụ na-awa, na-adakwa,
\q2 ma mee ngwangwa laghachi ebe o si awapụta.
\q1 
\v 6 Ifufe na-efe gaa na ndịda;
\q2 feekwa gburugburu gaa nʼugwu,
\q1 ọ na-efegharị gburugburu ebe niile;
\q2 na-efe na-enweghịkwa nsọtụ.
\q1 
\v 7 Mmiri dị nʼiyi niile na-asọbanye nʼoke osimiri
\q2 ma oke osimiri ejughị eju.
\q1 Emesịakwa, mmiri ndị a na-alọghachi nʼiyi ndị a,
\q2 malitekwa ịsọkwa na-aga nʼosimiri.
\q1 
\v 8 Ihe niile nọ na-adọgbu onwe ha nʼọrụ;
\q2 ọnụ apụghị ịkọ ụdị ike ọgwụgwụ dịnụ.
\q1 Otu ọbụla anyị si lee anya, afọ adịghị eju anya anyị.
\q2 Afọ adịghịkwa eju ntị anyị ịnụ ihe, na ige ntị.
\q1 
\v 9 Ihe ọbụla nke dịrịla na mbụ ga-adịkwa ọzọ.
\q2 Ihe ndị mmadụ mere nʼoge gara aga ka a ga-emekwa ọzọ.
\q2 Ọ dịkwaghị ihe ọhụrụ ọbụla dị nʼokpuru anyanwụ.
\q1 
\v 10 Ọ dị ihe enwere ike ikwu sị,
\q2 “Lee, ihe a bụ ihe ọhụrụ”?
\q1 Ọ bụ ihe dịịrị nʼoge gara aga,
\q2 nʼoge ndị garalarị tupu oge anyị.
\q1 
\v 11 Anaghị echeta ndị mgbe ochie,
\q2 otu aka ahụ kwa, ọgbọ na-abịa abịa
\q1 ndị ga-eso ha
\q2 agakwaghị echeta ha.
\s1 Amamihe enweghị isi
\p 
\v 12 Mụ onwe m bụ onye nkuzi, bụrịị eze Izrel nʼime Jerusalem.
\v 13 Ekpebiri m, were onwe m nye, iji amamihe nnyochapụta ihe m nwere ike ịmata banyere ihe niile a na-eme nʼime ụwa. Olee ụdị ibu arọ bụ nke a, nke Chineke bokwasịrị ụmụ mmadụ?
\v 14 Enyochaala m ihe niile a na-eme nʼụwa chọpụta na ha enweghị isi. Ọ dị ka mmadụ ịchụgharị ifufe.
\q1 
\v 15 Ihe gbagọrọ agbagọ, apụghị ime ya ka ọ dizie.
\q2 Ihe na-ezughị ezu, enweghị ike ịgụta ha ọnụ.
\p 
\v 16 Echere m nʼime obi m sị, “Lee anya! Aghọọla m onye ukwu, bụrụ onye maara ihe karịa ndị eze niile chịrịla na Jerusalem. Enweela m amamihe nʼebe ọ dị ukwu, babigakwa ụba oke nʼihe ọmụma.”
\v 17 Nʼihi ya, agbalịsiri m ike ịmụta ihe dị iche nʼetiti ihe ọmụma, na ịyị ara na nzuzu. Ma ihe m chọpụtara bụ na ọ baghị uru. Ọ dị ka itufu oge ịchọ ụzọ ijide ifufe.
\q1 
\v 18 Nʼihi na mgbe amamihe na-aba ụba, mgbe ahụ ka iwe na ọnụma na-ejupụta,
\q2 oke ihe ọmụma na-ewetakwa oke ihe mgbu.
\c 2
\s1 Ịgbaso ihe na-enye aṅụrị enweghị isi
\p 
\v 1 Echere m nʼime obi m sị, Ugbu a, aga m eji ihe na-enye obi aṅụrị nwaa gị site otu a chọpụta ihe dị mma, ma nke a bụkwa ihe efu.
\v 2 “Ọchị,” ka m sịrị na “ọ bụ ihe nzuzu. Ikpori ndụ, uru gịnị ka ọ bara?”
\v 3 Echere m nʼobi ụtọ m ga-esite nʼịṅụ mmanya. Agbasokwara m ụzọ ibi ndụ nzuzu ma obi m nọ nnọọ na-edu m site nʼamamihe. Olileanya m bụ na m ga-esi otu a chọta ụzọ kachasị mma ndị mmadụ nwere ike iji bie mkpụmkpụ ndụ ha nʼụwa.
\p 
\v 4 Arụpụtara m ọtụtụ ihe dị iche iche, ewuru m ụlọ nye onwe m ma nweekwa ubi vaịnị.
\v 5 Ewuru m ubi a gbara ogige ebe izuike, ma kụọkwa osisi na-amị mkpụrụ dị iche iche nʼime ha,
\v 6 wuore onwe m ọdọ mmiri ebe a ga-esi na-agba ubi m niile mmiri.
\v 7 Agbatara m ndị ohu nwoke na nwanyị, nweekwa ndị ohu ọzọ a mụrụ nʼụlọ m. Enwekwara m ọtụtụ igwe ehi na anụ ụlọ karịa eze niile ndị bu m ụzọ chịa na Jerusalem.
\v 8 Achịkọtara m ọlaọcha na ọlaedo nye onwe m, na akụnụba nke ọtụtụ ndị eze na-achị ala ha na-atụtara m. E nwetakwara m nye onwe m ndị ikom na ndị inyom ndị na-abụ abụ. Enwekwara ndị iko nwanyị nʼebe ọ bara ụba. Ihe ụtọ niile ndị na-amasị obi nwa mmadụ.
\v 9 E, aghọrọ m onye dị ukwuu karịa eze niile ndị burula m ụzọ chịa na Jerusalem. Ma nʼime ihe ndị a niile, anya doro m, ihe niile ka m ji amamihe tulee.
\q1 
\v 10 Ihe ọbụla m chọrọ, ka m na-ewere;
\q2 egbochighị m onwe m aṅụrị ọbụla.
\q1 Obi m ṅụrịrị ọṅụ site nʼọrụ niile,
\q2 nke a bụkwa oke m ketara na ndọgbu niile m dọgburu onwe m.
\q1 
\v 11 Mgbe m tulere ihe banyere ihe ndị a niile m tinyetụrụ aka,
\q2 otu m si dọgbuo onwe m nʼọrụ banyere ha,
\q1 mkpebi m bụ na ha niile bụ ihe efu, dịka ịchọ ijide ifufe.
\q2 Nʼezie, ihe niile bụ ihe efu, ha abakwaghị uru.
\s1 Amamihe na nzuzu enweghị isi
\q1 
\v 12 Atụgharịrị m bido ịmụ ihe banyere amamihe,
\q2 na ịyị ara na nzuzu.
\q1 Olee ihe ọzọ nke onye ga-anọchi anya eze ga-eme,
\q2 karịa ihe ndị ahụ e merela na mbụ?
\q1 
\v 13 Achọpụtara m na amamihe dị mma karịa nzuzu,
\q2 dịka ìhè si dị mma karịa ọchịchịrị.
\q1 
\v 14 Nʼihi na onye maara ihe na-ahụ ụzọ
\q2 ma isi kpuru onye nzuzu.
\q1 Ma achọpụtakwara m
\q2 na otu ihe ndaba na-adabara onye amamihe na onye nzuzu.
\p 
\v 15 Agwara m onwe m okwu sị,
\q1 “Dịka onye nzuzu ga-anwụ, otu ahụ kwa ka m ga-anwụ.
\q2 Gịnị bụ uru amamihe m niile bara?”
\q1 Ekwuru m nʼobi m sị,
\q2 “Ihe a bụkwa ihe efu.
\q1 
\v 16 Nʼihi na onye maara ihe na onye nzuzu bụ ndị a na-agaghị echeta ihe banyere ogologo oge dị nʼihu.
\q2 Nʼụbọchị ndị na-abịa nʼihu, a gaghị echeta ha.
\q1 Onye amamihe na onye nzuzu aghaghị ịnwụ.”
\s1 Ndọgbu nʼọrụ abaghị uru
\p 
\v 17 Ya mere, akpọrọ m ịdị ndụ asị, nʼihi na ọrụ a na-arụ nʼokpuru anyanwụ wutere m. Ihe efu ka ọ bụ; ọ dị ka ịchụgharị ifufe.
\v 18 Ihe niile m gbalịrị ịrụpụta ka m kpọrọ asị, nʼihi na amaara m na emesịa, aga m ahapụrụ ha onye ọzọ na-abịa nʼazụ m.
\v 19 Onye maara ma ọ ga-abụ onye maara ihe ma ọ ga-abụkwanụ onye nzuzu? Ma ihe niile m ji amamihe ǹka m na ike m rụpụta nʼokpuru anyanwụ ga-abụ nke ya! Ihe a bụ ihe efu.
\v 20 Ya mere, o wutere m nʼobi na m dọgburu onwe m nʼọrụ nʼokpuru anyanwụ.
\v 21 Nʼihi na mmadụ nwere ike jiri amamihe, na ihe ọmụma na ǹka dọgbuo onwe ya nʼọrụ, emesịa, ha ahapụrụ onye na-enweghị mgbe ọ rụrụ ọrụ ọbụla ihe ndị ahụ niile. Nke a bụkwa ihe efu, na oke ihe ndakwasị.
\v 22 Gịnị bụ uru mmadụ na-enweta na ndọgbu niile ọ na-adọgbu onwe ya nʼọrụ nʼokpuru anyanwụ?
\v 23 Nʼihi nʼụbọchị ha niile jupụtara naanị nʼihe mgbu na iru ụjụ, ọ bụladị nʼabalị, obi ha anaghị ezu ike. Ihe ndị a bụkwa ihe efu.\f + \fr 2:23 \ft \xt Job 5:7; Job 14:1\xt*\f*
\p 
\v 24 Nʼihi ya, ekpebiri m na ọ dịghị ihe ọzọ ga-abara mmadụ uru karịakwa naanị ịnọdụ ala rie nri, ṅụọkwa ihe ma chọta ojuju afọ nʼọrụ ya. Achọpụtakwara m na ọ bụladị nke a si nʼaka Chineke.
\v 25 Ọ dịghị onye pụrụ iri maọbụ ṅụọ ma o siteghị na Chineke?
\v 26 Nʼihi na ndị na-eme ihe na-atọ ya ụtọ, ka Chineke na-enye amamihe na ihe ọmụma, na ọṅụ; ma ọ na-enye onye mmehie ọrụ ịkpakọta na ịchịkọba akụnụba nke ọ ga-enyefe nʼaka onye ahụ ihe ya dị Chineke mma. Nke a bụkwa ihe efu; ịchụso ifufe.
\c 3
\s1 Ihe niile nwere oge
\q1 
\v 1 Ihe ọbụla nwere oge;
\q2 mgbe dịkwara ihe ọbụla a na-eme eme nʼeluigwe.
\b
\q2 
\v 2 Oge ịmụ nwa na oge ịnwụ anwụ,
\q2 oge ịkụ ihe na oge ihopu,
\q2 
\v 3 oge igbu egbu; na oge ịgwọ ọrịa,
\q2 oge itikpọ na oge iwuzi ewuzi,
\q2 
\v 4 oge ịkwa akwa, na oge ịchị ọchị,\f + \fr 3:4 \ft \xt Rom 12:15\xt*\f*
\q2 oge iru ụjụ na oge ite egwu,
\q2 
\v 5 oge ikposa nkume na oge ịchịkọta nkume,
\q2 oge ịbakụ na oge ịkwụsị ịbakụ,
\q2 
\v 6 oge ịchọ ihe, na oge ntufu,
\q2 oge ịchịkọba, na oge ichifusi,
\q2 
\v 7 oge ndọwasị, na oge ndụkọta,
\q2 oge ịgba nkịtị, na oge ikwu okwu,\f + \fr 3:7 \ft \xt Ems 5:13; Ilu 25:11\xt*\f*
\q2 
\v 8 oge ịhụnanya na oge ịkpọ asị,
\q2 oge ibu agha, na oge ime udo.
\p 
\v 9 Gịnị bụ nnọọ ihe mmadụ na-enweta site na ndọgbu niile nke nʼọrụ niile ọ na-arụ?
\v 10 Ahụla m ibu arọ nke Chineke bokwasịrị ndị mmadụ e kere eke.
\v 11 O meela ka ihe niile maa mma nʼoge nke ya. O tinyekwala ebighị ebi nʼime obi ndị mmadụ; ma o nweghị ka mmadụ ghọta ọrụ Chineke site na mmalite ruo nʼọgwụgwụ.
\v 12 Nʼihi ya, ekpebiri m na ihe dịịrị mmadụ ịchọ bụ obi ụtọ na inwe aṅụrị na ndụ ya niile.
\v 13 Ihe ọzọ bụ ka mmadụ rie, ṅụọ, ma nwee afọ ojuju na ndọgbu niile ọ na-adọgbu onwe ya, nʼihi na ha bụ onyinye si nʼaka Chineke.
\v 14 Amaara m na ihe niile Chineke mere na-adịgidekwa. O nweghị ihe apụrụ itinye na ya, o nweghịkwa ihe apụrụ iwepụkwa site na ya. Chineke na-eme nke a ka ndị mmadụ tụọ egwu ya.
\q1 
\v 15 Ihe ọbụla dị ugbu a, adịlarị na mgbe ochie,
\q2 ihe ọbụla gaje ịdị dịlarị na mbụ.
\q2 Chineke na-eme ka ihe niile mere na mgbe gara aga megharịakwa ọzọ.
\p 
\v 16 Ọzọkwa, achọpụtara m otu ihe nʼokpuru anyanwụ,
\q1 na ọnọdụ ezi ikpe naanị mmebi iwu jupụtara,
\q2 nʼebe e kwesiri inwe ikpe ziri ezi ị ga-achọpụta na ihe ọjọọ dịkwa ya.
\p 
\v 17 A gwara m onwe m,
\q1 “Chineke ga-ekpe,
\q2 ndị ezi omume na ndị ajọ omume ikpe,
\q1 nʼihi na a ga-enwe oge maka ihe ọbụla a na-eme eme,
\q2 oge dịkwa maka ikpe ọrụ niile nke mmadụ ikpe.”
\p 
\v 18 Echere m nʼobi sị, “Ebe mmadụ nọ, Chineke na-anwale ya, ka mmadụ mata na ha dị ka anụmanụ.
\v 19 Nʼihi na ihe na-eche mmadụ na anụmanụ bụ otu. Ha abụọ na-eku ume, ha abụọ na-anwụkwa anwụ. Ọ dịghị ihe mmadụ ji karịa anụmanụ. Ihe niile bụ ihe efu.
\v 20 Ha niile na-alaghachi nʼotu ebe; ọ bụ nʼaja ka ha si pụta, ebe ahụ kwa ka ha ga-alaghachi.
\v 21 Onye pụrụ iguzo gbaa akaebe na mmụọ mmadụ na-ala nʼelu ma nke anụmanụ na-ala nʼaja?”
\p 
\v 22 Nʼihi ya, ahụrụ m na ọ dịghị ihe ọzọ ụmụ mmadụ kwesiri ime karịakwa inwe ọṅụ nʼọrụ ha, nʼihi na nke ahụ bụ oke ha nʼebe a. Onye ga-eme ka ha bịaghachi hụ ihe ga-eme nʼazụ ha?
\c 4
\s1 Mmegbu, ndọgbu nʼọrụ, na enweghị enyi
\p 
\v 1 Ọzọ, ahụrụ m mmegbu na obi ilu niile dị nʼokpuru anyanwụ,
\q1 anya mmiri akwa ndị a na-emegbu emegbu,
\q2 ma ọ dịkwaghị ndị nkasiobi ha nwere,
\q1 ma ike dị nʼaka ndị mmegbu a,
\q2 ma ha enwekwaghị ndị nkasiobi.
\q1 
\v 2 Nʼihi ya, ekwuru m, na ndị nwụrụ anwụ,
\q2 bụ ndị nwụrụ anwụ mgbe gara aga,
\q1 ka ndị dị ndụ mma,
\q2 bụ ndị nke dị ndụ ruo ugbu a.
\q1 
\v 3 Ma ọ dị mma karịa ha abụọ
\q2 bụ onye ahụ a na-amụbeghị,
\q1 onye na-ahụbeghị ihe ọjọọ
\q2 nke dị nʼokpuru anyanwụ.
\p 
\v 4 Achọpụtakwara m na ihe mere ndị mmadụ ji na-adọgbu onwe ha nʼọrụ bụ nʼihi anya ụfụ ha nwere nʼebe ihe ndị agbataobi ha dị. Nke a bụ ihe efu, ịchụso ifufe.
\q1 
\v 5 Onye nzuzu na-afanye aka abụọ nʼapata,
\q2 na-eri anụ ahụ onwe ya.\f + \fr 4:5 \ft \xt Ilu 24:30-31\xt*\f*
\q1 
\v 6 Ọ ka mma inwe ihe ntakịrị na obi udo,
\q2 karịa mmadụ inweju akụ site nʼịdọgbu onwe ya nʼọrụ,
\q2 nke bụ naanị ịchụso ifufe.
\p 
\v 7 Ọ dịkwa ihe ọzọ m hụrụ nʼokpuru anyanwụ bụ naanị ihe efu.
\q1 
\v 8 Ọ dị otu nwoke nke naanị ya nọ,
\q2 o nweghị nwa, o nwekwaghị ụmụnne.
\q1 Mgbe niile, ọ na-adọgbu onwe ya nʼọrụ,
\q2 ma nke a emeghị ka afọ ju ya nʼakụnụba o nwere.
\q1 Ọ jụrụ sị, “Ọ bụ nʼihi onye ka m ji adọgbu onwe m nʼọrụ,”
\q2 “nʼihi gịnị ka m ji anapụ onwe m ihe obi aṅụrị?”
\q1 Ihe nke a enweghị isi,
\q2 ihe efu na-eweta obi mgbawa ka ha bụ.
\b
\q1 
\v 9 Mmadụ abụọ ka mma karịa otu onye,
\q2 nʼihi na ha ga-arụpụta ọtụtụ ihe:
\q1 
\v 10 Otu onye nʼime ha daa,
\q2 onye nke ọzọ ga-apalite ya.
\q1 Ma mgbe ọ bụ naanị otu onye,
\q2 onye ga-apalite ya? Ọ nọ nʼime nsogbu.
\q1 
\v 11 Ọzọ, ọ bụrụ na mmadụ abụọ edinakọ, ahụ ga-ekpokwa ha ọkụ,
\q2 ma olee otu onye naanị ya dina ga-esi nweta okpomọkụ?
\q1 
\v 12 Ọ bụ ezie na e nwere ike merie onye naanị ya guzo,
\q2 ma mmadụ abụọ pụrụ iguzo zọọ onwe ha.
\q1 Ụdọ e ji eriri atọ tụkọta nʼotu, adịghị adọbi ya ngwangwa.
\s1 Ọganihu enweghị isi
\p 
\v 13 Ọ ka mma ịbụ nwantakịrị na onye ogbenye nwere nghọta karịa ịbụ agadi bụ eze ndị nzuzu, onye na-adịghị aṅa ntị na ndụmọdụ ọbụla.
\v 14 Nwata dị otu a, ma eleghị anya, ọ ga-esi nʼụlọ mkpọrọ pụta bụrụ eze, ma ọ bụkwanụ na a mụrụ ya ogbenye nʼalaeze ahụ.
\v 15 Ahụrụ m na mmadụ niile ndị bi nʼokpuru anyanwụ na-eso nwantakịrị ahụ onye nọchiri anya eze.
\v 16 A pụghị ịgụta ndị dịnyere ya, ma ndị ga-esota nʼazụ agaghị enwe ọṅụ nʼebe onye nọchiri eze ahụ nọ. Ọzọkwa, nke a bụ ihe efu, naanị ịchụso ifufe.
\c 5
\s1 Kwụghachi nkwa ị kwere Chineke
\p 
\v 1 Mgbe ị na-aba nʼụlọ ukwu Chineke, lezie anya. Meghee ntị gị nke ọma, karịa ịchụ aja onyinye nke ndị nzuzu, ndị na-amaghị na ha na-eme ihe ọjọọ.
\q1 
\v 2 Abụla onye na-eme ọsịịsọ ikwu okwu
\q2 maọbụ ime ngwangwa nʼime echiche obi gị,
\q2 maọbụ ikwe Chineke nkwa ọnụ efu.\f + \fr 5:2 \ft \xt Ilu 20:25\xt*\f*
\q1 Nʼihi na Chineke nọ nʼeluigwe
\q2 ma naanị nʼụwa ka ị nọ,
\q2 nʼihi ya ka okwu ọnụ gị dị ole na ole.
\q1 
\v 3 Dị ka ọtụtụ nchekasị si eweta ị rọọ nrọ,
\q2 otu a ka okwu onye nzuzu si dị mgbe ọtụtụ okwu dị ya nʼọnụ.
\p 
\v 4 Nʼihi ya, mgbe ị na-ekwe Chineke nkwa, atụfula oge imezu ihe ahụ, nʼihi na ihe banyere ndị nzuzu adịghị atọ Chineke ụtọ. Mezuo nkwa niile i kwere Chineke.
\v 5 Ọ ka mma na ị gbara nkịtị karịa na ị ga-ekwe nkwa ma ị gaghị emezu ya.
\v 6 Ekwela ka ọnụ gị duba gị na mmehie. Azọkwala onwe gị site nʼịgwa onyeozi Chineke, “na i kwere nkwa a na-amaghị ama.” Nʼihi gịnị ka Chineke ga-eji wee iwe nʼihi ihe ị kwuru, ma bibiekwa ọrụ aka gị?
\v 7 Aga m eme, aga m eme, ma e meghị ya bụ naanị okwu efu. Ya mere, tụọ egwu Chineke.
\s1 Akụnụba enweghị isi
\p 
\v 8 Ọ bụrụ na ị hụ ebe a na-emegbu ndị ogbenye, na-anapụkwa ha ihe ruru ha site nʼikpe ikpe na-ezighị ezi na mpaghara obodo a na-achị achị, ya ejula gị anya, nʼihi na onyeisi ọbụla nwere onye na-atụrụ ya. Ndịisi na-atụ iwu nwekwara ndị kachasị ha elu. Otu a kwa, ọ dịkwa ndị dị elu karịa ha.
\v 9 Mgbe ihe nnweta si nʼala ubi bara ụba, ọ na-abara onye ọbụla uru; ọ na-abakwara eze nʼonwe ya uru.
\q1 
\v 10 Onye ọbụla hụrụ ego nʼanya, ọ gaghị eju ya afọ.
\q2 Onye ọbụla hụrụ akụnụba nʼanya adịghị enwe afọ ojuju nʼihe ọbụla.
\q2 Nke a bụkwa ihe efu.
\b
\q1 
\v 11 Akụ na-abawanye,
\q2 ndị na-eri ya na-abawanyekwa.
\q1 Olee uru ha bara nye onyenwe ha
\q2 karịa iji anya ya abụọ na-ele ha?
\b
\q1 
\v 12 Onye na-arụsị ọrụ ike na-arahụ ụra nke ọma,
\q2 ma o riri nri nta ma o rikwaranụ nke dị ukwuu,
\q1 ma oke iriju afọ onye ọgaranya
\q2 anaghị ekwe ya rahụ ụra.
\p 
\v 13 Ahụrụ m ihe ọjọọ ọzọ nʼokpuru anyanwụ,
\q1 mmadụ debere akụnụba ruo mgbe o wetara ya ihe mgbu,
\q2 
\v 14 ma akụnụba ndị ahụ bụ ihe furu site nʼọdachi
\q1 nke bụ na mgbe ha mụtara ụmụ,
\q2 o nwekwaghị ihe fọdụrụ ụmụ ahụ iketa.
\q1 
\v 15 Dịka mmadụ si gbara ọtọ site nʼafọ nne ya bata nʼụwa,
\q2 otu a ka anyị ga-esi hapụ ya.
\q1 O nweghị ihe ọ ga-ebu pụọ site na ndọgbu niile
\q2 ọ dọgburu onwe ya nʼọrụ.
\p 
\v 16 Ma nke a bụ ihe ọjọọ nke na-egbu mgbu nʼobi.
\q1 Mmadụ na-ala dịka o siri bịa.
\q2 Gịnị bụ uru ya,
\q2 mgbe ọ na-adọgbu onwe ya nʼọrụ nye ifufe?
\q1 
\v 17 Ụbọchị ndụ ya niile, ọ na-eri ihe nʼọchịchịrị,
\q2 site oke mgbagwoju anya, na nsogbu na iwe.
\p 
\v 18 Ma achọpụtara m na ọ bụ ihe dị mma na ihe kwesiri omume, ka nwoke rie ihe ma ṅụọkwa ihe ọṅụṅụ Ka ọ chọtakwa afọ ojuju nʼime ndọgbu niile nke ọrụ ọ ruru nʼokpuru anyanwụ, nʼoge mkpụmkpụ ndụ nke Chineke nyere ya. Nʼihi na nke a bụ oke ya.
\v 19 Ọzọkwa, ọ bụrụ na Chineke enye mmadụ akụnụba na ihe nweta, ma nyekwa ya ike ọ ga-eji kporie ndụ nʼime ihe ndị a, ya nabata nke a dị ka oke ya ma were ọṅụ rụọ ọrụ ya. Ha bụ onyinye si nʼaka Chineke.
\v 20 Ebe ọ bụ na Chineke enyela ya obi ụtọ, ụbọchị ndụ ya ekwesighị iwetara ya oke echiche.
\c 6
\p 
\v 1 Ọ dị ihe ọjọọ ọzọ nke m hụrụ nʼokpuru anyanwụ, nke na-anyịdo ụmụ mmadụ.
\v 2 Chineke na-enye mmadụ akụnụba, na ihe nnweta, na nsọpụrụ, na-emekwa ka ha nwee ihe niile ha chọrọ, ma ọ dịghị enye ha ike ịnụ ụtọ ha; ma onye ọzọ na-anụ ụtọ ha. Nke a bụ ihe efu, bụrụkwa ihe jọgburu onwe ya.
\p 
\v 3 Mmadụ nwere ike mụta narị ụmụ, o nwekwara ike nwee ndụ ogologo ruo agadi, ma ọ bụrụ na o nweghị ike ịnụ ụtọ akụnụba ya, ọ bụrụkwa na o nwetaghị ụdị olili ruru ya, ana m asị, na nwa nwụrụ nʼafọ\f + \fr 6:3 \ft Maọbụ, \fqa a mụkworo amụkwo\f* dị mma karịa ya.
\v 4 Ọbịbịa ya e nweghị isi, nʼọchịchịrị ka ọ na-ala, ọ bụkwa ọchịchịrị ka e kpuchiri aha ya.
\v 5 Ọ bụ ezie na ọ gaghị ahụ ihe anwụ anya, ọ makwaghị ihe ọbụla, o nwere izuike karịa nwoke ahụ.
\v 6 A sịkwarị na o biri ndụ puku afọ, okpukpu abụọ, ma ọ nụghị ụtọ akụnụba ya. Ọ bụghị nʼotu ebe ka ha niile na-ala?
\q1 
\v 7 Ndọgbu niile mmadụ na-adọgbu onwe ya nʼọrụ bụ ka o rijuo afọ,\f + \fr 6:7 \ft \xt Ilu 16:26\xt*\f*
\q2 ma o nweghị onye na-enweta ihe na-ezuru ya.
\q1 
\v 8 Olee ụzọ onye maara ihe si dị mma karịa onye nzuzu?
\q1 Gịnị bụ uru dịịrị onye ogbenye
\q2 na ọ maara otu e si akpa ezi agwa nʼihu ndị dị ndụ?\f + \fr 6:8 \ft Maọbụ, \fqa nʼebe ndị ọzọ nọ\f*
\q1 
\v 9 Ihe eji anya hụ
\q2 ka mma karịa oke ọchịchọ!
\q1 Nke a bụkwa ihe efu
\q2 na ịchụso ifufe.
\b
\q1 
\v 10 Ihe ọbụla dị ugbu a, ka akpọrọ aha na mgbe gara aga.
\q2 Amakwaara ihe mmadụ bụ,
\q1 mmadụ ọbụla apụghị ịlụso
\q2 onye ka ya ike ọgụ.
\q1 
\v 11 Okwu na-aba ụba,
\q2 nghọta na-adị nta.
\q2 O nwere uru nke a bara?
\p 
\v 12 Onye mara ihe dịrị mmadụ mma na ndụ, nʼụbọchị ole na ole nke na-abaghị uru o nwere ịgabiga ndụ a dịka onyinyo? Onye pụrụ ịgwa ya ihe ga-eme nʼokpuru anyanwụ, mgbe ọ nwụsịrị?
\c 7
\s1 Amamihe
\q1 
\v 1 Ezi aha\f + \fr 7:1 \ft \xt Ilu 22:1\xt*\f* ka mma karịa mmanụ isi ụtọ.\f + \fr 7:1 \ft Maọbụ, \fqa mmanụ oke ọnụahịa\f*
\q2 Ụbọchị mmadụ nwụrụ ka ụbọchị a mụrụ ya mma.
\q1 
\v 2 Ọ kaara gị mma ije nʼebe a na-eru ụjụ
\q2 karịa ebe a na-eri na-aṅụ.
\q1 Nʼihi na ọnwụ dịịrị mmadụ ọbụla;
\q2 ndị dị ndụ kwesiri iburu nke a nʼobi.
\q1 
\v 3 Iru ụjụ ka ịchị ọchị mma,
\q2 ihu gbarụrụ agbarụ na-enyere obi aka
\q1 
\v 4 Onye maara ihe na-eche echiche banyere ọnwụ,
\q2 ma onye nzuzu na-eche naanị banyere ikpori ndụ.
\q1 
\v 5 Ọ ka mma ige ntị nye mba onye maara ihe
\q2 karịa ịṅa ntị nʼabụ ndị na-enweghị uche na-abụ.
\q1 
\v 6 Ọchị onye nzuzu
\q2 dị ka mkpọtụ nke ogwu na-ere ọkụ na-eme nʼokpuru ite.\f + \fr 7:6 \ft Mgbe ogwu na-ere ọkụ, na-eme mkpọtụ, na-asụkwa anwụrụ, nke a adịghị eme ka ahụ ndị na anya ọkụ ya nʼoge oyi kporo ọkụ.\f*
\q2 Ihe a bụkwa ihe efu.
\b
\q1 
\v 7 Iji anya ike nara mmadụ ihe na-eme ka onye mara ihe ghọọ onye nzuzu,
\q2 iri ngarị na-emerụ obi mmadụ.
\b
\q1 
\v 8 Ọgwụgwụ ihe ọbụla dị mma karịa mmalite ya!
\q2 Ogologo ntachiobi dị mma karịa mpako!
\q1 
\v 9 Abụla onye na-ewe iwe ọsịịsọ,
\q2 nʼihi na iwe bụ oke ndị nzuzu.
\b
\q1 
\v 10 Asịla, “Gịnị mere ụbọchị gara aga ji dị mma karịa ụbọchị ndị a?”
\q2 Nʼihi na ọ bụghị amamihe ị jụ ajụjụ dị otu a.
\b
\q1 
\v 11 Amamihe dịka ihe nketa, bụ ihe dị mma.
\q2 Ọ na-abara uru nye ndị na-ahụ anyanwụ anya.
\q1 
\v 12 Amamihe bụ ndo
\q2 dịka ego si bụrụkwa ndo,
\q1 ma ụzọ ihe ọmụma ji dị mma karịa bụ nke a:
\q2 Amamihe na-echebe ndụ ndị nwere ya.
\p 
\v 13 Chee echiche banyere ihe Chineke na-eme.
\q1 Mmadụ ọ pụrụ ime ka ọ dịzie adịzie,
\q2 bụ ihe Chineke mere ka ọ gbagọọ agbagọ?
\q1 
\v 14 Mgbe ihe na-agara gị nke ọma, ṅụrịa ọṅụ, nʼihi ọ dịrị gị mma,
\q2 ma mgbe mmekpa ahụ batara, mata nke ọma
\q1 na Chineke onye na-enye ọnọdụ ọma
\q2 makwa ihe banyere ọnọdụ ọjọọ.
\q1 Ya mere, o nweghị onye ọbụla nwere ike ịchọpụta
\q2 ọdịnihu ya.
\p 
\v 15 Ndụ m nʼụwa a bụ ihe efu, ahụla m ihe abụọ ndị a;
\q1 onye ezi omume na-anwụ nʼezi omume ya,
\q2 ma onye na-emebi iwu na-ebi ogologo ndụ na mmebi iwu ya.
\q1 
\v 16 Nʼihi ya, abụbigala onye ezi omume oke,
\q2 emekwala onwe gị onye mabigara ihe oke.
\q2 Gịnị mere i ji achọ igbu onwe gị?
\q1 
\v 17 Abụbigala onye na-emefe ajọ omume oke,
\q2 abụkwala onye nzuzu!
\q2 Gịnị ka ị ga-eji nwụọ mgbe oge gị na-erubeghị?
\q1 
\v 18 Ọ dị mma ijide otu
\q2 na-esepụghị aka na nke ọzọ,
\q2 onye na-atụ egwu Chineke ga-enweta uru nʼime ha abụọ.
\b
\q1 
\v 19 Amamihe na-eme ka otu onye dị ike
\q2 karịa mmadụ iri na-achị otu obodo.
\b
\q1 
\v 20 Gbaa ụwa niile gburugburu, ọ dịghị otu onye bụ onye ezi omume,
\q2 ọ dịghị onye na-eme ihe ziri ezi nke na-adịghị eme mmehie mgbe ọbụla.
\b
\q1 
\v 21 Egela ntị nʼihe niile ndị mmadụ na-ekwu,
\q2 ị pụrụ ịnụ nkọcha nke ohu gị na-akọcha gị.
\q1 
\v 22 Gị onwe gị maara
\q2 na ọtụtụ oge, ị na-akọchakwa ndị ọzọ.
\p 
\v 23 Agbalịsiela m ike inwe nghọta. Ekwuru m sị,
\q1 “Aga m abụ onye amamihe,”
\q2 ma nke a karịrị m.
\q1 
\v 24 Amamihe adịghị mfe inweta, ọ dị omimi nke ukwuu;
\q2 ọ bụ onye pụrụ ịchọpụta ya?
\q1 
\v 25 A tụgharịrị uche m ka m ghọta,
\q2 iledo na ịchọpụta amamihe na atụmatụ otu ihe niile si dị
\q1 na ịghọtakwa nzuzu nke dị na ajọ omume
\q2 na ịyị ara nke dị na enweghị uche.
\b
\q1 
\v 26 Achọpụtara m na ọ dị ihe dị ilu karịa ọnwụ,
\q2 ihe ahụ bụ nwanyị.
\q1 Obi ya dị ka ụgbụ.
\q2 Otu a kwa, aka o ji ejikụ gị dị ka ụdọ igwe.
\q1 Onye ahụ na-eme ihe na-atọ Chineke ụtọ na-esi nʼaka ya gbapụ,
\q2 ma ndị mmehie ka ọ na-enwude nʼọnya ya.
\p 
\v 27 “Lee, Ihe a ka m chọpụtara,” ka onye nkuzi kwuru:
\q1 “Site nʼịtụkwasị otu ihe nʼelu ibe ya ka m matara isi ihe niile.
\q2 
\v 28 Mgbe m ka na-achọ
\q2 ma achọtaghị m,
\q1 nʼetiti puku mmadụ ndị ikom, achọtara m otu onye aka ya dị ọcha,
\q2 ma ọ dịghị otu nwanyị m chọtara nʼetiti ha.
\q1 
\v 29 Achọpụtara m naanị nke a,
\q2 Chineke mere ndị mmadụ ka ha bụrụ ndị ụzọ ha ziri ezi,
\q2 ma ha atụgharịala chọrọ ọtụtụ ihe nchepụta gawa.”
\b
\c 8
\q1 
\v 1 Onye dị ka onye amamihe?
\q2 Onye maara nkọwa ihe?
\q1 Amamihe na-enyekwa ihu ya ihe,
\q2 na-emekwa ka mgbarụ nke ihu ya gbanwee.
\s1 Rubere eze isi
\p 
\v 2 Asị m, debe iwu eze, nʼihi iyi ị ṅụrụ nʼihu Chineke.\f + \fr 8:2 \ft Ọtụtụ oge, ndị ọchịchị na ndịisi obodo na-aṅụ iyi nʼihu ndị ọkaikpe, ndị ụkọchukwu nakwa ọha obodo, na ha ga-abụ ndị kwesiri ntụkwasị obi nʼije ozi ha. Ọ bụ ya ka a na-ekwu nʼebe.\f*
\v 3 Emela ngwangwa isi nʼihu eze pụọ. Akwagidela ihe ọjọọ nʼihi na ọ ga-eme ihe masịrị ya.
\v 4 Nʼihi na okwu eze nwere ike ọ dịghị onye pụrụ ịjụ ya, Gịnị ka ị na-eme?
\q1 
\v 5 Onye na-edebe iwu eze agaghị adaba na nsogbu.
\q2 Onye maara ihe na-ama mgbe kwesiri na ụzọ kwesiri ime ihe.
\q1 
\v 6 Ihe niile nwere oge kwesiri ya, ụzọ e si eme ha dịkwa,
\q2 ọ bụ ezie na nsogbu mmadụ dị ukwuu nʼahụ ya.
\b
\q1 
\v 7 Ebe ọ bụ na o nweghị onye mara ihe na-aga ime,
\q2 onye pụrụ ịgwa ibe ya ihe gaje ime?
\q1 
\v 8 Ọ dịghị onye nwere ike igbochi mmụọ mmadụ\f + \fr 8:8 \ft Maọbụ, \fqa ifufe\f* mgbe ọ chọrọ.
\q2 Ọ dịghị onye nwere ike igbochi ụbọchị ọnwụ ya.
\q1 Dịka o si sie ike izighachi mmadụ azụ nʼoge agha,
\q2 otu a ka o si sie ike ajọ omume ịtọghapụ ndị na-eme ihe ọjọọ.
\p 
\v 9 Ihe ndị a niile ka m hụrụ, mgbe m na-atụgharị uche banyere ihe niile a na-eme nʼokpuru anyanwụ. Mgbe ụfọdụ, mmadụ na-emegide ibe ya si otu a wetara onwe ya nsogbu.
\v 10 Ọzọkwa, ahụrụ m ebe e liri ndị ajọ omume, ndị na-abata na apụkwa site nʼebe dị nsọ, a na-etokwa ha nʼobodo ebe ha mere ihe ndị a. Nke a bụkwa nnọọ ihe na-enweghị isi; ihe efu.
\p 
\v 11 Nʼihi na e nyeghị ntaramahụhụ mmehie mgbe o kwesiri, obi ndị mmadụ na-ejupụta nʼatụmatụ ime mmehie.
\v 12 Onye ajọ omume nwere ike mee narị mmehie bikwaa ogologo ndụ, ma amara m na ọ ga-adịrị ndị na-atụ egwu Chineke mma karịa, bụ ndị na-atụ egwu nʼihu Chineke.
\v 13 Nʼihi na ndị ajọ omume adịghị atụ egwu Chineke, ọ gaghị adịrị ha na mma, ụbọchị ndụ ha agaghị agbatịkwa ogologo dịka onyinyo.
\p 
\v 14 Ọ dị ihe ọzọ na-enweghị isi nʼụwa: ndị ezi omume na-anata ntaramahụhụ dịrị ndị na-emebi iwu. Ndị na-emebi iwu na-anata ụgwọ ọrụ ruru ndị ezi omume. Nʼezie, ihe ndị a niile bụ ihe efu, ha enweghị isi.
\v 15 Ya mere, ana m ekwupụta, na ikpori ezi ndụ dị mma, nʼihi na ọ dịghị ihe ka mma nye mmadụ nʼokpuru anyanwụ, karịa iri, na ịṅụ, na inwe obi ụtọ. Mgbe ahụ ọ ga-enwe obi ụtọ nʼọrụ ọ na-arụ nʼụbọchị niile nke Chineke nyere ya nʼokpuru anyanwụ.
\p 
\v 16 Mgbe m wepụtara obi m ịchọ amamihe na ịghọta ọrụ mmadụ nʼokpuru anyanwụ nke mere na ọ naghị ehi ụra ehihie na abalị,
\v 17 mgbe ahụ ka m chọpụtara ihe Chineke mere. O nweghị onye pụrụ ịghọta ihe na-aga nʼokpuru anyanwụ. Otu ọbụla mmadụ siri gbalịa o nweghị ike ịchọpụta ihe ọ pụtara. Onye maara ihe pụrụ ị sị na a amatala ya, ma nʼezie ọ maghị ya.
\c 9
\s1 Ihe na-eche mmadụ niile
\p 
\v 1 Ihe ndị a niile ka m tulere nke ọma nʼobi m, kpebie na ihe ndị ezi omume na ndị maara ihe na-eme dị nʼaka Chineke, ma ọ dịghị onye maara ihe na-echere ha maọbụ ịhụnanya maọbụ ịkpọ asị.
\v 2 Ihe niile na-adakwasị mmadụ niile nʼotu ụzọ ahụ, ma onye ezi omume ma onye ajọ omume, ezi mmadụ na onye na-abụghị ezi mmadụ, onye dị ọcha na onye na-adịghị ọcha, onye na-achụ aja na onye na-adịghị achụ aja.
\q1 Dịka ọ dịrị ezi mmadụ,
\q2 otu a ka ọ dịrị onye mmehie;
\q1 dịka ọ dịrị ndị na-aṅụ iyi,
\q2 otu a kwa ka ọ dị nye ndị na-adịghị aṅụ.
\p 
\v 3 Nke a bụkwa ihe ọjọọ na-eme nʼokpuru anyanwụ. Otu ihe ndakwasị dịrị mmadụ niile. Ọzọkwa, obi ụmụ mmadụ jupụtara nʼihe ọjọọ na ịyị ara mgbe ha nọ na ndụ, emesịa ha alakwuru ndị nwụrụ anwụ.
\v 4 Naanị ndị dị ndụ nwere olileanya. Ọ ka mma ịbụ nkịta dị ndụ karịa ịbụ ọdụm nwụrụ anwụ.
\q1 
\v 5 Nʼihi na ndị dị ndụ maara nke ọma na ha ga-anwụ,
\q2 ma ndị nwụrụ anwụ amaghị ihe ọbụla;
\q1 ha enwekwaghị ụgwọ ọrụ ọzọ,
\q2 nʼihi na ha bụ ndị echefurula echefu.
\q1 
\v 6 Ịhụnanya ha, na ịkpọ asị ha,
\q2 na ekworo ha gabigara mgbe ha nwụrụ.
\q1 Ha agaghị enwekwa oke
\q2 nʼihe ọbụla na-eme nʼokpuru anyanwụ.
\p 
\v 7 Ya mere, gaa nʼihu, jiri ọṅụ rie nri gị, jirikwa ọṅụ ṅụọ ihe ọṅụṅụ nʼihi na ọ bụ ugbu a ka Chineke nabatara ọrụ gị.
\v 8 Yiri akwa dị ọcha mgbe niile, tee mmanụ na-esi isi ụtọ nʼisi gị.\f + \fr 9:8 \ft Ihe e ji maara ndị Juu nʼoge mmemme, maọbụ ụbọchị izuike, bụ iyi akwa ọcha na itekwasị mmanụ nʼisi ha.\f*
\v 9 Bie ndụ obi ụtọ, gị na nwunye gị ị hụrụ nʼanya, ụbọchị niile nke ndụ ihe efu gị nke Chineke nyere gị nʼokpuru anyanwụ, nʼihi na nke a bụ oke dịịrị gị na ndụ ndọgbu onwe gị nʼọrụ nʼokpuru anyanwụ.
\v 10 Ihe ọbụla ị na-eme, were ike gị niile mee ya, nʼihi na ịrụ ọrụ maọbụ iche echiche, maọbụ ihe ọmụma, maọbụ amamihe adịghị nʼala ndị nwụrụ anwụ. Ebe ahụ kwa ka ị na-aga.
\p 
\v 11 Ahụrụ ihe ọzọ nʼokpuru anyanwụ,
\q1 ọ bụghị ndị nwere ụkwụ ọsọ na-agbata ihe,
\q2 ọ bụkwaghị onye sikarịrị ike na-emeri nʼagha;
\q1 ọ bụghị ndị maara ihe ka nri dịrị,
\q2 ọ bụghị ndị nwere nghọta ka akụnụba dịrị,
\q2 ọzọkwa, ọ bụghị ndị nka ka amara na-adịrị;
\q1 kama ọ bụ mgbe na ihe ndaba na-eme ka ihe ndị a dịrị.
\p 
\v 12 Nke ka nke, ọ dịghị mmadụ ọbụla maara mgbe oge ya ga-eru:
\q1 Ọ dị ka nnụnụ nke mara nʼọnya,
\q2 maọbụ azụ e jidere nʼụgbụ.
\q1 Dịka ha, ụmụ mmadụ na-adaba nʼọnya nke ihe ọjọọ
\q2 mgbe ha na-atụghị anya ya.
\s1 Amamihe dị mkpa karịa nzuzu
\p 
\v 13 Ahụkwara m ihe ọzọ nʼokpuru anyanwụ, nke a bụ ụdị amamihe nke metụrụ m nʼobi nʼebe ọ dị ukwuu.
\v 14 Ọ dị obodo nke naanị mmadụ ole na ole bi nʼime ya, ma otu eze dị ike chịịrị ndị agha ya bịa ibuso obodo nta a agha. Ndị agha ya gbara obodo a gburugburu na-achọ ịkwatu mgbidi ya.
\v 15 Ma ọ dị otu onye ogbenye bi nʼobodo nta ahụ, onye maara ihe, ọ zọpụtara obodo ahụ site nʼamamihe ya. Ma o nweghị onye chetara ihe banyere ya.
\v 16 Nke a mere m ji sị, inwe amamihe bara uru karịa ịdị ike, ma ọ bụrụ na onye amamihe ahụ bụ onye ogbenye, a ga-eleda ya anya, a gaghị akpọkwa okwu ya ihe.
\q1 
\v 17 Okwu nke onye maara ihe na-ekwu na nwayọọ ka a na-anụ,
\q2 karịa iti mkpu nke onye na-achị achị nʼetiti ndị nzuzu.
\q1 
\v 18 Amamihe ka ihe agha niile mma,
\q2 ma otu onye mmehie na-ala ọtụtụ ezi ihe nʼiyi.
\b
\c 10
\q1 
\v 1 Ijiji nwụrụ anwụ ga-eme ka mmanụ isi ụtọ sie isi ọjọọ.
\q2 Otu a kwa, nzuzu nta pụrụ ime ka amamihe dị ukwuu ghara inwe nsọpụrụ.
\q1 
\v 2 Obi onye maara ihe na-eme ka o mee ihe ziri ezi,
\q2 ma obi onye nzuzu na-eduba ya na mmehie.
\q1 
\v 3 Ị ga-ama onye nzuzu site nʼije ụkwụ ya,
\q2 nʼihi na o maghị ihe.
\q2 Ọ bụladị onye ọbụla na-achọpụta onye nzuzu\f + \fr 10:3 \ft \xt Ilu 13:16; Ilu 18:2\xt*\f* ọsịịsọ.
\q1 
\v 4 Ọ bụrụ na iwe onye ọchịchị ebilie megide gị,
\q2 ahapụla ọnọdụ gị,
\q2 nʼihi na mmụọ dị nwayọọ ga-eme ka mmehie ukwu dị iche iche dajụọ.
\b
\q1 
\v 5 Ọ dịkwa ihe ọjọọ ọzọ m hụrụ nʼokpuru anyanwụ,
\q2 dịka njehie nke ndị eze na ndị na-achị achị na-ejehie.
\q1 
\v 6 Ahụrụ m ka ndị nzuzu na-enweta ọkwa dị elu,
\q2 ma ndị ọgaranya adịghị enweta ọnọdụ ruuru ha.
\q1 
\v 7 Ahụla m ka ohu na-agba ịnyịnya,
\q2 ma ụmụ eze ji ụkwụ na-aga dịka ụmụ ohu.
\b
\q1 
\v 8 Onye gwuru olulu ga-adaba nʼime ya!
\q2 Onye na-etida mgbidi ka agwọ ga-atagbu.
\q1 
\v 9 Onye na-arụ ọrụ nʼebe a na-awa nkume ka nkume ga-adakwasị.
\q2 Onye na-awa nkụ nọ nʼize ndụ site na ha.
\b
\q1 
\v 10 Ọ bụrụ na anyụike adịghị nkọ,
\q2 ọ bụrụkwa na-amụghị ihu ya amụ,
\q1 a ga-etinye ike karịa,
\q2 ma ịma eme ihe na-eme ka ihe gazie agazi.
\b
\q1 
\v 11 Ọ bụrụ na agwọ ataa mmadụ tupu e kechie ya ọnụ,
\q2 ọ dịkwaghị uru ọ bara na e kechiri ya ọnụ.
\b
\q1 
\v 12 Okwu onye maara ihe na-ejupụta nʼamara,
\q2 ma okwu onye nzuzu na-eduba ya nʼịla nʼiyi
\q1 
\v 13 Nʼihi na mmalite okwu ya bụ nzuzu,
\q2 ọgwụgwụ okwu ya bụkwa naanị mmebi iwu na ịyị ara.
\q2 
\v 14 Onye nzuzu na-ekwu ọtụtụ okwu.
\b
\q1 Ma o nweghị onye ma ihe na-aga ime,
\q2 onye pụrụ ịgwa ya ihe gaje ime mgbe ọ nwụrụ?
\b
\q1 
\v 15 Ọrụ nke ndị nzuzu na-agwụ ya ike,
\q2 ha makwaghị ụzọ ijeru obodo.
\b
\q1 
\v 16 Ahụhụ ga-adịrị ala nke eze ya bụ nwantakịrị,
\q2 nke ndị na-achị achị bụ ndị na-akpọ oriri nʼụtụtụ.
\q1 
\v 17 Ngọzị na-adịrị ala ahụ nke eze ya bụ onye a na-asọpụrụ,
\q2 nke ụmụ eze ya na-eri ihe mgbe o kwesiri nʼihi inweta ike,
\q2 ọ bụghị maka ịṅụbiga mmanya oke.
\b
\q1 
\v 18 Ọ bụ umengwụ na-eme ka ụlọ hie mmiri;
\q2 ọ bụkwa umengwụ na-eme ka elu ụlọ malite ize eze.
\b
\q1 
\v 19 Ịkpọ oriri na-eweta ọnụ ọchị,
\q2 mmanya na-enye obi ụtọ,
\q2 ma ego bụ ọsịsa nye ihe niile.
\b
\q1 
\v 20 Akọchala eze, ọ bụladị nʼechiche obi gị\f + \fr 10:20 \ft \xt Ọpụ 22:28; Ọrụ 23:5\xt*\f*;
\q2 maọbụ bụọ ọgaranya ọnụ nʼime ụlọ ndina gị,
\q1 nʼihi na anụ ufe nọ nʼelu nwere ike buru okwu gị
\q2 nwa nnụnụ nwere nku ga-akọ ihe i kwuru.
\c 11
\s1 Ịgbasapụ aka
\q1 
\v 1 Gbasapụ aka gị nʼinye onyinye
\q2 nʼihi na mgbe ọtụtụ ụbọchị gasịrị ị ga-anata ụgwọ ọrụ gị.
\q1 
\v 2 Kee akụ gị ụzọ asaa maọbụ ụzọ asatọ
\q2 nʼihi na ị maghị ụdị ihe ndaba ọjọọ nwere ike ịbịakwasị gị nʼobodo.
\b
\q1 
\v 3 Mgbe eluigwe rujiri,
\q2 mmiri ga-ezo;
\q1 mgbe osisi dara, maọbụ nʼugwu maọbụ na ndịda,
\q2 ebe ahụ ka ọ na-atọgbọ.
\q1 
\v 4 Onye na-ele ikuku anya agaghị akụ mkpụrụ ọbụla,
\q2 onye na-ele igwe ojii anya agaghị ewe ihe ubi.
\b
\q1 
\v 5 Dịka mmadụ na-apụghị ịmata ụzọ ikuku si aga
\q2 maọbụ otu ndụ ọhụrụ si ebido nʼime afọ nwanyị dị ime,
\q1 otu a ka o si dịrị ma mmadụ apụghị ịghọta ọrụ Chineke,
\q2 onye mere ihe niile.
\b
\q1 
\v 6 Ghaa mkpụrụ gị nʼụtụtụ,
\q2 esepụkwala aka nʼanyasị,
\q1 nʼihi na ị maghị nke ga-eto,
\q2 maọbụ nke a maọbụ nke ọzọ,
\q2 ha niile nwere ike too nke ọma.
\s1 Cheta Chineke nʼokorobịa gị
\q1 
\v 7 Ìhè dị ụtọ,
\q2 ọ na-amasịkwa anya ịhụ ìhè anyanwụ.
\q1 
\v 8 Ọ bụrụ na mmadụ adị ndụ ọtụtụ afọ,
\q2 ya ṅụrịa nʼime ihe niile,
\q1 ma ya cheta ụbọchị ọchịchịrị
\q2 ga-adị ọtụtụ.
\q2 Ihe niile ndị na-abịa bụ ihe efu.
\b
\q1 
\v 9 Nwa okorobịa, ọ bụ ihe oke ọṅụ na ị bụ okorobịa.
\q2 Ya mere, ka obi gị nye gị ọṅụ nʼụbọchị niile nke okorobịa gị.\f + \fr 11:9 \ft \xt Akw 3:27\xt*\f*
\q1 Mee ihe niile ị chọrọ ime;
\q2 gbasookwa ihe niile nke anya gị na-ahụ.
\q1 Kama, ghọtakwa nke a,
\q2 na ị ghaghị ịza ajụjụ nʼihu Chineke nʼihi ihe niile i mere.
\q1 
\v 10 Ya mere, wezuga nchegbu site nʼobi,\f + \fr 11:10 \ft \xt 2Tm 2:22.\xt*\f*
\q2 wezugakwa nsogbu nke ahụ gị,
\q2 nʼihi na okorobịa na ịdị ike bụ ihe efu.
\b
\c 12
\q1 
\v 1 Ya mere, cheta Onye kere gị
\q2 mgbe ị ka bụ okorobịa,
\q1 tupu ụbọchị ọjọọ ndị ahụ abịa,
\q2 na mgbe afọ aka abịarubeghị
\q2 mgbe ị ga-asị, “Ha anaghị atọkwa m ụtọ.”
\q1 
\v 2 Tupu anyanwụ na ìhè,
\q2 ọnwa na kpakpando ga-agba ọchịchịrị,
\q2 na nlọghachi igwe ojii mgbe mmiri zosiri.
\q1 
\v 3 Mgbe ndị na-echebe ụlọ ga-ama jijiji,
\q2 mgbe ndị dimkpa nwoke ga-ehulata,
\q1 mgbe ndị na-akwọ ihe kwụsịrị maka ha dị ole na ole,
\q2 mgbe ndị na-elepụ anya site nʼoghere ga-ebido ịgba ọchịchịrị,
\q1 
\v 4 mgbe e mechiri ọnụ ụzọ nke pụrụ nʼokporoụzọ,
\q2 mgbe olu ịkwọ nri ga-adị ala,
\q1 mgbe ụda olu abụ ụmụ nnụnụ ga-akpọte ndị mmadụ,
\q2 ma abụ ha niile na-ala ala,
\q1 
\v 5 mgbe ndị mmadụ ga-atụ egwu ebe dị elu;
\q2 na ihe egwu nke okporoụzọ,
\q1 mgbe osisi alụmọnd ga-ama ifuru
\q2 mgbe ụkpana ga na-adọkpụ onwe ya nʼụzọ,
\q2 agụụ ihe ọbụla ga-akwụsịkwa.
\q1 Mgbe ahụ, ndị mmadụ ga-ala ụlọ ebighị ebi ya,
\q2 ndị na-akwa akwa ga na-agagharị nʼokporoụzọ niile.
\b
\q1 
\v 6 E, cheta ya, tupu e gbubie ụdọ ọlaọcha ahụ,
\q2 tupu e tiwaa ọkwa ọlaedo,
\q1 tupu ite adawaa nʼisi iyi,
\q2 tupu e tijie ụkwụ igwe olulu mmiri.
\q1 
\v 7 Mgbe ahụ, anụ ahụ anyị ga-alaghachi nʼaja ebe o si pụta;\f + \fr 12:7 \ft \xt Jen 3:19; Job 34:15; Abụ 90:3\xt*\f*
\q2 mmụọ\f + \fr 12:7 \ft \xt Ekl 3:21\xt*\f* anyị ga-alaghachikwuru Chineke onye nyere ya.
\b
\q1 
\v 8 “Ihe efu! Ihe efu!” ka onye ozizi kwuru.
\q2 “Ihe niile bụ ihe efu!”
\s1 Nchịkọta okwu niile
\p 
\v 9 Ọ bụghị naanị nʼonye ozizi ahụ bụ onye maara ihe, o jegharịrị na-ezi ndị mmadụ ihe ọ maara. Ọ tụgharịrị uche chọpụta ọtụtụ ilu, detuokwa ha nʼusoro.
\v 10 Onye ozizi chọpụtara okwu ndị dabanyere nʼusoro, ihe o depụtara bụ ihe ziri ezi na eziokwu.
\p 
\v 11 Okwu ọnụ nke onye maara ihe dị ka ndụdụ e ji achụ ehi. Nchịkọta okwu amamihe ndị a dị ka ǹtu a kumiri nke ọma, nke onye na-azụ atụrụ nyere.
\v 12 Ma nwa m nwoke lezie anya, atụkwasịla ihe ọzọ nʼelu ihe ndị a.
\p Akwụkwọ a na-ede ede enweghị ọgwụgwụ, ọtụtụ mmụta na-agwụ ike.
\q1 
\v 13 Ugbu a anụla ihe ndị a niile,
\q2 ma nụrụ ihe bụ nkwubi okwu:
\q1 Tụọ egwu Chineke, debekwa iwu ya niile,
\q2 nʼihi na nke a bụ ọrụ niile dịrị mmadụ.
\q1 
\v 14 Nʼihi na Chineke ga-ekpe ọrụ ọbụla ikpe,
\q2 ya na ihe nzuzo anyị niile,
\q2 ma ha dị mma ma ha dị njọ.
