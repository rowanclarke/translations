\v 6 \w à|strong="H06213"\w* \w cause|strong="H03651"\w* \w de|strong="H06213"\w* \w cela|strong="H03651"\w*, \w je|strong="H03588"\w* \w suis|strong="H01961"\w* \w vivant|strong="H02416"\w*, — \w oracle|strong="H04853"\w* \w du|strong="H06213"\w* \w Seigneur|strong="H00136"\w* \nd \+w Yahweh|strong="H03068"\+w*\nd* : \w Je|strong="H03588"\w* \w te|strong="H01818"\w* \w mettrai|strong="H06213"\w* \w à|strong="H06213"\w* \w sang|strong="H01818"\w*\f + \fr 35:6 \ft 6. \ft \+it Le sang\+it* : allusion probable au nom même d’\+it Edom\+it*, qui signifie \+it rouge\+it*, et qui ressemble au mot \+it dâm, sang\+it*.\f*, \w et|strong="H06213"\w* \w le|strong="H05002"\w* \w sang|strong="H01818"\w* \w te|strong="H01818"\w* \w poursuivra|strong="H07291"\w* ; \w parce|strong="H06903"\w* \w que|strong="H03588"\w* \w tu|strong="H03588"\w* n’\w as|strong="H03588"\w* \w pas|strong="H03808"\w* \w haï|strong="H08130"\w* \w le|strong="H05002"\w* \w sang|strong="H01818"\w*, \w le|strong="H05002"\w* \w sang|strong="H01818"\w* \w te|strong="H01818"\w* \w poursuivra|strong="H07291"\w*.  
\v 7 \w Et|strong="H07725"\w* \w je|strong="H07725"\w* \w ferai|strong="H05414"\w* \w de|strong="H02022"\w* \w la|strong="H05414"\w* \w montagne|strong="H02022"\w* \w de|strong="H02022"\w* \w Séir|strong="H08165"\w* \w une|strong="H05414"\w* \w solitude|strong="H08077"\w* \w et|strong="H07725"\w* \w un|strong="H05414"\w* \w désert|strong="H08077"\w*, \w et|strong="H07725"\w* j’\w en|strong="H05414"\w* \w retrancherai|strong="H03772"\w* \w tout|strong="H05414"\w* \w allant|strong="H03212"\w* \w et|strong="H07725"\w* \w venant|strong="H00935"\w*.  
