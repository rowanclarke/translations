\id LAM  
\h Plač Jeremijin 
\toc1 Plač Jeremijin 
\toc2 Plač Jeremijin 
\toc3 Plač 
\mt1 Plač Jeremijin  
\c 1  
\s1 Jerusalim opustošen i osramoćen tuži i moli za pomoć.  
\q1
\v 1 Kako sedi sam, posta kao udovica,  
\q2 grad koji beše pun naroda!  
\q1 Velik među narodima,  
\q2 glava među zemljama potpade pod danak!   
\b  
\q1
\v 2 Jednako plače noću, i suze su mu na obrazima,  
\q2 nema nikoga od svih koji ga ljubljahu da ga poteši;  
\q1 svi ga prijatelji njegovi izneveriše,  
\q2 postaše mu neprijatelji.   
\b  
\q1
\v 3 Iseli se Juda od muke i ljutog ropstva;  
\q2 sedi među narodima,  
\q1 ne nalazi mir;  
\q2 svi koji ga goniše stigoše ga u tesnacu.   
\b  
\q1
\v 4 Putevi sionski tuže,  
\q2 jer niko ne ide na praznik;  
\q1 sva su vrata njegova pusta,  
\q2 sveštenici njegovi uzdišu,  
\q1 devojke su njegove žalosne,  
\q2 i sam je jadan.   
\b  
\q1
\v 5 Protivnici njegovi postaše glava,  
\q2 neprijateljima je njegovim dobro;  
\q1 jer ga Gospod ucveli za mnoštvo bezakonja njegovog;  
\q2 deca njegova idu u ropstvo pred neprijateljem.   
\b  
\q1
\v 6 I otide od kćeri sionske sva slava njena;  
\q2 knezovi su njeni kao jeleni koji ne nalaze paše;  
\q1 idu nemoćni pred onim koji ih goni.   
\b  
\q1
\v 7 Opominje se Jerusalim u muci svojoj i u jadu svom  
\q2 svih milina što je imao od starine,  
\q1 kad pada narod njegov od ruke neprijateljeve,  
\q2 a nikoga nema da mu pomogne;  
\q1 neprijatelji gledaju ga  
\q2 i smeju se prestanku njegovom.   
\b  
\q1
\v 8 Teško sagreši Jerusalim,  
\q2 zato posta kao nečista žena;  
\q1 svi koji su ga poštovali preziru ga,  
\q2 jer videše golotinju njegovu;  
\q1 a on uzdiše,  
\q2 i okreće se natrag.   
\b  
\q1
\v 9 Nečistota mu beše na skutovima;  
\q2 nije mislio na kraj svoj;  
\q1 pao je za čudo,  
\q2 a nema nikoga da ga poteši.  
\q1 Pogledaj, Gospode, muku moju,  
\q2 jer se neprijatelj poneo.   
\b  
\q1
\v 10 Neprijatelj poseže rukom na sve drage stvari njegove,  
\q2 i on gleda kako narodi ulaze u svetinju njegovu,  
\q2 za koje si zapovedio da ne dolaze na sabor Tvoj.   
\b  
\q1
\v 11 Sav narod njegov uzdiše tražeći hleba,  
\q2 daju dragocene stvari svoje za jelo da okrepe dušu.  
\q1 Pogledaj, Gospode,  
\q2 i vidi kako sam poništen.   
\b  
\q1
\v 12 Zar vam nije stalo,  
\q2 svi koji prolazite ovuda?  
\q1 Pogledajte i vidite,  
\q2 ima li bola kakav je moj,  
\q1 koji je meni dopao,  
\q2 kojim me ucveli Gospod u dan žestokog gneva svog.   
\b  
\q1
\v 13 S visine pusti oganj u kosti moje,  
\q2 koji ih osvoji;  
\q1 razape mrežu nogama mojim,  
\q2 obori me nauznako,  
\q1 pustoši me,  
\q2 te po vas dan tužim.   
\b  
\q1
\v 14 Svezan je rukom njegovom jaram od greha mojih,  
\q2 usukani su i dođoše mi na vrat;  
\q1 obori silu moju;  
\q1 predade me Gospod u ruke,  
\q2 iz kojih se ne mogu podignuti.   
\b  
\q1
\v 15 Polazi Gospod sve junake moje usred mene,  
\q2 sazva na me sabor da potre mladiće moje;  
\q1 kao grožđe u kaci izgazi Gospod devojku,  
\q2 kćer Judinu.   
\b  
\q1
\v 16 Zato ja plačem, oči moje,  
\q2 oči moje liju suze,  
\q1 jer je daleko od mene utešitelj,  
\q2 koji bi ukrepio dušu moju;  
\q1 sinovi moji propadoše,  
\q2 jer nadvlada neprijatelj.   
\b  
\q1
\v 17 Sion širi ruke svoje,  
\q2 nema nikoga da ga teši;  
\q1 Gospod zapovedi za Jakova,  
\q2 te ga opkoliše neprijatelji;  
\q1 Jerusalim posta među njima kao nečista žena.   
\b  
\q1
\v 18 Pravedan je Gospod,  
\q2 jer se suprotih zapovesti Njegovoj;  
\q1 čujte, svi narodi,  
\q2 i vidite bol moj;  
\q1 devojke moje i mladići moji otidoše u ropstvo.   
\b  
\q1
\v 19 Zvah prijatelje svoje,  
\q2 oni me prevariše;  
\q1 sveštenici moji i starešine moje pomreše u gradu  
\q2 tražeći hrane da okrepe dušu svoju.   
\b  
\q1
\v 20 Pogledaj, Gospode, jer mi je tuga,  
\q2 utroba mi se uskolebala,  
\q1 srce se moje prevrće u meni,  
\q2 jer se mnogo suprotih;  
\q1 napolju učini me sirotim mač,  
\q2 a kod kuće sama smrt.   
\b  
\q1
\v 21 Čuju gde uzdišem,  
\q2 ali nema nikoga da me poteši;  
\q1 svi neprijatelji moji čuše za nesreću moju  
\q2 i raduju se što si to učinio;  
\q1 dovešćeš dan koji si oglasio,  
\q2 te će oni biti kao ja.   
\b  
\q1
\v 22 Neka izađe preda te sva zloća njihova,  
\q2 i učini kao što si učinio meni za sve grehe moje;  
\q1 jer je mnogo uzdaha mojih  
\q2 i srce je moje žalosno.   
\c 2  
\s1 Tužnjava zbog propasti Jude i Jerusalima.  
\q1
\v 1 Kako obastre Gospod oblakom u gnevu svom kćer sionsku!  
\q2 Svrže s neba na zemlju slavu Izrailjevu,  
\q1 i ne opomenu se podnožja nogu svojih u dan gneva svog!   
\b  
\q1
\v 2 Gospod potre nemilice sve stanove Jakovljeve,  
\q2 razvali u gnevu svom gradove kćeri Judine,  
\q1 i na zemlju obori,  
\q2 oskvrni carstvo i knezove njegove.   
\b  
\q1
\v 3 Odbi u žestokom gnevu sav rog Izrailju,  
\q2 obrati natrag desnicu svoju od neprijatelja,  
\q1 i raspali se na Jakova kao oganj plameni,  
\q2 koji proždire sve oko sebe.   
\b  
\q1
\v 4 Nateže luk svoj kao neprijatelj,  
\q2 podiže desnicu svoju kao protivnik,  
\q1 i pobi sve što beše drago očima;  
\q2 na šator kćeri sionske prosu kao oganj gnev svoj.   
\b  
\q1
\v 5 Gospod posta kao neprijatelj;  
\q2 potre Izrailja, potre sve dvore njegove,  
\q1 raskopa sve gradove njegove,  
\q2 i umnoži kćeri Judinoj žalost i jad.   
\b  
\q1
\v 6 Razvali mu ogradu kao vrtu;  
\q2 potre mesto sastancima njegovim;  
\q1 Gospod vrže u zaborav na Sionu praznike i subotu,  
\q2 i u žestini gneva svog odbaci cara i sveštenika.   
\b  
\q1
\v 7 Odbaci Gospod oltar svoj,  
\q2 omrze na svetinju svoju,  
\q1 predade u ruke neprijateljima zidove dvora sionskih;  
\q2 stade ih vika u domu Gospodnjem kao na praznik.   
\b  
\q1
\v 8 Gospod naumi da raskopa zid kćeri sionske,  
\q2 rasteže uže,  
\q1 i ne odvrati ruke svoje da ne zatre,  
\q2 i ojadi opkop i zid, iznemogoše skupa.   
\b  
\q1
\v 9 Utonuše u zemlju vrata njena,  
\q2 polomi i potre prevornice njene;  
\q1 car njen i knezovi njeni među narodima su;  
\q2 zakona nema, i proroci njeni ne dobijaju utvare od Gospoda.   
\b  
\q1
\v 10 Starešine kćeri sionske sede na zemlji i ćute,  
\q2 posule su prahom glavu i pripasale kostret;  
\q1 oborile su k zemlji glave svoje devojke jerusalimske.   
\b  
\q1
\v 11 Iščileše mi oči od suza,  
\q2 utroba se moja uskolebala,  
\q1 prosipa se na zemlju jetra moja od pogibli kćeri naroda mog,  
\q2 jer deca i koja sisaju obamiru na ulicama gradskim.   
\b  
\q1
\v 12 Govore materama svojim:  
\q2 Gde je žito i vino?  
\q1 Obamiru kao ranjenici na ulicama gradskim,  
\q2 i ispuštaju dušu svoju u naručju matera svojih.   
\b  
\q1
\v 13 Koga ću ti uzeti za svedoka?  
\q2 S čim ću te izjednačiti, kćeri jerusalimska?  
\q1 Kakvu ću ti priliku naći, da te utešim,  
\q2 devojko, kćeri sionska?  
\q1 Jer je nesreća tvoja velika kao more,  
\q2 ko će te isceliti?   
\b  
\q1
\v 14 Proroci tvoji prorokovaše ti laž i bezumlje,  
\q2 i ne otkrivaše bezakonja tvog  
\q2 da bi odvratili ropstvo tvoje;  
\q1 nego ti kazivaše utvare lažne  
\q2 i koje će te prognati.   
\b  
\q1
\v 15 Pljeskaju rukama nad tobom svi koji prolaze,  
\q2 zvižde i mašu glavom za kćerju jerusalimskom:  
\q1 To li je grad, za koji govorahu da je prava lepota,  
\q2 radost svoj zemlji?   
\b  
\q1
\v 16 Razvaljuju usta na te svi neprijatelji tvoji,  
\q2 zvižde i škrguću zubima govoreći:  
\q1 Proždresmo; ovo je doista dan koji čekasmo;  
\q2 dočekasmo, videsmo.   
\b  
\q1
\v 17 Učini Gospod šta naumi,  
\q2 ispuni reč svoju, koju kaza odavna;  
\q1 razori nemilice i razveseli tobom neprijatelja,  
\q2 podiže rog protivnicima tvojim.   
\b  
\q1
\v 18 Viče srce njihovo ka Gospodu:  
\q1 Zide kćeri sionske,  
\q2 prolivaj potokom suze dan i noć,  
\q1 ne daj sebi mira,  
\q2 i zenica oka tvog da ne staje.   
\b  
\q1
\v 19 Ustani, viči obnoć, u početku straže,  
\q2 prolivaj srce svoje kao vodu pred Gospodom,  
\q1 podiži k Njemu ruke svoje za dušu dece svoje  
\q2 koja obamiru od gladi na uglovima svojih ulica.   
\b  
\q1
\v 20 Pogledaj, Gospode, i vidi,  
\q2 kome si ovako učinio.  
\q1 Eda li žene jedu porod svoj,  
\q2 decu koju nose u naručju?  
\q1 Eda li se ubija u svetinji Gospodnjoj sveštenik i prorok?   
\b  
\q1
\v 21 Leže na zemlji po ulicama deca i starci,  
\q2 devojke moje i mladići moji padoše od mača,  
\q1 pobio si ih u dan gneva svog  
\q2 i poklao ne žaleći.   
\b  
\q1
\v 22 Sazvao si kao na praznik strahote moje od svuda,  
\q2 i u dan gneva Gospodnjeg niko ne uteče niti osta.  
\q1 Koje na ruku nosih i othranih,  
\q2 njih mi neprijatelj moj pobi.   
\c 3  
\s1 Jeremijin plač i uteha.  
\q1
\v 1 Ja sam čovek koji videh muku  
\q2 od pruta gneva Njegovog.   
\q1
\v 2 Odvede me i opravi me u tamu,  
\q2 a ne na videlo.   
\q1
\v 3 Samo se na me obraća,  
\q2 obraća ruku svoju po vas dan.   
\b  
\q1
\v 4 Učini, te mi ostare telo i koža,  
\q2 potre kosti moje.   
\q1
\v 5 Zazida me,  
\q2 i optoči me žučju i mukom.   
\q1
\v 6 Posadi me u tamu  
\q2 kao umrle odavna.   
\b  
\q1
\v 7 Ogradi me da ne izađem,  
\q2 i metnu na me teške okove.   
\q1
\v 8 Kad vičem i vapim,  
\q2 odbija molitvu moju.   
\q1
\v 9 Zagradi puteve moje tesanim kamenom,  
\q2 i prevrati staze moje.   
\b  
\q1
\v 10 Posta mi kao medved u zasedi,  
\q2 kao lav u potaji.   
\q1
\v 11 Pomete puteve moje,  
\q2 i razdre me, i uništi me.   
\q1
\v 12 Nateže luk svoj,  
\q2 i metnu me streli za belegu.   
\b  
\q1
\v 13 Ustreli me u bubrege  
\q2 strelama iz tula svog.   
\q1
\v 14 Postah podsmeh svemu narodu svom  
\q2 i pesma njihova po vas dan.   
\q1
\v 15 Nasiti me gorčinom,  
\q2 opoji me pelenom.   
\b  
\q1
\v 16 Polomi mi zube kamenjem,  
\q2 uvali me u pepeo.   
\q1
\v 17 Udaljio si dušu moju od mira,  
\q2 zaboravih dobro.   
\q1
\v 18 I rekoh:  
\q2 Propade sila moja i nadanje moje od Gospoda.   
\b  
\q1
\v 19 Opomeni se muke moje i jada mog,  
\q2 pelena i žuči.   
\q1
\v 20 Duša se moja opominje bez prestanka,  
\q2 i poništila se u meni.   
\q1
\v 21 Ali ovo napominjem srcu svom,  
\q2 te se nadam:   
\b  
\q1
\v 22 Milost je Gospodnja što ne izgibosmo sasvim,  
\q2 jer milosrđa Njegovog nije nestalo.   
\q1
\v 23 Ponavlja se svako jutro;  
\q2 velika je vera tvoja.   
\q1
\v 24 Gospod je deo moj, govori duša moja;  
\q2 zato ću se u Njega uzdati.   
\b  
\q1
\v 25 Dobar je Gospod onima koji ga čekaju,  
\q2 duši, koja ga traži.   
\q1
\v 26 Dobro je mirno čekati spasenje Gospodnje.   
\q1
\v 27 Dobro je čoveku nositi jaram za mladosti svoje.   
\b  
\q1
\v 28 Sam će sedeti i ćutati,  
\q2 jer Bog metnu breme na nj.   
\q1
\v 29 Metnuće usta svoja u prah,  
\q2 eda bi bilo nadanja.   
\q1
\v 30 Podmetnuće obraz svoj onome koji ga bije,  
\q2 biće sit sramote.   
\b  
\q1
\v 31 Jer Gospod ne odbacuje za svagda.   
\q1
\v 32 Jer ako i ucveli, opet će se i smilovati  
\q2 radi mnoštva milosti svoje.   
\q1
\v 33 Jer ne muči iz srca svog  
\q2 ni cveli sinove čovečje.   
\b  
\q1
\v 34 Kad gaze nogama sve sužnje na zemlji,   
\q1
\v 35 Kad izvrću pravicu čoveku pred Višnjim,   
\q1
\v 36 Kad čine krivo čoveku u parnici njegovoj,  
\q2 ne vidi li Gospod?   
\b  
\q1
\v 37 Ko je rekao što i zbilo se,  
\q2 a Gospod da nije zapovedio?   
\q1
\v 38 Ne dolaze li i zla i dobra iz usta Višnjeg?   
\q1
\v 39 Zašto se tuži čovek živ,  
\q2 čovek na kar za grehe svoje?   
\b  
\q1
\v 40 Pretražimo i razgledajmo pute svoje,  
\q2 i povratimo se ka Gospodu.   
\q1
\v 41 Podignimo srce svoje i ruke k Bogu na nebesima.   
\q1
\v 42 Zgrešismo i nepokorni bismo;  
\q2 Ti ne praštaš.   
\b  
\q1
\v 43 Obastro si se gnevom, i goniš nas,  
\q2 ubijaš i ne žališ.   
\q1
\v 44 Obastro si si se oblakom  
\q2 da ne prodre molitva.   
\q1
\v 45 Načinio si od nas smetlište  
\q2 i odmet usred tih naroda.   
\b  
\q1
\v 46 Razvaljuju usta svoja na nas  
\q2 svi neprijatelji naši.   
\q1
\v 47 Strah i jama zadesi nas,  
\q2 pustošenje i zatiranje.   
\q1
\v 48 Potoci teku iz očiju mojih  
\q2 radi pogibli kćeri naroda mog.   
\b  
\q1
\v 49 Oči moje liju suze bez prestanka,  
\q2 jer nema odmora,   
\q1
\v 50 Dokle Gospod ne pogleda  
\q2 i ne vidi s neba.   
\q1
\v 51 Oko moje muči mi dušu  
\q2 radi svih kćeri grada mog.   
\b  
\q1
\v 52 Teraju me jednako kao pticu neprijatelji moji nizašta.   
\q1
\v 53 Svališe u jamu život moj  
\q2 i nabacaše kamenje na me.   
\q1
\v 54 Dođe mi voda svrh glave;  
\q2 rekoh: Pogiboh!   
\b  
\q1
\v 55 Prizivah ime Tvoje, Gospode,  
\q2 iz jame najdublje.   
\q1
\v 56 Ti ču glas moj;  
\q2 ne zatiskuj uha svog od uzdisanja mog, od vike moje.   
\q1
\v 57 Pristupao si kad Te prizivah,  
\q2 i govorio si: Ne boj se.   
\b  
\q1
\v 58 Raspravljao si, Gospode, parbu duše moje,  
\q2 i izbavljao si život moj.   
\q1
\v 59 Vidiš, Gospode, nepravdu koja mi se čini;  
\q2 raspravi parbu moju.   
\q1
\v 60 Vidiš svu osvetu njihovu,  
\q2 sve što mi misle.   
\b  
\q1
\v 61 Čuješ rug njihov, Gospode,  
\q2 sve što mi misle,   
\q1
\v 62 Šta govore oni koji ustaju na me  
\q2 i šta namišljaju protiv mene po vas dan.   
\q1
\v 63 Vidi, kad sedaju i kad ustaju,  
\q2 ja sam im pesma.   
\b  
\q1
\v 64 Plati im, Gospode,  
\q2 po delima ruku njihovih.   
\q1
\v 65 Podaj im uporno srce,  
\q2 prokletstvo svoje.   
\q1
\v 66 Goni ih gnevom,  
\q2 i istrebi ih ispod nebesa Gospodnjih.   
\c 4  
\s1 Beda i sramota Judina.  
\q1
\v 1 Kako potamne zlato,  
\q2 promeni se čisto zlato?  
\q1 Kamenje je od svetinje razmetnuto po uglovima svih ulica.   
\b  
\q1
\v 2 Dragi sinovi sionski,  
\q2 cenjeni kao najčistije zlato,  
\q1 kako se cene zemljani sudovi,  
\q2 kao delo ruku lončarevih!   
\b  
\q1
\v 3 I zveri ističu sise svoje i doje mlad svoju,  
\q2 a kći naroda mog posta nemilostiva kao noj u pustinji.   
\b  
\q1
\v 4 Jezik detetu koje sisa prionu za grlo od žeđi;  
\q2 deca ištu hleba, a nema nikoga da im lomi.   
\b  
\q1
\v 5 Koji jeđahu poslastice,  
\q2 ginu na ulicama;  
\q1 koji odrastoše u skerletu,  
\q2 valjaju se po bunjištu.   
\b  
\q1
\v 6 I kar koji dopade kćeri naroda mog veći je od propasti koja dopade Sodomu,  
\q2 koji se zatre u času  
\q2 i ruke se ne zabaviše oko njega.   
\b  
\q1
\v 7 Nazireji njeni behu čistiji od snega,  
\q2 belji od mleka;  
\q1 telo im beše crvenije od dragog kamenja,  
\q2 glatki kao safir.   
\b  
\q1
\v 8 A sada im je lice crnje od uglja,  
\q2 ne poznaju se na ulicama;  
\q1 koža im se prilepila za kosti,  
\q2 osušila se kao drvo.   
\b  
\q1
\v 9 Bolje bi onima koji su pobijeni mačem nego onima koji mru od gladi,  
\q2 koji izdišu ubijeni od nestašice roda zemaljskog.   
\b  
\q1
\v 10 Svojim rukama žene žalostive kuvaše decu svoju,  
\q2 ona im biše hrana u pogibli kćeri naroda mog.   
\b  
\q1
\v 11 Navrši Gospod gnev svoj,  
\q2 izli žestoki gnev svoj,  
\q1 i raspali oganj na Sionu,  
\q2 koji mu proždre temelje.   
\b  
\q1
\v 12 Ne bi verovali carevi zemaljski i svi stanovnici po vasiljenoj  
\q2 da će neprijatelj i protivnik ući na vrata jerusalimska.   
\b  
\q1
\v 13 Ali bi za grehe proroka njegovih i za bezakonja sveštenika njegovih,  
\q2 koji prolivahu krv pravedničku usred njega.   
\b  
\q1
\v 14 Lutahu kao slepci po ulicama,  
\q2 kaljahu se krvlju,  
\q2 koje ne mogahu da se ne dotiču haljinama svojim.   
\b  
\q1
\v 15 Odstupite, nečisti, viču im,  
\q2 odstupite, odstupite, ne dodevajte se ničega.  
\q1 I odlaze i skitaju se;  
\q2 i među narodima se govori: Neće se više staniti.   
\b  
\q1
\v 16 Gnev Gospodnji raseja ih,  
\q2 neće više pogledati na njih;  
\q1 ne poštuju sveštenika,  
\q2 nisu žalostivi na starce.   
\b  
\q1
\v 17 Već nam oči iščileše izgledajući pomoć zaludnu;  
\q2 čekasmo narod koji ne može izbaviti.   
\b  
\q1
\v 18 Vrebaju nam korake,  
\q2 da ne možemo hoditi po ulicama svojim,  
\q1 približi se kraj naš,  
\q2 navršiše se dani naši, dođe kraj naš.   
\b  
\q1
\v 19 Koji nas goniše,  
\q2 behu lakši od orlova nebeskih,  
\q1 po gorama nas goniše,  
\q2 u pustinji nam zasedaše.   
\b  
\q1
\v 20 Disanje nozdrva naših, pomazanik Gospodnji,  
\q2 za kog govorasmo da ćemo živeti pod senom njegovim među narodima,  
\q2 uhvati se u jame njihove.   
\b  
\q1
\v 21 Raduj se i veseli se, kćeri edomska,  
\q2 koja živiš u zemlji Uzu!  
\q1 Doći će do tebe čaša, opićeš se,  
\q2 i otkrićeš se.   
\b  
\q1
\v 22 Svrši se kar za bezakonje tvoje, kćeri sionska;  
\q2 neće te više voditi u ropstvo;  
\q1 pohodiće tvoje bezakonje, kćeri edomska,  
\q2 otkriće grehe tvoje.   
\c 5  
\s1 Molitve ugnjetenog naroda za milost i pomoć.  
\q1
\v 1 Opomeni se, Gospode, šta nas zadesi;  
\q2 pogledaj i vidi sramotu našu.   
\q1
\v 2 Nasledstvo naše privali se tuđincima,  
\q2 domovi naši inostrancima.   
\q1
\v 3 Postasmo sirote, bez oca,  
\q2 matere naše kao udovice.   
\q1
\v 4 Svoju vodu pijemo za novce,  
\q2 svoja drva kupujemo.   
\q1
\v 5 Na vratu nam je jaram, i gone nas;  
\q2 umoreni nemamo odmora.   
\q1
\v 6 Pružamo ruku k Misircima i Asircima,  
\q2 da se nasitimo hleba.   
\q1
\v 7 Oci naši zgrešiše, i nema ih,  
\q2 a mi nosimo bezakonja njihova.   
\q1
\v 8 Robovi nam gospodare,  
\q2 nema nikoga da izbavi iz ruku njihovih.   
\q1
\v 9 Sa strahom za život svoj od mača  
\q2 u pustinji donosimo sebi hleb.   
\q1
\v 10 Koža nam pocrne kao peć od ljute gladi.   
\q1
\v 11 Sramote žene na Sionu  
\q2 i devojke po gradovima Judinim.   
\q1
\v 12 Knezove vešaju svojim rukama,  
\q2 ne poštuju lice staračko.   
\q1
\v 13 Mladiće uzimaju pod žrvnje,  
\q2 i deca padaju pod drvima.   
\q1
\v 14 Staraca nema više na vratima,  
\q2 ni mladića na pevanju.   
\q1
\v 15 Nesta radosti srcu našem,  
\q2 igra naša pretvori se u žalost.   
\q1
\v 16 Pade venac s glave naše;  
\q2 teško nama, što zgrešismo!   
\q1
\v 17 Stoga je srce naše žalosno,  
\q2 stoga oči naše potamneše,   
\q1
\v 18 Sa gore Siona, što opuste,  
\q2 i lisice idu po njoj.   
\q1
\v 19 Ti, Gospode, ostaješ doveka,  
\q2 presto Tvoj od kolena do kolena.   
\q1
\v 20 Zašto hoćeš da nas zaboraviš doveka,  
\q2 da nas ostaviš zadugo?   
\q1
\v 21 Obrati nas, Gospode, k sebi, i obratićemo se;  
\q2 ponovi dane naše kako behu pre.   
\q1
\v 22 Jer eda li ćeš nas sasvim odbaciti  
\q2 i gneviti se na nas veoma?   