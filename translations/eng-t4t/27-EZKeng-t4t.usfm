\c 36  
\s1 A prophecy about Yahweh bringing his people back to Israel  
\p
\v 1 \w You|strong="H2022"\w* human, \w prophesy|strong="H5012"\w* \w about|strong="H1697"\w* \w the|strong="H8085"\w* \w mountains|strong="H2022"\w* \w in|strong="H3478"\w* \w Israel|strong="H3478"\w*. \w Say|strong="H1697"\w* \w to|strong="H3478"\w* \w them|strong="H1121"\w*, “\w You|strong="H2022"\w* \w mountains|strong="H2022"\w* \w in|strong="H3478"\w* \w Israel|strong="H3478"\w*, \w listen|strong="H8085"\w* \w to|strong="H3478"\w* \w what|strong="H1697"\w* \w Yahweh|strong="H3068"\w* \w says|strong="H1697"\w*.  
