\v 3 \w David|strong="H1732"\w* derrotó \w a|strong="H3068"\w* \w Hadad-ezer|strong="H1909"\w*, \w rey|strong="H4428"\w* de Soba, cerca de Hamat, cuando éste \w iba|strong="H3212"\w* \w a|strong="H3068"\w* restablecer su dominio \w junto|strong="H3027"\w* \w al|strong="H4428"\w* \w río|strong="H5104"\w* \w Éufrates|strong="H6578"\w*.  
\v 4 \w David|strong="H1732"\w* le capturó 1.000 carruajes \w de|strong="H4480"\w* guerra, 7.000 \w jinetes|strong="H6571"\w* y 20.000 infantes. \w David|strong="H1732"\w* \w desjarretó|strong="H6131"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* caballos \w de|strong="H4480"\w* \w los|strong="H3605"\w* carruajes y dejó solo caballos \w para|strong="H4480"\w* 100 carruajes.   
\p
\v 5 Cuando los sirios de \w Damasco|strong="H1834"\w* llegaron \w a|strong="H3068"\w* ayudar \w a|strong="H3068"\w* \w Hadad-ezer|strong="H1909"\w*, \w rey|strong="H4428"\w* de Soba, \w David|strong="H1732"\w* \w mató|strong="H5221"\w* \w a|strong="H3068"\w* 22.000 \w hombres|strong="H8147"\w* de los sirios.  
\v 6 \w David|strong="H1732"\w* estableció guarniciones en Siria de \w Damasco|strong="H1834"\w*. \w Los|strong="H3605"\w* sirios \w fueron|strong="H1961"\w* tributarios y esclavos de \w David|strong="H1732"\w*, \w porque|strong="H1732"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* daba \w la|strong="H3605"\w* victoria \w a|strong="H3068"\w* \w David|strong="H1732"\w* dondequiera \w que|strong="H1961"\w* \w iba|strong="H1980"\w*.   
\p
\v 7 \w David|strong="H1732"\w* \w tomó|strong="H3947"\w* \w los|strong="H5921"\w* \w escudos|strong="H7982"\w* \w de|strong="H5921"\w* \w oro|strong="H2091"\w* \w que|strong="H5921"\w* \w tenían|strong="H1961"\w* \w los|strong="H5921"\w* esclavos \w de|strong="H5921"\w* \w Hadad-ezer|strong="H1909"\w* \w y|strong="H5921"\w* \w los|strong="H5921"\w* \w llevó|strong="H3947"\w* \w a|strong="H3068"\w* Jerusalén.  
\v 8 Asimismo de Tibhat y de Cun, \w ciudades|strong="H5892"\w* de \w Hadad-ezer|strong="H1909"\w*, \w David|strong="H1732"\w* \w tomó|strong="H3947"\w* \w gran|strong="H3966"\w* cantidad de bronce, con \w el|strong="H6213"\w* cual \w Salomón|strong="H8010"\w* \w hizo|strong="H6213"\w* \w el|strong="H6213"\w* \w mar|strong="H3220"\w* de bronce, las \w columnas|strong="H5982"\w* y los utensilios de bronce.   
\p
\v 9 \w Cuando|strong="H3588"\w* \w Tou|strong="H8583"\w*, \w rey|strong="H4428"\w* \w de|strong="H3588"\w* Hamat, \w oyó|strong="H8085"\w* \w que|strong="H3588"\w* \w David|strong="H1732"\w* \w venció|strong="H5221"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H3588"\w* \w ejército|strong="H2426"\w* \w de|strong="H3588"\w* \w Hadad-ezer|strong="H1909"\w*, \w rey|strong="H4428"\w* \w de|strong="H3588"\w* Soba,  
\v 10 \w envió|strong="H7971"\w* \w a|strong="H3068"\w* \w su|strong="H3588"\w* \w hijo|strong="H1121"\w* Adoram \w al|strong="H5921"\w* \w rey|strong="H4428"\w* \w David|strong="H1732"\w* \w para|strong="H5921"\w* saludarlo \w y|strong="H3588"\w* felicitarlo, \w porque|strong="H3588"\w* \w peleó|strong="H3898"\w* \w contra|strong="H5921"\w* \w Hadad-ezer|strong="H1909"\w* \w y|strong="H3588"\w* \w lo|strong="H5921"\w* derrotó. (\w Hadad-ezer|strong="H1909"\w* \w era|strong="H1961"\w* adversario \w de|strong="H5921"\w* \w Tou|strong="H8583"\w*.) \add El rey Tou\add* \w le|strong="H5921"\w* obsequió \w toda|strong="H3605"\w* clase \w de|strong="H5921"\w* utensilios \w de|strong="H5921"\w* \w oro|strong="H2091"\w*, \w plata|strong="H3701"\w* \w y|strong="H3588"\w* bronce.   
\p
\v 11 \w El|strong="H5973"\w* \w rey|strong="H4428"\w* \w David|strong="H1732"\w* \w también|strong="H1571"\w* \w los|strong="H1121"\w* consagró \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \w junto|strong="H5973"\w* \w con|strong="H5973"\w* \w la|strong="H1571"\w* \w plata|strong="H3701"\w* \w y|strong="H1571"\w* \w el|strong="H5973"\w* \w oro|strong="H2091"\w* \w que|strong="H1571"\w* \w tomó|strong="H5375"\w* \w de|strong="H5973"\w* \w todas|strong="H3605"\w* las \w naciones|strong="H1471"\w*: \w de|strong="H5973"\w* Edom, \w Moab|strong="H4124"\w*, \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5973"\w* Amón, \w los|strong="H1121"\w* \w filisteos|strong="H6430"\w* \w y|strong="H1571"\w* \w Amalec|strong="H6002"\w*.   
\p
\v 12 Además \w de|strong="H1121"\w* esto, Abisai, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Sarvia, destrozó \w a|strong="H3068"\w* 18.000 edomitas \w en|strong="H5221"\w* \w el|strong="H1121"\w* \w valle|strong="H1516"\w* \w de|strong="H1121"\w* la \w Sal|strong="H4417"\w*.  
\v 13 \w Impuso|strong="H7760"\w* guarniciones en Edom. \w Todos|strong="H3605"\w* \w los|strong="H3605"\w* edomitas \w fueron|strong="H1961"\w* esclavos de \w David|strong="H1732"\w*, \w porque|strong="H1732"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* daba \w la|strong="H3605"\w* victoria \w a|strong="H3068"\w* \w David|strong="H1732"\w* dondequiera \w que|strong="H1961"\w* \w iba|strong="H1980"\w*.   
\p
\v 14 \w David|strong="H1732"\w* \w reinó|strong="H4427"\w* \w sobre|strong="H5921"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* \w y|strong="H5921"\w* juzgaba \w con|strong="H5921"\w* \w justicia|strong="H6666"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* su \w pueblo|strong="H5971"\w*.  
\v 15 \w Joab|strong="H3097"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Sarvia, \w era|strong="H1121"\w* general \w del|strong="H5921"\w* \w ejército|strong="H6635"\w*, \w y|strong="H5921"\w* Josafat, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Ahilud, \w el|strong="H5921"\w* cronista.  
\v 16 \w Sadoc|strong="H6659"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Ahitob y Abimelec, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Abiatar eran \w sacerdotes|strong="H3548"\w*, y Savsa, \w secretario|strong="H5608"\w*.  
\v 17 \w Benaía|strong="H1141"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Joiada|strong="H3077"\w*, \w era|strong="H1121"\w* jefe \w de|strong="H5921"\w* \w los|strong="H1121"\w* cereteos \w y|strong="H5921"\w* peleteos. \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w David|strong="H1732"\w* eran supervisores \w junto|strong="H5921"\w* \w al|strong="H5921"\w* \w rey|strong="H4428"\w*.   
\c 19  
\s1 Derrota de los hijos de Amón  
\p
\v 1 \w Aconteció|strong="H1961"\w* \w después|strong="H1961"\w* \w de|strong="H8478"\w* estas cosas \w que|strong="H1121"\w* \w murió|strong="H4191"\w* Nahas, \w rey|strong="H4428"\w* \w de|strong="H8478"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H8478"\w* Amón, y \w reinó|strong="H4427"\w* \w en|strong="H8478"\w* su \w lugar|strong="H8478"\w* su \w hijo|strong="H1121"\w*.  
\v 2 \w Y|strong="H3068"\w* \w David|strong="H1732"\w* dijo: Tendré \w misericordia|strong="H2617"\w* \w de|strong="H5921"\w* \w Hanún|strong="H2586"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Nahas, \w porque|strong="H3588"\w* también \w su|strong="H3588"\w* padre \w tuvo|strong="H6213"\w* \w misericordia|strong="H2617"\w* \w conmigo|strong="H5973"\w*. \w David|strong="H1732"\w* \w envió|strong="H7971"\w* \w mensajeros|strong="H4397"\w* \w a|strong="H3068"\w* consolarlo \w por|strong="H5921"\w* \w la|strong="H5921"\w* muerte \w de|strong="H5921"\w* \w su|strong="H3588"\w* padre.  
\p \w Pero|strong="H3588"\w* \w cuando|strong="H3588"\w* \w los|strong="H1121"\w* esclavos \w de|strong="H5921"\w* \w David|strong="H1732"\w* entraron \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* Amón \w para|strong="H5921"\w* consolar \w a|strong="H3068"\w* \w Hanún|strong="H2586"\w*,  
\v 3 \w los|strong="H1121"\w* \w jefes|strong="H8269"\w* \w de|strong="H3588"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* Amón dijeron \w a|strong="H3068"\w* \w Hanún|strong="H2586"\w*: ¿\w Te|strong="H5869"\w* parece \w que|strong="H3588"\w* \w David|strong="H1732"\w* \w honra|strong="H3513"\w* \w a|strong="H3068"\w* tu padre \w porque|strong="H3588"\w* \w te|strong="H5869"\w* \w envió|strong="H7971"\w* \w consoladores|strong="H5162"\w*? ¿\w No|strong="H3808"\w* vienen \w más|strong="H3588"\w* \w bien|strong="H3588"\w* sus esclavos \w a|strong="H3068"\w* ti \w para|strong="H3588"\w* averiguar, destruir \w y|strong="H3588"\w* espiar \w la|strong="H3588"\w* tierra?  
\v 4 Entonces \w Hanún|strong="H2586"\w* \w tomó|strong="H3947"\w* \w a|strong="H3068"\w* los esclavos \w de|strong="H5704"\w* \w David|strong="H1732"\w* \w y|strong="H5704"\w* los rapó. Les \w cortó|strong="H3772"\w* las ropas \w por|strong="H5704"\w* la mitad \w hasta|strong="H5704"\w* las nalgas \w y|strong="H5704"\w* los \w despidió|strong="H7971"\w*.   
\p
\v 5 \w Luego|strong="H7725"\w* salieron. \w Cuando|strong="H3588"\w* \w llegó|strong="H3212"\w* \w la|strong="H5921"\w* noticia \w a|strong="H3068"\w* \w David|strong="H1732"\w* \w sobre|strong="H5921"\w* aquellos \w varones|strong="H3588"\w*, \w él|strong="H5921"\w* \w envió|strong="H7971"\w* \w a|strong="H3068"\w* recibirlos, \w pues|strong="H3588"\w* \w los|strong="H3427"\w* hombres \w estaban|strong="H1961"\w* \w muy|strong="H3966"\w* \w avergonzados|strong="H3637"\w*. \w El|strong="H5921"\w* \w rey|strong="H4428"\w* \w dijo|strong="H5046"\w*: Permanezcan \w en|strong="H5921"\w* \w Jericó|strong="H3405"\w* \w hasta|strong="H5704"\w* \w que|strong="H3588"\w* crezcan sus barbas \w y|strong="H3588"\w* \w entonces|strong="H3588"\w* regresen.   
\s1 Derrota de los sirios  
\p
\v 6 \w Al|strong="H4480"\w* \w ver|strong="H7200"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* Amón \w que|strong="H3588"\w* \w se|strong="H4480"\w* volvieron aborrecibles \w a|strong="H3068"\w* \w David|strong="H1732"\w*, \w Hanún|strong="H2586"\w* \w y|strong="H3588"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* Amón \w enviaron|strong="H7971"\w* 33 toneladas \w de|strong="H4480"\w* \w plata|strong="H3701"\w* \w para|strong="H3588"\w* contratar carruajes \w y|strong="H3588"\w* \w jinetes|strong="H6571"\w* \w de|strong="H4480"\w* Mesopotamia, Siria, Maaca \w y|strong="H3588"\w* Soba.  
\v 7 Contrataron 32.000 carruajes, \w al|strong="H4428"\w* \w rey|strong="H4428"\w* \w de|strong="H6440"\w* Maaca y \w a|strong="H3068"\w* su ejército, quienes llegaron y acamparon frente \w a|strong="H3068"\w* \w Medeba|strong="H4311"\w*. \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* Amón salieron \w desde|strong="H6440"\w* sus \w ciudades|strong="H5892"\w* y fueron \w a|strong="H3068"\w* la \w guerra|strong="H4421"\w*.   
\p
\v 8 Cuando \w David|strong="H1732"\w* \w lo|strong="H3605"\w* \w oyó|strong="H8085"\w*, \w envió|strong="H7971"\w* \w a|strong="H3068"\w* \w Joab|strong="H3097"\w* con \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w ejército|strong="H6635"\w* de \w los|strong="H3605"\w* \w valientes|strong="H1368"\w*.  
\v 9 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Amón \w salieron|strong="H3318"\w* y dispusieron la \w batalla|strong="H4421"\w* \w en|strong="H3318"\w* la entrada \w de|strong="H1121"\w* la \w ciudad|strong="H5892"\w*. \w Los|strong="H1121"\w* \w reyes|strong="H4428"\w* \w que|strong="H1121"\w* llegaron estaban aparte \w en|strong="H3318"\w* \w el|strong="H1121"\w* \w campo|strong="H7704"\w*.   
\p
\v 10 Al \w ver|strong="H7200"\w* \w Joab|strong="H3097"\w* \w que|strong="H3588"\w* \w la|strong="H3588"\w* \w batalla|strong="H4421"\w* \w se|strong="H1961"\w* le presentaba \w por|strong="H3588"\w* \w el|strong="H3588"\w* \w frente|strong="H7125"\w* \w y|strong="H3588"\w* \w por|strong="H3588"\w* \w la|strong="H3588"\w* retaguardia, eligió algunos \w de|strong="H3588"\w* \w entre|strong="H3588"\w* \w los|strong="H3605"\w* mejores hombres \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* \w y|strong="H3588"\w* \w los|strong="H3605"\w* dispuso \w en|strong="H3588"\w* orden \w de|strong="H3588"\w* \w batalla|strong="H4421"\w* \w contra|strong="H7125"\w* \w los|strong="H3605"\w* sirios.  
\v 11 \w Entregó|strong="H5414"\w* \w el|strong="H1121"\w* \w resto|strong="H3499"\w* del ejército en \w mano|strong="H3027"\w* \w de|strong="H1121"\w* su hermano Abisai y \w los|strong="H1121"\w* dispuso en orden \w de|strong="H1121"\w* batalla \w contra|strong="H7125"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Amón.  
\v 12 Entonces dijo: \w Si|strong="H1961"\w* \w los|strong="H1121"\w* sirios \w son|strong="H1961"\w* demasiado \w fuertes|strong="H1121"\w* \w para|strong="H4480"\w* \w mí|strong="H1961"\w*, tú \w me|strong="H4480"\w* ayudarás, y \w si|strong="H1961"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* Amón \w son|strong="H1961"\w* demasiado \w fuertes|strong="H1121"\w* \w para|strong="H4480"\w* \w ti|strong="H4480"\w*, entonces \w yo|strong="H4480"\w* \w te|strong="H4480"\w* ayudaré.  
\v 13 \w Esfuérzate|strong="H2388"\w*, esforcémonos \w por|strong="H1157"\w* nuestro \w pueblo|strong="H5971"\w* y \w por|strong="H1157"\w* las \w ciudades|strong="H5892"\w* \w de|strong="H5971"\w* nuestro \nd ʼElohim\nd* y \w haga|strong="H6213"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w lo|strong="H6213"\w* \w que|strong="H5971"\w* \w le|strong="H1157"\w* parezca \w bien|strong="H2896"\w*.   
\p
\v 14 \w Joab|strong="H3097"\w* \w se|strong="H5971"\w* \w acercó|strong="H5066"\w* \w con|strong="H5973"\w* \w el|strong="H5973"\w* ejército \w que|strong="H5971"\w* tenía \w consigo|strong="H5973"\w* \w para|strong="H5973"\w* pelear \w contra|strong="H5973"\w* \w los|strong="H5973"\w* sirios, pero ellos \w huyeron|strong="H5127"\w* \w de|strong="H6440"\w* \w él|strong="H5973"\w*.   
\p
\v 15 Al \w ver|strong="H7200"\w* \w que|strong="H3588"\w* \w los|strong="H1992"\w* sirios huían, \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* Amón \w también|strong="H1571"\w* \w huyeron|strong="H5127"\w* \w de|strong="H3588"\w* Abisai, hermano \w de|strong="H3588"\w* \w Joab|strong="H3097"\w*, \w y|strong="H1571"\w* entraron \w en|strong="H3588"\w* \w su|strong="H1992"\w* \w ciudad|strong="H5892"\w*. \w Entonces|strong="H3588"\w* \w Joab|strong="H3097"\w* regresó \w a|strong="H3068"\w* Jerusalén.  
\v 16 \w Cuando|strong="H3588"\w* \w los|strong="H3588"\w* sirios \w vieron|strong="H7200"\w* \w que|strong="H3588"\w* cayeron derrotados \w ante|strong="H6440"\w* \w Israel|strong="H3478"\w*, \w enviaron|strong="H7971"\w* \w embajadores|strong="H4397"\w* \w y|strong="H3588"\w* llevaron \w a|strong="H3068"\w* \w los|strong="H3588"\w* sirios \w que|strong="H3588"\w* estaban al otro \w lado|strong="H5676"\w* del Éufrates, cuyo \w jefe|strong="H8269"\w* era Sofac, \w general|strong="H8269"\w* del \w ejército|strong="H6635"\w* \w de|strong="H3588"\w* \w Hadad-ezer|strong="H1909"\w*.   
\p
\v 17 Cuando se informó \w a|strong="H3068"\w* \w David|strong="H1732"\w*, éste reunió \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w*. \w Y|strong="H3068"\w* al cruzar \w el|strong="H5973"\w* \w Jordán|strong="H3383"\w* fue \w hacia|strong="H7125"\w* \w ellos|strong="H3605"\w* y dispuso \w batalla|strong="H4421"\w* \w contra|strong="H5973"\w* \w ellos|strong="H3605"\w*. Cuando \w David|strong="H1732"\w* \w ordenó|strong="H6186"\w* su tropa \w contra|strong="H5973"\w* \w los|strong="H3605"\w* sirios, \w éstos|strong="H3605"\w* \w pelearon|strong="H3898"\w* \w contra|strong="H5973"\w* \w él|strong="H5973"\w*.  
\v 18 Pero los sirios \w huyeron|strong="H5127"\w* \w de|strong="H6440"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*. \w David|strong="H1732"\w* \w mató|strong="H2026"\w* \w a|strong="H3068"\w* 7.000 hombres \w de|strong="H6440"\w* los sirios \w de|strong="H6440"\w* los carruajes y 40.000 infantes, y \w mató|strong="H2026"\w* \w a|strong="H3068"\w* Sofac, \w general|strong="H8269"\w* del \w ejército|strong="H6635"\w*.   
\p
\v 19 \w Cuando|strong="H3588"\w* \w los|strong="H1121"\w* esclavos \w de|strong="H3588"\w* \w Hadad-ezer|strong="H1909"\w* \w vieron|strong="H7200"\w* \w que|strong="H3588"\w* \w fueron|strong="H1732"\w* derrotados \w por|strong="H3588"\w* \w Israel|strong="H3478"\w*, negociaron \w la|strong="H3588"\w* \w paz|strong="H7999"\w* \w con|strong="H5973"\w* \w David|strong="H1732"\w* \w y|strong="H3588"\w* \w le|strong="H5973"\w* \w sirvieron|strong="H5647"\w*.  
\p \w Los|strong="H1121"\w* sirios \w no|strong="H3808"\w* quisieron volver \w a|strong="H3068"\w* socorrer \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* Amón.   
\c 20  
\s1 Guerra contra los hijos de Amón  
\p
\v 1 \w Aconteció|strong="H1961"\w* \w el|strong="H1121"\w* \w año|strong="H8141"\w* siguiente, \w en|strong="H3318"\w* \w el|strong="H1121"\w* \w tiempo|strong="H6256"\w* \w cuando|strong="H1961"\w* \w los|strong="H3427"\w* \w reyes|strong="H4428"\w* acostumbran \w salir|strong="H3318"\w* \w a|strong="H3068"\w* la \w guerra|strong="H6635"\w*, \w que|strong="H1121"\w* \w Joab|strong="H3097"\w* \w sacó|strong="H3318"\w* las fuerzas del \w ejército|strong="H6635"\w*. \w Destruyó|strong="H2040"\w* la tierra \w de|strong="H1121"\w* \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Amón y sitió \w a|strong="H3068"\w* Rabá.  
\p Sin embargo, \w David|strong="H1732"\w* permaneció \w en|strong="H3318"\w* Jerusalén, mientras \w Joab|strong="H3097"\w* atacaba y \w destruía|strong="H7843"\w* \w a|strong="H3068"\w* Rabá.  
\v 2 \w David|strong="H1732"\w* \w tomó|strong="H3947"\w* \w la|strong="H5921"\w* \w corona|strong="H5850"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w cabeza|strong="H7218"\w* \w del|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Rabá. Comprobó \w que|strong="H5921"\w* pesaba 33 kilogramos \w de|strong="H5921"\w* \w oro|strong="H2091"\w* \w y|strong="H5921"\w* \w había|strong="H1961"\w* \w en|strong="H5921"\w* \w ella|strong="H5921"\w* piedras \w preciosas|strong="H3368"\w*. \w Fue|strong="H1961"\w* colocada \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w cabeza|strong="H7218"\w* \w de|strong="H5921"\w* \w David|strong="H1732"\w*. \w También|strong="H3318"\w* \w sacó|strong="H3318"\w* \w despojo|strong="H7998"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w* \w en|strong="H5921"\w* \w gran|strong="H3966"\w* \w abundancia|strong="H7235"\w*.  
\v 3 \w Sacó|strong="H3318"\w* \w también|strong="H3651"\w* \w a|strong="H3068"\w* \w la|strong="H3605"\w* \w gente|strong="H5971"\w* \w que|strong="H5971"\w* estaba \w en|strong="H3318"\w* \w ella|strong="H3605"\w* y \w la|strong="H3605"\w* obligó \w a|strong="H3068"\w* \w trabajar|strong="H6213"\w* con sierras, trillos\f + \fr 20:3 \ft Trillo: Tablón preparado con piedras duras o cuchillas de acero por un lado.\f* \w de|strong="H1121"\w* \w hierro|strong="H1270"\w* y hachas. \w Así|strong="H3651"\w* \w David|strong="H1732"\w* \w hizo|strong="H6213"\w* \w a|strong="H3068"\w* \w todas|strong="H3605"\w* las \w ciudades|strong="H5892"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Amón. \w Y|strong="H3068"\w* \w David|strong="H1732"\w* regresó con \w todo|strong="H3605"\w* \w el|strong="H3605"\w* ejército \w a|strong="H3068"\w* Jerusalén.   
\s1 Guerras contra los filisteos  
\p
\v 4 \w Después|strong="H1961"\w* \w de|strong="H5973"\w* esto \w aconteció|strong="H1961"\w* \w que|strong="H1961"\w* \w hubo|strong="H1961"\w* otra \w guerra|strong="H4421"\w* \w contra|strong="H5973"\w* \w los|strong="H5973"\w* \w filisteos|strong="H6430"\w* \w en|strong="H5973"\w* \w Gezer|strong="H1507"\w*. Sibecai \w husatita|strong="H2843"\w* \w mató|strong="H5221"\w* \w a|strong="H3068"\w* Sipai, uno \w de|strong="H5973"\w* \w los|strong="H5973"\w* descendientes \w de|strong="H5973"\w* \w los|strong="H5973"\w* \w gigantes|strong="H7497"\w*, \w los|strong="H5973"\w* cuales \w fueron|strong="H1961"\w* sometidos.   
\p
\v 5 \w Hubo|strong="H1961"\w* \w otra|strong="H5750"\w* \w guerra|strong="H4421"\w* \w contra|strong="H1961"\w* \w los|strong="H1121"\w* \w filisteos|strong="H6430"\w*. Elhanán, \w hijo|strong="H1121"\w* \w de|strong="H5750"\w* Jaír, \w mató|strong="H5221"\w* \w a|strong="H3068"\w* Lahmi, hermano \w de|strong="H5750"\w* Goliat geteo, cuya asta \w de|strong="H5750"\w* la \w lanza|strong="H2595"\w* \w era|strong="H1961"\w* \w como|strong="H1961"\w* un rodillo \w de|strong="H5750"\w* telar.   
\p
\v 6 \w Volvió|strong="H5750"\w* \w a|strong="H3068"\w* \w haber|strong="H1961"\w* \w guerra|strong="H4421"\w* \w en|strong="H5750"\w* Gat, \w donde|strong="H1931"\w* \w había|strong="H1961"\w* un hombre \w de|strong="H5750"\w* gran estatura, \w el|strong="H1931"\w* \w cual|strong="H1931"\w* \w tenía|strong="H1961"\w* \w seis|strong="H8337"\w* dedos \w en|strong="H5750"\w* pies \w y|strong="H1571"\w* manos, un total \w de|strong="H5750"\w* 24. \w También|strong="H1571"\w* \w éste|strong="H1931"\w* \w era|strong="H1961"\w* descendiente \w de|strong="H5750"\w* \w los|strong="H1931"\w* \w gigantes|strong="H7497"\w*.  
\v 7 Cuando desafió \w a|strong="H3068"\w* \w Israel|strong="H3478"\w*, lo \w mató|strong="H5221"\w* Jonatán, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Simea, hermano \w de|strong="H1121"\w* \w David|strong="H1732"\w*.   
\p
\v 8 Éstos eran descendientes de los \w gigantes|strong="H7497"\w* de Gat, los cuales \w cayeron|strong="H5307"\w* en \w mano|strong="H3027"\w* de \w David|strong="H1732"\w* y en \w mano|strong="H3027"\w* de sus esclavos.   
\c 21  
\s1 Un censo no ordenado por \nd Yavé\nd*  
\p
\v 1 Entonces \w Satán|strong="H7854"\w* \w se|strong="H5921"\w* levantó \w contra|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w e|strong="H3068"\w* incitó \w a|strong="H3068"\w* \w David|strong="H1732"\w* \w a|strong="H3068"\w* hacer un censo \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.  
\v 2 \w David|strong="H1732"\w* dijo \w a|strong="H3068"\w* \w Joab|strong="H3097"\w* \w y|strong="H5704"\w* \w a|strong="H3068"\w* los \w jefes|strong="H8269"\w* del ejército: \w Vayan|strong="H3212"\w*, hagan un censo \w de|strong="H5704"\w* \w Israel|strong="H3478"\w*, \w desde|strong="H5704"\w* Beerseba \w hasta|strong="H5704"\w* \w Dan|strong="H1835"\w*. Traíganme el resultado \w para|strong="H5704"\w* \w que|strong="H5704"\w* yo \w sepa|strong="H3045"\w* el \w número|strong="H4557"\w* \w de|strong="H5704"\w* ellos.   
\p
\v 3 \w Joab|strong="H3097"\w* respondió: \w Añada|strong="H3254"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w a|strong="H3068"\w* \w su|strong="H1992"\w* \w pueblo|strong="H5971"\w* 100 \w veces|strong="H6471"\w* \w más|strong="H3254"\w*, \w rey|strong="H4428"\w* \tl ʼadón\tl* \w mío|strong="H5921"\w*. ¿\w No|strong="H3808"\w* \w son|strong="H1961"\w* \w todos|strong="H3605"\w* \w éstos|strong="H1992"\w* esclavos \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \tl ʼadón\tl*? ¿\w Por|strong="H5921"\w* \w qué|strong="H4100"\w* \w mi|strong="H5921"\w* \tl ʼadón\tl* \w procura|strong="H1245"\w* \w esto|strong="H2063"\w*? \w Porque|strong="H5921"\w* debe ser causa \w de|strong="H5921"\w* culpa \w para|strong="H5921"\w* \w Israel|strong="H3478"\w*.   
\p
\v 4 Pero \w la|strong="H5921"\w* \w palabra|strong="H1697"\w* \w del|strong="H5921"\w* \w rey|strong="H4428"\w* \w prevaleció|strong="H2388"\w* \w contra|strong="H5921"\w* \w Joab|strong="H3097"\w*, \w por|strong="H5921"\w* \w lo|strong="H1697"\w* cual \w Joab|strong="H3097"\w* \w salió|strong="H3318"\w*, recorrió \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* \w y|strong="H5921"\w* regresó \w a|strong="H3068"\w* Jerusalén.  
\v 5 \w Joab|strong="H3097"\w* \w dio|strong="H5414"\w* \w a|strong="H3068"\w* \w David|strong="H1732"\w* \w el|strong="H3605"\w* total del censo \w de|strong="H5971"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* ejército. En \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* \w había|strong="H1961"\w* 1.100.000 hombres \w que|strong="H5971"\w* \w sacaban|strong="H8025"\w* \w espada|strong="H2719"\w*, y en \w Judá|strong="H3063"\w*, 470.000.   
\p
\v 6 \w Entre|strong="H8432"\w* éstos \w los|strong="H3588"\w* levitas \w no|strong="H3808"\w* fueron contados \w ni|strong="H3808"\w* \w los|strong="H3588"\w* hijos \w de|strong="H3588"\w* \w Benjamín|strong="H1144"\w*, \w porque|strong="H3588"\w* \w la|strong="H3588"\w* orden del \w rey|strong="H4428"\w* era repugnante \w para|strong="H3588"\w* \w Joab|strong="H3097"\w*.   
\p
\v 7 \w Esto|strong="H2088"\w* \w también|strong="H2088"\w* desagradó \w a|strong="H3068"\w* \nd ʼElohim\nd*, \w e|strong="H3068"\w* \w hirió|strong="H5221"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w*.   
\p
\v 8 \w Entonces|strong="H3588"\w* \w David|strong="H1732"\w* confesó \w a|strong="H3068"\w* \nd ʼElohim\nd*: \w Pequé|strong="H2398"\w* \w gravemente|strong="H3966"\w* al \w hacer|strong="H6213"\w* \w esto|strong="H2088"\w*. \w Pero|strong="H3588"\w* \w ahora|strong="H6258"\w* \w te|strong="H3588"\w* \w ruego|strong="H4994"\w* \w que|strong="H3588"\w* quites \w la|strong="H3588"\w* \w iniquidad|strong="H5771"\w* \w de|strong="H3588"\w* \w tu|strong="H6213"\w* esclavo, \w porque|strong="H3588"\w* obré \w muy|strong="H3966"\w* \w neciamente|strong="H5528"\w*.   
\s1 El castigo de \nd Yavé\nd* por el atrevimiento de David  
\p
\v 9 \nd \+w Yavé|strong="H3068"\+w*\nd* \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Gad|strong="H1410"\w*, \w vidente|strong="H2374"\w* de \w David|strong="H1732"\w*:  
\v 10 \wj \+w Vé|strong="H3212"\+w* \+w y|strong="H5921"\+w* \+w habla|strong="H1696"\+w* \+w a|strong="H3068"\+w* \+w David|strong="H1732"\+w*: \+nd \+w Yavé|strong="H3068"\+w*\+nd* \+w dice|strong="H1696"\+w*: \+w Tres|strong="H7969"\+w* \+w cosas|strong="H2007"\+w* \+w te|strong="H5921"\+w* \+w propongo|strong="H5186"\+w*. Escoge una \+w de|strong="H5921"\+w* \+w ellas|strong="H2007"\+w*, \+w y|strong="H5921"\+w* \+w Yo|strong="H6213"\+w* \+w te|strong="H5921"\+w* \+w la|strong="H5921"\+w* aplicaré.\wj*   
\p
\v 11 \w Y|strong="H3068"\w* \w Gad|strong="H1410"\w* fue \w a|strong="H3068"\w* \w David|strong="H1732"\w*, \w y|strong="H3541"\w* le dijo: \nd \+w Yavé|strong="H3068"\+w*\nd* dice:  
\v 12 \wj Escoge \+w para|strong="H6258"\+w* ti: \+w tres|strong="H7969"\+w* \+w años|strong="H8141"\+w* \+w de|strong="H6440"\+w* hambruna, \+w o|strong="H3068"\+w* \+w tres|strong="H7969"\+w* \+w meses|strong="H2320"\+w* derrotado \+w por|strong="H1697"\+w* tus \+w enemigos|strong="H6862"\+w* y \+w que|strong="H4100"\+w* \+w la|strong="H3605"\+w* \+w espada|strong="H2719"\+w* \+w de|strong="H6440"\+w* tus \+w adversarios|strong="H6862"\+w* te \+w alcance|strong="H5381"\+w*, \+w o|strong="H3068"\+w* \+w tres|strong="H7969"\+w* \+w días|strong="H3117"\+w* \+w la|strong="H3605"\+w* \+w espada|strong="H2719"\+w* \+w de|strong="H6440"\+w* \+nd \+w Yavé|strong="H3068"\+w*\+nd*, \+w es|strong="H1697"\+w* decir, \+w la|strong="H3605"\+w* \+w pestilencia|strong="H1698"\+w* en \+w la|strong="H3605"\+w* tierra y \+w que|strong="H4100"\+w* \+w el|strong="H3605"\+w* \+w Ángel|strong="H4397"\+w* \+w de|strong="H6440"\+w* \+nd \+w Yavé|strong="H3068"\+w*\+nd* haga estragos en \+w todo|strong="H3605"\+w* \+w el|strong="H3605"\+w* territorio \+w de|strong="H6440"\+w* \+w Israel|strong="H3478"\+w*. \+w Ahora|strong="H6258"\+w* \+w pues|strong="H6258"\+w*, \+w mira|strong="H7200"\+w* \+w qué|strong="H4100"\+w* debo \+w responder|strong="H7725"\+w* al \+w que|strong="H4100"\+w* me \+w envió|strong="H7971"\+w*.\wj*   
\p
\v 13 \w David|strong="H1732"\w* respondió \w a|strong="H3068"\w* \w Gad|strong="H1410"\w*: \w Estoy|strong="H6862"\w* \w en|strong="H3588"\w* \w gran|strong="H3966"\w* \w angustia|strong="H6862"\w*. \w Ruego|strong="H4994"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* \w caiga|strong="H5307"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* \w mano|strong="H3027"\w* \w de|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \w porque|strong="H3588"\w* sus \w misericordias|strong="H7356"\w* \w son|strong="H3588"\w* \w muy|strong="H3966"\w* \w grandes|strong="H7227"\w*, \w pero|strong="H3588"\w* \w que|strong="H3588"\w* \w no|strong="H3588"\w* \w caiga|strong="H5307"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* \w mano|strong="H3027"\w* del hombre.   
\p
\v 14 Así que \nd \+w Yavé|strong="H3068"\+w*\nd* envió una \w pestilencia|strong="H1698"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w*, y \w murieron|strong="H5307"\w* 70.000 hombres \w de|strong="H5414"\w* \w Israel|strong="H3478"\w*.   
\s1 La era de Ornán jebuseo  
\p
\v 15 \nd ʼElohim\nd* \w envió|strong="H7971"\w* \w al|strong="H5921"\w* \w Ángel|strong="H4397"\w* \w a|strong="H3068"\w* Jerusalén \w para|strong="H5921"\w* destruirla, pero cuando \w destruía|strong="H7843"\w*, \nd \+w Yavé|strong="H3068"\+w*\nd* \w miró|strong="H7200"\w* \w y|strong="H5921"\w* sintió pesar \w por|strong="H5921"\w* \w aquella|strong="H5921"\w* calamidad. Dijo \w al|strong="H5921"\w* \w Ángel|strong="H4397"\w* \w que|strong="H6258"\w* \w destruía|strong="H7843"\w*: \wj ¡\+w Basta|strong="H7227"\+w*! ¡\+w Detén|strong="H7503"\+w* tu \+w mano|strong="H3027"\+w*!\wj* \w Y|strong="H3068"\w* \w el|strong="H5921"\w* \w Ángel|strong="H4397"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w estaba|strong="H5975"\w* \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* era \w de|strong="H5921"\w* Ornán \w jebuseo|strong="H2983"\w*.   
\p
\v 16 \w Al|strong="H5921"\w* levantar \w David|strong="H1732"\w* sus \w ojos|strong="H5869"\w*, \w vio|strong="H7200"\w* \w al|strong="H5921"\w* \w Ángel|strong="H4397"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, quien \w estaba|strong="H5975"\w* \w entre|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w cielo|strong="H8064"\w*, \w con|strong="H5921"\w* una \w espada|strong="H2719"\w* desenvainada \w en|strong="H5921"\w* su \w mano|strong="H3027"\w*, \w extendida|strong="H5186"\w* \w sobre|strong="H5921"\w* Jerusalén. Entonces \w David|strong="H1732"\w* \w y|strong="H5921"\w* \w los|strong="H5921"\w* \w ancianos|strong="H2205"\w* \w se|strong="H5921"\w* postraron \w sobre|strong="H5921"\w* sus \w rostros|strong="H6440"\w*, \w cubiertos|strong="H3680"\w* \w de|strong="H5921"\w* tela áspera.   
\p
\v 17 \w David|strong="H1732"\w* dijo \w a|strong="H3068"\w* \nd ʼElohim\nd*: ¿\w No|strong="H3808"\w* \w soy|strong="H1961"\w* \w yo|strong="H4994"\w* \w quien|strong="H4100"\w* ordenó contar \w el|strong="H1931"\w* \w pueblo|strong="H5971"\w*? \w Yo|strong="H4994"\w* \w soy|strong="H1961"\w* \w quien|strong="H4100"\w* \w pecó|strong="H2398"\w* y ciertamente obré \w mal|strong="H7489"\w*. Pero \w estas|strong="H6213"\w* \w ovejas|strong="H6629"\w*, ¿\w qué|strong="H4100"\w* \w hicieron|strong="H6213"\w*? ¡\w Oh|strong="H4100"\w* \nd \+w Yavé|strong="H3068"\+w* ʼElohim\nd* \w mío|strong="H5971"\w*, levanta \w ahora|strong="H4994"\w* \w tu|strong="H6213"\w* \w mano|strong="H3027"\w* \w contra|strong="H1961"\w* \w mí|strong="H1961"\w* y \w contra|strong="H1961"\w* \w la|strong="H1931"\w* \w casa|strong="H1004"\w* \w de|strong="H5971"\w* \w mi|strong="H1961"\w* padre, pero \w no|strong="H3808"\w* llegue \w la|strong="H1931"\w* pestilencia \w sobre|strong="H1961"\w* \w tu|strong="H6213"\w* \w pueblo|strong="H5971"\w*!   
\p
