\id 2TH - Maya-Tektiteko NT -Guatemala 2003 (DBL -2013) 
\h Tkab'i' U'j Kye Aj Tesalonk 
\toc1 Te Tkab'i' U'j Stz'ib'en Pa'k Kye Qerman Aj Amaq' Tesalonk 
\toc2 Tkab'i' U'j Kye Aj Tesalonk 
\toc3 2Tes 
\mt1 Te Tkab'i' U'j Stz'ib'en Pa'k Kye Qerman Aj Amaq' Tesalonk 
\c 1  
\s1 Jun Limb'il 
\p  
\v 1 Wetz a'in Pa'k b'ix ajune' wuky'i'l te Silbáno b'ix te Timotey. Qetza nqet qtz'ib'a'na ja u'jni te etetz erman aj amaq' Tesalonk,\x * \xo 1:1 \xt Kya 17:1; 1Tes 1:1\x* etetz aj a'ix te Qtata Dios b'ix te Qajaw Jesukrist.  
\v 2 Qtata Dios b'ix te Qajaw Jesukrist tzaj ksi'xwit etajsik etetz jun nim b'an galan b'ix qetxwit kchewsa' ek'u'j. 
\s1 Jun Pixon Te Dios Kyi'j Kye Qerman Aj Tesalonk 
\p  
\v 3 Erman, tume'lkixi' qetza nxik qsi'na pixon te Qtata Dios eti'j etetz b'ajq'ij. Komo etetz b'ajq'ij mas n'ok wit'let ek'u'j ti'j te Qajawil b'ix mas nqet egani' etib' exolx b'ix kyuky'i txq'anky xjal.  
\v 4 Qetza b'an nqochalajna eti'j cha'oj qyolin eti'j etetz kxol kye txq'anky b'uch'uj qerman. Komo etetz b'an nim epasens b'ix b'an wit'lik ek'u'j byenech anke n'ok eten twitz xhcho'nal b'ix b'is, per ipa' etitza'. 
\s1 Te Qtata Dios Oxe'l Tsi' Te Junjun Iktza'x Ma'tx Kyk'uluj 
\p  
\v 5 [Erman waq,] tzan tpaj etetz nkx'ipan tuky'i nim epasens te xhcho'nal aj nky'ik eti'jni, ikxji telponx te Qtata Dios at tkawb'il tuj tq'ab' tzan txik tsi' jun etanq'in tuj ka'j tzan tpaj n'etajo', komo astilji nkx'ipan b'an b'an'ax jun nim xhcho'nal.  
\v 6 Per yatzun kye aj n'ok sin xhcho'nal eti'j, tume'l tzan txik tsi' te Qtata Dios xhcho'nal kyi'j.  
\v 7 B'ix yatzun etetz aj n'ok eten twitz xhcho'nal, te Qtata Dios okxtel tkolo', otk'ulu'tz tzan etojlan junx quky'ila cha'oj tul te Qajaw Jesukrist. Tetz otzajel tuj ka'j junx kyuky'i kye ángel aj nim kyajwalil,  
\v 8 tzul tuky'i toq q'aq' tzan txik tsi' jun xhcho'nal kyi'j kye aj k'onti'l kyotzqi' Qtata Dios, a'e' aj k'onti'l nqet kyoksla' te tpakb'alil galan ti'j Qajaw Jesukrist.  
\v 9 Kye aj xjalji owokel kyen jun xhcho'nal aj nlay tz'el kyi'j,\f + \fr 1:9 \ft Tuj ja taqanni, te yol “destruir” k'onti'l telponx tzan tpon tnajsa' b'eyx te jun-ele'x sinoke telponx tzan tok jun xhcho'onal ti'j b'eyx te jun-ele'x; Mat 13:41-42; 25:31-46; Mak 9:43-48; Wnch 5:28-29; Tmnk 14:9-11; 20:11-15; 21:8; 22:15.\f* okye'elax in b'eyx te jun-ele'x twitz Qajaw Jesukrist b'ix nlay tz'ok kyen te aj b'an tb'anil oj tkaj kyaqil tuj tq'ab' tuky'i jun tajwalil.  
\v 10 Ikxji oky'el tuj aj q'ij cha'oj tul tetz tzan tqet jiq'b'a' tzan kye aj pawame' titza', b'ix tzan kchalaj ti'j tetz kye aj nkye'okslan tetz. B'ix etetz, ax owokel eten tuj aj q'ijji tzan tpaj oxik etoksla' te tpakb'alil aj oxik qpakb'a'na exol. 
\s1 Titza' Nxnaq'tzan Tuq Te Pa'k Kyi'j Kye Aj Tesalonk 
\p  
\v 11 Tzan tpaj nini qetza k'onti'l nkaj qsi'na tzan qxnaq'tzan eti'j. Nqoxnaq'tzana tzan etel galan tuj twitz Qtata Dios b'ix nya'tx chagan okxtzaj tuk'le', b'ix nqoxnaq'tzana tzan tb'antik tuky'i jun tajwalil kyaqil aj egan k'ulun te tetz b'ix kyaqil aj nkxk'ulun tzan tpaj toklen wit'let ek'u'j ti'j.  
\v 12 Ikxji tzan tqet jiq'b'a' te Qajaw Jesukrist eti'j etetz, b'ix ax tzan eqet jiq'b'a' etetz ti'j tetz, tzan tpaj kyaqil aj nim b'an galan aj k'onti'l n'etajo' aj ntzaj si' etajsik tzan te Qtata Dios b'ix te Qajaw Jesukrist. 
\c 2  
\s1 Te Xjal Chimol Choj Tajq'oj Dios 
\p  
\v 1 Bwen, ajna'l waq erman, qetza qgana tzan txik jq'uma'na etetz titza' oj tul te Qajaw Jesukrist b'ix titza' oky'el oj qok xhchimo' tuky'i'l.\x * \xo 2:1 \xt 1Tes 4:15-17\x* 
\v 2 K'on etzoqpij tzan eqet eq'i' tzan nijunwt, k'on jaw eky'ixpu' titza' nkxb'isun etetz ti'j nini, b'ix k'on kxob' qa at jun tpakb'alil iktze'xtzun tzan te Txew Dios per nya'tx, qatzun ek'amo'tz jun u'j iktze'xtzun qtz'ib'ena qetza aj ja' nyolin ma'tx pon te q'ij tzan tul te Qajaw Jesukrist.  
\v 3 K'on kxqet moyi' tzan nijunwt ti'j titza' owulel te Qajawil. Tetz nlay tzul qa mina' tpon jun tyemp aj b'an ky'ila'j xjal okajel kykola' tzan kyokslan, b'ix qa mina' tuq tul te Chimol Choj Tajq'oj Qtata Dios, aj okaj si'kix tzan txik tuj te nim q'aq'.  
\v 4 Tetz oq'ojiyon ti'j kyaqil tidi'chq aj n'ok q'uma' dios tzan kye xjal, b'ix oqtel tjiq'b'a' tib' ti'j kyaqil nini b'ix ti'j kyaqil tidi'chq aj ntzaj kyna'o' kye xjal, b'ix tetz owokex wit'let tuj te Nin Jay Nab'il Qtata Dios b'ix otq'uma'tz a tetz Dios.\x * \xo 2:4 \xt Dan 11:36; Ezq 28:2\x* 
\v 5 ¿K'onti'l petzun na'ik etitza' aj txik nq'uma' etetz kyaqil ntzani aj akyinqet tuq exol tzi?  
\v 6 Etetz eteb'en tidi' k'onti'l ntzoqpin tetz ajna'l sinoke max oj tpon or tetz.  
\v 7 Oje tz'aq'ik te aj nya'tx galan aj k'onti'l n'el kyniky' kye xjal ti'j, cha a'ox at jun aj tzunx k'onti'l ntzoqpin tetz ajna'l, sinoke max oj tel in te aj tzyul tetz.  
\v 8 Ntons maxji owokel qen te Tajq'oj Qtata Dios, b'ix tetz owokel ten jun xhcho'nal aj ni nlay ponaj\f + \fr 2:8 \ft Intqet awe'e' te aj nyolin ti'j 1:9.\f* tzan tpaj cha'oj tul te Qajaw Jesukrist, tetz owokel tsi' te aj xhcho'nal ti'j cha tuky'i tyol aj oxe'l tq'uma' tuky'i tajwalil b'ix tzan tpaj te xhchqitz'unal.\x * \xo 2:8 \xt Isa 11:4\x* 
\v 9 Te Tajq'oj Qtata Dios aj tzulni, tetz cha lajo' tzan te Satanas, b'ix tzul tuky'i nim tajwalil b'ix oqtel tk'ulu' ti'chq yek'b'il aj at tidi' telponx b'ix tidi'chq aj okyelab'ayon kye xjal ti'j, per te aj oxe'l tyoli' nya'tx b'an'ax.\x * \xo 2:9 \xt Mat 24:24\x* 
\v 10 B'ix oqtel tk'ulu' tidi'chq nya'tx galan tzan kyqet teq'i' kye aj okyepoyonaj tzan tpaj k'onti'l oqet tuj kywitz tzan tqet kygani' te b'an'ax aj b'a'n tuq tzan tkolon kyi'j.  
\v 11 Astilji te Qtata Dios nstzoqpi' tzan kyqet eq'i' tzan te nya'tx galan b'ix tzan kyokslan ti'j te aj nya'tx b'an'ax.  
\v 12 Ikxji tzan kxik si' tuj il kyaqil kye aj k'onti'l nkye'okslan te b'an'ax sinoke cha echalaj ti'j te nya'tx galan. 
\p  
\v 13 Per yatzun eti'j etetz waq erman, qetza k'onti'lkix tzan tkaj qsi' tzan txik qsi'na pixon te Qtata Dios eti'j etetz aj ganimix nim tzan te Qajawil. Komo te Qtata Dios okx'el tjoyo' tzan etok etetz kye tb'ay tzan ekolet titza', b'ix okxkolet titza' tzan tpaj te Txew Dios owel tsjapunsa' ti'j etanim b'ix etetz owok ewit'b'a' ek'u'j ti'j te tpakb'alil b'an'ax.  
\v 14 Tzan tpaj ntzani te Qtata Dios okxtzaj tuk'le' txiklen qpakb'a'na te tpakb'alil ti'j te tume'l titza' nqokolet, b'ix oqet tk'ulu' ikxji tzan tok eten etetz te xhchqitz'unal Qajaw Jesukrist.  
\v 15 Astilji waq erman, pe'eten waq jwert b'ix k'on tz'aj enajsa' ti'j etanim te xnaq'tzb'ilj aj oxik qxnaq'tza'na etetz, aj oxik qyoli'na etetz qatzun aj oqet qtz'ib'a'na te etetzji.\x * \xo 2:15 \xt 1Kor 11:2\x* 
\p  
\v 16 Ntons [nkyinxnaq'tzan] tuky'i Qajaw Jesukrist b'ix tuky'i Qtata Dios aj nqoqet tgani' b'ix aj oje tzaj tnimsa' jk'u'j te jun-ele'x b'ix aj oje tzaj tsi' ja' tzan tkaj lo'et jk'u'j tzan tpaj nim b'an galan nab'lin anke k'onti'l nqajo';  
\v 17 [nkyinxnaq'tzan tuky'i'l tzan] tnimsan ek'u'j b'ix tzan kyk'ulun tzan tel galan kyaqil aj oxe'l eq'uma' b'ix kyaqil aj oqtel ek'ulu'. 
\c 3  
\s1 A Tgan Tzan Qxnaq'tzan Kyi'j Kye Aj Nkyepakb'an Tyol Qtata Dios Ja'chq 
\p  
\v 1 Ajna'l waq erman, ngan tzan txik nq'uma' etetz tzan exnaq'tzan ch'in qi'ja tzan txik pakb'let te tpakb'alil ti'j Qajaw Jesukrist tuj kyaqil amaq' b'ix tzan tqet kyjiq'b'a' iktza' oky'ik exol etetz.  
\v 2 B'ix pe'exnaq'tzan ch'in qi'ja tzan jkoletna tuj kyq'ab' kye xjal aj nya'tx galan kyenab'lin b'ix aj pur nya'tx galan nkyb'isu', komo nya'tx kyaqil xjal n'ok wit'let kyk'u'j ti'j Qtata Dios.  
\v 3 Per yatzun te Qtata Dios, tetz jun yolin b'ix otk'ulu'tz tzan eten jwert b'ix okxtkolo'tz ti'j kyaqil aj nya'tx galan.  
\v 4 Qetza wit'lik jk'u'j ti'j Qajawil etetz nlay kaj esi' tzan tqet ek'ulu' kyaqil aj ma'tx xik jq'uma'na etetzni.  
\v 5 Qajaw tz'onenxwit eti'j tzan kyqet egani' txq'anky iktza' te Qtata Dios nkyeqet tgani', b'ix tzan txik tsi' ebalor tzan etipan te xhcho'nal iktza'x te Krist otipaj te xhcho'nal. 
\s1 Nya'tx Galan Tzan Qok Ky'aj 
\p  
\v 6 Waq erman, qetza qgana tzan txik jq'uma'na etetz iktza' tky'ixel Qajaw Jesukrist a'o'na, tzan tel epawa' etib' kyi'j kye qerman aj k'on kygan aq'unan b'ix k'onti'l nkye'aq'unan iktza'x aj oxik qxnaq'tza'na etetz.  
\v 7 Etetz eteb'en titza' presis tzan tel etin qi'ja. Komo qetza k'onti'l ob'etna exol aj cha-wit nqoky'ajina,  
\v 8 b'ix k'onti'l oxik qwa'a'na jun qwe' tjay jun aj cha-wit jkotzijna, sinoke b'ajq'ij b'ix b'ajaq'b'il nqo'aq'unana tuq tzan k'on qokna cha te ek'a'chb'e'tz.\x * \xo 3:8 \xt Kya 18:3; 1Tes 2:9\x* 
\v 9 B'an'ax qetza at qoklena tzan txik jq'uma'na tuq etetz tzan qokna etone', per qetza o'aq'unana nim tzan tok eten tuq qi'ja titza' tuq nqo'aq'unan tzan tel etin tuq etetz ikxji.  
\v 10 Aj aqoqet tuq exol nxik jq'uma'na tuq etetz ikxjani. Ab'l aj k'on tgan aq'unan, ax k'onti'l tzan twa'an. 
\p  
\v 11 Per ajna'l qchab'enkyna, ate' junjun exol k'onti'l nkye'aq'unan, k'onti'l nkyek'ulun ch'inwt, cha n'ox ksamo'qet kyib' aj ja' k'onti'l kyoklen.  
\v 12 Qetza tuky'i tb'i Qajaw Jesukrist nxik jq'uma'na b'ix nkyexik jkawi'na kye aj xjal ikxji tzan kyaq'unan galan tzan kywa'an tuky'i kyaq'umb'enx.  
\v 13 B'ix etetz waq erman, k'on kxsiktik tzan ek'ulun te tume'l galan.\x * \xo 3:13 \xt Gal 6:9\x* 
\p  
\v 14 Qa at ab'l aj k'onti'l nqet toksla' aj nxik jq'uma'na tuj ja u'jni, intok esi' enab'l ti'j b'ix ya k'onky tz'ok ejunch'i' etib' tuky'i'l tzan tqet ky'ixwik ch'in.  
\v 15 Per k'on qet eten iktza' etajq'oj sinoke intxik ekawi' iktza'x jun eterman. 
\s1 Jun Kawb'il 
\p  
\v 16 Ntons Qtata Dios aj nchewsan jk'u'j, qet xhchewsa'xwit etetz ek'u'j b'ajq'ij ti'j kyaqil. Qajaw qet tenxwit etuky'i'l tzi. 
\p  
\v 17 Wetz a'in Pa'k nqet ntz'ib'a' ja limb'il etetzni tuky'i nq'ab'x b'ix ntz'ib'enx. Te ja ntzani telponx b'an'ax a'in nkyinxik saman ja u'jni. Ikxji wetz nqet ntz'ib'a' tuj kyaqil wu'uj aj nkyexik nsama'.  
\v 18 Qajaw Jesukrist tzaj sinxwit etajsik etetz tzi jun nim b'an galan.