\v 14 \w Con|strong="H5973"\w* \w los|strong="H5973"\w* \w reyes|strong="H4428"\w* y \w con|strong="H5973"\w* \w los|strong="H5973"\w* \w con|strong="H5973"\w*­sejeros \w de|strong="H5973"\w* la tierra, que \w edifican|strong="H1129"\w* \w para|strong="H5973"\w* sí \w los|strong="H5973"\w* desiertos;
