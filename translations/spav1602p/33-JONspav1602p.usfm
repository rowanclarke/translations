\v 2 \w Levántate|strong="H6965"\w*, \w y|strong="H3588"\w* \w ve|strong="H3212"\w* \w a|strong="H3068"\w* \w Nínive|strong="H5210"\w*, ciu­dad \w grande|strong="H1419"\w*, \w y|strong="H3588"\w* \w pregona|strong="H7121"\w* \w contra|strong="H5921"\w* \w ella|strong="H5921"\w*; \w porque|strong="H3588"\w* \w su|strong="H3588"\w* \w maldad|strong="H7451"\w* ha \w subido|strong="H5927"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w mí|strong="H5921"\w*.   
