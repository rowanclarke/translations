\c 29  
\p
\v 1  \w The|strong="H3605"\w* \w prophet|strong="H5030"\w* \w Jeremiah|strong="H3414"\w* \w sent|strong="H7971"\w* \w a|strong="H3068"\w* \w letter|strong="H5612"\w* \w to|strong="H7971"\w* \w the|strong="H3605"\w* \w exiles|strong="H1473"\w* \w Nebuchadnezzar|strong="H5019"\w* \w had|strong="H3548"\w* \w carried|strong="H1540"\w* \w off|strong="H7971"\w* \w from|strong="H7971"\w* \w Jerusalem|strong="H3389"\w* \w to|strong="H7971"\w* Babylon. \w It|strong="H7971"\w* \w was|strong="H1697"\w* addressed \w to|strong="H7971"\w* \w the|strong="H3605"\w* \w elders|strong="H2205"\w* \w who|strong="H3605"\w* \w were|strong="H5971"\w* \w left|strong="H3499"\w* \w among|strong="H5971"\w* \w the|strong="H3605"\w* \w exiles|strong="H1473"\w*, \w to|strong="H7971"\w* \w the|strong="H3605"\w* \w priests|strong="H3548"\w*, \w to|strong="H7971"\w* \w the|strong="H3605"\w* \w prophets|strong="H5030"\w*, \w and|strong="H7971"\w* \w to|strong="H7971"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w other|strong="H3605"\w* \w people|strong="H5971"\w* \w who|strong="H3605"\w* \w were|strong="H5971"\w* \w exiled|strong="H1540"\w* \w in|strong="H1697"\w* Babylon.  
