\id JOS - Tarok 
\h AJoshuwa 
\toc3 AJosh 
\toc2 AJoshuwa 
\toc1 Nlir AJoshuwa 
\mt1 Nlir AJoshuwa 
\c 1  
\s1 Inan kyer uJoshuwa yà unəm uga mpyal 
\p  
\v 1 Kà̱ nva̱ng ikú aMusa uzwal aYawe te, uYawe là nnap ká̱ uJoshuwa uya aNun ununggwan, uva i ka̱mshi ûMusa.  
\v 2 Uza̱ là a na pa̱, <<Uzwal mi uMusa kú chit. Ǹyangmata̱ te, mmaɓu ká̱ nkpaktak onəm a ta̱, o gbar izər na o pa̱ng Awang aUrdun na o ga ashe mbin va̱ mmami ka̱ ngga na wó, oIsa̱rila.  
\v 3 Nkpaktak atak va̱ ashe ashar wó i tongchi te, mi na wó, wa nva ka̱ n yar nsar nnap-nlà ûMusa á.  
\v 4 Aswari wó i ɓan ka̱ nzam mmaləng i ga aLebanon, kang i ɓan ka̱ awang achumchum, awang aYufriti, ká̱ nkpaktak mbin oHiti, i ga i chu ìWa aMeditereniya ka̱ asa̱l ntar alum.  
\v 5 Unəm uro i kur nnəm igwan ka̱ apal ishi ɓu ka̱t, ka̱ ashe nkpaktak nra irirì ɓu. Wa nva ka̱ n yà nzəng ká̱ uMusa te, wa nnà ta kpa mi yà nzəng ká̱ ɓu. Mi yà ka̱ mmandar ɓu, ka̱t te mi re ɓu ka̱t.  
\v 6 Sat pa̱ kakkərak, nəm nkam igwak, ka̱kul ɓu ga nləp mpyal onəm va̱ ta̱, na á ka̱m mbin va̱ ka̱ n sóng anung ôkəka oza̱ pa̱ mi na ôza̱ á. 
\p  
\v 7 <<Sat pa̱ kakkərak, nəm nkam igwak pa̱ gənggəng. Nəm pa̱ dakdak na u kpak nkpaktak nnap-mpakpak va̱ uzwal mi uMusa nak a ɓu. Kang wa ga̱ɓa̱n nri ka̱t te mpəra̱m ka̱ pəpal ka̱t, na u nəm igwan nkpaktak atak va̱ ɓu ga kà̱.  
\v 8 Kang nlir ngga nnap-mpakpak va̱ ta̱ a kap ka̱ anung ɓu ka̱t. Rəng nnap ka̱ pəpal ìzwam ka̱ alum pa̱ ɗəkər, na u nəm nkpaktak iya̱m va̱ mmá lir ka̱ ashishe. Nna chit te, ɓu ya ngga mpyal ká̱ igwan pa̱ makmak.  
\v 9 Rəng, ka̱ n nak ɓu chit pa̱ u sat pa̱ kakkərak, u nəm nkam igwak. Kang ayər a nəm ɓu ka̱t, kang izər a rusok ka̱ ɓu ka̱t, ka̱kul uYawe Inan ɓu i yà nzəng ká̱ ɓu kà̱ nkpaktak atak va̱ ɓu ga kà̱.>> 
\p  
\v 10 Te uJoshuwa nak onəm oga mpyal onəm pa̱,  
\v 11 <<A ga ashe apa̱k, na a là ônəm pa̱, <Ó ɗa̱mshi iya̱m-nrì wó ka̱kul ka̱ nva̱ng nra pa̱ nshatɗing te, ó ga mpa̱ng awang aUrdun, na ó ka̱m mbin va̱ uYawe Inan wó ka̱ nna a wó.> >> 
\p  
\v 12 Ǹnyi te, uJoshuwa là âkum ìjili aRuben, ká̱ uGat ká̱ nkap kà̱ ishimshe akum ìjili aManase pa̱,  
\v 13 <<Ó rəng nnap-nlà aMusa uzwal aYawe va̱ nak a wó, ka̱ là pa̱, <UYawe Inan wó i ga nna njul a wó ka̱ atak nna mbin va̱ ta̱ a wó.>  
\v 14 Ochar wó, ká̱ ovan wó, ká̱ oga iya̱mkang wó, i təm ka̱ ashe mbin va uMusa na wó chit ka̱ asa̱l nfa alum Awang aUrdun á, ǹnyi te, nkpaktak onəm oga nyi ashar ìkum wó okamkam va̱ gbar izər ikum te, nkpak oza̱ i pa̱ng mpyal ogənang oza̱ na oza̱ a ka̱mshi ôza̱ ka̱ atak ikum.  
\v 15 Oza̱ i ka̱m ishi oza̱ i ga i chu awalang va̱ uYawe i na njul ogənang oza̱, wa nva̱ uza̱ ka̱ nəm a wó, kang oza̱ i ka̱m mbin va̱ nji oza̱ kpa, nva uYawe Inan wó ka̱ nna oza̱. Nna chit te, ó le ó ga ó təm ka̱ mbin wó va̱ uMusa uzwal aYawe ka̱ na wó ka̱ gwong Awang aUrdun va̱ dər asa̱l nfa alum.>> 
\p  
\v 16 Te oza̱ na ama̱n ûJoshuwa pa̱, << Iya̱m va pa̱ kap u nak á yi te, i nənəm. Atak va pa̱ kap ɓu re yi kà̱ te, i gəga.  
\v 17 Wa nva i kpak nnap nnəm uMusa te, wa nnà ta i kpak a ɓu kpa. Ǹnyi te, re uYawe Inan ɓu a ya nzəng ka̱ ɓu, wa nva uza̱ ka̱ ya nzəng ká̱ uMusa á.  
\v 18 Unəm va pa̱ kap fa iya̱mkak ka̱ nnap-nlà ngga anung ɓu kang a yang ka̱ nkpak nkpaktak iya̱m va̱ u nak oza̱ pa̱ a nəm te, mí gba̱l na. Ǹnyi te, sat pa̱ kakkərak, igwak á kam a ɓu.>> 
\c 2  
\s1 UJoshuwa re nre ká̱ onəm oga nsòng mbin ga aJariko 
\p  
\v 1 UJoshuwa uya aNun re nre ká̱ onəm oga nsòng mbin ká̱ ayi pa̱ oparəm ka̱ aShitim. Uza̱ là ôza̱ pa̱, <<Ó ga na ó sòng mbin va̱ ta jwakjwak aJariko.>> Te oza̱ ga tar ashe nzhi achar umaimai uro, aɗiɗin pa̱ uRahap, kang oza̱ ra ka̱ ta. 
\p  
\v 2 Te mma là ûponzhi uga aJariko pa̱, <<Dər, onəm oga aIsa̱rila oro mma táng ka̱ ashe ìtong va̱ ta̱ ka̱ ìzwam pa̱ na ó sòng mbin va̱ ta̱.>>  
\v 3 Te uponzhi uga aJariko re nre ga atak aRahap pa̱, <<Fa ká̱ onungwan va̱ ɓa atak ɓu kang oza̱ táng nzhi ɓu, ka̱kul oza̱ ɓa nsòng nkpaktak mbin yi.>> 
\p  
\v 4 Ǹnyi te, uchar va̱ ta ka̱ bwam onunggwan oga oparəm va̱ ta chit. Uza̱ là pa̱, <<À, onunggwan va̱ ta ɓa atak mi ɓa, ǹnyi te, n nyi atak va̱ oza̱ fa kà̱ ka̱t.  
\v 5 Kang mí kùk anung asa̱l ìtong ká̱ anung arurong te, onunggwan va̱ ta fa chit. N nyi asa̱l va̱ oza̱ wòl kà̱ ka̱t. Ó ga ká̱ nggha̱n ka̱ nva̱ng oza̱, mwote, ó ɓan oza̱ nggo.>>  
\v 6 Ǹnyi te, uza̱ ka̱ ga ká̱ oza̱ chit ka̱ apal nzhi, uza̱ bwam oza̱ ka̱ akum akun ǹsàmsam va uza̱ ka̱ nak ka̱ ta.  
\v 7 Te onunggwan va̱ ta fa wa nva̱ng onəm oga nsòng mbin, i mwo oza̱ ga chu asa̱l aga mpa̱l Awang aUrdun. Ká̱ nfa onəm va̱ ta byet te, mma kùk anung asa̱l. 
\p  
\v 8 Kang onəm oga nsòng mbin va̱ ta ì ra nda te, uRahap ga ka̱ atak oza̱ ka̱ apal nzhi va̱ ta,  
\v 9 uza̱ là oza̱ pa̱, <<N nyinyi pa̱ uYawe na mbin va̱ ta̱ a wo chit, kang ayər wó nəm yi chit, nkpaktak onəm ka̱ ashe mbin va̱ ta̱ ìchəgwak la̱p oza̱ pa gənggəng ka̱kul wó.  
\v 10 I fe iya̱m va̱ chit uYawe nəm, á nak ndəng ngga ìWa Isəksək wom ka̱kul wó awalang va̱ ó fa ka̱ aMasar á, ká̱ nkpaktak iya̱m va̱ ó nəm ûSihon ká̱ uOk, oponzhi oga oparəm oga aAmori ova ka̱ asa̱l nfa alum aUrdun, ova ó zhì oza̱ pa̱ kpaktak.  
\v 11 Awalang va̱ í fe te, ìchəgwak la̱p yi, ayər nəm yi ka̱kul wó kang unəm uro ka̱ ashe yi yà ká̱ nkam igwak lap ka̱t. Ka̱kul uYawe Inan wó, uza̱ Inan ka̱ apaɓur ká̱ apambin. 
\p  
\v 12 <<Ǹyangmata̱ te, ó sóng anung á mi ka̱ ashe aɗin aYawe pa̱, wa nva n nəm ikin a wó te, wa nnà ta kpa, ó nəm n̂zhi apo mi. Ó nyám ìpir nnàp á mi va̱ i nak mi na nnandər ká̱ wó,  
\v 13 pa̱ ó re upo mi, ká̱ unang mi, ká̱ ogənang mi onunggwan, ká̱ ogənang mi ochar ká̱ irirì, ká̱ nkpaktak onəm va̱ oji oza̱. Kang ó re yi i kú ka̱t.>> 
\p  
\v 14 Te onəm va̱ ta là ûRahap pa̱, <<Irirì yi ka̱ anung irirì ɓu, a yà pa̱ u fa ká̱ ìjili yi kà̱ nnap va̱ ta̱ ka̱t, te i nəm iya̱m inəna̱n a ɓu ká̱ nnandər awalang va̱ uYawe á na mbin va̱ ta̱ á yi chit á.>> 
\p  
\v 15 Nna chit te, uRahap fər ká̱ oza̱ ká̱ asang ka̱ mɓol ayir nzhi, ka̱kul mmá me nzhizhi ka̱ izər akamsəlang ìtong.  
\v 16 Te uza̱ là ôza̱ pa̱, <<Ó ga ka̱ ashe oga aɗuktum le kang onəm oga ngwa nva̱ng wó a ya wó ka̱t. Ó bwam ka̱ ta nra pa̱ nshatɗing, nva̱ngva̱ onəm oga ngwa nva̱ng wó a le chit, te ó kpán asa̱l wó ɗak.>> 
\p  
\v 17 Te onəm va̱ ta là ûRahap pa̱, <<Nsóng anung va̱ u nak yi i sóng te, i təm wa nnà ta.  
\v 18 Iya̱m va ta̱ ɓu nəm awalang va̱ i táng ashe mbin va̱ ta̱. Te wa ran afini arəzang va̱ ta̱ ka̱ mɓol ayir nzhi va̱ u re yi i fəng kà̱. Wa ɓa ká̱ upo ɓu, ká̱ unang ɓu, ká̱ ogənang ɓu onunggwan, ká̱ nkpaktak nzhi oza̱ ka̱ nzhi ɓu.  
\v 19 A yà pa̱ unəm uro a fa agbai anung nzhi ɓu te, nchə̀r oza̱ i təm ka̱ apal ishishi, í yà ká̱ mpat ka̱t. Ǹnyi te, a yà pa̱ mma nak awo ûnəm uro uva uwa yà nzəng ka̱ ɓu ka̱ ashe nzhi te, nchə̀r oza̱ i təm ka̱ apal ishi yi.  
\v 20 Ǹnyi te, a yà pa̱ u là ûnəm uro iya̱m va̱ ɓa ká̱ yi, te nsóng anung va̱ u nak yi i sóng te, i kpán yi ka̱t.>> 
\p  
\v 21 URahap na ama̱n pa̱, <<Re á təm wa nva ó là.>> 
\p Te uza̱ re oza̱, kang oza̱ kpán asa̱l ga. Kà̱ nva̱ngva̱ oza̱ ga chit, te uza̱ ran afini arəzang ka̱ mɓol ayir nzhi va̱. 
\p  
\v 22 Awalang va̱ oza̱ fa te, oza̱ ga ashe oga aɗuktum kang oza̱ təm ka̱ ta nra pa̱ nshatɗing, ga chu awalang va̱ onəm oga ngwa nva̱ng mwo oga atak pa̱ kpaktak ka̱ apal asa̱l, kang oza̱ ya oza̱ ka̱t, oza̱ le pa.  
\v 23 Te onunggwan oga oparəm va̱ ta̱ fəng ka̱ apal oga aɗuktum, pa̱ng awang le ga atak aJoshuwa uya aNun ununggwan, kang oza̱ là á na nkpaktak iya̱m va̱ ya oza̱. 
\p  
\v 24 Oza̱ là ûJoshuwa pa̱, <<Nnandər, uYawe na nkpaktak mbin va̱ ta chit, ka̱ ashe awo yi. Nkpaktak onəm oga mbin va̱ ta ka̱ ntán ká̱ ayər ka̱kul yi.>> 
\c 3  
\s1 OIsa̱rila pa̱ng Awang aUrdun 
\p  
\v 1 Ìpin fa kpa̱k ká̱ iɓotak te, uJoshuwa ká̱ nkpaktak oIsa̱rila wong achen ka̱ aShitim kang oza̱ ga aUrdun, ka̱ ta na oza̱ ra apa̱k kang oza̱ wong pa̱ng awang va̱ ta.  
\v 2 Ka̱ nva̱ng nra pa̱ nshatɗing te, onəm oga mpyal onəm ga ashe nkpaktak apa̱k,  
\v 3 kang oza̱ nak onəm pa̱, << Awalang va̱ ó ya akwati aga nsar nnap-nlà aYawe Inan wó kang onəm oga mpyal awop oLawi á yar te, ó wong ka̱ atak va̱ mmawó kà̱, ó yar nvəva̱ng.  
\v 4 Ó re ishimshe wó a gbəgba̱ng ká̱ akwati aga nsar nnap-nlà va̱ ta, ngbəgba̱ng a yà ashar ìkalong pa̱ ishatɗing. Kang ó ɓa datkulung ká̱ ka̱t, te i nak ó nyi asa̱l va̱ ó ga ngwol kà̱, ka̱kul pa̱ nna ka̱ ó wòl asa̱l ata̱ chit ka̱t.>> 
\p  
\v 5 Te uJoshuwa là ônəm pa̱, <<Ó gar ishi wó ka̱kul ìpin te, uYawe i ga nnəm iya̱m iga nnəm ayər ká̱ ishimshe wó.>> 
\p  
\v 6 Kang uJoshuwa là ônəm oga mpyal awop pa̱, <<Ó yar akwati aga nsar nnap-nlà na ó lyam ká̱ ka̱ mpyal onəm.>> Te oza̱ yar akwati aga nsar nnap-nlà va̱ ta, oza̱ lyam ká̱ ka̱ mpyal onəm. 
\p  
\v 7 Te uYawe là ûJoshuwa pa̱, <<Ka̱ nda va̱ ta̱ mi ga nrup ká̱ ɓu ka̱ mpyal nkpaktak oIsa̱rila, ka̱kul na oza̱ á nyi pa̱, wa nva ka̱ n yà nzəng ká̱ uMusa te, wa nnà ta kpa, mi yà nzəng ká̱ ɓu.  
\v 8 Nak onəm oga mpyal awop ova̱ yar akwati aga nsar nnap-nlà pa̱, <Awalang va̱ ó táng ka̱ arwangchwang ndəng aUrdun te, ó tong pa̱ kwák ka̱ ta.> >> 
\p  
\v 9 Te uJoshuwa là ôIsa̱rila pa̱, <<Ó ɓa datkulung na ó fe nnap-nlà aYawe Inan wó.  
\v 10 Wa nnà ta̱ ó nyi ɗak pa̱, Inan iga irirì wa ká̱ ìshimshe wó, te i mai ka̱t uza̱ i ga mɓak oKanana, ká̱ oHiti, ká̱ oHivi, ká̱ oPerizi, ká̱ oGirgashi, ká̱ oAmori, ká̱ oJebusi i le ka̱ mpyal wó.  
\v 11 Dər, akwati aga nsar nnap-nlà Inan uga nkpaktak apambin ka̱ nlyam ka̱ mpyal wó ka̱ ashe awang aUrdun.  
\v 12 Ǹyangmata̱ te, yak onunggwan pa̱ ogba̱pchi ama̱n pa̱ aparəm ka̱ ashe akum ìjili oIsa̱rila. Unəm pa̱ uzəng ka̱ ashe nza̱ akum ìjili nggo.  
\v 13 Kang awalang va̱ ndong ashar onəm oga mpyal awop ova̱ yar akwati aga nsar nnap-nlà aYawe, unəm uga nzhi nkpaktak apambin, á táng ka̱ ashe ndəng aUrdun te, ndəng aUrdun va̱ ta i gəl. Kang ndəng va̱ ka̱ yà ka̱ nnang te, i ɓut ka̱ atak pa̱ zəng.>> 
\p  
\v 14 Kang awalang va̱ onəm fa ka̱ ashe oga aghal pa̱ na ó pa̱ng Awang aUrdun te, onəm oga mpyal awop va̱ yar akwati aga nsar nnap-nlà ləp mpyal ôza̱.  
\v 15 Ka̱ awalang aga mɓən iya̱m na ndəng i yəl Awang aUrdun ká̱. Awalang va̱ onəm oga mpyal awop chu arwangchwang ndəng kang á táng ka̱ ashishe te,  
\v 16 ndəng va̱ ta re nnang. Ndəng va̱ ta ɓut atak pa̱ zəng nəm aɗuktum, gba̱ng ká̱ awang, ka̱ ìtong va mi wor pa̱ aAdam dat ká̱ aZaretan. Ndəng va̱ ta re nnang ngga ka̱ ashe ìWa Mman. Ǹna chit te, onəm pa̱ng awang va̱ dat ká̱ aJariko.  
\v 17 Te onəm oga mpyal awop va̱ yar akwati aga nsar nnap-nlà aYawe tong ka̱ mbin ngwomwom ka̱ ishimshe Awang aUrdun va̱ ta. Kang nkpaktak oIsa̱rila pa̱ng ka̱ mbin ngwomwom ga chu awalang va̱ nkpaktak onəm pa̱ng aUrdun ká̱ á. 
\c 4  
\s1 Mmá nak ipang ka̱kul nrəng 
\p  
\v 1 Ka̱ nva̱ngva̱ nkpaktak onəm pa̱ng aUrdun chit kur te, uYawe là ûJoshuwa pa̱,  
\v 2 <<Yak onunggwan pa̱ ogba̱pchi ama̱n pa̱ aparəm, yar pa̱ uzəng ka̱ ashe nza̱ akum ìjili nggo,  
\v 3 te là ôza̱ pa̱, ó wur ipáng pa̱ igba̱pchi ama̱n pa̱ aparəm ká̱ ishimshe aUrdun va̱ ta̱, dakdak ka̱ atak va̱ onəm oga mpyal awop tong kà̱, te oza̱ á ɓa ka̱ ipáng va̱ ta á nak ka̱ atak va̱ ó ga nra ka̱ nda ta̱.>> 
\p  
\v 4 Te uJoshuwa wór onunggwan oga ogba̱pchi ama̱n pa̱ aparəm va̱ uza̱ yak, unəm pa̱ uzəng ka̱ ashe nza̱ akum ìjili nggo.  
\v 5 Kang uza̱ là ôza̱ pa̱, <<Ó lyam ka̱ mpyal akwati aYawe Inan wó, ó ga ishimshe aUrdun, kang nza̱ uzəngtəng wó nggo á yar ìpang ka̱ agar wò, kà̱ iyil akum ìjili oIsa̱rila.  
\v 6 Nna ta i yà iya̱m iga ǹnyám ìpir nnàp ka̱ ashe wó. Ka̱ ilum iga mɓa, awalang va̱ ovan wó i ɓəp wó pa̱ iza̱ ipir ipáng va̱ ta̱ ka̱ atak wó yà?  
\v 7 Te ó là ôza̱ pa̱, ka̱kul pa̱ mmá gəl ndəng Awang aUrdun kà̱ nnang ka̱ awalang va̱ onəm oga mpyal awop yar akwati aga nsar nnap-nlà aYawe pa̱ng aUrdun ká̱. Ipáng va̱ ta̱ te, i sat iya̱m iga nrəng ká̱ oIsa̱rila mbyet.>> 
\p  
\v 8 Te onəm oIsa̱rila nəm wa nva uJoshuwa nak oza̱. Oza̱ wur ipáng pa̱ igba̱pchi ama̱n pa̱ parəm ka̱ ishimshe aUrdun. A mal ka̱ iyil akum ìjili oIsa̱rila, wa nva uYawe là ûJoshuwa. Kang oza̱ wur pa̱ng ká̱, ga ká̱ ka̱ atak va̱ oza̱ ra kà̱, te oza̱ nak ka̱ ta.  
\v 9 Te uJoshuwa dàt ipáng iga igba̱pchi ama̱n pa̱ parəm va̱ ta ka̱ ishimshe aUrdun, ka̱ atak va̱ ashar onəm oga mpyal awop va̱ yar akwati aga nsar nnap-nlà tong kà̱. Kang nna yà ka̱ ta ɓa chu nda va̱ ta̱. 
\p  
\v 10 Onəm oga mpyal awop va̱ yar akwati aga nsar nnap-nlà, tong ka̱ ishimshe aUrdun, a ga chu awalang va̱ mmá gba̱l ka̱ nkpaktak iya̱m va̱ uYawe nak uJoshuwa pa̱ á là ônəm, wa nva̱ uMusa nak uJoshuwa. Te onəm wong ka̱ ashe ǹngha̱n pa̱ng aUrdun,  
\v 11 ka̱ nva̱ngva̱ nkpaktak onəm gba̱l ka̱ mpa̱ng awang chit te, akwati aYawe ká̱ onəm oga mpyal awop lyam ka̱ mpyal onəm.  
\v 12 Onəm oga nlung ìkum ka̱ akum ìjili aRuben, ká̱ akum ìjili aGat, ká̱ nkap ishimshe akum ìjili aManase gbar izər ìkum pa̱ng ka̱ mpyal oIsa̱rila, wa nva uMusa là ôza̱.  
\v 13 Onəm oga nlung ìkum chu ìkalong chu ìsəm pa̱ ineɗing ova̱ pa̱ng ka̱ mpyal akwati aga nsar nnap-nlà aYawe pa̱ ó lung ìkum ka̱ ashe agbagba aJariko.  
\v 14 Ka̱ nda va̱ ta te, uYawe rup ká̱ uJoshuwa ka̱ mpyal nkpaktak oIsa̱rila. Kang oza̱ na ichumchum a na mbyet, wa nva oza̱ ka̱ na ûMusa ka̱ ashe nkpaktak nra irirìriri á. 
\p  
\v 15 Te uYawe là ûJoshuwa pa̱,  
\v 16 <<Nak onəm oga mpyal awop, ova yar akwati aga nsar nnap-nlà pa̱, oza̱ á fa ka̱ ashe aUrdun.>> 
\p  
\v 17 Te uJoshuwa nak onəm oga mpyal awop pa̱, <<Ó fa ka̱ ashe aUrdun.>> 
\p  
\v 18 Kang awalang va̱ onəm oga mpyal awop va̱ yar akwati aga nsar nnap-nlà aYawe fa ká̱ ishimshe aUrdun te, oza̱ chen ka̱ mbin ngwomwom. Kang ndəng aUrdun le nang yəl awang wa nva̱ ka̱ yà á. 
\p  
\v 19 Onəm fa ka̱ ashe aUrdun ka̱ nra ngga ngba̱pchi ngga ape aga nggəshi, te oza̱ la̱p apa̱k ka̱ aGilgal ka̱ asa̱l nfa alum aswari aJariko.  
\v 20 Kang ipáng iga igba̱pchi ama̱n pa̱ parəm va̱ oza̱ ka̱ wur ka̱ ashe aUrdun te, uJoshuwa dàt ka̱ aGilgal.  
\v 21 Te uza̱ là ôIsa̱rila pa̱, <<A yà pa̱ ka̱ ashe nra ngga mɓa, kang ovan wó a ɓəp opo oza̱ pa̱, <Iza̱ ipir ipáng va̱ ta̱ yà?>  
\v 22 Te ó là ôza̱ pa̱, <OIsa̱rila pa̱ng aUrdun kà̱ mbin ngwomwom.>  
\v 23 Ka̱kul uYawe Inan wó nak ndəng ngga aUrdun wom ka̱kul wó, a ga chu awalang va̱ ó pa̱ng, wa nva uYawe Inan wó nak Ìwa Isəksək wom ka̱kul wó a ga chu awalang va̱ i pa̱ng ka̱ á.  
\v 24 Uza̱ nəm i va̱ ta̱ ka̱kul pa̱ na nkpaktak onəm oga apambin á nyi pa̱ ichumchum nna ka̱ awo aYawe, na ó nəm ayər aYawe Inan wó mbyet.>> 
\c 5  
\p  
\v 1 Awalang va̱ nkpaktak oponzhi oAmori ovəngva̱ ka̱ asa̱l ntar alum aUrdun, ká̱ nkpaktak oponzhi oKanana va̱ ka̱ anung ìwa fe chit pa̱, uYawe nak ndəng Awang aUrdun wom ka̱kul oIsa̱rila, a ga chu awalang va̱ oza̱ pa̱ng ká̱ te, ìchəgwak la̱p oza̱ kang ayər nəm oza̱ ka̱kul oIsa̱rila. 
\s1 Mpà ache ka̱ aGilgal 
\p  
\v 2 Ka̱ awalang va̱ ta te, uYawe là ûJoshuwa pa̱, <<Nəm ikpal iga ipáng na ú pà ache ôIsa̱rila onunggwan ká̱ kà̱ɗi\f + \fr 5.2 \fq kà̱ɗi \ft A yar onəm va̱ mma ka̱ pà ache ôza̱ chit kang ka̱t.\f*.>> 
\p  
\v 3 Te uJoshuwa nəm ikpal iga ipáng kang uza̱ pà ache ôIsa̱rila ka̱ Gibiyat Haralot.  
\v 4 Iya̱m va̱ nak kang uJoshuwa pà ache oza̱ te, ka̱kul pa̱ nkpaktak onunggwan ká̱ onunggwan oga nlung ìkum va̱ fa ka̱ ashe aMasar te, a kú chit pa̱ kpaktak ka̱ ashe nzam.  
\v 5 Nkpaktak onəm va̱ fa ka̱ ashe aMasar te, mmá pà ache pà oza̱, ǹnyi te, ovəngva̱ mmá mar ya oma ka̱ yà ka̱ apal asa̱l ka̱ ashe nzam te, mmá pà ache ôza̱ ka̱t.  
\v 6 Ka̱kul onəm oIsa̱rila nəm ìzun ìsəm pa̱ ineɗing oma ka̱ nchèn ka̱ ashe nzam, a ga chu awalang va̱ nkpaktak onəm ká̱ onunggwan oga nlung ìkum va̱ fa ka̱ ashe aMasar á zhì, ka̱kul pa̱ oza̱ fe ichu aYawe ka̱t. Te uYawe sóng anung ôza̱ chit pa̱, oza̱ i yà ka̱ ya mbin va̱ ò yar nsar nnap-nlà okəka oza̱ pa̱ ò na oza̱ ka̱t. Mbin va mbyal ká̱ irizhe i nang ka̱ ashishe\x - \xo 5.6 \xt Nfa 3.8, 17; 13.5; 33.3; aLev 20.24; Nkung 16.14\x*.  
\v 7 Ovan oza̱ va̱ uYawe nak ka̱ anung oza̱ te, oma uJoshuwa pà ache ôza̱. Ka̱kul pa̱ mmá mar oza̱ ka̱ apal asa̱l, te nna mmá ka̱ pà ache ôza̱ chit ka̱t.  
\v 8 Ka̱ nva̱ngva̱ mmá gba̱l ka̱ mpà ache ônunggwan va̱ ta chit pa̱ kpaktak te, oza̱ təm ka̱ atak oza̱ ka̱ ashe apa̱k a ga chu awalang va̱ oza̱ tàn kang. 
\p  
\v 9 Te uYawe là ûJoshuwa pa̱, <<Nda ta̱ n tutur mpwat oga aMasar le a wó chit ka̱ ishi.>> Ka̱kul nva̱ ta te, nda ta̱ aɗin atak va̱ ta nna mmá kà̱ nwór pa̱ aGilgal. 
\p  
\v 10 Nva̱ onəm oIsa̱rila la̱p apa̱k ka̱ aGilgal te, oza̱ ri iya̱m-nrì iga nrəng ka̱ ilum Nggantal kà̱ nra ngga ngba̱pchi ama̱n pa̱ neɗing ngga ape va̱ ta ká̱ arurong ka̱ agbagba aJariko.  
\v 11 Ìpin fa kpa̱k ka̱ nva̱ng ilum Nggantal te, ka̱ nda va̱ ta oza̱ ri iya̱m-nrì iga ashe mbin va̱ ta, nzəngkəng va yà ká̱ anyer ka̱t ká̱ ìpirkur iforfor.  
\v 12 Ká̱ nda va̱ oza̱ ri iya̱m-nrì iga mbin va̱ ta kang ìpin fa kpa̱k te, aMana gəl. OIsa̱rila ya aMana a ta lap ka̱t, te oza̱ ɓan nrì iya̱m-nrì iga mbin aKanana kà̱ ìzun va ta. 
\s1 UJoshuwa ká̱ unəm uga nkpán ndokchi 
\p  
\v 13 Ka̱ awalang va̱ uJoshuwa ɓa dat ká̱ aJariko te, uza̱ wong ká̱ iwu wò dər te, uza̱ ya unəm sat ka̱ mpyal wò, á tur ndokchi ka̱ awo. Te uJoshuwa ga atətak á ɓəp na pa̱, <<Mmaɓu uji yi, ka̱t te mmaɓu ukpa ìkum yi ɗò?>> 
\p  
\v 14 Te unəm va̱ ta na a ma̱n pa̱, <<Mmami uji wó ka̱t, kang mmami ukpa ikum wo ka̱t kpa. Ǹnyi te, mmami unəm uga mpyal ìkum aYawe. Kang ǹyangmata̱ na m ɓa.>> Te uJoshuwa ru zəp ka̱ afu ka̱ mbin á na ichumchum á na, kang uza̱ ɓəp na pa̱, <<Iza̱ u ɗom pa̱ uzwal ɓu a nəm yà? ANəm uga nzhi mi.>> 
\p  
\v 15 Te unəm uga mpyal ìkum aYawe là ûJoshuwa pa̱, <<Zəp akwap va̱ ka̱ ashar ɓu, ka̱kul atak va̱ mmaɓu ka̱ nsat ka̱ ta te, atak ayə́ryər.>> Te wa nnà ta uJoshuwa nəm. 
\c 6  
\s1 Mmá ri aJariko ká̱ ìkum 
\p  
\v 1 Mmá kùk anung asa̱l aJariko ashe ká̱ agbai ka̱kul onəm oIsa̱rila. Unəm uro yà ká̱ nfa ka̱t, kang unəm uro yà ká̱ ntar ka̱t. 
\p  
\v 2 Te uYawe là ûJoshuwa pa̱, <<Dər, n na aJariko chit ka̱ ashe awo ɓu, ká̱ uponzhiponzhi, ká̱ onəm oga nlung ìkukum.  
\v 3 Mmaɓu ká̱ nkpaktak onəm oga nlung ìkum ɓu, ó chen ó gáng ìtong va̱ ta̱ nva̱ng pa̱ nzəng. Ó nəm wa nnà ta i ga i chu nra pa̱ nkpa̱ɗing.  
\v 4 Te onəm oga mpyal awop pa̱ ofangshat, i kpán oga agbəshi inagam ka̱ mpyal akwati aga nsar nnap-nlà. Ka̱ nra ngga nfangshat te, ó chen ó gang ìtong va̱ ta̱ nva̱ng pa̱ nfangshat, kang onəm oga mpyal awop i yà kà̱ mɓur oga agbəshi va̱ ta.  
\v 5 Ka̱ nva̱ngva̱ ó fe oza̱ ɓur oga agbəshi chit yar awalang te, nkpaktak onəm i bà achu ká̱ ìkam, te akamsəlang ìtong va̱ ta i shin. Kang onəm i táng ashe ìtong, nza̱ unəm nggo i kpán mpyal wò.>> 
\p  
\v 6 Te uJoshuwa uya aNun ununggwan ɓut onəm oga mpyal awop kang a là ôza̱ pa̱, <<Ó yar akwati aga nsar nnap-nlà aYawe, ǹnyi te, onəm oga mpyal awop oro pa̱ ofangshat a wur oga agbəshi a ləp mpyal ká̱.>>  
\v 7 Te uza̱ là ôshozha pa̱, <<Ó lyam ó chen ó gáng ìtong va̱ ta, kang onəm va̱ ká̱ iya̱m ìkum te, oza̱ á lyam kà̱ mpyal akwati aga nsar nnap-nlà aYawe va̱ ta̱.>> 
\p  
\v 8 Ka̱ nva̱ngva̱ uJoshuwa là nnap ka̱ ônəm chit, te onəm oga mpyal awop va̱ pa̱ ofangshat va̱ wur oga agbəshi pa̱ fangshat ka̱ mpyal aYawe watar mpyal ká̱ i ɓur, kang akwati aga nsar nnap-nlà aYawe ka̱ nyar nva̱ng oza̱.  
\v 9 Onəm oga iya̱m ikum ka̱ nchen ka̱ mpyal onəm oga mpyal awop ova̱ ka̱ mɓur oga agbəshi, kang onəm oga mpángchí nva̱ng ka̱ mɓa ka̱ nva̱ng akwati. Ka̱ ashe nkpaktak oga awalang va̱ ta te, mmá pak inok mɓur oga agbəshi.  
\v 10 Ǹnyi te, uJoshuwa ka̱ nak oshozha chit pa̱, <<Kang ó bà achu ka̱t, kang ó ma̱n mmá fe ichu wó, ka̱t te nnap-nlà nro á fa ka̱ anung wó ka̱t, yà i ga i chu nra va̱ mi là a wó pa̱ ó bà achu, nna chit te, ó bà ɗak.>>  
\v 11 Uza̱ nak mmá yar akwati aYawe mmá gáng ìtong va̱ ta ká̱, nva̱ng pa̱ nzəng. Nna chit te, oza̱ le ka̱ ashe apa̱k kang oza̱ ra ka̱ ta. 
\p  
\v 12 UJoshuwa wong ká̱ iɓotak, kang onəm oga mpyal awop yar akwati aYawe.  
\v 13 Onəm oga mpyal awop oga ofangshat va̱ wur oga agbəshi pa̱ fangshat te, oza̱ watar i chen ká̱ ka̱ mpyal akwati aYawe, oza̱ i nəm inok mɓuɓur. Onəm oga iya̱m ìkum ka̱ mpyal oza̱, kang onəm oga mpángchí nva̱ng ka̱ mɓa ka̱ nva̱ng akwati aYawe. Ka̱ ashe nkpaktak oga awalang va̱ ta te, mmá pak inok mɓur oga agbəshi.  
\v 14 Ka̱ nra ngga mparəm te, oza̱ gáng ìtong va̱ ta nva̱ng pa̱ nzəng, nna chit te, oza̱ le ashe apa̱k. Wa ǹna ta oza̱ nəm nra pa̱ nkpa̱ɗing. 
\p  
\v 15 Kà̱ nra ngga nfangshat te, oza̱ wong ká̱ iɓotak, oza̱ chen gáng ìtong va̱ ta nva̱ng pa̱ nfangshat wa nva oza̱ mmà nəm a. Kà̱ nra va ta na byet, oza̱ chen gang ìtong va̱ ta nva̱ng pa̱ nfangshat.  
\v 16 Ka̱ nggáng ngga nfangshat te, awalang va̱ onəm oga mpyal awop ɓur oga agbəshi chit, te uJoshuwa nak oshozha pa̱, <<Ó bà achu, ka̱kul uYawe na ìtong va̱ ta̱ a wó chit.  
\v 17 Ìtong va̱ ta ka̱ nkpaktak iya̱m va̱ ka̱ ashishe te mmá gar ûYawe ka̱kul nzhì. URahap uchar uga nnəm mmai va̱ ta ká̱ nkpaktak onəm va̱ nzəng ká̱ na ka̱ ashe nzhizhi te, oma mí re ká̱ irirì ɓyet ka̱kul pa̱ uza̱ bwam onəm oga nsòng atak yi va̱ í re nre kà̱ ka̱ ashe mbin va̱ ta̱.  
\v 18 Mmawo ǹnyi te, ó pángchí ishi wó ka̱ atak oga iya̱m va̱ mmá gar chit ka̱kul nzhì. Le kang ó ɓa ká̱ nzhì ká̱ nɗaktak îshi wó ká̱ apa̱k oIsa̱rila ka̱t.  
\v 19 Kang nkpaktak aazurfa ká̱ azənariya, ká̱ acham aləbər, ká̱ acham arəzang ǹnyi te, iya̱m iyə́ryər ûYawe. Mí táng ká̱ ka̱ ashe nzhi ngga mɓut iya̱m aYawe.>> 
\p  
\v 20 Te onəm oga mpyal awop ɓur oga agbəshi. Onəm fe nnap agbəshi te, oza̱ bà achu pa̱ gbá̱nggbá̱ng, kang akamsəlang va̱ ta shin. Te onəm táng ka̱ ashe ìtong va̱ ta, uda nggo kpán mpyal wò pa̱ dakdak, kang oza̱ kpán ìtong va̱ ta.  
\v 21 Nna chit te, oza̱ zhì nkpaktak iya̱m va̱ ka̱ ashe ìtong va̱ ta ká̱ ndokchi, ochar ká̱ onunggwan, ovan ká̱ onəm gbakgbak, ina ká̱ itam ká̱ azhaki. 
\p  
\v 22 Te uJoshuwa là ônunggwan oga oparəm va̱ oma ka̱ sòng mbin va̱ ta pa̱, <<Ó ga ashe nzhi achar uga nəm mmai va̱, na ó fa ka̱ na ká̱ nkpaktak onəm va̱ ojini wa nva ka̱ ó sóng anung a na á.>>  
\v 23 Te ovan nza̱m va̱ ka̱ sòng mbin va̱ ta táng fa ká̱ uRahap, ká̱ upupo ká̱ unənang ká̱ ogənanggənang onunggwan ká̱ ochar, ká̱ nkpaktak onəm va̱ ojini. Kang oza̱ fa ká̱ nkpaktak onəm oga nzhizhi, oza̱ nak ka̱ nsəm apa̱k oIsa̱rila. 
\p  
\v 24 Te oza̱ pwak ìtong va̱ ta ká̱ apər, ká̱ nkpaktak iya̱m va̱ ka̱ ashishe, ǹnyi te, mmá nak aazurfa ká̱ azənariya ká̱ oga acham arəzang ká̱ acham aləbər, ka̱ ashe nzhi ngga mɓut iya̱m aYawe.  
\v 25 Ǹnyi te, uJoshuwa re uRahap uchar uga nnəm mmai, ká̱ onəm oga ashe nzhizhi, ká̱ nkpaktak onəm va̱ ojini ka̱ irirì, ka̱kul pa̱ uza̱ bwam onunggwan va̱ uJoshuwa re ǹre ká̱ pa̱ á sòng mbin aJariko á. Uwa ka̱ ntəm ka̱ ashe aIsa̱rila ɓa chu nda va̱ ta̱. 
\p  
\v 26 Ka̱ awalang va̱ ta te, uJoshuwa là nnap ôza̱ nzəng ka̱ nsóng anung pa̱, <<Unəm va̱ a wong ka̱kul pa̱ ô me ìtong aJariko kà̱ɗi te, uza̱ sat unəm uvyapvyap chit ka̱ mpyal aYawe, 
\q1 <<ka̱ anung irirì ayiyen ununggwan uga nggəshi, 
\q2 kang uza̱ i bang akukum, 
\q1 ka̱ anung irirì ayiyen ununggwan uga nku irəng 
\q2 kang uza̱ i me oga anung asəsa̱l.>> 
\p  
\v 27 Te uYawe uwa yà nzəng ká̱ uJoshuwa, kang aɗiɗin dam ka̱ ashe nkpaktak mbin va̱ ta. 
\c 7  
\s1 Nnap mɓá̱ngɓa̱ng aAkan 
\p  
\v 1 Ǹnyi te, oIsa̱rila nyám nlang nnandər ka̱ apal iya̱m igargar ka̱kul nzhì. UAkan, uya aKarmi ununggwan, uya aZabdi, uya aZera uga akum ìjili aYahuda, kpa̱k ka̱ ashe iga iya̱m va̱ mmá dang oza̱ kà̱ ngwuwur. Te igwak aYawe lak ka̱ apal ishi oIsa̱rila pa̱ gənggəng. 
\p  
\v 2 Te uJoshuwa re onunggwan ka̱ aJariko pa̱ oza̱ a ga aAyi, va̱ dat ká̱ aBet-Aven, ka̱ asa̱l nfa alum aBetel, uza̱ là ôza̱ pa̱, <<Ó ga ó sòng mbin va̱ ta.>> Te onunggwan va̱ ta ga nsòng aAyi. 
\p  
\v 3 Awalang va̱ oza̱ le atak aJoshuwa te, oza̱ là á na pa̱, <<Kang nkpaktak oshozha á ga ka̱t, mmá re onəm achu ìkalong pa̱ iparəm ka̱t te pa̱ ishatɗing á ga á ri aAyi ká̱ ìkum, kang mmá nak nkpaktak oshozha á ɓək anung ngga ka̱ ta ka̱t, ka̱kul oza̱ yəl ka̱t.>>  
\v 4 Te onəm chu wa ìkalong pa̱ ishatɗing ka̱ ashe onəm ɓa ga, kang onəm oga aAyi ga ɓak oza̱ chəng.  
\v 5 Onəm oga aAyi gbá̱ng onəm á chu ìsəm pa̱ ishatɗing ama̱n pa̱ kpa̱ɗing ka̱ ashe oIsa̱rila, oza̱ ɓak oza̱ ɓan ka̱ anung asa̱l ìtong a ga chu aShebarim, kang oza̱ nəm inok ngbá̱ng oza̱ ka̱ aba̱nda̱m va̱ ta. Te izər rusok ká̱ onəm wa ndəng. 
\p  
\v 6 Te uJoshuwa ká̱ onəmgbak oIsa̱rila kan ilukwan oza̱, kang oza̱ tak zəp ká̱ afu ka̱ mbin kà̱ mpyal akwati aYawe a ga chu arurong. Kang oza̱ wung mɓwang ka̱ apal ishi oza̱.  
\v 7 Te uJoshuwa là pa̱, <<Iya̱m iga ngga aɗor ka̱kul yi, áNəm Uga Nzhi uYawe, iza̱ nak kang u pa̱ng ká̱ onəm va̱ ta̱ ɓa igwong aUrdun, ka̱kul pa̱ ú na yi ka̱ ashe awo oga aAmori á gbá̱ng yi yà? Kapkap ká̱ i təm iya̱m yi ka̱ agwong aUrdun va cho.  
\v 8 Ánəm uga nzhi, iza̱ mi là ka̱ nva̱ngva̱ oIsa̱rila ga̱ɓa̱n asəm ka̱ mpyal okpa ìkum oza̱ yà?  
\v 9 Ka̱kul oKanana ká̱ nkpaktak onəm va̱ ka̱ ntəm ka̱ ashe mbin va̱ ta̱ i fe nnap va̱ ta̱, te i gáng yi kang i dərkən aɗin yi ka̱ apambin. Te iza̱ ɓu nəm ka̱kul aɗin ɓu achumchum yà?>> 
\p  
\v 10 Te uYawe là ûJoshuwa pa̱, <<Wong, ka̱kul iza̱ kang u ru u zəp ká̱ afu ka̱ mbin yà?  
\v 11 AIsa̱rila nəm nnap-mɓá̱ngɓa̱ng chit, oza̱ yəl nsar nnap-nla mi va̱ n nak ôza̱ ka̱t, ka̱kul oza̱ nəm ayi, oza̱ kpa̱k ka̱ ashe oga iya̱m igargar ka̱kul nzhì va̱ mma dang chit, oza̱ nak ka̱ ashe iji oza̱, kang oza̱ nap akwam ka̱ apal iya̱m va̱ oza̱ nəm.  
\v 12 Ka̱kul nva̱ ta te onəm oIsa̱rila i yà ka̱ nsat ka̱ mpyal okpa ìkum oza̱ lap ka̱t. Oza̱ ga̱ɓa̱n asəm chəng ka̱ mpyal okpa ìkum oza̱, kang oza̱ tong ovyapvyap chit ka̱kul nzhì. Mi yà nzəng ká̱ wo lap ka̱t, yà ó zhì oga iya̱m igargar iga nzhì va̱ ta ka̱ ashe wó kang. 
\p  
\v 13 <<Wóng, na u gar onəm, là ôza̱ pa̱ <Ó gar ishi wó ka̱kul ìpin, ka̱kul uYawe, Inan oIsa̱rila là pa̱, ÓIsa̱rila, oga iya̱m igargar ka̱kul nzhì na yà ka̱ ishimshe wó. Ó yà ka̱ nsat ka̱ mpyal okpa ìkum wó lap ka̱t, ya ó fa ká̱ oga iya̱m va̱ ta kang. 
\p  
\v 14 << <Ká̱ ìpin te, ó nyám ishi wó ka̱ atak oga akum ìjili wó. Akum ìjili va̱ uYawe i yak te, oza̱ i səng i ɓa datkulung ka̱ atak oga akum oza̱. Akum va̱ uYawe i yak te, i səng i ɓa datkulung nzhi ká̱ nzhi. Kang nzhi va̱ uYawe i yak te, i səng i ɓa datkulung unəm ká̱ unəm.  
\v 15 Unəm va̱ mmá ya na ká̱ iya̱m igargar ka̱kul nzhì te, mí pwak na ká̱ apər, ká̱ nkpaktak iya̱m va̱ uza̱ ká̱. Uza̱ gantal nsar nnap-nlà aYawe chit, kang uza̱ nəm iya̱m iga ìwuswa ka̱ ashe oIsa̱rila.> >> 
\p  
\v 16 Te uJoshuwa wong ká̱ iɓotak, nak oIsa̱rila ɓa datkulung ka̱ atak oga akum ìjili oza̱, te mmá yak akum ìjili aYahuda.  
\v 17 Uza̱ ɓa ká̱ akum ìjili aYahuda, te mmá yak akum aZera. Uza̱ ɓa ká̱ akum aZera nzhi ká̱ nzhi, te mmá yak nzhi aZabdi.  
\v 18 UJoshuwa ɓa ká̱ nzhi aZabdi dat unəm ka̱ unəm, kang mmá yak uAkan uya aKarmi ununggwan, uya aZabdi, uya aZera, ka̱ akum ìjili aYahuda. 
\p  
\v 19 Te uJoshuwa là ûAkan pa̱, <<Áyen mi, n chal ɓu, là mpat ɓu ûYawe, Inan oIsa̱rila, te là á mi iya̱m va̱ u nəm. Kang wa bwam á mi ka̱t.>> 
\p  
\v 20 Te uAkan na ama̱n pa̱, <<À nnandər n nəm nnap-mɓá̱ngɓa̱ng uYawe, Inan oIsa̱rila chit. Iya̱m va̱ n nəm te nnà ta̱.  
\v 21 Ka̱ ashe oga iya̱m iga ngwur ka̱ atak ìkum te, n ya ìlukwan ìnəna̱n apir iji oga aBabila, ká̱ ashekel ìgba̱l pa̱ ìpa̱rəm aga aazurfa, ká̱ idari azenariya va iɗəɗək ashekel ìsəm pa̱ ìtukun. Te n nəm aɗom oza̱, kang n wur, n li ka̱ ashe mbin ka̱ ashe aghal mi, ká̱ aazurfa ka̱ avəvəng.>> 
\p  
\v 22 Te uJoshuwa re onəm oga nre, kang oza̱ chəng ga ashe aghal va̱ ta, te oza̱ ya nna a bwam ka̱ ashe aghəghal ká̱ aazurfa va̱ ta ka̱ avəvəng.  
\v 23 Oza̱ wur oga iya̱m va̱ ta fa ka̱ ashe aghal, oza̱ ɓa ka̱ ûJoshuwa ká̱ nkpaktak onəm oIsa̱rila, kang oza̱ nak ka̱ mpyal aYawe. 
\p  
\v 24 Te uJoshuwa ká̱ nkpaktak oIsa̱rila yar uAkan uya aZera ununggwan, ká̱ aazurfa, ká̱ ìlukwan, ká̱ idari azənariya, ká̱ ovəvan onunggwan ká̱ ochar, ká̱ inəna, ká̱ oga azhakizhaki, ká̱ itətam, ká̱ aghəghal, ká̱ nkpaktak iya̱m va̱ uza̱ ka̱, kang oza̱ ɓa ká̱ oza̱ ka̱ mba̱nda̱m ngga aAkor.  
\v 25 UJoshuwa là pa̱, <<Ka̱kul iza̱ kang u ɓa ká̱ nɗaktak va̱ ta̱ á yi yà? Ka̱ nda ta̱ uYawe i ɓa ká̱ nɗaktak a ɓu.>> 
\p Te nkpaktak oIsa̱rila gwan na ká̱ ipang, kang nva̱ngva̱ oza̱ gwan onənəm chit te, oza̱ pwak oza̱ ká̱ nkpaktak iya̱m oza̱ ká̱ apər.  
\v 26 Oza̱ ɓut ipang ɓing ka̱ apal ishishi. Mɓing ipang va̱ ta nna yà ka̱ ta nda va̱ ta̱. Te nlak igwak aYawe fər ɗak. Ka̱kul nna kang mí wór atak va̱ ta pa̱ mba̱nda̱m aAkor nda va̱ ta̱. 
\c 8  
\s1 Mmá zhì aAyi 
\p  
\v 1 Te uYawe là ûJoshuwa pa̱, <<Kang wa nəm ayər, ka̱t te wa ga̱m ka̱t. Wur nkpaktak onəm oga nlung ìkum nzəng ká̱ ɓu, na ó ga ó ru aAyi ká̱ ìkum. Ka̱kul n na uponzhi uga aAyi chit ka̱ ashe awo ɓu, ká̱ onənəm, ká̱ ìtutong, ká̱ mbibin.  
\v 2 Nəm a aAyi ká̱ uponzhiponzhi wa nva u nəm aJariko ká̱ uponzhiponzhi á. Ǹnyi te, ìdur oza̱ ká̱ iya̱mkang nnà ó wur i yà iya̱m iga ngwur ka̱ atak ìkum îshi wó. Ó ra anyimnyal ka̱ nsəm ìtong va̱ ta.>> 
\p  
\v 3 Te uJoshuwa ká̱ nkpaktak onəm oga nlung ìkum wong ga pa̱ na ó ru aAyi ká̱ ìkum. Uza̱ yak onəm oga ǹnyi nlung ìkum ova ji ìkalong ìsəm pa̱ ishatɗing kang uza̱ re oza̱ fa ká̱ ìzwam,  
\v 4 uza̱ nak oza̱ pa̱, <<Ó gong achwang pa̱ dakdak. Ó ra anyimnyal ìtong va̱ ta ka̱ nsəm. Kang ó gbà̱ng ká̱ ìtong va̱ ta ka̱t. Nkpaktak wó, ó təm ká̱ ngbar izər pa̱ dakdak.  
\v 5 Mmami ká̱ nkpaktak onəm va̱ nzəng ká̱ mi, i ga i datkulung ká̱ ìtong va̱ ta. Ka̱ nva̱ngva̱ oza̱ i fa nlung yi wa nva ka̱ yà te, í chəng i le ka̱ mpyal oza̱.  
\v 6 Oza̱ i fa i wa nva̱ng yi, mmayi te, i dap oza̱ i gbà̱ng ká̱ ìtong va̱ ta, ka̱kul oza̱ i là pa̱, <Oza̱ ka̱ nchəng yi wa mmatmat va.> Awalang va̱ i chəng ka̱ mpyal oza̱ te,  
\v 7 ó wong ka̱ atak anyimnyal wó kang ó ka̱m ìtong va̱ ta. UYawe Inan wó i na ìtong va̱ ta ka̱ ashe awo wó.  
\v 8 Ka̱ nva̱ngva̱ ó ka̱m ìtong va̱ ta chit, te ó pa apər ká̱ ìtong va̱ ta. Ó kpak nnap-mpakpak aYawe va̱ ka̱ nak a wó. Nnap-nkpakpak wó na ta̱.>> 
\p  
\v 9 Te uJoshuwa re oza̱ fa ga nra anyimnyal, kang oza̱ ga ra ka̱ ishimshe aBetel ká̱ aAyi, ka̱ asa̱l ntar alum aAyi. Ǹnyi te, uJoshuwa ra nzəng ká̱ onəm va̱ ta. 
\p  
\v 10 Ká̱ iɓotak te, uJoshuwa wong ɓut onəm oga nlung ìkum, kang uza̱ ká̱ onəm oga mpyal oIsa̱rila ləp mpyal ôza̱ ga aAyi.  
\v 11 Nkpaktak onəm oga nlung ìkum va̱ nzəng ka̱ na te, chen ga dat ká̱ ìtong va̱ ta kang oza̱ la̱p apa̱k ka̱ asa̱l mpəpal. Kang aba̱nda̱m nna yà ka̱ ishimshe oza̱ ká̱ aAyi.  
\v 12 UJoshuwa wur onunggwan chu ìkalong chu pa̱ ìtukun, kang uza̱ nak oza̱ ra anyimnyal ká̱ ishimshe aBetel ká̱ aAyi, ka̱ asa̱l ntar alum aga ìtong va̱ ta.  
\v 13 Te onəm oga nlung ìkum va̱ ta la̱p apa̱k ka̱ asa̱l mpal ìtong va̱ ta, kang onəm oga nra anyimnyal ra ka̱ asa̱l ntar alulum. Ǹnyi te, uJoshuwa le ashe aba̱nda̱m ka̱ ìzwam va̱ ta. 
\p  
\v 14 Awalang va̱ uPonzhi uga aAyi ya chit pa te, uza̱ ká̱ nkpaktak onunggwan oga ìtong va̱ ta fa ka̱ ǹngha̱n ka̱ iɓotak ga pa̱ na ó gwang ka̱ agbagba ka̱ mpyal aAraba, ka̱kul pa̱ na ó lung ìkum ká̱ oIsa̱rila. Ǹnyi te, uza̱ nyi pa̱ nnà mmá ra anyimnyal ka̱ nsəm ìtong va̱ ta ka̱kul wò ka̱t.  
\v 15 UJoshuwa ká̱ nkpaktak oIsa̱rila nəm na oza̱ ji nkàm wó chit, te oza̱ chəng ka̱ mpyal oza̱ le asa̱l ashe ǹzam.  
\v 16 Nnà chit te, mmá wór nkpaktak onunggwan va̱ ka̱ ashe ìtong va̱ ta ɓut wa oza̱. Wa nnà ta, oIsa̱rila dap oza̱ gbà̱ng ká̱ ìtong va̱ ta.  
\v 17 Ununggwan uro yà bur ka̱ ashe aAyi, ka̱t te aBetel va̱ fa mɓàk oIsa̱rila ka̱t. Oza̱ re anung ìtong va̱ ta abolbol, kang oza̱ ga mɓàk oIsa̱rila. 
\p  
\v 18 Te uYawe là ûJoshuwa pa̱, <<Yichi aɓár va̱ ka̱ awo ɓu a ga ka̱ asa̱l aAyi, ka̱kul mi ga nnəna ka̱ ashe awo ɓu.>> Te uJoshuwa yichi aɓár va̱ ka̱ awo wò a ga ka̱ asa̱l ìtong va̱ ta.  
\v 19 Kang nva̱ngva̱ uza̱ yichi awo wò chit, te onəm va̱ ra anyimnyal wong ká̱ ǹngha̱n, oza̱ chəng táng ìtong va̱ ta kang oza̱ kpán. Te oza̱ rap apər îtong va̱ ta ka̱ ǹngha̱n.  
\v 20 Ka̱ awalang va̱ onunggwan oga aAyi dər nva̱ng te, oza̱ ya nggù nəngət chit ga apaɓur. Ǹnyi te, oza̱ yà ká̱ asa̱l aga nchəng ngga mpyal, ka̱t te nle nva̱ng ka̱t, ka̱kul onəm va̱ ka̱ chəng le ashe ǹzam te, á ga̱ɓa̱n chit kà̱ nru oza̱ ká̱ ìkum.  
\v 21 Awalang va̱ uJoshuwa ka̱ nkpaktak oIsa̱rila ya pa̱ onəm va̱ ra anyimnyal kpán ìtong va̱ ta chit, kang nggù nəngət chit ka̱ apal, te oza̱ ga̱ɓa̱n le gbá̱ng onəm oga aAyi.  
\v 22 Onunggwan va̱ kpan ìtong va̱ ta chit, fa ka̱ ashe ìtong va̱ ta ru oza̱ ká̱ ìkum. Kang oIsa̱rila nak oza̱ ká̱ ishimshe. Te oza̱ gbá̱ng oza̱, unəm uro yà lár, ka̱t te chə́r fa ka̱t.  
\v 23 Ǹnyi te, oza̱ kpán uPonzhi oga aAyi ká̱ irirì, kang oza̱ ɓa ka̱ na ûJoshuwa. 
\p  
\v 24 Ka̱ nva̱ngva̱ oIsa̱rila gba̱l ka̱ ngbá̱ng nkpaktak onəm oga aAyi ovəngva̱ wa nva̱ng oza̱ ka̱ ashe ǹzam mmaləng ká̱ agbagba, kang va̱ oza̱ gbá̱ng oza̱ ká̱ ndokchi tak chit. Te oIsa̱rila le ga aAyi gbá̱ng onəm va̱ ka̱ ashishe ká̱ ndokchi.  
\v 25 Onəm va̱ mmá gbá̱ng ká̱ nda ta te, ìkalong pa̱ igba̱pchi ama̱n pa̱ ìparəm, onunggwan ka̱ ochar, nkpaktak onəm oga aAyi.  
\v 26 Ǹnyi te, uJoshuwa le ká̱ awo va̱ uza̱ yichi aɓár ká̱ ka̱t, a ga chu awalang va̱ uza̱ zhì nkpaktak onəm oga ntəm ka̱ ashe aAyi kang.  
\v 27 Oga Iya̱mkang ká̱ idur iga ashe ìtong va̱ ta nna byet oIsa̱rila wur iya̱m iga ngwur ka̱ atak ìkum îshi oza̱, wa nva uYawe ka̱ nak ûJoshuwa pa̱ á nəm. 
\p  
\v 28 Te uJoshuwa pwak aAyi, kang á nak ɓing sat agúng mbyet, nna yà wa nnà ta nda va̱ ta̱.  
\v 29 Uza̱ zong uponzhi uga aAyi ka̱ apal ìkun a ga chu arurong. Ka̱ nva̱ngva̱ alum tar chit, te uJoshuwa nak pa̱ mmá fər ká̱ akúkum ka̱ apal ìkun va̱ ta, mmá máng ka̱ anung asa̱l aga ntar ìtong va̱ ta. Kang mmá ɓing ipáng pa̱ makmak ka̱ apal ishishi, nna yà ka̱ ta nda va̱ ta̱. 
\s1 Mmá kung nnap-mpakpak ka̱ apal aƁam aEbal 
\p  
\v 30 Te uJoshuwa me atak nshì iya̱m awop ûYawe, Inan oIsa̱rila, ka̱ apal aɓam aEbal,  
\v 31 wa nva uMusa, uzwal aYawe ka̱ nak onəm oIsa̱rila á. Uza̱ me wa nva ka̱ ashe nlir nnap-mpakpak aMusa va̱ là pa̱, <<Ó me atak nshì iya̱m awop ká̱ ipang pa̱ chatchat iva na mmá kwat chit ká̱ acham ka̱t.>> Te oza̱ yichi iya̱m inana iga nshì ûYawe, ká̱ iya̱m inana nləfər ngga ntəm ikángkáng ka̱ apəpal.  
\v 32 Kang ka̱ ta ka̱ mpyal oIsa̱rila, uJoshuwa lir nnap-mpakpak aMusa ka̱ apal ipang va̱ ta, nva uMusa ka̱ lir chit á.  
\v 33 Nkpaktak oIsa̱rila, ká̱ onəmgbak, ká̱ onəm oga mpyal, ká̱ onəm oga nnap-akwali, nzəng ká̱ oɗyanəm va̱ ka̱ ashe oza̱, ká̱ ovəngva̱ oza̱ mar, tong kà̱ oga ngba̱k akwati aga nsar nnap-nlà, ka̱ mpyal onəm oga mpyal awop oLawi, ovəngva̱ yar akwati aga nsar nnap-nlà aYawe. Kang nkap kà̱ ishimshe onəm tong ka̱ mpyal aƁam aGerizim, kang aɓo nkap nro tong ka̱ mpyal aƁam aEbal, wa nva uMusa, uzwal aYawe ka̱ nak chit, pa̱ mmá nak nnap-nnəna̱n onəm oIsa̱rila. 
\p  
\v 34 Ka̱ nvəva̱ng te, uJoshuwa kung nkpaktak oga nnap-nlà va̱ ka̱ ashe nnap-mpakpak ngga nnak oga nnap-nnəna̱n ká̱ nvyap, mal dakdak ká̱ nkpaktak iya̱m va̱ mmá lir ka̱ ashe nnap-mpakpak.  
\v 35 Nnap-nlà nro yà nva uMusa nak kang uJoshuwa kung ka̱ mpyal nkpaktak mɓut oIsa̱rila ka̱t te, a yà ka̱t, nzəng ká̱ ochar, ká̱ ovan, ká̱ oɗyanəm va̱ ka̱ ntəm ka̱ ashe oza̱ á. 
\c 9  
\s1 Onəm oga aGibiyon lam uJoshuwa 
\p  
\v 1 Ka̱ awalang va̱ nkpaktak oponzhi va̱ kà̱ ntar alum aUrdun, ká̱ oponzhi va̱ kà̱ mbin ngga aɗuktum ká̱ mba̱nda̱m oIsa̱rila, kang oponzhi va̱ kà̱ mbin ngga anung inang ìwa aMeditereniya a ga chu aLebanon, oma oponzhi oHitti, ká̱ oAmori, ká̱ oKanana, ká̱ oPerizi, ká̱ oHivi, ká̱ oJebusi fe nnap igwan va̱ ta,  
\v 2 te oza̱ gwang ishi ka̱ anung zəngtəng ka̱kul pa̱ ó lung uJoshuwa ká̱ oIsa̱rila. 
\p  
\v 3 Ǹnyi te, awalang va̱ onəm oga ntəm ka̱ aGibiyon fe iya̱m va̱ uJoshuwa nəm aJariko ká̱ aAyi te,  
\v 4 oza̱ nəm aghan. Oza̱ ɗa̱mshi iya̱m-nrì iga nkpán ka̱ awo, oza̱ wur ijiga igbakgbak ka̱ apal oga azhaki oza̱ ká̱ aba̱ng ndəng ìba̱ngba̱ng ǹsámsàm igbakgbak, va kan chit kang izəzər pa̱ kap mmá dədan.  
\v 5 Oza̱ mwak oga akwap agbakgbak ka̱ ashar oza̱ va mmá ɓəɓáp, ká̱ ilukwan igbakgbak. Kang nkpaktak nzəngkəng ngga nkpán awo oza̱ a wom chit kang a gum.  
\v 6 Te oza̱ ga atak aJoshuwa ka̱ ashe apa̱k ka̱ aGilgal, kang oza̱ là á na ká̱ oIsa̱rila pa̱, <<Í fa ka̱ mbin nggbá̱nggbà̱ng, ǹyangmata̱ te, ó yar nsar nnap-nlà ká̱ yi.>> 
\p  
\v 7 Ǹnyi te, oIsa̱rila là ôHivi pa̱, <<Mwote mmawó ka̱ ntəm dát ka̱ yi nggo, te sang kang í yar nsar nnap ká̱ wó yà?>> 
\p  
\v 8 Kang oza̱ là ûJoshuwa pa̱, <<Mmayi ozwal ɓu.>> 
\p Ǹnyi te, uJoshuwa ɓəp oza̱ pa̱, <<Mmawó, o da yà? ó fa ka̱ che kang ó ɓa yà?>> 
\p  
\v 9 Te oza̱ na ama̱n á na pa̱, <<Ozwal ɓu fa ka̱ mbin va gbà̱ng byet kang à ɓa, ka̱kul aɗin aYawe Inan ɓu. Ka̱kul i fe nnap-nnənəm chit, ká̱ nkpaktak iya̱m va̱ uza̱ nəm ka̱ aMasar,  
\v 10 kang nkpaktak iya̱m va̱ uza̱ nəm ôponzhi oga oparəm oga aAmori va̱ ka̱ asa̱l nfa alum aUrdun, oma uponzhi uSihon uga aHeshbon, ká̱ uponzhi uOg uga aBashan, ova ka̱ nəm iponzhi ka̱ aAshtarot.  
\v 11 Onəmgbak yi ká̱ nkpaktak onəm oga ntəm ka̱ ashe mbin yi là á yi pa̱, <Ó wur iya̱m-nrì iga nkpán awo ka̱kul nnəm achen, na ó ga ó ya oza̱, kang ó là ôza̱ pa̱, <<Mmayi ozwal wó, ó yar nsar nnap ka̱ yi.>> >  
\v 12 Nzəngkəng yi nna ka̱ yà susur ka̱ awalang va̱ í wur ka̱ nzhi ka̱ nra va̱ í fa pa̱ í ɓa atak wó. Ǹnyi te, dər ǹyangmata̱, a wom chit kang á gum.  
\v 13 Kang oga aba̱ng ndəng ìba̱ngba̱ng ǹsámsàm va̱ i yə́l ta̱, te nna ka̱ yà apipye, ǹnyi te, dər asa̱l va̱ oza̱ chwan ká̱. Kang ilukwan ká̱ oga akwap yi á gbák chit ka̱kul ngbà̱ng achen.>> 
\p  
\v 14 Te oIsa̱rila kpa̱k ka̱ ashe iya̱m-nrì onəm oga aGibiyon, ǹnyi te, oza̱ ɓəp ichən ka̱ atak aYawe ka̱t.  
\v 15 Te uJoshuwa ma̱n yar nsar nnap-nlà ngga ntəm ikángkáng ká̱ oza̱, pa̱ mmá re oza̱ á təm ká̱ irirì. Kang onəm oga mpyal mɓut sóng anung ôza̱. 
\p  
\v 16 Ka̱ nva̱ng nra pa̱ nshatɗing nva̱ oza̱ yar nsar nnap-nlà ká̱ onəm oga aGibiyon chit, te oIsa̱rila fe pa̱ oza̱ onəm oga ngba̱k oza̱, kang oza̱ ka̱ ntəm dát ká̱ oza̱.  
\v 17 Te onəm oIsa̱rila fa achen, kang ka̱ nra ngga nshatɗing te, oza̱ chu itong va̱ onəm va̱ ta i təm kà̱. Oma aGibiyon, ká̱ aKefira, ká̱ aBiyerot, ká̱ aKiriyat-Jeyarim.  
\v 18 Ǹnyi te, oIsa̱rila gbá̱ng oza̱ ka̱t, ka̱kul onəm oga mpyal mɓut ka̱ sóng anung ôza̱ chit ka̱ ashe aɗin aYawe, Inan oIsa̱rila. 
\p Te nkpaktak nggatək lwang nnap ka̱ apal onəm oga mpyal va̱ ta.  
\v 19 Ǹnyi te, nkpaktak onəm oga mpyal na ama̱n n̂ggatək va̱ ta pa̱, <<I sóng anung ôza̱ chit ka̱ ashe aɗin aYawe, Inan oIsa̱rila, ka̱kul nva̱ ta te, i yà ka̱ ndok oza̱ ka̱t.  
\v 20 Iya̱m va̱ i nəm ôza̱ te, i re oza̱ ká̱ irirì ka̱kul nsóng anung va̱ i sóng ôza̱ chit, le kang í dapchi nlak ìgwak aYawe ka̱ apal ishi yi ka̱t.>>  
\v 21 Onəm oga mpyal là ôza̱ ka̱ɗi pa̱, <<Mmá re oza̱ ká̱ irirì, ǹnyi te, re oza̱ á tong onəm oga nkyen akun ká̱ nɗyang ndəng n̂ggatək.>> Wa nnà ta onəm oga mpyal yə́l nsar nnap-nlà oza̱. 
\p  
\v 22 Te uJoshuwa wór onəm oga aGibiyon kang á là ôza̱ pa̱, <<Sang kang ó lam yi, ó là pa̱, <I fa gbəgba̱ng,> ǹnyi te, mmawó ka̱ ntəm dát ká̱ yi yà?  
\v 23 Ǹyangmata̱ te, uYawe vyap wó chit, ka̱ ashe wó unəm uro i yà iya̱m iro lap ka̱t, ozwal na chwat, onəm oga nkyen akun ká̱ nɗyang ndəng ka̱kul nzhi Inan mi.>> 
\p  
\v 24 Te oza̱ ma̱n ûJoshuwa pa̱, << Ozwal ɓu fe nnap va̱ uYawe, Inan ɓu, nak ûzwal wò uMusa chit pa̱, á na nkpaktak mbin va̱ ta̱ a wó, na ó zhì nkpaktak onəm va̱ ka̱ ntəm ka̱ ashishe. Nnà nak te, ayər nəm yi pa̱ gənggəng ka̱kul irirì yi, kang i nəm iya̱m va̱ ta̱.  
\v 25 Ǹyangmata̱ te, mmayi ka̱ ashe awo ɓu, nəm á yi iya̱m va̱ u ya məmal kang aɓiɓyen ká̱ ɓu á.>> 
\p  
\v 26 Te uJoshuwa ka̱m ishi oza̱ ka̱ ashe awo oIsa̱rila, oza̱ gbá̱ng oza̱ ka̱t.  
\v 27 Ǹnyi te, ka̱ nda va̱ ta uJoshuwa nak oGibiyon tong onəm oga nkyen akun ká̱ nɗyang ndəng ka̱kul nggatək, ká̱ atak va̱ uYawe yak ka̱kul nshì iya̱m awop. Kang wa nnà ta oza̱, ɓa chu ká̱ nda va̱ ta̱. 
\c 10  
\s1 Mmá ri oAmori ká̱ ìkum 
\p  
\v 1 Ǹyangmata̱ te, uAdonizedek uPonzhi uga aUrushelima fe chit pa̱ uJoshuwa ri aAyi kang uza̱ zhì na pa̱ chatchat, uza̱ nəm á na wa nva uza̱ ka̱ nəm âJariko ká̱ uponzhiponzhi, kang pa̱ onəm oga aGibiyon nəm ntəm ikángkáng ká̱ oIsa̱rila chit, kang oma ka̱ ntəm ka̱ ashe oza̱.  
\v 2 Te ayər nəm na nzəng ká̱ onənəm pa̱ gənggəng ka̱kul aGibiyon inang ìtong, wa itong va ká̱ iponzhi, ka̱kul pa̱ á ji aAyi ji ká̱ ìrup, kang nkpaktak onunggwannunggwan te, onunggwan ìkum.  
\v 3 Te uAdonizedek uponzhi uga aUrushelima, re ǹre ga atak aHoham uPonzhi uga aHebron, ká̱ uPiram uponzhi uga aJarmut, ká̱ uJafiya uponzhi uga aLakish, kang ká̱ uDebir uponzhi uga aEglon, là pa̱,  
\v 4 <<Ó ɓa ó ka̱mshi mi, na i lung ìkum ká̱ oga aGibiyon, ka̱kul oza̱ yar nsar nnap-nlà chit ká̱ uJoshuwa ká̱ onəm oIsa̱rila.>> 
\p  
\v 5 Te oPonzhi oga otukun oga aAmori va̱ ta̱, uponzhi uga aUrushelima, ká̱ uponzhi uga aHebron, ká̱ uponzhi uga aJarmut, ká̱ uponzhi uga aLakish, ká̱ uponzhi uga aEglon, ɓut nkpaktak onəm ìkum oza̱ te, a ɓa ga ləp apa̱k gáng aGibiyon kang a ru oza̱ ká̱ ìkum. 
\p  
\v 6 Te oGibiyon re ǹre ga atak aJoshuwa ka̱ ashe apa̱k ka̱ aGilgal, oza̱ là pa̱, <<Kang wa swang ozwal ɓu ka̱t. Ɓa atak yi pa̱ kəlak, na ú ka̱m ishi yi. Ka̱mshi yi, ka̱kul pa̱ nkpaktak oponzhi oga oAmori, ova ka̱ ntəm ka̱ ashe mbin ngga aɗuktum, oza̱ gwang ishi chit pa̱ ó lung yi.>> 
\p  
\v 7 Te uJoshuwa wong ka̱ aGilgal ɓa ga, uza̱ ká̱ nkpaktak onəm oga nlung ìkum wò, ká̱ nkpaktak onunggwan oga ǹnyi ìkum.  
\v 8 UYawe là ûJoshuwa pa̱, <<Kang a nəm ayər oza̱ ka̱t, ka̱kul n na oza̱ chit ka̱ ashe awo ɓu. Unəm uro yà ka̱ ashe oza̱ chu nsat ka̱ mpyal ɓu ka̱t.>> 
\p  
\v 9 Te uJoshuwa wong ka̱ aGilgal nəm achen ka̱ ashe nkpaktak ìzwam, kang uza̱ ga mul oAmori.  
\v 10 UYawe nak oza̱ zwar ka̱ mpyal oIsa̱rila. Te oza̱ gbá̱ng oAmori pa̱ makmak ka̱ aGibiyon, kang oza̱ ɓak oza̱ ka̱ asa̱l aga nkyen mɓa ngga aBet-Horon oza̱ nəm inok ngbá̱ng oza̱ ga chu aAzeka ká̱ aMakeda.  
\v 11 Ka̱ awalang va̱ oza̱ ka̱ nchəng ka̱ mpyal oIsa̱rila, ka̱ nvang asa̱l aBet-Horon va iga aAzeka te, uYawe swang oga aɗəɗal va mwal wa inang ipang ka̱ apaɓur vang ka̱ apal oza̱. Ovəngva̱ kú ka̱ atak aɗəɗal va̱ ta te, yə́l ji ovəngva̱ ji onəm oIsa̱rila gbá̱ng ká̱ ndokchi. 
\p  
\v 12 Kà̱ ìlum va̱ uYawe na oAmori ka̱ ashe awo oIsa̱rila te, uJoshuwa là nnap ûYawe, ka̱ mpyal oIsa̱rila pa̱, 
\q1 <<Álum, sat pa̱ kwák ka̱ apal aGibiyon, 
\q2 kang mmaɓu, ápe ka̱ apal mba̱nda̱m aAjalon.>> 
\q1  
\v 13 Te alum sat pa̱ kwák, kang ape ta̱l, 
\q2 a ga chu awalang va̱ onəm pyát ka̱ apal ishi okpa ìkum oza̱, 
\q2 wa nva ka̱ ashe nlìr aJashar. 
\p Te alum sat ka̱ ishimshe aɓuɓur, a kali ka̱ ntar ga chu ìlum pa̱ izəng.  
\v 14 Ìlum ya yà chit wa nva̱ ta̱ ka̱t, ka̱ nva̱ng ka̱t te, matmat ka̱t, ìlum nva uYawe fe ìchu anəmləbər ká̱. Nnandər uYawe uwa ka̱ nlung ìkum ka̱kul oIsa̱rila. 
\p  
\v 15 Kà̱ nvəva̱ng te, uJoshuwa ká̱ nkpaktak oIsa̱rila le apa̱k ka̱ aGilgal. 
\s1 Mmá gbá̱ng oponzhi oAmori pa̱ otukun 
\p  
\v 16 Ǹyangmata̱ te, oponzhi oga otukun va̱ ta̱ ka̱ chəng chit ka̱ bwam ka̱ ashe agba̱k ka̱ aMakeda.  
\v 17 Awalang va̱ mmá là ûJoshuwa pa̱, mmá ya oponzhi oga otukun va̱ ta̱ chit, oma bwam ka̱ ashe agba̱k ka̱ aMakeda,  
\v 18 te uza̱ là pa̱, <<Ó ɓəndəng ipang imwalmwal á kùk anung agba̱k va̱ ta, kang ó nak onəm apángchí oza̱.  
\v 19 Ǹnyi te, kang ó sat ka̱ ta ka̱t. Ó wa nva̱ng okpa ìkum wó, kang ó ru oza̱ ka̱ asa̱l nva̱ng. Kang ó re oza̱ a le a táng oga itong oza̱ ka̱t, ka̱kul uYawe Inan wó, a na oza̱ chit ka̱ ashe awo wó.>> 
\p  
\v 20 Te uJoshuwa ká̱ onəm oga aIsa̱rila ngbá̱ng oza̱ pa̱ chatchat, ǹnyi te, aɓo oro pa̱ ɗa̱p chəng táng ashe itong iga akamsəlang oza̱.  
\v 21 Te nkpaktak onəm le ká̱ ikángkáng ka̱ atak aJoshuwa ka̱ apa̱k ka̱ aMakeda. Kang unəm uro yà ram anung ka̱ oIsa̱rila lap ka̱t. 
\p  
\v 22 UJoshuwa là pa̱, <<Ó bol anung agba̱k va̱ ta, na ó fa ká̱ oponzhi oga otukun va̱ ta, ó ɓa ká̱ oza̱ á mi.>>  
\v 23 Te oza̱ fa ká̱ oponzhi oga otukun va̱ ta ka̱ ashe agba̱k, uponzhi uga aUrushelima, ká̱ uga aHebron, ká̱ uga aJarmut, ká̱ uga aLakish, ká̱ uga aEglon.  
\v 24 Awalang va̱ oza̱ ɓa ká̱ oponzhi va̱ ta chit ûJoshuwa, te uza̱ ɓut nkpaktak onunggwan oIsa̱rila, kang uza̱ là ônəm oga mpyal ìkum va̱ ɓa nzəng ká̱ na pa̱, <<Ó ɓa ka̱ ta̱, na ó nak ashar wó ka̱ ishak oponzhi va̱ ta̱.>>Te oza̱ ɓa mpyal kang oza̱ nak ashar ka̱ apal ishak oza̱. 
\p  
\v 25 Te uJoshuwa là ôza̱ pa̱, <<Kang ayər a nəm wó ka̱t, kang ichəgwak a la̱p wó ka̱t. Ó nəm nkam ìgwak, ó tong pa̱ kakkərak. Iya̱m va ta̱ uYawe i ga nnəm n̂kpaktak okpa ìkum va̱ mmawó kà ngga nlulung.>>  
\v 26 Te uJoshuwa gbá̱ng oponzhi va̱ ta, kang a zong oga akúm oza̱ ka̱ apal ikún pa̱ itukun, kang a re oza̱ zong ka̱ apal ikún va̱ ta ga chu arurong. 
\p  
\v 27 Alum kà̱ ntar te, uJoshuwa nak pa̱, mmá fəng ká̱ oza̱ ka̱ apal ikún mmá swang ka̱ ashe agba̱k va̱ oza̱ ka̱ bwam kà̱. Te oza̱ kùk anung agba̱k va̱ ta ká̱ ipang imwalmwal, oma yà ka̱ ta nda ta̱. 
\s1 UJoshuwa ri oga itong iga nkwandal ká̱ ìkum 
\p  
\v 28 Ká̱ nda va̱ ta uJoshuwa ri aMakeda ká̱ ìkum. Uza̱ gbá̱l uponzhiponzhi ká̱ ndokchi, kang uza̱ zhì nkpaktak onəm va̱ ka̱ ashe ìtong va̱ ta. Unəm uro yà uza̱ re fa ka̱ ashishe ka̱t. Uza̱ nəm ûponzhi uga aMakeda wa nva uza̱ ka̱ nəm ûponzhi uga aJariko. 
\p  
\v 29 Te uJoshuwa ká̱ nkpaktak oIsa̱rila va̱ ká̱ na wong ka̱ aMakeda ga aLibna, kang oza̱ ru oza̱ ká̱ ìkum.  
\v 30 Te uYawe na ìtong va̱ ta ká̱ uponzhiponzhi ka̱ ashe awo oIsa̱rila kpa. Kang ìtong va̱ ta ká̱ nkpaktak onəm va̱ ka̱ ashishe uJoshuwa gbá̱ng ká̱ ndokchi. Uza̱ re unəm uro fa ka̱ ashishe ka̱t. Uza̱ nəm ûponzhiponzhi wa nva uza̱ ka̱ nəm ûponzhi uga aJariko. 
\p  
\v 31 Te uJoshuwa ká̱ nkpaktak oIsa̱rila va̱ ká̱ na wong ka̱ aLibna fər ga aLakish, oza̱ gáng na kang a ru ká̱ ìkum.  
\v 32 Kang uYawe na aLakish ka̱ ashe awo oIsa̱rila, te oza̱ ri na ká̱ ìkum ka̱ nra ngga mparəm. Kang oza̱ gbá̱l nza̱ unəm nggo uva̱ ka̱ ashe ìtong va̱ ta ká̱ ndokchi, wa nva oza̱ ka̱ nəm âLibna á.  
\v 33 Te uHoram uPonzhi uga aGezer wong ɓa nka̱mshi aLakish, ǹnyi te, uJoshuwa gba̱l na nzəng ká̱ onəm ìkukum, uza̱ re unəm uro ká̱ irirì ka̱ ashe oza̱ ka̱t. 
\p  
\v 34 Te uJoshuwa ká̱ nkpaktak oIsa̱rila va̱ ká̱ na wong ka̱ aLakish fər ga aEglon. Oza̱ gáng na kang a ru ká̱ ìkum.  
\v 35 Oza̱ ri na ká̱ ìkum ka̱ nda va ta, oza̱ gbá̱ng onənəm ká̱ ndokchi kang oza̱ zhì nza̱ unəm nggo uva̱ ka̱ ashishe, wa nva oza̱ ka̱ nəm aLakish á. 
\p  
\v 36 Te uJoshuwa ka̱ nkpaktak oIsa̱rila va̱ ka̱ na wong ka̱ aEglon ɓa ga aHebron, kang oza̱ ru na ká̱ ìkum.  
\v 37 Oza̱ ri na kang oza̱ gba̱l uponzhiponzhi, ká̱ ivan itutong, ká̱ nza̱ unəm nggo ka̱ ashishe ká̱ ndokchi. Oza̱ re unəm uro fa ka̱t. Oza̱ zhì na pa̱ chatchat ká̱ nza̱ unəm nggo ka̱ ashishe, wa nva oza̱ ka̱ nəm aEglon á. 
\p  
\v 38 Te uJoshuwa ka̱ nkpaktak oIsa̱rila va̱ ka̱ na ga̱ɓa̱n ga ru aDebir ká̱ ìkum.  
\v 39 Oza̱ ri ìtong va̱ ta ká̱ ìkum, ká̱ uponzhiponzhi, ká̱ ivan itutong. Kang oza̱ zhì nza̱ unəm nggo ka̱ ashe ìtong va̱ ta ká̱ ndokchi. Oza̱ re unəm uro fa ka̱t. Oza̱ nəm aDebir ká̱ uponzhiponzhi wa nva oza̱ ka̱ nəm âHebron, ká̱ aLibna ká̱ oponzhiponzhi. 
\p  
\v 40 Te uJoshuwa nəm igwan ká̱ nkpaktak nkap mbin, nzəng ká̱ mbin ngga aɗuktum, ká̱ aNegep, ká̱ ovan oga aɗuktum aga asa̱l ntar alum, ká̱ ngga aba̱nda̱m, ká̱ nkpaktak oponzhi oza̱. Uza̱ re unəm uro fa ka̱t. Uza̱ zhì nkpaktak onəm oga irirì, wa nva uYawe, Inan oIsa̱rila ka̱ nak á.  
\v 41 UJoshuwa nəm igwan ká̱ oza̱ ɓan ka̱ aKadesh-Barneya a ga chu aGaza, ká̱ nkpaktak nkap mbin aGoshen, ga chu aGibiyon.  
\v 42 Kang uJoshuwa nəm igwan ká̱ oponzhi va̱ ta̱ pa̱ kpaktak ká̱ oga mbin oza̱ ka̱ awalang pa̱ zəng, ka̱kul uYawe, Inan oIsa̱rila uwa kà̱ nlung ìkum ka̱kul onəm wò. 
\p  
\v 43 Nnà chit te, uJoshuwa ká̱ nkpaktak oIsa̱rila le apa̱k ka̱ aGilgal ɗak. 
\c 11  
\s1 UJoshuwa nəm igwan ká̱ oponzhi oga asa̱l mpal 
\p  
\v 1 Ka̱ awalang va̱ uJabin uPonzhi uga aHazor fe nnap va̱ ta̱ te, uza̱ re ǹre ga ûJobap uponzhi uga aMadon, ká̱ uponzhi uga aShimron, ká̱ uponzhi uga aAkshap,  
\v 2 kang ká̱ oponzhi va̱ ka̱ asa̱l mpal ova ka̱ ashe oga aɓam, ka̱ aAraba aga nkwandal aKinnerot, ka̱ mbin oga avan aɗuktum aga asa̱l ntar alum, kang ká̱ aDor ka̱ asa̱l ntar alum,  
\v 3 ká̱ oKanana ka̱ asa̱l nfa alum ká̱ asa̱l ntar alum, ká̱ oAmori, ká̱ oHitti, ká̱ oPerizi, ká̱ oJebusi ka̱ mbin ngga aɗuktum, kang ká̱ oHivi va̱ ka̱ avəng aHermon ka̱ nkap mbin ngga aMizpa.  
\v 4 Te oza̱ fa nzəng ka̱ nkpaktak onəm oga nnəm ìkum oza̱, nggatək pa̱ makmak wa ashishiri ka̱ anung ìwa, ká̱ oga ipəri, ká̱ oga akeke ipəri pa̱ makmak.  
\v 5 Nkpaktak oponzhi va̱ ta̱ gwang ishi ka̱ anung nzəngtəng, ɓa ləp apa̱k ka̱ anung ndəng ngga aMerom pa̱ ó lung ìkum ká̱ oIsa̱rila. 
\p  
\v 6 Te uYawe là ûJoshuwa pa̱, <<Kang o nəm ayər oza̱ ka̱t, ka̱kul ìpin ká̱ atak wa nva̱ ta̱ te, mi na nkpaktak oza̱ ôIsa̱rila okúkú. Ó kyèn irəng ipəri oza̱ i gutum, kang ó pwak oga akeke ipəri oza̱.>> 
\p  
\v 7 Te uJoshuwa ká̱ nkpaktak onəm ìkum wò, ɓa ká̱ ǹnyi oza̱ ka̱t, ru oza̱ ká̱ ìkum ka̱ anung ndəng aMerom.  
\v 8 Kang uYawe na oza̱ ka̱ ashe awo oIsa̱rila. Oza̱ nəm igwan ká̱ oza̱ kang a ɓak oza̱ ga chu aSidon aChumchum, lyam ga aMisrefot Mayim, kang a ga chu aba̱nda̱m aMizpa ka̱ asa̱l nfa alum. Oza̱ re unəm uro fa ká̱ irirì ka̱t.  
\v 9 UJoshuwa nəm ôza̱ wa nva uYawe là á na. Uza̱ kyèn irəng ipəri oza̱ gutum, kang uza̱ pwak oga akeke ipəri oza̱. 
\p  
\v 10 Ka̱ awalang va ta uJoshuwa le nva̱ng ga ri aHazor, kang a gbá̱l uponzhiponzhi ká̱ ndokchi. AHazor nna ka̱ yà atak achumchum n̂kpaktak oga iponzhi va̱ ta.  
\v 11 Oza̱ gbá̱ng nkpaktak onəm va̱ ka̱ ashishe ká̱ ndokchi. Oza̱ zhì oza̱ pa̱ chatchat, unəm uro yà oza̱ re ká̱ irirì ka̱t, kang oza̱ pwak aHazor. 
\p  
\v 12 UJoshuwa ri nkpaktak oga itong iga iponzhi va̱ ta, ká̱ oponzhiponzhi, kang a gbá̱ng oza̱ ká̱ ndokchi. Uza̱ zhì oza̱ pa̱ chatchat, wa nva uMusa uzwal aYawe ka̱ nak á.  
\v 13 Ká̱ nnà te, itong va̱ mmá me ka̱ apal agəgər te, oIsa̱rila pwak ka̱t, aHazor na byet uJoshuwa pwak.  
\v 14 Kang oIsa̱rila wur nkpaktak ndur itong va̱ ta ká̱ iya̱mkang, a sat iya̱m iga nwur ka̱ atak ìkum îshi oza̱. Ǹnyi te, oza̱ gbá̱ng nkpaktak onəm ká̱ ndokchi, a ga chu awalang va̱ oza̱ zhì oza̱ pa̱ chatchat. Oza̱ re unəm uro fa ká̱ irirì ka̱t.  
\v 15 Wa nva uYawe nak ûMusa uzuzwal te, wa nnà ta uMusa nak ûJoshuwa. Kang uJoshuwa nəm wa nnà ta, uza̱ nəm nkpaktak iya̱m va̱ uYawe nak ûMusa. 
\p  
\v 16 Te uJoshuwa nəm igwan ká̱ nkpaktak mbin va̱ ta, mbin ngga aɗuktum, ká̱ nkpaktak aNegep, ká̱ nkpaktak nkap mbin aGoshen, ká̱ mbin oga avan aɗuktum ka̱ asa̱l ntar alum, ká̱ aAraba, ká̱ oga aɓam aIsa̱rila ká̱ oga avan aɗuktum oza̱,  
\v 17 aɓang ka̱ aƁam aHalak va̱ ɓa ga asa̱l aSeyir, a ga chu aBal Gat ka̱ mba̱nda̱m aLebanon ka̱ avəng aƁam aHermon. Uza̱ wur nkpaktak oponzhi oza̱, kang a gbá̱ng oza̱.  
\v 18 UJoshuwa gba̱ng chit ka̱ nnəm ìkum ká̱ nkpaktak oponzhi va̱ ta.  
\v 19 Ìtong iro yà yar nsar nnap-nlà ntəm ikángkáng ká̱ onəm oga aIsa̱rila ka̱t, oHivi na byet, ova ka̱ ntəm ka̱ aGibiyon á. Nkpaktak aɓoshi itong te, oIsa̱rila ri ká̱ ìkum.  
\v 20 Ka̱kul uYawe uwa nak igwak oza̱ twat, na oza̱ a ɓa ká̱ ìkum ka̱ oIsa̱rila, na ô zhì oza̱ pa̱ chatchat, ô zhì oza̱ nzəng ká̱ nyam nrusok afu ka̱t, wa nva uYawe ka̱ nak uMusa á. 
\p  
\v 21 Ka̱ awalang va ta uJoshuwa ga zhì oAnakim, ova ka̱ ntəm ka̱ ashe mbin ngga aɗuktum, aHebron, ká̱ aDebir, ká̱ aAnap, ká̱ nkpaktak mbin ngga aɗuktum oYahuda, ká̱ nkpaktak mbin ngga aɗuktum oIsa̱rila. uJoshuwa zhì oza̱ pa̱ chatchat ká̱ itong oza̱.  
\v 22 Unəm uro yà le ka̱ ashe oAnakim va̱ ka̱ ntəm ka̱ ashe mbin oIsa̱rila ka̱t. Ka̱ aGaza, ká̱ aGat, ká̱ aAshdot na byet, aɓo oro le.  
\v 23 Te uJoshuwa nəm igwan ká̱ nkpaktak mbin va̱ ta, wa nva uYawe ka̱ là ûMusa. Kang uJoshuwa na mbin va̱ ta iya̱mkup ôIsa̱rila ka̱ atak oga akum ìjili oza̱. Te mbin va̱ ta jul ka̱ ìkum. 
\c 12  
\s1 Oponzhi va uMusa ri ká̱ ìkum 
\p  
\v 1 OPonzhi va ta̱ ka̱ ashe oga mbin va̱ onəm oga aIsa̱rila ka̱ ri ká̱ ìkum, ova oza̱ ka̱m mbin oza̱ ka̱ asa̱l nfa alum agwong aUrdun, a ɓan ka̱ mba̱nda̱m ngga aArnon ga chu aƁam aHermon, nzəng ká̱ nkpaktak asa̱l nfa alum aAraba.  
\v 2 USihon uponzhi oAmori, uva ka̱ nəm iponzhi ka̱ aHeshbon. Iponzhiponzhi ɓan ka̱ aAroyer, va kà̱ nkur mba̱nda̱m aArnon, ɓan ká̱ ishimshe aba̱nda̱m va̱ ta ga chu awang aJabok ka̱ aswari oAmmon. Oga mbin va ta̱ nzəng ká̱ nkap kà̱ ishimshe aGileyat.  
\v 3 Uza̱ nəm iponzhi kpa ka̱ nkap mbin aAraba ka̱ asal nfa alum, a ɓan kà̱ ìWa aGalili, lyam ga ìWa aAraba, nna ìWa mMan\f + \fr 12.3 \ft Nna mí wor pa̱ ìWa iKú kpa\f* á, ka̱ asa̱l nfa alum aBet Jeshimot, ka̱ asa̱l nkwandal ka̱ nkwangtal avəng aɓam aPisga. 
\m  
\v 4 Ká̱ mbin aOg uponzhi uga aBashan, Uzəngtəng ka̱ ashe aɓo onəm aRefayim, uva ka̱ nəm iponzhi ka̱ aAshtarot ká̱ aEdireyi á. 
\mi  
\v 5 Uza̱ nəm iponzhi ká̱ nkap mbin aɓam aHermon, ká̱ aSaleka, ká̱ nkpaktak aBashan ga chu aswari oGeshuri, ká̱ oMakati, ká̱ nkap ka̱ ishimshe aGileyat ga chu aswari aSihon uponzhi uga aHeshbon. 
\p  
\v 6 UMusa, uzwal aYawe, ká̱ onəm oga aIsa̱rila ri oza̱ ká̱ ìkum. Kang uMusa, uzwal aYawe na mbin oza̱ iya̱mkup akum ìjili aRuben, ká̱ uGat, ká̱ nkap ka̱ ishimshe akum ìjili aManase. 
\s1 Oponzhi va uJoshuwa ri ká̱ ìkum 
\p  
\v 7 Oponzhi va ta̱ oma mbin oza̱ uJoshuwa ka̱ onəm oga aIsa̱rila ri ká̱ ìkum ka̱ asa̱l ntar alum agwong aUrdun, ɓan ka̱ aBal Gat ka̱ mba̱nda̱m aLebanon ga chu aɓam aHalak, va̱ ga asa̱l aSeyir. Kang uJoshuwa na mbin oza̱ ôIsa̱rila sat iya̱mkup oza̱, ka̱ atak nkap akum ìjili oza̱.  
\v 8 Oga mbin nva̱ ta̱ nzəng ká̱ mbin ngga aɗuktum, ká̱ oga avan aɗuktum, ká̱ aAraba, ká̱ mba̱nda̱m, ká̱ ashe ǹzam, kang ká̱ aNegep. Oma oga mbin oHitti, ká̱ oAmori, ká̱ oKanana, ká̱ oPerizi, ká̱ oHivi, kang ká̱ oJebusi.  
\v 9 Oponzhi va̱ ta̱ te, oma uponzhi uga aJariko, ká̱ uponzhi uga aAyi, uva datkulung ká̱ aBetel,  
\v 10 ká̱ uponzhi uga aUrushelima, ká̱ uponzhi uga aHebron,  
\v 11 ká̱ uponzhi uga aJarmut, ká̱ uponzhi uga aLakish,  
\v 12 ká̱ uponzhi uga aEglon, ká̱ uponzhi uga aGezer,  
\v 13 ká̱ uponzhi uga aDebir, ká̱ uponzhi uga aGeder,  
\v 14 ká̱ uponzhi uga aHorma, ká̱ uponzhi uga aArat,  
\v 15 ká̱ uponzhi uga aLibna, ká̱ uponzhi uga aAdulam,  
\v 16 ká̱ uponzhi uga aMakeda, ká̱ uponzhi uga aBetel,  
\v 17 ká̱ uponzhi uga aTapuwa, ká̱ uponzhi uga aHefer,  
\v 18 ká̱ uponzhi uga aAfek, ká̱ uponzhi uga aLasharon,  
\v 19 ká̱ uponzhi uga aMadon, ká̱ uponzhi uga aHazor,  
\v 20 ká̱ uponzhi uga aShimron Meron, ká̱ uponzhi uga aAkshap,  
\v 21 ká̱ uponzhi uga aTanak, ká̱ uponzhi uga aMegido,  
\v 22 ká̱ uponzhi uga aKedesh, ká̱ uponzhi uga aJokneyam ka̱ aKarmel,  
\v 23 ká uponzhi uga aDor ka̱ aNaphot Dor, ká̱ uponzhi uga aGoyim ka̱ aGilgal,  
\v 24 ká̱ uponzhi uga aTirza, pa̱ kpaktak te, oponzhi ìsəm pa̱ ishatɗing ama̱n pa̱ zəng. 
\c 13  
\s1 Mbin nva nna mmá ri chit ka̱t 
\p  
\v 1 Ka̱ awalang va̱ uJoshuwa gbák chit pa̱ gənggəng te, uYawe là á na pa̱, <<U gbák chit pa̱ gənggəng, kang mbín nna re pa̱ makmak nva̱ nna o ri chit ka̱t. 
\p  
\v 2 <<Oga mbin va ta̱ oma ɓur, nkpaktak nkap mbin oFilisti, ká̱ oGeshuri,  
\v 3 ɓan ka̱ Awang aShihor nna ka̱ asa̱l nfa alum aMasar, ga chu mbin aEkron ka̱ mpal, mmá kung oza̱ wa mbin oKanana. Oma mbin oponzhi pa̱ otukun oji oFilisti va̱ i nəm iponzhi ka̱ aGaza, ká̱ aAshdot, ká̱ aAshkelon, ká̱ aGat, kang ká̱ aEkron va̱ ka̱ mbin oAvi,  
\v 4 ka̱ asa̱l nkwandal. Nkpaktak mbin oKanana, va̱ ɓan ka̱ aMeyara va aji oSidon ga aAfek, ɓa chu aswari oAmori,  
\v 5 kang mbin oGebali, ká̱ nkpaktak aLebanon, ka̱ asa̱l nfa alum, ɓan ka̱ aBal Gat ka̱ avəng aƁam aHermon ga aLebo Hamat. 
\p  
\v 6 <<Nkpaktak onəm oga ntəm ka̱ oga nkap mbin ngga aɗuktum ɓan ka̱ aLebanon ga chu aMisrefot Mayim, nnà nkpaktak oSidon, te mmami ka̱ ishi mi, mi ɓak oza̱ ka̱ mpyal onəm oIsa̱rila. Ɗak na u kap mbin va̱ ta ôIsa̱rila a təm iya̱mkup oza̱, wa nva n nak ɓu á.  
\v 7 Ǹyangmata̱ te, kap mbin va̱ ta̱ iya̱mkup akum ìjili pa̱ fangzəngtəng va̱ ta̱ ká̱ nkap ka̱ ishimshe akum ìjili aManase.>> 
\s1 Nkap mbin va̱ ka̱ asa̱l nfa alum aUrdun 
\p  
\v 8 Aɓo nkap ka̱ ishimshe akum aManase, ká̱ oRuben, ká̱ oGat, ka̱ ka̱m iya̱mkup iji oza̱ chit nna uMusa ka̱ na ôza̱ ka̱ agwong aUrdun ka̱ asa̱l nfa alum. Iya̱m va ta na uMusa uzwal aYawe na ôza̱. 
\p  
\v 9 Mbin oza̱ ɓan ka̱ aAroyer va̱ ka̱ nkur mba̱nda̱m ngga aArnon, kang a ɓan ká̱ ìtong va̱ ká̱ ishimshe aba̱nda̱m va̱ ta, ka̱ nkpaktak agbagba aga aMedeba ga chu aDibon.  
\v 10 Kang ká̱ nkpaktak itong iji aSihon uponzhi oAmori, uva nəm iponzhi ka̱ aHeshbon, ga chu aswari onəm oAmmon.  
\v 11 Nzəng ká̱ aGileyat, ká̱ mbin oGeshuri, ká̱ oMakati, nkpaktak aƁam aHermon, kang ká̱ nkpaktak aBashan ga chu aSaleka,  
\v 12 nnà nkpaktak atak iponzhi aOg ka̱ aBashan, uva ka̱ nəm iponzhi ka̱ aAshtarot kang ká̱ aEdreyi. UOg uwa uga nkur anung ka̱ ashe oRefayim. Oma uMusa ka̱ ri oza̱ ká̱ ìkum kang a ɓàk oza̱.  
\v 13 Ǹnyi te, onəm oIsa̱rila ɓàk oGeshuri ká̱ oMakati ka̱t, nnà nak kang, oma ka̱ ntəm ka̱ ashe oIsa̱rila ɓa chu nda va̱ ta̱. 
\p  
\v 14 Ǹnyi te, akum ìjili aLawi na byet uMusa na iya̱mkup á na ka̱t. Ka̱ɗor nva̱ ta te, oza̱ i ya iya̱m-nrì oza̱ ka̱ atak oga iya̱m inana nləfər ûYawe, Inan oIsa̱rila, nna ta iya̱mkup iji oza̱, wa nva uYawe là ôza̱. 
\m  
\v 15 UMusa ka̱ na iya̱mkup chit âkum ìjili aRuben ka̱ atak oga akum oza̱. 
\p  
\v 16 Aswari oza̱ ɓan ka̱ aAroyer, va ka̱ nkur mba̱nda̱m ngga aAmon, kang kà̱ ìtong va̱ ka̱ ishimshe aba̱nda̱m va̱ ta, ká̱ nkpaktak agbagba va̱ lyam aMedeba,  
\v 17 ga aHeshbon, ká̱ nkpaktak itutong va̱ ka̱ agbagba, nna aDibon, ká̱ aBamot Bal, ká̱ aBet Bal Meyon,  
\v 18 ká̱ aJahaz, ká̱ aKedemot, ká̱ aMefayat,  
\v 19 ká̱ aKiriyatayim, ká̱ aSibmak, ká̱ aZeret Shahar va ka̱ apal aɗuktum ka̱ ashe mba̱nda̱m va̱ ta,  
\v 20 ká̱ aBet Peyor, mba̱nda̱m ngga aPisga, ká̱ aBet Jeshimot,  
\v 21 ká̱ nkpaktak itong va̱ ka̱ agbagba va̱ ta̱, kang ká̱ nkpaktak mbin iponzhi aSihon, uponzhi uga oAmori, uva nəm iponzhi ka̱ aHeshbon. UMusa ka̱ ri na ká̱ ìkum ká̱ onəm oga mpyal oMidiyan, uEvi ká̱ uRekem, ká̱ uZur ká̱ uHur, ká̱ uReba, oma ovan oponzhi va̱ kà̱ ntəm nzəng ká̱ uSihon ka̱ ashe nkap mbin va̱ ta.  
\v 22 Kang uBalam, uya aBeyor, unəm uga nəm iva̱k, uwa yà ka̱ ashe onəm va̱ oIsa̱rila gbá̱ng ká̱ ndokchi kpa.  
\v 23 AUrdun nna aswari akum ìjili aRuben. Itong va̱ ta̱ ká̱ ivan itong oza̱ nna iya̱mkup akum ìjili aRuben ka̱ atak akum oza̱. 
\m  
\v 24 UMusa ka̱ na iya̱mkup chit âkum ìjili aGat kpa, uza̱ na oza̱ ka̱ atak akum oza̱. 
\p  
\v 25 Aswari oza̱ nna aJazer ká̱ nkpaktak itong aGileyat, ká̱ nkap ìshimshe mbin oAmori ga chu aAroyer va ka̱ asa̱l nfa alum dat ká̱ aRaba,  
\v 26 kang ɓan ka̱ aHeshbon ga aRamat Mizpa ká̱ aBetonim, kang ɓan ka̱ aMahanayim ɓa chu aswari aga aDebir.  
\v 27 Ká̱ mba̱nda̱m va̱ aBet Haram, aBet Nimra, aSukkot, ká̱ aZafon, ká̱ aɓo nkap mbin aSihon, uponzhi uga aHeshbon, awang aUrdun nna nkur aswari mbin oza̱, vang asa̱l mpal ìWa aGalili\x - \xo 13.27 \xt AJosh 12.3\x*, kang le ga asa̱l nfa alum.  
\v 28 Itong va̱ ta̱ ká̱ ivan itong oza̱ nna iya̱mkup akum ìjili aGat ka̱ atak oga akum oza̱. 
\m  
\v 29 UMusa ka̱ na iya̱mkup chit n̂kap ká̱ ìshimshe akum ìjili aManase, ka̱ atak oga akum oza̱. 
\p  
\v 30 Aswari oza̱ ɓan ka̱ aMahanayim, kang nzəng ká̱ nkpaktak aBashan, nkpaktak nkap mbin iponzhi aOg uponzhi uga aBashan, ká̱ nkpaktak itong ìsəm pa̱ ikpa̱ɗing iga aJayir ka̱ aBashan,  
\v 31 kang nkap ká̱ ìshimshe aGileyat, ká̱ aAshtarot, ká̱ aEdreyi, itong iga nnəm iponzhi aOg ka̱ aBashan. Nkpaktak itong va̱ ta̱ mmá na âkum ìjili aMakir uya aManase ununggwan ka̱ atak oga akum oza̱. 
\p  
\v 32 Ka̱ asa̱l va ta̱ uMusa kap iya̱mkup ká̱ ka̱ agbagba aMowap, ka̱ gwong aUrdun ka̱ asa̱l nfa alum aJariko.  
\v 33 Ǹnyi te, uMusa na iya̱mkup akum ìjili aLawi ka̱t. ka̱kul uYawe, Inan oIsa̱rila uwa iya̱mkup oza̱, wa nva uza̱ ka̱ yar nsar nnap-nlà ôza̱. 
\c 14  
\s1 Mmá kap mbin va̱ ka̱ asa̱l ntar alum awang aUrdun 
\p  
\v 1 Oga atak va ta̱ mma na onəm oga oIsa̱rila iya̱mkup, ka̱ ashe mbin aKanana, va uEleyazar, unəm uga mpyal awop, ká̱ uJoshuwa uya aNun ununggwan, ká̱ onəm oga mpyal akum ìjili oIsa̱rila kap ôza̱ iya̱mkup.  
\v 2 Wa nva uYawe ka̱ nak ûMusa te, akum ìjili aga fangzəngtəng va̱ ta̱ ká̱ nkap kà̱ ìshimshe akum ìjili ka̱m iya̱mkup iji oza̱ ká̱, ka̱ asa̱l ntar alum ka̱ atak mmàng ayàk.  
\v 3 Ka̱kul uMusa ka̱ na iya̱mkup chit âkum ìjili aga aparəm ká̱ nkap kà̱ ìshimshe akum ìjili va̱ ta ka̱ asa̱l nfa alum awang aUrdun, ǹnyi te, uza̱ na iya̱mkup oLawi ka̱ ashe aɓo oga akum ìjili jiwò ka̱t.  
\v 4 Akum ìjili aYusufu, kap akum pa̱ parəm, uManase ká̱ uEfrayim. Mmá na iya̱mkup ôLawi ka̱ ashe mbin va̱ ta ka̱t, ka̱ɗor nva̱ ta te, mmá na itong oza̱ iva̱ oza̱ i təm kà̱, ká̱ oga ǹzam ka̱kul nkpak ina ká̱ iya̱mkang oza̱.  
\v 5 OIsa̱rila kap mbin va̱ ta, wa nva uYawe ka̱ nak uMusa á. 
\s1 Mmá na aHebron ûKalip 
\p  
\v 6 N̂da nro te, onəm oga aYahuda ɓa atak aJoshuwa ka̱ aGilgal, kang uKalip uya aJefune unəm oKeni, là á na pa̱, << Rəng ká̱ nnap-nlà va̱ uYawe ka̱ là ûMusa, unəm Inan ka̱ apal mi ka̱ ɓu, ka̱ aKadesh Barneya.  
\v 7 Mmami ká̱ ìzun ìsəm pa̱ ineɗing awalang va̱ uMusa, uzwal aYawe ka̱ re mi ka̱ aKadesh Barneya pa̱ n sòng mbin va̱ ta. Kang m ɓa ká̱ ama̱n aga nnandər va̱ ka̱ ashe igwak mi.  
\v 8 Ǹnyi te, ogənang mi va̱ ga nzəng ka̱ mi nak igwak onəm rusok. Ka̱ nna te, n kpán uYawe, Inan mi ká̱ nkpaktak ìgwak mi.  
\v 9 Te n̂da va̱ ta uMusa sóng anung a mi pa̱, <Nkpaktak mbin va̱ ashar ɓu tongchi kà̱ te, i təm iya̱mkup ɓu ká̱ ovan ɓu mbyet, ka̱kul u kpán uYawe Inan mi ká̱ nkpaktak ìgwak ɓu.> 
\p  
\v 10 <<Dər, wa nva̱ uYawe ka̱ yar nsar nnap-nlà te, uwa a re mi ká̱ irirì ìzun ìsəm pa̱ ineɗing ama̱n pa̱ tukun, á ɓan ka̱ awalang va̱ uza̱ là nnap-nlà va̱ ta̱ ûMusa, ya oIsa̱rila oma ka̱ nranggang ka̱ ashe nzam. Kang ǹyangmata̱ te, mmami ká̱ ìzun ìsəm pa̱ ina̱nne ama̱n pa̱ tukun.  
\v 11 N̂da ta̱ na nkəkam wa nra va̱ uMusa ka̱ re mi ká̱, kang ǹyangmata̱ nna n yà ká̱ ìkàm iga ngga ìkum wa nva ka̱ n yà matmat á.  
\v 12 Ǹyangmata̱ te, na mbin ngga aɗuktum va̱ ta̱ a mi, wa nva uYawe ka̱ yar nsar nnap-nlà a mi ká̱ nda va̱ ta. Mmaɓu ká̱ ishi ɓu, ka̱ u fife pa̱ oAnakim oma ka̱ ta, ká̱ inang itong oza̱ iva ká̱ akamsəlang. Ǹnyi te, ká̱ nka̱mshi aYawe te, mi ɓak oza̱ wa nva uza̱ ka̱ là á.>> 
\p  
\v 13 Te uJoshuwa nak nnap-nnəna̱n ûKalip, uya aJefune ununggwan kang uza̱ na aHebron á na sat iya̱mkukup.  
\v 14 Te aHebron təm iya̱mkup akum ìjili aKalip uya aJefune ununggwan unəm oKeni ɓa chu nda va̱ ta̱, ka̱kul uza̱ kpán uYawe, Inan oIsa̱rila ká̱ nkpaktak ìgwak wò.  
\v 15 Ká̱ mmatmat te, mí wor aHebron pa̱ aKiriyat Arba. UArba va̱ ta te, unəm uchumchum ka̱ ashe oAnakim. Te mbin va̱ ta jul ká̱ nlung ìkum. 
\c 15  
\s1 Mbin va mmá na âkum ìjili aYahuda 
\p  
\v 1 Mbin va̱ mmá na akum ìjili aYahuda ka̱ atak akum oza̱ te, a ɓan ka̱ nkwandal aswari nkap mbin aEdom, a ga chu nkwandal nzam aZin.  
\v 2 Aswari oza̱ aga nkwandal ɓan ka̱ nkur akongkong ìWa mMan\f + \fr 15.2 \ft Nna mí wor pa̱ ìWa iKú\f*, va dər nkwandal,  
\v 3 a ga mpyal ka̱ nkwandal ka̱ asa̱l aAkrabim, watar ga nzam aZin, ga nkwandal ká̱ aKadesh-Barneya, a watar asa̱l aHezron kyen ga aAdar kang ga̱ɓa̱n ga aKarka.  
\v 4 Te a watar ga aAzmon, wòl aWang aMasar a ɓa kur ka̱ ìwa aMeditereniya. Nna ta aswari oza̱ aga asa̱l nkwandal.  
\v 5 Aswari aga asa̱l nfa alum a ɓan ka̱ ìWa mMan\f + \fr 15.5 \ft Nna mí wor pa̱ ìWa iKú\f*, a ɓa anung aUrdun. Aswari aga asa̱l mpal te, a ɓan ka̱ anung ìWa mMan\f + \fr 15.5 \ft Nna mí wor pa̱ ìWa iKú\f* ka̱ atak va̱ aWang aUrdun i nang iga ashe ìwa.  
\v 6 Te aswari va̱ ta kyen ɓa aBet-Hogla a ga asa̱l mpal aBet-Araba, a le kyen ga ìPang aBohan, uya aRuben ununggwan.  
\v 7 Aswari kyen ga aDebir ɓan ka̱ mba̱nda̱m ngga aAkor, kang a ga̱ɓa̱n asa̱l mpal ga aGilgal, va mal ikoksok ká̱ asa̱l aAdummim va ka̱ nkwandal ngba̱k mba̱nda̱m va̱ ta. Te aswari va̱ ta watar ga atak mɓəl ndəng aEn-Shemesh a ɓa fa ka̱ aEn-Rogel.  
\v 8 Te aswari kyen ga mba̱nda̱m aBen-Hinnom ka̱ asa̱l nkwandal aba̱nda̱m oJebusi, nna aUrushelima á. A wong ka̱ ta te, a kyen ga apal aɗuktum va̱ ka̱ asa̱l ntar alum aba̱nda̱m aHinnom ka̱ asa̱l mpal nkur mba̱nda̱m ngga aRefayim.  
\v 9 A wong ka̱ apal aɗuktum te, aswari va̱ ta lyam ga atak mɓəl ndəng ngga aNeptowa, te a fa ga itong va̱ dat ká̱ aƁam aEpron, kang a ga̱ɓa̱n ga aBayala, nna aKiriyat-Jeyarim.  
\v 10 Te a kandar ga asa̱l ntar alum aBayala ga aƁam aSeyir, te a wol asa̱l mpal aƁam aJeyarim, nna aKesalon á, kang a fə́r ga aBet-Shemesh, te a watar ga aTimna.  
\v 11 A watar ga nkwangtal aEkron ka̱ asa̱l mpal, kang a ga̱ɓa̱n ga aShikkeron, te a lyam ka̱ ngba̱k aƁam aBayala, a ga chu aJabneyel. Te aswari va̱ ta ɓa kur ka̱ ìWa aMeditereniya.  
\v 12 Kang aswari aga asa̱l ntar alum, ka̱ inang ìwa va̱ ta. 
\p Nnà ta aswari va̱ gang akum ìjili aYahuda ka̱ atak akum oza̱. 
\s1 UKalip ri aHebron ká̱ aDebir ká̱ ìkum 
\p  
\v 13 Wa nva uYawe ka̱ nak ûJoshuwa te, uza̱ kpál atak ka̱ ashe mbin onəm aYahuda na ûKalip uya aJefune ununggwan. Kang uza̱ na aKiriyat-Arba á na, nna mí wor pa̱ aHebron. UArba te, uwa upo oAnakim.  
\v 14 Te uKalip ɓak akum aAnak pa̱ oshatɗing ka̱ aHebron, oma uSheshayi, ká̱ uAhiman, ká̱ uTalmayi.  
\v 15 Uza̱ wong ka̱ ta te, uza̱ ga ru onəm oga ntəm ka̱ aDebir ká̱ ìkum, ka̱ yà te, mí wor aDebir pa̱ aKiriyat-Sefer.  
\v 16 Kang uKalip là pa̱, <<Unəm va pa̱ kap a ri aKiriyat-Sefer ká̱ ìkum te, mi na uyen mi uAksa á na kà̱ ivang.>>  
\v 17 UOtniyel uya aKenaz ununggwan, ugənang aKalip ri ìtong va̱ ta ká̱ ìkum. Te uKalip na uyen wò uchar uAksa á na kà̱ ivang. 
\p  
\v 18 Ka̱ nva̱ngva̱ uza̱ ga atak aɓar wò te, uza̱ nok na pa̱ uza̱ á ɓəp iram ka̱ upo wò. Awalang va̱ uAksa fər ka̱ apal azhaki wò te, uKalip ɓəp na pa̱, <<Iza̱ mi nəm a ɓu yà?>> 
\p  
\v 19 Uza̱ na ama̱n a na pa̱, <<pa̱r mi, ka̱kul u na mbin a mi chit ka̱ aNegep\f + \fr 15.19 \ft Atak va yà ká̱ ndəng ka̱t\f*, n chal pa̱ u na oga atak mɓəl ndəng á mi kpa.>> Te uKalip na oga atak aga mɓəl ndəng á na ngga apal ká̱ ngga avəng. 
\p  
\v 20 Iya̱mkup onəm aYahuda nnà ta̱ ka̱ atak akum oza̱. 
\m  
\v 21 Itong va ta̱ mmá na akum ìjili aYahuda iva ka̱ asa̱l nkwandal va̱ datkulung ká̱ aswari aEdom, oma aKapzeyel, ká̱ aEder, ká̱ aJagur,  
\v 22 ká̱ aKina, ká̱ aDimona, ká̱ aAdada,  
\v 23 ká̱ aKadesh, ká̱ aHazor, ká̱ aItnan,  
\v 24 ká̱ aZip, ká̱ aTelem, ká̱ aBeyalot,  
\v 25 ká̱ aHazor-Hadata, ká̱ aKiriyot-Hezron, nna aHazor á,  
\v 26 ká̱ aAmam, ká̱ aShema, ká̱ aMolada,  
\v 27 ká̱ aHazar-Gada, ká̱ aHeshmon, ká̱ aBet-Pelet,  
\v 28 ká̱ aHazar-Shuwal, ká̱ aBeyersheba, ká̱ aBiziyotiya,  
\v 29 ká̱ aBayala, ká̱ aLim, ká̱ aEzem,  
\v 30 ká̱ aEltolat, ká̱ aKesil, ká̱ aHorma,  
\v 31 ká̱ aZiklak, ká̱ aMatmanna, ká̱ aSansanna,  
\v 32 ká̱ aLebayot, ká̱ aShilhim, ká̱ aAyin, ká̱ aRimmon. Pa̱ kpaktak te, itong ìsəm pa̱ iparəm ama̱n pa̱ fangzəngtəng nzəng ká̱ ivan itong oza̱. 
\m  
\v 33 Itong iga avan aɓam te, oma aEshtawol, ká̱ aZora, ká̱ aAshna,  
\v 34 ká̱ aZanowa, ká̱ aEn-Ganim, ká̱ aTapuwa, ká̱ aEnam,  
\v 35 ká̱ aJarmut, ká̱ aAdulam, ká̱ aSoko, ká̱ aAzeka,  
\v 36 ká̱ aShayarayim, ká̱ aAditayim, ká̱ aGedera, ká̱ aGederotayim. Pa̱ kpaktak te, itong pa̱ igba̱pchi ama̱n pa̱ neɗing nzəng ká̱ ivan itong oza̱. 
\p  
\v 37 Mmá na itong va̱ ta̱ âkum ìjili aYahuda kpa, oma aZenan, ká̱ aHadasha, ká̱ aMikdal-Gat,  
\v 38 ká̱ aDileyan, ká̱ aMizpa, ká̱ aJokteyel,  
\v 39 ká̱ aLakish, ká̱ aBozkat, ká̱ aEglon,  
\v 40 ká̱ aKapbon, ká̱ aLahmas, ká̱ aKitlish,  
\v 41 ká̱ aGederot, ká̱ aBet-Dagon, ká̱ aNayama, ká̱ aMakeda. Pa̱ kpaktak te, itong pa̱ igba̱pchi ama̱n pa̱ kpa̱ɗing nzəng ká̱ ivan itong oza̱. 
\p  
\v 42 Mmá na itong va̱ ta̱ âkum ìjili aYahuda kpa, oma aLibna, ká̱ aEter, ká̱ aAshan,  
\v 43 ká̱ aIpta, ká̱ aAshna, ká̱ aNezip,  
\v 44 ká̱ aKeyila, ká̱ aAkzip, ká̱ aMaresha. Pa̱ kpaktak te, itong pa̱ fangzəngtəng nzəng ká̱ ivan itong oza̱. 
\p  
\v 45 Mmá na aEkron ká̱ itong va̱ gáng na nzəng ká̱ ivan itutong âkum ìjili aYahuda kpa,  
\v 46 ká̱ nkpaktak itong va̱ datkulung ká̱ aAshdot, ɓan ka̱ ntar alum aEkron nzəng ká̱ ivan itong oza̱.  
\v 47 AAshdot, ká̱ itutong nzəng ká̱ ivan itutong, kang aGaza, ká̱ itutong nzəng ká̱ ivan itutong, a ga chu aWang aMasar, ká̱ anung ìWa aMeditereniya. 
\m  
\v 48 Mmá na itong âkum ìjili aYahuda ka̱ ashe mbin ngga aɗuktum kpa, oma aShamir, ká̱ aJatir, ká̱ aSoko,  
\v 49 ká̱ aDanna, ká̱ aKiriyat-Sefer, nna aDebir á,  
\v 50 ká̱ aAnap, ká̱ aEshtemo, ká̱ aAnim,  
\v 51 ká̱ aGoshen, ká̱ aHolon, ká̱ aGilo. Pa̱ kpaktak te, itong pa̱ igba̱pchi ama̱n pa̱ zəng nzəng ká̱ ivan itong oza̱. 
\p  
\v 52 Mmá na itong va̱ ta̱ âkum ìjili aYahuda kpa, oma aArap, ká̱ aDuma, ká̱ aEshan,  
\v 53 ká̱ aJanim, ká̱ aBet-Tapuwa, ká̱ aAfeka,  
\v 54 ká̱ aHumta, ká̱ aKiriyat-Arba, nna aHebron á, ká̱ aZiyor. Pa̱ kpaktak te, itong pa̱ fangzəngtəng nzəng ká̱ ivan itong oza̱. 
\p  
\v 55 Mmá na itong va̱ ta̱ âkum ìjili aYahuda kpa, oma aMayon, ká̱ aKarmel, ká̱ aZip, ká̱ aJutta,  
\v 56 ká̱ aJezireyel, ká̱ aJokdeyam, ká̱ aZanowa,  
\v 57 ká̱ aKayin, ká̱ aGibeya, ká̱ aTimna. Pa̱ kpaktak te, itong pa̱ igba̱pchi ká̱ ivan itong oza̱. 
\p  
\v 58 Mmá na itong va̱ ta̱ âkum ìjili aYahuda kpa, oma aHalhul, ká̱ aBet-Zur, ká̱ aGedor,  
\v 59 ká̱ aMayarat, ká̱ aBet-Anot, ká̱ aEltekon. Pa̱ kpaktak te, itong pa̱ ìkpa̱ɗing nzəng ká̱ ivan itong oza̱. 
\p  
\v 60 Mmá na itong va̱ ta̱ âkum ìjili aYahuda kpa, oma aKiriyat-Bayal, nna aKiriyat-Jeyarim á, ká̱ aRapba. Pa̱ kpaktak te, itong pa̱ iparəm nzəng ká̱ ivan itong oza̱. 
\m  
\v 61 Mmá na itong âkum ìjili aYahuda kpa ka̱ ashe ǹzam, oma aBet-Araba, ká̱ aMitdin, ká̱ aSekaka,  
\v 62 ká̱ aNipshan, ká̱ ìtong iga Mman, ká̱ aEn-Gedi. Pa̱ kpaktak te, itong pa̱ ìkpa̱ɗing nzəng ká̱ ivan itong oza̱. 
\p  
\v 63 Ǹnyi te, oJebusi va̱ ka̱ ntəm ka̱ aUrushelima te, a ma̱t onəm aYahuda ka̱ mɓak nfa, a nak te, oJebusi oma ka̱ ntəm nzəng ká̱ onəm aYahuda ka̱ ashe aUrushelima nda va̱ ta̱. 
\c 16  
\s1 Mbin va mmá na ûEfrayim ká̱ ûManase 
\p  
\v 1 Mbin va̱ mmá na akum ìjili aYusufu te, ɓan ka̱ aUrdun ka̱ asa̱l nfa alum oga atak mɓəl ndəng ngga aJariko, a kyen ga nzam mmaləng a ɓa chu mbin ngga aɗuktum ngga aBetel.  
\v 2 A wong ka̱ aBetel, nna aLuz á, kang a watar ɓa chu aAtarot ka̱ mbin oArki.  
\v 3 Te a kwangtal ga asa̱l ntar alum ɓa chu mbin oJapleti, ga chu nkap mbin aBet-Horon ngga aVəng te, a lyam ga aGezer kang a kur ka̱ ìWa aMeditereniya. 
\m  
\v 4 Te akum ìjili aYusufu, uManase ká̱ uEfrayim, ka̱m iya̱mkup iji oza̱. 
\m  
\v 5 Mbin va ta̱ ka̱ yà nji aEfrayim ka̱ atak oga akukum. 
\p Aswari aga mbin ngga iya̱mkup oza̱, wong ka̱ aAtarot-Atdar ka̱ asa̱l nfa alum a kyen ga aBet-Horon aga aPal,  
\v 6 te aswari va̱ ta fa ga ìWa aMeditereniya. Ka̱ aMikmetat ka̱ asa̱l mpal te, a ga̱ɓa̱n ga asa̱l nfa alum a ɓa chu aTanat-Shilo, te a watar ka̱ asa̱l nfa alum ɓa chu aJanowa.  
\v 7 A wong ka̱ aJanowa te, a kwangtal ga aAtarot ká̱ aNayara, te a ga gwang aJariko, kang a ga fa ka̱ aUrdun.  
\v 8 Ka̱ aTapuwa te, aswari wòl asa̱l ntar alum ga aWang aKana, kang a kur ka̱ ìWa aMeditereniya. Nnà ta̱ ka̱ yà iya̱mkup akum ìjili aEfrayim ka̱ atak oga akukum.  
\v 9 Mbin va̱ ta gwang ká̱ nkpaktak itong nzəng ká̱ ivan itong oza̱ va̱ mmá ka̱ re ka̱kul akum ìjili aEfrayim ka̱ ashe iya̱mkup akum ìjili aManase. 
\m  
\v 10 Oza̱ ɓàk oKanana va̱ ka̱ ntəm ka̱ aGezer ka̱t, ka̱kul nva̱ ta te, oKanana oma ka̱ ntəm nzəng ká̱ oEfrayim nda ta̱. Ǹnyi te, mmá nak nkpak ôza̱ pa̱ a nəm inok wa ozwal. 
\c 17  
\p  
\v 1 Mmá na iya̱mkup âkum ìjili aManase, uya aYusufu uga nggəshi. Mmá na aGileyat ká̱ aBashan ûMakir uya aManase uga nggəshi upo oGileyat, ka̱kul pa̱ oza̱ ununggwan ìkum okamkam.  
\v 2 Te mmá kap iya̱mkup aɓo onəm aManase ka̱ atak akum oza̱, oma uAbiyezer, ká̱ uHelek, ká̱ uAsriyel, ká̱ uShekem, ká̱ uHefer, ká̱ uShemida. Oma ta̱ ovan aManase onunggwan uya aYusufu, ka̱ atak akum oza̱. 
\p  
\v 3 Ǹyangmata̱ te, uZelofehat uya aHefer ununggwan, uya aGileyat ununggwan, uya aMakir ununggwan, uya aManase ununggwan yà ka̱ ovan onunggwan ka̱t. Ǹnyi te, ovan ochar ma chwat, oma aɗin oza̱ pa̱, uMala, ká̱ uNowa, ká̱ uHokla, ká̱ uMilka, ká̱ uTirza.  
\v 4 Oza̱ ga atak aEleyazar unəm uga mpyal awop, ká̱ uJoshuwa uya aNun ununggwan, ká̱ onəm oga mpyal, oza̱ là pa̱, <<UYawe nak uMusa pa̱ á na iya̱mkup a yi nzəng ká̱ ogənang yi>> Te uJoshuwa na iya̱mkup ôza̱ nzəng ká̱ ogənang apo oza̱ onunggwan, wa nva uYawe nak á.  
\v 5 UManase yà nkap pa̱ ngba̱pchi, nzəng ká̱ mbin aGileyat ká̱ aBashan, va̱ ka̱ asa̱l nfa alum agwong aUrdun,  
\v 6 ka̱kul ovan ochar oga akum ìjili aManase yà iya̱mkup nzəng ká̱ ovəvan onunggwan. Mbin aGileyat təm nji aɓo akum ìjili aManase.  
\v 7 Mbin aManase ɓan ka̱ aAsher a ɓa chu aMikmetat va ka̱ asa̱l nfa alum aShekem á. Kang aswari va̱ ta fa ga asa̱l nkwandal gwang ká̱ onəm oga ntəm ka̱ aEn-Tapuwa.  
\v 8 Mbin ngga aTapuwa te, nji aManase, ǹnyi te, ìtong iga aTapuwa ka̱ aswari aManase te, iji onəm aEfrayim.  
\v 9 Te aswari lyam ga aWang aKana. Itong na yà iji aEfrayim ka̱ ashe itong aManase. Ǹnyi te, aswari aManase wòl ngba̱k ngga asa̱l mpal awang, kang a ga kur ka̱ ìWa aMeditereniya.  
\v 10 Mbin ngga asa̱l nkwandal te, nji aEfrayim, kang ngga asa̱l mpal te, nji aManase. Mbin aManase ga chu ìWa aMeditereniya, kang a nəm aswari ká̱ aAsher ka̱ asa̱l mpal, kang ká̱ aIsakar ka̱ asa̱l nfa alum.  
\v 11 Ka̱ ashe mbin akum ìjili aIsakar ká̱ aAsher te, uManase uwa ká̱ aBet-Sheyan, ká̱ aIbleyam, ká̱ onəm oga ntəm ka̱ aDor nna aNafot á, ká̱ aEn-Dor ká̱ aTanak ká̱ aMegitdo nzəng ká̱ ivan itong va̱ gáng oza̱. 
\m  
\v 12 Ka̱ nna te, nka̱m itong va̱ ta̱ ma̱t onəm aManase ma̱t. Ka̱kul oKanana zhet pa̱ o təm ka̱ ashe mbin va̱ ta.  
\v 13 Awalang va̱ onəm oIsa̱rila kam pa̱ gənggəng te, oza̱ nak inok iga nkpak oKanana, nnyi te oza̱ ɓak oza̱ fa ka̱t. 
\p  
\v 14 Te onəm aYusufu là ûJoshuwa pa̱, << Iza̱ nak kang u na nkap iya̱mkup a yi pa̱ nzəng na byet yà? Mmayi pa te, onəm va yəl pa̱ kyák ka̱kul pa̱ uYawe nak nnap-nnəna̱n a yi chit.>> 
\p  
\v 15 Te uJoshuwa na a ma̱n ôza̱ pa̱, <<A yà pa̱ mmawó onəm yəlyəl kang mbin ngga aɗuktum aEfrayim ayiyen ká̱ wo te, o ga ashe ǹzam mbin oPerizi ká̱ oRefayim, na o mwak mpwom îshi wó ka̱ ta.>> 
\p  
\v 16 Onəm aYusufu na ama̱n pa̱, << Mbin ngga aɗuktum kur yi ka̱t. Kang nkpaktak oKanana va̱ ka̱ ntəm ka̱ agbagba va̱ ta, oma ká̱ oga akeke ipəri iga acham, ká̱ ovəngva̱ ka̱ aBet-Shan ká̱ ivan itutong, ká̱ ovəngva̱ ka̱ mba̱nda̱m ngga aJezireyel.>> 
\p  
\v 17 Ǹnyi te, uJoshuwa là âkum ìjili aYusufu, uEfrayim, ká̱ uManase pa̱, << Ó yəl pa̱ kyák, kang ó kam pa̱ gənggəng. Te ó yà ka̱ nya nkap pa̱ nzəng na byet ka̱t.  
\v 18 Ǹnyi te, mbin ngga aɗuktum va̱ ka̱ ashe nzam i təm nji wó kpa, o gbá̱ng, kang o ka̱m pa̱ kpaktak i ga i chu aswariswari. Káp ká̱ nva̱, oKanana oma yà ká̱ akeke ipəri iga acham kang oza̱ kam te, o ga mɓàk oza̱ i fa.>> 
\c 18  
\s1 Nkap aɓo mbin 
\p  
\v 1 Ka̱ nva̱ngva̱ nkpaktak nggatək onəm oIsa̱rila ri mbin va̱ ta chit te, oza̱ ɓut ka̱ aShilo kang oza̱ pak aghal aga mɓut ka̱ ta.  
\v 2 Ǹnyi te, akum ìjili pa̱ ifangshat ka̱ ashe oIsa̱rila oma ka̱ ka̱m iya̱mkup oza̱ chit ka̱t. 
\p  
\v 3 Te uJoshuwa là ônəm oIsa̱rila pa̱, <<Ó kali i gbà̱ng nva̱ng wa nsang, kang ó ɓan nka̱m mbin va̱ nna uYawe, Inan okəka wo na wo chit yà?  
\v 4 Ó na onunggwan a mi pa̱ oshatɗing ka̱ ashe nza̱ akum nggo. Mi ga nre oza̱ i ranggang i mal mbin va̱ ta ka̱ asa̱l awu va̱ mí kap iya̱mkup ká̱, kang oza̱ i le i ɓa atak mi.  
\v 5 Ó ga nkap mbin va̱ ta nkap pa̱ nfangshat. UYahuda i ga mpyal ka̱ ntəm ka̱ mbin ngga asa̱l nkwandal, kang akum ìjili aYusufu i təm ka̱ mbin oza̱ ka̱ asa̱l mpal.  
\v 6 Kà̱ nva̱ngva̱ ó cha ala̱ka̱n mbin va̱ ta chit nkap pa̱ ifangshat te, ó ɓa ká̱ á mi. Kang mi máng ayàk a wó ka̱ ta̱, ka̱ mpyal aYawe, Inan yi.  
\v 7 OLawi jiwò te, oza̱ yà ka̱ nkap ka̱ ashe wó ka̱t, ka̱kul inok onəm oga mpyal awop aYawe nna iya̱mkup oza̱. Kang uGat, ká̱ uRuben, ká̱ aɓo nkap ka̱ ishimshe akum ìjili aManase te, oza̱ ya iya̱mkup oza̱ chit ka̱ gwong aUrdun ka̱ asa̱l nfa alum, i va uMusa uzwal aYawe na ôza̱ á.>> 
\p  
\v 8 Onunggwan va̱ ta wong ga pa̱ na ó màl mbin va̱ ta te, uJoshuwa nak oza̱ pa̱, <<Ó ga, ó ranggang ka̱ ashe mbin va̱ ta pa̱ kpaktak, ó màl, ó lir ila̱ka̱n ka̱ apal ishishi, kang ó le atak mi. Te mi máng ayàk a wó ka̱ ta̱ ka̱ mpyal aYawe ka̱ aShilo.>>  
\v 9 Te onunggwan va̱ ta ga kang oza̱ ranggang ka̱ ashe mbin va̱ ta. Oza̱ lir ila̱ka̱n ka̱ apəpal ka̱ awa achəndərchəndər, oza̱ kap na ka̱ atak ìtong idongkong pa̱ ifangshat ka̱ ashe nlir, te oza̱ le atak aJoshuwa ka̱ ashe apa̱k ka̱ aShilo.  
\v 10 Kang uJoshuwa màng ayàk ôza̱ ka̱ mpyal aYawe ka̱ aShilo. Ka̱ ta na uJoshuwa kap mbin va̱ ta âɓo akum ìjili oIsa̱rila, nza̱ akum nggo ká̱ nkap nji wò. 
\s1 Mbin va mmá na ûBenjamin 
\m  
\v 11 Akum ìjili aBenjamin oma ya ayàk aga nggəshi ka̱ atak oga akum oza̱. Nva̱n mbin va̱ mmá na ôza̱ te, ka̱ ishimshe akum ìjili aYahuda ká̱ uYusufu. 
\p  
\v 12 Aswari oza̱ ka̱ asa̱l mpal te, a ɓan ka̱ aUrdun, kang a watar ga mba̱nda̱m aJariko ka̱ asa̱l mpal, te a kyen ga mbin ngga aɗuktum ka̱ asa̱l ntar alum, a ɓa chu nzam ngga aBet-Aven.  
\v 13 A wong ka̱ ta te, a pa̱l ga asa̱l nkwandal mba̱nda̱m ngga aLuz, nna aBetel á, kang a kwangtal vang aAtarot-Adar ka̱ apal aɗuktum va ka̱ asa̱l nkwandal aBet-Horon aga aVəng. 
\p  
\v 14 A wong ka̱ ta te, aswari ga̱ɓa̱n ga asa̱l ntar alum, a watar ga nkwandal aɗuktum va̱ ta ka̱ asa̱l ntar alum, kang a ɓa fa ka̱ aKiriyat-Bayal, nna aKiriyat-Jeyarim á. Ìtong va̱ ta̱ iji onəm aYahuda. Nna ta nkur aswari oza̱ ka̱ asa̱l ntar alum. 
\p  
\v 15 Aswari aga ngba̱k ngga asa̱l nkwandal ɓan ka̱ nkur aKiriyat-Jeyarim ka̱ asa̱l ntar alum, te a watar ga asa̱l nfa alum aEfron ka̱ atak mɓəl ndəng ngga aNeptowa.  
\v 16 Aswari va̱ ta kwangtal ga avəng aɗuktum va̱ ka̱ ndər mba̱nda̱m aBen-Hinnom, ka̱ asa̱l mpal mba̱nda̱m aRefayim á. A watar fa ga mba̱nda̱m aHinnom, ka̱ asa̱l nkwandal ìtong oJebusi, kang a ga aEn-Rogel.  
\v 17 Te a ga̱ɓa̱n ga asa̱l mpal ɓa aEn-Shemesh, kang a lyam ga aGelilot va̱ ka̱ ndər asa̱l va̱ kyen ga aAdummim. Kang a kwangtal ga ìPáng aBohan, uya aRuben ununggwan.  
\v 18 A watar ka̱ asa̱l mpal aBet-Araba kang a kwangtal ga ashe aAraba.  
\v 19 Te aswari va̱ ta watar fa ga asa̱l mpal aBet-Hokla, kang a ɓa fa ka̱ asa̱l mpal akongkong ìWa mMan, va̱ ndəng aUrdun i nang i tar ka̱ ashishe ka̱ asa̱l nkwandal. Nna ta ka̱ yà aswari aga asa̱l nkwandal. 
\p  
\v 20 AWang aUrdun nna aswari aga asa̱l nfa alum. Oma ta aswari iya̱mkup va̱ akum ìjili aBenjamin ya ka̱ nza̱ ngba̱k nggo.  
\v 21 Itong akum ìjili aBenjamin ka̱ atak oga akum oza̱, oma, aJariko, ká̱ aBet-Hokla, ká̱ aEmek-Kezit,  
\v 22 ká̱ aBet-Araba, ká̱ aZemarayim, ká̱ aBetel,  
\v 23 ká̱ aAvim, ká̱ aPara, ká̱ aOfəra,  
\v 24 ká̱ aKefar-Ammoni, ká̱ aOfəni, ká̱ aGeba. Pa̱ kpaktak te, itong pa̱ igba̱pchi ama̱n pa̱ parəm nzəng ká̱ ivan itong oza̱.  
\v 25 Mmá na itong va̱ ta̱ âkum ìjili aBenjamin kpa, oma, aGibiyon, ká̱ aRama, ká̱ aBeyerot,  
\v 26 ká̱ aMizpa, ká̱ aKefira, ká̱ aMoza,  
\v 27 ká̱ aRekem, ká̱ aLərpeyel, ká̱ aTarala,  
\v 28 ká̱ aZela, ká̱ aHayelep, ká̱ ìtong oJebusi, nna aUrushelima á, ká̱ aGibeya, ká̱ aKiriyat. Pa̱ kpaktak te, itong pa̱ ìgba̱pchi ama̱n pa̱ neɗing nzəng ká̱ ivan itong oza̱. Nna ta iya̱mkup akum ìjili aBenjamin ka̱ atak oga akum oza̱. 
\c 19  
\s1 Mbin va mmá na âkum ìjili aSimeyon 
\p  
\v 1 Mmàng ayàk ngga mparəm a ru âkum ìjili aSimeyon, ka̱ atak oga akum oza̱. Kang iya̱mkup oza̱ lyam tar ka̱ ashe mbin akum ìjili aYahuda.  
\v 2 Oga atak iya̱mkup oza̱ oma, aBeyersheba, ká̱ aSheba, ká̱ aMolada,  
\v 3 ká̱ aHazar-Shuwal, ká̱ aBala, ká̱ aEzem,  
\v 4 ká̱ aEltolat, ká̱ aBetul, ká̱ aHorma,  
\v 5 ká̱ aZiklak, ká̱ aBet-Markabot, ká̱ aHazar-Susa,  
\v 6 ká̱ aBet-Lebayot, ká̱ aSharuhen. Pa̱ kpaktak te, itong pa̱ ìgba̱pchi ama̱n pa̱ shatɗing nzəng ká̱ ivan itong oza̱.  
\v 7 Mmá na itong va̱ ta̱ âkum ìjili aSimeyon kpa, oma, aAyin, ká̱ aRimmon, ká̱ aEter, ká̱ aAshan. Pa̱ nkpaktak te, itong pa̱ ineɗing nzəng ká̱ ivan itong oza̱.  
\v 8 Nzəng ká̱ nkpaktak ivan itong va̱ gang itong va̱ ta ga chu aBayalat-Beyer, nna aRama aga aNegep\f + \fr 19.8 \ft Mbin ngga nkwandal va yà ká̱ ndəng ka̱t\f*. Nna ta ka̱ yà iya̱mkup akum ìjili aSimeyon ka̱ atak oga akum oza̱. 
\m  
\v 9 Iya̱mkup akum ìjili aSimeyon mmá pà ka̱ ashe iya̱mkup aYahuda, ka̱kul nkap nji akum ìjili aYahuda mak ji nkam oza̱ ji. Te akum ìjili aSimeyon ka̱m iya̱mkup iji oza̱ ka̱ ishimshe iya̱mkup akum ìjili aYahuda. 
\s1 Mbin va mmá na âkum ìjili aZebulun 
\m  
\v 10 Mmàng ayàk ngga nshatɗing a ru âkum ìjili aZebulun ka̱ atak oga akum oza̱. Aswari iya̱mkup oza̱ ga chu ìtong aSarit.  
\v 11 A wong ka̱ ta te, a wòl asa̱l ntar alum ga aMarala, ga chu aDapbeshet, ká̱ awang va̱ ka̱ asa̱l nfa alum aJokneyam.  
\v 12 Ka̱ aSarit a ga̱ɓa̱n dər asa̱l nfa alum a ga aswari aga aKislot-Tabor. Ka̱ ta te a ga wòl aDaberat, kang a kyen ga aJafiya.  
\v 13 Ka̱ ta te, a lyam ka̱ asa̱l nfa alum a ga aGat-Hefer, ká̱ aEt-Kazin, kang a ɓa fa ka̱ aRimmon, a ga̱ɓa̱n dər aNeya.  
\v 14 Ka̱ asa̱l mpal te, aswari va̱ ta ga̱ɓa̱n ga aHannaton, kang a kur ka̱ mba̱nda̱m ngga aIftah-El.  
\v 15 Oga atak iya̱mkup oza̱ oma, aKattat, ká̱ aNahalal, ká̱ aShimron, ká̱ aIdala, kang ká̱ aBet-Lehem. Pa̱ kpaktak te, itong pa̱ ìgba̱pchi ama̱n pa̱ parəm nzəng ká̱ ivan itong oza̱. 
\m  
\v 16 Itong va̱ ta̱, nzəng ká̱ ivan itong oza̱, oma iya̱mkup akum ìjili aZebulun ka̱ atak oga akum oza̱. 
\s1 Mbin va mmá na âkum ìjili aIsakar. 
\m  
\v 17 Mmàng ayàk ngga nneɗing a ru âkum ìjili aIsakar ka̱ atak oga akum oza̱.  
\v 18 Mbin oza̱ oma, aJezireyel, ká̱ aKesulot, ká̱ aShunem,  
\v 19 ká̱ aHafarayim, ká̱ aShiyon, ká̱ aAnaharat,  
\v 20 ká̱ aRapbit, ká̱ aKishiyon, ká̱ aEbet,  
\v 21 ká̱ aRemet, ká̱ aEn-Gannim, ká̱ aEn-Hatda, ká̱ aBet-Patzet.  
\v 22 Aswari va̱ ta ga chu aTabor, ká̱ aShahazuma, ká̱ aBet-Shemesh, kang a ɓa kur ka̱ aWang aUrdun. Pa̱ kpaktak te, itong pa̱ ìgba̱pchi ama̱n pa̱ kpa̱ɗing nzəng ká̱ ivan itong oza̱. 
\m  
\v 23 Itong va̱ ta̱, nzəng ká̱ ivan itong oza̱, oma, iya̱mkup akum ìjili aIsakar ka̱ atak oga akum oza̱. 
\s1 Mbin va mmá na âkum ìjili aAsher 
\m  
\v 24 Mmàng ayàk ngga ntukun a ru âkum ìjili aAsher ka̱ atak oga akum oza̱.  
\v 25 Mbin oza̱ oma, aHelkat, ká̱ aHali, ká̱ aBeten, ká̱ aAkshap,  
\v 26 ká̱ aAlammelek, ká̱ aAmat, ká̱ aMishal. Ka̱ asa̱l ntar alum te, aswari va̱ ta ga chu aKarmel, ká̱ aShihor-Lipnat,  
\v 27 te a ga̱ɓa̱n ga asa̱l nfa alum, kang a lyam ga aBet-Dagon, ga chu aZebulun, ká̱ mba̱nda̱m ngga aIftah-El, kang a ga asa̱l mpal ka̱ aBet-Emek ká̱ aNeyiyel. Te, a watar ka̱ asa̱l mpal ga aKabul.  
\v 28 Ká̱ aEbron, ká̱ aRehop, ká̱ aHammon, ká̱ aKana, ga chu aSidon aChumchum.  
\v 29 Te aswari va̱ ta ga̱ɓa̱n ga aRama, a ga chu ìtong aTaya iga akamsəlang, kang a ga̱ɓa̱n ga aHosa, te a kur ká̱ ìWa aMeditereniya ka̱ nkap mbin aMahalap ká̱ aAkzip,  
\v 30 ká̱ aUmma, ká̱ aAfek, ká̱ aRehop. Pa̱ kpaktak te, itong ìsəm pa̱ ìparəm ama̱n pa̱ parəm nzəng ká̱ ivan itong oza̱. 
\m  
\v 31 Itong va̱ ta̱, nzəng ká̱ ivan itong oza̱, oma, iya̱mkup akum ìjili aAsher ka̱ atak oga akum oza̱. 
\s1 Mbin va mmá na âkum ìjili aNaftali 
\m  
\v 32 Mmàng ayàk ngga nkpa̱ɗing a ru âkum ìjili aNaftali ka̱ atak oga akum oza̱. 
\p  
\v 33 Kang aswari oza̱ wong ka̱ aHelep, ka̱ inang ikún aOak va̱ ka̱ aZayanannim, a watar ga aAdami-Nekep, ká̱ aJapneyel ga chu aLakkum, kang a kur ka̱ aWang aUrdun.  
\v 34 Aswari va̱ ta ga̱ɓa̱n ka̱ asa̱l ntar alum ga aAznot-Tabor, kang a lyam ka̱ ta ga aHukkok, ga chu aZebulun ka̱ asa̱l nkwandal, aAsher ka̱ asal ntar alum, kang aYahuda ka̱ atak aWang aUrdun ka̱ asa̱l nfa alum.  
\v 35 Itong iga akamsəlang oma, aZitdim, ká̱ aZer, ká̱ aHammat, ká̱ aRakkat, ká̱ aKinneret,  
\v 36 ká̱ aAdama, ká̱ aRama, ká̱ aHazor,  
\v 37 ká̱ aKadesh, ká̱ aEdreyi, ká̱ aEn-Hazor,  
\v 38 ká̱ aYiron, ká̱ aMikdal-El, ká̱ aHorem, ká̱ aBet-Anat, ká̱ aBet-Shemesh. Pa̱ kpaktak te, itong pa̱ ìgba̱pchi ama̱n pa̱ fangzəngtəng nzəng ká̱ ivan itong oza̱. 
\m  
\v 39 Itong va̱ ta̱, nzəng ká̱ ivan itong oza̱, oma, iya̱mkup akum ìjili aNaftali ka̱ atak oga akum oza̱. 
\s1 Mbin va mmá na âkum ìjili aDan 
\m  
\v 40 Mmàng ayàk ngga nfangshat a ru âkum ìjili aDan, ka̱ atak oga akum oza̱.  
\v 41 Mbin ngga iya̱mkup oza̱ oma, aZora, ká̱ aEshtawol, ká̱ aIr-Shemesh,  
\v 42 ká̱ aShayalapbin, ká̱ aAijalon, ká̱ aItla,  
\v 43 ká̱ aElon, ká̱ aTimna, ká̱ aEkron,  
\v 44 ká̱ aElteke, ká̱ aGipbeton, ká̱ aBayalat,  
\v 45 ká̱ aJehut, ká̱ aBene-Berak, ká̱ aGat-Rimmon,  
\v 46 ká̱ aMe-Jarkon, ká̱ aRakkon, ká̱ mbin va̱ mal ìkwoksok ká̱ aJoppa. 
\p  
\v 47 Ka̱ nva̱ngva̱ akum ìjili aDan lang mbin oza̱ te, oza̱ ga ru aLeshem ká̱ ìkum, oza̱ ri na, oza̱ gbá̱ng onənəm ká̱ ndokchi, kang oza̱ təm ka̱ ashe mbin va̱ ta. Te, oza̱ ga̱ɓa̱n aɗiɗin i wor ká̱ aɗin akəka oza̱ uDan. 
\m  
\v 48 Itong va̱ ta̱, nzəng ká̱ ivan itong oza̱, oma, iya̱mkup akum ìjili aDan ka̱ atak oga akum oza̱. 
\s1 Mbin va mmá na ûJoshuwa 
\p  
\v 49 Ka̱ nva̱ngva̱ oza̱ gba̱l ka̱ nkap mbin va̱ ta chit iya̱mkup ka̱ atak aswari oza̱ te, oIsa̱rila na ûJoshuwa uya aNun ununggwan iya̱mkup ijini ka̱ ashe iji oza̱,  
\v 50 wa nva̱ uYawe ka̱ nak. Te, oza̱ na ìtong va á na uza̱ ɓəp, nna aTimnat-Sera ka̱ mbin ngga aɗuktum aEfrayim. Kang uza̱ me ìtong va̱ ta ka̱ɗi, uza̱ təm ka̱ ashishe. 
\p  
\v 51 Oga mbin va ta̱ uEleyazar unəm uga mpyal awop, ká̱ uJoshuwa uya aNun ununggwan, ká̱ onəm oga mpyal oga akum oIsa̱rila kap iya̱mkup ká̱, ka̱ atak mmàng ayàk ka̱ aShilo ka̱ mpyal aYawe, ka̱ anung asa̱l aga ntar Aghal Mɓut. Wa nnà ta oza̱ gba̱l ka̱ nkap mbin va̱ ta. 
\c 20  
\s1 Itong va mí bwam kà̱ 
\p  
\v 1 Te uYawe là ûJoshuwa pa̱,  
\v 2 <<Là ôIsa̱rila pa̱ ó yak itong ka̱kul atak mbwam îshi wó, wa nva ka̱ nlà a wó ka̱ atak aMusa á,  
\v 3 ka̱kul unəm va̱ pa̱ kpaktak a gba̱l unəm ka̱ ashe mməma̱n, ka̱t te ka̱ ashe ǹnyinyi ka̱t, te uza̱ i chə́r i ga ka̱ ta. Itong va̱ ta i yà atak mbwam a wó, ka̱ atak anəm uga nɗom mpyát akat nchə̀r.  
\v 4 Awalang va̱ uza̱ á chə́r a ga ìtong iro pa̱ izəng ka̱ ashe itong va̱ ta, te uza̱ i sat ka̱ anung asa̱l aga ntar ìtong va̱ ta, kang uza̱ i là ônəmgbak oga ìtong va̱ ta iya̱m va̱ ya na á. Te oza̱ i ka̱m na i tar ka̱ ka̱ ashe ìtong va̱ ta, oza̱ i na atak á na, kang uza̱ i təm ka̱ ashe oza̱.  
\v 5 A yà pa̱ unəm uga nɗom mpyát akat nchə̀r va̱ ta a wà nvəva̱ng te, onəmgbak oga ìtong va̱ ta i yà ká̱ nná unəm va̱ gba̱l unəm á na ka̱t, ka̱kul uza̱ gba̱l unəm uga nra datkulung ká̱ na ká̱ ǹnyinyi ka̱t, kang uza̱ ka̱ nkpàng na matmat ka̱t.  
\v 6 Uza̱ i təm ka̱ ashe ìtong va̱ ta i ga i chu awalang va̱ uza̱ i sat ka̱ mpyal nggatək ka̱kul nnap-akwali, ká̱ awalang va̱ unəm uchumchum uga mpyal awop uga nra va̱ ta ikú ká̱ kang. Nna chit te, unəm uga ngba̱l unəm va̱ ta i le, i ga nzhi wò ka̱ ashe ìtong va̱ uza̱ ka̱ chə́r kà̱.>> 
\p  
\v 7 Te oza̱ gar aKadesh ka̱ aGalili ka̱ mbin ngga aɗuktum aNaftali, ká̱ aShekem ka̱ mbin ngga aɗuktum aEfrayim, ká̱ aKiriyat-Arba, nna aHebron á, ka̱ mbin ngga aɗuktum aYahuda.  
\v 8 Ka̱ gwong aUrdun ka̱ asa̱l nfa alum aJariko te, oza̱ gar aBezer ka̱ ashe ǹzam ka̱ mbin ngga agbagba, ka̱ akum ìjili aRuben, ká̱ aRamot ka̱ aGileyat, ka̱ akum ìjili aGat, kang aGolan ka̱ aBashan, ka̱ akum ìjili aManase.  
\v 9 Itong va ta̱ mmá gar ka̱kul nkpaktak oIsa̱rila, ká̱ onəmchən va̱ ka̱ ntəm ka̱ ashe oza̱. Ka̱kul nkpaktak unəm va̱ gba̱l unəm ka̱ ashe mməma̱n ka̱t, te i chə́r i ga ka̱ ta, na kang unəm uga nɗom mpyát akat nchə̀r a gba̱l na ka̱t. Uza̱ i təm ka̱ ta i ga i chu awalang va̱ uza̱ i sat ka̱ mpyal nggatək ka̱kul akwali kang. 
\c 21  
\s1 Itong va mmá na ôLawi 
\p  
\v 1 Te onəm oga mpyal nzhi oLawi ɓa atak aEleyazar unəm uga mpyal awop, ká̱ uJoshuwa uya aNun ununggwan, ká̱ aɓoshi onəm oga mpyal nzhí akum ìjili oIsa̱rila.  
\v 2 Kang oza̱ là ôza̱ ka̱ aShilo ka̱ mbin aKanana pa̱, <<UYawe ka̱ nak ûMusa chit pa̱ mmá na itong iga ntəm á yi, nzəng ka̱ atak nkpak iya̱m ka̱kul iya̱mkang yi.>>  
\v 3 Wa nva uYawe ka̱ nak, te oIsa̱rila na itong va̱ ta̱ ôLawi ká̱ oga atak nkpak iya̱m ka̱ ashe iya̱mkup oza̱. 
\p  
\v 4 Mmàng ayàk nggəshi a ru âkum aKohat. OLawi ova ka̱ akum ìjili aHaruna unəm uga mpyal awop ka̱m itong pa̱ igba̱pchi ama̱n pa̱ shatɗing ka̱ atak oga akum ìjili aYahuda, ká̱ aSimeyon, ká̱ aBenjamin.  
\v 5 Kang aɓo akum aKohat ka̱m itong pa̱ igba̱pchi ka̱ atak oga akum ìjili aEfrayim, ká̱ uDan, kang ká̱ nkap ka̱ ishimshe akum ìjili aManase. 
\p  
\v 6 Akum ìjili aGershon ǹnyi te, ka̱m itong pa̱ igba̱pchi ama̱n pa̱ shatɗing ka̱ atak oga akum ìjili aIsakar, ká̱ uAsher, ká̱ uNaftali, kang ká̱ nkap ka̱ ishimshe akum ìjili aManase ka̱ aBashan. 
\p  
\v 7 Akum ìjili aMerari ka̱m itong pa̱ igba̱pchi ama̱n pa̱ parəm ka̱ atak oga akum ìjili aRuben, ká̱ uGat, ká̱ uZebulun. 
\p  
\v 8 Te oIsa̱rila na itong va̱ ta̱ ôLawi nzəng ká̱ atak nkpak iya̱mkang ka̱ atak mmàng ayàk, wa nva uYawe ka̱ nak ûMusa á.  
\v 9 Ka̱ ashe oga akum ìjili aYahuda ká̱ uSimeyon te, oza̱ na itong va̱ ta̱ oma aɗin oza̱ pa̱.  
\v 10 Mmá na itong va̱ ta̱ âkum ìjili aHaruna, ova ka̱ ashe akum aKohat, ka̱ akum ìjili oLawi, ka̱kul mmàng ayàk aga nggəshi a ru ôma. 
\p  
\v 11 Te oza̱ na aKiriyat-Arba ôza̱, nna aHebron á, nzəng ká̱ oga atak nkpak iya̱m nkəkang va̱ gang na, ka̱ mbin ngga aɗuktum aYahuda. UArba uwa upo aAnak.  
\v 12 Ǹnyi te, oga ǹzam ngga ìtong va̱ ta ká̱ ivan itutong, mmá na uKalip uya aJefune ununggwan a təm iya̱mkukup.  
\v 13 Te oza̱ na aHebron âkum ìjili aHaruna, unəm uga mpyal awop, ìtong iga atak mbwam ka̱kul anəm uga gba̱l unəm, ká̱ aLipna,  
\v 14 ká̱ aJatir, ká̱ aEshtemowa,  
\v 15 ká̱ aHolon, ká̱ aDebir,  
\v 16 ká̱ aAyin, ká̱ aJutta, ká̱ aBet-Shemesh, nzəng ká̱ oga atak nkpak iya̱mkang oza̱. Pa̱ kpaktak te, itong pa̱ ìfangzəngtəng ka̱ ashe oga akum ìjili aga aparəm va̱ ta̱. 
\p  
\v 17 Ka̱ ashe akum ìjili aBenjamin te, mmá na aGibiyon, ká̱ aGeba,  
\v 18 ká̱ aAnatot, ká̱ aAlmon ôza̱, nzəng ká̱ oga atak nkpak iya̱mkang oza̱. Pa̱ kpaktak te, itong pa̱ ineɗing.  
\v 19 Nkpaktak itong va̱ mmá na ônəm oga mpyal awop, ova akum ìjili aHaruna, unəm uga mpyal awop te, pa̱ igba̱pchi ama̱n pa̱ shatɗing nzəng ká̱ oga atak nkpak iya̱mkang oza̱. 
\m  
\v 20 Aɓo akum aKohat ka̱ ashe akum ìjili óLawi te, mmá na itong ôza̱ ka̱ ashe nkap akum ìjili aEfrayim.  
\v 21 Ka̱ ashe mbin ngga aɗuktum aEfrayim te, mmá na aShekem, ìtong iga atak mbwam ka̱kul anəm uga gba̱l unəm, ká̱ aGezer,  
\v 22 ká̱ aKipzayim, ká̱ aBet-Horon ôza̱, nzəng ká̱ oga atak nkpak iya̱mkang oza̱. Pa̱ kpaktak te, itong pa̱ ineɗing. 
\p  
\v 23 Ka̱ ashe akum ìjili aDan te, mmá na aElteke, ká̱ aGipbeton,  
\v 24 ká̱ aAijalon, ká̱ aGat-Rimmon ôza̱, nzəng ká̱ oga atak nkpak iya̱mkang oza̱. Pa̱ kpaktak te, itong pa̱ ineɗing. 
\p  
\v 25 Ka̱ ashe nkap ka̱ ishimshe akum ìjili aManase te, mmá na aTayanak, ká̱ aGat-Rimmon ôza̱, nzəng ká̱ oga atak nkpak iya̱mkang oza̱. Pa̱ kpaktak te, itong pa̱ iparəm.  
\v 26 Pa̱ kpaktak te, mmá na itong pa̱ igba̱pchi nzəng ka̱ oga atak nkpak iya̱mkang oza̱, âɓo akum aKohat. 
\p  
\v 27 Kang akum aGershon, ka̱ ashe akum ìjili oLawi te, mmá na itong ôza̱ ka̱ ashe nkap ka̱ ishimshe akum ìjili aManase, oma, aGolan ka̱ aBashan, ìtong iga atak mbwam ka̱kul anəm uga gba̱l unəm, ká̱ aBe-Eshtera, nzəng ká̱ oga atak nkpak iya̱mkang oza̱. Pa̱ kpaktak te, itong pa̱ iparəm.  
\v 28 Ka̱ ashe akum ìjili aIsakar te, mmá na aKishiyon, ká̱ aDaberat,  
\v 29 ká̱ aJarmut, ká̱ aEn-Gannim ôza̱, nzəng ka̱ oga atak nkpak iya̱mkang oza̱. Pa̱ kpaktak te, itong pa̱ ineɗing.  
\v 30 Ka̱ ashe akum ìjili aAsher te, mmá na aMishal, ká̱ aAbdon,  
\v 31 ká̱ aHelkat, ká̱ aRehop ôza̱, nzəng ká̱ oga atak nkpak iya̱mkang oza̱. Pa̱ kpaktak te, itong pa̱ ineɗing.  
\v 32 Ka̱ ashe akum ìjili aNaftali te, mmá na aKadesh ka̱ aGalili, ìtong iga atak mbwam ka̱kul anəm uga gba̱l unəm, ká̱ aHammot-Dor, ká̱ aKartan ôza̱, nzəng ká̱ oga atak nkpak iya̱mkang oza̱. Pa̱ kpaktak te, itong pa̱ ishatɗing. 
\m  
\v 33 Nkpaktak itong va̱ mmá na âkum aGershon te, pa̱ ìgba̱pchi ama̱n pa̱ shatɗing nzəng ká̱ oga atak nkpak iya̱mkang oza̱. 
\p  
\v 34 Akum aMerari, ka̱ ashe aɓo akum ìjili óLawi te, mmá na itong ôza̱ ka̱ ashe akum ìjili aZebulun, oma, aJokneyam, ká̱ aKarta,  
\v 35 ká̱ aDimna, ká̱ aNahalal ôza̱, nzəng ká̱ oga atak nkpak iya̱mkang oza̱. Pa̱ kpaktak te, itong pa̱ ineɗing. 
\p  
\v 36 Ka̱ ashe akum ìjili aRuben te, mmá na aBezer, ká̱ aJahat,  
\v 37 ká̱ aKedemot, ká̱ aMefayat ôza̱, nzəng ká̱ oga atak nkpak iya̱mkang oza̱. Pa̱ kpaktak te, itong pa̱ ineɗing. 
\p  
\v 38 Ka̱ ashe akum ìjili aGat te, mmá na aRamot ka̱ aGileyat, ìtong iga atak mbwam ka̱kul anəm uga gba̱l unəm, ká̱ aMahanayim,  
\v 39 ká̱ aHeshbon, ká̱ aJazer ôza̱, nzəng ká̱ oga atak nkpak iya̱mkang oza̱. Pa̱ kpaktak te, itong pa̱ ineɗing. 
\m  
\v 40 Nkpaktak itong va̱ mmá na âkum aMerari, ka̱ ashe aɓo akum ìjili oLawi, ka̱ atak mmàng ayàk te, pa̱ igba̱pchi ama̱n pa̱ parəm. 
\p  
\v 41 Nkpaktak itong oLawi ka̱ ashe mbin iji oIsa̱rila te, ìsəm pa̱ ineɗing ama̱n pa̱ na̱nne nzəng ká̱ oga atak nkpak iya̱mkang oza̱.  
\v 42 Nza̱ ìtong nggo nna yà ká̱ atak nkpak iya̱mkang va̱ gang na. Wa nnà ta n̂za̱ ìtong nggo.  
\v 43 Wa nnà ta, uYawe na ôIsa̱rila nkpaktak mbin va̱ uza̱ ka̱ sóng anung pa̱ ò na ôkəka oza̱. Te oza̱ ka̱m mbin va̱ ta kang oza̱ təm ka̱ ashishe.  
\v 44 Te uYawe na njul oza̱ ka̱ nza̱ ngba̱k nggo, wa nva uza̱ ka̱ sóng anung okəka oza̱. Unəm uro yà ka̱ ashe okpa ìkum oza̱ pa̱ a sat a lung oza̱ ka̱t, ka̱kul uYawe na okpa ìkum oza̱ chit pa̱ kpaktak ka̱ ashe awo oza̱.  
\v 45 UYawe yəl nkpaktak oga nsar nnap-nlà nnəna̱n va̱ uza̱ yar n̂zhi aIsa̱rila. Nro yà bur ka̱t. 
\c 22  
\s1 Oga akum ìjili ngga asa̱l nfa alum le nzhi 
\p  
\v 1 Te uJoshuwa wór akum ìjili aRuben, ká̱ uGat, ká̱ nkap ishimshe akum ìjili aManase,  
\v 2 kang uza̱ là ôza̱ pa̱, <<O nəm nkpaktak iya̱m va̱ chit uMusa, uzwal aYawe ka̱ nak a wó, kang o kpak nnap-nnəm á mi chit ka̱ ashe nkpaktak iya̱m va̱ n nak a wó.  
\v 3 Ka̱ ashe nkpaktak oga nra mmakmak va̱ ta̱, a ga chu nda va̱ ta̱ te, nna o yang ogənang wo chit ka̱t. Kang ó kpak nnap-mpakpak aYawe, Inan wó kpak kpa pa̱ gənggəng.  
\v 4 Ǹyangmata̱ te, uYawe, Inan wó, á na njul ogənang wó chit, wa nva uza̱ ka̱ yar nsar nnap ôza̱. Ka̱kul nva̱ ta te, ó le ó ga oga nzhi wó, ka̱ mbin va̱ nna təm iya̱mkup wó chit, nva uMusa, uzwal aYawe ka̱ na a wó ka̱ gwong aUrdun á.  
\v 5 Ǹnyi te, ó nak ishi nak ka̱ nkpak oga nnap-mpakpak ká̱ nnap-nkpakkpak nva uMusa uzwal aYawe ka̱ nak a wó. Nna pa̱ ó ma̱n uYawe Inan wó, ó chen achen ka̱ ashe nnap-nnənəm, ó kpak oga nnap-mpakpakpakpak, ó da̱r nkam ká̱ izəzər, kang ó wop na ka̱ nkpaktak igwak, ka̱ nkpaktak irirì wó.>> 
\p  
\v 6 Te, uJoshuwa nak nnap-nnəna̱n ôza̱, kang uza̱ re oza̱, nna chit te, oza̱ le oga nzhi oza̱ ɗak.  
\v 7 UMusa ka̱ na iya̱mkup n̂kap ishimshe akum ìjili aManase aga azəng chit ka̱ aBashan, kang uJoshuwa na iya̱mkup âɓo nkap ishimshe akum ìjili nro chit ka̱ asa̱l ntar alum a gwong aUrdun nzəng ka̱ ogənang oza̱ oIsa̱rila. Awalang va̱ uJoshuwa re oza̱ pa̱ á ga oga nzhi oza̱ te, uza̱ nak nnap-nnəna̱n ôza̱,  
\v 8 kang uza̱ là ôza̱ pa̱, <<Ó le ó ga oga nzhi wó ká̱ ndur pa̱ mmakmak, ká̱ iya̱mkang pa̱ kyák, ká̱ aazurfa, ká̱ azənariya, ká̱ acham arəzang, ká̱ acham, ká̱ ilukwan pa̱ makmak. Ó kap iya̱m iga nwur ka̱ atak ìkum, ka̱ atak okpa ìkum wó ká̱ ogənang wó.>> 
\p  
\v 9 Te oga akum ìjili aRuben, ká̱ uGat, ká̱ nkap ishimshe akum ìjili aManase, re aɓo oIsa̱rila ka̱ aShilo ka̱ mbin aKanana le mbin aGileyat, mbin va oza̱ ka̱m chit sat iya̱mkup oza̱, wa nva uYawe ka̱ nak ka̱ atak aMusa á. 
\p  
\v 10 Awalang va̱ oza̱ chu aGelilot va̱ dat ká̱ aWang aUrdun ka̱ mbin aKanana te, akum ìjili aRuben, ká̱ uGat, ká̱ nkap ishimshe akum ìjili aManase me atak nshì iya̱m awop dat ká̱ anung awang va̱ ta, a va rúp, kang à ɓyen ndər pa̱ gənggəng.  
\v 11 Ka̱ nva̱ngva̱ aɓo oIsa̱rila fe pa̱ oza̱ me atak nshì iya̱m awop chit ka̱ aGelilot ka̱ anung aWang aUrdun, ka̱ aswari mbin aKanana, ka̱ ngba̱k nji oIsa̱rila,  
\v 12 te nkpaktak nggatək oIsa̱rila ɓut ka̱ aShilo ka̱kul pa̱ na ó ga ó lung ìkum ká̱ ôza̱. 
\p  
\v 13 Te oIsa̱rila re uFinehas uya aEleyazar ununggwan, unəm uga mpyal awop, ka̱ atak akum ìjili aRuben, ká̱ uGat, ká̱ nkap ishimshe akum ìjili aManase ka̱ mbin aGileyat.  
\v 14 Mmá re na nzəng ká̱ onəm oga mpyal pa̱ ogba̱pchi, nza̱ unəm nggo te, unəm uga mpyal akum ka̱ ashe oga akum ìjili oIsa̱rila. 
\p  
\v 15 Awalang va̱ oza̱ ga mbin aGileyat, ka̱ atak akum ìjili aRuben, ká̱ uGat, ká̱ nkap ishimshe akum ìjili aManase te, oza̱ là ôza̱ pa̱,  
\v 16 <<Nkpaktak nggatək onəm aYawe ɓəp pa̱, <Nza̱ apir nlang nnandər ta̱ ó nəm ka̱ mpyal Inan oIsa̱rila, nva̱ ó ga̱ɓa̱n asəm ûYawe, ó fa iya̱mkak, ó me atak nshì iya̱m awop îshi wó yà?  
\v 17 Nnap-mɓá̱ngɓa̱ng va̱ í nəm ka̱ aFeyor te, nná kúr yi chit ka̱t ɗò? Dər, a ɓa chu nda va̱ ta̱, nna í fa chit ka̱ ashe mɓək anung nnap-mɓá̱ngɓa̱ng va̱ ta ka̱t, kap ka̱ nva̱ uYawe re nrè ká̱ arwa aɓá̱ngɓa̱ng ka̱ apal ishi yi onənəm á.  
\v 18 Kang ǹyangmata̱, ó ga̱ɓa̱n asəm ó ná ûYawe ka̱ nda ta̱ ɗò? Kang a yà pa̱ ó fa iya̱mkak ká̱ uYawe nda ta̱, ìpin te, uza̱ i mən ìkum ká̱ nkpaktak nggatək oIsa̱rila.  
\v 19 A yà pa̱ mbin nji wó nna ka̱ adak, te ó pa̱ng ó ɓa ashe mbin va aGhal aYawe kà̱, na ó ka̱m mbin îshi wó ka̱ ashe yi. Ǹnyi te, kang ó fa iya̱mkak ká̱ uYawe, ka̱t te, ó fa iya̱mkak ká̱ yi ka̱t, ka̱ atak mme atak nshì iya̱m awop îshi wó pa̱ɗi, ká̱ atak nshì iya̱m awop aYawe, Inan yi ka̱t.  
\v 20 Ka̱ awalang va̱ uAkan uya aZera ununggwan nəm nnandər ka̱t ka̱ apal oga iya̱m va̱ mmá gor ka̱kul nzhì te, nfə́l ìgwak Inan fə́r ka̱ apal nkpaktak nggatək oIsa̱rila ka̱t ɗò? UAkan wa ká̱ nkukwa zhì ka̱kul nnap-mɓá̱ngɓa̱ng wò ka̱t.> >> 
\p  
\v 21 Te akum ìjili aRuben, ká̱ uGat, ká̱ nkap ishimshe akum ìjili aManase na ama̱n ônəm oga mpyal oga akum oIsa̱rila pa̱,  
\v 22 <<UYawe, Inan, Uga Ichumchum. UYawe, Inan, Uga Ichumchum. Uza̱ wa nyi iya̱m va̱ nyi nak kang í nnəm iya̱m va̱ ta, kang í ɗom pa̱ oIsa̱rila a nyi kpa. A yà pa̱ i fa iya̱mkak, ka̱t te, i nəm nnandər ûYawe ka̱t, te kang ó re yi ká̱ irirì nda ta̱ ka̱t.  
\v 23 A yà pa̱ í ga̱ɓa̱n asəm ûYawe kang í me atak nshì iya̱m awop îshi yi, ka̱kul na í yichi iya̱m inana iga nshì, ka̱t te, iya̱m inana iga ìpirkur, ka̱t te, iya̱m inana iga ntəm ikángkáng te, re uYawe ká̱ ishi wò á pyát a yi. 
\p  
\v 24 <<Í nəm pa, ka̱kul ayər ka̱ nnəm yi, kang nra ngga mɓa te, ovan wó a là ovan yi pa̱, <Iza̱ gwang wó ká̱ uYawe, Inan oIsa̱rila yà?  
\v 25 Ka̱kul mmawó akum ìjili aRuben, ká̱ uGat te, uYawe nak aWang aUrdun chit aswari ka̱ ishimshe yi ká̱ wó. Te wa nnà ta iya̱m ro gwang wó ká̱ uYawe ka̱t.> Le kang ovan wó a nak ovan yi a re nwop uYawe ka̱t. 
\p  
\v 26 <<Ka̱kul nva̱ ta te, í la pa̱, <Re í gbar izər, í me atak nshì iya̱m awop îshi yi, ǹnyi te, ka̱kul nná iya̱m inana iga nshì, ka̱t te, nná nləfər iya̱m ipápà ka̱t.>  
\v 27 Ka̱ɗor nva̱ ta te, i təm iya̱m iga nshet nnàp ka̱ ishimshe yi ká̱ wó, kang ka̱ ishimshe nlwàk ngga mɓa, pa̱ mmayi ka̱ nwop uYawe nna kpa ka̱ mpyal aGhəghal aYəyər ká̱ oga iya̱m inana iga nshì, ká̱ oga nləfər iya̱m ipápà, ká̱ oga iya̱m inana iga ntəm ikángkáng, le kang ovan wo á la ovan yi ka̱ nra ngga mɓa pa̱, <iza̱ gwang wó ká̱ nwop uYawe yà ka̱t.> 
\p  
\v 28 <<Te í rəng pa̱, a yà pa̱ ka̱ awalang va̱ mmá là a yi, ka̱t te nlwàk ngga mɓa, te í na ama̱n pa̱, <Ó dər ala̱ka̱n atak nshì iya̱m awop aYawe, va̱ ópo yi me, ka̱kul ǹyichi iya̱m inana iga nshì, ka̱t te nləfər iya̱m ipápà ka̱t, pa̱ na a yà iya̱m iga nshet nnàp ká̱ ishimshe yi ká̱ wó.> 
\p  
\v 29 <<Inan a kap yi ká̱ nva̱ pa̱ i fa iya̱mkak ka̱ ûYawe, i ga̱ɓa̱n asəm a na ka̱ nda va̱ ta̱ ka̱ atak mme atak nshì iya̱m awop aro pa̱ɗi, ka̱kul oga iya̱m inana iga nshì, ká̱ oga iya̱m inana iga ìpirkur, ka̱t te, oga nləfər iya̱m ipápà, iva watar atak nshì iya̱m awop aYawe va̱ ka̱ mpyal aghəghal aga mɓut á.>> 
\p  
\v 30 Awalang va̱ uFinehas unəm uga mpyal awop, ká̱ onəm oga mpyal nggatək, ká̱ onəm oga mpyal akum oIsa̱rila va̱ nzəng ka̱ na, fe nnap-nlà va̱ akum ìjili aRuben, ká̱ uGat, ká̱ nkap ishimshe akum ìjili aManase là te, igwak chàng oza̱.  
\v 31 Kang uFinehas uya aEleyazar ununggwan unəm uga mpyal awop, là ônəm aRuben, ká̱ uGat, ká̱ uManase pa̱, <<Ka̱ nda í nyi pa̱ uYawe uwa yà nzəng ka̱ yi. Ka̱kul pa̱ í nyám nlang nna nnandər ka̱ mpyal aYawe ka̱t. Ǹyangmata̱ te, ó ka̱m ishi oIsa̱rila chit ka̱ ashe awó aYawe.>> 
\p  
\v 32 Te, uFinehas uya Eleyazar ununggwan unəm uga mpyal awop, ká̱ onəm oga mpyal le ka̱ atak onəm aRuben, ká̱ uGat, ká̱ uManase ka̱ mbin aGileyat, ga mbin aKanana, kang a ɓa ká̱ ama̱n ôIsa̱rila.  
\v 33 Ìgwak chàng oIsa̱rila ka̱ nfe ama̱n va̱ ta, kang oza̱ shep Inan. Kang oza̱ là nnap ngga nəm ìkum nro lap ka̱ apal oza̱ ka̱t, na pa̱ ó zhì onəm aRuben, ká̱ uGat ká̱ mbin va̱ oza̱ təm kà̱. 
\p  
\v 34 Kang onəm aRuben, ká̱ uGat na aɗin atak nshì iya̱m awop va̱ ta̱ pa̱, Ǹnyám Nnap ka̱ Ishimshe Yi pa̱ uYawe uwa Inan. 
\c 23  
\s1 Nnap-nlà aJoshuwa ôIsa̱rila ngga nkur anung 
\p  
\v 1 UYawe na njul ôIsa̱rila chit ka̱ atak nkpaktak okpa ìkum oza̱, ovəngva̱ gang oza̱ á. Oza̱ gba̱ng chit ka̱ ashe njul va̱ ta, kang uJoshuwa gbák chit, a nəm izún chit pa̱ makmak.  
\v 2 Te uJoshuwa wór nkpaktak oIsa̱rila, ká̱ onəmgbak oza̱, ká̱ onəm oga mpyal oza̱, ká̱ onəm oga nnáp-akwali oza̱, ká̱ onəm oga mpyal ìkum oza̱, kang uza̱ là ôza̱ pa̱, <<Ǹyangmata̱ te, n gbák chit, kang izún mi ga chit.  
\v 3 Mmawó ká̱ ishi wó, ó ya nkpaktak iya̱m va̱ ya uYawe, Inan wó nəm n̂kpaktak oga mbin va̱ ta̱ ka̱kul wó, ka̱kul uYawe, Inan wó, uwa lung ìkum ka̱kul wó.  
\v 4 Ó dər, n káp oga mbin va̱ ta̱ chit iya̱mkup ôga akum ìjili wó, nvəngva̱ nná re, ká̱ nkpaktak oga mbin va̱ n ri chit ká̱ ìkum, a ɓan ka̱ aWang aUrdun ka̱ asal nfa alum, ga chu ìWa aMeditereniya ka̱ asa̱l ntar alum.  
\v 5 UYawe, Inan wó, uwa ká̱ ishi wò, i nak oza̱ i chəng ka̱ mpyal wó, kang uza̱ i ɓak oza̱ i fa ka̱ ashe mbin va̱ ta. Te ó ka̱m mbin oza̱, wa nva uYawe, Inan wó ka̱ yar nsar nnap-nlà á wó á.>> 
\p  
\v 6 <<Ka̱kul nva̱ ta̱ te, ó sat pa̱ kakkərak, ó nak ishi, ó kpak nkpaktak iya̱m va̱ mmá lir ka̱ ashe nlir nnap-mpakpak aMusa, kang ó ga̱ɓa̱n awo ari ka̱t te, awo apəra̱m ka̱t.  
\v 7 Kang ó gwang ishi ká̱ aɓo oga mbin va̱ re ka̱ ashe mbin va̱ ta ka̱t, kang ó wór oga aɗin inan oza̱, ka̱t te ó sóng anung ká̱ oza̱ ka̱t. Kang ó wop oza̱, ka̱t te ó ɓəram ôza̱ ka̱t.  
\v 8 Ǹnyi te, ó da̱r nkàm ka̱ atak aYawe, Inan wó, wa nva ka̱ ó nəm ɓa chu nda ata̱ á.>> 
\p  
\v 9 <<Ka̱kul uYawe ka̱ ɓak oga nnang mbin nkamkam chit ka̱ mpyal wó, kang a ɓa chu nda va̱ ta̱, unəm uro ya kur ndap ká̱ wó ka̱t.  
\v 10 Unəm pa̱ uzəng ka̱ ashe wó, i ɓak okpa ìkum ìkalong, ka̱kul pa̱ uYawe, Inan wó, uwa i lung ìkum ka̱kul wó, wa nva uza̱ ka̱ yar nsar nnap-nlà á wó á.  
\v 11 Te ó nak ishi ká̱ ishi wó pa̱ dakdak, ó ma̱n uYawe, Inan wó.>> 
\p  
\v 12 <<Ǹnyi te, a yà pa̱ ó ga̱ɓa̱n, ó gwang ishi ká̱ aɓo oga mbin va̱ re ka̱ ashe wó, kang ó ka̱m ichar ká̱ ôza̱,  
\v 13 te ó nyi pa̱ kpátkpát pa̱ uYawe, Inan wó i yà ká̱ mɓak oga mbin va̱ ta̱ ka̱ mpyal wó lap ka̱t. Ka̱ɗor nva̱ ta te, oza̱ i tong ipang iga ləp ìfang, ká̱ oga ajəp a wó, oga nlilyat ka̱ asəm wó, kang izú ka̱ ashe íwu wó, yá ó ga ó zhì pa̱ kpaktak ka̱ ashe mbin nnəna̱n va̱ ta̱, nva̱ uYawe, Inan wó ka̱ na á wó á.>> 
\p  
\v 14 <<Ǹyangmata̱ te, mmami ka̱ ngga nwòl asa̱l va̱ nkpaktak apambin i wòl kà̱. Ó nyinyi ká̱ nkpaktak igwák wó ká̱ irirì wó pa̱, oga iya̱m inəna̱n va̱ uYawe, Inan wó ka̱ yar nsar nnap-nlà kà̱ ka̱ apal wó pa̱ kpaktak te, iro pa̱ izəng á ɓur ka̱t.  
\v 15 Ǹnyi te, wa nva nkpaktak oga iya̱m inəna̱n va̱ uYawe, Inan wó ka̱ yar nsar nnap-nlà kà̱ ka̱ apal wó kang iro pa̱ izəng ɓur ka̱t, te wa nnà ta uza̱ i ɓa ka̱ nkpaktak oga iya̱m iɓá̱ngɓa̱ng va̱ uza̱ ka̱ là ka̱ apal wó, i ga chu awalang va̱ uza̱ i zhì wó ka̱ ashe mbin nnəna̱n va̱ ta̱, nva uza̱ ka̱ na á wó á.  
\v 16 A yà pa̱ ó gantal nsar nnap-nlà aYawe, Inan wó va̱ ta̱, nva̱ uza̱ nak á wó, kang ó ga ó wop oga inan iro, ó kuchi ôza̱ te, nlak ìgwak aYawe i fə̀r ka̱ apal wó, kang uza̱ i zhì wó pa̱ kəlak ka̱ ashe mbin nnəna̱n va̱ ta̱, nva uza̱ ka̱ na á wó á.>> 
\c 24  
\s1 Mmá rəng ká̱ nsar nnap-nlà ka̱ aShekem 
\p  
\v 1 Te uJoshuwa ɓut nkpaktak oga akum ìjili oIsa̱rila ka̱ aShekem. Uza̱ wór onəmgbak, ká̱ onəm oga mpyal, ká̱ onəm oga nnáp-akwali, ká̱ onəm oga mpyal ìkum oIsa̱rila. Kang oza̱ ɓa ka̱ mpyal Inan. 
\p  
\v 2 Te uJoshuwa là n̂kpaktak onəm pa̱, <<Iya̱m va ta̱ uYawe, Inan oIsa̱rila là, ka̱ ashe nra va̱ watar te, okəka wó, oma, uTera upo aIbərahim, ká̱ uNahor va̱ ka̱ təm ka̱ gwong aWang aYufriti te, oza̱ wop oga inan iro.  
\v 3 Ǹnyi te, n yar ukəka wó uIbərahim ka̱ gwong aWang aYufriti va̱ cho, kang m ɓa ka̱ na ka̱ ashe nkpaktak mbin aKanana, te n nak akukum myak. N na uIshaku á na,  
\v 4 kang ûIshaku te, n na uYakubu ká̱ uIsuwa á na. Te n na aɓam aSeyir iya̱mkup ûIsuwa, ǹnyi te, uYakubu ká̱ nzhi wò ga aMasar.>> 
\p  
\v 5 <<Te, n re uMusa ká̱ uHaruna, kang n la̱p aMasar ka̱ arwa aɓá̱ngɓa̱ng, wa nva̱ ka̱ n nəm ka̱ ishimshe oza̱ á. Ká̱ nvəva̱ng te, n fa ká̱ wó.  
\v 6 Awalang va̱ n fa ká̱ okəka wó ka̱ ashe aMasar, kang oza̱ fa chu ìwa, te onəm oga aMasar ɓak nva̱ng okəka wó ká̱ oga akeke ipəri, ká̱ onəm oga nkwák ipəri ga chu ìWa iRəzang.  
\v 7 Ǹnyi te, oza̱ yə́ng ûYawe, te uza̱ nak atak kpa̱rkpa̱r ká̱ ishimshe oza̱ ká̱ onəm oga aMasar, kang uza̱ nak ìwa gún oza̱. Ó yi ya ká̱ iwú wó iya̱m va̱ n nəm onəm oga aMasar. Kang ó tətəm ka̱ ashe ǹzam izún pa̱ makmak.  
\v 8 Te, m ɓa ká̱ wó ka̱ mbin oAmori ova təm ka̱ asal nfa alum aUrdun. Oza̱ lung wó, ǹnyi te, n na oza̱ ka̱ ashe awo wó. N zhì oza̱ ka̱ mpyal wó, kang ó ka̱m mbin oza̱.  
\v 9 Ka̱ walang va̱ uBalak uya aZipo ununggwan, uponzhi uga aMowap, a wong pa̱ ò lung oIsa̱rila, kang uza̱ re nre ká̱ ichal ûBalam uya aBeyor ununggwan, pa̱ á ɓa á vyap oza̱.  
\v 10 Ǹnyi te, n gwong achwang ká̱ uBalam ka̱t, ka̱kul nva̱ ta te, uza̱ pak inok nak nnap-nnəna̱n á wó. Ka̱ asal va̱ ta n fa ká̱ wó ka̱ ashe awuwo.>> 
\p  
\v 11 <<Ka̱ walang va̱ ó pa̱ng aUrdun ó ɓa aJariko te, onəm oga aJariko lung wó, wa nnà ta kpa oAmori, ká̱ oPerizi, ká̱ oKanana, ká̱ oHitti, ká̱ oGirgasi, ká̱ oHivi, ká̱ oJebusi. Ǹnyi te, n na oza̱ ka̱ ashe awo wó.  
\v 12 Kang n re nre ka̱ nlàga ka̱ mpyal wó, nva ɓàk oponzhi oga aAmori oga oparəm va̱ ta̱ ka̱ mpyal wó. Ó nəm igwan va̱ ta ka̱ atak ndokchi wó, ka̱t te ìjang wó ka̱t.  
\v 13 N na mbin a wó nva ó ɓək anung ka̱ ka̱t, ká̱ itong iva ó me ka̱t, kang mmawó ka̱ ntəm ka̱ ashishe, ó rì oga awar ìba̱ngba̱ng, ká̱ oga awar mpyet ovəngva mmawó na ó ɓál ka̱t.>> 
\p  
\v 14 <<Ǹyangmata̱ te, ó nəm ayər aYawe, ó wop na ka̱ nkpaktak nnandər. Ó swang oga inan va̱ okəka wó ka̱ wop ka̱ gwong aWang aYufriti, ká̱ ashe aMasar, na ó wop uYawe uwa byet.  
\v 15 Ǹnyi te, a yà pa̱ ó ya pa̱ nwop uYawe iya̱m iɓá̱ngɓa̱ng ka̱ mpyal wó te, ó yak nda va̱ ta̱ unəm va̱ ó wop, mwote oga inan va okəka wó ka̱ wop ka̱ gwong aWang aYufriti, ka̱t te, oga inan oAmori va̱ mmawó ka̱ ntəm ka̱ ashe mbin oza̱. Ǹnyi te, mmami ka̱ nzhi mi jiwò te, í wop uYawe.>> 
\p  
\v 16 Te onəm na ama̱n là pa̱, << Í yà ka̱ nre uYawe, pa̱ í wop inan iro ka̱t.  
\v 17 Ka̱kul pa̱ uYawe, Inan yi uwa fa ka̱ yi ká̱ okəka yi ka̱ mbin aMasar, nzhi ngga nəm izwal, kang uza̱ nəm oga iya̱m ichumchum iga nɗak atak ká̱ iwu yi. Uza̱ kpak yi ka̱ ashe nkpaktak achen va̱ í nəm, ká̱ nkpaktak onəm va̱ í watar ka̱ ashe oza̱ á.  
\v 18 Kang uYawe ɓàk nkpaktak onəm á yi, nzəng ká̱ oAmori va̱ ka̱ ntəm ka̱ ashe mbin va̱ ta̱. Ka̱kul nva̱ ta te, mmayi kpa í wop uYawe, ka̱kul uza̱ wa Inan yi.>> 
\p  
\v 19 Te uJoshuwa là ônəm pa̱, <<Ó chu nwop uYawe ka̱t, ka̱kul uza̱ Inan iyə́ryər. Uza̱ Inan iga ìkpar, uza̱ i yà ka̱ nyar nfa iya̱mkak wó, ká̱ oga nnap-mɓá̱ngɓa̱ng wó ka̱t.  
\v 20 A yà pa̱ ó kap ká̱ uYawe, ó wop oga inan iro te, uza̱ i ga̱ɓa̱n i na mɓək anung a wó, kang i zhì wó, kap ka̱ nva̱ uza̱ ka̱ nəm inəna̱n a wó chit á.>> 
\p  
\v 21 Ǹnyi te, onəm va̱ ta là ûJoshuwa pa̱, <<Pa ka̱t, mmayi te, uYawe wa í wop.>> 
\p  
\v 22 Te uJoshuwa là ôza̱ pa̱, <<Mmawo na ó ta̱l onəm oga nshet nnàp îshi wó pa̱ ó yak uYawe chit, uwa ó wop á.>> 
\p Te oza̱ na ama̱n pa̱, <<Á, mmayi na onəm oga nshet nnàp.>> 
\p  
\v 23 Te, uJoshuwa là ôza̱ pa̱, <<Ǹyangmata̱ te, ó swang oga inan iga mbin nkak va̱ ka̱ ashe wó, ó ga̱ɓa̱n igwák wó ka̱ atak aYawe, Inan oIsa̱rila.>> 
\p  
\v 24 Te onəm va̱ ta là ûJoshuwa pa̱, << UYawe, Inan yi uwa i wop, kang uwa i kpak nnap-nnəm á na.>> 
\p  
\v 25 Ka̱ nda va̱ ta te, uJoshuwa yar nsar nnap-nlà ka̱ onəm, kang uza̱ pak oga nnap-mpakpak ká̱ oga nnap-nnəm ôza̱ ka̱ aShekem.  
\v 26 Kang uza̱ lir oga nnap-nlà va̱ ta ka̱ ashe nlir ngga nnap-mpakpak Inan. Te uza̱ yar inang ìpang kang uza̱ pak ka̱ ta ka̱ akum ikún aOak ka̱ atak ayə́ryər aYawe. 
\p  
\v 27 Te uJoshuwa là n̂kpaktak onəm pa̱, <<Ó dər, ìpang va̱ ta̱ i yà nshet nnap ka̱ apal yi. Ka̱kul á fe nkpaktak oga nnap-nlà va̱ uYawe là á yi chit. Ka̱kul nva̱ ta te, i ga nyà nshet nnap ka̱ apal wó, á ya pa̱ ó yang ka̱ Inan wó á.>> 
\p  
\v 28 Te uJoshuwa re onəm va̱ ta ga, nza̱ unəm nggo le ka̱ atak iya̱mkup wò. 
\s1 Ikú aJoshuwa ká̱ uEleyazar 
\p  
\v 29 Ka̱ nva̱ng oga iya̱m va̱ ta̱ te, uJoshuwa uya aNun ununggwan, uzwal aYawe kú, uza̱ ka̱ ìzun igba̱l pa̱ izəng ka̱ ngba̱pchi.  
\v 30 Kang oza̱ li na ka̱ mbin iya̱mkukup ka̱ aTimnat-Sera, va ka̱ mbin ngga aɗuktum aEfrayim, ka̱ asa̱l mpal aƁam aGayash. 
\p  
\v 31 OIsa̱rila wop uYawe ka̱ ashe nkpaktak nra aJoshuwa, ká̱ nkpaktak nra onəmgbak va̱ oma yà ká̱ irirì ka̱ nva̱ng ikuku, ovəngva nyi nkpaktak oga iya̱m va̱ uYawe nəm ka̱kul oIsa̱rila á. 
\p  
\v 32 Kang oga akup aYusufu va̱ onəm oIsa̱rila fa kà̱ ka̱ aMasar te, oza̱ li ka̱ aShekem, ka̱ ashe atak va̱ uYakubu yáp ka̱ ovan aHamor onunggwan, upo aShekem ka̱ apal aazurfa igba̱l pa̱ izəng. Atak va̱ ta təm iya̱mkup akum ìjili aYusufu. 
\p  
\v 33 Kang uEleyazar uya aHaruna ununggwan kú, te oza̱ li na ka̱ aGibeya, ìtong iva mmá ka̱ na ûyiyen uFinehas chit ka̱ mbin aɗuktum aEfrayim.