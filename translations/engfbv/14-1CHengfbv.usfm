\c 4
\p 
\v 1 \w The|strong="H1121"\w* \w sons|strong="H1121"\w* \w of|strong="H1121"\w* \w Judah|strong="H3063"\w*: \w Perez|strong="H6557"\w*, \w Hezron|strong="H2696"\w*, \w Carmi|strong="H3756"\w*, \w Hur|strong="H2354"\w*, \w and|strong="H1121"\w* \w Shobal|strong="H7732"\w*.
\v 2 \w Reaiah|strong="H7211"\w*, \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Shobal|strong="H7732"\w*, \w was|strong="H1121"\w* \w the|strong="H3205"\w* \w father|strong="H3205"\w* \w of|strong="H1121"\w* \w Jahath|strong="H3189"\w*. \w Jahath|strong="H3189"\w* \w was|strong="H1121"\w* \w the|strong="H3205"\w* \w father|strong="H3205"\w* \w of|strong="H1121"\w* Ahumai \w and|strong="H1121"\w* \w Lahad|strong="H3855"\w*. These \w were|strong="H1121"\w* \w the|strong="H3205"\w* \w families|strong="H4940"\w* \w of|strong="H1121"\w* \w the|strong="H3205"\w* \w Zorathites|strong="H6882"\w*.
\p 
\v 3 These \w were|strong="H8034"\w* \w the|strong="H8034"\w* sons\f + \fr 4:3 \ft “Sons”: the Hebrew text reads “father,” but some Septuagint manuscripts and the Vulgate read “sons.”\f* \w of|strong="H8034"\w* \w Etam|strong="H5862"\w*: \w Jezreel|strong="H3157"\w*, \w Ishma|strong="H3457"\w*, \w and|strong="H8034"\w* \w Idbash|strong="H3031"\w*. Their sister \w was|strong="H8034"\w* \w called|strong="H8034"\w* \w Hazzelelponi|strong="H6753"\w*.
\v 4 \w Penuel|strong="H6439"\w* \w was|strong="H1121"\w* \w the|strong="H1121"\w* \w father|strong="H1121"\w* \w of|strong="H1121"\w* \w Gedor|strong="H1446"\w*, \w and|strong="H1121"\w* \w Ezer|strong="H5829"\w* \w was|strong="H1121"\w* \w the|strong="H1121"\w* \w father|strong="H1121"\w* \w of|strong="H1121"\w* \w Hushah|strong="H2364"\w*. These \w were|strong="H1121"\w* \w the|strong="H1121"\w* \w descendants|strong="H1121"\w* \w of|strong="H1121"\w* \w Hur|strong="H2354"\w*, Ephrathah's \w firstborn|strong="H1060"\w* \w and|strong="H1121"\w* \w father|strong="H1121"\w*\f + \fr 4:4 \ft “Father”: probably in the sense of “founder.”\f* \w of|strong="H1121"\w* \w Bethlehem|strong="H1035"\w*.
\p 
\v 5 Ashhur \w was|strong="H1961"\w* \w the|strong="H1961"\w* father \w of|strong="H8147"\w* \w Tekoa|strong="H8620"\w* \w and|strong="H8147"\w* \w had|strong="H1961"\w* \w two|strong="H8147"\w* wives, \w Helah|strong="H2458"\w* \w and|strong="H8147"\w* \w Naarah|strong="H5292"\w*.
\p 
\v 6 \w Naarah|strong="H5292"\w* \w was|strong="H1121"\w* \w the|strong="H3205"\w* mother \w of|strong="H1121"\w* Ahuzzam, \w Hepher|strong="H2660"\w*, \w Temeni|strong="H8488"\w*, \w and|strong="H1121"\w* Haahashtari. These \w were|strong="H1121"\w* \w the|strong="H3205"\w* \w sons|strong="H1121"\w* \w of|strong="H1121"\w* \w Naarah|strong="H5292"\w*.
\p 
