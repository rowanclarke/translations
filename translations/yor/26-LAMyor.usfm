\id LAM - Biblica® Open Yoruba Contemporary Bible 2017
\h Ẹkún Jeremiah
\toc1 Ìwé Ẹkún Jeremiah
\toc2 Ẹkún Jeremiah
\toc3 Ẹj
\mt1 Ìwé Ẹkún Jeremiah
\c 1
\q1 
\v 1 Báwo ni ìlú ṣe jókòó nìkan,
\q2 nígbà kan tí ó sì kún fún ènìyàn!
\q1 Ó ti fìgbà kan jẹ́ ìlú olókìkí láàrín àwọn orílẹ̀-èdè,
\q2 tí ó wà ní ipò opó,
\q1 ẹni tí ó jẹ́ ọmọ ọbabìnrin láàrín ìlú
\q2 ni ó padà di ẹrú.
\b
\q1 
\v 2 Ọ̀gànjọ́ òru ni ó fi máa ń sọkún kíkorò
\q2 pẹ̀lú omijé ní ẹ̀rẹ̀kẹ́ rẹ̀ tí ó dúró sí ẹ̀rẹ̀kẹ́ rẹ̀.
\q1 Nínú gbogbo àwọn olólùfẹ́ rẹ̀
\q2 kò sí ọ̀kan nínú wọn láti rẹ̀ ẹ́ lẹ́kún.
\q1 Gbogbo àwọn ọ̀rẹ́ rẹ̀ ti jọ̀wọ́ rẹ̀
\q2 wọ́n ti di alátakò rẹ̀.
\b
\q1 
\v 3 Lẹ́yìn ìjìyà àti ìpọ́njú nínú oko ẹrú,
\q2 Juda lọ sí àjò
\q1 Ó tẹ̀dó láàrín àwọn orílẹ̀-èdè,
\q2 ṣùgbọ́n kò rí ibi ìsinmi.
\q1 Àwọn tí ó ń tẹ̀lé ká á mọ́
\q2 ibi tí kò ti le sá àsálà.
\b
\q1 
\v 4 Gbogbo ọ̀nà tí ó wọ Sioni ń ṣọ̀fọ̀,
\q2 nítorí ẹnìkan kò wá sí àjọ̀dún tí a yàn.
\q1 Gbogbo ẹnu-bodè rẹ̀ dahoro,
\q2 àwọn àlùfáà rẹ̀ kẹ́dùn,
\q1 àwọn wúńdíá rẹ̀ sì ń káàánú,
\q2 òun gan an wà ní ọkàn kíkorò.
\b
\q1 
\v 5 Àwọn aninilára rẹ̀ gbogbo di olúwa rẹ̀,
\q2 nǹkan sì rọrùn fún àwọn ọ̀tá rẹ̀,
\q1 \nd Olúwa\nd* ti fún un ní ìjìyà tó tọ́
\q2 nítorí àwọn ẹ̀ṣẹ̀ rẹ̀.
\q1 Àwọn ẹ̀ṣọ́ wẹ́wẹ́ rẹ̀ lọ sí oko ẹrú,
\q2 ìgbèkùn níwájú àwọn ọ̀tá.
\b
\q1 
\v 6 Gbogbo ẹwà ti di ohun ìgbàgbé
\q2 kúrò lọ́dọ̀ ọmọbìnrin Sioni.
\q2 Àwọn ìjòyè rẹ̀ dàbí i àgbọ̀nrín
\q1 tí kò rí ewé tútù jẹ;
\q2 nínú àárẹ̀ wọ́n sáré
\q1 níwájú ẹni tí ó ń lé wọn.
\b
\q1 
\v 7 Ní ọjọ́ ìpọ́njú àti àrìnká rẹ̀ ni
\q2 Jerusalẹmu rántí àwọn ohun ìní dáradára rẹ̀
\q2 tí ó jẹ́ tirẹ̀ ní ọjọ́ pípẹ́.
\q1 Nígbà tí àwọn ènìyàn rẹ̀ ṣubú ṣọ́wọ́ àwọn ọ̀tá,
\q2 kò sì ṣí olùrànlọ́wọ́ fún un.
\q1 Àwọn ọ̀tá rẹ̀ wò ó
\q2 wọ́n sì ń fi ìparun rẹ̀ ṣẹlẹ́yà.
\b
\q1 
\v 8 Jerusalẹmu sì ti dẹ́ṣẹ̀ púpọ̀
\q2 ó sì ti di aláìmọ́.
\q1 Àwọn tí ó ń tẹríba fún un sì kẹ́gàn rẹ̀,
\q2 nítorí wọ́n ti rí ìhòhò rẹ̀;
\q1 ó kérora fúnra rẹ̀,
\q2 ó sì lọ kúrò.
\b
\q1 
\v 9 Ìdọ̀tí wà ní etí aṣọ rẹ̀,
\q2 bẹ́ẹ̀ ni kò wo ọjọ́ iwájú rẹ̀.
\q1 Ìṣubú rẹ̀ ya ni lẹ́nu;
\q2 olùtùnú kò sì ṣí fún un.
\q1 “Wo ìpọ́njú mi, \nd Olúwa\nd*,
\q2 nítorí àwọn ọ̀tá ti borí.”
\b
\q1 
\v 10 Ọ̀tá ti gbọ́wọ́ lé
\q2 gbogbo ìní rẹ;
\q1 o rí pé àwọn orílẹ̀-èdè
\q2 tí wọ́n wọ ibi mímọ́ rẹ—
\q1 àwọn tí o ti kọ̀sílẹ̀
\q2 láti wọ ìpéjọpọ̀ rẹ.
\b
\q1 
\v 11 Àwọn ènìyàn rẹ̀ ń kérora
\q2 bí wọ́n ti ń wá oúnjẹ;
\q1 wọ́n fi ohun ìní wọn ṣe pàṣípàrọ̀ oúnjẹ
\q2 láti mú wọn wà láààyè.
\q1 “Wò ó, \nd Olúwa\nd*, kí o sì rò ó,
\q2 nítorí a kọ̀ mí sílẹ̀.”
\b
\q1 
\v 12 “Kò ha jẹ́ nǹkan kan sí i yín?
\q2 Gbogbo ẹ̀yin tí ń rékọjá.
\q1 Ǹjẹ́ ẹnìkan ń jìyà bí èmi ti ń jìyà
\q2 tí a fi fún mi, ti
\q1 \nd Olúwa\nd* mú wá fún mi
\q2 ní ọjọ́ ìbínú gbígbóná rẹ̀.
\b
\q1 
\v 13 “Ó rán iná láti òkè
\q2 sọ̀kalẹ̀ sínú egungun ara mi.
\q1 Ó dẹ àwọ̀n fún ẹsẹ̀ mi,
\q2 ó sì yí mi padà.
\q1 Ó ti pa mí lára
\q2 mó ń kú lọ ní gbogbo ọjọ́.
\b
\q1 
\v 14 “Ẹ̀ṣẹ̀ mi ti di sísopọ̀ sí àjàgà;
\q2 ọwọ́ rẹ̀ ni a fi hun ún papọ̀.
\q1 Wọ́n ti yí ọrùn mi ká
\q2 Olúwa sì ti dín agbára mi kù.
\q1 Ó sì ti fi mí lé
\q2 àwọn tí n kò le dojúkọ lọ́wọ́.
\b
\q1 
\v 15 “Olúwa kọ
\q2 àwọn akọni mi sílẹ̀,
\q1 ó rán àwọn ológun lòdì sí mi
\q2 kí wọn pa àwọn ọ̀dọ́mọkùnrin mi run.
\q1 Nínú ìfúntí wáìnì rẹ̀ Olúwa tẹ́
\q2 àwọn ọ̀dọ́mọbìnrin Juda.
\b
\q1 
\v 16 “Ìdí nìyí tí mo fi ń sọkún
\q2 tí omijé sì ń dà lójú mi.
\q1 Olùtùnú àti ẹni tí ó le mú ọkàn mi sọjí jìnnà sí mi,
\q2 kò sí ẹni tí yóò dá ẹ̀mí mi padà.
\q1 Àwọn ọmọ mi di aláìní
\q2 nítorí ọ̀tá ti borí.”
\b
\q1 
\v 17 Sioni na ọwọ́ jáde,
\q2 ṣùgbọ́n kò sí olùtùnú fún un.
\q1 \nd Olúwa\nd* ti pàṣẹ fún Jakọbu
\q2 pé àwọn ará ilé rẹ̀ di ọ̀tá fún un
\q1 Jerusalẹmu ti di
\q2 ohun aláìmọ́ láàrín wọn.
\b
\q1 
\v 18 “Olóòtítọ́ ni \nd Olúwa\nd*,
\q2 ṣùgbọ́n mo ṣọ̀tẹ̀ sí àṣẹ rẹ̀.
\q1 Ẹ gbọ́, gbogbo ènìyàn;
\q2 ẹ wò mí wò ìyà mi.
\q1 Gbogbo ọ̀dọ́mọkùnrin àti ọ̀dọ́mọbìnrin mi
\q2 ni a ti kó lọ sí ìgbèkùn.
\b
\q1 
\v 19 “Mo pe àwọn ọ̀rẹ́ mi
\q2 ṣùgbọ́n wọ́n dà mí.
\q1 Àwọn olórí àlùfáà àti àgbàgbà mi
\q2 ṣègbé sínú ìlú
\q1 nígbà tí wọ́n ń wá oúnjẹ
\q2 tí yóò mú wọn wà láààyè.
\b
\q1 
\v 20 “\nd Olúwa\nd*, wò ó, bí mo ti wà nínú ìnira!
\q2 Tí mo sì ń jẹ̀rora nínú mi,
\q1 ìdààmú dé bá ọkàn mi
\q2 nítorí pé a ti ṣọ̀tẹ̀ sí mi gidigidi.
\q1 Ní gbangba ni idà ń parun;
\q2 ikú wà nínú ilé pẹ̀lú.
\b
\q1 
\v 21 “Àwọn ènìyàn ti gbọ́ ìrora mi,
\q2 ṣùgbọ́n kò sí olùtùnú fún mi.
\q1 Àwọn ọ̀tá mi ti gbọ́ ìparun mi;
\q2 wọ́n yọ̀ sí ohun tí o ṣe.
\q1 Kí o mú ọjọ́ tí o ti kéde,
\q2 kí wọ́n le dàbí tèmi.
\b
\q1 
\v 22 “Jẹ́ kí ìwà ìkà wọn wá síwájú rẹ;
\q2 jẹ wọ́n ní yà
\q1 bí o ṣe jẹ mí ní yà
\q2 nítorí gbogbo ẹ̀ṣẹ̀ mi.
\q1 Ìrora mi pọ̀
\q2 ọkàn mi sì rẹ̀wẹ̀sì.”
\b
\b
\c 2
\q1 
\v 1 Báwo ni Olúwa ṣe bo ọmọbìnrin Sioni
\q2 pẹ̀lú àwọsánmọ̀ ìbínú rẹ̀!
\q1 Ó sọ ògo Israẹli kalẹ̀,
\q2 láti ọ̀run sí ayé;
\q1 kò rántí àpótí ìtìsẹ̀ rẹ̀
\q2 ní ọjọ́ ìbínú rẹ̀.
\b
\q1 
\v 2 Láìní àánú ni Olúwa gbé
\q2 ibùgbé Jakọbu mì;
\q1 nínú ìrunú rẹ̀, ni ó wó
\q2 ibi gíga ọmọbìnrin Juda lulẹ̀.
\q1 Ó ti mú ìjọba àti àwọn ọmọ-aládé ọkùnrin
\q2 lọ sínú ilẹ̀ ní àìlọ́wọ̀.
\b
\q1 
\v 3 Ní ìbínú gbígbóná rẹ̀ ni ó ké
\q2 gbogbo ìwo Israẹli.
\q1 Ó ti mú ọwọ́ ọ̀tún rẹ̀ kúrò
\q2 nígbà tí àwọn ọ̀tá dé.
\q1 Ó run ní Jakọbu bí ọ̀wọ́-iná
\q2 ní àgọ́ àwọn ọmọbìnrin Sioni.
\b
\q1 
\v 4 Ó na ọfà rẹ̀ bí ọ̀tá;
\q2 ọwọ́ ọ̀tún rẹ̀ sì múra.
\q1 Bí ti ọ̀tá tí ó ti parun
\q2 ó tú ìbínú rẹ̀ jáde bí iná
\q1 sórí àgọ́ ọmọbìnrin Sioni.
\b
\q1 
\v 5 Olúwa dàbí ọ̀tá;
\q2 ó gbé Israẹli mì.
\q1 Ó ti gbé gbogbo ààfin rẹ̀ mì
\q2 ó pa ibi gíga rẹ̀ run.
\q1 Ó sọ ìmí ẹ̀dùn àti ìbànújẹ́ di púpọ̀
\q2 fún àwọn ọmọbìnrin Juda.
\b
\q1 
\v 6 Ó mú ìparun bá ibi mímọ́,
\q2 ó pa ibi ìpàdé rẹ̀ run.
\q1 \nd Olúwa\nd* ti mú Sioni gbàgbé
\q2 àjọ̀dún tí a yàn àti ọ̀sẹ̀ tí ó yàn;
\q1 nínú ìbínú gbígbóná rẹ̀ ni ó run
\q2 ọba àti olórí àlùfáà.
\b
\q1 
\v 7 Olúwa ti kọ̀ pẹpẹ rẹ̀ sílẹ̀
\q2 ó sì ti kọ̀ ibi mímọ́ rẹ̀.
\q1 Ó sì fi lé ọ̀tá lọ́wọ́
\q2 àwọn odi ààfin rẹ̀;
\q1 wọ́n sì kígbe ní ilé \nd Olúwa\nd*
\q2 gẹ́gẹ́ bí ọjọ́ àpèjẹ tí a yàn.
\b
\q1 
\v 8 \nd Olúwa\nd* pinnu láti fa
\q2 ògiri tí ó yí ọmọbìnrin Sioni ya.
\q1 Ó gbé wọn sórí òsùwọ̀n,
\q2 kò sì fa ọwọ́ rẹ̀ padà kúrò nínú ìparun wọn.
\q1 Ó mú kí ilé ìṣọ́ àti odi rẹ̀ ṣọ̀fọ̀
\q2 wọ́n ṣòfò papọ̀.
\b
\q1 
\v 9 Ẹnu-ọ̀nà rẹ̀ ti wọ inú ilẹ̀;
\q2 òpó rẹ̀ ni ó wó tí ó sì ti bàjẹ́.
\q1 Ọba àti ọmọ ọbakùnrin rẹ̀ wà ní ìgbèkùn láàrín àwọn orílẹ̀-èdè,
\q2 kò sí òfin mọ́,
\q1 àwọn wòlíì rẹ̀ kò rí
\q2 ìran láti ọ̀dọ̀ \nd Olúwa\nd* mọ́.
\b
\q1 
\v 10 Àwọn àgbàgbà ọmọbìnrin Sioni
\q2 jókòó sílẹ̀ ní ìdákẹ́rọ́rọ́;
\q1 wọ́n da eruku sí orí wọn
\q2 wọ́n sì wọ aṣọ àkísà.
\q1 Àwọn ọ̀dọ́mọbìnrin Jerusalẹmu
\q2 ti tẹrí wọn ba sí ilẹ̀.
\b
\q1 
\v 11 Ojú mi kọ̀ láti sọkún,
\q2 mo ń jẹ ìrora nínú mi,
\q1 mo tú ọkàn mi jáde sí ilẹ̀
\q2 nítorí a pa àwọn ènìyàn mí run,
\q1 nítorí àwọn ọmọdé àti ọmọ ọwọ́ ń kú
\q2 ní òpópó ìlú.
\b
\q1 
\v 12 Wọ́n wí fún àwọn ìyá wọn,
\q2 “Níbo ni ọkà àti wáìnì wà?” Wò ó
\q1 bí wọ́n ṣe ń kú lọ bí àwọn ọkùnrin tí a ṣe léṣe
\q2 ní àwọn òpópónà ìlú,
\q1 bí ayé wọn ṣe ń ṣòfò
\q2 láti ọwọ́ ìyá wọn.
\b
\q1 
\v 13 Kí ni mo le sọ fún ọ?
\q2 Pẹ̀lú kí ni mo lè fi ọ́ wé,
\q2 ìwọ ọmọbìnrin Jerusalẹmu?
\q1 Kí sì ni mo lè fi ọ́ wé,
\q2 kí n lè tù ọ́ nínú,
\q2 ìwọ wúńdíá obìnrin Sioni?
\q1 Ọgbẹ́ rẹ jì bí Òkun.
\q2 Ta ni yóò wò ọ́ sàn?
\b
\q1 
\v 14 Ìran àwọn wòlíì rẹ
\q2 jẹ́ kìkì ẹ̀tàn láìní ìwọ̀n;
\q1 wọn kò sì fi ẹ̀ṣẹ̀ rẹ̀ hàn
\q2 tí yóò mú ìgbèkùn kúrò fún ọ.
\q1 Àwọn òrìṣà tí wọ́n fún ọ
\q2 jẹ́ èké àti ìmúniṣìnà.
\b
\q1 
\v 15 Àwọn tí ó gba ọ̀nà ọ̀dọ̀ rẹ
\q2 pàtẹ́wọ́ lé ọ lórí;
\q1 wọ́n kẹ́gàn wọ́n ju orí wọn
\q2 sí ọmọbìnrin Jerusalẹmu:
\q1 “Èyí ha ni ìlú tí à ń pè
\q2 ní àṣepé ẹwà,
\q2 ìdùnnú gbogbo ayé?”
\b
\q1 
\v 16 Gbogbo àwọn ọ̀tá rẹ la ẹnu wọn
\q2 gbòòrò sí ọ;
\q1 wọ́n kẹ́gàn, wọ́n sì payínkeke
\q2 wọ́n wí pé, “A ti gbé e mì tán.
\q1 Èyí ni ọjọ́ tí a ti ń retí;
\q2 tí a sì wá láti rí.”
\b
\q1 
\v 17 \nd Olúwa\nd* ti ṣe ohun tí ó pinnu;
\q2 ó ti mú ọ̀rọ̀ rẹ̀ ṣẹ,
\q2 tí ó sì pàṣẹ ní ọjọ́ pípẹ́.
\q1 Ó ti ṣí ọ ní ipò láì láàánú,
\q2 ó fún ọ̀tá ní ìṣẹ́gun lórí rẹ,
\q2 ó ti gbé ìwo àwọn ọ̀tá rẹ̀ ga.
\b
\q1 
\v 18 Ọkàn àwọn ènìyàn
\q2 kígbe jáde sí \nd Olúwa\nd*.
\q1 Odi ọmọbìnrin Sioni,
\q2 jẹ́ kí ẹkún rẹ̀ sàn bí odò
\q2 ní ọ̀sán àti òru;
\q1 má ṣe fi ara rẹ fún ìtura,
\q2 ojú rẹ fún ìsinmi.
\b
\q1 
\v 19 Dìde, kígbe sókè ní àṣálẹ́,
\q2 bí ìṣọ́ òru ti bẹ̀rẹ̀
\q1 tú ọkàn rẹ̀ jáde bí omi
\q2 níwájú \nd Olúwa\nd*.
\q1 Gbé ọwọ́ yín sókè sí i
\q2 nítorí ẹ̀mí àwọn èwe rẹ̀
\q1 tí ó ń kú lọ nítorí ebi
\q2 ní gbogbo oríta òpópó.
\b
\q1 
\v 20 “Wò ó, \nd Olúwa\nd*, kí o sì rò ó.
\q2 Ta ni ìwọ ti fìyà jẹ bí èyí.
\q1 Ǹjẹ́ àwọn obìnrin yóò ha jẹ ọmọ wọn,
\q2 àwọn ọmọ tí wọn ń ṣe ìtọ́jú fún?
\q1 Ǹjẹ́ kí a pa olórí àlùfáà àti àwọn wòlíì
\q2 ní ibi mímọ́ \nd Olúwa\nd*?
\b
\q1 
\v 21 “Ọmọdé àti àgbà ń sùn papọ̀
\q2 sínú eruku àwọn òpópó;
\q1 àwọn ọ̀dọ́mọkùnrin àti ọ̀dọ́mọbìnrin mi
\q2 ti ṣègbé nípa idà.
\q1 Ìwọ pa wọ́n run ní ọjọ́ ìbínú rẹ,
\q2 Ìwọ pa wọ́n láìní àánú.
\b
\q1 
\v 22 “Bí ó ti ṣe ní ọjọ́ àsè,
\q2 bẹ́ẹ̀ ni ó ṣe fi ẹ̀rù sí ẹ̀gbẹ́ mi.
\q1 Ní ọjọ́ ìbínú \nd Olúwa\nd*
\q2 kò sí ẹni tí ó sálà tí ó sì yè;
\q1 àwọn tí mo ti tọ́jú tí mo sì fẹ́ràn,
\q2 ni ọ̀tá mi parun.”
\b
\b
\c 3
\q1 
\v 1 Èmi ni ọkùnrin tí ó rí ìpọ́njú
\q2 pẹ̀lú ọ̀pá ìbínú rẹ.
\q1 
\v 2 Ó ti lé mi jáde ó sì mú mi rìn
\q2 nínú òkùnkùn ju ti ìmọ́lẹ̀.
\q1 
\v 3 Nítòótọ́, ó ti yí ọwọ́ rẹ̀ padà sí mi
\q2 síwájú àti síwájú sí i ní gbogbo ọjọ́.
\b
\q1 
\v 4 Ó jẹ́ kí àwọ̀ mi àti ẹran-ara mi gbó
\q2 ó sì tún ṣẹ́ egungun mi.
\q1 
\v 5 Ó ti fi mí sí ìgbèkùn, ó sì ti yí mi ká
\q2 pẹ̀lú ìkorò àti làálàá.
\q1 
\v 6 Ó mú mi gbé nínú òkùnkùn,
\q2 bí ti àwọn tó ti kú fún ìgbà pípẹ́.
\b
\q1 
\v 7 Ó ti tì mí mọ́ ilé, nítorí náà n kò le è sálọ;
\q2 ó ti fi ẹ̀wọ̀n mú mi mọ́lẹ̀.
\q1 
\v 8 Pàápàá nígbà tí mo ké fún ìrànlọ́wọ́,
\q2 ó kọ àdúrà mi.
\q1 
\v 9 Ó fi ògiri òkúta dí ọ̀nà mi;
\q2 ó sì mú ọ̀nà mi wọ́.
\b
\q1 
\v 10 Bí i beari tí ó dùbúlẹ̀,
\q2 bí i kìnnìún tí ó sá pamọ́.
\q1 
\v 11 Ó wọ́ mi kúrò ní ọ̀nà, ó tẹ̀ mí mọ́lẹ̀
\q2 ó fi mi sílẹ̀ láìsí ìrànlọ́wọ́.
\q1 
\v 12 Ó fa ọfà rẹ̀ yọ
\q2 ó sì fi mí ṣe ohun ìtafàsí.
\b
\q1 
\v 13 Ó fa ọkàn mí ya
\q2 pẹ̀lú ọfà nínú àkọ̀ rẹ̀.
\q1 
\v 14 Mo di ẹni yẹ̀yẹ́ láàrín àwọn ènìyàn mi;
\q2 wọn yẹ̀yẹ́ mi pẹ̀lú orin ní gbogbo ọjọ́.
\q1 
\v 15 Ó ti kún mi pẹ̀lú ewé kíkorò
\q2 àti ìdààmú bí omi.
\b
\q1 
\v 16 Ó ti fi òkúta kán eyín mi;
\q2 ó ti tẹ̀ mí mọ́lẹ̀ nínú eruku.
\q1 
\v 17 Mo ti jìnnà sí àlàáfíà;
\q2 mo ti gbàgbé ohun tí àṣeyege ń ṣe.
\q1 
\v 18 Nítorí náà mo wí pé, “Ògo mi ti lọ
\q2 àti ìrètí mi nínú \nd Olúwa\nd*.”
\b
\q1 
\v 19 Mo ṣe ìrántí ìpọ́njú àti ìdààmú mi,
\q2 ìkorò àti ìbànújẹ́.
\q1 
\v 20 Mo ṣèrántí wọn,
\q2 ọkàn mi sì gbọgbẹ́ nínú mi.
\q1 
\v 21 Síbẹ̀, èyí ni mo ní ní ọkàn
\q2 àti nítorí náà ní mo nírètí.
\b
\q1 
\v 22 Nítorí ìfẹ́ \nd Olúwa\nd* tí ó lágbára ni àwa kò fi ṣègbé,
\q2 nítorí ti àánú rẹ kì í kùnà.
\q1 
\v 23 Wọ́n jẹ́ ọ̀tún ní àárọ̀;
\q2 títóbi ni òdodo rẹ̀.
\q1 
\v 24 Mo wí fún ara mi, ìpín mi ni \nd Olúwa\nd*;
\q2 nítorí náà èmi yóò dúró dè ọ́.
\b
\q1 
\v 25 Dídára ni \nd Olúwa\nd* fún àwọn tí ó ní ìrètí nínú rẹ̀,
\q2 sí àwọn tí ó ń wá a.
\q1 
\v 26 Ó dára kí a ní sùúrù
\q2 fún ìgbàlà \nd Olúwa\nd*.
\q1 
\v 27 Ó dára fún ènìyàn láti gbé àjàgà
\q2 nígbà tí ó wà ní èwe.
\b
\q1 
\v 28 Jẹ́ kí ó jókòó ní ìdákẹ́ jẹ́ẹ́,
\q2 nítorí \nd Olúwa\nd* ti fi fún un.
\q1 
\v 29 Jẹ́ kí ó bo ojú rẹ̀ sínú eruku—
\q2 ìrètí sì lè wà.
\q1 
\v 30 Jẹ́ kí ó fi ẹ̀rẹ̀kẹ́ fún àwọn tí yóò gbá a,
\q2 sì jẹ́ kí ó wà ní ìdójútì.
\b
\q1 
\v 31 Ènìyàn kò di ìtanù
\q2 lọ́dọ̀ Olúwa títí láé.
\q1 
\v 32 Lóòtítọ́ ó mú ìbànújẹ́ wá, yóò fi àánú hàn,
\q2 nítorí títóbi ni ìfẹ́ rẹ̀.
\q1 
\v 33 Nítorí kò mọ̀ ọ́n mọ̀ mú ìpọ́njú wá
\q2 tàbí ìrora wá fún ọmọ ènìyàn.
\b
\q1 
\v 34 Láti tẹ mọ́lẹ̀ lábẹ́ ẹsẹ̀
\q2 gbogbo àwọn ẹlẹ́wọ̀n ní ilẹ̀ náà.
\q1 
\v 35 Láti ṣẹ́ ọmọ ènìyàn fún ẹ̀tọ́ rẹ̀
\q2 níwájú Ọ̀gá-ògo jùlọ,
\q1 
\v 36 láti yí ìdájọ́ ènìyàn padà,
\q2 ǹjẹ́ Olúwa kò rí ohun bẹ́ẹ̀.
\b
\q1 
\v 37 Ta ni yóò sọ̀rọ̀ tí yóò rí bẹ́ẹ̀
\q2 tí Olúwa kò bá fi àṣẹ sí i.
\q1 
\v 38 Ǹjẹ́ kì í ṣe láti ẹnu Ọ̀gá-ògo jùlọ
\q2 ni rere àti búburú tí ń wá?
\q1 
\v 39 Kí ló dé tí ẹ̀dá alààyè ṣe ń kùn
\q2 nígbà tí ó bá ń jìyà ẹ̀ṣẹ̀ rẹ̀?
\b
\q1 
\v 40 Ẹ jẹ́ kí a yẹ ọ̀nà wa, kí a sì dán an wò,
\q2 kí a sì tọ \nd Olúwa\nd* lọ.
\q1 
\v 41 Ẹ jẹ́ kí a gbé ọkàn àti ọwọ́ wa sókè
\q2 sí Ọlọ́run ní ọ̀run, kí a wí pé,
\q1 
\v 42 “Àwa ti ṣẹ̀ a sì ti ṣọ̀tẹ̀
\q2 ìwọ kò sì fi ẹ̀ṣẹ̀ wa jì wá.
\b
\q1 
\v 43 “Ìwọ fi ìbínú bo ara rẹ ìwọ sì ń lépa wa;
\q2 ìwọ ń parun láìsí àánú.
\q1 
\v 44 Ìwọ ti fi àwọsánmọ̀ bo ara rẹ
\q2 pé kí àdúrà wa má ba à dé ọ̀dọ̀ rẹ.
\q1 
\v 45 Ó ti sọ wá di èérí àti ààtàn
\q2 láàrín orílẹ̀-èdè gbogbo.
\b
\q1 
\v 46 “Gbogbo àwọn ọ̀tá wa ti la ẹnu wọn
\q2 gbòòrò sí wa.
\q1 
\v 47 Àwa ti jìyà àti ìparun,
\q2 nínú ìbẹ̀rù àti ewu.”
\q1 
\v 48 Omijé ń sàn ní ojú mi bí odò
\q2 nítorí a pa àwọn ènìyàn mi run.
\b
\q1 
\v 49 Ojú mi kò dá fún omijé,
\q2 láì sinmi,
\q1 
\v 50 títí ìgbà tí \nd Olúwa\nd* yóò síjú wolẹ̀
\q2 láti òkè ọ̀run tí yóò sì rí i.
\q1 
\v 51 Ohun tí mo rí mú ìbẹ̀rù wá ọkàn mi
\q2 nítorí gbogbo àwọn obìnrin ìlú mi.
\b
\q1 
\v 52 Àwọn tí ó jẹ́ ọ̀tá mi láìnídìí
\q2 dẹ mí bí ẹyẹ.
\q1 
\v 53 Wọ́n gbìyànjú láti mú òpin dé bá ayé mi nínú ihò
\q2 wọ́n sì ju òkúta lù mí.
\q1 
\v 54 Orí mi kún fún omi,
\q2 mo sì rò pé ìgbẹ̀yìn dé.
\b
\q1 
\v 55 Mo pe orúkọ rẹ, \nd Olúwa\nd*,
\q2 láti ọ̀gbun ìsàlẹ̀ ihò.
\q1 
\v 56 Ìwọ gbọ́ ẹ̀bẹ̀ mi, “Má ṣe di etí rẹ
\q2 sí igbe ẹ̀bẹ̀ mi fún ìtura.”
\q1 
\v 57 O wá tòsí nígbà tí mo ké pè ọ́,
\q2 o sì wí pé, “Má ṣe bẹ̀rù.”
\b
\q1 
\v 58 \nd Olúwa\nd*, ìwọ gba ẹjọ́ mi rò,
\q2 o ra ẹ̀mí mi padà.
\q1 
\v 59 O ti rí i, \nd Olúwa\nd*, búburú tí a ṣe sí mi.
\q2 Gba ẹjọ́ mi ró!
\q1 
\v 60 Ìwọ ti rí ọ̀gbun ẹ̀san wọn,
\q2 gbogbo ìmọ̀ wọn sí mi.
\b
\q1 
\v 61 \nd Olúwa\nd* ìwọ ti gbọ́ ẹ̀gàn wọn
\q2 àti ìmọ̀ búburú wọn sí mi,
\q1 
\v 62 ohun tí àwọn ọ̀tá mi ń sọ
\q2 sí mi ní gbogbo ọjọ́.
\q1 
\v 63 Wò wọ́n! Ní jíjòkòó tàbí ní dídìde,
\q2 wọ́n ń ṣẹlẹ́yà mi nínú orin wọn.
\b
\q1 
\v 64 \nd Olúwa\nd* san wọ́n lẹ́san ohun tí ó tọ́ sí wọn
\q2 fún ohun tí ọwọ́ wọn ti ṣe.
\q1 
\v 65 Fi ìbòjú bò wọ́n ní ọkàn,
\q2 kí o sì fi wọ́n ré.
\q1 
\v 66 Ni wọ́n lára kí o sì pa wọ́n run pẹ̀lú ìbínú,
\q2 lábẹ́ ọ̀run \nd Olúwa\nd*.
\b
\b
\c 4
\q1 
\v 1 Báwo ni wúrà ṣe sọ ògo dídán rẹ̀ nù,
\q2 wúrà dídára di àìdán!
\q1 Òkúta ibi mímọ́ wá túká
\q2 sí oríta gbogbo òpópó.
\b
\q1 
\v 2 Báwo ni àwọn ọ̀dọ́mọkùnrin Sioni tí ó ṣe iyebíye,
\q2 tí wọ́n fi wúrà dídára ṣe
\q1 wá dàbí ìkòkò amọ̀ lásán
\q2 iṣẹ́ ọwọ́ amọ̀kòkò!
\b
\q1 
\v 3 Àwọn ajáko pèsè ọmú wọn
\q2 fún ìtọ́jú àwọn ọmọ wọn,
\q1 ṣùgbọ́n àwọn ènìyàn mi wá láì lọ́kàn
\q2 bí ògòǹgò ní aginjù.
\b
\q1 
\v 4 Nítorí òǹgbẹ, ahọ́n àwọn ọmọ ọwọ́
\q2 lẹ̀ mọ́ òkè ẹnu wọn;
\q1 àwọn ọmọdé bẹ̀bẹ̀ fún oúnjẹ,
\q2 ṣùgbọ́n kò sí ẹni tí ó fi fún wọn.
\b
\q1 
\v 5 Àwọn tí ó ń jẹ ohun dáradára
\q2 di òtòṣì ní òpópó.
\q1 Àwọn tí a fi aṣọ dáradára wọ̀
\q2 ni wọ́n sùn ní orí òkìtì eérú.
\b
\q1 
\v 6 Ìjìyà àwọn ènìyàn mi
\q2 tóbi ju ti Sodomu lọ,
\q1 tí a sí ní ipò ní òjijì
\q2 láìsí ọwọ́ láti ràn án lọ́wọ́.
\b
\q1 
\v 7 Ọmọ ọba ọkùnrin wọn mọ́ ju òjò-dídì,
\q2 wọ́n sì funfun ju wàrà lọ
\q1 wọ́n ni ìtọ́jú bí iyùn pupa,
\q2 ìrísí wọn dàbí safire.
\b
\q1 
\v 8 Ṣùgbọ́n nísinsin yìí wọ́n dúdú ju èédú;
\q2 wọn kò sì dá wọn mọ̀ ní òpópó.
\q1 Ara wọn hun mọ́ egungun;
\q2 ó sì gbẹ bí igi gbígbẹ.
\b
\q1 
\v 9 Àwọn tí ó kù nípasẹ̀ idà sàn
\q2 ju àwọn tí ìyàn pa;
\q1 tí ó wọ àkísà ebi, tí ó ń ṣòfò
\q2 fún àìní oúnjẹ láti inú pápá.
\b
\q1 
\v 10 Pẹ̀lú ọwọ́ àwọn obìnrin aláàánú
\q2 ni wọ́n ṣe ọmọ wọn jẹ
\q1 tí ó di oúnjẹ fún wọn
\q2 nígbà tí a pa àwọn ènìyàn mi run.
\b
\q1 
\v 11 \nd Olúwa\nd* ti fi ihò kíkún fún ìbínú rẹ̀;
\q2 ó sì tú ìbínú gbígbóná rẹ̀ jáde.
\q1 Ó da iná ní Sioni
\q2 tí ó jó ìpìlẹ̀ rẹ̀ run.
\b
\q1 
\v 12 Àwọn ọba ayé kò gbàgbọ́,
\q2 tàbí àwọn ènìyàn ayé,
\q1 wí pé àwọn ọ̀tá àti aninilára le wọ
\q2 odi ìlú Jerusalẹmu.
\b
\q1 
\v 13 Èyí ṣẹlẹ̀ nítorí ẹ̀ṣẹ̀ àwọn wòlíì
\q2 àti àìṣedéédéé àwọn olórí àlùfáà,
\q1 tí ó ta ẹ̀jẹ̀ àwọn olódodo
\q2 sílẹ̀ láàrín rẹ̀.
\b
\q1 
\v 14 Nísinsin yìí wọ́n ń rìn kiri ní òpópó
\q2 bí ọkùnrin tí ó fọ́jú.
\q1 Ẹ̀jẹ̀ ara wọn sọ wọ́n di àbàwọ́n
\q2 tí kò sẹ́ni tó láyà láti fọwọ́ kan aṣọ wọn.
\b
\q1 
\v 15 “Lọ kúrò! Ẹ̀yin di aláìmọ́!” ni àwọn ènìyàn ń kígbe sí wọn.
\q2 “Ẹ lọ! Ẹ lọ! Ẹ má ṣe fọwọ́ kàn wá!”
\q1 Àwọn ènìyàn láàrín orílẹ̀-èdè wí pé,
\q2 “Wọn kì yóò tẹ̀dó síbí mọ́.”
\b
\q1 
\v 16 \nd Olúwa\nd* ti tú wọn ká fúnra rẹ̀;
\q2 kò sí bojútó wọn mọ́.
\q1 Kò sí ọ̀wọ̀ fún olórí àlùfáà mọ́,
\q2 àti àánú fún àwọn àgbàgbà.
\b
\q1 
\v 17 Síwájú sí i, ojú wa kùnà
\q2 fún wíwo ìrànlọ́wọ́ asán;
\q1 láti orí ìṣọ́ wa ni à ń wò
\q2 fún orílẹ̀-èdè tí kò le gbà wá là.
\b
\q1 
\v 18 Wọ́n ń ṣọ́ wa kiri,
\q2 àwa kò sì le rìn ní òpópó wa mọ́.
\q1 Òpin wa ti súnmọ́, ọjọ́ wa sì níye
\q2 nítorí òpin wa ti dé.
\b
\q1 
\v 19 Àwọn tí ń lé wa yára
\q2 ju idì ojú ọ̀run lọ;
\q1 wọ́n lé wa ní gbogbo orí òkè
\q2 wọ́n sì gẹ̀gùn dè wá ní aginjù.
\b
\q1 
\v 20 Ẹni àmì òróró \nd Olúwa\nd*, èémí ìyè wa,
\q2 ni wọ́n fi tàkúté wọn mú.
\q1 Àwa rò pé lábẹ́ òjìji rẹ̀
\q2 ni àwa yóò máa gbé láàrín orílẹ̀-èdè gbogbo.
\b
\q1 
\v 21 Ẹ yọ̀ kí inú yín sì dùn, ẹ̀yin ọmọbìnrin Edomu,
\q2 ẹ̀yin tó ń gbé ní ilẹ̀ Usi.
\q1 Ṣùgbọ́n, a ó gbé ago náà kọjá sọ́dọ̀ rẹ pẹ̀lú;
\q2 ìwọ yóò yó bí ọ̀mùtí, ìwọ yóò sì rìn ní ìhòhò.
\b
\q1 
\v 22 Ìwọ ọmọbìnrin Sioni, ìjìyà rẹ yóò dópin;
\q2 kò ní mú ìgbèkùn rẹ pẹ́ mọ́.
\q1 Ṣùgbọ́n, ìwọ ọmọbìnrin Edomu, yóò jẹ ẹ̀ṣẹ̀ rẹ ní yà
\q2 yóò sì fi àìṣedéédéé rẹ hàn kedere.
\b
\b
\c 5
\q1 
\v 1 Rántí, \nd Olúwa\nd*, ohun tí ó ṣẹlẹ̀ sí wa;
\q2 wò ó, kí o sì rí ìtìjú wa.
\q1 
\v 2 Àwọn ohun ìní wa ti di ti àlejò,
\q2 ilé wa ti di ti àjèjì.
\q1 
\v 3 Àwa ti di aláìní òbí àti aláìní baba,
\q2 àwọn ìyá wa ti di opó.
\q1 
\v 4 A gbọdọ̀ ra omi tí à ń mu;
\q2 igi wa di títà fún wa.
\q1 
\v 5 Àwọn tí ó ń lé wa súnmọ́ wa;
\q2 àárẹ̀ mú wa àwa kò sì rí ìsinmi.
\q1 
\v 6 Àwa jọ̀wọ́ ara wa fún Ejibiti àti Asiria
\q2 láti rí oúnjẹ tó tó jẹ.
\q1 
\v 7 Àwọn baba wa ti ṣẹ̀, wọn kò sì ṣí mọ́,
\q2 àwa sì ń ru ìjìyà ẹ̀ṣẹ̀ wọn.
\q1 
\v 8 Àwọn ẹrú ń jẹ ọba lórí wa,
\q2 kò sì ṣí ẹni tí yóò gbà wá lọ́wọ́ wọn.
\q1 
\v 9 Àwa ń rí oúnjẹ wa nínú ewu ẹ̀mí wa
\q2 nítorí idà tí ó wà ní aginjù.
\q1 
\v 10 Ẹran-ara wa gbóná bí ààrò,
\q2 ebi sì yó wa bí àárẹ̀.
\q1 
\v 11 Wọ́n ti fipá bá àwọn obìnrin wa lòpọ̀ ní Sioni,
\q2 àti àwọn wúńdíá ti o wa ní ìlú Juda.
\q1 
\v 12 Àwọn ọmọ ọbakùnrin ti di síso sókè ní ọwọ́ wọn;
\q2 kò sí ìbọ̀wọ̀ fún àgbàgbà mọ́.
\q1 
\v 13 Àwọn ọ̀dọ́mọkùnrin wa ru òkúta;
\q2 àwọn ọmọkùnrin sì ń ṣàárẹ̀ lábẹ́ ẹrù igi.
\q1 
\v 14 Àwọn àgbàgbà ti lọ kúrò ní ẹnu-bodè ìlú;
\q2 àwọn ọ̀dọ́mọkùnrin sì dákẹ́ orin wọn.
\q1 
\v 15 Ayọ̀ ti ṣáko ní ọkàn wa;
\q2 ọ̀fọ̀ sì ti dúró bí ijó fún wa.
\q1 
\v 16 Adé ti ṣí kúrò ní orí wa
\q2 ègbé ni fún wa, nítorí a ti ṣẹ̀.
\q1 
\v 17 Nítorí èyí, àárẹ̀ mú ọkàn wa,
\q2 nítorí èyí, ojú wa sì ṣú.
\q1 
\v 18 Fún òkè Sioni tí ó ti di ahoro
\q2 lórí rẹ̀ àwọn kọ̀lọ̀kọ̀lọ̀ sì ń rìn kiri.
\b
\q1 
\v 19 Ìwọ, \nd Olúwa\nd*, jẹ ọba títí láé;
\q2 ìjọba rẹ dúró láti ìran kan dé ìran mìíràn.
\q1 
\v 20 Kí ló dé tí o ń gbàgbé wa ní gbogbo ìgbà?
\q2 Kí ló dé tí o fi kọ̀ wá sílẹ̀ fún ọjọ́ pípẹ́?
\q1 
\v 21 Mú wa padà sí ọ̀dọ̀ rẹ, \nd Olúwa\nd*, kí àwa kí ó le padà;
\q2 mú ọjọ́ wa di tuntun bí ìgbàanì,
\q1 
\v 22 àyàfi tí o bá ti kọ̀ wá sílẹ̀ pátápátá
