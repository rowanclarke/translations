\id ECC - Biblica® Open Shona Contemporary Bible 2017
\h Muparidzi
\toc1 Muparidzi
\toc2 Muparidzi
\toc3 Mupa
\mt1 MUPARIDZI
\c 1
\s1 Zvose hazvina maturo
\p 
\v 1 Mashoko oMuparidzi, mwanakomana waDhavhidhi, mambo muJerusarema:
\q1 
\v 2 Zvanzi noMuparidzi,
\q2 “Hazvina maturo! Hazvina maturo!
\q1 Hazvina maturo chose!
\q2 Zvose hazvina maturo.”
\b
\q1 
\v 3 Munhu achawaneiko kubva pakushanda kwake kwose
\q2 kwaanoita nesimba pasi pezuva?
\q1 
\v 4 Zvizvarwa zvinouya uye zvizvarwa zvinoenda,
\q2 asi nyika inogara nokusingaperi.
\q1 
\v 5 Zuva rinobuda uye zuva rinovira,
\q2 uye rinokurumidza kudzokerazve kwarinobudira.
\q1 
\v 6 Mhepo inovhuvhuta ichienda zasi,
\q2 yozodzokera kumusoro;
\q1 inotenderera nokutenderera
\q2 ichingodzokerazve pagwara rayo.
\q1 
\v 7 Nzizi dzose dzinodira mugungwa,
\q2 kunyange zvakadaro gungwa harizari.
\q1 Kunzvimbo kwadzinobva nzizi,
\q2 ikoko ndiko kwadzinodzokerazve.
\q1 
\v 8 Zvinhu zvose zvinonetesa,
\q2 zvisina ani angazvitaura.
\q1 Ziso hariguti kuona,
\q2 uye nzeve haizari nokunzwa.
\q1 
\v 9 Chakanga chiripo, chichazovapozve,
\q2 chakamboitwa chichaitwazve;
\q2 hapana chitsva pasi pezuva.
\q1 
\v 10 Chiripo here chinhu chinganzi nomunhu,
\q2 “Tarira! Chinhu ichi chitsva?”
\q1 Chakanga chichingovapo, kare kare;
\q2 chakanga chiripo isu tisati tavapo.
\q1 
\v 11 Vanhu vakare havacharangarirwi;
\q2 uye kunyange vanovatevera,
\q1 havachazorangarirwi
\q2 nevanozotevera.
\s1 Uchenjeri hahuna maturo
\p 
\v 12 Ini muparidzi ndakanga ndiri mambo weIsraeri muJerusarema.
\v 13 Ndakazvipira kunzvera nokutsvaka nouchenjeri zvose zvinoitwa pasi pedenga. Ibasa rinotambudza rakapiwa vanakomana vavanhu naMwari kuti vazvitambudze naro.
\v 14 Ndakaona zvinhu zvose zvinoitwa pasi pezuva; zvose hazvo hazvina maturo, kudzingana nemhepo bedzi.
\q1 
\v 15 Chakakombamiswa hachingatwasanudzwi;
\q2 chinoshayikwa hachingaverengwi.
\p 
\v 16 Ndakafunga mumwoyo mangu ndikati, “Tarira, ndazviwanira uchenjeri hwakawanda kupfuura vose vakanditangira kutonga muJerusarema; ndava nouchenjeri uye noruzivo rwakawanda.”
\v 17 Ipapo ndakazvipira kutsvaka kunzwisisa uchenjeri uyezve noupengo noupenzi, asi ndakadzidzawo zvakare kuti, naizvozviwo kudzingana nemhepo.
\q1 
\v 18 Nokuti muuchenjeri huzhinji mune kusuwa kuzhinji;
\q2 kuwanda kwezivo, kuwandawo kwokuchema.
\c 2
\s1 Kufara kuzhinji hakuna maturo
\p 
\v 1 Ndakati mumwoyo mangu, “Uya zvino, ndichakuedza nomufaro kuti uzive chakanaka.” Asi naizvozviwo hazvina maturo.
\v 2 Ndakati, “Kuseka upenzi, uyezve mafaro anobatsireiko?”
\v 3 Ndakaedza kuzvifadza newaini, uye kumbundikira upenzi, pfungwa dzangu dzichinditungamirira nouchenjeri. Ndaida kuona kuti chii chakafanira kuti vanhu vaite pasi pedenga mumazuva mashoma oupenyu hwavo.
\p 
\v 4 Ndakaita mabasa makuru; ndakazvivakira dzimba ndikazvirimira minda yemizambiringa.
\v 5 Ndakazvigadzirira mapindu, neminda yemiti uye ndikasimamo miti yemichero yendudzi dzose.
\v 6 Ndakavaka madhamu kuti ndidiridzire sango remiti yaikura.
\v 7 Ndakatenga varandarume navarandakadzi, uye ndaiva navamwe varanda vakaberekerwa mumba mangu. Ndaivawo nepfuma zhinji yemombe namakwai, kupfuura ani zvake akanditangira kuvapo paJerusarema.
\v 8 Ndakazviunganidzira sirivha negoridhe, uye nepfuma yamadzimambo uye neyamatunhu. Ndakatsvaka vaimbi, varume navakadzi, uye nezviridzwa, nezvinofadza vanakomana vavanhu, navarongowo vazhinji.
\v 9 Saka ndakava mukuru kwazvo kupfuura ani zvake akanditangira paJerusarema. Mune izvi zvose uchenjeri hwangu hwakaramba huneni.
\q1 
\v 10 Handina kuzvirambidza zvinhu zvaidiwa nameso angu,
\q2 handina kurambidza mwoyo wangu mufaro.
\q1 Mwoyo wangu wakafadzwa nebasa rangu rose,
\q2 uye uyu ndiwo wakava mubayiro wokushanda kwangu kwose.
\q1 
\v 11 Asi pandakaongorora mabasa ose akanga aitwa namaoko angu
\q2 uye zvandakatambudzikira kuti ndiwane,
\q1 zvose zvakanga zvisina maturo, kwaingova kudzingana nemhepo;
\q2 hapana chaibatsira pasi pezuva.
\s1 Uchenjeri noUpenzi hazvina maturo
\q1 
\v 12 Naizvozvo ndakapindura pfungwa dzangu kuti ndicherechedze uchenjeri,
\q2 urema uye noupenzi.
\q1 Chii chimwe chingaitwa nomunhu
\q2 anotevera mumwe paumambo kunze kwezvakatoitwa kare?
\q1 
\v 13 Ndakaona kuti uchenjeri huri nani pano upenzi,
\q2 sezvo chiedza chiri nani pane rima.
\q1 
\v 14 Meso omunhu akachenjera ari mumusoro make,
\q2 nokuno rumwe rutivi benzi richifamba murima;
\q1 asi ndakasvika pakuziva kuti
\q2 vose vanowirwa nedambudziko rimwe chete.
\p 
\v 15 Ipapo ndakafunga mumwoyo mangu ndikati,
\q1 “Magumo ebenzi achandiwanawo neni.
\q2 Chii zvino chandinowana pakuva munhu akachenjera?”
\q1 Ndakati mumwoyo mangu,
\q2 “Izviwo hazvina maturo.”
\q1 
\v 16 Nokuti munhu akachenjera akafanana nebenzi pakusarangarirwa;
\q2 mumazuva anouya vose vachazokanganwikwa.
\q1 Kufanana nebenzi, akachenjera anofanira kufawo!
\s1 Kushanda hakuna maturo
\p 
\v 17 Saka ndakavenga upenyu, nokuti basa rinoitwa pasi pezuva rakandirwadza kwazvo. Zvose hazvo hazvina maturo, kudzingana nemhepo.
\v 18 Ndakavenga zvinhu zvose zvandakashingairira pasi pezuva, nokuti ndinofanira kuzvisiyira anonditevera.
\v 19 Uye ndiani angaziva kana achizova akachenjera kana benzi? Kunyange zvakadaro achava nesimba pamusoro pebasa rose randakatamburira nesimba nounyanzvi hwangu pasi pezuva. Izviwo hazvina maturo.
\v 20 Saka mwoyo wangu wakatanga kushungurudzika pamusoro pokutambudzika nokushanda kwangu pasi pezuva.
\v 21 Nokuti munhu angaite basa rake nouchenjeri, noruzivo uye nounyanzvi, zvino ipapo ozofanira kusiya zvose zvaanazvo kuno mumwe asina kuzvishandira. Naizvozviwo hazvina maturo uye chinhu chakaipa kwazvo.
\v 22 Munhu anowanei pakushanda kwose nokushingaira kwomwoyo nokuda kwokushanda kwake pasi pezuva?
\v 23 Mazuva ake ose basa rake kurwadziwa nokusuwa; kunyange nousiku pfungwa dzake hadzizorori. Naizvozviwo hazvina maturo.
\p 
\v 24 Munhu haana chaangaita chinopfuura kudya nokunwa kuti awane kugutswa pakushanda kwake. Naizvozviwo, ndinoona kuti zvinobva muruoko rwaMwari,
\v 25 nokuti kana pasina iye, ndiani angadya kana kuwana mufaro?
\v 26 Kuno munhu anomufadza, Mwari anopa uchenjeri, nezivo nomufaro asi kuno mutadzi, anopa basa rokuunganidza nokuchengetera upfumi kuti agozvipa uyo anofadza Mwari. Naizvozviwo hazvina maturo, kudzingana nemhepo.
\c 3
\s1 Chimwe nechimwe chine nguva yacho
\q1 
\v 1 Chinhu chimwe nechimwe chine nguva yacho,
\q2 uye basa rimwe nerimwe rine nguva yaro pasi pedenga:
\b
\q2 
\v 2 nguva yokuberekwa nenguva yokufa,
\q2 nguva yokusima nenguva yokudzura;
\q2 
\v 3 nguva yokuuraya nenguva yokuporesa,
\q2 nguva yokuputsa nenguva yokuvaka;
\q2 
\v 4 nguva yokuchema nenguva yokuseka,
\q2 nguva yokuungudza nenguva yokudzana;
\q2 
\v 5 nguva yokurasa mabwe nenguva yokuaunganidza pamwe chete,
\q2 nguva yokumbundikira nenguva yokurega;
\q2 
\v 6 nguva yokutsvaka nenguva yokurega zvirasike,
\q2 nguva yokuchengeta nenguva yokurasa;
\q2 
\v 7 nguva yokubvarura nenguva yokusona,
\q2 nguva yokunyarara nenguva yokutaura;
\q2 
\v 8 nguva yokuda nenguva yokuvenga,
\q2 nguva yehondo nenguva yorugare.
\p 
\v 9 Ko, mushandi anowanei kubva mukushanda kwake kwose?
\v 10 Ndakaona mutoro wakapiwa vanhu naMwari.
\v 11 Akaita chinhu chimwe nechimwe chakanaka nenguva yacho. Akaisawo zvisingaperi mumwoyo yavanhu; kunyange zvakadaro havangagoni kunzwisisa zvakaitwa naMwari kubva pakutanga kusvika pakupedzisira.
\v 12 Ndinoziva kuti hakuna chinhu chakanakira munhu kupfuura kuti afare uye kuti aite zvakanaka achiri mupenyu.
\v 13 Kuti munhu wose adye uye anwe uye azviwanire kugutsikana kubva pakushanda kwake kwose, ichi ndicho chipo chaMwari.
\v 14 Ndinoziva kuti zvose zvinoitwa naMwari zvichagara nokusingaperi; hapana chingawedzerwa pazviri uye hapana chingabviswa pazviri. Mwari anozviita kuti vanhu vamukudze.
\q1 
\v 15 Chipi nechipi chiripo zvino, chakagara chiripo kare,
\q2 uye zvichazovapo zvakatovapo kare;
\q2 uye Mwari anotsvakazve zvakapfuura.
\p 
\v 16 Uyezve ndakaona chimwe chinhu pasi pezuva:
\q1 Panzvimbo yokururamisira, zvakaipa zvakanga zviripo,
\q2 panzvimbo yokururama, zvakaipa zvakanga zviripo.
\p 
\v 17 Ndakafunga mumwoyo mangu ndikati,
\q2 “Mwari achatonga vose
\q1 vakarurama nevakaipa,
\q2 nokuti pachava nenguva yebasa rimwe nerimwe.”
\p 
\v 18 Ndakatizve, “Kana vari vanhu, Mwari anovaedza kuti vaone kuti vakangofanana nemhuka.
\v 19 Zvinoitika kumunhu zvakafanana nezvinoitika kumhuka; zvose zvinoitirwa zvimwe chetezvo: sokufa kunoita chimwe, chimwe chinofawo. Zvose zvinofema mweya mumwe; munhu hapana paanopfuura mhuka. Zvose hazvina maturo.
\v 20 Zvose zvinoenda kunzvimbo imwe chete; zvose zvinobva kuvhu, uye kuvhu zvose zvinodzokera.
\v 21 Ndiani angaziva kana mweya womunhu uchikwira kuenda kumusoro uye kana mweya wemhuka uchidzika pasi?”
\p 
\v 22 Saka ndakaona kuti hapana chingapfuure ichi, kuti munhu afadzwe nebasa rake, nokuti uyu ndiwo mugove wake. Nokuti ndiani achazomudzosazve kuti aone zvichazoitika shure kwake?
\c 4
\s1 Udzvinyiriri, Kushanda, noKusava Neshamwari
\p 
\v 1 Ndakatarirazve ndikaona udzvinyiriri hwose hwaiitika pasi pezuva:
\q1 Ndakaona misodzi yavanodzvinyirirwa,
\q2 uye havana munyaradzi;
\q1 simba raiva kudivi ravadzvinyiriri vavo,
\q2 uye havana munyaradzi.
\q1 
\v 2 Ndakati vakafa,
\q2 vakanguri vafa kare,
\q1 vano mufaro kupfuura vapenyu,
\q2 vachiri kurarama.
\q1 
\v 3 Asi ari nani kupfuura
\q2 vose ndiye uyo asati atombovapo,
\q1 uyo asati amboona zvakaipa
\q2 zvinoitwa pasi pezuva.
\p 
\v 4 Uye ndakaona kuti kushanda kwose nokuwana kwose kwomunhu kunobva pakuchiva muvakidzani wake. Izviwo hazvina maturo, kudzinganisana nemhepo.
\q1 
\v 5 Benzi rinopeta maoko aro,
\q2 rozviparadza.
\q1 
\v 6 Tsama imwe yorugare
\q2 inopfuura tsama mbiri dzokutambudzika
\q2 nokudzingana nemhepo.
\p 
\v 7 Zvino ndakaona chinhu chisina maturo pasi pezuva.
\q1 
\v 8 Kwaiva nomunhu aigara ari oga;
\q2 akanga asina mwanakomana, kana mununʼuna.
\q1 Kushanda kwake kwakanga kusina magumo,
\q2 kunyange zvakadaro meso ake haana kugutswa nepfuma yake.
\q1 Akabvunza akati, “Ndinotambudzikira aniko,
\q2 uye sei ndichizvinyima mafaro?”
\q1 Naizvozviwo hazvina maturo,
\q2 basa rokutambura!
\b
\q1 
\v 9 Vaviri vari nani pano mumwe chete,
\q2 nokuti vano mugove wakanaka pakushanda kwavo:
\q1 
\v 10 Kana mumwe akawira pasi,
\q2 shamwari yake inogona kumubatsira kuti amire zvakare.
\q1 Asi ane nhamo munhu anowira pasi,
\q2 asina anomusimudza!
\q1 
\v 11 Uyezve kana vaviri vachivata pamwe chete, vachadziyirwa.
\q2 Asi mumwe chete angadziyirwa sei?
\q1 
\v 12 Munhu mumwe chete angakurirwa simba,
\q2 asi vaviri vanozvidzivirira.
\q1 Rwodzi rwakakoswa mutatu harungakurumidzi kudamburwa.
\s1 Kuenda mberi hakuna maturo
\p 
\v 13 Jaya murombo asi rakachenjera riri nani kupfuura mambo mutana ari benzi, asisazivi kuteerera kana achipiwa yambiro.
\v 14 Jaya ringava rakabva mutorongo rikazova mambo, kana angava akaberekwa ari muurombo, muushe hwokwake.
\v 15 Ndakaona kuti vose vapenyu vakafamba pasi pezuva vakatevera jaya, rakazotevera panzvimbo yamambo.
\v 16 Vakanga vasingaverengeki vanhu vose vaaitonga. Asi vakazouya pashure havana kufadzwa neakanga achitonga panzvimbo yamambo. Naizvozviwo hazvina maturo, kudzinganisana nemhepo.
\c 5
\s1 Mira utye Mwari
\p 
\v 1 Chenjerera rutsoka rwako kana uchienda kuimba yaMwari. Enda pedyo undonzwa pano kuti upe chibayiro chamapenzi, vasingazivi kuti vanoita zvakaipa.
\q1 
\v 2 Usakurumidza nomuromo wako,
\q2 usakurumidza mumwoyo mako
\q2 kutaura chipi zvacho chinhu pamberi paMwari.
\q1 Mwari ari kudenga
\q2 uye iwe uri pasi,
\q2 saka mashoko ako ngaave mashoma.
\q1 
\v 3 Sokuuya kwechiroto kana pane matambudziko akawanda
\q2 ndizvowo zvinoita kutaura kwebenzi kana pane mashoko mazhinji.
\p 
\v 4 Kana waita mhiko kuna Mwari, usanonoka kuizadzisa. Iye haafariri mapenzi; zadzisa mhiko yako.
\v 5 Zviri nani kurega kupika pano kuita mhiko wozorega kuizadzisa.
\v 6 Usaregera muromo wako uchikutungamirira mukutadza. Uye usapikisa mutumwa wetemberi uchiti, “Ndakakanganisa pakupika.” Mwari achatsamwireiko pamusoro pezvaunotaura, uye agoparadza basa ramaoko ako?
\v 7 Kurota kuzhinji namashoko mazhinji hazvina maturo. Naizvozvo mira utye Mwari.
\s1 Upfumi hahuna maturo
\p 
\v 8 Kana ukaona murombo achidzvinyirirwa mudunhu uye achinyimwa kururamisirwa nekodzero, usashamiswa nezvinhu zvakadai; nokuti mumwe mukuru anotarirwa nomumwe ari pamusoro pake, uye pamusoro pavo vose pane vamwe vakavakurirawo.
\v 9 Zvinowanikwa kubva panyika zvinotorwa navose; iye mambo ane zvaanowana kubva kuminda.
\q1 
\v 10 Uyo zvake anoda mari haazombowani mari yakakwana;
\q2 ani zvake anoda pfuma haazombogutswi nezvaanowana.
\q2 Naizvozviwo hazvina maturo.
\b
\q1 
\v 11 Nokuwanda kunoita pfuma,
\q2 ndiko kuwanda kunoitawo vanoidya.
\q1 Uye zvinobatsireiko kumuridzi wayo
\q2 kunze kwokungogutsa meso ake nayo?
\b
\q1 
\v 12 Hope dzomushandi dzakanaka,
\q2 hazvinei kuti adya zvishoma kana zvizhinji,
\q1 asi kuwanda kwezvinhu
\q2 zvomupfumi hakumuwanisi hope.
\p 
\v 13 Ndakaona chinhu chakaipisisa pasi pezuva:
\q1 pfuma inounganidzwa nomwene wayo, ichimuonesa nhamo,
\q2 
\v 14 kana pfuma inorasika nokuda kwechinhu chakaipa chinomuwira,
\q1 kuti kana abereka mwana mukomana
\q2 anoshaya chaanomusiyira.
\q1 
\v 15 Munhu sezvaanobuda mudumbu ramai vake,
\q2 uye sokuuya kwake, saizvozvowo anoenda.
\q1 Haana chaanotakura chinobva pabasa rake,
\q2 chaangaenda nacho muruoko rwake.
\p 
\v 16 Ichi zvakare chinhu chakaipa kwazvo:
\q1 Sokuuya kunoita munhu saizvozvowo anoenda,
\q2 uye chii chaangawana,
\q2 iye achishandira mhepo?
\q1 
\v 17 Pamazuva ake ose anodyira murima,
\q2 nokudzungaira kukuru, kutambudzika uye nehasha.
\p 
\v 18 Ipapo ndakaziva kuti zvakanaka uye zvakafanira kuti munhu adye uye anwe, uye kuti azviwanire kugutsikana mukushanda kwake kwaakabata pasi pezuva pamazuva ake mashoma oupenyu aakapiwa naMwari, nokuti uyu ndiwo mugove wake.
\v 19 Pamusoro pezvo, Mwari paanopa munhu upi zvake mari nezvinhu, uye achiita kuti akwanise kuti afadzwe nazvo kuti agamuchire mugove wake uye kuti afadzwe nebasa rake, ichi chipo chinobva kuna Mwari.
\v 20 Haawanzofunga pamusoro poupenyu hwake, nokuti Mwari anopindura zvinofadza mwoyo wake.
\c 6
\p 
\v 1 Ndakaona chimwe chinhu chakaipa pasi pezuva, uye chinoremedza vanhu zvikuru:
\v 2 Mwari anopa munhu mari nezvinhu zvakawanda uye nokukudzwa, zvokuti haana chaangashayiwa pazvinhu zvinodiwa nomwoyo wake, asi Mwari haazomutenderi kuti afadzwe nazvo, uye mutorwa ndiye anozofadzwa nazvo panzvimbo yake. Izvi hazvina maturo, chinhu chakaipa chinorwadza.
\p 
\v 3 Munhu angava navana zana agorarama makore akawanda, asi hazvinei kuti ararama nguva yakareba sei, kana akasafara nezvaanowana uyezve akasavigwa zvakanaka, ndinoti mwana aberekwa ari gavamwedzi ari nani pana iye.
\v 4 Anouya asina zvaanoreva anoendazve murima, uye murima zita rake rinofukidzirwa.
\v 5 Kunyange asina kumboona zuva kana kuziva chinhu, ane zororo rinopfuura munhu iyeyu,
\v 6 kunyange akararama makore anokwana zviuru zviviri, asi akatadza kufadzwa nezvaanowana. Ko, vose havaendi kunzvimbo imwe chete here?
\q1 
\v 7 Kushingaira kwose kwomunhu kunoitirwa muromo wake,
\q2 kunyange zvakadaro kuda kwake zvokudya hakugutswi.
\q1 
\v 8 Ko, akachenjera anokurira
\q2 benzi pachii?
\q1 Ko, murombo anowanei nokuziva
\q2 kuzvibata pamberi pavamwe?
\q1 
\v 9 Zviri nani zvinoonekwa nameso
\q2 pane kutsvaka-tsvaka kwomwoyo.
\q1 Izviwo hazvina maturo,
\q2 kudzinganisana nemhepo.
\b
\q1 
\v 10 Chinhu chipi nechipi chiripo chakapiwa zita kare,
\q2 uye munhu zvaari zvakazivikanwa kare;
\q1 hakuna munhu anorwisana
\q2 nomunhu anomupfuura pasimba.
\q1 
\v 11 Kuwanda kwamashoko
\q2 ndikowo kuwanda kwezvisina maturo,
\q2 uye zvingabatsira aniko zvakadai?
\p 
\v 12 Zvino ndiani angaziva zvakanakira munhu muupenyu, pamazuva mashoma uye asina maturo anopfuura somumvuri? Nokuti ndiani angaudza munhu zvinozomutevera mushure mokunge iye aenda?
\c 7
\s1 Uchenjeri
\q1 
\v 1 Zita rakanaka rinopfuura mafuta anonhuhwira zvakanaka kwazvo,
\q2 uye zuva rokufa rinopfuura zuva rokuzvarwa.
\q1 
\v 2 Zviri nani kuenda kuimba yokuchema
\q2 pano kuenda kuimba yamabiko,
\q1 nokuti rufu ndiwo mugumo womunhu wose;
\q2 vapenyu ngavazviise izvi pamwoyo.
\q1 
\v 3 Kusuwa kunopfuura kuseka,
\q2 nokuti chiso chinopunyaira chakanakira mwoyo.
\q1 
\v 4 Mwoyo womuchenjeri uri mumba yokuchema,
\q2 asi mwoyo yamapenzi iri kuimba yamafaro.
\q1 
\v 5 Zviri nani kuteerera kutsiura kwomunhu akachenjera,
\q2 pano kuteerera rwiyo rwamapenzi.
\q1 
\v 6 Sokuputika kweminzwa pasi pehari,
\q2 ndizvo zvakaita kuseka kwamapenzi.
\q2 Naizvozviwo hazvina maturo.
\q1 
\v 7 Udzvinyiriri hunoshandura muchenjeri achiva benzi,
\q2 uye fufuro inosvibisa mwoyo.
\b
\q1 
\v 8 Magumo echinhu anopfuura mavambo acho,
\q2 uye mwoyo murefu unopfuura kuzvikudza.
\q1 
\v 9 Usakurumidza kutsamwa pamweya wako
\q2 nokuti kutsamwa kunogara muchipfuva chamapenzi.
\b
\q1 
\v 10 Usati, “Sei mazuva akare ari nani kupfuura azvino?”
\q2 Nokuti hazvina kuchenjera kubvunza mibvunzo yakadaro.
\b
\q1 
\v 11 Uchenjeri chinhu chakanaka senhaka,
\q2 uye hunobatsira avo vanoona zuva.
\q1 
\v 12 Uchenjeri hunodzivirira sokudzivirira kunoita mari,
\q2 asi kunakisa kworuzivo ndokuku:
\q1 kuti uchenjeri hunochengetedza
\q2 upenyu hwomunhu anahwo.
\p 
\v 13 Cherechedza zvakaitwa naMwari:
\q1 Ndiani angatwasanudza
\q2 zvaakagonyanisa?
\q1 
\v 14 Kana zvinhu zvakanaka, fara;
\q2 asi kana nguva dzakaipa, rangarira kuti:
\q1 Mwari ndiye akaita izvozvo
\q2 zvose zviri zviviri.
\q1 Naizvozvo, munhu haagoni kuziva chinhu
\q2 pamusoro peramangwana rake.
\p 
\v 15 Muupenyu hwangu husina maturo ndakaona zvose izvi:
\q1 akarurama achiparara mukururama kwake,
\q2 nowakaipa achirarama nguva refu mukuipa kwake.
\q1 
\v 16 Usava munhu akanyanyisa kururama,
\q2 kana munhu akanyanyisa kuchenjera,
\q2 uchazviparadzireiko?
\q1 
\v 17 Usava munhu akanyanyisa kuipa,
\q2 uye usava benzi.
\q2 Ungada kufa nguva yako isati yakwana?
\q1 
\v 18 Zvakanaka kubatisisa chimwe chinhu,
\q2 uye usingaregedzi chimwe chacho chichienda.
\q2 Munhu anotya Mwari acharega kuita zvinopfurikidza mwero.
\b
\q1 
\v 19 Uchenjeri hunoita kuti mumwe munhu akachenjera
\q2 ave nesimba guru kupfuura vatariri gumi vari muguta.
\b
\q1 
\v 20 Hapana munhu akarurama panyika,
\q2 anoita zvakanaka uye asingatadzi.
\b
\q1 
\v 21 Usava nehanya namashoko ose anotaurwa navanhu,
\q2 zvichida ungangonzwa muranda wako achikutuka,
\q1 
\v 22 nokuti unoziva mumwoyo mako
\q2 kuti nguva zhinji iwe pachako wakambotuka vamwe.
\p 
\v 23 Zvose izvi ndakazviedza nouchenjeri ndikati,
\q1 “Ndakazvipira kuva munhu akachenjera,”
\q2 asi izvi zvaiva kure neni.
\q1 
\v 24 Chii zvacho chingava uchenjeri,
\q2 chiri kure kwazvo uye chakadzama,
\q2 ndiani angachiwana?
\q1 
\v 25 Saka ndakashandura pfungwa dzangu ndikatanga kutsvaka kunzwisisa,
\q2 kuti ndiongorore uye nditsvakisise uchenjeri nourongwa hwezvinhu,
\q1 uye kuti ndinzwisise upenzi hwokuipa
\q2 nomupengo hwoupenzi.
\b
\q1 
\v 26 Ndakawana chinhu chinovava kupfuura rufu,
\q2 mukadzi anova musungo,
\q1 mwoyo wake uri hunza
\q2 uye maoko ake ari ngetani.
\q1 Munhu anofadza Mwari achapunyuka kwaari,
\q2 asi mutadzi achabatwa naye.
\p 
\v 27 Muparidzi anoti, “Tarira, izvi ndizvo zvandakawana:
\q1 “Ndichisanganisa chimwe nechimwe kuti ndiwane marongerwo ezvinhu,
\q2 
\v 28 pandakanga ndichiri kutsvaka
\q2 asi ndisina chandinowana,
\q1 ndakawana murume mumwe chete akarurama pakati pechiuru,
\q2 asi handina kuwana mukadzi mumwe chete akarurama pakati pavo vose.
\q1 
\v 29 Chinhu ichi chete ndicho chandakawana chokuti:
\q2 Mwari akaita vanhu vakarurama,
\q2 asi vanhu vakaenda kundotsvaka mano mazhinji.”
\c 8
\q1 
\v 1 Ndiani akafanana nomunhu akachenjera?
\q2 Ndiani anoziva tsananguro yezvinhu?
\q1 Uchenjeri hunobwinyisa chiso chomunhu
\q2 uye hunoshandura kuomarara kwechiso.
\s1 Teerera Mambo
\p 
\v 2 Ndinoti, teerera murayiro wamambo, nokuti wakaita mhiko pamberi paMwari.
\v 3 Usakurumidza kubva pamberi pamambo. Usamiririra zvinhu zvakaipa, nokuti iye achaita chinhu chipi zvacho chinomufadza.
\v 4 Sezvo shoko ramambo riri pamusoro pamashoko ose, ndiani angati kwaari, “Munoiteiko?”
\q1 
\v 5 Ani naani zvake achateerera murayiro wake haangawani chinomukuvadza,
\q2 uye mwoyo wakachenjera uchaziva nguva yakafanira namaitiro akafanira.
\q1 
\v 6 Nokuti kune nguva yakafanira namaitiro akafanira pazvinhu zvose,
\q2 kunyange nhamo yomunhu ichimuremera zvikuru.
\b
\q1 
\v 7 Sezvo pasina munhu anoziva ramangwana,
\q2 ndiani angamuzivisa zvichauya?
\q1 
\v 8 Hakuna munhu ane simba pamusoro pemhepo kuti aitonge;
\q2 saizvozvowo hakuna munhu ane simba pamusoro pezuva rokufa kwake.
\q1 Sezvo kusinawo munhu anoregedzeswa kurwa panguva yehondo,
\q2 saizvozvowo zvakaipa hazvingaregedzi uyo anozviita.
\p 
\v 9 Zvose izvi ndakazviona, pandakaisa pfungwa dzangu pane zvose zvinoitwa pasi pezuva. Pane nguva yokuti mumwe munhu anenge ane simba pamusoro pavamwe, asi achizvikuvadza pachake.
\v 10 Zvino ndakaonazve vakaipa vachivigwa mumakuva, vose vaisiuya nokuenda kubva kunzvimbo tsvene uye vachirumbidzwa muguta mavaiitira izvi. Naizvozviwo hazvina maturo.
\p 
\v 11 Kana mhosva ikarega kukurumidza kutongwa, mwoyo yavanhu ichazara nezvirongwa zvokuita zvakaipa.
\v 12 Kunyange munhu akaipa akapara mhosva dzinosvika zana agorarama nguva refu, ndinoziva kuti zvichava nani kuna vanhu vanotya Mwari, avo vanokudza Mwari.
\v 13 Asi nokuti vakaipa havatyi Mwari, hazvizovanakira, uye mazuva avo haangarebi somumvuri.
\p 
\v 14 Pane chimwezve chinhu chisina maturo chinoitika panyika: Vanhu vakarurama vanoitirwa zvakafanira kuitirwa vakaipa, uye vanhu vakaipa vanowana zvakafanira kuwanikwa navakarurama. Naizvozviwo ndinoti hazvina maturo.
\v 15 Saka ndinokurudzira vanhu kuti vafadzwe noupenyu, nokuti hapana chinhu chiri nani kumunhu pasi pezuva kupfuura kudya nokunwa nokufara. Ipapo mufaro uchamutevera mubasa rake mazuva ose oupenyu hwaakapiwa naMwari pasi pezuva.
\p 
\v 16 Pandakaisa pfungwa dzangu kuti ndizive uchenjeri nokuongorora mabasa omunhu panyika, maziso ake asingawani hope usiku namasikati,
\v 17 ipapo ndakaona zvose zvakaitwa naMwari. Hapana munhu angazvinzwisisa zvinoitika pasi pezuva. Hazvinei kuti munhu anoedza sei kuzvitsvaka, munhu haangagoni kuziva zvazvinoreva. Kunyange munhu akachenjera akati anozviziva haangakwanisi kunyatsozvinzwisisa.
\c 9
\s1 Mugumo waVanhu Vose
\p 
\v 1 Nokudaro ndakafunga pamusoro pezvose izvi uye ndikapedzisira nokuti vakarurama navakachenjera, nezvavanoita zviri mumaoko aMwari, asi hakuna munhu anoziva kuti rudo here kana ruvengo zvakamumirira.
\v 2 Vose vane mugumo wakafanana, akarurama neakaipa, akanaka nomutadzi, akachena neakasviba, avo vanobayira zvibayiro neavo vasingabayiri.
\q1 Sezvazvakaita nomunhu akanaka,
\q2 ndizvozvowo nomutadzi;
\q1 sezvazvakaita neavo vanoita mhiko,
\q2 ndizvozvowo neavo vanotya kuita mhiko.
\p 
\v 3 Ichi ndicho chinhu chakaipa pane zvose zvinoitika pasi pezuva: Vose vane mugumo mumwe chete. Pamusoro pezvo, mwoyo yavanhu izere nezvakaipa uye mumwoyo yavo mune upenzi panguva yokurarama kwavo, uye shure kwaizvozvo vanobatana navakafa.
\v 4 Ani naani ari pakati pavapenyu ane tariro; kunyange imbwa mhenyu iri nani kupfuura shumba yakafa!
\q1 
\v 5 Nokuti vapenyu vanoziva kuti vachafa,
\q2 asi vakafa havana chavanoziva;
\q1 havachinazve mumwe mubayiro,
\q2 uye nokurangarirwa kwavo kwakanganikwa.
\q1 
\v 6 Rudo rwavo, ruvengo rwavo
\q2 negodo zvakanguri zvapera kare;
\q1 havachazovizve nechikamu,
\q2 pane zvose zvinoitika pasi pezuva.
\p 
\v 7 Enda, undodya zvokudya zvako nomufaro, unwe waini nomwoyo wakafara, nokuti iye zvino Mwari ndipo paari kufadzwa namabasa ako.
\v 8 Nguva dzose upfeke nguo chena, uye ugare wakazodza musoro wako namafuta.
\v 9 Fadzwa noupenyu hwako nomukadzi wako waunoda, mazuva ose oupenyu huno husina maturo Mwari hwaakakupa pasi pezuva, mazuva ose asina maturo. Nokuti uyu ndiwo mugove wako muupenyu uye mukushanda kwako nesimba pasi pezuva.
\v 10 Zvose zvinowanikwa noruoko rwako kuti ruzviite, zviite nesimba rako rose, nokuti muguva, mauri kuenda, hamuna kushanda kana kuronga, kana ruzivo kana uchenjeri.
\p 
\v 11 Ndakaona chimwe chinhuzve pasi pezuva:
\q1 Anomhanyisa haasi iye anokunda
\q2 uye ane simba haasi iye anokunda pakurwa,
\q1 uye akachenjera haasi iye ane zvokudya,
\q2 uye vane njere havasi ivo vane pfuma,
\q2 uye vakadzidza havasi ivo vanodiwa navanhu;
\q1 asi vose vanowirwa nenguva nezvinoitika.
\p 
\v 12 Pamusoro pezvo hakuna munhu anoziva nguva yake painosvika:
\q1 Sehove dzinobatwa murutava rwakaipa,
\q2 kana shiri dzinobatwa murugombe,
\q1 saizvozvowo vanhu vanobatwa
\q2 nenguva dzakaipa dzinovawira vasingatarisire.
\s1 Uchenjeri hunopfuura Upenzi
\p 
\v 13 Ndakaonazve pasi pezuva muenzaniso uyu wouchenjeri wakandifadza zvikuru:
\v 14 Kwakanga kune guta duku, raiva navanhu vashoma mariri. Mumwe mambo ane simba akarimukira, akarikomba, akarivakira masvingo makuru okurirwisa.
\v 15 Zvino muguta umu maigara mumwe murume akanga ari murombo asi akachenjera, uye akaponesa guta iri nouchenjeri hwake. Asi hakuna munhu akarangarira murombo uya.
\v 16 Saka ndakati, “Uchenjeri hunopfuura simba.” Asi uchenjeri hwomurombo hunoshorwa uye mashoko ake haangateererwi.
\q1 
\v 17 Mashoko manyoro omuchenjeri anoteererwa
\q2 kupfuura kudanidzira kwomunhu anobata ushe pakati pamapenzi.
\q1 
\v 18 Uchenjeri hunopfuura zvombo zvehondo,
\q2 asi mutadzi mumwe anoparadza zvakanaka zvizhinji.
\c 10
\q1 
\v 1 Nhunzi dzakafa dzinonhuwisa mafuta akanaka,
\q2 saizvozvowo upenzi hushoma hunorema kukunda uchenjeri nokukudzwa.
\q1 
\v 2 Mwoyo womunhu akachenjera unosimbira kurudyi,
\q2 asi mwoyo webenzi unosimbira kuruboshwe.
\q1 
\v 3 Kunyange richifamba pamugwagwa,
\q2 benzi rinoshayiwa njere
\q2 uye rinoratidza vanhu vose upenzi hwaro.
\q1 
\v 4 Kana kutsamwa kwomutongi kukakumukira,
\q2 usabva panzvimbo yako;
\q2 unyoro hunonyaradza mhosva huru.
\q1 
\v 5 Kune chinhu chakaipa chandakaona pasi pezuva,
\q2 kutadza kunobva kuvatongi:
\q1 
\v 6 Mapenzi anoiswa munzvimbo zhinji dzapamusoro,
\q2 ipapo vapfumi vachitora nzvimbo dzakaderera.
\q1 
\v 7 Ndakaona varanda vakatasva mabhiza,
\q2 ipapo machinda achifamba pasi netsoka savaranda.
\b
\q1 
\v 8 Ani naani anochera gomba angangowira mariri;
\q2 ani naani anopwanya naparusvingo angangorumwa nenyoka.
\q1 
\v 9 Ani naani anopwanya matombo angangokuvadzwa nawo;
\q2 ani naani anotsemura matanda angangozviisa panjodzi nawo.
\b
\q1 
\v 10 Kana demo rakagomara
\q2 uye rikasarodzwa,
\q1 panodiwa simba rakawanda,
\q2 asi unyanzvi hunouyisa kubudirira.
\b
\q1 
\v 11 Kana nyoka ikaruma mupingudzi asati aibata,
\q2 mupingudzi haachabatsiri.
\b
\q1 
\v 12 Mashoko anobva mumuromo momunhu akachenjera ane unyoro,
\q2 asi benzi rinomedzwa nomuromo waro.
\q1 
\v 13 Kutanga kwamashoko ake upenzi;
\q2 nokuguma kwokutaura kwake mupengo wakashata.
\q2 
\v 14 Uye benzi rinowanza mashoko.
\b
\q1 Hapana munhu anoziva zvichauya,
\q2 ndiani angamuudza zvichaitika shure kwake?
\b
\q1 
\v 15 Basa rebenzi rinomunetesa;
\q2 haazivi nzira inoenda kuguta.
\b
\q1 
\v 16 Une nhamo iwe nyika ina mambo aiva muranda
\q2 uye ina machinda anoita mabiko mangwanani.
\q1 
\v 17 Wakaropafadzwa iwe nyika ina mambo akaberekwa mukukudzwa
\q2 uye ina machinda anodya panguva yakafanira,
\q2 kuti vasimbiswe kwete kuti vadhakwe.
\b
\q1 
\v 18 Kana munhu ari simbe, denga remba rinosakara;
\q2 kana achigarira maoko, imba inobvinza.
\b
\q1 
\v 19 Mabiko anoitirwa kuseka,
\q2 uye waini inofadza upenyu,
\q2 asi mari imhinduro kune zvose.
\b
\q1 
\v 20 Usatuka mambo kunyange mupfungwa dzako,
\q2 kana kutuka mupfumi paimba yako yokuvata,
\q1 nokuti shiri yedenga ingangotakura mashoko ako,
\q2 uye china mapapiro chingangozivisa zvawataura.
\c 11
\s1 Chingwa pamusoro peMvura
\q1 
\v 1 Kanda chingwa chako pamusoro pemvura zhinji,
\q2 nokuti mushure mamazuva mazhinji uchachiwanazve.
\q1 
\v 2 Govera vanomwe, kunyange navaserewo;
\q2 nokuti hauzivi kuti idambudziko rakadii richauya panyika.
\q1 
\v 3 Kana makore azara nemvura
\q2 anonayisa mvura panyika.
\q1 Hazvinei kuti muti wawira zasi kana kumusoro,
\q2 panzvimbo paunowira, ndipo paucharara.
\q1 
\v 4 Ani naani anotarira mhepo haangadyari;
\q2 ani naani anotarira makore haangakohwi.
\b
\q1 
\v 5 Sezvo usingazivi nzira yemhepo,
\q2 kana magadzirirwo omuviri mudumbu ramai,
\q1 saizvozvowo haunganzwisisi basa raMwari,
\q2 Muiti wezvose.
\b
\q1 
\v 6 Kusha mbeu dzako mangwanani,
\q2 uye madekwana urege kugarira maoko ako,
\q1 nokuti hauzivi kuti chichabudirira ndechipi,
\q2 chingava ichi kana icho,
\q2 kana kuti zvose zviri zviviri zvichafanana pakunaka.
\s1 Rangarira Musiki wako uchiri muduku
\q1 
\v 7 Chiedza chakanaka,
\q2 uye zvinofadza meso kuona zuva.
\q1 
\v 8 Kunyange zvazvo munhu akararama makore mazhinji,
\q2 ngaafadzwe nawo ose.
\q1 Asi ngaarangarire mazuva erima,
\q2 nokuti achava mazhinji.
\q2 Zvose zvichazouya hazvina maturo.
\b
\q1 
\v 9 Fara zvako jaya, pauduku hwako,
\q2 uye mwoyo wako ngaukupe mufaro pamazuva ouduku hwako.
\q1 Tevera nzira dzomwoyo wako,
\q2 nezvose zvingaonekwe nameso ako,
\q1 asi uzive kuti pazvinhu zvose izvi
\q2 Mwari achakusvitsa pakutongwa.
\q1 
\v 10 Saka zvino dzinga zvinonetsa pamwoyo
\q2 wako ugobvisa zvinotambudza pamuviri wako,
\q2 nokuti uduku nesimba hazvina maturo.
\c 12
\q1 
\v 1 Rangarira Musiki wako
\q2 pamazuva ouduku hwako,
\q1 mazuva okutambudzika asati auya,
\q2 namakore asati aswedera pauchati,
\q2 “Handioni zvinofadza maari,”
\q1 
\v 2 zuva nechiedza uye nomwedzi
\q2 nenyeredzi zvisati zvadzima,
\q2 uye makore asati adzoka mushure mokunaya kwemvura;
\q1 
\v 3 kana vatariri vemba vodedera,
\q2 navarume vakasimba vokotama,
\q1 kana vakuyi vorega nokuti vashoma,
\q2 uye vaya vanotarira napamawindo voonera madzerere;
\q1 
\v 4 kana mikova yokunzira ichinge yapfigwa
\q2 uye maungira okukuya oderera;
\q1 kana vanhu vomutswa nokuimba kweshiri
\q2 asi nziyo dzavo dzose dzisisanzwiki zvakanaka;
\q1 
\v 5 kana vanhu votya nzvimbo dzakakwirira
\q2 nenjodzi mumigwagwa;
\q1 kana muamanda wotumbuka
\q2 nemhashu yozvikwekweredza
\q2 uye kuda kwose kwapera.
\q1 Ipapo munhu anoenda kumusha wake usingaperi,
\q2 uye vanochema vachafamba-famba munzira.
\q1 
\v 6 Murangarirei, rwodzi rwesirivha rusati rwadambuka;
\q2 uye mbiya yegoridhe isati yaputswa;
\q1 chirongo chisati chapwanyika pachitubu,
\q2 uye vhiri risati raputswa patsime,
\q1 
\v 7 uye guruva risati radzokera kuvhu kwarakabva,
\q2 nomweya usati wadzokera kuna Mwari akaupa.
\b
\q1 
\v 8 Muparidzi anoti, “Hazvina maturo! Hazvina maturo!
\q2 Zvose hazvina maturo!”
\s1 Magumo eNyaya
\p 
\v 9 Muparidzi akanga asina kuchenjera chete asi akadzidzisawo zivo kuvanhu. Akarangarira akaongorora uye akaronga zvirevo zvizhinji.
\v 10 Muparidzi akatsvaka kuti awane mashoko akanaka chete, uye zvaakanyora zvakarurama uye ndezvechokwadi.
\p 
\v 11 Mashoko avachenjeri akafanana nezvibayiso, mashoko avo akaunganidzwa akasimbiswa sembambo dzakarovererwa kwazvo, akapiwa noMufudzi mumwe chete.
\v 12 Yambirwa, mwanakomana wangu, kuti pasava nechinhu chipi zvacho chichawedzerwa pazviri.
\p Zvokunyora mabhuku mazhinji hazvina magumo, uye kudzidza zvizhinji kunonetesa muviri.
\q1 
\v 13 Zvino zvose zvanzwikwa;
\q2 houno mugumo wenyaya yacho:
\q1 Itya Mwari uchengete mirayiro yake,
\q2 nokuti iri ndiro basa rose romunhu.
\q1 
\v 14 Nokuti Mwari achatonga basa rimwe nerimwe
\q2 kusanganisira nezvakavanzika zvose,
\q2 zvakanaka kana zvakaipa.
