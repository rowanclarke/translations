\id 1JN - Tzutujil (Western) NT (tzjT=tzt) -Guatemala 2010 (DBL -2013)
\h 1 JUAN
\toc1 1 Juan
\toc2 1 Juan
\toc3 1 Jn
\mt1 1 JUAN
\c 1
\p 
\v 1 Jawa' jun carta ja nkatakel chewe ri' rc'amonto nak rbanic ja Ralc'wal Dios ja Yo'l utzlaj c'aslemal ja mta q'uisic trij, arja' xurk'alasani jani' rna'oj ja Dios. Ja Ralc'wal Dios arja' ni c'o wi' ja tok tz'ucarsaxto ja rwach'ulew. Ajoj katz'at ruq'uin kawach, kac'axaj ja xbij, katz'at jani' ja rc'aslemal, kachap ruq'uin kak'a'.
\v 2 Ja Yo'l c'aslemal xerila' ja k'ij chi ntz'attaji, ajoj katz'at in camic kamajon rk'alasaxic nak rbanic in jari' nkaya' rbixic chewe. Nabey ni c'o wi' ruq'uin ja Tatixel pro peti xurc'utu' kaj ri' chikawach.
\v 3 Ja katz'aton in ja kac'axan jari' nkaya' rbixic chewe utzc'a chi ixix jun nixquicot kuq'uin rmal como xa jun kabanon ruq'uin ja Dios ja Tatixel in chakaja' xa jun kabanon ruq'uin ja Jesucristo ja Ralc'wal.
\v 4 Ja katz'ibaj ri' nkatakel ewq'uin utzc'a chi nq'uiyi in nwachini ja quicotemal xin Dios pa tak ewanma.
\s1 * * * * * * * * * *
\p 
\v 5 Ja xtikatz'ibaj ri' jawa' tijonem kac'axan ja bix chake rmal ja Jesucristo quewari', ja Dios arja' ni sakil wi' rc'an, ni utz wi' ja nuban, majun k'ekumal rc'an ta.
\v 6 Ja wi nkabij chi xa jun kabanon ruq'uin ja Dios pro wi k'ekumal c'ayon kaxin jari' xa ok tz'akol tak tzij in ni k'alaj wi' chi matikanimaj ja utzlaj tzij xin Jesucristo.
\v 7 Pro wi sakil c'ayon kaxin cani' tre ja Dios arja' ni pa sakil wi' c'o wi', ja wi queri' kabanon xc'a jun kabanon ari'. Ja wi queri' kabanon ja rquiq'uel ja Jesucristo ja Ralc'wal jari' nch'ach'ojirsaj nojel ja kil kamac nkaban.
\p 
\v 8 Ja wi nkabij chi mta ja il mac kabanon jari' xa nkaban kaj engañar ki' kayon in ma katzij ta ja nkabij.
\v 9 Pro wi nkachol ja kil kamac chwach ja Dios arja' ni nuban wi' cumplir in ni utz wi' nuban chi rcuyic in nokrch'ach'ojirsaj chipan nojelal ja ritzelal ja nkaban.
\v 10 Ja c'a wi nkabij chi mta ja il mac kabanon jari' xa cani' tz'akol tzij nkacoj wi' ja Dios. Ja wi queri' nkabij jari' ni k'alaj wi' chi ma kacojon ta ja rtzobal Dios pa tak kanma.
\c 2
\p 
\v 1 Chak'laj walc'wal, jawa' jun carta ja ntakel ewq'uin ri' utzc'a chi maquixmacuni. Pro wi c'o jun chewe chaka jalal xuban ril bien kotak chi c'o jun ja nsamaj pa kacuenta chwach Dios ja Tatixel jari' ja Jesucristo, arja' ni utz wi' ja nuban.
\v 2 Arja' chomarsbal rxin ja kil kamac in ma ruyon ta chake ajoj nuban wi' queri', canojel winak ja nuban queri' chique.
\p 
\v 3 Ja wi nkanimaj ja mandamiento xin Jesucristo tri' nkatz'at wi' chi kotak rwach.
\v 4 Ja wi c'o jun nbij chi arja' rotak rwach ja Jesucristo pro wi matinimaj ja rmandamiento jari' xa tz'akol tzij, mta rtzobal Dios pa ranma.
\v 5 Pro ja winak ja nenimani ja rmandamiento eje'e' ri' ja q'uiynak chic in wachinnak chic ja rajoben ri'il xin Dios pa tak canma. Ja wi queri' kabanon tri' nkatz'at wi' chi xa jun kabanon ruq'uin.
\v 6 Ja wi c'o jun nbij chi arja' xa jun rbanon chic ruq'uin ja Jesucristo jari' ni rjawaxic wi' chi nrc'aj jun utzlaj c'aslemal ja cani' rc'aslemal ja Jesucristo.
\s1 * * * * * * * * * *
\p 
\v 7 Wach'alal, ja ntz'ibajel chewe ri' ma jun c'ac'a mandamiento ta, jawa' jun ojer mandamiento ec'waxan chic ja kas ya'to chewe nabey, jari' chi nawajo' awi'.
\v 8 Pro nkabij tre chakaja' chi c'ac'a mandamiento como ja rc'aslemal ja Jesucristo nuc'ut chikawach nak rbanic ja nawajo' awi' in queri' tre ja rec'aslemal ixix chakaja' jani' chi la newajo' ewi'. Queri' nkabij como ja rajoben ri'il ja rc'amonto ja Jesucristo ni katzij wi' chi ruq'uin Dios penak wi', okrya'on chic pa sakil cani' nuban k'ij tok npi rsakaric, ja c'a k'ekumal xin ojer ntajini nq'uisi.
\p 
\v 9 Ja wi c'o jun nbij chi arja' pa sakil chic c'o wi' pro wi xa itzel nutz'at jun rch'alal jari' c'a pa k'ekumal na c'o wi'.
\v 10 Ja wi ne'awajo' ja rawach'alal jari' ni pa sakil chi wi' atc'o wi' in majun nak chi ta xcatc'amo'el chi ta chipan jun itzelal.
\v 11 Pro wi c'o jun xa itzel nutz'at jun rch'alal jari' ni pa k'ekumal wi' c'o wi', ja k'ekumal jari' c'ayon rxin. Arja' moyirnak rmal ja k'ekumal rmalc'ari' ma rotak ta bar nekaj wi' tre ja rc'aslemal.
\p 
\v 12 Chak'laj walc'wal, rmal ja Jesucristo Dios xucuy ja rewil emac in rmalari' ntakel ja carta chewe.
\v 13 In chewe ixix ja rix rija', ixix ewotak rwach ja Ralc'walaxel ja ni c'o wi' ja tok tz'ucarsaxto ja rwach'ulew in rmalari' ntakel ja carta chewe. In chewe ixix ja rix c'ajola', ixix xixcowin trij ja diablo xech'ec in rmalari' ntakel ja carta chewe.
\p Chak'laj walc'wal, ewotak rwach ja Tatixel in rmalari' xintakel ja carta chewe.
\v 14 In chewe ixix ja rix rija', ewotak rwach ja Ralc'walaxel ja ni c'o wi' ja tok tz'ucarsaxto ja rwach'ulew in rmalari' xintakel ja carta chewe. In chewe ixix ja rix c'ajola', ixix ixcowirnak chipan ja rtzobal Dios in ni c'o wi' ja rtzobal pa tak ewanma in chakaja' xixcowin trij ja diablo xech'ec in rmalari' xintakel ja carta chewe.
\p 
\v 15 Wach'alal, maxta congana tel ec'u'x trij ja c'aslemal xin rwach'ulew nixtac'a ja ta ja ntzujuj chakaja'. Ja wi c'o jun congana nel ruc'u'x trij ja c'aslemal xin rwach'ulew jari' matel ruc'u'x trij ja katata' Dios.
\v 16 Ja ntzujuj ja rwach'ulew ma in katata' Dios ta penak wi', xa chwach'ulew winakarnak wi' cani' tre ja ritzel tak yarinem ja c'o pa tak kanma in cani' tre ja ma utz ta nkayarij je'e ja nutz'at je'e kawach in cani' tre chakaja' nojel ja nkayabej kaj kak'ij ja mta noc wi'.
\v 17 Ja c'aslemal xin rwach'ulew rachbil nojelal ja ntzujuj ja nkayarij jari' xa nk'axi pro canojel ja nenimani ja Dios chi nqueban ja najo'x chique rmal chi nqueban eje'e' ne'ec'ase' na chijutij ruq'uin.
\s1 * * * * * * * * * *
\p 
\v 18 Chak'laj walc'wal, anin nbij chewe chi xurwila' ja q'uisbal tiempo. Ixix ec'waxan chic chi npi na ja rc'ulel ja Cristo in camic e q'uiy ja rc'ulel epenak chic chewi' tok kotak chi xurwila' ja q'uisbal tiempo.
\v 19 Eje'e' ri' winak ja xe'elel chikacojol in xokqueya' can, bien k'alaj chi ma e kachbil ta. Ja wixta e kachbil maquita xokqueya' can ari'. Ma chaka ta xe'eli, tri' ntz'a̱t wi' chi ni majun chique kachbil ta.
\p 
\v 20 Pro ja c'a rixix ch'obtajnak chic emwal ewanojel nak rbanic ja utzlaj tzij xin Jesucristo. Ma chaka ta ch'obtajnak emwal como ja Cristo arja' rtakonto ja rEspíritu Santo ewq'uin.
\v 21 Anin ntz'ibajel ja carta chewe ri' pro ma rmal ta chi maja'n tich'obtaj emwal nak rbanic ja utzlaj tzij pro como ch'obtajnak chic emwal chewi' tok ntz'ibajel chewe. Ixix bien ewotak chi ja tz'akoj tzij ni matuc'am wi' ri' ruq'uin ja utzlaj tzij xin Jesucristo.
\p 
\v 22 Anin nbij chewe chi xa e tz'akol tak tzij ja winak ja nebini chi ja Jesús ma arja' ta ja Cristo ja Ralc'wal Dios. Eje'e' c'ari' e rc'ulel ja Cristo, nquibij chi ja Dios ma Tatixel ta in nquibij chakaja' chi ja Jesús ma Alc'walaxel ta.
\v 23 Ja winak ja nebini chi ja Jesús ma Alc'walaxel ta jari' mta ja Dios Tatixel pa tak canma pro ja nebini chi Alc'walaxel jari' c'oli ja Dios Tatixel pa tak canma.
\v 24 Rmalc'ari' tok nbij chewe, teya'a' lugar tre ja utzlaj tijonem ja kas xec'waxajto nabey chi nq'ueje' pa tak ewanma. Ja wi queri' xteban jari' nixq'ueje' pa ranma ja Ralc'walaxel in pa ranma ja Tatixel chakaja'.
\v 25 In quewa' rtzujun can chake ri', jun utzlaj c'aslemal ja mta q'uisic trij.
\p 
\v 26 Jawa' xintz'ibaj chewe ri' cumal ja winak ja ncajo' nqueya' jun tijonem chewe ja xa nquiyojbej ja tijonem eniman.
\v 27 Pro ixix c'o chic ja rEspíritu Santo takonto ewq'uin rmal ja Jesucristo, arja' c'o chic pa tak ewanma. Rmalc'ari' ja tok ma rjawaxic ta chewe xquixtijox chi ta cumal jule' winak, ja' Espíritu Santo c'ol ewq'uin jari' nixtijoni, arja' nch'obo chewach nojelal. Ja tijonem nuya' arja' chewe ni katzij wi', majun tz'akoj tzij rc'amonto. In cani' nuch'ob arja' chewach ni ta queri' neban, quixq'ueje' pa ranma ja Jesucristo.
\p 
\v 28 Chak'laj walc'wal, camic nbij chic jutij chewe, ni quixq'ueje' wi' pa ranma ja Jesucristo. Ja wi queri' xtikaban jari' matikaxbej ki' chwach ja tok xtipi chic jutij pro c'o kaconfianza ruq'uin tri' in chakaja' matikawawaj ki' chwach, ma q'uixbal ta nkana' chwach ja tok xtipeti.
\v 29 Ixix bien ewotak chi ni utz wi' rna'oj ja Jesucristo in tri' c'a newotakij wi' chi canojel ja winak ja ni utz wi' ja nqueban eje'e' ri' e ralc'wal Dios.
\c 3
\p 
\v 1 Janila nokrajo' ja Dios ja Tatixel. Arja' nbij chake chi ok ralc'wal, tri' c'a nkatz'at wi' chi congana nokrajo' in ni katzij wi' chi ok ralc'wal. Ja winak ja xa ruq'uin rwach'ulew yukul wi' quec'u'x eje'e' matich'obtaj cumal jani' rna'oj ja Dios in rmalari' matich'obtaj cumal nak kabanic ajoj chakaja'.
\v 2 Chak'laj wach'alal, anin nbij chewe chi ok ralc'wal chic ja Dios camic. Maja'n tik'alasax chikawach nak kabanic ja tok xkoq'uextaji pa jun k'ij xarwari' kotak chi ja tok xtipi chic jutij ja Jesucristo ajoj nij ok queri' chic tri' ja cani' arja'. Nkatz'at na chi utz tri' jani' ja kas mero rbanic ja Jesucristo chewi' tok nokoqui ja cani' arja'.
\v 3 Ja wi nokquicoti chi raybexic ja Jesucristo jari' nkach'ach'ojirsbej ja kanma como ja Jesucristo arja' ni rc'an wi' jun ch'ajch'ojlaj anma.
\p 
\v 4 ¿Jani' c'a ja il mac? Ja il mac junan ruq'uin ja matanimaj ja ley xin Dios. Ja c'a tok natmacuni ley xin Dios ari' ja matanimaj.
\v 5 Ixix bien ewotak chi peti ja Jesucristo wawe' chwach'ulew chi rchupic ja kil kamac in arja' ni mta wi' jun ril rumac rbanon.
\v 6 Ja wi natq'ueje' pa ranma ja Jesucristo jari' macatmacuni. Ja c'a wi chaka natmacuni jari' ma ch'obtajnak ta amwal jani' rna'oj ja Jesucristo in nixtac'a ch'obtajnak ta amwal nak rbanic chakaja'.
\p 
\v 7 Chak'laj walc'wal, maquita c'o jun xquixbano engañar, ja winak ja nebanowi ja rutzil xa queyon eje'e' ja utz netz'a̱t rmal ja Dios cani' tre ja Jesucristo arja' banol utzil.
\v 8 Pro ja winak ja chaka nemacuni eje'e' ri' e ralc'wal diablo cani' tre ja diablo arja' nij aj'il nij ajmac wi' ja tok tz'ucarsaxto ja rwach'ulew. Ja c'a Ralc'wal Dios peti wawe' chwach'ulew chi ryojic ja samaj ja nuban ja diablo.
\p 
\v 9 Ja wi at ralc'wal Dios jari' awc'an ja c'aslemal xin Dios in macatmacuni. Rmal ja rat ralc'wal Dios chewi' tok mta moda natmacuni.
\v 10 Wawe' nkatz'at wi' echinatak ja ralc'wal Dios in echinatak ja ralc'wal diablo, ja wi ma utz ta ja nqueban in wi maquecajo' ja cach'alal ma e ralc'wal Dios ta c'ari'.
\s1 * * * * * * * * * *
\p 
\v 11 Ni rjawaxic wi' chi nkajo' ki' como queri' nuc'ut chikawach ja tijonem ja rec'waxanto nabey.
\v 12 Maxta queri' tikaban ajoj ja cani' xuban ja Caín ojer, xoc pa rcuenta ja diablo ja Caín in xcamsaj ja ruchak'. ¿Nak tre tok xcamsaj? Como arja' xa itzel rc'aslemal pro ja ruchak' utz rc'aslemal xa chewi' tok xcamsaj.
\p 
\v 13 Wach'alal, maxta junwi' tena' rmal ja nixtzelax cumal ja winak ja xa ruq'uin rwach'ulew yukul wi' quec'u'x.
\v 14 Ja wi matawajo' awi' jari' atcamnak chwach ja Dios. Ja c'a rajoj nekajo' ja kach'alal rmalc'ari' tok kotak chi ma okcamnak chi ta chwach ja Dios, kotak chi okk'axnakpi chic chipan ja camíc in kawilon chic ja utzlaj c'aslemal ja mta q'uisic trij.
\v 15 Ja wi xa itzel natz'at jun awach'alal jari' at jun camsanel. Ixix bien ewotak chi majun camsanel rc'an ta ja utzlaj c'aslemal ja mta q'uisic trij.
\v 16 Ja Jesucristo arja' xuya' ri' chi camsax pa kacuenta, tri' nkotakij wi' jani' ja rajoben ri'il. Queri' chake ajoj chakaja' yatal chakij chi matikapokonaj nkaya' ki' pa camíc pa quicuenta ja kach'alal.
\v 17 Pro ja wi c'o jun awach'alal wi c'oli nc'atzin tre ja ntzukbej ri' in wi c'ol awq'uin ja nc'atzin tre, ja c'a wi matapokonaj rwach, wi matato' jari' ni k'alaj wi' chi mta ja rajoben ri'il xin Dios pan awanma.
\v 18 Chak'laj walc'wal, maxta xa chi kachi' c'o wi' ja tok nkabij chi nkajo' ki'. Ja kas nrajo' chi c'oli nkaban ja nkac'utbej chi ni katzij wi' chi nkajo' ki'.
\s1 * * * * * * * * * *
\p 
\v 19-20 Ja wi ni katzij wi' chi nkajo' ki' tri' nkotakij wi' chi ja Dios okc'ayon. In jun chic, masqui nti'oni ja kanma rmal ja ma utz ta kabanon pro wi c'oli ja rajoben ri'il xin Dios chake xa rmalari' tok nquicoti ja kanma chwa Dios in matiti'on chic. Queri' rbanic como ja Dios arja' más chi na nim ruk'ij, c'o ruk'a' tre ja kanma in nojel rotak.
\v 21 Chak'laj wach'alal, ja wi mta nti'on pa tak kanma jari' c'o kaconfianza noktzijon ruq'uin ja Dios
\v 22 in arja' nuya' chake xa nak ta ja nkac'utuj tre. Como ajoj nkanimaj ja rmandamiento in como arja' nquicot chakij chewi' tok nuban queri' chake.
\v 23 Ja rmandamiento ja Dios quewa' nbij chake ri', tiyuke' kac'u'x ruq'uin ja Jesucristo ja Ralc'wal in tikajo' ki' ja cani' bin can chake rmal.
\v 24 Ja wi nanimaj ja rmandamiento ja Dios jari' natq'ueje' pa ranma ja Dios in nq'ueje'e ja Dios pan awanma atat chakaja'. Rmal ja rEspíritu Santo ja rya'on ja Dios chake chewi' tok kotak chi arja' c'o pa tak kanma.
\c 4
\p 
\v 1 Chak'laj wach'alal, teya'a' ewxquin tre ja xtinbij chewe ri'. E q'uiy ja winak quipaxin qui' chwach'ulew eje'e' nquibij chi tijonem xin Dios ja nqueya'. Pro xa quipayil ja nquibij, ma katzij ta. Rmalc'ari' tok nbij chewe, ma que'enimaj ta canojel ja winak ja nebini chi Espíritu xin Dios ec'ayon. Pro ja neban, bien teya'a' cuenta chique jani' netzijoni ja wi katzij chi Espíritu xin Dios ec'ayon owi mani.
\v 2 Wawe' newotakij wi' ja wi Espíritu xin Dios ec'ayon, ja nebini chi kajto ja Jesucristo in xoc kach winak eje'e' ri' ja katzij chi Espíritu xin Dios ec'ayon.
\v 3 Pro ja nebini chi ja Jesucristo ma xoc ta kach winak eje'e' ri' ja ma Espíritu xin Dios ta ec'ayon. Junwi' chi na chi espíritu c'ayon quixin, jari' espíritu xa rc'ulel ja Cristo. Jari' espíritu ec'waxan chic chi npi na pro camic c'o chic wawe' chwach'ulew.
\p 
\v 4 Chak'laj walc'wal, ixix ixc'o pa rcuenta ja Dios. Ja maestro ja ma Dios ta ec'ayon eje'e' ma xecowin ta chewij, ixix xixch'eco quixin. Queri' xeban como ja Dios ja c'o pa tak ewanma ixix más chi na k'axnak rchok'ak' chwach ja diablo ja c'o pa tak canma ja winak ja xa ruq'uin rwach'ulew yukul wi' quec'u'x.
\v 5 Como eje'e' xa ruq'uin rwach'ulew yukul wi' quec'u'x rmalari' tok xa ja' nquinataj ja xin rwach'ulew. Ja c'a jule' chic winak ja yukul quec'u'x ruq'uin ja rwach'ulew eje'e' nel quec'u'x chi rc'axaxic ja nbix chique cumal.
\v 6 Pro ja rajoj okc'o pa rcuenta ja Dios. Ja winak ja cotak rwach ja Dios eje'e' nel quec'u'x chi rc'axaxic ja nkabij pro ja ma ec'o ta pa rcuenta ja Dios eje'e' maticajo' nquic'axaj ja nkabij. Tri' c'a nkotakij wi' echinatak ja re'uc'an rmal ja rEspíritu xin Dios, jun Espíritu ja mta tz'akoj tzij rc'amonto, in echinatak ja re'uc'an rmal ja respíritu xin diablo, jun espíritu ja xa tz'akoj tzij rc'amonto.
\s1 * * * * * * * * * *
\p 
\v 7 Chak'laj wach'alal, congana rjawaxic chi nkajo' ki'. Ja rajoben ri'il ruq'uin Dios winakarnakto wi'. Ja nawajo' awi' jari' at ralc'wal Dios, jari' awotak rwach ja Dios.
\v 8 Ja Dios arja' ni rc'an wi' ja rajoben ri'il rmalc'ari' ja tok nbij chewe, ja wi matawajo' awi' jari' ma awotak ta rwach ja Dios.
\v 9 Ja Dios xutakto ja Ralc'wal chi kato'ic, ni xarwari' jun ja Ralc'wal. Tri' nkatz'at wi' chi nokrajo' ja Dios como xutakto ja Ralc'wal wawe' chwach'ulew. Queri' xuban utzc'a chi rmal ja Ralc'wal nkawil ja utzlaj c'aslemal ja mta q'uisic trij.
\v 10 Ja Dios ma ajoj ta xokajo'n rxin nabey, arja' xajo'n kaxin nabey como xutakto ja Jesucristo ja Ralc'wal chi arja' xoc chomarsbal rxin ja kil kamac chwach ja Dios. Tri' nkatz'at wi' ja kas mero rbanic ja rajoben ri'il.
\p 
\v 11 Chak'laj wach'alal, queri' xuban ja Dios, arja' congana xokrajo' rmalc'ari' nbij chewe chi yatal chakij chi nkajo' ki' ajoj chakaja'.
\v 12 Ja Dios majun nak ta tz'atyon rxin pro wi nkajo' ki' jari' nq'ueje' pa tak kanma ja Dios in chakaja' nq'uiyi nwachini pa tak kanma ja rajoben ri'il rxin.
\p 
\v 13 Ja Dios rya'onto chake ja rEspíritu rxin, tri' c'a nkatz'at wi' chi okc'o pa ranma in arja' chakaja' c'o pa tak kanma.
\v 14 In ajoj chakaja' katz'at rwach ja Jesucristo ja Ralc'wal Dios in nkaya' rbixic chi arja' takto rmal ja Tatixel, xoc To'onel kaxin kanojelal ja rok winak.
\v 15 Canojel ja winak ja nebini chi Jesús arja' Ralc'wal Dios eje'e' ri' c'oli pa tak canma ja Dios in eje'e' chakaja' ec'o pa ranma ja Dios.
\v 16 Ajoj kotak chi ja Dios nokrajo', yukul kac'u'x ruq'uin ja rajoben ri'il rc'an. Ja Dios ni rxin wi' ni rc'an wi' ja rajoben ri'il. Kanojelal ja kuc'an chic ja rajoben ri'il xin Dios jari' okc'o pa ranma ja Dios in queri' chake ajoj chakaja' c'oli ja Dios pa tak kanma.
\v 17 Ja wi matikaxbej ki' chwach ja nimlaj k'ij xin juicio ja tok xtipi chic jutij ja Jesucristo tri' nkatz'at wi' chi q'uiynak chic in wachinnak chic ja rajoben ri'il xin Dios pa tak kanma. Ajoj c'a okc'o na wawe' chwach'ulew pro como xa junan chic kana'oj ruq'uin ja Jesucristo chewi' tok matikaxbej ki' chwach.
\v 18 Ja rajoben ri'il xin Dios ni majun xbeben ri'il rc'an. Pro ja rbanic, ja wi nwachini ja rajoben ri'il xin Dios chipan ja rawanma ja c'a xbeben ri'il nlasaxel rmal. Ja xbeben ri'il congana lawulo' nuban chawe. Ja wi xa naxbej awi' jari' maja'n tiq'uiyi chi utz maja'n tiwachini ja rajoben ri'il xin Dios chipan ja rawanma.
\v 19 Ja Dios arja' xokrajo' ajoj nabey rmalc'ari' tok nkajo' arja' chakaja'.
\v 20 Ja wi c'o jun nbij: —Anin nwajo' ja Dios, wi ne'e, pro wi xa itzel nutz'at jun rch'alal jari' xa tz'akol tzij. Ja rawach'alal c'oloc chawach, natz'at rwach pro wi matawajo' ¿nak ta c'a moda ari' natcowini nawajo' ja Dios ja matitz'attaji?
\v 21 Ja mandamiento xin Dios quewa' nbij chake ri': —Ja wi ninewajo' anin rjawaxic chi ne'ewajo' ja rewach'alal chakaja', ne'e ja Dios chake.
\c 5
\p 
\v 1 Kanojel ja kaniman ja Jesús chi arja' ja Cristo ja cha'on rmal ja Dios, ja wi queri' kaniman ok ralc'wal Dios c'ari'. Cani' tre jun alc'walaxel ja wi nrajo' ja rtata' nerajo' c'ari' chakaja' ja jule' chic rch'alal.
\v 2 Ja wi nkajo' ja Dios in wi nkanimaj ja rmandamiento tri' nkatz'at wi' chi nekajo' ja ralc'wal Dios chakaja'.
\v 3 Ja wi nkanimaj ja mandamiento xin Dios jari' nkac'utbej chi nkajo' ja Dios chakaja'. Ja c'a mandamiento xin Dios ma al ta rc'axic
\v 4 como arja' rya'on kachok'ak' kanojel ja rok ralc'wal in rmalari' ja ritzelal xin rwach'ulew maticowin chakij, ajoj nokch'ocmaji. Rmal ja yukulbal kac'u'x ruq'uin ja Jesucristo chewi' tok nokch'ocmaji.
\v 5 ¿Echinatak c'ari' ja nech'ocmaji? Ajoj c'ari' ja kaniman ja Jesús chi arja' ja Ralc'wal Dios ajoj nokch'ocmaji.
\s1 * * * * * * * * * *
\p 
\v 6 Ja tok peti ja Jesucristo c'oli k'alasan rxin chi Ralc'wal Dios jari' tok ban bautizar in tok camsaxi xutix ja rquiq'uel chwach cruz. Ma chaka ta ruyon ari' ja ban bautizar pro xutix ja rquiq'uel chwach cruz chakaja'. Ja rEspíritu Santo arja' nbini chakaja' chi ja Jesucristo arja' Ralc'wal Dios. Ja rEspíritu Santo ni rxin wi' chi katzij nojel ja nbij.
\v 7 E oxi' ja rec'o chila' chicaj ja xa junan nquibij tre ja Jesús chi arja' Ralc'wal Dios, jun, Dios ja Tatixel, in jun chic, ja Ralc'walaxel ja nk'alasani jani' rna'oj ja Dios, in jun chic, ja rEspíritu Santo.
\v 8 In chakaja' oxi' rwach ja testigo ja c'o chwach'ulew, jun, ja rEspíritu Santo, in jun chic, ja tok ban bautizar ja Jesús, in jun chic, tok xutix ja rquiq'uel chwach cruz, xa junan nk'alasaj chi oxi' chi Jesús arja' Ralc'wal Dios.
\v 9 Como nekanimaj winak tok nqueya' testigo'il rmalc'ari' tok más na rjawaxic chi nkanimaj ja testigo xin Dios. Ja Dios rcojon ja testigo chi rk'alasaxic chi ja Jesús arja' ja Ralc'wal. Ja testigo'il nuya' ja Dios más na nim ruk'ij chwach ja nqueya' winak.
\v 10 Kanojel ja yukul kac'u'x ruq'uin ja Ralc'wal Dios c'o chic ja testigo'il xin Dios pa tak kanma ja nyabex kaseguro. Ja wi matanimaj ja nbij ja Dios nel c'ari' xa cani' tz'akol tzij nacoj wi'. Queri' naban ja wi matanimaj ja testigo'il ja rya'onto ja Dios tre ja Ralc'wal.
\v 11 Ja testigo'il xin Dios quewa' nuc'ut chikawach ri', chi arja' Dios rya'on chake ja utzlaj c'aslemal ja mta q'uisic trij in ruq'uin ja Ralc'wal nkawil wi'.
\v 12 Ja wi awc'an ja Ralc'wal Dios chipan ja rawanma jari' awc'an chic ja utzlaj c'aslemal ja mta q'uisic trij. Ja c'a wi ma awc'an ta ja Ralc'wal Dios pan awanma jari' ma awc'an ta ja utzlaj c'aslemal ja mta q'uisic trij.
\s1 * * * * * * * * * *
\p 
\v 13 Anin xintz'ibajel ja carta ri' in ntakel ewq'uin ixix ja yukul ec'u'x ruq'uin ja Jesucristo ja Ralc'wal Dios. Ja xintz'ibaj chipan jari' nyabej eseguro chi ixix ewc'an chic ja utzlaj c'aslemal ja mta q'uisic trij.
\p 
\v 14 Yukul kac'u'x ruq'uin ja Dios chi arja' nc'ulba' ja roración nkaban ja wi utz nc'axaj ja nkac'utuj tre.
\v 15 Como kotak chi Dios nc'axaj ja koración nkaban xa nak ta nkabij tre rmalc'ari' kotak chi arja' ni nuya' wi' chake ja nkac'utuj tre.
\p 
\v 16 Ja tok nkatz'at jun kach'alal wi xuban jun ril kabana' orar pa rcuenta in nyataj na tre ja utzlaj c'aslemal rmal ja Dios. Queri' rubey ja wi ma ja ta xuban ja mta cuytajic trij ja natc'amo'el chijutij chipan ja camíc. Pro c'oli ja il mac wi xaban natruc'amel chijutij chipan ja camíc jari' matinbij chi nkaya' pan oración.
\v 17 Nojelal ja naban ja matirajo' Dios chawe chi naban jari' il mac. Pro c'oli ja il mac wi xaban c'oli cuytajic trij in macatruc'amel chijutij chipan ja camíc.
\p 
\v 18 Kotak chi kanojel ja rokalaxnak chic jutij ja c'o rc'aslemal Dios pa tak kanma ajoj makomacuni pro ja Jesús ja Ralc'wal Dios arja' nokchajini in maticowini ja diablo nokruchap ta.
\p 
\v 19 Kotak chakaja' chi ajoj okc'o pa rcuenta ja Dios pro ja jule' chic winak ja rec'o chwach'ulew xa pa ruk'a' ja diablo ec'o wi'.
\p 
\v 20 In kotak chakaja' chi ja Jesús ja Ralc'wal Dios peti wawe' chwach'ulew in xuya' chake chi kotakij rwach ja Dios ja katzij chi Dios. In ajoj xa jun kabanon ruq'uin ja Dios ja katzij chi Dios in xa jun kabanon ruq'uin ja Jesucristo ja Ralc'wal, ruyon arja' ja Dios ja katzij chi Dios, ruyon arja' nyowi ja utzlaj c'aslemal ja mta q'uisic trij.
\v 21 Chak'laj walc'wal, tebana' cuenta ewi', maxta tiyuke' ec'u'x cuq'uin ja cachbal tak winak nixtac'a ruq'uin ta ja rachbal tak nakun. Amén.
