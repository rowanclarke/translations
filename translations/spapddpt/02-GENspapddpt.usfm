\v 44 \w Faraón|strong="H6547"\w* dijo \w a|strong="H3068"\w* \w José|strong="H3130"\w*: Yo soy \w Faraón|strong="H6547"\w*, pero \w sin|strong="H3808"\w* tu autorización \w nadie|strong="H3808"\w* \w levantará|strong="H7311"\w* su \w mano|strong="H3027"\w* \w ni|strong="H3808"\w* su \w pie|strong="H7272"\w* en \w toda|strong="H3605"\w* \w la|strong="H3605"\w* tierra de \w Egipto|strong="H4714"\w*.  
\v 45 \w Faraón|strong="H6547"\w* \w llamó|strong="H7121"\w* \w a|strong="H3068"\w* \w José|strong="H3130"\w* Zafnat-panea,\f + \fr 41:45 \ft Es decir, Descubridor de lo oculto, Salvador del mundo.\f* \w y|strong="H5921"\w* \w le|strong="H5921"\w* \w dio|strong="H5414"\w* \w como|strong="H5921"\w* esposa \w a|strong="H3068"\w* Asenat, \w hija|strong="H1323"\w* \w de|strong="H5921"\w* Potifera, \w sacerdote|strong="H3548"\w* \w de|strong="H5921"\w* On. Entonces \w José|strong="H3130"\w* \w salió|strong="H3318"\w* \w a|strong="H3068"\w* recorrer \w toda|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w*.   
\p
\v 46 \w José|strong="H3130"\w* tenía 30 \w años|strong="H8141"\w* cuando compareció \w ante|strong="H6440"\w* \w Faraón|strong="H6547"\w*, \w rey|strong="H4428"\w* \w de|strong="H6440"\w* \w Egipto|strong="H4714"\w*. \w Luego|strong="H3318"\w* \w José|strong="H3130"\w* se retiró \w de|strong="H6440"\w* \w la|strong="H3605"\w* \w presencia|strong="H6440"\w* \w de|strong="H6440"\w* \w Faraón|strong="H6547"\w* y recorrió \w toda|strong="H3605"\w* \w la|strong="H3605"\w* tierra \w de|strong="H6440"\w* \w Egipto|strong="H4714"\w*.  
\v 47 En los \w siete|strong="H7651"\w* \w años|strong="H8141"\w* de abundancia, la tierra produjo \w a|strong="H3068"\w* montones.  
\v 48 Almacenó \w todo|strong="H3605"\w* \w el|strong="H3605"\w* alimento \w que|strong="H1961"\w* \w hubo|strong="H1961"\w* \w de|strong="H5414"\w* \w los|strong="H3605"\w* \w siete|strong="H7651"\w* \w años|strong="H8141"\w* \w de|strong="H5414"\w* abundancia \w en|strong="H8432"\w* \w la|strong="H3605"\w* tierra \w de|strong="H5414"\w* \w Egipto|strong="H4714"\w*. Luego \w puso|strong="H5414"\w* \w el|strong="H3605"\w* alimento \w en|strong="H8432"\w* las \w ciudades|strong="H5892"\w* y depositó \w en|strong="H8432"\w* ellas \w la|strong="H3605"\w* producción del \w campo|strong="H7704"\w* \w de|strong="H5414"\w* sus \w alrededores|strong="H5439"\w*.  
\v 49 \w José|strong="H3130"\w* también almacenó grano \w como|strong="H3588"\w* \w la|strong="H3588"\w* arena del \w mar|strong="H3220"\w*, \w mucho|strong="H3966"\w* \w en|strong="H5704"\w* extremo, \w hasta|strong="H5704"\w* \w no|strong="H3588"\w* poderse \w contar|strong="H5608"\w*, \w pues|strong="H3588"\w* era incalculable.   
\p
\v 50 \w Antes|strong="H2962"\w* \w que|strong="H1121"\w* llegara \w el|strong="H1121"\w* primer \w año|strong="H8141"\w* \w de|strong="H1121"\w* la hambruna, le \w nacieron|strong="H3205"\w* \w a|strong="H3068"\w* \w José|strong="H3130"\w* \w dos|strong="H8147"\w* \w hijos|strong="H1121"\w*, \w los|strong="H1121"\w* cuales Asenat, \w hija|strong="H1323"\w* \w de|strong="H1121"\w* Potifera, \w sacerdote|strong="H3548"\w* \w de|strong="H1121"\w* On, le dio \w a|strong="H3068"\w* luz.  
\v 51 \w José|strong="H3130"\w* \w llamó|strong="H7121"\w* al \w primogénito|strong="H1060"\w* \w Manasés|strong="H4519"\w*, \w porque|strong="H3588"\w* dijo: \nd ʼElohim\nd* \w me|strong="H3588"\w* hizo olvidar \w todo|strong="H3605"\w* mi sufrimiento \w y|strong="H3588"\w* \w toda|strong="H3605"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* mi padre.  
\v 52 \w Llamó|strong="H7121"\w* al \w segundo|strong="H8145"\w* Efraín, \w porque|strong="H3588"\w* dijo: \nd ʼElohim\nd* \w me|strong="H3588"\w* hizo fructífero \w en|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* mi \w aflicción|strong="H6040"\w*.   
\p
\v 53 \w Se|strong="H1961"\w* \w acabaron|strong="H3615"\w* \w los|strong="H1961"\w* \w siete|strong="H7651"\w* \w años|strong="H8141"\w* de abundancia \w que|strong="H1961"\w* \w hubo|strong="H1961"\w* en la tierra de \w Egipto|strong="H4714"\w*.  
\v 54 \w Comenzaron|strong="H2490"\w* \w los|strong="H3605"\w* \w siete|strong="H7651"\w* \w años|strong="H8141"\w* de hambruna, \w como|strong="H1961"\w* dijo \w José|strong="H3130"\w*. \w Hubo|strong="H1961"\w* hambruna en \w todos|strong="H3605"\w* \w los|strong="H3605"\w* países, pero en \w toda|strong="H3605"\w* \w la|strong="H3605"\w* tierra de \w Egipto|strong="H4714"\w* \w había|strong="H1961"\w* \w pan|strong="H3899"\w*.  
\v 55 Cuando \w se|strong="H5971"\w* sintió \w la|strong="H3605"\w* hambruna \w en|strong="H3212"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* tierra \w de|strong="H5971"\w* \w Egipto|strong="H4714"\w*, \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* \w clamó|strong="H6817"\w* \w a|strong="H3068"\w* \w Faraón|strong="H6547"\w* por \w pan|strong="H3899"\w*. \w Y|strong="H3068"\w* \w Faraón|strong="H6547"\w* dijo \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w Egipto|strong="H4714"\w*: \w Vayan|strong="H3212"\w* \w a|strong="H3068"\w* \w José|strong="H3130"\w* y \w hagan|strong="H6213"\w* \w lo|strong="H6213"\w* \w que|strong="H5971"\w* \w él|strong="H3605"\w* les diga.   
\p
\v 56 \w La|strong="H5921"\w* hambruna \w estaba|strong="H1961"\w* \w por|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* extensión \w del|strong="H5921"\w* país. Entonces \w José|strong="H3130"\w* \w abrió|strong="H6605"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* graneros, \w y|strong="H5921"\w* vendió \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w egipcios|strong="H4713"\w*, \w pues|strong="H1961"\w* \w la|strong="H5921"\w* hambruna \w era|strong="H1961"\w* severa \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w*.  
\v 57 También llegaban \w de|strong="H3588"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* tierra \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w* \w para|strong="H3588"\w* comprar grano \w a|strong="H3068"\w* \w José|strong="H3130"\w*, \w porque|strong="H3588"\w* \w la|strong="H3605"\w* hambruna aumentaba \w en|strong="H3588"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* tierra.   
\c 42  
\s1 El primer viaje de los hijos de Israel a Egipto  
\p
\v 1 \w Jacob|strong="H3290"\w*, al considerar \w que|strong="H3588"\w* \w había|strong="H3588"\w* grano \w en|strong="H3588"\w* \w Egipto|strong="H4714"\w*, dijo \w a|strong="H3068"\w* sus \w hijos|strong="H1121"\w*: ¿\w Por|strong="H3588"\w* \w qué|strong="H3588"\w* \w se|strong="H4100"\w* \w miran|strong="H7200"\w* unos \w a|strong="H3068"\w* otros?  
\v 2 \w Y|strong="H3068"\w* añadió: Miren, \w oí|strong="H8085"\w* \w que|strong="H3588"\w* \w hay|strong="H3426"\w* grano \w en|strong="H3588"\w* \w Egipto|strong="H4714"\w*. Bajen \w allá|strong="H8033"\w* \w y|strong="H3588"\w* compren algo \w para|strong="H3588"\w* nosotros \w a|strong="H3068"\w* fin \w de|strong="H3588"\w* \w que|strong="H3588"\w* vivamos \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w muramos|strong="H4191"\w*.   
\p
\v 3 \w Bajaron|strong="H3381"\w*, \w pues|strong="H3381"\w*, \w diez|strong="H6235"\w* de los hermanos de \w José|strong="H3130"\w* \w a|strong="H3068"\w* comprar grano en \w Egipto|strong="H4714"\w*.  
\v 4 \w Pero|strong="H3588"\w* \w Jacob|strong="H3290"\w* \w no|strong="H3808"\w* \w envió|strong="H7971"\w* \w a|strong="H3068"\w* \w Benjamín|strong="H1144"\w*, hermano \w de|strong="H3588"\w* \w José|strong="H3130"\w*, \w con|strong="H3588"\w* sus hermanos, \w porque|strong="H3588"\w* dijo: \w No|strong="H3808"\w* \w sea|strong="H6435"\w* \w que|strong="H3588"\w* le ocurra alguna calamidad.  
\v 5 \w Así|strong="H3588"\w* \w que|strong="H3588"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* \w fueron|strong="H1961"\w* \w a|strong="H3068"\w* comprar grano \w entre|strong="H8432"\w* \w los|strong="H1121"\w* \w que|strong="H3588"\w* iban, \w pues|strong="H3588"\w* \w la|strong="H3588"\w* hambruna \w estaba|strong="H1961"\w* \w en|strong="H8432"\w* \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* \w Canaán|strong="H3667"\w*.   
\p
\v 6 \w José|strong="H3130"\w* \w era|strong="H1931"\w* \w el|strong="H1931"\w* gobernante \w del|strong="H5921"\w* país, \w el|strong="H1931"\w* \w que|strong="H1931"\w* vendía \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H1931"\w* \w pueblo|strong="H5971"\w* \w de|strong="H5921"\w* \w la|strong="H1931"\w* tierra. Entonces \w los|strong="H5921"\w* hermanos \w de|strong="H5921"\w* \w José|strong="H3130"\w* llegaron \w y|strong="H5921"\w* \w se|strong="H1931"\w* postraron ante \w él|strong="H1931"\w* \w con|strong="H5921"\w* \w su|strong="H1931"\w* rostro \w en|strong="H5921"\w* tierra.  
\v 7 \w José|strong="H3130"\w* \w vio|strong="H7200"\w* \w a|strong="H3068"\w* sus hermanos y los reconoció, pero fingió ser un extraño para ellos, y les \w habló|strong="H1696"\w* \w duramente|strong="H7186"\w*. \w Y|strong="H3068"\w* les preguntó: ¿De dónde vinieron? Ellos \w respondieron|strong="H1696"\w*: De la tierra de \w Canaán|strong="H3667"\w* \w a|strong="H3068"\w* comprar alimento.   
\p
\v 8 \w Así|strong="H1992"\w* \w que|strong="H3808"\w* \w José|strong="H3130"\w* reconoció \w a|strong="H3068"\w* \w sus|strong="H1992"\w* hermanos, pero \w ellos|strong="H1992"\w* \w no|strong="H3808"\w* \w lo|strong="H3808"\w* \w reconocieron|strong="H5234"\w*.  
\v 9 Al \w acordarse|strong="H2142"\w* \w José|strong="H3130"\w* de los \w sueños|strong="H2472"\w* que \w tuvo|strong="H2492"\w* con respecto \w a|strong="H3068"\w* ellos, los acusó: ¡Ustedes son \w espías|strong="H7270"\w*! ¡Vinieron para \w ver|strong="H7200"\w* lo desprotegido del país!   
\p
\v 10 Pero ellos le contestaron: \w No|strong="H3808"\w*, \tl ʼadón\tl* nuestro, tus esclavos vinimos \w a|strong="H3068"\w* comprar alimento.  
\v 11 \w Todos|strong="H3605"\w* \w nosotros|strong="H3605"\w* \w somos|strong="H1961"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* un \w mismo|strong="H3605"\w* \w hombre|strong="H1121"\w*. \w Somos|strong="H1961"\w* honestos. Tus esclavos \w no|strong="H3808"\w* \w somos|strong="H1961"\w* \w espías|strong="H7270"\w*.   
\p
\v 12 \w Pero|strong="H3588"\w* \w él|strong="H3588"\w* les dijo: ¡\w No|strong="H3808"\w*! Vinieron \w a|strong="H3068"\w* \w ver|strong="H7200"\w* \w lo|strong="H3808"\w* desprotegido del país.   
\p
\v 13 \w Entonces|strong="H3117"\w* ellos respondieron: Tus esclavos somos 12 hermanos, \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* un varón \w de|strong="H1121"\w* la tierra \w de|strong="H1121"\w* \w Canaán|strong="H3667"\w*, y \w mira|strong="H2009"\w*, \w el|strong="H1121"\w* \w menor|strong="H6996"\w* está \w hoy|strong="H3117"\w* con nuestro padre, y \w el|strong="H1121"\w* otro desapareció.   
\p
\v 14 Pero \w José|strong="H3130"\w* les \w dijo|strong="H1696"\w*: \w Es|strong="H1931"\w* \w lo|strong="H1931"\w* \w que|strong="H1931"\w* les digo: ¡Son \w espías|strong="H7270"\w*!  
\v 15 \w En|strong="H3588"\w* \w esto|strong="H2063"\w* serán probados: \w Vive|strong="H2416"\w* \w Faraón|strong="H6547"\w*, \w que|strong="H3588"\w* \w no|strong="H3588"\w* \w saldrán|strong="H3318"\w* \w de|strong="H3588"\w* \w aquí|strong="H2008"\w* \w hasta|strong="H2088"\w* \w cuando|strong="H3588"\w* venga \w aquí|strong="H2008"\w* \w su|strong="H3588"\w* hermano \w menor|strong="H6996"\w*.  
\v 16 Envíen \w a|strong="H3068"\w* uno \w de|strong="H4480"\w* ustedes \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w traiga|strong="H3947"\w* \w a|strong="H3068"\w* \w su|strong="H3588"\w* hermano. \w Entre|strong="H3808"\w* tanto, queden ustedes detenidos \w y|strong="H3588"\w* sean comprobadas sus \w palabras|strong="H1697"\w*, \w si|strong="H3588"\w* hay verdad \w en|strong="H4480"\w* ustedes, \w y|strong="H3588"\w* \w si|strong="H3588"\w* \w no|strong="H3808"\w*, ¡\w vive|strong="H2416"\w* \w Faraón|strong="H6547"\w*, \w que|strong="H3588"\w* \w son|strong="H3588"\w* \w espías|strong="H7270"\w*!  
\v 17 \w Y|strong="H3068"\w* los envió todos juntos \w a|strong="H3068"\w* la \w cárcel|strong="H4929"\w* por \w tres|strong="H7969"\w* \w días|strong="H3117"\w*.   
\p
\v 18 Pero al tercer \w día|strong="H3117"\w* \w José|strong="H3130"\w* les dijo: \w Hagan|strong="H6213"\w* \w esto|strong="H2063"\w* y \w vivirán|strong="H2421"\w*. \w Yo|strong="H6213"\w* \w temo|strong="H3372"\w* \w a|strong="H3068"\w* \nd ʼElohim\nd*.  
\v 19 Si son honestos, uno de los hermanos quede encarcelado mientras los demás van y \w llevan|strong="H3212"\w* el grano para el hambre de sus \w familias|strong="H1004"\w*.  
\v 20 Pero me traerán \w a|strong="H3068"\w* su hermano \w menor|strong="H6996"\w* para \w que|strong="H3808"\w* sus \w palabras|strong="H1697"\w* sean verificadas, y \w no|strong="H3808"\w* \w morirán|strong="H4191"\w*. \w E|strong="H3068"\w* \w hicieron|strong="H6213"\w* \w así|strong="H3651"\w*.   
\p
\v 21 Cada \w cual|strong="H5315"\w* decía \w a|strong="H3068"\w* su hermano: \w Ciertamente|strong="H8085"\w* somos culpables \w por|strong="H5921"\w* nuestro hermano, \w pues|strong="H3651"\w* \w vimos|strong="H7200"\w* \w la|strong="H5921"\w* \w angustia|strong="H6869"\w* \w de|strong="H5921"\w* su \w alma|strong="H5315"\w* cuando \w nos|strong="H5921"\w* \w rogaba|strong="H2603"\w*, \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w lo|strong="H3808"\w* escuchamos. \w Por|strong="H5921"\w* \w eso|strong="H3651"\w* vino \w sobre|strong="H5921"\w* \w nosotros|strong="H5921"\w* \w esta|strong="H2063"\w* \w angustia|strong="H6869"\w*.   
\p
\v 22 \w Entonces|strong="H1571"\w* \w Rubén|strong="H7205"\w* les \w respondió|strong="H6030"\w*: ¿\w No|strong="H3808"\w* les \w hablé|strong="H6030"\w*: \w No|strong="H3808"\w* pequen contra \w el|strong="H1571"\w* muchacho? Pero \w no|strong="H3808"\w* me \w escucharon|strong="H8085"\w*, \w y|strong="H1571"\w* \w ahora|strong="H2009"\w*, \w ciertamente|strong="H1571"\w*, nos es demandada su \w sangre|strong="H1818"\w*.  
\v 23 \w Ellos|strong="H1992"\w* \w no|strong="H3808"\w* \w sabían|strong="H3045"\w* \w que|strong="H3588"\w* \w José|strong="H3130"\w* \w entendía|strong="H3045"\w*, \w porque|strong="H3588"\w* \w había|strong="H3588"\w* un traductor \w entre|strong="H3808"\w* \w ellos|strong="H1992"\w*.   
\p
\v 24 \w Entonces|strong="H7725"\w* \w él|strong="H5921"\w* \w se|strong="H5921"\w* \w apartó|strong="H5437"\w* \w y|strong="H5921"\w* \w lloró|strong="H1058"\w*. \w Después|strong="H5921"\w* \w volvió|strong="H7725"\w* \w a|strong="H3068"\w* \w ellos|strong="H5921"\w* \w y|strong="H5921"\w* \w les|strong="H5921"\w* \w habló|strong="H1696"\w*, \w y|strong="H5921"\w* \w al|strong="H5921"\w* \w tomar|strong="H3947"\w* \w de|strong="H5921"\w* \w entre|strong="H5921"\w* \w ellos|strong="H5921"\w* \w a|strong="H3068"\w* \w Simeón|strong="H8095"\w*, \w lo|strong="H5921"\w* ató \w delante|strong="H5869"\w* \w de|strong="H5921"\w* \w ellos|strong="H5921"\w*.   
\p
\v 25 \w Entonces|strong="H3651"\w* \w José|strong="H3130"\w* \w ordenó|strong="H6680"\w* que llenaran sus \w sacos|strong="H8242"\w* \w de|strong="H5414"\w* grano, devolvieran la \w plata|strong="H3701"\w* \w de|strong="H5414"\w* cada uno \w de|strong="H5414"\w* ellos \w a|strong="H3068"\w* su \w saco|strong="H8242"\w* y \w les|strong="H6680"\w* dieran provisiones \w para|strong="H5414"\w* \w el|strong="H6213"\w* \w camino|strong="H1870"\w*. \w Y|strong="H3068"\w* \w así|strong="H3651"\w* \w se|strong="H3651"\w* \w hizo|strong="H6213"\w* con ellos.  
\v 26 \w Ellos|strong="H5921"\w* cargaron su grano \w sobre|strong="H5921"\w* sus \w asnos|strong="H2543"\w* \w y|strong="H5921"\w* salieron \w de|strong="H5921"\w* \w allí|strong="H8033"\w*.   
\p
\v 27 Pero en \w la|strong="H1931"\w* posada, al abrir uno \w de|strong="H5414"\w* \w ellos|strong="H1931"\w* \w su|strong="H1931"\w* \w saco|strong="H8242"\w* \w para|strong="H5414"\w* \w dar|strong="H5414"\w* \w forraje|strong="H4554"\w* \w a|strong="H3068"\w* \w su|strong="H1931"\w* \w asno|strong="H2543"\w*, \w vio|strong="H7200"\w* \w que|strong="H1931"\w* ahí \w estaba|strong="H2009"\w* \w su|strong="H1931"\w* \w dinero|strong="H3701"\w* en \w la|strong="H1931"\w* \w boca|strong="H6310"\w* \w de|strong="H5414"\w* \w su|strong="H1931"\w* \w saco|strong="H8242"\w*.  
\v 28 Dijo \w a|strong="H3068"\w* sus hermanos: ¡\w Mi|strong="H2009"\w* \w plata|strong="H3701"\w* \w fue|strong="H1571"\w* devuelta, \w y|strong="H1571"\w* miren, \w está|strong="H2063"\w* \w en|strong="H3318"\w* \w mi|strong="H2009"\w* \w saco|strong="H3318"\w*!  
\p \w Entonces|strong="H7725"\w* \w el|strong="H6213"\w* \w corazón|strong="H3820"\w* \w se|strong="H4100"\w* les sobresaltó \w y|strong="H1571"\w* espantados \w se|strong="H4100"\w* dijeron \w el|strong="H6213"\w* uno al otro: ¿\w Qué|strong="H4100"\w* \w es|strong="H2063"\w* \w esto|strong="H2063"\w* \w que|strong="H4100"\w* \nd ʼElohim\nd* \w nos|strong="H4100"\w* \w hizo|strong="H6213"\w*?   
\p
\v 29 Cuando llegaron \w a|strong="H3068"\w* su padre \w Jacob|strong="H3290"\w* en tierra de \w Canaán|strong="H3667"\w*, le \w contaron|strong="H5046"\w* \w todas|strong="H3605"\w* las cosas \w que|strong="H3605"\w* les sucedieron y dijeron:  
\v 30 Aquel hombre, el \tl ʼadón\tl* \w de|strong="H5414"\w* aquella tierra nos \w habló|strong="H1696"\w* cosas \w duras|strong="H7186"\w* y nos \w trató|strong="H5414"\w* como \w a|strong="H3068"\w* \w espías|strong="H7270"\w* \w de|strong="H5414"\w* aquel país.  
\v 31 Pero le dijimos: Nosotros \w somos|strong="H1961"\w* honestos, \w no|strong="H3808"\w* \w somos|strong="H1961"\w* \w espías|strong="H7270"\w*.  
\v 32 Somos 12 hermanos, \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* nuestro padre, uno no aparece, y \w el|strong="H1121"\w* \w menor|strong="H6996"\w* está \w hoy|strong="H3117"\w* con nuestro padre en la tierra \w de|strong="H1121"\w* \w Canaán|strong="H3667"\w*.   
\p
\v 33 Aquel hombre, \w el|strong="H3588"\w* \tl ʼadón\tl* \w de|strong="H3588"\w* \w aquella|strong="H2063"\w* tierra, nos dijo: \w En|strong="H3588"\w* \w esto|strong="H2063"\w* sabré \w que|strong="H3588"\w* ustedes \w son|strong="H3588"\w* honestos. Dejen \w a|strong="H3068"\w* uno \w de|strong="H3588"\w* sus hermanos conmigo, \w y|strong="H3588"\w* \w tomen|strong="H3947"\w* grano \w para|strong="H3588"\w* \w el|strong="H3588"\w* hambre \w de|strong="H3588"\w* sus \w familias|strong="H1004"\w* \w y|strong="H3588"\w* váyanse.  
\v 34 Tráiganme \w a|strong="H3068"\w* \w su|strong="H3588"\w* hermano \w menor|strong="H6996"\w*, \w y|strong="H3588"\w* \w así|strong="H3651"\w* sabré \w que|strong="H3588"\w* \w no|strong="H3808"\w* \w son|strong="H3588"\w* \w espías|strong="H7270"\w*, \w que|strong="H3588"\w* \w son|strong="H3588"\w* honestos. Les devolveré \w a|strong="H3068"\w* \w su|strong="H3588"\w* hermano \w y|strong="H3588"\w* podrán negociar \w en|strong="H3588"\w* \w el|strong="H3588"\w* país.   
\p
\v 35 \w Sucedió|strong="H1961"\w* \w que|strong="H1961"\w* al vaciar \w ellos|strong="H1992"\w* \w sus|strong="H1992"\w* \w sacos|strong="H8242"\w*, ahí \w estaba|strong="H1961"\w* la bolsa \w de|strong="H3372"\w* \w dinero|strong="H3701"\w* \w de|strong="H3372"\w* cada uno en \w su|strong="H1992"\w* \w saco|strong="H8242"\w*. \w Y|strong="H3068"\w* al \w ver|strong="H7200"\w* \w ellos|strong="H1992"\w* y \w su|strong="H1992"\w* padre \w las|strong="H1992"\w* bolsas \w de|strong="H3372"\w* \w dinero|strong="H3701"\w* \w tuvieron|strong="H1961"\w* \w temor|strong="H3372"\w*.  
\v 36 Entonces su padre \w Jacob|strong="H3290"\w* \w les|strong="H5921"\w* dijo: Ustedes \w me|strong="H5921"\w* privaron \w de|strong="H5921"\w* hijos: \w José|strong="H3130"\w* ya \w no|strong="H1961"\w* \w está|strong="H1961"\w*, \w Simeón|strong="H8095"\w* tampoco \w está|strong="H1961"\w*, \w y|strong="H5921"\w* quieren llevarse \w a|strong="H3068"\w* \w Benjamín|strong="H1144"\w*. ¡\w Todas|strong="H3605"\w* estas cosas \w están|strong="H1961"\w* \w contra|strong="H5921"\w* \w mí|strong="H5921"\w*!   
\p
\v 37 \w Rubén|strong="H7205"\w* habló \w a|strong="H3068"\w* su padre: Ordena \w que|strong="H3808"\w* \w mueran|strong="H4191"\w* \w mis|strong="H5414"\w* \w dos|strong="H8147"\w* \w hijos|strong="H1121"\w* \w si|strong="H3808"\w* \w no|strong="H3808"\w* \w te|strong="H5921"\w* \w lo|strong="H3808"\w* traigo. \w Entrégalo|strong="H5414"\w* \w en|strong="H5921"\w* \w mi|strong="H5921"\w* \w mano|strong="H3027"\w*, \w que|strong="H3808"\w* yo \w te|strong="H5921"\w* \w lo|strong="H3808"\w* devolveré.   
\p
\v 38 \w Pero|strong="H3588"\w* \w él|strong="H1931"\w* respondió: \w Mi|strong="H3015"\w* \w hijo|strong="H1121"\w* \w no|strong="H3808"\w* bajará \w con|strong="H5973"\w* ustedes, \w pues|strong="H3588"\w* \w su|strong="H1931"\w* hermano \w murió|strong="H4191"\w* \w y|strong="H3588"\w* \w quedó|strong="H7604"\w* \w él|strong="H1931"\w* \w solo|strong="H1931"\w*. \w Si|strong="H3588"\w* alguna desgracia \w le|strong="H1931"\w* acontece \w en|strong="H5973"\w* \w el|strong="H1931"\w* \w camino|strong="H1870"\w* \w por|strong="H3588"\w* \w donde|strong="H1931"\w* van, harán descender mis canas \w con|strong="H5973"\w* \w dolor|strong="H3015"\w* al \tl Seol\tl*.   
\c 43  
\s1 El segundo viaje de los hijos de Israel a Egipto  
\p
\v 1 Pero la hambruna era severa en aquella tierra.  
\v 2 Ocurrió \w que|strong="H1961"\w*, \w cuando|strong="H1961"\w* \w acabaron|strong="H3615"\w* de comer el grano \w que|strong="H1961"\w* llevaron de \w Egipto|strong="H4714"\w*, su padre les dijo: \w Vuelvan|strong="H7725"\w* y compren un \w poco|strong="H4592"\w* de alimento \w para|strong="H1961"\w* nosotros.   
\p
\v 3 \w Judá|strong="H3063"\w* le respondió: Aquel hombre nos advirtió seriamente: \w No|strong="H3808"\w* \w verán|strong="H7200"\w* \w mi|strong="H1115"\w* \w rostro|strong="H6440"\w* \w a|strong="H3068"\w* menos \w que|strong="H3808"\w* su hermano venga con ustedes.  
\v 4 \w Si|strong="H3426"\w* \w envías|strong="H7971"\w* \w a|strong="H3068"\w* nuestro hermano con nosotros, bajaremos y te compraremos alimento,  
\v 5 \w pero|strong="H3588"\w* \w si|strong="H3588"\w* \w no|strong="H3808"\w* \w lo|strong="H3808"\w* \w envías|strong="H7971"\w*, \w no|strong="H3808"\w* bajaremos, \w porque|strong="H3588"\w* aquel hombre nos dijo: \w No|strong="H3808"\w* \w verán|strong="H7200"\w* \w mi|strong="H1115"\w* \w rostro|strong="H6440"\w*, \w a|strong="H3068"\w* \w menos|strong="H3588"\w* \w que|strong="H3588"\w* \w su|strong="H3588"\w* hermano esté \w con|strong="H3588"\w* ustedes.   
\p
\v 6 \w E|strong="H3068"\w* \w Israel|strong="H3478"\w* preguntó: ¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* me \w hicieron|strong="H4100"\w* tanto \w mal|strong="H7489"\w* al declarar \w a|strong="H3068"\w* ese hombre \w que|strong="H4100"\w* tenían \w otro|strong="H5750"\w* hermano?   
\p
\v 7 \w Ellos|strong="H5921"\w* respondieron: Aquel hombre \w nos|strong="H5921"\w* \w preguntó|strong="H7592"\w* \w expresamente|strong="H7592"\w* \w con|strong="H5921"\w* respecto \w a|strong="H3068"\w* \w nosotros|strong="H5921"\w* \w y|strong="H3588"\w* \w de|strong="H5921"\w* nuestra \w parentela|strong="H4138"\w*: ¿\w Vive|strong="H2416"\w* \w aún|strong="H5750"\w* \w su|strong="H3588"\w* padre? ¿\w Tienen|strong="H3426"\w* \w otro|strong="H5750"\w* hermano? \w Y|strong="H3068"\w* \w le|strong="H5921"\w* declaramos \w conforme|strong="H6310"\w* \w a|strong="H3068"\w* estas \w preguntas|strong="H7592"\w*. ¿Sabíamos \w que|strong="H3588"\w* \w él|strong="H5921"\w* diría: Hagan bajar \w a|strong="H3068"\w* \w su|strong="H3588"\w* hermano?   
\p
\v 8 \w Judá|strong="H3063"\w* dijo \w a|strong="H3068"\w* su padre \w Israel|strong="H3478"\w*: \w Envía|strong="H7971"\w* al joven conmigo, \w así|strong="H1571"\w* nos levantaremos \w e|strong="H3068"\w* \w iremos|strong="H3212"\w* para \w que|strong="H3808"\w* vivamos \w y|strong="H1571"\w* \w no|strong="H3808"\w* \w muramos|strong="H4191"\w* \w también|strong="H1571"\w* nosotros, \w también|strong="H1571"\w* tú, \w y|strong="H1571"\w* \w también|strong="H1571"\w* nuestros pequeños.  
\v 9 Yo salgo fiador \w por|strong="H6440"\w* \w él|strong="H3605"\w*. \w A|strong="H3068"\w* \w mí|strong="H1245"\w* \w mismo|strong="H3605"\w* me pedirás cuentas \w por|strong="H6440"\w* \w él|strong="H3605"\w*. \w Si|strong="H3808"\w* \w no|strong="H3808"\w* te \w lo|strong="H3808"\w* devuelvo y \w lo|strong="H3808"\w* coloco \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ti, \w seré|strong="H3808"\w* culpable \w ante|strong="H6440"\w* ti \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w días|strong="H3117"\w*.  
\v 10 \w Si|strong="H3588"\w* \w no|strong="H3884"\w* hubiéramos demorado, \w ciertamente|strong="H3588"\w* \w ya|strong="H2088"\w* habríamos \w vuelto|strong="H7725"\w* \w dos|strong="H6471"\w* \w veces|strong="H6471"\w*.   
\p
\v 11 Su padre \w Israel|strong="H3478"\w* respondió: Si tiene que ser \w así|strong="H3651"\w*, háganlo. \w Tomen|strong="H3947"\w* de \w lo|strong="H6213"\w* mejor de \w la|strong="H2063"\w* tierra en sus sacos y lleven obsequios \w a|strong="H3068"\w* \w aquel|strong="H6213"\w* varón, un \w poco|strong="H4592"\w* de \w bálsamo|strong="H6875"\w*, un \w poco|strong="H4592"\w* de \w miel|strong="H1706"\w*, especias, mirra, nueces y \w almendras|strong="H8247"\w*.  
\v 12 Lleven en \w sus|strong="H1931"\w* \w manos|strong="H3027"\w* \w el|strong="H1931"\w* doble de \w la|strong="H1931"\w* \w plata|strong="H3701"\w* y lleven en \w su|strong="H1931"\w* \w mano|strong="H3027"\w* \w la|strong="H1931"\w* \w plata|strong="H3701"\w* devuelta en las \w bocas|strong="H6310"\w* de \w sus|strong="H1931"\w* sacos, \w pues|strong="H1931"\w* quizás \w fue|strong="H1931"\w* un error.  
\v 13 \w Tomen|strong="H3947"\w* \w a|strong="H3068"\w* su hermano, \w levántense|strong="H6965"\w* y \w vuelvan|strong="H7725"\w* ante aquel hombre.  
\v 14 \w Y|strong="H3068"\w* que \nd ʼEL-Shadday\nd* les conceda gran misericordia \w ante|strong="H6440"\w* aquel hombre, y les suelte \w a|strong="H3068"\w* su otro hermano, y \w a|strong="H3068"\w* \w Benjamín|strong="H1144"\w*. \w Y|strong="H3068"\w* \w si|strong="H6440"\w* tengo que quedar \w privado|strong="H7921"\w* \w de|strong="H6440"\w* hijos, ¡que quede \w privado|strong="H7921"\w* \w de|strong="H6440"\w* \w mis|strong="H5414"\w* hijos!   
\p
\v 15 Entonces los hombres, al \w tomar|strong="H3947"\w* los obsequios, el doble \w de|strong="H6440"\w* \w plata|strong="H3701"\w* \w en|strong="H5975"\w* su \w mano|strong="H3027"\w*, y \w a|strong="H3068"\w* \w Benjamín|strong="H1144"\w*, se \w levantaron|strong="H6965"\w* y \w bajaron|strong="H3381"\w* \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w* para presentarse \w ante|strong="H6440"\w* \w José|strong="H3130"\w*.  
\v 16 \w Cuando|strong="H3588"\w* \w José|strong="H3130"\w* \w vio|strong="H7200"\w* \w a|strong="H3068"\w* \w Benjamín|strong="H1144"\w* \w con|strong="H5921"\w* \w ellos|strong="H5921"\w*, dijo \w al|strong="H5921"\w* administrador \w de|strong="H5921"\w* \w su|strong="H3588"\w* \w casa|strong="H1004"\w*: \w Ordena|strong="H3559"\w* \w que|strong="H3588"\w* esos \w varones|strong="H3588"\w* entren \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w*, degüella un animal \w y|strong="H3588"\w* prepáralo, \w porque|strong="H3588"\w* estos \w varones|strong="H3588"\w* comerán conmigo \w a|strong="H3068"\w* mediodía.   
\p
\v 17 \w El|strong="H6213"\w* hombre \w hizo|strong="H6213"\w* como \w José|strong="H3130"\w* dijo, y los \w hizo|strong="H6213"\w* entrar en \w casa|strong="H1004"\w* de \w José|strong="H3130"\w*.  
\v 18 \w Los|strong="H5921"\w* hombres tuvieron \w temor|strong="H3372"\w* \w cuando|strong="H3588"\w* fueron conducidos \w a|strong="H3068"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w José|strong="H3130"\w*, \w pues|strong="H3588"\w* decían: \w Por|strong="H5921"\w* \w el|strong="H5921"\w* \w asunto|strong="H1697"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w plata|strong="H3701"\w* \w que|strong="H3588"\w* fue devuelta \w en|strong="H5921"\w* nuestros sacos \w la|strong="H5921"\w* primera vez somos traídos acá, \w para|strong="H5921"\w* atacarnos, abalanzarse \w sobre|strong="H5921"\w* \w nosotros|strong="H5921"\w* \w y|strong="H3588"\w* tomarnos \w como|strong="H3588"\w* esclavos \w a|strong="H3068"\w* \w nosotros|strong="H5921"\w* \w y|strong="H3588"\w* \w a|strong="H3068"\w* nuestros \w asnos|strong="H2543"\w*.   
\p
\v 19 Entonces \w llegaron|strong="H5066"\w* \w al|strong="H5921"\w* administrador \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w José|strong="H3130"\w*, \w y|strong="H5921"\w* \w le|strong="H5921"\w* \w hablaron|strong="H1696"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w puerta|strong="H6607"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w*:  
\v 20 ¡Ay, \tl ʼadón\tl* nuestro! Nosotros ciertamente bajamos la primera vez \w a|strong="H3068"\w* comprar alimento,  
\v 21 \w pero|strong="H3588"\w* \w sucedió|strong="H1961"\w* \w que|strong="H3588"\w* \w cuando|strong="H3588"\w* llegamos \w a|strong="H3068"\w* \w la|strong="H3588"\w* posada \w y|strong="H3588"\w* abrimos nuestros sacos, \w la|strong="H3588"\w* \w plata|strong="H3701"\w* \w de|strong="H3588"\w* cada uno \w estaba|strong="H1961"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* \w boca|strong="H6310"\w* \w de|strong="H3588"\w* \w su|strong="H3588"\w* saco, nuestra \w plata|strong="H3701"\w* \w en|strong="H3588"\w* \w su|strong="H3588"\w* justo \w peso|strong="H4948"\w*. \w Por|strong="H3588"\w* eso \w la|strong="H3588"\w* \w volvimos|strong="H7725"\w* \w a|strong="H3068"\w* traer \w en|strong="H3588"\w* nuestras \w manos|strong="H3027"\w*.  
\v 22 Trajimos otra \w plata|strong="H3701"\w* para comprar alimento. \w No|strong="H3808"\w* \w sabemos|strong="H3045"\w* \w quién|strong="H4310"\w* \w puso|strong="H7760"\w* nuestra \w plata|strong="H3701"\w* en los sacos.   
\p
\v 23 \w Y|strong="H3068"\w* él respondió: \w Paz|strong="H7965"\w* \w a|strong="H3068"\w* ustedes, no \w teman|strong="H3372"\w*. El \nd ʼElohim\nd* \w de|strong="H3372"\w* ustedes y el \nd ʼElohim\nd* \w de|strong="H3372"\w* su padre les \w dio|strong="H5414"\w* un tesoro escondido \w en|strong="H3318"\w* sus sacos. La \w plata|strong="H3701"\w* \w de|strong="H3372"\w* ustedes llegó \w a|strong="H3068"\w* mí. \w Y|strong="H3068"\w* les \w sacó|strong="H3318"\w* \w a|strong="H3068"\w* \w Simeón|strong="H8095"\w*.   
\p
\v 24 Entonces el hombre ordenó \w a|strong="H3068"\w* aquellos varones \w que|strong="H4325"\w* entraran en la \w casa|strong="H1004"\w* \w de|strong="H5414"\w* \w José|strong="H3130"\w*. Les \w dio|strong="H5414"\w* \w agua|strong="H4325"\w* y lavaron sus \w pies|strong="H7272"\w*, y \w dio|strong="H5414"\w* \w forraje|strong="H4554"\w* \w a|strong="H3068"\w* sus \w asnos|strong="H2543"\w*.  
\v 25 Ellos prepararon \w el|strong="H3588"\w* \w presente|strong="H4503"\w* \w para|strong="H5704"\w* \w la|strong="H3588"\w* llegada \w de|strong="H3588"\w* \w José|strong="H3130"\w* \w al|strong="H5704"\w* mediodía, \w pues|strong="H3588"\w* \w oyeron|strong="H8085"\w* \w que|strong="H3588"\w* \w allí|strong="H8033"\w* iban \w a|strong="H3068"\w* comer \w los|strong="H3588"\w* \w alimentos|strong="H3899"\w*.   
\p
\v 26 Cuando \w José|strong="H3130"\w* llegó \w a|strong="H3068"\w* la \w casa|strong="H1004"\w*, \w ellos|strong="H3027"\w* le presentaron los regalos \w que|strong="H3027"\w* tenían en sus \w manos|strong="H3027"\w*, y se postraron \w a|strong="H3068"\w* tierra ante él.  
\v 27 Entonces les \w preguntó|strong="H7592"\w* \w cómo|strong="H5750"\w* estaban: ¿Está \w bien|strong="H7965"\w* su padre, el \w anciano|strong="H2205"\w* del cual hablaron? ¿\w Vive|strong="H2416"\w* \w aún|strong="H5750"\w*?   
\p
\v 28 \w Y|strong="H3068"\w* ellos respondieron: Tu esclavo nuestro padre está \w bien|strong="H7965"\w*, \w aún|strong="H5750"\w* \w vive|strong="H2416"\w*. Hicieron reverencia y se postraron.   
\p
\v 29 \w Y|strong="H3068"\w* \w él|strong="H1121"\w* \w levantó|strong="H5375"\w* sus \w ojos|strong="H5869"\w* y \w vio|strong="H7200"\w* \w a|strong="H3068"\w* su hermano \w Benjamín|strong="H1144"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* su madre, y preguntó: ¿\w Es|strong="H2088"\w* \w éste|strong="H2088"\w* su hermano \w menor|strong="H6996"\w*, \w de|strong="H1121"\w* quien me hablaron? \w Y|strong="H3068"\w* añadió: \nd ʼElohim\nd* tenga \w de|strong="H1121"\w* ti \w misericordia|strong="H2603"\w*, \w hijo|strong="H1121"\w* mío.  
\v 30 \w José|strong="H3130"\w* se apresuró \w a|strong="H3068"\w* salir, \w porque|strong="H3588"\w* \w su|strong="H3588"\w* ser interno estaba conmovido \w por|strong="H3588"\w* causa \w de|strong="H3588"\w* \w su|strong="H3588"\w* hermano. \w Buscó|strong="H1245"\w* \w dónde|strong="H8033"\w* llorar, \w y|strong="H3588"\w* entró \w en|strong="H3588"\w* \w su|strong="H3588"\w* \w cámara|strong="H2315"\w* \w y|strong="H3588"\w* \w lloró|strong="H1058"\w* \w allí|strong="H8033"\w*.   
\p
\v 31 Después se \w lavó|strong="H7364"\w* el \w rostro|strong="H6440"\w* y \w salió|strong="H3318"\w*. \w Luego|strong="H3318"\w* \w de|strong="H6440"\w* refrenarse, \w ordenó|strong="H7760"\w*: ¡Sirvan los \w alimentos|strong="H3899"\w*!   
\p
\v 32 \w Pero|strong="H3588"\w* sirvieron separadamente \w para|strong="H3588"\w* \w ellos|strong="H1931"\w* \w y|strong="H3588"\w* \w por|strong="H3588"\w* separado \w para|strong="H3588"\w* \w los|strong="H1931"\w* \w egipcios|strong="H4713"\w* \w que|strong="H3588"\w* comían \w con|strong="H3588"\w* \w él|strong="H1931"\w*, \w pues|strong="H3588"\w* \w los|strong="H1931"\w* \w egipcios|strong="H4713"\w* \w no|strong="H3808"\w* \w podían|strong="H3201"\w* comer \w alimentos|strong="H3899"\w* \w con|strong="H3588"\w* \w los|strong="H1931"\w* \w hebreos|strong="H5680"\w*, \w porque|strong="H3588"\w* \w eso|strong="H1931"\w* \w era|strong="H1931"\w* repugnancia \w para|strong="H3588"\w* \w los|strong="H1931"\w* \w egipcios|strong="H4713"\w*.   
\p
\v 33 Ellos se \w sentaron|strong="H3427"\w* \w ante|strong="H6440"\w* \w él|strong="H3427"\w*, \w el|strong="H3427"\w* \w primogénito|strong="H1060"\w* conforme \w a|strong="H3068"\w* su primogenitura, y \w el|strong="H3427"\w* \w menor|strong="H6810"\w* conforme \w a|strong="H3068"\w* su \w menor|strong="H6810"\w* edad. \w Y|strong="H3068"\w* aquellos varones \w estaban|strong="H3427"\w* \w atónitos|strong="H8539"\w* y se miraban \w el|strong="H3427"\w* uno al \w otro|strong="H7453"\w*.  
\v 34 Luego \w él|strong="H5973"\w* \w tomó|strong="H5375"\w* porciones \w de|strong="H6440"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w él|strong="H5973"\w* \w para|strong="H5973"\w* \w ellos|strong="H3027"\w*, pero \w la|strong="H3605"\w* porción \w de|strong="H6440"\w* \w Benjamín|strong="H1144"\w* era \w cinco|strong="H2568"\w* \w veces|strong="H3027"\w* mayor \w que|strong="H3605"\w* las porciones \w de|strong="H6440"\w* \w todos|strong="H3605"\w* \w ellos|strong="H3027"\w*. \w Bebieron|strong="H8354"\w* y se alegraron \w con|strong="H5973"\w* \w él|strong="H5973"\w*.   
\c 44  
\s1 La copa de José  
\p
\v 1 Luego \w él|strong="H5921"\w* \w ordenó|strong="H6680"\w* \w al|strong="H5921"\w* administrador \w de|strong="H5921"\w* su \w casa|strong="H1004"\w*: \w Llena|strong="H4390"\w* \w de|strong="H5921"\w* comida \w los|strong="H5921"\w* sacos \w de|strong="H5921"\w* estos hombres, \w tanto|strong="H5921"\w* \w como|strong="H5921"\w* puedan llevar, \w y|strong="H5921"\w* \w pon|strong="H7760"\w* \w la|strong="H5921"\w* \w plata|strong="H3701"\w* \w de|strong="H5921"\w* cada uno \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w boca|strong="H6310"\w* \w de|strong="H5921"\w* su saco.  
\v 2 \w Y|strong="H3068"\w* \w pon|strong="H7760"\w* mi copa \w de|strong="H1697"\w* \w plata|strong="H3701"\w* en la \w boca|strong="H6310"\w* del saco del \w menor|strong="H6996"\w* con la \w plata|strong="H3701"\w* \w de|strong="H1697"\w* su grano. \w E|strong="H3068"\w* \w hizo|strong="H6213"\w* \w conforme|strong="H6310"\w* \w a|strong="H3068"\w* la \w palabra|strong="H1697"\w* \w que|strong="H1697"\w* le \w habló|strong="H1696"\w* \w José|strong="H3130"\w*.   
\p
\v 3 Cuando rayó \w el|strong="H1992"\w* alba, \w aquellos|strong="H1992"\w* varones fueron despedidos con \w sus|strong="H1992"\w* \w asnos|strong="H2543"\w*.  
\v 4 \w Ellos|strong="H1992"\w* \w salieron|strong="H3318"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w*, \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w se|strong="H5921"\w* habían alejado \w cuando|strong="H4100"\w* \w José|strong="H3130"\w* dijo \w al|strong="H5921"\w* administrador \w de|strong="H5921"\w* \w su|strong="H1992"\w* \w casa|strong="H1004"\w*: \w Levántate|strong="H6965"\w* \w y|strong="H5921"\w* \w persigue|strong="H7291"\w* \w a|strong="H3068"\w* esos hombres, \w y|strong="H5921"\w* \w cuando|strong="H4100"\w* \w los|strong="H1992"\w* alcances, diles: ¿\w Por|strong="H5921"\w* \w qué|strong="H4100"\w* pagaron \w mal|strong="H7451"\w* \w por|strong="H5921"\w* \w bien|strong="H2896"\w*?  
\v 5 ¿\w No|strong="H3808"\w* \w es|strong="H1931"\w* \w esta|strong="H2088"\w* \w la|strong="H1931"\w* copa en \w la|strong="H1931"\w* \w cual|strong="H1931"\w* mi \tl ʼadón\tl* \w bebe|strong="H8354"\w* y \w suele|strong="H6213"\w* \w adivinar|strong="H5172"\w* con \w ella|strong="H1931"\w*? Obraron \w mal|strong="H7489"\w* en \w lo|strong="H1931"\w* \w que|strong="H1931"\w* \w hicieron|strong="H6213"\w*.   
\p
\v 6 Cuando él los \w alcanzó|strong="H5381"\w* les \w dijo|strong="H1696"\w* estas \w palabras|strong="H1697"\w*.  
\v 7 \w Y|strong="H3068"\w* ellos le contestaron: ¿\w Por|strong="H1697"\w* \w qué|strong="H4100"\w* nuestro \tl ʼadón\tl* \w dice|strong="H1696"\w* tales \w cosas|strong="H1697"\w*? ¡\w Lejos|strong="H2486"\w* \w esté|strong="H2088"\w* \w de|strong="H1697"\w* tus esclavos \w hacer|strong="H6213"\w* \w tal|strong="H2088"\w* \w cosa|strong="H1697"\w*!  
\v 8 \w Mira|strong="H2005"\w*, la \w plata|strong="H3701"\w* \w que|strong="H6310"\w* \w hallamos|strong="H4672"\w* en la \w boca|strong="H6310"\w* de nuestros sacos te la \w volvimos|strong="H7725"\w* \w a|strong="H3068"\w* traer desde la tierra de \w Canaán|strong="H3667"\w*. ¿Cómo, pues, robaríamos \w plata|strong="H3701"\w* u \w oro|strong="H2091"\w* de la \w casa|strong="H1004"\w* de tu \tl ʼadón\tl*?  
\v 9 Aquel de tus esclavos en quien \w sea|strong="H1961"\w* hallada \w la|strong="H1571"\w* copa, \w que|strong="H1571"\w* \w muera|strong="H4191"\w*, \w y|strong="H1571"\w* nosotros \w también|strong="H1571"\w* \w seremos|strong="H1961"\w* esclavos de \w mi|strong="H1961"\w* \tl ʼadón\tl*.   
\p
\v 10 \w Y|strong="H3068"\w* \w él|strong="H1931"\w* dijo: \w Sea|strong="H1961"\w* \w ahora|strong="H6258"\w* \w conforme|strong="H1931"\w* \w a|strong="H3068"\w* \w sus|strong="H1931"\w* \w palabras|strong="H1697"\w*. \w Aquél|strong="H1931"\w* \w en|strong="H5355"\w* \w cuyo|strong="H1931"\w* poder \w se|strong="H1961"\w* \w halle|strong="H4672"\w* \w será|strong="H1961"\w* \w mi|strong="H1961"\w* esclavo, \w y|strong="H1571"\w* ustedes \w serán|strong="H1961"\w* inocentes.   
\p
\v 11 Se apresuraron \w a|strong="H3068"\w* bajar cada uno su saco \w a|strong="H3068"\w* tierra. Cada cual \w abrió|strong="H6605"\w* su saco.  
\v 12 Él \w comenzó|strong="H2490"\w* \w a|strong="H3068"\w* registrar desde el \w mayor|strong="H1419"\w* y terminó con el \w menor|strong="H6996"\w*, y la copa fue hallada en el saco de \w Benjamín|strong="H1144"\w*.  
\v 13 \w Entonces|strong="H7725"\w* \w ellos|strong="H5921"\w* \w rasgaron|strong="H7167"\w* sus \w ropas|strong="H8071"\w*, \w y|strong="H5921"\w* cada uno cargó su \w asno|strong="H2543"\w* \w y|strong="H5921"\w* regresaron \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w*.   
\p
\v 14 \w Judá|strong="H3063"\w* llegó con \w sus|strong="H1931"\w* hermanos \w a|strong="H3068"\w* \w la|strong="H1931"\w* \w casa|strong="H1004"\w* \w de|strong="H6440"\w* \w José|strong="H3130"\w*. \w Él|strong="H1931"\w* \w estaba|strong="H1004"\w* \w aún|strong="H5750"\w* \w allí|strong="H8033"\w*, y \w cayeron|strong="H5307"\w* \w a|strong="H3068"\w* tierra \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w él|strong="H1931"\w*.  
\v 15 \w José|strong="H3130"\w* les preguntó: ¿\w Qué|strong="H3588"\w* acción \w es|strong="H2088"\w* \w esta|strong="H2088"\w* \w que|strong="H3588"\w* realizaron? ¿\w No|strong="H3808"\w* \w saben|strong="H3045"\w* \w que|strong="H3588"\w* un hombre \w como|strong="H4100"\w* \w yo|strong="H3588"\w* puede \w en|strong="H3588"\w* verdad \w adivinar|strong="H5172"\w*?   
\p
\v 16 \w Entonces|strong="H1571"\w* \w Judá|strong="H3063"\w* contestó: ¿\w Qué|strong="H4100"\w* diremos \w a|strong="H3068"\w* nuestro \tl ʼadón\tl*? ¿\w Qué|strong="H4100"\w* \w hablaremos|strong="H1696"\w*? ¿\w Cómo|strong="H4100"\w* \w nos|strong="H4100"\w* justificaremos? \nd ʼElohim\nd* \w descubrió|strong="H4672"\w* \w la|strong="H1571"\w* \w iniquidad|strong="H5771"\w* de tus esclavos. \w Aquí|strong="H2005"\w* estamos. Somos esclavos de mi \tl ʼadón\tl*, nosotros \w y|strong="H1571"\w* \w también|strong="H1571"\w* aquél en cuyo saco \w fue|strong="H3063"\w* hallada \w la|strong="H1571"\w* copa.   
\p
\v 17 Pero \w él|strong="H1931"\w* dijo: \w Lejos|strong="H2486"\w* de \w mí|strong="H1961"\w* \w hacer|strong="H6213"\w* \w esto|strong="H2063"\w*. \w El|strong="H1931"\w* hombre en \w cuyo|strong="H1931"\w* \w saco|strong="H5927"\w* \w fue|strong="H1961"\w* hallada \w la|strong="H1931"\w* copa \w será|strong="H1961"\w* \w mi|strong="H1961"\w* esclavo. Ustedes suban en \w paz|strong="H7965"\w* \w a|strong="H3068"\w* \w su|strong="H1931"\w* padre.   
\p
\v 18 \w Entonces|strong="H3588"\w* \w Judá|strong="H3063"\w* se \w acercó|strong="H5066"\w* \w a|strong="H3068"\w* \w él|strong="H3588"\w* \w y|strong="H3588"\w* le \w dijo|strong="H1696"\w*: ¡Ay, \tl ʼadón\tl* mío! \w Te|strong="H3588"\w* \w ruego|strong="H4994"\w* \w que|strong="H3588"\w* permitas \w que|strong="H3588"\w* tu esclavo \w hable|strong="H1696"\w* una \w palabra|strong="H1697"\w* \w a|strong="H3068"\w* oídos \w de|strong="H3588"\w* \w mi|strong="H4994"\w* \tl ʼadón\tl*. \w No|strong="H3588"\w* se encienda tu ira contra tu esclavo, \w porque|strong="H3588"\w* eres igual \w a|strong="H3068"\w* \w Faraón|strong="H6547"\w*.  
\v 19 Mi \tl ʼadón\tl* \w preguntó|strong="H7592"\w* \w a|strong="H3068"\w* sus esclavos: ¿\w Tienen|strong="H3426"\w* padre \w o|strong="H3068"\w* hermano?  
\v 20 \w Nosotros|strong="H1931"\w* dijimos \w a|strong="H3068"\w* nuestro \tl ʼadón\tl*: \w Tenemos|strong="H3426"\w* un padre \w anciano|strong="H2205"\w* y un joven \w menor|strong="H6996"\w* \w que|strong="H1931"\w* \w le|strong="H1931"\w* nació en \w su|strong="H1931"\w* vejez. \w Su|strong="H1931"\w* hermano \w murió|strong="H4191"\w*. \w Solo|strong="H1931"\w* \w él|strong="H1931"\w* \w quedó|strong="H3498"\w* de \w su|strong="H1931"\w* madre, y \w su|strong="H1931"\w* padre \w lo|strong="H1931"\w* ama.   
\p
\v 21 Dijiste \w a|strong="H3068"\w* tus esclavos: Tráiganmelo \w para|strong="H5921"\w* \w que|strong="H5921"\w* \w lo|strong="H5921"\w* vea.   
\p
\v 22 Entonces nosotros dijimos \w a|strong="H3068"\w* nuestro \tl ʼadón\tl*: El joven \w no|strong="H3808"\w* \w puede|strong="H3201"\w* abandonar \w a|strong="H3068"\w* su padre, \w porque|strong="H3808"\w* \w si|strong="H3808"\w* \w lo|strong="H3808"\w* abandona, su padre muere.   
\p
\v 23 Dijiste \w a|strong="H3068"\w* tus esclavos: \w A|strong="H3068"\w* menos \w que|strong="H3808"\w* su hermano \w menor|strong="H6996"\w* baje con ustedes, \w no|strong="H3808"\w* \w volverán|strong="H3254"\w* \w a|strong="H3068"\w* \w ver|strong="H7200"\w* mi \w rostro|strong="H6440"\w*.   
\p
\v 24 \w Aconteció|strong="H1961"\w* \w que|strong="H3588"\w* \w cuando|strong="H3588"\w* llegamos \w a|strong="H3068"\w* tu esclavo, nuestro padre, le referimos las \w palabras|strong="H1697"\w* \w de|strong="H3588"\w* \w mi|strong="H1961"\w* \tl ʼadón\tl*.  
\v 25 Nuestro padre dijo: \w Vuelvan|strong="H7725"\w* \w a|strong="H3068"\w* comprar un \w poco|strong="H4592"\w* de alimento para nosotros.  
\v 26 \w Pero|strong="H3588"\w* nosotros dijimos: \w No|strong="H3808"\w* \w podemos|strong="H3201"\w* bajar. \w Si|strong="H3588"\w* nuestro hermano \w menor|strong="H6996"\w* \w va|strong="H3068"\w* \w con|strong="H3588"\w* nosotros, bajaremos, \w porque|strong="H3588"\w* \w no|strong="H3808"\w* \w podremos|strong="H3201"\w* \w ver|strong="H7200"\w* \w el|strong="H3588"\w* \w rostro|strong="H6440"\w* \w de|strong="H3588"\w* aquel hombre \w si|strong="H3588"\w* \w no|strong="H3808"\w* \w está|strong="H3426"\w* \w con|strong="H3588"\w* nosotros nuestro hermano \w menor|strong="H6996"\w*.   
\p
\v 27 \w Entonces|strong="H3588"\w* tu esclavo, mi padre, nos dijo: Ustedes mismos \w saben|strong="H3045"\w* \w que|strong="H3588"\w* mi esposa \w me|strong="H3588"\w* dio \w a|strong="H3068"\w* luz \w dos|strong="H8147"\w*.  
\v 28 El uno \w salió|strong="H3318"\w* \w de|strong="H5704"\w* mi lado, \w y|strong="H5704"\w* dije: Ciertamente \w fue|strong="H3808"\w* destrozado. \w Hasta|strong="H5704"\w* \w ahora|strong="H2008"\w* \w no|strong="H3808"\w* \w lo|strong="H3808"\w* volví \w a|strong="H3068"\w* \w ver|strong="H7200"\w*.  
\v 29 \w Y|strong="H3068"\w* \w si|strong="H1571"\w* toman \w también|strong="H1571"\w* \w a|strong="H3068"\w* \w éste|strong="H2088"\w* \w de|strong="H6440"\w* mi \w presencia|strong="H6440"\w* \w y|strong="H1571"\w* \w le|strong="H5973"\w* sucede alguna desgracia, harán descender mis canas \w con|strong="H5973"\w* dolor al Seol.   
\p
\v 30 \w Y|strong="H3068"\w* \w ahora|strong="H6258"\w*, \w cuando|strong="H5650"\w* \w yo|strong="H5315"\w* llegue ante tu esclavo, \w mi|strong="H5315"\w* padre, y el joven no esté con nosotros, como su \w vida|strong="H5315"\w* está ligada \w a|strong="H3068"\w* la \w vida|strong="H5315"\w* de él,  
\v 31 \w sucederá|strong="H1961"\w* \w que|strong="H3588"\w* \w cuando|strong="H3588"\w* \w vea|strong="H7200"\w* \w que|strong="H3588"\w* \w el|strong="H3588"\w* joven \w no|strong="H3588"\w* \w está|strong="H1961"\w*, \w morirá|strong="H4191"\w*, \w y|strong="H3588"\w* tus esclavos habrán \w hecho|strong="H1961"\w* descender \w con|strong="H3588"\w* \w dolor|strong="H3015"\w* al Seol las canas \w de|strong="H3588"\w* tu esclavo, nuestro padre.  
\v 32 \w Porque|strong="H3588"\w* \w yo|strong="H3588"\w*, tu esclavo, quedé \w como|strong="H3588"\w* fiador \w del|strong="H5973"\w* joven ante mi padre, \w y|strong="H3588"\w* dije: \w Si|strong="H3588"\w* \w no|strong="H3808"\w* \w te|strong="H3588"\w* \w lo|strong="H3808"\w* traigo, \w entonces|strong="H3117"\w* \w yo|strong="H3588"\w* \w seré|strong="H3808"\w* culpable ante mi padre \w para|strong="H3588"\w* \w siempre|strong="H3605"\w*.   
\p
\v 33 \w Por|strong="H8478"\w* tanto, \w te|strong="H5973"\w* \w ruego|strong="H4994"\w* \w ahora|strong="H6258"\w* \w que|strong="H6258"\w* tu esclavo \w quede|strong="H3427"\w* \w como|strong="H5973"\w* esclavo \w de|strong="H8478"\w* \w mi|strong="H4994"\w* \tl ʼadón\tl* \w en|strong="H5973"\w* \w lugar|strong="H8478"\w* \w del|strong="H5973"\w* joven, y \w que|strong="H6258"\w* \w el|strong="H5973"\w* joven \w suba|strong="H5927"\w* \w con|strong="H5973"\w* sus hermanos.  
\v 34 \w Porque|strong="H3588"\w* ¿\w cómo|strong="H3588"\w* \w iré|strong="H5927"\w* \w yo|strong="H3588"\w* \w a|strong="H3068"\w* mi padre \w si|strong="H3588"\w* \w el|strong="H3588"\w* joven \w no|strong="H6435"\w* está conmigo? ¡\w No|strong="H6435"\w* \w vea|strong="H7200"\w* \w yo|strong="H3588"\w* \w el|strong="H3588"\w* \w mal|strong="H7451"\w* \w que|strong="H3588"\w* le \w vendrá|strong="H5927"\w* \w a|strong="H3068"\w* mi padre!   
\c 45  
\s1 José se da a conocer a sus hermanos  
\p
\v 1 \w José|strong="H3130"\w* ya \w no|strong="H3808"\w* \w podía|strong="H3201"\w* contenerse ante \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w que|strong="H3808"\w* \w estaban|strong="H5975"\w* \w a|strong="H3068"\w* su lado \w y|strong="H5921"\w* exclamó: ¡Saquen \w de|strong="H5921"\w* \w mi|strong="H5921"\w* presencia \w a|strong="H3068"\w* \w todos|strong="H3605"\w*! \w Nadie|strong="H3808"\w* \w quedó|strong="H5975"\w* \w con|strong="H5921"\w* \w él|strong="H5921"\w* cuando \w José|strong="H3130"\w* \w se|strong="H3045"\w* dio \w a|strong="H3068"\w* conocer \w a|strong="H3068"\w* sus hermanos.  
\v 2 Entonces alzó su \w voz|strong="H6963"\w* con \w llanto|strong="H1065"\w*. Lo \w oyeron|strong="H8085"\w* los \w egipcios|strong="H4713"\w* y lo \w oyó|strong="H8085"\w* la \w casa|strong="H1004"\w* \w de|strong="H5414"\w* \w Faraón|strong="H6547"\w*.   
\p
\v 3 \w José|strong="H3130"\w* dijo \w a|strong="H3068"\w* sus hermanos: ¡\w Yo|strong="H3588"\w* soy \w José|strong="H3130"\w*! ¿\w Vive|strong="H2416"\w* \w aún|strong="H5750"\w* \w mi|strong="H6030"\w* padre? Sus hermanos \w no|strong="H3808"\w* \w pudieron|strong="H3201"\w* \w responderle|strong="H6030"\w*, \w porque|strong="H3588"\w* estaban turbados \w delante|strong="H6440"\w* \w de|strong="H3588"\w* \w él|strong="H3588"\w*.   
\p
\v 4 Entonces \w José|strong="H3130"\w* dijo \w a|strong="H3068"\w* sus hermanos: ¡Acérquense \w a|strong="H3068"\w* \w mí|strong="H4994"\w*, les \w ruego|strong="H4994"\w*! Ellos se acercaron, y \w él|strong="H5066"\w* dijo: \w Yo|strong="H4994"\w* soy su hermano \w José|strong="H3130"\w*, \w a|strong="H3068"\w* quien ustedes \w vendieron|strong="H4376"\w* para \w Egipto|strong="H4714"\w*.  
\v 5 \w Ahora|strong="H6258"\w* \w pues|strong="H3588"\w*, \w no|strong="H3588"\w* se entristezcan \w ni|strong="H6258"\w* les pese \w por|strong="H3588"\w* haberme vendido \w acá|strong="H2008"\w*, \w pues|strong="H3588"\w* \nd ʼElohim\nd* \w me|strong="H3588"\w* \w envió|strong="H7971"\w* \w delante|strong="H6440"\w* \w de|strong="H3588"\w* ustedes \w para|strong="H3588"\w* preservar \w la|strong="H3588"\w* \w vida|strong="H4241"\w*.  
\v 6 \w Porque|strong="H3588"\w* \w ya|strong="H2088"\w* hubo \w dos|strong="H8141"\w* \w años|strong="H8141"\w* \w de|strong="H3588"\w* hambruna \w en|strong="H3588"\w* \w la|strong="H3588"\w* tierra, \w y|strong="H3588"\w* \w aún|strong="H5750"\w* quedan \w cinco|strong="H2568"\w* \w años|strong="H8141"\w* \w en|strong="H3588"\w* \w los|strong="H3588"\w* cuales \w no|strong="H3588"\w* habrá siembra ni cosecha.  
\v 7 \w Por|strong="H6440"\w* eso \nd ʼElohim\nd* me \w envió|strong="H7971"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ustedes con el propósito \w de|strong="H6440"\w* preservar un remanente en la tierra para ustedes y mantenerlos vivos \w por|strong="H6440"\w* medio \w de|strong="H6440"\w* una \w gran|strong="H1419"\w* liberación.   
\p
\v 8 \w Así|strong="H3588"\w* \w que|strong="H3588"\w*, \w no|strong="H3808"\w* \w me|strong="H3588"\w* \w enviaron|strong="H7971"\w* ustedes \w acá|strong="H2008"\w*, \w sino|strong="H3588"\w* \nd ʼElohim\nd*. \w Él|strong="H3588"\w* \w me|strong="H3588"\w* colocó \w como|strong="H3588"\w* un padre \w para|strong="H3588"\w* \w Faraón|strong="H6547"\w*, \tl ʼadón\tl* \w de|strong="H3588"\w* \w toda|strong="H3605"\w* \w su|strong="H3588"\w* \w casa|strong="H1004"\w* \w y|strong="H3588"\w* gobernador \w en|strong="H3588"\w* \w toda|strong="H3605"\w* \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* \w Egipto|strong="H4714"\w*.   
\p
\v 9 Dense prisa, suban hasta mi padre \w y|strong="H3541"\w* díganle: \w Así|strong="H3541"\w* dice tu \w hijo|strong="H1121"\w* \w José|strong="H3130"\w*: \nd ʼElohim\nd* \w me|strong="H3541"\w* estableció como \tl ʼadón\tl* \w de|strong="H1121"\w* \w todo|strong="H3605"\w* \w Egipto|strong="H4714"\w*. \w Desciende|strong="H3381"\w* \w a|strong="H3068"\w* mí, no te detengas.  
\v 10 Vivirás en \w la|strong="H3605"\w* tierra \w de|strong="H1121"\w* Gosén \w y|strong="H1241"\w* \w estarás|strong="H1961"\w* \w cerca|strong="H7138"\w* \w de|strong="H1121"\w* \w mí|strong="H1961"\w*, tú \w y|strong="H1241"\w* tus \w hijos|strong="H1121"\w*, \w y|strong="H1241"\w* \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* tus \w hijos|strong="H1121"\w*, tus rebaños \w y|strong="H1241"\w* tus manadas \w de|strong="H1121"\w* \w ganado|strong="H6629"\w* \w vacuno|strong="H1241"\w* \w y|strong="H1241"\w* \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w que|strong="H1121"\w* tienes.  
\v 11 \w Allí|strong="H8033"\w* \w te|strong="H3588"\w* sustentaré, \w pues|strong="H3588"\w* \w aún|strong="H5750"\w* quedan \w cinco|strong="H2568"\w* \w años|strong="H8141"\w* \w de|strong="H3588"\w* hambruna, \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w no|strong="H6435"\w* lleguen \w a|strong="H3068"\w* \w la|strong="H3588"\w* pobreza, tú \w y|strong="H3588"\w* tu \w casa|strong="H1004"\w*, \w y|strong="H3588"\w* \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w que|strong="H3588"\w* \w tienes|strong="H5750"\w*.   
\p
\v 12 \w Por|strong="H3588"\w* \w cierto|strong="H3588"\w*, \w los|strong="H3588"\w* \w ojos|strong="H5869"\w* \w de|strong="H3588"\w* ustedes pueden \w ver|strong="H7200"\w*, \w y|strong="H3588"\w* \w los|strong="H3588"\w* \w ojos|strong="H5869"\w* \w de|strong="H3588"\w* \w mi|strong="H2009"\w* hermano \w Benjamín|strong="H1144"\w*, \w que|strong="H3588"\w* \w es|strong="H3588"\w* \w mi|strong="H2009"\w* \w boca|strong="H6310"\w* \w la|strong="H3588"\w* \w que|strong="H3588"\w* les \w habla|strong="H1696"\w*.  
\v 13 Tienen \w que|strong="H3605"\w* informar \w a|strong="H3068"\w* mi padre de \w todo|strong="H3605"\w* mi esplendor en \w Egipto|strong="H4714"\w* \w y|strong="H3519"\w* \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w que|strong="H3605"\w* \w vieron|strong="H7200"\w*. Tienen \w que|strong="H3605"\w* darse prisa \w y|strong="H3519"\w* traigan \w a|strong="H3068"\w* mi padre \w acá|strong="H2008"\w*.   
\p
\v 14 Entonces \w se|strong="H5921"\w* \w echó|strong="H5307"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w cuello|strong="H6677"\w* \w de|strong="H5921"\w* su hermano \w Benjamín|strong="H1144"\w*, \w y|strong="H5921"\w* \w lloró|strong="H1058"\w*, \w y|strong="H5921"\w* \w Benjamín|strong="H1144"\w* \w lloró|strong="H1058"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w cuello|strong="H6677"\w* \w de|strong="H5921"\w* \w él|strong="H5921"\w*.  
\v 15 \w Besó|strong="H5401"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* sus hermanos \w y|strong="H5921"\w* \w lloró|strong="H1058"\w* \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w*. \w Después|strong="H5921"\w* sus hermanos \w hablaron|strong="H1696"\w* \w con|strong="H5921"\w* \w él|strong="H5921"\w*.   
\p
\v 16 En el palacio \w de|strong="H5869"\w* \w Faraón|strong="H6547"\w* una \w voz|strong="H6963"\w* fue oída que decía: Vinieron los hermanos \w de|strong="H5869"\w* \w José|strong="H3130"\w*. \w Y|strong="H3068"\w* \add esto\add* \w agradó|strong="H3190"\w* \w a|strong="H3068"\w* \w Faraón|strong="H6547"\w* y \w a|strong="H3068"\w* sus esclavos.  
\v 17 \w Faraón|strong="H6547"\w* dijo \w a|strong="H3068"\w* \w José|strong="H3130"\w*: Dí \w a|strong="H3068"\w* tus hermanos: \w Hagan|strong="H6213"\w* \w esto|strong="H2063"\w*. Carguen sus \w bestias|strong="H1165"\w* y \w vayan|strong="H3212"\w*. Entren \w en|strong="H3212"\w* \w la|strong="H2063"\w* tierra de \w Canaán|strong="H3667"\w*.  
\v 18 Luego \w tomen|strong="H3947"\w* \w a|strong="H3068"\w* su padre y \w a|strong="H3068"\w* sus \w familias|strong="H1004"\w*, y vengan \w a|strong="H3068"\w* mí. Yo les \w daré|strong="H5414"\w* lo bueno \w de|strong="H5414"\w* la tierra \w de|strong="H5414"\w* \w Egipto|strong="H4714"\w*, y comerán \w de|strong="H5414"\w* la abundancia del país.   
\p
\v 19 Mándales también: \w Tomen|strong="H3947"\w* carrozas de \w la|strong="H2063"\w* tierra de \w Egipto|strong="H4714"\w* para sus pequeños y sus esposas. \w Traigan|strong="H3947"\w* \w a|strong="H3068"\w* su padre y vengan.  
\v 20 \w Y|strong="H3068"\w* \w no|strong="H3588"\w* \w se|strong="H1931"\w* preocupen \w por|strong="H5921"\w* \w sus|strong="H1931"\w* \w enseres|strong="H3627"\w*, \w porque|strong="H3588"\w* \w lo|strong="H1931"\w* mejor \w de|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H1931"\w* tierra \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w* \w es|strong="H1931"\w* \w de|strong="H5921"\w* ustedes.   
\p
\v 21 \w Así|strong="H3651"\w* \w lo|strong="H5921"\w* \w hicieron|strong="H6213"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*. \w José|strong="H3130"\w* \w les|strong="H5921"\w* \w dio|strong="H5414"\w* carrozas \w conforme|strong="H6310"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* orden \w de|strong="H5921"\w* \w Faraón|strong="H6547"\w* \w y|strong="H5921"\w* \w les|strong="H5921"\w* \w dio|strong="H5414"\w* provisiones \w para|strong="H5921"\w* \w el|strong="H5921"\w* \w camino|strong="H1870"\w*.  
\v 22 \w A|strong="H3068"\w* \w todos|strong="H3605"\w* \w ellos|strong="H3605"\w* les \w dio|strong="H5414"\w* \w mudas|strong="H2487"\w* \w de|strong="H2568"\w* \w ropa|strong="H8071"\w* y \w a|strong="H3068"\w* \w Benjamín|strong="H1144"\w* le \w dio|strong="H5414"\w* 300 piezas \w de|strong="H2568"\w* \w plata|strong="H3701"\w* y \w cinco|strong="H2568"\w* \w mudas|strong="H2487"\w* \w de|strong="H2568"\w* \w ropa|strong="H8071"\w*.  
\v 23 \w A|strong="H3068"\w* su padre \w envió|strong="H7971"\w* \w diez|strong="H6235"\w* \w asnos|strong="H2543"\w* \w cargados|strong="H5375"\w* de lo mejor de \w Egipto|strong="H4714"\w*, y \w diez|strong="H6235"\w* asnas \w cargadas|strong="H5375"\w* de \w trigo|strong="H1250"\w*, \w pan|strong="H3899"\w* y víveres para el \w viaje|strong="H1870"\w* de su padre.  
\v 24 \w Despidió|strong="H7971"\w* \w a|strong="H3068"\w* sus hermanos y salieron. \w Y|strong="H3068"\w* les dijo: \w No|strong="H1870"\w* discutan \w por|strong="H1870"\w* el \w camino|strong="H1870"\w*.   
\p
\v 25 \w Subieron|strong="H5927"\w* de \w Egipto|strong="H4714"\w* y llegaron \w a|strong="H3068"\w* la tierra de \w Canaán|strong="H3667"\w*, \w a|strong="H3068"\w* su padre \w Jacob|strong="H3290"\w*.   
\p
\v 26 \w Le|strong="H1931"\w* dieron las noticias \w y|strong="H3588"\w* dijeron: ¡\w José|strong="H3130"\w* \w aún|strong="H5750"\w* \w vive|strong="H2416"\w* \w y|strong="H3588"\w* \w es|strong="H1931"\w* gobernador \w en|strong="H3588"\w* \w toda|strong="H3605"\w* \w la|strong="H1931"\w* tierra \w de|strong="H3588"\w* \w Egipto|strong="H4714"\w*! \w Pero|strong="H3588"\w* \add Jacob\add* \w estaba|strong="H2416"\w* afligido, \w pues|strong="H3588"\w* \w no|strong="H3808"\w* les creía.  
\v 27 Pero \w ellos|strong="H3605"\w* le \w dijeron|strong="H1697"\w* \w todas|strong="H3605"\w* las \w palabras|strong="H1697"\w* \w que|strong="H1697"\w* \w José|strong="H3130"\w* les \w dijo|strong="H1696"\w*, y al \w ver|strong="H7200"\w* las carrozas \w que|strong="H1697"\w* \w José|strong="H3130"\w* \w envió|strong="H7971"\w* para \w llevarlo|strong="H5375"\w*, \w el|strong="H3605"\w* \w espíritu|strong="H7307"\w* \w de|strong="H1697"\w* su padre \w Jacob|strong="H3290"\w* \w revivió|strong="H2421"\w*.   
\p
\v 28 Entonces \w Israel|strong="H3478"\w* dijo: ¡\w Basta|strong="H7227"\w*! ¡Mi \w hijo|strong="H1121"\w* \w José|strong="H3130"\w* \w aún|strong="H5750"\w* \w vive|strong="H2416"\w*! \w Iré|strong="H3212"\w* y lo \w veré|strong="H7200"\w* \w antes|strong="H2962"\w* \w que|strong="H1121"\w* yo \w muera|strong="H4191"\w*.   
\c 46  
\s1 Israel en Egipto  
\p
\v 1 \w Israel|strong="H3478"\w* salió con \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w que|strong="H3605"\w* tenía. \w Fue|strong="H5265"\w* \w a|strong="H3068"\w* Beerseba y \w ofreció|strong="H2076"\w* \w sacrificios|strong="H2077"\w* al \nd ʼElohim\nd* de su padre \w Isaac|strong="H3327"\w*.   
\p
\v 2 \w Y|strong="H3068"\w* \nd ʼElohim\nd* habló \w a|strong="H3068"\w* \w Israel|strong="H3478"\w* en \w visiones|strong="H4759"\w* de \w noche|strong="H3915"\w*: \wj ¡\+w Jacob|strong="H3290"\+w*! ¡\+w Jacob|strong="H3290"\+w*!\wj*  
\p \w Y|strong="H3068"\w* él respondió: \w Aquí|strong="H2009"\w* estoy.   
\p
\v 3 \w Entonces|strong="H3588"\w* le dijo: \wj \+w Yo|strong="H3588"\+w* soy \+nd \+w ʼEL|strong="H3588"\+w*\+nd*, \+w el|strong="H3588"\+w* \+nd ʼElohim\+nd* \+w de|strong="H3588"\+w* tu padre. \+w No|strong="H3588"\+w* \+w temas|strong="H3372"\+w* bajar \+w a|strong="H3068"\+w* \+w Egipto|strong="H4714"\+w*, \+w porque|strong="H3588"\+w* \+w allí|strong="H8033"\+w* \+w te|strong="H3588"\+w* convertiré \+w en|strong="H3588"\+w* una \+w gran|strong="H1419"\+w* \+w nación|strong="H1471"\+w*.\wj*  
\v 4 \wj Yo \+w descenderé|strong="H3381"\+w* \+w contigo|strong="H5973"\+w* \+w a|strong="H3068"\+w* \+w Egipto|strong="H4714"\+w* \+w y|strong="H1571"\+w* \+w ciertamente|strong="H1571"\+w* Yo \+w también|strong="H1571"\+w* \+w te|strong="H5869"\+w* haré \+w subir|strong="H5927"\+w*, \+w y|strong="H1571"\+w* \+w la|strong="H5921"\+w* \+w mano|strong="H3027"\+w* \+w de|strong="H5921"\+w* \+w José|strong="H3130"\+w* cerrará tus \+w ojos|strong="H5869"\+w*.\wj*   
\p
\v 5 \w Jacob|strong="H3290"\w* \w de|strong="H1121"\w* Beerseba se \w levantó|strong="H5375"\w*, y \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* hicieron subir \w a|strong="H3068"\w* su padre \w Jacob|strong="H3290"\w*, \w a|strong="H3068"\w* sus pequeños y \w a|strong="H3068"\w* sus esposas en las carrozas \w que|strong="H1121"\w* \w Faraón|strong="H6547"\w* \w envió|strong="H7971"\w* para \w que|strong="H1121"\w* lo \w llevaran|strong="H5375"\w*.  
\v 6 También \w tomaron|strong="H3947"\w* sus \w ganados|strong="H4735"\w* y las pertenencias \w que|strong="H3605"\w* adquirieron en \w la|strong="H3605"\w* tierra de \w Canaán|strong="H3667"\w*. \w Jacob|strong="H3290"\w* y \w toda|strong="H3605"\w* su \w descendencia|strong="H2233"\w* fueron \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w*,  
\v 7 sus \w hijos|strong="H1121"\w* y \w nietos|strong="H1121"\w*, sus \w hijas|strong="H1323"\w* y nietas. Llevó consigo \w toda|strong="H3605"\w* su \w descendencia|strong="H2233"\w* \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w*.   
\p
