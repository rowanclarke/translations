\id PHM  
\h Pilemona 
\toc1 Pilemona 
\toc2 Pilemona 
\toc3 Pilemona 
\mt1 Pilemona  
\c 1  
\q1
\v 1 NA Paulo he pio no Iesu Kriato, a na Timoteo ka hoahanau, ia Pilemona i ko maua mea aloha, a me ka hoalawehana,   
\q1
\v 2 A ia Apia hoi i alohaia, a ia Arekipo i ko kakou hoakoa, a i ka ekalesia hoi iloko o kou hale:   
\q1
\v 3 Ia oukou ke aloha a me ka maluhia mai ke Akua mai o ko kakou Makua a me ka Haku o Iesu Kristo.   
\b  
\q1
\v 4 Ke hoomaikai mau aku nei au i ko'u Akua, e hoohiki mau ana ia oe ma ka'u pule ana,   
\q1
\v 5 I ko'u lohe ana'ku i kou aloha a me kou manaoio i ka Haku ia Iesu, a i ka poe haipule a pau;   
\q1
\v 6 I lilo ka hui ana mai o kou manaoio i mea ikaika e hooiaioia mai ai na mea maikai a pau iloko o oukou no Kristo Iesu.   
\q1
\v 7 No ka mea, he nui no ko makou olioli a me ka oluolu no kou aloha, no ka mea, ua hoohoihoiia ns naau o ka poe haipule e oe, e ka hoahanau.   
\b  
\q1
\v 8 Nolaila, oiai ua hiki no ia'u iloko o Kristo ke kauleo ikaika aku ia oe i ka mea e pono ai;   
\q1
\v 9 Aka hoi, no ke aloha, ke makemake nei no au e nonoi malie aku, owau no, o Paulo ka elemakule e noho nei, a he pio no hoi no Iesu Kristo;   
\q1
\v 10 Ke nonoi aku nei au ia oe no ka'u keiki a'u i hoohanau aku nei iloko o ko'u paa ana, no Onesimo:   
\q1
\v 11 Ka mea pono ole nou mamua, ano hoi he mea pono io no kaua:   
\q1
\v 12 Oia ka'u e hoihoi aku nei; nolaila e hookipa oe ia ia, oia hoi, o kou naau iho.   
\q1
\v 13 Ua makemake nae au e kaohi ia ia e noho pu me an, i hiki ia ia ke malama mai ia'u nou, i kuu paa ana no ka euanelio:   
\q1
\v 14 Aka, aole loa o'u manao e hana pela me kou ae ole mai; i like ole keia pono ou me he mea la i kaili wale ia aka, no ka naau mai.   
\q1
\v 15 No ka mea, ua hookaawaleia mai paha ia i ka wa pokole i lilo hou aku ia nou mau loa;   
\q1
\v 16 Aole me he kauwa la ma ia hope, aka, me he mea la e oi i ke kauwa, he hoahanau punahele, pela io ia'u, a he oiaio maoli no ia oe, ma ke kino, a maloko hoi o ka Haku.   
\q1
\v 17 A ina i manao mai oe ia'u he hoalawepu, e hookipa oe ia ia e like me ia'u uei.   
\q1
\v 18 A ina ua lawehala oia i kau, a ua aie paha, o kau ia e hooili mai ai maluna o'u;   
\q1
\v 19 Na'u na Paulo nei i kakau iho keia me ko'u lima ponoi, na'u ia e uku aku; aole nae me ka olelo aku ia oe, o oe iho no ka i aie ia oe iho na'u.   
\q1
\v 20 Oiaio hoi, e ka hoahanau, no'u kahi olioli ia oe iloko o ka Haku; e hoomaha mai oe i ko'u naau maloko o ka Haku.   
\b  
\q1
\v 21 No ka paulele aku i kou hoolohe ana mai, ua palapala aku au ia oe, me ka ike aku hoi e oi aku no kau hana ana mamua o ko'u olelo ana'ku.   
\q1
\v 22 Eia kekahi, e hoomakaukau e oe i wahi no'u e moe ai; no ka mea, ke manaolana nei au, no ka oukou pule ana e haawiia'ku ai au ia oukou.   
\b  
\q1
\v 23 Ke aloha aku nei ia oe o Epapera, o ko'u hoapio iloko o Kristo Iesu;   
\q1
\v 24 A o Mareko, a o Arisetareko, o Dema, o Luka hoi, o ko'u mau hoalawehana.   
\b  
\q1
\v 25 E alohaia mai ko oukou uhane e ko kakou Haku e Iesu Kristo. Amene.   