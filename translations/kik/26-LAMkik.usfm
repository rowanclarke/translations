\id LAM - Biblica® Open Kikuyu Holy Word of God 
\h Macakaya 
\toc1 Macakaya 
\toc2 Macakaya 
\toc3 Maca 
\mt1 MACAKAYA 
\c 1  
\q1  
\v 1 Hĩ! Kaĩ itũũra rĩu inene nĩrĩikarĩte rĩtiganĩirio, 
\q2 o rĩu rĩratũire rĩiyũrĩte andũ-ĩ! 
\q1 Kaĩ rĩĩkũhaana o ta mũtumia wa ndigwa, 
\q2 ũcio ũraarĩ mũnene gatagatĩ ka ndũrĩrĩ-ĩ! 
\q1 O we ũratũire arĩ mũthamaki-mũndũ-wa-nja ngʼongo-inĩ cia bũrũri-rĩ, 
\q2 rĩu atuĩkĩte ngombo. 
\b  
\q1  
\v 2 Ũtukũ araaraga akĩrĩra na ruo, 
\q2 maithori makanyũrũrũkĩra makai-inĩ make. 
\q1 Arĩa othe marendanĩte nake-rĩ, 
\q2 hatirĩ o na ũmwe wa kũmũhooreria. 
\q1 Arata ake othe nĩmamũkunyanĩire; 
\q2 othe matuĩkĩte thũ ciake. 
\b  
\q1  
\v 3 Thuutha wa thĩĩna na mawĩra maritũ, 
\q2 Juda nĩatwarĩtwo ithaamĩrio. 
\q1 Atũũraga gatagatĩ ka ndũrĩrĩ; 
\q2 agakĩaga handũ ha kũhurũka. 
\q1 Arĩa othe mamũingatithagia nĩmamũkinyĩrĩire 
\q2 arĩ hatĩka-inĩ ciake. 
\b  
\q1  
\v 4 Njĩra cia gũthiĩ Zayuni no macakaya, 
\q2 nĩ ũndũ gũtirĩ andũ mookaga ciathĩ ciake iria njathane. 
\q1 Matoonyero make mothe makirĩte ihooru, 
\q2 athĩnjĩri-Ngai ake no gũcaaya maracaaya, 
\q1 airĩtu ake no kũgirĩka, 
\q2 nake arĩ na ruo rũnene. 
\b  
\q1  
\v 5 Amuku ake matuĩkĩte nĩo mamwathaga; 
\q2 thũ ciake nĩcio igaacĩire. 
\q1 Jehova nĩamũrehithĩirie kĩeha 
\q2 nĩ ũndũ wa mehia make maingĩ. 
\q1 Ciana ciake itahĩtwo igatwarwo bũrũri ũngĩ, 
\q2 igatuĩka mĩgwate ya thũ. 
\b  
\q1  
\v 6 Mwarĩ wa Zayuni nĩehereirwo nĩ riiri wake. 
\q2 Anene ake mahaanĩte ta thwariga ciagĩte ũrĩithio; 
\q1 moorĩte matarĩ na hinya, 
\q2 moimĩtwo thuutha nĩ arĩa mamaingatithĩtie. 
\b  
\q1  
\v 7 Matukũ-inĩ ma thĩĩna na kũũrũũra gwake-rĩ, 
\q2 Jerusalemu aririkanaga igĩĩna ciothe 
\q2 iria ciarĩ ciake matukũ ma tene. 
\q1 Rĩrĩa andũ ake maagũire moko-inĩ ma thũ-rĩ, 
\q2 gũtiarĩ mũndũ o na ũmwe wa kũmũteithia. 
\q1 Thũ ciake ikĩmũrora, 
\q2 igĩthekerera mwanangĩko wake. 
\b  
\q1  
\v 8 Jerusalemu nĩehĩtie mũno, 
\q2 na nĩ ũndũ ũcio akanyiitwo nĩ thaahu. 
\q1 Arĩa othe maamũtĩĩte-rĩ, rĩu nĩmamũnyararĩte, 
\q2 nĩ ũndũ nĩmonete njaga yake; 
\q1 we mwene no gũcaaya aracaaya, 
\q2 na akamahutatĩra. 
\b  
\q1  
\v 9 Gĩko gĩake nĩkĩnyiitĩte nguo ciake; 
\q2 nake ndaigana gwĩcũũrania mũtũũrĩre wake wa thuutha. 
\q1 Kũgũa gwake kwarĩ gwa kũmakania; 
\q2 gũtiarĩ mũndũ o na ũmwe wa kũmũhooreria. 
\q1 “Wee Jehova, ta kĩone mathĩĩna makwa, 
\q2 nĩgũkorwo thũ yakwa nĩhootanĩte.” 
\b  
\q1  
\v 10 Thũ ĩyo nĩyegwatĩire 
\q2 igĩĩna-inĩ ciake ciothe; 
\q1 nake akĩĩonera ndũrĩrĩ iria itooĩ Ngai 
\q2 igĩtoonya handũ harĩa hake haamũre: 
\q1 o arĩa wee wathanĩte 
\q2 matikanatoonye kĩũngano-inĩ gĩaku.\f + \fr 1:10 \ft Andũ a ndũrĩrĩ matietĩkĩrĩtio gũtoonya hekarũ matikamĩthaahie (Ezek 44:7-9).\f* 
\b  
\q1  
\v 11 Andũ ake othe nĩgũcaaya maracaaya 
\q2 magĩetha gĩa kũrĩa; 
\q1 magagĩkũũrania igĩĩna ciao 
\q2 na irio nĩguo matũũre muoyo. 
\q1 “Wee Jehova, ta cũrania wone, 
\q2 nĩgũkorwo ndĩ mũmeneku.” 
\b  
\q1  
\v 12 “Atĩrĩrĩ, inyuĩ mũrahĩtũka, 
\q2 anga mũkuona ũndũ ũyũ ta ũtamũkoniĩ? 
\q1 Ta rorai muone. 
\q2 Nĩ kũrĩ thĩĩna ũiganaine na thĩĩna ũyũ wakwa, 
\q1 thĩĩna ũrĩa njigĩrĩirwo, 
\q2 o ũcio Jehova aandehithĩirie 
\q2 mũthenya wa marakara make mahiũ? 
\b  
\q1  
\v 13 “We aandũmĩire mwaki uumĩte igũrũ, 
\q2 akĩũikũrũkia, ũgĩtoonya nginya mahĩndĩ-inĩ makwa. 
\q1 Aambĩire magũrũ makwa wabu wa kũmatega, akĩĩhũndũra. 
\q2 Nake agĩtũma nyiitwo nĩ ihooru, ngĩkĩringĩka mũthenya wothe. 
\b  
\q1  
\v 14 “Mehia makwa mohanĩtio, magatuĩka icooki. 
\q2 Moko make mamogothanĩtie hamwe. 
\q1 Magagĩĩkĩrwo ngingo-inĩ yakwa, 
\q2 nake Mwathani agakĩĩniina hinya. 
\q1 Akaaneana moko-inĩ ma arĩa itangĩhota gwĩtiiria. 
\b  
\q1  
\v 15 “Mwathani nĩaregete 
\q2 njamba ciothe cia ita iria ndĩ nacio, 
\q1 akanjĩtĩra ita nĩguo rĩnjũkĩrĩre, 
\q2 rĩmemende aanake akwa. 
\q1 Kĩhihĩro-inĩ gĩake kĩa ndibei-rĩ, 
\q2 Mwathani nĩarangĩrĩirie 
\q1 Mwarĩ Gathirange wa Juda. 
\b  
\q1  
\v 16 “Maũndũ macio nĩmo maratũma ndĩre, 
\q2 namo maitho makwa makanyũrũrũkia maithori. 
\q1 Gũtirĩ mũndũ ũrĩ hakuhĩ wa kũũhooreria, 
\q2 gũtirĩ mũndũ wa kũnyũmĩrĩria ngoro. 
\q1 Ciana ciakwa ituĩkĩte cia kũnyamarĩka 
\q2 tondũ thũ nĩyo ĩhootanĩte.” 
\b  
\q1  
\v 17 Zayuni atambũrũkĩtie moko, 
\q2 no gũtirĩ mũndũ wa kũmũhooreria. 
\q1 Jehova nĩathanĩte ũhoro wa Jakubu 
\q2 atĩ arĩa mariganĩtie nake matuĩke thũ ciake; 
\q1 Jerusalemu nĩatuĩkĩte 
\q2 kĩndũ kĩrĩ thaahu gatagatĩ-inĩ kao. 
\b  
\q1  
\v 18 “Jehova nĩ mũthingu, 
\q2 no rĩrĩ, nĩndaremeire watho wake. 
\q1 Thikĩrĩriai, inyuĩ andũ othe, 
\q2 na mũrore gũthĩĩnĩka gwakwa. 
\q1 Aanake akwa na airĩtu akwa 
\q2 nĩmatahĩtwo magatwarwo thĩ ngʼeni. 
\b  
\q1  
\v 19 “Ndaatũmanĩire arĩa twarĩ ngwatanĩro, 
\q2 no-o makĩngunyanĩra. 
\q1 Athĩnjĩri-Ngai akwa, na athuuri akwa 
\q2 marakuĩrĩire itũũra-inĩ rĩu inene, 
\q1 o magĩcaragia irio cia kũmatũũria muoyo. 
\b  
\q1  
\v 20 “Wee Jehova, ta rora wone ũrĩa ndĩ hatĩka-inĩ! 
\q2 Nĩndĩratangĩka thĩinĩ wakwa, 
\q1 na ngathĩĩnĩka thĩinĩ wa ngoro yakwa, 
\q2 nĩ ũndũ ngoretwo ndĩ mũremi mũno. 
\q1 Na kũu nja, hiũ cia njora nĩirooraga andũ, 
\q2 nakuo thĩinĩ no gĩkuũ kũrĩ. 
\b  
\q1  
\v 21 “Andũ nĩmaiguĩte mũcaayo wakwa, 
\q2 no gũtirĩ mũndũ o na ũmwe wa kũũhooreria. 
\q1 Thũ ciakwa ciothe nĩciguĩte ũhoro wa hatĩka ciakwa, 
\q2 nacio igakena nĩ ũndũ wa ũguo wĩkĩte. 
\q1 Nawe gĩkinyie mũthenya ũrĩa wanĩrĩire 
\q2 nĩguo nao mahaane ta niĩ. 
\b  
\q1  
\v 22 “Waganu wao wothe nĩũgĩkinye mbere yaku, 
\q2 nawe ũmeke o ta ũrĩa ũnjĩkĩte 
\q1 nĩ ũndũ wa mehia makwa mothe. 
\q1 Mĩcaayo yakwa nĩ mĩingĩ, 
\q2 nayo ngoro yakwa nĩĩringĩkĩte.” 
\c 2  
\q1  
\v 1 Hĩ! Kaĩ Mwathani nĩakĩhumbĩrĩte Mwarĩ wa Zayuni 
\q2 na itu rĩa marakara make-ĩ! 
\q1 Nĩatungumanĩtie riiri wa Isiraeli, 
\q2 akaũharũrũkia kuuma igũrũ nginya thĩ; 
\q1 ndaaririkanire gaturwa ka magũrũ make, 
\q2 mũthenya ũrĩa aarakarire. 
\b  
\q1  
\v 2 Mwathani-rĩ, nĩameretie 
\q2 itũũro ciothe cia Jakubu atarĩ na tha; 
\q1 nĩamomorete ciĩhitho iria nũmu 
\q2 cia Mwarĩ wa Juda arĩ na marakara. 
\q1 Nĩagũithĩtie ũthamaki wa Mwarĩ wa Juda, 
\q2 na akagũithia anene ake, akamaconorithia. 
\b  
\q1  
\v 3 Rũhĩa rwa Isiraeli ruothe 
\q2 arũrengete arĩ na marakara mahiũ. 
\q1 Nĩeheretie guoko gwake kwa ũrĩo, 
\q2 gũkameeherera o rĩrĩa thũ ciamakuhĩrĩria. 
\q1 Nĩgũcina acinĩte Jakubu ta mwaki ũkũrĩrĩmbũka, 
\q2 ũrĩa ũcinaga kĩrĩa gĩothe kĩrĩ hakuhĩ naguo. 
\b  
\q1  
\v 4 Ageetete ũta wake o ta thũ; 
\q2 guoko gwake kwa ũrĩo nĩ kwĩhaarĩirie. 
\q1 Arĩa othe maatũire makenagia maitho-rĩ, 
\q2 amooragĩte o ta marĩ thũ; 
\q1 hema ya Mwarĩ wa Zayuni 
\q2 amĩitĩrĩirie mangʼũrĩ make mahaana ta mwaki. 
\b  
\q1  
\v 5 Mwathani-rĩ, atuĩkĩte ta thũ; 
\q2 nĩameretie Isiraeli. 
\q1 Nĩameretie nyũmba ciake ciothe cia ũthamaki, 
\q2 na akaananga ciĩhitho ciake iria nũmu. 
\q1 Nĩaingĩhĩirie Mwarĩ wa Juda 
\q2 gũcakaya na kũgirĩka. 
\b  
\q1  
\v 6 Nĩonũhĩte gĩikaro gĩake ta mũgũnda; 
\q2 nĩanangĩte handũ hake ha gũtũnganĩrwo. 
\q1 Jehova nĩatũmĩte Zayuni ariganĩrwo 
\q2 nĩ ciathĩ ciake iria njathane, o hamwe na Thabatũ ciake; 
\q1 nĩ ũndũ wa marakara make mahiũ-rĩ, 
\q2 akanyarara mũthamaki, o hamwe na mũthĩnjĩri-Ngai. 
\b  
\q1  
\v 7 Mwathani nĩaregete kĩgongona gĩake, 
\q2 na agatiganĩria handũ hake harĩa haamũre. 
\q1 Nĩaneanĩte thingo cia nyũmba ciake cia ũthamaki kũrĩ thũ; 
\q2 iraanĩrĩra irĩ thĩinĩ wa nyũmba ya Jehova, 
\q2 o taarĩ mũthenya wa gĩathĩ kĩrĩa gĩathane. 
\b  
\q1  
\v 8 Jehova nĩatuire itua rĩa kũmomora 
\q2 rũthingo rũrĩa rũthiũrũrũkĩirie Mwarĩ wa Zayuni. 
\q1 Nĩatambũrũkirie rũrigi rwa gũthima, 
\q2 na ndaagiririe guoko gwake gũtige kũrwananga. 
\q1 Nĩatũmire njirigo na thingo icakaye; 
\q2 o cierĩ igĩgĩtuĩka cia kwanangĩka. 
\b  
\q1  
\v 9 Ihingo ciakuo nĩihorokeire na thĩ; 
\q2 mĩgĩĩko yacio nĩamiunangĩte, akamĩananga. 
\q1 Mũthamaki na anene akuo nĩmatahĩtwo magatwarwo ndũrĩrĩ-inĩ, 
\q2 watho rĩu ndũrutanagwo, 
\q1 na anabii akuo nĩmatigire kuona cioneki 
\q2 ciumĩte kũrĩ Jehova. 
\b  
\q1  
\v 10 Athuuri a kũu kwa Mwarĩ wa Zayuni 
\q2 maikarĩte thĩ makirĩte ki; 
\q1 nao nĩmehurĩirie rũkũngũ mĩtwe, 
\q2 na makehumba nguo cia makũnia. 
\q1 Airĩtu a Jerusalemu 
\q2 mainamĩrĩire maturumithĩtie mĩtwe yao thĩ. 
\b  
\q1  
\v 11 Maitho makwa nĩmaroora nĩ kũrĩra, 
\q2 ngatangĩka thĩinĩ wakwa, 
\q1 naguo roho wakwa nĩũitũrũrĩirwo thĩ 
\q2 nĩ ũndũ wa andũ akwa kwanangwo, 
\q1 nĩgũkorwo twana na tũkenge 
\q2 tũraringĩkĩra njĩra-inĩ cia itũũra rĩrĩa inene. 
\b  
\q1  
\v 12 Tũrooria manyina atĩrĩ, 
\q2 “Irio na ndibei irĩ ha?” 
\q1 o tũkĩringĩkaga ta andũ matiihĩirio 
\q2 njĩra-inĩ cia itũũra rĩrĩa inene, 
\q1 o mĩoyo yatuo ĩgĩthiragĩra 
\q2 moko-inĩ ma manyina. 
\b  
\q1  
\v 13 Ingĩkiuga atĩa nĩ ũndũ waku? 
\q2 Ingĩkũgerekania nakĩ, 
\q2 wee Mwarĩ ũyũ wa Jerusalemu? 
\q1 Ingĩkũhaanania nakĩ, 
\q2 nĩguo ngũhoorerie, 
\q2 wee Mwarĩ ũyũ Gathirange wa Zayuni? 
\q1 Kĩronda gĩaku kĩrikĩte o ta iria. 
\q2 Nũũ ũngĩhota gũkũhonia? 
\b  
\q1  
\v 14 Cioneki iria anabii aku moonaga 
\q2 ciarĩ cia tũhũ na cia maheeni; 
\q1 matiigana kũmũguũrĩria mehia manyu 
\q2 nĩguo magirĩrĩrie gũtahwo kwanyu. 
\q1 Ndũmĩrĩri iria maamũheire 
\q2 ciarĩ cia maheeni, na cia kũmũhĩtithia. 
\b  
\q1  
\v 15 Ehĩtũkĩri othe mahũũraga hĩ; 
\q2 mathekaga makĩinainagĩria Mwarĩ ũyũ wa Jerusalemu mĩtwe, 
\q1 makĩũragia atĩrĩ: 
\q2 “Ĩĩ rĩĩrĩ nĩrĩo itũũra inene rĩrĩa rĩetagwo 
\q1 ũthaka ũrĩa mũkinyanĩru biũ, 
\q2 na rĩgeetwo gĩkeno gĩa thĩ yothe?” 
\b  
\q1  
\v 16 Thũ ciaku ciothe 
\q2 ciathamagia tũnua igũũkĩrĩre; 
\q1 igũthekagĩrĩra na ikahagarania magego, 
\q2 ikoiga atĩrĩ, “Ithuĩ nĩtũmũmeretie. 
\q1 Ũyũ nĩguo mũthenya ũrĩa tũtũire twetereire, 
\q2 na rĩu nĩtũwonete.” 
\b  
\q1  
\v 17 Jehova nĩarĩkĩtie gwĩka ũrĩa aathugundĩte; 
\q2 we nĩahingĩtie kiugo gĩake, 
\q2 kĩrĩa aathanire o matukũ ma tene. 
\q1 Akũngʼaũranĩtie ategũkũiguĩra tha, 
\q2 atũmĩte thũ igũkenerere, 
\q2 rũhĩa rwa amuku aku nĩruo atũgĩrĩtie. 
\b  
\q1  
\v 18 Ngoro cia andũ nĩirakaĩra Mwathani. 
\q2 Atĩrĩrĩ, wee rũthingo rũrũ rwa Mwarĩ wa Zayuni, 
\q1 reke maithori maku manyũrũrũke ta rũũĩ 
\q2 mũthenya na ũtukũ; 
\q1 ndũkahurũke, 
\q2 kana ũreke maitho maku mahurũke. 
\b  
\q1  
\v 19 Arahũka, ũkayũrũrũke ũtukũ, 
\q2 rĩrĩa ũrangĩri wa ũtukũ wambagĩrĩria; 
\q1 itũrũraga ngoro yaku ta maaĩ 
\q2 mbere ya Mwathani. 
\q1 Ambararia moko maku na igũrũ kũrĩ we 
\q2 nĩ ũndũ wa mĩoyo ya ciana ciaku, 
\q1 o icio iraringĩka nĩ ngʼaragu 
\q2 magomano-inĩ ma njĩra ciothe. 
\b  
\q1  
\v 20 “Wee Jehova, ta rora, na ũcũũranie: 
\q2 Nũũ ũngĩ wee ũrĩ weka ũguo? 
\q1 Andũ-a-nja nĩmagĩrĩirwo nĩ kũrĩa maciaro mao, 
\q2 o ciana iria marerete? 
\q1 Mũthĩnjĩri-Ngai na mũnabii nĩmagĩrĩire 
\q2 kũũragagĩrwo handũ-harĩa-haamũre ha Mwathani? 
\b  
\q1  
\v 21 “Andũ ethĩ o na arĩa akũrũ 
\q2 makomete hamwe rũkũngũ-inĩ rwa njĩra, 
\q1 aanake akwa na airĩtu 
\q2 moragĩtwo na rũhiũ rwa njora. 
\q1 Ũmoragĩte mũthenya ũrĩa ũrakarĩte; 
\q2 ũmoragĩte ũtekũmaiguĩra tha. 
\b  
\q1  
\v 22 “O ta ũrĩa wĩtanaga mũthenya wa gĩathĩ-rĩ, 
\q2 noguo ũnjĩtĩire maũndũ ma kũnguoyohia, 
\q1 makandigiicĩria mĩena yothe 
\q2 o taarĩ mũthenya wa gĩathĩ. 
\q1 Mũthenya wa marakara ma Jehova-rĩ, 
\q2 gũtirĩ mũndũ o na ũmwe wahonokire kana agĩtigara; 
\q1 arĩa ndarũmbũirie na ngĩrera-rĩ, 
\q2 thũ yakwa nĩĩmanangĩte.” 
\c 3  
\q1  
\v 1 Niĩ ndĩ mũndũ wonete thĩĩna 
\q2 nĩ ũndũ wa kũhũũrwo na rũthanju rwa mangʼũrĩ make. 
\q1  
\v 2 Andwarĩte akangereria nduma-inĩ 
\q2 handũ ha ũtheri-inĩ; 
\q1  
\v 3 ti-itherũ, atũmĩte guoko gwake kũnjũkĩrĩre 
\q2 rĩngĩ na rĩngĩ, mũthenya wothe. 
\b  
\q1  
\v 4 Nĩatũmĩte nyama cia mwĩrĩ wakwa 
\q2 na gĩkonde kĩaguo ihinyare, 
\q2 na akoinanga mahĩndĩ makwa. 
\q1  
\v 5 Nĩandigiicĩirie, na agaathiũrũrũkĩria 
\q2 na marũrũ, na thĩĩna. 
\q1  
\v 6 Atũmĩte ndũũre nduma-inĩ 
\q2 o ta andũ arĩa maakuire tene. 
\b  
\q1  
\v 7 Nĩanjirigĩire na rũthingo nĩguo ndikae kũũra; 
\q2 mĩnyororo yakwa nĩamĩritũhĩtie mũno. 
\q1  
\v 8 O na rĩrĩa ndetana kana ndakaya ngĩenda ũteithio-rĩ, 
\q2 nĩ kũhingĩrĩria ahingagĩrĩria mahooya makwa. 
\q1  
\v 9 Nĩahingĩte njĩra yakwa na mahiga maicũhie; 
\q2 atũmĩte tũcĩra twakwa tuogome. 
\b  
\q1  
\v 10 Kũrĩ niĩ aatuĩkĩte o ta nduba rĩrĩa yoheirie, 
\q2 kana ta mũrũũthi rĩrĩa wĩhithĩte, 
\q1  
\v 11 akĩngururia kuuma gacĩra-inĩ, 
\q2 akĩndambuura, akĩndiganĩria itarĩ na ũteithio. 
\q1  
\v 12 Ageetete ũta wake, akangereka, 
\q2 nduĩke cabaa ya kũrathagwo nĩ mĩguĩ yake. 
\b  
\q1  
\v 13 Nĩatheecire ngoro yakwa 
\q2 na mĩguĩ kuuma thiaka-inĩ wake. 
\q1  
\v 14 Ngĩgĩtuĩka wa gũthekagĩrĩrwo nĩ andũ akwa othe; 
\q2 maanyũrũragia na rwĩmbo mũthenya wothe. 
\q1  
\v 15 Anjiyũrĩtie maũndũ marũrũ, 
\q2 na akaahũũnia na maaĩ ma nyongo. 
\b  
\q1  
\v 16 Nĩangʼethũrangĩte magego makwa na kagoto; 
\q2 anangĩrĩirie rũkũngũ-inĩ. 
\q1  
\v 17 Nĩnjagithĩtio thayũ; 
\q2 nĩndiganĩirwo ũgaacĩru nĩ kĩĩ. 
\q1  
\v 18 Nĩ ũndũ ũcio nguuga atĩrĩ, “Riiri wakwa nĩũthirĩte, 
\q2 o hamwe na maũndũ marĩa mothe ndũire njĩrĩgĩrĩire kuuma kũrĩ Jehova.” 
\b  
\q1  
\v 19 Nĩngũririkana thĩĩna wakwa, na kũũrũũra gwakwa, 
\q2 na ngaririkana maũndũ marũrũ, o na maaĩ ma nyongo. 
\q1  
\v 20 Ngoro yakwa no ĩraririkana maũndũ macio, 
\q2 nayo ĩkaringĩka thĩinĩ wakwa. 
\q1  
\v 21 O na gũtariĩ ũguo nĩndirikanaga ũndũ ũyũ, 
\q2 na tondũ wa ũguo ngagĩa na kĩĩrĩgĩrĩro: 
\b  
\q1  
\v 22 Tondũ wa wendo mũnene wa Jehova, nĩkĩo tũtaniinĩtwo biũ, 
\q2 nĩgũkorwo tha ciake itirĩ hĩndĩ ithiraga. 
\q1  
\v 23 Tha ciaku ikoragwo irĩ njerũ rũciinĩ o rũciinĩ, 
\q2 wĩhokeku waku nĩ mũnene mũno. 
\q1  
\v 24 Ngoro yakwa yugaga atĩrĩ, 
\q2 “Jehova nĩwe igai rĩakwa; tondũ ũcio nĩwe ndĩrĩetagĩrĩra.” 
\b  
\q1  
\v 25 Jehova nĩ mwega kũrĩ arĩa mamwĩhokaga, 
\q2 kũrĩ ngoro ĩyo ĩmũrongoragia; 
\q1  
\v 26 nĩ wega mũndũ gweterera 
\q2 ũhonokio wa Jehova o akirĩte. 
\q1  
\v 27 Nĩ wega mũndũ gũkuua icooki 
\q2 hĩndĩ ĩrĩa arĩ mũnini. 
\b  
\q1  
\v 28 Nĩaikare arĩ wiki akirĩte, 
\q2 nĩgũkorwo nĩ Jehova ũmũigĩrĩire rĩo. 
\q1  
\v 29 Nĩaturumithie ũthiũ wake rũkũngũ-inĩ, 
\q2 no gũkorwo aahota kũgĩa na kĩĩrĩgĩrĩro. 
\q1  
\v 30 Nĩerekererie rũthĩa kũrĩ mũndũ ũrĩa ũkũmũgũtha, 
\q2 na aiyũrwo nĩ thoni. 
\b  
\q1  
\v 31 Nĩgũkorwo Jehova 
\q2 ndateanagĩria andũ nginya tene. 
\q1  
\v 32 O na gũtuĩka nĩarehaga kĩeha-rĩ, we nĩaiguanagĩra tha, 
\q2 nĩgũkorwo wendo ũcio wake ũtathiraga nĩ mũnene mũno. 
\q1  
\v 33 Nĩgũkorwo ndarehagĩra andũ mĩnyamaro, 
\q2 kana akarehere ciana cia andũ kĩeha akĩendaga. 
\b  
\q1  
\v 34 Rĩrĩa andũ a bũrũri arĩa othe mohetwo 
\q2 maarangĩrĩrio na makinya-rĩ, 
\q1  
\v 35 rĩrĩa mũndũ aagithio kĩhooto gĩake 
\q2 mbere ya Ũrĩa-ũrĩ-Igũrũ-Mũno-rĩ, 
\q1  
\v 36 o na rĩrĩa mũndũ atuĩrwo ciira hatarĩ kĩhooto-rĩ, 
\q2 githĩ Mwathani ndonaga maũndũ macio? 
\b  
\q1  
\v 37 Nũũ ũngĩaria na atũme ũndũ ũcio ũhinge, 
\q2 Mwathani ataathanĩte gũtuĩke ũguo? 
\q1  
\v 38 Githĩ kanua-inĩ ka Ũrĩa-ũrĩ-Igũrũ-Mũno 
\q2 tiho hoimaga maũndũ mooru, na hakoima maũndũ mega? 
\q1  
\v 39 Mũndũ o wothe ũrĩ muoyo-rĩ, atetaga nĩkĩ 
\q2 rĩrĩa ekũherithio nĩ ũndũ wa mehia make? 
\b  
\q1  
\v 40 Nĩtũthuthuurie-i mĩthiĩre iitũ na tũmĩtuĩrie, 
\q2 tũcokerere Jehova. 
\q1  
\v 41 Nĩtwambararie ngoro ciitũ na moko maitũ na igũrũ 
\q2 kũrĩ Mũrungu ũrĩa ũrĩ igũrũ, tuuge atĩrĩ: 
\q1  
\v 42 “Ithuĩ-rĩ, nĩtwĩhĩtie na tũgakũremera, 
\q2 wee nawe ũkaaga gũtũrekera. 
\b  
\q1  
\v 43 “Wee wĩhumbĩrĩte na marakara, ũgatũingatithia; 
\q2 ũũraganĩte ũtekũiguanĩra tha. 
\q1  
\v 44 Wee wĩhumbĩrĩte na itu 
\q2 nĩgeetha gũtikagĩe na ihooya rĩngĩgũkinyĩra. 
\q1  
\v 45 Wee ũtũmĩte tũtuĩke ta gĩko, 
\q2 na ta mahuti gatagatĩ ka ndũrĩrĩ. 
\b  
\q1  
\v 46 “Thũ ciitũ ciothe itwathamĩirie tũnua itũũkĩrĩre. 
\q1  
\v 47 Nĩtũkorereirwo nĩ kĩmako kĩnene, na tũkenjerwo marima, 
\q2 tũgakorwo nĩ ũniinani, na mwanangĩko.” 
\q1  
\v 48 Maitho makwa maranyũrũrũkia tũrũũĩ twa maithori 
\q2 nĩ ũndũ andũ akwa nĩmanangĩtwo. 
\b  
\q1  
\v 49 Maitho makwa marĩnyũrũrũkagia maithori mategũtigithĩria, 
\q2 magaikara o makĩnyũrũrũkaga, 
\q1  
\v 50 nginya rĩrĩa Jehova agaacũthĩrĩria arĩ igũrũ oone. 
\q1  
\v 51 Maũndũ marĩa ndĩrona nĩmaranjiguithia kĩeha ngoro, 
\q2 tondũ wa andũ-a-nja othe a itũũra rĩakwa inene. 
\b  
\q1  
\v 52 Andũ arĩa maatuĩkĩte thũ ciakwa hatarĩ gĩtũmi 
\q2 nĩo maanguĩmaga ta nyoni. 
\q1  
\v 53 Maanjikirie irima makĩenda kũnjũraga, 
\q2 na makĩĩhũũra na mahiga; 
\q1  
\v 54 ndaahubanĩirio nĩ maaĩ maingĩ, 
\q2 magĩikũrũkĩra igũrũ rĩa mũtwe wakwa, 
\q2 na niĩ ngĩĩciiria ndĩ hakuhĩ kũniinwo. 
\b  
\q1  
\v 55 Ngĩkaĩra rĩĩtwa rĩaku Wee Jehova, 
\q2 ndĩ kũu irima-inĩ rĩu iriku. 
\q1  
\v 56 Na we ũkĩigua ithaithana rĩakwa, ngĩkwĩra atĩrĩ, 
\q2 “Tiga kũhinga matũ maku ngĩgũkaĩra ũndeithie.” 
\q1  
\v 57 Nawe ũkĩnguhĩrĩria rĩrĩa ndagũkaĩire, 
\q2 ũkĩnjĩĩra atĩrĩ, “Tiga gwĩtigĩra.” 
\b  
\q1  
\v 58 Wee Mwathani-rĩ, nĩwe wanjiirĩrĩire; 
\q2 nawe ũgĩgĩkũũra muoyo wakwa. 
\q1  
\v 59 Wee Jehova, nĩwonete ũũru ũrĩa njĩkĩtwo. 
\q2 Tua ciira wakwa arĩ we! 
\q1  
\v 60 Wee nĩwonete kwĩrĩhĩria kwao guothe, 
\q2 o na mathugunda mao mothe ma kũnjũkĩrĩra. 
\b  
\q1  
\v 61 Wee Jehova-rĩ, nĩũiguĩte irumi iria manumĩte nacio, 
\q2 o na mathugunda mao mothe ma kũnjũkĩrĩra: 
\q1  
\v 62 maũndũ marĩa thũ ciakwa ciaragia na mĩheehũ ikĩngʼungʼuanaga 
\q2 injũkĩrĩre mũthenya wothe. 
\q1  
\v 63 Ta kĩmarore! Magĩikara thĩ kana magĩũkĩra, 
\q2 maanyũrũragia na nyĩmbo ciao. 
\b  
\q1  
\v 64 Wee Jehova-rĩ, marĩhe kũringana na ũrĩa mekĩte, 
\q2 kũringana na wĩra wa moko mao. 
\q1  
\v 65 Ũmia ngoro ciao, nakĩo kĩrumi gĩaku kĩroikara nao! 
\q1  
\v 66 Maingatithie ũrĩ na marakara, 
\q2 na ũmaniine mathire gũkũ mũhuro wa igũrũ rĩa Jehova. 
\c 4  
\q1  
\v 1 Hĩ! Kaĩ thahabu ĩyo nĩĩthirĩte ũkengu wayo-ĩ, 
\q2 thahabu ĩrĩa therie kaĩ ĩrĩ gũthita-ĩ! 
\q1 Tũhiga twa goro tũrĩa twamũre 
\q2 nĩtũhurunjĩtwo magomano-inĩ ma njĩra ciothe. 
\b  
\q1  
\v 2 Ariũ a Zayuni arĩa me bata, 
\q2 arĩa rĩmwe mangĩaringithanirio na thogora wa thahabu, 
\q1 kaĩ rĩu moonagwo ta nyũngũ cia rĩũmba-ĩ, 
\q2 o ta wĩra wa moko ma mũũmbi! 
\b  
\q1  
\v 3 O na mbwe nĩciongithagia ciana ciacio, 
\q2 no andũ akwa matuĩkĩte andũ matarĩ tha, 
\q2 o ta nyaga cia werũ-inĩ. 
\b  
\q1  
\v 4 Rũrĩmĩ rwa gakenge 
\q2 rũnyiitanĩte na karakara nĩ ũndũ wa kũnyoota; 
\q1 twana tũhooyaga irio, 
\q2 no gũtirĩ mũndũ ũtũheaga. 
\b  
\q1  
\v 5 Andũ arĩa rĩmwe maarĩĩaga irio njega, 
\q2 rĩu maikaraga njĩra-inĩ mekonotete, 
\q1 arĩa maarerirwo makĩhumbagwo nguo cia rangi wa ndathi-rĩ, 
\q2 rĩu makomaga ciara-inĩ cia mũhu. 
\b  
\q1  
\v 6 Iherithia rĩa andũ akwa 
\q2 nĩ inene gũkĩra rĩa itũũra rĩa Sodomu, 
\q1 rĩrĩa rĩangʼaũranirio o rĩmwe, 
\q2 gũtarĩ guoko kwarĩteithirie. 
\b  
\q1  
\v 7 Anene akuo maatherete gũkĩra tharunji, 
\q2 na makeerũha gũkĩra iria, 
\q1 maarĩ atune mĩĩrĩ gũkĩra ruru ĩrĩa ndune, 
\q2 magakĩhaana ta kahiga ka goro karĩa getagwo yakuti. 
\b  
\q1  
\v 8 No rĩu mairĩte o na gũkĩra mbiro; 
\q2 matikũũrĩkanaga marĩ njĩra-inĩ. 
\q1 Ikonde cia mĩĩrĩ yao ciũmanĩrĩire na mahĩndĩ; 
\q2 ciumĩte o ta rũthanju. 
\b  
\q1  
\v 9 Kaba arĩa mooragagwo na rũhiũ rwa njora, 
\q2 kũrĩ arĩa makuuaga nĩ ngʼaragu; 
\q1 matooragio nĩkũhũũta, 
\q2 makamoca nĩ ũndũ wa kwaga irio cia kuuma mũgũnda. 
\b  
\q1  
\v 10 Moko ma andũ-a-nja arĩa marĩ tha 
\q2 nĩmarugire ciana ciao ene, 
\q1 igĩtuĩka irio ciao 
\q2 hĩndĩ ĩyo andũ akwa manangirwo. 
\b  
\q1  
\v 11 Jehova nĩarekereirie mangʼũrĩ make biũ; 
\q2 aitũrũrĩte marakara make mahiũ. 
\q1 Nĩakĩtie mwaki kũu Zayuni 
\q2 ũrĩa ũcinĩte mĩthingi yakuo. 
\b  
\q1  
\v 12 Athamaki a thĩ matingĩetĩkirie, 
\q2 o na kana kĩrĩndĩ o na kĩmwe gĩa gũkũ thĩ, 
\q1 atĩ thũ na amuku nĩmangĩahotire 
\q2 gũtoonya ihingo cia Jerusalemu. 
\b  
\q1  
\v 13 No ũndũ ũcio wekĩkire nĩ ũndũ wa mehia ma anabii akuo, 
\q2 na mawaganu ma athĩnjĩri-Ngai akuo 
\q1 arĩa manaita thakame 
\q2 ya andũ arĩa athingu kũu thĩinĩ. 
\b  
\q1  
\v 14 Rĩu maturuuraga njĩra-inĩ 
\q2 ta andũ atumumu. 
\q1 Mathaahĩtio nĩ thakame ũũ atĩ 
\q2 gũtirĩ mũndũ o na ũmwe ũngĩgeria kũhutia nguo ciao. 
\b  
\q1  
\v 15 Andũ mamakayagĩrĩria, makoiga atĩrĩ, 
\q2 “Thiĩi nakũu! Mũrĩ na thaahu! Thiĩi! Thiĩi! Mũtigatũhutie!”\f + \fr 4:15 \ft Andũ arĩa maakoragwo na mangũ maanagĩrĩra nĩguo andũ matikamahutie tondũ maakoragwo na thaahu (Alaw 13:45).\f* 
\q1 Ningĩ moora na maatuĩka orũũri, 
\q2 makeerwo atĩrĩ kũu ndũrĩrĩ-inĩ, 
\q2 “Matingĩikara gũkũ rĩngĩ.” 
\b  
\q1  
\v 16 Jehova we mwene nĩwe ũmahurunjĩte; 
\q2 nĩatigĩte kũmarũmbũiya. 
\q1 Athĩnjĩri-Ngai matiheagwo gĩtĩĩo, 
\q2 o na makarega gũtuga athuuri. 
\b  
\q1  
\v 17 Makĩria ma ũguo-rĩ, maitho maitũ nĩmathirire hinya, 
\q2 o tũcũthĩrĩirie ũteithio ũrĩa tũtoonire; 
\q1 kuuma mĩthiringo iitũ ĩrĩa mĩraihu-rĩ, 
\q2 twetereire rũrĩrĩ rũtangĩahotire gũtũhonokia. 
\b  
\q1  
\v 18 Andũ maatũcemaga ikinya gwa ikinya, 
\q2 nĩ ũndũ ũcio tũtingĩathiĩrĩire njĩra-inĩ ciitũ. 
\q1 Ithirĩro riitũ rĩgĩkuhĩrĩria, namo matukũ maitũ maarĩ matare, 
\q2 nĩgũkorwo ithirĩro riitũ nĩrĩakinyĩte. 
\b  
\q1  
\v 19 Andũ arĩa matũingatithĩtie-rĩ, 
\q2 maarĩ na ihenya gũkĩra nderi irĩ rĩera-inĩ; 
\q1 maatũhanyũkagĩria irĩma-inĩ, 
\q2 na magatuoheria werũ-inĩ. 
\b  
\q1  
\v 20 Mũndũ ũrĩa mũitĩrĩrie maguta nĩ Jehova, 
\q2 o we ũrĩa warĩ ta mĩhũmũ iitũ-rĩ, 
\q2 nĩagwatirio nĩ mĩtego yao. 
\q1 Tweciiragia atĩ tũrĩ kĩĩruru-inĩ gĩake-rĩ, 
\q2 no tũtũũre gatagatĩ ka ndũrĩrĩ. 
\b  
\q1  
\v 21 Kena na ũcanjamũke, wee Mwarĩ wa Edomu, 
\q2 o wee ũtũũraga bũrũri wa Uzu. 
\q1 No rĩrĩ, o nawe gĩkombe gĩkĩ nĩgĩgagũkora; 
\q2 ũgaakĩnyuĩra ũrĩĩo, na ũrutwo nguo, ũtigwo njaga. 
\b  
\q1  
\v 22 Wee Mwarĩ wa Zayuni-rĩ, iherithia rĩaku nĩrĩgathira; 
\q2 ndakoongerera ihinda rĩaku rĩa gũikara ũrĩ mũtahe. 
\q1 No wee, Mwarĩ wa Edomu-rĩ, nĩagakũherithĩria mehia maku 
\q2 na aguũrie waganu waku. 
\c 5  
\q1  
\v 1 Wee Jehova-rĩ, ririkana maũndũ marĩa matũkorete; 
\q2 ta rora wone gũconoka gwitũ. 
\q1  
\v 2 Igai riitũ nĩrĩneanĩtwo kũrĩ ageni, 
\q2 nayo mĩciĩ iitũ ĩgakĩneanwo kũrĩ andũ a kũngĩ. 
\q1  
\v 3 Nĩtũtuĩkĩte ciana cia ngoriai na ciana itarĩ na maithe, 
\q2 nao manyina maitũ magatuĩka ta atumia a ndigwa. 
\q1  
\v 4 Maaĩ marĩa tũnyuuaga no tũgũrire; 
\q2 o na ngũ nĩkũgũra tũragũra. 
\q1  
\v 5 Arĩa matũingatithagia marĩ o magũrũ-inĩ maitũ; 
\q2 nĩtũnogete, na tũkaaga ũhurũko. 
\q1  
\v 6 Twĩneanĩte kũrĩ andũ a Misiri na a Ashuri 
\q2 nĩgeetha tuone irio cia gũtũigana. 
\q1  
\v 7 Maithe maitũ nĩmehirie na rĩu matirĩ ho, 
\q2 na ithuĩ nĩ ithuĩ tũraherithio handũ hao. 
\q1  
\v 8 Ngombo nĩcio itwathaga, 
\q2 na gũtirĩ mũndũ wa gũtũteithũra kuuma moko-inĩ ma cio. 
\q1  
\v 9 Tuonaga irio na ũndũ wa gũtwarĩrĩria mĩoyo iitũ ũgwati-inĩ, 
\q2 nĩ ũndũ wa rũhiũ rwa njora rũrĩa rũrĩ werũ-inĩ. 
\q1  
\v 10 Gĩkonde giitũ kĩhiũhĩte o ta riiko rĩa kũruga mĩgate, 
\q2 tũkainaina nĩ ũndũ wa kũhũũta. 
\q1  
\v 11 Andũ-a-nja nĩmanyiitĩtwo na hinya gũkũ Zayuni, 
\q2 nao airĩtu gathirange makanyiitwo na hinya matũũra-inĩ ma Juda. 
\q1  
\v 12 Anene akuo nĩ macuurĩtio na moko mao; 
\q2 athuuri nao matiheagwo gĩtĩĩo. 
\q1  
\v 13 Aanake marutithagio wĩra wa hinya ithĩi-inĩ; 
\q2 tũmwana natuo tũtũgũũgaga nĩgũkuuithio mĩrigo ya ngũ. 
\q1  
\v 14 Athuuri nĩmatigĩte gũikara kĩhingo-inĩ gĩa itũũra inene; 
\q2 aanake nao nĩmatigĩte kũina nyĩmbo ciao. 
\q1  
\v 15 Ngoro ciitũ nĩithirĩte gĩkeno; 
\q2 ndũrũhĩ ciitũ igarũrũkĩte igatuĩka macakaya. 
\q1  
\v 16 Thũmbĩ ya ũnene\f + \fr 5:16 \ft Thũmbĩ yonanagia riiri na gĩtĩĩo (Isa 28:1, 3).\f* nĩĩgwĩte, ĩgatuuma mũtwe, 
\q2 kaĩ tũrĩ na haaro-ĩ, nĩgũkorwo nĩtwĩhĩtie! 
\q1  
\v 17 Tondũ ũcio ngoro ciitũ nĩiringĩkĩte; 
\q2 na tondũ wa maũndũ macio maitho maitũ makaira, 
\q1  
\v 18 tondũ wa Kĩrĩma gĩa Zayuni, kĩrĩa gĩkirĩte ihooru, 
\q2 nacio mbwe rĩu nĩkuo iceeraga. 
\q1  
\v 19 Wee Jehova-rĩ, wathanaga nginya tene; 
\q2 gĩtĩ gĩaku kĩa ũnene gĩtũũraga kuuma njiarwa nginya njiarwa. 
\q1  
\v 20 Ũriganagĩrwo nĩ ithuĩ hĩndĩ ciothe nĩkĩ? 
\q2 Ũtũtiganĩirie hĩndĩ ndaaya ũguo nĩkĩ? 
\q1  
\v 21 Wee Jehova-rĩ, tũcookererie harĩwe, nĩguo tũhote gũgũcookerera; 
\q2 erũhia matukũ maitũ macooke o ta ũrĩa matariĩ tene, 
\q1  
\v 22 tiga ũkorirwo nĩũtũregeete biũ, 
\q2 ũgagĩtũrakarĩra o mũno makĩria.