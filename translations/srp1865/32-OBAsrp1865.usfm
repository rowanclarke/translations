\id OBA
\h Knjiga proroka Avdija
\toc1 Knjiga proroka Avdija
\toc2 Avdija
\toc3 Avd
\mt1 Knjiga proroka Avdija
\c 1
\s1 Proricanje kazne zluradim Edomcima i izbavljanja Izrailja.
\p 
\v 1 Utvara Avdijeva.
\p Ovako veli Gospod Gospod za edomsku:
\b
\q1 Čusmo glas od Gospoda,
\q2 i glasnik bi poslan k narodima:
\q2 Ustajte, da ustanemo na nju u boj.
\q1 
\v 2 Gle, učiniću te malim među narodima,
\q2 bićeš vrlo prezren.
\q1 
\v 3 Ponos srca tvog prevari te,
\q2 tebe, koji živiš u raselinama kamenim,
\q2 u visokom stanu svom,
\q1 i govoriš u srcu svom:
\q2 Ko će me oboriti na zemlju?
\q1 
\v 4 Da podigneš visoko kao orao
\q2 i među zvezde da metneš gnezdo svoje,
\q1 odande ću te oboriti,
\q2 govori Gospod.
\b
\q1 
\v 5 Kako si oplenjen?!
\q1 Da su došli k tebi kradljivci ili lupeži noću,
\q2 ne bi li pokrali koliko im je dosta?
\q1 Da su došli k tebi berači vinogradski,
\q2 ne bi li ostavili pabiraka?
\q1 
\v 6 Kako se pretraži Isav,
\q2 kako se nađoše potaje njegove!
\q1 
\v 7 Do granice te odvedoše svi koji behu s tobom u veri,
\q2 prevariše te i nadvladaše te koji behu u miru s tobom;
\q1 koji jedu hleb tvoj podmetnuše ti zamku,
\q2 da se ne opazi.
\b
\q1 
\v 8 U onaj dan, govori Gospod,
\q2 neću li pogubiti mudre u zemlji edemskoj
\q2 i razumne u gori Isavovoj?
\q1 
\v 9 I tvoji će se junaci uplašiti, Temane,
\q2 da se istrebe pokoljem svi iz gore Isavove.
\b
\q1 
\v 10 Za nasilje učinjeno bratu tvom Jakovu pokriće te stid
\q2 i istrebićeš se zasvagda.
\q1 
\v 11 Onaj dan, kad ti stajaše nasuprot;
\q2 onaj dan, kad inostranci odvođahu u ropstvo vojsku njegovu,
\q1 i tuđinci ulažahu na vrata njegova
\q2 i bacahu žreb za Jerusalim,
\q2 beše i ti kao koji od njih.
\q1 
\v 12 Ali ti ne trebaše gledati dana brata svog,
\q2 dana, kad se odvođaše u tuđu zemlju,
\q1 niti se radovati sinovima Judinim u dan kad propadahu,
\q2 niti razvaljivati usta u dan nevolje njihove.
\q1 
\v 13 Ne trebaše ti ući na vrata naroda mog u dan pogibli njihove,
\q2 ne trebaše da i ti gledaš zlo njihovo u dan pogibli njihove,
\q2 ni da se dohvataš dobra njihova u dan pogibli njihove.
\q1 
\v 14 Niti trebaše da staneš na rasputicu da ubijaš bežan njihovu,
\q2 niti da izdaješ onih koji ostaše u dan nevolje.
\b
\q1 
\v 15 Jer je dan Gospodnji blizu svim narodima:
\q2 kako si činio, tako će ti biti,
\q2 plata će ti se vratiti na glavu tvoju.
\q1 
\v 16 Jer kao što ste vi pili na svetoj gori mojoj,
\q2 tako će piti svi narodi vazda,
\q1 piće, i ždreće,
\q2 i biće kao da ih nije bilo.
\q1 
\v 17 A na gori će Sionu biti spasenje,
\q2 i biće sveta,
\q2 i dom će Jakovljev naslediti nasledstvo svoje.
\q1 
\v 18 I dom će Jakovljev biti oganj
\q2 i dom Josifov plamen,
\q2 a dom Isavov strnjika;
\q1 i razgoreće se na njih,
\q2 i spaliće ih;
\q1 i neće biti ostataka domu Isavovom,
\q2 jer Gospod reče.
\b
\q1 
\v 19 I naslediće jug, goru Isavovu,
\q2 i ravnicu, Filisteje;
\q1 i naslediće polje Jefremovo i polje samarijsko
\q2 i Venijaminovo i Galad;
\q1 
\v 20 I zarobljena vojska sinova Izrailjevih naslediće šta je bilo hananejsko do Sarepte;
\q2 a roblje jerusalimsko, što je u Sefaradu,
\q2 naslediće južne gradove.
\q1 
\v 21 I izbavitelji će izaći na goru Sion da sude gori Isavovoj,
\q2 i carstvo će biti Gospodnje. 
