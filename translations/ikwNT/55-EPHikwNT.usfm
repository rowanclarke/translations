\id EPH - IKWERRE 
\h Ele Efesọsi 
\toc1 Ọkwukwo izi Pọlu gbaznennu Ele Efesọsi 
\toc2 Ele Efesọsi 
\toc3 Efes 
\mt2 Ọkwukwo izi Pọlu 
\mt2 gbaznennu 
\mt1 Ele Efesọsi 
\imt1 Nhne gbasịri ọkwukwo izi ka 
\im Nụ \bk Ọkwukwo izi Pọlu gbaznennu ele Efesọsi,\bk* ọ naakanụ ọgbako Chiokike nhne gbasịri olile anya be nwernu. Risi ikwu-ọnu Pọlu bụ nụ Karaịsi nwụrnu ẹnwu n'olu ọgba ma ọ znọhia aị hite nụ mmehie. Kọvu nụ Chiokike mernu o hi n'ẹnwu lizọ, ọ dazịri ẹli n'akarikwnunga Chiokike n'oligwe, hne ọ zị nẹechi ọwa. Ọ jẹechi masị ọwa ke vazne nụ ruwhnu. 
\ip Karaịsi mernu ele Ju nụ ele bụ́o ele Ju bụru otu, kwnornu nụ ọ kwnadnarnụ mkpọ irno ke kewarụ be (2:14). Ka neegesi nụ Chiokike jeehite n'Enine a mee mkpọma ele Karaịsi bụru otu, mee be zịri n'udno n'esilawụru be, (4:3), ma ele Karaịsi bụru otu. Ka bụ nhne zị mkpa n'ọkwukwo izi, ka mernu Pọlu gbarụ a k'agịda neegesi nụ ọ bụru ọma ma ele Karaịsi zịri n'otu. A nwernu otu Nyenwe aị, ọkwnata mkpọma aị bụ otu, ọwuwu mini aị bụ otu, ke neeme ele Karaịsi ghọ otu anọ-ẹhni. 
\iot Nhne zị n'ọkwukwo izi ka 
\io1 Obekwu ikwu \ior (1:1-2) \ior* 
\io1 Karaịsi nụ ọgbako a \ior (1:3---3:21) \ior* 
\io1 Bụdnu ikne hite nụ Karaịsi \ior (4:1---6:20) \ior* 
\io1 Ibekwu ipne-aznụ \ior (6:21-24) \ior* 
\c 1  
\s1 Obekwu ikwu 
\p  
\v 1 Mawa, Pọlu, nye izi Karaịsi Jizọsi hite n'echiche Chiokike, naagbaznenu ele Chiokike ke zị n'Efesọsi ọkwukwo, ele kwnagwụ mkpọma nụ Karaịsi Jizọsi. 
\p  
\v 2 Oru nụ udno ke hi n'aka Chiokike Nda aị nụ Nyenwe aị Jizọsi Karaịsi dazịnu anụ. 
\s1 Ngọzi ke enine 
\p  
\v 3 A nọotunu Chiokike nụ Nda Nyenwe aị Jizọsi Karaịsi mmamma, nye jiri kpakara ngọzi ke oligwe kesi aị n'enine nụ rime Karaịsi.  
\v 4 Chiokike beru ọsno họrukwo aị ma a bụru ele ke a kwnornu Karaịsi, sụ ọ kpụru ọwa, ma a bụru ele zị nsọ, ele nwée ọru nụ ruwhnu a kwnornu ọwhnun'anya a.  
\v 5 O beru ọsno họru aị, o kwubnanya aị lele rụmu a hite nụ Jizọsi Karaịsi lele kpa o jiri masị a.  
\v 6 Ngwa ma a ja Chiokike kwnornu agịda oru a ke o nyernu aị etekne hite nụ Nnwọ a ọ whnụrnu n'anya.  
\v 7 Chiokike gbahịaru aị hite n'ọvnarna Karaịsi wụsiri, nụ ọ gbarụ mmehie aị kwnornu n'oru a zị agịda,  
\v 8 bụ ke o nyernu aị n'ọkwnamarna, ya nụ akọniche nụ ọghohia a.  
\v 9 Chiokike mernu a mahịa nhne miri emi ke echiche a lele kpa o jiri masị a hite nụ Karaịsi. Ọ marnụ mmụma  
\v 10 o mezu echiche a ka nga ige a dụru. Ka bụ ma o gwebnanya kpakara nhne zị n'oligwe n'ọwa n'otu nụ mkpururu risi Karaịsi. 
\p  
\v 11 Chiokike họrukwo aị ma a bụru ele ke a nụ rime Karaịsi, hne o beru ọsno kpebi kpakara nhne lele kpa echiche a jiri zị.  
\v 12 Chiokike mernu ka ma a znarnị a kwnornu igwugwu a. A bụ ele mbọm neele anya Karaịsi.  
\v 13 Anụ bụ masị ele Karaịsi nga anụ nụrnu ezi ọka wam, ke bụ izi ọma ke ọznohia anụ. Anụ kweru nhne anụ nụrnu, Chiokike hnịasiri anụ iri Enine Nsọ nụ anụ bụ ke a lele kpa o kweru mkwna.  
\v 14 Enine Nsọ wam zị nụ rime aị, a maam nụ Chiokike jeenyerịri aị kpakara nhne bụru ọma nga Chiokike jaagbahịakwo ele ke a. N'ige wam, a jaaznarnị Chiokike kwnornu igwugwu a. 
\s1 Okpukpe Pọlu 
\p  
\v 15 Kam kpayarụ, nga me nụrnu nhne gbasịri ọkwnata mkpọma anụ nụ Nyenwe aị Jizọsi, ya nụ ọwhnun'anya anụ nwernu hne rụmu Chiokike zị,  
\v 16 m gwépụgam aka nụ ọ tụnu Chiokike mmamma nụ risi anụ. M zị m neekpenu anụ okpukpe kpakara ige.  
\v 17 M naarịasno Chiokike ke Nyenwe aị Jizọsi Karaịsi, Nda ke igwugwu, o mee anụ nwehịa enine akọniche, kpumenu anụ ẹhni a ma anụ mahịa a nkarị nkarị.  
\v 18 M nọorio masị ma Chiokike kpume anya ke ovu anụ, ma anụ ghọhia olile anya o nyernu ele o sukwuru, nụ ẹkwnu ngọzi zị igwugwu o kweru ele ke a nụ mkwna.  
\v 19 M nọorio masị ma anụ mahịa iknernema a ke nwée atụ bụ ke o nyernu aị ele kweru nụ Karaịsi. Ọ bụ okne iknernema ka  
\v 20 ke Chiokike jiri mee Karaịsi hi n'ẹnwu lizọ, mee ọ dazịri ẹli n'akarikwnunga Chiokike n'oligwe,  
\v 21 hne kakwo kpakara ọchichi nụ rikne nụ iknernema nụ ele nwe. Rẹwhna a kakwo kpakara nhne ke nwernu rẹwhna, ọ bụ́o n'ige ka kpọi, kọvu n'ige ke jaava.  
\v 22 Chiokike bịtaru kpakara nhne nụ mkpururu ọchi Karaịsi, mee a ọ bụru risi kpakara nhne ma ọgbako Chiokike naahịa ngọzi.  
\v 23 Ọgbako Chiokike bụ ẹhni Karaịsi, Karaịsi jihịaru n'ọgbako Chiokike. Karaịsi bụ nye mezuru kpakara nhne n'apna ọbula. 
\c 2  
\s1 Hite n'ẹnwu bna nụ bụdnu 
\p  
\v 1 Nụ mbọm, anụ nụ lele ele nwụrnu ọnwu, ele be kewamarnụ hne Chiokike zị kwnornu nụ anụ bnóne nsnị, mee nhne ọjo.  
\v 2 N'ige wam anụ wuru bụdnu ọjo lele ele zị n'ọwa. Anụ snornu badnụ ọjo wam ke nẹechi kpakara rẹnwu ọjo n'ọwa. Setani bụ rẹnwu ọjo wam ke nọornu ẹrnu nụ mkpọma ele zá noobnonu Chiokike nsnị kịtna.  
\v 3 Kpakara aị wuru bụdnu n'esilawụru be n'ige wheru ewhe lele kpa nhne nọogwnu anọ-ẹhni aị. A snornu ele berere mezu nhne echiche ọjo aị pioru, kam kpayarụ, a bụru ele ke ovu owe ẹhni Chiokike dnakwasịri. 
\p  
\v 4 Kọvu Chiokike bụ nye obirizi k'agịda. Ọwhnun'anya a zị agịda hne a zị.  
\v 5 Ọ bụ n'ezi nụ a bụ ele nwụrnu ọnwu nụ rime mmehie, kọvu Chiokike mernu aị nụ Karaịsi zịri bụdnu nga o mernu Karaịsi hi n'ẹnwu lizọ. Chiokike znọhiaru anụ kwnornu nụ oru a.  
\v 6 Chiokike mernu a snornu Karaịsi hi n'ẹnwu lizọ. O mee aị nụ Karaịsi Jizọsi dazịri ẹli nụ hne kakwo n'oligwe.  
\v 7 Chiokike mernu ka ma kpakara ele badnụ mahịa n'ige vazne nụ ruwhnu ẹkwnu ke oru a ke nwée atụ ke o jiri ovu ọma a gesi aị nụ rime Karaịsi Jizọsi.  
\v 8 Kwnornu nụ Chiokike jiri oru a znọhia anụ hite n'ọkwnata mkpọma nụ Karaịsi. Ọ bụ́o kwnornu nhne ọbula ke anụ mernu. Ọznohia anụ bụ nkesi hi n'aka Chiokike.  
\v 9 Ọ bụ́o ẹrnu ọma ọbula anụ rnụrnu, ọ zá nye ji a mee oknomokno.  
\v 10 A bụ ẹrnu aka Chiokike. Ọ kpụru aị ma aị nụ Karaịsi Jizọsi zịri n'otu rnụ ẹrnu ọma Chiokike beru ọsno kwabịtanu aị. 
\s1 A bụ otu nụ Karaịsi 
\p  
\v 11 Anụ chenwanya nụ mbọm anụ ele bụ́o ele Ju hite nụ ọmumu anụ. Anụ bụ ele ke ele Ju be kparụ nka neeledna anya, nookwu anụ ele be kpáge nka. Ọkpa nka bụ ke be jiri aka kpa n'anọ-ẹhni.  
\v 12 N'ige wam, be kewamarnụ anụ hne Karaịsi zị, anụ bụ́o ele Izirẹli, ke kpayarụ, anụ nwée igwe nụ mkwna Chiokike kweru ọ znọhia Izirẹli. Anụ wuru bụdnu n'ọwa ka lele ele nwée olile anya, anụ máa Chiokike nụ mbọm.  
\v 13 Anụ bụ ele be kewamarnụ hne Chiokike zị nụ mbọm, kọvu kịtna, Chiokike mernu anụ nụ Karaịsi zịri n'otu, mee masị anụ va nụ ruwhnu a hite n'ọvnarna Karaịsi wụsiri kwnornu anụ. 
\p  
\v 14 Karaịsi mernu udno zịri n'esilawụru ele Ju nụ ele bụ́o ele Ju nga o mernu ele Ju nụ ele bụ́o ele Ju otu badnụ. O mernu ka nga o jiri anọ-ẹhni a kwnadna mkpọ irno ke kewamarnụ ele Ju nụ ele bụ́o ele Ju.  
\v 15 Karaịsi luluru iwu ele Ju hite n'ẹnwu a ma o gweru ele Ju nụ ele bụ́o Ju ele kweru mee otu badnụ ikne, mee ma udno zịri n'esilawụru be.  
\v 16 Karaịsi mernu ele Ju nụ ele bụ́o ele Ju nụ Chiokike zịri n'udno hite n'ẹnwu ọ nwụrnu n'olu ọgba, mee be bụru otu badnụ. Ka gwemernu irno n'esilawụru ele Ju nụ ele bụ́o ele Ju.  
\v 17 Karaịsi varụ zni anụ izi ọma udno, anụ ele bụ́o ele Ju nụ aị ele Ju masị.  
\v 18 Hite nụ Karaịsi, kpakara aị nwernu oghere o znekwnusi Chiokike Nda aị hite n'otu Enine. 
\p  
\v 19 Kam kpayarụ, anụ ele bụ́o ele Ju bụ́ma ele izne, kọvu anụ ghọlam rụmu Chiokike nụ ele ezi-nụ-ọro Chiokike.  
\v 20 O wukwasịri anụ lele ọro n'olu ntụ-ẹli ele izi nụ ele ọwhnurninya, hne Karaịsi Jizọsi n'iwhuru a bụ risi nsụkala ọro.  
\v 21 Ya bụ ngalaba jigwu ọro n'otu, ọro wam noosopiya bụru Ọro Nsọ be bịtaru nsọ nyee Nyenwe aị.  
\v 22 Be wukọtaru anụ n'otu nụ rime Karaịsi, ma anụ bụru Ọro Nsọ hne Enine Chiokike wu. 
\c 3  
\s1 Pọlu nye ẹrnu  //  ele bụ́o ele Ju 
\p  
\v 1 Kam kpayarụ, mawa Pọlu, m bụ m nye ikelu kwnornu Karaịsi Jizọsi nụ kwnornu risi anụ ele bụ́o ele Ju neekpenu Chiokike.  
\v 2 N'ezi, anụ nụrnu nhne gbasịri kpa Chiokike nyernu m ẹrnu o mee anụ ele bụ́o ele Ju mahịa oru a.  
\v 3 Chiokike mernu m mahịa nhne miri emi ke badnụ máa nụ mbọm, lele kpa me gbarụ a n'ọkwukwo matị nụ mbọm. 
\p  
\v 4 Nga anụ gwnụrnu ka anụ jọowhnu nụ Chiokike mernu m ghọhia nhne miri emi gbasịri Karaịsi.  
\v 5 N'ige wheru ewhe, Chiokike kpúmene ele badnụ nhne ka, kọvu kịtna Enine Chiokike kpumennu a ele izi nụ ele ọwhnurninya ele ọ họhiaru.  
\v 6 Nhne miri emi wam bụ anụ ele bụ́o ele Ju ele kweru nụ ele Ju ele kweru ghọru otu anọ-ẹhni. Anụ joosno masị ele Ju kehịa nhne Chiokike kweru be nụ mkwna hite nụ Karaịsi Jizọsi kwnornu nụ izi ọma. 
\p  
\v 7 Chiokike nyernu m ẹrnu ke o zni izi ọma ka kwnornu ovu ọma a. O mernu ka hite nụ rikne a nọornu ẹrnu nụ rime m.  
\v 8 Ọ bụ n'ezi nụ m kwésile m, kọvu Chiokike nyernu m oru a n'esilawụru ele ke a, o zni anụ ele bụ́o ele Ju izi ọma ke okne nhne gbasịri Karaịsi ke ele badnụ nwée rikne ghọhiali.  
\v 9 O nyee kwno m ẹrnu o mee kpa ele badnụ jaamahịa kpa o jeeme nhne miri emi ka. Chiokike nye keru kpakara nhne kpusnirni nhne miri emi ka n'anya ele badnụ agịda ige wheru ewhe.  
\v 10 Echiche a bụ ma kpakara rikne ke nẹechi ẹchi n'oligwe mahịa akọniche Chiokike ke hna ezi hite n'ọgbako a. 
\p  
\v 11 Ka bụ nhne Chiokike vu nụ mkpọma sụ ọ kpụru ọwa. Kịtna, o mezuru a hite nụ Karaịsi Jizọsi Nyenwe aị.  
\v 12 Aị nụ Karaịsi bụ otu, a kweru nụ ya, kam kpayarụ, a nwernu mkpọma siri rikne o zne nụ ruwhnu Chiokike, énwe ogwnu.  
\v 13 M naarịasno anụ, anụ bikno kwé rikne gwụ anụ kwnornu awhnụwhnu me naatanụ anụ, ke jeegweyanụ anụ igwugwu. 
\s1 Karaịsi whnụrnu aị n'anya 
\p  
\v 14 Kam kpayarụ, me gwu mpnerne ọchi kpenu Chiokike Nda,  
\v 15 nye jịri kpakara ezi-nụ-ọro ke zị n'oligwe nụ ọwa rẹwhna be.  
\v 16 M nọorio Chiokike ma o hite n'ẹkwnu ke ngọzi a, nyee anụ iknernema hite n'Enine a ma mkpọma anụ si rikne,  
\v 17 ma Karaịsi hite n'ọkwnata ovu wuru nụ rime mkpọma anụ, ma anụ gba ẹgwnugwnu, gwuzoru chịm chịm n'ọwhnun'anya a.  
\v 18 M nọorio masị ma anụ nụ kpakara ele Chiokike mahịa ọwhnun'anya Karaịsi nwernu hne a zị, kpa ọ hna nụ rude, nụ ogologo a, nụ kpa ọ hna n'olu, nụ omimi a,  
\v 19 ma anụ mahịa ọwhnun'anya ka ke kakwo nhne badnụ etekne nwernu rikne ghọhiali. M nọorio ma Chiokike mejihịa anụ nụ kpakara nhne Chiokike bụ. 
\p  
\v 20 A ja Chiokike, nye nwernu rikne o mee kakwo kpa a nwernu rikne rịo mọbu rị hite nụ iknernema a ke nọornu ẹrnu nụ rime aị.  
\v 21 Ngwa ma aị ọgbako Chiokike ele o mernu aị nụ Karaịsi Jizọsi bụru otu, ja Chiokike hite n'otu ebiri dụ n'ebiri berere, ọwa kwnurnu ọwa. Amịm. 
\c 4  
\s1 A bụ otu nụ rime Karaịsi 
\p  
\v 1 Mawa, nye ikelu kwnornu Nyenwe aị, naarịasno anụ, anụ wu bụdnu kwesiri ikwu Chiokike sukwuru anụ.  
\v 2 Nhne ọbula anụ neeme, anụ gweru ovu hieru ẹli nụ ọzi wọhnernerne nụ ndidi naabnanya ibne anụ kwnornu anụ whnụrnu ẹhni anụ n'anya.  
\v 3 Anụ gbalị ọ bịta ọzi n'otu ke Enine hite noowu n'udno n'esilawụru anụ.  
\v 4 Ele Chiokike bụ otu anọ-ẹhni, a nahịaru otu Enine, lele kpa Chiokike sukwuru anụ n'otu olile anya.  
\v 5 A nwernu otu Nyenwe aị, ọkwnata mkpọma aị bụ otu, ọwuwu mini aị bụ otu.  
\v 6 A neekpenu otu Chiokike bụ Nda kpakara badnụ, nye nẹechi kpakara badnụ, ọ nọornu ẹrnu hite nụ kpakara badnụ, nye zị nụ rime kpakara badnụ. 
\p  
\v 7 Karaịsi nyernu nye ọbula nụ rime aị rikne ọ rnụ ẹrnu lele kpa o kpebiri a.  
\v 8 Lele kpa be gbarụ a n'ọkwukwo nsọ, 
\q1 “Nga ọ larụ olu, 
\q2 ọ dọru agịda ele irno a n'ọhi, be snornu a n'aznụ, 
\q2 o nyee ele badnụ nkesi.” 
\m  
\v 9 Kịni bụ n'ọkwukwo nsọ kwuru nụ ọ larụ n'olu? Ọ bụ nụ Karaịsi beru ọsno hiedna n'ọwa ka.  
\v 10 Nye wam hiednarnụ n'ọwa bụ masị nye larụ hne kakwo n'olu n'oligwe, ma o jihịa kpakara nhne.  
\v 11 Karaịsi bụ nye wam, nye nyernu ele badnụ rikne ọ rnụ ẹrnu, mernu agwna badnụ ele izi, ele berere ele ọwhnurninya, ele berere ele naagagharị nọokpo okwo izi ọma, ele berere ele nọoznu atnụrnu nụ ele neezni nhne.  
\v 12 O mernu ka ma o jiknernu ele Chiokike ma be rnụnu a ẹrnu, ma ọgbako Chiokike nooso, gwuzosi rikne,  
\v 13 tem a dụ n'ọzi n'otu ke ọkwnata ovu, nụ ọ mahịa Nnwọ Chiokike, ma a bụru ele sozuru nụ badnụ, ele dụru nụ nhne ọtutu ke zuru ozu nụ rime Karaịsi. 
\p  
\v 14 Ige wam a jọ́obuma rụmu takịri. Ele aghịgho nụ ele nooduwhu ele badnụ jéegweru iznizni aghalaghala ọbula ruwhere noovugharị duwhu aị, lele kpa abaka-mini nụ ruwhere noovughari ọgbo n'olu mini.  
\v 15 Tnụnuma, a gweru ọwhnun'anya nookwu ezi ọka, ma a nooso lele Karaịsi Nyenwe aị nụ nhne ọbula.  
\v 16 Karaịsi neeknekọta ele ke a n'otu, lele kpa rụknani jikọtaru kpakara nhne zị n'ẹhni badnụ n'otu. Ọ bụru nhne ọbula zị n'ẹhni nọornu ẹrnu a, kpakara ẹhni jọoburu nhne gwuzosiri rikne n'ọwhnun'anya. 
\s1 Bụdnu ikne nụ rime  //  Karaịsi 
\p  
\v 17 Kam kpayarụ, m ji m rẹwhna Nyenwe aị nọodo anụ aka nụ nsnị, anụ wúma bụdnu lele ele máa Chiokike, hite n'ọri ọriri ke nwée mbnarna.  
\v 18 Ele ka nwée rikne ọ ghọhia nhne gbasịri Chiokike. Be kewamarnụ be hne Chiokike zị kwnornu nụ be máa Chiokike, be bụ ele risi rikne.  
\v 19 Iwhnerne o mee nhne bụ́o ọma tụ́ be. Be bụ ele neeme nhne ọjo ke gwnụrnu be, ma be neeme nhne sọ ize n'anya lele kpa ọ nọogwnusi be rikne. 
\p  
\v 20 Kọvu kị bụ́o nhne anụ mụhiaru gbasịri Karaịsi.  
\v 21 N'ezi, anụ nụrnu nhne gbasịri a, be znirni anụ ezi ọka zị nụ Jizọsi.  
\v 22 Be znirni anụ sịgbasi bụdnu ọknani wam anụ noowu. Badnụ ọknani wam neeji kpakara nhne nọogwnu anụ nooduwhu anụ, noolulu masị bụdnu anụ.  
\v 23 Kịtna, anụ gharụ Chiokike ma ọ gbanwo echiche anụ.  
\v 24 Anụ wuru bụdnu ikne ke Chiokike nyernu anụ, ma anụ bụru ele ke Chiokike, ele mee mma, ele zị masị nsọ n'ezi. 
\p  
\v 25 Kam kpayarụ, anụ gháma aghalaghala, nye ọbula kwunu ibne a ezi ọka, kwnornu nụ a nụ lele nhne zị n'otu ẹhni.  
\v 26 Ọ bụru nụ ovu we anụ ẹhni, anụ mékọ mmehie, anụ kwékọ ovu owe ẹhni anụ dazịri tem ẹhnam dna.  
\v 27 Anụ nyékọ Ekwensu oghere nụ bụdnu anụ ọ rnawhu anụ.  
\v 28 Nye buznu znúma buznu, o gweru aka a rnụ ẹrnu kwesiri ma o yinu ele zị nụ mkpa aka. 
\p  
\v 29 Anụ kwé ọka bụ́o ọma hi n'ọnu anụ whụya, kọvu anụ kwu ọka bụru ọma ke jeeme badnụ gwuzosi rikne n'ọkwnata mkpọma a. Ige ọbula, anụ kwu nhne bụru ọma nụ nsnị ele badnụ ma be wulizọ be olu lele ọro.  
\v 30 Anụ mée Enine Nsọ Chiokike ovu owe ẹhni, bụ ke Chiokike jiri hnịasi anụ iri nụ anụ bụ ke a tem dụ n'ige anụ jeenwernukwo ẹhni anụ.  
\v 31 Anụ gweme kpakara mkpọma nlulu, nụ ọnuma, nụ ovu owe ẹhni, ya nụ ọlu ọgwnu nụ ọkaja nụ irno mkpọma.  
\v 32 Kọvu anụ nwe ovu ọma, whnụ ibne anụ n'anya, naagbarụnu ibne anụ lele kpa Chiokike gbarụnu anụ kwnornu Karaịsi. 
\c 5  
\p  
\v 1 Lele rụmu Chiokike whnụrnu n'anya, anụ wu bụdnu lele Chiokike.  
\v 2 Anụ wuru bụdnu ọwhnun'anya, lele kpa Karaịsi whnụrnu aị n'anya, gweru bụdnu a kwanụ Chiokike arịohna ke nwernu ẹknarna ọma kwnornu aị. 
\p  
\v 3 Anụ kwé be whnụ ewhere, mọbu nhne zị́la rịchna, mọbu anya-kwu n'esilawụru anụ. Nhne ele ka kwésile ele Chiokike zị nsọ.  
\v 4 Anụ kwú ọka tụ iwhnerne, mọbu ọka iwhnirniwhno, mọbu ọka bnána nụ nhne, ke kwésile, tnụnuma, anụ tụnu Chiokike mmamma.  
\v 5 Kwnornu nụ anụ magwụ nụ ọ zá nye naagba ewhere, mọbu nye zị́la rịchna, mọbu nye anya-kwu, ke nụ lele ọkwa rẹnwu, nwernu igwe nụ nhne ọma ke ẹli-eze Karaịsi nụ Chiokike. 
\p  
\v 6 Anụ kwékọ badnụ ọbula gweru ọka etekne rnawhu anụ. Chiokike jaata ele zá noobnonu a nsnị awhnụwhnu kwnornu nụ nhne nụ kpa.  
\v 7 Kam kpayarụ, anụ nụ ele nụ kpa mékọ nhne. 
\p  
\v 8 Anụ zị n'ọchichiri nụ mbọm, kọvu kịtna anụ bnarnụ n'iwhne Nyenwe aị, anụ wu bụdnu kwesiri ele zị n'iwhne.  
\v 9 Ele zị n'iwhne naamị mkpụru ọma ke ovu ọma, ome mma nụ ezi ọka.  
\v 10 Anụ piohịa, neeme masị nhne jaakpasu Nyenwe aị ovu ọso n'ọnu.  
\v 11 Anụ snó ẹrnu ọchichiri ke nwernu mkpụru bnáge nụ nhne kekọ nhne, kọvu anụ bigbọ be, ma nhne ọjo be mernu whụya iwhne.  
\v 12 Kwnornu nụ ọ nọotu iwhnerne o kwu nhne ele zá noobnonu Chiokike nsnị neeme nụ mgwụgwa.  
\v 13 Kọvu iwhne jeeme kpakara nhne whụya iwhne.  
\v 14 Kwnornu nhne ọbula ke iwhne kpumernu bụ́ma nhne zị nụ mgwụgwa. Kam kpayarụ, be karụ, 
\q1 “Tnenya, jị nye neezni anyarna, 
\q2 jị nye nụ lele nye nwụrnu ọnwu, lizọ, 
\q2 Karaịsi jọomukwasi ị iwhne a.” 
\p  
\v 15 Anya dụ anụ ẹli kpa anụ noowu bụdnu anụ. Anụ wú bụdnu lele ele iwhnirniwhno, kọvu lele ele nwernu akọniche.  
\v 16 Anụ gweru oghere ọbula anụ nwernu rnụ ẹrnu ọma, kwnornu nụ ele badnụ nọornu ẹrnu ọjo k'agịda n'ige ka.  
\v 17 Anụ bụ́o ele iwhnirniwhno, tnụnuma, anụ yisi ẹhni piohịa, neeme masị nhne Nyenwe aị pioru.  
\v 18 Anụ nwọ́ manya ke naabna n'anya, ke joolulu bụdnu anụ. Tnụnuma, anụ gharụ Enine Chiokike ma o mejihịa ovu anụ.  
\v 19 Anụ gweru eri ọma, eri ọznarni nụ eri mkpọma ọso n'ọnu kanụ ibne anụ ọka, gweru kpakara mkpọma anụ gwnụnu Nyenwe aị eri,  
\v 20 nọotunu Chiokike bụ Nda mmamma ige ọbula kwnornu kpakara nhne nụ rẹwhna Nyenwe aị Jizọsi Karaịsi.  
\v 21 Ele Chiokike bịta ẹhni be nụ mkpururu ibne anụ kwnornu nụ anụ nọosobisinu Nyenwe aị Karaịsi. 
\s1 Nzi nụ nnwerne 
\p  
\v 22 Ele bụ nnwerne anụ bịta ẹhni anụ nụ mkpururu nzi anụ lele nụ anụ bịtaru ẹhni anụ nụ mkpururu Nyenwe aị.  
\v 23 Kwnornu nụ nzi bụ risi nnwerne lele kpa Karaịsi bụ risi ọgbako Chiokike. Ọgbako Chiokike nụ lele anọ-ẹhni Karaịsi. Karaịsi bụ Nye Ọznohia ọgbako a.  
\v 24 Lele kpa ọgbako Chiokike zị nụ mkpururu Karaịsi, kpam masị, nnwerne ọbula bịta ẹhni a nụ mkpururu nzi a nụ kpakara nhne. 
\p  
\v 25 Ele bụ nzi, anụ whnụ nnwerne anụ n'anya lele kpa Karaịsi whnụrnu ọgbako a n'anya nwụ kwnornu a,  
\v 26 ma o mee a ọ zịri nsọ, o gweruru ikwu-ọnu Chiokike nụ mini snụ a, mee a, ọ zịri rịchna.  
\v 27 Karaịsi mernu ka ma o chetenu ọgbako wam n'ẹhni a, lele nhne zị igwugwu, nwée rune, mọbu ruwhnu dọliri ọdili, mọbu nhne ọjo berere, tnụnuma, ọgbako ke zị nsọ, ke nwée ọtna.  
\v 28 Kpam masị, nzi kwesiri ọ whnụ nnwerne a n'anya lele kpa ọ whnụrnu ẹhni a. Nye ọbula ke whnụrnu nnwerne a n'anya whnụrnu ẹhni a n'anya.  
\v 29 Ọ zá badnụ ọbula ke snornu ẹhni a irno, kọvu o nọoznu, neelekwa ẹhni a anya nkarị. Ọ bụ masị kpa Karaịsi neelekwa ọgbako Chiokike,  
\v 30 a bụ nhne zị n'ẹhni Karaịsi.  
\v 31 Kam kpayarụ, nyerukna jaagharụ nda a nụ nne a, takwnụsi n'ẹhni nnwerne a, be lawụru ghọ otu badnụ.  
\v 32 Ka bụ nhne miri emi k'agịda, kọvu m nookwu gbasịri Karaịsi nụ ọgbako Chiokike.  
\v 33 Nyerukna ọbula n'esilawụru anụ, whnụ nụ o whnụrnu nnwerne a n'anya lele kpa ọ whnụrnu ẹhni a, nnwerne masị, whnụ nụ ọ nọoso nzi a anya. 
\c 6  
\s1 Rụmu takịri nụ  //  ele mụrnu be 
\p  
\v 1 Rụmu takịri, anụ noobnonu ele mụrnu anụ nsnị lele kpa Nyenwe aị pioru, kwnornu nụ ọ bụru ọma o mee kpam.  
\v 2 Lele kpa be gbarụ a n'ọkwukwo nsọ, “Sọbisinu nda ị nụ nne i.” Ke bụ nhne mbọm ke Chiokike nyernu n'iwu ke nwernu mkwna.  
\v 3 I mee kpam, nhne jaagakwanụ ị nkarị, ma ị zịri bụdnu ogologo n'ọwa.  
\v 4 Ele bụ nda, anụ mée nhne jaakpasu rụmu anụ ovu owe ẹhni. Tnụnuma, anụ gweru ikwu-ọnu Chiokike nọoznu, neezni be. 
\s1 Ele ọhi nụ ele nwe be 
\p  
\v 5 Ele ọhi, anụ noobnonu ele nwe anụ nsnị, anụ sọ be anya, nọotu ọgwnu be. Anụ gweru mkpọma anụ neeme a lele anụ neemenu a Karaịsi.  
\v 6 Anụ bnonu be nsnị, ọ bụ́o ke anya nọowhnu kpọi lele ele neeme nhne naamasị badnụ, kọvu noobnonu be nsnị lele ele ọhi Karaịsi, ele neeme nhne Chiokike pioru hite nụ mkpọma anụ.  
\v 7 Anụ gweru ovu ọma nọornu ẹrnu lele nụ anụ bụ ọhi Nyenwe aị, bụ́o ke badnụ.  
\v 8 Kwnornu nụ anụ magwụ nụ Nyenwe aị jọokwu nye ọbula ọgwo ẹrnu ọma a, ma ọhi mọbu nye bụ́o ọhi. 
\p  
\v 9 Kpam masị, anụ ele nwe ọhi, anụ mee masị ele ọhi anụ kpam. Anụ kpásị be ogwnu, hne anụ mahịaru nụ Nyenwe anụ nụ be zị n'oligwe. Ọ zá neele badnụ anya nụ ruwhnu. 
\s1 Mgwna ọgwnu Chiokike 
\p  
\v 10 Ka bụ ọka ipne-aznụ m, anụ gbasị rikne nụ Nyenwe aị nụ okne iknernema ke a.  
\v 11 Anụ woru kpakara mgwna ọgwnu Chiokike nyernu anụ, ma anụ nwernu rikne o gwuzogidne kpakara nhne ke Ekwensu neeziya.  
\v 12 Kwnornu nụ a zá nọolu ọgwnu megidne ele badnụ etekne. Kọvu a nọolu ọgwnu megidne kpakara ele ọchichi, megidne kpakara rikne, megidne kpakara ele nwe ọwa ke ọchichiri ka, megidne ele rẹnwu ọjo ke zị n'olu.  
\v 13 Kam kpayarụ, anụ woru kpakara mgwna ọgwnu Chiokike nyernu anụ ma anụ nwernu rikne o gwuzo n'ọbochi ọjo, nga anụ mezuru kpakara nhne, o gwuzoru chịm chịm. 
\p  
\v 14 Anụ jiknernu ọ lụ ọgwnu, anụ suru ezi ọka n'ikwnu anụ ke nụ lele ajnị. Anụ woru ome mma ke nụ lele mbno nụ mkpọma anụ.  
\v 15 Anụ gweru masị ojiknernu ọ kpọ okwo izi ọma ke udno woru n'ọchi lele okoro-ọchi.  
\v 16 Tụkwasi n'olu ka, anụ gweru ọkwnata mkpọma nụ Chiokike ke nụ lele ekpeke anụ jeeji mesni kpakara mkpakwụ bẹkwnu ke Ekwensu naagba megidne anụ.  
\v 17 Anụ kpuru ọznohia nụ risi anụ ke nụ lele okpu-ọgwnu. Anụ gweru ama-ọgwnu ke Enine neenye, ama-ọgwnu wam bụ ikwu-ọnu Chiokike.  
\v 18 Anụ neekpe okpukpe lele kpa Enine noodu anụ ige ọbula n'ọnodi ọbula. Anụ neese nse kpa anụ neekpe okpukpe, anụ gwuzosi rikne kpa anụ neekpenu kpakara ele Chiokike okpukpe. 
\p  
\v 19 Anụ neekpenu m okpukpe masị ma Chiokike nyee m ikwu-ọnu ke me kwesiri o kwu ige ọbula me kpumernu ọnu m, ma m gweru ọnu rikne mee ele badnụ mahịa nhne miri emi ke izi ọma,  
\v 20 ke me bụ nye izi a n'ọro ikelu. Anụ kpenu m okpukpe ma m kpọ m okwo izi ọma énwe ogwnu lele kpa me kwesiri. 
\s1 Obekwu ikwu ipne-aznụ 
\p  
\v 21 Taịkikosi bụ nnwọ nda aị a whnụrnu n'anya nye be kwesiri ọ kwnata mkpọma n'ẹrnu Nyenwe aị jaakanụ anụ kpakara nhne gbasịri m, ma anụ mahịa kpa me nụ, nụ nhne me neeme.  
\v 22 Ka bụ nhne me kwno neeziyanu anụ ya, ma anụ mahịa kpa a nụ, ma ọ kasi anụ mkpọma. 
\p  
\v 23 Udno ke Chiokike Nda aị nụ Nyenwe aị Jizọsi Karaịsi dazịnu ele kweru nụ Karaịsi, o mee anụ whnụ ibne anụ n'anya kpa anụ naakwnata mkpọma nụ Karaịsi.  
\v 24 Oru ke Chiokike dazịnu kpakara ele whnụrnu Nyenwe aị Jizọsi Karaịsi n'anya n'ezi.