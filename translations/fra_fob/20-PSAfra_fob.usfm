\v 5 \w Tu|strong="H3588"\w* \w as|strong="H3588"\w* châtié \w les|strong="H6213"\w* \w nations|strong="H6213"\w*, \w tu|strong="H3588"\w* \w as|strong="H3588"\w* \w fait|strong="H6213"\w* \w périr|strong="H6213"\w* \w le|strong="H6213"\w* méchant, \w tu|strong="H3588"\w* \w as|strong="H3588"\w* effacé \w leur|strong="H3588"\w* \w nom|strong="H3427"\w* \w pour|strong="H6213"\w* \w toujours|strong="H3427"\w*, \w à|strong="H6213"\w* perpétuité.
\v 6 C'\w en|strong="H5769"\w* \w est|strong="H8034"\w* \w fait|strong="H1471"\w* \w des|strong="H8034"\w* ennemis; \w plus|strong="H1471"\w* \w que|strong="H1471"\w* \w des|strong="H8034"\w* ruines! \w Tu|strong="H1471"\w* as détruit \w leurs|strong="H8034"\w* villes \w et|strong="H8034"\w* \w leur|strong="H4229"\w* mémoire \w a|strong="H3068"\w* péri.
