\p 
\v 12 \w Mephibosheth|strong="H4648"\w* \w had|strong="H1121"\w* \w a|strong="H3068"\w* \w young|strong="H1121"\w* \w son|strong="H1121"\w* \w named|strong="H8034"\w* \w Mica|strong="H4316"\w*. \w All|strong="H3605"\w* \w of|strong="H1121"\w* \w Ziba|strong="H6717"\w*’s \w family|strong="H1004"\w* \w became|strong="H5650"\w* \w servants|strong="H5650"\w* \w of|strong="H1121"\w* \w Mephibosheth|strong="H4648"\w*.
\v 13 \w And|strong="H4428"\w* \w Mephibosheth|strong="H4648"\w*, \w who|strong="H1931"\w* \w was|strong="H1931"\w* \w still|strong="H3427"\w* crippled \w in|strong="H3427"\w* \w both|strong="H8147"\w* \w of|strong="H4428"\w* \w his|strong="H5921"\w* \w feet|strong="H7272"\w*, started \w to|strong="H5921"\w* \w live|strong="H3427"\w* \w in|strong="H3427"\w* \w Jerusalem|strong="H3389"\w*, \w and|strong="H4428"\w* \w he|strong="H1931"\w* \w always|strong="H8548"\w* ate ◄\w at|strong="H3427"\w* \w the|strong="H5921"\w* \w king|strong="H4428"\w*’s \w table|strong="H7979"\w*/\w with|strong="H5921"\w* \w the|strong="H5921"\w* \w king|strong="H4428"\w*►.
\c 10
\s1 David’s army defeated the Ammon people-group
\p 
\v 1 Some \w time|strong="H1961"\w* \w later|strong="H1961"\w*, \w the|strong="H8478"\w* \w king|strong="H4428"\w* \w of|strong="H1121"\w* \w the|strong="H8478"\w* \w Ammon|strong="H5983"\w* people-group \w died|strong="H4191"\w*, \w and|strong="H1121"\w* \w his|strong="H1961"\w* \w son|strong="H1121"\w* \w Hanun|strong="H2586"\w* \w became|strong="H4427"\w* \w their|strong="H1961"\w* \w king|strong="H4428"\w*.
\v 2 \w David|strong="H1732"\w* thought, “\w Nahash|strong="H5176"\w* \w was|strong="H1732"\w* kind \w to|strong="H7971"\w* \w me|strong="H7971"\w*, \w so|strong="H6213"\w* \w I|strong="H5650"\w* \w will|strong="H5650"\w* \w be|strong="H3027"\w* kind \w to|strong="H7971"\w* \w his|strong="H7971"\w* \w son|strong="H1121"\w*.” \w So|strong="H6213"\w* \w David|strong="H1732"\w* \w sent|strong="H7971"\w* \w some|strong="H3027"\w* \w officials|strong="H5650"\w* there, \w to|strong="H7971"\w* tell \w Hanun|strong="H2586"\w* \w that|strong="H1121"\w* \w David|strong="H1732"\w* \w was|strong="H1732"\w* \w sorry|strong="H5162"\w* \w that|strong="H1121"\w* \w Hanun|strong="H2586"\w*’s \w father|strong="H1121"\w* \add had died\add*.
\p \w When|strong="H6213"\w* \w those|strong="H1121"\w* \w messengers|strong="H5650"\w* arrived \w in|strong="H6213"\w* \w the|strong="H6213"\w* land \w where|strong="H3027"\w* \w the|strong="H6213"\w* \w Ammon|strong="H5983"\w* people-group lived,
\v 3 \w the|strong="H3588"\w* \w leaders|strong="H8269"\w* \w of|strong="H1121"\w* \w the|strong="H3588"\w* \w Ammon|strong="H5983"\w* people-group said \w to|strong="H7971"\w* \w Hanun|strong="H2586"\w*, “\w Do|strong="H5869"\w* \w you|strong="H3588"\w* \w think|strong="H5869"\w* \w that|strong="H3588"\w* \w it|strong="H3588"\w* \w is|strong="H5892"\w* \w to|strong="H7971"\w* \w honor|strong="H3513"\w* \w your|strong="H3588"\w* \w father|strong="H1121"\w* \w that|strong="H3588"\w* King \w David|strong="H1732"\w* \w has|strong="H5650"\w* \w sent|strong="H7971"\w* \w these|strong="H1732"\w* \w men|strong="H1121"\w* \w to|strong="H7971"\w* say \w that|strong="H3588"\w* \w he|strong="H3588"\w* \w is|strong="H5892"\w* \w sorry|strong="H5162"\w* \w that|strong="H3588"\w* \w your|strong="H3588"\w* \w father|strong="H1121"\w* died [RHQ]? \add We think that\add* \w he|strong="H3588"\w* \w has|strong="H5650"\w* \w sent|strong="H7971"\w* \w them|strong="H7971"\w* here \w to|strong="H7971"\w* \w look|strong="H5869"\w* \w around|strong="H2015"\w* \w the|strong="H3588"\w* \w city|strong="H5892"\w* \w to|strong="H7971"\w* determine \w how|strong="H3588"\w* \w his|strong="H7971"\w* \add army\add* \w can|strong="H5650"\w* conquer \w us|strong="H3588"\w*!”
\v 4 \w Hanun|strong="H2586"\w* \add believed what they said; so he commanded some soldiers to\add* \w seize|strong="H3947"\w* \w David|strong="H1732"\w*’s \w officials|strong="H5650"\w* \w and|strong="H7971"\w* \add insult them by\add* shaving \w off|strong="H3772"\w* one side \w of|strong="H5650"\w* \w each|strong="H3947"\w* man’s \w beard|strong="H2206"\w*, \w and|strong="H7971"\w* \add by\add* cutting \w off|strong="H3772"\w* \w the|strong="H3947"\w* lower \w part|strong="H2677"\w* \w of|strong="H5650"\w* \w their|strong="H3947"\w* robes, \add with the result that their buttocks could be seen\add*, \w and|strong="H7971"\w* \w then|strong="H3947"\w* \w they|strong="H5704"\w* \w sent|strong="H7971"\w* \w them|strong="H7971"\w* \w away|strong="H7971"\w*.
\p 
