\v 6 \w Y|strong="G2532"\w* \w tú|strong="G4771"\w*, Belén, \w tierra|strong="G1093"\w* \w de|strong="G1537"\w* \w Judá|strong="G2448"\w*, \w de|strong="G1537"\w* ningún modo \w eres|strong="G1510"\w* \w la|strong="G3588"\w* \w más|strong="G2532"\w* pequeña \w entre|strong="G1722"\w* \w los|strong="G3588"\w* líderes \w de|strong="G1537"\w* \w Judá|strong="G2448"\w*, \w porque|strong="G1063"\w* \w de|strong="G1537"\w* ti \w saldrá|strong="G1831"\w* \w un|strong="G3588"\w* Caudillo \w que|strong="G3588"\w* \w apacentará|strong="G4165"\w* \w a|strong="G1722"\w* \w mi|strong="G3588"\w* \w pueblo|strong="G2992"\w* \w Israel|strong="G2474"\w*.   
