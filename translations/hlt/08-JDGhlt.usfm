\p \w Tedae|strong="H9999"\w* \w amih|strong="H9908"\w* \w te|strong="H9997"\w* Samson loh, “\w Kai|strong="H9901"\w* kah \w vaito|strong="H5697"\w* \w neh|strong="H9996"\w* na \w phayai|strong="H2790"\w* uh \w pawt|strong="H3884"\w* koinih \w ka|strong="H9901"\w* \w olkael|strong="H2420"\w* he na \w puk|strong="H4672"\w* uh \w mahpawh|strong="H3808"\w*,” a \w ti|strong="H0559"\w* nah.   
\p
\v 19 \w BOEIPA|strong="H3068"\w* \w Mueihla|strong="H7307"\w* loh \w Samson|strong="H9909"\w* te a \w thaihtak|strong="H6743"\w* sak \w dongah|strong="H9999"\w* \w Ashkelon|strong="H0831"\w* la \w suntla|strong="H3381"\w* \w tih|strong="H9999"\w* \w hlang|strong="H0376"\w* \w sawmthum|strong="H7970"\w* a \w ngawn|strong="H5221"\w*. \w Amih|strong="H9908"\w* kah \w pumoep|strong="H2488"\w* \w te|strong="H0853"\w* a \w loh|strong="H3947"\w* pah \w tih|strong="H9999"\w* \w olkael|strong="H2420"\w* aka \w thui|strong="H5046"\w* rhoek \w te|strong="H9997"\w* \w thovaelnah|strong="H2487"\w* himbai te a \w paek|strong="H5414"\w*. \w Tedae|strong="H9999"\w* \w a|strong="H9909"\w* \w thintoek|strong="H0639"\w* a \w sai|strong="H2734"\w* \w doeah|strong="H9999"\w* \w a|strong="H9909"\w* \w napa|strong="H0001"\w* \w im|strong="H1003"\w* la \w mael|strong="H5927"\w*.  
\v 20 \w Samson|strong="H8123"\w* \w yuu|strong="H0802"\w* te \w anih|strong="H9909"\w* \w taengah|strong="H9997"\w* aka \w luem|strong="H7462"\w* \w a|strong="H9909"\w* \w baerhoep|strong="H4828"\w* \w taengla|strong="H9997"\w* a \w om|strong="H1961"\w* pah.   
\b  
\c 15  
\s1 Samson kah Kutthung  
\p
\v 1 \w Khohnin|strong="H3117"\w* puet \w om|strong="H1961"\w* tih \w cangah|strong="H7105,H2406"\w* \w tue|strong="H3117"\w* \w vaengah|strong="H9996"\w* tah \w Samson|strong="H8123"\w* loh \w a|strong="H9909"\w* \w yuu|strong="H0802"\w* \w te|strong="H0853"\w* \w maae|strong="H5795"\w* \w ca|strong="H1423"\w* \w neh|strong="H9996"\w* a \w hip|strong="H6485"\w*. Te \w dongah|strong="H9999"\w*, “\w Ka|strong="H9901"\w* \w yuu|strong="H0802"\w* \w taengah|strong="H0413"\w* \w imkhui|strong="H2315"\w* \w la|strong="H9911"\w* ka \w kun|strong="H0935"\w* pawn ni,” a \w ti|strong="H0559"\w* van \w hatah|strong="H9999"\w* huta kah \w a|strong="H9907"\w* \w napa|strong="H0001"\w* loh \w anih|strong="H9909"\w* te \w kun|strong="H0935"\w* \w sak|strong="H5414"\w* \w pawh|strong="H3808"\w*.   
\p
\v 2 Te \w phoeiah|strong="H9999"\w* huta kah \w a|strong="H9907"\w* \w napa|strong="H0001"\w* loh, “\w Anih|strong="H9907"\w* he \w hnoel|strong="H8130"\w* rhoela na \w hnoel|strong="H8130"\w* \w tila|strong="H3588"\w* ka \w ti|strong="H0559"\w* khaw ka \w ti|strong="H0559"\w* coeng \w dongah|strong="H9999"\w* \w anih|strong="H9907"\w* he \w na|strong="H9905"\w* \w baerhoep|strong="H4828"\w* \w taengah|strong="H9997"\w* ka \w paek|strong="H5414"\w* coeng. \w A|strong="H9907"\w* \w mana|strong="H0269,H6996"\w* te \w anih|strong="H9907"\w* \w lakah|strong="H4480"\w* a \w then|strong="H2896"\w* ngai \w moenih|strong="H3808"\w* \w a|strong="H9994"\w*? \w A|strong="H9907"\w* ham \w yueng|strong="H8478"\w* la \w nang|strong="H9905"\w* \w taengah|strong="H9997"\w* tloep \w om|strong="H1961"\w* mai \w saeh|strong="H4994"\w*,” a ti nah.   
\p
\v 3 Te \w phoeiah|strong="H9999"\w* \w Samson|strong="H8123"\w* loh \w amih|strong="H9908"\w* \w te|strong="H9997"\w*, “\w Philisti|strong="H6430"\w* taeng \w lamloh|strong="H4480"\w* \w voeivai|strong="H6471"\w* tah m'\w hmil|strong="H5352"\w* dae saeh, \w amih|strong="H9908"\w* \w taengah|strong="H5973"\w* \w boethae|strong="H7451"\w* \w ka|strong="H0589"\w* \w saii|strong="H6213"\w* \w vaengah|strong="H3588"\w* he,” a \w ti|strong="H0559"\w* nah.   
\p
\v 4 Te \w phoeiah|strong="H9999"\w* \w Samson|strong="H8123"\w* te \w cet|strong="H1980"\w* \w tih|strong="H9999"\w* \w maetang|strong="H7776"\w* \w ya|strong="H3967"\w* \w thum|strong="H7969"\w* a \w tuuk|strong="H3920"\w*. \w Hmaithoi|strong="H3940"\w* a \w loh|strong="H3947"\w* \w tih|strong="H9999"\w* maetang a \w mai|strong="H2180"\w* neh \w mai|strong="H2180"\w* boeih a \w hlaengtang|strong="H6437"\w* pah. Maetang kah a \w mai|strong="H2180"\w* \w rhoi|strong="H8147"\w* \w laklo|strong="H8432"\w* \w ah|strong="H9996"\w* \w hmaithoi|strong="H3940"\w* a \w khih|strong="H7760"\w* pah.  
\v 5 \w Hmaithoi|strong="H3940"\w* te \w hmai|strong="H0784"\w* a \w hlae|strong="H1197"\w* \w tih|strong="H9999"\w* \w Philisti|strong="H6430"\w* kah \w canghli|strong="H7054"\w* \w ah|strong="H9996"\w* a \w hlah|strong="H7971"\w* \w vaengah|strong="H9999"\w* \w canghlom|strong="H1430"\w* \w lamloh|strong="H4480"\w* \w canghli|strong="H7054"\w* \w khaw|strong="H9999"\w*, \w misur|strong="H3754"\w* neh \w olive|strong="H2132"\w* \w khaw|strong="H9999"\w* boeih a \w ung|strong="H1197"\w* pah.   
\p
\v 6 Te \w dongah|strong="H9999"\w* \w Philisti|strong="H6430"\w* rhoek loh, “\w He|strong="H2063"\w* he \w ulae|strong="H4310"\w* aka \w saii|strong="H6213"\w*,” a \w ti|strong="H0559"\w* uh \w hatah|strong="H9999"\w*, “\w A|strong="H9909"\w* \w yuu|strong="H0802"\w* \w te|strong="H0853"\w* a \w bong|strong="H3947"\w* pah \w tih|strong="H9999"\w* \w a|strong="H9909"\w* \w baerhoep|strong="H4828"\w* \w taengla|strong="H9997"\w* vik a \w paek|strong="H5414"\w* pah \w dongah|strong="H3588"\w* \w Timni|strong="H8554"\w* \w cava|strong="H2860"\w* \w Samson|strong="H8123"\w* loh a saii,” a \w ti|strong="H0559"\w* uh. Te \w dongah|strong="H9999"\w* \w Philisti|strong="H6430"\w* rhoek te \w cet|strong="H5927"\w* uh \w tih|strong="H9999"\w* \w amah|strong="H9907"\w* \w khaw|strong="H9999"\w* \w a|strong="H9907"\w* \w napa|strong="H0001"\w* \w te|strong="H0853"\w* khaw \w hmai|strong="H0784"\w* \w neh|strong="H9996"\w* a \w hoeh|strong="H8313"\w* uh.   
\p
\v 7 \w Tedae|strong="H9999"\w* \w amih|strong="H9908"\w* \w te|strong="H9997"\w* \w Samson|strong="H8123"\w* loh, “\w He|strong="H2063"\w* \w bang|strong="H9995"\w* he na \w saii|strong="H6213"\w* uh \w van|strong="H0518"\w* \w dongah|strong="H3588"\w* \w nangmih|strong="H9904"\w* phu kan \w loh|strong="H5358"\w* \w daengah|strong="H9999"\w* ni ka \w paa|strong="H2308"\w* eh?,” a \w ti|strong="H0559"\w* nah.   
\p
\v 8 \w Amih|strong="H9908"\w* \w te|strong="H0853"\w* a \w hlit|strong="H3409"\w* neh a \w laeng|strong="H7785"\w* \w dongah|strong="H5921"\w* \w hmasoe|strong="H4347"\w* \w len|strong="H1419"\w* neh a \w taam|strong="H5221"\w* \w daengah|strong="H9999"\w* \w suntla|strong="H3381"\w* \w tih|strong="H9999"\w* \w Etam|strong="H5862"\w* \w thaelpang|strong="H5553"\w* kah \w thaelvap|strong="H5585"\w* \w khuiah|strong="H9996"\w* kho a \w sak|strong="H3427"\w*.   
