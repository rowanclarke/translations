\id 3JN  
\h 3 Juan 
\toc1 To̱ꞌon yóꞌo kía̱n kúú oni̱ ni̱ taa San Juan 
\toc2 3 Juan 
\toc3 3 Jn. 
\mt1 To̱ꞌon yóꞌo kía̱n kúú oni̱ ni̱ taa San Juan 
\c 1  
\s1 Káꞌa̱n Juan ndisáꞌán 
\p  
\v 1 Yuꞌu̱ kúú na̱ sáꞌano, ta káꞌa̱n yuꞌu̱ ndisáꞌán xíꞌín yoꞌó, Gayo, ñani mani̱. Miía̱n ndaa̱ ndisa kúꞌu̱ nda̱ꞌo inii̱ sa̱ꞌo̱n.  
\v 2 Ñani mani̱, xíka̱i̱ noo̱ Ndios ña̱ daá keva̱ꞌón tein ndidaá kúú ña̱ꞌa kéeón, ta daá kuití ná koo va̱ꞌa ino̱n táto̱ꞌon ki̱ꞌo va̱ꞌa nímo̱n noo̱ Ndios.  
\v 3 Ni̱ kadii̱ nda̱ꞌo inii̱ tá ni̱ kixi dao ñani yo̱ kuendá Jesús, chi̱ ni̱ na̱kani na xíꞌíín ña̱ íin ndaa̱o̱n xíꞌín ña̱ ndaa̱ kándísa yó.  
\v 4 Ta ko̱ó iin ka̱ ña̱ꞌa xíꞌo ña̱ kádii̱ cháá ka̱ inii̱ táto̱ꞌon ki̱ꞌo kádii̱ inii̱ tá níꞌi̱ to̱ꞌin ña̱ ndíta ndaa̱ de̱ꞌi kuendá Jesús xíꞌín ña̱ ndaa̱ kándísa yó. 
\s1 Va̱ꞌa va kée Gayo, chi̱ nátiin va̱ꞌa ra na̱ kúú kuendá Jesús veꞌe ra 
\p  
\v 5 Ñani mani̱, va̱ꞌa va kéeón tá chíndeéón ndidaá ñani yo̱, ta va̱ꞌa cháá ka̱ kéeón tá kéeón dión xíꞌín na̱ ko̱ náꞌón.  
\v 6 Ta na̱ yóꞌo kúú na̱ xíꞌo kuendá noo̱ na̱ kúú kuendá Jesús ndéi yóꞌo ña̱ kúꞌu̱ nda̱ꞌo ino̱n saꞌa̱ ná. Ta va̱ꞌa keeón tá chindeéón na̱ xíꞌín ndá ña̱ꞌa xínñóꞌó ná noo̱ koꞌo̱n na̱, chi̱ ki̱ꞌo dión kánian kee yó xíꞌín ná saꞌa̱ ña̱ kéchóon na noo̱ Ndios, dá kuu koꞌo̱n na̱ dao ka̱ xíán.  
\v 7 Chi̱ sa̱ꞌá ña̱ kóni̱ na̱ Jesús, sa̱ꞌá ño̱ó ni̱ ka̱nkuei na xíonoo na dánaꞌa̱ na̱, ta ko̱ kíꞌin ya̱ꞌi taꞌon na no̱ó ña̱yuu ko̱ náꞌá Ndios.  
\v 8 Sa̱ꞌá ño̱ó kánian ki̱ꞌo yó ña̱ꞌa xínñóꞌó ná, ta ki̱ꞌo dión chíndeé yó na̱ noo̱ dánaꞌa̱ na̱ to̱ꞌon ndaa̱ saꞌa̱ Jesús. 
\s1 Naá iin ra̱ naní Diótrefes xíꞌín Juan 
\p  
\v 9 Sa̱ ni̱ taa yuꞌu̱ iin tuti ko̱saa̱ no̱ó na̱ kúú kuendá Jesús ndéi xaa̱n, tído ko̱ xi̱ín taꞌon Diótrefes kueídóꞌo ra choon saꞌándá ndu̱, chi̱ kóni̱ mií rá kaꞌanda ra̱ choon.  
\v 10 Ta sa̱ꞌá ña̱ kée ra dión, sa̱ꞌá ño̱ó tá ná saa̱i̱, dá kaꞌi̱n xíꞌín rá, dá chi̱ xíonoo ra káꞌa̱n ndava̱ꞌa ra saꞌa̱ ndúꞌu̱. Ta ko̱ ndínoo ini ra̱ xíꞌín ña̱ yóꞌo oon ni, chi̱ dión taꞌani ko̱ kóni̱ ra̱ natiin va̱ꞌa ra ñani yo̱, na̱ xíonoo dánaꞌa̱ to̱ꞌon Ndios. Ta ko̱ sónó rá ña̱ natiin va̱ꞌa ñaá dao ka̱ ñani yo̱. Ta kúú táxí rá na̱ káꞌán natiin va̱ꞌa ñaá. 
\s1 Va̱ꞌa káꞌa̱n Juan saꞌa̱ iin ra̱ naní Demetrio 
\p  
\v 11 Ñani mani̱, o̱ sa̱ kóo ino̱n keeón ña̱ kini kée dao ka̱ ña̱yuu. Diꞌa koo ino̱n keeón ña̱ kúú ña̱ va̱ꞌa. Chi̱ na̱ kée ña̱ va̱ꞌa kúú kuendá Ndios, ta na̱ ko̱ kée ña̱ va̱ꞌa, no̱ón kúú na̱ ko̱ náꞌá Ndios.  
\v 12 Ta ndidaá kúú na̱ kúú kuendá Jesús xíꞌo na kuendá saꞌa̱ iin ka̱ ta̱a naní Demetrio ña̱ kúú rá ta̱a va̱ꞌa, ta miía̱n ndaa̱ ndisa dión kíán. Nda̱ nduꞌu̱ xíꞌo kuendá ña̱ ta̱ va̱ꞌa kúú rá, ta sa̱ náꞌá vá miíón ña̱ kuendá xíꞌo nduꞌu̱ kúú ña̱ ndaa̱. 
\s1 Káꞌa̱n Juan ndisáꞌán noo̱ ndíꞌi xíꞌín Gayo 
\p  
\v 13 Kua̱ꞌá nda̱ꞌo ña̱ꞌa ió kaꞌi̱n xíꞌón, tído ko̱ kóni̱ taai ña̱ noo̱ iin tuti,  
\v 14 chi̱ ndáti kíi̱i̱ konii̱ yo̱ꞌó, ta kantóꞌón yúꞌí xíꞌón. 
\p  
\v 15 Ta ná koo va̱ꞌa ino̱n kee Ndios. Ta káꞌa̱n na̱ néꞌe táꞌan va̱ꞌa xíꞌón ndéi yóꞌo ndisáꞌán xíꞌón. Ta keeón ña̱ mani̱ kaꞌo̱n ndisáꞌán xíꞌín iin rá iin na̱ néꞌe táꞌan va̱ꞌa xíꞌín nduꞌu̱ ndéi xaa̱n.