\li1 Sanyii Ziihaa, sanyii Hasuufaa, sanyii Xabaaʼoot,
\li1 
\v 47 sanyii Keeroos, sanyii Siiʼaa, sanyii Faadon,
\li1 
\v 48 sanyii Lebaanaa, sanyii Hagaabaa, sanyii Shalmaayi,
\li1 
\v 49 sanyii Haanaan, sanyii Gideel, sanyii Gahar,
\li1 
\v 50 sanyii Reʼaayaa, sanyii Reziin, sanyii Neqoodaa,
\li1 
\v 51 sanyii Gazaam, sanyii Uzaa, sanyii Faasehaa,
\li1 
\v 52 sanyii Beesaay, sanyii Meʼuuniim, sanyii Nefuushesiim,
\li1 
\v 53 sanyii Baqbuuq, sanyii Haquufaa, sanyii Harhuur,
\li1 
