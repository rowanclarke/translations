\id HAB - Kuna, San Blas - Bible -Panama 2014 (DBL -2014) 
\h Habacuc 
\toc1 Habacuc-Garda 
\toc2 Habacuc 
\toc3 Hab 
\mt1 HABACUC-GARDA 
\mt2 HABACUC 
\imt2 GEBE-SOGLENAID 
\imt1 Garda-nug 
\ip \it Habacuc-Garda.\it* Judá-dulemar Babilonia-yarse selesmalad-idu, Habacuc, Judá-dulemarga Bab-Dummad-gayaburba-barsoged-napidga gusadid. Dulemar dogdar innikimakar e-nug-obarileged wissulid. Egi binsaledo, wede \it Angaagwar-gaed,\it* e-nug obarileye. 
\is1 Habacuc-Gardagi weyob sunmaklenaid 
\ip Habacuc, Judá-dulemar Babilonia-dulemarse gebe-gales-seledsokarmalad-idu ega sunmaksa gusad. Habacucʼgi binsaleged, Sofonías-ibagangi, Jeremías-ibagangi, degine, Nahúm-ibagangi, Bab-Dummad-gayaburbagi sunmaksaye. 
\ip Habacuc, Bab-Dummad-ibmar-imaknaidba ese egisnai gusad, ibiga Judá-dulemar deyob ibmar imaknaiye. Habacuc, Judá-dulemar-daed nabir daksursoggu, Bab-Dummadga sognai gusad: “We-dulemar be sabsur-odurdakye.” Bab-Dummadi, Habacuc-ese-gochad itosad. Geb ega sogsad: “We-dulemar, Babilonia-sordamarse sabsur-odurdaklemaloye.” 
\ip We-gardagine, weyob ilemakar sunmaklenaid: 
\io1 1. Igar-inniki-imaklesulidba, Habacuc sabsur-ibmar soged (1:1-4). 
\io1 2. Bab-Jehová, Habacuc-abin-imaksad (1:5-11). 
\io1 3. Habacuc, Bab-Dummadga gannar-ibmar soged (1:12-17). 
\io1 4. Bab-Jehová, Habacuc-abin-imaksad (2:1-5). 
\io1 5. Dule-inniki-ibmar-imaksurmalad, dummad-wilegoed (2:6-20). 
\io1 6. Habacuc, Bab-Dummadse-goled (3:1-19). 
\ip Be itogua. 
\c 1  
\ms1 1. IGAR-INNIKI-IMAKLESULIDBA, HABACUC SABSUR-IBMAR SOGED 
\mr (1:1-4) 
\p  
\v 1 Bab-Dummad-gayaburba-barsoged-Habacuc negburgan-daksagua, we-gayaburba ega soglesad. 
\s1 Habacuc, Bab-Dummadga ibmar soged 
\q1  
\v 2 Bab-Jehováʼye, ¿sanagwadse an bese bendakleged egisnaiguoe? 
\q2 Emide, gwen be an-itosulid. 
\q1 ¿Sanagwadse dulemar-sabsur-imakledimalad-ular, an bese gornaiguoe? 
\q2 Emide, gwen be anmar-bendaksulid. 
\q1  
\v 3 ¿Ibigala, igar-innikwad-imaklesulid-dakega be an-imake? 
\q2 ¿Ibiga ibmar-isgana-imaklenaid-dakega be an-imake? 
\q1 Unnila neg-gagalenaidbi, degi, dule-sabsur-imaklegedbi an daked. 
\q2 Urwelegedbi, degi, na abin-abin-imakmaladbi neg-naid. 
\q1  
\v 4 Agala, igar-maidba ibmar-imaklesulid, 
\q2 igar-innikigwad-imakleged bar imaklesulid. 
\q1 Dule-isgana dule-nued-balegindiid, 
\q2 dulemarga igar-innikigwadba igar nabolesulid. 
\ms1 2. BAB-JEHOVÁ, HABACUC-ABIN-IMAKSAD 
\mr (1:5-11) 
\p  
\v 5 Bab-Jehová sogded: 
\q1 “Dule-yar-baid-baidgi-bukwamalad be dakmala. 
\q2 Nuekwaa be dakmala, geger-dakbukwa be gumala. 
\q1 We-ibagangi ibmar-gegerdaklemalad an imaksokalid, 
\q2 amba dule bemarga a-ibmar-imaklegoed-odulogele, bemar amba bengumaloed. 
\q1  
\v 6 Caldea-dulemar an bemargi bila-onodagega imaknaid, 
\q2 we-dulemar, dule-isgana-nanaed, binna-binnasuli ibmar-imakmaladid. 
\q1 Dule-baid-ibe napa-suega bela napneg-ebirdii damalad. 
\q2  
\v 7 We-dulemar dule-buleganad, dule-ogwayemaladid, 
\q1 na e-sogedba igar-innikigwad-imakleged imakmaladid. 
\q2 Na e-nugbi-dummarbagued amidimaladid. 
\q1  
\v 8 E-molimar, achu-barbadba bur bule abarmakmalad, 
\q2 achu-sapurba bur bule ursirmalad. 
\q1 E-sordamar-moli-birgi-bila-onomalad sabsur-abarmakmalad, 
\q2 we-sordamar dikasur danimalad. 
\q1 Igi sulubagi e-mas-daksale, binnasuli egi melleardae, 
\q2 deyobi dulemargi mellear damalad. 
\q1  
\v 9 We-dulemar unnila emar-sabsur-imakega danimalad, 
\q2 e-nadapmaladba neg-dobedbi nasiknadapmalad. 
\q2 Ukub-weeyobi dulemar-gamalad. 
\q1  
\v 10 Reymar-mamaidgi burgunagus damalad, 
\q2 sapin-dummagan-negsemamaidgi dodonagus damarbalid. 
\q1 Neggwebur-galu-matusur-nikamaladga allenana damalad, 
\q2 ar ade, a-neggweburmargi-dogegala arsanyob napamar sobmalad. 
\q1  
\v 11 We-dulemar burwa-dummadyobi bela ese ibmar oitoledaed. 
\q2 E-gangued e-bab-dummadga imakdimalad. Agi e-isgued siid.” 
\ms1 3. HABACUC, BAB-DUMMADGA GANNAR-IBMAR SOGED 
\mr (1:12-17) 
\q1  
\v 12 Be, Bab-Jehová, bato be negasaila-akale gudiid. 
\q2 Be, an-Bab-Dummad-isligwaled, be degisadegu dula maid. 
\q1 Be, Bab-Jehová, igar-innikigwad-imakmalaga be Babilonia-dorgan urbisad. 
\q2 Be, akwasaila-dukuedyob anmarga gued. 
\q2 Anmar-sabsur-odurdaked-oyogega be Babilonia-dorgan urbisad. 
\q1  
\v 13 Be, bela-bela dule-swilidikgusoggu, ibmar-isgana be abesulid. 
\q2 Dule-sabsur-imakleged be yeer daksurbalid, 
\q1 degite, ¿ibiga be dule-isganamar baisur-daksunna? 
\q2 Dule-isganamar dule-nuegan-sabsur-imaknaid be dakmaidgi, 
\q2 ¿ibiga be gayamakar maisunna? 
\q1  
\v 14 Uamar-e-idued-satedyobi be dulemar-imaksad, 
\q2 ibmar-unimalad-e-idued-satedyob be dulemar-imaksad. 
\q1  
\v 15 A-ulale, Babilonia-dorgan achwergi-uasoeyobi dulemar-gamalad. 
\q2 E-sakigi ua-galesar-ebipidamaladyobi dulemar-ebipimalad. 
\q1 E-saki-ollo-ollogwad-imbaba ua-galesnanaid-weedyobi dulemar-wemalad, 
\q2 degidba, yeer itomalad, weligwar itomalad.\fig Ua-gaed-dule, sakigi ua-ganaid. (Habacuc 1:14-15) |src="LB00210B.TIF" size="col" ref="Habacuc 1:15" \fig* 
\q1  
\v 16 A-ulale, Babilonia-dorgan na e-sakiga bab-dummadyobi ega ibmar-ukleged ukmalad. 
\q2 E-sakiga ina-wawadikid ogumakmalad. 
\q1 Ar e-saki-nukad na e-masgunned bukidar nikad, 
\q2 e-mas yeer gullebalid. 
\q1  
\v 17 Ar deyobi, Babilonia-dorgan, dulemar-wiogega, ¿na e-saki-midii gumaloe? 
\q2 ¿Dulemar-gwen-wiledaksuli gindakdii gumaloe? 
\c 2  
\ms1 4. BAB-JEHOVÁ, HABACUC-ABIN-IMAKSAD 
\mr (2:1-5) 
\p  
\v 1 Habacuc sogdebalid: 
\q1 An nakuledii imakoed, 
\q2 aila-birgi an edarbegwichi imakoed. 
\q1 Bab-Jehová anga-ibmar-sogdagoed an nue-itoagwar itogoed, 
\q2 an ega ibmar-sogsad igi-an-abin-imakdagodibe. 
\s1 Bab-Jehová, Habacuc-abin-imaksad 
\p  
\v 2 Bab-Jehová an-abin-imaksad: 
\q1 “Be negburgan-daknaid narmake, 
\q2 urgogi magar-daklege, be nuekwaa narmako, 
\q2 adi, nabir baisursunna absolegegar. 
\q1  
\v 3 Ar negburgan-oyolenaidi, na e-iba-sogedba gunonikoed, 
\q2 bela a-ibmarmar-gunadapid, bela guedsegad. 
\q1 Ar we-ibmar gwen emiskwaa guosur-inigwele, be abitogo, 
\q2 ar bela guedsegad. 
\b  
\q1  
\v 4 ”Dule-isgana e-gwagegi innikidasulid. 
\q2 Dule-gwage-swilidikiddi, Bab-Jehováʼgi-bensulidgi gudii guoed. 
\q1  
\v 5 Napiragwa, ibmar-bukidar-nikuedi dulegi aibined. 
\q2 A-ulale, dule-na-san-dummarba-imakedi, undar-gudii guosulid. 
\q1 Ar a-dule, neg-uan-mui-dodaeyobi sulibinsa ibmarbina itoged. 
\q2 Burgwedyobi bogigudisulid, napi-ibmar abedaed. 
\q1 Bela yarmar-nanaid ese sulemaid, 
\q2 bela dulemar ese galemamaid.” 
\ms1 5. DULE-INNIKI-IBMAR-IMAKSURMALAD, DUMMAD-WILEGOED 
\mr (2:6-20) 
\p  
\v 6 Bab-Jehová sogdebalid: 
\q1 “Dulemar-galesmaladi, yoedsega, dulemar-e-gasmaladgi burgunanai gumaloed, 
\q2 galagwensuli egi sunmaknanai gumaloed. 
\q1 Weyobi ega namaknanai gumaloed: 
\q2 ‘Dule, emar-ibe-ibmar-suedba mani-ibedga-guedi, ¡duledar-wiles! 
\q1 Dule, emar-ibe ibmar-galemalad egadga-omelodimaladi, ¡duledar-wiles! 
\q2 ¿Sanagwadse be deyob-gudiid indakoe?’ 
\q1  
\v 7 Bese dulemar-mesagwar-imaklediid, ukiagwar begi gwisgudagoed. 
\q2 We-dulemar wawanmakega be-imaknonimaloed, 
\q2 sabsuli be-annik ibmar sunonimaloed. 
\q1  
\v 8 Ar be yarmar-bamalad-ibe ibmar atur-imaksasoggu, 
\q2 yarmar-bamalad-bese-atursalessurmaladdi, be-ibe ibmar atursamarmogoed. 
\q1 Ar emar-ibe be wilub-obicha ablis-eosad, 
\q2 degi, we-yar-naidi be sabsur-imaksad, 
\q1 e-neggwebur be sabsur-imaksad, 
\q2 e-dulemar be sabsur-imaksabalid, 
\q2 a-ulale, deyobi be-imakmarmogoed. 
\b  
\q1  
\v 9 ”Dule atursaale ibmar-ena na e-neg-siedi, ¡duledar-wiles! 
\q2 Ar na binsasanad, deyobi na e-neguya bendakoye, 
\q2 deyobi bar an wiledii guosurye. 
\b  
\q1  
\v 10 ”Weyobi be binsaedba na be-neguya bingeguega imaksad. 
\q2 Bukidar be dulemar-ogilonai-gusadba, na be dukin obeloed amisad. 
\q1  
\v 11 A-ulale, akwa-galumarse-bakale, 
\q2 degi, urgomar nagubirga-mamaid-bakale, begi aibitemaloed. 
\b  
\q1  
\v 12 ”Dule emar-ibe-ablis-eogar neggwebur-sobed, ¡duledar-wiles! 
\q2 Dule-sabsur-imakedgi neggwebur-urbed, ¡duledar-wiles! 
\q1  
\v 13 Ar ani Bab-Jehová-Bur-Gangued-Nikadi, 
\q1 dulemar-e-ibmar-imaked, ¿soogi-ogumaklegega igar mesissursi? 
\q2 Dulemar binsarsunna, ¿geggus-alamaknaiguega igar mesissursi? 
\q1  
\v 14 Ar igi-dii demar-enarkwaa sigisdae, 
\q2 deyobi napnega Bab-Jehová-e-gargangued-yeerdakleged magar-dake guoed. 
\b  
\q1  
\v 15 ”Dule e-ai-omumguedi, ¡duledar-wiles! 
\q2 Dule e-ai-uka-swana-dakega, vinoʼgi e-ai-omumguoedi, ¡duledar-wiles! 
\q1  
\v 16 Degidba na be dukin be-nug oichosad, 
\q2 gwen be na be-nug odummossulid. 
\q1 Degisoggu, be vino gobmosunna, 
\q2 an na be Bab-Dummad-akudaked oyosunna. 
\q1 Bab-Jehová e-argan-nuedgi bingegued-nog-ganisiid gobega be-imake, 
\q2 be-nug-dummarba-nikad, bipii imakega imake. 
\q1  
\v 17 Babilonia-dorgan, be Líbano-yar-sabsur-imaksagusad begi aibinoed. 
\q2 Be ibdurgan-ogilosgusad, dobguega be-imakoed. 
\q1 Ar be dulemar-ibe doggus ablis eosad, 
\q2 e-yar-naid be sabsur-imaksad, 
\q1 e-neggweburmar, degi, e-dulemar be sabsur-imaksad. 
\q2 A-ulale, be sabsur-odurdaklemogoed. 
\b  
\q1  
\v 18 ”Duleyob-ibmar-sobaledi, ¿ibi-nuedga wis gue? Ibmar-nuedga gusuli. 
\q2 Nuchu-esgoro-diregwadgi-sobaledi, ¿ibi-nuedga wis gue? Unnila gakansaedginbi emar-odurdaked. 
\q2 Dule nuchu-gege-sunmaked-sobedi, unnila na e-arbaedginbi bensulid. 
\q1  
\v 19 Dule suar-sobaledga sogdibe: ‘¡Atake!’ 
\q2 ¡We-dule, duledar-wiles! 
\q1 Dule akwa-sobaledga sogdibe: ‘¡Gwisgue!’ 
\q2 ¡We-dule, duledar-wiles! 
\q1 Ar we-ibmarmar amba bela or egi-ebiris-nai-inigwele, 
\q2 amba bela mani egi-ebiris-nai-inigwele, 
\q1 gege ibmargi be-odurdaked, 
\q2 ar burba sated, unnila uka-ollobi gued. 
\q1  
\v 20 Ar Bab-Jehováʼdi na e-neg-islidikidgi maid. 
\q2 Bela dulemar Bab-Jehová-asabin gaya-bogidik gumala.” 
\c 3  
\ms1 6. HABACUC, BAB-DUMMADSE-GOLED 
\mr (3:1-19) 
\p  
\v 1 Bab-Dummad-gayaburba-barsoged-Habacuc, Bab-Dummadse-goled. We-Bab-Dummadse-goledi, Sigionot-gar-goledba gorlegoed. 
\b  
\q1  
\v 2 Bab-Jehová, be-nug-dummarba-gued an itosad, 
\q2 Bab-Jehová be-ibmar-imaksadi, be-dobekwaa-nanaega an-imaked. 
\q1 Bab-Jehováʼye, emi anmar-dulagudiidgi be gannar a-ibmarmar imake, 
\q2 be gannar a-ibmarmar oyoge. 
\q1 Bab-Jehováʼye, be uludele, 
\q2 be-dule-wiledaked mer be iego. 
\b  
\q1  
\v 3 Bab-Dummad neg-Temánʼye-nugad-akale, danikid, 
\q2 Dule-Isligwaled yar-Paránʼye-nugad-akale, danikid. 
\b  
\q1 Bab-Dummad-e-gangued-yeerdakleged bela nibneg-gasad, 
\q2 bela dulemar-we-napneggi-bukwadi e-nug odummomalad. 
\q1  
\v 4 E-dakarmakedi, mala-dakarmakmaiyobi gued. 
\q2 E-argangine malamar milemaid, 
\q2 agine, e-gargangued dukuar maid. 
\q1  
\v 5 Bab-Dummad-daged-idu, bonigan-bulegan ainied. 
\q2 Bab-Dummad-sorbali, soo-ginnitibi danidaed. 
\q1  
\v 6 Bab-Dummad gwisgunonikile, napaneg giglimakde daed. 
\q2 Dulemar-yar-baid-baidgi-bukwad-dakdele, dulemar wawanmakde daed. 
\q1 Bela yar-dummagan-dikasurgus-bubukwad malud daed, 
\q2 yar-senigana-sergan-bubukwad babatid daed, 
\q2 ar Bab-Dummad-igardi degisadeguad. 
\b  
\q1  
\v 7 Cusán-dulemar-danar-danar-bukwadi, suli-suli-itobukwa an daksad. 
\q2 Madián-dulemar-bukwadi, bela-bela dobe-itobukwa an daksad. 
\b  
\q1  
\v 8 Bab-Jehová, ¿diwarmarse be ulus gusa? 
\q2 ¿Suke-iirmakmaidse be urwemai gusa? 
\q1 Be-moli-birgi-sii be abarmakmaigua, be-ur-napagined-gege-galakuedgi be nakwisgua, 
\q2 ¿demarse be nue-urwemai gusa? 
\b  
\q1  
\v 9 Be-warsi na be guagwar ganikid, 
\q2 be-saguyaba sigumar be enosad. 
\b  
\q1 Be napaneg-marisadgi dii-iirmakega imaksad. 
\q2  
\v 10 Yarmar-bubukwad be-dakdedba wawanmakdemalad. 
\q1 Mogirmala, diidar-dummad owinonikid, 
\q2 muu-billi binnasuli uurmakded, demar-mullugana dunguded. 
\q1  
\v 11 Be-mala-ibyemaidba, dad-ibeler geg gaed, 
\q2 be-mala-dakarmakmaidba nii geg noed. 
\q1  
\v 12 Sae-itodiidba, napneggi be bipirmakdiid. 
\q2 Urwedgine, be dulemar-sabsur-imaked. 
\b  
\q1  
\v 13 Be-dulamar-bendakegala, be noalid, 
\q2 na be dule-nug-imaksad-bendakegala, be noalid. 
\q1 Dule-isganamar-e-rey-nono, be maad imaksad, 
\q2 bela e-negsemaid e-ibe be obelosad. 
\b  
\q1  
\v 14 E-sordamar-e-nono, be-eswargi be buudu imaksad, 
\q2 we-sordamar an-oaisakiega burwa-dummadyobi, angi yolenonikid. 
\q1 Dule-wileged dule-e-bendaked-satedba, igi dule egi yolenonidae, 
\q2 deyobi, we-sordamar bela-bela-yeer-itogedba angi yolenonikid. 
\q1  
\v 15 Be-moli-birgi-sii, be demargi bipirmakdiid, 
\q2 demar-binnasuli-arwemamaid-birgi, be bipirmakdiid. 
\b  
\q1  
\v 16 An deyob itosgua, bela an-gwage-ulubse an-ebusad, 
\q2 an be-gaya-itosgua, an-gakuli wawanmakded. 
\q1 Bela an-garmala gulleded, an-nagmar bela nollomakded. 
\q2 Degi-inigwele, andi binnalee, anmar-wionanaid-e-sabsur-odurdaklegoed-iba-nonikoedi, an edarbed. 
\b  
\q1  
\v 17 Ar amba sapi-higuera sanmaksulile, 
\q2 uva-dubmar sanmaksurbalile, 
\q1 andi Bab-Jehováʼgi yeer itogoed, 
\q2 Bab-Dummad-an-abonogedgi, an weligwar itogoed. 
\q1 Amba olivo-sapi e-san nikusulile, 
\q2 amba nainumargi ibmar-gwag welesurbalile, 
\q1 andi Bab-Jehováʼgi yeer itogoed, 
\q2 Bab-Dummad-an-abonogedgi, an weligwar itogoed. 
\q1 Amba sibad-wawaadmar e-galugi bar bukwasulile, 
\q2 amba moli-bebe-nikad wargwensaale, e-galugi bar bukwasurbalile, 
\q1  
\v 18 andi Bab-Jehováʼgi yeer itogoed, 
\q2 Bab-Dummad-an-abonogedgi, an weligwar itogoed. 
\b  
\q1  
\v 19 Bab-Jehová-Bela-Gangued-Nikadi, an-ogannogedid. 
\q2 Goe-sapur-gwae-gwae-abarmakeyobi, an-imaked, 
\q2 nega-matusulidganba nanaega an-imaked. 
\b  
\d Gar-gormalad-dub-nikadba-namaklegega narmaklesad. Namakmalad-e-iduedga narmaklesad.