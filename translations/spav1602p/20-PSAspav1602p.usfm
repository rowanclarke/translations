\v 8 \w Y|strong="H3068"\w* \w no|strong="H3808"\w* \w sean|strong="H1961"\w* \w como|strong="H1961"\w* sus padres, \w generación|strong="H1755"\w* \w contumaz|strong="H5637"\w* y \w rebelde|strong="H5637"\w*; \w Generación|strong="H1755"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w apercibió|strong="H3559"\w* su \w corazón|strong="H3820"\w*, \w ni|strong="H3808"\w* \w fue|strong="H1961"\w* fiel \w para|strong="H1961"\w* con Dios su \w espíritu|strong="H7307"\w*.
