\id 3JN
\h ÁR HÑU AR XUWA
\toc1 ÁR HÑU AR XUWA Ár hñu ar he̱ꞌmi bi ꞌyotꞌa ar Xuwa
\toc2 ÁR HÑU AR XUWA
\toc3 3 Jn.
\mt1 ÁR HÑU AR XUWA
\mt2 Ár hñu ar he̱ꞌmi bi ꞌyotꞌa ar Xuwa
\c 1
\s1 Ar nze̱ngwa
\p 
\v 1 Nuga dar Xuwa ar dönzia, di otꞌa nunar he̱ꞌminu̱, ma tsi hmöka ku Gayo togo di möꞌi ngetho gi te̱nga nöꞌö majöni.
\p 
\v 2 Ma tsi hmöka kuꞌi, di a̱pa Jö da bo̱nga gatho xiñho nöꞌö gi pe̱fi, ne gi pe̱ꞌsa ar nzaki, ngu ꞌyo di xu ár tsꞌe̱di Jö ha ri mu̱i.
\p 
\v 3 Xa da njohya núꞌmu̱ mba e ya ku bi xikagi nöꞌö majöni ja ha ri mu̱i, ne hanja gi umba ri mu̱i gi te̱nu̱.
\p 
\v 4 Hiñꞌotho manꞌar johya di töta nöꞌö xta o̱de, nuꞌu̱ po̱ntho ma bötsi xa umba yá mu̱i te̱nga nöꞌö majöni.
\s1 Ar Gayo tꞌeꞌspa ár nsu unga nse̱ki hár ngu
\p 
\v 5 Ma tsi kuꞌi, xa gi o̱tꞌa nꞌar hoga ꞌbe̱fi gi fa̱xa ya ku, ne mꞌe̱tꞌo nuꞌu̱ hinga ri mpödi.
\p 
\v 6 Nuya kuꞌu̱ xi da̱majöni har nijö xa gi pe̱ꞌsar mhöte. Jange di beni xiñho hingi hye̱pꞌu̱tho njapꞌu̱. Fa̱tsꞌi da ñꞌo yá ꞌñu, ngu di ꞌñepi da mfa̱xa nꞌár ꞌbe̱go Jö, ne da zo̱nga habu̱ di maꞌu̱.
\p 
\v 7 Nuya kuyu̱ mpe̱fi ngetho möpa ár thuhu ar tsi Hmu, ne hingi hömba yá mfa̱tsꞌi umba nuꞌu̱ hingya gamfi.
\p 
\v 8 Nuju̱ dar gamfihu̱ꞌmu̱, ma ga fa̱xu̱ nuya kuyu̱, ne njapꞌu̱ ga mfa̱xtehu̱ da nu̱nga nöꞌö majöni.
\s1 Ar Diotrefe ne da tsꞌoka ar ꞌbe̱fi
\p 
\v 9 Nuga xta otꞌwa ar nijö, ha nunar Diotrefe togo o̱tꞌa ndöta madeda ya ku, hingi japamasu nöꞌö di xife.
\p 
\v 10 Jange nuꞌmu̱ xka mapꞌu̱, ma ga xiꞌahu̱ ha ri mhuntsꞌihu̱ gatho nuya te o̱tꞌa nunar Diotrefe. Ju̱sje ya nhemhñö. Hinge ho̱ntꞌö pe̱fi, hingi umba ar se̱ki ya ku, ha nuꞌu̱ unga ar se̱ki tsu̱i ne e̱nga har nijö.
\s1 Ar hoga ꞌbe̱fi o̱tꞌa ar ku Demetrio
\p 
\v 11 Ma tsi kuꞌi, yo gi te̱nga nöꞌö hingi ho, te̱nga nöꞌö xiñho. Nöꞌö togo o̱tꞌa xiñho, gor me̱ti Jö, ha nöꞌö togo o̱tꞌa nöꞌö hingi ho, hinxi bö Jö.
\p 
\v 12 Gatho ya ku da̱majöni, nunar ku Demetrio o̱tꞌa xiñho, ne nöꞌö o̱tꞌe da̱se̱ majöni nꞌehe. Ha nuje di eñhe, hö njapꞌu̱, ne gi pöhu̱ di möñhe majöni.
\s1 Ya ngöxanze̱ngwa
\p 
\v 13 Nuga ndi pe̱ꞌsa nze̱ye̱ te nga xiꞌahu̱, mödi hindi ne ga otꞌa ha nꞌar he̱ꞌmi ne ar ntꞌotꞌi.
\p 
\v 14 Ngetho di ne ga nthe̱wi ngutꞌa ne ga ñhandwi ga ñöhu̱.
\p 
\v 15 Jö da ꞌraꞌa nꞌar hogamꞌu̱i. Gatho ya ku di mpöhu̱ pe̱ñꞌa nze̱ngwa. Ze̱ngwagihepꞌu̱ nꞌa ngu nꞌa ya ku di mpöhu̱.
