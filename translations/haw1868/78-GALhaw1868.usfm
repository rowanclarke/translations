\id GAL  
\h Galatia 
\toc1 Galatia 
\toc2 Galatia 
\toc3 Galatia 
\mt1 Galatia  
\c 1  
\s1 O KA EPISETOLE  
\q1
\v 1 O PAULO, he lunaolelo, aole na kanaka mai, aole hoi ma ko kanaka, aka, ma o Iesu Kristo la, a ma ke Akua ka Makua nana ia i hoala'e mai ka make mai;   
\q1
\v 2 O ka poe hoahanau no hoi me au, na na ekalesia o Galatia:   
\q1
\v 3 E alohaia oukou, e maluhia hoi i ke Akua ka Makua, a i ko kakou Haku ia Iesu Kristo,   
\q1
\v 4 Nana i haawi mai ia ia iho no ko kakou hala, i hoopakele ae oia ia kakou i keia ao ino nei, e like me ka makemake o ke Akua, ko kakou Makua;   
\q1
\v 5 Oia ka hoonani mau loa ia'ku Amene.   
\b  
\q1
\v 6 Ua kahaha iho no wau i ka emoole o ko oukou haalele ana mai i ka mea i kono aku ia oukou iloko o ka euanelio a Kristo, a lilo i ka euanelio okoa:   
\q1
\v 7 Aole hoi ho euanelio okoa ia; aka, ke hoohihia nei kekahi poe ia oukou, me ka mauao e hookahuli i ka euanelio a Kristo.   
\q1
\v 8 Ina paha o makou, a he anela paha mai ka lani mai, e hai aku i ka euanelio i ku e i ka makou i hai aku ai ia oukou, e hoomainoinoia oia.   
\q1
\v 9 Me ka makou i olelo ai mamua, pela hoi au e olelo hou aku nei, a i hai aku kekahi ia oukou i ka olelo ku e i ka mea a oukou i loaa'i, e hoomainoinoia oia.   
\q1
\v 10 Ke hoolaulea nei anei au i kanaka, a i ke Akua anei? Ke imi nei anei hoi au e hoolealea i kanaka? no ka mea, a i hoolealea aku au i kanaka, aole au he kauwa na Kristo.   
\b  
\q1
\v 11 Ke hoike aku nei au ia oukou, e na hoahanau, o ka euanelio a'u i hai aku ai, aole ia ma ka ke kanaka.   
\q1
\v 12 No ka mea, aole i loaa ia'u ia na ke kanaka mai, aole hoi au i aoia mai, aka, ma ka hoikeia mai no e Iesu Kristo.   
\q1
\v 13 Ua lohe oukou i kuu noho ana mamua ma ko ka Iudaio manao, he nui loa kuu hoomaau ana'ku i ka ekalesia o ke Akua, me ka luku aku.   
\q1
\v 14 Ua oi aku au ma ko ka Iudaio manao, mamua o ka nui o ka poe hoahanauna o'u, a he nui loa ko'u ikaika ma na mooolelo a o'u mau kupuna.   
\q1
\v 15 I ka manawa i manao ai ke Akua nana au i hookaawale ae mai ka opu mai o ko'u makuwahine, a koho mai la ia'u ma kona lokomaikai,   
\q1
\v 16 E hoike mai i kana Keiki ia'u, i hai aku ai au ia ia i na kanaka e; wikiwiki iho la au, aole au i kuka me ka mea io a me ka mea koko;   
\q1
\v 17 Aole hoi au i pii aku i Ierusalema, i ka poe lunaolelo mamua o'u: aka, hele aku la au i Arabia, a hoi hou mai la i Damaseko.   
\b  
\q1
\v 18 A hala na makahiki ekolu, pii aku la au i Ierusalema e ike ia Petero a noho pu iho la au me ia i na la he umikumamalima.   
\q1
\v 19 O Iakobo hoi ka hoahanau o ka Haku ka'u i ike, aole ka lunaolelo e ae.   
\q1
\v 20 Aia hoi, imua o ke Akua, aole o'u hoopunipuni i na mea a'u e palapala aku nei ia oukou.   
\q1
\v 21 Ma ia hope mai, hele aku la au i na moku o Suria a me Kilikia;   
\q1
\v 22 A ua ike maka ole ia au e na ekalesia o Kristo ma Iudea.   
\q1
\v 23 He lohe wale no ko lakou, O ka mea nana kakou i hoomaau mai mamua, i neia manawa ke hai aku la ia i ka manao oiaio ana i hoino ai mamua.   
\q1
\v 24 A hoonani aku la lakou i ke Akua no'u.   
\c 2  
\b  
\q1
\v 1 A HALA na makahiki he umikumamaha, pii hou aku la au i Ierusalema, me Barenaba, a lawe pu aku no hoi ia Tito.   
\q1
\v 2 Pii aku la au no ka hoikeia mai, a hoakaka aku la au ia lakou i ka enanelio a'u i hai aku ai i ko na aina e; aka, hoakaka malu aku la au i ka poe i manao maikai ia'e, malia o holo hewa paha uanei au, a ua holo hewa paha mamua.   
\q1
\v 3 Aka, o Tito ka Helene i noho pu me au, aole ia i lilo i ke koiia mai e okipoepoeia;   
\q1
\v 4 No ka poe hoahanau hoopunipuni i hookipa malu ia, ka i komo malu mai iloko e hoomakakiu mai i ko kakou luhi ole iloko o Kristo Iesu, i hooluhi mai ai lakou ia kakou.   
\q1
\v 5 Aole makou i hoolohe aku ia lakou me ka hoopili aku i hookahi hora; i mau ai ka oiaio o ka euanelio me oukou.   
\q1
\v 6 Aka, o ka poe i manao maikai ia, he oia paha, he mea ole ia ia'u; aole ke Akua i manao mai i ko ke kanaka kino. No ka mea, aohe mea hou a ka poe i manao maikai ia i haawi mai ai ia'u.   
\q1
\v 7 Aka, a ike iho la lakou, ua haawiia mai ia'u ka euanelio no ka poe i okipoepoe ole ia, e like me ia i haawiia mai ia Petero no ka poe i okipoepoeia;   
\q1
\v 8 (No ka mea, o ka mea nana i hooikaika mai ia Petero ma ka oihana lunaolelo no ka poe i okipoepoeia, oia ka i hooikaika mai ia'u no na kanaka e;)   
\q1
\v 9 A ike mai la Iakobo me Kepa a me Ioane i manaoia he mau Kia, i ka maikai i haawiia mai ia'u, haawi mai la lakou ia maua me Barenaba i na lima akau e hoolauna pu ai; i hele maua i ko na aina e, a o lakou i ka poe okipoepoeia.   
\q1
\v 10 I manao hoi maua i ka poe ilihune, oia hoi ka'u i manao nui ai e hana.   
\b  
\q1
\v 11 A hele mai la Petero i Anetioka, ku e aku la au ia ia imua o kona alo, no ka mea, ua hewa ia.   
\q1
\v 12 No ka mea, mamua o ka hiki ana mai o kekahi poe mai o Iakobo mai, ua ai pu iho la ia me ko na aina e; a hiki mai la lakou, hookaawale ae la oia ia ia iho, e makau ana i ka poe i okipoepoeia.   
\q1
\v 13 A hoomahui pu aku la ka poe Iudaio e ae me ia; a lilo aku la o Barenaba mamuli o ko lakou hookamaui ana.   
\q1
\v 14 A ike aku la au, aole i ku pono ko lakou hele ana ma ka oiaio o ka euanelio, i aku la au ia Petero imua o lakou a pau, Ina o oe he Iudaio e noho like ana me ko na aina e, aole me ka poe Iudaio, pehea la kau e koi aku nei i ko na aina e e noho like me ko ka Iudaio?   
\q1
\v 15 O kakou na Iudaio maoli, aole na lawehala o ko na aina e,   
\q1
\v 16 Ke ike nei kakou, aole e hoaponoia ke kanaka ma na hana o ke kanawai, aka, ma ka manaoio ia Iesu Kristo; o kakou hoi kekahi i manaoio ia Iesu Kristo, i hoaponoia mai kakou ma ka manaoio ia Kristo, aole ma na hana o ke kanawai: no ka mea, aole e hoaponoia mai kekahi kanaka ma na hana o ke kanawai.   
\q1
\v 17 Ina paha e imi kakou e hoaponoia mai ma o Kristo la, a ikea mai kakou he poe hewa, ke kumu anei o Kristo no ka hewa? Aole loa.   
\q1
\v 18 No ka mea, a i kukulu hou au i na mea a'u i wawahi ai, ua hoolilo iho la au ia'u iho i lawehala.   
\q1
\v 19 A owau nei ma ke kanawai, ua make i ke kanawai, i ola aku ai au i ke Akua.   
\q1
\v 20 Ua kau pu ia'ku au me Kristo ma ke kea: ua ola no hoi au, aole nae owau iho, aka, e ola ana o Kristo iloko o'u: a o ke ola e ola nei au iloko o ke kino, e ola'na au ma ka manaoio aku i Ke Keiki a ke Akua, nana au i aloha mai, a haawi mai la ia ia iho no'u.   
\q1
\v 21 Aole au e hoolilo i ka lokomaikai o ke Akua i mea ole; no ka mea, ina ma ke kanawai ka pono, ina ua ano ole ko Kristo make ana.   
\c 3  
\b  
\q1
\v 1 E NA Galatia naaupo, nawai oukou i hoowalewale mai i hoo lohe ole ai oukou i ka oiaio, imua o ko oukou maka ua waihoia o Iesu Kristo i kaulia ma ke kea iwaena o oukou?   
\q1
\v 2 Eia wale no ko'u makemake e hoikeia mai e oukou; Ma na hana o ke kanawai anei i loaa'i ia oukou ka Uhane, a ma ka hoolohe aku o ka mauaoio anei?   
\q1
\v 3 Pela anei ko oukou naaupo? i hoomaka iho ai oukou ma ko ka Uhane, a ke hooki nei anei oukou ma ko ke kino?   
\q1
\v 4 Ua make hewa anei kela mau mea pilikia i hiki mai ai io oukou la? ina pela ua make hewa paha.   
\q1
\v 5 No ia hoi, o ka mea i haawi mai i ka Uhane no oukou, a hana mai hoi i na hana mana iwaena o oukou, ma na hana o ke kanawai anei ia, a ma ka hoolohe ana o ka manaoio anei?   
\q1
\v 6 E like me Aberahama i manaoio ai i ke Akua, a na hooliloia'e ia i pono nona.   
\q1
\v 7 No ia mea, e ike oukou, o ka poe ma ka manaoio, o lakou ka poe keiki na Aberahama.   
\q1
\v 8 Ike e iho la ka palapala hemolele, e hoopono ana ke Akua i na lahuikanaka ma ka manaoio, hai e aku la ia mamua i ka euanelio ia Aberahama, Ma on aku la e hoopomaikaiia'i na lahuikanaka a pau.   
\q1
\v 9 Nolaila hoi, o na mea ma ka manaoio, na hoopomaikai pu ia lakou me Aberahama ka mea manaoio.   
\q1
\v 10 No ka mea, o ka poe a pau ma na hana o ke kanawai, aia no lakou malalo o ka hoahewaia; penei i palapalaia'i, E hoahewaia'ku na mea a pau i hoomau ole o hana i na mea a pau i kakauia maloko o ka buke o ke kanawai.   
\q1
\v 11 Aka, ua akaka keia, aole kekahi e hoaponoia imua o ke Akua ma ke kanawai: no ka mea, O ka mea i pono, e ola ia ma ka manaoio.   
\q1
\v 12 A o ke kanawai, aole ia ma ka manaoio: aka, o ke kanaka e hana ana ia mau mea, e ola ia ilaila.   
\q1
\v 13 Ua hoola ae la o Kristo ia kakou mai ka hoahewaia e ke kanawai, i kona lilo ana i ka hoahewaia no kakou: no ka mea, na palapalaia, Ua hoahewaia na mea a pau i kauia maluna o ka laau:   
\q1
\v 14 I kau mai ai ka hoopomaikaiia o Aberahama maluna o ko na aina e ma o Iesu Kristo la: i loaa mai ai ia kakou ma ka manaoio ka mea i oleloia mai ka Uhane.   
\b  
\q1
\v 15 E na hoahanau, ke olelo aku nei au ma ka ke kanaka; Ina i hoopania ka berita a kanaka wale no, aole kekahi e hoole ia mea, aole hoi e hana hou.   
\q1
\v 16 A ua haiia mai no na olelo ia Aberahama a me kana mamo. Aole ia i olelo mai no na mamo he nui; aka, no ka mea hookahi, No kau mamo, oia hoi o Kristo.   
\q1
\v 17 O keia ka'u o olelo aku nei, o ka berita i hoopaa e ia mamua e ke Akua no Kristo, aole e hiki i ke kanawai i kania mahope mai o na haneri makahiki eha a me kanakolu ke hoole aku, i haule ai ka olelo.   
\q1
\v 18 A ina ma ke kanawai ka hooili ana, aole no ia ma ka olelo: aka, na ke Akua ia i haawi wale mai ia Aberahama ma ka olelo.   
\b  
\q1
\v 19 I me aha hoi ke kanawai? Ua kauia mai ia no na hala, a hiki mai ka mamo nona ka olelo; a na hoolahaia'e la ia e na anela ma ka lima o ka mea uwao.   
\q1
\v 20 A o ka mea uwao, aole ia no ka mea hookahi; aka, o ke Akua, hookahi no ia.   
\q1
\v 21 Ua ku e no anei ke kanawai i na olelo a ke Akua? Aole loa: no ka mea, ina i haawiia mai ke kanawai e hiki ia ia ke hoola, ina no ma ke kanawai ka pono.   
\q1
\v 22 Aka, ua papapau pu na mea a pau i ka palapala hemolele malalo o ka hewa, i haawiia mai ai ka olelo ma ka manaoio ia Iesu Kristo na ka poe manaoio aku.   
\b  
\q1
\v 23 A mamua o ka hiki ana mai o ka manaoio, ua hoopaaia kakou malalo o ke kanawai, ua pio hoi a hiki i ka manawa e hoakakaia mai ai ka manaoio.   
\q1
\v 24 Nolaila, ua lilo ae la ke kanawai i kumualakai no kakou io Kristo la, i hoaponoia mai ai kakou ma ka manaoio.   
\q1
\v 25 Aka, i ka hiki ana mai o ka manaoio, aole o noho hou kakou malalo o ke kumualakai.   
\q1
\v 26 No ka mea, he poe keiki oukou a pau na ke Akua ma ka manaoio ia Kristo Iesu.   
\q1
\v 27 No ka mea, o na mea a pau o oukou i hapetisoia iloko o Kristo, ua aahu iho oukou ia Kristo.   
\q1
\v 28 Aole he Iudaio, aole hoi he Helene, aole he mea paa, aole hoi he mea paa ole, aole he kane, aole hoi he wahine; no ka mea, hookahi no oukou a pau iloko o Kristo Iesu.   
\q1
\v 29 Ina paha no Kristo oukou, alaila he poe mamo oukou na Aberahama, a me na hooilina hoi mamuli o ka olelo hoopomaikai.   
\c 4  
\b  
\q1
\v 1 KE olelo aku nei hoi au, o ka hooilina i kona wa opiopio, aole he ano e kona i ko ke kauwa, aka, nona ka waiwai a pau;   
\q1
\v 2 Aia no ia malalo o ua kumu a me na kahu, a hiki i ka manawa i hoikeia mai ai e ka makua.   
\q1
\v 3 Pela no kakou i ko kakou wa kamalii, ua hooluhiia e na oihana mua o ke ao nei.   
\q1
\v 4 Aka, i ka hiki ana mai o ka manawa maopopo, hoouna mai la ke Akua i kana Keiki, a ka wahine i hanau ai, i hanau malalo o ko kanawai.   
\q1
\v 5 E hoopakele ae i ka poe malalo o ke kanawai, i hookamaia mai ai kakou he poe keiki.   
\q1
\v 6 No ka mea, no ko oukou keiki ana, ua hoouna mai la ke Akua i ka Uhane o kana Keiki iloko o ko oukou mau naau, e kahea ana, E Aba, ka Makua.   
\q1
\v 7 No ia mea, aole he kauwa luhi oe ma ia hope aku, aka, he keiki no; ina he keiki, he hooilina no hoi na ke Akua ma o Kristo la.   
\b  
\q1
\v 8 Aka, i ka manawa i ike ole ai oukou i ke Akua, hookauwa aku la oukou na na akua oiaio ole.   
\q1
\v 9 Ano hoi, ua ike oukou i ke Akua, he oiaio ua ikeia mai e ke Akua, pehea la hoi oukou i huli hou aku ai i na oihana mua palupalu ilihune, i na mea a oukou i makemake hou ai e hookauwa aku na lakou?   
\q1
\v 10 Ke malama nei oukou i ua la, a me na mahina, i na manawa a me na makahiki.   
\q1
\v 11 Ua hopohopo wau ia oukou, o make hewa paha kuu hooluhi ana no oukou.   
\b  
\q1
\v 12 E na hoahanau, ke nonoi aku nei au ia oukou, i like oukou me au, no ka mea, ua like hoi au mo oukou: aole no oukou i hana ino iki mai ia'u.   
\q1
\v 13 Ua ike no oukou me ka palupalu o ke kino i hai aku ai au i ka euanelio ia oukou i kinohou.   
\q1
\v 14 Aole no oukou i hoowahawaha mai i ka ino o kuu kino, aole hoi oukou i hoopailua mai; aka, na hookipa mai no oukou ia'u me he anela la no ke Akua, me Kristo Iesu hoi.   
\q1
\v 15 Heaha la hoi ko oukou pomaikai ana? No ka mea, ke hoike maka aku nei au no oukou, ina he mea hiki ia, ina ua poalo ae oukou i ko oukou mau maka a haawi mai ia'u.   
\q1
\v 16 Ua lilo anei au i enemi no oukou, i kuu hai ana'ku i ka oiaio ia oukou?   
\q1
\v 17 Ua hu mai ko lakou aloha ia oukou, aole nae ma ka pono: ke ake nei lakou e hookaawalo ia oukou, i hu mai ko oukou aloha ia lakou.   
\q1
\v 18 Aka, he mea pono no ke hu ae a mau mai ke aloha i ka mea maikai, aole i ka wa wale no e noho ai au me oukou.   
\q1
\v 19 E kuu mau keiki liilii, ka poe a'u e haakohi nei e hoohanau hou aku, a loaa mai o Kristo iloko o oukou,   
\q1
\v 20 Ke ake nei au e ike ia oukou i neia manawa, a e hoololi ae i kuu leo; no ka mea, ke haohao nui nei au ia oukou.   
\b  
\q1
\v 21 E hai mai oukou ia'u, e ka poe i makemake e noho malalo o ke kanawai, aole anei oukou i lohe i ke kanawai?   
\q1
\v 22 No ka mea, ua palapalaia, Elua a Aberahama keikikane; hookahi na ke kauwawahine, hookahi hoi na ka hakuwahine.   
\q1
\v 23 O ka mea na ke kauwawahine, ua hanau ia ma ko ke kino; aka, o ka mea na ka hakuwahine, ma ka olelo hoopomaikai mai oia.   
\q1
\v 24 O keia mau mea, he hoailona ia; o laua no na kauoha elua; o kekahi nae no ke kuahiwi no Sinai mai, e hanau ana i ua keiki kauwa, oia o Hagara.   
\q1
\v 25 No ka mea, o ua Hagara la oia ke kuahiwi o Sinai i Arabia; ua like hoi ia me Ierusalema i neia manawa, a e hooluhi ana oia me kana poe keiki.   
\q1
\v 26 Aka, o ka Ierusalema maluna ka hakuwahine, oia ka makuwahine o kakou a pau.   
\q1
\v 27 No ka mea, ua palapalaia, E olioli oe, e ka mea pa, i hanau ole i keiki; e poha aku me ka hea nui, e ka mea i hanau keiki ole; no ka mea, he nui na keiki a ka mea i haaleleia, he hapa ka ka mea kane.   
\q1
\v 28 E na hoahanau, he poe keiki no hoi kakou ma ka olelo hoopomaikai mai e like me Isaaka.   
\q1
\v 29 E like mamua, hoomaau aku la ka mea i hanau ma ke kino i ka mea i hanau ma ka Uhane, pela no hoi i neia manawa.   
\q1
\v 30 Aka, heaha ka ka palapala hemolele i i mai ai? E hookuke aku oe i ua kauwawahine la a me kana keiki; no ka mea, aole e hooili pu ia'ku ka waiwai i ke keiki a ke kauwawahine me ke keiki a ka hakuwahine.   
\q1
\v 31 Nolaila, e na hoahanau, aole he poe keiki kakou na ke kauwawahine, na ka hakuwahine no.   
\c 5  
\b  
\q1
\v 1 NO ia mea, e kupaa oukou iloko a ke ola a Kristo i hoola mai ai ia kakou, aole hoi e paa hou oukou malalo o ka auamo hooluhi.   
\b  
\q1
\v 2 Eia hoi, wau o Paulo ke i aku nei ia oukou; a i okipoepoeia oukou, aole oukou e pono ia Kristo.   
\q1
\v 3 Ke hoike hou aku nei au i kela mea i keia mea i okipoepoeia, he aie kana e malama aku ai i ke kanawai a pau.   
\q1
\v 4 Oukou ka poe e aponoia ma ke kanawai, ua hookaawaleia oukou mai o Kristo aku la; ua haule iho oukou mai ka lokomaikai aku.   
\q1
\v 5 Aka, ma ka Uhane makou e kali nei i ka pono e lana ai ka naau ma ka manaoio.   
\q1
\v 6 No ka mea, iloko o Kristo Iesu, aole ke okipoepoe ka mea e pono ai, aole hoi ke okipoepoe ole; aka, o ka manaoio e hana ana ma ke aloha.   
\q1
\v 7 Ua holo pono oukou; nawai la oukou i keakea, i hoolohe ole ai oukou i ka oiaio?   
\q1
\v 8 O ka mea nana oukou i kahea aku, aole nona mai ia manao.   
\q1
\v 9 O kahi mea hu he uuku, ke hoohu ae la ia i ka popopalaoa a pau.   
\q1
\v 10 Ua maopopo kuu manao ia oukou ma ka Haku, aole oukou e manao ma ka mea ku e: aka, o ka mea nana oukou i hoopilikia aku, e ukuia'na oia.   
\q1
\v 11 E na hoahanau, ina paha wau e kauoha aku i ko okipoepoe, no ke aha la wau e hoomaauia mai nei? Ua pau nae ka hihia o ke kea ilaila.   
\q1
\v 12 He pono i kuu manao i hookiia'e ka poe hookahuli ia oukou.   
\b  
\q1
\v 13 E na hoahanau, ua heaia oukou ma ka luhi ole; mai hoolilo nae oukou i ua luhi ole la i mea no ke kino, aka, ma ke aloha e malama aku kekahi i kekahi.   
\q1
\v 14 No ka mea, ua malamaia ke kanawai a pau make kauoha hookahi, oia hoi keia, E aloha aku oe i kou hoalauna e like me oe iho.   
\q1
\v 15 Aka, ina e akiaki oukou me ka hoopau i kekahi i kekahi; e ao o pau auanei oukou i kekahi i kekahi   
\b  
\q1
\v 16 Ke olelo aku nei hoi au, e haele oukou ma ko ka Uhane, aole e hooko oukou i ke kuko hewa o ke kino.   
\q1
\v 17 No ka mea, ua ku e ke kuko o ke kino i ko ka Uhane, a o ko ku Uhane i ko ke kino; a ua ku e ia mau mea i kekahi i kekahi, i hiki ole ai ia oukou ke hana i na mea n oukou i makemake ai.   
\q1
\v 18 A i alakaiia oukou e ka Uhaue, aole no oukou malalo o ke kanawai.   
\q1
\v 19 A ua akaka ae la ua hana o ke kino; oia ka moe kolohe, ka hookamakama, ka hoohaumia, ka makaleho,   
\q1
\v 20 Ka hoomana kii, ka hoopiopio, ka inaina, ka hakaka, ka ukiuki, ka huhu, ka hoopaapaa, ka mokuahana, ka manao ku e,   
\q1
\v 21 Ka huahuwa, ka pepehi kanaka, ka ona ana, ka uhauha ana, a me na mea like; na mea a'u e hai e aku nei ia oukou, me a'u i hai e aku ai mamua, o ka poe e hana i ua mau mea la, aole e hooiliia no lakou ke aupuni o ke Akua.   
\q1
\v 22 Aka, o ka hua na ka Uhane, oia ke aloha, ka olioli, ke kuikahi, ke ahonui, ka lokomaikai, ka maikai, ka manaoio,   
\q1
\v 23 Ke akahai, ka pakiko; aohe kanawai papa mai ia mau mea.   
\q1
\v 24 A o ka poe no Kristo, ua kau aku lakou i ko ke kino, me na manao hewa, a me na kuko hewa ma ke kea.   
\b  
\q1
\v 25 A i noho kakou ma ko ka Uhane, e hele hoi kakou ma ko ka Uhane.   
\q1
\v 26 Mai manao kiekie kakou, me ka hoonaukiuki aku i kekahi i kekahi, a me ka huahuwa i kekahi i kekahi.   
\c 6  
\b  
\q1
\v 1 E NA hoahanau, a i loohia wale ke kanaka e kekahi hewa, na oukou ka poe ma ka Uhane, e hoihoi mai ia ia me ka naau akahai; a mo ka malama ia oe iho, o lilo hoi oe i ka hoowalewaleia.   
\q1
\v 2 E hali kekahi o oukou i na mea kaumaha a kekahi, pela oukou e hooko ai i ke kanawai o Kristo.   
\q1
\v 3 No ka mea, ina paha e manao ana kekahi ia ia iho he mea nui oia, aole ka hoi, ina ua hoopunipuni oia ia ia iho.   
\q1
\v 4 Aka, e hoao iho kela mea keia mea i kana hana ana, alaila iloko wale iho no ona kona kaena ana, aole iloko o hai.   
\q1
\v 5 No ka mea, e halihali auanei kola mea keia mea i kona luhi iho.   
\b  
\q1
\v 6 O ka mea i aoia mai i ka olelo, e haawi aku oia i na mea maikai a pau na ka mea nana i ao mai.   
\q1
\v 7 Mai kuhi hewa oukou, aole ke Akua e hoomaewaewaia'ku; no ka mea, o ka ke kanaka i lulu, o kana hoi ia e ohi mai.   
\q1
\v 8 No ia mea, o ka mea e lulu ma kona kino iho, no ke kino ia e ohi auanei i ka make; aka, o ka mea e lulu ma ka Uhane, no ka Uhane ia e ohi auanei i ke ola mau loa.   
\q1
\v 9 Mai hoopalaleha kakou i ka hana maikai; no ka mea, i ka wa pono e ohi auanei kakou, ke hoonawaliwali ole kakou.   
\q1
\v 10 Nolaila, e like me ko kakou manawa maopopo, pela e hana maikai aku ai kakou i na mea a pau, oiaio hoi i ka poe ohana manaoio.   
\b  
\q1
\v 11 E ike oukou i ka nui o ka palapala a'u e kakau aku nei na oukou me ko'u lima iho.   
\q1
\v 12 O ka poe a pau e ake e hoomaikai i ko ke kino, o lakou ke koi aku ia oukou e okipoepoeia; i mea wale no e hoomaau ole ia mai ai lakou no ke kea o Kristo.   
\q1
\v 13 No ka mea, o ka poe i okipoepoeia, aole hoi lakou i malama i ke kanawai; ke ake nei lakou e okipoepoeia oukou, i mea e kaena aku ai lakou i ko oukou kino.   
\q1
\v 14 Aole loa a'u mea e ae e kaena aku ai, o ke kea wale no o ko kakou Haku o Iesu Kristo, nona i kaulia'i ma ko kea ko ke ao nei ia'u, a owau hoi i ko ke ao nei.   
\q1
\v 15 No ka mea, iloko o Kristo Iesu aole ke okipoepoeia ka mea e pono ai, aole hoi ke okipoepoe ole ia, aka, o ka mea i haua hou ia.   
\q1
\v 16 A o ka poe a pau e hele ma keia manao, maluna o lakou ka mala a me ke aloha, a maluna hoi o ka poo Iseraela o ke Akua.   
\b  
\q1
\v 17 Ma ia hope aku, mai hooluhi mai kekahi ia'u; no ka mea, ke halihali nei au ma ko'u kino i na hoailona o ka Haku o Iesu.   
\b  
\q1
\v 18 E na hoahanau, o ka lokomaikai o ko kakou Haku o Iesu Kristo mo ko oukou uhane. Amene.   