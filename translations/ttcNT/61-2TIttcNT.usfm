\id 2TI - Maya-Tektiteko NT -Guatemala 2003 (DBL -2013)
\h Tkab'i' U'j Te Timotey
\toc1 Te Tkab'i' U'j Stz'ib'en Pa'k Te Timotey
\toc2 Tkab'i' U'j Te Timotey
\toc3 2Tim
\mt1 Te Tkab'i' U'j Stz'ib'en Pa'k Te Timotey
\c 1
\s1 Jun Limb'il
\p 
\v 1 Wetz a'in Pa'k aj tky'ixel Kristo Jesus tzan tpaj inkaj si' tzan te Qtata Dios [tzan npakb'an] ti'j te qanq'in te jun-ele'x tuky'i Kristo Jesus iktza'x okaj tsi' tyol ti'j.
\v 2 Nqet ntz'ib'a' ja u'j te yatz nk'wa'al Timotey\x * \xo 1:2 \xt Kya 16:1; 1Tim 1:2\x* aj b'an ganimich witza'. Tzaj si'xwit te yatz tzan te Qtata Dios b'ix te Qajaw Kristo Jesus jun nim b'an galan aj mas nim twitz te aj nqajo', b'ix tz'okxwit lo'et tk'u'j awi'j b'ix qetxwit xhchewsa' ak'u'j.
\s1 Te Pa'k B'an Nxnaq'tzan Ti'j Timotey
\p 
\v 3 Wetz, oj nxnaq'tzan tuky'i Qtata Dios b'ajq'ij b'ix b'ajaq'b'il, nxhstzaj nna'o' b'ix nxik nsi' nim pixon te Qtat awi'j yatz. Wetz nqet nna'o' te Qtat iktza'x kye wijajil oqtxi', b'ix k'onti'l nyolin wanim jun tidi' wi'j.
\v 4 Wetz ntzaj nna'o' awo'jb'en b'ix ngan tzan awok wen tzan nchalaj nim awi'j.
\v 5 Ntzaj nna'o' titza' yatz wit'lik ak'u'j ti'j Qtata Dios tuky'i jun tk'u'jlal b'an b'an'ax iktza'x te ab'i'ixh Loyd b'ix te anan Ewnis [wit'lik tuq kyk'u'j ti'j Qajawil], b'ix wetz web'en ax yatz ikxji wit'lik ak'u'j ti'j Qajawil.\x * \xo 1:5 \xt Kya 16:1\x*
\v 6 Astilji wetz ngan tzan txik nq'uma' yatz tzan k'on tkaj asi' te awajb'en aj otzaj tsi' te Qtata Dios te yatz, aj tqet nsi' nq'ab' awajsik.
\v 7 Komo te Qtata Dios otzaj tsi' Txew te qetz nya'tx tzan qxob' sinoke tzan tnimsan jk'u'j, b'ix tzan kyqet qgani' [txq'anky], b'ix tzan tok jun qnab'l tzan jk'ulun mandad qib'x [iktza' tetz tgan].
\p 
\v 8 Astilji k'on chqet ky'ixwik tzan txik apakb'a' ti'j Qajawil, b'ix k'on chqet ky'ixwik wi'j tzan tpaj akyinqex pres. Komo te Qtata Dios nnimsan ak'u'j, k'amoj tzan tok awen ch'in twitz aj xhcho'nal aj n'ok qen tzan tpaj nqopakb'an te tpakb'alil aj nkolon te qetz.
\v 9 Te Qtata Dios oqet tkolo' a'o' b'ix ajna'l aji tetz twitzale' otzaj uk'len te qetz tzan jkaj pawa' a'ox te tetz, nya'tx tzan tpaj galan-wit a'o', sinoke tzan tpaj ikxjikix tetz tgan b'ix tetz otzaj tsi' jun nim b'an galan qajsik tzan tpaj Kristo Jesus anke k'onti'l tuq nqajo', b'ix [oqet tb'isu' ntzani] atx aj mina' tuq tb'antik te twitz tx'o'tx' kyaqil.
\v 10 B'ix ajna'l oje qet tyek'u' titza' nqoqet tgani' tzan tpaj otzaj tlajo' te Kristo Jesus aj koloyon qi'j, b'ix ikxji opon tnajsa' te kamikyj b'ix otzaj tq'uma' te tpakb'alil galan aj nyolin titza' tzan qanq'in te jun-ele'x.
\v 11 Te Qtata Dios okaj sin te wetz tzan txik npakb'a' ja tpakb'alilni, b'ix inkaj tsi' iktza' jun tky'ixel te Kristo Jesus b'ix tzan kxik nxnaq'tza' txq'anky.\x * \xo 1:11 \xt 1Tim 2:7\x*
\v 12 Astilji nky'ik wi'j kyaqil ja xhcho'nalni, per k'onti'l nkyinky'ixwik tzan tpaj wetz web'en ab'l qi'j oje kyin'okslan, b'ix wetz web'en tetz at tajwalil tzan tqet tkolo' te aj otzaj tq'uma' wetz, kolomaj titza' ajna'l max oj tul.
\p 
\v 13 B'ix yatz, intxik awin te tumelil iktza'x aj oxik nxnaq'tza' yatz, pawanq'in wit'lik ak'u'j ti'j Kristo Jesus, b'ix inkyqet agani' txq'anky iktza'x tetz nqoqet tgani',
\v 14 b'ix tzan te Txew Dios aj atqex tuj qanim, intqet akolo' te ja xnaq'tzb'il galanni.
\p 
\v 15 Komo yatz aweb'en kyi'j kye aj tzajnaqe' tuj Asy, kyetz oje kyinkaj kykola', b'ix kxol kyetz ax te Pijel b'ix te Ermójenes.
\v 16 Yatzun ti'j te qerman Onesíforo, tz'ok lo'etxwit tk'u'j te Qtata Dios kyi'j kye aj tuj tjay, tzan tpaj tetz ky'ila'j-el ojaw teq'i' nk'u'j b'ix k'onti'l oqet ky'ixwik tzan tpaj akyinqex tuq pres.
\v 17 B'ix aj tpon tetz amaq' Rom, owokten joyol wetz ja' tuq akyinqet, k'onti'l okaj tsi' tzan tjoyon wi'j max aj nkanet titza'.
\v 18 Tz'okxwit lo'et tk'u'j te Qajawil ti'j tetz tuj aj q'ij aj tzul mas yajni. Yatz aweb'en titza' tetz owonen galan qi'j tuj Efeso.
\c 2
\s1 Titza' Tzan Qipan Oj Tok Qen Twitz Jun Xhcho'nal
\p 
\v 1 Yatz nk'ajol, paten jwert tzan tpaj te aj nim b'an galan aj ntzaj tsi' Kristo Jesus awajsik.
\v 2 Te aj owok acha'o' aj nxik tuq nq'uma' kywitz ky'ila'j xjal, ax yatz intxik aq'uma' ikxji kyuky'i kye aj k'onti'l nkaj kykola' [tzan kyokslan te Qtata Dios] b'ix b'a'n tzan txik kxnaq'tza' txq'anky.
\p 
\v 3 Ax intxik awin ch'in yatz aj xhcho'nal aj n'ok qena, iktza'x jun soldad galan [ntipa' tidi'chq xhcho'nal].
\v 4 B'ix jun soldad [galan] k'onti'l n'ox tsamo' tib' tuj tidi'chq kxol kye xjal tzan tpaj tgan tzan tkaj galan tuj twitz te twitzale' k'ulul mandad ti'j.
\v 5 [B'ix ax ikxji] ti'j jun saqchb'ilon, tzan tkamb'an te aj tgan, presis tzan k'on tkaj tsi' tzan tsaqchb'ilan tuky'i tume'l.
\v 6 [B'ix ax ikxji] ti'j jun aj nqet taq'una' xtx'o'otx', qa tgan tzan tk'amon twitz te awalj, a tgan tb'ay tzan taq'unan byenech ti'j.
\v 7 Intqet ab'isu' ti'j aj nxik nq'uma'ni, b'ix te Qajawil oxe'l tsi' jun anab'l tzan tel aniky' ti'j kyaqil.
\p 
\v 8 Instzaj ana'o' te Jesukrist aj tijajil Dawid.\f + \fr 2:8 \ft Ax: Dawid aj twitzale' k'ulul mandad oqtxi'.\f* Tetz ojaw anq'in kxol kye kamnaq, b'ix aj ntza'n te tpakb'alil galan aj nxik npakb'a'.
\v 9 Tzan tpaj te ja tpakb'alilni wetz n'ok wen twitz xhcho'nal, b'ix k'alomin tuky'i kaden [tuj pres] naqe jun eleq' a'in, per te tyol Qtata Dios nya'tx k'alo'.
\v 10 Astilji wetz nwipa' tidi'chq ja xhcho'nalni tzan kypaj kyaqil kye aj joyome' tzan Qtata Dios, tzan kykoletky tzan Kristo Jesus tzan tok kyen xhchqitz'unal te jun-ele'x.
\v 11 Ja yol ntzani b'an'ax: Qa qokamel tuky'i'l, ax oqo'anq'iyon tuky'i'l.
\v 12 Qa qipa'tz twitz xhcho'nal, ax oqok'uluyon mandad oj tkaj kyaqil tuj tq'ab'.\x * \xo 2:12 \xt 1Xhp 5:1\x* Qa qetz oxe'l jq'uma' k'onti'l qotzqi' tetz, ax tetz oxe'l tq'uma' k'onti'l totzqi' a'o'.\x * \xo 2:12 \xt Mat 10:33; Luks 12:9\x*
\v 13 Qa qetz okajel jkola' tetz, tetz tzunx jun yolin tzan tpaj k'onti'l njaw meltz'jik.
\s1 Titza' Tzan Tb'et Jun Aq'unon Aj N'el Galan Tuj Twitz Qtata Dios
\p 
\v 14 Instzaj ana'o' kxol kye qerman aj nxik nq'uma'ni b'ix inkxik akawi' kyetz tuky'i tb'i Qtata Dios tzan tkaj ksi' tzan kywululun, tzan tpaj k'onti'l n'oken b'ix cha n'ok te jun nya'tx galan kye aj nkyecha'on kyi'j.
\v 15 Intok asi' ak'u'j tzan awel galan tuj twitz Qtata Dios iktza' jun aq'unon aj k'onti'l tidi' qi'j b'a'n tzan tqet ky'ixwik, b'ix nxik txnaq'tza' galan te tpakb'alil b'an'ax.
\v 16 K'on tz'ox asamo' awib' kxol kye aj nkyewululun ti'j tidi'chq aj k'onti'l token, tzan tpaj kyeb'ayle' cha mas nkyek'ulun te aj k'onti'l nqet tuj twitz Qtata Dios.
\v 17 Te aj nkyyoli' nxik le'lon tib' naqe jun yab'il aj nxik tq'aysa' qchi'jel.\f + \fr 2:17 \ft Ax: gangrena.\f* Xjal iktza' kyetz a'e' te Iméneo b'ix Pilet,
\v 18 a'e' aj okaj kykola' te b'an'ax. Komo nkyq'uma' oje qojaw anq'in b'ix ikxji cha nkyek'ulun tzan tkaj kykola' junjun titza' wit'lik kyk'u'j.
\v 19 Per te Qtata Dios oje kaj tsi' jun tume'l aj nlay ky'ixpjik aj ja' tz'ib'ankaj ikxjani: “Te Qajawil totzqi' kye aj etzame' titza'.”\x * \xo 2:19 \xt Núm 16:5; Wnch 10:14; 1Kor 8:3\x* B'ix [ax tuj junky part nyolin ikxjani]: “Etetz ekyaqil aj nqet etoksla' te Qajawil, intel epawa' etib' ti'j te aj nya'tx galan.”\x * \xo 2:19 \xt Isa 52:11; Ezq 20:30-44; 2Kor 6:16-18\x*
\p 
\v 20 Tuj jun nim jay, nya'tx a'ox okensb'il xtx'otx'al oro b'ix xtx'otx'al plata ate', sinoke ax ate' xtx'otx'al tze' b'ix tx'o'tx', b'ix junjun nkye'oken te jun q'ijb'il b'ix kye txq'anky te qwab'l b'ajq'ij.
\v 21 [Ax ikxji] qa qetz nlay xik qsamo' qib' tuj te nya'tx galan, b'a'n tzan qoken qetz te jun b'an galan te Qajawil tzan tpaj pawamo' a'ox te tetz iktza'x jun okensb'il b'a'n tzan token te jun b'an galan, b'ix ax ikxji qi'j qetz, b'a'n tzan qoken tzan jk'ulun tidi'chq galan aj tgan te Qajawil.
\p 
\v 22 Intel apawa' awib' ti'j kyaqil aj nya'tx galan n'el kygani' kye ku'xon, pab'et tuj tume'l, intok wit'let ak'u'j ti'j Qajawil, inkyqet agani' txq'anky, b'ix intok awen titza' tzan aten galan kxol kye aj nqet kywitz twitz Qajawil tuky'i jun kyanim b'an saq.
\v 23 Per k'on tz'ok asi' awi' ti'j tidi' b'an tont aj cha nkywululu' b'ix cha kyyol aj cha tuj kywi'x n'etz kyin. Yatz aweb'en, tzan tpaj nini njaw q'oj.
\v 24 Jun xjal aj n'aq'unan te Qtata Dios, a tgan nya'tx aj cha twululunqet, sinoke a tgan galan nab'lin kyuky'i txq'anky xjal, b'ix b'a'n tzan txik txnaq'tza' txq'anky, b'ix at tpasens.
\v 25 Ax a tgan tzan tyolin kyeb'a' kyuky'i kye aj k'on kygan okslan. Komo qanq te Qtata Dios otk'ulu'tz tzan tjaw kky'ixpu' kynab'lin tzan tel kyniky' alkyetz te b'an'ax,
\v 26 b'ix ikxji tzan kykolpjik tuj tq'ab' te Tajaw Choj, komo ajna'l cha tzyume' titza' tzan kyk'ulun iktza' tetz tgan.
\c 3
\s1 Titza' Okyeb'etel Kye Xjal Mas Yajxi' Ch'inky Tuq Tul Te Qajawil
\p 
\v 1 Ntons, ax presis tzan tok acha'o' ntzani: Tuj jun tyemp aj tzul mas yaj, aj ch'inky tuq tul te Qajawil, owokel e'elet twitz nim xhcho'nal.
\v 2 Kye xjal cha a'ox owokel ksi' kyk'u'j kyi'jx kyetz, cha kyb'isunqet ti'j kytumin, cha kyjiq'b'anqet kyib', cha kyk'ulunqet iktza' kyetz kygan, cha kyyolinqet nya'tx galan ti'j Qtata Dios, nlay qet kyoksla' kytat, nlay xik ksi' pixon te nijunwt, cha kyk'ulunqet nya'tx galan,
\v 3 nlay qet kygani' nijunwt, nlay tz'ok lo'et kyk'u'j ti'j junky, cha ojawel kynik'o' yol kyi'j xjal, luwew okyejawel q'ojlik, okyek'uluyon kyuky'i txq'anky iktza' k'onti'l Dios tuj kywitz, owelal kyik'o' kyaqil aj galan,
\v 4 okyejawel meltz'jik ti'j junky, tidi'chq okyek'uluyon b'ix k'onti'l kky'exaw, tuj kynab'l kyetz b'an galan-e', cha owelal kygani' te aj tgan te kchi'jel b'ix nlay tz'el kygani' Qtata Dios.
\v 5 Kyetz okye'okel en iktza' xjal aj nkyexjanin Qtata Dios, per nya'tx b'an'ax kyitza' tzan tpaj k'onti'l okyk'amoj tajwalil Qtata Dios kyi'j. K'on tz'ox asamo' awib' kxol aj xjal ikxji.
\v 6 Komo kxol kyetz ate' kye aj nkye'ewlaj tzan kyox tuj jun jay kyuky'i xuj aj nya'tx jwert-e', ikxji tzan kykaj tuj kyq'ab' kyetz, xuj aj cha kyjoyonqet choj b'ix tidi'chq aj n'el kygani'.
\v 7 Ko'chq nkyexik xnaq'tza' per k'onti'l n'ox tuj kywi' te b'an'ax.
\v 8 Iktza'x te Jans b'ix te Jambrs ejaw q'ojlik ti'j Moisés,\f + \fr 3:8 \ft Kyekyi oqtxi' Jans b'ix Jambrs kyb'i kye kab'e' chman aj nkye'aq'unan tuq te twitzale' k'ulul mandad tuj amaq' Ejipt, b'ix a'e' kyetz kye aj eq'ojin ti'j Moisés; Exo 7:11.\f* b'ix nkyeyolin tuq nya'tx galan ti'j te b'an'ax, ax kye aj xjal ajna'l cha pur tidi'chq nya'tx b'an'ax nkyb'isu', k'onti'l wit'lik kyk'u'j ti'j Qtata Dios b'an b'an'ax.
\v 9 Per nlay kyk'uluj masky, [kyekyinal kyetz qa ikx oxe'l kymañji] tzan tpaj kyaqil kye xjal okye'okel e'en kyetz b'an mok'-e', iktza'x oky'ik kyi'j kye kab'e' aj ejaw q'ojlik ti'j Moisés.
\s1 K'onti'l Tzan Tkaj Jkola' Te Tume'l Anke Kye Xjal Ti'chq Okyk'ulu'tz
\p 
\v 10 Per yatz aweb'en b'ix eq'i' awitza', te aj nxik nxnaq'tza' ti'j Qtata Dios, b'ix ax te tume'l iktza' nkyinb'et, b'ix iktza' aj ngan wetz, b'ix iktza' wetz wit'lik nk'u'j, b'ix iktza' wetz npasens, b'ix iktza' wetz nkyeqet ngani' txq'anky, b'ix iktza' wetz nkyin'ipan xhcho'nal.
\v 11 Ax aweb'en titza' wetz injaw lajo', b'ix titza' tuq te xhcho'nal aj owok wen tuj Antyokiy\x * \xo 3:11 \xt Kya 13:14-52\x* b'ix tuj Ikony\x * \xo 3:11 \xt Kya 14:1-7\x* b'ix Listr.\x * \xo 3:11 \xt Kya 14:8-20\x* Tidi'chq nya'tx galan aj oje ky'ik wi'j, per te Qajawil intkoloj ti'j kyaqil.
\v 12 Kyaqil kye aj kygan tzan kyanq'in mojb'a' kyib' tuky'i Kristo Jesus, okyejawel lajo', owokel kyen twitz xhcho'nal.
\v 13 Per kye xjal aj nkyek'ulun nya'tx galan, b'ix kye aj nkyeqet kyeq'i' txq'anky, cha masky oqtel kyb'antza' kyib', okyeqtel kyeq'i' txq'anky b'ix ax kyetz okyeqtel eq'i'.
\p 
\v 14 Yatzun yatz k'on kaj akola' tzan txik aweq'i' kyaqil aj otzaj xnaq'tza' yatz b'ix oxik awoksla', komo aweb'en ab'l otzaj xnaq'tzan te yatz.
\v 15 Komo atx aj man tuq nekitich owok awotzqila' te Tu'jal Dios, te Tu'jal aj b'a'n tzan txik tsi' jun anab'l tzan tel aniky' titza' tzan jkolet tzan tpaj wit'lik jk'u'j ti'j Kristo Jesus.
\v 16 Kyaqil te Tu'jal Dios, Diosx otzaj yolin tetz, b'ix at nim token tzan qtzaj txnaq'tza', b'ix tzan stzaj tq'uma' alkyetz te nya'tx galan aj njk'ulu', b'ix tzan qtzaj tkawi' alkyetz te galan tzan jk'ulun, b'ix tzan qtzaj txnaq'tza' titza' tzan qb'et tuj tume'l.
\v 17 Ikxji jun aj n'aq'unan te Qtata Dios, xnaq'tzamaj b'ix oje tzaj si' jun tnab'l tzan tk'ulun tidi'chq galan.
\c 4
\s1 K'onti'l Tzan Tkaj Qsi' Tzan Qpakb'an Te Tpakb'alil Galan
\p 
\v 1 Ntons, wetz twitz te Qtata Dios b'ix Qajaw Kristo Jesus aj q'umal kyil kye aj itz'oje' b'ix kye aj kamnaqe', b'ix tzan tpaj tetz tzul b'ix okajel kyaqil tuj tq'ab', oxe'l nq'uma' yatz ikxjani:
\v 2 Intxik apakb'a' ch'in te tpakb'alil galan tuj kyaqil tyemp b'isu' qa nya'txji; intxik akub'sa' kyk'u'j tzan kyokslan, intxik aq'uma' alkyetz te aj nya'tx galan aj nkyk'ulu', inkxik akawi', b'ix panimsan kyk'u'j [titza' tzan kyanq'in tuj tume'l], b'ix kyaqil nini tuky'i apasens, b'ix paxnaq'tzan kyetz.
\v 3 Komo tzul jun q'ij kye xjal nlay kyk'amoj te xnaq'tzb'ilj aj b'an tume'l ti'j te Qtata Dios; sinoke tzan tpaj ktz'akal kyetzx, okyeqtel kyjoyo' ky'ila'j aj okyexnaq'tzayon kxol, per a'ox aj kygan kyetz cha'on.
\v 4 Kyetz nlay ktzoqpij tzan tok kcha'o' te b'an'ax b'ix owokel ksi' kywi' ti'j tidi'chq xnaq'tzb'ilj aj nya'tx b'an'ax.
\v 5 Per yatz, intok asi' anab'l byenech, ipaj te kyaqil xhcho'nal, intok asi' ak'u'j tzan apakb'an te tpakb'alil titza' nqokolet, pak'ulun galan kyaqil te awaq'un te Qtata Dios.
\p 
\v 6 Per yatzun wetz, cha ch'inky nkamik, ch'inky nxik q'apo' iktza' jun oyej te Qtata Dios.
\v 7 Ma'tx kyin'aq'unan\f + \fr 4:7 \ft Ax: ma'tx kyinq'ojin tuj tume'l te b'an'ax.\f* nim tuj taq'un Qtata Dios, ma'tx kyinpon aj ja' tuq ngan tzan npon,\f + \fr 4:7 \ft Ax: ma'tx mankun tzan woqelan tuj te “carrera”.\f* b'ix k'onti'l ma'tx kaj nkola' tzan tok wit'let nk'u'j [ti'j Krist].
\v 8 Ajna'l [ch'inky] tzan nk'amon te tb'anil aj otzajel tsi' te Qajawil wetz tzan tpaj nkyinb'et tuj tume'l, ntons te Qajaw aj pujul il aj at tkawb'il tuj tq'ab', tetz otzajel tsi' te aj tb'anil wetz oj tul junky'el, b'ix nya'tx a'ox te wetz sinoke ax kye kyaqil kye aj nkyechalaj tzan tul.
\s1 Junjun Tidi' Aj Presis Tuq Tzan Tk'ulun Te Timotey
\p 
\v 9 Tzaj asak'so' tzan awul q'olb'el wetz naj.
\v 10 Komo te Démas\x * \xo 4:10 \xt Kol 4:14; Mnch 24\x* owel tgani' mas tidi'chq aj at tzani twitz ja tx'o'tx'ni, ajna'l ma'tx kyinkaj tka'yi', ma'tx xik amaq' Tesalonk. Te Kresent ma'tx xik tuj tkwentil Galasy, b'ix te Tit\x * \xo 4:10 \xt 2Kor 8:23; Gal 2:3; Tit 1:4\x* tuj Dalmasy.
\v 11 A'ox te Luks\x * \xo 4:11 \xt Kol 4:14; Mnch 24\x* atqet wuky'i'l. Intqet ajoyo' te Mak\x * \xo 4:11 \xt Kya 12:12,25; 13:13; 15:37-39; Kol 4:10; Mnch 24\x* b'ix instzaj awin awuky'i'l, komo tetz owoneyon wuky'i'l tzani tuj waq'un te Qtata Dios.
\v 12 Te Tíkiko\x * \xo 4:12 \xt Kya 20:4; Efe 6:21-22; Kol 4:7-8\x* ma'tx xik nlajo' tuj amaq' Efeso.
\v 13 Oj atzaj, otzajel awin ch'in te ntxo'w aj okaj nsi' tuj amaq' Troas\x * \xo 4:13 \xt Kya 20:6\x* tuj tjay Karp, b'ix ax kye u'j b'ix te aj mas presis kye u'j pergamino.
\p 
\v 14 Te Jant\x * \xo 4:14 \xt 1Tim 1:20\x* aj n'aq'unan tuky'i k'uxb'il, tetz tidi'chq nya'tx galan ma'tx tk'uluj wi'j; Qtata Dios xik sinxwit tetz iktza'x aj ma'tx tk'uluj.\x * \xo 4:14 \xt Sal 62:12; Rom 2:6\x*
\v 15 Ax yatz intok asi' anab'l ti'j tzan tpaj tetz nim n'aq'unan tzan k'on txik oksla' te aj nxik qpakb'a'.
\p 
\v 16 Aj nxwa'q tb'ay-el [kywitz kye aj at kyajwalil] tzan txik nq'uma' qa at tuq wil, nijunwt e'onen wi'j, kyaqil inkaj kykola'. K'onxwit kyexik si' tuj il tzan tpaj nini.
\v 17 Per te Qajawil oqet ten wuky'i'l b'ix otzaj tsi' nbalor tzan txik npakb'a' kyaqil te tpakb'alil aj nkolon qetz, b'ix ikxji tzan tok kcha'o' kye aj k'onti'l nkye'okslan. Ikxji te Qajawil in'el tkolo' tuj tq'ab' te nya'tx galan.\f + \fr 4:17 \ft Ax: tuj tq'ab' te leon.\f*
\v 18 Te Qajawil okyintkolo'tz ti'j kyaqil aj nya'tx galan b'ix okyintkolo'tz tzan nten tuky'i'l tuj ka'j. Intqetxwit jiq'b'a' tetz te jun-ele'x. Ky'ikxwit ikxji.
\s1 Jun Kawb'il
\p 
\v 19 Intxik asi' jun limb'il te qerman Akiy b'ix Xhil,\x * \xo 4:19 \xt Kya 18:2,18,26\x* b'ix kye a'e' aj tuj tjay te Onesíforo.\x * \xo 4:19 \xt 2Tim 1:16-17\x*
\v 20 Te Erast\x * \xo 4:20 \xt Kya 19:22; Rom 16:23\x* okaj tuj amaq' Korint, b'ix te Trófimo\x * \xo 4:20 \xt Kya 20:4; 21:29\x* yab' tuq, okaj nsi' tuj amaq' Milet.
\p 
\v 21 Tzaj asak'so' ch'in tzan awul mina' tuq qok jab'alil. Jun limb'il te yatz tzan Eubúlos b'ix tzan te Pudénte, b'ix tzan te Lin b'ix ax tzan Claudia b'ix tzan kyaqil kye a'e' qerman.
\p 
\v 22 Qajaw Jesukrist qet tenxwit awuky'i'l b'ix tzaj tsi'xwit te Qtata Dios jun nim b'an galan awajsik.
