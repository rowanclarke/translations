\id GEN
\h Kinohi
\toc1 Kinohi
\toc2 Kinohi
\toc3 Kinohi
\mt1 Kinohi
\c 1
\s1 KA BUKE MUA A MOSE, I KAPAIA
\q1 
\v 1 I KINOHI hana ke Akua i ka lani a me ka honua.
\q1 
\v 2 He ano ole ka honua, ua olohelohe; a maluna no o ka hohonu ka pouli. Hoopunana iho la ka Uhane o ke Akua maluna o ka wai.
\b
\q1 
\v 3 I iho la ke Akua, I malamalama; a ua malamalama ae la.
\q1 
\v 4 Nana ae la ke Akua i ka malamalama, ua maikai: a hookaawale ae la ke Akua mawaena o ka malamalama, a me ka pouli.
\q1 
\v 5 Kapa mai la ke Akua i ka malamalama, he Ao, a kapa mai hoi ia i ka pouli, he Po. A o ke ahiahi a me ke kakahiaka, o ka la mua ia.
\b
\q1 
\v 6 I iho la ke Akua, I aouli mawaena o na wai, i mea hookaawale i kekahi wai me kekahi wai.
\q1 
\v 7 Hana iho la ke Akua i ke aouli; a hookaawale ae la ia i ka wai malalo o ke aouli, me ka wai maluna o ke aouli: a pela io no.
\q1 
\v 8 Kapa iho la ke Akua i ke aouli, he Lani. A o ke ahiahi a me ke kakahiaka, o ka lua ia o ka la.
\b
\q1 
\v 9 I iho la ke Akua, E hui pu na wai malalo o ka lani i kahi hookahi, i ikea ai kahi maloo: a pela io no.
\q1 
\v 10 Kapa iho la ke Akua i kahi maloo, he Aina; a kapa iho la oia i na wai i hui pu ia 'i, o na moana: a nana ae la ke Akua, ua maikai.
\q1 
\v 11 I iho la ke Akua, E hooulu mai ka honua i ka mauu, a me ka launahele e hua ana i ka hua, a me ka laau hua e hua ana hoi ma kona ano iho, iloko ona iho kona hua maluna o ka honua: a pela io no.
\q1 
\v 12 A hooulu mai la ka honua i ka mauu, a me ka launahele e hua ana i ka hua ma kona ano iho, a me ka laau e hua ana i ka hua, iloko ona kona hua ma kona ano iho: nana iho la hoi ke Akua, ua maikai.
\q1 
\v 13 A o ke ahiahi a me ke kakahiaka, o ke kolu ia o ka la.
\b
\q1 
\v 14 I iho la ke Akua, I mau malamalama iloko o ke aouli o ka lani, i mea hookaawale i ke ao a me ka po; i mau hoailona lakou no na kau, a no na la, a me na makahiki:
\q1 
\v 15 I mau kukui hoi lakou iloko o ke aouli o ka lani, e hoomalamalama mai ai i ka honua: a pela io no.
\q1 
\v 16 Hana iho la ke Akua i na malamalama nui elua: o ka malamalama nui, e alii ai maluna o ke ao, a o ka malamalama uuku iho, e alii ai maluna o ka po, a me na hoku hoi.
\q1 
\v 17 Kau aku la ke Akua ia mau mea ma ke aouli o ka lani, e hoomalamalama mai ai i ka honua,
\q1 
\v 18 E hooalii hoi maluna o ke ao a me ka po, a e hookaawale ae i ka malamalama a me ka pouli: a nana iho la ke Akua, ua maikai.
\q1 
\v 19 A o ke ahiahi a me ke kakahiaka, o ka ha ia o ka la.
\b
\q1 
\v 20 I iho la ke Akua, E hoohua nui mai na wai i na mea ola e holo ana, a me na manu e lele ae maluna o ka honua, ma ka lewa akea o ka lani.
\q1 
\v 21 Hana iho la ke Akua i na ia nui, a me na mea ola a pau e holo ana, a ka wai i hoohua nui mai ai ma ko lakou ano iho a me na mea eheu hoi a pau ma ko lakou ano iho: a nana iho la ke Akua, ua maikai.
\q1 
\v 22 Hoomaikai iho la ke Akua ia mau mea, i iho la, E hoohua ae oukou e hoolaha nui hoi, a e hoopiha i na wai o na moana; a e hoolaha ae na manu maluna o ka honua.
\q1 
\v 23 O ke kakahiaka a me ke ahiahi, o ka lima ia o ka la.
\b
\q1 
\v 24 I iho la ke Akua, E hoohua mai ka honua i ka mea ola ma kona ano iho, i ka holoholona laka, me ka mea kolo, a me ka holoholona hihiu ma kona ano iho: a pela io no.
\q1 
\v 25 Hana iho la ke Akua i ka holoholona hihiu ma kona ano iho, me na holoholona laka ma ko lakou ano iho, a me na mea kolo a pau o ka honua ma ko lakou ano iho: a nana iho la ke Akua, ua maikai.
\b
\q1 
\v 26 I iho la ke Akua, E hana kakou i ke kanaka o ku ia kakou, ma ka like ana me kakou iho: a e hooalii ia ia maluna o na ia o ke kai, maluna hoi o na manu o ka lewa, maluna hoi o na holoholona laka, a maluna hoi o ka honua a pau, a maluna no hoi o na mea kolo a pau e kolo ana ma ka honua.
\q1 
\v 27 Hana iho la ke Akua i ke kanaka ma kona ano iho, ma ke ano o ke Akua oia i hana'i ia ia; hana mai la ia i kane a i wahine.
\q1 
\v 28 Hoomaikai mai la ke Akua ia laua, i mai la hoi ke Akua ia laua, E hoohua ae olua, e hoolaha hoi, e hoopiha i ka honua, a e lanakila maluna, a e noho alii maluna o na ia o ke kai, a me na manu o ka lewa, a me na mea a pau e kolo ana maluna o ka honua.
\b
\q1 
\v 29 I mai la ke Akua, Aia hoi, na haawi aku au na olua i na launahele a pau e hua ana i ka hua maluna o ka honua a pau, a me na laau a pau iloko ona ka hua o ka laau e hua ana i ka hua; he mea ai ia na olua.
\q1 
\v 30 A na ka poe holoholona a pau o ka honua, me na manu a pau o ka lewa, a me na mea a pau e kolo ana ma ka honua, na mea e ola ana, na lakou ka nahelehele a pau i mea ai: a pela io no.
\q1 
\v 31 Nana iho la ke Akua i na mea a pau ana i hana'i, aia hoi, ua maikai wale no. A o ke ahiahi a me ke kakahiaka, o ke ono ia o ka la.
\c 2
\b
\q1 
\v 1 PELA i paa ai ka lani a me ka honua i ka hanaia, a me ko laila poe mea a pau.
\q1 
\v 2 A i ka hiku o ka la, hooki iho la ke Akua i ka hana ana i hana'i: a hoornaha iho la oia i kana hana a pau ana i hana'i.
\q1 
\v 3 Hoomaikai mai la ke Akua i ka hiku o ka la, a hoano iho la; no ka mea, hoomaha iho la oia ia la i ka hana a pau a ke Akua i hana'i.
\b
\q1 
\v 4 Eia ka mooolelo no ka lani a me ka honua i ka wa i hanaia'i ia mau mea, i ka la a Iehova a ke Akua i hana'i i ka honua a me ka lani.
\q1 
\v 5 A me na mea kanu a pau o ka mahiuaai, i ka wa aole ia maloko o ka honua, a mo na launahele a pau o ke kula mamua o kona ulu ana: no ka mea, aole i hooua mai o Iehova ko Akua i ka ua maluna o ka honua, aole hoi he kanaka nana e mahi ka aina.
\q1 
\v 6 Aka, pii aku la ka ohu mai ka honua aku, a hoomau iho la i ka ili a pau o ka aina.
\q1 
\v 7 Hana iho la o Iehova ke Akua i ke kanaka, he lepo o ka honua, a ha iho la ia i ka hanu ola iloko o na puka ihu ona; a lilo ae la ke kanaka i mea ola.
\b
\q1 
\v 8 Kanu iho la o Iehova ke Akua i ka mahinaai maloko o Edena ma ka hikina; a malaila oia i hoonoho iho ai i ke kanaka ana i hana'i.
\q1 
\v 9 Hooulu ae la o Iehova ke Akua i na laau a pau mailoko ae o ka honua, i na mea oluolu no ka maka, i na mea ono hoi ke ai; i ka laau o ke ola hoi iwaena konu o ka mahinaai, a me ka laau i ikea'i ka pono a me ka hewa.
\b
\q1 
\v 10 Kahe ae la kekahi muliwai mai Edena aku e hoomau i ka mahinaai; a malaila aku, manamana ae la ia a lilo i eha mana.
\q1 
\v 11 O Pisona ka inoa o ka mua: oia no ka mea o hoopuni ana i ka aina a pau o Havila, he wahi gula ia;
\q1 
\v 12 A he maikai ke gula o ia aina: ilaila no ka deliuma a me ka pohaku onika.
\q1 
\v 13 O Gihona ka inoa o ka lua o ka muliwai: oia ka mea e hoopuni ana i ka aina a pau o Aitiopa.
\q1 
\v 14 O Hidekela ka inoa o ke kolu o ka muliwai: oia ka mea e kahe ana ma ka aoao hikina o Asuria. A o Euperate ka inoa o ka ha o ka muliwai.
\b
\q1 
\v 15 Lawe ae la o Iehova ke Akua i ke kanaka, a hoonoho iho la ia ia ma ka mahinaai ma Edena, e mahi a e malama ia wahi.
\q1 
\v 16 Kauoha mai la o Iehova ke Akua i ke kanaka, i mai la, E ai wale oe i ko keia laau kela laau o ka mahinaai nei:
\q1 
\v 17 Aka, o ko ka laau i ikea ai ka pono a me ka hewa, mai ai iho oe ia mea: no ka mea, i kou la e ai ai ia mea, he oiaio no e make oe.
\b
\q1 
\v 18 I iho la o Iehova ke Akua, Aole pono ke kanaka ke noho, oia wale; e hana no wau i kokoolua nona e ku ia ia.
\q1 
\v 19 No ka lepo i hana'i o Iehova ke Akua i na holoholona a pau o ke kula, a me na manu a pau o ka lewa, a kai mai la ia lakou io Adamu la, i ikea na inoa a Adamu e kapa aku ai ia lakou: a o ka inoa a Adamu i kapa aku ai i na mea ola a pau, oia iho la kona inoa.
\q1 
\v 20 Kapa aku la o Adamu i na inoa no na holoholona laka a pau, a no na manu o ka lewa, a no na holoholona hihiu a pau; aka no Adamu, aole i loaa kona kokoolua e ku ia ia.
\b
\q1 
\v 21 Hookau mai la o Iehova ke Akua i ka hiamoe nui ia Adamu, a hiamoe iho la ia: unuhi ae la kela i kekahi iwiaoao ona, a hoopili iho la ia i ka io ma kona wahi.
\q1 
\v 22 A o ka iwiaoao a Iehova ke Akua i unuhi mai ai noloko mai o ke kanaka, hana iho la oia ia mea i wahine, a alakai ae la ia ia i ke hanaka.
\q1 
\v 23 I aku la o Adamu, Oia nei no ka iwi o kuu mau iwi, a me ka io o kuu io; e kapaia oia nei, wahine, no ka mea, ua unuhiia ae oia mailoko ae o ke kane.
\q1 
\v 24 No keia mea, e haalele aku ke kanaka i kona makuakane a me kona makuwahine, a e pili aku oia i kana wahine: a e lilo laua i io hookahi.
\q1 
\v 25 Aohe kapa o laua a elua, o ke kane a me kana wahine, aole hoi o laua hilahila.
\c 3
\b
\q1 
\v 1 U A oi aku ka maalea o ka nahesa i ko na holoholona o ke kula a pau a Iehova ke Akua i hana'i. I mai la ia i ka wahine, He oiaio anei, ua papa mai ke Akua, Aole olua e ai i ko na laau a pau o ka mahinaai nei!
\q1 
\v 2 I aku la ka wahine i ka nahesa, E pono no maua ke ai i ka hua o na laau o ka mahinaai nei:
\q1 
\v 3 Aka, o ka hua o ka laau iwaena konu o ke kihapai, ua i mai ke Akua, Mai ai olua ia mea, aole hoi e hoopa aku, o make olua.
\q1 
\v 4 Olelo mai la ka nahesa i ka wahine, Aohe oiaio e make olua:
\q1 
\v 5 No ka mea, ua ike no ke Akua, a i ka la e ai ai olua ia mea, e hookaakaaia auanei ko olua mau maka; a e like olua me ke Akua, i ka ike i ka pono a me ka hewa.
\b
\q1 
\v 6 A ike ae la ka wahine, he ono ko ia laau i mea ai, a he maikai hoi i na maka, a he laau makemakeia i mea hoonaauao, lalau aku la ia i kona hua, ai iho la, a haawi aku la hoi na kana kane me ia, a ai iho la no hoi oia.
\q1 
\v 7 A hookaakaaia ae la na maka o laua a elua, a ike iho la laua, aohe o laua kapa; kui iho la laua i na lau fiku a paa, i mau papalu no laua.
\b
\q1 
\v 8 Lohe ae la laua i ka leo o Iehova ke Akua, e holoholo ana ma ka mahinaai i ka wa malu o ka la: pee iho la o Adamu me kana wahine mawaena o na laau o ua mahinaai la, mai ke alo aku o Iehova ke Akua.
\b
\q1 
\v 9 Hea mai la o Iehova ke Akua ia Adamu, i mai la ia ia, Auhea oe?
\q1 
\v 10 I aku la oia, I lohe au i kou leo iloko o ka mahinaai nei, a makau no wau, no ka mea, aohe o'u kapa, a pee iho la au.
\q1 
\v 11 I mai la kela, Nawai i hai mai ia oe, aohe ou kapa? Ua ai anei oe i ko ka laau a'u i papa aku ai ia oe, Mai ai oe!
\q1 
\v 12 Olelo aku la ke kanaka, Na ka wahine au i haawi mai ai na'u, nana no i haawi mai i ko ka laau, a ai iho la au.
\q1 
\v 13 I mai la o Iehova ke Akua i ka wahine, Heaha keia mea au i hana'i! I aku la ka wahine, Na ka nahesa wau i hoowalewale mai, a ai iho la au.
\q1 
\v 14 I aku la o Iehova ke Akua i ka nahesa, No kau hana ana ia mea, e oi aku kou ahewaia i ko na holoholona laka a pau, a i ko na holoholona hihiu a pau o ke kula; ilalo kou alo e kolo ai oe, o ka lepo kau e ai ai, a pau na la o kou ola ana.
\q1 
\v 15 E waiho no au i ka inaina mawaena o olua a me ka wahine, a mawaena hoi o kou hua a me kona hua; nana e paopao iho kou poo, a nau hoi e pakuikui aku kona kuekuewawae.
\q1 
\v 16 I mai la hoi oia i ka wahine, E hoonui loa aku au i ka eha o kou hapai ana: me ka eha hoi oe e hanau mai ai i na keiki; a o kou makemake aku aia no ia i kau kane, a oia hoi kou haku.
\q1 
\v 17 I mai la hoi oia ia Adamu, No ka mea, ua hoolohe oe i ka leo o kau wahine, a ua ai hoi i ko ka laau a'u i papa aku ai ia oe, i ka i ana, Mai ai oe ia mea, ua hoohewaia ka aina nou; me ka luhi oe e ai ai i kana, a pau na la o kou ola ana:
\q1 
\v 18 E hookupu mai no hoi ia i na kakalaioa a me na puakala nau; a nau no e ai i na mea kanu o ka waena.
\q1 
\v 19 Me ka hou o kou maka e ai ai oe i ka ai, a hiki i kou wa e hoi hou aku ai i ka lepo; no ka mea, mailaila oe i laweia mai ai; no ka mea, he lepo no oe, a e hoi hou aku oe i ka lepo.
\b
\q1 
\v 20 Kapa aku la o Adamu i ka inoa o kana wahine, o I Eva; no ka mea, ka makuwahine ia o na kanaka a pau.
\q1 
\v 21 A hana iho la o Iehova ke Akua i na kapa ili no Adamu a no kana wahine, a hoaahu iho la ia laua.
\b
\q1 
\v 22 I iho la o Iehova ke Akua, Aia hoi, ua like ke kanaka me kekahi o kakou, ka ike i ka pono a me ka hewa: ano hoi, o lalau aku kona lima, a lawe hoi i ko ka laau ola, ai iho a ola mau loa aku:
\q1 
\v 23 No ia mea, kipaku aku la o Iehova ke Akua ia ia iwaho o ke kihapai o Edena, e mahi i ka lepo, kahi ana i laweia mai ai.
\q1 
\v 24 Pela oia i kipaku ai i ke kanaka; a hoonoho iho la ma ka hikina o ka mahinaai o Edena i na kerubima, a me ka pahi wakawaka e ka ana io ia nei i maluhia'i ke ala ma ka laau ola.
\c 4
\b
\q1 
\v 1 A IKE aku la o Adamu i kana wahine ia Eva; hapai ae la oia, a hanau mai la ia I Kaina, i mai la, Ua loaa no ia'u he kanaka no Iehova mai.
\q1 
\v 2 Hanau hou iho la oia i kona kaikaina ia Abela. He kahuhipa o Abela, a he mahiai o Kaina.
\q1 
\v 3 Mahope iho o na la, lawe aku la o Kaina i kekahi hua o ka honua i mohai na Iehova.
\q1 
\v 4 Lawe aku la hoi o Abela i kekahi o na hanau mua o kana poe hipa, i na mea momona hoi. A maliu mai la o Iehova ia Abela a me kana mohai:
\q1 
\v 5 Aka, aole ia i maliu mai ia Kaina a me kana mohai. Huhu loa iho la o Kaina, a kulou iho la kona maka ilalo.
\q1 
\v 6 I mai la o Iehova ia Kaina, Heaha kau i huhu ai? No ke aha hoi i kulou iho ai kou maka ilalo!
\q1 
\v 7 A i hana pono oe, aole anei oe e maliuia'ku? a i ole oe e hana i ka pono, ke waiho la ka mohai hala ma ka puka. A ia oe no ko ia la makemake, a e alii iho oe maluna ona.
\b
\q1 
\v 8 Kamailio ae la o Kaina me kona kaikaina, me Abela: a ia laua ma ka waena, ku ae la o Kaina me ke ku e i kona kaikaina ia Abela, pepehi iho la ia ia a make.
\b
\q1 
\v 9 Olelo mai la o Iehova ia Kaina, Auhea la o Abela o kou kaikaina! I aku la oia, Aole au i ike: owau anei ke kahu o kuu kaikaina!
\q1 
\v 10 I mai la kela, Heaha kau i hana iho net? ke hea mai nei ka leo o ke koko o kou kaikaina ia'u mai ka lepo mai.
\q1 
\v 11 Ma keia hone aku, e hoohewaia'ku ai oe mai ka honua ae, i hamama ae kona waha e ale i ke koko o kou kaikaina, na kou lima aku.
\q1 
\v 12 I kou mahi ana i ka honua, aole ia e hua mai ma keia hope i kona momona: a e lilo hoi oe i kanaka aea a me ke kuewa wale maluna o ka honua.
\q1 
\v 13 I aku la o Kaina ia Iehova, He nui loa kuu hewa: aole paha ia e hiki ke kalaia.
\q1 
\v 14 Aia hoi, ua kipaku aku oe ia'u i keia la mai ke alo aku o ka honua nei; a ua hookaawaleia au mai kou alo aku; a e lilo ana au i kanaka aea me ke kuewa wale maluna o ka honua; a i loaa au i kekahi, e pepehi mai ia ia'u a make.
\q1 
\v 15 I mai la o Iehova ia ia, Nolaila, o ka mea nana e pepehi ia Kaina, e pahiku ka hoopai ana i kona hewa. A kau iho la o Iehova i hoailona maluna o Kaina, o loaa ia i kekahi nana ia e pepehi aku a make.
\b
\q1 
\v 16 Hele aku la o Kaina mai ke alo aku o Iehova, a noho iho la ma ka aina o Noda, ma ka hikina o Edena.
\b
\q1 
\v 17 Ike aku la o Kaina i kana wahine; hapai ae la oia, a hanau mai la ia Enoka: kukulu iho la oia i kulanakauhale, a kapa iho la i ka inoa o ua kulanakauhale la, mamuli o ka inoa o kana keiki, o Enoka.
\q1 
\v 18 Na Enoka hoi i hanau mai o Irada: na Irada hoi o Mehuiaela: na Mehuiaela o Metusaela: na Metusaela o Lameka.
\b
\q1 
\v 19 Lawe ae la o Lameka i na wahine elua nana: o Ada ka inoa o kekahi, a o Zila ka inoa o kekahi.
\q1 
\v 20 Na Ada i hanau mai o Iabala: o ka makamua ia o ka poe noho halelewa, a o ka hanai holoholona.
\q1 
\v 21 A o Iubala ka inoa o kona kaikaina: o ka makamua ia o ka poe a pau i hookani i ka lira a me ka ohe.
\q1 
\v 22 A o Zila, hanau mai no hoi nana o Tubalakaina, oia ke kumu a na paahana a pau e kui ana i ke keleawe a me Ka hao: a o Naama ke kaikuwahine o Tubalakaina.
\q1 
\v 23 I aku la o Lameka i na wahine ana, ia Ada, laua o Zila, E hoolohe mai olua i ko'u leo; e na wahine a Lameka, e haliu mai i ka'u olelo: no ka mea, ua pepehi iho la au i ke kanaka no ka hoeha ana mai ia'u, i ke kanaka opiopio no ka paopao ana mai ia'u.
\q1 
\v 24 Ina paha e pahiku ka hoopai ana no Kama, he oiaio no, e pakanahiku me kumamahiku hoi ia no Lameka.
\b
\q1 
\v 25 Ike hou iho la o Adamu i kana wahine; a hanau mai la ia he keikikane, a kapa aku la i kona inoa o I Seta: No ka mea, ua haawi mai la ke Akua i ka hua hou na'u, wahi ana, i panihakahaka no Abela i pepehiia e Kaina.
\q1 
\v 26 Na Seta hoi i hanau kekahi keikikane; a kapa iho ia i kona inoa o Enosa: ia manawa ka hoomaka ana o na kanaka e kahea aku i ka inoa o Iehova.
\c 5
\b
\q1 
\v 1 EIA ka olelo kuauhau no na hanauna o Adamu. I ka la a ke Akua i hana'i ke kanaka, ma ke ano o ke Akua kana i hana mai ai ia ia.
\q1 
\v 2 He kane laua me ka wahine kana i hana'i; hoomaikai iho la oia ia laua, a kapa iho la i ko laua inoa o Adamu, i ka la i hanaia'i o laua.
\b
\q1 
\v 3 Hookahi haneri makahiki o ko Adamu ola ana a me kanakolu, a hanau mai nana ke keikikane i ku ia ia, ma kona ano iho; a kapa aku la i kona inoa o Seta:
\q1 
\v 4 O na la o Adamu mahope mai o ka hanau ana o Seta, ewalu ia haneri makahiki: a nana mai na keikikane a me na kaikamahine:
\q1 
\v 5 O na la a pau o ko Adamu ola ana, he eiwa haneri makahiki a me kanakolu: a make iho la ia.
\b
\q1 
\v 6 Hookahi haneri makahiki a me kumamalima o ko Seta ola ana, a hanau ae la o Enosa nana:
\q1 
\v 7 Ewalu haneri makahiki o ko Seta ola ana a me kumamahiku mahope mai o ka hanau ana o Enosa, a nana mai na keikikane a me na kaikamahine.
\q1 
\v 8 O na la a pau o Seta, eiwa ia haneri makahiki a me ka umikumamalua: a make iho la ia.
\b
\q1 
\v 9 He kanaiwa makahiki o ko Enosa ola ana, a hanau ae la o Kainana.
\q1 
\v 10 Ewalu haneri makahiki a me ka umikumamalima o ko Enosa ola ana, mahope mai o ka hanau ana o Kainana, a nana mai na keikikane a me na kaikamahine:
\q1 
\v 11 O na la a pau o Enosa, eiwa haneri makahiki a me kumamalima: a make iho la ia.
\b
\q1 
\v 12 He kanahiku na makahiki o ko Kainana ola ana, a hanau mai o Mahalaleela nana:
\q1 
\v 13 Mahope mai o ka hanau ana o Mahalaleela, ewalu haneri makahiki o ko Kainana ola ana a me kanaha, a nana mai na keikikane a me na kaikamahine:
\q1 
\v 14 A o na la a pau o Kainana, eiwa haneri makahiki a me ka umi keu: a make iho la ia.
\b
\q1 
\v 15 He kanaono na makahiki a me kumamalima o ko Mahalaleela ola ana, a hanau ae la o Iareda nana.
\q1 
\v 16 Mahope mai o ko Iareda hanau ana, ewalu haneri makahiki a me ke kanakolu o ko Mahalaleela ola ana, a nana mai na keikikane a me na kaikamahine.
\q1 
\v 17 O na la a pau o Mahalaleela, ewalu ia haneri makahiki a me kanaiwa kumamalima: a make iho la ia.
\b
\q1 
\v 18 Hookahi haneri makahiki o ko Iareda ola ana a me kanaonokumamalua, a hanau ae la o Enoka nana.
\q1 
\v 19 Mahope mai o ka hanau ana o Enoka, ewalu haneri makahiki o ko Iareda ola ana, a nana mai na keikikane a me na kaikamahine.
\q1 
\v 20 O na la a pau o Iareda, eiwa ia haneri makahiki a me ke kanaonokumamalua: a make iho la ia.
\b
\q1 
\v 21 He kanaonokumamalima na makahiki o ko Enoka ola ana, a hanau ae la o Metusala nana.
\q1 
\v 22 Hele pu ae la o Enoka me ke Akua, ekolu haneri makahiki mahope mai o ka hanau ana o Metusala, a nana mai na keikikane a me na kaikamahine:
\q1 
\v 23 O na la a pau o Enoka, ekolu haneri na makahiki a me kanaonokumamalima:
\q1 
\v 24 Hele pu ae la o Enoka me ke Akua, aole ia i make; no ka mea, na ke Akua ia i lawe aku.
\b
\q1 
\v 25 Hookahi haneri makahiki o ko Metusala ola ana a me kanawalukumamahiku, a hanau ae la o Lameka nana.
\q1 
\v 26 Mahope mai o ka hanau ana o Lameka, ehiku haneri me ke kanawalukumamalua na makahiki o ko Metusala ola ana, a nana mai na keikikane a me na kaikamahine.
\q1 
\v 27 O na la a pau o Metusala, eiwa haneri na makahiki a me kanaonokumamaiwa: a make iho la ia.
\b
\q1 
\v 28 Hookahi haneri na makahiki a me ke kanawalukumamalua o ko Lameka ola ana, a hanau ae la ke keikikane nana:
\q1 
\v 29 Kapa aku la ia i kona inoa, o Noa, i ae la, E hoomaha mai oia nei ia kakou i ka kakou hana ana a me ka luhi ana a ko kakou mau lima, no ka honua a Iehova i hoino mai ai.
\q1 
\v 30 Mahope mai o ka hanau ana o Noa, elima haneri na makahiki a me kanaiwakumamalima o ko Lameka ola ana, a nana mai na keikikane a me na kaikamahine.
\q1 
\v 31 A o na la a pau o Lameka, ehiku haneri makahiki a me kanahikukumamahiku: a make iho la ia.
\b
\q1 
\v 32 Elima haneri makahiki o Noa: a nana mai o Sema, a o Hama, a me Iapeta.
\c 6
\b
\q1 
\v 1 A I ka wa o ka hoomaka ana e mahuahua ai na kanaka maluna o ka honua, a ua hanau mai na kaikamahine a lakou.
\q1 
\v 2 Ike ae la na keiki a ke Akua i na kaikamahine a na kanaka, ua maikai lakou; lalau aku la lakou i na mea a lakou i makemake ai i mau wahine na lakou.
\q1 
\v 3 I iho la o Iehova, Aole e noho loa ana kuu Uhane me kanaka, no ka mea, he kino no ia; aku, o kona mau la ma keia hope aku, he haneri makahiki ia a me ka iwakalua.
\q1 
\v 4 Noho iho la na kanaka nunui ma ka honua ia manawa; a mahope aku, a komo aku la na keiki a ke Akua iloko i na kaikamahine a na kanaka, a hanau mai na lakou ka poe kanaka ikaika, he poe kanaka kaulana lakou i ka wa kahiko.
\b
\q1 
\v 5 A ike mai la ke Akua, he nui ka hewa o kanaka ma ka honua, a ua hewa wale no ka noonoo ana o kona naau, ana i manao ai i na la a pau.
\q1 
\v 6 A mihi iho la o Iehova i kana hana ana i na kanaka maluna o ka honua, a ua ehaeha kona naau.
\q1 
\v 7 I iho la o Iehova, E luku auanei au i na kanaka a'u i hana'i, mai ke alo aku o ka honua, i na kanaka a me na holoholona, a me na mea kolo, a me na manu o ka lewa: no ka mea, ke mihi nei au i ka'u hana ana ia lakou:
\q1 
\v 8 Aka, loaa ia Noa ke alohaia mai imua o Iehova.
\b
\q1 
\v 9 Eia ka mooolelo no Noa: He kanaka pono o Noa, a he hemolele iwaena o na hanauna ona, a hele pu o Noa me ke Akua.
\q1 
\v 10 Ua hanau mai na Noa ekolu keikikane, o Sema, o Hama, a o Iapeta.
\q1 
\v 11 Ua inoino hoi ka honua imua o ke Akua; a ua piha ka honua i ka hoino.
\q1 
\v 12 Nana mai la ke Akua i ka honua, aia hoi, ua inoino ia; no ka mea, ua hana ino na kanaka a pau i ko lakou aoao ma ka honua.
\b
\q1 
\v 13 Olelo mai la o Iehova ia Noa, Ua hiki mai i ko'u alo nei ka hope o na mea ola a pau; no ka mea, ua piha ka honua i ka hoino ma o lakou la: aia hoi, e luku auanei au ia lakou ma ka honua.
\b
\q1 
\v 14 E hana oe i halelana nou; e hana hoi oe i na keena maloko o ka halelana, a e hapala ae i ke kepau maloko a mawaho.
\q1 
\v 15 Penei kau e hana aku ai: ekolu haneri kubita o ka loa o ka halelana, he kanalima na kubita ka laula, a he kanakolu na kubita o kona kiekie.
\q1 
\v 16 He malamalama kau e hana'i ma ka halelana, a e hoopaa ia mea maluna ma ke kubita; a e kau oe i ka pukakomo o ka halelana ma kona paia: a he papalalo, me ka papawaena, a me ka papaluna kau e hana'i ma ia mea.
\q1 
\v 17 A owau la e, e lawe mai ana au i ke kaiakahinalii maluna o ka honua, i mea e lukuia'i na mea io a pau, i ka poe nona ka hanu ola malalo o ka lani; a e make na mea a pau ma ka honua.
\q1 
\v 18 Aka, e hoopaa aku au i ka'u berita ia oe; a e komo ae oe iloko o ka halelana, o oe, me kau mau keikikane, a me kau wahine, a me na wahine a kau mau keikikane.
\q1 
\v 19 A no na mea io a pau e ola ana, e lawe oe i elua o kela mea keia mea iloko o ka halelana, i kane i wahine, i malama ola pu ia lakou me oe.
\q1 
\v 20 O na manu ma ko lakou ano, a o na holoholona, ma ko lakou ano, a o kela mea kolo keia mea kolo o ka honua, ma kona ano iho, e hele papalua mai lakou iou la, i malama ola ia lakou.
\q1 
\v 21 E lawe oe nau i na mea ai a pau, a e hoiliili oe ia iou la; i mea ai nau, a na lakou.
\q1 
\v 22 Pela o Noa i hana'i; ma ka mea a pau a ke Akua i kauoha mai ai ia ia, pela oia i hana'i.
\c 7
\b
\q1 
\v 1 I MAI ia o Iehova ia Noa, E komo ae oe me kau ohana a pau iloko o ka halelana; no ka mea, o oe no o keia hanauna ka'u i ike ai, he pono imua o'u.
\q1 
\v 2 O na holoholona maemae a pau, e lawe pahiku aku oe ia lakou me oe, i ke Kane a me kana wahine; a o na holoholona maemae ole, e papalua he kane me kana wahine,
\q1 
\v 3 E pahikuia no hoi na manu o ka lewa, ke kane, ka wahine, e hoola i kumuhoolaha maluna o ka honua a pau.
\q1 
\v 4 No ka mea, ehiku la e koe, alaila e hooua iho ai au maluna o ka honua he kanaha la a me na po; a e luku ana au i na mea ola a pau a'u i hana'i, mai ke alo o ka honua aku.
\q1 
\v 5 Hana iho la o Noa i na mea a pau a Iehova i kauoha mai ai ia ia.
\b
\q1 
\v 6 Eono haneri na makahiki o Noa i ka wa i hiki mai ai ke kaiakahinalii maluna o ka honua.
\b
\q1 
\v 7 Komo aku la e Noa me na keikikane ana, a me kana wahine, a me na wahine a kana mau keikikane iloko o ka halelana, no ke kaiakahinalii.
\q1 
\v 8 O na holoholona maemae a me na holoholona maemae ole, a o na manu, a me na mea kolo a pau maluna o ka honua.
\q1 
\v 9 Komo papalua aku la lakou iloko io Noa la, ke kane, ka wahine, me ka ke Akua i kauoha mai ai ia Noa.
\b
\q1 
\v 10 A hala ae la na la ehiku, hiki mai ke kaiakahinalii maluna o ka honua.
\b
\q1 
\v 11 I ka makahiki eono haneri o ko Noa ola ana, i ka lua o ka malama, a ma ka la umikumamahiku o ua malama la, ia la no, huahuai mai la na panawai a pau o ka hohonu nui, a hamarna ae la na puka wai o ka lani.
\q1 
\v 12 Hookahi kanaha la a me na po o ka ua ana maluna o ka honua.
\b
\q1 
\v 13 Ia la hookahi no, komo ae la o Noa, a o Sema, a o Hama, a o Iapeta, na keikikane a Noa, a me ka wahine a Noa, a me na wahine ekolu a kana mau keikikane me lakou, iloko o ka halelana.
\q1 
\v 14 O lakou me na holoholona hihiu a pau ma ko lakou ano iho, a me na holoholona laka a pau ma ko lakou ano iho, a me kela mea kolo keia mea kolo, e kolo ana maluna o ka honua ma kona ano iho, a me na manu a pau ma ko lakou ano iho, o na mea eheu a pau, o kela ano keia ano.
\q1 
\v 15 Komo papalua ae la lakou io Noa la iloko o ka halelana, o na mea io a pau e ha ana i ka hanu ola.
\q1 
\v 16 He kane he wahine o na mea io a pau ka poe i komo aku iloko, mo ka ke Akua i kauoha mai ai ia ia: a papani ae la o Iehova i ka puka mahope ona.
\b
\q1 
\v 17 Hookahi kanaha la o ke kaiakahinalii maluna o ka honua; mahuahua ae la ka wai, a hoolana ae la i ka halelana, a ua kaikaiia ae la ia maluna o ka honua.
\q1 
\v 18 Lanakila ae la ka wai a mahuahua loa ae la maluna o ka honua; a holo aku la ka halelana maluna o ka wai.
\q1 
\v 19 Lanakila loa ae la ka wai maluna o ka honua; a uhiia ae la na kuahiwi kiekie a pau loa malalo o ka lani.
\q1 
\v 20 He umikumamalima na kubita o ke kiekie o ka wai maluna; a uhiia ae la na kuahiwi.
\q1 
\v 21 A make iho la na mea ola a pau i holo maluna o ka honua, o na manu, o na holoholona laka, o na holoholona hihiu, a o na mea kolo a pau e kolo ana maluna o ka honua, a me na kanaka a pau;
\q1 
\v 22 O ka poe a pau nona ka hanu ola iloko o na puka ihu, o na mea a pau ma ka aina maloo, make iho la lakou.
\q1 
\v 23 A pau loa iho la na mea ola maluna o ka honua i ka make, o na kanaka, me na holoholona, a me na mea kolo, a me na manu o ka lewa; a ua hoopauia lakou mai ka honua aku: o Noa wale no ka i koe, a me ka poe me ia iloko o ka halelana.
\q1 
\v 24 A lanakila ae la ka wai maluna o ka honua, hookahi haneri na la a me kanalima.
\c 8
\b
\q1 
\v 1 HOOMANAO iho la o Iehova ia Noa, a me na mea ola a pau, a me na holoholona a pau me ia iloko o ka halelana: hoohuai mai la ke Akua i ka makani maluna o ka honua, a emi iho la ka wai:
\q1 
\v 2 Ua papaniia ae la na punawai o ka hohonu, a me na puka wai o ka lani, a malie iho ka ua mai luna mai:
\q1 
\v 3 Hoi hou mau aku la ka wai mailuna ae o ka honua: a mahope o na la he haneri a me kanalima, ua emi ka wai.
\b
\q1 
\v 4 A i ka hiku o ka malama, i ka la umikumamahiku o ua malama la, ili iho la ka halelana ma na kuahiwi o Ararata.
\q1 
\v 5 Emi mau iho la ka wai, a hiki i ka umi o ka malama: i ka umi o ka malama, i ka la mua o ua malama la, ua ikea na wahi kiekie o na kuahiwi.
\b
\q1 
\v 6 A hala na la he kanaha, wehe ae la o Noa i ka puka makani o ka halelana ana i hana'i:
\q1 
\v 7 Hookuu aku la ia i kekahi koraka, nana i lele aku a hoi mai ma kela wahi a ma keia wahi, a maloo iho ka wai ma ka honua.
\q1 
\v 8 Hookuu aku la hoi oia i ka manu nunu e ike i ka emi ana o ka wai mai ka aina aku;
\q1 
\v 9 Aka, aole i loaa i ua manu nunu la he wahi e maha'i o kona wawae, a hoi hou mai la ia io na la iloko o ka halelana, no ka mea, ua uhi ka wai maluna o ka honua a pau; alaila, o aku la kona lima, lalau aku la oia ia ia, a huki mai la ia ia io na la iloko o ka halelana.
\q1 
\v 10 Noho iho la ia i na la hou aka i ehiku; a hookuu hou aku la i ka manu nunu iwaho o ka halelana;
\q1 
\v 11 A ahiahi iho la, hoi mai la ka manu nunu io na la, aia hoi, he lau oliva hou ma kona waha. Pela o Noa i ike ai, ua emi iho ka wai mai luna aka o ka honua.
\q1 
\v 12 Noho iho la ia i na la hou aku i ehiku; a hookuu aku la i ka manu nunu; aole no ia i hoi hou mai io na la ma ia hope mai.
\b
\q1 
\v 13 I ka makahiki eono haneri a me kumamakahi, i ka malama hookahi, a i ka la mua o ua malama la, maloo iho la ka wai mai ka honua aku; a wehe ae la o Noa i ke pani maluna o ka halelana, a nana ae la, aia hoi, ua maloo ka aina.
\q1 
\v 14 A i ka lua o ka malama, i ka la iwakaluakumamahiku o ua malama la, ua maloo iho ka honua.
\b
\q1 
\v 15 Olelo mai la ke Akua ia Noa, i mai la,
\q1 
\v 16 E hele aku oe iwaho o ka halelana, o oe, me kau wahine, me au mau keikikane, a me na wahine a kau mau keikikane me oe.
\q1 
\v 17 E lawe pu mai me oe i na mea ola a pau ia oe, o na mea io, o na manu, na holoholona, a me na mea kolo a pau e kolo ana maluna o ka honua; i hanau nui ai lakou ma ka honua, i hua mai, a mahuahua maluna o ka honua.
\q1 
\v 18 Hele aku la o Noa me kana mau keikikane, a me kana wahine, a me na wahine a kana mau keikikane me ia:
\q1 
\v 19 O na holoholona hoi a pau, o na mea kolo a pau, me na manu a pau, a me na mea a pau e kolo ana maluna o ka honua, ma ko lakou mau ano iho, hele aku la lakou iwaho o ka halelana.
\b
\q1 
\v 20 Hana iho la o Noa i kuahu no Iehova, lalau aku la ia i kekahi o na holoholona maemae a pau, a o na manu maemae a pau, a kaumaha aku la i na mohaikuni maluna o ke kuahu.
\q1 
\v 21 Honi mai la o Iehova i ke ala oluolu: i iho la o Iehova iloko o kona naau, Aole au e hoino hou i ka aina no kanaka, no ka mea, ua hewa no ka manao ana o ko ke kanaka naau mai kona wa opiopio; aole hoi au e luku hou aku i na mea ola a pau, me au i hana iho nei.
\q1 
\v 22 E mau auanei ka wa e kanu ai a e ohi ai; ke ana a me ka wela, ke kau a me ka hooilo, ka la a me ka po; a pau na la o ka honua.
\c 9
\b
\q1 
\v 1 HOOPOMAIKAI mai la ke Akua ia Noa, a me kana mau keikikane, i mai la ia lakou, E hoohua mai oukou, e mahuahua, a e hoopiha i ka honua.
\q1 
\v 2 E kau mai auanei ka makau ia oukou a me ka weliweli maluna o na holoholona a pau o ka honua, maluna hoi o na manu a pau e ka lewa, a maluna hoi o na mea a pau e hele ana ma ka honua, a maluna no hoi o na ia a pau o ke kai; ua haawiia'ku lakou iloko o na lima o oukou.
\q1 
\v 3 O na mea hele a pau e ola ana, na oukou ia e ai; me ka'u i haawi aku ai i na launahele opiopio na oukou, pela ka'u e haawi aku nei i na mea a pau.
\q1 
\v 4 Aka, mai ai oukou i ka io me kona ola, oia kona koko.
\q1 
\v 5 He oiaio, e hoopai auanei au i ke koko o ko oukou ola; ma ka lima o na holoholona a pau ka'u e hoopai aku ai; a ma ka lima hoi o na kanaka; ma ka lima hoi o ka hoahanau o kela kanaka keia kanaka ka'u e hoopai aku ai i ke ola o kanaka.
\q1 
\v 6 O ka mea nana e hookahe i ke koko o kanaka, e hookaheia no kona koko e kanaka: no ka mea, ma ke ano o ke Akua oia i hana'i i kanaka.
\q1 
\v 7 A oukou, e hoohua mai oukou, a e mahuahua; e hanau nui ma ka honua, a e hoolaha malaila.
\b
\q1 
\v 8 Olelo mai la ke Akua ia Noa a i kana mau keiki me ia, i mai la,
\q1 
\v 9 Owau la e, ke hoopaa nei au i ka u berita me oukou a me ka oukou poe mamo mahope o oukou:
\q1 
\v 10 A me na mea ola a pau me oukou, o na manu, o na holoholona laka a me na holoholona hihiu o ka honua me oukou: mai ka poe a pau i hele mai iwaho e ka halelana, a i na holoholona a pau o ka honua.
\q1 
\v 11 E hoopaa no wau i ka'u berita me oukou: aole hoi e luku hou ia ua mea ola a pau i na wai o ke kaiakahinalii: aole hoi he kaiakahinalii e hiki hou mai ana e pau ai ka honua.
\q1 
\v 12 I mai la ke Akua. Eia ka hoailona o ka berita a'u e hana nei mawaena o'u a o oukou, me na mea ola a pau me oukou, no ua hanauna a pau.
\q1 
\v 13 Ke kau nei au i kuu anuenue ma ke ae, i hoailona ia uo ka berita mawaena o'u a o ka honua.
\q1 
\v 14 A hoouhi aku ai au i ke ao maluna o ka honua, e ikea auanei ke anuenue ma ke ae.:
\q1 
\v 15 A e hoomanao iho uo au i ka'u berita mawaena o'u a o oukou, me na mea io e ola ana a pau: aole loa e lilo hou ana ka wai i kaiakahinalii e luku ai i na mea io a pau.
\q1 
\v 16 A e kau mai auanei ke anuenue ma ke ao: a e nana aku au ia i hoomanao iho ai au i ka berita mau loa mawaena o ke Akua a o na mea ola a pau o na mea io a pau maluna o ka honua.
\q1 
\v 17 Olelo mai la ke Akua ia Noa Ola ka hoailona o ka berita a'u i hoopaa iho ai mawaena o'u a e na mea io a pau maluna o ka houna.
\b
\q1 
\v 18 O na keikikane a Noa. ua mea i puka mai iwaho o ka halelana. oia o Sema, o Hama, a o lapeta: a o Hama ka makuakaue no Kananna.
\q1 
\v 19 O lakou ua keikikane ekolu a Noa. a na lakou i hoolalaia ku [na kanaka] ma ka honua a pau.
\b
\q1 
\v 20 Hoomaka iho la o Noa e mahiai, a kanu iho la ia i ka malawaina:
\q1 
\v 21 Inu iho la ia i ka waina, a ona: a ua uhi ole ia oia i ke kapa maloko o kona halelewna.
\q1 
\v 22 Ike aku la o Hama ka makuakane o Kauaana i kahi hilahila o kona makuakane. a hai mai la i kona mau hoahanau elua mawaho.
\q1 
\v 23 Lalau aku la o Sema laua o Iapeta i ka aahu. a kau iho la maluna o ko laua mau poohiwi. a hele hope aku la laua. a uhi iho la i kahi hilahila o ko laua makuakane: ua huli hope ko laua mau maka. a ike ole aku laua i kahi hilahila o ko laua makuakane.
\q1 
\v 24 Ala ae la o Noa i ka pau ana o kona waina. a ike iho la ia i ka mea a kana keiki muli iho i hana aku ai ia ia.
\q1 
\v 25 Olelo mai la oia. E poino ne o Kanaaua: he kauwa ia ua na kauwa a kona poe hoahanau.
\q1 
\v 26 Olelo mai la hoi oia. E hoomaikaiia o Iehova. ke Akua o Sema: a o Kauaana kana kauwa.
\q1 
\v 27 E hoomahuahua auanei ke Akua ia Iapeta, a e noho no auanei ia ma ua halelewa o Sema: a o Kauaana kana kauwa.
\b
\q1 
\v 28 A e ko Noa ola ana mahope o ke kaiakahinalii, akolu ia haneri makahiki a me kanalima.
\q1 
\v 29 O ua la a pau o Noa. aiwa ia haneri makahiki a me kanalima: a make iho la ia.
\c 10
\b
\q1 
\v 1 EIA ka mooolelo no na keikikane a Noa o Sema, o Hama, a o Iapeta: ua hanau na lakou na keikikaua mahope o ke kaiakahinalii.
\b
\q1 
\v 2 O na keikikane a lapeta: o Gomera, o Magoga, o Madai, o lavaua. o Tuhala. o Meseka, a o Tirasa.
\q1 
\v 3 O na keikikane a Gomera: o Asekenaza, o Kipata, a o Elia.
\q1 
\v 4 O na keikikane a lavana o Elia. o Taresisa. o Kitima, a o Dodanima.
\q1 
\v 5 Ua puunaneia na aina kahakai o na lahuikanaka e lakeu nei ma ke lakou mau aina, e kela mea a o keia mea e like me kana olelo, mamuli o ka lakou mau ohnau, ma na lahuikanaka o lakou.
\b
\q1 
\v 6 O na keiki a Hama: o Kusa. o Migeraima, e Puta, a o Kanaaua.
\q1 
\v 7 O na keikikane a Kusa: o Seba e Havila. o Sabeta. e Raama, a o Sabeteka: a o na keikikane a Raama: o Seba, a o Dedana.
\q1 
\v 8 Na Kusa o Nimeroda: hoomaka iho la ia e hoolanakila ma ka honua nei.
\q1 
\v 9 He kanaka koa ia i ka hahai holoholona imua o Iehova: nolaila i oleloia'i, E like me Nimeroda ka mea koa loa, ka hahai holoholona imua o Iehova.
\q1 
\v 10 O ka hoomaka ana o kona aupuni, oia o Babela, o Araka, o Akada, a o Kalene, ma ka aina o Sinara.
\q1 
\v 11 Ma ia aina aku i hele aku ai o Asura, a kukulu iho la ia Nineva, a me ke kulanakauhale o Rehobota, a me Kala,
\q1 
\v 12 A me Resena mawaena o Nineva a o Kala: he kulanakauhale nui no ia.
\q1 
\v 13 Na Mizeraima ka Luda, me ka Anama, me ka Lehaba, me ka Naputuha.
\q1 
\v 14 Me ka Paterima, me ka Kaseluhima, (na lakou mai ka Pilisetia,) a me ka Kapetora.
\b
\q1 
\v 15 Na Kanaana mai o Sidona, kana hiapo, a o Heta,
\q1 
\v 16 A o ka Iebusa, a o ka Amora, a o ka Giragasa,
\q1 
\v 17 A o ka Hiva, a o ka Areka, a o ka Sinite,
\q1 
\v 18 A o ka Aravada, a o Zemara, a o ka Hamata: a mahope iho ua hoolahaia'ku na ohana a ka poe Kanaana.
\q1 
\v 19 A o ka mokuna aina o ka Kanaana, mai Sidona ia, i kona hele ana mai i Gerara, a hiki i Gaza; i kou hele ana aku i Sodoma, me Gomora, a me Adema, a me Geboima, a hiki i Lasa.
\q1 
\v 20 Oia na keikikane a Hama, mamuli o ka lakou mau ohana, mamuli hoi o ka lakou mau olelo, ma na aina o lakou, a ma na lahuikanaka o lakou.
\b
\q1 
\v 21 Na Sema hoi, na ka makuakane o ka poe keiki a pau a Ebera, na ke kaikaina a Iapeta ka hoahanau mua, ua hanau no hoi na keiki nana.
\q1 
\v 22 O na keiki a Sema; o Elama, o Asura, o Arepakada, o Luda, a o Arama.
\q1 
\v 23 O na keikikane a Arama; o Uza, o Kula, a o Getera, a o Masa.
\q1 
\v 24 Na Arepakada o Sala, na Sala hoi o Ebera.
\q1 
\v 25 Ua hanau na Ebera na keikikane elua: o Pelega ka inoa o kekahi; no ka mea, ua maheleia ka honua i kona mau la; a o Ioketana ka inoa o kona kaikaina.
\q1 
\v 26 Na Ioketana o Alemodada, o Selepa, a Hazamaveta, o Iera,
\q1 
\v 27 O Hadorama, o Uzala, o Dikela,
\q1 
\v 28 O Obala, o Abimaela, o Seba,
\q1 
\v 29 O Opira, o Havila, a o Iobaba: o lakou nei a pau na keikikane a Ioketana.
\q1 
\v 30 A o ko lakou wahi noho ai, mai Mesa aku no ia, i kou hele ana a hiki i Separa, i kekahi mauna o ka hikina.
\q1 
\v 31 Oia na keikikane a Sema, mamuli o ka lakou mau ohana, mamuli hoi o ka lakou mau olelo, ma ko lakou mau aina, a me ko lakou mau lahuikanaka.
\b
\q1 
\v 32 Oia na ohana a na keikikane a Noa, e like me ko lakou mau hanauna, ma ko lakou mau lahuikanaka; ma o lakou nei ua maheleia na lahuikanaka ma ka honua mahope mai o ke kaiakahinalii.
\c 11
\b
\q1 
\v 1 HOOKAHI no lehelehe, hookahi hoi olelo a ko ka honua a pau.
\q1 
\v 2 A i ko lakou hele ana mai ka hikina mai, loaa ia lakou kahi papu ma ka aina o Sinara; a noho iho la lakou ilaila.
\q1 
\v 3 Olelo ae la kekahi kanaka i kona hoa, Ina kakou, e hana kakou i na pohaku ula, e kahu a moa loa. O ko lakou pohaku, he pohaku ula, a he bitumena ko lakou puna.
\q1 
\v 4 Olelo ae la lakou, Ina kakou, e hana kakou i kulanakauhale no kakou, a me ka halepakui e kiekie ae kona welau i ka lani; a e hookaulana i ko kakou inoa, o hoopuehuia'ku kakou maluna o ka honua a pau.
\q1 
\v 5 Iho mai la o Iehova ilalo e nana i ke kulanakauhale a me ka halepakui a na keiki a kanaka i hana'i.
\q1 
\v 6 I iho la o Iehova, Aia hoi, hookahi no ka poe kanaka, hookahi hoi ko lakou lehelehe; eia ka lakou e hoomaka nei e hana: a mahope aku, aohe mea keakea ia lakou ke hana i na mea a pau a lakou e manao ai.
\q1 
\v 7 Ina kakou, e iho iho kakou, a malaila kakou hookahuli ai i ka lakou olelo, i hoomaopopo ole ai lakou i ka olelo a kekahi.
\q1 
\v 8 Pela o Iehova i hoopuehu aku ai ia lakou maluna o ka honua a pau: a oki iho la ka lakou hana ana i ua kulanakauhale la.
\q1 
\v 9 No ia mea, ua kapaia ka inoa o ia wahi, o Babela, no ka mea, ilaila o Iehova i hookahuli ai i ka olelo a ko ka honua a pau: a mai ia wahi aku i hoopuehu aku ai o Iehova ia lakou maluna o ka honua a pau.
\b
\q1 
\v 10 Eia ka mooolelo na Sema: hookani haneri makahiki o Sema, a hanau mai o Arepakada nana, elua makahiki mahope mai o ke kaiakahinalii.
\q1 
\v 11 Mahope mai o ka hanau ana o Arepakada, alima haneri no makahiki o ko Sema ola ana, a nana mai na keikikane a me na kaikamahine.
\b
\q1 
\v 12 He kanakolu na makahiki a me kumamalima o ko Arepakada ola ana, a hanau mai o Sala nana:
\q1 
\v 13 Mahope mai o ka hanau ana o Sala, aha haneri na makahiki a me kumamakolu o ko Arepakada ola ana, a nana mai na keikikane a me na kaikamahine.
\b
\q1 
\v 14 He kanakolu na makahiki o ko Sala ola ana, a hanau mai o Ebera nana:
\q1 
\v 15 Mahope mai o ka hanau ana o Ebera, aha haneri na makahiki me kumamakolu o ko Sala ola ana, a nana mai na keikikane a me na kaikamahine.
\b
\q1 
\v 16 He kanakolu na makahiki a me kumamaha o ko Ebera ola ana, a hanau mai o Pelega nana:
\q1 
\v 17 Mahope mai o ka hanau ana o Pelega, aha haneri na makahiki a me kanakolu o ko Ebera ola ana, a nana mai na keikikane a me na kaikamahine.
\b
\q1 
\v 18 He kanakolu na makahiki o ko Pelega ola ana, a hanau mai o Reu nana:
\q1 
\v 19 Mahope mai o ko Reu hanau ana, alua haneri na makahiki a me kumamaiwa o ko Pelega ola ana, a nana mai na keikikane a me na kaikamahine.
\b
\q1 
\v 20 He kanakolu na makahiki a me kumamalua o ko Reu ola ana, a hanau mai o Seruga nana:
\q1 
\v 21 Elua haneri na makahiki a me kumamahiku o ko Reu ola ana mahope mai o ka hanau ana o Seruga, a nana mai na keikikane a me na kaikamahine.
\b
\q1 
\v 22 He kanakolu na makahiki o ko Seruga ola ana, a hanau mai o Nahora nana:
\q1 
\v 23 Mahope mai o ka hanau ana o Nahora, elua haneri na makahiki o ko Seruga ola ana, a nana mai na keikikane a me na kaikamahine.
\b
\q1 
\v 24 He iwakalua na makahiki a me kumamaiwa o ko Nahora ola ana, a hanau mai o Tera nana:
\q1 
\v 25 Mahope mai o ka hanau ana o Tera, he haneri na makahiki a me ka umikumamaiwa o ko Nahora ola ana, a nana mai na keikikane a me na kaikamahine.
\b
\q1 
\v 26 He kanahiku na makahiki o ko Tera ola ana, a hanau mai o Aberama, o Nahora, a o Harana.
\b
\q1 
\v 27 Eia ka mooolelo no Tera; na Tera o Aberama, o Nahora, a o Harana; na Harana o Lota.
\q1 
\v 28 Make iho la o Harana mamua o kona makuakane o Tera, ma kona aina i hanau ai, ma Ura no ko Kaledea.
\q1 
\v 29 Lawe ae la o Aberama laua o Nahora i mau wahine na laua: o Sarai ka inoa o ka wahine a Aberama, a o Mileka ka inoa o ka wahine a Nahora; oia ke kaikamahine a Harana, a ka makuakane o Mileka, a o ka makuakane hoi o Iseka.
\q1 
\v 30 A he pa o Sarai; aohe ana keiki.
\b
\q1 
\v 31 Lawe ae la o Tera i kana keiki ia Aberama, a me kana moopuna ia Lota, ke keiki a Harana, a me Sarai kana hunonawahine, o ka wahine a kana keiki a Aberama; a haele pu mai la lakou mai Ura mai no ko Kaledea, i ka hele ana ma ka aina o Kanaana: hiki mai la lakou i Harana, a noho iho la ilaila.
\q1 
\v 32 O na la o Tera, elua ia haneri makahiki a me kumamalima: a make iho la o Tera ma Harana.
\c 12
\b
\q1 
\v 1 I OLELO mai o Iehova ia Aberama, E hele aku oe mai kou aina aku, a mai kou poe hoahanau aku, a mai ka hale o kou makuakane aku, a hiki i ka aina a'u e kuhikuhi aku ai ia oe.
\q1 
\v 2 A e hoolilo au ia oe i lahuikanaka nui, e hoomaikai aku hoi au ia oe, e hookaulana hoi au i kou inoa, a e lilo oe i mea e pomaikai ai.
\q1 
\v 3 E hoopomaikai aku hoi au i ka poe hoomaikai ia oe, a e hoino aku au i ka mea hoino ia oe, a ia oe e pomaikai ai na ohana a pau o ka honua.
\b
\q1 
\v 4 Hele aku la o Aberama e like me ka Iehova i olelo mai ai ia ia; a hele pu o Lota me ia. He kanahiku kumamalima na makahiki o Aberama, i kona wa i hele mai ai mai Harana mai.
\q1 
\v 5 Lawe ae la o Aberama i kana wahine ia Sarai, a me Lota ke keiki a kona kaikuaana, a me ka waiwai a pau a lakou i hoiliili ai, a me na ohua a pau i loaa ia lakou ma Harana; a puka mai la lakou e hele mai i ka aina o Kanaana; a hiki mai la lakou i ka aina o Kanaana.
\b
\q1 
\v 6 Kaahele ae la o Aberama i ka aina, a hiki aku la i kahi o Sikema, i ka laau oka o More. E noho ana no na mamo a Kanaana ma ia aina ia manawa.
\q1 
\v 7 Ikea ae la o Iehova e Aberama, i mai la ia, E haawi aku no wau i keia aina no kau poe mamo: malaila oia i hana'i i kuahu no Iehova, ka mea i ikea e ia.
\q1 
\v 8 Hele aku la ia mai ia wahi aku a ka puu ma ka hikina o Betela, a kukulu iho la i kona halelewa, o Betela ma ke komohana, a o Hai ma ka hikina: malaila oia i hana'i i kuahu no Iehova, a hea aku la ia i ka inoa o Iehova.
\q1 
\v 9 Hele hou aku la o Aberama e neenee ana i ke kukuluhema.
\b
\q1 
\v 10 He wi ma ia aina; a hele aku la o Aberama ilalo i Aigupita e noho malihini malaila, no ka mea, ua nui loa ka wi ma ka aina.
\q1 
\v 11 A kokoke aku la ia e komo i Aigupita, i aku la ia i kana wahine ia Sarai, Eia hoi ke ike nei au he wahine maikai oe ke nanaia'ku:
\q1 
\v 12 Nolaila, a ike mai ko Aigupita ia oe, e olelo auanei lakou, Eia kana wahine; a e pepehi mai lakou ia'u, a e hoola ae lakou ia oe.
\q1 
\v 13 Ke nonoi aku nei au ia oe, e i aku oe, he kaikuwahine oe no'u, i pomaikai ai au ia oe, a e malamaia kuu ola nou.
\b
\q1 
\v 14 A hiki aku la o Aberama i Aigupita, ike mai la ko Aigupita i ka wahine he maikai loa.
\q1 
\v 15 A ike mai la na luna a Parao ia ia, hoomaikai lakou ia ia imua o Parao, a ua laweia aku la ua wahine la ma ka hale o Parao.
\q1 
\v 16 Lokomaikai mai la oia ia Aberama no Sarai: a ia ia na hipa, na bipi, na hoki, na kauwakane, na kauwawahine, na hokiwahine, a me na kamelo.
\q1 
\v 17 Hooeha mai la o Iehova ia Parao a me kona poe ohua i na mai eha loa, no Sarai ka wahine a Aberama.
\q1 
\v 18 Kahea mai la o Parao ia Aberama, i mai la, Heaha keia mea au i hana mai ai ia'u? No ke aha la i hai ole mai oe ia'u o kau wahine ia?
\q1 
\v 19 No ke aha la oe i olelo mai ai, O ko'u kaikuwahine ia, i mea e lawe ai au ia ia i wahine na'u? Eia hoi kau wahine, e lawe oe ia ia, a e hele aku.
\q1 
\v 20 Kauoha aku la o Parao i kona poe kanaka nona, a hoihoi mai la lakou ia ia, me kana wahine, a me kana mau mea a pau.
\c 13
\b
\q1 
\v 1 PII hou mai la o Aberama mai Aigupita mai, oia me kana wahine, a me kana mau mea a pau, a me ia no o Lota, i kau wahi o ke kukuluhema.
\q1 
\v 2 Ua waiwai nui loa o Aberama i na holoholona, i ke kala a me ke gula.
\q1 
\v 3 Hele ae la ia i kona hele ana mai ke kukuluhema mai a Betela, kahi i ku ai o kona halelewa mamua, mawaena o Betela a me Hai;
\q1 
\v 4 Kahi o ke kuahu ana i haua'i mamua: ilaila o Aberama i kahea aku ai i ka inoa o Iehova.
\b
\q1 
\v 5 A o Lota hoi, ka mea i hele pu me Aberama, he hipa no kana me na bipi a me na halelewa.
\q1 
\v 6 Aole i pono ka aina no laua, i noho pu ai laua, no ka nui o ko laua waiwai, aole i hiki ia laua ke noho pu.
\b
\q1 
\v 7 Hakaka ae la ka poe kahubipi a Aberama me ka poe kahubipi a Lota: e noho ana no ka Kanaana a me ka Perezi ma ia aina ia manawa.
\q1 
\v 8 I aku la o Aberama ia Lota, Ea, aole make hakaka kaua, kekahi i kekahi, aole hoi ka'u poe kahubipi me kau poe kahubipi; no ka mea, he mau hoahanau kaua.
\q1 
\v 9 Aole anei ma kou alo ka aina a pau? ke noi aku nei au ia oe, e hookaawale kaua: ina oe ma ka lima hema, alaila e hele au ma ka lima akau; a ma ka lima akau oe, alaila e hele au ma ka lima hema.
\b
\q1 
\v 10 Alawa ae la ko Lota mau maka, ike aku la i na wahi papu o Ioredane, he nui ka wai ma ia wahi a pau i kou hele ana mai i Zoara, mamua o ko Iehova luku ana ia Sodoma a me Gomora, e like me ka mahinaai o Iehova, a e like me ka aina i Aigupita.
\q1 
\v 11 Alaila, wae iho la o Lota i ka papu a pau o Ioredane: a hele aku la o Lota ma ka hikina, a hookaawale ae la laua i ke kekahi me kekahi.
\q1 
\v 12 Noho iho la o Aberama ma ka aina i Kanaana, a noho aku la o Lota ma na kulanakauhale o ua papu la, a kukulu iho la i kona halelewa ma Sodoma.
\q1 
\v 13 A o na kanaka o Sodoma, he poe hewa lakou, he lawehala loa imua o Iehova.
\b
\q1 
\v 14 Olelo mai la o Iehova ia Aberama mahope mai o ko Lota hookaawale ana ae mai ona aku la, E alawa ae oe i kou mau maka, a e nana aku mai kou wahi e noho nei, i ke kukuluakau a i ke kukuluhema, a i ka hikina hoi a i ke komohana:
\q1 
\v 15 No ka mea, o ka aina a pau au e ike nei, na'u ia e haawi aku nou, a no kau poe mamo mahope mau loa aku.
\q1 
\v 16 E hoomahuahua aku no wau i kau poe mamo e like me ka lepo o ka honua: ina e hiki i ke kanaka ke helu i na huna lepo o ka honua, alaila e heluia kau poe mamo.
\q1 
\v 17 E ku ae; e kaahele i ka aina ma kona loa a ma kona laula; no ka mea, na'u no ia e haawi aku nou.
\q1 
\v 18 Alaila lawe ae la o Aberama i kona halelewa, hele aku la ia a noho iho la ma na laau oka no Mamere, aia no ma Heberona, a hana iho la ia ilaila i kuahu no Iehova.
\c 14
\b
\q1 
\v 1 I KA manawa ia Amerapela ke alii o Sinara, o Arioka ke alii o Elasara, o Kedorelaomera ke alii o Elama, a o Tidala ke alii o Goima;
\q1 
\v 2 Kaua mai la lakou me Bera ke alii o Sodoma, me Biresa ke alii o Gomora, me Sinaba ke alii o Adema, me Semebara ke alii o Zeboima, a me ke alii o Bela, oia hoi o Zoara.
\q1 
\v 3 I hoakoakoaia keia poe a pau ma ke awawa o Sidima, kahi ia o ka moana paakai.
\q1 
\v 4 Hookauwa aku la lakou na Kedorelaomera i na makahiki he umikumamalua; a i ka umikumamakolu o ka makahiki, kipi ae la lakou.
\q1 
\v 5 A i ka makahiki umikumamaha, hele mai la o Kedorelaomera, a me ia pu ua mau alii la, a hahau mai la i ka Repaima ma Aseterota Kanaima, me ka Zuzima ma Hama, a me ka Emima ma Sehave ma Kiriataima.
\q1 
\v 6 A me ka Hora ma ko lakou mauna Seira, a hiki Elepazana ma ka waoakua.
\q1 
\v 7 A hoi mai la lakou, a hiki mai la i Enemisepata, oia o Kadesa, a hahau aku ia i ko ka aina a pau o ka Amaleki, a me ka Amori i noho la ma Hazezona-tamara.
\q1 
\v 8 Hele aku la ke alii o Sodoma me ke alii o Gomora, me ke alii o Adema, a me ke alii o Zeboima, a me ke alii o Bela, oia hoi o Zoara; a kaua aku la lakou me kela poe ma ke awawa o Sidima;
\q1 
\v 9 Me Kedorelaomera ke alii o Elama, a me Tidala ke alii o Goima, a me Amerapela ke alii o Sinara, a me Arioka ke alii o Elasara; o na'lii eha me na'lii elima.
\q1 
\v 10 He nui na lua bitumena ma ke awawa o Sidima; hee aku la na alii o Sodoma a me Gomora, a haule iho la ilaila; a holo aku la ka poe i koe ma ka mauna.
\q1 
\v 11 Lawe pio aku la lakou i ka waiwai a pau o Sodoma a o Gomora, a me ka lakou ai a pau, a hele aku la.
\q1 
\v 12 Lawe aku la hoi lakou ia Lota, i noho ai ma Sodoma, o ke keiki a ko Aberama kaikuaana, a me kana waiwai, a hoi aku la.
\b
\q1 
\v 13 Hele mai la kekahi o ka poe i pakele, a hai mai la ia Aberama ka Hebera; no ka mea, i noho ai oia ma na laau oka no Mamere ka Amori, ka hoahanau o Esekola, a o Anera: a ua hoolauna pu lakou nei me Aberama.
\q1 
\v 14 Lohe ae la o Aberama, ua lawe pio ia kona hoahanau, alakai aku la ia i kona poe kanaka i hoomakaukauia ka poe i hanau ma kona hale iho, akolu haneri a me kumamawalu, a alualu aku la ia lakou a hiki i Dana.
\q1 
\v 15 Mahele iho la oia i kona poe e ku e ia lakou, oia a me kana poe kauwa i ka po, poipo aku la ia lakou, a alualu aku la ia lakou a hiki i Hoba, aia ma ka lima hema o Damaseko.
\q1 
\v 16 Hoihoi mai la ia i ka waiwai a pau, a lawe mai la hoi oia i kona hoahanau ia Lota, a me kona waiwai, me na wahine hoi, a me na kanaka.
\b
\q1 
\v 17 Hele aku ke alii o Sodoma iwaho e halawai me Aberama, mahope o kona hoi hou ana mai mai ka luku ana ia Kedorelaomera a me na alii me ia, ma ke awawa o Save, oia ke awawa o ke alii.
\q1 
\v 18 A o Melekizedeka ke alii o Salema, lawe mai la ia i ka berena a me ka waina: oia ke kahuna o ke Akua kiekie loa.
\q1 
\v 19 Hoomaikai mai la oia ia ia, i mai la, E pomaikai no o Aberama i ke Akua kiekie loa, nona ka lani a me ka honua.
\q1 
\v 20 E hoomaikaiia hoi ke Akua kiekie loa, nana i hoolilo mai kou poe enemi iloko o kou lima. A haawi aku la ia nana i ka hapaumi o na mea a pau.
\b
\q1 
\v 21 I mai la ke alii o Sodoma ia Aberama, o ke kanaka ko'u, a e lawe oe i ka waiwai nou.
\q1 
\v 22 I aku la o Aberama i ke alii o Sodoma, Ua hapai aku no au i ko'u lima ia Iehova, i ke Akua kiekie loa, i ka mea nona ka lani a me ka honua,
\q1 
\v 23 Aole au e lawe no'u i kekahi maawe, aole hoi kekahi mea iki o kau, o olelo ae oe, Ua waiwai o Aberama ia'u:
\q1 
\v 24 O ka mea wale no a ka poe kanaka opiopio i ai ai, a me ka puu waiwai pio a ka poe kanaka i hele pu ai me an, o Anera, o Esekola, a o Mamere; e lawe lakou i ko lakou puu.
\c 15
\b
\q1 
\v 1 MAHOPE mai oia mau mea, hiki mai la ka olelo a Iehova ia Aberama ma ka hihio, i mai la, Mai makau oe, e Aberama, owau no kou palekaua a me kau uku nui loa.
\q1 
\v 2 I aku la o Aberama, E ka Haku, e Iehova e, heaha kau mea e haawi mai ai ia'u, no ka mea, ke hele keiki ole nei au, a o ka puuku o kuu hale, oia o Eliezera no Damaseko.
\q1 
\v 3 I aku la o Aberama, Aia hoi, aole oe i haawi mai i keiki na'u; a o kekahi i hanau iloko o ko'u hale, oia kuu hooilina.
\b
\q1 
\v 4 Aia hoi, hiki mai la ka olelo a Iehova ia ia, i ka i ana mai, Aole keia o kou hooilina; aka, o ka mea e hele mai ana mailoko mai ou iho, o kou hooilina ia.
\q1 
\v 5 Kai aku la oia ia ia mawaho, i mai la, E nana aku oe iluna i ka lani, e helu i na hoku, ina e hiki ia oe ke helu: i mai la kela ia ia, Pela auanei kau poe mamo.
\q1 
\v 6 Manaoio aku la oia ia Iehova, a hooili mai la oia ia mea i pono nona.
\b
\q1 
\v 7 I mai la kela ia ia, Owau no Iehova nana oe i lawe mai nei, mai Ura o ko Kaledea mai, e haawi aku nou i keia aina i wahi e noho ai.
\q1 
\v 8 I aku la ia, E ka Haku, e Iehova e, pehea la au e ike ai, e ili mai ana keia aina no'u?
\q1 
\v 9 I mai la kela ia ia, E lalau oe na'u i bipiwahine akolu makahiki ona, i kaowahine akolu makahiki ona, i hipakane akolu ona makahiki, i manu kuhukuku, a me ka nunu opiopio.
\q1 
\v 10 Lawe mai la oia ia mau mea a pau io na la, a mahele ae la ia lakou mawaena, a waiho iho la i kela apana i keia apana e ku pono aku i kona hoa: aka, aole ia i mahele i na manu.
\q1 
\v 11 A lele mai la na manu maluna iho o na mohai, hoopuehu aku la o Aberama ia lakou.
\b
\q1 
\v 12 A i ka napoo ana o ka la, ua pauhia o Aberama i ka hiamoe nui; aia hoi, kau mai la ka, weliweli a me ka pouli nui maluna iho ona.
\q1 
\v 13 Olelo mai la ia ia Aberama, E ike pono oe, e lilo ana kau poe mamo i malihini ma ka aina e aole no lakou, a e hookauwa aku na lakou; a e hoinoia mai lakou e kela poe i na haneri makahiki eha.
\q1 
\v 14 A o ua lahuikanaka la nana lakou e hooluhi mai, na'u lakou e hoohewa aku: a mahope iho, e puka mai lakou iwaho me ka waiwai nui.
\q1 
\v 15 E huiia'ku oe i ou mau makua me ka malu; a e kanuia oe i ka wa elemakule maikai.
\q1 
\v 16 Aka, e hoi hou mai no lakou ia nei i ka ha o ka hanauna: no ka mea, aole i lawa ka hewa o ka Amori i nei manawa.
\q1 
\v 17 A napoo iho la ka la, a poeleele iho la, aia hoi, nee ae la ka umuahi e punohu ana a me ke kukui e a ana mawaena o ua mau apana la.
\q1 
\v 18 Ia la no, hoopaa iho la oia i berita me Aberama, i ka i ana mai, Ua haawi aku no wau i keia aina no kau poe mamo, mai ka muliwai o Aigupita a hiki aku i ka muliwai nui, ka muliwai o Euperate:
\q1 
\v 19 I ka Kena, i ka Keniza, i ka Kademona,
\q1 
\v 20 I ka Heta, i ka Periza, me ka Repaima,
\q1 
\v 21 I ka Amora, i ka Kanaana, i ka Giregasa, a me ka Iebusa.
\c 16
\b
\q1 
\v 1 O SARAI ka wahine a Aberama, aole ia i hanau keiki nana: a ia ia kekahi kauwawahine no Aigupita, o Hagara kona inoa.
\q1 
\v 2 I mai la o Sarai ia Aberama, Aia hoi, ua pa wau ia Iehova; ke nonoi aku nei au ia oe, e komo ae oe iloko i ka'u kauwawahine, i loaa paha ia'u na keiki ma o na la. Hoolohe aku la o Aberama i ka leo o Sarai.
\q1 
\v 3 Lalau aku la o Sarai o ka wahine a Aberama ia Hagara i kana kauwawahine no Aigupita, i ka umi o ka makahiki a Aberama i noho ai ma ka aina o Kanaana, a haawi mai la ia ia i wahine na kana kane na Aberama.
\b
\q1 
\v 4 Komo aku la ia iloko io Hagara la, a ko ae la ia: a ike iho la ia ua ko, ua hoowahawahaia kona hakuwahine imua o kona maka.
\q1 
\v 5 I mai la o Sarai ia Aberama, Iluna iho ou ko'u hoinoia: ua haawi aku au i ka'u kauwawahine iloko o kou poli; a ike iho la ia, na ko oia, hoowahawahaia no au e ia: e hooponopono mai o Iehova mawaena o kaua.
\b
\q1 
\v 6 I aku la o Aberama ia Sarai, Aia hoi, iloko no o kou lima kau kauwawahine, e hana aku oe ia ia e like me kou makemake. A hoopilikia aku la o Sarai ia ia, mahuka aku la ia mai kona alo aku.
\b
\q1 
\v 7 A loaa oia i ka anela o Iehova ma ka punawai iloko o ka waonahele, ma ka punawai o ke alanui e hele ai i Sura.
\q1 
\v 8 I mai la ia, E Hagara, e ke kauwawahine a Sarai, no hea mai oe? e hele ana hoi oe ihea? I aku la kela, Ke mahuka aku nei au mai ke alo o ko'u hakuwahine, mai o Sarai aku.
\q1 
\v 9 Olelo mai la ka anela o Iehova ia ia, E hoi hou oe i kou hakuwahine, a e noho iho oe malalo o kona mau lima.
\q1 
\v 10 I mai la hoi ka anela o Iehova ia ia, E hoonui loa no wau i kau poe mamo, aole lakou e hiki ke heluia no ka lehulehu.
\q1 
\v 11 I mai la hoi ka anela o Iehova ia ia, Aia hoi, ua hapai oe, a e hanau mai no oe i keikikane, a e kapa oe i kona inoa o Isemaela; no ka mea, ua lohe no o Iehova i kou popilikia.
\q1 
\v 12 E lilo auanei ia i kanaka hihiu, e ku e aku no kona lima i na kanaka a pau, a e ku e mai no hoi ka lima o na kanaka a pau ia ia: a e noho auanei no ia ma ke alo o kona poe hoahanau a pau.
\q1 
\v 13 Kapa aku la ia i ka inoa o Iehova nana i olelo mai ia ia, O oe e ke Akua ka mea i ike mai ia'u: no ka mea, i iho la ia, Ua imi aku no anei au i ka Mea ike mai ia'u?
\q1 
\v 14 Nolaila, ua kapaia ua punawai la, o Beeralahairoi: aia no ia mawaena o Kadesa a o Bereda.
\b
\q1 
\v 15 Hanau mai la o Hagara i keikikane na Aberama: kapa aku la o Aberama i ka inoa o kana keiki a Hagara i hanau ai, o Isemaela.
\q1 
\v 16 He kanawalukumamaono na makahiki o Aberama, i ka wa a Hagara i hanau ai ia Isemaela na Aberama.
\c 17
\b
\q1 
\v 1 I KE kanaiwakumamaiwa o na makahiki o Aberama, ikea mai la o Iehova e Aberama, i mai la ia ia, Owau no ke Akua mana; e hele oe imua o ko'u alo, a e hemolele oe.
\q1 
\v 2 A e hoopaa auanei au i kau berita mawaena o'u a ou; a e hoomahuahua aku au ia oe a nui loa.
\q1 
\v 3 Moe iho la o Aberama ilalo kona alo: a kamailio mai la ke Akua me ia, i mai la,
\q1 
\v 4 Owau no, ea, aia hoi me oe ka'u berita, a e lilo auanei oe i kupuna no na lahuikanaka he nui loa.
\q1 
\v 5 Aole oe e hea hou ia, o Aberama, aka, o Aberahama kou inoa: no ka mea, ua hoolilo aku no au ia oe i kupuna no na lahuikanaka he nui loa.
\q1 
\v 6 A e hoolilo no wau ia oe i mea hoohua nui loa, e hoopuka auanei au i na lahuikanaka mailoko aku ou, a e puka mai no hoi na alii nui mailoko aku ou.
\q1 
\v 7 A e hoopaa no hoi au i ka'u berita mawaena o'u a ou, a me kau poe mamo mahope ou ma na hanauna o lakou, i berita mau loa, i Akua no au nou, a no kau poe mamo mahope ou.
\q1 
\v 8 A e haawi aku no au i ka aina au e noho malihini nei, i ka aina a pau o Kanaana, nou, a no kau poe mamo mahope ou, i wahi e noho mau ai: a owau hoi ko lakou Akua.
\b
\q1 
\v 9 Olelo mai la ke Akua ia Aberahama, Nolaila, e malama oe i ka'u berita, o oe a me kau poe mamo mahope ou, ma na hanauna o lakou.
\q1 
\v 10 Eia ka'u berita e malama ai oukou mawaena o'u a o oukou, a me kau poe mamo mahope ou; E okipoepoeia na keikikane a pau o oukou.
\q1 
\v 11 E okipoepoe oukou i ka io o ko oukou omaka; o ka hoailona ia o ka berita mawaena o'u a o oukou.
\q1 
\v 12 I ka poawalu o kona ola ana, e okipoepoeia na keikikane a pau o na hanauna o oukou; o ka mea i hanau ma kou wahi, a me ka mea i kuaiia i ke kala na ke kanaka e mai, ka mea aole nau i hua mai.
\q1 
\v 13 O ka mea i hanau ma kou wahi, a me ka mea i kuaiia i kou kala, he pono no e okipoepoeia oia: a e pili auanei ka'u berita ma ko oukou io i berita mau loa.
\q1 
\v 14 A o ke keikikane okipoepoe ole ia, ke okipoepoe ole ia ka io o kona omaka, e hookiia'ku ia kanaka mai kona hanauna aku; ua haihai oia i ka'u berita.
\b
\q1 
\v 15 Olelo mai la ke Akua ia Aberahama, A o Sarai o kau wahine, aole oe e kahea hou aku i kona inoa, o Sarai, e kapaia oia, o Sara.
\q1 
\v 16 E hoopomaikai aku hoi au ia ia, a e haawi aku hoi au ia oe, i keikikane nana mai: oia, e hoopomaikai no au la ia, nana mai na lahuikanaka; a nana mai no hoi na alii o kanaka.
\q1 
\v 17 Alaila, moe iho la o Aberahama ilalo kona maka, akaaka iho la, a i iho la iloko o kona naau, E hanauia anei ke keiki na ka mea nona na makahiki he haneri? E hanau mai no anei o Sara, nona na makahiki he kanaiwa?
\q1 
\v 18 I aku la o Aberahama i ke Akua, Ina no o Isemaela e ola imua ou!
\q1 
\v 19 I mai la ke Akua, He oiaio, na Sara e hanau ke keikikane nau, a e kapa aku oe i kona inoa o Isaaka: a e hoopaa auanei au i ka'u berita me ia, a me kana poe mamo mahope ona, i berita mau loa.
\q1 
\v 20 A o Isemaela, ua hoolohe hoi au ia oe nona: Aia hoi, na hoopomaikai no au ia ia, a e hoohua auanei au i na keiki nana, a e hoomahuahua no hoi au ia ia; e hanau nana na alii he umikumamalua, a e hoolilo hoi au ia ia i Iahuikanaka nui.
\q1 
\v 21 Aka, e hoopaa auanei au i kuu berita ia Isaaka, i ka mea a Sara e hanau mai ai nau, i keia manawa o kela makahiki aku.
\b
\q1 
\v 22 A oki iho la kana kamailio ana me ia, hoi aku la ke Akua iluna mai o Aberahama aku.
\b
\q1 
\v 23 Lalau aku la o Aberahama i kana keiki ia Isemaela, a me na mea a pau i hanau ma kona hale, a me na mea a pau i kuaiia i kana kala, i na kane a pau o ko Aberahama mau ohua; a okipoepoe iho la i ka io o ko lakou omaka ia la hookahi no, e like me, ka ke Akua i olelo mai ai ia ia.
\q1 
\v 24 He kanaiwa na makahiki a me kumamaiwa o ko Aberahama ola ana, ia ia i okipoepoeia'i ma ka io o kona omaka.
\q1 
\v 25 He umikumamakolu na makahiki o Isemaela, ia ia i okipoepoeia'i ma ka io o kona omaka.
\q1 
\v 26 Ia la hookahi no, i okipoepoeia'i o Aberahama, a me kana keiki o Isemaela.
\q1 
\v 27 Ua okipoepoe pu ia me ia na kanaka a pau o kona mau ohua, i hanau ma kona hale, a i kuaiia i kona kala na ke kanaka e mai.
\c 18
\b
\q1 
\v 1 I KEA ae la o Iehova e ia ma na laau oka o Mamere: a noho iho la ia ma ka puka o ka halelewa, i ka manawa i wela mai ai ka la.
\q1 
\v 2 Alawa ae la kona mau maka iluna, ike ae la, aia hoi, ku mai la na kanaka ekolu imua ona: a i kona ike ana aku, holo aku la ia mai ka puka o ka halelewa aku e halawai me lakou, a kulou iho la ia ma ka honua.
\q1 
\v 3 I aku la ia, E kuu haku, ina i loaa ia'u ke alohaia imua o kou mau maka, ke noi aku nei au ia oe, mai hele wale aku oe mai kau kauwa aku.
\q1 
\v 4 Ke noi aku nei au, i laweia mai kekahi wai iki e holoi i ko oukou mau wawae, a e hoomaha iho oukou malalo o ka laau.
\q1 
\v 5 E lawe mai no hoi au i wahi berena, a e hooluolu iho i ko oukou naau; a mahope iho oukou e hele aku ai; no ka mea, nolaila ko oukou hele ana mai i ko oukou kauwa, I mai la lakou. Me kau i olelo mai ai, pela oe e hana'i.
\q1 
\v 6 Wikiwiki ae la o Aberahama i ka hele iloko o ka halelewa io Sara la, i aku la, E hoomakaukau koke oe i ekolu sato palaoa wali; e hookawili a e pulehu i papaberena.
\q1 
\v 7 Holo aku la o Aberahama i ka ohana bipi, lalau aku la i ka bipikeiki opiopio momona, haawi aku la i kekahi keiki, a wikiwiki iho la ia e kalua.
\q1 
\v 8 Lalau aku ia i wahi bata a me ka waiu, a me ka bipikeiki ana i kalua ai, a kau aku la imua o lakou: a ku aku la ia ma o lakou la malalo o ka laau; a ai iho la lakou.
\b
\q1 
\v 9 Ninau mai la lakou ia ia, Auhea kau wahine, o Sara? I aku la ia, aia no iloko o ka halelewa.
\q1 
\v 10 Alaila, i mai la kela, Ho oiaio, e hoi hou mai ana au i keia manawa o kela makahiki, aia hoi, e loaa uanei ia Sara he keikikane. A lohe ae la o Sara ma ka puka o ka halelewa ma kona kua.
\q1 
\v 11 A o Aberahama laua o Sara, ua kahiko no laua, he nui ko laua mau la; a ua pau ia Sara ka mea a na wahine.
\q1 
\v 12 Nolaila, akaaka iho la o Sara iloko iho ona, i iho la, E olioli no anei au mahope o kuu wa luwahine, a ua elemakule hoi kuu haku?
\q1 
\v 13 Ninau mai la o Iehova ia Aberahama, No ko aha la i akaaka ai o Sara, i ka i ana, He oiaio anei, o hanau no wau i keiki i kuu wa luwahine?
\q1 
\v 14 E hakalia anei kekahi mea ia Iehova? I ka wa i oleloia'i e hoi hou mai ana au i ou la, i keia manawa o kela makahiki, a e loaa ia Sara he keikikane.
\q1 
\v 15 Alaila hoole aku la o Sara, i aku la, Aole au i akaaka; no ka mea, makau iho la ia. I mai la kela, Aole, ua akaaka no oe.
\b
\q1 
\v 16 Ku ae la ua mau kanaka la, nana aku la ma Sodoma; a hele pu o Aberahama me lakou e hookuu aku ia lakou.
\q1 
\v 17 I ae la o Iehova, E huna anei au ia Aberahama i ka'u mea e hana nei?
\q1 
\v 18 No ka mea, e lilo io no auanei o Aberahama i lahuikanaka nui a ikaika hoi, a e pomaikai hoi na lahuikanaka a pau o ka honua ia ia.
\q1 
\v 19 No ka mea, ke ike nei au ia ia, e kauoha aku no ia i kana poe keiki a me kona mau ohua mahope ona, i malama mai ai lakou i ka aoao o Iehova, a e hana lakou ma ka pono a me ka pololei; i hooili aku ai o Iehova maluna o Aberahama i ka mea ana i olelo ai nona.
\q1 
\v 20 Olelo mai la o Iehova, Ua nui loa ka leo no Sodoma a me Gomora, ua kaumaha no hoi ko lakou hewa;
\q1 
\v 21 E iho ana au ilaila e ike, i like paha ka lakou hana ana me ka leo no ia wahi i hiki mai ai io'u nei; a i ole paha, o ike auanei hoi au.
\b
\q1 
\v 22 Huli ae la ua mau kanaka la i na maka o laua mailaila aku, a hele aku la i Sodoma: aka, ku iho la o Aberahama imua o Iehova.
\b
\q1 
\v 23 Neenee aku la o Aberahama a kokoke, i aku la, E luku pu anei oe i ka poe pono me ka poe hewa?
\q1 
\v 24 Ina paha he kanalima na kanaka pono maloko o ua kulanakauhale la, e luku anei oe ia wahi, aole no o malama ia wahi no ka poe pono he kanalima maloko?
\q1 
\v 25 Aole loa oe e hana pela, ke pepehi pu i ka poe pono me ka poe hewa: i like pu ai ka poe pono me ka poe hewa, aole loa oe pela: aole anei o hana pono ka lunakanawai o ka honua a pau?
\q1 
\v 26 I mai la o Iehova, Ina loaa ia'u ma Sodoma na kanaka pono he kanalima maloko o ke kulanakauhale, alaila au e malama ai ia wahi a pau no lakou.
\q1 
\v 27 Olelo aku la o Aberahama, i aku la, Eia hoi, ua hoomaka no wau e olelo aku i ka Haku, owau he lepo wale no, a me ka lehu:
\q1 
\v 28 A i emi mai na mea elima o ka poe pono he kanalima; e luku anei oe ia kulanakauhale a pau no ia mau mea elima? I mai ia kela, A i loaa ia'u ilaila he kanaha a me kumamalima, aole au e luku aku.
\q1 
\v 29 Olelo hou aku la oia ia ia, i aku la, Ina paha he kanaha ka poe i loaa ilaila? i mai la kela, Aole au o hana aku ia mea, ke kanaha lakou.
\q1 
\v 30 I aku la hoi oia, Ea, a i huhu ole mai ka Haku, e olelo aku no au: Ina paha he kanakolu ka poe i loaa ilaila? I mai la kela, Aole au e hana ia mea, ke loaa ia'u he kanakolu ilaila.
\q1 
\v 31 I aku la oia, Aia hoi, na hoomaka iho nei au e olelo aku i ka Haku: Ina paha ho iwakalua ka poe i loaa ilaila? I mai la kola, aole au o luku aku, ko iwakalua lakou.
\q1 
\v 32 I aku la hoi oia, A i ole e huhu mai ka Haku, a hookahi wale no a'u olelo e koe: Ina paha he umi ka poe i loaa ilaila? I mai la kela, Aole au e luku aku, ke umi lakou.
\q1 
\v 33 A pau ae la ka Iehova kamailio ana mo Aberahama, hele aku la o Iehova; a hoi hou mai la o Aberahama i kona wahi.
\c 19
\b
\q1 
\v 1 A AHIAHI iho la, hiki aku la na anela elua ma Sodoma: a noho iho la o Lota ma ka ipuka o Sodoma: ike aku la o Lota, ku ae la ia e halawai me lakou, a kulou iho la kona mau maka ilalo ma ka honua;
\q1 
\v 2 I aku la, E kuu mau haku, ke noi aku nei au ia olua, e kipa mai olua maloko o ka hale o ka olua kauwa nei, e moe no a ao ka po, a e holoi i ko olua wawae, a kakahiaka nui e ala'e olua a e hele aku. I mai la laua, Aole, e moe no maua ma ke alanui a ao ka po.
\q1 
\v 3 Koi ikaika aku la ia ia laua; a kipa ae la laua io na la, a komo aku la iloko o kona hale; a hana iho no ia i ahaaina na laua, pulehu iho la i ka palaoa huole, a ai iho la laua.
\b
\q1 
\v 4 Aole laua i moe iho, a o na kanaka o ke kulanakauhale, o na kanaka o Sodoma, o ka poe kahiko a me ka poe hou, o na kanaka a pau mai o a o, hoopuni mai la lakou i ka hale:
\q1 
\v 5 Kahea mai la lakou ia Lota, i mai la ia ia, Auhea na kanaka i hele mai i ou la i keia po? E kai mai ia laua iwaho io makou nei, i ike makou ia laua.
\q1 
\v 6 Hele aku la o Lota iwaho ma ka puka io lakou la; a papani ae la i ka puka mahope ona.
\q1 
\v 7 I aku la, E na hoahanau, ke nonoi aku nei au ia oukou, mai hana hewa oukou.
\q1 
\v 8 Eia hoi ia'u na kaikamahine elua i ike ole i ke kane; e ae mai oukou ia'u e lawe mai ia laua iwaho io oukou nei, a e hana aku oukou ia laua i ka mea pono ma ko oukou maka: aka, mai hana aku oukou i kekahi mea i keia mau kanaka; no ka mea, nolaila laua i hele mai nei ma ka malumalu o kuu hale.
\q1 
\v 9 I mai la lakou, E hookaawale oe. I ae la hoi lakou, I hele mai no oia nei e noho wale maanei, a e lilo ana ka ia i lunakanawai: ano hoi, e oi aku ka makou hana ino ana ia oe i ko laua la. A hookeke nui mai la lakou i ua kanaka nei, ia Lota, a neenee mai la e wawahi i ka pani puka.
\q1 
\v 10 Aka, lalau aku la ua mau kanaka la ia Lota, a huki mai laua ia ia iloko o ka hale io laua la, a papani aku la i ka puka.
\q1 
\v 11 Hoomakapo iho la laua i ka poe kanaka iwaho o ka puka o ka hale, i na mea uuku a me na mea nui: a hoopauaho lakou ia lakou iho i ka imi i ka puka.
\b
\q1 
\v 12 I mai la laua ia Lota, Aole anei ia oe kekahi poe e ae maanei? o ka hunonakane paha, o na keikikane au, a me au mau kaikamahine, a o na mea a pau ia oe, e laweia'ku iwaho o keia wahi:
\q1 
\v 13 No ka mea, e luku aku maua i keia wahi, no ka nui loa ae o ka leo no lakou, imua o ke alo o Iehova; a ua hoouna mai no o Iehova ia maua e luku aku ia wahi.
\q1 
\v 14 Hele aku la o Lota iwaho, olelo aku la i kona mau hunonakane i mare me na kaikamahine ana, i aku la, E ala'e, e holo aku iwaho o keia wahi; no ka mea, e luku mai ana o Iehova i neia kulanakauhale. Aka, ua like ia i ka manao o na hunonakane me ka mea hoomaewaewa.
\b
\q1 
\v 15 I ka wanaao, hoolalelale ua mau anela la ia Lota, i mai la, E ala ae, e lawe i kau wahine, a me kau mau kaikamahine elua maanei, o pau auanei oe iloko o ka make o ko ke kulanakauhale.
\q1 
\v 16 Ia ia i hookaulua ai, lalau aku la ua mau kanaka la i kona lima, me ka lima o kana wahine, a me ka lima o kana mau kaikamahine elua; ahonui mai la o Iehova ia ia: alakai aku la laua ia ia, a hookuu aku la iwaho o ke kulanakauhale.
\b
\q1 
\v 17 I ka wa i alakai aku ai laua ia lakou iwaho o ke kulanakauhale, alaila i mai la ia, E holo i pakele kou ola; mai nana i hope ou, mai kali oe ma neia wahi papu a pau; e holo i ka mauna, o make oe.
\q1 
\v 18 I aku la o Lota ia laua, Auwe! e kuu Haku, aole pela.
\q1 
\v 19 Eia hoi, ua loaa iho nei i kau kauwa ka lokomaikai imua o kou mau maka, a ua hoonui ae nei oe i kou aloha au i hoike mai ai ia'u i ka hoola ana mai ia'u, aole e hiki ia'u ke holo ma ka mauna, o loaa ia'u ka poino, a make au.
\q1 
\v 20 Eia ae ke kulanakauhale, e hiki koke ke holo malaila, a ua liilii hoi ia; ea, e ae mai ia'u e holo malaila, (aole anei ia he wahi liilii?) a e malamaia kuu ola.
\q1 
\v 21 I mai la kela ia ia, Aia, ua hoolohe aku no au i keia mea hoi; aole au e luku aku ia kulanakauhale, no ka mea au i olelo mai ai.
\q1 
\v 22 E wikiwiki oe e holo ilaila; no ka mea, aole e hiki ia'u ke hana i kekahi mea, a puka aku no oe ilaila. Nolaila, ua kapaia ka inoa o ia kulanakauhale, o i Zoara.
\b
\q1 
\v 23 Ua puka mai ka la maluna o ka honua i ke komo ana o Lota iloko o Zoara.
\q1 
\v 24 Alaila, hooua mai la o Iehova maluna o Sodoma i ka luaipele a me ke ahi mai o Iehova la, mai ka lani mai.
\q1 
\v 25 Hookahuli iho la oia ia mau kulanakauhale, a me kahi papu a pau, a me na kanaka a pau o ua mau kulanakauhale la, a me na mea ulu ma ka honua.
\b
\q1 
\v 26 Aka, nana ae la kana wahine mahope ona, a lilo iho la ia i kukulu paakai.
\b
\q1 
\v 27 Ala ae la o Aberahama i kakahiaka nui, a hoi hou aku la ia i kahi ana i ku ai imua o Iehova:
\q1 
\v 28 Nana aku la ia ma Sodoma a me Gomora, a ma ka aina papu a pau, ike aku la ia, aia hoi, pii ae la ka uahi o ia aina iluna, e like me ka punohu o ka lua ahi.
\b
\q1 
\v 29 A i ka wa a ke Akua i luku ai i na kulanakauhale o ka papu, hoomanao iho la no ke Akua ia Aberahama, a hoopakele ae la ia Lota maiwaena aku o ka hookahuli ana, ia ia i hookahuli ai i na kulanakauhale kahi a Lota i noho ai.
\b
\q1 
\v 30 Pii ae la o Lota mailoko aku o Zoara, a noho iho la ma ka mauna, a me ia pu na kaikamahine ana elua; no ka mea, makau iho la ia ke noho ma Zoara: noho no ia ma kekahi ana, oia a me kana mau kaikamahine elua.
\q1 
\v 31 I aku la ka hanau mua i kona kaikaina, Ea, ua elemakule ko kana makuakane, aole hoi he kanaka ma ka honua nei a pau nana e komo mai io kaua nei, e like me ka nana ana a ko ka honua nei:
\q1 
\v 32 Ina kaua, o hooinu kaua i ko kaua makuakane i ka waina, a e moe kaua me ia, i malama ai kana i hua na ko kaua makuakane.
\q1 
\v 33 Hooinu laua ia po i ko laua makuakane i ka waina: a komo aku la ka hanau mua iloko, a moe iho la me kona makuakane: aole nae i ike kela i kona wa i moe iho ai, aole hoi kona wa i ala'i.
\q1 
\v 34 A ia la ae, i aku la ka hanau mua i ke kaikaina, Aia hoi, moe iho no au me kuu makuakane i ka po nei: e hooinu kaua ia ia i ka waina i keia po no hoi; a e komo aku oe iloko, e moe me ia, i malama ai kana i hua na ko kana makuakane.
\q1 
\v 35 Hooinu laua i ko laua makuakane i ka waina ia po no hoi: a ku ae la ke kaikaina, a moe iho la me ia; aole kela i ike i kona wa i moe iho ai, aole hoi i kona wa i ala ai.
\q1 
\v 36 Hapai na kaikamahine elua a Lota na ko laua makuakane.
\q1 
\v 37 Hanau mai la ka mua i keikikane, a kapa iho la i kona inoa o Moaba: oia ke kupuna o ka Moaba a hiki i keia manawa.
\q1 
\v 38 A hanau mai la hoi ka muli iho i keikikane, a kapa iho la i kona inoa o Benami: oia ke kupuna o ka Amona a hiki i keia manawa.
\c 20
\b
\q1 
\v 1 HELE aku la o Aberahama mailaila aku ma ka aina kukuluhema, a noho hoi ia mawaena o Kadesa a o Sura, a ma Gerara kona noho malihini ana.
\q1 
\v 2 Olelo aku la o Aberahama no kana wahine no Sara, Oia no kuu kaikuwahine: a hoouna mai la o Abimeleka ke alii o Gerara, a lawe aku la ia Sara.
\q1 
\v 3 A hele mai la ke Akua io Abimeleka la ma ka moeuhane i ka po, i mai la ia ia, Aia hoi, he kanaka make oe, no ka wahine au i lawe iho nei, no ka mea, he wahine mea kane ia.
\q1 
\v 4 Aka, aole i hoopili o Abimeleka ia ia: i aku la oia, E ka Haku, e pepehi mai no hoi oe i ka lahuikanaka hala ole?
\q1 
\v 5 Aole anei ia i olelo mai ia'u, O ko'u kaikuwahine ia! a o ka wahine, oia ka i i mai, He kaikunane keia no'u: ma ka manao pono o kuu naau a me ka hala ole o kuu mau lima ka'u i hana aku ai i keia.
\q1 
\v 6 I mai la ke Akua ia ia ma ka moeuhane, Oiaio. ke ike nei au, ua hana aku oe i keia ma ka manao pono o kou naau; a ua hoopaa no hoi au ia oe, i ole oe e hana hewa mai ia'u: nolaila, aole au i ae aku ia oe e hoopa ia ia.
\q1 
\v 7 No ia mea hoi, e hoihoi aku na ua kanaka la i kana wahine; no ka mea, he kaula ia, a nana no e pule mai nou, i ola ai oe: a i ole oe e hoihoi mai ia ia, alaila e ike pono oe, he oiaio e make no oe, o oe a me ou poe a pau.
\b
\q1 
\v 8 Ala ae la o Abimeleka i kakahiaka nui, houluulu ae la i kana poe kauwa a pau, a hai aku la i keia mau mea maloko o ko lakou mau pepeiao: a makau loa iho la na kanaka.
\b
\q1 
\v 9 Alaila, kahea mai la o Abimeleka ia Aberahama, i mai la ia ia, Heaha kau i hana mai ai ia makou? Heaha hoi ko'u hala in oe, i hooili mai ai oe iluna iho o'u a o ko'u aupuni ka hewa nui? Ua hana mai oe ia'u i na mea pono ole ke hanaia.
\q1 
\v 10 Ninau mai la o Abimeleka ia Aberahama, Heaha kau i ike mai ai, i hana iho ai oe i keia mea?
\q1 
\v 11 I aku la o Aberahama, No ka mea, i iho la au ma kuu naau, He oiaio, aole ka makau i ke Akua ma keia wahi; a e pepehi mai auanei lakou ia'u no kuu wahine.
\q1 
\v 12 He oiaio hoi, o ko'u kaikuwahine no ia, ke kaikamahine a kuu makuakane, aole nae ia ke kaikamahine a kuu makuwahine, a lilo mai la ia i wahine na'u.
\q1 
\v 13 A i ka manawa a ke Akua i hooanwana mai ai ia'u mai ka hale o ko'u makuakane mai, i aku la au ia ia nei, Eia kou lokomaikai au e hoike mai ai ia'u: i na wahi a pau e hiki aku ai kana, e olelo aku oe no'u, O ko'u kaikunane ia.
\b
\q1 
\v 14 Lawe ae la o Abimeleka i na hipa, me na bipikane, i na kauwakane a me na kauwawahine, a haawi mai la ia Aberahama, a hoihoi mai la oia ia Sara kana wahine nana.
\q1 
\v 15 I mai la o Abimeleka, Aia hoi, imua ou ko'u aina, e noho ma kahi i makemake ai oe.
\q1 
\v 16 I mai la hoi oia ia Sara, Aia hoi, ua haawi iho nei au i na apana kala he tausani na kou kaikunane: aia hoi, he mea pale maka ia nou imua o ka poe a pau me oe, a me na mea a pau: pela oia i aoia mai ai.
\b
\q1 
\v 17 Pule aku la o Aberahama i ke Akua: a hoola mai la ke Akua ia Abimeleka, me kana wahine a me kana poe kauwawahine; a hanaukeiki lakou.
\q1 
\v 18 No ka mea, ua papaniia e Iehova na opu o na wahine a pau o ka hale o Abimeleka, no Sara ka wahine a Aberahama.
\c 21
\b
\q1 
\v 1 I KE mai la o Iehova ia Sara e like me kana i i mai ai; a hana mai la o Iehova ia Sara e like me kana i olelo mai ai.
\q1 
\v 2 No ka mea, hapai ae la o Sara, a hanau mai la he keikikane na Aberahama i kona wa elemakule; i ka manawa a ke Akua i olelo mai ai ia ia.
\q1 
\v 3 Kapa aku la o Aberahama i ka inoa o kana keiki i hanau nana, i ka mea a Sara i hanau ai nana, o Isaaka.
\q1 
\v 4 I ka po awalu, okipoepoe ae la o Aberahama i kana keiki ia Isaaka e like me ka ke Akua i kauoha mai ai ia ia.
\q1 
\v 5 Hookahi haneri makahiki o Aberahama i ka wa i hanau ai o Isaaka nana.
\b
\q1 
\v 6 I mai la o Sara, Ua hoakaaka mai no ke Akua ia'u, a e akaaka pu hoi me au ka poe lohe a pau.
\q1 
\v 7 I mai la hoi oia, Owai ka mea i olelo ia Aberahama, e hanai auanei o Sara i na keiki i ka waiu? no ka mea, ua hanau iho nei au i keikikane nana i kona wa elemakule.
\b
\q1 
\v 8 Nui ae la na keiki nei, a ukuhi ia: a hana iho la o Aberahama i ka ahaaina nui, i ka la a Isaaka i haalele ai i ka waiu.
\b
\q1 
\v 9 Ike aku la o Sara i ke keiki a Hagara no Aigupita, i ka mea ana i hanau ai na Aberahama, e hoomaewaewa ana.
\q1 
\v 10 No ia mea, i mai la oia ia Aberahama, E hookuke aku oe i ua kauwawahine la a me kana keiki: no ka mea, aole e hooili pu ia'ku ka waiwai i ke keiki a ua kauwawahine la me ka'u keiki, me Isaaka.
\q1 
\v 11 He mea ehaeha loa ia i ka manao o Aberahama, no kana keiki.
\b
\q1 
\v 12 I mai la ke Akua ia Aberahama, Mai hoehaeha oe i kou naau no ke keiki, a no kau kauwawahine, e hoolohe aku oe i ka leo o Sara i ka mea a pau ana i olelo mai ai ia oe; no ka mea, e kapaia'ku kau poe mamo mamuli o Isaaka.
\q1 
\v 13 A e hoolilo auanei hoi au i ke keiki a ke kauwawahine i lahuikanaka, no ka mea, o kau keiki ia.
\b
\q1 
\v 14 Ala ae la o Aberahama i ke kakahiaka nui, lalau aku la ia i ka berena a me ka wai iloko o ka hue a haawi ae la ia Hagara, a kau aku la maluna o kona poohiwi, a me ke keiki no hoi, a kuu aku la ia ia: hele aku no ia, a kuewa wale ae la maloko o ka waonahele o Beeresaba.
\b
\q1 
\v 15 A pau ae la ka wai iloko o ka huewai, waiho iho la ia i ke keiki malalo o kekahi laau uuku.
\q1 
\v 16 Hele aku la ia, a noho iho la i kahi kupono ia ia, e mamao aku ana e like me ka pana ana o ka pua: no ka mea, i iho la ia, Aole au e pono ke ike i ka make ana o ke keiki Noho aku la ia i kahi kupono, a hookiekie ae la ia i kona leo, a uwe iho la.
\q1 
\v 17 Hoolohe mai la ke Akua i ka leo o ke keiki; a kahea mai la ka anela o ke Akua ia Hagara mai ka lani mai, i mai la ia ia, Heaha kau e Hagara? mai makau oe; no ka mea, ua hoolohe mai no ke Akua i ka leo o ke keiki ma kona wahi i waiho ai.
\q1 
\v 18 E ku ae oe, e kaikai ae i ke keiki, a e hoopaa aku kou lima ia ia; no ka mea, e hoolilo auanei au ia ia i lahuikanaka nui.
\q1 
\v 19 Hookaakaa ae la ke Akua i kona mau maka, a ike aku la ia i kekahi luawai: hele aku la ia, ukuhi iho la a piha ka huewai i ka wai, a hooinu iho la i ke keiki.
\q1 
\v 20 Me ua keiki nei no ke Akua, a nui ae la ia, a noho iho la ma ka waonahele, a lilo ae la ia i kanaka pana pua,
\q1 
\v 21 Noho iho la ia ma ka waonahele o Parana: a lawe ae la kona makuwahine i wahine nana, no Aigupita mai.
\b
\q1 
\v 22 Ia manawa, olelo mai la o Abimeleka laua o Pikola kona luna koa ia Aberahama, i ka i ana mai, Me oe no ke Akua i na mea a pau au e hana nei:
\q1 
\v 23 Nolaila hoi, e hoohiki oe no'u ano ma ke Akua, aole oe e hoopunipuni mai ia'u, aole i ka'u keiki, aole hoi i ka'u moopuna: e like me ka lokomaikai a'u i hana aku ai ia oe, pela hoi oe e hana mai ai ia'u, a i ko ka aina au i noho iho ai.
\q1 
\v 24 I aku la o Aberahama, E hoohiki no wau.
\q1 
\v 25 Ao aku la hoi o Aberahama ia Abimeleka no ka luawai a na kauwa a Abimeleka i kaili aku ai.
\q1 
\v 26 I mai la o Abimeleka, Aole au i ike i ka men nana i hana ia mea: aole hoi oe i hai mai; aole hoi au i lohe a hiki i keia la.
\q1 
\v 27 Lalau aku la o Aberahama i na hipa a me na bipikane, a haawi aku la ia mau mea no Abimeleka; a hoopaa iho la laua a elua i berita.
\q1 
\v 28 A hoonoho aku la o Aberahama i na hipa keiki wahine i ehiku ma kahi kaawale.
\q1 
\v 29 Ninau mai la o Abimeleka ia Aberahama, I me aha keia mau hipa keiki wahine ehiku, au i hoonoho iho ai ma kahi kaawale!
\q1 
\v 30 I aku la keia, No ka mea, e lawe oe i keia mau hipa keiki wahine ehiku na kuu lima aku, i mea hoike maka no'u, na'u no i eli iho i keia luawai.
\q1 
\v 31 Nolaila, kapa iho la oia ia wahi, o Beereseba; no ka mea, ilaila i hoohiki aku ai laua a elua.
\q1 
\v 32 Pela no laua i hoopaa iho ai i berita ma Beereseba: alaila, ku ae la o Abimeleka laua o Pikola kona luna koa, a hoi hou aku la laua i ka aina o ko Pilisetia.
\b
\q1 
\v 33 Kanu iho la o Aberahama i laau ma Beereseba, a kahea aku la ilaila i ka inoa o Iehova ke Akua mau loa.
\q1 
\v 34 Noho iho la o Aberahama ma ka aina o ko Pilisetia i na la he nui loa.
\c 22
\b
\q1 
\v 1 MAHOPE mai o ia mau mea, hoao mai la ke Akua ia Aberahama, i mai la ia ia, E Aberahama: i aku la kela, Eia no wau.
\q1 
\v 2 I mai la oia, E lawe aku oe i kau keiki i kau ponoi, ia Isaaka, i kau mea au e aloha nei, a e hele aku oe i ka aina o Moria; malaila oe e kaumaha aku ai ia ia i mohaikuni maluna o kekahi puu a'u e hoike aku ai ia oe.
\b
\q1 
\v 3 Ala ae la o Aberahama i kakahiaka nui, hoee aku la ia i ka noho maluna o kona hoki, kono pu ae la i na kanaka ui elua ona me ia, a me Isaaka kana keiki, kaka iho la i ka wahie no ka mohaikuni, ku ae la a hele aku la i kahi a ke Akua i i mai ai ia ia.
\q1 
\v 4 I ke kolu o ka la alawa ae la na maka o Aberahama, a ike aku la ia wahi mamao aku.
\q1 
\v 5 I aku la o Aberahama i kona mau kanaka ui, E noho iho olua maanei me ka hoki, a hele no maua me ke keiki i o e hoomana ai; a hoi hou mai io olua nei.
\q1 
\v 6 Lawe ae la o Aberahama i ka wahie no ka mohaikuni, a kau iho la maluna o kana keiki o Isaaka, lawe aku la ia i ke ahi, a me ka pahi ma kona lima, a haele pu aku la laua.
\q1 
\v 7 Olelo aku la o Isaaka i kona makuakane, ia Aberahama, E kuu makua: i mai la kela, Eia wan, e kuu keiki. I aku la ia, Eia ke ahi, a me ka wahie; auhea hoi ke keikihipa i mohaikuni?
\q1 
\v 8 I mai la o Aberahama, E kuu keiki, na ke Akua no e hoomakaukau i keikihipa nana i mohaikuni: a haele pu aku la laua.
\b
\q1 
\v 9 A hiki aku la laua i kahi a ke Akua i i mai ai ia ia; hana iho la o Aberahama i kuahu ilaila, kau pono aku la i ka wahie maluna, hikii iho la ia i kana keiki ia Isaaka, a kau aku la ia ia ma ke kuahu maluna o ka wahie.
\q1 
\v 10 O aku la ko Aberahama lima, a lalau i ka pahi e pepehi i kana keiki.
\b
\q1 
\v 11 Kahea mai la ka anela o Iehova mai ka lani mai, i mai la, E Aberahama! e Aberahama! I aku la kela, Eia wau.
\q1 
\v 12 I mai la ia, Mai kau aku oe i kou lima maluna o ke keiki, aole hoi e mea iki aku ia ia: no ka mea, ke ike nei au, ua makau oe i ke Akua: no ka mea, aole oe i aua i kau keiki, i kau keiki ponoi ia'u.
\q1 
\v 13 Alawa ae la na maka o Aberahama iluna, ike aku la, aia hoi, ma kona kua he hipakane, ua hihia kona pepeiaohao i ka nahelehele: hele aku la o Aberahama, lalau aku la i ua hipakane la, a kaumaha aku la ia ia i mohaikuni, i kala no kana keiki.
\q1 
\v 14 Kapa aku la o Aberahama i ka inoa o ia wahi, O Iehova-iire: me ia i oleloia mai ai a hiki i keia la, Ma ka mauna o Iehova e hoomakaukauia'i.
\b
\q1 
\v 15 Kahea hou mai la ka anela o Iehova ia Aberahama mai ka lani mai,
\q1 
\v 16 I mai la, Ke olelo mai nei o Iehova, Ma o'u nei au i hoohiki iho ai, no kau hana ana i keia mea, aole hoi i aua i kau keiki, i kau keiki ponoi;
\q1 
\v 17 E hoopomaikai nui aku no au ia oe, a e hoonui loa aku hoi au i kau poe mamo e like me na hoku o ka lani, a me na one ma kahakai; a e lilo auanei i kau poe mamo ka ipuka o kona poe enemi:
\q1 
\v 18 A ma kou mamo e hoopomaikaiia'i na lahuikanaka a pau o ka honua; no ka mea, ua hoolohe mai oe i ko'u leo.
\q1 
\v 19 Hoi hou aku la o Aberahama i kona mau kanaka ui, ku ae la laua a hele pu aku la i Beereseba: a noho iho la o Aberahama i Beereseba.
\b
\q1 
\v 20 Mahope mai o ia mau mea, haiia mai ia Aberahama, i ka i ana mai, Aia hoi, o Mileka, ua hanau no hoi oia i na keiki na kou kaikuaana na Nahora;
\q1 
\v 21 O Huza kana hiapo, o Buza kona kaikaina, a o Kemuela ka makuakane o Arama,
\q1 
\v 22 O Keseda, a o Hazo, a o Piledasa, a o Iidelapa, a o Betuela.
\q1 
\v 23 Na Betuela o Rebeka: o keia mau mea ewalu ka Mileka i hanau ai na Nahora ke kaikuaana o Aberahama.
\q1 
\v 24 Na kana haiawahine hoi, o Reuma kona inoa, nana hoi i hanau mai o Teba, o Gehama, o Tahasa, a o Maaka.
\c 23
\b
\q1 
\v 1 HOOKAHI haneri na makahiki me ka iwakaluakumamahiku o Sara: oia na makahiki o ke ola ana o Sara.
\q1 
\v 2 A make aku la o Sara ma Kiriatareba, oia o Heberona ma ka aina o Kanaana; a hele mai la o Aberahama e uwe a e kanikau ia Sara.
\b
\q1 
\v 3 Ka ae la o Aberahama iluna, mai ke alo ae o kana mea i make, olelo aku la ia i na mamo a Heta, i aku la,
\q1 
\v 4 He malihini no wau e noho wale ana me oukou: e haawi mai i ilina iwaena o oukou, i lilo ia no'u, i kanu aku au i kuu mea i make, mai ko'u mau maka aku.
\q1 
\v 5 Olelo mai na mamo a Heta ia Aberahama, i mai la ia ia,
\q1 
\v 6 E hoolohe mai oe i ka makou, e kuu haku: he alii nui no oe iwaena o makou; ma ka ilina maikai loa o makou, e kanu iho ai oe i kau mea make: aole e aua kekahi o makou i kona ilina ia oe, i ole oe e kanu i kou mea make.
\q1 
\v 7 Ka ae la o Aberahama, a kulou iho la imua o na kanaka o ka aina, o na mamo a Heta.
\q1 
\v 8 Kamailio aku la ia me lakou, i aku la, Ina o ko oukou manao ia, i kanu iho ai au i kuu mea make mai o'u mau maka aku; e hoolohe mai, a e noi aka oukou ia Eperona ke keiki a Zohara no'u;
\q1 
\v 9 I haawi mai ai oia i ke ana o Makepela no'u; nona no ia, aia no ma ka palena o kana mahinaai; no na kala e pono ke kuai, e haawi mai no oia ia wahi no'u i ilina iwaena o oukou.
\q1 
\v 10 Noho pa iho la o Eperona me na mamo a Heta: olelo mai la o Eperona ka Heta ia Aberahama, ma ka lohe o na mamo a Heta, a o ka poe a pau i komo ma ka ipuka o ke kulanakauhale, i mai la,
\q1 
\v 11 E kuu haku, e hoolohe mai oe ia'u: ke haawi wale aku nei au i ka mahinaai a me ke ana maloko, nou, ke haawi aku nei au nou ia wahi: imua o na keiki a o'u poe kanaka, ke haawi aku nei au nou ia wahi: e kanu aku oe i kau mea make.
\q1 
\v 12 Kulou iho la o Aberahama ilalo, imua o na kanaka o ia aina.
\q1 
\v 13 I aku la oia ia Eperona ma ka lohe o na kanaka o ia aina, i ka i ana, Ke noi aku nei au ia oe, e hoolohe mai oe ia'u, Ina e ae mai oe, e haawi aku no wau i ke kala no ua mahinaai la; e lawe oe i ka'u, a e kanu no wau i kau mea make ilaila.
\q1 
\v 14 Olelo mai la o Eperona ia Aberahama, i mai la ia ia,
\q1 
\v 15 E kuu haku, e hoolohe mai ia'u, eha haneri sekela kala ke kumukuai o ia aina; heaha hoi ia iwaena o kaua? e kanu hoi oe i kau mea make.
\q1 
\v 16 Ae mai la o Aberahama ia Eperona; a kaupouna iho la o Aberahama no Eperona i ke kala ana i olelo ai ma ka lohe o na mamo a Heta, eha haneri sekela kala, he kala pono i ka poe kuai.
\b
\q1 
\v 17 A ua hoolilo paa ia ka mahinaai a Eperona ma Makepela, ma ke alo o Mamere, o ka mahinaai me ke ana maloko, a me na laau a pau o na mahinaai la, a e puni ana ma na palena a pau,
\q1 
\v 18 No Aberahama i wahi nona ma ke alo o na mamo a Heta, imua hoi o ka poe a pau i komo ma ka ipuka o kona kulanakauhale.
\b
\q1 
\v 19 Mahope iho, kanu iho la o Aberahama i kana wahine ia Sara iloko o ke ana ma ka mahinaai o Makepela ma ke alo o Mamere: oia o Heberona i ka aina o Kanaana.
\q1 
\v 20 Ua hoolilo paa ia ka mahinaai a me ke ana maloko, no Aberahama i ilina nona, e na mamo a Heta.
\c 24
\b
\q1 
\v 1 U A elemakule o Aberahama, ua nui no hoi kona mau la, a ua hoopomaikai o Iehova ia Aberahama i na mea a pau.
\q1 
\v 2 I aku la o Aberahama i ke kauwa kahiko o kona hale, i ka mea ia ia ka malama i kona mea a pau, E, e kau mai oe i kou lima malalo iho o ko'u uha:
\q1 
\v 3 A na'u no e haawi aku ia oe e hoohiki ma o Iehova la, ma ke Akua o ka lani, a ke Akua o ka honua; i lawe ole ai oe i wahine na ka'u keiki na Isaaka, no na kaikamahine a ko Kanaana ka poe a'u o noho nei iwaena.
\q1 
\v 4 Aka, e hele aku oe i ko'u aina, a i ko'u poe hoahanau, a e lawe mai i wahine na ka'u keiki na Isaaka.
\q1 
\v 5 I mai la ua kauwa nei ia ia, Ina paha aole e makemake ka wahine e hahai mai ia'u a hiki i keia aina: e pono anei ia'u e kai aku i kau keiki i ka aina au i hele mai nei?
\q1 
\v 6 Papa aku la o Aberahama ia ia, E ao oe, mai kai aku oe i ka'u keiki malaila.
\b
\q1 
\v 7 Na Iehova ke Akua o ka lani, nana au i lawe, mai ka hale mai o ko'u makuakane, a mai ka aina mai o ko'u poe hoahanau, a olelo mai ia'u, a hoohiki mai no hoi ia'u, i ka i ana mai, E haawi auanei au i keia aina no kau poe mamo; nana no e hoouna aku i kona anela mamua ou, a e lawe mai oe i wahine na ka'u keiki mailaila mai.
\q1 
\v 8 A i makemake ole ka wahine e hahai mai ia oe, alaila e hala ole oe i keia hoohiki ana no'u: aka, mai kai aku oe i ka'u keiki ilaila.
\q1 
\v 9 A kau iho la ke kauwa i kona lima malalo iho o ka uha o Aberahama kona haku, a hoohiki iho la nona ma ia mea.
\b
\q1 
\v 10 Lalau aku la ua kauwa la i na kamelo o kona haku he umi, no ka mea, ma kona lima ka waiwai a pau o kona haku: ku ae la ia, a hele aku la i Mesopotamia, i ke kulanakauhale o Nahora.
\q1 
\v 11 Hookukuli iho la ia i kona mau kamelo mawaho o ke kulanakauhale, ma ka luawai, i ke ahiahi, i ka manawa e hele mai ai na wahine e huki wai.
\b
\q1 
\v 12 I aku la ia, E Iehova ke Akua o kuu haku o Aberahama, ke pule aku nei au ia oe, e hoopomaikai mai oe ia'u i keia la, a e lokomaikai mai oe i kuu haku ia Aberahama,
\q1 
\v 13 Eia au ke ku nei ma ka luawai; a e hele mai ana na kaikamahine a na kanaka o ke kulanakauhale e huki i ka wai:
\q1 
\v 14 E ae mai oe, o ke kaikamahine a'u e olelo aku ai, Ke noi aku nei au ia oe, e kuu iho oe i kou bakeke, i inu ai au; a e i mai oia, E inu oe, a e hoohainu hoi au i na kamelo: oia no ka mea au i koho ai na kau kauwa na Isaaka: ilaila au e ike ai i kau lokomaikai ana mai i kuu haku.
\b
\q1 
\v 15 Aole ia i hooki iho i kana olelo ana, Aia hoi, hiki mai la o Rebeka, ka mea i hanau na Betuela, na ke keikikane a Mileka a ka wahine a Nahora, ko Aberahama kaikuaana, me kona bakeke maluna o kona poohiwi.
\q1 
\v 16 Ua maikai ka maka o ua kaikamahine la ke nanaia'ku, he wahine puupaa, aole i ikeia e kekahi kane: iho iho la ia ma ka luawai, hoopiha iho la i kona bakeke, a hoi mai la iluna.
\q1 
\v 17 Holo aku la ua kauwa la e halawai me ia, i aku la, E, ke noi aku nei au ia oe, e ho mai no'u i wahi wai o kou bakeke e inu.
\q1 
\v 18 I mai la kela, E inu oe, e kuu haku a wikiwiki oia i kuu iho i kona bakeke ma kona lima, a hoohainu mai la ia ia.
\q1 
\v 19 A pau kana hoohainu ana ia ia, i mai la ia, E huki hoi au i ka wai no kou mau kamelo, a pau ko lakou inu ana.
\q1 
\v 20 Wikiwiki ae la ia, a ninini iho la i ka wai o kona bakeke iloko o ke pa, a holo hou ae la i ka luawai e huki ai, a huki mai la ia no kona poe kamelo a pau.
\q1 
\v 21 Mahalo iho la ka naau o ua kanaka la ia ia, aole ia i ekemu aku, i mea e ike ai oia, i ka hoopomaikai ana mai paha o Iehova i kona hele ana mai, aole paha.
\b
\q1 
\v 22 A pau ka inu ana o na kamelo, lawe ae la ua kanaka la i kekahi apo gula no ka ihu, he hapalua o ka sekela ma ke kaupouna ana, me na kupee gula elua no kona mau lima, he umi [na sekela] ma ke kaupouna ana;
\q1 
\v 23 Ninau aku la ia, He kaikamahine oe nawai? ke noi aku nei au ia oe, e hai mai ia'u: a he wahi kaawale no anei iloko o ka hale o kou makuakane e moe ai makou?
\q1 
\v 24 I mai la kela ia ia, Owau no ke kaikamahine a Betuela a ke keiki a Mileka, ana i hanau ai na Nahora.
\q1 
\v 25 I hou mai la hoi kela ia ia, He mauu maloo no a he ai na na holoholona ia makou a nui, a he wahi no hoi e moe ai.
\q1 
\v 26 Kulou iho la ke poo o ua kanaka la, a hoomaikai aku la ia Iehova;
\q1 
\v 27 I aku la, E hoomaikaiia'ku o Iehova ke Akua o kuu haku o Aberahama, aole ia i hoonele mai i kuu haku i kona aloha a me kona oiaio: ma ke alanui wau, a ua alakai aku o Iehova ia'u ma ka hale o na hoahanau o kuu haku.
\b
\q1 
\v 28 Holo aku la ua kaikamahine la, a hai aku la i ko ka hale o kona makuwahine ia mau mea.
\b
\q1 
\v 29 He kaikunane ko Rebeka, o Labana kona inoa; a holo mai la o Labana iwaho i ua kanaka la, ma ka luawai.
\q1 
\v 30 A ike aku la ia i ke apo no ka ihu, a me na kupee lima ma na lima o kona kaikuwahine, a lohe aku la ia i ka olelo a kona kaikuwahine a Rebeka, i ka i ana mai, Pela i olelo mai ai ke kanaka ia'u; hele mai la ia i ua kanaka nei; aia hoi, ku iho la ia me na kamelo ma ka luawai.
\q1 
\v 31 I mai la ia, E ka mea i alohaia e Iehova, e komo mai oe; heaha kau e ku wale nei iwaho? no ka mea, ua hoomakaukau iho nei au i ka hale, a me ka wahi no na kamelo.
\b
\q1 
\v 32 Komo aku la ua kanaka la iloko o ka hale: wehe ae la ia i na kamelo, a haawi aku la i ka mauu maloo a me ka mea ai na na kamelo, a me ka wai e holoi i kona mau wawae, a me na wawae o na kanaka me ia.
\q1 
\v 33 A laweia mai ka ai nana: i aku la oia, Aole au e ai, a hai e aku au mamua i ka'u mea i hele mai nei. I mai la kela, E hai mai.
\q1 
\v 34 I aku la ia, Owau no ke kauwa a Aberahama.
\q1 
\v 35 Ua hoopomaikai nui mai o Iehova i kuu haku; a ua lilo ia i mea nui: ua haawi mai ia nana i hipa, a me na bipi, i ke kala a me ke gula, i na kauwakane a me na kauwawahine, i na kamelo a me na hoki.
\q1 
\v 36 A hanau mai la o Sara ka wahine a kuu haku i keikikane nana i kona wa luwahine, a ua haawi aku kela i kona waiwai a pau nona.
\q1 
\v 37 A ua haawi mai kuu haku ia'u e hoohiki, i ka i ana mai, Mai lawe oe i wahine na kuu keiki no na kaikamahine a ko Kanaana, nona keia wahi a'u e noho nei:
\q1 
\v 38 Aka, e hele oe i ka ohana a kuu maknakane, a i ko'u poe hoahanau, a e lawe mai oe i wahine na kuu keiki.
\q1 
\v 39 I aku la au i kuu haku, Ina paha aole e makemake ka wahine e hahai mai ia'u.
\q1 
\v 40 I mai la kela ia'u, Na Iehova, na ka Mea imua ona ko'u hele ana, nana no e hoouna aku i kona anela me oe, a e hoopomaikai i kou hele ana; a e lawe mai oe i wahine na kuu keiki no ko'u poe hoahanau, a no ka ohana a ko'u makuakane:
\q1 
\v 41 Alaila, e hala ole oe i kuu hoohiki ana, ke hiki aku oe i ko'u poe hoahanau, a haawi ole mai lakou ia oe, alaila e hala ole oe i kuu hoohiki ana.
\q1 
\v 42 A hiki mai la au i keia la i ka luawai, i aku la, E Iehova ke Akua o kuu haku o Aberahama, ina oe e hoopomaikai mai i kuu hele ana e hele nei:
\q1 
\v 43 Eia wau, ke ku nei ma ka luawai, a i ka manawa e hele mai ai ka wahine puupaa e huki wai ai, a e i aku au ia ia, Ke noi aku nei au ia oe, e haawi mai no'u i wahi wai o kou bakeke e inu;
\q1 
\v 44 A e olelo mai oia ia'u, E inu oe, a e huki hoi au no kou mau kamelo; oia ka wahine a Iehova i koho ai na ke keiki a ko'u haku.
\q1 
\v 45 Aole au i hooki iho i ka olelo ana iloko o kuu naau, aia hoi, puka mai la o Rebeka, me kona bakeke maluna o kona poohiwi; iho iho la ia ma ka luawai, a huki mai la: i aku la au ia ia, Ke noi aku nei au ia oe, e haawi mai no'u e inu.
\q1 
\v 46 Wikiwiki iho la ia, a kuu iho la i kona bakeke mailuna iho ona, i mai la, E inu oe, a e hooinu hoi au i kou mau kamelo: inu iho la no au, a hooinu aku la hoi oia i na kamelo.
\q1 
\v 47 Ninau aku la au ia ia, i aku la, He kaikamahine oe nawai? I mai la kela, He kaikamahine na Betuela ke keiki a Nahora, na ka mea a Mileka i hanau ai nana: a lou aku la au i ke apo ma kona ihu, a me na kupee lima ma kona mau lima.
\q1 
\v 48 Kulou iho la au i kuu poo, a hoomana aku la ia Iehova, a hoomaikai aku la ia Iehova i ke Akua o kun haku o Aberahama, nana au i alakai ma ke ala pono, i lawe au i ke kaikamahine a ka hoahanau o kuu haku i wahine na kana keiki.
\q1 
\v 49 Ano la, a i manao lokomaikai io mai oukou i kuu haku, e hai mai ia'u: a i ole, e hai mai hoi; i huli aku ai au i ka akau paha, i ka hema paha.
\b
\q1 
\v 50 Alaila, olelo mai la o Labana laua o Betuela, i mai la, No Iehova mai ia mea; aole e hiki ia maua ke olelo aku ia oe he hewa, aole hoi he pono.
\q1 
\v 51 Aia hoi o Rebeka imua o kou alo, e lawe oe ia ia a e hele aku, i lilo ai ia i wahine na ke keiki a kou haku, e like me ka Iehova i olelo mai ai.
\q1 
\v 52 A lohe ae la ke kanwa a Aberahama i ka laua olelo, hoomana aku la ia ia Iehova, [e kulou ana] i ka honua.
\q1 
\v 53 Lawe mai la ua kauwa la i na mea kala a me na mea gula, a me na aahu, a haawi aku la ia mau mea no Rebeka: haawi aku la hoi oia i na mea maikai na kona kaikunane a me kona makuwahine.
\q1 
\v 54 Ai iho la lakou a inu hoi, oia a me na kanaka me ia, a moe iho la ia po. Ala ae la lakou i kakahiaka, i aku la ia, E kuu aku oukou ia'u e hele i ko'u haku.
\q1 
\v 55 I mai la kona kaikunane laua o kona makuwahine, E noho no ke kaikamahine me makou i kekahi mau la, i umi paha: a mahope aku e hele no ia.
\q1 
\v 56 I aku la kela ia laua, Mai keakea mai olua ia'u, no ka mea, ua hoopomaikai mai o Iehova i kuu hele ana mai; e kuu aku oukou ia'u e hele aku ai i ko'u haku.
\q1 
\v 57 I mai la laua, E hea aku maua i ke kaikamahine, a e ninau aku ia ia.
\q1 
\v 58 Hea aku la laua ia Rebeka, ninau aku la ia ia, E aku oe e hele pu me keia kanaka? I mai la kela, E hele wau.
\q1 
\v 59 Kuu aku la laua ia Rebeka o ko laua kaikuwahine, me kona kahu, a me ke kauwa a Aberahama, a me na kanaka ona.
\q1 
\v 60 Hoomaikai aku la laua ia Rebeka, i aku la, O oe no ko maua kaikuwahine, e lilo oe i makuwahine o na tausani miliona: e lilo hoi no kau poe mamo, ka pukapa o ka poe inaina aku ia lakou.
\b
\q1 
\v 61 Ku ae la o Rebeka, me kona mau wahine, holo mai la lakou maluna o na kamelo, e hahai ana i ua kanaka la: a lawe ae la ua kauwa la ia Rebeka, a hoi mai la.
\b
\q1 
\v 62 I hele mai la o Isaaka ma ke alanui o ka punawai Lahairoi: no ka mea, i noho no ia ma ka aina kukuluhema.
\q1 
\v 63 Hele aku la o Isaaka ma ke kula e noonoo ai i ka wa ahiahi: alawa ae la kona mau maka iluna, aia hoi na kamelo e hoi mai ana.
\q1 
\v 64 Nana mai la o Rebeka, a ike mai la oia ia Isaaka, lele iho la ia mai luna iho o ke kamelo.
\q1 
\v 65 No ka mea, ua ninau aku ia i ua kauwa la, Owai ia kanaka e hele mai ana i ke kula e halawai me kakou? a ua i mai ke kauwa, O kuu haku no ia: no ia mea, lawe ae la ia i ka pale, a hoouhi iho la ia ia iho.
\q1 
\v 66 A hai mai la ua kauwa la ia Isaaka i na mea a pau ana i hana'i.
\q1 
\v 67 Alakai aku la o Isaaka ia ia maloko o ka halelewa o kona makuwahine o Sara; lawe aku la oia ia Rebeka, a lilo iho la ia i wahine nana, a aloha ae la oia ia ia. A ua hooluoluia o Isaaka no kona makuwahine.
\c 25
\b
\q1 
\v 1 LAWE hou ae la o Aberahama i wahine nana, o Ketura kona inoa.
\q1 
\v 2 O na keiki ana i hanau ai nana, o Zimerama, o Iokesana, o Medana, o Midiana, o Isebaka a o Sua.
\q1 
\v 3 Na Iokesana o Seba, a o Dedana. Eia ka poe mamo a Dedana, o ka Asurima, Ka Letusima, a me ka Leumima.
\q1 
\v 4 O na keiki a Midiana; o Epa, o Epera, o Hanoka, o Abida, a o Eledaa. O keia poe a pau na Ketura mai.
\b
\q1 
\v 5 Kauoha mai la o Aberahama i kona waiwai a pau ia Isaaka.
\q1 
\v 6 Aka, haawi aku la o Aberahama i na makana na na keikikane a na haiawahine a Aberahama, a hookuu aku la ia lakou, i kona wa e ola ana, mai kana keiki o Isaaka aku, e hele i ka aina o ka hikina.
\b
\q1 
\v 7 Eia na la o na makahiki o ko Aberahama ola ana, hookahi haneri a me kanahikukumamalima.
\q1 
\v 8 Alaila kaliia'ku ke ea o Aberahama, a make iho la ia i ka wa elemakule maikai; he kanaka kahiko loa ia, a ua nui na la ona, a ua huiia'ku ia me kona poe kanaka.
\q1 
\v 9 Na kana mau keiki na Isaaka laua o Isemaela i kanu aku ia ia maloko o ke ana o Makepela, ma ka mahinaai a Eperona ke keiki a Zohara no ka Heta, ma ke alo o Mamere,
\q1 
\v 10 Ma ka mahinaai a Aberahama i kuai ai me na mamo a Heta: ilaila i kanuia'i o Aberahama, a me Sara o kana wahine.
\b
\q1 
\v 11 Mahope mai o ka make ana o Aberahama, hoopomaikai mai la ke Akua ia Isaaka; a noho iho la o Isaaka ma ka luawai o Lahairoi.
\b
\q1 
\v 12 Eia ka mooolelo no Isemaela, no ke keikikane a Aberahama, o ka mea a Hagara no Aigupita ke kauwawahine a Sara i hanau ai na Aberahama:
\q1 
\v 13 Eia hoi na inoa o na keikikane a Isemaela, ma ko lakou mau inoa, e like me ko lakou hanau ana: o Nebaiota kana hiapo; o Kedara, o Adebeela, o Mibesama,
\q1 
\v 14 O Misama, o Duma, o Masa.
\q1 
\v 15 Hadara, o Tema, o Ietura, o Napisa, a o Kedema.
\q1 
\v 16 Oia na keikikane a Isemaela, oia hoi ko lakou mau inoa; ma ko lakou mau kauhale, a ma ko lakou mau kulanahale; he umikumamalua mau alii e like me ko lakou mau lahuikanaka.
\q1 
\v 17 Eia na makahiki o ke ola ana o Isemaela, hookahi haneri na makahiki me kanakolukumamahiku: ua kailiia'ku kona ea, a make iho la ia; a ua huiia aku ia me kona poe kanaka.
\q1 
\v 18 Noho iho la lakou mai Havila a hiki i Sura, ma ke alo o Aigupita, i kou hele ana i Asuria; pela oia I noho ai ma ke alo o kona poe hoahanau a pau.
\b
\q1 
\v 19 Eia ka mooolelo no Isaaka no ke keiki a Aberahama: Na Aberahama o Isaaka:
\q1 
\v 20 He kanaha na makahiki o Isaaka i kona wa i lawe ai ia Rebeka ke kaikamahine a Betuela no Suria, a ke kaikuwahine o Labana no Suria, i wahine nana.
\b
\q1 
\v 21 Nonoi aku la o Isaaka ia Iehova no kana wahine, no ka mea, ua pa oia: a hoolohe mai la ke Akua ia ia, a hapai ae la kana wahine o Rebeka.
\q1 
\v 22 Oni pu ae la na keiki iloko ona; i iho la ia, A i pela ia, i aha keia mea a'u? A hele aku la ia e ninau ia Iehova.
\q1 
\v 23 I mai la o Iehova ia ia, Elua no lahuikanaka iloko o kou opu, elua hoi poe kanaka e puka mai ana noloko mai o kou opu, a e oi aku ka ikaika o kekahi poe i ko kekahi poe; a e hookauwa aku ka hanau mua i ka hanau hope.
\b
\q1 
\v 24 A hiki mai kona manawa e hanau ai, aia hoi, he mau mahoe iloko o kona opu.
\q1 
\v 25 A puka mai la ka mua, ua huluhulu, a ulaula, e like me ka aahu huluhulu, a kapa iho la lakou i kona inoa, o Esau.
\q1 
\v 26 Mahope iho, puka mai la kona kaikaina, a paa aku la kona lima i ke kuekue wawae o Esau; a kapaia kona inoa, o Iakoba. He kanaono na makahiki o Isaaka i ko Rebeka manawa i hanau ai laua.
\b
\q1 
\v 27 Nui ae la ua mau keiki la: he kanaka akamai o Esau i ka hahai holoholona hihiu, he kanaka no ka nahelehele: aka, he kanaka noho malie o Iakoba, e noho ana ma na halelewa.
\q1 
\v 28 Aloha aku la o Isaaka ia Esau, no ka mea, ai iho la ia i ka io o ua mea hihiu: a o Rebeka ka i aloha ia Iakoba.
\b
\q1 
\v 29 Hoolapalapa iho la o Iakoba i ka mea ai: a hoi mai la o Esau mai ka nahelehele mai, a ua nawaliwali ia.
\q1 
\v 30 I mai la o Esau ia Iakoba, Ke noi aku nei au ia oe, e ho mai na'u e ai ia mea ulaula; no ka mea, ua nawaliwali au: nolaila ua kapaia kona inoa o Edoma.
\q1 
\v 31 I aku la o Iakoba, E kuai kaua i keia la, i lilo mai ia'u kau pono o ka hanau mua.
\q1 
\v 32 I iho la o Esau, Eia wau ua kokoke e make, a heaha auanei ko'u pomaikai i keia pono o ka hanau mua?
\q1 
\v 33 I aku la o Iakoba E hoohiki oe na'u i keia la; a hoohiki aku la ia nana: a kuai lilo mai la ia i kana pono o ka hanau mua, na Iakoba.
\q1 
\v 34 Alaila, haawi aku la o Iakoba na Esau i ka berena a me na papapa i hoolapalapaia; ai iho la ia a inu hoi, ku ae la ia a hele aku la i kona wahi i hele ai: pela o Esau i hoowahawaha'i i kana pono o ka hanau mua.
\c 26
\b
\q1 
\v 1 HE wi no ma ia aina, he okoa ka wi mua i hiki mai ai i ka wa ia Aberahama. A hele aku la o Isaaka io Abimeleka la, i ke alii o ko Pilisetia ma Gerara.
\q1 
\v 2 Ikea aku la o Iehova e ia, i mai La, Mai hele oe ilalo i Aigupita, E noho iho ma ka aina a'u e hai aku ai ia oe:
\q1 
\v 3 E noho oe ma keia aina, a me oe pu no wau, a e hoopomaikai aku no wau ia oe: no ka mea, e haawi aku auanei au nou, a no kau poe mamo i keia mau aina a pau; a e hooko auanei au i ka hoohiki ana a'u i hoohiki ai i kou makuakane ia Aberahama.
\q1 
\v 4 A e hoonui aku au i kau poe mamo e like me na hoku o ka lani, a e haawi aku. no wau i keia mau aina a pau no kau poe mamo; a i kau mamo e hoopomaikaiia'i na lahuikanaka a pau o ka honua:
\q1 
\v 5 No ka mea, i hoolohe mai no o Aberahama i ko'u leo, a i malama hoi i ka'u mau kauoha, i ka'u mau olelo, a me ko'u mau kanawai.
\b
\q1 
\v 6 A noho iho la o Isaaka ma Gerara.
\q1 
\v 7 Ninau mai la na kanaka o ia wahi ia ia no kana wahine; i aku la ia, O ko'u kaikuwahine no ia: no ka mea, makau iho la ia i ka i aku, Oia ka'u wahine; o pepehi mai na kanaka o ia wahi ia'u no Rebeka; no ka mea, he maikai ia ke nanaia'ku.
\q1 
\v 8 Ia ia i noho ai ma ia wahi a liuliu, nana mai la o Abimeleka o ke alii o ko Pilisetia, ma ka puka makani, ike mai la ia, aia hoi, o Isaaka e lealea ana me kana wahine, me Rebeka.
\q1 
\v 9 Hea mai la o Abimeleka ia Isaaka, i mai la, Aia hoi, he oiaio no, o kau wahine no ia; a pehea hoi oe i olelo mai ai, O ko'u kaikuwahine ia? I aku la o Isaaka ia ia, No ka mea, i iho la au, E make paha uanei au nona.
\q1 
\v 10 I mai la o Abimeleka, Heaha keia au i hana mai ai ia makou? Ina i moe wale paha kekahi o na kanaka me kau wahine, ina ua hooili mai oe i ka hala maluna o makou.
\q1 
\v 11 Kauoha aku o Abimeleka i na kanaka a pau, i ka i ana, O ka mea hoopa aku i keia kanaka, a i kana wahine paha, he oiaio e make ia.
\b
\q1 
\v 12 Lulu hua iho la o Isaaka ma ia aina, a loaa pahaneri mai la ia ia ia makahiki: a hoopomaikai mai la o Iehova ia ia.
\q1 
\v 13 Lilo ae la ua kanaka la i mea nui, mahuahua ae la ia, ulu ae la, a lilo i kanaka nui loa:
\q1 
\v 14 No ka mea, nana na hipa, a me na bipi, a me na kanaka he nui loa: a huahuwa mai la ko Pilisetia ia ia.
\q1 
\v 15 A o na punawai a pau i eliia e na kauwa a kona makuakane, i ka wa ia Aberahama, huna ae la ko Pilisetia ia mau mea i ka hoopiha i ka lepo.
\q1 
\v 16 Olelo mai la o Abimeleka ia Isaaka, E hele aku oe mai o makou aku, no ka mea, ua nui loa aku kau, i ka makou.
\b
\q1 
\v 17 Hele aku la o Isaaka, a kukulu iho la i kona halelewa ma ke awawa o Gerara, a noho iho la ilaila.
\b
\q1 
\v 18 Eli hou iho la o Isaaka i na luawai a lakou i eli iho ai i ka wa ia Aberahama o kona makuakane; no ka mea, ua huna iho ko Pilisetia ia mau mea mahope o ka make ana o Aberahama: a kapa iho la ia i ko lakou mau inoa, ma na inoa a kona makuakane i kapa iho ai.
\q1 
\v 19 Eli iho la na kanwa a Isaaka ma ke awawa, a loaa iho la ka punawai ilaila, he wai mau.
\q1 
\v 20 Hakaka mai la na kahu bipi no Gerara me na kahu bipi o Isaaka, i ka i ana mai, No makou ia wai: a kapa iho la ia i ka inoa o ua luawai la, o Eseka, no ko lakou hakaka ana mai me ia.
\q1 
\v 21 Eli iho la hoi lakou i ka luawai hou, a hakaka mai no hoi lakou no ia mea: a kapa iho la oia i kona inoa, o Sitena.
\q1 
\v 22 Neenee aku la ia mai ia wahi aku, a eli iho la i ka luawai hou; aole no lakou i hakaka mai no ia mea: a kapa iho la oia i kona inoa, o i Rehobota: i iho la ia, ano hoi, ua haawi mai o Iehova i kahi akea no kakou; a e hoohua auanei kakou ma ka aina.
\b
\q1 
\v 23 A mahope aku, pii aku la ia malaila aku a Beereseba.
\q1 
\v 24 Ikea ae la o Iehova e ia ia po iho, i mai la, Owau no ke Akua o Aberahama o kou makuakane: mai makau oe, owau no me oe, a e hoopomaikai no au ia oe a e hoonui hoi i kau poe mamo no ka'u kauwa, no Aberahama.
\q1 
\v 25 Hana iho la ia i kuahu malaila, a kahea aku la ia i ka inoa o Iehova, a kukulu iho la i kona halelewa ilaila: ilaila hoi na kauwa a Isaaka i eli iho ai i ka luawai.
\b
\q1 
\v 26 Alaila, hele mai la io na la o Abimeleka mai Gerara mai, oia me Ahuzata kekahi hoalauna ona, a me Pikola ka luna koa o kona poe kaua.
\q1 
\v 27 I aku la o Isaaka ia lakou, Heaha ka oukou i hele mai ai io'u nei, no ka mea, ke inaina mai nei oukou ia'u, a ua hookuke mai nei oukou ia'u mai o oukou aku.
\q1 
\v 28 Olelo mai la lakou, Ua ike io makou, aia no o Iehova me oe: olelo ae la makou, I hoohiki ana mawaena o kakou, o makou nei, a on la, a e hoopaa makou i berita me oe;
\q1 
\v 29 I hana ino ole mai oe ia makou, me makou i hoopa ole aku ai ia oe, o ka maikai wale no ka makou i hana aku ai ia oe, a ua hoihoi aku ia oe me ka maluhia: o oe io no ka mea i hoopomaikaiia e Iehova.
\q1 
\v 30 Hana iho la ia i ahaaina na lakou, ai iho la lakou a inu hoi.
\q1 
\v 31 Ala ae la lakou i kakahiaka nui, a hoohiki iho la laua, i kekahi i kekahi: hookuu aku la o Isaaka ia lakou, a hoi hou aku la lakou mai ona aku la me ke kuikahi.
\q1 
\v 32 Ia la hookahi no, hele mai la na kauwa a Isaaka, a hai mai la ia ia no ka luawai a lakou i eli iho ai, i mai la ia ia, Ua loaa ia makou ka wai.
\q1 
\v 33 Kapa iho la oia ia wahi, o Seba: nolaila, o Beereseba ka inoa o ia kulanakauhale a hiki i keia la.
\b
\q1 
\v 34 Hookahi kanaha na makahiki o Esau ia ia i lawe ai ia Iehudita ke kaikamahine a Beeri no ka Heta, a me Basemata ke kaikamahine a Elona no ka Heta, i mau wahine nana:
\q1 
\v 35 He mau mea ehaeha laua no ka naau o Isaaka a me Rebeka.
\c 27
\b
\q1 
\v 1 I KO Isaaka manawa i elemakule ai, a powehiwehi ai kona mau maka, a hiki ole ia ia ke ike aku; hea aku la oia ia Esau i kana keiki mua, i aku la ia ia, E kuu keiki: i mai la kela, Eia wau.
\q1 
\v 2 I aku la oia, Eia hoi, ua elemakule au, aole hoi au i ike i kuu la e make ai:
\q1 
\v 3 Ano hoi, e lawe oe i kau mau mea pana, i kau aapua a me kau kakaka, e hele aku oe i ka nahelehele e imi i kahi io na'u;
\q1 
\v 4 A e hana oe i mea ono na'u i ka mea hoi a'u i ono ai, a e lawe mai oe i o'u nei, i paina au, a i hoomaikai aku kuu uhane ia oe mamua o kuu make ana.
\b
\q1 
\v 5 Lohe ae la o Rebeka i ka wa a Isaaka i olelo aku ai ia Esau i kana keiki A hele aku o Esau i ka nahelehele e imi aku a e lawe mai i ka io o ka holoholona hihiu.
\b
\q1 
\v 6 Olelo aku la o Rebeka ia Iakoba i kana keiki, i aku la, Aia hoi, ua lohe iho nei au i kou makuakane e olelo ana i kou kaikuaana ia Esau, i ka i ana ae,
\q1 
\v 7 E lawe mai oe io'u nei i io holoholona hihiu, a e hana i ka mea ono na'u, i paina au, a i hoomaikai hoi au ia oe imua o Iehova mamua o kuu make ana.
\q1 
\v 8 Ano hoi, e kuu keiki, e hoolohe mai oe i ko'u leo, ma ka mea a'u e kauoha aku nei ia oe.
\q1 
\v 9 E hele koke aku oe i ka poe holoholona, a e lawe mai i na keiki kao maikai i elua; a na'u no e hana i ka mea ono na kou makuakane, i kana mea i ono ai:
\q1 
\v 10 A e halihali aku oe ia mea i kou makuakane, i ai iho ia, a i hoomaikai mai oia ia oe mamua o kona make ana.
\q1 
\v 11 Olelo mai la o Iakoba ia Rebeka i kona makuwahine, Aia hoi, he kanaka huluhulu o Esau kuu kai kuaana, a he kanaka pahee no wau:
\q1 
\v 12 A e hana mai paha kuu makuakane ia'u, a e ikea auanei au e ia he mea hoopunipuni; a e hooili mai au i ka hoinoia maluna iho o'u, aole ka hoomaikaiia,
\q1 
\v 13 I aku la kona makuwahine ia ia, Maluna iho o'u kou hoinoia, e kuu keiki; e hoolohe wale mai oe i ko'u leo, e kii aku, a e lawe mai io'u nei.
\q1 
\v 14 Kii aku la ia, a lawe mai la ia mau mea i kona makuwahine: a na kona makuwahine i hana i ka mea ono, a kona makuakane i ono ai.
\q1 
\v 15 Lawe ae la o Rebeka i ka aahu maikai o kana keiki mua o Esau, i ka mea e waiho ana iloko o ka hale me ia, a hoaahu iho la ia Iakoba i kana keiki muli iho ia mea.
\q1 
\v 16 A hoopili aku la o Rebeka i na ili o na keiki kao maluna o kona mau lima, a me ka pahee o kona a-i.
\q1 
\v 17 Haawi aku la ia i ka mea ono, a me ka berena ana i hoomakaukau ai, iloko o ka lima o Iakoba o kana keiki.
\b
\q1 
\v 18 A hele aku la ia i kona makuakane, i aku la, E kuu makuakane: i mai la kela, Eia no wau; owai la oe, e kuu keiki?
\q1 
\v 19 I aku la o Iakoba i kona makuakane, Owau no o Esau, o kau makahiapo; ua hana iho nei au i kau mea i kauoha mai ai; ke noi aku nei au, e ala mai oe, e noho a e ai iho i ka'u io o ka mea hihiu, i hoomaikai mai kou uhane ia'u.
\q1 
\v 20 I mai la o Isaaka i kana keiki, Pehea ka emoole o ka loaa ana o ia mea ia oe, e kuu keiki? I aku la kela, No ka mea, na Iehova na kou Akua i hoohalawai ia mea me au.
\q1 
\v 21 I mai la o Isaaka ia Iakoba, Ke noi aku nei au ia oe, e neenee mai a kokoke, i hana aku au ia oe, e kuu keiki, i ike au o ka'u keiki o Esau paha oe, aole paha.
\q1 
\v 22 Neenee aku la o Iakoba io Isaaka la i kona makuakane: a hana mai la oia ia ia, i mai la, O ka leo, ka leo no o Iakoba, aka, o na lima, na lima no o Esau.
\q1 
\v 23 Aole no i ikea oia, no ka mea, ua huluhulu kona mau lima, e like me na lima o kona kaikuaana, o Esau: a hoomaikai mai oia ia ia.
\q1 
\v 24 Ninau mai la oia ia ia, O oe io no anei o ka'u keiki o Esau? I aku la kela, Owau no.
\q1 
\v 25 I mai la oia, E lawe mai ia mea a kokoke ia'u, a e ai iho no wau i ka io mea hihiu a kuu keiki, i hoomaikai aku kuu uhane ia oe, Lawe aku la o Iakoba a kokoke, a ai iho la kela: lawe aku la hoi oia i ka waina, a inu iho la kela.
\q1 
\v 26 Olelo mai la kona makuakane o Isaaka ia ia, E hele mai oe a honi ia'u, e kuu keiki.
\q1 
\v 27 Hele aku la o Iakoba, a honi ae la ia ia: honi iho la o Isaaka i ke ala o kona aahu, hoomaikai mai la ia ia, i mai la, Aia, o ke ala o kuu keiki, ua like me ke ala o ka mahinaai a Iehova i hoomaikai ai:
\q1 
\v 28 E haawi mai ke Akua ia oe i ka hau no ka lani mai, me ka momona o ka honua, a me ka palaoa a me ka waina he nui:
\q1 
\v 29 E hookauwa mai na kanaka nau, a e moe iho na lahuikanaka imua ou, o lilo oe i haku maluna o kou poe hoahanau, a e moe iho na keiki o kou makuwahine imua ou: e hoinoia'ku na mea a pau e hoino mai ia oe, a e hoopomaikaiia'ku ka mea hoomaikai ia oe.
\b
\q1 
\v 30 A oki ae la ka hoomaikai ana mai a Isaaka ia Iakoba, aneane hoi ole mai o Iakoba mai ke alo mai o Isaaka o kona makuakane, puka mai la hoi o Esau o kona kaikuaana mai kona imi mea hihiu ana.
\q1 
\v 31 Hana no hoi oia i ka mea ono, a lawe mai hoi ia mea i kona makuakane, i aku la ia i kona makuakane, E ala mai oe, e kuu makuakane, a e ai iho i ka io mea hihia a kana keiki, i hoomaikai mai kou uhane ia'u.
\q1 
\v 32 Ninau mai la o Isaaka o kona makuakane ia ia, Owai oe? I aku la kela, Owau no o kau keiki, o kau makahiapo, o Esau.
\q1 
\v 33 Haalulu nui loa iho la o Isaaka, i mai la, Owai? auhea hoi ka mea i kii i ka io mea hihiu, a i lawe mai hoi io'u nei, a ua ai iho nei au a pau, mamua o kou hiki ana mai, a ua hoomaikai au ia ia? Oiaio, oia ke hoomaikaiia.
\q1 
\v 34 A lohe ae la o Esau i ka olelo a kona makuakane, uwe iho la ia me ka uwe nui loa, i aku la ia i kona makuakane, E hoomaikai mai ia'u, ia'u hoi, e kuu makuakane,
\q1 
\v 35 I mai la kela, Ua hele mai nei kou kaikaina me ka maalea, a ua lawe aku i kou hoomaikaiia,
\q1 
\v 36 I aku la oia, Aole anei i pono ke kapa ana ia ia o Iakoba? no ka mea, eia ka lua o kona kaili ana i ko'u pono: kaili aku la oia i ko ka hanaumua pono o'u; eia hoi, ano, ua kaili ae la oia i ko'u hoomaikaiia. I aku la hoi o Esau, Aole anei oe i malama no'u kekahi hoomaikai ana?
\q1 
\v 37 Olelo mai la o Isaaka ia Esau, Aia hoi, ua hoolilo aku au ia ia i haku nou, a ua haawi aku no wau i kona poe hoahanau a pau i poe kauwa nana; ua malama aku hoi au ia ia i ka palaoa a me ka waina: a heaha ka'u e hana aku ai nau, e kuu keiki?
\q1 
\v 38 I aku la o Esau i kona makuakane, Hookahi wale no anei au hoomaikai ana, e kuu makuakane? e hoomaikai mai oe ia'u hoi, e kuu makuakane. Hookiekie ae la o Esau i kona leo, a uwe iho la.
\q1 
\v 39 Olelo mai la o Isaaka, kona makuakane, i mai la ia ia, Aia hoi, ma ka aina momona kou noho ana, a ma kahi o ka hau o ka lani mai luna iho.
\q1 
\v 40 I kau pahikaua e ola auanei oe, a e hookauwa aku oe na kou kaikaina: a i ka manawa e loaa'i ia oe ke alii ana, alaila e haihai iho oe i kana anamo ma kou a-i.
\b
\q1 
\v 41 Inaina aku la o Esau ia Iakoba, no ka hoomaikai ana a kona makuakane i hoomaikai aku ai ia ia: i iho la o Esau iloko o kona naau, Ua kokoke mai na la e kanikau ai i kuu makuakane; alaila au e pepehi ai i kuu kaikaina ia Iakoba.
\q1 
\v 42 Ua haiia'ku keia olelo ana a Esau ia Rebeka: hoouna aku la ia e hea ia Iakoba i kana keiki muli iho, i aku la ia ia, Aia hoi, o kou kaikuaana o Esau, e hooluolu ana oia ia ia iho nou, e pepehi iho ia oe.
\q1 
\v 43 Ano hoi, e kuu keiki, e hoolohe mai oe i kuu lee; e ku ae oe, e holo aku io Labana la, i kuu kaikunane ma Harana:
\q1 
\v 44 E noho me ia i kekahi mau la, a huli ae ka inaina o kou kaikuaana mai ou aku la;
\q1 
\v 45 A huli ae ka inaina o kou kaikuaana mai ou aku la, a poina ia ia kau mea i hana aku ai ia ia: alaila e hoouna aku no wau e hoihoi mai ia oe: no ke aha la e hooneleia mai au ia olua a elua i ka la hookahi?
\b
\q1 
\v 46 Olelo aku la o Rebeka ia Isaaka, Ua pauaho no wau i kuu ola ana, no na kaikamahine a ka Heta: ina e lawe o Iakoba i kekahi kaikamahine a ka Heta i wahine nana, e like me na kaikamahine o ka aina, pehea la wau e pono ai i kuu ola aua?
\c 28
\b
\q1 
\v 1 HEA aku la o Isaaka ia Iakoba, hoomaikai aku la ia ia, kauoha aku la ia ia, i aku la, Mai lawe oe i wahine nau no na kaikamahine a ko Kanaana,
\q1 
\v 2 E ku ae, e hele aku oe i Padanarama, i ka hale o Betuela o ka makuakane o kou makuwahine; a e lawe oe i wahine nau nolaila, no na kaikamahine a Labana a ke kaikunane o kou makuwahine.
\q1 
\v 3 E hoomaikai mai ke Akua mana ia oe, e hoohua mai kela ia oe, e hoomahuahua hoi ia oe, i lilo oe i poe kanaka he nui:
\q1 
\v 4 E haawi mai hoi oia nou i ka pomaikai o Aberahama, nou, a no kau poe mamo me oe; i hooiliia nou ka aina au e noho malihini nei, ka mea a ke Akua i haawi mai ai no Aberahama.
\q1 
\v 5 Hoouna aku la o Isaaka ia Iakoba: a hele aku la ia i Padauarama io Labana la, i ke keiki a Betuela no Suria, i ke kaikunane o Rebeka, o ka makuwahine o Iakoba laua o Esau.
\b
\q1 
\v 6 A ike iho o Esau, ua hoomaikai mai o Isaaka ia Iakoba, a ua hoouna aku ia ia e hele i Padanarama, e lawe i wahine nana mai ia wahi mai; a i kana hoomaikai ana ia ia, kauoha aku la ia, i ka i ana, Mai lawe oe i wahine nau no na kaikamahine a ko Kanaana;
\q1 
\v 7 A ua hoolohe mai o Iakoba i kona makuakane, a me kona makuwahine, a ua hala aku la i Padanarama;
\q1 
\v 8 A ike iho la o Esau, aole i oluolu o Isaaka o kona makuakane i na kaikamahine a ko Kanaana;
\q1 
\v 9 Alaila, hele aku la o Esau io Isemaela la, a hui mai la me kana mau wahine, ia Mahalata i ke kaikamahine a Isemaela a ke keiki a Aberahama, oia ke kaikuwahine o Nebaiota, i wahine nana.
\b
\q1 
\v 10 Hele aku la o Iakoba mai Beereseba aku, i kona hele ana i Harana.
\q1 
\v 11 A hiki aku la ia i kau wahi, a noho iho la ilaila i ka po; no ka mea, ua napoo ka la: lawe ae la ia i kekahi o na pohaku o ia wahi i uluna nona, a moe iho la ilaila.
\q1 
\v 12 Moe iho la ia i ka uhane; aia hoi, ku mai la kekahi ala haka maluna o ka honua, a hiki aku la kona welau i ka lani: aia hoi, ua ikea na anela o ke Akua i ka pii ana ae, a i ka iho ana mai maluna o ka haka.
\q1 
\v 13 Aia hoi, ku mai la o Iehova maluna ae o ka haka, i mai la, Owau no Iehova ke Akua o Aberahama o kou kupunakane, a ke Akua o Isaaka: e haawi aku no au i ka aina au e moe iho ai nou, a no kau poe mamo;
\q1 
\v 14 A e like auanei ka nui o kau poe mamo me ka lepo o ka honua, a e palahalaha ana ae oe i ke komohana, i ka hikina, i ke kukulu akau, a i ke kukulu hema: ia oe no a i kau poe mamo e hoopomaikaiia'i na ohana a pau o ka honua.
\q1 
\v 15 Aia hoi, me oe no wau, a e malama auanei ia oe i na wahi a pau au e hele ai, a e hoihoi mai no wau ia oe i keia aina; no ka mea, aole au e haalele ia oe, a pau i ka hanaia e au ka mea a'u i olelo aku ai ia oe.
\b
\q1 
\v 16 Ala ae la o Iakoba mai kona hiamoe ana, i iho la ia. He oiaio, maanei no o Iehova, aole nae au i ike.
\q1 
\v 17 Eehia iho la ia, i iho la, He wahi eehia keia! o ka hale wale no keia no ke Akua, o ka ipuka hoi keia o ka lani.
\b
\q1 
\v 18 Ala ae la o Iakoba i kakahiaka nui, lalau aku la ia i ka pohaku ana i uluna ai, hooku ae la i eho, a ninini iho la i ka aila maluna o kona welau.
\q1 
\v 19 Kapa iho la ia i ka inoa o ia wahi, o i Betela: o Luza ka inoa mamua o ua kulanakauhale la.
\q1 
\v 20 Hoohiki aku la o Iakoba i ka hoohiki ana, i aku la, Ina e noho pu ke Akua me au, a e malama mai ia'u ma keia ala a'u e hele nei, a e haawi mai i ai na'u e ai ai, a i kapa hoi e aahu ai,
\q1 
\v 21 A hoi hou mai au i ka hale o ko'u makuakane me ka maluhia; alaila o Iehova no ko'u Akua:
\q1 
\v 22 A o keia pohaku a'u i hooku ae nei i kukulu, a e lilo auanei ia i hale no ke Akua: a e haawi io aku no wau nou i ka hapaumi o na mea a pau au e haawi mai ai ia'u.
\c 29
\b
\q1 
\v 1 A LAILA, hele aku la o Iakoba i. kona hele ana, a hiki aku la i ka aina o na kanaka o ka hikina.
\q1 
\v 2 Nana aku la ia, aia hoi, he luawai ma ke kula, a me na ohana hipa ekolu e moe ana ilaila: no ka mea, ua hoohainuia na ohana holoholona i ka wai o ua luawai la: a aia maluna o ka waha o ka luawai he pohaku nui.
\q1 
\v 3 Ilaila i hoakoakoaia'i na ohana holoholona a pau: olokaa ae la lakou i ka pohaku mai ka waha ae o ka luawai, a hoohainu iho la i na hipa; a kau hou iho la i ka pohaku maluna o ka waha o ka luawai, ma kona wahi.
\q1 
\v 4 I aku la o Iakoba ia lakou, E kuu mau hoahanau, nohea oukou? I mai la lakou, No Harana makou.
\q1 
\v 5 I aku la ia ia lakou, Ua ike anei oukou ia Labana, ka moopuna a Nahora? I mai la lakou, Ua ike no makou.
\q1 
\v 6 I aku la ia ia lakou, E ola ana anei oia? I mai la lakou, E ola ana no, aia hoi, ke hele mai la o Rahela, o kana kaikamahine me ka pua hipa.
\q1 
\v 7 I aku la ia, Aia hoi, he la okoa keia; aole i hiki ka manawa e houluulu ai i na bipi: e hoohainu oukou i na hipa, a hele e hanai.
\q1 
\v 8 I mai la lakou, Aole makou e hiki, a pau na ohana hipa i ka houluuluia, a olokaa ae lakou i ka pohaku, mai ka waha mai o ka luawai; alaila makou e hoohainu i na hipa.
\b
\q1 
\v 9 Ia ia i olelo ai me lakou, hiki mai la o Rahela me na hipa a kona makuakane: no ka mea, nana lakou i malama.
\q1 
\v 10 A ike aku la o Iakoba ia Rahela, ke kaikamahine a Labana, o ke kaikunane o kona makuwahine, a me ka poe hipa a Labana, o ke kaikunane o kona makuwahine, neenee aku la o Iakoba, olokaa ae la ia i ka pohaku mai ka waha ae o ka luawai, a hoohainu iho la i ka poe hipa a Labana, o ke kaikunane o kona makuwahine.
\q1 
\v 11 Honi aku la o Iakoba ia Rahela, hookiekie ae la ia i kona leo, a uwe iho la.
\q1 
\v 12 Hai aku la o Iakoba ia Rahela, he hoahanau ia no kona makuakane, a he keiki na Rebeka: holo aku la kela, a hai aku la i kona makuakane.
\b
\q1 
\v 13 A lohe ae la o Labana i ka olelo no Iakoba no ke keikikane a kona kaikuwahine, holo mai la ia e halawai me ia, apo mai la ia ia, honi ae la, a kai aku la ia ia i kona hale. Hai aku la oia ia Labana ia mau mea a pau.
\q1 
\v 14 Olelo mai la o Labana ia ia, He oiaio, o oe no kuu iwi, a me kuu io. A noho pu iho la oia me ia, hookahi malama.
\b
\q1 
\v 15 Olelo mai la o Labana ia Iakoba, E hookauwa wale anei oe na'u, no kou pili hoahanau ana ia'u? e hai mai oe ia'u i kau uku.
\q1 
\v 16 Elua mau kaikamahine a Labana, o Lea ka inoa o ka mua, a o Rahela ka inoa o ka muli iho.
\q1 
\v 17 He makawai ko Lea; aka, ua maikai o Rahela ke nana aku, a ua maikai kona helehelena.
\q1 
\v 18 Aloha aku la o Iakoba ia Rahela: i aku la ia, E hooikaika aku no au i kau hana i na makahiki ehiku no Rahela, no kau kaikamahine muli iho.
\q1 
\v 19 I mai la o Labana, E aho no'u ke haawi aku ia ia nau, aole na ke kanaka e ae; e noho pu oe me au.
\q1 
\v 20 Hooikaika aku la o Iakoba i na makahiki ehiku no Rahela; a he mau la uuku wale no ia i kona manao, no kona aloha ia ia.
\b
\q1 
\v 21 I aku la o Iakoba ia Labana, E haawi mai oe i ka'u wahine, i komo ai au iloko io na la, no ka mea, ua hala ae nei ko'u mau la.
\q1 
\v 22 Houluulu ae la o Labana i na kanaka a pau o ia wahi, a hana iho la i ka ahaaina,
\q1 
\v 23 A ahiahi iho la, lalau aku la ia i kana kaikamahine ia Lea, a lawe mai la ia ia io Iakoba la, a komo aku la ia io na la.
\q1 
\v 24 Haawi aku la o Labana ia Zilepa i kona kaikamahine i kauwawahine na kana kaikamahine na Lea.
\q1 
\v 25 A ao ae la, aia hoi, o Lea ka ia: i aku la o Iakoba ia Labana, Heaha keia mea au i hana mai ai ia'u? aole anei o Rahela ka'u i hooikaika aku ai nau? No ke aha hoi oe i hoopunipuni mai ai ia'u?
\q1 
\v 26 I mai la o Labana, Aole pela e pono ke hana ma ko makou aina, ke haawi e aku i ka hanau hope mamua o ka hanau mua.
\q1 
\v 27 E hoopau oe i ko ia nei hebedoma, alaila e haawi hoi makou ia Rahela nau, no ka hooikaika ana au e hooikaika ai me au, i na makahiki hou aku i ehiku.
\q1 
\v 28 Pela no o Iakoba i hana aku ai, a hoopau ae la i ko ia la hebedoma: a haawi aku la hoi oia ia Rahela i kana kaikamahine i wahine nana.
\q1 
\v 29 Haawi mai la o Labana ia Bileha i kona kaikamahine, i kauwawahine na Rahela, na kana kaikamahine.
\q1 
\v 30 Komo aku la hoi oia io Rahela la, a oi aku la kona aloha ia Rahela mamua o kona aloha ia Lea; a hooikaika aku la ia me Labana i na makahiki hou aku i ehiku.
\b
\q1 
\v 31 A ike iho la o Iehova, ua hoowahawahaia o Lea, hoohua iho la ia i kona opu: aka, ua pa o Rahela.
\q1 
\v 32 Hapai iho la o Lea, a hanau mai la he keikikane, a kapa iho la ia i kona inoa o I Reubena: no ka mea, i mai la ia, He oiaio, ua nana mai o Iehova i kuu popilikia; ano hoi, e aloha mai auanei ka'u kane ia'u.
\q1 
\v 33 Hapai hou iho la ia, a hanau mai la he keikikane; i mai la, No ka mea, ua lohe o Iehova i kuu hoowahawahaia, nolaila, ua haawi mai hoi oia i keia keikikane: kapa iho la ia i kona inoa, o I Simeona.
\q1 
\v 34 Hapai hou iho la ia, a hanau mai la, he keikikane; i mai la, I keia manawa no, e hoopiliia mai auanei ka'u kane ia'u; no ka mea, ua hanau no wau i na keikikane ekolu nana: no ia mea i kapaia'i kona inoa, o I Levi.
\q1 
\v 35 Hapai hou iho la ia, a hanau mai la he keikikane: i mai la ia, Ano no, e hoolea aku wau ia Iehova; nolaila, kapa iho la ia i kona inoa, o I Iuda; a oki iho la kona hanau ana.
\c 30
\b
\q1 
\v 1 A IKE ae la o Rahela, aole ia i hanau i na keiki na Iakoba, huahuwa aku la o Rahela i kona kaikaana; i mai la ia ia Iakoba, E haawi, mai oe i keiki na'u, o make au.
\q1 
\v 2 Hoaaia ka inaina o Iakoba ia Rahela; i aku la ia, Owau no anei ka panihakahaka no ke Akua, nana i aua mai ka hua o kou opu?
\q1 
\v 3 I mai la ia, Aia hoi kuu kauwawahine o Bileha, e komo aku oe io na la; a e hanau mai auanei ia maluna o kuu mau kuli, i keiki ai hoi au ma ona la.
\q1 
\v 4 Haawi mai la oia ia Bileha i kana kauwawahine, i wahine nana: a komo aku la o Iakoba io na la.
\q1 
\v 5 Hapai iho la o Bileha, a hanau mai la, he keikikane na Iakoba.
\q1 
\v 6 I mai la o Rahela, Ua hoapono mai ke Akua ia'u, ua hoolohe mai hoi ia i ko'u leo, a ua haawi mai ia i keiki na'u: nolaila, kapa iho la ia i kona inoa, o I Dana.
\q1 
\v 7 Hapai hou iho la o Bileha ke kauwawahine a Rahela, a hanau mai la, o ka lua ia o kana keikikane na Iakoba.
\q1 
\v 8 I mai la o Rahela, Me na hakoko nui ka'u i hakoko pu ai me kuu kaikuaana, a ua lanakila au: a kapa iho la ia i kona inoa, o I Napetali.
\b
\q1 
\v 9 A ike iho la o Lea, ua oki kona hanau ana, lalau aku la ia ia Zilepa, i kana kauwawahine, a haawi aku la ia ia i wahine na Iakoba.
\q1 
\v 10 A hanau mai la o Zilepa ke kauwawahine a Lea i keikikane na Iakoba.
\q1 
\v 11 I mai la o Lea, Pomaikai; a kapa iho la ia i kona inoa, o I Gada,
\q1 
\v 12 Hanau mai la hoi o Zilepa o ke kauwawahine a Lea i ka lua o ke keikikane na Iakoba.
\q1 
\v 13 I mai la o Lea, Pomaikai no wau, no ka mea, e hoomaikai mai auanei na kaikamahine ia'u: a kapa iho la i kona inoa o I Asera.
\b
\q1 
\v 14 Hele aku la o Reubena i na la o ka ohi palaoa ana, a loaa ia ia ma ke kula na hua dudaima, a lawe mai la ia mau mea i kona makuwahine ia Lea. Alaila, i mai la o Rahela ia Lea, Ke noi aku nei au ia oe, o haawi mai na'u i kekahi mau dudaima a kau keikikane.
\q1 
\v 15 I aku la kela ia ia, He mea uuku anei kou lawe ana aku i ka'u kane? a manao anei hoi oe o lawe aku i na dudaima a kuu keiki? I mai la o Rahela, Nolaila, e moe pu ia me oe i neia po no na dudaima a kau keiki.
\q1 
\v 16 I ke ahiahi, hoi mai la o Iakoba mai ke kula mai, a hele aku la o Lea e halawai me ia, i aku la, E komo mai oe io'u nei; no ka mea, he oiaio no, ua hoolimalima au ia oe me na dudaima a ka'u keiki. A moe pu iho la oia me ia ia po.
\q1 
\v 17 Hoolohe mai la ke Akua ia Lea a hapai iho la o Lea, a hanau mai la na Iakoba i ka lima o kana keikikane.
\q1 
\v 18 I mai la o Lea, Ua haawi mai la ke Akua i ka'u uku, no kuu haawi ana aku i ka'u kauwawahine na kuu kane: a kapa iho la ia i kona inoa o I Isakara.
\q1 
\v 19 Hapai hoa iho la o Lea, a hanau mai na Iakoba i ke ono o kana keikikane.
\q1 
\v 20 I mai la o Lea, Ua haawi mai ke Akua ia'u i ka haawina maikai; ano la, e noho pu auanei ka'u kane me a'u, no ka mea, ua hanau no au i na keikikane eono nana: a kapa iho la ia i kona inoa o I Zebuluna.
\q1 
\v 21 A mahope iho, hanau mai la ia i kaikamahine, a kapa iho la i kona inoa o I Dina.
\b
\q1 
\v 22 Hoomanao mai la ke Akua ia Rahela, a hoolohe mai la ke Akua ia ia, a hoohua mai la i kona opu.
\q1 
\v 23 Hapai iho la oia, a hanau mai la he keikikane: i mai la ia, Ua lawe aku no ke Akua i kuu hoinoia.
\q1 
\v 24 Kapa iho la ia i kona inoa o I Iosepa; i iho la, E haawi mai ke Akua i keikikane hou na'u.
\b
\q1 
\v 25 I ka manawa a Rahela i hanau ai ia Iosepa, i aku la o Iakoba ia Labana, E hoihoi aku oe ia'u, i hele aku ai au i ko'u wahi, a i ko'u aina.
\q1 
\v 26 E haawi mai oe i ka'u mau wahine, a me ka'u mau kamalii, i na mea a'u i hooikaika aku ai nau, a e kuu ae oe ia'u e hele: no ka mea, ua ike oe i ka hana au i hana aku ai nau.
\q1 
\v 27 I mai la o Labana ia ia, Ke noi aku nei au ia oe, ina i loaa ia'u ke aloha imua ou, e noho; ua ike no wau ma ka hoao ana, nou no ka Iehova i hoopomaikai mai ai ia'u.
\q1 
\v 28 I mai la hoi oia, E hai mai oe i kau uku, a e haawi aku no wau.
\q1 
\v 29 I aku la kela ia Labana, Ua ike no oe i ko'u hooikaika ana aku nau, a me ka pono o kau poe holoholona.
\q1 
\v 30 No ka mea, he mea uuku kau mamua o ko'u hiki ana mai, a hoomahuahuaia'e ia he lehulehu loa: a ua hoopomaikai mai o Iehova ia oe, mahope mai o kuu hele ana mai: ano hoi, ahea la au e hoolako ai i ko ka hale o'u kekahi?
\q1 
\v 31 I mai la oia, Heaha ka'u e uku aku ai ia oe? I aku la o Iakoba, Aole oe e uku mai ia'u i kekahi mea: ina paha penei oe e hana mai ai ia'u, alaila au e hana hou, a e malama hoi i kau poe holoholona:
\q1 
\v 32 E hele ae au iwaena o kau poe holoholona a pau i neia la, a e hookaawale aku i na holoholona kikokiko a onionio, a me na mea eleele a pau o ka poe hipa, a me na mea onionio a kikokiko o ka poe kao: a oia ka'u uku.
\q1 
\v 33 Pela e hoapono aku ai ho'u pono ia'u i ka wa mahope, i ka wa e lilo mai ai ia i uku na'u imua o kou mau maka: o na mea a pau o ka poe kao me au, aole i kikokiko, aole noi i eleele no ka poe hipa, oia ke oleloia he mea i aihueia.
\q1 
\v 34 I mai la o Labana, Aia hoi, o ko'u makemake no ia, me kau i olelo mai ai.
\q1 
\v 35 Ia la no, hookaawale ae la oia i na kao kane a pau i onionio a i kikokiko, a me na kao wahine a pau i onionio a kikokiko, me na mea kiko keokeo a pau; a me na mea eleele o na mea keikihipa, a haawi aku la iloko o ka lima o kana mau keikikane.
\q1 
\v 36 A hookaawale ae la o Labana i na la hele i ekolu mawaena ona a o Iakoba: a hanai aku la o Iakoba i na poe holoholona a Labana i koe.
\b
\q1 
\v 37 Lawe ae la o Iakoba i na laau popela maka, me na laau alemone, a me na laau pelane, a ihi iho la i na kaha onionio keokeo ma ua mau laau la, i moakaka na wahi keokeo o na mau laau la.
\q1 
\v 38 Kukulu iho la ia i na laau ana i ihi ai, imua o na holoholona, ma na pawai hooinu, i ka wa i hele ai lakou e inu, i hapai ai lakou i ka wa i hele ai lakou e inu.
\q1 
\v 39 Hapai iho la na holoholona imua o na mau laau la, a hanau mai la i na keiki onionio, kikokiko, a me ke kikohukohu.
\q1 
\v 40 Hookaawale ae la o Iakoba i na keikihipa, a haliu ae la i na maka o ka poe holoholona ma na mea onionio, a me na mea eleele o ko Labana poe holoholona; hookaawale ae la ia i kona mau poe holoholona, aole i hookokoke aku ia lakou me na holoholona a Labana.
\q1 
\v 41 I ka wa i ai ai na holoholona ikaika, alaila, waiho iho la o Iakoba i na laau imua o na maka o na holoholona maloko o na pawaiinu, i hapai ai lakou imua o na laau.
\q1 
\v 42 Aka, ina he mau holoholona nawaliwali lakou, aole ia i waiho i na laau iloko; pela no, na Labana ka poe nawaliwali, a na Iakoba ka poe ikaika.
\q1 
\v 43 A he nui loa ka waiwai o ua kanaka nei: ia ia na holoholona he nui wale, me na kauwawahine, a me na kauwakane, na kamelo, a me na hoki.
\c 31
\b
\q1 
\v 1 LOHE aku la o Iakoba i na olelo a na keikikane a Labana, i ka i ana ae, Ua lawe aku la o Iakoba i na mea a pau a ko kakou makuakane, a ua loaa ia ia keia waiwai a pau no na mea a ko kakou makuakane.
\q1 
\v 2 Nana aku la o Iakoba i ka maka o Labana, aole ia i maliu mai ia ia e like mamua.
\b
\q1 
\v 3 Olelo mai la hoi o Iehova ia Iakoba, E hoi hou aku oe i ka aina o kou poe makua, a i na hoahanau ou; a owau kekahi pu me oe.
\q1 
\v 4 Hoouna aku la o Iakoba e kahea ia Rahela laua o Lea e hele mai ma ke kula i kona poe holoholona.
\q1 
\v 5 I aku la oia ia laua, Ua ike no wau i ka maka o ko olua makuakane, aole ia i maliu mai ia'u e like mamua: aka, me au no ke Akua o ko'u makuakane.
\q1 
\v 6 Ua ike hoi olua i ko'u malama i ana i ko olua makuakane me ko'u ikaika a pau.
\q1 
\v 7 A ua hoopunipuni mai ko olua makuakane ia'u, a he umi kana hoololi ana i ka'u uku: aka, aole ke Akua i ae mai e hoopoino mai ia ia'u.
\q1 
\v 8 Ina i olelo mai kela penei, O na mea kikokiko kau uku, alaila hanau mai la na holoholona i na mea kikokiko: a i olelo mai ia penei, O na mea onionio kau uku, alaila hanau mai la na holoholona a pau i na mea onionio.
\q1 
\v 9 Pela ke Akua i lawe ai i na holoholona a ko olua makuakane, a ua haawi mai ia'u.
\q1 
\v 10 A i ka manawa a ka poe holoholona i ko ai, nana aku la ko'u mau maka ma ka moeuhane, ike aku la, aia hoi, o na kao kane i lele aku maluna o na kao wahine ua onionio, a ua kikokiko, a me ke kikohukohu.
\q1 
\v 11 Olelo mai la ka anela o ke Akua ia'u ma ka moeuhane, E Iakoba: i aku la au, Eia wau.
\q1 
\v 12 I mai la kela, E nana aku oe e ike, o na kao kane e lele ana maluna o na kao wahine, ua onionio, ua kikokiko, a me ke kikohukohu: no ka mea, ua ike no wau i ka mea a pau a Labana i hana mai ai ia oe.
\q1 
\v 13 Owau no ke Akua no Betela, kahi au i poni ai i ka pohaku kukulu, kahi hoi au i hoohiki ai i ka hoohiki ia'u: ano hoi, e ku ae oe, e haalele aku i keia aina, a e hoi hou aku i ka aina o kou poe hoahanau.
\q1 
\v 14 Olelo mai la o Rahela laua o Lea, i mai la ia ia, Auhea kekahi kuleana, a o kekahi waiwai hooili no maua ma ka hale o ko maua makuakane?
\q1 
\v 15 Aole anei i manaoia maua e ia, he mau mea e? no ka mea, ua lilo maua i ke kuaiia e ia, a ua pau loa hoi ko maua kala ia ia.
\q1 
\v 16 Nolaila, o ka waiwai a pau a ke Akua i lawe ae mai ko maua makuakane mai, no kakou ia a no na keiki a kakou: ano hoi, e hana aku oe i ka mea a ke Akua i olelo mai ai ia oe.
\b
\q1 
\v 17 Alaila, ku ae la o Iakoba, hoee aku la i kana mau keiki a me kana mau wahine maluna o na kamelo;
\q1 
\v 18 A lawe aku la ia i kana poe holoholona a pau, a me kona waiwai a pau i loaa ia ia, o na holoholona ana, i loaa ia ia ma Padanarama, e hele aku ai io Isaaka la i kona makuakane, ma ka aina o Kanaana.
\q1 
\v 19 Ua hala aku la o Labana e ako i kana poe hipa: a aihue iho la o Rahela i na kii o kona makuakane.
\q1 
\v 20 Puni aku la ka naau o Labana ka Suria, ia Iakoba, i ka hai ole aku ia ia i kona mahuka ana.
\q1 
\v 21 Pela oia i mahuka ai me kana mau mea a pau: ku ae la ia, hele mai la ma keia aoao o ka muliwai, a hele pololei mai la i ka mauna o Gileada.
\b
\q1 
\v 22 I ke kolu o ka la, olelo aku la kekahi ia Labana, Ua mahuka aku o Iakoba.
\q1 
\v 23 Kono aku la ia i kona poe hoahanau e hele pa me ia, alualu mai mahope ona i na la hele ehiku, a hiki mai la io Iakoba la ma ka mauna o Gileada.
\q1 
\v 24 Hele mai la ke Akua io Labana la ka Suria ma ka moeuhane i ka po, i mai la ia ia, E ao ia oe iho, mai olelo aku oe ia Iakoba i ka mea aloha, aole hoi ka mea hoino.
\b
\q1 
\v 25 Alaila loaa mai la o Iakoba ia Labana. Ua kukulu o Iakoba i kona halelewa ma ua mauna la: kukulu hoi o Labana me kona poe hoahanau ma ka mauna o Gileada.
\q1 
\v 26 Olelo mai la o Labana ia Iakoba, Heaha kau i hana'i i hoopunipuni mai ai oe ia'u, a i lawe aku ai hoi i ka'u mau kaikamahine, e like me na pio e ke kana?
\q1 
\v 27 No ke aha la oe i holo malu mai ai, me ka puni mai ia'u, aole hoi i hai mai ia'u, i hoihoi aku ai au ia oe me ka olioli a me na mele, me na pahukani a me na lira!
\q1 
\v 28 Aole hoi i ae mai oe ia'u e honi i ka'u mau moopuna a me na kaikamahine a'u? He lapuwale ka hana ana au i hana'i.
\q1 
\v 29 E hiki no i kuu lima ke hana aku ia oe i ke ino: aka, o ke Akua o kou makuakane i olelo mai ia'u, i ka po nei, i ka i ana, E ao oe, mai olelo aku oe ia Iakoba i ka mea aloha, aole hoi ka mea hoino.
\q1 
\v 30 Ano hoi, i ka hele ana ua hala aku la oe, no kou iini nui ana i ka hale o kou makuakane; no ke aha hoi oe i aihue ai i ko'u mau akua?
\q1 
\v 31 Olelo aku la o Iakoba ia Labana, i aku la, No ka mea, ua makau wau: i iho la au, E kaili aku paha oe i kau mau kaikamahine mai o'u aku nei.
\q1 
\v 32 A o ka mea e loaa ia oe, ia ia kou mau akua, aole ia e ola; imua o ko kana mau hoahanau e nana oe i kau maanei me au, a e lawe aku oe i ou la. No ka mea, aole i ike o Iakoba, na Rahela i aihue ia mau mea.
\b
\q1 
\v 33 Komo aku la o Labana iloko o ka halelewa o Iakoba, a iloko o ka halelewa o Lea, iloko hoi o na halelewa o na kauwawahine elua, aole i loaa. Alaila, hele aku la ia iwaho o ka halelewa o Lea, a komo aku la iloko o ka halelewa o Rahela.
\q1 
\v 34 Ua lawe aku no o Rahela i ua mau kii la, a waiho pu iho la me na noho kamelo, a noho iho la maluna. Huli iho la o Labana i ka halelewa a pau, aole nae i loaa.
\q1 
\v 35 I aku la o Rahela i kona makuakane, mai huhu mai ko'u haku i kuu hiki ole ke ku ae iluna; no ka mea, he mai wahine ko'u. Imi iho la oia, aole nae i loaa ia ia na kii.
\b
\q1 
\v 36 Ukiuki iho la o Iakoba, a ao aku la ia Labana: olelo aku la o Iakoba, i aku la ia Labana, Heaha ko'u hala? heaha hoi ko'u hewa, i alualu wela mai ai oe ia'o?
\q1 
\v 37 A ua huli iho oe i ka'u ukana a pau, a heaha kau i loaa ai o na mea a pau o kou hale? e kau mai ianei imua o ko'u mau hoahanau a me kou mau hoahanau, i hooponopono mai ai lakou iwaena o kaua.
\q1 
\v 38 He iwakalua na makahiki a'u i noho ai me oe; o kau poe hipa wahine a me kau poe kao wahine, aole lakou i hanau i ka wa, aole hoi au i ai i na hipa kane o kou poe holoholona.
\q1 
\v 39 O na mea i haehaeia, aole au i lawe aku ion la; na'u no i uku aku: nau i lawe aku ia mea mai kuu lima aku, no ka mea i aihueia i ke ao, a i aihueia i ka po.
\q1 
\v 40 Pela wau; i ke ao, ua wela au i ka la, a i ka po, ua make i ke anu: a holo aku la ka hiamoe mai o'u mau maka aku.
\q1 
\v 41 Pela wau i na makahiki he iwakalua maloko o kou hale; hooikaika au nau i na makahiki he umikumamaha no kau mau kaikamahine, a me na makahiki eono no kou poe holoholona: a he umi kau hoololi ana i ka'u uku.
\q1 
\v 42 Ina aole me au ke Akua o ko'u knpunakane, ke Akua o Aberahama, a o ka makau o Isaaka, he oiaio, ina ua hoihoi nele mai oe ia'u i neia manawa. Ua ike mai no ke Akua i ko'u popilikia, a me ka hana ana a ko u mau lima, a ua papa mai ia oe i ka po nei.
\b
\q1 
\v 43 Olelo mai la o Labana ia Iakoba, i mai la, Na'u no keia mau kaikamahine, a na'u no keia mau kamalii, a na'u no hoi keia poe holoholona, a na'u no na mea a pau au e ike nei; a heaha ka'u mea e hiki ai i keia la ke hana aku i keia mau kaikamahine a'u, a me keia mau kamalii a lakou i hanau ai?
\q1 
\v 44 Nolaila ea, e hoopaa kaua i berita, owau a o oe, i mea hoikeike mawaena o kaua.
\q1 
\v 45 Lalau aku la o Iakoba i ka pohaku, a hooku ae la ia mea i kukulu.
\q1 
\v 46 I aku la hoi o Iakoba i kona poe hoahanau, E houluulu mai oukou i na pohaku; lawe mai la lakou i na pohaku, a hana iho la i ahu; a ai iho la lakou maluna o ua ahu la.
\q1 
\v 47 Kapa iho la o Labana ia ahu, o I Iegasaduha: kapa iho ia o Iakoba ia mea, o I Galeeda.
\q1 
\v 48 Olelo mai la o Labana, He mea hoikeike keia ahu pohaku mawaena o kaua i keia la. Nolaila i kapaia'i kona inoa o Galeeda.
\q1 
\v 49 A o I Mizepa hoi; no ka mea, i mai la ia, O Iehova ke kiai mai mawaena o kaua, i ko kaua manawa e noho kaawale ana.
\q1 
\v 50 Ina oe e hoopilikia i ka'u mau kaikamahine ina hoi oe e lawe i na wahine hou, he okoa keia mau kaikamahine a'u, aohe kanaka me kaua; e ao oe, o ke Akua no ke ike maka mai mawaena o kaua.
\q1 
\v 51 I mai la o Labana ia Iakoba, E nana i keia ahu, e nana hoi i keia pohaku kukulu a'u i hoolei aku ai mawaena o kaua;
\q1 
\v 52 He mea hoikeike keia ahu, he mea hoikeike hoi keia pohaku kukulu, i hele ole aku ai au ma keia aoao o keia ahu i ou la, aole hoi oe e hele mai ma keia aoao o ua ahu nei a me keia pohaku kukulu i o'u nei, e hana ino.
\q1 
\v 53 O ke Akua o Aberahama, a o ke Akua o Nahora, ke Akua o ko laua makuakane, e hooponopono mawaena o kaua. A hoohiki aku la o Iakoba ma ka Makau o kona makuakane o Isaaka.
\q1 
\v 54 Alaila, kaumaha aku la o Iakoba i ka mohai maluna o ia mauna, a kahea aku la i kona poe hoahanau e ai i ka berena: ai iho la lakou i ka berena, a moe iho la ia po ma ka mauna.
\q1 
\v 55 I kakahiaka nui, aia ae ia o Labana, honi ae la i kana mau moopuna a me kana mau kaikamahine, a hoomaikai iho la ia lakou; hele aku la o Labana, a hoi aku la i kona wahi.
\c 32
\b
\q1 
\v 1 HELE aku la o Iakoba i kona hele ana, a halawai mai la na anela o ke Akua me ia.
\q1 
\v 2 A ike aku la o Iakoba ia lakou, i aku la ia, O ka puali kaua keia o ke Akua: a kapa iho la ia i ka inoa o ia wahi, o I Mahanaima.
\b
\q1 
\v 3 Hoouna aku la o Iakoba i na elele imua ona io Esau la i kona kaikuaana, ma ka aina o Seira, oia ka aina o Edoma.
\q1 
\v 4 Kauoha aku la ia ia lakou, i aku la, Penei ka oukou e olelo aku ai i kuu haku, ia Esau; Ke i mai nei o kau kauwa o Iakoba penei, Ua noho pu au me Labana, ua kali aku no wau ilaila a hiki i neia manawa.
\q1 
\v 5 Ia'u no na bipi, na hoki, na holoholona, me na kauwakane a me na kauwawahine; a ua hoouna aku no wau e hai aku i kuu haku, i loaa ia'u ke alohaia imua o kou maka.
\b
\q1 
\v 6 Hoi hou mai la na elele io Iakoba la, i mai la, Hele aku la makou i kou kaikuaana io Esau la; a ke hele mai nei hoi oia e halawai me oe, a me ia na haneri kanaka eha.
\q1 
\v 7 Alaila, makau nui iho la o Iakoba, a ua pilikia loa: mahele ae la oia i na kanaka me ia, i na holoholona, i na bipi a me na kamelo, elua poe;
\q1 
\v 8 I aku la, Ina e hele mai o Esau, a pepehi mai i kekahi poe, alaila e pakele ka poe i koe.
\b
\q1 
\v 9 I aku la o Iakoba, E ke Akua o kun kupunakane o Aberahama, ke Akua o kuu makuakane o Isaaka, e Iehova, ka mea nana i olelo mai ia'u, E hoi hou aku oe i kou aina, a i kou poe hoahanau, a e lokomaikai aku no au ia oe:
\q1 
\v 10 Aole au e pono no na lokomaikai a pau a me ka oiaio a pau au i hoike mai ai, i kau kauwa nei; no ka mea, me kuu kookoo iho i hele mai ai au ma keia kapa o loredane; a ua lilo no wau ano i elua poe.
\q1 
\v 11 Ke pule aku nei au ia oe, e hoopakele ae ae ia'u mai ka lima aku o kuu kaikuaana, mai ka lima o Esau: no ka mea, ke makau nei au ia ia, o hele mai nei oia e pepehi mai ia'u me ka makuwahine a me na kamalii.
\q1 
\v 12 Ua olelo mai oe, E lokomaikai io no wau ia oe, a e hoonui au i kau poe mamo e like me ke one o ke kai, aole e pau lakou i ka heluia no ka lehulehu.
\b
\q1 
\v 13 Moe iho la ia malaila ia po; lalau aku la ia i na mea i loaa i kona lima, i makana na kona kaikuaana, na Esau,
\q1 
\v 14 I elua haneri kao wahine, me na kao kane he iwakalua; elua haneri hipa wahine, me na hipa kane he iwakalua,
\q1 
\v 15 He kanakolu kamelo waiu, me ka lakou mau keiki; he kanaha bipi wahine, me na bipi kane he umi; he iwakalua hoki wahine a me na hokikeiki he umi.
\q1 
\v 16 Haawi aku la oia ia mau mea i ka lima o kana poe kauwa, a kaawale kekahi poe me kahi poe; i aku la ia i kana poe kauwa, E hele e aku oukou mamua o'u, a e hookaawale i kahi poe me kahi poe.
\q1 
\v 17 Kauoha aku la ia i ka mea i hele mamua, i aku la, A halawai mai ko'u kaikuaana o Esau me oe, a ninau mai ia oe, i ka i ana mai, Nowai oe? Mahea oe e hele nei? Nawai hoi keia poe mamua ou?
\q1 
\v 18 Alaila, e olelo aku oe, Na kau kauwa, na Iakoba lakou nei, ua hoounaia mai, i makana na ko'u haku na Esau: eia ae hoi oia mahope o makou.
\q1 
\v 19 Pela hoi oia i kauoha aku ai i ka lua a me ke kolu, a me ka poe a pau i hahai mahope o na pua holoholona, i ka i ana, Pela hoi oukou e olelo aku ai ia Esau, i ka wa e loaa'i ia oukou ia.
\q1 
\v 20 E i aku hoi oukou, Eia ae kau kauwa o Iakoba mahope o makou. No ka mea, i iho la ia, E hoolaulea aku au ia ia i ka makana e hele la mamua o'u, a mahope iho e ike aku au i kona maka; a e maliu mai paha ia ia'u.
\q1 
\v 21 Pela i hele aku ai ka makana ma kela kapa imua ona: a moe pu iho la oia ia po me ka huakai.
\b
\q1 
\v 22 Ala ae la oia ia po, lalau aku la ia i kana mau wahine elua, me kana mau kauwawahine elua, a me kana mau keiki kane he umikumamakahi, a hele aku la ma kahi papau o Iaboka ma kela kapa.
\q1 
\v 23 Lalau aku la ia ia lakou, hoouna aku la ia lakou ma kela kapa o ke kahawai, a hoouka aku la hoi i kana mau mea a pau.
\b
\q1 
\v 24 O Iakoba wale no i koe: a hakoko mai la kekahi kanaka me ia, a wehe ae la ke alaula o ke ao.
\q1 
\v 25 A ike iho la kela, aole ia i lanakila maluna ona, papai mai la ia i ka hena o kona uha, a ua kapeke ae la ka huamoa o ko Iakoba uha, i kona hakoko ana me ia.
\q1 
\v 26 I mai la kela, E kuu ae oe ia'u, no ka mea, ke wehe mai la ke alaula. I aku la oia, Aole au e kuu aku ia oe, a hoomaikai mai oe ia'u.
\q1 
\v 27 Ninau mai la kela ia ia, Owai kou inoa? I aku la oia, O Iakoba.
\q1 
\v 28 I mai la kela, Aole e hea hou ia kou inoa, o Iakoba; aka, o Iseraela: no ka mea, he ikaika kou imua o ke Akua; a e lanakila hoi oe maluna o na kanaka.
\q1 
\v 29 Ninau aku la o Iakoba, i aku la, Ke noi aku nei au ia oe, e hai mai oe ia'u i kou inoa. I mai la kela, Heaha kau i ninau mai ai i ko'u inoa? A hoomaikai mai la kela ia ia ilaila.
\q1 
\v 30 Kapa aku la o Iakoba i ka inoa o ia wahi o i Peniela: No ka mea, ua ike iho nei au i ke Akua, he maka no he maka, a ua malamaia kuu ola.
\b
\q1 
\v 31 Puka mai la ka la maluna ona i kona hele ana ae maluna o Penuela, kapeke ae la oia maluna o kona uha.
\q1 
\v 32 No ia mea, aole e ai na mamo a Iseraela i ke olona i eeke, ka mea ma ka uha, a hiki i keia la: no ka mea, papai mai la kela i ka hena o ko Iakoba uha ma ke olona i eeke.
\c 33
\b
\q1 
\v 1 NANA aku la na maka o Iakoba, ike aku la, aia hoi, ua hiki mai o Esau me na haneri kanaka eha. A puunaue aku la ia i na kamalii ia Lea, a ia Rahela, a i na kauwawahine elua.
\q1 
\v 2 Hoonoho aku la ia i na kauwawahine me na keiki a laua mamua, ia Lea hoi me kana mau keiki mahope iho, a ia Rahela me Iosepa mahope loa.
\q1 
\v 3 Hele e aku la ia mamua o lakou; kulou pahiku iho la ia ma ka honua, a hiki aku la ia i kona kaikuaana.
\q1 
\v 4 Holo mai la o Esau e halawai me ia, apo mai la ia ia, kau iho la ma kona a-i, a honi iho la ia ia: a uwe iho la laua.
\q1 
\v 5 Alawa ae la kona mau maka, ike ae i na wahine a me na kamalii; ninau mai la ia, Owai lakou nei me oe? I aku la kela, O lakou no na keiki a ke Akua i haawi lokomaikai mai ai i kau kauwa.
\q1 
\v 6 Alaila neenee mai la na kauwawahine, o laua me na keiki a laua, a kulou iho la lakou.
\q1 
\v 7 Neenee mai la hoi o Lea me kana mau keiki, a kulou iho la lakou: a mahope iho, neenee mai la o Iosepa me Rahela, a kulou iho la laua.
\q1 
\v 8 Ninau mai la kela, Heaha ia oe kela poe nui a pau i halawai me au? I aku la oia, He mea ia e loaa mai ai ke aloha o kuu haku.
\q1 
\v 9 I mai la kela, He nui no ka'u, e kuu kaikaina, ia oe no kau mea.
\q1 
\v 10 I aku la o Iakoba, Aole, ke noi aku nei au ia oe, ina i loaa ia'u ke alohaia imua on, e lawe oe i ka'u makana ma ko'u lima: no ka mea, ua ike iho nei au i kou maka, e like me kuu ike ana i ka maka o ke Akua, a ua oluolu mai oe ia'u.
\q1 
\v 11 Ke noi aku nei au ia oe, e lawe oe i ka'u hoomaikai ana i haawiia ku nau; no ka mea, ua lokomaikai mai ke Akua ia'u, a no ka mea, ua lako hoi au. Koi aku la oia ia ia, a lawe hoi kela.
\q1 
\v 12 I mai la kela, e neenee aku kakou i ko kakou hele ana, a e hele hoi au imua ou.
\q1 
\v 13 I aku la oia ia ia, Ua ike no kuu haku, he palupalu na kamalii, a me au no na hipa hapai a me na bipi hapai: ina e hoolalelaleia lakou i ka la hookahi, e pau ka ohana holoholona i ka make.
\q1 
\v 14 Ke noi aku nei au ia oe, e hele e aku kuu haku mamua o kana kauwa ma kela kapa; a na'u no e hele malie aku, e like me ka hiki ana o na holoholona a me na kamalii ke hele imua o'u, a hiki aku au i kuu haku ma Seira.
\q1 
\v 15 I mai la o Esau, E pono paha na'u e waiho me oe i kekahi poe kanaka o'u. I aku la ia, No ke aha hoi ia? ina e loaa ia'u ke alohaia imua o kuu haku.
\b
\q1 
\v 16 A hoi hou aku la o Esau ia la i kona hele ana i Seira.
\b
\q1 
\v 17 Hele aku la o Iakoba i Sukota, a kukulu ia i hale nona, a hana iho la i hale kamala no kona poe holoholona: nolaila, i kapaia'i ka inoa o ia wahi, o i Sukota.
\b
\q1 
\v 18 Hele pomaikai aku la o Iakoba i kekahi kulanakauhale o Sekema, ma ka aina o Kanaana ia ia i hoi mai ai mai Padanarama mai, a kukulu iho la ia i kona halelewa imua o ua kulanakauhale la.
\q1 
\v 19 Kuai aku la ia i kauwahi o ka aina, kahi ana i kukulu ai i kona halelewa, ma ka lima o na keiki a Hamora a ka makuakane o Sekema, i na apana kala he haneri.
\q1 
\v 20 Malaila oia i hana'i i kuahu, a kapa iho la i kona inoa, o Elelohe-Iseraela.
\c 34
\b
\q1 
\v 1 HELE aku la o Dina o ke kaikamahine a Lea i hanau ai na Iakoba, e ike i na kaikamahine o ia aina.
\q1 
\v 2 A ike mai la o Sekema o ke keiki a Hamora no ka Hivi ke alii o ua aina la ia ia, lalau aku la kela ia ia, moe iho la me ia, a hoohaumia ia ia.
\q1 
\v 3 Hoopili mai la kona naau ia Dina i ke kaikamahine a Iakoba; aloha mai la ia i ua kaikamahine la, a olelo oluolu mai la i ua kaikamahine la.
\q1 
\v 4 Olelo aku la o Sekema i kona makuakane ia Hamora, E kii aku oe i ua kaikamahine la, i wahine na'u.
\q1 
\v 5 Lohe ae la o Iakoba ua hoohaumia oia i kana kaikamahine ia Dina: aia no kana mau keikikane ma ke kula me kona poe holoholona; a noho olelo ole la o Iakoba, a hoi mai la lakou.
\b
\q1 
\v 6 Hele aku la o Hamora, ka makuakane o Sekema iwaho io Iakoba la e kamailio me ia.
\q1 
\v 7 A lohe ae la na keiki a Iakoba, hoi mai la lakou mai ke kela mai: ehaeha loa ka naau o ua poe kanaka la, a huhu loa iho la lakou, no ka mea, ua hana mai ia i ka mea kolohe i ka Iseraela, i ka moe ana me ke kaikamahine a Iakoba; ka mea pono ole ke hanaia pela.
\q1 
\v 8 Kamailio mai la o Hamora me lakou, i mai la, Ua pili ka naau o kuu keikikane i ka oukou kaikamahine: ke noi aku nei au ia oukou, e haawi mai ia ia i wahine nana.
\q1 
\v 9 E mare mai oukou me makou; e haawi mai i na kaikamahine a oukou na makou, a e lawe hoi i na kaikamahine a makou na oukou.
\q1 
\v 10 E noho pu oukou me makou: imua hoi o ko oukou alo ka aina: e noho oukou, a e kuai hoi iloko, a e hoolilo i ka aina no oukou.
\q1 
\v 11 Olelo mai la hoi o Sekema i ko Dina makuakane a me kona mau kaikunane, E lokomaikai mai oukou ia'u, a e haawi aku hoi au i ka oukou mea e olelo mai ai ia'u.
\q1 
\v 12 E hoonui loa oukou i ka'u mea e uku aku ai, a me ka makana, a e haawi aku no au e like me ka oukou e olelo mai ai: aka, e haawi mai i ke kaikamahine i wahine na'u.
\q1 
\v 13 Olelo hoopunipuni aku la na keikikane a Iakoba ia Sekema, a ia Hamora i kona makuakane, olelo lakou pela, no ka mea, ua hoohaumia oia ia Dina i ko lakou kaikuwahine.
\q1 
\v 14 Olelo aku la lakou ia laua, Aole e pono ia makou ke hana ia mea, ke haawi aku i ko makou kaikuwahine na ka mea i okipoepoe ole ia; no ka mea, he mea hoino ia no makou.
\q1 
\v 15 Penei wale no ka makou e ae aku ai ia olua, a i like auanei oukou me makou, i okipoepoeia na kane o oukou a pau;
\q1 
\v 16 Alaila makou e haawi aku ai i ka makou kaikamahine na oukou, a e lawe hoi i na kaikamahine a oukou na makou; a e noho pu me oukou, a lilo kakou i hookahi poe kanaka.
\q1 
\v 17 Aka, ke hoolohe ole oukou i ka makou, e okipoepoeia'i; alaila e lawe aku makou i ka makou kaikamahine, a e hele.
\b
\q1 
\v 18 A he oluolu ka lakou olelo ia Hamora, a me Sekema ke keiki a Hamora.
\q1 
\v 19 Aole i hoopanee aku na kanaka opiopio la i ka hana ana ia mea; no ka mea, he makemake kona i ke kaikamahine a Iakoba: a ua oi aku kona maikai imua o ko ka hale a pau o kona makuakane.
\b
\q1 
\v 20 Hele aku la o Hamora, laua o Sekema o kana keiki ma ka ipuka o ko laua kulanakauhale, a kamailio pu iho la me na kanaka o ko laua kulanakauhale, i kai ana aku,
\q1 
\v 21 Ea, ke noho malie nei keia poe kanaka me kakou; nolaila, e hoonoho kakou ia lakou ma ka aina, e piele lakou iloko; no ka mea, o ka aina, aia hoi, ua akea ia no lakou; e lawe kakou i na kaikamahine a lakou i wahine na kakou, a e haawi aku hoi kakou i na kaikamahine a kakou na lakou.
\q1 
\v 22 Penei wale no e ae mai ai ua poe kanaka la e noho me kakou, hookahi poe, i okipoepoeia na kane a pau o kakou, e like me lakou i okipoepoeia'i.
\q1 
\v 23 Aole anei e lilo na kakou ko lakou poe holoholona iki, ka lakou waiwai, a me na holoholona nui a pau a lakou? E ae wale aku no kakou ia lakou, a e noho pu auanei lakou me kakou.
\q1 
\v 24 Hoolohe aku la lakou ia Hamora a i kana keiki ia Sekema, o ka poe a pau i puka iwaho ma ka ipuka o kona kulanakauhale: a ua okipoepoeia na kane a pau, ka poe a pau i puka iwaho ma ka ipuka o kona kulanakauhale.
\b
\q1 
\v 25 A i ke kolu o ka la, ia lakou i eha ai, o na keikikane elua a Iakoba, o Simeona laua o Levi, na kaikunane o Dina, lalau aku la laua i na pahikaua a laua, hele aku la laua i ua kulanakauhale la me ka makau ole, a pepehi aku la i na kane a pau.
\q1 
\v 26 Pepehi aku la laua ia Hamora, laua o Sekema o kana keiki me ka maka o ka pahikaua, lawe aku la hoi ia Dina iwaho o ka hale o Sekema, a hele aku la iwaho.
\q1 
\v 27 Held mai la na keiki a Iakoba i ka poe i pepehiia, a lawe pio ae la i ka waiwai o ke kulanakauhale; no ka mea, ua hoohaumia lakou i ko lakou kaikuwahine.
\q1 
\v 28 Lawe pio aku la hoi lakou i na hipa a lakou, a me na bipi a lakou, a me na hoki a lakou, me ko loko o ke kulanakauhale, a me ko ke kula,
\q1 
\v 29 Me ko lakou waiwai a pau, me ka lakou kamalii a pau, a me na wahine a lakou, na pau ia lakou i ka hoopioia; a hao ae la lakou i na mea a pau o ka hale.
\b
\q1 
\v 30 Olelo aku la o Iakoba ia Simeona laua o Levi, Ua hoopilikia mai olua ia'u, i pilau aku ai au iwaena o na kanaka o ka aina nei, iwaena o ka Kanaana a me ka Perezi: a owau la e, he poe uuku ko'u, e hoakoakoa mai auanei lakou e ku e ia'u, a e pepehi mai ia'u, a e make auanei au me ko ka Hale o'u.
\q1 
\v 31 I mai la lakou, E pono anei e hana mai ia i ko makou kaikuwahine, me he wahine hookamakama la?
\c 35
\b
\q1 
\v 1 OLELO mai la ke Akua ia Iakoba, E ku ae oe, e pii aku i Betela, ilaila e noho ai: ilaila oe e hana'i i kuahu no ke Akua i ikea e oe i kou wa i mahuka ai mai ka maka o kou kaikuaana o Esau.
\q1 
\v 2 Alaila, i aku la o Iakoba i ko ka hale ona, a i ka poe a pau me ia, E haalele oukou i na akua e iwaena o oukou, e huikala ia oukou iho, a e aahu iho i na kapa hou:
\q1 
\v 3 A e ku ae kakou, e pii aku i Betela; malaila au e hana'i i kuahu no ke Akua nana au i maliu mai i ka la o ko'u popilikia, a i hele pu me au i kuu ala i hele ai.
\q1 
\v 4 Haawi mai la lakou ia Iakoba i na akua e ma ko lakou lima, a me na apo ma na pepeiao o lakou: a huna iho la o Iakoba ia mau mea malalo o ka laau oka aia ma Sekema.
\b
\q1 
\v 5 Hele aku la lakou: a kau mai la ka weliweli mai ke Akua mai maluna o na kulanakauhale ma kela aoao a keia aoao o lakou, a alualu ole mai la lakou i na keiki o Iakoba.
\b
\q1 
\v 6 A hiki aku la o Iakoba ia Luza, oia hoi o Betela, ma ka aina o Kanaana, oia a me na kanaka a pau me ia.
\q1 
\v 7 Hana iho la ia i kuahu malaila, a kapa iho la ia wahi o i Ele-betela: no ka mea, ilaila ke Akua i ikea ai e ia i kona wa i mahuka ai mai ka maka aku o kona kaikuaana.
\b
\q1 
\v 8 Make iho la o Debora o ke kahu no Rebeka, a ua kanuia oia malalo o Betela malalo o kekahi laau oka: a ua kapaia ka inoa o ia wahi, o i Alona-bakuta.
\b
\q1 
\v 9 Ikea hou ke Akua e Iakoba, i kona hoi ana mai, noloko mai o Padanarama, a hoomaikai mai la ia ia.
\q1 
\v 10 I mai la ke Akua ia ia, O Iakoba kou inoa: aole e hea hou ia kou inoa o Iakoba, aka, o Iseraela kou inoa: a kapa iho la oia i kona inoa o Iseraela.
\q1 
\v 11 I mai la ke Akua ia ia, Owau no ke Akua Mana: a e hoohua ae oe, a e mahuahua; nau mai no kekahi lahuikanaka, a me na lahuikanaka; a e puka mai auanei na alii mailoko mai o kou puhaka;
\q1 
\v 12 A o ka aina a'u i haawi aku ai no Aberahama, a no Isaaka, e haawi aku hoi au nou, a no kau poe mamo mahope ou ka'u e haawi aku ai i ka aina.
\q1 
\v 13 A pii aku la ke Akua iluna mai ona aku la, ma kahi ana i kamailio pu ai me ia.
\b
\q1 
\v 14 Hooku ae la o Iakoba i eho ma kahi ana i kamailio mai ai me ia, he eho pohaku: a ninini iho la ia i ka mohaiinu maluna; a ninini iho la hoi oia i ka aila maluna.
\q1 
\v 15 Kapa iho la o Iakoba i ka aina o kahi a ke Akua i olelo mai ai me ia, o Betela.
\b
\q1 
\v 16 Hele aku la lakou mai Betela aku, a ua kokoke e hiki i Eperata, haakohi iho la o Rahela, a puua iho i ka hanau keiki ana.
\q1 
\v 17 A i kona puua ana, i aku la ka pale keiki ia ia, Mai makau oe, e loaa auanei ia oe keia keiki no hoi.
\q1 
\v 18 A i ka wa e kaili ana kona ea, (no ka mea, make no oia,) kapa iho la ia i kona inoa, i Benoni: aka, kapa aka la kona makuakane ia ia, o Beniamina.
\q1 
\v 19 Make iho la o Rahela, a kanuia oia ma ke alanui e hele ai i Eperata, oia o Betelehema.
\q1 
\v 20 Hooku ae la o Iseraela, i pohaku eho maluna o kona he, oia ka eho no ka he o Rahela, a hiki i keia manawa.
\b
\q1 
\v 21 Hele aku la o Iseraela, a kukulu iho la i kona halelewa ma o aku o ka halekiai o Edara.
\q1 
\v 22 A i ka noho ana o Iseraela ma ia aina, hele aka la o Reubena, a moe pu iho la me Bileha me ka haiawahine a kona makuakane; a lohe ae la o Iseraela. O na keikikane a Iakoba he umikumamalua:
\q1 
\v 23 O na keikikane a Lea; o Reubena ka makahiapo a Iakoba, o Simeona, o Levi, o Iuda, o Isakara, a o Zebuluna.
\q1 
\v 24 O na keikikane a Rahela; o Iosepa, a o Beniamina.
\q1 
\v 25 O na keikikane a Bileha, a ke kauwawahine a Rahela; o Dana, a o Napetali.
\q1 
\v 26 O na keikikane a Zilepa, a ke kauwawahine a Lea; o Gada a o Asera. O lakou na keikikane a Iakoba, i hanau nana ma Padanarama.
\b
\q1 
\v 27 Hele aku la o Iakoba i kona makuakane ia Isaaka ma Mamere, ma ke kulanakauhale o Areba, (oia o Heberona,) kahi i noho ai o Aberahama a me Isaaka.
\b
\q1 
\v 28 A o na la o Isaaka, hookahi haneri makahiki a me kanawalu.
\q1 
\v 29 Kuu aku la o Isaaka i ka uhane, a make iho la, a ua huiia'ku ia me kona poe kanaka: ua elemakule ia, a nui loa kona mau la: na kana mau keikikane na Esau ma laua o Iakoba oia i kanu.
\c 36
\b
\q1 
\v 1 EIA ka mooolelo no Esau, oia o Edoma.
\b
\q1 
\v 2 Lawe ae la o Esau i kana mau wahine no na kaikamahine o Kanaana: o Ada, ke kaikamahine a Elona ka Heta, a me Aholibama ke kaikamahine a Ana, ke kaikamahine a Zibeona ka Hivi;
\q1 
\v 3 A o Basemata ke kaikamahine a Isemaela, a o ke kaikuwahine o Nebaiota.
\q1 
\v 4 Na Ada mai i hanau o Elipaza na Esau; a na Basemata i hanau o Reuela;
\q1 
\v 5 Na Aholibama i hanau o Ieusa, o Iaalama, a o Kora: o lakou na keikikane a Esau, i hanau nana ma ka aina o Kanaana.
\b
\q1 
\v 6 Lalau aku la o Esau i kana mau wahine, me kana mau keikikane, a me kana mau kaikamahine, a me na kanaka a pau o kona hale, i na holoholona liilii, a me na holoholona nui, a me kona waiwai a pau i loaa ia ia ma ka aina o Kanaana; a hele aku la ma ka aina e, mai ka maka aku o kona kaikaina o Iakoba.
\q1 
\v 7 Aole i hiki ia laua ke noho pu, no ka nui loa o ko laua waiwai; aole i pono i ka aina, kahi a laua i noho malihini ai ke malama ia laua, no na holoholona a laua.
\q1 
\v 8 A noho aku la o Esau ma mauna Seira: a o Esau, oia no o Edoma.
\b
\q1 
\v 9 Eia na hanauna o Esau, o ke kupuna no ka Edoma, ma mauna Seira.
\b
\q1 
\v 10 Eia na inoa o na keikikane a Esau, o Elipaza, ke keiki a Ada, a ka wahine na Esau; o Reuela ke keiki a Basemata a ka wahine na Esau.
\q1 
\v 11 O na keikikane a Elipaza, o Temana, o Omara, o Zepo, o Gatama, a o Kenaza.
\q1 
\v 12 A o Timena ka haiawahine na Elipaza na ke keiki a Esau; a nana mai i hanau o Amaleka na Elipaza: o lakou na keikikane a Ada, a ka wahine na Esau.
\q1 
\v 13 Eia na keikikane a Reuela; o Nahata, o Zera, o Sama, a o Miza: o lakou na keikikane a Basemata a ka wahine a Esau.
\b
\q1 
\v 14 Eia na keikikane a Aholibama, a ke kaikamahine a Ana, ke kaikamahine a Zibeona, ka wahine a Esau: a nana i hanau mai o Ieusa, o Iaalama, a o Kora na Esau.
\b
\q1 
\v 15 O lakou nei na makualii o na moopuna a Esau: o na keikikane a Elipaza a ka makahiapo na Esau, o Temana he makualii, o Omara he makualii, o Zepo he makualii, o Kenaza he makualii,
\q1 
\v 16 O Kora he makualii, o Gatama he makualii, a o Amaleka he makualii: o lakou na makualii na Elipaza ma ka aina o Edoma: o lakou hoi na keikikane a Ada.
\b
\q1 
\v 17 Eia na keikikane a Reuela a ke keikikane a Esau; o Nahata he makualii, o Zera he makualii, o Sama, he makualii, a o Miza he makualii: o lakou na makualii na Reuela, ma ka aina o Edoma: o lakou na moopuna a Basemata, a ka wahine a Esau.
\b
\q1 
\v 18 Eia na keikikane a Aholibama, a ka wahine na Esau; o Ieusa he makualii, o Iaalama he makualii, a o Kora he makualii: o lakou na makualii na Aholibama, ke kaikamahine a Ana, a ka wahine a Esau.
\q1 
\v 19 O lakou na keikikane a Esau, oia o Edoma; o lakou hoi na makualii o lakou.
\b
\q1 
\v 20 Eia na keikikane a Seira ka Hori, i noho ma ia aina; o Lotara, o Sobala, o Zibeona, o Ana,
\q1 
\v 21 O Disona, o Ezera, a o Disana: o lakou na makualii o ka Hori, o na keikikane a Seira, ma ka aina o Edoma.
\q1 
\v 22 O na keiki a Lotana, o Hori a o Hemama; a o Timena ke kaikuwahine o Lotana.
\q1 
\v 23 Eia na keikikane a Sobala: Alevana, o Manahata, o Ebala, o Sepo, a o Onama.
\q1 
\v 24 Eia na keikikane a Zibeona, o Aia, laua o Ana: oia no ua Ana la i loaa ia ia na hoki ma ka waonahele, ia ia i hanai ai i na miula o kona makuakane o Zibeona.
\q1 
\v 25 Eia na keiki a Ana; o Disona, a o Aholibama ke kaikamahine a Ana.
\q1 
\v 26 Eia na keiki a Disona; o Hemedana, o Esebana, o Iterana, a o Kerana.
\q1 
\v 27 Eia na keiki a Ezera; o Bilehana, o Zaavana, a o Akana.
\q1 
\v 28 Eia na keiki a Disana; o Uza, a o Arana.
\q1 
\v 29 Eia na makualii o ka Hori, o Lotana he makualii, o Sobala he makualii, o Zibeona he makualii, a o Ana he makualii,
\q1 
\v 30 O Disona he makualii, o Ezera he makualii, a o Disana he makualii; o lakou na makualii na ka Hori, no ko lakou poe makualii ma ka aina o Seira.
\b
\q1 
\v 31 Eia ka poe alii i noho alii ai ma ka aina o Edoma mamua o ka manawa i noho ai kekahi alii maluna o na mamo a Iseraela.
\q1 
\v 32 O Bela ke keikikane a Beora, noho alii ae la ia ma Edoma: a o Dinehaba ka inoa o kona kulanakauhale.
\q1 
\v 33 A make iho la o Bela, a noho alii ae la o Iobaba ke keikikane a Zera no Bozera ma kona hakahaka.
\q1 
\v 34 A make iho la o Iobaba, noho alii ae la o Husama, no ka aina o Temani, ma kona wahi.
\q1 
\v 35 A make iho la o Husama, o Hadada, o ke keiki a Bedada, nana i pepehi ia Midiana ma ke kula o Moaba, a noho alii ae la ia ma kona wahi: a o A vita ka inoa o kona kulanakauhale.
\q1 
\v 36 A make iho la o Hadada, noho alii ae la o Samela no Masereka ma kona wahi.
\q1 
\v 37 A make iho la o Samela, noho alii ae la o Saula no Rehobota o ka muliwai, ma kona wahi.
\q1 
\v 38 A make iho la o Saula, noho alii ae la o Baala-hanana o ke keiki a Akebora ma kona wahi.
\q1 
\v 39 A make iho la o Baala-hanana ke keiki a Akebora, noho alii ae la o Hadara ma kona wahi: o Pau ka inoa o kona kulanakauhale; a o Mehetabela ka inoa o kana wahine, oia ke kaikamahine a Matereda, ke kaikamahine a Mezahaba.
\b
\q1 
\v 40 Eia na inoa o na makualii na Esau, e like me ko lakou mau ohana, mamuli o ko lakou mau wahi, ma ko lakou mau inoa; o Timena he makualii, o Aleva he makualii, o Ieteta he makualii,
\q1 
\v 41 O Aholibama he makualii, o Ela he makualii, o Pinona he makualii,
\q1 
\v 42 O Kenaza he makualii, o Temana he makualii, o Mibezara he makualii,
\q1 
\v 43 O Magediela he makualii, a o Irama he makualii; o lakou na makualii na Edoma, e like me ko lakou mau noho ana, ma ka aina i noho ai lakou: oia o Esau ke kupuna no ko Edoma.
\c 37
\b
\q1 
\v 1 NOHO aka la o Iakoba ma ka aina a kona makuakane i noho malihini ai, ma ka aina i Kanaana.
\q1 
\v 2 Eia ka mooolelo no Iakoba. He umi ko Iosepa makahiki a me kumamahiku, e hanai ana oia i na holoholona me kona poe kaikuaana, e noho pu ana o ua keiki la me na keikikane a Bileha, a me na keikikane a Zilepa, na wahine a kona makuakane, a hai mai la o Iosepa i ka makuakane o lakou i ka lono ino o lakou.
\q1 
\v 3 Ua oi aku la ke aloha o Iseraela ia Iosepa mamua o kana mau keiki a pau, no ka mea, he keiki ia no kona wa elemakule: a hana iho la ia i kapakomo onionio nona.
\q1 
\v 4 A ike iho la kona poe kaikuaana i ke kela ana aku o ke aloha o ko lakou makuakane ia Iosepa mamua o kona poe hoahanau a pau, inaina aku la lakou ia Iosepa, aole i hiki ke olelo oluolu aku ia ia.
\b
\q1 
\v 5 Moe iho la o Iosepa i ka moe, a hai aku la i kona poe kaikuaana, a nui hou mai la ko lakou inaina ana ia ia.
\q1 
\v 6 I aku la ia ia lakou, Ea, e hoolohe mai oukou i keia moe a'u i moe ai.
\q1 
\v 7 Eia hoi, i ka pua ana a kakou i na pua, ma ka mahina ai, ala mai la ka'u pua, a kupono ae la iluna; a o ka oukou mau pua ka i ku poai mai la, a kulou iho la i ka'u pua.
\q1 
\v 8 Olelo mai la kona poe kaikuaana ia ia, E alii ana ka oe maluna o makou? O oe anei ka haku maluna o makou? Huhu nui aku la lakou ia ia i kana moe, a i kana olelo.
\b
\q1 
\v 9 A mahope aku, moe hou iho la ia i ka moe, a hai hou aku la i kona poe kaikuaana, i aku la, Eia hoi, ua moe hou iho nei au i ka moe; a ua kulou mai ia'u ka la, a me ka mahina, a me na hoku he umikumamakahi.
\q1 
\v 10 Hai aku la ia i kona makuakane, a i kona poe kaikuaana. Papa mai la kona makuakane, i mai la ia ia, Heaha keia moe au i moe ai? E hele anei au iou la, a me kou makuwahine, a me kou poe hoahanau, e kulou ilalo i ka honua imua ou?
\q1 
\v 11 Huahuwa ae la kona poe kaikuaana ia ia, a malama iho la kona makuakane i ua olelo la.
\b
\q1 
\v 12 Hele aku la kona poe kaikuaana i Sekema, e hanai i ka poe holoholona a ka makuakane o lakou.
\q1 
\v 13 Olelo aku la o Iseraela ia Iosepa, Aia paha kou poe kaikuaana e hanai holoholona ana ma Sekema? Auhea oe? E hoouna ana au ia oe io lakou la. I mai la kela ia ia, Eia no wau.
\q1 
\v 14 I aku la oia ia ia, Ea, o hele oe e ike i ka pono o kou poe kaikuaana, a me ka pono o na holoholona, a e hai mai ia'u. Hoouna aka la oia ia ia, iwaho o ke awawa o Heberona, a hiki aku la ia i Sekema.
\b
\q1 
\v 15 A loaa ia i kekahi kanaka, aia hoi, ua hele hewa ia i ke kula. Ninau mai la ua kanaka la ia ia, i mai la, Heaha kau mea e imi nei?
\q1 
\v 16 Olelo aku la ia, E imi ana au i ko'u poe kaikuaana: e hai mai oe ia'u i kahi a lakou e hanai ai i na holoholona.
\q1 
\v 17 Olelo mai la ia kanaka, Ua hala'ku la lakou: ua lohe au i ka olelo ana a lakou, E, e hele kakou i Dotana. Hahai aku la o Iosepa i kona poe kaikuaana, a loaa aku la lakou Dotana.
\b
\q1 
\v 18 A ike mai la lakou ia ia ma kahi loihi aku, aole ia i lihi koke mai, ohumu iho la lakou ia ia, e make ia.
\q1 
\v 19 Olelo ae la lakou i kekahi i kekahi, Eia'e ka mea nana na moe, ke hele mai nei.
\q1 
\v 20 Ina kakou e pepehi ia ia a make loa, e hoolei ia ia iloko o kahi lua, a e olelo aku kakou, Na ka ilio hihiu ia i ai; alaila, e ike kakou i ka hope o kana mau moe.
\q1 
\v 21 A lohe ae la o Reubena, hoola ae la oia ia ia, mai ko lakou lima ae; i ae la, Mai pepehi kakou ia ia.
\q1 
\v 22 Olelo aku la o Reubena ia lakou, Mai hookahe i ke koko; e hoolei ia ia iloko o keia hua o ka aina waonahele. Mai kau i ka lima maluna ona. Manao iho la ia e hoopakele ia ia, mai ko lakou lima ae, a e hoihoi aku ia ia i kona makuakane.
\b
\q1 
\v 23 A hiki aku la o Iosepa i kona poe kaikuaana, hao ae la lakou i ko Iosepa kapa, o ke kapa onionio maluna ona;
\q1 
\v 24 Lalau ae la lakou ia ia, hoolei aku la ia ia iloko o ka lua. Ua kaawale ka lua, aole he wai oloko.
\b
\q1 
\v 25 A noho iho la lakou e ai i ka ai. Alawa'e la ko lakou maka, ike aku la, aia hoi kekahi poe mamo a Isemaela, e hele mai ana, mai Gileada mai, me ko lakou mau kamelo, ua kaumaha i ka mea ala, a me ka bama, a me ka mura, e lawe hele ana i Aigupita.
\q1 
\v 26 Olelo aku la o Inda i kona poe hoahanau, Heaha ka maikai, ke pepehi kakou i ko kakou kaikaina, a huna i kona koko?
\q1 
\v 27 Ina kakou e kuai aku ia ia i ka Isemaela; mai kau ko kakou lima maluna ona; no ka mea, o ko kakou kaikaina no ia, a me ko kakou io. A hoolohe mai la kona poe hoahanau ia ia.
\q1 
\v 28 Hele ae la ua poe kanaka kuai la, no Midiana, huki mai la lakou, a hapai ae la ia Iosepa, mai loko mai o ka lua, a kuai aku la ia ia, i ka Isemaela, i na hapakala, he iwakalua. A lawe ae la lakou ia Iosepa i Aigupita.
\b
\q1 
\v 29 A hoi mai la o Reubena i ka lua, aia hoi, aole o Iosepa iloko o ka lua: haehae iho la ia i kona kapa.
\q1 
\v 30 A hoi aku la ia i kona poe hoahanau, i aku la, Aole loa ke keiki; a o wau, ihea la wau e hele ai?
\b
\q1 
\v 31 Lawe ae la lakou i ke kapa o Iosepa, pepehi iho la lakou i ke kao keiki, a kupenu iho la i ke kapa i ke koko.
\q1 
\v 32 Hoouka aku la lakou i ua kapa onionio la, a hiki i ko lakou makuakane; i aku la, Ua loaa mai keia ia makou: e nana oe, o ke kapa paha o kau keiki, aole paha.
\q1 
\v 33 Ike mai la kela, i mai la, Oia, o ke kapa no ia o ka'u keiki; ua pau o Iosepa i ka ilio hihiu, oiaio no, ua haehaeia o Iosepa.
\q1 
\v 34 Haehae iho la o Iseraela i kona kapa, kaei ae la i ke kapa inoino ma kona puhaka, a kanikau iho la ia i kana keiki a nui na la.
\q1 
\v 35 Ku mai la kana mau keikikane a pau, a me kana mau kaikamahine a pau, e hoonana ia ia. Hoole aku la kela, aole e na: i aku la, E kanikau no au, a hiki au ilalo i ka lua i kuu keiki la. Pela i uwe ai kona makuakane ia ia.
\q1 
\v 36 A kuai aku la ko Midiana ia ia i Aigupita, ia Potipara, he luna na Parao, oia ka luna o ka poe koa.
\c 38
\b
\q1 
\v 1 I A manawa no, iho aku la o Iuda mai kona poe hoahanau aku, a kipa aku la i kekahi kanaka no Adulama, o Hira kona inoa.
\q1 
\v 2 Ike aku la o luda i ke kaikamahine a kekahi mamo a Kanaana ilaila, o Sua kona inoa, lawe ae la oia ia ia, a komo aku la io na la.
\q1 
\v 3 Hapai iho la oia, a hanau mai la he keikikane; a kapa iho la ia i kona inoa, o Era.
\q1 
\v 4 Hapai hou iho la oia, a hanau mai la he keikikane; a kapa iho la ia i kona inoa, o Onana.
\q1 
\v 5 Hapai hou iho la oia a hanau mai la he keikikane; a kapa iho la ia i kona inoa, o Sela: ma Keziba oia i kona wa i hanau ai.
\b
\q1 
\v 6 Lawe ae la o Iuda i wahine na Era, na kana hiapo, o Tamara kona inoa.
\q1 
\v 7 A ua hewa o Era, o ka hiapo a Iuda imua o Iehova; a pepehi iho la o Iehova ia ia.
\q1 
\v 8 I aku la o Iuda ia Onana, E komo aku oe i ka wahine a kou kaikuaana, e mare me ia, a e hooku ae i keiki na kou kaikuaana.
\q1 
\v 9 Ike iho la o Onana, aole nana ke keiki, alaila, i ka manawa ana i komo aku ai i ka wahine a kona kaikuaana, kiki iho la oia i ka mea ma ka honua, o haawi auanei ia i hua na kona kaikuaana.
\q1 
\v 10 A o ka mea ana i hana'i, ua hewa ia imua o Iehova: a nana hoi ia i pepehi.
\q1 
\v 11 Alaila, i aku la o Iuda ia Tamara, E noho kane ole oe ma ka hale o kou makuakane, a ka manawa e nui ai kuu keikikane o Sela: no ka mea, i iho la ia, O make paha hoi oia, e like me kona mau kaikuaana. Hele aku la o Tamara a noho iho la ma ka hale o kona makuakane.
\b
\q1 
\v 12 A nui na la i hala, make iho la ke kaikamahine a Sua, o ka luda wahine; a pau ko Iuda kanikau ana, pii aku la ia i Timenata i kona poe ako hipa, oia a me kona makamaka o Hira no Adulama.
\q1 
\v 13 Hai aku la kekahi ia Tamara, Ea, e pii ana kou makuahunowaikane i Timenata e ako i kana hipa.
\q1 
\v 14 Wehe ae la ia i kona mau kapa makena, a uhi iho la ia ia iho i ka palemaka, aahu iho la ia ia iho, a noho iho la ma ka pukapa o Enaima ma kapa alanui e hele ai i Timenata: no ka mea, ike aku la ia, ua nui ae la o Sela, aole hoi i haawiia oia i wahine naua.
\q1 
\v 15 A ike aku la o Iuda ia ia, manao iho la ia he wahine hookamakama kela; no ka mea, ua paleia kona maka.
\q1 
\v 16 Kipa ae la ia io na la ma kapa alanui, i aku la, Ea, ke noi aku nei au ia oe, e ae mai ia'u e komo aku iou la; (no ka mea, aole ia i ike, o kana hunona wahine ia.) Ninau mai la kela, Heaha kau e haawi mai ai ia'u, i mea e komo mai ai oe i o'u nei?
\q1 
\v 17 I aku la ia, E hoouka aku au i wahi kao keiki no ka poe holoholona mai I mai la kela, Aole anei oe e haawi mai i hoailona, a hoouka mai oe ia mea?
\q1 
\v 18 I aku la oia, Heaha ka hoailona a'u e haawi aku ai ia oe? I mai la kela, O kou apolima, me kou kaula hoolewa, a me ke kookoo maloko o kou lima. Haawi aku la oia ia ia, a komo aku la io na la, a hapai iho la kela ma ona la.
\q1 
\v 19 Ku ae la ia, hele aku la, a waiho iho la i kona pale maka, a aahu hou iho la i kona mau kapa no ka noho wahine kanemake ana.
\b
\q1 
\v 20 Hoouka aku la o Iuda i ke kao keiki ma ka lima o kona makamaka no Adulama, i loaa mai ai kana hooiaio mai ka lima mai o ka wahine: aole nae i loaa ua wahine la ia ia.
\q1 
\v 21 Ninau aku la ia i na kanaka o ia wahi, i aku la, Auhea la ka wahine hookamakama i noho ma Enaima, ma kapa alanui? I mai la lakou, Aohe wahine hookamakama ia nei.
\q1 
\v 22 Hoi hou aku la ia io Iuda la i aku la, Aohe i loaa ia ia'u; a ua i mai hoi na kanaka o ia wahi, aole wahine hookamakama ia nei.
\q1 
\v 23 I aku la o Iuda, E aho no e lilo ia mau mea nona, o hoohilahilaia kaua: aia hoi, hoouka aku no au i keia kao keiki, aole ka i loaa ka wahine ia oe.
\b
\q1 
\v 24 A hala na malama ekolu paha, hai mai la kekahi ia Iuda, i ka i ana, Ua moekolohe iho nei kau hunonawahine o Tamara; aia hoi, ua hapai oia ma ka moekolohe. I aku la o Iuda, E kaiia mai oia, i puhiia'i ia i ke ahi.
\q1 
\v 25 A kaiia'ku oia, hoouna mai la ia, i mai la i kona makuahunowaikane, Na ke kanaka nana keia mau mea au i hapai ai. I mai la hoi oia, E nana oe, ea, i ike i ka mea nana keia mau mea, o ke apolima, me ke kaula hoolewa, a me ke kookoo.
\q1 
\v 26 A ike iho la o Iuda, i aku la, Ua oi aku kona pono i ko'u; no ka mea, aole au i haawi aku ia ia na kuu keiki na Sela. Aole hoi o Iuda i ike hou ia ia.
\b
\q1 
\v 27 A i ka manawa o kona haakohi ana, aia hoi, he mau mahoe maloko o kona opu.
\q1 
\v 28 A i ka hanau ana, puka mai la ka lima o kekahi; lalau aku la ka palekeiki i ua lima la a nakii iho la i ke kaula ulaula ilaila, i mai la, Eia ka hanau mua.
\q1 
\v 29 A i ka huki hou ana o kona lima iloko, aia hoi, puka e mai la kona hoahanau: i aku la ke palekeiki, Heaha kau i poha wale mai? Maluna iho ou keia nahae: nolaila, kapa iho la ia i kona inoa o Pareza.
\q1 
\v 30 Mahope iho puka mai la ke kaikaina, ia ia ke kaula ulaula ma kona lima: a ua kapaia kona inoa o Zara.
\c 39
\b
\q1 
\v 1 U A laweia'ku la o Iosepa ilalo i Aigupita; kuaiia'ku la oia no Potipara, he luna na Parao, he luna o ka poe koa, a he kanaka no Aigupita, mai na lima aku o ka Isemaela, nana ia i lawe aku ilalo.
\q1 
\v 2 Me Iosepa no o Iehova, he kanaka ia i hoopomaikaiia, aia no ia ma ka hale o kona haku, he Aigupita.
\q1 
\v 3 Ike ae la kona haku, aia no o Iehova me Iosepa, a na Iehova no i pono ai ka hana a pau a kona lima.
\q1 
\v 4 A loaa ia Iosepa ka lokomaikaiia imua ona, a hookauwa aku ia nana, a hoolilo aku la oia ia ia i luna no kona ohua, a no kona waiwai a pau, a waiho aku la ia i kana mea a pau i kona lima.
\q1 
\v 5 Eia hoi kekahi, mai ka wa mai o kona hoolilo ana ia ia i luna no kona ohua, a maluna o kona mea a pau, hoopomaikai mai ke Akua i ko ka hale o ua kanaka Aigupita nei no Iosepa; a na Iehova no ka pomaikai o na mea a pau ona, ma ka hale, a ma ke kula.
\q1 
\v 6 A waiho iho la oia i kona mea a pau i na lima o Iosepa, aole ia i ike aku i kekahi mea nona, o ka ai ana i ai ai wale no. Ua maikai ke kino o Iosepa, he maikai no hoi ka maka.
\b
\q1 
\v 7 A mahope iho o keia mau mea, ike mai la na maka o ka wahine a kona haku ia Iosepa, i mai la ia, E moe kaua.
\q1 
\v 8 Hoole aku la ia, i aku la i ka wahine a kona haku, Aia hoi, aole ike kuu haku i na mea ia'u ma keia hale, ua waiho mai nei ko'u haku i kana mea a pau i kuu lima:
\q1 
\v 9 Aohe mea nui e ae oloko o keia hale, owau wale no; aole keia i paa aku i kekahi mea ia'u, o oe wale no, no ka mea, o kana wahine no oe. Pehea la wau e hana'i i keia hewa nui, a hana ino aku i ke Akua?
\q1 
\v 10 Koi mai la oia ia Iosepa i keia la a i keia la, aole loa ia i hoolohe iki aku ia ia, e moe me ia, a e noho me ia.
\q1 
\v 11 Ia manawa iho, komo ae la o Iosepa iloko o ka hale, e hana i kana hana, aohe kanaka o ka hale iloko.
\q1 
\v 12 Apo mai la kela ia ia ma ke kapa ona, i mai la, E moe kaua. Haalele iho la ia i kona kapa ma ka lima ona, holo aku la a hiki iwaho.
\q1 
\v 13 A ike aku la ua wahine la, ua haalele ia i kona kapa ma kona lima, a ua holo aku la iwaho,
\q1 
\v 14 Kahea aku la ua wahine la i na kanaka o kona hale, olelo aku la ia lakou, i aku la, E nana oukou, ua lawe mai nei kela i ke kanaka no ka poe Hebera io kakou nei, e hoomaewaewa mai ia kakou. Hele mai la oia io'u nei e moe me au, a kahea aku la au me ka leo nui;
\q1 
\v 15 A lohe mai la kela i kuu hookiekie ana i kuu leo iluna, a i kuu hea ana aku, haalele iho nei oia i ke kapa ona ia'u, holo aku la a hiki iwaho.
\q1 
\v 16 Malama iho la ua wahine la i kona kapa, a hoi mai la kona haku i ka hale.
\q1 
\v 17 Olelo aku la ua wahine la ia ia i keia mau olelo, i aku la, O ko kauwa Hebera, au i lawe mai ai io kakou nei, ua komo mai ia io'u nei e hoomaewaewa mai ia'u.
\q1 
\v 18 A hookiekie au i kuu leo iluna a kahea aku au, alaila, haalele iho la ia i ke kapa ona ia'u, a holo aku la iwaho.
\b
\q1 
\v 19 A lohe ae la kona haku i ka olelo a kana wahine i olelo mai ni ia ia, i ka i ana mai, E like me keia mau olelo i hana mai ai kau kauwa ia'u; nui iho la ka huhu ona.
\q1 
\v 20 Lalau mai la ka haku o Iosepa ia in, hahao aku la ia ia iloko o ka halepaahao, i kahi i paa ai ka poe paa o ke alii, a paa no ia maluila ma ka halepaahao.
\b
\q1 
\v 21 Me Iosepa no o Iehova, aloha nui mai la ia ia, a haawi mai la ia ia i ka pono imua o na maka o ka mea nana i malama ka halepaahao.
\q1 
\v 22 Waiho ae la ka mea nana i malama ka halepaahao i ka poe paa a pau oloko o ka halepaahao i ka lima o Iosepa, a o na mea a pau i hanaia malaila, nana no ia i hana.
\q1 
\v 23 Aole hoi i nana aku ka luna o ka halepaahao i kekahi mea malalo iho o kona lima, no ka mea, aia no o Iehova me ia, a hoopomaikai mai la o Iehova i ka hana a pau ana i hana'i.
\c 40
\b
\q1 
\v 1 A MAHOPE iho o keia mau mea, hewa ka mea lawe kiaha, a me ka mea kahuai o ke alii o Aigupita, i ko laua haku, i ke alii o Aigupita.
\q1 
\v 2 Huhu aku la Parao i kana mau luna elua, i ka luna lawe kiaha, a me ka luna kahuai.
\q1 
\v 3 A hahao aku la oia ia laua iloko o kahi paa o ka hale o ka luna koa, ma ka halepaahao i kahi o Iosepa i paa ai.
\q1 
\v 4 Kauoha aku la ka luna koa ia Iosepa no laua, nana e malama mai laua, a nui na la a laua i paa ai.
\b
\q1 
\v 5 Moe iho la laua a elua i ka moe, i ka po hookahi ko laua moe ana, ma ka oiaio ke ano o ko laua moe, o ka mea lawe kiaha, a me ka mea kahuai o ke alii o Aigupita, o na mea i paa ma ka halepaahao.
\q1 
\v 6 A ao ae la, hele aku la o Iosepa io laua la, nana aku la ia laua, aia hoi, ua kaumaha iho la laua.
\q1 
\v 7 Ninau aku la ia i ua mau luna la me ia, ana i malama'i ma kahi paa o ka hale o kona haku, i aku la, No ke aha la i inoino ai na maka o olua i keia la?
\q1 
\v 8 I aku la laua ia ia, Ua moe maua i ka moe, aohe mea nana e hai mai ke ano o ia mea. I aku la o Iosepa ia laua, Aole anei na ke Akua ke ano oiaio? e hoike mai olua ia'u.
\b
\q1 
\v 9 Hai aku la ka luna lawe kiaha i kana moe ia Iosepa, i aku la ia ia, O kuu moe, aia hoi, he kumu waina imua o'u.
\q1 
\v 10 Ekolu manamana o ke kumu waina; me he mea opuu mai la ia, a mohala mai la ka pua; a hua mai la ka hua waina pala.
\q1 
\v 11 Ma kuu lima ke kiaha o Parao, a lawe ae la au i na hua waina, kowi iho la ia lakou iloko o ke kiaha o Parao, a haawi aku la au i ke kiaha i ko Parao lima.
\q1 
\v 12 Olelo aku la o Iosepa ia ia, Eia ke ano oiaio o ia mea: o na manamana ekolu, ekolu ia la.
\q1 
\v 13 I na la ekolu, e hookiekie ae o Parao i kou poo iluna, a e hoihoi aku ia oe i kou wahi mamua, alaila, e haawi aku oe i ke kiaha o Parao iloko o kona lima, e like me kau hana'na mamua, i ka wa ia oe ka lawe kiaha.
\q1 
\v 14 A pomaikai oe, ea, e hoomanao mai oe ia'u, alaila, ke noi aku nei au, e hana lokomaikai mai oe ia'u. E hai aku oe ia'u ia Parao, e laweia'ku hoi au iwaho o keia hale.
\q1 
\v 15 No ka mea, ua aihue io ia mai au, noloko mai o ka aina o ka poe Hebera; ia nei hoi, aole au i hana i mea i hahaoia'i e lakou iloko o ka lua.
\b
\q1 
\v 16 A ike mai la ka luna kahuai, ua hoike mai kela i ke ano ma ka maikai, olelo mai la oia ia Iosepa, He moe no hoi ka'u, aia hoi, he mau hinai palaoa keokeo ekolu iluna o kuu poo.
\q1 
\v 17 A iloko o ka hinai maluna iho, o na mea ai a pau i kahuia na Parao. Ai mai la na manu ia mau mea noloko mai o ka hinai maluna o kuu poo.
\q1 
\v 18 Olelo aku la Iosepa, i aku la, Eia ke ano o ia mea. O na hinai ekolu, ekolu ia la.
\q1 
\v 19 I na la ekolu, e hookiekie aku o Parao i kou poo mai ou aku, a e kaawe aku hoi ia oe iluna o ka laau; a e ai mai na manu i kou io.
\b
\q1 
\v 20 A i ke kolu o ka la, i ka la o Parao i hanau ai, hana iho la ia i ka ahaaina na na kauwa ana a pau: hookiekie ae la ia i ke poo o ka luna lawe kiaha a me ka luna kahuai, mawaena o na kauwa ana.
\q1 
\v 21 Hoihoi aku la ia i ka luna lawe kiaha i kona lawe kiaha ana; a haawi aku la ia i ke kiaha i ko Parao lima.
\q1 
\v 22 Kau aku la ia i ka luna kahuai iluna, e like me ka Iosepa hai ana mai ia laua.
\q1 
\v 23 Aole hoi i hoomanao mai ka luna lawe kiaha ia Iosepa, aka, hoopoina iho la ia ia.
\c 41
\b
\q1 
\v 1 MAHOPE o na makahiki elua, moe iho la o Parao, aia hoi, ku iho la ia ma kapa o ka muliwai.
\q1 
\v 2 Aia hoi, hoea mai la, mai loko mai o ka muliwai, ehiku bipi maikai, kaha ke kino, ai iho la lakou ma kahi weuweu.
\q1 
\v 3 Hoea hou mai la, mahope mai o lakou, mai loko mai o ka muliwai, ehiku bipi inoino, a olala ke kino, a ku pu mai la lakou me kela mau bipi, ma kapa o ka muliwai.
\q1 
\v 4 Ai iho la na bipi ehiku inoino a olala ke kino, i na bipi maikai a kaha ke kino; a hikilele mai o Parao.
\q1 
\v 5 Hiamoe hou iho la ia, a loaa ka moe, aia hoi, hua mai la na opuu palaoa ehiku i ke kumu hookahi, he ohaha a he maikai.
\q1 
\v 6 Aia hoi, hua hou mai la mahope mai o lakou, na opuu hou ehiku, he wiwi, a mae i ka makani mai ka hikina mai.
\q1 
\v 7 Ai iho la na opuu wiwi ehiku i na opuu ehiku i ohaha a nui. A hikilele mai la o Parao, aia hoi, he moe nana.
\q1 
\v 8 A ao ae la anoninoni iho la kona naau; hoouna aku la ia e kii i na kilo a pau o Aigupita, a me na kanaka naauao a pau o ia wahi; a hai aku la o Parao ia lakou i kana mau moe; aohe mea nana i hoakaka mai i ke ano o ua mau moe nei a Parao.
\b
\q1 
\v 9 Alaila olelo aku la ka luna lawe kiaha ia Parao, i aku la, Ke hoomanao nei au i keia la i kuu hewa.
\q1 
\v 10 Mamua, huhu mai o Parao i kana mau kauwa, a hahao aku la ia maua me ka luna kahuai iloko o ka halepaahao, i kahi o ka luna koa.
\q1 
\v 11 I ka po hookahi no, moe iho la maua i ka moe, owau a me kela, e like me ka hoike ana mai i ka moe ana i moe ai.
\q1 
\v 12 Ilaila kekahi kanaka opiopio me maua, he Hebera, he kauwa ia na ka luna koa; hai aku la maua ia ia, a hai mai la kela ia maua i ke ano o ka maua mau moe. He oiaio ke ano ana i hoike mai ai ia maua.
\q1 
\v 13 E like me kana i hoike mai ai, oiaio no ia. Hoihoiia mai au i ko'u wahi, a kaaweia kela.
\b
\q1 
\v 14 Alaila hoouna aku la o Parao, e kii ia Iosepa: hoolalelale ae la lakou ia ia, mai kahi paa mai; kahi ae la oia i ka umiumi, komo iho la ia i ke kapa hou, a hele aku la io Parao la.
\q1 
\v 15 Olelo mai la o Parao ia Iosepa, Ua moe au i ka moe, aohe mea nana e hoakaka mai ke ano, ua lohe au nou, aia lohe oe i ka moe, e hiki ia oe ke hai i ke ano.
\q1 
\v 16 Olelo aku la o Iosepa ia Parao, i aku la, Aole na'u ia, na ke Akua no e hai lokomaikai mai ia Parao.
\b
\q1 
\v 17 I aku la o Parao ia Iosepa, Ma kuu moe ana, ku aku la au ma kapa o ka muliwai.
\q1 
\v 18 Aia hoi, hoea mai la, mai loko mai o ka muliwai, ehiku bipi kaha a maikai ke nana aku, a ai iho la ma kahi weuweu.
\q1 
\v 19 Aia hoi, hoea hou mai la, mahope mai o lakou na bipi ehiku he wiwi, a inoino loa ke nana aku, olala ke kino, aole i ikeia ka mea e like me lakou ma ka aina a pau o Aigupita, no ka ino.
\q1 
\v 20 Ai iho la na bipi wiwi a olala, i na bipi kaha ehiku i hoea mua mai ai.
\q1 
\v 21 A komo iho la lakou iloko o ko lakou opu, aole hoi i ikeia ko lakou komo ana iloko o ka opu, no ka mea, ua mau no ko lakou ino, e like mamua. A hikilele ae la au.
\q1 
\v 22 A ike aku la au ma kuu moe, aia hoi, ehiku opuu palaoa ma ke kumu hookahi, he ohaha a he maikai.
\q1 
\v 23 Aia hoi, kupu hou mai la mahope mai o lakou, ehiku opuu hou, he mimino, he wiwi, a mae i ka makani mai ka hikina mai.
\q1 
\v 24 Pau ae la na opuu ohaha maikai ehiku i na opuu wiwi. A hai aku la au i ka poe akamai, aohe mea nana i hoakaka mai.
\b
\q1 
\v 25 Olelo aku la o Iosepa ia Parao, O ka moe a Parao, hookahi no ia; ua hoike mai ke Akua ia Parao i kana mea e hana mai ana.
\q1 
\v 26 O ua mau bipi maikai la ehiku, ehiku ia makahiki; a o ua mau opuu palaoa maikai la ehiku, ehiku ia makahiki; hookahi no ia moe.
\q1 
\v 27 A o ua mau bipi wiwi inoino la ehiku, i ea mai ai mahope o lakou, ehiku ia makahiki; a o na opuu palaoa wiwi a mae i ka makani no ka hikina mai, ehiku makahiki ia o ke kau wi.
\q1 
\v 28 Eia no ka'u mea i hai aku ai ia Parao: ua hoike mai ke Akua ia Parao i kana mea e hana mai ana.
\q1 
\v 29 Aia hoi, e hiki mai ana na makahiki ehiku, he mau makahiki ai nui ma ka aina a pau o Aigupita.
\q1 
\v 30 A mahope iho o lakou, e hiki mai auanei na makahiki ehiku e wi ai, a e poinaia auanei ke ola a pau, ma ka aina i Aigupita, e oki loa ka aina i ka wi.
\q1 
\v 31 Aole e ikeia ke ola ma ka aina, no ka wi e hiki ana mahope, no ka mea, e kaumaha loa ia.
\q1 
\v 32 Ua papaluaia ka moe a Parao, no ka mea, ua paa ia manao o ke Akua, a ua kokoke e hana io mai no ke Akua.
\q1 
\v 33 No keia mea, pono e imi o Parao i kekahi kanaka naauao a me ke akamai, a e hoonoho ia ia maluna o ka aina o Aigupita a pau loa.
\q1 
\v 34 E pono ia Parao e hoomakaukau, a e hoonoho i poe luna no ka aina, a e ohi lakou i ka hapalima o ka ai ma ka aina o Aigupita, ia mau makahiki momona ehiku:
\q1 
\v 35 A e hoiliili mai lakou i ka ai a pau o na makahiki maikai e hiki mai ana, a e hoahu mai i palaoa malalo o ka lima o Parao, a e malama hoi lakou i ka ai iloko o na kulanakauhale.
\q1 
\v 36 He ai malama ia no ka aina, no na makahiki wi ehiku, e hiki mai ana ma ka aina o Aigupita, i make ole ai ka aina i ka wi.
\b
\q1 
\v 37 Ua maikai ia mea i ka maka o Parao, a i ka maka o kana mau kauwa a pau.
\q1 
\v 38 Olelo ae la o Parao i kana mau kauwa, E loaa anei ia kakou kekahi kanaka e like me ia nei, ke kanaka iloko ona ka Uhane o ke Akua?
\q1 
\v 39 A olelo aku la o Parao ia Iosepa, No ka mea, ua hoike mai ke Akua ia mea a pau ia oe, aohe mea e ae e like me oe, ka naauao a me ke akamai.
\q1 
\v 40 O oe no maluna o ko'u hale, a ma kau olelo e hoolohe ai ko'u kanaka a pau, aka, o ka nohoalii wale no ka'u maluna ou.
\q1 
\v 41 Olelo aku la o Parao ia Iosepa, E nana oe, ua hoonoho au ia oe maluna o ka aina o Aigupita a pau.
\q1 
\v 42 Unuhi aku la Parao i ke komo ona, mai kona lima aku, a hookomo aku la i ka lima o Iosepa, a kahiko ae la oia ia ia i ka lole keokeo maikai, a hoolei aku la i ka lei gula ma kona a-i.
\q1 
\v 43 Hooholoholo iho la oia ia ia ma ka lua o ke kaa ona, hea mai la lakou imua ona, E kukuli iho. Hoonoho aku la oia ia ia maluna o ka aina a pau o Aigupita.
\q1 
\v 44 I aku la o Parao ia Iosepa, Owau no o Parao. A i ole oe e ae aku, aole loa e hapai kekahi kanaka i kona lima, a me kona wawae, ma ka aina a pau o Aigupita.
\q1 
\v 45 Kapa aku la o Parao i ka inoa o Iosepa, o Sapenapanea; a haawi aku la oia ia Asenata, i ke kaikamahine a Potipera a ke kahuna o Ona, i wahine nana. A hele aku la o Iosepa a puni ka aina o Aigupita.
\b
\q1 
\v 46 He kanakolu ko Iosepa mau makahiki, i ka wa ana i ku ai imua o Parao o ke alii o Aigupita. A hoi aku la o Iosepa mai ke alo aku o Parao, a hele aku la i ka aina o Aigupita a pau.
\q1 
\v 47 A i na makahiki ai ehiku, hua mai la ka hua o ka honua a nui loa.
\q1 
\v 48 Hoiliili mai la ia i ka ai a pau o na makahiki ehiku ma ka aina o Aigupita, a waiho iho la ia i ka ai maloko o na kulanakauhale, o ka ai o na mahinaai e pili ana i ua kulanakauhale la; waiho iho la ia maloko olaila.
\q1 
\v 49 Hoiliili mai la o Iosepa i ka palaoa e like me ke one o ke kai ka nui loa, a oki iho la ka helu no ka hiki ole ke helu aku.
\b
\q1 
\v 50 A hanau iho la ka Iosepa mau keikikane elua, mamua o ka hiki ana o na makahiki wi, na Asenata, ke kaikamahine a Potipera a ke kahuna o Ona i hanau nana.
\q1 
\v 51 Kapa aku la o Iosepa i ka inoa o ka hiapo, o Manase, no ka mea, ua haawi mai ke Akua ia'u i ka hoopoina i ko'u luhi, a me na mea a pau o ka hale o ko'u makuakane.
\q1 
\v 52 A o ka inoa o ka muli mai, kapa aku la ia, o Eperaima: No ka mea, ua hoopalahalaha mai ke Akua ia'u, ma ka aina o ko'u popilikia.
\b
\q1 
\v 53 Pau ae la na makahiki momona ehiku i hiki mai ai ma ka aina o Aigupita.
\q1 
\v 54 Alaila, hiki mai la na makahiki wi ehiku, e like me ka Iosepa i olelo mai ai. He wi no ma na aina a pau, aka, he ai ma na aina a pau i Aigupita.
\q1 
\v 55 Oki loa iho la ka aina a pau i Aigupita, i ka wi, a uwe aku la na kanaka ia Parao i ka ai. Olelo aku la o Parao i na kanaka a pau o Aigupita, O hele aku io Iosepa la; a i kana olelo ana mai ia oukou, malaila aku oukou.
\q1 
\v 56 A ua puni i ka wi na aina a pau; a wehe ae la o Iosepa i na halepapaa a pau, a kuai aku la na na kanaka o Aigupita; a ikaika nui mai la ka wi ma ka aina o Aigupita.
\q1 
\v 57 A hele mai la ko na aina a pau i Aigupita io Iosepa la e kuai: no ka mea, ua nui loa ka wi ma na aina a pau.
\c 42
\b
\q1 
\v 1 A IKE ae la o Iakoba, he ai ma Aigupita, olelo aku la o Iakoba i kana poe keikikane, O ke aha ka oukou e nana aku nei, kekahi i kekahi?
\q1 
\v 2 Olelo aku la ia, Aia hoi, ua lohe au, ho ai ma Aigupita, E iho aku oukou ilaila, e kuai i ai na kakou, i ola kakou, aole e make.
\b
\q1 
\v 3 Hele aku la ka poe kaikuaana o Iosepa he umi ilalo i Aigupita e kuai i ai.
\q1 
\v 4 A o Beniamina, ke kaikaina o Iosepa, aole o Iakoba i hoouna aku ia ia me kona poe kaikunana, no ka mea, i olelo iho la ia, O poino kela.
\q1 
\v 5 Hele pu ae la na keiki a Iseraela iwaena o ka poe hele, e kuai i ai, no ka mea, ua wi loa ka aina o Kanaana.
\q1 
\v 6 O Iosepa no ke kiaaina olaila, a nana no i kuai na na kanaka a pau o ia aina. Hele mai la ka poe kaikuaana o Iosepa, a kulou iho la lakou imua ona, me na maka i ka honua.
\q1 
\v 7 A nana aku la o Iosepa i kona poe kaikuaana, ike ae la oia ia lakou, a hoohuahualau aku oia ia lakou, olelo koikoi aku la oia ia lakou, i aku la ia lakou, Nohea mai oukou? Olelo mai la lakou, No ka aina o Kanaana mai, e kuai i ai.
\b
\q1 
\v 8 Ua ike no o Iosepa i kona poe kaikuaana, aole nae lakou i ike ia ia.
\q1 
\v 9 Hoomanao iho la o Iosepa i na moe ana i moe ai no lakou, i aku la oia ia lakou, He poe kiu oukou; ua hele mai oukou e nana i ka hemahema o ka aina.
\q1 
\v 10 Olelo mai la lakou ia ia, Aole ia, e kuu haku. I hele mai kau poe kauwa e kuai i ai.
\q1 
\v 11 He poe keiki makou a pau na ke kanaka hookahi; he poe kanaka pono, aole he poe kin makou o kau poe kauwa.
\q1 
\v 12 Olelo aku la ia ia lakou, Aole, ua hele mai nei oukou e nana i ka hemahema o ka aina.
\q1 
\v 13 Olelo mai la lakou, O kau poe kauwa, he umi makou a me kumamalua o ko makou hanauna, na keiki a ke kanaka hookahi i ka aina o Kanaana, aia hoi ka muli loa i keia la me ka makuakane o makou, a o kekahi hoi, aole ia.
\q1 
\v 14 Olelo aku la o Iosepa ia lakou, Oia hoi ka'u i olelo aku nei ia oukou, he poe kiu oukou.
\q1 
\v 15 I keia mea e ikea ai oukou, ma ke ola o Parao, aole oukou e hoi aku, ke hiki ole mai ko oukou kaikaina.
\q1 
\v 16 E hoouna ae i kekahi o oukou e kii i ko oukou kaikaina, a e paa oukou, i ikea ka oukou olelo a me ka pono io o oukou, aka, i ole, ma ke ola o Parao, he poe kiu io no oukou.
\q1 
\v 17 A hoakoakoa mai la oia ia lakou a pau iloko o kahi paa, a ekolu la.
\b
\q1 
\v 18 A i ka po akolu, olelo aku la o Iosepa ia lakou, E hana oukou i keia, i ola oukou; ua makau wau i ke Akua.
\q1 
\v 19 Ina he poe kanaka pono oukou, e paaia kekahi o oukou i ka halepaahao: e hoi aku oukou e halihali i ai na ka wi o ko oukou mau hale:
\q1 
\v 20 A e lawe mai i ko oukou kaikaina io'u nei, pela e oiaio ai ka oukou olelo, alaila, aole oukou e make. Hana mai la lakou pela.
\b
\q1 
\v 21 Olelo ae la lakou kekahi i kekahi, Ua hewa io kakou i ko kakou kaikaina, no ka mea, ua ike kakou i ka ehaeha o kona naau, i ka manawa ana i noi mai ai ia kakou, aole kakou i hoolohe aku; no ia mea, ua hiki mai keia popilikia io kakou nei.
\q1 
\v 22 A olelo aku la o Reubena ia lakou, i aku la, Aole anei au i olelo aku ia oukou, i ka i ana aku, Mai hana hewa aku i ke keiki? Aole oukou i hoolohe mai. Aia hoi, no ia mea, ua imiia mai ko ia la koko.
\q1 
\v 23 Aole i ike lakou ua lohe pono o Iosepa ia lakou, no ka mea, ua olelo aku oia ia lakou, ma ke kanaka hoohalike olelo.
\q1 
\v 24 Haliu aku la ia, mai o lakou la, a uwe iho la; haliu hou mai la oia ia lakou, kamailio pu me lakou, a lawe mai la oia ia Simeona, mai o lakou mai la, a hana paa iho la ia ia mamua o ko lakou mau maka.
\b
\q1 
\v 25 Alaila, kauoha aku la o Iosepa, e uhao i ka ai i na eke a lakou a piha, a e hoihoi i ka moni a lakou iloko o ka lakou mau eke, a e haawi aku i o na lakou no ke alanui. Pela oia i hana aku ai ia lakou.
\q1 
\v 26 Hooili ae la lakou i ka ai iluna iho o ko lakou mau hoki, a hele aku la.
\q1 
\v 27 A i ka wehe ana o kekahi i kana eke, e haawi aku i ai na kona hoki, ma kahi oioina, ike ae la ia i kana moni, no ka mea, aia hoi ia ma ka waha o kana eke.
\q1 
\v 28 A olelo aku la ia i kona poe hoahanau, E, ua hoihoiia mai ka'u moni; eia hoi ia iloko o ka'u eke. Hikilele iho la ko lakou naau, haalulu iho la lakou, i aku la kekahi i kekahi, Heaha keia mea a ke Akua i hana mai ai ia kakou?
\b
\q1 
\v 29 A hiki lakou io Iakoba la, i ko lakou makuakane i ka aina o Kanaana, hai aku la lakou ia ia i na mea a pau i loaa'i ia lakou; i aku la,
\q1 
\v 30 O ke kanaka, ka haku o ka aina i olelo koikoi mai ai ia makou; ua kuhi mai kela ia makou, he poe kiu no ka aina.
\q1 
\v 31 A olelo aku la makou ia ia, He poe pono makou; aohe makou he kiu.
\q1 
\v 32 He poe hanauna makou, he umi a me kumamalua, na keiki a ko makou makuakane; aole kekahi, a o ka muli loa, aia no ia i keia la me ko makou makuakane, i ka aina o Kanaana.
\q1 
\v 33 A o ke kanaka, ka haku o ka aina, olelo mai la ia makou, I keia mea e ikeia'i he poe kanaka pono oukou, E waiho mai oukou i kekahi hoahanau o oukou me au, a e lawe i ai na ka wi o ko oukou mau hale, a e hoi aku:
\q1 
\v 34 A e lawe mai oukou i ko oukou kaikaina io'u nei; alaila, ike au ia oukou, aohe kiu, he poe kanaka maikai no oukou; a e kuu aku au ia oukou i ko oukou hoahanau, a e kuai oukou iloko o keia aina.
\b
\q1 
\v 35 A i ka ninini ana aku a lakou i ka lakou mau eke, aia hoi, iloko o na eke a lakou, ka lakou mau laulau moni a pau. A ike ae la lakou a me ko lakou makuakane i na laulau moni, makau nui iho la lakou.
\q1 
\v 36 A olelo mai la o Iakoba ko lakou makuakane ia lakou, Ua hoonele mai oukou ia'u i ka'u mau keiki. O Iosepa, aole ia, a o Simeona, aole ia, a e lawe aku ana oukou ia Beniamina. Ke pale mai nei keia mau mea a pau ia'u.
\q1 
\v 37 Olelo aku la o Reubena i kona makuakane, i aku la, E pepehi mai oe i ka'u mau keiki elua, ke hoihoi ole mai au ia ia nei iou la; e haawi mai oe ia ia nei i kuu lima, na'u ia e hoihoi hou mai iou la.
\q1 
\v 38 Olelo mai la ia, Aole e iho aku ka'u keiki me oukou ilaila, no ka mea, ua make kona kaikuaana, oia nei wale no koe: ina poino keia, ma ke alanui a oukou e hele ai, alaila, lawe iho oukou i ko'u oho hina i ka lua me ke kaniuhu.
\c 43
\b
\q1 
\v 1 A OKI loa iho la ka aina i ka wi.
\q1 
\v 2 A pau i ka aiia e lakou ka ai a lakou i lawe mai ai, mai Aigupita mai, olelo mai la ko lakou makuakane ia lakou, O hele hou oukou, e kuai i wahi ai iki na kakou.
\q1 
\v 3 A olelo aku la o Iuda ia ia, i aku la, Ua olelo ikaika mai ua kanaka la ia makou, ua i mai, Aole oukou e ike i kuu maka, ke hele ole mai ko oukou kaikaina me oukou.
\q1 
\v 4 A i hoouna oe i ko makou kaikaina me makou, alaila, hele aku makou ilalo, e kuai i ai nau.
\q1 
\v 5 Aka, i hoouna ole oe ia ia, aole makou e hele aku ilalo, no ka mea, ua olelo mai ua kanaka la ia makou, Aole oukou e ike i kuu maka, ke hele ole mai ko oukou kaikaina me oukou.
\q1 
\v 6 Olelo mai la o Iseraela, No ke aha la onkou i hana ino mai ai ia'u, i ka hai aku i ua kanaka la i ko oukou kaikaina?
\q1 
\v 7 Olelo aku la lakou, I ninau ikaika mai no ua kanaka la ia makou, i ko makou hoahanau, i mai la, Ke ola la no anei ko oukou makuakane? He kaikaina e anei, ko oukou? A hai aku la makou ia ia ma ke ano o keia mau olelo. Ua ike pono anei makou, e i mai ana ia, E lawe mai ilalo nei i ko oukou kaikaina?
\q1 
\v 8 Olelo aku la o Iuda ia Iseraela i kona makuakane, E kuu mai oe i ke keiki me au, alaila ku ae makou e hele aku; i ola kakou; aole e make o makou, a o oe, a me ka kakou poe kamalii.
\q1 
\v 9 Owau no ka panai nona; ma ko'u lima, e imi mai oe ia ia; i hoihoi ole mai au ia ia iou la, a e hoonoho ia ia mamua ou, no'u mau loa aku no ka hewa.
\q1 
\v 10 Ina aole makou i hookaulua, ina ua hoi hou mai makou, mai ka lua o ka hele ana.
\b
\q1 
\v 11 Olelo aku la ko lakou makuakane o Iseraela ia lakou, Ina pela mai, e hana i keia; e ahu i ko ka aina hua maikai iloko o ka oukou mau eke, a e lawe aku ilalo i makana na ua kanaka la; i wahi bama iki, a i wahi meli iki, a i mea ala kahi, a me ka mura, a i hua pisetakia, a i alemona.
\q1 
\v 12 A e papalua i na kala ma ko oukou lima; a o ke kala i hoihoiia mai, maloko o ka waha o ka oukou mau eke, e halihali hou aku oukou ia mea, i ko oukou mau lima; malia paha, aole i ikeia.
\q1 
\v 13 E lawe aku hoi oukou i ko oukou kaikaina, a e ku nui iluna, e hele hou aku i ua kanaka la.
\q1 
\v 14 A na ke Akua mana loa e haawi mai ke aloha no oukou mamua o ua kanaka la, i kuu mai ia i kela hoahanau o oukou, a ia Beniamina hoi A i nele au i kuu mau keiki, ua nele au.
\b
\q1 
\v 15 Lawe ae la na kanaka i ua makana la, a lawe papalua no hoi lakou i ke kala ma ko lakou lima, a ia Beniamina hoi; ku ae la lakou, a hele aku la ilalo i Aigupita, a ku aku la imua o Iosepa.
\b
\q1 
\v 16 A ike mai la o Iosepa ia Beniamina me lakou, olelo ae la ia i ka luna o kona hale, E alakai oe i keia poe kanaka i ka hale, e kalua i holoholona, a e hoomakaukau hoi; no ka mea, e ai pu keia poe kanaka me au i ke awakea.
\q1 
\v 17 Hana mai la ke kanaka e like me ka Iosepa olelo ana ae; a alakai aku la ia i ua poe kanaka la, iloko o ka hale o Iosepa.
\q1 
\v 18 Makau iho la ua poe kanaka la, no ka mea, ua alakaiia'ku la lakou iloko o ka hale o Iosepa, a olelo ae la lakou, No ka moni i hoihoiia'i iloko o ka kakou mau eke i ka manawa mamua, nolaila kakou i alakaiia mai ai iloko nei, i hoolawehala mai oia ia kakou a lele mai iluna o kakou, a e hana paa hoi ia kakou, i poe kauwa, a me ko kakou mau hoki.
\q1 
\v 19 Hookokoke aku la lakou i ka luna o ko Iosepa hale, a kamailio pu lakou me ia ma ka puka o ka hale;
\q1 
\v 20 I aku la lakou, E kuu haku e, i ko makou hele ana mai mamua, ua hele mai makou e kuai i ai.
\q1 
\v 21 A hiki aku la makou i kahi oioina, wehe ae la makou i ka makou mau eke, aia hoi ka moni a pau a makou iloko o ka waha o na eke a makou. A ua halihali hou mai makou ia mea ma ko makou mau lima.
\q1 
\v 22 A ua halihali mai no hoi makou ilalo nei i na moni e ae ma ko makou mau lima e kuai i ai; aole ike makou i ka mea nana i waiho ka moni a makou iloko o ka makou mau eke.
\q1 
\v 23 Olelo mai la kela, Aloha oukou, mai makau; na ko oukou Akua, ke Akua o ko oukou makuakane, nana i haawi ka waiwai na oukou iloko o ka oukou mau eke: ua hiki mai ka oukou moni ia'u. Alakai mai la oia ia Simeona io lakou la.
\q1 
\v 24 Alakai ae la ua kanaka la i ka poe kanaka iloko o ko Iosepa hale, a haawi mai la ia lakou i ka wai, holoi iho la lakou i ko lakou mau wawae, a haawi mai la hoi ia i ai na na hoki o lakou.
\q1 
\v 25 Hoomakaukau iho la lakou i ka makana i ka hele ana mai o Iosepa i ke awakea; no ka mea, ua lohe lakou, e ai ana lakou i ka ai ilaila.
\b
\q1 
\v 26 A hoi mai la o Iosepa i kona hale, halihali mai la lakou iloko o ka hale i ka makana nana, na ko lakou lima i paa ai, a kulou iho la lakou imua ona ilalo i ka honua.
\q1 
\v 27 Ninau mai la ia ia lakou i ko lakou noho ana, i aku la, Pehea ko oukou makuakane, o ka elemakule a oukou i olelo mai ai? Ke ola la no ia, ea?
\q1 
\v 28 Olelo aku la lakou, E noho pomaikai ana no kau kauwa, ka makuakane o makou, ke ola la no ia. A kulou iho la lakou a moe ilalo.
\q1 
\v 29 Alawa ae la kona maka iluna, ike mai la i kona kaikaina ia Beniamina, ke keiki a kona makuwahine ponoi, a i mai la ia, O ko oukou kaikaina anei keia, a oukou i olelo mai ai ia'u? A olelo ae la hoi ia, E aloha mai ke Akua ia oe, e kuu keiki.
\q1 
\v 30 Wikiwiki ae la o Iosepa; no ka mea, ua mokumokuahua kona manawa i kona kaikaina, imi ae la ia i kahi e uwe ai; komo ae la ia i kona keena maluna, a uwe iho la ilaila.
\q1 
\v 31 Holoi ae la ia i kona maka, hele aku la iwaho, a uumi iho la ia i kona aloha, a olelo aku la, E ho mai i ka ai.
\q1 
\v 32 Kau mai la lakou nana ma ke kaawale, a na lakou ma ke kaawale, a na ko Aigupita i ai pu me ia ma ke kaawale; no ka mea, aole e hiki i ko Aigupita, ke ai pu me na Hebera, he mea haumia ia i ko Aigupita.
\q1 
\v 33 Noho iho la lakou imua ona, o ka hiapo e like me kona hanau mua ana, a o ka muli loa e like me kona hanau muli ana mai. Kahaha iho la ko lakou naau kekahi i kekahi.
\q1 
\v 34 Lalau ae la ia i ka ai a haawi aku la ia lakou, mai kona alo aku, ua palimaia ka Beniamina i ka lakou. Inu pu lakou a olioli me ia.
\c 44
\b
\q1 
\v 1 A KAUOHA aku la ia i ka luna o kona hale, i aku la, E uhao i ka ai iloko o na eke a ua mau kanaka la a piha, a e waiho i ka moni a lakou a pau maloko o ka waha o ka lakou mau eke.
\q1 
\v 2 A e uhao hoi i kuu kiaha, i ke kiaha kala maloko o ka waha o ka eke a ka mea opiopio loa, a me kana moni no ka ai. Hana mai la kela ma ka olelo a Iosepa i olelo aku ai.
\q1 
\v 3 A ao ae la, ua hoihoiia'ku la ua poe kanaka la, a me ko lakou mau hoki.
\q1 
\v 4 A puka aku la lakou mawaho o ke kulanakauhale, aole i hiki i kahi loihi, alaila olelo aku la o Iosepa i kana luna, E ku oe, e alualu aku i ua poe kanaka la, a loaa lakou ia oe, e i aku ia lakou, No ke aha oukou i hoihoi mai ai i ka hewa no ka pono?
\q1 
\v 5 Aole anei keia o ka mea a ka'u haku i inu ai iloko? a i kilo ai hoi? Ua hewa oukou i ka hana ana pela.
\b
\q1 
\v 6 A hiki aku la ia io lakou la, olelo aku la ia ia lakou i keia mau olelo.
\q1 
\v 7 Ninau mai la lakou ia ia, No ke aha la i olelo mai ai kuu haku i keia olelo? Aole loa e hiki i kou poe kauwa ke hana e like me ia.
\q1 
\v 8 Eia hoi, o ka moni a makou i loaa'i iloko o ka waha o ka makou mau eke, ua halihali hou mai makou ia nei ia oe mai loko mai o ka aina o Kanaana, Pehea hoi makou i aihue ai i ke kala, a i ke gula, noloko mai o ka hale o kou haku?
\q1 
\v 9 A i ikeia ia mea i kekahi o kou poe kauwa, e make ia, a e lilo makou i poe kauwa na kou haku.
\q1 
\v 10 Olelo aku la ia, Ae, e like me ka oukou olelo, pela no ia: o ka mea ua loaa me ke kiaha, e lilo ia i kauwa na'u, a e hala ole oukou.
\q1 
\v 11 Kuu koke iho la lakou a pau i ka lakou mau eke ilalo i ka honua, a wehe ae la lakou i ka lakou mau eke.
\q1 
\v 12 A imi iho la kela, a hoomaka iho la ma ka hiapo, a oki ae la ma ka muli loa, a loaa mai la ke kiaha ma ka eke a Beniamina.
\q1 
\v 13 Alaila haehae iho la lakou i ko lakou mau kapa, a kau aku la kela kanaka keia kanaka i ka ukana ma kana hoki, a hoi aku la i ke kulanakauhale.
\b
\q1 
\v 14 A hele aku la o Iuda a me kona poe hoahanau i ka hale o Iosepa, aia no ia; a moe iho la lakou imua ona ilalo i ka honua.
\q1 
\v 15 Ninau aku la o Iosepa ia lakou, Heaha keia mea a oukou i hana mai nei? Aole anei oukou i ike, e hiki i ke kanaka me a'u nei e kilokilo aku?
\q1 
\v 16 Olelo aku la o Iuda, Pehea la makou e pane aku ai ia oe, e kuu haku? Heaha ka makou e olelo aku ai? Pehea makou e hoapono ai ia makou iho? Ua loaa i ke Akua ka hewa o kau poe kauwa; eia hoi, he poe kauwa makou na ko'u haku. o makou, a me ka mea i loaa ke kiaha ma koua lima.
\q1 
\v 17 Olelo mai la o Iosepa, Aole loa e hiki ia'u ke hana pela; aka, o ke kanaka, i loaa'i ke kiaha i kona lima, e lilo ia i kauwa na'u: a o oukou, e hoi aku me ka maluhia i ko oukou makuakane.
\b
\q1 
\v 18 Alaila neenee aku la o Iuda io na la, i aku la, Auwe, e kuu haku e! Ina e ae mai kuu haku i kana kauwa nei, ke hai aku i kekahi olelo ma kona pepeiao, aole hoi e wela mai kou huhu i kau kauwa, no ka mea, ua like oe me Parao.
\q1 
\v 19 Ninau mai la kuu haku i kau poe kauwa nei, i mai la, He makuakane anei ko oukou, a he kaikaina anei?
\q1 
\v 20 A olelo aku la makou i kuu haku, He makuakane no ko makou, he kanaka kahiko, a me kahi keiki o kona wa elemakule, he mea nuku; a o kona kaikuaana, ua make ia, oia wale no ka i koe a kona makuwahine, a ua aloha kona makuakane ia ia.
\q1 
\v 21 A olelo mai la oe i kau poe kauwa, E lawe mai ia ia ilalo io'u nei, i ike aku kuu maka ia ia.
\q1 
\v 22 Alaila olelo aku la makou ia oe i kuu haku, Aole e hiki i ke keiki ke haalele i kona makuakane; no ka mea, ina e haalele ke keiki i kona makuakane, e make no ia.
\q1 
\v 23 A olelo mai la oe i kau poe kauwa, A i hele ole mai ko oukou kaikaina me oukou, aole oukou e ike hou mai i kuu maka.
\q1 
\v 24 A hiki aku la makou i kau kauwa i ko'u makuakane, hai aku la makou ia ia i ka olelo a kuu haku.
\q1 
\v 25 A olelo mai la ko makou makuakane, O hele hou oukou e kuai i wahi ai iki na kakou.
\q1 
\v 26 Olelo aku makou, Aole loa makou e hiki ke hele ilalo; aka, i hele pu ko makou kaikaina me makou, alaila e hele aku makou ilalo, no ka mea, aole e hiki ia makou ke ike aku i ka maka o ua kanaka la, ke hele pu ole ko makou kaikaina me makou.
\q1 
\v 27 Alaila olelo mai la kau kauwa o ko'u makuakane ia makou, Ua ike oukou, ua hanau mai la ka'u wahine i na keiki elua na'u.
\q1 
\v 28 A hele aku la kekahi mai o'u aku nei, a i aku la au, He oiaio no ua weluwelu ia; aole hoi au i ike hou aku ia ia.
\q1 
\v 29 A i lawe aku oukou ia ia nei, mai o'u aku nei, a loohia ia i ka poino, alaila, e lawe aku oukou i ko'u oho hina ilalo i ka lua me ke kaniuhu.
\q1 
\v 30 No keia mea hoi, ke hiki aku au i kau kauwa i ko'u makuakane, aole ke keiki me makou, ua pai pu ia kona ola me ke ola o ke Keiki;
\q1 
\v 31 A ike mai ia, aole ke keiki me makou, alaila, e make ia; a e lawe iho o kau poe kauwa i ke oho hina o kau kauwa o ko makou makuakane ilalo i ka lua me ke kaniuhu.
\q1 
\v 32 No ka mea, ua hoohiki au ia'u iho no ke keiki i ko'u makuakane, ua i aku au, A i hoihoi ole mai au ia ia iou la, no'u mau loa aku no ka hewa imua o ko'u makuakane.
\q1 
\v 33 No keia mea hoi, e ae mai oe ia'u i noho au, kau kauwa i panai no ke keiki, i kanwa na kuu haku; e hoi aku hoi ke keiki me kona poe kaikuaana.
\q1 
\v 34 No ka mea, pehea la au e hoi aku ai i kuu makuakane, aole ke keiki me au? o ike auanei au i ka mea ino e hiki mai ana maluna o kuu makuakane.
\c 45
\b
\q1 
\v 1 A LAILA aole e hiki ia Iosepa ke uumi iho i ke aloha iloko ona imua o lakou a pau, o ka poe i ku pu mai la me ia: a hea aku la ia, E hele aku na kanaka a pau iwaho, mai o'u aku nei. Aole i noho mai kekahi kanaka me ia, i ka manawa a Iosepa i hoike ai ia ia iho i kona poe hoahanau.
\q1 
\v 2 Hooho ae la ia i kona leo me ka uwe nui ana: a lohe ae la na kanaka o Aigupita a lohe pu no ko ka hale o Parao.
\q1 
\v 3 Olelo aku la o Iosepa i kona poe hoahanau, Owau no o Iosepa; ke ola la no anei ko'u makuakane? Aole i hiki ke ekemu iki mai kona poe hoahanau ia ia: no ka mea, makau nui iho lakou imua ona.
\q1 
\v 4 A olelo aku la o Iosepa i kona poe hoahanau, E neenee mai oukou io'u nei. A neenee mai la lakou. Olelo aku la ia, Owau no o Iosepa, ko oukou kaikaina a oukou i kuai ai iloko o Aigupita.
\q1 
\v 5 Eia hoi, mai hookaumaha oukou, aole hoi e huhu oukou ia oukou iho i ka oukou kuai ana ia'u ia nei. No ka mea, na ke Akua au i hoouna mai mamua o oukou e hoola aku.
\q1 
\v 6 No ka mea, ua wi ae nei ka aina i keia mau makahiki elua; a elima hoi makahiki e koe, aole e mahi, aole hoi e ohi mai.
\q1 
\v 7 A ua hoouna mai ke Akua ia'u mamua o oukou, e hookoe aku ia oukou ma ka honua, a e hoola ia oukou i ke ola nui.
\q1 
\v 8 Aia hoi, aole na oukou i hoouna mai au ia nei, na ke Akua no, a ua hoolilo ae ia ia'u i makuakane no Parao, a i haku no kona hale a pau, a i kiaaina no Aigupita a pau.
\q1 
\v 9 E wikiwiki oukou, e hoi aku i ko'u makuakane, a e i aku ia ia, Penei i olelo mai ai kau keiki o Iosepa, Ua hoolilo mai ke Akua ia'u, i haku no ka aina o Aigupita a pau; e hele mai oe ilalo io'u nei, mai hookaulua aku oe.
\q1 
\v 10 A e noho oe ma ka aina o Gosena, a e kokoke mai oe me au, o oe, a me kau poe keiki, a me kau poe moopuna, a o kau poe hipa a me kau poe holoholona a me kou mea a pau loa.
\q1 
\v 11 Ilaila au e malama'i ia oe: no ka mea, elima makahiki wi a koe; o ilihune oe, a me ko ka hale ou, a me kau mau mea a pau.
\q1 
\v 12 Aia hoi, ua ike ko oukou mau maka, a me ka maka o ko'u kaikaina, o Beniamina, o ko'u waha no ka i olelo aku ia oukou.
\q1 
\v 13 A e hai aku oukou i ko'u makuakane i kuu hanohano a pau ma Aigupita nei, a i na mea a pau a oukou i ike ai: a e wikiwiki oukou e lawe mai i ko'u makuakane ilalo.
\q1 
\v 14 Kau iho la ia ma ka a-i o kona kaikaina, o Beniamina, a uwe iho la; a uwe iho la hoi o Beniamina ma kona a-i.
\q1 
\v 15 Honi aku la o Iosepa i kona poe hoahanau a pau, a uwe iho la iluna o lakou. A mahope iho o ia mea, kamailio pu kona poe hoahanau me ia.
\b
\q1 
\v 16 Lohea iho la keia mea ma ka hale o Parao, oleloia iho la, Ua hiki mai na hoahanau o Iosepa. Ua pono hoi ia i na maka o Parao, a i na maka o kana poe kauwa.
\q1 
\v 17 Olelo mai la o Parao ia Iosepa, E i aku oe i kou poe hoahanau, E hana peneia, e kau i ko oukou mea ma na hoki a hoi aku a hiki i ka aina o Kanaana.
\q1 
\v 18 E kii i ko oukou makuakane, a me na mea o ko oukou hale, a e hele mai io'u nei, a na'u no e haawi aku na oukou i ka maikai o ka aina o Aigupita, a e ai hoi oukou i ka momona o ka aina.
\q1 
\v 19 Ua kauohaia oe, e hana hoi i keia, E lawe i mau kaa no oukou, mai ka aina o Aigupita aku, no ka oukou kamalii a no ka oukou wahine, a e kii i ko oukou makuakane, a e hele mai.
\q1 
\v 20 Mai aua ko oukou mau maka ma ko oukou mea a pau; no ka mea, no oukou ka maikai o ka aina a pau ma Aigupita.
\b
\q1 
\v 21 A hana iho la na keiki a Iseraela pela; a haawi aku la o Iosepa ia lakou i mau kaa e like me ka olelo a Parao, a haawi no hoi i o na lakou ma ke ala.
\q1 
\v 22 Haawi aku la hoi ia i kapa komo no lakou a pau; a ia Beniamina, haawi aku la oia ia ia, i ekolu haneri moni, a me na kapa komo elima.
\q1 
\v 23 A hoouna aku la ia no kona makuakane, he umi na hoki e lawe ana i na mea maikai o Aigupita, a he umi na hoki wahine, e lawe ana i ka palaoa a me ka ai i o na kona makuakane ma ke alanui.
\q1 
\v 24 Pela hoi i hoouna aku ai oia i kona poe hoahanau, a hoi aku la lakou. Olelo aku ia ia lakou, Mai paio oukou ma ke alanui.
\b
\q1 
\v 25 A hoi aku la lakou, mai waho mai o Aigupita, a hiki aku la i ka aina o Kanaana, ia Iakoba, i ko lakou makuakane.
\q1 
\v 26 A hai aku la lakou ia ia, i aku la, E, ke ola la no o Iosepa, oia ke kiaaina o ka aina o Aigupita a pau. A maule iho la ko Iakoba naau, no ka mea, aole kela i manaoio i ka.
\q1 
\v 27 Alaila, hai aku la lakou ia ia i ka olelo a pau a Iosepa i olelo mai ai ia lakou. A ike aku la ia i na kaa a Iosepa i hoouna mai ai e lawe ia ia, pohala iho la ka naau o ko lakou makuakane.
\q1 
\v 28 A olelo aku la Iseraela, Ua nui ia, na ola o Iosepa kuu keiki; e hele aku au e ike ia ia mamua o kuu make ana.
\c 46
\b
\q1 
\v 1 HELE mai la o Iseraela me kana mau mea a pau loa, a hiki mai la i Beereseba, a mohai aku la ia i na mohai i ke Akua o kona makuakane o Isaaka.
\q1 
\v 2 Olelo mai la ke Akua ia Iseraela ma ka hihio i ka po, i mai la, E Iakoba, e Iakoba. I aku la keia, Eia no wau.
\q1 
\v 3 I mai la kela, Owau no ke Akua, o ke Akua o kou makuakane: mai makau oe ke iho ilalo i Aigupita; no ka mea, e hoolilo au ia oe i lahuikanaka nui malaila.
\q1 
\v 4 A e iho pu aku no au me oe i Aigupita; e oiaio no hoi, e lawe hou mai au ia oe malaila mai, a e kau no o Iosepa i kona lima ma kou mau maka.
\q1 
\v 5 Ala mai la o Iakoba mai Beereseba mai, a lawe ae la na keiki a Iseraela ia Iakoba, ko lakou makuakane, a me na kamalii, a me ka lakou mau wahine maluna o na kaa a Parao i hoouna aku ai e lawe ia lakou.
\q1 
\v 6 Lawe ae la lakou i ka lakou mau holoholona, a me ka waiwai a lakou i loaa ai ma ka aina ma Kanaana, a hele mai i Aigupita; o Iakoba, lakou pu me na keiki ana a pau:
\q1 
\v 7 O kana mau keikikane, a me ka lakou mau keikikane me ia, o kana mau kaikamahine, a me na kaikamahine a kana mau keikikane, a me kana mau hua a pau kana i lawe pu mai ai me ia i Aigupita.
\b
\q1 
\v 8 Eia na inoa o na keikikane a Iseraela i hele i Aigupita; o Iakoba a me kana mau keikikane: o Reubena, ka Iakoba makahiapo.
\q1 
\v 9 A o na keikikane a Reubena; o Hanoka, o Palu, o Hezerona, a o Karemi.
\b
\q1 
\v 10 O na keikikane a Simeona; o Iemuela, o Iamina, o Ohada, o Iakina, o Zohara, a o Saula, ke keiki a kekahi wahine no Kanaana.
\b
\q1 
\v 11 O na keikikane a Levi; o Geresona, o Kohata, a o Merari.
\b
\q1 
\v 12 O na keikikane a Iuda; o Era, o Onana, o Sela, o Pareza, a o Zara: aka, make iho la o Era laua o Onana ma ka aina o Kanaana. A o na keikikane a Pareza; o Hezerona a o Hamula.
\b
\q1 
\v 13 O na keikikane a Isakara; o Tola, o Puva, o Ioba a o Simerona.
\b
\q1 
\v 14 O na keikikane a Zebuluna; o Sereda, o Elona a o Iahelela.
\q1 
\v 15 O lakou na keikikane a Lea, ana i hanau ai na Iakoba ma Padanarama, a me kana kaikamahine o Dina: o kana poe keikikane a pau a me na kaikamahine, he kanakolukumamakolu o lakou.
\b
\q1 
\v 16 O na keikikane a Gada; o Zipiona, o Hagi, o Suni, o Ezebona, o Eri, o Arodi, a o Areli.
\b
\q1 
\v 17 O na keikikane a Asera; o Iimena, o Isua, o Isui, o Beria, a o Sera ko lakou kaikuwahine: a o na keikikane a Beria; o Hebera, a o Malekiela,
\q1 
\v 18 O lakou na keikikane a Zilepa, a Labana i haawi aku ai i kana kaikamahine ia Lea: a o lakou kana i hanau ai na Iakoba, he poe umikumamaono.
\q1 
\v 19 O na keikikane a Rahela a ka wahine na Iakoba: o Iosepa, a o Beniamina.
\b
\q1 
\v 20 A ua hanau na Iosepa ma ka aina o Aigupita, o Manase a o Eperaima, a Asenata a ke kaikamahine na Potipera ke kahuna no Ona, i hanau ai nana.
\b
\q1 
\v 21 A o na keikikane a Beniamina; o Bela, o Bekera, o Asebela, o Gera, o Naamana, o Ehi, o Rosa, o Mupima, o Hupima, a o Areda.
\q1 
\v 22 O lakou na keiki a Rahela i hanau na Iakoba: a o lakou a pau, he umikumamaha.
\b
\q1 
\v 23 O na keikikane a Dana; o na Husima.
\b
\q1 
\v 24 O na keiki a Napetali; o Iahezela, o Guni, o Iezera, a o Silema.
\q1 
\v 25 O lakou na keikikane a Bileha, a Labana i haawi aku ai na Rahela na kana kaikamahine; a hanau mai la oia ia laua na Iakoba: a o lakou a pau, ehiku lakou.
\q1 
\v 26 O na kanaka a pau i hele pu me Iakoba i Aigupita, o ka poe mai loko mai o kona puhaka; kanaono lakou, a me kumamaono, aole hoi i heluia na wahine a kana mau keiki.
\q1 
\v 27 A o na keiki a Iosepa, i hanauia nana ma Aigupita, elua laua. O na kanaka a pau ma ka hale o Iakoba i hele mai i Aigupita, kanahiku lakou.
\b
\q1 
\v 28 A hoouna aku la oia ia Iuda, mamua ona io Iosepa la, e kuhiknhi aku mamua ona i Gosena; a hiki mai la lakou i ka aina o Gosena.
\q1 
\v 29 A hoomakaukau ae la o Iosepa i ke kaa ona, pii aku la ia e halawai me Iseraela, me kona makuakane i Gosena, a ike aku la oia ia ia, kau iho la ia ma kona a-i, a uwe iho la ma kona a-i, a liuliu wale.
\q1 
\v 30 Olelo aku la o Iseraela ia Iosepa, Ano, e pono ia'u ka make, no kuu ike ana i kou maka, no ka mea, e ola ana oe.
\q1 
\v 31 Olelo aku la o Iosepa i kona poe hoahanau a me ka poe o kona makuakane, E, e pii aku au, e hoakaka aku ia Parao, a e hai aku au ia ia; O ko'u poe hoahanau, a me ka poe o ko'u makuakane i noho ai i ka aina o Kanaana, ua hele mai io'u nei:
\q1 
\v 32 He poe kanaka malama hipa lakou, he poe kanaka hanai holoholona, a ua hele mai lakou me ka lakou hipa, a me ka lakou holoholona, a me ka lakou mea a pau.
\q1 
\v 33 A hiki i ka wa e hea mai ai o Parao ia oukou, a e ninau mai, Heaha ka oukou oihana?
\q1 
\v 34 Alaila, e olelo aku, He poe kanaka hanai holoholona kau mau kauwa nei, mai ka wa kamalii mai, o makou, a me ko makou poe makua: i noho ai oukou ma ka aina, ma Gosena, no ka mea, he haumia i ko Aigupita, na kahuhipa a pau.
\c 47
\b
\q1 
\v 1 HELE ae la o Iosepa, hai aku la ia Parao, i aku la, Ua hiki mai nei ko'u makuakane a me ko'u poe hanauna, a me ka lakou hipa, a me ka lakou holoholona, a me ka lakou mea a pau, mai ka aina mai o Kanaana, aia hoi lakou ma ka aina, i Gosena.
\q1 
\v 2 Lawe ae la ia i elima o kona poe hanauna, hoonoho iho la ia lakou imua o Parao.
\q1 
\v 3 Olelo mai la o Parao i na hoahanau o Iosepa, Heaha ka oukou oihana? I mai la lakou ia Parao, He poe kahuhipa kau poe kauwa nei, o makou a me ko makou poe makua.
\q1 
\v 4 I hou mai la lakou ia Parao, Ua hele mai nei makou e noho ma keia aina, no ka mea, aole ai na ka poe holoholona a kau poe kauwa, no ka nui o ka wi ma ka aina o Kanaana. No ia mea, ke noi aku nei makou ia oe, e noho makou ma ka aina i Gosena.
\q1 
\v 5 A olelo mai la o Parao ia Iosepa, i mai la, Ua hiki mai iou la kou makuakane a me na hoahanau ou.
\q1 
\v 6 O ka aina o Aigupita, eia no ia imua ou: i ka aina maikai nui, e hoonoho ai oe i kou makuakane a me na hoahanau ou: e noho iho lakou i ka aina o Gosena. A ina i ike oe i na kanaka akamai o lakou, e hoonoho oe ia lakou i mau kahu no ka'u poe holoholona,
\q1 
\v 7 Alakai mai la o Iosepa ia Iakoba i kona makuakane, a hoonoho mai la ia ia imua o Parao. Hoomaikai aku la o Iakoba ia Parao.
\q1 
\v 8 Ninau mai la o Parao ia Iakoba, Ehia la na makahiki o kou ola ana?
\q1 
\v 9 I aku la o Iakoba ia Parao, O na la o ko'u mau makahiki i noho malihini ai, hookahi ia haneri makahiki a me kanakolu. He hapa a he ino hoi na la o ko'u mau makahiki e ola nei; aole nae i loaa ia'u na la a me na makahiki o ko'u poe kupuna i ko lakou noho malihini ana.
\q1 
\v 10 Hoomaikai aku la o Iakoba ia Parao, a hele aku la mai ke alo aku o Parao.
\b
\q1 
\v 11 Hoonoho iho la o Iosepa i kona makuakane a me kona poe hoahanau, a haawi aku la oia ia lakou i wahi e noho ai ma ka aina o Aigupita, i kahi aina maikai, i ka aina o Ramese, e like me ke kanoha ana mai a Parao.
\q1 
\v 12 Malama aku la o Iosepa i kona makuakane, a me kona poe hoahanau, a me ka ohana a kona makuakane a pau i ka ai, e like me na waha o ka ohana.
\b
\q1 
\v 13 Aole ai ma ka aina a pau, no ka mea, ua hanahana loa ka wi. Oki loa iho la ka aina o Aigupita a me ka aina o Kanaana i ka wi.
\q1 
\v 14 Hooiliili iho la o Iosepa i ke kala a pau loa ma ka aina o Aigupita, a ma ka aina o Kanaana, no ka ai a lakou i kuai ai; a lawe mai la o Iosepa i ke kala iloko o ka hale o Parao.
\q1 
\v 15 Pau iho la ko kala ma ka aina o Aigupita, a ma ka aina o Kanaana, a hele mai la ko Aigupita a pau io Iosepa la, i mai la, Ho mai i ai na makou, no ke aha la makou e make ai imua o kou alo i ka pau ana o ke kala?
\q1 
\v 16 I mai la Iosepa ia lakou, Ina i pau ke kala, ho mai i ka oukou holoholona, a e haawi aku au i ai na oukou no ka oukou holoholona.
\q1 
\v 17 Lawe mai la lakou i ka lakou holoholona ia Iosepa, a haawi aku la o Iosepa i ai na iakou, no na lio, a no na hipa, a no na bipi, a no na hoki, a malama aku la oia ia lakou i ka ai ia makahiki, no ka lakou holoholona.
\q1 
\v 18 A pau ae la ia makahiki, hele mai la lakou ia ia, i ka lua o na makahiki, i mai la ia ia, Aole makou e huna mai ko makou haku aku, i ka pau ana o ko makou kala, a me ka makou holoholona ia oe i ko makou haku. Aohe mea i koe imua ou, o ko makou kino, a me ko makou aina wale no.
\q1 
\v 19 No ke aha la makou e make ai imua o kou mau maka, o makou a me ko makou aina! E kuai oe ia makou a me ko makou aina, no ka ai, a lilo makou a me ko makou aina i kauwa na Parao. E haawi mai hoi i hua, i ola makou, sole hoi e make, i ole ai e neoneo ka aina.
\b
\q1 
\v 20 Kuai iho la o Iosepa i ka aina a pau i Aigupita no Parao, no ka mea, kuai aku la na kanaka a pau o Aigupita i ko lakou aina, no ka mea, ua hauahana loa ka wi maluna o lakou, a lilo ae la ka aina no Parao.
\q1 
\v 21 A lawe ae la ia i kanaka o kekahi kihi, a hoonoho ia lakou ma na kulanakauhale ma kela kihi o ka aina.
\q1 
\v 22 O ka aina o na kahuna, aole ia i kuai, no ka mea, na Parao mai, ka na kahuna, a ai iho la lakou i ka mea a Parao i haawi mai ai na lakou, no ia mea, aole lakou i kuai i ko lakou aina.
\q1 
\v 23 Olelo iho o Iosepa i kanaka, Eia hoi, ua kuai au ia oukou i keia la no Parao, a me ko oukou aina; eia no ka hua na oukou e kanu i ka aina.
\q1 
\v 24 Eia hoi kekahi, i ka hua ana mai, e haawi oukou i ka hapalima na Parao, a koe no eha mau hapa na oukou, i mea kanu o ka aina, a i mea ai na oukou, a na ko oukou kanaka, a i mea ai hoi na ka oukou kamalii.
\q1 
\v 25 I mai la lakou, Ua hoola mai oe ia makou, ina e loaa ia makou ka lokomaikaiia mai imua o na maka o ko'u haku, a e lilo auanei makou i poe kauwa na Parao.
\q1 
\v 26 Hoopaa iho la o Iosepa ia mea i kanawai, mai ia manawa mai, ma ka aina o Aigupita, na Parao ka hapalima o ka ai; o ka aina o na kahuna wale no ka i koe, aole ia i lilo na Parao.
\b
\q1 
\v 27 Noho iho la o Iseraela, ma ka aina o Aigupita, i ka aina o Gosena, a loaa mai la ia lakou ka waiwai ilaila, a hanau mai la lakou, a lilo ae la i poe nui loa.
\q1 
\v 28 O na makahiki o ka noho ana o Iakoba i ka aina o Aigupita, he umikumamahiku: a o na makahiki a pau o ke ola ana o Iakoba, hookahi haneri makahiki a me kanahakumamahiku.
\q1 
\v 29 A kokoke aku la ka la e make ai o Iseraela, hea aku la ia i kana keiki ia Iosepa, i aku la ia ia, Ina i loaa mai ia'u ke alohaia imua o kou maka, e kau mai oe i kou lima malalo o ko'u uha. a e hana mai oe ia'u ma ka lokomaikai a me ka oiaio; ea, mai kanu oe ia'u ma Aigupita nei.
\q1 
\v 30 E moe au me o'u mau makua. E lawe oe ia'u mai Aigupita aku, a e kanu ia'u ma ko lakou ilina. I mai la kela, E hana no wau e like mo kau olelo.
\q1 
\v 31 I aku la keia, E hoohiki mai oe ia'u, a hoohiki iho la kela, a kulou hoomana iho la o Iseraela ma ke poo o kona wahi moe.
\c 48
\b
\q1 
\v 1 A MAHOPE iho o keia mau mea, hai aku la kekahi ia Iosepa, Ua mai kou makuakane. Lawe ae la ia i kana mau keikikane, ia Manase laua o Eperaima.
\q1 
\v 2 A hai ae la kekahi ia Iakoba, i ae la, Eia ae kau keiki o Iosepa, ke hele mai la iou nei. Hooikaika ae la o Iseraela, a noho iho la ma kahi moe.
\b
\q1 
\v 3 Olelo aku la o Iakoba ia Iosepa, Ikea mai la ke Akua mana ia'u ma Luza, ma ka aina o Kanaana, a hoomaikai mai la ia ia'u.
\q1 
\v 4 I mai la, E hoomahuahua aku au ia oe; a e hoonui aku ia oe, a e hoolilo ia oe i lahuikanaka nui loa, a e haawi aku i keia aina, no kau poe mamo mahope ou, i hooilina mau loa.
\b
\q1 
\v 5 A o na keiki au elua, i hanauia mai nau ma ka aiua i Aigupita nei, i ka wa mamua aku o ko'u hele ana mai ia oe i Aigupita nei, na'u no laua. O Eperaima a o Manase, e like me Reubena a me Simeona, pela no laua na'u.
\q1 
\v 6 A o kau mau keiki i hanauia mai nau, mahope mai o laua e kapaia lakou ma ka inoa o ko lakou mau kaikuaana ma ko lakou noho ana.
\q1 
\v 7 I ko'u hele ana mai, mai Padana mai, make ae la o Rahela ma ko'u aoao, ma ka aina o Kanaana, ma ke ala, kokoke e hiki aku i Eperata, a kanu iho la au ia ia malaila ma ke ala ma Eperata, oia hoi o Betelehema.
\b
\q1 
\v 8 A ike aku la o Iseraela i na keiki a Iosepa, ninau aku la ia, Owai laua nei?
\q1 
\v 9 I mai la o Iosepa i kona makuakane, O laua nei na keiki a'u, a ke Akua i haawi mai ai na'u ma keia wahi. I mai la kela, E hoonoho oe ia laua imua o'u, a e hoomaikai aku au ia laua.
\q1 
\v 10 Kaumaha no na maka o Iseraela, no ka elemakule, aole hiki ia ia ke nana; a hoonoho mai kela ia laua imua ona, a honi aku la oia ia laua, a puliki iho la.
\q1 
\v 11 I ae la o Iseraela ia Iosepa, Aole au i manao e ike aku i kou maka, aia hoi, ua hoike mai ke Akua ia'u i kau mau keiki.
\q1 
\v 12 A lawe mai la o Iosepa ia laua mawaena mai o kona mau kuli, a kulou iho la ia me ka maka ilalo i ka honua.
\q1 
\v 13 Lawe iho la o Iosepa ia laua a elua, ia Eperaima i kona lima akau, ma ka lima hema o Iseraela, a ia Manase, i kona lima hema ma ka lima akau o Iseraela, a hoonoho iho la ia laua imua ona.
\q1 
\v 14 Hohola aku la o Iseraela i kona lima akau, a kau iho la ma ke poo o Eperaima, oia hoi ke kaikaina, a i kona lima hema hoi, ma ke poo o Manase: kau akamai no ia i kona lima; no ka mea, o Manase ka hanau mua.
\b
\q1 
\v 15 Hoomaikai mai la oia ia Iosepa, i mai la, Na ke Akua, ka mea a ko'u mau makua o Aberahama a me Isaaka i hele ae imua ona, na ke Akua nana wau i malama mai, mai ko'u wa uuku a hiki loa mai i neia la;
\q1 
\v 16 Na ka Anela i hoopakele mai ia'u mai loko mai o ka hewa a pau, e hoomaikai ia mau keiki, a e heaia ko'u inoa maluna o laua, a me ka inoa o ko'u makua o Aberahama, a me Isaaka, a e laha loa laua i poe nui iwaena o ka honua.
\q1 
\v 17 A ike aku la o Iosepa, ua kau aku kona makuakane i kona lima akau ma ke poo o Eperaima, ua hewa ia i kona maka; hapai ae la ia i ka lima o kona makuakane e hoihoi ae, mai ke poe ae o Eperaima a i ke poo o Manase.
\q1 
\v 18 I aku la o Iosepa i kona makuakane, Aole pela, e ko'u makuakane, o ke kaikuaana keia, e kau oe i kou lima akau maluna o kona poe.
\q1 
\v 19 Hoole mai la kona makuakane, i mai la, Ua ike au, e kuu keiki, ua ike au, e lilo no hoi ia i lahuikanaka a e nui no ia, aka, o kona kaikaina, e kela aku kona nui mamua o keia, a e lilo ana ia i lahuikanaka nui loa.
\q1 
\v 20 Hoomaikai aku la oia ia laua ia la, i aku la, iloko ou e hoomaikai aku ka Iseraela, me ka i ana aku, E hoohalike mai ke Akua ia oe me Eperaima a me Manase. Hoonoho no oia ia Eperaima mamua o Manase.
\q1 
\v 21 I mai la o Iseraela ia Iosepa, Eia hoi, na kokoke au e make, a e noho ana no ke Akua me oukou, a e hoihoi aku no ia ia oukou i ka aina o ko oukou poe makua.
\q1 
\v 22 Ua haawi hoi au in oe i kekahi puu waiwai maluna o kou poe hanauna, i ka mea a'u i loaa ai ma ka lima o ka Amora, me kuu pahikaua a me kuu kakaka.
\c 49
\b
\q1 
\v 1 KAHEA aku la o Iakoba i kana mau keikikane, i aku la, E houluulu mai ia oukou iho i hai aku ai au ia oukou i na mea e hiki mai ana io oukou la i na la mahope.
\q1 
\v 2 E houluulu mai ia oukou iho, e lohe, e na keiki a Iakoba; e hoolohe mai ia Iseraela i ko oukou makuakane.
\b
\q1 
\v 3 E Reubena e, o oe no ka'u hiapo, o ko'u ikaika, a me ka hoomaka ana o ka ui o'u; ke kela ana i ka hanohano, ke kela ana i ka mana:
\q1 
\v 4 He hu wale me he wai la, aole oe e kela aku, no ka mea, pii aku la oe i ka moe o kou makuakane: alaila oe i hoohaumia iho ai: pii aka la ia i kuu wahi moe.
\b
\q1 
\v 5 O Simeona laua o Levi, he mau hoahanau laua: aia na mea hoomainoino ma ko laua hoolimalima.
\q1 
\v 6 Ma ko laua wahi ohumu aole e hele aku kuu uhane, ma ko laua halawai aole e hui pu ia'ku ko'u naui: no ka mea, no ko laua inaina pepehi iho la laua i ke kanaka, a no ko laua makemake oki iho la laua i ke olona wawae o ka bipi.
\q1 
\v 7 E hoinoia ka laua inaina, no ka mea, he ino ia, a me ko laua huhu, no ka mea, he koikoi ia: e mahelehele au ia laua iloko o ka Iakoba, a e hoopuehu au in laua iloko o ka Iseraela.
\b
\q1 
\v 8 E Iuda e, o oe ka mea a na hoahanau ou e hoomaikai ai: o kou lima, aia no ia ma ka a-i o kou poe enemi; e kulou iho hoi na keiki a kou makuakane imua on.
\q1 
\v 9 He keiki a ka liona o Iuda, ua pii ae oe, e kuu keiki, mai ke pio ae: kukuli iho la ia, a moe iho la me he liona kane la, a me ka liona wahine; nawai ia e hoala ae?
\q1 
\v 10 Aole e lilo aku ke kookeo alii mai o Iuda aku, aole hoi ka mea webewehe kanawai maiwaena aku o kona mau wawae, a hiki mai ai o Silo; a ia ia ke akoakoa ana ae o na kanaka.
\q1 
\v 11 E hikii ana i kana keikihoki i ke kumuwaina, a me ke keiki a ka hokiwahine i ke kumuwaina maikai, holoi iho la ia i kona kapa i ka waina, a me kona aahu i ke koko o ka huawaina.
\q1 
\v 12 E ulaula kona mau maka i ka waina, e keokeo hoi kona mau niho i ka waiu.
\b
\q1 
\v 13 E noho auanei o Zebuluna ma ke kahakai; oia no ke kahakai no na moku; a e hiki aku kona palena i Sidona.
\b
\q1 
\v 14 He hoki ikaika no o Isakara e moe ana mawaena o na halemalumalu:
\q1 
\v 15 Ike iho la ia i ka maha he maikai ia, a i ka aina he oluolu ia, kulon iho la ia i kona hokua i ka ukana, a lilo iho la ia i kauwn e auhauia'i.
\b
\q1 
\v 16 E hooponopono o Dana i kona hanauna a kanaka, e like me kekahi o na ohana o Iseraela.
\q1 
\v 17 He nahesa o Dana ma kapa alanui, he moolele ma ke ala; nana e nahu aku na kuekuewawae o ka lio, a e haule hope iho ka mea e hooholo ana ia ia.
\q1 
\v 18 Ua kali au i kou hoola ana, e Iehova.
\b
\q1 
\v 19 O Gada, e lanakila mai ka poe kaua maluna ona, aka, e lanakila aku oia ma ka hope.
\b
\q1 
\v 20 Mai Asera mai kana ai momona, a e haawi aku ia i na mea ono na na'lii.
\b
\q1 
\v 21 O Napetali, he diawahine ia i kalaia'ku; ke hua mai nei ia i na huaolelo maikai.
\b
\q1 
\v 22 He lala hua o Iosepa, he lala hua ma ka punawai: ke kolo ae nei na lala ona maluna o ka pa.
\q1 
\v 23 Ua hooeha nui mai, a ua pana mai hoi na mea pana ia ia, a ua inaina mai lakou ia ia.
\q1 
\v 24 Aka, ua mau no kona kakaka i ka ikaika, a ua hooikaikaia kona mau lima e na lima o ka Mea mana o Iakoba; (nolaila mai ke kahuhipa, ka pohaku no Iseraela;)
\q1 
\v 25 E ke Akua o kou makua, nana oe e kokua mai; e ka Mea mana loa hoi, nana oe e hoomaikai mai i na mea maikai o ka lani iluna, a o ka hohonu ilalo, i na mea maikai o ka u, a o ka opu.
\q1 
\v 26 Ua oi aku ka hoomaikai ana o kou makuakane maluna o na hoomaikai ana o na mauna mau, a hiki aku hoi i na mokuna o na puu kahiko loa: maluna no auanei ia o ke poo o Iosepa, a maluna hoi o ka piko o ke poo o ka mea i hookaawaleia ae mai koua poe hanauna aku.
\b
\q1 
\v 27 E haehae o Beniamina me he iliohae la, i ke kakahiaka e ai iho ia i ke pio, a i ke ahiahi e puunaue ia i ka waiwai pio.
\b
\q1 
\v 28 O keia poe a pau, o ka poe ohana ia a Iseraela he umikumamalua: a oia ka mea a ko lakou makuakane i olelo mai ai ia lakou, a i hoomaikai mai ai ia lakou; i kela kanaka keia kanaka e like me ka hoomaikai ana, ana i hoomaikai mai ai ia lakou.
\b
\q1 
\v 29 Kauoha aku la oia ia lakou, i aku la, E huipu ana au me ko'u poe makua: e kanu pu hoi oukou la'u me na makua o'u ma ke ana maloko o ke kula o Eperona, no ka Heta,
\q1 
\v 30 Ma ke ana iloko o ke kula ma Makepela, ma ke alo o Mamere, ma ka aina o Kanaana, o ke kula a Aberahama i kuai ai me Eperona, no ka Heta, i wahi ilina kupapau nona.
\q1 
\v 31 Malaila lakou i kanu ai ia Aberahama, a me kana wahine me Sara, a malaila lakou i kanu ai ia Isaaka a me kana wahine mo Rebeka, a malaila hoi au i kanu ai ia Lea.
\q1 
\v 32 Ua kuaiia ke kula, a me ke ana iloko me na mamo a Heta.
\q1 
\v 33 A pau ka Iakoba kauoha ana i kana poe keiki, opili ae la ia i kona mau wawae maluna o kahi moe, kaili aku la ke aho, a huipu ia iho la ia me kona poe makua.
\c 50
\b
\q1 
\v 1 HAULE iho la o Iosopa ma ka maka o kona makuakane, a uwe iho la maluna iho, a houi aku la.
\q1 
\v 2 Kauoha ae la o Iosepa i kana mau kauwa, i na kahnua e ialoa i kona makuakane, a ialoa no na kahuna ia Iseraela.
\q1 
\v 3 A pau ae la na la hookahi kanaha nona, no ka mea, oia na la e pau ai ka ialoa ana o ka poe i ialoaia; a kanikau iho la ko Aigupita nona i na la he kanahiku.
\b
\q1 
\v 4 A pau ae la na la kanikau, olelo aku la o Iosepa i na kanaka o Parao, i aku la, Ina i loaa ia'u ka lokomaikaiia mai ia oukou, ke nei aku nei au, e olelo aku oukou ma ka pepeiao o Parao, me ka i aku,
\q1 
\v 5 Na ko'u makuakane i hoohiki ai au, i mai la ia, E, e make ana au. E kanu oe ia'u, ma ka lua kupapau a'u i kohi ai no'u ma ka aina i kanaana. Malaila oe e kanu ai ia'u. E ae mai hoi oe ia'u ke pii aku a kanu i kuu makuakane, a hoi hou mai no.
\q1 
\v 6 I mai la o Parao, O hele e kanu i kou makuakane, e like me kau i hoohiki ai nana.
\b
\q1 
\v 7 Pii aku la o Iosepa e kanu i kona makuakane, a pii pu aku la me ia na kauwa a Parao a pau, a me na luna kahiko o kona hale, a me na luna kahiko a pau o ka aina o Aigupita:
\q1 
\v 8 O ko Iosepa poe a pau me kona poe hoahanau, a me ka poe a pau o kona makuakane. O na kamalii, a me na hipa, a me na bipi, oia wale no ka lakou i waiho ai mahope, ma ka aina i Gosena.
\q1 
\v 9 Pii pu aku la me ia na kaa a me na hoohololio; he poe nui loa.
\q1 
\v 10 Pii aku la lakou i kahi hehi palaoa o Atada, ma o aku o Ioredaue, a malaila lakou i uwe ai me ka uwe nui loa, a kanikau iho la lakou i kona makuakane i na la ehiku.
\q1 
\v 11 A ike ae la ka poe noho ma ia aina, o ko Kanaana i ua kanikau nei, ma kahi hehi palaoa o Atada, olelo iho la lakou, He kanikau nui loa keia a ko Aigupita: no ia mea, ua kapa aku la ka inoa o Abelamizeraima, aia ma o aku o Ioredane.
\q1 
\v 12 A hana aku la kana mau keiki ia ia e like me kana i kauoha ai ia lakou.
\q1 
\v 13 Lawe aku la no kana mau keiki ia ia, i ka aina o Kanaana, a kanu iho la ia ia ma ke ana iloko o ke kula, ma Makepela, na Aberahama i kuai ia kula i wahi ilina nona, me Eperona no ka Heta, aia ma ke alo o Mamere.
\b
\q1 
\v 14 A pau ke kanu ana i kona makuakane, hoi aku la o Iosepa i Aigupita, oia, a me kona poe hoahanau a pau i hele pu me ia e kanu i kona makuakane.
\b
\q1 
\v 15 A ike iho la na kaikuaana o Iosepa, ua make ko lakou makuakane, olelo lakou, E ukiuki mai auanei o Iosepa ia kakou; e oiaio no, e hoopai mai ia i ka hewa a pau a kakou i hana aku ai ia ia.
\q1 
\v 16 Kauoha ae la lakou ia Iosepa, i ae la, Kauoha mai la kou makuakane, mamua o kona make ana, i mai la,
\q1 
\v 17 E i aku oukou ia Iosepa, Ke nonoi aku nei makou ia oe, e kala oe i ka hewa o kou poe kaikuaana, a me ko lakou hala, no ka mea, ua hana hewa lakou ia oe. Ano hoi, e kala oe i ka hewa o na kauwa a ke Akua o kou makuakane. Uwe iho la o Iosepa i ka lakou olelo ana mai ia ia.
\q1 
\v 18 Hele ae la hoi kona poe kaikuaana, haule iho la ma kona alo, i ae la, O kau mau kanwa makou.
\q1 
\v 19 I mai la o Iosepa ia lakou, Mai makau oukou, Owau anei ma ko ke Akua wahi?
\q1 
\v 20 I manao no oukou e hana ino mai ia'u, a hoololi mai ke Akua ia mea, i mea maikai, e hana mai ai e like me ia i neia la, e hoola i na kanaka he nui loa.
\q1 
\v 21 Mai makau: na'u no oukou e malama aku i ka ai, a me ka oukou poe keiki. Hooluolu mai la ia ia lakou, a olelo lokomaikai mai la i ko lakou naau.
\b
\q1 
\v 22 Noho iho la o Iosepa ma Aignpita, oia, a me ka ohana a kona makuakane: a o na makahiki o ko Iosepa oia ana, hookahi haneri a me ka umi keu.
\q1 
\v 23 A ike iho la o Iosepa i na keiki a Eperaima a me ke ku akolu, a me na keiki a Makira, ke keiki a Manase, o ka mea i hanauia ma na kuli o Iosepa.
\q1 
\v 24 I ae la o Iosepa i kona poe hoahanau, E make ana au. E oiaio no, e ike mai ke Akua ia oukou, a e hoihoi aku ia oukou, mai keia aina aku, a ka aina ana i hoohiki ai ia Aberahama a ia Isaaka, a ia Iakoba.
\q1 
\v 25 Na Iosepa no, na mamo a Iseraela i hoohiki ai, i ae la, E oiaio no, e ike mai ke Akua ia oukou, a e lawe aku oukou i ko'u mau iwi, mai anei aku.
\q1 
\v 26 A make iho la o Iosepa ma ka makahiki o kona ola ana, hookahi haneri a me ka umi keu. A ialoa iho la lakou ia ia a waiho iho la maloko o ka pahu ma Aigupita. 
