\p
\v 31 \w While|strong="G1510"\w* \w they|strong="G2532"\w* \w were|strong="G1510"\w* \w talking|strong="G3004"\w*, lots \w of|strong="G2532"\w* \w other|strong="G4183"\w* \w people|strong="G2068"\w* \w kept|strong="G2532"\w* \w on|strong="G1519"\w* \w coming|strong="G2064"\w* \w up|strong="G1519"\w* \w to|strong="G1519"\w* \w Jesus|strong="G3004"\w*, \w and|strong="G2532"\w* \w Jesus|strong="G3004"\w* \w and|strong="G2532"\w* \w his|strong="G1519"\w* \w followers|strong="G3588"\w* didn’\w t|strong="G3588"\w* \w have|strong="G2532"\w* \w time|strong="G2119"\w* \w to|strong="G1519"\w* \w eat|strong="G2068"\w* \w any|strong="G5315"\w* \w food|strong="G5315"\w*. \w So|strong="G2532"\w* \w Jesus|strong="G3004"\w* \w said|strong="G3004"\w* \w to|strong="G1519"\w* \w his|strong="G1519"\w* \w followers|strong="G3588"\w*, “\w Let|strong="G1510"\w*’s \w go|strong="G5217"\w* \w to|strong="G1519"\w* \w a|strong="G2532"\w* quiet \w place|strong="G5117"\w* \w out|strong="G2532"\w* bush, \w so|strong="G2532"\w* \w that|strong="G3588"\w* \w we|strong="G1063"\w* \w can|strong="G3004"\w* \w rest|strong="G1510"\w* \w for|strong="G1063"\w* \w a|strong="G2532"\w* \w while|strong="G1510"\w*.”   
\p
