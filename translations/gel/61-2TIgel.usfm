\id 2TI - Fakai Translation 
\h 2 Timoti 
\toc1 Ran-u u-yu̱ru̱mse̱ u̱ Burus pane̱ Timoti 
\toc2 2 Timoti 
\toc3 2Tim 
\mt2 Ran-u u-yu̱ru̱mse̱ u̱ Burus pane̱ 
\mt1 Timoti 
\c 1  
\s1 U̱s-vu̱k u̱du̱ Timoti 
\p  
\v 1 Uno̱ ran-o̱ o̱o̱n du̱gu̱-du̱ Burus, wu̱ Ru̱-u̱ dage̱ wa shu̱'u̱t wa-to̱m-u̱ Kiristi Ye̱so̱ u̱ cite̱ mu̱ u-Ru̱. Wa to̱mo̱g me̱ u̱m waru̱ ne̱t-ne̱ mo̱t-tu̱ este̱du̱ u̱s-rem su̱ u̱r-fat u̱du̱ yadu̱ jab u̱-me̱ Kiristi Ye̱so̱. 
\p  
\v 2 U̱m o̱ pan-du̱ uno̱ ran-o̱ u̱du̱ Timoti. Bo̱ o̱ u̱ka wa'-u̱ ri wu̱ u̱m o̱ u̱t-cwan. Yage̱ u-Ru̱ u-U̱so u̱ Kiristi Ye̱so̱ ne̱ Wa-ko-uyan in ya' bo̱ u-nya, u̱r-o̱n ne̱ u̱ ru̱s-du̱ jab ne̱. 
\s1 Shiriktin-mu̱ u̱r-shu̱'u̱t u̱ yadu̱ jab-u̱ ne̱ 
\p  
\v 3 U̱m vam-u̱g u-Ru̱ wu̱ u̱m o̱ no̱me̱ m-to̱k u̱ka u̱so-tu̱ u̱so-u̱t ri nomte̱ u̱ jab ne̱ u̱ ko̱se̱ u̱zu̱ u̱m zatte̱ u̱t-ba'as da, u̱ka u-ho̱ u̱ m-gyu̱p ne̱ u̱m o̱ u̱t-baku̱s u̱ bo̱ ne̱ u̱-me̱ to̱o̱g-u̱s ri.  
\v 4 Da-u̱ u̱m bakse̱ u̱ is-m ró ne̱, u̱m tumbte̱ u̱t-sa u̱m hyan bo̱, ko̱ jab-u̱ ri do̱'e̱ u̱t-shu̱ u̱ u̱r-so̱ ne̱.  
\v 5 U̱m no̱ng u̱t-vam remu̱ u̱zu̱ u̱m baku̱ste̱ u̱ yadu̱ jab-u̱ u̱t-nip ró ne̱ u̱ o̱o̱ge̱ u̱r-taku̱n u̱-me̱ wu̱ mate̱ ino-u ró Rois, tu̱msu̱ ino-u ró Afiniki. Tu̱msu̱ u̱m nak u̱ da-o̱ u̱zu̱ gandi yadu̱ jab-u̱ o̱ u̱ u̱-me̱ ró.  
\v 6 Rem iya u̱m o̱ baksu̱n bo̱, u̱zu̱ bo̱ puk-u̱t u-ra u̱ nya-u̱ u-Yar u̱ Ru̱-u̱ yasu̱ bo̱, da-u̱ u̱m do̱ru̱ bo̱ kom-u̱t ri do̱m-u̱ ró.  
\v 7 Remu̱ u̱zu̱ Ru̱-u̱ yaag in yar-u̱ u-gye̱r da, se̱di yar-u̱ u̱r-be̱b, tu̱msu̱ u̱t-cwan ne̱ tu̱msu̱ him-tu̱ u̱r-hi ne̱. 
\p  
\v 8 Remu̱ iya a-bo̱ ho̱g e̱'-mu̱ warru̱ rem-u̱s mo̱t-u̱t Wa-ko-uyan in ko̱ e̱'-m ri da, me̱ yu̱ o̱ u̱-me̱ bu-u̱ m-to̱k u̱ remu̱ wa. Se̱di Afisa bo̱ same̱ u̱t-hi u̱ me̱ ne̱ u̱ te̱k-u̱ swadu̱ u̱r-ko̱b u̱ remu̱ warru̱ Re̱m-su̱ m-Re̱me̱r, u̱du̱ be̱b-du̱ u-Ru̱.  
\v 9 Remu̱ Ru̱-u̱ gwu̱u̱g in tu̱msu̱ wa fog in u̱zu̱ in no̱mo̱n yu̱-du̱ u-he̱n. Wa no̱ng inya, za remu̱ u̱zu̱ in ko̱rge̱ wa no̱me̱ in iya da. Se̱di kanda wa no̱m u-dak u-be̱e̱t Ru̱-u̱ zo̱ngte̱ wa ko̱se̱ in o̱n-u̱r wa u̱du̱ Kiristi Ye̱so̱.  
\v 10 Se̱di na ko̱ske̱ o̱n-du̱ u-Ru̱ u̱ da-o̱ u̱du̱ haan-u̱r Wa-u̱-u̱ku̱r in Kiristi Ye̱so̱. Wa ge̱k-u̱t be̱b-du̱ m-mar tu̱msu̱ wa ko̱se̱ fu̱n-yu̱ fat-du̱ m-mo̱mmo̱ u̱du̱ rem-su̱ m-re̱me̱r.  
\v 11 Ru̱-u̱ dak me̱ u̱m shu̱'u̱t wa-u̱t-bu̱t, wa-to̱m-u̱ Ye̱so̱, tu̱msu̱ wa-u̱t-ko̱se̱ tu̱ Re̱m-su̱ m-Re̱me̱r wa.  
\v 12 O̱ wu̱te̱ u̱m o̱tte̱ swadu̱ u̱r-ko̱b u̱ ana u̱-me̱ bu-u̱ m-to̱k. Se̱di u̱m ho̱k e̱'-mu̱ se̱ da, remu̱ u̱zu̱ u̱m nak wu̱ u̱m o̱tte̱ yadu̱ jab. Tu̱msu̱ u̱m nak za u-sakna u̱zu̱ wa kere̱ e̱'-du̱ Rem-su̱ M-re̱me̱r su̱ u̱m o̱o̱ge̱ bu̱t-tu̱ se̱ m-te̱ ho̱-du̱ Kiristi do̱'e̱ mu̱u̱n. 
\p  
\v 13 No̱m-u̱ bo̱ ho̱ge̱ du̱gu̱-du̱ ri, ship o̱ u̱ka fu̱n-yu̱ ko̱se̱-tu̱ u̱t-nip u̱r-zwar ne̱ so̱k. Tu̱msu̱ bo̱ no̱m inya u̱ yadu̱ jab ne̱ tu̱msu̱ u̱t-cwan ne̱ tu̱ bo̱ kume̱ du̱gu̱-du̱ same̱-du̱ u̱t-hi u̱ Kiristi Ye̱so̱ ne̱.  
\v 14 Remu̱ be̱b-du̱ Yar-u̱ u-he̱n u̱ o̱ m-yu̱ u̱-me̱ in, gwat ko̱se̱-tu̱ u̱t-nip tu̱ so̱-to̱ tu̱ na yasu̱ bo̱. 
\p  
\v 15 Bo̱ nap u̱zu̱ ko̱wan u̱ Asiya kuus-tu̱n me̱ u-shin, m-ha Fajerus tu̱msu̱ Hamojenis ne̱. 
\p  
\v 16 Yage̱ Wa-ko-uyan ko̱se̱ u̱r-o̱n u̱ bu-u Onesiforus, remu̱ u̱zu̱ u-da u-tát wa yaag me̱ m-hiriktin sok, tu̱msu̱ wa ho̱k m-e̱' u̱zu̱ u̱m o̱o̱g u̱-me̱ bu-u̱ m-to̱k da.  
\v 17 Se̱di da-u̱ wa haane̱ Roma, wa goot me̱ sok se̱ da-u̱ wa hyanu̱ me̱.  
\v 18 U̱m no̱ng u̱s-to̱o̱g u̱zu̱ Wa-ko-uyan u̱zu̱ wa ko̱se̱ wu̱n o̱n-u̱r wa u̱ ho̱-du̱ Kiristi do̱'e̱ mu̱u̱n. Tu̱msu̱ bo̱ nak sok u̱r-zwar ne̱ u̱ka wa no̱m-te̱ me̱ u̱r-se̱ge̱ u̱-me̱ Afisa. 
\c 2  
\p  
\v 1 Remu̱ iya, wa'u̱ ri, shu̱'u̱te̱ u̱r-be̱b ne̱ u̱du̱ u-nya u̱ bo̱ o̱tte̱ remu̱ same̱-du̱ u̱t-hi ró u̱ Kiristi Ye̱so̱.  
\v 2 Tu̱msu̱ no̱m-tu̱ bo̱ ho̱ge̱ me̱ u̱t-war u̱du̱ u̱t-ne̱t u-tát, iise̱ no̱m-u̱t to̱ u̱du̱ u̱t-ne̱t tu̱ o̱ yadu̱ jab ne̱, i do̱'e̱ kere̱ iis-u̱ e̱ke̱n.  
\v 3 Gag jab-u̱ swa-u̱ u̱r-ko̱b u̱ it ne̱ u̱ka wa m-gag so̱-wa wu̱ Kiristi Ye̱so̱.  
\v 4 Wa m-gag zaar wu̱ do̱'e̱ gu̱ksu̱ hi-u̱r wa u̱ no̱m-du̱ to̱ko̱n no̱m-to̱ tu̱ ne̱t-tu̱ nome̱ da, re̱mu̱ zu̱ cwan-u̱t wa u̱zu̱ yu̱-shu̱ wa wu̱ kabe̱ wu̱n wa ho̱g zwar-u̱r wu̱n.  
\v 5 Iya tu̱msu̱, da-u̱ waku̱n o̱ so̱m-mu̱ maga, na zaar wa' wu̱n to̱p-du̱ re̱-du̱ u̱r-ko̱rro da se̱ wa do̱ro̱g bo̱r-tu̱ maga.  
\v 6 Wa-u̱r-to̱m wu̱ nome̱ m-ank sok wa kamu̱g kwu̱m-du̱ no̱m-tu̱ u̱r-to̱m tu̱ u̱r-taku̱n.  
\v 7 No̱m u̱s-dorog u̱ mo̱t-tu̱ no̱m u̱m o̱ u̱t-war. Remu̱ u̱zu̱ Wa-ko-uyan do̱'e̱ se̱gu̱ bo̱, u̱zu̱ bo̱ nap to̱ no̱m-to̱ u̱t-be̱e̱t. 
\p  
\v 8 U-da u-be̱e̱t bakse̱ u̱zu̱ Kiristi Ye̱so̱, wu̱ yu̱ne̱ du̱gu̱ marimari-ne̱, wa o̱ du̱gu̱ ko̱-u̱r Faru̱k Dawuda. Sin-se̱ o̱ Rem-su̱ m-Re̱me̱r su̱ u̱m o̱ u̱t-war.  
\v 9 Remu̱ warru̱ Rem-su̱ m-Re̱me̱r, o̱ wa'e̱ u̱m o̱tte̱ swadu̱ u̱r-ko̱b, teet u̱n gu̱g-u̱t me̱ ho-su̱ kwam u̱ka waku̱n wu̱ no̱me̱ u̱t-ba'as. Se̱di waku̱n zaar wu̱ do̱'e̱ keru̱ gag-du̱ remsu̱ u-Ru̱ da.  
\v 10 Remu̱ iya, u̱m gak jab u̱ ko-uyan remu̱ i Ru̱-u̱ dage̱. U̱m no̱ng iya remu̱ ko̱'e̱ e̱ kum u-u̱ku̱r u̱du̱ yadu̱ jab u̱-me̱ Kiristi Ye̱so̱, tu̱msu̱ e̱ kum u̱r-cwa u̱-me̱ m-sek mu̱ m-mo̱mmo̱. 
\p  
\v 11 Rem-u̱s se̱ nip-to̱: 
\q1 A in mare̱ u̱ Kiristi ne̱, 
\q2 in do̱'e̱ tu̱msu̱ u̱r-yu̱ u̱ wa ne̱. 
\q1  
\v 12 A in gage̱ jab, 
\q2 in u̱t-no̱m u̱r-Faru̱k u̱ wu̱n ne̱. 
\q1 A in no̱me̱ se-m wu̱n, 
\q2 wu̱n do̱'e̱ no̱m-du̱ se-m in.  
\v 13 A in zatte̱ yadu̱ jab da, 
\q2 wu̱n o̱mo̱n u̱ jab-u̱ so̱-o̱ ne̱, 
\q2 remu̱ u̱zu̱ wu̱n za no̱mu̱ se-mu̱ hi-u̱r wu̱n da. 
\s1 Wa u-pama wu̱ Ru̱-u̱ ho̱ge̱ zwar-u̱r wa 
\p  
\v 14 Baksu̱n kowan mo̱t-tu̱ tunto̱ no̱m-to̱, tu̱msu̱ no̱mu̱ u̱n u̱t-him u̱-shu̱ u-Ru̱ u̱zu̱ u̱n yage̱ m-dum mu̱ u̱t-gom. Go̱-du̱ nan-i e̱ i m-zan, tu̱msu̱ to̱ kere̱ naasu̱ i o̱ e̱rru̱ u̱n.  
\v 15 No̱m u̱ka bo̱ do̱te̱ u̱t-kere̱ u-be̱e̱t bo̱ ko̱se̱ hi-u̱r ro u̱du̱ u-Ru̱ u̱ka wa u-pama wu̱ Ru̱-u̱ hoge̱ zwar-u̱r wa. Shu̱'u̱te̱ ne̱t-u̱ wu̱ zare̱ ho̱g-du̱ e̱'-mu̱ pama-u̱s wa da, tu̱msu̱ wu̱ iis-u̱ ne̱t-ne̱ rem-su̱ u̱t-nip ho̱n-ho̱n.  
\v 16 Eese̱ m-ra du̱gu̱ rem-su̱ m-zan u̱ rem-su̱ m-rag su̱ wu̱'e̱ u̱t-ne̱t e̱ sur m-no̱m no̱m-tu̱ za tu̱ u-Ru̱ da.  
\v 17 Ko̱se̱-u̱t u̱n bu̱ru̱g u̱ka u̱r-bu̱bu̱. Ne̱t-ne̱ yu̱r i nome̱ go̱-du̱ ko̱se̱-u̱t to̱ u̱na o̱ Himeniyus u̱ Fire̱tus ne̱.  
\v 18 U̱n yakke̱ fu̱n-yu̱ u̱t-nip. U̱n zu̱ na no̱mo̱g yu̱ne̱-du̱ marimari-ne̱, tu̱msu̱ u̱n o̱ natu̱sse̱ ya-du̱ jab-u̱ e̱ke̱n.  
\v 19 M-ha iya ne̱, ne̱t-tu̱ u-Ru̱ ees u̱r-be̱b ne̱ u̱ka u̱r-tak du̱ zaare̱ u̱t-ru̱mu̱s da. U̱-do̱mu̱ tak-u̱r rinde̱ Ru̱-u̱ pu̱nte̱ tunto̱ gom-to̱: <<Ru̱-u̱ nak ne̱t-tu̱ o̱o̱ge̱ ne̱t-u̱t wa>> tu̱msu̱ <<I zu̱ye̱ u̱zu̱ e̱ o̱ a-doru̱ Wa-ko-uyan se̱ e̱ yakke̱ no̱m-du̱ no̱m-u̱t yo̱-to̱.>> 
\p  
\v 20 U̱-me̱ bu-u̱ yat-o̱ a kwano tu̱ shik tu̱ kwam-tu̱ bu̱-mu̱ u̱t-ro u̱ kwam-u̱t pus-to̱ ne̱ to̱ o̱ war-to̱ da, tu̱msu̱ to̱ku̱n o̱ro tu̱ na no̱me̱ u̱s-te u̱ u̱t-rwab ne̱. To̱ko̱n na zo̱ngte̱ to̱ u̱ remu̱ mo̱ro̱g-u̱r yat-de̱, to̱ko̱n remu̱ ank-mu̱ ko̱-uyan ho̱-de̱.  
\v 21 Bo̱ yu̱ shu̱'u̱te̱ kwano du̱ ank-mu̱ ko-uyan ho̱-de̱, a bo̱ jaase̱ hi-u̱r ró u-he̱n ne̱, bo̱ do̱'e̱ u̱t-shu̱'u̱t u̱ka u̱t-kwano remu̱ ank-m yat-mo̱. Na do̱'e̱ has-tu̱ bo̱ u̱-kit, remu̱ ank-mu̱ u̱so-u̱ u-bu, zo̱ngi zo̱ngi remu̱ ko-uyan ank-m so̱-mo̱. 
\p  
\v 22 Se̱di so̱m du̱gu̱ no̱m-u̱t yo̱-to̱ tu̱ nak-du̱ jab-su̱ yaag-u̱ be̱b-ne̱. Tu̱msu̱ bo̱ do̱r yu̱-du̱ jab-u̱ so̱-o̱, u̱ yadu̱ jab ne̱, u̱ u̱t-cwan ne̱, u̱ shu̱'u̱t-du̱ m-yar ne̱, u̱r-ko̱t u̱ i foge̱ dim-u̱r Wa-ko-uyan u̱ jab-u̱ u-he̱n ne̱.  
\v 23 Se̱di gu̱gme̱ m-rag tu̱msu̱ inan i m-zan ne̱, remu̱ u̱zu̱ bo̱ hi-u̱r ro bo̱ nak u̱zu̱ to̱ haatu̱n u-har.  
\v 24 Tu̱msu̱ to̱k-u Wa-ko-uyan se̱ wa shu̱'u̱te̱ za u-har. Se̱di se̱ wa ko̱ske̱ u̱r-o̱n u̱du̱ ko̱wan, wa shu̱'u̱t wu̱ do̱'e̱ kere̱ no̱m-du̱ u̱t-ko̱se̱, tu̱msu̱ wa shu̱'u̱t wa tor-mu̱ jab.  
\v 25 U̱-te̱k u̱t-swu̱u̱mse̱ u̱ no̱me̱ u̱n i o̱ gu̱g-mu̱ bo̱ u̱t-him, u̱-me̱ wadu̱ jab u̱zu̱ Ru̱-o̱ u̱t-wa u̱n yage̱ u̱t-ba'as, tu̱msu̱ u̱ do̱'e̱ hu̱u̱tu̱ u̱n u̱du̱ nap-mu̱ u̱t-nip.  
\v 26 Se̱ u̱ da-u o̱, u̱n do̱'e̱ u̱t-mu̱u̱n u̱-me̱ dorog-u̱s u̱n tu̱msu̱ u̱n kum u̱t-ku̱su̱m du̱gu̱-du̱ re̱n-du̱ faru̱k-u̱ no̱m u̱s-te. Remu̱ u̱zu̱ wa maaste̱ u̱n u̱ka to̱k-ne̱ remu̱ e̱ nom-u̱t ko-uyan u̱ wa u̱t-sa. 
\c 3  
\s1 Yu̱-du̱ u̱t-ne̱t u̱ da-u̱ m-vaste̱ 
\p  
\v 1 U̱m u̱t-sa bo̱ nap u̱zu̱ ho̱-tu̱ m-vaste̱ da-u̱ swadu̱ u̱r-ko̱b do̱'e̱ haan.  
\v 2 Remu̱ ne̱t-ne̱ do̱'e̱ u̱t-shu̱'u̱t a cwan-tu̱ u̱r-hi ne̱, a cwan-tu̱ shik ne̱, a u̱t-u̱k ne̱, a hu̱k-mu̱ u̱r-hi ne̱, a u̱s-pyap ne̱, a-ko̱b-du̱ doru̱ i mate̱ e̱ ne̱, a-ko̱b-du̱ u̱t-vam ne̱ tu̱msu̱ a-za u-he̱n ne̱.  
\v 3 U̱n do̱'e̱ u̱t-shu̱'u̱t a-ko̱b-du̱ u̱t-cwan ne̱, a shu̱p-du̱ o̱r-u̱t e̱ ne̱ u̱ jab, a naasu̱ dim-tu̱ o̱r-u̱t e̱ ne̱, a-ko̱b-du̱ shu̱p-du̱ u̱r-hi ne̱, a-u̱t-gam ne̱, tu̱msu̱ i gu̱g-mu̱ no̱m-tu̱ o̱o̱ge̱ tu̱ so̱to̱ ne̱.  
\v 4 U̱n do̱'e̱ u̱t-shu̱u̱t a re̱-du̱ u-ra u̱ hu̱u̱b-u̱t u̱n, a-ko̱b-du̱ gwat-du̱ o̱ru̱t e̱ ne̱, a hu̱k-mu̱ u̱r-hi ne̱, tu̱msu̱ a cwan-tu̱ m-re̱me̱r ne̱ m-ze̱g cwan-tu̱ u-Ru̱.  
\v 5 U̱n do̱'e̱ u̱t-ko̱se̱ u̱ka a-dor u-Ru̱ ne̱, se̱di u̱n do̱'e̱ gu̱gu̱m du̱ shin-m mu̱ do̱'e̱ u̱t-wa u̱n shu̱'u̱t ne̱t-tu̱ u-Ru̱. So̱m m-ra du̱gu̱ ne̱t-tu̱ o̱o̱ge̱ iya. 
\p  
\v 6 U̱na o̱o̱ge̱ go̱-du̱ ne̱t-u̱t to̱ tu̱ cwu̱ye̱ u̱-me̱ u̱t-bu tu̱ u̱t-ne̱t tu̱msu̱ u̱n e̱ngu̱sse̱ jab-su̱ ne̱ta-ne̱. Ne̱ta-u̱t tun-to̱ zatte̱ u̱s-ve̱r da, i no-mu̱ ba'as-u̱t e̱ ru̱ye̱ u̱n u-dak, tu̱msu̱ go̱-du̱ u̱t-ba'as u̱t-go̱ u̱t-go̱ to̱ o̱ dor-tu̱ u̱n.  
\v 7 Go̱-du̱ ne̱ta-u̱t to̱ u-da u-be̱e̱t e̱ o̱ u-iis, se̱di m-ha iya ne̱ e̱ kerge̱ nap-du̱ rem-su̱ u̱t-nip da.  
\v 8 A-u̱t-ko̱se̱ ne̱ ine̱ e̱ gu̱gu̱m u̱t-nip u̱ka Yanne̱s u̱ Yamris e̱ gu̱gu̱mte̱ Mosa. Jab-u̱s u̱n za so̱-se̱ da tu̱msu̱ u̱n zatte̱ yadu̱ jab u̱ u̱t-nip da.  
\v 9 Se̱di u̱n zaar ha-mu̱ m-ra da. De̱ku̱n ho̱-de̱ za m-tumb ko̱wan do̱'e̱ u̱t-nap u̱zu̱ u̱n o̱ rag-ne̱, u̱ka Yanne̱s e̱ Yamris. 
\s1 Burus nak Timoti u̱t-to̱ 
\p  
\v 10 Se̱di bo̱, Timoti, bo̱ nak u̱ mo̱t-tu̱ ko̱se̱-u̱t ri, tu̱msu̱ u̱ka yu̱-u̱r ri ne̱, no̱m-u̱ u̱m u̱t-sa u̱t-no̱m u̱ fat-u̱r ri, u̱ yadu̱ jab-u̱ ri ne̱, u̱ shiriktin-mu̱ jab-u̱ ri ne̱ u̱ cwan-u̱t ri ne̱, u̱ gag-du̱ jab-u̱ ri ne̱.  
\v 11 Bo̱ nak u̱ka u̱n yu̱te̱ me̱ u̱r-ko̱b tu̱msu̱ swadu̱ u̱r-ko̱b ne̱ du̱ kume̱ me̱ u̱-me̱ Antakiya, u̱ Ikoniya u̱ Risitira ne̱. U̱m gak jab u̱ swadu̱ u̱r-ko̱b dinde̱ tu̱msu̱ Wa-ko̱-uyan ruut me̱ du̱gu̱ to̱ u̱t-be̱e̱t.  
\v 12 U̱t-nip, ko̱wana o̱o̱ge̱ u̱ssa wa do̱r fu̱n-yu̱ u-Ru̱ u̱ka wa-doru̱ Kiristi Ye̱so̱ wa do̱'e̱ swadu̱ u̱r-ko̱b.  
\v 13 Se̱di ne̱t-u̱t yo̱-to̱ u̱ i o̱ e̱ngu̱sse̱ u̱t-ne̱t ne̱ e̱ do̱'e u̱t-re̱ u-shu̱ m-swu̱r ne̱. U̱n do̱'e̱ e̱ngu̱sse̱ e̱ke̱n tu̱msu̱ na do̱'e̱ e̱ngu̱sse̱ u̱n. 
\p  
\v 14 Se̱di se̱ bo̱ eese̱ u̱ yadu̱ jab ne̱ u̱du̱ no̱m-tu̱ na iise̱ bo̱ ne̱. Bo̱ nak u̱zu̱ no̱m-u̱t to̱ nip-to̱, remu̱ u̱zu̱ bo̱ nak u̱zu̱ bo̱ ke̱ru̱ yadu̱ jab u̱du̱ i iise̱ bo̱.  
\v 15 Na iise̱ bo̱ Ran-u̱ u-He̱n du̱gu̱ fa-u̱r ró. Tu̱msu̱ o̱ yaag bo̱ u̱s-ve̱r u̱ bo̱ o̱nk u̱ku̱r-u̱ u̱ o̱o̱ne̱ u̱du̱ yadu̱ jab u̱-me̱ Kiristi Ye̱so̱.  
\v 16 Remsu̱ Ran u-Ru̱ u̱s-be̱e̱t gom-to̱ tu̱ Ru̱-u̱ wa'e̱ u̱-me̱ jab-su̱ i pane̱ se̱ u̱du̱ Yar-u wa. Tu̱msu̱ se̱ kere̱ iis-u̱ in u̱t-nip, tu̱msu̱ se̱ wa' in nap no̱m-u̱ o̱o̱ge̱ u̱ za so̱-o̱ u̱-me̱ fat-u̱t in. Se̱ mang in da-u̱ in no̱me̱ no̱m-u̱ o̱o̱ge̱ za so̱-o̱, tu̱msu̱ se̱ iis-u̱ in no̱m-du̱ no̱m-u̱ o̱o̱ge̱ u̱ ho̱n-ho̱n.  
\v 17 No̱m-u̱ wu̱te̱ inya u-be̱e̱t o̱ u̱zu̱ ne̱t wu̱ no̱mu̱ u-Ru̱ u̱t-huuk do̱'e̱ u̱t-shu̱'u̱t u-zo̱ngi zo̱ngi shu̱yi-shu̱yi u̱ remu̱ wa nom-u̱t ko̱-uyan u̱ o̱o̱ge̱ u̱ ank-m so̱-mo̱. 
\c 4  
\p  
\v 1 U̱m o̱ hyu̱m-du̱ bo̱ u̱-shu̱ u-Ru̱ u̱ Kiristi Ye̱so̱ ne̱, wu̱ do̱'e̱ no̱mu̱ i o̱o̱ge̱ u̱r-fat u̱ i mari ne̱ kwu̱p-du̱ u̱s-rem, tu̱msu̱ remu̱ u̱zu̱ wa do̱'e̱ mu̱u̱n wa ka faru̱k-u̱r wa:  
\v 2 No̱m do̱nse̱-du̱ remsu̱ u-Ru̱. Bo̱ shu̱'u̱t u̱s-zo̱ng ne̱, ko̱ da-u̱ m-re̱me̱r ko̱ da-u̱ za m-re̱me̱r. Bo̱ mang, bo̱ no̱m u̱t-him, tu̱msu̱ bo̱ ya' shiriktin-mu̱ jab u̱ gag-du̱ jab-u̱ yato̱ ne̱ tu̱msu̱ u̱ ko̱se̱-u̱t so̱-to̱ ne̱. 
\p  
\v 3 Remu̱ da-u̱ o̱o̱n da-u̱ ne̱t-tu̱ zamu̱ttu̱n cwan-tu̱ e̱rru̱ ko̱se̱-tu̱ u̱t-nip da, se̱di u̱n do̱'e̱ do̱ru̱ no̱mu̱ jab-u̱s u̱n u̱t-sa. U̱n do̱'e̱ kargu̱sse̱ hi-du̱ war-e̱ a-u̱t-ko̱se̱ ne̱ i do̱'e̱ waru̱ u̱n no̱m-u̱ to̱-tu̱ m-koot u̱n u̱t-sa u̱t-ho̱g.  
\v 4 U̱n do̱'e̱ zwape̱ to̱-u̱t u̱n du̱gu̱ e̱rru̱ u̱t-nip, tu̱msu̱ u̱n bir u̱-kit u̱du̱ e̱rru̱ u̱t-kwu̱r. 
\p  
\v 5 Se̱di bo̱, Timoti, se̱ bo̱ shu̱'u̱te̱ u̱ shu̱p-du̱ u̱r-hi ne̱ u-da u-be̱e̱t, gag jab u̱ swa-u̱ u̱r-ko̱b ne̱, no̱m ank-mu̱ warru̱ Rem-su̱ m-Re̱me̱r, tu̱msu̱ bo̱ shu̱u̱s no-mu̱ ank-mu̱ Ru̱-u̱ yase̱ u̱du̱ ró. 
\p  
\v 6 U̱m o̱ yadu̱ bo̱ tunto̱ bo̱r-to̱ remu̱ u̱zu̱ fat-u̱r ri o̱ u̱ka u̱r-to̱o̱g du̱ u-swa du̱ wa-to̱o̱g dase̱, tu̱msu̱ da-u̱ u̱m do̱'e̱ yage̱ uno̱ dak-u̱ u-be̱e̱t o̱ u̱t-mo̱r.  
\v 7 U̱m jwu̱mu̱g dum-m so̱-mo̱ u̱ka ku̱mte̱. U̱m taaste̱ maga. U̱m shu̱pu̱k rem-su̱ u̱t-nip su̱ mo̱t-u̱t Kiristi u̱r-be̱b ne̱.  
\v 8 Tu̱msu̱ u̱ da-o̱ o̱g-du̱ o̱ e̱stu̱ me̱, to̱p-du̱ u̱r-faru̱k jab-u̱ so̱-o̱. Wa-ko-uyan, wa-kwu̱p-du̱ u̱s-rem ho̱n-ho̱n, wa do̱'e̱ yadu̱ me̱ dinde̱ o̱g-de̱ u̱ ho̱-du̱ wa do̱'e̱ mu̱u̱n. Tu̱msu̱ o̱g-u̱r rinde̱ za remu̱ ri o̱ warri da, se̱di tu̱msu̱ remu̱ i o̱o̱ge̱ cwan-tu̱ mu̱u̱n-u̱r wu̱n be̱e̱t. 
\s1 Gom-tu̱ m-vaste̱ Burus 
\p  
\v 9 No̱m m-ho̱r u̱ka bo̱ do̱te̱ u̱t-no̱m bo̱ haan u̱du̱ ri.  
\v 10 Remu̱ zu̱ Dimas kuustu̱n me̱ u-shin u̱ remu̱ cwan-tu̱ no̱m-tu̱ u-dak tu̱msu̱ wa yakke̱ me̱ wa do̱'e̱ u̱ Tasaronika. Kiricin do̱'e̱ u̱ Garatiya, tu̱msu̱ Titus do̱'e̱ u̱ Dimatiya.  
\v 11 Ruka wa o̱ u̱r-ko̱t u̱-me̱ ne̱ kyak. Gote̱ Markus u̱ bo̱ haatu̱n wa, remu̱ u̱zu̱ wa o̱ u̱r-se̱ge̱ ne̱ du̱ yat-de̱ u̱-me̱ ank-m ri.  
\v 12 U̱m to̱mo̱g Tikikus m-ha Afisa.  
\v 13 Da-u̱ bo̱ o̱ haan, se̱ bo̱ kabnu̱ me̱ u-go̱do̱ yu̱ u̱m yagne̱ u̱-me̱ bo̱-u̱ Toruwa u̱ kom-u̱t Karbus. Tu̱msu̱ bo̱ kabne̱ me̱ ran-tu̱ u̱s-pan ri, hadde tu̱ na no̱me̱ u̱ ka-tu̱ u̱t-bisa. 
\p  
\v 14 Are̱zanda wu̱ no̱me̱ u-zwa u̱t-kwam, wa no̱ngu̱ me̱ no̱m-u̱t yo̱-to̱ u-tát. Wa-ko-uyan do̱'e̱ to̱p-u̱ wu̱n remu̱ no̱m-u̱ wu̱n no̱me̱.  
\v 15 Tu̱msu̱ bo̱ ees m-ra du̱gu̱-du̱ wu̱n, remu̱ wa gu̱gu̱mte̱ rem-u̱s in u̱r-be̱b ne̱. 
\p  
\v 16 Da u̱m ruute̱ hi-u̱r ri u̱r-taku̱n u̱-shu̱ wa-kwu̱p-du̱ u̱s-rem, waku̱n do̱ro̱g dim-u̱ ri da. Kowan so̱mo̱g me̱. Ta'as Ru̱-u̱ to̱p u̱n no̱m-u̱t to̱ u̱t-be̱e̱t m-yo̱ u̱ u̱n ne̱ da.  
\v 17 Se̱di Wa-ko-uyan ees u̱r-ko̱t u̱ me̱ ne̱ tu̱msu̱ wa yu̱' me̱ u̱r-be̱b re̱mu̱ u̱m shu̱u̱ste̱ do̱nse̱-du̱ rem-su̱ m-re̱me̱r m-zu̱n m-ha u̱du̱ i za-Yahuda-ne̱ da e̱ ho̱g. Tu̱msu̱ wa u̱-ku̱r me̱ du̱gu̱ nu-u̱ u-zur.  
\v 18 Wa-ko-uyan do̱'e̱ ruutu̱ me̱ du̱gu̱ ko̱-uyan ank-m yo̱-mo̱ mu̱ do̱'e̱ he̱e̱se̱ me̱ tu̱msu̱ wa do̱'e̱ mu̱u̱tu̱n me̱ m-yar u̱-me̱ faru̱k-du̱ u-ru̱ wa. M-sek m-be̱e̱t u̱du̱ u-Ru̱ m-mo̱mmo̱! U̱ shu̱'u̱t iya. 
\s1 Vu̱k-su̱ m-vaste̱ Burus 
\p  
\v 19 Bo̱ vu̱k-se̱ me̱ Biskira u̱ Akira ne̱ u̱ ne̱t-tu̱ bu-u Onesiforus ne̱.  
\v 20 Eratus ees u̱-me̱ bo̱-u̱ Ko̱rintiya, tu̱msu̱ u̱m yakke̱ Tarofimus u̱ ko̱b-du̱ m-yar u̱-me̱ bo̱-u̱ Miretus. 
\p  
\v 21 No̱m u̱ka bo̱ do̱te̱ u̱t-kere̱ bo̱ teen ane̱ kanda go̱s-u̱ he̱e̱n. Yuburus o̱ to̱mto̱n bo̱ u̱s-vu̱k, u̱ Fudens ne̱, u̱ Rinus ne̱, u̱ Karadiya ne̱, tu̱msu̱ a-doru̱ Ye̱so̱ ne̱ be̱e̱t. 
\p  
\v 22 Yage̱ Wa-ko̱-uyan no̱m u̱r-kot u̱ yar-u ró ne̱. Nya-u shu̱'u̱t u̱r-kot u̱ no̱ ne̱.