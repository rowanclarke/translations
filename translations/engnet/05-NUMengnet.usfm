\v 9 “‘\w Then|strong="H1961"\w* \w a|strong="H3068"\w* \w man|strong="H1121"\w* \w who|strong="H1931"\w* \w is|strong="H1931"\w* ceremonially \w clean|strong="H2889"\w* \w must|strong="H1121"\w* gather \w up|strong="H3240"\w* \w the|strong="H1961"\w* ashes \w of|strong="H1121"\w* \w the|strong="H1961"\w* red \w heifer|strong="H6510"\w* \w and|strong="H1121"\w* \w put|strong="H3240"\w* \w them|strong="H1961"\w* \w in|strong="H3478"\w* \w a|strong="H3068"\w* ceremonially \w clean|strong="H2889"\w* \w place|strong="H4725"\w* \w outside|strong="H2351"\w* \w the|strong="H1961"\w* \w camp|strong="H4264"\w*. \w They|strong="H1931"\w* \w must|strong="H1121"\w* \w be|strong="H1961"\w* \w kept|strong="H4931"\w* \w for|strong="H4325"\w* \w the|strong="H1961"\w* \w community|strong="H5712"\w* \w of|strong="H1121"\w* \w the|strong="H1961"\w* \w Israelites|strong="H3478"\w* \w for|strong="H4325"\w* \w use|strong="H1961"\w* \w in|strong="H3478"\w* \w the|strong="H1961"\w* \w water|strong="H4325"\w* \w of|strong="H1121"\w* \w purification|strong="H2403"\w* – \w it|strong="H1931"\w* \w is|strong="H1931"\w* \w a|strong="H3068"\w* \w purification|strong="H2403"\w* \w for|strong="H4325"\w* \w sin|strong="H2403"\w*.  
\v 10  \w The|strong="H8432"\w* \w one|strong="H1121"\w* \w who|strong="H1616"\w* gathers \w the|strong="H8432"\w* ashes \w of|strong="H1121"\w* \w the|strong="H8432"\w* \w heifer|strong="H6510"\w* \w must|strong="H1121"\w* \w wash|strong="H3526"\w* \w his|strong="H3526"\w* clothes \w and|strong="H1121"\w* \w be|strong="H1961"\w* ceremonially \w unclean|strong="H2930"\w* \w until|strong="H5704"\w* \w evening|strong="H6153"\w*. \w This|strong="H8432"\w* \w will|strong="H1961"\w* \w be|strong="H1961"\w* \w a|strong="H3068"\w* \w permanent|strong="H5769"\w* \w ordinance|strong="H2708"\w* both \w for|strong="H5704"\w* \w the|strong="H8432"\w* \w Israelites|strong="H3478"\w* \w and|strong="H1121"\w* \w the|strong="H8432"\w* resident \w foreigner|strong="H1121"\w* \w who|strong="H1616"\w* \w lives|strong="H1481"\w* \w among|strong="H8432"\w* \w them|strong="H8432"\w*.   
\s1 Purification from Uncleanness  
\p
\v 11 “‘\w Whoever|strong="H3605"\w* \w touches|strong="H5060"\w* \w the|strong="H3605"\w* \w corpse|strong="H4191"\w* \w of|strong="H3117"\w* \w any|strong="H3605"\w* \w person|strong="H5315"\w* \w will|strong="H5315"\w* \w be|strong="H4191"\w* ceremonially \w unclean|strong="H2930"\w* \w seven|strong="H7651"\w* \w days|strong="H3117"\w*.  
