\id 2CO - Ikwerre 
\h 2 Ele Kọrinti 
\toc1 Ọkwukwo izi ke Ẹbo Pọlu gbaznennu Ele Kọrinti 
\toc2 2 Ele Kọriniti 
\toc3 2 Kọr 
\mt2 Ọkwukwo izi 
\mt2 ke Ẹbo 
\mt2 Pọlu gbaznennu 
\mt1 Ele Kọrinti 
\imt1 Nhne gbasịri ọkwukwo izi ka 
\im \bk Ọkwukwo izi Pọlu gbaznennu ele Kọrinti ke ẹbo\bk* bụ ke Pọlu gbarụ nga ọgbako Chiokike ke zị nụ Kọrinti nụ Pọlu zị nụ mkpa. Agwa ele zị nụ rime ọgbako wam bnornu Pọlu nhne, kọvu Pọlu noopio ma ya nụ be mee udno. 
\ip Nụ rime nhne mbọm Pọlu gbarụ n'ọkwukwo, o nookwu ọka nhne gbasịri ọgbako Chiokike ke zị nụ Kọrinti, nọokowa nụ mkpọma nọoso a n'ọnu k'agịda kwnornu nụ be tụhnasnarnu mkpọma. Ọ naarịasno ọgbako Chiokike gbalị gweru mkpọma be gweya nhne be jeekesi ele Karaịsi zị nụ Judiya. Nụ ipne-aznụ, Pọlu nọogoru ọnu a lele ọmamarna nye izi Karaịsi, megidne agwa ele kwuru ẹhni be ọmamarna ele izi. Be naakaa nụ Pọlu bụ nye izi aghalaghala. 
\iot Nhne zị n'ọkwukwo ka 
\io1 Ọpanizo \ior (1:1-11) \ior* 
\io1 Pọlu nụ ọgbako Chiokike zị nụ Kọrinti \ior (1:12---7:16) \ior* 
\io1 Nkesi be nyernu ọgbako Chiokike zị nụ Judiya \ior (8:1---9:15) \ior* 
\io1 Pọlu gọru ọnu a lele nye izi \ior (10:1---13:10) \ior* 
\io1 Obekwu ikwu ipne-aznụ \ior (13:11-14) \ior* 
\c 1  
\p  
\v 1 Mawa Pọlu, nye izi Jizọsi Karaịsi lele kpa ọ masịri Chiokike, nụ nnwọ nda aị Timoti, gbaznenu ọgbako Karaịsi ke zị nụ Kọrinti nụ kpakara ele ke Chiokike zị nụ kpakara Akaya ọkwukwo.  
\v 2 Oru nụ udno ke Chiokike Nda aị nụ Nyenwe aị Jizọsi Karaịsi dazịnu anụ. 
\s1 Pọlu nọotunu Chiokike  //  mmamma 
\p  
\v 3 Ọznarni zịnu Chiokike bụ Nda Nyenwe aị Jizọsi Karaịsi, Nda ke obirizi, Chiokike ke nkasi ovu,  
\v 4 nye naakasi aị ovu nụ rime kpakara awhnụwhnu aị, ma a nwernu rikne kasi ele berere zị n'awhnụwhnu ọbula ovu hite n'ọkasi ovu a nwehịaru n'aka Chiokike.  
\v 5 Lele kpa a snornu Karaịsi takọ agịda awhnụwhnu a, ọ bụ masị kpa Karaịsi naakasi aị ovu k'agịda.  
\v 6 Ọ bụru nụ a zị nụ mkpa, ọ bụ ma be snụta ovu anụ, znọhia masị anụ. Ọkasi aị ovu bụ nkasi ovu anụ masị, ọkasi ovu wam nọornusi ẹrnu rikne neegwehịa ndidi nụ rime awhnụwhnu wam a nọowhnuzu.  
\v 7 Olile anya aị nụ hne anụ zị, zị chịm chịm, kwnornu nụ a maam nụ kpa anụ sno aị ta awhnụwhnu anụ joosno masị aị nwe nkasi ovu. 
\p  
\v 8 A pioru anụ mahịa nhne dnakwasịri aị n'Esia, nhne zị ogwnu ke dnakwasịri aị kakwo aị rikne, a nwéma olile anya bụdnu.  
\v 9 A neeche nụ be joogbu aị. Kọvu ka gesiri aị nụ a kwésile ọ tụkwasi ẹhni aị mkpọma, kọvu a tụkwasiri Chiokike ovu, nye neeme nye nwụrnu ọnwu hi n'ẹnwu lizọ.  
\v 10 Ọ dọhiaru aị n'aka ẹnwu tụ ogwnu, nọodohia aị kọriri, a kwnatarụ ovu nụ hne ọ zị nụ ọ jaazị kọriri nọodohia aị,  
\v 11 kpa anụ zị neekpenu aị okpukpe. Agịda ele badnụ jọotunu Chiokike mmamma kwnornu nụ ruwhnu ọma o jeenye aị, ọ jaaza okpukpe agịda ele badnụ. 
\s1 Pọlu gbanwornu mmụma a 
\p  
\v 12 Ka bụ nhne a ji naanya risi, nhne mkpọma aị naagba akebne, a wuru bụdnu zị snam, zị masị nsọ ke hi n'aka Chiokike. Ọ bụ́o kpa akọniche ke badnụ pioru, kọvu hite n'oru ke Chiokike, a wuru bụdnu aị nụ rime ọwa, ke kakwo nụ hne anụ zị.  
\v 13 A gbála ọkwukwo nhne anụ jọ́ogwnuli mọbu jọ́oghohiali, kọvu nhne anụ jọoghohiali. M neele anya nụ anụ jọoghohiazu a,  
\v 14 lele kpa anụ ghọhiaru aị matị, ma a kpa nganga kwnornu anụ, anụ kpa masị nganga kwnornu aị n'ọbochi Nyenwe aị. 
\p  
\v 15 Ka bụ olile anya me vu nụ mkpọma nụ mbọm kpa me marnụ mmụma ọ va, ma anụ nwehịa ngọzi okpukpu lawụru.  
\v 16 M marnụ m mmụma ọ vakwnusi anụ kpa me neezne Masidonia nụ nga me jeehi Masidonia hiehna. Anụ znernu eyinu m aka m zne Judiya.  
\v 17 Nga me neeme ka, m mernu m a ewheke ewheke sa? M marnụ m mmụma kwnornu nhne anọ-ẹhni m pioru, ọ kaa, “Owe, owe” nụ “Ọ́za, ọ́za”? 
\p  
\v 18 Kọvu kpa Chiokike bụ nye ezi ọka, izi me znirni anụ bụ́o izi “Owe” nụ “Ọ́za.”  
\v 19 Kwnornu nụ Jizọsi Karaịsi Nnwọ Chiokike nye Saịlasi nụ Timoti nụ me gbasarụ n'esilawụru anụ bụ́o nye “Owe” nụ “Ọ́za.” Kọvu kpakara nhne bụ “Owe” hne ọ zị.  
\v 20 Jizọsi neeji “Owe” neemezu kpakara mkwna Chiokike kweru. Hite nụ rime Jizọsi a naakaa, “Amịm” neenye Chiokike igwugwu.  
\v 21 Ọ bụ Chiokike nye neeme aị nụ anụ gwuzosi rikne nụ rime Karaịsi, Chiokike jiri aka a họhia aị,  
\v 22 nye bnịasiri aka nyenwe nụ risi aị, nye kesiri aị Enine Nsọ nụ rime mkpọma aị neemesi nhne ọ bịtannu aị rikne. 
\p  
\v 23 M noosukwu Chiokike nye akebne m, ọ magwụ mkpọma m, nhne mernu me vála Kọrinti bụ m gharụ o bigbọ anụ.  
\v 24 A zá neeme ẹhni aị lele nụ ọ bụ aị nwe anụ, ele naakanụ anụ nhne anụ jeekweru. Tnụnuma, aị nụ anụ nọornuko ẹrnu ma ovu sọ anụ n'ọnu. Anụ gwuzoru kwem n'ọkwnata mkpọma anụ. 
\c 2  
\p  
\v 1 Ka bụ nhne me kpebiri nụ mkpọma m, m jáavakwnusi anụ berere mee nhne joogbu anụ igbugbu.  
\v 2 Ọ bụru me mee nhne gbu anụ igbugbu, nyele jeeme ovu sọ m n'ọnu? Okwolem nye wam me mernu nhne gbu a igbugbu.  
\v 3 Kam kpayarụ, me gbannụ anụ ọkwukwo nụ mbọm, ọ zị nga me varụ, ele wam kwesiri o mee ovu sọ m n'ọnu mee m nhne gbu m igbugbu. Kwnornu nụ m maam nụ anụ joosno m nwụdna.  
\v 4 M zị m n'awhnụwhnu k'agịda kpa me ji igbugbu mkpọma nụ agịda anya-mini gbanụ anụ ọkwukwo, ọ bụ́o ma o gbu anụ igbugbu, kọvu o gesi nụ m whnụrnu m anụ n'anya k'agịda. 
\s1 Ọgbarunu nye mmehie 
\p  
\v 5 Ọ bụru nụ nye ọbula mernu nhne igbugbu, o méne me kpọi, kọvu nhne gburu kpakara anụ igbugbu matị, me kwú k'agịda.  
\v 6 Awhnụwhnu nye wam tarụ n'aka agịda ele badnụ zulem.  
\v 7 Bikno, anụ gbarụnu a, kasi a mkpọma, ọ zị igbugbu a nyịgbu a, mee mkpọma dna mba.  
\v 8 Anụ mee a ma ọ mahịa nụ anụ whnụrnu a n'anya n'ezi.  
\v 9 Ka bụ nhne me kwno gbanụ anụ ọkwukwo, ma m mahịa m ma anụ gwuzosiri rikne, noobno nsnị kpakara nhne me kannụ anụ.  
\v 10 Ọ bụru nụ anụ gbarụnu badnụ nhne o mernu, m gbarụlam masị. M gbarụlam, ọ bụru nụ ọ zị nhne ọbula ke zị nụ ọ gbarụnu, ka bụ nhne me mennu anụ nụ ruwhnu Karaịsi,  
\v 11 ma Ekwensu gharụ o megbu aị, kwnornu nụ a magwụ kpakara aghịgho a. 
\s1 Mkpọma ọla mini Pọlu  //  nụ Torasi 
\p  
\v 12 Nga me vaduru Torasi o zni izi ọma Karaịsi, Nyenwe aị gbamannụ m ọnu-mgbo izi ọma.  
\v 13 Kọvu nụ enine m kwé ozukwa inwe kwnornu nụ m whnụ́na m nnwọ nda m Taịtosi, m ghasarụ m be zne Masidonia. 
\s1 Omegbu hite nụ Karaịsi 
\p  
\v 14 Kọvu Chiokike nwe kpakara mmamma, nye mernu a snornu Karaịsi tne eri omeri a. O ji aị mee ele badnụ mahịa Karaịsi, nhne ke nụ lele ẹknarna ọma ke noozute penupe ọbula.  
\v 15 Kwnornu nụ a bụ nhne ẹknarna ọma Karaịsi ke neeznekwnusi Chiokike n'esilawụru ele be nọoznohia nụ ele noowhu owhu.  
\v 16 Nụ hne ele noowhu owhu zị, a bụ ẹknarna ẹnwu, hne ele be nọoznohia zị, a bụ ẹknarna bụdnu. Nyele jọornuli ẹrnu ka hna rikne kpa?  
\v 17 A bụ́o ele ji izi ọma Chiokike nọozu ahịa lele agịda ele berere, kọvu a bụ ele ezi, nookwu ezi ọka Karaịsi nụ ruwhnu Chiokike lele ele Chiokike ziyaru. 
\c 3  
\s1 Ele ẹrnu ọgba-njọ-ẹhni  //  ikne 
\p  
\v 1 A naanya risi nụ rime ẹhni aị berere sa? A neeme lele ele berere, noopio ọkwukwo ọ kahịa nhne a bụ ke a jeenye anụ, mọbu ke hi n'aka anụ?  
\v 2 Anụ n'iwhuru anụ bụ ọkwukwo izi aị, be gbarụ anụ nụ mkpọma aị ke ele badnụ magwụ, nọogwnu masị.  
\v 3 Ka neegesi nụ anụ bụ ọkwukwo izi ke Karaịsi ke hi n'aka aị. Be jíle nki gba a n'olu rugwu, kọvu be ji Enine Chiokike zị bụdnu gbasị anụ n'anọ-ẹhni ke mkpọma. 
\p  
\v 4 Ka bụ okne ọtukwasi ovu aị nụ Chiokike hite nụ Karaịsi.  
\v 5 Ọ bụ́o nụ a nwernu rikne nụ rime aị ke a kwesiri ọ rnụ ẹrnu ka, kọvu ozu ozu aị hi n'aka Chiokike va.  
\v 6 Chiokike mernu aị a bụru ele zuru ozu n'ẹrnu ọgba-njọ-ẹhni ikne, ọ bụ́o ke mkpụru ọkwukwo, kọvu ke enine, kwnornu nụ mkpụru ọkwukwo neegweya ẹnwu, kọvu enine neenye bụdnu. 
\s1 Igwugwu ke ọgba-njọ-ẹhni  //  ikne 
\p  
\v 7 Ọ bụru nụ ẹrnu ke ẹnwu be gbakwasịri n'olu rugwu vuru igwugwu va, ke mernu rụmu Izirẹli nwée rikne legidne Mozizi anya nụ ruwhnu, ọ bụ n'ezi nụ igwugwu a jaagawhe,  
\v 8 ndaa kpa igwugwu ke ẹrnu Enine jaahna?  
\v 9 Ọ bụru nụ ẹrnu ke noovuya ẹnwu nwernu igwugwu, le kpa ẹrnu ke neegweya ome mma jaahna n'igwugwu karụkwo.  
\v 10 N'ezi, nhne ke nwernu igwugwu nwéma igwugwu kwnornu nụ nhne ke kakwo n'igwugwu whụyaru iwhne.  
\v 11 Ọ bụru nụ nhne ke jaazị ige matị vu igwugwu, le kpa nhne ke jaazị ọkwnukokwnu jaahna n'igwugwu karụkwo. 
\p  
\v 12 Kwnornu nụ a nwernu olile anya ke nụ kpa, a nwernu ọnu rikne nookwu ọka.  
\v 13 A nụ́ lele Mozizi nye jiri ikpe kpusni ruwhnu a ma ele Izirẹli gharụ ọ whnụ okwukwo ogbu marna marna ke naagawhe agawhe.  
\v 14 Mkpọma be zị kọriri n'ọchichiri, tem dụ tna. Ikpe wam be jiri kpusni zị kọriri nga be nọogwnu ọgba-njọ-ẹhni ọknani. Be kpúmene ikpe wam, Karaịsi kpọi nwernu rikne o kpume a.  
\v 15 Dụ tna, ige ọbula be nọogwnu Iwu Mozizi, ikpe wam nookpusni mkpọma be.  
\v 16 Kọvu ige ọbula nye ọbula znekwnusiri Nyenwe aị, be jeegweme ikpe wam.  
\v 17 Nyenwe aị bụ Enine, hne ọbula Enine Nyenwe aị zị, badnụ jeenwernu ẹhni a.  
\v 18 Kọvu kpakara aị, ji ruwhnu be jíle ikpe kpusni neele igwugwu ke Nyenwe aị lele nhne a nọowhnu nụ nyno, a naagbanwo hite n'otu igwugwu bna n'igwugwu berere. Enine Nyenwe aị neeme nhne ka. 
\c 4  
\s1 Ẹkwnu ke zị nụ rime  //  ite rịzna 
\p  
\v 1 Kam kpayarụ, hne Chiokike nyernu aị ẹrnu ka hite n'obirizi a, a jéekwe inwe gwụ aị.  
\v 2 Tnụnuma, a sịgbasiri kpakara nhne ke tugwaru otugwa ke tụ iwhnerne. A zá nọogho aghịgho mọbu mee ikwu-ọnu Chiokike aghalaghala. A gwuzo nụ ruwhnu Chiokike nookwu ezi ọka, neegesi ele badnụ nụ a bụ ele ezi ọka.  
\v 3 Ọ bụru nụ be tugwaru izi ọma a nọokpo okwo a otugwa, ọ bụ n'anya ele noowhu owhu.  
\v 4 Chi ke ọwa ka mernu mkpọma ele ke kwé ekwe gba ọchichiri. O mernu be whnụ́na iwhne ke izi ọma nọomukwasi be, bụ izi ọma igwugwu Karaịsi, nye bụ oyiyi ke Chiokike n'ezi.  
\v 5 Kwnornu nụ a zá nọokponu ẹhni aị okwo, kọvu a nọokpo okwo Jizọsi Karaịsi bụ Nyenwe aị, aị n'iwhuru aị bụ ele izi anụ kwnornu Karaịsi.  
\v 6 Chiokike wam ke karụ, “Iwhne mụ n'ọchichiri,” bụ otu Chiokike wam ke mernu iwhne a mụkwasi nụ mkpọma aị, ma a mụhia igwugwu Chiokike ke a nọowhnu nụ ruwhnu Karaịsi. 
\p  
\v 7 A nwernu ẹkwnu ka nụ rime ite rịzna, ke neegesi nụ rikne ke kakwo rikne hi nụ Chiokike, ọ bụ́o nụ rime aị.  
\v 8 Be naakpakna aị ẹhni n'apna ọbula, kọvu inwe zá nọogwu aị, a neenwe mkpọma lawụru, kọvu inwe zá nọogwu aị.  
\v 9 Ele irno naakpakna aị ẹhni, kọvu Chiokike ghásala aị etekne. Be mekasi aị ẹhni, kọvu a nwụ́na.  
\v 10 A vu n'ẹhni aị ẹnwu Jizọsi ige ọbula, ma bụdnu Jizọsi whụya iwhne nụ rime aị.  
\v 11 Aị ele zị bụdnu zị n'ọnu ẹnwu ige ọbula kwnornu Jizọsi, ma bụdnu a whụya iwhne n'anọ-ẹhni aị ke nọonwu ọnwu.  
\v 12 Kam kpayarụ, ẹnwu nọornu ẹrnu nụ rime aị, kọvu bụdnu zị nụ rime anụ. 
\p  
\v 13 Be gbarụ n'ọkwukwo nsọ, kaa, “M kwuru m ọka kwnornu nụ m kweru m.” A ji otu enine ọkwnata ovu wam kwu ọka kwnornu nụ a kweru ekwe.  
\v 14 A magwụ nụ Chiokike wam ke mernu Jizọsi hi n'ẹnwu lizọ, jeeme a snornu Jizọsi hi n'ẹnwu lizọ masị, mee aị nụ anụ gwuzoru nụ ruwhnu a.  
\v 15 Kpakara nhne ka bụ kwnornu anụ, ma oru ke naabanụ anụ ọba dụnu agịda ele badnụ, ma be tụnu Chiokike mmamma k'agịda, neenye a igwugwu. 
\p  
\v 16 Kam kpayarụ, inwe zá nọogwu aị, ọ bụ n'ezi nụ a naata ẹhni n'anọ-ẹhni aị, kọvu badnụ ke enine aị zị ikne ikne hite n'ọbochi dụ n'ọbochi.  
\v 17 Awhnụwhnu matị ka a naata neegweyanụ aị okne igwugwu ke zị ọkwnukokwnu ke kakwo kpakara awhnụwhnu.  
\v 18 A zá neele anya nhne a nọowhnu anya, kọvu nhne a whnụ́ anya. Kwnornu nụ nhne a nọowhnu anya zị ige matị, kọvu nhne a zá nọowhnu anya zị ọkwnukokwnu. 
\c 5  
\s1 Ọro aị n'oligwe 
\p  
\v 1 A magwụ nụ ọ bụru nụ ọro-ẹka ke ọwa ka, ke bụ ẹhni aị dnarnụ, Chiokike wunnu aị ọro berere n'oligwe ke jaadazịgidne, ke be jíle aka badnụ wu, ke jaazị tim tọm.  
\v 2 Kam kpayarụ, a nọosnu idne k'agịda, ọ nọogwu aị ma a wuru nụ rime ọro aị ke zị n'oligwe,  
\v 3 ma a woru a lele iwo, a jọ́obu ele gba ẹto.  
\v 4 Hne a zị kọriri n'anọ-ẹhni ka, a zị nọosnu idne nụ rime awhnụwhnu, ọ bụ́o nụ a pioru ọ whọga n'anọ-ẹhni ka, kọvu ma be wosi aị anọ-ẹhni ke oligwe, ma Chiokike gbanwo anọ-ẹhni aị ke nọonwu ọnwu nụ anọ-ẹhni ke zị ọkwnukokwnu.  
\v 5 Chiokike n'iwhuru a kpụru aị ma a jiknernu ọ gbanwo ka, o nyernu aị Enine a ma ọ bụru nhne neemesi kpakara nhne jaava rikne. 
\p  
\v 6 Kam kpayarụ, mkpọma siri aị rikne ige ọbula. A mahịaru nụ nga a zị n'ọro aị n'anọ-ẹhni, a zị́la hne Chiokike zị.  
\v 7 Kwnornu nụ a noowu bụdnu hite n'ọkwnata mkpọma, ọ bụ́o nụ nhne anya nọowhnu.  
\v 8 Mkpọma siri aị rikne, ọ jaamasị aị a whọga n'anọ-ẹhni ka, wuru hne Nyenwe aị zị.  
\v 9 Ke kakwo, a pioru o mee nhne jaamasị Chiokike, ma a wu hne Nyenwe aị zị, mọbu a zị n'ọwa ka.  
\v 10 Kwnornu nụ kpakara aị joogwuzo nụ ruwhnu ngadna ikpe Karaịsi, ma nye ọbula nahọru ọgwo ẹrnu kpakara nhne a rnụrnu nga a zị bụdnu, mọbu nhne ọma mọbu nhne bụ́o ọma. 
\s1 Badnụ nụ Chiokike  //  zịri n'udno 
\p  
\v 11 Hne a mahịaru ọ tụ ogwnu Chiokike, a naarịasno ele badnụ be vakwnusi Chiokike. Chiokike mazuru aị, m neele anya nụ anụ mazuru aị masị n'echiche anụ.  
\v 12 A zá naaja ẹhni aị n'anya anụ berere, kọvu a neenye anụ oghere ma anụ gweru aị nyaa risi, ma anụ mahịa nhne anụ jaasa ele ji nhne be nọowhnu nụ ruwhnu badnụ naanya risi kakwo nhne zị nụ mkpọma badnụ.  
\v 13 Anụ neeche nụ a bụ ele ẹra naagba? Ọ bụ kwnornu Chiokike. Kọvu ọ bụru nụ a bụ ele anya dnornu, ọ bụ kwnornu anụ.  
\v 14 Ọwhnun'anya Karaịsi neeme a mee kpa a neeme. A magwụ nụ otu badnụ nwụhianu kpakara badnụ ẹnwu, ka gesiri nụ kpakara badnụ snornu a n'ẹnwu.  
\v 15 Ọ nwụhianu kpakara badnụ ẹnwu, ma ele zị bụdnu gharụ o wunu ẹhni be bụdnu, kọvu wunu Nyenwe aị nye nwụhianu be ẹnwu, ke hiri n'ẹnwu lizọ masị. 
\p  
\v 16 A zá neele badnụ anya nụ ruwhnu lele kpa ele berere neele, ọ bụ n'ezi nụ ọ bụ kpa a leru Karaịsi nụ mbọm. Kọvu a zá neeme kpam kịtna.  
\v 17 Ọ bụru nụ nye ọbula zị nụ rime Karaịsi, ọ bụ nye be kpụghariri ikne, nhne ọknani whelem, be ghọlam nhne ikne.  
\v 18 Kpakara nhne ka hi n'aka Chiokike va, nye hiteru nụ Karaịsi mee ma aị nụ ya zịri n'udno, nyee masị aị ẹrnu ma a mee ya nụ ele badnụ zịri n'udno.  
\v 19 Chiokike hiteru nụ Karaịsi neeme ma ya nụ kpakara ele badnụ zịri n'udno. Chiokike zá nọogwnu mmehie be megidne be. O nyernu aị ẹrnu a mee ya nụ ele badnụ zịri n'udno.  
\v 20 A bụ ele naadnasni anya Karaịsi, Chiokike zị nụ rime aị naarịasno. A ji Karaịsi naarịasno anụ, anụ mee ma anụ nụ Chiokike zịri n'udno.  
\v 21 Karaịsi méne mmehie, kọvu Chiokike mernu a o bụru mmehie kwnornu aị, ma a hite nụ rime a kehịa igwe nụ ome mma ke Chiokike. 
\c 6  
\p  
\v 1 Lele ele be nụ Chiokike sno nọornu ẹrnu, a naarịasno anụ kwé oru Chiokike anụ nahịaru bụru nhne etekne.  
\v 2 Ka bụ nhne Chiokike kwuru, 
\q1 “M nụrnu m anụ n'ige o gesi anụ ruwhnu ọma, 
\q2 m yinu m anụ aka n'ọbochi ọznohia.” 
\p Anụ bno nsnị, kịtna bụ ige ọ nahọru ruwhnu ọma Chiokike, kịtna bụ ọbochi ọznohia.  
\v 3 A píole badnụ ọbula piohịa nhne ọjo n'ẹrnu aị, kpayarụ a kwéle ọ bịta nhne jọokpobi badnụ ọchi n'ogodo apna. 
\p  
\v 4 Kọvu nụ kpakara nhne a neeme, a neegesi ẹhni aị lele ele ẹrnu Chiokike hite n'ọsnuta mkpọma nụ rime awhnụwhnu, nụ nhne siri rikne, nụ nhne igbugbu,  
\v 5 ma ọli nhne, ma nụ ọro ikelu, nụ mkpakpọ, nụ ẹrnu rikne, ma nụ ọka anyarna abalị, ma nụ ọgwnu wiri,  
\v 6 ma nụ ọzi rịchna, ma nụ nhne ọmuma, nụ ndidi, ma nụ ovu ọma, hite n'Enine Nsọ, n'ezi ọka ọwhnun'anya,  
\v 7 hite n'okwu ezi ọka nụ rikne Chiokike, ya nụ mgwna ọgwnu ke ome mma nụ akarikwnunga ma nụ akarita.  
\v 8 A nwernu ọson'anya agwna ige, agwna ige be ledna aị anya, agwna ige ele badnụ kparị aị, agwna ige be znarnị aị. Be neeme aị ele aghalaghala, kọvu a bụ ele kwu ezi ọka.  
\v 9 A bụ ele be máa, kọvu kpakara ele badnụ magwụ aị. A nụ lele ele nọowu ọnwu, kọvu a zị kọriri bụdnu, awhnụwhnu a naata nwée rikne gbu aị.  
\v 10 A bụ ele mkpọma sọ́ n'ọnu, kọvu a nwernu snarnịma, ele mboni, kọvu neeme ele berere ele eze. Ọ zá nhne a nwernu, kọvu kpakara nhne bụ ke aị. 
\p  
\v 11 Anụ ele Kọrinti, a kpumernu mkpọma aị kwunu anụ ezi ọka.  
\v 12 Anụ kpusnirni mkpọma anụ megidne aị, ọ bụ́o aị megidne anụ.  
\v 13 Anụ menu aị kpa a mennu anụ, m nookwu lele nụ anụ bụ rụmu m, anụ kpume mkpọma anụ. 
\s1 Ọdo aka nụ nsnị  //  gbasịri ele kwé ekwe 
\p  
\v 14 Anụ nụ ele kwé ekwe knékọta ẹhni anụ n'otu. Kịni bụ nhne ome mma nụ arụru-ẹli nwekọru? Ndaa ọzi n'otu ke iwhne n'ọchichiri nwekọru?  
\v 15 Mọbu ndaa nhne Karaịsi nụ Ekwensu neekekọ? Kịni bụ nhne nye Karaịsi nụ nye kwé ekwe nwekọru n'otu?  
\v 16 Ndaa okwerikọta ke Ọro Nsọ Chiokike nụ rẹnwu nwernu? Kwnornu nụ a bụ Ọro Nsọ Chiokike ke zị bụdnu, lele kpa Chiokike kwuru, 
\q1 “M joosno be wuru, zne izne n'esilawụru be. 
\q2 M jọobu Chiokike be, 
\q2 be jọobu ele ke m.” 
\q1  
\v 17 Kam kpayarụ, “Anụ hi nụ rime be whụya, zịri ichne, 
\q2 anụ kpátụ nhne zị́la rịchna aka, 
\q2 m jaanabnanya anụ,” ka bụ nhne Nyenwe aị kwuru. 
\q1  
\v 18 “M jọoburu Nda anụ, 
\q2 anụ jọoburu rụmu m rukna nụ rụmu m rinya. 
\q2 Ka bụ nhne Nyenwe aị ke Meli Nhne Dum kwuru.” 
\c 7  
\p  
\v 1 Ele me whnụrnu n'anya, hne a nwernu kpakara mkwna ka, a mee ẹhni aị ma a zịri rịchna ma n'anọ-ẹhni ma nụ rime enine, whọga nụ kpakara nhne ke neemeru emeru, ma a zịri nsọ kpam kpam noowu bụdnu ke nọotu ogwnu Chiokike. 
\s1 Ovu ọso n'ọnu Pọlu 
\p  
\v 2 Anụ gweru aị kwnornu nụ ọ zá badnụ ọbula a mejọru, mọbu lulu, mọbu megbu n'apna ọbula.  
\v 3 Nhne me kwno nookwu ka bụ́o ma ikpe ma anụ, lele kpa me kwuru nụ mbọm, anụ zị aị mkpa nụ mkpọma, ma a snornu anụ zịri bụdnu mọbu a snornu anụ nwụ ẹnwu.  
\v 4 M tụkwasiri m anụ mkpọma k'agịda, m ji m anụ noolu ọnu. Anụ mernu mkpọma neesi m rikne, mkpọma nọoso m n'ọnu nụ rime awhnụwhnu. 
\p  
\v 5 Nga a vaduru Masidonia, a nwée ozukwa inwe n'anọ-ẹhni, be kpaknarnụ aị ẹhni n'apna ọbula, ọgwnu n'ederezi, ogwnu nụ mkpọma.  
\v 6 Kọvu Chiokike ke naakasi ele inwe gwụru mkpọma kasiri aị mkpọma nga Taịtosi varụ.  
\v 7 Ọ bụ́o kwnornu nụ Taịtosi varụ kpọi, kọvu nkasi mkpọma anụ nyernu a. Ọ kannụ aị nhne gbasịri obirizi anụ, nụ nhne igbugbu nụ nhne gbasịri m metụru anụ nụ mkpọma. Ka mernu mkpọma sọ m n'ọnu k'agịda. 
\p  
\v 8 Ọ bụrubedi nụ ọkwukwo izi me gbarụ vuteru anụ nhne igbugbu, m nwée m mkpọma lawụru nụ me gbarụ a. Nụ mbọm, o mernu m mkpọma lawụru, nga me whnụrnu nụ ọkwukwo me gbarụ vuteru anụ nhne igbugbu ige matị.  
\v 9 Kịtna, mkpọma nọoso m n'ọnu, ọ bụ́o nụ m vuteru anụ nhne igbugbu, kọvu kwnornu nụ nhne igbugbu anụ mernu anụ tụhnasna mkpọma. Chiokike jiri nhne igbugbu anụ rnụ ẹrnu, ka neegesi nụ ọ zá nhne ọjo a mernu anụ.  
\v 10 Kwnornu nụ nhne igbugbu ke Chiokike noodubna badnụ ọ tụhnasna mkpọma dụ ọznohia, ka nwée mkpọma lawụru. Kọvu nhne igbugbu ke ọwa noodubna n'ẹnwu.  
\v 11 Anụ le kpa nhne igbugbu ke Chiokike kpahịaru anụ jiknernu ọ gọru ọnu anụ. Nhne ka kpahịaru ovu owe ẹhni, o ji anụ anya, o neerne anụ lele bẹkwnu, o metụru anụ nụ mkpọma, anụ jiknernu ọ ta nye mmehie awhnụwhnu. Anụ gesiri ẹhni anụ lele ele ikpe mána.  
\v 12 Ọ bụ n'ezi nụ me gbarụ ọkwukwo izi wam, ọ bụ́o kwnornu nye mernu nhne ọjo mọbu nye o mejọru. Kọvu m gbarụ m ma anụ mahịa nụ ruwhnu Chiokike kpa anụ noobnonu aị nsnị.  
\v 13 Ka mernu mkpọma si aị rikne. 
\p Ọ bụ́o nụ mkpọma siri aị rikne kpọi, Taịtosi mernu mkpọma sọ aị n'ọnu, kpa anụ mernu a ọ nwụdna nga ọ vakwnusiri anụ.  
\v 14 M ji m anụ noolu ọnu nụ ruwhnu a. Anụ kpásịla m iwhnerne. A nookwunu anụ ezi ọka ige ọbula, kpam masị, a jiri Taịtosi luu ọnu nụ ruwhnu anụ, anụ whnụrnu nụ ọ bụ ezi ọka.  
\v 15 Ka mernu ọwhnun'anya o nwernu hne anụ zị si rikne, nga o neechenwanya anụ noobno nsnị, kpa anụ jiri ogwnu nụ ọznu biri biri nabnanya a.  
\v 16 Mkpọma nọoso m n'ọnu nụ m nwernu rikne tụkwasi anụ mkpọma. 
\c 8  
\s1 Nkesi ke nye Karaịsi 
\p  
\v 1 Rụmu nda m, a pioru ma anụ mahịa nhne Chiokike jiri oru a rnụ n'ọgbako Chiokike ke zị nụ Masidonia.  
\v 2 Ọ bụ n'ezi nụ be gawheru agịda ọkpagbu, kọvu okne mkpọma ọso n'ọnu mernu be gweya agịda nkesi, ọ bụ n'ezi nụ be bụ ele ọwa nyịrni.  
\v 3 M naagbanụ be akebne nụ be nyernu kpa be nwernu rikne, n'ezi, kakwo kpa be nwernu rikne, hite nụ mkpọma be.  
\v 4 Be rịasnosi aị rikne ma be nwernu oghere yisi aka be n'oyinu ele Chiokike ke zị nụ Judiya aka.  
\v 5 Be mernu nhne a tụ́la anya a, be beru ọsno gweru ẹhni be nyega Nyenwe aị, nyee kwno aị hite n'echiche Chiokike.  
\v 6 Kam kpayarụ, a rịasno Taịtosi nye panịzoru ẹrnu ka, rnụrnu a zne nụ ruwhnu mee anụ rnụzu ẹrnu ọwhnun'anya ka.  
\v 7 Anụ nwernu kpakara nhne, ọkwnata ovu, nụ ikwu-ọnu, nụ nhne ọmuma, nụ ezi ọka zuru ozu nụ ọwhnun'anya anụ nwernu hne a zị. Anụ bụru masị ele zuru ozu nụ oru ke nkesi. 
\p  
\v 8 M zá m neenye anụ iwu. Kọvu m kannụ m anụ kpa ele berere nwernu mkpọma o kesi be nhne, ma m mahịa m ezi ọka ke ọwhnun'anya anụ hite nụ nhne anụ jeenye be.  
\v 9 Anụ magwụ oru ke Nyenwe aị Jizọsi Karaịsi, ọ bụ n'ezi nụ ọ bụ nye eze, kọvu o mernu ẹhni a wọmboni kwnornu anụ, ma o mee anụ bụru ele eze hite n'ọdna mboni a. 
\p  
\v 10 Ka bụ ezni me neezni anụ, ọ jọoburu ọma ọ bụru nụ anụ rnụzne ẹrnu anụ panịzoru otu awha wheru ewhe. Anụ bụ ele mbọm panịzoru ẹrnu wam, ma ele mbọm jiknernu ọ rnụ a.  
\v 11 Anụ zne nụ ruwhnu nọornu a, rnụkwo a masị. Anụ zịri gnarnagnarna nụ ọ rnụkwo ẹrnu wam hite nụ nhne anụ nwernu, lele kpa ọ zị nga anụ marnụ mmụma a.  
\v 12 Ọ bụru nụ anụ nwernu mkpọma nkesi, Chiokike jaanarnụ nkesi anụ hite nụ nhne anụ nwernu, ọ bụ́o hite nụ nhne anụ nwée. 
\p  
\v 13 A zá nookwu ma ele berere nwedna inwe ozukwa inwe, anụ bụru ele zị nụ mkpa, kọvu ma nye ọbula hnata n'otu.  
\v 14 Kịtna, agịda nhne anụ nwernu anụ jeenye be nụ mkpa be. Ige berere, be jeenwe nhne be jeenye anụ nụ mkpa anụ, ma nye ọbula hnata n'otu.  
\v 15 Lele kpa be gbarụ a n'ọkwukwo nsọ, 
\q1 “Nye chịkataru agịda nwée kakwo 
\q2 nye wam ke chịkataru matị, ke ọ chịkataru zunnu a.” 
\s1 Be ziznernu Taịtosi  //  Kọrinti 
\p  
\v 16 M nọotunu Chiokike mmamma nye yisiri nụ mkpọma Taịtosi, nhne gbasịri anụ lele kpa ọ zị nụ mkpọma m.  
\v 17 O kweruru, ọ bụ́o kwnornu nụ a kannụ a, kọvu o jiknernu hite nụ mkpọma a ọ va.  
\v 18 A neeziya ya nụ otu nnwọ nda ke nwernu igwugwu nụ kpakara ọgbako Chiokike n'ọkpo okwo izi ọma.  
\v 19 Tụkwasi nụ ka, ọgbako Chiokike họhiaru a ma o snornu aị vuru nkesi ka zne Judiya. Ẹrnu ka neenye Nyenwe aị igwugwu, neegesi nụ a nwernu mkpọma o yisi aka n'ẹrnu ka.  
\v 20 A neeze ẹhni aị ọ zị badnụ ọbula ma aị ikpe kpa a neeke agịda nkesi.  
\v 21 A naagbalị o mee nhne kwesiri ekwesi, ọ bụ́o n'anya Chiokike kpọi, kọvu ma n'anya ele badnụ. 
\p  
\v 22 A neeziya otu nnwọ nda berere yisinu be, bụ nye a kparụ iru agịda ige, whnụ nụ a nwernu rikne kwnata a mkpọma. Nụ olu ka, kịtna, o jiknernu o yinu anụ aka, ke kakwo kpa ọ tụkwasiri anụ mkpọma.  
\v 23 Nhne gbasịri Taịtosi, ọ bụ nye me nụ a nọornu ẹrnu, neenyinu anụ aka. Rụmu nda ele ya nụ be sno bụ ele dnasni anya ọgbako Chiokike, be bụ igwugwu Karaịsi.  
\v 24 Anụ gesi be ọwhnun'anya anụ ma kpakara ọgbako Chiokike whnụ nhne kpayarụ a jiri anụ luu ọnu n'ezi. 
\c 9  
\s1 O yinu ele Karaịsi aka 
\p  
\v 1 Ọ zá mkpa nụ me jaagbanụ anụ ọkwukwo gbasịri o yinu ele Chiokike ele zị nụ Judiya aka.  
\v 2 M maam nụ anụ jiknernu o yinu be aka, m ji m anụ lunu ele zị nụ Masidonia ọnu. M kanụ m be nụ rụmu nda aị ele zị nụ Akaya jiknernu o yi aka hite n'awha ke wheru ewhe. Nga be nụrnu nụ anụ jiknernu o kesi nhne, mkpọma be kwnalizọru o mee kpam.  
\v 3 Kọvu m neeziya rụmu nda ka, ma ọnu a jiri anụ luu gharụ ọ bụ nhne etekne. Lele kpa me kwuru, anụ bịta nhne nkesi anụ,  
\v 4 ọ zị ele Masidonia snornu m va whnụ nụ anụ jíknernune, ọ jọobunu aị nhne iwhnerne, ke kakwo iwhnerne jọotu anụ k'agịda.  
\v 5 Kam kpayarụ, me rịasno rụmu nda ele ka be beru ọsno va, ma be whnụ anụ jaabịta nkesi anụ kweru mkwna sụ me va. Ka jeegesi nụ anụ nyernu hite nụ mkpọma anụ, ọ bụ́o nụ be kwnagidnernu anụ. 
\p  
\v 6 Anụ chenwanya nụ nye kpasịri mkpụru matị jọoghohia mkpụru matị, nye wam ke kpasịri agịda mkpụru jọoghohia agịda mkpụru.  
\v 7 Nye ọbula nyee lele kpa o kpebiri nụ mkpọma a, ọ bụ́o nụ mkpọma lawụru kwnornu nụ be karụ be nyee. Chiokike whnụrnu nye wam jiri mkpọma ọma a nyee n'anya.  
\v 8 Chiokike nwernu rikne o nyee anụ karụkwo kpa ọ zị anụ mkpa, ma anụ nwernu nhne kpakara ige, nụ karụkwo kpa anụ jeeji o mee nhne bụru ọma.  
\v 9 Lele kpa be gbarụ a n'ọkwukwo nsọ, kaa, 
\q1 “O neenye ele mboni k'agịda, 
\q2 ome mma a jaazị ọkwnukokwnu.” 
\p  
\v 10 Chiokike, nye neenye nye ẹrnu ẹkwu mkpụru ọkpukpa nụ wiri ele badnụ jeeri, jeeme kpakara mkpụru anụ so oso, mịnya agịda mkpụru hite nụ nkesi anụ nyernu hite nụ mkpọma ọma anụ.  
\v 11 O jeeme anụ ba agịda nụ kpakara nhne, ma anụ bụru ele jeekesi ele badnụ nhne ige ọbula, ke jeeme ele badnụ tụnu Chiokike mmamma kwnornu anụ. 
\p  
\v 12 Ẹrnu ọma ka anụ nọornu zá neeme ele Chiokike riji rụwho kpọi, kọvu o neeme ele badnụ nọotunu Chiokike mmamma k'agịda.  
\v 13 Lele kpa ẹrnu ọma ka neegesi nụ anụ bụ ele ezi ọka, ele badnụ jaaznarnị Chiokike kwnornu nụ anụ noobno nsnị izi ọma Karaịsi ke anụ kwuhịaru, anụ neeji mkpọma ọma neekesi be nụ ele berere nhne.  
\v 14 Be jeeji mkpọma ọwhnun'anya be kpenu anụ okpukpe kwnornu oru Chiokike ke zị agịda hne anụ zị.  
\v 15 Ngwa ma a tụnu Chiokike mmamma kwnornu nkesi a ke ọnu jọ́okowali. 
\c 10  
\s1 Pọlu gọru ọnu ẹrnu a 
\p  
\v 1 Mawa Pọlu, naarịasno anụ, me nye be karụ nụ m bụ m nye mési rikne nga me zị nụ ruwhnu anụ, kọvu nye nwernu anya rikne hne anụ zị́la. M ji m ọzi wọhnernerne nụ mkpọma ọma Karaịsi, naarịasno anụ, anụ bikno,  
\v 2 anụ mée m, m bụru nye anya rikne hne anụ zị nga me varụ, kwnornu nụ m nwernu m rikne nwe anya rikne n'ẹhni ele nookwu nụ a noowu bụdnu lele kpa ele ọwa noowu.  
\v 3 Ọ bụ n'ezi nụ a zị n'ọwa, kọvu a zá nọolu ọgwnu lele kpa ele ọwa nọolu.  
\v 4 Kwnornu nụ mgwna ọgwnu aị bụ́o ke badnụ, kọvu ọ zị rikne nụ Chiokike ke naakwnadna hne be wusiri rikne. A naakwnadna kpakara agịrigo  
\v 5 nụ kpakara nhne ke noovulizọ ẹhni a olu megidne ọmahia Chiokike, a nọodoru kpakara echiche n'ọgwnu mee be bnonu Karaịsi nsnị.  
\v 6 Nga anụ ghọru ele bnozuru nsnị, a jeejiknernu ọ ta kpakara nye ọbula ke zá noobno nsnị awhnụwhnu. 
\p  
\v 7 Anụ neele kpakara nhne anya n'olu kpọi. Ọ zị nye ọbula n'esilawụru anụ ke neeche nụ ọ bụ nye Karaịsi? Nye wam che kwno echiche, kwnornu nụ a bụ ele Karaịsi lele nye wam.  
\v 8 Ọ bụrubedi nụ me gweru rikne Nyenwe aị nyernu aị mee oknomokno k'agịda, iwhnerne jọ́otu m. Nyenwe aị nyernu aị rikne o wulizọ anụ olu lele ọro, ọ bụ́o rikne ọ kwnadna anụ akwnadna.  
\v 9 M píole m o ji ọkwukwo izi me gbannụ anụ kpasị anụ ogwnu.  
\v 10 Otu badnụ jaakaa, “Ọkwukwo Pọlu naagba siri rikne, nọotu ogwnu, kọvu, nga aị nụ a zịri, o nwée rikne, ikwu-ọnu a bụ nhne etekne.”  
\v 11 Nye wam mahịa nụ ọ zá nhne zị ichne nụ nhne a gbarụ n'ọkwukwo nga a zị ikere nụ nhne a jeeme nga aị nụ anụ zị. 
\p  
\v 12 Kwnornu nụ a zá nọogwnu ẹhni aị n'esilawụru ele ji ẹhni be nọotu nhne zị olu k'agịda. Ele ji ẹhni be nọotunu n'ẹhni be, neekpe ẹhni be ikpe n'iwu ke be nyernu, bụ ele nwée akọniche.  
\v 13 Kọvu nụ oknomokno aị zá neewhe hne a nwernu rikne, oknomokno aị bụ n'ẹrnu Chiokike nyernu aị, bụ ke dụru nụ hne anụ zị.  
\v 14 Hne ọ bụ nụ ẹrnu aị zị n'esilawụru anụ, a gáwhele a. A vuru izi ọma Karaịsi vakwnusi anụ.  
\v 15 A zá neeji ẹrnu ele berere rnụrnu naanya risi. Ẹrnu kam wheru hne Chiokike nyernu. Kọvu a neele anya nụ ọkwnata mkpọma anụ jooso oso, ma a nwe rikne rnụ agịda ẹrnu n'esilawụru anụ dụ hne Chiokike nyernu aị.  
\v 16 Nga wam, a jeenwe rikne kpọ okwo izi ọma nụ mba berere whe anụ. Kọvu a jéeji ẹrnu ele berere rnụrnu nyaa risi. 
\p  
\v 17 Lele kpa ọkwukwo nsọ kwuru, “Nye ọbula ke jeeme oknomokno, o mee oknomokno nụ nhne Nyenwe aị rnụrnu.”  
\v 18 Kwnornu nụ nye naaja ẹhni a mma bụ nhne etekne, kọvu nye wam Nyenwe aị naaja mma bụ nhne. 
\c 11  
\s1 Pọlu nụ ele izi  //  aghalaghala 
\p  
\v 1 Ọ jaamasị m ọ bụru nụ anụ jeenwe rikne nagidne iwhnirniwhno m, bikno, anụ gweru m.  
\v 2 Mkpọma m zị nụ hne anụ zị lele Chiokike, anụ nụ lele nyerinya máa nyerukna zị snam me kweru ọ nịsi otu badnụ, ke bụ Karaịsi.  
\v 3 Kọvu ogwnu nọotu m nụ be joolulu mkpọma anụ, lele kpa agwọ wam jiri aghịgho rnawhu Ivu, mee anụ gharụ o gweru kpakara mkpọma anụ kpenu Karaịsi.  
\v 4 Kwnornu nụ anụ jiri ẹso nahọru nye wam ke znirni anụ Jizọsi berere bụ́o Jizọsi ke a znirni anụ, nụ enine berere nụ izi ọma berere ke bụ́o ke a znirni anụ. 
\p  
\v 5 Kọvu ọ bụ́o nụ m zị m matị kakwo ele izi ka anụ kaa nụ be ka m mma.  
\v 6 Nyele ma, m máam kpa be kwu ọka sọ n'ọnu, kọvu m magwụ m nhne, a mernu ka whụya iwhne hne anụ zị ige ọbula ma nụ ọnodi ọbula. 
\p  
\v 7 M náge m anụ nhne ọbula nga me znirni anụ izi ọma Chiokike, m gwednarnụ m ẹhni m ẹli ma anụ bụru ele be gwelizọru olu. Kị ọ bụ nhne ọjo me mernu sa?  
\v 8 M nahịaru m ọgbako Chiokike berere nhne me jiri nọornu ẹrnu n'esilawụru anụ.  
\v 9 Ige me nụ anụ zị, m kpáknage m anụ ẹhni nụ ịwai nga me zị nụ mkpa, rụmu nda ele hi nụ Masidonia va gweyarụ kpakara nhne zị m mkpa. Lele kpa me neeme, m jọ́obu ivu nyee anụ tna mọbu ekile.  
\v 10 Hite n'ezi ọka Karaịsi ke zị nụ rime m, ọ zá badnụ ọbula ke zị n'Akaya jeenwe rikne kpusni ọnu m, kpa me naanya risi.  
\v 11 Ndaa nhne me jiri kwu kpa? Me whnụ́ge anụ n'anya sa? Chiokike magwụ nụ m whnụrnu m anụ n'anya. 
\p  
\v 12 M jaazị kọriri neeme kpa me neeme, ma ele izi ka gharụ o nwe oghere be noopio gweru luu ọnu, kaa nụ be nụ aị neeme otu nhne.  
\v 13 Be bụ ele izi aghalaghala, be bụ́o ezi, be ji ẹrnu be naagha ọgha, ma be nụ lele ele izi Karaịsi n'ezi.  
\v 14 O jí anụ anya, Setani n'iwhuru a gbanwornu ẹhni a lele enine izi ke iwhne.  
\v 15 Ọ bụ́o okne nhne ọ bụru nụ ele ẹrnu a gbanwornu ẹhni be ma be nụ lele ele ẹrnu ome mma. Be jeeji aka ẹrnu be kwụ be ọgwo ẹrnu. 
\s1 Awhnụwhnu Pọlu lele  //  nye izi Karaịsi 
\p  
\v 16 M nookwu kwno a berere, ọ zá nye kwu m nye iwhnirniwhno. Ọ bụru nụ ọ bụ nhne me bụ, anụ gweru m kpam, ma m gweru m nhne matị luu ọnu.  
\v 17 Nhne me nookwu kịtna bụ́o nhne Nyenwe aị pioru me kwu, ke gbasịri olu ọnu ka, m nookwu lele nye iwhnirniwhno.  
\v 18 Agịda ele badnụ noolu ọnu lele kpa ele badnụ noolu, m jeeme kpam.  
\v 19 Anụ bụ ele ji ovu ọso n'ọnu nagidne ele iwhnirniwhno, ọ bụ n'ezi nụ anụ bụ ele nwernu akọniche.  
\v 20 Anụ nagidnernu ele mernu anụ lele ọhi, nahọru anụ nhne, kwnagharị anụ, gwuzote ẹhni a, gbọ anụ aka nụ nti.  
\v 21 Ka nọotu m iwhnerne nụ a nwée rikne mee anụ kpam. 
\p Kọvu ọ bụru nụ nye ọbula luu ọnu nhne ọbula, m jeeme masị kpam. M nookwu lele nye iwhnirniwhno.  
\v 22 Be bụ ele Hiburu? M bụ m masị. Be bụ ele Izirẹli? M bụ m masị. Be bụ ele hi n'avnụrnu Ebereham? M bụ m masị.  
\v 23 Be bụ ele ẹrnu Karaịsi? Ẹra naagba m sa? M bụ m nye ẹrnu Karaịsi kakwo be. M nọornu ẹrnu kakwo be. M lala m ikelu agịda ige kakwo be, be pnịarnu m nhne k'agịda kakwo be, agịda ige ọ gwnarnụ matị m nwụ.  
\v 24 Mgba isne ele Ju pnịarnu m nri ẹto nụ tolu ọnu mbịnibini.  
\v 25 Ele Rom lịri m isisi mgba ẹto, be tụru m akaworugwu otu mgba, ọgbo me zị nụ rime a kpuru mgba ẹto, m dazịri m nụ rime mini iwhnehnie nụ abalị.  
\v 26 Kpa me neezne izne ige ọbula, m neeze bụdnu nụ rime mini, ma n'aka ele buznu, m neeze bụdnu n'aka ele Ju ma n'aka ele bụ́o ele Ju. Nhne oze bụdnu nụ rime ẹli-ọhna, ma nụ rime ẹli-ịkpa, neeze bụdnu n'okne abajị, neeze bụdnu n'aka rụmu nda aghalaghala.  
\v 27 M nọornu ẹrnu, nọodoli ndọli, ma n'ọka anyarna abalị, ma wiri ọgwnugwnu nụ akpịri ọkpo bẹkwnu, m dazịla m agịda ige nwée wiri o riri, ma nụ iyi ọtutu, m nwée m iwo o kpusni ẹto.  
\v 28 Be gweme kpakara nhne ka, nhne naakpa m kpakara ọbochi bụ nhne gbasịri ọgbako Chiokike.  
\v 29 Ndaa nye rikne gwụru ke rikne gwụ́lam? Ndaa nye dnabnarnụ nụ mmehie ke mkpọma lála m mini, neerne m bẹkwnu? 
\p  
\v 30 Ọ bụru nhne be luu ọnu, m jeeji kpakara nhne neegesi nụ m bụ nye nwée rikne noolu ọnu.  
\v 31 Chiokike nụ Nda Nyenwe aị Jizọsi, nye nwe ọznarni ọkwnukokwnu, magwụ nụ m nookwu ezi ọka.  
\v 32 Nga me zị nụ Damasịkosi, nye nẹechi ẹli, nye zị nụ mkpururu Eze Arẹtasi, bịtaru ele neese ọnu-mgbo ẹli-ọhna, be nwudne m.  
\v 33 Kọvu be yisiri m nụ rime nkịta garụ n'ọnunu zị nụ mkpọ ẹli-ọhna kwuhala m n'ẹli a, ọ bụ kpa me jiri gbawhunahọru a. 
\c 12  
\s1 Ọwhnurninya Pọlu 
\p  
\v 1 M joolu ọnu, ọ bụ n'ezi nụ ọ zá nhne zị nụ rime a. Kọvu m jookwu ọka gbasịri nhne me whnụrnu nụ nhne Nyenwe aị kpumennu m.  
\v 2 M maam otu nye Karaịsi nri nụ awha ẹno wheru ewhe, nye be gwelizọru zne oligwe k'ẹto. (Ọ bụru nụ ọ bụ n'anọ-ẹhni mọbu ọ bụ́o n'anọ-ẹhni, m máam, Chiokike kpọi ma.  
\v 3 Berere, m máam ma ọ bụ n'anọ-ẹhni ma ọ bụ́o n'anọ-ẹhni, Chiokike kpọi ma.) Nhne me magwụ bụ nụ  
\v 4 be gwelizọru badnụ ka zne Paradasị. Ọ nụrnu nhne ke be jáagbali n'ọkwukwo, nhne ọnu badnụ jéenwe rikne kwu.  
\v 5 M jeeji nyerukna ka nọolu ọnu, m jéeji ẹhni m noolu ọnu, okwolem nhne neegesi nụ m bụ m nye nwée rikne.  
\v 6 Ọ bụru nụ me luu ọnu m jọ́obu nye iwhnirniwhno, kwnornu nụ m nookwu ezi ọka. Kọvu m jóolu ọnu, ọ jáamasị m badnụ ọbula gweru m kakwo kpa o gweruru m hite nụ nhne ọ whnụrnu me mernu nụ ke ọ nụrnu me kwuru.  
\v 7 Lele kpa ọ bụ́o ọma me vulizọ ẹhni m olu kwnornu okne nhne me whnụrnu, be nyernu m nhne igbugbu n'ẹhni m. Ọ bụ nye izi ke Setani, ma ọ kpakna m ẹhni ma m gharụ m o luu ọnu.  
\v 8 M rịoru m Nyenwe aị nhne gbasịri a mgba ẹto, ma o gweme a n'ẹhni m.  
\v 9 Ka bụ nhne ọ sarụ m, “Oru m zunnem jị, iknernema m zuru ozu nga i nwée rikne.” Kam kpayarụ, mkpọma nọoso m n'ọnu me luu ọnu nụ m nwée m rikne, ma rikne Karaịsi whụya iwhne nụ rime m.  
\v 10 Kam kpayarụ, m bụ m nye nwée rikne. Ele badnụ naakpasị m iwhnerne, be ta m awhnụwhnu, be kpagburu m. Kpakara nhne igbugbu me gawheru kwnornu Karaịsi jiri m rụwho. Nga me nwée rikne, iknernema zị m n'ẹhni. 
\s1 Ele Kọrinti metụru Pọlu  //  nụ mkpọma 
\p  
\v 11 Anụ mernu m mee lele nye iwhnirniwhno. Anụ bụ ele kwesiri o kwu nhne ọma gbasịri m, kwnornu nụ ele izi anụ wam, ke anụ kaa nụ be ka m mma, béle m ọsno. Ọ bụ n'ezi nụ ọ zá nhne me bụ.  
\v 12 Kwnornu n'ezi, nhne neegesi nhne nye izi whụyaru iwhne n'esilawụru anụ. Be bụ ẹrnu elekema, nụ ẹrnu ndu-ẹhni nụ ẹrnu rikne zị ọdo nụ ọdo me jiri ndidi rnụ.  
\v 13 Ndaa nhne me mernu ọgbako Chiokike ele berere ke me méne hne anụ zị? Ọ bụ nụ m kwéle m ọ bụru nhne ivu rịnya hne anụ zị? Anụ gbarụnu m nhne ọjo ka. 
\p  
\v 14 Ka jọobu mgba ẹto me jiknernu ọ vakwnusi anụ. M jọ́oburu ivu rịnya hne anụ zị. Anụ zị m mkpa, ọ bụ́o nhne anụ nwernu. Ọ bụ́o rụmu naakpabịtanu ele mụrnu be ẹkwnu, kọvu ele nda nụ nne naakpabịtanu rụmu be ẹkwnu.  
\v 15 Ọ jaamasị m o nyega anụ nhne me nwernu. Owe! M jeenye iwhuru m nụ risi anụ ma m yisinu m anụ aka. Ka o jeeme anụ bọ́ whnụ m n'anya, lele kpa me whnụrnu anụ n'anya k'agịda?  
\v 16 Anụ jeekweru, nụ m bụ́o m ivu rịnya nyee anụ. Hne me bụ nye aghịgho, m ji m aghịgho nwudne anụ.  
\v 17 Ndaa? Ele me ziyannu anụ, m jiri be nahọru anụ nhne sa?  
\v 18 M rịasnornu m Taịtosi ọ va, ya nụ nye Karaịsi berere, anụ jaakaa nụ Taịtosi nahọru anụ nhne? Me nụ ya a jíle otu enine mee nhne lele nụ a bụ otu badnụ? 
\p  
\v 19 Anụ neeche nụ a noopio ọ gọru ẹhni aị nụ hne anụ zị? Ọ́za! A nookwu ọka nụ ruwhnu Chiokike lele ele Karaịsi, kpakara nhne a neeme bụ ma anụ bụru ele zị kwem lele ele a whnụrnu n'anya.  
\v 20 Ogwnu nọotu m nụ me vadu n'esilawụru anụ, m jọowhnu nụ anụ zị ichne, ke bụ́o nhne me leru anya a. Anụ jọowhnu masị nụ m zị m ichne, ke bụ́o nhne anụ leru anya a. Ogwnu nọotu m nụ m jọowhnu oknorno nụ okwno-awụwa, mkpọma bẹkwnu nụ okewa, ọnu-ọjo, izno, oknomokno nụ mkpakpọ.  
\v 21 Ogwnu nọotu m nụ me va berere nụ Chiokike m jeegwedna m ẹli nụ ruwhnu anụ, m jaakwa ẹkwna kwnornu agịda ele mernu mmehie ke kwéle ọ tụhnasna, hite nụ nhne zá rịchna be mernu, ke bụ ome ọyi n'apna tụ iwhnerne. 
\c 13  
\s1 Ọdo aka nụ nsnị ipne-aznụ 
\p  
\v 1 Ka jọobu mgba ẹto me naava lekasi anụ. “Kpakara nhne be bnornu badnụ, jeenwerịri ele akebne lawụru mọbu ẹto,” lele kpa ọkwukwo nsọ kwuru.  
\v 2 Lele kpa me kannụ anụ nga me varụ ke mgba lawụru, ele mehieru n'ige wheru ewhe, nụ kpakara ele berere, m nookwu a berere kpa me zị ikere, me va kwno, kpakara be jaata awhnụwhnu mmehie be.  
\v 3 Hne anụ noopio nhne ke neegesi nụ Karaịsi ji m nookwu ọka, ọ bụ́o nye nwée rikne n'esilawụru anụ kọvu o jeegesi iknernema a hne anụ zị.  
\v 4 Ọ bụ n'ezi nụ be gburu a n'énwe rikne, kọvu ọ zị bụdnu hite nụ iknernema Chiokike. A bụ ele nwée rikne nụ rime Karaịsi, kọvu hne anụ zị a joosno a zịri bụdnu n'iknernema Chiokike. 
\p  
\v 5 Anụ nyosnama ẹhni anụ lekasi ma anụ zị kọriri bụdnu n'ọkwnata mkpọma. Ọ bụ nụ anụ máa Karaịsi Jizọsi wu nụ rime anụ? Okwolem ma anụ dnarnụ adna.  
\v 6 M kweru m nụ anụ jaamahịa nụ a bụ́o ele dnarnụ adna.  
\v 7 A naarịasno Chiokike, anụ mée nhne ọjo. Ọ bụ́o ma ele badnụ kaa nụ a bụ ele ọma, kọvu ma anụ mee nhne ke kwesiri, ọ bụbedi nụ a nụ lele ele dnarnụ adna.  
\v 8 A jéenwe rikne mee nhne megidne ezi ọka, kọvu dasịnu ezi ọka n'ikwnu.  
\v 9 Mkpọma nọoso aị n'ọnu nga a nwée rikne, kọvu nụ anụ nwernu rikne. A neekpe ma anụ bụru ele zuru ozu.  
\v 10 Kam kpayarụ, me naagbanụ anụ ọkwukwo ka kpa me zị ikere, ma ọ bụru me va, m jéeme anụ nhne rikne hite n'iknernema Nyenwe aị nyernu m, rikne o wulizọ anụ olu lele ọro, ọ bụ́o ọ kwnadna anụ akwnadna. 
\s1 Obekwu ikwu ipne-aznụ 
\p  
\v 11 N'ipne-aznụ, rụmu nda m, anụ dazịkwaru nkarị. Anụ gbalị dụ ozuzu. Anụ bno nsnị nụ nhne me nọorio anụ, anụ bụru ele nwernu otu mkpọma, anụ wuru n'udno. Chiokike ke ọwhnun'anya nụ udno dazịgidnenu anụ. 
\p  
\v 12 Anụ bekwurita ibne anụ lele rụmu nda.  
\v 13 Kpakara ele nsọ Chiokike neebekwu anụ.  
\v 14 Oru ke Nyenwe aị Jizọsi Karaịsi, ọwhnun'anya ke Chiokike, nụ owugidne ke Enine Nsọ dazịnu kpakara anụ.