\id ECC - Biblica® Open Ndebele Contemporary Bible
\h UMtshumayeli
\toc1 UMtshumayeli
\toc2 UMtshumayeli
\toc3 Mtsh
\mt1 UMtshumayeli
\c 1
\s1 Konke Kuyize
\p 
\v 1 Amazwi oMtshumayeli, indodana kaDavida inkosi yaseJerusalema:
\q1 
\v 2 “Ize! Ize!”
\q2 kutsho uMtshumayeli.
\q1 “Ize elipheleleyo!
\q2 Konke kuyize.”
\b
\q1 
\v 3 Umuntu uzuzani ngawo wonke umsebenzi wakhe awusebenza nzima
\q2 ngaphansi kwelanga?
\q1 
\v 4 Izizukulwane ziyafika, izizukulwane ziyedlula,
\q2 kodwa umhlaba umi lanini.
\q1 
\v 5 Ilanga liyaphuma njalo ilanga liyatshona,
\q2 liphinde liphange libuyele lapho eliphuma khona.
\q1 
\v 6 Umoya uphephethela eningizimu
\q2 ujike uye enyakatho;
\q1 uyabhoda, ubhode njalo
\q2 ujinge ubuyela endleleni yawo.
\q1 
\v 7 Zonke izifula zigelezela olwandle,
\q2 kodwa ulwandle kalugcwali.
\q1 Endaweni lapho izifula ezidabuka khona
\q2 zicina zibuyela khona njalo.
\q1 
\v 8 Zonke izinto ziyadina,
\q2 lokho okungelandiswe muntu.
\q1 Ilihlo kalidinwa yikubona,
\q2 lendlebe layo kayigcwali ngokuzwa.
\q1 
\v 9 Lokho okwake kwaba khona kuzakuba khona njalo;
\q2 okwake kwenziwa kuzakwenziwa njalo;
\q2 akulalutho olutsha ngaphansi kwelanga.
\q1 
\v 10 Kukhona yini umuntu angathi ngakho,
\q2 “Khangela! Lolulutho lutsha?”
\q1 Selwake lwaba khona ngaphambili, kudala;
\q2 lwalukhona singakabi khona.
\q1 
\v 11 Kayikho imikhumbulo ngabantu bakudala,
\q2 njalo lalabo abezayo abayikukhunjulwa
\q2 yilabo abalandelayo.
\s1 Ukuhlakanipha Kuyize
\p 
\v 12 Mina Mtshumayeli, ngangiyinkosi yako-Israyeli eJerusalema.
\v 13 Ngazinikela ekufundeni lokudingisisa ngolwazi konke okwenziwayo ngaphansi kwezulu. Unzima kangakanani umthwalo uNkulunkulu awethese abantu!
\v 14 Sengizibonile zonke izinto ezenziwayo ngaphansi kwelanga; zonke kazitsho lutho, kuyikuxotshana lomoya.
\q1 
\v 15 Okutshileneyo kungaze kwaqondiswa;
\q2 okungekho kungaze kwabalwa.
\p 
\v 16 Ngacabanga ngedwa ngathi, “Khangela, sengikhulile njalo kwanda ukuhlakanipha kwami okudlula bonke asebake babusa eJerusalema ngaphambi kwami; sengibe lakho ukuhlakanipha okukhulu lolwazi.”
\v 17 Ngasengizimisela ukuzwisisa ukuhlakanipha, njalo lokuphambana ingqondo lobuwula, kodwa ngafunda ukuthi lokhu lakho kuyikuxotshana lomoya.
\q1 
\v 18 Phela ngokwanda kokuhlakanipha kuyanda lokukhathazeka;
\q2 ukwandisa ulwazi yikwandisa usizi.
\c 2
\s1 Ukuzithokozisa Kakusizi Lutho
\p 
\v 1 Ngacabanga ngenhliziyo ngathi, “Kulungile, ake ngizame ukuzithokozisa ngibone ingabe kuhle yini.” Kodwa lokho lakho kwakhanya kuyize.
\v 2 Ngathi, “Ukuhleka kuyibuthutha. Ukuzithokozisa khona kusizani?”
\v 3 Ngazama ukuzithabisa ngewayini, ngisenza ubuwula kodwa ingqondo yami ilokhu ingikhokhela ngokuhlakanipha. Ngangifuna ukubona ukuthi kuyini okumlungeleyo umuntu ukuthi akwenze lapha ngaphansi kwezulu ngezinsukwana lezo zokuphila kwakhe.
\p 
\v 4 Ngaqalisa imisebenzi emikhulu: ngazakhela izindlu ngahlanyela amavini.
\v 5 Ngasungula izivande lezigcawu zokubukwa ngahlanyela kuzo yonke imihlobo yezihlahla lezithelo.
\v 6 Ngenza iziziba zamanzi okuthelela izihlahla ezazikhula kuhle.
\v 7 Ngathenga izigqili zesilisa lezesifazane, ngilezinye futhi izigqili ezazalelwa emzini wami. Ngaba lemihlambihlambi yenkomo lezimvu okwedlula bonke abake babakhona eJerusalema ngaphambi kwami.
\v 8 Ngabuthelela isiliva legolide, kanye lempahla yamakhosi eligugu ivela ezigodini. Ngazidingela abahlabeleli besilisa labesifazane, lesithembo esikhulu, khona okujabulisa inhliziyo yendoda.
\v 9 Ngaba mkhulu ngokwedluleyo kulaloba ngubani owaba seJerusalema ngaphambi kwami. Phakathi kwayo yonke inyakanyaka le ukuhlakanipha kwami kwahlala kukhona.
\q1 
\v 10 Angizincitshanga lutho olwalufiswa ngamehlo ami;
\q2 inhliziyo yami angiyalelanga layiphi intokozo.
\q1 Inhliziyo yami yathokoza ngawo wonke umsebenzi wami,
\q2 lokhu kwaba ngumvuzo wezithukuthuku zami.
\q1 
\v 11 Kanti lanxa ngahlolisisa konke okwenziwa yizandla zami
\q2 lalokho engangibhensela ukukuzuza,
\q1 konke kwakuyize, yikuxotshana lomoya;
\q2 kwakungela nzuzo ngaphansi kwelanga.
\s1 Ukuhlakanipha Lobuwula Kuyize
\q1 
\v 12 Ngasengigxilisa imicabango yami ekuhlolisiseni ukuhlakanipha,
\q2 njalo lobuhlanya kanye lobuwula.
\q1 Kambe angenzani othatha isikhundla senkosi
\q2 ngaphandle kwalokho obekuvele sekwenziwe?
\q1 
\v 13 Ngabona ukuhlakanipha kungcono kulobuwula,
\q2 njengokukhanya kungcono kulomnyama.
\q1 
\v 14 Umuntu ohlakaniphileyo ulamehlo ekhanda,
\q2 ikanti isiwula sihamba ebumnyameni;
\q1 kodwa ngacina sengibona
\q2 ukuthi isiphetho sabo bonke sinye.
\p 
\v 15 Ngasengicabanga enhliziyweni yami ngathi,
\q1 “Isiphetho sesiwula sizangehlela lami.
\q2 Pho, ngizuzani ngokuhlakanipha?”
\q1 Ngathi ngenhliziyo yami,
\q2 “Lokhu lakho kuyize.”
\q1 
\v 16 Ngoba umuntu ohlakaniphileyo, njengesiwula,
\q2 akazukukhunjulwa kokuphela;
\q2 ngezinsuku ezizayo bobabili bazakhohlakala.
\q1 Njengesiwula, umuntu ohlakaniphileyo laye uzakufa!
\s1 Ukusebenza Nzima Kuyize
\p 
\v 17 Yikho-ke ngasengikuzonda ukuphila, ngoba umsebenzi owenziwayo ngaphansi kwelanga wawubuhlungu kimi. Wonke uyize, yikuxotshana lomoya.
\v 18 Ngazizonda zonke izinto engangiziginqele ngaphansi kwelanga, ngoba ngimele ngitshiyele lowo oza ngemva kwami.
\v 19 Njalo ngubani owaziyo ingabe uzakuba ngumuntu ohlakaniphileyo loba isiwula? Kodwa nguye ozalawula wonke umsebenzi wamaginqo ami lobungcitshi bami. Lokhu lakho kuyize.
\v 20 Ngalokho inhliziyo yami yaqalisa ukuphela amandla ngikhumbula konke lokho engakuginqelayo ngaphansi kwelanga.
\v 21 Ngoba umuntu angenza umsebenzi wakhe ngokuhlakanipha, ngolwazi langamasu, kodwa utshiyela konke alakho komunye ongazange akusebenzele. Lokhu lakho kuyize, kungumnyama.
\v 22 Umuntu uzuzani ngakho konke ukusebenza nzima langokutshikatshika kabuhlungu lapha emhlabeni?
\v 23 Ubuhlungu umsebenzi wakhe awenzayo kuzozonke insuku zokuphila kwakhe; kwala kanye lebusuku umkhumbulo wakhe kawuphumuli. Lokhu lakho kuyize.
\p 
\v 24 Akukho okungcono emuntwini ngaphandle kokuthi adle, anathe njalo azuze ukusuthiseka ngomsebenzi wakhe. Lokhu lakho ngiyakubona ukuthi kuvela kuNkulunkulu,
\v 25 ngoba ngaphandle kwakhe ngubani ongadla kumbe azuze intokozo?
\v 26 Kulowo omthokozisayo uNkulunkulu umupha ukuhlakanipha, ulwazi lokuthaba, kodwa koyisoni umupha umsebenzi wokuqoqa lokulonda inotho ukuze ayiphe lowo othokozisa uNkulunkulu. Lokhu lakho kuyize, yikuxotshana lomoya.
\c 3
\s1 Konke Kulesikhathi Sakho
\q1 
\v 1 Zonke izinto zilesikhathi sazo,
\q2 konke okwenziwayo ngaphansi kwelanga kulesibanga sakho:
\b
\q2 
\v 2 isikhathi sokuzalwa lesikhathi sokufa,
\q2 isikhathi sokuhlanyela lesikhathi sokusiphuna,
\q2 
\v 3 isikhathi sokubulala lesikhathi sokuphilisa,
\q2 isikhathi sokubhidliza lesikhathi sokwakha,
\q2 
\v 4 isikhathi sokukhala lesikhathi sokuhleka,
\q2 isikhathi sokulila lesikhathi sokugida,
\q2 
\v 5 isikhathi sokuchithiza amatshe lesikhathi sokuwabutha,
\q2 isikhathi sokugona lesikhathi sokunina,
\q2 
\v 6 isikhathi sokudinga lesikhathi sokukhalala,
\q2 isikhathi sokugcina lesikhathi sokulahla,
\q2 
\v 7 isikhathi sokudabula lesikhathi sokuthunga,
\q2 isikhathi sokuthula lesikhathi sokukhuluma,
\q2 
\v 8 isikhathi sokuthanda lesikhathi sokuzonda,
\q2 isikhathi sempi lesikhathi sokuthula.
\p 
\v 9 Umuntu osebenzayo uzuzani na ngokusadalala kwakhe?
\v 10 Sengiwubonile umthwalo uNkulunkulu awethese abantu.
\v 11 Yonke into uyenze yabanhle ngesikhathi sayo. Wamupha umuntu iphakade enhliziyweni yakhe; kodwa abantu bangeke bafinyelele kulokho uNkulunkulu asakwenzayo kwasekuqaleni kusiya ekupheleni.
\v 12 Ngiyakwazi ukuthi kakukho okungcono ebantwini kulokuthi bajabule njalo benze okuhle besaphila.
\v 13 Ukuthi wonke umuntu adle, anathe asuthiseke ekusebenzeni kwakhe gadalala, lokhu kuyisipho sikaNkulunkulu.
\v 14 Ngiyazi yonke into eyenziwa nguNkulunkulu izakuba khona kokuphela; akulalutho olungengezwa kukho loba kususwe kukho. UNkulunkulu uyenza lokho ukuze abantu bamkhonze.
\q1 
\v 15 Loba yini ekhona seyake yaba khona,
\q2 kulalokho okuzakuba khona sekwaba khona ngaphambili;
\q2 njalo uNkulunkulu uzakubalisa okwedlulayo.
\p 
\v 16 Njalo ngabona okunye ngaphansi kwelanga:
\q1 endaweni yokwahlulela, ububi babukhona,
\q2 endaweni yokulungisa, ububi babukhona.
\p 
\v 17 Ngacabanga ngenhliziyo yami,
\q1 “UNkulunkulu uzabehlulela
\q2 bonke abalungileyo lababi,
\q1 ngoba sizaba khona isikhathi sezenzakalo zonke,
\q2 isikhathi sawo wonke umsebenzi.”
\p 
\v 18 Ngacabanga njalo ngathi, “UNkulunkulu uyabahlola abantu ukuze babone ukuthi banjengezinyamazana.
\v 19 Isiphetho somuntu siyafana lesezinyamazana; isiphetho sinye sibalindele bonke: njengoba lokhu kuyafa, kanjalo lokunye kuyafa. Konke kokubili kulomphefumulo munye; umuntu kangcono kulenyamazana. Konke kuyize.
\v 20 Konke kuya ndawo yinye; konke kuvela othulini, yikho konke kubuyela othulini.
\v 21 Ngubani owaziyo ingabe umphefumulo womuntu uyakhwela uye phezulu kuthi owenyamazana wehlele phansi phakathi emhlabathini?”
\p 
\v 22 Yikho ngabona ukuthi kakukho okungcono emuntwini ngaphandle kokuthi akholise umsebenzi wakhe ngoba leso yiso isabelo sakhe. Ngoba kambe ngubani ongamenza ukuthi abone lokho okuzakwenzakala yena esedlule?
\c 4
\s1 Ukuhlupheka, Ukusebenza Nzima, Ukuswela Umngane
\p 
\v 1 Ngakhangela njalo ngabona konke ukuncindezelwa okwakukhona ngaphansi kwelanga:
\q1 Ngabona inyembezi zabancindezelwayo
\q2 babengelabaduduzi;
\q1 amandla ayekulaba abancindezelayo
\q2 abalaye umduduzi.
\q1 
\v 2 Ngangifakaza ukuthi abafileyo,
\q2 abavele sebefile,
\q1 bayathokoza kulabaphilayo,
\q2 abalokhu besaphila.
\q1 
\v 3 Kodwa okungcono kulakho kokubili
\q2 ngulowo ongakabikhona,
\q1 ongakaboni ububi
\q2 obenziwayo ngaphansi kwelanga.
\p 
\v 4 Ngasengibona ukuthi konke ukusebenza lokuphumelela konke kuvela emhawini womuntu ngomakhelwane wakhe. Lokhu lakho kuyize, kuyikuxotshana lomoya.
\q1 
\v 5 Isiwula sigoqa izandla zaso
\q2 sidilize impilo yaso.
\q1 
\v 6 Kungcono isandla esisodwa esigcweleyo silokuthula
\q2 kulezandla ezimbili ezingagcwalanga ezilomtshikatshika
\q2 lokuxotshana lomoya.
\p 
\v 7 Njalo ngabona okunye okuyize ngaphansi kwelanga:
\q1 
\v 8 Kwakulendoda eyayiyodwa zwi;
\q2 yayingelandodana loba umfowabo.
\q1 Yayisebenza gadalala ingaphumuli,
\q2 kodwa amehlo ayo ayengasuthiswa yinotho yayo.
\q1 Yabuza yathi, “Ngiginqela bani kangaka,
\q2 njalo kungani ngizincitsha intokozo?”
\q1 Lokhu lakho kuyize
\q2 umsebenzi othelela usizi!
\b
\q1 
\v 9 Ababili bangcono kuloyedwa,
\q2 ngoba balomvuzo obonakalayo ngomsebenzi wabo.
\q1 
\v 10 Omunye angawa,
\q2 umngane wakhe uyamncedisa amvuse.
\q1 Kodwa maye lowomuntu owayo
\q2 kungelamuntu ongamsiza amvuse!
\q1 
\v 11 Njalo nxa ababili belala ndawonye bazakhudumezana.
\q2 Kanti umuntu angakhudumala kanjani eyedwa na?
\q1 
\v 12 Loba umuntu engehlulwa nxa eyedwa,
\q2 ababili bangazivikela.
\q1 Intambo elemicu emithathu kayiqamuki lula.
\s1 Ukuphiwa Isikhundla Kuyize
\p 
\v 13 Lingcono ijaha elingumyanga kodwa lihlakaniphile kulenkosi endala eyisiwula eyalayo ukwamukela izixwayiso.
\v 14 Ijaha lelo kungabe ngeliphuma ejele libe yinkosi, loba lingelazalelwa ebuyangeni elizweni lalowombuso.
\v 15 Ngabona ukuthi bonke ababephila behamba ngaphansi kwelanga balilandela lelojaha elathatha isikhundla sobukhosi.
\v 16 Amakhosi la (endala lencinyane) kungabe ayelodumo elandelwa ngabantu abanengi abangelakubalwa. Kodwa izizukulwane ezilandelayo azimthandanga lowo owathatha ubukhosi. Lokhu lakho kuyize, yikuxotshana lomoya.
\c 5
\s1 Mesabe UNkulunkulu
\p 
\v 1 Qaphela izinyathelo zakho nxa usiya endlini kaNkulunkulu. Sondela ulalele kulokuthi wenze imihlatshelo yeziwula ezingaziyo ukuthi ziyona.
\q1 
\v 2 Ungawalazeli ngomlomo wakho,
\q2 ungabi lephaphu
\q2 uphange uthembise kuNkulunkulu.
\q1 UNkulunkulu usezulwini
\q2 ikanti wena usemhlabeni,
\q2 ngakho kawabe malutshwana amazwi akho.
\q1 
\v 3 Njengephupho elifika nxa kulezinkathazo ezinengi,
\q2 injalo inkulumo yesiwula nxa ilamazwi amanengi.
\p 
\v 4 Nxa usenza isifungo kuNkulunkulu, ungaphuzi ukusigcwalisa. Kathokozi ngeziwula; gcwalisa isifungo sakho.
\v 5 Kungcono ukungafungi kulokwenza isifungo ungabe usasigcwalisa.
\v 6 Ungavumeli umlomo wakho ukungenise esonweni. Njalo ungatshingeli isithunywa sethempelini usithi, “Isifungo sami besiyisiphosiso.” UNkulunkulu angakuthukuthelelani lokho okutshoyo abesebhidliza umsebenzi wezandla zakho na?
\v 7 Ukuphupha kanengi lamazwi amanengi kuyize. Ngakho mesabe uNkulunkulu.
\s1 Inotho Iyize
\p 
\v 8 Nxa ubona abayanga esiqintini bencindezelwa, bencitshwa ukwahlulelwa okuhle kanye lamalungelo, ungamangaliswa yilezozinto; ngoba phela induna nganye ikhangelwe ngomunye ongaphezu kwayo, kuthi ngaphezu kwabo bonke kube labanye njalo abangaphezulu.
\v 9 Inala elizweni ngeyomuntu wonke; inkosi ngokwayo ithola inzuzo ngalokho okuvela emasimini.
\q1 
\v 10 Lowo othanda imali akaneliswa yiloba yimalini;
\q2 lowo othanda inotho akasuthiswa yilokho akuzuzayo.
\q2 Lokhu lakho kuyize.
\b
\q1 
\v 11 Nxa inotho isanda,
\q2 bayanda lalabo abayisebenzisayo.
\q1 Imsiza ngani umniniyo
\q2 ngaphandle kokuyithapha ngamehlo nje kuphela?
\b
\q1 
\v 12 Bumnandi ubuthongo besisebenzi,
\q2 loba sisidla okuncane loba okunengi,
\q1 kodwa isinothi
\q2 asilali ngenxa yenotho yaso.
\p 
\v 13 Sengibone ububi obudanisayo ngaphansi kwelanga:
\q1 ubuhaga ngenotho okulimaza umnikazi,
\q2 
\v 14 loba inotho esuke yachitheka ngomnyama othile,
\q1 okuthi nxa umuntu elendodana
\q2 ayisayikuthola lutho.
\q1 
\v 15 Umuntu uphuma esiswini sikanina engelalutho,
\q2 njengokufika kwakhe ubuyela enjalo.
\q1 Kazuzi lutho olusuka emsebenzini wakhe
\q2 angaluphatha ezandleni zakhe.
\p 
\v 16 Lobu labo yibubi obudanisayo:
\q1 Njengokufika kwakhe, umuntu uzabuyela enjalo,
\q2 ngakho uzuzani,
\q2 njengoba esebenza esadalalela umoya?
\q1 
\v 17 Zonke insuku zakhe udlela emnyameni,
\q2 ekhathazekile, ehluphekile, ezondile.
\p 
\v 18 Ngasengibona ukuthi kuhle kuqondile ukuthi umuntu adle njalo anathe, njalo azuze ukusuthiseka ekutshikatshikeni kwakhe ngomsebenzi ngaphansi kwelanga ngalezonsuku ezilutshwane ezokuphila uNkulunkulu asamuphe zona ngoba lesi yisabelo sakhe.
\v 19 Kunjalo futhi ukuthi nxa uNkulunkulu esipha umuntu inotho lempahla, amvumele ukuthi akholise ngazo, emukele isabelo sakhe athokoze emsebenzini wakhe, lesi yisipho sikaNkulunkulu.
\v 20 Kahlali ekhumbula ngezinsuku zempilo yakhe ngoba uNkulunkulu umenza ahlale ngenjabulo enhliziyweni.
\c 6
\p 
\v 1 Sengibone obunye ububi ngaphansi kwelanga engibona ukuthi bunzima kakhulu ebantwini:
\v 2 UNkulunkulu upha umuntu inotho lempahla lodumo ukuze angasileli lutho oluloyiswa yinhliziyo yakhe, kodwa uNkulunkulu kamniki amandla okuthi azikholise lezozinto, zikholiswa ngowemzini. Lokhu kuyize, ububi obudanisayo.
\p 
\v 3 Umuntu angaba labantwana abalikhulu aphile okweminyaka eminengi; ikanti loba angaze aphile kanganani kodwa nxa engeke akholise inotho yakhe njalo angangcwatshwa ngendlela eqondileyo, ngithi umphunzo ungcono kulaye.
\v 4 Ufika ungasilutho, unyamalale emnyameni lebizo lawo liphelele emnyameni.
\v 5 Loba lowomphunzo ungazange ulibone ilanga loba wazi ulutho usekuphumuleni okungcono kulalowomuntu
\v 6 loba angaze aphile okweminyaka eyinkulungwane iphindwe kabili kodwa angaze akholisa inotho yakhe. Kabayi ndawonye bonke na?
\q1 
\v 7 Yonke imizamo yomuntu iya emlonyeni wakhe,
\q2 kodwa iphango lakhe kaligcwali.
\q1 
\v 8 Umuntu ohlakaniphileyo ungcono ngani kulesiwula?
\q1 Umuntu ongumyanga uzuzani
\q2 ngokwazi ukuziphatha kuhle phambi kwabanye na?
\q1 
\v 9 Kungcono okubonwa lilihlo
\q2 kulokuhwaywa liphango.
\q1 Lokhu lakho kuyize,
\q2 yikuxotshana lomoya.
\b
\q1 
\v 10 Loba yini ekhona seyavele yethiwa ibizo,
\q2 laloba yini umuntu ayiyo yona kuvele sekusaziwa;
\q1 akulamuntu ongaphuthumana
\q2 lomunye olamandla kulaye.
\q1 
\v 11 Ngokwanda kwamazwi
\q2 siyancipha lesisindo sawo;
\q2 pho kumsiza ngani umuntu?
\p 
\v 12 Kambe ngubani okwaziyo okulungele umuntu ekuphileni kwakhe ngensuku ezimbalwa ezingatsho lutho adlula kuzo njengethunzi na? Ngubani ongamtshela okuzakwenzeka ngaphansi kwelanga yena esedlule?
\c 7
\s1 Inhlakanipho
\q1 
\v 1 Ibizo elihle lingcono kulamakha amnandi,
\q2 lelanga lokufa lingcono kulelanga lokuzalwa.
\q1 
\v 2 Kungcono ukuya endlini yesililo
\q2 kulokuya endlini yamadili,
\q1 ngoba ukufa kuyisiphetho somuntu wonke;
\q2 abaphilayo kabakunanzelele lokho.
\q1 
\v 3 Usizi lungcono kulokuhleka,
\q2 ngoba ubuso obudanileyo buyayisiza inhliziyo.
\q1 
\v 4 Inhliziyo yabahlakaniphileyo isendlini yokulila,
\q2 kodwa inhliziyo yeziwula isendlini yokuzithokozisa.
\q1 
\v 5 Kungcono ukulalela izixwayiso zomuntu ohlakaniphileyo
\q2 kulokulalela ingoma yeziwula.
\q1 
\v 6 Njengokuchachamba kwameva ngaphansi kwembiza,
\q2 lunjalo uhleko lweziwula.
\q2 Lokhu lakho kuyize.
\b
\q1 
\v 7 Ukuqilibezela kwenza ohlakaniphileyo abe yisiwula,
\q2 lesivalamlomo siyayona inhliziyo.
\b
\q1 
\v 8 Isiphetho sendaba singcono kulokuqala kwayo,
\q2 lokubekezela kungcono kulokuqinisa intamo.
\q1 
\v 9 Ungaphangisi ukufuthelana ngaphakathi,
\q2 ngoba ulaka luhlezi lugonwe yiziwula.
\b
\q1 
\v 10 Ungaze wathi, “Kungani insuku zayizolo zazingcono kulalezi?”
\q2 Ngoba kakukuhle ukubuza imibuzo enjalo.
\b
\q1 
\v 11 Ukuhlakanipha, njengelifa, kuyinto enhle
\q2 njalo kuyabasiza bonke abaphilayo.
\q1 
\v 12 Ukuhlakanipha kuyisiphephelo
\q2 njengoba imali iyisiphephelo,
\q1 kodwa ubungcono bolwazi yilobu:
\q2 ukuthi ukuhlakanipha kuyayilondoloza impilo yalowo olakho.
\p 
\v 13 Nakana ngalokho uNkulunkulu akwenzayo:
\q1 Ngubani ongakuqondisa
\q2 lokho akwenze kwagoba na?
\q1 
\v 14 Ngezikhathi konke kukuhle, thokoza;
\q2 kodwa ngezikhathi zobubi, cabanga ukuthi:
\q1 uNkulunkulu ukwenzile lokhu
\q2 kanye lalokhuyana njalo.
\q1 Ngakho-ke umuntu ngeke akwazi
\q2 ukuthi ikusasa lakhe lizakuba yini.
\p 
\v 15 Kuyonale impilo yami eyize sengizibonile izinto lezi zombili:
\q1 umuntu olungileyo uyafa elungile enjalo,
\q2 lomuntu omubi uba lempilo enhle emubi enjalo.
\q1 
\v 16 Ungalungi wedlulise,
\q2 futhi ungabi lokuhlakanipha okweqileyo
\q2 kambe uzibulalelani na?
\q1 
\v 17 Ungaxhwali okudlulisileyo,
\q2 njalo ungabi yisiwula
\q2 kambe ufelani singakafiki isikhathi sakho?
\q1 
\v 18 Kuhle ukuthi uthi ubambe lokhu
\q2 ungayekeli uphunyukwe ngokunye.
\q2 Umuntu owesaba uNkulunkulu kedlulisi amalawulo.
\b
\q1 
\v 19 Ukuhlakanipha kwenza umuntu ohlakaniphileyo oyedwa abe lamandla
\q2 kulababusi abalitshumi edolobheni.
\b
\q1 
\v 20 Akulamuntu loyedwa olungileyo emhlabeni
\q2 owenza okulungileyo ongazake enze isono.
\b
\q1 
\v 21 Ungaphiki ngokulalela wonke amazwi akhulunywa ngabantu,
\q2 funa uzwe inceku yakho ikuthuka
\q1 
\v 22 ngoba uyakwazi enhliziyweni yakho
\q2 ukuthi wena ngokwakho uyawubathuke abanye.
\p 
\v 23 Konke lokhu ngakuhlolisisa ngokuhlakanipha ngathi,
\q1 “Ngizimisele ukuhlakanipha”
\q2 kodwa lokhu kwakungaphezu kwami.
\q1 
\v 24 Ukuhlakanipha okungabe kukhona,
\q2 kukhatshana kakhulu njalo kuzikile kakhulu:
\q2 ngubani ongakufinyelela na?
\q1 
\v 25 Ngasengibeka ingqondo yami ukuthi ngizwisise,
\q2 ngidingisise njalo ngichwayisise ukuhlakanipha kanye lesimo sezinto
\q1 lokuzwisisa ubuphukuphuku bokuxhwala
\q2 lobuhlanya lobuwula.
\b
\q1 
\v 26 Ngibona ukuthi uyingozi eyedlula ukufa
\q2 umfazi ongumjibila,
\q1 onhliziyo yakhe iyisithiyo
\q2 njalo ozandla zakhe zingamaketane.
\q1 Indoda eyesaba uNkulunkulu izaphepha kuye,
\q2 kodwa isigangi uzasihilela.
\p 
\v 27 Uthi uMtshumayeli, “Khangela, nanku esengikunanzelele:
\q1 Ngihlanganisa lokhu lalokhu ngizama ukubona isimo sezinto
\q2 
\v 28 ngilokhu ngisachwayisisa
\q2 kodwa ngingatholi
\q1 ngafumanisa indoda eyodwa elungileyo kwabayinkulungwane,
\q2 kodwa ngitsho loyedwa umfazi oqondileyo kubo.
\q1 
\v 29 Yilokhu kuphela esengikufumene:
\q2 UNkulunkulu wamenza umuntu wabaqotho,
\q2 kodwa abantu basuka bazenzele okwabo.”
\b
\c 8
\q1 
\v 1 Ngubani onjengomuntu ohlakaniphileyo na?
\q2 Ngubani oyaziyo ingcazelo yezinto na?
\q1 Ukuhlakanipha kuyabukhanyisa ubuso bomuntu
\q2 njalo kuguqula ukunyukubala kwabo.
\s1 Hlonipha Inkosi
\p 
\v 2 Ngithi hlonipha umlayo wenkosi ngoba wenza isifungo phambi kukaNkulunkulu.
\v 3 Ungawalazeli ukusuka phambi kwenkosi. Ungalumeli ulutho nxa lungaqondanga ngoba yona ingenza loba yini eyithandayo.
\v 4 Njengoba ilizwi lenkosi lingaphikiswa ngubani ongathi kuyo, “Kanti wenzani?”
\q1 
\v 5 Lowo ohlonipha imilayo yayo akayikwehlelwa ngokubi,
\q2 lenhliziyo ehlakaniphileyo iyasazi isikhathi lendlela yokwenza.
\q1 
\v 6 Ngoba into yonke ilesikhathi esiqondileyo lendlela yokwenza eqondileyo,
\q2 lanxa umuntu eyabe esindwa yizinkathazo zakhe.
\b
\q1 
\v 7 Njengoba kungekho muntu olaziyo ikusasa,
\q2 ngubani pho ongamtshela okuzayo na?
\q1 
\v 8 Njengoba kungelamuntu olamandla phezu komoyo ovunguzayo
\q2 Akulamuntu olamandla phezu kosuku lwakhe lokufa.
\q1 Njengoba ibutho lingakhululwa ngesikhathi sempi,
\q2 kunjalo ukuxhwala akuyikubakhulula labo abaphila ngakho.
\p 
\v 9 Konke lokhu ngakubona lapho ngangihlolisisa ngengqondo yami konke okwenziwayo ngaphansi kwelanga. Kukhona isikhathi lapho umuntu aphatha khona abanye ngochuku kanti uyazilimaza yena.
\v 10 Ngabona njalo ababi bengcwatshwa, labo ababehlala befika bahambe endaweni engcwele bazuze udumo kulelodolobho ababeganga khona. Khona lakho kuyize.
\p 
\v 11 Nxa isigwebo secala singenziwanga masinyane, abantu basuka bacabange ukuqhubeka ngokuganga kwabo.
\v 12 Loba umuntu ogangileyo engenza amacala alikhulu ajinge aphile okwesikhathi eside, ngiyazi ukuthi kuzakuba ngcono kulabo abamesabayo uNkulunkulu, abazithobayo kuNkulunkulu.
\v 13 Kodwa ngenxa yokuthi izixhwali kazimesabi uNkulunkulu, kakuzukuzilungela, lezinsuku zazo kaziyukweluleka njengesithunzi.
\p 
\v 14 Kukhona njalo enye into eyize eyenzakalayo emhlabeni: abantu abalungileyo abazuza okufanele ababi, labantu ababi abazuza okufanele abalungileyo. Ngithi lokhu lakho kudida ingqondo.
\v 15 Ngakho-ke ngikhuthaza ukuzithokozisa empilweni ngoba kakukho okungcono emuntwini ngaphansi kwelanga kulokuzitika, unathe, uthokoze. Lapho-ke injabulo izahlala injalo kuye emsebenzini wakhe zonke insuku zokuphila kwakhe aziphiwe nguNkulunkulu lapha emhlabeni.
\p 
\v 16 Ngathi ngibeka ingqondo yami ekwazini ukuhlakanipha lokunanzelela imisebenzi yabantu emhlabeni, umuntu engalali imini lobusuku,
\v 17 ngasengibona konke uNkulunkulu akwenzileyo. Kakho ongaqedisisa okwenzakalayo ngaphansi kwelanga. Loba umuntu ohlakaniphileyo angazitshaya owaziyo, kodwa angeke akuqedisise.
\c 9
\s1 Isiphetho Sinye Kubo Bonke
\p 
\v 1 Yikho ngakucabanga konke lokhu ngabona ukuthi abalungileyo labahlakaniphileyo labakwenzayo kusezandleni zikaNkulunkulu, kodwa kakho owaziyo ingabe ulindelwe luthando langabe yinzondo.
\v 2 Bonke balesiphetho sinye, abaqondileyo labaxhwalileyo, abalungileyo lababi, abahlambulukileyo labangcolileyo, abenza imihlatshelo labangayenziyo.
\q1 Njengoba kunjalo emuntwini olungileyo,
\q2 kunjalo lakoyisoni;
\q1 njengoba kunjalo kwabenza izifungo,
\q2 kunjalo lakulabo abesaba ukuzenza.
\p 
\v 3 Lobu yibo ububi obuvelela zonke izinto ngaphansi kwelanga: Konke kulesiphetho sinye. Njalo inhliziyo zabantu zigcwele izibozi futhi kulokubheda phakathi kwazo nxa besaphila, ikanti emva kwakho konke baya kwabafileyo.
\v 4 Loba ngubani olethemba nxa esahlezi kwabaphilayo, yebo kambe phela inja ephilayo ingcono kulesilwane esifileyo!
\q1 
\v 5 Ngoba abaphilayo bayakwazi ukuthi bazakufa,
\q2 kodwa abafileyo kabazi lutho;
\q1 kabaselawo omunye umvuzo,
\q2 ngitsho lokukhumbula ngabo kuyaphela.
\q1 
\v 6 Uthando lwabo, inzondo yabo
\q2 lomona wabo sekwedlula nya;
\q1 nini lanini kabasayikuba lengxenye
\q2 loba kukuphi okwenzakalayo ngaphansi kwelanga.
\p 
\v 7 Hamba nje uyezidlela ukudla kwakho uchelesile, unathe iwayini lakho ngenhliziyo emhlophe, ngoba uNkulunkulu usakuvumele okwamanje.
\v 8 Gqoka ezimhlophe ngezikhathi zonke, ugcobe ikhanda lakho ngamafutha.
\v 9 Kholisa impilo lomfazi wakho omthandayo kuzozonke insuku zale impilo eyize uNkulunkulu akunike yona ngaphansi kwelanga, zonke insuku zakho eziyize. Phela lesi yiso isabelo sakho empilweni phakathi kokutshikatshika kwakho ngaphansi kwelanga.
\v 10 Lokho isandla sakho esingakwenza kwenze ngamandla akho wonke, ngoba engcwabeni lapho oya khona akusetshenzwa, akulakulungiselela, kakulalwazi kumbe ukuhlakanipha.
\p 
\v 11 Ngikubonile okunye njalo ngaphansi kwelanga:
\q1 Ukutshiya abanye kakuyi ngesiqubu
\q2 kumbe ukunqoba impi kuye ngamandla;
\q1 kakutsho ukuthi ukudla kuya kwabahlakaniphileyo
\q2 kumbe inotho kwabakhaliphileyo
\q2 loba okuhle kwehlele abafundileyo;
\q1 kodwa kuya ngesikhathi langenhlanhla kubani lobani.
\p 
\v 12 Futhi kakho owaziyo ukuthi isikhathi sakhe sizafika nini:
\q1 Njengezinhlanzi ezigolwa kabuhlungu ngamambule
\q2 loba izinyoni zibanjwa esifini,
\q1 kanjalo abantu bafikelwa yizikhathi ezimbi
\q2 ezibafikela belibele.
\s1 Kungcono Ukuhlakanipha Kulobuwula
\p 
\v 13 Ngaphinda ngabona ngaphansi kwelanga lesisibonelo sokuhlakanipha esagxila engqondweni yami:
\v 14 Kwake kwaba khona idolobho elincinyane elalilabantu abalutshwana kulo. Kwasuka inkosi elamandla yalihlasela, yalihonqolozela yakha amadundulu amakhulu okuvimbezela.
\v 15 Kulelodolobho kwakuhlala indoda ethile engesulutho kodwa ihlakaniphile, ngakho yawusindisa umuzi lowo ngokuhlakanipha kwayo. Kodwa kakho loyedwa owaphinde wayikhumbula leyondoda eyayingebani.
\v 16 Yikho-ke ngasengisithi, “Ukuhlakanipha kungcono kulamandla.” Kodwa ukuhlakanipha komuntukazana kuyeyiswa lamazwi akhe akasanakwa.
\q1 
\v 17 Amazwi apholileyo abahlakaniphileyo afanele alalelwe
\q2 ngcono kulokumemeza kombusi weziwula.
\q1 
\v 18 Ukuhlakanipha kungcono kulezikhali zempi,
\q2 umoni oyedwa uyabuchitha bonke ubuhle.
\b
\c 10
\q1 
\v 1 Njengoba impukane ezifele phakathi kwamakha ziwenza anuke kubi,
\q2 kunjalo lobuwula obuncinyane bugabhela ukuhlakanipha lodumo.
\q1 
\v 2 Inhliziyo yolungileyo ikhungathekela ekulungeni,
\q2 kodwa inhliziyo yesiwula ikhungathekela ebubini.
\q1 
\v 3 Loba ehamba nje emgwaqweni
\q2 oyisiwula kalangqondo,
\q2 utshengisa loba ngubani ubuphukuphuku bakhe.
\q1 
\v 4 Aluba umbusi ekuthukuthelela,
\q2 ungasuki esikhundleni sakho;
\q2 ukuthobeka kungathoba umonakalo obungaba khona.
\b
\q1 
\v 5 Bukhona ububi esengibubonile ngaphansi kwelanga,
\q2 kuliphutha elenziwa ngumbusi:
\q1 
\v 6 Iziwula ziphakanyiselwa ezikhundleni ezinengi eziphezulu,
\q2 kodwa abanothileyo belezikhundla eziphansi.
\q1 
\v 7 Sengibone izichaka zigade amabhiza,
\q2 kuthi amakhosana ahambe ngezinyawo njengezichaka.
\b
\q1 
\v 8 Lowo ogebha umgodi angawela kuwo;
\q2 odiliza umduli angalunywa yinyoka.
\q1 
\v 9 Oqhekeza amatshe angalinyazwa yiwo;
\q2 obanda inkuni angaba sengozini yazo.
\b
\q1 
\v 10 Lapho ihloka libuthundu
\q2 ubukhali balo bungalolwanga,
\q1 kudingeka amandla amanengi
\q2 kodwa ubungcitshi buyaphumelelisa.
\b
\q1 
\v 11 Nxa inyoka ihle ilume ingakalunjwa,
\q2 umlumbi kaselanzuzo.
\b
\q1 
\v 12 Amazwi aphuma emlonyeni wesihlakaniphi amnandi,
\q2 kodwa isiwula sichithwa yizindebe zaso.
\q1 
\v 13 Ekuqaleni amazwi aso ayibuwula;
\q2 ekucineni aseyikuwumana okubi
\q2 
\v 14 njalo isiwula sanda ngamazwi.
\b
\q1 Kakho okwaziyo okuzayo
\q2 ngubani ongamazisa okuzakwenzakala ngemva kwakhe na?
\b
\q1 
\v 15 Umtshikatshika wesiwula uyasidinisa;
\q2 kasiyazi indlela eya edolobheni.
\b
\q1 
\v 16 Maye kuwe, wena lizwe onkosi yalo yayiyisichaka,
\q2 amakhosana akho azitika ngamadili ekuseni.
\q1 
\v 17 Ubusisiwe wena, wena lizwe onkosi yalo izalwa esikhosini
\q2 amakhosana alo adla ngezikhathi eziqondileyo
\q2 edlela ukuqina hatshi ukudakwa.
\b
\q1 
\v 18 Nxa indoda ilivila intungo ziyabhensa;
\q2 nxa izandla zayo ziyekethisa indlu iyavuza.
\b
\q1 
\v 19 Idili lenzelwa ukujabula,
\q2 lewayini lenza impilo ibe mnandi,
\q2 kodwa imali yiyo impendulo yakho konke.
\b
\q1 
\v 20 Ungayithuki inkosi lasemicabangweni yakho,
\q2 loba uqalekise abanothileyo loba usendlini yakho yokulala,
\q1 ngoba mhlawumbe inyoni yasemoyeni ingawathwala amazwi akho,
\q2 loba inyoni ephaphayo ingayabika okutshoyo.
\c 11
\s1 Isinkwa Emanzini
\q1 
\v 1 Phosela isinkwa sakho phezu kwamanzi,
\q2 ngoba ngemva kwensuku ezinengi uzasifumana futhi.
\q1 
\v 2 Yabela abayisikhombisa, yebo abayisificaminwembili,
\q2 ngoba kawuwazi umonakalo ongehlela elizweni.
\b
\q1 
\v 3 Nxa amayezi ethwele, anisa izulu emhlabathini.
\q2 Aluba isihlahla singawela eningizimu loba enhla,
\q2 silala khonapho esiwele khona.
\q1 
\v 4 Lowo onanzelela umoya kayikuhlanyela;
\q2 lowo okhangela amayezi akazukuvuna.
\b
\q1 
\v 5 Njengoba ungayazi indlela yomoya,
\q2 loba ukubunjwa komzimba esiswini sikanina,
\q1 yikho ungeke uzwisise umsebenzi kaNkulunkulu,
\q2 uMenzi wezinto zonke.
\b
\q1 
\v 6 Hlanyela inhlanyelo yakho ekuseni,
\q2 kuthi ntambama uphumuze izandla zakho,
\q1 ngoba kawukwazi okuzaphumelela,
\q2 kumbe yilokhu loba yilokhuyana,
\q2 langabe kokubili kuzalunga ngokufananayo.
\s1 Khumbula UMenzi Wakho UseseMutsha
\q1 
\v 7 Ukukhanya kumnandi,
\q2 njalo kuhle emehlweni ukubona ilanga.
\q1 
\v 8 Umuntu angaze aphile iminyaka emingaki,
\q2 kayikholise yonke.
\q1 Kodwa makakhumbule insuku zobumnyama,
\q2 ngoba zizabe zizinengi.
\q2 Konke okuzakuza kuyize.
\b
\q1 
\v 9 Jabula nsizwa usesemutsha,
\q2 uvumele inhliziyo yakho ikuthokozise ensukwini zobutsha bakho.
\q1 Landela izindlela zenhliziyo yakho
\q2 lakho konke amehlo akho akubonayo,
\q1 kodwa yazi ukuthi ngenxa yazo zonke lezizinto
\q2 uNkulunkulu uzakumisa ekwahlulelweni.
\q1 
\v 10 Ngakho-ke, susa ukukhathazeka enhliziyweni yakho
\q2 ulahlele kude inhlupheko zomzimba wakho,
\q2 ngoba ubutsha lamadlabuzane kuyize.
\b
\c 12
\q1 
\v 1 Khumbula uMdali wakho
\q2 ngezinsuku zobutsha bakho,
\q1 kungakafiki insuku zokuhlupheka
\q2 njalo kusondele leminyaka
\q2 lapho ozakuthi,
\q2 “Angizuzi kuthokoza kuyo”
\q1 
\v 2 andubana ilanga lokukhanya
\q2 kanye lenyanga lezinkanyezi kufiphale,
\q1 lamayezi achitheke
\q2 ngemva kwezulu;
\q1 
\v 3 lapho abalindi bendlu
\q2 bezathuthumela,
\q1 amadoda aqinileyo akhokhobe,
\q2 labacholi batshiye umsebenzi
\q1 ngoba sebebalutshwana,
\q2 kuthi labalunguzayo ngamawindi
\q2 sebebona lufifi;
\q1 
\v 4 lapho iminyango ephumela emigwaqweni isivaliwe
\q2 lomsindo wokuchola usufiphala;
\q1 lapho abantu besethuswa yikukhala kwenyoni,
\q2 lezingoma zazo zincipha;
\q1 
\v 5 lapho abantu sebesesaba izindawo eziphakemeyo
\q2 lezingozi emigwaqweni;
\q1 lapho isihlahla se-alimondi sesiqhakaza
\q2 lentethe isihamba ngokuzihudula nje
\q2 njalo kungasekho ukulangazelela.
\q1 Lapho-ke umuntu usesiya ekhaya lakhe
\q2 laphakade njalo abalilayo
\q2 bagcwale emigwaqweni.
\b
\q1 
\v 6 Mkhumbule intambo yesiliva ingakaqamuki,
\q2 kumbe umganu wegolide ungakabhidlizwa;
\q1 lodiwo lungakahlikizwa emthonjeni,
\q2 loba ivili lephulwe emgodini wamanzi,
\q1 
\v 7 kuthi umhlabathi ubuyele emhlabathini
\q2 lapho owavela khona,
\q1 lomphefumulo ubuyele kuNkulunkulu
\q2 onguye owawuphayo.
\b
\q1 
\v 8 “Ize! Ize!” kutsho uMtshumayeli,
\q2 “Konke kuyize!”
\s1 Isiphetho Sendaba
\p 
\v 9 UMtshumayeli wayehlakaniphile, njalo esabela abantu ulwazi. Wazidla ingqondo wadingisisa wamisa kuhle izaga ezinengi.
\v 10 UMtshumayeli wadingisisa ukuze azuze amazwi ayiwonawona, kwathi-ke konke akulobayo kwaqonda njalo kuliqiniso.
\p 
\v 11 Amazwi abahlakaniphileyo anjengenswazi zokwethusa izimvu, izitsho zabo eziqoqiweyo zinjengezipikili ezibethelwe zatshona, zivela kuMalusi munye.
\v 12 Limuka, ndodana yami, loba kuyini okudlula lapho.
\p Ukulotshwa kwezincwadi ezinengi akulamkhawulo, njalo ukufunda kakhulu kuhlukuluza umzimba.
\q1 
\v 13 Manje-ke konke sekuzwakele;
\q2 nansi isiphetho sendaba:
\q1 Mesabe uNkulunkulu ugcine imiyalo yakhe,
\q2 ngoba lo yiwo wonke umlandu womuntu.
\q1 
\v 14 Ngoba uNkulunkulu uzazahlulela zonke izenzo,
\q2 lalokho okufihliweyo
\q2 loba kuhle loba kubi.
