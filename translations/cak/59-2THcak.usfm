\id 2TH KM2TH.SCR 2 TES. CAK. SUR CENTRAL 17 feb 2005
\h 2 Tesalonicenses
\toc1 2 Tesalonicenses
\toc2 Ri ruca'n carta ri xutz'ibaj ri apóstol San Pablo chique ri quiniman ri Jesucristo pa tinamit Tesalónica
\toc3 2 Ts.
\mt1 Ri ruca'n carta ri xutz'ibaj ri apóstol San Pablo chique ri quiniman ri Jesucristo pa tinamit Tesalónica
\c 1
\s1 Ri Pablo nutak-e qui-saludo ri quiniman ri Jesucristo
\p 
\v 1 Yin Pablo, ri Silvano y ri Timoteo, nikatz'ibaj-e ri vuj re' chive rix ri nimol-ivi' pa rubi' ri Dios pa tinamit Tesalónica, ri xa jun ibanon riq'uin ri Katata' Dios y ri Ajaf Jesucristo.
\v 2 Ri favor y ri uxlanen ri nipe riq'uin ri Katata' Dios y ri Ajaf Jesucristo can ta xtic'uje' pan ivánima.
\s1 Ri Dios xqueruya' pa c'ayef ri yeyo'on pa c'ayef ri aj-Tesalónica
\p 
\v 3 Roj jumul nic'atzin nikaya' matiox che ri Dios ivoma rix ri junan kaniman ri Jesucristo iviq'uin, y can nuc'ul-vi chi quiri' nika'an, roma k'ij-k'ij más cukul ic'u'x riq'uin ri Dios, y k'ij-k'ij más nijo-ivi' chivech chi nimalaj ivonojel.
\v 4 Romari', ja jun roj nkuquicot nikatzijoj chique ri niquimol-qui' pa rubi' ri Dios pa jalajoj tak lugares, chi cof rixc'o y cukul ic'u'x riq'uin ri Jesucristo chupan ri c'ayef\x * \xo 1:4 \xt 1 Ts. 2:14.\x* y ri jalajoj tak pokon ri ni'an chive.
\v 5 Y re' retal chi ri Dios pa ruchojmil ninic'on. Roma riq'uin ri nik'asaj k'axomal\x * \xo 1:5 \xt Fil. 1:28, 29.\x* rix, chiri' yixtz'etetaj-vi chi can nuc'ul-vi chi yixoc ruvinak ri ru-gobierno ri Dios ri achok roma nik'asaj ri k'axomal.
\v 6 Roma ri Dios can pa ruchojmil vi nu'on chi yeruya' pa c'ayef ri vinak roma ri c'ayef ri yixquiya-vi rix.\x * \xo 1:6 \xt Ap. 6:9, 10.\x*
\v 7 Jac'a rix ri yixyo'ox pa c'ayef, ri Dios xtuya' uxlanen\x * \xo 1:7 \xt Ap. 14:13.\x* chive junan kiq'uin roj tok c'a chila' chicaj\x * \xo 1:7 \xt 1 Ts. 4:16.\x* xtuc'ut-vi-pe-ri' ri Ajaf Jesús junan quiq'uin ri ru-ángeles ri yo'on-pe nimalaj uchuk'a' chique.
\v 8 Chupan ruxak-k'ak'\x * \xo 1:8 \xt He. 10:27; Ap. 21:8.\x* xtuc'ut-vi-ri' richin nuya' ruq'uexel chique ri man queteman ta ruvech ri Dios,\x * \xo 1:8 \xt Sal. 79:6.\x* nis-ta man yeniman ta\x * \xo 1:8 \xt Ro. 2:8.\x* ri utzulaj ch'abel richin ri Kajaf Jesucristo ri nu'ij achique ruchojmil yecolotaj.
\v 9 Ri ruq'uexel ri xtiyo'ox chique, ja chi manak chic che'el yecolotaj\x * \xo 1:9 \xt 2 P. 3:7.\x* richin jumul. Naj che ri Ajaf xquec'uje-vi, y man jun bey xtiquitz'et ri nimalaj ruchuk'a' ri jani na ruk'ij.\x * \xo 1:9 \xt Is. 2:19.\x*
\v 10 Quiri' ruq'uexel xtiquic'ul chupan ri k'ij tok xtipe ri Ajaf richin niyo'ox ruk'ij coma ri erichin ri lok'olaj rutinamit,\x * \xo 1:10 \xt Sal. 89:7.\x* y (chuka', ka) richin jabel nitz'etetaj coma conojel ri quiniman rija', ri achok chiquicojol rixc'o-vi rix roma xic'ul ri ruch'abel ri xkatzijoj chive.
\p 
\v 11 Y richin chi niyo'ox ruk'ij ri Ajaf roma ri ic'aslen rix tok man nkutane' ta nika'an orar ivoma, chi ri Dios xquixrutz'et chi can nuc'ul-vi chi xixroyoj, y chi xquixruto' riq'uin ri ruchuk'a' richin nitz'akatitaj ronojel ri utzulaj ino'oj ri iyo'on pan ivánima chi ni'en, y ronojel samaj\x * \xo 1:11 \xt 1 Ts. 1:3.\x* ri yixtajin roma cukul ic'u'x riq'uin rija'.
\v 12 Quiri' ri nikac'utuj ivoma rix, roma nikajo' chi ri rubi' ri Kajaf Jesucristo can ta niyo'ox ruk'ij roma ri xu'on pan iq'uexel, y chi can ta ja jun rix niyo'ox ik'ij riq'uin, roma ri ru-favor ri ka-Dios y ri Ajaf Jesucristo pan ivi'.
\c 2
\s1 Ri achi ri man jun ley pa ruvech
\p 
\v 1 Jac'a pa ruvi' ri k'ij tok xtipe chic jun bey ri Kajaf Jesucristo, y ri kamolic\x * \xo 2:1 \xt Mt. 24:31; 1 Ts. 4:17.\x* xti'an riq'uin, yixkapaxa'aj c'a rix ri junan kaniman ri Jesucristo iviq'uin,
\v 2 chi man tich'ujirisaj-ivi' ni man tisatz ic'u'x,\x * \xo 2:2 \xt Ef. 5:6.\x* masque c'o jun ni'in chi c'o xk'alajrises che roma ri Lok'olaj Espíritu, o c'o ch'abel ivac'axan, o c'o jun vuj ic'ulun ri pa kabi' roj banon-vi-e ri nu'ij chi xuka yan ri nimalaj k'ij tok ri Ajaf xtu'on ri ru'in can.
\v 3 Man jun tisatzo ino'oj riq'uin ri jalajoj yebilo'x, roma na'ey chi nuka ri k'ij ri', xa eq'uiy xtiquiya' can quij chuvech ri Dios;\x * \xo 2:3 \xt 1 Ti. 4:1.\x* y xtuc'ut c'a pe ri' jun achi ri man jun ley pa ruvech,\x * \xo 2:3 \xt Dn. 7:24, 25.\x* ri can richin vi chi manak che'el nicolotaj.
\v 4 Ri achi ri', ronojel ri ni'ix Dios\x * \xo 2:4 \xt 1 Co. 8:5, 6.\x* che y ronojel ri niyo'ox ruk'ij coma ri vinak, rija' xticataj chirij y xtunimirisaj-ri' pa ruvi' ronojel.\x * \xo 2:4 \xt Is. 14:12-14.\x* Hasta xtoc pa racho ri Dios y xtitz'uye' chiri', achel can ta ja rija' ri Dios, y can xtuk'ebaj-ri' chi Dios.
\v 5 Rix nuka pan ivi' chi ronojel re', yin xin-ij chive tok xic'uje' chi'icojol.
\v 6 Iveteman ri achique k'atayon vacami richin ri achi ri', c'a terila' na ri k'ij ri k'aton chirij, c'ajari' xtik'alajin-pe.
\v 7 Can kitzij na vi chi q'uiy chic man utz ta najin vacami, y ri itzel ri najin man can ta nik'alajin-pe, roma c'o jun k'atayon richin. Pero tok re jun re' elesan chic e,
\v 8 jac'ari' xtik'alajin-pe ri achi ri man jun ley pa ruvech. Jac'a ri Ajaf Jesucristo, xaxe (xtuxupuj, xtuvupuj),\x * \xo 2:8 \xt Job 4:8, 9.\x* ja xtucamisaj, y xaxe riq'uin ri rusakil ri nitz'intz'ot tok xtipe chic jun bey, xtuq'uis ruk'ij ri itzel achi ri'.
\v 9 Tok xtipe, ri itzel achi ri' ruchuk'a' ri Satanás uc'uayon-pe richin, xtusamajij nimalaj uchuk'a',\x * \xo 2:9 \xt Dt. 13:1-3; Mt. 24:24.\x* xquerubanala' nimalaj tak retal y nima'k tak milagros ri man jun bey etz'eton. Pero ronojel ri yerubanala' man riq'uin ta ri Dios petenak-vi.
\v 10 Xquerucusaj ronojel ruvech itzel no'oj richin xquerusetz ri xa pa k'ak' ebenak-vi, roma man xquijak ta ri cánima richin xcajo' ri kitzij y can ta xecolotaj.
\v 11 Romari' ri Dios nutak-pe jun uchuk'a' richin satzoj no'oj pa quivi', richin tiquinimaj ri man kitzij ta.\x * \xo 2:11 \xt Mt. 24:5; 1 Ti. 4:1.\x*
\v 12 Richin quiri' nika castigo pa quivi' conojel ri man xquinimaj ta ri kitzij, y ja ri man choj ta ri xka chiquivech richin xequibanala'.\x * \xo 2:12 \xt Ro. 1:32; 2:7, 8.\x*
\s1 Ri aj-Tesalónica can echa'on-vi richin yecolotaj
\p 
\v 13 Jac'a roj nic'atzin chi jumul nikamatioxij che ri Dios ivoma rix ri junan kaniman ri Jesucristo iviq'uin, rix ri jani na yixrojo' ri Ajaf. Roma ri Dios xe tok man jani c'o ri roch'ulef xixrucha'\x * \xo 2:13 \xt Ef. 1:4; 1 P. 1:2.\x* richin yixcolotaj, y ri' roma niya' ivánima riq'uin ri kitzij, y ni'an ch'ajch'oj che ri ic'aslen roma ri Lok'olaj Espíritu.
\v 14 Can richin vi ri' xixroyoj ri Dios, tok xkatzijoj chive ri utzulaj ch'abel ri nu'ij achique ruchojmil yixcolotaj, richin quiri' nic'uje' ik'ij rix chupan ri nimalaj ruk'ij\x * \xo 2:14 \xt 1 Ts. 2:12.\x* ri Kajaf Jesucristo.
\p 
\v 15 Roma c'a ri', rix ri junan kaniman ri Jesucristo iviq'uin, cof quixc'uje', man tiya' can juc'an ruchojmil ri xivetemaj\x * \xo 2:15 \xt 1 Co. 11:2.\x* can tok xojch'o iviq'uin y tok xkatak vuj chive.
\v 16 Nikac'utuj che ri Kajaf Jesucristo y che ri Katata' Dios ri can nkurojo'\x * \xo 2:16 \xt Jn. 3:16; 15:9; Ro. 5:8; Ef. 2:4; 1 Jn. 4:10.\x* y nuya' ruchuk'a' ri kánima richin jumul, y rubanon chi c'o jun utzulaj rajil koyo'en riq'uin ri nimalaj ru-favor,
\v 17 chi can ta xtuya' ruchuk'a' ri ivánima\x * \xo 2:17 \xt Col. 2:2; 1 Ts. 3:13.\x* y xquixruto' chi ja ri utz ri ni'en y ri ni'ij.
\c 3
\s1 Ri ruch'abel ri Dios can ta xtiyo'ox ruk'ij
\p 
\v 1 Vacami c'a, rix ri junan kaniman ri Jesucristo iviq'uin, tibana' orar koma, richin quiri' cha'anin ni'e rutzijol y niyo'ox ruk'ij ruch'abel ri Ajaf, achel xbanataj chi'icojol rix.
\v 2 Tic'utuj che ri Dios chi roj man nkuka pa quik'a' itzel tak achi'a' ri mana-ta ri utz uc'uayon quichin, roma man conojel ta quiyo'on cánima riq'uin ri utzulaj ch'abel ri nikatzijoj.\x * \xo 3:2 \xt Ro. 10:16.\x*
\v 3 Jac'a ri Ajaf can nu'on-vi ri ru'in. Rija' can xtuya' ivuchuk'a' y xquixruchajij\x * \xo 3:3 \xt Jn. 17:15; 2 P. 2:9.\x* chuvech ri itzel.
\v 4 Y roj cukul kac'u'x chi rix, riq'uin chi xa jun ibanon riq'uin ri Ajaf, yixtajin riq'uin ri xka'ij can chive, y man xtiya' ta can rubanic.
\v 5 Xtu'on ta c'a ri Dios chi xtijo' rija' achel yixrojo'\x * \xo 3:5 \xt 1 Jn. 4:16.\x* rix, y chi yixcoch'on achel xcoch'on ri Jesucristo.
\s1 Nic'atzin chi nkusamaj y mani nkuk'oran
\p 
\v 6 Pero pa rubi' ri Kajaf Jesucristo yixkapaxa'aj rix ri junan kaniman ri Jesucristo iviq'uin, chi man chic quixbin\x * \xo 3:6 \xt Ro. 16:17; 1 Co. 5:11; 2 Jn. 10.\x* riq'uin xa achique na jun ri runiman ri Jesucristo, pero xa man jun ruchojmil ri ruc'aslen ruc'uan, jun c'aslen ri man achel ta ruchojmil ri c'aslen kac'utun can chivech.
\v 7 Roma rix mismo iveteman chi can utz vi chi ni'en pan ic'aslen achel ri xka'an roj tok xojc'uje' chi'icojol. Mana-ta jun c'aslen ri man jun ruchojmil ri xkac'uaj chivech.\x * \xo 3:7 \xt 1 Ts. 1:5.\x*
\v 8 Nis-ta man jun achok che xka'ij-vi chi xe quiri' kurutzuku'. Chi chak'a' chi pak'ij xkatij kak'ij xojsamaj,\x * \xo 3:8 \xt Hch. 18:3; 20:34; 1 Co. 4:12.\x* richin quiri' nis-ta jun chive xkaya' eka'n chirij.
\v 9 Quiri' xka'an, man roma ta chi manak kak'a'\x * \xo 3:9 \xt Mt. 10:10; 1 Co. 9:6.\x* chi xkac'utuj kato'ic chive, xa richin chi ja ri kac'aslen roj mismo nic'utu chivech ri achique chi c'aslen nic'atzin nic'uaj.\x * \xo 3:9 \xt 1 P. 5:3.\x*
\v 10 Roma tok xojc'uje' iviq'uin, xka'ij chive chi xa achique na jun ri man nrojo' ta nisamaj,\x * \xo 3:10 \xt Gn. 3:19; Pr. 13:4; 1 Ts. 4:11.\x* man c'a tiva'.
\v 11 Roma kac'axan chi ec'o jujun chi'icojol ri quic'uan jun c'aslen ri man jun ruchojmil, man jun samaj niqui'en, xaxe niquik'ok'ola-qui' pa tak tzij ri manak qui-cuenta che.
\v 12 Ri yebano quiri', yekapaxa'aj y nika'ij chique pa rubi' ri Ajaf Jesucristo, chi ekal tiquibana' ri quisamaj\x * \xo 3:12 \xt Ro. 12:11; Ef. 4:28.\x* richin niquich'ec ri niquitij.
\v 13 Y rix ri junan kaniman ri Jesucristo iviq'uin, man quixcos ni'en ri utz.
\v 14 Jac'a si c'o jun man nrojo' ta nunimaj ri ka'in-e chupan ri vuj re', tic'utu' ri jun ri' chiquivech conojel, y man chic tic'uje'\x * \xo 3:14 \xt 1 Co. 5:1, 2.\x* chi'icojol, richin quiri' tiq'uix.
\v 15 Pero man itzel titz'et. Xa tipaxa'aj,\x * \xo 3:15 \xt Lv. 19:17; Gá. 6:1; 1 Ts. 5:14.\x* achel jun chique ri junan iniman ri Jesucristo quiq'uin.
\s1 Ri ruq'uisbel tak ch'abel che ri vuj re'
\p 
\v 16 Ri Ajaf ri mismo rajaf ri uxlanen, can ta jumul xtuya' uxlanen pan ivánima rix, chupan xa achique na ri nik'asaj pan ic'aslen. Ri Ajaf xtic'uje' ta c'a iviq'uin chi'ivonojel.\x * \xo 3:16 \xt Ro. 15:33.\x*
\p 
\v 17 Ri saludo re', riq'uin nuk'a' yin Pablo nin-en-vi-e,\x * \xo 3:17 \xt 1 Co. 16:21.\x* y jari' retal chi ja yin ri yitakon-e ri vuj re' chive, roma yin can quire' vi yitz'iban, y ronojel ri vuj yentak, quire' nin-en-e chique.
\v 18 Ri ru-favor ri Kajaf Jesucristo xtic'uje' ta c'a iviq'uin chi'ivonojel. Amén.
