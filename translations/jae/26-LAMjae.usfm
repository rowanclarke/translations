\id LAM -Jabem partial Bible [jae] -Papua New Guinea 1980 (web 2015) 
\h TAŊIBOA 
\toc1 Jeremianê Taŋiboa 
\toc2 Taŋiboa 
\toc3 Taŋ 
\mt1 Jeremianê Taŋiboa  
\ip Taŋiboa lemeŋ teŋ kêsêp buku tonec ŋalêlôm. Taŋiboa tau ŋam gebe ŋacjo seseŋ malac Jerusalem su ma sêwê lau jasêŋgôŋ kapoacwalô aŋga Babilon gêdêŋ jala 586 gêmuŋ Kilisi gêmêŋ nom. Biŋ ŋawapac gêjam sêga aŋga buku tonec, mago biŋ takêŋ gêwiŋ Anôtôŋa to takêŋ mateŋ têm, taŋ gêc nêmŋa naŋ, gêc buku ŋalêlôm amboac tonaŋgeŋ. Kêtôm jalageŋ Judawaga taêŋ gêjam ŋacjo seseŋ Jerusalem su gêdêŋ jala 586 gêmuŋ Kilisi gêmêŋ nomŋa ŋabiŋ ma sêjam dabuŋ mo to têtaŋ taŋiboa tonec aŋga nêŋ lôm dabuŋ ŋamuŋa.  
\c 3  
\s1 Ŋagêjô ma sêjam tauŋ ôkwi to sêkêŋ mateŋ  
\q1
\v 1 Aê ŋac teŋ, taŋ kêjala gêŋwapac gêdêŋ Anôtô kêkêŋ ŋagêjô naŋ.   
\q1
\v 2 Eŋ kêtiŋ aê to kêjanda aê kasêp ŋakesec ŋalêlôm gaja, naŋ ŋawê teŋ kêsa atom.   
\q1
\v 3 Ma gêjac aê kêtiam-kêtiam popocgeŋ ma taê labu masi.   
\b  
\q1
\v 4 Eŋ gêjac aê ôlic lasê ma ŋoc ŋatêkwa popocgeŋ.   
\q1
\v 5 Eŋ kêkêŋ aê gaŋgôŋ kapoacwalô gêŋwapac to katêc taucŋa.   
\q1
\v 6 Eŋ kêkêŋ aê gamoa ŋakesec kêtôm gêŋmatê laŋgwa teŋ.   
\b  
\q1
\v 7 Eŋ gêsô aê tôŋ ŋa kapoacwalô ŋajaŋa. Katu ŋac kapoacwalôŋa, taŋ jaêc su êtôm atom.   
\q1
\v 8 Aê gamôêc ma kataŋ gebe sênam aê sa. Anôtô gedec gebe êkêŋ taŋa ŋoc môêc.   
\q1
\v 9 Eŋ gêbôc ŋoc intêna samob auc ŋa poc sagiŋ. Eŋ gêgôm ŋoc lêŋ kêtu poalic.   
\b  
\q1
\v 10 Eŋ gêdib aê amboac bôc saleŋŋa ber kêboaŋ pusup tageŋ kêpi aê amboac lewe teŋ.   
\q1
\v 11 Eŋ kêjanda aê aŋga intêna ma kêkac aê popoc, go gêwi aê siŋ.   
\q1
\v 12 Eŋ kêkêkam talam ma kêkêŋ aê katu ênê sôb ŋasokoc.   
\b  
\q1
\v 13 Eŋ kêpê nê sôb kêsô ŋoc ŋalêlôm ŋanôgeŋ   
\q1
\v 14 e lau samob sêômac kêpi aê ma katu biŋ susuŋa gêdêŋ êsêac samob kêtôm bêc samucgeŋ.   
\q1
\v 15 Eŋ kêkêc bu ŋamakic kêsêp koclabeŋ ma kêsalê aê auc ŋa gêŋ to bu ŋamakic.   
\b  
\q1
\v 16 Eŋ gêgôm lucluŋ kikec-kikec kêpi gaŋac ma gaŋgôŋ wao ŋalêlôm.   
\q1
\v 17 Ŋoc katuc kêjala wama atom. Aê kaliŋ ŋalêlôm ŋajamŋa siŋ.   
\q1
\v 18 Amboac tonaŋ tec kasôm gebe “Ŋoc ŋawasi gêjaŋa su ma kakêŋ matoc Apômtauŋa amboac tonaŋgeŋ.”   
\q1
\v 19 Taêc gêjam ŋoc gêŋwapac to gamoa jageoŋa tonaŋ kêtôm ŋamalic sec.   
\q1
\v 20 Aê taêc gêjam biŋ tonaŋ ŋapaŋ ma kêkôniŋ aê katuc tôŋ.   
\q1
\v 21 Mago biŋ kakêŋ matocŋa gêmu gêmêŋ gêdêŋ aê taêc gêjam biŋ tageŋ tonec gebe   
\b  
\q1
\v 22 Apômtaunê moasiŋ gêjac pep su atom ma nê taê labu gêbacnê su atom tageŋ.   
\q1
\v 23 Bêbêcgeŋ samob mêŋkêtu wakuc, aômnêm biŋ ŋaŋêŋ gêjam sêga.   
\q1
\v 24 Katuc kêsôm lasê gebe “Apômtau kêtu ŋoc gêŋlênsêm, tec jakêŋ matoc eŋ.”   
\b  
\q1
\v 25 Apômtau eŋ ŋac gabêjam gêdêŋ aêac, taŋ akêŋ mateŋ eŋ, gêdêŋ lau, taŋ tonêŋ ŋalêlôm sesom eŋ samucgeŋ naŋ.   
\q1
\v 26 Daôŋ Apômtau gebe mêŋênam aêac kêsi ŋa aweŋmêgeŋ nec gêŋ ŋajamgoc.   
\q1
\v 27 Ŋac teŋ embe êôc nê gêŋwapac ênac m êndêŋ eŋ ŋapalêgeŋ oc êmoasiŋ eŋ ŋajam.   
\b  
\q1
\v 28 Apômtau embe êkêŋ gêŋwapac naênsac eŋ, naŋ ênam tau tôŋgeŋ êŋgôŋ nê tauŋa.   
\q1
\v 29 Eŋ êmbôc awasuŋ auc, ec êmac êndu samucgeŋ atom.   
\q1
\v 30 Eŋ êtôc alianô êndêŋ ŋac, taŋ kêtap eŋ naŋ, ma êkêŋ tau êndêŋ lau sêŋgôm eŋ maja êsa e êôc eŋ tôŋ.   
\b  
\q1
\v 31 Gebe Apômtau eŋ taê walô ŋam, tec êtiŋ su endeŋ tôŋgeŋ atom.   
\q1
\v 32 Eŋ embe êkêŋ gêŋwapac êtap aêac sa oc taê walô aêac êtiam gebe gabêjam gêjam eŋ auc   
\q1
\v 33 gebe êkêŋ gêŋwapac to ŋandaŋ tonaŋ kêmoasiŋ eŋ atom.   
\b  
\q1
\v 34 Apômtau kêjala embe sêkôniŋ aêac katuŋ sêsêp kapoacwalô,   
\q1
\v 35 embe sêŋgamiŋ biŋgêdêŋ, taŋ eŋ kêkêŋ gêdêŋ aêac naŋ,   
\q1
\v 36 embe sênam biŋgêdêŋ ôkwi aŋga gamêŋ mêtôcŋa, eŋ kêjala.   
\b  
\q1
\v 37 Apômtaunê ŋalêlôm ŋanô kêsa ŋapaŋ.   
\q1
\v 38 Biŋ ŋajam to biŋ sec oc mêŋêsa êtôm taugeŋ êtu ênê jatuŋa.   
\q1
\v 39 Embe sêkêŋ ŋagêjô êtu aêacnêŋ secŋa, naŋ tali aweŋ sa êtu asageŋŋa.   
\b  
\q1
\v 40 Tasala to tansaê nêŋ lêŋ ma tamu dandêŋ Apômtau tana.   
\q1
\v 41 Daôc lemeŋ to ŋalêlôm sa êndêŋ Anôtô undambêŋa gebe   
\q1
\v 42 “Aêac agêli to ali tauŋ sa ma aôm Apômtau kôsuc ma biŋ ôkwi atom.   
\b  
\q1
\v 43 “Aôm kôkwa taôm auc ŋa têmtac ŋandaŋ ma kôjanda aêac ma gôjac aêac ŋa taêm walô masigeŋ.   
\q1
\v 44 Aôm kôkwa taôm auc ŋa tao gebe aêacma mec êsô wacêtap aôm sa atom.   
\q1
\v 45 Aôm gôgôm aêac atu nom samucgeŋ ŋalênduc to gêŋgambu.   
\b  
\q1
\v 46 “Aêacma ŋacjo sêpêlê to sêsu aêac susu.   
\q1
\v 47 Ŋalêlôm ŋatutuc ma gêŋwapac kêkôm aêac auc ma aêac amoa atêc tauŋ to alendec ŋanôgeŋ.   
\q1
\v 48 Ŋoc matocsulu kêsêwa amboac bu kapôêŋ gebe aêŋoc lau samob sêjaŋa.   
\b  
\q1
\v 49 “Matocsulu keseleŋ gê tôŋgeŋ   
\q1
\v 50 e Apômtau êtu kêniŋ aŋga undambê ma êlic aêac.   
\q1
\v 51 Ŋoc ŋalêlôm ŋawapac ŋanôgeŋ gebe gêlic gêŋ, taŋ kêtap aêŋoc lauo malacŋa sa naŋ.   
\b  
\q1
\v 52 “Ŋacjo taŋ sedec aê ŋam masigeŋ naŋ, nêŋ lip gêjac aê amboac moc.   
\q1
\v 53 Êsêac sêbaliŋ aê tomatoc jaligeŋ kasêp sê ma sêsabi poc gêŋgôŋ sêawa auc.   
\q1
\v 54 Bu gêjam aê auc. Aê taêc gêjam gebe ‘Aê gabacgac.’   
\q1
\v 55 “O Apômtau, aŋga sê ŋalêlôm aê gamôêc gêdêŋ aôm,   
\q1
\v 56 ma gêdêŋ taŋ aê kateŋ aôm gebe ‘Ôŋô ŋoc môêc’ naŋ, aôm kôkêŋ taŋam.   
\q1
\v 57 Aôm gôjô aêŋoc biŋ ma kôsôm gebe ‘Ôtêc taôm atom.’   
\b  
\q1
\v 58 “O Apômtau, aôm mêŋgôjam aê sa to gôjam aê katuc kêsi.   
\q1
\v 59 O Apômtau, aôm gôlic gêŋ geo, taŋ sêgôm gêdêŋ aê naŋ. Ômêtôc aê naêndêŋ.   
\q1
\v 60 Aôm kôjala ŋacjo nêŋ têntac gedec aêŋa ma sêgôm gêŋlêlôm taêsam kêtu aêŋa.   
\b  
\q1
\v 61 “O Apômtau, aôm gôŋô êsêacnêŋ biŋ kêsi-kêsi, nêŋ gêŋlêlôm samob kêtu aêŋa.   
\q1
\v 62 Sêsôm biŋ kêtôm bêc samob ma sêkic biŋ kêtu aêŋa.   
\q1
\v 63 Gêdêŋ bêbêc e oc kêsêp êsêac têtaŋ pêlê aê.   
\b  
\q1
\v 64 “O Apômtau, ôkêŋ ŋagêjô êndêŋ êsêac êtôm gêŋ, taŋ sêgôm naŋ.   
\q1
\v 65 Ôpuc boa êsêac ma ôkêŋ êsêac sêŋgôŋ togêŋwapac ŋanôgeŋ.   
\q1
\v 66 Ôjanda êsêac to onseŋ êsêac su samucgeŋ aŋga nom.”   