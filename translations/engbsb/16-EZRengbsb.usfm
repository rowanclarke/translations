\c 8  
\s1 The Exiles Who Returned with Ezra  
\m
\v 1 \w These|strong="H4428"\w* \w are|strong="H4428"\w* \w the|strong="H5927"\w* family \w heads|strong="H7218"\w* \w and|strong="H4428"\w* \w genealogical|strong="H3187"\w* records \w of|strong="H4428"\w* \w those|strong="H5973"\w* \w who|strong="H4428"\w* \w returned|strong="H5927"\w* \w with|strong="H5973"\w* \w me|strong="H5973"\w* \w from|strong="H5927"\w* Babylon during \w the|strong="H5927"\w* \w reign|strong="H4438"\w* \w of|strong="H4428"\w* \w King|strong="H4428"\w* Artaxerxes:   
\b  
\li1
\v 2 from the descendants of Phinehas, Gershom;  
\b  
\li1 from the descendants of Ithamar, Daniel;  
\b  
\li1 from the descendants of David, Hattush  
\v 3 of the descendants of Shecaniah;  
\b  
\li1 from the descendants of Parosh, Zechariah, and with him were registered 150 men;   
\b  
\li1
\v 4 from the descendants of Pahath-Moab, Eliehoenai son of Zerahiah, and with him 200 men;   
\b  
\li1
\v 5 from the descendants of Zattu, Shecaniah son of Jahaziel,\f + \fr 8:5 \ft Some LXX manuscripts (see also 1 Esdras 8:32); Hebrew from the descendants of Shecaniah, the son of Jahaziel\f* and with him 300 men;   
\b  
\li1
\v 6 from the descendants of Adin, Ebed son of Jonathan, and with him 50 men;   
\b  
\li1
\v 7 from the descendants of Elam, Jeshaiah son of Athaliah, and with him 70 men;   
\b  
\li1
\v 8 from the descendants of Shephatiah, Zebadiah son of Michael, and with him 80 men;   
\b  
\li1
\v 9 from the descendants of Joab, Obadiah son of Jehiel, and with him 218 men;   
\b  
\li1
\v 10 from the descendants of Bani, Shelomith son of Josiphiah,\f + \fr 8:10 \ft Some LXX manuscripts (see also 1 Esdras 8:36); Hebrew from the descendants of Shelomith, the son of Josiphiah\f* and with him 160 men;   
\b  
\li1
\v 11 from the descendants of Bebai, Zechariah son of Bebai, and with him 28 men;   
\b  
\li1
\v 12 from the descendants of Azgad, Johanan son of Hakkatan, and with him 110 men;   
\b  
\li1
\v 13 from the later \f + \fr 8:13 \ft Or the last\f* descendants of Adonikam, these were their names: Eliphelet, Jeiel, and Shemaiah, and with them 60 men;   
\b  
\li1
\v 14 and from the descendants of Bigvai, both Uthai and Zaccur,\f + \fr 8:14 \ft LXX, Syriac, and an alternate MT reading; the other alternate reads Zabbud.\f* and with them 70 men.   
\s1 Ezra Sends for the Levites  
\b  
\m
\v 15 \w Now|strong="H3117"\w* \w I|strong="H3117"\w* \w assembled|strong="H6908"\w* \w these|strong="H5971"\w* \w exiles|strong="H1121"\w* \w at|strong="H2583"\w* \w the|strong="H3117"\w* \w canal|strong="H5104"\w* \w that|strong="H5971"\w* flows \w to|strong="H3117"\w* Ahava, \w and|strong="H1121"\w* \w we|strong="H3068"\w* \w camped|strong="H2583"\w* \w there|strong="H8033"\w* \w three|strong="H7969"\w* \w days|strong="H3117"\w*. \w And|strong="H1121"\w* \w when|strong="H3117"\w* \w I|strong="H3117"\w* searched \w among|strong="H4672"\w* \w the|strong="H3117"\w* \w people|strong="H5971"\w* \w and|strong="H1121"\w* \w priests|strong="H3548"\w*, \w I|strong="H3117"\w* \w found|strong="H4672"\w* \w no|strong="H3808"\w* \w Levites|strong="H3878"\w* \w there|strong="H8033"\w*.   
