\v 14 \w No|strong="G3361"\w* \w se|strong="G1096"\w* unan \w en|strong="G4314"\w* yugo desigual \w con|strong="G4314"\w* incrédulos, \w porque|strong="G1063"\w* ¿\w qué|strong="G5101"\w* compañerismo hay \w entre|strong="G4314"\w* \add la \add*\w justicia|strong="G1343"\w* \w y|strong="G2532"\w* \add la \add*iniquidad? ¿\w Qué|strong="G5101"\w* \w comunión|strong="G2842"\w* hay \w entre|strong="G4314"\w* \add la \add*\w luz|strong="G5457"\w* \w y|strong="G2532"\w* \add la \add*oscuridad?  
\v 15 ¿\w Qué|strong="G5101"\w* acuerdo hay \w entre|strong="G4314"\w* \w Cristo|strong="G5547"\w* \w y|strong="G1161"\w* Belial? ¿\w O|strong="G2228"\w* \w qué|strong="G5101"\w* \w parte|strong="G3310"\w* \add tiene\add* un \w creyente|strong="G4103"\w* \w con|strong="G3326"\w* un incrédulo?  
\v 16 ¿\w Qué|strong="G3754"\w* acuerdo \w hay|strong="G3588"\w* \w entre|strong="G1722"\w* \w el|strong="G3588"\w* santuario \w de|strong="G1722"\w* \w Dios|strong="G2316"\w* \w y|strong="G2532"\w* \add los\add* \w ídolos|strong="G1497"\w*? \w Porque|strong="G1063"\w* \w nosotros|strong="G2249"\w* somos santuario \w del|strong="G3588"\w* \w Dios|strong="G2316"\w* \w que|strong="G3754"\w* \w vive|strong="G2198"\w*. \w Como|strong="G2531"\w* \w Dios|strong="G2316"\w* \w dijo|strong="G3004"\w*:  
\m \wj Moraré \+w en|strong="G1722"\+w* \+w ellos|strong="G3588"\+w*. \+w Andaré|strong="G1704"\+w* \+w entre|strong="G1722"\+w* \+w ellos|strong="G3588"\+w*. Seré \+w su|strong="G3588"\+w* \+w Dios|strong="G2316"\+w*, \+w y|strong="G2532"\+w* \+w ellos|strong="G3588"\+w* serán \+w mi|strong="G3588"\+w* \+w pueblo|strong="G2992"\+w*.\wj*   
\p
\v 17 \wj \+w Por|strong="G1537"\+w* tanto \wj*  
\m \wj salgan \+w de|strong="G1537"\+w* \+w en|strong="G1537"\+w* \+w medio|strong="G3319"\+w* \+w de|strong="G1537"\+w* \+w ellos|strong="G1537"\+w* \+w y|strong="G2532"\+w* sepárense,\wj* \w dice|strong="G3004"\w* \w el|strong="G1537"\w* \w Señor|strong="G2962"\w*. \wj \+w No|strong="G3361"\+w* toquen lo impuro. \+w Yo|strong="G2504"\+w* \+w los|strong="G2532"\+w* tomaré. \wj*  
\v 18 \wj \+w Y|strong="G2532"\+w* seré \+w para|strong="G1519"\+w* ustedes \+w Padre|strong="G3962"\+w*, \+w y|strong="G2532"\+w* ustedes serán \+w para|strong="G1519"\+w* Mí \+w hijos|strong="G5207"\+w* \+w e|strong="G2532"\+w* \+w hijas|strong="G2364"\+w*,\wj* \w dice|strong="G3004"\w* el \w Señor|strong="G2962"\w* \w Todopoderoso|strong="G3841"\w*.   
\c 7  
\p
\v 1 \w Por|strong="G1722"\w* tanto, amados, \w puesto|strong="G1722"\w* \w que|strong="G3588"\w* \w tenemos|strong="G2192"\w* \w estas|strong="G3778"\w* \w promesas|strong="G1860"\w*, purifiquémonos \w de|strong="G1722"\w* \w toda|strong="G3956"\w* contaminación \w del|strong="G3588"\w* cuerpo \w y|strong="G2532"\w* \w del|strong="G3588"\w* \w espíritu|strong="G4151"\w*, \w y|strong="G2532"\w* perfeccionemos \add la\add* santidad \w en|strong="G1722"\w* \add el\add* \w temor|strong="G5401"\w* \w a|strong="G1722"\w* \w Dios|strong="G2316"\w*.   
\s1 Gozo por el arrepentimiento  
\p
\v 2 Admítannos. A \w nadie|strong="G3762"\w* hicimos mal, a \w nadie|strong="G3762"\w* corrompimos, a \w nadie|strong="G3762"\w* engañamos.  
\v 3 \w No|strong="G3756"\w* \add lo\add* \w digo|strong="G3004"\w* \w para|strong="G1519"\w* condenación, \w porque|strong="G1063"\w* \w ya|strong="G2532"\w* \w dije|strong="G3004"\w* \w que|strong="G3754"\w* están \w en|strong="G1722"\w* nuestros \w corazones|strong="G2588"\w* \w para|strong="G1519"\w* \w morir|strong="G4880"\w* \w y|strong="G2532"\w* \w vivir|strong="G4800"\w* juntos.  
\v 4 \w Yo|strong="G1473"\w* tengo \w mucha|strong="G4183"\w* franqueza \w con|strong="G4314"\w* ustedes. \w Me|strong="G1473"\w* enaltezco \w mucho|strong="G4183"\w* \w por|strong="G5228"\w* \w esto|strong="G3588"\w*. \w Me|strong="G1473"\w* \w llené|strong="G4137"\w* \w de|strong="G1909"\w* \w consolación|strong="G3874"\w*. \w Sobreabundo|strong="G5248"\w* \w de|strong="G1909"\w* \w gozo|strong="G5479"\w* \w en|strong="G1909"\w* \w todas|strong="G3956"\w* nuestras \w aflicciones|strong="G2347"\w*.   
\p
\v 5 \w Porque|strong="G1063"\w* \w en|strong="G1722"\w* verdad \w cuando|strong="G1722"\w* fuimos \w a|strong="G1519"\w* \w Macedonia|strong="G3109"\w*, \w nuestro|strong="G2249"\w* cuerpo \w no|strong="G3762"\w* \w tuvo|strong="G2192"\w* algún reposo, sino fuimos afligidos \w en|strong="G1722"\w* \w todo|strong="G3956"\w*: \w de|strong="G1722"\w* afuera, conflictos, \w de|strong="G1722"\w* adentro, \w temores|strong="G5401"\w*.  
\v 6 Pero \w Dios|strong="G2316"\w*, \w Quien|strong="G3588"\w* \w consuela|strong="G3870"\w* \w a|strong="G1722"\w* \w los|strong="G3588"\w* \w humildes|strong="G5011"\w*, \w nos|strong="G2316"\w* \w consoló|strong="G3870"\w* \w con|strong="G1722"\w* \w la|strong="G3588"\w* \w presencia|strong="G3952"\w* \w de|strong="G1722"\w* \w Tito|strong="G5103"\w*,  
\v 7 \w no|strong="G3756"\w* \w solo|strong="G3441"\w* \w con|strong="G1722"\w* \w su|strong="G3588"\w* \w presencia|strong="G3952"\w*, \w sino|strong="G1161"\w* \w también|strong="G2532"\w* \w con|strong="G1722"\w* \w la|strong="G3588"\w* \w consolación|strong="G3874"\w* \w que|strong="G3588"\w* \add él\add* recibió \w de|strong="G1722"\w* ustedes. \w Pues|strong="G1161"\w* nos informó \w del|strong="G3588"\w* anhelo \w de|strong="G1722"\w* ustedes, \w de|strong="G1722"\w* \w su|strong="G3588"\w* llanto \w y|strong="G2532"\w* preocupación \w por|strong="G1722"\w* \w mí|strong="G3588"\w*. Fui consolado \w hasta|strong="G1909"\w* \w el|strong="G3588"\w* punto \w de|strong="G1722"\w* regocijarme \w aun|strong="G2532"\w* \w más|strong="G1161"\w*.   
\p
\v 8 \w Pues|strong="G1063"\w* \w ciertamente|strong="G1063"\w* \w los|strong="G3588"\w* entristecí \w con|strong="G1722"\w* \w la|strong="G3588"\w* \w epístola|strong="G1992"\w*, \w pero|strong="G2532"\w* \w no|strong="G3756"\w* \w me|strong="G4314"\w* pesa, \w aunque|strong="G1487"\w* \w entonces|strong="G2532"\w* \w me|strong="G4314"\w* lamenté. Veo \w que|strong="G3754"\w* \w aunque|strong="G1487"\w* \w aquella|strong="G1565"\w* \w epístola|strong="G1992"\w* \w los|strong="G3588"\w* entristeció \w por|strong="G1722"\w* algún \w tiempo|strong="G5610"\w*,  
\v 9 \w ahora|strong="G3568"\w* gozo, \w no|strong="G3756"\w* \w porque|strong="G1063"\w* fueron \w entristecidos|strong="G3076"\w*, sino \w porque|strong="G1063"\w* fueron \w entristecidos|strong="G3076"\w* \w para|strong="G1519"\w* cambio \w de|strong="G1537"\w* mente. Fueron \w entristecidos|strong="G3076"\w* \w según|strong="G2596"\w* \w Dios|strong="G2316"\w* \w para|strong="G1519"\w* \w que|strong="G3754"\w* \w en|strong="G1722"\w* \w nada|strong="G3367"\w* fueran \w entristecidos|strong="G3076"\w* \w por|strong="G1722"\w* \w causa|strong="G2596"\w* \w de|strong="G1537"\w* \w nosotros|strong="G2249"\w*.   
\p
\v 10 \w La|strong="G3588"\w* \w tristeza|strong="G3077"\w* \w según|strong="G2596"\w* \w Dios|strong="G2316"\w* se activa \w en|strong="G1519"\w* cambio \w de|strong="G1519"\w* mente \w para|strong="G1519"\w* \w salvación|strong="G4991"\w* sin remordimiento, \w pero|strong="G1161"\w* \w la|strong="G3588"\w* \w tristeza|strong="G3077"\w* \w del|strong="G3588"\w* \w mundo|strong="G2889"\w* se manifiesta \w en|strong="G1519"\w* \w muerte|strong="G2288"\w*.  
\v 11 Consideren \w que|strong="G3588"\w* \w por|strong="G1722"\w* ser \w entristecidos|strong="G3076"\w* \w según|strong="G2596"\w* \w Dios|strong="G2316"\w*, ¡\w cuánta|strong="G4214"\w* \w diligencia|strong="G4710"\w* \w se|strong="G1438"\w* manifestó \w en|strong="G1722"\w* ustedes! \w También|strong="G5210"\w* defensa, indignación, \w temor|strong="G5401"\w*, ardiente afecto, \w celo|strong="G2205"\w* \w y|strong="G1063"\w* \w vindicación|strong="G1557"\w*. \w Se|strong="G1438"\w* demostraron \w a|strong="G1722"\w* ustedes mismos \w que|strong="G3588"\w* \w son|strong="G1510"\w* inocentes \w en|strong="G1722"\w* \w todo|strong="G3956"\w*.   
\p
\v 12 \w Así|strong="G2532"\w* \w que|strong="G3588"\w*, \w aunque|strong="G1487"\w* \w les|strong="G4314"\w* \w escribí|strong="G1125"\w*, \w no|strong="G3756"\w* ocurrió \w por|strong="G5228"\w* \w causa|strong="G1752"\w* \w del|strong="G3588"\w* \w que|strong="G3588"\w* cometió \w el|strong="G3588"\w* agravio, \w ni|strong="G3761"\w* \w por|strong="G5228"\w* \w el|strong="G3588"\w* agraviado, \w sino|strong="G1487"\w* \w para|strong="G4314"\w* \w que|strong="G3588"\w* \w la|strong="G3588"\w* devoción \w de|strong="G4314"\w* \w nosotros|strong="G2249"\w* \w por|strong="G5228"\w* ustedes \w delante|strong="G1799"\w* \w de|strong="G4314"\w* \w Dios|strong="G2316"\w* \w se|strong="G4314"\w* \w manifestara|strong="G5319"\w*.  
\v 13 \w Por|strong="G1223"\w* \w esto|strong="G3778"\w* fuimos consolados. \w Pero|strong="G1161"\w* fuimos regocijados \w mucho|strong="G4056"\w* \w más|strong="G1161"\w* \w por|strong="G1223"\w* \w el|strong="G3588"\w* \w gozo|strong="G5479"\w* \w de|strong="G1909"\w* \w Tito|strong="G5103"\w*, \w porque|strong="G3754"\w* \w su|strong="G3588"\w* \w espíritu|strong="G4151"\w* fue tranquilizado \w por|strong="G1223"\w* \w todos|strong="G3956"\w* ustedes.  
\v 14 \w Porque|strong="G3754"\w* \w si|strong="G1487"\w* \w en|strong="G1722"\w* \w algo|strong="G5100"\w* \w me|strong="G1473"\w* enaltecí \w con|strong="G1722"\w* respecto \w a|strong="G1909"\w* ustedes, \w no|strong="G3756"\w* \w fui|strong="G1096"\w* avergonzado. \w Más|strong="G2532"\w* bien, \w como|strong="G5613"\w* \w todas|strong="G3956"\w* \w las|strong="G3588"\w* \w cosas|strong="G5100"\w* \w que|strong="G3754"\w* \w hablamos|strong="G2980"\w* \w en|strong="G1722"\w* \w cuanto|strong="G3588"\w* \w a|strong="G1909"\w* ustedes \w son|strong="G1487"\w* \w verdad|strong="G1909"\w*, \w así|strong="G3779"\w* \w también|strong="G2532"\w* \w nuestra|strong="G3588"\w* buena apreciación \w ante|strong="G1909"\w* \w Tito|strong="G5103"\w* \w fue|strong="G1096"\w* \w verdad|strong="G1909"\w*.  
\v 15 \w Su|strong="G3588"\w* afecto entrañable \w hacia|strong="G1519"\w* ustedes es \w aun|strong="G2532"\w* \w más|strong="G2532"\w* abundante \w cuando|strong="G5613"\w* \add él\add* \w se|strong="G2532"\w* acuerda \w de|strong="G1519"\w* \w la|strong="G3588"\w* \w obediencia|strong="G5218"\w* \w de|strong="G1519"\w* \w todos|strong="G3956"\w* ustedes, \w cómo|strong="G5613"\w* \w lo|strong="G3588"\w* \w recibieron|strong="G1209"\w* \w con|strong="G3326"\w* \w temor|strong="G5401"\w* \w y|strong="G2532"\w* \w temblor|strong="G5156"\w*.  
