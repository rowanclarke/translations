\id RUT
\h رَاعُوثْ
\toc1 رَاعُوثْ
\toc2 رَاعُوثْ
\toc3 رَاع.
\mt1 رَاعُوثْ
\c 1
\m 
\v 1 ذڭْ وُوسَّانْ إِ ذِي قطَّانْ ڒْقُوضَاثْ ڒحْكَامَاثْ \add ذِي ثمُّورْثْ\add*، إِمْسَارْ إِجّْ ن ڒَاژْ ذِي ثمُّورْثْ. س ؤُينِّي إِفّغْ إِجّْ ن ورْيَازْ زِي بَايْثْ-لَاحْمْ ذِي يَاهُوذِييَّا حِيمَا أَذْ إِزْذغْ ذ أَبَارَّانِي ذڭْ إِيَّارنْ ن مُوآبَ، نتَّا ذ ثمْغَارْثْ نّسْ ذ ثْنَاينْ ن إِحنْجِيرنْ نّسْ أَكِيذسْ.
\v 2 أَرْيَازْ تّْڒَاغَانْ أَسْ \bd أَلِيمَالِيكْ\bd*، ثَامْغَارْثْ نّسْ تّْڒَاغَانْ أَسْ \bd نَاعُومِي\bd*، ذ ثْنَاينْ ن إِحنْجِيرنْ نّسْ تّْڒَاغَانْ أَسنْ مَاحْلُونْ ذ كِيلْيُونْ، \add نِيثْنِي ثُوغَا أَثنْ ذ\add* أَيْثْ ن إِفْرَاثَا زِي بَايْثْ-لَاحْمْ ذِي يَاهُوذِييَّا. نِيثْنِي إِوْضنْ غَارْ إِيَّارنْ ن مُوآبَ، قِّيمنْ ذِينِّي.
\v 3 أَلِيمَالِيكْ، أَرْيَازْ ن نَاعُومِي، إِمُّوثْ. ثقِّيمْ \bd نتَّاثْ\bd* أَكْ-ذ ثْنَاينْ ن وَارَّاوْ نّسْ.
\v 4 إِنَا إِوْينْ ثِيمْغَارِينْ ن مُوآبَ، إِسمْ ن إِشْثْ قَّارنْ أَسْ عُورْفَا ؤُ إِسمْ ن ثنّغْنِي رَاعُوثْ، ؤُشَا قِّيمنْثْ ذِينِّي ڒْقدّْ ن عْڒَاحَاڒْعشْرَا ن إِسڭّْوُوسَا.
\v 5 ؤُ مُّوثنْ ؤُڒَا ذ ثْنَاينْ نِّي: مَاحْلُونْ ذ كِيلْيُونْ. ثقِّيمْ ثمْغَارْثْ \add وحّْذسْ\add*، بْڒَا ثْنَاينْ ن وَارَّاوْ نّسْ ؤُ بْڒَا أَرْيَازْ نّسْ.
\b
\s1 أَعْقَابْ ن نَاعُومِي أَكْ-ذ رَاعُوثْ
\m 
\v 6 ؤُشَا ثعْذڒْ نَاعُومِي إِخفْ نّسْ أَكْ-ذ ثسْڒَاثِينْ نّسْ، حِيمَا أَذْ د-ثذْوڒْ زڭْ إِيَّارنْ ن مُوآبَ، مَاغَارْ ثُوغَا ثسْڒَا أَقَا سِيذِي يَارْزفْ إِ ڒْڭنْسْ نّسْ ؤُشَا إِوْشَا أَسنْ أَغْرُومْ.
\v 7 \add س ؤُينِّي\add* ثفّغْ نتَّاثْ أَكْ-ذ ثْنَاينْ ن ثسْڒَاثِينْ نّسْ زڭْ ومْشَانْ مَانِي ثُوغَا ثقِّيمْ \add مَارَّا ڒْوقْثْ نِّي\add*. نِيثنْثِي رُوحنْثْ ذڭْ وبْرِيذْ مَاحنْذْ أَذْ أَرڭّْوْحنْثْ غَارْ ثمُّورْثْ ن يَاهُوذِييَّا.
\v 8 ثنَّا نَاعُومِي إِ ثْنَاينْ ن ثسْڒَاثِينْ نّسْ: ”أَرڭّْوْحنْثْ-إِ-د، ذوْڒنْثْ-إِ-د، كُوڒْ إِشْثنْ غَارْ ثَادَّارْثْ ن يمَّاسْ! سِيذِي أَذْ أَكنْثْ إِوْشْ ثَامخْسِيوْثْ \add نّسْ\add* إِشوَّارنْ، أَمْ مَامّشْ ت ثڭِّينْثْ ذڭْ إِمتَّانْ ؤُ ذَايِي.
\v 9 سِيذِي أَذْ يجّْ أَذْ ثَافنْثْ أَرَّاحثْ، كُوڒْ إِشْثنْ ذِي ثَادَّارْثْ ن ورْيَازْ نّسْ!“ خنِّي ثسُّوذمْ إِ-ثنْثْ ؤُشَا نِيثنْثِي سّْڭعّْذنْثْ ثْمِيجَّا نْسنْثْ، سْغُوينْثْ،
\v 10 نَّانْثْ أَسْ: ”نشِّينْ أَذْ د-نذْوڒْ نِيشَانْ أَكِيذمْ غَارْ ڒْڭنْسْ نّمْ!“
\v 11 نَاعُومِي ثنَّا: ”عقْبنْثْ-إِ-د، أَ يسِّي! مَايمِّي ثخْسنْثْ أَكِيذِي ثْرَاحنْثْ؟ مَا \add غَارِي\add* ذڭْ ؤُعذِّيسْ إِنُو عَاذْ إِحنْجِيرنْ نِّي إِزمَّارنْ أَذْ ذوْڒنْ ذ إِرْيَازنْ إِ كنِّينْثْ؟
\v 12 عقْبنْثْ-إِ-د، أَ يسِّي إِنُو! رُوحنْثْ، مِينْزِي نشّْ أَقَا وْسَارغْ مَاحنْذْ أَذْ غَارِي يِيڒِي عَاذْ ورْيَازْ. وَاخَّا نِّيغْ: ’نشّْ غَارِي عَاذْ أَسِيثمْ!‘، وَاهْ، إِڒِي دْجِيڒثْ-أَ أَذْ إِڒِيغْ إِ يِيجّْ ن ورْيَازْ، وَاهْ، أَذْ أَرْوغْ إِحنْجِيرنْ،
\v 13 مَا ثخْسنْثْ أَذْ ثْرَاجَانْثْ أَڒْ غَا مْغَارنْ، مَا ثخْسنْثْ أَذْ ثْمنْعنْثْ إِخفْ نْكنْثْ مَاحنْذْ أَذْ ثْذوْڒنْثْ إِ يِيجّْ ن ورْيَازْ؟ لَّ، أَ يسِّي! أَقَا أَمدُّورْ إِنُو إِفّغْ ذ أَمرْزَاڭْ خَاكنْثْ أَطَّاسْ، مَاغَارْ إِفّغْ-د ؤُفُوسْ ن سِيذِي ضِيدّْ أَيِي.“
\v 14 \add خنِّي\add* سّْڭعّْذنْثْ ثِيمِيجَّاوِينْ نْسنْثْ ؤُشَا أَرْنِينْثْ عَاذْ ذڭْ إِغُويَّانْ ؤُشَا عُورْفَا ثسُّوذمْ لَالَّاسْ، مَاشَا رَاعُوثْ ثقِّيمْ ثڒْصقْ ذَايسْ.
\m 
\v 15 ثنَّا: ”خْزَارْ، ثَانُوطْ نّمْ أَقَا ثذْوڒْ غَارْ ڒْڭنْسْ نّسْ ؤُ غَارْ إِربِّيثنْ نّسْ. ذْوڒْ، ثضْفَارذْ ثَانُوطْ نّمْ!“
\v 16 رَاعُوثْ ثَارَّا-د خَاسْ: ”وَارْ خَافِي تّْزِييَّارْ حِيمَا أَذْ ذَايمْ سمْحغْ ؤُشَا أَذْ د-ذوْڒغْ أَوَارْنِي إِ وعْرُورْ نّمْ، مِينْزِي مَانِي غَا ثُويُورذْ شمْ، ذِينْ إِ غَا ؤُيُورغْ ؤُڒَا ذ نشّْ، ؤُ مَانِي إِ غَا ثسّنْسذْ شمْ، ذِينْ إِ غَا سّنْسغْ ؤُڒَا ذ نشّْ، ڒْڭنْسْ نّمْ ذ ڒْڭنْسْ إِنُو، ذ أَربِّي نّمْ ذ أَربِّي إِنُو.
\v 17 مَانِي إِ غَا ثمّْثذْ، ذِينْ إِ غَا مّْثغْ ؤُڒَا ذ نشّْ ؤُ ذِينْ إِ غَا تّْوَانضْڒغْ ؤُڒَا ذ نشّْ. أجّْ أَذْ أَيِي إِڭّْ سِيذِي ثَا ذ ثَا ؤُشَا أَذْ ذَايسْ يَارْنِي عَاذْ، مِينْزِي مْغِيرْ ڒْموْثْ إِ ذ أَيِي غَا إِبْضَانْ خَامْ!“
\v 18 أَڒَامِي ثژْرَا \add نَاعُومِي\add* بلِّي نتَّاثْ ثڭَّا خْ ثشْڒِي، وَارْ ثقِّيمْ ثسَّاوَاڒْ عَاذْ أَكِيذسْ.
\m 
\v 19 أَمُّو إِ يُويُورنْثْ س ثْنَاينْ إِذْسنْثْ أَڒَامِي إِوْضنْثْ غَارْ بَايْثْ-لَاحْمْ. ؤُمِي إِوْضنْثْ غَارْ بَايْثْلَاحْمْ، إِمْسَارْ، أَقَا مَارَّا ثَانْذِينْثْ ثنّحْوڒْ ذِي طّْوعْ نْسنْثْ ؤُشَا نَّانْثْ \add ثمْغَارِينْ\add*: ”مَا ذ ثَا ذ نَاعُومِي؟“
\v 20 مَاشَا نتَّاثْ ثَارَّا-د خَاسنْ ثنَّا: ”وَارْ ذ أَيِي تّْڒَاغَانْثْ ’نَاعُومِي‘ \add سَّا ذ ثْسَاونْثْ\add*، \add مَاشَا\add* ڒَاغَانْثْ أَيِي: ’مَارَا‘، مَاغَارْ أَمْزمَّارْ خْ كُوڒْشِي إِڭَّا ذَايِي ثَارْزُوڭِي ذ ثَامقّْرَانْثْ.\f ◼ \fr 1:‏20 \ft \bd ’مَارَا‘\bd* - مَانْ أَيَا إِخْسْ أَذْ يِينِي ’ثَامَارْزَاڭْثْ‘.\f*
\v 21 فّْغغْ شُّورغْ مَاشَا سِيذِي إِجَّا أَيِي أَذْ د-أَرڭّْوْحغْ س إِفَاسّنْ خْوَانْ. مَايمِّي ذ أَيِي تّْڒَاغَانْثْ \add عَاذْ\add* ’نَاعُومِي‘ ؤُمِي خَافِي إِشْهذْ سِيذِي ؤُ أَمْزمَّارْ خْ كُوڒْشِي إِڭَّا أَيِي مِينْ إِدْجَانْ ذ أَعفَّانْ؟“
\v 22 \add أَمُّو\add* إِ ثَارڭّْوحْ نَاعُومِي أَكْ-ذ رَاعُوثْ، ثَامُو‘أَبشْثْ، ثَاسْڒِيفْثْ نّسْ نِّي د-إِذوْڒنْ أَكِيذسْ زڭْ إِيَّارنْ ن مُوآبَ. إِوْضنْثْ نِيثنْثِي غَارْ بَايْثْلْ-لَاحْمْ غَارْ ؤُمزْوَارُو ن ثْميْرَا ن إِمنْذِي. \f ◼ \fr 1:‏22 \ft \bd ’إِمنْذِي‘\bd* - نِيغْ ’شَاعِيرْ‘ ( الشعير).\f*
\b
\b
\c 2
\s1 رَاعُوثْ ذڭْ إِيَّارْ ن بُوعَازْ
\m 
\v 1 نَاعُومِي ثُوغَا غَارسْ إِجّنْ زِي ڒَادْجْ ن ورْيَازْ نّسْ، إِجّْ ن ورْيَازْ س وَاطَّاسْ ن وَاڭْڒَا، زِي ڒَادْجْ ن أَلِيمَالِيكْ، تّْڒَاغَانْ أَسْ بُوعَازْ. \x ◘ \xo 2:‏1 \xt مت. 1‏:‏5\x*
\v 2 ثنَّا رَاعُوثْ ثَامُو‘أَبشْثْ إِ نَاعُومِي: ”أجّْ أَيِي أَذْ فّْغغْ غَارْ إِيَّارْ أَذْ سّْمُونغْ ثِيذْرِينْ أَوَارْنِي إِ ونِّي إِ غَا يَافغْ أَرْضَا ذِي ثِيطَّاوِينْ نّسْ.“ ؤُشَا نتَّاثْ ثَارَّا-د خَاسْ: ”ؤُيُورْ، يدْجِي!“ \x ◘ \xo 2:‏2 \xt لَاوِي 19‏:‏9؛ 23‏:‏22، أَعَوذ. 24‏:‏19\x*
\m 
\v 3 رَاعُوثْ ثُويُورْ ؤُشَا ثُوسَا-د ذِينْ، ثسّْمُونَا أَوَارْنِي إِ يِينِّي إِمجَّارنْ. ؤُشَا إِمْسَارْ، ثوْضَا أَسْ-د ثسْغَارْثْ ن ييَّارْ ن بُوعَازْ ونِّي زِي ڒَادْجْ ن أَلِيمَالِيكْ.
\v 4 ؤُ خْزَارْ، يُوسَا-د بُوعَازْ زِي بَايْثْ-لَاحْمْ، إِنَّا إِ يِينِّي إِمجَّارنْ: ”سِيذِي أَكِيذْومْ!“ نِيثْنِي أَرِّينْ-د خَاسْ: ”سِيذِي أَذْ شكْ إِبَاركْ!“
\v 5 \add خنِّي\add* إِنَّا بُوعَازْ إِ ؤُمْسخَّارْ نّسْ ونِّي ثُوغَا خْ يِينِّي إِمجَّارنْ: ”ؤُمِي ثڭَّا يدْجِيسْ ثَاحنْجِيرْثْ نِّي؟“
\v 6 أَمْسخَّارْ ونِّي ثُوغَا خْ يِينِّي إِمجَّارنْ، يَارَّا-د خَاسْ، إِنَّا: ”نتَّاثْ ذ ثَاحنْجِيرْثْ ثَامُو‘أَبشْثْ إِ د-يُوسِينْ أَكْ-ذ نَاعُومِي زڭْ إِيَّارْ ن مُوآبَ.
\v 7 نتَّاثْ ثنَّا: ’أجّْ أَيِي أَذْ سّْمُونغْ ثِيذْرِينْ ؤُ أَذْ يَارْوغْ ثِيذْرِينْ غَارْ إِشوَّافنْ \add ن إِمنْذِي\add* أَوَارْنِي إِ يِينِّي إِمجَّارنْ!‘ أَمُّو إِ د-ثُوسَا ؤُشَا ثقِّيمْ زڭْ ؤُثفُّو ن ڒْحَاڒْ أَڒْ ڒخُّو. ذْرُوسْ وَاهَا إِ ثقِّيمْ ذِي ثَادَّارْثْ.“
\m 
\v 8 بُوعَازْ إِنَّا إِ رَاعُوثْ: ”سْحسْ غَارِي، أَ يدْجِي! وَارْ ثْڒقّْضذْ ؤُڒَا غَارْ إِجّْ ن ييَّارْ نّغْنِي، وَارْ تَّاڭّْوجْ زِي سَّا، مَاشَا قِّيمْ ثُوذْسذْ غَارْ ثمْسخَّارِينْ إِنُو.
\v 9 \add ثبّثْ\add* ثِيطَّاوِينْ نّمْ ذڭْ إِيَّارْ أَيَا مَانِي مجَّارنْ، ؤُيُورْ أَوَارْنِي أَسنْثْ. نشّْعڒْمغْ إِ إِمْسخَّارنْ إِنُو، وَارْ شمْ تّْحِيذِينْ. \add مَاڒَا\add* ثفُّوذذْ، ثْزمَّارذْ أَذْ ثُويُورذْ غَارْ إِقُوبَاشْ أَذْ ثسْوذْ زِي مِينْ ذ يُويْمنْ إِمْسخَّارنْ.“
\v 10 نتَّاثْ ثوْضَا خْ وُوذمْ نّسْ ؤُشَا ثُوضَارْ غَارْ ثمُّورْثْ، ثنَّا أَسْ: ”مَايمِّي ؤُفِيغْ أَرْضَا ذِي ثِيطَّاوِينْ نّشْ، أَقَا شكْ ثْبدّذْ أَكِيذِي، \add وَاخَّا\add* نشّْ ذ ثَابَارَّانِيثْ؟“
\v 11 بُوعَازْ يَارَّا-د خَاسْ، إِنَّا: ”أَقَا نَّانْ أَيِي نِيشَانْ مَارَّا مِينْ ثڭِّيذْ إِ لَالَّامْ أَوَارْنِي إِ ڒْموْثْ ن ورْيَازْ نّمْ، مَامّشْ ثڭِّيذْ ثْسمْحذْ ذِي بَابَامْ ذ يمَّامْ ذ ثمُّورْثْ نّمْ مَانِي ثْخڒْقذْ ؤُشَا ثُويُورذْ غَارْ إِجّْ ن ڒْڭنْسْ إِ وَارْ ث ثسِّينذْ قْبڒْ.
\v 12 أَذْ شمْ إِخدْجصْ سِيذِي ن إِسْرَائِيل ثَاسخَّارْثْ نّمْ \add ثَاصبْحَانْثْ\add* إِ ثڭِّيذْ ؤُشَا أَذْ أَمْ د-ثَاسْ ڒْمُونثْ ثشُّورْ زِي سِيذِي، أَربِّي ن إِسْرَائِيل، سَاذُو إِفْرِيونْ نّسْ إِ د-ثُوسِيذْ مَاحنْذْ أَذْ ذِينِّي ثدُّورْيذْ.“ \x ◘ \xo 2:‏12 \xt أَعَوذ. 32‏:‏11؛ إِزهد. 36‏:‏8؛ 57‏:‏2؛ 91‏:‏4\x*
\v 13 نتَّاثْ ثنَّا: ”أجّْ أَيِي أَذْ أَفغْ أَرْضَا ذِي ثِيطَّاوِينْ نّشْ، أَ سِيذِي إِنُو، مِينْزِي ثسّْفوّْجذْ خَافِي، ثسِّيوْڒذْ غَارْ وُوڒْ ن ثَايَّا نّشْ، وَاخَّا نشّْ وَارْ دْجِيغْ أَمْ ؤُڒَا ذ إِشْثْ زِي ثِييَّا نّشْ.“
\m 
\v 14 غَارْ ڒْحَاڒْ ن مَاشَّا إِنَّا أَسْ بُوعَازْ: ”أَسْ-د ذَا ؤُشَا أشّْ زڭْ وغْرُومْ، سِيسنْ أَڒقُّوزْ نّمْ ذِي ڒْخدْجْ!“ نتَّاثْ ثقِّيمْ زَّاثْ إِ يِينِّي إِمجَّارنْ ؤُشَا إِوْشَا أَسْ نتَّا ثِيغْوَاوِينْ، ثشَّا ثجِّيونْ، إِشطّْ خَاسْ عَاذْ.
\v 15 أَڒَامِي ثكَّارْ حِيمَا أَذْ ثسّْمُونْ ثِيذْرِينْ، إِعْڒمْ بُوعَازْ إِ إِمْسخَّارنْ نّسْ: ”أجّْ إِ-ت أَذْ ثسّْمُونْ جَارْ إِشوَّافنْ \add ن إِمنْذِي\add* ؤُ وَارْ ت ثسّحْقَارَامْ شَا!
\v 16 غضْڒمْ أَسْ-د شْوَايْثْ شْوَايْثْ زِي ثْقبِّيضِينْ ؤُشَا جّمْ ت \add ذِي ثَامُّورْثْ\add*، ؤُشَا جّمْ ت أَذْ ثسّْمُونْ أَيَا، وَارْ ت ثْزَاوَارمْ.“
\m 
\v 17 ؤُشَا نتَّاثْ ثُوغَا ثْڒقّضْ ذڭْ إِيَّارْ نِّي أَڒْ ثَامذِّيثْ. خنِّي ثْصفَّا مِينْ ثُوغَا ثڒْقضْ. ثُوغَا عْڒَاحَاڒْ ڒْقدّْ ن إِجّْ ن إِفَا ن إِمنْذِي.
\v 18 نتَّاثْ ثسّْمُونْ إِ-ث، ثُوذفْ غَارْ ثنْذِينْثْ ؤُشَا ثژْرَا لَالَّاسْ مِينْ ثُوغَا ثڒْقضْ. ثجْبذْ \add عَاوذْ\add* مِينْ ثُوغَا إِشطّنْ زِي مَاشَّا نّسْ ثَامقّْرَانْثْ ؤُشَا ثوْشَا أَسْ ث.
\v 19 \add خنِّي\add* ثسّقْسَا لَالَّاسْ: ”مَانِي ثْڒقْضذْ أَسّْ-أَ ؤُ مَانِي ثْخذْمذْ؟ أَذْ إِتّْوَابَاركْ ونِّي ثُوغَا أَكِيذمْ إِبدّنْ!“ ؤُشَا نتَّاثْ ثْحَاجَا أَسْ إِ لَالَّاسْ وِي إِ غَارْ ثُوغَا ثخْذمْ، ثنَّا: ”أَرْيَازْ إِ غَارْ خذْمغْ أَسّْ-أَ تّْڒَاغَانْ أَسْ بُوعَازْ.“
\v 20 \add خنِّي\add* ثنَّا نَاعُومِي إِ ثسْڒِيفْثْ نّسْ: ”أَذْ إِتّْوَابَاركْ سِيذِي ونِّي وَارْ إِكِّيسنْ ثَامخْسِيوْثْ نّسْ إِشوَّارنْ زڭْ يِينِّي إِدَّارنْ ذ يِينِّي إِمُّوثنْ!“ ثنَّا أَسْ نَاعُومِي \add عَاوذْ\add*: ”أَرْيَازْ نِّي زَّايْنغْ، نتَّا ذ إِجّْ زڭْ إِمفْذِييّنْ نّغْ \add إِنِّي زمَّارنْ أَذْ سْغنْ أَفدَّايْ\add*.“ \f ◼ \fr 2:‏20 \ft \bd ’أَمفْذِي - إِمفْذِييّنْ‘\bd* - ونِّي إِزمَّارنْ أَذْ إِفكّْ أَفْذَايْ ؤُ أَذْ إِذْوڒْ عَاوذْ غَارْ ثْوَاشُونْثْ إِ غَارْ إِدْجْ وفْذَايْ ذ أَڭْڒَا ن زِيشْ.\f*  \x ◘ \xo 2:‏20 \xt لَاوِي 25‏:‏26، 48، 49\x*
\v 21 رَاعُوثْ، ثَامُو‘أَبشْثْ، ثنَّا: ”نتَّا إِنَّا أَيِي عَاذْ: ’قِّيمْ غَارْ إِمْسخَّارنْ نِّي غَارِي إِدْجَانْ، أَڒْ غَا كمّْڒنْ أَذْ سّْمُوننْ مَارَّا ثَامڭْرَا نِّي غَارِي إِدْجَانْ.‘ “
\v 22 ثنَّا نَاعُومِي إِ ثسْڒِيفْثْ نّسْ رَاعُوثْ: ”مْلِيحْ، أَ يدْجِي، مَاڒَا ثفّْغذْ شمْ أَكْ-ذ ثمْسخَّارِينْ نّسْ، خنِّي وَارْ إِدْجِي وِي شمْ إِ غَا إِهوْڒنْ ذڭْ إِيَّارْ نّغْنِي.“
\v 23 رَاعُوثْ ثقِّيمْ ثُوذسْ إِ ثمْسخَّارِينْ ن بُوعَازْ حِيمَا أَذْ ثسّْمُونْ \add ثِيذْرِينْ\add*، أَڒَامِي ثقْضَا ثْميْرَا ن إِمنْذِي ذ ثْميْرَا ن إِرْذنْ ؤُشَا ثقِّيمْ \add ثزْذغْ\add* غَارْ لَالَّاسْ.
\b
\b
\c 3
\s1 رَاعُوثْ ذ بُوعَازْ خْ ؤُنذْرَارْ
\m 
\v 1 ؤُشَا لَالَّاسْ نَاعُومِي ثنَّا أَسْ: ”أَ يدْجِي، مَا ثُوغَا وَارْ تّخْسغْ أَذْ أَمْ أَفغْ أَمْشَانْ ن ڒَامَانْ حِيمَا أَذْ ثِيڒِيذْ مْلِيحْ؟
\v 2 مَا وَارْ إِدْجِي بُوعَازْ، إِ غَارْ ثُوغَا شمْ جَارْ ثمْسخَّارِينْ نّسْ، ذ إِجّنْ زِي رَادْجْ نّغْ؟ خْزَارْ، أَسّْ-أَ غَارْ ثْمذِّيثْ، أَذْ إِزُّوزَارْ إِمنْذِي ذڭْ ؤُنذْرَارْ.
\v 3 سِيرْذْ، ذْهنْ إِخفْ نّمْ ؤُشَا يَارْضْ ثَاقنْذُورْثْ نّمْ، خنِّي هْوَا-د غَارْ ؤُنذْرَارْ! وَارْ سشَّانْ إِخفْ نّمْ إِ ورْيَازْ أَڒْ غَا يِيڒِي إِشَّا إِسْوَا.
\v 4 مَاڒَا إِرَاحْ أَذْ إِطّصْ، أَذْ ثِيڒِي أَذْ ثَارْزُوذْ أَمْشَانْ مَانِي إِزّڒْ. أَذفْ \add خنِّي\add* غَارْ ذِينْ، ثْعَارِّيذْ خْ دُّورِي خْ إِضَارنْ نّسْ ؤُشَا زّڒْ ذِينِّي! نتَّا أَذْ أَمْ يِينِي \add خنِّي\add*، مِينْ إِتّْخصَّا أَذْ ث ثڭّذْ.“
\v 5 نتَّاثْ ثَارَّا-د خَاسْ: ”مَارَّا مِينْ ذ أَيِي ثقَّارذْ، أَذْ ث ڭّغْ.“
\m 
\v 6 نتَّاثْ ثهْوَا غَارْ ؤُنذْرَارْ ؤُشَا ثڭَّا أَمنِّي قَاعْ مِينْ ثُوغَا ذ أَسْ ثنَّا لَالَّاسْ.
\v 7 \add ڒَْامِي\add* إِشَّا إِسْوَا بُوعَازْ، إِفَارْحْ وُوڒْ نّسْ، إِكَّارْ يُويُورْ، حِيمَا أَذْ إِزّڒْ غَارْ طَّارْفْ ن إِجّْ ن ؤُعُورِّيشْ ن ثْقبِّيضِينْ \add ن إِمنْذِي\add*. \add خنِّي\add* ثُوسَا-د بْڒَا ڒْحسّْ، ثْعَارَّا \add خْ دُّورِي\add* غَارْ إِضَارنْ نّسْ ؤُشَا ثزّڒْ.
\v 8 غَارْ وزْينْ ن دْجِيڒثْ إِنّخْڒعْ ورْيَازْ نِّي، إِنّقْڒبْ، ؤُشَا خْزَارْ، إِشْثْ ن ثمْغَارْثْ ثُوغَا ثزّڒْ غَارْ إِضَارنْ نّسْ.
\v 9 نتَّا إِنَّا: ”مِينْ ثعْنِيذْ شمْ؟“ نتَّاثْ ثَارَّا-د خَاسْ: ”نشّْ ذ رَاعُوثْ، ثَايَّا نّشْ. أڭّْ مَاشَا أَفْرِيوْ نّشْ خْ ثَايَّا نّشْ، مَاغَارْ شكْ ذ ونِّي إِزمَّارنْ أَذْ أَيِي إِفْذِي.“ \f ◼ \fr 3:‏9 \ft \bd ’إِفْذِي‘\bd* - خْزَارْ إِزهد. 78:35.\f*  \x ◘ \xo 3:‏9 \xt أَعَوذ. 23‏:‏1؛ 27‏:‏20؛ حِز. 16‏:‏8\x*
\v 10 إِنَّا نتَّا: ”ثتّْوَابَارْكذْ شمْ زِي سِيذِي، أَ يدْجِي! \add ڒخُّو\add* ذڭْ ؤُنڭَّارْ ثڭِّيذْ ثَامخْسِيوْثْ نّمْ إِشوَّارنْ مَاهُو س مِينْ ثڭِّيذْ ذڭْ ؤُمزْوَارُو، مَاغَارْ شمْ وَارْ ثُوزِّيڒذْ أَوَارْنِي إِ إِعزْرِييّنْ، إِمزْڒَاضْ نِيغْ أَيْثْ ن بُو وَاڭْڒَا.
\v 11 \add خنِّي\add* ڒخُّو، \add أَ\add* يدْجِي، وَارْ تّڭّْوذْ شَا! مَارَّا مِينْ غَا ثِينِيذْ، أَذْ أَمْ ث ڭّغْ، مَاغَارْ قَاعْ وِي ذَا ذِي ثوَّارْثْ \add ن ثنْذِينْثْ\add* ن ڒْڭنْسْ إِنُو إِسّنْ، أَقَا شمْ ذ إِشْثْ ن ثمْغَارْثْ ثمْحضْ.
\v 12 ڒخُّو \add خنِّي\add*، ذ ثِيذتّْ نشّْ ذ إِجّْ ن ؤُمفْذِي، مَاشَا ذِينْ عَاذْ إِجّْ ن ؤُمفْذِي نّغْنِي، ونِّي ذ أَمْ إِتّعْنَانْ كْثَارْ خَافِي نشّْ.
\v 13 سعْذُو دْجِيڒثْ-أَ ذَا. مَاڒَا إِمْسَارْ ثِيوشَّا ذِي صّْبحْ، نتَّا إِخْسْ أَذْ خَامْ إِفْذِي، مْلِيحْ، \add خنِّي\add* أجّْ إِ-ث أَذْ إِفْذِي، مَاشَا مَاڒَا نتَّا وَارْ إِخْسْ أَذْ شمْ إِفْذِي، خنِّي نشّْ أَذْ خَامْ فْذِيغْ، س ثِيذتّْ خنِّي أَمْ إِدَّارْ سِيذِي. قِّيمْ زّڒْ أَڒْ ثِيوشَّا.“
\m 
\v 14 \add أَمُّو\add* إِ ثقِّيمْ ثزّڒْ غَارْ إِضَارنْ نّسْ أَڒْ ثِيوشَّا ؤُشَا قْبڒْ مَا إِزمَّارْ إِجّْ أَذْ إِژَارْ ونّغْنِي، ثكَّارْ، \add مَاغَارْ\add* نتَّا إِنَّا: ”وَارْ ثتِّيڒِي ثتّْوَاسّْننْ، أَقَا إِشْثْ ن ثمْغَارْثْ ثُوغَا ثُوسَا-د غَارْ ؤُنذْرَارْ“
\v 15 نتَّا إِنَّا \add عَاوذْ\add*: ”كْسِي ثَاشْضَاضْثْ إِ زِي ثْڒحّْفذْ، طّفْ إِ-ت!“ ؤُشَا نتَّا إِشُّورْ إِ-ت س ستَّا ن \add ڒقْيَاسَاثْ\add* ن إِمنْذِي ؤُشَا إِسَّارْبُو ت خَاسْ. خنِّي يُوذفْ غَارْ ثنْذِينْثْ.
\m 
\v 16 ثُوسَا-د نتَّاثْ غَارْ لَالَّاسْ ؤُ ثَانِيثَا ثسّقْسَا: ”مِينْ ثعْنِيذْ شمْ، أَ يدْجِي؟“ نتَّاثْ ثْحَاجَا أَسْ مَارَّا مِينْ كِيسْ إِڭَّا ورْيَازْ \add نِّي\add*. \f ◼ \fr 3:‏16 \ft \bd ’مِينْ ثعْنِيذْ شمْ، أَ يدْجِي؟‘\bd* - إِخْسْ أَذْ يِينِي ’مَامّشْ ثدْجِيذْ، أَ يدْجِي؟‘\f*
\v 17 ثنَّا: ”ستَّا ن ڒْمُوذَاثْ-أَ ن إِمنْذِي إِوْشَا أَيِي ثنْ، مَاغَارْ نتَّا إِنَّا: ’شمْ وَارْ ثڭُّورذْ شَا غَارْ لَالَّامْ س إِفَاسّنْ إِخْوَانْ.‘ “
\v 18 \add خنِّي\add* ثنَّا \add نَاعُومِي\add*: ”رَاجَا، أَ يدْجِي، قِّيمْ \add ذَا\add* أَڒْ غَا ثسّْنذْ مَامّشْ غَا ثفّغْ ثْمسْڒَاشْثْ. مِينْزِي أَرْيَازْ \add نِّي\add* وَارْ إِتَّاريِّيحْ شَا أَڒْ د-إِسُّوفّغْ ثَامسْڒَاشْثْ عَاذْ أَسّْ-أَ غَارْ ؤُنڭَّارْ نّسْ.“
\b
\b
\c 4
\s1 پُوعَازْ إِفْذِي إِيَّارْ ن أَلِيمِيلِيكْ ؤُشَا إِمْڒشْ أَكْ-ذ رَاعُوثْ
\m 
\v 1 بُوعَازْ إِڭعّذْ غَارْ ثوَّارْثْ ن ثنْذِينْثْ ؤُشَا إِقِّيمْ ذِينِّي. ؤُ خْزَارْ، إِعْذُو-د ؤُمفْذِي، ونِّي خفْ ثُوغَا إِسِّيوڒْ بُوعَازْ. نتَّا إِنَّا أَسْ: ”أَ شكْ، ذِيهَا، أَسْ-د غَارْ طَّارْفْ \add ن وبْرِيذْ\add* ؤُ ثقِّيمذْ ذَانِيثَا!“ يُوسَا-د غَارْ طَّارْفْ \add ن وبْرِيذْ\add* ؤُشَا إِقِّيمْ.
\v 2 يِيوِي-د بُوعَازْعشْرَا ن يرْيَازنْ زڭْ إِمْغَارنْ ن ثنْذِينْثْ، إِنَّا: ”قِيممْ-د ذَانِيثَا!“، ؤُشَا قِّيمنْ.
\v 3 \add خنِّي\add* إِنَّا إِ ؤُمفْذِي: ”نَاعُومِي ثنِّي د-إِعقْبنْ زِي ثمُّورْثْ ن مُوآبَ ثخْسْ أَذْ ثزّنْزْ ثَاكِيرَاثْ ن ييَّارْ إِ ثُوغَا غَارْ ؤُمَاثْنغْ أَلِيمَالِيكْ.
\v 4 نشّْ خمّغْ، خْسغْ أَذْ شكْ خَاسْ خبَّارغْ ؤُشَا أَذْ أَشْ إِنِيغْ: سغْ إِ-ت زَّاثْ ن يِينِّي إِ ذَا إِقِّيمنْ ؤُ زَّاثْ ن إِمْغَارنْ ن ڒْڭنْسْ. مَاڒَا ثخْسذْ أَذْ ت ثفْذِيذْ، فْذِي ت ؤُ مَاڒَا وَارْ ثخْسذْ أَذْ ت ثفْذِيذْ، إِنِي أَيِي ث حِيمَا أَذْ سّْنغْ، مِينْزِي وَارْ ذَا حذْ إِزمَّارْ أَذْ ت إِفْذِي مْغِيرْ شكْ نِيغْ ذ نشّْ، ؤُ نشّْ إِ إِدْجَانْ أَوَارْنِي أَشْ.“ \add خنِّي\add* إِنَّا نتَّا: ”نشّْ أَذْ ت فْذِيغْ.“\f ◼ \fr 4:‏4 \ft \bd ’ثفْذِيذْ ... فْذِي ... إِفْذِي‘\bd* - خْزَارْ إِزهد. 78:35.\f*
\m 
\v 5 بُوعَازْ يَارْنِي إِنَّا: ”ذڭْ وَاسّْ إِ ذِي إِ غَا ثسْغذْ إِيَّارْ زڭْ ؤُفُوسْ ن نَاعُومِي، \add خنِّي\add* أَذْ ثسْغذْ أَكِيذسْ ؤُڒَا ذ رَاعُوثْ، ثَامُو‘أَبشْثْ، ثَامْغَارْثْ ن ونِّي إِمُّوثنْ، حِيمَا أَذْ ثحْضِيذْ إِسمْ ن ؤُمتِّينْ خْ ثسْغَارْثْ نّسْ ن ڒْوَارْثْ.“
\v 6 إِنَّا ؤُمفْذِي: ”\add خنِّي\add* نشّْ وَارْ زمَّارغْ أَذْ ث فْذِيغْ، حِيمَا وَارْ تّْضِييّْعغْ ثَاسْغَارْثْ إِنُو. فْذِي \add ث\add* شكْ إِ يِيخفْ نّشْ مِينْ خَافِي مَاحنْذْ أَذْ ث فْذِيغْ، مَاغَارْ نشّْ وَارْ زمَّارغْ أَذْ ث فْذِيغْ.“
\m 
\v 7 أَمُّو ثُوغَا تّڭّنْ إِنِّي ن زّْمَانْ ؤُمِي ڭِّينْ أَذْ بدّْڒنْ \add إِيَّارْ\add* جَارْ أَسنْ نِيغْ ؤُمِي ث فْذِينْ، أَقَا، حِيمَا أَذْ ثوْشذْ ثَامسْڒَاشْثْ زَّاثْ إِ وُوذمْ ن مَارَّا إِسْرَائِيل، أَقَا أَرْيَازْ إِتّكّسْ سَانْذَالَا نّسْ ؤُشَا إِتِّيشْ إِ-ت إِ جَّارْ نّسْ. ذ مَانْ أَيَا ثُوغَا إِدْجَانْ ذِي إِسْرَائِيل. \x ◘ \xo 4:‏7 \xt أَعَوذ. 25‏:‏7\x*
\v 8 أَمفْذِي إِنَّا إِ بُوعَازْ: ”سغْ إِ-ث إِ يِيخفْ نّشْ!“ ؤُشَا نتَّا إِكّسْ سَانْذَالَا نّسْ.
\v 9 \add خنِّي\add* بُوعَازْ إِنَّا إِ مَارَّا إِمْغَارنْ ؤُ إِ مَارَّا ڒْڭنْسْ: ”كنِّيوْ ذ ڒشْهُوذْ ذڭْ وَاسّْ-أَ، أَقَا نشّْ، مَارَّا مِينْ \add إِدْجَانْ\add* ن أَلِيمَالِيكْ ؤُ مَارَّا مِينْ \add إِدْجَانْ\add* ن كِيلْيُونْ ؤُ ن مَاحْلُونْ، سْغِيغْ ث زڭْ ؤُفُوسْ ن نَاعُومِي.
\v 10 ؤُڒَا ذ رَاعُوثْ، ثَامُو‘أَبشْثْ، ثَامْغَارْثْ ن مَاحْلُونْ، إِوْيغْ ت ذ ثَامْغَارْثْ، حِيمَا أَذْ إِقِّيمْ إِسمْ ن ونِّي إِمُّوثنْ خْ ثسْغَارْثْ ن ڒْوَارْثْ نّسْ، مَاحنْذْ إِسمْ ن ونِّي إِمُّوثنْ وَارْ إِتّكّسْ جَارْ أَيْثْمَاشْ ؤُ زِي ثوَّارْثْ ن ومْشَانْ ن ثْزذِّيغْثْ نّسْ. ذڭْ وَاسّْ-أَ أَقَا كنِّيوْ ذ ڒشْهُوذْ.“ *
\b
\m 
\v 11 مَارَّا ڒْڭنْسْ نِّي إِدْجَانْ ذِي ثوَّارْثْ \add ن ثنْذِينْثْ\add* ذ إِمْغَارنْ نَّانْ:
\m ”نشِّينْ ذ ڒشْهُوذْ! إِڒِي سِيذِي أَذْ يڭّْ ثَامْغَارْثْ نِّي إِ ذ غَا يَاذْفنْ غَارْ ثَادَّارْثْ نّشْ أَمْ رَاحِيلْ ذ لِييَا، ثِينِّي زَّايْسنْثْ س ثْنَاينْ ثتّْوَاڭّْ ثدَّارْثْ ن إِسْرَائِيل. أڭّْ س شْضَارثْ ذِي إِفْرَاثَا ؤُشَا أَذْ إِتّْوَابَارّحْ إِسمْ \add نّشْ\add* ذِي بَايْثْ-لَاحْمْ! \f ◼ \fr 4:‏11 \ft \bd ’رَاحِيلْ ذ لِييَا‘\bd* - نِيثنْثِي ذ ثِيمْغَارِينْ ن يَاعْقُوبْ،\f*  \x ◘ \xo 4:‏11 \xt أَمز. 29‏:‏32‏-‏35؛ 30‏:‏1‏-‏25؛ 35‏:‏17، 18\x*
\v 12 ثَادَّارْثْ نّشْ ثڭَّا أَمْ ثَادَّارْثْ ن فَارِيصْ، ونِّي ثُورُووْ-د ثَامَارْ إِ يَاهُوذَا، زڭْ وَارَّاوْ إِ ذ أَشْ غَا إِوْشْ سِيذِي زِي ثبْڒِيغْثْ-أَ.“ \x ◘ \xo 4:‏12 \xt أَمز. 38‏:‏29؛ 1 إِم. 2‏:‏4؛ مت. 1‏:‏3\x*
\b
\m 
\v 13 بُوعَازْ يِيوِي رَاعُوثْ ؤُشَا نتَّاثْ ثذْوڒْ ذ ثَامْغَارْثْ نّسْ ؤُشَا يُوذفْ خَاسْ ؤُشَا سِيذِي إِوْشَا أَسْ أَذْ ثكْسِي س دّيْسثْ ؤُشَا ثُورُووْ-د إِجّْ ن ؤُحنْجِيرْ.
\v 14 ؤُشَا نَّانْثْ ثِيمْغَارِينْ إِ نَاعُومِي: ”أَذْ إِتّْوَابَاركْ سِيذِي ونِّي وَارْ شمْ إِجِّينْ أَسّْ-أَ نْهْڒَا إِجّْ ن ؤُمفْذِي. إِڒِي أَذْ إِتّْوَابَارّحْ إِسمْ نّسْ ذِي إِسْرَائِيل!
\v 15 أَذْ غَارْومْ يِيڒِي أَمْ ونِّي د-إِسّْفَاقنْ ڒعْمَارْ نّمْ ؤُشَا أَذْ شمْ إِصُونْ خْ ثوْسَارْ نّمْ، مَاغَارْ ثَاسْڒِيفْثْ نّمْ، ثنِّي شمْ إِتّخْسنْ، ثُورُووْ إِ-ث-إِ-د، أَقَا نتَّاثْ ثحْڒَا خْ سبْعَا ن إِحنْجِيرنْ.“
\m 
\v 16 نَاعُومِي ثكْسِي أَحنْجِيرْ، ثسَّارْسْ إِ-ث خْ إِذْمَارنْ نّسْ ؤُ ثذْوڒْ ثسّْيَامْ إِ-ث.
\v 17 ثَاجَّارِينْ وْشِينْثْ أَسْ إِجّْ ن يِيسمْ، نَّانْثْ: ”إِ نَاعُومِي إِتّْوَارْوُووْ أَسْ-د إِجّْ ن ؤُحنْجِيرْ!“، ؤُ ڭِّينْ أَسْ عُوبِيذْ. نتَّا ذ بَابَاسْ ن يَاسَّا، بَابَاسْ ن ذَاوُوذْ.
\b
\s1 ڒجْذُوذْ ن ذَاوُوذْ
\m 
\v 18 \bd إِنَا ذ إِنِّي د-إِتّْوَارْونْ زِي فَارِيصْ:\bd* فَارِيصْ إِجَّا-د حَاصْرُونْ، \x ◘ \xo 4:‏18 \xt 1 إِم. 2‏:‏5؛ مت. 1‏:‏3\x*
\m 
\v 19 حَاصْرُونْ إِجَّا-د رَامْ، رَامْ إِجَّا-د عَامِّينَاذَابْ،\x ◘ \xo 4:‏19 \xt مت. 1‏:‏4\x*
\m 
\v 20 عَامِّينَاذَابْ إِجَّا-د نَاحْشُونْ، نَاحْشُونْ إِجَّا-د سَالْمُونْ، \x ◘ \xo 4:‏20 \xt 1 إِم. 2‏:‏11\x*
\m 
\v 21 سَالْمُونْ إِجَّا-د بُوعَازْ، بُوعَازْ إِجَّا-د عُوبِيذْ،\x ◘ \xo 4:‏21 \xt مت. 1‏:‏5\x*
\m 
\v 22 عُوبِيذْ إِجَّا-د يَاسَّا ذ يَاسَّا إِجَّا-د ذَاوُوذْ. \x ◘ \xo 4:‏22 \xt مت. 1‏:‏6\x* 
