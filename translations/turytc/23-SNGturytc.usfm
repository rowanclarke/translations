\id SNG - Yorumsuz Türkçe Çeviri (YTC)
\h SOLOMON'UN EZGİSİ
\toc1 SOLOMON'UN EZGİSİ
\toc2 SOLOMON'UN EZGİSİ
\toc3 SOLOMON'UN EZGİSİ
\mt1 SOLOMON'UN EZGİSİ
\c 1
\p 
\v 1 Ezgiler ezgisi, Solomon'undur.
\sp Sevgili
\q1 
\v 2 Ağzının öpüşleriyle beni öpsün;
\q2 çünkü senin sevgin şaraptan daha iyidir.
\q1 
\v 3 Esansının kokusu hoştur.
\q2 Senin adın dökülmüş esanstır,
\q2 bu yüzden kızlar seni seviyor.
\q1 
\v 4 Beni seninle birlikte al götür.
\q2 Haydi koşalım.
\q2 Kral beni odalarına götürdü.
\sp Dostlar
\q1 Sende sevineceğiz ve coşacağız.
\q2 Senin sevgini şaraptan daha çok öveceğiz!
\sp Sevgili
\q1 Seni sevmekte haklılar.
\q1 
\v 5 Ben esmerim, ama güzelim,
\q2 ey Yeruşalem kızları,
\q2 kedar çadırları gibi,
\q2 Solomon'un perdeleri gibi.
\q1 
\v 6 Esmer olduğuma bakmayın,
\q2 çünkü beni güneş yaktı.
\q1 Annemin oğulları bana kızdılar.
\q2 Beni bağlara bekçi yaptılar.
\q2 Kendi bağıma bakmadım.
\q1 
\v 7 Söyle bana, ey sen, canımın sevdiği,
\q2 sürünü nerede otlatıyorsun,
\q2 öğleyin onları nerede yatırıyorsun?
\q2 Çünkü neden arkadaşlarının sürülerinin yanında
\q2 Örtünen biri gibi olayım?
\sp Seven
\q1 
\v 8 Eğer bilmiyorsan, kadınların en güzeli,
\q2 koyun izlerini takip et.
\q2 Oğlaklarını çoban çadırlarının yanında otlat.
\q1 
\v 9 Seni, sevgilim,
\q2 Firavun'un arabalarındaki bir ata benzetirim.
\q1 
\v 10 Yanakların küpelerle,
\q2 boynun mücevher dizileriyle ne güzel.
\sp Dostlar
\q1 
\v 11 Sana altın küpeler yapacağız,
\q2 gümüş düğmelerle.
\sp Sevgili
\q1 
\v 12 Kral sofrasında otururken,
\q2 benim kokum güzel kokusunu yaydı.
\q1 
\v 13 Sevgilim benim için memelerimin
\q2 arasında yatan bir mür kesesidir.
\q1 
\v 14 Sevgilim benim için En Gedi bağlarında
\q2 bir salkım kına çiçeğidir.
\sp Seven
\q1 
\v 15 İşte,\f + \fr 1:15 \ft “İşte”, “הִנֵּה” kelimesinden gelir ve bakmak, farkına varmak, gözlemlemek, görmek veya dik dik bakmak anlamına gelir. Genellikle bir ünlem olarak kullanılır.\f* güzelsin, sevgilim.
\q2 İşte, güzelsin.
\q2 Gözlerin güvercinler gibi.
\sp Sevgili
\q1 
\v 16 İşte, güzelsin, sevgilim, evet, hoşsun;
\q2 ve yatağımız yemyeşil.
\sp Seven
\q1 
\v 17 Evimizin kirişleri sedirlerdir.
\q2 Tavanlarımız köknarlardır.
\c 2
\sp Sevgili
\q1 
\v 1 Ben Şaron gülüyüm,
\q2 vadilerin zambağıyım.
\sp Seven
\q1 
\v 2 Dikenler arasında zambak nasılsa,
\q2 kızlar arasında sevgilim öyledir.
\sp Sevgili
\q1 
\v 3 Orman ağaçları arasında elma ağacı nasılsa,
\q2 oğlanlar arasında sevgilim öyledir.
\q1 Onun gölgesinde büyük bir zevkle oturdum,
\q2 meyvesi damağıma tatlı geldi.
\q1 
\v 4 Beni ziyafet salonuna götürdü.
\q2 Onun üzerimdeki sancağı sevgidir.
\q1 
\v 5 Beni kuru üzümle güçlendirin,
\q2 elmayla beni canlandırın;
\q2 çünkü ben aşktan bitkinim.
\q1 
\v 6 Sol eli başımın altında olsun.
\q2 Sağ eli beni kucaklasın.
\q1 
\v 7 Ey Yeruşalem kızları,
\q2 dişi ceylanlar ve kırın dişi geyikleri üzerine
\q2 size ant ettiriyorum ki,
\q2 sevgiyi ayıltmayın ve uyandırmayın,
\q2 ta ki o arzu edene kadar.
\q1 
\v 8 Sevgilimin sesi!
\q2 İşte geliyor,
\q2 dağların üzerinden sekerek,
\q2 tepelerin üzerinden sıçrayarak.
\q1 
\v 9 Sevgilim bir ceylan ya da geyik yavrusuna benzer.
\q2 İşte, duvarımızın arkasında duruyor!
\q1 Pencerelerden içeri bakıyor.
\q2 Kafeslerden bakış atıyor.
\q1 
\v 10 Sevgilim konuşup bana şöyle dedi,
\q2 “Sevgilim, güzelim, kalk da gel.”
\q1 
\v 11 “Çünkü işte, kış geçti.
\q2 Yağmurlar geçip gitti.
\q1 
\v 12 Yerde çiçekler görünüyor.
\q2 Ezgi söyleme zamanı geldi,
\q2 ve diyarımızda kumru sesi duyuldu.
\q1 
\v 13 İncir ağacı ham incirlerini yetiştirmekte.
\q2 Asmalar çiçek açtı.
\q2 Güzel kokular yaymaktalar.
\q1 Sevgilim, güzelim, kalk da gel.”
\sp Seven
\q1 
\v 14 Kaya kovuklarındaki,
\q2 dağ yamaçlarının gizli yerlerindeki güvercinim,
\q2 yüzünü bana göster.
\q2 Sesini bana duyur;
\q2 çünkü sesin tatlı, yüzün güzeldir.
\q1 
\v 15 Bizim için tilkileri,
\q2 bağları yağmalayan küçük tilkileri yakalayın;
\q2 çünkü bağlarımız çiçek açtı.
\sp Sevgili
\q1 
\v 16 Sevgilim benimdir, ben de onun.
\q2 Zambakların arasında gezinir.
\q1 
\v 17 Gün serinleyip gölgeler kaçıncaya dek,
\q2 dön, sevgilim,
\q2 yarılmış dağlar üzerinde ceylan ya da geyik yavrusu gibi ol.
\c 3
\p 
\v 1 Geceleyin yatağımın üzerinde,
\q2 onu, canımın sevdiğini aradım.
\q2 Aradım, ama onu bulamadım.
\q1 
\v 2 Şimdi kalkıp kenti dolaşayım;
\q2 sokaklarda ve meydanlarda
\q2 onu, canımın sevdiğini arayayım.
\q2 Aradım, ama onu bulamadım.
\q1 
\v 3 Kentte dolaşan bekçiler beni buldular;
\q2 “Onu, canımın sevdiğini gördünüz mü?”
\q1 
\v 4 Onlardan ayrılır ayrılmaz,
\q2 onu, canımın sevdiğini buldum.
\q1 Onu tuttum ve bırakmadım;
\q2 ta ki onu annemin evine,
\q2 bana gebe kalan kadının odasına götürene dek.
\q1 
\v 5 Ey Yeruşalem kızları,
\q2 dişi ceylanlar ve kırın dişi geyikleri üzerine
\q2 size ant ettiriyorum ki,
\q2 sevgiyi ayıltmayın ve uyandırmayın,
\q2 ta ki o arzu edene kadar.
\q1 
\v 6 Duman sütunları gibi çölden çıkan,
\q2 mür ve günlükle,
\q2 tüccarın bütün baharatlarıyla
\q2 kokulandırılmış olan bu kimdir?
\q1 
\v 7 İşte, Solomon'un arabası!
\q2 İsrael'in yiğitlerinden,
\q2 altmış yiğit onun çevresinde.
\q1 
\v 8 Hepsi kılıç kullanır ve savaşta ustadır.
\q2 Gecenin dehşetinden,
\q2 her birinin kılıcı belindedir.
\q1 
\v 9 Kral Solomon,
\q2 kendine Lübnan ağacından bir araba yaptı.
\q1 
\v 10 Sütunlarını gümüşten,
\q2 tabanını altından,
\q2 koltuğunu mordan yaptı,
\q2 içi Yeruşalem kızlarından sevgiyle döşendi.
\q1 
\v 11 Ey Siyon kızları, çıkın,
\q2 Kral Solomon'u, düğünü gününde,
\q2 yüreğinin sevinci gününde,
\q2 annesinin ona giydirdiği taçla görün.
\c 4
\p 
\v 1 Ah, ne güzelsin, sevgilim.
\q2 Ah, ne güzelsin.
\q1 Gözlerin peçenin ardındaki güvercinler gibi.
\q2 Saçların Gilad Dağı'ndan inen keçi sürüsü gibi.
\q1 
\v 2 Dişlerin yıkanmaktan çıkmış,
\q2 yeni kırkılmış bir sürüye benzer.
\q2 Her birinin ikizi var.
\q2 Aralarında yavrusuz olan yok.
\q1 
\v 3 Dudakların al iplik gibi.
\q2 Ağzın ne güzel.
\q2 Yanakların peçenin ardındaki nar parçası gibi.
\q1 
\v 4 Boynun David'in silah evi için yapılmış kulesine benzer,
\q2 üzerine bin kalkan asılmış,
\q2 hepsi yiğit kalkanları.
\q1 
\v 5 İki memen, sanki bir çift geyik yavrusu,
\q2 zambaklar arasında otlayan,
\q2 ikiz ceylan yavrusu.
\q1 
\v 6 Gün serinleyince, gölgeler kaçıp gidinceye dek,
\q2 mür dağına,
\q2 günnük tepesine gideceğim.
\q1 
\v 7 Tümüyle güzelsin, sevgilim.
\q2 Sende hiç kusur yok.
\q1 
\v 8 Lübnan'dan benimle gel,
\q2 ey gelinim, benimle Lübnan'dan.
\q2 Amana Tepesi'nden,
\q2 senir ve Hermon'un tepelerinden,
\q2 aslanların inlerinden,
\q2 parsların dağlarından bak.
\q1 
\v 9 Yüreğimi çaldın, kız kardeşim, gelinim.
\q2 Bir bakışınla, boynunun bir zinciriyle yüreğimi çaldın.
\q1 
\v 10 Sevgin ne kadar güzel, kız kardeşim, gelinim!
\q2 Sevgin şaraptan ne kadar daha hoş,
\q2 esansının kokusu her türlü baharattan daha güzel!
\q1 
\v 11 Ey gelinim, bal damlatır dudakların.
\q2 Balla süt dilinin altındadır.
\q2 Giysilerinin kokusu sanki Lübnan kokusu.
\q1 
\v 12 Kız kardeşim, gelinim, kapalı bir bahçedir;
\q2 kapalı bir kaynak, mühürlü bir pınardır.
\q1 
\v 13 Fidanların nar bahçesidir,
\q2 değerli meyvelerle, kına ve nardin fidanlarıyla,
\q1 
\v 14 nardin ve safran,
\q2 kamış ve tarçın, her türlü günnük ağacıyla,
\q2 mür ve öd ağacı, en iyisinden her çeşit baharatlarla,
\q1 
\v 15 Bahçelerin pınarı,
\q2 diri suların kuyusu,
\q2 Lübnan'dan akan dereler.
\sp Sevgili
\q1 
\v 16 Uyan, ey kuzey rüzgârı,
\q2 sen de gel, ey güney!
\q2 Bahçeme es de, onun baharatları aksın.
\q1 Sevgilim bahçesine gelsin,
\q2 ve değerli meyvelerini tatsın.
\c 5
\sp Sevgili
\q1 
\v 1 Bahçeme girdim, kız kardeşim, gelinim.
\q2 Baharatımla mürümü topladım;
\q2 balımla peteğimi yedim;
\q2 sütümle şarabımı içtim.
\sp Dostlar
\q1 Yiyin, ey dostlar! İçin, evet, bol bol için, ey sevgililer.
\sp Sevgili
\q1 
\v 2 Uyuyordum, ama yüreğim uyanıktı.
\q2 Kapıyı çalan sevgilimin sesi:
\q2 “Aç bana, kız kardeşim, aşkım, güvercinim, lekesizim;
\q2 çünkü başım çiyle dolu,
\q2 saçlarım da gecenin nemiyle.”
\q1 
\v 3 Entarimi çıkardım. Gerçekten giymeli miyim?
\q2 Ayaklarımı yıkadım. Gerçekten onları kirletmeli miyim?
\q1 
\v 4 Sevgilim elini sürgü deliğinden içeri uzattı.
\q2 Kalbim onun için çarpıyordu.
\q1 
\v 5 Sevgilime kapıyı açmak için kalktım.
\q2 Ellerimden mür damladı,
\q2 parmaklarımdan aktı,
\q2 sürgü tokmakları üzerine.
\q1 
\v 6 Sevgilime açtım;
\q2 ama sevgilim ayrılıp gitmişti.
\q1 O konuşurken ben kendimden geçmiştim.
\q2 Onu aradım, ama bulamadım.
\q2 Onu çağırdım, ama o yanıt vermedi.
\q1 
\v 7 Kentte dolaşan bekçiler beni buldular.
\q2 Beni dövdüler,
\q2 beni yaraladılar.
\q2 Sur bekçileri üzerimden şalımı alıp götürdüler.
\q1 
\v 8 Size ant içiriyorum, ey Yeruşalem kızları,
\q2 eğer sevgilimi bulursanız,
\q2 ona aşktan bitkin olduğumu söyleyin.
\sp Dostlar
\q1 
\v 9 Kadınların en güzeli,
\q2 senin sevgilin öteki sevgililerden nasıl daha iyidir?
\q2 Senin sevgilin öteki sevgililerden nasıl daha iyidir ki,
\q2 bize böyle ant içiriyorsun?
\sp Sevgili
\q1 
\v 10 Sevgilim beyaz ve kızıldır.
\q2 On binler arasında en iyisidir.
\q1 
\v 11 Başı en saf altına benzer.
\q2 Saçları gür, kuzgun gibi siyahtır.
\q1 
\v 12 Gözleri akarsu kenarındaki güvercinler gibidir,
\q2 sütle yıkanmış, mücevher gibi takılmış.
\q1 
\v 13 Yanakları güzel kokulu çiçeklik gibidir,
\q2 güzel kokular yığınlarıyla.
\q2 Dudakları zambaklar gibidir, mür yağı damlatır.
\q1 
\v 14 Elleri beril kakmalı altın yüzükler gibidir.
\q2 Gövdesi safirlerle kaplı fildişi işi gibidir.
\q1 
\v 15 Bacakları saf altın ayaklıklar üzerine yerleştirilmiş
\q2 mermer sütunlar gibidir.
\q2 Görünüşü Lübnan gibidir,
\q2 sedirler kadar harikadır.
\q1 
\v 16 Ağzı tatlıdır; evet, her yönüyle sevimlidir.
\q1 Bu benim sevgilimdir ve bu benim dostumdur,
\q2 ey Yeruşalem kızları.
\c 6
\sp Dostlar
\q1 
\v 1 Ey kadınların en güzeli, sevgilin nereye gitti?
\q2 Sevgilin nereye döndü ki, onu seninle birlikte arayalım?
\sp Sevgili
\q1 
\v 2 Bahçelerde sürüsünü otlatmak ve zambak toplamak için,
\q2 sevgilim bahçesine,
\q2 güzel kokulu çiçekliklerine indi.
\q1 
\v 3 Sevgilim benimdir, ben de sevgilimin.
\q2 Zambaklar arasında geziniyor.
\sp Seven
\q1 
\v 4 Sen güzelsin, sevgilim, Tirtsa kadar güzelsin,
\q2 Yeruşalem kadar sevimlisin,
\q2 sancak açmış bir ordu kadar muhteşemsin.
\q1 
\v 5 Gözlerini benden çevir,
\q2 çünkü onlar bana galip geldiler.
\q2 Saçların Gilad yamacında yatan keçi sürüsü gibi.
\q1 
\v 6 Dişlerin yıkanmaktan yeni çıkmış koyun sürüsü gibi,
\q2 her birinin ikizi var;
\q2 aralarında yavrularını yitiren yoktur.
\q1 
\v 7 Yanakların peçenin ardındaki nar parçası gibi.
\q1 
\v 8 Altmış kraliçe, seksen cariye,
\q2 ve sayısız el değmemiş kız var.
\q1 
\v 9 Kusursuz güvercinim, eşsizdir.
\q2 Annesinin biricik kızıdır.
\q2 Kendisini doğuranın gözdesidir.
\q1 Kızlar onu gördüler ve ona mutlu dediler.
\q2 Kraliçeler ve cariyeler onu gördüler ve onu övdüler.
\q1 
\v 10 Görünüşü sabah gibi,
\q2 ay kadar güzel, güneş kadar parlak,
\q2 ve sancak açmış ordu kadar muhteşem olan bu kadın kimdir?
\q1 
\v 11 Vadinin yeşil fidanlarını görmek,
\q2 asma tomurcuklandı mı, narlar çiçek açtı mı diye görmek için,
\q2 ceviz bahçesine indim.
\q1 
\v 12 Farkına varmadan,
\q2 arzum beni soylu halkımın arabalarıyla oturttu.
\sp Dostlar
\q1 
\v 13 Geri dön, geri dön, ey Şulamlı!
\q2 Geri dön, geri dön de sana bakalım.
\sp Seven
\q1 Neden Şulamlı'ya, Mahanaim dansına bakar gibi bakmak istiyorsun?
\c 7
\p 
\v 1 Sandaletler içinde ayakların ne güzel, ey bey kızı!
\q2 Yuvarlak kalçaların mücevher gibi,
\q2 usta ellerinin işi.
\q1 
\v 2 Vücudun yuvarlak bir kadeh gibi,
\q2 karışık şaraptan yoksun değil.
\q2 Belin zambaklarla süslenmiş bir buğday yığını gibi.
\q1 
\v 3 İki memen sanki bir çift geyik vayrusu,
\q2 ikiz ceylan yavrusu.
\q1 
\v 4 Boynun fildişi kulesine benzer.
\q2 Gözlerin Batrabbim Kapısı yanındaki Heşbon havuzları gibi.
\q2 Burnun Damaskus'a bakan Lübnan Kulesi gibi.
\q1 
\v 5 Üzerindeki başın Karmel gibi.
\q2 Başındaki saçlar mora çalıyor.
\q2 Kral senin kaküllerine tutsak oldu.
\q1 
\v 6 Zevkler için,
\q2 sen ne güzelsin, ne hoşsun, ey aşk!
\q1 
\v 7 Bu senin boyun palmiye ağacına benzer,
\q2 memelerin onun meyvesi gibi.
\q1 
\v 8 “Hurma ağacına çıkayım, meyvesini tutayım.” dedim.
\q1 Memelerin asma salkımları gibi olsun,
\q2 soluğunun kokusu da elma gibi.
\q1 
\v 9 Ağzın en iyi şarap gibi,
\q2 sevgilim için kolayca akan,
\q2 uyuyanların dudaklarından kayan.
\sp Sevgili
\q1 
\v 10 Ben sevgiliminim.
\q2 Onun arzusu banadır.
\q1 
\v 11 Gel, sevgilim! Kıra çıkalım.
\q2 Köylerde geceleyelim.
\q1 
\v 12 Sabahleyin erkenden bağlara çıkalım.
\q2 Asma tomurcuk verdi mi,
\q2 çiçeği açtı mı,
\q2 narlar çiçeklendi mi görelim.
\q2 Orada sana sevgimi vereceğim.
\q1 
\v 13 Adamotları hoş koku saçıyor.
\q2 Kapılarımızın önünde
\q2 Taze ve kuru her çeşit değerli meyve var,
\q2 onları senin için sakladım, ey sevgilim.
\c 8
\p 
\v 1 Ah, keşke sen annemin memelerinden süt emmiş kardeşim gibi olsaydın!
\q2 Seni dışarıda bulsam, öperdim;
\q2 kimse de beni kınamazdı.
\q1 
\v 2 Sana yol gösterir,
\q2 beni eğiten annemin evine götürürdüm.
\q2 Sana baharatlı şaraptan,
\q2 narımın suyundan içirirdim.
\q1 
\v 3 Sol eli başımın altında olurdu.
\q2 Sağ eli beni kucaklardı.
\q1 
\v 4 Size ant içiriyorum, ey Yeruşalem kızları,
\q2 sevgiyi ayıltmayasınız, uyandırmayasınız diye,
\q2 ta ki öyle arzu edene kadar.
\sp Dostlar
\q1 
\v 5 Sevgilisine yaslanarak çölden çıkan bu kimdir?
\sp Sevgili,
\q1 Elma ağacının altında seni uyandırdım.
\q2 Orada annen sana gebe kaldı.
\q2 Orada doğum sancıları çekti ve seni doğurdu.
\q1 
\v 6 Beni yüreğine bir mühür,
\q2 kolunun üzerine bir mühür gibi koy;
\q2 çünkü sevgi ölüm kadar güçlüdür.
\q2 Kıskançlık Şeol\f + \fr 8:6 \ft Şeol ölüler diyarıdır. \f* kadar zalimdir.
\q2 Onun ışıltıları ateş ışıltılarıdır,
\q2 Yah'ın\f + \fr 8:6 \ft “Yah”, Tanrı’nın özel ismi olan “Yahve”nin kısaltılmış halidir ve diğer çevirilerde bazen “RAB=EFENDİ” (tamamı büyük harfle) olarak çevrilir.\f* gerçek alevidir.
\q1 
\v 7 Büyük sular sevgiyi söndüremez,
\q2 seller de onu boğamaz.
\q1 Bir adam sevgisi için evinin bütün servetini verse,
\q2 tümüyle hor görülür.
\sp Kardeşler
\q1 
\v 8 Küçük bir kız kardeşimiz var.
\q2 Onun daha memeleri yok.
\q2 Onun için söz söyleneceği gün,
\q2 kız kardeşimiz için ne yapacağız?
\q1 
\v 9 Eğer o bir duvarsa,
\q2 üzerine gümüş bir kule yaparız.
\q2 Eğer bir kapıysa,
\q2 onu sedir tahtalarıyla kapatırız.
\sp Sevgili
\q1 
\v 10 Ben bir duvarım, memelerim de kuleler gibi,
\q2 o zaman onun gözünde esenlik bulan biri gibi oldum.
\q1 
\v 11 Solomon'un Baal Hamon'da bir bağı vardı.
\q2 Bağı tutanlara kiraladı.
\q2 Her biri ürünü için bin şekel\f + \fr 8:11 \ft Bir şekel yaklaşık 10 gram veya 0,35 onstur, dolayısıyla 1000 şekel yaklaşık 10 kilogram veya 22 pounddur.\f* gümüş getirirdi.
\q1 
\v 12 Benim kendi bağım önümdedir.
\q2 Bini senin olsun, ey Solomon,
\q2 iki yüzü de ürününe bakanların olsun.
\sp Seven
\q1 
\v 13 Bahçelerde oturan,
\q2 dostlarınla birlikte hazır bulunan ey sen,
\q2 sesini duyur bana!
\sp Sevgili
\q1 
\v 14 Kaç gel, sevgilim!
\q2 Hoş kokulu dağların üzerinde,
\q2 bir ceylan gibi, ya da geyik yavrusu gibi ol! 
