\p Mientras \w hablaba|strong="H1697"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w*, \w los|strong="H5921"\w* servidores \w cubrieron|strong="H2645"\w* \w el|strong="H5921"\w* \w rostro|strong="H6440"\w* \w de|strong="H5921"\w* \w Amán|strong="H2001"\w*.
